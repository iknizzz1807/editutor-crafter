direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # eBPF Tracer: Complete System Data Flow
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_space: {
    direction: down
    label: "KERNEL SPACE"
    style.fill: "#E8F4EA"
    style.stroke: "#2E7D32"
    syscall_layer: {
      label: "Syscall Layer"
      style.fill: "#C8E6C9"
      sys_read: "sys_read()"
      sys_write: "sys_write()"
      sys_openat: "sys_openat()"
    }
    tcp_stack: {
      label: "TCP Stack"
      style.fill: "#C8E6C9"
      tcp_connect: "tcp_connect()"
      tcp_state: "tcp_set_state()"
      tcp_close: "tcp_close()"
    }
    scheduler: {
      label: "Scheduler"
      style.fill: "#C8E6C9"
      sched_switch: "sched_switch"
      sched_process: "sched_process_fork"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ebpf_programs: {
    direction: down
    label: "eBPF PROGRAMS"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    kprobe_handlers: {
      label: "Kprobe Handlers"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      kp_read_entry: {
        label: "kprobe/read_entry"
        width: 140
      }
      kp_read_exit: {
        label: "kretprobe/read_exit"
        width: 140
      }
      kp_write_entry: {
        label: "kprobe/write_entry"
        width: 140
      }
      kp_write_exit: {
        label: "kretprobe/write_exit"
        width: 140
      }
    }
    tracepoint_handlers: {
      label: "Tracepoint Handlers"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      tp_tcp_state: {
        label: "tp/inet_sock_set_state"
        width: 160
      }
      tp_sched: {
        label: "tp/sched_switch"
        width: 160
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bpf_maps: {
    direction: down
    label: "BPF MAPS"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    hash_maps: {
      label: "Hash Maps (Correlation)"
      style.fill: "#BBDEFB"
      start_times: {
        shape: sql_table
        label: "start_times (u32 → u64)"
        f0: "key | u32 | thread_id"
        f1: "value | u64 | timestamp_ns"
        sz: "max_entries: 10240"
      }
      conn_track: {
        shape: sql_table
        label: "connections (u64 → conn_info)"
        f0: "key | u64 | socket_ptr"
        f1: "value | struct | conn_info"
        sz: "max_entries: 65536"
      }
    }
    percpu_arrays: {
      label: "Per-CPU Arrays (Aggregation)"
      style.fill: "#BBDEFB"
      latency_hist: {
        shape: sql_table
        label: "syscall_histograms (PERCPU)"
        f0: "key | u32 | syscall_nr * 64 + bucket"
        f1: "value | u64[ncpu] | counts"
        sz: "512 * 64 buckets"
      }
      proc_stats: {
        shape: sql_table
        label: "proc_stats_map (HASH)"
        f0: "key | u32 | pid"
        f1: "value | struct | cpu_time, ctxsw"
        sz: "max_entries: 1024"
      }
    }
    ring_buffer: {
      label: "Ring Buffer (Events)"
      style.fill: "#BBDEFB"
      events_rb: {
        shape: cylinder
        label: "events (16 MB)"
        width: 120
      }
    }
    config_map: {
      label: "Config Map (Runtime)"
      style.fill: "#BBDEFB"
      config: {
        shape: sql_table
        label: "config (ARRAY)"
        f0: "key | u32 | tracer_id"
        f1: "value | u32 | enabled (0/1)"
        sz: "4 tracers"
      }
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  userspace: {
    direction: down
    label: "USERSPACE"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    consumers: {
      label: "Data Consumers"
      style.fill: "#E1BEE7"
      histogram_agg: {
        label: "Histogram Aggregator"
        code: |'c
          // Sum per-CPU values
          for (i = 0; i < num_cpus; i++)
            total += values[i];
        '|
        width: 200
      }
      event_handler: {
        label: "Event Handler"
        code: |'c
          // ring_buffer__consume()
          // Parse TCP events
          // Update connection list
        '|
        width: 200
      }
      proc_agg: {
        label: "Process Aggregator"
        code: |'c
          // Iterate proc_stats_map
          // Sort by CPU time
          // Build top-N list
        '|
        width: 200
      }
    }
    poller: {
      label: "Event Loop (epoll)"
      style.fill: "#E1BEE7"
      epoll: {
        shape: class
        label: "Poller"
        -timer_fd: "int"
        -ringbuf_fd: "int"
        -epoll_fd: "int"
        +poll(timeout_ms): "int"
        +on_timer(): "void"
        +on_ringbuf(): "void"
      }
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dashboard: {
    direction: down
    label: "TERMINAL DASHBOARD"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    ui_sections: {
      label: "UI Sections (1 Hz refresh)"
      style.fill: "#FFCDD2"
      syscall_panel: {
        label: "Syscall Latency"
        code: |md
          read (n=45,231)
            0-1us  ████████  27.3%
            1-2us  ██████████  34.7%
          p99: 15us
        |
        width: 220
      }
      tcp_panel: {
        label: "TCP Connections"
        code: |md
          PID   COMM    STATE
          1234  nginx   ESTAB
          5678  mysql   ESTAB
          Active: 23
        |
        width: 220
      }
      proc_panel: {
        label: "Top Processes"
        code: |md
          PID   COMM    CPU%
          1234  nginx   12.3%
          5678  mysql   8.7%
          ctxsw/s: 1,234
        |
        width: 220
      }
    }
    controls: {
      label: "Controls"
      style.fill: "#FFCDD2"
      ctrl_panel: |md
        [q] Quit  [p] Toggle Probes
        [f] Filter  [r] Reset  [1-3] Sources
      |
    }
  }
}
kernel_space.syscall_layer.sys_read -> ebpf_programs.kprobe_handlers.kp_read_entry: "entry" {style.stroke: "#4CAF50"}
kernel_space.syscall_layer.sys_read -> ebpf_programs.kprobe_handlers.kp_read_exit: "exit" {style.stroke: "#4CAF50"; style.stroke-dash: 4}
kernel_space.syscall_layer.sys_write -> ebpf_programs.kprobe_handlers.kp_write_entry: "entry" {style.stroke: "#4CAF50"}
kernel_space.syscall_layer.sys_write -> ebpf_programs.kprobe_handlers.kp_write_exit: "exit" {style.stroke: "#4CAF50"; style.stroke-dash: 4}
kernel_space.syscall_layer.sys_openat -> ebpf_programs.kprobe_handlers.kp_read_entry: "entry" {style.stroke: "#4CAF50"}
kernel_space.tcp_stack.tcp_state -> ebpf_programs.tracepoint_handlers.tp_tcp_state: "tracepoint" {style.stroke: "#2196F3"}
kernel_space.scheduler.sched_switch -> ebpf_programs.tracepoint_handlers.tp_sched: "tracepoint" {style.stroke: "#2196F3"}
ebpf_programs.kprobe_handlers.kp_read_entry -> bpf_maps.hash_maps.start_times: "bpf_map_update_elem" {style.stroke: "#FF9800"}
ebpf_programs.kprobe_handlers.kp_read_exit -> bpf_maps.hash_maps.start_times: "bpf_map_lookup_elem" {style.stroke: "#FF9800"; style.stroke-dash: 4}
ebpf_programs.kprobe_handlers.kp_read_exit -> bpf_maps.percpu_arrays.latency_hist: "(*bucket)++" {style.stroke: "#FF9800"}
ebpf_programs.tracepoint_handlers.tp_tcp_state -> bpf_maps.hash_maps.conn_track: "ESTABLISHED\nstore ts" {style.stroke: "#FF9800"}
ebpf_programs.tracepoint_handlers.tp_tcp_state -> bpf_maps.ring_buffer.events_rb: "TIME_WAIT\nevent" {style.stroke: "#FF9800"}
ebpf_programs.tracepoint_handlers.tp_sched -> bpf_maps.percpu_arrays.proc_stats: "update stats" {style.stroke: "#FF9800"}
bpf_maps.percpu_arrays.latency_hist -> userspace.consumers.histogram_agg: "bpf_map_lookup_elem\n(sum per-CPU)" {style.stroke: "#9C27B0"}
bpf_maps.ring_buffer.events_rb -> userspace.consumers.event_handler: "ring_buffer__consume" {style.stroke: "#9C27B0"}
bpf_maps.percpu_arrays.proc_stats -> userspace.consumers.proc_agg: "bpf_map_lookup_elem\n(iterate)" {style.stroke: "#9C27B0"}
userspace.consumers.histogram_agg -> userspace.poller.epoll: "on_timer" {style.stroke: "#7B1FA2"}
userspace.consumers.event_handler -> userspace.poller.epoll: "on_ringbuf" {style.stroke: "#7B1FA2"}
userspace.consumers.proc_agg -> userspace.poller.epoll: "on_timer" {style.stroke: "#7B1FA2"}
userspace.poller.epoll -> dashboard.ui_sections.syscall_panel: "draw_histogram" {style.stroke: "#F44336"}
userspace.poller.epoll -> dashboard.ui_sections.tcp_panel: "draw_connections" {style.stroke: "#F44336"}
userspace.poller.epoll -> dashboard.ui_sections.proc_panel: "draw_top_procs" {style.stroke: "#F44336"}
dashboard.controls -> bpf_maps.config_map.config: "runtime filter\nbpf_map_update_elem" {style.stroke: "#F44336"; style.stroke-dash: 4}
bpf_maps.config_map.config -> ebpf_programs.kprobe_handlers.kp_read_entry: "check enabled" {style.stroke: "#607D8B"; style.stroke-dash: 3}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: "Data Flow Legend"
  l2: "─── Event/Trigger"
  l3: "- - - Config/Lookup"
  l4: ""
  l5: "Colors:"
  l6: "Green = Kernel events"
  l7: "Orange = eBPF → Maps"
  l8: "Purple = Maps → Userspace"
  l9: "Red = Userspace → Display"
  l10: "Gray = Runtime config"
}