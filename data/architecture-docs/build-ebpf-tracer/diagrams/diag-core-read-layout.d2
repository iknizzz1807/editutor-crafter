direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "CO-RE: Compile Once, Run Everywhere" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_label: "BEFORE: Hardcoded Offsets" {
    shape: text
    style: {
      font-size: 20
      bold: true
      font-color: "#C0392B"
    }
  }
}
kernel_5_4_old: {
  label: "struct inode (kernel 5.4)"
  shape: sql_table
  f0: "0x00 | umode_t     | i_mode"
  f1: "0x04 | kuid_t      | i_uid"
  f2: "0x08 | kgid_t      | i_gid"
  f3: "0x10 | loff_t      | i_size"
  f4: "0x18 | struct *    | i_op"
  note: "Offsets hardcoded in eBPF bytecode"
}
bad_code: {
  label: "eBPF Program (BROKEN)"
  width: 380
  code: |'c
    // Hardcoded offset - works on 5.4 only!
    struct inode *ino = ...;
    u64 *size_ptr = (u64 *)((char *)ino + 0x10);
    u64 size = *size_ptr;  // DANGER!
  '|
}
kernel_5_15_old: {
  label: "struct inode (kernel 5.15)"
  shape: sql_table
  f0: "0x00 | spinlock_t  | i_lock"
  f1: "0x10 | umode_t     | i_mode"
  f2: "0x14 | kuid_t      | i_uid"
  f3: "0x18 | kgid_t      | i_gid"
  f4: "0x20 | loff_t      | i_size"
  note: "Fields shifted! i_size now at 0x20"
}
kernel_5_4_old -> bad_code: "compiled on"
bad_code -> kernel_5_15_old: "runs on" {
  label: "❌ WRONG DATA\nReads i_op as i_size!"
  style: {
    stroke: "#C0392B"
    stroke-width: 3
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after_label: "AFTER: CO-RE Relocations" {
    shape: text
    style: {
      font-size: 20
      bold: true
      font-color: "#27AE60"
    }
  }
}
btf_section: {
  label: "BTF + Relocation Records"
  direction: right
  width: 400
  btf_data: {
    label: "vmlinux.btf (embedded)"
    shape: class
    +types: "struct definitions"
    +offsets: "field locations"
    +members: "member names"
  }
  reloc: {
    label: "Relocation Records"
    shape: class
    +rec1: "BPF_CORE_READ(inode, i_size)"
    +rec2: "\"field i_size in struct inode\""
    +rec3: "\"not offset 0x10\""
  }
}
btf_data -> reloc: "references"
good_code: {
  label: "eBPF Program (PORTABLE)"
  width: 380
  code: |'c
    // CO-RE read - offset resolved at load!
    struct inode *ino = ...;
    u64 size = BPF_CORE_READ(ino, i_size);
    // Macro expands to relocation record
    // libbpf patches correct offset at load
  '|
}
kernel_5_4_new: {
  label: "struct inode (kernel 5.4)"
  shape: sql_table
  f0: "0x00 | umode_t     | i_mode"
  f1: "0x04 | kuid_t      | i_uid"
  f2: "0x08 | kgid_t      | i_gid"
  f3: "0x10 | loff_t      | i_size"
  f4: "0x18 | struct *    | i_op"
  note: "i_size at 0x10"
}
kernel_5_15_new: {
  label: "struct inode (kernel 5.15)"
  shape: sql_table
  f0: "0x00 | spinlock_t  | i_lock"
  f1: "0x10 | umode_t     | i_mode"
  f2: "0x14 | kuid_t      | i_uid"
  f3: "0x18 | kgid_t      | i_gid"
  f4: "0x20 | loff_t      | i_size"
  note: "i_size at 0x20 - different!"
}
libbpf: {
  label: "libbpf (load time)"
  shape: class
  -btf: "kernel BTF from /sys/kernel/btf/vmlinux"
  +resolve: "match field names to kernel offsets"
  +patch: "rewrite bytecode with correct offset"
}
good_code -> libbpf: "relocation records"
libbpf -> kernel_5_4_new: "patch offset=0x10" {
  label: "kernel 5.4"
  style.stroke: "#27AE60"
}
libbpf -> kernel_5_15_new: "patch offset=0x20" {
  label: "kernel 5.15"
  style.stroke: "#27AE60"
}
kernel_5_4_new <- good_code: "✓ Correct" {
  style: {
    stroke: "#27AE60"
    stroke-width: 2
  }
}
kernel_5_15_new <- good_code: "✓ Correct" {
  style: {
    stroke: "#27AE60"
    stroke-width: 2
  }
}
flow_note: {
  near: bottom-center
  content: |md
    **Key Insight**: With CO-RE, you compile *once* and the bytecode contains **field names**, not **offsets**.
    At load time, libbpf reads your kernel's BTF, finds the actual offset of `i_size` in `struct inode`,
    and patches the bytecode. Same `.o` file works on any kernel with BTF support.
  |
}
row_before -> row_after: "Fix with CO-RE" {
  style: {
    stroke: "#3498DB"
    stroke-width: 2
    stroke-dash: 4
  }
}