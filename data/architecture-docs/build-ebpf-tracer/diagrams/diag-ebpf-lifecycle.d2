direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # eBPF Program Lifecycle
    **Compile → Verify → Load → Attach**
  |
  near: top-center
  shape: text
  style.font-size: 28
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1_compile: {
    direction: down
    label: "1. COMPILE (Userspace)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    c_source: {
      label: "C Source (program.bpf.c)"
      shape: rectangle
      width: 250
      code: |'c
        #include <linux/bpf.h>
        SEC("kprobe/do_sys_open")
        int trace_open(struct pt_regs *ctx) {
          struct event *e = bpf_ringbuf_reserve(&rb, sizeof(*e), 0);
          if (!e) return 0;
          bpf_ringbuf_submit(e, 0);
          return 0;
        }
      '|
      style.fill: "#1E1E1E"
      style.font-color: "#D4D4D4"
      style.font: mono
    }

    clang_box: {
      label: "Compiler: Clang/LLVM"
      shape: rectangle
      width: 250
      row1: "Target: -target bpf"
      row2: "Debug: -g (BTF Generation)"
      row3: "Opt: -O2 (Required for BPF)"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }

    btf_data: {
      shape: sql_table
      label: "BTF (.BTF Section)"
      f1: "Type Information"
      f2: "CO-RE Relocations"
      note: "Enables 'Write Once Run Everywhere'"
      style.fill: "#E1F5FE"
    }

    c_source -> clang_box: "cc"
    clang_box -> btf_data: "emits"
  }

  step2_verify: {
    direction: down
    label: "2. VERIFY (Kernel Runtime)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2

    bytecode_in: {
      label: "BPF Bytecode Instruction Stream"
      shape: rectangle
      width: 220
      code: |'
        0: (bf) r6 = r1
        1: (85) call bpf_get_current_pid_tgid
        2: (77) r0 >>= 32
        3: (63) *(u32 *)(r10 -8) = r0
        4: (bf) r1 = r10
        5: (07) r1 += -8
      '|
      style.fill: "#263238"
      style.font-color: "#80CBC4"
      style.font: mono
      style.font-size: 11
    }

    verifier: {
      label: "IN-KERNEL VERIFIER"
      shape: diamond
      width: 180
      height: 120
      style.fill: "#F44336"
      style.font-color: white
      style.bold: true
      style.stroke: "#B71C1C"
      style.stroke-width: 3
    }

    v_logic: {
      shape: sql_table
      label: "Verification Checks"
      c1: "✓ No Unbounded Loops"
      c2: "✓ Safe Memory Access"
      c3: "✓ Valid Helper Calls"
      c4: "✓ Register State Tracking"
      style.fill: "#FFFFFF"
    }

    results: {
      direction: right
      style.stroke: transparent
      accept: {
        label: "✓ PASS"
        style.fill: "#4CAF50"
        style.font-color: white
        style.bold: true
      }
      reject: {
        label: "✗ FAIL"
        style.fill: "#D32F2F"
        style.font-color: white
        style.bold: true
      }
    }

    bytecode_in -> verifier: "Analysis"
    verifier -> results: "Verdict"
    verifier -> v_logic: {style.stroke-dash: 3}
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step3_load: {
    direction: down
    label: "3. LOAD (JIT Compilation)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    syscall_bpf: {
      label: "syscall: bpf(BPF_PROG_LOAD)"
      shape: rectangle
      width: 200
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
    }

    jit_engine: {
      label: "JIT COMPILER"
      shape: rectangle
      width: 200
      style.fill: "#90CAF9"
      style.bold: true
      note: "Translates Bytecode to Arch-Specific ASM"
    }

    native_code: {
      label: "x86_64 Native Machine Code"
      shape: rectangle
      width: 200
      code: |'
        55              push rbp
        48 89 e5        mov rbp, rsp
        48 83 ec 10     sub rsp, 16
        48 89 7d f8     mov [rbp-8], rdi
        bf 01 00 00 00  mov edi, 1
      '|
      style.fill: "#1565C0"
      style.font-color: white
      style.font: mono
      style.font-size: 10
    }

    syscall_bpf -> jit_engine: "Verified Bytecode"
    jit_engine -> native_code: "Generate"
  }

  step4_attach: {
    direction: down
    label: "4. ATTACH (Event Binding)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2

    attach_call: {
      label: "libbpf: bpf_program__attach()"
      shape: rectangle
      width: 220
      code: |'c
        struct bpf_link *link;
        link = bpf_program__attach(prog);
        if (!link) {
          fprintf(stderr, "Attach failed\n");
        }
      '|
      style.fill: "#E1BEE7"
      style.font: mono
      style.font-size: 11
    }

    hooks: {
      label: "Kernel Hook Points"
      kprobe: "kprobe/do_sys_open"
      tracepoint: "tp/syscalls/sys_enter_openat"
      uprobe: "uprobe/bin/bash:readline"
      style.fill: "#F8BBD0"
    }

    active_state: {
      label: "🟢 PROGRAM RUNNING"
      shape: rectangle
      width: 200
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
      style.shadow: true
    }

    attach_call -> hooks: "Bind FD to Event"
    hooks -> active_state: "Execution Flow Live"
  }
}

# Cross-Step Flow
step1_compile.clang_box -> step2_verify.bytecode_in: "ELF (.o) | Bytecode" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  style.animated: true
}

step2_verify.results.accept -> step3_load.syscall_bpf: "Safety Guaranteed" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  style.animated: true
}

step3_load.native_code -> step4_attach.attach_call: "Prog FD" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.animated: true
}

# Documentation & Metadata
legend: {
  shape: sql_table
  label: "Diagram Legend"
  item1: "Green Path: Success Lifecycle"
  item2: "Red Path: Safety Rejection"
  item3: "Kernel Space: Verification/JIT/Execution"
  item4: "User Space: Compilation/Loading"
}
legend.near: bottom-right

verifier_note: {
  label: "Verifier Architecture"
  row1: "State: Path-pruning abstract interpretation"
  row2: "Limit: Max 1 million instructions"
  row3: "Safety: Proves zero out-of-bounds"
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#EF5350"
  style.stroke-dash: 2
}
verifier_note.near: top-right