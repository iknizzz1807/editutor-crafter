direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "IPv4/IPv6 Dual-Stack Address Extraction"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  socket_struct: {
    label: "struct sock (kernel)"
    shape: sql_table
    f0: "0x00 | void *         | sk_state"
    f1: "0x08 | __u32          | sk_priority"
    f2: "0x0C | sa_family_t    | sk_family"
    f3: "0x10 | __be16         | sk_num (sport)"
    f4: "0x12 | __be16         | sk_dport"
    f5: "0x18 | struct sock *  | sk_bind_node"
    f6: "0x20 | addr[16]       | sk_v6_rcv_saddr"
    f7: "0x30 | addr[16]       | sk_v6_daddr"
    note: "Address family determines interpretation"
  }
  tracepoint_ctx: {
    label: "Tracepoint Context"
    shape: sql_table
    t0: "0x00 | const void * | skaddr"
    t1: "0x08 | int          | oldstate"
    t2: "0x0C | int          | newstate"
    t3: "0x10 | __u16        | sport"
    t4: "0x12 | __u16        | dport"
    t5: "0x14 | __u16        | family"
    t6: "0x18 | __u8[16]     | saddr"
    t7: "0x28 | __u8[16]     | daddr"
    note: "inet_sock_set_state args"
  }
}
family_check: {
  label: "Address Family Check"
  width: 400
  code: |'c
    __u16 family = BPF_CORE_READ(args, family);
    if (family == AF_INET) {      // family == 2
        // IPv4: only first 4 bytes valid
        bpf_probe_read_kernel(saddr, 4, &args->saddr);
        bpf_probe_read_kernel(daddr, 4, &args->daddr);
    } else if (family == AF_INET6) { // family == 10
        // IPv6: all 16 bytes valid
        bpf_probe_read_kernel(saddr, 16, &args->saddr);
        bpf_probe_read_kernel(daddr, 16, &args->daddr);
    }
  '|
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  ipv4_layout: {
    label: "AF_INET (family=2)"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    ipv4_saddr: {
      label: "saddr[16] buffer"
      shape: sql_table
      style.fill: "#C8E6C9"
      v4b0: "0x00 | __u8[4] | IPv4 address (VALID)"
      v4b1: "0x04 | __u8[4] | undefined/garbage"
      v4b2: "0x08 | __u8[4] | undefined/garbage"
      v4b3: "0x0C | __u8[4] | undefined/garbage"
      v4note: "Read ONLY bytes 0-3"
    }
    ipv4_example: {
      label: "Example: 192.168.1.100"
      shape: sql_table
      style.fill: "#A5D6A7"
      ex0: "Byte 0 | 0xC0 | 192"
      ex1: "Byte 1 | 0xA8 | 168"
      ex2: "Byte 2 | 0x01 | 1"
      ex3: "Byte 3 | 0x64 | 100"
    }
  }
  ipv6_layout: {
    label: "AF_INET6 (family=10)"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    ipv6_saddr: {
      label: "saddr[16] buffer"
      shape: sql_table
      style.fill: "#BBDEFB"
      v6b0: "0x00 | __u8[16] | Full IPv6 address (VALID)"
      v6note: "Read ALL 16 bytes"
    }
    ipv6_example: {
      label: "Example: 2001:db8::1"
      shape: sql_table
      style.fill: "#90CAF9"
      v6ex0: "Bytes 0-3  | 0x20010db8"
      v6ex1: "Bytes 4-7  | 0x00000000"
      v6ex2: "Bytes 8-11 | 0x00000000"
      v6ex3: "Bytes 12-15| 0x00000001"
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  mapped_ipv4: {
    label: "IPv4-Mapped IPv6 (::ffff:a.b.c.d)"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    mapped_layout: {
      label: "Special Case Layout"
      shape: sql_table
      style.fill: "#FFE0B2"
      m0: "Bytes 0-9   | 0x00...00 (10 zeros)"
      m1: "Bytes 10-11 | 0xFF 0xFF"
      m2: "Bytes 12-15 | IPv4 address"
      mnote: "Handle in userspace or detect"
    }
  }
  common_trap: {
    label: "Common Pitfall"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    trap_code: {
      label: "WRONG: Always read 16 bytes"
      width: 380
      code: |'c
        // DANGER: For AF_INET, bytes 4-15
        // contain garbage from kernel memory
        __u8 addr[16];
        bpf_probe_read_kernel(addr, 16, 
                              &args->saddr);
        // inet_ntop() will produce wrong output!
      '|
    }
  }
}
socket_struct -> tracepoint_ctx: "tracepoint\nprovides" {
  style.stroke-dash: 3
  style.stroke: "#666"
}
tracepoint_ctx -> family_check: "family field\ndrives dispatch" {
  style.stroke: "#1565C0"
  style.bold: true
}
family_check -> ipv4_layout: "AF_INET (2)" {
  style.stroke: "#4CAF50"
  style.bold: true
}
family_check -> ipv6_layout: "AF_INET6 (10)" {
  style.stroke: "#2196F3"
  style.bold: true
}
ipv4_layout -> mapped_ipv4: "may appear as\nmapped format" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#999"
  l1: {
    label: "AF_INET  = 2  (IPv4)"
    shape: text
    style.font-color: "#4CAF50"
  }
  l2: {
    label: "AF_INET6 = 10 (IPv6)"
    shape: text
    style.font-color: "#2196F3"
  }
  l3: {
    label: "Read size: 4 bytes vs 16 bytes"
    shape: text
  }
}