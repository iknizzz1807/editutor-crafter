direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Kprobe vs Tracepoint: Stability Across Kernel Versions" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kprobe_before: {
    direction: down
    label: "KPROBE APPROACH"
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"
    ebpf_k1: {
      label: "eBPF Program\n(trace_open.bpf.c)"
      style.fill: "#C8E6C9"
      code_k1: |'c
SEC("kprobe/tcp_set_state")
int trace_tcp(void *ctx) {
    // Assumes function exists
    // with specific signature
}
      '|
    }
    arrow_k1: {
      label: "attaches to"
      shape: text
    }
    kernel_5_10: {
      label: "Kernel 5.10"
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      func_5_10: {
        label: "tcp_set_state(sk, state)"
        shape: code
        style.fill: "#FFE0B2"
      }
    }
    status_k1: {
      label: "✓ WORKS"
      shape: text
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    ebpf_k1 -> kernel_5_10: "kprobe\nhook"
  }
  tracepoint_before: {
    direction: down
    label: "TRACEPOINT APPROACH"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    ebpf_t1: {
      label: "eBPF Program\n(trace_tcp.bpf.c)"
      style.fill: "#BBDEFB"
      code_t1: |'c
SEC("tracepoint/sock/inet_sock_set_state")
int trace_tcp(void *ctx) {
    struct trace_event_raw_inet_sock_set_state *args = ctx;
    // Access via stable struct
}
      '|
    }
    arrow_t1: {
      label: "subscribes to"
      shape: text
    }
    kernel_5_10_t: {
      label: "Kernel 5.10"
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      tp_5_10: {
        label: "tracepoint: inet_sock_set_state\n├─ skaddr (void*)\n├─ oldstate (int)\n├─ newstate (int)\n├─ sport, dport (u16)\n└─ saddr, daddr (u8[16])"
        shape: rectangle
        style.fill: "#FFECB3"
      }
    }
    status_t1: {
      label: "✓ WORKS"
      shape: text
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    ebpf_t1 -> kernel_5_10_t: "tracepoint\nsubscription"
  }
}
upgrade_arrow: {
  label: "⬇️ KERNEL UPGRADE (5.10 → 5.19) ⬇️"
  shape: text
  style: {
    font-size: 20
    bold: true
    font-color: "#D32F2F"
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kprobe_after: {
    direction: down
    label: "KPROBE APPROACH"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    ebpf_k2: {
      label: "eBPF Program\n(UNCHANGED)"
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      code_k2: |'c
SEC("kprobe/tcp_set_state")
int trace_tcp(void *ctx) {
    // Still looking for
    // tcp_set_state()...
}
      '|
    }
    kernel_5_19: {
      label: "Kernel 5.19"
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      func_5_19: {
        label: "__tcp_set_state(sk, state, fast_path)\n└─ Note: renamed + new param!"
        shape: code
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
      }
    }
    status_k2: {
      label: "✗ BROKEN"
      shape: text
      style.fill: "#D32F2F"
      style.font-color: white
      style.bold: true
    }
    broken_arrow: {
      label: "kprobe\nMISSING"
      shape: text
      style.font-color: "#D32F2F"
    }
    ebpf_k2 -> broken_arrow
    broken_arrow -> kernel_5_19: {
      style.stroke-dash: 4
      style.stroke: "#D32F2F"
    }
  }
  tracepoint_after: {
    direction: down
    label: "TRACEPOINT APPROACH"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    ebpf_t2: {
      label: "eBPF Program\n(UNCHANGED)"
      style.fill: "#C8E6C9"
      code_t2: |'c
SEC("tracepoint/sock/inet_sock_set_state")
int trace_tcp(void *ctx) {
    // Same struct layout
    // Kernel maintains ABI
}
      '|
    }
    kernel_5_19_t: {
      label: "Kernel 5.19"
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      tp_5_19: {
        label: "tracepoint: inet_sock_set_state\n├─ skaddr (void*)\n├─ oldstate (int)\n├─ newstate (int)\n├─ sport, dport (u16)\n└─ saddr, daddr (u8[16])\n\n└─ SAME STABLE ABI"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
    }
    status_t2: {
      label: "✓ WORKS"
      shape: text
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    ebpf_t2 -> kernel_5_19_t: "tracepoint\nsubscription"
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: "🔴 Kprobe: Hooks internal function\n    → Fragile, breaks on rename/refactor"
  l2: "🟢 Tracepoint: Stable ABI contract\n    → Kernel developers maintain compatibility"
}