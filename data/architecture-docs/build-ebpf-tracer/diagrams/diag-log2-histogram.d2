direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Log2 Histogram: Bucket Distribution for Syscall Latency
| {near: top-center}
header_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scale_info: {
    label: "Latency Scale\n(6 orders of magnitude)"
    width: 180
    style.fill: "#E8F4FD"
    style.stroke: "#4A90D9"
    scale_note: |md
      100ns → 1μs → 10μs → 100μs → 1ms → 10ms → 100ms → 1s
    |
  }
  bucket_logic: {
    label: "Bucket Index Formula"
    width: 280
    code: |'c
      // Convert to microseconds
      u64 latency_us = latency_ns / 1000;
      // Compute log2 bucket
      int bucket = 64 - __builtin_clzll(latency_us);
      // Clamp to valid range
      if (bucket >= NUM_BUCKETS) bucket = NUM_BUCKETS - 1;
    '|
    style.fill: "#FFF9E6"
    style.stroke: "#D4A500"
  }
}
bucket_table: {
  label: "Bucket Boundaries (Log2 Scale)"
  shape: sql_table
  width: 600
  b0: "0    | 0 μs        | 1 μs       | 1 μs     | Sub-microsecond"
  b1: "1    | 1 μs        | 2 μs       | 1 μs     | Cache hit"
  b2: "2    | 2 μs        | 4 μs       | 2 μs     | Fast syscall"
  b3: "3    | 4 μs        | 8 μs       | 4 μs     | Buffer cache"
  b4: "4    | 8 μs        | 16 μs      | 8 μs     | Page cache hit"
  b5: "5    | 16 μs       | 32 μs      | 16 μs    | Hot path"
  b6: "6    | 32 μs       | 64 μs      | 32 μs    | Normal I/O"
  b7: "7    | 64 μs       | 128 μs     | 64 μs    | SSD read"
  b8: "8    | 128 μs      | 256 μs     | 128 μs   | SSD write"
  b9: "9    | 256 μs      | 512 μs     | 256 μs   | NVMe slow"
  b10: "10   | 512 μs      | 1,024 μs   | 512 μs   | ~1ms threshold"
  b11: "11   | 1 ms        | 2 ms       | 1 ms     | HDD seek"
  b12: "12   | 2 ms        | 4 ms       | 2 ms     | HDD read"
  b13: "13   | 4 ms        | 8 ms       | 4 ms     | Network local"
  b14: "14   | 8 ms        | 16 ms      | 8 ms     | Network regional"
  b15: "15   | 16 ms       | 32 ms      | 16 ms    | Cross-AZ"
  b16: "16   | 32 ms       | 64 ms      | 32 ms    | Cross-region"
  b17: "17   | 64 ms       | 128 ms     | 64 ms    | WAN latency"
  b18: "18   | 128 ms      | 256 ms     | 128 ms   | Cross-continent"
  b19: "19   | 256 ms      | 512 ms     | 256 ms   | Satellite?"
  b20: "20+  | 512 ms+     | ...        | 512 ms+  | Timeout zone"
  note: "Total: 64 buckets covers 0 → 18+ hours"
}
