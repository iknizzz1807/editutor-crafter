direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Monotonic vs Wall-Clock Time for Latency Measurement" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  monotonic: "MONOTONIC TIME (bpf_ktime_get_ns)" {
    direction: down
    style.stroke: "#4CAF50"
    style.fill: "#E8F5E9"
    m_label: "Steady increase - never jumps" {
      shape: text
      style.font-color: "#2E7D32"
      style.bold: true
    }
    m_timeline: {
      direction: right
      grid-columns: 6
      grid-gap: 0
      m_t0: "T=0" {
        style.fill: "#81C784"
        style.stroke: "#4CAF50"
      }
      m_t1: "T=1" {
        style.fill: "#81C784"
        style.stroke: "#4CAF50"
      }
      m_t2: "T=2" {
        style.fill: "#81C784"
        style.stroke: "#4CAF50"
      }
      m_t3: "T=3" {
        style.fill: "#81C784"
        style.stroke: "#4CAF50"
      }
      m_t4: "T=4" {
        style.fill: "#81C784"
        style.stroke: "#4CAF50"
      }
      m_t5: "T=5" {
        style.fill: "#81C784"
        style.stroke: "#4CAF50"
      }
    }
    m_entry: "Entry Probe\nbpf_ktime_get_ns()\n= 1000 ns" {
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 120
    }
    m_exit: "Exit Probe\nbpf_ktime_get_ns()\n= 1050 ns" {
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 120
    }
    m_duration: "Duration = 1050 - 1000 = 50 ns ✓" {
      shape: rectangle
      style.fill: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
    m_entry -> m_timeline: "syscall start"
    m_timeline -> m_exit: "syscall end"
    m_exit -> m_duration: "compute"
  }
  wallclock: "WALL-CLOCK TIME (gettimeofday)" {
    direction: down
    style.stroke: "#F44336"
    style.fill: "#FFEBEE"
    w_label: "Can jump - NTP, admin, suspend" {
      shape: text
      style.font-color: "#C62828"
      style.bold: true
    }
    w_timeline: {
      direction: right
      grid-columns: 6
      grid-gap: 0
      w_t0: "T=0" {
        style.fill: "#EF9A9A"
        style.stroke: "#F44336"
      }
      w_t1: "T=1" {
        style.fill: "#EF9A9A"
        style.stroke: "#F44336"
      }
      w_jump: "JUMP!" {
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        style.font-color: "#B71C1C"
        style.bold: true
      }
      w_t4: "T=4" {
        style.fill: "#EF9A9A"
        style.stroke: "#F44336"
      }
      w_t5: "T=5" {
        style.fill: "#EF9A9A"
        style.stroke: "#F44336"
      }
      w_t6: "T=6" {
        style.fill: "#EF9A9A"
        style.stroke: "#F44336"
      }
    }
    w_entry: "Entry Probe\ngettimeofday()\n= 1000 ms" {
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 120
    }
    w_exit: "Exit Probe\ngettimeofday()\n= 800 ms (!)" {
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 120
    }
    w_duration: "Duration = 800 - 1000 = -200 ms ✗" {
      shape: rectangle
      style.fill: "#C62828"
      style.font-color: white
      style.bold: true
    }
    w_entry -> w_timeline: "syscall start"
    w_timeline -> w_exit: "syscall end"
    w_exit -> w_duration: "WRONG!"
  }
}
ntp_event: "NTP Adjustment (-200ms)" {
  shape: callout
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  near: bottom-center
}
row1.wallclock.w_timeline.w_jump -> ntp_event: "causes"
comparison: {
  direction: right
  grid-columns: 2
  grid-gap: 20
  use_monotonic: "USE MONOTONIC FOR" {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    m_item1: "• Latency measurement" {shape: text}
    m_item2: "• Duration calculation" {shape: text}
    m_item3: "• Interval timing" {shape: text}
    m_item4: "• Rate limiting" {shape: text}
    m_item5: "• Timeout detection" {shape: text}
  }
  use_wall: "USE WALL-CLOCK FOR" {
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    w_item1: "• Log timestamps" {shape: text}
    w_item2: "• Human-readable dates" {shape: text}
    w_item3: "• Event correlation" {shape: text}
    w_item4: "• Cross-system sync" {shape: text}
    w_item5: "• Database records" {shape: text}
  }
}
key_insight: {
  label: "KEY INSIGHT"
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  width: 600
  insight: |md
    **bpf_ktime_get_ns()** returns nanoseconds since system boot.
    • Never goes backward (monotonic guarantee)
    • Ignores NTP adjustments  
    • Continues across suspend/resume (modern kernels)
    • Perfect for measuring *deltas* between events
    If you need wall-clock correlation, track the offset between
    monotonic and wall-clock time in userspace, then apply it
    when formatting timestamps.
  |
}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  leg_title: "Clock Types" {
    style.bold: true
    style.underline: true
  }
  leg_mono: "CLOCK_MONOTONIC" {
    style.fill: "#E8F5E9"
  }
  leg_real: "CLOCK_REALTIME" {
    style.fill: "#FFEBEE"
  }
}