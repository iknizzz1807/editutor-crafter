direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Multi-Program eBPF Lifecycle Manager Architecture"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  userspace: {
    direction: down
    label: "Userspace (dashboard.c)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    probe_manager: {
      shape: class
      label: "ProbeManager"
      -probes: "Probe[MAX_PROBES]"
      -num_probes: "int"
      -bpf_obj: "bpf_object*"
      -config_map_fd: "int"
      -events_map_fd: "int"
      +probe_enable(mgr, name): "int"
      +probe_disable(mgr, name): "int"
      +probe_manager_destroy(mgr): "void"
    }
    probe_struct: {
      shape: class
      label: "Probe"
      -name: "const char*"
      -program_name: "const char*"
      -attach_target: "const char*"
      -type: "probe_type"
      -enabled: "bool"
      -link: "bpf_link*"
      -event_count: "u64"
    }
    probe_manager -> probe_struct: "manages array of"
  }
  kernel_space: {
    direction: down
    label: "Kernel Space"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    bpf_programs: {
      label: "Loaded eBPF Programs"
      style.fill: "#FFE0B2"
      prog1: {
        shape: rectangle
        label: "trace_read_entry\n(kprobe/__x64_sys_read)"
      }
      prog2: {
        shape: rectangle
        label: "trace_read_exit\n(kretprobe/__x64_sys_read)"
      }
      prog3: {
        shape: rectangle
        label: "handle_tcp_state\n(tracepoint/sock:inet_sock_set_state)"
      }
      prog4: {
        shape: rectangle
        label: "handle_sched_switch\n(tracepoint/sched:sched_switch)"
      }
    }
    bpf_maps: {
      label: "BPF Maps"
      style.fill: "#E1F5FE"
      config_map: {
        shape: cylinder
        label: "config\n(ARRAY)"
      }
      start_times: {
        shape: cylinder
        label: "start_times\n(HASH)"
      }
      histograms: {
        shape: cylinder
        label: "latency_histograms\n(PERCPU_ARRAY)"
      }
      ringbuf: {
        shape: cylinder
        label: "events\n(RINGBUF)"
      }
    }
    hook_points: {
      label: "Kernel Hook Points"
      style.fill: "#FCE4EC"
      kprobe_read: {
        shape: diamond
        label: "__x64_sys_read\n(kprobe)"
      }
      kretprobe_read: {
        shape: diamond
        label: "__x64_sys_read\n(kretprobe)"
      }
      tp_sock: {
        shape: diamond
        label: "inet_sock_set_state\n(tracepoint)"
      }
      tp_sched: {
        shape: diamond
        label: "sched_switch\n(tracepoint)"
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  enable_flow: {
    direction: down
    label: "Enable Probe Flow"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    e1: {
      label: "1. Find Probe by Name"
      width: 200
    }
    e2: {
      label: "2. Lookup bpf_program*"
      width: 200
    }
    e3: {
      label: "3. bpf_program__attach_*()"
      width: 200
    }
    e4: {
      label: "4. Store bpf_link* in Probe"
      width: 200
    }
    e5: {
      label: "5. Set enabled = true"
      width: 200
    }
    e1 -> e2 -> e3 -> e4 -> e5: {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
  }
  disable_flow: {
    direction: down
    label: "Disable Probe Flow"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    d1: {
      label: "1. Find Probe by Name"
      width: 200
    }
    d2: {
      label: "2. Verify link != NULL"
      width: 200
    }
    d3: {
      label: "3. bpf_link__destroy(link)"
      width: 200
    }
    d4: {
      label: "4. Set link = NULL"
      width: 200
    }
    d5: {
      label: "5. Set enabled = false"
      width: 200
    }
    d1 -> d2 -> d3 -> d4 -> d5: {
      style.stroke: "#F44336"
      style.stroke-width: 2
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  lifecycle: {
    direction: down
    label: "Resource Lifecycle"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    load_phase: {
      label: "Load Phase (Once)"
      width: 280
      code: |'c
        skel = dashboard_bpf__open();
        dashboard_bpf__load(skel);
        // All programs loaded,
        // maps created, FDs opened
      '|
    }
    attach_phase: {
      label: "Attach Phase (Per-Probe)"
      width: 280
      code: |'c
        prog = bpf_object__find_program_by_name(
            obj, probe->program_name);
        link = bpf_program__attach_*(prog, ...);
        // link owns attachment FD
      '|
    }
    detach_phase: {
      label: "Detach Phase (Per-Probe)"
      width: 280
      code: |'c
        bpf_link__destroy(probe->link);
        probe->link = NULL;
        // FD closed, hook removed
      '|
    }
    destroy_phase: {
      label: "Destroy Phase (Once)"
      width: 280
      code: |'c
        // Detach all probes first
        for (i = 0; i < num_probes; i++)
          if (probes[i].link)
            bpf_link__destroy(probes[i].link);
        bpf_object__close(obj);
      '|
    }
    load_phase -> attach_phase: "programs ready"
    attach_phase -> detach_phase: "runtime toggle"
    detach_phase -> attach_phase: "re-enable" {
      style.stroke-dash: 3
    }
    detach_phase -> destroy_phase: "shutdown"
  }
  fd_tracking: {
    direction: down
    label: "File Descriptor Tracking"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    fd_types: {
      shape: sql_table
      label: "FD Types Managed"
      f1: "Program FD | bpf_program__fd() | Per-program"
      f2: "Map FD | bpf_map__fd() | Per-map"
      f3: "Link FD | bpf_link__fd() | Per-attachment"
      f4: "Ringbuf FD | ring_buffer__fd() | Event stream"
      f5: "Timer FD | timerfd_create() | Periodic poll"
      f6: "Epoll FD | epoll_create1() | Multi-source wait"
    }
    leak_warning: {
      label: "⚠️ Leak Risk"
      width: 260
      code: |'c
        // BAD: Toggle probes 1000x
        for (i = 0; i < 1000; i++) {
          probe_enable(mgr, "read");
          probe_disable(mgr, "read");
          // BUG: forgot bpf_link__destroy()
          // Result: 1000 leaked FDs
        }
      '|
      style.fill: "#FFCDD2"
    }
    fd_types -> leak_warning: "must track"
  }
}
userspace.probe_manager -> kernel_space.bpf_programs: "manages program FDs"
userspace.probe_manager -> kernel_space.bpf_maps: "holds map FDs"
kernel_space.bpf_programs -> kernel_space.hook_points: "attached via link FD"
enable_flow.e3 -> kernel_space.hook_points: "creates attachment" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
  label: "bpf_link*"
}
disable_flow.d3 -> kernel_space.hook_points: "removes attachment" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
  label: "destroy link"
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  green: "Green arrow = Enable flow"
  red: "Red arrow = Disable flow"
  dashed: "Dashed = Optional/runtime path"
  green.style.fill: "#E8F5E9"
  red.style.fill: "#FFEBEE"
  dashed.style.fill: "#E0E0E0"
}