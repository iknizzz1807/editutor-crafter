direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Per-Syscall Histogram Storage (BPF_MAP_TYPE_ARRAY)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
histogram_map: {
  label: "histograms (BPF_MAP_TYPE_ARRAY)\nmax_entries: 512"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  idx0: {
    label: "Index 0"
    shape: rectangle
    style.fill: "#FFE4B5"
    style.stroke: "#CC8800"
    width: 180
  }
  idx1: {
    label: "Index 1"
    shape: rectangle
    style.fill: "#FFE4B5"
    style.stroke: "#CC8800"
    width: 180
  }
  idx2: {
    label: "Index 2-256"
    shape: rectangle
    style.fill: "#F0F0F0"
    style.stroke: "#999999"
    style.stroke-dash: 3
    width: 180
  }
  idx257: {
    label: "Index 257"
    shape: rectangle
    style.fill: "#FFE4B5"
    style.stroke: "#CC8800"
    width: 180
  }
  idx_rest: {
    label: "Index 258-511"
    shape: rectangle
    style.fill: "#F0F0F0"
    style.stroke: "#999999"
    style.stroke-dash: 3
    width: 180
  }
}
syscall_read: {
  label: "SYS_READ (0)"
  shape: rectangle
  style.fill: "#D4EDDA"
  style.stroke: "#28A745"
  style.stroke-width: 2
  width: 140
}
syscall_write: {
  label: "SYS_WRITE (1)"
  shape: rectangle
  style.fill: "#D4EDDA"
  style.stroke: "#28A745"
  style.stroke-width: 2
  width: 140
}
syscall_openat: {
  label: "SYS_OPENAT (257)"
  shape: rectangle
  style.fill: "#D4EDDA"
  style.stroke: "#28A745"
  style.stroke-width: 2
  width: 140
}
bucket_read: {
  label: "u64[64] Histogram Buckets"
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  width: 320
  r0: "0: 0-1us"
  r1: "1: 1-2us"
  r2: "2: 2-4us"
  r3: "3: 4-8us"
  rdots: "... (log2 scale)"
  r62: "62: 2^62-2^63us"
  r63: "63: >=2^63us"
  shape: sql_table
}
bucket_write: {
  label: "u64[64] Histogram Buckets"
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  width: 320
  w0: "0: 0-1us"
  w1: "1: 1-2us"
  w2: "2: 2-4us"
  w3: "3: 4-8us"
  wdots: "... (log2 scale)"
  w62: "62: 2^62-2^63us"
  w63: "63: >=2^63us"
  shape: sql_table
}
bucket_openat: {
  label: "u64[64] Histogram Buckets"
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  width: 320
  o0: "0: 0-1us"
  o1: "1: 1-2us"
  o2: "2: 2-4us"
  o3: "3: 4-8us"
  odots: "... (log2 scale)"
  o62: "62: 2^62-2^63us"
  o63: "63: >=2^63us"
  shape: sql_table
}
unused: {
  label: "Unused (zeros)"
  shape: rectangle
  style.fill: "#F8D7DA"
  style.stroke: "#DC3545"
  style.stroke-dash: 3
  width: 140
}
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: "#666666"
  style.stroke-dash: 2
  legend_title: "Legend" {
    shape: text
    style.bold: true
  }
  active_syscall: "Active Syscall Tracing" {
    shape: rectangle
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
  }
  map_entry: "Map Entry (in use)" {
    shape: rectangle
    style.fill: "#FFE4B5"
    style.stroke: "#CC8800"
  }
  histogram: "Log2 Histogram Buckets" {
    shape: rectangle
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
  }
  unused_entry: "Unused Map Entry" {
    shape: rectangle
    style.fill: "#F0F0F0"
    style.stroke: "#999999"
    style.stroke-dash: 3
  }
}
lookup_code: {
  label: "Lookup Pattern"
  width: 400
  code: |'c
    // Key = syscall number (0, 1, 257, ...)
    u32 key = syscall_nr;
    // Value = pointer to 64-element histogram
    u64 (*hist)[NUM_BUCKETS];
    hist = bpf_map_lookup_elem(&histograms, &key);
    if (hist) {
      // Compute bucket: floor(log2(latency_us))
      int bucket = 64 - __builtin_clzll(latency_us);
      (*hist)[bucket]++;
    }
  '|
}
syscall_read -> histogram_map.idx0: "key=0"
syscall_write -> histogram_map.idx1: "key=1"
syscall_openat -> histogram_map.idx257: "key=257"
histogram_map.idx0 -> bucket_read: "value"
histogram_map.idx1 -> bucket_write: "value"
histogram_map.idx257 -> bucket_openat: "value"
histogram_map.idx2 -> unused: "value\n(unused)"
lookup_code -> histogram_map: "bpf_map_lookup_elem"