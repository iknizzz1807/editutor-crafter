direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Performance Overhead Measurement
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  baseline: {
    direction: down
    label: "Baseline (No Probes)"
    bench1: {
      label: "Benchmark Run 1"
      width: 280
      code: |'bash
        # Measure syscall throughput
        time dd if=/dev/zero of=/dev/null \
             bs=1M count=10000
        # Result: 12.5 GB/s
        # Syscalls: ~100,000/sec
      '|
    }
    metrics1: {
      shape: sql_table
      label: "Baseline Metrics"
      m1: "syscall_rate | 100,000/sec"
      m2: "throughput    | 12.5 GB/s"
      m3: "latency_p99   | 1.2 μs"
    }
  }
  with_probes: {
    direction: down
    label: "With eBPF Probes Enabled"
    bench2: {
      label: "Benchmark Run 2"
      width: 280
      code: |'bash
        # Same benchmark with probes
        sudo ./dashboard &
        time dd if=/dev/zero of=/dev/null \
             bs=1M count=10000
        # Result: 12.3 GB/s
        # Syscalls: ~98,000/sec
      '|
    }
    metrics2: {
      shape: sql_table
      label: "Instrumented Metrics"
      m1: "syscall_rate | 98,000/sec"
      m2: "throughput    | 12.3 GB/s"
      m3: "latency_p99   | 1.4 μs"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: {
    direction: down
    label: "Overhead Calculation"
    width: 400
    formula_box: {
      label: "Formula"
      code: |md
        
        overhead % = (with_probes - baseline) 
                     ───────────────────────── × 100
                            baseline
        
        **Example (throughput):**
        
        overhead = (12.3 - 12.5) / 12.5 × 100
                 = -0.2 / 12.5 × 100
                 = 1.6%
        
      |
      width: 380
    }
  }
  results: {
    direction: down
    label: "Measured Overhead"
    result_table: {
      shape: sql_table
      label: "Overhead Results"
      r1: "Metric        | Baseline  | Probes    | Overhead"
      r2: "Throughput    | 12.5 GB/s | 12.3 GB/s | 1.6%"
      r3: "Syscall rate  | 100K/s    | 98K/s     | 2.0%"
      r4: "p99 latency   | 1.2 μs    | 1.4 μs    | 16.7%"
    }
    verdict: {
      shape: diamond
      label: "Acceptable?\n(< 2%)"
      style.fill: "#ACE1AF"
      style.stroke: "#2E7D32"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  acceptable: {
    direction: down
    label: "Acceptable Range"
    range_viz: {
      label: "Overhead Threshold"
      code: |md
        
              0%     1%     2%     3%     4%     5%
              │──────│──────│──────│──────│──────│
              ├──────┴──────┤
                  ✓ OK
              Target: < 2% CPU overhead
              Acceptable: < 5% for development
              Warning: > 5% requires optimization
        
      |
      width: 360
    }
  }
  methods: {
    direction: down
    label: "Measurement Methods"
    method1: {
      label: "1. Self-Measurement"
      width: 320
      code: |'c
        // In eBPF probe
        u64 start = bpf_ktime_get_ns();
        // ... probe logic ...
        u64 duration = bpf_ktime_get_ns() - start;
        // Record to overhead histogram
      '|
    }
    method2: {
      label: "2. External Benchmark"
      width: 320
      code: |'bash
        # Use perf to measure
        perf stat -e cycles,instructions \
          -a sleep 10  # without probes
        perf stat -e cycles,instructions \
          -a sleep 10  # with probes
      '|
    }
  }
}
baseline.metrics1 -> comparison.formula_box: "baseline values"
with_probes.metrics2 -> comparison.formula_box: "instrumented values"
comparison.formula_box -> results.result_table: "compute"
results.result_table -> results.verdict: "check"
baseline -> with_probes: "Enable probes" {
  style.stroke-dash: 4
  style.stroke: "#666"
}