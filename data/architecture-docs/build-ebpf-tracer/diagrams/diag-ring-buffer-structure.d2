direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: BPF Ring Buffer Internal Layout {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_layout: {
    direction: down
    label: "Ring Buffer Memory Layout (16 MB typical)"
    header_row: {
      direction: right
      label: ""
      style.stroke: transparent
      data_pages: {
        label: "Data Pages (NR_PAGES × 4KB)"
        style.fill: "#E8F4FD"
        style.stroke: "#2E86AB"
        width: 400
      }
    }
    page_array: {
      direction: right
      grid-columns: 8
      grid-gap: 2
      p0: "Page 0" {style.fill: "#C5E8B7"}
      p1: "Page 1" {style.fill: "#C5E8B7"}
      p2: "Page 2" {style.fill: "#C5E8B7"}
      p3: "Page 3" {style.fill: "#C5E8B7"}
      p4: "Page 4" {style.fill: "#C5E8B7"}
      p5: "Page 5" {style.fill: "#C5E8B7"}
      p6: "Page 6" {style.fill: "#C5E8B7"}
      p7: "Page N" {style.fill: "#C5E8B7"}
    }
    page_array.*.width: 60
    page_array.*.height: 40
    page_array.*.style.stroke: "#4A7C59"
    page_array.*.style.font-size: 10
    circular_note: {
      label: "Logically circular: Page N wraps to Page 0"
      style.fill: transparent
      style.stroke: "#666"
      style.stroke-dash: 3
      style.italic: true
    }
  }
  positions: {
    direction: down
    label: "Position Pointers (8 bytes each)"
    producer_pos: {
      label: "Producer Position"
      style.fill: "#FFE5B4"
      style.stroke: "#E8833A"
      width: 300
      prod_struct: {
        shape: sql_table
        label: "struct bpf_ringbuf (kernel)"
        f0: "0x00 | unsigned long | producer"
        f1: "0x08 | unsigned long | consumer"
        f2: "0x10 | unsigned long | mask"
        sz: "In mmapped shared memory"
      }
    }
    consumer_pos: {
      label: "Consumer Position"
      style.fill: "#E5D4FF"
      style.stroke: "#8B5CF6"
      width: 300
      cons_note: {
        label: "Userspace reads, kernel writes"
        style.fill: transparent
        style.italic: true
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  record_layout: {
    direction: down
    label: "Record Header + Payload"
    width: 450
    record_struct: {
      shape: sql_table
      label: "struct bpf_ringbuf_hdr (8 bytes)"
      f0: "0x00 | u32 | len (payload size)"
      f1: "0x04 | u32 | locking/flags"
      note: "Header immediately precedes payload"
    }
    payload: {
      label: "Payload (variable length, 8-byte aligned)"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      width: 430
      height: 60
    }
    example_record: {
      direction: right
      label: ""
      style.stroke: transparent
      hdr_box: {
        label: "HDR\n8B"
        style.fill: "#FFE5B4"
        style.stroke: "#E8833A"
        width: 50
        height: 50
      }
      data_box: {
        label: "Event Data\n(N bytes)"
        style.fill: "#D4EDDA"
        style.stroke: "#28A745"
        width: 200
        height: 50
      }
      pad_box: {
        label: "Pad\n(0-7B)"
        style.fill: "#F8D7DA"
        style.stroke: "#DC3545"
        width: 60
        height: 50
      }
    }
  }
  flow_diagram: {
    direction: down
    label: "Write → Read Flow"
    write_flow: {
      direction: down
      label: "Kernel (Producer)"
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
      w1: "1. bpf_ringbuf_reserve()"
      w2: "2. Atomic fetch_add producer_pos"
      w3: "3. Check space vs consumer_pos"
      w4: "4. Write header + payload"
      w5: "5. bpf_ringbuf_submit()"
      w1 -> w2 -> w3 -> w4 -> w5
    }
    write_flow.*.style.fill: "#FFF3CD"
    write_flow.*.width: 250
    read_flow: {
      direction: down
      label: "Userspace (Consumer)"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      r1: "1. Read consumer_pos"
      r2: "2. Check if < producer_pos"
      r3: "3. Read header for length"
      r4: "4. Copy payload to local"
      r5: "5. Advance consumer_pos"
      r1 -> r2 -> r3 -> r4 -> r5
    }
    read_flow.*.style.fill: "#D4EDDA"
    read_flow.*.width: 250
    write_flow.w5 -> read_flow.r1: "visible" {
      style.stroke-dash: 3
      style.stroke: "#666"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  circular_view: {
    direction: down
    label: "Circular Buffer State"
    buffer_state: {
      direction: right
      label: ""
      style.stroke: transparent
      left_segment: {
        label: "[Consumed]"
        style.fill: "#E5D4FF"
        style.stroke: "#8B5CF6"
        width: 80
        height: 60
      }
      middle_segment: {
        label: "[Available]"
        style.fill: "#E8F4FD"
        style.stroke: "#2E86AB"
        width: 120
        height: 60
      }
      right_segment: {
        label: "[Pending]"
        style.fill: "#FFE5B4"
        style.stroke: "#E8833A"
        width: 60
        height: 60
      }
    }
    position_markers: {
      direction: right
      label: ""
      style.stroke: transparent
      cons_marker: {
        label: "↑ Consumer\nPosition"
        style.fill: transparent
        style.font-color: "#8B5CF6"
      }
      spacer: {
        label: ""
        width: 120
        style.fill: transparent
      }
      prod_marker: {
        label: "↑ Producer\nPosition"
        style.fill: transparent
        style.font-color: "#E8833A"
      }
    }
    buffer_state.left_segment -> position_markers.cons_marker: {
      style.stroke: "#8B5CF6"
      style.stroke-width: 2
    }
    buffer_state.right_segment -> position_markers.prod_marker: {
      style.stroke: "#E8833A"
      style.stroke-width: 2
    }
  }
  key_operations: {
    direction: down
    label: "Key Operations"
    ops_table: {
      shape: sql_table
      label: "Helper Functions"
      reserve: "bpf_ringbuf_reserve() | Returns ptr or NULL"
      submit: "bpf_ringbuf_submit() | Makes record visible"
      discard: "bpf_ringbuf_discard() | Aborts reservation"
      output: "bpf_ringbuf_output() | Reserve+copy+submit"
    }
  }
  userspace_api: {
    direction: down
    label: "Userspace API (libbpf)"
    user_table: {
      shape: sql_table
      label: "Consumer Functions"
      new: "ring_buffer__new() | Create consumer"
      poll: "ring_buffer__poll() | Block for events"
      consume: "ring_buffer__consume() | Non-block read"
      ep_fd: "ring_buffer__fd() | For epoll integration"
    }
  }
}
legend: {
  near: bottom-right
  direction: right
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  l1: "Produced" {style.fill: "#FFE5B4"}
  l2: "Consumed" {style.fill: "#E5D4FF"}
  l3: "Available" {style.fill: "#E8F4FD"}
}
memory_layout -> positions: "shared via\nmmap" {
  style.stroke-dash: 3
}
record_layout -> circular_view: "records fill\nbuffer" {
  style.stroke-dash: 3
}