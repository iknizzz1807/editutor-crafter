direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Ring Buffer vs Perf Event Array: Kernel-to-Userspace Event Streaming"
  style: {
    font-size: 24
    bold: true
    stroke-width: 0
    fill: transparent
  }
}

row_compare: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  perf: "Perf Event Array (Legacy / < 5.8)" {
    direction: down
    style.stroke: "#c0392b"
    style.fill: "#fdf2f2"
    
    desc: {
      shape: rectangle
      label: |md
        **Per-CPU Architecture**
        - Isolated buffer per logical core
        - Memory overhead: $N_{cpu} \times BufferSize$
        - No global chronological ordering
      |
      style.fill: white
    }

    kernel: "Kernel Space" {
      direction: down
      cpus: "" {
        direction: right
        style.stroke: transparent
        cpu0: "CPU 0\n[Buffer]" {
          shape: cylinder
          style.fill: "#e74c3c"
          style.font-color: white
        }
        cpu1: "CPU 1\n[Buffer]" {
          shape: cylinder
          style.fill: "#e74c3c"
          style.font-color: white
        }
        cpu2: "CPU 2\n[Buffer]" {
          shape: cylinder
          style.fill: "#e74c3c"
          style.font-color: white
        }
      }
    }

    event: "eBPF Event" {
      shape: oval
      style.fill: "#f5b7b1"
    }

    event -> kernel.cpus.cpu0: "CPU 0 affinity"
    event -> kernel.cpus.cpu1: "CPU 1 affinity"

    userspace: "Userspace" {
      direction: down
      poll_logic: "Poller (libbpf)"
      code: |'c
        // Complexity: O(N) Polling
        for (int i = 0; i < n_cpus; i++) {
          perf_buffer__poll(pb[i], timeout);
        }
        // Manual sort required for time
      '|
    }

    kernel.cpus -> userspace.poll_logic: "Read N Streams"

    footer: "Use when: Kernel < 5.8 or strict CPU isolation needed" {
      shape: rectangle
      style.stroke-dash: 3
      style.fill: "#fadbd8"
    }
  }

  ring: "BPF Ring Buffer (Modern / 5.8+)" {
    direction: down
    style.stroke: "#27ae60"
    style.fill: "#f0fdf4"

    desc: {
      shape: rectangle
      label: |md
        **Shared Architecture**
        - Single Mapped Buffer for all CPUs
        - Lower memory (one shared allocation)
        - Native global event ordering
      |
      style.fill: white
    }

    kernel: "Kernel Space" {
      direction: down
      shared_buf: "Shared Ring Buffer" {
        shape: cylinder
        style.fill: "#27ae60"
        style.font-color: white
        width: 250
      }
      slots: "" {
        direction: right
        style.stroke: transparent
        s1: "[Event A]" { style.fill: "#82e0aa" }
        s2: "[Event B]" { style.fill: "#82e0aa" }
        s3: "[ Empty ]" { style.fill: "#d5f5e3" }
      }
    }

    event: "eBPF Event" {
      shape: oval
      style.fill: "#abebc6"
    }

    event -> kernel.shared_buf: "Any CPU -> Atomic Push" {
      style.animated: true
    }

    userspace: "Userspace" {
      direction: down
      poll_logic: "Poller (libbpf)"
      code: |'c
        // Complexity: O(1) Polling
        ring_buffer__poll(rb, timeout);
        
        // Events arrive in global 
        // chronological order.
      '|
    }

    kernel.shared_buf -> userspace.poll_logic: "Single Stream"

    footer: "Preferred: Lower overhead & simpler API" {
      shape: rectangle
      style.stroke-dash: 3
      style.fill: "#d5f5e3"
    }
  }
}

feature_comparison: {
  shape: sql_table
  label: "Implementation Metrics"
  h: "Metric | Perf Event Array | BPF Ring Buffer"
  m1: "Memory Model | Per-CPU (Multi-buffer) | Global (Single-buffer)"
  m2: "Ordering | Local to CPU | Global (Strict)"
  m3: "API | bpf_perf_event_output() | bpf_ringbuf_output()"
  m4: "Data Types | Fixed Size Records | Variable Length Records"
  m5: "Performance | High contention on many CPUs | High efficiency, low wake-ups"
  m6: "Kernel | Linux 4.4+ | Linux 5.8+"
}

legend: {
  direction: right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  l1: "Legacy Path" {
    style.fill: "#e74c3c"
    style.font-color: white
  }
  l2: "Hot Path" {
    style.fill: "#27ae60"
    style.font-color: white
    style.animated: true
  }
}
legend.near: bottom-right

row_compare.perf -> feature_comparison: "Legacy standard" {style.stroke-dash: 3}
row_compare.ring -> feature_comparison: "Recommended" {style.stroke: "#27ae60"; style.stroke-width: 3}