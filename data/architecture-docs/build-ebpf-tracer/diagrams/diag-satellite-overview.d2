direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    userspace: "#E8F4FD"
    kernel: "#FFF3E0"
    ebpf: "#E8F5E9"
    map: "#F3E5F5"
    ringbuf: "#FFEBEE"
    kprobe: "#E3F2FD"
    tracepoint: "#E0F7FA"
  }
}
title: {
  near: top-center
  shape: text
  label: "eBPF Tracer System Architecture"
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    label: "Legend"
    style.fill: white
    leg_userspace: "Userspace" {
      style.fill: ${colors.userspace}
      shape: rectangle
    }
    leg_kernel: "Kernel Space" {
      style.fill: ${colors.kernel}
      shape: rectangle
    }
    leg_ebpf: "eBPF Programs" {
      style.fill: ${colors.ebpf}
      shape: rectangle
    }
    leg_maps: "BPF Maps" {
      style.fill: ${colors.map}
      shape: cylinder
    }
    leg_ringbuf: "Ring Buffer" {
      style.fill: ${colors.ringbuf}
      shape: queue
    }
  }
  config: {
    label: "Config Map\nBPF_MAP_TYPE_ARRAY"
    shape: cylinder
    style.fill: ${colors.map}
    width: 140
  }
}
userspace: {
  label: "USERSPACE"
  style: {
    fill: ${colors.userspace}
    stroke: "#1976D2"
    stroke-width: 2
  }
  direction: down
  dashboard: {
    label: "Dashboard (dashboard.c)"
    style.fill: white
    style.stroke: "#1976D2"
    ui_renderer: "Terminal UI\n1-2 Hz refresh"
    epoll_loop: "epoll Event Loop\n(timerfd + ringbuf fd)"
    ui_renderer -- epoll_loop
  }
  probe_manager: {
    label: "Probe Manager"
    style.fill: white
    +probe_enable(name): "int"
    +probe_disable(name): "int"
    -links: "struct bpf_link**"
  }
  aggregators: {
    label: "Per-CPU Aggregators"
    style.fill: white
    hist_agg: "Histogram\nSummation"
    proc_agg: "Process Stats\nCollection"
    hist_agg -- proc_agg
  }
  dashboard -- probe_manager: "attach/detach"
  dashboard -- aggregators: "poll maps"
}
kernelspace: {
  label: "KERNEL SPACE"
  style: {
    fill: ${colors.kernel}
    stroke: "#E65100"
    stroke-width: 2
  }
  direction: down
  ebpf_programs: {
    label: "eBPF Programs (Verified + JIT Compiled)"
    style.fill: ${colors.ebpf}
    style.stroke: "#388E3C"
    direction: right
    m1_m2: {
      label: "M1/M2: Syscall Tracer"
      style.fill: white
      direction: down
      kprobe_read: "kprobe\n__x64_sys_read"
      kprobe_write: "kprobe\n__x64_sys_write"
      kprobe_openat: "kprobe\n__x64_sys_openat"
      kretprobe_read: "kretprobe\n__x64_sys_read"
      kretprobe_write: "kretprobe\n__x64_sys_write"
      kprobe_read.style.fill: ${colors.kprobe}
      kprobe_write.style.fill: ${colors.kprobe}
      kprobe_openat.style.fill: ${colors.kprobe}
      kretprobe_read.style.fill: ${colors.kprobe}
      kretprobe_write.style.fill: ${colors.kprobe}
    }
    m3: {
      label: "M3: TCP Tracer"
      style.fill: white
      direction: down
      tp_tcp: "tracepoint\nsock:inet_sock_set_state"
      tp_tcp.style.fill: ${colors.tracepoint}
    }
    m4: {
      label: "M4: Scheduler"
      style.fill: white
      direction: down
      tp_sched: "tracepoint\nsched:sched_switch"
      tp_sched.style.fill: ${colors.tracepoint}
    }
  }
  bpf_maps: {
    label: "BPF Maps (Kernel Memory)"
    style.fill: ${colors.map}
    style.stroke: "#7B1FA2"
    direction: right
    start_times: {
      label: "start_times\nHASH\nTID -> timestamp"
      shape: cylinder
    }
    histograms: {
      label: "histograms\nPERCPU_ARRAY\nsyscall -> buckets[]"
      shape: cylinder
    }
    connections: {
      label: "connections\nHASH\nskaddr -> conn_info"
      shape: cylinder
    }
    proc_stats: {
      label: "proc_stats\nHASH\nPID -> stats"
      shape: cylinder
    }
  }
  ringbuf: {
    label: "events\nRINGBUF\n16 MB"
    shape: queue
    style.fill: ${colors.ringbuf}
    style.stroke: "#C62828"
  }
  kernel_hooks: {
    label: "Kernel Hook Points"
    style.fill: white
    style.stroke-dash: 3
    do_sys_openat2: "do_sys_openat2()"
    __x64_sys_read: "__x64_sys_read()"
    __x64_sys_write: "__x64_sys_write()"
    tcp_state_change: "TCP state machine"
    schedule: "schedule()"
  }
}
boundary: "User/Kernel Boundary" {
  style: {
    fill: transparent
    stroke: "#424242"
    stroke-dash: 5
    stroke-width: 2
  }
}
ebpf_programs -- bpf_maps: "bpf_map_update_elem()\nbpf_map_lookup_elem()"
ebpf_programs -- ringbuf: "bpf_ringbuf_reserve()\nbpf_ringbuf_submit()"
bpf_maps -- userspace.aggregators: "bpf_map_lookup_elem()\n(per-CPU aggregation)"
ringbuf -- userspace.dashboard.epoll_loop: "ring_buffer__poll()\nevent stream"
userspace.probe_manager -- ebpf_programs: "bpf_program__attach_kprobe()\nbpf_program__attach_tracepoint()"
config -- ebpf_programs: "runtime filter\ntoggle"
config -- userspace.dashboard: "CLI options\nset filters"
kernel_hooks.do_sys_openat2 -- ebpf_programs.m1_m2: "fires" {
  style.stroke: ${colors.kprobe}
  style.stroke-dash: 3
}
kernel_hooks.tcp_state_change -- ebpf_programs.m3: "fires" {
  style.stroke: ${colors.tracepoint}
  style.stroke-dash: 3
}
kernel_hooks.schedule -- ebpf_programs.m4: "fires" {
  style.stroke: ${colors.tracepoint}
  style.stroke-dash: 3
}
flow_note: {
  near: bottom-center
  label: |md
    **Data Flow:**
    1. Kernel hook fires → eBPF program executes
    2. eBPF reads/writes BPF maps for state
    3. eBPF submits events to ring buffer
    4. Userspace polls via epoll (ringbuf + timer)
    5. Aggregator sums per-CPU values
    6. Dashboard renders at 1-2 Hz
  |
  style.fill: white
  style.stroke: "#757575"
}