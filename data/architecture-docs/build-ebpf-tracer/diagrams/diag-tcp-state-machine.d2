direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: |md
    # TCP State Machine Transitions
    Traced via `sock:inet_sock_set_state`
  |
  style: {
    stroke: transparent
    fill: transparent
    font-size: 20
  }
}

# TCP State Constants
TCP_STATES: {
  shape: sql_table
  label: "TCP State Constants (include/net/tcp_states.h)"
  s0: "0x01 | TCP_ESTABLISHED"
  s1: "0x02 | TCP_SYN_SENT"
  s2: "0x03 | TCP_SYN_RECV"
  s3: "0x04 | TCP_FIN_WAIT1"
  s4: "0x05 | TCP_FIN_WAIT2"
  s5: "0x06 | TCP_TIME_WAIT"
  s6: "0x07 | TCP_CLOSE"
  s7: "0x08 | TCP_CLOSE_WAIT"
  s8: "0x09 | TCP_LAST_ACK"
  s9: "0x0A | TCP_LISTEN"
  s10: "0x0B | TCP_CLOSING"
}

# Layout Row for Paths
diagram_body: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  client_path: {
    direction: down
    label: "Client (Active Open)"
    style.stroke: "#4A90D9"
    style.fill: "#E8F4FD"
    
    CLOSED_START: {
      shape: circle
      label: "CLOSED"
      style.fill: "#F5F5F5"
    }
    SYN_SENT: {
      shape: circle
      label: "SYN_SENT"
      style.fill: "#FFF3CD"
    }
  }

  shared_path: {
    direction: down
    label: "Connection State"
    style.stroke: "#28A745"
    style.fill: "#D4EDDA"

    ESTABLISHED: {
      shape: circle
      label: "ESTABLISHED"
      style: {
        fill: "#C8E6C9"
        stroke: "#28A745"
        stroke-width: 4
        bold: true
      }
    }
    
    FIN_WAIT1: {
      shape: circle
      label: "FIN_WAIT1"
    }
    
    FIN_WAIT2: {
      shape: circle
      label: "FIN_WAIT2"
    }
    
    TIME_WAIT: {
      shape: circle
      label: "TIME_WAIT"
      style: {
        fill: "#FFCDD2"
        stroke: "#D32F2F"
        stroke-width: 3
      }
    }
  }

  server_path: {
    direction: down
    label: "Server (Passive Open)"
    style.stroke: "#9C27B0"
    style.fill: "#F3E5F5"
    
    LISTEN: {
      shape: circle
      label: "LISTEN"
    }
    SYN_RECV: {
      shape: circle
      label: "SYN_RECV"
    }
    CLOSE_WAIT: {
      shape: circle
      label: "CLOSE_WAIT"
    }
    LAST_ACK: {
      shape: circle
      label: "LAST_ACK"
    }
  }
}

# Terminal state
CLOSED_END: {
  shape: circle
  label: "CLOSED"
  style.fill: "#F5F5F5"
}

# Three-way Handshake
diagram_body.client_path.CLOSED_START -> diagram_body.server_path.LISTEN: "bind/listen" { style.stroke-dash: 3 }
diagram_body.client_path.CLOSED_START -> diagram_body.client_path.SYN_SENT: "connect | SYN" { style.stroke: "#28A745" }
diagram_body.server_path.LISTEN -> diagram_body.server_path.SYN_RECV: "SYN | SYN+ACK" { style.stroke: "#28A745" }
diagram_body.client_path.SYN_SENT -> diagram_body.shared_path.ESTABLISHED: "SYN+ACK | ACK" { 
  style.stroke: "#28A745"
  style.stroke-width: 3
}
diagram_body.server_path.SYN_RECV -> diagram_body.shared_path.ESTABLISHED: "ACK" { style.stroke: "#28A745" }

# Connection Teardown
diagram_body.shared_path.ESTABLISHED -> diagram_body.shared_path.FIN_WAIT1: "close | FIN" { style.stroke: "#D32F2F" }
diagram_body.shared_path.FIN_WAIT1 -> diagram_body.shared_path.FIN_WAIT2: "ACK" { style.stroke: "#D32F2F" }
diagram_body.shared_path.FIN_WAIT2 -> diagram_body.shared_path.TIME_WAIT: "FIN | ACK" { 
  style.stroke: "#D32F2F"
  style.stroke-width: 3
}
diagram_body.shared_path.TIME_WAIT -> CLOSED_END: "2MSL Timeout" { style.stroke-dash: 3 }

# Passive Close
diagram_body.shared_path.ESTABLISHED -> diagram_body.server_path.CLOSE_WAIT: "FIN | ACK" { style.stroke: "#D32F2F" }
diagram_body.server_path.CLOSE_WAIT -> diagram_body.server_path.LAST_ACK: "close | FIN" { style.stroke: "#D32F2F" }
diagram_body.server_path.LAST_ACK -> CLOSED_END: "ACK" { style.stroke: "#D32F2F" }

# Data Flow Reference
data_flow: {
  label: "Kernel Data Path"
  code: |'c
    // net/ipv4/tcp_input.c
    void tcp_rcv_established(struct sock *sk, ...) {
        // High-speed path for ESTABLISHED state
        if (tcp_header_prediction(sk, th)) { ... }
    }
  '|
}

# Tracepoint Logic
tracepoint_info: {
  label: "eBPF Instrumentation"
  struct_def: {
    shape: sql_table
    label: "struct trace_event_raw_inet_sock_set_state"
    f0: "0x00 | void* | skaddr"
    f1: "0x08 | int   | oldstate"
    f2: "0x0C | int   | newstate"
    f3: "0x10 | u16   | sport"
    f4: "0x12 | u16   | dport"
    sz: "Total: 36 bytes (with headers)"
  }
}

# eBPF Logic Callouts
ESTABLISHED_MARKER: {
  shape: callout
  label: "★ START\nBpfMapUpdate(sk, now)"
  style.fill: "#C8E6C9"
}

TIME_WAIT_MARKER: {
  shape: callout
  label: "★ END\nDelta = now - MapLookup(sk)"
  style.fill: "#FFCDD2"
}

# Positioning via root-level constants
tracepoint_info.near: bottom-right
TCP_STATES.near: top-right
ESTABLISHED_MARKER.near: center-right
TIME_WAIT_MARKER.near: bottom-left

# Legend
legend: {
  label: "Protocol Legend"
  handshake: "Handshake Transition" { style.stroke: "#28A745" }
  teardown: "Teardown Transition" { style.stroke: "#D32F2F" }
  passive: "Passive/Secondary" { style.stroke-dash: 3 }
}
legend.near: top-left