direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Terminal Dashboard Layout
  Multi-source eBPF observability with 1-2 Hz refresh
| {near: top-center}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_panel: {
    direction: down
    label: "Terminal Display"
    header: {
      label: |md
        
        ╔═══════════════════════════════════════════════════════════════════╗
        ║ eBPF Dashboard                    CPU: 2.3%  MEM: 45MB  [1.0s]  ║
        ╠═══════════════════════════════════════════════════════════════════╣
        
      |
      width: 600
    }
    syscall_section: {
      label: "SYSCALL LATENCY HISTOGRAM"
      width: 600
      read_hist: {
        label: |md
          
          │ read (n=45,231)
          │   0-1us    ████████████████████████  12,340 (27.3%)
          │   1-2us    ██████████████████████████████  15,678 (34.7%)
          │   2-4us    █████████████  8,901 (19.7%)
          │   4-8us    ███████  4,123 (9.1%)
          │   >8us     ████  4,189 (9.2%)  [p99: 15us]
          
        |
        width: 580
      }
      write_hist: {
        label: |md
          
          │ write (n=23,456)
          │   0-1us    ████████████████████  8,234 (35.1%)
          │   1-2us    ██████████████████████  9,876 (42.1%)
          │   2-4us    █████████  3,456 (14.7%)
          │   >4us     ███  1,890 (8.1%)  [p99: 8us]
          
        |
        width: 580
      }
      openat_hist: {
        label: |md
          
          │ openat (n=1,234)
          │   0-50us   ████████████████████  678 (54.9%)
          │   50-100us ████████████  423 (34.3%)
          │   >100us   ████  133 (10.8%)  [p99: 180us]
          
        |
        width: 580
      }
    }
    tcp_section: {
      label: "TCP CONNECTIONS (Active: 23)"
      width: 600
      tcp_table: {
        label: |md
          
          │ PID    COMM        LOCAL              REMOTE             STATE
          │ ─────────────────────────────────────────────────────────────────
          │ 1234   nginx       192.168.1.10:443   10.0.0.5:52341    ESTAB
          │ 1234   nginx       192.168.1.10:443   10.0.0.8:49123    ESTAB
          │ 5678   postgres    127.0.0.1:5432     127.0.0.1:45678   ESTAB
          │ 9012   curl        192.168.1.10:44521 93.184.216.34:80  TIME_WAIT
          
        |
        width: 580
      }
    }
    proc_section: {
      label: "TOP PROCESSES BY CPU (ctxsw/s: 1,234)"
      width: 600
      proc_table: {
        label: |md
          
          │ PID    COMM        CPU%   CTXSW   RUNTIME   SYSCALLS
          │ ────────────────────────────────────────────────────────
          │ 1234   nginx       12.3%  234     1.2s      45,678
          │ 5678   postgres    8.7%   156     0.9s      23,456
          │ 9012   python      5.2%   89      0.5s      12,345
          │ 3456   redis       3.1%   45      0.3s      8,901
          
        |
        width: 580
      }
    }
    status_section: {
      label: "PROBE STATUS & CONTROLS"
      width: 600
      status_line: {
        label: |md
          
          │ Probes: [read:ON] [write:ON] [openat:ON] [tcp:ON] [sched:ON]
          │ Overhead: Probe 0.8%  Userspace 1.5%
          │ [q] Quit [p] Toggle [f] Filter [r] Reset [1-5] Toggle Probe
          ╚═══════════════════════════════════════════════════════════════════╝
          
        |
        width: 580
      }
    }
  }
  right_panel: {
    direction: down
    label: "Data Flow Architecture"
    refresh_cycle: {
      label: "Refresh Cycle (1-2 Hz)"
      width: 350
      timer: {
        shape: oval
        label: "timerfd\n(1000ms)"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      epoll: {
        shape: diamond
        label: "epoll_wait()"
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
      }
      update: {
        label: "Update & Render"
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
      }
      timer -> epoll: "wakeup"
      epoll -> update: "trigger"
      update -> timer: "reset"
    }
    data_sources: {
      label: "Data Sources"
      width: 350
      percpu_maps: {
        shape: class
        label: "Per-CPU Histograms"
        +map_type: "BPF_MAP_TYPE_PERCPU_ARRAY"
        +buckets: "64 per syscall"
        +update_rate: "100K/sec"
      }
      ringbuf: {
        shape: class
        label: "Ring Buffer Events"
        +map_type: "BPF_MAP_TYPE_RINGBUF"
        +event_size: "96 bytes"
        +update_rate: "1K/sec"
      }
      proc_map: {
        shape: class
        label: "Process Stats Hash"
        +map_type: "BPF_MAP_TYPE_HASH"
        +key: "pid_t"
        +entries: "1024 max"
      }
    }
    aggregation: {
      label: "Userspace Aggregation"
      width: 350
      sum_box: {
        label: |md
          **Per-CPU Summation:**
          c
          for (i = 0; i < num_cpus; i++)
            total += per_cpu[i];
          
        |
        width: 300
        style.fill: "#F3E5F5"
      }
    }
    probe_manager: {
      label: "Probe Manager"
      width: 350
      probe_state: {
        shape: sql_table
        label: "Probe State Table"
        p0: "probe_id | name | enabled | link_ptr"
        p1: "0 | sys_read | 1 | 0x7f..."
        p2: "1 | sys_write | 1 | 0x7f..."
        p3: "2 | sys_openat | 1 | 0x7f..."
        p4: "3 | tcp_state | 1 | 0x7f..."
        p5: "4 | sched_switch | 1 | 0x7f..."
      }
    }
  }
}
data_sources.percpu_maps -> aggregation.sum_box: "bpf_map_lookup_elem()\nreturns num_cpus values"
data_sources.ringbuf -> epoll: "EPOLLIN\nready"
data_sources.proc_map -> aggregation.sum_box: "iterate\nentries"
aggregation.sum_box -> update: "aggregated\ndata"
epoll -> probe_state: "config\nupdates" {
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  direction: right
  box1: {
    label: "1 Hz refresh"
    shape: rectangle
    style.fill: "#E8F5E9"
    width: 100
  }
  box2: {
    label: "Event-driven"
    shape: rectangle
    style.fill: "#E3F2FD"
    width: 100
  }
  box3: {
    label: "Per-CPU data"
    shape: rectangle
    style.fill: "#F3E5F5"
    width: 100
  }
}
refresh_cycle.style.stroke: transparent
data_sources.style.stroke: transparent
aggregation.style.stroke: transparent
probe_manager.style.stroke: transparent