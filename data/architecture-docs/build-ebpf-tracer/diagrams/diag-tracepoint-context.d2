direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Tracepoint Context: `sock:inet_sock_set_state`
  Struct layout provided by BTF for CO-RE portable access
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  context_struct: {
    direction: down
    label: "struct trace_event_raw_inet_sock_set_state (tracepoint context)"
    fields: {
      shape: sql_table
      label: "Tracepoint Arguments (kernel 5.15+)"
      common: "0x00 | u16          | common_type"
      flags: "0x02 | u8           | common_flags"
      preempt: "0x03 | u8          | common_preempt_count"
      pid: "0x04 | s32          | common_pid"
      skaddr: "0x08 | const void*  | skaddr"
      oldstate: "0x10 | int          | oldstate"
      newstate: "0x14 | int          | newstate"
      sport: "0x18 | __be16       | sport"
      dport: "0x1A | __be16       | dport"
      family: "0x1C | __u16        | family"
      protocol: "0x1E | __u16        | protocol"
      saddr: "0x20 | __u8[16]     | saddr"
      daddr: "0x30 | __u8[16]     | daddr"
      total: "Total: 64 bytes (varies by kernel)"
    }
    fields.style.fill: "#E8F4FD"
  }
  btf_section: {
    direction: down
    label: "BTF Type Information (vmlinux.h)"
    btf_data: {
      shape: sql_table
      label: "BTF encoded in vmlinux"
      t1: "struct offset | 0x08 | skaddr"
      t2: "struct offset | 0x10 | oldstate"
      t3: "struct offset | 0x14 | newstate"
      t4: "struct offset | 0x18 | sport"
      t5: "struct offset | 0x1A | dport"
      t6: "struct offset | 0x1C | family"
      note: "Offsets may differ per kernel"
    }
    btf_data.style.fill: "#FFF3E0"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  core_access: {
    direction: down
    label: "CO-RE Access Pattern"
    width: 380
    code: |'c
      // eBPF program uses BPF_CORE_READ
      SEC("tracepoint/sock/inet_sock_set_state")
      int handle_tcp(void *ctx) {
        struct trace_event_raw_* args = ctx;
        // CO-RE: offset resolved at load time
        __u64 sk = BPF_CORE_READ(args, skaddr);
        int old = BPF_CORE_READ(args, oldstate);
        int new = BPF_CORE_READ(args, newstate);
        // Not hardcoded: args->skaddr
        // libbpf patches with kernel's BTF
      }
    '|
  }
  relocation: {
    direction: down
    label: "Relocation Process"
    flow: {
      shape: class
      label: "Compile Time (clang)"
      step1: "Emit relocation record: need offset of oldstate"
      step2: "Store in .BTF.ext section"
    }
    flow.style.fill: "#E8F5E9"
    flow2: {
      shape: class
      label: "Load Time (libbpf)"
      step3: "Read kernel BTF from /sys/kernel/btf/vmlinux"
      step4: "Find struct trace_event_raw_* in BTF"
      step5: "Locate oldstate field offset"
      step6: "Patch bytecode with correct offset"
    }
    flow2.style.fill: "#FCE4EC"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_variants: {
    direction: down
    label: "Why CO-RE? Kernel Version Differences"
    k510: {
      shape: sql_table
      label: "Kernel 5.10"
      f1: "0x08 | skaddr"
      f2: "0x10 | oldstate"
      f3: "0x14 | newstate"
    }
    k510.style.fill: "#E3F2FD"
    k510.style.stroke: "#1976D2"
    k519: {
      shape: sql_table
      label: "Kernel 5.19"
      f1: "0x00 | skaddr      // MOVED!"
      f2: "0x08 | oldstate"
      f3: "0x0C | newstate"
      note: "Offsets changed"
    }
    k519.style.fill: "#FFEBEE"
    k519.style.stroke: "#D32F2F"
  }
  result: {
    direction: down
    label: "Result: Single Binary, All Kernels"
    box: {
      shape: rectangle
      label: |md
        **Before CO-RE**: Recompile for each kernel version
        **With CO-RE**: 
        1. Build once with `clang -target bpf -g`
        2. BTF embedded in .o file
        3. libbpf patches offsets at load
        4. Same binary works on 5.10, 5.15, 5.19, 6.x
      |
      width: 320
    }
    box.style.fill: "#E8F5E9"
    box.style.stroke: "#388E3C"
    box.style.stroke-width: 2
  }
}
context_struct -> core_access: "struct definition"
btf_section -> core_access: "BTF types"
core_access -> relocation: "relocation records"
relocation -> result: "patched bytecode"
kernel_variants -> result: "handles variations"
legend: {
  near: bottom-right
  label: "Legend"
  btf: "BTF provides type info"
  core: "CO-RE = portable access"
  rel: "Relocation = runtime patch"
}
legend.style.fill: "#F5F5F5"
legend.style.stroke: "#9E9E9E"