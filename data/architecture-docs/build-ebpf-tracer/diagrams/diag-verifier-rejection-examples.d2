direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Common BPF Verifier Rejections" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  rejection1: "1. Unbounded Loop" {
    direction: down
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    code1: {
      label: "eBPF Code"
      width: 320
      code: |'c
        SEC("kprobe/do_sys_open")
        int bad_loop(void *ctx) {
            int i = 0, sum = 0;
            // REJECTED: Verifier cannot
            // prove termination
            while (i < 1000) {
                sum += i;
                i++;
            }
            return sum;
        }
      '|
    }
    error1: {
      shape: callout
      style.fill: "#ff6b6b"
      style.font-color: "#1a1a1a"
      style.bold: true
      label: |'text
        Error: infinite loop detected
        (back-edge from insn 6 to 4)
      '|
    }
  }
  rejection2: "2. Uninitialized Variable" {
    direction: down
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    code2: {
      label: "eBPF Code"
      width: 320
      code: |'c
        SEC("kprobe/do_sys_open")
        int bad_uninit(void *ctx) {
            int value;
            u32 pid = bpf_get_current_pid_tgid();
            if (pid > 1000) {
                value = 42;
            }
            // REJECTED: value may be
            // uninitialized on else path
            return value;
        }
      '|
    }
    error2: {
      shape: callout
      style.fill: "#ff6b6b"
      style.font-color: "#1a1a1a"
      style.bold: true
      label: |'text
        Error: R0 !read_ok
        read from uninitialized stack
        off -4 size 4
      '|
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  rejection3: "3. Out-of-Bounds Access" {
    direction: down
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    code3: {
      label: "eBPF Code"
      width: 320
      code: |'c
        SEC("kprobe/do_sys_open")
        int bad_oob(void *ctx) {
            int arr[10];
            u32 idx = bpf_get_current_pid_tgid();
            idx &= 0xFF;  // 0-255
            // REJECTED: idx could be
            // >= 10, OOB access
            return arr[idx];
        }
      '|
    }
    error3: {
      shape: callout
      style.fill: "#ff6b6b"
      style.font-color: "#1a1a1a"
      style.bold: true
      label: |'text
        Error: invalid access to map
        value, value_size=40 off=0
        R0 max value is outside range
      '|
    }
  }
  rejection4: "4. Direct Pointer Dereference" {
    direction: down
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    code4: {
      label: "eBPF Code"
      width: 320
      code: |'c
        SEC("kprobe/do_sys_openat2")
        int bad_deref(struct pt_regs *ctx) {
            const char *fn;
            fn = (const char *)PT_REGS_PARM2(ctx);
            // REJECTED: Cannot directly
            // dereference kernel pointer
            char first = *fn;
            return first;
        }
      '|
    }
    error4: {
      shape: callout
      style.fill: "#ff6b6b"
      style.font-color: "#1a1a1a"
      style.bold: true
      label: |'text
        Error: R2 invalid mem access
        'fn' (otype=SCALAR_VALUE)
        implies >=0
      '|
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  rejection5: "5. Stack Size Exceeded" {
    direction: down
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    code5: {
      label: "eBPF Code"
      width: 320
      code: |'c
        struct big_event {
            char filename[512];
            char comm[64];
            u64 data[32];
        };  // Total: 832 bytes
        SEC("kprobe/do_sys_open")
        int bad_stack(void *ctx) {
            // REJECTED: 832 > 512 limit
            struct big_event e;
            bpf_get_current_comm(e.comm, 64);
            return 0;
        }
      '|
    }
    error5: {
      shape: callout
      style.fill: "#ff6b6b"
      style.font-color: "#1a1a1a"
      style.bold: true
      label: |'text
        Error: combined stack size
        of 832 bytes is too large.
        Limit is 512 bytes.
      '|
    }
  }
  rejection6: "6. Unchecked Helper Return" {
    direction: down
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    code6: {
      label: "eBPF Code"
      width: 320
      code: |'c
        SEC("kprobe/do_sys_open")
        int bad_unchecked(void *ctx) {
            char buf[64];
            const char *fn = ...;
            // REJECTED: Return not
            // checked before using buf
            bpf_probe_read_kernel_str(
                buf, sizeof(buf), fn);
            return buf[0];  // unsafe!
        }
      '|
    }
    error6: {
      shape: callout
      style.fill: "#ff6b6b"
      style.font-color: "#1a1a1a"
      style.bold: true
      label: |'text
        Error: invalid indirect read
        from stack off -64+0 size 1
        R0 min value is negative
      '|
    }
  }
}
legend: "Verifier Safety Properties" {
  near: bottom-center
  style.fill: "#1a2a1a"
  style.stroke: "#4a9f4a"
  style.stroke-width: 2
  width: 800
  prop1: "Termination: All loops must have statically provable upper bound"
  prop2: "Memory Safety: Every pointer access must be bounds-checked"
  prop3: "Initialization: Variables must be written before being read on all paths"
  prop4: "Stack Limit: Maximum 512 bytes of stack usage per program"
  prop5: "Helper Checks: Return values must be checked before using results"
}
arrow_legend: "Fix Strategy" {
  near: bottom-right
  style.fill: "#1a1a2a"
  style.stroke: "#6b9fff"
  fix1: "Use bpf_probe_read_kernel() for safe pointer access"
  fix2: "Use BPF_MAP_TYPE_PERCPU_ARRAY for large buffers"
  fix3: "Add explicit bounds checks: if (idx < ARRAY_SIZE)"
  fix4: "Check return: if (ret < 0) return error;"
}