vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # eBPF System Architecture Overview
  Compile → Verify → Load → Attach → Execute
| {near: top-center}
direction: right
# === COMPILATION STAGE ===
compilation: "1. Compilation Stage" {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  c_source: "C Source\ncode (.c)" {
    shape: rectangle
    style.fill: "#FAFAFA"
    icon: https://icons.terrastruct.com/dev%2Fcode.svg
  }
  clang: "Clang/LLVM\n-target bpf -g -O2" {
    shape: hexagon
    style.fill: "#FFE4B5"
  }
  bpf_obj: "BPF Object\n(.o)" {
    shape: rectangle
    style.fill: "#E8E8E8"
    style.multiple: true
  }
  btf_info: "BTF Debug Info\n(type metadata)" {
    shape: page
    style.fill: "#F0E68C"
  }
  c_source -> clang: "compile"
  clang -> bpf_obj: "emit"
  clang -> btf_info: "embed"
}
# === LOADING STAGE ===
loading: "2. Loading & Verification" {
  style.fill: "#FFF8E7"
  style.stroke: "#DAA520"
  style.stroke-width: 2
  libbpf: "libbpf\nUserspace" {
    shape: rectangle
    style.fill: "#98FB98"
    icon: https://icons.terrastruct.com/dev%2Fpackage.svg
  }
  verifier: "BPF Verifier\n(Abstract Interpretation)" {
    shape: diamond
    style.fill: "#FF6B6B"
    style.font-color: white
  }
  rejected: "REJECTED\n(program unsafe)" {
    shape: oval
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
    style.stroke-dash: 3
  }
  jit: "JIT Compiler\n(x86-64/ARM64)" {
    shape: rectangle
    style.fill: "#DDA0DD"
  }
  native_code: "Native\nMachine Code" {
    shape: rectangle
    style.fill: "#87CEEB"
  }
  libbpf -> verifier: "bpf() syscall\nload program"
  verifier -> rejected: "unsafe" {style.stroke-dash: 3; style.stroke: "#DC143C"}
  verifier -> jit: "verified ✓"
  jit -> native_code: "compile"
}
# === KERNEL EXECUTION STAGE ===
kernel: "3. Kernel Execution" {
  style.fill: "#F0FFF0"
  style.stroke: "#228B22"
  style.stroke-width: 2
  hook_points: "Hook Points" {
    style.fill: "#E6FFE6"
    kprobe: "kprobe\nfunction entry" {shape: circle; style.fill: "#98D8C8"}
    tracepoint: "tracepoint\nstable ABI" {shape: circle; style.fill: "#7FCDBB"}
    xdp: "XDP\npacket rx" {shape: circle; style.fill: "#41B6C4"}
    tc: "tc\ntraffic ctrl" {shape: circle; style.fill: "#2C7FB8"}
  }
  bpf_prog: "eBPF Program\nExecution Context" {
    shape: rectangle
    style.fill: "#90EE90"
    style.3d: true
    ctx: "struct pt_regs *ctx\n(current state)"
    helpers: "BPF Helpers\n(probe_read, ktime, etc.)"
    maps: "BPF Maps\n(key-value storage)"
    ctx -> helpers
    helpers -> maps
  }
  event: "Event Trigger\n(syscall, packet, etc.)" {
    shape: parallelogram
    style.fill: "#FFFACD"
  }
  event -> hook_points: "fires"
  hook_points -> bpf_prog: "invoke"
}
# === DATA TRANSFER STAGE ===
data_transfer: "4. Kernel↔Userspace" {
  style.fill: "#F5F5DC"
  style.stroke: "#8B4513"
  style.stroke-width: 2
  ringbuf: "BPF Ring Buffer\nBPF_MAP_TYPE_RINGBUF" {
    shape: cylinder
    style.fill: "#FFD700"
    style.fill-pattern: lines
  }
  percpu_map: "Per-CPU Array\ncontention-free" {
    shape: cylinder
    style.fill: "#87CEFA"
  }
  hash_map: "Hash Map\ncorrelation" {
    shape: cylinder
    style.fill: "#DDA0DD"
  }
  consumer: "Userspace Consumer\nring_buffer__poll()" {
    shape: rectangle
    style.fill: "#98FB98"
    icon: https://icons.terrastruct.com/dev%2Fterminal.svg
  }
  bpf_prog -> ringbuf: "bpf_ringbuf_submit()"
  bpf_prog -> percpu_map: "increment counters"
  bpf_prog -> hash_map: "store state"
  ringbuf -> consumer: "stream events"
  percpu_map -> consumer: "read + sum"
  hash_map -> consumer: "lookup"
}
# === SECURITY BOUNDARY ===
security: "Security Boundary" {
  style.fill: transparent
  style.stroke: "#8B0000"
  style.stroke-dash: 5
  style.stroke-width: 3
  kernel_space: "KERNEL SPACE\n(privileged)" {
    style.fill: "#FFE4E1"
    style.fill-pattern: dots
  }
  user_space: "USER SPACE\n(unprivileged)" {
    style.fill: "#F0FFFF"
    style.fill-pattern: dots
  }
  kernel_space -> user_space: "BPF syscall\n(CAP_BPF required)" {style.stroke: "#8B0000"; style.stroke-width: 2}
}
# === CONNECTIONS BETWEEN STAGES ===
compilation.bpf_obj -> loading.libbpf: "load"
loading.native_code -> kernel.hook_points: "attach"
kernel.bpf_prog -> data_transfer.ringbuf: "output"
# === CAPABILITY ANNOTATION ===
caps: |md
  **Capability Requirements:**
  - `CAP_BPF` (kernel 5.8+): Load BPF programs
  - `CAP_PERFMON`: Attach tracing programs
  - `CAP_NET_ADMIN`: Attach network programs
  - Pre-5.8: `CAP_SYS_ADMIN` (root)
| {near: bottom-left}
# === KEY INSIGHT ===
insight: |md
  **Key Insight:** The verifier proves safety
  *before* execution — no runtime checks.
  Programs are sandboxed callbacks that
  respond to kernel events.
| {near: bottom-right}
# === INVARIANTS BOX ===
invariants: "Invariants" {
  style.fill: "#FFF5EE"
  style.stroke: "#CD853F"
  inv1: "512-byte stack limit"
  inv2: "No unbounded loops"
  inv3: "Verified memory access"
  inv4: "Helper functions only"
  inv5: "No direct kernel deref"
}
# === PERFORMANCE NOTES ===
perf: |md
  **Performance:**
  - Probe overhead: <100ns
  - JIT → near-native speed
  - Per-CPU maps → zero contention
  - Ring buffer → lock-free transfer
| {near: top-right}