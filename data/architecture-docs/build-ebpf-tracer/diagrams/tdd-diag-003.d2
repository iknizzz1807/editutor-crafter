vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # BPF Verifier Path Exploration
  Abstract interpretation proving safety through exhaustive state tracking
|
title.near: top-center

direction: right

# Entry point
entry: {
  shape: circle
  label: "●"
  style: {
    fill: "#4A90D9"
    stroke: "#2E5A8C"
    font-color: white
    bold: true
  }
}

# Initial state
initial_state: {
  label: "Initial Register State\n────────────────\nR1: ctx pointer (PTR_TO_CTX)\nR10: stack pointer (PTR_TO_STACK)\nR2-R9: uninitialized (NOT_INIT)\nStack: [512 bytes uninit]"
  shape: rectangle
  style: {
    fill: "#E8F4FD"
    stroke: "#4A90D9"
    double-border: true
  }
}

entry -> initial_state: "program load"

# Instruction processing loop
instruction_fetch: {
  label: "Fetch Next Instruction\n[PC: offset]"
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#666"
}

initial_state -> instruction_fetch

# State update
state_update: {
  label: "Update Register State (Simulation)\n────────────────\n• Track type (scalar/ptr)\n• Track bounds (min/max_value)\n• Track alignment (off/mask)\n• Track nullability (ID tracking)"
  shape: rectangle
  style: {
    fill: "#FFF9E6"
    stroke: "#D4A500"
  }
}

instruction_fetch -> state_update: "execute instruction"

# Branch decision
branch_check: {
  label: "Conditional\nBranch?"
  shape: diamond
  style.fill: "#E6F3E6"
  style.stroke: "#2E7D32"
}

state_update -> branch_check

# Branch exploration - TRUE path
branch_true: {
  label: "TRUE Path\n────────────────\nAssume condition holds\nExplore with constrained state"
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
  }
}

branch_check -> branch_true: "yes (jump taken)" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

# Branch exploration - FALSE path
branch_false: {
  label: "FALSE Path\n────────────────\nAssume condition fails\nExplore with negated state"
  shape: rectangle
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
  }
}

branch_check -> branch_false: "no (fallthrough)" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}

# Safety checks for each path
safety_check_true: {
  label: "Safety Invariants?\n────────────────\n• Memory Access Bounds\n• Pointer Provenance\n• Reg/Stack Initialization\n• Helper Call Prototype"
  shape: diamond
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
}

safety_check_false: {
  label: "Safety Invariants?\n────────────────\n• Memory Access Bounds\n• Pointer Provenance\n• Reg/Stack Initialization\n• Helper Call Prototype"
  shape: diamond
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
}

branch_true -> safety_check_true
branch_false -> safety_check_false

# Rejection paths
reject_node: {
  label: "REJECT\n────────────────\nProgram Unsafe\nInvalid Instruction"
  shape: rectangle
  style: {
    fill: "#FF5252"
    stroke: "#B71C1C"
    font-color: white
    bold: true
  }
}

safety_check_true -> reject_node: "violation" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 3
  style.animated: true
}

safety_check_false -> reject_node: "violation" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 3
  style.animated: true
}

# Continue paths
continue_true: {
  label: "Queue State"
  shape: rectangle
  style.fill: "#A5D6A7"
  style.stroke: "#2E7D32"
}

continue_false: {
  label: "Queue State"
  shape: rectangle
  style.fill: "#A5D6A7"
  style.stroke: "#2E7D32"
}

safety_check_true -> continue_true: "pass"
safety_check_false -> continue_false: "pass"

# Merge point / State pruning
merge_point: {
  label: "State Pruning / Merge\n────────────────\nCompare current state\nwith previously visited:\n• If current is subtype of old\n• Terminate exploration"
  shape: rectangle
  style: {
    fill: "#E1BEE7"
    stroke: "#7B1FA2"
  }
}

continue_true -> merge_point
continue_false -> merge_point

# Loop detection
loop_check: {
  label: "Loop\nBack-edge?"
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}

merge_point -> loop_check

# Loop handling
loop_bounded: {
  label: "Bounded?\n(Verified Induction)"
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}

loop_check -> loop_bounded: "yes"

loop_continue: {
  label: "Continue with\nwidened state"
  shape: rectangle
  style.fill: "#FFE0B2"
  style.stroke: "#E65100"
}

loop_bounded -> loop_continue: "safe"
loop_bounded -> reject_node: "unbounded" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 3
}

loop_continue -> instruction_fetch

# Exit condition
exit_check: {
  label: "EXIT OP?"
  shape: diamond
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
}

loop_check -> exit_check: "no"
exit_check -> instruction_fetch: "no"

# Final Verification
verified: {
  label: "✓ VERIFIED\n────────────────\nAll paths proven safe\nProgram may execute"
  shape: rectangle
  style: {
    fill: "#4CAF50"
    stroke: "#2E7D32"
    font-color: white
    bold: true
    double-border: true
  }
}

exit_check -> verified: "yes (R0 valid)"

# Legend & Annotations
legend: {
  near: bottom-right
  state_tracking: |md
    ## Verifier State Tracking
    **Register Fields:**
    - `type`: PTR_TO_STACK, PTR_TO_MAP, SCALAR
    - `min/max`: Possible integer range
    - `align`: Memory alignment tracking
    - `off`: Pointer offset
  |
  state_tracking.shape: rectangle
  state_tracking.style.fill: white
}

complexity_note: |md
  ### Complexity Limits
  - **Max Instructions:** 1,000,000
  - **Max States:** 64K per program
  - **Stack Limit:** 512 Bytes
  - **Memory:** Bounds must be scalar constants
|
complexity_note.near: bottom-left
complexity_note.shape: rectangle
complexity_note.style: {
  fill: "#FFF8E1"
  stroke: "#FF8F00"
}