direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # CO-RE Relocation Process
  **Compile Once - Run Everywhere (CO-RE)**
  Enables portable eBPF programs by deferring field offset resolution to load-time via BTF.
| {near: top-center}

# ============ COMPILE TIME ============
compile_time: {
  label: "STEP 1: COMPILE TIME (Clang/LLVM)"
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 4
  }
  
  c_source: "eBPF C Source Code" {
    shape: rectangle
    tooltip: "Programmer uses CO-RE macros to access fields"
    label: |md
      c
      struct open_how *how;
      // Macro captures field access metadata
      u64 f = BPF_CORE_READ(how, flags);
      
    |
    style: {
      fill: "#FFF9E6"
      stroke: "#D4A500"
      font: mono
    }
  }
  
  clang: "Clang/LLVM Frontend" {
    shape: hexagon
    style: {
      fill: "#4A90D9"
      font-color: white
    }
  }
  
  btf_gen: "BTF Information Generator" {
    shape: rectangle
    style: {
      fill: "#7B68EE"
      font-color: white
    }
  }
  
  reloc_section: ".BTF.ext Section" {
    shape: cylinder
    style: {
      fill: "#9370DB"
      font-color: white
    }
  }
  
  reloc_record: "CO-RE Relocation Record (sizeof=16B)" {
    shape: sql_table
    style: {
      stroke: "#9370DB"
      stroke-width: 2
      fill: "#F3E5F5"
    }
    00: "u32 insn_off (0x42)" {constraint: "4 Bytes"}
    04: "u32 type_id (struct open_how)" {constraint: "4 Bytes"}
    08: "u32 access_str_off ('flags')" {constraint: "4 Bytes"}
    12: "u32 kind (BPF_CORE_FIELD_BYTE_OFFSET)" {constraint: "4 Bytes"}
  }
  
  macros_info: |md
    ### BPF CO-RE Macros
    - `BPF_CORE_READ(...)`: Read field safely
    - `bpf_core_type_id(...)`: Get local BTF ID
    - `bpf_core_field_exists(...)`: Guard logic
  | {
    near: bottom-left
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#9C27B0"
      stroke-dash: 2
    }
  }
  
  c_source -> clang: "ast"
  clang -> btf_gen: "generate debug info"
  btf_gen -> reloc_section: "emit CO-RE records"
  reloc_section -> reloc_record: "contains"
}

# ============ KERNEL BTF ============
kernel_btf: {
  label: "KERNEL ENVIRONMENT (/sys/kernel/btf/vmlinux)"
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 4
  }
  
  vmlinux_btf: "System BTF Database" {
    shape: document
    style.fill: "#C8E6C9"
  }
  
  kernel_layout_a: "Kernel v5.15 Layout" {
    shape: sql_table
    style.fill: "#A5D6A7"
    "0x00": "u64 flags" {constraint: "8B"}
    "0x08": "u64 mode" {constraint: "8B"}
    "0x10": "u64 resolve" {constraint: "8B"}
  }
  
  kernel_layout_b: "Kernel v6.1 Layout" {
    shape: sql_table
    style: {
      fill: "#A5D6A7"
      stroke: "#FF9800"
      stroke-dash: 3
    }
    "0x00": "u64 flags" {constraint: "8B"}
    "0x08": "u64 mode" {constraint: "8B"}
    "0x10": "u64 resolve" {constraint: "8B"}
    "0x18": "u64 extra_field" {constraint: "Padding/New Field"}
  }
  
  vmlinux_btf -> kernel_layout_a
  vmlinux_btf -> kernel_layout_b: "Structure may differ"
}

# ============ LOAD TIME ============
load_time: {
  label: "STEP 2: LOAD TIME (libbpf / Loader)"
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 4
  }
  
  libbpf: "Loader (libbpf)" {
    shape: hexagon
    style: {
      fill: "#FF9800"
      font-color: white
    }
  }
  
  core_resolver: "CO-RE Resolver Engine" {
    shape: rectangle
    style.fill: "#FFB74D"
  }
  
  type_match: "1. Fuzzy Name Matching" {
    shape: rectangle
    style.fill: "#FFE0B2"
  }
  
  offset_calc: "2. Target Offset Calculation" {
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF9800"
    }
  }
  
  bytecode_patch: "3. Bytecode Instruction Patch" {
    shape: rectangle
    style: {
      fill: "#FFECB3"
      stroke: "#FF9800"
      stroke-width: 2
      font: mono
    }
  }

  annotation_portability: |md
    ### Portability Guarantee
    Relocation allows the `flags` field to be 
    found even if offset shifts (e.g. version diff).
  | {
    near: bottom-right
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#FF9800"
      stroke-dash: 2
    }
  }

  annotation_failure: |md
    ### Relocation Guard
    If `flags` is missing in host kernel, 
    `libbpf` aborts load to ensure safety.
  | {
    near: top-right
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-dash: 2
    }
  }
  
  libbpf -> core_resolver: "bpf_object__load"
  core_resolver -> type_match: "Lookup 'struct open_how'"
  type_match -> offset_calc: "Find 'flags' member"
  offset_calc -> bytecode_patch: "Update insn at 0x42"
}

# ============ VERIFIED PROGRAM ============
verified: {
  label: "STEP 3: RUNTIME (Kernel In-Place)"
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 4
  }
  
  patched_bpf: "Patched BPF Bytecode" {
    shape: rectangle
    label: |md
      ### eBPF Instruction Stream
      
      **Original Compile-Time:**
      `0x42: r1 = *(u64 *)(r2 + 0xFFFFFFFF)`
      
      **Patched Load-Time:**
      `0x42: r1 = *(u64 *)(r2 + 0x00000000)`
    |
    style: {
      fill: "#BBDEFB"
      font: mono
      stroke: "#2196F3"
    }
  }
  
  verifier: "Kernel Verifier" {
    shape: diamond
    style: {
      fill: "#4CAF50"
      font-color: white
    }
  }
  
  patched_bpf -> verifier: "Load to JIT"
}

# ============ GLOBAL FLOW ============
compile_time.reloc_section -> load_time.libbpf: "Portable ELF (.o)" {
  style: {
    stroke: "#9370DB"
    stroke-width: 3
    animated: true
  }
}

kernel_btf.vmlinux_btf -> load_time.libbpf: "Host BTF Info" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
  }
}

load_time.bytecode_patch -> verified.patched_bpf: "Patched Offsets" {
  style: {
    stroke: "#FF9800"
    stroke-width: 3
    animated: true
  }
}

# ============ LEGEND ============
legend: {
  label: "CO-RE RELOCATION DOMAINS"
  grid-columns: 4
  near: bottom-center
  
  c1: "Compile-Time Artifacts" { style.fill: "#F3E5F5"; style.stroke: "#9C27B0" }
  c2: "Kernel State" { style.fill: "#E8F5E9"; style.stroke: "#4CAF50" }
  c3: "Loader Processing" { style.fill: "#FFF3E0"; style.stroke: "#FF9800" }
  c4: "Kernel Runtime" { style.fill: "#E3F2FD"; style.stroke: "#2196F3" }
}