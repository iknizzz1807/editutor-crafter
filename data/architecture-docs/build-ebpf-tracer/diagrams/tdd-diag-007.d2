vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Kprobe Context: Register State for x86-64
  ## BPF Tracepoint Argument Extraction
| {near: top-center}

direction: right

# --- PT_REGS MEMORY LAYOUT ---
# Representing the struct pt_regs as a memory stack with offsets
pt_regs_struct: "struct pt_regs (x86_64)" {
  style.fill: "#F3F4F6"
  style.stroke: "#374151"
  style.stroke-width: 2

  header: {
    grid-columns: 3
    grid-gap: 0
    style.fill: "#A855F7"
    style.font-color: white
    
    off: "Offset" { style.bold: true }
    fld: "Register Field" { style.bold: true }
    sz: "Size" { style.bold: true }
  }

  body: {
    grid-columns: 3
    grid-gap: 0
    style.fill: "#EFF6FF"

    # Row 1
    o15: "0x00" { style.font-color: gray }
    r15: "r15" { style.fill: "#DBEAFE" }
    s15: "8B"
    # Row 2
    o14: "0x08" { style.font-color: gray }
    r14: "r14" { style.fill: "#DBEAFE" }
    s14: "8B"
    # Row 3
    o13: "0x10" { style.font-color: gray }
    r13: "r13" { style.fill: "#DBEAFE" }
    s13: "8B"
    # Row 4
    o12: "0x18" { style.font-color: gray }
    r12: "r12" { style.fill: "#DBEAFE" }
    s12: "8B"
    # Row 5
    obp: "0x20" { style.font-color: gray }
    rbp: "rbp" { style.fill: "#DBEAFE" }
    sbp: "8B"
    # Row 6
    obx: "0x28" { style.font-color: gray }
    rbx: "rbx" { style.fill: "#DBEAFE" }
    sbx: "8B"
    # Row 7
    o11: "0x30" { style.font-color: gray }
    r11: "r11" { style.fill: "#DBEAFE" }
    s11: "8B"
    # Row 8
    o10: "0x38" { style.font-color: gray }
    r10: "r10" { style.fill: "#DBEAFE" }
    s10: "8B"
    # Row 9
    o9: "0x40" { style.font-color: gray }
    r9: "r9" { style.fill: "#DBEAFE" }
    s9: "8B"
    # Row 10
    o8: "0x48" { style.font-color: gray }
    r8: "r8" { style.fill: "#DBEAFE" }
    s8: "8B"
    # Row 11
    oax: "0x50" { style.font-color: gray }
    rax: "rax" { style.fill: "#DBEAFE" }
    sax: "8B"
    # Row 12
    ocx: "0x58" { style.font-color: gray }
    rcx: "rcx" { style.fill: "#DBEAFE" }
    scx: "8B"
    # Row 13
    odx: "0x60" { style.font-color: gray }
    rdx: "rdx" { style.fill: "#F97316"; style.font-color: white }
    sdx: "8B"
    # Row 14
    osi: "0x68" { style.font-color: gray }
    rsi: "rsi" { style.fill: "#F97316"; style.font-color: white }
    ssi: "8B"
    # Row 15
    odi: "0x70" { style.font-color: gray }
    rdi: "rdi" { style.fill: "#F97316"; style.font-color: white }
    sdi: "8B"
  }
}

# --- ABI ARGUMENT MAPPING ---
args_mapping: Logical Arguments {
  style.fill: "#ECFDF5"
  style.stroke: "#10B981"
  style.stroke-width: 2

  arg1: "Arg 1: dfd (int)" { style.fill: "#D1FAE5" }
  arg2: "Arg 2: *filename" { style.fill: "#D1FAE5" }
  arg3: "Arg 3: *how" { style.fill: "#D1FAE5" }
}

# --- BPF_KPROBE MACRO LOGIC ---
bpf_macro: BPF_KPROBE Macro Interface {
  style.fill: "#F0F9FF"
  style.stroke: "#0369A1"
  
  definition: |md
    c
    // Definition (libbpf)
    #define BPF_KPROBE(name, args...)          \
    SEC("kprobe/" #name)                       \
    int name(struct pt_regs *ctx, ##args)
    
  |
  
  usage: |md
    c
    // Implementation
    SEC("kprobe/do_sys_openat2")
    int BPF_KPROBE(trace_openat2, int dfd, 
                   const char *filename,
                   struct open_how *how)
    
  |
}

# --- CONNECTIONS & DATA FLOW ---

# pt_regs to logical arguments via PT_REGS_PARM macros
pt_regs_struct.body.rdi -> args_mapping.arg1: "PT_REGS_PARM1(ctx)" {
  style: {
    stroke: "#F97316"
    stroke-width: 2
    animated: true
  }
}

pt_regs_struct.body.rsi -> args_mapping.arg2: "PT_REGS_PARM2(ctx)" {
  style: {
    stroke: "#F97316"
    stroke-width: 2
    animated: true
  }
}

pt_regs_struct.body.rdx -> args_mapping.arg3: "PT_REGS_PARM3(ctx)" {
  style: {
    stroke: "#F97316"
    stroke-width: 2
    animated: true
  }
}

# Mapping arguments to the BPF handler
args_mapping -> bpf_macro.usage: "Macro provides typed access" {
  style.stroke-dash: 3
}

# Annotation for total size moved to root level to fix compiler error
pt_regs_footer: "sizeof(struct pt_regs) = 168 bytes (x86_64)" {
  shape: text
  style.italic: true
  near: bottom-right
}