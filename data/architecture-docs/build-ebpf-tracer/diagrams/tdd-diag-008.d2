vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    rejected: "#DC2626"
    accepted: "#16A34A"
    kernel_mem: "#7C3AED"
    bpf_prog: "#2563EB"
    error_path: "#F59E0B"
    state_box: "#FEF3C7"
  }
}

title: |md
  # bpf_probe_read_kernel Safety Flow
  **Direct Dereference** vs **Safe Probe Read** with verifier-guaranteed bounds checking
| {near: top-center}

direction: right

# ========== REJECTED PATH: Direct Dereference ==========
rejected_flow: {
  label: "REJECTED: Direct Pointer Dereference"
  style: {
    stroke: ${colors.rejected}
    stroke-width: 4
    fill: "#FEF2F2"
    border-radius: 10
  }

  direct_probe: {
    label: "eBPF Probe Handler"
    shape: rectangle
    style: {
      fill: ${colors.bpf_prog}
      font-color: white
      stroke-width: 2
    }
    code_direct: |go
      // DANGEROUS: Direct dereference
      const char *filename = PT_REGS_PARM2(ctx);
      char first = *filename;  // ← Verifier REJECTS
    |
  }

  kernel_ptr: {
    label: "Kernel Pointer\n(filename)"
    shape: hexagon
    style: {
      fill: ${colors.kernel_mem}
      font-color: white
      stroke-width: 2
    }
  }

  question_valid: {
    label: "Is pointer valid?"
    shape: diamond
    style.fill: "#E5E7EB"
  }

  null_case: {
    label: "Could be NULL\n→ Page fault\n→ Kernel panic"
    shape: rectangle
    style: {
      fill: ${colors.rejected}
      font-color: white
      stroke-width: 2
    }
  }

  invalid_case: {
    label: "Could be unmapped\n→ Page fault\n→ Kernel panic"
    shape: rectangle
    style: {
      fill: ${colors.rejected}
      font-color: white
      stroke-width: 2
    }
  }

  userspace_case: {
    label: "Could be userspace\n→ Privilege violation\n→ Kernel panic"
    shape: rectangle
    style: {
      fill: ${colors.rejected}
      font-color: white
      stroke-width: 2
    }
  }

  verifier_reject: {
    label: "VERIFIER REJECTION\n\"invalid mem access\"\n\"R2 invalid read from stack\""
    shape: rectangle
    style: {
      fill: "#1F2937"
      font-color: ${colors.rejected}
      bold: true
      multiple: true
      stroke-width: 3
    }
  }

  kernel_ptr -> direct_probe: "PT_REGS_PARM2(ctx)"
  direct_probe -> question_valid: "*filename"
  question_valid -> null_case: "NULL?"
  question_valid -> invalid_case: "Unmapped?"
  question_valid -> userspace_case: "Userspace?"
  
  null_case -> verifier_reject: "Cannot prove safety"
  invalid_case -> verifier_reject: "Cannot prove safety"
  userspace_case -> verifier_reject: "Cannot prove safety"
}

# ========== ACCEPTED PATH: Safe Probe Read ==========
accepted_flow: {
  label: "ACCEPTED: Safe Probe Read with Error Handling"
  style: {
    stroke: ${colors.accepted}
    stroke-width: 4
    fill: "#F0FDF4"
    border-radius: 10
  }

  safe_probe: {
    label: "eBPF Probe Handler"
    shape: rectangle
    style: {
      fill: ${colors.bpf_prog}
      font-color: white
      stroke-width: 2
    }
    code_safe: |go
      // SAFE: Bounds-checked read
      char buf[256];
      int ret = bpf_probe_read_kernel_str(
          buf, sizeof(buf), filename);
      if (ret < 0) {
          buf[0] = '\0';  // Handle error
          return 0;
      }
      // Use buf safely
    |
  }

  kernel_ptr_safe: {
    label: "Kernel Pointer\n(filename)"
    shape: hexagon
    style: {
      fill: ${colors.kernel_mem}
      font-color: white
      stroke-width: 2
    }
  }

  helper_call: {
    label: "bpf_probe_read_kernel_str()\nHelper Function"
    shape: rectangle
    style: {
      fill: "#DBEAFE"
      stroke: ${colors.bpf_prog}
      stroke-width: 2
    }
  }

  bounds_check: {
    label: "Bounds Check\nsize ≤ sizeof(buf)"
    shape: diamond
    style.fill: "#E5E7EB"
  }

  null_check: {
    label: "NULL check\nptr == NULL?"
    shape: diamond
    style.fill: "#E5E7EB"
  }

  valid_read: {
    label: "Safe Copy\ncopy_from_kernel_nofault()"
    shape: rectangle
    style: {
      fill: ${colors.accepted}
      font-color: white
      stroke-width: 2
    }
  }

  error_return: {
    label: "Return negative\nerror code\n(e.g., -EFAULT)"
    shape: rectangle
    style: {
      fill: ${colors.error_path}
      font-color: white
      stroke-width: 2
    }
  }

  error_handler: {
    label: "Error Handler\nbuf[0] = '\\0'\nreturn 0"
    shape: rectangle
    style: {
      fill: ${colors.error_path}
      font-color: white
      stroke-width: 2
    }
  }

  success_path: {
    label: "Success\nbuf contains valid data"
    shape: rectangle
    style: {
      fill: ${colors.accepted}
      font-color: white
      stroke-width: 2
    }
  }

  verifier_accept: {
    label: "VERIFIER APPROVES\n✓ All paths checked\n✓ No unsafe memory access\n✓ Error handling present"
    shape: rectangle
    style: {
      fill: "#1F2937"
      font-color: ${colors.accepted}
      bold: true
      multiple: true
      stroke-width: 3
    }
  }

  kernel_ptr_safe -> safe_probe: "PT_REGS_PARM2(ctx)"
  safe_probe -> helper_call: "bpf_probe_read_kernel_str(buf, 256, filename)"
  helper_call -> null_check
  
  null_check -> error_return: "Yes (NULL)"
  null_check -> bounds_check: "No (valid)"
  
  bounds_check -> error_return: "No (overflow)"
  bounds_check -> valid_read: "Yes"
  
  valid_read -> error_return: "Copy failed"
  valid_read -> success_path: "Copy succeeded"
  
  error_return -> error_handler: "ret < 0"
  error_handler -> verifier_accept
  success_path -> verifier_accept
}

# ========== Comparison Summary ==========
comparison: {
  label: "Key Differences"
  shape: rectangle
  style: {
    fill: "#F9FAFB"
    stroke: "#9CA3AF"
    stroke-width: 2
  }

  direct: |md
    ### ❌ Direct Dereference
    - No bounds checking
    - No NULL validation
    - No error handling
    - Verifier cannot prove safety
    - **Result: Program rejected**
  |

  safe: |md
    ### ✓ Safe Probe Read
    - Explicit size limit (256 bytes)
    - Helper handles NULL/unmapped
    - Return value checked
    - Graceful error handling
    - **Result: Program accepted**
  |

  direct -> safe: { style.opacity: 0 }
}

# ========== Verifier State Tracking ==========
verifier_state: {
  label: "Verifier Register State Tracking"
  shape: rectangle
  style: {
    fill: ${colors.state_box}
    stroke: ${colors.error_path}
    stroke-width: 2
  }

  state_before: |md
    **Before helper call:**
    
    - R1: ptr to buf (stack, fp-256)
    - R2: 256 (scalar, literal constant)
    - R3: ptr to filename (unknown kernel address)
  |

  state_after: |md
    **After helper call:**
    
    - R0: return value (scalar, integer range [-4095, 256])
         - `[0, 256]`: bytes read (success)
         - `[-4095, -1]`: error code (failure)
    - R1-R5: clobbered (scratch registers)
  |

  invariant: |md
    **Verifier Invariant:**
    The helper function guarantees that:
    1. Memory read never exceeds R2 bytes.
    2. Invalid addresses (NULL/unmapped) cause R0 < 0.
    3. No kernel page fault can occur (exception handler logic).
    4. Registers R1-R5 must be re-initialized before use.
  |
}

# ========== Global Flow Connections ==========
rejected_flow -> accepted_flow: "IMPLEMENTATION UPGRADE" {
  style: {
    stroke-dash: 5
    stroke-width: 2
    animated: true
  }
}

accepted_flow -> comparison: "Logical Summary"
comparison -> verifier_state: "Internal Mechanics"