vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # CAP_BPF Security Model
  Linux Capability Hierarchy for eBPF Operations
| {near: top-center}

direction: down

# Legend
legend: {
  near: top-right
  legend_box: "Legend: Capabilities" {
    shape: rectangle
    style.fill: "#f8f9fa"
    style.stroke: "#666666"
    style.stroke-width: 1
    
    cap_sys_admin_legend: "CAP_SYS_ADMIN" {
      style.fill: "#ff6b6b"
      style.stroke: "#c92a2a"
    }
    cap_bpf_legend: "CAP_BPF" {
      style.fill: "#4dabf7"
      style.stroke: "#1971c2"
    }
    cap_perfmon_legend: "CAP_PERFMON" {
      style.fill: "#69db7c"
      style.stroke: "#2f9e44"
    }
    cap_net_admin_legend: "CAP_NET_ADMIN" {
      style.fill: "#ffd43b"
      style.stroke: "#f59f00"
    }
  }
}

# Root capability
cap_sys_admin: CAP_SYS_ADMIN {
  shape: rectangle
  style: {
    fill: "#ff6b6b"
    stroke: "#c92a2a"
    stroke-width: 4
    font-color: "#ffffff"
    bold: true
  }
  note: |md
    **Legacy "God Mode"**
    - Full system administration
    - All eBPF operations
    - All other capabilities
    - **AVOID in production**
  |
}

# Modern capabilities (Kernel 5.8+)
modern_caps: Modern Capabilities (Kernel 5.8+) {
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  style.stroke-dash: 3
  
  cap_bpf: CAP_BPF {
    shape: rectangle
    style: {
      fill: "#4dabf7"
      stroke: "#1971c2"
      stroke-width: 2
      font-color: "#ffffff"
      bold: true
    }
    desc: |md
      **BPF Program Control**
      - Load eBPF programs
      - Create BPF maps
      - Read/write map entries
      - Query program info
    |
  }
  
  cap_perfmon: CAP_PERFMON {
    shape: rectangle
    style: {
      fill: "#69db7c"
      stroke: "#2f9e44"
      stroke-width: 2
      font-color: "#ffffff"
      bold: true
    }
    desc: |md
      **Performance Monitoring**
      - Access perf events
      - Attach tracing programs
      - Read performance counters
      - Access tracepoints
    |
  }
  
  cap_net_admin: CAP_NET_ADMIN {
    shape: rectangle
    style: {
      fill: "#ffd43b"
      stroke: "#f59f00"
      stroke-width: 2
      font-color: "#000000"
      bold: true
    }
    desc: |md
      **Network Administration**
      - Modify network config
      - Attach socket filters
      - XDP program attachment
      - TC (traffic control) programs
    |
  }
}

# Use case combinations
use_cases: Required Capability Combinations {
  style.fill: "#e9ecef"
  style.stroke: "#adb5bd"
  grid-columns: 1
  
  tracing: Tracing / Observability {
    shape: rectangle
    style.fill: "#d0ebff"
    style.stroke: "#339af0"
    caps: "CAP_BPF + CAP_PERFMON" {
      style.font: mono
      style.bold: true
    }
    examples: |md
      - Kprobes / Kretprobes
      - Tracepoints
      - Perf event programs
      - Ring buffer events
    |
  }
  
  networking: Networking / XDP {
    shape: rectangle
    style.fill: "#d3f9d8"
    style.stroke: "#51cf66"
    caps: "CAP_BPF + CAP_NET_ADMIN" {
      style.font: mono
      style.bold: true
    }
    examples: |md
      - XDP programs
      - TC classifier/actions
      - Socket filters
      - cgroup socket programs
    |
  }
  
  security: Security Monitoring {
    shape: rectangle
    style.fill: "#fff3bf"
    style.stroke: "#fcc419"
    caps: "CAP_BPF + CAP_PERFMON + CAP_NET_ADMIN" {
      style.font: mono
      style.bold: true
    }
    examples: |md
      - Full system observability
      - Network + syscall tracing
      - Security policy enforcement
      - Audit logging
    |
  }
}

# Pre-5.8 comparison
legacy_vs_modern: Before vs After Kernel 5.8 {
  style.fill: "#fff5f5"
  style.stroke: "#ff8787"
  
  before: Pre-5.8 (Legacy) {
    shape: rectangle
    style.fill: "#ffc9c9"
    style.stroke: "#fa5252"
    content: |md
      **Single capability required:**
      `CAP_SYS_ADMIN` (root)
      - All-or-nothing access
      - No fine-grained control
      - High security risk
      - Container: `privileged: true`
    |
  }
  
  after: Post-5.8 (Modern) {
    shape: rectangle
    style.fill: "#b2f2bb"
    style.stroke: "#40c057"
    content: |md
      **Principle of least privilege:**
      `CAP_BPF` for program loading
      `CAP_PERFMON` for tracing
      `CAP_NET_ADMIN` for networking
      - Granular permissions
      - Reduced attack surface
      - Container-friendly
    |
  }
}

# Container deployment
kubernetes: Kubernetes Deployment {
  style.fill: "#e7f5ff"
  style.stroke: "#74c0fc"
  
  pod_spec: Pod Security Context {
    shape: rectangle
    style.fill: "#d0ebff"
    style.font: mono
    content: |go
      spec:
        containers:
        - name: ebpf-agent
          securityContext:
            capabilities:
              add:
                - CAP_BPF
                - CAP_PERFMON
              # NOT: privileged: true
    |
  }
  
  comparison: {
    bad: "❌ privileged: true" {
      style.fill: "#ffc9c9"
      style.font: mono
    }
    good: "✓ capabilities.add: [CAP_BPF, CAP_PERFMON]" {
      style.fill: "#b2f2bb"
      style.font: mono
    }
  }
}

# Verification commands
verification: Verification Commands {
  style.fill: "#f8f9fa"
  style.stroke: "#868e96"
  
  check_kernel: |bash
    # Check kernel BTF support
    bpftool btf list
    # Check capability mode
    cat /proc/sys/kernel/unprivileged_bpf_disabled
    # 0 = unprivileged allowed (insecure)
    # 1 = CAP_BPF required (secure)
    # 2 = CAP_SYS_ADMIN required (legacy)
  |
  
  check_caps: |bash
    # Check current capabilities
    capsh --print
    # Run with specific capabilities
    capsh --caps="cap_bpf+eip cap_perfmon+eip" \
          -- -c "./ebpf_tracer"
  |
}

# Relationships
cap_sys_admin -> modern_caps.cap_bpf: supersedes {
  style.stroke-dash: 5
  style.stroke: "#868e96"
  label: "kernel 5.8+"
}

cap_sys_admin -> modern_caps.cap_perfmon: supersedes {
  style.stroke-dash: 5
  style.stroke: "#868e96"
}

cap_sys_admin -> modern_caps.cap_net_admin: includes {
  style.stroke-dash: 5
  style.stroke: "#868e96"
}

# Use case arrows
modern_caps.cap_bpf -> use_cases.tracing: required {
  style.stroke: "#4dabf7"
}

modern_caps.cap_perfmon -> use_cases.tracing: required {
  style.stroke: "#69db7c"
}

modern_caps.cap_bpf -> use_cases.networking: required {
  style.stroke: "#4dabf7"
}

modern_caps.cap_net_admin -> use_cases.networking: required {
  style.stroke: "#ffd43b"
}

# Footer note
footer: |md
  **Key Principle:** Even with CAP_BPF, the **verifier still validates** all code.
  Capabilities control *who* can load; the verifier controls *what* can run.
| {near: bottom-center}