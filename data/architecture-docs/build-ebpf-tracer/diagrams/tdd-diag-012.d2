vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B59B6"
    data: "#3498DB"
    pointer: "#E67E22"
    padding: "#95A5A6"
    footer: "#BDC3C7"
    text: "#2C3E50"
    offset: "#7F8C8D"
  }
}

title: |md
  # struct event Memory Layout
  **Total Size: 328 bytes (0x148)**
  Alignment: 8-byte aligned
| {near: top-center}

direction: right

header_section: {
  style.fill: ${colors.header}
  style.stroke: "#8E44AD"
  style.font-color: white
  label: |md
    ## Header Fields
    **Process Identification**
  |
}

data_section: {
  style.fill: ${colors.data}
  style.stroke: "#2980B9"
  style.font-color: white
  label: |md
    ## Data Fields
    **Event Payload**
  |
}

string_section: {
  style.fill: "#27AE60"
  style.stroke: "#1E8449"
  style.font-color: white
  label: |md
    ## String Fields
    **Variable Content**
  |
}

footer_section: {
  style.fill: ${colors.footer}
  style.stroke: "#7F8C8D"
  style.font-color: white
  label: |md
    ## Footer Fields
    **Metadata & Padding**
  |
}

memory_layout: {
  grid-rows: 17
  grid-columns: 4
  grid-gap: 0
  style.fill: white
  style.stroke: "#BDC3C7"
  style.font: mono
  style.font-size: 14

  # Column headers
  col_offset: "Offset" {
    style.fill: ${colors.offset}
    style.font-color: white
    style.bold: true
  }
  col_field: "Field" {
    style.fill: ${colors.offset}
    style.font-color: white
    style.bold: true
  }
  col_type: "Type" {
    style.fill: ${colors.offset}
    style.font-color: white
    style.bold: true
  }
  col_size: "Size" {
    style.fill: ${colors.offset}
    style.font-color: white
    style.bold: true
  }

  # Row 0: timestamp
  r0_off: "0x00" {style.fill: ${colors.data}}
  r0_field: "timestamp" {style.fill: ${colors.data}; style.bold: true}
  r0_type: "__u64" {style.fill: ${colors.data}}
  r0_size: "8 bytes" {style.fill: ${colors.data}}

  # Row 1: pid
  r1_off: "0x08" {style.fill: ${colors.header}}
  r1_field: "pid" {style.fill: ${colors.header}; style.bold: true}
  r1_type: "__u32" {style.fill: ${colors.header}}
  r1_size: "4 bytes" {style.fill: ${colors.header}}

  # Row 2: tid
  r2_off: "0x0C" {style.fill: ${colors.header}}
  r2_field: "tid" {style.fill: ${colors.header}; style.bold: true}
  r2_type: "__u32" {style.fill: ${colors.header}}
  r2_size: "4 bytes" {style.fill: ${colors.header}}

  # Row 3: uid
  r3_off: "0x10" {style.fill: ${colors.header}}
  r3_field: "uid" {style.fill: ${colors.header}; style.bold: true}
  r3_type: "__u32" {style.fill: ${colors.header}}
  r3_size: "4 bytes" {style.fill: ${colors.header}}

  # Row 4: gid
  r4_off: "0x14" {style.fill: ${colors.header}}
  r4_field: "gid" {style.fill: ${colors.header}; style.bold: true}
  r4_type: "__u32" {style.fill: ${colors.header}}
  r4_size: "4 bytes" {style.fill: ${colors.header}}

  # Row 5: dfd
  r5_off: "0x18" {style.fill: ${colors.data}}
  r5_field: "dfd" {style.fill: ${colors.data}; style.bold: true}
  r5_type: "__s32" {style.fill: ${colors.data}}
  r5_size: "4 bytes" {style.fill: ${colors.data}}

  # Row 6: ret_val
  r6_off: "0x1C" {style.fill: ${colors.data}}
  r6_field: "ret_val" {style.fill: ${colors.data}; style.bold: true}
  r6_type: "__s32" {style.fill: ${colors.data}}
  r6_size: "4 bytes" {style.fill: ${colors.data}}

  # Row 7: comm start
  r7_off: "0x20" {style.fill: "#27AE60"}
  r7_field: "comm[0]" {style.fill: "#27AE60"; style.bold: true}
  r7_type: "char[16]" {style.fill: "#27AE60"}
  r7_size: "16 bytes" {style.fill: "#27AE60"}

  # Row 8-11: filename
  r8_off: "0x30" {style.fill: "#27AE60"}
  r8_field: "filename[0-63]" {style.fill: "#27AE60"; style.bold: true}
  r8_type: "char[256]" {style.fill: "#27AE60"}
  r8_size: "256 bytes" {style.fill: "#27AE60"}
  r9_off: "0x70" {style.fill: "#27AE60"}
  r9_field: "filename[64-127]" {style.fill: "#27AE60"}
  r9_type: "..." {style.fill: "#27AE60"}
  r9_size: "" {style.fill: "#27AE60"}
  r10_off: "0xB0" {style.fill: "#27AE60"}
  r10_field: "filename[128-191]" {style.fill: "#27AE60"}
  r10_type: "..." {style.fill: "#27AE60"}
  r10_size: "" {style.fill: "#27AE60"}
  r11_off: "0xF0" {style.fill: "#27AE60"}
  r11_field: "filename[192-255]" {style.fill: "#27AE60"}
  r11_type: "..." {style.fill: "#27AE60"}
  r11_size: "" {style.fill: "#27AE60"}

  # Row 12: flags
  r12_off: "0x130" {style.fill: ${colors.data}}
  r12_field: "flags" {style.fill: ${colors.data}; style.bold: true}
  r12_type: "__u64" {style.fill: ${colors.data}}
  r12_size: "8 bytes" {style.fill: ${colors.data}}

  # Row 13: mode
  r13_off: "0x138" {style.fill: ${colors.data}}
  r13_field: "mode" {style.fill: ${colors.data}; style.bold: true}
  r13_type: "__u64" {style.fill: ${colors.data}}
  r13_size: "8 bytes" {style.fill: ${colors.data}}

  # Row 14: resolve
  r14_off: "0x140" {style.fill: ${colors.footer}}
  r14_field: "resolve" {style.fill: ${colors.footer}; style.bold: true}
  r14_type: "__u32" {style.fill: ${colors.footer}}
  r14_size: "4 bytes" {style.fill: ${colors.footer}}

  # Row 15: is_entry
  r15_off: "0x144" {style.fill: ${colors.footer}}
  r15_field: "is_entry" {style.fill: ${colors.footer}; style.bold: true}
  r15_type: "__u8" {style.fill: ${colors.footer}}
  r15_size: "1 byte" {style.fill: ${colors.footer}}

  # Row 16: padding
  r16_off: "0x145" {style.fill: ${colors.padding}}
  r16_field: "pad[3]" {style.fill: ${colors.padding}}
  r16_type: "__u8[3]" {style.fill: ${colors.padding}}
  r16_size: "3 bytes" {style.fill: ${colors.padding}}
}

visual_layout: {
  direction: right
  box: {
    style.fill: ${colors.header}
    style.stroke: "#8E44AD"
    style.stroke-width: 3
    label: |md
      **Header (36 bytes)**
      
      0x00-0x07: timestamp
      0x08-0x0B: pid
      0x0C-0x0F: tid
      0x10-0x13: uid
      0x14-0x17: gid
      0x18-0x1B: dfd
      0x1C-0x1F: ret_val
    |
  }
  arrow1: -> {
    label: ""
    style.stroke-width: 2
    style.stroke: "#BDC3C7"
  }
  box2: {
    style.fill: "#27AE60"
    style.stroke: "#1E8449"
    style.stroke-width: 3
    label: |md
      **Strings (272 bytes)**
      
      0x20-0x2F: comm[16]
      0x30-0x12F: filename[256]
    |
  }
  arrow2: -> {
    label: ""
    style.stroke-width: 2
    style.stroke: "#BDC3C7"
  }
  box3: {
    style.fill: ${colors.data}
    style.stroke: "#2980B9"
    style.stroke-width: 3
    label: |md
      **Open Flags (16 bytes)**
      
      0x130-0x137: flags
      0x138-0x13F: mode
    |
  }
  arrow3: -> {
    label: ""
    style.stroke-width: 2
    style.stroke: "#BDC3C7"
  }
  box4: {
    style.fill: ${colors.footer}
    style.stroke: "#7F8C8D"
    style.stroke-width: 3
    label: |md
      **Footer (8 bytes)**
      
      0x140-0x143: resolve
      0x144: is_entry
      0x145-0x147: padding
    |
  }
}

legend: {
  near: bottom-center
  style.fill: white
  style.stroke: "#BDC3C7"
  leg_title: "Color Legend" {
    style.bold: true
    style.underline: true
  }
  leg1: "Purple = Process/Header Fields" {style.fill: ${colors.header}; style.font-color: white}
  leg2: "Blue = Numeric Data Fields" {style.fill: ${colors.data}; style.font-color: white}
  leg3: "Green = String Buffers" {style.fill: "#27AE60"; style.font-color: white}
  leg4: "Gray = Padding/Reserved" {style.fill: ${colors.padding}; style.font-color: white}
  leg5: "Silver = Metadata/Footer" {style.fill: ${colors.footer}; style.font-color: white}
}

notes: {
  near: bottom-right
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
  label: |md
    ### Key Design Notes
    - **8-byte alignment** maintained throughout
    - **filename[256]** is largest field (78% of struct)
    - **Total: 328 bytes** (Fits in ~5 Cache Lines)
    - **comm[16]** matches kernel's `TASK_COMM_LEN`
    - **dfd = -100** means `AT_FDCWD` (current dir)
  |
}