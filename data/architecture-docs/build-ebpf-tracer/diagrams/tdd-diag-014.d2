vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # eBPF Tracer System Architecture
  *Technical Design Specification - Performance Monitoring & Tracing Subsystem*
| {near: top-center}

direction: right

kernel_space: Kernel Space {
  style: {
    fill: "#E8E8E8"
    stroke: "#666666"
    stroke-width: 2
  }

  kernel_core: Linux Kernel {
    style.fill: "#F5F5F5"
    style.stroke: "#888888"
    
    syscall_entry: Syscall Entry {
      style.fill: "#D4E6F1"
      label: "Syscall Dispatcher\n(IDT/MSR_LSTAR)"
    }
    tcp_stack: TCP Stack {
      style.fill: "#D4E6F1"
      label: "TCP/IP Stack\n(inet_sock_set_state)"
    }
    scheduler: Scheduler {
      style.fill: "#D4E6F1"
      label: "Process Scheduler\n(context_switch)"
    }
  }

  ebpf_vm: eBPF Virtual Machine {
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
    style.stroke-width: 2
    
    verifier: BPF Verifier {
      style.fill: "#ABEBC6"
      style.stroke: "#1E8449"
      label: "DAG Verifier\n(Safety Check)"
    }
    jit: JIT Compiler {
      style.fill: "#ABEBC6"
      style.stroke: "#1E8449"
      label: "JIT Compiler\n(BPF → x86_64)"
    }
    probe_handlers: Probe Handlers {
      style.fill: "#82E0AA"
      kprobe_openat: "kprobe\ndo_sys_openat2"
      kretprobe_openat: "kretprobe\ndo_sys_openat2"
      kprobe_read: "kprobe\n__x64_sys_read"
      kretprobe_read: "kretprobe\n__x64_sys_read"
      kprobe_write: "kprobe\n__x64_sys_write"
      kretprobe_write: "kretprobe\n__x64_sys_write"
      tp_tcp: "tracepoint\nsock:inet_sock_set_state"
      tp_sched: "tracepoint\nsched/sched_switch"
    }
  }

  bpf_maps: BPF Maps {
    style.fill: "#FCF3CF"
    style.stroke: "#D4AC0D"
    
    hash_start: Hash Map\nstart_times\n(tid → timestamp) {
      style.fill: "#F9E79F"
      tooltip: "Used for latency calculation"
    }
    percpu_hist: Per-CPU Array\nsyscall_histograms\n(1024 entries × N CPUs) {
      style.fill: "#F9E79F"
      style.stroke: "#B7950B"
      label: "Per-CPU Array\nsyscall_histograms\n[sizeof=(1024*8)*N_CPUs]"
    }
    hash_conn: Hash Map\nconnections\n(skaddr → conn_info) {
      style.fill: "#F9E79F"
    }
    ringbuf: Ring Buffer\nevents (16 MB) {
      style.fill: "#F5B7B1"
      style.stroke: "#C0392B"
      label: "BPF_MAP_TYPE_RINGBUF\nsize=16MB (Shared Page)"
    }
    config_map: Array Map\nconfig {
      style.fill: "#F9E79F"
    }
    percpu_stats: Per-CPU Array\nself_stats {
      style.fill: "#F9E79F"
    }
  }
}

userspace: Userspace {
  style: {
    fill: "#EBF5FB"
    stroke: "#2E86AB"
    stroke-width: 2
  }

  libbpf: libbpf Runtime {
    style.fill: "#AED6F1"
    skeleton: Skeleton\nLoader {
      style.fill: "#85C1E9"
    }
    core_reloc: CO-RE\nRelocations {
      style.fill: "#85C1E9"
      label: "BTF/CO-RE\nRelocations"
    }
    ringbuf_consumer: Ring Buffer\nConsumer {
      style.fill: "#85C1E9"
      label: "ring_buffer__poll()"
    }
  }

  probe_manager: Probe Manager {
    style.fill: "#D6EAF8"
    probe_lifecycle: Probe Lifecycle {
      style.fill: "#AED6F1"
      enable: "probe_enable()"
      disable: "probe_disable()\n↓\nbpf_link__destroy()"
    }
  }

  percpu_agg: Per-CPU Aggregator {
    style.fill: "#D6EAF8"
    sum_func: "percpu_aggregator_sum()\n↓\nΣ values[i] for all CPUs"
  }

  epoll_loop: Event Loop {
    style.fill: "#D6EAF8"
    epoll_create: "epoll_create1()"
    epoll_wait: "epoll_wait()\n    ↓\n  ┌─────────────┐\n  │ timer FD    │\n  │ ringbuf FD  │\n  └─────────────┘"
  }

  terminal_ui: Terminal UI {
    style.fill: "#E8DAEF"
    ansi_render: ANSI Escape\nRenderer {
      style.fill: "#D7BDE2"
    }
    refresh_timer: "timerfd\n(1000ms)"
  }

  dashboard: Dashboard State {
    style.fill: "#F5EEF8"
    # Fixed syntax: Wrapped labels containing brackets in quotes
    histograms: "Histograms[]"
    connections: "Connections[]"
    processes: "Processes[]"
    probes: "Probes[]"
  }
}

build_chain: Build Chain {
  style.fill: "#FAE5D3"
  clang: "clang -target bpf\n↓"
  bpf_obj: "BPF Object (.o)\n↓"
  bpftool_skel: "bpftool gen skeleton\n↓"
  skel_header: "Skeleton Header (.h)"
}

data_flow_connections: {
  style.stroke-dash: 3
  kernel_space.kernel_core.syscall_entry -> kernel_space.ebpf_vm.probe_handlers.kprobe_openat: "1. fires"
  kernel_space.kernel_core.syscall_entry -> kernel_space.ebpf_vm.probe_handlers.kretprobe_openat: "1. fires"
  kernel_space.kernel_core.tcp_stack -> kernel_space.ebpf_vm.probe_handlers.tp_tcp: "1. state change"
  kernel_space.kernel_core.scheduler -> kernel_space.ebpf_vm.probe_handlers.tp_sched: "1. ctx switch"
}

map_access_connections: {
  style.stroke: "#27AE60"
  kernel_space.ebpf_vm.probe_handlers.kprobe_openat -> kernel_space.bpf_maps.hash_start: "2. store tid→ts"
  kernel_space.ebpf_vm.probe_handlers.kretprobe_openat -> kernel_space.bpf_maps.hash_start: "2. lookup ts"
  kernel_space.ebpf_vm.probe_handlers.kretprobe_openat -> kernel_space.bpf_maps.percpu_hist: "3. increment bucket"
  kernel_space.ebpf_vm.probe_handlers.tp_tcp -> kernel_space.bpf_maps.hash_conn: "2. store/lookup"
  kernel_space.ebpf_vm.probe_handlers.tp_tcp -> kernel_space.bpf_maps.ringbuf: "3. submit event"
  kernel_space.ebpf_vm.probe_handlers.tp_sched -> kernel_space.bpf_maps.percpu_stats: "2. update stats"
}

userspace_kernel_boundary: {
  style.stroke: "#C0392B"
  style.stroke-width: 2
  userspace.libbpf.skeleton -> kernel_space.ebpf_vm.verifier: "bpf_prog_load()"
  kernel_space.ebpf_vm.verifier -> kernel_space.ebpf_vm.jit: "verified"
  kernel_space.ebpf_vm.jit -> kernel_space.ebpf_vm.probe_handlers: "native code"
}

userspace_data_flow: {
  style.stroke: "#2E86AB"
  kernel_space.bpf_maps.ringbuf -> userspace.libbpf.ringbuf_consumer: "events"
  kernel_space.bpf_maps.percpu_hist -> userspace.percpu_agg.sum_func: "lookup + sum"
  userspace.libbpf.ringbuf_consumer -> userspace.dashboard.connections: "TCP events"
  userspace.percpu_agg.sum_func -> userspace.dashboard.histograms: "aggregated counts"
  userspace.epoll_loop.epoll_wait -> userspace.terminal_ui.ansi_render: "timer tick"
  userspace.dashboard -> userspace.terminal_ui.ansi_render: "state"
}

probe_lifecycle_flow: {
  style.stroke: "#8E44AD"
  userspace.probe_manager.probe_lifecycle.enable -> kernel_space.ebpf_vm.probe_handlers: "bpf_program__attach_*"
  userspace.probe_manager.probe_lifecycle.disable -> kernel_space.ebpf_vm.probe_handlers: "bpf_link__destroy()"
  userspace.probe_manager -> userspace.dashboard.probes: "status update"
}

build_flow: {
  style.stroke: "#D4AC0D"
  build_chain.clang -> build_chain.bpf_obj -> build_chain.bpftool_skel -> build_chain.skel_header
  build_chain.skel_header -> userspace.libbpf.skeleton
}

legend: |md
  ### Architectural Legend
  **Control & Data Paths**
  - <span style="color:#27AE60">**Green**</span>: eBPF Map writes from Kernel Probes
  - <span style="color:#2E86AB">**Blue**</span>: Userspace asynchronous data consumption
  - <span style="color:#C0392B">**Red**</span>: Explicit Kernel/Userspace boundary crossings (syscalls)
  - <span style="color:#8E44AD">**Purple**</span>: Probe instrumentation lifecycle management
  - <span style="color:#D4AC0D">**Yellow**</span>: Static build-time compilation pipeline
| {
  near: bottom-left
  style.fill: "#FFFFFF"
  style.stroke: "#CCCCCC"
}