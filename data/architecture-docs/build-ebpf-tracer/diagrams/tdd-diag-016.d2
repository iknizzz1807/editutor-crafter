vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Entry/Exit Probe Correlation Flow
  Syscall Latency Measurement via Hash Map State Bridge
| {near: top-center}
# === TIMELINE SEQUENCE ===
# Phase markers
phase_1: "Phase 1\nEntry Probe" {
  shape: text
  style.font-size: 14
  style.bold: true
  style.font-color: "#5B21B6"
}
phase_2: "Phase 2\nKernel Execution" {
  shape: text
  style.font-size: 14
  style.bold: true
  style.font-color: "#0369A1"
}
phase_3: "Phase 3\nExit Probe" {
  shape: text
  style.font-size: 14
  style.bold: true
  style.font-color: "#047857"
}
# === STEP 1: SYSCALL ENTRY ===
step_1: {
  label: "Step 1: Syscall Entry"
  entry_event: "read() invoked\nby Thread TID=12345" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    style.stroke-width: 2
    style.font-size: 11
  }
  kprobe_entry: "Kprobe fires on\n__x64_sys_read" {
    shape: hexagon
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
    style.stroke-width: 2
    style.font-size: 11
  }
  entry_event -> kprobe_entry: triggers {style.stroke: "#3B82F6"; style.stroke-width: 2}
}
# === STEP 2: HASH MAP WRITE ===
step_2: {
  label: "Step 2: Hash Map Write"
  get_tid: "get_current_pid_tgid()\n→ TID = 12345" {
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#A855F7"
    style.stroke-width: 2
    style.font-size: 11
  }
  get_timestamp: "bpf_ktime_get_ns()\n→ start_ns = 9876543210" {
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#A855F7"
    style.stroke-width: 2
    style.font-size: 11
  }
  hash_map_write: "start_times[TID] = start_ns\nbpf_map_update_elem()" {
    shape: cylinder
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    style.stroke-width: 2
    style.font-size: 11
  }
  get_tid -> get_timestamp: then {style.stroke-dash: 3; style.stroke: "#A855F7"}
  get_timestamp -> hash_map_write: store {style.stroke: "#10B981"; style.stroke-width: 2; style.animated: true}
}
# === STEP 3: SYSCALL EXECUTION ===
step_3: {
  label: "Step 3: Syscall Execution"
  kernel_exec: "Kernel executes\nread() syscall\n(actual I/O happens)" {
    shape: rectangle
    style.fill: "#E0E7FF"
    style.stroke: "#6366F1"
    style.stroke-width: 2
    style.font-size: 11
    style.stroke-dash: 4
  }
  time_passes: "Time passes...\n~50μs - 10ms typical" {
    shape: text
    style.font-size: 10
    style.italic: true
    style.font-color: "#6B7280"
  }
  kernel_exec -> time_passes: {style.stroke: "transparent"}
}
# === STEP 4: SYSCALL EXIT ===
step_4: {
  label: "Step 4: Syscall Exit"
  exit_event: "read() returns\n(fd=5, bytes=1024)" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    style.stroke-width: 2
    style.font-size: 11
  }
  kretprobe_exit: "Kretprobe fires on\n__x64_sys_read return" {
    shape: hexagon
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
    style.stroke-width: 2
    style.font-size: 11
  }
  exit_event -> kretprobe_exit: triggers {style.stroke: "#3B82F6"; style.stroke-width: 2}
}
# === STEP 5: HASH MAP READ ===
step_5: {
  label: "Step 5: Hash Map Read"
  get_tid_exit: "get_current_pid_tgid()\n→ TID = 12345" {
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#A855F7"
    style.stroke-width: 2
    style.font-size: 11
  }
  hash_map_lookup: "lookup start_times[TID]\n→ start_ns = 9876543210" {
    shape: cylinder
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    style.stroke-width: 2
    style.font-size: 11
  }
  get_tid_exit -> hash_map_lookup: retrieve {style.stroke: "#10B981"; style.stroke-width: 2; style.animated: true}
}
# === STEP 6: DURATION COMPUTE ===
step_6: {
  label: "Step 6: Duration Compute"
  get_end_ts: "bpf_ktime_get_ns()\n→ end_ns = 9876593210" {
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#A855F7"
    style.stroke-width: 2
    style.font-size: 11
  }
  compute_duration: "duration_ns = end - start\n= 9876593210 - 9876543210\n= 50,000 ns (50 μs)" {
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 2
    style.font-size: 11
    style.bold: true
  }
  cleanup: "delete start_times[TID]\nbpf_map_delete_elem()" {
    shape: cylinder
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 2
    style.font-size: 11
  }
  update_histogram: "histogram[syscall][bucket]++\nlog2(50μs) → bucket 6" {
    shape: rectangle
    style.fill: "#DCFCE7"
    style.stroke: "#22C55E"
    style.stroke-width: 2
    style.font-size: 11
  }
  get_end_ts -> compute_duration: calculate {style.stroke: "#EF4444"; style.stroke-width: 2}
  compute_duration -> cleanup: cleanup {style.stroke-dash: 3; style.stroke: "#EF4444"}
  compute_duration -> update_histogram: record {style.stroke: "#22C55E"; style.stroke-width: 2; style.animated: true}
}
# === PHASE CONNECTIONS ===
phase_1 -> step_1: {style.stroke: "transparent"}
step_1.kprobe_entry -> step_2.get_tid: {style.stroke: "#F59E0B"; style.stroke-width: 2}
step_2.hash_map_write -> step_3.kernel_exec: "return 0\n(control back\nto kernel)" {style.stroke: "#6366F1"; style.stroke-width: 2; style.stroke-dash: 5}
step_3.kernel_exec -> step_4.exit_event: {style.stroke: "#6366F1"; style.stroke-width: 2; style.stroke-dash: 5}
step_4.kretprobe_exit -> step_5.get_tid_exit: {style.stroke: "#F59E0B"; style.stroke-width: 2}
step_5.hash_map_lookup -> step_6.get_end_ts: {style.stroke: "#A855F7"; style.stroke-width: 2}
# === HASH MAP DETAIL BOX ===
hash_map_detail: {
  label: "Hash Map: start_times"
  map_structure: {
    grid-rows: 4
    grid-columns: 2
    grid-gap: 0
    header_key: "Key (TID)" {
      style.fill: "#1F2937"
      style.font-color: "white"
      style.bold: true
      style.font-size: 10
    }
    header_val: "Value (start_ns)" {
      style.fill: "#1F2937"
      style.font-color: "white"
      style.bold: true
      style.font-size: 10
    }
    entry1_key: "12345" {
      style.fill: "#D1FAE5"
      style.font-size: 10
      style.bold: true
    }
    entry1_val: "9876543210" {
      style.fill: "#D1FAE5"
      style.font-size: 10
    }
    entry2_key: "67890" {
      style.fill: "#F3F4F6"
      style.font-size: 10
    }
    entry2_val: "9876123456" {
      style.fill: "#F3F4F6"
      style.font-size: 10
    }
    entry3_key: "..." {
      style.fill: "#F3F4F6"
      style.font-size: 10
      style.font-color: "#9CA3AF"
    }
    entry3_val: "..." {
      style.fill: "#F3F4F6"
      style.font-size: 10
      style.font-color: "#9CA3AF"
    }
  }
  map_info: |md
    **Type:** `BPF_MAP_TYPE_HASH`
    **Max Entries:** 10,240
    **Key:** `u32` (Thread ID)
    **Value:** `u64` (start timestamp)
    **CRITICAL:** Key by TID not PID!
    Multi-threaded processes share PID
    but have unique TIDs.
  | {
    shape: text
    style.font-size: 9
  }
  map_structure -> map_info: {style.stroke: "transparent"}
}
# === KEY INVARIANTS BOX ===
invariants: {
  label: "Key Invariants"
  inv1: "1. Each thread gets unique hash map entry" {
    shape: text
    style.font-size: 10
  }
  inv2: "2. Entry created on syscall ENTRY only" {
    shape: text
    style.font-size: 10
  }
  inv3: "3. Entry MUST be deleted on EXIT (prevent leak)" {
    shape: text
    style.font-size: 10
    style.font-color: "#DC2626"
    style.bold: true
  }
  inv4: "4. Missing entry = started before tracing" {
    shape: text
    style.font-size: 10
  }
  inv5: "5. Monotonic time guarantees non-negative duration" {
    shape: text
    style.font-size: 10
  }
  inv1 -> inv2 -> inv3 -> inv4 -> inv5: {style.stroke: "transparent"}
}
# === COMMON MISTAKES BOX ===
mistakes: {
  label: "Common Mistakes"
  mistake1: {
    label: "❌ Keying by PID instead of TID"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    style.font-size: 10
  }
  mistake2: {
    label: "❌ Forgetting bpf_map_delete_elem()"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    style.font-size: 10
  }
  mistake3: {
    label: "❌ Using wall-clock time (can jump)"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    style.font-size: 10
  }
  mistake4: {
    label: "❌ Not checking lookup result for NULL"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    style.font-size: 10
  }
  mistake1 -> mistake2 -> mistake3 -> mistake4: {style.stroke: "transparent"}
}
# === CONNECT DETAIL BOXES ===
step_2.hash_map_write -> hash_map_detail: "stores to" {style.stroke: "#10B981"; style.stroke-dash: 3}
hash_map_detail -> invariants: {style.stroke: "transparent"}
invariants -> mistakes: {style.stroke: "transparent"}
# === TIMING ANNOTATION ===
timing: {
  label: "Timing Characteristics"
  entry_overhead: "Entry probe: <50ns" {
    shape: text
    style.font-size: 10
    style.font-color: "#059669"
  }
  exit_overhead: "Exit probe: <100ns" {
    shape: text
    style.font-size: 10
    style.font-color: "#059669"
  }
  hash_ops: "Hash map ops: O(1)" {
    shape: text
    style.font-size: 10
    style.font-color: "#059669"
  }
  entry_overhead -> exit_overhead -> hash_ops: {style.stroke: "transparent"}
}
step_6.update_histogram -> timing: {style.stroke: "transparent"}
# === LEGEND ===
legend: {
  label: "Legend"
  leg1: "Event/Trigger" {shape: rectangle; style.fill: "#DBEAFE"; style.stroke: "#3B82F6"}
  leg2: "Probe Point" {shape: hexagon; style.fill: "#FEF3C7"; style.stroke: "#F59E0B"}
  leg3: "Data Operation" {shape: rectangle; style.fill: "#F3E8FF"; style.stroke: "#A855F7"}
  leg4: "Hash Map" {shape: cylinder; style.fill: "#D1FAE5"; style.stroke: "#10B981"}
  leg5: "Computation" {shape: rectangle; style.fill: "#FEE2E2"; style.stroke: "#EF4444"}
  leg6: "Output" {shape: rectangle; style.fill: "#DCFCE7"; style.stroke: "#22C55E"}
  leg1 -> leg2 -> leg3 -> leg4 -> leg5 -> leg6: {style.stroke: "transparent"}
}
mistakes -> legend: {style.stroke: "transparent"}