layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F59E0B"
    kernel: "#10B981"
    userspace: "#EC4899"
    map: "#6366F1"
    error: "#EF4444"
    text: "#64748B"
    padding: "#E2E8F0"
    border: "#1E293B"
  }
}

# === TITLE ===
title: {
  label: |md
    # eBPF Tracer: Multi-Source Dashboard Architecture
    ## Log2 Histogram Bucket Aggregation & TCP Lifecycle Tracking
    **Revision: 1.0.4** | **Status: Implementation Grade**
  |
  near: top-center
  style: {
    font-size: 18
    stroke-width: 0
    fill: transparent
  }
}

direction: right

# === CLASSES ===
classes: {
  k_component: {
    style: {
      fill: "#10B981"
      stroke: "#065F46"
      stroke-width: 2
      font-color: white
      bold: true
      border-radius: 4
    }
  }
  u_component: {
    style: {
      fill: "#EC4899"
      stroke: "#9D174D"
      stroke-width: 2
      font-color: white
      border-radius: 4
    }
  }
  bpf_map: {
    shape: cylinder
    style: {
      fill: "#6366F1"
      stroke: "#4338CA"
      font-color: white
      bold: true
    }
  }
  flow_label: {
    style: {
      font-size: 12
      font: mono
      bold: true
    }
  }
}

# === KERNEL SPACE ===
kernel_space: "Kernel Space (Ring 0)" {
  style: {
    fill: "#10B981"
    stroke: "#10B981"
    stroke-width: 4
    font-color: "#065F46"
    opacity: 0.1
  }

  syscalls: "Syscall Tracepoints / KProbes" {
    style.stroke-dash: 3
    read_entry: "kprobe:__x64_sys_read" {class: k_component}
    read_exit: "kretprobe:__x64_sys_read" {class: k_component}
    write_entry: "kprobe:__x64_sys_write" {class: k_component}
    write_exit: "kretprobe:__x64_sys_write" {class: k_component}
  }

  scheduler: "Process Scheduler" {
    style.stroke-dash: 3
    sched_switch: "tracepoint:sched/sched_switch" {class: k_component}
  }

  tcp_stack: "Network Stack" {
    style.stroke-dash: 3
    tcp_state: "tracepoint:sock/inet_sock_set_state" {class: k_component}
  }

  handlers: "eBPF Program Runtime (JIT Compiled)" {
    syscall_prog: "syscall_handler" {
      tooltip: "Calculates latency: exit_ts - entry_ts -> log2_index"
      style: {
        fill: "#10B981"
        double-border: true
        font-color: white
        bold: true
      }
    }
    sched_prog: "sched_handler" {
      label: "sched_handler"
      tooltip: "Tracks task_struct -> on_cpu duration"
      style: {
        fill: "#10B981"
        font-color: white
      }
    }
    tcp_prog: "tcp_handler" {
      label: "tcp_handler"
      tooltip: "Correlates sk_addr to connection lifecycle"
      style: {
        fill: "#10B981"
        font-color: white
      }
    }
  }

  maps: "BPF Maps (Global Shared Memory)" {
    percpu_hist: "BPF_MAP_TYPE_PERCPU_ARRAY\nsyscall_histograms" {
      class: bpf_map
      tooltip: "Key: u32 (syscall_id), Value: u64[64] (log2 buckets)"
    }
    start_times: "BPF_MAP_TYPE_HASH\nstart_timestamps" {
      class: bpf_map
      tooltip: "Key: u32 (tid), Value: u64 (ns)"
    }
    ringbuf: "BPF_MAP_TYPE_RINGBUF\ntcp_events" {
      class: bpf_map
      style.fill: "#8B5CF6"
    }
  }
}

# === MEMORY LAYOUT ===
histogram_layout: {
  label: "PERCPU_ARRAY Value Layout (per CPU)"
  shape: sql_table
  style: {
    fill: "#3B82F6"
    stroke: "#1E293B"
    stroke-width: 2
  }
  
  "0x00": "Bucket 0 (0-1 µs)" {constraint: "8 Bytes"}
  "0x08": "Bucket 1 (2-3 µs)" {constraint: "8 Bytes"}
  "0x10": "Bucket 2 (4-7 µs)" {constraint: "8 Bytes"}
  "0x18": "Bucket 3 (8-15 µs)" {constraint: "8 Bytes"}
  "0x20": "Bucket 4 (16-31 µs)" {constraint: "8 Bytes"}
  "0x28": "..." {constraint: "..."}
  "0x1F8": "Bucket 63 (Max)" {constraint: "8 Bytes"}
  
  "sizeof": "512 bytes per core (Total = 512 * nproc)" {constraint: "Metadata"}
}

# === USER SPACE ===
userspace: "Userspace Control Plane & Dashboard" {
  style: {
    fill: "#EC4899"
    stroke: "#EC4899"
    stroke-width: 4
    font-color: "#9D174D"
    opacity: 0.1
  }

  loader: "Agent / Loader (Golang/C++)" {
    libbpf: "libbpf core" {
      
    }
    skeleton: "BPF Skeleton" {
      tooltip: "Auto-generated glue code"
      style.stroke-dash: 2
    }
    mgr: "Link Manager" {
      tooltip: "bpf_link_create() / pin management"
    }
  }

  engine: "Data Processing Engine" {
    aggregator: "Aggregator" {
      tooltip: "Summation of PERCPU maps across N cores"
      style.multiple: true
    }
    poller: "Ring Buffer Poller" {
      tooltip: "epoll_wait() on BPF ringbuf FD"
    }
  }

  tui: "Terminal Dashboard (BubbleTea)" {
    style: {
      fill: "#1E293B"
      font-color: white
    }
    
    panel_stats: "System Stats"
    panel_hist: "Histogram: Syscall Latency" {
      style: {
        stroke: "#3B82F6"
        stroke-width: 3
      }
    }
    panel_tcp: "TCP Event Log" {
      style: {
        stroke: "#8B5CF6"
        stroke-width: 3
      }
    }
  }
}

# === FLOWS & CONNECTIONS ===

# Kernel Probes to Handlers
kernel_space.syscalls.read_entry -> kernel_space.handlers.syscall_prog: "fentry / kprobe" {class: flow_label}
kernel_space.syscalls.read_exit -> kernel_space.handlers.syscall_prog: "fexit / kretprobe" {class: flow_label}
kernel_space.tcp_stack.tcp_state -> kernel_space.handlers.tcp_prog: "tracepoint" {class: flow_label}
kernel_space.scheduler.sched_switch -> kernel_space.handlers.sched_prog: "context switch" {class: flow_label}

# Handler interactions with Maps
kernel_space.handlers.syscall_prog -> kernel_space.maps.start_times: "lookup/update (tid)" {
  style: {
    stroke: "#F59E0B"
    stroke-width: 2
  }
}
kernel_space.handlers.syscall_prog -> kernel_space.maps.percpu_hist: "atomic_add (idx)" {
  style: {
    stroke: "#3B82F6"
    stroke-width: 3
  }
}
kernel_space.handlers.tcp_prog -> kernel_space.maps.ringbuf: "bpf_ringbuf_submit()" {
  style: {
    stroke: "#8B5CF6"
    stroke-width: 3
    animated: true
  }
}

# Userspace Aggregation
userspace.engine.aggregator -> kernel_space.maps.percpu_hist: "bpf_map_lookup_elem" {
  style: {
    stroke: "#3B82F6"
    stroke-dash: 5
  }
}
userspace.engine.poller -> kernel_space.maps.ringbuf: "mmap consume" {
  style: {
    stroke: "#8B5CF6"
    stroke-dash: 3
  }
}

# Userspace Internal
userspace.loader.libbpf -> userspace.loader.skeleton: "generates"
userspace.loader.skeleton -> userspace.loader.mgr: "initializes"
userspace.engine.aggregator -> userspace.tui.panel_hist: "render"
userspace.engine.poller -> userspace.tui.panel_tcp: "update"

# === LEGEND ===
legend: {
  label: "Architecture Key"
  near: bottom-right
  style: {
    fill: "#F8FAFC"
    stroke: "#64748B"
    shadow: true
  }
  
  L1: "Kernel Execution" {
    style: {
      fill: "#10B981"
      font-color: white
      bold: true
    }
  }
  L2: "Userspace Processing" {
    style: {
      fill: "#EC4899"
      font-color: white
      bold: true
    }
  }
  L3: "BPF Map" {
    shape: cylinder
    style: {
      fill: "#6366F1"
      font-color: white
    }
  }
}

# === INVARIANTS & SPECS ===
invariants: {
  label: |md
    ### Critical Implementation Specs
    1. **Log2 Alignment**: Bucket $i$ represents range $[2^i, 2^{i+1}-1]$ ns.
    2. **Memory Safety**: `bpf_probe_read_kernel` for task_struct fields.
    3. **Performance**: PERCPU_ARRAY avoids spinlocks, critical for high frequency.
    4. **RingBuf**: Used for TCP events to preserve strict chronological order.
    5. **Overhead**: Total tracing overhead < 150ns per syscall.
    6. **Map Cleanup**: Syscall exit MUST delete tid from `start_timestamps`.
  |
  near: bottom-center
  style: {
    stroke: "#EF4444"
    stroke-width: 3
    fill: "#FFF5F5"
    font-size: 14
  }
}

# Constraints for ELK
histogram_layout.near: top-right
invariants.near: bottom-center
legend.near: bottom-right
title.near: top-center