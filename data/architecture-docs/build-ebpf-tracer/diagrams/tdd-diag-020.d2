direction: right
title: |md
  # Log2 Histogram Bucket Range Distribution
  64 buckets spanning 6+ orders of magnitude (sub-microsecond to hours)
| {near: top-center}
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  bucket-group: {
    style: {
      fill: "#E8F4FD"
      stroke: "#4A90D9"
      stroke-width: 2
      border-radius: 4
    }
  }
  bucket: {
    style: {
      fill: "#FFFFFF"
      stroke: "#B8D4E8"
      stroke-width: 1
      font-size: 11
    }
  }
  bucket-highlight: {
    style: {
      fill: "#FFE4B5"
      stroke: "#FF8C00"
      stroke-width: 2
      font-size: 11
      bold: true
    }
  }
  range-label: {
    style: {
      font-size: 10
      font-color: "#666666"
    }
  }
  count-bar: {
    style: {
      fill: "#4CAF50"
      stroke: "#388E3C"
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 10
      font-color: "#888888"
      italic: true
    }
  }
}
# Time Scale Reference
time_scale: {
  label: "Time Scale (Log2)"
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  width: 900
  scale_marker_0: "0μs"
  scale_marker_10: "1ms"
  scale_marker_20: "1s"
  scale_marker_30: "17min"
  scale_marker_40: "12days"
  scale_marker_63: "≈years"
}
# Sub-Microsecond Range (Bucket 0)
sub_micro: {
  label: "Sub-μs Range"
  class: bucket-group
  b0: {
    label: "Bucket 0\n0-1μs"
    class: bucket-highlight
    bar_0: {
      label: "234"
      shape: rectangle
      width: 60
      height: 20
      class: count-bar
    }
    pct_0: "15.4%" {class: range-label}
  }
  note_0: |md
    Trivial syscalls:
    `getpid()`, cache hits
  | {class: annotation}
}
# Fast Path (Buckets 1-3: 1-8μs)
fast_path: {
  label: "Fast Path\n1-8μs"
  class: bucket-group
  b1: {
    label: "Bucket 1\n1-2μs"
    class: bucket-highlight
    bar_1: {
      label: "456"
      shape: rectangle
      width: 80
      class: count-bar
    }
    pct_1: "29.9%" {class: range-label}
  }
  b2: {
    label: "Bucket 2\n2-4μs"
    class: bucket-highlight
    bar_2: {
      label: "312"
      shape: rectangle
      width: 65
      class: count-bar
    }
    pct_2: "20.5%" {class: range-label}
  }
  b3: {
    label: "Bucket 3\n4-8μs"
    class: bucket
    bar_3: {
      label: "189"
      shape: rectangle
      width: 50
      class: count-bar
    }
    pct_3: "12.4%" {class: range-label}
  }
  note_fast: |md
    Hot page cache reads,
    buffer writes
  | {class: annotation}
}
# Medium Range (Buckets 4-7: 8μs-128μs)
medium: {
  label: "Medium\n8μs-128μs"
  class: bucket-group
  b4: {
    label: "Bucket 4\n8-16μs"
    class: bucket
    bar_4: {label: "87"; shape: rectangle; width: 35; class: count-bar}
  }
  b5: {
    label: "Bucket 5\n16-32μs"
    class: bucket
    bar_5: {label: "45"; shape: rectangle; width: 25; class: count-bar}
  }
  b6: {
    label: "Bucket 6\n32-64μs"
    class: bucket
    bar_6: {label: "23"; shape: rectangle; width: 18; class: count-bar}
  }
  b7: {
    label: "Bucket 7\n64-128μs"
    class: bucket
    bar_7: {label: "12"; shape: rectangle; width: 12; class: count-bar}
  }
  note_med: |md
    SSD writes, HDD reads
  | {class: annotation}
}
# Network Range (Buckets 8-12: 128μs-4ms)
network: {
  label: "Network I/O\n128μs-4ms"
  class: bucket-group
  b8: {label: "Bucket 8\n128-256μs"; class: bucket; bar_8: {label: "8"; shape: rectangle; width: 10; class: count-bar}}
  b9: {label: "Bucket 9\n256-512μs"; class: bucket; bar_9: {label: "5"; shape: rectangle; width: 8; class: count-bar}}
  b10: {label: "Bucket 10\n512μs-1ms"; class: bucket; bar_10: {label: "3"; shape: rectangle; width: 6; class: count-bar}}
  b11: {label: "Bucket 11\n1-2ms"; class: bucket; bar_11: {label: "2"; shape: rectangle; width: 5; class: count-bar}}
  b12: {label: "Bucket 12\n2-4ms"; class: bucket; bar_12: {label: "1"; shape: rectangle; width: 4; class: count-bar}}
  note_net: |md
    Local network, same DC
  | {class: annotation}
}
# Slow Range (Buckets 13-20: 4ms-1s)
slow: {
  label: "Slow Path\n4ms-1s"
  class: bucket-group
  ellipsis_1: "..." {class: range-label; style.font-size: 16}
  b13_20: {
    label: "Buckets 13-20\n4ms → 1s"
    class: bucket
    style.fill: "#FFF8E1"
  }
  note_slow: |md
    Cross-region network,
    slow disk, NFS
  | {class: annotation}
}
# Pathological Range (Buckets 21-63)
pathological: {
  label: "Pathological\n>1s"
  class: bucket-group
  style.fill: "#FFEBEE"
  style.stroke: "#EF5350"
  ellipsis_2: "..." {class: range-label; style.font-size: 16}
  b21_63: {
    label: "Buckets 21-63\n1s → years"
    class: bucket
    style.fill: "#FFCDD2"
  }
  note_path: |md
    NFS hangs, pathological
    cases (usually empty)
  | {class: annotation}
}
# Connections showing flow
sub_micro -> fast_path: "Power-of-2\nbucketing" {style.stroke-dash: 3}
fast_path -> medium: {style.stroke-dash: 3}
medium -> network: {style.stroke-dash: 3}
network -> slow: {style.stroke-dash: 3}
slow -> pathological: {style.stroke-dash: 3}
# Formula box
formula: {
  label: |md
    **Bucket Computation:**
    
    bucket = 64 - __builtin_clzll(latency_us)
    Example: 3000ns → 3μs
    __builtin_clzll(3) = 62
    bucket = 64 - 62 = 2
    Range: [2, 4) μs ✓
    
  |
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    border-radius: 4
    font: mono
    font-size: 10
  }
}
# Statistics summary
stats: {
  label: |md
    **Distribution Summary:**
    - Total samples: 1,523
    - p50: 2μs (bucket 2)
    - p95: 8μs (bucket 4)
    - p99: 16μs (bucket 5)
    - 78% in fast path (0-8μs)
  |
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    border-radius: 4
    font-size: 11
  }
}
# Memory footprint
memory: {
  label: |md
    **Memory Footprint:**
    - 64 buckets × 8 bytes = 512 bytes
    - Per-CPU: 512 × num_cpus
    - 8 CPUs = 4KB total
    - 300× less than raw samples
  |
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    border-radius: 4
    font-size: 11
  }
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  hot: "Hot path (>10%)" {class: bucket-highlight}
  normal: "Normal traffic" {class: bucket}
  bar_legend: "Count bar (scaled)" {class: count-bar}
}