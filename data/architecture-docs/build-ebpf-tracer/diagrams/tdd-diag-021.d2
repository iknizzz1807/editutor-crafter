vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Per-Syscall Histogram Storage
  **BPF_MAP_TYPE_PERCPU_ARRAY**
  *Layout Specification for syscall_histograms*
| {near: top-center}

direction: down

# -----------------------------------------------------------------------------------------
# STYLING CLASSES
# -----------------------------------------------------------------------------------------
classes: {
  memory_header: {
    style: {
      fill: "#6f42c1"
      font-color: white
      bold: true
      stroke: "#4b2c85"
      stroke-width: 2
    }
  }
  memory_data: {
    style: {
      fill: "#cfe2ff"
      stroke: "#0d6efd"
      stroke-width: 1
    }
  }
  cache_line_boundary: {
    style: {
      stroke-dash: 3
      stroke: "#6c757d"
    }
  }
  page_boundary: {
    style: {
      stroke-width: 4
      stroke: "#212529"
    }
  }
}

# -----------------------------------------------------------------------------------------
# METADATA AND CALCULATION (Fixed the 'near' error by grouping in a container)
# -----------------------------------------------------------------------------------------
Technical_Specs: {
  near: top-left
  map_header: {
    class: memory_header
    label: "BPF Map: syscall_histograms"
    details: |md
      **Type**: `BPF_MAP_TYPE_PERCPU_ARRAY`
      **Max Entries**: 16,512 (258 slots × 64 buckets)
      **Key Size**: 4 Bytes (u32)
      **Value Size**: 8 Bytes (u64)
      **Total Size/CPU**: 132,096 Bytes (~129 KB)
    |
  }

  key_formula: {
    shape: rectangle
    style: {
      fill: "#f8f9fa"
      stroke: "#868e96"
      stroke-dash: 3
    }
    label: "Index Calculation Logic"
    formula: |md
      c
      u32 bucket_idx = bpf_log2l(latency_ns);
      u32 key = (syscall_nr * 64) + (bucket_idx & 63);
      
      **read(0)**: indices 0 - 63
      **write(1)**: indices 64 - 127
      **openat(257)**: indices 16448 - 16511
    |
  }
}

# -----------------------------------------------------------------------------------------
# MEMORY MAP VISUALIZATION (Byte Offsets & Field Sizes)
# -----------------------------------------------------------------------------------------
Memory_Map: {
  label: "Kernel Memory Layout (Per-CPU Data Segment)"
  
  # Offsets are shown on the left
  read_syscall: {
    label: "Syscall 0: read()"
    class: memory_data
    style.fill: "#d1e7dd"
    style.stroke: "#198754"
    
    row_0: {
      grid-columns: 8
      offsets: "0x0000 | 0B" {shape: text; style.font-size: 10}
      b0: "B0: 0-1µs" {width: 80; height: 40; style.fill: "#198754"; style.font-color: white}
      b1: "B1: 1-2µs" {width: 80; height: 40; style.fill: "#198754"; style.font-color: white}
      b2: "B2: 2-4µs" {width: 80; height: 40; style.fill: "#198754"; style.font-color: white}
      b3: "B3: 4-8µs" {width: 80; height: 40; style.fill: "#198754"; style.font-color: white}
      b4: "B4: 8-16µs" {width: 80; height: 40; style.fill: "#198754"; style.font-color: white}
      b5: "B5" {width: 80; height: 40}
      b6: "B6" {width: 80; height: 40}
      b7: "B7" {width: 80; height: 40}
      size: "64 Bytes" {shape: text; style.font-size: 10}
    }
    
    cache_line_0: "" {class: cache_line_boundary; width: 800; height: 0}
    
    row_last: {
      grid-columns: 8
      offsets: "0x01F8 | 504B" {shape: text; style.font-size: 10}
      ellip: "..." {width: 80; height: 40; style.stroke-width: 0}
      ellip2: "..." {width: 80; height: 40; style.stroke-width: 0}
      ellip3: "..." {width: 80; height: 40; style.stroke-width: 0}
      ellip4: "..." {width: 80; height: 40; style.stroke-width: 0}
      ellip5: "..." {width: 80; height: 40; style.stroke-width: 0}
      ellip6: "..." {width: 80; height: 40; style.stroke-width: 0}
      ellip7: "..." {width: 80; height: 40; style.stroke-width: 0}
      b63: "B63: Max" {width: 80; height: 40; style.fill: "#0f5132"; style.font-color: white}
      size: "8 Bytes" {shape: text; style.font-size: 10}
    }
  }

  write_syscall: {
    label: "Syscall 1: write()"
    class: memory_data
    style.fill: "#cfe2ff"
    
    row_0: {
      grid-columns: 8
      offsets: "0x0200 | 512B" {shape: text; style.font-size: 10}
      b0: "B0" {width: 80; height: 40; style.fill: "#0d6efd"; style.font-color: white}
      b1: "B1" {width: 80; height: 40; style.fill: "#0d6efd"; style.font-color: white}
      b2: "B2" {width: 80; height: 40; style.fill: "#0d6efd"; style.font-color: white}
      b3: "B3" {width: 80; height: 40; style.fill: "#0d6efd"; style.font-color: white}
      b4: "B4" {width: 80; height: 40; style.fill: "#0d6efd"; style.font-color: white}
      b5: "B5" {width: 80; height: 40}
      b6: "B6" {width: 80; height: 40}
      b7: "B7" {width: 80; height: 40}
      size: "64 Bytes" {shape: text; style.font-size: 10}
    }
  }

  gap: {
    label: "--- Indices 128 to 16447 (Reserved/Unused) ---"
    style: {
      stroke-dash: 5
      fill: "#f8f9fa"
      font-color: "#adb5bd"
    }
  }

  openat_syscall: {
    label: "Syscall 257: openat()"
    class: memory_data
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    
    row_0: {
      grid-columns: 8
      offsets: "0x20380 | 131968B" {shape: text; style.font-size: 10}
      b0: "B0" {width: 80; height: 40; style.fill: "#ffc107"}
      b1: "B1" {width: 80; height: 40; style.fill: "#ffc107"}
      b2: "B2" {width: 80; height: 40; style.fill: "#ffc107"}
      b3: "B3" {width: 80; height: 40; style.fill: "#ffc107"}
      b4: "B4" {width: 80; height: 40; style.fill: "#ffc107"}
      b5: "B5" {width: 80; height: 40}
      b6: "B6" {width: 80; height: 40}
      b7: "B7" {width: 80; height: 40}
      size: "64 Bytes" {shape: text; style.font-size: 10}
    }
  }
}

# -----------------------------------------------------------------------------------------
# PER-CPU DETAIL & AGGREGATION
# -----------------------------------------------------------------------------------------
Runtime_Aggregation: {
  label: "Aggregation View (Userspace Side)"
  style.fill: "#f1f3f5"

  cpu_grid: {
    grid-columns: 4
    grid-gap: 10
    c0: "CPU 0\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
    c1: "CPU 1\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
    c2: "CPU 2\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
    c3: "CPU 3\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
    c4: "CPU 4\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
    c5: "CPU 5\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
    c6: "CPU 6\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
    c7: "CPU 7\n[8B val]" {style.fill: "#e2e3e5"; width: 100; height: 60}
  }

  agg_logic: |md
    ### bpf_map_lookup_percpu_elem
    Total = Σ(CPU₀..CPUₙ)
  | {shape: rectangle; style.fill: "#fff"}

  total_box: "Resulting Histogram\n(Sum of all CPUs)" {
    shape: parallelogram
    style: { fill: "#0d6efd"; font-color: white; bold: true }
  }

  cpu_grid -> agg_logic -> total_box
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS & FLOW
# -----------------------------------------------------------------------------------------
Technical_Specs.key_formula -> Memory_Map.read_syscall: "Index into Array"
Memory_Map.read_syscall -> Runtime_Aggregation: "Read key 5 across all CPUs" {
  style.stroke-dash: 3
  style.animated: true
}

# Legend for colors
Legend: {
  near: bottom-right
  h: "Memory Types" {class: memory_header}
  d: "Active Data" {class: memory_data}
  p: "Padding/Gap" {style.fill: "#f8f9fa"; style.stroke-dash: 5}
}