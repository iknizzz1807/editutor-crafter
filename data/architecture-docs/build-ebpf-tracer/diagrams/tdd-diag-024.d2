layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: ||md
    # Config Map for Runtime Control
    **Runtime reconfiguration without eBPF program reload**
  ||
  near: top-center
}

direction: right

# ------------------------------------------------------------
# Userspace Control
# ------------------------------------------------------------
userspace: "Userspace Control Program" {
  style: {
    fill: "white"
    stroke: "#2E86AB"
    stroke-width: 2
  }

  update_call: |||md
    ### bpf_map_update_elem()
    c
    struct filter_config cfg = {
      .enabled = 1,
      .filter_pid = 1234,
      .filter_dport = 3306,
    };
    __u32 key = 0;
    bpf_map_update_elem(config_fd, &key, &cfg, BPF_ANY);
    
  |||
}

# ------------------------------------------------------------
# Config Map (BPF_MAP_TYPE_ARRAY)
# ------------------------------------------------------------
config_map: "Config Map\nBPF_MAP_TYPE_ARRAY" {
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
  }

  # Simulation of byte-offsets/header
  header: {
    grid-columns: 2
    grid-gap: 0
    style.fill: "#FFE0B2"
    key_h: "Key: u32 (4B)" {
      style.bold: true
    }
    val_h: "Value: struct filter_config (32B)" {
      style.bold: true
    }
  }

  entry0: {
    grid-columns: 2
    grid-gap: 0
    style.fill: "#FFF8E1"
    key0: "[ 0x00 ]" {
      style.font: mono
    }
    value0: ||md
      **Active Config State**
      - enabled: 1 (bool)
      - filter_pid: 1234
      - filter_dport: 3306
      - filter_sport: 0
      - daddr_mask: 24
    ||
  }
}

# ------------------------------------------------------------
# eBPF Program (Logic)
# ------------------------------------------------------------
ebpf_program: "eBPF Program\n(Kernel Space)" {
  style: {
    fill: "white"
    stroke: "#2E7D32"
    stroke-width: 2
  }

  check_code: |||md
    c
    // Runtime Lookup
    __u32 key = 0;
    struct filter_config *cfg;
    cfg = bpf_map_lookup_elem(&config, &key);

    if (!cfg || cfg->enabled == 0) return 0;

    // Hot-swappable Filter Logic
    if (cfg->filter_pid != 0 && pid != cfg->filter_pid) {
      return 0; 
    }
    if (cfg->filter_dport != 0 && dport != cfg->filter_dport) {
      return 0;
    }
    
  |||
}

# ------------------------------------------------------------
# Traced Events
# ------------------------------------------------------------
syscalls: "Traced Syscalls" {
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
  read: "read()" {
    shape: diamond
    style.fill: "#E1BEE7"
  }
  write: "write()" {
    shape: diamond
    style.fill: "#E1BEE7"
  }
  openat: "openat()" {
    shape: diamond
    style.fill: "#E1BEE7"
  }
}

# ------------------------------------------------------------
# Connections
# ------------------------------------------------------------
userspace.update_call -> config_map: "Update Element\n(Non-blocking)" {
  style: {
    stroke: "#2E86AB"
    stroke-width: 3
    animated: true
  }
}

config_map -> ebpf_program: "bpf_map_lookup_elem()" {
  style: {
    stroke: "#E65100"
    stroke-dash: 3
  }
}

syscalls.read -> ebpf_program: "Trigger" {
  style.stroke: "#7B1FA2"
}
syscalls.write -> ebpf_program: "Trigger" {
  style.stroke: "#7B1FA2"
}
syscalls.openat -> ebpf_program: "Trigger" {
  style.stroke: "#7B1FA2"
}

# ------------------------------------------------------------
# Annotations and Lifecycle
# ------------------------------------------------------------
pattern_note: {
  label: ||md
    ## Feature Flag Pattern
    This mimics systems like LaunchDarkly/Unleash:
    - **Config Store**: BPF map (Global state)
    - **Decision Point**: eBPF probe logic
    - **Control Plane**: Userspace CLI/Daemon

    | Operation | Latency | Overhead |
    |-----------|---------|----------|
    | Map Update | < 1ms | Negligible |
    | Map Lookup | ~20ns | Minimal |
    | Progam Reload| ~500ms | High (Missed events) |
  ||
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 2
  }
}

lifecycle: "Maintenance Lifecycle Comparison" {
  traditional: "Static Approach (Hardcoded)" {
    style.fill: "#FFEBEE"
    t1: "Update Code"
    t2: "Compile"
    t3: "Unload"
    t4: "Reload"
    t5: "Attach"

    t1 -> t2 -> t3 -> t4 -> t5
  }

  runtime: "Dynamic Approach (Config Map)" {
    style.fill: "#E8F5E9"
    r1: "Update Map Value" {
      style: {
        fill: "#C8E6C9"
        bold: true
      }
    }
  }

  traditional -> runtime: "Eliminates Steps 2-5" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 4
    }
  }
}