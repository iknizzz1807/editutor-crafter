vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B7280"
    data: "#3B82F6"
    highlight: "#EF4444"
    success: "#10B981"
    target: "#F59E0B"
    bg_light: "#F9FAFB"
  }
}

title: |md
  # Percentile Calculation from Histogram
  **Algorithm: total count → p50/p95/p99 targets → cumulative sum → find bucket**
| {near: top-center}

direction: right

# STEP 1: Input Histogram Data
step1: {
  label: "STEP 1: Input Histogram Data"
  style: {
    fill: "${colors.header}"
    font-color: white
  }
  histogram: {
    label: "Syscall Latency Histogram\n(read syscall)"
    style: {
      fill: "${colors.data}"
      font-color: white
    }
    bucket0: "Bucket 0: 1,234"
    bucket1: "Bucket 1: 2,567"
    bucket2: "Bucket 2: 3,890"
    bucket3: "Bucket 3: 1,456"
    bucket4: "Bucket 4: 890"
    dots: "..."
    bucket63: "Bucket 63: 12"
  }
}

# STEP 2: Calculate Total Count
step2: {
  label: "STEP 2: Calculate Total Count"
  style: {
    fill: "${colors.header}"
    font-color: white
  }
  calc: {
    label: ||md
      **Sum all buckets:**
      
      c
      total = 0;
      for (int i = 0; i < 64; i++) {
        total += histogram[i];
      }
      
    ||
    style.fill: white
    result: "total = 15,678 samples"
    result.style: {
      fill: "${colors.success}"
      font-color: white
      bold: true
    }
  }
}

# STEP 3: Compute Percentile Targets
step3: {
  label: "STEP 3: Compute Percentile Targets"
  style: {
    fill: "${colors.header}"
    font-color: white
  }
  targets: {
    style.fill: white
    p50: {
      label: "p50 target\n= total × 0.50\n= 7,839"
      style: {
        fill: "${colors.target}"
        font-color: white
      }
    }
    p95: {
      label: "p95 target\n= total × 0.95\n= 14,894"
      style: {
        fill: "${colors.target}"
        font-color: white
      }
    }
    p99: {
      label: "p99 target\n= total × 0.99\n= 15,521"
      style: {
        fill: "${colors.target}"
        font-color: white
      }
    }
  }
}

# STEP 4: Cumulative Scan
step4: {
  label: "STEP 4: Cumulative Sum Scan"
  style: {
    fill: "${colors.header}"
    font-color: white
  }
  scan: {
    label: ||md
      **Algorithm:**
      
      c
      cumulative = 0;
      for (int i = 0; i < 64; i++) {
        cumulative += histogram[i];
        if (cumulative >= target) return i;
      }
      
    ||
    style.fill: white
  }
}

# STEP 5: Trace Example
step5: {
  label: "STEP 5: Example Trace"
  style: {
    fill: "${colors.header}"
    font-color: white
  }
  trace: {
    style.fill: white
    row0: {
      label: "Bucket 0 (0-4μs)"
      style.fill: "#F3F4F6"
      count0: "count: 1,234"
      count0.style.fill: "${colors.data}"
      count0.style.font-color: white
      cum0: "cumulative: 1,234"
      check0: "< 7,839 (p50)"
      check0.style.fill: "#FCA5A5"
    }
    row1: {
      label: "Bucket 1 (4-8μs)"
      style.fill: "#F3F4F6"
      count1: "count: 2,567"
      count1.style.fill: "${colors.data}"
      count1.style.font-color: white
      cum1: "cumulative: 3,801"
      check1: "< 7,839 (p50)"
      check1.style.fill: "#FCA5A5"
    }
    row2: {
      label: "Bucket 2 (8-12μs)"
      style.fill: "#F3F4F6"
      count2: "count: 3,890"
      count2.style.fill: "${colors.data}"
      count2.style.font-color: white
      cum2: "cumulative: 7,691"
      check2: "< 7,839 (p50)"
      check2.style.fill: "#FCA5A5"
    }
    row3: {
      label: "Bucket 3 (12-16μs)"
      style: {
        fill: "${colors.highlight}"
        font-color: white
        bold: true
      }
      count3: "count: 1,456"
      count3.style.fill: "${colors.data}"
      count3.style.font-color: white
      cum3: "cumulative: 9,147"
      cum3.style: {
        fill: "${colors.highlight}"
        font-color: white
        bold: true
      }
      check3: "≥ 7,839 ✓"
      check3.style: {
        fill: "${colors.success}"
        font-color: white
        bold: true
      }
    }
    found: "p50 found at Bucket 3\nUpper bound: 16μs"
    found.style: {
      fill: "${colors.success}"
      font-color: white
      bold: true
    }
  }
}

# STEP 6: Output
step6: {
  label: "STEP 6: Report Results"
  style: {
    fill: "${colors.header}"
    font-color: white
  }
  output: {
    label: ||md
      **Percentile Report:**
      | Percentile | Bucket | Range |
      |------------|--------|-------|
      | p50 | 3 | 12-16μs |
      | p95 | 6 | 64-128μs |
      | p99 | 8 | 256-512μs |

      **Interpretation:**
      - 50% of syscalls complete in <16μs
      - 95% of syscalls complete in <128μs
      - 99% of syscalls complete in <512μs
    ||
    style.fill: white
  }
}

# Flow arrows
step1 -> step2: "Sum\nbuckets"
step2 -> step3: "Compute\ntargets"
step3 -> step4: "Scan\nbuckets"
step4 -> step5: "Find\nbuckets"
step5 -> step6: "Report\nupper bounds"

# Legend
legend: {
  near: bottom-right
  style.fill: white
  title: "Legend"
  title.style.bold: true
  found_marker: "Green = Percentile found"
  found_marker.style.fill: "${colors.success}"
  found_marker.style.font-color: white
  target_marker: "Orange = Target value"
  target_marker.style.fill: "${colors.target}"
  target_marker.style.font-color: white
  highlight_marker: "Red = Matching bucket"
  highlight_marker.style.fill: "${colors.highlight}"
  highlight_marker.style.font-color: white
}

# Complexity note
complexity: {
  near: bottom-left
  label: ||md
    **Performance Specification:**
    - **Time Complexity:** O(N) where N is number of buckets (Fixed at 64).
    - **Space Complexity:** O(1) beyond histogram storage.
    - **Resolution:** Limited by bucket width (log2 scaling typically).
    - **Safety:** Always report the *upper bound* of the bucket for conservative estimation.
  ||
  style: {
    fill: "#FEF3C7"
    stroke: "#F59E0B"
  }
}