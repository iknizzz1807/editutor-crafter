direction: right
title: |md
  # Userspace Histogram Display Format
| {near: top-center}
header: Header Row {
  shape: rectangle
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  syscall_name: Syscall: read (total: 1523 samples)
}
divider1: Divider {
  shape: rectangle
  width: 700
  height: 10
  style.fill: "#CCCCCC"
}
column_headers: Column Headers {
  shape: rectangle
  style.fill: "#F5F5F5"
  latency_col: Latency
  count_col: Count
  percent_col: Percent
  dist_col: Distribution
}
divider2: Divider {
  shape: rectangle
  width: 700
  height: 10
  style.fill: "#CCCCCC"
}
bucket_0: Bucket 0 (0-1μs) {
  shape: rectangle
  style.fill: "#E3F2FD"
  range: 0-1μs
  count: 234
  percent: 15.4%
  bar: ████████████
}
bucket_1: Bucket 1 (1-2μs) {
  shape: rectangle
  style.fill: "#BBDEFB"
  range: 1-2μs
  count: 456
  percent: 29.9%
  bar: █████████████████████████
}
bucket_2: Bucket 2 (2-4μs) {
  shape: rectangle
  style.fill: "#90CAF9"
  range: 2-4μs
  count: 312
  percent: 20.5%
  bar: ████████████████
}
bucket_3: Bucket 3 (4-8μs) {
  shape: rectangle
  style.fill: "#64B5F6"
  range: 4-8μs
  count: 189
  percent: 12.4%
  bar: ██████████
}
bucket_4: Bucket 4 (8-16μs) {
  shape: rectangle
  style.fill: "#42A5F5"
  range: 8-16μs
  count: 87
  percent: 5.7%
  bar: █████
}
bucket_5: Bucket 5 (16-32μs) {
  shape: rectangle
  style.fill: "#2196F3"
  range: 16-32μs
  count: 34
  percent: 2.2%
  bar: ██
}
divider3: Divider {
  shape: rectangle
  width: 700
  height: 10
  style.fill: "#CCCCCC"
}
percentile_row: Percentile Summary {
  shape: rectangle
  style.fill: "#E8F5E9"
  p50: p50: 2μs
  p95: p95: 8μs
  p99: p99: 16μs
}
legend: Format Legend {
  near: bottom-center
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  explanation: |md
    **Bucket Range**: Log₂ power-of-2 microsecond ranges
    **Count**: Total events in bucket (aggregated from per-CPU maps)
    **Percent**: (count / total) × 100
    **Bar**: Proportional to max bucket count (max 40 chars)
  |
}
header -> divider1 -> column_headers -> divider2
column_headers -> bucket_0 -> bucket_1 -> bucket_2 -> bucket_3 -> bucket_4 -> bucket_5
bucket_5 -> divider3 -> percentile_row