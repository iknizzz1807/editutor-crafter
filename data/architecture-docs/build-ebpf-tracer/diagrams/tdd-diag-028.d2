vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: "Tracepoint vs Kprobe Stability" {
  near: top-center
  style: {
    font-size: 32
    bold: true
  }
}

# === KPROBE APPROACH (Unstable) ===
kprobe_section: "Kprobe on Internal Function - Brittle Path" {
  style: {
    fill: "#FFE4E1"
    stroke: "#CD5C5C"
    stroke-width: 2
  }

  kernel_5_15: "Kernel v5.15 (Legacy)" {
    style.fill: "#FFF0F0"
    
    func_old: {
      shape: rectangle
      label: |'md
**`tcp_set_state(sk, state)`**
c
void tcp_set_state(
  struct sock *sk, 
  int new_state
)

'|
      style.fill: "#90EE90"
    }

    kprobe_old: "Kprobe\nAttached ✓" {
      shape: circle
      style.fill: "#32CD32"
    }
    
    kprobe_old -> func_old: "BPF_PROG_TYPE_KPROBE" {
      style: {
        stroke: orange
        stroke-width: 2
      }
    }
  }

  upgrade_path: "Kernel Maintenance / Upgrade" {
    shape: parallelogram
    style: {
      fill: "#FFF0F0"
      stroke: "#8B0000"
      stroke-width: 4
      stroke-dash: 5
    }
  }

  kernel_5_19: "Kernel v5.19 (Modern)" {
    style.fill: "#FFF0F0"
    
    func_new: {
      shape: rectangle
      label: |'md
**`__tcp_set_state(sk, state, fast)`**
c
void __tcp_set_state(
  struct sock *sk,
  int new_state,
  bool fast_path  // Signature Change!
)

'|
      style.fill: "#FFB6C1"
    }

    kprobe_broken: "Kprobe\nMISSING ✗" {
      shape: circle
      style: {
        fill: "#FF6347"
        stroke: "#8B0000"
        stroke-width: 3
        double-border: true
      }
    }
    
    kprobe_broken -> func_new: "symbol not found" {
      style: {
        stroke: red
        stroke-dash: 3
        opacity: 0.6
      }
    }
  }
  
  kernel_5_15 -> upgrade_path -> kernel_5_19
}

# === TRACEPOINT APPROACH (Stable) ===
tracepoint_section: "Tracepoint (Stable ABI Contract)" {
  style: {
    fill: "#E0FFE0"
    stroke: "#228B22"
    stroke-width: 2
  }

  tp_kernel_5_15: "Kernel v5.15" {
    style.fill: "#F0FFF0"
    
    tracepoint_def: {
      shape: rectangle
      label: |'md
**`sock:inet_sock_set_state`**
c
// Stable tracepoint contract:
struct trace_event_raw_inet_sock_set_state {
  const void *skaddr; // offset 8
  int oldstate;       // offset 16
  int newstate;       // offset 20
  __u16 sport;        // offset 24
  __u16 dport;        // offset 26
};

'|
      style.fill: "#98FB98"
    }

    ebpf_tp_old: "eBPF\nAttached ✓" {
      shape: circle
      style.fill: "#32CD32"
    }
    
    ebpf_tp_old -> tracepoint_def: "BPF_PROG_TYPE_TRACEPOINT" {
      style: {
        stroke: orange
        stroke-width: 2
      }
    }
  }

  tp_upgrade: "Kernel Upgrade (Transparent)" {
    shape: parallelogram
    style: {
      fill: "#F0FFF0"
      stroke: "#006400"
      stroke-width: 4
    }
  }

  tp_kernel_5_19: "Kernel v5.19" {
    style.fill: "#F0FFF0"
    
    tracepoint_same: {
      shape: rectangle
      label: |'md
**`sock:inet_sock_set_state`**
c
// SAME STABLE CONTRACT:
struct trace_event_raw_inet_sock_set_state {
  const void *skaddr;    // Layout preserved
  int oldstate;          // Offset verified
  int newstate;          // ABI stable
  // ... (No logic changes needed)
};

'|
      style.fill: "#98FB98"
    }

    ebpf_tp_new: "eBPF\nAttached ✓" {
      shape: circle
      style.fill: "#32CD32"
    }
    
    ebpf_tp_new -> tracepoint_same: "No re-compilation" {
      style: {
        stroke: "#32CD32"
        stroke-width: 2
      }
    }
  }
  
  tp_kernel_5_15 -> tp_upgrade -> tp_kernel_5_19
}

# === COMPARISON SUMMARY ===
comparison: {
  grid-columns: 2
  style.fill: transparent
  style.stroke: transparent

  k_char: {
    label: |'md
### ❌ Kprobe Characteristics
| Aspect | Behavior |
| :--- | :--- |
| **Target** | Internal non-exported functions |
| **Stability** | No guarantees - can change anytime |
| **Renaming** | Common (e.g., `__tcp` vs `tcp`) |
| **Inlining** | Compiler may remove function entirely |
| **Context** | Full access to CPU registers/args |
'|
    style: {
      fill: "#FFF0F0"
      stroke: "#CD5C5C"
      font-size: 14
    }
  }

  t_char: {
    label: |'md
### ✓ Tracepoint Characteristics
| Aspect | Behavior |
| :--- | :--- |
| **Target** | Explicitly exported static hooks |
| **Stability** | Guaranteed across versions (ABI) |
| **Renaming** | Extremely rare (requires deprecation) |
| **Inlining** | Always preserved as hook point |
| **Context** | Filtered via structured trace event |
'|
    style: {
      fill: "#F0FFF0"
      stroke: "#228B22"
      font-size: 14
    }
  }
}

# === RECOMMENDATION ===
recommendation: {
  label: |'md
### 🎯 Implementation Decision Matrix
**Use Kprobes when:**
- High-granularity debugging of logic not exposed by hooks.
- Capturing function local variables (requires DWARF info).
- Temporary patching or prototyping.

**Use Tracepoints when:**
- Developing production monitoring tools (e.g., `bpftrace`, `datadog-agent`).
- Requirement for "compile once, run everywhere" (CO-RE) portability.
- Targeting high-security environments where internal symbols are hidden.
'|
  style: {
    fill: "#F5F5DC"
    stroke: "#DAA520"
    stroke-width: 2
    border-radius: 8
  }
}

# === LEGEND ===
legend: {
  near: bottom-right
  stable_icon: "Stable ABI" {
    shape: circle
    style.fill: "#32CD32"
  }
  broken_icon: "Broken/Missing" {
    shape: circle
    style.fill: "#FF6347"
  }
}

kprobe_section -> tracepoint_section: "Recommended Migration Path" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
    stroke-dash: 5
  }
}