direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

classes: {
  state: {
    shape: rectangle
    style: {
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
  active: {
    style: {
      fill: "#4CAF50"
      font-color: white
    }
  }
  closing: {
    style: {
      fill: "#FF9800"
      font-color: white
    }
  }
  closed: {
    style: {
      fill: "#9E9E9E"
      font-color: white
    }
  }
  wait: {
    style: {
      fill: "#2196F3"
      font-color: white
    }
  }
  listen: {
    style: {
      fill: "#9C27B0"
      font-color: white
    }
  }
  transition: {
    style: {
      stroke-width: 2
      font-size: 12
    }
  }
  passive: {
    style.stroke-dash: 3
  }
  active_trans: {
    style.stroke: "#4CAF50"
  }
  trigger: {
    shape: text
    style.font-size: 11
    style.italic: true
  }
}

# --- States Definition ---

CLOSED: "CLOSED\n━━━━━━━\nInitial State / Terminal" {
  class: [state; closed]
  style.double-border: true
}

LISTEN: "LISTEN\n━━━━━━\nWaiting for\nremote SYN" {
  class: [state; listen]
}

SYN_RCVD: "SYN_RCVD\n━━━━━━━\nSYN sent,\nwaiting ACK" {
  class: [state; active]
}

SYN_SENT: "SYN_SENT\n━━━━━━━\nSYN sent,\nwaiting SYN-ACK" {
  class: [state; active]
}

ESTABLISHED: "ESTABLISHED\n━━━━━━━━━━\nConnection active\nFull duplex data" {
  class: [state; active]
  style: {
    fill: "#2E7D32"
    shadow: true
    stroke-width: 4
  }
}

# Active Close Path (Initiator)
FIN_WAIT_1: "FIN_WAIT_1\n━━━━━━━━━\nFIN sent,\nwaiting ACK" {
  class: [state; closing]
}

FIN_WAIT_2: "FIN_WAIT_2\n━━━━━━━━━\nFIN-ACK received\nwaiting FIN" {
  class: [state; closing]
}

CLOSING: "CLOSING\n━━━━━━\nSimultaneous close\nwaiting ACK" {
  class: [state; closing]
}

TIME_WAIT: "TIME_WAIT\n━━━━━━━━\nWaiting 2MSL\n(60s typical)" {
  class: [state; wait]
}

# Passive Close Path (Receiver)
CLOSE_WAIT: "CLOSE_WAIT\n━━━━━━━━\nFIN received\nwaiting app close" {
  class: [state; closing]
}

LAST_ACK: "LAST_ACK\n━━━━━━━━\nFIN sent,\nwaiting ACK" {
  class: [state; closing]
}

# --- Annotations & Metadata ---

invariants: |md
  ### TCP State Invariants (RFC 9293)
  *   **CLOSED**: No TCB, no connection exists.
  *   **LISTEN**: Server is waiting for an incoming connection.
  *   **SYN_SENT**: Active open initiated; waiting for matching SYN.
  *   **SYN_RCVD**: Received SYN; acknowledged and sent own SYN.
  *   **ESTABLISHED**: Handshake complete; data transfer can occur.
  *   **FIN_WAIT_1**: Local application closed; FIN segment sent.
  *   **FIN_WAIT_2**: Remote side acknowledged our FIN.
  *   **CLOSING**: Both sides initiated close simultaneously.
  *   **TIME_WAIT**: Segment lifetime enforcement; ensures remote ACK delivery.
  *   **CLOSE_WAIT**: Remote side closed; local app must now close.
  *   **LAST_ACK**: Local FIN sent after receiving remote FIN; waiting for final ACK.
| {
  near: top-right
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
    font-size: 11
  }
}

legend: {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#E0E0E0"
  }
  title: "Transition Legend" {
    shape: text
    style.bold: true
  }
  active_legend: "━━ Active Open (Client Path)" {
    shape: text
    style.font-color: "#4CAF50"
  }
  passive_legend: "┅┅ Passive Open (Server Path)" {
    shape: text
    style.font-color: "#9C27B0"
  }
  close_legend: "━━ Close / Error Path" {
    shape: text
    style.font-color: "#FF9800"
  }
}

# --- State Transitions ---

# Passive Open Path (Server)
CLOSED -> LISTEN: "passive OPEN\n(socket, bind, listen)" {
  class: [transition; passive]
  style.stroke: "#9C27B0"
}

LISTEN -> SYN_RCVD: "rcv SYN\nsend SYN, ACK" {
  class: [transition; passive]
  style.stroke: "#9C27B0"
}

SYN_RCVD -> ESTABLISHED: "rcv ACK\n(handshake ok)" {
  class: [transition]
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}

# Active Open Path (Client)
CLOSED -> SYN_SENT: "active OPEN\nsend SYN" {
  class: [transition; active_trans]
}

SYN_SENT -> ESTABLISHED: "rcv SYN, ACK\nsend ACK" {
  class: [transition; active_trans]
  style.stroke-width: 3
}

# Simultaneous Open (Special case)
SYN_SENT -> SYN_RCVD: "rcv SYN\nsend ACK" {
  class: transition
  style.stroke: "#E91E63"
  style.stroke-dash: 5
}

# Active Close Path (Client initiates close)
ESTABLISHED -> FIN_WAIT_1: "CLOSE\nsend FIN" {
  class: [transition]
  style.stroke: "#FF9800"
}

FIN_WAIT_1 -> FIN_WAIT_2: "rcv ACK\n(waiting for remote FIN)" {
  class: [transition]
  style.stroke: "#FF9800"
}

FIN_WAIT_1 -> CLOSING: "rcv FIN\nsend ACK\n(simultaneous)" {
  class: [transition]
  style.stroke: "#E91E63"
}

FIN_WAIT_2 -> TIME_WAIT: "rcv FIN\nsend ACK" {
  class: [transition]
  style.stroke: "#FF9800"
}

TIME_WAIT -> CLOSED: "timeout (2MSL)" {
  class: [transition]
  style.stroke: "#2196F3"
}

# Passive Close Path (Server/Remote initiates close)
ESTABLISHED -> CLOSE_WAIT: "rcv FIN\nsend ACK" {
  class: [transition]
  style.stroke: "#FF9800"
}

CLOSE_WAIT -> LAST_ACK: "CLOSE\nsend FIN" {
  class: [transition]
  style.stroke: "#FF9800"
}

LAST_ACK -> CLOSED: "rcv ACK" {
  class: [transition]
  style.stroke: "#FF9800"
}

# Simultaneous Close Path Completion
CLOSING -> TIME_WAIT: "rcv ACK" {
  class: [transition]
  style.stroke: "#E91E63"
}

# Error/Maintenance Transitions
SYN_RCVD -> CLOSED: "timeout / rcv RST" {
  class: transition
  style.stroke: "#F44336"
  style.stroke-dash: 2
}

LISTEN -> CLOSED: "CLOSE\n(stop listening)" {
  class: transition
  style.stroke: "#9E9E9E"
  style.stroke-dash: 4
}

# Title & Layout Labels
title: "RFC 9293: TCP Transmission Control Protocol State Machine" {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

subtitle: "Events: [OPEN, SEND, RECEIVE, CLOSE, ABORT, STATUS] | Signals: [SYN, ACK, FIN, RST, timeout]" {
  near: top-center
  shape: text
  style: {
    font-size: 13
    italic: true
  }
}

reset_note: "Any state → RST received → CLOSED" {
  shape: text
  near: bottom-left
  style: {
    font-size: 10
    font-color: "#D32F2F"
    italic: true
  }
}