direction: right
layout-engine: elk
theme-id: 4
title: |md
  # IPv4/IPv6 Address Extraction Algorithm
  Branching logic for tracepoint context address family dispatch
| {near: top-center}
# Input: tracepoint context
input: "ctx (tracepoint)" {
  shape: rectangle
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
}
# Decision: Check family
check_family: "family == ?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
}
# AF_INET branch (IPv4)
af_inet: "AF_INET\n(2)" {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#43A047"
}
read_ipv4: "bpf_probe_read_kernel\n(saddr, 4, ctx->saddr)" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
}
read_ipv4_dst: "bpf_probe_read_kernel\n(daddr, 4, ctx->daddr)" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
}
zero_ipv4: "Zero bytes [4-15]\n(prevent garbage)" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}
# AF_INET6 branch (IPv6)
af_inet6: "AF_INET6\n(10)" {
  shape: rectangle
  style.fill: "#BBDEFB"
  style.stroke: "#1976D2"
}
read_ipv6: "bpf_probe_read_kernel\n(saddr, 16, ctx->saddr)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
}
read_ipv6_dst: "bpf_probe_read_kernel\n(daddr, 16, ctx->daddr)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
}
# Unknown family
unknown_family: "Unknown family\n(return -1)" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
}
# Success output
success: "conn_info populated\nreturn 0" {
  shape: rectangle
  style.fill: "#DCEDC8"
  style.stroke: "#689F38"
  style.stroke-width: 2
}
# Connections
input -> check_family: "extract family"
check_family -> af_inet: "2" {style.stroke: "#43A047"}
check_family -> af_inet6: "10" {style.stroke: "#1976D2"}
check_family -> unknown_family: "other" {style.stroke: "#D32F2F"}
af_inet -> read_ipv4
read_ipv4 -> read_ipv4_dst
read_ipv4_dst -> zero_ipv4
zero_ipv4 -> success
af_inet6 -> read_ipv6
read_ipv6 -> read_ipv6_dst
read_ipv6_dst -> success
# Memory layout annotation
memory_layout: |md
  ## Address Buffer Layout (16 bytes)
  **IPv4 (AF_INET):**
  
  [0-3]: 192.168.1.100  ← VALID
  [4-15]: ?? ?? ?? ...  ← GARBAGE (must ignore)
  
  **IPv6 (AF_INET6):**
  
  [0-15]: 2001:db8::1   ← ALL VALID
  
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  style.stroke-width: 1
}
# Critical note
note: |md
  **CRITICAL:** Never read more than 4 bytes for IPv4!
  The tracepoint context always allocates 16 bytes for
  address fields, but only first 4 are valid for IPv4.
  Bytes 4-15 contain undefined kernel memory.
| {
  near: bottom-right
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 2
}