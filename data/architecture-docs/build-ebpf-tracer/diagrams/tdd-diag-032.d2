direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL STYLES ---
***.style.font: mono

# --- TITLE & OVERVIEW ---
header: {
  shape: rectangle
  label: |md
    # Algorithm: Network-to-Host (16-bit)
    ### Implementation: `ntohs_bpf` for x86_64 eBPF
  |
  style: {
    font-size: 24
    bold: true
    fill: "#E1BEE7"
    stroke: "#7B1FA2"
  }
}

# --- MEMORY LAYOUT REPRESENTATION ---
memory_layout: {
  label: "Memory Representation (Big Endian Order)"
  style.fill: "#F3F4F6"
  
  byte_map: {
    grid-columns: 2
    grid-gap: 0
    
    offset_0: "Offset +0" { 
      style.stroke-width: 0
      style.font-size: 12
    }
    offset_1: "Offset +1" { 
      style.stroke-width: 0
      style.font-size: 12
    }

    byte_hi: "0x00" { 
      style.fill: "#BBDEFB"
      tooltip: "High Byte in BE (Port 80)"
    }
    byte_lo: "0x50" { 
      style.fill: "#90CAF9"
      tooltip: "Low Byte in BE (Port 80)"
    }
  }

  register_view: {
    label: |md
      **CPU Register (Little Endian Load)**
      Read as `u16`: `0x5000` (Decimal: 20480)
    |
    style: {
      stroke-dash: 3
      fill: "#FAFAFA"
      border-radius: 4
    }
  }
  
  byte_map.byte_hi -> register_view: "Loaded as High-Order bits" { style.stroke-dash: 5 }
  byte_map.byte_lo -> register_view: "Loaded as Low-Order bits" { style.stroke-dash: 5 }
}

# --- ALGORITHM STEPS ---
algorithm_steps: {
  label: "Conversion Pipeline (State Evolution)"
  
  step_1: {
    label: |md
      ### 1. Extract & Mask
      `low_byte = val & 0x00FF`
      **State**: `0x5000 & 0x00FF` = <span style="color:red">**0x0000**</span>
    |
    style.fill: "#E8F5E9"
    style.border-radius: 8
  }

  step_2: {
    label: |md
      ### 2. Left Shift
      `shifted = low_byte << 8`
      **State**: `0x0000 << 8` = <span style="color:red">**0x0000**</span>
    |
    style.fill: "#E3F2FD"
    style.border-radius: 8
  }

  step_3: {
    label: |md
      ### 3. Extract & Right Shift
      `high_byte = val >> 8`
      **State**: `0x5000 >> 8` = <span style="color:red">**0x0050**</span>
    |
    style.fill: "#FFF3E0"
    style.border-radius: 8
  }

  step_4: {
    label: ||md
      ### 4. Bitwise OR (Merge)
      `result = shifted | high_byte`
      **State**: `0x0000 | 0x0050` = **0x0050** (Decimal: 80)
    ||
    style.fill: "#F3E5F5"
    style.bold: true
    style.stroke-width: 4
  }

  step_1 -> step_2: "Shift Low to High"
  step_3 -> step_4: "Position High as Low"
  step_2 -> step_4: "Final Bitwise Merge"
}

# --- FINAL OUTPUT ---
output_data: {
  label: |md
    ### Result: 80 (Host Order)
    Correct LE Integer for x86 comparison.
  |
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 4
    shadow: true
  }
}

# --- CONNECTIONS ---
memory_layout.register_view -> algorithm_steps.step_1: "Input val (0x5000)"
memory_layout.register_view -> algorithm_steps.step_3: "Input val (0x5000)"
algorithm_steps.step_4 -> output_data: "Final Return Value"

# --- SIDEBARS & DOCUMENTATION ---
implementation: {
  label: ||cpp
    static __always_inline __u16 ntohs_bpf(__u16 val) {
        // Swap 16-bit: [A][B] -> [B][A]
        // (0x5000 & 0x00FF) << 8 | (0x5000 >> 8)
        return ((val & 0x00FF) << 8) | (val >> 8);
    }
  ||
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#607D8B"
  }
}

logic_table: {
  label: ||md
    ### Byte Order Matrix
    | Port | BE Memory | LE Reg | Host u16 |
    | :--- | :--- | :--- | :--- |
    | 80 | `00 50` | `0x5000` | 80 |
    | 443 | `01 BB` | `0xBB01` | 443 |
    | 22 | `00 16` | `0x1600` | 22 |
  ||
  near: top-right
  style.fill: "#ECEFF1"
}

rationale: {
  label: |md
    ### Rationale
    Network protocols use **Big-Endian**.
    x86 CPUs use **Little-Endian**.
    Direct bit comparison `if(port == 80)`
    without `ntohs` results in `0x0050 == 0x5000`
    which evaluates to **False**.
  |
  near: top-left
  style.fill: "#FFFDE7"
}

warning: {
  label: |md
    ### ⚠️ Performance Note
    eBPF verifier prefers bitwise shifts
    over `__builtin_bswap16` in some
    older kernel versions to ensure
    compatibility across LLVM backends.
  |
  near: bottom-left
  style: {
    fill: "#FFEBEE"
    stroke: "#B71C1C"
    font-color: "#B71C1C"
  }
}