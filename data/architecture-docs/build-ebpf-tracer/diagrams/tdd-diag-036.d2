vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    decision: "#E8F5E9"
    process: "#E3F2FD"
    result_true: "#C8E6C9"
    result_false: "#FFCDD2"
    arrow_yes: "#2E7D32"
    arrow_no: "#C62828"
  }
}

title: |md
  # Filter Evaluation Logic
  *Logic sequence for eBPF tracer event filtering*
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# --- SHAPE DEFINITIONS ---

# Step 1: Check if filter is enabled
start: "START: Filter Evaluation" {
  shape: oval
  style.fill: "#F5F5F5"
}

check_enabled: "cfg->enabled == 0?" {
  shape: diamond
  style.fill: ${colors.decision}
}

return_true_early: "return true\n(trace all)" {
  shape: parallelogram
  style.fill: ${colors.result_true}
}

# Step 2: PID filter check
check_pid: "cfg->filter_pid != 0?" {
  shape: diamond
  style.fill: ${colors.decision}
}

pid_mismatch: "info->pid != cfg->filter_pid?" {
  shape: diamond
  style.fill: ${colors.decision}
}

return_false_pid: "return false\n(PID mismatch)" {
  shape: parallelogram
  style.fill: ${colors.result_false}
}

# Step 3: Destination port filter check
check_dport: "cfg->filter_dport != 0?" {
  shape: diamond
  style.fill: ${colors.decision}
}

dport_mismatch: "info->dport != cfg->filter_dport?" {
  shape: diamond
  style.fill: ${colors.decision}
}

return_false_dport: "return false\n(dport mismatch)" {
  shape: parallelogram
  style.fill: ${colors.result_false}
}

# Step 4: Source port filter check
check_sport: "cfg->filter_sport != 0?" {
  shape: diamond
  style.fill: ${colors.decision}
}

sport_mismatch: "info->sport != cfg->filter_sport?" {
  shape: diamond
  style.fill: ${colors.decision}
}

return_false_sport: "return false\n(sport mismatch)" {
  shape: parallelogram
  style.fill: ${colors.result_false}
}

# Step 5: IP address filter check
check_daddr_mask: "cfg->daddr_mask > 0?" {
  shape: diamond
  style.fill: ${colors.decision}
}

check_family: "cfg->family != 0 AND\ninfo->family != cfg->family?" {
  shape: diamond
  style.fill: ${colors.decision}
}

return_false_family: "return false\n(family mismatch)" {
  shape: parallelogram
  style.fill: ${colors.result_false}
}

compare_daddr: "Compare daddr[0..mask_bytes-1]" {
  shape: rectangle
  style.fill: ${colors.process}
}

daddr_match_check: "All bytes match?" {
  shape: diamond
  style.fill: ${colors.decision}
}

return_false_daddr: "return false\n(daddr mismatch)" {
  shape: parallelogram
  style.fill: ${colors.result_false}
}

# Step 6: Source IP filter
check_saddr_mask: "cfg->saddr_mask > 0?" {
  shape: diamond
  style.fill: ${colors.decision}
}

compare_saddr: "Compare saddr[0..mask_bytes-1]" {
  shape: rectangle
  style.fill: ${colors.process}
}

saddr_match_check: "All bytes match?" {
  shape: diamond
  style.fill: ${colors.decision}
}

return_false_saddr: "return false\n(saddr mismatch)" {
  shape: parallelogram
  style.fill: ${colors.result_false}
}

# Final result
return_true_final: "return true\n(should_trace)" {
  shape: parallelogram
  style.fill: ${colors.result_true}
}

# --- CONNECTIONS ---

start -> check_enabled

check_enabled -> return_true_early: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}
check_enabled -> check_pid: "NO" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}

check_pid -> pid_mismatch: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}
check_pid -> check_dport: "NO" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}

pid_mismatch -> return_false_pid: "YES" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}
pid_mismatch -> check_dport: "NO" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}

check_dport -> dport_mismatch: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}
check_dport -> check_sport: "NO" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}

dport_mismatch -> return_false_dport: "YES" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}
dport_mismatch -> check_sport: "NO" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}

check_sport -> sport_mismatch: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}
check_sport -> check_daddr_mask: "NO" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}

sport_mismatch -> return_false_sport: "YES" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}
sport_mismatch -> check_daddr_mask: "NO" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}

check_daddr_mask -> check_family: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}
check_daddr_mask -> check_saddr_mask: "NO" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}

check_family -> return_false_family: "YES" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}
check_family -> compare_daddr: "NO" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}

compare_daddr -> daddr_match_check
daddr_match_check -> return_false_daddr: "NO" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}
daddr_match_check -> check_saddr_mask: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}

check_saddr_mask -> compare_saddr: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}
check_saddr_mask -> return_true_final: "NO" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}

compare_saddr -> saddr_match_check
saddr_match_check -> return_false_saddr: "NO" {
  style.stroke: ${colors.arrow_no}
  target-arrowhead.shape: arrow
}
saddr_match_check -> return_true_final: "YES" {
  style.stroke: ${colors.arrow_yes}
  target-arrowhead.shape: arrow
}

# --- LEGEND ---

legend: {
  near: bottom-right
  grid-columns: 2
  grid-gap: 10
  style: {
    stroke: "#CCCCCC"
    fill: "#F9F9F9"
    border-radius: 4
  }
  
  legend_title: "Legend" {
    grid-column-span: 2
    shape: text
    style.bold: true
  }
  
  yes_marker: "---->" {
    shape: text
    style.font-color: ${colors.arrow_yes}
    style.bold: true
  }
  yes_label: "YES = filter passes" {
    shape: text
  }
  
  no_marker: "---->" {
    shape: text
    style.font-color: ${colors.arrow_no}
    style.bold: true
  }
  no_label: "NO = continue / mismatch" {
    shape: text
  }
}