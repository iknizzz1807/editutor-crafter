vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "IPv4-Mapped IPv6 Address Format (RFC 4291)" {
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------
# Memory layout container: Technical Byte View
# -----------------------------------------------------------------------------
memory_layout: {
  style.fill: transparent
  
  # Byte offset labels (left margin)
  offsets: {
    shape: text
    style.font: mono
    style.font-size: 12
    label: |md
      **Offset**
      `0x00`
      `0x01`
      `0x02`
      `0x03`
      `0x04`
      `0x05`
      `0x06`
      `0x07`
      `0x08`
      `0x09`
      `0x0A`
      `0x0B`
      `0x0C`
      `0x0D`
      `0x0E`
      `0x0F`
    |
  }

  # Byte values (center)
  bytes: {
    shape: text
    style.font: mono
    style.font-size: 12
    label: |md
      **Value**
      `0x00`
      `0x00`
      `0x00`
      `0x00`
      `0x00`
      `0x00`
      `0x00`
      `0x00`
      `0x00`
      `0x00`
      `0xFF`
      `0xFF`
      `0xC0`
      `0xA8`
      `0x01`
      `0x01`
    |
  }

  # Field descriptions (right margin / field names)
  fields: {
    shape: text
    style.font: mono
    style.font-size: 12
    label: |md
      **Field Identification**
      ────────────────────
      80-bits Zero Padding
      (Padding)
      ────────────────────
      16-bits Marker
      (0xFFFF)
      ────────────────────
      32-bits IPv4 Address
      (192.168.1.1)
      ────────────────────
    |
  }
}

# -----------------------------------------------------------------------------
# Visual Byte Grid (Intel Manual Style)
# -----------------------------------------------------------------------------
byte_grid: {
  grid-columns: 16
  grid-gap: 2
  
  # Header Row (Offsets 0-F)
  # Style: Header=Purple
  b0_hdr: "0"; b1_hdr: "1"; b2_hdr: "2"; b3_hdr: "3"; b4_hdr: "4"; b5_hdr: "5"; b6_hdr: "6"; b7_hdr: "7"
  b8_hdr: "8"; b9_hdr: "9"; bA_hdr: "A"; bB_hdr: "B"; bC_hdr: "C"; bD_hdr: "D"; bE_hdr: "E"; bF_hdr: "F"
  
  b0_hdr, b1_hdr, b2_hdr, b3_hdr, b4_hdr, b5_hdr, b6_hdr, b7_hdr, b8_hdr, b9_hdr, bA_hdr, bB_hdr, bC_hdr, bD_hdr, bE_hdr, bF_hdr: {
    style: {
      fill: "#E1D5E7" # Purple Header
      stroke: "#9673A6"
      font: mono
      font-size: 10
      bold: true
    }
  }

  # Row 2: Content
  # Zero bytes: Padding=Gray
  b0: "00"; b1: "00"; b2: "00"; b3: "00"; b4: "00"; b5: "00"; b6: "00"; b7: "00"; b8: "00"; b9: "00"
  b0, b1, b2, b3, b4, b5, b6, b7, b8, b9: {
    style: {
      fill: "#F5F5F5" # Gray Padding
      font: mono
      font-size: 12
      stroke: "#666666"
      stroke-dash: 2
    }
  }

  # Marker bytes
  bA: "FF"; bB: "FF"
  bA, bB: {
    style: {
      fill: "#FFF2CC" # Yellow/Marker
      font: mono
      font-size: 12
      stroke: "#D6B656"
      bold: true
    }
  }

  # IPv4 bytes: Data=Blue
  bC: "C0"; bD: "A8"; bE: "01"; bF: "01"
  bC, bD, bE, bF: {
    style: {
      fill: "#DAE8FC" # Blue Data
      font: mono
      font-size: 12
      stroke: "#6C8EBF"
      bold: true
    }
  }
}

# -----------------------------------------------------------------------------
# Summary Representations
# -----------------------------------------------------------------------------
representation: {
  style: {
    fill: "#F8F9FA"
    stroke: "#6C757D"
    stroke-width: 2
    border-radius: 8
  }
  repr_title: "Notation Summary" {
    style: { bold: true; font-size: 14; underline: true }
  }
  full_notation: "::ffff:192.168.1.1" {
    style: { font: mono; font-size: 20; bold: true; font-color: "#007BFF" }
  }
  mixed_notation: "0000:0000:0000:0000:0000:ffff:c0a8:0101" {
    style: { font: mono; font-size: 12; font-color: "#6C757D" }
  }
}

# -----------------------------------------------------------------------------
# Field Legend & Size Info
# -----------------------------------------------------------------------------
legend: {
  style.fill: transparent
  legend_title: "Field Legend" {
    style: { bold: true; font-size: 14; underline: true }
  }
  
  zero_legend: {
    shape: rectangle
    width: 24
    height: 24
    style: { fill: "#F5F5F5"; stroke: "#666666"; stroke-dash: 2 }
  }
  zero_label: "Zero Padding (80 bits / 10 bytes)" { style.font-size: 11 }
  
  marker_legend: {
    shape: rectangle
    width: 24
    height: 24
    style: { fill: "#FFF2CC"; stroke: "#D6B656" }
  }
  marker_label: "IPv4 Marker (16 bits / 0xFFFF)" { style.font-size: 11 }
  
  ipv4_legend: {
    shape: rectangle
    width: 24
    height: 24
    style: { fill: "#DAE8FC"; stroke: "#6C8EBF" }
  }
  ipv4_label: "Embedded IPv4 Address (32 bits)" { style.font-size: 11 }

  zero_legend -> zero_label: { style.stroke-width: 0 }
  marker_legend -> marker_label: { style.stroke-width: 0 }
  ipv4_legend -> ipv4_label: { style.stroke-width: 0 }
}

size_info: {
  style: {
    fill: "#E9ECEF"
    stroke: "#6C757D"
    border-radius: 4
  }
  size_title: "sizeof=16 bytes (128 bits)" {
    style: { bold: true; font-size: 12; font: mono }
  }
  total_size: "Standard IPv6 Address Alignment"
}

# -----------------------------------------------------------------------------
# Usage Annotation
# -----------------------------------------------------------------------------
usage_note: {
  near: bottom-center
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    border-radius: 4
    font-size: 11
  }
  label: |md
    **Transition Mechanism:** IPv4-mapped IPv6 addresses are used by the IPv6 
    application layer to communicate with IPv4-only nodes. 
    The kernel handles the translation to standard IPv4 packets on the wire.
  |
}

# -----------------------------------------------------------------------------
# Structural Connections
# -----------------------------------------------------------------------------
memory_layout -> byte_grid
byte_grid -> representation
representation -> legend
legend -> size_info