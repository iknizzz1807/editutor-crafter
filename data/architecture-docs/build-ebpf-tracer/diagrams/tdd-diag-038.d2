vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

title: |md
  # Tracepoint Attachment Sequence & Memory Layout
  **Process Workflow:** `open` → `load` → `verify BTF` → `attach` → `bpf_link`
  **Security Context:** Requires `CAP_BPF` and `CAP_TRACING`
  **Kernel Visibility:** `/sys/kernel/debug/tracing/events/`
| {near: top-center}

# -----------------------------------------------------------------------------
# Participants & Memory Structures
# -----------------------------------------------------------------------------

Userspace: Userspace Process (Control Plane) {
  style: {
    fill: "#E8F4FD"
    stroke: "#2E86AB"
    stroke-width: 2
  }
  
  main: "main() Entry" {
    shape: oval
    style.fill: "#D1E9F9"
  }

  skeleton: "Struct: bpf_skeleton (sizeof=32B)" {
    shape: sql_table
    style: {
      fill: "#7B1FA2" # Header=Purple
      stroke: "#4A148C"
      font-color: white
    }
    # Offset | Field Name | Type/Size
    "0x00": "object: struct bpf_object *" {
      constraint: "8 Bytes"
      style.fill: "#FFE0B2" # Pointers=Orange
    }
    "0x08": "progs: struct bpf_program *" {
      constraint: "8 Bytes"
      style.fill: "#FFE0B2" # Pointers=Orange
    }
    "0x10": "maps: struct bpf_map *" {
      constraint: "8 Bytes"
      style.fill: "#FFE0B2" # Pointers=Orange
    }
    "0x18": "links: struct bpf_link *" {
      constraint: "8 Bytes"
      style.fill: "#FFE0B2" # Pointers=Orange
    }
  }

  prog_fd: "FD Table: prog_fd (int)" {
    shape: rectangle
    style: {
      fill: "#BBDEFB" # Data=Blue
      stroke-dash: 2
    }
    tooltip: "Handle returned by BPF_PROG_LOAD"
  }

  bpf_link_handle: "Handle: bpf_link *" {
    style: {
      fill: "#FFE0B2" # Pointers=Orange
      bold: true
      double-border: true
    }
  }
}

Libbpf: libbpf.so (Userspace Helper) {
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
  }
  
  open: "bpf_object__open()" {
    tooltip: "Parses ELF sections, relocations, and maps"
  }
  load: "bpf_object__load()" {
    tooltip: "Performs syscalls for map/prog creation"
  }
  attach: "bpf_program__attach()" {
    tooltip: "Finalizes the tracepoint hook"
  }
}

Kernel: Linux Kernel (eBPF Subsystem) {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  
  bpf_syscall: "SYS_BPF (bpf_cmd)" {
    shape: rectangle
    style: {
      double-border: true
      fill: "#A5D6A7"
      bold: true
    }
  }

  verifier: "BPF Verifier (Log Level 1/2)" {
    shape: parallelogram
    style.fill: "#C8E6C9"
  }

  btf_registry: "BTF Type Data (vmlinux)" {
    shape: cylinder
    style.fill: "#E1F5FE"
  }

  tracepoint_registry: "Tracepoint Registry" {
    style.fill: "#F1F8E9"
  }
  
  perf_events: "Perf Event Subsystem" {
    tooltip: "Manages tracepoint enabling/disabling"
  }
}

Tracepoint: "sock:inet_sock_set_state" {
  shape: diamond
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}

# -----------------------------------------------------------------------------
# Sequence Steps (Call Flow)
# -----------------------------------------------------------------------------

# Step 1: Initialization
Userspace.main -> Libbpf.open: "1. tcp_tracer_bpf__open()" {
  style: {
    stroke: "#2E86AB"
    stroke-width: 3
  }
}
Libbpf.open -> Kernel.bpf_syscall: "bpf(BPF_OBJ_GET)" {
  style.stroke: "#E65100"
}
Libbpf.open -> Userspace.skeleton: "Populate Vtable & Sections" {
  style: {
    stroke-dash: 3
    stroke: "#2E86AB"
  }
}

# Step 2: Load & Verify
Userspace.skeleton -> Libbpf.load: "2. tcp_tracer_bpf__load()" {
  style: {
    stroke: "#2E86AB"
    stroke-width: 3
  }
}
Libbpf.load -> Kernel.bpf_syscall: "bpf(BPF_MAP_CREATE) xN"
Libbpf.load -> Kernel.bpf_syscall: "bpf(BPF_PROG_LOAD)" {
  style.stroke: "#E65100"
}
Kernel.bpf_syscall -> Kernel.verifier: "Check DAG, Bound Checks"
Kernel.verifier -> Kernel.btf_registry: "Resolve Type Offsets"
Kernel.verifier -> Kernel.bpf_syscall: "Status: ACCEPTED" {
  style.stroke: "#2E7D32"
}
Libbpf.load -> Userspace.prog_fd: "Populate File Descriptor" {
  style: {
    stroke-dash: 3
    stroke: "#2E86AB"
  }
}

# Step 3: Attachment
Userspace.prog_fd -> Libbpf.attach: "3. tcp_tracer_bpf__attach()" {
  style: {
    stroke: "#2E86AB"
    stroke-width: 3
  }
}

Libbpf.attach -> Kernel.bpf_syscall: "bpf(BPF_LINK_CREATE)" {
  style.stroke: "#E65100"
}
Kernel.bpf_syscall -> Kernel.tracepoint_registry: "Resolve Symbol"
Kernel.tracepoint_registry -> Tracepoint: "Inject JIT Bytecode Hook" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}
Kernel.tracepoint_registry -> Kernel.perf_events: "TP_EVENT_ENABLE"
Kernel.bpf_syscall -> Libbpf.attach: "Return link_fd (int)" {
  style.stroke-dash: 3
}
Libbpf.attach -> Userspace.bpf_link_handle: "Instantiate link pointer" {
  style: {
    stroke-dash: 3
    stroke: "#2E86AB"
  }
}

# Step 4: Verification Loop
Userspace.bpf_link_handle -> Kernel.tracepoint_registry: "4. IOCTL_CHECK_LINK" {
  style: {
    stroke: "#7B1FA2"
    stroke-dash: 5
  }
}
Kernel.tracepoint_registry -> Userspace.bpf_link_handle: "STATE: RUNNING" {
  style.stroke-dash: 3
}

# -----------------------------------------------------------------------------
# Callouts & Technical Notes
# -----------------------------------------------------------------------------

Libbpf_logic_note: |md
  ### Libbpf Internal Logic
  ---
  - **Relocation:** Patches map FDs into instructions.
  - **Auto-Attach:** Parses `SEC("tp/sock/inet_sock_set_state")`.
  - **BTF Sanitization:** Downgrades BTF for older kernels if needed.
| {
  near: bottom-left
  style.fill: "#FFF9C4"
}

Userspace_error_callout: |md
  ### ⚠️ ATTACHMENT ERRORS
  ---
  - **EPERM:** Lacks `CAP_BPF` or `CAP_TRACING`
  - **EINVAL:** `SEC()` name mismatch or invalid type
  - **EACCES:** Verifier rejected bytecode (Check `dmesg`)
  - **ENOENT:** Tracepoint not found in registry
| {
  near: bottom-left
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
}

Performance_metrics: |md
  ### Critical Path Latency
  ---
  - **ELF Parse:** ~5-15ms (I/O bound)
  - **Verification:** 10-500ms (Complexity bound)
  - **JIT/Attach:** <2ms (Atomic in Kernel)
| {
  near: bottom-right
  style.font-size: 11
}

# -----------------------------------------------------------------------------
# Legend
# -----------------------------------------------------------------------------

legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  
  call: "Solid: Synchronous Call" {
    style.stroke: "#2E86AB"
    style.stroke-width: 2
  }
  ret: "Dashed: Response/Data Update" {
    style.stroke-dash: 3
  }
  kernel_edge: "Green: Kernel Action" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
}