vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cache Contention vs Per-CPU Comparison
  Atomic increment contention vs lock-free per-CPU increments
| {near: top-center}
direction: right
# Left side: Contention scenario
Contention: {
  label: "Cache Contention\n(Shared Counter)"
  style.fill: "#FFE4E1"
  style.stroke: "#CD5C5C"
  style.stroke-width: 3
  Shared_Counter: {
    label: "Shared Counter\n(atomic u64)"
    shape: rectangle
    style.fill: "#FF6B6B"
    style.stroke: "#8B0000"
    style.stroke-width: 2
    style.bold: true
    style.font-color: white
  }
  CPU0_C: {
    label: "CPU 0\nCache Line"
    shape: rectangle
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
  }
  CPU1_C: {
    label: "CPU 1\nCache Line"
    shape: rectangle
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
  }
  CPU2_C: {
    label: "CPU 2\nCache Line"
    shape: rectangle
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
  }
  CPU3_C: {
    label: "CPU 3\nCache Line"
    shape: rectangle
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
  }
  CPU0_C -> Shared_Counter: "atomic_inc\n(wait for lock)" {
    style.stroke: "#FF0000"
    style.stroke-width: 3
    style.stroke-dash: 4
    style.animated: true
    label: "█ contention"
  }
  CPU1_C -> Shared_Counter: "atomic_inc\n(wait for lock)" {
    style.stroke: "#FF0000"
    style.stroke-width: 3
    style.stroke-dash: 4
    style.animated: true
  }
  CPU2_C -> Shared_Counter: "atomic_inc\n(wait for lock)" {
    style.stroke: "#FF0000"
    style.stroke-width: 3
    style.stroke-dash: 4
    style.animated: true
  }
  CPU3_C -> Shared_Counter: "atomic_inc\n(wait for lock)" {
    style.stroke: "#FF0000"
    style.stroke-width: 3
    style.stroke-dash: 4
    style.animated: true
  }
}
# Right side: Per-CPU scenario
PerCPU: {
  label: "Per-CPU Counters\n(Lock-Free)"
  style.fill: "#E8F5E9"
  style.stroke: "#228B22"
  style.stroke-width: 3
  Counter0: {
    label: "Counter[CPU0]\n(u64)"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#1B5E20"
    style.bold: true
    style.font-color: white
  }
  Counter1: {
    label: "Counter[CPU1]\n(u64)"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#1B5E20"
    style.bold: true
    style.font-color: white
  }
  Counter2: {
    label: "Counter[CPU2]\n(u64)"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#1B5E20"
    style.bold: true
    style.font-color: white
  }
  Counter3: {
    label: "Counter[CPU3]\n(u64)"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#1B5E20"
    style.bold: true
    style.font-color: white
  }
  CPU0_P: {
    label: "CPU 0"
    shape: rectangle
    style.fill: "#B2EBF2"
    style.stroke: "#00838F"
  }
  CPU1_P: {
    label: "CPU 1"
    shape: rectangle
    style.fill: "#B2EBF2"
    style.stroke: "#00838F"
  }
  CPU2_P: {
    label: "CPU 2"
    shape: rectangle
    style.fill: "#B2EBF2"
    style.stroke: "#00838F"
  }
  CPU3_P: {
    label: "CPU 3"
    shape: rectangle
    style.fill: "#B2EBF2"
    style.stroke: "#00838F"
  }
  CPU0_P -> Counter0: "local_inc\n(no wait)" {
    style.stroke: "#00C853"
    style.stroke-width: 3
  }
  CPU1_P -> Counter1: "local_inc\n(no wait)" {
    style.stroke: "#00C853"
    style.stroke-width: 3
  }
  CPU2_P -> Counter2: "local_inc\n(no wait)" {
    style.stroke: "#00C853"
    style.stroke-width: 3
  }
  CPU3_P -> Counter3: "local_inc\n(no wait)" {
    style.stroke: "#00C853"
    style.stroke-width: 3
  }
}
# Comparison arrow
Contention -> PerCPU: "BPF_MAP_TYPE_ARRAY\n→ BPF_MAP_TYPE_PERCPU_ARRAY" {
  style.stroke: "#9C27B0"
  style.stroke-width: 4
  style.stroke-dash: 6
  label: "Eliminates contention\nvia per-CPU isolation"
}
# Legend
Legend: {
  near: bottom-center
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  Contention_Legend: {
    label: "████ Contention\n(serialized access)"
    shape: text
    style.font-color: "#D32F2F"
  }
  LockFree_Legend: {
    label: "──── Lock-Free\n(parallel access)"
    shape: text
    style.font-color: "#388E3C"
  }
  Contention_Legend -> LockFree_Legend
}
# Performance comparison box
Performance: {
  near: bottom-right
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  Bad: {
    label: "Contention:\n~500ns per increment\n(8-core system)"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  Good: {
    label: "Per-CPU:\n~50ns per increment\n(10x faster!)"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#43A047"
  }
  Bad -> Good: "Improvement" {
    style.stroke: "#FF9800"
    style.stroke-width: 2
  }
}
# Code example
Code_Note: |md
  c
  // WRONG: Shared counter causes contention
  struct {
      __uint(type, BPF_MAP_TYPE_ARRAY);
      __type(value, __u64);  // Single shared counter
  } counter;
  // CORRECT: Per-CPU eliminates contention
  struct {
      __uint(type, BPF_MAP_TYPE_PERCPU_ARRAY);
      __type(value, __u64);  // One counter per CPU
  } counter;
  // Userspace must sum across CPUs:
  int ncpus = libbpf_num_possible_cpus();
  __u64 values[ncpus];
  bpf_map_lookup_elem(fd, &key, values);
  __u64 total = 0;
  for (int i = 0; i < ncpus; i++)
      total += values[i];
  
| {near: bottom-left}