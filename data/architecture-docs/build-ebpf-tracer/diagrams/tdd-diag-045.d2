vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Multi-Source eBPF Dashboard Data Flow
| {near: top-center}
direction: right
classes: {
  kernel_component: {
    style: {
      fill: "#E8D4F8"
      stroke: "#7B4B94"
      stroke-width: 2
    }
  }
  userspace_component: {
    style: {
      fill: "#D4E8F8"
      stroke: "#4B7B94"
      stroke-width: 2
    }
  }
  map_component: {
    shape: cylinder
    style: {
      fill: "#F8E8D4"
      stroke: "#947B4B"
      stroke-width: 2
    }
  }
  percpu_map: {
    shape: cylinder
    style: {
      fill: "#D4F8E8"
      stroke: "#4B947B"
      stroke-width: 2
    }
  }
  ring_buffer: {
    shape: hexagon
    style: {
      fill: "#F8D4D4"
      stroke: "#944B4B"
      stroke-width: 2
    }
  }
  event_source: {
    shape: diamond
    style: {
      fill: "#F8F8D4"
      stroke: "#94944B"
      stroke-width: 2
    }
  }
}
kernel_space: Kernel Space {
  style.fill: "#FAF5FF"
  style.stroke: "#7B4B94"
  style.stroke-dash: 3
  syscall_probes: Syscall Probes {
    class: kernel_component
    read_entry: read() entry kprobe
    read_exit: read() exit kretprobe
    write_entry: write() entry kprobe
    write_exit: write() exit kretprobe
    openat_entry: openat() entry kprobe
    openat_exit: openat() exit kretprobe
    read_entry -> read_exit: correlate by TID
    write_entry -> write_exit: correlate by TID
    openat_entry -> openat_exit: correlate by TID
  }
  tcp_tracepoint: TCP Tracepoint {
    class: kernel_component
    label: "sock:inet_sock_set_state\ntracepoint"
  }
  sched_tracepoint: Scheduler Tracepoint {
    class: kernel_component
    label: "sched/sched_switch\ntracepoint"
  }
  syscall_histograms: Syscall Histograms {
    class: percpu_map
    label: "PERCPU_ARRAY\n16 syscalls × 64 buckets\nPer-CPU counters"
  }
  proc_stats_map: Process Stats {
    class: percpu_map
    label: "PERCPU_HASH\nPID → stats\nPer-CPU counters"
  }
  tcp_events_rb: TCP Events {
    class: ring_buffer
    label: "RINGBUF\n16 MB\nConnection events"
  }
  syscall_start_times: Start Times {
    class: map_component
    label: "HASH\nTID → timestamp\nEntry/exit correlation"
  }
  tcp_connections: TCP Connections {
    class: map_component
    label: "HASH\nskaddr → conn_info\nConnection tracking"
  }
  config_map: Config {
    class: map_component
    label: "ARRAY\nRuntime filter\nconfiguration"
  }
  self_stats: Self Stats {
    class: percpu_map
    label: "PERCPU_ARRAY\nOverhead\nmeasurement"
  }
  syscall_probes -> syscall_start_times: store timestamp
  syscall_probes -> syscall_histograms: update bucket
  tcp_tracepoint -> tcp_connections: store ESTABLISHED
  tcp_tracepoint -> tcp_events_rb: emit on close
  sched_tracepoint -> proc_stats_map: update stats
}
userspace: Userspace {
  style.fill: "#F5FAFF"
  style.stroke: "#4B7B94"
  style.stroke-dash: 3
  epoll: Epoll Event Loop {
    class: userspace_component
    label: "epoll_wait()\nMultiplexed I/O"
  }
  timer_fd: Timer {
    class: event_source
    label: "timerfd\n1000ms interval"
  }
  ring_buffer_consumer: Ring Buffer\nConsumer {
    class: userspace_component
  }
  percpu_aggregator: Per-CPU\nAggregator {
    class: userspace_component
    label: "Sum across\ncpus"
  }
  probe_manager: Probe Manager {
    class: userspace_component
    label: "Enable/disable\nbpf_link lifecycle"
  }
  state: Dashboard State {
    class: userspace_component
    shape: class
    label: |md
      - histograms[16]
      - connections[100]
      - processes[50]
      - probe_status[32]
    |
  }
  terminal_ui: Terminal UI {
    class: userspace_component
    label: "ANSI escape codes\n1-2 Hz refresh"
  }
  keyboard: Keyboard Input {
    class: event_source
    label: "q/p/r/1-9"
  }
}
kernel_space.syscall_histograms -> userspace.percpu_aggregator: bpf_map_lookup_elem\n(returns num_cpus values) {
  style.stroke: "#4B947B"
  style.stroke-width: 3
}
kernel_space.proc_stats_map -> userspace.percpu_aggregator: bpf_map_lookup_elem\n(returns num_cpus values) {
  style.stroke: "#4B947B"
  style.stroke-width: 3
}
userspace.percpu_aggregator -> userspace.state: summed values {
  style.stroke: "#4B947B"
  style.stroke-dash: 3
}
kernel_space.tcp_events_rb -> userspace.ring_buffer_consumer: ring_buffer__poll() {
  style.stroke: "#944B4B"
  style.stroke-width: 3
  style.animated: true
}
userspace.ring_buffer_consumer -> userspace.state: TCP events {
  style.stroke: "#944B4B"
}
userspace.timer_fd -> userspace.epoll: EPOLLIN {
  style.stroke: "#94944B"
  style.stroke-width: 2
}
userspace.ring_buffer_consumer -> userspace.epoll: EPOLLIN {
  style.stroke: "#944B4B"
  style.stroke-width: 2
}
userspace.keyboard -> userspace.epoll: EPOLLIN {
  style.stroke: "#4B7B94"
  style.stroke-width: 2
}
userspace.epoll -> userspace.state: update on timer {
  style.stroke: "#94944B"
}
userspace.state -> userspace.terminal_ui: render frame {
  style.stroke: "#4B7B94"
  style.stroke-width: 3
}
userspace.state -> userspace.probe_manager: toggle probes {
  style.stroke: "#7B4B94"
  style.stroke-dash: 3
}
userspace.probe_manager -> kernel_space.syscall_probes: bpf_link__destroy()\n/ attach {
  style.stroke: "#7B4B94"
  style.stroke-dash: 3
}
userspace.probe_manager -> kernel_space.tcp_tracepoint: attach/detach {
  style.stroke: "#7B4B94"
  style.stroke-dash: 3
}
userspace.probe_manager -> kernel_space.sched_tracepoint: attach/detach {
  style.stroke: "#7B4B94"
  style.stroke-dash: 3
}
legend: |md
  **Legend:**
  - 🟣 Purple: Kernel components (eBPF probes)
  - 🔵 Blue: Userspace components
  - 🟢 Green: Per-CPU maps (aggregation required)
  - 🔴 Red: Ring buffer (event streaming)
  - 🟡 Yellow: Event sources (timer, keyboard)
  - ⬡ Hexagon: Ring buffer
  - ◇ Diamond: Event source
  - ▤ Cylinder: BPF map
| {near: bottom-center}