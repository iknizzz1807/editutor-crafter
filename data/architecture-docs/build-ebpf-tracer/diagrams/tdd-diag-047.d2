vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
}

title: |md
  ### Timer-Based Refresh Sequence Diagram
  *eBPF Dashboard Application Logic*
| {
  near: top-center
  shape: text
}

TimerRefreshSequence: {
  shape: sequence_diagram

  # Participants
  Epoll: "Event Subsystem\n(epoll_fd)" {
    style.fill: "#DEE1EB"
  }
  MainLoop: "Main Application\n(tracer.c)" {
    style.fill: "#C7F1FF"
  }
  State: "Dashboard State\n(dashboard_state_t)" {
    style.fill: "#B5AFF6"
  }
  UI: "Terminal Engine\n(ncurses)" {
    style.fill: "#E4DBFE"
  }
  BPF: "Kernel/BPF\n(ring_buffer)" {
    style.fill: "#FCE7C6"
  }

  # Initialization block (implicit in C context)
  MainLoop -> Epoll: "epoll_wait(fd, events, 2, 1000)"
  Epoll -> MainLoop: "return event_count (n)"

  # Event Handling Section
  "Runtime Loop (while !exiting)": {
    # Path A: Timer Expiry
    MainLoop.timer_exec: "if (events[i].data.fd == timer_fd)" {
      MainLoop.timer_exec -> MainLoop.timer_exec: "on_timer()"
      
      MainLoop.timer_exec -> State: "update_syscall_histograms(state)"
      State -> MainLoop.timer_exec: return void
      
      MainLoop.timer_exec -> State: "update_process_stats(state)"
      State -> MainLoop.timer_exec: return void
      
      MainLoop.timer_exec -> State: "update_system_metrics(state)"
      State -> MainLoop.timer_exec: return void
      
      MainLoop.timer_exec -> UI: "terminal_clear()"
      UI -> MainLoop.timer_exec: return void
      
      MainLoop.timer_exec -> UI: "terminal_draw_frame(state)"
      UI -> MainLoop.timer_exec: return void
    }

    # Path B: Ring Buffer Data
    MainLoop.ring_exec: "else if (events[i].data.fd == ring_buffer_fd)" {
      MainLoop.ring_exec -> MainLoop.ring_exec: "on_ring_data()"
      
      MainLoop.ring_exec -> BPF: "ring_buffer__consume(rb)"
      BPF -> MainLoop.ring_exec: "callback(data)"
      
      MainLoop.ring_exec -> State: "update_active_connection_count(state)"
      State -> MainLoop.ring_exec: return void
    }
  }

  # Termination Section
  "Shutdown & Cleanup Phase": {
    MainLoop -> BPF: "probe_disable_all(&mgr)"
    MainLoop -> BPF: "ring_buffer__free(rb)"
    MainLoop -> BPF: "dashboard_bpf__destroy(skel)"
    MainLoop -> UI: "terminal_cleanup()"
  }

  # Styling lifelines
  MainLoop.style.stroke: "#007AFF"
  MainLoop.style.stroke-width: 2
  State.style.stroke: "#5856D6"
  UI.style.stroke: "#AF52DE"
  BPF.style.stroke: "#FF9500"
}

# Documentation Metadata
Legend: {
  near: bottom-left
  SyncCall: "Solid Line" {
    shape: text
    style.font-color: "#000000"
  }
  AsyncData: "Dashed Line" {
    shape: text
    style.font-color: "#000000"
  }
}

annotation: |md
  **Implementation Notes:**
  1. **on_timer**: High-priority UI refresh path. Clears screen and re-renders from state cache.
  2. **on_ring_data**: Async data consumption path. Updates state counters without triggering redraws.
  3. **epoll_wait**: Blocking call with 1000ms timeout to ensure minimum 1Hz heartbeat if no events occur.
| {
  near: bottom-right
  shape: text
}