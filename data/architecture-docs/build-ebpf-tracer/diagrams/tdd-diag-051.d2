vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  process: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 4
    }
  }
  signal: {
    shape: diamond
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
    }
  }
  action: {
    shape: rectangle
    style: {
      fill: "#DCFCE7"
      stroke: "#16A34A"
      stroke-width: 2
      border-radius: 4
    }
  }
  resource: {
    shape: cylinder
    style: {
      fill: "#F3E8FF"
      stroke: "#9333EA"
      stroke-width: 2
    }
  }
  arrow: {
    style: {
      stroke-width: 2
      animated: true
    }
  }
}
title: |md
  # Resource Cleanup on Shutdown Sequence
| {near: top-center}
direction: right
# Sequence Flow
sigint: SIGINT/SIGTERM {
  class: signal
  near: top-left
}
handler: Signal Handler {
  class: process
  label: "sig_handler(int sig)\n──────────\nsets exiting = true"
}
epoll_loop: Epoll Event Loop {
  class: process
  label: "event_loop_run()\n──────────\nwhile (!exiting)\n  epoll_wait(...)"
}
probe_cleanup: Probe Cleanup {
  class: action
  label: "probe_disable_all()\n──────────\nfor each probe:\n  bpf_link__destroy(link)\n  link = NULL"
}
ringbuf_cleanup: Ring Buffer Cleanup {
  class: action
  label: "ring_buffer__free(rb)\n──────────\nfree ring buffer\nmemory and FD"
}
bpf_cleanup: BPF Object Cleanup {
  class: action
  label: "bpf_object__close(obj)\n──────────\nclose all maps\nfree all programs"
}
terminal_cleanup: Terminal Cleanup {
  class: action
  label: "terminal_cleanup()\n──────────\nrestore terminal\nsettings"
}
exit: Process Exit {
  class: signal
  label: "return 0"
}
# Resources (shown below actions)
links: bpf_links {
  class: resource
  style.fill: "#FEE2E2"
  label: "File Descriptors\n(kprobe attachments)"
}
maps: BPF Maps {
  class: resource
  label: "Map FDs\n(percpu arrays,\nringbuf, etc)"
}
programs: BPF Programs {
  class: resource
  label: "Program FDs\n(verified bytecode)"
}
# Sequence connections
sigint -> handler: "1. kernel delivers\nsignal" {class: arrow; style.stroke: "#D97706"}
handler -> epoll_loop: "2. exiting = true\nbreaks loop" {class: arrow; style.stroke: "#2563EB"}
epoll_loop -> probe_cleanup: "3. cleanup begins" {class: arrow; style.stroke: "#16A34A"}
probe_cleanup -> ringbuf_cleanup: "4. probes detached" {class: arrow; style.stroke: "#16A34A"}
ringbuf_cleanup -> bpf_cleanup: "5. ringbuf freed" {class: arrow; style.stroke: "#16A34A"}
bpf_cleanup -> terminal_cleanup: "6. BPF closed" {class: arrow; style.stroke: "#16A34A"}
terminal_cleanup -> exit: "7. terminal restored" {class: arrow; style.stroke: "#D97706"}
# Resource lifecycle connections
links -> probe_cleanup: "destroyed" {style.stroke: "#DC2626"; style.stroke-dash: 3}
maps -> bpf_cleanup: "closed" {style.stroke: "#9333EA"; style.stroke-dash: 3}
programs -> bpf_cleanup: "freed" {style.stroke: "#9333EA"; style.stroke-dash: 3}
# Critical invariant box
invariant: |md
  **CRITICAL INVARIANT**
  Every `bpf_link` created by `bpf_program__attach_*()`
  MUST be destroyed by `bpf_link__destroy()`
  Forgetting this:
  - Leaks file descriptors
  - Probes remain attached
  - Eventually hits `RLIMIT_NOFILE`
| {
  shape: rectangle
  near: bottom-center
  style: {
    fill: "#FEF2F2"
    stroke: "#DC2626"
    stroke-width: 2
    border-radius: 4
  }
}
# Legend
legend: {
  near: bottom-right
  legend_title: Legend {
    shape: text
    style.font-size: 14
    style.bold: true
  }
  sig: Signal {class: signal}
  proc: Process {class: process}
  act: Action {class: action}
  res: Resource {class: resource}
  legend_title -> sig -> proc -> act -> res {style.opacity: 0}
}