vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # eBPF Multi-Source Dashboard Data Flow
| {near: top-center}
direction: right
# Kernel Space
kernel_space: Kernel Space {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
  # eBPF Programs
  ebpf_programs: eBPF Programs {
    style.fill: "#D4E6F1"
    syscall_tracer: Syscall Tracer {
      style.fill: "#AED6F1"
      read_entry: read() kprobe
      read_exit: read() kretprobe
      write_entry: write() kprobe
      write_exit: write() kretprobe
      openat_entry: openat() kprobe
      openat_exit: openat() kretprobe
      read_entry -> read_exit: correlate by TID
      write_entry -> write_exit: correlate by TID
      openat_entry -> openat_exit: correlate by TID
    }
    tcp_tracer: TCP Tracer {
      style.fill: "#AED6F1"
      tcp_tp: sock:inet_sock_set_state
    }
    sched_tracer: Scheduler Tracer {
      style.fill: "#AED6F1"
      sched_tp: sched/sched_switch
    }
  }
  # BPF Maps
  bpf_maps: BPF Maps {
    style.fill: "#D5F5E3"
    percpu_hist: Per-CPU Histogram {
      shape: cylinder
      style.fill: "#82E0AA"
    }
    percpu_proc: Per-CPU Process Stats {
      shape: cylinder
      style.fill: "#82E0AA"
    }
    ringbuf: Ring Buffer (16MB) {
      shape: cylinder
      style.fill: "#F9E79F"
    }
    config_map: Config Map {
      shape: cylinder
      style.fill: "#D7BDE2"
    }
  }
  # Data flow from programs to maps
  syscall_tracer -> percpu_hist: update buckets {
    style.stroke: "#2980B9"
    style.stroke-width: 2
  }
  tcp_tracer -> ringbuf: submit events {
    style.stroke: "#8E44AD"
    style.stroke-width: 2
  }
  sched_tracer -> percpu_proc: update stats {
    style.stroke: "#27AE60"
    style.stroke-width: 2
  }
}
# Userspace
userspace: Userspace {
  style.fill: "#FEF9E7"
  style.stroke: "#666666"
  style.stroke-width: 2
  # Probe Manager
  probe_manager: Probe Manager {
    style.fill: "#FADBD8"
    enable: probe_enable() {
      shape: rectangle
      style.fill: "#E6B0AA"
    }
    disable: probe_disable() {
      shape: rectangle
      style.fill: "#E6B0AA"
    }
    link_mgr: bpf_link lifecycle {
      shape: rectangle
      style.fill: "#E6B0AA"
    }
  }
  # Per-CPU Aggregator
  aggregator: Per-CPU Aggregator {
    style.fill: "#D5F5E3"
    init: libbpf_num_possible_cpus() {
      shape: rectangle
      style.fill: "#82E0AA"
    }
    sum: sum across CPUs {
      shape: rectangle
      style.fill: "#82E0AA"
    }
  }
  # Event Loop
  event_loop: Event Loop (epoll) {
    style.fill: "#FCF3CF"
    epoll_fd: epoll_create1() {
      shape: rectangle
      style.fill: "#F9E79F"
    }
    timer_fd: timerfd (1Hz) {
      shape: rectangle
      style.fill: "#F9E79F"
    }
    ringbuf_poll: ring_buffer__poll() {
      shape: rectangle
      style.fill: "#F9E79F"
    }
  }
  # Terminal UI
  terminal_ui: Terminal UI {
    style.fill: "#EBDEF0"
    histograms: Draw Histograms {
      shape: rectangle
      style.fill: "#D7BDE2"
    }
    connections: Draw Connections {
      shape: rectangle
      style.fill: "#D7BDE2"
    }
    processes: Draw Processes {
      shape: rectangle
      style.fill: "#D7BDE2"
    }
    refresh: 1-2 Hz Refresh {
      shape: rectangle
      style.fill: "#D7BDE2"
    }
  }
}
# Cross-boundary connections
kernel_space.bpf_maps.percpu_hist -> userspace.aggregator.sum: bpf_map_lookup_elem {
  style.stroke: "#2980B9"
  style.stroke-dash: 3
}
kernel_space.bpf_maps.ringbuf -> userspace.event_loop.ringbuf_poll: events {
  style.stroke: "#8E44AD"
  style.stroke-dash: 3
}
kernel_space.bpf_maps.percpu_proc -> userspace.aggregator.sum: bpf_map_lookup_elem {
  style.stroke: "#27AE60"
  style.stroke-dash: 3
}
userspace.probe_manager -> kernel_space.ebpf_programs: attach/detach {
  style.stroke: "#C0392B"
  style.stroke-width: 2
}
userspace.event_loop -> kernel_space.bpf_maps.config_map: runtime config {
  style.stroke: "#7D3C98"
  style.stroke-dash: 3
}
# Internal userspace flow
userspace.aggregator.sum -> userspace.terminal_ui.histograms: aggregated data
userspace.event_loop.ringbuf_poll -> userspace.terminal_ui.connections: TCP events
userspace.aggregator.sum -> userspace.terminal_ui.processes: process stats
userspace.event_loop.timer_fd -> userspace.terminal_ui.refresh: trigger redraw {
  style.stroke: "#F39C12"
  style.animated: true
}
# Legend
legend: |md
  **Data Flow Legend:**
  - Blue: Syscall histogram data
  - Purple: TCP connection events  
  - Green: Scheduler/process stats
  - Red dashed: Probe management
  - Orange animated: Timer trigger
| {near: bottom-center}