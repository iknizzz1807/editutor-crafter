vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Multi-Source Dashboard: Graceful Shutdown Sequence
| {near: top-center}
direction: down
# Signal Handler
signal: SIGINT/SIGTERM {
  shape: diamond
  style: {
    fill: "#FFE4B5"
    stroke: "#FF8C00"
    stroke-width: 2
  }
}
signal -> shutdown_start: "Set exiting = true"
# Shutdown Start
shutdown_start: "Shutdown Initiated" {
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
  }
}
# Step 1: Disable All Probes
step1: "Step 1: probe_disable_all()" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    bold: true
  }
  probe_manager: "Probe Manager" {
    style.fill: "#BBDEFB"
    probe_1: "syscall_read_entry" {
      link_ptr: "bpf_link*"
      status: "ENABLED"
      style.fill: "#C8E6C9"
    }
    probe_2: "syscall_read_exit" {
      link_ptr: "bpf_link*"
      status: "ENABLED"
      style.fill: "#C8E6C9"
    }
    probe_3: "syscall_write_entry" {
      link_ptr: "bpf_link*"
      status: "ENABLED"
      style.fill: "#C8E6C9"
    }
    probe_4: "sched_switch" {
      link_ptr: "bpf_link*"
      status: "ENABLED"
      style.fill: "#C8E6C9"
    }
    probe_5: "tcp_state" {
      link_ptr: "bpf_link*"
      status: "ENABLED"
      style.fill: "#C8E6C9"
    }
  }
}
# Step 1 Detail - Link Destroy
step1_detail: |md
  FOR each probe in probes[]:
    IF probe->link != NULL:
      bpf_link__destroy(probe->link)
      // Detaches from kernel
      // Closes file descriptor
      // Frees link memory
      probe->link = NULL
      probe->status = DISABLED
| {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    font: mono
    font-size: 12
  }
}
# After Step 1
step1_result: "All Probes Disabled" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
  }
  probe_1_disabled: "syscall_read_entry" {
    link_ptr: "NULL"
    status: "DISABLED"
    style.fill: "#FFCDD2"
  }
  probe_2_disabled: "syscall_read_exit" {
    link_ptr: "NULL"
    status: "DISABLED"
    style.fill: "#FFCDD2"
  }
  probe_3_disabled: "syscall_write_entry" {
    link_ptr: "NULL"
    status: "DISABLED"
    style.fill: "#FFCDD2"
  }
  probe_4_disabled: "sched_switch" {
    link_ptr: "NULL"
    status: "DISABLED"
    style.fill: "#FFCDD2"
  }
  probe_5_disabled: "tcp_state" {
    link_ptr: "NULL"
    status: "DISABLED"
    style.fill: "#FFCDD2"
  }
}
# Step 2: Free Ring Buffer
step2: "Step 2: ring_buffer__free(rb)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    bold: true
  }
  ring_buffer: "Ring Buffer Consumer" {
    style.fill: "#BBDEFB"
    fd: "int ring_fd"
    state: "ACTIVE"
    style.fill: "#C8E6C9"
  }
}
step2_detail: |md
  // Releases ring buffer consumer
  // Closes internal file descriptor
  // Frees consumer structure
  ring_buffer__free(rb);
  rb = NULL;
| {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    font: mono
    font-size: 12
  }
}
step2_result: "Ring Buffer Freed" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
  }
  ring_freed: "Ring Buffer" {
    fd: "CLOSED"
    state: "FREED"
    style.fill: "#FFCDD2"
  }
}
# Step 3: Close Timer FD
step3: "Step 3: close(timer_fd)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    bold: true
  }
  timer: "Timer FD" {
    style.fill: "#BBDEFB"
    fd: "int timer_fd"
    state: "ACTIVE"
    style.fill: "#C8E6C9"
  }
}
step3_detail: |md
  // Close timer file descriptor
  // Stops periodic events
  close(timer_fd);
  timer_fd = -1;
| {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    font: mono
    font-size: 12
  }
}
step3_result: "Timer Closed" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
  }
  timer_closed: "Timer FD" {
    fd: "CLOSED (-1)"
    state: "INACTIVE"
    style.fill: "#FFCDD2"
  }
}
# Step 4: Close Epoll FD
step4: "Step 4: close(epoll_fd)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    bold: true
  }
  epoll: "Epoll Instance" {
    style.fill: "#BBDEFB"
    fd: "int epoll_fd"
    state: "ACTIVE"
    style.fill: "#C8E6C9"
  }
}
step4_detail: |md
  // Close epoll instance
  // Automatically unregisters all FDs
  close(epoll_fd);
  epoll_fd = -1;
| {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    font: mono
    font-size: 12
  }
}
step4_result: "Epoll Closed" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
  }
  epoll_closed: "Epoll FD" {
    fd: "CLOSED (-1)"
    state: "INACTIVE"
    style.fill: "#FFCDD2"
  }
}
# Step 5: Destroy BPF Object
step5: "Step 5: bpf_object__close(obj)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    bold: true
  }
  bpf_obj: "BPF Object (Skeleton)" {
    style.fill: "#BBDEFB"
    maps: "BPF Maps" {
      style.fill: "#C8E6C9"
      map1: "syscall_histograms (PERCPU_ARRAY)"
      map2: "proc_stats (PERCPU_HASH)"
      map3: "tcp_events (RINGBUF)"
      map4: "config (ARRAY)"
      map5: "self_stats (PERCPU_ARRAY)"
    }
    programs: "BPF Programs" {
      style.fill: "#C8E6C9"
      prog1: "trace_read_entry"
      prog2: "trace_read_exit"
      prog3: "handle_sched_switch"
    }
  }
}
step5_detail: |md
  // Destroys BPF object and ALL maps
  // Closes all map file descriptors
  // Unloads programs from kernel
  // Frees skeleton memory
  dashboard_bpf__destroy(skel);
  skel = NULL;
| {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    font: mono
    font-size: 12
  }
}
step5_result: "BPF Object Destroyed" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
  }
  maps_freed: "All Maps" {
    state: "UNLOADED"
    style.fill: "#FFCDD2"
  }
  progs_unloaded: "All Programs" {
    state: "UNLOADED"
    style.fill: "#FFCDD2"
  }
}
# Step 6: Terminal Cleanup
step6: "Step 6: terminal_cleanup()" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    bold: true
  }
}
step6_detail: |md
  // Restore terminal settings
  // Switch from alternate screen buffer
  // Show cursor
  // Re-enable line buffering
  terminal_cleanup();
| {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    font: mono
    font-size: 12
  }
}
# Final State
final: "Shutdown Complete - Exit(0)" {
  shape: oval
  style: {
    fill: "#4CAF50"
    stroke: "#2E7D32"
    font-color: white
    bold: true
  }
}
# Connections - Main Flow
shutdown_start -> step1
step1 -> step1_detail
step1_detail -> step1_result
step1_result -> step2
step2 -> step2_detail
step2_detail -> step2_result
step2_result -> step3
step3 -> step3_detail
step3_detail -> step3_result
step3_result -> step4
step4 -> step4_detail
step4_detail -> step4_result
step4_result -> step5
step5 -> step5_detail
step5_detail -> step5_result
step5_result -> step6
step6 -> step6_detail
step6_detail -> final
# Legend
legend: |md
  ## Resource State Colors
  - 🟢 **Green**: Active/In-use resource
  - 🔴 **Red**: Closed/Freed resource
  ## Critical Order
  1. **Probes FIRST** - Must detach before closing maps
  2. **Ring Buffer** - Consumer before map
  3. **Timer/Epoll** - Userspace FDs
  4. **BPF Object LAST** - Destroys all maps
  ## Common Leak Causes
  - Forgetting `bpf_link__destroy()` → FD leak
  - Calling `bpf_object__close()` first → Use-after-free
  - Not closing timer_fd → Orphan FD
| {
  near: bottom-left
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
}
# Warning Box
warning: "⚠️ WRONG ORDER = CRASH OR LEAK" {
  shape: diamond
  near: bottom-right
  style: {
    fill: "#FFCDD2"
    stroke: "#D32F2F"
    bold: true
  }
}