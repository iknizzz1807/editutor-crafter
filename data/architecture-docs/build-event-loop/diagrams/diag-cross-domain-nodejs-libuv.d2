direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Node.js libuv Event Loop ↔ This Project's Reactor
  `uv_run()` is structurally identical to `reactor_run_once()`
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  libuv_col: "libuv  (Node.js internals)" {
    direction: down
    style.fill: "#e8f4f8"
    style.stroke: "#2980b9"
    style.stroke-width: 2
    uv_run: {
      shape: class
      label: "uv_run() — event loop"
      style.fill: "#2980b9"
      style.font-color: white
      +uv_run(loop, mode): "int"
    }
  }
  eq0: "≡" {
    shape: oval
    style.fill: "#f39c12"
    style.font-color: white
    style.stroke: "#e67e22"
    width: 60
    height: 60
  }
  reactor_col: "This Project  (reactor.c)" {
    direction: down
    style.fill: "#eafaf1"
    style.stroke: "#27ae60"
    style.stroke-width: 2
    reactor_run: {
      shape: class
      label: "reactor_run() — event loop"
      style.fill: "#27ae60"
      style.font-color: white
      +reactor_run(r): "void"
    }
  }
}
row0.libuv_col.uv_run -> row0.eq0
row0.eq0 -> row0.reactor_col.reactor_run
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  p1_libuv: "Phase 1 — Timers" {
    direction: down
    style.fill: "#fadbd8"
    style.stroke: "#e74c3c"
    p1_desc: {
      shape: sql_table
      label: "uv__run_timers(loop)"
      c1: "setTimeout() / setInterval() callbacks"
      c2: "Fires when expiry_ms <= now_ms()"
      c3: "Min-heap: O(log n) insert/cancel"
    }
  }
  arrow1: "≡" {
    shape: oval
    style.fill: "#f39c12"
    style.font-color: white
    style.stroke: "#e67e22"
    width: 60
    height: 60
  }
  p1_reactor: "Phase 4 — Timer Expiry" {
    direction: down
    style.fill: "#fadbd8"
    style.stroke: "#e74c3c"
    p1r_desc: {
      shape: sql_table
      label: "reactor_expire_timers(r)"
      c1: "reactor_set_timeout() / set_interval()"
      c2: "timer_heap_t min-heap (CLOCK_MONOTONIC)"
      c3: "Runs AFTER deferred tasks per tick"
    }
  }
}
row1.p1_libuv -> row1.arrow1
row1.arrow1 -> row1.p1_reactor
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  p2_libuv: "Phase 2 — Pending Callbacks" {
    direction: down
    style.fill: "#fdebd0"
    style.stroke: "#e67e22"
    p2_desc: {
      shape: sql_table
      label: "uv__run_pending(loop)"
      c1: "Deferred close callbacks"
      c2: "I/O errors from prev tick"
      c3: "Runs before poll — clears backlog"
    }
  }
  arrow2: "≡" {
    shape: oval
    style.fill: "#f39c12"
    style.font-color: white
    style.stroke: "#e67e22"
    width: 60
    height: 60
  }
  p2_reactor: "Phase 2 — Pending epoll Ops" {
    direction: down
    style.fill: "#fdebd0"
    style.stroke: "#e67e22"
    p2r_desc: {
      shape: sql_table
      label: "apply pending_ops[]"
      c1: "Deferred EPOLL_CTL_DEL / MOD / ADD"
      c2: "Queued during dispatch (dispatching=1)"
      c3: "Clears handler slots after close"
    }
  }
}
row2.p2_libuv -> row2.arrow2
row2.arrow2 -> row2.p2_reactor
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  p3_libuv: "Phase 3 — I/O Poll (HOT PATH)" {
    direction: down
    style.fill: "#d5f5e3"
    style.stroke: "#27ae60"
    style.stroke-width: 2
    p3_desc: {
      shape: sql_table
      label: "uv__io_poll(loop, timeout_ms)"
      c1: "Calls epoll_wait(epfd, evs, MAX, ms)"
      c2: "timeout = nearest timer expiry - now"
      c3: "Returns array of ready fd events"
      c4: "0 connections idle = blocks on epoll"
    }
  }
  arrow3: "≡" {
    shape: oval
    style.fill: "#27ae60"
    style.font-color: white
    style.stroke: "#1e8449"
    width: 60
    height: 60
  }
  p3_reactor: "Phase 1 — epoll_wait (HOT PATH)" {
    direction: down
    style.fill: "#d5f5e3"
    style.stroke: "#27ae60"
    style.stroke-width: 2
    p3r_desc: {
      shape: sql_table
      label: "epoll_wait(r->epfd, events, 1024, ms)"
      c1: "timeout = compute_epoll_timeout(r)"
      c2: "Returns nready ready descriptors"
      c3: "ET mode: EPOLLIN | EPOLLOUT | EPOLLET"
      c4: "dispatching=1 during dispatch loop"
    }
  }
}
row3.p3_libuv -> row3.arrow3
row3.arrow3 -> row3.p3_reactor
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  p4_libuv: "Phase 4 — I/O Callbacks" {
    direction: down
    style.fill: "#d6eaf8"
    style.stroke: "#2980b9"
    p4_desc: {
      shape: sql_table
      label: "uv__io_cb dispatch"
      c1: "uv_tcp_t / uv_udp_t read/write cb"
      c2: "uv_stream_t on_read / on_write"
      c3: "handle = epoll_event.data.ptr"
      c4: "Callback owns the uv_handle_t*"
    }
  }
  arrow4: "≡" {
    shape: oval
    style.fill: "#f39c12"
    style.font-color: white
    style.stroke: "#e67e22"
    width: 60
    height: 60
  }
  p4_reactor: "Phase 1 — I/O Callbacks (same)" {
    direction: down
    style.fill: "#d6eaf8"
    style.stroke: "#2980b9"
    p4r_desc: {
      shape: sql_table
      label: "fd_handler_t dispatch (handlers[fd])"
      c1: "reactor_io_cb(fd, events, udata)"
      c2: "udata = http_conn_t* or echo_conn_t*"
      c3: "data.ptr stores handler pointer (M3+)"
      c4: "h->closing guard prevents UAF"
    }
  }
}
row4.p4_libuv -> row4.arrow4
row4.arrow4 -> row4.p4_reactor
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  p5_libuv: "Phase 5 — setImmediate (check)" {
    direction: down
    style.fill: "#e8daef"
    style.stroke: "#8e44ad"
    p5_desc: {
      shape: sql_table
      label: "uv__run_check(loop)"
      c1: "setImmediate(fn) callbacks"
      c2: "Runs AFTER I/O poll returns"
      c3: "Before next epoll_wait call"
      c4: "Tasks enqueued during this phase"
      c5: "run in NEXT tick (snapshot trick)"
    }
  }
  arrow5: "≡" {
    shape: oval
    style.fill: "#f39c12"
    style.font-color: white
    style.stroke: "#e67e22"
    width: 60
    height: 60
  }
  p5_reactor: "Phase 3 — Deferred Queue" {
    direction: down
    style.fill: "#e8daef"
    style.stroke: "#8e44ad"
    p5r_desc: {
      shape: sql_table
      label: "reactor_defer() drain (deferred[])"
      c1: "reactor_defer_cb(udata) callbacks"
      c2: "Ring buffer: head/tail indices"
      c3: "Snapshot tail before drain loop"
      c4: "New reactor_defer() in cb → next tick"
      c5: "dispatching=0 — epoll_ctl immediate"
    }
  }
}
row5.p5_libuv -> row5.arrow5
row5.arrow5 -> row5.p5_reactor
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  p6_libuv: "process.nextTick (micro-queue)" {
    direction: down
    style.fill: "#f9ebea"
    style.stroke: "#c0392b"
    style.stroke-width: 2
    p6_desc: {
      shape: sql_table
      label: "nextTick queue (highest priority)"
      c1: "Drains BETWEEN every phase"
      c2: "Runs before setImmediate"
      c3: "Can starve I/O if infinite-loops"
      c4: "Not part of uv_run() phase array"
    }
  }
  arrow6: "~" {
    shape: oval
    style.fill: "#95a5a6"
    style.font-color: white
    style.stroke: "#7f8c8d"
    width: 60
    height: 60
  }
  p6_reactor: "Priority Deferred Queue (extension)" {
    direction: down
    style.fill: "#f9ebea"
    style.stroke: "#c0392b"
    style.stroke-width: 2
    p6r_desc: {
      shape: sql_table
      label: "Two-queue extension (not yet built)"
      c1: "next_tick_queue[] — drains before"
      c2: "deferred_queue[] (setImmediate tier)"
      c3: "Current reactor has single deferred[]"
      c4: "Extension: add priority drain pass"
    }
  }
}
row6.p6_libuv -> row6.arrow6: "approx"
row6.arrow6 -> row6.p6_reactor
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  data_structs: "Key Data Structures — Side-by-Side" {
    direction: right
    style.fill: "#fdfefe"
    style.stroke: "#2c3e50"
    style.stroke-width: 2
    libuv_structs: "libuv Types" {
      shape: sql_table
      label: "libuv (deps/uv/include/uv.h)"
      s1: "uv_loop_t    | entire event loop state"
      s2: "uv_tcp_t     | TCP handle (our http_conn_t)"
      s3: "uv_timer_t   | timer handle (our timer_entry_t)"
      s4: "uv_handle_t  | base class (our fd_handler_t)"
      s5: "uv_req_t     | pending I/O request"
      s6: "uv__io_t     | per-fd interest (our fd_handler_t)"
    }
    reactor_structs: "This Project Types" {
      shape: sql_table
      label: "This Project (reactor.h / reactor.c)"
      s1: "reactor_t      | entire event loop state"
      s2: "http_conn_t    | per-connection state (M4)"
      s3: "timer_entry_t  | min-heap node"
      s4: "fd_handler_t   | per-fd callback + udata"
      s5: "deferred_task_t| deferred callback entry"
      s6: "pending_mod_t  | queued epoll_ctl call"
    }
  }
}
row_key: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: "Legend" {
    direction: down
    style.fill: "#fef9e7"
    style.stroke: "#f39c12"
    l1: "≡  (green/orange)  =  structurally identical" {
      style.font-size: 14
    }
    l2: "~  (gray)  =  conceptually equivalent, not identical" {
      style.font-size: 14
    }
    l3: "Phase order: libuv runs timers FIRST; reactor runs timers LAST" {
      style.font-size: 14
      style.italic: true
    }
    l4: "Both use epoll_wait(timeout_ms) as the blocking primitive" {
      style.font-size: 14
    }
  }
}
row0 -> row1: "tick starts"
row1 -> row2: "timers done"
row2 -> row3: "pending cleared"
row3 -> row4: "I/O events ready"
row4 -> row5: "callbacks done"
row5 -> row6: "setImmediate done"
row6 -> row7: "nextTick done"
row7 -> row_key