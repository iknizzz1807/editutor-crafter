direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# ─── HARDWARE LAYER ───────────────────────────────────────────────────────────
hw_layer: "HARDWARE LAYER" {
  direction: right
  style.fill: "#1a1a2e"
  style.stroke: "#e94560"
  style.stroke-width: 2
  style.font-color: "#e94560"
  style.bold: true
  nic: "NIC (Network Interface)" {
    shape: rectangle
    style.fill: "#16213e"
    style.stroke: "#e94560"
    style.font-color: "#e94560"
    style.bold: true
  }
  dma: "DMA Engine" {
    shape: rectangle
    style.fill: "#16213e"
    style.stroke: "#e94560"
    style.font-color: "#e94560"
  }
  cpu: "CPU + Caches" {
    shape: rectangle
    style.fill: "#16213e"
    style.stroke: "#e94560"
    style.font-color: "#e94560"
    desc: "L1 32KB | L2 256KB | L3 8-32MB"
  }
  nic -> dma: "IRQ | DMA xfer"
  dma -> cpu: "interrupt"
}
# ─── KERNEL LAYER ─────────────────────────────────────────────────────────────
kernel_layer: "KERNEL LAYER" {
  direction: right
  style.fill: "#0f3460"
  style.stroke: "#533483"
  style.stroke-width: 2
  style.font-color: "#c084fc"
  style.bold: true
  sock_buf: "Kernel Socket Buffers" {
    shape: sql_table
    label: "socket (net/socket.c)"
    rcv: "recv_buf | ~87KB | filled by NIC/TCP stack"
    snd: "send_buf | ~16KB | drained by TCP stack"
    state: "sk_state  | tcp_state_t | ESTABLISHED etc."
    window: "rcv_wnd   | u32        | advertised window"
  }
  epoll_interest: "epoll Interest Set" {
    shape: sql_table
    label: "epoll instance (fs/eventpoll.c)"
    rbtree: "rb_root   | rbtree     | fd → (events, data)"
    n_fds: "nfds      | int        | O(1) add/remove"
    epfd: "epfd      | int        | returned by epoll_create1"
    note: "EPOLL_CTL_ADD/MOD/DEL"
  }
  ready_q: "Readiness Queue" {
    shape: sql_table
    label: "ready list (eventpoll.c)"
    list: "rdllist   | list_head  | fds ready since last wait"
    lock: "lock      | spinlock_t | kernel-side"
    note: "populated by sock wakeup cb"
  }
  page_cache: "Page Cache" {
    shape: cylinder
    label: "VFS Page Cache"
    style.fill: "#1a1a2e"
    style.stroke: "#533483"
    style.font-color: "#c084fc"
  }
  sock_buf -> epoll_interest: "sk_data_ready() | transition"
  epoll_interest -> ready_q: "ep_poll_callback | enqueue"
}
# ─── M1 LAYER ─────────────────────────────────────────────────────────────────
m1_layer: "MILESTONE 1 — epoll Core (echo_server.c)" {
  direction: right
  style.fill: "#1e3a2f"
  style.stroke: "#22c55e"
  style.stroke-width: 2
  style.font-color: "#22c55e"
  style.bold: true
  m1_anchor: "M1: epoll Basics" {
    shape: hexagon
    style.fill: "#14532d"
    style.stroke: "#22c55e"
    style.font-color: "#22c55e"
    style.bold: true
  }
  epoll_setup: "epoll_create1 + listen_fd" {
    shape: rectangle
    style.fill: "#052e16"
    style.stroke: "#22c55e"
    style.font-color: "#86efac"
    desc: "EPOLL_CLOEXEC | SOCK_NONBLOCK"
  }
  conn_table: "conn_table[MAX_CONNS]" {
    shape: sql_table
    label: "conn_t (echo_server.c)"
    f0: "0x00 | conn_state_t | state"
    f1: "0x04 | int          | fd"
    f2: "0x08 | char[4096]   | read_buf"
    f3: "0x1008 | size_t     | read_len"
    sz: "Total: 4112 bytes | indexed by fd"
  }
  lt_loop: "LT Event Loop" {
    shape: rectangle
    style.fill: "#052e16"
    style.stroke: "#22c55e"
    style.font-color: "#86efac"
    desc: "read 1 chunk | epoll re-notifies if data remains"
  }
  et_loop: "ET Event Loop" {
    shape: rectangle
    style.fill: "#052e16"
    style.stroke: "#16a34a"
    style.font-color: "#86efac"
    desc: "drain until EAGAIN | EPOLLET flag"
  }
  m1_anchor -> epoll_setup: "init"
  epoll_setup -> conn_table: "fd → conn_t"
  conn_table -> lt_loop: "LT path"
  conn_table -> et_loop: "ET path"
}
# ─── M2 LAYER ─────────────────────────────────────────────────────────────────
m2_layer: "MILESTONE 2 — Write Buffer + Timer Heap (conn.c / timer.c)" {
  direction: right
  style.fill: "#1e2a3a"
  style.stroke: "#3b82f6"
  style.stroke-width: 2
  style.font-color: "#60a5fa"
  style.bold: true
  m2_anchor: "M2: Write Buf + Timers" {
    shape: hexagon
    style.fill: "#1e3a5f"
    style.stroke: "#3b82f6"
    style.font-color: "#60a5fa"
    style.bold: true
  }
  write_buf: "write_buf_t" {
    shape: sql_table
    label: "write_buf_t (conn.c)"
    f0: "0x00 | uint8_t*  | data (heap 64KB)"
    f1: "0x08 | size_t    | capacity"
    f2: "0x10 | size_t    | write_offset"
    f3: "0x18 | size_t    | write_len"
    sz: "Total: 32 bytes | pending = len - offset"
  }
  epollout: "EPOLLOUT Lifecycle" {
    shape: rectangle
    style.fill: "#0c1e3a"
    style.stroke: "#3b82f6"
    style.font-color: "#93c5fd"
    desc: "arm on EAGAIN | disarm on drain | else 100% CPU"
  }
  timer_heap: "timer_heap_t (min-heap)" {
    shape: sql_table
    label: "timer_heap_t (timer.c)"
    f0: "entries[N] | timer_entry_t | expiry_ms, fd, heap_idx"
    f1: "size       | int           | current heap entries"
    f2: "sift_up    | O(log n)      | after insert"
    f3: "sift_down  | O(log n)      | after cancel/extract"
    sz: "CLOCK_MONOTONIC | epoll_wait timeout integration"
  }
  m2_anchor -> write_buf: "partial write"
  write_buf -> epollout: "EPOLL_CTL_MOD"
  m2_anchor -> timer_heap: "idle timeout 30s"
}
# ─── M3 LAYER ─────────────────────────────────────────────────────────────────
m3_layer: "MILESTONE 3 — Reactor API (reactor.c)" {
  direction: right
  style.fill: "#2a1e3a"
  style.stroke: "#a855f7"
  style.stroke-width: 2
  style.font-color: "#d8b4fe"
  style.bold: true
  m3_anchor: "M3: Reactor Abstraction" {
    shape: hexagon
    style.fill: "#3b0764"
    style.stroke: "#a855f7"
    style.font-color: "#d8b4fe"
    style.bold: true
  }
  reactor_struct: "reactor_t" {
    shape: class
    label: "reactor_t (reactor.h)"
    -epfd: "int"
    -running: "int"
    -dispatching: "int"
    -handlers: "fd_handler_t*"
    -timer_pool: "timer_entry_t*"
    -timer_heap: "int*"
    -deferred: "deferred_task_t[1024]"
    -pending_ops: "pending_mod_t[256]"
    +reactor_create(max_fds, max_timers): "reactor_t*"
    +reactor_register(r, fd, events, cb, udata): "int"
    +reactor_deregister(r, fd): "int"
    +reactor_set_timeout(r, delay_ms, cb, udata): "int"
    +reactor_set_interval(r, interval_ms, cb, udata): "int"
    +reactor_cancel_timer(r, timer_id): "int"
    +reactor_defer(r, cb, udata): "int"
    +reactor_run(r): "void"
    +reactor_stop(r): "void"
    +reactor_destroy(r): "void"
  }
  dispatch_phases: "4-Phase Dispatch Loop" {
    shape: sql_table
    label: "reactor_run() phases (reactor.c)"
    p1: "Phase 1 | I/O Dispatch    | dispatching=1 | callbacks fire"
    p2: "Phase 2 | Apply Pending   | epoll_ctl deferred ops"
    p3: "Phase 3 | Deferred Tasks  | reactor_defer queue | nextTick"
    p4: "Phase 4 | Expire Timers   | min-heap walk | close idle"
  }
  reentrancy: "Re-entrancy Guard" {
    shape: rectangle
    style.fill: "#1a0a2e"
    style.stroke: "#a855f7"
    style.font-color: "#d8b4fe"
    desc: "dispatching=1 → enqueue pending_ops | closing=1 → mark-skip"
  }
  m3_anchor -> reactor_struct: "owns"
  reactor_struct -> dispatch_phases: "reactor_run()"
  dispatch_phases -> reentrancy: "iterator safety"
}
# ─── M4 LAYER ─────────────────────────────────────────────────────────────────
m4_layer: "MILESTONE 4 — HTTP/1.1 Server (http_server.c)" {
  direction: right
  style.fill: "#2a1a1a"
  style.stroke: "#ef4444"
  style.stroke-width: 2
  style.font-color: "#fca5a5"
  style.bold: true
  m4_anchor: "M4: HTTP Server + C10K" {
    shape: hexagon
    style.fill: "#450a0a"
    style.stroke: "#ef4444"
    style.font-color: "#fca5a5"
    style.bold: true
  }
  http_conn: "http_conn_t" {
    shape: sql_table
    label: "http_conn_t (http_server.c)"
    f0: "0x00  | int              | fd"
    f1: "0x04  | http_conn_state_t| state (6 states)"
    f2: "0x08  | int              | idle_timer_id"
    f3: "0x0c  | int              | header_timer_id"
    f4: "0x10  | char[16384]      | read_buf"
    f5: "0x4010| uint8_t*         | write_buf (64KB heap)"
    f6: "0x4018| http_request_t   | method, path, headers[32]"
    sz: "Total: ~26KB | 10K conns = ~260MB"
  }
  http_sm: "HTTP State Machine" {
    shape: sql_table
    label: "http_conn_state_t transitions"
    s0: "READING_HEADERS  → parse until CRLF CRLF found"
    s1: "READING_BODY     → accumulate Content-Length bytes"
    s2: "PROCESSING       → open file, build response"
    s3: "WRITING_RESPONSE → flush write_buf, handle EAGAIN"
    s4: "KEEP_ALIVE       → reset state, await next request"
    s5: "CLOSING          → cancel timers, deregister, free"
  }
  parser: "Incremental HTTP Parser" {
    shape: rectangle
    style.fill: "#1a0505"
    style.stroke: "#ef4444"
    style.font-color: "#fca5a5"
    desc: "find_header_end() | parse_request_line() | parse_headers() | resumable"
  }
  static_serve: "Static File Serving" {
    shape: rectangle
    style.fill: "#1a0505"
    style.stroke: "#dc2626"
    style.font-color: "#fca5a5"
    desc: "realpath() sanitize | MIME table | read()+write() | sendfile() path"
  }
  m4_anchor -> http_conn: "per connection"
  http_conn -> http_sm: "state transitions"
  http_sm -> parser: "READING_* states"
  http_sm -> static_serve: "PROCESSING state"
}
# ─── DATA FLOW: vertical stack ────────────────────────────────────────────────
hw_layer -> kernel_layer: "NIC DMA → sock recv_buf" {
  style.stroke: "#e94560"
  style.stroke-width: 2
  style.animated: true
}
kernel_layer -> m1_layer: "epoll_wait() → events[]" {
  style.stroke: "#22c55e"
  style.stroke-width: 2
  style.animated: true
}
m1_layer -> m2_layer: "conn_t + read handler" {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
}
m2_layer -> m3_layer: "write_buf_t + timer_heap_t" {
  style.stroke: "#a855f7"
  style.stroke-width: 2
}
m3_layer -> m4_layer: "reactor_register() | reactor_defer()" {
  style.stroke: "#ef4444"
  style.stroke-width: 2
}
# ─── CROSS-LAYER CONTROL FLOWS ────────────────────────────────────────────────
m4_layer -> kernel_layer: "write() | sendfile()" {
  style.stroke: "#f97316"
  style.stroke-dash: 4
  style.stroke-width: 1
}
m3_layer -> m1_layer: "epoll_ctl ADD/MOD/DEL" {
  style.stroke: "#a855f7"
  style.stroke-dash: 5
  style.stroke-width: 1
}
m2_layer -> m1_layer: "EPOLL_CTL_MOD EPOLLOUT" {
  style.stroke: "#3b82f6"
  style.stroke-dash: 5
  style.stroke-width: 1
}
# ─── LEGEND ───────────────────────────────────────────────────────────────────
legend: "Legend" {
  near: bottom-right
  shape: rectangle
  style.fill: "#111827"
  style.stroke: "#374151"
  style.font-color: "#f9fafb"
  l1: "Solid arrow  = data flow (bytes)"
  l2: "Dashed arrow = control flow (syscalls)"
  l3: "Animated     = hot path (packet delivery)"
  l4: "Hexagon      = milestone anchor node"
}