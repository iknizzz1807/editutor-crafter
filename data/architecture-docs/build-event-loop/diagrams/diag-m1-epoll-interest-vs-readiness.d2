direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # epoll: Interest Set vs. Readiness Queue (Kernel Data Structures)
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  user_api: "User API (epoll_ctl / epoll_wait)" {
    direction: down
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.border-radius: 8
    api_table: {
      shape: sql_table
      label: "epoll syscalls (user.c)"
      create: "epoll_create1(EPOLL_CLOEXEC)  → epfd"
      add:    "epoll_ctl(epfd, ADD, fd, &ev) → interest set insert"
      mod:    "epoll_ctl(epfd, MOD, fd, &ev) → interest set update"
      del:    "epoll_ctl(epfd, DEL, fd, NULL)→ interest set remove"
      wait:   "epoll_wait(epfd, events, n, t)→ drain readiness queue"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  interest_col: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    interest_hdr: "INTEREST SET — Red-Black Tree (O(log n) lookup)" {
      style.fill: "#7B1FA2"
      style.font-color: white
      style.bold: true
      style.border-radius: 4
    }
    rb_tree: "struct epitem rb-tree (fs/eventpoll.c)" {
      direction: down
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      style.border-radius: 6
      row_a: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        node1: {
          shape: sql_table
          label: "epitem (fd=3)"
          f1: "fd:       int    | 3"
          f2: "events:   u32    | EPOLLIN|ET"
          f3: "ffd:      file*  | &file[3]"
          f4: "pwqlist:  list   | wait_queue ptr"
          f5: "nwait:    int    | 1"
          sz: "Total: 80 bytes"
        }
        node2: {
          shape: sql_table
          label: "epitem (fd=7)"
          f1: "fd:       int    | 7"
          f2: "events:   u32    | EPOLLIN|EPOLLOUT"
          f3: "ffd:      file*  | &file[7]"
          f4: "pwqlist:  list   | wait_queue ptr"
          f5: "nwait:    int    | 1"
          sz: "Total: 80 bytes"
        }
      }
      row_b: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        node3: {
          shape: sql_table
          label: "epitem (fd=12)"
          f1: "fd:       int    | 12"
          f2: "events:   u32    | EPOLLIN"
          f3: "ffd:      file*  | &file[12]"
          f4: "pwqlist:  list   | wait_queue ptr"
          f5: "nwait:    int    | 1"
          sz: "Total: 80 bytes"
        }
        node4: {
          shape: sql_table
          label: "epitem (fd=99)"
          f1: "fd:       int    | 99"
          f2: "events:   u32    | EPOLLIN"
          f3: "ffd:      file*  | &file[99]"
          f4: "pwqlist:  list   | wait_queue ptr"
          f5: "nwait:    int    | 1"
          sz: "Total: 80 bytes"
        }
      }
      complexity: {
        shape: sql_table
        label: "Red-Black Tree Properties"
        p1: "Lookup:  O(log n) by fd key"
        p2: "Insert:  O(log n) — epoll_ctl ADD"
        p3: "Delete:  O(log n) — epoll_ctl DEL"
        p4: "n=10000: ~13 comparisons per op"
        p5: "Stored in kernel, NOT user memory"
      }
    }
  }
  readiness_col: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    ready_hdr: "READINESS QUEUE — Linked List (O(1) drain)" {
      style.fill: "#1B5E20"
      style.font-color: white
      style.bold: true
      style.border-radius: 4
    }
    rq: "struct list_head rdllist (fs/eventpoll.c)" {
      direction: down
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      style.border-radius: 6
      rdl_note: {
        shape: sql_table
        label: "rdllist: doubly-linked list of ready epitem*"
        n1: "Only fds with PENDING events appear here"
        n2: "Kernel appends when socket buffer changes"
        n3: "epoll_wait copies and clears in O(ready) time"
        n4: "LT mode: re-adds if buffer still non-empty"
        n5: "ET mode: NOT re-added — one event per transition"
      }
      ready_fd7: {
        shape: sql_table
        label: "ready_entry → fd=7  (EPOLLIN|EPOLLOUT ready)"
        e1: "epitem*:  &epitem[fd=7]"
        e2: "revents:  EPOLLIN | EPOLLOUT"
        e3: "next:     → ready_fd12"
        e4: "prev:     → list_head"
      }
      ready_fd12: {
        shape: sql_table
        label: "ready_entry → fd=12 (EPOLLIN ready)"
        e1: "epitem*:  &epitem[fd=12]"
        e2: "revents:  EPOLLIN"
        e3: "next:     → NULL (end of list)"
        e4: "prev:     → ready_fd7"
      }
      wait_note: {
        shape: sql_table
        label: "epoll_wait() output — copied to userspace"
        w1: "struct epoll_event events[MAX]"
        w2: "events[0]: {.events=EPOLLIN|EPOLLOUT, .data.fd=7}"
        w3: "events[1]: {.events=EPOLLIN,           .data.fd=12}"
        w4: "returns nready=2  (fd=3, fd=99 idle — not here)"
        w5: "O(nready) copy — NOT O(n_registered)"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_path: "Kernel Event Delivery Path" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.border-radius: 6
    path_table: {
      shape: sql_table
      label: "NIC → Socket Buffer → epoll (per packet)"
      s1: "1. NIC raises hardware interrupt (IRQ)"
      s2: "2. Interrupt handler: DMA bytes → sk_receive_buf"
      s3: "3. sk_data_ready() callback fires on socket"
      s4: "4. Kernel walks socket wait_queue → finds epitem"
      s5: "5. ep_poll_callback(): appends epitem → rdllist"
      s6: "6. wake_up() unblocks thread sleeping in epoll_wait"
      s7: "7. epoll_wait copies rdllist → userspace events[]"
      s8: "8. rdllist cleared (ET) or re-checked (LT)"
    }
  }
  scale_box: "Why epoll Scales (vs select/poll)" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.border-radius: 6
    scale_table: {
      shape: sql_table
      label: "Complexity Comparison (n = watched fds)"
      h0: "Operation      | select/poll | epoll"
      r1: "Register fd    | O(1)        | O(log n)"
      r2: "Deregister fd  | O(1)        | O(log n)"
      r3: "Wait for event | O(n) rescan | O(1) sleep"
      r4: "Event delivery | O(n) rescan | O(1) append"
      r5: "Return results | O(n) copy   | O(ready) copy"
      r6: "n=10000, 50 ready: select rescans 10000; epoll copies 50"
    }
  }
}
row0 -> row1: "epoll_ctl ADD/MOD/DEL | write to interest set"
row1.interest_col.rb_tree -> row1.readiness_col.rq: "packet arrives → ep_poll_callback() | O(1) append"
row1.readiness_col.rq -> row2: "epoll_wait() drain | O(nready)"
row0 -> row2: "epoll_wait() call | blocks thread until ready"
row1.interest_col.rb_tree.row_a.node2.f1 -> row1.readiness_col.rq.ready_fd7: "fd=7 became ready"
row1.interest_col.rb_tree.row_b.node3.f1 -> row1.readiness_col.rq.ready_fd12: "fd=12 became ready"