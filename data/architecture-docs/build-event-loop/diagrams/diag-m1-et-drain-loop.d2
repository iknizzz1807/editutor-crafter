direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Edge-Triggered Drain Loop — Correct vs. Incorrect
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wrong_side: "WRONG: Single Read per ET Event" {
    direction: down
    style.fill: "#fff0f0"
    style.stroke: "#cc0000"
    style.border-radius: 8
    w_event: "EPOLLIN fires on fd=5" {
      shape: oval
      style.fill: "#ffcccc"
      style.stroke: "#cc0000"
      style.bold: true
    }
    w_read: "read(fd, buf, 4096)" {
      shape: rectangle
      style.fill: "#ffe0e0"
      style.stroke: "#cc0000"
      label: "read(fd, buf, 4096)"
      width: 280
    }
    w_read_result: "Returns n = 4096 bytes" {
      shape: rectangle
      style.fill: "#ffe0e0"
      style.stroke: "#cc0000"
      width: 280
    }
    w_process: "process(buf, 4096)" {
      shape: rectangle
      style.fill: "#ffe0e0"
      style.stroke: "#cc0000"
      width: 280
    }
    w_return: "return  (handler exits)" {
      shape: rectangle
      style.fill: "#ffcccc"
      style.stroke: "#cc0000"
      style.bold: true
      width: 280
    }
    w_kernel_buf: "Kernel recv buffer" {
      shape: sql_table
      label: "Kernel recv buf (fd=5)"
      consumed: "0x000 — 0xFFF  | 4096 B | CONSUMED by read()"
      remaining: "0x1000 — 0x1FFF | 4096 B | STUCK — unread"
      note: "No new data arrives → no ET transition"
      style.fill: "#fff5cc"
      style.stroke: "#cc8800"
    }
    w_epoll_wait: "epoll_wait() → returns 0 events" {
      shape: rectangle
      style.fill: "#ffcccc"
      style.stroke: "#cc0000"
      style.bold: true
      width: 280
    }
    w_stall: "CONNECTION STALLED" {
      shape: oval
      style.fill: "#cc0000"
      style.font-color: white
      style.bold: true
      width: 280
    }
    w_event -> w_read: "ET: EPOLLIN delivered once"
    w_read -> w_read_result: "ret=4096, errno=0"
    w_read_result -> w_process
    w_process -> w_return: "BUG: exits without draining"
    w_return -> w_kernel_buf: "4096 B remain unread"
    w_kernel_buf -> w_epoll_wait: "no new arrival → no transition"
    w_epoll_wait -> w_stall: "silent hang forever"
  }
  correct_side: "CORRECT: Drain Loop Until EAGAIN" {
    direction: down
    style.fill: "#f0fff0"
    style.stroke: "#006600"
    style.border-radius: 8
    c_event: "EPOLLIN fires on fd=5" {
      shape: oval
      style.fill: "#ccffcc"
      style.stroke: "#006600"
      style.bold: true
    }
    c_loop_top: "while (true)" {
      shape: diamond
      style.fill: "#ccffcc"
      style.stroke: "#006600"
      style.bold: true
      width: 280
    }
    c_read: "n = read(fd, buf, 4096)" {
      shape: rectangle
      style.fill: "#e0ffe0"
      style.stroke: "#006600"
      width: 280
    }
    c_check_eagain: "n == -1 ?" {
      shape: diamond
      style.fill: "#ccffcc"
      style.stroke: "#006600"
      width: 280
    }
    c_check_errno: "errno == EAGAIN ?" {
      shape: diamond
      style.fill: "#ccffcc"
      style.stroke: "#006600"
      width: 280
    }
    c_break: "break  (buffer drained)" {
      shape: rectangle
      style.fill: "#99ff99"
      style.stroke: "#006600"
      style.bold: true
      width: 280
    }
    c_real_err: "real error → close(fd)" {
      shape: rectangle
      style.fill: "#ffeeaa"
      style.stroke: "#888800"
      width: 280
    }
    c_check_eof: "n == 0 ?" {
      shape: diamond
      style.fill: "#ccffcc"
      style.stroke: "#006600"
      width: 280
    }
    c_eof_close: "EOF → close(fd)" {
      shape: rectangle
      style.fill: "#ffeeaa"
      style.stroke: "#888800"
      width: 280
    }
    c_process: "process(buf, n)" {
      shape: rectangle
      style.fill: "#e0ffe0"
      style.stroke: "#006600"
      width: 280
    }
    c_kernel_buf: "Kernel recv buffer" {
      shape: sql_table
      label: "Kernel recv buf (fd=5)"
      r1: "0x000 — 0xFFF  | 4096 B | read() #1 → ret=4096"
      r2: "0x1000 — 0x1FFF | 4096 B | read() #2 → ret=4096"
      r3: "0x2000+          | 0 B   | read() #3 → ret=-1, EAGAIN"
      style.fill: "#ccffcc"
      style.stroke: "#006600"
    }
    c_epoll_ready: "epoll_wait() notifies on NEXT new data" {
      shape: oval
      style.fill: "#006600"
      style.font-color: white
      style.bold: true
      width: 280
    }
    c_event -> c_loop_top: "ET: EPOLLIN delivered once"
    c_loop_top -> c_read: "loop iteration"
    c_read -> c_check_eagain: "syscall returns"
    c_check_eagain -> c_check_errno: "yes (n == -1)"
    c_check_errno -> c_break: "yes → EAGAIN | buffer empty"
    c_check_errno -> c_real_err: "no → ECONNRESET etc."
    c_check_eagain -> c_check_eof: "no (n != -1)"
    c_check_eof -> c_eof_close: "yes (n == 0) | peer FIN"
    c_check_eof -> c_process: "no (n > 0) | data bytes"
    c_process -> c_loop_top: "continue drain"
    c_break -> c_kernel_buf: "fully drained"
    c_kernel_buf -> c_epoll_ready: "transition occurs on next arrival"
  }
}
annotation_box: "ET Invariant" {
  direction: down
  style.fill: "#fffbe6"
  style.stroke: "#ccaa00"
  style.border-radius: 6
  width: 680
  rule1: "Rule: EPOLLET fires ONCE per not-ready → ready transition" {
    shape: rectangle
    style.fill: "#fffbe6"
    style.stroke: transparent
    width: 660
  }
  rule2: "Implication: unread bytes in kernel buf cause NO further notifications" {
    shape: rectangle
    style.fill: "#fffbe6"
    style.stroke: transparent
    width: 660
  }
  rule3: "Fix: call read() in a loop until errno == EAGAIN (buffer empty)" {
    shape: rectangle
    style.fill: "#fffbe6"
    style.stroke: transparent
    width: 660
  }
  rule4: "Diagnosis: ss -ti shows rcv_buf bytes with idle connection = ET drain bug" {
    shape: rectangle
    style.fill: "#fffbe6"
    style.stroke: transparent
    width: 660
  }
}
row1 -> annotation_box: "summary"