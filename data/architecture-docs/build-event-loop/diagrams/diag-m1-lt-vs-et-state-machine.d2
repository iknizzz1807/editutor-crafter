direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # LT vs ET: Kernel Notification State Machine
| {near: top-center}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lt_panel: "LEVEL-TRIGGERED (LT) — Default Mode" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.stroke-width: 2
    lt_idle: "FD IDLE" {
      shape: circle
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
      style.stroke-width: 2
      width: 120
      height: 120
    }
    lt_has_data: "RECV BUFFER\nHAS DATA" {
      shape: circle
      style.fill: "#fff9c4"
      style.stroke: "#f9a825"
      style.stroke-width: 2
      width: 140
      height: 140
    }
    lt_on_list: "ON READINESS\nLIST" {
      shape: circle
      style.fill: "#ffe082"
      style.stroke: "#f57f17"
      style.stroke-width: 3
      width: 140
      height: 140
    }
    lt_returned: "RETURNED BY\nepoll_wait()" {
      shape: circle
      style.fill: "#fff3e0"
      style.stroke: "#e65100"
      style.stroke-width: 2
      width: 150
      height: 150
    }
    lt_partial_read: "HANDLER READS\nPARTIAL DATA" {
      shape: diamond
      style.fill: "#f3e5f5"
      style.stroke: "#7b1fa2"
      style.stroke-width: 2
      width: 200
      height: 100
    }
    lt_re_listed: "RE-ADDED TO\nREADINESS LIST" {
      shape: circle
      style.fill: "#ffe082"
      style.stroke: "#f57f17"
      style.stroke-width: 3
      width: 160
      height: 160
    }
    lt_drained: "BUFFER\nFULLY DRAINED" {
      shape: circle
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
      style.stroke-width: 2
      width: 140
      height: 140
    }
    lt_safe_note: "LT SAFE NOTE" {
      shape: class
      label: "LT Safety (reactor.c)"
      partial_ok: "partial reads OK — auto re-notified"
      no_drain_loop: "no drain loop required"
      cost: "higher: stale fds in readiness list"
      used_by: "most servers, safe default"
    }
    lt_idle -> lt_has_data: "data arrives\nin recv buf"
    lt_has_data -> lt_on_list: "kernel adds fd\nto readiness queue"
    lt_on_list -> lt_returned: "epoll_wait()\nreturns EPOLLIN"
    lt_returned -> lt_partial_read: "handler called"
    lt_partial_read -> lt_re_listed: "data remains\nin buffer"
    lt_partial_read -> lt_drained: "buffer empty\n(EAGAIN)"
    lt_drained -> lt_idle: "wait for\nnew data"
    lt_re_listed -> lt_returned: "NEXT epoll_wait()\nauto-returns fd" {
      style.stroke: "#f57f17"
      style.stroke-width: 2
      style.stroke-dash: 4
    }
  }
  et_panel: "EDGE-TRIGGERED (ET) — EPOLLET Flag" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#b71c1c"
    style.stroke-width: 2
    et_idle: "FD IDLE\n(no data)" {
      shape: circle
      style.fill: "#ffcdd2"
      style.stroke: "#b71c1c"
      style.stroke-width: 2
      width: 120
      height: 120
    }
    et_transition: "STATE TRANSITION\nno-data → has-data" {
      shape: diamond
      style.fill: "#fff9c4"
      style.stroke: "#f9a825"
      style.stroke-width: 3
      width: 220
      height: 100
    }
    et_on_list: "ADDED TO\nREADINESS LIST\n(EXACTLY ONCE)" {
      shape: circle
      style.fill: "#ef9a9a"
      style.stroke: "#c62828"
      style.stroke-width: 3
      width: 160
      height: 160
    }
    et_returned: "RETURNED BY\nepoll_wait()" {
      shape: circle
      style.fill: "#ffcdd2"
      style.stroke: "#b71c1c"
      style.stroke-width: 2
      width: 150
      height: 150
    }
    et_removed: "REMOVED FROM\nREADINESS LIST" {
      shape: circle
      style.fill: "#b0bec5"
      style.stroke: "#546e7a"
      style.stroke-width: 2
      width: 160
      height: 160
    }
    et_handler_choice: "HANDLER READS\nHOW MUCH?" {
      shape: diamond
      style.fill: "#f3e5f5"
      style.stroke: "#7b1fa2"
      style.stroke-width: 2
      width: 200
      height: 100
    }
    et_drained_ok: "DRAIN TO\nEAGAIN ✓" {
      shape: circle
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
      style.stroke-width: 3
      width: 140
      height: 140
    }
    et_bug: "DATA STRANDED\nIN BUFFER ☠" {
      shape: circle
      style.fill: "#d32f2f"
      style.stroke: "#b71c1c"
      style.stroke-width: 4
      style.font-color: white
      width: 160
      height: 160
    }
    et_wait_new: "WAITING FOR\nNEXT TRANSITION" {
      shape: circle
      style.fill: "#ffcdd2"
      style.stroke: "#b71c1c"
      style.stroke-width: 2
      width: 160
      height: 160
    }
    et_bug_detail: "BUG ANATOMY" {
      shape: class
      label: "ET Drain Bug (echo_server.c)"
      symptom: "client sends 8192B, handler reads 4096B"
      effect: "4096B sits silent in recv buffer forever"
      no_new_data: "no new transition → no new event"
      detection: "ss -ti shows rcv_buf bytes pending"
      fix: "while(read()!=EAGAIN) loop required"
    }
    et_idle -> et_transition: "new bytes\narrive in buf"
    et_transition -> et_on_list: "kernel detects\nno-data→data edge"
    et_on_list -> et_returned: "epoll_wait()\nreturns EPOLLIN"
    et_returned -> et_removed: "fd auto-removed\nfrom readiness list"
    et_removed -> et_handler_choice: "handler invoked"
    et_handler_choice -> et_drained_ok: "reads until\nEAGAIN"
    et_handler_choice -> et_bug: "reads only\nonce (WRONG)"
    et_drained_ok -> et_wait_new: "buffer empty\nready for next"
    et_wait_new -> et_idle: "client closes\nor server resets"
    et_wait_new -> et_transition: "new data\narrives" {
      style.stroke: "#2e7d32"
      style.stroke-width: 2
    }
    et_bug -> et_bug: "HUNG FOREVER\nno EAGAIN seen\nno re-notification" {
      style.stroke: "#d32f2f"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
  }
}
comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lt_summary: "LT PROPERTIES" {
    shape: sql_table
    label: "Level-Triggered Properties (epoll.h)"
    r1: "Re-notify       | YES — if buffer still has data"
    r2: "Read strategy   | One chunk per event is safe"
    r3: "Missed data     | Never — epoll re-notifies"
    r4: "Busy-loop risk  | Possible if ignored for long"
    r5: "Complexity      | Lower — forgiving"
    r6: "Used by         | General servers, safe default"
  }
  et_summary: "ET PROPERTIES" {
    shape: sql_table
    label: "Edge-Triggered Properties (epoll.h)"
    r1: "Re-notify       | NO — only on state transition"
    r2: "Read strategy   | MUST drain to EAGAIN always"
    r3: "Missed data     | YES if drain loop missing"
    r4: "Busy-loop risk  | None — notifications minimal"
    r5: "Complexity      | Higher — strict contract"
    r6: "Used by         | NGINX, Node.js libuv, Redis"
  }
}
row_main -> comparison: "" {
  style.stroke: transparent
}