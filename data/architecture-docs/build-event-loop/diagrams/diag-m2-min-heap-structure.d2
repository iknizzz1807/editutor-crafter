direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Min-Heap Timer Data Structure — Memory Layout and Operations" {
  near: top-center
  style: {
    font-size: 20
    bold: true
  }
}
row_structs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timer_node: {
    label: "struct timer_node_t (timer_heap.h)"
    shape: sql_table
    f0: "0x00 | uint64_t | expiry_ms  // CLOCK_MONOTONIC abs ms"
    f1: "0x08 | int      | conn_id    // index into conn_table[]"
    f2: "0x0C | bool     | cancelled  // lazy-delete flag"
    f3: "0x0D | uint8_t  | _pad[3]   // alignment padding"
    sz: "Total: 16 bytes (1/4 cache line)"
  }
  heap_struct: {
    label: "struct timer_heap_t (timer_heap.h)"
    shape: sql_table
    h0: "0x00 | timer_node_t* | nodes       // heap-allocated array"
    h1: "0x08 | int           | size        // active entries"
    h2: "0x0C | int           | capacity    // allocated slots"
    h3: "0x10 | int           | n_cancelled // lazy-deleted count"
    sz: "Total: 20 bytes + nodes[capacity*16]"
    note: "n=10K: nodes = 10240*16 = 163,840 bytes (~160KB, fits L2/L3)"
  }
}
