    legend_prop: {
      shape: sql_table
      label: "Heap Invariant (min-heap)"
      prop1: "heap[i].expiry_ms <= heap[2*i+1].expiry_ms"
      prop2: "heap[i].expiry_ms <= heap[2*i+2].expiry_ms"
      prop3: "Parent idx: (i-1)/2"
      prop4: "Left child:  2*i+1"
      prop5: "Right child: 2*i+2"
    }
