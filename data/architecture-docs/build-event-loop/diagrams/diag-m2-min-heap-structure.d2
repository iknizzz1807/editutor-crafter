    }
    level1: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      left_child: "nodes[1] expiry=2500 conn=7" {
        shape: circle
        style.fill: "#fff9c4"
      }
      right_child: "nodes[2] expiry=3100 CANCELLED" {
        shape: circle
        style.fill: "#ffccbc"
        style.stroke: "#bf360c"
      }
    }
    level2: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      ll: "nodes[3] expiry=5000" {
        shape: circle
        style.fill: "#fff9c4"
      }
      lr: "nodes[4] expiry=6200" {
