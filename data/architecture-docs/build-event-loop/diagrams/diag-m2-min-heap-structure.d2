        style.fill: "#ffccbc"
        style.stroke: "#bf360c"
      }
      idx3: "idx=3" {
        shape: sql_table
        label: "nodes[3]"
        e: "expiry_ms: 5000"
        c: "conn_id:   15"
        x: "cancelled: false"
