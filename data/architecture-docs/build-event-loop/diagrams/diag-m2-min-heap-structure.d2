    }
    root_node -> level1.left_child: "i=0, left=1"
    root_node -> level1.right_child: "i=0, right=2"
    level1.left_child -> level2.ll: "i=1, left=3"
    level1.left_child -> level2.lr: "i=1, right=4"
    level1.right_child -> level2.rl: "i=2, left=5"
  }
}
row_heap_array.heap_visual.arr_row.idx0 -> row_heap_array.tree_view.root_node: "maps to"
row_ops: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_insert: "INSERT Operation — O(log n)" {
    direction: down
    style.fill: "#e8eaf6"
    style.stroke: "#3949ab"
    insert_steps: {
      shape: sql_table
      label: "timer_heap_insert(heap, node)"
      s1: "Step 1 | Append to nodes[size]     | O(1)       | size++"
      s2: "Step 2 | i = size - 1              | O(1)       | start idx"
      s3: "Step 3 | SIFT-UP loop              | O(log n)   | restore heap"
      s4: "  3a   |   parent = (i-1)/2        | O(1)       | parent idx"
      s5: "  3b   |   if nodes[parent] <= nodes[i]: break | O(1)"
      s6: "  3c   |   swap(nodes[parent], nodes[i])       | O(1)"
      s7: "  3d   |   i = parent; goto 3a     | O(1)       | move up"
      s8: "n=10K  | max swaps = log2(10000) ~ 13 swaps    | 13 iters"
    }
    insert_code: {
      label: "sift_up (timer_heap.c)"
      width: 420
      code: |'c
        void sift_up(timer_heap_t *h, int i) {
            while (i > 0) {
                int p = (i - 1) / 2;
                if (h->nodes[p].expiry_ms
                    <= h->nodes[i].expiry_ms) break;
                swap(&h->nodes[p], &h->nodes[i]);
                i = p;  // move up
            }
        }
      '|
    }
  }
  op_extract: "EXTRACT-MIN Operation — O(log n)" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    extract_steps: {
      shape: sql_table
      label: "timer_heap_extract_min(heap)"
      s1: "Step 1 | Skip cancelled root: pop+retry        | O(log n)"
      s2: "Step 2 | result = nodes[0]          | O(1)       | save min"
      s3: "Step 3 | nodes[0] = nodes[size-1]  | O(1)       | move last"
      s4: "Step 4 | size--                    | O(1)       | shrink"
      s5: "Step 5 | SIFT-DOWN from i=0        | O(log n)   | restore"
      s6: "  5a   |   left  = 2*i+1           | O(1)"
      s7: "  5b   |   right = 2*i+2           | O(1)"
      s8: "  5c   |   smallest = min(i,l,r)   | O(1)"
      s9: "  5d   |   if smallest==i: break   | O(1)"
      sa: "  5e   |   swap(i, smallest); i=smallest       | O(1)"
      sb: "n=10K  | max depth = log2(10000) ~ 13 levels"
    }
    extract_code: {
      label: "sift_down (timer_heap.c)"
      width: 420
      code: |'c
        void sift_down(timer_heap_t *h, int i) {
            int n = h->size;
            while (1) {
                int l = 2*i+1, r = 2*i+2, s = i;
                if (l<n && h->nodes[l].expiry_ms
                         < h->nodes[s].expiry_ms) s=l;
                if (r<n && h->nodes[r].expiry_ms
                         < h->nodes[s].expiry_ms) s=r;
                if (s == i) break;
                swap(&h->nodes[i], &h->nodes[s]);
                i = s;
            }
        }
      '|
    }
  }
  op_cancel: "CANCEL Operation — O(1) amortized (lazy delete)" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#c62828"
    cancel_steps: {
      shape: sql_table
      label: "timer_heap_cancel(heap, conn_id)"
      s1: "Step 1 | Find node by conn_id       | O(n) naive / O(1) with index"
      s2: "Step 2 | node.cancelled = true      | O(1)  | mark, do NOT remove"
      s3: "Step 3 | heap.n_cancelled++         | O(1)  | track for compaction"
      s4: "----   | No heap restructure needed | O(1) total"
      s5: "SKIP   | extract_min skips cancelled nodes: pop+retry"
      s6: "COMPACT| When n_cancelled > size/2: rebuild  | O(n log n)"
      note: "Lazy delete avoids O(log n) remove; correct because"
      note2: "cancelled nodes are skipped during extract_min loop"
    }
    cancel_code: {
      label: "cancel + skip-on-extract (timer_heap.c)"
      width: 420
      code: |'c
        // CANCEL: O(1) mark
        void timer_cancel(timer_heap_t *h, int conn_id) {
            // conn stores its heap-idx for O(1) lookup
            int i = conn_table[conn_id].heap_idx;
            h->nodes[i].cancelled = true;
            h->n_cancelled++;
        }
        // EXTRACT: skip cancelled
        timer_node_t extract_min(timer_heap_t *h) {
            while (h->size > 0 &&
                   h->nodes[0].cancelled) {
                _extract_root(h); // sift-down
                h->n_cancelled--;
            }
            return _extract_root(h);
        }
      '|
    }
  }
}
row_complexity: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  complexity_table: "Operation Complexity Summary — n = 10,000 timers" {
    shape: sql_table
    label: "timer_heap_t Performance"
    c0: "Operation   | Complexity  | n=10K Cost         | Notes"
    c1: "INSERT      | O(log n)    | ~13 comparisons    | append + sift-up"
    c2: "EXTRACT-MIN | O(log n)    | ~13 comparisons    | swap root + sift-down"
    c3: "CANCEL      | O(1)        | 1 write            | lazy delete, no restructure"
    c4: "PEEK-MIN    | O(1)        | 1 read nodes[0]    | always root"
    c5: "BUILD-HEAP  | O(n)        | n/2 sift-downs     | Floyd's algorithm"
    c6: "COMPACT     | O(n log n)  | rare (>50% cancel) | rebuild from scratch"
    c7: "Memory      | O(n)        | 10K*16B = 160KB    | fits in L2/L3 cache"
    c8: "vs Sort.List| O(n) insert | 10K compares       | 769x slower at insert"
    c9: "vs T.Wheel  | O(1) both   | 0 compares         | more complex, fixed res"
  }
  cache_note: "Hardware: Cache Behavior at n=10K" {
    shape: sql_table
    label: "Cache Analysis (timer_heap.c)"
    n1: "Heap array size | 10K*16B = 160KB | L2 (256KB) boundary — hot under load"
    n2: "Sift-up path    | 13 nodes * 16B  | 208B — 4 cache lines — L1 hot"
    n3: "Sift-down path  | 13 nodes * 16B  | 208B — 4 cache lines — L1 hot"
    n4: "Root access     | nodes[0]        | always L1 — most frequent access"
    n5: "CLOCK_MONOTONIC | vDSO call ~20ns | no syscall — kernel maps read-only page"
    n6: "Each epoll tick | 1 peek + ~50 cancel+insert | ~100 comparisons total"
  }
}
row_structs -> row_heap_array: "instantiated as"
row_heap_array -> row_ops: "operations on"
row_ops -> row_complexity: "complexity"