direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title_box: "reactor_t Struct Memory Layout (reactor.h)" {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a8a"
    stroke-width: 2
    font-color: "#e0e0ff"
    bold: true
    font-size: 18
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  reactor_struct: {
    shape: sql_table
    label: "struct reactor_t (reactor.h) — 112+ bytes"
    style: {
      fill: "#0d1117"
      font-color: "#c9d1d9"
      stroke: "#30363d"
    }
    f00: "0x00 | int          | epoll_fd        // epoll instance"
    f04: "0x04 | int          | running         // loop control flag"
    f08: "0x08 | int          | dispatching     // re-entrancy guard"
    f0c: "0x0C | int          | _pad0"
    cl0: "---- CACHE LINE 0 BOUNDARY (0x00–0x3F, 64 bytes) ----"
    f10: "0x10 | fd_handler_t*| handlers        // ptr → heap array[max_fds]"
    f18: "0x18 | int          | max_fds"
    f1c: "0x1C | int          | _pad1"
    f20: "0x20 | timer_entry_t*| timer_pool     // ptr → heap timer slots"
    f28: "0x28 | int*         | timer_heap      // ptr → heap index array"
    f30: "0x30 | int          | timer_pool_size"
    f34: "0x34 | int          | timer_heap_size"
    f38: "0x38 | int          | next_timer_id   // monotonic timer ID"
    f3c: "0x3C | int          | _pad2"
    cl1: "---- CACHE LINE 1 BOUNDARY (0x40–0x7F, 64 bytes) ----"
    f40: "0x40 | int          | deferred_head   // ring buf read idx"
    f44: "0x44 | int          | deferred_tail   // ring buf write idx"
    f48: "0x48 | int          | pending_count   // deferred epoll ops count"
    f4c: "0x4C | int          | _pad3"
    f50: "0x50 | deferred_task_t| deferred[1024] // 1024×16 = 16384 bytes"
    fc0: "0x4050 | pending_mod_t| pending_ops[256] // 256×12 = 3072 bytes"
    sz:  "Total: ~19.5 KB (deferred + pending arrays dominate)"
  }
  cache_legend: {
    direction: down
    style: {
      fill: "#0d1117"
      stroke: "#30363d"
    }
    hot_label: "ACCESS FREQUENCY" {
      shape: rectangle
      style: {
        fill: "#0d1117"
        stroke: transparent
        font-color: "#8b949e"
        bold: true
        font-size: 13
      }
    }
    hot: "HOT PATH (every tick)" {
      shape: rectangle
      style: {
        fill: "#3d1a1a"
        stroke: "#e05252"
        stroke-width: 2
        font-color: "#ff8888"
        bold: true
      }
    }
    warm: "WARM (per connection)" {
      shape: rectangle
      style: {
        fill: "#1a2e1a"
        stroke: "#52e052"
        stroke-width: 2
        font-color: "#88ff88"
        bold: true
      }
    }
    cold: "COLD (rare / setup)" {
      shape: rectangle
      style: {
        fill: "#1a1a2e"
        stroke: "#5252b0"
        stroke-width: 2
        font-color: "#8888ff"
        bold: true
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cl0_detail: "CACHE LINE 0  [0x00–0x3F]  64 bytes" {
    direction: down
    style: {
      fill: "#3d1a1a"
      stroke: "#e05252"
      stroke-width: 2
    }
    epoll_fd_note: {
      shape: sql_table
      label: "HOT FIELDS — touched every epoll_wait() tick"
      style: { fill: "#5c1f1f"; font-color: "#ffaaaa"; stroke: "#e05252" }
      r1: "0x00 | int (4B)  | epoll_fd        // syscall arg every tick"
      r2: "0x04 | int (4B)  | running         // while(r->running) check"
      r3: "0x08 | int (4B)  | dispatching     // set=1 before loop, 0 after"
      r4: "0x0C | int (4B)  | _pad0           // alignment"
      note: "All 4 fields fit in 16 bytes → same cache line as each other"
    }
  }
  cl1_detail: "CACHE LINE 1  [0x10–0x3F continued]  warm fields" {
    direction: down
    style: {
      fill: "#1a2e1a"
      stroke: "#52e052"
      stroke-width: 2
    }
    ptrs: {
      shape: sql_table
      label: "WARM FIELDS — per-event pointer loads"
      style: { fill: "#1f3d1f"; font-color: "#aaffaa"; stroke: "#52e052" }
      r1: "0x10 | ptr (8B)  | handlers        // load on every fd dispatch"
      r2: "0x18 | int (4B)  | max_fds         // bounds check on accept"
      r3: "0x1C | int (4B)  | _pad1"
      r4: "0x20 | ptr (8B)  | timer_pool      // load during timer expiry"
      r5: "0x28 | ptr (8B)  | timer_heap      // load during sift ops"
      r6: "0x30 | int (4B)  | timer_pool_size // bounds check on insert"
      r7: "0x34 | int (4B)  | timer_heap_size // heap loop condition"
      r8: "0x38 | int (4B)  | next_timer_id   // increment on timer create"
      r9: "0x3C | int (4B)  | _pad2"
      note: "Spans cache lines 0–1; timer ptrs warm only during timer phase"
    }
  }
  cl2_detail: "CACHE LINE 2+  [0x40–…]  cold / bulk fields" {
    direction: down
    style: {
      fill: "#1a1a2e"
      stroke: "#5252b0"
      stroke-width: 2
    }
    bulk: {
      shape: sql_table
      label: "COLD / BULK FIELDS — deferred queues"
      style: { fill: "#1f1f3d"; font-color: "#aaaaff"; stroke: "#5252b0" }
      r1: "0x40 | int (4B)  | deferred_head   // ring drain pointer"
      r2: "0x44 | int (4B)  | deferred_tail   // ring fill pointer"
      r3: "0x48 | int (4B)  | pending_count   // pending epoll ops count"
      r4: "0x4C | int (4B)  | _pad3"
      r5: "0x50 | 16384B    | deferred[1024]  // {cb*, udata*} × 1024"
      r6: "0x4050 | 3072B   | pending_ops[256]// {op,fd,events} × 256"
      note: "deferred[] and pending_ops[] are cold until Phase 2/3 of tick"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fd_handler_struct: {
    shape: sql_table
    label: "fd_handler_t (per-fd entry, handlers[fd])"
    style: {
      fill: "#0d1117"
      font-color: "#c9d1d9"
      stroke: "#1f6feb"
    }
    r0: "0x00 | int           | registered    // 0=free, 1=active"
    r1: "0x04 | int           | closing       // mark-and-skip flag"
    r2: "0x08 | int           | fd"
    r3: "0x0C | uint32_t      | events        // EPOLLIN|EPOLLOUT|EPOLLET"
    r4: "0x10 | reactor_io_cb | callback      // fn ptr: void(*)(int,u32,void*)"
    r5: "0x18 | void*         | udata         // conn_t*, http_conn_t*, etc."
    sz: "Total: 32 bytes = 0.5 cache lines — 2 handlers per cache line"
  }
  timer_entry_struct: {
    shape: sql_table
    label: "timer_entry_t (timer_pool[slot])"
    style: {
      fill: "#0d1117"
      font-color: "#c9d1d9"
      stroke: "#f0883e"
    }
    r0: "0x00 | int              | active       // 0=free slot"
    r1: "0x04 | int              | timer_id     // opaque ID returned to caller"
    r2: "0x08 | int              | heap_idx     // position in timer_heap[]"
    r3: "0x0C | int              | _pad"
    r4: "0x10 | uint64_t         | expiry_ms    // CLOCK_MONOTONIC absolute"
    r5: "0x18 | uint32_t         | interval_ms  // 0=one-shot, >0=repeating"
    r6: "0x1C | uint32_t         | _pad2"
    r7: "0x20 | reactor_timer_cb | callback     // fn ptr"
    r8: "0x28 | void*            | udata"
    sz: "Total: 48 bytes = 0.75 cache lines"
  }
  pending_mod_struct: {
    shape: sql_table
    label: "pending_mod_t (pending_ops[i])"
    style: {
      fill: "#0d1117"
      font-color: "#c9d1d9"
      stroke: "#8b949e"
    }
    r0: "0x00 | pending_op_t | op      // PENDING_ADD | MOD | DEL"
    r1: "0x04 | int          | fd"
    r2: "0x08 | uint32_t     | events  // epoll flags for ADD/MOD"
    r3: "0x0C | int          | _pad"
    sz: "Total: 16 bytes = 0.25 cache lines; 256 entries = 4KB"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tick_phases: "reactor_run() — 4-Phase Tick" {
    direction: down
    style: {
      fill: "#161b22"
      stroke: "#30363d"
      stroke-width: 2
    }
    p1: "Phase 1: I/O Dispatch  (dispatching=1)" {
      shape: rectangle
      style: { fill: "#3d1a1a"; stroke: "#e05252"; font-color: "#ffaaaa"; bold: true }
    }
    p2: "Phase 2: Apply pending_ops[]  (epoll_ctl calls)" {
      shape: rectangle
      style: { fill: "#2e1a3d"; stroke: "#a05252"; font-color: "#ffaaee" }
    }
    p3: "Phase 3: Drain deferred[]  (nextTick semantics)" {
      shape: rectangle
      style: { fill: "#1a2e3d"; stroke: "#5280a0"; font-color: "#aaeeff" }
    }
    p4: "Phase 4: Expire timers  (heap root check loop)" {
      shape: rectangle
      style: { fill: "#1a3d1a"; stroke: "#52a052"; font-color: "#aaffaa" }
    }
    p1 -> p2: "dispatching=0"
    p2 -> p3: "pending_count=0"
    p3 -> p4: "drain_until snapshot"
    p4 -> p1: "next epoll_wait()"
  }
  hot_path_access: "Hot-Path Field Access Pattern" {
    direction: down
    style: {
      fill: "#161b22"
      stroke: "#30363d"
    }
    ha: {
      shape: sql_table
      label: "Fields accessed per epoll_wait() tick"
      style: { fill: "#0d1117"; font-color: "#8b949e"; stroke: "#30363d" }
      r1: "epoll_fd        | Phase 1 | syscall arg — must be in reg/L1"
      r2: "running         | Phase 1 | while() check — branch predictor"
      r3: "dispatching     | Ph 1–2  | set/clear — write → L1 invalidate"
      r4: "handlers[fd]    | Phase 1 | pointer chase — L3 miss risk"
      r5: "timer_heap[0]   | Phase 4 | root of min-heap — always L1 hot"
      r6: "timer_pool[idx] | Phase 4 | expiry_ms compare"
      r7: "deferred[]      | Phase 3 | cold unless callbacks deferred"
      r8: "pending_ops[]   | Phase 2 | cold unless callbacks modified epoll"
    }
  }
}
title_box -> row1: ""
row1 -> row2: ""
row2 -> row3: ""
row3 -> row4: ""
row2.cl0_detail -> row3.fd_handler_struct: "handlers[fd] →" {
  style: {
    stroke: "#52e052"
    stroke-dash: 4
    font-color: "#52e052"
  }
}
row2.cl1_detail -> row3.timer_entry_struct: "timer_pool[slot] →" {
  style: {
    stroke: "#f0883e"
    stroke-dash: 4
    font-color: "#f0883e"
  }
}
row2.cl2_detail -> row3.pending_mod_struct: "pending_ops[i] →" {
  style: {
    stroke: "#8b949e"
    stroke-dash: 4
    font-color: "#8b949e"
  }
}