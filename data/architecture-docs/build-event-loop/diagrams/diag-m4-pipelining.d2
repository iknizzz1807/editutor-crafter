direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## HTTP/1.1 Pipelining: Multiple In-Flight Requests
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  client_col: "CLIENT" {
    direction: down
    style.fill: "#e8f4f8"
    style.stroke: "#5b9bd5"
    style.bold: true
    req1_send: "Send Request 1" {
      shape: step
      style.fill: "#c6e0f5"
      style.stroke: "#2e75b6"
      width: 220
    }
    req2_send: "Send Request 2 (no wait)" {
      shape: step
      style.fill: "#c6e0f5"
      style.stroke: "#2e75b6"
      width: 220
    }
    wait_resp: "Waiting for Response 1" {
      shape: step
      style.fill: "#fff2cc"
      style.stroke: "#d6ae00"
      width: 220
    }
    recv_resp1: "Receive Response 1" {
      shape: step
      style.fill: "#e2efda"
      style.stroke: "#538135"
      width: 220
    }
    recv_resp2: "Receive Response 2" {
      shape: step
      style.fill: "#e2efda"
      style.stroke: "#538135"
      width: 220
    }
  }
  wire_col: "TCP STREAM (kernel recv buffer)" {
    direction: down
    style.fill: "#f3e8ff"
    style.stroke: "#7030a0"
    style.bold: true
    wire_both: "GET /a HTTP/1.1\\r\\n...\\r\\n\\r\\nGET /b HTTP/1.1\\r\\n...\\r\\n\\r\\n" {
      shape: queue
      style.fill: "#e1d5f5"
      style.stroke: "#7030a0"
      width: 320
    }
    wire_note: "Both requests arrive as one byte stream — no delimiter between them" {
      shape: rectangle
      style.fill: "#f3e8ff"
      style.stroke: "#7030a0"
      style.italic: true
      style.font-size: 12
      width: 320
    }
    wire_resp_q: "Response Queue (ordered FIFO): [Resp1, Resp2]" {
      shape: queue
      style.fill: "#ffd966"
      style.stroke: "#d6ae00"
      width: 320
    }
    wire_ordering: "MUST send Resp1 before Resp2 — TCP has no framing" {
      shape: rectangle
      style.fill: "#ffe699"
      style.stroke: "#bf8f00"
      style.bold: true
      style.font-size: 12
      width: 320
    }
  }
  server_col: "SERVER (http_conn_t state machine)" {
    direction: down
    style.fill: "#fff4e6"
    style.stroke: "#c55a11"
    style.bold: true
    s_readbuf: "read_buf accumulates both requests" {
      shape: sql_table
      label: "read_buf (16KB)"
      f0: "0x0000 | char[] | GET /a HTTP/1.1\\r\\n..."
      f1: "0x00XX | char[] | \\r\\n\\r\\n (end of req 1)"
      f2: "0x00YY | char[] | GET /b HTTP/1.1\\r\\n..."
      f3: "0x00ZZ | char[] | \\r\\n\\r\\n (end of req 2)"
      f4: "read_len | size_t | total bytes in buffer"
    }
    s_parse1: "http_try_parse() → PARSE_COMPLETE (req 1)" {
      shape: hexagon
      style.fill: "#c55a11"
      style.font-color: white
      style.bold: true
      width: 320
    }
    s_proc1: "HTTP_STATE_PROCESSING: generate Response 1" {
      shape: step
      style.fill: "#fce4d6"
      style.stroke: "#c55a11"
      width: 320
    }
    s_write1: "HTTP_STATE_WRITING_RESPONSE: flush Resp1 write_buf" {
      shape: step
      style.fill: "#fce4d6"
      style.stroke: "#c55a11"
      width: 320
    }
    s_keepalive: "HTTP_STATE_KEEP_ALIVE: read_len > 0 → reactor_defer()" {
      shape: step
      style.fill: "#fff2cc"
      style.stroke: "#d6ae00"
      width: 320
    }
    s_parse2: "http_try_parse() → PARSE_COMPLETE (req 2)" {
      shape: hexagon
      style.fill: "#c55a11"
      style.font-color: white
      style.bold: true
      width: 320
    }
    s_proc2: "HTTP_STATE_PROCESSING: generate Response 2" {
      shape: step
      style.fill: "#fce4d6"
      style.stroke: "#c55a11"
      width: 320
    }
    s_write2: "HTTP_STATE_WRITING_RESPONSE: flush Resp2 write_buf" {
      shape: step
      style.fill: "#fce4d6"
      style.stroke: "#c55a11"
      width: 320
    }
  }
}
why_h2: "Why HTTP/2 Was Invented" {
  shape: rectangle
  style.fill: "#ffd7d7"
  style.stroke: "#c00000"
  style.bold: true
  hol: "HTTP/1.1 Head-of-Line Blocking: Resp2 must wait for Resp1 even if Resp2 is ready first"
  fix: "HTTP/2 multiplexing: each request gets a stream ID; responses can arrive out-of-order"
  impl: "Simple implementation: response_queue[] per conn; dequeue only when front is sent"
}
why_h2.near: bottom-center
row0.client_col.req1_send -> row0.wire_col.wire_both: "GET /a\\r\\n\\r\\n | write"
row0.client_col.req2_send -> row0.wire_col.wire_both: "GET /b\\r\\n\\r\\n | write"
row0.wire_col.wire_both -> row0.server_col.s_readbuf: "REACTOR_READ | drain ET"
row0.server_col.s_readbuf -> row0.server_col.s_parse1: "http_try_parse()"
row0.server_col.s_parse1 -> row0.server_col.s_proc1: "PARSE_COMPLETE req1"
row0.server_col.s_proc1 -> row0.server_col.s_write1: "write_buf append"
row0.server_col.s_write1 -> row0.wire_col.wire_resp_q: "Resp1 | enqueue"
row0.server_col.s_write1 -> row0.server_col.s_keepalive: "buf drained"
row0.server_col.s_keepalive -> row0.server_col.s_parse2: "reactor_defer → Phase 3"
row0.server_col.s_parse2 -> row0.server_col.s_proc2: "PARSE_COMPLETE req2"
row0.server_col.s_proc2 -> row0.server_col.s_write2: "write_buf append"
row0.server_col.s_write2 -> row0.wire_col.wire_resp_q: "Resp2 | enqueue"
row0.wire_col.wire_resp_q -> row0.wire_col.wire_ordering: "ordering enforced"
row0.wire_col.wire_resp_q -> row0.client_col.recv_resp1: "Resp1 | send first" {
  style.stroke: "#538135"
  style.bold: true
}
row0.wire_col.wire_resp_q -> row0.client_col.recv_resp2: "Resp2 | send second" {
  style.stroke: "#538135"
  style.bold: true
  style.stroke-dash: 4
}
row0.client_col.req1_send -> row0.client_col.req2_send: "immediate"
row0.client_col.req2_send -> row0.client_col.wait_resp: "waiting"
row0.client_col.wait_resp -> row0.client_col.recv_resp1: "arrives"
row0.client_col.recv_resp1 -> row0.client_col.recv_resp2: "in order"