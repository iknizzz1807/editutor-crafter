direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Resource Cleanup: All Connection Close Paths (http_conn.c)
| {near: top-center}
# ─── EXIT PATHS ───────────────────────────────────────────────────────────────
paths_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  path_a: "Path A" {
    direction: down
    style.fill: "#fff3cd"
    style.stroke: "#f0ad4e"
    style.border-radius: 8
    label: "Path A — Idle Timeout"
    t1: {
      shape: rectangle
      label: "timer_expire_all()"
      style.fill: "#f9d8a7"
      style.stroke: "#f0ad4e"
    }
    t2: {
      shape: rectangle
      label: "idle_timeout_cb(timer_id, conn)"
      style.fill: "#f9d8a7"
      style.stroke: "#f0ad4e"
    }
    t1 -> t2: "Phase 4"
  }
  path_b: "Path B" {
    direction: down
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 8
    label: "Path B — EOF"
    b1: {
      shape: rectangle
      label: "EPOLLIN fires"
      style.fill: "#b8dfc4"
      style.stroke: "#28a745"
    }
    b2: {
      shape: diamond
      label: "read() == 0"
      style.fill: "#b8dfc4"
      style.stroke: "#28a745"
    }
    b1 -> b2: "ET drain loop"
  }
  path_c: "Path C" {
    direction: down
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 8
    label: "Path C — read() Error"
    c1: {
      shape: rectangle
      label: "EPOLLIN fires"
      style.fill: "#f5b7bb"
      style.stroke: "#dc3545"
    }
    c2: {
      shape: diamond
      label: "read() == -1"
      style.fill: "#f5b7bb"
      style.stroke: "#dc3545"
    }
    c3: {
      shape: diamond
      label: "errno != EAGAIN"
      style.fill: "#f5b7bb"
      style.stroke: "#dc3545"
    }
    c1 -> c2: "ET drain loop"
    c2 -> c3: "error"
  }
  path_d: "Path D" {
    direction: down
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 8
    label: "Path D — Write Overflow"
    d1: {
      shape: rectangle
      label: "conn_write()"
      style.fill: "#f5b7bb"
      style.stroke: "#dc3545"
    }
    d2: {
      shape: diamond
      label: "write_buf > MAX"
      style.fill: "#f5b7bb"
      style.stroke: "#dc3545"
    }
    d1 -> d2: "append fails"
  }
  path_e: "Path E" {
    direction: down
    style.fill: "#d1ecf1"
    style.stroke: "#17a2b8"
    style.border-radius: 8
    label: "Path E — HTTP Close"
    e1: {
      shape: rectangle
      label: "http_handle_write()"
      style.fill: "#a8d8e0"
      style.stroke: "#17a2b8"
    }
    e2: {
      shape: diamond
      label: "write_buf drained"
      style.fill: "#a8d8e0"
      style.stroke: "#17a2b8"
    }
    e3: {
      shape: diamond
      label: "keep_alive == 0"
      style.fill: "#a8d8e0"
      style.stroke: "#17a2b8"
    }
    e1 -> e2: "flush complete"
    e2 -> e3: "check header"
  }
  path_f: "Path F" {
    direction: down
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 8
    label: "Path F — epoll Error"
    f1: {
      shape: rectangle
      label: "epoll_wait() returns"
      style.fill: "#f5b7bb"
      style.stroke: "#dc3545"
    }
    f2: {
      shape: diamond
      label: "EPOLLERR | EPOLLHUP"
      style.fill: "#f5b7bb"
      style.stroke: "#dc3545"
    }
    f1 -> f2: "ev & error mask"
  }
}
# ─── CONVERGENCE POINT ────────────────────────────────────────────────────────
converge: "conn_close(conn)" {
  shape: rectangle
  label: "conn_close(conn)  — ALL PATHS ENTER HERE"
  style.fill: "#6c757d"
  style.font-color: white
  style.stroke: "#343a40"
  style.stroke-width: 3
  style.bold: true
  style.border-radius: 6
}
# ─── CLEANUP SEQUENCE ─────────────────────────────────────────────────────────
cleanup_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: "Step 1" {
    shape: rectangle
    label: "① timer_cancel(conn->timer_id)"
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 6
    note: "heap remove O(log n)"
  }
  step2: "Step 2" {
    shape: rectangle
    label: "② epoll_ctl(epfd, DEL, fd, NULL)"
    style.fill: "#fff3cd"
    style.stroke: "#f0ad4e"
    style.border-radius: 6
    note: "MUST precede close(fd)"
  }
  step3: "Step 3" {
    shape: rectangle
    label: "③ free(conn->write_buf)"
    style.fill: "#d1ecf1"
    style.stroke: "#17a2b8"
    style.border-radius: 6
    note: "64KB heap alloc"
  }
  step1 -> step2: "then"
  step2 -> step3: "then"
}
cleanup_row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step4: "Step 4" {
    shape: rectangle
    label: "④ conn_table[fd] = {state=FREE}"
    style.fill: "#d1ecf1"
    style.stroke: "#17a2b8"
    style.border-radius: 6
    note: "slot freed before close"
  }
  step5: "Step 5" {
    shape: rectangle
    label: "⑤ close(fd)"
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 6
    style.bold: true
    note: "OS recycles fd number"
  }
  step4 -> step5: "then"
}
# ─── RACE CONDITION WARNING ───────────────────────────────────────────────────
race_warn: "fd-reuse-race" {
  shape: callout
  label: "⚠ fd Reuse Race: close(fd) before epoll DEL → new accept() reuses fd number → stale epoll entry watches WRONG connection. Always DEL before close."
  style.fill: "#f8d7da"
  style.stroke: "#dc3545"
  style.font-color: "#721c24"
  style.bold: true
  width: 520
}
# ─── DOUBLE-CLOSE GUARD ───────────────────────────────────────────────────────
guard: "double-close-guard" {
  shape: rectangle
  label: "Guard: if (conn->state == CLOSING) return;  // already being closed"
  style.fill: "#e2e3e5"
  style.stroke: "#6c757d"
  style.font: mono
  style.border-radius: 4
  width: 480
}
# ─── CONNECTIONS ──────────────────────────────────────────────────────────────
paths_row.path_a.t2 -> converge: "timeout" {
  style.stroke: "#f0ad4e"
  style.stroke-width: 2
}
paths_row.path_b.b2 -> converge: "EOF" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
paths_row.path_c.c3 -> converge: "error" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
}
paths_row.path_d.d2 -> converge: "overflow" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
}
paths_row.path_e.e3 -> converge: "close hdr" {
  style.stroke: "#17a2b8"
  style.stroke-width: 2
}
paths_row.path_f.f2 -> converge: "error event" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
}
converge -> guard: "entry check"
guard -> cleanup_row.step1: "proceed"
cleanup_row.step3 -> cleanup_row2.step4: "then"
cleanup_row2.step5 -> race_warn: "why DEL first"