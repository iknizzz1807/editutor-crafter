vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

classes: {
  header_purple: {
    style: {
      fill: "#f5f0ff"
      stroke: "#7c3aed"
      stroke-width: 3
    }
  }
  data_blue: {
    style: {
      fill: "#3b82f6"
      stroke: "#1e3a8a"
      font-color: white
    }
  }
  active_green: {
    style: {
      fill: "#22c55e"
      stroke: "#14532d"
      font-color: white
    }
  }
  padding_gray: {
    style: {
      fill: "#9ca3af"
      stroke: "#4b5563"
      font-color: white
    }
  }
  pointer_orange: {
    style: {
      stroke: "#f97316"
      stroke-width: 2
      animated: true
    }
  }
}

title: ||md
  ### epoll Kernel Data Structures
  **Interest Set (RBT)** vs **Readiness Queue (Linked List)**
|| {
  near: top-center
}

# 1. Memory Layout Detail (struct epitem)
# sizeof = 64 bytes (One Cache Line)
epitem_memory_layout: {
  shape: sql_table
  class: header_purple
  tooltip: "Memory alignment: 64B Cache Line"
  
  "Offset" | "Field: struct epitem" | "Size"
  "0x00" | "rb_node (Interest Set Link)" | "24B"
  "0x18" | "rdllink (Readiness Queue Link)" | "16B"
  "0x28" | "epoll_event (event.data, event.events)" | "12B"
  "0x34" | "fd (Target File Descriptor)" | "4B"
  "0x38" | "padding / next_epitem_start" | "8B"

  *.style.font-size: 12
}
epitem_memory_layout.style.stroke-dash: 5

# 2. Interest Set (Red-Black Tree)
interest_set: "Interest Set (eventpoll.rbr)" {
  class: header_purple
  
  rbt_root: "ROOT: fd=7" {
    class: data_blue
  }
  
  node_active: "NODE: fd=4\n(Active Target)" {
    class: data_blue
    style.bold: true
    style.double-border: true
  }
  
  node_idle: "NODE: fd=12" {
    class: data_blue
  }

  rbt_root -> node_active: "left"
  rbt_root -> node_idle: "right"
  
  label_rbt: "O(log N) Lookup" {
    shape: text
    style.italic: true
  }
}

# 3. Readiness Queue (Doubly Linked List)
readiness_queue: "Readiness Queue (eventpoll.rdllist)" {
  class: active_green
  style.fill: "#f0fdf4"

  head: "LIST_HEAD" {
    shape: circle
    class: active_green
  }

  ready_entry: "epitem [fd=4]\nStatus: EPOLLIN" {
    class: active_green
    style.bold: true
  }

  null_ptr: "NULL" {
    shape: parallelogram
    class: padding_gray
  }

  head -> ready_entry: "next"
  ready_entry -> null_ptr: "next"
  
  label_rq: "O(K) Ready fds" {
    shape: text
    style.italic: true
  }
}

# 4. Architecture Interaction & Sequence
# Triggered by Hardware Interrupt
nic_interrupt: "NIC Hardware Interrupt\nPacket Data for fd=4" {
  shape: hexagon
  style: {
    fill: "#fff7ed"
    stroke: "#f97316"
    stroke-width: 3
  }
}

callback_logic: "epoll_callback()" {
  shape: step
  style.fill: "#fef3c7"
}

epoll_wait_call: "epoll_wait(..., events, ...)\nReturn nready=1" {
  shape: rectangle
  style.fill: "#fef3c7"
  style.stroke: "#f97316"
  style.bold: true
}

# Sequence Connections
nic_interrupt -> interest_set.node_active: "1. Search RBT" {
  class: pointer_orange
}

interest_set.node_active -> callback_logic: "2. Trigger"

callback_logic -> readiness_queue.ready_entry: "3. Insert into list" {
  class: pointer_orange
}

readiness_queue.ready_entry -> epoll_wait_call: "4. Copy to user array" {
  style.stroke: "#22c55e"
  style.stroke-width: 3
}

# Explanatory Table
complexity_summary: ||md
| epoll Operation | Primary Data Structure | Time Complexity |
| :--- | :--- | :--- |
| `CTL_ADD/MOD/DEL` | Red-Black Tree (RBT) | **O(log n)** |
| `WAIT` | Linked List (Ready) | **O(k ready)** |
|| {
  near: bottom-center
}

# Layout constraints
interest_set.near: left_pane
readiness_queue.near: right_pane
epitem_memory_layout.near: center-left

legend: {
  near: top-right
  h: "Header (Purple)" { class: header_purple }
  d: "Data/Node (Blue)" { class: data_blue }
  a: "Active/Ready (Green)" { class: active_green }
  p: "Padding/Idle (Gray)" { class: padding_gray }
  l: "Pointer/Trigger (Orange)" { 
    shape: line
    style.stroke: "#f97316"
  }
}