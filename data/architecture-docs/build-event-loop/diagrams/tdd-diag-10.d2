vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## `write_buf_t` Struct Memory Layout and Offset Mechanics
| {near: top-center}
# ─── STRUCT LAYOUT ───────────────────────────────────────────────────────────
struct_layout: "`write_buf_t` — 32 bytes (½ cache line)" {
  style: {
    fill: "#1a1a2e"
    stroke: "#7c3aed"
    stroke-width: 2
    border-radius: 4
    font-color: white
    bold: true
  }
  header_row: "Byte Offset  │  Field         │  Size  │  Notes" {
    shape: text
    style: {
      font-color: "#a78bfa"
      font: mono
      bold: true
      font-size: 13
    }
  }
  row0: "0x00 (+0)    │  data          │  8 B   │  ptr → heap-allocated byte array" {
    shape: text
    style: { font: mono; font-color: "#fb923c"; font-size: 13 }
  }
  row8: "0x08 (+8)    │  capacity      │  8 B   │  fixed after new() = 65536" {
    shape: text
    style: { font: mono; font-color: "#60a5fa"; font-size: 13 }
  }
  row16: "0x10 (+16)   │  write_offset  │  8 B   │  first unsent byte (consume ptr)" {
    shape: text
    style: { font: mono; font-color: "#34d399"; font-size: 13 }
  }
  row24: "0x18 (+24)   │  write_len     │  8 B   │  fill high-water mark" {
    shape: text
    style: { font: mono; font-color: "#f472b6"; font-size: 13 }
  }
  row32: "0x20 (+32)   │  [END]         │  —     │  total = 32 B, 8-byte aligned" {
    shape: text
    style: { font: mono; font-color: "#94a3b8"; font-size: 13 }
  }
  formula: |md
    `pending = write_len − write_offset`
  | {
    style: {
      font-size: 13
      font-color: "#fbbf24"
    }
  }
}
# ─── CACHE LINE ANNOTATION ────────────────────────────────────────────────────
cache_line_note: "64-byte cache line boundary" {
  shape: text
  style: {
    font-color: "#64748b"
    font-size: 11
    italic: true
  }
  near: top-right
}
# ─── STATE DIAGRAMS ──────────────────────────────────────────────────────────
states_container: "data[] Heap Buffer — State Progression (capacity = 65536 B)" {
  style: {
    fill: "#0f172a"
    stroke: "#334155"
    stroke-width: 2
    border-radius: 4
  }
  # ── STATE A ──────────────────────────────────────────────────────────────
  stateA: "State A: Initial (after write_buf_new)" {
    style: {
      fill: "#1e293b"
      stroke: "#4ade80"
      stroke-width: 2
      border-radius: 3
      font-color: "#4ade80"
      bold: true
    }
    a_bar: |md
      
      data[]:
      ┌────────────────────────────────────────────────────┐ capacity=65536
      │                  FREE (65536 B)                    │
      └────────────────────────────────────────────────────┘
       ↑ offset=0
       ↑ len=0
      
    | {
      style: { font: mono; font-size: 12; font-color: "#e2e8f0" }
    }
    a_vals: "write_offset = 0   │   write_len = 0   │   pending = 0" {
      shape: text
      style: { font: mono; font-size: 12; font-color: "#94a3b8" }
    }
  }
  # ── STATE B ──────────────────────────────────────────────────────────────
  stateB: "State B: After append(3000 B)" {
    style: {
      fill: "#1e293b"
      stroke: "#60a5fa"
      stroke-width: 2
      border-radius: 3
      font-color: "#60a5fa"
      bold: true
    }
    b_bar: |md
      
      data[]:
      ┌──────────────┬─────────────────────────────────────┐
      │ VALID 3000 B │           FREE (62536 B)            │
      └──────────────┴─────────────────────────────────────┘
       ↑ offset=0     ↑ len=3000
      
    | {
      style: { font: mono; font-size: 12; font-color: "#e2e8f0" }
    }
    b_vals: "write_offset = 0   │   write_len = 3000   │   pending = 3000" {
      shape: text
      style: { font: mono; font-size: 12; font-color: "#94a3b8" }
    }
  }
  # ── STATE C ──────────────────────────────────────────────────────────────
  stateC: "State C: After partial write(2000 B) → offset advances" {
    style: {
      fill: "#1e293b"
      stroke: "#fb923c"
      stroke-width: 2
      border-radius: 3
      font-color: "#fb923c"
      bold: true
    }
    c_bar: |md
      
      data[]:
      ┌──────────────┬─────────┬────────────────────────────┐
      │  SENT 2000 B │PEND 1kB │     FREE (62536 B)         │
      └──────────────┴─────────┴────────────────────────────┘
       ↑ base          ↑ offset=2000   ↑ len=3000
      
    | {
      style: { font: mono; font-size: 12; font-color: "#e2e8f0" }
    }
    c_vals: "write_offset = 2000   │   write_len = 3000   │   pending = 1000" {
      shape: text
      style: { font: mono; font-size: 12; font-color: "#94a3b8" }
    }
    c_trigger: "Compact trigger: offset (2000) > capacity/2 (32768)? NO — compaction not yet triggered" {
      shape: text
      style: { font-size: 11; font-color: "#fbbf24"; italic: true }
    }
  }
  # ── STATE D ──────────────────────────────────────────────────────────────
  stateD: "State D: After compaction (offset > capacity/2 threshold)" {
    style: {
      fill: "#1e293b"
      stroke: "#f472b6"
      stroke-width: 2
      border-radius: 3
      font-color: "#f472b6"
      bold: true
    }
    d_bar: |md
      
      data[]:  ← memmove(data, data+offset, pending)
      ┌─────────┬──────────────────────────────────────────┐
      │PEND 1kB │          FREE (64536 B)                  │
      └─────────┴──────────────────────────────────────────┘
       ↑ offset=0   ↑ len=1000
      
    | {
      style: { font: mono; font-size: 12; font-color: "#e2e8f0" }
    }
    d_vals: "write_offset = 0   │   write_len = 1000   │   pending = 1000" {
      shape: text
      style: { font: mono; font-size: 12; font-color: "#94a3b8" }
    }
    d_cost: "compaction cost = O(pending bytes)   │   amortized O(1) per byte appended" {
      shape: text
      style: { font: mono; font-size: 12; font-color: "#a78bfa"; bold: true }
    }
  }
  # ── INVARIANTS ────────────────────────────────────────────────────────────
  invariants: |md
    **Invariants always held:**
    - `0 ≤ write_offset ≤ write_len ≤ capacity`
    - When `write_offset == write_len`: both reset to 0 (buffer logically empty)
    - `data` pointer is never NULL after successful `write_buf_new()`
  | {
    style: {
      fill: "#1e293b"
      stroke: "#475569"
      stroke-width: 1
      border-radius: 3
      font-size: 12
      font-color: "#94a3b8"
    }
  }
}
# ─── SLOW-LORIS DEFENSE ───────────────────────────────────────────────────────
slowloris: "Slow-Loris Defense" {
  shape: rectangle
  style: {
    fill: "#2d1515"
    stroke: "#ef4444"
    stroke-width: 2
    border-radius: 3
    font-color: "#ef4444"
    bold: true
  }
  label: "WRITE_BUF_MAX = 131072 (128KB)\npending + len > WRITE_BUF_MAX → return -1 → conn_close()\nPrevents unbounded write buffer growth from slow readers"
}
# ─── CONNECTIONS ─────────────────────────────────────────────────────────────
struct_layout -> states_container: "data ptr references heap buffer" {
  style: { stroke: "#fb923c"; stroke-dash: 4; font-color: "#fb923c"; font-size: 11 }
  target-arrowhead: { shape: arrow }
}
states_container.stateA -> states_container.stateB: "write_buf_append(src, 3000)" {
  style: { stroke: "#4ade80"; font-color: "#4ade80"; font-size: 11 }
  target-arrowhead: { shape: arrow }
}
states_container.stateB -> states_container.stateC: "write_buf_consume(2000)\n[advance offset]" {
  style: { stroke: "#60a5fa"; font-color: "#60a5fa"; font-size: 11 }
  target-arrowhead: { shape: arrow }
}
states_container.stateC -> states_container.stateD: "write_buf_append(…)\nif offset > capacity/2:\n  memmove → compact" {
  style: { stroke: "#f472b6"; font-color: "#f472b6"; font-size: 11; bold: true }
  target-arrowhead: { shape: arrow }
}
states_container -> slowloris: "overflow guard" {
  style: { stroke: "#ef4444"; stroke-dash: 3; font-color: "#ef4444"; font-size: 11 }
  target-arrowhead: { shape: arrow }
}