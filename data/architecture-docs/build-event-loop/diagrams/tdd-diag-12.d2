layout-engine: elk
vars: {
  d2-config: {
    theme-id: 6
  }
}

title: {
  label: |'md
    ## EPOLLOUT Busy Loop Anti-Pattern vs Correct Lifecycle
  '|
  near: top-center
}

wrong: "WRONG — Busy Loop (100% CPU)" {
  style: {
    fill: "#2d0a0a"
    stroke: "#cc2200"
    stroke-width: 3
    border-radius: 8
  }
  
  label_wrong: {
    label: |'md
      ❌ **EPOLLOUT registered at connection creation**
      `ev.events = EPOLLIN | EPOLLOUT`  — NEVER do this
    '|
    style: {
      fill: "#3d1010"
      stroke: "#cc2200"
      border-radius: 4
    }
  }

  conn_create_w: {
    label: "accept4()\nepoll_ctl(ADD)\nevents = EPOLLIN|EPOLLOUT"
    style: {
      fill: "#8b0000"
      stroke: "#ff4444"
      font-color: white
      bold: true
    }
  }

  wait1: {
    label: "epoll_wait()\nreturns immediately\nfd ready (EPOLLOUT)"
    style: {
      fill: "#6b1a1a"
      stroke: "#ff6666"
      font-color: white
    }
  }

  flush1: {
    label: "flush_write_buf()\npending == 0\nnothing to write\nreturn"
    style: {
      fill: "#6b1a1a"
      stroke: "#ff6666"
      font-color: white
    }
  }

  wait2: {
    label: "epoll_wait()\nreturns immediately AGAIN\nEPOLLOUT still set"
    style: {
      fill: "#6b1a1a"
      stroke: "#ff6666"
      font-color: white
    }
  }

  flush2: {
    label: "flush_write_buf()\npending == 0\nreturn"
    style: {
      fill: "#6b1a1a"
      stroke: "#ff6666"
      font-color: white
    }
  }

  loop_annot: {
    label: "epoll_wait() → flush() → epoll_wait() → flush() ..."
    style: {
      fill: "#3d1010"
      stroke: "#ff2200"
      font-color: "#ff9999"
      italic: true
    }
  }

  perf_w: {
    label: |'md
      **perf stat output (pathological)**
      `instructions retired:  ████████████ MAX`
      `context-switches:      0`
      `dTLB-load-misses:      ~0 (working set fits cache)`
      `CPU utilization:       99.9% (one core pinned)`
      `epoll_wait calls/sec:  ~10,000,000`
      `useful work:           0 bytes/sec`
    '|
    style: {
      fill: "#1a0000"
      stroke: "#ff4444"
      border-radius: 4
      font: mono
      font-color: "#ff8888"
    }
  }

  conn_create_w -> wait1: "EPOLLOUT armed\nsend buf has space" {
    style: {
      stroke: "#ff4444"
      font-color: "#ff9999"
      bold: true
    }
  }
  
  wait1 -> flush1: "EPOLLIN|EPOLLOUT event" {
    style.stroke: "#ff6666"
  }
  
  flush1 -> wait2: "nothing flushed\nEPOLLOUT still registered" {
    style.stroke: "#ff6666"
  }
  
  wait2 -> flush2: "EPOLLOUT fires again\n(send buf still has space)" {
    style.stroke: "#ff6666"
  }
  
  flush2 -> loop_annot: "infinite loop\nno exit condition" {
    style: {
      stroke: "#ff2200"
      stroke-dash: 4
      bold: true
      font-color: "#ff6666"
    }
  }
  
  loop_annot -> wait2: "forever" {
    style: {
      stroke: "#ff2200"
      stroke-dash: 6
      animated: true
    }
  }
}

correct: "CORRECT — Minimal epoll_ctl Calls, Zero Busy Loop" {
  style: {
    fill: "#0a1f0a"
    stroke: "#22aa44"
    stroke-width: 3
    border-radius: 8
  }

  label_correct: {
    label: |'md
      ✅ **EPOLLOUT disarmed at creation — armed only when write buffer has data**
      `ev.events = EPOLLIN`  — EPOLLOUT added only on EAGAIN
    '|
    style: {
      fill: "#0d2b0d"
      stroke: "#22aa44"
      border-radius: 4
    }
  }

  conn_create_c: {
    label: "accept4()\nepoll_ctl(ADD)\nevents = EPOLLIN only\nepollout_armed = 0"
    style: {
      fill: "#1a4a1a"
      stroke: "#44cc66"
      font-color: white
      bold: true
    }
  }

  wait_block: {
    label: "epoll_wait(-1)\n[BLOCKS until data arrives]\nno spurious wakeups"
    style: {
      fill: "#1a3a1a"
      stroke: "#44cc66"
      font-color: white
    }
  }

  epollin_ev: {
    label: "EPOLLIN fires\nread() drains buffer\nbuild response"
    style: {
      fill: "#1a3a1a"
      stroke: "#44cc66"
      font-color: white
    }
  }

  try_write: {
    label: "write(fd, buf, len)\n→ returns EAGAIN\n(send buffer full)"
    style: {
      fill: "#2a3a1a"
      stroke: "#88cc44"
      font-color: white
    }
  }

  arm_epollout: {
    label: "epoll_ctl(MOD)\nevents = EPOLLIN|EPOLLOUT\nepollout_armed = 1\n[call #1 of 2]"
    style: {
      fill: "#223322"
      stroke: "#aadd44"
      font-color: "#ccff88"
      bold: true
      3d: true
    }
  }

  wait_again: {
    label: "epoll_wait(-1)\n[BLOCKS until send buf drains\nor new data arrives]"
    style: {
      fill: "#1a3a1a"
      stroke: "#44cc66"
      font-color: white
    }
  }

  epollout_fires: {
    label: "EPOLLOUT fires\n(kernel: send buf has space)"
    style: {
      fill: "#1a3a1a"
      stroke: "#44cc66"
      font-color: white
    }
  }

  flush_buf: {
    label: "flush_write_buf()\nwrite() succeeds\nwrite_buf_consume()\npending → 0"
    style: {
      fill: "#1a3a1a"
      stroke: "#44cc66"
      font-color: white
    }
  }

  disarm_epollout: {
    label: "epoll_ctl(MOD)\nevents = EPOLLIN only\nepollout_armed = 0\n[call #2 of 2]"
    style: {
      fill: "#223322"
      stroke: "#aadd44"
      font-color: "#ccff88"
      bold: true
      3d: true
    }
  }

  back_to_wait: {
    label: "return to epoll_wait()\nonly EPOLLIN registered\nno spurious wakeups"
    style: {
      fill: "#1a3a1a"
      stroke: "#44cc66"
      font-color: white
    }
  }

  write_ok: {
    label: "write() fully succeeds\n(no EAGAIN)\nEPOLLOUT stays disarmed\nepoll_ctl NOT called"
    style: {
      fill: "#0d250d"
      stroke: "#33bb55"
      font-color: "#88dd88"
      italic: true
    }
  }

  perf_c: {
    label: |'md
      **perf stat output (correct)**
      `instructions retired:  proportional to traffic`
      `epoll_ctl(MOD) calls:  exactly 2 per backpressure event`
      `epoll_wait calls/sec:  proportional to events`
      `CPU utilization:       <0.1% at 10K idle connections`
      `Bytes/sec:             network-limited (not CPU-limited)`
    '|
    style: {
      fill: "#051a05"
      stroke: "#44cc66"
      border-radius: 4
      font: mono
      font-color: "#88dd88"
    }
  }

  conn_create_c -> wait_block: "registered with\nEPOLLIN only" {
    style.stroke: "#44cc66"
  }
  
  wait_block -> epollin_ev: "client sends data" {
    style.stroke: "#44cc66"
  }
  
  epollin_ev -> try_write: "response ready\nattempt direct write" {
    style.stroke: "#44cc66"
  }
  
  epollin_ev -> write_ok: "fast path:\nwrite() succeeds immediately" {
    style: {
      stroke: "#33bb55"
      stroke-dash: 4
    }
  }
  
  write_ok -> back_to_wait: "0 epoll_ctl calls\nfor this request" {
    style: {
      stroke: "#33bb55"
      stroke-dash: 4
    }
  }
  
  try_write -> arm_epollout: "EAGAIN:\nsend buffer full" {
    style: {
      stroke: "#aadd44"
      bold: true
    }
  }
  
  arm_epollout -> wait_again: "epoll_ctl(MOD) #1\nadds EPOLLOUT" {
    style.stroke: "#aadd44"
  }
  
  wait_again -> epollout_fires: "kernel drains\nTCP send buffer" {
    style.stroke: "#44cc66"
  }
  
  epollout_fires -> flush_buf: "EPOLLOUT event\ndispatched" {
    style.stroke: "#44cc66"
  }
  
  flush_buf -> disarm_epollout: "buffer drained\nmust disarm NOW" {
    style: {
      stroke: "#aadd44"
      bold: true
    }
  }
  
  disarm_epollout -> back_to_wait: "epoll_ctl(MOD) #2\nremoves EPOLLOUT" {
    style.stroke: "#aadd44"
  }
  
  back_to_wait -> wait_block: "next request cycle" {
    style: {
      stroke: "#44cc66"
      stroke-dash: 3
    }
  }
}

invariant: {
  label: |'md
    **The EPOLLOUT Invariant (must hold at all times):**
    `epollout_armed == 1`  ↔  `write_buf_pending(conn->write_buf) > 0`  ↔  `EPOLLOUT ∈ epoll interest set`
    All three conditions are simultaneously true or simultaneously false. Any violation → busy loop or data loss.
    **Cost breakdown per backpressure event:** 2× `epoll_ctl(MOD)` syscalls (~400ns each) = ~800ns total overhead.
    **Cost of missing disarm:** `epoll_wait` returns at 10M/sec × 0 useful work = one full CPU core wasted permanently.
  '|
  near: bottom-center
  style: {
    fill: "#1a1a2e"
    stroke: "#8888ff"
    stroke-width: 2
    border-radius: 6
    font: mono
    font-color: "#ccccff"
  }
}

(wrong -> correct): "fix: never register EPOLLOUT\nat connection creation" {
  style: {
    stroke: "#aaaaaa"
    stroke-dash: 5
    font-color: "#aaaaaa"
  }
}