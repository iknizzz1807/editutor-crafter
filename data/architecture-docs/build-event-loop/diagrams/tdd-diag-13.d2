    style.stroke: "#818cf8"
    style.font-size: 11
  }

  formulas: |md
    **Navigation Formulas**
    parent(i)     = (i в€’ 1) / 2
    left_child(i) = 2i + 1
    right_child(i)= 2i + 2

    **Example: node at idx 2**
    - parent  = (2в€’1)/2 = 0  вњ“
    - left    = 2Г—2+1  = 5  вњ“
    - right   = 2Г—2+2  = 6  вњ“
  | {
    style.fill: "#e0e7ff"
    style.stroke: "#6b7db3"
    style.border-radius: 6
  }
}

