  node1 -> node4: "parent=(4-1)/2 = 1" {
    style.stroke: "#818cf8"
    style.font-size: 11
  }
  node2 -> node5: "parent=(5-1)/2 = 2" {
    style.stroke: "#818cf8"
    style.font-size: 11
