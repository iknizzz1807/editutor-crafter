direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "Heap Sift-Up After Insert: Step-by-Step State Transitions"
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

legend: {
  label: |md
    **Legend:** 🔴 Changed element (RED) | ✅ Heap invariant satisfied | 🔄 heap_swap updates BOTH heap_idx AND conn_t→timer_id
    **Cost:** log₂(10000) ≈ 13 comparisons max · Sift stops when parent.expiry ≤ child.expiry
  |
  near: bottom-center
}

# ─── FRAME 1: Before Insert ───────────────────────────────────────────────────
f1: {
  label: "Frame 1: Initial Heap (7 entries)"
  style: {
    fill: "#f0f4ff"
    stroke: "#4a6fa5"
    stroke-width: 2
    border-radius: 8
  }
  root: {
    label: "idx 0\nexpiry=1000ms\nfd=10\nheap_idx=0"
    style: { fill: "#b794f4"; stroke: "#6b46c1"; font-size: 13; bold: true }
  }
  n1: {
    label: "idx 1\nexpiry=1500ms\nfd=20\nheap_idx=1"
    style: { fill: "#90cdf4"; stroke: "#2b6cb0"; font-size: 13 }
  }
  n2: {
    label: "idx 2\nexpiry=1200ms\nfd=30\nheap_idx=2"
    style: { fill: "#90cdf4"; stroke: "#2b6cb0"; font-size: 13 }
  }
  n3: {
    label: "idx 3\nexpiry=2000ms\nfd=40\nheap_idx=3"
    style: { fill: "#90cdf4"; stroke: "#2b6cb0"; font-size: 13 }
  }
  n4: {
    label: "idx 4\nexpiry=3000ms\nfd=50\nheap_idx=4"
    style: { fill: "#90cdf4"; stroke: "#2b6cb0"; font-size: 13 }
  }
  n5: {
    label: "idx 5\nexpiry=1800ms\nfd=60\nheap_idx=5"
    style: { fill: "#90cdf4"; stroke: "#2b6cb0"; font-size: 13 }
  }
  n6: {
    label: "idx 6\nexpiry=2500ms\nfd=70\nheap_idx=6"
    style: { fill: "#90cdf4"; stroke: "#2b6cb0"; font-size: 13 }
  }
  
  root -> n1: "parent(1)=0"
  root -> n2: "parent(2)=0"
  n1 -> n3: "parent(3)=1"
  n1 -> n4: "parent(4)=1"
  n2 -> n5: "parent(5)=2"
  n2 -> n6: "parent(6)=2"

  state_info: {
    label: |md
      **State:** size=7 · root=1000ms ✅ heap invariant holds
      **Array:** [1000, 1500, 1200, 2000, 3000, 1800, 2500]
    |
    style: { fill: "#e9f5e9"; stroke: "#276749" }
  }
}

# ─── FRAME 2: Append New Entry ────────────────────────────────────────────────
f2: {
  label: "Frame 2: Append New Entry at idx 7 (900ms)"
  style: {
    fill: "#fff5f5"
    stroke: "#c53030"
    stroke-width: 2
    border-radius: 8
  }
  root: {
    label: "idx 0\nexpiry=1000ms\nfd=10"
    style: { fill: "#b794f4"; stroke: "#6b46c1"; font-size: 13; bold: true }
  }
  n1: "idx 1\nexpiry=1500ms"
  n2: "idx 2\nexpiry=1200ms"
  n3: "idx 3\nexpiry=2000ms"
  n4: "idx 4\nexpiry=3000ms"
  n5: "idx 5\nexpiry=1800ms"
  n6: "idx 6\nexpiry=2500ms"
  new_node: {
    label: "🔴 idx 7 (NEW)\nexpiry=900ms\nfd=80\nheap_idx=7"
    style: {
      fill: "#fed7d7"
      stroke: "#c53030"
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  root -> n1
  root -> n2
  n1 -> n3
  n1 -> n4
  n2 -> n5
  n2 -> n6
  n3 -> new_node: "parent(7)=3" {
    style: { stroke: "#c53030"; stroke-width: 2; bold: true }
  }

  action_info: {
    label: |md
      **Action:** timer_pool[7] = {900, 80, 7}
      **Action:** h->size++ → size=8
      **Next:** heap_sift_up(h, pos=7)
    |
    style: { fill: "#fff0f0"; stroke: "#c53030" }
  }
}

# ─── FRAME 3: Sift-Up Iteration 1 ─────────────────────────────────────────────
f3: {
  label: "Frame 3: Sift-Up Iter 1 (Swap 7 & 3)"
  style: {
    fill: "#fffaf0"
    stroke: "#d69e2e"
    stroke-width: 2
    border-radius: 8
  }
  n3_before: {
    label: "🔴 idx 3 BEFORE\nexpiry=2000ms\nfd=40"
    style: { fill: "#fed7d7"; stroke: "#c53030"; stroke-width: 2; bold: true }
  }
  new_before: {
    label: "🔴 idx 7 BEFORE\nexpiry=900ms\nfd=80"
    style: { fill: "#fed7d7"; stroke: "#c53030"; stroke-width: 2; bold: true }
  }
  
  n3_before -> new_before: "900 < 2000 → SWAP" {
    style: { stroke: "#e53e3e"; stroke-width: 3; bold: true }
  }

  after_container: {
    label: "After heap_swap(h, 3, 7):"
    n3_after: {
      label: "🔴 idx 3 AFTER\nexpiry=900ms\nfd=80"
      style: { fill: "#c6f6d5"; stroke: "#276749"; stroke-width: 2; bold: true }
    }
    n7_after: {
      label: "🔴 idx 7 AFTER\nexpiry=2000ms\nfd=40"
      style: { fill: "#c6f6d5"; stroke: "#276749"; stroke-width: 2; bold: true }
    }
    style: { fill: "#fefcbf"; stroke: "#d69e2e"; bold: true }
  }

  swap_detail: {
    label: |md
      **heap_swap(3, 7):**
      1. Swap timer_heap indices
      2. Update timer_pool[slot].heap_idx
      3. conn_t[fd].timer_id = new_pos
      **Next:** parent(3) = 1
    |
    style: { fill: "#fffff0"; stroke: "#d69e2e" }
  }
}

# ─── FRAME 4: Sift-Up Iteration 2 ─────────────────────────────────────────────
f4: {
  label: "Frame 4: Sift-Up Iter 2 (Swap 3 & 1)"
  style: {
    fill: "#f0fff4"
    stroke: "#276749"
    stroke-width: 2
    border-radius: 8
  }
  n1_before: {
    label: "🔴 idx 1 (1500ms)"
    style: { fill: "#fed7d7"; stroke: "#c53030"; stroke-width: 2; bold: true }
  }
  n3_curr: {
    label: "🔴 idx 3 (900ms)"
    style: { fill: "#fed7d7"; stroke: "#c53030"; stroke-width: 2; bold: true }
  }
  
  n1_before -> n3_curr: "900 < 1500 → SWAP" {
    style: { stroke: "#e53e3e"; stroke-width: 2; bold: true }
  }

  res: {
    label: "Result:"
    n1_a: { label: "🔴 idx 1 AFTER\n900ms"; style.fill: "#c6f6d5" }
    n3_a: { label: "🔴 idx 3 AFTER\n1500ms"; style.fill: "#c6f6d5" }
  }
}

# ─── FRAME 5: Final State ─────────────────────────────────────────────────────
f5: {
  label: "Frame 5: Root Comparison & Final"
  style: {
    fill: "#ebf8ff"
    stroke: "#2c5282"
    stroke-width: 3
    border-radius: 8
  }
  root_f: {
    label: "✅ ROOT idx 0\nexpiry=900ms\nfd=80"
    style: { fill: "#9ae6b4"; stroke: "#22543d"; stroke-width: 3; bold: true }
  }
  n1_f: { label: "idx 1\n1000ms\nfd=10"; style.fill: "#c6f6d5" }
  n2_f: { label: "idx 2\n1200ms" }
  
  root_f -> n1_f
  root_f -> n2_f

  final_check: {
    label: |md
      **Sift-Up Terminated at pos=0**
      **Final array:** [900, 1000, 1200, 1500, 3000, 1800, 2500, 2000]
      **Invariant:** parent.expiry ≤ child.expiry ✅
    |
    style: { fill: "#ebf8ff"; stroke: "#2c5282" }
  }
}

# ─── Step summary strip ────────────────────────────────────────────────────────
summary: {
  label: "Sift-Up Operation Summary"
  style: {
    fill: "#faf5ff"
    stroke: "#6b46c1"
    stroke-width: 2
    border-radius: 6
  }
  s1: { label: "Step 1\nAppend idx 7"; style.fill: "#e9d8fd" }
  s2: { label: "Step 2\nSwap(3,7)"; style: { fill: "#ed8936"; font-color: white; bold: true } }
  s3: { label: "Step 3\nSwap(1,3)"; style: { fill: "#ed8936"; font-color: white; bold: true } }
  s4: { label: "Step 4\nSwap(0,1)"; style: { fill: "#ed8936"; font-color: white; bold: true } }
  s5: { label: "Step 5\nRoot: Done"; style: { fill: "#9ae6b4"; bold: true } }

  s1 -> s2 -> s3 -> s4 -> s5
}

f1 -> f2 -> f3 -> f4 -> f5
f5 -> summary