vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## Timer Cancel: Swap-With-Last Pattern and Dual Sift to Restore Heap Order
| {near: top-center}

frame1: "Frame 1: Initial Heap — Cancel Target at idx=2" {
  style.fill: "#f0f4ff"
  style.border-radius: 8

  heap1: "Min-Heap (size=6)" {
    style.fill: "#e8eaf6"
    style.border-radius: 6
    
    n0: "idx=0\nexpiry=1000ms\nfd=3" {
      style.fill: "#b39ddb"
      style.font-color: white
      style.border-radius: 4
    }
    n1: "idx=1\nexpiry=1400ms\nfd=7" {
      style.fill: "#9fa8da"
      style.font-color: white
      style.border-radius: 4
    }
    n2: "idx=2 ← **CANCEL**\nexpiry=1200ms\nfd=5" {
      style.fill: "#ef5350"
      style.font-color: white
      style.border-radius: 4
      style.bold: true
      style.stroke: red
      style.stroke-width: 4
    }
    n3: "idx=3\nexpiry=2100ms\nfd=9" {
      style.fill: "#9fa8da"
      style.font-color: white
      style.border-radius: 4
    }
    n4: "idx=4\nexpiry=2500ms\nfd=2" {
      style.fill: "#9fa8da"
      style.font-color: white
      style.border-radius: 4
    }
    n5: "idx=5 ← **LAST**\nexpiry=1800ms\nfd=11" {
      style.fill: "#66bb6a"
      style.font-color: white
      style.border-radius: 4
      style.bold: true
      style.stroke: green
      style.stroke-width: 4
    }

    n0 -> n1: "left"
    n0 -> n2: "right" {style.stroke: "#ef5350"; style.stroke-width: 3}
    n1 -> n3: "left"
    n1 -> n4: "right"
    n2 -> n5: "left" {style.stroke: "#66bb6a"; style.stroke-width: 3}
  }

  conn5: "conn_table[fd=5]\ntimer_id = 2" {
    style.fill: "#ffccbc"
    style.border-radius: 4
  }
  conn11: "conn_table[fd=11]\ntimer_id = 5" {
    style.fill: "#c8e6c9"
    style.border-radius: 4
  }

  heap1.n2 -> conn5: "back-ptr" {style.stroke-dash: 4; style.stroke: "#ef5350"}
  heap1.n5 -> conn11: "back-ptr" {style.stroke-dash: 4; style.stroke: "#66bb6a"}

  note1: |md
    **Step 1:** Record cancelled_fd = fd[idx=2] = fd=5  
    Set conn_table[fd=5].timer_id = TIMER_ID_NONE (= -1)  
    `last = heap_size - 1 = 5`; `idx(2) != last(5)` → proceed with swap
  | {style.fill: "#fffde7"; style.border-radius: 4}
}

frame2: "Frame 2: Swap idx=2 ↔ idx=5 (Last), heap_size-- → 5" {
  style.fill: "#f0f4ff"
  style.border-radius: 8

  heap2: "Min-Heap (size=5, idx=5 REMOVED)" {
    style.fill: "#e8eaf6"
    style.border-radius: 6
    
    m0: "idx=0\nexpiry=1000ms\nfd=3" {
      style.fill: "#b39ddb"
      style.font-color: white
      style.border-radius: 4
    }
    m1: "idx=1\nexpiry=1400ms\nfd=7" {
      style.fill: "#9fa8da"
      style.font-color: white
      style.border-radius: 4
    }
    m2: "**idx=2 ← SWAPPED IN**\nexpiry=1800ms\nfd=11" {
      style.fill: "#66bb6a"
      style.font-color: white
      style.border-radius: 4
      style.bold: true
      style.stroke: red
      style.stroke-width: 4
    }
    m3: "idx=3\nexpiry=2100ms\nfd=9" {
      style.fill: "#9fa8da"
      style.font-color: white
      style.border-radius: 4
    }
    m4: "idx=4\nexpiry=2500ms\nfd=2" {
      style.fill: "#9fa8da"
      style.font-color: white
      style.border-radius: 4
    }
    m5: "idx=5 FREED\n(out of range)" {
      style.fill: "#eceff1"
      style.font-color: "#90a4ae"
      style.border-radius: 4
      style.stroke-dash: 5
      style.italic: true
    }

    m0 -> m1
    m0 -> m2 {style.stroke: red; style.stroke-width: 3}
    m1 -> m3
    m1 -> m4
  }

  updates2: "Back-pointer Updates" {
    style.fill: "#fff9c4"
    u1: "**conn_table[fd=5].timer_id = -1**" {
      style.fill: "#ffcdd2"
      style.border-radius: 4
    }
    u2: "**conn_table[fd=11].timer_id = 2**" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    u3: "**timer_pool[slot_11].heap_idx = 2**" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    u1 -> u2 {style.stroke-dash: 3}
    u2 -> u3 {style.stroke-dash: 3}
  }

  note2: |md
    **Step 2:** `heap_swap(h, idx=2, last=5)` performs:  
    • Swap `timer_heap[2]` ↔ `timer_heap[5]`  
    • Update `timer_pool[slot].heap_idx` for both  
    • Update `conn_t->timer_id` for both fds  
    **Step 3:** `heap_size-- → 5`  (idx=5 now out of range)
  | {style.fill: "#fffde7"; style.border-radius: 4}
}

frame3: "Frame 3: Dual Sift from idx=2" {
  style.fill: "#f0f4ff"
  style.border-radius: 8

  sifts: {
    sift_up: "Frame 3a: heap_sift_up(h, idx=2)" {
      style.fill: "#e3f2fd"
      su_title: |md
        **Parent check:**  
        parent_idx = (2-1)/2 = 0 (1000ms)  
        node.expiry = 1800ms  
        **1000 ≤ 1800 → NO SWAP**
      | {style.fill: "#bbdefb"}
      su0: "idx=0 (1000ms)" {style.fill: "#b39ddb"; style.font-color: white}
      su2: "idx=2 (1800ms)" {style.fill: "#66bb6a"; style.font-color: white}
      su0 -> su2: "OK" {style.stroke: "#1565c0"; style.stroke-width: 2}
    }

    sift_down: "Frame 3b: heap_sift_down(h, idx=2)" {
      style.fill: "#e8f5e9"
      sd_title: |md
        **Children check:**  
        Children 5,6 ≥ size 5  
        **NO SWAP**
      | {style.fill: "#c8e6c9"}
      sd2: "idx=2 (1800ms)" {style.fill: "#66bb6a"; style.font-color: white}
      sd_null: "OUT OF RANGE" {style.fill: "#eceff1"; style.stroke-dash: 5}
      sd2 -> sd_null: "no children" {style.stroke-dash: 4}
    }
  }

  final_heap: "Final Min-Heap (size=5)" {
    style.fill: "#fce4ec"
    f0: "idx=0\n1000ms\nfd=3" {style.fill: "#ad1457"; style.font-color: white}
    f1: "idx=1\n1400ms\nfd=7" {style.fill: "#c2185b"; style.font-color: white}
    f2: "idx=2\n1800ms\nfd=11" {style.fill: "#66bb6a"; style.font-color: white; style.stroke-width: 2}
    f3: "idx=3\n2100ms\nfd=9" {style.fill: "#c2185b"; style.font-color: white}
    f4: "idx=4\n2500ms\nfd=2" {style.fill: "#c2185b"; style.font-color: white}
    
    f0 -> f1
    f0 -> f2 {style.stroke: "#388e3c"; style.stroke-width: 2}
    f1 -> f3
    f1 -> f4
  }

  invariant_check: |md
    **Back-pointer invariant (all hold):**  
    1. `conn_table[fd=5].timer_id = -1` ✓  
    2. `conn_table[fd=11].timer_id = 2` ✓  
    3. `timer_pool[slot_11].heap_idx = 2` ✓  
    **Dual Sift Logic:** Only one direction ever performs swaps; the other is a no-op. Handles all swap-in locations.
  | {style.fill: "#fffde7"; style.border-radius: 6}
}

frame1 -> frame2: "Step 1→2:\nSwap with last\nUpdate back-ptrs" {
  style.stroke: "#5c6bc0"
  style.stroke-width: 3
}

frame2 -> frame3: "Step 3:\nShrink size\nDual Sift" {
  style.stroke: "#5c6bc0"
  style.stroke-width: 3
}