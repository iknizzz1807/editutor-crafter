vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: {
  shape: text
  label: |md
    ## `reactor_t` Internal Struct Layout
    **All Fields with Byte Offsets and Embedded Arrays**
  |
  near: top-center
}

annotation: {
  shape: text
  label: |md
    **Design Rationale:** `deferred[]` and `pending_ops[]` are embedded directly 
    in `reactor_t` to avoid pointer chasing in the hot dispatch path. 
    `handlers` and `timer_pool` are heap-allocated to support runtime-configured 
    `max_fds` and `max_timers`.
  |
  near: bottom-center
  style.italic: true
}

reactor_struct: {
  label: "`reactor_t`  —  Total ≈ 20.1 KB"
  style.fill: "#f0f0f0"
  style.stroke: "#333"
  style.stroke-width: 2
  style.bold: true

  # ─── SECTION 1: SCALAR FIELDS ───────────────────────────────────────
  scalars: "Section 1 — Scalar Fields (offset 0-55)" {
    style.fill: "#d0c0e8"
    style.stroke: "#7b3f9e"
    style.stroke-width: 2

    f_epfd: {
      label: "**+0** `int epfd` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_running: {
      label: "**+4** `int running` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_dispatching: {
      label: "**+8** `int dispatching` (4 B) ★"
      style.fill: "#c8a8f0"
      style.stroke: "#5b1f8e"
      style.stroke-width: 2
    }
    f_pad0: {
      label: "**+12** `int _pad` (4 B)"
      style.fill: "#dddddd"
      style.stroke: "#999999"
    }
    
    cl_boundary_0: "── cache line 0 boundary (64 B) ──" {
      style.stroke-dash: 5
      style.stroke: "#888888"
    }

    f_max_fds: {
      label: "**+24** `int max_fds` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_timer_pool_size: {
      label: "**+28** `int timer_pool_size` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_timer_heap_size: {
      label: "**+32** `int timer_heap_size` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_next_timer_id: {
      label: "**+36** `int next_timer_id` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_pending_count: {
      label: "**+40** `int pending_count` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_deferred_head: {
      label: "**+44** `int deferred_head` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_deferred_tail: {
      label: "**+48** `int deferred_tail` (4 B)"
      style.fill: "#e8d8f8"
      style.stroke: "#7b3f9e"
    }
    f_pad1: {
      label: "**+52** `int _pad4` (4 B)"
      style.fill: "#dddddd"
      style.stroke: "#999999"
    }
  }

  # ─── SECTION 2: POINTER FIELDS ──────────────────────────────────────
  pointers: "Section 2 — Heap Pointer Fields (offset 56-79)" {
    style.fill: "#ffe0b0"
    style.stroke: "#b86800"
    style.stroke-width: 2

    p_handlers: {
      label: "**+56** `fd_handler_t *handlers` (8 B)"
      style.fill: "#fff0d0"
      style.stroke: "#b86800"
    }
    p_timer_pool: {
      label: "**+64** `timer_entry_t *timer_pool` (8 B)"
      style.fill: "#fff0d0"
      style.stroke: "#b86800"
    }
    p_timer_heap: {
      label: "**+72** `int *timer_heap` (8 B)"
      style.fill: "#fff0d0"
      style.stroke: "#b86800"
    }

    cl_boundary_1: "── cache line 1 boundary (128 B) ──" {
      style.stroke-dash: 5
      style.stroke: "#888888"
    }
  }

  # ─── SECTION 3A: EMBEDDED deferred[] ARRAY ──────────────────────────
  deferred_arr: "Section 3a — `deferred[1024]` (offset 80-16463)" {
    style.fill: "#b8e0b8"
    style.stroke: "#2a7a2a"
    style.stroke-width: 2

    deferred_hdr: {
      label: "|md\n**+80** `deferred_task_t deferred[1024]`\nEach entry: 16 B\nTotal: 16,384 B\n|"
      style.fill: "#d8f0d8"
      style.stroke: "#2a7a2a"
    }
    deferred_entry0: { label: "[0] +80"; style.fill: "#e8f8e8" }
    deferred_entry1: { label: "[1] +96"; style.fill: "#e8f8e8" }
    deferred_ellipsis: "   ··· entries [2] - [1021] ···" {
      style.stroke-dash: 4
      style.italic: true
    }
    deferred_entry1023: { label: "[1023] +16448"; style.fill: "#e8f8e8" }
  }

  # ─── SECTION 3B: EMBEDDED pending_ops[] ARRAY ───────────────────────
  pending_arr: "Section 3b — `pending_ops[256]` (offset 16464-20559)" {
    style.fill: "#b8d0f0"
    style.stroke: "#1a4a9a"
    style.stroke-width: 2

    pending_hdr: {
      label: "|md\n**+16,464** `pending_mod_t pending_ops[256]`\nEach entry: 16 B\nTotal: 4,096 B\n|"
      style.fill: "#d8e8f8"
      style.stroke: "#1a4a9a"
    }
    pending_entry0: { label: "[0] +16464"; style.fill: "#e0ecfa" }
    pending_ellipsis: "   ··· entries [1] - [254] ···" {
      style.stroke-dash: 4
      style.italic: true
    }
    pending_entry255: { 
      label: "[255] +20544"
      style.fill: "#e0ecfa"
    }
  }

  total_size_box: {
    label: "|md\n**Total `sizeof(reactor_t)` = 20,560 B**\n≈ 321 cache lines\n|"
    style.fill: "#f8f0e0"
    style.stroke: "#885500"
    style.stroke-width: 2
  }
}

heap_handlers: {
  label: "|md\n**fd_handler_t handlers[]**\nHeap-allocated\n+0 registered (4)\n+8 fd (4)\n+16 callback (8)\n+24 udata (8)\n= 32 B/entry\n|"
  style.fill: "#fff0d0"
  style.stroke: "#b86800"
}

heap_timer_pool: {
  label: "|md\n**timer_entry_t timer_pool[]**\nHeap-allocated\n+0 active (4)\n+8 heap_idx (4)\n+16 expiry_ms (8)\n+32 callback (8)\n= 48 B/entry\n|"
  style.fill: "#fff0d0"
  style.stroke: "#b86800"
}

heap_timer_heap: {
  label: "|md\n**int timer_heap[]**\nHeap-allocated\nMin-heap indices\npointing to\ntimer_pool[]\n|"
  style.fill: "#fff0d0"
  style.stroke: "#b86800"
}

dispatching_note: {
  label: "|md\n★ **`dispatching` field (+8)**\nRe-entrancy guard. Set to `1` during\nPhase 1 (I/O dispatch). Registration\ncalls seeing `1` enqueue to `pending_ops`.\n|"
  style.fill: "#f0e0ff"
  style.stroke: "#7b3f9e"
}

reactor_struct.pointers.p_handlers -> heap_handlers: "O(1) lookup" {
  style.stroke: "#b86800"
  style.stroke-dash: 4
  style.animated: true
}
reactor_struct.pointers.p_timer_pool -> heap_timer_pool: "flat pool" {
  style.stroke: "#b86800"
  style.stroke-dash: 4
}
reactor_struct.pointers.p_timer_heap -> heap_timer_heap: "min-heap" {
  style.stroke: "#b86800"
  style.stroke-dash: 4
}
heap_timer_heap -> heap_timer_pool: "pool index" {
  style.stroke: "#555555"
  style.stroke-dash: 3
}