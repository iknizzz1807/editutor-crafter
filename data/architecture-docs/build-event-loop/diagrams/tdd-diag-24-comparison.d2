vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # One-Shot vs Repeating Timer: Behavioral Comparison
| {near: top-center}

grid-columns: 2
grid-gap: 40

oneshot: "One-Shot (interval_ms = 0)" {
  direction: down
  style.fill: "#2d1b4e"
  style.stroke: "#9b59b6"
  style.border-radius: 4

  b1: "heap_cancel_at_slot called BEFORE cb" {
    style.fill: "#3d2b5e"
    style.stroke: "#9b59b6"
  }
  b2: "slot memset'd to zero" {
    style.fill: "#3d2b5e"
    style.stroke: "#9b59b6"
  }
  b3: "heap_size decremented" {
    style.fill: "#3d2b5e"
    style.stroke: "#9b59b6"
  }
  b4: "cb sees timer already gone" {
    style.fill: "#3d2b5e"
    style.stroke: "#9b59b6"
  }
  b5: "cancel(tid) in cb → -1 (safe no-op)" {
    style.fill: "#3d2b5e"
    style.stroke: "#9b59b6"
  }
  b6: "no re-fire after cb" {
    style.fill: "#3d2b5e"
    style.stroke: "#9b59b6"
  }

  b1 -> b2 -> b3 -> b4 -> b5 -> b6
}

repeating: "Repeating (interval_ms > 0)" {
  direction: down
  style.fill: "#1a2e1a"
  style.stroke: "#27ae60"
  style.border-radius: 4

  c1: "expiry_ms += interval called BEFORE cb" {
    style.fill: "#1e4d2b"
    style.stroke: "#27ae60"
  }
  c2: "sift_down repositions in heap" {
    style.fill: "#1e4d2b"
    style.stroke: "#27ae60"
  }
  c3: "heap_size unchanged" {
    style.fill: "#1e4d2b"
    style.stroke: "#27ae60"
  }
  c4: "slot remains active during cb" {
    style.fill: "#1e4d2b"
    style.stroke: "#27ae60"
  }
  c5: "cancel(tid) in cb → 0 (found and removed)" {
    style.fill: "#1e4d2b"
    style.stroke: "#27ae60"
  }
  c6: "re-fires at new expiry if not cancelled" {
    style.fill: "#1e4d2b"
    style.stroke: "#27ae60"
  }

  c1 -> c2 -> c3 -> c4 -> c5 -> c6
}
