vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # One-Shot vs Repeating Timer: Heap State Before and After Expiry
| {near: top-center}
scenarios: {
  direction: right
  scenario_a: "SCENARIO A — One-Shot (interval_ms = 0)" {
    style.fill: "#2d1b4e"
    style.stroke: "#9b59b6"
    style.border-radius: 8
    before_a: "BEFORE: Heap Root Expires" {
      style.fill: "#1a1a2e"
      style.stroke: "#7d3c98"
      style.border-radius: 6
      root_a: "heap[0] → pool[slot]" {
        style.fill: "#4a235a"
        style.stroke: "#e056fd"
        style.border-radius: 4
        label: |md
          **heap[0] → pool[slot]**
          timer_id = 42
          expiry_ms = 1000 ≤ now_ms()
          interval_ms = **0** ← one-shot
          heap_idx = 0
          cb = on_idle_timeout
          udata = conn*
        |
      }
      last_a: "heap[size-1] → pool[slot_last]" {
        style.fill: "#2c3e50"
        style.stroke: "#7f8c8d"
        style.border-radius: 4
        label: |md
          **heap[size-1] → pool[slot_last]**
          timer_id = 77
          expiry_ms = 45000
          interval_ms = 0
          heap_idx = size-1
        |
      }
      heap_size_a: "timer_heap_size = N" {
        style.fill: "#1a1a2e"
        style.stroke: "#7d3c98"
        style.font-color: "#e8b4f8"
        shape: text
      }
    }
    steps_a: "EXPIRY EXECUTION STEPS" {
      style.fill: "#1a1a2e"
      style.stroke: "#8e44ad"
      style.border-radius: 6
      s1: "① Capture before mutation" {
        style.fill: "#512e5f"
        style.stroke: "#a569bd"
        style.border-radius: 4
        label: |md
          **① Capture before mutation**
          tid      ← pool[slot].timer_id  = 42
          interval ← pool[slot].interval_ms = 0
          cb       ← pool[slot].callback
          udata    ← pool[slot].udata
        |
      }
      s2: "② interval_ms == 0 → REMOVE" {
        style.fill: "#512e5f"
        style.stroke: "#e056fd"
        style.stroke-width: 2
        style.bold: true
        style.border-radius: 4
        label: |md
          **② interval_ms == 0 → REMOVE**
          heap_cancel_at_slot(r, slot)
            swap heap[0] ↔ heap[size-1]
            timer_heap_size--
            sift_down(r, 0)
            memset(pool[slot], 0)
        |
      }
      s3: "③ Call cb(tid=42, udata)" {
        style.fill: "#512e5f"
        style.stroke: "#a569bd"
        style.border-radius: 4
        label: |md
          **③ Call cb(tid=42, udata)**
          on_idle_timeout fires
          cb may call:
            reactor_cancel_timer(r, 42)
            → linear scan finds NO active entry
               with timer_id=42
            → returns -1 (safe no-op)
        |
      }
    }
    after_a: "AFTER: Heap Root Replaced" {
      style.fill: "#1a1a2e"
      style.stroke: "#7d3c98"
      style.border-radius: 6
      new_root_a: "heap[0] → pool[slot_last] (promoted)" {
        style.fill: "#1a472a"
        style.stroke: "#27ae60"
        style.border-radius: 4
        label: |md
          **heap[0] → pool[slot_last]** (promoted)
          timer_id = 77
          expiry_ms = 45000
          heap_idx = 0  ← updated by sift_down
        |
      }
      freed_slot_a: "pool[slot] — CLEARED" {
        style.fill: "#2c2c2c"
        style.stroke: "#e74c3c"
        style.stroke-dash: 5
        style.border-radius: 4
        label: |md
          **pool[slot] — CLEARED**
          memset → all zeros
          active = 0
          timer_id = 0
          (slot available for reuse)
        |
      }
      heap_size_after_a: "timer_heap_size = N-1" {
        style.fill: "#1a1a2e"
        style.stroke: "#27ae60"
        style.font-color: "#abebc6"
        shape: text
      }
    }
    result_a: "RESULT ANNOTATION" {
      style.fill: "#0d1117"
      style.stroke: "#e056fd"
      style.stroke-dash: 3
      style.border-radius: 4
      style.font-size: 14
      label: |md
        **One-Shot Result:**
        Timer removed from heap BEFORE cb fires.
        cb calling reactor_cancel_timer(42) → returns -1 → harmless.
        No ghost entries. No double-free risk.
        Heap property restored by sift_down in O(log N).
      |
    }
    before_a -> steps_a.s1: "expiry_ms ≤ now_ms()" {
      style.stroke: "#9b59b6"
      style.animated: true
    }
    steps_a.s1 -> steps_a.s2
    steps_a.s2 -> steps_a.s3
    steps_a.s3 -> after_a: "heap mutated before cb"
    after_a -> result_a
  }
  scenario_b: "SCENARIO B — Repeating (interval_ms = 5000)" {
    style.fill: "#1a2e1a"
    style.stroke: "#27ae60"
    style.border-radius: 8
    before_b: "BEFORE: Heap Root Expires" {
      style.fill: "#0d1a0d"
      style.stroke: "#229954"
      style.border-radius: 6
      root_b: "heap[0] → pool[slot]" {
        style.fill: "#1e4d2b"
        style.stroke: "#2ecc71"
        style.border-radius: 4
        label: |md
          **heap[0] → pool[slot]**
          timer_id = 99
          expiry_ms = 5000 ≤ now_ms() = 35000
          interval_ms = **5000** ← repeating
          heap_idx = 0
          cb = on_heartbeat
          udata = server*
        |
      }
      heap_size_b: "timer_heap_size = M" {
        style.fill: "#0d1a0d"
        style.stroke: "#229954"
        style.font-color: "#abebc6"
        shape: text
      }
    }
    steps_b: "EXPIRY EXECUTION STEPS" {
      style.fill: "#0d1a0d"
      style.stroke: "#1e8449"
      style.border-radius: 6
      sb1: "① Capture before mutation" {
        style.fill: "#1a5276"
        style.stroke: "#2e86c1"
        style.border-radius: 4
        label: |md
          **① Capture before mutation**
          tid      ← pool[slot].timer_id  = 99
          interval ← pool[slot].interval_ms = 5000
          cb       ← pool[slot].callback
          udata    ← pool[slot].udata
        |
      }
      sb2: "② interval_ms > 0 → RESCHEDULE (NOT remove)" {
        style.fill: "#1a5276"
        style.stroke: "#2ecc71"
        style.stroke-width: 2
        style.bold: true
        style.border-radius: 4
        label: |md
          **② interval_ms > 0 → RESCHEDULE**
          pool[slot].expiry_ms = 5000 + 5000 = 40000
          sift_down(r, 0)
          ← DO NOT call heap_cancel_at_slot
          ← DO NOT memset the slot
          timer_heap_size unchanged = M
        |
      }
      sb3: "③ Call cb(tid=99, udata)" {
        style.fill: "#1a5276"
        style.stroke: "#2e86c1"
        style.border-radius: 4
        label: |md
          **③ Call cb(tid=99, udata)**
          on_heartbeat fires
          cb may call:
            reactor_cancel_timer(r, 99)
            → scan finds pool[slot].timer_id==99
               pool[slot].active==1 ← still there!
            → heap_cancel_at_slot removes it
            → returns 0 (success)
          OR cb returns without cancelling
            → timer fires again at expiry=40000
        |
      }
    }
    after_b_keep: "AFTER (cb did NOT cancel): Timer Rescheduled" {
      style.fill: "#0d1a0d"
      style.stroke: "#229954"
      style.border-radius: 6
      rescheduled: "pool[slot] — RESCHEDULED" {
        style.fill: "#1e4d2b"
        style.stroke: "#27ae60"
        style.border-radius: 4
        label: |md
          **pool[slot] — RESCHEDULED**
          timer_id = 99 (unchanged)
          expiry_ms = 40000 ← next fire
          interval_ms = 5000
          active = 1 (still live)
          heap position may differ (sift_down moved it)
        |
      }
      heap_size_after_b: "timer_heap_size = M (unchanged)" {
        style.fill: "#0d1a0d"
        style.stroke: "#229954"
        style.font-color: "#abebc6"
        shape: text
      }
    }
    after_b_cancel: "AFTER (cb called cancel): Timer Removed" {
      style.fill: "#0d1a0d"
      style.stroke: "#e74c3c"
      style.border-radius: 6
      cancelled: "pool[slot] — CANCELLED during cb" {
        style.fill: "#2c2c2c"
        style.stroke: "#e74c3c"
        style.stroke-dash: 5
        style.border-radius: 4
        label: |md
          **pool[slot] — CANCELLED during cb**
          reactor_cancel_timer(99) found it
          heap_cancel_at_slot executed
          memset → zeros
          timer_heap_size = M-1
        |
      }
    }
    ordering_annotation: "⚠ CRITICAL ORDERING INVARIANT" {
      style.fill: "#4a1a00"
      style.stroke: "#e67e22"
      style.stroke-width: 2
      style.border-radius: 6
      label: |md
        **⚠ CRITICAL ORDERING INVARIANT**
        **CORRECT (implemented above):**
          pool[slot].expiry_ms = prev + interval   ← RESCHEDULE FIRST
          sift_down(r, 0)
          cb(tid, udata)                           ← cb fires SECOND
          if cb calls cancel → finds live entry → removes correctly
        **WRONG (if order reversed):**
          cb(tid, udata)                           ← fires first
          if cb calls cancel → removes entry (heap shrinks)
          pool[slot].expiry_ms = prev + interval   ← RESCHEDULE NOW ADDS GHOST
          sift_up / sift_down on already-cancelled slot
          → ghost entry with timer_id=99; next expire closes random conn
      |
    }
    before_b -> steps_b.sb1: "expiry_ms ≤ now_ms()" {
      style.stroke: "#27ae60"
      style.animated: true
    }
    steps_b.sb1 -> steps_b.sb2
    steps_b.sb2 -> steps_b.sb3: "reschedule complete BEFORE cb" {
      style.stroke: "#2ecc71"
      style.bold: true
    }
    steps_b.sb3 -> after_b_keep: "cb returns normally" {
      style.stroke: "#27ae60"
    }
    steps_b.sb3 -> after_b_cancel: "cb calls cancel(99)" {
      style.stroke: "#e74c3c"
    }
    steps_b.sb2 -> ordering_annotation: "ordering enforced here" {
      style.stroke: "#e67e22"
      style.stroke-dash: 3
    }
  }
  comparison: "SIDE-BY-SIDE BEHAVIORAL DIFF" {
    style.fill: "#0d0d0d"
    style.stroke: "#7f8c8d"
    style.border-radius: 8
    grid-columns: 2
    oneshot_summary: "One-Shot" {
      style.fill: "#2d1b4e"
      style.stroke: "#9b59b6"
      style.border-radius: 4
      label: |md
        **One-Shot (interval_ms = 0)**
        • heap_cancel_at_slot BEFORE cb
        • slot memset'd to zero
        • heap_size decremented
        • cb sees timer already gone
        • cancel(tid) in cb → -1 (safe)
        • No re-fire after cb
      |
    }
    repeating_summary: "Repeating" {
      style.fill: "#1a2e1a"
      style.stroke: "#27ae60"
      style.border-radius: 4
      label: |md
        **Repeating (interval_ms > 0)**
        • expiry_ms += interval BEFORE cb
        • sift_down repositions in heap
        • heap_size unchanged
        • slot remains active during cb
        • cancel(tid) in cb → 0 (found and removed)
        • Re-fires at new expiry if not cancelled
      |
    }
  }
}