vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
## `http_conn_t` Memory Layout — Cache Line Boundaries
`sizeof(http_conn_t) ≈ 26,760 bytes`  ·  10K connections ≈ **260 MB**
'| {near: top-center}

legend: |'md
**Colors:** 🟣 Header/Fields (#8e44ad)  🔵 Data (#2980b9)  🟠 Pointers (#e67e22)  ⬜ Padding (#7f8c8d)  🟢 Success/Structs (#27ae60)
'| {near: bottom-center}

# ─────────────────────────────────────────────
# CACHE LINE 0  (bytes 0–63)  HOT FIELDS
# ─────────────────────────────────────────────
cl0: "Cache Line 0  [0x00 - 0x3F]  ← HOT: Fits in L1" {
  style: {
    fill: "#2d1b69"
    stroke: "#9b59b6"
    stroke-width: 4
    font-color: white
    bold: true
    border-radius: 6
  }
  grid-rows: 1
  grid-gap: 0

  f_fd: "fd\n[int]\n0x00\n4 B" {
    style.fill: "#8e44ad"
    style.font-color: white
    style.stroke: "#6c3483"
  }
  f_idle: "idle_tmr\n[int]\n0x04\n4 B" {
    style.fill: "#8e44ad"
    style.font-color: white
    style.stroke: "#6c3483"
  }
  f_hdr_timer: "hdr_tmr\n[int]\n0x08\n4 B" {
    style.fill: "#8e44ad"
    style.font-color: white
    style.stroke: "#6c3483"
  }
  f_epoll: "ep_arm\n[int]\n0x0C\n4 B" {
    style.fill: "#8e44ad"
    style.font-color: white
    style.stroke: "#6c3483"
  }
  f_reactor: "reactor*\n[ptr]\n0x10\n8 B" {
    style.fill: "#e67e22"
    style.font-color: white
    style.stroke: "#d35400"
  }
  f_state: "state\n[enum]\n0x18\n4 B" {
    style.fill: "#8e44ad"
    style.font-color: white
    style.stroke: "#6c3483"
  }
  f_pad1: "pad\n[int]\n0x1C\n4 B" {
    style.fill: "#7f8c8d"
    style.font-color: white
    style.stroke: "#626567"
  }
  f_wbuf: "w_buf*\n[ptr]\n0x20\n8 B" {
    style.fill: "#e67e22"
    style.font-color: white
    style.stroke: "#d35400"
  }
  f_rlen: "r_len\n[size_t]\n0x28\n8 B" {
    style.fill: "#2980b9"
    style.font-color: white
    style.stroke: "#1a5276"
  }
  f_pad2: "alignment padding\n[0x30 - 0x3F]\n16 B" {
    style.fill: "#7f8c8d"
    style.font-color: "#ecf0f1"
    style.stroke: "#626567"
    style.italic: true
  }
}

# ─────────────────────────────────────────────
# CACHE LINES 1–256  read_buf
# ─────────────────────────────────────────────
cl_rdbuf: "Cache Lines 1–256  [0x40 - 0x403F]  ← read_buf[16384]" {
  style: {
    fill: "#1a3a5c"
    stroke: "#2980b9"
    stroke-width: 3
    stroke-dash: 5
    font-color: white
    bold: true
    border-radius: 6
  }
  grid-rows: 1
  grid-gap: 0
  rb_label: "Receive staging buffer (16 KB).\nSequential access patterns used during epoll_wait cycle.\nDemand-paged: Zero overhead for idle connections." {
    style.fill: "#154360"
    style.font-color: "#aed6f1"
    style.stroke: "#1f618d"
    width: 600
  }
  rb_hint: "Memory Pressure:\n10K x 16KB = 160MB\nDRAM miss: ~200cyc" {
    style.fill: "#0b2132"
    style.font-color: "#f39c12"
    style.stroke: "#e67e22"
    style.italic: true
  }
}

# ─────────────────────────────────────────────
# CACHE LINE 257  body_received
# ─────────────────────────────────────────────
cl_body: "Cache Line 257  [0x4040 - 0x407F]" {
  style: {
    fill: "#1a3a5c"
    stroke: "#2980b9"
    stroke-width: 2
    font-color: white
    border-radius: 4
  }
  grid-rows: 1
  grid-gap: 0
  f_brec: "body_received\n[size_t]\n8 B" {
    style.fill: "#2980b9"
    style.font-color: white
    style.stroke: "#1a5276"
  }
  f_gap: "(padding to align next struct)" {
    style.fill: "#7f8c8d"
    style.opacity: 0.5
  }
}

# ─────────────────────────────────────────────
# http_request_t
# ─────────────────────────────────────────────
cl_req: "Cache Lines 258–280  [http_request_t]" {
  style: {
    fill: "#145a32"
    stroke: "#27ae60"
    stroke-width: 3
    font-color: white
    bold: true
    border-radius: 6
  }
  grid-rows: 1
  grid-gap: 0
  rq_method: "method[16]\n[char]\n16 B" {
    style.fill: "#2980b9"
    style.font-color: white
    style.stroke: "#1a5276"
  }
  rq_fields: "HTTP Meta\n(minor, KA)\n8 B" {
    style.fill: "#8e44ad"
    style.stroke: "#6c3483"
  }
  rq_cl: "content_len\n[ssize_t]\n8 B" {
    style.fill: "#2980b9"
    style.stroke: "#1a5276"
  }
  rq_path: "path[1024]\n[char array]\n1024 B" {
    style.fill: "#154360"
    style.font-color: "#abebc6"
    style.stroke: "#0e3d22"
    width: 250
  }
  rq_hdrs: "headers[32]\n[ptr pairs]\n512 B" {
    style.fill: "#e67e22"
    style.font-color: white
    style.stroke: "#d35400"
  }
}

# ─────────────────────────────────────────────
# header_buf
# ─────────────────────────────────────────────
cl_hbuf: "Cache Lines 281–409  [header_buf]" {
  style: {
    fill: "#1a3a5c"
    stroke: "#2980b9"
    stroke-width: 3
    stroke-dash: 5
    font-color: white
    bold: true
    border-radius: 6
  }
  hb_label: "header_buf[8192]\nFlat storage for parsed header strings.\nPointers in http_request_t reference this region." {
    style.fill: "#154360"
    style.font-color: "#aed6f1"
    style.stroke: "#1f618d"
  }
}

# ─────────────────────────────────────────────
# TOTAL SIZE ANNOTATION
# ─────────────────────────────────────────────
total_ann: |'md
| Region | Offset (Hex) | Size | Cache Lines |
| :--- | :--- | :--- | :--- |
| **Hot Fields** | 0x00 - 0x3F | 64 B | 1 |
| **Read Buffer** | 0x40 - 0x403F | 16,384 B | 256 |
| **Counters** | 0x4040 - 0x4047 | 8 B | 1 (part) |
| **Request Meta** | 0x4048 - 0x4697 | ~1,616 B | ~26 |
| **Header Buffer**| 0x46A0 - 0x669F | 8,192 B | 128 |
| **Total** | | **~26,272 B** | **~412** |

**Architecture Impact:**
1. **L1 Alignment:** Hot fields packed in CL 0 prevents "false sharing" and minimizes L1 misses on the main loop.
2. **Demand Paging:** `read_buf` and `header_buf` are 24KB. On Linux, these pages are only allocated physically when touched. Idle connections effectively consume only ~2KB physical RAM.
'| {near: bottom-center}

# ─────────────────────────────────────────────
# CONNECTIONS
# ─────────────────────────────────────────────
cl0 -> cl_rdbuf: "0x40 boundary" {
  style.stroke: "#2980b9"
  style.stroke-dash: 3
}
cl_rdbuf -> cl_body: "buffer end" {
  style.stroke: "#2980b9"
  style.stroke-dash: 3
}
cl_body -> cl_req: "0x4048" {
  style.stroke: "#27ae60"
  style.stroke-dash: 3
}
cl_req -> cl_hbuf: "ptr reference" {
  style.stroke: "#e67e22"
  style.animated: true
}