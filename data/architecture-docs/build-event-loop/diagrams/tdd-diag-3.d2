vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## `conn_t` Struct Memory Layout — Cache Line Boundaries
  Total: **4112 bytes = 64.25 cache lines (64B each)**
| {near: top-center}

mem_col: "Memory Layout" {
  direction: down
  style.fill: transparent
  style.stroke: transparent

  cl0: "Cache Line 0  [0x0000 – 0x003F]  64 bytes" {
    style.fill: "#e8d5f5"
    style.stroke: "#7c3aed"
    style.stroke-width: 3
    style.font: mono
    style.bold: true
    cl0_fields: {
      style.fill: transparent
      style.stroke: transparent
      f_state: "offset 0x0000 │ state │ conn_state_t │ 4 B" {
        style.fill: "#c4b5fd"
        style.stroke: "#7c3aed"
        style.stroke-width: 2
        style.font: mono
        width: 700
      }
      f_fd: "offset 0x0004 │ fd │ int │ 4 B" {
        style.fill: "#c4b5fd"
        style.stroke: "#7c3aed"
        style.stroke-width: 2
        style.font: mono
        width: 700
      }
      f_rbuf_start: "offset 0x0008 │ read_buf[0..55] │ char[56] │ 56 B" {
        style.fill: "#93c5fd"
        style.stroke: "#1d4ed8"
        style.stroke-width: 2
        style.font: mono
        width: 700
      }
      f_state -> f_fd
      f_fd -> f_rbuf_start
    }
    annotation_cl0: |'md
      **⚑ Hot fields: state + fd land here**
      First access = 1 cache miss → loads
      `state`, `fd`, and first 56B of `read_buf`
    '| {
      style.fill: "#fdf4ff"
      style.stroke: "#7c3aed"
      style.stroke-dash: 3
    }
    cl0_fields -> annotation_cl0: {style.stroke-width: 0}
  }

  cl1_63: "Cache Lines 1 – 63  [0x0040 – 0x0FFF]  4032 bytes" {
    style.fill: "#dbeafe"
    style.stroke: "#1d4ed8"
    style.stroke-width: 3
    style.font: mono
    style.bold: true
    f_rbuf_body: "offset 0x0040 │ read_buf[56..4095] │ char[4040] │ 4040 B" {
      style.fill: "#93c5fd"
      style.stroke: "#1d4ed8"
      style.stroke-width: 2
      style.font: mono
      width: 700
    }
    annotation_rbuf: |'md
      **62 full cache lines + partial tails**
      Cold access pattern: reading large messages
      sequentially prefetched by hardware prefetcher.
      Random access (mid-buffer parse) = L3 miss.
    '| {
      style.fill: "#eff6ff"
      style.stroke: "#1d4ed8"
      style.stroke-dash: 3
    }
    f_rbuf_body -> annotation_rbuf: {style.stroke-width: 0}
  }

  cl64_partial: "Cache Line 64 (partial)  [0x1000 – 0x100F]  16 bytes" {
    style.fill: "#d1fae5"
    style.stroke: "#065f46"
    style.stroke-width: 3
    style.font: mono
    style.bold: true
    f_read_len: "offset 1000 │ read_len │ size_t │ 8 B" {
      style.fill: "#6ee7b7"
      style.stroke: "#065f46"
      style.stroke-width: 2
      style.font: mono
      width: 700
    }
    annotation_rlen: |'md
      **Shares cache line 64 with end of struct.**
      Accessing `read_len` after `read_buf` tail
      = separate cache miss if buffer is cold.
      **8-byte aligned** — no struct padding needed.
    '| {
      style.fill: "#ecfdf5"
      style.stroke: "#065f46"
      style.stroke-dash: 3
    }
    f_read_len -> annotation_rlen: {style.stroke-width: 0}
  }

  cl0 -> cl1_63: "" {
    style.stroke-dash: 5
    style.stroke: "#7c3aed"
    style.stroke-width: 2
    target-arrowhead.shape: arrow
  }
  cl1_63 -> cl64_partial: "" {
    style.stroke-dash: 5
    style.stroke: "#1d4ed8"
    style.stroke-width: 2
    target-arrowhead.shape: arrow
  }
}

legend: "Legend & Annotations" {
  near: bottom-center
  style.fill: "#f8f8f8"
  style.stroke: "#666"
  style.stroke-width: 1
  style.border-radius: 6
  grid-columns: 3
  leg_header: "■ Purple — Header fields\n(state, fd)" {
    style.fill: "#c4b5fd"
    style.stroke: "#7c3aed"
    style.font: mono
    width: 220
  }
  leg_data: "■ Blue — Data buffer\n(read_buf[4096])" {
    style.fill: "#93c5fd"
    style.stroke: "#1d4ed8"
    style.font: mono
    width: 220
  }
  leg_meta: "■ Green — Metadata\n(read_len)" {
    style.fill: "#6ee7b7"
    style.stroke: "#065f46"
    style.font: mono
    width: 220
  }
}

totals: |'md
  **sizeof(conn_t) = 4112 bytes**
  Cache lines (64 B each): **64.25** — spans 65 cache lines total.
  **Cold first access**: ~64 cache-miss loads from DRAM (≈200 cycles each).
  **Hot access**: state+fd in L1; read_buf in L2/L3.
  Growth direction: **low → high address** (top to bottom as shown).
'| {
  near: bottom-right
  style.fill: "#fffbeb"
  style.stroke: "#b45309"
  style.stroke-width: 2
  style.border-radius: 4
}