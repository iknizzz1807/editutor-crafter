vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: ||md
  ## C10K Benchmark Architecture: wrk Load Profile and Kernel Buffer Pipeline
|| {near: top-center}

wrk_client: wrk Benchmark Client {
  style.fill: "#2D4A7A"
  style.font-color: white
  style.border-radius: 8
  style.shadow: true

  config: ||md
    **12 threads**
    **10,000 connections**
    **60s duration**
    `--latency` flag
  ||

  threads: Thread Pool {
    style.fill: "#3A5F9A"
    style.font-color: white
    t1: Thread 0..11 {
      style.fill: "#4A7ABF"
      style.font-color: white
      style.multiple: true
    }
  }

  conn_pool: Connection Pool {
    style.fill: "#3A5F9A"
    style.font-color: white
    active: "~833 conns/thread" {
      style.fill: "#4A7ABF"
      style.font-color: white
    }
  }
}

loopback: Loopback Interface (127.0.0.1) {
  style.fill: "#1A3A2A"
  style.font-color: "#7AF0A0"
  style.border-radius: 6
  style.stroke: "#4AF080"
  style.stroke-width: 2
  note: ||md
    **~200 active I/O events/tick**
    TCP segments via kernel loopback
    No physical NIC latency
  ||
}

server: HTTP Server Process (1 Thread) {
  style.fill: "#1A2A1A"
  style.font-color: "#A0F0A0"
  style.border-radius: 8
  style.shadow: true
  style.stroke: "#4AF080"
  style.stroke-width: 2

  epoll_inst: epoll Instance {
    style.fill: "#0A3A1A"
    style.font-color: "#80FF80"
    style.border-radius: 6
    style.stroke: "#4AF080"

    interest_set: Interest Set (Red-Black Tree) {
      style.fill: "#0A2A10"
      style.font-color: "#70EF70"
      registered: "9,950 IDLE fds" {
        style.fill: "#1A3A18"
        style.font-color: "#888"
        style.font-size: 11
        style.multiple: true
      }
      active: "~50 ACTIVE fds" {
        style.fill: "#206820"
        style.font-color: "#80FF80"
        style.stroke: "#4AF080"
        style.stroke-width: 2
        style.multiple: true
      }
    }

    readiness_q: Readiness Queue {
      style.fill: "#0A3020"
      style.font-color: "#60DF60"
      label: "~200 events ready\n(EPOLLIN | EPOLLOUT)"
    }
  }

  reactor: reactor_t (M3) {
    style.fill: "#142814"
    style.font-color: "#90EF90"
    style.border-radius: 6
    phase1: "Phase 1: I/O Dispatch" {
      style.fill: "#1E3A1E"
      style.font-color: "#A0F0A0"
      style.font-size: 11
    }
    phase2: "Phase 2: Pending epoll_ctl" {
      style.fill: "#1E3A1E"
      style.font-color: "#A0F0A0"
      style.font-size: 11
    }
    phase3: "Phase 3: Deferred Tasks" {
      style.fill: "#1E3A1E"
      style.font-color: "#A0F0A0"
      style.font-size: 11
    }
    phase4: "Phase 4: Expire Timers" {
      style.fill: "#1E3A1E"
      style.font-color: "#A0F0A0"
      style.font-size: 11
    }
    phase1 -> phase2 -> phase3 -> phase4
  }

  per_tick: Per-Tick Processing {
    style.fill: "#1A3020"
    style.font-color: "#80F080"
    style.border-radius: 6
    label: ||md
      **Per epoll_wait tick (~200 events):**
      1. `epoll_wait` returns 200 events
      2. 200 × `http_io_callback` calls
      3. 200 × file `open/stat/read`
      4. 200 × response writes → write_buf
      5. 200 × timer resets (cancel + insert)
    ||
  }

  conn_table: http_conn_t Pool {
    style.fill: "#142814"
    style.font-color: "#90EF90"
    style.border-radius: 6
    active_conns: Active Connections {
      style.fill: "#206820"
      style.font-color: "#80FF80"
      style.stroke: "#4AF080"
      style.multiple: true
      label: "~200 hot conns\n(in L2/L3 cache)"
    }
    idle_conns: Idle Connections {
      style.fill: "#1A2A1A"
      style.font-color: "#606060"
      style.multiple: true
      label: "~9,800 idle conns\n(cold — DRAM)"
    }
  }

  timer_heap: Min-Heap Timer {
    style.fill: "#142814"
    style.font-color: "#90EF90"
    style.border-radius: 6
    label: "10,000 timer entries\n160 KB total\nO(log 10000) ≈ 13 ops"
  }

  page_cache: Kernel Page Cache {
    style.fill: "#0A1A2A"
    style.font-color: "#80A0FF"
    style.border-radius: 6
    label: "index.html (hot)\nserved file data\n(warm after first req)"
  }
}

memory_breakdown: Memory Layout {
  style.fill: "#2A1A0A"
  style.font-color: "#F0B060"
  style.border-radius: 8
  style.stroke: "#F08020"
  style.stroke-width: 2
  near: bottom-left
  layout: ||md
    **Per-Connection Memory**
    | Component | Per-Conn | × 10K |
    |-----------|----------|-------|
    | `http_conn_t` | 26 KB | **260 MB** |
    | `write_buf` data | 64 KB | **640 MB** |
    | `write_buf` struct | 32 B | ~320 KB |
    | `fd_handler_t` | 32 B | ~320 KB |
    | `timer_entry_t` | 48 B | ~480 KB |
    | **Total** | **~90 KB** | **~901 MB** |
    *write_buf: 64KB only allocated per conn,*
    *not all filled simultaneously in practice*
  ||
}

benchmark_results: Expected Benchmark Output {
  style.fill: "#1A0A2A"
  style.font-color: "#C080FF"
  style.border-radius: 8
  style.stroke: "#8040FF"
  style.stroke-width: 2
  near: bottom-right
  results: ||md
    **wrk Results: 12 threads, 10K conns, 60s**
    | Metric | Value | Target |
    |--------|-------|--------|
    | p50 latency | ~1.5 ms | ✓ |
    | p75 latency | ~2.9 ms | ✓ |
    | p90 latency | ~5.2 ms | ✓ |
    | **p99 latency** | **~12 ms** | **< 100ms** |
    | p99.9 latency | ~45 ms | ✓ |
    | Throughput | **~100K req/s** | ✓ |
    | Errors | **0** | ✓ |
    `Requests/sec: 101,234.12`
    `Transfer/sec: 12.43 MB`
  ||
}

tuning: System Tuning Checklist {
  style.fill: "#1A1A0A"
  style.font-color: "#F0F060"
  style.border-radius: 8
  style.stroke: "#A0A020"
  style.stroke-width: 2
  near: top-right
  checklist: ||md
    **Pre-Benchmark System Tuning**
    bash
    ulimit -n 65536
    # /proc/sys/fs/file-max = 65536
    # /proc/sys/net/core/somaxconn = 65536
    # /proc/sys/net/ipv4/tcp_max_syn_backlog = 65536
    # /proc/sys/net/ipv4/ip_local_port_range = 1024 65535
    # /proc/sys/net/ipv4/tcp_tw_reuse = 1
    
    
    **Verify before run:**
    - `ulimit -n` → 65536
    - `ss -s` → sockets available
    - `free -h` → ≥ 2GB RAM free
  ||
}

# Connections
wrk_client -> loopback: "10,000 TCP connections\nHTTP GET /index.html\nKeep-Alive" {
  style.stroke: "#4A9AFF"
  style.stroke-width: 3
  style.animated: true
  style.font-color: "#4A9AFF"
}

loopback -> server.epoll_inst.interest_set.active: "~200 active reads/writes\nper epoll_wait call" {
  style.stroke: "#4AF080"
  style.stroke-width: 2
  style.animated: true
  style.font-color: "#4AF080"
}

server.epoll_inst.interest_set -> server.epoll_inst.readiness_q: "kernel delivers\nreadiness events" {
  style.stroke: "#60DF60"
  style.stroke-dash: 3
}

server.epoll_inst.readiness_q -> server.reactor.phase1: "nready events\nto dispatch loop" {
  style.stroke: "#80FF80"
  style.stroke-width: 2
}

server.reactor.phase1 -> server.conn_table.active_conns: "http_io_callback(fd,\nevents, conn*)" {
  style.stroke: "#A0F0A0"
  style.stroke-dash: 3
}

server.conn_table.active_conns -> server.page_cache: "open() + read()\nfile content" {
  style.stroke: "#80A0FF"
  style.stroke-dash: 3
}

server.reactor.phase4 -> server.timer_heap: "expire idle timers\n(30s deadline)" {
  style.stroke: "#F0B060"
  style.stroke-dash: 5
}

server.conn_table.active_conns -> loopback: "write() response\n→ kernel send buffer\n→ TCP segment" {
  style.stroke: "#4AF080"
  style.stroke-width: 2
  style.animated: true
  style.font-color: "#4AF080"
}

loopback -> wrk_client: "HTTP/1.1 200 OK\nContent-Length: N\n(keep-alive)" {
  style.stroke: "#4A9AFF"
  style.stroke-width: 2
  style.animated: true
  style.font-color: "#4A9AFF"
}