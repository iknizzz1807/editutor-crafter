vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Per-FD Connection Table: Flat Array Indexed by File Descriptor
  `conn_t conn_table[MAX_CONNS=10240]` — O(1) lookup, direct index by fd number
| {near: top-center}
classes: {
  reserved: {
    style: {
      fill: "#9b59b6"
      font-color: white
      stroke: "#6c3483"
      stroke-width: 2
      bold: true
      font-size: 11
    }
  }
  listen_active: {
    style: {
      fill: "#2980b9"
      font-color: white
      stroke: "#1a5276"
      stroke-width: 2
      bold: true
      font-size: 11
    }
  }
  client_active: {
    style: {
      fill: "#1abc9c"
      font-color: white
      stroke: "#148f77"
      stroke-width: 2
      bold: true
      font-size: 11
    }
  }
  client_hot: {
    style: {
      fill: "#e74c3c"
      font-color: white
      stroke: "#922b21"
      stroke-width: 3
      bold: true
      font-size: 11
    }
  }
  free_slot: {
    style: {
      fill: "#ecf0f1"
      font-color: "#7f8c8d"
      stroke: "#bdc3c7"
      stroke-width: 1
      font-size: 11
    }
  }
  ellipsis: {
    style: {
      fill: "#d5dbdb"
      font-color: "#7f8c8d"
      stroke: "#aab7b8"
      stroke-width: 1
      font-size: 13
      bold: true
    }
  }
  epoll_event: {
    style: {
      fill: "#f39c12"
      font-color: white
      stroke: "#b7770d"
      stroke-width: 2
      bold: true
      font-size: 11
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 11
      font-color: "#5d6d7e"
      italic: true
    }
  }
}
array: "conn_t conn_table[10240]" {
  style: {
    fill: "#fdfefe"
    stroke: "#2c3e50"
    stroke-width: 2
    border-radius: 4
  }
  slot0: "fd=0  [RESERVED]\nstdin\nstate=FREE" {
    class: reserved
  }
  slot1: "fd=1  [RESERVED]\nstdout\nstate=FREE" {
    class: reserved
  }
  slot2: "fd=2  [RESERVED]\nstderr\nstate=FREE" {
    class: reserved
  }
  slot3: "fd=3  [RESERVED]\nepfd (epoll)\nstate=FREE" {
    class: reserved
  }
  slot4: "fd=4  [LISTEN]\nlisten_fd :8080\nstate=CONN_ACTIVE\nread_buf[4096]\nread_len=0" {
    class: listen_active
  }
  slot5: "fd=5  [CLIENT]\n192.168.1.10:54321\nstate=CONN_ACTIVE\nread_len=0\ntimer_id=0" {
    class: client_active
  }
  slot6: "fd=6  [CLIENT ← EVENT]\n10.0.0.5:49200\nstate=CONN_ACTIVE\nread_len=1024\ntimer_id=1" {
    class: client_hot
  }
  slot7: "fd=7  [CLIENT]\n172.16.0.3:60001\nstate=CONN_ACTIVE\nread_len=0\ntimer_id=2" {
    class: client_active
  }
  ellipsis_a: "fd 8–127\n...\nstate=CONN_FREE" {
    class: ellipsis
  }
  slot128: "fd=128  [FREE]\nstate=CONN_FREE\n(zero-initialized)" {
    class: free_slot
  }
  ellipsis_b: "fd 129–10238\n...\nstate=CONN_FREE\n(BSS — never faulted)" {
    class: ellipsis
  }
  slot10239: "fd=10239  [FREE]\nstate=CONN_FREE" {
    class: free_slot
  }
}
epoll_event_box: "epoll_wait() returns:\nevents[i].events = EPOLLIN\nevents[i].data.fd = 6" {
  class: epoll_event
}
conn_result: "conn_t *c = &conn_table[6]\nc→state    = CONN_ACTIVE\nc→fd       = 6\nc→read_buf = [1024 bytes]\nc→read_len = 1024\nc→timer_id = 1" {
  style: {
    fill: "#fef9e7"
    stroke: "#e74c3c"
    stroke-width: 2
    border-radius: 4
    font-size: 11
    bold: true
  }
}
lookup_note: |md
  **O(1) Lookup**
  `conn_get(fd)` = `&conn_table[fd]`
  Single array index — no hash, no search
| {
  near: top-center
  style: {
    fill: "#eafaf1"
    stroke: "#1abc9c"
    stroke-width: 1
    border-radius: 4
    font-size: 11
  }
}
cache_note: |md
  **Cache Behavior Warning**
  `sizeof(conn_t) ≈ 4128 bytes = 64.5 cache lines`
  10K connections → 40MB working set
  Sparse access pattern → L3 misses per dispatch
  Each active conn: ~200 cycle DRAM penalty if cold
| {
  near: bottom-center
  style: {
    fill: "#fef5e7"
    stroke: "#f39c12"
    stroke-width: 1
    border-radius: 4
    font-size: 11
  }
}
mem_note: |md
  **Memory Layout**
  BSS segment (zero-init at load time)
  10240 × 4128 = **42 MB total**
  On-demand paging: only active slots
  fault physical pages; idle slots = 0 cost
| {
  style: {
    fill: "#eaf2ff"
    stroke: "#2980b9"
    stroke-width: 1
    border-radius: 4
    font-size: 11
  }
}
epoll_event_box -> array.slot6: "data.fd=6\n→ array index" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 3
    font-color: "#922b21"
    bold: true
    animated: true
  }
  target-arrowhead: {
    shape: arrow
  }
}
array.slot6 -> conn_result: "O(1) deref\n&conn_table[6]" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    font-color: "#922b21"
    stroke-dash: 4
    bold: true
  }
  target-arrowhead: {
    shape: arrow
  }
}
reserved_note: "RESERVED (fd 0–3)\nOS-assigned; never\nregistered with epoll" {
  class: annotation
  near: top-left
}
active_note: "ACTIVE CONNECTIONS\nfd 4: listen socket\nfd 5,6,7: clients\nAll non-blocking (O_NONBLOCK)" {
  class: annotation
}
free_note: "FREE SLOTS (fd 8–10239)\nstate=CONN_FREE (=0)\nzero-initialized by BSS\nOS demand-pages; no RAM cost" {
  class: annotation
}