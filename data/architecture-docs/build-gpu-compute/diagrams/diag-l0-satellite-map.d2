direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  shape: text
  label: "GPU COMPUTE ATLAS"
  style: {
    font-size: 48
    bold: true
    underline: true
    font-color: "#2C3E50"
  }
}
subtitle: {
  near: top-center
  shape: text
  label: "System Map: The Journey from Naive Parallelism to Hardware Mastery"
  style: {
    font-size: 20
    italic: true
    font-color: "#7F8C8D"
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  m1: {
    direction: down
    label: "MILESTONE 1"
    style: {
      fill: "#E8F6F3"
      stroke: "#1ABC9C"
      stroke-width: 3
      border-radius: 12
    }
    m1_title: {
      label: "CUDA Fundamentals\n& Memory"
      style: {
        bold: true
        font-size: 18
        fill: "#16A085"
      }
    }
    m1_anchor: {
      label: "⚓ ANCHOR\nThe GPU is a\nSeparate Computer"
      style: {
        fill: "#D5F5E3"
        stroke: "#27AE60"
        stroke-dash: 4
        border-radius: 8
      }
    }
    m1_skills: {
      shape: sql_table
      label: "Core Skills (m1)"
      s1: "Kernel launch <<< >>>"
      s2: "Thread hierarchy"
      s3: "cudaMalloc / cudaMemcpy"
      s4: "Thread indexing formula"
      s5: "Error handling patterns"
    }
    m1_output: {
      label: "📦 OUTPUT\nVector Operations\nLibrary"
      style: {
        fill: "#A9DFBF"
        border-radius: 6
      }
    }
  }
  m2: {
    direction: down
    label: "MILESTONE 2"
    style: {
      fill: "#FEF9E7"
      stroke: "#F1C40F"
      stroke-width: 3
      border-radius: 12
    }
    m2_title: {
      label: "Memory Optimization\n& Coalescing"
      style: {
        bold: true
        font-size: 18
        fill: "#D4AC0D"
      }
    }
    m2_anchor: {
      label: "⚓ ANCHOR\nTransactions,\nNot Bytes"
      style: {
        fill: "#FCF3CF"
        stroke: "#F4D03F"
        stroke-dash: 4
        border-radius: 8
      }
    }
    m2_skills: {
      shape: sql_table
      label: "Core Skills (m2)"
      s1: "Coalesced access patterns"
      s2: "Shared memory tiling"
      s3: "Bank conflict avoidance"
      s4: "AoS → SoA transformation"
      s5: "Cache line alignment"
    }
    m2_output: {
      label: "📦 OUTPUT\nOptimized Matrix\nTranspose"
      style: {
        fill: "#F9E79F"
        border-radius: 6
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  m3: {
    direction: down
    label: "MILESTONE 3"
    style: {
      fill: "#EBF5FB"
      stroke: "#3498DB"
      stroke-width: 3
      border-radius: 12
    }
    m3_title: {
      label: "Parallel Algorithms"
      style: {
        bold: true
        font-size: 18
        fill: "#2980B9"
      }
    }
    m3_anchor: {
      label: "⚓ ANCHOR\nWork vs Steps:\nThe Parallel Tension"
      style: {
        fill: "#D4E6F1"
        stroke: "#5DADE2"
        stroke-dash: 4
        border-radius: 8
      }
    }
    m3_skills: {
      shape: sql_table
      label: "Core Skills (m3)"
      s1: "Tree-based reduction"
      s2: "Blelloch scan (O(n) work)"
      s3: "Histogram privatization"
      s4: "Warp shuffle intrinsics"
      s5: "Atomic contention patterns"
    }
    m3_output: {
      label: "📦 OUTPUT\nParallel Primitives\nLibrary"
      style: {
        fill: "#AED6F1"
        border-radius: 6
      }
    }
  }
  central: {
    direction: down
    label: "HARDWARE-AWARE\nPARALLELISM"
    style: {
      fill: "#F5EEF8"
      stroke: "#8E44AD"
      stroke-width: 4
      border-radius: 16
      font-size: 22
      bold: true
      font-color: "#6C3483"
    }
    central_desc: {
      label: "The Central Theme\n\nEvery optimization flows from\nunderstanding the hardware:\n\n• Memory hierarchy (latency vs bandwidth)\n• Execution model (SIMT, warps, occupancy)\n• Resource limits (registers, shared mem, SMs)"
      style: {
        fill: "#E8DAEF"
        border-radius: 8
        font-size: 14
      }
    }
    hw_layers: {
      label: "Hardware Layers"
      shape: class
      -registers: "1 cycle | Per-thread"
      -shared_mem: "20-30 cycles | Per-block"
      -l2_cache: "200-300 cycles | Device-wide"
      -global_mem: "400-800 cycles | VRAM"
      -pcie: "10,000+ cycles | Host↔Device"
    }
  }
  m4: {
    direction: down
    label: "MILESTONE 4"
    style: {
      fill: "#FDEDEC"
      stroke: "#E74C3C"
      stroke-width: 3
      border-radius: 12
    }
    m4_title: {
      label: "Streams & Async\nExecution"
      style: {
        bold: true
        font-size: 18
        fill: "#C0392B"
      }
    }
    m4_anchor: {
      label: "⚓ ANCHOR\nThe Default Stream\nSerializes Everything"
      style: {
        fill: "#FADBD8"
        stroke: "#EC7063"
        stroke-dash: 4
        border-radius: 8
      }
    }
    m4_skills: {
      shape: sql_table
      label: "Core Skills (m4)"
      s1: "cudaStreamCreate/Destroy"
      s2: "cudaMemcpyAsync (pinned!)"
      s3: "Compute-transfer overlap"
      s4: "CUDA events for timing"
      s5: "GPU-side synchronization"
    }
    m4_output: {
      label: "📦 OUTPUT\nStreaming Pipeline"
      style: {
        fill: "#F5B7B1"
        border-radius: 6
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  m5: {
    direction: down
    label: "MILESTONE 5"
    style: {
      fill: "#F4ECF7"
      stroke: "#9B59B6"
      stroke-width: 3
      border-radius: 12
    }
    m5_title: {
      label: "Profiling &\nOptimization"
      style: {
        bold: true
        font-size: 18
        fill: "#7D3C98"
      }
    }
    m5_anchor: {
      label: "⚓ ANCHOR\nOptimization Without\nMeasurement is Guessing"
      style: {
        fill: "#E8DAEF"
        stroke: "#AF7AC5"
        stroke-dash: 4
        border-radius: 8
      }
    }
    m5_skills: {
      shape: sql_table
      label: "Core Skills (m5)"
      s1: "Nsight Systems (timeline)"
      s2: "Nsight Compute (counters)"
      s3: "Roofline model analysis"
      s4: "Occupancy calculation"
      s5: "Bottleneck identification"
    }
    m5_output: {
      label: "📦 OUTPUT\nOptimization\nMethodology"
      style: {
        fill: "#D2B4DE"
        border-radius: 6
      }
    }
  }
  legend: {
    direction: down
    label: "LEGEND"
    style: {
      fill: "#F8F9F9"
      stroke: "#BDC3C7"
      border-radius: 8
    }
    legend_items: {
      shape: sql_table
      label: "Map Symbols"
      anchor: "⚓ = Conceptual Anchor\n(The mental model shift)"
      output: "📦 = Deliverable Artifact\n(Reusable code/library)"
      flow: "→ = Knowledge dependency\n(Builds upon previous)"
    }
    learning_path: {
      label: "Learning Journey:\nM1 → M2 → M3 → M4 → M5\n\nEach milestone unlocks\nthe next through its\nanchor concept and\noutput artifact."
      style: {
        fill: "#EAECEE"
        border-radius: 6
        italic: true
      }
    }
  }
}
