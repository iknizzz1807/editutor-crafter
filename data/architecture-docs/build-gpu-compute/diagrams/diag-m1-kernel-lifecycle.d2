direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    host: "#E8F4FD"
    driver: "#FFF3E0"
    gpu: "#E8F5E9"
    async: "#FF6B6B"
    sync: "#4ECDC4"
    time: "#95A5A6"
  }
}
title: |md
  # Kernel Launch to Completion Timeline
  **Asynchronous Execution: Host Returns Immediately**
|
timeline_container: {
  label: ""
  direction: right
  style.fill: transparent
  style.stroke: transparent
  time_axis: {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    t0: {
      label: "t₀"
      shape: circle
      style.fill: ${colors.time}
      width: 40
    }
    t1: {
      label: "t₁"
      shape: circle
      style.fill: ${colors.time}
      width: 40
    }
    t2: {
      label: "t₂"
      shape: circle
      style.fill: ${colors.time}
      width: 40
    }
    t3: {
      label: "t₃"
      shape: circle
      style.fill: ${colors.time}
      width: 40
    }
    t4: {
      label: "t₄"
      shape: circle
      style.fill: ${colors.time}
      width: 40
    }
    t5: {
      label: "t₅"
      shape: circle
      style.fill: ${colors.time}
      width: 40
    }
    t0 -> t1 -> t2 -> t3 -> t4 -> t5: {
      style.stroke: ${colors.time}
      style.stroke-width: 2
    }
  }
  host_column: {
    label: "HOST (CPU)"
    direction: down
    style.fill: ${colors.host}
    style.stroke: "#2196F3"
    style.stroke-width: 2
    h1: {
      label: "kernel<<<grid,block>>>\n(args)"
      width: 180
      code: |'c
        // Triple-angle-bracket syntax
        // Returns IMMEDIATELY
        vectorAdd<<<blocks, threads>>>(
            d_A, d_B, d_C, N);
      '|
      style.fill: ${colors.async}
      style.stroke: "#C0392B"
    }
    h2: {
      label: "CPU continues..."
      width: 180
      code: |'c
        // Host code continues
        // executing immediately
        prepareNextBatch();
        doCpuWork();
      '|
      style.fill: "#BB8FCE"
      style.stroke: "#8E44AD"
    }
    h3: {
      label: "cudaDeviceSynchronize()"
      width: 180
      code: |'c
        // OPTIONAL: Block until
        // GPU work completes
        cudaDeviceSynchronize();
      '|
      style.fill: ${colors.sync}
      style.stroke: "#16A085"
    }
    h1 -> h2 -> h3
  }
  driver_column: {
    label: "CUDA DRIVER"
    direction: down
    style.fill: ${colors.driver}
    style.stroke: "#FF9800"
    style.stroke-width: 2
    d1: {
      label: "Validate params"
      width: 160
      code: |'c
        // Check grid/block dims
        // Verify memory pointers
        // Resource availability
      '|
      style.fill: "#FFE0B2"
    }
    d2: {
      label: "Queue to GPU"
      width: 160
      code: |'c
        // Push to command buffer
        // via PCIe MMIO
        // Non-blocking for host
      '|
      style.fill: "#FFCC80"
    }
    d3: {
      label: "WAITING..."
      width: 160
      style.fill: "#FFF8E1"
      style.stroke-dash: 3
    }
    d4: {
      label: "Completion Signal"
      width: 160
      code: |'c
        // GPU writes status
        // to memory location
        // Driver polls/receives
      '|
      style.fill: "#C8E6C9"
    }
    d1 -> d2 -> d3 -> d4
  }
  gpu_column: {
    label: "GPU DEVICE"
    direction: down
    style.fill: ${colors.gpu}
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    g1: {
      label: "IDLE"
      width: 200
      style.fill: "#FAFAFA"
      style.stroke-dash: 2
    }
    g2: {
      label: "Block Scheduling"
      width: 200
      code: |'c
        // Work distributor assigns
        // blocks to available SMs
        // Block → SM mapping
      '|
      style.fill: "#B2DFDB"
    }
    g3: {
      label: "Warp Execution"
      width: 200
      code: |'c
        // Each SM runs warps
        // Warp schedulers pick
        // ready warps each cycle
      '|
      style.fill: "#81C784"
    }
    g4: {
      label: "Signal Complete"
      width: 200
      code: |'c
        // All blocks done
        // Write completion event
        // Interrupt/poll notify
      '|
      style.fill: "#66BB6A"
    }
    g1 -> g2 -> g3 -> g4
  }
  time_axis -> host_column: {
    style.stroke: transparent
  }
  host_column -> driver_column: {
    style.stroke: transparent
  }
  driver_column -> gpu_column: {
    style.stroke: transparent
  }
}
flow_annotations: {
  direction: down
  label: ""
  style.fill: transparent
  style.stroke: transparent
  async_note: {
    label: "ASYNC HANDOFF"
    width: 400
    code: |'c
      // CRITICAL INSIGHT:
      // <<<>>> launch is NON-BLOCKING
      // Host returns after queuing, NOT after execution
      // This enables CPU-GPU overlap
    '|
    style.fill: "#FFEBEE"
    style.stroke: ${colors.async}
    style.stroke-width: 2
  }
  sync_note: {
    label: "EXPLICIT SYNC REQUIRED"
    width: 400
    code: |'c
      // Host only blocks if YOU call:
      // - cudaDeviceSynchronize()
      // - cudaStreamSynchronize()
      // - cudaMemcpy (implicit sync)
    '|
    style.fill: "#E0F7FA"
    style.stroke: ${colors.sync}
    style.stroke-width: 2
  }
  async_note -> sync_note
}
detail_sm: {
  label: "SM Execution Detail (Per SM)"
  direction: down
  style.fill: "#F5F5F5"
  style.stroke: "#666"
  sm_intro: {
    label: "Warp Scheduler Behavior"
    width: 450
    code: |'c
      // Each SM has multiple warp schedulers
      // Each cycle: pick READY warps to issue
      while (blocks_remaining > 0) {
        for each scheduler:
          warp = select_ready_warp();
          if (warp != NULL) {
            issue_instruction(warp);
          }
      }
    '|
    style.fill: "#E1F5FE"
  }
  warp_states: {
    label: "Warp States"
    shape: class
    READY: "Can execute next instruction"
    STALLED_MEM: "Waiting for memory (400-800 cycles)"
    STALLED_SYNC: "Waiting at __syncthreads()"
    STALLED_DEP: "Waiting for register dependency"
    ACTIVE: "Currently executing"
  }
  sm_intro -> warp_states
}
latency_hiding: {
  label: "Latency Hiding via Warp-Level Parallelism"
  direction: down
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  explanation: {
    label: "How GPU Hides 400+ Cycle Memory Latency"
    width: 500
    code: |'c
      // Key: Many warps per SM (occupancy)
      // When Warp 0 stalls on memory:
      //   → Scheduler instantly switches to Warp 1
      //   → Warp 2, 3, 4... also ready
      // Memory latency is HIDDEN, not eliminated
      // Example timeline on single SM:
      // Cycle   0-100:  Warp 0 executes (load issued)
      // Cycle 100-500:  Warp 0 stalled (memory fetch)
      //                 Warp 1 executes (load issued)
      //                 Warp 2 executes (load issued)
      // Cycle 500+:     Warp 0 data arrives, resumes
    '|
  }
  occupancy_req: {
    label: "Occupancy Requirement"
    width: 500
    code: |'c
      // Minimum warps to hide latency:
      //   warps_needed = latency_cycles / throughput_cycles
      //   
      // Example: 400 cycle latency, 20 cycles useful work
      //   warps_needed = 400 / 20 = 20 warps minimum
      //
      // More warps = better latency hiding (to a point)
    '|
  }
  explanation -> occupancy_req
}
completion_flow: {
  label: "Completion Signaling"
  direction: down
  style.fill: ${colors.gpu}
  signal: {
    label: "How GPU Signals Completion"
    width: 400
    code: |'c
      // 1. All blocks in grid complete
      // 2. GPU writes completion to event/status location
      // 3. Option A: Memory-mapped register (CPU polls)
      // 4. Option B: MSI interrupt (CPU notified)
      // 5. Driver updates stream state
      // 6. cudaStreamSynchronize() returns
    '|
  }
}
legend: {
  label: "Timeline Legend"
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#999"
  async_box: {
    label: "Asynchronous\n(Non-blocking)"
    style.fill: ${colors.async}
  }
  sync_box: {
    label: "Synchronous\n(Blocking)"
    style.fill: ${colors.sync}
  }
  idle_box: {
    label: "Idle/Waiting"
    style.fill: "#FFF8E1"
    style.stroke-dash: 3
  }
  async_box -> sync_box -> idle_box: {
    style.stroke: transparent
  }
}
legend.near: bottom-right