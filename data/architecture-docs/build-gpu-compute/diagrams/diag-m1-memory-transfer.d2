direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Host-Device Memory Transfer Pattern
  **The PCIe Bottleneck: 16 GB/s vs 900+ GB/s**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  host: {
    label: "HOST (CPU)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    h_mem: {
      shape: sql_table
      label: "Host Memory (DRAM)"
      f0: "void* h_data"
      f1: "Allocated via malloc()"
      f2: "Size: 32+ GB typical"
      f3: "Bandwidth: ~100 GB/s"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pcie: {
    label: "PCIe Bus\n(Gen4 x16)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 3
    style.stroke-dash: 4
    pcie_stats: {
      shape: sql_table
      label: "Transfer Characteristics"
      f0: "Theoretical: 32 GB/s"
      f1: "Achievable: 25-28 GB/s"
      f2: "Latency: ~10 μs overhead"
      f3: "BOTTLENECK: 50-100× slower than GPU memory"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  device: {
    label: "DEVICE (GPU)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    d_mem: {
      shape: sql_table
      label: "Device Memory (VRAM)"
      f0: "void* d_data"
      f1: "Allocated via cudaMalloc()"
      f2: "Size: 8-80 GB"
      f3: "Bandwidth: 900-2000 GB/s"
    }
    kernel: {
      label: "Kernel Execution"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      code: |'c
        __global__ void myKernel(float* d_data, int N) {
          int idx = blockIdx.x * blockDim.x + threadIdx.x;
          if (idx < N) {
            d_data[idx] = process(d_data[idx]);
          }
        }
      '|
      width: 320
    }
  }
}
lifecycle: {
  label: "CUDA Memory Lifecycle"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  step1: {
    label: "1. cudaMalloc(&d_ptr, bytes)"
    code: |'c
      float* d_data;
      size_t bytes = N * sizeof(float);
      cudaMalloc(&d_data, bytes);  // Allocate on GPU
    '|
    width: 300
  }
  step2: {
    label: "2. cudaMemcpy(d, h, bytes, H2D)"
    code: |'c
      cudaMemcpy(d_data, h_data, bytes,
                 cudaMemcpyHostToDevice);
    '|
    width: 300
  }
  step3: {
    label: "3. kernel<<<grid, block>>>(d_data, N)"
    code: |'c
      myKernel<<<blocks, threads>>>(d_data, N);
      cudaDeviceSynchronize();  // Wait for completion
    '|
    width: 300
  }
  step4: {
    label: "4. cudaMemcpy(h, d, bytes, D2H)"
    code: |'c
      cudaMemcpy(h_result, d_data, bytes,
                 cudaMemcpyDeviceToHost);
    '|
    width: 300
  }
  step5: {
    label: "5. cudaFree(d_ptr)"
    code: |'c
      cudaFree(d_data);  // Release GPU memory
    '|
    width: 300
  }
  step1 -> step2: "GPU buffer ready"
  step2 -> step3: "Data on device"
  step3 -> step4: "Computation done"
  step4 -> step5: "Results retrieved"
}
host.h_mem -> pcie.pcie_stats: "cudaMemcpy\nH2D" {
  style.stroke: "#FF5722"
  style.stroke-width: 3
  style.animated: true
}
pcie.pcie_stats -> device.d_mem: "DMA Transfer\n~25 GB/s" {
  style.stroke: "#FF5722"
  style.stroke-width: 3
}
device.d_mem -> device.kernel: "Data ready\n900+ GB/s" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
device.kernel -> device.d_mem: "Write results" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.stroke-dash: 3
}
device.d_mem -> pcie.pcie_stats: "cudaMemcpy\nD2H" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.animated: true
}
pcie.pcie_stats -> host.h_mem: "DMA Transfer\n~25 GB/s" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
}
legend: {
  near: bottom-right
  label: "Transfer Directions"
  h2d: "H2D: Host → Device (input data)" {
    style.fill: "#FFEBE9"
    style.stroke: "#FF5722"
  }
  d2h: "D2H: Device → Host (results)" {
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  gpu_internal: "GPU Internal: 900+ GB/s" {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  bottleneck: "PCIe: 50-100× slower!" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-dash: 4
  }
}
performance_note: {
  near: bottom-center
  label: "Performance Implication"
  code: |md
    **Minimize PCIe transfers:**
    - Keep data on GPU across multiple kernels
    - Use pinned memory (cudaMallocHost) for faster transfers
    - Overlap compute with transfer using streams
    - Batch small transfers into larger ones
  |
  width: 400
  style.fill: "#FFFDE7"
  style.stroke: "#FFC107"
}