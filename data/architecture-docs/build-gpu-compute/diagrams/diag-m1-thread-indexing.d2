direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Computing Global Thread Index
  `idx = blockIdx.x * blockDim.x + threadIdx.x`
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  formula_box: {
    label: "Index Formula"
    width: 420
    formula: |md
      c
      // Global thread index computation
      int idx = blockIdx.x * blockDim.x + threadIdx.x;
      // Where:
      //   blockIdx.x  = block index within grid (0, 1, 2, ...)
      //   blockDim.x  = number of threads per block
      //   threadIdx.x = thread index within block (0..blockDim.x-1)
      
    |
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  visual_breakdown: {
    direction: down
    label: "Visual Breakdown: Grid with 4 Blocks × 8 Threads"
    grid_visual: {
      direction: down
      width: 600
      blocks_row: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        block0: {
          label: "Block 0\n(blockIdx.x = 0)"
          style.fill: "#E8F4FD"
          style.stroke: "#2196F3"
          threads_label: |md
            **Threads: 0-7**
            threadIdx.x: 0,1,2,3,4,5,6,7
            idx = 0×8 + threadIdx.x
          |
        }
        block1: {
          label: "Block 1\n(blockIdx.x = 1)"
          style.fill: "#FFF3E0"
          style.stroke: "#FF9800"
          threads_label: |md
            **Threads: 8-15**
            threadIdx.x: 0,1,2,3,4,5,6,7
            idx = 1×8 + threadIdx.x
          |
        }
        block2: {
          label: "Block 2\n(blockIdx.x = 2)"
          style.fill: "#E8F5E9"
          style.stroke: "#4CAF50"
          threads_label: |md
            **Threads: 16-23**
            threadIdx.x: 0,1,2,3,4,5,6,7
            idx = 2×8 + threadIdx.x
          |
        }
        block3: {
          label: "Block 3\n(blockIdx.x = 3)"
          style.fill: "#FCE4EC"
          style.stroke: "#E91E63"
          threads_label: |md
            **Threads: 24-31**
            threadIdx.x: 0,1,2,3,4,5,6,7
            idx = 3×8 + threadIdx.x
          |
        }
      }
      data_array: {
        label: "Data Array (32 elements)"
        shape: sql_table
        width: 580
        row0: "data[0]  | data[8]  | data[16] | data[24]"
        row1: "data[1]  | data[9]  | data[17] | data[25]"
        row2: "data[2]  | data[10] | data[18] | data[26]"
        row3: "data[3]  | data[11] | data[19] | data[27]"
        row4: "data[4]  | data[12] | data[20] | data[28]"
        row5: "data[5]  | data[13] | data[21] | data[29]"
        row6: "data[6]  | data[14] | data[22] | data[30]"
        row7: "data[7]  | data[15] | data[23] | data[31]"
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  indexing_modes: {
    direction: down
    label: "Indexing Modes"
    mode_1d: {
      label: "1D Indexing (Most Common)"
      width: 380
      code_1d: |'c
        // Single dimension
        int idx = blockIdx.x * blockDim.x + threadIdx.x;
        if (idx < N) {
            output[idx] = input[idx] * 2.0f;
        }
      '|
    }
    mode_2d: {
      label: "2D Indexing (Matrices/Images)"
      width: 380
      code_2d: |'c
        // Two dimensions
        int row = blockIdx.y * blockDim.y + threadIdx.y;
        int col = blockIdx.x * blockDim.x + threadIdx.x;
        // Linear index (row-major)
        int idx = row * width + col;
        if (row < height && col < width) {
            out[idx] = in[idx];
        }
      '|
    }
    mode_3d: {
      label: "3D Indexing (Volumes)"
      width: 380
      code_3d: |'c
        // Three dimensions
        int z = blockIdx.z * blockDim.z + threadIdx.z;
        int y = blockIdx.y * blockDim.y + threadIdx.y;
        int x = blockIdx.x * blockDim.x + threadIdx.x;
        // Linear index
        int idx = z * width * height + y * width + x;
        if (x < W && y < H && z < D) {
            out[idx] = in[idx];
        }
      '|
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  example_calc: {
    direction: down
    label: "Worked Example: N=1000 elements, blockDim.x=256"
    width: 600
    calc_table: {
      shape: sql_table
      label: "Thread Index Mapping"
      row0: "Block | Thread in Block | Formula | Global Index"
      row1: "0 | 0 | 0 × 256 + 0 | 0"
      row2: "0 | 255 | 0 × 256 + 255 | 255"
      row3: "1 | 0 | 1 × 256 + 0 | 256"
      row4: "1 | 255 | 1 × 256 + 255 | 511"
      row5: "2 | 0 | 2 × 256 + 0 | 512"
      row6: "3 | 231 | 3 × 256 + 231 | 999"
      row7: "3 | 232-255 | (exceeds N) | SKIPPED by bounds check"
    }
    launch_config: |'c
      // Host-side launch configuration
      int threadsPerBlock = 256;
      int blocksPerGrid = (N + threadsPerBlock - 1) / threadsPerBlock;  // = 4
      kernel<<<blocksPerGrid, threadsPerBlock>>>(d_data, N);
    '|
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bounds_check: {
    label: "Critical: Bounds Check"
    width: 580
    explanation: |md
      **Why bounds check is essential:**
      Grid size is rounded UP to cover all elements.
      If N=1000 and blockDim=256, we launch 1024 threads.
      Threads 1000-1023 would access invalid memory without this guard.
    |
    code: |'c
      __global__ void safeKernel(float* data, int N) {
          int idx = blockIdx.x * blockDim.x + threadIdx.x;
          // ALWAYS check bounds for non-power-of-2 sizes!
          if (idx < N) {
              data[idx] = process(data[idx]);
          }
      }
    '|
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dim3_box: {
    label: "dim3 Type for Multi-Dimensional Launches"
    width: 580
    code: |'c
      // 2D grid and block dimensions
      dim3 blockDim(16, 16);  // 16×16 = 256 threads per block
      dim3 gridDim((width + 15) / 16, (height + 15) / 16);
      kernel2D<<<gridDim, blockDim>>>(d_data, width, height);
      // Inside kernel:
      // threadIdx.x, threadIdx.y  → position in block (0-15 each)
      // blockIdx.x, blockIdx.y    → block position in grid
      // blockDim.x, blockDim.y    → block dimensions (16 each)
      // gridDim.x, gridDim.y      → grid dimensions
    '|
  }
}
legend: {
  near: bottom-center
  label: "Built-in Variables"
  var_table: {
    shape: sql_table
    v0: "Variable | Type | Description | Range"
    v1: "threadIdx | uint3 | Thread index within block | 0 to blockDim-1"
    v2: "blockIdx | uint3 | Block index within grid | 0 to gridDim-1"
    v3: "blockDim | uint3 | Threads per block (from launch config)"
    v4: "gridDim | uint3 | Blocks in grid (from launch config)"
  }
}