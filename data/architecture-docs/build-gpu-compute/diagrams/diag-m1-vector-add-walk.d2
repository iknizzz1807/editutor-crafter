direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Vector Addition: Coalesced Data Walk" {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# --- ROW 1: EXECUTION CONTEXT ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  threads: {
    direction: down
    label: "Warp Threads (0-31)"
    t0: "Thread 0" {
      shape: circle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    t1: "Thread 1" {
      shape: circle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    t2: "Thread 2" {
      shape: circle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    t3: "Thread 3" {
      shape: circle
      style.fill: "#FCE4EC"
      style.stroke: "#E91E63"
    }
  }

  kernel_logic: {
    label: "Kernel Logic (vector_add.cu)"
    width: 400
    code: |'c
      // Parallel Index Calculation
      int i = blockIdx.x * blockDim.x + threadIdx.x;
      
      if (i < n) {
          C[i] = A[i] + B[i];
      }
    '|
  }
}

# --- ROW 2: MEMORY LAYOUT ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  array_a: {
    shape: sql_table
    label: "float* A (Global Memory)"
    row0: "0x00 | 1.0f | A[0]"
    row1: "0x04 | 2.0f | A[1]"
    row2: "0x08 | 3.0f | A[2]"
    row3: "0x0C | 4.0f | A[3]"
    style.fill: "#E8F5E9"
  }

  array_b: {
    shape: sql_table
    label: "float* B (Global Memory)"
    row0: "0x00 | 10.0f | B[0]"
    row1: "0x04 | 20.0f | B[1]"
    row2: "0x08 | 30.0f | B[2]"
    row3: "0x0C | 40.0f | B[3]"
    style.fill: "#E3F2FD"
  }

  array_c: {
    shape: sql_table
    label: "float* C (Global Memory)"
    row0: "0x00 | 11.0f | C[0]"
    row1: "0x04 | 22.0f | C[1]"
    row2: "0x08 | 33.0f | C[2]"
    row3: "0x0C | 44.0f | C[3]"
    style.fill: "#FFF3E0"
  }

  mem_ctrl: {
    label: "Memory Transaction"
    direction: down
    cache_line: "L2 Cache Line" {
      label: "128-Byte Transaction"
      shape: rectangle
      style: {
        stroke-dash: 5
        fill: "#F5F5F5"
      }
      note: "Coalesced: A[0..31]"
    }
  }
}

# --- ROW 3: TECHNICAL EXPLANATION ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  explanation: {
    label: "Coalescing Analysis"
    width: 800
    content: |'md
      ## Memory Efficiency Breakdown
      - **Request:** Warp (32 threads) requests 4-byte floats at contiguous addresses.
      - **Detection:** Hardware coalescer identifies that all addresses fall within the same 128-byte segment.
      - **Execution:** A single **128-byte memory transaction** is dispatched to DRAM.
      - **Efficiency:** 100% (All fetched bytes are utilized by threads).
      
      **Avoid Strided Access:**
      Using `A[idx * 32]` would result in 32 separate 128-byte fetches, wasting 97% of bandwidth.
    '|
  }
}

# --- ROW 4: TIMING & PERFORMANCE ---
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  perf_table: {
    label: "Execution Timeline"
    width: 800
    table: |'md
      | Step | Operation | Scope | Est. Latency |
      | :--- | :--- | :--- | :--- |
      | 1 | Load A | 128B Transaction | 400 - 800 cycles |
      | 2 | Load B | 128B Transaction | 400 - 800 cycles |
      | 3 | compute | FP32 Add (SIMD) | 4 - 20 cycles |
      | 4 | Store C | 128B Transaction | 400 - 800 cycles |
    '|
  }
}

# --- CONNECTIONS ---

# Reads from A
row1.threads.t0 -> row2.array_a.row0: "A[0] | read" { style.stroke: "#4CAF50" }
row1.threads.t1 -> row2.array_a.row1: "A[1] | read" { style.stroke: "#2196F3" }
row1.threads.t2 -> row2.array_a.row2: "A[2] | read" { style.stroke: "#FF9800" }
row1.threads.t3 -> row2.array_a.row3: "A[3] | read" { style.stroke: "#E91E63" }

# Reads from B
row1.threads.t0 -> row2.array_b.row0: "B[0] | read" { style.stroke: "#4CAF50"; style.stroke-dash: 3 }
row1.threads.t1 -> row2.array_b.row1: "B[1] | read" { style.stroke: "#2196F3"; style.stroke-dash: 3 }

# Writes to C
row1.threads.t0 -> row2.array_c.row0: "C[0] | write" { 
  style.stroke: "#4CAF50"
  style.animated: true 
}
row1.threads.t1 -> row2.array_c.row1: "C[1] | write" { 
  style.stroke: "#2196F3"
  style.animated: true 
}

# Grouping for Transaction
row2.array_a -> row2.mem_ctrl.cache_line: "Consolidated" {
  style.stroke-width: 4
  style.stroke: "#9E9E9E"
}

# Flow Indicator
row1 -> row2: "Data Dependency"
row2 -> row3: "Analysis"
row3 -> row4: "Metrics"