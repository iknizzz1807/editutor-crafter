direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Bandwidth: Naive vs Optimized Transpose
| {near: top-center}
subtitle: |md
  RTX 3080 Theoretical Peak: **760 GB/s**
| {near: top-center}
comparison_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  naive: {
    direction: down
    label: "Naive Transpose"
    bar_naive: {
      shape: rectangle
      width: 80
      height: 20
      style.fill: "#E53935"
      style.stroke: "#B71C1C"
      style.stroke-width: 2
    }
    stats_naive: {
      shape: sql_table
      label: "Performance Metrics"
      bandwidth: "Bandwidth | 2 GB/s"
      efficiency: "Efficiency | 0.3%"
      bottleneck: "Bottleneck | Non-coalesced writes"
    }
    code_naive: {
      label: "Kernel Pattern"
      width: 280
      code: |'cuda
        // Strided write pattern
        output[col * height + row] = 
            input[row * width + col];
        // Adjacent threads write to
        // different cache lines!
      '|
    }
  }
  shared: {
    direction: down
    label: "Shared Memory"
    bar_shared: {
      shape: rectangle
      width: 80
      height: 400
      style.fill: "#FB8C00"
      style.stroke: "#EF6C00"
      style.stroke-width: 2
    }
    stats_shared: {
      shape: sql_table
      label: "Performance Metrics"
      bandwidth: "Bandwidth | 80 GB/s"
      efficiency: "Efficiency | 10.5%"
      bottleneck: "Bottleneck | Bank conflicts"
    }
    code_shared: {
      label: "Kernel Pattern"
      width: 280
      code: |'cuda
        // Load coalesced, store via tile
        __shared__ float tile[32][32];
        tile[ty][tx] = input[row*w + col];
        __syncthreads();
        output[col*h + row] = tile[tx][ty];
        // But column access = bank conflicts!
      '|
    }
  }
  optimized: {
    direction: down
    label: "Shared + Padding"
    bar_optimized: {
      shape: rectangle
      width: 80
      height: 600
      style.fill: "#43A047"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
    stats_optimized: {
      shape: sql_table
      label: "Performance Metrics"
      bandwidth: "Bandwidth | 120 GB/s"
      efficiency: "Efficiency | 15.8%"
      bottleneck: "Bottleneck | None (optimal)"
    }
    code_optimized: {
      label: "Kernel Pattern"
      width: 280
      code: |'cuda
        // Padding breaks bank conflicts
        __shared__ float tile[32][32+1];
        tile[ty][tx] = input[row*w + col];
        __syncthreads();
        output[col*h + row] = tile[tx][ty];
        // +1 offset = each row different bank
      '|
    }
  }
}
peak_line: {
  shape: rectangle
  width: 400
  height: 4
  style.fill: "#1565C0"
  style.stroke: "#0D47A1"
  label: "Theoretical Peak: 760 GB/s"
}
legend: {
  near: bottom-center
  direction: right
  style.stroke: transparent
  style.fill: transparent
  red_box: {
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#E53935"
  }
  red_label: "0.3% efficiency"
  orange_box: {
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#FB8C00"
  }
  orange_label: "10.5% efficiency"
  green_box: {
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#43A047"
  }
  green_label: "15.8% efficiency"
}
naive -> shared: "40x faster" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
shared -> optimized: "1.5x faster" {
  style.stroke: "#666"
  style.stroke-dash: 3
}