direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "Memory Access Patterns: GPU Coalescing Impact"
  style.font-size: 24
  style.bold: true
  style.stroke: transparent
  style.fill: transparent
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  coalesced: {
    direction: down
    label: "Pattern 1: Coalesced Access (Optimal)"
    
    threads_c: {
      direction: right
      label: "Warp Threads (T0-T31)"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      t0_c: "T0" { shape: circle; style.fill: "#81C784" }
      t1_c: "T1" { shape: circle; style.fill: "#81C784" }
      t2_c: "T2" { shape: circle; style.fill: "#81C784" }
      dots_c: { label: "···"; shape: text; style.font-size: 20 }
      t31_c: "T31" { shape: circle; style.fill: "#81C784" }
    }

    memory_c: {
      direction: right
      label: "Global Memory (128-byte cache line)"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      m0: { label: "[0]"; style.fill: "#66BB6A"; style.font-color: white }
      m1: { label: "[1]"; style.fill: "#66BB6A"; style.font-color: white }
      m2: { label: "[2]"; style.fill: "#66BB6A"; style.font-color: white }
      dots_m: { label: "···"; shape: text; style.font-size: 20 }
      m31: { label: "[31]"; style.fill: "#66BB6A"; style.font-color: white }
    }

    result_c: {
      label: "Result: 1 Transaction"
      shape: rectangle
      style.fill: "#43A047"
      style.font-color: white
      style.bold: true
      width: 200
    }

    code_c: {
      label: "Kernel Implementation"
      code: |'c
        // Adjacent threads access adjacent memory
        int idx = blockIdx.x * blockDim.x + threadIdx.x;
        float val = data[idx];  // T0->[0], T1->[1], ...
      '|
      width: 320
    }

    threads_c.t0_c -> memory_c.m0
    threads_c.t1_c -> memory_c.m1
    threads_c.t2_c -> memory_c.m2
    threads_c.t31_c -> memory_c.m31
    
    threads_c -> result_c: "32 threads | 1 line" {
      style.stroke: "#4CAF50"
      style.stroke-width: 3
    }
  }

  spacer1: {
    width: 50
    style.stroke: transparent
    style.fill: transparent
  }

  strided: {
    direction: down
    label: "Pattern 2: Strided Access (Non-Optimal)"
    
    threads_s: {
      direction: right
      label: "Warp Threads (T0-T31)"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      t0_s: "T0" { shape: circle; style.fill: "#FFB74D" }
      t1_s: "T1" { shape: circle; style.fill: "#FFB74D" }
      t2_s: "T2" { shape: circle; style.fill: "#FFB74D" }
      dots_s: { label: "···"; shape: text; style.font-size: 20 }
      t31_s: "T31" { shape: circle; style.fill: "#FFB74D" }
    }

    memory_s: {
      direction: down
      label: "Global Memory (Scattered Cache Lines)"
      style.fill: "#FFE0B2"
      style.stroke: "#FF9800"
      
      row0: {
        direction: right
        style.fill: transparent
        m0_s: { label: "[0]"; style.fill: "#F57C00"; style.font-color: white }
        empty0: { label: "··· (31 floats gap)"; shape: text; style.font-color: "#8D6E63" }
      }
      row1: {
        direction: right
        style.fill: transparent
        m32_s: { label: "[32]"; style.fill: "#F57C00"; style.font-color: white }
        empty1: { label: "··· (31 floats gap)"; shape: text; style.font-color: "#8D6E63" }
      }
      dots_row: { label: "···"; shape: text; style.font-size: 20 }
      row31: {
        direction: right
        style.fill: transparent
        m992_s: { label: "[992]"; style.fill: "#F57C00"; style.font-color: white }
        empty31: { label: "··· (end)"; shape: text; style.font-color: "#8D6E63" }
      }
    }

    result_s: {
      label: "Result: 32 Transactions"
      shape: rectangle
      style.fill: "#EF6C00"
      style.font-color: white
      style.bold: true
      width: 200
    }

    code_s: {
      label: "Kernel Implementation"
      code: |'c
        // Access with stride=32 floats (128 bytes)
        int idx = blockIdx.x * blockDim.x + threadIdx.x;
        float val = data[idx * 32]; 
        // T0->[0], T1->[32], T2->[64]...
      '|
      width: 320
    }

    threads_s.t0_s -> memory_s.row0.m0_s
    threads_s.t1_s -> memory_s.row1.m32_s
    threads_s.t31_s -> memory_s.row31.m992_s
    
    threads_s -> result_s: "32 threads | 32 lines" {
      style.stroke: "#FF9800"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  random: {
    direction: down
    label: "Pattern 3: Random/Indirect Access"
    
    threads_r: {
      direction: right
      label: "Warp Threads (T0-T31)"
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      t0_r: "T0" { shape: circle; style.fill: "#EF5350" }
      t1_r: "T1" { shape: circle; style.fill: "#EF5350" }
      t2_r: "T2" { shape: circle; style.fill: "#EF5350" }
      dots_r: { label: "···"; shape: text; style.font-size: 20 }
      t31_r: "T31" { shape: circle; style.fill: "#EF5350" }
    }

    memory_r: {
      direction: down
      label: "Global Memory (Random Segments)"
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      
      r0: {
        direction: right
        style.fill: transparent
        addr0: { label: "[47]"; style.fill: "#D32F2F"; style.font-color: white }
        empty_r0: { label: "···"; shape: text }
      }
      r1: {
        direction: right
        style.fill: transparent
        addr1: { label: "[891]"; style.fill: "#D32F2F"; style.font-color: white }
        empty_r1: { label: "···"; shape: text }
      }
      dots_r2: { label: "···"; shape: text; style.font-size: 20 }
      r31: {
        direction: right
        style.fill: transparent
        addr31: { label: "[1024]"; style.fill: "#D32F2F"; style.font-color: white }
        empty_r31: { label: "···"; shape: text }
      }
    }

    result_r: {
      label: "Result: 32 Transactions"
      shape: rectangle
      style.fill: "#C62828"
      style.font-color: white
      style.bold: true
      width: 220
    }

    code_r: {
      label: "Kernel Implementation"
      code: |'c
        // Gather operation via lookup table
        int ptr = random_indices[threadIdx.x];
        float val = data[ptr];
        // T0->[47], T1->[891], T2->[23]...
      '|
      width: 320
    }

    threads_r.t0_r -> memory_r.r0.addr0
    threads_r.t1_r -> memory_r.r1.addr1
    threads_r.t31_r -> memory_r.r31.addr31
    
    threads_r -> result_r: "Random Scatter" {
      style.stroke: "#F44336"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
  }

  spacer2: {
    width: 50
    style.stroke: transparent
    style.fill: transparent
  }

  metrics: {
    direction: down
    label: "Performance Metrics (Theoretical)"
    
    bw_table: {
      shape: sql_table
      label: "Pattern Efficiency (NVIDIA A100 Class)"
      col1: "Pattern | Transactions | Bus Utilization | Efficiency"
      row1: "Coalesced | 1 | 100% | 1.0x (Peak)"
      row2: "Strided-32 | 32 | 3.1% | 0.03x"
      row3: "Random | 32 | 3.1% | 0.03x"
      foot: "Note: Stride > 1 causes severe divergence in memory controller."
    }

    insight: {
      label: "Key Architectural Rule"
      shape: callout
      style.fill: "#BBDEFB"
      width: 320
      content: |md
        **Memory Coalescing** allows the GPU to merge multiple memory requests from a single warp into a single transaction. 
        
        If threads in a warp access a contiguous 128-byte block, the hardware performs **one fetch**. If they are strided, the hardware performs **32 separate fetches**, wasting 97% of the fetched data.
      |
    }
  }
}

legend: {
  near: bottom-right
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  
  l1: {
    shape: circle
    style.fill: "#4CAF50"
    label: ""
  }
  t1: "Optimal Flow"
  
  l2: {
    shape: circle
    style.fill: "#FF9800"
    label: ""
  }
  t2: "Bandwidth Waste"
}