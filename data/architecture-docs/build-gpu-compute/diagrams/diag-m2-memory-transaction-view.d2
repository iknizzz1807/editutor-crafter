direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # GPU Memory Transaction Granularity
  ## How the Memory Controller Views Your Requests
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cache_line: {
    direction: down
    label: "L2 Cache Line (128 bytes)"
    cache_header: {
      shape: rectangle
      label: "Cache Line Header"
      width: 600
      style.fill: "#E8E8E8"
    }
    cache_data: {
      direction: right
      style.stroke: transparent
      byte0: {
        label: "Bytes 0-3"
        shape: rectangle
        width: 140
        style.fill: "#90EE90"
      }
      byte4: {
        label: "Bytes 4-7"
        shape: rectangle
        width: 140
        style.fill: "#90EE90"
      }
      byte8: {
        label: "Bytes 8-11"
        shape: rectangle
        width: 140
        style.fill: "#90EE90"
      }
      byte12: {
        label: "Bytes 12-15"
        shape: rectangle
        width: 140
        style.fill: "#90EE90"
      }
    }
    cache_data2: {
      direction: right
      style.stroke: transparent
      byte16: {
        label: "Bytes 16-19"
        shape: rectangle
        width: 140
        style.fill: "#87CEEB"
      }
      byte20: {
        label: "Bytes 20-23"
        shape: rectangle
        width: 140
        style.fill: "#87CEEB"
      }
      byte24: {
        label: "Bytes 24-27"
        shape: rectangle
        width: 140
        style.fill: "#87CEEB"
      }
      byte28: {
        label: "Bytes 28-31"
        shape: rectangle
        width: 140
        style.fill: "#87CEEB"
      }
    }
    ellipsis: {
      label: "... (96 more bytes)"
      shape: text
      style.font-size: 14
    }
    cache_footer: {
      shape: rectangle
      label: "Total: 128 bytes per cache line"
      width: 600
      style.fill: "#E8E8E8"
    }
  }
  mem_transaction: {
    direction: down
    label: "Memory Transaction (32 bytes)"
    mem_header: {
      shape: rectangle
      label: "DRAM Transaction Unit"
      width: 600
      style.fill: "#E8E8E8"
    }
    mem_data: {
      direction: right
      style.stroke: transparent
      sector0: {
        label: "Sector 0\n(32B)"
        shape: rectangle
        width: 145
        style.fill: "#FFD700"
      }
      sector1: {
        label: "Sector 1\n(32B)"
        shape: rectangle
        width: 145
        style.fill: "#FFD700"
      }
      sector2: {
        label: "Sector 2\n(32B)"
        shape: rectangle
        width: 145
        style.fill: "#FFD700"
      }
      sector3: {
        label: "Sector 3\n(32B)"
        shape: rectangle
        width: 145
        style.fill: "#FFD700"
      }
    }
    mem_footer: {
      shape: rectangle
      label: "4 sectors × 32 bytes = 128 bytes (1 cache line)"
      width: 600
      style.fill: "#E8E8E8"
    }
  }
}
row1_cache_line_cache_data -> row1_mem_transaction_mem_data: "maps to" {
  style.stroke-dash: 3
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  warp_view: {
    direction: down
    label: "Warp Memory Request View"
    warp_header: {
      shape: class
      label: "Warp (32 threads) (hardware.h)"
      -threads: "32 threads"
      -request_size: "4 bytes × 32 = 128 bytes (ideal)"
      -coalesced: "bool coalesced"
      +issue_request(): "void"
    }
    coalesced_example: {
      label: "Coalesced Access Pattern"
      width: 350
      code: |'c
        // Thread i reads data[i]
        int idx = blockIdx.x * blockDim.x 
                + threadIdx.x;
        float val = data[idx];
        // All 32 threads read consecutive
        // addresses → 1 cache line fetched
      '|
    }
    coalesced_result: {
      shape: rectangle
      label: "Result: 1 transaction, 100% bandwidth"
      width: 350
      style.fill: "#90EE90"
    }
  }
  strided_view: {
    direction: down
    label: "Strided Access Pattern"
    strided_example: {
      label: "Strided Access (BAD)"
      width: 350
      code: |'c
        // Thread i reads data[i * 32]
        int idx = blockIdx.x * blockDim.x 
                + threadIdx.x;
        float val = data[idx * 32];
        // Each thread hits different
        // cache line → 32 transactions!
      '|
    }
    strided_result: {
      shape: rectangle
      label: "Result: 32 transactions, 3.1% bandwidth"
      width: 350
      style.fill: "#FF6B6B"
    }
    strided_cost: {
      shape: sql_table
      label: "Cost Analysis (stride_access.c)"
      f0: "0x00 | int | threads_requested"
      f1: "0x04 | int | cache_lines_fetched"
      f2: "0x08 | int | bytes_used"
      f3: "0x0C | int | bytes_wasted"
      sz: "Total: 16 bytes"
    }
  }
  random_view: {
    direction: down
    label: "Random Access Pattern"
    random_example: {
      label: "Random Access (WORST)"
      width: 350
      code: |'c
        // Thread i reads random index
        int idx = indices[threadIdx.x];
        float val = data[idx];
        // No coalescing possible
        // Up to 32 cache lines fetched
      '|
    }
    random_result: {
      shape: rectangle
      label: "Result: Up to 32 transactions, ~3% bandwidth"
      width: 350
      style.fill: "#FF6B6B"
    }
  }
}
row2_warp_view_coalesced_result -> row2_strided_view_strided_result: "vs" {
  style.stroke: red
  style.stroke-dash: 4
}
row2_strided_view_strided_result -> row2_random_view_random_result: "vs" {
  style.stroke: red
  style.stroke-dash: 4
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  alignment_view: {
    direction: down
    label: "Memory Alignment Impact"
    aligned: {
      direction: right
      label: "Aligned Access"
      aligned_mem: {
        shape: sql_table
        label: "Aligned (address % 128 == 0)"
        f0: "0x00-0x1F | float[0-7] | Thread 0-7"
        f1: "0x20-0x3F | float[8-15] | Thread 8-15"
        f2: "0x40-0x5F | float[16-23] | Thread 16-23"
        f3: "0x60-0x7F | float[24-31] | Thread 24-31"
        sz: "1 cache line (128B)"
      }
      aligned_result: {
        shape: rectangle
        label: "1 transaction\n100% efficiency"
        width: 120
        style.fill: "#90EE90"
      }
    }
    misaligned: {
      direction: right
      label: "Misaligned Access"
      misaligned_mem: {
        shape: sql_table
        label: "Misaligned (address % 128 == 4)"
        f0: "0x04-0x1F | float[0-6] | Thread 0-6"
        f1: "0x20-0x3F | float[7-14] | Thread 7-14"
        f2: "0x40-0x5F | float[15-22] | Thread 15-22"
        f3: "0x60-0x7F | float[23-30] | Thread 23-30"
        f4: "0x80-0x83 | float[31] | Thread 31"
        sz: "2 cache lines (256B)"
      }
      misaligned_result: {
        shape: rectangle
        label: "2 transactions\n50% efficiency"
        width: 120
        style.fill: "#FFD700"
      }
    }
  }
}
row3_alignment_view_aligned_aligned_result -> row3_alignment_view_misaligned_misaligned_result: "misalignment cost" {
  style.stroke: orange
  style.stroke-dash: 4
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bandwidth_math: {
    direction: down
    label: "Bandwidth Efficiency Math"
    formula: {
      shape: class
      label: "Efficiency Calculator (bandwidth.h)"
      -peak_bandwidth: "float // GB/s"
      -cache_line_size: "int // 128 bytes"
      +calc_efficiency(bytes_used, bytes_fetched): "float"
      +calc_effective_bw(peak, efficiency): "float"
    }
    example_calc: {
      label: "Example Calculations"
      width: 400
      code: |'c
        // Coalesced: 32 threads × 4B = 128B used
        //            1 cache line = 128B fetched
        efficiency = 128 / 128 = 100%
        // Strided: 32 threads × 4B = 128B used
        //          32 cache lines = 4096B fetched
        efficiency = 128 / 4096 = 3.125%
        // RTX 3080 @ 760 GB/s peak:
        // Coalesced: 760 × 1.00 = 760 GB/s
        // Strided:   760 × 0.03 = 24 GB/s
      '|
    }
  }
  hardware_limits: {
    direction: down
    label: "Hardware Transaction Limits"
    limits_table: {
      shape: sql_table
      label: "Memory Transaction Specs (gpu_spec.h)"
      f0: "0x00 | int | CACHE_LINE_SIZE = 128"
      f1: "0x04 | int | SECTOR_SIZE = 32"
      f2: "0x08 | int | SECTORS_PER_LINE = 4"
      f3: "0x0C | int | WARP_SIZE = 32"
      f4: "0x10 | int | MAX_TX_PER_WARP = 32"
      sz: "Total: 20 bytes"
    }
    implication: {
      shape: rectangle
      label: "Key Implication:\nGPU fetches ENTIRE cache lines.\nYou pay for 128B even if you use 4B."
      width: 380
      style.fill: "#FFD700"
      style.font-color: "#000"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.stroke: transparent
  style.fill: transparent
  good: {
    shape: rectangle
    label: "Optimal"
    width: 80
    style.fill: "#90EE90"
  }
  warn: {
    shape: rectangle
    label: "Suboptimal"
    width: 80
    style.fill: "#FFD700"
  }
  bad: {
    shape: rectangle
    label: "Inefficient"
    width: 80
    style.fill: "#FF6B6B"
  }
}