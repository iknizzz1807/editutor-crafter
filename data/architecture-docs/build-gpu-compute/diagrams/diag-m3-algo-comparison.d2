direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "CPU vs GPU Algorithm Comparison\nStep Complexity | Work Complexity | Wall-Clock Time"
  style: {
    font-size: 20
    bold: true
    fill: "#F0F0F0"
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  reduction_container: "Reduction (Sum)" {
    direction: right
    
    cpu_reduction: {
      label: "CPU Sequential"
      style.fill: "#E8E8E8"
      style.stroke: "#666666"
      
      logic: {
        label: "Approach: Scalar Loop"
        code_block: |'c
          float sum = 0.0f;
          for (int i = 0; i < N; i++) {
              sum += data[i];
          }
        '|
      }
      
      metrics: {
        shape: sql_table
        label: "Complexity & Performance"
        step: "Steps | O(n)"
        work: "Work  | O(n)"
        time_1m: "N=1M  | ~2.8 ms"
        time_16m: "N=16M | ~38.0 ms"
      }
    }

    gpu_reduction: {
      label: "GPU Parallel"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      
      logic: {
        label: "Approach: Tree-Based"
        code_block: |'c
          for (stride = blockDim.x/2; stride > 0; stride >>= 1) {
            if (tid < stride)
              sdata[tid] += sdata[tid + stride];
            __syncthreads();
          }
        '|
      }
      
      metrics: {
        shape: sql_table
        label: "Complexity & Performance"
        step: "Steps | O(log n)"
        work: "Work  | O(n)"
        time_1m: "N=1M  | ~0.04 ms"
        time_16m: "N=16M | ~0.75 ms"
      }
    }
    
    cpu_reduction -> gpu_reduction: "Parallelize"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scan_container: "Scan (Prefix Sum)" {
    direction: right

    cpu_scan: {
      label: "CPU Sequential"
      style.fill: "#E8E8E8"
      style.stroke: "#666666"
      
      logic: {
        label: "Approach: Dependency Chain"
        code_block: |'c
          output[0] = input[0];
          for (int i = 1; i < N; i++) {
              output[i] = output[i-1] + input[i];
          }
        '|
      }
      
      metrics: {
        shape: sql_table
        label: "Complexity & Performance"
        step: "Steps | O(n)"
        work: "Work  | O(n)"
        time_1m: "N=1M  | ~4.2 ms"
        time_16m: "N=16M | ~55.0 ms"
      }
    }

    gpu_scan: {
      label: "GPU Blelloch"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      
      logic: {
        label: "Approach: Upsweep/Downsweep"
        code_block: |'c
          // Phase 1: Build partial sum tree
          // Phase 2: Traverse down to propagate
          // Step: O(log n)
          // Work: O(n)
        '|
      }
      
      metrics: {
        shape: sql_table
        label: "Complexity & Performance"
        step: "Steps | O(log n)"
        work: "Work  | O(n)"
        time_1m: "N=1M  | ~0.09 ms"
        time_16m: "N=16M | ~1.62 ms"
      }
    }
    
    cpu_scan -> gpu_scan: "Parallelize"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  hist_container: "Histogram (256 Bins)" {
    direction: right

    cpu_hist: {
      label: "CPU Sequential"
      style.fill: "#E8E8E8"
      style.stroke: "#666666"
      
      logic: {
        label: "Approach: Global Bins"
        code_block: |'c
          int bins[256] = {0};
          for (int i = 0; i < N; i++) {
              bins[input[i]]++;
          }
        '|
      }
      metrics: {
        shape: sql_table
        label: "Complexity & Performance"
        step: "Steps | O(n)"
        work: "Work  | O(n)"
        time_1m: "N=1M  | ~5.5 ms"
        time_16m: "N=16M | ~72.0 ms"
      }
    }

    gpu_hist: {
      label: "GPU Privatized"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      
      logic: {
        label: "Approach: Shared Memory Atomics"
        code_block: |'c
          __shared__ int localHist[256];
          atomicAdd(&localHist[bin], 1);
          __syncthreads();
          atomicAdd(&global[bin], localHist[tid]);
        '|
      }
      metrics: {
        shape: sql_table
        label: "Complexity & Performance"
        step: "Steps | O(n/P)"
        work: "Work  | O(n)"
        time_1m: "N=1M  | ~0.07 ms"
        time_16m: "N=16M | ~1.45 ms"
      }
    }
    
    cpu_hist -> gpu_hist: "Parallelize"
  }
}

footer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  summary: {
    label: "Architectural Conclusion"
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    text_content: |md
      **Throughput vs Latency**: 
      The GPU does not reduce total operations (Work). 
      It reduces execution time (Steps) by mapping 
      independent tasks to thousands of hardware cores.
      
      **Efficiency**: 
      Blelloch Scan and Tree Reduction achieve O(n) work 
      efficiency while maintaining O(log n) span.
    |
  }

  hw_spec: {
    label: "Benchmark Context"
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
    text_content: |md
      **Hardware**:
      - CPU: Intel Core i7 (8-Core)
      - GPU: NVIDIA RTX 3080
      
      **Note**: GPU times include PCIe 
      transfer overhead for N=16M.
    |
  }
}

row3 -> footer: "Resultant Strategy"