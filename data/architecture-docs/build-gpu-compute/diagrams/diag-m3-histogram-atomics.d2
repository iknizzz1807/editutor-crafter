direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Atomic Contention in Histogram {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  problem: Problem: Atomic Contention {
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
    style.stroke-width: 2
    
    threads_label: "32 Threads in Warp (SIMT Execution)" {
      shape: text
      style.font-size: 14
      style.bold: true
    }
    
    threads: {
      direction: right
      grid-columns: 8
      grid-gap: 4
      t0: T0 {shape: circle; style.fill: "#E8E8E8"; width: 28; height: 28}
      t1: T1 {shape: circle; style.fill: "#E8E8E8"; width: 28; height: 28}
      t2: T2 {shape: circle; style.fill: "#E8E8E8"; width: 28; height: 28}
      t3: T3 {shape: circle; style.fill: "#E8E8E8"; width: 28; height: 28}
      t4: T4 {shape: circle; style.fill: "#E8E8E8"; width: 28; height: 28}
      t5: T5 {shape: circle; style.fill: "#E8E8E8"; width: 28; height: 28}
      t6: "..." {shape: text; style.font-size: 12}
      t7: T31 {shape: circle; style.fill: "#E8E8E8"; width: 28; height: 28}
    }
    
    input_label: "Input Data Vector: [3, 0, 0, 3, 0, 2, 3, 1, ...]" {
      shape: text
      style.font-size: 12
      style.font: mono
    }
    
    instr: {
      label: "atomicAdd(&hist[bin], 1)"
      shape: code
      style.font-size: 11
    }
    
    histogram: {
      shape: sql_table
      label: "Global Memory: int histogram[4]"
      bin0: "0x00 | hist[0] | 3 threads contending"
      bin1: "0x04 | hist[1] | 1 thread"
      bin2: "0x08 | hist[2] | 1 thread"
      bin3: "0x0C | hist[3] | 3 threads contending"
      total: "Total Size: 16 bytes"
    }
    
    contention_marker: "CONTENTION!" {
      shape: callout
      style.fill: "#FF6B6B"
      style.font-color: white
      style.bold: true
    }
    
    histogram.bin0 -> contention_marker: "High Pressure"
    histogram.bin3 -> contention_marker: "High Pressure"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  timeline: Serialization Timeline (Hardware Bottleneck) {
    style.fill: "#FFF8DC"
    style.stroke: "#DAA520"
    
    explanation: "6 threads targeting hist[0] and hist[3] are serialized by the memory controller:" {
      shape: text
      style.font-size: 12
    }
    
    seq: {
      direction: right
      step1: "T0 locks [0]" {
        style.fill: "#90EE90"
        width: 100
      }
      step2: "T1 stalls..." {
        style.fill: "#FFB6C1"
        width: 80
      }
      step3: "T2 stalls..." {
        style.fill: "#FFB6C1"
        width: 80
      }
      step4: "T3 locks [3]" {
        style.fill: "#90EE90"
        width: 100
      }
      step5: "T4 stalls..." {
        style.fill: "#FFB6C1"
        width: 80
      }
      step6: "T5 stalls..." {
        style.fill: "#FFB6C1"
        width: 80
      }
      step1 -> step2 -> step3 -> step4 -> step5 -> step6
    }
    
    result: "Result: Pipeline Serialized (Effective Throughput drops to Latency of Atomic)" {
      shape: text
      style.font-size: 12
      style.font-color: "#8B0000"
      style.bold: true
    }
    
    bandwidth: "Measured Bandwidth: < 5% of Peak Global Memory Bandwidth" {
      shape: text
      style.font-size: 11
      style.font-color: "#666666"
    }
  }
}

row1 -> row2: "Hardware Contention"

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  solution: Solution: Memory Privatization {
    style.fill: "#E0FFE0"
    style.stroke: "#228B22"
    style.stroke-width: 2
    
    desc_node: "Shared Memory Privatization Strategy" {
      shape: text
      label: "Each threadblock maintains a private histogram in fast On-Chip Shared Memory (L1 cache speed)"
      style.font-size: 12
    }
    
    blocks: {
      direction: right
      block0: Block 0 {
        style.fill: "#F0F8FF"
        threads0: "256 threads" {shape: text; style.font-size: 10}
        local0: {
          shape: sql_table
          label: "__shared__ localHist[4]"
          l0: "bin 0 | Fast SMEM Atomic"
          l1: "bin 1 | Fast SMEM Atomic"
          l2: "bin 2 | Fast SMEM Atomic"
          l3: "bin 3 | Fast SMEM Atomic"
        }
      }
      block1: Block 1 {
        style.fill: "#F0F8FF"
        threads1: "256 threads" {shape: text; style.font-size: 10}
        local1: {
          shape: sql_table
          label: "__shared__ localHist[4]"
          l0: "bin 0 | Fast SMEM Atomic"
          l1: "bin 1 | Fast SMEM Atomic"
          l2: "bin 2 | Fast SMEM Atomic"
          l3: "bin 3 | Fast SMEM Atomic"
        }
      }
      block_sep: {
        label: "..."
        shape: text
        style.font-size: 30
      }
      blockN: Block N {
        style.fill: "#F0F8FF"
        threadsN: "256 threads" {shape: text; style.font-size: 10}
        localN: {
          shape: sql_table
          label: "__shared__ localHist[4]"
          l0: "bin 0 | Fast SMEM Atomic"
          l1: "bin 1 | Fast SMEM Atomic"
          l2: "bin 2 | Fast SMEM Atomic"
          l3: "bin 3 | Fast SMEM Atomic"
        }
      }
    }
    
    merge_label: "Merge Phase: __syncthreads() then write to Global" {
      shape: text
      style.font-size: 12
      style.bold: true
    }
    
    global_hist: {
      shape: sql_table
      label: "Global Histogram (Post-Merge)"
      g0: "Reduced Contention | block0..N atomics"
      g1: "Reduced Contention | block0..N atomics"
      g2: "Reduced Contention | block0..N atomics"
      g3: "Reduced Contention | block0..N atomics"
    }
    
    blocks.block0 -> global_hist: "atomicAdd" {style.stroke: "#228B22"; style.stroke-dash: 3}
    blocks.blockN -> global_hist: "atomicAdd" {style.stroke: "#228B22"; style.stroke-dash: 3}
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  comparison: Performance Analysis (N=16M, Bins=256) {
    style.fill: "#F5F5F5"
    style.stroke: "#666666"
    
    metrics: {
      direction: down
      naive: {
        label: "Approach 1: Naive Global"
        style.fill: "#FFCCCC"
        ops: "16M Global Memory Atomics" {shape: text; style.font-size: 11}
        time: "Latency: ~150-280ms" {shape: text; style.font-size: 12; style.bold: true}
      }
      privatized: {
        label: "Approach 2: Privatized Shared"
        style.fill: "#CCFFCC"
        ops: "16M Shared + 16K Global Atomics" {shape: text; style.font-size: 11}
        time: "Latency: ~6-10ms (25x Speedup)" {shape: text; style.font-size: 12; style.bold: true}
      }
      warp_agg: {
        label: "Approach 3: Warp Aggregation"
        style.fill: "#90EE90"
        ops: "Warp-level Register Combining" {shape: text; style.font-size: 11}
        time: "Latency: ~2-4ms (70x Speedup)" {shape: text; style.font-size: 12; style.bold: true}
      }
      
      naive -> privatized: "Privatization"
      privatized -> warp_agg: "Aggregation"
    }
  }
}

row2 -> row3: "Optimization Path"
row3 -> row4: "Metric Verification"

legend: Legend {
  near: bottom-right
  direction: right
  red: "Contention / Serialization" {
    shape: rectangle
    style.fill: "#FFB6C1"
  }
  green: "Parallel Throughput" {
    shape: rectangle
    style.fill: "#90EE90"
  }
  mem: "On-Chip Resource" {
    shape: rectangle
    style.fill: "#F0F8FF"
  }
}