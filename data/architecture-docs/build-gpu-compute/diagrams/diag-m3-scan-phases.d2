direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Blelloch Scan: Two-Phase Parallel Prefix Sum"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  input_label: {
    label: "INPUT ARRAY"
    shape: text
    style: {
      font-size: 18
      bold: true
      font-color: "#666666"
    }
  }
  input: {
    label: "Input[0..7]"
    shape: sql_table
    width: 480
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
    i0: "0 | [3]"
    i1: "1 | [1]"
    i2: "2 | [7]"
    i3: "3 | [0]"
    i4: "4 | [4]"
    i5: "5 | [1]"
    i6: "6 | [6]"
    i7: "7 | [3]"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  phase1: {
    direction: down
    label: "PHASE 1: UPSWEEP (REDUCE)"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      border-radius: 8
    }
    phase1_desc: {
      label: "Build reduction tree, save partial sums at each node"
      shape: text
      style: {
        font-size: 14
        italic: true
        font-color: "#E65100"
      }
    }
    level0: {
      label: "Level 0 (d=1)"
      shape: sql_table
      width: 480
      style: {
        fill: "#FFECB3"
        stroke: "#FFA000"
      }
      l0_0: "0 | [3]"
      l0_1: "1 | [4] ← 3+1"
      l0_2: "2 | [7]"
      l0_3: "3 | [7] ← 7+0"
      l0_4: "4 | [4]"
      l0_5: "5 | [5] ← 4+1"
      l0_6: "6 | [6]"
      l0_7: "7 | [9] ← 6+3"
    }
    level1: {
      label: "Level 1 (d=2)"
      shape: sql_table
      width: 480
      style: {
        fill: "#FFE082"
        stroke: "#FF8F00"
      }
      l1_0: "0 | [3]"
      l1_1: "1 | [4]"
      l1_2: "2 | [7]"
      l1_3: "3 | [11] ← 4+7"
      l1_4: "4 | [4]"
      l1_5: "5 | [5]"
      l1_6: "6 | [6]"
      l1_7: "7 | [14] ← 5+9"
    }
    level2: {
      label: "Level 2 (d=4)"
      shape: sql_table
      width: 480
      style: {
        fill: "#FFD54F"
        stroke: "#FF6F00"
      }
      l2_0: "0 | [3]"
      l2_1: "1 | [4]"
      l2_2: "2 | [7]"
      l2_3: "3 | [11]"
      l2_4: "4 | [4]"
      l2_5: "5 | [5]"
      l2_6: "6 | [6]"
      l2_7: "7 | [25] ← 11+14"
    }
    total: {
      label: "Total Sum = 25"
      shape: rectangle
      width: 200
      style: {
        fill: "#FF6F00"
        font-color: white
        bold: true
        border-radius: 4
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  clear_op: {
    label: "CLEAR LAST ELEMENT"
    shape: rectangle
    width: 200
    style: {
      fill: "#FCE4EC"
      stroke: "#E91E63"
      stroke-width: 2
    }
    clear_desc: {
      label: "Set array[7] = 0\n(for exclusive scan)"
      shape: text
      style: {
        font-size: 14
        font-color: "#C2185B"
      }
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  phase2: {
    direction: down
    label: "PHASE 2: DOWNSWEEP (DISTRIBUTE)"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      border-radius: 8
    }
    phase2_desc: {
      label: "Traverse tree top-down, propagate partial sums"
      shape: text
      style: {
        font-size: 14
        italic: true
        font-color: "#2E7D32"
      }
    }
    down_level2: {
      label: "Level 2 (d=4) — Clear root, swap children"
      shape: sql_table
      width: 480
      style: {
        fill: "#C8E6C9"
        stroke: "#43A047"
      }
      dl2_0: "0 | [3]"
      dl2_1: "1 | [4]"
      dl2_2: "2 | [7]"
      dl2_3: "3 | [0] ← was 11"
      dl2_4: "4 | [4]"
      dl2_5: "5 | [5]"
      dl2_6: "6 | [6]"
      dl2_7: "7 | [11] ← was 25"
    }
    down_level1: {
      label: "Level 1 (d=2) — Propagate down"
      shape: sql_table
      width: 480
      style: {
        fill: "#A5D6A7"
        stroke: "#388E3C"
      }
      dl1_0: "0 | [3]"
      dl1_1: "1 | [0] ← was 4"
      dl1_2: "2 | [7]"
      dl1_3: "3 | [4] ← 0+4"
      dl1_4: "4 | [4]"
      dl1_5: "5 | [11] ← was 5"
      dl1_6: "6 | [6]"
      dl1_7: "7 | [17] ← 11+6"
    }
    down_level0: {
      label: "Level 0 (d=1) — Final propagation"
      shape: sql_table
      width: 480
      style: {
        fill: "#81C784"
        stroke: "#2E7D32"
      }
      dl0_0: "0 | [0] ← was 3"
      dl0_1: "1 | [3] ← 0+3"
      dl0_2: "2 | [4] ← was 7"
      dl0_3: "3 | [11] ← 4+7"
      dl0_4: "4 | [0] ← was 4"
      dl0_5: "5 | [4] ← 0+4"
      dl0_6: "6 | [15] ← was 6"
      dl0_7: "7 | [21] ← 15+6"
    }
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  output_label: {
    label: "OUTPUT (EXCLUSIVE SCAN)"
    shape: text
    style: {
      font-size: 18
      bold: true
      font-color: "#666666"
    }
  }
  output: {
    label: "Output[0..7] — Prefix Sums"
    shape: sql_table
    width: 480
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
    o0: "0 | [0]"
    o1: "1 | [3]"
    o2: "2 | [4]"
    o3: "3 | [11]"
    o4: "4 | [11]"
    o5: "5 | [15]"
    o6: "6 | [16]"
    o7: "7 | [22]"
  }
}
row6: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  verification: {
    label: "VERIFICATION"
    shape: rectangle
    width: 500
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      border-radius: 8
    }
    verify_content: {
      shape: text
      label: |md
        **Exclusive Scan Definition:** `output[i] = sum(input[0..i-1])`
        - `output[0] = 0` (empty sum)
        - `output[1] = input[0] = 3`
        - `output[2] = input[0] + input[1] = 3 + 1 = 4`
        - `output[3] = 3 + 1 + 7 = 11`
        - `output[7] = 3+1+7+0+4+1+6 = 22`
        **Complexity:** O(log n) steps, O(n) total work
      |
    }
  }
}
row1.input -> row2.phase1: " "
row2.phase1 -> row3.clear_op: " "
row3.clear_op -> row4.phase2: " "
row4.phase2 -> row5.output: " "