direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Warp Divergence in Parallel Reduction"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  divergent_section: {
    direction: down
    label: "Divergent Reduction (if tid < stride)"
    warp_state: {
      direction: down
      label: "Warp Execution Timeline"
      cycle_header: {
        label: "Cycles 0-3: stride=16"
        shape: rectangle
        width: 500
        style.fill: "#E8E8E8"
      }
      threads_diverge: {
        direction: right
        label: ""
        active_box: {
          label: "Active Threads\n(tid 0-15)"
          shape: rectangle
          width: 200
          style: {
            fill: "#90EE90"
            stroke: "#228B22"
            stroke-width: 2
          }
          code_active: |'c
            if (tid < 16) {
              sdata[tid] += 
                sdata[tid + 16];
            }
          '|
        }
        inactive_box: {
          label: "Inactive Threads\n(tid 16-31)"
          shape: rectangle
          width: 200
          style: {
            fill: "#FFB6C1"
            stroke: "#DC143C"
            stroke-width: 2
          }
          code_inactive: |'c
            // Masked off
            // Waiting...
            // Cycles wasted
          '|
        }
      }
      divergence_note: {
        label: "Warp executes BOTH paths serially"
        shape: rectangle
        width: 420
        style: {
          fill: "#FFF3CD"
          stroke: "#856404"
          stroke-dash: 3
        }
      }
    }
    timeline_diverge: {
      direction: down
      label: "Serialized Execution"
      cycle_0_15: {
        label: "Cycles 0-15: Path A executes (tid 0-15 active)"
        shape: rectangle
        width: 380
        style.fill: "#90EE90"
      }
      cycle_16_31: {
        label: "Cycles 16-31: Path B skipped (tid 16-31 masked)"
        shape: rectangle
        width: 380
        style.fill: "#FFB6C1"
      }
      total_diverge: {
        label: "Total: 32 cycles for 16 useful operations"
        shape: rectangle
        width: 380
        style: {
          fill: "#FF6B6B"
          font-color: white
          bold: true
        }
      }
    }
  }
  shuffle_section: {
    direction: down
    label: "Warp Shuffle (Divergence-Free)"
    shuffle_state: {
      direction: down
      label: "Warp Execution Timeline"
      shuffle_header: {
        label: "Single Instruction: __shfl_down_sync"
        shape: rectangle
        width: 500
        style.fill: "#E8E8E8"
      }
      all_active: {
        label: "All 32 Threads Active"
        shape: rectangle
        width: 420
        style: {
          fill: "#87CEEB"
          stroke: "#4682B4"
          stroke-width: 2
        }
        shuffle_code: |'c
          // No branch - all threads execute
          val += __shfl_down_sync(
            0xffffffff, val, 16);
        '|
      }
      uniform_note: {
        label: "SIMT lockstep: all threads execute same instruction"
        shape: rectangle
        width: 420
        style: {
          fill: "#D4EDDA"
          stroke: "#155724"
          stroke-dash: 3
        }
      }
    }
    timeline_shuffle: {
      direction: down
      label: "Parallel Execution"
      single_cycle: {
        label: "1 Cycle: All threads complete shuffle"
        shape: rectangle
        width: 380
        style.fill: "#87CEEB"
      }
      benefit: {
        label: "No serialization penalty"
        shape: rectangle
        width: 380
        style: {
          fill: "#98FB98"
          stroke: "#228B22"
        }
      }
      total_shuffle: {
        label: "Total: 1 cycle for 16 useful operations"
        shape: rectangle
        width: 380
        style: {
          fill: "#32CD32"
          font-color: white
          bold: true
        }
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  comparison: {
    direction: down
    label: "Performance Comparison"
    metrics: {
      shape: sql_table
      label: "Reduction Method Analysis"
      m1: "Method | Cycles (stride=16) | Efficiency"
      m2: "Divergent if-stmt | 32 cycles | 50%"
      m3: "Warp shuffle | 1 cycle | 100%"
      m4: "Speedup | 32× faster | —"
    }
  }
  explanation: {
    direction: down
    label: "Why Divergence Hurts"
    width: 400
    concept: {
      label: "SIMT Execution Model"
      shape: rectangle
      style.fill: "#F0F8FF"
      simt_text: |md
        **Key Insight:**
        GPU warps execute in **lockstep**. When threads diverge:
        1. The warp executes the **if** path with active threads masked on
        2. Then executes the **else** path with the other threads masked on
        3. **Both paths consume cycles**
        Effective throughput = Active threads / Total threads
      |
    }
    shuffle_benefit: {
      label: "Shuffle Benefit"
      shape: rectangle
      style.fill: "#F0FFF0"
      shuffle_text: |md
        **Warp Shuffle Instructions:**
        - `__shfl_down_sync(mask, var, delta)`
        - No branching required
        - All threads participate
        - Data moves through special hardware
        - **100% of cycles are useful**
      |
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  reduction_tree: {
    direction: down
    label: "Reduction Strides and Divergence"
    stride_table: {
      shape: sql_table
      label: "Divergence by Stride"
      s0: "Stride | Active Threads | Divergence?"
      s1: "256 | All 32 | No (uniform warp)"
      s2: "128 | All 32 | No (uniform warp)"
      s3: "64 | All 32 | No (uniform warp)"
      s4: "32 | All 32 | No (exactly one warp)"
      s5: "16 | 16 (tid 0-15) | YES - 2× penalty"
      s6: "8 | 8 (tid 0-7) | YES - 4× penalty"
      s7: "4 | 4 (tid 0-3) | YES - 8× penalty"
      s8: "2 | 2 (tid 0-1) | YES - 16× penalty"
      s9: "1 | 1 (tid 0) | YES - 32× penalty"
    }
  }
  optimization: {
    direction: down
    label: "Optimization Strategy"
    strategy: {
      label: "Warp-Synchronous Unrolling"
      shape: rectangle
      width: 400
      style.fill: "#FFF8DC"
      unroll_code: |'c
        // For stride <= 32: use shuffle
        // (all active threads in one warp)
        if (tid < 32) {
          volatile float* v = sdata;
          v[tid] += v[tid + 32];
          v[tid] += v[tid + 16];
          v[tid] += v[tid + 8];
          v[tid] += v[tid + 4];
          v[tid] += v[tid + 2];
          v[tid] += v[tid + 1];
        }
      '|
    }
    modern_approach: {
      label: "Modern: Pure Shuffle"
      shape: rectangle
      width: 400
      style.fill: "#E6FFE6"
      modern_code: |'c
        // Entire reduction via shuffle
        for (int offset = 16; offset > 0; 
             offset /= 2) {
          val += __shfl_down_sync(
            0xffffffff, val, offset);
        }
        // Thread 0 holds final result
      '|
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  label: "Legend"
  green: {
    label: "Active Execution"
    shape: rectangle
    style.fill: "#90EE90"
    width: 100
  }
  red: {
    label: "Inactive/Masked"
    shape: rectangle
    style.fill: "#FFB6C1"
    width: 100
  }
  blue: {
    label: "Uniform (All Active)"
    shape: rectangle
    style.fill: "#87CEEB"
    width: 100
  }
}