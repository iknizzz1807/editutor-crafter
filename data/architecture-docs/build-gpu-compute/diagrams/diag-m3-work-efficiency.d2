direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Work Efficiency Tradeoff | "Sequential O(n) vs Parallel O(n log n)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  sequential: {
    direction: down
    label: "Sequential Reduction"
    style.fill: "#E8F5E9"
    seq_desc: {
      label: "Each element touched exactly once"
      width: 280
    }
    seq_formula: {
      label: "Work: O(n) operations"
      width: 280
      style.fill: "#C8E6C9"
    }
    seq_steps: {
      label: |md
        **Step 1:** a₀ + a₁ = s₁
        **Step 2:** s₁ + a₂ = s₂
        **Step 3:** s₂ + a₃ = s₃
        **...**
        **Step n-1:** sₙ₋₂ + aₙ₋₁ = **result**
      |
      width: 280
    }
    seq_total: {
      label: "Total Steps: n-1 (sequential)"
      width: 280
      style.fill: "#A5D6A7"
    }
  }
  parallel: {
    direction: down
    label: "Tree-Based Parallel Reduction"
    style.fill: "#E3F2FD"
    par_desc: {
      label: "Elements touched multiple times across levels"
      width: 280
    }
    par_formula: {
      label: "Work: O(n log n) operations"
      width: 280
      style.fill: "#BBDEFB"
    }
    par_tree: {
      label: |md
        **Level 0 (Input):**  a₀  a₁  a₂  a₃  a₄  a₅  a₆  a₇
        **Level 1:**          └a₀+a₁┘ └a₂+a₃┘ └a₄+a₅┘ └a₆+a₇┘
        **Level 2:**          └─sum₀+sum₁─┘ └─sum₂+sum₃─┘
        **Level 3:**          └─────final sum─────┘
      |
      width: 280
    }
    par_total: {
      label: "Total Steps: log₂(n) (parallel)"
      width: 280
      style.fill: "#90CAF9"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  work_analysis: {
    direction: down
    label: "Work Analysis"
    style.fill: "#FFF3E0"
    work_table: {
      shape: sql_table
      label: "Operation Count Comparison"
      f1: "n=8     | 7 ops (seq)  | 7 ops (par)  | Same"
      f2: "n=1024  | 1,023       | 5,120        | 5× more"
      f3: "n=1M    | 999,999     | ~20M         | 20× more"
      note: "Parallel does MORE total work!"
    }
    key_insight: {
      label: |md
        **Key Insight:**
        Parallel algorithms trade **total work** for **reduced latency**.
        More processors working simultaneously completes faster
        even though each processor does less-efficient work.
      |
      width: 320
      style.fill: "#FFE0B2"
    }
  }
  crossover: {
    direction: down
    label: "The Crossover Point"
    style.fill: "#F3E5F5"
    crossover_graph: {
      label: |md
        
        Time
          │
          │     ╱ Sequential (1 proc)
          │    ╱
          │   ╱
          │  ╱      ╱ Parallel (p procs)
          │ ╱      ╱
          │╱      ╱
          └─────────────────── n
               ↑
            Crossover
        
      |
      width: 280
    }
    crossover_explain: {
      label: |md
        **Below crossover:** Overhead exceeds benefit
        **Above crossover:** Parallelism wins despite extra work
        Crossover depends on:
        • Number of processors (p)
        • Overhead per parallel step
        • Problem size (n)
      |
      width: 320
      style.fill: "#E1BEE7"
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  tension_box: {
    direction: down
    label: "The Fundamental Tension"
    style.fill: "#FFEBEE"
    tension_desc: {
      width: 700
      label: |md
        **Step Complexity (Depth/Span):** How many sequential steps with infinite processors?
        → Parallel reduction: O(log n) steps
        **Work Complexity:** Total operations across all processors?
        → Parallel reduction: O(n log n) work (not work-efficient!)
        **Work-Efficient Algorithm:** Does no more work than sequential
        → Blelloch scan: O(n) work in O(log n) steps ✓
      |
    }
    bottom_line: {
      label: "Parallelism ≠ Less Work | Parallelism = Lower Latency"
      width: 700
      style: {
        fill: "#FFCDD2"
        bold: true
        font-size: 18
      }
    }
  }
}
legend: {
  near: bottom-right
  style.fill: transparent
  leg1: "Sequential: Touch each element once" {
    style.fill: "#A5D6A7"
  }
  leg2: "Parallel: Touch elements at each tree level" {
    style.fill: "#90CAF9"
  }
  leg3: "Tradeoff: More work, fewer steps" {
    style.fill: "#E1BEE7"
  }
}
sequential -> parallel: "Same result,\ndifferent cost structure" {
  style.stroke-dash: 3
}
work_analysis -> crossover: "When does\nparallelism win?" {
  style.stroke-dash: 3
}