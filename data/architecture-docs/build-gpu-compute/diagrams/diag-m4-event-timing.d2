direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL HEADER ---
header: {
  label: "CUDA EVENT TIMING: ARCHITECTURAL SPECIFICATION"
  icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
  style: {
    font-size: 32
    bold: true
    fill: "#f0f4f8"
    stroke: "#2c3e50"
    stroke-width: 4
  }
}

# --- ROW 1: EXECUTION TIMELINE (Sequence Diagram) ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  timeline: {
    shape: sequence_diagram
    host: CPU (Host) {
      icon: https://icons.terrastruct.com/dev/go.svg
    }
    stream: CUDA Stream (Queue) {
      style.fill: "#e8f8f5"
    }
    gpu: GPU (Device Execution) {
      icon: https://icons.terrastruct.com/tech/022-server.svg
    }

    host -> stream: "cudaEventRecord(start)"
    stream -> gpu: "ENQUEUE_TIMESTAMP_MARKER"
    gpu -> gpu: "Capture Global Clock (t0)"

    host -> stream: "kernel(params)"
    stream -> gpu: "DISPATCH_KERNEL_WORK"
    gpu -> gpu: "Kernel Execution Block"

    host -> stream: "cudaEventRecord(stop)"
    stream -> gpu: "ENQUEUE_TIMESTAMP_MARKER"
    gpu -> gpu: "Capture Global Clock (t1)"

    host -> stream: "cudaEventSynchronize(stop)"
    stream -> host: "BLOCK_UNTIL_T1_READY"

    host -> host: "cudaEventElapsedTime(ms, start, stop)"
    host."Result: ms = (t1 - t0) / freq"
  }
}

# --- ROW 2: COMPARISON & MECHANICS ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  timing_comparison: {
    shape: sql_table
    label: "Timing Metric Comparison"
    h1: "Metric | CPU Wall-Clock | CUDA Events"
    r1: "Resolution | ~100ns (OS dependent) | ~0.5us (Hardware Clock)"
    r2: "Context | Includes Launch Latency | Pure GPU Pipeline execution"
    r3: "Sync | Requires host blocking | Asynchronous recording"
    r4: "Async Safety | Thread-unsafe | Stream-ordered (Safe)"
    total: "Recommendation: Use Events for profiling."
  }

  impl_detail: {
    label: "Timing Implementation Patterns"
    direction: down
    
    bad_practice: {
      label: "INACCURATE: CPU-Side Timing"
      style.fill: "#fff5f5"
      style.stroke: "#e74c3c"
      code: |'cpp
        auto t_start = high_res_clock::now();
        kernel<<<G, B>>>(d_ptr); // Async!
        auto t_end = high_res_clock::now();
        // Result: measures launch overhead only
      '|
    }

    good_practice: {
      label: "ACCURATE: GPU-Side Events"
      style.fill: "#f4fdf4"
      style.stroke: "#27ae60"
      code: |'cpp
        cudaEventRecord(start, stream);
        kernel<<<G, B>>>(d_ptr);
        cudaEventRecord(stop, stream);
        cudaEventSynchronize(stop); // Essential
        cudaEventElapsedTime(&ms, start, stop);
      '|
    }
    bad_practice -> good_practice: "MIGRATION"
  }
}

# --- ROW 3: WORKFLOW PIPELINE ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  workflow_steps: {
    label: "Event Lifecycle Pipeline"
    direction: right
    
    s1: {
      label: "1. ALLOCATION"
      code: |'cpp
        cudaEvent_t start, stop;
        cudaEventCreate(&start);
        cudaEventCreate(&stop);
      '|
    }
    s2: {
      label: "2. RECORDING"
      code: |'cpp
        cudaEventRecord(start, stream);
        // ... GPU Work ...
        cudaEventRecord(stop, stream);
      '|
    }
    s3: {
      label: "3. BARRIER"
      code: |'cpp
        // Wait for STOP marker in queue
        cudaEventSynchronize(stop);
      '|
    }
    s4: {
      label: "4. CALCULATE"
      code: |'cpp
        float ms;
        cudaEventElapsedTime(&ms, start, stop);
      '|
    }

    s1 -> s2 -> s3 -> s4: "Dataflow"
  }
}

# --- ROW 4: PITFALLS & MEMORY ---
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  pitfall_box: {
    label: "CRITICAL IMPLEMENTATION PITFALLS"
    direction: down
    
    no_sync: {
      label: "Missing Synchronization"
      style.fill: "#fffcf0"
      code: |'cpp
        cudaEventRecord(stop, stream);
        // Race: CPU reads before GPU writes
        cudaEventElapsedTime(&ms, start, stop); 
        // Result: 0.0 or garbage value
      '|
    }

    leak_warn: {
      label: "Resource Leak Prevention"
      style.fill: "#f4faff"
      code: |'cpp
        // Events consume driver resources
        // Do not forget to deallocate:
        cudaEventDestroy(start);
        cudaEventDestroy(stop);
      '|
    }
  }

  event_struct: {
    shape: sql_table
    label: "Opaque Handle: cudaEvent_t (Internal Layout)"
    f1: "0x00 | void*    | device_ptr // Hardware queue ref"
    f2: "0x08 | uint32_t | flags      // Config/Sync flags"
    f3: "0x0C | int      | stream_id  // Stream affinity"
    f4: "0x10 | uint64_t | timestamp  // Captured Cycle Count"
    sz: "Total: 24 Bytes (Standard Handle)"
  }
}

# --- GLOBAL CONNECTORS ---
header -> row1: "Specification"
row1 -> row2: "Implementation"
row2 -> row3: "Workflow"
row3 -> row4: "Memory & Safety"

# --- LEGEND ---
legend: {
  label: "Visual Key"
  green_path: "ACCURATE / STABLE" {
    style.stroke: "#27ae60"
    style.fill: "#f4fdf4"
  }
  red_path: "DANGER / INACCURATE" {
    style.stroke: "#e74c3c"
    style.fill: "#fff5f5"
  }
}
legend.near: bottom-right