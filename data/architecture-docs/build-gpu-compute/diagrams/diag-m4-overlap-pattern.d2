direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Compute-Transfer Overlap Patterns
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pattern1: {
    direction: down
    label: "(1) No Overlap\nSequential Execution"
    seq_timeline: {
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
      h2d_1: {
        label: "H2D"
        shape: rectangle
        width: 120
        height: 40
        style.fill: "#ffc107"
        style.stroke: "#e0a800"
      }
      kernel_1: {
        label: "Kernel"
        shape: rectangle
        width: 120
        height: 50
        style.fill: "#28a745"
        style.stroke: "#1e7e34"
      }
      d2h_1: {
        label: "D2H"
        shape: rectangle
        width: 120
        height: 40
        style.fill: "#17a2b8"
        style.stroke: "#117a8b"
      }
    }
    seq_timeline.h2d_1 -> seq_timeline.kernel_1: {style.stroke: transparent}
    seq_timeline.kernel_1 -> seq_timeline.d2h_1: {style.stroke: transparent}
    seq_time: {
      label: "Total: 9ms per chunk\n(2ms + 5ms + 2ms)"
      shape: text
      style.font-color: "#6c757d"
    }
    throughput1: {
      label: "Throughput: 111 MB/s\n(1MB chunk)"
      shape: rectangle
      style.fill: "#f8d7da"
      style.stroke: "#f5c6cb"
      style.font-color: "#721c24"
    }
  }
  pattern2: {
    direction: down
    label: "(2) Pipeline Overlap\nMultiple Chunks in Flight"
    pipe_timeline: {
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
      pipe_row1: "" {
        direction: right
        style.stroke: transparent
        h2d_c0: {label: "H2D\nC0"; width: 50; height: 35; style.fill: "#ffc107"}
        h2d_c1: {label: "H2D\nC1"; width: 50; height: 35; style.fill: "#ffc107"}
        h2d_c2: {label: "H2D\nC2"; width: 50; height: 35; style.fill: "#ffc107"}
      }
      pipe_row2: "" {
        direction: right
        style.stroke: transparent
        spacer2: {label: ""; width: 15; style.fill: transparent; style.stroke: transparent}
        kern_c0: {label: "Kern\nC0"; width: 50; height: 45; style.fill: "#28a745"}
        kern_c1: {label: "Kern\nC1"; width: 50; height: 45; style.fill: "#28a745"}
        kern_c2: {label: "Kern\nC2"; width: 50; height: 45; style.fill: "#28a745"}
      }
      pipe_row3: "" {
        direction: right
        style.stroke: transparent
        spacer3: {label: ""; width: 30; style.fill: transparent; style.stroke: transparent}
        d2h_c0: {label: "D2H\nC0"; width: 50; height: 35; style.fill: "#17a2b8"}
        d2h_c1: {label: "D2H\nC1"; width: 50; height: 35; style.fill: "#17a2b8"}
        d2h_c2: {label: "D2H\nC2"; width: 50; height: 35; style.fill: "#17a2b8"}
      }
    }
    pipe_time: {
      label: "Total: 19ms for 3 chunks\n(2 + 5×3 + 2)"
      shape: text
      style.font-color: "#6c757d"
    }
    throughput2: {
      label: "Throughput: 158 MB/s\n1.42× faster"
      shape: rectangle
      style.fill: "#fff3cd"
      style.stroke: "#ffc107"
      style.font-color: "#856404"
    }
  }
  pattern3: {
    direction: down
    label: "(3) Full Overlap\nDouble-Buffered (2 Streams)"
    full_timeline: {
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
      stream0: "" {
        direction: right
        label: "S0"
        style.stroke: transparent
        s0_h2d_0: {label: "H2D"; width: 45; height: 30; style.fill: "#ffc107"}
        s0_kern_0: {label: "K"; width: 45; height: 40; style.fill: "#28a745"}
        s0_d2h_0: {label: "D2H"; width: 45; height: 30; style.fill: "#17a2b8"}
        s0_h2d_2: {label: "H2D"; width: 45; height: 30; style.fill: "#ffc107"}
        s0_kern_2: {label: "K"; width: 45; height: 40; style.fill: "#28a745"}
        s0_d2h_2: {label: "D2H"; width: 45; height: 30; style.fill: "#17a2b8"}
      }
      stream1: "" {
        direction: right
        label: "S1"
        style.stroke: transparent
        spacer1: {label: ""; width: 10; style.fill: transparent; style.stroke: transparent}
        s1_h2d_1: {label: "H2D"; width: 45; height: 30; style.fill: "#ffc107"}
        s1_kern_1: {label: "K"; width: 45; height: 40; style.fill: "#28a745"}
        s1_d2h_1: {label: "D2H"; width: 45; height: 30; style.fill: "#17a2b8"}
        s1_h2d_3: {label: "H2D"; width: 45; height: 30; style.fill: "#ffc107"}
        s1_kern_3: {label: "K"; width: 45; height: 40; style.fill: "#28a745"}
        s1_d2h_3: {label: "D2H"; width: 45; height: 30; style.fill: "#17a2b8"}
      }
    }
    full_time: {
      label: "Total: 14ms for 3 chunks\n(max(2+5+2, 5×3))"
      shape: text
      style.font-color: "#6c757d"
    }
    throughput3: {
      label: "Throughput: 214 MB/s\n1.93× faster"
      shape: rectangle
      style.fill: "#d4edda"
      style.stroke: "#28a745"
      style.font-color: "#155724"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: {
    direction: down
    label: "Throughput Comparison"
    chart: {
      grid-columns: 3
      grid-gap: 0
      header1: {label: "Pattern"; style.underline: true; style.fill: "#e9ecef"}
      header2: {label: "Time (3 chunks)"; style.underline: true; style.fill: "#e9ecef"}
      header3: {label: "Speedup"; style.underline: true; style.fill: "#e9ecef"}
      p1_name: "Sequential"
      p1_time: "27ms"
      p1_speed: "1.0×"
      p2_name: "Pipeline"
      p2_time: "19ms"
      p2_speed: "1.42×"
      p3_name: "Double-Buffer"
      p3_time: "14ms"
      p3_speed: "1.93×"
    }
  }
  key_insight: {
    direction: down
    label: "Key Insight"
    width: 280
    insight_code: |'c
      // Double-buffering with streams
      // enables H2D, Kernel, D2H overlap
      cudaMemcpyAsync(d_in[s], h_in, bytes,
          cudaMemcpyHostToDevice, stream[s]);
      kernel<<<grid, block, 0, stream[s]>>>(
          d_in[s], d_out[s]);
      cudaMemcpyAsync(h_out, d_out[s], bytes,
          cudaMemcpyDeviceToHost, stream[s]);
    '|
  }
}
legend: {
  near: bottom-center
  direction: right
  leg_h2d: {label: "H2D"; shape: rectangle; width: 40; height: 20; style.fill: "#ffc107"}
  leg_kern: {label: "Kernel"; shape: rectangle; width: 50; height: 20; style.fill: "#28a745"}
  leg_d2h: {label: "D2H"; shape: rectangle; width: 40; height: 20; style.fill: "#17a2b8"}
}