direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Pinned vs Pageable Memory Transfer"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  pageable: {
    direction: down
    label: "Pageable Memory Transfer"
    style: {
      fill: "#FFF5F5"
      stroke: "#E53E3E"
      stroke-width: 2
    }
    host_mem: {
      label: "Host Memory (Pageable)"
      style: {
        fill: "#FED7D7"
        stroke: "#E53E3E"
      }
      user_buf: {
        label: "User Buffer\n(malloc)"
        shape: rectangle
        style: {
          fill: "#FEB2B2"
          stroke: "#E53E3E"
        }
      }
    }
    staging: {
      label: "Staging Buffer\n(Pinned)"
      shape: rectangle
      style: {
        fill: "#FED7D7"
        stroke: "#E53E3E"
        stroke-dash: 3
      }
    }
    gpu_mem1: {
      label: "GPU Memory"
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
      }
      device_buf1: {
        label: "Device Buffer"
        shape: rectangle
        style: {
          fill: "#9AE6B4"
          stroke: "#38A169"
        }
      }
    }
    step1: {
      label: "Step 1: CPU Copy"
      width: 280
      code: |'c
        // CPU copies pageable → pinned
        // This is SYNCHRONOUS!
        memcpy(staging, user_buf, bytes);
      '|
      style: {
        fill: "#FED7D7"
        stroke: "#E53E3E"
        stroke-dash: 4
      }
    }
    step2: {
      label: "Step 2: DMA Transfer"
      width: 280
      code: |'c
        // DMA: pinned → GPU
        // This part is async
        cudaMemcpyAsync(d_buf, staging, 
          bytes, H2D, stream);
      '|
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
      }
    }
    host_mem -> step1: "1"
    step1 -> staging
    staging -> step2: "2"
    step2 -> gpu_mem1
    warning1: {
      label: "⚠️ cudaMemcpyAsync with pageable memory\nis NOT fully asynchronous!"
      shape: callout
      style: {
        fill: "#FED7D7"
        stroke: "#E53E3E"
        font-color: "#C53030"
      }
    }
  }
  pinned: {
    direction: down
    label: "Pinned Memory Transfer"
    style: {
      fill: "#F0FFF4"
      stroke: "#38A169"
      stroke-width: 2
    }
    pinned_host: {
      label: "Host Memory (Pinned)"
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
      }
      pinned_buf: {
        label: "Pinned Buffer\n(cudaMallocHost)"
        shape: rectangle
        style: {
          fill: "#9AE6B4"
          stroke: "#38A169"
        }
      }
    }
    gpu_mem2: {
      label: "GPU Memory"
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
      }
      device_buf2: {
        label: "Device Buffer"
        shape: rectangle
        style: {
          fill: "#9AE6B4"
          stroke: "#38A169"
        }
      }
    }
    direct_dma: {
      label: "Direct DMA Transfer"
      width: 280
      code: |'c
        // Direct DMA: pinned → GPU
        // FULLY asynchronous!
        cudaMemcpyAsync(d_buf, pinned_buf,
          bytes, H2D, stream);
      '|
      style: {
        fill: "#9AE6B4"
        stroke: "#38A169"
      }
    }
    pinned_host -> direct_dma: "Single Step"
    direct_dma -> gpu_mem2
    checkmark: {
      label: "✓ True async transfer\n✓ No CPU staging copy\n✓ Higher bandwidth"
      shape: callout
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
        font-color: "#276749"
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  comparison: {
    label: "Memory Transfer Comparison"
    style: {
      fill: "#EDF2F7"
      stroke: "#A0AEC0"
    }
    table: {
      shape: sql_table
      label: "Transfer Characteristics"
      aspect: "Aspect"
      pageable_col: "Pageable"
      pinned_col: "Pinned"
      alloc: "Allocation | malloc() | cudaMallocHost()"
      async: "cudaMemcpyAsync | Pseudo-async* | True async"
      cpu_block: "CPU Blocked | Yes (staging) | No"
      bandwidth: "Bandwidth | Lower | Higher"
      mem_limit: "Memory Limit | System RAM | Limited"
    }
  }
  note: {
    label: "Why Pinned Memory for Async?"
    style: {
      fill: "#EBF8FF"
      stroke: "#3182CE"
    }
    explanation: {
      width: 400
      code: |'c
        // Pageable memory can be:
        // - Paged out to disk at any time
        // - Relocated by OS (defragmentation)
        // - Virtual address ≠ physical address
        //
        // DMA requires stable physical addresses.
        // With pageable memory, CUDA must:
        // 1. Allocate pinned staging buffer
        // 2. CPU copies pageable → pinned (BLOCKS!)
        // 3. Then DMA can proceed
        //
        // Pinned memory is page-locked:
        // - Physical address is constant
        // - Cannot be paged out
        // - DMA can access directly
      '|
      style: {
        fill: "#BEE3F8"
        stroke: "#3182CE"
      }
    }
  }
}
legend: {
  near: bottom-center
  style: {
    fill: "#F7FAFC"
    stroke: "#A0AEC0"
  }
  legend_title: {
    label: "Timeline Comparison"
    shape: text
    style: {
      bold: true
      underline: true
    }
  }
  timeline_container: {
    direction: right
    pageable_timeline: {
      label: "Pageable:"
      style: {
        fill: transparent
        stroke: transparent
      }
      cpu_block: {
        label: "[CPU Block]"
        shape: rectangle
        style: {
          fill: "#FEB2B2"
          stroke: "#E53E3E"
        }
      }
      dma_async: {
        label: "[DMA]"
        shape: rectangle
        style: {
          fill: "#9AE6B4"
          stroke: "#38A169"
        }
      }
      cpu_block -> dma_async
    }
    pinned_timeline: {
      label: "Pinned:"
      style: {
        fill: transparent
        stroke: transparent
      }
      dma_only: {
        label: "[DMA Only - Fully Async]"
        shape: rectangle
        style: {
          fill: "#9AE6B4"
          stroke: "#38A169"
        }
        width: 200
      }
    }
  }
}