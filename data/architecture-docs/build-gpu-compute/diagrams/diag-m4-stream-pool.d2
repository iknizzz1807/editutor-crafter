direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    cpu: "#E8F4FD"
    gpu: "#FFF3E0"
    pool: "#E8F5E9"
    queue: "#FCE4EC"
    stream: "#F3E5F5"
    active: "#4CAF50"
    idle: "#9E9E9E"
  }
}
title: {
  label: "CUDA Stream Pool Architecture"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  cpu_side: {
    direction: down
    label: "CPU (Host)"
    style.fill: ${colors.cpu}
    app_threads: {
      direction: down
      label: "Application Threads"
      style: {
        stroke: "#1976D2"
        stroke-width: 2
      }
      thread0: {
        label: "Thread 0"
        shape: person
      }
      thread1: {
        label: "Thread 1"
        shape: person
      }
      threadN: {
        label: "Thread N"
        shape: person
        style.multiple: true
      }
    }
    work_queue: {
      direction: down
      label: "Work Queue"
      style: {
        fill: ${colors.queue}
        stroke: "#C2185B"
        stroke-width: 2
      }
      wq_desc: {
        label: |md
          Thread-safe queue holding
          pending GPU operations
        |
        shape: text
        style.font-size: 11
      }
      task0: {
        label: "Task: kernel<<<...>>>"
        shape: queue
      }
      task1: {
        label: "Task: cudaMemcpyAsync"
        shape: queue
      }
      task2: {
        label: "Task: ..."
        shape: queue
        style.multiple: true
      }
    }
  }
  pool_section: {
    direction: down
    label: "Stream Pool"
    style.fill: ${colors.pool}
    pool_class: {
      shape: class
      label: "StreamPool (stream_pool.h)"
      -streams: "std::vector<cudaStream_t>"
      -nextIdx: "std::atomic<uint32_t>"
      -mutex: "std::mutex"
      -initialized: "bool"
      +StreamPool(n): "void"
      +~StreamPool(): "void"
      +acquire(): "cudaStream_t"
      +release(s): "void"
      +getNext(): "cudaStream_t"
      +syncAll(): "void"
      +size(): "size_t"
    }
    pool_impl: {
      label: "Pool Instance"
      direction: right
      style: {
        stroke: "#388E3C"
        stroke-width: 2
        border-radius: 8
      }
      streams_array: {
        label: "Pre-allocated Streams"
        direction: right
        style.fill: ${colors.stream}
        s0: {
          label: "Stream 0"
          shape: diamond
          style.fill: ${colors.active}
        }
        s1: {
          label: "Stream 1"
          shape: diamond
          style.fill: ${colors.idle}
        }
        s2: {
          label: "Stream 2"
          shape: diamond
          style.fill: ${colors.active}
        }
        sN: {
          label: "..."
          shape: diamond
          style.multiple: true
        }
      }
      state: {
        direction: down
        label: "Pool State"
        in_use: {
          shape: sql_table
          label: "In-Use Bitmap"
          b0: "0 | 1 | in_use"
          b1: "1 | 0 | in_use"
          b2: "2 | 1 | in_use"
          sz: "N bits total"
        }
        counter: {
          label: "Round-Robin Counter"
          shape: oval
          style.fill: "#FFF9C4"
        }
      }
    }
  }
  gpu_side: {
    direction: down
    label: "GPU (Device)"
    style.fill: ${colors.gpu}
    hw_queues: {
      direction: right
      label: "Hardware Work Queues"
      style: {
        stroke: "#F57C00"
        stroke-width: 2
      }
      ce0: {
        label: "Copy Engine 0\n(H2D)"
        shape: cylinder
      }
      ce1: {
        label: "Copy Engine 1\n(D2H)"
        shape: cylinder
      }
      sm: {
        label: "SMs\n(Compute)"
        shape: rectangle
        style.multiple: true
      }
    }
    execution: {
      direction: right
      label: "Concurrent Execution"
      style.stroke-dash: 3
      ex_desc: {
        label: |md
          Streams mapped to
          independent HW queues
        |
        shape: text
        style.font-size: 11
      }
      timeline: {
        direction: right
        label: ""
        t_s0: {
          label: "S0: [H2D][Kern][D2H]"
          shape: rectangle
          style.fill: ${colors.active}
        }
        t_s1: {
          label: "S1: [H2D][Kern][D2H]"
          shape: rectangle
          style.fill: ${colors.active}
        }
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  flow_section: {
    direction: down
    label: "Stream Assignment Flow"
    style.fill: "#FAFAFA"
    step1: {
      label: "1. Thread requests stream"
      width: 200
    }
    step2: {
      label: "2. Pool returns next available\n    (round-robin: idx = atomic_fetch_add)"
      width: 280
    }
    step3: {
      label: "3. Thread launches async ops"
      width: 200
    }
    step4: {
      label: "4. Operations execute concurrently"
      width: 240
    }
    step5: {
      label: "5. Thread syncs or releases stream"
      width: 240
    }
    step1 -> step2 -> step3 -> step4 -> step5: {
      style.stroke-dash: 3
    }
  }
  benefits: {
    direction: down
    label: "Benefits"
    style: {
      fill: "#E8F5E9"
      border-radius: 8
    }
    b1: {
      label: |md
        **Eliminates Creation Overhead**
        - cudaStreamCreate: ~50-100μs each
        - Pool: one-time init at startup
      |
      shape: rectangle
      width: 220
    }
    b2: {
      label: |md
        **Enables Concurrent Execution**
        - Multiple streams = parallel ops
        - Compute overlapped with transfer
      |
      shape: rectangle
      width: 220
    }
    b3: {
      label: |md
        **Thread-Safe Access**
        - Atomic counter for round-robin
        - No lock contention on getNext()
      |
      shape: rectangle
      width: 220
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  label: "Legend"
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  leg_active: {
    label: "Active Stream"
    shape: diamond
    style.fill: ${colors.active}
  }
  leg_idle: {
    label: "Idle Stream"
    shape: diamond
    style.fill: ${colors.idle}
  }
}
cpu_side.app_threads.thread0 -> pool_section.pool_class: "acquire()"
cpu_side.app_threads.thread1 -> pool_section.pool_class: "getNext()"
pool_section.pool_class -> pool_section.pool_impl.streams_array: "index"
pool_section.pool_impl.streams_array -> gpu_side.hw_queues: "stream ID"
cpu_side.work_queue -> pool_section.pool_class: "dequeue task" {
  style.stroke-dash: 5
  style.animated: true
}