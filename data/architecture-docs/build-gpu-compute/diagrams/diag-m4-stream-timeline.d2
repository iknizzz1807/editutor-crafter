direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    serial: "#E74C3C"
    stream1: "#3498DB"
    stream2: "#2ECC71"
    h2d: "#9B59B6"
    kernel: "#F39C12"
    d2h: "#1ABC9C"
    gap: "#95A5A6"
  }
}
title: |md
  # CUDA Streams: Concurrent Execution Timeline
  ## Default Stream Serialization vs Multi-Stream Overlap
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  serial_section: {
    direction: down
    label: "Default Stream (Stream 0)"
    serial_desc: {
      label: "Implicit Synchronization"
      width: 380
      code: |'c
        // All operations serialize
        cudaMemcpy(d_in, h_in, bytes, H2D);
        kernel<<<grid, block>>>(d_in, d_out);
        cudaMemcpy(h_out, d_out, bytes, D2H);
        // Total = H2D + Kernel + D2H
      '|
    }
    serial_timeline: {
      label: "Timeline View"
      t0: "T0"
      t1: "T1"
      t2: "T2"
      t3: "T3"
      t0.style.fill: transparent
      t1.style.fill: transparent
      t2.style.fill: transparent
      t3.style.fill: transparent
      h2d_s: {
        label: "H2D Transfer"
        shape: rectangle
        width: 180
        style.fill: ${colors.h2d}
        style.stroke: "#7D3C98"
      }
      kernel_s: {
        label: "Kernel"
        shape: rectangle
        width: 200
        style.fill: ${colors.kernel}
        style.stroke: "#D68910"
      }
      d2h_s: {
        label: "D2H Transfer"
        shape: rectangle
        width: 180
        style.fill: ${colors.d2h}
        style.stroke: "#148F77"
      }
      gap1_s: {
        label: "gap"
        shape: rectangle
        width: 20
        style.fill: ${colors.gap}
        style.stroke: transparent
        style.font-color: ${colors.gap}
      }
      gap2_s: {
        label: "gap"
        shape: rectangle
        width: 20
        style.fill: ${colors.gap}
        style.stroke: transparent
        style.font-color: ${colors.gap}
      }
      h2d_s -> gap1_s -> kernel_s -> gap2_s -> d2h_s
    }
    serial_total: {
      label: "Total Time: 100% (baseline)"
      shape: rectangle
      width: 380
      style.fill: ${colors.serial}
      style.stroke: "#C0392B"
      style.font-color: white
      style.bold: true
    }
  }
  multi_section: {
    direction: down
    label: "Multi-Stream Overlap"
    multi_desc: {
      label: "Explicit Concurrency"
      width: 380
      code: |'c
        // 2 streams, double-buffered
        cudaStream_t s0, s1;
        cudaStreamCreate(&s0);
        cudaStreamCreate(&s1);
        // Stream 0
        cudaMemcpyAsync(d0, h0, bytes, H2D, s0);
        kernel<<<grid, block, 0, s0>>>(d0, out0);
        cudaMemcpyAsync(h0, out0, bytes, D2H, s0);
        // Stream 1 (overlaps!)
        cudaMemcpyAsync(d1, h1, bytes, H2D, s1);
        kernel<<<grid, block, 0, s1>>>(d1, out1);
        cudaMemcpyAsync(h1, out1, bytes, D2H, s1);
      '|
    }
    stream0_timeline: {
      label: "Stream 0"
      s0_h2d: {
        label: "H2D"
        shape: rectangle
        width: 120
        style.fill: ${colors.stream1}
        style.stroke: "#2874A6"
      }
      s0_kernel: {
        label: "Kernel"
        shape: rectangle
        width: 160
        style.fill: ${colors.stream1}
        style.stroke: "#2874A6"
      }
      s0_d2h: {
        label: "D2H"
        shape: rectangle
        width: 120
        style.fill: ${colors.stream1}
        style.stroke: "#2874A6"
      }
      s0_h2d -> s0_kernel -> s0_d2h
    }
    stream1_timeline: {
      label: "Stream 1"
      s1_gap: {
        label: ""
        shape: rectangle
        width: 40
        style.fill: transparent
        style.stroke: transparent
      }
      s1_h2d: {
        label: "H2D"
        shape: rectangle
        width: 120
        style.fill: ${colors.stream2}
        style.stroke: "#1E8449"
      }
      s1_kernel: {
        label: "Kernel"
        shape: rectangle
        width: 160
        style.fill: ${colors.stream2}
        style.stroke: "#1E8449"
      }
      s1_d2h: {
        label: "D2H"
        shape: rectangle
        width: 120
        style.fill: ${colors.stream2}
        style.stroke: "#1E8449"
      }
      s1_gap -> s1_h2d -> s1_kernel -> s1_d2h
    }
    overlap_indicator: {
      label: "← Overlap Region →"
      shape: rectangle
      width: 380
      style.fill: "#E8F8F5"
      style.stroke: "#1ABC9C"
      style.stroke-dash: 4
      style.font-color: "#148F77"
    }
    multi_total: {
      label: "Total Time: ~55-65% of baseline"
      shape: rectangle
      width: 380
      style.fill: ${colors.stream2}
      style.stroke: "#1E8449"
      style.font-color: white
      style.bold: true
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  resources_section: {
    direction: down
    label: "Hardware Resource Utilization"
    copy_engine: {
      label: "Copy Engine (DMA)"
      shape: class
      -engine_id: "int"
      -max_concurrent: "1-2"
      +transfer_async(): "void"
    }
    sm_cluster: {
      label: "SMs (Compute)"
      shape: class
      -sm_count: "int"
      -warps_per_sm: "int"
      +execute_kernel(): "void"
    }
    resource_timeline: {
      label: "Resource Occupancy"
      ce_row: {
        label: "Copy Eng"
        shape: rectangle
        width: 400
        style.fill: ${colors.h2d}
        style.stroke: "#7D3C98"
      }
      sm_row: {
        label: "SMs"
        shape: rectangle
        width: 400
        style.fill: ${colors.kernel}
        style.stroke: "#D68910"
      }
      ce_row -> sm_row: "feeds data"
    }
  }
  ideal_vs_real: {
    direction: down
    label: "Ideal vs Realistic Overlap"
    ideal: {
      label: "Ideal (Perfect Overlap)"
      i_stream0: {
        label: "S0"
        shape: rectangle
        width: 300
        style.fill: ${colors.stream1}
        style.stroke: "#2874A6"
      }
      i_stream1: {
        label: "S1"
        shape: rectangle
        width: 300
        style.fill: ${colors.stream2}
        style.stroke: "#1E8449"
      }
      i_stream0 -> i_stream1
    }
    realistic: {
      label: "Realistic (Resource Contention)"
      r_stream0: {
        label: "S0"
        shape: rectangle
        width: 350
        style.fill: ${colors.stream1}
        style.stroke: "#2874A6"
      }
      r_stream1: {
        label: "S1"
        shape: rectangle
        width: 350
        style.fill: ${colors.stream2}
        style.stroke: "#1E8449"
      }
      r_stream0 -> r_stream1
    }
    contention_note: {
      label: "Contention Sources"
      width: 380
      code: |'c
        // Why perfect overlap is rare:
        // 1. Copy engine bandwidth shared
        // 2. L2 cache contention
        // 3. Memory controller queuing
        // 4. SM resource limits
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pitfall_section: {
    direction: down
    label: "Common Pitfalls"
    pitfall1: {
      label: "Mixing Default Stream"
      width: 350
      style.fill: "#FADBD8"
      style.stroke: ${colors.serial}
      code: |'c
        // WRONG: Default stream blocks all
        cudaStream_t s;
        cudaStreamCreate(&s);
        kernel<<<grid, block, 0, s>>>(data);
        // This serializes everything!
        cudaMemcpy(h_out, d_out, bytes, D2H);
      '|
    }
    pitfall2: {
      label: "Pageable Memory"
      width: 350
      style.fill: "#FADBD8"
      style.stroke: ${colors.serial}
      code: |'c
        // WRONG: Pageable = staging copy
        float* h = malloc(bytes);
        cudaMemcpyAsync(d, h, bytes, H2D, s);
        // Silently synchronous staging!
      '|
    }
    pitfall3: {
      label: "Buffer Reuse"
      width: 350
      style.fill: "#FADBD8"
      style.stroke: ${colors.serial}
      code: |'c
        // WRONG: Same buffer, no sync
        for (int i = 0; i < N; i++) {
          kernel<<<grid, block, 0, s>>>(buf);
          // buf reused before kernel done!
        }
      '|
    }
  }
  best_practices: {
    direction: down
    label: "Best Practices"
    practice1: {
      label: "Pinned Memory"
      width: 350
      style.fill: "#D5F5E3"
      style.stroke: ${colors.stream2}
      code: |'c
        // CORRECT: Pinned for true async
        float* h;
        cudaMallocHost(&h, bytes);
        cudaMemcpyAsync(d, h, bytes, H2D, s);
      '|
    }
    practice2: {
      label: "Double Buffering"
      width: 350
      style.fill: "#D5F5E3"
      style.stroke: ${colors.stream2}
      code: |'c
        // CORRECT: N buffers for N streams
        float* d_in[NUM_STREAMS];
        for (int i = 0; i < NUM_STREAMS; i++)
          cudaMalloc(&d_in[i], bytes);
      '|
    }
    practice3: {
      label: "Stream Pool"
      width: 350
      style.fill: "#D5F5E3"
      style.stroke: ${colors.stream2}
      code: |'c
        // CORRECT: Reuse streams
        cudaStream_t pool[MAX_STREAMS];
        int idx = batch % MAX_STREAMS;
        kernel<<<grid, block, 0, pool[idx]>>>();
      '|
    }
  }
}
serial_section.serial_timeline.t0 -> multi_section.stream0_timeline.s0_h2d: "compare"
serial_section.serial_total -> multi_section.multi_total: "speedup 1.5-1.8x"
legend: {
  near: bottom-center
  label: "Legend"
  l_h2d: {
    label: "Host-to-Device"
    shape: rectangle
    width: 100
    style.fill: ${colors.h2d}
  }
  l_kernel: {
    label: "Kernel Exec"
    shape: rectangle
    width: 100
    style.fill: ${colors.kernel}
  }
  l_d2h: {
    label: "Device-to-Host"
    shape: rectangle
    width: 100
    style.fill: ${colors.d2h}
  }
  l_gap: {
    label: "Idle/Gap"
    shape: rectangle
    width: 100
    style.fill: ${colors.gap}
  }
}