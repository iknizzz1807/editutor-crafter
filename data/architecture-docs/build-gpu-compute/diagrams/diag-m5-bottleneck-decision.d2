direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Bottleneck Identification Decision Tree {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
start: Profile Kernel {
  shape: oval
  style: {
    fill: "#E8E8E8"
    stroke: "#333333"
    stroke-width: 2
  }
}
check_mem: Memory Throughput > 75%? {
  shape: diamond
  width: 200
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
}
mem_bound: MEMORY-BOUND {
  shape: rectangle
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
    stroke-width: 3
  }
}
check_compute: Compute Throughput > 75%? {
  shape: diamond
  width: 200
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
}
compute_bound: COMPUTE-BOUND {
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 3
  }
}
latency_bound: LATENCY-BOUND {
  shape: rectangle
  style: {
    fill: "#BBDEFB"
    stroke: "#1565C0"
    stroke-width: 3
  }
}
# Memory-bound optimizations
mem_opt_title: Memory Optimization Strategies {
  shape: rectangle
  style: {
    fill: transparent
    stroke-dash: 3
    stroke: "#C62828"
  }
}
mem_opt: {
  shape: rectangle
  width: 320
  style.fill: "#FFEBEE"
  code: |'text
  • Improve coalescing
  • Use shared memory tiling
  • Reduce memory traffic
  • Increase cache reuse
  • Check L2 hit rate
  '|
}
# Compute-bound optimizations
comp_opt_title: Compute Optimization Strategies {
  shape: rectangle
  style: {
    fill: transparent
    stroke-dash: 3
    stroke: "#2E7D32"
  }
}
comp_opt: {
  shape: rectangle
  width: 320
  style.fill: "#E8F5E9"
  code: |'text
  • Reduce instruction count
  • Use tensor cores
  • Lower precision (FP16)
  • Unroll loops
  • Remove data dependencies
  '|
}
# Latency-bound optimizations
lat_opt_title: Latency Optimization Strategies {
  shape: rectangle
  style: {
    fill: transparent
    stroke-dash: 3
    stroke: "#1565C0"
  }
}
lat_opt: {
  shape: rectangle
  width: 320
  style.fill: "#E3F2FD"
  code: |'text
  • Increase occupancy
  • Reduce register usage
  • Reduce shared memory
  • More threads per block
  • Check warp divergence
  '|
}
# Arrows
start -> check_mem: "Nsight Compute"
check_mem -> mem_bound: "Yes"
check_mem -> check_compute: "No"
check_compute -> compute_bound: "Yes"
check_compute -> latency_bound: "No"
mem_bound -> mem_opt_title: "Focus Here"
mem_opt_title -> mem_opt
compute_bound -> comp_opt_title: "Focus Here"
comp_opt_title -> comp_opt
latency_bound -> lat_opt_title: "Focus Here"
lat_opt_title -> lat_opt
# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 2
  }
  header: "Metric Thresholds" {
    shape: text
    style.bold: true
  }
  m: "Memory > 75% peak → memory-bound"
  c: "Compute > 75% peak → compute-bound"
  l: "Both < 50% → latency-bound"
}