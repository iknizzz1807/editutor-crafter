direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Nsight Compute Analysis Workflow
    Systematic GPU Kernel Optimization
  |
  near: top-center
  shape: text
  style.font-size: 28
}
step1: {
  label: "Step 1: Profile with ncu"
  shape: step
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 3
  cmd: {
    label: |md
      bash
      ncu --set full -o report ./my_app
      ncu-ui report.ncu-rep
      
    |
  }
  key_metrics: {
    label: "Key Metrics Collected"
    shape: rectangle
    style.fill: "#FFF3E0"
    m1: "• Memory Throughput (% of peak)"
    m2: "• Compute Throughput (% of peak)"
    m3: "• Achieved Occupancy (%)"
    m4: "• Warp Stall Reasons"
    m5: "• L2 Cache Hit Rate"
    m6: "• Bank Conflicts"
  }
}
step2: {
  label: "Step 2: Identify Bottleneck"
  shape: diamond
  style.fill: "#FFECB3"
  style.stroke: "#FF8F00"
  style.stroke-width: 3
  decision: {
    label: |md
      **Decision Logic:**
      Memory Throughput > 75%?
      → Memory-bound
      Compute Throughput > 75%?
      → Compute-bound
      Both < 50%?
      → Latency-bound
    |
    shape: rectangle
    style.fill: transparent
  }
}
step3_memory: {
  label: "Step 3a: Memory-Bound Optimization"
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 2
  indicators: {
    label: "Indicators"
    shape: rectangle
    style.fill: "#FFEBEE"
    i1: "Memory throughput > 75%"
    i2: "Warp stalled (memory) > 30%"
    i3: "L2 hit rate < 50%"
    i4: "Low load/store efficiency"
  }
  fixes: {
    label: "Targeted Fixes"
    shape: rectangle
    style.fill: "#C8E6C9"
    f1: "• Improve coalescing (adjacent threads → adjacent addresses)"
    f2: "• Use shared memory tiling"
    f3: "• Reduce memory traffic (compression, precision)"
    f4: "• Increase cache hit rate (blocking)"
    f5: "• Avoid bank conflicts in shared memory"
  }
}
step3_compute: {
  label: "Step 3b: Compute-Bound Optimization"
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  indicators: {
    label: "Indicators"
    shape: rectangle
    style.fill: "#E8F5E9"
    i1: "Compute throughput > 75%"
    i2: "Memory throughput < 50%"
    i3: "Pipeline utilization > 60%"
    i4: "High instruction count"
  }
  fixes: {
    label: "Targeted Fixes"
    shape: rectangle
    style.fill: "#C8E6C9"
    f1: "• Reduce instruction count (algorithmic)"
    f2: "• Use tensor cores (matrix ops)"
    f3: "• Lower precision (FP16 → FP32)"
    f4: "• Break data dependencies (unroll)"
    f5: "• Avoid expensive ops (sqrt, div, sin)"
  }
}
step3_latency: {
  label: "Step 3c: Latency-Bound Optimization"
  shape: rectangle
  style.fill: "#E1BEE7"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  indicators: {
    label: "Indicators"
    shape: rectangle
    style.fill: "#F3E5F5"
    i1: "Both throughputs < 50%"
    i2: "Occupancy < 50%"
    i3: "Issue slot utilization < 30%"
    i4: "High stall cycles"
  }
  fixes: {
    label: "Targeted Fixes"
    shape: rectangle
    style.fill: "#C8E6C9"
    f1: "• Increase occupancy (reduce registers/shared mem)"
    f2: "• More threads per block"
    f3: "• Grid-stride loops (more work per thread)"
    f4: "• Reduce warp divergence"
    f5: "• Kernel fusion (reduce launch overhead)"
  }
}
step4: {
  label: "Step 4: Re-Profile & Verify"
  shape: step
  style.fill: "#B2DFDB"
  style.stroke: "#00695C"
  style.stroke-width: 3
  verify: {
    label: |md
      **Verification Checklist:**
      ✓ Kernel time decreased?
      ✓ Target metric improved?
      ✓ No new bottlenecks introduced?
      ✓ Document before/after metrics
    |
    shape: rectangle
    style.fill: "#E0F2F1"
  }
  decision_final: {
    label: "Performance acceptable?"
    shape: diamond
    style.fill: "#FFF9C4"
  }
  iterate: {
    label: "Return to Step 1"
    shape: rectangle
    style.fill: "#FFECB3"
  }
  done: {
    label: "Optimization Complete"
    shape: oval
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
}
step1 -> step2: "Analyze metrics"
step2 -> step3_memory: "Memory-bound"
step2 -> step3_compute: "Compute-bound"
step2 -> step3_latency: "Latency-bound"
step3_memory -> step4: "Apply fixes"
step3_compute -> step4: "Apply fixes"
step3_latency -> step4: "Apply fixes"
step4.decision_final -> step4.iterate: "No"
step4.iterate -> step1: "Iterate"
step4.decision_final -> step4.done: "Yes"
legend: {
  near: bottom-right
  label: "Bottleneck Classification (Roofline)"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  roofline: |md
    
         FLOPS
           │    ╱────────────────
           │   ╱ Compute-bound
           │  ╱  (horizontal roof)
           │ ╱
           │╱ Memory-bound
           │  (diagonal slope = BW)
           └────────────────────
               FLOPs/Byte
    
  |
}
legend2: {
  near: bottom-left
  label: "Quick Reference: ncu Commands"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  cmds: |md
    bash
    # Full profiling
    ncu --set full -o report ./app
    # Quick profiling
    ncu --set basic -o report ./app
    # Profile specific kernel
    ncu --kernel-name "myKernel" \
        --set full -o report ./app
    # View report
    ncu-ui report.ncu-rep
    
  |
}