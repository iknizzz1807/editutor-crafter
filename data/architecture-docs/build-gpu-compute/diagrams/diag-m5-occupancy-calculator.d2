direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # GPU Occupancy Calculator
  ## Analysis of Hardware Resource Pressure (Registers & Shared Memory)
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  sm_resources: {
    direction: down
    label: "SM Hardware Resource Pool (Ampere GA102)"
    
    limits: {
      shape: sql_table
      label: "Hardware Limits (sm_limits.h)"
      f0: "0x00 | uint32_t | maxThreadsPerSM      = 1536 // Max concurrent threads"
      f1: "0x04 | uint32_t | maxWarpsPerSM        = 48   // 1536 / 32"
      f2: "0x08 | uint32_t | maxBlocksPerSM       = 16   // Schedulable blocks"
      f3: "0x0C | uint32_t | registersPerSM       = 65536// 32-bit registers"
      f4: "0x10 | uint32_t | sharedMemPerSM       = 102400// Bytes (100 KB)"
      sz: "Hardware Constraint Vector"
    }

    formula_logic: {
      label: "Occupancy Logic (occupancy.c)"
      width: 400
      code: |'c
        // Critical Path Analysis
        warps_per_block = ceil(threads / 32.0);
        lim_threads = maxThreadsPerSM / threads;
        lim_regs    = regsPerSM / (threads * regsPerThread);
        lim_smem    = sharedMemPerSM / bytesPerBlock;
        
        max_blocks  = min(lim_threads, lim_regs, lim_smem, 16);
        active_warps = max_blocks * warps_per_block;
        pct_occupancy = (active_warps / 48.0) * 100;
      '|
    }
  }

  kernel_configs: {
    direction: down
    label: "Kernel Configurations"
    
    config_a: {
      shape: sql_table
      label: "Config A: Optimal (Compute Bound)"
      f0: "0x00 | int | threadsPerBlock = 256"
      f1: "0x04 | int | regsPerThread   = 32"
      f2: "0x08 | int | smemPerBlock    = 4096"
      sz: "Expectation: 100% Occupancy"
    }

    config_b: {
      shape: sql_table
      label: "Config B: Reg Pressure (Heavy)"
      f0: "0x00 | int | threadsPerBlock = 256"
      f1: "0x04 | int | regsPerThread   = 64"
      f2: "0x08 | int | smemPerBlock    = 16384"
      sz: "Expectation: ~67% Occupancy"
    }

    config_c: {
      shape: sql_table
      label: "Config C: Register Spiller (Extreme)"
      f0: "0x00 | int | threadsPerBlock = 512"
      f1: "0x04 | int | regsPerThread   = 128"
      f2: "0x08 | int | smemPerBlock    = 8192"
      sz: "Expectation: 33% Occupancy (Limiting)"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  calc_a: {
    direction: down
    label: "Trace: Config A"
    step1: {
      label: "Threads/SM Constraint"
      width: 320
      code: |'c
        1536 / 256 = 6 blocks
      '|
    }
    step2: {
      label: "Register Constraint"
      width: 320
      code: |'c
        regs_block = 256 * 32 = 8192
        65536 / 8192 = 8 blocks
      '|
    }
    result: {
      label: "Final A"
      width: 320
      code: |'c
        Blocks = min(6, 8, 25, 16) = 6
        Warps  = 6 blocks * 8 warps = 48
        Occ    = 48/48 = 100%
      '|
      style.fill: "#90EE90"
    }
  }

  calc_b: {
    direction: down
    label: "Trace: Config B"
    step1: {
      label: "Threads/SM Constraint"
      width: 320
      code: |'c
        1536 / 256 = 6 blocks
      '|
    }
    step2: {
      label: "Register Constraint"
      width: 320
      code: |'c
        regs_block = 256 * 64 = 16384
        65536 / 16384 = 4 blocks
      '|
    }
    result: {
      label: "Final B"
      width: 320
      code: |'c
        Blocks = min(6, 4, 6, 16) = 4
        Warps  = 4 blocks * 8 warps = 32
        Occ    = 32/48 = 66.7%
      '|
      style.fill: "#FFD700"
    }
  }

  calc_c: {
    direction: down
    label: "Trace: Config C"
    step1: {
      label: "Threads/SM Constraint"
      width: 320
      code: |'c
        1536 / 512 = 3 blocks
      '|
    }
    step2: {
      label: "Register Constraint"
      width: 320
      code: |'c
        regs_block = 512 * 128 = 65536
        65536 / 65536 = 1 block
      '|
    }
    result: {
      label: "Final C"
      width: 320
      code: |'c
        Blocks = min(3, 1, 12, 16) = 1
        Warps  = 1 block * 16 warps = 16
        Occ    = 16/48 = 33.3%
      '|
      style.fill: "#FF6B6B"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  visual_bars: {
    direction: down
    label: "Occupancy Visualization (Warp Slots)"
    
    bar_a: {
      direction: right
      label: "Config A (Full)"
      active: {
        width: 480
        height: 25
        style.fill: "#90EE90"
      }
    }
    bar_b: {
      direction: right
      label: "Config B (Partial)"
      active: {
        width: 320
        height: 25
        style.fill: "#FFD700"
      }
      inactive: {
        width: 160
        height: 25
        style.fill: "#E0E0E0"
      }
    }
    bar_c: {
      direction: right
      label: "Config C (Low)"
      active: {
        width: 160
        height: 25
        style.fill: "#FF6B6B"
      }
      inactive: {
        width: 320
        height: 25
        style.fill: "#E0E0E0"
      }
    }
  }

  opt_guide: {
    direction: down
    label: "Optimization Strategies"
    strat1: {
      label: "Register Reduction"
      width: 420
      code: |'c
        // Use __launch_bounds__ to force limit
        __global__ void __launch_bounds__(256, 6)
        MyKernel(...) { ... }

        // Compiler flag for global cap
        nvcc -maxrregcount 32 ...
      '|
    }
    strat2: {
      label: "Memory/Compute Balancing"
      width: 420
      code: |'c
        // Occupancy != Performance
        // Latency hiding often saturates at 50%
        // Higher occupancy increases cache thrash
        if (stalls == "Long Scoreboard") {
          increase_occupancy();
        }
      '|
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  runtime_api: {
    direction: down
    label: "Dynamic Analysis (cuda_api.h)"
    usage: {
      width: 450
      code: |'c
        int maxBlocks;
        cudaOccupancyMaxActiveBlocksPerMultiprocessor(
          &maxBlocks, 
          kernel_ptr, 
          block_size, 
          dynamic_smem_bytes
        );
        // Returns hardware-limited capacity
      '|
    }
  }

  cli_analysis: {
    direction: down
    label: "Static Analysis (ptxas)"
    cmd: {
      width: 450
      code: |'bash
        # verbose output for register usage
        nvcc -ptxas-options=-v kernel.cu
        
        # Result interpretation:
        # ptxas info : Used 64 registers, 1024 bytes smem
        # Check against sm_resources.limits.registersPerSM
      '|
    }
  }
}

legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  l1: "100%: Target for Compute-Bound" {
    style.fill: "#90EE90"
    shape: rectangle
  }
  l2: "50-75%: Sufficient for Memory-Bound" {
    style.fill: "#FFD700"
    shape: rectangle
  }
  l3: "< 40%: Resource Bottleneck Detected" {
    style.fill: "#FF6B6B"
    shape: rectangle
  }
}