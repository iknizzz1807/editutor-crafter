direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
  label: "GPU Optimization Cycle: The Profiling Methodology"
}
row_cycle: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  cycle_container: {
    direction: down
    phase_measure: {
      label: "1. MEASURE"
      style: {
        fill: "#4A90D9"
        stroke: "#2E5A8C"
        stroke-width: 3
        font-color: white
      }
      measure_content: {
        tool_nsys: {
          label: "Nsight Systems"
          shape: rectangle
          style: {
            fill: "#6BA3E0"
            font-color: white
          }
        }
        tool_ncu: {
          label: "Nsight Compute"
          shape: rectangle
          style: {
            fill: "#6BA3E0"
            font-color: white
          }
        }
        metric_mem: "Memory throughput %"
        metric_compute: "Compute throughput %"
        metric_occupancy: "Achieved occupancy"
      }
    }
    phase_analyze: {
      label: "2. ANALYZE"
      style: {
        fill: "#E8A838"
        stroke: "#B8841C"
        stroke-width: 3
        font-color: white
      }
      analyze_content: {
        classify: {
          label: "Classify Bottleneck"
          style: {
            fill: "#F0C060"
            font-color: "#333"
          }
        }
        memory_bound: "Memory-bound: mem > 75%"
        compute_bound: "Compute-bound: comp > 75%"
        latency_bound: "Latency-bound: both < 50%"
        root_cause: "Identify root cause"
      }
    }
    phase_optimize: {
      label: "3. OPTIMIZE"
      style: {
        fill: "#5CB85C"
        stroke: "#3D8B3D"
        stroke-width: 3
        font-color: white
      }
      optimize_content: {
        opt_memory: {
          label: "Memory"
          style: {
            fill: "#7ED17E"
            font-color: "#333"
          }
        }
        mem_actions: "Coalescing, Tiling, Shared mem"
        opt_compute: {
          label: "Compute"
          style: {
            fill: "#7ED17E"
            font-color: "#333"
          }
        }
        comp_actions: "Reduce instructions, Tensor cores"
        opt_latency: {
          label: "Latency"
          style: {
            fill: "#7ED17E"
            font-color: "#333"
          }
        }
        lat_actions: "Increase occupancy, More threads"
      }
    }
    phase_verify: {
      label: "4. VERIFY"
      style: {
        fill: "#9B59B6"
        stroke: "#6C3483"
        stroke-width: 3
        font-color: white
      }
      verify_content: {
        reprofile: {
          label: "Re-profile"
          style: {
            fill: "#B87ED1"
            font-color: white
          }
        }
        compare: "Compare metrics"
        check_new: "Check for new bottlenecks"
        document: "Document change + rationale"
      }
    }
  }
}
cycle_arrows: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  arrow1: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: transparent
    }
  }
}
phase_measure -> phase_analyze: {
  label: "Data"
  style: {
    stroke: "#2E5A8C"
    stroke-width: 3
  }
}
phase_analyze -> phase_optimize: {
  label: "Bottleneck ID"
  style: {
    stroke: "#B8841C"
    stroke-width: 3
  }
}
phase_optimize -> phase_verify: {
  label: "Code change"
  style: {
    stroke: "#3D8B3D"
    stroke-width: 3
  }
}
phase_verify -> phase_measure: {
  label: "Repeat"
  style: {
    stroke: "#6C3483"
    stroke-width: 3
    stroke-dash: 5
  }
  target-arrowhead.shape: arrow
}
row_antipatterns: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  anti_container: {
    label: "Anti-Patterns (Avoid These!)"
    style: {
      fill: "#FFE5E5"
      stroke: "#D9534F"
      stroke-width: 2
    }
    anti1: {
      label: "Premature Optimization"
      style: {
        fill: "#F2DEDE"
        stroke: "#D9534F"
      }
      desc1: "\"This looks slow\" → Optimize"
      desc1_sub: "NO! Measure first"
    }
    anti2: {
      label: "Wrong Bottleneck"
      style: {
        fill: "#F2DEDE"
        stroke: "#D9534F"
      }
      desc2: "Optimize compute on"
      desc2_sub: "memory-bound kernel"
    }
    anti3: {
      label: "Assume Improvement"
      style: {
        fill: "#F2DEDE"
        stroke: "#D9534F"
      }
      desc3: "\"This should be faster\""
      desc3_sub: "NO! Verify with profiler"
    }
    anti4: {
      label: "100% Occupancy Chaser"
      style: {
        fill: "#F2DEDE"
        stroke: "#D9534F"
      }
      desc4: "Sacrifice everything"
      desc4_sub: "for max occupancy"
    }
  }
}
row_principles: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  principles: {
    label: "Core Principles"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
    p1: {
      label: "1. Never optimize without measuring"
      style: {
        fill: "#C8E6C9"
        font-color: "#2E7D32"
        bold: true
      }
    }
    p2: {
      label: "2. Never assume the bottleneck"
      style: {
        fill: "#C8E6C9"
        font-color: "#2E7D32"
        bold: true
      }
    }
    p3: {
      label: "3. Always verify improvement"
      style: {
        fill: "#C8E6C9"
        font-color: "#2E7D32"
        bold: true
      }
    }
    p4: {
      label: "4. Document every change"
      style: {
        fill: "#C8E6C9"
        font-color: "#2E7D32"
        bold: true
      }
    }
  }
}
cycle_container -> anti_container: {
  label: "AVOID"
  style: {
    stroke: "#D9534F"
    stroke-dash: 3
    stroke-width: 2
  }
}
anti_container -> principles: {
  label: "INSTEAD"
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
legend: {
  near: bottom-right
  label: "Decision Tree Quick Reference"
  style: {
    fill: "#F5F5F5"
    stroke: "#999"
    border-radius: 8
  }
  decision: {
    label: "Is mem throughput > 75%?"
    shape: diamond
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
    }
  }
  yes_mem: {
    label: "YES: Memory-bound"
    style: {
      fill: "#4A90D9"
      font-color: white
    }
  }
  no_check_compute: {
    label: "NO: Check compute"
    shape: diamond
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
    }
  }
  yes_compute: {
    label: "Compute > 75%: Compute-bound"
    style: {
      fill: "#5CB85C"
      font-color: white
    }
  }
  latency: {
    label: "Both < 50%: Latency-bound"
    style: {
      fill: "#9B59B6"
      font-color: white
    }
  }
  decision -> yes_mem: "YES"
  decision -> no_check_compute: "NO"
  no_check_compute -> yes_compute: "YES"
  no_check_compute -> latency: "NO"
}