direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Roofline Model: Memory vs Compute Bound
| {near: top-center}
roofline_container: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  axes: {
    label: "Performance Space"
    style.fill: "#f8f9fa"
    style.stroke: "#dee2e6"
    style.stroke-width: 2
    y_axis: {
      label: "Attainable GFLOP/s"
      shape: text
      style.font-size: 14
      style.bold: true
    }
    x_axis: {
      label: "Operational Intensity (FLOPs/Byte)"
      shape: text
      style.font-size: 14
      style.bold: true
    }
  }
  compute_ceiling: {
    label: "Compute-Bound Region\n(Horizontal Ceiling)"
    shape: rectangle
    width: 600
    height: 60
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    style.stroke-width: 3
    style.stroke-dash: 0
    peak_label: {
      label: "Peak Compute: 19,500 GFLOP/s (RTX 3080 FP32)"
      shape: text
      style.font-size: 12
      style.font-color: "#1976d2"
      style.bold: true
    }
  }
  memory_slope: {
    label: ""
    shape: parallelogram
    width: 200
    height: 280
    style.fill: "linear-gradient(135deg, #fff3e0 0%, #ffcc80 100%)"
    style.stroke: "#e65100"
    style.stroke-width: 3
    slope_label: {
      label: "Memory-Bound Region\n(Diagonal Slope)"
      shape: text
      style.font-size: 13
      style.bold: true
      style.font-color: "#e65100"
    }
    bandwidth_label: {
      label: "Peak Memory BW: 760 GB/s"
      shape: text
      style.font-size: 11
      style.font-color: "#e65100"
    }
    formula: {
      label: "Perf = BW × Intensity"
      shape: text
      style.font-size: 11
      style.italic: true
      style.font-color: "#bf360c"
    }
  }
  ridge_point: {
    label: "Ridge Point\n~26 FLOPs/Byte"
    shape: diamond
    width: 80
    height: 80
    style.fill: "#7b1fa2"
    style.stroke: "#4a148c"
    style.stroke-width: 3
    style.font-color: white
    style.bold: true
  }
  kernel_examples: {
    label: "Example Kernel Positions"
    style.fill: "#fafafa"
    style.stroke: "#bdbdbd"
    style.stroke-dash: 3
    vector_add: {
      label: "Vector Add\nIntensity: 0.08 FLOP/B\n~60 GB/s achieved"
      shape: circle
      style.fill: "#ef5350"
      style.stroke: "#b71c1c"
      style.stroke-width: 2
      style.font-color: white
      style.font-size: 10
    }
    matrix_transpose: {
      label: "Matrix Transpose\nIntensity: 0.25 FLOP/B\n~500 GB/s achieved"
      shape: circle
      style.fill: "#ff7043"
      style.stroke: "#bf360c"
      style.stroke-width: 2
      style.font-color: white
      style.font-size: 10
    }
    stencil: {
      label: "Stencil (3x3)\nIntensity: 4 FLOP/B\nMemory-bound"
      shape: circle
      style.fill: "#ffca28"
      style.stroke: "#f57f17"
      style.stroke-width: 2
      style.font-size: 10
    }
    matrix_mult: {
      label: "Matrix Multiply\nIntensity: 64 FLOP/B\nCompute-bound"
      shape: circle
      style.fill: "#66bb6a"
      style.stroke: "#2e7d32"
      style.stroke-width: 2
      style.font-color: white
      style.font-size: 10
    }
    convolution: {
      label: "Deep Convolution\nIntensity: 200+ FLOP/B\nCompute-bound"
      shape: circle
      style.fill: "#42a5f5"
      style.stroke: "#1565c0"
      style.stroke-width: 2
      style.font-color: white
      style.font-size: 10
    }
  }
}
legend: {
  near: bottom-center
  label: "Interpretation Guide"
  style.fill: white
  style.stroke: "#9e9e9e"
  style.stroke-dash: 2
  mem_bound: {
    label: "Below Diagonal: Memory-Bound\n→ Optimize memory access, coalescing, caching"
    shape: rectangle
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
  }
  comp_bound: {
    label: "Below Horizontal: Compute-Bound\n→ Optimize instruction count, use tensor cores"
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
  }
  at_roof: {
    label: "At Roofline: Optimized\n→ Algorithmic changes needed for further gains"
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
  }
}
intensity_scale: {
  near: bottom-right
  label: "Operational Intensity Zones"
  style.fill: transparent
  style.stroke: transparent
  low: {
    label: "< 10 FLOP/B\nAlmost always\nmemory-bound"
    shape: rectangle
    style.fill: "#ffebee"
    style.stroke: "#ef5350"
    style.font-size: 11
  }
  mid: {
    label: "10-50 FLOP/B\nTransition zone\nProfile to determine"
    shape: rectangle
    style.fill: "#fff8e1"
    style.stroke: "#ffc107"
    style.font-size: 11
  }
  high: {
    label: "> 50 FLOP/B\nLikely compute-bound\n(if roof not hit)"
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#4caf50"
    style.font-size: 11
  }
}
memory_slope -> compute_ceiling: "Slope meets ceiling\nat ridge point" {
  style.stroke: "#7b1fa2"
  style.stroke-width: 3
  style.stroke-dash: 5
}
kernel_examples.vector_add -> memory_slope: "Far below roof" {
  style.stroke: "#ef5350"
  style.stroke-dash: 3
}
kernel_examples.matrix_transpose -> memory_slope: "Closer to roof" {
  style.stroke: "#ff7043"
  style.stroke-dash: 3
}
kernel_examples.stencil -> ridge_point: "Near ridge" {
  style.stroke: "#ffca28"
  style.stroke-dash: 3
}
kernel_examples.matrix_mult -> compute_ceiling: "At compute ceiling" {
  style.stroke: "#66bb6a"
  style.stroke-dash: 3
}
kernel_examples.convolution -> compute_ceiling: "Well below compute ceiling" {
  style.stroke: "#42a5f5"
  style.stroke-dash: 3
}