direction: down
title: GPU Compute Programming System Blueprint {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
# Milestone Index Panel
milestone_index: {
  label: "Milestone Index\n━━━━━━━━━━━━━━━━━━━━━━━━"
  shape: class
  style.fill: "#E8F4FD"
  m1_ref: "M1: CUDA Execution Model & Thread Hierarchy"
  m2_ref: "M2: Memory Hierarchy & Coalescing"
  m3_ref: "M3: Parallel Primitives & Algorithms"
  m4_ref: "M4: Streams & Asynchronous Execution"
  m5_ref: "M5: Profiling & Performance Analysis"
  legend: "━━━━━━━━━━━━━━━━━━━━━━━━\nLegend:\n▶ sql_table = Data Structures\n▶ class = Modules/Classes\n▶ rectangle = Concepts\n▶ → = Data Flow\n▶ ⟹ = Dependency"
}
# Row 1: M1 - CUDA Execution Model
row1: {
  direction: right
  m1_header: {
    label: "MILESTONE 1\nCUDA Execution Model"
    shape: rectangle
    style.fill: "#1a1a2e"
    style.font-color: "#fff"
    style.stroke: "#4a4a6a"
  }
  m1_structures: {
    direction: down
    launch_config: {
      shape: sql_table
      label: "LaunchConfig"
      grid_dim: "dim3 gridDim | +0x00 | 12 bytes | Example: (256,1,1)"
      block_dim: "dim3 blockDim | +0x0C | 12 bytes | Example: (128,1,1)"
      shared_mem: "size_t sharedMem | +0x18 | 8 bytes | Default: 0"
      stream: "cudaStream_t stream | +0x20 | 8 bytes | Default: 0"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 40 bytes"
    }
    thread_id: {
      shape: sql_table
      label: "ThreadIdx"
      x: "uint32_t x | +0x00 | 4 bytes | Range: 0-blockDim.x"
      y: "uint32_t y | +0x04 | 4 bytes | Range: 0-blockDim.y"
      z: "uint32_t z | +0x08 | 4 bytes | Range: 0-blockDim.z"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 12 bytes"
    }
    warp_state: {
      shape: sql_table
      label: "WarpState"
      warp_id: "int warpId | +0x00 | 4 bytes | Computed: threadIdx.x/32"
      lane_id: "int laneId | +0x04 | 4 bytes | Range: 0-31"
      active_mask: "uint32_t activeMask | +0x08 | 4 bytes | Bitmask of active threads"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 12 bytes"
    }
  }
  m1_modules: {
    direction: down
    vector_ops_h: {
      shape: class
      label: "vector_ops.h"
      style.fill: "#2d2d44"
      style.font-color: "#fff"
      namespace: "namespace gpu::vector"
      saxpy_kernel: "__global__ void saxpy_kernel(\n  int n,\n  float a,\n  const float* x,\n  float* y\n)\nPerforms y[i] = a*x[i] + y[i]"
      vector_add_kernel: "__global__ void vector_add_kernel(\n  int n,\n  const float* a,\n  const float* b,\n  float* c\n)\nPerforms c[i] = a[i] + b[i]"
      compute_grid: "dim3 compute_grid(int n)\nReturns optimal grid dimensions"
    }
    vector_ops_cu: {
      shape: class
      label: "vector_ops.cu"
      style.fill: "#1e3a5f"
      style.font-color: "#fff"
      launch_saxpy: "void launch_saxpy(\n  int n,\n  float a,\n  const float* d_x,\n  float* d_y,\n  cudaStream_t stream\n)\nLaunches SAXPY kernel with auto config"
      occupancy: "int compute_occupancy(\n  int blockSize,\n  size_t sharedMem\n)\nReturns occupancy percentage"
    }
  }
  m1_concepts: {
    direction: down
    simt_model: {
      shape: rectangle
      label: "SIMT Execution Model\n━━━━━━━━━━━━━━━━━━━━\n• 32 threads per warp\n• Lock-step execution\n• Divergence handling\n• Predicate masking"
      style.fill: "#2d4a3e"
    }
    thread_hierarchy: {
      shape: rectangle
      label: "Thread Hierarchy\n━━━━━━━━━━━━━━━━━━━━\nGrid → Blocks → Threads\nGrid: up to (2^31-1, 65535, 65535)\nBlock: up to 1024 threads\nWarp: 32 threads (SIMD)"
      style.fill: "#4a2d4a"
    }
  }
}
# Row 2: M2 - Memory Hierarchy
row2: {
  direction: right
  m2_header: {
    label: "MILESTONE 2\nMemory Hierarchy"
    shape: rectangle
    style.fill: "#1a1a2e"
    style.font-color: "#fff"
    style.stroke: "#4a4a6a"
  }
  m2_structures: {
    direction: down
    tile_params: {
      shape: sql_table
      label: "TileParams"
      tile_width: "int TILE_WIDTH | +0x00 | 4 bytes | Typical: 16 or 32"
      tile_height: "int TILE_HEIGHT | +0x04 | 4 bytes | Typical: 16 or 32"
      padding: "int PADDING | +0x08 | 4 bytes | Bank conflict avoidance"
      shared_size: "size_t sharedSize | +0x0C | 8 bytes | Computed: tileWidth*tileHeight*sizeof(T)"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 20 bytes"
    }
    mem_info: {
      shape: sql_table
      label: "MemoryRegion"
      ptr: "void* ptr | +0x00 | 8 bytes | Device pointer"
      size: "size_t size | +0x08 | 8 bytes | Allocation size"
      type: "MemoryType type | +0x10 | 4 bytes | GLOBAL|SHARED|REGISTER"
      pitch: "size_t pitch | +0x14 | 8 bytes | Row pitch for 2D"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 28 bytes"
    }
    coalescing_info: {
      shape: sql_table
      label: "CoalescingStats"
      transactions: "int transactions | +0x00 | 4 bytes | Memory transactions"
      bytes_transferred: "int bytesTransferred | +0x04 | 4 bytes | Total bytes moved"
      efficiency: "float efficiency | +0x08 | 4 bytes | Ratio: useful/total"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 12 bytes"
    }
  }
  m2_modules: {
    direction: down
    transpose_h: {
      shape: class
      label: "transpose.h"
      style.fill: "#2d2d44"
      style.font-color: "#fff"
      namespace: "namespace gpu::memory"
      naive_transpose: "__global__ void naive_transpose(\n  const float* input,\n  float* output,\n  int width,\n  int height\n)\nNon-coalesced baseline"
      tiled_transpose: "__global__ void tiled_transpose(\n  const float* input,\n  float* output,\n  int width,\n  int height\n)\nShared memory tiled version"
    }
    transpose_cu: {
      shape: class
      label: "transpose.cu"
      style.fill: "#1e3a5f"
      style.font-color: "#fff"
      pad_kernel: "__global__ void pad_kernel(\n  const float* in,\n  float* out,\n  int w, int h, int pitch\n)\nAvoids bank conflicts via padding"
      benchmark: "void benchmark_transpose(\n  int size,\n  int iterations\n)\nCompares naive vs tiled performance"
    }
  }
  m2_concepts: {
    direction: down
    memory_hierarchy: {
      shape: rectangle
      label: "Memory Hierarchy\n━━━━━━━━━━━━━━━━━━━━\nRegisters (1 cycle)\nShared (1-32 cycles, ~20TB/s)\nL1 Cache (per SM)\nL2 Cache (shared, ~4TB/s)\nGlobal (400-800 cycles, ~900GB/s)"
      style.fill: "#3d2d1e"
    }
    coalescing: {
      shape: rectangle
      label: "Memory Coalescing\n━━━━━━━━━━━━━━━━━━━━\n• Adjacent threads → adjacent addresses\n• 128-byte segment alignment\n• Warp-wide access patterns\n• L1/L2 transaction merging"
      style.fill: "#1e3d3d"
    }
    bank_conflicts: {
      shape: rectangle
      label: "Bank Conflicts\n━━━━━━━━━━━━━━━━━━━━\n• 32 banks, 4-byte wide\n• Stride ≠ 32×k avoids conflicts\n• Padding techniques\n• XOR schemes for transposes"
      style.fill: "#3d1e3d"
    }
  }
}
# Row 3: M3 - Parallel Primitives
row3: {
  direction: right
  m3_header: {
    label: "MILESTONE 3\nParallel Primitives"
    shape: rectangle
    style.fill: "#1a1a2e"
    style.font-color: "#fff"
    style.stroke: "#4a4a6a"
  }
  m3_structures: {
    direction: down
    reduce_config: {
      shape: sql_table
      label: "ReduceConfig"
      block_size: "int BLOCK_SIZE | +0x00 | 4 bytes | Must be power of 2"
      elements_per_thread: "int EPT | +0x04 | 4 bytes | Typically 4-8"
      algorithm: "ReduceAlgo algo | +0x08 | 4 bytes | INTERLEAVED|SEQUENTIAL|WARP"
      use_shared: "bool useShared | +0x0C | 1 byte | Use shared memory"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 16 bytes"
    }
    scan_config: {
      shape: sql_table
      label: "ScanConfig"
      scan_type: "ScanType type | +0x00 | 4 bytes | INCLUSIVE|EXCLUSIVE"
      data_type: "DataType dtype | +0x04 | 4 bytes | INT|FLOAT|DOUBLE"
      op: "ScanOp op | +0x08 | 4 bytes | ADD|MAX|MIN"
      block_size: "int blockSize | +0x0C | 4 bytes | Power of 2, max 1024"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 16 bytes"
    }
    hist_config: {
      shape: sql_table
      label: "HistogramConfig"
      num_bins: "int numBins | +0x00 | 4 bytes | Range partitions"
      bins_per_block: "int binsPerBlock | +0x04 | 4 bytes | Shared memory bins"
      use_privatized: "bool privatized | +0x08 | 1 byte | Per-block histograms"
      atomics_type: "AtomicType atomic | +0x09 | 1 byte | GLOBAL|SHARED"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 10 bytes"
    }
  }
  m3_modules: {
    direction: down
    reduce_cu: {
      shape: class
      label: "reduce.cu"
      style.fill: "#2d2d44"
      style.font-color: "#fff"
      namespace: "namespace gpu::reduce"
      reduce_kernel: "__global__ void reduce_kernel(\n  const T* input,\n  T* output,\n  int n\n)\nTree-based parallel reduction"
      warp_reduce: "__device__ T warp_reduce(\n  T val\n)\nUses __shfl_down_sync"
      host_reduce: "T reduce(\n  const T* d_input,\n  int n,\n  cudaStream_t stream\n)\nHost wrapper with multi-block"
    }
    scan_cu: {
      shape: class
      label: "scan.cu"
      style.fill: "#1e3a5f"
      style.font-color: "#fff"
      blelloch_scan: "__global__ void blelloch_scan(\n  T* data,\n  T* partials,\n  int n\n)\nWork-efficient O(n) scan"
      hillis_steele: "__global__ void hillis_steele(\n  T* data,\n  int n\n)\nO(n log n) but simpler"
      uniform_add: "__global__ void uniform_add(\n  T* data,\n  const T* partials,\n  int n\n)\nSecond pass for multi-block"
    }
    histogram_cu: {
      shape: class
      label: "histogram.cu"
      style.fill: "#3d1e1e"
      style.font-color: "#fff"
      global_histogram: "__global__ void global_histogram(\n  const uchar* input,\n  int* histogram,\n  int n,\n  int numBins\n)\nGlobal atomic approach"
      privatized_hist: "__global__ void privatized_histogram(\n  const uchar* input,\n  int* histogram,\n  int n,\n  int numBins\n)\nShared memory privatization"
      aggregation: "__global__ void aggregate_histograms(\n  const int* localHists,\n  int* globalHist,\n  int numBlocks,\n  int numBins\n)\nFinal reduction step"
    }
  }
  m3_algorithms: {
    direction: down
    reduction_algo: {
      shape: rectangle
      label: "Parallel Reduction\n━━━━━━━━━━━━━━━━━━━━\nAlgorithm: Tree-based\nComplexity: O(log n) parallel\nSteps: n→n/2→n/4→...→1\nOptimizations:\n• Warp shuffles\n• Loop unrolling\n• Shared memory banking"
      style.fill: "#2d4a2d"
    }
    scan_algo: {
      shape: rectangle
      label: "Prefix Sum (Scan)\n━━━━━━━━━━━━━━━━━━━━\nBlelloch (Work-Efficient):\n  Upsweep + Downsweep\n  O(n) work, O(log n) depth\n\nHillis-Steele:\n  O(n log n) work\n  Better for small arrays"
      style.fill: "#4a2d2d"
    }
    histogram_algo: {
      shape: rectangle
      label: "Histogram\n━━━━━━━━━━━━━━━━━━━━\nGlobal Atomics: Simple, slow\nPrivatized: Fast, more memory\n\nBin Mapping:\n  atomicAdd(&hist[val], 1)\n\nAggregation: Final reduce"
      style.fill: "#2d2d4a"
    }
  }
}
# Row 4: M4 - Streams & Async
row4: {
  direction: right
  m4_header: {
    label: "MILESTONE 4\nStreams & Async"
    shape: rectangle
    style.fill: "#1a1a2e"
    style.font-color: "#fff"
    style.stroke: "#4a4a6a"
  }
  m4_structures: {
    direction: down
    stream_config: {
      shape: sql_table
      label: "StreamConfig"
      num_streams: "int numStreams | +0x00 | 4 bytes | Pipeline depth"
      priority: "int priority | +0x04 | 4 bytes | Higher=lower value"
      flags: "unsigned int flags | +0x08 | 4 bytes | cudaStreamNonBlocking"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 12 bytes"
    }
    pipeline_stage: {
      shape: sql_table
      label: "PipelineStage"
      stage_id: "int stageId | +0x00 | 4 bytes | 0=H2D, 1=Compute, 2=D2H"
      stream_id: "int streamId | +0x04 | 4 bytes | Associated stream"
      event: "cudaEvent_t event | +0x08 | 8 bytes | Sync point"
      status: "StageStatus status | +0x10 | 4 bytes | PENDING|RUNNING|DONE"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 24 bytes"
    }
    pinned_buffer: {
      shape: sql_table
      label: "PinnedBuffer"
      host_ptr: "void* hostPtr | +0x00 | 8 bytes | Page-locked memory"
      device_ptr: "void* devicePtr | +0x08 | 8 bytes | Device buffer"
      size: "size_t size | +0x10 | 8 bytes | Buffer capacity"
      is_mapped: "bool isMapped | +0x18 | 1 byte | Zero-copy flag"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 25 bytes"
    }
  }
  m4_modules: {
    direction: down
    stream_pipeline_cu: {
      shape: class
      label: "stream_pipeline.cu"
      style.fill: "#2d2d44"
      style.font-color: "#fff"
      namespace: "namespace gpu::stream"
      create_pipeline: "StreamPipeline* create_pipeline(\n  int numStreams,\n  int priority\n)\nAllocates streams and events"
      enqueue_op: "void enqueue_op(\n  StreamPipeline* pipeline,\n  OperationType type,\n  void* data,\n  size_t size,\n  int streamIdx\n)\nAdds operation to pipeline"
      sync_pipeline: "void sync_pipeline(\n  StreamPipeline* pipeline\n)\nWaits for all streams"
    }
    stream_pool_cu: {
      shape: class
      label: "stream_pool.cu"
      style.fill: "#1e3a5f"
      style.font-color: "#fff"
      pool_init: "StreamPool* pool_init(\n  int poolSize,\n  int maxPending\n)\nCreates stream pool"
      acquire_stream: "int acquire_stream(\n  StreamPool* pool\n)\nReturns available stream index"
      release_stream: "void release_stream(\n  StreamPool* pool,\n  int streamIdx\n)\nReturns stream to pool"
    }
  }
  m4_concepts: {
    direction: down
    stream_execution: {
      shape: rectangle
      label: "Stream-Based Execution\n━━━━━━━━━━━━━━━━━━━━\nDefault Stream: Sequential\nNamed Streams: Concurrent\n\nRules:\n• Operations in same stream: sequential\n• Operations in different streams: concurrent\n• cudaStreamSynchronize() for wait"
      style.fill: "#1e4a1e"
    }
    pinned_memory: {
      shape: rectangle
      label: "Pinned (Page-Locked) Memory\n━━━━━━━━━━━━━━━━━━━━\ncudaMallocHost(): Host pinned\ncudaHostRegister(): Pin existing\n\nBenefits:\n• DMA transfers\n• Faster async copy\n• Enables overlap"
      style.fill: "#4a1e4a"
    }
    pipeline_pattern: {
      shape: rectangle
      label: "Pipeline Pattern\n━━━━━━━━━━━━━━━━━━━━\n3-Stage Pipeline:\n  H2D → Compute → D2H\n\nStream i handles:\n  Chunk[i]: Copy In\n  Chunk[i-1]: Compute\n  Chunk[i-2]: Copy Out"
      style.fill: "#1e1e4a"
    }
  }
}
# Row 5: M5 - Profiling
row5: {
  direction: right
  m5_header: {
    label: "MILESTONE 5\nProfiling"
    shape: rectangle
    style.fill: "#1a1a2e"
    style.font-color: "#fff"
    style.stroke: "#4a4a6a"
  }
  m5_structures: {
    direction: down
    kernel_metrics: {
      shape: sql_table
      label: "KernelMetrics"
      kernel_name: "char name[64] | +0x00 | 64 bytes | Kernel identifier"
      duration_us: "float durationUs | +0x40 | 4 bytes | Execution time"
      grid_size: "dim3 gridSize | +0x44 | 12 bytes | Grid dimensions"
      block_size: "dim3 blockSize | +0x50 | 12 bytes | Block dimensions"
      registers: "int registers | +0x5C | 4 bytes | Registers per thread"
      shared_mem: "size_t sharedMem | +0x60 | 8 bytes | Static + dynamic shared"
      occupancy: "float occupancy | +0x68 | 4 bytes | Active warps / max warps"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 104 bytes"
    }
    roofline_point: {
      shape: sql_table
      label: "RooflinePoint"
      arith_intensity: "float arithIntensity | +0x00 | 4 bytes | FLOPs/Byte"
      gflops: "float gflops | +0x04 | 4 bytes | Achieved GFLOPs"
      bandwidth: "float bandwidth | +0x08 | 4 bytes | Achieved GB/s"
      peak_flops: "float peakFlops | +0x0C | 4 bytes | Peak GFLOPs"
      peak_bw: "float peakBw | +0x10 | 4 bytes | Peak GB/s"
      bottleneck: "BottleneckType type | +0x14 | 4 bytes | COMPUTE|MEMORY|BALANCED"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 24 bytes"
    }
    profiler_config: {
      shape: sql_table
      label: "ProfilerConfig"
      output_file: "char outputFile[256] | +0x00 | 256 bytes | .qdrep or .json"
      metrics: "uint64_t metrics | +0x100 | 8 bytes | Metric bitmask"
      trace_mode: "TraceMode mode | +0x108 | 4 bytes | KERNEL|API|ALL"
      sample_rate: "int sampleRate | +0x10C | 4 bytes | Sampling interval"
      total_size: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTotal Size: 272 bytes"
    }
  }
  m5_modules: {
    direction: down
    profiling_framework_cu: {
      shape: class
      label: "profiling_framework.cu"
      style.fill: "#2d2d44"
      style.font-color: "#fff"
      namespace: "namespace gpu::profile"
      start_profiling: "void start_profiling(\n  const ProfilerConfig* config\n)\nStarts Nsight capture"
      end_profiling: "void end_profiling()\nEnds Nsight capture"
      get_kernel_metrics: "KernelMetrics get_kernel_metrics(\n  const char* kernelName\n)\nReturns collected metrics"
      calculate_occupancy: "float calculate_occupancy(\n  int blockSize,\n  size_t sharedMem,\n  int registers\n)\nComputes theoretical occupancy"
    }
    roofline_cu: {
      shape: class
      label: "roofline.cu"
      style.fill: "#1e3a5f"
      style.font-color: "#fff"
      measure_roofline: "RooflinePoint measure_roofline(\n  const KernelMetrics* km,\n  int64_t flops,\n  int64_t bytes\n)\nComputes roofline analysis"
      plot_roofline: "void plot_roofline(\n  const RooflinePoint* points,\n  int n\n)\nGenerates roofline visualization"
      classify_bottleneck: "BottleneckType classify_bottleneck(\n  float arithIntensity,\n  float ridgePoint\n)\nReturns COMPUTE or MEMORY"
    }
  }
  m5_tools: {
    direction: down
    nsight_systems: {
      shape: rectangle
      label: "Nsight Systems\n━━━━━━━━━━━━━━━━━━━━\nTimeline analysis tool\n\nUsage:\n  nsys profile ./app\n  nsys-ui report.qdrep\n\nMetrics:\n• API calls\n• Kernel timelines\n• Memory transfers\n• Stream concurrency"
      style.fill: "#4a4a1e"
    }
    nsight_compute: {
      shape: rectangle
      label: "Nsight Compute\n━━━━━━━━━━━━━━━━━━━━\nKernel profiling tool\n\nUsage:\n  ncu ./app\n  ncu-ui report.ncu-rep\n\nMetrics:\n• Warp execution\n• Memory throughput\n• Instruction mix\n• Roofline analysis"
      style.fill: "#1e4a4a"
    }
    roofline_model: {
      shape: rectangle
      label: "Roofline Model\n━━━━━━━━━━━━━━━━━━━━\nAI = FLOPs / Bytes\nRidge Point = PeakFLOPs/PeakBW\n\nAI < Ridge: Memory-bound\nAI > Ridge: Compute-bound\n\nOptimization focus based on\nposition relative to roof"
      style.fill: "#4a1e1e"
    }
  }
}
# Scale Indicators
scale_panel: {
  direction: right
  label: "Scale Indicators\n━━━━━━━━━━━━━━━━━━━━"
  shape: class
  style.fill: "#f0f0f0"
  memory_scale: "Memory Scale:\n  Register: 1-64 bytes/thread\n  Shared: 1-48 KB/block\n  Global: MBs to GBs\n  L2 Cache: 4-6 MB (device-wide)"
  thread_scale: "Thread Scale:\n  Warp: 32 threads\n  Block: up to 1024 threads\n  Grid: millions of threads\n  SM: 2048 max threads (A100)"
  time_scale: "Time Scale:\n  Register access: ~1 cycle\n  Shared memory: ~20 cycles\n  L1/L2 cache: ~100 cycles\n  Global memory: 400-800 cycles\n  PCIe transfer: microseconds"
}
