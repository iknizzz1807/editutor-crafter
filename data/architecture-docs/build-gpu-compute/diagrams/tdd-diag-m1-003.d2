direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# 0. HEADER & TITLES
# -----------------------------------------------------------------------------
title: "SIMT Warp Execution Model (NVIDIA Ampere/Hopper Style)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------
# 1. WARP HARDWARE CONTAINER
# -----------------------------------------------------------------------------
Warp: {
  label: "Streaming Multiprocessor: Warp Unit (32 Threads)"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a9eff"
    stroke-width: 4
    border-radius: 8
  }

  Control: {
    ProgramCounter: {
      label: "Shared PC: 0x0040F100"
      shape: rectangle
      style: {
        fill: "#2d2d44"
        stroke: "#ff6b6b"
        stroke-width: 2
        font-color: "#ffffff"
        bold: true
      }
    }

    InstructionFetch: {
      label: "Instruction Buffer\nOP: IMAD.WIDE [R1], R2, R3"
      shape: rectangle
      style: {
        fill: "#2d2d44"
        stroke: "#ffd93d"
        stroke-width: 2
        font-color: "#ffffff"
      }
    }
    
    ActiveMask: {
      label: "Active Mask (32-bit)\nValue: 0x0000FFFF"
      shape: rectangle
      style: {
        fill: "#2d2d44"
        stroke: "#a29bfe"
        stroke-width: 2
        font-color: "#ffffff"
      }
    }
    
    ProgramCounter -> InstructionFetch: "Fetch" {
      style: { stroke: "#4a9eff"; stroke-width: 2; animated: true }
    }
  }

  # Execution Lanes (Threads)
  Threads: {
    grid-columns: 8
    grid-gap: 10
    label: "SIMT Execution Lanes (SP/INT32 Units)"
    
    # Path A: Active Threads (0-15)
    T0: "T0"; T1: "T1"; T2: "T2"; T3: "T3"; T4: "T4"; T5: "T5"; T6: "T6"; T7: "T7"
    T8: "T8"; T9: "T9"; T10: "T10"; T11: "T11"; T12: "T12"; T13: "T13"; T14: "T14"; T15: "T15"

    # Path B: Masked Threads (16-31)
    T16: "T16"; T17: "T17"; T18: "T18"; T19: "T19"; T20: "T20"; T21: "T21"; T22: "T22"; T23: "T23"
    T24: "T24"; T25: "T25"; T26: "T26"; T27: "T27"; T28: "T28"; T29: "T29"; T30: "T30"; T31: "T31"

    # Styles for Active Threads (Green)
    T0.style.fill: "#00b894"; T1.style.fill: "#00b894"; T2.style.fill: "#00b894"; T3.style.fill: "#00b894"
    T4.style.fill: "#00b894"; T5.style.fill: "#00b894"; T6.style.fill: "#00b894"; T7.style.fill: "#00b894"
    T8.style.fill: "#00b894"; T9.style.fill: "#00b894"; T10.style.fill: "#00b894"; T11.style.fill: "#00b894"
    T12.style.fill: "#00b894"; T13.style.fill: "#00b894"; T14.style.fill: "#00b894"; T15.style.fill: "#00b894"
    T0.style.bold: true; T1.style.bold: true; T2.style.bold: true; T3.style.bold: true
    T4.style.bold: true; T5.style.bold: true; T6.style.bold: true; T7.style.bold: true
    T8.style.bold: true; T9.style.bold: true; T10.style.bold: true; T11.style.bold: true
    T12.style.bold: true; T13.style.bold: true; T14.style.bold: true; T15.style.bold: true

    # Styles for Inactive Threads (Red/Dashed)
    T16.style.fill: "#e17055"; T17.style.fill: "#e17055"; T18.style.fill: "#e17055"; T19.style.fill: "#e17055"
    T20.style.fill: "#e17055"; T21.style.fill: "#e17055"; T22.style.fill: "#e17055"; T23.style.fill: "#e17055"
    T24.style.fill: "#e17055"; T25.style.fill: "#e17055"; T26.style.fill: "#e17055"; T27.style.fill: "#e17055"
    T28.style.fill: "#e17055"; T29.style.fill: "#e17055"; T30.style.fill: "#e17055"; T31.style.fill: "#e17055"
    T16.style.stroke-dash: 3; T17.style.stroke-dash: 3; T18.style.stroke-dash: 3; T19.style.stroke-dash: 3
    T20.style.stroke-dash: 3; T21.style.stroke-dash: 3; T22.style.stroke-dash: 3; T23.style.stroke-dash: 3
    T24.style.stroke-dash: 3; T25.style.stroke-dash: 3; T26.style.stroke-dash: 3; T27.style.stroke-dash: 3
    T28.style.stroke-dash: 3; T29.style.stroke-dash: 3; T30.style.stroke-dash: 3; T31.style.stroke-dash: 3
  }

  Control.InstructionFetch -> Threads: "SIMD Broadcast" {
    style: { stroke: "#ffd93d"; stroke-width: 3 }
  }
  Threads -> Control.ActiveMask: "Update predicate bits" {
    style: { stroke: "#a29bfe"; stroke-width: 2; stroke-dash: 3 }
  }
}

# -----------------------------------------------------------------------------
# 2. DIVERGENCE TIMELINE
# -----------------------------------------------------------------------------
DivergenceTimeline: {
  label: "Execution Flow (Serialization Analysis)"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a9eff"
    stroke-width: 2
    border-radius: 8
  }

  Step1: {
    label: "Cycle 1-N: IF Path\n[T0-T15] Active\n[T16-T31] Masked Out"
    style: { fill: "#00b894"; font-color: "#ffffff"; bold: true }
  }
  Step2: {
    label: "Cycle N+1-M: ELSE Path\n[T0-T15] Masked Out\n[T16-T31] Active"
    style: { fill: "#e17055"; font-color: "#ffffff"; bold: true }
  }
  Step3: {
    label: "Cycle M+1: Reconvergence\nSSY (Set Sync) Barrier Reached"
    style: { fill: "#4a9eff"; font-color: "#ffffff"; bold: true }
  }

  Step1 -> Step2: "Serialization\n(Warp Divergence)" {
    style: { stroke: "#ff6b6b"; stroke-width: 2; bold: true }
  }
  Step2 -> Step3: "Merge Path" {
    style: { stroke: "#00b894"; stroke-width: 2 }
  }
}

# -----------------------------------------------------------------------------
# 3. REGISTER FILE LAYOUT (MEMORY)
# -----------------------------------------------------------------------------
RegisterDetail: {
  label: "Physical Register File (PRF) Mapping"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#ffd93d"
    stroke-width: 2
    border-radius: 8
  }
  
  RegFile: {
    label: ||md
      | Offset | Field | Size |
      | :--- | :--- | :--- |
      | 0x00 | General Purpose Regs (R0-R31) | 128 Bytes |
      | 0x80 | Predicate Registers (P0-P7) | 8 Bytes |
      | 0x88 | Control Registers (PC, SR) | 24 Bytes |
      | 0xA0 | Local Memory Stack Frame | 156 Bytes |
    ||
    shape: rectangle
    style: {
      fill: "#2d2d44"
      stroke: "#ffd93d"
      font-color: "#ffffff"
    }
  }
}

# -----------------------------------------------------------------------------
# 4. CODE CONTEXT & LEGEND
# -----------------------------------------------------------------------------
CodeContext: {
  Code: {
    label: |cpp
      // Thread ID determines branching
      if (tid < 16) {
        // High-Throughput Path A
        val = val * 2 + offset;
      } else {
        // High-Throughput Path B
        val = val * 3 - bias;
      }
    |
    shape: code
    style.font-size: 14
  }
}

Legend: {
  grid-rows: 1
  grid-columns: 3
  A: "Active (Path A)" { style.fill: "#00b894"; style.bold: true }
  B: "Inactive (Path B)" { style.fill: "#e17055"; style.bold: true }
  C: "Hardware Logic" { style.fill: "#2d2d44"; style.bold: true }
}

# -----------------------------------------------------------------------------
# GLOBAL CONNECTIONS
# -----------------------------------------------------------------------------
Warp -> DivergenceTimeline: "Temporal Execution View" {
  style.stroke-dash: 5
  style.stroke: "#4a9eff"
}

CodeContext -> Warp.Control.InstructionFetch: "Kernel Instructions" {
  style.stroke: "#ffffff"
  style.stroke-width: 2
}

RegisterDetail -> Warp.Threads: "Register Data Path" {
  style.stroke: "#ffd93d"
  style.stroke-dash: 2
}

PerfNote: {
  label: "PERFORMANCE WARNING: Branch divergence detected. 50% Functional Unit Utilization."
  shape: text
  near: bottom-center
  style: { 
    font-color: "#ff6b6b"
    bold: true 
  }
}