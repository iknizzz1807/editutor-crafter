direction: down
layout-engine: elk
theme-id: 4

title: {
  label: "Thread Index Calculation\nCUDA Thread Indexing Algorithms"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

step_1: {
  label: "STEP 1: 1D Global Index Calculation"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
    font-size: 16
    bold: true
  }
}

formula_1d: {
  label: "global_idx = blockIdx.x × blockDim.x + threadIdx.x"
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
    font-size: 18
    bold: true
    font: mono
  }
}

step_1 -> formula_1d: {
  label: "formula"
  style: { stroke: "#1976D2" }
}

visual_1d: {
  grid_representation: {
    label: "Grid Visualization (1D)"
    shape: rectangle
    block_0: {
      label: "Block 0\nblockIdx.x = 0"
      shape: rectangle
      style: { fill: "#BBDEFB" }
      t0: { label: "T0\nidx=0"; shape: rectangle; style: { fill: "#90CAF9" } }
      t1: { label: "T1\nidx=1"; shape: rectangle; style: { fill: "#64B5F6" } }
      t2: { label: "T2\nidx=2"; shape: rectangle; style: { fill: "#42A5F5" } }
      t3: { label: "T3\nidx=3"; shape: rectangle; style: { fill: "#2196F3" } }
      t0 -> t1 -> t2 -> t3: { style: { stroke-dash: 3 } }
    }
    block_1: {
      label: "Block 1\nblockIdx.x = 1"
      shape: rectangle
      style: { fill: "#C8E6C9" }
      t4: { label: "T0\nidx=4"; shape: rectangle; style: { fill: "#81C784" } }
      t5: { label: "T1\nidx=5"; shape: rectangle; style: { fill: "#66BB6A" } }
      t6: { label: "T2\nidx=6"; shape: rectangle; style: { fill: "#4CAF50" } }
      t7: { label: "T3\nidx=7"; shape: rectangle; style: { fill: "#43A047" } }
      t4 -> t5 -> t6 -> t7: { style: { stroke-dash: 3 } }
    }
    block_0 -> block_1: { style: { stroke-dash: 5 } }
  }
  calculation_example: {
    label: "Example: Block 1, Thread 2\nblockIdx.x=1, blockDim.x=4, threadIdx.x=2\nglobal_idx = 1 × 4 + 2 = 6"
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      font: mono
    }
  }
  grid_representation -> calculation_example
}

formula_1d -> visual_1d: {
  label: "visualization"
  style: { stroke: "#F57C00" }
}

step_2: {
  label: "STEP 2: 2D Matrix Index Calculation"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
    stroke-width: 2
    font-size: 16
    bold: true
  }
}

formula_2d: {
  label: "row = blockIdx.y × blockDim.y + threadIdx.y\ncol = blockIdx.x × blockDim.x + threadIdx.x"
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
    font-size: 16
    bold: true
    font: mono
  }
}

step_2 -> formula_2d: {
  label: "formulas"
  style: { stroke: "#388E3C" }
}

visual_2d: {
  matrix_grid: {
    label: "2D Grid → 2D Block Layout"
    shape: rectangle
    grid_layout: {
      label: "Grid (2×2 Blocks)"
      shape: rectangle
      style: { fill: "#ECEFF1" }
      block_00: {
        label: "Block(0,0)"
        shape: rectangle
        style: { fill: "#BBDEFB" }
      }
      block_01: {
        label: "Block(0,1)"
        shape: rectangle
        style: { fill: "#C8E6C9" }
      }
      block_10: {
        label: "Block(1,0)"
        shape: rectangle
        style: { fill: "#FFE0B2" }
      }
      block_11: {
        label: "Block(1,1)"
        shape: rectangle
        style: { fill: "#F8BBD9" }
      }
      block_00 -> block_01: { label: "x"; style: { stroke-dash: 3 } }
      block_10 -> block_11: { style: { stroke-dash: 3 } }
      block_00 -> block_10: { label: "y"; style: { stroke-dash: 3 } }
      block_01 -> block_11: { style: { stroke-dash: 3 } }
    }
    block_detail: {
      label: "Single Block (2×2 Threads)"
      shape: rectangle
      style: { fill: "#E3F2FD" }
      thread_matrix: {
        label: "(tx,ty) → global indices\n┌─────────────────┬─────────────────┐\n│ (0,0)→col=0,row=0│ (1,0)→col=1,row=0│\n├─────────────────┼─────────────────┤\n│ (0,1)→col=0,row=1│ (1,1)→col=1,row=1│\n└─────────────────┴─────────────────┘"
        shape: rectangle
        style: {
          font: mono
          fill: "#FAFAFA"
        }
      }
    }
    grid_layout -> block_detail: { style: { stroke-dash: 5 } }
  }
  linear_index: {
    label: "Linear Index (for flat arrays):\nglobal_idx = row × WIDTH + col"
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF8F00"
      font: mono
      bold: true
    }
  }
  matrix_grid -> linear_index
}

formula_2d -> visual_2d: {
  label: "visualization"
  style: { stroke: "#F57C00" }
}

step_3: {
  label: "STEP 3: Grid Size Calculation"
  shape: rectangle
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
    stroke-width: 2
    font-size: 16
    bold: true
  }
}

grid_calc: {
  label: "Ceiling Division for Grid Size\ngridSize = (N + blockSize - 1) / blockSize"
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
    font-size: 16
    bold: true
    font: mono
  }
}

step_3 -> grid_calc: {
  label: "formula"
  style: { stroke: "#C2185B" }
}

grid_example: {
  label: "Example: N=1000 elements, blockSize=256\ngridSize = (1000 + 256 - 1) / 256 = 4 blocks\n\nTotal threads launched: 4 × 256 = 1024\nNeed bounds check for threads 1000-1023"
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    font: mono
  }
}

grid_calc -> grid_example: {
  label: "example"
  style: { stroke: "#7B1FA2" }
}

step_4: {
  label: "STEP 4: Bounds Checking Pattern"
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FFA000"
    stroke-width: 2
    font-size: 16
    bold: true
  }
}

bounds_code: {
  label: "__global__ void kernel(float* data, int N) {\n    int idx = blockIdx.x * blockDim.x + threadIdx.x;\n    \n    // Bounds check - CRITICAL!\n    if (idx < N) {\n        data[idx] = computation(idx);\n    }\n}"
  shape: rectangle
  style: {
    fill: "#263238"
    stroke: "#455A64"
    font-color: "#ECEFF1"
    font-size: 14
    font: mono
  }
}

step_4 -> bounds_code: {
  label: "kernel code"
  style: { stroke: "#FFA000" }
}

bounds_visual: {
  label: "Memory Layout with Bounds Check"
  shape: rectangle
  memory_layout: {
    valid_region: {
      label: "Valid Data [0..N-1]\n┌───┬───┬───┬───┬───┬─────┐\n│ 0 │ 1 │ 2 │ 3 │...│N-1│\n└───┴───┴───┴───┴───┴─────┘\n      ↑ Safe to access ↑"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        font: mono
      }
    }
    invalid_region: {
      label: "Invalid [N..gridSize×blockSize-1]\n┌───┬───┬─────┐\n│ N │...│ G-1│\n└───┴───┴─────┘\n  ↑ OUT OF BOUNDS ↑\n  (if idx >= N, skip)"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        font: mono
      }
    }
    valid_region -> invalid_region: {
      label: "boundary"
      style: { stroke: "#D32F2F"; stroke-width: 3 }
    }
  }
}

bounds_code -> bounds_visual: {
  label: "memory view"
  style: { stroke: "#FFA000" }
}

hardware_limits: {
  label: "⚠️ Hardware Constraints\n\n• Max threads per block: 1024\n• Max blocks per grid dimension: 2³¹-1 (x), 65535 (y,z)\n• Warp size: 32 threads\n• Recommended block sizes: 128, 256, 512"
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 2
    font-size: 14
  }
}

visual_1d -> step_2: { style: { stroke: "#9E9E9E"; stroke-dash: 5 } }
visual_2d -> step_3: { style: { stroke: "#9E9E9E"; stroke-dash: 5 } }
grid_example -> step_4: { style: { stroke: "#9E9E9E"; stroke-dash: 5 } }
bounds_visual -> hardware_limits: { style: { stroke: "#9E9E9E"; stroke-dash: 5 } }

summary: {
  label: "📌 Key Takeaways\n\n1. 1D: global_idx = blockIdx.x × blockDim.x + threadIdx.x\n2. 2D: Compute row and col separately, then flatten if needed\n3. Always use ceiling division for grid size\n4. ALWAYS bounds check: if (idx < N) { ... }\n5. Excess threads beyond N are inactive but safe"
  shape: rectangle
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    stroke-width: 2
    font-size: 14
  }
}

hardware_limits -> summary: {
  style: { stroke: "#3F51B5"; stroke-width: 2 }
}