direction: right
Kernel Launch Lifecycle: {
  shape: sequence_diagram
  Host Application: {
    style.font: mono
  }
  CUDA Runtime: {
    style.font: mono
  }
  GPU Driver: {
    style.font: mono
  }
  Work Distributor: {
    style.font: mono
  }
  SM Scheduler: {
    style.font: mono
  }
  Warp 0; Warp 1; Warp 2

  Host Application -> Host Application: "Execute host code"
  
  Host Application -> CUDA Runtime: "kernel<<<grid, block>>>(args)" {
    label: "Async launch\n(non-blocking)"
    style.stroke-dash: 3
  }
  
  CUDA Runtime -> Host Application: "Return immediately" {
    label: "Control returns\n~5-10μs"
    style.stroke-dash: 3
  }
  
  Host Application -> Host Application: "Continue host work" {
    style.stroke-dash: 3
  }
  
  CUDA Runtime -> GPU Driver: "Submit kernel to command buffer"
  GPU Driver -> Work Distributor: "Push to GPU work queue"
  Work Distributor -> Work Distributor: "Decode kernel parameters\nGrid: (N, M, K)\nBlock: (x, y, z)"
  Work Distributor -> SM Scheduler: "Dispatch block (0,0,0)"
  Work Distributor -> SM Scheduler: "Dispatch block (1,0,0)"
  Work Distributor -> SM Scheduler: "Dispatch block (0,1,0)"
  
  SM Scheduler -> SM Scheduler: "Assign blocks to SMs\nbased on availability"
  
  SM Scheduler -> Warp 0: "Schedule warp 0\n(threads 0-31)" {
    label: "32 threads\nlockstep"
  }
  SM Scheduler -> Warp 1: "Schedule warp 1\n(threads 32-63)" {
    label: "32 threads\nlockstep"
  }
  SM Scheduler -> Warp 2: "Schedule warp 2\n(threads 64-95)" {
    label: "32 threads\nlockstep"
  }
  
  Warp 0 -> Warp 0: "Fetch instruction"
  Warp 0 -> Warp 0: "Execute SIMT\n(all 32 threads)"
  Warp 1 -> Warp 1: "Fetch instruction"
  Warp 1 -> Warp 1: "Execute SIMT"
  Warp 2 -> Warp 2: "Fetch instruction"
  Warp 2 -> Warp 2: "Execute SIMT"
  
  Warp 0 -> Warp 0: "Memory operations\n(latency hidden by\nwarp switching)"
  Warp 1 -> Warp 1: "Memory operations"
  Warp 2 -> Warp 2: "Memory operations"
  
  Warp 0 -> SM Scheduler: "Warp complete"
  Warp 1 -> SM Scheduler: "Warp complete"
  Warp 2 -> SM Scheduler: "Warp complete"
  
  SM Scheduler -> Work Distributor: "All blocks complete"
  Work Distributor -> GPU Driver: "Write completion event"
  GPU Driver -> CUDA Runtime: "Update event status"
  
  Host Application -> CUDA Runtime: "cudaDeviceSynchronize()" {
    label: "Explicit sync\n(blocking call)"
  }
  
  CUDA Runtime -> Host Application: "Kernel complete\nreturn success"
  Host Application -> Host Application: "Access results\nfrom device memory"
}