direction: right
layout-engine: elk
theme-id: 4
title: CUDA Memory Transfer Pattern {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Host Memory Space
host_memory: {
  label: "Host Memory (CPU RAM)"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  host_buffer: {
    label: "h_data\n(Host Buffer)"
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    width: 140
    height: 80
  }
  host_buffer_label: {
    shape: text
    label: "4096 bytes (4 KB)\nfloat[1024]"
    style.font-size: 11
    style.italic: true
  }
  host_buffer_label -> host_buffer: {style.opacity: 0}
}
# Device Memory Space
device_memory: {
  label: "Device Memory (GPU VRAM)"
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
  dev_buffer: {
    label: "d_data\n(Device Buffer)"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
    width: 140
    height: 80
  }
  dev_buffer_label: {
    shape: text
    label: "4096 bytes (4 KB)\nfloat[1024]"
    style.font-size: 11
    style.italic: true
  }
  dev_buffer_label -> dev_buffer: {style.opacity: 0}
}
# PCIe Bus
pcie: {
  label: "PCIe Gen4 x16\n~32 GB/s"
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-dash: 5
  width: 180
}
# Process Flow Steps
step1: {
  label: "1. cudaMalloc"
  shape: hexagon
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  width: 120
}
step2: {
  label: "2. cudaMemcpy\nH2D"
  shape: hexagon
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  width: 120
}
step3: {
  label: "3. kernel<<<>>>\nExecution"
  shape: circle
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
  width: 100
}
step4: {
  label: "4. cudaMemcpy\nD2H"
  shape: hexagon
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  width: 120
}
step5: {
  label: "5. cudaFree"
  shape: hexagon
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  width: 120
}
# Flow Connections
step1 -> step2: {
  label: "allocated"
  style.stroke: "#388E3C"
}
step2 -> step3: {
  label: "data ready"
  style.stroke: "#388E3C"
}
step3 -> step4: {
  label: "computed"
  style.stroke: "#D32F2F"
}
step4 -> step5: {
  label: "results copied"
  style.stroke: "#388E3C"
}
# Data Flow Arrows with Byte Counts
host_memory.host_buffer -> pcie: {
  label: "cudaMemcpyHostToDevice\n4096 bytes →"
  style.stroke: "#1976D2"
  style.stroke-width: 3
  style.animated: true
}
pcie -> device_memory.dev_buffer: {
  label: "→ VRAM"
  style.stroke: "#1976D2"
  style.stroke-width: 3
}
device_memory.dev_buffer -> pcie: {
  label: "cudaMemcpyDeviceToHost\n← 4096 bytes"
  style.stroke: "#F57C00"
  style.stroke-width: 3
  style.animated: true
}
pcie -> host_memory.host_buffer: {
  label: "→ RAM"
  style.stroke: "#F57C00"
  style.stroke-width: 3
}
# Timing annotations
timing_box: {
  label: "Transfer Timing (est.)\n• H2D: ~0.125 μs @ 32 GB/s\n• D2H: ~0.125 μs @ 32 GB/s\n• Kernel: variable"
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  style.stroke-dash: 3
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  item1: {
    label: "→ Data direction (Host to Device)"
    shape: text
  }
  item2: {
    label: "← Data direction (Device to Host)"
    shape: text
  }
  item3: {
    label: "████ Host Memory Space"
    shape: text
    style.fill: "#E3F2FD"
  }
  item4: {
    label: "████ Device Memory Space"
    shape: text
    style.fill: "#FFF3E0"
  }
}
# Positioning hints
step1 -- host_memory: {style.opacity: 0}
step5 -- device_memory: {style.opacity: 0}