direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- HEADER SECTION ---
header: {
  near: top-center
  style: {
    stroke-width: 0
    fill: transparent
  }
  title: "GPU Memory Hierarchy & Data Path" {
    shape: text
    style: {
      font-size: 32
      bold: true
      underline: true
    }
  }
  subtitle: "Intel-Grade Technical Specification: Latency, Bandwidth, and Allocation Scope" {
    shape: text
    style: {
      font-size: 18
      italic: true
    }
  }
}

# --- AXIS INDICATORS ---
performance_axis: {
  near: top-left
  fast: "↑ INCREASING PERFORMANCE (Low Latency / Peak BW)" {
    shape: text
    style: {
      font-size: 14
      font-color: "#2E7D32"
      bold: true
    }
  }
  slow: "↓ INCREASING CAPACITY (High Latency / Mass Storage)" {
    shape: text
    style: {
      font-size: 14
      font-color: "#B71C1C"
      bold: true
    }
  }
}

# --- MEMORY LEVELS ---

# LEVEL 1: REGISTERS
registers: {
  label: "L0: Register File (RF)"
  shape: rectangle
  style: {
    fill: "#4CAF50"
    stroke: "#1E4620"
    stroke-width: 4
    font-color: white
    bold: true
    shadow: true
  }
  
  stats: {
    grid-columns: 1
    style.stroke-width: 0
    
    latency: "⏱ Access: 1 Clock Cycle (Fixed)"
    bandwidth: "⚡ Agg. Bandwidth: ~12.5 TB/s (SM-wide)"
    capacity: "📦 Size: 64K x 32-bit per SM"
    addressing: "⊕ Mode: Non-indexed, Compiler Managed"
  }
  
  unit_info: |md
    ### Register Characteristics
    - **Scope:** Single Thread
    - **Width:** 32-bit per register
    - **Granularity:** 4-register per SIMD lane
    - **Overflow:** Spills to 'Local Memory' (backed by L1/Global)
  |
}

# LEVEL 2: SHARED MEMORY / L1
shared_mem: {
  label: "L1 Cache / Shared Memory (SRAM)"
  shape: rectangle
  style: {
    fill: "#2196F3"
    stroke: "#0D47A1"
    stroke-width: 4
    font-color: white
    bold: true
    shadow: true
  }
  
  stats: {
    grid-columns: 1
    style.stroke-width: 0
    
    latency: "⏱ Access: ~18-32 Clock Cycles"
    bandwidth: "⚡ Bandwidth: ~5.2 TB/s"
    capacity: "📦 Capacity: 128KB (Configurable Partition)"
    topology: "☊ Banking: 32 Banks x 32-bit Width"
  }
  
  internal: {
    label: "Conflict Management: 4-byte Interleaving | Broadcast/Multicast support"
    shape: text
    style: {
      font-size: 11
      italic: true
      font-color: "#E3F2FD"
    }
  }
}

# LEVEL 3: L2 CACHE
l2_cache: {
  label: "L2 Cache (Unified Silicon Hub)"
  shape: rectangle
  style: {
    fill: "#FF9800"
    stroke: "#E65100"
    stroke-width: 4
    font-color: white
    bold: true
    shadow: true
  }
  
  stats: {
    grid-columns: 1
    style.stroke-width: 0
    
    latency: "⏱ Access: ~150-250 Clock Cycles"
    bandwidth: "⚡ Bandwidth: ~2.8 TB/s"
    capacity: "📦 Capacity: 40MB - 80MB (Architecture-specific)"
    coherence: "↮ Scope: Global Device-wide Coherence"
  }
  
  details: |md
    - Non-inclusive backing store
    - Handles atomic operation serialization
    - Segmented by Memory Controllers
  |
}

# LEVEL 4: GLOBAL MEMORY
global_mem: {
  label: "VRAM: Device Memory (HBM3 / GDDR6X)"
  shape: rectangle
  style: {
    fill: "#F44336"
    stroke: "#B71C1C"
    stroke-width: 4
    font-color: white
    bold: true
    shadow: true
  }
  
  stats: {
    grid-columns: 1
    style.stroke-width: 0
    
    latency: "⏱ Access: 450 - 900 Clock Cycles"
    bandwidth: "⚡ Bandwidth: 1.0 - 3.2 TB/s"
    capacity: "📦 Capacity: 16GB - 80GB+"
    line_size: "▭ Transaction: 128-byte Burst (Coalesced)"
  }
  
  phys: {
    label: "ECC Enabled | High-Voltage Swing Interface"
    shape: text
    style: {
      font-size: 11
      bold: true
      font-color: "#FFEBEE"
    }
  }
}

# --- DATA FLOW & SPILL PATHS ---

registers -> shared_mem: "Local Memory Spill" {
  style: {
    stroke-dash: 5
    stroke: "#616161"
    stroke-width: 2
  }
}

shared_mem -> l2_cache: "L1 Write-Back / Miss" {
  style: {
    stroke-dash: 5
    stroke: "#616161"
    stroke-width: 2
  }
}

l2_cache -> global_mem: "L2 Eviction / DRAM Fetch" {
  style: {
    stroke-dash: 5
    stroke: "#616161"
    stroke-width: 2
  }
}

# --- ANNOTATIONS (FIXED NEAR POSITIONING) ---

latency_summary: {
  near: top-right
  shape: rectangle
  label: "Cycle Latency Reference Table\n----------------------------\nRF: 1x (Base)\nL1/Shared: 30x\nL2 Cache: 200x\nDRAM: 800x"
  style: {
    stroke-dash: 3
    fill: "#FAFAFA"
    font-size: 12
    font: mono
  }
}

# --- OPTIMIZATION BOX ---
perf_guide: {
  label: "Implementation Engineering Guidelines"
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
    double-border: true
  }
  
  tips: |md
    - **Occupancy Tuning:** Monitor `RegCount` per thread; excessive usage limits active Warps.
    - **Memory Coalescing:** Ensure thread indices map to linear addresses for 128B DRAM bursts.
    - **Shared Memory Tiling:** Use `__syncthreads()` to coordinate block-level data reuse.
    - **Bank Conflicts:** Use padding (e.g., `[32][33]`) to avoid vertical bank alignment.
    - **Pinned Memory:** Use `cudaHostAlloc` for faster Host-to-Device (H2D) transfers.
  |
}

# --- LEGEND ---
legend: {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#424242"
  }
  
  fastest: "■ Green: On-Chip Registers (Zero Overhead)"
  moderate: "■ Blue/Orange: Intermediate Caches (SRAM)"
  slowest: "■ Red: Off-Chip VRAM (DRAM Interface)"
  path: "⇢ Dotted: Implicit Hardware Spill/Fill"
}

# --- STRUCTURAL HINTS (ELK LAYOUT) ---
header -> registers: { style.stroke-width: 0 }
registers -> shared_mem: { style.stroke-width: 0 }
shared_mem -> l2_cache: { style.stroke-width: 0 }
l2_cache -> global_mem: { style.stroke-width: 0 }