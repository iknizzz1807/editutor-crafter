direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 40
  }
}

title: {
  label: "CUDA ERROR HANDLING STATE MACHINE (IMPLEMENTATION SPEC v1.2)"
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
    font-color: "#2E5A8B"
  }
}

# -----------------------------------------------------------------------------
# LOGIC EXECUTION FLOW
# -----------------------------------------------------------------------------
state_machine: {
  label: "Runtime Execution Logic"
  style: {
    stroke-width: 2
    stroke-dash: 5
    fill: "#F8F9FA"
  }
  
  start: "●" {
    shape: circle
    style: {
      fill: "#4A90D9"
      stroke: "#2E5A8B"
      stroke-width: 4
    }
  }

  cuda_call: {
    label: "CUDA API Call\n(cudaMalloc, cudaMemcpy, etc.)"
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#4A90D9"
      border-radius: 8
      stroke-width: 2
    }
  }

  capture_return: {
    label: "Capture Return Code\ncudaError_t err = call"
    shape: rectangle
    style: {
      fill: "#FFF9E6"
      stroke: "#D4A000"
      border-radius: 8
      stroke-width: 2
    }
  }

  check_result: {
    label: "err == cudaSuccess?"
    shape: diamond
    style: {
      fill: "#F0F0F0"
      stroke: "#666666"
      stroke-width: 2
    }
  }

  success: {
    label: "Continue Execution\n(Sequence Resume)"
    shape: rectangle
    style: {
      fill: "#D4EDDA"
      stroke: "#28A745"
      border-radius: 8
      stroke-width: 2
    }
  }

  error_report: {
    label: "Report Error\nfprintf(stderr, ...)\ncudaGetErrorString(err)"
    shape: rectangle
    style: {
      fill: "#F8D7DA"
      stroke: "#DC3545"
      border-radius: 8
      stroke-width: 2
    }
  }

  exit_failure: {
    label: "EXIT_FAILURE\n(Status 1)"
    shape: rectangle
    style: {
      fill: "#DC3545"
      stroke: "#A71D2A"
      font-color: white
      bold: true
      border-radius: 4
    }
  }

  end: "●" {
    shape: circle
    style: {
      fill: "#28A745"
      stroke: "#1E7B34"
      double-border: true
      stroke-width: 4
    }
  }

  # Transitions with detailed guards
  start -> cuda_call: "invoke macro" {
    style.stroke-width: 2
  }
  cuda_call -> capture_return: "store result" {
    style.stroke-width: 2
  }
  capture_return -> check_result: "evaluate" {
    style.stroke-width: 2
  }
  
  check_result -> success: "[YES]\nguard: err == 0" {
    style: {
      stroke: "#28A745"
      stroke-width: 4
      bold: true
    }
  }
  
  check_result -> error_report: "[NO]\nguard: err != 0" {
    style: {
      stroke: "#DC3545"
      stroke-width: 4
      bold: true
    }
  }
  
  success -> end: "normal flow" {
    style: {
      stroke: "#28A745"
      stroke-width: 2
    }
  }
  
  error_report -> exit_failure: "terminate" {
    style: {
      stroke: "#DC3545"
      stroke-dash: 3
      stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------
# IMPLEMENTATION DETAILS: MACROS
# -----------------------------------------------------------------------------
macro_expansion: {
  label: "CUDA_CHECK Macro Expansion"
  style.fill: "#F1F4F9"
  
  macro_definition: |cpp
    #define CUDA_CHECK(call) \
      do { \
        cudaError_t err = call; \
        if (err != cudaSuccess) { \
          fprintf(stderr, \
            "CUDA error at %s:%d - %s\n", \
            __FILE__, __LINE__, \
            cudaGetErrorString(err)); \
          exit(EXIT_FAILURE); \
        } \
      } while (0)
  | {
    shape: rectangle
    style.font: mono
  }
  
  usage_example: "Developer Integration Example" {
    shape: text
    style.bold: true
  }
  
  expanded_code: |cpp
    // Source: main.cu:42
    CUDA_CHECK(cudaMalloc(&d_ptr, 1024));

    // Compiled ASM/Logic:
    cudaError_t err = cudaMalloc(&d_ptr, 1024);
    if (err != 0) {
       // Logic jumps to Error Handler
       __handle_cuda_error(err, "main.cu", 42);
    }
  | {
    shape: rectangle
    style.font: mono
    style.fill: "#FFFFFF"
  }
  
  usage_example -> expanded_code
}

kernel_check: {
  label: "Asynchronous Kernel Validation"
  style.fill: "#FFF5F5"
  
  kernel_macro: |cpp
    #define KERNEL_CHECK() \
      do { \
        cudaError_t err = cudaGetLastError(); \
        if (err != cudaSuccess) { \
          // Log Kernel Launch Failure
          exit(EXIT_FAILURE); \
        } \
      } while (0)
  | {
    shape: rectangle
    style.font: mono
  }
  
  note: {
    label: "CRITICAL: kernel launches are non-blocking.\nUse KERNEL_CHECK() immediately after '<<<...>>>'\nto catch configuration/resource errors."
    shape: text
    style: {
      italic: true
      font-color: "#DC3545"
      font-size: 12
    }
  }
  
  kernel_macro -> note
}

# -----------------------------------------------------------------------------
# ERROR DATA REFERENCE
# -----------------------------------------------------------------------------
error_types: {
  label: "CUDA runtime-api error_t Reference"
  
  errors: {
    shape: sql_table
    style.fill: "#F8F9FA"
    cudaSuccess: "0x00" {label: "Success: No error reported"; constraint: [PK; UNQ]}
    cudaErrorInvalidValue: "0x01" {label: "Invalid argument passed to API"; constraint: UNQ}
    cudaErrorMemoryAllocation: "0x02" {label: "Device out of memory (OOM)"; constraint: UNQ}
    cudaErrorLaunchFailure: "0x2CF" {label: "An exception occurred on the device"; constraint: UNQ}
  }
}

# -----------------------------------------------------------------------------
# INTER-MODULE MAPPING
# -----------------------------------------------------------------------------
state_machine.cuda_call -> macro_expansion.expanded_code: "Call pattern" {
  style: {
    stroke-dash: 4
    stroke: "#4A90D9"
    opacity: 0.5
  }
}

state_machine.check_result -> error_types.errors.cudaSuccess: "Comparison" {
  style: {
    stroke-dash: 4
    stroke: "#666666"
    opacity: 0.5
  }
}

# -----------------------------------------------------------------------------
# VISUAL LEGEND
# -----------------------------------------------------------------------------
legend: {
  label: "Diagram Symbology"
  near: bottom-right
  
  success_path: {
    label: "Happy Path (No Error)"
    shape: rectangle
    style: {
      fill: "#D4EDDA"
      stroke: "#28A745"
      stroke-width: 4
    }
  }
  
  error_path: {
    label: "Exception Path (Failure)"
    shape: rectangle
    style: {
      fill: "#F8D7DA"
      stroke: "#DC3545"
      stroke-width: 4
    }
  }
  
  success_path -> error_path: {
    style.opacity: 0
  }
}