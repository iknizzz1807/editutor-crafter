vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

direction: down

title: {
  label: "AoS vs SoA Memory Layout Analysis\nCache Line Utilization & GPU Memory Coalescing"
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# -----------------------------------------------------------------------------
# 0. Data Definition (The "Header")
# -----------------------------------------------------------------------------
particle_definition: {
  label: |`cpp
struct Particle {
    float x, y, z;    // [00-11] Position
    float vx, vy, vz; // [12-23] Velocity
    float r, g, b;    // [24-35] Color
    float mass;       // [36-39] Mass
}; // sizeof = 40 Bytes
`|
  shape: code
  style: {
    stroke: "#89b4fa"
    fill: "#585b70" # Purple-ish header per instructions
    font-color: white
  }
}

# -----------------------------------------------------------------------------
# 1. Array of Structures (AoS) - The OOP Approach
# -----------------------------------------------------------------------------
aos_analysis: "AoS Layout (Array of Structures)" {
  style: {
    stroke: "#f97583"
    stroke-width: 4
    fill: "#161b22"
  }

  description: |md
    ### Interleaved Memory Pattern
    - **Stride:** 40 Bytes (sizeof Struct)
    - **Locality:** Spatial locality is poor for attribute-specific kernels.
    - **Fetching:** Loading `x` forces the fetch of `vx, vy, vz, r, g, b, mass` into cache.
  |

  memory_block: {
    grid-columns: 10
    grid-gap: 2
    style.fill: "#0d1117"

    # Particle 0
    p0_x: "x₀\n0x00" { style.fill: "#79c0ff"; width: 50; height: 50 } # Blue = Data
    p0_y: "y₀\n0x04" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_z: "z₀\n0x08" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_vx: "vx₀\n0x0C" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_vy: "vy₀\n0x10" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_vz: "vz₀\n0x14" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_r: "r₀\n0x18" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_g: "g₀\n0x1C" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_b: "b₀\n0x20" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p0_m: "m₀\n0x24" { style.fill: "#56d364"; width: 50; height: 50 } # Green = Mass/Free/Other

    # Particle 1
    p1_x: "x₁\n0x28" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_y: "y₁\n0x2C" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_z: "z₁\n0x30" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_vx: "vx₁\n0x34" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_vy: "vy₁\n0x38" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_vz: "vz₁\n0x3C" { style.fill: "#79c0ff"; width: 50; height: 50 }
    
    # Boundary representation (Replaces the invalid 'line' shape)
    cache_line_marker: "--- 64B CACHE LINE BOUNDARY ---" {
      grid-column-span: 10
      style: {
        fill: "#ffa500"
        stroke-dash: 5
        font-color: "#ffa500"
        bold: true
        border-radius: 0
      }
    }
    
    p1_r: "r₁\n0x40" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_g: "g₁\n0x44" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_b: "b₁\n0x48" { style.fill: "#79c0ff"; width: 50; height: 50 }
    p1_m: "m₁\n0x4C" { style.fill: "#56d364"; width: 50; height: 50 }
  }

  access_summary: {
    label: "Stride: 40B | Cache Waste: 90% (when only x is needed)\nCPU must fetch entire struct for one field."
    style: {
      stroke: "#f97583"
      font-color: "#f97583"
      bold: true
      fill: "#1e1e2e"
    }
  }
}

# -----------------------------------------------------------------------------
# 2. Structure of Arrays (SoA) - The SIMD/GPU Approach
# -----------------------------------------------------------------------------
soa_analysis: "SoA Layout (Structure of Arrays)" {
  style: {
    stroke: "#56d364"
    stroke-width: 4
    fill: "#161b22"
  }

  description: |md
    ### Parallel-Friendly Memory Pattern
    - **Stride:** 4 Bytes (sizeof float)
    - **Locality:** Perfect spatial locality for streaming kernels.
    - **GPU:** Enables Memory Coalescing (Single Instruction Multiple Threads).
  |

  memory_block: {
    style.fill: "#0d1117"
    
    x_array: "X-Coordinate Plane [0x00 - 0x3F]" {
      grid-columns: 8
      grid-gap: 2
      style.fill: "#161b22"
      
      x0: "x₀" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x1: "x₁" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x2: "x₂" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x3: "x₃" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x4: "x₄" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x5: "x₅" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x6: "x₆" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x7: "x₇" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x8: "x₈" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x9: "x₉" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x10: "x₁₀" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x11: "x₁₁" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x12: "x₁₂" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x13: "x₁₃" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x14: "x₁₄" { style.fill: "#79c0ff"; width: 45; height: 45 }
      x15: "x₁₅" { style.fill: "#79c0ff"; width: 45; height: 45 }
    }

    cache_boundary: "--- 1 x 64B Cache Line (16 Floats Loaded) ---" {
      style: {
        fill: "#56d364"
        font-color: white
        bold: true
        stroke-dash: 2
      }
    }
  }

  access_summary: {
    label: "Stride: 4B | Cache Efficiency: 100%\n16 particles processed per cache line load."
    style: {
      stroke: "#56d364"
      font-color: "#56d364"
      bold: true
      fill: "#1e1e2e"
    }
  }
}

# -----------------------------------------------------------------------------
# 3. Performance Matrix
# -----------------------------------------------------------------------------
comparison: "Summary Performance Matrix" {
  label: |`md
| Metric | AoS (OOP) | SoA (Data-Oriented) |
| :--- | :--- | :--- |
| **Stride** | 40 Bytes | **4 Bytes** |
| **Cache Waste** | High (Padding effect) | **Zero (Densely packed)** |
| **SIMD/Vectorization** | Scatter/Gather req. | **Direct Vector Load** |
| **GPU Coalescing** | Strided (Slow) | **Coalesced (Max Throughput)** |
`|
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    font-color: "#cdd6f4"
    stroke: "#89b4fa"
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# 4. Global Links & Legend
# -----------------------------------------------------------------------------
particle_definition -> aos_analysis: "Interleaved Access"
particle_definition -> soa_analysis: "Streaming Access"
aos_analysis -> comparison
soa_analysis -> comparison

legend: "Intel Memory Map Legend" {
  near: bottom-right
  header: "Header/Struct" { style.fill: "#585b70" }
  data: "Float Data" { style.fill: "#79c0ff" }
  misc: "Mass/Other" { style.fill: "#56d364" }
  bound: "Cache Boundary" { style: { fill: "#ffa500"; stroke-dash: 5 } }
}