direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: "Bank Conflict Scenarios | GPU Shared Memory Architecture" {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# --- 1. Hardware Specification ---
# Intel Manual Style: Memory Layout with Byte Offsets
bank_arch: {
  label: "Shared Memory Hardware (L1/Shared)"
  style: {
    fill: "#E8F4FD"
    stroke: "#0071C5"
    stroke-width: 4
  }

  tooltip: "32-wide SIMD Warp Access Architecture"

  mem_layout: {
    shape: sql_table
    style.fill: "#673AB7" # Purple Header
    "Offset (Byte)" | "Bank Index" | "Data/Field" | "Size"
    "0x00" | "Bank 0" | "Word 0" | "4B"
    "0x04" | "Bank 1" | "Word 1" | "4B"
    "0x08" | "Bank 2" | "Word 2" | "4B"
    "..." | "..." | "..." | "..."
    "0x7C" | "Bank 31" | "Word 31" | "4B"
    "0x80 (Line 2)" | "Bank 0" | "Word 32" | "4B"
  }

  specs: |md
    ### Memory Layout Details
    - **Total Banks:** 32 (Independent access ports)
    - **Bank Width:** 4 Bytes (32-bit words)
    - **Interleaving:** Cyclic across 128-byte segments
    - **Total Bandwidth:** 32 words / cycle (Optimal)
  |

  banks: {
    grid-columns: 8
    grid-gap: 15
    
    b0: "Bank 0\n[0, 128, 256]" { 
      style.fill: "#BBDEFB"
      tooltip: "Address % 128 == 0"
    }
    b1: "Bank 1\n[4, 132, 260]" { style.fill: "#BBDEFB" }
    b2: "Bank 2\n[8, 136, 264]" { style.fill: "#BBDEFB" }
    b3: "Bank 3\n[12, 140, 268]" { style.fill: "#BBDEFB" }
    b4: "Bank 4\n[16, 144, 272]" { style.fill: "#BBDEFB" }
    b5: "Bank 5\n[20, 148, 276]" { style.fill: "#BBDEFB" }
    b6: "Bank 6\n[24, 152, 280]" { style.fill: "#BBDEFB" }
    b7: "Bank 7\n[28, 156, 284]" { style.fill: "#BBDEFB" }
  }

  addressing: ||md
    **Addressing Logic (CUDA Hardware):**
    - `BankID = (ByteAddress / 4) % 32`
    - `LocalOffset = ByteAddress / 128`
  | {
    shape: text
    style.font: mono
  }
}

# --- 2. Scenario 1: Optimal Mapping ---
scenario_1: {
  label: "Scenario 1: Conflict-Free (Stride 1)"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"

  pattern: |md
    **Access Pattern:** `shared[threadIdx.x]`
    *Threads 0-31 map uniquely to Banks 0-31*
  ||

  viz: {
    grid-columns: 3
    grid-gap: 60
    
    threads: {
      label: "Warp Threads"
      t0: "T0"
      t1: "T1"
      t31: "T31"
      style.fill: "#C8E6C9"
    }

    x: "Full Crossbar" {
      shape: parallelogram
      style.fill: "#E0E0E0"
    }

    banks: {
      label: "Memory Banks"
      bk0: "B0"
      bk1: "B1"
      bk31: "B31"
      style.fill: "#A5D6A7"
    }

    threads.t0 -> x -> banks.bk0
    threads.t1 -> x -> banks.bk1
    threads.t31 -> x -> banks.bk31
  }

  stats: {
    shape: sql_table
    Metric: "Value"
    "Cycles": "1 Cycle"
    "Throughput": "100%"
    "Serialization": "None"
  }
}

# --- 3. Scenario 2: Strided Conflict ---
scenario_2: {
  label: "Scenario 2: 2-Way Conflict (Stride 2)"
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"

  pattern: |md
    **Access Pattern:** `shared[threadIdx.x * 2]`
    *Stride = 8 Bytes (Double bank width)*
  |

  viz: {
    direction: right
    
    warp_req: {
      t0: "Thread 0"
      t16: "Thread 16"
      style.fill: "#FFF59D"
    }

    conflict_node: "Shared Memory Arbiter" {
      shape: diamond
      style.fill: "#FBC02D"
    }

    hardware_banks: {
      b0: "Bank 0" { 
        style.fill: "#FBC02D"
        style.stroke-width: 4
      }
    }

    warp_req.t0 -> conflict_node: "Req 1 (Bank 0)"
    warp_req.t16 -> conflict_node: "Req 2 (Bank 0)"
    conflict_node -> hardware_banks.b0: "Phase 1: T0" { 
      style.stroke: red; 
      style.bold: true 
    }
    conflict_node -> hardware_banks.b0: "Phase 2: T16" { 
      style.stroke: red; 
      style.stroke-dash: 3 
    }
  }

  warning: "⚠ COLLISION: T0 and T16 both target Bank 0" {
    shape: text
    style.font-color: red
    style.bold: true
  }
}

# --- 4. Scenario 3: Worst Case ---
scenario_3: {
  label: "Scenario 3: 32-Way Conflict (Column-Major)"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"

  code: |||cpp
// COLUMN-MAJOR ACCESS ON 32x32 TILE
__shared__ float tile[32][32];
float val = tile[threadIdx.x][0]; // BAD

// Indices: 0, 32, 64, 96... (128-byte strides)
// All indices map to: (index * 4 / 4) % 32 == 0
| {
    style.font: mono
  }

  viz: {
    threads: "Warp (T0...T31)" {
      style.fill: "#EF5350"
      style.multiple: true
    }
    
    bottleneck: "Bank 0 Serializer" {
      shape: diamond
      style.fill: "#B71C1C"
      style.font-color: white
    }

    threads -> bottleneck: "32 Concurrent Requests"
    bottleneck -> bank_storage: "SERIALIZED ACCESS" {
      style.animated: true
      style.stroke: red
      style.stroke-width: 5
    }
    
    bank_storage: "Physical Bank 0" {
      shape: cylinder
    }
  }

  impact: "Penalty: 32-cycle latency" {
    shape: text
    style.bold: true
    style.font-color: red
  }
}

# --- 5. Optimization: Padding ---
solution: {
  label: "Optimization: Memory Padding Strategy"
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"

  # Fixed Block String formatting to prevent D2 syntax conflict with Markdown pipes
  before: {
    label: "Physical Layout: Standard [32][32]"
    grid: ||md
| Row | Bank 0 | Bank 1 | ... |
|---|---|---|---|
| 0 | 0 | 1 | ... |
| 1 | 32 (x)| 33 | ... |
|
    note: "Conflict: Index 0 and 32 map to Bank 0"
  }

  after: {
    label: "Physical Layout: Padded [32][33]"
    grid: ||md
| Row | Bank 0 | Bank 1 | Bank 2 |
|---|---|---|---|
| 0 | 0 | 1 | 2 |
| 1 | PAD | 32 (✓) | 33 |
|
    note: "Success: Index 0 in B0, Index 32 shifts to B1"
  }

  fix_code: ||cpp
// OPTIMIZED: Add one extra element per row to break stride alignment
__shared__ float tile[32][32 + 1]; 

// Logical index = (Row * 33) + Col
// Column 0 access: (i * 33) % 32 == i % 32
// Result: Linear mapping across 32 banks!
| {
    style.font: mono
    style.fill: "#E8F5E9"
  }

  before -> after: "Interleave Shift (Skewing)" {
    style.stroke-width: 4
    style.stroke: "#0288D1"
  }
}

# --- 6. Metrics Summary ---
perf_summary: {
  label: "Performance Impact Matrix"
  style.fill: "#F5F5F5"
  
  grid-rows: 5
  grid-columns: 3
  grid-gap: 0

  # Header Row
  c1: "Config / Pattern" { style.bold: true; style.fill: "#E0E0E0" }
  c2: "Latency (Cycles)" { style.bold: true; style.fill: "#E0E0E0" }
  c3: "Efficiency" { style.bold: true; style.fill: "#E0E0E0" }

  # Data Rows
  r1c1: "Linear (Optimal)"
  r1c2: "1"
  r1c3: "100%"

  r2c1: "Stride-2 (2-way)"
  r2c2: "2"
  r2c3: "50%"

  r3c1: "Column-Major (32-way)"
  r3c2: "32"
  r3c3: "3.1%"

  r4c1: "Padded Fix"
  r4c2: "1"
  r4c3: "100%"
}

# Global Flow
bank_arch -> scenario_1: "Stride=1"
scenario_1 -> scenario_2: "Stride=2"
scenario_2 -> scenario_3: "Stride=32"
scenario_3 -> solution: "Apply Padding"
solution -> perf_summary: "Benchmarked"

# Legend
legend: {
  near: bottom-right
  opt: "Optimal Path" { style.fill: "#C8E6C9" }
  err: "Conflict Delay" { style.fill: "#FFEBEE" }
}
|||