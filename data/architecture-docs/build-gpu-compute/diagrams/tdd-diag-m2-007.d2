layout-engine: elk
theme-id: 4

direction: right

title: {
  label: "Shared Memory Tile[32][33] Layout\nPadding Strategy for Bank Conflict Avoidance"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Legend
legend: {
  shape: rectangle
  style: {
    fill: "#f8f9fa"
    stroke: "#333"
    stroke-width: 2
  }
  label: ""
  legend_title: {
    shape: text
    label: "LEGEND"
    style.bold: true
    style.font-size: 14
  }
  data_cell: {
    shape: rectangle
    label: "Data Element"
    style: {
      fill: "#4a90d9"
      font-color: white
    }
  }
  pad_cell: {
    shape: rectangle
    label: "Padding (+1)"
    style: {
      fill: "#6c757d"
      font-color: white
    }
  }
  bank_label: {
    shape: text
    label: "Bank 0-31 (4 bytes each)"
    style.italic: true
  }
  data_cell -> pad_cell: {
    style.opacity: 0
  }
  pad_cell -> bank_label: {
    style.opacity: 0
  }
}

# Bank assignment formula
formula_box: {
  shape: rectangle
  style: {
    fill: "#fff3cd"
    stroke: "#856404"
    stroke-width: 2
  }
  label: ""
  formula_title: {
    shape: text
    label: "Bank Assignment Formula"
    style.bold: true
    style.font-size: 14
  }
  formula: {
    shape: text
    label: "Bank = (address / 4) % 32 = (row × 33 + col) % 32\n\nWith padding: consecutive rows shift bank assignment by +1\nColumn access: thread[row] reads tile[row][col] → Bank = (row×33 + col) % 32\nAll threads access DIFFERENT banks → NO CONFLICTS"
    style.font-size: 12
  }
  formula_title -> formula: {
    style.opacity: 0
  }
}

legend -> formula_box: {
  style.opacity: 0
}

# Problem description - tile[32][32]
problem_section: {
  label: "PROBLEM: tile[32][32] Column Access"
  style: {
    fill: "#f8d7da"
    stroke: "#721c24"
    stroke-width: 2
  }
  problem_desc: {
    shape: text
    label: "When accessing column x in tile[32][32]:\nBank = (row × 32 + x) % 32 = x\nALL 32 threads access Bank x → 32-way conflict!"
    style.font-size: 11
  }
  # Show first 4 rows of problematic layout
  problem_grid: {
    label: ""
    shape: rectangle
    style.fill: "#ffffff"
    # Row labels
    r0_p: {shape: text; label: "Row 0"}
    r1_p: {shape: text; label: "Row 1"}
    r2_p: {shape: text; label: "Row 2"}
    r3_p: {shape: text; label: "Row 3"}
    # Bank labels
    b0_p: {shape: text; label: "B0"; style.fill: "#ff6b6b"}
    b1_p: {shape: text; label: "B1"; style.fill: "#feca57"}
    b2_p: {shape: text; label: "B2"; style.fill: "#48dbfb"}
    b3_p: {shape: text; label: "B3"; style.fill: "#ff9ff3"}
    b4_p: {shape: text; label: "..."; style.fill: "#ffffff"}
    # Row 0 cells - accessing column 1 (all B1 = CONFLICT)
    c00_p: {shape: rectangle; label: "0,0\nB0"; style.fill: "#ff6b6b"; style.font-size: 9}
    c01_p: {shape: rectangle; label: "0,1\nB1"; style.fill: "#ff0000"; style.font-size: 9; style.stroke: "#ff0000"; style.stroke-width: 3}
    c02_p: {shape: rectangle; label: "0,2\nB2"; style.fill: "#48dbfb"; style.font-size: 9}
    c03_p: {shape: rectangle; label: "0,3\nB3"; style.fill: "#ff9ff3"; style.font-size: 9}
    # Row 1 cells
    c10_p: {shape: rectangle; label: "1,0\nB0"; style.fill: "#ff6b6b"; style.font-size: 9}
    c11_p: {shape: rectangle; label: "1,1\nB1"; style.fill: "#ff0000"; style.font-size: 9; style.stroke: "#ff0000"; style.stroke-width: 3}
    c12_p: {shape: rectangle; label: "1,2\nB2"; style.fill: "#48dbfb"; style.font-size: 9}
    c13_p: {shape: rectangle; label: "1,3\nB3"; style.fill: "#ff9ff3"; style.font-size: 9}
    # Row 2 cells
    c20_p: {shape: rectangle; label: "2,0\nB0"; style.fill: "#ff6b6b"; style.font-size: 9}
    c21_p: {shape: rectangle; label: "2,1\nB1"; style.fill: "#ff0000"; style.font-size: 9; style.stroke: "#ff0000"; style.stroke-width: 3}
    c22_p: {shape: rectangle; label: "2,2\nB2"; style.fill: "#48dbfb"; style.font-size: 9}
    c23_p: {shape: rectangle; label: "2,3\nB3"; style.fill: "#ff9ff3"; style.font-size: 9}
    # Row 3 cells
    c30_p: {shape: rectangle; label: "3,0\nB0"; style.fill: "#ff6b6b"; style.font-size: 9}
    c31_p: {shape: rectangle; label: "3,1\nB1"; style.fill: "#ff0000"; style.font-size: 9; style.stroke: "#ff0000"; style.stroke-width: 3}
    c32_p: {shape: rectangle; label: "3,2\nB2"; style.fill: "#48dbfb"; style.font-size: 9}
    c33_p: {shape: rectangle; label: "3,3\nB3"; style.fill: "#ff9ff3"; style.font-size: 9}
    # Layout
    r0_p -> c00_p -> c01_p -> c02_p -> c03_p -> b4_p: {style.opacity: 0}
    r1_p -> c10_p -> c11_p -> c12_p -> c13_p: {style.opacity: 0}
    r2_p -> c20_p -> c21_p -> c22_p -> c23_p: {style.opacity: 0}
    r3_p -> c30_p -> c31_p -> c32_p -> c33_p: {style.opacity: 0}
  }
  conflict_indicator: {
    shape: text
    label: "← Column 1 access: ALL rows → Bank 1\n   32-way bank conflict!"
    style: {
      fill: "#ff0000"
      font-color: "#721c24"
      bold: true
    }
  }
}

# Solution - tile[32][33]
solution_section: {
  label: "SOLUTION: tile[32][33] with Padding"
  style: {
    fill: "#d4edda"
    stroke: "#155724"
    stroke-width: 2
  }
  solution_desc: {
    shape: text
    label: "With +1 padding (tile[32][33]):\nBank = (row × 33 + col) % 32\nEach row shifts by +1 → ALL threads access DIFFERENT banks!"
    style.font-size: 11
  }
  # Show first 4 rows of solution layout
  solution_grid: {
    label: ""
    shape: rectangle
    style.fill: "#ffffff"
    # Row labels
    r0_s: {shape: text; label: "Row 0"}
    r1_s: {shape: text; label: "Row 1"}
    r2_s: {shape: text; label: "Row 2"}
    r3_s: {shape: text; label: "Row 3"}
    # Row 0 cells - with padding, column 1 gives different banks
    c00_s: {shape: rectangle; label: "0,0\nB0"; style.fill: "#ff6b6b"; style.font-size: 9}
    c01_s: {shape: rectangle; label: "0,1\nB1"; style.fill: "#feca57"; style.font-size: 9; style.stroke: "#28a745"; style.stroke-width: 3}
    c02_s: {shape: rectangle; label: "0,2\nB2"; style.fill: "#48dbfb"; style.font-size: 9}
    c03_s: {shape: rectangle; label: "0,3\nB3"; style.fill: "#ff9ff3"; style.font-size: 9}
    c04_s: {shape: rectangle; label: "PAD"; style.fill: "#6c757d"; style.font-color: white; style.font-size: 9}
    # Row 1 cells - shifted by +1
    c10_s: {shape: rectangle; label: "1,0\nB1"; style.fill: "#feca57"; style.font-size: 9}
    c11_s: {shape: rectangle; label: "1,1\nB2"; style.fill: "#48dbfb"; style.font-size: 9; style.stroke: "#28a745"; style.stroke-width: 3}
    c12_s: {shape: rectangle; label: "1,2\nB3"; style.fill: "#ff9ff3"; style.font-size: 9}
    c13_s: {shape: rectangle; label: "1,3\nB4"; style.fill: "#1dd1a1"; style.font-size: 9}
    c14_s: {shape: rectangle; label: "PAD"; style.fill: "#6c757d"; style.font-color: white; style.font-size: 9}
    # Row 2 cells - shifted by +2
    c20_s: {shape: rectangle; label: "2,0\nB2"; style.fill: "#48dbfb"; style.font-size: 9}
    c21_s: {shape: rectangle; label: "2,1\nB3"; style.fill: "#ff9ff3"; style.font-size: 9; style.stroke: "#28a745"; style.stroke-width: 3}
    c22_s: {shape: rectangle; label: "2,2\nB4"; style.fill: "#1dd1a1"; style.font-size: 9}
    c23_s: {shape: rectangle; label: "2,3\nB5"; style.fill: "#10ac84"; style.font-size: 9}
    c24_s: {shape: rectangle; label: "PAD"; style.fill: "#6c757d"; style.font-color: white; style.font-size: 9}
    # Row 3 cells - shifted by +3
    c30_s: {shape: rectangle; label: "3,0\nB3"; style.fill: "#ff9ff3"; style.font-size: 9}
    c31_s: {shape: rectangle; label: "3,1\nB4"; style.fill: "#1dd1a1"; style.font-size: 9; style.stroke: "#28a745"; style.stroke-width: 3}
    c32_s: {shape: rectangle; label: "3,2\nB5"; style.fill: "#10ac84"; style.font-size: 9}
    c33_s: {shape: rectangle; label: "3,3\nB6"; style.fill: "#00d2d3"; style.font-size: 9}
    c34_s: {shape: rectangle; label: "PAD"; style.fill: "#6c757d"; style.font-color: white; style.font-size: 9}
    # Layout
    r0_s -> c00_s -> c01_s -> c02_s -> c03_s -> c04_s: {style.opacity: 0}
    r1_s -> c10_s -> c11_s -> c12_s -> c13_s -> c14_s: {style.opacity: 0}
    r2_s -> c20_s -> c21_s -> c22_s -> c23_s -> c24_s: {style.opacity: 0}
    r3_s -> c30_s -> c31_s -> c32_s -> c33_s -> c34_s: {style.opacity: 0}
  }
  noconflict_indicator: {
    shape: text
    label: "← Column 1 access: Row 0→B1, Row 1→B2, Row 2→B3, Row 3→B4\n   Each thread → DIFFERENT bank → NO CONFLICTS!"
    style: {
      fill: "#28a745"
      font-color: "#155724"
      bold: true
    }
  }
}

problem_section -> solution_section: {
  label: "Add +1 padding"
  style: {
    stroke: "#155724"
    stroke-width: 3
    stroke-dash: 5
  }
}

# Memory layout detail
memory_detail: {
  label: "Memory Layout Detail (First 8 Columns of Rows 0-3)"
  style: {
    fill: "#e2e3e5"
    stroke: "#383d41"
  }
  # Byte offset header
  offset_header: {
    shape: rectangle
    label: ""
    style.fill: "#343a40"
    off_0: {shape: text; label: "+0"; style.font-color: white; style.font-size: 10}
    off_4: {shape: text; label: "+4"; style.font-color: white; style.font-size: 10}
    off_8: {shape: text; label: "+8"; style.font-color: white; style.font-size: 10}
    off_12: {shape: text; label: "+12"; style.font-color: white; style.font-size: 10}
    off_16: {shape: text; label: "+16"; style.font-color: white; style.font-size: 10}
    off_20: {shape: text; label: "+20"; style.font-color: white; style.font-size: 10}
    off_24: {shape: text; label: "+24"; style.font-color: white; style.font-size: 10}
    off_28: {shape: text; label: "+28"; style.font-color: white; style.font-size: 10}
    off_0 -> off_4 -> off_8 -> off_12 -> off_16 -> off_20 -> off_24 -> off_28: {style.opacity: 0}
  }
  # Bank header
  bank_header: {
    shape: rectangle
    label: ""
    style.fill: "#495057"
    bk_0: {shape: text; label: "B0"; style.font-color: white; style.font-size: 10}
    bk_1: {shape: text; label: "B1"; style.font-color: white; style.font-size: 10}
    bk_2: {shape: text; label: "B2"; style.font-color: white; style.font-size: 10}
    bk_3: {shape: text; label: "B3"; style.font-color: white; style.font-size: 10}
    bk_4: {shape: text; label: "B4"; style.font-color: white; style.font-size: 10}
    bk_5: {shape: text; label: "B5"; style.font-color: white; style.font-size: 10}
    bk_6: {shape: text; label: "B6"; style.font-color: white; style.font-size: 10}
    bk_7: {shape: text; label: "B7"; style.font-color: white; style.font-size: 10}
    bk_0 -> bk_1 -> bk_2 -> bk_3 -> bk_4 -> bk_5 -> bk_6 -> bk_7: {style.opacity: 0}
  }
  # Row 0 data
  row0_data: {
    label: ""
    shape: rectangle
    r0_label: {shape: text; label: "Row 0:"; style.bold: true}
    d00: {shape: rectangle; label: "[0][0]"; style.fill: "#ff6b6b"; style.font-size: 9}
    d01: {shape: rectangle; label: "[0][1]"; style.fill: "#feca57"; style.font-size: 9}
    d02: {shape: rectangle; label: "[0][2]"; style.fill: "#48dbfb"; style.font-size: 9}
    d03: {shape: rectangle; label: "[0][3]"; style.fill: "#ff9ff3"; style.font-size: 9}
    d04: {shape: rectangle; label: "[0][4]"; style.fill: "#1dd1a1"; style.font-size: 9}
    d05: {shape: rectangle; label: "[0][5]"; style.fill: "#10ac84"; style.font-size: 9}
    d06: {shape: rectangle; label: "[0][6]"; style.fill: "#00d2d3"; style.font-size: 9}
    d07: {shape: rectangle; label: "[0][7]"; style.fill: "#5f27cd"; style.font-size: 9}
    r0_label -> d00 -> d01 -> d02 -> d03 -> d04 -> d05 -> d06 -> d07: {style.opacity: 0}
  }
  # Row 1 data (shifted by 1)
  row1_data: {
    label: ""
    shape: rectangle
    r1_label: {shape: text; label: "Row 1:"; style.bold: true}
    d10: {shape: rectangle; label: "[1][0]"; style.fill: "#feca57"; style.font-size: 9}
    d11: {shape: rectangle; label: "[1][1]"; style.fill: "#48dbfb"; style.font-size: 9}
    d12: {shape: rectangle; label: "[1][2]"; style.fill: "#ff9ff3"; style.font-size: 9}
    d13: {shape: rectangle; label: "[1][3]"; style.fill: "#1dd1a1"; style.font-size: 9}
    d14: {shape: rectangle; label: "[1][4]"; style.fill: "#10ac84"; style.font-size: 9}
    d15: {shape: rectangle; label: "[1][5]"; style.fill: "#00d2d3"; style.font-size: 9}
    d16: {shape: rectangle; label: "[1][6]"; style.fill: "#5f27cd"; style.font-size: 9}
    d17: {shape: rectangle; label: "[1][7]"; style.fill: "#ff6b6b"; style.font-size: 9}
    r1_label -> d10 -> d11 -> d12 -> d13 -> d14 -> d15 -> d16 -> d17: {style.opacity: 0}
  }
  # Row 2 data (shifted by 2)
  row2_data: {
    label: ""
    shape: rectangle
    r2_label: {shape: text; label: "Row 2:"; style.bold: true}
    d20: {shape: rectangle; label: "[2][0]"; style.fill: "#48dbfb"; style.font-size: 9}
    d21: {shape: rectangle; label: "[2][1]"; style.fill: "#ff9ff3"; style.font-size: 9}
    d22: {shape: rectangle; label: "[2][2]"; style.fill: "#1dd1a1"; style.font-size: 9}
    d23: {shape: rectangle; label: "[2][3]"; style.fill: "#10ac84"; style.font-size: 9}
    d24: {shape: rectangle; label: "[2][4]"; style.fill: "#00d2d3"; style.font-size: 9}
    d25: {shape: rectangle; label: "[2][5]"; style.fill: "#5f27cd"; style.font-size: 9}
    d26: {shape: rectangle; label: "[2][6]"; style.fill: "#ff6b6b"; style.font-size: 9}
    d27: {shape: rectangle; label: "[2][7]"; style.fill: "#feca57"; style.font-size: 9}
    r2_label -> d20 -> d21 -> d22 -> d23 -> d24 -> d25 -> d26 -> d27: {style.opacity: 0}
  }
  # Row 3 data (shifted by 3)
  row3_data: {
    label: ""
    shape: rectangle
    r3_label: {shape: text; label: "Row 3:"; style.bold: true}
    d30: {shape: rectangle; label: "[3][0]"; style.fill: "#ff9ff3"; style.font-size: 9}
    d31: {shape: rectangle; label: "[3][1]"; style.fill: "#1dd1a1"; style.font-size: 9}
    d32: {shape: rectangle; label: "[3][2]"; style.fill: "#10ac84"; style.font-size: 9}
    d33: {shape: rectangle; label: "[3][3]"; style.fill: "#00d2d3"; style.font-size: 9}
    d34: {shape: rectangle; label: "[3][4]"; style.fill: "#5f27cd"; style.font-size: 9}
    d35: {shape: rectangle; label: "[3][5]"; style.fill: "#ff6b6b"; style.font-size: 9}
    d36: {shape: rectangle; label: "[3][6]"; style.fill: "#feca57"; style.font-size: 9}
    d37: {shape: rectangle; label: "[3][7]"; style.fill: "#48dbfb"; style.font-size: 9}
    r3_label -> d30 -> d31 -> d32 -> d33 -> d34 -> d35 -> d36 -> d37: {style.opacity: 0}
  }
  # Vertical alignment
  offset_header -> bank_header -> row0_data -> row1_data -> row2_data -> row3_data: {
    style.opacity: 0
  }
}

# Bank architecture
bank_arch: {
  label: "Shared Memory Bank Architecture"
  style: {
    fill: "#cce5ff"
    stroke: "#004085"
  }
  bank_desc: {
    shape: text
    label: "32 banks × 4 bytes wide = 128 bytes per bank row\nSuccessive 4-byte words map to successive banks (0→1→2→...→31→0)"
    style.font-size: 11
  }
  banks_visual: {
    label: ""
    shape: rectangle
    bank_row: {
      shape: text
      label: "Banks 0-31 (128 bytes total width)"
      style.bold: true
    }
    b0_box: {shape: rectangle; label: "Bank 0\n0-3"; style.fill: "#ff6b6b"; style.font-size: 9}
    b1_box: {shape: rectangle; label: "Bank 1\n4-7"; style.fill: "#feca57"; style.font-size: 9}
    b2_box: {shape: rectangle; label: "Bank 2\n8-11"; style.fill: "#48dbfb"; style.font-size: 9}
    dots1: {shape: text; label: "..."}
    b30_box: {shape: rectangle; label: "Bank 30\n120-123"; style.fill: "#54a0ff"; style.font-size: 9}
    b31_box: {shape: rectangle; label: "Bank 31\n124-127"; style.fill: "#5f27cd"; style.font-size: 9}
    b0_box -> b1_box -> b2_box -> dots1 -> b30_box -> b31_box: {style.opacity: 0}
  }
  wrap_note: {
    shape: text
    label: "Bank assignment wraps: byte 128 → Bank 0, byte 132 → Bank 1, etc."
    style: {
      italic: true
      font-size: 10
    }
  }
  bank_desc -> banks_visual -> wrap_note: {style.opacity: 0}
}

# Code example
code_example: {
  label: "CUDA Declaration"
  style: {
    fill: "#f5f5f5"
    stroke: "#333"
  }
  code: {
    shape: code
    language: cpp
    label: |cpp
      // WITHOUT padding - 32-way bank conflict on column access
      __shared__ float tile[32][32];  // Bank = (row*32 + col) % 32

      // WITH padding - NO bank conflicts
      __shared__ float tile[32][33];  // Bank = (row*33 + col) % 32
      // Each row shifted by +1 bank relative to previous row
    |
  }
}

solution_section -> memory_detail: {style.opacity: 0}
memory_detail -> bank_arch: {style.opacity: 0}
bank_arch -> code_example: {style.opacity: 0}