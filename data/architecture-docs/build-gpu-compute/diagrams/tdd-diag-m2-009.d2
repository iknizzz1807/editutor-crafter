vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

title: {
  label: "Synchronization Barrier State Machine\n__syncthreads() Thread Block Coordination"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}

legend: {
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#1a1a2e"
  }
  near: bottom-right

  normal_flow: { label: "в”Җв”Җв”Җв–¶  Normal Execution Flow" }
  error_path: { label: "- - - в–¶  Error Path (Race Condition)" }
  deadlock_path: { 
    label: "===> Deadlock Path (Divergent Code)"
  }
  init_marker: {
    label: "(init)\nInitial State"
    shape: circle
    style.fill: "#4a5568"
  }
  final_marker: {
    label: "(final)\nTerminal State"
    shape: circle
    style.fill: "#48bb78"
  }
  error_marker: {
    label: "(error)\nError State"
    shape: circle
    style.fill: "#fc8181"
  }
}

# Initial pseudo-state
init_arriving: {
  shape: circle
  style: {
    fill: "#2d3748"
    stroke: "#a0aec0"
    stroke-width: 3
  }
  width: 20
  height: 20
}

# Thread states within barrier synchronization
thread_running: {
  label: "Thread Running\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n[entry / execute_kernel_code]\n[invariant: thread_id вҲҲ block]"
  shape: rectangle
  style: {
    fill: "#2d3748"
    stroke: "#4299e1"
    stroke-width: 2
    font-color: "#e2e8f0"
  }
}

barrier_arriving: {
  label: "Arriving at Barrier\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n[entry / register_arrival]\n[invariant: arrival_count += 1]\n[guard: arrival_count вүӨ block_size]"
  shape: rectangle
  style: {
    fill: "#2c5282"
    stroke: "#63b3ed"
    stroke-width: 2
    font-color: "#e2e8f0"
  }
}

waiting_at_barrier: {
  label: "Waiting at Barrier\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n[invariant: waiting_for_all_threads]\n[invariant: block_size == arrival_count]\n[entry / spin_on_barrier_flag]\n[guard: arrival_count < block_size]"
  shape: rectangle
  style: {
    fill: "#2b6cb0"
    stroke: "#90cdf4"
    stroke-width: 2
    font-color: "#e2e8f0"
    multiple: true
  }
}

all_threads_arrived: {
  label: "All Threads Arrived\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n[entry / release_all_threads]\n[invariant: barrier_complete == true]\n[action: broadcast_release_signal]"
  shape: rectangle
  style: {
    fill: "#276749"
    stroke: "#68d391"
    stroke-width: 2
    font-color: "#e2e8f0"
  }
}

proceeding_synced: {
  label: "Proceeding (Synchronized)\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n[entry / continue_kernel_execution]\n[invariant: all_threads_synced]\n[action: memory_fence_complete]"
  shape: rectangle
  style: {
    fill: "#22543d"
    stroke: "#48bb78"
    stroke-width: 2
    font-color: "#e2e8f0"
  }
}

# Final state
final_complete: {
  shape: circle
  label: "вң“"
  style: {
    fill: "#48bb78"
    stroke: "#276749"
    stroke-width: 3
    font-color: "#1a202c"
    font-size: 20
    bold: true
  }
  width: 40
  height: 40
}

# Error states
race_condition: {
  label: "вҡ  RACE CONDITION\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n[error: missing_barrier]\n[diagnostic: unsafe_shared_memory_access]\n[impact: data_corruption]\n[cause: thread_A_writes_before_thread_B_reads]"
  shape: rectangle
  style: {
    fill: "#742a2a"
    stroke: "#fc8181"
    stroke-width: 3
    font-color: "#fed7d7"
  }
}

deadlock_state: {
  label: "вҳ  DEADLOCK\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n[error: divergent_barrier]\n[diagnostic: subset_threads_at_barrier]\n[impact: gpu_hang_timeout]\n[cause: conditional_syncthreads]\n[example: if(tid < 128) __syncthreads()]"
  shape: rectangle
  style: {
    fill: "#553c9a"
    stroke: "#b794f4"
    stroke-width: 3
    font-color: "#e9d8fd"
    double-border: true
  }
}

# Transitions - Normal Flow
init_arriving -> thread_running: "kernel_launch" {
  style: {
    stroke: "#4299e1"
    stroke-width: 2
  }
}

thread_running -> barrier_arriving: "__syncthreads() called" {
  style: {
    stroke: "#4299e1"
    stroke-width: 2
  }
}

barrier_arriving -> waiting_at_barrier: "not_last_thread\n[guard: arrival_count < block_size]" {
  style: {
    stroke: "#63b3ed"
    stroke-width: 2
  }
}

barrier_arriving -> all_threads_arrived: "last_thread_arrived\n[guard: arrival_count == block_size]" {
  style: {
    stroke: "#68d391"
    stroke-width: 2
  }
}

waiting_at_barrier -> all_threads_arrived: "all_threads_reached\n[trigger: barrier_release_signal]" {
  style: {
    stroke: "#68d391"
    stroke-width: 2
  }
}

all_threads_arrived -> proceeding_synced: "release_all\n[action: invalidate_shared_memory_cache]" {
  style: {
    stroke: "#48bb78"
    stroke-width: 2
  }
}

proceeding_synced -> final_complete: "kernel_complete" {
  style: {
    stroke: "#48bb78"
    stroke-width: 2
  }
}

# Transitions - Error Paths (Race Condition)
thread_running -> race_condition: "missing __syncthreads()\n[guard: shared_memory_write вҶ’ read\nwithout synchronization]" {
  style: {
    stroke: "#fc8181"
    stroke-width: 2
    stroke-dash: 6
    animated: true
  }
}

race_condition -> race_condition: "undefined_behavior\n[memory_hazard_persists]" {
  style: {
    stroke: "#fc8181"
    stroke-width: 1
    stroke-dash: 4
  }
}

# Transitions - Deadlock Path
barrier_arriving -> deadlock_state: "divergent_execution_path\n[guard: syncthreads_inside\nconditional_branch]" {
  style: {
    stroke: "#b794f4"
    stroke-width: 4
    stroke-dash: 6
  }
}

waiting_at_barrier -> deadlock_state: "waiting_forever\n[trigger: timeout]\n[some_threads_never_arrive]" {
  style: {
    stroke: "#b794f4"
    stroke-width: 4
    stroke-dash: 6
  }
}

# Code examples
code_example_correct: {
  label: "вң“ Correct Usage:\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ __shared__ float s[256];в”Ӯ\nв”Ӯ s[tid] = data[tid];     в”Ӯ\nв”Ӯ __syncthreads();        в”Ӯ\nв”Ӯ float v = s[255-tid];   в”Ӯ\nв”Ӯ __syncthreads();        в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
  shape: text
  style: {
    font: mono
    font-color: "#68d391"
    font-size: 12
  }
}

code_example_race: {
  label: "вң— Race Condition:\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ __shared__ float s[256];в”Ӯ\nв”Ӯ s[tid] = data[tid];     в”Ӯ\nв”Ӯ // MISSING BARRIER!     в”Ӯ\nв”Ӯ float v = s[255-tid];   в”Ӯ\nв”Ӯ // вҶ‘ Reads stale data   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
  shape: text
  style: {
    font: mono
    font-color: "#fc8181"
    font-size: 12
  }
}

code_example_deadlock: {
  label: "вң— Deadlock:\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ if (tid < 128) {        в”Ӯ\nв”Ӯ   // ... code A ...     в”Ӯ\nв”Ӯ   __syncthreads();      в”Ӯ\nв”Ӯ } else {                в”Ӯ\nв”Ӯ   // ... code B ...     в”Ӯ\nв”Ӯ   __syncthreads();      в”Ӯ\nв”Ӯ }                       в”Ӯ\nв”Ӯ // вҶ‘ Only half arrive!  в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
  shape: text
  style: {
    font: mono
    font-color: "#b794f4"
    font-size: 12
  }
}

# Annotations
annotation_barrier: {
  label: "Barrier Semantics:\nвҖў All threads in block must reach\nвҖў Guarantees memory consistency\nвҖў Acts as memory fence for shared memory\nвҖў Block-level synchronization only"
  shape: text
  style: {
    font-color: "#a0aec0"
    font-size: 11
  }
}

# Layout connections (invisible, for positioning)
code_example_correct -> thread_running: { style.opacity: 0 }
annotation_barrier -> waiting_at_barrier: { style.opacity: 0 }
code_example_race -> race_condition: { style.opacity: 0 }
code_example_deadlock -> deadlock_state: { style.opacity: 0 }