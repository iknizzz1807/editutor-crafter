direction: right
layout-engine: elk
theme-id: 4

title: {
  label: "Matrix Transpose Bandwidth Comparison\nRTX 3080 Performance Analysis"
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

y_axis_label: {
  label: "Bandwidth (GB/s)"
  shape: text
  style: {
    font-size: 14
    bold: true
  }
}

scale_700: {
  label: "700 ─"
  shape: text
}
scale_600: {
  label: "600 ─"
  shape: text
}
scale_500: {
  label: "500 ─"
  shape: text
}
scale_400: {
  label: "400 ─"
  shape: text
}
scale_300: {
  label: "300 ─"
  shape: text
}
scale_200: {
  label: "200 ─"
  shape: text
}
scale_100: {
  label: "100 ─"
  shape: text
}
scale_50: {
  label: " 50 ─"
  shape: text
}
scale_0: {
  label: "   0 └───────────────────────────────────────"
  shape: text
}

chart_area: {
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: transparent
  }

  bar_theoretical: {
    shape: rectangle
    label: ""
    width: 80
    height: 380
    style: {
      fill: "#E53935"
      stroke: "#B71C1C"
      stroke-width: 2
    }
    value_label: {
      label: "760 GB/s\n(100%)"
      shape: text
      style: {
        font-size: 11
        bold: true
      }
    }
    name_label: {
      label: "Theoretical\nPeak"
      shape: text
      style: {
        font-size: 10
      }
    }
  }

  bar_optimized: {
    shape: rectangle
    label: ""
    width: 80
    height: 275
    style: {
      fill: "#43A047"
      stroke: "#1B5E20"
      stroke-width: 2
    }
    value_label: {
      label: "550 GB/s\n(72%)"
      shape: text
      style: {
        font-size: 11
        bold: true
      }
    }
    name_label: {
      label: "Tiled +\nPadding"
      shape: text
      style: {
        font-size: 10
      }
    }
  }

  bar_tiled: {
    shape: rectangle
    label: ""
    width: 80
    height: 150
    style: {
      fill: "#FB8C00"
      stroke: "#E65100"
      stroke-width: 2
    }
    value_label: {
      label: "300 GB/s\n(39%)"
      shape: text
      style: {
        font-size: 11
        bold: true
      }
    }
    name_label: {
      label: "Tiled\n(No Padding)"
      shape: text
      style: {
        font-size: 10
      }
    }
  }

  bar_naive: {
    shape: rectangle
    label: ""
    width: 80
    height: 20
    style: {
      fill: "#546E7A"
      stroke: "#263238"
      stroke-width: 2
    }
    value_label: {
      label: "40 GB/s\n(5%)"
      shape: text
      style: {
        font-size: 11
        bold: true
      }
    }
    name_label: {
      label: "Naive\nTranspose"
      shape: text
      style: {
        font-size: 10
      }
    }
  }
}

improvement_arrow: {
  label: "13.75x Improvement"
  shape: text
  style: {
    font-size: 16
    bold: true
    font-color: "#2E7D32"
  }
}

naive_to_tiled: {
  label: "7.5x"
  shape: text
  style: {
    font-size: 12
    font-color: "#E65100"
  }
}

tiled_to_optimized: {
  label: "1.8x"
  shape: text
  style: {
    font-size: 12
    font-color: "#1B5E20"
  }
}

legend_box: {
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 0
  }
  legend_title: {
    label: "Optimization Stages"
    shape: text
    style: {
      font-size: 12
      bold: true
    }
  }
  leg_theoretical: {
    label: "■ Theoretical Peak (Device Limit)"
    shape: text
    style: {
      font-size: 10
      font-color: "#E53935"
    }
  }
  leg_optimized: {
    label: "■ Tiled + Bank Conflict Padding"
    shape: text
    style: {
      font-size: 10
      font-color: "#43A047"
    }
  }
  leg_tiled: {
    label: "■ Tiled (Shared Memory)"
    shape: text
    style: {
      font-size: 10
      font-color: "#FB8C00"
    }
  }
  leg_naive: {
    label: "■ Naive (Non-Coalesced)"
    shape: text
    style: {
      font-size: 10
      font-color: "#546E7A"
    }
  }
}

bottleneck_note: {
  label: "Bottleneck Analysis:\n• Naive: Strided memory access (non-coalesced reads)\n• Tiled: Shared memory bank conflicts\n• Optimized: Bank conflict padding eliminates conflicts\n• Gap to peak: DRAM efficiency, kernel overhead"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-dash: 4
    font-size: 10
  }
}

hardware_spec: {
  label: "Hardware: NVIDIA RTX 3080\nGDDR6X @ 19 Gbps\n320-bit memory bus"
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
    font-size: 10
  }
}

connections: {
  style: {
    stroke: transparent
  }
}

y_axis_label -> scale_700 -> scale_600 -> scale_500 -> scale_400 -> scale_300 -> scale_200 -> scale_100 -> scale_50 -> scale_0 -> chart_area

chart_area.bar_naive -> chart_area.bar_tiled -> chart_area.bar_optimized -> chart_area.bar_theoretical

chart_area -> legend_box

legend_box.legend_title -> legend_box.leg_theoretical -> legend_box.leg_optimized -> legend_box.leg_tiled -> legend_box.leg_naive

chart_area.bar_naive.value_label -> naive_to_tiled -> chart_area.bar_tiled.value_label
chart_area.bar_tiled.value_label -> tiled_to_optimized -> chart_area.bar_optimized.value_label
chart_area.bar_naive.name_label -> improvement_arrow -> chart_area.bar_optimized.name_label

chart_area -> bottleneck_note -> hardware_spec