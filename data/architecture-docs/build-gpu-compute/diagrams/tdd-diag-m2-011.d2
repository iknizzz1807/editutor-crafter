direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

# DRAM Row Buffer Access Architecture
# Detailed Technical Specification: Row-Hit vs. Row-Miss Scenarios

title: {
  label: "DRAM Row Buffer Access Patterns: Performance & Coalescing"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# 1. DRAM Bank Physical Layout
DRAM_Bank: {
  label: "DRAM Bank (Physical Hardware)"
  tooltip: "sizeof=8GB per Rank, 8-16 Banks per Rank"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 4
  }

  Row_Buffer: {
    label: "SRAM Row Buffer (8KB Sense Amplifiers)"
    shape: rectangle
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      stroke-width: 5
      double-border: true
    }
    
    buffer_data: "Active Row Data Segment" {
      style.fill: "#90CAF9"
      style.bold: true
    }
    
    metadata: |md
      - **State:** ACTIVE
      - **Current Row:** R0
      - **Access Time:** tCAS (Column Address Strobe)
    |
  }

  Row_Array: "Memory Cell Array (Capacitor Grid)" {
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
    }

    Row_0: "Row 0 (Addr: 0x0000) [A|B|C|D|E|F|G|H]" {
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    Row_1: "Row 1 (Addr: 0x2000) [I|J|K|L|M|N|O|P]" {
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
    }
    Row_2: "Row 2 (Addr: 0x4000) [Q|R|S|T|U|V|W|X]" {
      style.fill: "#FFF9C4"
      style.stroke: "#FFC107"
    }
    Row_N: "Row N ..." {
      style.fill: "#E1BEE7"
      style.stroke: "#9C27B0"
    }
  }

  Row_Buffer -> Row_Array: "1. PRE (Precharge)\n2. ACT (Activate)" {
    style.stroke-dash: 3
    style.font-size: 10
  }
}

# 2. Optimized Path: Coalesced Access
Row_Hit_Scenario: {
  label: "CASE A: Coalesced Access (Row-Hit)"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
  }

  GPU_Warps: {
    label: "Warp 0 (Threads 0-31)"
    T0: "T0 → 0x000"
    T1: "T1 → 0x004"
    T2: "T2 → 0x008"
    T3: "T3 → 0x00C"
    
    style.fill: "#C8E6C9"
    *.shape: circle
    *.style.fill: "#81C784"
  }

  Coalescer: {
    label: "MQA (Memory Request Aggregator)"
    shape: diamond
    style.fill: "#A5D6A7"
  }

  Transaction: "Single 128B Memory Transaction" {
    shape: rectangle
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      bold: true
    }
  }

  Hit_Metrics: "Performance Profile" {
    shape: sql_table
    Status: ROW HIT {constraint: PK}
    Latency: "~20ns (tCAS)"
    Throughput: "Peak (100%)"
  }

  GPU_Warps -> Coalescer: "Contiguous Addresses"
  Coalescer -> Transaction: "Combined"
  Transaction -> Hit_Metrics: "Single Bus Cycle"
}

# 3. Degraded Path: Strided Access
Row_Miss_Scenario: {
  label: "CASE B: Strided Access (Row-Miss/Thrashing)"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
  }

  GPU_Warps_Bad: {
    label: "Warp 1 (Threads 0-31)"
    T0_m: "T0 → R0"
    T1_m: "T1 → R1"
    T2_m: "T2 → R2"
    T3_m: "T3 → R3"
    
    style.fill: "#FFCDD2"
    *.shape: circle
    *.style.fill: "#E57373"
  }

  Miss_Logic: "Serialized Bus Cycles" {
    shape: diamond
    style.fill: "#EF9A9A"
  }

  Timeline: {
    shape: sequence_diagram
    Memory_Controller: "Controller"
    DRAM_Buffer: "Row Buffer"
    
    Memory_Controller -> DRAM_Buffer: "ACT R0"
    DRAM_Buffer -> Memory_Controller: "Data T0"
    Memory_Controller -> DRAM_Buffer: "PRE (Close R0)"
    Memory_Controller -> DRAM_Buffer: "ACT R1 (MISS!)"
    DRAM_Buffer -> Memory_Controller: "Data T1"
    Memory_Controller -> DRAM_Buffer: "PRE (Close R1)"
  }

  Miss_Metrics: "Performance Profile" {
    shape: sql_table
    Status: ROW MISS {constraint: "ERR"}
    Latency: "100ns+ (tRP+tRC+tCAS)"
    Throughput: "Sub-15%"
  }

  GPU_Warps_Bad -> Miss_Logic: "Non-contiguous"
  Miss_Logic -> Timeline: "Serializing Requests"
  Timeline -> Miss_Metrics
}

# 4. Access Pattern Visualization
Access_Patterns: {
  label: "Access Pattern Comparison"
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    stroke-width: 2
  }

  Good_Pattern: {
    label: "Coalesced (Optimal)"
    shape: rectangle
    style.fill: "#C8E6C9"
    pattern: |md
      
      Thread:  [0] [1] [2] [3] [4] [5] [6] [7]
      Address: [A] [B] [C] [D] [E] [F] [G] [H]
               └─────────── SAME ROW ───────────┘
      
    |
    pattern.style.font: mono
  }

  Bad_Pattern: {
    label: "Strided (Sub-optimal)"
    shape: rectangle
    style.fill: "#FFCDD2"
    pattern: |md
      
      Thread:  [0]   [1]   [2]   [3]
      Address: [A]   [I]   [Q]   [Y]
               R0    R1    R2    R3
               └──── DIFFERENT ROWS ────┘
      
    |
    pattern.style.font: mono
  }
}

# 5. Legend & Best Practices
Footer: {
  near: bottom-center
  
  Legend: {
    grid-columns: 3
    L1: "Row Hit (Fast Path)" { style.fill: "#4CAF50" }
    L2: "Row Miss (Slow Path)" { style.fill: "#F44336" }
    L3: "Memory Hierarchy" { style.fill: "#1976D2"; style.font-color: white }
  }

  Best_Practices: |md
    ### Developer Implementation Checklist
    1. **Adjacent Access:** Ensure threads in a warp access adjacent 4-byte words.
    2. **Alignment:** Base address of memory transactions should be aligned to **128 bytes**.
    3. **Layout:** Prefer **Structure of Arrays (SoA)** over Arrays of Structures (AoS).
    4. **Shared Memory:** If strided access is unavoidable, stage data in L1/Shared Memory first.
  |
}

# System Connections
Row_Hit_Scenario -> DRAM_Bank: "1. Transaction" {
  style.stroke: "#2E7D32"
  style.stroke-width: 4
}
Row_Miss_Scenario -> DRAM_Bank: "N Serial Transactions" {
  style.stroke: "#C62828"
  style.stroke-dash: 5
}
DRAM_Bank -> Access_Patterns: "Hardware Feedback"
Access_Patterns -> Footer.Best_Practices: "Refactoring Signal"