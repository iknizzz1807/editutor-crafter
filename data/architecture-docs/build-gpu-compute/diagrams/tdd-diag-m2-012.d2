direction: right
layout: elk
title: Matrix Transpose Block Mapping {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}
# Input Matrix Grid
input_matrix: {
  label: "Input Matrix (NxN)"
  shape: rectangle
  style.fill: "#E3F2FD"
  # Row labels
  row0: { label: "by=0"; shape: text; style.font-size: 10 }
  row1: { label: "by=1"; shape: text; style.font-size: 10 }
  row2: { label: "by=2"; shape: text; style.font-size: 10 }
  row3: { label: "by=..."; shape: text; style.font-size: 10 }
  # Block grid
  block_0_0: {
    label: "(0,0)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  block_1_0: {
    label: "(1,0)"
    shape: rectangle
    style.fill: "#90CAF9"
  }
  block_2_0: {
    label: "(2,0)"
    shape: rectangle
    style.fill: "#64B5F6"
  }
  block_0_1: {
    label: "(0,1)"
    shape: rectangle
    style.fill: "#81C784"
  }
  block_1_1: {
    label: "(1,1)"
    shape: rectangle
    style.fill: "#66BB6A"
  }
  block_2_1: {
    label: "(2,1)"
    shape: rectangle
    style.fill: "#4CAF50"
  }
  block_0_2: {
    label: "(0,2)"
    shape: rectangle
    style.fill: "#CE93D8"
  }
  block_1_2: {
    label: "(1,2)"
    shape: rectangle
    style.fill: "#BA68C8"
  }
  block_2_2: {
    label: "(2,2)"
    shape: rectangle
    style.fill: "#AB47BC"
  }
  # Layout connections for grid
  block_0_0 -> block_1_0 -> block_2_0
  block_0_1 -> block_1_1 -> block_2_1
  block_0_2 -> block_1_2 -> block_2_2
  block_0_0 -> block_0_1 -> block_0_2
  block_1_0 -> block_1_1 -> block_1_2
  block_2_0 -> block_2_1 -> block_2_2
  row0 -> block_0_0
  row1 -> block_0_1
  row2 -> block_0_2
}
# Block detail
block_detail: {
  label: "Block (bx, by)"
  shape: rectangle
  style.fill: "#FFF9C4"
  tile_grid: {
    label: "Tile 32×32"
    shape: rectangle
    style.fill: "#FFEB3B"
    cell: {
      label: "32×32\n-elements"
      shape: rectangle
      style.fill: "#FFEE58"
    }
  }
  threads: {
    label: "256 threads\n(BLOCK_ROWS=8)"
    shape: text
    style.font-size: 11
  }
  tile_grid -> threads
}
# Mapping arrow
mapping: {
  label: "Transpose\nMapping"
  shape: text
  style: {
    font-size: 14
    bold: true
  }
}
input_matrix -> mapping: {
  label: "block(bx,by)\n→ (by,bx)"
  style.stroke-dash: 3
}
mapping -> output_matrix
# Output Matrix Grid
output_matrix: {
  label: "Output Matrix (NxN) - Transposed"
  shape: rectangle
  style.fill: "#FCE4EC"
  # Column labels
  col0: { label: "bx=0"; shape: text; style.font-size: 10 }
  col1: { label: "bx=1"; shape: text; style.font-size: 10 }
  col2: { label: "bx=2"; shape: text; style.font-size: 10 }
  col3: { label: "bx=..."; shape: text; style.font-size: 10 }
  # Transposed block grid (swapped positions)
  out_0_0: {
    label: "(0,0)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  out_0_1: {
    label: "(1,0)"
    shape: rectangle
    style.fill: "#90CAF9"
  }
  out_0_2: {
    label: "(2,0)"
    shape: rectangle
    style.fill: "#64B5F6"
  }
  out_1_0: {
    label: "(0,1)"
    shape: rectangle
    style.fill: "#81C784"
  }
  out_1_1: {
    label: "(1,1)"
    shape: rectangle
    style.fill: "#66BB6A"
  }
  out_1_2: {
    label: "(2,1)"
    shape: rectangle
    style.fill: "#4CAF50"
  }
  out_2_0: {
    label: "(0,2)"
    shape: rectangle
    style.fill: "#CE93D8"
  }
  out_2_1: {
    label: "(1,2)"
    shape: rectangle
    style.fill: "#BA68C8"
  }
  out_2_2: {
    label: "(2,2)"
    shape: rectangle
    style.fill: "#AB47BC"
  }
  # Layout connections for grid
  out_0_0 -> out_0_1 -> out_0_2
  out_1_0 -> out_1_1 -> out_1_2
  out_2_0 -> out_2_1 -> out_2_2
  out_0_0 -> out_1_0 -> out_2_0
  out_0_1 -> out_1_1 -> out_2_1
  out_0_2 -> out_1_2 -> out_2_2
  col0 -> out_0_0
  col1 -> out_0_1
  col2 -> out_0_2
}
# Example mapping highlight
example_mapping: {
  label: ""
  shape: rectangle
  src_block: {
    label: "Source\nBlock (1,2)"
    shape: rectangle
    style.fill: "#BA68C8"
  }
  arrow: { label: "→"; shape: text; style.font-size: 20 }
  dst_block: {
    label: "Destination\nBlock (2,1)"
    shape: rectangle
    style.fill: "#4CAF50"
  }
  src_block -> arrow -> dst_block
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  note: |`md
  **Mapping Rule:**
  - Input block at (bx, by)
  - Writes to output at (by, bx)
  **Configuration:**
  - TILE_DIM = 32
  - BLOCK_ROWS = 8
  - Threads per block = 256
  `|
}
input_matrix -- block_detail
output_matrix -- example_mapping
legend -- block_detail