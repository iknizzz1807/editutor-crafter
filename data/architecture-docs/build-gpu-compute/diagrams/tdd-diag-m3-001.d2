direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Parallel Reduction Tree (Binary Sum) {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# Level annotations for structural clarity
level_metadata: {
  level_0_label: "Level 0\n(N=8 elements)" {
    style: {
      font-size: 14
      italic: true
    }
  }
  level_1_label: "Level 1\n(N/2=4)" {
    style: {
      font-size: 14
      italic: true
    }
  }
  level_2_label: "Level 2\n(N/4=2)" {
    style: {
      font-size: 14
      italic: true
    }
  }
  level_3_label: "Level 3\n(Result)" {
    style: {
      font-size: 14
      italic: true
    }
  }
}

# Level 0 - Input elements (8 leaves)
n0: "arr[0]\n= 3"
n1: "arr[1]\n= 7"
n2: "arr[2]\n= 1"
n3: "arr[3]\n= 5"
n4: "arr[4]\n= 9"
n5: "arr[5]\n= 2"
n6: "arr[6]\n= 8"
n7: "arr[7]\n= 4"

# Group Level 0 styling
n0, n1, n2, n3, n4, n5, n6, n7: {
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
  }
}

# Level 1 - First reduction (4 partial sums)
l1_0: "3+7\n= 10"
l1_1: "1+5\n= 6"
l1_2: "9+2\n= 11"
l1_3: "8+4\n= 12"

# Group Level 1 styling
l1_0, l1_1, l1_2, l1_3: {
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 2
  }
}

# Level 2 - Second reduction (2 partial sums)
l2_0: "10+6\n= 16"
l2_1: "11+12\n= 23"

# Group Level 2 styling
l2_0, l2_1: {
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
}

# Level 3 - Final result (root)
l3_0: "16+23\n= 39" {
  style: {
    fill: "#FFCCBC"
    stroke: "#E64A19"
    bold: true
    font-size: 18
    double-border: true
  }
}

# Connections from Level 0 to Level 1
n0 -> l1_0: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }
n1 -> l1_0: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }
n2 -> l1_1: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }
n3 -> l1_1: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }
n4 -> l1_2: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }
n5 -> l1_2: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }
n6 -> l1_3: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }
n7 -> l1_3: "+" { style.stroke: "#1976D2"; style.stroke-dash: 3 }

# Connections from Level 1 to Level 2
l1_0 -> l2_0: "+" { style.stroke: "#388E3C"; style.stroke-dash: 3 }
l1_1 -> l2_0: "+" { style.stroke: "#388E3C"; style.stroke-dash: 3 }
l1_2 -> l2_1: "+" { style.stroke: "#388E3C"; style.stroke-dash: 3 }
l1_3 -> l2_1: "+" { style.stroke: "#388E3C"; style.stroke-dash: 3 }

# Connections from Level 2 to Level 3
l2_0 -> l3_0: "+" { style.stroke: "#F9A825"; style.stroke-dash: 3 }
l2_1 -> l3_0: "+" { style.stroke: "#F9A825"; style.stroke-dash: 3 }

# Legend
legend: {
  near: bottom-right
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#FAFAFA"
    border-radius: 10
  }
  input_legend: "Input Array" {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  partial_1_legend: "Level 1 Partial Sums" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  partial_2_legend: "Level 2 Partial Sums" {
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
  result_legend: "Final Result" {
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
  }
  input_legend -> partial_1_legend -> partial_2_legend -> result_legend
}

# Complexity info box
complexity_info: "Complexity Analysis\n━━━━━━━━━━━━━━━━━━\nWork: O(N)\nSpan: O(log N)\nParallelism: O(N/log N)\n━━━━━━━━━━━━━━━━━━\nSteps = log₂(N) = 3" {
  shape: rectangle
  style: {
    font: mono
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    border-radius: 4
  }
}

# CUDA kernel hint using block strings for high precision
cuda_hint: |cpp
  __global__ void reduce(float *in, float *out) {
    // Shared memory for partial sums
    extern __shared__ float partial[];
    int tid = threadIdx.x;
    
    // Logarithmic Reduction Stride: N/2 → N/4 → ... → 1
    for (int s = blockDim.x/2; s > 0; s >>= 1) {
      if (tid < s) {
        partial[tid] += partial[tid + s];
      }
      __syncthreads();
    }
    // Write result of this block to global memory
    if (tid == 0) out[blockIdx.x] = partial[0];
  }
| {
  near: center-left
  style: {
    font-size: 12
    fill: "#263238"
    font-color: "#ECEFF1"
    stroke: "#000000"
    stroke-width: 2
  }
}