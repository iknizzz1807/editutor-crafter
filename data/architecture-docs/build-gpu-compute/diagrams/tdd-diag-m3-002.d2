direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

title: {
  label: "Parallel Reduction: Shared Memory Access Pattern\nKernel: reductionInterleaved (Stride: 8 → 4 → 2 → 1)\nsizeof(sdata) = 64 Bytes (16 x 4B float)"
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# --- LEGEND ---
# Positioned at constant top-left
legend: {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
    shadow: true
  }
  near: top-left
  
  l_title: "Memory Legend" {
    shape: text
    style: { font-size: 16; bold: true; font-color: "#ffffff" }
  }
  
  act: "● Active Thread (tid < stride)" {
    shape: text
    style.font-color: "#00ff88"
  }
  idl: "○ Idle Thread (tid >= stride)" {
    shape: text
    style.font-color: "#666666"
  }
  src: "■ Source sdata[tid]" {
    shape: text
    style.font-color: "#ff6b6b"
  }
  dst: "■ Target sdata[tid+stride]" {
    shape: text
    style.font-color: "#4ecdc4"
  }
  res: "■ Final Accumulated Result" {
    shape: text
    style.font-color: "#ffe66d"
  }
}

# --- TECHNICAL REFERENCE ---
# FIXED: Changed from relative 'near: legend' to constant 'near: top-right' 
# to resolve the circular/constant positioning conflict.
code_block: {
  label: ||cpp
    // Parallel Reduction inside Global/Shared Memory
    // Stride reduces by half each iteration
    for (unsigned int s = blockDim.x / 2; s > 0; s >>= 1) {
        if (tid < s) {
            sdata[tid] += sdata[tid + s];
        }
        __syncthreads();
    }
  ||
  shape: code
  near: top-right
  style: {
    fill: "#0d1117"
    stroke: "#30363d"
    font-color: "#c9d1d9"
  }
}

# --- ITERATION 1 ---
iter1: {
  label: "Iteration 1: stride = 8"
  style: {
    fill: "#0f0f23"
    stroke: "#00ff88"
    stroke-width: 2
  }
  
  threads: {
    grid-columns: 16
    style.fill: "#1a1a2e"
    t0: "T0 ●"; t1: "T1 ●"; t2: "T2 ●"; t3: "T3 ●"; t4: "T4 ●"; t5: "T5 ●"; t6: "T6 ●"; t7: "T7 ●"
    t8: "T8 ○"; t9: "T9 ○"; t10: "T10 ○"; t11: "T11 ○"; t12: "T12 ○"; t13: "T13 ○"; t14: "T14 ○"; t15: "T15 ○"
    
    t0.style.font-color: "#00ff88"; t1.style.font-color: "#00ff88"; t2.style.font-color: "#00ff88"; t3.style.font-color: "#00ff88"
    t4.style.font-color: "#00ff88"; t5.style.font-color: "#00ff88"; t6.style.font-color: "#00ff88"; t7.style.font-color: "#00ff88"
    t8.style.font-color: "#666666"; t9.style.font-color: "#666666"; t10.style.font-color: "#666666"; t11.style.font-color: "#666666"
    t12.style.font-color: "#666666"; t13.style.font-color: "#666666"; t14.style.font-color: "#666666"; t15.style.font-color: "#666666"
  }

  memory: {
    label: "sdata[16] (Shared Memory Layout) | Total Size: 64B"
    grid-columns: 16
    m0: "00h"; m1: "04h"; m2: "08h"; m3: "0Ch"; m4: "10h"; m5: "14h"; m6: "18h"; m7: "1Ch"
    m8: "20h"; m9: "24h"; m10: "28h"; m11: "2Ch"; m12: "30h"; m13: "34h"; m14: "38h"; m15: "3Ch"
    
    m0.style: { fill: "#ff6b6b"; stroke: "#ffffff" }; m1.style: { fill: "#ff6b6b"; stroke: "#ffffff" }
    m2.style: { fill: "#ff6b6b"; stroke: "#ffffff" }; m3.style: { fill: "#ff6b6b"; stroke: "#ffffff" }
    m4.style: { fill: "#ff6b6b"; stroke: "#ffffff" }; m5.style: { fill: "#ff6b6b"; stroke: "#ffffff" }
    m6.style: { fill: "#ff6b6b"; stroke: "#ffffff" }; m7.style: { fill: "#ff6b6b"; stroke: "#ffffff" }
    
    m8.style: { fill: "#4ecdc4"; stroke: "#ffffff" }; m9.style: { fill: "#4ecdc4"; stroke: "#ffffff" }
    m10.style: { fill: "#4ecdc4"; stroke: "#ffffff" }; m11.style: { fill: "#4ecdc4"; stroke: "#ffffff" }
    m12.style: { fill: "#4ecdc4"; stroke: "#ffffff" }; m13.style: { fill: "#4ecdc4"; stroke: "#ffffff" }
    m14.style: { fill: "#4ecdc4"; stroke: "#ffffff" }; m15.style: { fill: "#4ecdc4"; stroke: "#ffffff" }
  }
}

# --- ITERATION 2 ---
