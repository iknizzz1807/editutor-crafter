    stroke: "#00ff88"
    stroke-dash: 2
  }

  threads: {
    grid-columns: 16
    t0: "T0 ●"; t1: "T1 ●"; t2: "T2 ●"; t3: "T3 ●"
    t4: "T4 ○"; t5: "T5 ○"; t6: "T6 ○"; t7: "T7 ○"
    t8: "T8 ○"; t9: "T9 ○"; t10: "T10 ○"; t11: "T11 ○"
    t12: "T12 ○"; t13: "T13 ○"; t14: "T14 ○"; t15: "T15 ○"
    
    t0.style.font-color: "#00ff88"; t1.style.font-color: "#00ff88"; t2.style.font-color: "#00ff88"; t3.style.font-color: "#00ff88"
    
    t4.style.font-color: "#666666"; t5.style.font-color: "#666666"; t6.style.font-color: "#666666"; t7.style.font-color: "#666666"
    t8.style.font-color: "#666666"; t9.style.font-color: "#666666"; t10.style.font-color: "#666666"; t11.style.font-color: "#666666"
