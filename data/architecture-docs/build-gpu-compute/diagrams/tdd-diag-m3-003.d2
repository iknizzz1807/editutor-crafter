vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

direction: right

# Warp Divergence Visualization
# When stride=16 in Parallel Reduction
title: {
  label: "Warp Divergence in CUDA\nstride=16: Threads 0-15 Active, Threads 16-31 Inactive"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# Legend explaining visual states
legend: {
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#1a1a2e"
  }
  active_legend: {
    shape: rectangle
    label: "Active Thread\n(executes body)"
    style: {
      fill: "#2d6a4f"
      stroke: "#40916c"
    }
  }
  inactive_legend: {
    shape: rectangle
    label: "Inactive Thread\n(skips body)"
    style: {
      fill: "#9d0208"
      stroke: "#d00000"
    }
  }
  active_legend -- inactive_legend: {
    style: {
      stroke-width: 0
    }
  }
}

# Code snippet being visualized
code_block: {
  shape: rectangle
  label: |md
    cuda
    for (stride = blockDim.x / 2; stride > 0; stride >>= 1) {
        if (tid < stride) {        // stride = 16
            sdata[tid] += sdata[tid + stride];
        }
        __syncthreads();
    }
    
  |
  style: {
    fill: "#0d1117"
    stroke: "#30363d"
    font: mono
  }
}

# Warp container showing 32 threads
warp: {
  label: "Warp 0 (32 threads in lockstep)"
  shape: rectangle
  style: {
    fill: "#16213e"
    stroke: "#e94560"
    stroke-width: 3
    border-radius: 8
  }

  # Active threads (0-15)
  active_group: {
    label: "Active Threads (tid < 16)\n✓ TRUE branch"
    shape: rectangle
    grid-columns: 8
    style: {
      fill: "#1b4332"
      stroke: "#40916c"
      stroke-dash: 3
    }
    t0: { label: "0"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t1: { label: "1"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t2: { label: "2"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t3: { label: "3"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t4: { label: "4"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t5: { label: "5"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t6: { label: "6"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t7: { label: "7"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t8: { label: "8"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t9: { label: "9"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t10: { label: "10"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t11: { label: "11"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t12: { label: "12"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t13: { label: "13"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t14: { label: "14"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
    t15: { label: "15"; shape: circle; style: { fill: "#2d6a4f"; stroke: "#40916c"; font-color: white } }
  }

  # Inactive threads (16-31)
  inactive_group: {
    label: "Inactive Threads (tid ≥ 16)\n✗ FALSE branch"
    shape: rectangle
    grid-columns: 8
    style: {
      fill: "#3c0712"
      stroke: "#d00000"
      stroke-dash: 3
    }
    t16: { label: "16"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t17: { label: "17"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t18: { label: "18"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t19: { label: "19"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t20: { label: "20"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t21: { label: "21"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t22: { label: "22"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t23: { label: "23"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t24: { label: "24"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t25: { label: "25"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t26: { label: "26"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t27: { label: "27"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t28: { label: "28"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t29: { label: "29"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t30: { label: "30"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
    t31: { label: "31"; shape: circle; style: { fill: "#9d0208"; stroke: "#d00000"; font-color: white } }
  }

  active_group -- inactive_group: "DIVERGENCE!" {
    style: {
      stroke: "#ff6b6b"
      stroke-width: 4
      animated: true
    }
  }
}

# Serial execution timeline
timeline: {
  label: "SIMT Execution Timeline (Serial Path Execution)"
  shape: rectangle
  style: {
    fill: "#0f0f23"
    stroke: "#6272a4"
  }
  step1: {
    label: |md
      ### Step 1: TRUE Path
      Threads 0-15 execute:
      `sdata[tid] += sdata[tid + 16]`
      Threads 16-31: **STALL** (masked)
    |
    shape: rectangle
    style: {
      fill: "#1b4332"
      stroke: "#40916c"
    }
  }
  step2: {
    label: |md
      ### Step 2: FALSE Path
      Threads 16-31 execute:
      (empty body - no-op)
      Threads 0-15: **STALL** (masked)
    |
    shape: rectangle
    style: {
      fill: "#3c0712"
      stroke: "#d00000"
    }
  }
  step3: {
    label: |md
      ### Step 3: Reconverge
      All threads sync at
      `__syncthreads()`
      Full warp active again
    |
    shape: rectangle
    style: {
      fill: "#1a1a2e"
      stroke: "#4cc9f0"
    }
  }
  step1 -> step2 -> step3: "Serial Execution" {
    style: {
      stroke: "#f72585"
      stroke-width: 3
    }
  }
}

# Impact callout
impact: {
  label: |md
    ## ⚠️ Performance Impact
    **Warp Divergence Cost:**
    - Both code paths execute serially
    - Effective throughput: **50%** of peak
    - 16 threads useful, 16 threads wasted
    **Mitigation Strategies:**
    1. Restructure code to minimize branch divergence
    2. Use `__ballot_sync()` for branch aggregation
    3. Reorganize data access patterns
    4. Consider warp-level primitives
  |
  shape: rectangle
  style: {
    fill: "#2d2d44"
    stroke: "#f72585"
    stroke-width: 2
    double-border: true
  }
}

# Connections
code_block -> warp: "executes" {
  style: { stroke: "#6272a4"; stroke-dash: 3 }
}
warp -> timeline: "SIMT behavior" {
  style: { stroke: "#e94560"; stroke-width: 2 }
}
timeline -> impact: "causes" {
  style: { stroke: "#f72585"; stroke-dash: 3 }
}