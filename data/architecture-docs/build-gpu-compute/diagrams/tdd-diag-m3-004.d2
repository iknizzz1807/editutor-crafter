direction: right
layout-engine: elk
theme-id: 4

title: {
  label: "Warp Shuffle Reduction: __shfl_down_sync\nMethod: val += __shfl_down_sync(0xffffffff, val, offset)\nOperation: Thread i reads from thread i+offset within a 32-thread warp"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# Legend for thread states
legend: {
  shape: rectangle
  style.stroke-dash: 3
  label: "Execution State Legend"
  
  active_thread: "Thread with initial value" {
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
  source_thread: "Source (Data being read)" {
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
  result_thread: "Destination (Receives sum)" {
    style.fill: "#90CAF9"
    style.stroke: "#0D47A1"
    style.bold: true
  }
  idle_thread: "Idle / Masked Out" {
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
    style.opacity: 0.6
  }
  final_result: "Final Reduction Result" {
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
  }
}

