# Transitions
step0 -> step1: "Offset 16"
step1 -> step2: "Offset 8"
step2 -> step3: "Offset 4"
step3 -> step4: "Offset 2"
step4 -> step5: "Offset 1"

# Implementation Code
implementation: {
  label: "CUDA Kernel Implementation"
  code_block: |cpp
__device__ float warpReduceSum(float val) {
    // 0xffffffff is the thread mask (all threads active)
    for (int offset = 16; offset > 0; offset >>= 1) {
        val += __shfl_down_sync(0xffffffff, val, offset);
    }
    // Only thread 0 now holds the full sum of the warp
    return val; 
}
  |
  shape: code
}

# Technical Insight Summary
insights: {
  label: "Technical Insights"
  near: bottom-center
  
  perf: {
    label: "Performance:\n• Execution Time: log2(32) = 5 cycles\n• Bandwidth: Uses register-to-register shuffle\n• Memory: Zero Shared Memory usage"
    shape: rectangle
    style.fill: "#FFF3E0"
  }
  
  constraints: {
    label: "Constraints:\n• Warp Scope: Only works within 32-thread warps\n• Implicit Sync: Warp-synchronous on modern architectures\n• Mask: 0xffffffff ensures all threads participate"
    shape: rectangle
    style.fill: "#E8F5E9"
  }
}