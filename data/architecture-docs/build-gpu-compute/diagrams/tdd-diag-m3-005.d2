layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

# --- HEADER SECTION ---
title: {
  shape: text
  label: "Blelloch Scan - Upsweep Phase (Reduction Tree)"
  style: {
    font-size: 28
    bold: true
  }
}

subtitle: {
  shape: text
  label: |md
    ### Algorithm: Parallel Prefix Sum (Upsweep)
    **Objective:** Build a balanced binary reduction tree in $\log_2 n$ steps.
    **Invariant:** After step $d$, `temp[i]` stores the sum of $2^d$ elements.
  |
}

# --- LEGEND & CONFIG ---
legend: {
  shape: rectangle
  near: top-right
  style.fill: "#f8f9fa"
  
  changed: {
    label: "Modified Index"
    style: {
      fill: "#ef5350"
      stroke: "#b71c1c"
      bold: true
    }
  }
  read: {
    label: "Read Index"
    style: {
      fill: "#90caf9"
      stroke: "#1565c0"
    }
  }
}

config: {
  shape: rectangle
  style: {
    fill: "#e3f2fd"
    stroke: "#1976d2"
  }
  label: |md
    ### Memory Specification
    - **N:** 8 (Elements)
    - **Type:** `int32` (4 bytes/element)
    - **Total Size:** 32 bytes
    - **Initial State:** `[3, 1, 7, 0, 4, 1, 6, 3]`
  |
}

# --- STEP 1 ---
step1: {
  label: "Upsweep Step 1: d=0, stride=2"
  style.fill: "#ffffff"
  style.stroke: "#000000"
  style.stroke-width: 2

  step1_desc: {
    shape: rectangle
    style.fill: "#fff3e0"
    label: "Stride=2: temp[2i+1] += temp[2i]"
  }

  states: {
    grid-columns: 2
    
    before: {
      label: "Before Step 1"
      direction: right
      m: {
        grid-columns: 8
        grid-gap: 0
        0: "3" { style.fill: "#e0e0e0" }
        1: "1" { style.fill: "#e0e0e0" }
        2: "7" { style.fill: "#e0e0e0" }
        3: "0" { style.fill: "#e0e0e0" }
        4: "4" { style.fill: "#e0e0e0" }
        5: "1" { style.fill: "#e0e0e0" }
        6: "6" { style.fill: "#e0e0e0" }
        7: "3" { style.fill: "#e0e0e0" }
      }
    }

    after: {
      label: "After Step 1"
      direction: right
      m: {
        grid-columns: 8
        grid-gap: 0
        0: "3" { style.fill: "#e0e0e0" }
        1: "4" { style.fill: "#ef5350"; style.bold: true }
        2: "7" { style.fill: "#e0e0e0" }
        3: "7" { style.fill: "#ef5350"; style.bold: true }
        4: "4" { style.fill: "#e0e0e0" }
        5: "5" { style.fill: "#ef5350"; style.bold: true }
        6: "6" { style.fill: "#e0e0e0" }
        7: "9" { style.fill: "#ef5350"; style.bold: true }
      }
    }
  }
  
  (states.before.m.0 -> states.after.m.1): "+3" { style.stroke: "#ef5350"; style.stroke-dash: 3 }
  (states.before.m.2 -> states.after.m.3): "+7" { style.stroke: "#ef5350"; style.stroke-dash: 3 }
  (states.before.m.4 -> states.after.m.5): "+4" { style.stroke: "#ef5350"; style.stroke-dash: 3 }
  (states.before.m.6 -> states.after.m.7): "+6" { style.stroke: "#ef5350"; style.stroke-dash: 3 }
}

# --- STEP 2 ---
step2: {
  label: "Upsweep Step 2: d=1, stride=4"
  style.fill: "#ffffff"
  style.stroke: "#000000"
  style.stroke-width: 2

  step2_desc: {
    shape: rectangle
    style.fill: "#fff3e0"
    label: "Stride=4: temp[4i+3] += temp[4i+1]"
  }

  states: {
    grid-columns: 2
    
    before: {
      label: "Before Step 2"
      m: {
        grid-columns: 8
        grid-gap: 0
        0: "3"; 1: "4"; 2: "7"; 3: "7"; 4: "4"; 5: "5"; 6: "6"; 7: "9"
        *.style.fill: "#e0e0e0"
      }
    }

    after: {
      label: "After Step 2"
      m: {
        grid-columns: 8
        grid-gap: 0
        0: "3"; 1: "4"; 2: "7"; 
        3: "11" { style.fill: "#ef5350"; style.bold: true }
        4: "4"; 5: "5"; 6: "6"; 
        7: "14" { style.fill: "#ef5350"; style.bold: true }
        *.style.fill: "#e0e0e0"
      }
    }
  }
  
  (states.before.m.1 -> states.after.m.3): "+4" { style.stroke: "#ef5350"; style.stroke-dash: 3 }
  (states.before.m.5 -> states.after.m.7): "+5" { style.stroke: "#ef5350"; style.stroke-dash: 3 }
}

# --- STEP 3 ---
step3: {
  label: "Upsweep Step 3: d=2, stride=8"
  style.fill: "#ffffff"
  style.stroke: "#000000"
  style.stroke-width: 2

  step3_desc: {
    shape: rectangle
    style.fill: "#fff3e0"
    label: "Stride=8: temp[7] += temp[3]"
  }

  states: {
    grid-columns: 2
    
    before: {
      label: "Before Step 3"
      m: {
        grid-columns: 8
        grid-gap: 0
        0: "3"; 1: "4"; 2: "7"; 3: "11"; 4: "4"; 5: "5"; 6: "6"; 7: "14"
        *.style.fill: "#e0e0e0"
      }
    }

    after: {
      label: "Final Reduction"
      m: {
        grid-columns: 8
        grid-gap: 0
        0: "3"; 1: "4"; 2: "7"; 3: "11"; 4: "4"; 5: "5"; 6: "6"; 
        7: "25" { style.fill: "#4caf50"; style.bold: true; style.font-color: white }
        *.style.fill: "#e0e0e0"
      }
    }
  }
  
  (states.before.m.3 -> states.after.m.7): "+11" { style.stroke: "#4caf50"; style.stroke-dash: 3 }
}

# --- TREE STRUCTURE ---
tree: {
  label: "Logical Reduction Tree"
  
  t_root: "25 [Idx 7]" { shape: circle; style: { fill: "#4caf50"; font-color: white; bold: true } }
  
  t_l1_l: "11 [Idx 3]" { shape: circle; style.fill: "#ef5350" }
  t_l1_r: "14 [Idx 7]" { shape: circle; style.fill: "#ef5350" }
  
  t_l2_1: "4 [Idx 1]" { shape: circle; style.fill: "#ff9800" }
  t_l2_2: "7 [Idx 3]" { shape: circle; style.fill: "#ff9800" }
  t_l2_3: "5 [Idx 5]" { shape: circle; style.fill: "#ff9800" }
  t_l2_4: "9 [Idx 7]" { shape: circle; style.fill: "#ff9800" }
  
  t_leaf_0: "3 [0]"; t_leaf_1: "1 [1]"; t_leaf_2: "7 [2]"; t_leaf_3: "0 [3]"
  t_leaf_4: "4 [4]"; t_leaf_5: "1 [5]"; t_leaf_6: "6 [6]"; t_leaf_7: "3 [7]"
  
  t_root <- t_l1_l
  t_root <- t_l1_r
  t_l1_l <- t_l2_1
  t_l1_l <- t_l2_2
  t_l1_r <- t_l2_3
  t_l1_r <- t_l2_4
  
  t_l2_1 <- t_leaf_0
  t_l2_1 <- t_leaf_1
  t_l2_2 <- t_leaf_2
  t_l2_2 <- t_leaf_3
  t_l2_3 <- t_leaf_4
  t_l2_3 <- t_leaf_5
  t_l2_4 <- t_leaf_6
  t_l2_4 <- t_leaf_7
}

# --- CUDA KERNEL ---
code: {
  label: "CUDA Implementation: Upsweep"
  shape: rectangle
  style: { fill: "#263238"; font-color: "#eceff1" }
  
  code_content: |c
    __global__ void upsweep(int* temp, int n) {
      for (int d = 0; d < log2(n); d++) {
        int stride = 1 << (d + 1);
        int i = threadIdx.x * stride;
        if (i < n) {
          temp[i + stride - 1] += temp[i + (stride/2) - 1];
        }
        __syncthreads();
      }
    }
  |
}

# --- ANALYSIS ---
analysis: {
  shape: rectangle
  style: { fill: "#f3e5f5"; stroke: "#7b1fa2" }
  label: |md
    ### Performance Metadata
    - **Work Complexity:** $O(n)$
    - **Step Complexity:** $O(\log n)$
    - **Space:** $O(1)$ auxiliary (In-place)
  |
}

# --- CONNECTIONS ---
title -> subtitle
subtitle -> config
step1 -> step2 -> step3
step3 -> tree
tree -> code
code -> analysis