direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: "Blelloch Scan - Downsweep Phase (Exclusive Prefix Sum)" {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# LEGEND FOR IMPLEMENTATION
Legend: {
  near: top-right
  Array_Cell: "Original Value" { class: arrayCell }
  Modified_Cell: "New Prefix Value" { class: changedCell }
  Active_Node: "Processing Node" { class: activeNode }
}

# Style definitions
classes: {
  treeNode: {
    shape: circle
    width: 60
    height: 60
    style: {
      stroke: "#333333"
      stroke-width: 2
      fill: white
    }
  }
  activeNode: {
    shape: circle
    width: 65
    height: 65
    style: {
      stroke: "#E53935"
      stroke-width: 4
      bold: true
      fill: "#FFEBEE"
    }
  }
  arrayCell: {
    shape: rectangle
    width: 50
    height: 40
    style: {
      stroke: "#666666"
      stroke-width: 1
      fill: "#F5F5F5"
      font-size: 14
    }
  }
  changedCell: {
    shape: rectangle
    width: 50
    height: 40
    style: {
      stroke: "#E53935"
      stroke-width: 3
      fill: "#FFEBEE"
      bold: true
      font-color: "#D32F2F"
      font-size: 16
    }
  }
  stepLabel: {
    shape: text
    style: {
      font-size: 20
      bold: true
      font-color: "#1565C0"
    }
  }
  arrow: {
    style: {
      stroke: "#E53935"
      stroke-width: 3
      animated: true
    }
  }
}

# Initial State - After Upsweep, Before Downsweep
Step0_Initial: {
  label: "Step 0: Initial State (After Upsweep)"
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    fill: "#E3F2FD"
  }
  
  Step0_Label: "Input Array [3, 1, 7, 0, 4, 1, 6, 3]" { class: stepLabel }
  
  Array_Indices: {
    grid-columns: 8
    grid-gap: 5
    i0: "0"; i1: "1"; i2: "2"; i3: "3"; i4: "4"; i5: "5"; i6: "6"; i7: "7"
    style.stroke-width: 0
  }

  Step0_Array: {
    grid-columns: 8
    grid-gap: 5
    A0: "3" { class: arrayCell }
    A1: "1" { class: arrayCell }
    A2: "7" { class: arrayCell }
    A3: "0" { class: arrayCell }
    A4: "4" { class: arrayCell }
    A5: "1" { class: arrayCell }
    A6: "6" { class: arrayCell }
    A7: "3" { class: arrayCell }
  }
  
  Step0_Note: {
    shape: text
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    "INV: Root (temp[7]) set to 0 before starting."
    "All internal sums from upsweep are in temp array."
  }
}

# Step 1: Level 3 -> Level 2
Step1: {
  label: "Step 1: Level 3 → Level 2 (d=1, offset=4)"
  style: {
    stroke: "#E53935"
    stroke-width: 3
    fill: "#FFEBEE"
  }
  
  Step1_Op: {
    label: "Kernel Op (tid=0)"
    Op1: |md
      **indices:** ai=3, bi=7
      t = temp[3] (11)
      temp[3] = temp[7] (0)
      temp[7] = 0 + 11 = 11
    | {
      shape: rectangle
      style.fill: "#E8F5E9"
    }
  }

  Step1_Array: {
    grid-columns: 8
    grid-gap: 5
    B0: "3" { class: arrayCell }
    B1: "1" { class: arrayCell }
    B2: "7" { class: arrayCell }
    B3: "0" { class: changedCell }
    B4: "4" { class: arrayCell }
    B5: "1" { class: arrayCell }
    B6: "6" { class: arrayCell }
    B7: "11" { class: changedCell }
  }
  
  Step1_Note: {
    shape: text
    style.fill: "#FFCDD2"
    "CHANGED: indices 3, 7"
    "temp[3] becomes identity(0)"
    "temp[7] becomes sum of Level 3 nodes"
  }
}

# Step 2: Level 2 -> Level 1
Step2: {
  label: "Step 2: Level 2 → Level 1 (d=2, offset=2)"
  style: {
    stroke: "#E53935"
    stroke-width: 3
    fill: "#FFEBEE"
  }
  
  Step2_Ops: {
    grid-columns: 2
    Op2a: |md
      **tid=0: ai=1, bi=3**
      t = temp[1] (4)
      temp[1] = temp[3] (0)
      temp[3] = 0 + 4 = 4
    | {
      shape: rectangle
      style.fill: "#E8F5E9"
    }
    Op2b: |md
      **tid=1: ai=5, bi=7**
      t = temp[5] (5)
      temp[5] = temp[7] (11)
      temp[7] = 11 + 5 = 16
    | {
      shape: rectangle
      style.fill: "#E8F5E9"
    }
  }

  Step2_Array: {
    grid-columns: 8
    grid-gap: 5
    C0: "3" { class: arrayCell }
    C1: "0" { class: changedCell }
    C2: "7" { class: arrayCell }
    C3: "4" { class: changedCell }
    C4: "4" { class: arrayCell }
    C5: "11" { class: changedCell }
    C6: "6" { class: arrayCell }
    C7: "16" { class: changedCell }
  }
  
  Step2_Note: {
    shape: text
    style.fill: "#FFCDD2"
    "CHANGED: indices 1, 3, 5, 7"
    "Parallel Downsweep (2 threads)"
  }
}

# Step 3: Level 1 -> Level 0
Step3: {
  label: "Step 3: Level 1 → Level 0 (d=4, offset=1)"
  style: {
    stroke: "#E53935"
    stroke-width: 3
    fill: "#FFEBEE"
  }
  
  Step3_Ops: {
    grid-columns: 2
    Op3a: "ai=0, bi=1: temp[0]=0, temp[1]=3" { style.fill: "#E8F5E9" }
    Op3b: "ai=2, bi=3: temp[2]=4, temp[3]=11" { style.fill: "#E8F5E9" }
    Op3c: "ai=4, bi=5: temp[4]=11, temp[5]=15" { style.fill: "#E8F5E9" }
    Op3d: "ai=6, bi=7: temp[6]=16, temp[7]=22" { style.fill: "#E8F5E9" }
  }

  Step3_Array: {
    grid-columns: 8
    grid-gap: 5
    D0: "0" { class: changedCell }
    D1: "3" { class: changedCell }
    D2: "4" { class: changedCell }
    D3: "11" { class: changedCell }
    D4: "11" { class: changedCell }
    D5: "15" { class: changedCell }
    D6: "16" { class: changedCell }
    D7: "22" { class: changedCell }
  }
  
  Step3_Note: {
    shape: text
    style.fill: "#FFCDD2"
    "CHANGED: All indices"
    "Result is the full Exclusive Prefix Sum"
  }
}

# Final Result Comparison
Step4_Final: {
  label: "Final Comparison"
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    fill: "#E8F5E9"
  }
  
  Compare_Box: {
    grid-columns: 1
    Input: "Input: [3, 1, 7, 0, 4, 1, 6, 3]" { class: arrayCell }
    Output: "Exclusive Sum: [0, 3, 4, 11, 11, 15, 16, 22]" { class: changedCell }
  }

  Step4_Verify: |md
    ### Implementation Logic Check:
    - prefix[0] = 0
    - prefix[1] = 0 + a[0] = 3
    - prefix[2] = 0 + a[0] + a[1] = 4
    - prefix[3] = 0 + a[0] + a[1] + a[2] = 11
    ...
    - prefix[7] = $\sum_{i=0}^{6} a_i = 22$
  | {
    shape: text
    style.fill: "#C8E6C9"
  }
}

# Algorithm Reference
AlgorithmCode: {
  label: "CUDA Downsweep Kernel Fragment"
  shape: rectangle
  style: {
    stroke: "#666"
    fill: "#F5F5F5"
  }
  code: {
    shape: code
    language: c
    "for (int d = 1; d < N; d <<= 1) { // Downsweep\n  offset >>= 1;\n  __syncthreads();\n  if (tid < d) {\n    int ai = offset*(2*tid+1) - 1;\n    int bi = offset*(2*tid+2) - 1;\n    float t = temp[ai];\n    temp[ai] = temp[bi];\n    temp[bi] += t;\n  }\n}"
  }
}

# Visualizing the Tree Downsweep logic
TreeVisualization: {
  label: "Pointer Swapping Tree (Downsweep Path)"
  style: {
    stroke: "#1565C0"
    fill: "#E3F2FD"
  }
  
  # Structural Nodes
  Root: "0" { class: activeNode }
  
  L1_L: "0" { class: activeNode }
  L1_R: "11" { class: activeNode }
  
  L0_0: "0" { class: treeNode }
  L0_1: "3" { class: treeNode }
  L0_2: "4" { class: treeNode }
  L0_3: "11" { class: treeNode }
  
  # Connections
  Root -> L1_L: "Swap temp[3], temp[7]"
  Root -> L1_R: "temp[7] += t"
  
  L1_L -> L0_0
  L1_L -> L0_1
  L1_R -> L0_2
  L1_R -> L0_3
}

# Workflow connections
Step0_Initial -> Step1 { class: arrow }
Step1 -> Step2 { class: arrow }
Step2 -> Step3 { class: arrow }
Step3 -> Step4_Final { class: arrow }

# Connection Class application
(Step0_Initial -> Step1)[0].label: "d=1"
(Step1 -> Step2)[0].label: "d=2"
(Step2 -> Step3)[0].label: "d=4"
(Step3 -> Step4_Final)[0].label: "Verified"