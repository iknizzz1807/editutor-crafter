layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  bank_color: "#E8F4FD"
  offset_color: "#FFF3E0"
  data_color: "#E3F2FD"
  index_color: "#F3E5F5"
  header_color: "#EDE7F6"
}

title: |md
  # Scan Shared Memory Layout
  ### 2*BLOCK_SIZE Array with Bank Conflict Avoidance
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# Memory array visualization
memory_array: {
  label: "Bank Mapping Structure (32-wide)"
  shape: rectangle
  style: {
    stroke-width: 2
  }

  # Byte offsets column
  offsets: "Byte\nOffset" {
    shape: rectangle
    style: {
      fill: "#F5F5F5"
      font-size: 10
      stroke: "#BDBDBD"
    }
  }

  # Memory banks (32 banks on NVIDIA GPUs)
  bank0: "Bank 0" {
    style: {
      fill: "${bank_color}"
      font-size: 10
    }
  }
  bank1: "Bank 1" {
    style: {
      fill: "${bank_color}"
      font-size: 10
    }
  }
  bank2: "Bank 2" {
    style: {
      fill: "${bank_color}"
      font-size: 10
    }
  }
  bank3: "Bank 3" {
    style: {
      fill: "${bank_color}"
      font-size: 10
    }
  }
  bank15: "Bank 15" {
    style: {
      fill: "${bank_color}"
      font-size: 10
    }
  }
  bank31: "Bank 31" {
    style: {
      fill: "${bank_color}"
      font-size: 10
    }
  }

  # Index column
  indices: "Array\nIndex" {
    shape: rectangle
    style: {
      fill: "${index_color}"
      font-size: 10
      stroke: "#9C27B0"
    }
  }

  # Layout chain (using transparent stroke to enforce order in ELK)
  offsets -> bank0 -> bank1 -> bank2 -> bank3 -> bank15 -> bank31 -> indices {
    style: { stroke: transparent }
  }
}

# Detailed temp array structure
temp_array: {
  label: "temp[2 * BLOCK_SIZE] - Shared Memory Virtual View"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#333"
    stroke-width: 2
  }

  # First half - temp[0..BLOCK_SIZE-1] (with offset padding)
  first_half: {
    label: "Padded/Offset Region\n(Indices 0 to BLOCK_SIZE-1)"
    shape: rectangle
    style: {
      fill: "${offset_color}"
      stroke: "#FF9800"
    }
    padding_row: "Padding (Conflict Avoidance)" {
      shape: rectangle
      style: {
        fill: "#FFE0B2"
        font-size: 9
        stroke-dash: 2
      }
    }
    data_rows_0: "temp[0 ... n/2-1]" {
      shape: rectangle
      style: {
        fill: "${data_color}"
        font-size: 9
      }
    }
    padding_row -> data_rows_0 { style: { stroke: transparent } }
  }

  # Second half - temp[BLOCK_SIZE..2*BLOCK_SIZE-1] (main data)
  second_half: {
    label: "Main Data Region\n(Indices BLOCK_SIZE to 2*BLOCK_SIZE-1)"
    shape: rectangle
    style: {
      fill: "${data_color}"
      stroke: "#2196F3"
    }
    data_rows_1: "temp[BLOCK_SIZE ... 2*BLOCK_SIZE-1]" {
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        font-size: 9
      }
    }
  }

  first_half -> second_half {
    style: { stroke: transparent }
  }
}

# Upsweep phase indexing
upsweep: {
  label: "UPSWEEP Phase Indexing (Reduce)"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }
  header_u: "Parallel Reduction Tree" {
    shape: rectangle
    style: {
      fill: "${header_color}"
      font-size: 11
      bold: true
    }
  }
  formula_ai: "ai = offset*(2*tid+1) - 1 + BLOCK_SIZE" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      font-size: 10
      font: mono
    }
  }
  formula_bi: "bi = offset*(2*tid+2) - 1 + BLOCK_SIZE" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      font-size: 10
      font: mono
    }
  }
  example_u: "Example: tid=0, offset=1\nai=0+8, bi=1+8" {
    shape: rectangle
    style: {
      fill: "#A5D6A7"
      font-size: 9
    }
  }
  header_u -> formula_ai -> formula_bi -> example_u {
    style: { stroke: transparent }
  }
}

# Downsweep phase indexing
downsweep: {
  label: "DOWNSWEEP Phase Indexing (Scan)"
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FFC107"
    stroke-width: 2
  }
  header_d: "Parallel Distribution Tree" {
    shape: rectangle
    style: {
      fill: "${header_color}"
      font-size: 11
      bold: true
    }
  }
  formula_ai_d: "ai = offset*(2*tid+1) - 1 + BLOCK_SIZE" {
    shape: rectangle
    style: {
      fill: "#FFE082"
      font-size: 10
      font: mono
    }
  }
  formula_bi_d: "bi = offset*(2*tid+2) - 1 + BLOCK_SIZE" {
    shape: rectangle
    style: {
      fill: "#FFE082"
      font-size: 10
      font: mono
    }
  }
  example_d: "Swap & Propagate Partial Sums" {
    shape: rectangle
    style: {
      fill: "#FFD54F"
      font-size: 9
    }
  }
  header_d -> formula_ai_d -> formula_bi_d -> example_d {
    style: { stroke: transparent }
  }
}

# Bank conflict explanation
bank_conflicts: {
  label: "Bank Conflict Mitigation Strategy"
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-width: 2
  }
  problem: |md
    **Problem:**
    Threads accessing `temp[tid*2]` 
    hit the same bank every 16 
    threads at higher offsets.
  | {
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      font-size: 9
    }
  }
  conflict_case: "Conflict: Offset > 1 maps to same bank" {
    shape: rectangle
    style: {
      fill: "#EF9A9A"
      font-size: 9
    }
  }
  solution: |md
    **Solution:**
    Shift all logic indices by `+BLOCK_SIZE`.
    The strided access now maps to distinct banks.
  | {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      font-size: 9
      stroke: "#4CAF50"
    }
  }
  problem -> conflict_case -> solution {
    style: { stroke: transparent }
  }
}

# Memory layout grid - Intel manual style
layout_grid: {
  label: "Physical Mapping (Example: BLOCK_SIZE=8)"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#333"
  }
  row_header: "Byte Offset | Index | Bank | Content" {
    shape: rectangle
    style: {
      fill: "${header_color}"
      font-size: 10
      bold: true
      font: mono
    }
  }
  row_0: "0x00        | 0     |  0   | [Padding]" {
    shape: rectangle
    style: {
      fill: "${offset_color}"
      font-size: 9
      font: mono
    }
  }
  row_1: "0x20        | 8     |  0   | temp[0] (Actual)" {
    shape: rectangle
    style: {
      fill: "${data_color}"
      font-size: 9
      font: mono
    }
  }
  row_2: "0x24        | 9     |  1   | temp[1] (Actual)" {
    shape: rectangle
    style: {
      fill: "${data_color}"
      font-size: 9
      font: mono
    }
  }
  row_3: "...         | ...   | ...  | ..." {
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      font-size: 9
      font: mono
    }
  }
  row_4: "0x58        | 22    |  6   | temp[14] (Actual)" {
    shape: rectangle
    style: {
      fill: "${data_color}"
      font-size: 9
      font: mono
    }
  }
  row_header -> row_0 -> row_1 -> row_2 -> row_3 -> row_4 {
    style: { stroke: transparent }
  }
}

# Cache line boundary annotation
cache_line: "Cache Line = 64 bytes (16 x 4B items)" {
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    stroke-dash: 5
  }
}

# Logical Flow Connections
memory_array -> temp_array: "Hardware-to-Software Mapping" {
  style: {
    stroke: "#666"
    stroke-dash: 3
  }
}
temp_array -> upsweep: "Phase 1: Reduction" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
upsweep -> downsweep: "Phase 2: Scan" {
  style: {
    stroke: "#FFC107"
    stroke-width: 2
  }
}
temp_array -> bank_conflicts: "Offset Shifting" {
  style: {
    stroke: "#F44336"
    stroke-dash: 3
  }
}
bank_conflicts -> layout_grid: "Resolved Mapping" {
  style: {
    stroke: "#666"
  }
}

# Legend
legend: {
  label: "Legend & Color Codes"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#333"
  }
  leg_pad: "Padding/Offset" {
    shape: rectangle
    style: {
      fill: "${offset_color}"
      font-size: 9
    }
  }
  leg_data: "Data Elements" {
    shape: rectangle
    style: {
      fill: "${data_color}"
      font-size: 9
    }
  }
  leg_up: "Upsweep Logic" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      font-size: 9
    }
  }
  leg_down: "Downsweep Logic" {
    shape: rectangle
    style: {
      fill: "#FFE082"
      font-size: 9
    }
  }
  leg_pad -> leg_data -> leg_up -> leg_down {
    style: { stroke: transparent }
  }
}

# Code snippet for reference
code_snippet: {
  label: "CUDA Implementation Reference"
  shape: rectangle
  style: {
    fill: "#263238"
    stroke: "#455A64"
  }
  code: ||c
    __shared__ float temp[BLOCK_SIZE * 2];
    
    // Bank Conflict Free Access via BLOCK_SIZE Offset
    int ai = offset * (2 * tid + 1) - 1 + BLOCK_SIZE;
    int bi = offset * (2 * tid + 2) - 1 + BLOCK_SIZE;
    
    temp[ai] += temp[bi];
  || {
    style: {
      font-size: 10
      font: mono
      font-color: "#ECEFF1"
    }
  }
}

# Layout constraints using transparent edges
legend -> code_snippet { style: { stroke: transparent } }
cache_line -> legend { style: { stroke: transparent } }
layout_grid -> cache_line { style: { stroke: transparent } }