layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    sketch: false
    pad: 20
  }
}

title: |md
  # Atomic Contention in Histogram: Naive Global Approach
  *Serialization of parallel threads at high-collision addresses*
  **Intel-Manual Quality Technical Specification**
| {
  near: top-center
  shape: text
}

# -----------------------------------------------------------------------------
# THREAD BLOCK (SIMD LANES)
# -----------------------------------------------------------------------------
threads: "GPU Warp Execution Unit" {
  style: {
    stroke: "#0D47A1"
    fill: "#E3F2FD"
    stroke-width: 4
    double-border: true
  }

  t0: "Lane 0\nLoad: 2" {
    shape: hexagon
    style.fill: "#BBDEFB"
  }
  t1: "Lane 1\nLoad: 2" {
    shape: hexagon
    style: {
      fill: "#90CAF9"
      stroke: "#FFC107"
      stroke-width: 3
    }
  }
  t2: "Lane 2\nLoad: 5" {
    shape: hexagon
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 4
    }
  }
  t3: "Lane 3\nLoad: 5" {
    shape: hexagon
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 4
    }
  }
  t4: "Lane 4\nLoad: 5" {
    shape: hexagon
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 4
    }
  }
  t5: "Lane 5\nLoad: 7" {
    shape: hexagon
    style.fill: "#BBDEFB"
  }

  t0 -> t1 -> t2 -> t3 -> t4 -> t5: { style.opacity: 0 }
}

# -----------------------------------------------------------------------------
# GLOBAL MEMORY (VRAM) LAYOUT
# -----------------------------------------------------------------------------
histogram: "Global Memory (Histogram Bins)" {
  style: {
    stroke: "#1B5E20"
    fill: "#E8F5E9"
    stroke-width: 3
  }

  bin_0: "bin[0]\nOffset: 0x00" { shape: stored_data; style.fill: "#C8E6C9" }
  bin_1: "bin[1]\nOffset: 0x04" { shape: stored_data; style.fill: "#C8E6C9" }
  bin_2: "bin[2]\nOffset: 0x08" { 
    shape: stored_data
    style: {
      fill: "#A5D6A7"
      stroke: "#FFC107"
      stroke-width: 3
    } 
  }
  bin_3: "bin[3]\nOffset: 0x0C" { shape: stored_data; style.fill: "#C8E6C9" }
  bin_4: "bin[4]\nOffset: 0x10" { shape: stored_data; style.fill: "#C8E6C9" }
  bin_5: "bin[5]\nOffset: 0x14\n[HOTSPOT]" { 
    shape: stored_data
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 5
      bold: true
    }
  }
  bin_6: "bin[6]\nOffset: 0x18" { shape: stored_data; style.fill: "#C8E6C9" }
  bin_7: "bin[7]\nOffset: 0x1C" { shape: stored_data; style.fill: "#A5D6A7" }

  bin_0 -> bin_1 -> bin_2 -> bin_3 -> bin_4 -> bin_5 -> bin_6 -> bin_7: { style.opacity: 0 }
}

# -----------------------------------------------------------------------------
# ATOMIC REQUEST FLOWS
# -----------------------------------------------------------------------------
threads.t0 -> histogram.bin_2: "atomicAdd\n[ACK]" {
  style: { stroke: "#4CAF50"; stroke-width: 2; animated: true }
}

threads.t1 -> histogram.bin_2: "atomicAdd\n[COLLISION]" {
  style: { stroke: "#FFC107"; stroke-width: 3; stroke-dash: 3 }
}

threads.t2 -> histogram.bin_5: "atomicAdd\n[LOCK_OWN]" {
  style: { stroke: "#D32F2F"; stroke-width: 4; animated: true }
}

threads.t3 -> histogram.bin_5: "atomicAdd\n[WAITING]" {
  style: { stroke: "#D32F2F"; stroke-width: 2; opacity: 0.6 }
}

threads.t4 -> histogram.bin_5: "atomicAdd\n[WAITING]" {
  style: { stroke: "#D32F2F"; stroke-width: 2; opacity: 0.6 }
}

threads.t5 -> histogram.bin_7: "atomicAdd\n[ACK]" {
  style: { stroke: "#4CAF50"; stroke-width: 2; animated: true }
}

# -----------------------------------------------------------------------------
# MEMORY CONTROLLER SERIALIZATION TIMELINE
# -----------------------------------------------------------------------------
timeline: "Memory Controller Serialization Pipeline" {
  style: {
    stroke: "#37474F"
    fill: "#ECEFF1"
    stroke-width: 2
  }

  t_start: "Cycle T" { shape: text }
  
  op1: "Lane 0 -> bin[2]\nStatus: Complete" {
    shape: rectangle
    style.fill: "#4CAF50"
  }
  op2: "Lane 5 -> bin[7]\nStatus: Complete" {
    shape: rectangle
    style.fill: "#4CAF50"
  }
  
  t_mid: "Cycle T + 100" { shape: text }
  
  op3: "Lane 1 -> bin[2]\nStatus: Retrying..." {
    shape: rectangle
    style.fill: "#FFC107"
  }
  op4: "Lane 2 -> bin[5]\nStatus: Active Lock" {
    shape: rectangle
    style.fill: "#F44336"
  }

  t_stall: "Cycle T + 200\n[SERIALIZATION STALL]" { 
    shape: text
    style: {
      font-color: red
      bold: true
    }
  }
  
  op5: "Lane 3 -> bin[5]\nStatus: Queued" {
    shape: rectangle
    style.fill: "#EF9A9A"
  }
  
  t_end: "Cycle T + 300" { shape: text }
  
  op6: "Lane 4 -> bin[5]\nStatus: Queued" {
    shape: rectangle
    style.fill: "#EF9A9A"
  }

  t_start -> op1 -> op2 -> t_mid -> op3 -> op4 -> t_stall -> op5 -> t_end -> op6: {
    style.stroke: "#90A4AE"
  }
}

# -----------------------------------------------------------------------------
# PERFORMANCE ANALYSIS & CODE
# -----------------------------------------------------------------------------
diagnostics: {
  warning: "❌ HARDWARE LIMITATION: ATOMIC CONTENTION" {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 3
      font-size: 18
      bold: true
    }
  }

  metrics: |md
    ### Contention Metrics
    - **Address Hotspot**: `bin[5]` at `0x14`
    - **Contention Degree**: 3-Way Serialization
    - **Effective Bandwidth**: 1/N cycles per lane
    - **Occupancy Impact**: High (Lanes stalled in retry loop)
  | {
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke-dash: 2
    }
  }
}

naive_code: "Naive CUDA Kernel (Inefficient)" {
  code: |cpp
    // Global Atomic Approach
    __global__ void histogram_kernel(int *data, int *bins, int N) {
        int tid = blockIdx.x * blockDim.x + threadIdx.x;
        if (tid < N) {
            int val = data[tid];
            // Hardware serializes access to the same 
            // address across the entire chip.
            atomicAdd(&bins[val], 1); 
        }
    }
  | {
    shape: code
    style.font-size: 14
  }
}

# -----------------------------------------------------------------------------
# STRUCTURAL CONNECTIONS
# -----------------------------------------------------------------------------
threads -> histogram: "SIMD Atomic Requests"
histogram -> timeline: "Address Conflict Logic"
timeline -> diagnostics.warning: "Bottleneck Detected"
diagnostics.metrics -> naive_code: "Code Context"

legend: {
  shape: package
  near: bottom-right
  label: "Visualization Legend"
  
  g: "Parallel Success" { style.fill: "#4CAF50" }
  y: "Address Collision (Retry)" { style.fill: "#FFC107" }
  r: "Hotspot (Serialization)" { style.fill: "#F44336" }
}