vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Histogram Privatization Pattern
  ### CUDA Memory Hierarchy & Atomic Operation Optimization
  *Per-block private histograms in shared memory*
| {near: top-center}

direction: right

# Global Memory Space (Input)
input: "Input Array\nd_input[N]\n(Size: 16M × 4B)" {
  shape: cylinder
  tooltip: "High-latency Global Memory (VRAM)"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
}

# Execution Grid
blocks: "Compute Grid (Thread Blocks)" {
  style: {
    fill: transparent
    stroke: "#BDBDBD"
    stroke-dash: 5
  }
  
  direction: right
  grid-gap: 40

  block0: "Thread Block 0" {
    direction: down
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      double-border: true
    }
    
    threads0: "Threads 0-255\n(Grid-Stride Loop)" {
      shape: parallelogram
      style: {
        fill: "#FFE0B2"
        font-size: 14
      }
    }
    
    local0: "localHist[256]\n(Shared Memory)\nOffset: 0x0000 | Size: 1 KB" {
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
    }
    
    threads0 -> local0: "atomicAdd_shared(localHist)" {
      style: {
        stroke: "#2E7D32"
        animated: true
        font-size: 11
      }
    }
  }

  block1: "Thread Block 1" {
    direction: down
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      double-border: true
    }
    
    threads1: "Threads 0-255\n(Grid-Stride Loop)" {
      shape: parallelogram
      style: {
        fill: "#FFE0B2"
        font-size: 14
      }
    }
    
    local1: "localHist[256]\n(Shared Memory)\nOffset: 0x0400 | Size: 1 KB" {
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
    }
    
    threads1 -> local1: "atomicAdd_shared(localHist)" {
      style: {
        stroke: "#2E7D32"
        animated: true
        font-size: 11
      }
    }
  }

  ellipsis: "..." {
    shape: text
    style.font-size: 30
  }

  blockN: "Thread Block N-1" {
    direction: down
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      double-border: true
    }
    
    threadsN: "Threads 0-255\n(Grid-Stride Loop)" {
      shape: parallelogram
      style: {
        fill: "#FFE0B2"
        font-size: 14
      }
    }
    
    localN: "localHist[256]\n(Shared Memory)\nOffset: 0xFC00 | Size: 1 KB" {
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
    }
    
    threadsN -> localN: "atomicAdd_shared(localHist)" {
      style: {
        stroke: "#2E7D32"
        animated: true
        font-size: 11
      }
    }
  }
}

# Data Flow: Global to Shared
input -> blocks: "d_input[i]\nCoalesced Load" {
  style: {
    stroke: "#1565C0"
    stroke-dash: 3
    font-size: 12
  }
}

# Final Output Space
global: "Global Histogram (Final Result)" {
  direction: right
  style: {
    fill: "#E1BEE7"
    stroke: "#7B1FA2"
    stroke-width: 3
  }
  
  bins: {
    grid-columns: 4
    b0: "Bin 0" { shape: rectangle; style.fill: white }
    b1: "Bin 1" { shape: rectangle; style.fill: white }
    bdots: "..." { shape: text }
    b255: "Bin 255" { shape: rectangle; style.fill: white }
  }
}

# Data Flow: Shared to Global (Privatization Merge)
blocks -> global: "Merge Phase:\n__syncthreads()\natomicAdd_global(d_hist)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 4
    animated: true
    font-size: 13
    bold: true
  }
}

# Technical Annotation and Legend
legend: "Memory Legend" {
  near: bottom-left
  direction: right
  grid-gap: 30
  
  shared: "Shared Memory (On-Chip)\nLow Latency | Block Scope" {
    shape: rectangle
    width: 180
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  
  globalmem: "Global Memory (DRAM)\nHigh Latency | Grid Scope" {
    shape: rectangle
    width: 180
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
}

stats: |md
  ### Performance Analysis (Design Constraints)
  
  **1. Atomic Operation Reduction**
  - **Naive Pattern:** N global atomics = 16,777,216 operations.
  - **Privatized Pattern:** numBlocks × numBins = 64 × 256 = 16,384 global operations.
  - **Efficiency Gain:** ~1024× reduction in DRAM contention.
  
  **2. Shared Memory Utilization**
  - **Resource Usage:** 256 bins × 4 bytes = 1,024 Bytes per block.
  - **Hardware Limit:** Typically 48KB - 164KB per SM.
  - **Occupancy:** High occupancy maintained (64KB total shared footprint).
  
  **3. Implementation Notes**
  - Thread synchronization (`__syncthreads()`) is required before merging local results to global memory.
  - localHist must be initialized to zero for every block.
| {
  near: bottom-right
  style: {
    stroke: "#757575"
    fill: "#F5F5F5"
  }
}