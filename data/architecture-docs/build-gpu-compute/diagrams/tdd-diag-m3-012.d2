direction: right
layout: elk
title: {
  label: CPU vs GPU Algorithm Performance
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
  style.underline: true
}
# Performance data: Execution time in milliseconds (16M elements)
# Reduction: CPU=25ms, GPU Naive=150ms, GPU Optimized=0.8ms
# Scan: CPU=35ms, GPU Naive=200ms, GPU Optimized=2.0ms
# Histogram: CPU=40ms, GPU Naive=250ms, GPU Optimized=3.5ms
# Legend container
legend: {
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  legend_title: {
    label: "LEGEND"
    shape: text
    style.bold: true
    style.font-size: 12
  }
  cpu_bar: {
    shape: rectangle
    width: 40
    height: 16
    style.fill: "#e74c3c"
    style.stroke: "#c0392b"
  }
  cpu_label: {
    label: "CPU Single-Thread"
    shape: text
    style.font-size: 10
  }
  naive_bar: {
    shape: rectangle
    width: 40
    height: 16
    style.fill: "#f39c12"
    style.stroke: "#d68910"
  }
  naive_label: {
    label: "GPU Naive Atomic"
    shape: text
    style.font-size: 10
  }
  opt_bar: {
    shape: rectangle
    width: 40
    height: 16
    style.fill: "#27ae60"
    style.stroke: "#1e8449"
  }
  opt_label: {
    label: "GPU Optimized"
    shape: text
    style.font-size: 10
  }
}
# Y-Axis Label
y_axis_label: {
  label: "Execution Time (ms)\n[Log Scale]"
  shape: text
  style.font-size: 14
  style.bold: true
}
# Chart Grid
chart_grid: {
  shape: rectangle
  width: 800
  height: 500
  style.fill: "#ffffff"
  style.stroke: "#2c3e50"
  style.stroke-width: 2
  # Y-axis scale markers (log scale representation)
  y_100ms: {
    shape: rectangle
    width: 780
    height: 1
    style.fill: "#bdc3c7"
    pos: [10, 50]
  }
  y_100_label: {
    label: "100ms"
    shape: text
    pos: [-45, 45]
  }
  y_10ms: {
    shape: rectangle
    width: 780
    height: 1
    style.fill: "#bdc3c7"
    pos: [10, 175]
  }
  y_10_label: {
    label: "10ms"
    shape: text
    pos: [-40, 170]
  }
  y_1ms: {
    shape: rectangle
    width: 780
    height: 1
    style.fill: "#bdc3c7"
    pos: [10, 300]
  }
  y_1_label: {
    label: "1ms"
    shape: text
    pos: [-35, 295]
  }
  y_01ms: {
    shape: rectangle
    width: 780
    height: 1
    style.fill: "#bdc3c7"
    pos: [10, 425]
  }
  y_01_label: {
    label: "0.1ms"
    shape: text
    pos: [-45, 420]
  }
  # REDUCTION Algorithm Bars
  reduction_group: {
    pos: [80, 50]
    reduction_cpu: {
      shape: rectangle
      width: 50
      height: 300
      style.fill: "#e74c3c"
      style.stroke: "#c0392b"
      style.stroke-width: 1
      # 25ms -> ~300px height (between 10ms and 100ms)
    }
    reduction_naive: {
      shape: rectangle
      width: 50
      height: 380
      style.fill: "#f39c12"
      style.stroke: "#d68910"
      style.stroke-width: 1
      pos: [60, 0]
      # 150ms -> ~380px height (above 100ms line)
    }
    reduction_opt: {
      shape: rectangle
      width: 50
      height: 40
      style.fill: "#27ae60"
      style.stroke: "#1e8449"
      style.stroke-width: 1
      pos: [120, 340]
      # 0.8ms -> ~40px height (near 1ms line)
    }
    reduction_value_cpu: {
      label: "25ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [8, -15]
    }
    reduction_value_naive: {
      label: "150ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [68, -15]
    }
    reduction_value_opt: {
      label: "0.8ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [128, -15]
    }
  }
  reduction_label: {
    label: "REDUCTION\n(tree-based)"
    shape: text
    style.font-size: 12
    style.bold: true
    pos: [100, 480]
  }
  # SCAN Algorithm Bars
  scan_group: {
    pos: [320, 50]
    scan_cpu: {
      shape: rectangle
      width: 50
      height: 320
      style.fill: "#e74c3c"
      style.stroke: "#c0392b"
      style.stroke-width: 1
      # 35ms -> ~320px height
    }
    scan_naive: {
      shape: rectangle
      width: 50
      height: 400
      style.fill: "#f39c12"
      style.stroke: "#d68910"
      style.stroke-width: 1
      pos: [60, 0]
      # 200ms -> ~400px height
    }
    scan_opt: {
      shape: rectangle
      width: 50
      height: 100
      style.fill: "#27ae60"
      style.stroke: "#1e8449"
      style.stroke-width: 1
      pos: [120, 280]
      # 2.0ms -> ~100px height
    }
    scan_value_cpu: {
      label: "35ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [8, -15]
    }
    scan_value_naive: {
      label: "200ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [68, -15]
    }
    scan_value_opt: {
      label: "2.0ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [128, -15]
    }
  }
  scan_label: {
    label: "SCAN\n(Blelloch)"
    shape: text
    style.font-size: 12
    style.bold: true
    pos: [340, 480]
  }
  # HISTOGRAM Algorithm Bars
  histogram_group: {
    pos: [560, 50]
    histogram_cpu: {
      shape: rectangle
      width: 50
      height: 330
      style.fill: "#e74c3c"
      style.stroke: "#c0392b"
      style.stroke-width: 1
      # 40ms -> ~330px height
    }
    histogram_naive: {
      shape: rectangle
      width: 50
      height: 420
      style.fill: "#f39c12"
      style.stroke: "#d68910"
      style.stroke-width: 1
      pos: [60, 0]
      # 250ms -> ~420px height
    }
    histogram_opt: {
      shape: rectangle
      width: 50
      height: 140
      style.fill: "#27ae60"
      style.stroke: "#1e8449"
      style.stroke-width: 1
      pos: [120, 240]
      # 3.5ms -> ~140px height
    }
    histogram_value_cpu: {
      label: "40ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [8, -15]
    }
    histogram_value_naive: {
      label: "250ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [68, -15]
    }
    histogram_value_opt: {
      label: "3.5ms"
      shape: text
      style.font-size: 9
      style.bold: true
      pos: [128, -15]
    }
  }
  histogram_label: {
    label: "HISTOGRAM\n(privatized)"
    shape: text
    style.font-size: 12
    style.bold: true
    pos: [570, 480]
  }
}
# X-Axis Label
x_axis_label: {
  label: "Parallel Algorithm Primitives"
  shape: text
  style.font-size: 14
  style.bold: true
  pos: [350, 540]
}
# Speedup annotations
speedup_box: {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#27ae60"
  style.stroke-dash: 5
  pos: [750, 100]
  width: 180
  height: 120
  speedup_title: {
    label: "GPU OPTIMIZED\nSPEEDUP"
    shape: text
    style.font-size: 11
    style.bold: true
    pos: [40, 10]
  }
  speedup_reduction: {
    label: "Reduction: 31x"
    shape: text
    style.font-size: 10
    style.fill: "#27ae60"
    pos: [20, 35]
  }
  speedup_scan: {
    label: "Scan: 17.5x"
    shape: text
    style.font-size: 10
    style.fill: "#27ae60"
    pos: [20, 55]
  }
  speedup_histogram: {
    label: "Histogram: 11.4x"
    shape: text
    style.font-size: 10
    style.fill: "#27ae60"
    pos: [20, 75]
  }
  note: {
    label: "(vs CPU single-thread)"
    shape: text
    style.font-size: 8
    style.italic: true
    pos: [20, 95]
  }
}
# Test configuration
config_box: {
  shape: rectangle
  style.fill: "#fff3e0"
  style.stroke: "#f39c12"
  pos: [750, 250]
  width: 180
  height: 100
  config_title: {
    label: "TEST CONFIG"
    shape: text
    style.font-size: 11
    style.bold: true
    pos: [55, 10]
  }
  config_data: {
    label: "Data: 16M elements\nGPU: NVIDIA RTX 4090\nCPU: Intel i9-13900K"
    shape: text
    style.font-size: 9
    pos: [20, 30]
  }
}
# Key insights
insight_box: {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#3498db"
  pos: [750, 380]
  width: 180
  height: 100
  insight_title: {
    label: "KEY INSIGHT"
    shape: text
    style.font-size: 11
    style.bold: true
    pos: [55, 10]
  }
  insight_text: {
    label: "Naive GPU atomic\napproaches are SLOWER\nthan CPU due to\ncontention overhead"
    shape: text
    style.font-size: 9
    pos: [20, 30]
  }
}
# Connections showing data flow insight
chart_grid -> insight_box: {
  label: "Critical Finding"
  style.stroke-dash: 4
  style.stroke: "#3498db"
}