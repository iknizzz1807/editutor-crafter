vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: |md
    # GPU ENGINE ORCHESTRATION & OVERLAP
    ### Multi-Stream Concurrent Execution Timeline
    *Target Hardware: PCIe Gen4 x16 | 80GB HBM2e VRAM*
  |
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}

# Technical Hardware Specifications Legend
specs: {
  near: top-right
  PCIe: {
    label: |md
      **Bus Interface: PCIe Gen4 x16**
      - Max Bandwidth: 31.5 GB/s
      - Duplex: Full (H2D + D2H)
      - Latency: 1.5μs - 2.0μs
    |
  }
  mem: {
    label: |md
      **VRAM: 80GB HBM2e**
      - Bandwidth: 1.2 TB/s
      - ECC: Enabled
    |
  }
  style: {
    stroke: "#059669"
    fill: "#f0fdf4"
    stroke-width: 2
    shadow: true
  }
}

# Primary Concurrency Sequence Diagram
gpu_concurrency_seq: {
  shape: sequence_diagram

  # Participants
  host: "Host CPU (x86_64)" {
    style: {
      stroke: "#2563eb"
      stroke-width: 3
    }
    icon: https://icons.terrastruct.com/tech%2F022-server.svg
  }
  
  copy_engine: "DMA Copy Engine (PCIe)" {
    style: {
      stroke: "#059669"
      stroke-width: 3
    }
    icon: https://icons.terrastruct.com/infra%2F019-storage-router.svg
  }
  
  sm: "Streaming Multiprocessors (SM)" {
    style: {
      stroke: "#dc2626"
      stroke-width: 3
    }
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAmazon-EC2_C4-Instance_light-bg.svg
  }

  # T0: Resource Allocation
  host."t₀: Stream Setup"

  Stream_1_H2D: {
    label: "Stream 1 (S1) - Host-to-Device"
    host -> copy_engine: "cudaMemcpyAsync(BufA, H2D, S1)" {
      style: {
        stroke: "#7c3aed"
        stroke-width: 2
      }
    }
  }

  # T1: Overlap Trigger
  host."t₁: Parallel Launch Strategy"
  
  Stream_2_Compute: {
    label: "Stream 2 (S2) - Compute Kernel"
    host -> sm: "kernel_launch<<<G, B, 0, S2>>>(BufB)" {
      style: {
        stroke: "#0891b2"
        stroke-width: 2
      }
    }
    
    sm -> sm: "Execute MatrixMul(Buffer B)" {
      style: {
        stroke: "#0891b2"
        bold: true
        fill: "#cffafe"
      }
    }
  }

  # T2: DMA Completion
  copy_engine."t₂: H2D Transfer Locked"
  
  copy_engine -> host: "cuEventRecord(Event_A_Ready)" {
    style: {
      stroke-dash: 3
      stroke: "#7c3aed"
      animated: true
    }
  }

  Concurrent_Overlap: {
    label: "Stream Overlap Region - Max Hardware Saturation"
    
    # Launch Stream 1 Kernel
    host -> sm: "kernel_launch<<<G, B, 0, S1>>>(BufA)" {
      style: {
        stroke: "#7c3aed"
        stroke-width: 2
      }
    }

    # Concurrent D2H Transfer
    sm -> host: "cudaMemcpyAsync(BufB_Result, D2H, S2)" {
      style: {
        stroke: "#0891b2"
        stroke-dash: 4
      }
    }

    # Stream 1 execution
    sm -> sm: "Execute FFT_Conv(Buffer A)" {
      style: {
        stroke: "#7c3aed"
        bold: true
        fill: "#ede9fe"
      }
    }
  }

  # T3: Final Reduction
  sm."t₃: Compute Engines Idle"
  
  sm -> copy_engine: "cuMemcpyDtoHAsync(BufA_Final, S1)" {
    style: {
      stroke: "#7c3aed"
    }
  }
  
  copy_engine -> host: "TransferComplete(Results_A)" {
    style: {
      stroke: "#7c3aed"
      stroke-dash: 3
    }
  }

  # T4: Synchronous Barrier
  host."t₄: Global Sync"
  host -> host: "cudaDeviceSynchronize()" {
    style: {
      stroke: "#1f2937"
      stroke-width: 3
    }
  }
}

# Performance Engineering Annotations
annotations: {
  near: bottom-center
  throughput: {
    shape: rectangle
    label: |md
      ### Architectural Performance Analysis
      Concurrency utilizes independent **Copy Engines (DMA)** and **Compute Engines (SMs)**. 
      
      **Real-world Metrics:**
      - SM Utilization: 94% (Concurrent Peak)
      - PCIe Saturation: 88% (Bidirectional)
      - **Throughput Gain:** ~1.82x vs. Sequential Pattern
    |
    style: {
      fill: "#fef3c7"
      stroke: "#f59e0b"
      stroke-width: 2
      border-radius: 8
    }
  }
}

# Legend
legend: {
  near: center-left
  s1: Stream 1 (Op: Buffer A) {
    style: {
      fill: "#7c3aed"
      font-color: white
      bold: true
    }
  }
  s2: Stream 2 (Op: Buffer B) {
    style: {
      fill: "#0891b2"
      font-color: white
      bold: true
    }
  }
  async: Async Signal / Event {
    style: {
      stroke-dash: 3
    }
  }
  
  style: {
    stroke: "#94a3b8"
    fill: "#f8fafc"
    border-radius: 4
  }
}