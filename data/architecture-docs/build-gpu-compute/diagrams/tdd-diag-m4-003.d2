vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

# -----------------------------------------------------------------------------
# GLOBAL TITLE & HEADER
# -----------------------------------------------------------------------------
title: "Compute-Transfer Overlap Pattern (Double-Buffered Pipeline)" {
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------
# ENGINEERING LEGEND
# -----------------------------------------------------------------------------
legend: {
  shape: rectangle
  style: {
    fill: "#F8F9FA"
    stroke: "#343A40"
    stroke-width: 2
    shadow: true
  }
  near: top-left

  label: "COMPONENT SPECIFICATIONS"
  
  h2d: "H2D Transfer (Host to Device)" {
    shape: rectangle
    style: { fill: "#4DABF7"; stroke: "#228BE6"; bold: true }
  }
  compute: "Kernel Compute (CUDA Kernel)" {
    shape: rectangle
    style: { fill: "#69DB7C"; stroke: "#37B24D"; bold: true }
  }
  d2h: "D2H Transfer (Device to Host)" {
    shape: rectangle
    style: { fill: "#FFA94D"; stroke: "#FD7E14"; bold: true }
  }
  barrier: "cudaStreamSynchronize()" {
    shape: circle
    style: { fill: "#E9ECEF"; stroke: "#ADB5BD"; stroke-dash: 2 }
  }
}

# -----------------------------------------------------------------------------
# TIMELINE / PHASES
# -----------------------------------------------------------------------------
timeline: {
  grid-columns: 6
  grid-gap: 50
  
  t0: "T₀: Initial" { shape: square; style.fill: "#E9ECEF" }
  t1: "T₁: Prefetch" { shape: square; style.fill: "#D0EBFF" }
  t2: "T₂: Overlap A" { shape: square; style.fill: "#FFD8A8"; style.stroke: red; style.stroke-width: 3 }
  t3: "T₃: Overlap B" { shape: square; style.fill: "#FFD8A8"; style.stroke: red; style.stroke-width: 3 }
  t4: "T₄: Drain" { shape: square; style.fill: "#D3F9D8" }
  t5: "T₅: Complete" { shape: square; style.fill: "#E9ECEF" }
  
  t0 -> t1 -> t2 -> t3 -> t4 -> t5: { style.stroke-width: 2 }
}

# -----------------------------------------------------------------------------
# GPU EXECUTION STREAMS
# -----------------------------------------------------------------------------
streams_group: {
  label: "GPU COMMAND QUEUES (STREAMS)"
  style: {
    stroke: "#212529"
    stroke-width: 3
    fill: "#F1F3F5"
  }

  stream_0: "cudaStream_t s0" {
    style.fill: "#FFFFFF"
    
    s0_h2d: "H2D: Chunk 0" {
      shape: rectangle
      style.fill: "#4DABF7"
      width: 160; height: 60
    }
    s0_compute: "KERNEL: Proc 0" {
      shape: rectangle
      style.fill: "#69DB7C"
      width: 200; height: 60
    }
    s0_d2h: "D2H: Result 0" {
      shape: rectangle
      style.fill: "#FFA94D"
      width: 160; height: 60
    }
    s0_h2d -> s0_compute -> s0_d2h
  }

  stream_1: "cudaStream_t s1" {
    style.fill: "#FFFFFF"

    s1_idle: "IDLE / WAIT" {
      shape: rectangle
      style.fill: "#F8F9FA"; style.stroke-dash: 5; style.font-color: "#ADB5BD"
      width: 120; height: 60
    }
    s1_h2d: "H2D: Chunk 1" {
      shape: rectangle
      style.fill: "#4DABF7"
      width: 160; height: 60
    }
    s1_compute: "KERNEL: Proc 1" {
      shape: rectangle
      style.fill: "#69DB7C"
      width: 200; height: 60
    }
    s1_d2h: "D2H: Result 1" {
      shape: rectangle
      style.fill: "#FFA94D"
      width: 160; height: 60
    }
    s1_idle -> s1_h2d -> s1_compute -> s1_d2h
  }
}

# Critical Path Visualization
(streams_group.stream_0.s0_compute -> streams_group.stream_1.s1_h2d): "ASYNCHRONOUS OVERLAP" {
  style: {
    stroke: red
    stroke-width: 4
    stroke-dash: 5
    animated: true
  }
}

# -----------------------------------------------------------------------------
# MEMORY ARCHITECTURE (VRAM)
# -----------------------------------------------------------------------------
memory: {
  label: "DEVICE GLOBAL MEMORY (VRAM)"
  style.fill: "#FFFFFF"
  style.stroke-width: 2

  page_boundary_top: "PAGE BOUNDARY (Offset 0x0000)" {
    shape: parallelogram
    width: 500; height: 10
    style.fill: "#212529"
  }

  buffer_a: {
    label: "BUFFER A (Ping)\n0x0000 - 0x0FFF"
    grid-rows: 2
    style.fill: "#E7F5FF"
    
    in_0: "Input Segment 0" { style.fill: "#A5D8FF" }
    out_0: "Output Segment 0" { style.fill: "#74C0FC" }
  }

  cache_line_sep: "--- 64B CACHE LINE BOUNDARY ---" {
    shape: text
    style.font-size: 10
    style.font-color: "#ADB5BD"
  }

  buffer_b: {
    label: "BUFFER B (Pong)\n0x1000 - 0x1FFF"
    grid-rows: 2
    style.fill: "#FFF4E6"
    
    in_1: "Input Segment 1" { style.fill: "#FFD8A8" }
    out_1: "Output Segment 1" { style.fill: "#FFC078" }
  }

  page_boundary_bottom: "PAGE BOUNDARY (Offset 0x2000)" {
    shape: parallelogram
    width: 500; height: 10
    style.fill: "#212529"
  }

  page_boundary_top -> buffer_a -> cache_line_sep -> buffer_b -> page_boundary_bottom
}

# -----------------------------------------------------------------------------
# SYSTEM TOPOLOGY
# -----------------------------------------------------------------------------
topology: {
  host_mem: "HOST RAM (Pinned/Locked)\nsizeof=8GB" {
    shape: rectangle
    style: { fill: "#FFF9DB"; stroke: "#F59F00"; double-border: true }
  }

  pcie_bus: "PCIe Gen4 x16 Controller\n(31.5 GB/s)" {
    shape: diamond
    style.fill: "#FFE3E3"; style.stroke: "#FA5252"
  }

  host_mem -> pcie_bus: "DMA PULL/PUSH"
  pcie_bus -> memory: "Async Memcpy Path"
}

# -----------------------------------------------------------------------------
# IMPLEMENTATION SEQUENCE (Fixed from board/step keywords)
# -----------------------------------------------------------------------------
implementation_sequence: {
  label: "ENGINEERING IMPLEMENTATION STEPS"
  style.fill: "#F1F3F5"
  style.stroke: "#343A40"
  
  step1: "1. Create N=2 cudaStream_t Handles" { shape: rectangle; style.fill: white }
  step2: "2. cudaMalloc Device Ping-Pong Buffers" { shape: rectangle; style.fill: white }
  step3: "3. cudaHostAlloc Pinned Memory (Zero-Copy/DMA)" { shape: rectangle; style.fill: white }
  step4: "4. Pipeline Loop: Launch async H2D(i+1) | Kernel(i) | D2H(i-1)" { shape: rectangle; style.fill: white }
  step5: "5. Synchronize all streams on exit" { shape: rectangle; style.fill: white }

  step1 -> step2 -> step3 -> step4 -> step5: { style.stroke: "#228BE6" }
}

# -----------------------------------------------------------------------------
# PERFORMANCE ANALYSIS
# -----------------------------------------------------------------------------
analysis_box: {
  shape: rectangle
  style: {
    fill: "#212529"
    stroke: "#343A40"
    font-color: "#FFFFFF"
    border-radius: 8
  }
  label: "⚡ THROUGHPUT ANALYSIS"
  
  content: |md
    ### Invariants
    - **Latency Hiding**: Target $T_{transfer} \le T_{compute}$
    - **Page Alignment**: All buffers must be 4KB aligned for DMA stability.
    - **Stream Affinity**: Avoid NULL stream (Default) to prevent global sync.
  |
}

# -----------------------------------------------------------------------------
# FINAL LAYOUT CONNECTIONS
# -----------------------------------------------------------------------------
timeline -> streams_group: "Sync Schedule"
streams_group -> memory: "Memory Map"
streams_group -> topology: "HW Interaction"
analysis_box -> implementation_sequence: "Logic -> Code"