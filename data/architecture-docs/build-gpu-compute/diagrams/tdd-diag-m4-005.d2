layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    sketch: false
    pad: 40
  }
}

# 1. Host System Memory Map (Intel Manual Quality Reference)
Host: "Host System (CPU Side)" {
  shape: rectangle
  style: {
    fill: "#f8f9fa"
    stroke: "#343a40"
    stroke-width: 4
  }
  
  HostMemory: "System RAM Layout (DDR5)" {
    Table: {
      grid-rows: 7
      grid-columns: 3
      grid-gap: 0
      
      # Header Row
      h1: "Address Offset" { style: { bold: true; fill: "#6f42c1"; font-color: white } }
      h2: "Field / Memory Region Description" { style: { bold: true; fill: "#6f42c1"; font-color: white } }
      h3: "Size (Bytes)" { style: { bold: true; fill: "#6f42c1"; font-color: white } }
      
      # Low Mem Row
      a1: "0x0000_0000" { style.fill: "#e9ecef" }
      a2: "Kernel Reserved / BIOS Hooks" { style.fill: "#dee2e6" }
      a3: "2 GB" { style.fill: "#e9ecef" }
      
      # Heap Row
      b1: "0x0800_0000" { style.fill: "#e7f5ff" }
      b2: "User Space Application Heap" { style.fill: "#d0ebff" }
      b3: "32 GB" { style.fill: "#e7f5ff" }
      
      # Cache Line Boundary Indicator (Symbolic)
      cl: "------" { style.stroke-dash: 3; style.stroke: gray }
      cl2: "64B Cache Line Boundary" { style: { italic: true; font-size: 10 } }
      cl3: "------" { style.stroke-dash: 3; style.stroke: gray }

      # Pinned Pool Row (DMA Target)
      c1: "0x8800_0000" { style.fill: "#fff4e6" }
      c2: "Pinned Pool (Locked DMA Source/Sink)" {
        style: {
          fill: "#ffe8cc"
          stroke: "#fd7e14"
          stroke-width: 2
        }
      }
      c3: "512 MB" { style.fill: "#fff4e6" }
      
      # Alignment Row
      d1: "0x8A00_0000" { style.fill: "#f1f3f5" }
      d2: "SIMD Alignment Padding (64B Aligned)" { style: { fill: "#f1f3f5"; italic: true } }
      d3: "64 KB" { style.fill: "#f1f3f5" }
      
      # Pageable Row
      e1: "0x9000_0000" { style.fill: "#e7f5ff" }
      e2: "Pageable Host Memory (Subject to Swap)" { style.fill: "#d0ebff" }
      e3: "Variable" { style.fill: "#e7f5ff" }
    }
    
    Buffers: {
      H2D_Buffer: "H2D Source Buffer" {
        tooltip: "Physical Address: 0x88000000"
        style.fill: "#74c0fc"
        style.stroke: "#1971c2"
        style.double-border: true
      }
      D2H_Buffer: "D2H Sink Buffer" {
        tooltip: "Physical Address: 0x88100000"
        style.fill: "#ff8787"
        style.stroke: "#c92a2a"
        style.double-border: true
      }
    }
  }
}

# 2. PCIe Interconnect - Transaction Layer (TLP)
PCIe: "PCIe Gen4 x16 Interconnect" {
  shape: parallelogram
  style: {
    fill: "#fff9db"
    stroke: "#fcc419"
    stroke-width: 3
    stroke-dash: 5
  }
  label.near: top-center

  TLP_Specs: |md
    ### TLP Structure (Transaction Layer Packet)
    - **Header**: 12-16 Bytes (Address, Type, Length)
    - **Payload**: Up to 512 Bytes (Max Payload Size)
    - **LCRC**: 4 Bytes (Error Checking)
    - **Throughput**: 31.51 GB/s (Full Duplex)
  | {
    shape: text
    style.font-size: 14
  }
}

# 3. GPU Device Architecture (Copy Engines & VRAM)
GPU: "Discrete GPU (Device Side)" {
  style: {
    fill: "#f4fce3"
    stroke: "#5c940d"
    stroke-width: 4
  }

  CopyEngines: "Asynchronous DMA Engines" {
    CE0: "Copy Engine 0\n(H2D Specialist)" {
      shape: hexagon
      style: { fill: "#94d82d"; stroke: "#2b8a3e"; shadow: true }
    }
    CE1: "Copy Engine 1\n(D2H Specialist)" {
      shape: hexagon
      style: { fill: "#94d82d"; stroke: "#2b8a3e"; shadow: true }
    }
  }

  VRAM: "Video Memory (GDDR6 / HBM3)" {
    shape: cylinder
    Input_Region: "Input Buffer (Device)" { style.fill: "#74c0fc"; style.stroke: "#1971c2" }
    Output_Region: "Output Buffer (Device)" { style.fill: "#ff8787"; style.stroke: "#c92a2a" }
    
    Label_Size: "16GB Address Space" {
      shape: text
      style.font-size: 11
    }
  }

  SM_Complex: "Compute Core Fabric" {
    style.multiple: true
    Cores: "ALU Array" { style.fill: "#69db7c" }
    L1: "L1 / Shared Memory" { style.fill: "#c0eb75" }
  }

  CE_Capabilities: "Concurrent Bidirectional Support" {
    shape: text
    style.font-color: "#2b8a3e"
    style.bold: true
    label.near: top-right
  }
}

# 4. DMA Transaction Flow & Connectivity
# Path: Host-to-Device (H2D) - Blue Trace
Host.HostMemory.Buffers.H2D_Buffer -> PCIe: "1. Virtual-to-Physical Map" {
  style: { stroke: "#1c7ed6"; stroke-width: 3; animated: true }
}
PCIe -> GPU.CopyEngines.CE0: "2. Write DMA Descriptor" {
  style: { stroke: "#1c7ed6"; stroke-width: 3 }
}
GPU.CopyEngines.CE0 -> GPU.VRAM.Input_Region: "3. Async PCIe Write TLP" {
  style: { stroke: "#1c7ed6"; stroke-width: 3 }
}

# Path: Device-to-Host (D2H) - Red Trace
GPU.VRAM.Output_Region -> GPU.CopyEngines.CE1: "4. Internal Read Trigger" {
  style: { stroke: "#e03131"; stroke-width: 3; animated: true }
}
GPU.CopyEngines.CE1 -> PCIe: "5. PCIe Read Request TLP" {
  style: { stroke: "#e03131"; stroke-width: 3 }
}
PCIe -> Host.HostMemory.Buffers.D2H_Buffer: "6. MSI-X Interrupt / Completion" {
  style: { stroke: "#e03131"; stroke-width: 3 }
}

# GPU Internal Memory Fabric
GPU.SM_Complex <-> GPU.VRAM: "Internal Bus (1.5 TB/s)" {
  style: {
    stroke: "#2b8a3e"
    stroke-width: 5
    stroke-dash: 2
  }
}

# 5. Legend and Root Metadata
Title: "GPU COPY ENGINE: ASYNCHRONOUS DMA ARCHITECTURE" {
  shape: text
  near: top-center
  style: {
    font-size: 34
    bold: true
    font-color: "#1864ab"
  }
}

Design_Notes: |md
  ## Hardware Implementation Logic
  1. **Memory Pinning (mlock)**: OS must lock virtual pages into RAM to provide stable physical addresses to the IOMMU.
  2. **Descriptor Rings**: Copy engines poll command buffers for new transfer jobs without CPU intervention.
  3. **Zero-Copy Optimization**: Unified Memory models allow bypassing discrete transfers using page migration.
  4. **TLP Protocol**: Data is packetized; CE0/CE1 manage credit-based flow control on the PCIe bus.
| {
  near: bottom-left
  style.font-size: 14
}

Legend: "Technical Interface Legend" {
  near: bottom-right
  style: {
    fill: "#f8f9fa"
    stroke: "#adb5bd"
    border-radius: 8
  }
  
  H2D: "━━▶ H2D (Blue): Host Source → GPU Sink" { shape: text; style.font-color: "#1c7ed6" }
  D2H: "━━▶ D2H (Red): GPU Source → Host Sink" { shape: text; style.font-color: "#e03131" }
  Int: "⇄  Internal: Compute / VRAM Interconnect" { shape: text; style.font-color: "#2b8a3e" }
  Bus: "- - PCIe Tunnel: Gen4 Transaction Layer" { shape: text; style.font-color: "#fcc419" }
}

# Structural Constraints
Host.width: 700
GPU.width: 750
PCIe.width: 900

# Invisible flow guides for ELK engine
Host -> PCIe -> GPU: { style.opacity: 0 }