vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  header: {
    style: {
      fill: "#2E3440"
      font-color: white
      bold: true
      font-size: 18
    }
  }
  cell_prop: {
    style: {
      fill: "#E5E9F0"
      bold: true
    }
  }
  cell_val: {
    style: {
      fill: "white"
    }
  }
  blocking_state: {
    style: {
      fill: "#F87171"
      stroke: "#B91C1C"
      bold: true
    }
  }
  executing_state: {
    style: {
      fill: "#60A5FA"
      stroke: "#1D4ED8"
    }
  }
  success_path: {
    style: {
      stroke: "#059669"
      stroke-width: 3
    }
  }
}

direction: down

title: {
  shape: text
  label: "CUDA Synchronization Options & Hardware Interaction"
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# --- COMPARISON GRID ---
sync_comparison: {
  grid-columns: 4
  grid-gap: 0
  style.stroke: "#2E3440"
  style.stroke-width: 2

  # Row 1: Headers
  h1: "Property"; h2: "cudaStreamSynchronize"; h3: "cudaStreamWaitEvent"; h4: "cudaStreamQuery"
  h1.class: header; h2.class: header; h3.class: header; h4.class: header

  # Row 2: Mechanism
  r2c1: "Blocking Mechanism"; r2c2: "CPU blocks (Host stall)"; r2c3: "GPU blocks (Stream stall)"; r2c4: "Non-blocking (Polling)"
  r2c1.class: cell_prop; r2c2.class: cell_val; r2c3.class: cell_val; r2c4.class: cell_val

  # Row 3: Execution Site
  r3c1: "Execution Site"; r3c2: "Host (CPU)"; r3c3: "Device (GPU Scheduler)"; r3c4: "Host (CPU)"
  r3c1.class: cell_prop; r3c2.class: cell_val; r3c3.class: cell_val; r3c4.class: cell_val

  # Row 4: CPU Behavior
  r4c1: "CPU Resource Usage"; r4c2: "Idle/Yield until done"; r4c3: "Free to do other work"; r4c4: "Available for other work"
  r4c1.class: cell_prop; r4c2.class: cell_val; r4c3.class: cell_val; r4c4.class: cell_val

  # Row 5: Interaction
  r5c1: "Dependency Target"; r5c2: "Entire Stream contents"; r5c3: "Specific Recorded Event"; r5c4: "Stream Status Snapshot"
  r5c1.class: cell_prop; r5c2.class: cell_val; r5c3.class: cell_val; r5c4.class: cell_val

  # Row 6: Return Codes
  r6c1: "API Return Logic"; r6c2: "cudaSuccess upon finish"; r6c3: "cudaSuccess immediately"; r6c4: "cudaErrorNotReady if busy"
  r6c1.class: cell_prop; r6c2.class: cell_val; r6c3.class: cell_val; r6c4.class: cell_val

  # Row 7: Latency/Overhead
  r7c1: "Sync Overhead"; r7c2: "High (Context Switch)"; r7c3: "Microscopic (HW Level)"; r7c4: "Minimal (Register Read)"
  r7c1.class: cell_prop; r7c2.class: cell_val; r7c3.class: cell_val; r7c4.class: cell_val
}

# --- IMPLEMENTATION DETAILS WRAPPER ---
# We wrap the grid and the diagrams to prevent the 'near grid cell' layout error.
implementation_container: {
  
  diagram_group: {
    grid-columns: 3
    grid-gap: 50
    
    # 1. Host Synchronous Block
    cpu_sync_diagram: {
      label: "Option A: cudaStreamSynchronize (Host-Side)"
      
      cpu_timeline: {
        label: "CPU Timeline"
        t0: "Task A Executing" { class: executing_state }
        t1: "BLOCKING CALL" { class: blocking_state }
        t2: "Resume Task B" { class: executing_state }
        
        t0 -> t1: "Invokes Sync"
        t1 -> t2: "Return"
      }

      gpu_timeline: {
        label: "GPU Stream 0"
        k1: "Kernel Execution" { style.fill: "#D1FAE5" }
        k1_done: "Done" { shape: circle }
        
        k1 -> k1_done
      }

      cpu_timeline.t1 -> gpu_timeline.k1: "Waiting..." {
        style.stroke: "#EF4444"
        style.stroke-dash: 5
      }
      gpu_timeline.k1_done -> cpu_timeline.t2: "Interrupt/Wakeup" {
        class: success_path
      }
    }

    # 2. Inter-Stream Dependency
    gpu_wait_diagram: {
      label: "Option B: cudaStreamWaitEvent (Device-Side)"
      
      stream_1: {
        label: "Stream 1 (Producer)"
        s1_k1: "Compute Kernel"
        s1_ev: "Record Event (E1)" { style.fill: "#DDD6FE" }
        s1_k1 -> s1_ev
      }

      stream_2: {
        label: "Stream 2 (Consumer)"
        s2_wait: "WAIT EVENT (E1)" { class: blocking_state }
        s2_k2: "Dependent Kernel"
        s2_wait -> s2_k2
      }

      stream_1.s1_ev -> stream_2.s2_wait: "GPU-Side Signal" {
        style.stroke: "#8B5CF6"
        style.stroke-width: 4
      }

      cpu_host: "CPU: Continues immediately" {
        shape: parallelogram
        style.fill: "#FEF3C7"
      }
    }

    # 3. Polling Pattern
    poll_query_diagram: {
      label: "Option C: cudaStreamQuery (Non-Blocking)"
      
      poll_loop: {
        label: "Host Poll Loop"
        check: "cudaStreamQuery()"
        eval: "Is Done?" { shape: diamond }
        work: "Do Other CPU Work"
        exit: "Finish" { shape: circle }
        
        check -> eval
        eval -> work: "No: NotReady"
        work -> check: "Loop"
        eval -> exit: "Yes: Success" { class: success_path }
      }

      gpu_stream: {
        label: "GPU Execution"
        long_task: "Running Task..." { style.fill: "#E0F2FE" }
      }
      
      poll_loop.check -> gpu_stream.long_task: "Status Check" {
        style.stroke-dash: 2
      }
    }
  }

  # --- SUMMARY ANNOTATION ---
  # Placed inside the implementation_container but outside the diagram_group grid.
  annotation: |md
    ### Engineering Guidelines for Implementation:
    
    1.  **cudaStreamSynchronize**:
        *   *Offset Latency*: ~5-10 microseconds context switch overhead.
        *   *Constraint*: Use only when the CPU absolutely requires kernel results to compute the next host-side branch.
    
    2.  **cudaStreamWaitEvent**:
        *   *Optimization*: Zero CPU cycles consumed. The Hardware Command Processor (CP) stalls the specific stream queue at the GPU front-end.
        *   *Constraint*: Preferred for Pipeline/Graph dependencies.
    
    3.  **cudaStreamQuery**:
        *   *Optimization*: Use in "Busy-Wait" loops where the CPU has secondary tasks (e.g., UI updates, Disk I/O) that can progress while waiting for hardware.
  | {
    style.font-size: 14
  }
}

# Link the container to the comparison for vertical flow
sync_comparison -> implementation_container: "Implementation Visuals" {
  style.stroke-width: 0
}