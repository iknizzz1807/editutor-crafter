direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # GPU Resource Constraints & Kernel Concurrency
  **Technical Specification: CUDA SM Partitioning & Resource Exhaustion**
  *Intel/NVIDIA Reference Architecture Grade Implementation Diagram*
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

gpu_hardware: GPU Compute Device {
  style: {
    fill: "#f8f9fa"
    stroke: "#1a1a2e"
    stroke-width: 4
  }

  sm_pool: Streaming Multiprocessors (SMs) {
    grid-columns: 3
    style.fill: "#eef2f3"

    sm_0: SM_UNIT_0 {
      style.fill: "#ffffff"
      style.stroke: "#0f3460"
      
      reg_0: Register File {
        label: "RF: 64K Regs"
        "0x0000": "Allocated [48K]" { style.fill: "#00b894"; style.opacity: 0.8 }
        "0xC000": "Available [16K]" { style.fill: "#dfe6e9" }
      }
      
      smem_0: Shared Memory (L1) {
        label: "SMem: 164KB"
        "0x0000": "Kernel_A [96KB]" { style.fill: "#533483"; style.font-color: white }
        "0x1800": "Free [68KB]" { style.fill: "#dfe6e9" }
      }

      blocks: Active Hardware Blocks {
        b0: "Block 0 (Stream A)" { style.fill: "#00b894" }
        b1: "Block 1 (Stream A)" { style.fill: "#00b894" }
        b2: "Block 2 (Stream A)" { style.fill: "#00b894" }
        b3: "Block 3 (Stream A)" { style.fill: "#00b894" }
      }
    }

    sm_1: SM_UNIT_1 {
      style.fill: "#ffffff"
      style.stroke: "#0f3460"

      reg_1: Register File {
        label: "RF: 64K Regs"
        "0x0000": "Kernel_A [32K]" { style.fill: "#00b894" }
        "0x8000": "Kernel_B [32K]" { style.fill: "#fdcb6e" }
      }

      smem_1: Shared Memory (L1) {
        label: "SMem: 164KB"
        "0x0000": "Kernel_A [48KB]" { style.fill: "#533483"; style.font-color: white }
        "0x0C00": "Kernel_B [24KB]" { style.fill: "#fdcb6e" }
        "0x1200": "Free [92KB]" { style.fill: "#dfe6e9" }
      }

      blocks: Active Hardware Blocks {
        b0: "Block 0 (Stream A)" { style.fill: "#00b894" }
        b1: "Block 1 (Stream A)" { style.fill: "#00b894" }
        b2: "Block 0 (Stream B)" { style.fill: "#fdcb6e" }
        b3: "Block 1 (Stream B)" { style.fill: "#fdcb6e" }
      }
    }

    sm_2: SM_UNIT_2 {
      style.fill: "#ffffff"
      style.stroke: "#0f3460"
      
      reg_2: Register File {
        label: "RF: 64K Regs"
        "0x0000": "Kernel_B [64K]" { style.fill: "#fdcb6e" }
      }

      smem_2: Shared Memory (L1) {
        label: "SMem: 164KB"
        "0x0000": "Kernel_B [48KB]" { style.fill: "#fdcb6e" }
        "0x0C00": "Free [116KB]" { style.fill: "#dfe6e9" }
      }

      blocks: Active Hardware Blocks {
        b0: "Block 2 (Stream B)" { style.fill: "#fdcb6e" }
        b1: "Block 3 (Stream B)" { style.fill: "#fdcb6e" }
        b2: "Block 4 (Stream B)" { style.fill: "#fdcb6e" }
        b3: "Block 5 (Stream B)" { style.fill: "#fdcb6e" }
      }
    }
  }
}

streams: CUDA Compute Streams {
  style.fill: "#2d3436"
  style.font-color: white

  stream_a: Stream A (Async) {
    launch: "Kernel_A <<<Grid 256, Block 256>>>" {
      registers: "64/thread"
      shmem: "24KB/block"
      style.fill: "#00b894"
    }
    status: EXECUTING { style.fill: "#00b894"; style.bold: true }
  }

  stream_b: Stream B (Async) {
    launch: "Kernel_B <<<Grid 512, Block 128>>>" {
      registers: "48/thread"
      shmem: "12KB/block"
      style.fill: "#fdcb6e"
    }
    status: PARTIAL_DISPATCH { style.fill: "#fdcb6e"; style.bold: true }
  }

  stream_c: Stream C (Async) {
    launch: "Kernel_C <<<Grid 1024, Block 512>>>" {
      registers: "128/thread"
      shmem: "64KB/block"
      style.fill: "#d63031"
      style.font-color: white
    }
    status: QUEUED_SERIALIZED { 
      style.fill: "#d63031"
      style.font-color: white
      style.bold: true
      tooltip: "Waiting for RF availability on SMs"
    }
  }
}

constraints: Resource Limits {
  style.fill: "#dfe6e9"
  
  reg_limit: Register Unit {
    shape: sql_table
    max_per_sm: 65536
    granularity: "256 regs/block"
    max_per_thread: 255
    style.fill: "#e74c3c"
  }
  
  smem_limit: Shared Memory Unit {
    shape: sql_table
    max_sm_cap: "164 KB"
    bank_width: "32-bit"
    banks: 32
    style.fill: "#9b59b6"
  }
  
  warp_limit: Warp Scheduler {
    shape: sql_table
    max_warps_sm: 64
    threads_warp: 32
    max_thread_sm: 2048
    style.fill: "#3498db"
  }
}

analysis: Serialization Logic {
  grid-rows: 2
  reg_full: RF Exhaustion {
    condition: "Req_Regs > Avail_Regs"
    action: "Block Dispatch Stall"
    style.fill: "#fab1a0"
  }
  smem_full: SMem Exhaustion {
    condition: "Req_SMem > Avail_SMem"
    action: "Block Dispatch Stall"
    style.fill: "#dff9fb"
  }
}

# Connections
streams.stream_a.launch -> gpu_hardware.sm_pool.sm_0: "Dispatch Blocks (64 regs/t)" {
  style.stroke: "#00b894"
  style.stroke-width: 2
}
streams.stream_a.launch -> gpu_hardware.sm_pool.sm_1: "Dispatch Blocks" {
  style.stroke: "#00b894"
}

streams.stream_b.launch -> gpu_hardware.sm_pool.sm_1: "Concurrent Dispatch" {
  style.stroke: "#fdcb6e"
  style.animated: true
}
streams.stream_b.launch -> gpu_hardware.sm_pool.sm_2: "Dispatch Blocks" {
  style.stroke: "#fdcb6e"
}

streams.stream_c.launch -> gpu_hardware.sm_pool: "BLOCKED: RF Capacity" {
  style.stroke: "#d63031"
  style.stroke-dash: 5
  target-arrowhead: cross
}

constraints.reg_limit -> gpu_hardware.sm_pool: "Hard Hardware Cap" {
  style.stroke: "#636e72"
  style.stroke-dash: 3
}

# Legend Area
legend: Runtime Status {
  near: bottom-right
  exec: Full Execution { style.fill: "#00b894" }
  conc: Concurrent Execution { style.fill: "#fdcb6e" }
  stall: Resource Stall { style.fill: "#d63031"; style.font-color: white }
  avail: Resource Available { style.fill: "#dfe6e9" }
}