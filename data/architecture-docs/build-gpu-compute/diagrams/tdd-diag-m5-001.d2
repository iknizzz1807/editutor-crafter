direction: right

# Nsight Systems Timeline View - Detailed GPU/CPU Interaction
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Style definitions for technical clarity
classes: {
  memory_op: {
    style: {
      fill: "#4A90D9"
      stroke: "#2E5A8B"
      font-color: white
      bold: true
    }
  }
  kernel_op: {
    style: {
      fill: "#7B68EE"
      stroke: "#5A4BA3"
      font-color: white
      bold: true
    }
  }
  gap: {
    style: {
      fill: "#FFE5E5"
      stroke: "#CC0000"
      stroke-dash: 3
    }
  }
  async_op: {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      bold: true
    }
  }
  thread: {
    shape: person
    style: {
      fill: "#F3F4F6"
      stroke: "#374151"
    }
  }
  stream: {
    shape: rectangle
    style: {
      fill: "#E5E7EB"
      stroke: "#1F2937"
      double-border: true
    }
  }
}

timeline_analysis: {
  shape: sequence_diagram
  
  # Actors Definition
  cpu_main: CPU Main Thread {
    class: thread
  }
  cpu_worker: CPU Worker Thread {
    class: thread
  }
  gpu_stream0: GPU Stream 0\n(Default) {
    class: stream
  }
  gpu_stream1: GPU Stream 1 {
    class: stream
  }
  gpu_stream2: GPU Stream 2 {
    class: stream
  }

  # Timeline Initial State
  "T=0ms Start Profiling"

  # CPU Main Thread Initialization Phase
  cpu_main -> cpu_main: cudaInit() {
    tooltip: "Initialize CUDA Context and primary device"
  }
  
  cpu_main -> gpu_stream0: cudaMalloc(d_data, 1GB) {
    label: "H2D Allocation"
    class: memory_op
  }
  
  cpu_main -> gpu_stream0: cudaMemcpyH2D(d_in, h_in, 256MB) {
    label: "Blocking Transfer"
    class: memory_op
  }

  # Serialization gap indicator (Self-message to show wait time)
  cpu_main -> cpu_main: ⚠️ SERIAL GAP - Waiting for Stream 0 {
    class: gap
  }

  # Worker thread spawns
  cpu_main -> cpu_worker: Launch Worker Thread

  # Stream 0 operations (serialized execution)
  cpu_worker -> gpu_stream0: kernel_preprocess<<<>>>() {
    label: "Grid: 256x256\nBlocks: 128"
    class: kernel_op
  }

  # Stream 1 operations (async, overlaps with stream 0)
  cpu_worker -> gpu_stream1: cudaMemcpyAsync(d_buf1, h_buf1, 128MB) {
    label: "Async H2D"
    class: async_op
  }
  
  cpu_worker -> gpu_stream1: kernel_compute_v1<<<>>>() {
    label: "Compute Kernel V1"
    class: kernel_op
  }

  # Stream 2 operations
  cpu_worker -> gpu_stream2: cudaMemcpyAsync(d_buf2, h_buf2, 128MB) {
    label: "Async H2D"
    class: async_op
  }
  
  cpu_worker -> gpu_stream2: kernel_compute_v2<<<>>>() {
    label: "Compute Kernel V2"
    class: kernel_op
  }

  # Concurrency demonstration - note the overlap
  gpu_stream0 -> gpu_stream0: kernel_postprocess<<<>>>() {
    label: "Post-process (Stream 0)"
    class: kernel_op
  }

  # Another serialization gap
  cpu_worker -> cpu_worker: ⚠️ SERIAL GAP - cudaDeviceSynchronize() {
    class: gap
  }

  # D2H transfers
  gpu_stream0 -> cpu_main: cudaMemcpy(h_out, d_out, 256MB) {
    label: "D2H Blocking"
    class: memory_op
  }
  
  gpu_stream1 -> cpu_main: cudaMemcpyAsync(h_result1, d_result1, 64MB) {
    label: "Async D2H"
    class: async_op
  }
  
  gpu_stream2 -> cpu_main: cudaMemcpyAsync(h_result2, d_result2, 64MB) {
    label: "Async D2H"
    class: async_op
  }

  # Final synchronization barrier
  cpu_main -> cpu_main: cudaDeviceSynchronize() {
    label: "Final Barrier"
    style: {
      stroke: "#CC0000"
      stroke-width: 4
    }
  }
  
  "T=30ms End Profiling"
}

# Legend Section (Placed outside sequence diagram for layout stability)
legend: {
  label: "Timeline Metadata & Legend"
  near: bottom-center
  
  grid-columns: 2
  
  mem_transfer: {
    label: "Memory Transfer (H2D/D2H)"
    class: memory_op
  }
  kernel_exec: {
    label: "Kernel Execution"
    class: kernel_op
  }
  serial_gap: {
    label: "Serialization Gap (Idle Time)"
    class: gap
  }
  overlap: {
    label: "Concurrent Execution (Async)"
    class: async_op
  }
}

# Global Style Overrides for Manual quality
***.style.font: mono
(*** -> ***)[*]: {
  style.stroke-width: 2
}