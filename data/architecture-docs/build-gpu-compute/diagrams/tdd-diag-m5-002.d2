direction: right
layout: elk
title: Nsight Compute Analysis Workflow {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Style definitions
classes: {
  section_container: {
    style: {
      fill: "#1a1a2e"
      stroke: "#4a4a6a"
      stroke-width: 3
      border-radius: 12
      shadow: true
    }
  }
  section_header: {
    style: {
      fill: "#16213e"
      stroke: "#0f3460"
      stroke-width: 2
      font-color: "#e94560"
      bold: true
      font-size: 16
    }
  }
  metric_label: {
    style: {
      fill: "#0f3460"
      stroke: "#1a1a2e"
      font-color: "#94d0cc"
      font-size: 11
    }
  }
  metric_value: {
    shape: diamond
    style: {
      fill: "#533483"
      stroke: "#e94560"
      font-color: "#ffffff"
      font-size: 10
    }
  }
  flow_arrow: {
    style: {
      stroke: "#e94560"
      stroke-width: 3
      animated: true
    }
  }
  label_container: {
    style: {
      fill: "#0d0d1a"
      stroke: "#2a2a4a"
      stroke-dash: 4
      border-radius: 6
    }
  }
}
# Section 1: Launch Statistics
launch_stats: {
  class: section_container
  header: {
    class: section_header
    label: "🚀 Launch Statistics"
  }
  grid: {
    rows: 5
    columns: 2
    grid_cells: [
      # Row 1
      {
        label: "Grid Size\n(dim3)"
        class: metric_label
      }
      {
        label: "<<< Grid.x × Grid.y × Grid.z >>>"
        class: metric_value
      }
      # Row 2
      {
        label: "Block Size\n(Threads)"
        class: metric_label
      }
      {
        label: "256 threads/block"
        class: metric_value
      }
      # Row 3
      {
        label: "Registers\nPer Thread"
        class: metric_label
      }
      {
        label: "32 regs"
        class: metric_value
      }
      # Row 4
      {
        label: "Shared Memory\nPer Block"
        class: metric_label
      }
      {
        label: "4,096 bytes"
        class: metric_value
      }
      # Row 5
      {
        label: "Occupancy\nTheory | Achieved"
        class: metric_label
      }
      {
        label: "100% | 87.5%"
        class: metric_value
      }
    ]
  }
  header -> grid
}
# Section 2: Memory Workload
memory_workload: {
  class: section_container
  header: {
    class: section_header
    label: "💾 Memory Workload"
  }
  grid: {
    rows: 4
    columns: 2
    grid_cells: [
      # Row 1
      {
        label: "Global Load\nThroughput"
        class: metric_label
      }
      {
        label: "412.5 GB/s"
        class: metric_value
      }
      # Row 2
      {
        label: "Global Store\nThroughput"
        class: metric_label
      }
      {
        label: "198.3 GB/s"
        class: metric_value
      }
      # Row 3
      {
        label: "L2 Cache\nHit Rate"
        class: metric_label
      }
      {
        label: "78.4%"
        class: metric_value
      }
      # Row 4
      {
        label: "DRAM\nThroughput"
        class: metric_label
      }
      {
        label: "610.8 GB/s\n(Peak: 900 GB/s)"
        class: metric_value
      }
    ]
  }
  header -> grid
}
# Section 3: Compute Workload
compute_workload: {
  class: section_container
  header: {
    class: section_header
    label: "⚡ Compute Workload"
  }
  grid: {
    rows: 4
    columns: 2
    grid_cells: [
      # Row 1
      {
        label: "FMA Pipeline\nUtilization"
        class: metric_label
      }
      {
        label: "45.2%"
        class: metric_value
      }
      # Row 2
      {
        label: "ALU Pipeline\nUtilization"
        class: metric_label
      }
      {
        label: "32.8%"
        class: metric_value
      }
      # Row 3
      {
        label: "Tensor Core\nUtilization"
        class: metric_label
      }
      {
        label: "0% (N/A)"
        class: metric_value
      }
      # Row 4
      {
        label: "Issue Slot\nUtilization"
        class: metric_label
      }
      {
        label: "62.1%"
        class: metric_value
      }
    ]
  }
  header -> grid
}
# Section 4: Warp State
warp_state: {
  class: section_container
  header: {
    class: section_header
    label: "🧵 Warp State"
  }
  grid: {
    rows: 5
    columns: 2
    grid_cells: [
      # Row 1
      {
        label: "Warps Active\nPer Cycle"
        class: metric_label
      }
      {
        label: "24 / 32"
        class: metric_value
      }
      # Row 2
      {
        label: "Warps Eligible\nPer Cycle"
        class: metric_label
      }
      {
        label: "18 / 32"
        class: metric_value
      }
      # Row 3
      {
        label: "Stall: Memory\nDependency"
        class: metric_label
      }
      {
        label: "28.5%"
        class: metric_value
      }
      # Row 4
      {
        label: "Stall: Execution\nDependency"
        class: metric_label
      }
      {
        label: "12.3%"
        class: metric_value
      }
      # Row 5
      {
        label: "Stall: Sync\n| Other"
        class: metric_label
      }
      {
        label: "8.1% | 5.2%"
        class: metric_value
      }
    ]
  }
  header -> grid
}
# Section 5: Memory Access Patterns
mem_patterns: {
  class: section_container
  header: {
    class: section_header
    label: "📊 Memory Access Patterns"
  }
  grid: {
    rows: 4
    columns: 2
    grid_cells: [
      # Row 1
      {
        label: "Global Load\nEfficiency"
        class: metric_label
      }
      {
        label: "92.3%"
        class: metric_value
      }
      # Row 2
      {
        label: "Global Store\nEfficiency"
        class: metric_label
      }
      {
        label: "87.6%"
        class: metric_value
      }
      # Row 3
      {
        label: "Shared Bank\nConflicts"
        class: metric_label
      }
      {
        label: "0.02%"
        class: metric_value
      }
      # Row 4
      {
        label: "L2 Sector\nMiss Rate"
        class: metric_label
      }
      {
        label: "21.6%"
        class: metric_value
      }
    ]
  }
  header -> grid
}
# Flow connections between sections
launch_stats -> memory_workload: {
  class: flow_arrow
  label: "Analyze\nMemory"
}
memory_workload -> compute_workload: {
  class: flow_arrow
  label: "Check\nCompute"
}
compute_workload -> warp_state: {
  class: flow_arrow
  label: "Inspect\nWarps"
}
warp_state -> mem_patterns: {
  class: flow_arrow
  label: "Optimize\nAccess"
}
# Classification labels (Roofline context)
classification: {
  class: label_container
  label: "🎯 Classification: Memory-Bound Kernel\n\nPeak DRAM BW: 900 GB/s\nAchieved: 610.8 GB/s (67.9% efficiency)\n\nRoofline Position: Below ridge point"
}
# Optimization recommendations
optimization: {
  class: label_container
  label: "🔧 Next Steps:\n\n1. Improve L2 cache hit rate\n2. Coalesce memory accesses\n3. Reduce memory dependency stalls\n4. Consider shared memory caching"
}
# Connect classification and optimization
memory_workload -> classification: {
  style: {
    stroke: "#533483"
    stroke-width: 2
    stroke-dash: 3
  }
}
mem_patterns -> optimization: {
  style: {
    stroke: "#533483"
    stroke-width: 2
    stroke-dash: 3
  }
}