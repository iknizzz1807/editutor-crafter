direction: right
layout-engine: elk
title: {
  label: Roofline Model Visualization\nGPU Performance Analysis
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Legend Box
legend: {
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: "#1a1a2e"
  }
  legend_title: {
    label: Kernel Classification
    shape: text
    style: {
      font-size: 14
      bold: true
      underline: true
    }
  }
  mem_bound: {
    label: ● Memory Bound\n  (AI < 10 FLOPs/Byte)
    shape: text
    style: {
      font-color: "#e74c3c"
    }
  }
  trans_bound: {
    label: ● Transition Zone\n  (10 ≤ AI ≤ 50 FLOPs/Byte)
    shape: text
    style: {
      font-color: "#f39c12"
    }
  }
  comp_bound: {
    label: ● Compute Bound\n  (AI > 50 FLOPs/Byte)
    shape: text
    style: {
      font-color: "#27ae60"
    }
  }
}
# Main Plot Area
plot_area: {
  shape: rectangle
  style: {
    fill: "#0d1117"
    stroke: "#30363d"
    stroke-width: 2
  }
}
# Y-Axis Label
y_axis_label: {
  label: Achievable FLOPS\n(GFLOPS/s)
  shape: text
  style: {
    font-size: 14
    bold: true
    font-color: "#8b949e"
  }
}
# X-Axis Label
x_axis_label: {
  label: Arithmetic Intensity (FLOPs/Byte) →
  shape: text
  style: {
    font-size: 14
    bold: true
    font-color: "#8b949e"
  }
}
# Y-Axis Scale
y_scale: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
  y_1000: {
    label: 10,000
    shape: text
    style: { font-size: 10 }
  }
  y_800: {
    label: 8,000
    shape: text
    style: { font-size: 10 }
  }
  y_600: {
    label: 6,000
    shape: text
    style: { font-size: 10 }
  }
  y_400: {
    label: 4,000
    shape: text
    style: { font-size: 10 }
  }
  y_200: {
    label: 2,000
    shape: text
    style: { font-size: 10 }
  }
  y_0: {
    label: 0
    shape: text
    style: { font-size: 10 }
  }
}
# X-Axis Scale
x_scale: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
  x_0: {
    label: 0.1
    shape: text
    style: { font-size: 10 }
  }
  x_1: {
    label: 1
    shape: text
    style: { font-size: 10 }
  }
  x_10: {
    label: 10
    shape: text
    style: { font-size: 10 }
  }
  x_50: {
    label: 50
    shape: text
    style: { font-size: 10 }
  }
  x_100: {
    label: 100
    shape: text
    style: { font-size: 10 }
  }
  x_1000: {
    label: 1000
    shape: text
    style: { font-size: 10 }
  }
}
# Roofline Components
roofline: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
  # Memory Bandwidth Line (Slope = Peak BW)
  # Peak BW = 900 GB/s → creates diagonal slope
  memory_slope: {
    label: Peak Memory Bandwidth (900 GB/s)
    shape: parallelogram
    style: {
      fill: transparent
      stroke: "#e74c3c"
      stroke-width: 3
      stroke-dash: 0
      opacity: 0.9
    }
  }
  # Compute Peak Line (Horizontal)
  # Peak Compute = 9,700 GFLOPS (RTX 4090)
  compute_ceiling: {
    label: Peak Compute (9,700 GFLOPS)
    shape: rectangle
    style: {
      fill: transparent
      stroke: "#27ae60"
      stroke-width: 3
      stroke-dash: 0
      opacity: 0.9
    }
  }
  # Ridge Point annotation
  ridge_point: {
    label: Ridge Point\n(AI ≈ 10.8)
    shape: text
    style: {
      font-size: 11
      bold: true
      font-color: "#f39c12"
    }
  }
}
# Zone Labels
zones: {
  memory_zone: {
    label: Memory\nBound\nRegion
    shape: text
    style: {
      font-size: 16
      bold: true
      font-color: "#e74c3c"
      opacity: 0.6
    }
  }
  compute_zone: {
    label: Compute\nBound\nRegion
    shape: text
    style: {
      font-size: 16
      bold: true
      font-color: "#27ae60"
      opacity: 0.6
    }
  }
}
# Kernel Points - Memory Bound
kernels_memory: {
  style: {
    fill: transparent
    stroke: transparent
  }
  # Vector Add: AI = 0.5, ~450 GFLOPS
  vec_add: {
    label: Vector Add\nAI=0.5
    shape: circle
    style: {
      fill: "#e74c3c"
      stroke: "#ff6b6b"
      stroke-width: 2
      shadow: true
    }
  }
  # Copy: AI = 0.125, ~112 GFLOPS
  copy: {
    label: Memcpy\nAI=0.125
    shape: circle
    style: {
      fill: "#e74c3c"
      stroke: "#ff6b6b"
      stroke-width: 2
      shadow: true
    }
  }
  # Sparse MV: AI = 2, ~1,800 GFLOPS
  sparse_mv: {
    label: SpMV\nAI=2
    shape: circle
    style: {
      fill: "#e74c3c"
      stroke: "#ff6b6b"
      stroke-width: 2
      shadow: true
    }
  }
  # Reduction: AI = 1, ~900 GFLOPS
  reduction: {
    label: Reduction\nAI=1
    shape: circle
    style: {
      fill: "#e74c3c"
      stroke: "#ff6b6b"
      stroke-width: 2
      shadow: true
    }
  }
}
# Kernel Points - Transition Zone
kernels_transition: {
  style: {
    fill: transparent
    stroke: transparent
  }
  # Matrix-Vector: AI = 16
  mat_vec: {
    label: GEMV\nAI=16
    shape: circle
    style: {
      fill: "#f39c12"
      stroke: "#f1c40f"
      stroke-width: 2
      shadow: true
    }
  }
  # Stencil: AI = 24
  stencil: {
    label: Stencil\nAI=24
    shape: circle
    style: {
      fill: "#f39c12"
      stroke: "#f1c40f"
      stroke-width: 2
      shadow: true
    }
  }
}
# Kernel Points - Compute Bound
kernels_compute: {
  style: {
    fill: transparent
    stroke: transparent
  }
  # SGEMM: AI = 256
  sgemm: {
    label: SGEMM\nAI=256
    shape: circle
    style: {
      fill: "#27ae60"
      stroke: "#2ecc71"
      stroke-width: 2
      shadow: true
    }
  }
  # DGEMM: AI = 128
  dgemm: {
    label: DGEMM\nAI=128
    shape: circle
    style: {
      fill: "#27ae60"
      stroke: "#2ecc71"
      stroke-width: 2
      shadow: true
    }
  }
  # FFT: AI = 80
  fft: {
    label: FFT\nAI=80
    shape: circle
    style: {
      fill: "#27ae60"
      stroke: "#2ecc71"
      stroke-width: 2
      shadow: true
    }
  }
  # Convolution: AI = 60
  conv: {
    label: Conv2D\nAI=60
    shape: circle
    style: {
      fill: "#27ae60"
      stroke: "#2ecc71"
      stroke-width: 2
      shadow: true
    }
  }
}
# Performance Optimization Arrows
optimizations: {
  style: {
    fill: transparent
    stroke: transparent
  }
  # Optimization path for Vector Add
  opt_vec_add: {
    label: Optimize: Coalesced Access\n+ Shared Memory
    shape: text
    style: {
      font-size: 9
      font-color: "#58a6ff"
      italic: true
    }
  }
  # Optimization path for GEMV
  opt_gemv: {
    label: Optimize: Tile +\nReduce Traffic
    shape: text
    style: {
      font-size: 9
      font-color: "#58a6ff"
      italic: true
    }
  }
  # Arrow showing optimization direction
  opt_arrow: {
    shape: diamond
    style: {
      fill: "#58a6ff"
      stroke: "#58a6ff"
      opacity: 0.7
    }
  }
}
# Formula Box
formulas: {
  shape: rectangle
  style: {
    fill: "#161b22"
    stroke: "#30363d"
    stroke-dash: 3
  }
  formula_title: {
    label: Key Formulas
    shape: text
    style: {
      font-size: 12
      bold: true
      underline: true
    }
  }
  f1: {
    label: "Arithmetic Intensity = FLOPs / Bytes Transferred"
    shape: text
    style: { font-size: 10 }
  }
  f2: {
    label: "Achievable GFLOPS = min(Peak Compute, AI × Peak BW)"
    shape: text
    style: { font-size: 10 }
  }
  f3: {
    label: "Ridge Point AI = Peak Compute / Peak BW"
    shape: text
    style: { font-size: 10 }
  }
}
# Hardware Specs Box
hw_specs: {
  shape: rectangle
  style: {
    fill: "#161b22"
    stroke: "#30363d"
    stroke-dash: 3
  }
  spec_title: {
    label: Reference Hardware
    shape: text
    style: {
      font-size: 12
      bold: true
      underline: true
    }
  }
  spec1: {
    label: "NVIDIA RTX 4090"
    shape: text
    style: { font-size: 10 }
  }
  spec2: {
    label: "Peak Compute: 9,700 GFLOPS (FP32)"
    shape: text
    style: { font-size: 10 }
  }
  spec3: {
    label: "Peak Memory BW: 900 GB/s"
    shape: text
    style: { font-size: 10 }
  }
  spec4: {
    label: "Ridge Point: AI ≈ 10.8 FLOPs/Byte"
    shape: text
    style: { font-size: 10 }
  }
}
# Connection relationships for layout
y_axis_label -> plot_area
x_axis_label -> plot_area
plot_area -> legend
formulas -> hw_specs