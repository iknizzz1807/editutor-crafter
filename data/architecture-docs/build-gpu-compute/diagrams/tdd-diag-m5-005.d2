direction: right
title: {
  label: CUDA Occupancy Calculator Flow\n\nAlgorithm Steps for Determining Active Warps per SM
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# Input Section
inputs: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  label: "INPUTS"
  threads_per_block: {
    shape: rectangle
    label: "threads_per_block\n(e.g., 256)"
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  registers_per_thread: {
    shape: rectangle
    label: "registers_per_thread\n(e.g., 32)"
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  shared_mem_per_block: {
    shape: rectangle
    label: "shared_mem_per_block\n(e.g., 2048 bytes)"
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
}
# Device Properties
device_props: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
  label: "DEVICE PROPERTIES\n(cudaDeviceProp)"
  max_threads_per_sm: {
    shape: rectangle
    label: "maxThreadsPerMultiProcessor\n(e.g., 2048)"
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  max_blocks_per_sm: {
    shape: rectangle
    label: "maxBlocksPerMultiProcessor\n(e.g., 32)"
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  regs_per_sm: {
    shape: rectangle
    label: "regsPerBlock or\nregsPerMultiprocessor\n(e.g., 65536)"
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  shared_mem_per_sm: {
    shape: rectangle
    label: "sharedMemPerBlock or\nsharedMemPerMultiprocessor\n(e.g., 65536 bytes)"
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  warp_size: {
    shape: rectangle
    label: "warpSize\n(e.g., 32)"
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
}
# Calculation Steps
calculations: {
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
  }
  label: "CALCULATE LIMITS"
  # Limit 1: Threads
  limit_threads: {
    shape: rectangle
    label: "LIMIT_THREADS\n\nblocks_limit_by_threads = \nfloor(maxThreadsPerSM /\nthreads_per_block)"
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
    }
  }
  # Limit 2: Registers
  limit_regs: {
    shape: rectangle
    label: "LIMIT_REGISTERS\n\nregs_per_block = \nceil(threads_per_block / warpSize)\n × regs_per_warp\n\nblocks_limit_by_regs = \nfloor(regsPerSM /\nregs_per_block)"
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
    }
  }
  # Limit 3: Shared Memory
  limit_smem: {
    shape: rectangle
    label: "LIMIT_SHARED_MEM\n\nblocks_limit_by_smem = \nfloor(sharedMemPerSM /\nshared_mem_per_block)"
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
    }
  }
  # Limit 4: Hardware Blocks
  limit_hw: {
    shape: rectangle
    label: "LIMIT_HARDWARE\n\nblocks_limit_by_hw = \nmaxBlocksPerMultiProcessor"
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
    }
  }
}
# Minimum Selection
min_selection: {
  shape: diamond
  label: "SELECT\nMINIMUM"
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
    stroke-width: 2
  }
}
# Result
result: {
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }
  label: "RESULT"
  active_blocks: {
    shape: rectangle
    label: "active_blocks_per_sm = \nmin(\n  blocks_limit_by_threads,\n  blocks_limit_by_regs,\n  blocks_limit_by_smem,\n  blocks_limit_by_hw\n)"
    style: {
      fill: "#E1BEE7"
      stroke: "#8E24AA"
    }
  }
  active_warps: {
    shape: rectangle
    label: "active_warps = \nactive_blocks_per_sm ×\nceil(threads_per_block / warpSize)"
    style: {
      fill: "#E1BEE7"
      stroke: "#8E24AA"
    }
  }
  occupancy_pct: {
    shape: rectangle
    label: "occupancy = \n(active_warps / maxWarpsPerSM)\n× 100%"
    style: {
      fill: "#E1BEE7"
      stroke: "#8E24AA"
    }
  }
  limiting_factor: {
    shape: rectangle
    label: "limiting_factor = \nwhich limit achieved\nthe minimum"
    style: {
      fill: "#E1BEE7"
      stroke: "#8E24AA"
    }
  }
}
# Output
output: {
  shape: rectangle
  label: "OUTPUT\n\noccupancy_pct: float\nlimiting_factor: enum\nactive_blocks: int\nactive_warps: int"
  style: {
    fill: "#FFEBEE"
    stroke: "#B71C1C"
    stroke-width: 2
  }
}
# Connections
inputs -> device_props: {
  label: "query device"
  style: {
    stroke-dash: 3
  }
}
device_props -> calculations: {
  label: "properties"
}
inputs -> calculations: {
  label: "kernel params"
}
calculations.limit_threads -> min_selection: {
  label: "limit_1"
}
calculations.limit_regs -> min_selection: {
  label: "limit_2"
}
calculations.limit_smem -> min_selection: {
  label: "limit_3"
}
calculations.limit_hw -> min_selection: {
  label: "limit_4"
}
min_selection -> result.active_blocks: {
  label: "minimum"
  style: {
    stroke-width: 3
    stroke: "#C2185B"
  }
}
result.active_blocks -> result.active_warps
result.active_warps -> result.occupancy_pct
result.active_blocks -> result.limiting_factor
result -> output: {
  style: {
    stroke-width: 2
  }
}
# Legend
legend: {
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-width: 1
  }
  label: "LEGEND"
  green_box: {
    shape: rectangle
    label: "User Inputs"
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  blue_box: {
    shape: rectangle
    label: "Device Properties"
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  orange_box: {
    shape: rectangle
    label: "Calculations"
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
    }
  }
  pink_box: {
    shape: rectangle
    label: "Results"
    style: {
      fill: "#E1BEE7"
      stroke: "#8E24AA"
    }
  }
}
# Example calculation box
example: {
  shape: rectangle
  style: {
    fill: "#ECEFF1"
    stroke: "#546E7A"
    stroke-width: 1
  }
  label: "EXAMPLE\n\nthreads_per_block = 256\nregisters_per_thread = 32\nshared_mem = 4096 bytes\n\nmaxThreadsPerSM = 2048\nregsPerSM = 65536\nsharedMemPerSM = 65536\nmaxBlocksPerSM = 32\n\nLimit by threads: 2048/256 = 8 blocks\nLimit by regs: 65536/(256×32) = 8 blocks\nLimit by smem: 65536/4096 = 16 blocks\nLimit by hw: 32 blocks\n\nMIN = 8 blocks\nactive_warps = 8 × 8 = 64 warps\noccupancy = 64/64 = 100%"
}