direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # GPU Performance Bottleneck Identification
  ## Decision Logic for Nsight Compute Analysis
| {
  near: top-center
  shape: text
  style: {
    font-size: 20
    bold: true
  }
}

# --- Style Classes ---
classes: {
  entry_point: {
    shape: oval
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  metric_collection: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      double-border: true
    }
  }
  decision_node: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
    }
  }
  terminal_state: {
    style: {
      stroke-width: 3
      shadow: true
      border-radius: 10
    }
  }
  note_box: {
    shape: sticky_note
    style: {
      font-size: 12
    }
  }
}

# --- Diagram Elements ---

start: Start Profiling {
  class: entry_point
  tooltip: "Initialize Nsight Compute Session"
}

collect_metrics: {
  class: metric_collection
  label: |md
    **COLLECT THROUGHPUT METRICS**
    ---
    • `sm__throughput.avg.pct_of_peak_sustained_elapsed`
    • `gpu__compute_memory_throughput.avg.pct_of_peak_sustained_elapsed`
    • `smsp__occupancy.avg.pct_of_peak_sustained_active`
  |
}

check_memory: Memory Throughput > 75%? {
  class: decision_node
}

memory_bound: {
  class: terminal_state
  style.fill: "#FFCDD2"
  label: |md
    ### 🛑 MEMORY-BOUND
    **Focus Areas:**
    1. **Coalescing:** Check `L1 Wavefronts`
    2. **Shared Memory:** Bank conflicts?
    3. **Access Patterns:** Avoid strided access
  |
}

check_compute: Compute Throughput > 75%? {
  class: decision_node
}

compute_bound: {
  class: terminal_state
  style.fill: "#C8E6C9"
  label: |md
    ### ⚡ COMPUTE-BOUND
    **Focus Areas:**
    1. **Arithmetic Intensity:** Increase FLOPs/Byte
    2. **Unrolling:** Use `#pragma unroll`
    3. **FMA Utilization:** Check FP32/FP64 pipes
  |
}

check_both_low: Both < 50%? {
  class: decision_node
}

latency_bound: {
  class: terminal_state
  style.fill: "#BBDEFB"
  label: |md
    ### ⏳ LATENCY-BOUND
    **Focus Areas:**
    1. **Occupancy:** Increase threads/blocks
    2. **Divergence:** Check Branch Efficiency
    3. **ILP:** Increase instructions per thread
  |
}

balanced: {
  class: terminal_state
  style.fill: "#E1BEE7"
  label: |md
    ### ⚖️ BALANCED
    **Focus Areas:**
    1. **Roofline Model:** Near Peak Performance
    2. **TDP Limits:** Check clock throttling
    3. **Kernel Overheads:** Constant memory/Launch latency
  |
}

# --- Connections ---

start -> collect_metrics: "nsys profile --stats=true" {
  style: {
    stroke-width: 2
    font-size: 14
  }
}

collect_metrics -> check_memory: "Analyze SOL (Speed of Light)"

check_memory -> memory_bound: "YES" {
  style: {
    stroke: red
    bold: true
    font-color: red
  }
}

check_memory -> check_compute: "NO" {
  style.stroke-dash: 3
}

check_compute -> compute_bound: "YES" {
  style: {
    stroke: green
    bold: true
    font-color: green
  }
}

check_compute -> check_both_low: "NO" {
  style.stroke-dash: 3
}

check_both_low -> latency_bound: "YES" {
  style: {
    stroke: blue
    bold: true
    font-color: blue
  }
}

check_both_low -> balanced: "NO (Mixed-Bound)" {
  style.stroke-dash: 3
}

# --- Technical Annotations ---
legend: {
  near: bottom-right
  title: "Performance Thresholds"
  t1: ">75%: Primary Bottleneck" { shape: text }
  t2: "<50%: Underutilization / Latency Issues" { shape: text }
  style: {
    stroke: gray
    fill: "#F5F5F5"
  }
}