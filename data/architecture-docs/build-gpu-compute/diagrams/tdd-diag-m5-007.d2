layout-engine: elk
theme-id: 6

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

classes: {
  state: {
    shape: rectangle
    style: {
      stroke: "#4A90D9"
      stroke-width: 2
      fill: "#E8F4FC"
      border-radius: 8
      shadow: true
    }
  }
  decision: {
    shape: diamond
    style: {
      stroke: "#F5A623"
      stroke-width: 2
      fill: "#FFF3CD"
    }
  }
  terminal: {
    shape: oval
    style: {
      stroke: "#7ED321"
      stroke-width: 2
      fill: "#E8F9E8"
    }
  }
  error_state: {
    shape: rectangle
    style: {
      stroke: "#D0021B"
      stroke-width: 2
      fill: "#FFE8EA"
      border-radius: 8
    }
  }
}

# Node Definitions
initial: "" {
  shape: circle
  style: {
    fill: "#333"
    stroke: "#333"
  }
  width: 20
  height: 20
}

measure: "Measure\n───\nProfile kernel execution\nCollect timing metrics" {
  class: state
  tools: "Nsight Systems\nNsight Compute\nCUDA Events"
}

analyze: "Analyze\n───\nIdentify bottleneck type\nCheck roofline position" {
  class: state
  checks: "Memory bandwidth\nCompute throughput\nLatency factors"
}

classify: "Classify\nBottleneck?" {
  class: decision
}

memory_bound: "Memory-Bound\nOptimization\n───\nCoalescing\nShared memory\nCache optimization" {
  class: state
}

compute_bound: "Compute-Bound\nOptimization\n───\nKernel fusion\nInstruction mix\nWarp-level primitives" {
  class: state
}

latency_bound: "Latency-Bound\nOptimization\n───\nOccupancy increase\nWarp scheduling\nInstruction-level parallelism" {
  class: state
}

verify: "Verify\n───\nRe-profile changes\nCompare metrics" {
  class: state
  check: "Improvement?\nBefore vs After"
}

improved: "Improved?" {
  class: decision
}

document: "Document\n───\nRecord changes\nLog before/after metrics\nUpdate baseline" {
  class: terminal
}

regression: "Regression\nDetected\n───\nRevert changes\nInvestigate cause" {
  class: error_state
}

thermal_throttle: "Thermal\nThrottle\n───\nCheck GPU temps\nReduce clock variance" {
  class: error_state
}

# Main Flow Transitions
initial -> measure: "Start optimization\ncycle"

measure -> analyze: "Profiling data\ncollected"

analyze -> classify: "Metrics analyzed"

classify -> memory_bound: "Memory\nbandwidth\nlimited"

classify -> compute_bound: "ALU\nutilization\nhigh"

classify -> latency_bound: "Low\noccupancy"

memory_bound -> verify: "Apply memory\noptimizations"

compute_bound -> verify: "Apply compute\noptimizations"

latency_bound -> verify: "Apply latency\noptimizations"

verify -> improved: "Re-profile\ncomplete"

improved -> document: "Yes\n≥5% gain" {
  style: {
    stroke: "#7ED321"
    stroke-width: 3
  }
}

improved -> regression: "No\n<0% perf" {
  style: {
    stroke: "#D0021B"
    stroke-width: 3
  }
}

improved -> analyze: "Partial\n0-5% gain" {
  style: {
    stroke: "#F5A623"
    stroke-dash: 4
  }
}

regression -> analyze: "Rollback &\ntry alternative" {
  style: {
    stroke: "#D0021B"
    stroke-dash: 4
  }
}

document -> measure: "Continue\ncycle" {
  style: {
    stroke: "#7ED321"
    stroke-dash: 4
  }
}

# Thermal throttle detection and handling
measure -> thermal_throttle: "Clock variance\n>5% detected" {
  style: {
    stroke: "#D0021B"
    stroke-width: 2
  }
}

thermal_throttle -> measure: "Cool down &\nadjust power" {
  style: {
    stroke: "#D0021B"
    stroke-dash: 4
  }
}

# Legend / Metadata
legend: {
  near: bottom-right
  title: "Optimization Status Keys" { shape: text }
  success: "Success (Significant Gain)" {
    style.fill: "#E8F9E8"
    style.stroke: "#7ED321"
  }
  warning: "Iteration (Marginal Gain)" {
    style.fill: "#FFF3CD"
    style.stroke: "#F5A623"
  }
  fail: "Critical / Regression" {
    style.fill: "#FFE8EA"
    style.stroke: "#D0021B"
  }
}