direction: down
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    pad: 40
    sketch: false
  }
}

# -----------------------------------------------------------------------------
# GLOBAL STYLES & CLASSES
# -----------------------------------------------------------------------------
classes: {
  metric_container: {
    style: {
      fill: "#FDFDFD"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  decision_node: {
    shape: diamond
    width: 160
    height: 120
    style: {
      font-size: 14
      bold: true
    }
  }
  status_red: {
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      font-color: "#C62828"
      bold: true
    }
  }
  status_yellow: {
    style: {
      fill: "#FFFDE7"
      stroke: "#FBC02D"
      font-color: "#827717"
      bold: true
    }
  }
  status_green: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      font-color: "#1B5E20"
      bold: true
    }
  }
}

# -----------------------------------------------------------------------------
# HEADER SECTION
# -----------------------------------------------------------------------------
header_container: {
  style: {
    stroke-width: 0
    fill: transparent
  }

  title: "GPU METRICS INTERPRETATION GUIDE" {
    shape: text
    style: {
      font-size: 36
      bold: true
      font-color: "#263238"
    }
  }

  subtitle: "NVIDIA Nsight Compute - Kernel Profiling Decision Matrix" {
    shape: text
    style: {
      font-size: 20
      italic: true
      font-color: "#546E7A"
    }
  }
}

# -----------------------------------------------------------------------------
# DIAGNOSTIC PIPELINE (Decision Flow)
# -----------------------------------------------------------------------------
pipeline: {
  label: "DIAGNOSTIC PIPELINE"
  style: {
    fill: "#ECEFF1"
    stroke: "#37474F"
    stroke-width: 2
    stroke-dash: 5
  }

  direction: right

  m_thru: "1. Memory\nThroughput %" {
    class: decision_node
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
  
  c_thru: "2. Compute\nThroughput %" {
    class: decision_node
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }

  warp_diag: "3. Warp\nStall Reasons" {
    class: decision_node
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }

  cache_util: "4. Cache\nEfficiency" {
    class: decision_node
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }

  m_thru -> c_thru: "Next"
  c_thru -> warp_diag: "Next"
  warp_diag -> cache_util: "Next"
}

# -----------------------------------------------------------------------------
# DETAILED ANALYTICS GRID
# -----------------------------------------------------------------------------
analytics_grid: {
  style.stroke-width: 0
  style.fill: transparent
  grid-columns: 2
  grid-gap: 50

  # --- Memory Throughput Detail ---
  memory_analysis: {
    class: metric_container
    label: "MEMORY THROUGHPUT ANALYSIS"
    style.stroke: "#1565C0"
    
    table: ||md
      | Metric Range | Classification | Optimization Action |
      | :--- | :--- | :--- |
      | **> 70%** | 🔴 Memory-Bound | Optimize coalescing, use Shared Mem |
      | **50% - 70%** | 🟡 Balanced | Profile warp latency, check occupancy |
      | **< 50%** | 🟢 Latency-Bound | Increase ILP, reduce sync overhead |
    ||
  }

  # --- Compute Throughput Detail ---
  compute_analysis: {
    class: metric_container
    label: "COMPUTE THROUGHPUT ANALYSIS"
    style.stroke: "#7B1FA2"

    table: ||md
      | Metric Range | Classification | Optimization Action |
      | :--- | :--- | :--- |
      | **> 70%** | 🔴 Compute-Bound | Optimize math operations, check FP32 units |
      | **50% - 70%** | 🟡 Balanced | Instruction mix review, check pipelines |
      | **< 50%** | 🟢 Not Bound | Look for memory/host transfer bottlenecks |
    ||
  }

  # --- Warp Stall Diagnosis ---
  warp_analysis: {
    class: metric_container
    label: "WARP STALL DIAGNOSIS"
    style.stroke: "#2E7D32"

    table: ||md
      | Stall Reason | Root Cause | Mitigation Strategy |
      | :--- | :--- | :--- |
      | **Mem Dep** | Global latency | Tiling, Shared Mem, Prefetch |
      | **Sync** | Barrier overhead | Reduce __syncthreads(), check divergence |
      | **Pipe Busy** | Unit saturation | Reduce math intensity, check SFU |
      | **Not Selected** | Readiness issues | Increase warps per SM (Occupancy) |
    ||
  }

  # --- Cache & Locality ---
  cache_analysis: {
    class: metric_container
    label: "L2 CACHE & LOCALITY"
    style.stroke: "#E65100"

    table: ||md
      | L2 Hit Rate | Status | Recommendation |
      | :--- | :--- | :--- |
      | **> 60%** | 🟢 Excellent | Maintain data reuse patterns |
      | **40% - 60%** | 🟡 Moderate | Evaluate working set size vs L2 capacity |
      | **< 40%** | 🔴 Poor | Restructure data layout (AoS to SoA) |
    ||
  }
}

# -----------------------------------------------------------------------------
# LEGEND & NOTES FOOTER
# -----------------------------------------------------------------------------
footer: {
  style.stroke-width: 0
  style.fill: transparent
  grid-columns: 2
  grid-gap: 50

  legend_box: {
    label: "Classification Legend"
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      stroke-dash: 3
    }
    
    red: "🔴 Critical: Primary bottleneck. High ROI for optimization." { shape: text }
    yellow: "🟡 Balanced: No clear limit. Secondary profiling required." { shape: text }
    green: "🟢 Optimized: Resource underutilized. Move to next metric." { shape: text }
  }

  pro_tips: {
    label: "Implementation Notes"
    style: {
      fill: "#FFFDE7"
      stroke: "#FBC02D"
    }
    content: |md
      1. **Occupancy vs Latency**: High occupancy is only useful if it hides latency.
      2. **Memory Coalescing**: Ensure 32-byte alignment for global accesses.
      3. **Shared Memory**: Watch out for bank conflicts (check `shared_load_transactions_per_request`).
    |
  }
}

# -----------------------------------------------------------------------------
# STRUCTURAL FLOW (Non-visual connections for layout)
# -----------------------------------------------------------------------------
header_container -> pipeline
pipeline -> analytics_grid
analytics_grid -> footer

(header_container -> pipeline).style.stroke-width: 0
(pipeline -> analytics_grid).style.stroke-width: 0
(analytics_grid -> footer).style.stroke-width: 0