vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
    pad: 20
  }
}

launch_overhead_detection: {
  shape: sequence_diagram
  
  Host: {
    label: "CPU (Host)"
    shape: rectangle
    style: {
      fill: "#1a1a2e"
      stroke: "#4a90d9"
      font-color: "#ffffff"
    }
  }
  
  GPU: {
    label: "GPU (Device)"
    shape: rectangle
    style: {
      fill: "#16213e"
      stroke: "#e94560"
      font-color: "#ffffff"
    }
  }

  Host -> GPU: cudaMalloc() {
    style.stroke: "#4a90d9"
  }
  
  Host -> GPU: kernel_1<<<>>>() {
    style: {
      stroke-dash: 3
      stroke: "#f39c12"
    }
  }
  
  Host -> GPU: kernel_2<<<>>>() {
    style: {
      stroke-dash: 3
      stroke: "#f39c12"
    }
  }
  
  Host -> GPU: kernel_3<<<>>>() {
    style: {
      stroke-dash: 3
      stroke: "#f39c12"
    }
  }
  
  Host -> GPU: cudaMemcpyAsync() {
    style.stroke: "#4a90d9"
  }
  
  Host -> Host: Driver overhead\n~8-10μs per launch {
    style: {
      stroke: "#e74c3c"
      font-color: "#e74c3c"
    }
  }

  overhead_annotation: {
    label: "⚠️ LAUNCH OVERHEAD DETECTED\n\nGap between launches (8-10μs) > Kernel execution (2-3μs)\n\nCPU-side overhead dominates!\n\nSolutions:\n• Batch small kernels\n• Use CUDA streams\n• Increase kernel work per launch"
    shape: rectangle
    style: {
      fill: "#2d1810"
      stroke: "#e74c3c"
      stroke-width: 2
      font-color: "#ffcc00"
      multiple: true
    }
  }

  timeline_view: {
    label: "Timeline View (Nsight Systems)\n\n|K1|────gap────|K2|────gap────|K3|\n 2μs    8μs    2μs    9μs   2μs\n\n    ▲              ▲\n    │              │\n Overhead      Overhead\n\nTotal kernel time: ~6μs\nTotal overhead: ~17μs"
    shape: rectangle
    style: {
      fill: "#1a1a2e"
      stroke: "#4a90d9"
      font: mono
      multiple: true
    }
  }

  # Performance metrics box
  metrics: {
    label: "Performance Impact\n\nKernel execution:  6μs (26%)\nLaunch overhead:  17μs (74%)\n─────────────────────\nTotal time:       23μs\n\nEfficiency: 26%\nOverhead cost: 2.8x kernel time"
    shape: rectangle
    style: {
      fill: "#0d2137"
      stroke: "#00bcd4"
      font: mono
      font-color: "#00bcd4"
    }
  }

  # Classification
  severity: {
    label: "CRITICAL\nLaunch Overhead Dominance"
    shape: diamond
    style: {
      fill: "#8b0000"
      stroke: "#ff4444"
      font-color: "#ffffff"
      bold: true
    }
  }

  Host -> timeline_view: {
    style: {
      stroke: "#4a90d9"
      opacity: 0.5
    }
  }

  GPU -> metrics: {
    style: {
      stroke: "#00bcd4"
      opacity: 0.5
    }
  }

  Host -> severity: "diagnosis" {
    style: {
      stroke: "#ff4444"
      stroke-dash: 5
      font-color: "#ff4444"
    }
  }
}