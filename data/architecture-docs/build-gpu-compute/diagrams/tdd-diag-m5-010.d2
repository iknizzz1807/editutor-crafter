vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # GPU Compute Programming Curriculum
  **Learning Path & Knowledge Dependencies**
| {near: top-center}
direction: right
style: {
  fill: "#F8F9FA"
  stroke: "#CBD6E0"
  border-radius: 12
}
m1: "Milestone 1\nCUDA Fundamentals & Memory" {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  concepts: |md
    **Core Concepts:**
    - GPU execution model
    - Host-device memory
    - Thread hierarchy
    - Kernel launch syntax
  |
  skills: |md
    **Skills:**
    - Memory allocation
    - Thread indexing
    - Error handling
  |
  output: |md
    **Outputs:**
    - Vector operations library
    - Basic kernel patterns
  |
}
m2: "Milestone 2\nMemory Optimization & Coalescing" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  concepts: |md
    **Core Concepts:**
    - Coalescing rules
    - Shared memory
    - Bank conflicts
    - Cache line behavior
  |
  skills: |md
    **Skills:**
    - Access pattern optimization
    - Tiling strategies
    - Barrier synchronization
  |
  output: |md
    **Outputs:**
    - Optimized transpose
    - Memory bandwidth analysis
  |
}
m3: "Milestone 3\nParallel Algorithms" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  concepts: |md
    **Core Concepts:**
    - Work vs step complexity
    - Work-efficient algorithms
    - Atomic contention
    - Warp shuffle
  |
  skills: |md
    **Skills:**
    - Reduction trees
    - Blelloch scan
    - Privatization patterns
  |
  output: |md
    **Outputs:**
    - Parallel primitives library
    - Reduction, scan, histogram
  |
}
m4: "Milestone 4\nStreams & Async Execution" {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  concepts: |md
    **Core Concepts:**
    - Stream serialization
    - Pinned memory
    - Compute-transfer overlap
    - Event timing
  |
  skills: |md
    **Skills:**
    - Stream management
    - Double-buffering
    - Async API usage
  |
  output: |md
    **Outputs:**
    - Streaming pipeline
    - Concurrent execution
  |
}
m5: "Milestone 5\nProfiling & Optimization" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  concepts: |md
    **Core Concepts:**
    - Roofline model
    - Occupancy analysis
    - Bottleneck classification
    - Performance counters
  |
  skills: |md
    **Skills:**
    - Nsight tools
    - Metric interpretation
    - Optimization methodology
  |
  output: |md
    **Outputs:**
    - Optimization reports
    - Performance analysis
  |
}
m1 -> m2: "Provides:\n• Kernel fundamentals\n• Memory management\n• Thread indexing" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.animated: true
}
m1 -> m3: "Provides:\n• Shared memory basics\n• Thread cooperation" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.stroke-dash: 3
}
m2 -> m3: "Provides:\n• Coalescing knowledge\n• Shared memory mastery\n• Bank conflict avoidance" {
  style.stroke: "#FF9800"
  style.stroke-width: 3
  style.animated: true
}
m1 -> m4: "Provides:\n• Async kernel launch\n• Stream basics" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.stroke-dash: 3
}
m2 -> m4: "Provides:\n• Memory bandwidth concepts\n• Access patterns" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.stroke-dash: 3
}
m3 -> m4: "Provides:\n• Kernel patterns\n• Optimization techniques" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.stroke-dash: 3
}
m1 -> m5: "Provides:\n• Basic kernels to profile\n• Memory patterns" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.stroke-dash: 3
}
m2 -> m5: "Provides:\n• Coalescing metrics\n• Memory optimization" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.stroke-dash: 3
}
m3 -> m5: "Provides:\n• Algorithm benchmarks\n• Throughput targets" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.stroke-dash: 3
}
m4 -> m5: "Provides:\n• Stream profiling\n• Overlap analysis" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  style.stroke-dash: 3
}
tools: "Development Tools" {
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  nvcc: "NVCC Compiler"
  nsight_systems: "Nsight Systems\n(Timeline)"
  nsight_compute: "Nsight Compute\n(Detailed)"
  events: "CUDA Events\n(Timing)"
}
tools.nvcc -> m1
tools.events -> m1
tools.events -> m2
tools.events -> m3
tools.events -> m4
tools.nsight_systems -> m5
tools.nsight_compute -> m5
legend: |md
  **Arrow Types:**
  - **Solid**: Primary dependency (must complete first)
  - **Dashed**: Secondary dependency (knowledge transfer)
  - **Animated**: Critical learning path
| {near: bottom-center}