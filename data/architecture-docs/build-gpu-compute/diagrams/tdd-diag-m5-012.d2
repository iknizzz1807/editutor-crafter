direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: {
  label: "Memory vs Compute Bound Region Map\nArithmetic Intensity Classification"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# Axis definitions for logical positioning
x_axis: {
  label: "Arithmetic Intensity (FLOPs/Byte)"
  shape: text
  style.italic: true
}

y_axis: {
  label: "Attainable Performance (GFLOPS/s)"
  shape: text
  style.italic: true
}

# Memory Bound Region (< 10 FLOP/byte)
# Highlighting the bandwidth bottleneck zone
memory_bound: {
  label: "Memory-Bound Region\n< 10 FLOPs/Byte"
  shape: rectangle
  style: {
    fill: "#E74C3C"
    opacity: 0.3
    stroke: "#C0392B"
    stroke-width: 3
  }
  
  mem_char_1: {
    label: "• Data movement dominates\n• Bandwidth-limited\n• Low computational reuse"
    shape: text
    style: {
      font-size: 12
      fill: transparent
    }
  }
  
  mem_examples: {
    label: "Examples:\n- Vector copy (0 FLOP/B)\n- SAXPY (0.25 FLOP/B)\n- Sparse matrix ops"
    shape: text
    style: {
      font-size: 11
      italic: true
      fill: transparent
    }
  }
}

# Transition Zone (10-50 FLOP/byte)
# The "Ridge" point area of the Roofline model
transition_zone: {
  label: "Transition Zone\n10-50 FLOPs/Byte"
  shape: rectangle
  style: {
    fill: "#F39C12"
    opacity: 0.3
    stroke: "#D68910"
    stroke-width: 3
  }
  
  trans_char: {
    label: "• Mixed characteristics\n• Architecture-dependent\n• Optimize both paths"
    shape: text
    style: {
      font-size: 12
      fill: transparent
    }
  }
  
  trans_examples: {
    label: "Examples:\n- Dense matrix multiply\n- Some convolutions\n- FFT variants"
    shape: text
    style: {
      font-size: 11
      italic: true
      fill: transparent
    }
  }
}

# Compute Bound Region (> 50 FLOP/byte)
# Highlighting the compute throughput bottleneck zone
compute_bound: {
  label: "Compute-Bound Region\n> 50 FLOPs/Byte"
  shape: rectangle
  style: {
    fill: "#27AE60"
    opacity: 0.3
    stroke: "#1E8449"
    stroke-width: 3
  }
  
  comp_char: {
    label: "• Computation dominates\n• Throughput-limited\n• High data reuse"
    shape: text
    style: {
      font-size: 12
      fill: transparent
    }
  }
  
  comp_examples: {
    label: "Examples:\n- Matrix multiply (256+ FLOP/B)\n- Dense convolutions\n- N-body simulations"
    shape: text
    style: {
      font-size: 11
      italic: true
      fill: transparent
    }
  }
}

# Threshold markers - Structural logic points
threshold_10: {
  label: "10 FLOPs/Byte\nMemory Threshold"
  shape: diamond
  style: {
    fill: "#C0392B"
    stroke: "#922B21"
    font-color: white
  }
}

threshold_50: {
  label: "50 FLOPs/Byte\nCompute Threshold"
  shape: diamond
  style: {
    fill: "#1E8449"
    stroke: "#145A32"
    font-color: white
  }
}

# Roofline curve visual markers
roofline_slope: {
  label: "Memory\nCeiling"
  shape: text
  style: {
    bold: true
    fill: transparent
  }
}

roofline_flat: {
  label: "Compute\nCeiling"
  shape: text
  style: {
    bold: true
    fill: transparent
  }
}

# Optimization strategies panel
optimization_panel: {
  label: "Optimization Strategies"
  shape: rectangle
  style.stroke-dash: 5
  
  mem_opt: {
    label: "Memory-Bound Optimizations:\n• Coalesced memory access\n• Shared memory caching\n• Memory access patterns\n• Minimize data transfers"
    shape: text
    style.font-size: 11
  }
  
  comp_opt: {
    label: "Compute-Bound Optimizations:\n• Increase parallelism\n• Instruction-level parallelism\n• Reduce register pressure\n• Loop unrolling"
    shape: text
    style.font-size: 11
  }
}

# Formula reference box
formula_box: {
  label: "Arithmetic Intensity = FLOPs / Bytes Transferred"
  shape: code
  style: {
    fill: "#2C3E50"
    font-color: "#ECF0F1"
  }
}

# Logical and Data Flow Connections
memory_bound -> transition_zone: "Increasing Intensity" {
  style: {
    stroke: "#8E44AD"
    stroke-width: 2
  }
}

transition_zone -> compute_bound: "Increasing Intensity" {
  style: {
    stroke: "#8E44AD"
    stroke-width: 2
  }
}

threshold_10 -> memory_bound: "defines boundary" {
  style.stroke-dash: 3
}

threshold_50 -> compute_bound: "defines boundary" {
  style.stroke-dash: 3
}

memory_bound -> optimization_panel.mem_opt: "apply" {
  style: {
    stroke: "#E74C3C"
    stroke-dash: 4
  }
}

compute_bound -> optimization_panel.comp_opt: "apply" {
  style: {
    stroke: "#27AE60"
    stroke-dash: 4
  }
}

formula_box -> memory_bound: "calculates" {
  style: {
    stroke: "#34495E"
    stroke-dash: 2
  }
}

formula_box -> compute_bound: "calculates" {
  style: {
    stroke: "#34495E"
    stroke-dash: 2
  }
}

# Legend for Engineer reference
legend: {
  label: "Classification Guide"
  shape: rectangle
  near: bottom-right
  style.stroke: "#7F8C8D"
  
  certainty_high: {
    label: "■ < 10 FLOP/B: Almost certainly memory-bound"
    shape: text
    style: {
      font-size: 11
      fill: transparent
    }
  }
  
  certainty_mid: {
    label: "■ 10-50 FLOP/B: Architecture-dependent"
    shape: text
    style: {
      font-size: 11
      fill: transparent
    }
  }
  
  certainty_low: {
    label: "■ > 50 FLOP/B: Likely compute-bound"
    shape: text
    style: {
      font-size: 11
      fill: transparent
    }
  }
}