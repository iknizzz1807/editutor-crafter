direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    active: "#4ade80"
    memory: "#f97316"
    eligible: "#3b82f6"
    exec: "#a855f7"
    sync: "#ec4899"
    dark_bg: "#1a1a2e"
  }
}

title: {
  label: "Warp State Statistics Interpretation\n(Performance Profiler Manual View)"
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND SECTION - Visual representation of warp occupancy
# -----------------------------------------------------------------------------------------
legend: {
  label: "Warp State Distribution Metrics"
  style: {
    stroke-width: 2
    fill: "#f8fafc"
  }
  
  active_row: {
    direction: right
    indicator: "" {
      width: 24; height: 24
      style: { fill: ${colors.active}; stroke: "#166534" }
    }
    bar: "Active: 23%" {
      shape: rectangle
      width: 115; height: 24
      style: { fill: ${colors.active}; font-color: ${colors.dark_bg}; bold: true }
    }
  }
  
  stalled_mem_row: {
    direction: right
    indicator: "" {
      width: 24; height: 24
      style: { fill: ${colors.memory}; stroke: "#9a3412" }
    }
    bar: "Stalled-Memory: 42%" {
      shape: rectangle
      width: 210; height: 24
      style: { fill: ${colors.memory}; font-color: ${colors.dark_bg}; bold: true }
    }
  }
  
  eligible_row: {
    direction: right
    indicator: "" {
      width: 24; height: 24
      style: { fill: ${colors.eligible}; stroke: "#1e40af" }
    }
    bar: "Eligible: 31%" {
      shape: rectangle
      width: 155; height: 24
      style: { fill: ${colors.eligible}; font-color: ${colors.dark_bg}; bold: true }
    }
  }
  
  stalled_exec_row: {
    direction: right
    indicator: "" {
      width: 24; height: 24
      style: { fill: ${colors.exec}; stroke: "#6b21a8" }
    }
    bar: "Stalled-Exec: 3%" {
      shape: rectangle
      width: 40; height: 24
      style: { fill: ${colors.exec}; font-color: ${colors.dark_bg}; bold: true }
    }
  }
  
  stalled_sync_row: {
    direction: right
    indicator: "" {
      width: 24; height: 24
      style: { fill: ${colors.sync}; stroke: "#9d174d" }
    }
    bar: "Stalled-Sync: 1%" {
      shape: rectangle
      width: 30; height: 24
      style: { fill: ${colors.sync}; font-color: ${colors.dark_bg}; bold: true }
    }
  }
}

# -----------------------------------------------------------------------------------------
# INTERPRETATION SECTION - Deep technical breakdown for engineers
# -----------------------------------------------------------------------------------------
interpretations: {
  label: "Bottleneck Analysis & Invariants"
  style.fill: "#f1f5f9"

  active_interp: {
    shape: rectangle
    label: |md
      ### ACTIVE (23%)
      Warps currently issuing instructions to execution units.
      - **Target Range**: 20% - 40%
      - **Diagnosis**: Normal utilization. Current ILP is sufficient.
    |
    style: { fill: "#f0fdf4"; stroke: ${colors.active}; stroke-width: 2; multiple: true }
  }

  memory_interp: {
    shape: rectangle
    label: |md
      ### STALLED-MEMORY (42%)
      **CRITICAL THRESHOLD EXCEEDED (>30%)**
      Warps blocked on `LD/ST` operations (Global/Local/Texture).
      - **Check**: Coalescing efficiency, L2 cache hit rate.
      - **Action**: Optimize memory access patterns (Avoid Bank Conflicts).
    |
    style: { fill: "#fff7ed"; stroke: ${colors.memory}; stroke-width: 4; multiple: true }
  }

  eligible_interp: {
    shape: rectangle
    label: |md
      ### ELIGIBLE (31%)
      Warps ready to execute but waiting for the Warp Scheduler.
      - **Insight**: Indicates sufficient Thread Level Parallelism.
      - **Saturation**: High eligible + low active = scheduler contention.
    |
    style: { fill: "#eff6ff"; stroke: ${colors.eligible}; stroke-width: 2; multiple: true }
  }

  exec_interp: {
    shape: rectangle
    label: |md
      ### STALLED-EXEC (3%)
      Wait for execution pipeline (FP32, FP64, INT, Tensor).
      - **Acceptable**: < 10%.
      - **Cause**: High latency instructions or structural hazards.
    |
    style: { fill: "#faf5ff"; stroke: ${colors.exec}; stroke-width: 2; multiple: true }
  }
}

# -----------------------------------------------------------------------------------------
# DIAGNOSIS SECTION - Final implementation directives
# -----------------------------------------------------------------------------------------
diagnosis: {
  label: "Primary Diagnosis: MEMORY-LATENCY LIMITED"
  style: { stroke: "#dc2626"; stroke-width: 3; fill: "#fef2f2" }

  evidence: {
    shape: rectangle
    label: "**Evidence Matrix**\n- Memory Stalls: 42%\n- Active cycles: 23%\n- Memory:Exec Ratio: 14:1"
    style: { fill: "#ffffff"; stroke: "#dc2626"; multiple: true }
  }

  optimization_plan: {
    shape: rectangle
    label: |md
      **Optimization Directives**
      1. **Global Memory**: Align accesses to 128B cache lines.
      2. **Shared Memory**: Use for temporal data reuse to bypass DRAM.
      3. **Occupancy**: Evaluate if higher occupancy hides latency.
    |
    style: { fill: "#ffffff"; stroke: "#16a34a"; multiple: true }
  }

  metrics_table: {
    shape: sql_table
    label: "Key Profiler Metrics to Query"
    dram_throughput: "dram__throughput.avg.pct_of_peak_sustained_elapsed"
    l2_hit_rate: "lts__t_sector_hit_rate.pct"
    sm_efficiency: "sm__throughput.avg.pct_of_peak_sustained_elapsed"
  }
}

# Mapping relationships between metrics and diagnostics
legend.stalled_mem_row -> interpretations.memory_interp: "Triggers Alert"
interpretations.memory_interp -> diagnosis.evidence: "Diagnostic Source"
diagnosis.evidence -> diagnosis.optimization_plan: "Actionable Path"