direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: Occupancy vs Performance Curve {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Main concept containers
concept_grid: {
  shape: rectangle
  style.fill: "#0D1117"
  # Axis definitions
  x_axis: {
    shape: rectangle
    label: "Occupancy (% of Maximum Warps)\n[Metric: active_warps / max_warps]"
    style: {
      fill: "#161B22"
      stroke: "#30363D"
      font-size: 14
      bold: true
      font-color: "#8B949E"
    }
  }
  y_axis: {
    shape: rectangle
    label: "Performance (GFLOPS / GB/s)\n[Metric: achieved_throughput]"
    style: {
      fill: "#161B22"
      stroke: "#30363D"
      font-size: 14
      bold: true
      font-color: "#8B949E"
    }
  }
}

# Kernel type zones
memory_bound_zone: {
  label: Memory-Bound Kernels
  shape: rectangle
  style: {
    fill: "#1C2526"
    stroke: "#F85149"
    stroke-dash: 3
    border-radius: 8
  }
  peak_region: {
    label: "Peak Performance\n50-75% Occupancy"
    shape: oval
    style: {
      fill: "#238636"
      stroke: "#3FB950"
      font-size: 12
      bold: true
    }
  }
  latency_hiding: {
    label: "Optimal Latency Hiding"
    shape: rectangle
    style: {
      fill: "#21262D"
      stroke: "#8B949E"
      font-size: 11
    }
  }
  oversubscription: {
    label: "Resource Contention\n(Cache/Shared Mem)"
    shape: rectangle
    style: {
      fill: "#21262D"
      stroke: "#F85149"
      font-size: 11
    }
  }
  peak_region -> latency_hiding: "Achieved by" {
    style.stroke: "#3FB950"
  }
  oversubscription -> peak_region: "Degrades beyond" {
    style.stroke: "#F85149"
    style.stroke-dash: 3
  }
}

compute_bound_zone: {
  label: Compute-Bound Kernels
  shape: rectangle
  style: {
    fill: "#1C2526"
    stroke: "#58A6FF"
    stroke-dash: 3
    border-radius: 8
  }
  scaling_region: {
    label: "Performance Scales\nwith Occupancy"
    shape: parallelogram
    style: {
      fill: "#0D419D"
      stroke: "#58A6FF"
      font-size: 12
      bold: true
    }
  }
  alu_saturation: {
    label: "ALU Utilization\nMaximizes"
    shape: rectangle
    style: {
      fill: "#21262D"
      stroke: "#58A6FF"
      font-size: 11
    }
  }
  high_occupancy: {
    label: "High Occupancy\nBeneficial"
    shape: rectangle
    style: {
      fill: "#21262D"
      stroke: "#3FB950"
      font-size: 11
    }
  }
  scaling_region -> alu_saturation: "Requires" {
    style.stroke: "#58A6FF"
  }
  alu_saturation -> high_occupancy: "Achieved at" {
    style.stroke: "#3FB950"
  }
}

# Curve data points
curve_memory_bound: {
  label: "Memory-Bound Curve"
  shape: sequence_diagram
  pt_0: {
    label: "0%"
    shape: circle
    style.fill: "#F85149"
  }
  pt_25: {
    label: "25%"
    shape: circle
    style.fill: "#D29922"
  }
  pt_50: {
    label: "50%\n(NEAR PEAK)"
    shape: circle
    style.fill: "#238636"
  }
  pt_75: {
    label: "75%\n(PEAK ZONE)"
    shape: circle
    style.fill: "#238636"
  }
  pt_100: {
    label: "100%\n(Degrades)"
    shape: circle
    style.fill: "#F85149"
  }
  pt_0 -> pt_25: "Rising" {style.stroke: "#D29922"}
  pt_25 -> pt_50: "Steep Rise" {style.stroke: "#3FB950"}
  pt_50 -> pt_75: "Plateau" {style.stroke: "#238636"}
  pt_75 -> pt_100: "Decline" {style.stroke: "#F85149"}
}

curve_compute_bound: {
  label: "Compute-Bound Curve"
  shape: sequence_diagram
  cpt_0: {
    label: "0%"
    shape: circle
    style.fill: "#F85149"
  }
  cpt_25: {
    label: "25%"
    shape: circle
    style.fill: "#D29922"
  }
  cpt_50: {
    label: "50%"
    shape: circle
    style.fill: "#D29922"
  }
  cpt_75: {
    label: "75%"
    shape: circle
    style.fill: "#58A6FF"
  }
  cpt_100: {
    label: "100%\n(OPTIMAL)"
    shape: circle
    style.fill: "#238636"
  }
  cpt_0 -> cpt_25: "Linear" {style.stroke: "#58A6FF"}
  cpt_25 -> cpt_50: "Linear" {style.stroke: "#58A6FF"}
  cpt_50 -> cpt_75: "Linear" {style.stroke: "#58A6FF"}
  cpt_75 -> cpt_100: "Linear" {style.stroke: "#3FB950"}
}

# Performance flow
performance_flow: {
  label: "Performance Analysis Flow"
  shape: rectangle
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    border-radius: 8
  }
  kernel_start: {
    label: "Kernel Launch"
    shape: oval
    style: {
      fill: "#21262D"
      stroke: "#8B949E"
    }
  }
  classify: {
    label: "Classify Kernel Type\n(Memory vs Compute Bound)"
    shape: diamond
    style: {
      fill: "#21262D"
      stroke: "#D29922"
    }
  }
  mem_path: {
    label: "Memory-Bound Path"
    shape: rectangle
    style: {
      fill: "#2D1B1B"
      stroke: "#F85149"
    }
  }
  comp_path: {
    label: "Compute-Bound Path"
    shape: rectangle
    style: {
      fill: "#1B2D2D"
      stroke: "#58A6FF"
    }
  }
  mem_optimize: {
    label: "Optimize for\n50-75% Occupancy\nReduce Register Pressure\nIncrease Shared Memory"
    shape: rectangle
    style: {
      fill: "#21262D"
      stroke: "#F85149"
      font-size: 11
    }
  }
  comp_optimize: {
    label: "Optimize for\nHigh Occupancy\nMaximize Thread Count\nBalance ILP"
    shape: rectangle
    style: {
      fill: "#21262D"
      stroke: "#58A6FF"
      font-size: 11
    }
  }
  profile: {
    label: "Profile with\nNsight Compute"
    shape: rectangle
    style: {
      fill: "#21262D"
      stroke: "#8B949E"
    }
  }
  kernel_start -> classify
  classify -> mem_path: "Memory\nBound" {style.stroke: "#F85149"}
  classify -> comp_path: "Compute\nBound" {style.stroke: "#58A6FF"}
  mem_path -> mem_optimize
  comp_path -> comp_optimize
  mem_optimize -> profile
  comp_optimize -> profile
}

# Key insight callout
key_insight: {
  label: |md
    ## ⚠️ Counterintuitive Principle
    **100% Occupancy ≠ Maximum Performance**
    For memory-bound kernels:
    - Excess warps compete for cache bandwidth
    - Shared memory limits active blocks
    - Register pressure reduces parallelism
    Sweet spot: **50-75% occupancy**
    provides sufficient latency hiding
    while preserving cache efficiency
  |
  shape: text
  style: {
    fill: "#161B22"
    stroke: "#D29922"
    border-radius: 8
    font-size: 12
    font-color: "#E6EDF3"
  }
}

# Legend
legend: {
  label: "Curve Legend"
  shape: rectangle
  grid-columns: 1
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    border-radius: 4
  }
  mem_curve: {
    label: "━ Memory-Bound (Peak 50-75%)"
    shape: text
    style: {
      font-color: "#F85149"
      font-size: 11
    }
  }
  comp_curve: {
    label: "━ Compute-Bound (Peak 100%)"
    shape: text
    style: {
      font-color: "#58A6FF"
      font-size: 11
    }
  }
  peak_zone: {
    label: "● Peak Performance Zone"
    shape: text
    style: {
      font-color: "#238636"
      font-size: 11
    }
  }
  degrade_zone: {
    label: "● Performance Degradation"
    shape: text
    style: {
      font-color: "#F85149"
      font-size: 11
    }
  }
}

# Occupancy metrics table
occupancy_metrics: {
  label: "Occupancy Calculation"
  shape: sql_table
  active_warps: "INT [0..2048]" {
    constraint: primary_key
  }
  max_warps: "INT [Physical Limit]"
  occupancy_pct: "FLOAT [0..1.0]"
  status: "ENUM [Optimal, Suboptimal, Contention]"
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    font-size: 10
  }
}

# Connections
concept_grid -> performance_flow: "Analysis\nWorkflow" {
  style.stroke: "#8B949E"
  style.stroke-dash: 3
}
memory_bound_zone -> curve_memory_bound: "Exhibits" {
  style.stroke: "#F85149"
}
compute_bound_zone -> curve_compute_bound: "Exhibits" {
  style.stroke: "#58A6FF"
}
key_insight -> memory_bound_zone: "Explains" {
  style.stroke: "#D29922"
  style.stroke-dash: 2
}
legend -> concept_grid: "Reference" {
  style.stroke: "#30363D"
  style.stroke-dash: 2
}
occupancy_metrics -> performance_flow: "Inputs" {
  style.stroke: "#8B949E"
}

# Root level connection showing relationship
memory_bound_zone <-> compute_bound_zone: "Different Optimization\nStrategies" {
  style.stroke: "#D29922"
  style.stroke-dash: 4
}