direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # System V AMD64 ABI Register Classification
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arg_regs: {
    direction: down
    label: "Integer Arguments (Caller-Saved)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2
    arg1: {
      shape: sql_table
      label: "rdi (arg1)"
      f0: "0x00 | int/ptr | 1st integer arg"
      note: "Caller-saved: clobbered by calls"
    }
    arg2: {
      shape: sql_table
      label: "rsi (arg2)"
      f0: "0x00 | int/ptr | 2nd integer arg"
    }
    arg3: {
      shape: sql_table
      label: "rdx (arg3)"
      f0: "0x00 | int/ptr | 3rd integer arg"
      note: "Also: div high bits, 3rd arg"
    }
    arg4: {
      shape: sql_table
      label: "rcx (arg4)"
      f0: "0x00 | int/ptr | 4th integer arg"
    }
    arg5: {
      shape: sql_table
      label: "r8 (arg5)"
      f0: "0x00 | int/ptr | 5th integer arg"
    }
    arg6: {
      shape: sql_table
      label: "r9 (arg6)"
      f0: "0x00 | int/ptr | 6th integer arg"
      last: "Args 7+ passed on stack"
    }
  }
  temp_regs: {
    direction: down
    label: "Caller-Saved Temporaries"
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
    style.stroke-width: 2
    rax_reg: {
      shape: sql_table
      label: "rax (return/accumulator)"
      f0: "0x00 | int/ptr | Return value"
      f1: "0x08 | int/ptr | Caller-saved temp"
      note: "Clobbered by div, syscall ret"
    }
    r10_reg: {
      shape: sql_table
      label: "r10 (temporary)"
      f0: "0x00 | int/ptr | Caller-saved"
      note: "Used for syscall number"
    }
    r11_reg: {
      shape: sql_table
      label: "r11 (temporary)"
      f0: "0x00 | int/ptr | Caller-saved"
      note: "Clobbered by PLT stubs"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  callee_saved: {
    direction: down
    label: "Callee-Saved (Preserved)"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
    rbx_reg: {
      shape: sql_table
      label: "rbx (preserved)"
      f0: "0x00 | int/ptr | Callee-saved"
      note: "MUST save/restore if used"
    }
    rbp_reg: {
      shape: sql_table
      label: "rbp (frame pointer)"
      f0: "0x00 | int/ptr | Callee-saved"
      note: "Typically: frame pointer base"
    }
    r12_reg: {
      shape: sql_table
      label: "r12 (preserved)"
      f0: "0x00 | int/ptr | Callee-saved"
    }
    r13_reg: {
      shape: sql_table
      label: "r13 (preserved)"
      f0: "0x00 | int/ptr | Callee-saved"
    }
    r14_reg: {
      shape: sql_table
      label: "r14 (preserved)"
      f0: "0x00 | int/ptr | Callee-saved"
    }
    r15_reg: {
      shape: sql_table
      label: "r15 (preserved)"
      f0: "0x00 | int/ptr | Callee-saved"
      last: "Safe across calls if saved"
    }
  }
  special_regs: {
    direction: down
    label: "Special Purpose"
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    style.stroke-width: 2
    rsp_reg: {
      shape: sql_table
      label: "rsp (stack pointer)"
      f0: "0x00 | int/ptr | Stack pointer"
      note: "MUST restore before ret"
    }
    notes: {
      label: "JIT Usage Rules"
      notes: |md
        **Caller-saved**: Free to use, but
        save before `call` if value needed
        **Callee-saved**: Use freely, but
        `push` in prologue, `pop` in epilogue
        **Never allocate**: rsp, rbp
      |
    }
  }
}
row1 -> row2: "ABI Compliance"