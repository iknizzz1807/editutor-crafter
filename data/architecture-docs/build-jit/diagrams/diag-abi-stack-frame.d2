direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # System V AMD64 ABI Stack Frame Layout
| {near: top-center}
frame_container: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  frame: "Stack Frame (callee's view)" {
    direction: down
    style.fill: "#F8F9FA"
    style.stroke: "#495057"
    style.stroke-width: 2
    width: 480
    header: "Address Range | Contents | Notes" {
      shape: sql_table
      style.fill: "#E9ECEF"
      style.stroke: "#495057"
      width: 460
      label: "Stack Frame Layout"
    }
    high_addr: "Higher Addresses" {
      width: 460
      style.fill: transparent
      style.stroke: transparent
      label.near: outside-right-center
    }
    caller_frame: "[caller's frame]" {
      width: 460
      style.fill: "#DEE2E6"
      style.stroke: "#6C757D"
      style.stroke-dash: 3
      label: "Caller's Stack Frame (varies)"
    }
    ret_addr: "rbp+8 | Return Address | pushed by CALL" {
      width: 460
      style.fill: "#FFC9C9"
      style.stroke: "#C92A2A"
    }
    saved_rbp: "rbp+0 | Saved RBP | push rbp" {
      width: 460
      style.fill: "#B2F2BB"
      style.stroke: "#2B8A3E"
    }
    callee_saved: "rbp-8  | Saved RBX  | callee-saved" {
      width: 460
      style.fill: "#D0BFFF"
      style.stroke: "#5F3DC4"
    }
    callee_r12: "rbp-16 | Saved R12  | callee-saved" {
      width: 460
      style.fill: "#D0BFFF"
      style.stroke: "#5F3DC4"
    }
    callee_r13: "rbp-24 | Saved R13  | callee-saved" {
      width: 460
      style.fill: "#D0BFFF"
      style.stroke: "#5F3DC4"
    }
    callee_r14: "rbp-32 | Saved R14  | callee-saved" {
      width: 460
      style.fill: "#D0BFFF"
      style.stroke: "#5F3DC4"
    }
    callee_r15: "rbp-40 | Saved R15  | callee-saved" {
      width: 460
      style.fill: "#D0BFFF"
      style.stroke: "#5F3DC4"
    }
    local_var1: "rbp-48 | Local Var 0| int64_t x" {
      width: 460
      style.fill: "#A5D8FF"
      style.stroke: "#1971C2"
    }
    local_var2: "rbp-56 | Local Var 1| int64_t y" {
      width: 460
      style.fill: "#A5D8FF"
      style.stroke: "#1971C2"
    }
    local_var3: "rbp-64 | Local Var 2| char buf[16]" {
      width: 460
      style.fill: "#A5D8FF"
      style.stroke: "#1971C2"
    }
    padding: "rbp-72 | Padding     | alignment" {
      width: 460
      style.fill: "#FFE8CC"
      style.stroke: "#E8590C"
      style.stroke-dash: 2
    }
    outgoing_7: "rbp-80 | Out Arg 7   | 7th arg (stack)" {
      width: 460
      style.fill: "#FFF3BF"
      style.stroke: "#F08C00"
    }
    outgoing_8: "rbp-88 | Out Arg 8   | 8th arg (stack)" {
      width: 460
      style.fill: "#FFF3BF"
      style.stroke: "#F08C00"
    }
    rsp_mark: "rsp →  | (16-byte aligned)" {
      width: 460
      style.fill: "#FF8787"
      style.stroke: "#C92A2A"
      style.bold: true
    }
    low_addr: "Lower Addresses" {
      width: 460
      style.fill: transparent
      style.stroke: transparent
      label.near: outside-right-center
    }
  }
  info_panel: "" {
    direction: down
    width: 400
    style.fill: transparent
    style.stroke: transparent
    alignment_box: "16-Byte Alignment Rules" {
      width: 380
      style.fill: "#FFF4E6"
      style.stroke: "#E8590C"
      style.border-radius: 8
      rule1: |md
        **Before CALL**: `rsp % 16 == 0`
        **After CALL**: `rsp % 16 == 8`
        (return address pushed)
        **After `push rbp`**: `rsp % 16 == 0`
        **After N pushes**: 
        - N even → aligned
        - N odd → add 8-byte padding
      |
    }
    reg_roles: "Register Roles (callee view)" {
      shape: class
      label: "Register Classification"
      style.fill: "#F8F9FA"
      +rdi: "arg 1 (caller-saved)"
      +rsi: "arg 2 (caller-saved)"
      +rdx: "arg 3 (caller-saved)"
      +rcx: "arg 4 (caller-saved)"
      +r8: "arg 5 (caller-saved)"
      +r9: "arg 6 (caller-saved)"
      +rax: "return val (caller-saved)"
      -rbx: "callee-saved"
      -r12: "callee-saved"
      -r13: "callee-saved"
      -r14: "callee-saved"
      -r15: "callee-saved"
      +rsp: "stack ptr (preserve)"
      +rbp: "frame ptr (preserve)"
    }
    stack_args: "Stack Arguments (args 7+)" {
      width: 380
      style.fill: "#E7F5FF"
      style.stroke: "#1971C2"
      style.border-radius: 8
      arg_info: |md
        Arguments 1-6: passed in registers
        (rdi, rsi, rdx, rcx, r8, r9)
        Arguments 7+: pushed **right-to-left**
        - Arg 7 at `rbp + 16`
        - Arg 8 at `rbp + 24`
        Caller cleans up stack args.
      |
    }
  }
}
legend: "Color Legend" {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  red_box: "Return Addr" {
    style.fill: "#FFC9C9"
    style.stroke: "#C92A2A"
    width: 100
  }
  green_box: "Saved RBP" {
    style.fill: "#B2F2BB"
    style.stroke: "#2B8A3E"
    width: 100
  }
  purple_box: "Callee-Saved" {
    style.fill: "#D0BFFF"
    style.stroke: "#5F3DC4"
    width: 100
  }
  blue_box: "Local Vars" {
    style.fill: "#A5D8FF"
    style.stroke: "#1971C2"
    width: 100
  }
  orange_box: "Padding" {
    style.fill: "#FFE8CC"
    style.stroke: "#E8590C"
    width: 100
  }
  yellow_box: "Out Args" {
    style.fill: "#FFF3BF"
    style.stroke: "#F08C00"
    width: 100
  }
}
frame_container.frame.high_addr -> frame_container.frame.caller_frame: "stack grows down" {
  style.stroke: "#868E96"
  style.stroke-dash: 3
}
frame_container.frame.rsp_mark -> frame_container.frame.low_addr: "push grows this way" {
  style.stroke: "#C92A2A"
  style.stroke-dash: 3
}