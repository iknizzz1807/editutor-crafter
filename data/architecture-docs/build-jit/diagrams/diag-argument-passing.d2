direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Function Argument Passing Sequence (System V AMD64 ABI)" {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  caller_state: {
    direction: down
    label: "Caller State\n(Before call)"
    reg_file: {
      label: "Integer Argument Registers"
      shape: class
      rdi: "int64_t"
      rsi: "int64_t"
      rdx: "int64_t"
      rcx: "int64_t"
      r8: "int64_t"
      r9: "int64_t"
    }
    reg_values: {
      label: "Register Values for f(1,2,3,4,5,6,7,8)"
      shape: sql_table
      r0: "rdi | 1"
      r1: "rsi | 2"
      r2: "rdx | 3"
      r3: "rcx | 4"
      r4: "r8  | 5"
      r5: "r9  | 6"
      note: "Args 1-6 in registers"
    }
  }
  stack_before: {
    direction: down
    label: "Stack Before Call"
    stack_layout_before: {
      shape: sql_table
      label: "Stack (grows down)"
      s0: "rsp+0  | arg8 | 8"
      s1: "rsp+8  | arg7 | 7"
      s2: "rsp+16 | (caller's frame)"
      note: "Args 7-8 pushed in reverse order"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  call_flow: {
    label: "Call Instruction"
    call_code: |'asm
      ; Push args 7-8 in reverse order
      push   8          ; arg8
      push   7          ; arg7
      ; Load args 1-6 into registers
      mov    rdi, 1
      mov    rsi, 2
      mov    rdx, 3
      mov    rcx, 4
      mov    r8,  5
      mov    r9,  6
      ; Set al=0 (no vector args)
      xor    rax, rax
      ; Call the function
      call   f
      ; Clean up (caller cleanup)
      add    rsp, 16
    '|
    width: 380
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stack_after: {
    direction: down
    label: "Stack After Call\n(Inside Callee)"
    stack_layout_after: {
      shape: sql_table
      label: "Stack (inside f)"
      s0: "rsp+0  | return addr | (pushed by call)"
      s1: "rsp+8  | arg7        | 7"
      s2: "rsp+16 | arg8        | 8"
      s3: "rsp+24 | (caller's frame)"
      note: "Access: arg7=[rsp+8], arg8=[rsp+16]"
    }
    alignment_note: {
      label: "Stack Alignment"
      shape: rectangle
      note: |md
        After `call`, rsp is 8 bytes from 16-byte alignment.
        After `push rbp`, rsp is 16-byte aligned.
      |
      width: 300
      style.fill: honeydew
    }
  }
  callee_access: {
    direction: down
    label: "Callee Access Pattern"
    access_code: |'c
      // Inside function f
      // Args 1-6 are in registers
      int64_t a1 = rdi;  // 1
      int64_t a2 = rsi;  // 2
      int64_t a3 = rdx;  // 3
      int64_t a4 = rcx;  // 4
      int64_t a5 = r8;   // 5
      int64_t a6 = r9;   // 6
      // Args 7-8 are on stack
      // At fixed offsets from rbp
      int64_t a7 = *(rbp + 16);  // 7
      int64_t a8 = *(rbp + 24);  // 8
    '|
    width: 380
  }
}
caller_state.reg_values -> stack_before.stack_layout_before: "push order\n7 then 8"
caller_state.reg_file -> call_flow: "loaded via\nmov"
stack_before.stack_layout_before -> stack_after.stack_layout_after: "call pushes\nreturn addr" {
  style.stroke-dash: 4
}
call_flow -> callee_access: "execution\ntransfers"
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: lightyellow
  reg_legend: "Register args: 1-6 (rdi, rsi, rdx, rcx, r8, r9)"
  stack_legend: "Stack args: 7+ (pushed right-to-left)"
  align_legend: "Stack 16-byte aligned before call"
  cleanup_legend: "Caller cleans up stack args"
}