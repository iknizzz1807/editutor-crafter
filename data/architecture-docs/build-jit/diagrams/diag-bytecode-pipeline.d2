direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STAGE 1: SOURCE ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  bytecode_src: {
    shape: sql_table
    label: "Bytecode Stream (Virtual ISA)"
    0x00: "0x01 | LOAD_CONST | index: 0"
    0x02: "0x12 | STORE_FAST | reg: rax"
    0x04: "0x45 | ADD_REG    | src: rbx, dst: rax"
    0x06: "0x99 | RET        | void"
    meta: "Total: 8 bytes"
    style.fill: "#E4DBFE"
  }

  profiler: {
    shape: class
    label: "Hot Path Detector"
    -threshold: "uint32_t"
    -counters: "uint16_t[]"
    +increment(pc): "void"
    +is_hot(pc): "bool"
    style.fill: "#FFF9C9"
  }
}

# --- STAGE 2: TRANSLATION ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  jit_core: {
    shape: class
    label: "JIT Compiler Core (jit_compiler.c)"
    -reg_map: "uint8_t[16]"
    -ir_buffer: "IR_Node*"
    +lower_to_ir(bytecode): "IR_Graph*"
    +allocate_registers(graph): "void"
    +optimize_cfg(graph): "void"
    +emit_native(graph): "void*"
    style.fill: "#C7F1FF"
  }

  reg_allocator: {
    label: "Linear Scan Allocator"
    width: 350
    code: |'c
      for (v : intervals) {
        if (free_regs > 0) {
          assign(v, next_free());
        } else {
          spill = find_furthest_use();
          spill_to_stack(spill);
        }
      }
    '|
  }
}

# --- STAGE 3: EMISSION ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  machine_code: {
    shape: sql_table
    label: "Native x86_64 Image"
    p0: "0x00 | 55          | PUSH rbp"
    p1: "0x01 | 48 89 E5    | MOV rbp, rsp"
    p2: "0x04 | 48 01 D8    | ADD rax, rbx"
    p3: "0x07 | 5D          | POP rbp"
    p4: "0x08 | C3          | RET"
    meta: "Total: 9 bytes native"
    style.fill: "#DEE1EB"
  }

  memory_manager: {
    shape: sql_table
    label: "Executable Memory (W^X)"
    v_addr: "0x7f00 | Base Address"
    size: "4096   | Page Size (4KB)"
    flags: "PROT_READ | PROT_EXEC"
    state: "Status: RUNNABLE"
    style.fill: "#ACE1AF"
  }
}

# --- ERROR & DEOPT ---
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  deoptimizer: {
    shape: class
    label: "Deoptimization Handler"
    -stack_frame: "void*"
    +capture_state(): "VMSnapshot"
    +restore_interpreter(): "void"
    style.fill: "#FFE7CB"
  }

  fallback: "Interpreter Safe-mode" {
    shape: oval
    style.stroke-dash: 5
  }
}

# --- DATA FLOW CONNECTIONS ---
row1.bytecode_src -> row2.jit_core: "ISA Data | stream"
row1.profiler -> row2.jit_core: "PC | trigger"

row2.jit_core -> row3.machine_code: "Opcode[] | emit"
row3.machine_code -> row3.memory_manager: "mprotect | RX"

row3.memory_manager -> row4.deoptimizer: "Guard Failure | signal" {
  style.stroke: red
  style.stroke-dash: 3
}

row4.deoptimizer -> row4.fallback: "Context | restore"

legend: {
  shape: sql_table
  label: "Architecture Legend"
  blue: "Control Flow"
  purple: "Translation Path"
  green: "Execution Memory"
  red: "Deopt/Safety Path"
}
legend.near: bottom-right

# Global filters for style
***.style.font-size: 14
(*** -> ***)[*]: {
  style.stroke-width: 2
}