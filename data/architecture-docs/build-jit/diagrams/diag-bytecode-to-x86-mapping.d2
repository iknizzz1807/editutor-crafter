direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Bytecode → x86-64 Translation Table
  Stack-based VM operations mapped to register-based native code
| {near: top-center}
row_header: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  col1: Bytecode Op {
    width: 140
    style.fill: "#E8E8E8"
    style.stroke: "#666"
    style.bold: true
  }
  col2: Stack Effect {
    width: 160
    style.fill: "#E8E8E8"
    style.stroke: "#666"
    style.bold: true
  }
  col3: x86-64 Sequence {
    width: 380
    style.fill: "#E8E8E8"
    style.stroke: "#666"
    style.bold: true
  }
  col4: Notes {
    width: 200
    style.fill: "#E8E8E8"
    style.stroke: "#666"
    style.bold: true
  }
}
row_arith: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  label_arith: ARITHMETIC {
    width: 880
    style.fill: "#D4E6F1"
    style.stroke: "#2E86AB"
    style.bold: true
  }
}
row_add: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_add: ADD {
    width: 140
    style.fill: "#E8F8F5"
    style.stroke: "#1ABC9C"
  }
  effect_add: "[a, b] → [a+b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_add: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; a in rax, b in rbx
      add rax, rbx      ; rax = a + b
      ; result in rax
    '|
  }
  note_add: "2 bytes\n(0x48 0x01)" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F4D03F"
  }
}
row_sub: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_sub: SUB {
    width: 140
    style.fill: "#E8F8F5"
    style.stroke: "#1ABC9C"
  }
  effect_sub: "[a, b] → [a-b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_sub: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; a in rax, b in rbx
      sub rax, rbx      ; rax = a - b
      ; result in rax
    '|
  }
  note_sub: "2 bytes\n(0x48 0x29)" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F4D03F"
  }
}
row_mul: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_mul: MUL {
    width: 140
    style.fill: "#E8F8F5"
    style.stroke: "#1ABC9C"
  }
  effect_mul: "[a, b] → [a*b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_mul: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; a in rax, b in rbx
      imul rax, rbx     ; rax = a * b (signed)
      ; result in rax
    '|
  }
  note_mul: "4 bytes\n(0x48 0x0F 0xAF)" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F4D03F"
  }
}
row_div: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_div: DIV {
    width: 140
    style.fill: "#FADBD8"
    style.stroke: "#E74C3C"
  }
  effect_div: "[a, b] → [a/b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_div: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; a in rax, b in rbx
      cqo               ; sign-extend rax → rdx:rax
      idiv rbx          ; rdx:rax / rbx
      ; quotient in rax, remainder in rdx
    '|
  }
  note_div: "FIXED REGISTERS\nrdx:rax implicit" {
    width: 200
    style.fill: "#FDEDEC"
    style.stroke: "#E74C3C"
    style.font-color: "#C0392B"
  }
}
row_udiv: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_udiv: UDIV {
    width: 140
    style.fill: "#FADBD8"
    style.stroke: "#E74C3C"
  }
  effect_udiv: "[a, b] → [a/b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_udiv: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; a in rax, b in rbx
      xor rdx, rdx      ; zero high bits
      div rbx           ; rdx:rax / rbx (unsigned)
      ; quotient in rax
    '|
  }
  note_udiv: "Must zero rdx\nbefore unsigned div" {
    width: 200
    style.fill: "#FDEDEC"
    style.stroke: "#E74C3C"
    style.font-color: "#C0392B"
  }
}
row_neg: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_neg: NEG {
    width: 140
    style.fill: "#E8F8F5"
    style.stroke: "#1ABC9C"
  }
  effect_neg: "[a] → [-a]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_neg: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; a in rax
      neg rax           ; rax = -rax (two's complement)
      ; result in rax
    '|
  }
  note_neg: "3 bytes\n(0x48 0xF7 0xD8)" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F4D03F"
  }
}
row_comp_header: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  label_comp: COMPARISONS {
    width: 880
    style.fill: "#D4E6F1"
    style.stroke: "#2E86AB"
    style.bold: true
  }
}
row_eq: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_eq: EQ {
    width: 140
    style.fill: "#E8DAEF"
    style.stroke: "#9B59B6"
  }
  effect_eq: "[a, b] → [a==b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_eq: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; a in rax, b in rbx
      cmp rax, rbx      ; set flags based on rax - rbx
      sete al           ; al = 1 if ZF=1 (equal)
      movzx eax, al     ; zero-extend to full register
      ; result (0 or 1) in rax
    '|
  }
  note_eq: "setcc + movzx pattern\nsete = 0x0F 0x94" {
    width: 200
    style.fill: "#F5EEF8"
    style.stroke: "#9B59B6"
  }
}
row_ne: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_ne: NE {
    width: 140
    style.fill: "#E8DAEF"
    style.stroke: "#9B59B6"
  }
  effect_ne: "[a, b] → [a!=b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_ne: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      cmp rax, rbx
      setne al          ; al = 1 if ZF=0 (not equal)
      movzx eax, al
      ; result in rax
    '|
  }
  note_ne: "setne = 0x0F 0x95" {
    width: 200
    style.fill: "#F5EEF8"
    style.stroke: "#9B59B6"
  }
}
row_lt: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_lt: LT {
    width: 140
    style.fill: "#E8DAEF"
    style.stroke: "#9B59B6"
  }
  effect_lt: "[a, b] → [a<b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_lt: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      cmp rax, rbx      ; compare a - b
      setl al           ; al = 1 if SF≠OF (signed less)
      movzx eax, al
      ; result in rax
    '|
  }
  note_lt: "SIGNED: uses SF and OF\nsetl = 0x0F 0x9C" {
    width: 200
    style.fill: "#F5EEF8"
    style.stroke: "#9B59B6"
  }
}
row_le: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_le: LE {
    width: 140
    style.fill: "#E8DAEF"
    style.stroke: "#9B59B6"
  }
  effect_le: "[a, b] → [a≤b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_le: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      cmp rax, rbx
      setle al          ; al = 1 if ZF=1 or SF≠OF
      movzx eax, al
      ; result in rax
    '|
  }
  note_le: "setle = 0x0F 0x9E" {
    width: 200
    style.fill: "#F5EEF8"
    style.stroke: "#9B59B6"
  }
}
row_gt: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_gt: GT {
    width: 140
    style.fill: "#E8DAEF"
    style.stroke: "#9B59B6"
  }
  effect_gt: "[a, b] → [a>b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_gt: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      cmp rax, rbx
      setg al           ; al = 1 if ZF=0 and SF=OF
      movzx eax, al
      ; result in rax
    '|
  }
  note_gt: "setg = 0x0F 0x9F" {
    width: 200
    style.fill: "#F5EEF8"
    style.stroke: "#9B59B6"
  }
}
row_ge: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_ge: GE {
    width: 140
    style.fill: "#E8DAEF"
    style.stroke: "#9B59B6"
  }
  effect_ge: "[a, b] → [a≥b]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_ge: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      cmp rax, rbx
      setge al          ; al = 1 if SF=OF (signed greater/equal)
      movzx eax, al
      ; result in rax
    '|
  }
  note_ge: "setge = 0x0F 0x9D" {
    width: 200
    style.fill: "#F5EEF8"
    style.stroke: "#9B59B6"
  }
}
row_ctrl_header: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  label_ctrl: CONTROL FLOW {
    width: 880
    style.fill: "#D4E6F1"
    style.stroke: "#2E86AB"
    style.bold: true
  }
}
row_jmp: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_jmp: JMP offset {
    width: 140
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
  }
  effect_jmp: "→ target" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_jmp: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; near jump (±2GB)
      jmp rel32         ; E8 xx xx xx xx
      ; short jump (±128B, smaller encoding)
      jmp rel8          ; EB xx
    '|
  }
  note_jmp: "Relative to NEXT instruction\nMay need back-patching" {
    width: 200
    style.fill: "#EAFAF1"
    style.stroke: "#27AE60"
  }
}
row_jz: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_jz: JZ offset {
    width: 140
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
  }
  effect_jz: "[cond] → branch if 0" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_jz: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; cond in rax
      test rax, rax     ; set ZF based on rax & rax
      jz rel32          ; branch if ZF=1 (rax was 0)
      ; or: je (synonym for jz)
    '|
  }
  note_jz: "test rax, rax = 48 85 C0\njz = 0x0F 0x84" {
    width: 200
    style.fill: "#EAFAF1"
    style.stroke: "#27AE60"
  }
}
row_jnz: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_jnz: JNZ offset {
    width: 140
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
  }
  effect_jnz: "[cond] → branch if ≠0" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_jnz: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      test rax, rax
      jnz rel32         ; branch if ZF=0 (rax was non-zero)
      ; or: jne (synonym for jnz)
    '|
  }
  note_jnz: "jnz = 0x0F 0x85" {
    width: 200
    style.fill: "#EAFAF1"
    style.stroke: "#27AE60"
  }
}
row_data_header: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  label_data: DATA MOVEMENT {
    width: 880
    style.fill: "#D4E6F1"
    style.stroke: "#2E86AB"
    style.bold: true
  }
}
row_push: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_push: PUSH imm {
    width: 140
    style.fill: "#FCF3CF"
    style.stroke: "#F39C12"
  }
  effect_push: "→ [imm]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_push: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; 64-bit immediate
      mov rax, imm64    ; 48 B8 xx xx xx xx xx xx xx xx
      ; 32-bit sign-extended (smaller)
      mov rax, imm32    ; 48 C7 C0 xx xx xx xx
    '|
  }
  note_push: "imm32 form: 7 bytes\nimm64 form: 10 bytes" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F39C12"
  }
}
row_load: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_load: LOAD slot {
    width: 140
    style.fill: "#FCF3CF"
    style.stroke: "#F39C12"
  }
  effect_load: "→ [local[slot]]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_load: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; local at [rbp - offset]
      mov rax, [rbp - 16]   ; load local slot 0
      ; offset = 16 + slot*8
    '|
  }
  note_load: "ModR/M encoding:\nmod=01, r/m=101 (rbp+disp8)" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F39C12"
  }
}
row_store: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_store: STORE slot {
    width: 140
    style.fill: "#FCF3CF"
    style.stroke: "#F39C12"
  }
  effect_store: "[val] → local[slot]" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_store: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; val in rax
      mov [rbp - 16], rax   ; store to local slot 0
      ; stack pop tracked virtually
    '|
  }
  note_store: "No stack adjustment\nVirtual stack tracks depth" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F39C12"
  }
}
row_ret: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_ret: RET {
    width: 140
    style.fill: "#FCF3CF"
    style.stroke: "#F39C12"
  }
  effect_ret: "[val] → return val" {
    width: 160
    style.fill: "#FDFEFE"
    style.stroke: "#BDC3C7"
  }
  code_ret: {
    width: 380
    label: "x86-64 Sequence"
    code: |'asm
      ; return value already in rax
      ; (or move to rax if elsewhere)
      ret               ; pop return address, jump
    '|
  }
  note_ret: "1 byte: 0xC3\nrax = return value" {
    width: 200
    style.fill: "#FEF9E7"
    style.stroke: "#F39C12"
  }
}
legend: |md
  **Legend:**
  - 🟢 **Green**: Simple arithmetic (2-4 bytes)
  - 🔴 **Red**: Division (fixed register constraints)
  - 🟣 **Purple**: Comparisons (cmp + setcc pattern)
  - 🟢 **Green border**: Control flow (relative jumps)
  - 🟡 **Yellow**: Data movement (memory/register ops)
| {near: bottom-center}
encoding_note: |md
  **Encoding Notes:**
  - All 64-bit ops require REX.W prefix (0x48)
  - Jump offsets are relative to **next instruction**
  - Division clobbers rdx (high bits of dividend)
  - setcc writes only low byte; movzx extends to full register
| {near: bottom-center}