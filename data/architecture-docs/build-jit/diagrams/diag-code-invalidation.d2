direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Safe Code Buffer Invalidation" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  active_code: "Active JIT Code Block" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    header: "CodeBlock (jit_cache.c)" {
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    block_struct: {
      shape: class
      label: "struct CodeBlock"
      +code_ptr: "void*"
      +code_size: "size_t"
      +ref_count: "atomic_int"
      +is_valid: "bool"
      +invalidation_time: "uint64_t"
    }
    ref_status: {
      label: "Reference Status"
      shape: rectangle
      width: 200
      ref_display: |md
        **ref_count = 3**
        (3 active frames executing)
      |
    }
    state_label: "ACTIVE — Executing" {
      shape: rectangle
      style: {
        fill: "#4CAF50"
        font-color: white
        bold: true
        border-radius: 4
      }
    }
  }
  active_frames: "Active Stack Frames" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    frames_label: "Frames Using This Code" {
      shape: rectangle
      style.fill: "#FF9800"
      style.font-color: white
      style.bold: true
    }
    frame3: {
      label: "Frame 3 (deepest)"
      shape: rectangle
      width: 180
      ret_addr: |md
        return_addr → `0x7f4c20`
        (inside code_block)
      |
    }
    frame2: {
      label: "Frame 2"
      shape: rectangle
      width: 180
      ret_addr: |md
        return_addr → `0x7f4c50`
        (inside code_block)
      |
    }
    frame1: {
      label: "Frame 1 (shallowest)"
      shape: rectangle
      width: 180
      ret_addr: |md
        return_addr → `0x7f4c88`
        (inside code_block)
      |
    }
    frame3 -> frame2: "calls"
    frame2 -> frame1: "calls"
  }
  entry_exit: "Entry/Exit Protocol" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    proto_label: "Reference Counting API" {
      shape: rectangle
      style.fill: "#2196F3"
      style.font-color: white
      style.bold: true
    }
    enter_func: {
      label: "enter_jit_code(block)"
      width: 220
      code: |'c
        void enter_jit_code(CodeBlock* b) {
          atomic_fetch_add(&b->ref_count, 1);
        }
      '|
    }
    exit_func: {
      label: "exit_jit_code(block)"
      width: 220
      code: |'c
        void exit_jit_code(CodeBlock* b) {
          if (atomic_fetch_sub(&b->ref_count, 1) == 1) {
            // Was 1, now 0 — FREE IT
            cache_free(b->code_ptr, b->code_size);
            free(b);
          }
        }
      '|
    }
    enter_func -> exit_func: "frames enter/exit"
  }
}
active_code.block_struct -> active_frames.frame3: "ref_count tracks" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.stroke-dash: 3
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  invalidation_event: "Invalidation Event" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    event_label: "invalidate_code() Called" {
      shape: rectangle
      style.fill: "#F44336"
      style.font-color: white
      style.bold: true
    }
    trigger: {
      label: "Trigger: Deoptimization"
      width: 200
      triggers: |md
        - Guard failure threshold exceeded
        - Class hierarchy changed
        - Function redefined (REPL)
        - Code cache pressure
      |
    }
    invalidate_code: {
      label: "invalidate_code(block)"
      width: 240
      code: |'c
        void invalidate_code(CodeBlock* b) {
          // Mark invalid — new calls rejected
          b->is_valid = false;
          b->invalidation_time = get_time_ns();
          // DON'T FREE YET!
          // Active frames still have
          // return addresses into this code
          add_to_zombie_list(b);
        }
      '|
    }
    key_point: {
      shape: callout
      label: "KEY: Code NOT freed immediately!"
      style: {
        fill: "#FFF9C4"
        stroke: "#F57F17"
        bold: true
      }
    }
  }
  zombie_list: "Deferred Free List (Zombies)" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    zombie_label: "zombie_list (global)" {
      shape: rectangle
      style.fill: "#9C27B0"
      style.font-color: white
      style.bold: true
    }
    zombie_struct: {
      shape: class
      label: "struct ZombieCode"
      +code_ptr: "void*"
      +code_size: "size_t"
      +invalidation_time: "uint64_t"
      +next: "ZombieCode*"
    }
    zombie1: {
      label: "Zombie Block 1"
      shape: rectangle
      width: 180
      style.fill: "#FFCDD2"
      info: |md
        ref_count: **2** → waiting
        invalidated: 50ms ago
      |
    }
    zombie2: {
      label: "Zombie Block 2"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
      info: |md
        ref_count: **0** → ready to free
        invalidated: 200ms ago
      |
    }
    zombie1 -> zombie2: "next"
    gc_note: {
      label: "gc_zombie_code() runs periodically"
      shape: rectangle
      width: 200
      style.fill: "#E1BEE7"
    }
  }
  gc_func: "Garbage Collection" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    gc_label: "Safe Free Condition" {
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    gc_code: {
      label: "gc_zombie_code()"
      width: 280
      code: |'c
        void gc_zombie_code(void) {
          ZombieCode** pp = &zombie_list;
          while (*pp != NULL) {
            ZombieCode* z = *pp;
            // Scan all stack frames
            bool still_live = false;
            for (void** sp = stack_top; 
                 sp < stack_bottom; sp++) {
              if (*sp >= z->code_ptr && 
                  *sp < z->code_ptr + z->code_size) {
                still_live = true;  // FOUND!
                break;
              }
            }
            if (!still_live) {
              // SAFE TO FREE
              cache_free(z->code_ptr, z->code_size);
              *pp = z->next;
              free(z);
            } else {
              pp = &z->next;
            }
          }
        }
      '|
    }
    safe_label: "SAFE TO FREE" {
      shape: rectangle
      style: {
        fill: "#4CAF50"
        font-color: white
        bold: true
        border-radius: 4
      }
    }
  }
}
invalidation_event -> zombie_list: "adds to" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 5
}
zombie_list -> gc_func: "periodically scanned" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  style.stroke-dash: 3
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  timeline: "Timeline: Safe Invalidation" {
    direction: down
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    timeline_label: "Event Sequence" {
      shape: rectangle
      style.fill: "#607D8B"
      style.font-color: white
      style.bold: true
    }
    t1: {
      label: "T1: Deoptimization Triggers"
      shape: step
      code: |'c
        // Guard fails, invalidate called
        invalidate_code(block);
        // block->is_valid = false
        // block->ref_count still = 3
      '|
    }
    t2: {
      label: "T2: Frames Unwind Normally"
      shape: step
      code: |'c
        // Frame 1 returns → ref_count = 2
        exit_jit_code(block);
        // Frame 2 returns → ref_count = 1
        exit_jit_code(block);
        // Frame 3 returns → ref_count = 0
        exit_jit_code(block); // FREE!
      '|
    }
    t3: {
      label: "T3: Memory Freed Safely"
      shape: step
      style.fill: "#C8E6C9"
      code: |'c
        // No dangling return addresses!
        // All frames have exited
        cache_free(block->code_ptr, block->code_size);
      '|
    }
    t1 -> t2: "frames unwind"
    t2 -> t3: "last frame exits"
  }
  dangling_problem: "The Dangling Pointer Problem" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    problem_label: "Why Immediate Free is WRONG" {
      shape: rectangle
      style.fill: "#F44336"
      style.font-color: white
      style.bold: true
    }
    bad_scenario: {
      label: "If we freed immediately:"
      width: 260
      scenario: |md
        
        Frame 2: executing at 0x7f4c50
        Frame 1: return_addr = 0x7f4c88
        invalidate_code() → FREE NOW
        Frame 1 tries to return...
        → jumps to freed memory!
        → CRASH or worse: silent corruption
        
      |
    }
    danger: {
      shape: diamond
      label: "DANGER"
      style: {
        fill: "#F44336"
        font-color: white
        bold: true
      }
    }
  }
  dispatch_table: "Dispatch Table Indirection" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    dispatch_label: "Alternative: Indirection" {
      shape: rectangle
      style.fill: "#2196F3"
      style.font-color: white
      style.bold: true
    }
    dispatch_struct: {
      shape: class
      label: "struct DispatchEntry"
      +jit_entry: "void*"
      +is_valid: "bool"
    }
    call_site: {
      label: "At Call Site"
      width: 260
      code: |'c
        // Always go through table
        DispatchEntry* e = &dispatch_table[func_id];
        if (e->is_valid && e->jit_entry) {
          ((void(*)(void))e->jit_entry)();
        } else {
          interpret_function(func_id);
        }
      '|
    }
    benefit: {
      label: "Benefit: No ref counting needed"
      shape: rectangle
      style.fill: "#BBDEFB"
      style.font-color: "#1565C0"
    }
    tradeoff: {
      label: "Tradeoff: Indirection overhead"
      shape: rectangle
      style.fill: "#FFECB3"
      style.font-color: "#FF6F00"
    }
  }
}
active_frames -> dangling_problem: "frames still active" {
  style.stroke: "#F44336"
  style.stroke-dash: 5
  style.animated: true
}
legend: "Legend" {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  active: "Active Code" {
    shape: rectangle
    style.fill: "#E8F5E9"
  }
  zombie: "Zombie (Waiting)" {
    shape: rectangle
    style.fill: "#F3E5F5"
  }
  danger: "Danger Zone" {
    shape: rectangle
    style.fill: "#FFEBEE"
  }
  safe: "Safe to Free" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
}