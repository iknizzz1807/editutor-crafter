direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  before: "BEFORE: Runtime Evaluation" {
    direction: down
    style: {
      fill: "#FFF0F0"
      stroke: "#CC0000"
      stroke-width: 2
      border-radius: 8
    }
    source: {
      label: "Source Code"
      width: 300
      code: |'c
        a = 2 + 3;      // add at runtime
        b = a * 4;      // mul at runtime
      '|
    }
    operations: {
      label: "Runtime Operations"
      direction: right
      style.fill: "#FFE0E0"
      op1: {
        label: "ADD"
        shape: oval
        style: {
          fill: "#FF6666"
          font-color: white
        }
      }
      op2: {
        label: "MUL"
        shape: oval
        style: {
          fill: "#FF6666"
          font-color: white
        }
      }
    }
    bytecode_label: "Emitted Bytecode (6 ops)"
    bytecode: {
      shape: sql_table
      label: "Bytecode Stream"
      width: 280
      c0: "0x00 | PUSH    | 2"
      c1: "0x03 | PUSH    | 3"
      c2: "0x06 | ADD     | —"
      c3: "0x07 | STORE   | a"
      c4: "0x09 | PUSH    | 4"
      c5: "0x0C | MUL     | —"
      total: "6 instructions | ~24 bytes"
    }
    cost: {
      label: "Execution Cost"
      shape: rectangle
      style: {
        fill: "#FFCCCC"
        stroke: "#CC0000"
        stroke-dash: 3
      }
      width: 280
      code: |'
        2 memory loads
        2 arithmetic ops
        6 dispatch cycles
      '|
    }
  }
  arrow_container: "" {
    direction: down
    style: {
      stroke: transparent
      fill: transparent
    }
    width: 80
    arrow: {
      label: "Constant\nFolding"
      shape: diamond
      style: {
        fill: "#4CAF50"
        font-color: white
        bold: true
      }
    }
  }
  after: "AFTER: Compile-Time Folding" {
    direction: down
    style: {
      fill: "#F0FFF0"
      stroke: "#008800"
      stroke-width: 2
      border-radius: 8
    }
    source_opt: {
      label: "Optimized Code"
      width: 300
      code: |'c
        a = 5;          // folded constant
        b = 20;         // folded constant
      '|
    }
    ops_opt: {
      label: "Runtime Operations"
      direction: right
      style.fill: "#E0FFE0"
      op_none: {
        label: "NONE"
        shape: oval
        style: {
          fill: "#88CC88"
          font-color: "#006600"
        }
      }
    }
    bytecode_opt_label: "Emitted Bytecode (2 ops)"
    bytecode_opt: {
      shape: sql_table
      label: "Optimized Bytecode"
      width: 280
      c0: "0x00 | PUSH    | 5"
      c1: "0x03 | STORE   | a"
      c2: "0x05 | PUSH    | 20"
      c3: "0x08 | STORE   | b"
      total: "4 instructions | ~16 bytes"
    }
    savings: {
      label: "Performance Gain"
      shape: rectangle
      style: {
        fill: "#CCFFCC"
        stroke: "#008800"
      }
      width: 280
      code: |'
        0 arithmetic ops
        33% smaller code
        66% fewer dispatches
      '|
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#F5F5F5"
    border-radius: 4
  }
  red_box: {
    shape: rectangle
    width: 16
    height: 16
    style.fill: "#FF6666"
  }
  red_label: "Eliminated Op"
  green_box: {
    shape: rectangle
    width: 16
    height: 16
    style.fill: "#4CAF50"
  }
  green_label: "Folded Constant"
}
transformation: {
  label: "Transformation Logic"
  near: bottom-center
  direction: right
  style: {
    fill: "#E8E8E8"
    border-radius: 8
  }
  step1: {
    label: "Step 1: Detect"
    code: |'c
      // Pattern match:
      if (is_const(a) && 
          is_const(b) &&
          is_pure_op(ADD)) {
        // Foldable!
      }
    '|
    width: 200
  }
  step2: {
    label: "Step 2: Evaluate"
    code: |'c
      // At compile time:
      int64_t result = eval(
        op, a.val, b.val
      );
      // 2 + 3 = 5
    '|
    width: 200
  }
  step3: {
    label: "Step 3: Replace"
    code: |'c
      // Replace with constant
      emit(PUSH, result);
      // No ADD instruction!
    '|
    width: 200
  }
}