direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Deoptimization in Mid-Expression
    **Trace: Guard fails after LHS evaluated, before RHS**
  |
  near: top-center
  shape: text
}
legend: {
  near: bottom-right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  legend_title: "Legend" {
    shape: text
    style.bold: true
  }
  interp: "Interpreter State" {
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
  }
  jit: "JIT Register State" {
    style.fill: "#fff3e0"
    style.stroke: "#f57c00"
  }
  guard: "Guard Failure" {
    style.fill: "#ffebee"
    style.stroke: "#c62828"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bytecode_stream: {
    direction: down
    label: "Bytecode Stream"
    bc_1: {
      label: "LOAD_LOCAL 0"
      width: 140
      style.fill: "#e8f5e9"
    }
    bc_2: {
      label: "LOAD_LOCAL 1"
      width: 140
      style.fill: "#e8f5e9"
    }
    bc_3: {
      label: "ADD"
      width: 140
      style.fill: "#e8f5e9"
    }
    bc_4: {
      label: "PUSH 10"
      width: 140
      style.fill: "#e8f5e9"
    }
    bc_5: {
      label: "MUL"
      width: 140
      style.fill: "#fff3e0"
      style.stroke: "#f57c00"
      style.stroke-width: 2
    }
    bc_6: {
      label: "RET"
      width: 140
      style.fill: "#e8f5e9"
    }
    bc_1 -> bc_2 -> bc_3 -> bc_4 -> bc_5 -> bc_6
  }
  interp_stack: {
    direction: down
    label: "Interpreter Operand Stack"
    is_frame: {
      style.fill: "#e3f2fd"
      style.stroke: "#1976d2"
      is_header: {
        label: "After LOAD_LOCAL 1"
        shape: text
        style.bold: true
        style.fill: transparent
      }
      is_stack: {
        shape: sql_table
        label: "Stack (depth=2)"
        slot1: "0 | local0"
        slot2: "1 | local1"
      }
    }
    is_arrow1: {
      label: "ADD executes"
      shape: text
    }
    is_frame2: {
      style.fill: "#e3f2fd"
      style.stroke: "#1976d2"
      is_header2: {
        label: "After ADD"
        shape: text
        style.bold: true
        style.fill: transparent
      }
      is_stack2: {
        shape: sql_table
        label: "Stack (depth=1)"
        slot1: "0 | local0+local1"
      }
    }
    is_arrow2: {
      label: "PUSH 10"
      shape: text
    }
    is_frame3: {
      style.fill: "#e3f2fd"
      style.stroke: "#1976d2"
      is_header3: {
        label: "Before MUL (guard point)"
        shape: text
        style.bold: true
        style.fill: transparent
      }
      is_stack3: {
        shape: sql_table
        label: "Stack (depth=2)"
        slot1: "0 | local0+local1"
        slot2: "1 | 10"
      }
    }
    is_frame -> is_arrow1 -> is_frame2 -> is_arrow2 -> is_frame3
  }
  jit_state: {
    direction: down
    label: "JIT Execution State"
    js_frame1: {
      style.fill: "#fff3e0"
      style.stroke: "#f57c00"
      js_header1: {
        label: "Registers at MUL guard"
        shape: text
        style.bold: true
        style.fill: transparent
      }
      js_regs: {
        shape: class
        label: "Register Mapping"
        rax: "int64_t"
        rbx: "int64_t"
        r12: "int64_t"
        r13: "int64_t"
        -note: '"See side table"'
      }
      js_desc: {
        label: |md
          - `rax` = local0 + local1 (LHS)
          - `rbx` = 10 (RHS constant)
          - `r12` = local0 (saved arg)
          - `r13` = local1 (saved arg)
        |
        shape: text
      }
    }
    js_guard: {
      label: "Guard Check"
      width: 200
      code: |'asm
        ; Type guard before MUL
        test  rax, TAG_MASK
        jnz   deopt_stub_3
        ; Guard FAILED → deoptimize!
      '|
      style.fill: "#ffebee"
      style.stroke: "#c62828"
    }
    js_frame1 -> js_guard
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  side_table: {
    direction: down
    label: "Side Table: Deopt Entry 3"
    st_header: {
      shape: sql_table
      label: "DeoptEntry @ MUL"
      f0: "jit_offset | 0x42"
      f1: "bytecode_offset | 18"
      f2: "guard_type | TYPE_TAG"
    }
    st_mappings: {
      shape: sql_table
      label: "ValueMappings"
      m0: "rax → STACK[0]"
      m1: "rbx → STACK[1]"
      m2: "r12 → LOCAL[0]"
      m3: "r13 → LOCAL[1]"
    }
    st_header -> st_mappings
  }
  deopt_stub: {
    direction: down
    label: "Deoptimization Stub"
    ds_code: {
      label: "Assembly"
      width: 280
      code: |'asm
        deopt_stub_3:
          push  rax, rbx, rcx, rdx
          push  rsi, rdi, r8-r11
          mov   rdi, 3            ; entry_id
          mov   rsi, rsp          ; saved_regs*
          mov   rdx, rbp          ; frame_ptr
          call  deoptimize
          ; Never returns - longjmps
          ; to interpreter at offset 18
      '|
      style.fill: "#fce4ec"
      style.stroke: "#ad1457"
    }
    ds_desc: {
      label: |md
        1. Save all registers
        2. Look up side table entry
        3. Reconstruct interpreter frame
        4. `longjmp` to interpreter loop
      |
      shape: text
    }
    ds_code -> ds_desc
  }
  reconstructed: {
    direction: down
    label: "Reconstructed Interpreter State"
    rs_frame: {
      style.fill: "#e8f5e9"
      style.stroke: "#2e7d32"
      rs_header: {
        label: "After Deoptimization"
        shape: text
        style.bold: true
        style.fill: transparent
      }
      rs_interp: {
        shape: class
        label: "InterpreterFrame"
        pc: "bytecode + 18"
        operand_stack: "int64_t*"
        stack_top: "2"
        local_vars: "int64_t*"
      }
      rs_stack: {
        shape: sql_table
        label: "operand_stack"
        s0: "0 | rax value"
        s1: "1 | rbx value"
      }
      rs_locals: {
        shape: sql_table
        label: "local_vars"
        l0: "0 | r12 value"
        l1: "1 | r13 value"
      }
    }
    rs_resume: {
      label: |md
        **Resume at MUL bytecode**
        - Stack has both operands
        - Locals preserved
        - PC points to MUL instruction
      |
      shape: text
      style.fill: "#e8f5e9"
    }
    rs_frame -> rs_resume
  }
}
bytecode_stream.bc_5 -> jit_state.js_guard: "guard here" {
  style.stroke: "#c62828"
  style.stroke-dash: 4
}
jit_state.js_guard -> deopt_stub.ds_code: "jump" {
  style.stroke: "#ad1457"
  style.animated: true
}
deopt_stub.ds_desc -> reconstructed.rs_frame: "reconstruct" {
  style.stroke: "#2e7d32"
}
side_table.st_mappings -> deopt_stub.ds_code: "lookup" {
  style.stroke: "#1976d2"
  style.stroke-dash: 3
}
interp_stack.is_frame3 -> reconstructed.rs_stack: "same state" {
  style.stroke: "#2e7d32"
  style.stroke-dash: 5
}
reconstructed.rs_resume -> bytecode_stream.bc_5: "resume execution" {
  style.stroke: "#2e7d32"
  style.stroke-width: 2
}