direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  jit_state: {
    direction: down
    label: "JIT Hardware State"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    registers: {
      shape: sql_table
      label: "CPU Registers (jit_state)"
      rax: "0x00 | int64 | rax"
      rbx: "0x08 | int64 | rbx"
      rcx: "0x10 | int64 | rcx"
      rdx: "0x18 | int64 | rdx"
      r12: "0x20 | int64 | r12"
      note: "Values at guard failure"
    }
    stack_frame: {
      shape: sql_table
      label: "JIT Stack Frame [rbp-N]"
      slot0: "-0x08 | int64 | spill[0]"
      slot1: "-0x10 | int64 | spill[1]"
      slot2: "-0x18 | int64 | spill[2]"
    }
  }
  side_table: {
    direction: down
    label: "Deopt Side Table"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    header: {
      shape: class
      label: "DeoptEntry (deopt.h)"
      guard_pc: "uint8_t*"
      bytecode_off: "uint32_t"
      mapping_count: "int"
    }
    mappings: {
      shape: sql_table
      label: "ValueMapping[] (side table)"
      m0: "0 | SOURCE_REG | rax | TARGET_LOCAL | 0"
      m1: "1 | SOURCE_REG | rbx | TARGET_STACK | 0"
      m2: "2 | SOURCE_REG | rcx | TARGET_STACK | 1"
      m3: "3 | SOURCE_SPILL | 0x08 | TARGET_LOCAL | 1"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vm_state: {
    direction: down
    label: "Interpreter VM State"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    locals: {
      shape: sql_table
      label: "local_vars[]"
      l0: "0 | int64 | local[0]"
      l1: "1 | int64 | local[1]"
      l2: "2 | int64 | local[2]"
    }
    operand_stack: {
      shape: sql_table
      label: "operand_stack[]"
      s0: "0 | int64 | stack[0] (bottom)"
      s1: "1 | int64 | stack[1]"
      s2: "2 | int64 | stack[2] (top)"
    }
    frame: {
      shape: class
      label: "InterpreterFrame (vm.h)"
      pc: "uint8_t*"
      stack_top: "int"
      locals: "int64_t*"
    }
  }
}
arrows: {
  direction: down
  jit_state.registers -> side_table.mappings: "register\nindex" {
    style.stroke: "#2196F3"
    style.stroke-dash: 3
  }
  jit_state.stack_frame -> side_table.mappings: "spill\noffset" {
    style.stroke: "#2196F3"
    style.stroke-dash: 3
  }
}
mapping_flow: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  step1: {
    label: "1. Read mapping"
    width: 140
  }
  step2: {
    label: "2. Extract value"
    width: 140
  }
  step3: {
    label: "3. Store to VM"
    width: 140
  }
  step1 -> step2 -> step3: {
    style.stroke: "#FF9800"
    style.animated: true
  }
}
jit_state -> mapping_flow.step1: "guard fails"
mapping_flow.step3 -> vm_state: "reconstructed"
legend: {
  near: bottom-center
  direction: right
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  reg_src: {
    label: "SOURCE_REG"
    style.fill: "#BBDEFB"
  }
  spill_src: {
    label: "SOURCE_SPILL"
    style.fill: "#FFE0B2"
  }
  local_tgt: {
    label: "TARGET_LOCAL"
    style.fill: "#C8E6C9"
  }
  stack_tgt: {
    label: "TARGET_STACK"
    style.fill: "#DCEDC8"
  }
}
example_mapping: {
  near: top-right
  label: |md
    **Example Mapping:**
    `rax → local[0]`
    c
    // At deoptimization:
    int64_t value = saved_regs[RAX];
    frame->local_vars[0] = value;
    
  |
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
}