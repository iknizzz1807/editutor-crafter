direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # x86-64 Division: Signed vs Unsigned
  Both forms divide 128-bit `rdx:rax` by divisor
| {near: top-center}
row_compare: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  signed: {
    direction: down
    label: "Signed Division (idiv)"
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"
    signed_step1: {
      label: "1. Sign-Extend"
      width: 280
      code: |'asm
        cqo    ; rdx:rax = sign_extend(rax)
      '|
    }
    signed_step1.style.fill: "#C8E6C9"
    signed_step2: {
      label: "2. Divide"
      width: 280
      code: |'asm
        idiv  rdi   ; rdx:rax / rdi
      '|
    }
    signed_step2.style.fill: "#A5D6A7"
    signed_result: {
      label: "Result"
      shape: sql_table
      rax: "0x00 | rax | Quotient"
      rdx: "0x08 | rdx | Remainder"
    }
    signed_result.style.fill: "#81C784"
  }
  unsigned: {
    direction: down
    label: "Unsigned Division (div)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    unsigned_step1: {
      label: "1. Zero High Bits"
      width: 280
      code: |'asm
        xor  rdx, rdx  ; rdx = 0
      '|
    }
    unsigned_step1.style.fill: "#BBDEFB"
    unsigned_step2: {
      label: "2. Divide"
      width: 280
      code: |'asm
        div  rdi   ; rdx:rax / rdi
      '|
    }
    unsigned_step2.style.fill: "#90CAF9"
    unsigned_result: {
      label: "Result"
      shape: sql_table
      rax: "0x00 | rax | Quotient"
      rdx: "0x08 | rdx | Remainder"
    }
    unsigned_result.style.fill: "#64B5F6"
  }
  signed.step1 -> signed.step2 -> signed.result
  unsigned.step1 -> unsigned.step2 -> unsigned.result
}
dividend_box: {
  label: "Dividend: 128-bit rdx:rax"
  shape: sql_table
  rdx_part: "High 64 bits | rdx"
  rax_part: "Low 64 bits  | rax"
  note: "Formed by concatenating rdx || rax"
}
dividend_box.style.fill: "#FFF3E0"
dividend_box.style.stroke: "#EF6C00"
dividend_box.near: top-center
arrow_note: |md
  Both `idiv` and `div` read from `rdx:rax`
| {
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
}
dividend_box -> row_compare.signed.step1: "rdx:rax"
dividend_box -> row_compare.unsigned.step1: "rdx:rax"
arrow_note.near: bottom-center
error_section: {
  direction: down
  label: "Edge Case: Division by Zero"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  error_code: {
    label: "Zero Divisor"
    width: 320
    code: |'asm
      xor  rdi, rdi    ; rdi = 0
      div  rdi         ; Hardware exception!
    '|
  }
  error_code.style.fill: "#FFCDD2"
  error_result: {
    label: "CPU Response"
    shape: class
    +exception: "SIGFPE (Signal 8)"
    +vector: "DE (Divide Error)"
    +action: "Terminate process"
  }
  error_result.style.fill: "#EF9A9A"
  error_code -> error_result: "triggers"
}
error_section.near: bottom-center
legend: {
  near: bottom-right
  direction: down
  label: "Register Roles"
  style.fill: "#F5F5F5"
  reg_rax: "rax = Quotient (result)"
  reg_rdx: "rdx = Remainder (modulo)"
  reg_div: "divisor = r/m64 operand"
}
legend.style.stroke: "#9E9E9E"