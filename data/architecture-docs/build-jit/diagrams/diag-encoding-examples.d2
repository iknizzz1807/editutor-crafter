direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Instruction Encoding Walkthrough
  Five x86-64 instructions traced byte-by-byte
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  instr1: {
    direction: down
    label: "Instruction 1: mov rax, 42"
    asm1: {
      label: "Assembly"
      code: |'asm
        mov rax, 42
      '|
      width: 200
    }
    bytes1: {
      label: "Raw Bytes"
      hex: |'
        48 C7 C0 2A 00 00 00
      '|
      width: 200
    }
    breakdown1: {
      shape: sql_table
      label: "Field Breakdown"
      f0: "0x00 | 48 | REX.W prefix"
      f1: "0x01 | C7 | mov r/m, imm32 opcode"
      f2: "0x02 | C0 | ModR/M (mod=11, reg=000, r/m=000)"
      f3: "0x03 | 2A | Immediate low byte (42)"
      f4: "0x04 | 00 | Immediate byte 1"
      f5: "0x05 | 00 | Immediate byte 2"
      f6: "0x06 | 00 | Immediate byte 3"
      sz: "Total: 7 bytes"
    }
    note1: |md
      REX.W (0x48) enables 64-bit operands.
      Opcode C7 /0 is mov r/m64, imm32.
      ModR/M C0 = 11 000 000 (reg-to-reg, rax).
      Immediate 0x0000002A = 42 (little-endian).
    | {width: 280}
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  instr2: {
    direction: down
    label: "Instruction 2: mov r8, rdi"
    asm2: {
      label: "Assembly"
      code: |'asm
        mov r8, rdi
      '|
      width: 200
    }
    bytes2: {
      label: "Raw Bytes"
      hex: |'
        49 89 F8
      '|
      width: 200
    }
    breakdown2: {
      shape: sql_table
      label: "Field Breakdown"
      f0: "0x00 | 49 | REX.WB prefix"
      f1: "0x01 | 89 | mov r/m64, r64 opcode"
      f2: "0x02 | F8 | ModR/M (mod=11, reg=111, r/m=000)"
      sz: "Total: 3 bytes"
    }
    note2: |md
      REX.WB (0x49): W=64-bit, B=extended r/m.
      r8 requires REX.B bit set (r/m becomes r8).
      Opcode 89: mov r/m64, r64 (src in reg).
      ModR/M F8 = 11 111 000 (rdi→r8).
    | {width: 280}
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  instr3: {
    direction: down
    label: "Instruction 3: add rax, rsi"
    asm3: {
      label: "Assembly"
      code: |'asm
        add rax, rsi
      '|
      width: 200
    }
    bytes3: {
      label: "Raw Bytes"
      hex: |'
        48 01 F0
      '|
      width: 200
    }
    breakdown3: {
      shape: sql_table
      label: "Field Breakdown"
      f0: "0x00 | 48 | REX.W prefix"
      f1: "0x01 | 01 | add r/m64, r64 opcode"
      f2: "0x02 | F0 | ModR/M (mod=11, reg=110, r/m=000)"
      sz: "Total: 3 bytes"
    }
    note3: |md
      REX.W (0x48) for 64-bit operands.
      Opcode 01: add r/m64, r64 (src in reg).
      ModR/M F0 = 11 110 000:
        mod=11 (register), reg=110 (rsi), r/m=000 (rax).
      Result: rax = rax + rsi.
    | {width: 280}
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  instr4: {
    direction: down
    label: "Instruction 4: imul rax, rdx, 3"
    asm4: {
      label: "Assembly"
      code: |'asm
        imul rax, rdx, 3
      '|
      width: 200
    }
    bytes4: {
      label: "Raw Bytes"
      hex: |'
        48 6B C2 03
      '|
      width: 200
    }
    breakdown4: {
      shape: sql_table
      label: "Field Breakdown"
      f0: "0x00 | 48 | REX.W prefix"
      f1: "0x01 | 6B | imul r64, r/m64, imm8"
      f2: "0x02 | C2 | ModR/M (mod=11, reg=000, r/m=010)"
      f3: "0x03 | 03 | Immediate (3)"
      sz: "Total: 4 bytes"
    }
    note4: |md
      Opcode 6B: three-operand imul with sign-extended imm8.
      ModR/M C2 = 11 000 010:
        reg=000 (destination: rax), r/m=010 (source: rdx).
      Immediate 0x03 = 3 (sign-extended to 64 bits).
      Result: rax = rdx * 3.
    | {width: 280}
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  instr5: {
    direction: down
    label: "Instruction 5: ret"
    asm5: {
      label: "Assembly"
      code: |'asm
        ret
      '|
      width: 200
    }
    bytes5: {
      label: "Raw Bytes"
      hex: |'
        C3
      '|
      width: 200
    }
    breakdown5: {
      shape: sql_table
      label: "Field Breakdown"
      f0: "0x00 | C3 | ret (near return)"
      sz: "Total: 1 byte"
    }
    note5: |md
      Single-byte instruction: C3.
      Pops return address from stack and jumps to it.
      No REX prefix needed—no operands to encode.
      Used for function epilogue.
    | {width: 280}
  }
}
summary: {
  label: "Complete Byte Sequence"
  direction: down
  full_bytes: {
    label: "All 18 bytes concatenated"
    hex: |'
      48 C7 C0 2A 00 00 00   49 89 F8   48 01 F0   48 6B C2 03   C3
      |____mov rax,42____|   |_mov r8_  |_add rax_| |__imul____|  |ret|
    '|
    width: 600
  }
  legend: {
    direction: right
    l1: {
      label: "REX Prefixes"
      code: |'
        48 = REX.W
        49 = REX.WB
      '|
    }
    l2: {
      label: "Common Opcodes"
      code: |'
        C7 = mov r/m, imm
        89 = mov r/m, r
        01 = add r/m, r
        6B = imul r, r/m, imm8
        C3 = ret
      '|
    }
  }
}
flow_label: |md
  **Encoding Flow**: Assembly → REX (if needed) → Opcode → ModR/M (if operands) → Immediate (if present)
| {near: bottom-center}