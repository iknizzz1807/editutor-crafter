direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Guard Failure Counter and Blacklisting
    State machine preventing compile-deopt thrashing
  |
  near: top-center
  shape: text
  style.font-size: 32
}
states: {
  direction: down
  compiled: {
    shape: hexagon
    label: "FUNCTION\nCOMPILED"
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 3
    }
    desc: {
      label: |md
        JIT code active
        Dispatch table → native entry
      |
      shape: text
      style.font-size: 16
      style.font-color: "#558B2F"
    }
  }
  guard_check: {
    shape: diamond
    label: "Guard\nCheck"
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
  guard_pass: {
    shape: oval
    label: "PASS"
    style: {
      fill: "#A5D6A7"
      stroke: "#388E3C"
    }
  }
  guard_fail: {
    shape: oval
    label: "FAIL"
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
  }
  increment: {
    shape: rectangle
    label: "deopt_count++"
    style: {
      fill: "#FFCCBC"
      stroke: "#E64A19"
    }
    code: {
      label: |'c
        profile->deopt_count++;
        profile->guard_failures[id]++;
        profile->last_deopt = now();
      '|
      width: 280
    }
  }
  threshold_check: {
    shape: diamond
    label: "deopt_count\n>= 3?"
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
  deopt_path: {
    shape: rectangle
    label: "Deoptimize\n→ Interpreter"
    style: {
      fill: "#B3E5FC"
      stroke: "#0277BD"
    }
    desc: {
      label: |md
        Reconstruct interpreter state
        Resume at bytecode PC
      |
      shape: text
      style.font-size: 14
    }
  }
  blacklist: {
    shape: rectangle
    label: "BLACKLIST\nFUNCTION"
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 3
    }
    code: {
      label: |'c
        func->is_blacklisted = true;
        func->jit_entry = NULL;
        log("blacklisted: too many deopts");
      '|
      width: 300
    }
  }
  always_interpret: {
    shape: hexagon
    label: "ALWAYS\nINTERPRET"
    style: {
      fill: "#B3E5FC"
      stroke: "#01579B"
      stroke-width: 3
    }
    desc: {
      label: |md
        No JIT compilation attempted
        Counter never resets
        Stable execution path
      |
      shape: text
      style.font-size: 16
      style.font-color: "#0277BD"
    }
  }
}
profile: {
  label: "DeoptProfile (deopt_profiles[func_id])"
  shape: sql_table
  width: 320
  f0: "0x00 | int       | func_id"
  f1: "0x04 | int       | deopt_count"
  f2: "0x08 | int[256]  | guard_failures"
  f3: "0x48 | bool      | is_blacklisted"
  f4: "0x50 | uint64    | last_deopt_time"
  sz: "Total: 88 bytes"
}
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style.fill: transparent
  style.stroke: "#9E9E9E"
  hex: {
    label: "State"
    shape: hexagon
    style.fill: "#E8F5E9"
  }
  diamond: {
    label: "Decision"
    shape: diamond
    style.fill: "#FFF9C4"
  }
  rect: {
    label: "Action"
    shape: rectangle
    style.fill: "#FFCCBC"
  }
}
states.compiled -> states.guard_check: "execute"
states.guard_check -> states.guard_pass: "pass"
states.guard_check -> states.guard_fail: "fail" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
states.guard_pass -> states.compiled: "continue JIT" {
  style.stroke: "#388E3C"
  style.stroke-dash: 3
}
states.guard_fail -> states.increment: "trigger"
states.increment -> states.threshold_check
states.threshold_check -> states.deopt_path: "< 3" {
  label: "NO"
  style.stroke: "#0277BD"
}
states.threshold_check -> states.blacklist: ">= 3" {
  label: "YES"
  style.stroke: "#B71C1C"
  style.stroke-width: 2
}
states.deopt_path -> states.compiled: "resume\n(next call)" {
  style.stroke-dash: 5
  style.stroke: "#7B1FA2"
}
states.blacklist -> states.always_interpret: "invalidate\nJIT code"
profile -> states.increment: "update" {
  style.stroke-dash: 3
  style.stroke: "#757575"
}