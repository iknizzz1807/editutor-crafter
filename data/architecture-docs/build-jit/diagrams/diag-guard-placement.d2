direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Speculative Guard Placement (JIT Tier 2)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

legend_box: {
  near: bottom-right
  style: {
    fill: "#f8f9fa"
    stroke: "#dee2e6"
    border-radius: 8
  }
  legend_title: "Legend" {
    shape: text
    style.bold: true
  }
  fast_path: "Fast Path (Guard Passes)" {
    style: {
      fill: "#d4edda"
      stroke: "#28a745"
      border-radius: 4
    }
  }
  slow_path: "Slow Path (Guard Fails)" {
    style: {
      fill: "#f8d7da"
      stroke: "#dc3545"
      border-radius: 4
      stroke-dash: 4
    }
  }
  guard_node: "Guard Check" {
    shape: diamond
    style: {
      fill: "#fff3cd"
      stroke: "#ffc107"
    }
  }
}

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  left_col: {
    direction: down
    label: "JIT Optimized Hot Path (jit_exec.c)"
    
    entry: "Function Entry" {
      shape: rectangle
      width: 200
      style: {
        fill: "#e3f2fd"
        stroke: "#1976d2"
        border-radius: 6
        bold: true
      }
    }
    
    load_args: {
      label: "T0: Load Arguments"
      width: 220
      code: |'c
        mov rbx, [rbp+0x10] ; arg a
        mov rcx, [rbp+0x18] ; arg b
      '|
    }
    
    guard1: {
      shape: diamond
      label: "Guard 1: Is_Int(a)?"
      width: 180
      style: {
        fill: "#fff3cd"
        stroke: "#ffc107"
        border-radius: 4
      }
    }
    
    guard2: {
      shape: diamond
      label: "Guard 2: Is_Int(b)?"
      width: 180
      style: {
        fill: "#fff3cd"
        stroke: "#ffc107"
        border-radius: 4
      }
    }
    
    optimized_block: {
      label: "T1: Fast Integer Add"
      width: 220
      style: {
        fill: "#d4edda"
        stroke: "#28a745"
        border-radius: 6
      }
      code: |'c
        mov rax, rbx
        add rax, rcx   ; CPU Add
        shl rax, 1     ; Tagging
        ret
      '|
    }
    
    exit_fast: "Return Result (RAX)" {
      shape: oval
      width: 160
      style: {
        fill: "#d4edda"
        stroke: "#28a745"
      }
    }
  }

  right_col: {
    direction: down
    label: "Deoptimization Cold Path (deopt.c)"
    
    deopt_stub: {
      label: "Deopt Stub #42"
      width: 220
      style: {
        fill: "#f8d7da"
        stroke: "#dc3545"
        stroke-dash: 4
        border-radius: 6
      }
      code: |'c
        push rbx       ; save context
        push rcx
        call jit_deoptimize
      '|
    }
    
    interp_frame: {
      label: "Interpreter Frame Restore"
      width: 220
      style: {
        fill: "#f8d7da"
        stroke: "#dc3545"
        stroke-dash: 4
        border-radius: 6
      }
      frame_layout: {
        shape: sql_table
        label: "VM Stack (frame.h)"
        row1: "0x00 | uintptr_t | op_stack"
        row2: "0x08 | uintptr_t | locals"
        row3: "0x10 | uint8_t*  | pc"
        sz: "Total: 24 bytes"
      }
    }
    
    interp_exec: {
      label: "Generic Bytecode Execution"
      width: 220
      style: {
        fill: "#f8d7da"
        stroke: "#dc3545"
        stroke-dash: 4
        border-radius: 6
      }
      code: |'c
        val_b = stack_pop();
        val_a = stack_pop();
        res = generic_add(val_a, val_b);
      '|
    }
    
    exit_slow: "Slow Exit" {
      shape: oval
      width: 160
      style: {
        fill: "#f8d7da"
        stroke: "#dc3545"
        stroke-dash: 4
      }
    }
  }
}

cost_benefit: {
  near: bottom-left
  label: "Heuristic Cost-Benefit"
  width: 400
  style: {
    fill: "#e8eaf6"
    stroke: "#3f51b5"
    border-radius: 8
  }
  
  cost_section: {
    label: "Guard Overheads"
    style.fill: transparent
    width: 380
    list: |md
      - **Check**: `test rax, tag_mask` (1-cycle)
      - **Branch**: `jnz deopt_stub` (BP dependent)
      - **Binary Size**: +12 bytes/guard
    |
  }
  
  verdict: {
    label: "Net Optimization Verdict"
    style: {
      fill: "#c8e6c9"
      border-radius: 4
      bold: true
    }
    width: 380
    content: |md
      **Speculation Win** if P(pass) > 99.2%
      Branch predictor hides guard cost.
    |
  }
}

side_table: {
  near: top-right
  label: "Deopt Metadata Table"
  width: 300
  style: {
    fill: "#fce4ec"
    stroke: "#c2185b"
    border-radius: 8
  }
  table_struct: {
    shape: sql_table
    label: "struct DeoptMap"
    f0: "0x00 | uint8_t* | native_pc"
    f1: "0x08 | uint32_t | bytecode_off"
    f2: "0x0C | uint16_t | num_slots"
    f3: "0x0E | uint16_t | padding"
    sz: "Total: 16 bytes"
  }
}

# Connections
row1.left_col.entry -> row1.left_col.load_args: "Context | load"
row1.left_col.load_args -> row1.left_col.guard1: "Registers | check"

row1.left_col.guard1 -> row1.left_col.guard2: "int | pass" {
  style: {
    stroke: "#28a745"
    stroke-width: 2
  }
}
row1.left_col.guard1 -> row1.right_col.deopt_stub: "non-int | FAIL" {
  style: {
    stroke: "#dc3545"
    stroke-dash: 4
  }
}

row1.left_col.guard2 -> row1.left_col.optimized_block: "int | pass" {
  style: {
    stroke: "#28a745"
    stroke-width: 2
  }
}
row1.left_col.guard2 -> row1.right_col.deopt_stub: "non-int | FAIL" {
  style: {
    stroke: "#dc3545"
    stroke-dash: 4
  }
}

row1.left_col.optimized_block -> row1.left_col.exit_fast: "uint64_t"
row1.right_col.deopt_stub -> row1.right_col.interp_frame: "metadata | map"
row1.right_col.interp_frame -> row1.right_col.interp_exec: "stack_t*"
row1.right_col.interp_exec -> row1.right_col.exit_slow: "Object*"