direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Linear Scan Register Allocation"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  phase1: {
    direction: down
    label: "Phase 1: Compute Live Intervals"
    bytecode_input: {
      label: "Bytecode Instructions"
      width: 280
      code: |'c
        0: load  a, arg0
        1: load  b, arg1  
        2: add   c, a, b
        3: load  d, arg2
        4: mul   e, c, d
        5: sub   f, e, a
        6: ret   f
      '|
    }
    compute_intervals: {
      label: "Compute Live Intervals"
      shape: diamond
      width: 160
    }
    interval_table: {
      label: "Live Intervals (sorted by start)"
      shape: sql_table
      a: "a   | [0, 5] | def@0, use@2,5"
      b: "b   | [1, 2] | def@1, use@2"
      c: "c   | [2, 4] | def@2, use@4"
      d: "d   | [3, 4] | def@3, use@4"
      e: "e   | [4, 5] | def@4, use@5"
      f: "f   | [5, 6] | def@5, use@6"
    }
  }
  phase2: {
    direction: down
    label: "Phase 2: Register Allocation"
    start: {
      label: "Start\n(sort by start position)"
      shape: oval
    }
    check_active: {
      label: "Any expired in\nActive list?"
      shape: diamond
      width: 140
    }
    expire_old: {
      label: "Remove expired\nFree their registers"
      shape: rectangle
      style.fill: honeydew
    }
    check_free: {
      label: "Free register\navailable?"
      shape: diamond
      width: 130
    }
    alloc_free: {
      label: "Allocate from\nFree list"
      shape: rectangle
      style.fill: honeydew
    }
    spill_decision: {
      label: "Spill current OR\nSpill from Active?"
      shape: diamond
      width: 150
    }
    spill_current: {
      label: "Spill current\ninterval to stack"
      shape: rectangle
      style.fill: "#FFE4E1"
    }
    spill_active: {
      label: "Spill longest-active\nTake its register"
      shape: rectangle
      style.fill: "#FFE4E1"
    }
    add_active: {
      label: "Add interval\nto Active list"
      shape: rectangle
      style.fill: "#E6F3FF"
    }
    more_intervals: {
      label: "More\nintervals?"
      shape: diamond
      width: 100
    }
    done: {
      label: "Done\nMapping complete"
      shape: oval
    }
    start -> check_active
    check_active -> expire_old: "Yes"
    expire_old -> check_free
    check_active -> check_free: "No"
    check_free -> alloc_free: "Yes"
    alloc_free -> add_active
    check_free -> spill_decision: "No"
    spill_decision -> spill_current: "Current ends\nlater"
    spill_decision -> spill_active: "Active ends\nlater"
    spill_current -> add_active
    spill_active -> add_active
    add_active -> more_intervals
    more_intervals -> check_active: "Yes"
    more_intervals -> done: "No"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  example_title: {
    label: "Example: 4 Registers, 6 Live Ranges"
    shape: text
    style: {
      font-size: 20
      bold: true
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  timeline: {
    direction: down
    label: "Instruction Timeline"
    time_header: {
      shape: sql_table
      label: "Position"
      t0: "0"
      t1: "1"
      t2: "2"
      t3: "3"
      t4: "4"
      t5: "5"
      t6: "6"
    }
    reg_rax: {
      label: "RAX (reg 0)"
      shape: sql_table
      style.fill: "#E6F3FF"
      s0: "a"
      s1: "a"
      s2: "a"
      s3: "a"
      s4: "a"
      s5: "a"
      s6: "-"
    }
    reg_rbx: {
      label: "RBX (reg 1)"
      shape: sql_table
      style.fill: "#FFF9E6"
      s0: "-"
      s1: "b"
      s2: "b"
      s3: "c"
      s4: "c"
      s5: "e"
      s6: "e"
    }
    reg_rcx: {
      label: "RCX (reg 2)"
      shape: sql_table
      style.fill: "#E6FFE6"
      s0: "-"
      s1: "-"
      s2: "c"
      s3: "d"
      s4: "d"
      s5: "f"
      s6: "f"
    }
    reg_rdx: {
      label: "RDX (reg 3)"
      shape: sql_table
      style.fill: "#FFE6F0"
      s0: "-"
      s1: "-"
      s2: "-"
      s3: "-"
      s4: "-"
      s5: "-"
      s6: "-"
    }
  }
  allocation_steps: {
    direction: down
    label: "Allocation Steps"
    step1: {
      label: "Step 1: Allocate a → RAX"
      width: 300
      code: |'text
        Interval a: [0, 5]
        Active: {a}
        Free: {RBX, RCX, RDX}
      '|
    }
    step2: {
      label: "Step 2: Allocate b → RBX"
      width: 300
      code: |'text
        Interval b: [1, 2]
        Active: {a, b}
        Free: {RCX, RDX}
      '|
    }
    step3: {
      label: "Step 3: Allocate c → RCX"
      width: 300
      code: |'text
        Interval c: [2, 4]
        Expire b (ends at 2)
        Active: {a, c}
        Free: {RBX, RDX}
      '|
    }
    step4: {
      label: "Step 4: Allocate d → RBX"
      width: 300
      code: |'text
        Interval d: [3, 4]
        Active: {a, c, d}
        Free: {RDX}
      '|
    }
    step5: {
      label: "Step 5: Allocate e → RBX"
      width: 300
      code: |'text
        Interval e: [4, 5]
        Expire c, d (both end at 4)
        Active: {a, e}
        Free: {RCX, RDX}
      '|
    }
    step6: {
      label: "Step 6: Allocate f → RCX"
      width: 300
      code: |'text
        Interval f: [5, 6]
        Expire a, e (both end at 5)
        Active: {f}
        Free: {RAX, RBX, RDX}
      '|
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  final_mapping: {
    label: "Final Register Mapping"
    shape: sql_table
    a_map: "a | RAX | [0, 5]"
    b_map: "b | RBX | [1, 2]"
    c_map: "c | RCX | [2, 4]"
    d_map: "d | RBX | [3, 4]"
    e_map: "e | RBX | [4, 5]"
    f_map: "f | RCX | [5, 6]"
    note: "No spills needed (4 regs ≥ max active)"
  }
  spill_example: {
    direction: down
    label: "Spill Scenario (if only 2 registers)"
    spill_state: {
      label: "When Active is full"
      shape: rectangle
      width: 320
      style.fill: "#FFE4E1"
      code: |'text
        Active: {a→RAX, c→RBX}
        Free: {}
        Next: d [3, 4]
        Compare end points:
        - a ends at 5 (longest)
        - c ends at 4
        - d ends at 4 (current)
        Decision: Spill a to stack
        Take RAX for d
      '|
    }
    spill_result: {
      label: "Spill Code Generated"
      width: 320
      code: |'c
        // Spill a before allocating d
        mov [rbp-8], rax   // spill a
        // Now RAX free for d
        mov rax, rdi       // load d
      '|
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  label: ""
  style: {
    stroke: transparent
    fill: transparent
  }
  alloc: {
    label: "Allocate"
    shape: rectangle
    style.fill: honeydew
  }
  spill: {
    label: "Spill"
    shape: rectangle
    style.fill: "#FFE4E1"
  }
  active: {
    label: "Add to Active"
    shape: rectangle
    style.fill: "#E6F3FF"
  }
}
phase1.bytecode_input -> phase1.compute_intervals: "Parse"
phase1.compute_intervals -> phase1.interval_table: "Build"
phase1.interval_table -> phase2.start: "Sorted list"
timeline.time_header -> timeline.reg_rax: "Position"
timeline.reg_rax -> timeline.reg_rbx: "RAX"
timeline.reg_rbx -> timeline.reg_rcx: "RBX"
timeline.reg_rcx -> timeline.reg_rdx: "RCX"