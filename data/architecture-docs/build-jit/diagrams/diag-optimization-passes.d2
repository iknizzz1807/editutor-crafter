direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Optimization Pass Pipeline"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
input_ir: {
  label: "Input IR"
  shape: class
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  op0: "PUSH_CONST 10"
  op1: "PUSH_CONST 20"
  op2: "ADD"
  op3: "STORE_LOCAL 0"
  op4: "PUSH_CONST 5"
  op5: "STORE_LOCAL 0"
  op6: "LOAD_LOCAL 0"
  op7: "PUSH_CONST 8"
  op8: "MUL"
  op9: "RET"
}
pass1: {
  label: "Pass 1: Constant Folding"
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  width: 280
  desc: {
    label: "Compute constant expressions at compile time"
    shape: text
    style.font-size: 14
    style.italic: true
  }
  before: {
    label: "Before"
    shape: text
    style.bold: true
    style.font-color: "#D32F2F"
  }
  ex1_before: {
    label: "PUSH_CONST 10\nPUSH_CONST 20\nADD"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
  arrow1: {
    label: "→"
    shape: text
    style.font-size: 24
  }
  after: {
    label: "After"
    shape: text
    style.bold: true
    style.font-color: "#388E3C"
  }
  ex1_after: {
    label: "PUSH_CONST 30"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
}
ir_after_fold: {
  label: "IR After Folding"
  shape: class
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  op0: "PUSH_CONST 30"
  op1: "STORE_LOCAL 0"
  op2: "PUSH_CONST 5"
  op3: "STORE_LOCAL 0"
  op4: "LOAD_LOCAL 0"
  op5: "PUSH_CONST 8"
  op6: "MUL"
  op7: "RET"
}
pass2: {
  label: "Pass 2: Dead Store Elimination"
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  style.stroke-width: 2
  width: 320
  desc: {
    label: "Remove stores that are overwritten before being read"
    shape: text
    style.font-size: 14
    style.italic: true
  }
  before: {
    label: "Before"
    shape: text
    style.bold: true
    style.font-color: "#D32F2F"
  }
  ex2_before: {
    label: "STORE_LOCAL 0  ; dead!\nPUSH_CONST 5\nSTORE_LOCAL 0  ; overwrites"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
  arrow2: {
    label: "→"
    shape: text
    style.font-size: 24
  }
  after: {
    label: "After"
    shape: text
    style.bold: true
    style.font-color: "#F9A825"
  }
  ex2_after: {
    label: "PUSH_CONST 5\nSTORE_LOCAL 0"
    shape: rectangle
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
}
ir_after_dse: {
  label: "IR After DSE"
  shape: class
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  style.stroke-width: 2
  op0: "PUSH_CONST 5"
  op1: "STORE_LOCAL 0"
  op2: "LOAD_LOCAL 0"
  op3: "PUSH_CONST 8"
  op4: "MUL"
  op5: "RET"
}
pass3: {
  label: "Pass 3: Strength Reduction"
  shape: rectangle
  style.fill: "#E1BEE7"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  width: 300
  desc: {
    label: "Replace expensive ops with cheaper equivalents"
    shape: text
    style.font-size: 14
    style.italic: true
  }
  before: {
    label: "Before"
    shape: text
    style.bold: true
    style.font-color: "#D32F2F"
  }
  ex3_before: {
    label: "PUSH_CONST 8\nMUL    ; x * 8"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
  arrow3: {
    label: "→"
    shape: text
    style.font-size: 24
  }
  after: {
    label: "After"
    shape: text
    style.bold: true
    style.font-color: "#7B1FA2"
  }
  ex3_after: {
    label: "PUSH_CONST 3\nSHL    ; x << 3"
    shape: rectangle
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
  }
}
output_ir: {
  label: "Optimized Output IR"
  shape: class
  style.fill: "#C5E1A5"
  style.stroke: "#33691E"
  style.stroke-width: 3
  op0: "PUSH_CONST 5"
  op1: "STORE_LOCAL 0"
  op2: "LOAD_LOCAL 0"
  op3: "PUSH_CONST 3"
  op4: "SHL"
  op5: "RET"
}
stats: {
  label: "Optimization Summary"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  near: bottom-center
  width: 400
  original: "Original: 10 ops"
  optimized: "Optimized: 6 ops"
  reduction: "40% reduction"
  saved: {
    label: "Saved: 1 ADD, 1 STORE_LOCAL, 1 PUSH_CONST"
    shape: text
    style.font-size: 12
    style.font-color: "#616161"
  }
}
input_ir -> pass1: "parse"
pass1 -> ir_after_fold: "fold"
ir_after_fold -> pass2: "analyze liveness"
pass2 -> ir_after_dse: "eliminate"
ir_after_dse -> pass3: "identify patterns"
pass3 -> output_ir: "reduce"
output_ir -> stats: "generate report"
legend: {
  near: bottom-right
  style.fill: transparent
  dead: {
    label: "Red = Dead/Expensive"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    width: 120
  }
  kept: {
    label: "Green = Optimized/Kept"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    width: 120
  }
}