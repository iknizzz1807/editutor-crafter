direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Production JIT Architecture Comparison
  ## Tiering Strategies and Optimization Approaches
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  v8: {
    direction: down
    label: "V8 (Chrome/Node.js)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2
    ignition: {
      label: "Tier 0: Ignition"
      shape: rectangle
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      desc: |md
        - Bytecode interpreter
        - Collects type feedback
        - Zero compilation cost
      |
    }
    sparkplug: {
      label: "Tier 1: Sparkplug"
      shape: rectangle
      style.fill: "#90CAF9"
      style.stroke: "#1976D2"
      desc: |md
        - Baseline JIT
        - Fast compilation
        - Minimal optimization
      |
    }
    turbofan: {
      label: "Tier 2: TurboFan"
      shape: rectangle
      style.fill: "#64B5F6"
      style.stroke: "#1976D2"
      style.font-color: "#0D47A1"
      desc: |md
        - Optimizing JIT
        - Speculative optimization
        - Inline caching, deopt
      |
    }
    ignition -> sparkplug: "hot functions"
    sparkplug -> turbofan: "very hot"
  }
  hotspot: {
    direction: down
    label: "HotSpot JVM"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2
    interp_hs: {
      label: "Tier 0: Interpreter"
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
      desc: |md
        - Bytecode interpreter
        - Method counters
        - Invocation profiling
      |
    }
    c1: {
      label: "Tier 1: C1 (Client)"
      shape: rectangle
      style.fill: "#FFCC80"
      style.stroke: "#E65100"
      desc: |md
        - Quick compilation
        - Local optimizations
        - Limited inlining
      |
    }
    c2: {
      label: "Tier 2: C2 (Server)"
      shape: rectangle
      style.fill: "#FFB74D"
      style.stroke: "#E65100"
      style.font-color: "#BF360C"
      desc: |md
        - Aggressive optimization
        - Escape analysis
        - Loop optimizations
      |
    }
    interp_hs -> c1: "1,000+ calls"
    c1 -> c2: "10,000+ calls"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  luajit: {
    direction: down
    label: "LuaJIT"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    interp_lj: {
      label: "Interpreter"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      desc: |md
        - Fast bytecode VM
        - Direct-threaded dispatch
        - Records hot loops
      |
    }
    tracer: {
      label: "Tracing JIT"
      shape: rectangle
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
      style.font-color: "#1B5E20"
      desc: |md
        - Records hot traces
        - Linear IR (SSA)
        - Trace specialization
      |
    }
    interp_lj -> tracer: "loop threshold"
  }
  thisproject: {
    direction: down
    label: "This Project"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
    our_interp: {
      label: "Tier 0: Interpreter"
      shape: rectangle
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
      desc: |md
        - Stack-based bytecode
        - Invocation counters
        - Hot path detection
      |
    }
    our_jit: {
      label: "Tier 1: Optimizing JIT"
      shape: rectangle
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
      style.font-color: "#4A148C"
      desc: |md
        - x86-64 code emission
        - Register allocation
        - Guards + deoptimization
      |
    }
    our_interp -> our_jit: "1,000 calls"
  }
}
legend: {
  near: bottom-center
  label: "Comparison Matrix"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  matrix: {
    shape: sql_table
    label: "Architecture Comparison"
    col1: "JIT | Tiers | Deopt | Tracing | Profile-Guided"
    v8row: "V8 | 3+ | Yes | No | Yes (type feedback)"
    hsrow: "HotSpot | 2-4 | Yes | No | Yes (counters)"
    ljrow: "LuaJIT | 2 | Yes | Yes | Yes (trace exits)"
    ourrow: "This Project | 2 | Yes | No | Yes (counters)"
  }
}
row1 -> row2: "Complexity vs. Performance Trade-off" {
  style.stroke-dash: 5
  style.stroke: "#757575"
  style.font-color: "#616161"
}