direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Function Prologue and Epilogue Structure
  System V AMD64 ABI — Callee-Saved Register Preservation
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  prologue: {
    direction: down
    label: "PROLOGUE (Function Entry)"
    style.fill: "#E8F4E8"
    style.stroke: "#2D7D2D"
    style.stroke-width: 2
    p1: {
      label: "push rbp"
      width: 280
      code: |'asm
        0x55              ; 1 byte
        ; rsp -= 8, [rsp] = rbp
      '|
    }
    p1_note: "Save caller's frame pointer" {
      shape: text
      style.font-color: "#2D7D2D"
      style.font-size: 12
    }
    p2: {
      label: "mov rbp, rsp"
      width: 280
      code: |'asm
        0x48 0x89 0xE5    ; 3 bytes
        ; rbp = rsp (establish our frame)
      '|
    }
    p2_note: "Establish new frame pointer" {
      shape: text
      style.font-color: "#2D7D2D"
      style.font-size: 12
    }
    p3: {
      label: "push rbx"
      width: 280
      code: |'asm
        0x53              ; 1 byte
        ; rsp -= 8, [rsp] = rbx
      '|
    }
    p3_note: "Save callee-saved rbx" {
      shape: text
      style.font-color: "#2D7D2D"
      style.font-size: 12
    }
    p4: {
      label: "push r12"
      width: 280
      code: |'asm
        0x41 0x54         ; 2 bytes (REX.B + push)
        ; rsp -= 8, [rsp] = r12
      '|
    }
    p4_note: "Save callee-saved r12" {
      shape: text
      style.font-color: "#2D7D2D"
      style.font-size: 12
    }
    p5: {
      label: "push r13"
      width: 280
      code: |'asm
        0x41 0x55         ; 2 bytes (REX.B + push)
        ; rsp -= 8, [rsp] = r13
      '|
    }
    p5_note: "Save callee-saved r13" {
      shape: text
      style.font-color: "#2D7D2D"
      style.font-size: 12
    }
    p6: {
      label: "sub rsp, N"
      width: 280
      code: |'asm
        0x48 0x83 0xEC N  ; 4 bytes (N < 128)
        ; rsp -= N (local var space + alignment)
      '|
    }
    p6_note: "Allocate stack space for locals" {
      shape: text
      style.font-color: "#2D7D2D"
      style.font-size: 12
    }
    p_total: {
      shape: sql_table
      label: "Prologue Summary (jit_emitter.c)"
      bytes: "Total | 13 bytes (with N<128)"
      effect: "Stack Effect | -40 bytes"
      align: "rsp % 16 | 0 (aligned)"
    }
    p1 -> p2 -> p3 -> p4 -> p5 -> p6 -> p_total
  }
  spacer: {
    width: 60
    style.fill: transparent
    style.stroke: transparent
  }
  epilogue: {
    direction: down
    label: "EPILOGUE (Function Exit)"
    style.fill: "#F4E8E8"
    style.stroke: "#7D2D2D"
    style.stroke-width: 2
    e1: {
      label: "add rsp, N"
      width: 280
      code: |'asm
        0x48 0x83 0xC4 N  ; 4 bytes (N < 128)
        ; rsp += N (deallocate locals)
      '|
    }
    e1_note: "Deallocate local variable space" {
      shape: text
      style.font-color: "#7D2D2D"
      style.font-size: 12
    }
    e2: {
      label: "pop r13"
      width: 280
      code: |'asm
        0x41 0x5D         ; 2 bytes (REX.B + pop)
        ; r13 = [rsp], rsp += 8
      '|
    }
    e2_note: "Restore callee-saved r13" {
      shape: text
      style.font-color: "#7D2D2D"
      style.font-size: 12
    }
    e3: {
      label: "pop r12"
      width: 280
      code: |'asm
        0x41 0x5C         ; 2 bytes (REX.B + pop)
        ; r12 = [rsp], rsp += 8
      '|
    }
    e3_note: "Restore callee-saved r12" {
      shape: text
      style.font-color: "#7D2D2D"
      style.font-size: 12
    }
    e4: {
      label: "pop rbx"
      width: 280
      code: |'asm
        0x5B              ; 1 byte
        ; rbx = [rsp], rsp += 8
      '|
    }
    e4_note: "Restore callee-saved rbx" {
      shape: text
      style.font-color: "#7D2D2D"
      style.font-size: 12
    }
    e5: {
      label: "pop rbp"
      width: 280
      code: |'asm
        0x5D              ; 1 byte
        ; rbp = [rsp], rsp += 8
      '|
    }
    e5_note: "Restore caller's frame pointer" {
      shape: text
      style.font-color: "#7D2D2D"
      style.font-size: 12
    }
    e6: {
      label: "ret"
      width: 280
      code: |'asm
        0xC3              ; 1 byte
        ; rip = [rsp], rsp += 8
      '|
    }
    e6_note: "Return to caller (result in rax)" {
      shape: text
      style.font-color: "#7D2D2D"
      style.font-size: 12
    }
    e_total: {
      shape: sql_table
      label: "Epilogue Summary (jit_emitter.c)"
      bytes: "Total | 11 bytes (with N<128)"
      effect: "Stack Effect | +40 bytes"
      returns: "Return Value | rax"
    }
    e1 -> e2 -> e3 -> e4 -> e5 -> e6 -> e_total
  }
}
row2: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  stack_diagram: {
    direction: down
    label: "Stack Frame Layout (after prologue)"
    style.fill: "#F5F5F5"
    style.stroke: "#666666"
    frame: {
      shape: sql_table
      label: "Stack Frame (rbp-relative)"
      h0: "rbp+16 | arg7+ | Stack args (if > 6)"
      h1: "rbp+8  | ret   | Return address"
      h2: "rbp+0  | old   | Saved rbp"
      h3: "rbp-8  | rbx   | Saved rbx"
      h4: "rbp-16 | r12   | Saved r12"
      h5: "rbp-24 | r13   | Saved r13"
      h6: "rbp-32 | local | Local vars..."
      h7: "rbp-N  | rsp   | Stack pointer"
    }
    alignment_note: |md
      **Alignment Check:**
      - After `call`: rsp % 16 == 8
      - After `push rbp`: rsp % 16 == 0 ✓
      - After 3 more pushes: rsp % 16 == 0 ✓
      - After `sub rsp, N` (N aligned): rsp % 16 == 0 ✓
    | {shape: rectangle}
  }
  legend: {
    direction: down
    label: "Register Roles"
    style.fill: "#FFF8E8"
    style.stroke: "#B8860B"
    reg_table: {
      shape: sql_table
      label: "ABI Register Classification"
      r1: "rbx   | Callee-saved | Must restore"
      r2: "r12   | Callee-saved | Must restore"
      r3: "r13   | Callee-saved | Must restore"
      r4: "r14   | Callee-saved | Must restore"
      r5: "r15   | Callee-saved | Must restore"
      r6: "rbp   | Frame ptr    | Must restore"
      r7: "rax   | Return val   | Caller-saved"
      r8: "r10   | Scratch      | Caller-saved"
    }
  }
}
flow: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  caller: "Caller" {
    shape: rectangle
    style.fill: "#E0E0E0"
  }
  pro_entry: "Prologue\n(13 bytes)" {
    shape: rectangle
    style.fill: "#E8F4E8"
  }
  body: "Function\nBody" {
    shape: rectangle
    style.fill: "#E0F0FF"
  }
  epi_entry: "Epilogue\n(11 bytes)" {
    shape: rectangle
    style.fill: "#F4E8E8"
  }
  ret_target: "Return to\nCaller" {
    shape: rectangle
    style.fill: "#E0E0E0"
  }
  caller -> pro_entry: "call"
  pro_entry -> body: "rsp aligned"
  body -> epi_entry: "result in rax"
  epi_entry -> ret_target: "ret"
}