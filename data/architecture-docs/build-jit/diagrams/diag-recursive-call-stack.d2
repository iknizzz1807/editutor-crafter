direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Recursive Call Stack: factorial(5)"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}
stack_frames: {
  direction: down
  frame5: {
    label: "Frame 5: factorial(1) — BASE CASE"
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    frame5_layout: {
      direction: right
      style: {
        fill: transparent
        stroke: transparent
      }
      frame5_memory: {
        direction: down
        label: ""
        style: {
          fill: transparent
          stroke: transparent
        }
        frame5_stack: {
          shape: sql_table
          label: "Stack Memory (grows down)"
          ra: "0x00 | uint64 | return_addr"
          rbp: "0x08 | uint64 | saved_rbp"
          rbx: "0x10 | uint64 | saved_rbx"
          n_val: "0x18 | int64  | n = 1"
          pad: "0x20 | uint8  | padding"
          total: "Total: 40 bytes"
        }
      }
      frame5_code: {
        direction: down
        label: ""
        style: {
          fill: transparent
          stroke: transparent
        }
        frame5_jit: {
          label: "JIT-Compiled Code (identical to C)"
          width: 320
          code: |'asm
  factorial:                  ; entry point
    push   rbp                ; save caller's frame
    mov    rbp, rsp           ; establish new frame
    push   rbx                ; save callee-saved reg
    sub    rsp, 8             ; local space + alignment
    mov    rbx, rdi           ; rbx = n (arg in rdi)
    cmp    rbx, 1             ; n <= 1?
    jle    .base_case
    ; recursive case...
  .base_case:
    mov    rax, 1             ; return 1
    add    rsp, 8
    pop    rbx
    pop    rbp
    ret
          '|
        }
      }
    }
  }
  arrow_5_to_4: {
    shape: text
    label: "▲ rsp moves down 40 bytes per call"
    style: {
      font-size: 14
      italic: true
    }
  }
  frame4: {
    label: "Frame 4: factorial(2)"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
    frame4_content: {
      direction: right
      style: {
        fill: transparent
        stroke: transparent
      }
      frame4_table: {
        shape: sql_table
        label: "Stack Frame @ RSP+40"
        ra4: "return_addr → factorial(3)"
        rbp4: "saved_rbp → Frame 3"
        rbx4: "saved_rbx (caller's)"
        n4: "n = 2"
        state4: "rax = ? (waiting for ret)"
      }
      frame4_note: {
        shape: rectangle
        label: "Waiting for factorial(1) to return"
        style: {
          fill: "#FFE0B2"
          stroke: "#E65100"
          italic: true
        }
      }
    }
  }
  arrow_4_to_3: {
    shape: text
    label: "▼"
    style: {
      font-size: 20
    }
  }
  frame3: {
    label: "Frame 3: factorial(3)"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
    frame3_table: {
      shape: sql_table
      label: "Stack Frame @ RSP+80"
      ra3: "return_addr → factorial(4)"
      rbp3: "saved_rbp → Frame 2"
      rbx3: "saved_rbx"
      n3: "n = 3"
      state3: "rax = ? (waiting)"
    }
  }
  arrow_3_to_2: {
    shape: text
    label: "▼"
    style: {
      font-size: 20
    }
  }
  frame2: {
    label: "Frame 2: factorial(4)"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
    frame2_table: {
      shape: sql_table
      label: "Stack Frame @ RSP+120"
      ra2: "return_addr → factorial(5)"
      rbp2: "saved_rbp → Frame 1"
      rbx2: "saved_rbx"
      n2: "n = 4"
      state2: "rax = ? (waiting)"
    }
  }
  arrow_2_to_1: {
    shape: text
    label: "▼"
    style: {
      font-size: 20
    }
  }
  frame1: {
    label: "Frame 1: factorial(5) — INITIAL CALL"
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 3
    }
    frame1_table: {
      shape: sql_table
      label: "Stack Frame @ RSP+160 (near stack top)"
      ra1: "return_addr → caller (main)"
      rbp1: "saved_rbp → main's frame"
      rbx1: "saved_rbx"
      n1: "n = 5"
      state1: "rax = ? (waiting)"
    }
  }
}
call_flow: {
  direction: right
  near: bottom-center
  style: {
    fill: transparent
    stroke: transparent
  }
  flow_label: {
    shape: text
    label: "Call Sequence: factorial(5) → factorial(4) → factorial(3) → factorial(2) → factorial(1) → return 1"
    style: {
      font-size: 16
      bold: true
    }
  }
}
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
  }
  legend_title: {
    shape: text
    label: "Stack Layout (per frame)"
    style: {
      bold: true
      underline: true
    }
  }
  legend_items: {
    direction: down
    label: ""
    style: {
      fill: transparent
      stroke: transparent
    }
    item1: {
      shape: text
      label: "• return_addr: Where to resume after ret"
    }
    item2: {
      shape: text
      label: "• saved_rbp: Caller's frame pointer chain"
    }
    item3: {
      shape: text
      label: "• saved_rbx: Callee-saved register (ABI)"
    }
    item4: {
      shape: text
      label: "• n: Function argument in callee-saved reg"
    }
    item5: {
      shape: text
      label: "• padding: 16-byte stack alignment"
    }
  }
  legend_note: {
    shape: text
    label: "JIT frames use identical layout to C!"
    style: {
      bold: true
      font-color: "#2E7D32"
    }
  }
}
comparison: {
  near: center-left
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
  comp_title: {
    shape: text
    label: "C vs JIT Stack Frames"
    style: {
      bold: true
      font-size: 18
    }
  }
  comp_content: {
    shape: rectangle
    width: 280
    label: |md
      **C compiler (gcc -O0):**
      
      push rbp
      mov rbp, rsp
      push rbx
      sub rsp, 8
      
      **JIT compiler emits:**
      
      push rbp
      mov rbp, rsp
      push rbx
      sub rsp, 8
      
      **Identical byte-for-byte!**
    |
    style: {
      font: mono
      font-size: 12
    }
  }
}