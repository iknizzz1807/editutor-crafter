direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Register Spilling Mechanism
  **Data Walk: Expression Tree → Register Assignment → Stack Spill**
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  expr_tree: {
    direction: down
    label: "Expression Tree (jit_compiler.c)"
    root: {
      label: "MUL (*)"
      shape: diamond
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    add_node: {
      label: "ADD (+)"
      shape: diamond
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    const_10: {
      label: "10"
      shape: circle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    const_5: {
      label: "5"
      shape: circle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    local_1: {
      label: "local1"
      shape: circle
      style.fill: "#F3E5F5"
      style.stroke: "#9C27B0"
    }
    add_node -> root
    const_10 -> root
    add_node -> local_1
    add_node -> const_5
  }

  reg_pool: {
    direction: down
    label: "Register Pool (7 available)"
    reg_header: {
      label: "RegAllocator.free_regs[]"
      shape: rectangle
      style.fill: "#ECEFF1"
      style.stroke: "#607D8B"
    }
    regs: {
      direction: right
      label: ""
      r8: {
        label: "r8"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      r9: {
        label: "r9"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      r10: {
        label: "r10"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      r11: {
        label: "r11"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      rcx: {
        label: "rcx"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      rsi: {
        label: "rsi"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      rdi: {
        label: "rdi"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
    }
    legend: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      legend_free: "■ Free" { style.font-color: "#4CAF50" }
      legend_used: "■ Allocated" { style.font-color: "#F44336" }
      legend_spill: "■ Spilled" { style.font-color: "#2196F3" }
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  compilation_steps: {
    direction: down
    label: "Compilation Steps"
    step1: {
      label: "T1: Load local1 → r8"
      width: 320
      code: |'c
        Reg r = ra_alloc(ra, e);  // returns r8
        emit_load_local(e, r, 1);
        // free_count: 7 -> 6
      '|
      style.fill: "#E8F5E9"
    }
    step2: {
      label: "T2: Load const 5 → r9"
      width: 320
      code: |'c
        emit_mov_r64_imm32(e, r9, 5);
        // r9 = 5
        // free_count: 6 -> 5
      '|
      style.fill: "#E8F5E9"
    }
    step3: {
      label: "T3: ADD r8, r9 → r8"
      width: 320
      code: |'c
        emit_add_r64_r64(e, r8, r9);
        ra_free(ra, r9); 
        // r8 = local1 + 5, free: 6
      '|
      style.fill: "#E3F2FD"
    }
    step4: {
      label: "T4: Load const 10 → r9"
      width: 320
      code: |'c
        emit_mov_r64_imm32(e, r9, 10);
        // r9 = 10, free: 5
      '|
      style.fill: "#E8F5E9"
    }
    step5: {
      label: "T5: MUL r8, r9 → rax"
      width: 320
      code: |'c
        emit_imul_r64_r64(e, r8, r9);
        ra_free(ra, r8);
        ra_free(ra, r9);
      '|
      style.fill: "#E3F2FD"
    }
  }

  spill_scenario: {
    direction: down
    label: "Spill Scenario (Pool Exhausted)"
    before_spill: {
      label: "State: 0 free registers"
      regs_state: {
        direction: right
        style.stroke: transparent
        r8_v0: "r8|v0" { style.fill: "#FFCDD2" }
        r9_v1: "r9|v1" { style.fill: "#FFCDD2" }
        r10_v2: "r10|v2" { style.fill: "#FFCDD2" }
        r11_v3: "r11|v3" { style.fill: "#FFCDD2" }
        rcx_v4: "rcx|v4" { style.fill: "#FFCDD2" }
        rsi_v5: "rsi|v5" { style.fill: "#FFCDD2" }
        rdi_v6: "rdi|v6" { style.fill: "#FFCDD2" }
      }
    }
    spill_action: {
      label: "ra_alloc: Force Spill"
      width: 380
      code: |'c
        VReg* victim = &ra->vregs[oldest_idx]; // v0
        int offset = SPILL_BASE + (slot * 8);
        // mov [rbp - 16], r8
        emit_mov_m64_r64(e, RBP, -offset, R8);
        victim->reg = -1;
        victim->spill_slot = slot;
        return R8; // v7 gets r8
      '|
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    after_spill: {
      label: "Result: vreg0 Spilled"
      regs_after: {
        direction: right
        style.stroke: transparent
        r8_v7: "r8|v7" { style.fill: "#C8E6C9" }
        others: "...v1-v6" { style.fill: "#FFCDD2" }
      }
      spilled_note: {
        label: "vreg0 -> [rbp - 16]"
        shape: rectangle
        style.fill: "#BBDEFB"
        style.stroke: "#2196F3"
      }
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  stack_frame: {
    direction: down
    label: "Stack Frame (jit_compiler.c)"
    layout: {
      shape: sql_table
      label: "Memory Map (rbp relative)"
      h0: "+0x08 | uint64_t | Return Address"
      h1: "+0x00 | uint64_t | Saved RBP"
      h2: "-0x08 | uint64_t | Saved RBX (callee-saved)"
      s0: "-0x10 | uint64_t | Spill Slot 0 (vreg0)"
      s1: "-0x18 | uint64_t | Spill Slot 1 (vreg3)"
      l0: "-0x20 | uint64_t | Local Var 0"
      l1: "-0x28 | uint64_t | Local Var 1"
      sz: "Total Frame: 48 bytes (aligned 16)"
    }
  }

  vreg_struct: {
    direction: down
    label: "Register Metadata"
    vreg: {
      shape: class
      label: "struct VReg"
      reg: "int // reg_id or -1"
      spill_slot: "int"
      is_live: "bool"
    }
    allocator: {
      shape: class
      label: "struct RegAllocator"
      vregs: "VReg[64]"
      free_mask: "uint32_t"
      stack_high_water: "int"
      +ra_alloc(ra): "int"
      +ra_free(ra, reg): "void"
      +ra_spill(ra, vreg): "void"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  reload_flow: {
    direction: down
    label: "Reload Logic"
    reload_code: {
      label: "ra_reload: Spill -> Reg"
      width: 400
      code: |'c
        VReg* vr = &ra->vregs[vreg_idx];
        if (vr->reg != -1) return;
        int off = SPILL_BASE + vr->spill_slot * 8;
        // mov r8, [rbp - 16]
        emit_mov_r64_m64(e, R8, RBP, -off);
        vr->reg = R8;
      '|
      style.fill: "#E8F5E9"
    }
    reload_asm: {
      label: "x86-64 Output"
      width: 400
      code: |'asm
        ; Restore vreg0 to r8
        mov r8, [rbp - 16] ; Rex.W + 8B /r
      '|
      style.fill: "#FFF8E1"
    }
  }

  metrics: {
    shape: sql_table
    label: "Spill Overhead Analysis"
    m1: "Register Op | 1 cycle"
    m2: "L1 Load     | 4 cycles"
    m3: "Store+Load  | ~12 cycles"
    m4: "Penalty     | 12x slow-down"
  }
}

# Global Data Flow Connections
row1.expr_tree -> row2.compilation_steps.step1: "compile" {style.stroke-dash: 3}
row2.compilation_steps.step1 -> row2.compilation_steps.step2 -> row2.compilation_steps.step3 -> row2.compilation_steps.step4 -> row2.compilation_steps.step5

row2.spill_scenario.before_spill -> row2.spill_scenario.spill_action -> row2.spill_scenario.after_spill

row2.spill_scenario.spill_action -> row3.stack_frame.layout: "MEM_WRITE" {
  style.stroke: "#F44336"
}
row3.stack_frame.layout -> row4.reload_flow.reload_code: "MEM_READ" {
  style.stroke: "#2196F3"
}