rex_w_section: "REX.W (Bit 3) — 64-bit Operand Size" {
  direction: down
  style: {
    fill: "#FFF8EE"
    stroke: "#CC8800"
    stroke-width: 2
    border-radius: 8
  }
  rex_w_desc: {
    shape: rectangle
    width: 560
    style: {
      fill: transparent
      stroke: transparent
    }
    code: |'c
      // 0 = Default operand size (32-bit)
      // 1 = 64-bit operand size
      uint8_t make_rex(bool w, bool r, bool x, bool b) {
          return 0x40 | (w ? 0x08 : 0) | ...;
      }
      // Example: mov rax, rbx (64-bit)
      // REX.W = 1 → 0x48
      emit_byte(0x48);  // REX prefix
      emit_byte(0x89);  // mov r/m64, r64
    '|
  }
  rex_w_effect: "When W=1: Operations use 64-bit registers (rax, rbx...) instead of 32-bit (eax, ebx...)" {
    shape: rectangle
    width: 560
    style: {
      fill: "#FFE4B5"
      stroke: "#CC8800"
      border-radius: 4
      font-size: 13
    }
  }
}
rex_r_section: "REX.R (Bit 2) — ModR/M reg Field Extension" {
  direction: down
  style: {
    fill: "#EEF5FF"
    stroke: "#0066CC"
    stroke-width: 2
    border-radius: 8
  }
  rex_r_desc: {
    shape: rectangle
    width: 560
    style: {
      fill: transparent
      stroke: transparent
    }
    code: |'c
      // Extends ModR/M reg field (bits 5-3)
      // 0 = rax-rdi (registers 0-7)
      // 1 = r8-r15 (registers 8-15)
      bool reg_needs_rex_r(Reg r) {
          return r >= 8;  // r8-r15 need extension
      }
      // Example: mov rax, r9
      // r9 is register 9, needs REX.R
      // REX.WR = 0x4C
      emit_byte(0x4C);  // REX.W | REX.R
      emit_byte(0x89);  // mov r/m64, r64
      emit_byte(0xC8);  // ModR/M: r9 → rax
    '|
  }
  rex_r_effect: "When R=1: ModR/M reg field accesses r8-r15 instead of rax-rdi" {
    shape: rectangle
    width: 560
    style: {
      fill: "#B5D8FF"
      stroke: "#0066CC"
      border-radius: 4
      font-size: 13
    }
  }
}
rex_x_section: "REX.X (Bit 1) — SIB Index Extension" {
  direction: down
  style: {
    fill: "#F8EEFF"
    stroke: "#7700CC"
    stroke-width: 2
    border-radius: 8
  }
  rex_x_desc: {
    shape: rectangle
    width: 560
    style: {
      fill: transparent
      stroke: transparent
    }
    code: |'c
      // Extends SIB index field (bits 5-3)
      // Used for scaled index addressing:
      //   [base + index * scale + disp]
      //
      // Example: mov rax, [rbp + r9*8 + 16]
      // r9 as index requires REX.X
      // REX.WX = 0x4A
      emit_byte(0x4A);  // REX.W | REX.X
      emit_byte(0x8B);  // mov r64, r/m64
      emit_byte(0x44);  // ModR/M + SIB indicator
      emit_byte(0xCD);  // SIB: r9*8 + rbp
      emit_byte(0x10);  // displacement
    '|
  }
  rex_x_effect: "When X=1: SIB index field accesses r8-r15 as index registers" {
    shape: rectangle
    width: 560
    style: {
      fill: "#D4B5FF"
      stroke: "#7700CC"
      border-radius: 4
      font-size: 13
    }
  }
}
rex_b_section: "REX.B (Bit 0) — ModR/M r/m or SIB Base Extension" {
  direction: down
  style: {
    fill: "#EEFFEE"
    stroke: "#008800"
    stroke-width: 2
    border-radius: 8
  }
  rex_b_desc: {
    shape: rectangle
    width: 560
    style: {
      fill: transparent
      stroke: transparent
    }
    code: |'c
      // Extends ModR/M r/m field OR SIB base field
      // 0 = rax-rdi / normal base
      // 1 = r8-r15 / extended base
      bool reg_needs_rex_b(Reg r) {
          return r >= 8;
      }
      // Example: mov r8, 42
      // r8 is register 8, needs REX.B
      // REX.WB = 0x49
      emit_byte(0x49);  // REX.W | REX.B
      emit_byte(0xB8);  // mov r64, imm64 (r8 variant)
      emit_uint64(42);
    '|
  }
  rex_b_effect: "When B=1: r/m field accesses r8-r15, or SIB base uses r8-r15 as base" {
    shape: rectangle
    width: 560
    style: {
      fill: "#B5FFB5"
      stroke: "#008800"
      border-radius: 4
      font-size: 13
    }
  }
}
encoding_table: "REX Prefix Value Encoding (jit_emitter.c)" {
  direction: down
  style: {
    fill: "#FAFAFA"
    stroke: "#666666"
    stroke-width: 2
    border-radius: 8
  }
  table: {
    shape: sql_table
    label: "REX Prefix Values (Base = 0x40)"
    row0: "0x40 | REX (no extensions)"
    row1: "0x48 | REX.W (64-bit operands)"
    row2: "0x49 | REX.WB (64-bit + r/m extension)"
    row3: "0x4C | REX.WR (64-bit + reg extension)"
    row4: "0x4D | REX.WRB (all three)"
    row5: "0x4A | REX.WX (64-bit + SIB index)"
    row6: "0x4E | REX.WRX (64-bit + reg + index)"
    row7: "0x4F | REX.WRXB (all four)"
  }
  note: "Note: REX prefix only needed for 64-bit operands OR extended registers (r8-r15)" {
    shape: rectangle
    width: 560
    style: {
      fill: "#FFFDE7"
      stroke: "#F9A825"
      border-radius: 4
      font-size: 12
    }
  }
}
register_map: "Register Encoding with REX Extension" {
  direction: down
  style: {
    fill: "#FAFAFA"
    stroke: "#666666"
    stroke-width: 2
    border-radius: 8
  }
  reg_table: {
    shape: sql_table
    label: "3-bit Register Code + REX Extension"
    col1: "Code | Low (REX=0) | High (REX=1)"
    row0: "000  | rax         | r8"
    row1: "001  | rcx         | r9"
    row2: "010  | rdx         | r10"
    row3: "011  | rbx         | r11"
    row4: "100  | rsp         | r12"
    row5: "101  | rbp         | r13"
    row6: "110  | rsi         | r14"
    row7: "111  | rdi         | r15"
  }
  reg_note: "The 3-bit code (0-7) stays the same; REX bit selects upper/lower half of register set" {
    shape: rectangle
    width: 560
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      border-radius: 4
      font-size: 12
    }
  }
}
pitfall: "Common Pitfall: Forgetting REX.W" {
  direction: down
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
    border-radius: 8
  }
  pitfall_code: {
    shape: rectangle
    width: 560
    style: {
      fill: transparent
      stroke: transparent
    }
    code: |'c
      // WRONG: 32-bit operation (zero-extends to 64-bit)
      emit_byte(0x89);   // mov r/m32, r32
      emit_byte(0xD8);   // ModR/M
      // Result: eax written, high 32 bits cleared
      // CORRECT: 64-bit operation
      emit_byte(0x48);   // REX.W prefix
      emit_byte(0x89);   // mov r/m64, r64
      emit_byte(0xD8);   // ModR/M
      // Result: full 64-bit rax written
    '|
  }
  pitfall_note: "Without REX.W, operations default to 32-bit, zero-extending results to 64 bits!" {
    shape: rectangle
    width: 560
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      border-radius: 4
      font-size: 13
      bold: true
    }
  }
}
row_header -> row_fixed
row_fixed -> row_label
row_label -> rex_w_section
rex_w_section -> rex_r_section
rex_r_section -> rex_x_section
rex_x_section -> rex_b_section
rex_b_section -> encoding_table
encoding_table -> register_map
register_map -> pitfall