direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Interpreted vs JIT Performance Comparison
  Benchmark: Sum 1 to 1,000,000 (loop with arithmetic)
| {
  near: top-center
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_label: |md
    ## BEFORE
    Interpreter Mode
  | {
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
  }
  interp_bar: "500 ms" {
    width: 400
    height: 60
    style: {
      fill: "#E74C3C"
      stroke: "#C0392B"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  interp_detail: {
    shape: rectangle
    width: 280
    height: 140
    label: ""
    style.fill: "#FADBD8"
    style.stroke: "#E74C3C"
    d1_overhead: |md
      **Dispatch overhead**: ~200 ms
      - Switch statement per bytecode
      - Indirect branch mispredictions
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
    d2_memory: |md
      **Memory traffic**: ~180 ms
      - Stack operations to RAM
      - No register utilization
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
    d3_compute: |md
      **Actual compute**: ~120 ms
      - Pure arithmetic work
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
  }
}
row_arrow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arrow_container: {
    width: 120
    height: 80
    label: ""
    style.fill: transparent
    style.stroke: transparent
    arrow_text: |md
      **JIT Compilation**
      ~2 ms overhead
      (one-time cost)
    | {
      shape: rectangle
      style.fill: "#D5F5E3"
      style.stroke: "#27AE60"
      style.border-radius: 8
    }
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after_label: |md
    ## AFTER
    JIT-Compiled Mode
  | {
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
  }
  jit_baseline_bar: "50 ms" {
    width: 40
    height: 60
    style: {
      fill: "#F39C12"
      stroke: "#D68910"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  jit_opt_bar: "30 ms" {
    width: 24
    height: 60
    style: {
      fill: "#27AE60"
      stroke: "#1E8449"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  jit_detail: {
    shape: rectangle
    width: 320
    height: 200
    label: ""
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
    j1_dispatch: |md
      **Dispatch: ELIMINATED** ✓
      - Direct CPU execution
      - No interpreter loop
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
    j2_memory: |md
      **Memory: REDUCED 90%** ✓
      - Values in registers (rax, rbx, r12...)
      - Only spills for call boundaries
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
    j3_optimizations: |md
      **Optimizations Applied** ✓
      - Constant folding: 10 + 20 → 30
      - Strength reduction: x * 2 → x << 1
      - Dead store elimination
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
  }
}
row_scale: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scale_container: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    scale_bar_500: "500 ms" {
      width: 400
      height: 20
      style.fill: "#BDC3C7"
      style.stroke: "#95A5A6"
    }
    scale_bar_100: "100 ms" {
      width: 80
      height: 20
      style.fill: "#BDC3C7"
      style.stroke: "#95A5A6"
    }
    scale_bar_50: "50 ms" {
      width: 40
      height: 20
      style.fill: "#BDC3C7"
      style.stroke: "#95A5A6"
    }
    scale_bar_30: "30 ms" {
      width: 24
      height: 20
      style.fill: "#BDC3C7"
      style.stroke: "#95A5A6"
    }
  }
}
row_summary: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  summary_box: {
    shape: rectangle
    width: 600
    label: ""
    style: {
      fill: "#EBF5FB"
      stroke: "#3498DB"
      stroke-width: 2
      border-radius: 8
    }
    s_title: "SPEEDUP ANALYSIS" {
      style: {
        bold: true
        font-size: 18
        font-color: "#2C3E50"
      }
    }
    s_baseline: |md
      **JIT Baseline (no opts)**: 500 ms → 50 ms = **10x faster**
      - Eliminated interpreter dispatch
      - Register allocation reduces memory traffic
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
    s_optimized: |md
      **JIT Optimized**: 500 ms → 30 ms = **16.7x faster**
      - Baseline speedup PLUS:
      - Constant folding (compile-time evaluation)
      - Strength reduction (multiply → shift)
    | { shape: rectangle; style.fill: transparent; style.stroke: transparent }
    s_target: |md
      **Target**: 5x+ speedup ✓ **ACHIEVED**
    | { 
      shape: rectangle
      style.fill: "#D5F5E3"
      style.stroke: "#27AE60"
      style.border-radius: 4
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  l1: "Interpreter" {
    width: 20
    height: 20
    style.fill: "#E74C3C"
    style.stroke: "#C0392B"
  }
  l1_label: ""
  l2: "JIT Baseline" {
    width: 20
    height: 20
    style.fill: "#F39C12"
    style.stroke: "#D68910"
  }
  l2_label: ""
  l3: "JIT Optimized" {
    width: 20
    height: 20
    style.fill: "#27AE60"
    style.stroke: "#1E8449"
  }
  l3_label: ""
}
row_before.interp_bar -> row_arrow.arrow_container: "compile"
row_arrow.arrow_container -> row_after.jit_baseline_bar: "baseline"
row_arrow.arrow_container -> row_after.jit_opt_bar: "optimized"
row_after.jit_baseline_bar -> row_after.jit_opt_bar: "+ opts"