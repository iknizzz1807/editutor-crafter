direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: "16-Byte Stack Alignment Requirement (System V AMD64 ABI)"
  style: {
    font-size: 24
    bold: true
    fill: "#f0f0f0"
    stroke: "#333333"
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  stack_before: {
    shape: sql_table
    label: "T0: Before CALL (Main/Caller)"
    header: "0x...FF00 | Alignment: 16n"
    r0: "0x...FF10 | uint64_t | Previous Data"
    r1: "0x...FF08 | uint64_t | Previous Data"
    rsp: "0x...FF00 | <RSP> | [Aligned]"
    footer: "Stack is 16-byte aligned"
  }

  stack_after: {
    shape: sql_table
    label: "T1: After CALL (Inside Callee)"
    header: "0x...FEF8 | Alignment: 16n + 8"
    r0: "0x...FF00 | uint64_t | Caller's Data"
    ret: "0x...FEF8 | void*    | Return Address (8B)"
    rsp: "0x...FEF8 | <RSP> | [Misaligned]"
    footer: "CALL pushes 8B Return Address"
  }

  stack_before -> stack_after: "CALL | pushes RIP" {
    style.stroke: "#0066CC"
    style.stroke-width: 2
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  prologue: {
    label: "Prologue Execution"
    code: |'asm
      ; Standard function prologue
      push   rbp         ; Save caller base pointer
      mov    rbp, rsp    ; Set new frame pointer
      ; RSP is now 16-byte aligned again
    '|
    width: 300
    style.fill: "#f8fff8"
  }

  stack_aligned: {
    shape: sql_table
    label: "T2: After push rbp"
    header: "0x...FEF0 | Alignment: 16n"
    r0: "0x...FEF8 | void*    | Return Address"
    rbp_save: "0x...FEF0 | uint64_t | Saved RBP (8B)"
    rsp: "0x...FEF0 | <RSP> | [Aligned]"
    footer: "Total 16B (Ret + RBP) restore alignment"
  }

  prologue -> stack_aligned: "push rbp"
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  padding_logic: {
    label: "Padding Calculation"
    content: |'md
      **Alignment Invariant:**
      RSP must be 16-byte aligned 
      immediately before any CALL.

      **Formula:**
      N_pushes = Callee-saved regs
      Size = (N_pushes * 8)
      If (Size + Locals) % 16 != 0:
         sub rsp, 8 ; Add padding
    '|
    width: 300
    style.fill: "#fff8ff"
  }

  stack_final: {
    shape: sql_table
    label: "T3: Final Frame for Nested CALL"
    header: "0x...FEC0 | Alignment: 16n"
    r0: "0x...FEF0 | uint64_t | Saved RBP"
    r1: "0x...FEE8 | uint64_t | Saved RBX"
    r2: "0x...FEE0 | uint64_t | Saved R12"
    pad: "0x...FED8 | uint64_t | PADDING (8B)"
    loc: "0x...FEC0 | byte[24] | Locals"
    rsp: "0x...FEC0 | <RSP> | [Aligned]"
    footer: "Ready for next CALL instruction"
  }

  padding_logic -> stack_final: "sub rsp, padding"
}

row1 -> row2: "Next Instr"
row2 -> row3: "Next Instr"

legend: {
  near: bottom-right
  shape: rectangle
  label: "ABI Alignment Rules"
  content: |'md
    **Rule:** (rsp + 8) % 16 == 0 
    at entry of function.

    **Why:** SSE/AVX (XMM/YMM) 
    registers require 16/32 byte 
    alignment for memory ops.
  '|
  style: {
    stroke: "#7B1FA2"
    fill: "#FAFAFA"
  }
}