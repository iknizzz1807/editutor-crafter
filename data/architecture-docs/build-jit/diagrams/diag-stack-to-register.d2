direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Stack-Based Bytecode to Register-Based Native" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  before: {
    direction: down
    label: "BEFORE: Bytecode VM"
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 8
    }
    bc_header: {
      shape: text
      label: "Stack-Based Execution"
      style: {
        font-size: 18
        bold: true
        font-color: "#1565C0"
      }
    }
    bc_step1: {
      label: "Step 1: PUSH a"
      width: 320
      code: |'asm
        PUSH a      ; stack: [a]
      '|
      style.fill: "#FFF9C4"
    }
    bc_step2: {
      label: "Step 2: PUSH b"
      width: 320
      code: |'asm
        PUSH b      ; stack: [a, b]
      '|
      style.fill: "#FFF9C4"
    }
    bc_step3: {
      label: "Step 3: ADD"
      width: 320
      code: |'asm
        ADD         ; pop b, pop a
                    ; push a+b
                    ; stack: [a+b]
      '|
      style.fill: "#C8E6C9"
    }
    bc_step4: {
      label: "Step 4: PUSH c"
      width: 320
      code: |'asm
        PUSH c      ; stack: [a+b, c]
      '|
      style.fill: "#FFF9C4"
    }
    bc_step5: {
      label: "Step 5: MUL"
      width: 320
      code: |'asm
        MUL         ; pop c, pop (a+b)
                    ; push (a+b)*c
                    ; stack: [(a+b)*c]
      '|
      style.fill: "#C8E6C9"
    }
    stack_viz: {
      label: "Operand Stack Evolution"
      shape: rectangle
      style.fill: "#BBDEFB"
      stack_frame: {
        shape: sql_table
        label: "Stack State (grows down)"
        s0: "SP+0  | temp    | top"
        s1: "SP+8  | value   | ..."
        s2: "SP+16 | value   | ..."
        note: "Memory accesses per op: 2-3"
      }
    }
    bc_header -> bc_step1 -> bc_step2 -> bc_step3 -> bc_step4 -> bc_step5 -> stack_viz: {
      style.stroke: transparent
    }
  }
  arrow: {
    shape: text
    label: "⟹ JIT\nTranslation"
    style: {
      font-size: 24
      bold: true
      font-color: "#FF5722"
    }
  }
  after: {
    direction: down
    label: "AFTER: Native x86-64"
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      border-radius: 8
    }
    nat_header: {
      shape: text
      label: "Register-Based Execution"
      style: {
        font-size: 18
        bold: true
        font-color: "#7B1FA2"
      }
    }
    nat_step1: {
      label: "Step 1: Load a"
      width: 320
      code: |'asm
        mov rax, a      ; rax = a
      '|
      style.fill: "#FFF9C4"
    }
    nat_step2: {
      label: "Step 2: Load b"
      width: 320
      code: |'asm
        mov rbx, b      ; rbx = b
      '|
      style.fill: "#FFF9C4"
    }
    nat_step3: {
      label: "Step 3: ADD"
      width: 320
      code: |'asm
        add rax, rbx    ; rax = rax + rbx
                        ; (rbx now dead)
      '|
      style.fill: "#C8E6C9"
    }
    nat_step4: {
      label: "Step 4: Load c"
      width: 320
      code: |'asm
        mov rcx, c      ; rcx = c
                        ; (reuse rbx slot)
      '|
      style.fill: "#FFF9C4"
    }
    nat_step5: {
      label: "Step 5: MUL"
      width: 320
      code: |'asm
        imul rax, rcx   ; rax = rax * rcx
                        ; result in rax
      '|
      style.fill: "#C8E6C9"
    }
    reg_viz: {
      label: "Register Allocation"
      shape: rectangle
      style.fill: "#E1BEE7"
      reg_frame: {
        shape: sql_table
        label: "Register State (fast)"
        r0: "RAX | a → (a+b) → (a+b)*c"
        r1: "RBX | b → dead"
        r2: "RCX | c"
        r3: "RDX | unused"
        note: "Memory accesses: 0-1 per op"
      }
    }
    nat_header -> nat_step1 -> nat_step2 -> nat_step3 -> nat_step4 -> nat_step5 -> reg_viz: {
      style.stroke: transparent
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  metrics: {
    label: "Translation Metrics"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      border-radius: 8
    }
    width: 600
    m_title: {
      shape: text
      label: "Stack Depth → Register Pressure Mapping"
      style: {
        font-size: 16
        bold: true
        font-color: "#E65100"
      }
    }
    m_table: {
      shape: sql_table
      label: "Pressure Analysis"
      col1: "Bytecode Stack Depth | Registers Needed | Spill Required?"
      row1: "1 value              | 1 register       | No"
      row2: "2 values             | 2 registers      | No"
      row3: "3 values             | 3 registers      | Maybe"
      row4: "4+ values            | 4+ registers     | Likely"
      note: "x86-64 has 16 GPRs, but ABI reserves some"
    }
  }
  key_insight: {
    label: "Key Insight"
    shape: callout
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
    }
    width: 350
    insight_text: {
      shape: text
      label: "Stack depth maps to register pressure.\n\nWhen stack depth > available registers,\nvalues spill to stack frames.\n\nJIT minimizes spills via live range analysis."
      style: {
        font-size: 14
        italic: true
      }
    }
  }
}
before -> arrow -> after: "translate"
row1 -> row2: "analyze"