direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Strength Reduction: Expensive → Cheap Operations"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  mul2: {
    label: "Multiply by 2"
    width: 280
    before: {
      label: "Before"
      shape: rectangle
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      code_before: |'c
        imul rax, 2    ; 3 cycles
      '|
    }
    arrow1: {
      label: "→"
      shape: text
      style: {
        font-size: 28
        bold: true
        font-color: "#228B22"
      }
    }
    after: {
      label: "After"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#228B22"
      code_after: |'c
        shl rax, 1     ; 1 cycle
      '|
    }
    savings: {
      label: "3x faster"
      shape: callout
      style.fill: "#FFF8DC"
      style.stroke: "#DAA520"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  mul8: {
    label: "Multiply by 8"
    width: 280
    before2: {
      label: "Before"
      shape: rectangle
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      code_b2: |'c
        imul rax, 8    ; 3 cycles
      '|
    }
    arrow2: {
      label: "→"
      shape: text
      style: {
        font-size: 28
        bold: true
        font-color: "#228B22"
      }
    }
    after2: {
      label: "After"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#228B22"
      code_a2: |'c
        shl rax, 3     ; 1 cycle
      '|
    }
    savings2: {
      label: "3x faster"
      shape: callout
      style.fill: "#FFF8DC"
      style.stroke: "#DAA520"
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  div4: {
    label: "Unsigned Divide by 4"
    width: 280
    before3: {
      label: "Before"
      shape: rectangle
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      code_b3: |'c
        xor rdx, rdx
        mov rcx, 4
        div rcx        ; 20-80 cycles
      '|
    }
    arrow3: {
      label: "→"
      shape: text
      style: {
        font-size: 28
        bold: true
        font-color: "#228B22"
      }
    }
    after3: {
      label: "After"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#228B22"
      code_a3: |'c
        shr rax, 2     ; 1 cycle
      '|
    }
    savings3: {
      label: "20-80x faster"
      shape: callout
      style.fill: "#FFF8DC"
      style.stroke: "#DAA520"
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  mod8: {
    label: "Modulo by 8"
    width: 280
    before4: {
      label: "Before"
      shape: rectangle
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      code_b4: |'c
        xor rdx, rdx
        mov rcx, 8
        div rcx        ; rdx = result
        mov rax, rdx   ; 20-80 cycles
      '|
    }
    arrow4: {
      label: "→"
      shape: text
      style: {
        font-size: 28
        bold: true
        font-color: "#228B22"
      }
    }
    after4: {
      label: "After"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#228B22"
      code_a4: |'c
        and rax, 7     ; 1 cycle
      '|
    }
    savings4: {
      label: "20-80x faster"
      shape: callout
      style.fill: "#FFF8DC"
      style.stroke: "#DAA520"
    }
  }
}
legend: {
  near: bottom-center
  style.fill: "#F5F5F5"
  style.stroke: "#808080"
  header: "Instruction Latency Reference (Skylake)"
  imul_row: "imul r64, r64/imm: 3 cycles"
  shl_row: "shl/shr r64, imm8: 1 cycle"
  div_row: "div r64: 20-80 cycles (variable)"
  and_row: "and r64, imm: 1 cycle"
}
mul2.before -> mul2.after: "strength\nreduce" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
    animated: true
  }
}
mul8.before2 -> mul8.after2: "strength\nreduce" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
    animated: true
  }
}
div4.before3 -> div4.after3: "strength\nreduce" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
    animated: true
  }
}
mod8.before4 -> mod8.after4: "strength\nreduce" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
    animated: true
  }
}