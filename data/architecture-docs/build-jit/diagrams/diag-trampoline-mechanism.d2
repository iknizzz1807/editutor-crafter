direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# JIT-Interpreter Trampoline Bridge
# Implementation Blueprint for Context Switching between Machine Code and Bytecode

bridge_system: {
  style.stroke: transparent
  style.fill: transparent

  trampoline_sequence: {
    shape: sequence_diagram

    JIT_Code: JIT Compiled Function {
      style.stroke: "#6366f1"
      style.stroke-width: 2
    }
    Trampoline: Trampoline Layer {
      style.stroke: "#10b981"
      style.stroke-width: 4
    }
    Interpreter: Bytecode Interpreter {
      style.stroke: "#f59e0b"
      style.stroke-width: 2
    }
    VM_State: VM State Structure {
      style.stroke: "#ef4444"
      style.stroke-width: 2
    }

    # --- TRACE START ---
    JIT_Code."Hot path entry (rip: 0x7f...)"

    JIT_Code.t1 -> Trampoline.t1: "Target: 0xBC" {
      label: "rdi = target_id"
    }

    Trampoline.t1."Preserve Context"
    
    Trampoline.t1 -> Trampoline.t1: "Save Registers" {
      label: "push rbx, r12-r15"
    }
    
    Trampoline.t1 -> Trampoline.t1: "Store RIP" {
      label: "[vm.rip] = ret_addr"
    }
    
    Trampoline.t1 -> Trampoline.t1: "Snapshot GPRs" {
      label: "[vm.regs] = rax...r15"
    }

    Trampoline.t1 -> VM_State.t1: "Struct Write" {
      label: "64-byte memcpy"
    }
    VM_State.t1.style.fill: "#fef3c7"

    # --- INTERPRETATION PHASE ---
    Trampoline.t2 -> Interpreter.t2: "call entry" {
      label: "rdi = &vm_state"
    }

    Interpreter.t2 -> Interpreter.t2: "Load PC" {
      label: "rsi = [vm.pc]"
    }
    
    Interpreter.t2 -> Interpreter.t2: "Dispatch Loop" {
      label: "Fetch/Decode/Exec"
    }
    
    Interpreter.t2 -> Interpreter.t2: "Execute op" {
      label: "Virtual ISA eval"
    }
    
    Interpreter.t2 -> Interpreter.t2: "Update Stack" {
      label: "vsp[top++] = res"
    }

    # --- RETURN PATH ---
    Interpreter.t3 -> Trampoline.t3: "ret (result)" {
      label: "rax = status"
    }

    Trampoline.t3 -> VM_State.t3: "Sync Locals" {
      label: "mov rbx, [vm.locals]"
    }

    Trampoline.t3 -> Trampoline.t3: "Pop Context" {
      label: "Restore r15...rbx"
    }

    Trampoline.t3 -> Trampoline.t3: "Restore Args" {
      label: "mov rdi, [vm.rdi]"
    }

    Trampoline.t3 -> JIT_Code.t3: "ret to JIT" {
      label: "jmp [vm.rip]"
    }

    JIT_Code.t3 -> JIT_Code.t3: "Hot Path" {
      label: "ALU op on rax"
    }

    JIT_Code."Resume execution"
  }
}

# Technical Implementation Details (Side-by-side Layout)
technical_specs: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  vm_state_memory: {
    shape: sql_table
    label: "struct VMState (vm_core.h)"
    f0: "0x00 | uint64_t | rip // Resume instruction pointer"
    f1: "0x08 | uint64_t | rsp // Native stack pointer"
    f2: "0x10 | uint64_t[16]| regs // Snapshotted GPRs"
    f3: "0x90 | uint8_t*  | pc // Virtual program counter"
    f4: "0x98 | uint64_t* | vsp // Virtual stack pointer"
    f5: "0xA0 | uint64_t  | flags // CPU flags / status"
    total: "Total Size: 168 Bytes"
  }

  bridge_logic: {
    label: "Trampoline Implementation (bridge.asm)"
    code: |'asm
      bridge_to_interp:
        ; 1. Save caller-saved context
        mov [rdi + 0x10], rax
        mov [rdi + 0x18], rcx
        ; ... 
        ; 2. Align stack for C call
        sub rsp, 8
        call interpreter_entry
        add rsp, 8
        ret
    '|
  }
}

# Documentation Overlay (Fixed near placement to root constant)
documentation_overlay: {
  grid-columns: 2
  
  note1: {
    label: "Bridge Mechanism"
    content: |md
      The Trampoline acts as a non-ABI-compliant 
      bridge that manually shuffles registers 
      into a memory-mapped VM structure.
    | 
    style.stroke: "#10b981"
    style.fill: "#d1fae5"
  }
  
  note2: {
    label: "Register Persistence"
    content: |md
      All GPRs must be snapshotted 
      to prevent clobbering by 
      C-compiled Interpreter entry.
    | 
    style.stroke: "#ef4444"
    style.fill: "#fee2e2"
  }
}

# Layout constraints
documentation_overlay.near: bottom-center
bridge_system -> technical_specs: "Implements" {style.stroke: transparent}
technical_specs -> documentation_overlay: "Details" {style.stroke: transparent}