direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: W^X Memory Lifecycle {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
# State definitions
rw_state: "RW\n(Write Mode)" {
  shape: circle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: "#1B5E20"
  }
}
rx_state: "RX\n(Execute Mode)" {
  shape: circle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 3
    font-color: "#0D47A1"
  }
}
freed_state: "Freed" {
  shape: circle
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    font-color: "#B71C1C"
  }
}
# Operations allowed boxes (positioned near states)
rw_ops: {
  label: "Legal Operations"
  style.fill: transparent
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
  op1: "mmap() with PROT_READ | PROT_WRITE"
  op2: "memcpy() / write bytes"
  op3: "Cursor increment"
  op4: "NO execution allowed"
}
rx_ops: {
  label: "Legal Operations"
  style.fill: transparent
  style.stroke: "#1565C0"
  style.stroke-dash: 3
  op1: "Call as function pointer"
  op2: "CPU fetches instructions"
  op3: "I-cache loads code"
  op4: "NO writes allowed"
}
freed_ops: {
  label: "Legal Operations"
  style.fill: transparent
  style.stroke: "#C62828"
  style.stroke-dash: 3
  op1: "Memory returned to OS"
  op2: "Pointer becomes invalid"
  op3: "No operations permitted"
}
# Transitions
rw_state -> rx_state: "mprotect(PROT_READ | PROT_EXEC)\n+ __builtin___clear_cache()" {
  label.near: center-left
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}
rx_state -> rw_state: "mprotect(PROT_READ | PROT_WRITE)\n(patch code)" {
  style: {
    stroke: "#FF8F00"
    stroke-width: 2
    stroke-dash: 5
    font-size: 14
  }
}
rx_state -> freed_state: "munmap()" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}
rw_state -> freed_state: "munmap()\n(compilation failed)" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    stroke-dash: 5
    font-size: 14
  }
}
# Self-loop for emit
rw_emit: {
  shape: text
  label: "emit_byte()\nemit_uint32()\nemit_instruction()"
  style.font-color: "#2E7D32"
  near: center-left
}
# Self-loop for execute
rx_exec: {
  shape: text
  label: "func()\n(function call)"
  style.font-color: "#1565C0"
  near: center-right
}
# Position ops near states
rw_ops.near: top-left
rx_ops.near: top-right
freed_ops.near: bottom-center
# Cache flush callout
cache_flush: {
  label: "Instruction Cache Flush\n(ARM64 / Apple Silicon)"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    border-radius: 8
  }
  note: |md
    **Critical on ARM platforms!**
    c
    __builtin___clear_cache(
      code_start, 
      code_end
    );
    
    - x86-64: Hardware maintains I/D cache coherence
    - ARM64: Explicit `ic ivau` + `dc cvau` required
    - macOS: Always call (no-op on Intel)
  |
}
cache_flush.near: center-right
# W^X policy note
policy_note: {
  label: "W^X Security Policy"
  style: {
    fill: "#FCE4EC"
    stroke: "#AD1457"
    border-radius: 8
  }
  note: |md
    **Write XOR Execute**
    A memory page can be:
    - Writable **OR** Executable
    - **NEVER both simultaneously**
    Prevents self-modifying code attacks:
    - Attacker cannot write shellcode
      to executable memory
    - JIT must explicitly flip permissions
  |
}
policy_note.near: bottom-left