direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # x86-64 Instruction Encoding Anatomy
  Variable-length encoding: 1–15 bytes total
| {near: top-center}
instruction_bytes: {
  grid-columns: 7
  grid-gap: 0
  legacy: |md
    **Legacy Prefixes**
    0–4 bytes
    Optional
  | {
    style: {
      fill: "#E8D5E8"
      stroke: "#8B5A8B"
      font-color: "#4A284A"
    }
  }
  rex: |md
    **REX**
    1 byte
    0x40–0x4F
  | {
    style: {
      fill: "#D4E8D4"
      stroke: "#4A8B4A"
      font-color: "#1A4A1A"
    }
  }
  opcode: |md
    **Opcode**
    1–3 bytes
    Operation
  | {
    style: {
      fill: "#D4D4E8"
      stroke: "#4A4A8B"
      font-color: "#1A1A4A"
    }
  }
  modrm: |md
    **ModR/M**
    1 byte
    Operands
  | {
    style: {
      fill: "#E8D4D4"
      stroke: "#8B4A4A"
      font-color: "#4A1A1A"
    }
  }
  sib: |md
    **SIB**
    0–1 byte
    Addressing
  | {
    style: {
      fill: "#E8E8D4"
      stroke: "#8B8B4A"
      font-color: "#4A4A1A"
    }
  }
  disp: |md
    **Disp**
    0–4 bytes
    Offset
  | {
    style: {
      fill: "#D4E8E8"
      stroke: "#4A8B8B"
      font-color: "#1A4A4A"
    }
  }
  imm: |md
    **Imm**
    0–8 bytes
    Constant
  | {
    style: {
      fill: "#E8D4E8"
      stroke: "#8B4A8B"
      font-color: "#4A1A4A"
    }
  }
}
legacy_field: {
  shape: sql_table
  label: "Legacy Prefixes (x86.h)"
  f0: "0xF0 | LOCK (atomic)"
  f1: "0xF2 | REPNE (string)"
  f2: "0xF3 | REP/REPE (string)"
  f3: "0x66 | Operand-size override"
  f4: "0x67 | Address-size override"
  f5: "0x2E/0x3E | Segment override"
  note: "Rarely used in 64-bit JIT"
}
rex_field: {
  shape: sql_table
  label: "REX Prefix (0x40–0x4F)"
  bits: "0100 | W | R | X | B"
  w: "W=1 | 64-bit operand size"
  r: "R=1 | Extends ModR/M reg (r8-r15)"
  x: "X=1 | Extends SIB index (r8-r15)"
  b: "B=1 | Extends ModR/M r/m (r8-r15)"
  example: "0x48 = REX.W (64-bit ops)"
}
opcode_field: {
  shape: sql_table
  label: "Opcode (1–3 bytes)"
  one: "1-byte: 0x01 (add), 0x89 (mov), 0xC3 (ret)"
  two: "2-byte: 0x0F 0xAF (imul), 0x0F 0x95 (setnz)"
  three: "3-byte: VEX/EVEX prefixes (SIMD)"
  note: "Primary operation identifier"
}
modrm_field: {
  shape: sql_table
  label: "ModR/M Byte"
  mod: "7–6 | Mod | 00=mem, 01=mem+disp8, 10=mem+disp32, 11=reg"
  reg: "5–3 | Reg | 1st register OR opcode extension"
  rm: "2–0 | R/M | 2nd register/memory operand"
  ex1: "11 011 000 = 0xD8 (reg-to-reg: rbx→rax)"
  ex2: "00 000 101 = 0x05 (rip-relative)"
}
sib_field: {
  shape: sql_table
  label: "SIB Byte (Scale-Index-Base)"
  scale: "7–6 | Scale | 00=×1, 01=×2, 10=×4, 11=×8"
  index: "5–3 | Index | Register × scale"
  base: "2–0 | Base | Base register for address"
  ex: "[rbx + rax×4] → Scale=10, Index=000, Base=011"
  when: "Used when ModR/M r/m = 100 (except mod=11)"
}
disp_field: {
  shape: sql_table
  label: "Displacement (0, 1, 2, 4 bytes)"
  d0: "0 bytes | Register-direct (mod=11)"
  d1: "1 byte | disp8 (mod=01), sign-extended"
  d2: "4 bytes | disp32 (mod=10)"
  d3: "Example: [rbp-16] → disp8 = 0xF0"
  le: "Stored little-endian"
}
imm_field: {
  shape: sql_table
  label: "Immediate (0, 1, 2, 4, 8 bytes)"
  i0: "0 bytes | Register-to-register ops"
  i1: "1 byte | imm8 (sign-extended for some ops)"
  i4: "4 bytes | imm32 (sign-extended to 64-bit)"
  i8: "8 bytes | imm64 (mov r64, imm64 only)"
  ex: "mov rax, 42 → imm32 = 0x2A000000 (LE)"
}
instruction_bytes -> legacy_field
instruction_bytes -> rex_field
instruction_bytes -> opcode_field
instruction_bytes -> modrm_field
instruction_bytes -> sib_field
instruction_bytes -> disp_field
instruction_bytes -> imm_field
example_encoding: {
  label: "Example: add rax, rbx"
  grid-columns: 3
  grid-gap: 0
  rex_byte: |md
    **0x48**
    REX.W
  | {
    style: {
      fill: "#D4E8D4"
      stroke: "#4A8B4A"
    }
  }
  opcode_byte: |md
    **0x01**
    add r/m64, r64
  | {
    style: {
      fill: "#D4D4E8"
      stroke: "#4A4A8B"
    }
  }
  modrm_byte: |md
    **0xD8**
    Mod=11, Reg=011, R/M=000
  | {
    style: {
      fill: "#E8D4D4"
      stroke: "#8B4A4A"
    }
  }
}
legend: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: transparent
    stroke: "#666666"
    stroke-dash: 3
  }
  required: {
    shape: rectangle
    style.fill: "#D4D4D4"
  }
  optional: {
    shape: rectangle
    style.fill: "#E8E8E8"
    style.stroke-dash: 3
  }
  required -> optional: "Required" {
    style.stroke: transparent
  }
  optional -> optional: "Optional" {
    style.stroke: transparent
  }
}