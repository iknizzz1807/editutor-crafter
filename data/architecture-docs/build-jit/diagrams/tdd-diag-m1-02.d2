direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
  }
}

# --- Style Classes ---
classes: {
  process: {
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      stroke-width: 2
      border-radius: 5
    }
  }
  data_store: {
    shape: cylinder
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
    }
  }
  error_state: {
    style: {
      fill: "#FFEBEE"
      stroke: "#B71C1C"
      stroke-dash: 3
    }
  }
  log_block: {
    shape: page
    style: {
      fill: "#F5F5F5"
      stroke: "#424242"
      font: mono
    }
  }
  highlight: {
    style: {
      stroke: "#D32F2F"
      stroke-width: 4
      bold: true
    }
  }
}

# --- Infrastructure & Setup ---
TestFramework: Automated Test Framework (ATF) {
  conftest: "conftest.py (Setup Phase)" {
    class: process
    tooltip: "Initializes ISIS configuration and interface mapping"
    
    LoadTopo: "Load Topology Map" {
      class: process
    }
    InterfaceMapping: "Interface Mapping\n(gl.DUT1.PORT1.l3intf)" {
      class: process
    }
  }

  TopologyData: "Topology Specification\n(topox file)" {
    class: data_store
  }

  LoadTopo -> TopologyData: "Read mappings"
  TopologyData -> InterfaceMapping: "DUT1:PORT1 -> RT1:PORT1"
}

# --- Execution Logic ---
ExecutionEngine: "Test Execution (test_case_0.py)" {
  Step1: "Step 1: Interface Initialization" {
    class: process
  }
  
  Step2: "Step 2: ISIS Configuration Push" {
    class: process
    tooltip: "NSKK Converter call to apply ISIS settings"
  }

  CheckCommand: "Step 3: State Verification\n'display isis peer'" {
    class: process
    style.fill: "#FFF3E0"
  }

  Step1 -> Step2: "Config successful"
  Step2 -> CheckCommand: "Wait for convergence"
}

# --- Failure Analysis (The Error Context) ---
FailurePath: "Expect Analysis & Logging" {
  ExpectCheck: "Expect String Check\n(Regex: 'State: Up')" {
    class: error_state
    tooltip: "Failed: Output does not contain 'State: Up'"
  }

  ErrorLog: "Failure Log Entry" {
    class: log_block
    label: |md
      ### Execution Trace
      **Error**: [expect检查] 字符串宽松检查失败
      **Command**: `display isis peer`
      **Expected**: `State: Up`
      **Actual**: `回显信息为空`
    |
  }

  LogDecryption: "Log Decryption Service" {
    class: process
    base64_engine: "Base64 Decode" {
      style.font: mono
    }
  }

  CheckCommand -> ExpectCheck: "Raw CLI Response"
  ExpectCheck -> ErrorLog: "FAIL -> Generate Report"
  ErrorLog -> LogDecryption: "Encrypted segments found"
}

# --- Decrypted Data Layout ---
MemoryLayout: "Decrypted Buffer Layout" {
  header: "Header" {
    style.fill: "#D1C4E9"
  }
  payload: "Payload (Base64)" {
    class: highlight
    label: "5Ymp5L2ZIDI5IOasoeajgOafpQ=="
  }
  metadata: "Metadata (VLAN/Layer)" {
    style.fill: "#C8E6C9"
  }

  header -> payload -> metadata
}

# --- Relationships ---
TestFramework.conftest.InterfaceMapping -> ExecutionEngine.Step1: "Provide gl.DUT1 object"
ExecutionEngine.CheckCommand -> FailurePath.ExpectCheck: "cli_buffer"
LogDecryption -> MemoryLayout: "Extracted VLAN ID"

# --- Annotations ---
title: |md
  # CodeEmitter Data Flow & Error Analysis
  ## Case Study: ISIS Peer State Verification Failure
| {
  near: top-center
}

legend: {
  near: bottom-right
  Success: {
    style.fill: "#C8E6C9"
  }
  Failure: {
    class: error_state
  }
  External: {
    class: data_store
  }
}

# --- Error Highlighting for Engineer ---
(ExecutionEngine.CheckCommand -> FailurePath.ExpectCheck)[0].style: {
  stroke: red
  stroke-width: 2
  animated: true
}

FailurePath.ExpectCheck.style.multiple: true