layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL CLASSES ---
classes: {
  header_purple: {
    style: {
      fill: "#6e41ab"
      font-color: white
      bold: true
    }
  }
  data_blue: {
    style: {
      fill: "#B8D4E8"
      stroke: "#4A90D9"
    }
  }
  padding_gray: {
    style: {
      fill: "#E8E8E8"
      stroke: "#CCCCCC"
      stroke-dash: 3
    }
  }
  pointer_orange: {
    style: {
      stroke: "#F39C12"
      stroke-width: 2
      animated: true
    }
  }
  cache_boundary: {
    style: {
      stroke: "#999999"
      stroke-dash: 5
      stroke-width: 1
    }
  }
}

# --- STRUCT LAYOUT ---
# Exact byte offsets and field sizes for the CodeEmitter object
# Fixed: Removed newline from sql_table label to prevent compilation error
CodeEmitter: {
  shape: sql_table
  label: "struct CodeEmitter (Virtual Memory) | sizeof: 32 bytes (64-bit)"
  style.fill: "#6e41ab"
  style.font-color: white

  "0x00": "buffer: uint8_t*" {
    constraint: "8 bytes"
    style.fill: "#B8D4E8"
  }
  "0x08": "cursor: uint8_t*" {
    constraint: "8 bytes"
    style.fill: "#B8D4E8"
  }
  "0x10": "capacity: size_t" {
    constraint: "8 bytes"
    style.fill: "#B8D4E8"
  }
  "0x18": "used: size_t" {
    constraint: "8 bytes"
    style.fill: "#B8D4E8"
  }
}

# --- MEMORY BUFFER VIEW ---
# Page-aligned executable memory representation
Memory_Region: "mmap'd Executable Memory (PROT_EXEC | PROT_WRITE)" {
  style: {
    stroke: black
    stroke-width: 2
    fill: "#FDFDFD"
  }

  Contents: {
    grid-columns: 1
    grid-gap: 20

    Used_Space: {
      label: "Active Instruction Stream"
      grid-columns: 4
      grid-gap: 0
      b0: "0x00\n[Code Start]" { class: data_blue; width: 140; height: 70 }
      b1: "0x01\n[Opcode]" { class: data_blue; width: 140; height: 70 }
      b2: "0x02\n[Imm32]" { class: data_blue; width: 140; height: 70 }
      b3: "Byte (used - 1)" { class: data_blue; width: 140; height: 70 }
    }

    Free_Space: {
      label: "Available Buffer Space"
      grid-columns: 4
      grid-gap: 0
      f0: "Next Write" {
        style: {
          fill: "#FFF4F4"
          stroke: red
          stroke-width: 3
          bold: true
        }
        width: 140
        height: 70
      }
      f1: "Padding" { class: padding_gray; width: 140; height: 70 }
      f2: "Padding" { class: padding_gray; width: 140; height: 70 }
      f3: "End (capacity)" { class: padding_gray; width: 140; height: 70 }
    }
  }
}

# --- LOGICAL POINTERS ---
# Shows how the struct fields relate to the physical memory buffer
CodeEmitter."0x00" -> Memory_Region.Contents.Used_Space.b0: "Base Pointer" {
  class: pointer_orange
  source-arrowhead: circle
  style.stroke-width: 3
}

CodeEmitter."0x08" -> Memory_Region.Contents.Free_Space.f0: "Write Pointer" {
  class: pointer_orange
  source-arrowhead: diamond
  label: "Invariant: cursor = buffer + used"
  style.font-size: 14
  style.bold: true
}

# --- DOCUMENTATION ---
# Using ||| delimiter to avoid collision with Markdown table pipes
Documentation: |||md
### CodeEmitter Implementation Specs
- **Memory Alignment**: Buffer must be aligned to `getpagesize()` (typically 4KB) for `mprotect` calls.
- **Growth Policy**: If `used + n > capacity`, perform `mremap` or re-allocate new buffer + `memcpy`.
- **Instruction Emitter**: 
  1. Check bounds: `if (used + sz > capacity) grow();`
  2. Write opcode to `*cursor`.
  3. Increment `cursor` by `instr_size`.
  4. Increment `used` by `instr_size`.

| Field | Purpose | Validation | Offset |
| :--- | :--- | :--- | :--- |
| `buffer` | Start of JIT block | Page-aligned (4KB) | +0 |
| `cursor` | Next available byte | `buffer <= cursor < buffer + capacity` | +8 |
| `capacity` | Reserved size | Total mmap size | +16 |
| `used` | Current stream length | `cursor - buffer` | +24 |
||| {
  near: bottom-center
  style: {
    font-size: 14
    stroke: "#CCCCCC"
    fill: "#FCFCFC"
    border-radius: 5
  }
}

# --- STYLING ANNOTATIONS ---
CodeEmitter.style.stroke: "#4b2c73"
Memory_Region.Contents.Used_Space.style.stroke: "#4A90D9"
Memory_Region.Contents.Free_Space.style.stroke: "#CCCCCC"

# Legend/Page Annotation
Legend: {
  near: top-right
  Header: "Field Header" { class: header_purple }
  Data: "Active Data" { class: data_blue }
  Free: "Allocated Free" { class: padding_gray }
}