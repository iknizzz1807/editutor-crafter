direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# ---------------------------------------------------------------------------------------
# State Machine: W^X (Write XOR Execute) Memory Lifecycle
# Hardware-level enforcement for JIT engines and Kernel hardening.
# ---------------------------------------------------------------------------------------

START: "" {
  shape: circle
  width: 30
  height: 30
  style: {
    fill: black
  }
}

STATE_UNALLOCATED: "UNALLOCATED / FREE" {
  shape: rectangle
  tooltip: "Physical page or virtual address range is unmapped"
  style: {
    stroke-dash: 4
    stroke: "#757575"
    opacity: 0.8
  }
}

STATE_ALLOCATED_RW: "STATE: RW (DATA)" {
  shape: rectangle
  label: |md
    ### Memory State: RW
    **Protection Bits:**
    - `PROT_READ | PROT_WRITE`
    **PTE Invariants:**
    - `Writable (W)    = 1`
    - `No-Execute (NX) = 1`
    - `Dirty (D)       = 0/1`
    **Hardware Guard:**
    - MMU: Allow Store/Load
    - MMU: Trap on Instruction Fetch (EFAULT)
  |
  style: {
    fill: "#e3f2fd"
    stroke: "#1565c0"
    stroke-width: 4
    border-radius: 8
  }
}

STATE_EXECUTABLE_RX: "STATE: RX (CODE)" {
  shape: rectangle
  label: |md
    ### Memory State: RX
    **Protection Bits:**
    - `PROT_READ | PROT_EXEC`
    **PTE Invariants:**
    - `Writable (W)    = 0`
    - `No-Execute (NX) = 0`
    - `Present (P)     = 1`
    **Hardware Guard:**
    - MMU: Allow Fetch/Load
    - MMU: Trap on Store attempt (SIGSEGV)
  |
  style: {
    fill: "#f1f8e9"
    stroke: "#2e7d32"
    stroke-width: 4
    border-radius: 8
  }
}

STATE_ILLEGAL_RWX: "STATE: RWX (VIOLATION)" {
  shape: rectangle
  label: |md
    ### SECURITY CRITICAL: RWX
    **POLICY VIOLATION DETECTED**
    - `Invariant: (W & X) == 0`
    - `Detected:  (1 & 1) == 1`
    **Resulting Vector:**
    - High-risk for Shellcode Injection
    - Kernel Panic / Immediate SIGKILL
  |
  style: {
    fill: "#ffebee"
    stroke: "#d32f2f"
    stroke-width: 6
    double-border: true
  }
}

# ---------------------------------------------------------------------------------------
# Valid Lifecycle Transitions
# ---------------------------------------------------------------------------------------

START -> STATE_UNALLOCATED: "Power On / VMM Init"

STATE_UNALLOCATED -> STATE_ALLOCATED_RW: "mmap(PROT_READ|PROT_WRITE)" {
  source-arrowhead: circle
  target-arrowhead: triangle
  style: {
    stroke-width: 2
    stroke: "#1565c0"
  }
}

STATE_ALLOCATED_RW -> STATE_EXECUTABLE_RX: {
  label: |md
    **JIT Commit Transition**
    1. Write Bytecode to Page
    2. `__builtin_clear_cache()`
    3. `mprotect(PROT_READ | PROT_EXEC)`
    4. Revoke W, Clear NX
  |
  style: {
    stroke: "#2e7d32"
    stroke-width: 3
  }
}

STATE_EXECUTABLE_RX -> STATE_ALLOCATED_RW: {
  label: |md
    **Code Patching Phase**
    1. Suspend JIT Threads
    2. `mprotect(PROT_READ | PROT_WRITE)`
    3. Revoke X, Grant W
  |
  style: {
    stroke: "#1565c0"
    stroke-width: 2
    stroke-dash: 2
  }
}

STATE_ALLOCATED_RW -> STATE_UNALLOCATED: "munmap()" {
  style: {
    stroke-dash: 5
    opacity: 0.6
  }
}

STATE_EXECUTABLE_RX -> STATE_UNALLOCATED: "munmap()" {
  style: {
    stroke-dash: 5
    opacity: 0.6
  }
}

# ---------------------------------------------------------------------------------------
# Forbidden / Illegal Transitions
# ---------------------------------------------------------------------------------------

STATE_ALLOCATED_RW -> STATE_ILLEGAL_RWX: "ILLEGAL mprotect(RW|X)" {
  style: {
    stroke: red
    stroke-dash: 2
    stroke-width: 4
    animated: true
  }
}

STATE_EXECUTABLE_RX -> STATE_ILLEGAL_RWX: "POLICY BREACH: Grant W to RX" {
  style: {
    stroke: red
    stroke-dash: 2
    stroke-width: 4
    animated: true
  }
}

STATE_ILLEGAL_RWX -> STATE_UNALLOCATED: "Hardware Fault: TERMINATE" {
  style: {
    stroke: "#d32f2f"
    stroke-width: 3
    bold: true
  }
}

# ---------------------------------------------------------------------------------------
# Specification Metadata
# ---------------------------------------------------------------------------------------

legend_container: "Implementation Legend" {
  near: bottom-right
  
  rw_key: "Writable Page (Data)" {
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
  }
  rx_key: "Executable Page (Code)" {
    style.fill: "#f1f8e9"
    style.stroke: "#2e7d32"
  }
  rwx_key: "Illegal RWX Page" {
    style.fill: "#ffebee"
    style.stroke: "#d32f2f"
    style.double-border: true
  }
}

title_node: "" {
  label: |md
    # W^X Memory Lifecycle Implementation Spec
    **System Programming Hardware Logic Enforcement Machine**
    ---
    *Draft: V2.2 | Safety Level: ASIL-D | Engine: ELK*
  |
  near: top-center
  shape: rectangle
  style: {
    stroke-width: 0
    fill: transparent
  }
}