direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# mmap/mprotect System Call Sequence: JIT Lifecycle
# Intel/x86_64 Implementation Context
jit_sequence: {
  shape: sequence_diagram

  # Participants
  Application: {
    shape: person
    style.fill: "#D2E1FF"
  }
  CodeEmitter: {
    style.fill: "#E4DBFE"
  }
  OS: Operating System {
    style.fill: "#F0F0F0"
    mmap: "mmap(2)" {
      style.fill: "#FFF5E6"
    }
    mprotect: "mprotect(2)" {
      style.fill: "#FFF5E6"
    }
  }
  CPU: x86_64 Processor {
    style.fill: "#FFEBCC"
  }

  # 1. Initialization Phase
  Application -> CodeEmitter: "emitter_create(4096)" {
    style.stroke: "#2D5AF7"
    style.bold: true
  }
  
  CodeEmitter.init -> OS.mmap: "mmap(NULL, 4096, PROT_READ|PROT_WRITE, MAP_PRIVATE|MAP_ANONYMOUS, -1, 0)" {
    tooltip: "Request Read/Write page from Kernel"
  }
  
  OS.mmap -> CodeEmitter.init: "buffer = 0x7fff0000 (page-aligned)" {
    style.stroke-dash: 3
  }

  CodeEmitter -> Application: "emitter = {buffer: 0x7fff0000, cursor: 0x7fff0000, capacity: 4096, used: 0, prot: RW}" {
    style.stroke: "#2D5AF7"
  }

  # 2. Emission Phase (Memory is PROT_READ | PROT_WRITE)
  Application -> CodeEmitter: "emit_mov_r64_imm64(REG_RAX, 42)"
  
  CodeEmitter."Emit: 48 B8 2A 00 00 00 00 00 00 00" {
    style.font-color: "#555555"
    style.italic: true
  }

  Application -> CodeEmitter: "emit_ret()"
  
  CodeEmitter."Emit: C3" {
    style.font-color: "#555555"
    style.italic: true
  }

  # 3. Finalization & State Transition (W^X Enforcement)
  Application -> CodeEmitter: "emitter_finalize(e)" {
    style.stroke: "#F7931A"
  }

  # Cache coherency
  CodeEmitter -> CPU: "__builtin___clear_cache(buffer, cursor)"
  CPU."Instruction Cache Flush\nSynchronize I-cache with D-cache" {
    style.stroke: "#E67E22"
  }

  # Transition from RW to RX
  CodeEmitter.finalize -> OS.mprotect: "mprotect(buffer, 4096, PROT_READ | PROT_EXEC)" {
    style.stroke: "#E74C3C"
  }

  OS.mprotect."W^X Policy Check:\n1. Remove Write Bit\n2. Verify No Existing Write Bit\n3. Add Exec Bit" {
    style.font-size: 10
  }

  OS.mprotect -> CodeEmitter.finalize: "0 (SUCCESS)" {
    style.stroke-dash: 3
    style.stroke: "#27AE60"
  }

  CodeEmitter -> CodeEmitter: "update internal state: prot_state = EXEC" {
    style.stroke: "#27AE60"
  }

  CodeEmitter -> Application: "return (int64_t (*)(void))0x7fff0000"

  # 4. Execution Phase
  Application -> Application: "func = (int64_t (*)(void))0x7fff0000"
  
  Application.exec -> CPU: "call *func" {
    style.bold: true
    style.stroke: "#2D5AF7"
  }

  CPU."Execution Context:\nrip = 0x7fff0000\nmov rax, 42\nret" {
    style.fill: "#FFF9C9"
  }

  CPU -> Application.exec: "rax = 42" {
    style.stroke-dash: 3
  }

  Application -> Application: "result == 42 ✓" {
    style.font-color: "#27AE60"
    style.bold: true
  }
}

# Annotations for Engineers
Legend: {
  near: bottom-right
  
  protection_rule: "Security Policy: W^X (Write XOR Execute)" {
    shape: text
    style.font-size: 12
    style.italic: true
  }
  
  off_0: "Offset 0x00: Page allocation (RW)" {
    shape: text
    style.font-color: "#2D5AF7"
  }
  off_final: "Offset 0xNN: Protection toggle (RX)" {
    shape: text
    style.font-color: "#E74C3C"
  }
}

# Style overrides for technical clarity
jit_sequence.**: {
  &shape: sequence_diagram
  style.stroke-width: 2
}

(jit_sequence.CodeEmitter.init -> jit_sequence.OS.mmap)[0].style.stroke: "#F39C12"
(jit_sequence.CodeEmitter.finalize -> jit_sequence.OS.mprotect)[0].style.stroke: "#E74C3C"