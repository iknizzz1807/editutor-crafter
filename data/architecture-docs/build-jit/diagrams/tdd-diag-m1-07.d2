direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # Intel x86-64 ModR/M Byte Encoding
  *Instruction Operand Encoding Reference*
|| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --- Visual Memory Layout Representation ---
# FIXED: Removed nested children from sql_table row definitions
layout: {
  near: top-left
  shape: sql_table
  style.fill: "#E1BEE7"
  
  "7 - 6": "MOD (Mode)"
  "5 - 3": "REG (Register / Opcode Extension)"
  "2 - 0": "R/M (Register or Memory)"
}

# Apply styles to specific rows via reference
layout."7 - 6".style.fill: "#BBDEFB"
layout."5 - 3".style.fill: "#C8E6C9"
layout."2 - 0".style.fill: "#FFF9C4"

# --- Algorithm Steps ---

step_1: "Step 1: Receive Input Components" {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  input_box: ||md
    ### Input Parameters
    | Field | Size | Description |
    | :--- | :--- | :--- |
    | **mod** | 2 bits | Addressing mode (00, 01, 10, 11) |
    | **reg** | 3 bits | Source/Dest Register or Opcode Ext |
    | **r/m** | 3 bits | Base register or Register operand |
  ||
}

step_2: "Step 2: Calculate Byte Value" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  formula: ||md
    ### Bitwise Assembly
    `Result = (mod << 6) | (reg << 3) | r/m`

    **Example: mov rax, rbx**
    - `mod` = `11` (Register direct)
    - `reg` = `011` (RBX)
    - `r/m` = `000` (RAX)
    - **Binary**: **11** **011** **000** → `0xD8`
  ||
}

step_3: "Step 3: Mode Interpretation" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  modes: {
    mode_00: "mod=00: [reg] (No Displacement)\n*Special: r/m=101 is RIP+disp32*"
    mode_01: "mod=01: [reg + disp8]"
    mode_10: "mod=10: [reg + disp32]"
    mode_11: "mod=11: Register Direct (rax, rbx, etc.)"
  }
}

step_4: "Step 4: Register-to-Register (mod=11)" {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  reg_reg: {
    example: ||md
      **Target: mov rax, rbx**
      - MOD: `11`
      - REG: `011` (Source: RBX)
      - R/M: `000` (Dest: RAX)
      - **Resulting Byte: 0xD8**
    ||
    note: ||md
      *Note: REX.R/REX.B bits may extend these 3-bit fields to 4 bits in x64 mode.*
    ||
  }
}

step_5: "Step 5: Memory Addressing (mod < 11)" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 2
  mem_mode: {
    example: ||md
      **Target: mov rax, [rbx]**
      - MOD: `00` (No disp)
      - REG: `000` (Dest: RAX)
      - R/M: `011` (Ptr: RBX)
      - **Resulting Byte: 0x03**
    ||
    special: ||md
      **Escapes:**
      - If `r/m == 100`, an **SIB byte** must follow.
      - If `mod == 00` and `r/m == 101`, address is `[RIP + disp32]`.
    ||
  }
}

# --- Transitions ---

step_1 -> step_2: "Pass bitfields"
step_2 -> step_3: "Evaluate bit 7:6"

step_3 -> step_4: "If MOD == 11" {
  style.stroke: "#9C27B0"
  style.bold: true
}

step_3 -> step_5: "If MOD < 11" {
  style.stroke: "#F44336"
  style.bold: true
}

final_output: "Encoded ModR/M Byte" {
  shape: cylinder
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
}

step_4 -> final_output
step_5 -> final_output

# --- Footer Legend ---
legend: ||md
  ### Common Register Bit Patterns (3-bit)
  | Value | Reg (x64) | Value | Reg (x64) |
  | :--- | :--- | :--- | :--- |
  | 000 | RAX | 100 | RSP (SIB) |
  | 001 | RCX | 101 | RBP |
  | 010 | RDX | 110 | RSI |
  | 011 | RBX | 111 | RDI |
|| {
  near: bottom-center
  style.font-size: 14
}