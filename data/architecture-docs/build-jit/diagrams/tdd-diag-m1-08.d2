vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
title: |md
  # ModR/M Encoding Decision Tree
| {near: top-center}
start: "ModR/M Operand" {
  shape: oval
  style.fill: "#E8F4FD"
  style.stroke: "#2563EB"
  style.font-color: "#1E40AF"
}
start -> is_reg
is_reg: "Is operand\na register?" {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
is_reg -> mod_11: YES
is_reg -> is_mem: NO
mod_11: "mod = 11\n(Register Direct)" {
  shape: rectangle
  style.fill: "#D1FAE5"
  style.stroke: "#059669"
}
mod_11 -> reg_field
is_mem -> disp_check
disp_check: "Has\ndisplacement?" {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
disp_check -> disp_size: YES
disp_check -> no_disp: NO
no_disp: "mod = 00\n(Memory,\nno disp)" {
  shape: rectangle
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
}
no_disp -> rbp_check
disp_size: "Displacement\nsize?" {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
disp_size -> mod_01: "8-bit\n(disp8)"
disp_size -> mod_10: "32-bit\n(disp32)"
mod_01: "mod = 01\n(Memory +\ndisp8)" {
  shape: rectangle
  style.fill: "#E0E7FF"
  style.stroke: "#4F46E5"
}
mod_10: "mod = 10\n(Memory +\ndisp32)" {
  shape: rectangle
  style.fill: "#F3E8FF"
  style.stroke: "#7C3AED"
}
mod_01 -> rbp_check
mod_10 -> rbp_check
rbp_check: "r/m = 101\n(rbp/r13)?" {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
rbp_check -> needs_sib_or_disp: YES
rbp_check -> final_rm: NO
needs_sib_or_disp: |md
  **SIB or disp32 required!**
  rbp/r13 cannot be base
  without SIB or displacement
| {
  shape: rectangle
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.font-color: "#991B1B"
}
needs_sib_or_disp -> sib_path
needs_sib_or_disp -> disp_only
sib_path: "Use SIB byte\nr/m = 100" {
  shape: rectangle
  style.fill: "#ECFDF5"
  style.stroke: "#059669"
}
disp_only: "Use disp32\nonly (no base)" {
  shape: rectangle
  style.fill: "#F0FDF4"
  style.stroke: "#16A34A"
}
final_rm: "Encode r/m\n(000-111)" {
  shape: rectangle
  style.fill: "#F0FDF4"
  style.stroke: "#16A34A"
}
reg_field: "Encode reg\n(000-111)" {
  shape: rectangle
  style.fill: "#ECFDF5"
  style.stroke: "#059669"
}
reg_field -> done
final_rm -> done
sib_path -> done
disp_only -> done
done: "ModR/M Byte\nComplete" {
  shape: oval
  style.fill: "#D1FAE5"
  style.stroke: "#059669"
  style.font-color: "#047857"
}
classes: {
  decision: {
    shape: diamond
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
  }
  action: {
    style.fill: "#ECFDF5"
    style.stroke: "#059669"
  }
}