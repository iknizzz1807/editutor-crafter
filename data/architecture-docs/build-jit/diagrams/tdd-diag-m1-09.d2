direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 20
  }
}

# ---------------------------------------------------------------------------------
# CLASSES & STYLING
# ---------------------------------------------------------------------------------
classes: {
  header_field: {
    style: {
      fill: "#E1D5E7" # Purple
      stroke: "#9673A6"
      stroke-width: 2
      bold: true
      font-size: 14
    }
  }
  data_field: {
    style: {
      fill: "#DAE8FC" # Blue
      stroke: "#6C8EBF"
      stroke-width: 2
      bold: true
      font-size: 14
    }
  }
  addressing_field: {
    style: {
      fill: "#FFE6CC" # Orange
      stroke: "#D79B00"
      stroke-width: 2
      bold: true
      font-size: 14
    }
  }
  bit_box: {
    style: {
      font: mono
      font-size: 12
      text-transform: uppercase
      border-radius: 2
    }
  }
}

# ---------------------------------------------------------------------------------
# ROOT LEVEL COMPONENTS
# ---------------------------------------------------------------------------------

Legend: {
  near: top-left
  Header: "Control/Prefix" { class: header_field }
  Data: "Opcode/Immediate" { class: data_field }
  Addressing: "Addressing/SIB" { class: addressing_field }
}

Instruction_Encoding_Anatomy: {
  style: {
    fill: "#fdfdfd"
    stroke: "#333333"
    stroke-width: 4 # Bold boundary representing the instruction block limit
  }
  
  Title: "Intel x86-64 Instruction Encoding" {
    shape: text
    style: { font-size: 20; bold: true }
  }

  # --- Byte Offsets (Left Margin) ---
  Offsets: |md
    Byte 0
    ...
    Byte 1
    ...
    Byte 2
    ...
    Byte N
    ...
    Byte 15
  | {
    shape: text
    style.font: mono
    style.font-size: 10
  }

  # --- Contiguous Memory Layout ---
  Memory_Layout: {
    grid-rows: 2
    grid-gap: 0
    
    # Row 1: Logical Field Names
    L1: "Legacy Prefixes" { width: 160; class: header_field }
    L2: "REX Prefix" { width: 100; class: header_field }
    L3: "Opcode" { width: 120; class: data_field }
    L4: "ModR/M" { width: 100; class: addressing_field }
    L5: "SIB" { width: 100; class: addressing_field }
    L6: "Displacement" { width: 140; class: addressing_field }
    L7: "Immediate" { width: 140; class: data_field }

    # Row 2: Field Sizes & Constraints
    S1: "0-4 Bytes" { height: 50; style.stroke-dash: 3 }
    S2: "0-1 Byte" { height: 50; style.stroke-dash: 3 }
    S3: "1-3 Bytes" { height: 50; style.stroke-dash: 0 }
    S4: "0-1 Byte" { height: 50; style.stroke-dash: 3 }
    S5: "0-1 Byte" { height: 50; style.stroke-dash: 3 }
    S6: "0, 1, 2, 4 B" { height: 50; style.stroke-dash: 3 }
    S7: "0, 1, 2, 4, 8 B" { height: 50; style.stroke-dash: 3 }
  }

  # --- Bitfield Breakdowns ---
  REX_Breakdown: {
    label: "REX Prefix (0x40-0x4F)"
    grid-columns: 5
    grid-gap: 2
    
    Fixed: "0100" { class: bit_box; tooltip: "Fixed prefix identifier" }
    W: "W" { class: bit_box; style.fill: "#E1D5E7"; tooltip: "0=Default, 1=64-bit Operand Size" }
    R: "R" { class: bit_box; style.fill: "#E1D5E7"; tooltip: "Extension of ModR/M 'reg' field" }
    X: "X" { class: bit_box; style.fill: "#E1D5E7"; tooltip: "Extension of SIB 'index' field" }
    B: "B" { class: bit_box; style.fill: "#E1D5E7"; tooltip: "Extension of ModR/M 'r/m' or SIB 'base'" }
  }

  ModRM_Breakdown: {
    label: "ModR/M Byte"
    grid-columns: 3
    grid-gap: 2
    
    Mod: "Mod [7:6]" { class: bit_box; style.fill: "#FFE6CC"; tooltip: "00, 01, 10 for displacement; 11 for Register-to-Register" }
    Reg: "Reg [5:3]" { class: bit_box; style.fill: "#FFE6CC"; tooltip: "Register index or opcode extension" }
    RM: "R/M [2:0]" { class: bit_box; style.fill: "#FFE6CC"; tooltip: "Register or Memory addressing mode" }
  }

  SIB_Breakdown: {
    label: "SIB (Scale-Index-Base)"
    grid-columns: 3
    grid-gap: 2
    
    Scale: "SS [7:6]" { class: bit_box; style.fill: "#FFE6CC"; tooltip: "Multiplier: 1, 2, 4, 8" }
    Index: "Index [5:3]" { class: bit_box; style.fill: "#FFE6CC"; tooltip: "Index register selector" }
    Base: "Base [2:0]" { class: bit_box; style.fill: "#FFE6CC"; tooltip: "Base register selector" }
  }
}

# ---------------------------------------------------------------------------------
# LOGICAL CONNECTIONS & ANNOTATIONS
# ---------------------------------------------------------------------------------

Instruction_Encoding_Anatomy.Memory_Layout.L2 -> Instruction_Encoding_Anatomy.REX_Breakdown
Instruction_Encoding_Anatomy.Memory_Layout.L4 -> Instruction_Encoding_Anatomy.ModRM_Breakdown
Instruction_Encoding_Anatomy.Memory_Layout.L5 -> Instruction_Encoding_Anatomy.SIB_Breakdown

Implementation_Notes: |md
  ### x86-64 Instruction Rules
  - **Instruction Length**: Hard limit of **15 bytes**. If prefixes + encoding exceeds 15, CPU triggers #UD.
  - **Legacy Prefixes**: Include Lock (F0), Repeat (F2, F3), Segment Overrides (2E, 36, etc.).
  - **REX**: Mandatory for 64-bit operand width or accessing R8-R15 registers. Must precede Opcode.
  - **ModR/M & SIB**: Only present if the Opcode requires memory/register addressing.
  - **Displacement/Immediate**: Encoded in Little-Endian byte order.
| {
  near: bottom-center
  style.font-size: 14
}

# --- Metadata (Right Margin) ---
TotalSize: "sizeof = 1...15 bytes" {
  near: top-right
  style: { font-size: 12; italic: true; font-color: "#444444" }
}

# ---------------------------------------------------------------------------------
# LAYOUT CONSTRAINTS
# ---------------------------------------------------------------------------------
Instruction_Encoding_Anatomy.Offsets -> Instruction_Encoding_Anatomy.Memory_Layout: {style.opacity: 0}
Instruction_Encoding_Anatomy.Title -> Instruction_Encoding_Anatomy.Memory_Layout: {style.opacity: 0}