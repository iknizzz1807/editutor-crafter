direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
  colors: {
    header: "#f3f4f6"
    rex_no: "#e3f2fd"
    rex_yes: "#fff3e0"
    border: "#1a1a1b"
    accent: "#ef5350"
  }
}

classes: {
  cell: {
    style: {
      stroke: ${colors.border}
      stroke-width: 1
      font-size: 14
      border-radius: 0
      fill: white
    }
  }
  header_cell: {
    style: {
      fill: ${colors.header}
      bold: true
      font-size: 14
      text-transform: uppercase
    }
  }
  no_rex_row: {
    style: {
      fill: ${colors.rex_no}
    }
  }
  rex_row: {
    style: {
      fill: ${colors.rex_yes}
    }
  }
}

title: {
  label: |md
    # x86-64 CPU Register Encoding Map
    ## ModR/M & REX.B Architectural Bit-Mapping
  |
  near: top-center
}

Register_Encoding_Table: {
  grid-columns: 5
  grid-gap: 0
  width: 1000

  # Bit Header Visualization
  bit_label: "Bit Weight" { class: [cell; header_cell] }
  b3: "2³ (8)" { class: [cell; header_cell] }
  b2: "2² (4)" { class: [cell; header_cell] }
  b1: "2¹ (2)" { class: [cell; header_cell] }
  b0: "2⁰ (1)" { class: [cell; header_cell] }

  # Functional Header Row
  h_field: "Field Name" { class: [cell; header_cell] }
  h_rex: "REX.B (Extension)" { class: [cell; header_cell] }
  h_reg_h: "Bit 2 (ModRM.reg)" { class: [cell; header_cell] }
  h_reg_m: "Bit 1 (ModRM.reg)" { class: [cell; header_cell] }
  h_reg_l: "Bit 0 (ModRM.reg)" { class: [cell; header_cell] }

  # Legacy Registers (REX.B = 0)
  r0_f: "RAX (Accumulator)"; r0_b3: "0"; r0_b2: "0"; r0_b1: "0"; r0_b0: "0"
  r1_f: "RCX (Counter)";     r1_b3: "0"; r1_b2: "0"; r1_b1: "0"; r1_b0: "1"
  r2_f: "RDX (Data)";        r2_b3: "0"; r2_b2: "0"; r2_b1: "1"; r2_b0: "0"
  r3_f: "RBX (Base)";        r3_b3: "0"; r3_b2: "0"; r3_b1: "1"; r3_b0: "1"
  r4_f: "RSP (Stack Ptr)";   r4_b3: "0"; r4_b2: "1"; r4_b1: "0"; r4_b0: "0"
  r5_f: "RBP (Frame Ptr)";   r5_b3: "0"; r5_b2: "1"; r5_b1: "0"; r5_b0: "1"
  r6_f: "RSI (Source Idx)";  r6_b3: "0"; r6_b2: "1"; r6_b1: "1"; r6_b0: "0"
  r7_f: "RDI (Dest Idx)";    r7_b3: "0"; r7_b2: "1"; r7_b1: "1"; r7_b0: "1"

  r0_f.class: [cell; no_rex_row]; r0_b3.class: [cell; no_rex_row]; r0_b2.class: [cell; no_rex_row]; r0_b1.class: [cell; no_rex_row]; r0_b0.class: [cell; no_rex_row]
  r1_f.class: [cell; no_rex_row]; r1_b3.class: [cell; no_rex_row]; r1_b2.class: [cell; no_rex_row]; r1_b1.class: [cell; no_rex_row]; r1_b0.class: [cell; no_rex_row]
  r2_f.class: [cell; no_rex_row]; r2_b3.class: [cell; no_rex_row]; r2_b2.class: [cell; no_rex_row]; r2_b1.class: [cell; no_rex_row]; r2_b0.class: [cell; no_rex_row]
  r3_f.class: [cell; no_rex_row]; r3_b3.class: [cell; no_rex_row]; r3_b2.class: [cell; no_rex_row]; r3_b1.class: [cell; no_rex_row]; r3_b0.class: [cell; no_rex_row]
  r4_f.class: [cell; no_rex_row]; r4_b3.class: [cell; no_rex_row]; r4_b2.class: [cell; no_rex_row]; r4_b1.class: [cell; no_rex_row]; r4_b0.class: [cell; no_rex_row]
  r5_f.class: [cell; no_rex_row]; r5_b3.class: [cell; no_rex_row]; r5_b2.class: [cell; no_rex_row]; r5_b1.class: [cell; no_rex_row]; r5_b0.class: [cell; no_rex_row]
  r6_f.class: [cell; no_rex_row]; r6_b3.class: [cell; no_rex_row]; r6_b2.class: [cell; no_rex_row]; r6_b1.class: [cell; no_rex_row]; r6_b0.class: [cell; no_rex_row]
  r7_f.class: [cell; no_rex_row]; r7_b3.class: [cell; no_rex_row]; r7_b2.class: [cell; no_rex_row]; r7_b1.class: [cell; no_rex_row]; r7_b0.class: [cell; no_rex_row]

  # Extended Registers (REX.B = 1)
  r8_f: "R8 (General)";      r8_b3: "1"; r8_b2: "0"; r8_b1: "0"; r8_b0: "0"
  r9_f: "R9 (General)";      r9_b3: "1"; r9_b2: "0"; r9_b1: "0"; r9_b0: "1"
  r10_f: "R10 (Temporary)";  r10_b3: "1"; r10_b2: "0"; r10_b1: "1"; r10_b0: "0"
  r11_f: "R11 (Temporary)";  r11_b3: "1"; r11_b2: "0"; r11_b1: "1"; r11_b0: "1"
  r12_f: "R12 (General)";    r12_b3: "1"; r12_b2: "1"; r12_b1: "0"; r12_b0: "0"
  r13_f: "R13 (General)";    r13_b3: "1"; r13_b2: "1"; r13_b1: "0"; r13_b0: "1"
  r14_f: "R14 (General)";    r14_b3: "1"; r14_b2: "1"; r14_b1: "1"; r14_b0: "0"
  r15_f: "R15 (General)";    r15_b3: "1"; r15_b2: "1"; r15_b1: "1"; r15_b0: "1"

  r8_f.class: [cell; rex_row]; r8_b3.class: [cell; rex_row]; r8_b2.class: [cell; rex_row]; r8_b1.class: [cell; rex_row]; r8_b0.class: [cell; rex_row]
  r9_f.class: [cell; rex_row]; r9_b3.class: [cell; rex_row]; r9_b2.class: [cell; rex_row]; r9_b1.class: [cell; rex_row]; r9_b0.class: [cell; rex_row]
  r10_f.class: [cell; rex_row]; r10_b3.class: [cell; rex_row]; r10_b2.class: [cell; rex_row]; r10_b1.class: [cell; rex_row]; r10_b0.class: [cell; rex_row]
  r11_f.class: [cell; rex_row]; r11_b3.class: [cell; rex_row]; r11_b2.class: [cell; rex_row]; r11_b1.class: [cell; rex_row]; r11_b0.class: [cell; rex_row]
  r12_f.class: [cell; rex_row]; r12_b3.class: [cell; rex_row]; r12_b2.class: [cell; rex_row]; r12_b1.class: [cell; rex_row]; r12_b0.class: [cell; rex_row]
  r13_f.class: [cell; rex_row]; r13_b3.class: [cell; rex_row]; r13_b2.class: [cell; rex_row]; r13_b1.class: [cell; rex_row]; r13_b0.class: [cell; rex_row]
  r14_f.class: [cell; rex_row]; r14_b3.class: [cell; rex_row]; r14_b2.class: [cell; rex_row]; r14_b1.class: [cell; rex_row]; r14_b0.class: [cell; rex_row]
  r15_f.class: [cell; rex_row]; r15_b3.class: [cell; rex_row]; r15_b2.class: [cell; rex_row]; r15_b1.class: [cell; rex_row]; r15_b0.class: [cell; rex_row]
}

Bit_Structure_Legend: {
  near: bottom-right
  grid-columns: 1
  grid-gap: 15
  
  No_REX: {
    direction: right
    Indicator: "" {
      width: 24; height: 24
      style.fill: ${colors.rex_no}
      style.stroke: black
    }
    Label: "Legacy GPRs (0-7): REX.B = 0"
    Indicator -> Label: {style.stroke-width: 0; source-arrowhead: none; target-arrowhead: none}
  }
  With_REX: {
    direction: right
    Indicator: "" {
      width: 24; height: 24
      style.fill: ${colors.rex_yes}
      style.stroke: black
    }
    Label: "Extended GPRs (8-15): REX.B = 1"
    Indicator -> Label: {style.stroke-width: 0; source-arrowhead: none; target-arrowhead: none}
  }
}

Encoding_Logic: {
  near: bottom-left
  style: {
    fill: "#fcfcfc"
    stroke: "#777"
    stroke-width: 2
    border-radius: 4
  }
  label: |md
    ### Architectural Encoding Logic
    
    The 4-bit register ID is synthesized from two instruction components:
    1. **REX.B (Bit 3)**: Extracted from the REX prefix byte.
    2. **Reg Code (Bits 0-2)**: Extracted from the `reg` or `r/m` fields of the ModR/M byte.
    
    **Identity Formula:**
    `Final_Reg_ID = (REX.B << 3) | ModRM.reg_code`
    
    *Example: R11*
    - REX Prefix contains `B=1`
    - ModR/M `reg` field contains `011`
    - Result: `1011` binary = `11` decimal.
  |
}

Technical_Constraints: {
  near: bottom-center
  style: {
    font-size: 13
    fill: "#fafafa"
  }
  label: |md
    ### Implementation Constraints
    - **Uniformity**: In 64-bit mode, the REX prefix is mandatory to access the high 8 registers (R8-R15).
    - **SIB Byte**: RSP (Code 4) and R12 (Code 4 + REX.B) trigger SIB addressing when used in the `r/m` field.
    - **Conflict**: High byte registers (AH, CH, DH, BH) cannot be addressed if a REX prefix is present.
    - **Default Size**: Instruction operands default to 32-bit; REX.W must be set to 1 for 64-bit operand size.
  |
  shape: text
}