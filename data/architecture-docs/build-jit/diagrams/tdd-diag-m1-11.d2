vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 30
  }
}

# -----------------------------------------------------------------------------
# GLOBAL HEADER
# -----------------------------------------------------------------------------
title: |`md
  # Instruction Emission Verification Loop
  ### JIT Compiler TDD Validation Pipeline & Byte-Level Consistency Check
  **ISA:** x86-64 / AMD64 | **Toolchain:** GNU Binutils & Capstone Engine
`|
title.shape: text
title.near: top-center
title.style: {
  font-size: 24
  bold: true
  font-color: "#0D47A1"
}

# -----------------------------------------------------------------------------
# MEMORY BUFFER VISUALIZATION (Byte Layout)
# -----------------------------------------------------------------------------
Instruction_Buffer: {
  label: "Instruction Stream Buffer (Memory Layout - 16B Aligned)"
  shape: sql_table
  style: {
    fill: "#F5F5F5"
    stroke: "#333333"
    stroke-width: 2
  }
  
  "0x00": "REX.W (0x48)" {constraint: "Header: Purple"; style.fill: "#E1BEE7"}
  "0x01": "Opcode (0x8B)" {constraint: "Data: Blue"; style.fill: "#BBDEFB"}
  "0x02": "ModR/M (0x05)" {constraint: "Data: Blue"; style.fill: "#BBDEFB"}
  "0x03": "Disp32 [byte 0]" {constraint: "Data: Blue"; style.fill: "#BBDEFB"}
  "0x04": "Disp32 [byte 1]" {constraint: "Data: Blue"; style.fill: "#BBDEFB"}
  "0x05": "Disp32 [byte 2]" {constraint: "Data: Blue"; style.fill: "#BBDEFB"}
  "0x06": "Disp32 [byte 3]" {constraint: "Data: Blue"; style.fill: "#BBDEFB"}
  "0x07": "Padding (0x00)" {constraint: "Padding: Gray"; style.fill: "#E0E0E0"}
}

Offset_Note: "Target: [RAX] = MOV [RIP + Disp32]"
Offset_Note.near: Instruction_Buffer
Offset_Note.shape: text
Offset_Note.style.font-size: 12

# -----------------------------------------------------------------------------
# PIPELINE STAGES
# -----------------------------------------------------------------------------
direction: down

Generation: {
  label: "Stage 1: Generation & Internal Verify"
  Emit_Bytes: "0x00: EMIT BYTES\n(Instruction Encoding)" {
    shape: class
    tooltip: "Appends opcode and operands to the instruction stream buffer."
    Definition: "void emit(instr_t* i)"
    Fields: "uint8_t* stream_ptr"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 3
    }
  }

  Capstone: "CAPSTONE ENGINE\n(Internal Disasm)" {
    shape: class
    tooltip: "Direct verification using cs_disasm() without file I/O overhead."
    Signature: "cs_disasm(handle, code, size, address, count, &insn)"
    style: {
      fill: "#E8EAF6"
      stroke: "#3F51B5"
      stroke-dash: 4
      stroke-width: 2
      multiple: true
    }
  }
  
  Emit_Bytes -> Capstone: "Pointer: uint8_t*" {
    style: {
      stroke: "#FF9800"
      stroke-width: 2
      source-arrowhead: circle
    }
  }
}

Persistence: {
  label: "Stage 2: Disk Sync"
  Write_Temp: "0x20: PERSISTENCE\nWrite to /tmp/jit.bin" {
    shape: cylinder
    tooltip: "Flushes the raw byte buffer to a temporary flat binary file."
    Command: "fwrite(buffer, 1, len, tmp_file)"
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
}

External_Analysis: {
  label: "Stage 3: GNU Toolchain Analysis"
  objdump: "0x40: EXTERNAL DISASM\nobjdump -D -b binary" {
    tooltip: "Verification Command: objdump -D -b binary -m i386:x86-64 -M intel verify.bin"
    Flags: "-D (Disassemble), -M intel (Syntax)"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      font: mono
      stroke-width: 2
    }
  }

  Parse_Output: "0x60: REGEX PARSER\nTokenize Stdout" {
    tooltip: "Extracts hex strings and mnemonics from objdump table format."
    Pattern: "/^\\s*[0-9a-f]+:\\s+((?:[0-9a-f]{2} )+)\\s+(.*)$/i"
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
    }
  }
}

Validation_Logic: {
  label: "Stage 4: Assertion Logic"
  Extract_Mnemonic: "EXTRACT MNEMONIC\n(Actual Result)" {
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
    }
  }

  Expected: "EXPECTED SPEC\n(Reference Mnemonic)" {
    tooltip: "The intended mnemonic defined in the TDD test case."
    Metadata: "const char* target_mnemonic"
    style: {
      fill: "#E0F7FA"
      stroke: "#00BCD4"
      stroke-width: 2
    }
  }

  Compare: "VALIDATION\nstrcmp()" {
    shape: diamond
    style: {
      fill: "#FFEB3B"
      stroke: "#F57F17"
      bold: true
    }
  }
}

# -----------------------------------------------------------------------------
# OUTCOME STATES
# -----------------------------------------------------------------------------
Outcome_Group: {
  Pass: "✓ TEST PASS\nCorrect Encoding" {
    shape: circle
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      font-color: white
      bold: true
      shadow: true
    }
  }

  Fail: "✗ TEST FAIL\nEncoding Mismatch" {
    shape: circle
    style: {
      fill: "#F44336"
      stroke: "#C62828"
      font-color: white
      bold: true
      shadow: true
    }
  }
}

# -----------------------------------------------------------------------------
# CONNECTIONS AND DATA FLOW
# -----------------------------------------------------------------------------
Generation.Emit_Bytes -> Persistence.Write_Temp: "Memory Dump\n(raw bytes)"
Persistence.Write_Temp -> External_Analysis.objdump: "File I/O\n(verify.bin)"
External_Analysis.objdump -> External_Analysis.Parse_Output: "STDOUT\n(pipe)"
External_Analysis.Parse_Output -> Validation_Logic.Extract_Mnemonic: "tokens"
Validation_Logic.Extract_Mnemonic -> Validation_Logic.Compare: "actual_str"
Validation_Logic.Expected -> Validation_Logic.Compare: "target_str"

Validation_Logic.Compare -> Outcome_Group.Pass: "Match (== 0)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 6
  }
}

Validation_Logic.Compare -> Outcome_Group.Fail: "Mismatch (!= 0)" {
  style: {
    stroke: "#F44336"
    stroke-width: 6
    stroke-dash: 4
  }
}

Generation.Capstone -> External_Analysis.Parse_Output: "Internal Path\n(Bypass Disk)" {
  style: {
    stroke: "#3F51B5"
    stroke-dash: 3
    animated: true
  }
}

# -----------------------------------------------------------------------------
# ANNOTATIONS
# -----------------------------------------------------------------------------
Verification_Notes: |`md
  ### Low-Level Verification Specification
  1. **Source:** JIT Compiler Instruction Buffer (Hex-encoded array).
  2. **Toolchain:** GNU Binutils `objdump` version 2.38+ | Capstone 5.0.
  3. **Target ISA:** x86-64 (Long Mode) | Intel Mnemonic Syntax.
  4. **Comparison Mode:** Case-insensitive string match on instruction mnemonic.
     *   *Standard:* `mov rax, 0x1`
     *   *Mismatch:* `mov eax, 1` (Incorrect operand size).
  5. **Error Reporting:** Returns `EXIT_FAILURE` and hex-diff of instruction bytes on fail.
`|
Verification_Notes.near: bottom-left
Verification_Notes.style: {
  fill: "#FAFAFA"
  stroke: "#B0BEC5"
  border-radius: 8
}

Instruction_Buffer -> Generation.Emit_Bytes: "Target Buffer" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}