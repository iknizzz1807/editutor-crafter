direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# --- CLASSES FOR TECHNICAL SPECIFICATION ---
# Defining rigorous styles for implementation-grade clarity.
classes: {
  actor_style: {
    style: {
      stroke-width: 2
      border-radius: 4
      font-size: 14
      bold: true
      font: mono
    }
  }
  internal_loop: {
    style: {
      stroke: "#666666"
      stroke-dash: 5
      fill: "#F9F9F9"
      double-border: true
    }
  }
  critical_path: {
    style: {
      stroke: "#FF4500"
      stroke-width: 3
      animated: true
    }
  }
}

# --- TEST CASE EXECUTION FLOW ---
# Orchestration of JIT-compiled test suites with isolation and telemetry.
execution_flow: {
  shape: sequence_diagram
  
  # Participants - Definitions with specific Type Signatures
  orchestrator: "Orchestrator\n(Control Plane)" {
    shape: person
    class: actor_style
    style.fill: "#C6E2FF"
  }
  
  test_runner: "TestRunner\n(Golang v1.21)" {
    icon: https://icons.terrastruct.com/dev/go.svg
    class: actor_style
    style.fill: "#B5AFF6"
  }
  
  jit_compiler: "JIT Compiler\n(LLVM-16)" {
    class: actor_style
    style.fill: "#E4DBFE"
  }
  
  sandbox: "Isolated Sandbox\n(cgroups v2)" {
    class: actor_style
    style.fill: "#DEE1EB"
  }
  
  report_gen: "Report Generator\n(JUnit/Allure)" {
    class: actor_style
    style.fill: "#88DCF7"
  }

  # --- SEQUENCE START ---

  # 1. Initialization Phase
  # Locking mechanism to ensure node-level atomicity.
  orchestrator -> test_runner: "▼ acquire_lock(job_id: UUID)" {
    tooltip: "Mutex prevent concurrent execution on same node"
  }
  orchestrator -> test_runner: "execute(suite_id: UUID, config: JSON): JobID"
  
  orchestrator."Resource Limits: 512MB RAM, 1.0 vCPU, 30s TTL"
  
  test_runner -> test_runner: "load_manifest(suite_id): TestManifest"
  
  # 2. Compilation Phase (High-Performance Path)
  # JIT compilation occurs before sandbox entry to minimize overhead.
  compilation_block: "Compilation Phase (LLVM IR Optimizations)" {
    test_runner -> jit_compiler: "compile_to_bytecode(src: String): IR"
    jit_compiler -> jit_compiler: "optimize_ir(level: O3): Binary"
    test_runner <- jit_compiler: "binary_handle: *u8 (offset: 0x400)"
  }

  # 3. Environment Setup
  # Establishing kernel namespaces for process isolation.
  test_runner -> sandbox: "unshare(CLONE_NEWPID | CLONE_NEWNET): void"
  test_runner -> sandbox: "provision(mem_limit: 536870912B): status_t"
  
  # 4. Critical Execution Loop
  # Iterative execution of test binaries within the cgroup boundary.
  execution_loop: "Test Execution Loop [0...N Tests]" {
    class: internal_loop
    
    test_runner -> sandbox: "run_test(bin: Binary, ctx: Map): ExitCode" {
      source-arrowhead: 1
    }
    
    sandbox -> sandbox: "mmap(PROT_EXEC): void"
    sandbox -> sandbox: "execute_instructions()"
    
    sandbox."Watchdog Monitor: SIGKILL at t > threshold"
    
    # State Capture & Telemetry
    # Returns raw memory dumps and performance counters.
    test_runner <- sandbox: "capture_telemetry(): raw_results" {
      label: "raw_results {std: [out, err], perf: metrics}"
      style.stroke: "#167c3c"
      style.bold: true
      style.stroke-dash: 3
    }
  }

  # 5. Teardown & Resource Release
  test_runner -> sandbox: "cleanup_namespaces(): status" {
    style.stroke: red
  }
  test_runner -> test_runner: "▲ release_lock(job_id)"

  # 6. Result Aggregation
  test_runner -> report_gen: "process_telemetry(data: raw_results): HTML"
  report_gen -> report_gen: "generate_analytics(p95_latency, failure_rate)"
  
  # Completion Signal
  orchestrator <- report_gen: "notify_completion(report_url: String)" {
    style: {
      animated: true
      stroke: blue
      stroke-width: 3
    }
  }
}

# Documentation Metadata - Positioned via explicit assignment to fix ELK constraint
metadata: {
  shape: rectangle
  near: execution_flow
  label: |md
    ### Sequence Specification & Technical Invariants
    
    | Phase | Component | Action | Expected Invariant |
    | :--- | :--- | :--- | :--- |
    | **Init** | Orchestrator | Lock | Job ID must be globally unique across clusters. |
    | **JIT** | Compiler | LLVM IR | Bytecode must be aligned to 16-byte boundaries. |
    | **Sandbox** | Sandbox | cgroups | Memory limit (hard) enforced via `memory.max`. |
    | **Report** | Generator | Cleanup | Ephemeral storage cleared post-ingestion. |

    #### Performance Constraints
    - **Latency**: JIT compilation must complete in < 500ms.
    - **Overhead**: Sandbox initialization must occupy < 5% of total runtime.
    - **Reliability**: Isolated namespace prevents PID exhaustion on host.
  |
  style: {
    font-size: 14
    fill: "#FDFDFD"
    stroke: "#DDDDDD"
    border-radius: 8
  }
}

# --- GLOBAL STYLING & GLOBS ---
# High-Resolution Styling for Intel-manual quality.
***.style.stroke-width: 2
(*** -> ***)[*]: {
  style.font-size: 13
  style.font: mono
}

# Explicit timing annotations for critical path segments
(execution_flow.test_runner -> execution_flow.sandbox)[0].label: "exec_req (T+10ms)"
(execution_flow.test_runner <- execution_flow.sandbox)[0].label: "telemetry_ret (T+Nms)"

# Error state highlights
(execution_flow.test_runner -> execution_flow.sandbox)[1].style.stroke: red

# Connection logic for metadata context
metadata -- execution_flow: "Implementation Guide" {
  style.stroke-dash: 5
}