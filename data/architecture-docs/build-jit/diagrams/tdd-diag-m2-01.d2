direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: "JitCompiler: AU Tax Rule Externalization & Execution Pipeline" {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
    font-color: "#1A237E"
  }
}

# Core Architecture: High-performance rule evaluation
core_group: "Core Logic Layer (Engine/Registry)" {
  style: {
    stroke: "#1976D2"
    stroke-width: 4
    fill: "#F0F7FF"
    double-border: true
  }

  rule_engine: RuleEngine {
    shape: class
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    
    # Method Signatures with proper quoting to avoid parser ambiguity
    "+ evaluate(taxpayer: TaxPayer, cat: Category, yr: int)": RuleResult
    "+ get_rule(category: Category, year: int)": Rule
    
    # Memory Layout Annotation for low-level implementation detail
    label: |md
      **RuleEngine**
      ---
      0x00: vtable_ptr [8B]
      0x08: cache_line_align [56B]
      sizeof: 64 bytes (1 cache line)
    |
  }

  rule_registry: RuleRegistry {
    shape: class
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    
    "- rules": "Dict[Tuple[str, int], Rule]"
    "+ register(category: str, year: int, rule: Rule)": void
    "+ lookup(category: str, year: int)": Rule
    
    label: |md
      **RuleRegistry**
      ---
      0x00: map_ptr [8B]
      0x08: mutex_lock [4B]
      0x0C: padding [4B]
      sizeof: 1024 bytes (Heap Allocated)
    |
  }

  rule_base: Rule {
    shape: class
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-dash: 3
    }
    
    # Interface definitions
    "+ id": string
    "+ category": string
    "+ effective_year": int
    "+ version": string
    "+ apply(context: EvalContext)": RuleResult
  }

  rule_engine -> rule_registry: "1. lookup_dispatch" {
    style.stroke: "#1976D2"
    style.stroke-width: 2
  }
  rule_registry -> rule_base: "contains" {
    style.stroke: "#388E3C"
    source-arrowhead: 1
    target-arrowhead: "*" {
      shape: diamond
    }
  }
}

# Concrete Rule Implementations
rules_group: "Concrete Rule Logic (FY23-FY25 Implementations)" {
  style: {
    stroke: "#C2185B"
    fill: "#FFF5F8"
    stroke-width: 3
  }

  wfh_rule: WFHFixedRateRule {
    shape: class
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    
    "- rate_cents_per_hour": int32
    "- allowed_methods": "List[string]"
    "+ apply(ctx)": RuleResult
    
    label: |md
      **WFHFixedRateRule**
      ---
      0x00: base_rule_header [32B]
      0x20: rate_data [4B]
      0x24: padding [4B]
    |
  }

  threshold_rule: ImmediateDeductionThresholdRule {
    shape: class
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    
    "- threshold_cents": int64
    "- applicable_assets": "List[string]"
  }

  depreciation_rule: DepreciationRule {
    shape: class
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
    
    "- default_method": string
    "- effective_life_years": int16
  }

  repairs_rule: RepairsRule {
    shape: class
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
    
    "- repair_criteria": "List[string]"
  }
}

# Rule Loading System: Cold Storage to In-Memory
loader_group: "Data Ingestion Layer (Filesystem -> Memory)" {
  style: {
    stroke: "#455A64"
    fill: "#F5F7F8"
    stroke-dash: 5
  }

  yaml_loader: YAMLRuleLoader {
    shape: class
    style.fill: "#ECEFF1"
    style.stroke: "#455A64"
    
    "- rules_path": Path
    "+ load()": "List[Rule]"
    "+ validate(data: YAMLNode)": bool
  }

  rule_files: "RuleFiles Partition" {
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    shape: queue
    
    label: |md
      **Rule Files Partition**
      ---
      - rules_au_2023.yaml [SHA256: 0xAF...]
      - rules_au_2024.yaml [SHA256: 0xBC...]
      - rules_au_2025.yaml [SHA256: 0xDE...]
    |
  }

  yaml_loader -> rule_files: "read_io" {
    style.stroke-dash: 3
  }
}

# Cross-Group Inheritance Connections
core_group.rule_base <- rules_group.wfh_rule: "implements" {
  style.stroke: "#C2185B"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
core_group.rule_base <- rules_group.threshold_rule: "implements" {
  style.stroke: "#7B1FA2"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
core_group.rule_base <- rules_group.depreciation_rule: "implements" {
  style.stroke: "#00838F"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
core_group.rule_base <- rules_group.repairs_rule: "implements" {
  style.stroke: "#FFA000"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}

loader_group.yaml_loader -> core_group.rule_registry: "registers rules" {
  style.stroke: "#455A64"
  style.animated: true
}

# Version Control & Persistence
version_group: "Version & Audit Integrity (Source of Truth)" {
  style: {
    stroke: "#3F51B5"
    fill: "#F1F2F9"
    stroke-width: 3
  }

  version_resolver: VersionResolver {
    shape: class
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    
    "+ resolve(cat: string, fy: int)": int
    "+ active_for(fy: int)": "List[Rule]"
  }

  version_history: RuleVersion_Store {
    shape: sql_table
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    
    # Typed fields for SQL specification
    "id": "uuid [PK]" {constraint: primary_key}
    "category": "varchar(50)"
    "fy_start": "int32"
    "fy_end": "int32"
    "version": "varchar(10)"
    "checksum": "char(64)"
  }

  version_resolver -> version_history: "SELECT version FROM storage" {
    style.stroke: "#3F51B5"
  }
}

core_group.rule_registry -> version_group.version_resolver: "delegates resolution"

# Quality Assurance Suite
test_group: "Quality Assurance (TDD Module M2)" {
  test_1: "Garbage Input Safety" {
    shape: hexagon
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
    }
  }
  test_2: "Mathematical Correctness" {
    shape: hexagon
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
    }
  }
  test_3: "Version Change Detection" {
    shape: hexagon
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
    }
  }
}

rules_group -> test_group.test_1: "validated by" { style.stroke-dash: 5 }
rules_group -> test_group.test_2: "validated by" { style.stroke-dash: 5 }
version_group -> test_group.test_3: "validated by" { style.stroke-dash: 5 }

# Output Results Handling
output_group: "Observation & Results" {
  rule_result: RuleResult {
    shape: class
    style.fill: "#F1F8E9"
    style.stroke: "#689F38"
    
    # Payload details
    "- deduction_cents": int64
    "- method_used": string
    "- rule_id": string
    "- metadata": RuleMetadata
  }

  audit_log: AuditLog {
    shape: class
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"
    
    "- timestamp": datetime
    "- rule_applied": string
    "- input_hash": string
    "- result": RuleResult
  }

  rule_result -> audit_log: "serialized to"
}

core_group.rule_engine -> output_group.rule_result: "produces_final_state" {
  style.stroke-width: 3
  style.stroke: "#689F38"
}