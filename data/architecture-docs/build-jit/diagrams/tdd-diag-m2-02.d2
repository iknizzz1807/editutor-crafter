direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# ---------------------------------------------------------------------------------------
# 1. MEMORY LAYOUT: JIT INSTRUCTION BUFFER (X86-64)
# ---------------------------------------------------------------------------------------
JIT_Buffer: {
  label: "JIT Execution Buffer (0x7f800000)"
  style: {
    stroke: "#333333"
    stroke-width: 6
    fill: "#f8f9fa"
    double-border: true
    border-radius: 4
  }

  MemoryMap: "64-Byte Cache Line Snapshot (Offsets 0x00-0x0F)" {
    grid-columns: 17
    grid-gap: 2
    style.stroke-dash: 5

    # Header Row (Offsets)
    H_OFF: "OFF" { style.bold: true; style.fill: "#dddddd" }
    H0: "0" { style.bold: true; style.fill: "#dddddd" }
    H1: "1" { style.bold: true; style.fill: "#dddddd" }
    H2: "2" { style.bold: true; style.fill: "#dddddd" }
    H3: "3" { style.bold: true; style.fill: "#dddddd" }
    H4: "4" { style.bold: true; style.fill: "#dddddd" }
    H5: "5" { style.bold: true; style.fill: "#dddddd" }
    H6: "6" { style.bold: true; style.fill: "#dddddd" }
    H7: "7" { style.bold: true; style.fill: "#dddddd" }
    H8: "8" { style.bold: true; style.fill: "#dddddd" }
    H9: "9" { style.bold: true; style.fill: "#dddddd" }
    HA: "A" { style.bold: true; style.fill: "#dddddd" }
    HB: "B" { style.bold: true; style.fill: "#dddddd" }
    HC: "C" { style.bold: true; style.fill: "#dddddd" }
    HD: "D" { style.bold: true; style.fill: "#dddddd" }
    HE: "E" { style.bold: true; style.fill: "#dddddd" }
    HF: "F" { style.bold: true; style.fill: "#dddddd" }

    # Row at 0x00
    R1: "0x00" { style.bold: true }
    
    # Instruction 1: MOV RAX, [RIP+disp32]
    m00: "48" { label: "REX.W"; style.fill: "#E1BEE7"; tooltip: "64-bit operand" }
    m01: "8B" { label: "MOV"; style.fill: "#BBDEFB" }
    m02: "05" { label: "ModRM"; style.fill: "#C8E6C9"; tooltip: "RIP-relative" }
    m03: "D0" { label: "Disp0"; style.fill: "#FFF9C4" }
    m04: "FF" { label: "Disp1"; style.fill: "#FFF9C4" }
    m05: "FF" { label: "Disp2"; style.fill: "#FFF9C4" }
    m06: "FF" { label: "Disp3"; style.fill: "#FFF9C4" }
    
    # Instruction 2: ADD RCX, R8
    m07: "4C" { label: "REX.R"; style.fill: "#E1BEE7"; tooltip: "Extends Reg field" }
    m08: "01" { label: "ADD"; style.fill: "#BBDEFB" }
    m09: "C1" { label: "ModRM"; style.fill: "#C8E6C9"; tooltip: "RCX to R8" }
    
    # NOP Alignment Padding
    m0A: "90" { label: "NOP"; style.fill: "#EEEEEE" }
    m0B: "90" { label: "NOP"; style.fill: "#EEEEEE" }
    m0C: "90" { label: "NOP"; style.fill: "#EEEEEE" }
    m0D: "90" { label: "NOP"; style.fill: "#EEEEEE" }
    m0E: "90" { label: "NOP"; style.fill: "#EEEEEE" }
    m0F: "90" { label: "NOP"; style.fill: "#EEEEEE" }
  }
}

# Fixed: near keys can only be set on root level shapes
Legend: "Instruction Encoding Legend" {
  near: top-left
  grid-columns: 2
  # Fixed: shape 'box' is for arrowheads, use 'rectangle' for shapes
  H: "Legacy/REX Prefix" { style.fill: "#E1BEE7"; shape: rectangle }
  O: "Opcode (1-3B)" { style.fill: "#BBDEFB"; shape: rectangle }
  M: "ModR/M + SIB" { style.fill: "#C8E6C9"; shape: rectangle }
  D: "Displacement" { style.fill: "#FFF9C4"; shape: rectangle }
  I: "Immediate" { style.fill: "#FFE0B2"; shape: rectangle }
  P: "Alignment Padding" { style.fill: "#EEEEEE"; shape: rectangle }
}

# Fixed: near keys can only be set on root level shapes
Metadata: |'md
  ### Buffer Architecture Specs
  - **Base Address:** `0x7f800000`
  - **Total Page Size:** 4096B (Bold Boundary)
  - **Instruction Alignment:** 16B (AVX Prefetch)
  - **Protection Flags:** `PROT_READ | PROT_WRITE | PROT_EXEC`
  - **Growth:** Linear forward allocation
'| {
  near: bottom-center
}

# ---------------------------------------------------------------------------------------
# 2. ARCHITECTURE: TRANSLATION PIPELINE
# ---------------------------------------------------------------------------------------
Pipeline: "Translation Engine Components" {
  Frontend: {
    BytecodeDecoder: {
      shape: class
      + Decode(raw_ptr: uint8_t*): Instruction
      + ValidateSignatures(ins: Instruction): bool
      - pc_offset: uint64_t
      - current_op: Opcode
    }
  }

  MiddleEnd: {
    Optimizer: {
      shape: class
      + BuildSSA(cfg: CFG): SSA_Form
      + ConstantFold(cfg: CFG): void
      + DeadCodeElimination(cfg: CFG): void
      - virtual_reg_map: Map<u32, VReg>
    }
  }

  Backend: {
    X64Emitter: {
      shape: class
      + EmitREX(w: bool, r: uint8, x: uint8, b: uint8): void
      + EmitModRM(mod: uint8, reg: uint8, rm: uint8): void
      + WriteImmediate(val: int64): void
      - buffer_head: uint8_t*
      - sizeof_cache: size_t = 64
    }
  }

  Frontend.BytecodeDecoder -> MiddleEnd.Optimizer: "SSA IR Stream" {
    style.stroke: orange
    style.stroke-width: 2
  }
  MiddleEnd.Optimizer -> Backend.X64Emitter: "Optimized LIR" {
    style.stroke: orange
    style.stroke-width: 2
  }
}

# ---------------------------------------------------------------------------------------
# 3. DATA FLOW: TRANSFORMATION STAGES
# ---------------------------------------------------------------------------------------
DataFlow: "Instruction Translation Flow" {
  Input: "Virtual Bytecode\n[PUSH EAX]" {
    shape: rectangle
    style.fill: "#E3F2FD"
  }

  Step1: "IR Generation\n(Stack -> Acc)" {
    shape: parallelogram
    style.fill: "#FFF3E0"
  }

  Step2: "RegAlloc\n(Bind to RAX)" {
    shape: parallelogram
    style.fill: "#FFF3E0"
  }

  Step3: "Native Emitter\n(x64 Machine Code)" {
    shape: parallelogram
    style.fill: "#FFF3E0"
  }

  Output: "Native x86-64\n[0x50]" {
    shape: rectangle
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    style.fill: "#E8F5E9"
  }

  Input -> Step1: "Parser"
  Step1 -> Step2: "Renamer"
  Step2 -> Step3: "Selection"
  Step3 -> Output: "JIT Commit"
}

# ---------------------------------------------------------------------------------------
# 4. ALGORITHM STATE: REGISTER ALLOCATION
# ---------------------------------------------------------------------------------------
Renaming: "Register Allocation Algorithm State" {
  Before: "T=0: Virtual State" {
    VReg0: "V_R0 (Unbound)" { style.stroke: red; style.bold: true; style.stroke-width: 4 }
    VReg1: "V_R1 (Unbound)"
    PhysicalPool: "Free: [RAX, RBX, RCX]" {
      shape: cylinder
    }
  }

  After: "T=1: Mapped State" {
    VReg0: "V_R0 -> RAX" { style.stroke: "#2E7D32"; style.bold: true; style.stroke-width: 4 }
    VReg1: "V_R1 -> RBX"
    PhysicalPool: "Free: [RCX]" {
      shape: cylinder
    }
  }

  Before -> After: "Greedy Allocator" {
    style.stroke: orange
    style.animated: true
  }
}

# ---------------------------------------------------------------------------------------
# 5. SEQUENCE: JIT LIFECYCLE
# ---------------------------------------------------------------------------------------
JIT_Sequence: "JIT Compilation Lifecycle" {
  shape: sequence_diagram
  Interpreter: "Interpreter Loop"
  Profiler: "Profiler"
  Compiler: "JIT Compiler"
  Runtime: "Native Exec"

  Interpreter -> Profiler: "call(f_idx)"
  Profiler -> Interpreter: "Threshold Exceeded (1000)"
  
  Interpreter -> Compiler: "JIT_COMPILE(bytecode)" {
    style.stroke: "#D32F2F"
    style.bold: true
  }
  
  Compiler -> Compiler: "Lock Acquire ▼" {
    style.stroke: red
  }
  
  Compiler -> Compiler: "SSA + DCE Optimization"
  Compiler -> Compiler: "Emit Machine Code"
  
  Compiler -> Runtime: "Patch Entry Point" {
    style.stroke: blue
    style.stroke-dash: 2
  }
  
  Compiler -> Compiler: "Lock Release ▲" {
    style.stroke: red
  }
  
  Compiler -> Interpreter: "return native_ptr"
  Interpreter -> Runtime: "CALL [native_ptr]" {
    style.animated: true
    style.stroke: "#2E7D32"
  }
}

# ---------------------------------------------------------------------------------------
# GLOBAL STYLING
# ---------------------------------------------------------------------------------------
classes: {
  implementation: {
    style: {
      fill: "#f1f8e9"
      stroke: "#33691e"
      font-size: 14
      font: mono
    }
  }
}

***.style.font: mono
***.style.font-size: 13

Pipeline.Frontend.BytecodeDecoder.class: implementation
Pipeline.MiddleEnd.Optimizer.class: implementation
Pipeline.Backend.X64Emitter.class: implementation

(DataFlow.Step3 -> DataFlow.Output)[0]: { style.stroke-width: 4; style.stroke: "#2E7D32" }