direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# AGENT: TECHNICAL DESIGN ARTIST
# TYPE: MEMORY_LAYOUT + ALGORITHM STATE
# REF: diag-vstack-state-tracking-v4

classes: {
  header: {
    style: {
      fill: "#673AB7"
      font-color: white
      bold: true
      font-size: 18
    }
  }
  entry_box: {
    style: {
      stroke-width: 1
      border-radius: 2
    }
  }
  type_slot: {
    style: { fill: "#E1F5FE"; stroke: "#0288D1" }
  }
  data_slot: {
    style: { fill: "#BBDEFB"; stroke: "#1976D2" }
  }
  reg_slot: {
    style: { fill: "#FFF9C4"; stroke: "#FBC02D" }
  }
  spill_slot: {
    style: { fill: "#F5F5F5"; stroke: "#9E9E9E" }
  }
  meta_slot: {
    style: { fill: "#FFCC80"; stroke: "#F57C00" }
  }
  changed: {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      font-color: "#D32F2F"
      bold: true
    }
  }
}

VirtualStack_Memory_Layout: {
  label: "struct VirtualStack (sizeof = 5128 bytes)"
  style: {
    stroke-width: 2
    fill: "#F3E5F5"
    font-color: "#4A148C"
    bold: true
  }

  header.class: header
  header: "Memory Layout: VirtualStackEntry Array [256]"

  # --- ENTRY 0 ---
  entry_0: "0x0000 | VirtualStackEntry[0]" {
    grid-columns: 5
    grid-gap: 0
    
    t0: "type" { class: [entry_box; type_slot]; tooltip: "4B: SlotType Enum" }
    c0: "const" { class: [entry_box; data_slot]; tooltip: "4B: Literal Value" }
    v0: "vreg" { class: [entry_box; reg_slot]; tooltip: "4B: Virtual Register Index" }
    s0: "spill" { class: [entry_box; spill_slot]; tooltip: "4B: Stack Offset" }
    p0: "pc" { class: [entry_box; data_slot]; tooltip: "4B: Bytecode Offset" }
  }

  # --- ENTRY 1 ---
  entry_1: "0x0014 | VirtualStackEntry[1]" {
    grid-columns: 5
    grid-gap: 0
    
    t1: "type" { class: [entry_box; type_slot] }
    c1: "const" { class: [entry_box; data_slot] }
    v1: "vreg" { class: [entry_box; reg_slot] }
    s1: "spill" { class: [entry_box; spill_slot] }
    p1: "pc" { class: [entry_box; data_slot] }
  }

  # --- ENTRY 2 ---
  entry_2: "0x0028 | VirtualStackEntry[2]" {
    grid-columns: 5
    grid-gap: 0
    
    t2: "type" { class: [entry_box; type_slot] }
    c2: "const" { class: [entry_box; data_slot] }
    v2: "vreg" { class: [entry_box; reg_slot] }
    s2: "spill" { class: [entry_box; spill_slot] }
    p2: "pc" { class: [entry_box; data_slot] }
  }

  # --- CACHE LINE STRADDLE VISUAL (64B / 0x40) ---
  # Moved outside of any grid context to prevent "near" errors in layout
  cache_line_boundary: "------------------ 64B CACHE LINE BOUNDARY (0x40) ------------------" {
    shape: text
    style: {
      font-size: 11
      font-color: "#D32F2F"
      bold: true
      stroke-dash: 3
    }
  }

  entry_3_split: {
    # Using grid-columns on sub-containers is fine, provided no 'near' keys 
    # point to the children (part_a/part_b) or use them as label anchors.
    grid-columns: 1
    grid-gap: 2
    
    part_a: "0x003C | VirtualStackEntry[3].type" { 
      class: [entry_box; type_slot]
      tooltip: "Final 4 bytes of first cache line"
    }
    
    part_b: "0x0040 | VirtualStackEntry[3].data_fields[1..4]" {
      class: [entry_box; data_slot]
      tooltip: "Start of second cache line (16 bytes remaining)"
    }
  }

  gap: "..." {
    shape: text
    style: { font-size: 32; font-color: "#7B1FA2" }
  }

  # --- FINAL ENTRY ---
  entry_255: "0x13EC | VirtualStackEntry[255]" {
    style: { fill: "#F3E5F5"; stroke: "#7B1FA2"; stroke-dash: 2 }
  }

  # --- METADATA ---
  metadata: {
    label: "Struct Metadata (Offset 0x1400)"
    style.fill: "#FFF3E0"
    
    # These are descendants of 'metadata'. If 'VirtualStack_Memory_Layout' 
    # were a grid, this would fail. It is not, so this is safe.
    depth: "0x1400 | depth (int32_t)" { class: [entry_box; meta_slot]; style.bold: true }
    max_depth: "0x1404 | max_depth (int32_t)" { class: [entry_box; meta_slot] }
  }
}

Runtime_Visual: {
  near: VirtualStack_Memory_Layout
  shape: package
  label: "Algorithm State Machine"
  style.fill: "#FAFAFA"

  state_n: {
    label: "State N: Empty Stack"
    depth_val: "depth = 0"
    slot_0: "entries[0] = { EMPTY, 0, -1, -1, 0 }"
    
    style.stroke: "#9E9E9E"
  }

  transition: "PUSH_CONST(42)" {
    style: { stroke-width: 2; animated: true }
  }

  state_n_plus_1: {
    label: "State N+1: After PUSH"
    depth_val: "depth = 1" { class: changed }
    slot_0: "entries[0] = { CONST, 42, -1, -1, 104 }" { class: changed }
    
    style.stroke: "#D32F2F"
    style.stroke-width: 2
  }
  
  state_n -> transition -> state_n_plus_1
}

Legend: {
  near: Runtime_Visual
  shape: package
  label: "Memory Map Color Key"
  
  grid-columns: 1
  grid-gap: 5
  
  l1: "Type Discriminant (SlotType)" { class: type_slot }
  l2: "Constants / Data Values" { class: data_slot }
  l3: "Register Allocation Indices" { class: reg_slot }
  l4: "Structural Metadata" { class: meta_slot }
  l5: "Empty / Padding Space" { class: spill_slot }
}

# --- CORRECTED CONNECTIONS ---
# Fix: Ensure source/target-arrowhead are outside style.
# Fix: Reference the container 'entry_1' instead of a cell if the label placement fails.
(VirtualStack_Memory_Layout.metadata.depth -> VirtualStack_Memory_Layout.entry_1)[0]: {
  label: "Points to next available entry"
  source-arrowhead: circle
  target-arrowhead: triangle
  style: {
    stroke: "#FF9800"
    stroke-width: 3
    animated: true
  }
}

# Documentation block
implementation_notes: |md
  ### Implementation Specification
  - **Memory Alignment**: Struct is 4-byte packed. No internal padding between array elements.
  - **Cache Performance**: `VirtualStackEntry[3]` spans a cache line boundary at byte 64. Accesses to `entries[3]` may incur two cache line fetches.
  - **State Guard**: `depth` increment must happen *after* slot write to ensure signal safety.
  - **Size**: 256 entries * 20 bytes + 8 bytes metadata = 5128 bytes total.
| {
  near: Legend
  style.font-size: 14
}

# Structural Offset Connector
(VirtualStack_Memory_Layout.entry_0 -> VirtualStack_Memory_Layout.entry_1)[0]: {
  label: "Offset 0x14 (20B)"
  style: {
    stroke: "#7B1FA2"
    opacity: 0.5
  }
}