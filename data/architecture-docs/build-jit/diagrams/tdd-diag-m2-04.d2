direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

# Metadata Header
Title: "Register Allocator State Machine (x86-64 JIT)" {
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# State Definitions
States: {
  INIT: "" {
    shape: circle
    style: {
      fill: black
    }
  }

  FREE: "FREE" {
    tooltip: "Register is available in the allocator's free_regs stack."
    |md
      ### Invariants
      - `reg ∈ free_regs`
      - `reg != rax` (unless div finished)
      - `reg != rdx` (unless div finished)
    |
    style: {
      fill: "#e1f5fe"
      stroke: "#01579b"
      stroke-width: 2
    }
  }

  ALLOCATED: "ALLOCATED (vreg=N)" {
    tooltip: "Register is actively mapped to a virtual register."
    |md
      ### Invariants
      - `vregs[N].state == VREG_IN_REG`
      - `vregs[N].phys_reg == current_reg`
      - `reg ∉ free_regs`
    |
    style: {
      fill: "#fff9c4"
      stroke: "#fbc02d"
      stroke-width: 2
    }
  }

  SPILLED: "SPILLED (slot=M)" {
    tooltip: "Value is evicted to the stack frame to free the physical register."
    |md
      ### Invariants
      - `vregs[N].state == VREG_SPILLED`
      - `vregs[N].spill_slot == M`
      - `offset = -(M+1)*8`
    |
    style: {
      fill: "#f8bbd0"
      stroke: "#c2185b"
      stroke-width: 2
    }
  }

  ERROR: "PANIC: REG EXHAUSTION" {
    style: {
      fill: "#ffcdd2"
      stroke: "#b71c1c"
      stroke-width: 4
      font-color: "#b71c1c"
      bold: true
    }
  }
}

# Transitions
States.INIT -> States.FREE: "ra_init()" {
  style: {
    stroke-width: 2
  }
}

States.FREE -> States.ALLOCATED: "ra_alloc()" {
  label: "ra_alloc()\n[guard: free_count > 0]"
  style: {
    font-color: "#2e7d32"
    stroke: "#2e7d32"
  }
}

States.ALLOCATED -> States.FREE: "ra_free()" {
  label: "ra_free()\n[action: push to free_regs]"
  style: {
    stroke-dash: 0
  }
}

States.ALLOCATED -> States.SPILLED: "ra_spill()" {
  label: "ra_spill()\n[action: emit mov [rbp-off], reg]"
  style: {
    font-color: "#c62828"
    stroke: "#c62828"
    bold: true
  }
}

States.SPILLED -> States.ALLOCATED: "ra_reload()" {
  label: "ra_reload()\n[action: emit mov reg, [rbp-off]]"
  style: {
    stroke: "#1565c0"
    animated: true
  }
}

States.SPILLED -> States.FREE: "ra_kill()" {
  label: "ra_kill()\n[vreg no longer live]"
}

States.FREE -> States.ERROR: "ra_alloc() Fails" {
  label: "ra_alloc()\n[guard: free_count == 0 && no spillable]"
  style: {
    stroke: "#b71c1c"
    stroke-width: 2
  }
}

# Illegal Transitions
States.FREE -> States.SPILLED: "ILLEGAL" {
  style: {
    stroke: red
    stroke-dash: 5
    opacity: 0.5
  }
}

# Implementation Details Component
Implementation: {
  near: bottom-right
  |md
    ### Register Allocator Details
    - **Total VRegs:** 1024 (MAX_VREGS)
    - **Physical Pool:** 9 Registers (Caller-saved)
    - **Spill Algorithm:** Linear Scan (LRU-based)
    - **Reserved:** `rax`, `rdx` (high-priority for division)
    - **Stack Growth:** `-(spill_slot + 1) * 8` from `rbp`
  |
  style: {
    fill: "#f5f5f5"
    stroke: "#9e9e9e"
    stroke-dash: 3
  }
}

# Footer Note
Note: "sizeof(RegAllocator) = 32,840 bytes" {
  shape: text
  near: bottom-center
  style: {
    italic: true
    font-size: 12
  }
}