direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STACK FRAME MEMORY LAYOUT ---
# Intel Manual Style: Growth from High Address (Top) to Low Address (Bottom)
stack_frame: {
  label: "Stack Frame Layout: Register Spilling\n(Growth: High to Low Address)"
  
  # Offsets and Memory are grouped to maintain alignment
  grid-columns: 3
  grid-gap: 20
  vertical-gap: 0

  # Column 1: Address Offsets
  o1: "rbp + 16" { style.font: mono; style.font-size: 14 }
  o2: "rbp + 8"  { style.font: mono; style.font-size: 14 }
  o3: "rbp + 0"  { style.font: mono; style.font-size: 14 }
  o4: "rbp - 8"  { style.font: mono; style.font-size: 14 }
  o5: "rbp - 16" { style.font: mono; style.font-size: 14 }
  o6: "rbp - 24" { style.font: mono; style.font-size: 14 }
  o7: "rbp - 32" { style.font: mono; style.font-size: 14 }

  # Column 2: Memory Cells (Fixed Width for Technical Specification)
  prev_frame: "Previous Frame / Caller Data" {
    width: 350; height: 50
    style: { fill: "#E1F5FE"; stroke-dash: 3 }
  }
  ret_addr: "Return Address (rip)" {
    width: 350; height: 50
    label.near: top-center
    style: { fill: "#D1C4E9"; bold: true; stroke-width: 2 }
  }
  saved_rbp: "Saved RBP (frame pointer)" {
    width: 350; height: 50
    style.fill: "#D1C4E9"
  }
  spill_0: "Spill Slot 0 (vreg 3)" {
    width: 350; height: 50
    style: { fill: "#BBDEFB"; stroke: "#1976D2"; stroke-width: 3 }
  }
  spill_1: "Spill Slot 1 (vreg 7)" {
    width: 350; height: 50
    style.fill: "#BBDEFB"
  }
  local_0: "Local Variable 0" {
    width: 350; height: 50
    style.fill: "#C8E6C9"
  }
  padding: "Padding (16B Alignment)" {
    width: 350; height: 50
    style: { fill: "#F5F5F5"; font-color: "#757575" }
  }

  # Column 3: Field Sizes
  s1: "8 Bytes" { style.font: mono }
  s2: "8 Bytes" { style.font: mono }
  s3: "8 Bytes" { style.font: mono }
  s4: "8 Bytes" { style.font: mono }
  s5: "8 Bytes" { style.font: mono }
  s6: "8 Bytes" { style.font: mono }
  s7: "8 Bytes" { style.font: mono }
}

# --- POINTER ANNOTATIONS ---
rbp_ptr: "RBP (Frame Pointer)" {
  shape: person
  style.fill: "#FFB74D" 
}
rsp_ptr: "RSP (Stack Pointer)" {
  shape: person
  style.fill: "#FFB74D"
}

# Explicit pointer-to-cell relationships
rbp_ptr -> stack_frame.saved_rbp: "points to [rbp+0]" {
  style: { stroke: "#F57C00"; font-color: "#F57C00"; bold: true }
}
rsp_ptr -> stack_frame.padding: "aligned top [rsp]" {
  style: { stroke: "#F57C00"; font-color: "#F57C00"; bold: true }
}

# --- EMISSION LOGIC BOX ---
instruction_logic: |md
  ### Register Spill Emission (TDD Stage 2)
  **Operation:** `regalloc_materialize()` spills vreg to stack.
  **Target:** `Spill Slot 0` (vreg 3)
  **Address Calculation:** 
  - `offset = -(slot_index + 1) * 8`
  - `slot 0 -> offset = -8`
  
  **Assembly:** `mov [rbp - 8], r8`
  **Encoding (x86-64):** `4C 89 45 F8`
  - `4C`: REX.WR (64-bit operand + R8 extension)
  - `89`: MOV r/m64, r64
  - `45`: ModR/M (mod=01, reg=r8, r/m=rbp)
  - `F8`: Disp8 (-8)
| {
  near: bottom-center
  style: { stroke: "#1976D2"; stroke-width: 3; fill: "#FAFAFA"; shadow: true }
}

# --- CACHE LINE BOUNDARIES (64B) ---
# Visualizing cache line crossing for alignment performance
cache_line_marker: "64B CACHE LINE BOUNDARY" {
  shape: text
  style: { font-color: "#D32F2F"; bold: true }
}

cache_line_bound: {
  width: 600
  style: { stroke-dash: 5; stroke: "#D32F2F" }
}

# Physical alignment indicators
stack_frame.spill_1 -- cache_line_bound: "Boundary" {
  style: { stroke-dash: 5; stroke: "#D32F2F" }
}

# --- PAGE BOUNDARY (4096B) ---
# Page boundary marker for MMU/TLB engineering
page_bound_marker: "PAGE BOUNDARY (0x1000 ALIGNED)" {
  shape: text
  style: { font-color: "#000000"; bold: true }
}

page_boundary_line: {
  height: 4; width: 600
  style: { stroke-width: 4; stroke: "#000000"; fill: "#000000" }
}

stack_frame.padding -- page_boundary_line: "End of Page" {
  style: { stroke-width: 4; stroke: "#000000" }
}

# --- LEGEND ---
legend: {
  near: top-right
  header: "Header/Control" { style.fill: "#D1C4E9" }
  data: "Spill Data" { style.fill: "#BBDEFB" }
  user: "Local Var" { style.fill: "#C8E6C9" }
  pad: "Alignment Pad" { style.fill: "#F5F5F5" }
}

# Global Styling overrides for Intel manual look
***.style.font: mono
(*** -> ***)[*].style.animated: true