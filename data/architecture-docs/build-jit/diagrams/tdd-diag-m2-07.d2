direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# SATELLITE MAP REFERENCE: ID=jit_backend.translation.division
# TASK: Signed Division (idiv) Algorithm State Transition

"Step 1: Load Accumulator" {
  explanation: |md
    ### Setup Phase
    Move the dividend into the **hardwired** `rax` register.
    The divisor is stored in any available general purpose register (e.g., `r8`).
  |
  registers: {
    rax: "**[Dividend: 100]**" {style.stroke: red; style.font-color: red}
    rdx: "[Stale Value]"
    r8: "[Divisor: 7]"
  }
  emission: {
    bytes: "48 B8 64 00 00 00 00 00 00 00"
    asm: "mov rax, 100"
  }
}

"Step 2: Sign Extension (cqo)" {
  explanation: |md
    ### Preparation Phase
    The `idiv` instruction expects a 128-bit dividend in `rdx:rax`.
    `cqo` sign-extends `rax` into `rdx`.
  |
  registers: {
    rax: "[Dividend: 100]"
    rdx: "**[Sign Bit: 0x0]**" {style.stroke: red; style.font-color: red}
    r8: "[Divisor: 7]"
  }
  emission: {
    bytes: "**48 99**" {style.stroke: red; style.font-color: red}
    asm: "**cqo**" {style.stroke: red; style.font-color: red}
  }
}

"Step 3: Hardware Division" {
  explanation: |md
    ### Execution Phase
    Execute `idiv`. Hardware divides `rdx:rax` by the operand.
    Quotient is forced into `rax`, remainder into `rdx`.
  |
  registers: {
    rax: "**[Quotient: 14]**" {style.stroke: red; style.font-color: red}
    rdx: "**[Remainder: 2]**" {style.stroke: red; style.font-color: red}
    r8: "[Divisor: 7]"
  }
  emission: {
    bytes: "**49 F7 F8**" {style.stroke: red; style.font-color: red}
    asm: "**idiv r8**" {style.stroke: red; style.font-color: red}
  }
}

"Step 1: Load Accumulator" -> "Step 2: Sign Extension (cqo)"
"Step 2: Sign Extension (cqo)" -> "Step 3: Hardware Division"

# Styling
"Step 1: Load Accumulator".style.fill: "#f0f0f0"
"Step 2: Sign Extension (cqo)".style.fill: "#f0f0f0"
"Step 3: Hardware Division".style.fill: "#f0f0f0"

"Step 1: Load Accumulator".registers.rax.style.bold: true
"Step 2: Sign Extension (cqo)".registers.rdx.style.bold: true
"Step 3: Hardware Division".registers.rax.style.bold: true
"Step 3: Hardware Division".registers.rdx.style.bold: true

"Step 1: Load Accumulator".registers.style.stroke: "#3f87a6"
"Step 2: Sign Extension (cqo)".registers.style.stroke: "#3f87a6"
"Step 3: Hardware Division".registers.style.stroke: "#3f87a6"

"Step 1: Load Accumulator".emission.style.stroke: "#7a4faf"
"Step 2: Sign Extension (cqo)".emission.style.stroke: "#7a4faf"
"Step 3: Hardware Division".emission.style.stroke: "#7a4faf"