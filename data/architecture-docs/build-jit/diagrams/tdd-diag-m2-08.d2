direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # ALGORITHM: Comparison to Boolean Sequence
  **Translating Stack-Based Comparison to x86-64 Register Logic**
| {near: top-center}

# --- Condition Code Mapping Table ---
cc_table: {
  shape: sql_table
  style.stroke: "#333"
  label: "Condition Code (CC) Mapping"
  
  header: "Logic" {constraint: "Opcode (setCC)"}
  eq: "Equal (==)" {constraint: "0F 94 (sete)"}
  ne: "Not Equal (!=)" {constraint: "0F 95 (setne)"}
  lt: "Less Than (<)" {constraint: "0F 9C (setl)"}
  le: "Less or Equal (<=)" {constraint: "0F 9E (setle)"}
  gt: "Greater Than (>)" {constraint: "0F 9F (setg)"}
  ge: "Greater or Equal (>=)" {constraint: "0F 9D (setge)"}
}

# --- Step 1 ---
step1: "Step 1: Materialize Operands" {
  state: {
    registers: {
      rax: "0x0000...000A (10)"
      rcx: "0x0000...000A (10)"
      rflags: "ZF=0, SF=0, OF=0"
    }
    buffer: {
      label: "Code Buffer"
      hex: "--- empty ---"
    }
  }
}

# --- Step 2 ---
step2: "Step 2: Emit CMP Instruction" {
  state: {
    registers: {
      rax: "0x0000...000A (10)"
      rcx: "0x0000...000A (10)"
      rflags: "**ZF=1**, SF=0, OF=0" {style.font-color: red; style.bold: true}
    }
    buffer: {
      label: "Code Buffer"
      hex: "**48 39 C8**" {style.font-color: red; style.bold: true}
      asm: "cmp rax, rcx"
    }
  }
}

# --- Step 3 ---
step3: "Step 3: Emit setCC Instruction" {
  state: {
    registers: {
      rax: "0x0000...00**01**" {style.font-color: red; style.bold: true}
      rcx: "0x0000...000A"
      rflags: "ZF=1, SF=0, OF=0"
    }
    buffer: {
      label: "Code Buffer"
      hex: "48 39 C8 **0F 94 C0**" {style.font-color: red; style.bold: true}
      asm: "sete al"
    }
  }
}

# --- Step 4 ---
step4: "Step 4: Emit MOVZX (Normalization)" {
  state: {
    registers: {
      rax: "**0x0000000000000001**" {style.font-color: red; style.bold: true}
      rcx: "0x0000...000A"
      rflags: "ZF=1, SF=0, OF=0"
    }
    buffer: {
      label: "Code Buffer"
      hex: "... 0F 94 C0 **0F B6 C0**" {style.font-color: red; style.bold: true}
      asm: "movzx eax, al"
    }
  }
}

# --- Execution Flow ---
step1 -> step2: "Subtract rcx from rax\nSet CPU Flags"
step2 -> step3: "sete (CC=0x4)\nWrites to RAX[7:0]"
step3 -> step4: "Clear upper 56 bits\nEnsure result is 0 or 1"

# --- Annotation ---
note: |md
  ### Sequence Logic
  1. **CMP**: Performs `rax - rcx` and updates `RFLAGS`.
  2. **SETCC**: If condition (e.g., EQ) is met, sets destination byte to `1`, else `0`.
  3. **MOVZX**: Critically important to zero-extend the byte. Without this, the upper bits of `rax` would remain stale, causing incorrect logic in subsequent 64-bit operations.
| {near: bottom-right}

# --- Styling ---
step*.state.registers.style.fill: "#e1f5fe"
step*.state.buffer.style.fill: "#fff9c4"
step*.state.style.stroke-width: 2
step*.state.registers.rax.style.font: mono
step*.state.registers.rcx.style.font: mono
step*.state.registers.rflags.style.font: mono
step*.state.buffer.hex.style.font: mono