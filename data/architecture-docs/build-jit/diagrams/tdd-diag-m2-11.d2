layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 40
  }
}

# JUMP OFFSET CALCULATION ALGORITHM
# Specification: offset = target_address - (instruction_start_address + instruction_length)

algorithm: {
  shape: package
  label: "Jump Offset Calculation Algorithm (TDD-M2-11)"

  # --- STEP 1: INPUT ACQUISITION ---
  step_1: {
    label: "1. Load Target and Base Addresses"
    
    input_params: {
      shape: sql_table
      target_addr: "uint64_t" {constraint: "0x1050"}
      jump_instr_start: "uint64_t" {constraint: "0x1000"}
    }
    
    memory_view: |md
      ### Code Buffer Layout
      | Offset | Address | Content | Size |
      | :--- | :--- | :--- | :--- |
      | 0x00 | **0x1000** | `JMP [??]` | 2/5B |
      | ... | ... | ... | ... |
      | 0x50 | **0x1050** | `TARGET_OP` | 1B |
    |
  }

  # --- STEP 2: HYPOTHETICAL CALCULATION ---
  step_2: {
    label: "2. Calculate rel8 Candidate"
    
    calc_block: |md
      ## Distance Formula
      $dist = Target - (JmpStart + Len_{rel8})$
      $dist = 0x1050 - (0x1000 + 2)$
      $dist = 0x4E \text{ (78 decimal)}$
    |
    
    note: "rel8 requires 2 bytes: [Opcode(1) | Imm8(1)]"
    style.stroke: "#FFA500"
    style.stroke-width: 4
  }

  # --- STEP 3: BOUNDS CHECKING ---
  step_3: {
    shape: diamond
    label: "Is dist in range?\n[-128, 127]"
    style.fill: "#FFF9C4"
  }

  # --- STEP 4A: REL8 ENCODING ---
  step_4a: {
    label: "4a. Emit rel8 Instruction"
    style.fill: "#E1F5FE"
    
    encoding: {
      shape: sql_table
      opcode: "0xEB (JMP rel8)" {style.fill: "#9575CD"}
      imm8: "0x4E" {style.fill: "#64B5F6"}
    }
    
    size_annotation: "sizeof = 2 bytes"
  }

  # --- STEP 4B: REL32 ENCODING ---
  step_4b: {
    label: "4b. Emit rel32 Instruction"
    style.fill: "#FFEBEE"
    
    recalc: |md
      ### Recalculate for rel32
      $dist = Target - (JmpStart + 5)$
      $dist = 0x1050 - 0x1005 = 0x4B$
    |
    
    encoding: {
      shape: sql_table
      opcode: "0xE9 (JMP rel32)" {style.fill: "#9575CD"}
      imm32: "0x4B 00 00 00" {style.fill: "#64B5F6"}
    }
    
    size_annotation: "sizeof = 5 bytes"
  }

  # --- STEP 5: FINAL PATCH ---
  step_5: {
    label: "5. Execution Verification"
    
    verification: |md
      ### RIP Resolution (rel8)
      $RIP_{base} = 0x1000$
      $RIP_{next} = RIP_{base} + Len_{instr}$
      $RIP_{next} = 0x1000 + 2 = 0x1002$
      $Target = RIP_{next} + Offset$
      $0x1002 + 0x4E = 0x1050$
      **Result: PASS**
    |
    
    style.stroke: "#4CAF50"
    style.stroke-width: 5
  }

  # Internal Logic Flow
  step_1 -> step_2: "Addresses valid"
  step_2 -> step_3: "Candidate: 0x4E"
  
  step_3 -> step_4a: "YES" {
    style: {
      stroke: green
      font-color: green
      stroke-width: 3
    }
  }
  
  step_3 -> step_4b: "NO" {
    style: {
      stroke: red
      font-color: red
      stroke-width: 2
      stroke-dash: 4
    }
  }
  
  step_4a -> step_5: "Short Branch"
  step_4b -> step_5: "Near Branch"
}

# Legend for Engineer reference
legend: {
  near: bottom-center
  
  title: "Encoding Color Key" {
    shape: text
    style.bold: true
  }
  
  c1: "Opcode / Control Byte" {
    style.fill: "#9575CD"
  }
  c2: "Relative Displacement" {
    style.fill: "#64B5F6"
  }
  c3: "Decision Node" {
    style.fill: "#FFF9C4"
  }
}

# Detailed Architectural Notes
info: |md
  ## Instruction Pointer (RIP) Behavior
  Engineers must account for the fact that the CPU increments the RIP to point 
  to the *following* instruction before adding the displacement.
  
  - **JMP rel8 (EB cb)**: Displacement is a signed 8-bit integer.
  - **JMP rel32 (E9 cd)**: Displacement is a signed 32-bit integer.
  - **Optimization**: The assembler/JIT must calculate the smallest possible 
    displacement to minimize instruction cache footprint.
|

info.near: legend

# Global Styling and Invariants
algorithm.** : {
  style.font: mono
}

# Visual Indicators for Logic
(algorithm.step_2 -> algorithm.step_3)[0].style.animated: true
(algorithm.step_3 -> algorithm.step_4a)[0].label: "Within [-128, 127]"
(algorithm.step_3 -> algorithm.step_4b)[0].label: "Out of Range"