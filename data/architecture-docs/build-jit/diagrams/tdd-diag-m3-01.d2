direction: right
layout-engine: elk
theme-id: 0

# FunctionCompiler Module Architecture
# Implementation Grade Specification - Intel Manual Quality

jit_module: {
  label: "FUNCTION COMPILER MODULE (Milestone 3)"
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
  }

  function_compiler: {
    shape: class
    label: "struct FunctionCompiler"
    style: {
      fill: "#e1d5e7" # Purple header
    }
    # Fields: name, type, size
    emitter: "CodeEmitter* (8B)"
    frame: "FrameLayout (128B)"
    args: "ArgumentState (284B)"
    locals: "LocalVarAllocator (2048B)"
    callee_saved_count: "int32_t (4B)"
    local_space: "int32_t (4B)"
    prologue_emitted: "bool (1B)"
    epilogue_emitted: "bool (1B)"
    has_error: "bool (1B)"
    error_msg: "char[256] (256B)"

    # Methods: full signature
    func_create(emitter: CodeEmitter*, args: int, locals: int): FunctionCompiler*
    func_emit_prologue(fc: FunctionCompiler*): void
    func_get_arg(fc: FunctionCompiler*, index: int): int
    func_alloc_local(fc: FunctionCompiler*): int32_t
    func_emit_call(fc: FunctionCompiler*, target: void*, args: int*, count: int): int
    func_emit_return(fc: FunctionCompiler*, ret_vreg: int): void
    func_finalize(fc: FunctionCompiler*): int64_t(*)()
    
    |'md
    ### Sizeof = ~2740 bytes
    Primary orchestrator for ABI-compliant function generation.
    '|
  }

  code_emitter: {
    shape: class
    label: "struct CodeEmitter (M1)"
    style: {
      fill: "#d5e8d4" # Green header
    }
    buffer: "uint8_t* (8B)"
    cursor: "uint8_t* (8B)"
    capacity: "size_t (8B)"
    used: "size_t (8B)"
    prot_state: "int (4B)"
    
    emit_prologue(e: CodeEmitter*, f: FrameLayout*): void
    emit_epilogue(e: CodeEmitter*, f: FrameLayout*): void
  }

  reg_allocator: {
    shape: class
    label: "struct RegAllocator (M2)"
    style: {
      fill: "#fff2cc" # Orange header
    }
    vregs: "VReg[1024] (32KB)"
    vreg_count: "int (4B)"
    free_regs: "Reg[16] (64B)"
    free_count: "int (4B)"
    next_spill_slot: "int (4B)"
  }

  frame_layout: {
    shape: class
    label: "struct FrameLayout"
    style: {
      fill: "#dae8fc" # Blue header
    }
    arg_count: "int32_t (4B)"
    local_count: "int32_t (4B)"
    spill_slot_count: "int32_t (4B)"
    total_frame_size: "int32_t (4B)"
    stack_args_offset: "int32_t (4B)"
    padding_bytes: "int32_t (4B)"
    callee_saved_regs: "Reg[5] (20B)"
    
    frame_init(f: FrameLayout*, args: int, locals: int, spills: int): void
  }

  argument_state: {
    shape: class
    label: "struct ArgumentState"
    total_args: "int32_t (4B)"
    reg_args: "int32_t (4B)"
    stack_args: "int32_t (4B)"
    args: "ArgState[16] (256B)"
    abi_regs_in_use: "bool[6] (6B)"
  }

  local_allocator: {
    shape: class
    label: "struct LocalVarAllocator"
    slot_count: "int32_t (4B)"
    slot_offsets: "int32_t[256] (1024B)"
    slot_sizes: "int32_t[256] (1024B)"
  }

  # Ownership Relationships (Solid Arrows)
  function_compiler -> code_emitter: "owns"
  function_compiler -> frame_layout: "owns"
  function_compiler -> argument_state: "owns"
  function_compiler -> local_allocator: "owns"
  function_compiler -> reg_allocator: "owns"

  # External Reference (Dashed)
  code_emitter -.-> native_mem: "PROT_EXEC region"
}

pipeline: {
  label: "COMPILATION PIPELINE"
  style.fill: "#dae8fc"
  
  step1: "1. Analyze Signature"
  step2: "2. frame_init()"
  step3: "3. emit_prologue()"
  step4: "4. args_get() / marshal"
  step5: "5. Compile Body (M2)"
  step6: "6. emit_epilogue()"
  step7: "7. mprotect RX"

  step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> step7
}

native_mem: {
  shape: cylinder
  label: "W^X Code Cache"
  style.fill: "#f5f5f5"
}

# Annotations
legend: {
  near: bottom-right
  note: |'md
  **Legend:**
  - Solid Arrow: Direct ownership (member struct or pointer)
  - Dashed Arrow: Reference or cross-module interaction
  - Purple Header: Milestone 3 logic
  - Green Header: Milestone 1 logic
  - Yellow Header: Milestone 2 logic
  '|
}