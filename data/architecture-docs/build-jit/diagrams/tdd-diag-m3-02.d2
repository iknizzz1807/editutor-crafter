direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 20
  }
}

classes: {
  header_field: {
    style: {
      fill: "#d1b3ff"
      bold: true
      font-size: 14
    }
  }
  frame_ctrl: {
    style: {
      fill: "#d1b3ff"
      stroke-width: 2
    }
  }
  data_field: {
    style: {
      fill: "#b3d1ff"
    }
  }
  pointer_reg: {
    style: {
      fill: "#ffd1b3"
      bold: true
      stroke-width: 3
    }
  }
  padding_field: {
    style: {
      fill: "#e0e0e0"
      stroke-dash: 3
    }
  }
  free_space: {
    style: {
      fill: "#ccffcc"
    }
  }
}

# Wrapper to avoid 'near' constraints on grid objects
System_V_ABI_Stack: {
  
  stack_visual: {
    label: "Memory Layout: AMD64 Stack Frame"
    grid-columns: 1
    grid-gap: 0

    h: "  Address Offset  |       Field Description                        |  Size " {
      class: header_field
    }

    prev_frame: "  0x...           |       Previous Stack Frame (Caller)            |  ...  " {
      class: padding_field
    }

    arg_n: "  rbp + 16 + 8*n  |       Incoming Argument N                      |  8B   " {
      class: data_field
    }

    arg_7: "  rbp + 16        |       Incoming Argument 7                      |  8B   " {
      class: data_field
      tooltip: "Arguments 1-6 are passed in registers (RDI, RSI, RDX, RCX, R8, R9)"
    }

    ret_addr: "  rbp + 8         |       Return Address (pushed by CALL)          |  8B   " {
      class: frame_ctrl
      style.double-border: true
    }

    saved_rbp: "  rbp + 0         |       Saved Frame Pointer (Parent RBP)         |  8B   " {
      class: pointer_reg
      tooltip: "Current RBP points here"
    }

    saved_regs: "  rbp - 8 to -40  |       Callee-Saved Regs (RBX, R12-R15)         |  40B  " {
      class: pointer_reg
    }

    locals: "  rbp - 48 to -X  |       Local Variables / Buffers                |  Var  " {
      class: data_field
    }

    spills: "  rbp - X to -Y   |       Compiler Spill Slots                     |  Var  " {
      class: data_field
    }

    align: "  Alignment       |       16-Byte Boundary Padding                 |  0-8B " {
      class: padding_field
    }

    rsp_ptr: "  rsp + 0         |       Bottom of Frame                          |  0B   " {
      class: pointer_reg
      tooltip: "Current RSP points here"
    }

    red_zone: "  rsp - 8 to -128 |       ABI Red Zone (Leaf function scratch)     |  128B " {
      class: free_space
      style.stroke-dash: 5
    }
    
    unallocated: "  rsp - 136...    |       Growth Direction (Lower Addresses)       |  ▼    " {
      class: padding_field
    }
  }

  abi_spec: {
    label: "ABI Implementation Notes"
    info: |md
      ### System V AMD64 ABI Invariants
      - **Stack Alignment**: The stack must be **16-byte aligned** at the point of a `call` instruction.
      - **The Red Zone**: 128 bytes below `rsp` are reserved. Functions can use this without adjusting `rsp`, provided they don't call other functions.
      - **Parity**: The `call` instruction pushes an 8-byte return address. A standard function prologue (`push rbp; mov rbp, rsp`) restores 16-byte alignment.
      - **Argument Passing**: 
        1. `%rdi`, `%rsi`, `%rdx`, `%rcx`, `%r8`, `%r9`
        2. Remaining arguments on stack in reverse order.
    |
    style: {
      stroke: "#d1b3ff"
      stroke-width: 2
      border-radius: 8
    }
  }

  legend: {
    label: "Memory Map Legend"
    grid-columns: 1
    grid-gap: 5
    
    l1: "Frame Control / Header" { class: header_field }
    l2: "Pointers / Registers" { class: pointer_reg }
    l3: "Data / Local Variables" { class: data_field }
    l4: "Padding / Boundary" { class: padding_field }
    l5: "Free / Red Zone" { class: free_space }
  }
}

# Structural Connections
System_V_ABI_Stack.stack_visual.saved_rbp -> System_V_ABI_Stack.abi_spec: "Standard Prologue" {
  style: {
    stroke: orange
    stroke-width: 2
    animated: true
  }
}

System_V_ABI_Stack.stack_visual.red_zone -> System_V_ABI_Stack.abi_spec: "Reserved Space" {
  style: {
    stroke-dash: 3
    stroke: green
  }
}