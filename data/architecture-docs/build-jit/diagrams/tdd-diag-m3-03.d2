direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# SYSTEM V AMD64 ABI REGISTER CLASSIFICATION
# Technical Specification for JIT Compiler Implementation

abi_registers: {
  grid-columns: 1
  grid-gap: 0

  header: {
    grid-columns: 4
    grid-gap: 0
    
    h1: "Register" { style: { font-color: white; fill: "#2d3436"; bold: true } }
    h2: "Classification" { style: { font-color: white; fill: "#2d3436"; bold: true } }
    h3: "Primary Role" { style: { font-color: white; fill: "#2d3436"; bold: true } }
    h4: "Preserved By" { style: { font-color: white; fill: "#2d3436"; bold: true } }
  }

  # Caller-Saved Group (Volatile)
  group_caller: {
    grid-columns: 4
    grid-gap: 0

    r_rax: "rax" { style: { fill: "#e1f5fe"; stroke: "#01579b" } }
    c_rax: "Caller-Saved" { style: { fill: "#e1f5fe" } }
    p_rax: "Return Value" { style: { fill: "#e1f5fe" } }
    b_rax: "CALLER" { style: { fill: "#e1f5fe"; font-color: "#b71c1c"; bold: true } }

    r_rdi: "rdi" { style: { fill: "#e1f5fe"; stroke: "#01579b" } }
    c_rdi: "Caller-Saved" { style: { fill: "#e1f5fe" } }
    p_rdi: "Argument 1" { style: { fill: "#e1f5fe" } }
    b_rdi: "CALLER" { style: { fill: "#e1f5fe"; font-color: "#b71c1c" } }

    r_rsi: "rsi" { style: { fill: "#e1f5fe"; stroke: "#01579b" } }
    c_rsi: "Caller-Saved" { style: { fill: "#e1f5fe" } }
    p_rsi: "Argument 2" { style: { fill: "#e1f5fe" } }
    b_rsi: "CALLER" { style: { fill: "#e1f5fe"; font-color: "#b71c1c" } }

    r_rdx: "rdx" { style: { fill: "#e1f5fe"; stroke: "#01579b" } }
    c_rdx: "Caller-Saved" { style: { fill: "#e1f5fe" } }
    p_rdx: "Argument 3 / Div" { style: { fill: "#e1f5fe" } }
    b_rdx: "CALLER" { style: { fill: "#e1f5fe"; font-color: "#b71c1c" } }

    r_rcx: "rcx" { style: { fill: "#e1f5fe"; stroke: "#01579b" } }
    c_rcx: "Caller-Saved" { style: { fill: "#e1f5fe" } }
    p_rcx: "Argument 4" { style: { fill: "#e1f5fe" } }
    b_rcx: "CALLER" { style: { fill: "#e1f5fe"; font-color: "#b71c1c" } }

    r_r8: "r8" { style: { fill: "#e1f5fe"; stroke: "#01579b"; double-border: true } }
    c_r8: "Caller-Saved (Ext)" { style: { fill: "#e1f5fe" } }
    p_r8: "Argument 5" { style: { fill: "#e1f5fe" } }
    b_r8: "CALLER" { style: { fill: "#e1f5fe"; font-color: "#b71c1c" } }

    r_r9: "r9" { style: { fill: "#e1f5fe"; stroke: "#01579b"; double-border: true } }
    c_r9: "Caller-Saved (Ext)" { style: { fill: "#e1f5fe" } }
    p_r9: "Argument 6" { style: { fill: "#e1f5fe" } }
    b_r9: "CALLER" { style: { fill: "#e1f5fe"; font-color: "#b71c1c" } }

    r_r10: "r10" { style: { fill: "#e3f2fd"; stroke: "#01579b"; double-border: true } }
    c_r10: "Caller-Saved (Ext)" { style: { fill: "#e3f2fd" } }
    p_r10: "Temporary / Syscall" { style: { fill: "#e3f2fd" } }
    b_r10: "CALLER" { style: { fill: "#e3f2fd"; font-color: "#b71c1c" } }

    r_r11: "r11" { style: { fill: "#e3f2fd"; stroke: "#01579b"; double-border: true } }
    c_r11: "Caller-Saved (Ext)" { style: { fill: "#e3f2fd" } }
    p_r11: "Temporary / PLT" { style: { fill: "#e3f2fd" } }
    b_r11: "CALLER" { style: { fill: "#e3f2fd"; font-color: "#b71c1c" } }
  }

  # Callee-Saved Group (Preserved)
  group_callee: {
    grid-columns: 4
    grid-gap: 0

    r_rbx: "rbx" { style: { fill: "#fff3e0"; stroke: "#e65100" } }
    c_rbx: "Callee-Saved" { style: { fill: "#fff3e0" } }
    p_rbx: "General Purpose" { style: { fill: "#fff3e0" } }
    b_rbx: "CALLEE" { style: { fill: "#fff3e0"; font-color: "#1b5e20"; bold: true } }

    r_rbp: "rbp" { style: { fill: "#fff3e0"; stroke: "#e65100" } }
    c_rbp: "Callee-Saved" { style: { fill: "#fff3e0" } }
    p_rbp: "Frame Pointer" { style: { fill: "#fff3e0" } }
    b_rbp: "CALLEE" { style: { fill: "#fff3e0"; font-color: "#1b5e20" } }

    r_r12: "r12" { style: { fill: "#fff3e0"; stroke: "#e65100"; double-border: true } }
    c_r12: "Callee-Saved (Ext)" { style: { fill: "#fff3e0" } }
    p_r12: "General Purpose" { style: { fill: "#fff3e0" } }
    b_r12: "CALLEE" { style: { fill: "#fff3e0"; font-color: "#1b5e20" } }

    r_r13: "r13" { style: { fill: "#fff3e0"; stroke: "#e65100"; double-border: true } }
    c_r13: "Callee-Saved (Ext)" { style: { fill: "#fff3e0" } }
    p_r13: "General Purpose" { style: { fill: "#fff3e0" } }
    b_r13: "CALLEE" { style: { fill: "#fff3e0"; font-color: "#1b5e20" } }

    r_r14: "r14" { style: { fill: "#fff3e0"; stroke: "#e65100"; double-border: true } }
    c_r14: "Callee-Saved (Ext)" { style: { fill: "#fff3e0" } }
    p_r14: "General Purpose" { style: { fill: "#fff3e0" } }
    b_r14: "CALLEE" { style: { fill: "#fff3e0"; font-color: "#1b5e20" } }

    r_r15: "r15" { style: { fill: "#fff3e0"; stroke: "#e65100"; double-border: true } }
    c_r15: "Callee-Saved (Ext)" { style: { fill: "#fff3e0" } }
    p_r15: "General Purpose" { style: { fill: "#fff3e0" } }
    b_r15: "CALLEE" { style: { fill: "#fff3e0"; font-color: "#1b5e20" } }
  }

  # Special Group
  group_special: {
    grid-columns: 4
    grid-gap: 0

    r_rsp: "rsp" { style: { fill: "#ffebee"; stroke: "#c62828" } }
    c_rsp: "Hardware Stack" { style: { fill: "#ffebee" } }
    p_rsp: "Stack Pointer" { style: { fill: "#ffebee" } }
    b_rsp: "CALLEE" { style: { fill: "#ffebee"; font-color: "#1b5e20"; italic: true } }
  }
}

# Key Definitions & Invariants
legend: {
  near: bottom-center
  
  caller_note: |md
    ### Caller-Saved (Volatile)
    - If caller needs the value after a `call`, **caller must save it** to the stack.
    - Callee can clobber these freely.
  |
  
  callee_note: |md
    ### Callee-Saved (Preserved)
    - Callee **must save** these if it intends to use them.
    - Callee **must restore** them before returning.
  |

  extended_note: |md
    ### Extended Registers
    - Registers `r8` through `r15`.
    - Indicated by double-borders.
    - Require **REX Prefix** bits (R, X, B) for x86-64 encoding.
  |
}

abi_registers.group_caller.r_r8 -> legend.extended_note: "Requires REX" {
  style: { stroke-dash: 3; opacity: 0.5 }
}