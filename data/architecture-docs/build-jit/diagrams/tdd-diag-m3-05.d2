direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# PROLOGUE EMISSION ALGORITHM: STEP-BY-STEP BYTE GENERATION
# -----------------------------------------------------------------------------

prologue_algorithm: {
  label: "Algorithm: emit_prologue(CodeEmitter* e, FrameLayout* f)"

  # STEP 1: SAVE CALLER RBP
  step_1: {
    label: "1. Save Caller RBP"
    instruction: "push rbp"
    
    buffer_state: {
      shape: sql_table
      # Columns: Key=Offset, Type=Byte, Constraint=Instruction
      "0x00": "0x55" {constraint: "PUSH RBP"}
      
      "0x00".style: {
        font-color: red
        bold: true
        fill: "#ffcfcf"
      }
    }
    
    explanation: |md
      ### Execution Profile
      - **Opcode:** `0x50 + rd` (rbp = 5)
      - **Stack:** `rsp <- rsp - 8`
      - **Memory:** `[rsp] <- rbp`
      - **Size:** 1 byte
    |
  }

  # STEP 2: ESTABLISH FRAME POINTER
  step_2: {
    label: "2. Set Frame Pointer"
    instruction: "mov rbp, rsp"
    
    buffer_state: {
      shape: sql_table
      "0x00": "0x55" {constraint: "PUSH RBP"}
      "0x01": "0x48" {constraint: "REX.W (64-bit)"}
      "0x02": "0x89" {constraint: "MOV r/m64, r64"}
      "0x03": "0xE5" {constraint: "ModR/M: rbp, rsp"}
      
      # Highlights for Step 2
      "0x01".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x02".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x03".style: { font-color: red; bold: true; fill: "#ffcfcf" }
    }
    
    explanation: |md
      ### MOV r/m64, r64
      - **REX.W (0x48):** Sets 64-bit operand size.
      - **0x89:** Opcode for MOV destination.
      - **ModR/M (0xE5):** `11 100 101`
        - mode `11`, src `rsp`, dst `rbp`.
    |
  }

  # STEP 3: CALLEE-SAVED REGS
  step_3: {
    label: "3. Save Callee-Saved Registers"
    instruction: "push rbx; push r12"
    
    buffer_state: {
      shape: sql_table
      "0x00": "0x55" {constraint: "PUSH RBP"}
      "0x01": "0x48" {constraint: "REX.W"}
      "0x02": "0x89" {constraint: "MOV"}
      "0x03": "0xE5" {constraint: "ModR/M"}
      "0x04": "0x53" {constraint: "PUSH RBX"}
      "0x05": "0x41" {constraint: "REX.B (for r12)"}
      "0x06": "0x54" {constraint: "PUSH R12"}
      
      # Highlights for Step 3
      "0x04".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x05".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x06".style: { font-color: red; bold: true; fill: "#ffcfcf" }
    }
    
    explanation: |md
      ### Register Extensions
      - **RBX:** Legacy register `0x53`.
      - **R12:** Extended register (r8-r15).
      - **REX.B (0x41):** Used for register extension bit.
    |
  }

  # STEP 4: ALIGNMENT LOGIC
  step_4: {
    label: "4. Calculate 16-byte Alignment"
    shape: diamond
    logic: |md
      **ABI Requirement:** 16-byte aligned.
      - Return Addr: +8
      - Pushed RBP: +8 (Aligned)
      - RBX, R12: +16 (Aligned)
      **Result:** 0 padding bytes.
    |
    style.fill: "#e1d5e7"
  }

  # STEP 5: ALLOCATE FRAME
  step_5: {
    label: "5. Subtract RSP (Frame Size)"
    instruction: "sub rsp, 128"
    
    buffer_state: {
      shape: sql_table
      "0x00": "0x55" {constraint: "PUSH RBP"}
      "0x01": "0x48" {constraint: "REX.W"}
      "0x02": "0x89" {constraint: "MOV"}
      "0x03": "0xE5" {constraint: "ModR/M"}
      "0x04": "0x53" {constraint: "PUSH RBX"}
      "0x05": "0x41" {constraint: "REX.B"}
      "0x06": "0x54" {constraint: "PUSH R12"}
      "0x07": "0x48" {constraint: "REX.W"}
      "0x08": "0x81" {constraint: "SUB r/m64, imm32"}
      "0x09": "0xEC" {constraint: "ModR/M: rsp, /5"}
      "0x0A": "0x80" {constraint: "imm32[0] (0x80)"}
      "0x0B": "0x00" {constraint: "imm32[1] (0x00)"}
      "0x0C": "0x00" {constraint: "imm32[2] (0x00)"}
      "0x0D": "0x00" {constraint: "imm32[3] (0x00)"}
      
      # Highlights for Step 5
      "0x07".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x08".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x09".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x0A".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x0B".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x0C".style: { font-color: red; bold: true; fill: "#ffcfcf" }
      "0x0D".style: { font-color: red; bold: true; fill: "#ffcfcf" }
    }
    
    explanation: |md
      ### Stack Allocation
      - **0x81:** SUB imm32.
      - **ModR/M (0xEC):** Mode 11, dst `rsp`, op `/5`.
      - **Imm32:** `128` encoded as `80 00 00 00`.
    |
  }

  # FLOW CONNECTIONS
  step_1 -> step_2: "Establish Base"
  step_2 -> step_3: "Preserve State"
  step_3 -> step_4: "Check Alignment"
  step_4 -> step_5: "Alloc Local Space"
}

# -----------------------------------------------------------------------------
# GLOBAL STYLING
# -----------------------------------------------------------------------------

prologue_algorithm.** {
  style: {
    font: mono
    stroke-width: 2
  }
}

# SQL Table Global Styling
prologue_algorithm.*.buffer_state: {
  style: {
    fill: "#f3f4f6"
    stroke: "#374151"
  }
}

# Header highlight for the sql_tables (using row coloring since Header is implicit)
prologue_algorithm.step_1.buffer_state.style.fill: "#dae8fc"
prologue_algorithm.step_2.buffer_state.style.fill: "#dae8fc"
prologue_algorithm.step_3.buffer_state.style.fill: "#dae8fc"
prologue_algorithm.step_5.buffer_state.style.fill: "#dae8fc"

# Legend for Engineers
legend: {
  near: bottom-center
  label: "Instruction Emission Reference"
  
  details: |md
    - **RED/BOLD:** Currently emitted bytes in this step.
    - **REX:** 64-bit extension prefix.
    - **LITTLE-ENDIAN:** Multi-byte immediates are reversed.
    - **ModR/M:** Encodes registers and addressing modes.
  |
  
  style: {
    fill: "#fff2cc"
    stroke: "#d6b656"
    stroke-dash: 2
    border-radius: 4
  }
}