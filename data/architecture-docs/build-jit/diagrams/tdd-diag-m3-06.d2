layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- STYLING CLASSES ---
classes: {
  step_container: {
    style: {
      stroke: "#212121"
      stroke-width: 2
      fill: "#f5f5f5"
      border-radius: 8
      shadow: true
    }
  }
  stack_frame: {
    style: {
      fill: "#ffffff"
      stroke: "#424242"
      stroke-width: 1
    }
  }
  changed: {
    style: {
      stroke: "#d32f2f"
      stroke-width: 5
      font-color: "#d32f2f"
      bold: true
    }
  }
  pointer: {
    shape: parallelogram
    style: {
      fill: "#ffe0b2"
      stroke: "#fb8c00"
      stroke-width: 2
    }
  }
  instruction_hex: {
    shape: code
    style: {
      fill: "#e1bee7"
      stroke: "#7b1fa2"
      font: mono
      bold: true
    }
  }
  memory_offset: {
    shape: text
    style: {
      font: mono
      font-size: 12
      font-color: "#757575"
    }
  }
}

title: |md
  # Epilogue Emission Algorithm
  **Module:** Function JIT (M3)
  **Constraint:** Strict symmetry with Prologue (M3-04)
  **Architecture:** x86_64 / System V AMD64 ABI
| {near: top-center}

# --- STEP 1: DEALLOCATE FRAME ---
emit_step_1: {
  class: step_container
  label: "Step 1: Deallocate Local Space"
  
  instr: "48 83 C4 [total_sub]" {
    class: instruction_hex
    tooltip: "add rsp, imm8/32"
  }

  frame_view: {
    class: stack_frame
    
    # Offsets
    off0: "+0x28" { class: memory_offset }
    off1: "+0x20" { class: memory_offset }
    off2: "+0x18" { class: memory_offset }
    off3: "+0x10" { class: memory_offset }
    off4: "+0x08" { class: memory_offset }
    off5: "+0x00" { class: memory_offset }

    # Slots
    stack_ceiling: "Caller Frame"
    local_vars: "Local Vars / Spills"
    saved_r12: "Saved R12"
    saved_rbx: "Saved RBX"
    saved_rbp: "Saved RBP"
    ret_addr: "Return Address"
    
    rsp_ptr: "RSP" { class: [pointer; changed] }
    rbp_ptr: "RBP" { class: pointer }
    
    # Transitions
    rsp_ptr -> saved_r12: "Moves UP (Add)" {
      style: { stroke: "#d32f2f"; animated: true; stroke-width: 3 }
    }
  }
  
  details: |md
    **Assembly:** `add rsp, <frame_size>`
    **Logic:** Reclaim stack space allocated for locals.
    **Invariant:** RSP must align to top of callee-saved register block.
  |
}

# --- STEP 2: RESTORE CALLEE-SAVED ---
emit_step_2: {
  class: step_container
  label: "Step 2: Restore Registers (REVERSE Order)"
  
  instr: "41 5C; 5B" {
    class: instruction_hex
    tooltip: "pop r12; pop rbx"
  }

  frame_view: {
    class: stack_frame
    
    stack_ceiling: "Caller Frame"
    reclaimed: "Free/Garbage" { style.fill: "#eeeeee"; style.stroke-dash: 3 }
    saved_r12: "Saved R12" { class: changed }
    saved_rbx: "Saved RBX" { class: changed }
    saved_rbp: "Saved RBP"
    ret_addr: "Return Address"
    
    rsp_ptr: "RSP" { class: [pointer; changed] }
    
    rsp_ptr -> saved_rbp: "Incrementing..." {
      style.stroke: "#fb8c00"
    }
  }
  
  details: |md
    **Assembly:** `pop r12`, `pop rbx`
    **Order:** LIFO recovery. Must match inverse of prologue pushes.
    **State:** Registers R12/RBX now hold caller values.
  |
}

# --- STEP 3: RESTORE FRAME POINTER ---
emit_step_3: {
  class: step_container
  label: "Step 3: Restore Base Pointer"
  
  instr: "5D" {
    class: instruction_hex
    tooltip: "pop rbp"
  }

  frame_view: {
    class: stack_frame
    
    stack_ceiling: "Caller Frame"
    saved_rbp: "Saved RBP" { class: changed }
    ret_addr: "Return Address"
    
    rsp_ptr: "RSP" { class: [pointer; changed] }
    rbp_ptr: "RBP" { class: [pointer; changed] }
    
    rsp_ptr -> ret_addr: "Points to RET"
    rbp_ptr -> stack_ceiling: "Restored to Parent" {
      style.stroke: "#388e3c"
      style.stroke-width: 3
    }
  }
  
  details: |md
    **Assembly:** `pop rbp`
    **Mechanism:** `rbp = [rsp]; rsp += 8`
    **Result:** Function returns to caller's frame context.
  |
}

# --- STEP 4: RETURN ---
emit_step_4: {
  class: step_container
  label: "Step 4: Final Return"
  
  instr: "C3" {
    class: instruction_hex
    tooltip: "ret"
  }

  frame_view: {
    class: stack_frame
    
    ret_addr: "Return Address" { class: changed; style.fill: "#ffebee" }
    caller_space: "Caller Stack Frame"
    
    rsp_ptr: "RSP" { class: [pointer; changed] }
    
    rsp_ptr -> caller_space: "Clean Stack"
  }
  
  details: |md
    **Assembly:** `ret`
    **Mechanism:** `rip = [rsp]; rsp += 8`
    **Outcome:** Execution resumes at caller's call site.
  |
}

# --- PIPELINE FLOW ---
emit_step_1 -> emit_step_2: "Next"
emit_step_2 -> emit_step_3: "Next"
emit_step_3 -> emit_step_4: "Finalize"

# --- LEGEND ---
legend: {
  near: bottom-right
  style: {
    fill: "#ffffff"
    stroke: "#9e9e9e"
    stroke-dash: 2
  }
  
  header: "Legend" { shape: text; style.bold: true }
  
  l1: "Opcode Bytes" { class: instruction_hex }
  l2: "State Change" { class: changed }
  l3: "CPU Pointer" { class: pointer }
  l4: "Stack Boundary" { class: stack_frame }
}

# Notes for Implementers
docs: |md
  ### Implementation Notes
  1. **Total Frame Size:** Calculated as `local_size + callee_saved_size + alignment_padding`.
  2. **Stack Alignment:** Epilogue must ensure RSP is 16-byte aligned *before* the `call` instructions, but `ret` expects RSP at `[original_rsp - 8]`.
  3. **Leaf Optimization:** If no stack is used and no registers saved, emit only `ret`.
| { near: bottom-left }