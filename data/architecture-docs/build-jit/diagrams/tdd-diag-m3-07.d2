direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# System V AMD64 ABI Argument Passing Sequence
# This diagram details the transition from Caller to Callee for functions with > 6 arguments.

argument_passing_sequence: {
  shape: sequence_diagram

  caller: Caller (JIT or C)
  cpu_regs: CPU Registers (GPRs)
  stack: Stack Memory (RAM)
  callee: Callee Entry

  preparation: Argument Preparation {
    
    group: Stack Arguments (Reverse Order) {
      caller -> stack: PUSH Arg 7 {
        note: |md
          **Offset: [rsp + 8]**
          High Address
        |
      }
      caller -> stack: PUSH Arg 6 {
        note: |md
          **Offset: [rsp + 0]**
          Low Address (Top of Stack)
        |
      }
    }

    group: Register Arguments (ABI Sequence) {
      caller -> cpu_regs: MOV %rdi, Arg 0
      caller -> cpu_regs: MOV %rsi, Arg 1
      caller -> cpu_regs: MOV %rdx, Arg 2
      caller -> cpu_regs: MOV %rcx, Arg 3
      caller -> cpu_regs: MOV %r8,  Arg 4
      caller -> cpu_regs: MOV %r9,  Arg 5
    }
  }

  alignment_check: Stack Alignment Check {
    caller -> caller: Ensure %rsp % 16 == 0
    note: "Required for SSE/AVX stability in Callee"
  }

  execution: Call Transition {
    caller -> callee: CALL rel32 / call *%rax {
      note: "Pushes Return Address (8 bytes)"
    }
    
    callee -> cpu_regs: Access Args 0-5
    callee -> stack: Access Args 6-7 via [%rbp + 16]...
  }

  # Memory Layout Annotation
  stack_layout_note: {
    near: stack
    shape: text
    label: |md
      ### Stack Layout at Entry
      | Offset | Content |
      | :--- | :--- |
      | [rbp + 24] | **Arg 7** |
      | [rbp + 16] | **Arg 6** |
      | [rbp + 8]  | Return Addr |
      | [rbp + 0]  | Saved RBP |
    |
  }
}

# Styling
argument_passing_sequence.caller.style.fill: "#E1F5FE"
argument_passing_sequence.callee.style.fill: "#E8F5E9"
argument_passing_sequence.cpu_regs.style.fill: "#FFF3E0"
argument_passing_sequence.stack.style.fill: "#F3E5F5"

# Highlight the stack pushes
(argument_passing_sequence.caller -> argument_passing_sequence.stack)[*].style: {
  stroke: "#7B1FA2"
  stroke-width: 2
}

# Highlight register moves
(argument_passing_sequence.caller -> argument_passing_sequence.cpu_regs)[*].style: {
  stroke: "#E65100"
  stroke-width: 2
}

# Call arrow
(argument_passing_sequence.caller -> argument_passing_sequence.callee)[0].style: {
  stroke: "#2E7D32"
  stroke-width: 3
  bold: true
}