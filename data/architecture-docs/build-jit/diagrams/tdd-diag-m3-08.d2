layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
  }
}

classes: {
  header_cell: {
    style: {
      fill: "#e1d5e7"
      stroke: "#9673a6"
      stroke-width: 2
    }
  }
  data_cell: {
    style: {
      fill: "#dae8fc"
      stroke: "#6c8ebf"
      stroke-width: 1
    }
  }
  pointer_node: {
    shape: parallelogram
    style: {
      fill: "#ffe6cc"
      stroke: "#d79b00"
      stroke-width: 2
      font-size: 14
      bold: true
    }
  }
  padding_cell: {
    style: {
      fill: "#f5f5f5"
      stroke: "#666666"
      stroke-dash: 3
    }
  }
  highlight: {
    style: {
      stroke: "#ff0000"
      stroke-width: 4
      font-color: "#ff0000"
      bold: true
    }
  }
}

# MAIN ARCHITECTURE CONTAINER
memory_subsystem: {
  label: "x86-64 Stack Frame & JIT Emission Logic"

  # --- STACK MEMORY LAYOUT ---
  stack_frame: {
    label: "Local Variable Slot Allocation (Stack)"
    
    grid-columns: 3
    grid-gap: 0
    
    # Header Row
    H1: "Offset (RBP)" { style.stroke-width: 0; style.font-size: 11; style.italic: true; style.bold: true }
    H2: "Memory Content" { style.stroke-width: 0; style.font-size: 11; style.italic: true; style.bold: true }
    H3: "Size" { style.stroke-width: 0; style.font-size: 11; style.italic: true; style.bold: true }

    # Higher Addresses (Argument Passing)
    off_arg: "+0x10"
    val_arg: "Argument 7 (Stack Overflow)" { class: data_cell }
    sz_arg: "8 Bytes"

    off_ret: "+0x08"
    val_ret: "Return Address (RIP)" { class: header_cell }
    sz_ret: "8 Bytes"

    # Base Pointer Reference (0x00)
    off_rbp: "0x00"
    val_rbp: "Saved RBP (Caller Frame)" { 
      class: header_cell
      style.double-border: true 
    }
    sz_rbp: "8 Bytes"

    # Local Variable Slots (Negative Offsets)
    off_l0: "-0x08"
    val_l0: "**local[0] (rax_backup)**" {
      class: [data_cell; highlight]
    }
    sz_l0: "8 Bytes"

    off_l1: "-0x10"
    val_l1: "local[1]" { class: data_cell }
    sz_l1: "8 Bytes"

    # Alignment and Cache Line logic
    # Note: Using row grouping for alignment boundary representation
    boundary_label: {
      grid-column-span: 3
      label: "----------------------- 16-Byte Stack Alignment Boundary -----------------------"
      style: {
        stroke-width: 0
        font-size: 10
        font-color: "#666666"
      }
    }

    off_pad: "-0x18"
    val_pad: "Stack Alignment Padding" { class: padding_cell }
    sz_pad: "8 Bytes"
  }

  # --- REGISTER POINTERS ---
  registers: {
    rbp_ptr: "RBP (Base Pointer)" { class: pointer_node }
    rsp_ptr: "RSP (Stack Pointer)" { class: pointer_node }
  }

  # Connections representing hardware pointers
  registers.rbp_ptr -> stack_frame.val_rbp: "0x00" {
    style.stroke: "#d79b00"
    style.stroke-width: 3
  }

  registers.rsp_ptr -> stack_frame.val_pad: "Current TOS" {
    style.stroke: "#d79b00"
    style.stroke-dash: 2
  }

  # --- JIT EMITTER ANNOTATION ---
  jit_logic: {
    label: "Machine Code Generation (Intel Manual Ref)"
    shape: package
    
    # Using double-pipe block string to safely handle internal markdown table pipes
    details: ||md
      ### MOV r/m64, r64 (Opcode 89)
      Encoding for `MOV [rbp - 8], rax`
      
      | Component | Value | Description |
      | :--- | :--- | :--- |
      | **REX.W** | `0x48` | 64-bit operand size prefix |
      | **Opcode**| `0x89` | MOV r/m64, r64 |
      | **ModR/M**| `0x45` | `[reg + disp8]` encoding |
      | **Disp8** | `0xF8` | `-8` signed displacement |
      
      **Instruction Stream:**
      `[ 48 89 45 F8 ]`
    ||
    
    style: {
      fill: "#fff2cc"
      stroke: "#d6b656"
    }
  }

  # Data flow from JIT engine to memory slot
  jit_logic -> stack_frame.val_l0: "Target Slot" {
    style: {
      animated: true
      stroke: "#ff0000"
      stroke-width: 2
    }
  }

  # --- SYSTEM METADATA ---
  summary: {
    shape: text
    label: ||md
      ### Frame Statistics
      - **Total Size:** 48 Bytes
      - **Direction:** Descending (High -> Low)
      - **Calling Conv:** System V AMD64 ABI
      - **Alignment:** RSP % 16 == 0
    ||
  }
}

# Global positioning via layout hints
memory_subsystem.summary -> memory_subsystem.stack_frame: { style.stroke-width: 0; label: "" }

# --- STYLING DEFAULTS ---
***.style.font: mono
(*** -> ***)[*].style.font-size: 12