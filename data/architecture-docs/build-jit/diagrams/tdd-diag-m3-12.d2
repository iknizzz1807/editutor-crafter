layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 40
  }
}

# FACTORIAL(5) RECURSIVE STACK LAYOUT
# Specification: System V AMD64 ABI (x86_64)
# Demonstrating: RBP Chaining, 16-Byte Alignment, and Cache Line Overlap

title: |md
  # Memory Layout: Recursive Stack Frames
  **factorial(5) ➔ factorial(4) ➔ factorial(3)**
  *Intel x86_64 ABI Implementation Details*
| {
  near: top-center
  shape: text
}

stack_container: {
  grid-columns: 3
  grid-gap: 15
  vertical-gap: 0
  style.stroke-width: 0

  # --- HEADER ROW ---
  h_off: "Offset" {shape: text; style.bold: true; style.font-size: 14}
  h_mem: "Stack Memory Content (High Addresses @ Top)" {shape: text; style.bold: true; style.font-size: 14}
  h_siz: "Size" {shape: text; style.bold: true; style.font-size: 14}

  # --- FRAME: factorial(5) (Base of recursion) ---
  o00: "0x58" {shape: text; style.font-size: 12}
  f5_ret: "Return Address (to main)" {
    style.fill: "#8e44ad" # Purple: Header/Control
    height: 45
    width: 380
    tooltip: "System V ABI: 8-byte return pointer"
  }
  s00: "8B" {shape: text; style.font-size: 12}

  o08: "0x50" {shape: text; style.font-size: 12}
  f5_rbp: "Saved RBP (main's base pointer)" {
    style.fill: "#e67e22" # Orange: Pointers
    height: 45
    width: 380
  }
  s08: "8B" {shape: text; style.font-size: 12}

  o16: "0x48" {shape: text; style.font-size: 12}
  f5_rbx: "Saved RBX (local n=5)" {
    style.fill: "#3498db" # Blue: Data
    height: 45
    width: 380
  }
  s16: "8B" {shape: text; style.font-size: 12}

  o24: "0x40" {shape: text; style.font-size: 12}
  f5_pad: "16-Byte Alignment Padding" {
    style.fill: "#95a5a6" # Gray: Padding
    height: 45
    width: 380
  }
  s24: "8B" {shape: text; style.font-size: 12}

  # --- FRAME: factorial(4) ---
  o32: "0x38" {shape: text; style.font-size: 12}
  f4_ret: "Return Address (to fact(5)+offset)" {
    style.fill: "#8e44ad"
    height: 45
    width: 380
  }
  s32: "8B" {shape: text; style.font-size: 12}

  o40: "0x30" {shape: text; style.font-size: 12}
  f4_rbp: "Saved RBP (fact(5)'s base pointer)" {
    style.fill: "#e67e22"
    height: 45
    width: 380
  }
  s40: "8B" {shape: text; style.font-size: 12}

  # --- CACHE LINE BOUNDARY (64B from base) ---
  cache_off: "" {style.opacity: 0}
  cache_line: "--- L1 Cache Line Boundary (64B Segment) ---" {
    style: {
      stroke: red
      stroke-dash: 5
      font-color: red
      bold: true
      stroke-width: 2
      fill: transparent
    }
    height: 30
  }
  cache_siz: "" {style.opacity: 0}

  o48: "0x28" {shape: text; style.font-size: 12}
  f4_rbx: "Saved RBX (local n=4)" {
    style.fill: "#3498db"
    height: 45
    width: 380
  }
  s48: "8B" {shape: text; style.font-size: 12}

  o56: "0x20" {shape: text; style.font-size: 12}
  f4_pad: "16-Byte Alignment Padding" {
    style.fill: "#95a5a6"
    height: 45
    width: 380
  }
  s56: "8B" {shape: text; style.font-size: 12}

  # --- FRAME: factorial(3) (Active Frame) ---
  o64: "0x18" {shape: text; style.font-size: 12}
  f3_ret: "Return Address (to fact(4)+offset)" {
    style.fill: "#8e44ad"
    height: 45
    width: 380
  }
  s64: "8B" {shape: text; style.font-size: 12}

  o72: "0x10" {shape: text; style.font-size: 12}
  f3_rbp: "Saved RBP (fact(4)'s base pointer)" {
    style.fill: "#e67e22"
    height: 45
    width: 380
  }
  s72: "8B" {shape: text; style.font-size: 12}

  o80: "0x08" {shape: text; style.font-size: 12}
  f3_rbx: "Saved RBX (local n=3)" {
    style.fill: "#3498db"
    height: 45
    width: 380
  }
  s80: "8B" {shape: text; style.font-size: 12}

  o88: "0x00" {shape: text; style.font-size: 12}
  rsp_active: "Active %rsp (Stack Pointer)" {
    style: {
      fill: "#2ecc71" # Green: Free/Active head
      stroke-width: 4
      stroke: black
    }
    height: 45
    width: 380
  }
  s88: "8B" {shape: text; style.font-size: 12}
}

# RBP CHAIN ANNOTATIONS (Frame Pointers)
# These represent the physical pointer values stored in the stack
stack_container.f3_rbp -> stack_container.f4_rbp: "points to prev RBP" {
  style: {
    stroke: "#e67e22"
    stroke-width: 4
    animated: true
  }
}

stack_container.f4_rbp -> stack_container.f5_rbp: "points to prev RBP" {
  style: {
    stroke: "#e67e22"
    stroke-width: 4
    animated: true
  }
}

# GROWTH DIRECTION
growth_indicator: {
  near: stack_container
  top_mark: "" {style.opacity: 0}
  bot_mark: "" {style.opacity: 0}
  top_mark -> bot_mark: "Stack Growth (Lower Addresses)" {
    style: {
      stroke-width: 6
      stroke: "#2c3e50"
    }
  }
}

# DOCUMENTATION AND SPECS
specs: |md
  ### Architectural Compliance (x86_64)
  1. **ABI Standard**: System V AMD64 (Linux/macOS).
  2. **16-Byte Alignment**: Before any `call` instruction, `%rsp` must be 16-byte aligned.
  3. **Call Mechanism**: `call` pushes 8 bytes (return address), shifting alignment by 8.
  4. **Prologues**: Each frame executes `push %rbp; mov %rsp, %rbp` to establish the chain.
  5. **Data Isolation**: Each frame occupies 32 bytes (4 words * 8 bytes).
| {
  near: stack_container
  shape: text
}

# LEGEND
legend: {
  near: bottom-right
  shape: sql_table
  style.fill: white
  
  control: "Control (Return Addr)" { style.fill: "#8e44ad"; font-color: white }
  pointer: "RBP Pointer Link" { style.fill: "#e67e22" }
  data: "Local Data (n)" { style.fill: "#3498db" }
  padding: "ABI Padding (8B)" { style.fill: "#95a5a6" }
  active: "Stack Pointer (%rsp)" { style.fill: "#2ecc71" }
}

# GLOBAL STYLING
***.style.font: mono
(*** -> ***)[*].style.font-size: 11
stack_container.*.style.stroke: "#2c3e50"