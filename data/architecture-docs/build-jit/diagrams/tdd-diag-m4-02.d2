direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

tiered_flow: "Tiered Compilation Decision Flow" {
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
    stroke: "#343a40"
  }

  entry: "vm_call(func_id, args)" {
    shape: parallelogram
    style: {
      fill: "#e7f3ff"
      stroke: "#1971c2"
      stroke-width: 2
    }
  }

  check_jit: "Is jit_entry != NULL?" {
    shape: diamond
    style: {
      fill: "#fff3bf"
      stroke: "#f59f00"
    }
    tooltip: "Checks if native code address is already cached in the function metadata"
  }

  # --- FAST PATH ---
  fast_path: "FAST PATH: Native Execution" {
    style: {
      stroke: "#2b8a3e"
      fill: "#f1fbe9"
      stroke-dash: 0
    }
    
    jit_exec: "Execute JIT Code\n(Direct Function Pointer Call)" {
      shape: rectangle
      style: {
        fill: "#ebfbee"
        stroke: "#2b8a3e"
        bold: true
      }
    }
    
    jit_return: "Return Result" {
      shape: parallelogram
      style: {
        fill: "#ebfbee"
        stroke: "#2b8a3e"
      }
    }

    jit_exec -> jit_return: "RET"
  }

  # --- SLOW PATH ---
  slow_path: "SLOW PATH: Profiling & Decision" {
    style: {
      fill: "#fff9db"
      stroke: "#f59f00"
    }
    
    dec_counter: "--invocation_counter\n(Decrement-and-Branch)" {
      shape: rectangle
      style: {
        fill: "#fff4e6"
        stroke: "#e67e22"
      }
      tooltip: "1 cycle overhead using DEC + JNZ pattern. Threshold typically 10,000."
    }

    check_hot: "Is counter == 0?" {
      shape: diamond
      style: {
        fill: "#fff3bf"
        stroke: "#f59f00"
      }
    }

    # --- COLD PATH ---
    cold_path: "COLD PATH: Interpretation" {
      style: {
        stroke: "#495057"
        fill: "#f1f3f5"
      }
      
      interpret: "Execute via Interpreter\n(Bytecode Dispatch Loop)" {
        style: {
          fill: "#ffffff"
          stroke: "#495057"
        }
      }
      
      interp_return: "Return Result" {
        shape: parallelogram
        style: {
          fill: "#ffffff"
          stroke: "#495057"
        }
      }
      
      interpret -> interp_return: "RET"
    }

    # --- HOT TRANSITION ---
    hot_transition: "HOT PATH: JIT Compilation Trigger" {
      style: {
        stroke: "#e03131"
        fill: "#fff5f5"
        stroke-width: 2
      }

      optimize: "Optimization Pipeline" {
        tooltip: "Constant Folding, Dead Store Elim, Strength Reduction"
        style: {
          fill: "#ffe3e3"
          stroke: "#e03131"
        }
      }

      compile: "JIT Compilation\n(Translate Bytecode to x86-64)" {
        style: {
          fill: "#ffe3e3"
          stroke: "#e03131"
        }
      }

      cache: "Code Cache Allocation\n(mmap RW -> mprotect RX)" {
        style: {
          fill: "#ffe3e3"
          stroke: "#e03131"
        }
      }

      update: "Update Entry\njit_entry = code_ptr" {
        style: {
          fill: "#ffc9c9"
          stroke: "#e03131"
          bold: true
        }
      }

      optimize -> compile -> cache -> update
    }
  }

  # Root Connections
  entry -> check_jit: "Call Start"

  check_jit -> fast_path.jit_exec: "Yes (Hot)" {
    style: {
      stroke: "#2b8a3e"
      stroke-width: 4
    }
  }

  check_jit -> slow_path.dec_counter: "No (Cold/Warmup)" {
    style: {
      stroke: "#f59f00"
      stroke-dash: 3
    }
  }

  slow_path.dec_counter -> slow_path.check_hot: "Update Counter"

  slow_path.check_hot -> slow_path.cold_path.interpret: "No (Warmup)" {
    style: {
      stroke: "#868e96"
      stroke-width: 1
    }
  }

  slow_path.check_hot -> slow_path.hot_transition.optimize: "Yes (Threshold Hit)" {
    style: {
      stroke: "#e03131"
      stroke-width: 3
      animated: true
    }
  }

  slow_path.hot_transition.update -> slow_path.cold_path.interpret: "Fallback for\ncurrent call" {
    style: {
      stroke: "#fa5252"
      stroke-dash: 5
    }
  }
}

legend: {
  near: bottom-right
  jit_color: "Native/JIT Execution Path" {
    style: {
      fill: "#ebfbee"
      stroke: "#2b8a3e"
    }
  }
  interp_color: "Bytecode Interpreter Path" {
    style: {
      fill: "#f1f3f5"
      stroke: "#495057"
    }
  }
  hot_color: "JIT Compiler Engine" {
    style: {
      fill: "#ffe3e3"
      stroke: "#e03131"
    }
  }
}

ann: |md
  ### Tiered Compilation System Design
  - **Overhead Control**: Path selection costs < 5% total runtime. 
  - **Memory Safety**: `W^X` policy enforced. Code cache is `RW-` during write, `R-X` during execution.
  - **Thresholding**: Default `counter` = 10k. Scaled based on loop nesting level.
  - **Concurrency**: JIT Compilation usually runs on a background thread in production (async).
| {
  near: bottom-left
  style: {
    stroke: "#dee2e6"
    fill: "#f8f9fa"
  }
}