direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# --- STYLING CLASSES ---
# Intel Manual Quality styling based on system prompts
classes: {
  header_cell: {
    style: {
      fill: "#6a1b9a" # Purple (Header)
      font-color: white
      bold: true
      text-transform: uppercase
      stroke: "#4a148c"
      stroke-width: 2
    }
  }
  pointer_cell: {
    style: {
      fill: "#ef6c00" # Orange (Pointers)
      font-color: white
      bold: true
      stroke: "#e65100"
      stroke-width: 1
    }
  }
  data_cell: {
    style: {
      fill: "#1976d2" # Blue (Data)
      font-color: white
      stroke: "#0d47a1"
      stroke-width: 1
    }
  }
  padding_cell: {
    style: {
      fill: "#9e9e9e" # Gray (Padding)
      font-color: white
      italic: true
      stroke: "#757575"
      stroke-width: 1
    }
  }
  margin_label: {
    shape: text
    style: {
      font-size: 14
      font: mono
      font-color: "#424242"
    }
  }
  boundary_line: {
    style: {
      stroke-dash: 5
      stroke: "#d32f2f"
      stroke-width: 3
    }
  }
}

# --- METADATA & ANNOTATIONS ---
"Struct Metadata": |md
  ### x86-64 Memory Alignment (ABI Compliant)
  - **Type:** `struct function_t`
  - **Total Size:** 40 Bytes (0x28)
  - **Alignment:** 8-byte boundary
  - **Cache Usage:** 100% contained in single 64B line
  - **Byte Order:** Little-Endian
| {
  near: top-center
}

# --- MEMORY LAYOUT CONTAINER ---
"Function Struct Memory Layout": {
  style: {
    stroke: "#212121"
    stroke-width: 2
    fill: "#f5f5f5"
  }

  table: {
    grid-columns: 3
    grid-gap: 0
    
    # --- TABLE HEADERS ---
    off_h: "Offset (Hex)" { class: margin_label; style.bold: true; style.underline: true }
    field_h: "Field Member (Type + Name)" { class: header_cell; width: 450 }
    size_h: "Size" { class: margin_label; style.bold: true; style.underline: true }

    # Row 0: bytecode pointer
    o0: "0x00" { class: margin_label }
    f0: "uint8_t* bytecode" { 
      class: pointer_cell
      tooltip: "Pointer to VM instruction stream"
    }
    s0: "8 Bytes" { class: margin_label }

    # Row 1: bytecode_len
    o1: "0x08" { class: margin_label }
    f1: "size_t bytecode_len" { 
      class: data_cell
      tooltip: "Total byte count of bytecode buffer"
    }
    s1: "8 Bytes" { class: margin_label }

    # Row 2: invocation_counter
    o2: "0x10" { class: margin_label }
    f2: "int32_t invocation_counter" { 
      class: data_cell
      tooltip: "Hotness tracking for JIT trigger"
    }
    s2: "4 Bytes" { class: margin_label }

    # Row 3: is_compiling
    o3: "0x14" { class: margin_label }
    f3: "bool is_compiling" { 
      class: data_cell
      tooltip: "Atomic flag for background compilation"
    }
    s3: "1 Byte" { class: margin_label }

    # Row 4: alignment padding
    o4: "0x15" { class: margin_label }
    f4: "[alignment padding]" { 
      class: padding_cell
      tooltip: "3-byte pad for 8-byte pointer alignment"
    }
    s4: "3 Bytes" { class: margin_label }

    # Row 5: jit_entry pointer
    o5: "0x18" { class: margin_label }
    f5: "void* jit_entry" { 
      class: pointer_cell
      tooltip: "Points to native code in RX buffer"
    }
    s5: "8 Bytes" { class: margin_label }

    # Row 6: is_blacklisted
    o6: "0x20" { class: margin_label }
    f6: "bool is_blacklisted" { 
      class: data_cell
      tooltip: "Flag to disable further JIT attempts"
    }
    s6: "1 Byte" { class: margin_label }

    # Row 7: tail padding
    o7: "0x21" { class: margin_label }
    f7: "[struct tail padding]" { 
      class: padding_cell
      tooltip: "7-byte pad for array element alignment"
    }
    s7: "7 Bytes" { class: margin_label }
  }
}

# --- CACHE LINE BOUNDARY ---
"Cache Line Boundary": {
  near: bottom-center
  label: "64-byte L1D Cache Line (Dashed = Line Boundary)"
  width: 600
  class: boundary_line
}

# --- VISUAL GUIDES & POINTERS ---
"Function Struct Memory Layout".table.o0 -> "Function Struct Memory Layout".table.o7: "Memory Growth" {
  style: {
    stroke: "#212121"
    stroke-width: 3
    animated: true
  }
}

# External memory regions
"Raw Bytecode Buffer": { 
  shape: parallelogram
  style: {
    fill: "#fff3e0"
    stroke: "#ef6c00"
    stroke-width: 2
  }
}

"JIT Executable Segment": { 
  shape: parallelogram
  style: {
    fill: "#fff3e0"
    stroke: "#ef6c00"
    stroke-width: 2
  }
}

# Pointer associations
# Corrected syntax: target-arrowhead moved outside style block
"Function Struct Memory Layout".table.f0 -> "Raw Bytecode Buffer": "points to (R)" {
  style: {
    stroke: "#ef6c00"
    stroke-dash: 4
  }
  target-arrowhead: triangle
}

"Function Struct Memory Layout".table.f5 -> "JIT Executable Segment": "points to (RX)" {
  style: {
    stroke: "#ef6c00"
    stroke-dash: 4
  }
  target-arrowhead: triangle
}

# --- LEGEND ---
Legend: {
  near: bottom-right
  grid-columns: 2
  grid-gap: 10
  style.stroke: "#cccccc"
  style.fill: "#ffffff"
  
  ptr_b: "" { class: pointer_cell; width: 30; height: 15 }
  ptr_l: "Pointer (8B)" { shape: text }
  
  dat_b: "" { class: data_cell; width: 30; height: 15 }
  dat_l: "Data (1-8B)" { shape: text }
  
  pad_b: "" { class: padding_cell; width: 30; height: 15 }
  pad_l: "Padding / Hole" { shape: text }
}

"Footer Label": "Size: 40 Bytes | Align: 8 Bytes" {
  near: bottom-left
  shape: text
  style.font: mono
  style.bold: true
}