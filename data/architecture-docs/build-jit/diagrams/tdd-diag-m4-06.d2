layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# AGENT: TECHNICAL DESIGN ARTIST
# JIT Code Cache Memory Pool - x86-64 Memory Layout Specification

code_cache_system: {
  label: "JIT Code Cache Management System"

  # 1. THE METADATA STRUCTURE (CodeCache Struct on Heap)
  # sizeof=40 bytes (aligned to 64B cache line in practice)
  cache_struct: {
    label: "struct CodeCache (Heap Allocated)"
    shape: sql_table
    style: {
      stroke: "#512da8"
      stroke-width: 2
      fill: "#FFFFFF"
    }
    
    header: "Offset | Field | Size" {
      style: {
        fill: "#EDE7F6"
        bold: true
      }
    }
    f1: "0x00 | buffer (uint8_t*) | 8B" {
      style: { fill: "#FFF3E0"; font-color: "#E65100" } # Pointer Orange
    }
    f2: "0x08 | capacity (size_t) | 8B" {
      style: { fill: "#E3F2FD" } # Data Blue
    }
    f3: "0x10 | used (size_t) | 8B" {
      style: { fill: "#E3F2FD" } # Data Blue
    }
    f4: "0x18 | entries (CodeCacheEntry*) | 8B" {
      style: { fill: "#FFF3E0"; font-color: "#E65100" } # Pointer Orange
    }
    f5: "0x20 | entry_count (int32_t) | 4B" {
      style: { fill: "#E3F2FD" } # Data Blue
    }
    f6: "0x24 | prot_state (int) | 4B" {
      style: { fill: "#E3F2FD" } # Data Blue
    }
    
    footer: "sizeof=40 bytes | Heap Metadata Ptr: 0x7FFF..." {
      style: { italic: true; font-size: 10 }
    }
  }

  # 2. THE EXECUTABLE MEMORY BUFFER (mmap'd Region)
  # Page alignment enforced. Permission: R-X (Post-JIT)
  executable_buffer: {
    label: "mmap'd Executable Region (PROT_READ | PROT_EXEC)"
    
    direction: down
    
    page_boundary_start: "---------------- PAGE BOUNDARY (4096B) ----------------" {
      style: { stroke-width: 4; stroke: black; font-color: gray; bold: true }
    }

    func_0: "Function 0 Code (Native x86-64)\nOffset: +0x0000 | Size: 256B" {
      style: {
        fill: "#BBDEFB" # Data Blue
        stroke: "#1976D2"
        stroke-dash: 0
      }
    }
    
    func_1: "Function 1 Code (Native x86-64)\nOffset: +0x0100 | Size: 384B" {
      style: {
        fill: "#BBDEFB" # Data Blue
        stroke: "#1976D2"
      }
    }

    alignment_padding: "Padding (16B Aligned)\n0x180 - 0x190" {
      style: {
        fill: "#EEEEEE" # Padding Gray
        stroke: "#9E9E9E"
        font-color: "#757575"
      }
    }

    bump_cursor: "--- BUMP CURSOR (base + used) ---" {
      shape: hexagon
      style: {
        fill: "#FFECB3"
        stroke: "#FFA000"
        bold: true
      }
    }

    free_space: "Available Space (Used for next compilation)\nSize: (capacity - used)" {
      style: {
        fill: "#C8E6C9" # Free Green
        stroke: "#388E3C"
        stroke-dash: 5
      }
    }

    page_boundary_end: "---------------- PAGE BOUNDARY (4096B) ----------------" {
      style: { stroke-width: 4; stroke: black; font-color: gray; bold: true }
    }
  }

  # 3. METADATA ENTRIES ARRAY (Ownership Tracking)
  # Fixed size or dynamic growth array
  entries_array: {
    label: "CodeCacheEntry[] (Metadata Array)"
    
    entry_0: {
      shape: sql_table
      header: "Entry 0"
      f1: "func_id: 0"
      f2: "code_start: 0x0000"
      f3: "code_size: 256B"
      style: { fill: "#F3E5F5"; stroke: "#7B1FA2" }
    }
    
    entry_1: {
      shape: sql_table
      header: "Entry 1"
      f1: "func_id: 1"
      f2: "code_start: 0x0100"
      f3: "code_size: 384B"
      style: { fill: "#F3E5F5"; stroke: "#7B1FA2" }
    }
    
    unused_entries: "..." {
      shape: text
    }
  }

  # CONNECTIONS & POINTERS
  # Establishing hardware-level references for implementation
  cache_struct.f1 -> executable_buffer.page_boundary_start: "mmap base pointer" {
    style: {
      stroke: "#E65100"
      stroke-width: 2
      animated: true
    }
  }

  cache_struct.f4 -> entries_array.entry_0: "metadata array ptr" {
    style: {
      stroke: "#E65100"
      stroke-width: 2
    }
  }

  # BUMP ALLOCATION LOGIC ANNOTATION
  # Near constant used for ELK compatibility
  allocation_logic: |md
    ### Bump Allocation Logic
    1. `size = (req_size + 15) & ~15` (Align to 16B)
    2. `if (used + size > capacity) fail`
    3. `code_ptr = buffer + used`
    4. `used += size`
    5. `Update entries[count++]`
  | {
    near: bottom-right
    style: {
      font-size: 12
      fill: "#FFFDE7"
      stroke: "#FBC02D"
    }
  }
}

# GLOBAL STYLING
***.style.font: mono
(executable_buffer.** -> executable_buffer.**): {
  style: { stroke-width: 1 }
}