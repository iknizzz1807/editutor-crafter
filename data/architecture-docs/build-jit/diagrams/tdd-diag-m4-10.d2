layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    header: "#D1C4E9"
    data: "#BBDEFB"
    pointer: "#FF9800"
    modified: "#D32F2F"
    padding: "#E0E0E0"
  }
}

direction: right

# -----------------------------------------------------------------------------------------
# CONSTANT FOLDING TRANSFORMATION FLOW
# -----------------------------------------------------------------------------------------
# Specification:
# 1. Linear scan identifies sequence: PUSH(const) -> PUSH(const) -> BIN_OP
# 2. Compile-time evaluation of BIN_OP(const1, const2)
# 3. Instruction rewriting: Replace first PUSH with PUSH(result), pad remainder with NOP
# -----------------------------------------------------------------------------------------

algorithm_execution: {
  grid-columns: 2
  grid-rows: 2
  grid-gap: 80

  # STEP 1: INITIAL STATE
  # ---------------------------------------------------------
  step_1: "1. Bytecode Traversal (Start)" {
    bytecode: {
      shape: sql_table
      style.fill: ${colors.header}
      line0: "0x00: OP_PUSH_IMM32" {constraint: "1B Type"}
      line1: "0x01: 10" {constraint: "4B Data"}
      line2: "0x05: OP_PUSH_IMM32" {constraint: "1B Type"}
      line3: "0x06: 20" {constraint: "4B Data"}
      line4: "0x0A: OP_ADD" {constraint: "1B Type"}
    }
    vstack: {
      shape: sql_table
      label: "Value Stack (Virtual)"
      style.fill: ${colors.data}
      s0: "EMPTY" {constraint: "Base"}
    }
    pc: "PC -> 0x00" {
      style.stroke: ${colors.pointer}
      style.stroke-width: 4
      style.border-radius: 5
    }
    
    # Highlight Current Instruction
    bytecode.line0.style: { font-color: ${colors.modified}; bold: true; stroke-width: 3 }
  }

  # STEP 2: TRACK FIRST CONSTANT
  # ---------------------------------------------------------
  step_2: "2. Constant Tracking" {
    bytecode: {
      shape: sql_table
      style.fill: ${colors.header}
      line0: "0x00: OP_PUSH_IMM32"
      line1: "0x01: 10"
      line2: "0x05: OP_PUSH_IMM32" {constraint: "TARGET"}
      line3: "0x06: 20"
      line4: "0x0A: OP_ADD"
    }
    vstack: {
      shape: sql_table
      label: "Value Stack"
      style.fill: ${colors.data}
      s0: "SLOT 0: {const: true, val: 10}" {constraint: "PUSHED"}
    }
    pc: "PC -> 0x05" {
      style.stroke: ${colors.pointer}
      style.stroke-width: 4
    }
    
    # Highlight changes
    bytecode.line2.style: { font-color: ${colors.modified}; bold: true; stroke-width: 3 }
    vstack.s0.style: { font-color: ${colors.modified}; bold: true }
  }

  # STEP 3: MATCH TRIGGER
  # ---------------------------------------------------------
  step_3: "3. Pattern Match (Fold Trigger)" {
    bytecode: {
      shape: sql_table
      style.fill: ${colors.header}
      line0: "0x00: OP_PUSH_IMM32"
      line1: "0x01: 10"
      line2: "0x05: OP_PUSH_IMM32"
      line3: "0x06: 20"
      line4: "0x0A: OP_ADD" {constraint: "MATCH!"}
    }
    vstack: {
      shape: sql_table
      label: "Value Stack"
      style.fill: ${colors.data}
      s0: "SLOT 0: {const: true, val: 10}"
      s1: "SLOT 1: {const: true, val: 20}" {constraint: "PUSHED"}
    }
    pc: "PC -> 0x0A" {
      style.stroke: ${colors.pointer}
    }
    
    match_logic: |md
      ### Fold Condition:
      - `stack[top] == CONST`
      - `stack[top-1] == CONST`
      - `instr == BIN_OP`
      **Result: FOLD(10, 20, ADD)**
    | {
      style.stroke: ${colors.modified}
      style.stroke-width: 4
      style.fill: "#FFF9C4"
      style.border-radius: 8
    }
    
    bytecode.line4.style: { font-color: ${colors.modified}; bold: true; stroke-width: 3 }
    vstack.s1.style: { font-color: ${colors.modified}; bold: true }
  }

  # STEP 4: REWRITE / FOLDING COMPLETE
  # ---------------------------------------------------------
  step_4: "4. Replacement (Fold Complete)" {
    bytecode: {
      shape: sql_table
      style.fill: ${colors.header}
      line0: "0x00: OP_PUSH_IMM32" {constraint: "RETAIN"}
      line1: "0x01: 30 (FOLDED)" {constraint: "RESULT"}
      line2: "0x05: OP_NOP" {constraint: "0x90"}
      line3: "0x06: OP_NOP" {constraint: "0x90"}
      line4: "0x0A: OP_NOP" {constraint: "0x90"}
    }
    vstack: {
      shape: sql_table
      label: "Value Stack"
      style.fill: ${colors.data}
      s0: "SLOT 0: {const: true, val: 30}" {constraint: "EVALED"}
    }
    pc: "PC -> 0x0B" {
      style.stroke: ${colors.pointer}
    }
    
    # Show rewritten section
    bytecode.line1.style: { font-color: ${colors.modified}; bold: true; stroke-width: 2 }
    # Rule 1 Padding: Gray
    bytecode.line2.style: { font-color: gray; italic: true; fill: ${colors.padding} }
    bytecode.line3.style: { font-color: gray; italic: true; fill: ${colors.padding} }
    bytecode.line4.style: { font-color: gray; italic: true; fill: ${colors.padding} }
    
    vstack.s0.style: { font-color: ${colors.modified}; bold: true }
  }
}

# TRANSITION EDGES
algorithm_execution.step_1 -> algorithm_execution.step_2: "Scan 0x00" { style.stroke: ${colors.pointer} }
algorithm_execution.step_2 -> algorithm_execution.step_3: "Scan 0x05" { style.stroke: ${colors.pointer} }
algorithm_execution.step_3 -> algorithm_execution.step_4: "Fold & Rewrite" { 
  style.stroke: ${colors.modified}
  style.stroke-width: 3
  style.animated: true
}

# IMPLEMENTATION SPECIFICATION
implementation_details: |md
  ### Transformation Byte Layout (Intel x86 Style)
  - **Original Stream (11 Bytes):**
    - `[00]` 0x68 (PUSH) + `[01..04]` (0x0000000A)
    - `[05]` 0x68 (PUSH) + `[06..09]` (0x00000014)
    - `[0A]` 0x01 (ADD)
  - **Folded Stream (11 Bytes Total):**
    - `[00]` 0x68 (PUSH) + `[01..04]` **0x0000001E (30)**
    - `[05]` 0x90 (NOP)
    - `[06]` 0x90 (NOP) x 4 (Pad Result Slot)
    - `[0A]` 0x90 (NOP) (Pad Op Slot)
  
  **Optimization Benefit:**
  1. Reduces cycles from 3 instructions to 1.
  2. Eliminates 2 stack push/pop overheads.
  3. Total size remains 11 bytes to avoid branch offset recalculation.
| {
  near: algorithm_execution
  style: {
    stroke: orange
    stroke-width: 2
    fill: "#FFF3E0"
    font-size: 14
  }
}

# DIAGRAM LEGEND
legend: {
  near: bottom-center
  grid-columns: 2
  l1: "Virtual Value Stack" { style.fill: ${colors.data} }
  l2: "Instruction Pointer (PC)" { style.stroke: ${colors.pointer}; stroke-width: 3 }
  l3: "Modified State" { style.font-color: ${colors.modified}; bold: true }
  l4: "Padded/NOP Regions" { style.font-color: gray; italic: true; fill: ${colors.padding} }
}

# GLOBAL STYLES
***.style.font-size: 14
algorithm_execution.** {
  bytecode: { style.stroke: "#333333" }
  vstack: { style.stroke: "#1976D2" }
}