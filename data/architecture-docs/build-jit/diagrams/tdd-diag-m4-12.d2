direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# 1. MEMORY LAYOUT: JIT NATIVE CODE BUFFER (RX)
# Intel Manual Quality: Byte offsets and field-level size annotations
native_buffer_layout: "Memory Map: JIT Native Instruction Buffer (Executable Segment)" {
  shape: sql_table
  style: {
    stroke: "#333333"
    fill: "#fdfdfd"
    stroke-width: 2
    shadow: true
  }
  
  "0x00": "Prologue: PUSH RBP; MOV RBP, RSP" {
    constraint: "8 Bytes ( Purple )"
    style.fill: "#E1BEE7" # Purple Header
  }
  "0x08": "Counter Check: CMP [RCX+Offset], Threshold" {
    constraint: "10 Bytes ( Orange )"
    style.fill: "#FFE0B2" # Orange Pointer/Logic
  }
  "0x12": "Hot Loop Body: ADD RAX, RBX" {
    constraint: "40 Bytes ( Blue )"
    style.fill: "#BBDEFB" # Blue Data
  }
  "0x3A": "Deopt Check: JO .deoptimize_handler" {
    constraint: "10 Bytes ( Red )"
    style.fill: "#FFCDD2" # Logic/Error
  }
  "0x44": "Padding: NOP; NOP; NOP" {
    constraint: "32 Bytes ( Gray )"
    style.fill: "#EEEEEE" # Gray Padding
  }
  "0x64": "Epilogue: POP RBP; RET" {
    constraint: "4 Bytes ( Purple )"
    style.fill: "#E1BEE7" # Purple Header
  }
}

# 2. PERFORMANCE ANALYSIS MODULE
# Visual comparison of execution tiers
performance_analysis: "Benchmark Analysis: Sum 1..1M Performance (Latency in ms)" {
  style: {
    stroke-width: 4
    fill: "#f8f9fa"
    border-radius: 10
  }

  # Performance Visualization Chart
  chart: {
    grid-columns: 2
    grid-gap: 20
    vertical-gap: 40

    label_interp: "INTERPRETER\n(Baseline)" { 
      shape: text 
      style.bold: true
    }
    bar_interp: "500ms (1.0x)" {
      width: 600
      height: 45
      style: {
        fill: "#e0e0e0"
        stroke: "#757575"
        stroke-width: 2
        shadow: true
      }
    }

    label_naive: "JIT NAIVE\n(Tier 1)" { 
      shape: text 
      style.bold: true
    }
    bar_naive: "50ms (10.0x Speedup)" {
      width: 150 # Proportional representation
      height: 45
      style: {
        fill: "#64b5f6"
        stroke: "#1976d2"
        stroke-width: 2
        shadow: true
      }
    }

    label_opt: "JIT OPTIMIZED\n(Tier 2)" { 
      shape: text 
      style.bold: true
    }
    bar_opt: "30ms (16.7x Speedup)" {
      width: 90 # Proportional representation
      height: 45
      style: {
        fill: "#81c784"
        stroke: "#388e3c"
        stroke-width: 2
        shadow: true
      }
    }
  }

  # Operational Cost Breakdown
  # FIXED: Removed 'near: bottom-center' from nested Markdown shape to resolve D2 compilation error.
  # The layout engine will naturally place this after the 'chart' within the container.
  cost_table: ||md
    | Operation | Interpreter | JIT Naive | JIT Optimized |
    | :--- | :--- | :--- | :--- |
    | **Opcode Fetch** | 5 cycles | 0 (eliminated) | 0 (eliminated) |
    | **Decode/Dispatch** | 15 cycles | 0 (eliminated) | 0 (eliminated) |
    | **Register Alloc** | 0 (Stack-based) | 3 (RAX/RBX) | 1 (Pinned) |
    | **Execution** | 5 cycles | 1 cycle | 1 cycle |
    | **Stack Sync** | 15 cycles | 0 (eliminated) | 0 (eliminated) |
    | **TOTAL PER OP** | **~40 cycles** | **~4 cycles** | **~2 cycles** |
  ||
}

# 3. DATA FLOW: OPTIMIZATION PIPELINE
logic_flow: "Hot Path Optimization Pipeline" {
  interpreter: "Interpreter Loop\n(Bytecode Dispatcher)" {
    shape: cylinder
    style.fill: "#cfd8dc"
  }
  
  profiler: "Hotness Profiler\n(Mcall Counter)" {
    style.fill: "#fff9c4"
    style.bold: true
  }
  
  jit_compiler: "Tier-2 JIT Compiler\n(SSA Optimization)" {
    style.fill: "#bbdefb"
    style.double-border: true
  }
  
  native_code: "Native Executable\n(RX Code Buffer)" {
    style.fill: "#c8e6c9"
    style.stroke-width: 3
  }

  interpreter -> profiler: "Instrumentation Hook" {
    style.stroke-dash: 3
  }
  
  profiler -> jit_compiler: "HOT THRESHOLD HIT (0)" {
    style.stroke: red
    style.stroke-width: 4
    style.font-color: red
    style.bold: true
  }
  
  jit_compiler -> native_code: "Binary Emission (mprotect RX)" {
    style.stroke: orange
    style.stroke-width: 2
    style.animated: true
  }
  
  native_code -> interpreter: "Deoptimization Handle" {
    label: "Guard Failure"
    style.stroke: "#777777"
    style.stroke-dash: 5
  }
}

# Documentation & Specifications
notes: {
  near: bottom-center
  style.fill: "#fffde7"
  style.stroke: "#fbc02d"
  
  explanation: |md
    ### Implementation-Grade JIT Design Specification (v2.4)
    
    1.  **Dispatch Reduction**: The primary speedup (90%+) is achieved by removing the `switch(opcode)` fetch-decode overhead. 
    2.  **Register Pinning**: In **Tier-2**, loop induction variables are mapped directly to physical registers (`RAX`, `RBX`), eliminating virtual stack `LDR/STR` operations.
    3.  **Strength Reduction**: Deterministic arithmetic (e.g., `x * 8`) is lowered to bit-shifts (`SHL x, 3`) during machine code generation.
    4.  **RX Policy**: Memory is mapped `RW` during emission and toggled to `RX` (Read-Execute) before branch execution to satisfy security primitives.
  |
}

# Top-level dependencies and flow
performance_analysis -> logic_flow: "Optimization Trigger" {
  style.stroke: "#1976d2"
  style.animated: true
}

logic_flow -> native_buffer_layout: "Memory Write" {
  style.stroke: orange
  style.stroke-width: 3
  source-arrowhead: diamond
}