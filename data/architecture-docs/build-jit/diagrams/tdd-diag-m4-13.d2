layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # JIT Hotness Distribution Analysis
    **Simulation Profile:** 100 Functions Total
    **Trigger Threshold:** 1,000 Invocations
  '|
  near: top-center
}

# --- Legend and Metadata ---
legend: {
  near: bottom-right
  note_hot: "Hot Path (JIT'd)" {
    style: {
      fill: "#ffcdd2"
      stroke: "#ca052b"
      stroke-width: 2
    }
  }
  note_cold: "Cold Path (Interpreted)" {
    style: {
      fill: "#bbdefb"
      stroke: "#01579b"
      stroke-width: 2
    }
  }
  spec: |'md
    **Memory Map:**
    - Counters: 0x4000
    - Code Cache: 0x8000
    - Interpreter: 0x1000
  '|
}

# --- Runtime Architecture ---
vm_runtime: Virtual Machine Runtime {
  style: {
    stroke-width: 4
    fill: "#fafafa"
  }

  # --- Memory Segment: Offsets ---
  offsets: {
    shape: text
    label: "0x0000\n\n\n0x1000\n\n\n0x4000\n\n\n0x8000"
    near: center-left
    style.font: mono
  }

  dispatcher: Function Dispatcher {
    shape: hexagon
    tooltip: "Entry Point: Selects between Interpreter Loop or Native Code Cache"
    style: {
      fill: "#fffde7"
      stroke: "#fbc02d"
    }
  }

  profiler: Profiling Engine {
    counters: Invocation Counters {
      shape: sql_table
      style: {
        fill: "#f5f5f5"
        stroke: "#9e9e9e"
      }
      # Corrected row definitions: key: type { constraint: label }
      f0_9: "uint32_t (4B)" {constraint: "HOT [0-9] @0x00"}
      f10_99: "uint32_t (4B)" {constraint: "COLD [10-99] @0x28"}
      
      # Style rows directly via key
      f0_9.style.fill: "#ffcdd2"
      f10_99.style.fill: "#bbdefb"
    }
    
    threshold_check: "Threshold > 1000?" {
      shape: diamond
      style.fill: "#fce4ec"
    }
  }

  interpreter: Bytecode Interpreter {
    loop: Dispatch Loop {
      style.fill-pattern: lines
      style.fill: "#e1f5fe"
    }
    perf_metrics: |'md
      **Performance Profile**
      - Avg: 50 cycles/op
      - Stack depth: 256
    '|
  }

  jit_subsystem: JIT Tier {
    compiler: Optimizing Compiler {
      passes: "ConstFold | DeadStore | Strength"
      style.fill: "#e1dbff"
    }
    code_cache: Code Cache {
      shape: cylinder
      label: "Code Cache (Native)"
      style.fill: "#d1c4e9"
      style.stroke: "#673ab7"
      style.double-border: true
    }
  }
}

# --- Call Sequences and Data Flow ---

# 1. Entry point to Dispatcher
vm_runtime.dispatcher -> vm_runtime.profiler.counters: "1. Increment Call Count"

# 2. Check if function is hot
vm_runtime.profiler.counters -> vm_runtime.profiler.threshold_check: "2. Atomic Load"

# 3. Path Selection: Cold Path
vm_runtime.profiler.threshold_check -> vm_runtime.interpreter.loop: "3a. No (Cold)" {
  style: {
    stroke: "#01579b"
    stroke-dash: 5
  }
}

# 4. Path Selection: Hot Path (Trigger JIT)
vm_runtime.profiler.threshold_check -> vm_runtime.jit_subsystem.compiler: "3b. Yes (Hot)" {
  style: {
    stroke: "#ca052b"
    stroke-width: 3
    animated: true
  }
}

# 5. Compilation to Cache
vm_runtime.jit_subsystem.compiler -> vm_runtime.jit_subsystem.code_cache: "4. Emit Machine Code"

# 6. Optimized Execution
vm_runtime.jit_subsystem.code_cache -> vm_runtime.dispatcher: "5. Update Entry Point (Patch)" {
  style: {
    stroke: "#673ab7"
    stroke-dash: 3
  }
}

# --- Structural Annotations ---
vm_runtime.interpreter.perf_metrics.near: bottom-center
vm_runtime.jit_subsystem.compiler.passes: {
  shape: text
  style.font-size: 10
}

# Explicitly style the Counter Table rows for visibility
vm_runtime.profiler.counters.f0_9.style.bold: true
vm_runtime.profiler.counters.f10_99.style.opacity: 0.8