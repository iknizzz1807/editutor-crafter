direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- CHART CONTAINER ---
Warmup_Curve: "WARMUP PERFORMANCE CURVE: CUMULATIVE EXECUTION TIME" {
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
  }

  # --- AXES ---
  Y_Axis: "Cumulative Time (ms)" {
    shape: line
    near: center-left
  }
  X_Axis: "Call Count (Invocations)" {
    shape: line
    near: bottom-center
  }

  # --- DATA POINTS ---
  # These represent coordinate vertices on the graph
  P0: "" { shape: circle; width: 0; height: 0 } # Origin
  
  # Interpreter Baseline vertices
  I_End: "Interpreter Path" {
    shape: text
    style: { font-color: "#6c757d"; italic: true }
  }

  # JIT Path vertices
  J_Start: "" { shape: circle; width: 4; height: 4; style.fill: blue }
  J_Compile_Start: "Compilation Triggered" {
    shape: circle
    width: 8; height: 8
    style.fill: red
    tooltip: "Counter hits 0 (Threshold=1000)"
  }
  J_Compile_End: "JIT Code Ready" {
    shape: circle
    width: 8; height: 8
    style.fill: green
    tooltip: "Compilation completed (approx. 5ms overhead)"
  }
  J_Steady_State: "Native Execution" {
    shape: text
    style: { font-color: "#007bff"; bold: true }
  }

  # --- TREND LINES ---
  
  # Interpreter Line: Constant slope
  P0 -> J_Start: { style.stroke: "#adb5bd"; style.stroke-dash: 3 }
  J_Start -> J_Compile_Start: { style.stroke: "#adb5bd"; style.stroke-dash: 3 }
  J_Compile_Start -> I_End: "Linear Growth (Constant Cost/Call)" {
    style.stroke: "#adb5bd"
    style.stroke-dash: 3
  }

  # JIT Line: Initial overlap, overhead spike, then shallow slope
  P0 -> J_Start: { style.stroke: "#007bff"; style.stroke-width: 3 }
  J_Start -> J_Compile_Start: "Profiling Phase" { 
    style.stroke: "#007bff"; style.stroke-width: 3 
  }
  
  # The "Steep" Compilation Spike
  J_Compile_Start -> J_Compile_End: "Compilation Overhead (T_compile)" {
    style.stroke: "#dc3545"
    style.stroke-width: 4
    style.animated: true
  }

  # The "Flat" Optimized Path
  J_Compile_End -> J_Steady_State: "Hot Path Optimization (Low Cost/Call)" {
    style.stroke: "#28a745"
    style.stroke-width: 4
  }

  # --- ANNOTATIONS ---
  Threshold_Marker: "HOT_THRESHOLD (1000)" {
    near: J_Compile_Start
    shape: text
    style.font-size: 12
  }

  Breakeven_Point: "Breakeven Point" {
    near: J_Steady_State
    shape: diamond
    style.fill: orange
    tooltip: "Point where JIT time saved > compilation cost"
  }

  # Indicators
  Annotations: {
    near: top-left
    Slope_I: "Interpreter Slope: ~100ns/call" { shape: text }
    Slope_J: "JIT Slope: ~5ns/call" { shape: text }
    Total_Savings: "Total Latency Saved" {
      shape: bracket
      direction: right
    }
  }
}

# --- LEGEND ---
Legend: {
  near: bottom-right
  Interpreter: "Interpreter Baseline" {
    style.stroke: "#adb5bd"
    style.stroke-dash: 3
  }
  JIT_Optimized: "Tiered JIT Path" {
    style.stroke: "#28a745"
    style.stroke-width: 4
  }
  Compile_Spike: "One-time Compilation Cost" {
    style.stroke: "#dc3545"
    style.stroke-width: 4
  }
}

# --- SATELLITE MAP ALIGNMENT ---
# Linking back to the Master Map IDs
Warmup_Curve.Threshold_Marker -> VM_Runtime.HOT_THRESHOLD: "Logic Reference"
Warmup_Curve.J_Compile_End -> Code_Cache.Entry: "Stores native bytes"
Warmup_Curve.J_Steady_State -> Register_Allocator.VReg: "Values in registers"