direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

statetracker_layout: {
  shape: package
  label: "StateTracker Memory Layout (ValueLocation locations[256])"

  header: {
    shape: rectangle
    style: {
      fill: "#f3e5f5"
      stroke-width: 2
    }
    label: |md
      ### StateTracker Header
      *sizeof = 32,832 bytes (aligned)*
      *location_count @ +0x2000*
    |
  }

  locations_array: {
    label: "locations[256] Array | Base Offset: +0x0000"
    
    entry_0: {
      label: "locations[0] - Active Register (32B)"
      style.stroke-dash: 0
      
      type: "0x00: type (LOC_REGISTER)" {
        style.fill: "#9575cd" # Header/Type: Purple
        style.font-color: white
      }
      union: "0x04: union { reg: REG_RAX }" {
        style.fill: "#64b5f6" # Data: Blue
      }
      gap: "0x0C: [Padding]" {
        style.fill: "#eeeeee" # Padding: Gray
      }
      bc_slot: "0x10: bytecode_slot (0)" {
        style.fill: "#64b5f6"
      }
      is_local: "0x14: is_local_var (false)" {
        style.fill: "#64b5f6"
      }
      pad_inner: "0x15: [Padding]" {
        style.fill: "#eeeeee"
      }
      l_slot: "0x18: local_slot (-1)" {
        style.fill: "#64b5f6"
      }
      pad_end: "0x1C: [Padding]" {
        style.fill: "#eeeeee"
      }

      type.width: 350
      union.width: 350
      bc_slot.width: 350
      is_local.width: 350
      l_slot.width: 350
    }

    entry_1: {
      label: "locations[1] - Deferred Constant (32B)"
      
      type: "0x20: type (LOC_CONST)" {
        style.fill: "#9575cd"
        style.font-color: white
      }
      union: "0x24: union { const_value: 42 }" {
        style.fill: "#64b5f6"
      }
      gap: "0x2C: [Padding]" {
        style.fill: "#eeeeee"
      }
      bc_slot: "0x30: bytecode_slot (1)" {
        style.fill: "#64b5f6"
      }
      is_local: "0x34: is_local_var (false)" {
        style.fill: "#64b5f6"
      }
      pad_inner: "0x35: [Padding]" {
        style.fill: "#eeeeee"
      }
      l_slot: "0x38: local_slot (-1)" {
        style.fill: "#64b5f6"
      }
      pad_end: "0x3C: [Padding]" {
        style.fill: "#eeeeee"
      }
    }

    cache_boundary: "" {
      shape: text
      label: "-------------------------- 64B Cache Line Boundary (Offset 0x40) --------------------------"
      style: {
        font-color: red
        bold: true
        stroke-dash: 2
      }
    }

    entry_2: {
      label: "locations[2] - Local Variable (Spilled) (32B)"
      
      type: "0x40: type (LOC_SPILL_SLOT)" {
        style.fill: "#9575cd"
        style.font-color: white
      }
      union: "0x44: union { spill_slot: 0 }" {
        style.fill: "#ffa726" # Pointers/Spills: Orange
      }
      gap: "0x4C: [Padding]" {
        style.fill: "#eeeeee"
      }
      bc_slot: "0x50: bytecode_slot (-1)" {
        style.fill: "#64b5f6"
      }
      is_local: "0x54: is_local_var (true)" {
        style.fill: "#64b5f6"
      }
      pad_inner: "0x55: [Padding]" {
        style.fill: "#eeeeee"
      }
      l_slot: "0x58: local_slot (0)" {
        style.fill: "#64b5f6"
      }
      pad_end: "0x5C: [Padding]" {
        style.fill: "#eeeeee"
      }
    }

    entry_3: {
      label: "locations[3] - DEAD / REUSABLE (32B)"
      
      type: "0x60: type (LOC_DEAD)" {
        style.fill: "#81c784" # Free/Green: Green
      }
      rest: "0x64 ... 0x7F: [Undefined/Free Data]" {
        style.fill: "#c8e6c9"
      }
    }
  }

  metadata: {
    label: "Control Fields | Offset: +0x2000"
    
    count: "0x2000: location_count (int32)" {
      style.fill: "#ce93d8"
    }
    depth: "0x2004: operand_stack_depth (int32)" {
      style.fill: "#ce93d8"
    }
    locals: "0x2008: local_var_count (int32)" {
      style.fill: "#ce93d8"
    }
    pc: "0x200C: current_bytecode_pc (uint32)" {
      style.fill: "#ce93d8"
    }
  }

  maps: {
    label: "Fast Lookup Tables | Offset: +0x2010"
    
    stack_map: "0x2010: stack_slot_to_location[256] (int32[256])" {
      style.fill: "#bbdefb"
    }
    local_map: "0x2410: local_slot_to_location[256] (int32[256])" {
      style.fill: "#bbdefb"
    }
  }

  header -> locations_array
  locations_array.entry_0 -> locations_array.entry_1
  locations_array.entry_1 -> locations_array.cache_boundary
  locations_array.cache_boundary -> locations_array.entry_2
  locations_array.entry_2 -> locations_array.entry_3
  locations_array.entry_3 -> metadata
  metadata -> maps
}

annotations: {
  near: top-right
  label: |md
    ### ValueLocation Anatomy (32B)
    - **Header**: Type discrimination for JIT backend.
    - **Union**: 64-bit slot for registers, constants, or spill offsets.
    - **Mapping**: Connects JIT state back to interpreter's virtual slots.
    
    **Structure Total Size**: 32,832 Bytes
    **Alignment**: 16-byte boundary
  |
  style: {
    stroke: "#9575cd"
    stroke-width: 2
    fill: "#f3e5f5"
  }
}

legend: {
  near: bottom-right
  h: Header { label: "Header/Type (Purple)"; style.fill: "#9575cd" }
  d: Data/Active { label: "Data/Active (Blue)"; style.fill: "#64b5f6" }
  s: Spill/Pointer { label: "Spill/Pointer (Orange)"; style.fill: "#ffa726" }
  f: Dead/Free { label: "Dead/Free (Green)"; style.fill: "#81c784" }
  p: Padding { label: "Padding (Gray)"; style.fill: "#eeeeee" }
}