direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# ---------------------------------------------------------------------------------------
# DEOPT ENTRY SIDE TABLE MEMORY STRUCTURE
# Purpose: Metadata used by the JIT bail-out mechanism to restore interpreter state.
# Total Size: 24 bytes (Header) + N * 24 bytes (Mappings)
# ---------------------------------------------------------------------------------------

deopt_entry_layout: {
  label: "DeoptEntry Memory Layout (sizeof=variable)"
  
  header: "Side Table Header (Fixed 24B)" {
    shape: sql_table
    style: {
      stroke: "#9673A6"
      stroke-width: 2
    }
    # Offset | Field Name | Type | Size
    "0x00": "jit_address" {
      label: "jit_address (uint8_t*)"
      constraint: "8 bytes"
      style.fill: "#FFE6CC" # Orange (Pointer)
    }
    "0x08": "bytecode_pc" {
      label: "bytecode_pc (uint32_t)"
      constraint: "4 bytes"
      style.fill: "#DAE8FC" # Blue (Data)
    }
    "0x0C": "guard_type" {
      label: "guard_type (uint8_t)"
      constraint: "1 byte"
      style.fill: "#DAE8FC" # Blue (Data)
    }
    "0x0D": "padding_1" {
      label: "padding (align 4)"
      constraint: "3 bytes"
      style.fill: "#F5F5F5" # Gray (Padding)
    }
    "0x10": "mapping_count" {
      label: "mapping_count (uint32_t)"
      constraint: "4 bytes"
      style.fill: "#DAE8FC" # Blue (Data)
    }
    "0x14": "padding_2" {
      label: "padding (align 8)"
      constraint: "4 bytes"
      style.fill: "#F5F5F5" # Gray (Padding)
    }
  }

  mapping_array: "ValueMapping mappings[] (N * 24B)" {
    style.stroke-dash: 3
    
    mapping_0: "mapping[0]" {
      shape: sql_table
      style.fill: "#DAE8FC"
      "0x18": "source_type (uint32_t)" { constraint: "4 bytes" }
      "0x1C": "target_type (uint32_t)" { constraint: "4 bytes" }
      "0x20": "source_val (uint64_t)" { constraint: "8 bytes" }
      "0x28": "target_slot (int32_t)" { constraint: "4 bytes" }
      "0x2C": "sort_order (int32_t)" { constraint: "4 bytes" }
    }
    
    mapping_n: "mapping[N-1]" {
      shape: sql_table
      style.fill: "#DAE8FC"
      "0x...": "..." { constraint: "24 bytes" }
    }
    
    mapping_0 -> mapping_n: "Sequential indexing" {
        style.stroke-dash: 5
    }
  }

  header."0x14" -> mapping_array.mapping_0."0x18": "Points to first element" {
    style: {
        stroke: "#FF8C00"
        stroke-width: 2
    }
  }
}

# ---------------------------------------------------------------------------------------
# PLACEMENT STRATEGY: HOW THE ENGINE FINDS THIS METADATA
# ---------------------------------------------------------------------------------------

placement_strategies: {
  label: "Metadata Placement Strategies"
  
  embedded: {
    label: "Strategy A: Inline (Cold Code Section)"
    code: "Native JIT Instructions" {
      style.fill: "#D5E8D4" # Green (Executable)
      style.stroke: "#82B366"
    }
    header: "Side Table Header" {
      style.fill: "#E1D5E7"
    }
    data: "Mappings Array" {
      style.fill: "#DAE8FC"
      style.multiple: true
    }
    
    code -> header: "Follows return/jmp"
    header -> data: "Adjacent"
  }

  separate: {
    label: "Strategy B: Out-of-line Table"
    
    code_ptr_map: "Native-to-Meta Hash Map" {
      shape: sql_table
      "Key: JIT PC": "Value: Meta Ptr"
      "0x7FFF1000": "0x8AAA2000"
    }
    
    side_table: "Global Deopt Store" {
      style.fill: "#DAE8FC"
      label: "Read-Only Side Tables"
    }
    
    code_ptr_map."0x7FFF1000" -> side_table: "Lookup at runtime" {
        style.stroke: "#FF8C00"
    }
  }
}

# ---------------------------------------------------------------------------------------
# ANNOTATIONS & DOCUMENTATION (FIXED COMPILER ERRORS)
# ---------------------------------------------------------------------------------------

# Memory Invariants
# ELK Engine Correction: Using constant values (top-right/bottom-center) instead of object IDs
memory_invariants: {
  near: top-right
  label: |md
    ### Memory Invariants
    - **Total size**: 24 bytes + (N * 24 bytes)
    - **Alignment**: 8-byte aligned (required for `uint8_t*`)
    - **Access**: Read-only once emitted by JIT
    - **Deoptimization Path**: 
      1. Trap native PC
      2. Lookup `bytecode_pc`
      3. Reconstruct frame using `mappings`
  |
  shape: text
  style.font: mono
}

# Visual Legend
legend: {
  near: bottom-right
  grid-columns: 2
  grid-gap: 10
  
  h_meta: "Metadata/Header" { style.fill: "#E1D5E7" }
  h_data: "Register/Stack Data" { style.fill: "#DAE8FC" }
  h_ptr: "Memory Pointer" { style.fill: "#FFE6CC" }
  h_pad: "Padding/Alignment" { style.fill: "#F5F5F5" }
  h_code: "Native Code" { style.fill: "#D5E8D4" }
}

# Cache Line Indicator (Visual aid for 64B boundaries)
cache_line: "--- Cache Line Boundary (64B) ---" {
    near: bottom-center
    shape: text
    style: {
        font-color: grey
        italic: true
    }
}