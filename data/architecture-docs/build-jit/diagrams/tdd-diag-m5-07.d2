layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

# Value Mapping Record Format - Memory Layout
# Detailed layout of the mapping between JIT machine state and Interpreter VM state

ValueMappingRecord: {
  style.fill: "#f8f9fa"
  style.stroke: "#333333"
  style.stroke-width: 2

  # Top Title
  Title: "struct ValueMapping (24 Bytes)" {
    shape: text
    style.font-size: 18
    style.bold: true
  }

  # Layout Grid
  RecordLayout: {
    grid-columns: 3
    grid-gap: 0

    # Row 0: source_type
    Offset00: "0x00" { shape: text; style.font-color: "#666666" }
    SourceType: "source_type (enum)" {
      width: 300
      style.fill: "#dae8fc" # Data: Blue
      tooltip: "0=REGISTER, 1=SPILL_SLOT, 2=CONST, 3=STACK_ARG"
    }
    Size04: "4B" { shape: text; style.font-color: "#666666" }

    # Row 1: target_type
    Offset04: "0x04" { shape: text; style.font-color: "#666666" }
    TargetType: "target_type (enum)" {
      style.fill: "#dae8fc" # Data: Blue
      tooltip: "0=OPERAND_STACK, 1=LOCAL_VAR"
    }
    Size04_2: "4B" { shape: text; style.font-color: "#666666" }

    # Row 2: union source_data
    Offset08: "0x08" { shape: text; style.font-color: "#666666" }
    SourceUnion: "union { source_reg | spill_slot | const_val }" {
      style.fill: "#dae8fc" # Data: Blue
      style.stroke-dash: 2
      tooltip: "8-byte storage for register ID, frame offset, or immediate"
    }
    Size08: "8B" { shape: text; style.font-color: "#666666" }

    # Row 3: target_slot
    Offset10: "0x10" { shape: text; style.font-color: "#666666" }
    TargetSlot: "target_slot (int32)" {
      style.fill: "#dae8fc" # Data: Blue
      tooltip: "Interpreter slot index"
    }
    Size04_3: "4B" { shape: text; style.font-color: "#666666" }

    # Row 4: sort_order
    Offset14: "0x14" { shape: text; style.font-color: "#666666" }
    SortOrder: "sort_order (int32)" {
      style.fill: "#dae8fc" # Data: Blue
      tooltip: "Correct push sequence for operand stack (ascending)"
    }
    Size04_4: "4B" { shape: text; style.font-color: "#666666" }
  }

  # Styling for logical groups
  RecordLayout.SourceType.style.stroke: "#0000FF"
  RecordLayout.TargetType.style.stroke: "#0000FF"
  RecordLayout.SourceUnion.style.stroke: "#0000FF"
  RecordLayout.TargetSlot.style.stroke: "#0000FF"
  RecordLayout.SortOrder.style.stroke: "#0000FF"
}

# Detail Metadata - Moved to root level to fix constant near error
Annotation: |md
  ### Bit Fields & Logic
  - **source_type**: Discriminant for reading JIT state.
  - **target_type**: Target area in reconstructed `InterpFrame`.
  - **source_reg**: If *REGISTER*, maps to index in `SavedRegisters` struct.
  - **source_spill_slot**: If *SPILL*, maps to `rbp - (slot+1)*8`.
  - **sort_order**: Ensures operand stack is rebuilt from bottom to top.
| {
  near: bottom-center
}

# Mapping Diagram Visualizing the Flow
MappingFlow: {
  near: center-right # Fixed: changed from 'right' to valid constant 'center-right'
  
  JIT_State: "JIT Machine State" {
    Regs: "Registers (rax..r15)" { style.fill: "#ffe6cc" } # Orange: Pointers/Refs
    Spills: "Stack Frame (rbp - offset)" { style.fill: "#dae8fc" }
  }

  Interp_State: "Interpreter VM State" {
    OpStack: "Operand Stack" { style.fill: "#dae8fc" }
    Locals: "Local Variables" { style.fill: "#dae8fc" }
  }

  JIT_State.Regs -> Interp_State.OpStack: "ValueMapping {REGISTER → STACK_SLOT}" {
    style.stroke: "#ff9900"
    style.animated: true
  }
  
  JIT_State.Spills -> Interp_State.Locals: "ValueMapping {SPILL → LOCAL_VAR}" {
    style.stroke: "#3366ff"
    style.stroke-dash: 3
  }
}

# Legend
Legend: {
  near: bottom-left
  Header: "Header/Meta" { style.fill: "#e1d5e7" }
  Data: "Data Fields" { style.fill: "#dae8fc" }
  Registers: "Registers/Refs" { style.fill: "#ffe6cc" }
}