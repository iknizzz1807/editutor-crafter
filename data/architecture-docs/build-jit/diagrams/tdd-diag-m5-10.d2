direction: right
layout-engine: elk
theme-id: 4

# JIT State to Interpreter State Mapping
# Bytecode Context: LOAD_LOCAL 0; PUSH 100; ADD; RET (Guard failure after ADD)

jit_machine_state: {
  label: "JIT Machine State (Hardware Context)"
  
  registers: {
    shape: sql_table
    label: "SavedRegisters Struct (at 0x7fffffffd000)"
    0x00: "rax = 142" {style.fill: "#3498db"}
    0x08: "rbx = 0x... (clobbered)" {style.fill: "#95a5a6"}
    0x10: "rcx = 0x... (clobbered)" {style.fill: "#95a5a6"}
    0x28: "rdi = 0x... (arg0)" {style.fill: "#e67e22"}
    0x48: "r12 = 42" {style.fill: "#3498db"}
    0x60: "r15 = 0x..."
  }

  stack_frame: {
    shape: sql_table
    label: "Native Stack Frame (RBP-relative)"
    "rbp + 08": "Return Address (Caller)" {style.fill: "#9b59b6"}
    "rbp + 00": "Saved RBP" {style.fill: "#9b59b6"}
    "rbp - 08": "Saved R12 (callee-saved)" {style.fill: "#e67e22"}
    "rbp - 16": "Spill Slot 0: Value (42)" {style.fill: "#3498db"}
    "rbp - 24": "Padding (16B alignment)" {style.fill: "#bdc3c7"}
  }
}

deopt_metadata: {
  label: "DeoptEntry Side Table"
  style.fill: "#f1c40f"
  
  info: |md
    ### Metadata for Guard ID #4
    - **PC:** 0x000A (Instruction: MUL)
    - **Stack Depth:** 2
    - **Local Count:** 1
  |
  
  mapping_table: {
    shape: sql_table
    "Mapping Index": "Source Type | Target Type | Target Slot | Order"
    "0": "REG_RAX | OP_STACK | 1 | 1"
    "1": "CONST 100 | OP_STACK | 0 | 0"
    "2": "SPILL -16 | LOCAL_VAR | 0 | 0"
  }
}

interpreter_vm_state: {
  label: "Interpreter VM State (Abstract Context)"
  
  interp_frame: {
    shape: sql_table
    label: "InterpFrame Struct (Reconstructed)"
    0x00: "bytecode*" {style.fill: "#9b59b6"}
    0x08: "pc = bytecode + 10" {style.fill: "#9b59b6"}
    0x10: "operand_stack_top = 2" {style.fill: "#2ecc71"}
    0x18: "local_count = 1" {style.fill: "#2ecc71"}
  }

  operand_stack: {
    shape: sql_table
    label: "Operand Stack Array"
    "slot[1] (top)": "142 (result)" {style.fill: "#3498db"}
    "slot[0] (base)": "100 (folded const)" {style.fill: "#3498db"}
  }

  locals: {
    shape: sql_table
    label: "Local Variables Array"
    "local[0]": "42" {style.fill: "#3498db"}
    "local[1]": "0 (unused)"
  }
}

# Mapping Logic Connections
jit_machine_state.registers.0x00 -> interpreter_vm_state.operand_stack."slot[1] (top)": "Deopt Mapping [0]: RAX -> Stack[1]" {
  style: {
    stroke: "#e67e22"
    stroke-width: 3
    animated: true
  }
}

jit_machine_state.stack_frame."rbp - 16" -> interpreter_vm_state.locals."local[0]": "Deopt Mapping [2]: [rbp-16] -> Local[0]" {
  style: {
    stroke: "#e67e22"
    stroke-width: 3
    animated: true
  }
}

deopt_metadata.mapping_table."1" -> interpreter_vm_state.operand_stack."slot[0] (base)": "Deopt Mapping [1]: Constant 100 -> Stack[0]" {
  style: {
    stroke: "#e67e22"
    stroke-width: 3
    stroke-dash: 5
  }
}

annotations: {
  near: top-center
  msg: |md
    ## VM State Reconstruction Process
    1. **Stub Triggers:** Guard fails, CPU jumps to generated stub.
    2. **Register Snapshot:** Stub pushes all registers to `SavedRegisters` struct.
    3. **Metadata Lookup:** C logic uses faulting RIP to find `DeoptEntry`.
    4. **Frame Allocation:** `malloc(sizeof(InterpFrame))`.
    5. **Mapping Loop:** 
       - Values pulled from `registers` array or `rbp` offsets.
       - Intermediate results sorted by `sort_order`.
       - Values pushed into `operand_stack` array.
    6. **Resume:** Interpreter loop starts at `pc = bytecode + deopt_entry->pc`.
  |
}

legend: {
  near: bottom-center
  header: "Purple" { style.fill: "#9b59b6" }
  data: "Blue" { style.fill: "#3498db" }
  pointers: "Orange" { style.fill: "#e67e22" }
  state: "Green" { style.fill: "#2ecc71" }
}