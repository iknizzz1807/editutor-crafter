direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 25
  }
}

# -----------------------------------------------------------------------------------------
# OPERAND STACK RECONSTRUCTION ALGORITHM - Intel Manual Quality Spec
# -----------------------------------------------------------------------------------------

m5_reconstruct_order: {
  label: "DEOPTIMIZATION PIPELINE: OPERAND STACK RECONSTRUCTION (MILESTONE 5)"

  # Step 1: Initial State
  step_1: "STEP 1: GATHER UNSORTED METADATA" {
    shape: package
    style.fill: "#F8F8F8"
    
    metadata_table: {
      label: "JIT Deopt Metadata (Heap Memory)"
      grid-rows: 4
      header: "Offset | ID | Target Slot | Source Reg/Disp | Size" { 
        style.fill: "#E1D5E7"
        style.bold: true 
      }
      row0: "0x00 | A  | Slot 1      | rax             | 8B" { style.fill: "#F0F0F0" }
      row1: "0x08 | B  | Slot 2      | [rbp-0x08]      | 8B" { style.fill: "#F0F0F0" }
      row2: "0x10 | C  | Slot 0      | rbx             | 8B" { style.fill: "#F0F0F0" }
    }
    
    initial_stack: {
      label: "Target Interpreter Stack (Uninitialized)"
      grid-rows: 3
      s2: "[+0x10] [ Empty / Garbage ]" { style.stroke-dash: 3; style.stroke: gray }
      s1: "[+0x08] [ Empty / Garbage ]" { style.stroke-dash: 3; style.stroke: gray }
      s0: "[+0x00] [ Empty / Garbage ]" { style.stroke-dash: 3; style.stroke: gray }
    }
    
    note: |md
      ### Entry State
      - **Instruction**: `0x2A` (Guard Fail)
      - **Context**: `RegisterDump` populated via signal handler or trampoline.
    |
  }

  # Step 2: Sorting Logic
  step_2: "STEP 2: DESCENDING SLOT SORT" {
    shape: package
    style.fill: "#F8F8F8"
    
    sorting_buffer: {
      label: "Ordered Materialization List (LIFO Priority)"
      grid-rows: 3
      high: "[0] **Mapping B: Slot 2**" { 
        style: { fill: "#D5E8D4"; stroke: "#FF0000"; stroke-width: 3; bold: true } 
      }
      mid:  "[1] **Mapping A: Slot 1**" { 
        style: { fill: "#D5E8D4"; stroke: "#FF0000"; stroke-width: 3; bold: true } 
      }
      low:  "[2] **Mapping C: Slot 0**" { 
        style: { fill: "#D5E8D4"; stroke: "#FF0000"; stroke-width: 3; bold: true } 
      }
    }
    
    algorithm_spec: |md
      cpp
      // Invariant: Process High -> Low to maintain 
      // strict sequential write order.
      std::sort(metadata.begin(), metadata.end(), 
        [](auto& a, auto& b) { 
          return a.slot_index > b.slot_index; 
        });
      
    | { style.font: mono }
  }

  # Step 3: Reconstruction Processing
  step_3: "STEP 3: SEQUENTIAL MATERIALIZATION" {
    shape: package
    style.fill: "#F8F8F8"
    
    execution_unit: {
      label: "Write-Combining Engine"
      source_reg: "rbx (Mapping C)" { 
        shape: cylinder
        style.fill: "#FFF2CC"
      }
      sp_ptr: "vSP (Pointer)" { 
        shape: parallelogram
        style.fill: "#FF8C00"
        style.font-color: white
      }
      
      source_reg -> sp_ptr: "MOV [vSP], rbx" {
        style.stroke: "#FF8C00"
        style.animated: true
        style.stroke-width: 3
      }
    }
    
    active_stack: {
      label: "Memory Commit State (Slot 0)"
      grid-rows: 3
      s2: "[+0x10] [ Pending... ]" { style.stroke-dash: 3 }
      s1: "[+0x08] [ Pending... ]" { style.stroke-dash: 3 }
      s0: "[+0x00] **0xDEADC0DE** (rbx)" { 
        style: { fill: "#DAE8FC"; stroke: "#0000FF"; stroke-width: 4; bold: true } 
      }
    }
    
    execution_unit.sp_ptr -> active_stack.s0: "COMMIT: 8 Bytes" {
      style: { stroke: "#FF0000"; stroke-width: 2; animated: true }
    }
  }

  # Step 4: Final VM State
  step_4: "STEP 4: RECONSTRUCTION COMPLETE" {
    shape: package
    style.fill: "#F8F8F8"
    
    final_stack: {
      label: "Reconstructed Operand Stack (Ready)"
      grid-rows: 3
      s2: "[+0x10] **Value B** ([rbp-8])" { style.fill: "#DAE8FC"; style.bold: true }
      s1: "[+0x08] **Value A** (rax)" { style.fill: "#DAE8FC"; style.bold: true }
      s0: "[+0x00] **Value C** (rbx)" { style.fill: "#DAE8FC"; style.bold: true }
    }
    
    vm_context: {
      shape: sql_table
      style.fill: "#E1D5E7"
      "PC (Program Counter)": "0x0000002A"
      "vSP (Stack Pointer)": "BaseAddr + 0x18"
      "Frame Type": "INTERP_FRAME"
      "ABI Alignment": "16-Byte Boundaries OK"
    }
    
    check: |md
      **Post-Check**:
      1. All descriptors consumed.
      2. Stack pointer correctly points to top of Slot 2.
      3. Control flow ready to resume at Interpreter Loop.
    |
  }

  # Flow Sequence
  step_1 -> step_2: "Deopt Trigger" {
    style.stroke: "#FF8C00"
    style.stroke-width: 5
  }
  step_2 -> step_3: "Processing Order Defined" {
    style.stroke: "#FF8C00"
    style.stroke-width: 5
  }
  step_3 -> step_4: "Finalization" {
    style.stroke: "#FF8C00"
    style.stroke-width: 5
  }
}

# -----------------------------------------------------------------------------------------
# GLOBAL DOCUMENTATION & LEGEND
# -----------------------------------------------------------------------------------------

doc: |md
  ## Implementation Architecture: Operand Stack Reconstruction
  This diagram specifies the logic for transforming JIT-compiled stack frames back into 
  interpreter-compatible operand stacks during a **deoptimization** event.
  
  ### Critical Invariants:
  - **Memory Direction**: Offset `0x00` represents the base of the operand stack.
  - **Ordering**: Descending sort ensures that we never write to an address that 
    hasn't been properly calculated, preventing stack smashing during in-place transitions.
  - **Alignment**: The resulting `vSP` must be aligned to 16 bytes for System V AMD64 ABI 
    compatibility if the interpreter calls external C functions.
| {
  near: top-left
}

legend: {
  near: bottom-right
  metadata: "Deopt Metadata Table (Purple)" { style.fill: "#E1D5E7" }
  memory: "Interpreter Stack Segment (Blue)" { style.fill: "#DAE8FC" }
  sort: "Sorting / Active State (Green)" { style.fill: "#D5E8D4"; style.stroke: "#FF0000" }
  registers: "Register Values (Yellow)" { style.fill: "#FFF2CC" }
  pointers: "Stack/Memory Pointers (Orange)" { style.fill: "#FF8C00"; style.font-color: white }
}

# Global Globals for Component Standardization
m5_reconstruct_order.step_*: {
  style: {
    stroke-width: 2
    border-radius: 4
    shadow: true
  }
}