direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- CUSTOM CLASSES & GLOBAL STYLES ---
classes: {
  memory_segment: {
    style: {
      stroke-width: 2
      border-radius: 4
      shadow: true
    }
  }
  pipeline_step: {
    style: {
      stroke-dash: 0
      stroke-width: 1
    }
  }
}

# --- STAGE 1: FRONTEND / BYTECODE LAYOUT ---
# Memory layout with exact byte offsets and alignment
Bytecode_Source: {
  label: "Instruction Stream\nBase: 0x0000 | Page: 4KB"
  shape: sql_table
  class: memory_segment
  style.fill: "#E1D5E7" # Purple Header
  
  "Offset": "Opcode" | "Size" | "Implementation Detail"
  "0x00": "0x15 (LOAD_ARG)" | "2B" | "Push Arg[0] to VM Stack"
  "0x02": "0x15 (LOAD_ARG)" | "2B" | "Push Arg[1] to VM Stack"
  "0x04": "0x60 (IADD)"     | "1B" | "Integer Add (TOS1 + TOS)"
  "0x05": "0xB1 (IRET)"     | "1B" | "Pop and Return Control"
  "0x06": "0x00 (PADDING)"  | "10B"| "Alignment to 16B Boundary" {
    style.fill: "#F5F5F5"
  }
  
  footer: "Total Segment Size: 16 Bytes | PROT_READ" {
    style.font-size: 10
    style.italic: true
  }
}

# --- STAGE 2: TIER 0 EXECUTION (INTERPRETER) ---
Interpreter: {
  label: "Tier 0: C++ Interpreter Dispatch"
  style.fill: "#FFF2CC"
  
  Loop: "Fetch-Decode-Execute\n(Computed Goto)" {
    shape: hexagon
    style.stroke-width: 3
    style.fill: "#FFE599"
  }
  
  Profiler: "MSR patterns / Hotness Monitor" {
    shape: rectangle
    tooltip: "Branch-and-Link Counter Implementation"
    style.stroke-dash: 3
    
    struct: {
      shape: class
      invocations: "uint32_t (0x0 - 0x08)"
      threshold: "const 1000"
      "check_hot(pc_t)": "bool"
    }
  }
}

# --- STAGE 3: JIT COMPILATION PIPELINE ---
JIT_Compiler: {
  label: "Tier 1: x86_64 Optimizing Compiler"
  style.fill: "#DAE8FC" # Blue Data

  Optimizer: "Pass 1: Mid-Level IR (SSA)" {
    shape: package
    style.fill: "#B9D3EE"
    Inlining: "Heuristic-based"
    Const_Fold: "1+2 -> 3"
    DCE: "Dead Code Elim"
  }

  Translator: "Pass 2: LIR & RegAlloc" {
    shape: package
    style.fill: "#B9D3EE"
    Virtual_Regs: "V0, V1, V2"
    Linear_Scan: "Spill to RBP-0x10"
    Emitter: "Machine Code Gen"
  }

  Guard_Injector: "Pass 3: Safety Checks" {
    shape: package
    style.fill: "#B9D3EE"
    Type_Guard: "IsInt(RAX)"
    Range_Guard: "Idx < Len"
    Overflow: "JO deopt_stub"
  }
  
  Side_Table_Gen: "Pass 4: Metadata Emission" {
    shape: rectangle
    tooltip: "Serialize Native-to-Virtual Map"
    Mapping: "Native_PC -> VM_State"
  }
}

# --- STAGE 4: EXECUTABLE MEMORY (CODE CACHE) ---
Code_Cache: {
  label: "Tier 1 Code Cache (RW -> RX)"
  style.fill: "#D5E8D4" # Green Free/Ready
  style.stroke-width: 4
  
  Function_Entry: |'md
    ### Native x86_64 (Offset: 0x1000)
    nasm
    ; --- Prologue ---
    0x1000: push rbp
    0x1001: mov rbp, rsp
    
    ; --- Speculative Guard ---
    0x1004: test rdi, 0x1      ; Bit 0 check
    0x1008: jnz deopt_entry    ; JIT Exit
    
    ; --- Optimized Fast-Path ---
    0x100A: add rdi, rsi       ; Native add
    
    ; --- Epilogue ---
    0x100D: pop rbp
    0x100E: ret
    
  '| {
    shape: rectangle
    style.stroke: "#2D7600"
  }
  
  Metadata: "Stack-Map / Deopt-Table" {
    shape: sql_table
    style.fill: "#F5F5F5"
    "PC Offset" | "VM Map" | "Action"
    "0x1004" | "RDI=Arg0" | "Sync VM Stack[0]"
    "0x100A" | "RAX=Sum"  | "Update VM PC"
  }
}

# --- STAGE 5: RUNTIME EXECUTION & FAULT HANDLING ---
Runtime_Execution: "CPU Pipeline (ALU/FPU)" {
  shape: diamond
  style.fill: "#F8CECC" # Red Error/Fault
  tooltip: "Hardware Execution Stage"
}

Deoptimizer: {
  label: "Recovery Subsystem"
  style.stroke: "#B85450"
  style.fill: "#F8CECC"
  
  Reg_Save: "Context Capture" { 
    shape: rectangle 
    style.fill: "#FFCCCC"
    label: "Save [RAX..R15]"
  }
  
  Reconstructor: "Frame Rebuilder" {
    shape: rectangle
    tooltip: "Map Physical Regs back to VM Stack Slots"
    logic: "RAX -> VM_Stack[TOS]"
  }
}

# --- CONNECTIONS (DATA FLOW & SEQUENCING) ---

Bytecode_Source -> Interpreter.Loop: "1. Dispatch" {
  style.stroke: "#666666"
}

Interpreter.Loop -> Interpreter.Profiler: "2. Profile Call"
Interpreter.Profiler -> JIT_Compiler: "3. Hot Spot Trigger" {
  style.stroke: "#FF9900" # Orange
  style.stroke-width: 4
  style.animated: true
}

JIT_Compiler.Optimizer -> JIT_Compiler.Translator: "IR Stream"
JIT_Compiler.Translator -> JIT_Compiler.Guard_Injector: "LIR Nodes"
JIT_Compiler.Guard_Injector -> JIT_Compiler.Side_Table_Gen: "Metadata"

JIT_Compiler.Translator -> Code_Cache.Function_Entry: "4. mprotect(PROT_WRITE)" {
  style.stroke-dash: 2
}
JIT_Compiler.Side_Table_Gen -> Code_Cache.Metadata: "5. Serialized Map"

Code_Cache.Function_Entry -> Runtime_Execution: "6. EXECUTE" {
  style.stroke: "#2D7600" # Dark Green
  style.stroke-width: 3
}

Runtime_Execution -> Deoptimizer.Reg_Save: "7. GUARD_FAIL" {
  label: "Trap to Deopt"
  style.stroke: "#B85450"
  style.font-color: "#B85450"
  style.stroke-width: 3
  style.animated: true
}

Deoptimizer.Reg_Save -> Deoptimizer.Reconstructor
Code_Cache.Metadata -> Deoptimizer.Reconstructor: "8. Metadata Lookup" {
  style.stroke: "#FF9900"
  style.stroke-dash: 5
}

Deoptimizer.Reconstructor -> Interpreter.Loop: "9. Resume (Tier 0)" {
  style.stroke: "#004C99"
  style.stroke-width: 2
  style.animated: true
}

# --- DOCUMENTATION ANNOTATIONS (FIXED STRING) ---
Annotation: |'md
### JIT Design & Memory Specification

**Memory Safety (W^X):**
The pipeline ensures memory pages are never both Writable and Executable.
1. `mmap(PROT_READ | PROT_WRITE)` during emission.
2. `mprotect(PROT_READ | PROT_EXEC)` before handover.

**Deoptimization Strategy:**
- **OSR (On-Stack Replacement):** Not shown, but supported via Reconstructor.
- **Safepoints:** Metadata table provides the mapping for all async-safe points.
- **Type Speculation:** Tier 1 relies on Tier 0 type-feedback. Guard failures are handled via trap-and-recover.
'| {
  near: bottom-right
  style.font-size: 11
  style.fill: "#FFFFE0"
  style.stroke: "#D4D4D4"
}

# Engineering Legend
Legend: {
  near: top-right
  Header: "Memory Metadata" { style.fill: "#E1D5E7" }
  Data: "Compiler Logic" { style.fill: "#DAE8FC" }
  Fault: "Error Handling" { style.fill: "#F8CECC" }
  Native: "Binary Cache" { style.fill: "#D5E8D4" }
}