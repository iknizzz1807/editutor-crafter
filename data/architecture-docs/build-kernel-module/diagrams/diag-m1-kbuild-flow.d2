direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  sources: "Source Files (your directory)" {
    direction: down
    style.fill: "#e8f4f8"
    style.stroke: "#2196F3"
    style.border-radius: 6

    c_file: {
      shape: document
      label: "hello.c"
      style.fill: "#ffffff"
      style.stroke: "#1565C0"
    }
    makefile: {
      shape: document
      label: "Makefile"
      style.fill: "#ffffff"
      style.stroke: "#1565C0"
    }
    makefile_content: {
      shape: sql_table
      label: "Makefile (out-of-tree)"
      obj_m: "obj-m += hello.o"
      kdir: 'KDIR := /lib/modules/$(uname -r)/build'
      pwd: 'PWD  := $(shell pwd)'
      all: 'all: $(MAKE) -C $(KDIR) M=$(PWD) modules'
      clean: 'clean: $(MAKE) -C $(KDIR) M=$(PWD) clean'
    }
  }

  kernel_headers: "Kernel Headers (installed)" {
    direction: down
    style.fill: "#f3e5f5"
    style.stroke: "#7B1FA2"
    style.border-radius: 6

    kbuild_dir: {
      shape: cylinder
      label: "/lib/modules/6.8.0/build"
      style.fill: "#ffffff"
      style.stroke: "#6A1B9A"
    }
    includes: {
      shape: sql_table
      label: "Kernel Include Paths"
      inc1: "include/linux/*.h   (core API)"
      inc2: "include/asm/*.h     (arch-specific)"
      inc3: "include/uapi/*.h    (user-facing ABI)"
      inc4: "arch/x86/include/*  (x86 specifics)"
      note: "NO libc / NO stdlib / NO stdio"
    }
    vermagic: {
      shape: sql_table
      label: "Version Constraints"
      v1: "vermagic: 6.8.0-45-generic SMP"
      v2: "CONFIG_*: kernel config flags"
      v3: "Module must match exactly"
    }
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  make_invocation: "Step 1: make Invocation" {
    direction: down
    style.fill: "#fff8e1"
    style.stroke: "#F9A825"
    style.border-radius: 6

    make_cmd: {
      shape: hexagon
      label: '$ make'
      style.fill: "#FFF9C4"
      style.stroke: "#F57F17"
    }
    make_detail: {
      shape: sql_table
      label: "make delegates to Kbuild"
      d1: '$(MAKE) -C /lib/modules/.../build'
      d2: 'M=$(PWD) modules'
      d3: "-C: change to kernel build dir"
      d4: "M=: come back to build your src"
    }
  }

  kbuild_engine: "Step 2: Kbuild Engine" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#2E7D32"
    style.border-radius: 6

    kbuild_reads: {
      shape: sql_table
      label: "Kbuild reads obj-m directive"
      k1: "obj-m += hello.o   → build as module"
      k2: "obj-y  += foo.o    → built-in (not here)"
      k3: "Resolves: hello.o ← hello.c"
    }
    cflags: {
      shape: sql_table
      label: "Kernel CFLAGS Applied"
      f1: "-nostdinc          (no C stdlib headers)"
      f2: "-isystem gcc-includes"
      f3: '-I$(KDIR)/include  (kernel headers)'
      f4: "-D__KERNEL__       (kernel context)"
      f5: "-DMODULE           (loadable module)"
      f6: "-fno-common        (no common symbols)"
      f7: "-O2 -Wall -Werror  (strict compile)"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  compile_step: "Step 3: CC — Compile to Object" {
    direction: down
    style.fill: "#e3f2fd"
    style.stroke: "#1565C0"
    style.border-radius: 6

    cc_cmd: {
      shape: hexagon
      label: "CC [M] hello.o"
      style.fill: "#BBDEFB"
      style.stroke: "#0D47A1"
    }
    obj_file: {
      shape: sql_table
      label: "hello.o (ELF relocatable)"
      o1: ".text     — compiled code"
      o2: ".init.text — __init functions"
      o3: ".exit.text — __exit functions"
      o4: ".data     — initialized globals"
      o5: ".bss      — zero-init globals"
      o6: "UNDEF syms: printk, module_param..."
    }
  }

  modpost_step: "Step 4: MODPOST — Module Post-Processing" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#C62828"
    style.border-radius: 6

    modpost_cmd: {
      shape: hexagon
      label: "MODPOST hello.ko"
      style.fill: "#FFCDD2"
      style.stroke: "#B71C1C"
    }
    modpost_detail: {
      shape: sql_table
      label: "modpost generates hello.mod.c"
      mp1: "Checks GPL symbol usage"
      mp2: "Detects non-GPL symbol violations"
      mp3: "Embeds module metadata struct"
      mp4: "Generates CRC for each symbol"
    }
    mod_c: {
      shape: sql_table
      label: "hello.mod.c (generated)"
      mc1: "MODULE_INFO(vermagic, ...);"
      mc2: 'MODULE_INFO(name, "hello");'
      mc3: "struct module __this_module = {"
      mc4: '  .name = "hello",'
      mc5: "  .init = hello_init,"
      mc6: "  .exit = hello_exit,"
      mc7: "};"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  link_step: "Step 5: LD — Link into .ko" {
    direction: down
    style.fill: "#e0f2f1"
    style.stroke: "#00695C"
    style.border-radius: 6

    ld_cmd: {
      shape: hexagon
      label: "LD [M] hello.ko"
      style.fill: "#B2DFDB"
      style.stroke: "#004D40"
    }
    ld_inputs: {
      shape: sql_table
      label: "Linker Inputs"
      li1: "hello.o        (your compiled code)"
      li2: "hello.mod.o    (compiled .mod.c)"
    }
  }

  ko_output: "Output: hello.ko (ELF .ko file)" {
    direction: down
    style.fill: "#f9fbe7"
    style.stroke: "#558B2F"
    style.border-radius: 6
    style.shadow: true

    ko_sections: {
      shape: sql_table
      label: "hello.ko ELF Sections"
      s0: "=== CODE SECTIONS ==="
      s1: ".text         — module functions"
      s2: ".init.text    — __init code (freed after load)"
      s3: ".exit.text    — __exit code"
      s4: "=== DATA SECTIONS ==="
      s5: ".data         — mutable globals"
      s6: ".bss          — zero-initialized globals"
      s7: ".rodata       — const strings, fops tables"
      s8: "=== MODULE METADATA ==="
      s9: ".modinfo      — license, author, version"
      s10: "__versions    — symbol CRCs for verification"
      s11: ".gnu.linkonce — vermagic string"
    }
    vermagic_embed: {
      shape: sql_table
      label: "Embedded vermagic (must match uname -r)"
      vm1: "6.8.0-45-generic SMP preempt"
      vm2: "mod_unload modversions"
      vm3: "Checked by kernel at insmod time"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  no_libc: "KEY DIFFERENCE from Normal Compilation" {
    direction: down
    style.fill: "#ffebee"
    style.stroke: "#c62828"
    style.border-radius: 6

    diff_table: {
      shape: sql_table
      label: "Normal gcc vs Kbuild"
      h: "FEATURE         | USERSPACE gcc   | KBUILD"
      d1: "stdlib headers  | /usr/include/   | FORBIDDEN"
      d2: "libc linkage    | -lc (implicit)  | NONE"
      d3: "printf()        | stdlib          | FORBIDDEN"
      d4: "malloc()        | stdlib          | FORBIDDEN"
      d5: "Logging         | printf/fprintf  | printk()"
      d6: "Allocation      | malloc/free     | kmalloc/kfree"
      d7: "Entry point     | main()          | module_init()"
      d8: "Symbol resolv   | ld.so at exec   | kernel at insmod"
      d9: "Error on crash  | process dies    | KERNEL PANICS"
    }
  }

  insmod_load: "Final: insmod Loads .ko into Kernel" {
    direction: down
    style.fill: "#ede7f6"
    style.stroke: "#4527A0"
    style.border-radius: 6

    load_steps: {
      shape: sql_table
      label: "insmod / finit_module() syscall"
      ls1: "1. Read .ko ELF into userspace"
      ls2: "2. finit_module() syscall → ring 3→0"
      ls3: "3. Kernel checks vermagic string"
      ls4: "4. vmalloc() .text/.data in kernel VAS"
      ls5: "5. Resolve UNDEFs: printk → kernel addr"
      ls6: "6. Mark .text RO+X, .data RW+NX"
      ls7: "7. Call __init function (hello_init)"
      ls8: "8. Free .init.text pages (RAM reclaim)"
      ls9: "9. Module live — lsmod shows it"
    }
  }
}

row0.sources -> row1.make_invocation: '$ make'
row0.kernel_headers -> row1.kbuild_engine: "headers + config"
row1.make_invocation -> row1.kbuild_engine: "delegates"
row1.kbuild_engine -> row2.compile_step: "gcc + kernel CFLAGS"
row2.compile_step -> row2.modpost_step: "hello.o"
row2.modpost_step -> row3.link_step: "hello.o + hello.mod.o"
row3.link_step -> row3.ko_output: "links into"
row3.ko_output -> row4.insmod_load: "hello.ko | insmod"

row0.sources -> row4.no_libc: "contrast" {
  style.stroke-dash: 4
  style.stroke: "#c62828"
}