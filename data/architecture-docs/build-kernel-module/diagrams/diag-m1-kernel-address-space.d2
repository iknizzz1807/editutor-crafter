direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_block: {
  near: top-center
  content: |md
    # x86-64 Virtual Address Space Layout
    **Kernel vs Userspace — 128 TB each half**
  |
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  userspace_col: "USERSPACE (Lower Canonical Half)" {
    direction: down
    style.stroke: "#1a472a"
    style.stroke-width: 2
    style.fill: "#f1f8f4"

    us_start: {
      shape: sql_table
      label: "0x0000000000000000"
      f1: "0x0000 – 0x0FFF | null guard page (unmapped)"
    }

    us_code: {
      shape: sql_table
      label: "Process Image (.text / .data / .bss)"
      addr: "0x0000400000000000 | ELF load base"
      seg1: "Permissions        | r-x (.text)"
      seg2: "Permissions        | rw- (.data / .bss)"
      style.fill: "#d4edda"
    }

    us_heap: {
      shape: sql_table
      label: "Process Heap"
      grows: "↑ grows upward     | brk / mmap anonymous"
      note:  "Allocation         | malloc/libc managed"
      style.fill: "#d4edda"
    }

    us_mmap: {
      shape: sql_table
      label: "Process mmap / Shared Libs"
      addr: "0x00007f...        | ld.so, libc.so, etc."
      type: "Mapping            | file-backed pages"
      style.fill: "#d4edda"
    }

    us_stack: {
      shape: sql_table
      label: "Process Stack"
      addr: "0x00007ffd12340000 | EXAMPLE userspace ptr"
      grows: "↓ grows downward   | 8 MB default limit"
      style.fill: "#d4edda"
    }

    us_ptr_warning: {
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
      style.stroke-width: 2
      label: "Pointer Constraint"
      info: |md
        **0x00007ffd12340000**
        - VALID in userspace
        - INVALID from kernel (SMAP fault)
        - Must use `copy_from_user()`
      |
    }

    us_end: {
      shape: sql_table
      label: "0x00007fffffffffff"
      last: "Top of user range  | 128 TB userspace"
    }
  }

  gap_col: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    canonical_hole: {
      style.fill: "#212529"
      style.font-color: "#ffc107"
      style.stroke: "#ffc107"
      style.stroke-width: 2
      label: "CANONICAL HOLE"
      content: |md
        **0x0000800000000000**
        to
        **0xffff7fffffffffff**

        ~16 EB unmapped
        CPU rejects non-canonical
        addresses with #GP fault
      |
      width: 280
    }
  }

  kernel_col: "KERNEL SPACE (Upper Canonical Half)" {
    direction: down
    style.stroke: "#1a237e"
    style.stroke-width: 2
    style.fill: "#f0f2ff"

    k_start: {
      shape: sql_table
      label: "0xffff800000000000"
      first: "Kernel Base        | mapped in ALL processes"
    }

    k_directmap: {
      shape: sql_table
      label: "Direct Physical Map"
      addr: "0xffff888000000000  | all physical RAM"
      map:  "Translation        | virt = phys + offset"
      type: "Allocation         | kmalloc memory"
      style.fill: "#cfe2ff"
    }

    k_vmalloc: {
      shape: sql_table
      label: "vmalloc / ioremap Area"
      addr: "0xffffc90000000000  | non-contiguous allocs"
      note: "Usage              | I/O remapping"
      style.fill: "#cfe2ff"
    }

    k_modules: {
      shape: sql_table
      label: "MODULE MAPPING AREA"
      addr: "0xffffffffa0000000  | .ko text base"
      size: "~1.5 GB window      | LKM residency"
      note: "Resolving          | Symbols patched at load"
      style.fill: "#fff3cd"
      style.stroke: "#fd7e14"
      style.stroke-width: 3
    }

    k_text: {
      shape: sql_table
      label: "Kernel Image (.text / .data)"
      addr: "0xffffffff81000000  | vmlinuz mapped here"
      sym:  "Symbols            | printk, copy_from_user"
      style.fill: "#cfe2ff"
    }

    k_fixmap: {
      shape: sql_table
      label: "Fixmap / CPU Data"
      addr: "0xffffffffff600000  | vsyscall / per-CPU"
      style.fill: "#cfe2ff"
    }

    k_end: {
      shape: sql_table
      label: "0xffffffffffffffff"
      last: "Top of address space| Canonical end"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  copy_mechanics: "copy_from_user / copy_to_user" {
    direction: down
    style.fill: "#f8f9fa"
    style.stroke: "#495057"
    style.stroke-width: 2

    boundary_logic: {
      shape: sql_table
      label: "Safe Boundary Crossing"
      s1: "1 | access_ok()      | validate ptr range"
      s2: "2 | STAC instr       | enable SMAP bypass"
      s3: "3 | fault-safe copy  | guarded deref"
      s4: "4 | CLAC instr       | re-arm SMAP"
      s5: "5 | return residual  | 0 = success"
    }

    bad_logic: {
      shape: sql_table
      label: "FORBIDDEN (Direct Deref)"
      f1: "BAD | memcpy()       | bypasses guard"
      f2: "BAD | *(ptr)         | SMAP panic"
    }

    boundary_logic -> bad_logic: "never use →"
  }

  smap_box: "SMAP / SMEP Hardware" {
    direction: down
    style.fill: "#fff3cd"
    style.stroke: "#fd7e14"
    style.stroke-width: 2

    cpu_flags: {
      shape: sql_table
      label: "Control Register Bits"
      smep: "CR4.bit20 | Prevent Kernel Executing User"
      smap: "CR4.bit21 | Prevent Kernel R/W User"
      ac:   "RFLAGS.AC | User Access Override (STAC/CLAC)"
    }

    fault_result: {
      shape: sql_table
      label: "Violation Outcome"
      pf: "Dereference | triggers #PF in ring 0"
      pan: "Result      | Kernel Oops or Panic"
    }
  }

  module_lifecycle: "LKM Lifecycle" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    style.stroke-width: 2

    load_sequence: {
      shape: sql_table
      label: "ELF to Virtual Space"
      m1: "1 | finit_module()   | binary read"
      m2: "2 | vmalloc() area   | map to 0xffffffffa..."
      m3: "3 | Relocations      | &printk patched"
      m4: "4 | Page Protection  | .text -> ro + exec"
      m5: "5 | DISCARD          | __init sections freed"
    }
  }
}

# Cross-row connections
row1.userspace_col.us_ptr_warning -> row2.copy_mechanics: "access method"
row1.kernel_col.k_modules -> row2.module_lifecycle: "load area"
row1 -> row2: "Virtual Topology Context"