direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # Linux Kernel Module Lifecycle
  `insmod` → init → running → `rmmod` → exit
| {near: top-center}
compiled: ".ko File on Disk" {
  shape: document
  style.fill: "#e8e8e8"
  style.stroke: "#888888"
  style.font-color: "#333333"
  style.bold: true
}
loading: "Loading (kernel space)" {
  shape: rectangle
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"
  style.bold: true
  step1: {
    shape: sql_table
    label: "load_module() — fs/module/main.c"
    s1: "1 | sys_finit_module() syscall | ring 3 → ring 0"
    s2: "2 | vmalloc() | map .ko ELF into kernel vmem"
    s3: "3 | walk reloc table | resolve EXPORT_SYMBOL refs"
    s4: "4 | verify vermagic | must match uname -r exactly"
    s5: "5 | set .text RX / .data RW | page-table attributes"
  }
}
init_running: "init Function Executing" {
  shape: rectangle
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
  style.bold: true
  ifn: {
    shape: sql_table
    label: "hello_init() — process context (ring 0)"
    i1: "context  | insmod process, can sleep, GFP_KERNEL OK"
    i2: "validates | module params (buffer_size > 0)"
    i3: "allocates | kzalloc(buffer_size, GFP_KERNEL)"
    i4: "registers | alloc_chrdev_region / cdev_add"
    i5: "logs      | printk(KERN_INFO) → dmesg ring buffer"
    i6: "returns   | 0 = success  |  -errno = failure"
  }
}
error_path: "Init Failed — Immediate Unload" {
  shape: rectangle
  style.fill: "#fee2e2"
  style.stroke: "#dc2626"
  style.bold: true
  ep: {
    shape: sql_table
    label: "Error Unwind (reverse init order)"
    e1: "kernel frees vmalloc'd module pages"
    e2: "removes from modules list"
    e3: "insmod reports: Operation not permitted"
    e4: "errno = abs(init_return_value)"
    e5: "dmesg shows KERN_ERR message"
    e6: "Total: module never becomes live"
  }
}
live: "Live / Running" {
  shape: rectangle
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"
  style.bold: true
  lv: {
    shape: sql_table
    label: "Module Resident in Kernel (kernel/module/)"
    l1: "symbols   | exported via EXPORT_SYMBOL visible to others"
    l2: "sysfs     | /sys/module/hello/parameters/buffer_size"
    l3: "refcount  | module.refcnt — incremented by try_module_get()"
    l4: "lsmod     | hello  <size>  <refcount>"
    l5: "/proc     | /proc/devices  /proc/mydevice  /proc/modules"
    l6: "code      | .text in kernel vmem, callable by VFS dispatch"
  }
}
unloading: "Unloading" {
  shape: rectangle
  style.fill: "#fce7f3"
  style.stroke: "#9d174d"
  style.bold: true
  ul: {
    shape: sql_table
    label: "rmmod → delete_module() syscall"
    u1: "check refcnt | if > 0: EBUSY — device still open"
    u2: "calls        | module_exit() → hello_exit()"
    u3: "exit runs    | proc_remove / device_destroy / kfree"
    u4: "kernel frees | vmalloc'd pages, kobjects, sysfs entries"
    u5: "udev fires   | removes /dev/mydevice node"
    u6: "result       | module vanishes from lsmod"
  }
}
removed: "Removed (memory freed)" {
  shape: oval
  style.fill: "#e8e8e8"
  style.stroke: "#888888"
  style.font-color: "#333333"
  style.bold: true
}
compiled -> loading: "sudo insmod hello.ko" {
  style.stroke: "#3b82f6"
  style.bold: true
  style.font-color: "#3b82f6"
}
loading -> init_running: "load_module() ok | symbols resolved" {
  style.stroke: "#ca8a04"
  style.bold: true
  style.font-color: "#ca8a04"
}
init_running -> live: "return 0 | init success" {
  style.stroke: "#16a34a"
  style.bold: true
  style.font-color: "#16a34a"
}
init_running -> error_path: "return -errno | init failure" {
  style.stroke: "#dc2626"
  style.bold: true
  style.stroke-dash: 4
  style.font-color: "#dc2626"
}
error_path -> compiled: "unloaded | .ko still on disk" {
  style.stroke: "#dc2626"
  style.stroke-dash: 4
  style.font-color: "#888888"
}
live -> unloading: "sudo rmmod hello" {
  style.stroke: "#9d174d"
  style.bold: true
  style.font-color: "#9d174d"
}
unloading -> removed: "exit ok | pages freed" {
  style.stroke: "#888888"
  style.bold: true
  style.font-color: "#888888"
}
busy_guard: "EBUSY Guard" {
  shape: diamond
  style.fill: "#fef3c7"
  style.stroke: "#d97706"
  style.font-color: "#92400e"
  style.bold: true
  label: "refcnt > 0?"
}
live -> busy_guard: "rmmod attempt" {
  style.stroke: "#d97706"
  style.stroke-dash: 3
}
busy_guard -> unloading: "no — safe to unload" {
  style.stroke: "#16a34a"
  style.font-color: "#16a34a"
}
busy_guard -> live: "yes — EBUSY returned" {
  style.stroke: "#dc2626"
  style.stroke-dash: 4
  style.font-color: "#dc2626"
}
legend: "Legend" {
  near: bottom-right
  shape: rectangle
  style.fill: "#f9fafb"
  style.stroke: "#d1d5db"
  lg: {
    shape: sql_table
    label: "Color Semantics"
    c1: "blue   | loading / kernel mechanics"
    c2: "yellow | init function execution"
    c3: "green  | success / live state"
    c4: "red    | error path / failure"
    c5: "pink   | unload sequence"
    c6: "gray   | on-disk / removed states"
  }
}