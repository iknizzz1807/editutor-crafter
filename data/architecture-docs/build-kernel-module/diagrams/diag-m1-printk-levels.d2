direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# ─── Row 0: Title ───────────────────────────────────────────────
title: "printk Log Levels and dmesg / Console Routing" {
  style.font-size: 22
  style.bold: true
  style.fill: transparent
  style.stroke: transparent
}
# ─── Row 1: Call sites ──────────────────────────────────────────
row1: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right
  callsites: "Call Sites (kernel code)" {
    style.fill: "#e8f4fd"
    style.stroke: "#4a90d9"
    style.border-radius: 8
    direction: down
    l0: {
      shape: sql_table
      label: "KERN_EMERG   (0)"
      lvl:  '0  |  "\\001"  |  System unusable — imminent panic'
      use:  "Use: kernel is about to die"
      style.fill: "#ff4444"
      style.font-color: white
    }
    l1: {
      shape: sql_table
      label: "KERN_ALERT   (1)"
      lvl:  '1  |  "\\001\\001"  |  Action must be taken NOW'
      use:  "Use: hardware failure, data loss imminent"
      style.fill: "#ff6600"
      style.font-color: white
    }
    l2: {
      shape: sql_table
      label: "KERN_CRIT    (2)"
      lvl:  '2  |  critical condition'
      use:  "Use: serious hardware/software error"
      style.fill: "#ff8800"
      style.font-color: white
    }
    l3: {
      shape: sql_table
      label: "KERN_ERR     (3)"
      lvl:  '3  |  error condition'
      use:  "Use: driver errors, operation failed"
      style.fill: "#cc4400"
      style.font-color: white
    }
    l4_warn: {
      shape: sql_table
      label: "KERN_WARNING (4)  ← console_loglevel default"
      lvl:  '4  |  warning condition'
      use:  "Use: recoverable issue, unusual state"
      style.fill: "#e6a817"
      style.font-color: white
    }
    l5: {
      shape: sql_table
      label: "KERN_NOTICE  (5)"
      lvl:  '5  |  normal but significant'
      use:  "Use: module load/unload, config change"
      style.fill: "#4a7c59"
      style.font-color: white
    }
    l6: {
      shape: sql_table
      label: "KERN_INFO    (6)"
      lvl:  '6  |  informational'
      use:  "Use: status messages, init success"
      style.fill: "#2a6496"
      style.font-color: white
    }
    l7: {
      shape: sql_table
      label: "KERN_DEBUG   (7)"
      lvl:  '7  |  debug-level message'
      use:  "Use: pr_debug() — compiled out without DEBUG"
      style.fill: "#555577"
      style.font-color: white
    }
    missing_note: {
      shape: sql_table
      label: "⚠  NO log level prefix"
      row1: "Kernel uses KERN_DEFAULT → resolves to KERN_WARNING (4)"
      row2: "Common mistake: printk(\"msg\") instead of printk(KERN_INFO \"msg\")"
      row3: "Fix: always use pr_info() / pr_err() wrappers — prefix is automatic"
      style.fill: "#fff3cd"
      style.stroke: "#e6a817"
      style.stroke-width: 3
    }
  }
}
# ─── Row 2: printk() internals ──────────────────────────────────
row2: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right
  printk_fn: "printk() (kernel/printk/printk.c)" {
    shape: class
    style.fill: "#f0f0ff"
    style.stroke: "#6666cc"
    label: "printk internals"
    +vprintk_emit(level, fmt, args): "int"
    +log_buf_write(msg, len): "void"
    +console_unlock(): "void — flushes to consoles"
    -cont_mutex: "raw_spinlock_t — continuation lock"
    note: "Level extracted from first byte of format string"
  }
}
# ─── Row 3: Ring Buffer ─────────────────────────────────────────
row3: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right
  ring_buf: "Kernel Ring Buffer (log_buf)" {
    style.fill: "#e8ffe8"
    style.stroke: "#2e8b57"
    style.border-radius: 6
    direction: down
    rb_meta: {
      shape: sql_table
      label: "log_buf  (kernel/printk/printk.c)"
      f0: "log_buf        | char*    | pointer to circular buffer"
      f1: "log_buf_len    | uint32_t | size — default 512KB (CONFIG_LOG_BUF_SHIFT)"
      f2: "log_first_seq  | uint64_t | sequence of oldest record"
      f3: "log_next_seq   | uint64_t | sequence of next record slot"
      f4: "log_first_idx  | uint32_t | byte offset of oldest record"
      f5: "log_next_idx   | uint32_t | byte offset for next write"
      total: "Records: struct printk_log { u64 ts_nsec; u16 len; u8 level; ... }"
    }
    rb_note: {
      shape: sql_table
      label: "Ring Buffer Properties"
      p1: "Circular — oldest records overwritten when full"
      p2: "In RAM only — lost on power cycle / reboot"
      p3: "Accessible via /dev/kmsg (one record per read)"
      p4: "Accessible via syslog(2) syscall"
      p5: "Size tunable: CONFIG_LOG_BUF_SHIFT (14=16KB … 25=32MB)"
    }
  }
}
# ─── Row 4: Two consumers side by side ──────────────────────────
row4: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right
  consumer_dmesg: "Consumer 1: dmesg" {
    style.fill: "#fff8e1"
    style.stroke: "#f9a825"
    style.border-radius: 6
    direction: down
    dmesg_info: {
      shape: sql_table
      label: "dmesg command"
      c1: "Reads /dev/kmsg or syslog(2) syscall"
      c2: "Dumps ALL records regardless of level"
      c3: "dmesg -w          → follow in real time (tail -f)"
      c4: "dmesg -T          → human-readable timestamps"
      c5: "dmesg -l err,warn → filter by level"
      c6: "dmesg | grep mymod → filter by module name"
      c7: "journalctl -k     → systemd: persistent across reboots"
    }
  }
  consumer_console: "Consumer 2: Console Driver" {
    style.fill: "#fce4ec"
    style.stroke: "#c2185b"
    style.border-radius: 6
    direction: down
    console_info: {
      shape: sql_table
      label: "console_loglevel gate"
      c1: "Controlled by: /proc/sys/kernel/printk"
      c2: "Format: console_loglevel  default  min  boot"
      c3: "Example:        4              4    1    7"
      c4: "Rule: level < console_loglevel → printed to console"
      c5: "Level 0-3 (EMERG…ERR): always visible (< 4)"
      c6: "Level 4 (WARNING): NOT visible at default (not < 4)"
      c7: "Level 5-7: suppressed at default console_loglevel"
      c8: "Override: echo 8 > /proc/sys/kernel/printk → show all"
    }
    console_types: {
      shape: sql_table
      label: "Console Types"
      t1: "VGA console    → /dev/tty0 (physical screen)"
      t2: "Serial console → ttyS0 (embedded / VM)"
      t3: "netconsole     → UDP over network"
      t4: "earlyprintk    → before normal console init"
    }
  }
}
# ─── Row 5: pr_* wrappers ───────────────────────────────────────
row5: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right
  wrappers: "Modern pr_* Wrappers (preferred over raw printk)" {
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
    style.border-radius: 6
    direction: down
    wr_table: {
      shape: sql_table
      label: "include/linux/printk.h"
      w0: "pr_emerg(fmt, ...)   | KERN_EMERG   | level 0"
      w1: "pr_alert(fmt, ...)   | KERN_ALERT   | level 1"
      w2: "pr_crit(fmt, ...)    | KERN_CRIT    | level 2"
      w3: "pr_err(fmt, ...)     | KERN_ERR     | level 3"
      w4: "pr_warn(fmt, ...)    | KERN_WARNING | level 4"
      w5: "pr_notice(fmt, ...)  | KERN_NOTICE  | level 5"
      w6: "pr_info(fmt, ...)    | KERN_INFO    | level 6"
      w7: "pr_debug(fmt, ...)   | KERN_DEBUG   | level 7 (no-op without DEBUG)"
      w8: "pr_devel(fmt, ...)   | KERN_DEBUG   | level 7 (no-op without DEBUG)"
    }
    pr_fmt_note: {
      shape: sql_table
      label: "pr_fmt auto-prefix (best practice)"
      n1: "#define pr_fmt(fmt) KBUILD_MODNAME \": \" fmt"
      n2: "Place at top of .c file before #include <linux/printk.h>"
      n3: "Result: pr_info(\"loaded\")  →  \"mydevice: loaded\\n\""
      n4: "Avoids repeating module name in every format string"
    }
  }
}
# ─── Arrows ─────────────────────────────────────────────────────
row1.callsites.l0 -> row2.printk_fn: "KERN_EMERG | level=0"
row1.callsites.l3 -> row2.printk_fn: "KERN_ERR | level=3"
row1.callsites.l6 -> row2.printk_fn: "KERN_INFO | level=6"
row1.callsites.l7 -> row2.printk_fn: "KERN_DEBUG | level=7"
row1.callsites.missing_note -> row2.printk_fn: "KERN_DEFAULT → level=4" {
  style.stroke: "#e6a817"
  style.stroke-width: 2
  style.stroke-dash: 5
}
row2.printk_fn -> row3.ring_buf: "vprintk_emit() | writes struct printk_log record"
row3.ring_buf -> row4.consumer_dmesg: "ALL levels | /dev/kmsg read"
row3.ring_buf -> row4.consumer_console: "level < console_loglevel only | synchronous flush"
row4.consumer_console -> row4.consumer_dmesg: "" {
  style.stroke: transparent
}
row5.wrappers -> row2.printk_fn: "compiles to printk(KERN_x fmt)" {
  style.stroke: "#7b1fa2"
  style.stroke-dash: 3
}
# ─── Legend ─────────────────────────────────────────────────────
legend: "Legend" {
  near: bottom-right
  style.fill: "#fafafa"
  style.stroke: "#999"
  style.border-radius: 4
  lg: {
    shape: sql_table
    label: "Color Semantics"
    r: "Red / Orange  → high-severity levels (0-3): always reach console"
    y: "Yellow        → WARNING (4): default console_loglevel boundary"
    g: "Green         → info / notice (5-6): ring buffer only by default"
    b: "Blue / Grey   → debug (7): compiled out unless DEBUG defined"
    w: "Dashed arrow  → implicit / default path (no explicit level)"
  }
}