direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Automatic /dev/ Node Creation
  `class_create` → `device_create` → udev → `/dev/mydevice`
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_code: "mydevice_init() (mydevice.c)" {
    direction: down
    style.fill: "#e8f4f8"
    style.stroke: "#2196F3"
    style.border-radius: 8
    step1: {
      shape: sql_table
      label: "Step 1: class_create()"
      call: 'mydevice_class = class_create(THIS_MODULE, "mydevice")'
      result: "returns struct class* (or ERR_PTR on fail)"
      note: "IS_ERR(mydevice_class) to check error"
    }
    step2: {
      shape: sql_table
      label: "Step 2: device_create()"
      call: 'device_create(mydevice_class, NULL, dev_num, NULL, "mydevice")'
      arg1: "arg1: mydevice_class — parent class"
      arg2: "arg2: NULL           — no parent device"
      arg3: "arg3: dev_num        — MKDEV(major, minor)"
      arg4: 'arg4: "mydevice"     — node name'
      result: "returns struct device* (or ERR_PTR on fail)"
    }
    step1 -> step2: "success"
  }
  sysfs: "sysfs (Virtual FS)" {
    direction: down
    style.fill: "#f3e5f5"
    style.stroke: "#9C27B0"
    style.border-radius: 8
    class_dir: {
      shape: sql_table
      label: "/sys/class/mydevice/"
      created_by: "class_create() writes kobject"
      content: "directory entry in sysfs"
    }
    dev_dir: {
      shape: sql_table
      label: "/sys/class/mydevice/mydevice/"
      created_by: "device_create() writes kobject + uevent"
      dev_file: "'dev' file: '251:0' (major:minor ASCII)"
      uevent: "uevent file: ACTION=add DEVNAME=mydevice"
    }
    class_dir -> dev_dir: "device_create()"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  udev_daemon: "udev Daemon (userspace)" {
    direction: down
    style.fill: "#fff8e1"
    style.stroke: "#FF9800"
    style.border-radius: 8
    monitor: {
      shape: sql_table
      label: "udev: netlink monitor"
      listen: "listens on NETLINK_KOBJECT_UEVENT socket"
      event: "receives ACTION=add SUBSYSTEM=mydevice"
      note: "always running as system daemon"
    }
    read_dev: {
      shape: sql_table
      label: "udev: reads major:minor"
      read: "cat /sys/class/mydevice/mydevice/dev"
      output: '"251:0"'
      parse: "major=251 minor=0"
    }
    mknod_call: {
      shape: sql_table
      label: "udev: calls mknod"
      cmd: "mknod /dev/mydevice c 251 0"
      perms: "applies udev rules for permissions/owner"
      result: "/dev/mydevice created (character device)"
    }
    monitor -> read_dev: "uevent received"
    read_dev -> mknod_call: "major:minor parsed"
  }
  manual_contrast: "Manual mknod (OLD way)" {
    direction: down
    style.fill: "#ffebee"
    style.stroke: "#f44336"
    style.border-radius: 8
    style.stroke-dash: 6
    manual_step1: {
      shape: sql_table
      label: "Without udev (deprecated)"
      s1: "1. insmod mydevice.ko"
      s2: "2. grep mydevice /proc/devices  → find major"
      s3: "3. sudo mknod /dev/mydevice c 251 0"
      s4: "4. sudo chmod 666 /dev/mydevice"
      problem1: "PROBLEM: /dev/ node gone on reboot"
      problem2: "PROBLEM: must repeat after every insmod"
      problem3: "PROBLEM: major number may change"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  devnode: "/dev/mydevice (ready)" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#4CAF50"
    style.border-radius: 8
    node_info: {
      shape: sql_table
      label: "Device Node Info"
      type: "type: c (character device)"
      major: "major: 251 (dynamic, from alloc_chrdev_region)"
      minor: "minor: 0"
      perms: "perms: crw------- root root (default)"
      vfs: "VFS inode → routes to mydevice_fops"
    }
  }
  cleanup: "module_exit() Cleanup — REVERSE ORDER" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#E91E63"
    style.border-radius: 8
    exit_steps: {
      shape: sql_table
      label: "mydevice_exit() — must unwind in reverse"
      e1: "1. proc_remove(proc_entry)           ← remove /proc first"
      e2: "2. device_destroy(class, dev_num)    ← udev removes /dev/mydevice"
      e3: "3. class_destroy(mydevice_class)     ← remove /sys/class/mydevice/"
      e4: "4. cdev_del(&my_cdev)                ← unregister from VFS dispatch"
      e5: "5. unregister_chrdev_region(dev_num) ← release major:minor"
      e6: "6. kfree(kernel_buffer)              ← free data buffer"
      warn: "WARNING: wrong order = use-after-free crash"
    }
  }
}
row1.kernel_code.step2 -> row2.udev_daemon.monitor: "netlink uevent\n(kernel → userspace)" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  style.animated: true
}
row1.sysfs.dev_dir -> row2.udev_daemon.read_dev: "reads 'dev' file\n(major:minor)" {
  style.stroke: "#FF9800"
}
row2.udev_daemon.mknod_call -> row3.devnode.node_info: "creates node\nmknod c 251 0" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row1.kernel_code.step1 -> row1.sysfs.class_dir: "/sys/class/mydevice/" {
  style.stroke: "#9C27B0"
}
row1.kernel_code.step2 -> row1.sysfs.dev_dir: "/sys/class/mydevice/mydevice/" {
  style.stroke: "#9C27B0"
}
row3.devnode.node_info -> row3.cleanup.exit_steps: "rmmod triggers\nreverse cleanup" {
  style.stroke: "#E91E63"
  style.stroke-dash: 4
}