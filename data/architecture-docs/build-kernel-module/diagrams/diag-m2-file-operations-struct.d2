direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## file_operations Struct — VFS Dispatch Table (linux/fs.h)
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  syscall_col: "Userspace Syscalls" {
    direction: down
    style.fill: "#e8f4f8"
    style.stroke: "#4a90c4"
    style.border-radius: 6
    sc_open: {
      shape: rectangle
      label: "open(\"/dev/mydevice\", flags)"
      style.fill: "#4a90c4"
      style.font-color: white
      style.bold: true
    }
    sc_read: {
      shape: rectangle
      label: "read(fd, buf, count)"
      style.fill: "#4a90c4"
      style.font-color: white
      style.bold: true
    }
    sc_write: {
      shape: rectangle
      label: "write(fd, buf, count)"
      style.fill: "#4a90c4"
      style.font-color: white
      style.bold: true
    }
    sc_ioctl: {
      shape: rectangle
      label: "ioctl(fd, cmd, arg)"
      style.fill: "#4a90c4"
      style.font-color: white
      style.bold: true
    }
    sc_poll: {
      shape: rectangle
      label: "poll/select/epoll(fd)"
      style.fill: "#4a90c4"
      style.font-color: white
      style.bold: true
    }
    sc_close: {
      shape: rectangle
      label: "close(fd)"
      style.fill: "#4a90c4"
      style.font-color: white
      style.bold: true
    }
    sc_lseek: {
      shape: rectangle
      label: "lseek(fd, off, whence)"
      style.fill: "#aac9dd"
      style.font-color: "#333"
    }
    sc_mmap: {
      shape: rectangle
      label: "mmap(addr, len, ...)"
      style.fill: "#aac9dd"
      style.font-color: "#333"
    }
    sc_fsync: {
      shape: rectangle
      label: "fsync(fd)"
      style.fill: "#aac9dd"
      style.font-color: "#333"
    }
  }
  fops_col: "struct file_operations mydevice_fops  (fs.h)" {
    direction: down
    style.fill: "#1a1a2e"
    style.stroke: "#e94560"
    style.border-radius: 6
    style.font-color: white
    fops_table: {
      shape: sql_table
      label: "const struct file_operations  (linux/fs.h)"
      f_owner:   "0x00 | struct module*         | .owner          = THIS_MODULE"
      f_open:    "0x08 | int(*)(inode*, file*)  | .open           = mydevice_open"
      f_release: "0x10 | int(*)(inode*, file*)  | .release        = mydevice_release"
      f_read:    "0x18 | ssize_t(*)(file*, char __user*, size_t, loff_t*) | .read = mydevice_read"
      f_write:   "0x20 | ssize_t(*)(file*, const char __user*, size_t, loff_t*) | .write = mydevice_write"
      f_ioctl:   "0x28 | long(*)(file*, uint, ulong) | .unlocked_ioctl = mydevice_ioctl"
      f_poll:    "0x30 | __poll_t(*)(file*, poll_table*) | .poll = mydevice_poll"
      f_llseek:  "0x38 | loff_t(*)(file*, loff_t, int) | .llseek  = NULL  → default_llseek"
      f_mmap:    "0x40 | int(*)(file*, vm_area_struct*) | .mmap    = NULL  → -ENODEV"
      f_fsync:   "0x48 | int(*)(file*, loff_t, loff_t, int) | .fsync = NULL  → -EINVAL"
      f_aio:     "0x50 | ssize_t(*)(kiocb*, iov_iter*) | .read_iter  = NULL  → generic"
      f_sendpage:"0x58 | ssize_t(*)(file*, page*, int, size_t, loff_t*, int) | .sendpage = NULL"
      f_flock:   "0x60 | int(*)(file*, int, file_lock*) | .lock    = NULL  → posix_lock_file"
      f_splice:  "0x68 | ssize_t(*)(pipe*, file*, loff_t*, size_t, uint) | .splice_write = NULL"
      total:     "Total: ~248 bytes (31 function pointers × 8 bytes each)"
      style.fill: "#16213e"
      style.font-color: "#e0e0e0"
      style.stroke: "#e94560"
    }
  }
  handler_col: "Implemented Handlers  (mydevice.c)" {
    direction: down
    style.fill: "#f0fff0"
    style.stroke: "#2e7d32"
    style.border-radius: 6
    h_owner: "THIS_MODULE guard" {
      shape: rectangle
      style.fill: "#ff6b35"
      style.font-color: white
      style.bold: true
      label: "THIS_MODULE\ntry_module_get / module_put\n(mydevice.c)"
    }
    h_open: "mydevice_open" {
      shape: class
      label: "mydevice_open  (mydevice.c:open)"
      +sig: "int(inode*, file*)"
      +try_module_get: "THIS_MODULE → bool"
      +atomic_inc: "open_count"
      +returns: "0 or -ENODEV"
    }
    h_release: "mydevice_release" {
      shape: class
      label: "mydevice_release  (mydevice.c:release)"
      +sig: "int(inode*, file*)"
      +atomic_dec: "open_count"
      +module_put: "THIS_MODULE"
      +returns: "0"
    }
    h_read: "mydevice_read" {
      shape: class
      label: "mydevice_read  (mydevice.c:read)"
      +sig: "ssize_t(file*, char __user*, size_t, loff_t*)"
      +wait: "wait_event_interruptible(read_q, len>0)"
      +lock: "mutex_lock_interruptible"
      +copy: "copy_to_user(buf, kernel_buffer, n)"
      +advance: "*f_pos += to_copy"
      +wake: "wake_up_interruptible(write_q)"
      +returns: "bytes_read or -EAGAIN or -ERESTARTSYS"
    }
    h_write: "mydevice_write" {
      shape: class
      label: "mydevice_write  (mydevice.c:write)"
      +sig: "ssize_t(file*, const char __user*, size_t, loff_t*)"
      +wait: "wait_event_interruptible(write_q, space>0)"
      +lock: "mutex_lock_interruptible"
      +copy: "copy_from_user(kernel_buffer, buf, n)"
      +wake: "wake_up_interruptible(read_q)"
      +returns: "bytes_written or -EAGAIN or -ERESTARTSYS"
    }
    h_ioctl: "mydevice_ioctl" {
      shape: class
      label: "mydevice_ioctl  (mydevice.c:ioctl)"
      +sig: "long(file*, uint cmd, ulong arg)"
      +validate: "_IOC_TYPE(cmd) == MYDEVICE_IOC_MAGIC"
      +dispatch: "RESIZE | CLEAR | STATUS"
      +returns: "0 or -ENOTTY or -EINVAL"
    }
    h_poll: "mydevice_poll" {
      shape: class
      label: "mydevice_poll  (mydevice.c:poll)"
      +sig: "__poll_t(file*, poll_table*)"
      +sub1: "poll_wait(filp, read_q, wait)"
      +sub2: "poll_wait(filp, write_q, wait)"
      +mask1: "POLLIN|POLLRDNORM if len>0"
      +mask2: "POLLOUT|POLLWRNORM if space>0"
      +returns: "__poll_t mask"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  null_box: "NULL Field Behavior  (VFS default dispatch)" {
    direction: down
    style.fill: "#fff8e1"
    style.stroke: "#f57f17"
    style.border-radius: 6
    null_table: {
      shape: sql_table
      label: "NULL fop field → VFS fallback"
      n1: ".llseek  = NULL | → default_llseek()  | seeks using f_pos"
      n2: ".mmap    = NULL | → -ENODEV           | mmap not supported"
      n3: ".fsync   = NULL | → -EINVAL           | fsync not supported"
      n4: ".lock    = NULL | → posix_lock_file() | POSIX byte-range locks"
      n5: ".read_iter = NULL | → old .read path  | wraps .read if set"
      n6: ".sendpage  = NULL | → -EINVAL         | splice not supported"
      rule: "Rule: NULL = 'I do not support this operation'"
      style.fill: "#fffde7"
      style.stroke: "#f9a825"
    }
  }
  module_guard: "Module Reference Guard  (module.h)" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#c62828"
    style.border-radius: 6
    guard_table: {
      shape: sql_table
      label: "THIS_MODULE reference counting"
      g1: "try_module_get(THIS_MODULE) | called in .open    | returns false if module dying"
      g2: "module_put(THIS_MODULE)     | called in .release | decrements refcount"
      g3: "module->refcnt == 0        | required for rmmod | rmmod polls until 0"
      g4: "rmmod with open fd         | returns -EBUSY     | Device or resource busy"
      g5: "open_count atomic_t        | tracks open fds    | informational only"
      guard_note: "Invariant: refcnt >= open_count always"
      style.fill: "#ffebee"
      style.stroke: "#e53935"
    }
  }
  vfs_dispatch: "VFS Dispatch Path  (fs/char_dev.c)" {
    direction: down
    style.fill: "#e8eaf6"
    style.stroke: "#3949ab"
    style.border-radius: 6
    vfs_table: {
      shape: sql_table
      label: "VFS → file_operations dispatch chain"
      v1: "sys_read(fd, buf, n)        | → vfs_read()        | → file->f_op->read()"
      v2: "sys_write(fd, buf, n)       | → vfs_write()       | → file->f_op->write()"
      v3: "sys_ioctl(fd, cmd, arg)     | → do_vfs_ioctl()    | → file->f_op->unlocked_ioctl()"
      v4: "sys_poll(fds, n, timeout)   | → do_sys_poll()     | → file->f_op->poll()"
      v5: "sys_open(path, flags)       | → do_sys_open()     | → file->f_op->open()"
      v6: "sys_close(fd)              | → filp_close()      | → file->f_op->release()"
      v7: "filp->f_op                 | set at open() time  | from cdev->ops via inode"
      style.fill: "#e8eaf6"
      style.stroke: "#3f51b5"
    }
  }
}
