direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
style.fill: "#f0f4f8"
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  caller_gfpk: "Caller — Process Context (module_init.c)" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    style.border-radius: 6
    call_gfpk: {
      shape: sql_table
      label: "kmalloc(4096, GFP_KERNEL)"
      f1: "size        | size_t       | 4096"
      f2: "flags       | gfp_t        | GFP_KERNEL"
      f3: "context     | string       | process (can sleep)"
      f4: "caller      | string       | module_init / syscall handler"
    }
    gfpk_props: {
      shape: sql_table
      label: "GFP_KERNEL properties"
      p1: "may_sleep   | bool         | true"
      p2: "may_reclaim | bool         | true"
      p3: "may_io      | bool         | true"
      p4: "pool        | enum         | normal zone"
      p5: "use_when    | string       | process context only"
    }
  }
  caller_gfpa: "Caller — Interrupt / Atomic Context" {
    direction: down
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
    style.border-radius: 6
    call_gfpa: {
      shape: sql_table
      label: "kmalloc(64, GFP_ATOMIC)"
      f1: "size        | size_t       | 64"
      f2: "flags       | gfp_t        | GFP_ATOMIC"
      f3: "context     | string       | IRQ / spinlock held"
      f4: "caller      | string       | irq handler / timer cb"
    }
    gfpa_props: {
      shape: sql_table
      label: "GFP_ATOMIC properties"
      p1: "may_sleep   | bool         | false (NEVER)"
      p2: "may_reclaim | bool         | false"
      p3: "may_io      | bool         | false"
      p4: "pool        | enum         | emergency reserves"
      p5: "use_when    | string       | interrupt / spinlock ctx"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  size_round: "Size Rounding (mm/slab_common.c)" {
    direction: down
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.border-radius: 6
    round_table: {
      shape: sql_table
      label: "kmalloc_index(): size → cache"
      r1: "1  –   32 | KMALLOC_MIN | kmalloc-32"
      r2: "33 –   64 | 64          | kmalloc-64"
      r3: "65 –  128 | 128         | kmalloc-128"
      r4: "129–  192 | 192         | kmalloc-192"
      r5: "193–  256 | 256         | kmalloc-256"
      r6: "257–  512 | 512         | kmalloc-512"
      r7: "513– 1024 | 1024        | kmalloc-1k"
      r8: "1025–2048 | 2048        | kmalloc-2k"
      r9: "2049–4096 | 4096        | kmalloc-4k  ← our request"
      r10: "4097–8192| 8192        | kmalloc-8k"
      r11: "note      | —          | rounds up to next power-of-2"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  slab: "Slab Allocator (mm/slub.c)" {
    direction: down
    style.fill: "#f3e5f5"
    style.stroke: "#6a1b9a"
    style.border-radius: 6
    slab_cache: {
      shape: sql_table
      label: "struct kmem_cache — kmalloc-4k"
      c1: "0x00 | char*          | name = 'kmalloc-4096'"
      c2: "0x08 | size_t         | object_size = 4096"
      c3: "0x10 | size_t         | size = 4096 (with align)"
      c4: "0x18 | unsigned int   | flags"
      c5: "0x1c | unsigned int   | min_partial"
      c6: "0x20 | struct list*   | node[] — per-NUMA freelist"
      c7: "0x28 | struct cpu_s*  | cpu_slab — per-CPU cache"
      c8: "total: ~128 bytes per cache descriptor"
    }
    slab_page: {
      shape: sql_table
      label: "struct slab (one 4KB page, 1 object)"
      sp1: "0x00 | struct page*  | page — backing physical page"
      sp2: "0x08 | void**        | freelist — next free object"
      sp3: "0x10 | unsigned int  | inuse — allocated objects"
      sp4: "0x14 | unsigned int  | objects — total capacity"
      sp5: "total: 1 object × 4096 B = 4096 B usable"
    }
  }
  reclaim: "Memory Reclaim (GFP_KERNEL path only)" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#880e4f"
    style.border-radius: 6
    reclaim_steps: {
      shape: sql_table
      label: "Page reclaim sequence (mm/vmscan.c)"
      s1: "1 | try_charge()    | check memory limits"
      s2: "2 | get_page_from_freelist() | fast path: free pages exist"
      s3: "3 | __alloc_pages_slowpath() | fast path failed"
      s4: "4 | wake_all_kswapd()       | wake kswapd daemon"
      s5: "5 | try_to_free_pages()     | direct reclaim (may sleep)"
      s6: "6 | writeback dirty pages   | I/O — sleeps here"
      s7: "7 | retry allocation        | after pages freed"
      s8: "GFP_ATOMIC: skip steps 3-7, return NULL immediately"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  success: "Success Path" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.border-radius: 6
    ret_ok: {
      shape: sql_table
      label: "kmalloc returns non-NULL ptr"
      ok1: "ptr     | void*   | kernel virtual address"
      ok2: "align   | bytes   | at least 8-byte aligned"
      ok3: "zeroed? | bool    | NO — use kzalloc() for zero"
      ok4: "region  | enum    | ZONE_NORMAL, kvmalloc range"
      ok5: "action  | code    | use ptr directly in kernel code"
    }
    usage_ok: "Usage in driver (mydevice.c)" {
      style.fill: "#f1f8e9"
      style.stroke: "#558b2f"
      code: |'c
        kernel_buffer = kzalloc(buffer_size, GFP_KERNEL);
        if (!kernel_buffer)
            return -ENOMEM;
        /* ptr is valid: read/write freely */
        memset(kernel_buffer, 0, buffer_size);
      '|
      width: 380
    }
  }
  failure: "Failure Path (NULL return)" {
    direction: down
    style.fill: "#ffebee"
    style.stroke: "#b71c1c"
    style.border-radius: 6
    ret_fail: {
      shape: sql_table
      label: "kmalloc returns NULL"
      f1: "when     | GFP_KERNEL | reclaim exhausted all options"
      f2: "when     | GFP_ATOMIC | emergency pool empty"
      f3: "errno    | int        | caller must return -ENOMEM"
      f4: "NEVER    | rule       | dereference NULL — kernel panic"
      f5: "ALWAYS   | rule       | check return value before use"
    }
    usage_fail: "Correct NULL check (mydevice.c)" {
      style.fill: "#fff8f8"
      style.stroke: "#c62828"
      code: |'c
        ptr = kmalloc(size, GFP_KERNEL);
        if (!ptr) {
            pr_err("mydevice: kmalloc failed\n");
            return -ENOMEM; /* propagate to insmod */
        }
      '|
      width: 380
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kfree_box: "kfree in module_exit (mydevice.c)" {
    direction: down
    style.fill: "#e8eaf6"
    style.stroke: "#283593"
    style.border-radius: 6
    kfree_api: {
      shape: sql_table
      label: "kfree(ptr) — mm/slub.c"
      k1: "void kfree(const void *ptr)"
      k2: "ptr == NULL | safe  | no-op (guaranteed by kernel)"
      k3: "double free | BUG() | kernel detects, oops"
      k4: "action      | puts object back on slab freelist"
      k5: "TLB flush?  | no    | virtual mapping stays valid"
      k6: "zeroed?     | no    | data may linger (security note)"
    }
    kfree_usage: "module_exit cleanup pattern" {
      style.fill: "#ede7f6"
      style.stroke: "#4527a0"
      code: |'c
        static void __exit mydevice_exit(void)
        {
            /* safe even if kzalloc failed in init */
            kfree(kernel_buffer);
            kernel_buffer = NULL;
            pr_info("mydevice: buffer freed\n");
        }
      '|
      width: 420
    }
  }
  danger: "What Happens Without Mutex (Milestone 4)" {
    direction: down
    style.fill: "#fff9c4"
    style.stroke: "#f57f17"
    style.border-radius: 6
    danger_table: {
      shape: sql_table
      label: "Race: concurrent kmalloc resize + read"
      d1: "CPU0 (resize) | reads  kernel_buffer ptr = 0xffff888001000000"
      d2: "CPU1 (read)   | reads  kernel_buffer ptr = 0xffff888001000000"
      d3: "CPU0 (resize) | kfree(0xffff888001000000) — freed!"
      d4: "CPU0 (resize) | kernel_buffer = new_buf"
      d5: "CPU1 (read)   | copy_to_user from 0xffff888001000000 — UAF!"
      d6: "result        | use-after-free → kernel oops or data corruption"
      d7: "fix           | mutex_lock before any ptr read or write"
    }
  }
}
row0.caller_gfpk -> row1.size_round: "GFP_KERNEL | round size"
row0.caller_gfpa -> row1.size_round: "GFP_ATOMIC | round size"
row1.size_round -> row2.slab: "index=10 | kmalloc-4k cache"
row2.slab -> row2.reclaim: "no free obj | need page" {
  style.stroke-dash: 4
  style.stroke: "#880e4f"
}
row2.reclaim -> row3.success: "page reclaimed | obj allocated" {
  style.stroke: "#2e7d32"
}
row2.slab -> row3.success: "free obj found | fast path" {
  style.stroke: "#2e7d32"
}
row2.slab -> row3.failure: "OOM | NULL" {
  style.stroke-dash: 4
  style.stroke: "#b71c1c"
}
row2.reclaim -> row3.failure: "reclaim failed | NULL" {
  style.stroke-dash: 4
  style.stroke: "#b71c1c"
}
row3.success -> row4.kfree_box: "module_exit | kfree(ptr)"
row3.failure -> row4.danger: "missing check | UAF risk" {
  style.stroke-dash: 4
  style.stroke: "#f57f17"
}