direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Major/Minor Number Registry & Device Identification (fs.h / cdev.h)
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dev_t_layout: {
    label: "dev_t (chrdev.h) — 32-bit packed value"
    shape: sql_table
    f0: "bits[31:20] | 12 bits | MAJOR — driver identity"
    f1: "bits[19:0]  | 20 bits | MINOR — device instance"
    f2: "Range major | 0–4095  | (1–199 reserved, 200+ dynamic)"
    f3: "Range minor | 0–1M    | per-driver instance selector"
    sz: "Total: 32 bits (typedef unsigned int dev_t)"
  }
  macros: {
    label: "Kernel Macros (kdev_t.h)"
    shape: class
    +MKDEV(ma, mi): "dev_t"
    +MAJOR(dev): "unsigned int"
    +MINOR(dev): "unsigned int"
    note_mkdev: "MKDEV = (ma<<20) | mi"
    note_major: "MAJOR = dev >> 20"
    note_minor: "MINOR = dev & 0xFFFFF"
  }
  dev_t_layout -> macros: "dev_t | encode/decode"
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  alloc_call: {
    label: "alloc_chrdev_region() Call Site (mydevice.c:init)"
    width: 420
    code: |'c
      dev_t dev_num;
      int ret = alloc_chrdev_region(
          &dev_num,   /* OUT: assigned dev_t     */
          0,          /* first_minor             */
          1,          /* count of minors         */
          "mydevice"  /* name in /proc/devices   */
      );
      /* ret < 0 → error; dev_num now holds major:minor */
      pr_info("major=%d minor=%d\n",
              MAJOR(dev_num), MINOR(dev_num));
    '|
  }
  chrdev_map: {
    label: "Kernel chrdevs[] Registry (char_dev.c)"
    shape: sql_table
    h: "major | driver_name | registered"
    r1: "1     | mem         | built-in"
    r4: "4     | tty         | built-in"
    r5: "5     | /dev/tty    | built-in"
    r8: "8     | sd          | scsi disk"
    rdot: "...   | ...         | ..."
    r251: "251   | mydevice    | THIS MODULE"
    r252: "252   | (free)      | —"
    note: "kernel scans for first unused slot"
  }
  alloc_call -> chrdev_map: "dev_t* | writes major"
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cdev_struct: {
    label: "struct cdev (cdev.h)"
    shape: sql_table
    f0: "0x00 | struct kobject     | kobj"
    f1: "0x28 | struct module*     | owner"
    f2: "0x30 | file_operations*  | ops   ← YOUR FOPS"
    f3: "0x38 | struct list_head  | list"
    f4: "0x48 | dev_t             | dev   (major:minor base)"
    f5: "0x4C | unsigned int      | count (# of minors)"
    sz: "Total: ~80 bytes"
  }
  cdev_register: {
    label: "cdev Registration (mydevice.c:init)"
    width: 400
    code: |'c
      struct cdev my_cdev;
      cdev_init(&my_cdev, &mydevice_fops);
      my_cdev.owner = THIS_MODULE;
      /* Links major:minor → file_operations in VFS */
      ret = cdev_add(&my_cdev, dev_num, 1);
      /* After cdev_add: kernel can route open() calls
         for this major to mydevice_fops             */
    '|
  }
  cdev_struct -> cdev_register: "struct cdev | init+add"
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  proc_devices: {
    label: "/proc/devices (read-only, kernel-generated)"
    shape: sql_table
    h: "Section: Character devices"
    r1: "1   mem"
    r4: "4   /dev/vc/0"
    r5: "5   /dev/tty"
    rdot: "..."
    r251: "251 mydevice    ← YOUR DRIVER"
    note: "cat /proc/devices shows this after insmod"
  }
  dev_node: {
    label: "ls -l /dev/mydevice  (after udev fires)"
    shape: sql_table
    f0: "type  | c = character device"
    f1: "perms | crw------- (root only by default)"
    f2: "major | 251 (matches /proc/devices)"
    f3: "minor | 0   (first minor, as requested)"
    f4: "name  | /dev/mydevice"
    note: "mknod: MKDEV(251, 0) embedded in inode"
  }
  proc_devices -> dev_node: "major:minor | udev mknod"
}
row1 -> row2: "dev_t encoding | MAJOR/MINOR macros"
row2 -> row3: "dev_num | cdev_init + cdev_add"
row3 -> row4: "cdev registered | udev event via sysfs"
legend: {
  near: bottom-right
  shape: sql_table
  label: "Color Key"
  c1: "Blue arrows  = data flow / registration"
  c2: "sql_table    = kernel data structure / file output"
  c3: "code block   = implementation in mydevice.c"
  c4: "251          = example dynamic major number"
}