direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Data Walk: `echo 'hello' > /dev/mydevice && cat /dev/mydevice`
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  userspace_box: "USERSPACE (ring 3)" {
    direction: down
    style.fill: "#e8f4fd"
    style.stroke: "#4a90d9"
    style.stroke-width: 2
    echo_proc: "echo process" {
      shape: rectangle
      style.fill: "#c8e6fa"
      style.stroke: "#2d7ab5"
      buf_echo: {
        shape: sql_table
        label: "userbuf (stack) — echo"
        b0: "0x7ffc...0000 | char[6] | 'h','e','l','l','o','\\n'"
        b1: "Total: 6 bytes"
      }
    }
    cat_proc: "cat process" {
      shape: rectangle
      style.fill: "#d4edda"
      style.stroke: "#28a745"
      buf_cat: {
        shape: sql_table
        label: "userbuf (stack) — cat"
        c0: "0x7ffc...2000 | char[4096] | (empty before read)"
        c1: "After copy_to_user: 'hello\\n' + zeros"
        c2: "Total: 4096 bytes capacity"
      }
    }
  }
  boundary_box: "KERNEL-USERSPACE BOUNDARY" {
    direction: down
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.stroke-width: 3
    write_syscall: "sys_write  (syscall #1)" {
      shape: hexagon
      style.fill: "#ffe082"
      style.stroke: "#f57f17"
    }
    read_syscall: "sys_read  (syscall #0)" {
      shape: hexagon
      style.fill: "#ffe082"
      style.stroke: "#f57f17"
    }
  }
  kernel_box: "KERNEL SPACE (ring 0)" {
    direction: down
    style.fill: "#fdecea"
    style.stroke: "#d32f2f"
    style.stroke-width: 2
    vfs_write: "VFS: vfs_write()" {
      shape: rectangle
      style.fill: "#f8bbd0"
      style.stroke: "#c2185b"
    }
    vfs_read: "VFS: vfs_read()" {
      shape: rectangle
      style.fill: "#f8bbd0"
      style.stroke: "#c2185b"
    }
    fops_write: "mydevice_write() (mydevice.c)" {
      shape: class
      style.fill: "#ffcdd2"
      style.stroke: "#b71c1c"
      +write(filp, ubuf, count, f_pos): "ssize_t"
      -to_copy: "min(count=6, buffer_size=4096) = 6"
      -not_copied: "copy_from_user(kbuf, ubuf, 6)"
      -buffer_data_len: "set to 6"
      -returns: "ssize_t 6"
    }
    fops_read: "mydevice_read() (mydevice.c)" {
      shape: class
      style.fill: "#ffcdd2"
      style.stroke: "#b71c1c"
      +read(filp, ubuf, count, f_pos): "ssize_t"
      -available: "buffer_data_len - *f_pos = 6-0 = 6"
      -to_copy: "min(count=4096, available=6) = 6"
      -not_copied: "copy_to_user(ubuf, kbuf+0, 6)"
      -f_pos_update: "*f_pos += 6  =>  f_pos = 6"
      -returns: "ssize_t 6"
    }
    copy_from: "copy_from_user() (arch/x86/lib/usercopy.c)" {
      shape: rectangle
      style.fill: "#ef9a9a"
      style.stroke: "#c62828"
      label: "copy_from_user(kbuf, ubuf, 6)\n1. validate ubuf in userspace\n2. STAC — enable SMAP crossing\n3. fault-safe memcpy 6 bytes\n4. CLAC — re-enable SMAP\n5. returns 0 (success)"
    }
    copy_to: "copy_to_user() (arch/x86/lib/usercopy.c)" {
      shape: rectangle
      style.fill: "#ef9a9a"
      style.stroke: "#c62828"
      label: "copy_to_user(ubuf, kbuf+0, 6)\n1. validate ubuf in userspace\n2. STAC — enable SMAP crossing\n3. fault-safe memcpy 6 bytes\n4. CLAC — re-enable SMAP\n5. returns 0 (success)"
    }
    kbuf_state: {
      shape: sql_table
      label: "kernel_buffer (kmalloc, 4096 bytes)"
      k0: "0x00 | char | 'h'  (0x68)"
      k1: "0x01 | char | 'e'  (0x65)"
      k2: "0x02 | char | 'l'  (0x6c)"
      k3: "0x03 | char | 'l'  (0x6c)"
      k4: "0x04 | char | 'o'  (0x6f)"
      k5: "0x05 | char | '\\n' (0x0a)"
      k6: "0x06..0xFFF | char | 0x00 (zeroed)"
      k7: "buffer_data_len = 6   buffer_size = 4096"
    }
    kbuf_state.style.fill: "#ffebee"
    kbuf_state.style.stroke: "#b71c1c"
    fpos_struct: {
      shape: sql_table
      label: "struct file (filp) — cat's fd"
      fp0: "f_pos  | loff_t | 0  (before read)"
      fp1: "f_pos  | loff_t | 6  (after read, f_pos += 6)"
      fp2: "f_flags| unsigned | O_RDONLY"
    }
    fpos_struct.style.fill: "#fff8e1"
    fpos_struct.style.stroke: "#f9a825"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  eof_box: "EOF LOGIC — Second read() call" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    style.stroke-width: 2
    eof_check: "mydevice_read() — call 2" {
      shape: diamond
      style.fill: "#a5d6a7"
      style.stroke: "#2e7d32"
      label: "*f_pos (6) >= buffer_data_len (6) ?"
    }
    eof_return: "return 0  →  EOF" {
      shape: oval
      style.fill: "#66bb6a"
      style.stroke: "#1b5e20"
    }
    cat_exit: "cat sees read()=0 → exits loop → process exits" {
      shape: rectangle
      style.fill: "#c8e6c9"
      style.stroke: "#388e3c"
    }
  }
  bug_box: "BUG: What happens WITHOUT f_pos logic" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#c62828"
    style.stroke-width: 3
    bug_read: "mydevice_read() — BROKEN version" {
      shape: rectangle
      style.fill: "#ef9a9a"
      style.stroke: "#b71c1c"
      label: "Always copies buffer_data_len bytes\nNever checks *f_pos\nAlways returns 6"
    }
    bug_loop: "cat read loop: n=6 → n=6 → n=6 → ..." {
      shape: rectangle
      style.fill: "#ef9a9a"
      style.stroke: "#b71c1c"
      style.stroke-dash: 4
    }
    bug_effect: "INFINITE OUTPUT — hello printed forever" {
      shape: callout
      style.fill: "#d32f2f"
      style.font-color: white
      style.stroke: "#b71c1c"
    }
  }
}
legend: "Legend" {
  near: bottom-right
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#9e9e9e"
  l1: "Blue  = userspace buffers and processes" {
    style.font-color: "#1565c0"
  }
  l2: "Red   = kernel code path (hot path)" {
    style.font-color: "#b71c1c"
  }
  l3: "Yellow= syscall boundary crossing" {
    style.font-color: "#f57f17"
  }
  l4: "Green = EOF / success / exit" {
    style.font-color: "#2e7d32"
  }
  l5: "Dashed red = BUG / infinite loop" {
    style.font-color: "#c62828"
  }
}
row0.userspace_box.echo_proc.buf_echo -> row0.boundary_box.write_syscall: "write(fd, ubuf, 6) | ring3→ring0"
row0.boundary_box.write_syscall -> row0.kernel_box.vfs_write: "vfs_write dispatch"
row0.kernel_box.vfs_write -> row0.kernel_box.fops_write: "fops->write | call"
row0.kernel_box.fops_write -> row0.kernel_box.copy_from: "copy_from_user(kbuf, ubuf, 6)"
row0.kernel_box.copy_from -> row0.kernel_box.kbuf_state: "6 bytes written | data_len=6"
row0.kernel_box.copy_from.style.stroke: "#d32f2f"
row0.userspace_box.cat_proc -> row0.boundary_box.read_syscall: "read(fd, ubuf, 4096) | ring3→ring0"
row0.boundary_box.read_syscall -> row0.kernel_box.vfs_read: "vfs_read dispatch"
row0.kernel_box.vfs_read -> row0.kernel_box.fops_read: "fops->read | call"
row0.kernel_box.fops_read -> row0.kernel_box.fpos_struct: "check *f_pos=0 < data_len=6"
row0.kernel_box.fpos_struct -> row0.kernel_box.copy_to: "to_copy=min(4096,6)=6"
row0.kernel_box.copy_to -> row0.kernel_box.kbuf_state: "read from kbuf+0 | 6 bytes"
row0.kernel_box.copy_to -> row0.userspace_box.cat_proc.buf_cat: "6 bytes to userbuf | SMAP guarded" {
  style.stroke: "#28a745"
  style.stroke-dash: 3
}
row0.kernel_box.fops_read -> row0.kernel_box.fpos_struct: "*f_pos += 6  →  f_pos=6" {
  style.stroke: "#f9a825"
}
row0.kernel_box.fops_read -> row1.eof_box.eof_check: "returns 6  →  cat calls read() again" {
  style.stroke: "#388e3c"
}
row1.eof_box.eof_check -> row1.eof_box.eof_return: "YES → return 0"
row1.eof_box.eof_return -> row1.eof_box.cat_exit: "EOF | cat exits"
row1.bug_box.bug_read -> row1.bug_box.bug_loop: "no EOF condition" {
  style.stroke: "#c62828"
  style.stroke-dash: 4
  style.animated: true
}
row1.bug_box.bug_loop -> row1.bug_box.bug_effect: "hello\\nhello\\nhello..." {
  style.stroke: "#c62828"
  style.stroke-dash: 4
  style.animated: true
}