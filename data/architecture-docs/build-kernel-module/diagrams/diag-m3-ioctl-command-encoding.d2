direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title_box: "ioctl Command Number Encoding — _IO / _IOW / _IOR / _IOWR (linux/ioctl.h)" {
  style.font-size: 15
  style.bold: true
  style.fill: "#1a1a2e"
  style.font-color: "#e0e0ff"
  style.stroke: "#3a3a6e"
  style.border-radius: 4
}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bit_layout: "32-bit ioctl cmd — Bit Field Layout" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#c9d1d9"
    style.stroke: "#30363d"
    b31_30: "Bits 31-30 | 2  bits | direction   | 00=none  01=write(IOW)  10=read(IOR)  11=rdwr(IOWR)"
    b29_16: "Bits 29-16 | 14 bits | size        | sizeof(arg_type), max 16383 bytes — used by strace"
    b15_08: "Bits 15-08 | 8  bits | magic/type  | ASCII char identifying driver  e.g. 0x6B = 'k'"
    b07_00: "Bits 07-00 | 8  bits | nr (seq)    | Sequential command number within this driver: 0-255"
    note:   "macro: _IOC(dir, type, nr, size)  — all four macros expand to this"
  }
  bit_visual: "Bit Positions (MSB → LSB)" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#c9d1d9"
    style.stroke: "#30363d"
    v1: "31  30 | 29 ............. 16 | 15 ......... 8 | 7 ......... 0"
    v2: "  DIR  |   SIZE  (14 bits)   |  TYPE (8 bits) | NR  (8 bits)"
    v3: "  2b   |       14b           |      8b        |     8b      "
    v4: "─────────────────────────────────── 32 bits total ───────────"
    dir_enc: "DIR encoding: 00=_IO  01=_IOW(write to kern)  10=_IOR(read from kern)  11=_IOWR"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ex_iow: "_IOW Example: Buffer Resize" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#58a6ff"
    style.stroke: "#1f6feb"
    macro:  "MYDEVICE_IOC_RESIZE = _IOW('k', 0, unsigned long)"
    dir:    "bits 31-30 | 01        | write — userspace sends ulong to kernel"
    size:   "bits 29-16 | 0x0008   | sizeof(unsigned long) = 8 bytes"
    magic:  "bits 15-8  | 0x6B     | 'k' = 0x6B — driver magic number"
    nr:     "bits  7-0  | 0x00     | command 0 in this driver"
    result: "cmd value  | 0x40086B00  (hex) — fully encoded 32-bit constant"
    usage:  "ioctl(fd, MYDEVICE_IOC_RESIZE, and_new_size)  // arg is ptr to ulong"
  }
  ex_io: "_IO Example: Buffer Clear (no arg)" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#3fb950"
    style.stroke: "#238636"
    macro:  "MYDEVICE_IOC_CLEAR = _IO('k', 1)"
    dir:    "bits 31-30 | 00        | none — no data transfer"
    size:   "bits 29-16 | 0x0000   | sizeof = 0 — no argument"
    magic:  "bits 15-8  | 0x6B     | 'k' = 0x6B — same magic"
    nr:     "bits  7-0  | 0x01     | command 1"
    result: "cmd value  | 0x00006B01  (hex)"
    usage:  "ioctl(fd, MYDEVICE_IOC_CLEAR)  // third arg ignored by kernel"
  }
  ex_ior: "_IOR Example: Status Query" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#d2a8ff"
    style.stroke: "#8957e5"
    macro:  "MYDEVICE_IOC_STATUS = _IOR('k', 2, struct mydevice_status)"
    dir:    "bits 31-30 | 10        | read — kernel sends struct to userspace"
    size:   "bits 29-16 | 0x0028   | sizeof(struct mydevice_status) = 40 bytes"
    magic:  "bits 15-8  | 0x6B     | 'k' = 0x6B"
    nr:     "bits  7-0  | 0x02     | command 2"
    result: "cmd value  | 0x80286B02  (hex)"
    usage:  "ioctl(fd, MYDEVICE_IOC_STATUS, and_status)  // arg is ptr to struct"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  macro_table: "Kernel Macro Expansion (linux/ioctl.h)" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#c9d1d9"
    style.stroke: "#30363d"
    m1: "_IO(type,nr)         | _IOC(_IOC_NONE,  type, nr, 0)"
    m2: "_IOW(type,nr,size)   | _IOC(_IOC_WRITE, type, nr, sizeof(size))"
    m3: "_IOR(type,nr,size)   | _IOC(_IOC_READ,  type, nr, sizeof(size))"
    m4: "_IOWR(type,nr,size)  | _IOC(_IOC_READ|_IOC_WRITE, type, nr, sizeof(size))"
    m5: "_IOC_WRITE = 1  _IOC_READ = 2  (from kernel's perspective)"
    m6: "WARNING: _IOC_WRITE means kernel writes to user (_IOR from user view)"
    m7: "WARNING: _IOC_WRITE means user writes to kernel (_IOW from user view)"
    m8: "Key: naming is from USERSPACE perspective; _IOC bits are KERNEL perspective"
  }
  decode_table: "Runtime Extraction Macros" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#ffa657"
    style.stroke: "#d29922"
    d1: "_IOC_TYPE(cmd)  | extract bits 15-8  | check against MYDEVICE_IOC_MAGIC"
    d2: "_IOC_NR(cmd)    | extract bits  7-0  | check <= MYDEVICE_IOC_MAXNR"
    d3: "_IOC_SIZE(cmd)  | extract bits 29-16 | used by access_ok() for range check"
    d4: "_IOC_DIR(cmd)   | extract bits 31-30 | check if access_ok needed"
    d5: "access_ok(ptr, _IOC_SIZE(cmd))       | validates userspace pointer range"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  validation: "Kernel Handler Validation Flow (mydevice_ioctl)" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#c9d1d9"
    style.stroke: "#30363d"
    s1: "Step 1 | _IOC_TYPE(cmd) != 'k'        | return -ENOTTY  (wrong driver)"
    s2: "Step 2 | _IOC_NR(cmd) > MAXNR         | return -ENOTTY  (unknown command)"
    s3: "Step 3 | dir and _IOC_READ: access_ok  | return -EFAULT  (bad user ptr)"
    s4: "Step 4 | dir and _IOC_WRITE: access_ok | return -EFAULT  (bad user ptr)"
    s5: "Step 5 | switch(cmd) dispatch          | call resize / clear / status"
    s6: "ENOTTY = 'Inappropriate ioctl for device' — correct errno for unknown cmd"
  }
  strace_decode: "How strace Decodes ioctl (uses _IOC_SIZE)" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#f85149"
    style.stroke: "#da3633"
    st1: "strace output: ioctl(3, _IOR(0x6b, 2, [40]), {buffer_size=4096, ...}) = 0"
    st2: "strace reads bits 31-30 -> direction=read -> decodes output struct"
    st3: "strace reads bits 29-16 -> size=40 -> reads 40 bytes from user ptr"
    st4: "strace reads bits 15-8  -> type=0x6b='k' -> driver identifier"
    st5: "strace reads bits 7-0   -> nr=2 -> sequence number"
    st6: "Without size in cmd bits: strace could not decode arg without debug info"
    st7: "This is WHY size is encoded in command — enables zero-recompile tracing"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  header_contract: "mydevice.h — Shared Kernel+Userspace Header" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#c9d1d9"
    style.stroke: "#30363d"
    h1: "struct mydevice_status  | unsigned long buffer_size  | 0x00 | 8 bytes"
    h2: "struct mydevice_status  | unsigned long bytes_used   | 0x08 | 8 bytes"
    h3: "struct mydevice_status  | unsigned int  open_count   | 0x10 | 4 bytes"
    h4: "struct mydevice_status  | unsigned long read_count   | 0x18 | 8 bytes"
    h5: "struct mydevice_status  | unsigned long write_count  | 0x20 | 8 bytes"
    h6: "Total: 40 bytes (0x28)  | matches _IOC_SIZE of MYDEVICE_IOC_STATUS"
    h7: "MYDEVICE_IOC_MAGIC = 'k'  MYDEVICE_IOC_MAXNR = 2"
  }
  collision_warn: "Magic Number Collision Prevention" {
    shape: sql_table
    style.fill: "#0d1117"
    style.font-color: "#ffa657"
    style.stroke: "#d29922"
    c1: "Each driver should use a UNIQUE 8-bit magic char"
    c2: "Registry: Documentation/userspace-api/ioctl/ioctl-number.rst"
    c3: "Collision risk: wrong driver receives your command number"
    c4: "Without magic check: _IOC_TYPE validation catches misdirected ioctls"
    c5: "With magic check: ENOTTY returned for cross-driver accidents"
    c6: "Example registered: 'T'=TCGETS terminal, 'S'=SCSI, 'V'=video4linux"
    c7: "Your driver 'k'=0x6B — verify unregistered before shipping"
  }
}
title_box -> row0: "" {
  style.stroke: transparent
}
row0 -> row1: "encoded 32-bit constant" {
  style.stroke: "#58a6ff"
  style.font-color: "#58a6ff"
  style.stroke-width: 2
}
row1 -> row2: "runtime decode in handler" {
  style.stroke: "#3fb950"
  style.font-color: "#3fb950"
  style.stroke-width: 2
}
row2 -> row3: "validation + strace visibility" {
  style.stroke: "#d2a8ff"
  style.font-color: "#d2a8ff"
  style.stroke-width: 2
}
row3 -> row4: "shared ABI contract" {
  style.stroke: "#ffa657"
  style.font-color: "#ffa657"
  style.stroke-width: 2
}
row1.ex_iow -> row1.ex_io: "same magic 'k'" {
  style.stroke-dash: 4
  style.stroke: "#555"
}
row1.ex_io -> row1.ex_ior: "same magic 'k'" {
  style.stroke-dash: 4
  style.stroke: "#555"
}