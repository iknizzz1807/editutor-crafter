direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: {
  label: "-ERESTARTSYS: Signals Meet Blocking I/O"
  near: top-center
  style: {
    font-size: 20
    bold: true
    font-color: "#1a1a2e"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  process_state: "Process State (signal-handler project)" {
    direction: down
    style.fill: "#e8eaf6"
    style.stroke: "#5c6bc0"
    style.border-radius: 8
    blocked: "TASK_INTERRUPTIBLE" {
      shape: oval
      style.fill: "#ffd54f"
      style.stroke: "#f57f17"
      style.font-color: "#1a1a2e"
      style.bold: true
    }
    blocked_detail: {
      shape: sql_table
      label: "Blocked Process State"
      r0: "state      | TASK_INTERRUPTIBLE"
      r1: "wait_queue | mydevice_read_queue"
      r2: "stack_ptr  | kernel stack frame"
      r3: "pending    | 0 (no signal yet)"
    }
  }
  signal_delivery: "Signal Delivery (kernel/signal.c)" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#e91e63"
    style.border-radius: 8
    sigint_node: "SIGINT Arrives" {
      shape: hexagon
      style.fill: "#e53935"
      style.stroke: "#b71c1c"
      style.font-color: white
      style.bold: true
    }
    sig_detail: {
      shape: sql_table
      label: "Signal Pending Bits"
      r0: "sigset_t   | SIGINT (bit 1)"
      r1: "si_signo   | 2 (SIGINT)"
      r2: "TIF_SIGPENDING | set in thread_info"
      r3: "action     | check SA_RESTART flag"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wait_event_box: "wait_event_interruptible (include/linux/wait.h)" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#43a047"
    style.border-radius: 8
    macro_code: {
      label: "wait_event_interruptible internals"
      width: 420
      code: |'c
        /* Conceptual expansion */
        while (!(buffer_data_len > 0)) {
          set_current_state(TASK_INTERRUPTIBLE);
          if (signal_pending(current)) {
            /* SIGINT detected here */
            __set_current_state(TASK_RUNNING);
            return -ERESTARTSYS;  /* escape hatch */
          }
          schedule();  /* yield CPU → sleep */
        }
        /* condition true: proceed */
        return 0;
      '|
    }
    signal_check: "signal_pending(current) == true" {
      shape: diamond
      style.fill: "#ef9a9a"
      style.stroke: "#c62828"
      style.font-color: "#1a1a2e"
    }
  }
  erestartsys_node: "-ERESTARTSYS returned" {
    shape: hexagon
    style.fill: "#7b1fa2"
    style.stroke: "#4a148c"
    style.font-color: white
    style.bold: true
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  correct_path: "CORRECT PATH (mydevice_read)" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.border-radius: 8
    style.stroke-width: 3
    correct_code: {
      label: "Handler propagates -ERESTARTSYS"
      width: 400
      code: |'c
        if (wait_event_interruptible(
              mydevice_read_queue,
              buffer_data_len > 0))
          return -ERESTARTSYS; /* CORRECT */
        if (mutex_lock_interruptible(
              &mydevice_mutex))
          return -ERESTARTSYS; /* CORRECT */
      '|
    }
    correct_result: "Returns -ERESTARTSYS to VFS" {
      shape: rectangle
      style.fill: "#a5d6a7"
      style.stroke: "#2e7d32"
      style.font-color: "#1a1a2e"
    }
  }
  wrong_path: "WRONG PATH (Bug: swallowed signal)" {
    direction: down
    style.fill: "#ffebee"
    style.stroke: "#c62828"
    style.border-radius: 8
    style.stroke-width: 3
    wrong_code: {
      label: "Handler ignores -ERESTARTSYS"
      width: 400
      code: |'c
        /* BUG: ignores return value */
        wait_event_interruptible(
          mydevice_read_queue,
          buffer_data_len > 0);
        /* loops back silently — */
        /* signal swallowed!    */
        goto retry;
      '|
    }
    wrong_result: "Process UNKILLABLE (D-state)" {
      shape: rectangle
      style.fill: "#ef9a9a"
      style.stroke: "#c62828"
      style.font-color: "#b71c1c"
      style.bold: true
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vfs_dispatch: "VFS Signal Disposition (kernel/signal.c: do_signal)" {
    direction: down
    style.fill: "#fff3e0"
    style.stroke: "#ef6c00"
    style.border-radius: 8
    sa_check: "SA_RESTART set?" {
      shape: diamond
      style.fill: "#ffe082"
      style.stroke: "#f57f17"
      style.font-color: "#1a1a2e"
    }
    restart_path: "Restart syscall transparently" {
      shape: rectangle
      style.fill: "#c8e6c9"
      style.stroke: "#388e3c"
      style.font-color: "#1b5e20"
      style.bold: true
    }
    eintr_path: "Convert to -EINTR for userspace" {
      shape: rectangle
      style.fill: "#ffe082"
      style.stroke: "#f57f17"
      style.font-color: "#1a1a2e"
    }
  }
  signal_handler_prereq: "signal-handler prerequisite project" {
    direction: down
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.border-radius: 8
    style.stroke-dash: 4
    prereq_detail: {
      shape: sql_table
      label: "sigaction SA_RESTART contract"
      r0: "SA_RESTART | kernel restarts syscall"
      r1: "no SA_RESTART | errno = EINTR"
      r2: "SIGKILL     | always delivered"
      r3: "SIGSTOP     | always delivered"
    }
    userspace_code: {
      label: "Userspace sees (without SA_RESTART)"
      width: 380
      code: |'c
        /* errno=EINTR: must retry */
        while (1) {
          n = read(fd, buf, sz);
          if (n < 0 && errno == EINTR)
            continue; /* retry */
          if (n < 0)
            break;    /* real error */
          process(buf, n);
        }
      '|
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  outcomes: "Outcomes Summary" {
    direction: right
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
    style.border-radius: 8
    outcome_table: {
      shape: sql_table
      label: "Signal + Blocking I/O Outcome Matrix"
      r0: "SA_RESTART + ERESTARTSYS | transparent restart  | CORRECT"
      r1: "no SA_RESTART + ERESTARTSYS | errno=EINTR userspace | CORRECT"
      r2: "ignored ERESTARTSYS + loop | signal swallowed     | BUG"
      r3: "TASK_UNINTERRUPTIBLE wait  | unkillable D-state   | BUG"
      r4: "return 0 on signal | false EOF returned   | BUG"
    }
  }
}
row1.process_state.blocked -> row2.wait_event_box.signal_check: "sleeping here"
row1.signal_delivery.sigint_node -> row2.wait_event_box.signal_check: "SIGINT | signal_pending=true" {
  style.stroke: "#e53935"
  style.stroke-width: 2
  style.font-color: "#c62828"
}
row2.wait_event_box.signal_check -> row2.erestartsys_node: "true | returns -ERESTARTSYS" {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
  style.font-color: "#7b1fa2"
}
row2.wait_event_box.signal_check -> row3.correct_path.correct_result: "false | data arrived" {
  style.stroke: "#2e7d32"
  style.stroke-dash: 4
}
row2.erestartsys_node -> row3.correct_path.correct_code: "propagate up" {
  style.stroke: "#2e7d32"
  style.stroke-width: 3
  style.font-color: "#2e7d32"
}
row2.erestartsys_node -> row3.wrong_path.wrong_code: "ignored" {
  style.stroke: "#c62828"
  style.stroke-width: 3
  style.stroke-dash: 4
  style.font-color: "#c62828"
}
row3.correct_path.correct_result -> row4.vfs_dispatch.sa_check: "-ERESTARTSYS | to VFS" {
  style.stroke: "#2e7d32"
  style.stroke-width: 2
}
row3.wrong_path.wrong_result -> row4.vfs_dispatch: "" {
  style.stroke: "#c62828"
  style.stroke-dash: 6
  style.opacity: 0.4
}
row4.vfs_dispatch.sa_check -> row4.vfs_dispatch.restart_path: "yes | SA_RESTART" {
  style.stroke: "#388e3c"
  style.font-color: "#1b5e20"
}
row4.vfs_dispatch.sa_check -> row4.vfs_dispatch.eintr_path: "no | default" {
  style.stroke: "#ef6c00"
  style.font-color: "#bf360c"
}
row4.vfs_dispatch -> row4.signal_handler_prereq: "userspace contract" {
  style.stroke: "#1565c0"
  style.stroke-dash: 4
}
row4.vfs_dispatch.restart_path -> row5.outcomes: "SA_RESTART path" {
  style.stroke: "#388e3c"
}
row4.vfs_dispatch.eintr_path -> row5.outcomes: "EINTR path" {
  style.stroke: "#ef6c00"
}