direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Lock + Wait Queue: Read/Write Critical Sections
  **RULE: Never hold mutex while sleeping in wait_event_interruptible**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  write_path: "WRITE PATH (mydevice_write)" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    style.stroke-width: 2
    w1: "① Entry" {
      shape: rectangle
      style.fill: "#c8e6c9"
      code: |'c
        if (count == 0) return 0;
      '|
      width: 320
    }
    w2: "② O_NONBLOCK check" {
      shape: diamond
      style.fill: "#fff9c4"
      width: 320
    }
    w3: "③ wait_event_interruptible" {
      shape: rectangle
      style.fill: "#fff9c4"
      code: |'c
        wait_event_interruptible(
          write_queue,
          buffer_data_len < buffer_size
        )
      '|
      width: 320
    }
    w4: "④ mutex_lock_interruptible" {
      shape: rectangle
      style.fill: "#ffcc80"
      style.stroke: "#e65100"
      style.stroke-width: 2
      code: |'c
        if (mutex_lock_interruptible(&mu))
            return -ERESTARTSYS;
      '|
      width: 320
    }
    w_locked: "⬛ CRITICAL SECTION BEGINS" {
      shape: rectangle
      style.fill: "#ef9a9a"
      style.stroke: "#b71c1c"
      style.stroke-width: 3
      style.bold: true
    }
    w5: "⑤ Recheck under mutex" {
      shape: rectangle
      style.fill: "#ffcdd2"
      code: |'c
        if (buffer_data_len >= buffer_size) {
            mutex_unlock(&mu);
            return -EAGAIN;
        }
      '|
      width: 320
    }
    w6: "⑥ copy_from_user" {
      shape: rectangle
      style.fill: "#ffcdd2"
      style.stroke: "#c62828"
      code: |'c
        copy_from_user(
          kernel_buffer + buffer_data_len,
          buf, to_copy
        )
      '|
      width: 320
    }
    w7: "⑦ Update buffer_data_len" {
      shape: rectangle
      style.fill: "#ffcdd2"
      code: |'c
        buffer_data_len += to_copy;
      '|
      width: 320
    }
    w8: "⑧ wake_up_interruptible" {
      shape: rectangle
      style.fill: "#ce93d8"
      style.stroke: "#6a1b9a"
      style.stroke-width: 2
      code: |'c
        wake_up_interruptible(
          &read_queue
        );
      '|
      width: 320
    }
    w_unlock: "⑨ mutex_unlock" {
      shape: rectangle
      style.fill: "#ffb74d"
      style.stroke: "#e65100"
      style.stroke-width: 2
      code: |'c
        mutex_unlock(&mydevice_mutex);
        return (ssize_t)to_copy;
      '|
      width: 320
    }
    w1 -> w2: "count > 0"
    w2 -> w3: "blocking mode"
    w2 -> w4: "O_NONBLOCK + space avail"
    w3 -> w4: "woke up (space available)"
    w4 -> w_locked
    w_locked -> w5
    w5 -> w6: "space confirmed"
    w6 -> w7: "bytes copied"
    w7 -> w8
    w8 -> w_unlock
  }
  gap1: "" {
    width: 40
    style.stroke: transparent
    style.fill: transparent
  }
  read_path: "READ PATH (mydevice_read) — BLOCKING MODE" {
    direction: down
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.stroke-width: 2
    r1: "① Entry" {
      shape: rectangle
      style.fill: "#bbdefb"
      code: |'c
        if (count == 0) return 0;
      '|
      width: 320
    }
    r2: "② O_NONBLOCK check" {
      shape: diamond
      style.fill: "#fff9c4"
      width: 320
    }
    r_nonblock: "② O_NONBLOCK: check + return -EAGAIN" {
      shape: rectangle
      style.fill: "#fff9c4"
      code: |'c
        if (buffer_data_len == 0)
            return -EAGAIN;
      '|
      width: 320
    }
    r3: "③ wait_event_interruptible" {
      shape: rectangle
      style.fill: "#ffe082"
      style.stroke: "#f57f17"
      style.stroke-width: 3
      code: |'c
        wait_event_interruptible(
          read_queue,
          buffer_data_len > 0
        )
      '|
      width: 320
    }
    r3_note: "NO MUTEX HELD HERE" {
      shape: callout
      style.fill: "#ff5722"
      style.font-color: white
      style.bold: true
      style.stroke: "#bf360c"
      style.stroke-width: 2
    }
    r_signal: "Signal received?" {
      shape: diamond
      style.fill: "#fff9c4"
      width: 320
    }
    r_restart: "return -ERESTARTSYS" {
      shape: rectangle
      style.fill: "#ffccbc"
      style.stroke: "#bf360c"
      code: |'c
        return -ERESTARTSYS;
      '|
      width: 320
    }
    r4: "④ mutex_lock_interruptible" {
      shape: rectangle
      style.fill: "#ffcc80"
      style.stroke: "#e65100"
      style.stroke-width: 2
      code: |'c
        if (mutex_lock_interruptible(&mu))
            return -ERESTARTSYS;
      '|
      width: 320
    }
    r_locked: "⬛ CRITICAL SECTION BEGINS" {
      shape: rectangle
      style.fill: "#ef9a9a"
      style.stroke: "#b71c1c"
      style.stroke-width: 3
      style.bold: true
    }
    r5: "⑤ Recheck under mutex" {
      shape: rectangle
      style.fill: "#ffcdd2"
      code: |'c
        if (buffer_data_len == 0) {
            mutex_unlock(&mu);
            return -EAGAIN;
        }
      '|
      width: 320
    }
    r6: "⑥ copy_to_user" {
      shape: rectangle
      style.fill: "#ffcdd2"
      style.stroke: "#c62828"
      code: |'c
        copy_to_user(buf,
          kernel_buffer, to_copy)
      '|
      width: 320
    }
    r7: "⑦ Shift buffer (memmove)" {
      shape: rectangle
      style.fill: "#ffcdd2"
      code: |'c
        buffer_data_len -= to_copy;
        memmove(kernel_buffer,
          kernel_buffer + to_copy,
          buffer_data_len);
      '|
      width: 320
    }
    r8: "⑧ wake_up_interruptible" {
      shape: rectangle
      style.fill: "#ce93d8"
      style.stroke: "#6a1b9a"
      style.stroke-width: 2
      code: |'c
        wake_up_interruptible(
          &write_queue
        );
      '|
      width: 320
    }
    r_unlock: "⑨ mutex_unlock" {
      shape: rectangle
      style.fill: "#ffb74d"
      style.stroke: "#e65100"
      style.stroke-width: 2
      code: |'c
        mutex_unlock(&mydevice_mutex);
        return (ssize_t)to_copy;
      '|
      width: 320
    }
    r1 -> r2
    r2 -> r_nonblock: "O_NONBLOCK"
    r2 -> r3: "blocking mode"
    r3 -> r3_note
    r3 -> r_signal: "woke up"
    r_signal -> r_restart: "yes (SIGINT etc.)"
    r_signal -> r4: "no"
    r4 -> r_locked
    r_locked -> r5
    r5 -> r6: "data confirmed"
    r6 -> r7: "bytes copied"
    r7 -> r8
    r8 -> r_unlock
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  deadlock_box: "DEADLOCK SCENARIO: What happens if you hold mutex during sleep" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#b71c1c"
    style.stroke-width: 3
    dl_title: "💀 FORBIDDEN PATTERN — NEVER DO THIS" {
      shape: rectangle
      style.fill: "#b71c1c"
      style.font-color: white
      style.bold: true
    }
    dl_bad: "BAD: Reader holds mutex, then sleeps" {
      shape: rectangle
      style.fill: "#ffcdd2"
      code: |'c
        mutex_lock(&mu);              // Reader acquires mutex
        while (buffer_data_len == 0)
            wait_event(read_queue,    // Reader SLEEPS — still holds mutex!
              buffer_data_len > 0);
      '|
      width: 500
    }
    dl_sequence: "Deadlock Sequence" {
      shape: sql_table
      label: "Deadlock Timeline"
      t0: "T=0 | Reader: mutex_lock() succeeds — Reader OWNS mutex"
      t1: "T=1 | Reader: buffer empty → enters wait_event (SLEEPING, mutex HELD)"
      t2: "T=2 | Writer: copy_from_user() done → tries mutex_lock()"
      t3: "T=3 | Writer: BLOCKS — mutex owned by sleeping Reader"
      t4: "T=4 | Writer cannot call wake_up → Reader never wakes"
      t5: "T=∞ | DEADLOCK: both processes stuck forever"
    }
    dl_fix: "CORRECT: Release mutex BEFORE sleeping" {
      shape: rectangle
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
      code: |'c
        // wait_event_interruptible does this internally:
        // 1. add self to wait queue
        // 2. check condition (no mutex needed for check)
        // 3. schedule() — sleep WITHOUT holding any mutex
        // 4. on wake: recheck condition under mutex
        wait_event_interruptible(read_queue, buffer_data_len > 0);
        mutex_lock(&mu);   // acquire AFTER waking
      '|
      width: 500
    }
    dl_title -> dl_bad
    dl_bad -> dl_sequence: "causes"
    dl_sequence -> dl_fix: "fix"
  }
  gap2: "" {
    width: 40
    style.stroke: transparent
    style.fill: transparent
  }
  invariant_box: "State Invariant + Wakeup Contract" {
    direction: down
    style.fill: "#f3e5f5"
    style.stroke: "#6a1b9a"
    style.stroke-width: 2
    inv_title: "Buffer Invariant (protected by mutex)" {
      shape: sql_table
      label: "Invariant: always true inside critical section"
      i1: "0 <= buffer_data_len <= buffer_size"
      i2: "kernel_buffer[0..buffer_data_len) = valid data"
      i3: "kernel_buffer[buffer_data_len..buffer_size) = undefined"
    }
    wakeup_contract: "Wakeup Contract" {
      shape: sql_table
      label: "Who wakes whom and when"
      wc1: "write() → wake_up(read_queue)  | after buffer_data_len increases"
      wc2: "read()  → wake_up(write_queue) | after buffer_data_len decreases"
      wc3: "clear() → wake_up(write_queue) | after buffer_data_len = 0"
      wc4: "resize()→ wake_up(both)        | capacity may have changed"
    }
    recheck_note: "Why recheck after wakeup?" {
      shape: rectangle
      style.fill: "#e1bee7"
      code: |'c
        // 4 readers wake simultaneously for 1 write:
        // Reader A: wakes, acquires mutex, reads data
        // Reader B: wakes, acquires mutex — buffer EMPTY!
        //   must return -EAGAIN or re-sleep
        // Without recheck → reads uninitialized data
        if (buffer_data_len == 0) {   // MANDATORY recheck
            mutex_unlock(&mu);
            return -EAGAIN;
        }
      '|
      width: 380
    }
    nonblock_table: "O_NONBLOCK Behavior Summary" {
      shape: sql_table
      label: "O_NONBLOCK flag (filp->f_flags & O_NONBLOCK)"
      nb1: "read() + empty buffer   | blocking: sleep   | O_NONBLOCK: -EAGAIN"
      nb2: "write() + full buffer   | blocking: sleep   | O_NONBLOCK: -EAGAIN"
      nb3: "read() + data present   | both: return data | (no difference)"
      nb4: "write() + space present | both: write data  | (no difference)"
    }
    inv_title -> wakeup_contract
    wakeup_contract -> recheck_note: "thundering herd requires"
    recheck_note -> nonblock_table
  }
}
row1 -> row2: "mutex scope shown above"
row1.write_path.w8 -> row1.read_path.r3: "wake_up_interruptible(read_queue)" {
  style.stroke: "#6a1b9a"
  style.stroke-width: 2
  style.stroke-dash: 4
  style.animated: true
}
row1.read_path.r8 -> row1.write_path.w3: "wake_up_interruptible(write_queue)" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
  style.stroke-dash: 4
  style.animated: true
}
legend: "Color Legend" {
  shape: sql_table
  label: "Color Semantics"
  l1: "Red border / fill   | Critical section — mutex HELD"
  l2: "Yellow fill         | Lock acquire/release boundary"
  l3: "Purple fill         | wake_up_interruptible calls"
  l4: "Orange fill         | Wait (sleep) without mutex"
  l5: "Green fill          | Correct / safe pattern"
  l6: "Pink container      | FORBIDDEN deadlock pattern"
}
legend.near: bottom-right