direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## O_NONBLOCK: Two Personalities of the Same read()
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  userspace_box: "Userspace Call Sites" {
    direction: right
    style.fill: "#e8f4fd"
    style.stroke: "#5b9bd5"
    style.border-radius: 8
    blocking_open: {
      label: "open('/dev/mydevice', O_RDONLY)"
      shape: rectangle
      style.fill: "#dbeafe"
      style.stroke: "#3b82f6"
      style.bold: true
    }
    nonblock_open: {
      label: "open('/dev/mydevice', O_RDONLY | O_NONBLOCK)"
      shape: rectangle
      style.fill: "#fef3c7"
      style.stroke: "#d97706"
      style.bold: true
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_col: "BLOCKING MODE (default)" {
    direction: down
    style.fill: "#eff6ff"
    style.stroke: "#3b82f6"
    style.border-radius: 6
    b_syscall: {
      label: "read(fd, buf, count)"
      shape: rectangle
      style.fill: "#dbeafe"
      style.stroke: "#3b82f6"
      style.bold: true
    }
    b_dispatch: {
      label: "mydevice_read()\n(kernel handler)"
      shape: rectangle
      style.fill: "#dbeafe"
      style.stroke: "#3b82f6"
    }
    b_check_flags: {
      shape: sql_table
      label: "filp->f_flags check (kernel)"
      f1: "f_flags & O_NONBLOCK | false"
      f2: "buffer_data_len      | 0 (empty)"
      f3: "decision             | enter wait path"
    }
    b_wait: {
      label: "wait_event_interruptible(\n  mydevice_read_queue,\n  buffer_data_len > 0\n)"
      shape: rectangle
      style.fill: "#bfdbfe"
      style.stroke: "#2563eb"
      style.border-radius: 4
      width: 360
    }
    b_sleep: {
      label: "TASK_INTERRUPTIBLE\nProcess sleeps — CPU released"
      shape: rectangle
      style.fill: "#93c5fd"
      style.stroke: "#1d4ed8"
      style.bold: true
    }
    b_signal_check: {
      label: "signal_pending(current)?"
      shape: diamond
      style.fill: "#fde68a"
      style.stroke: "#d97706"
    }
    b_erestartsys: {
      label: "return -ERESTARTSYS\n(→ EINTR to userspace\n or syscall restart)"
      shape: rectangle
      style.fill: "#fecaca"
      style.stroke: "#dc2626"
      style.border-radius: 4
    }
    b_woken: {
      label: "wake_up_interruptible()\ncalled by writer"
      shape: rectangle
      style.fill: "#bbf7d0"
      style.stroke: "#16a34a"
    }
    b_recheck: {
      label: "Recheck: buffer_data_len > 0?"
      shape: diamond
      style.fill: "#fde68a"
      style.stroke: "#d97706"
    }
    b_mutex: {
      label: "mutex_lock_interruptible()\nacquire buffer lock"
      shape: rectangle
      style.fill: "#dbeafe"
      style.stroke: "#3b82f6"
    }
    b_copy: {
      label: "copy_to_user(buf, kernel_buffer, n)"
      shape: rectangle
      style.fill: "#bbf7d0"
      style.stroke: "#16a34a"
    }
    b_return: {
      label: "return n  (bytes read)"
      shape: rectangle
      style.fill: "#dcfce7"
      style.stroke: "#15803d"
      style.bold: true
    }
  }
  right_col: "NON-BLOCKING MODE (O_NONBLOCK)" {
    direction: down
    style.fill: "#fffbeb"
    style.stroke: "#d97706"
    style.border-radius: 6
    nb_syscall: {
      label: "read(fd, buf, count)"
      shape: rectangle
      style.fill: "#fef3c7"
      style.stroke: "#d97706"
      style.bold: true
    }
    nb_dispatch: {
      label: "mydevice_read()\n(same kernel handler)"
      shape: rectangle
      style.fill: "#fef3c7"
      style.stroke: "#d97706"
    }
    nb_check_flags: {
      shape: sql_table
      label: "filp->f_flags check (kernel)"
      f1: "f_flags & O_NONBLOCK | true"
      f2: "buffer_data_len      | 0 (empty)"
      f3: "decision             | immediate return"
    }
    nb_decision: {
      label: "if (filp->f_flags & O_NONBLOCK)\n  && buffer_data_len == 0"
      shape: rectangle
      style.fill: "#fde68a"
      style.stroke: "#b45309"
      style.border-radius: 4
      width: 360
    }
    nb_eagain: {
      label: "return -EAGAIN"
      shape: rectangle
      style.fill: "#fed7aa"
      style.stroke: "#ea580c"
      style.bold: true
    }
    nb_errno: {
      shape: sql_table
      label: "errno in userspace"
      e1: "errno value    | EAGAIN = 11 = EWOULDBLOCK"
      e2: "meaning        | try again later"
      e3: "same errno     | non-blocking sockets (recv)"
      e4: "same errno     | pipes, FIFOs, ttys"
    }
    nb_userloop: {
      label: "Userspace reaction"
      shape: rectangle
      style.fill: "#fef9c3"
      style.stroke: "#ca8a04"
      style.border-radius: 4
    }
    nb_userloop.code: |'c
      n = read(fd, buf, sz);
      if (n < 0 && errno == EAGAIN) {
        /* no data now — use poll/epoll */
        poll(&pfd, 1, -1);
        /* retry after poll says ready */
      }
    '|
    nb_data_avail: {
      label: "If buffer NOT empty:\nsame copy_to_user path\nreturns data immediately"
      shape: rectangle
      style.fill: "#dcfce7"
      style.stroke: "#16a34a"
      style.border-radius: 4
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: {
    shape: sql_table
    label: "Behavioral Comparison: same read() syscall, two personalities"
    style.fill: "#f0f4ff"
    style.stroke: "#4f46e5"
    r0: "Condition          | Blocking (default)           | Non-blocking (O_NONBLOCK)"
    r1: "Buffer empty       | sleep until data arrives     | return -EAGAIN immediately"
    r2: "Buffer has data    | copy data, return n          | copy data, return n"
    r3: "Signal arrives     | return -ERESTARTSYS/-EINTR   | return -ERESTARTSYS/-EINTR"
    r4: "CPU during wait    | 0% (task sleeps, preempted)  | never waits, returns fast"
    r5: "Use case           | pipes, terminals, simple IPC | event loops, epoll, servers"
    r6: "errno on no data   | (never reaches userspace)    | EAGAIN = EWOULDBLOCK = 11"
  }
}
row0.userspace_box.blocking_open -> row1.left_col.b_syscall: "fd (blocking)"
row0.userspace_box.nonblock_open -> row1.right_col.nb_syscall: "fd (O_NONBLOCK set)"
row1.left_col.b_syscall -> row1.left_col.b_dispatch: "VFS dispatch"
row1.left_col.b_dispatch -> row1.left_col.b_check_flags: "read f_flags"
row1.left_col.b_check_flags -> row1.left_col.b_wait: "O_NONBLOCK = false"
row1.left_col.b_wait -> row1.left_col.b_sleep: "schedule()"
row1.left_col.b_sleep -> row1.left_col.b_signal_check: "woken up"
row1.left_col.b_signal_check -> row1.left_col.b_erestartsys: "yes" {
  style.stroke: "#dc2626"
  style.stroke-dash: 4
}
row1.left_col.b_signal_check -> row1.left_col.b_recheck: "no"
row1.left_col.b_recheck -> row1.left_col.b_sleep: "still empty" {
  style.stroke: "#d97706"
  style.stroke-dash: 4
}
row1.left_col.b_recheck -> row1.left_col.b_mutex: "data available"
row1.left_col.b_mutex -> row1.left_col.b_copy: "lock acquired"
row1.left_col.b_copy -> row1.left_col.b_return: "copied OK"
row1.right_col.nb_syscall -> row1.right_col.nb_dispatch: "VFS dispatch"
row1.right_col.nb_dispatch -> row1.right_col.nb_check_flags: "read f_flags"
row1.right_col.nb_check_flags -> row1.right_col.nb_decision: "O_NONBLOCK = true"
row1.right_col.nb_decision -> row1.right_col.nb_eagain: "empty → immediate exit" {
  style.stroke: "#ea580c"
  style.bold: true
}
row1.right_col.nb_eagain -> row1.right_col.nb_errno: "syscall returns -11"
row1.right_col.nb_errno -> row1.right_col.nb_userloop: "errno = EAGAIN"
row1.right_col.nb_decision -> row1.right_col.nb_data_avail: "not empty → read data" {
  style.stroke: "#16a34a"
}
row1.left_col -> row2.comparison
row1.right_col -> row2.comparison