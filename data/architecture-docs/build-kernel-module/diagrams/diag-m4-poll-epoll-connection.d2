direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
style.fill: "#0f1117"
style.stroke: "#0f1117"
title: {
  label: "From mydevice_poll to nginx: The Full .poll Stack"
  shape: rectangle
  style: {
    fill: "#1a1d27"
    stroke: "#4a5568"
    font-color: "#e2e8f0"
    font-size: 18
    bold: true
    border-radius: 6
  }
}
title.near: top-center
legend: {
  label: "Color Key"
  shape: rectangle
  style: {
    fill: "#1a1d27"
    stroke: "#4a5568"
    font-color: "#a0aec0"
    font-size: 11
    border-radius: 4
  }
  colors: |md
    🟣 Your driver code   🔵 VFS / kernel infra
    🟢 epoll subsystem    🟡 Userspace framework
    ⬜ Other .poll impls  🔴 Hot path / wakeup
  |
}
legend.near: bottom-right
level1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  your_poll: "L1 — Your Driver  (mydevice.c)" {
    direction: down
    style: {
      fill: "#2d1b4e"
      stroke: "#805ad5"
      stroke-width: 2
      border-radius: 8
      font-color: "#e9d8fd"
      bold: true
    }
    fn: {
      shape: class
      label: "mydevice_poll (mydevice.c:poll)"
      style: {
        fill: "#44337a"
        stroke: "#805ad5"
        font-color: "#e9d8fd"
      }
      +mydevice_poll(filp, wait): "__poll_t"
      step1: "poll_wait(filp, &read_queue,  wait)"
      step2: "poll_wait(filp, &write_queue, wait)"
      step3: "if (buf_len > 0)  mask |= POLLIN"
      step4: "if (buf_len < sz) mask |= POLLOUT"
      step5: "return mask"
    }
    queues: {
      shape: sql_table
      label: "Wait Queues (mydevice globals)"
      style: {
        fill: "#322659"
        stroke: "#6b46c1"
        font-color: "#d6bcfa"
      }
      rq: "read_queue  | wait_queue_head_t | readers sleep here"
      wq: "write_queue | wait_queue_head_t | writers sleep here"
    }
  }
  other_impls: "Other Kernel .poll Implementations" {
    direction: down
    style: {
      fill: "#1a2040"
      stroke: "#63b3ed"
      stroke-width: 1
      border-radius: 8
      font-color: "#bee3f8"
      bold: true
    }
    tcp_poll: {
      shape: rectangle
      label: "tcp_poll (net/ipv4/tcp.c)"
      style: {
        fill: "#1a365d"
        stroke: "#4299e1"
        font-color: "#bee3f8"
        border-radius: 4
      }
    }
    pipe_poll: {
      shape: rectangle
      label: "pipe_poll (fs/pipe.c)"
      style: {
        fill: "#1a365d"
        stroke: "#4299e1"
        font-color: "#bee3f8"
        border-radius: 4
      }
    }
    eventfd_poll: {
      shape: rectangle
      label: "eventfd_poll (fs/eventfd.c)"
      style: {
        fill: "#1a365d"
        stroke: "#4299e1"
        font-color: "#bee3f8"
        border-radius: 4
      }
    }
    contract: {
      shape: rectangle
      label: "All implement the same contract"
      style: {
        fill: "#2a4365"
        stroke: "#63b3ed"
        font-color: "#90cdf4"
        border-radius: 4
        italic: true
      }
    }
    tcp_poll -> contract
    pipe_poll -> contract
    eventfd_poll -> contract
  }
}
level2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vfs_infra: "L2 — VFS Poll Infrastructure  (fs/select.c, include/linux/poll.h)" {
    direction: right
    style: {
      fill: "#1a2840"
      stroke: "#4299e1"
      stroke-width: 2
      border-radius: 8
      font-color: "#bee3f8"
      bold: true
    }
    poll_wait_fn: {
      shape: class
      label: "poll_wait (include/linux/poll.h)"
      style: {
        fill: "#1e3a5f"
        stroke: "#63b3ed"
        font-color: "#bee3f8"
      }
      sig: "void poll_wait(file, wqh, pt)"
      a1: "  pt == NULL → no-op (fast path)"
      a2: "  pt->_qproc(file, wqh, pt)"
      note: "Adds wqh to poll_table subscription list"
    }
    poll_table_s: {
      shape: sql_table
      label: "poll_table (include/linux/poll.h)"
      style: {
        fill: "#1e3a5f"
        stroke: "#63b3ed"
        font-color: "#bee3f8"
      }
      f1: "0x00 | poll_queue_proc | _qproc  // fn ptr: called by poll_wait"
      f2: "0x08 | __poll_t       | _key    // events of interest"
      sz: "Total: 16 bytes"
    }
    vfs_dispatch: {
      shape: class
      label: "VFS poll dispatch (fs/select.c)"
      style: {
        fill: "#1e3a5f"
        stroke: "#63b3ed"
        font-color: "#bee3f8"
      }
      fn1: "mask = file->f_op->poll(file, pt)"
      fn2: "/* calls mydevice_poll or tcp_poll … */"
    }
  }
}
level3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  epoll_sub: "L3 — epoll Subsystem  (fs/eventpoll.c)" {
    direction: right
    style: {
      fill: "#1a3020"
      stroke: "#48bb78"
      stroke-width: 2
      border-radius: 8
      font-color: "#c6f6d5"
      bold: true
    }
    epitem: {
      shape: sql_table
      label: "struct epitem (fs/eventpoll.c)"
      style: {
        fill: "#1c3829"
        stroke: "#38a169"
        font-color: "#c6f6d5"
      }
      f0: "0x00 | rb_node        | rbn      // red-black tree node"
      f1: "0x18 | list_head      | rdllink  // ready list"
      f2: "0x28 | epoll_filefd   | ffd      // {file*, fd}"
      f3: "0x38 | eventpoll*     | ep       // back-ptr to ep"
      f4: "0x40 | epoll_event    | event    // events mask + data"
      f5: "0x50 | wait_queue_entry| wait    // our entry in driver wq"
      sz: "Total: ~96 bytes"
    }
    ep_ptable: {
      shape: class
      label: "ep_ptable_queue_proc (fs/eventpoll.c)"
      style: {
        fill: "#1c3829"
        stroke: "#38a169"
        font-color: "#c6f6d5"
      }
      fn1: "/* called by poll_wait() for each wait queue */"
      fn2: "add_wait_queue(wq, &epi->wait)"
      fn3: "/* installs ep_poll_callback as wakeup fn */"
    }
    ep_ctl: {
      shape: class
      label: "epoll_ctl(EPOLL_CTL_ADD)"
      style: {
        fill: "#1c3829"
        stroke: "#38a169"
        font-color: "#c6f6d5"
      }
      s1: "1. allocate epitem"
      s2: "2. ep_item_poll(epi, &epq.pt, 1)"
      s3: "   → calls file->f_op->poll(file, pt)"
      s4: "   → poll_wait() registers ep_poll_callback"
      s5: "   → returns current readiness mask"
      s6: "3. insert epi into ep->rbr (red-black tree)"
    }
    ep_callback: {
      shape: class
      label: "ep_poll_callback (wakeup fn)"
      style: {
        fill: "#276749"
        stroke: "#48bb78"
        font-color: "#f0fff4"
        bold: true
      }
      note: "/* installed in driver wait queue */"
      s1: "add epi to ep->rdllist"
      s2: "wake_up(&ep->wq)  ← wakes epoll_wait"
      ann: "Called when wake_up_interruptible fires in driver!"
    }
  }
}
level4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  epoll_wait_layer: "L4 — epoll_wait Kernel Side  (fs/eventpoll.c)" {
    direction: right
    style: {
      fill: "#2d1a0e"
      stroke: "#ed8936"
      stroke-width: 2
      border-radius: 8
      font-color: "#feebc8"
      bold: true
    }
    ep_struct: {
      shape: sql_table
      label: "struct eventpoll (fs/eventpoll.c)"
      style: {
        fill: "#3d2010"
        stroke: "#dd6b20"
        font-color: "#feebc8"
      }
      f0: "0x00 | mutex        | mtx       // protects rdllist"
      f1: "0x28 | wait_queue_head | wq     // epoll_wait sleeps here"
      f2: "0x40 | list_head    | rdllist   // ready file descriptors"
      f3: "0x58 | rb_root_cached | rbr    // all monitored fds (O(log n))"
      sz: "Total: ~200 bytes per epoll instance"
    }
    do_epoll_wait: {
      shape: class
      label: "do_epoll_wait (fs/eventpoll.c)"
      style: {
        fill: "#3d2010"
        stroke: "#dd6b20"
        font-color: "#feebc8"
      }
      s1: "1. if rdllist non-empty → collect events → return"
      s2: "2. else: add caller to ep->wq"
      s3: "3. schedule() ← SLEEP until ep_poll_callback fires"
      s4: "4. wake: ep_send_events() → copy to userspace"
      s5: "   O(1) per event — no re-scanning all fds!"
    }
    wakeup_path: {
      shape: rectangle
      label: "Wakeup chain (hot path — red)"
      style: {
        fill: "#742a2a"
        stroke: "#fc8181"
        font-color: "#fff5f5"
        bold: true
        border-radius: 4
      }
    }
  }
}
level5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  nginx_node: "L5 — Userspace: nginx / Node.js Event Loop" {
    direction: right
    style: {
      fill: "#1a2a1a"
      stroke: "#68d391"
      stroke-width: 2
      border-radius: 8
      font-color: "#c6f6d5"
      bold: true
    }
    nginx: {
      shape: class
      label: "nginx worker (event/ngx_epoll_module.c)"
      style: {
        fill: "#1c3a1c"
        stroke: "#48bb78"
        font-color: "#c6f6d5"
      }
      loop1: "for (;;) {"
      loop2: "  nevents = epoll_wait(epfd, events, MAX, timeout_ms)"
      loop3: "  for (i = 0; i < nevents; i++) {"
      loop4: "    rev = events[i].data.ptr"
      loop5: "    rev->handler(rev)  /* conn read/write */"
      loop6: "  }"
      loop7: "}"
    }
    nodejs: {
      shape: class
      label: "Node.js libuv (src/unix/epoll.c)"
      style: {
        fill: "#1c3a1c"
        stroke: "#48bb78"
        font-color: "#c6f6d5"
      }
      uv1: "uv__io_poll(loop, timeout) {"
      uv2: "  nfds = epoll_wait(loop->backend_fd, …)"
      uv3: "  uv__run_pending(loop)"
      uv4: "  uv__io_feed(loop, w, events)"
      uv5: "  /* fires JS callbacks via v8 */"
      uv6: "}"
    }
    scale_note: {
      shape: rectangle
      label: "50,000+ simultaneous connections — one thread — because epoll is O(1) per event"
      style: {
        fill: "#276749"
        stroke: "#68d391"
        font-color: "#f0fff4"
        border-radius: 4
        italic: true
        bold: true
      }
    }
  }
}
contract_box: "The Universal .poll Contract (every pollable fd)" {
  direction: right
  style: {
    fill: "#1a1d27"
    stroke: "#a0aec0"
    stroke-width: 1
    border-radius: 6
    font-color: "#e2e8f0"
  }
  phase1: {
    shape: rectangle
    label: "Phase 1 — Subscribe\npoll_wait(filp, wq, pt)\nRegisters wq for wakeup notification"
    style: {
      fill: "#2a2d3e"
      stroke: "#667eea"
      font-color: "#c3dafe"
      border-radius: 4
    }
  }
  phase2: {
    shape: rectangle
    label: "Phase 2 — Report\nreturn current mask\nPOLLIN | POLLOUT | POLLERR"
    style: {
      fill: "#2a2d3e"
      stroke: "#667eea"
      font-color: "#c3dafe"
      border-radius: 4
    }
  }
  phase3: {
    shape: rectangle
    label: "Phase 3 — Wakeup\nwake_up_interruptible(wq)\nFires ep_poll_callback → O(1) notify"
    style: {
      fill: "#742a2a"
      stroke: "#fc8181"
      font-color: "#fff5f5"
      border-radius: 4
    }
  }
  phase1 -> phase2: "same call"
  phase2 -> phase3: "async"
}
title -> level1: ""  { style.opacity: 0 }
level1.your_poll -> level2.vfs_infra: "file_operations.poll fn ptr" {
  style: {
    stroke: "#805ad5"
    stroke-width: 2
    animated: true
    font-color: "#d6bcfa"
  }
}
level1.other_impls.contract -> level2.vfs_infra: "same .poll interface" {
  style: {
    stroke: "#4299e1"
    stroke-dash: 4
    font-color: "#90cdf4"
  }
}
level2.vfs_infra -> level3.epoll_sub: "ep_item_poll() calls f_op->poll" {
  style: {
    stroke: "#48bb78"
    stroke-width: 2
    font-color: "#c6f6d5"
  }
}
level3.epoll_sub.ep_callback -> level4.epoll_wait_layer: "wake_up(ep->wq)" {
  style: {
    stroke: "#fc8181"
    stroke-width: 3
    animated: true
    font-color: "#fed7d7"
    bold: true
  }
}
level4.epoll_wait_layer -> level5.nginx_node: "events[] → userspace" {
  style: {
    stroke: "#68d391"
    stroke-width: 2
    animated: true
    font-color: "#c6f6d5"
  }
}
level3.epoll_sub.ep_ptable -> level2.vfs_infra.poll_wait_fn: "implements _qproc" {
  style: {
    stroke: "#48bb78"
    stroke-dash: 3
    font-color: "#9ae6b4"
  }
}
level1.your_poll.queues -> level3.epoll_sub.ep_callback: "ep_poll_callback lives in read_queue / write_queue" {
  style: {
    stroke: "#fc8181"
    stroke-width: 2
    stroke-dash: 3
    animated: true
    font-color: "#fed7d7"
  }
}
contract_box -> level1: "" { style.opacity: 0 }