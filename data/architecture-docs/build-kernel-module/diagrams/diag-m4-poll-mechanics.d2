direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## `.poll` Implementation: poll_wait + Mask Return
  poll/select/epoll kernel-side mechanics — mydevice driver
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  userspace_col: "USERSPACE" {
    direction: down
    style.fill: "#e8f4f8"
    style.stroke: "#5b9bd5"
    style.border-radius: 6
    us_call: {
      label: "poll(fds, 1, timeout)"
      shape: rectangle
      style.fill: "#5b9bd5"
      style.font-color: white
      style.bold: true
    }
    us_wait: {
      label: "blocked in poll()"
      shape: rectangle
      style.fill: "#b8d4e8"
      style.stroke: "#5b9bd5"
    }
    us_result: {
      label: "poll() returns: fd is POLLIN"
      shape: rectangle
      style.fill: "#5b9bd5"
      style.font-color: white
      style.bold: true
    }
  }
  kernel_col: "KERNEL VFS POLL MACHINERY" {
    direction: down
    style.fill: "#f0f0f0"
    style.stroke: "#666"
    style.border-radius: 6
    k_entry: {
      label: "sys_poll() → do_poll() → vfs_poll()"
      shape: rectangle
      style.fill: "#888"
      style.font-color: white
    }
    k_dispatch: {
      label: "file->f_op->poll(file, poll_table)"
      shape: rectangle
      style.fill: "#666"
      style.font-color: white
      style.bold: true
    }
    k_subscribe: {
      label: "poll_wait() adds wq to poll_table"
      shape: rectangle
      style.fill: "#aaa"
      style.font-color: white
      style.italic: true
      style.stroke-dash: 3
    }
    k_sleep: {
      label: "mask == 0 and timeout not expired"
      shape: diamond
      style.fill: "#f5c518"
      style.font-color: "#333"
    }
    k_sleeping: {
      label: "kernel sleeps — waits on registered wqs"
      shape: rectangle
      style.fill: "#e8c84a"
      style.stroke: "#c8a800"
    }
    k_rewake: {
      label: "wake_up_interruptible fires — re-call .poll"
      shape: rectangle
      style.fill: "#888"
      style.font-color: white
      style.stroke-dash: 4
    }
    k_return: {
      label: "return mask to userspace"
      shape: rectangle
      style.fill: "#4caf50"
      style.font-color: white
      style.bold: true
    }
  }
  driver_col: "DRIVER: mydevice_poll() (mydevice.c)" {
    direction: down
    style.fill: "#f3e8ff"
    style.stroke: "#8b5cf6"
    style.border-radius: 6
    d_entry: {
      label: "mydevice_poll(filp, wait)"
      shape: rectangle
      style.fill: "#8b5cf6"
      style.font-color: white
      style.bold: true
    }
    d_pw_r: {
      shape: sql_table
      label: "poll_wait() — read queue (DOES NOT BLOCK)"
      r1: "poll_wait(filp, &mydevice_read_queue, wait)"
      r2: "Registers interest in read wakeups"
      r3: "Cost: O(1) — pointer store, no sleep"
    }
    d_pw_w: {
      shape: sql_table
      label: "poll_wait() — write queue (DOES NOT BLOCK)"
      r1: "poll_wait(filp, &mydevice_write_queue, wait)"
      r2: "Registers interest in write wakeups"
      r3: "BOTH queues must always be registered"
    }
    d_check: {
      label: "Sample buffer state (no lock needed)"
      shape: diamond
      style.fill: "#c4b5fd"
      style.stroke: "#8b5cf6"
    }
    d_mask: {
      shape: sql_table
      label: "__poll_t mask — bitmask assembly"
      r1: "mask = 0"
      r2: "if (buffer_data_len > 0)  → mask |= POLLIN | POLLRDNORM"
      r3: "if (buffer_data_len < buffer_size) → mask |= POLLOUT | POLLWRNORM"
      r4: "return mask"
    }
  }
  wakeup_col: "WAKEUP PATH (Writer Thread)" {
    direction: down
    style.fill: "#fff0e8"
    style.stroke: "#f97316"
    style.border-radius: 6
    w_write: {
      label: "mydevice_write() called"
      shape: rectangle
      style.fill: "#f97316"
      style.font-color: white
      style.bold: true
    }
    w_data: {
      label: "buffer_data_len += to_copy"
      shape: rectangle
      style.fill: "#fed7aa"
      style.stroke: "#f97316"
    }
    w_wake: {
      label: "wake_up_interruptible"
      shape: rectangle
      style.fill: "#f97316"
      style.font-color: white
      style.bold: true
      style.stroke-width: 3
    }
    w_note: {
      shape: sql_table
      label: "wake_up_interruptible wakes ALL waiters"
      r1: "→ kernel scheduler marks waiters runnable"
      r2: "→ poll machinery re-invokes .poll"
      r3: "→ new mask is non-zero → return to userspace"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bug_panel: "COMMON BUG: Omitting poll_wait → Missed Events / Busy Loop" {
    direction: right
    style.fill: "#fff0f0"
    style.stroke: "#ef4444"
    style.border-radius: 6
    style.stroke-width: 2
    bug_a: {
      shape: sql_table
      label: "BUG A: Forget poll_wait — never woken up"
      r1: "static __poll_t bad_poll(struct file *f, poll_table *wait) {"
      r2: "  /* BUG: no poll_wait() call */"
      r3: "  if (buffer_data_len > 0) return POLLIN;"
      r4: "  return 0;  // mask=0 forever after first call"
      r5: "}"
      r6: "Result: poll() times out even when writer adds data"
    }
    bug_b: {
      shape: sql_table
      label: "BUG B: poll_wait but always return 0 — busy spin"
      r1: "static __poll_t bad_poll(struct file *f, poll_table *wait) {"
      r2: "  poll_wait(f, &rq, wait);  // subscribes"
      r3: "  poll_wait(f, &wq, wait);"
      r4: "  return 0;   // BUG: ignores buffer state"
      r5: "}"
      r6: "Result: every wake_up re-calls poll, gets 0, loops infinitely"
    }
    bug_c: {
      shape: sql_table
      label: "BUG C: Missing POLLOUT — writers starve with full buffer"
      r1: "static __poll_t bad_poll(struct file *f, poll_table *wait) {"
      r2: "  poll_wait(f, &rq, wait);  // only read queue"
      r3: "  /* BUG: no poll_wait for write queue */"
      r4: "  if (buffer_data_len > 0) return POLLIN;"
      r5: "  return 0;"
      r6: "}"
      r7: "Result: select(writefds) never returns for this fd"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  epoll_panel: "epoll vs select/poll: How .poll Serves Both" {
    direction: right
    style.fill: "#f0fdf4"
    style.stroke: "#22c55e"
    style.border-radius: 6
    ep_select: {
      shape: sql_table
      label: "select() / poll() path — O(n) per call"
      r1: "epoll_ctl: NOT used"
      r2: "On each poll() syscall:"
      r3: "  → calls .poll on EVERY monitored fd"
      r4: "  → poll_wait registers interest"
      r5: "  → mask checked: if non-zero, return to user"
      r6: "  → if all zero: sleep on all registered wqs"
      r7: "  → any wake_up → rescan ALL fds again"
      r8: "Cost: O(n) per event. Bad at n > 1000."
    }
    ep_epoll: {
      shape: sql_table
      label: "epoll path — O(1) per event"
      r1: "epoll_ctl(EPOLL_CTL_ADD, fd, ...):"
      r2: "  → calls .poll ONCE to register wqs"
      r3: "  → poll_wait stores epoll callback in wq"
      r4: "Subsequent events:"
      r5: "  → writer calls wake_up_interruptible"
      r6: "  → epoll callback fires (no .poll re-call)"
      r7: "  → fd added to epoll ready list"
      r8: "  → epoll_wait returns O(ready) events"
      r9: "Same .poll function — different poll_table machinery"
    }
    ep_mask: {
      shape: sql_table
      label: "Return mask bits (POSIX + Linux)"
      r1: "POLLIN      | data available to read"
      r2: "POLLRDNORM  | normal-priority read (= POLLIN for char dev)"
      r3: "POLLOUT     | space available to write"
      r4: "POLLWRNORM  | normal-priority write (= POLLOUT for char dev)"
      r5: "POLLERR     | error — auto-reported, always set on error"
      r6: "POLLHUP     | hangup — remote end closed"
      r7: "POLLPRI     | urgent/out-of-band data"
      r8: "Rule: return current state accurately — spurious POLLIN OK"
    }
  }
}
row0.userspace_col.us_call -> row0.kernel_col.k_entry: "poll(fds,1,timeout) | syscall"
row0.kernel_col.k_entry -> row0.kernel_col.k_dispatch: "vfs_poll()"
row0.kernel_col.k_dispatch -> row0.driver_col.d_entry: "f_op->poll | dispatch"
row0.driver_col.d_entry -> row0.driver_col.d_pw_r: "Phase 1: subscribe"
row0.driver_col.d_pw_r -> row0.driver_col.d_pw_w: "same call"
row0.driver_col.d_pw_w -> row0.driver_col.d_check: "Phase 2: sample"
row0.driver_col.d_check -> row0.driver_col.d_mask: "evaluate"
row0.driver_col.d_mask -> row0.kernel_col.k_subscribe: "__poll_t mask | return"
row0.kernel_col.k_subscribe -> row0.kernel_col.k_sleep: "mask value?"
row0.kernel_col.k_sleep -> row0.kernel_col.k_sleeping: "mask == 0" {
  style.stroke: "#f5c518"
  style.stroke-width: 2
}
row0.kernel_col.k_sleep -> row0.kernel_col.k_return: "mask != 0 (ready)" {
  style.stroke: "#4caf50"
  style.stroke-width: 2
}
row0.kernel_col.k_sleeping -> row0.userspace_col.us_wait: "process sleeps"
row0.wakeup_col.w_write -> row0.wakeup_col.w_data: "mutex held"
row0.wakeup_col.w_data -> row0.wakeup_col.w_wake: "after mutex_unlock"
row0.wakeup_col.w_wake -> row0.wakeup_col.w_note: "fires all waiters"
row0.wakeup_col.w_wake -> row0.kernel_col.k_rewake: "wake_up_interruptible | signal" {
  style.stroke: "#f97316"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row0.kernel_col.k_rewake -> row0.driver_col.d_entry: "re-invoke .poll" {
  style.stroke: "#8b5cf6"
  style.stroke-dash: 4
}
row0.kernel_col.k_return -> row0.userspace_col.us_result: "POLLIN ready | return"
row0 -> row1: "common mistakes" {
  style.stroke-dash: 4
  style.stroke: "#ef4444"
}
row1 -> row2: "scaling context" {
  style.stroke-dash: 4
  style.stroke: "#22c55e"
}