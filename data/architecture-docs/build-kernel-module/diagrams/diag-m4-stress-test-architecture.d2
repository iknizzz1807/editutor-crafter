direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_block: {
  label: |'md
    ### Stress Test: 4 Writers × 4 Readers — Concurrent Verification
    **mydevice.ko** | mutex + wait_queue + poll | data integrity under load
  '|
}

row0: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  writers_col: {
    label: "WRITER PROCESSES"
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    style.stroke-width: 2
    w0: {
      shape: class
      label: "Writer 0 (writer.c)"
      +pattern: "char[240]"
      +seq: "uint32_t"
      +crc: "uint32_t"
      "+run(fd, n)": "void"
    }
    w1: {
      shape: class
      label: "Writer 1 (writer.c)"
      +pattern: "char[240]"
      +seq: "uint32_t"
      +crc: "uint32_t"
      "+run(fd, n)": "void"
    }
    w2: {
      shape: class
      label: "Writer 2 (writer.c)"
      +pattern: "char[240]"
      +seq: "uint32_t"
      +crc: "uint32_t"
      "+run(fd, n)": "void"
    }
    w3: {
      shape: class
      label: "Writer 3 (writer.c)"
      +pattern: "char[240]"
      +seq: "uint32_t"
      +crc: "uint32_t"
      "+run(fd, n)": "void"
    }
  }

  chunk_fmt: {
    label: "Wire Format (256B)"
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
    hdr: {
      shape: sql_table
      label: "struct chunk (mydevice_stress.h)"
      f0: "0x00 | uint32_t | magic // 0xDEADBEEF"
      f1: "0x04 | uint32_t | writer_id"
      f2: "0x08 | uint32_t | seq_num"
      f3: "0x0C | uint32_t | payload_len // 240"
      f4: "0x10 | uint8_t  | payload[240]"
      f5: "0xF0 | uint32_t | crc32 // 0x00-0xEF"
      sz: "Total: 256 bytes (4 cache lines)"
    }
  }

  readers_col: {
    label: "READER PROCESSES"
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.stroke-width: 2
    r0: {
      shape: class
      label: "Reader 0 (reader.c)"
      +chunks: "atomic_t"
      +err_crc: "atomic_t"
      +err_mag: "atomic_t"
      "+run(fd)": "void"
    }
    r1: {
      shape: class
      label: "Reader 1 (reader.c)"
      +chunks: "atomic_t"
      +err_crc: "atomic_t"
      +err_mag: "atomic_t"
      "+run(fd)": "void"
    }
    r2: {
      shape: class
      label: "Reader 2 (reader.c)"
      +chunks: "atomic_t"
      +err_crc: "atomic_t"
      +err_mag: "atomic_t"
      "+run(fd)": "void"
    }
    r3: {
      shape: class
      label: "Reader 3 (reader.c)"
      +chunks: "atomic_t"
      +err_crc: "atomic_t"
      +err_mag: "atomic_t"
      "+run(fd)": "void"
    }
  }
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  kernel_dev: {
    label: "/dev/mydevice (mydevice.ko)"
    style.fill: "#fff8e1"
    style.stroke: "#f57f17"
    style.stroke-width: 3
    
    state_table: {
      shape: sql_table
      label: "Driver State (mydevice.c)"
      s0: "kernel_buffer | char*   | Slab"
      s1: "data_len      | size_t  | used"
      s2: "capacity      | size_t  | 4096"
      s3: "lock          | mutex   | Guard"
      s4: "read_q        | wq_head | wait"
      s5: "write_q       | wq_head | wait"
    }

    ops: {
      direction: right
      style.stroke: transparent
      wpath: {
        label: "write() Path"
        code: |'c
          wait_event(write_q, len < cap);
          mutex_lock(&lock);
          copy_from_user(buf+len, u, n);
          len += n;
          wake_up(&read_q);
          mutex_unlock(&lock);
        '|
      }
      rpath: {
        label: "read() Path"
        code: |'c
          wait_event(read_q, len > 0);
          mutex_lock(&lock);
          copy_to_user(u, buf, n);
          len -= n;
          memmove(buf, buf+n, len);
          wake_up(&write_q);
          mutex_unlock(&lock);
        '|
      }
    }
  }

  race_panel: {
    label: "Critical Race Paths"
    style.fill: "#ffebee"
    style.stroke: "#c62828"
    torn: {
      label: "Torn Write"
      note: "W0 preempted mid-write; W1 overwrites."
    }
    wakeup: {
      label: "Lost Wakeup"
      note: "Signal sent before Reader sleeps."
    }
    dead: {
      label: "Deadlock"
      note: "Lock held during sleep."
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  verifier: {
    label: "Verifier (verify.py)"
    style.fill: "#e8eaf6"
    style.stroke: "#283593"
    algo: {
      label: "Verification Logic"
      code: |'python
        total_in == total_out
        for chunk in received:
          assert chunk.magic == 0xDEADBEEF
          assert crc32(chunk.data) == chunk.crc
          seen[id][seq] += 1
        assert all(seen == 1)
      '|
    }
    counters: {
      shape: sql_table
      label: "Global Stats"
      c0: "0x00 | atomic64_t | sent"
      c1: "0x08 | atomic64_t | recv"
      c2: "0x10 | atomic64_t | crc_err"
      c3: "0x18 | atomic64_t | mag_err"
    }
  }

  results: {
    label: "Test Results"
    direction: right
    style.stroke: transparent
    pass_out: {
      label: "PASS Output"
      style.fill: "#e8f5e9"
      code: |'text
        Sent: 400 chunks
        Recv: 400 chunks
        CRC Errors: 0
        Magic Errors: 0
        [PASS] Verified
      '|
    }
    fail_out: {
      label: "FAIL (No Mutex)"
      style.fill: "#ffebee"
      style.stroke-dash: 4
      code: |'text
        Sent: 400 chunks
        Recv: 384 chunks
        CRC Errors: 23
        Magic Errors: 7
        [FAIL] Corrupted
      '|
    }
  }
}

row0.writers_col -> row1.kernel_dev: "write | 256B"
row1.kernel_dev -> row0.readers_col: "read | 256B"

row0.readers_col -> row2.verifier: "verify | chunk"

row2.verifier -> row2.results.pass_out: "0 errors"
row2.verifier -> row2.results.fail_out: ">0 errors" {
  style.stroke-dash: 4
}

row1.race_panel.torn -> row1.kernel_dev: "guards" { style.stroke-dash: 3 }
row1.race_panel.dead -> row1.kernel_dev: "guards" { style.stroke-dash: 3 }

title_block.near: top-center