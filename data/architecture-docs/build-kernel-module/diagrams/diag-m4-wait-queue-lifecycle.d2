direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # Wait Queue Lifecycle: Block → Sleep → Wakeup → Recheck → Proceed
  `wait_event_interruptible(wq, buffer_data_len > 0)` — Complete State Evolution
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  entry: "Reader: read() called" {
    shape: oval
    style.fill: "#4a90d9"
    style.font-color: white
    style.bold: true
  }
  check_nonblock: "O_NONBLOCK set?" {
    shape: diamond
    style.fill: "#888888"
    style.font-color: white
    style.bold: true
  }
  eagain_ret: "return -EAGAIN" {
    shape: oval
    style.fill: "#c0392b"
    style.font-color: white
    style.bold: true
  }
  entry -> check_nonblock: ""
  check_nonblock -> eagain_ret: "yes | buffer empty"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  check_empty: "buffer_data_len == 0?" {
    shape: diamond
    style.fill: "#888888"
    style.font-color: white
    style.bold: true
  }
  skip_wait: "acquire mutex" {
    shape: rectangle
    style.fill: "#27ae60"
    style.font-color: white
    style.bold: true
    width: 180
  }
  check_empty -> skip_wait: "no — data present"
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  macro_entry: "wait_event_interruptible(read_queue, buffer_data_len > 0)" {
    shape: rectangle
    style.fill: "#2c3e50"
    style.font-color: white
    style.bold: true
    width: 520
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step_add: "Step 1: add_wait_queue()" {
    shape: rectangle
    width: 340
    style.fill: "#5d6d7e"
    style.font-color: white
    label: "Step 1 — add_wait_queue()"
    note: |md
      `current` process added to
      `read_queue` wait list
    |
  }
  step_state: "Step 2: set_current_state(TASK_INTERRUPTIBLE)" {
    shape: rectangle
    width: 420
    style.fill: "#5d6d7e"
    style.font-color: white
    label: "Step 2 — set_current_state()"
    note: |md
      Task state: RUNNING → INTERRUPTIBLE
      Signals CAN interrupt this sleep
    |
  }
  step_add -> step_state: ""
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recheck_cond: "Recheck: buffer_data_len > 0?" {
    shape: diamond
    style.fill: "#8e44ad"
    style.font-color: white
    style.bold: true
    width: 360
  }
  schedule_call: "schedule() → yield CPU" {
    shape: rectangle
    style.fill: "#c0392b"
    style.font-color: white
    style.bold: true
    width: 300
    note: |md
      **Task is OFF the CPU**
      Scheduler runs other processes
      Reader is in TASK_INTERRUPTIBLE
      state on the wait queue
    |
  }
  recheck_cond -> schedule_call: "false — go to sleep"
}
sleeping_state: "SLEEPING (TASK_INTERRUPTIBLE) — on read_queue" {
  shape: rectangle
  style.fill: "#1a252f"
  style.font-color: "#f39c12"
  style.bold: true
  style.stroke: "#f39c12"
  style.stroke-width: 3
  width: 700
  note: |md
    Reader is OFF CPU. Waiting for one of two wakeup events:
    **Event A**: Writer calls `wake_up_interruptible(&read_queue)`
    **Event B**: Signal arrives (SIGINT, SIGKILL, etc.)
  |
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wakeup_writer: "WAKEUP PATH A: Writer adds data" {
    shape: rectangle
    style.fill: "#16a085"
    style.font-color: white
    style.bold: true
    width: 360
    label: "Wakeup Path A — Writer"
    note: |md
      `buffer_data_len += to_copy`
      `wake_up_interruptible(&read_queue)`
      → Sets reader state: INTERRUPTIBLE → RUNNING
      → Adds reader to CPU run queue
    |
  }
  wakeup_signal: "WAKEUP PATH B: Signal delivered" {
    shape: rectangle
    style.fill: "#c0392b"
    style.font-color: white
    style.bold: true
    width: 340
    label: "Wakeup Path B — Signal"
    note: |md
      SIGINT / SIGKILL / SIGTERM
      `signal_pending(current)` → true
      State: INTERRUPTIBLE → RUNNING
      macro returns **-ERESTARTSYS**
    |
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  erestartsys: "return -ERESTARTSYS" {
    shape: oval
    style.fill: "#c0392b"
    style.font-color: white
    style.bold: true
    width: 260
  }
  syscall_layer: "Syscall layer: SA_RESTART?" {
    shape: diamond
    style.fill: "#7f8c8d"
    style.font-color: white
    style.bold: true
    width: 300
  }
  eintr: "errno = EINTR → userspace" {
    shape: oval
    style.fill: "#e74c3c"
    style.font-color: white
    width: 280
  }
  restart: "Syscall restarted transparently" {
    shape: oval
    style.fill: "#27ae60"
    style.font-color: white
    width: 300
  }
  erestartsys -> syscall_layer: ""
  syscall_layer -> eintr: "no SA_RESTART"
  syscall_layer -> restart: "SA_RESTART set"
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recheck_after_wake: "Mandatory recheck: buffer_data_len > 0?" {
    shape: diamond
    style.fill: "#8e44ad"
    style.font-color: white
    style.bold: true
    width: 400
  }
  spurious_note: "Spurious Wakeup / Thundering Herd" {
    shape: rectangle
    style.fill: "#7f8c8d"
    style.font-color: white
    width: 340
    label: "Back to sleep — spurious/stolen"
    note: |md
      Another reader consumed data first,
      OR kernel issued a spurious wakeup.
      `set_current_state(TASK_INTERRUPTIBLE)`
      `schedule()` — sleep again on queue
    |
  }
  recheck_after_wake -> spurious_note: "false — data gone"
}
row8: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  remove_from_wq: "remove_from_wait_queue(), set TASK_RUNNING" {
    shape: rectangle
    style.fill: "#2980b9"
    style.font-color: white
    style.bold: true
    width: 500
  }
}
row9: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  acquire_mutex: "mutex_lock_interruptible(&mydevice_mutex)" {
    shape: rectangle
    style.fill: "#2c3e50"
    style.font-color: white
    style.bold: true
    width: 480
    mutex_interrupted: "interrupted?" {
      shape: diamond
      style.fill: "#7f8c8d"
      style.font-color: white
    }
    mutex_erestart: "return -ERESTARTSYS" {
      shape: oval
      style.fill: "#c0392b"
      style.font-color: white
    }
    mutex_interrupted -> mutex_erestart: "yes | signal"
  }
}
row10: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recheck_mutex: "Recheck under mutex: buffer_data_len > 0?" {
    shape: diamond
    style.fill: "#8e44ad"
    style.font-color: white
    style.bold: true
    width: 440
  }
  stolen_after_lock: "return -EAGAIN" {
    shape: oval
    style.fill: "#e67e22"
    style.font-color: white
    width: 220
    label: "return -EAGAIN\n(data stolen post-wakeup)"
  }
  recheck_mutex -> stolen_after_lock: "false — race lost"
}
row11: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  do_copy: "copy_to_user(buf, kernel_buffer, to_copy)" {
    shape: rectangle
    style.fill: "#27ae60"
    style.font-color: white
    style.bold: true
    width: 440
  }
  update_buf: "buffer_data_len -= to_copy; memmove(...)" {
    shape: rectangle
    style.fill: "#27ae60"
    style.font-color: white
    style.bold: true
    width: 440
  }
  do_copy -> update_buf: ""
}
row12: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wake_writers: "wake_up_interruptible(&write_queue)" {
    shape: rectangle
    style.fill: "#16a085"
    style.font-color: white
    style.bold: true
    width: 440
  }
  unlock_ret: "mutex_unlock(); return to_copy" {
    shape: oval
    style.fill: "#4a90d9"
    style.font-color: white
    style.bold: true
    width: 380
  }
  wake_writers -> unlock_ret: ""
}
legend: "Legend" {
  near: bottom-right
  shape: rectangle
  style.fill: "#1a252f"
  style.font-color: white
  style.stroke: "#4a90d9"
  width: 320
  l1: "Blue oval   = entry / success exit" {
    style.fill: "#4a90d9"
    style.font-color: white
  }
  l2: "Red oval    = error exit / signal" {
    style.fill: "#c0392b"
    style.font-color: white
  }
  l3: "Green box   = success path" {
    style.fill: "#27ae60"
    style.font-color: white
  }
  l4: "Purple diamond = condition recheck" {
    style.fill: "#8e44ad"
    style.font-color: white
  }
  l5: "Dark box    = sleeping state" {
    style.fill: "#1a252f"
    style.font-color: "#f39c12"
    style.stroke: "#f39c12"
  }
}
row0 -> row1: "blocking mode | no O_NONBLOCK"
row1.check_empty -> row2: "true — buffer empty"
row1.skip_wait -> row10: "data present | skip wait"
row2 -> row3: "macro entry"
row3 -> row4: "loop iteration"
row4.recheck_cond -> row4.schedule_call: "false — go to sleep"
row4.schedule_call -> sleeping_state: "CPU yielded"
sleeping_state -> row5.wakeup_writer: "Event A"
sleeping_state -> row5.wakeup_signal: "Event B"
row5.wakeup_signal -> row6.erestartsys: "-ERESTARTSYS"
row5.wakeup_writer -> row7: "reader scheduled"
row7.spurious_note -> row4: "loop back" {
  style.stroke-dash: 4
  style.stroke: "#f39c12"
}
row7.recheck_after_wake -> row8: "true — data confirmed"
row8 -> row9: "exit wait macro"
row9 -> row10: "mutex acquired"
row10 -> row11: "true — data still present"
row11 -> row12: ""
row4.recheck_cond -> row8: "true — data present (skip sleep)" {
  style.stroke-dash: 4
  style.stroke: "#27ae60"
}