vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  ## Module Lifecycle: insmod → init → running → rmmod → exit
  Kernel module state machine — Linux loadable module infrastructure
| {near: top-center}

# ── States ──────────────────────────────────────────────────────────────────

UNLOADED: {
  shape: circle
  style: {
    fill: "#1a1a2e"
    font-color: white
    stroke: "#e0e0e0"
    stroke-width: 3
    bold: true
  }
  label: |md
    **● UNLOADED**
    hello.ko on disk
    No kernel memory
    No sysfs entries
  |
}

LOADING: {
  shape: rectangle
  style: {
    fill: "#2d1b69"
    font-color: white
    stroke: "#9b59b6"
    stroke-width: 2
    border-radius: 8
    bold: true
  }
  label: |md
    **LOADING**
    finit_module() syscall active
    ─────────────────
    • vmalloc(.text/.data/.bss)
    • ELF relocation patching
    • Symbol resolution via
      kernel exported sym table
    • vermagic check
    • module_param writes
    ─────────────────
    CAP_SYS_MODULE required
  |
}

INIT_RUNNING: {
  shape: rectangle
  style: {
    fill: "#1a3a5c"
    font-color: white
    stroke: "#3498db"
    stroke-width: 2
    border-radius: 8
    bold: true
  }
  label: |md
    **INIT_RUNNING**
    module_init() executing
    ─────────────────
    • hello_init() runs in
      insmod process context
    • buffer_size validated
    • printk(KERN_INFO …)
    • Returns 0 or -errno
    ─────────────────
    Ring 0, process context
    Sleep permitted (GFP_KERNEL ok)
  |
}

LIVE: {
  shape: rectangle
  style: {
    fill: "#1a4a2e"
    font-color: white
    stroke: "#27ae60"
    stroke-width: 3
    border-radius: 8
    bold: true
    shadow: true
  }
  label: |md
    **LIVE**
    Module fully active
    ─────────────────
    • lsmod shows entry
    • /sys/module/hello/ visible
    • /sys/module/hello/parameters/
      buffer_size (0444)
    • module refcnt tracked
    • Code in kernel vmalloc space
    ─────────────────
    Invariant: buffer_size ∈ [1,1048576]
    MODULE_LICENSE("GPL") gates
    EXPORT_SYMBOL_GPL access
  |
}

INIT_FAILED: {
  shape: rectangle
  style: {
    fill: "#4a1a1a"
    font-color: "#ff6b6b"
    stroke: "#e74c3c"
    stroke-width: 2
    border-radius: 8
    bold: true
  }
  label: |md
    **INIT_FAILED**
    module_init() returned -errno
    ─────────────────
    • -EINVAL: buffer_size ≤ 0
    • -ENOMEM: kzalloc failed
    • -ENODEV: registration failed
    ─────────────────
    insmod reports error to shell
    errno propagated to userspace
  |
}

UNLOADING: {
  shape: rectangle
  style: {
    fill: "#4a3a1a"
    font-color: white
    stroke: "#f39c12"
    stroke-width: 2
    border-radius: 8
    bold: true
  }
  label: |md
    **UNLOADING**
    module_exit() executing
    ─────────────────
    • hello_exit() runs in
      rmmod process context
    • printk(KERN_INFO "unloaded")
    • /sys/module/hello/ removed
    • Unconditional — cannot fail
    • No return value checked
    ─────────────────
    __exit section reclaimed
    vmalloc pages freed by
    free_module() after exit()
  |
}

BLOCKED_BUSY: {
  shape: rectangle
  style: {
    fill: "#3a1a4a"
    font-color: "#ff9ff3"
    stroke: "#9b59b6"
    stroke-width: 2
    stroke-dash: 5
    border-radius: 8
  }
  label: |md
    **rmmod BLOCKED**
    (M2+ with open fds)
    ─────────────────
    module refcnt > 0
    try_module_get() held
    by open file descriptors
    ─────────────────
    EBUSY returned to rmmod
    Module remains LIVE
  |
}

# ── Initial state marker ──────────────────────────────────────────────────

initial: "" {
  shape: circle
  width: 30
  height: 30
  style: {
    fill: white
    stroke: white
    stroke-width: 2
  }
}

# ── Legal Transitions ─────────────────────────────────────────────────────

initial -> UNLOADED: "" {
  style: { stroke: white; stroke-width: 2 }
}

UNLOADED -> LOADING: "sudo insmod hello.ko\n[trigger: finit_module(2) syscall]\n[CAP_SYS_MODULE check passes]" {
  style: {
    stroke: "#9b59b6"
    stroke-width: 2
    font-color: "#d7bde2"
    bold: true
  }
}

LOADING -> INIT_RUNNING: "vermagic OK + symbols resolved\n[kernel: calls hello_init() fn ptr]" {
  style: {
    stroke: "#3498db"
    stroke-width: 2
    font-color: "#aed6f1"
    bold: true
  }
}

LOADING -> UNLOADED: "vermagic mismatch / symbol missing\n[-ENOEXEC / -ENOENT]" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    font-color: "#f1948a"
    stroke-dash: 4
  }
}

INIT_RUNNING -> LIVE: "hello_init() returns 0\n[kernel: module_finalize()]" {
  style: {
    stroke: "#27ae60"
    stroke-width: 3
    font-color: "#a9dfbf"
    bold: true
  }
}

INIT_RUNNING -> INIT_FAILED: "hello_init() returns -errno\n[insmod reports errno]" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    font-color: "#f1948a"
    stroke-dash: 4
  }
}

INIT_FAILED -> UNLOADED: "free_module() called by kernel\n[vmalloc pages freed]" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    font-color: "#f1948a"
    stroke-dash: 4
  }
}

LIVE -> UNLOADING: "sudo rmmod hello\n[refcnt == 0: no open fds]\n[trigger: delete_module(2) syscall]" {
  style: {
    stroke: "#f39c12"
    stroke-width: 2
    font-color: "#fad7a0"
    bold: true
  }
}

LIVE -> BLOCKED_BUSY: "sudo rmmod hello\n[refcnt > 0: open fds held]\n[kernel returns -EBUSY]" {
  style: {
    stroke: "#9b59b6"
    stroke-width: 2
    font-color: "#d7bde2"
    stroke-dash: 5
  }
}

BLOCKED_BUSY -> LIVE: "all fds closed\n[module_put() decrements refcnt]" {
  style: {
    stroke: "#9b59b6"
    stroke-width: 2
    font-color: "#d7bde2"
    stroke-dash: 5
  }
}

BLOCKED_BUSY -> UNLOADING: "refcnt drops to 0\nthen rmmod retried" {
  style: {
    stroke: "#f39c12"
    stroke-width: 2
    font-color: "#fad7a0"
    stroke-dash: 5
  }
}

UNLOADING -> UNLOADED: "free_module()\n[.text/.data/.bss vmalloc freed]" {
  style: {
    stroke: "#e0e0e0"
    stroke-width: 2
    font-color: "#d5d8dc"
    bold: true
  }
}

# ── ILLEGAL Transitions ───────────────────────────────────────────────────

UNLOADED -> LIVE: "ILLEGAL: cannot skip LOADING+INIT" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    stroke-dash: 3
    font-color: "#e74c3c"
    bold: true
  }
  target-arrowhead.shape: arrow
}

LIVE -> LOADING: "ILLEGAL: cannot reload without rmmod" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    stroke-dash: 3
    font-color: "#e74c3c"
    bold: true
  }
  target-arrowhead.shape: arrow
}

# ── Annotation legend ────────────────────────────────────────────────────

legend: |'md
  **Key Kernel Functions per Transition**
  | Transition | Kernel Function | Userspace Trigger |
  |---|---|---|
  | UNLOADED → LOADING | `load_module()` in `kernel/module/main.c` | `finit_module(2)` / `init_module(2)` |
  | vermagic check | `check_modinfo()` + `layout_and_allocate()` | automatic in load_module |
  | symbol resolve | `simplify_symbols()` via exported sym table | automatic in load_module |
  | LOADING → INIT_RUNNING | `do_init_module()` → calls `init()` fn ptr | automatic on success |
  | INIT_RUNNING → LIVE | `module_finalize()` + sysfs exposure | on `init()` returning 0 |
  | LIVE → UNLOADING | `delete_module()` → calls `exit()` fn ptr | `rmmod(8)` / `delete_module(2)` |
  | UNLOADING → UNLOADED | `free_module()` — frees vmalloc space | automatic after exit() |
  | refcnt guard (M2+) | `try_module_get()` / `module_put()` | open(2) / close(2) on /dev/node |

  **__init / __exit ELF sections:**
  `__init` → `.init.text` — freed by kernel after init() returns 0 (page reclaim)
  `__exit` → `.exit.text` — discarded if module compiled `obj-y` (built-in)
'| {
  near: bottom-center
  style: {
    fill: "#0d0d1a"
    font-color: "#bdc3c7"
    stroke: "#4a4a6a"
    stroke-width: 1
    border-radius: 6
    font-size: 12
  }
}