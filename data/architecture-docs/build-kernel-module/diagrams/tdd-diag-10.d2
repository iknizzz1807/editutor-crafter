vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |'md'
  ## f_pos Tracking and EOF Contract: `echo hello > /dev/mydevice && cat /dev/mydevice`
  *Per-fd file position enables correct EOF signaling — the most critical invariant in Milestone 2*
'| {
  near: top-center
  style: {
    font-size: 14
    bold: false
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# WRITE PATH
# ─────────────────────────────────────────────────────────────────────────────
write_path: "① WRITE PATH  (echo hello > /dev/mydevice)" {
  style: {
    fill: "#EDE7F6"
    stroke: "#7B1FA2"
    stroke-width: 2
    border-radius: 8
    font-size: 13
    bold: true
  }
  
  shell_write: "Shell / echo\nwrite(fd, \"hello\\n\", 6)" {
    shape: rectangle
    style: {
      fill: "#CE93D8"
      stroke: "#7B1FA2"
      stroke-width: 2
      font-size: 12
      bold: true
    }
  }
  
  syscall_w: "Syscall Boundary\nwrite(2) → ring 3→0\nVFS → mydevice_write()" {
    shape: hexagon
    style: {
      fill: "#9C27B0"
      font-color: white
      stroke: "#4A148C"
      stroke-width: 2
      font-size: 11
    }
  }
  
  mydevice_write: "mydevice_write()\nfilp, buf __user, count=6, f_pos" {
    shape: rectangle
    style: {
      fill: "#6A1B9A"
      font-color: white
      stroke: "#4A148C"
      stroke-width: 2
      font-size: 11
      bold: true
    }
  }
  
  copy_from: "copy_from_user(\n  kernel_buffer,   ← dst (kernel)\n  buf,             ← src (__user)\n  6                ← bytes\n)\nreturns 0  →  full success" {
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#AB47BC"
      stroke-width: 2
      font-size: 11
      font: mono
    }
  }
  
  write_state: "State after write:\n──────────────────────────────\nkernel_buffer[0..5] = 'hello\\n'\nbuffer_data_len     = 6\nbuffer_size         = 4096\n*f_pos reset to     = 0\n  (overwrite model: each write\n   resets position for next read)" {
    shape: rectangle
    style: {
      fill: "#A5D6A7"
      stroke: "#2E7D32"
      stroke-width: 2
      font-size: 11
      font: mono
      bold: false
    }
  }
  
  shell_write -> syscall_w: "count=6\nbuf='hello\\n'" {
    style: { stroke: "#7B1FA2"; stroke-width: 2; font-size: 11 }
  }
  syscall_w -> mydevice_write: "dispatched via\nfile_operations.write" {
    style: { stroke: "#9C27B0"; stroke-width: 2; font-size: 11 }
  }
  mydevice_write -> copy_from: "to_copy = min(6, 4096) = 6\nmemset(kernel_buffer, 0, 4096)\nthen copy_from_user()" {
    style: { stroke: "#AB47BC"; stroke-width: 2; font-size: 11 }
  }
  copy_from -> write_state: "not_copied = 0\nbuffer_data_len = 6\nreturn (ssize_t)6" {
    style: { stroke: "#2E7D32"; stroke-width: 2; font-size: 11 }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# KERNEL BUFFER (shared state)
# ─────────────────────────────────────────────────────────────────────────────
kernel_buf_container: "KERNEL BUFFER  (kzalloc, 4096 bytes)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 3
    border-radius: 6
    font-size: 13
    bold: true
  }
  
  buf_layout: |'md'
    | Byte offset | Value      | Status        |
    |-------------|------------|---------------|
    | 0           | `'h'`      | **valid**     |
    | 1           | `'e'`      | **valid**     |
    | 2           | `'l'`      | **valid**     |
    | 3           | `'l'`      | **valid**     |
    | 4           | `'o'`      | **valid**     |
    | 5           | `'\\n'`   | **valid**     |
    | 6 … 4095    | `0x00`     | free (zeroed) |
    
    `buffer_data_len = 6`   `buffer_size = 4096`
'| {
    style: { font-size: 11 }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# struct file — per-fd state
# ─────────────────────────────────────────────────────────────────────────────
struct_file: "struct file  (per open() fd)" {
  style: {
    fill: "#FFF8E1"
    stroke: "#F57F17"
    stroke-width: 3
    border-radius: 6
    font-size: 13
    bold: true
  }
  
  f_pos_box: "loff_t  f_pos\n─────────────────────────────────────────────────\nAfter write:  f_pos = 0   ← reset by mydevice_write\nAfter read1:  f_pos = 6   ← advanced by to_copy\nAfter read2:  f_pos = 6   ← NOT advanced (EOF)\n\n⚠  f_pos is PER FILE DESCRIPTOR\n   Two processes opening the same device\n   each get independent f_pos values.\n   This is the VFS struct file, NOT the inode." {
    style: {
      fill: "#FFECB3"
      stroke: "#FF8F00"
      stroke-width: 2
      font-size: 11
      font: mono
    }
  }
  
  f_flags_box: "unsigned int  f_flags\n─────────────────────────────────────────────\nO_RDONLY / O_WRONLY / O_RDWR\nO_NONBLOCK  (checked in M4 blocking I/O)\n\nNot examined in M2 read/write handlers" {
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 1
      font-size: 10
      font: mono
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# READ PATH — first read()
# ─────────────────────────────────────────────────────────────────────────────
read_path: "② READ PATH — First read()  (cat invokes read(fd, buf, 4096))" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
    font-size: 13
    bold: true
  }
  
  cat_proc: "cat process\nread(fd, buf, 4096)" {
    shape: rectangle
    style: {
      fill: "#81C784"
      stroke: "#2E7D32"
      stroke-width: 2
      font-size: 12
      bold: true
    }
  }
  
  syscall_r1: "Syscall Boundary\nread(2) → ring 3→0\nVFS → mydevice_read()" {
    shape: hexagon
    style: {
      fill: "#388E3C"
      font-color: white
      stroke: "#1B5E20"
      stroke-width: 2
      font-size: 11
    }
  }
  
  mydevice_read1: "mydevice_read()\n*f_pos = 0  (from struct file)" {
    shape: rectangle
    style: {
      fill: "#1B5E20"
      font-color: white
      stroke: "#0D3B12"
      stroke-width: 2
      font-size: 11
      bold: true
    }
  }
  
  eof_check1: "EOF check:\n*f_pos (0) >= buffer_data_len (6)?\n→ NO  →  proceed with read" {
    shape: diamond
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
      font-size: 11
    }
  }
  
  copy_to1: "available = 6 - 0 = 6\nto_copy   = min(4096, 6) = 6\n\ncopy_to_user(\n  buf,            ← dst (__user)\n  kernel_buffer,  ← src (kernel[0])\n  6               ← bytes\n)\nreturns 0  →  success" {
    shape: rectangle
    style: {
      fill: "#F1F8E9"
      stroke: "#7CB342"
      stroke-width: 2
      font-size: 11
      font: mono
    }
  }
  
  advance_fpos: "*f_pos += 6\n*f_pos is now 6\nreturn (ssize_t) 6" {
    shape: rectangle
    style: {
      fill: "#DCEDC8"
      stroke: "#558B2F"
      stroke-width: 2
      font-size: 11
      font: mono
      bold: true
    }
  }
  
  cat_output: "cat receives 6 bytes\nwrites to stdout: \"hello\\n\"\nOutputs: hello" {
    shape: rectangle
    style: {
      fill: "#AED581"
      stroke: "#33691E"
      stroke-width: 2
      font-size: 11
    }
  }
  
  cat_proc -> syscall_r1: "count=4096\nbuf=userspace ptr" {
    style: { stroke: "#2E7D32"; stroke-width: 2; font-size: 11 }
  }
  syscall_r1 -> mydevice_read1: "dispatched via\nfile_operations.read" {
    style: { stroke: "#388E3C"; stroke-width: 2; font-size: 11 }
  }
  mydevice_read1 -> eof_check1: "Step 1: check EOF\n*f_pos=0, data_len=6" {
    style: { stroke: "#1B5E20"; stroke-width: 2; font-size: 11 }
  }
  eof_check1 -> copy_to1: "NOT EOF\nhas data" {
    style: { stroke: "#2E7D32"; stroke-width: 2; font-size: 11 }
  }
  copy_to1 -> advance_fpos: "not_copied=0\ncopy succeeded" {
    style: { stroke: "#558B2F"; stroke-width: 2; font-size: 11 }
  }
  advance_fpos -> cat_output: "return 6\n(positive: more may exist)" {
    style: { stroke: "#33691E"; stroke-width: 2; font-size: 11 }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# READ PATH — second read() → EOF
# ─────────────────────────────────────────────────────────────────────────────
read_path2: "③ READ PATH — Second read()  → EOF → cat terminates" {
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
    border-radius: 8
    font-size: 13
    bold: true
  }
  
  cat_retry: "cat process\nread(fd, buf, 4096)\n[second call in loop]" {
    shape: rectangle
    style: {
      fill: "#FFCC80"
      stroke: "#E65100"
      stroke-width: 2
      font-size: 12
      bold: true
    }
  }
  
  syscall_r2: "Syscall Boundary\nread(2) → VFS → mydevice_read()" {
    shape: hexagon
    style: {
      fill: "#E65100"
      font-color: white
      stroke: "#BF360C"
      stroke-width: 2
      font-size: 11
    }
  }
  
  mydevice_read2: "mydevice_read()\n*f_pos = 6  (persisted from read 1)" {
    shape: rectangle
    style: {
      fill: "#BF360C"
      font-color: white
      stroke: "#870000"
      stroke-width: 2
      font-size: 11
      bold: true
    }
  }
  
  eof_check2: "EOF check:\n*f_pos (6) >= buffer_data_len (6)?\n→ YES  →  return 0" {
    shape: diamond
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
      stroke-width: 3
      font-size: 11
      bold: true
    }
  }
  
  return_zero: "return 0\n(EOF signal to VFS)" {
    shape: rectangle
    style: {
      fill: "#FF6D00"
      font-color: white
      stroke: "#BF360C"
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
  
  cat_exits: "cat's read loop:\nwhile ((n = read(fd, buf, N)) > 0)\n  write(stdout, buf, n);\n\nn == 0  →  loop exits\ncat closes fd and terminates" {
    shape: rectangle
    style: {
      fill: "#FFCCBC"
      stroke: "#BF360C"
      stroke-width: 2
      font-size: 11
      font: mono
    }
  }
  
  cat_retry -> syscall_r2: "same fd\n*f_pos persists" {
    style: { stroke: "#E65100"; stroke-width: 2; font-size: 11 }
  }
  syscall_r2 -> mydevice_read2: "dispatched" {
    style: { stroke: "#E65100"; stroke-width: 2; font-size: 11 }
  }
  mydevice_read2 -> eof_check2: "Step 1: check EOF\n*f_pos=6, data_len=6" {
    style: { stroke: "#BF360C"; stroke-width: 2; font-size: 11 }
  }
  eof_check2 -> return_zero: "EOF!\n6 >= 6" {
    style: { stroke: "#E65100"; stroke-width: 3; font-size: 12; bold: true }
  }
  return_zero -> cat_exits: "0 propagated back to\ncat's C runtime" {
    style: { stroke: "#BF360C"; stroke-width: 2; font-size: 11 }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# BUG BOX — what happens without EOF
# ─────────────────────────────────────────────────────────────────────────────
bug_box: "⚠  BUG: Missing EOF check — cat loops infinitely" {
  style: {
    fill: "#FFEBEE"
    stroke: "#B71C1C"
    stroke-width: 3
    stroke-dash: 5
    border-radius: 6
    font-size: 13
    bold: true
  }
  
  bug_detail: |'md'
    **Root cause:** `if (*f_pos >= buffer_data_len) return 0;` is absent or uses wrong operator.
    **Symptom:** `cat /dev/mydevice` never terminates. CPU at 100% in read() syscall loop.
    **Trace:**
    - `read()` #1: returns 6 bytes  ✓
    - `read()` #2: *f_pos=6, no EOF check → available = 6-6 = 0 → to_copy=0 → copy_to_user 0 bytes → return 0
    Wait — returning 0 IS EOF. The real bug variant:
    - Missing `*f_pos` advance → `read()` always returns same 6 bytes → infinite positive loop
    - Or: returning positive count even when nothing left → infinite loop
    **Correct invariant:** `if (*f_pos >= (loff_t)buffer_data_len) return 0;`
    must appear as the FIRST check after count==0 guard.
'| {
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 1
      font-size: 11
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# CONNECTIONS between top-level containers
# ─────────────────────────────────────────────────────────────────────────────
write_path.write_state -> kernel_buf_container: "writes 6 bytes\nbuffer_data_len=6" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    font-size: 11
    font-color: "#1565C0"
    bold: true
  }
}

write_path.write_state -> struct_file: "resets *f_pos = 0\n(in mydevice_write)" {
  style: {
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 11
    font-color: "#E65100"
    stroke-dash: 4
  }
}

read_path.mydevice_read1 -> kernel_buf_container: "reads kernel_buffer[0..5]\nvia copy_to_user" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    font-size: 11
    font-color: "#1565C0"
  }
}

read_path.mydevice_read1 -> struct_file: "reads *f_pos = 0\nthen updates *f_pos += 6" {
  style: {
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 11
    font-color: "#E65100"
    stroke-dash: 4
  }
}

read_path.advance_fpos -> struct_file.f_pos_box: "persists *f_pos = 6\nin struct file" {
  style: {
    stroke: "#FF8F00"
    stroke-width: 3
    font-size: 11
    font-color: "#E65100"
    bold: true
  }
}

read_path2.mydevice_read2 -> struct_file.f_pos_box: "reads *f_pos = 6\n(set by read 1)" {
  style: {
    stroke: "#FF8F00"
    stroke-width: 3
    font-size: 11
    font-color: "#E65100"
    bold: true
    stroke-dash: 3
  }
}

read_path2.mydevice_read2 -> kernel_buf_container: "reads buffer_data_len = 6\nfor EOF comparison" {
  style: {
    stroke: "#1565C0"
    stroke-width: 1
    font-size: 10
    stroke-dash: 3
  }
}

read_path.cat_output -> read_path2.cat_retry: "loop continues:\nnext read() call" {
  style: {
    stroke: "#FF6D00"
    stroke-width: 2
    font-size: 11
    font-color: "#E65100"
    bold: true
  }
}