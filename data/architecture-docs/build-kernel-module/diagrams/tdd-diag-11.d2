vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## `mydevice_init()` — 5-Step Init with Goto Error Unwind
  Each failed step jumps to a label that undoes **all prior steps in exact reverse order**.
| {near: top-center}
# ── STEP NODES (success staircase, left-to-right / top-to-bottom) ──────────
step1: "Step 1: kzalloc(buffer_size, GFP_KERNEL)" {
  style: {
    fill: "#B5D5F5"
    stroke: "#2563EB"
    stroke-width: 2
    bold: true
    border-radius: 6
    font-size: 14
  }
}
step2: "Step 2: alloc_chrdev_region(&dev_num, 0, 1, \"mydevice\")" {
  style: {
    fill: "#B5D5F5"
    stroke: "#2563EB"
    stroke-width: 2
    bold: true
    border-radius: 6
    font-size: 14
  }
}
step3: "Step 3: cdev_init(&my_cdev, &mydevice_fops)\n+ cdev_add(&my_cdev, dev_num, 1)" {
  style: {
    fill: "#B5D5F5"
    stroke: "#2563EB"
    stroke-width: 2
    bold: true
    border-radius: 6
    font-size: 14
  }
}
step4: "Step 4: class_create(THIS_MODULE, \"mydevice\")" {
  style: {
    fill: "#B5D5F5"
    stroke: "#2563EB"
    stroke-width: 2
    bold: true
    border-radius: 6
    font-size: 14
  }
}
step5: "Step 5: device_create(mydevice_class, NULL,\n dev_num, NULL, \"mydevice\")" {
  style: {
    fill: "#B5D5F5"
    stroke: "#2563EB"
    stroke-width: 2
    bold: true
    border-radius: 6
    font-size: 14
  }
}
success: "pr_info(\"mydevice: initialized\")\nreturn 0" {
  style: {
    fill: "#BBF7D0"
    stroke: "#16A34A"
    stroke-width: 3
    bold: true
    border-radius: 8
    font-size: 14
  }
}
# ── ERROR LABELS (cleanup chain — each falls through to the next) ────────────
err_destroy_device: "err_destroy_device:\ndevice_destroy(mydevice_class, dev_num)" {
  style: {
    fill: "#FEE2E2"
    stroke: "#DC2626"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    italic: true
  }
}
err_destroy_class: "err_destroy_class:\nclass_destroy(mydevice_class)" {
  style: {
    fill: "#FEE2E2"
    stroke: "#DC2626"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    italic: true
  }
}
err_del_cdev: "err_del_cdev:\ncdev_del(&my_cdev)" {
  style: {
    fill: "#FEE2E2"
    stroke: "#DC2626"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    italic: true
  }
}
err_unreg_region: "err_unreg_region:\nunregister_chrdev_region(dev_num, 1)" {
  style: {
    fill: "#FEE2E2"
    stroke: "#DC2626"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    italic: true
  }
}
err_free_buf: "err_free_buf:\nkfree(kernel_buffer)\n[kfree(NULL) is a no-op — safe]\nreturn ret" {
  style: {
    fill: "#FEE2E2"
    stroke: "#DC2626"
    stroke-width: 3
    border-radius: 6
    font-size: 13
    italic: true
    bold: true
  }
}
# ── CONDITION NODES (check after each step) ──────────────────────────────────
chk1: "!kernel_buffer ?" {
  shape: diamond
  style: {
    fill: "#FEF9C3"
    stroke: "#CA8A04"
    stroke-width: 2
    font-size: 13
  }
}
chk2: "ret < 0 ?" {
  shape: diamond
  style: {
    fill: "#FEF9C3"
    stroke: "#CA8A04"
    stroke-width: 2
    font-size: 13
  }
}
chk3: "ret < 0 ?" {
  shape: diamond
  style: {
    fill: "#FEF9C3"
    stroke: "#CA8A04"
    stroke-width: 2
    font-size: 13
  }
}
chk4: "IS_ERR(mydevice_class) ?" {
  shape: diamond
  style: {
    fill: "#FEF9C3"
    stroke: "#CA8A04"
    stroke-width: 2
    font-size: 13
  }
}
chk5: "IS_ERR(mydevice_device) ?" {
  shape: diamond
  style: {
    fill: "#FEF9C3"
    stroke: "#CA8A04"
    stroke-width: 2
    font-size: 13
  }
}
# ── ANNOTATION BOXES ─────────────────────────────────────────────────────────
note_order: |md
  **Cleanup rule:**
  Each label undoes exactly one step,
  then **falls through** to the label below,
  unwinding all prior steps in reverse order.
  Label chain: destroy_device → destroy_class
  → del_cdev → unreg_region → free_buf
| {
  near: bottom-right
  style: {
    fill: "#F3E8FF"
    stroke: "#7C3AED"
    stroke-width: 1
    border-radius: 8
    font-size: 12
  }
}
note_alloc: |md
  **Allocate-before-free invariant:**
  In RESIZE: `kzalloc` new buffer FIRST,
  then `kfree` old buffer only on success.
  Here: if Step 1 fails, nothing was allocated —
  `err_free_buf` still calls `kfree(NULL)` safely.
| {
  near: bottom-left
  style: {
    fill: "#ECFDF5"
    stroke: "#059669"
    stroke-width: 1
    border-radius: 8
    font-size: 12
  }
}
# ── SUCCESS PATH CONNECTIONS ─────────────────────────────────────────────────
step1 -> chk1
chk1 -> step2: "no (ok)" {
  style: { stroke: "#16A34A"; bold: true; font-size: 12 }
}
step2 -> chk2
chk2 -> step3: "no (ok)" {
  style: { stroke: "#16A34A"; bold: true; font-size: 12 }
}
step3 -> chk3
chk3 -> step4: "no (ok)" {
  style: { stroke: "#16A34A"; bold: true; font-size: 12 }
}
step4 -> chk4
chk4 -> step5: "no (ok)" {
  style: { stroke: "#16A34A"; bold: true; font-size: 12 }
}
step5 -> chk5
chk5 -> success: "no (ok)" {
  style: { stroke: "#16A34A"; stroke-width: 3; bold: true; font-size: 12 }
}
# ── ERROR JUMP CONNECTIONS ───────────────────────────────────────────────────
chk1 -> err_free_buf: "yes → -ENOMEM" {
  style: { stroke: "#DC2626"; stroke-dash: 4; bold: true; font-size: 12 }
}
chk2 -> err_free_buf: "yes → goto err_free_buf" {
  style: { stroke: "#DC2626"; stroke-dash: 4; bold: true; font-size: 12 }
}
chk3 -> err_unreg_region: "yes → goto err_unreg_region" {
  style: { stroke: "#DC2626"; stroke-dash: 4; bold: true; font-size: 12 }
}
chk4 -> err_del_cdev: "yes → goto err_del_cdev" {
  style: { stroke: "#DC2626"; stroke-dash: 4; bold: true; font-size: 12 }
}
chk5 -> err_destroy_class: "yes → goto err_destroy_class" {
  style: { stroke: "#DC2626"; stroke-dash: 4; bold: true; font-size: 12 }
}
# ── CLEANUP CHAIN FALL-THROUGH ───────────────────────────────────────────────
err_destroy_device -> err_destroy_class: "fall through ↓" {
  style: { stroke: "#7C3AED"; stroke-width: 2; bold: true; font-size: 12 }
}
err_destroy_class -> err_del_cdev: "fall through ↓" {
  style: { stroke: "#7C3AED"; stroke-width: 2; bold: true; font-size: 12 }
}
err_del_cdev -> err_unreg_region: "fall through ↓" {
  style: { stroke: "#7C3AED"; stroke-width: 2; bold: true; font-size: 12 }
}
err_unreg_region -> err_free_buf: "fall through ↓" {
  style: { stroke: "#7C3AED"; stroke-width: 2; bold: true; font-size: 12 }
}
# ── STEP ↔ LABEL CORRESPONDENCE ANNOTATIONS ─────────────────────────────────
step5 -> err_destroy_device: "undoes Step 5" {
  style: {
    stroke: "#9CA3AF"
    stroke-dash: 6
    stroke-width: 1
    font-size: 11
    font-color: "#6B7280"
  }
  target-arrowhead: {
    shape: arrow
    style.filled: false
  }
}
step4 -> err_destroy_class: "undoes Step 4" {
  style: {
    stroke: "#9CA3AF"
    stroke-dash: 6
    stroke-width: 1
    font-size: 11
    font-color: "#6B7280"
  }
  target-arrowhead: {
    shape: arrow
    style.filled: false
  }
}
step3 -> err_del_cdev: "undoes Step 3" {
  style: {
    stroke: "#9CA3AF"
    stroke-dash: 6
    stroke-width: 1
    font-size: 11
    font-color: "#6B7280"
  }
  target-arrowhead: {
    shape: arrow
    style.filled: false
  }
}
step2 -> err_unreg_region: "undoes Step 2" {
  style: {
    stroke: "#9CA3AF"
    stroke-dash: 6
    stroke-width: 1
    font-size: 11
    font-color: "#6B7280"
  }
  target-arrowhead: {
    shape: arrow
    style.filled: false
  }
}
step1 -> err_free_buf: "undoes Step 1" {
  style: {
    stroke: "#9CA3AF"
    stroke-dash: 6
    stroke-width: 1
    font-size: 11
    font-color: "#6B7280"
  }
  target-arrowhead: {
    shape: arrow
    style.filled: false
  }
}