vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # ioctl Command Number — 32-bit Encoding
  ### `_IOW` / `_IOR` / `_IO` bit-field layout · computed hex values · macro extraction
| {near: top-center}

# ─────────────────────────────────────────────────────────────────
# BIT-FIELD MAP (32-bit word, big-endian bit numbering)
# ─────────────────────────────────────────────────────────────────
bit_map: "32-bit ioctl cmd value" {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a8a"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 15
  }
  
  direction: right

  dir_field: "bits [31:30]\nDIRECTION\n2 bits" {
    style: {
      fill: "#6B21A8"
      stroke: "#9333EA"
      stroke-width: 2
      font-color: white
      bold: true
      font-size: 13
      border-radius: 4
    }
    width: 140
    height: 120
  }
  size_field: "bits [29:16]\nSIZE\n14 bits\nsizeof(arg_type)" {
    style: {
      fill: "#1e40af"
      stroke: "#3b82f6"
      stroke-width: 2
      font-color: white
      bold: true
      font-size: 13
      border-radius: 4
    }
    width: 160
    height: 120
  }
  type_field: "bits [15:8]\nTYPE / MAGIC\n8 bits\n'k' = 0x6B" {
    style: {
      fill: "#065f46"
      stroke: "#10b981"
      stroke-width: 2
      font-color: white
      bold: true
      font-size: 13
      border-radius: 4
    }
    width: 160
    height: 120
  }
  nr_field: "bits [7:0]\nNUMBER (nr)\n8 bits\ncmd index" {
    style: {
      fill: "#7c2d12"
      stroke: "#f97316"
      stroke-width: 2
      font-color: white
      bold: true
      font-size: 13
      border-radius: 4
    }
    width: 140
    height: 120
  }
}

# ─────────────────────────────────────────────────────────────────
# DIRECTION ENCODING TABLE
# ─────────────────────────────────────────────────────────────────
dir_table: "Direction field [31:30] encoding" {
  style: {
    fill: "#2d1b69"
    stroke: "#9333EA"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 14
  }
  none_row: "00  _IOC_NONE   →  _IO(type,nr)\nNo argument transferred\narg parameter: undefined / ignored" {
    style: {
      fill: "#374151"
      stroke: "#6b7280"
      font-color: "#d1d5db"
      font-size: 12
      border-radius: 3
    }
  }
  write_row: "01  _IOC_WRITE  →  _IOW(type,nr,t)\nUserspace WRITES to kernel\nKernel READS from userspace ptr" {
    style: {
      fill: "#1e3a5f"
      stroke: "#3b82f6"
      font-color: "#93c5fd"
      font-size: 12
      border-radius: 3
    }
  }
  read_row: "10  _IOC_READ   →  _IOR(type,nr,t)\nUserspace READS from kernel\nKernel WRITES to userspace ptr" {
    style: {
      fill: "#14532d"
      stroke: "#22c55e"
      font-color: "#86efac"
      font-size: 12
      border-radius: 3
    }
  }
  rw_row: "11  _IOC_RW      →  _IOWR(type,nr,t)\nBidirectional transfer\nBoth _IOC_READ and _IOC_WRITE set" {
    style: {
      fill: "#4a1d1d"
      stroke: "#ef4444"
      font-color: "#fca5a5"
      font-size: 12
      border-radius: 3
    }
  }
  naming_warning: |'md'
    ⚠️ **Name inversion trap**
    Macro names use the **userspace perspective** (`_IOW` = user writes).
    `_IOC_DIR()` bits use the **kernel perspective** (`_IOC_WRITE` = kernel reads from user).
    These are *opposite* — the #1 source of `access_ok()` validation bugs.
  '| {
    style: {
      fill: "#451a03"
      stroke: "#f59e0b"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 4
    }
  }
}

# ─────────────────────────────────────────────────────────────────
# THREE COMMAND COMPUTED VALUES
# ─────────────────────────────────────────────────────────────────
cmd_resize: "MYDEVICE_IOC_RESIZE" {
  style: {
    fill: "#1e293b"
    stroke: "#3b82f6"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 14
  }
  macro_def: "_IOW('k', 0, unsigned long)" {
    style: {
      fill: "#0f172a"
      stroke: "#3b82f6"
      font-color: "#93c5fd"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
  bit_breakdown: |'md'
    | Field | Value | Bits |
    |-------|-------|------|
    | dir   | `01` (_IOC_WRITE) | [31:30] |
    | size  | `0x0008` = 8 bytes (`sizeof(unsigned long)`) | [29:16] |
    | type  | `0x6B` = `'k'` | [15:8] |
    | nr    | `0x00` | [7:0] |
  '| {
    style: {
      fill: "#0f172a"
      stroke: "#334155"
      font-color: "#cbd5e1"
      font-size: 11
      border-radius: 3
    }
  }
  hex_val: "0x40086B00\n= (0x01<<30)|(0x0008<<16)|(0x6B<<8)|(0x00)" {
    style: {
      fill: "#1e3a5f"
      stroke: "#60a5fa"
      font-color: "#bfdbfe"
      font-size: 13
      bold: true
      border-radius: 4
      font: mono
    }
  }
  purpose: "Userspace writes new_size (unsigned long)\nto kernel for buffer resize.\nKernel calls copy_from_user(&new_size, arg, 8)" {
    style: {
      fill: "#172554"
      stroke: "#3b82f6"
      font-color: "#93c5fd"
      font-size: 11
      border-radius: 3
    }
  }
}

cmd_clear: "MYDEVICE_IOC_CLEAR" {
  style: {
    fill: "#1e293b"
    stroke: "#6b7280"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 14
  }
  macro_def: "_IO('k', 1)" {
    style: {
      fill: "#0f172a"
      stroke: "#6b7280"
      font-color: "#d1d5db"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
  bit_breakdown: |'md'
    | Field | Value | Bits |
    |-------|-------|------|
    | dir   | `00` (_IOC_NONE) | [31:30] |
    | size  | `0x0000` = 0 bytes (no arg) | [29:16] |
    | type  | `0x6B` = `'k'` | [15:8] |
    | nr    | `0x01` | [7:0] |
  '| {
    style: {
      fill: "#0f172a"
      stroke: "#334155"
      font-color: "#cbd5e1"
      font-size: 11
      border-radius: 3
    }
  }
  hex_val: "0x00006B01\n= (0x00<<30)|(0x0000<<16)|(0x6B<<8)|(0x01)" {
    style: {
      fill: "#1f2937"
      stroke: "#9ca3af"
      font-color: "#e5e7eb"
      font-size: 13
      bold: true
      border-radius: 4
      font: mono
    }
  }
  purpose: "No argument. arg is undefined — never dereference.\nmydevice_ioctl_clear() takes no parameters.\nzeros buffer + sets buffer_data_len = 0." {
    style: {
      fill: "#111827"
      stroke: "#6b7280"
      font-color: "#d1d5db"
      font-size: 11
      border-radius: 3
    }
  }
}

cmd_status: "MYDEVICE_IOC_STATUS" {
  style: {
    fill: "#1e293b"
    stroke: "#10b981"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 14
  }
  macro_def: "_IOR('k', 2, struct mydevice_status)" {
    style: {
      fill: "#0f172a"
      stroke: "#10b981"
      font-color: "#6ee7b7"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
  bit_breakdown: |'md'
    | Field | Value | Bits |
    |-------|-------|------|
    | dir   | `10` (_IOC_READ) | [31:30] |
    | size  | `0x0028` = 40 bytes (`sizeof(struct mydevice_status)`) | [29:16] |
    | type  | `0x6B` = `'k'` | [15:8] |
    | nr    | `0x02` | [7:0] |
  '| {
    style: {
      fill: "#0f172a"
      stroke: "#334155"
      font-color: "#cbd5e1"
      font-size: 11
      border-radius: 3
    }
  }
  hex_val: "0x80286B02\n= (0x02<<30)|(0x0028<<16)|(0x6B<<8)|(0x02)" {
    style: {
      fill: "#064e3b"
      stroke: "#34d399"
      font-color: "#a7f3d0"
      font-size: 13
      bold: true
      border-radius: 4
      font: mono
    }
  }
  purpose: "Kernel writes struct mydevice_status to userspace.\nKernel calls copy_to_user(user_status, &status, 40)\nSize=40 encodes struct layout for strace decoding." {
    style: {
      fill: "#022c22"
      stroke: "#10b981"
      font-color: "#6ee7b7"
      font-size: 11
      border-radius: 3
    }
  }
}

# ─────────────────────────────────────────────────────────────────
# MACRO EXTRACTION (_IOC_TYPE / _IOC_NR / _IOC_DIR / _IOC_SIZE)
# ─────────────────────────────────────────────────────────────────
macro_extract: "Decomposition Macros (include/uapi/asm-generic/ioctl.h)" {
  style: {
    fill: "#1c1917"
    stroke: "#d97706"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 14
  }
  ioc_type: "_IOC_TYPE(cmd)  →  (cmd >> 8) & 0xFF\nReturns the magic byte.\nUsed in mydevice_ioctl: if (_IOC_TYPE(cmd) != 'k') return -ENOTTY;" {
    style: {
      fill: "#292524"
      stroke: "#d97706"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
  ioc_nr: "_IOC_NR(cmd)    →  (cmd >> 0) & 0xFF\nReturns sequential command index.\nUsed in: if (_IOC_NR(cmd) > MYDEVICE_IOC_MAXNR) return -ENOTTY;" {
    style: {
      fill: "#292524"
      stroke: "#d97706"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
  ioc_dir: "_IOC_DIR(cmd)   →  (cmd >> 30) & 0x3\nReturns _IOC_NONE/WRITE/READ/RW.\nUsed in access_ok() validation path.\n_IOC_WRITE means kernel reads from user ptr.\n_IOC_READ  means kernel writes to user ptr." {
    style: {
      fill: "#292524"
      stroke: "#d97706"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
  ioc_size: "_IOC_SIZE(cmd)  →  (cmd >> 16) & 0x3FFF\nReturns sizeof(arg_type) baked at compile time.\nUsed in: access_ok((void __user *)arg, _IOC_SIZE(cmd))\nAlso used by strace to know how many bytes to display." {
    style: {
      fill: "#292524"
      stroke: "#d97706"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
}

# ─────────────────────────────────────────────────────────────────
# STRACE DECODE EXPLANATION
# ─────────────────────────────────────────────────────────────────
strace_explain: "How strace decodes ioctls without driver source" {
  style: {
    fill: "#0c0a09"
    stroke: "#f59e0b"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 14
  }
  step1: "1. strace intercepts ioctl(fd, cmd, arg) syscall" {
    style: {
      fill: "#1c1917"
      stroke: "#78716c"
      font-color: "#d6d3d1"
      font-size: 12
      border-radius: 3
    }
  }
  step2: "2. Reads _IOC_SIZE(cmd) from bits [29:16] of cmd\n   → knows exactly how many bytes arg points to\n   No driver header needed — size is in the number itself" {
    style: {
      fill: "#1c1917"
      stroke: "#f59e0b"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 3
    }
  }
  step3: "3. Reads _IOC_DIR(cmd) from bits [31:30]\n   → knows if it should capture before-call (write) or after-call (read) snapshot" {
    style: {
      fill: "#1c1917"
      stroke: "#f59e0b"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 3
    }
  }
  step4: "4. Reads _IOC_TYPE(cmd) from bits [15:8]\n   → looks up magic in its compiled-in ioctl table\n   (covers known subsystems: 'T'=termios, 'S'=SCSI, etc.)\n   Unknown magic → printed as raw hex (your 'k' driver)" {
    style: {
      fill: "#1c1917"
      stroke: "#f59e0b"
      font-color: "#fde68a"
      font-size: 12
      border-radius: 3
    }
  }
  step5: "5. For MYDEVICE_IOC_STATUS (0x80286B02):\n   strace output: ioctl(3, _IOR(0x6b, 2, [40]), 0x7ffc...) = 0\n   It decoded size=40 and dir=READ from the cmd bits alone" {
    style: {
      fill: "#1c1917"
      stroke: "#22c55e"
      font-color: "#86efac"
      font-size: 12
      border-radius: 3
      font: mono
    }
  }
  key_insight: |'md'
    **Key insight**: The 32-bit command number is *self-describing*.
    A kernel driver with zero userspace headers can be partially decoded
    by any tool that understands the `_IOC_*` bit layout.
    This is the same principle as TCP port numbers encoding protocol,
    or Ethernet ethertypes encoding frame type — structured integers
    carry metadata without out-of-band negotiation.
  '| {
    style: {
      fill: "#111827"
      stroke: "#6366f1"
      font-color: "#c7d2fe"
      font-size: 12
      border-radius: 4
    }
  }
}

# ─────────────────────────────────────────────────────────────────
# STRUCT mydevice_status SIZE ANNOTATION
# ─────────────────────────────────────────────────────────────────
status_layout: "struct mydevice_status — 40-byte layout (64-bit)" {
  style: {
    fill: "#0f172a"
    stroke: "#10b981"
    stroke-width: 2
    border-radius: 6
    font-color: white
    bold: true
    font-size: 14
  }
  f0: "offset 0x00  unsigned long  buffer_size   [8 bytes]" {
    style: { fill: "#064e3b"; stroke: "#10b981"; font-color: "#6ee7b7"; font-size: 12; border-radius: 2; font: mono }
  }
  f1: "offset 0x08  unsigned long  bytes_used    [8 bytes]" {
    style: { fill: "#064e3b"; stroke: "#10b981"; font-color: "#6ee7b7"; font-size: 12; border-radius: 2; font: mono }
  }
  f2: "offset 0x10  unsigned int   open_count    [4 bytes]" {
    style: { fill: "#1e3a5f"; stroke: "#3b82f6"; font-color: "#93c5fd"; font-size: 12; border-radius: 2; font: mono }
  }
  f3: "offset 0x14  (padding)                    [4 bytes]" {
    style: { fill: "#1f2937"; stroke: "#4b5563"; font-color: "#9ca3af"; font-size: 12; border-radius: 2; font: mono; italic: true }
  }
  f4: "offset 0x18  unsigned long  read_count    [8 bytes]" {
    style: { fill: "#064e3b"; stroke: "#10b981"; font-color: "#6ee7b7"; font-size: 12; border-radius: 2; font: mono }
  }
  f5: "offset 0x20  unsigned long  write_count   [8 bytes]" {
    style: { fill: "#064e3b"; stroke: "#10b981"; font-color: "#6ee7b7"; font-size: 12; border-radius: 2; font: mono }
  }
  f_total: "Total: 0x28 = 40 bytes  →  _IOC_SIZE(MYDEVICE_IOC_STATUS) == 40  ✓" {
    style: { fill: "#022c22"; stroke: "#34d399"; font-color: "#a7f3d0"; font-size: 13; bold: true; border-radius: 3; font: mono }
  }
}

# ─────────────────────────────────────────────────────────────────
# CONNECTIONS
# ─────────────────────────────────────────────────────────────────
bit_map.dir_field -> dir_table: "values" {
  style: { stroke: "#9333EA"; stroke-width: 2; stroke-dash: 3 }
}
bit_map.size_field -> status_layout: "_IOC_SIZE encodes\nsizeof(arg_type)" {
  style: { stroke: "#3b82f6"; stroke-width: 2; stroke-dash: 3 }
}
bit_map -> cmd_resize: "applied to\nRESIZE" {
  style: { stroke: "#3b82f6"; stroke-width: 1; stroke-dash: 5 }
}
bit_map -> cmd_clear: "applied to\nCLEAR" {
  style: { stroke: "#6b7280"; stroke-width: 1; stroke-dash: 5 }
}
bit_map -> cmd_status: "applied to\nSTATUS" {
  style: { stroke: "#10b981"; stroke-width: 1; stroke-dash: 5 }
}
bit_map -> macro_extract: "_IOC_TYPE/_NR/_DIR/_SIZE\nextract these fields" {
  style: { stroke: "#d97706"; stroke-width: 2 }
}
macro_extract -> strace_explain: "strace uses these\nsame extractions" {
  style: { stroke: "#f59e0b"; stroke-width: 2; animated: true }
}
cmd_status.hex_val -> status_layout: "size bits encode\n0x28 = 40" {
  style: { stroke: "#10b981"; stroke-width: 2; stroke-dash: 4 }
}