direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: |md
  # Shared Header: One `mydevice.h` Compiled in Two Worlds
  *Intel Manual Quality — Struct Alignment & ABI Contract*
| {near: top-center}

# ─────────────────────────────────────────────────────────────────────────────
# CENTER: THE SOURCE OF TRUTH (UAPI HEADER)
# ─────────────────────────────────────────────────────────────────────────────
header: "mydevice.h — Shared UAPI Contract" {
  style: {
    fill: "#E8F4FD"
    stroke: "#2980B9"
    stroke-width: 4
    border-radius: 8
  }

  magic: |'md
    ### Magic & IOCTL Commands
    c
    #define MYDEVICE_IOC_MAGIC  'k'  // 0x6B
    #define MYDEVICE_IOC_RESIZE \
      _IOW('k', 0, unsigned long)
    #define MYDEVICE_IOC_CLEAR \
      _IO ('k', 1)
    #define MYDEVICE_IOC_STATUS \
      _IOR('k', 2, struct mydevice_status)
    #define MYDEVICE_IOC_MAXNR  2
    
    *Macros compute command IDs based on type size.*
  '| {
    style.fill: "#D6EAF8"
    style.stroke: "#2471A3"
  }

  struct_layout: |'md
    ### struct mydevice_status
    **Size: 40 Bytes (64-bit ABI)**
    | Offset | Field | Size |
    | :--- | :--- | :--- |
    | +0x00 | `unsigned long buffer_size` | 8B |
    | +0x08 | `unsigned long bytes_used` | 8B |
    | +0x10 | `unsigned int  open_count` | 4B |
    | +0x14 | *Padding (Compiler)* | 4B |
    | +0x18 | `unsigned long read_count` | 8B |
    | +0x20 | `unsigned long write_count`| 8B |
  '| {
    style.fill: "#D6EAF8"
    style.stroke: "#2471A3"
  }

  constraints: |'md
    **Safety Constraints:**
    - Only include `<linux/ioctl.h>`
    - No `stddef.h` or `libc` headers
    - Use fixed-width types or kernel-equivalent `long`
  '| {
    style.fill: "#EBF5FB"
    style.stroke: "#5DADE2"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# LEFT: KERNEL SPACE (RING-0)
# ─────────────────────────────────────────────────────────────────────────────
kernel_space: "Kernel Build Context (ring-0)" {
  style: {
    fill: "#F4ECF7"
    stroke: "#7D3C98"
    stroke-width: 2
    border-radius: 8
  }

  k_make: "Kbuild Process" {
    style.fill: "#E8DAEF"
    desc: |'md
      **Makefile:**
      `obj-m += mydevice.o`
      `ccflags-y := -I$(PWD)`
    '|
  }

  k_gcc: "gcc -D__KERNEL__" {
    style.fill: "#D7BDE2"
    desc: |'md
      **Compilation Env:**
      - Freestanding (no libc)
      - Kernel headers path first
      - `unsigned long` matches 64-bit CPU word
    '|
  }

  k_binary: "mydevice.ko" {
    shape: package
    style: {
      fill: "#A9CCE3"
      stroke: "#1A5276"
      bold: true
    }
  }

  k_make -> k_gcc: "generates command"
  k_gcc -> k_binary: "links module"
}

# ─────────────────────────────────────────────────────────────────────────────
# RIGHT: USER SPACE (RING-3)
# ─────────────────────────────────────────────────────────────────────────────
user_space: "Userspace Build Context (ring-3)" {
  style: {
    fill: "#E9F7EF"
    stroke: "#1E8449"
    stroke-width: 2
    border-radius: 8
  }

  u_gcc: "gcc -Wall" {
    style.fill: "#D5F5E3"
    desc: |'md
      **Compilation Env:**
      - Standard Hosted (glibc)
      - `-I.` includes local header
      - Includes `sys/ioctl.h`
    '|
  }

  u_binary: "test_app" {
    shape: circle
    style: {
      fill: "#A9CCE3"
      stroke: "#1A5276"
      bold: true
    }
  }

  u_gcc -> u_binary: "links executable"
}

# ─────────────────────────────────────────────────────────────────────────────
# ANNOTATIONS & DANGER ZONES
# ─────────────────────────────────────────────────────────────────────────────
danger_zone: |'md
  ### ⚠️ ABI BREAKING HAZARDS
  | Construct | Result |
  | :--- | :--- |
  | `#include <linux/fs.h>` | Breaks Userspace build (missing headers) |
  | `atomic_t` | Unknown type in Userspace |
  | `void *` | Sizes must match (don't mix 32/64 bit) |
  | `__user` | Sparse-only tag; no-op in GCC but noisy |
'| {
  near: bottom-left
  style: {
    fill: "#FDEDEC"
    stroke: "#C0392B"
    stroke-width: 2
  }
}

sizeof_verification: |'md
  ### IOCTL Command Verification
  Command ID for `MYDEVICE_IOC_STATUS`:
  - **Direction**: `_IOR` (Read) = `0x80000000`
  - **Size**: `sizeof(struct)` = `40` (0x28) << 16
  - **Type**: `'k'` (0x6B) << 8
  - **NR**: `2`
  - **Final Hex**: `0x80286B02`

  *If the struct size differs by even 1 byte, the command ID changes and `ioctl()` returns `-ENOTTY`.*
'| {
  near: bottom-right
  style: {
    fill: "#FEF9E7"
    stroke: "#B7950B"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# GLOBAL CONNECTIONS
# ─────────────────────────────────────────────────────────────────────────────
kernel_space.k_gcc -> header: "Imports UAPI Contract" {
  style.stroke: "#7D3C98"
  style.stroke-width: 3
}

user_space.u_gcc -> header: "Imports UAPI Contract" {
  style.stroke: "#1E8449"
  style.stroke-width: 3
}

user_space.u_binary -> kernel_space.k_binary: "ioctl(fd, 0x80286B02, &buf)" {
  style: {
    stroke: "#E74C3C"
    stroke-width: 4
    animated: true
  }
}

legend: |'md
  **Layout Engine**: ELK
  **Theme**: Technical Neutral
  **Verified**: Byte-level alignment verified for x86_64
'| {
  near: top-right
}