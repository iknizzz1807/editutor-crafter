vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
direction: down
title: |md
  ## wait_event_interruptible: Reader Process State Machine
  `wait_event_interruptible(mydevice_read_queue, buffer_data_len > 0)`
| {near: top-center}
# ─── INITIAL STATE ───
initial: ● {
  shape: circle
  style: {
    fill: "#1a1a2e"
    stroke: "#e94560"
    stroke-width: 3
  }
  width: 28
  height: 28
  label: ""
}
# ─── STATES ───
RUNNING: "RUNNING\n(syscall entry)" {
  shape: rectangle
  style: {
    fill: "#2d6a4f"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#52b788"
    stroke-width: 2
  }
  invariant: |md
    *task->state = TASK_RUNNING*
    No queue membership
  |
}
CHECK_CONDITION: "CHECK CONDITION\n(fast path)" {
  shape: diamond
  style: {
    fill: "#1d3557"
    font-color: white
    bold: true
    stroke: "#457b9d"
    stroke-width: 2
  }
  label: "buffer_data_len > 0 ?"
}
FAST_EXIT: "FAST EXIT\n(condition true)" {
  shape: rectangle
  style: {
    fill: "#2d6a4f"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#52b788"
    stroke-width: 2
  }
  invariant: |md
    *Skip sleep entirely*
    Proceed to mutex acquire
  |
}
ADD_TO_QUEUE: "ADD_TO_QUEUE\nprepare_to_wait()" {
  shape: rectangle
  style: {
    fill: "#4a4e69"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#9a8c98"
    stroke-width: 2
  }
  invariant: |md
    *Process enqueued in*
    *mydevice_read_queue*
    DEFINE_WAIT(__wait) allocated
  |
}
SET_INTERRUPTIBLE: "SET_INTERRUPTIBLE\nset_current_state()" {
  shape: rectangle
  style: {
    fill: "#4a4e69"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#9a8c98"
    stroke-width: 2
  }
  invariant: |md
    *task->state = TASK_INTERRUPTIBLE*
    In queue; wakeable by signal
    ⚠ Set BEFORE re-checking condition
  |
}
RECHECK_INNER: "RECHECK CONDITION\n(loop body)" {
  shape: diamond
  style: {
    fill: "#1d3557"
    font-color: white
    bold: true
    stroke: "#457b9d"
    stroke-width: 2
  }
  label: "buffer_data_len > 0 ?"
}
CHECK_SIGNAL: "CHECK_SIGNAL\nsignal_pending()" {
  shape: diamond
  style: {
    fill: "#6b2737"
    font-color: white
    bold: true
    stroke: "#e63946"
    stroke-width: 2
  }
  label: "signal_pending\n(current) ?"
}
SCHEDULE: "SCHEDULE\nschedule()" {
  shape: rectangle
  style: {
    fill: "#212529"
    font-color: "#adb5bd"
    bold: true
    border-radius: 6
    stroke: "#6c757d"
    stroke-width: 2
    stroke-dash: 3
  }
  invariant: |md
    *CPU given to other tasks*
    *This process is SLEEPING*
    task removed from runqueue
    Resumes after wake_up call
  |
}
SLEEPING: "● SLEEPING ●" {
  shape: rectangle
  style: {
    fill: "#0d0d0d"
    font-color: "#6c757d"
    bold: true
    border-radius: 6
    stroke: "#343a40"
    stroke-width: 3
    stroke-dash: 5
  }
  invariant: |md
    *Off CPU entirely*
    Waiting in mydevice_read_queue
    TASK_INTERRUPTIBLE
  |
}
WOKEN: "WOKEN\nwake_up_interruptible()" {
  shape: rectangle
  style: {
    fill: "#7b2d8b"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#c77dff"
    stroke-width: 2
  }
  invariant: |md
    *Writer called:*
    wake_up_interruptible
      (&mydevice_read_queue)
    task->state = TASK_RUNNING
    Back on runqueue
  |
}
RECHECK_CONDITION: "RECHECK_CONDITION\n(post-wakeup loop)" {
  shape: diamond
  style: {
    fill: "#1d3557"
    font-color: white
    bold: true
    stroke: "#457b9d"
    stroke-width: 2
  }
  label: "buffer_data_len > 0 ?\n(re-evaluate)"
}
FINISH_WAIT: "FINISH_WAIT\nfinish_wait()" {
  shape: rectangle
  style: {
    fill: "#4a4e69"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#9a8c98"
    stroke-width: 2
  }
  invariant: |md
    *Remove from wait queue*
    task->state = TASK_RUNNING
    __wait entry freed
  |
}
ACQUIRE_MUTEX: "ACQUIRE_MUTEX\nmutex_lock_interruptible()" {
  shape: rectangle
  style: {
    fill: "#1b4332"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#40916c"
    stroke-width: 2
  }
  invariant: |md
    *mydevice_mutex acquired*
    Or -ERESTARTSYS if signaled
  |
}
RECHECK_UNDER_LOCK: "RECHECK_UNDER_LOCK\n(mandatory condition recheck)" {
  shape: diamond
  style: {
    fill: "#1d3557"
    font-color: white
    bold: true
    stroke: "#457b9d"
    stroke-width: 2
  }
  label: "buffer_data_len > 0 ?\n(under mutex)"
}
PROCEED_READ: "PROCEED_READ\ncopy_to_user()" {
  shape: rectangle
  style: {
    fill: "#2d6a4f"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#52b788"
    stroke-width: 3
    shadow: true
  }
  invariant: |md
    *Data confirmed under mutex*
    copy_to_user() executes
    buffer_data_len decremented
    memmove() shifts FIFO
    wake_up(write_queue)
    mutex_unlock()
  |
}
# ─── ERROR / SIGNAL STATES ───
REMOVE_FROM_QUEUE_SIG: "REMOVE_FROM_QUEUE\n(signal path)" {
  shape: rectangle
  style: {
    fill: "#6b2737"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#e63946"
    stroke-width: 2
  }
  invariant: |md
    *finish_wait() called*
    Removed from read_queue
    task->state = TASK_RUNNING
  |
}
RETURN_ERESTARTSYS: "return -ERESTARTSYS" {
  shape: rectangle
  style: {
    fill: "#e63946"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#c1121f"
    stroke-width: 3
  }
  invariant: |md
    *Signal received during sleep*
    VFS layer sees -ERESTARTSYS
    → SA_RESTART: syscall restarted
    → no SA_RESTART: errno=EINTR
  |
}
RETURN_EAGAIN_SPURIOUS: "return -EAGAIN\n(thundering herd)" {
  shape: rectangle
  style: {
    fill: "#9c6b00"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#f4a261"
    stroke-width: 2
  }
  invariant: |md
    *Another reader consumed data*
    Mutex released without read
    Caller retries wait loop
  |
}
RETURN_ERESTARTSYS_MUTEX: "return -ERESTARTSYS\n(mutex wait signaled)" {
  shape: rectangle
  style: {
    fill: "#e63946"
    font-color: white
    bold: true
    border-radius: 6
    stroke: "#c1121f"
    stroke-width: 2
  }
  invariant: |md
    *Signal while waiting for mutex*
    (Not while sleeping in wait queue)
    Same propagation rules apply
  |
}
final_ok: ● {
  shape: circle
  style: {
    fill: "#52b788"
    stroke: "#2d6a4f"
    stroke-width: 4
    double-border: true
  }
  width: 32
  height: 32
  label: ""
}
final_err: ● {
  shape: circle
  style: {
    fill: "#e63946"
    stroke: "#c1121f"
    stroke-width: 4
    double-border: true
  }
  width: 32
  height: 32
  label: ""
}
# ─── TRANSITIONS ───
initial -> RUNNING: "read() syscall\nenters kernel" {
  style: { stroke: "#e94560"; stroke-width: 2 }
}
RUNNING -> CHECK_CONDITION: "count > 0\n(not trivial zero)" {
  style: { stroke: "#52b788" }
}
CHECK_CONDITION -> FAST_EXIT: "TRUE\n(data already present)" {
  style: { stroke: "#52b788"; stroke-width: 2; bold: true }
}
CHECK_CONDITION -> ADD_TO_QUEUE: "FALSE\n(buffer empty)\nblocking mode" {
  style: { stroke: "#9a8c98"; stroke-width: 2; bold: true }
}
FAST_EXIT -> ACQUIRE_MUTEX: "skip sleep" {
  style: { stroke: "#52b788"; stroke-dash: 3 }
}
ADD_TO_QUEUE -> SET_INTERRUPTIBLE: "prepare_to_wait()\nenqueues process" {
  style: { stroke: "#9a8c98" }
}
SET_INTERRUPTIBLE -> RECHECK_INNER: "state set\nbefore condition check\n(prevents missed wakeup)" {
  style: { stroke: "#457b9d" }
}
RECHECK_INNER -> FINISH_WAIT: "TRUE\n(data appeared before sleep)" {
  style: { stroke: "#52b788"; stroke-width: 2; bold: true }
}
RECHECK_INNER -> CHECK_SIGNAL: "FALSE\n(still empty)" {
  style: { stroke: "#e63946" }
}
CHECK_SIGNAL -> REMOVE_FROM_QUEUE_SIG: "YES\nsignal_pending" {
  style: { stroke: "#e63946"; stroke-width: 2; bold: true }
}
CHECK_SIGNAL -> SCHEDULE: "NO\nno pending signal" {
  style: { stroke: "#adb5bd" }
}
SCHEDULE -> SLEEPING: "CPU released\nprocess descheduled" {
  style: { stroke: "#6c757d"; stroke-dash: 4 }
}
SLEEPING -> WOKEN: "wake_up_interruptible\n(&mydevice_read_queue)\ncalled by writer" {
  style: { stroke: "#c77dff"; stroke-width: 2; bold: true; animated: true }
}
SLEEPING -> REMOVE_FROM_QUEUE_SIG: "SIGKILL / SIGINT\nsignal delivered\nto sleeping process" {
  style: { stroke: "#e63946"; stroke-width: 2; stroke-dash: 3; bold: true }
}
WOKEN -> RECHECK_CONDITION: "task->state = TASK_RUNNING\nschedule() returns\nback in wait loop" {
  style: { stroke: "#c77dff" }
}
RECHECK_CONDITION -> FINISH_WAIT: "TRUE\ndata confirmed\n(normal wakeup)" {
  style: { stroke: "#52b788"; stroke-width: 2; bold: true }
}
RECHECK_CONDITION -> SET_INTERRUPTIBLE: "FALSE\n(spurious wakeup\nor thundering herd)\nloop back to sleep" {
  style: {
    stroke: "#9a8c98"
    stroke-width: 2
    stroke-dash: 4
    bold: true
    font-color: "#f4a261"
  }
}
REMOVE_FROM_QUEUE_SIG -> RETURN_ERESTARTSYS: "finish_wait()\ncomplete" {
  style: { stroke: "#e63946"; stroke-width: 2 }
}
FINISH_WAIT -> ACQUIRE_MUTEX: "wait_event_interruptible\nreturns 0\n(success)" {
  style: { stroke: "#40916c"; stroke-width: 2 }
}
ACQUIRE_MUTEX -> RECHECK_UNDER_LOCK: "mutex held\ncheck condition again" {
  style: { stroke: "#40916c" }
}
ACQUIRE_MUTEX -> RETURN_ERESTARTSYS_MUTEX: "signal during\nmutex_lock_interruptible\nreturns != 0" {
  style: { stroke: "#e63946"; stroke-dash: 3 }
}
RECHECK_UNDER_LOCK -> PROCEED_READ: "TRUE\ndata still present\n(we own the mutex)" {
  style: { stroke: "#52b788"; stroke-width: 3; bold: true }
}
RECHECK_UNDER_LOCK -> RETURN_EAGAIN_SPURIOUS: "FALSE\nanother reader\nconsumed data first\n(thundering herd)" {
  style: { stroke: "#f4a261"; stroke-width: 2; bold: true }
}
PROCEED_READ -> final_ok: "ssize_t bytes_read\nreturned to userspace" {
  style: { stroke: "#52b788"; stroke-width: 3 }
}
RETURN_ERESTARTSYS -> final_err: "errno = EINTR\nor syscall restart" {
  style: { stroke: "#e63946"; stroke-width: 2 }
}
RETURN_ERESTARTSYS_MUTEX -> final_err: "errno = EINTR\nor syscall restart" {
  style: { stroke: "#e63946"; stroke-width: 2 }
}
RETURN_EAGAIN_SPURIOUS -> final_err: "errno = EAGAIN\ncaller retries" {
  style: { stroke: "#f4a261"; stroke-width: 2 }
}
# ─── ANNOTATIONS ───
legend: |md
  **State Colors**
  🟢 Green  = Running / data available / success
  🟣 Purple = Queue membership / synchronization
  🔵 Blue   = Condition check (diamond)
  ⚫ Dark   = Sleeping (off CPU)
  🔴 Red    = Signal / error path
  🟠 Orange = Thundering herd recovery
  **Key Invariants**
  • NEVER hold mydevice_mutex while calling wait_event_interruptible
  • ALWAYS recheck condition after waking (under mutex)
  • ALWAYS propagate -ERESTARTSYS without conversion
  • SET_INTERRUPTIBLE before RECHECK_INNER prevents missed wakeup
| {
  near: bottom-right
  style: {
    fill: "#0d1117"
    stroke: "#30363d"
    font-color: "#c9d1d9"
    font-size: 12
    border-radius: 6
  }
}