vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # FIFO Buffer State: write-append + read-consume + memmove
  **M4 Semantics** — append on write, consume-from-head on read, memmove remaining tail
| {near: top-center}

# ─── STEP 0: Initial State ────────────────────────────────────────────────────
step0: "Step 0 — Initial State" {
  style.fill: "#EEF2FF"
  style.border-radius: 8
  style.stroke: "#6366F1"
  
  header0: |md
    **kernel_buffer[0..4095]  •  buffer_data_len = 0  •  buffer_size = 4096**
  | {
    style.fill: transparent
    style.stroke: transparent
  }
  
  buf0: {
    grid-columns: 16
    grid-gap: 0
    c0:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c1:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c2:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c3:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c4:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c5:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c6:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c7:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c8:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c9:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c10: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c11: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c12: "…" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c13: "[" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c14: "4095" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 9 }
    c15: "]" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    style.fill: "#F0FDF4"
    style.stroke: "#A7F3D0"
  }
  
  ann0: |md
    `buffer_data_len = 0`  (no valid bytes)
    All bytes are FREE space  •  Legend: **Blue**=valid data  **Green**=free
  | {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 12
  }
}

# ─── STEP 1: write('AAABBB', 6) ───────────────────────────────────────────────
step1: "Step 1 — write('AAABBB', 6 bytes)" {
  style.fill: "#EFF6FF"
  style.border-radius: 8
  style.stroke: "#3B82F6"
  
  op1: |md
    copy_from_user(kernel_buffer + buffer_data_len, buf, 6)
    //             kernel_buffer + 0  ← append at tail
    buffer_data_len += 6   →  buffer_data_len = 6
    wake_up_interruptible(&mydevice_read_queue)
  | {
    style.fill: "#DBEAFE"
    style.stroke: "#93C5FD"
    style.font-size: 11
    style.font: mono
  }
  
  buf1: {
    grid-columns: 16
    grid-gap: 0
    c0:  "A" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    c1:  "A" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    c2:  "A" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    c3:  "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    c4:  "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    c5:  "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    c6:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c7:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c8:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c9:  "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c10: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c11: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c12: "…" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c13: "[" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    c14: "4095" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 9 }
    c15: "]" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    style.fill: "#EFF6FF"
    style.stroke: "#BFDBFE"
  }
  
  ptr1: |md
    `[0]`=A `[1]`=A `[2]`=A `[3]`=B `[4]`=B `[5]`=B
    **buffer_data_len = 6** ←▲ valid data ends here
    Appended at offset 0 (was empty). **M4: does NOT overwrite — appends at tail.**
  | {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 12
  }
}

# ─── STEP 2: read(3 bytes) → copy_to_user + memmove ──────────────────────────
step2: "Step 2 — read(3 bytes): copy_to_user + memmove" {
  style.fill: "#FFF7ED"
  style.border-radius: 8
  style.stroke: "#F97316"
  
  op2: |md
    to_copy = min(3, buffer_data_len=6) = 3
    copy_to_user(userspace_buf, kernel_buffer, 3)   // sends A,A,A
    buffer_data_len -= 3   →  buffer_data_len = 3
    memmove(kernel_buffer, kernel_buffer + 3, 3)    // shift B,B,B to front
    wake_up_interruptible(&mydevice_write_queue)     // space freed → wake writers
  | {
    style.fill: "#FED7AA"
    style.stroke: "#FB923C"
    style.font-size: 11
    style.font: mono
  }
  
  memmove_detail: {
    grid-columns: 2
    grid-gap: 8
    
    before_mv: "BEFORE memmove" {
      style.fill: "#FEF9C3"
      style.stroke: "#FDE047"
      style.font-size: 11
      bm: {
        grid-columns: 8
        grid-gap: 0
        a0: "A" { style.fill: "#FCA5A5"; style.stroke: "#F87171"; style.font-size: 11 }
        a1: "A" { style.fill: "#FCA5A5"; style.stroke: "#F87171"; style.font-size: 11 }
        a2: "A" { style.fill: "#FCA5A5"; style.stroke: "#F87171"; style.font-size: 11 }
        b0: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
        b1: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
        b2: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
        f0: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
        f1: "…" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
        style.fill: "#FEF9C3"
        style.stroke: transparent
      }
      lbl_bm: |md
        **A,A,A** = consumed (sent to user)\n**B,B,B** = remaining tail at [3..5]
      | { style.fill: transparent; style.stroke: transparent; style.font-size: 11 }
    }
    
    after_mv: "AFTER memmove" {
      style.fill: "#DCFCE7"
      style.stroke: "#4ADE80"
      style.font-size: 11
      am: {
        grid-columns: 8
        grid-gap: 0
        b0: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
        b1: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
        b2: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
        f0: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
        f1: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
        f2: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
        f3: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
        f4: "…" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
        style.fill: "#DCFCE7"
        style.stroke: transparent
      }
      lbl_am: |md
        **B,B,B** shifted to [0..2] via memmove\n**buffer_data_len = 3**\nFree space at [3..4095]
      | { style.fill: transparent; style.stroke: transparent; style.font-size: 11 }
    }
  }
  
  cost_note: |md
    ⚠️ **memmove cost**: O(remaining_bytes) — shifts `buffer_data_len` bytes
    Worst case: 4095 bytes shifted after 1-byte read ≈ **4–10 µs** (64 cache lines)
    **Circular buffer alternative**: O(1) — advance `tail` index.
    Tradeoff: memmove = simpler code; circular = higher throughput.
  | {
    style.fill: "#FEF3C7"
    style.stroke: "#FCD34D"
    style.font-size: 12
  }
}

# ─── STEP 3: write('CCCC', 4) — append after remaining 'BBB' ─────────────────
step3: "Step 3 — write('CCCC', 4 bytes): append at buffer_data_len=3" {
  style.fill: "#F0FDF4"
  style.border-radius: 8
  style.stroke: "#22C55E"
  
  op3: |md
    space_available = buffer_size - buffer_data_len = 4096 - 3 = 4093
    to_copy = min(4, 4093) = 4
    copy_from_user(kernel_buffer + 3, buf, 4)   // append C,C,C,C at offset 3
    buffer_data_len += 4   →  buffer_data_len = 7
    wake_up_interruptible(&mydevice_read_queue)
  | {
    style.fill: "#BBF7D0"
    style.stroke: "#4ADE80"
    style.font-size: 11
    style.font: mono
  }
  
  buf3: {
    grid-columns: 16
    grid-gap: 0
    b0: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    b1: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    b2: "B" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.bold: true; style.font-size: 11 }
    c0: "C" { style.fill: "#C4B5FD"; style.stroke: "#A78BFA"; style.bold: true; style.font-size: 11 }
    c1: "C" { style.fill: "#C4B5FD"; style.stroke: "#A78BFA"; style.bold: true; style.font-size: 11 }
    c2: "C" { style.fill: "#C4B5FD"; style.stroke: "#A78BFA"; style.bold: true; style.font-size: 11 }
    c3: "C" { style.fill: "#C4B5FD"; style.stroke: "#A78BFA"; style.bold: true; style.font-size: 11 }
    f0: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    f1: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    f2: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    f3: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    f4: "_" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    f5: "…" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 11 }
    f6: "[4095]" { style.fill: "#D1FAE5"; style.stroke: "#6EE7B7"; style.font-size: 9 }
    style.fill: "#F0FDF4"
    style.stroke: "#A7F3D0"
  }
  
  ptr3: |md
    `[0]`=B `[1]`=B `[2]`=B  ← survived memmove
    `[3]`=C `[4]`=C `[5]`=C `[6]`=C  ← newly appended CCCC
    **buffer_data_len = 7**  •  FIFO order preserved
  | {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 12
  }
}

# ─── STEP 4: Buffer Full — write blocks ───────────────────────────────────────
step4: "Step 4 — Buffer Full: blocking write sleeps / O_NONBLOCK → -EAGAIN" {
  style.fill: "#FFF1F2"
  style.border-radius: 8
  style.stroke: "#F43F5E"
  
  scenario_full: {
    grid-columns: 2
    grid-gap: 16
    blocking_path: "Blocking mode (default)" {
      style.fill: "#FFE4E6"
      style.stroke: "#FB7185"
      style.font-size: 11
      code_blk: |md
        wait_event_interruptible(
          mydevice_write_queue,
          buffer_data_len < buffer_size)
      | {
        style.fill: "#FFE4E6"
        style.stroke: "#FECDD3"
        style.font-size: 10
        style.font: mono
      }
    }
    nonblock_path: "O_NONBLOCK mode" {
      style.fill: "#FEF2F2"
      style.stroke: "#FCA5A5"
      style.font-size: 11
      code_nb: |md
        if (buffer_data_len >= buffer_size):
          return -EAGAIN
      | {
        style.fill: "#FEF2F2"
        style.stroke: "#FECACA"
        style.font-size: 10
        style.font: mono
      }
    }
  }
  
  full_buf: {
    grid-columns: 16
    grid-gap: 0
    f0:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f1:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f2:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f3:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f4:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f5:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f6:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f7:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f8:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f9:  "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f10: "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f11: "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f12: "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f13: "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f14: "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    f15: "X" { style.fill: "#BFDBFE"; style.stroke: "#60A5FA"; style.font-size: 10 }
    style.fill: "#FFF1F2"
    style.stroke: "#FECDD3"
  }
  
  full_ann: |md
    ⛔ **FULL: zero free bytes**
    Writer cannot proceed until reader consumes bytes.
  | {
    style.fill: "#FFE4E6"
    style.stroke: "#FB7185"
    style.font-size: 12
  }
}

# ─── M2/M3 Contrast ───────────────────────────────────────────────────────────
contrast: "M2/M3 vs M4 Buffer Semantics Comparison" {
  style.fill: "#F5F3FF"
  style.border-radius: 8
  style.stroke: "#7C3AED"
  grid-columns: 2
  grid-gap: 16
  
  m2_box: "M2/M3: Overwrite Semantics (OBSOLETE)" {
    style.fill: "#EDE9FE"
    style.stroke: "#A78BFA"
    m2_code: |md
      memset(kernel_buffer, 0, buffer_size);
      copy_from_user(kernel_buffer, buf, to_copy);
    | {
      style.fill: "#EDE9FE"
      style.stroke: transparent
      style.font-size: 11
      style.font: mono
    }
  }
  
  m4_box: "M4: FIFO Append Semantics (CURRENT)" {
    style.fill: "#D1FAE5"
    style.stroke: "#34D399"
    m4_code: |md
      space = buffer_size - buffer_data_len;
      copy_from_user(kernel_buffer + buffer_data_len, buf, to_copy);
    | {
      style.fill: "#D1FAE5"
      style.stroke: transparent
      style.font-size: 11
      style.font: mono
    }
  }
}

# ─── Circular Buffer Alternative ──────────────────────────────────────────────
circ_alt: "Circular Buffer Alternative (Reference)" {
  style.fill: "#F0F9FF"
  style.border-radius: 8
  style.stroke: "#0EA5E9"
  grid-columns: 2
  grid-gap: 16
  
  memmove_cost: "memmove FIFO (this driver)" {
    style.fill: "#BAE6FD"
    style.stroke: "#38BDF8"
    mm_detail: |md
      **O(remaining_bytes) time**
      Worst case: read 1, memmove 4094.
    | {
      style.fill: "#BAE6FD"
      style.stroke: transparent
      style.font-size: 11
      style.font: mono
    }
  }
  
  circ_cost: "Circular Buffer (Production)" {
    style.fill: "#CFFAFE"
    style.stroke: "#22D3EE"
    circ_detail: |md
      **O(1) time**
      Complex wrap-around handling.
    | {
      style.fill: "#CFFAFE"
      style.stroke: transparent
      style.font-size: 11
      style.font: mono
    }
  }
}

# ─── Connections ──────────────────────────────────────────────────────────────
step0 -> step1: "write('AAABBB', 6)" {
  style.stroke: "#3B82F6"
  style.bold: true
}
step1 -> step2: "read(3 bytes)" {
  style.stroke: "#F97316"
  style.bold: true
}
step2 -> step3: "write('CCCC', 4)" {
  style.stroke: "#22C55E"
  style.bold: true
}
step3 -> step4: "buffer fills" {
  style.stroke: "#F43F5E"
  style.bold: true
  style.stroke-dash: 4
}
step4 -> step2: "unblock" {
  style.stroke: "#8B5CF6"
  style.bold: true
  style.stroke-dash: 5
  style.animated: true
}