vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## Stress Test Architecture: 4 Writers × 4 Readers + Checksum Verification
  `concurrent_test.py` — `NUM_WRITERS=4` · `NUM_READERS=4` · `MESSAGES_PER_WRITER=50` · `MESSAGE_SIZE=128 bytes`
| {near: top-center}
# ─── Writer Thread Column ───────────────────────────────────────────────
writers: "Writer Threads (4 concurrent)" {
  style.fill: "#e8f4fd"
  style.stroke: "#2980b9"
  style.stroke-width: 2
  style.border-radius: 8
  w0: "Writer 0\nchar = 'A' × 128 bytes" {
    style.fill: "#aed6f1"
    style.stroke: "#2980b9"
    style.border-radius: 6
    shape: rectangle
    w0_msg: |md
      `msg = b'A' * 128`
      `cksum = sha256(msg)`
      → `sent_checksums.put(cksum)`
      × 50 iterations
    |
  }
  w1: "Writer 1\nchar = 'B' × 128 bytes" {
    style.fill: "#aed6f1"
    style.stroke: "#2980b9"
    style.border-radius: 6
    shape: rectangle
    w1_msg: |md
      `msg = b'B' * 128`
      `cksum = sha256(msg)`
      → `sent_checksums.put(cksum)`
      × 50 iterations
    |
  }
  w2: "Writer 2\nchar = 'C' × 128 bytes" {
    style.fill: "#aed6f1"
    style.stroke: "#2980b9"
    style.border-radius: 6
    shape: rectangle
    w2_msg: |md
      `msg = b'C' * 128`
      `cksum = sha256(msg)`
      → `sent_checksums.put(cksum)`
      × 50 iterations
    |
  }
  w3: "Writer 3\nchar = 'D' × 128 bytes" {
    style.fill: "#aed6f1"
    style.stroke: "#2980b9"
    style.border-radius: 6
    shape: rectangle
    w3_msg: |md
      `msg = b'D' * 128`
      `cksum = sha256(msg)`
      → `sent_checksums.put(cksum)`
      × 50 iterations
    |
  }
}
# ─── Kernel Device — The Shared Resource Under Test ─────────────────────
device_col: "Kernel Space: /dev/mydevice" {
  style.fill: "#f9f0ff"
  style.stroke: "#7d3c98"
  style.stroke-width: 3
  style.border-radius: 8
  kbuf: "/dev/mydevice\nkernel_buffer[4096 bytes]" {
    style.fill: "#d7bde2"
    style.stroke: "#7d3c98"
    style.stroke-width: 2
    style.border-radius: 6
    shape: cylinder
    kbuf_detail: |md
      **FIFO buffer — shared mutable state**
      `kernel_buffer[0 .. buffer_data_len)`
      `buffer_data_len` ← bytes currently stored
      `buffer_size = 4096`
      **Protected by:** `mydevice_mutex`
      **Readers sleep on:** `mydevice_read_queue`
      **Writers sleep on:** `mydevice_write_queue`
    |
  }
  mutex_box: "mydevice_mutex\n(DEFINE_MUTEX)" {
    style.fill: "#f1948a"
    style.stroke: "#c0392b"
    style.stroke-width: 2
    style.border-radius: 6
    mutex_detail: |md
      **Critical section boundary**
      Every `read()` and `write()`
      acquires this before touching
      `kernel_buffer` or `buffer_data_len`
      Missing mutex → lost update:
      `buffer_data_len` torn between CPUs
    |
  }
  race_note: |md
    **Race condition without mutex:**
    CPU 0 (Writer A):          CPU 1 (Writer B):
    `to_copy = 128`             `to_copy = 128`
    `copy_from_user(buf, "AAA…")`
                                `copy_from_user(buf, "BBB…")`
    `buffer_data_len += 128`
                                `buffer_data_len += 128`  ← LOST UPDATE
    Reader sees 128 bytes of interleaved A+B bytes.
    SHA-256 of mixed block ∉ sent_checksums → **FAIL**
  | {
    style.fill: "#fdf2f8"
    style.stroke: "#c0392b"
    style.stroke-dash: 5
    style.border-radius: 4
  }
  kbuf -> mutex_box: "guards access to" {
    style.stroke: "#7d3c98"
    style.stroke-dash: 3
  }
}
# ─── Reader Thread Column ────────────────────────────────────────────────
readers: "Reader Threads (4 concurrent)" {
  style.fill: "#eafaf1"
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.border-radius: 8
  r0: "Reader 0" {
    style.fill: "#a9dfbf"
    style.stroke: "#27ae60"
    style.border-radius: 6
    r0_detail: |md
      `data = os.read(fd, 128)`
      `cksum = sha256(data)`
      → append to `received_checksums`
      loop until `stop_event`
    |
  }
  r1: "Reader 1" {
    style.fill: "#a9dfbf"
    style.stroke: "#27ae60"
    style.border-radius: 6
    r1_detail: |md
      `data = os.read(fd, 128)`
      `cksum = sha256(data)`
      → append to `received_checksums`
    |
  }
  r2: "Reader 2" {
    style.fill: "#a9dfbf"
    style.stroke: "#27ae60"
    style.border-radius: 6
    r2_detail: |md
      `data = os.read(fd, 128)`
      `cksum = sha256(data)`
      → append to `received_checksums`
    |
  }
  r3: "Reader 3" {
    style.fill: "#a9dfbf"
    style.stroke: "#27ae60"
    style.border-radius: 6
    r3_detail: |md
      `data = os.read(fd, 128)`
      `cksum = sha256(data)`
      → append to `received_checksums`
    |
  }
}
# ─── Shared Data Structures (bottom strip) ──────────────────────────────
queues_row: "Shared Python Data Structures (threading-safe)" {
  style.fill: "#fdfefe"
  style.stroke: "#717d7e"
  style.stroke-width: 1
  style.border-radius: 6
  grid-columns: 2
  sent_q: "sent_checksums\nqueue.Queue()" {
    style.fill: "#fef9e7"
    style.stroke: "#d4ac0d"
    style.border-radius: 6
    sent_detail: |md
      **Populated by:** all 4 writers
      **Contents:** SHA-256 hex strings
      Total entries: 4 × 50 = **200**
      Each entry = sha256(b'X' * 128)
      Only 4 distinct values exist
      (one per writer character)
    |
  }
  recv_list: "received_checksums\nlist (checksum_lock)" {
    style.fill: "#eaf2ff"
    style.stroke: "#2980b9"
    style.border-radius: 6
    recv_detail: |md
      **Populated by:** all 4 readers
      **Contents:** SHA-256 of each 128-byte
      block actually read from the device
      **If mutex correct:**
      every entry ∈ sent_checksums set
      **If mutex missing:**
      corrupted blocks produce unknown
      SHA-256 → ∉ sent_checksums → FAIL
    |
  }
}
# ─── Verification Phase ──────────────────────────────────────────────────
verify: "Verification Phase" {
  style.fill: "#f8f9fa"
  style.stroke: "#566573"
  style.stroke-width: 2
  style.border-radius: 8
  grid-columns: 2
  pass_box: "PASS outcome\n(mutex working)" {
    style.fill: "#d5f5e3"
    style.stroke: "#1e8449"
    style.stroke-width: 2
    style.border-radius: 6
    pass_detail: |md
      `corrupted = [c for c in received_checksums`
      `             if c not in expected_set]`
      `len(corrupted) == 0`
      Every 128-byte block read back is
      exactly one writer's pure message:
      all-A, all-B, all-C, or all-D.
      **Conclusion: mutex serialises writes
      correctly — no data interleaving.**
    |
  }
  fail_box: "FAIL outcome\n(mutex missing or broken)" {
    style.fill: "#fadbd8"
    style.stroke: "#c0392b"
    style.stroke-width: 2
    style.border-radius: 6
    fail_detail: |md
      `len(corrupted) > 0`
      At least one 128-byte block contains
      bytes from two different writers:
      e.g., first 64 bytes = 'A', last 64 = 'B'
      `sha256(mixed_block)` is NOT in
      `{sha256(b'A'*128), sha256(b'B'*128), …}`
      **Conclusion: lost update / torn write
      → buffer_data_len corrupted.**
    |
  }
}
# ─── Probabilistic Note ──────────────────────────────────────────────────
prob_note: |md
  **Why the test is reliable:** Race conditions are probabilistic — a single writer rarely exposes the bug.
  4 concurrent writers × 50 messages × 128-byte blocks provides thousands of opportunities for CPU interleaving.
  On a multi-core machine, missing-mutex corruption typically manifests within the first 20 messages.
  The test is **not exhaustive** (no formal proof), but it is a high-confidence detector in practice.
| {
  near: bottom-center
  style.fill: "#fdfefe"
  style.stroke: "#aab7b8"
  style.stroke-dash: 3
  style.border-radius: 4
}
# ─── Writer → Device connections ─────────────────────────────────────────
writers.w0 -> device_col.kbuf: "os.write(fd, b'A'×128)\n[blocks if full]" {
  style.stroke: "#2980b9"
  style.stroke-width: 2
  style.animated: true
}
writers.w1 -> device_col.kbuf: "os.write(fd, b'B'×128)" {
  style.stroke: "#2980b9"
  style.stroke-width: 2
  style.animated: true
}
writers.w2 -> device_col.kbuf: "os.write(fd, b'C'×128)" {
  style.stroke: "#2980b9"
  style.stroke-width: 2
  style.animated: true
}
writers.w3 -> device_col.kbuf: "os.write(fd, b'D'×128)" {
  style.stroke: "#2980b9"
  style.stroke-width: 2
  style.animated: true
}
# ─── Device → Reader connections ─────────────────────────────────────────
device_col.kbuf -> readers.r0: "os.read(fd, 128)\n[blocks if empty]" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.animated: true
}
device_col.kbuf -> readers.r1: "os.read(fd, 128)" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.animated: true
}
device_col.kbuf -> readers.r2: "os.read(fd, 128)" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.animated: true
}
device_col.kbuf -> readers.r3: "os.read(fd, 128)" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.animated: true
}
# ─── Writers record checksums ────────────────────────────────────────────
writers.w0 -> queues_row.sent_q: "sha256 → put()" {
  style.stroke: "#d4ac0d"
  style.stroke-dash: 4
}
writers.w1 -> queues_row.sent_q: "sha256 → put()" {
  style.stroke: "#d4ac0d"
  style.stroke-dash: 4
}
writers.w2 -> queues_row.sent_q: "sha256 → put()" {
  style.stroke: "#d4ac0d"
  style.stroke-dash: 4
}
writers.w3 -> queues_row.sent_q: "sha256 → put()" {
  style.stroke: "#d4ac0d"
  style.stroke-dash: 4
}
# ─── Readers record checksums ────────────────────────────────────────────
readers.r0 -> queues_row.recv_list: "sha256 → append()" {
  style.stroke: "#2980b9"
  style.stroke-dash: 4
}
readers.r1 -> queues_row.recv_list: "sha256 → append()" {
  style.stroke: "#2980b9"
  style.stroke-dash: 4
}
readers.r2 -> queues_row.recv_list: "sha256 → append()" {
  style.stroke: "#2980b9"
  style.stroke-dash: 4
}
readers.r3 -> queues_row.recv_list: "sha256 → append()" {
  style.stroke: "#2980b9"
  style.stroke-dash: 4
}
# ─── Queues feed verification ─────────────────────────────────────────────
queues_row.sent_q -> verify.pass_box: "expected_set =\nset(sent_checksums)" {
  style.stroke: "#1e8449"
  style.stroke-width: 2
}
queues_row.sent_q -> verify.fail_box: "expected_set" {
  style.stroke: "#c0392b"
  style.stroke-width: 2
}
queues_row.recv_list -> verify.pass_box: "check each ∈ expected_set" {
  style.stroke: "#1e8449"
  style.stroke-width: 2
}
queues_row.recv_list -> verify.fail_box: "unknown cksum detected" {
  style.stroke: "#c0392b"
  style.stroke-width: 2
}