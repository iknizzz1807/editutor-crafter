vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
title: |md
  ## Kernel vs. Userspace Virtual Address Space (x86-64)
  *Every process sees this full map; hardware enforces the privilege boundary*
| {near: top-center}

addr_space: "64-bit Virtual Address Space (per-process view)" {
  style: {
    fill: "#f0f0f0"
    stroke: "#333333"
    stroke-width: 3
    border-radius: 4
    font-size: 14
    bold: true
  }
  kernel_region: "KERNEL SPACE  [ 0xffff800000000000 → 0xffffffffffffffff ]" {
    style: {
      fill: "#7c3aed"
      font-color: white
      stroke: "#4c1d95"
      stroke-width: 2
      border-radius: 3
      bold: true
    }
    vmalloc_zone: "vmalloc / vmap region  [ 0xffffc90000000000 → 0xffffe8ffffffffff ]" {
      style: {
        fill: "#6d28d9"
        font-color: white
        stroke: "#5b21b6"
        stroke-width: 2
        border-radius: 2
      }
      module_text: "hello.ko  .text  (your init/exit code)\n≈200 bytes  |  __init → freed after load" {
        style: {
          fill: "#f97316"
          font-color: white
          stroke: "#c2410c"
          stroke-width: 2
          bold: true
          border-radius: 2
        }
        width: 480
      }
      module_data: "hello.ko  .data / .bss\nbuffer_size (int, 4B)  +  module metadata  ≈ 512 B" {
        style: {
          fill: "#3b82f6"
          font-color: white
          stroke: "#1d4ed8"
          stroke-width: 2
          border-radius: 2
        }
        width: 480
      }
      module_struct: "struct module  (kernel bookkeeping)\n~2–4 KB  |  symbol table, refcnt, init/exit ptrs" {
        style: {
          fill: "#9333ea"
          font-color: white
          stroke: "#7e22ce"
          stroke-width: 2
          border-radius: 2
        }
        width: 480
      }
      module_text -> module_data: "adjacent in vmalloc pages" {
        style: { stroke: "#e5e7eb"; stroke-dash: 4; font-color: "#e5e7eb" }
      }
      module_data -> module_struct: "kernel allocates together" {
        style: { stroke: "#e5e7eb"; stroke-dash: 4; font-color: "#e5e7eb" }
      }
    }
    direct_map: "direct-map physmem  [ 0xffff888000000000 → ... ]" {
      style: {
        fill: "#5b21b6"
        font-color: "#e9d5ff"
        stroke: "#4c1d95"
        stroke-width: 1
        border-radius: 2
      }
      width: 480
      kernel_text_ro: "kernel  .text + .rodata  (READ-ONLY + EXEC)\nprintk, schedule, kmalloc, tcp stack …" {
        style: {
          fill: "#7c3aed"
          font-color: white
          stroke: "#6d28d9"
          stroke-width: 2
          bold: true
          border-radius: 2
        }
        width: 440
      }
      kernel_data_rw: "kernel  .data + .bss  (READ-WRITE, NO-EXEC)\nglobal vars, page allocator state …" {
        style: {
          fill: "#2563eb"
          font-color: white
          stroke: "#1d4ed8"
          stroke-width: 2
          border-radius: 2
        }
        width: 440
      }
      kernel_stack: "per-CPU stacks + interrupt stacks  8 KB each\ncurrent task context during syscall / insmod" {
        style: {
          fill: "#475569"
          font-color: white
          stroke: "#1e293b"
          stroke-width: 2
          border-radius: 2
        }
        width: 440
      }
    }
  }
  boundary_bar: "━━━  TASK_SIZE_MAX  =  0x00007fffffffffff  ━━━\naccess_ok() rejects any userspace ptr ≥ this value  |  SMAP hardware enforcement line" {
    style: {
      fill: "#dc2626"
      font-color: white
      stroke: "#991b1b"
      stroke-width: 4
      bold: true
      border-radius: 2
    }
    width: 700
  }
  userspace_region: "USERSPACE  [ 0x0000000000000000 → 0x00007fffffffffff ]  (128 TB)" {
    style: {
      fill: "#1d4ed8"
      font-color: white
      stroke: "#1e40af"
      stroke-width: 2
      border-radius: 3
      bold: true
    }
    proc_a: "Process A  (e.g., insmod)" {
      style: {
        fill: "#2563eb"
        font-color: white
        stroke: "#1d4ed8"
        stroke-width: 2
        border-radius: 2
      }
      a_stack: "stack ↓  0x00007fffffffffff\nbuf ptr passed to write(): 0x7ffc1a238000" {
        style: {
          fill: "#1d4ed8"
          font-color: "#bfdbfe"
          stroke: "#3b82f6"
          border-radius: 2
        }
        width: 280
      }
      a_heap: "heap ↑   mmap / malloc regions\n(may be swapped — handled by copy_from_user pagefault)" {
        style: {
          fill: "#1e40af"
          font-color: "#bfdbfe"
          stroke: "#3b82f6"
          border-radius: 2
        }
        width: 280
      }
      a_bss: "BSS + data + text  0x00400000…\nprocess code (ring-3, cannot touch kernel)" {
        style: {
          fill: "#1e3a8a"
          font-color: "#bfdbfe"
          stroke: "#3b82f6"
          border-radius: 2
        }
        width: 280
      }
    }
    proc_b: "Process B  (e.g., cat /dev/mydevice)" {
      style: {
        fill: "#2563eb"
        font-color: white
        stroke: "#1d4ed8"
        stroke-width: 2
        border-radius: 2
      }
      b_stack: "stack ↓   own isolated stack\nread() buf: 0x7ffde8a01000 (DIFFERENT from A)" {
        style: {
          fill: "#1d4ed8"
          font-color: "#bfdbfe"
          stroke: "#3b82f6"
          border-radius: 2
        }
        width: 280
      }
      b_heap: "heap ↑   private pages\nprocess B cannot see process A's memory" {
        style: {
          fill: "#1e40af"
          font-color: "#bfdbfe"
          stroke: "#3b82f6"
          border-radius: 2
        }
        width: 280
      }
    }
    null_page: "NULL / unmapped  0x0000000000000000\nfirst 4 KB not mapped → NULL deref → SIGSEGV" {
      style: {
        fill: "#22c55e"
        font-color: "#14532d"
        stroke: "#15803d"
        stroke-width: 2
        border-radius: 2
      }
      width: 580
    }
  }
  kernel_region -> boundary_bar: "kernel occupies top canonical half" {
    style: { stroke: "#dc2626"; stroke-width: 3; font-color: "#dc2626" }
  }
  boundary_bar -> userspace_region: "userspace occupies bottom canonical half" {
    style: { stroke: "#dc2626"; stroke-width: 3; font-color: "#dc2626" }
  }
}

smap_note: |md
  **SMAP** *(Supervisor Mode Access Prevention)*
  CPU CR4.SMAP bit — ring-0 code **faults**
  if it directly touches any address below
  TASK_SIZE_MAX without STAC/CLAC bracketing.
  `copy_from_user` / `copy_to_user` issue
  `STAC` before the copy and `CLAC` after.
| {
  near: bottom-right
  style: {
    fill: "#fef3c7"
    stroke: "#d97706"
    stroke-width: 2
    font-color: "#92400e"
    border-radius: 4
  }
}

isolation_note: |md
  Each process sees **identical** virtual addresses
  (e.g., stack at 0x7fff…) but CPU page tables
  map them to **different physical pages**.
  Processes are **isolated from each other**.
| {
  near: bottom-center
  style: {
    fill: "#eff6ff"
    stroke: "#3b82f6"
    stroke-width: 2
    font-color: "#1e40af"
    border-radius: 4
  }
}

syscall_crossing: "syscall boundary  (ring-3 → ring-0)\nCPU: saves rsp, switches privilege; TLB NOT flushed (PCID)\nKernel sees both halves; SMAP blocks direct user-ptr deref" {
  style: {
    fill: "#fbbf24"
    font-color: "#78350f"
    stroke: "#d97706"
    stroke-width: 3
    bold: true
    border-radius: 4
  }
}

copy_contract: |md
  ### copy_from_user / copy_to_user contract
  
  1. access_ok(ptr, size)  → rejects ptr ≥ TASK_SIZE_MAX
  2. STAC  — CPU allows ring-0 to touch user pages
  3. fault-safe copy (exception table)
  4. CLAC  — SMAP re-armed
  5. return residual (bytes NOT copied)
  
  Never use memcpy / plain deref on a __user pointer.
| {
  style: {
    fill: "#f0fdf4"
    stroke: "#16a34a"
    stroke-width: 2
    font-color: "#14532d"
    border-radius: 4
  }
}

kernel_mapped_note: |md
  **Kernel mapped into every process**
  The purple kernel region appears in *every*
  process's page table, but CR0.WP + page-table
  USER bit prevents ring-3 access.
  One physical copy of kernel text serves all.
| {
  style: {
    fill: "#faf5ff"
    stroke: "#7c3aed"
    stroke-width: 2
    font-color: "#4c1d95"
    border-radius: 4
  }
}

addr_space -> syscall_crossing: "process issues syscall / insmod finit_module()" {
  style: { stroke: "#f59e0b"; stroke-width: 2; stroke-dash: 3 }
}
syscall_crossing -> copy_contract: "all kernel↔user data transfer goes through" {
  style: { stroke: "#16a34a"; stroke-width: 2 }
}
addr_space -> kernel_mapped_note: "purple region present in all page tables" {
  style: { stroke: "#7c3aed"; stroke-width: 2; stroke-dash: 3 }
}