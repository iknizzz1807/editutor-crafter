vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cache Line Behavior: Driver Globals Layout (.bss) and False Sharing Analysis
  **x86-64 Linux** · `sizeof(unsigned long) = 8` · Cache line = 64 bytes
  Hot path: `mydevice_read()` touches offsets 0–23 → all in CL0 → **single cache miss fetches all three**
| {near: top-center}
# ──────────────────────────────────────────────────────────
# CACHE LINE 0  [0x000 – 0x03F]  HOT DATA PATH
# ──────────────────────────────────────────────────────────
cl0: "Cache Line 0  [0x000 – 0x03F]  64 bytes" {
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 3
    font-size: 13
    bold: true
  }
  f0: "0x00 │ kernel_buffer  │ char *  │ 8 B  │ Pointer to kzalloc'd slab page" {
    style.fill: "#FF9800"
    style.font-color: white
    style.font-size: 12
    style.bold: true
  }
  f1: "0x08 │ buffer_data_len│ size_t  │ 8 B  │ Valid bytes in FIFO [0, buffer_size]" {
    style.fill: "#FF9800"
    style.font-color: white
    style.font-size: 12
    style.bold: true
  }
  f2: "0x10 │ buffer_size    │ size_t  │ 8 B  │ Total capacity; set at init / RESIZE ioctl" {
    style.fill: "#FF9800"
    style.font-color: white
    style.font-size: 12
    style.bold: true
  }
  f3: "0x18 │ open_count     │ atomic_t│ 4 B  │ Concurrent open fd count  (LOCK XADD)" {
    style.fill: "#2196F3"
    style.font-color: white
    style.font-size: 12
  }
  f4: "0x1C │ dev_num        │ dev_t   │ 4 B  │ major:minor encoded as uint32" {
    style.fill: "#9C27B0"
    style.font-color: white
    style.font-size: 12
  }
  f5: "0x20 │ read_count     │ atomic_t│ 4 B  │ Total read()  calls  (LOCK XADD)" {
    style.fill: "#2196F3"
    style.font-color: white
    style.font-size: 12
  }
  f6: "0x24 │ write_count    │ atomic_t│ 4 B  │ Total write() calls  (LOCK XADD)" {
    style.fill: "#2196F3"
    style.font-color: white
    style.font-size: 12
  }
  f7: "0x28 │ mydevice_class │ ptr     │ 8 B  │ struct class * → /sys/class/mydevice/" {
    style.fill: "#9C27B0"
    style.font-color: white
    style.font-size: 12
  }
  f8: "0x30 │ mydevice_device│ ptr     │ 8 B  │ struct device * → udev trigger" {
    style.fill: "#9C27B0"
    style.font-color: white
    style.font-size: 12
  }
  f9: "0x38 │ proc_entry     │ ptr     │ 8 B  │ struct proc_dir_entry *  /proc/mydevice" {
    style.fill: "#9C27B0"
    style.font-color: white
    style.font-size: 12
  }
  hotpath_note: |md
    ⚡ **Hot path spatial locality**
    `mydevice_read()` and `mydevice_write()` access
    `kernel_buffer` + `buffer_data_len` + `buffer_size`
    in tight sequence → **offsets 0x00–0x17** → all three
    arrive in a single 64-byte cache line fetch from L2/L3.
    Typical L1 hit after first access: **~4 cycles**.
  | {
    style.fill: "#FFF9C4"
    style.stroke: "#F57F17"
    style.font-size: 11
  }
}
# ──────────────────────────────────────────────────────────
# CACHE LINE 1  [0x040 – 0x07F]  struct cdev (part 1)
# ──────────────────────────────────────────────────────────
cl1: "Cache Line 1  [0x040 – 0x07F]  64 bytes  — struct cdev (first half)" {
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
    font-size: 13
    bold: true
  }
  c0: "0x40 │ my_cdev.kobj.name    │ char *  │ 8 B  │ kobject name pointer" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  c1: "0x48 │ my_cdev.kobj.entry  │ list    │16 B  │ kobject list linkage" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  c2: "0x58 │ my_cdev.kobj.kset   │ ptr     │ 8 B  │ kobject set pointer" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  c3: "0x60 │ my_cdev.kobj.ktype  │ ptr     │ 8 B  │ kobject type ops" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  c4: "0x68 │ my_cdev.kobj.sd     │ ptr     │ 8 B  │ sysfs dirent" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  c5: "0x70 │ my_cdev.kobj.refcount│atomic_t│ 4 B  │ kobject reference count" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  c6: "0x74 │ my_cdev.kobj (pad)  │ —       │12 B  │ alignment padding" {
    style.fill: "#EEEEEE"
    style.font-size: 12
  }
}
# ──────────────────────────────────────────────────────────
# CACHE LINE 2  [0x080 – 0x0BF]  struct cdev (part 2)
# ──────────────────────────────────────────────────────────
cl2: "Cache Line 2  [0x080 – 0x0BF]  64 bytes  — struct cdev (second half)" {
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
    font-size: 13
    bold: true
  }
  d0: "0x80 │ my_cdev.owner       │ ptr     │ 8 B  │ THIS_MODULE pointer" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  d1: "0x88 │ my_cdev.ops         │ ptr     │ 8 B  │ → &mydevice_fops  (file_operations)" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  d2: "0x90 │ my_cdev.list        │ list    │16 B  │ cdev list linkage in kernel registry" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  d3: "0xA0 │ my_cdev.dev         │ dev_t   │ 4 B  │ first device number (major:minor)" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  d4: "0xA4 │ my_cdev.count       │ uint    │ 4 B  │ number of consecutive minors (=1)" {
    style.fill: "#CE93D8"
    style.font-size: 12
  }
  d5: "0xA8 │ (padding / reserved)│ —       │24 B  │ struct padding to cache-line align" {
    style.fill: "#EEEEEE"
    style.font-size: 12
  }
  cdev_access_note: |md
    📖 **Access pattern**
    `my_cdev.ops` is fetched once at VFS dispatch
    time (`cdev_add` → `inode->i_cdev`).  After the
    initial `open()`, the `file_operations` pointer
    is cached in `filp->f_op`; `my_cdev` itself is
    **not** on the hot path for read/write.
  | {
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.font-size: 11
  }
}
# ──────────────────────────────────────────────────────────
# CACHE LINE 3  [0x0C0 – 0x0FF]  struct mutex  ← KEY ISOLATION
# ──────────────────────────────────────────────────────────
cl3: "Cache Line 3  [0x0C0 – 0x0FF]  64 bytes  — mydevice_mutex  ★ ISOLATED" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-width: 3
    font-size: 13
    bold: true
  }
  m0: "0xC0 │ mutex.owner         │atomic_long│ 8 B│ 0=unlocked; LSB flags; upper=task ptr" {
    style.fill: "#EF9A9A"
    style.font-size: 12
    style.bold: true
  }
  m1: "0xC8 │ mutex.wait_lock     │spinlock_t │ 4 B│ protects wait_list; IRQ-disabled spin" {
    style.fill: "#EF9A9A"
    style.font-size: 12
  }
  m2: "0xCC │ (spinlock padding)  │ —         │ 4 B│ natural alignment" {
    style.fill: "#EEEEEE"
    style.font-size: 12
  }
  m3: "0xD0 │ mutex.wait_list.next│ ptr       │ 8 B│ list_head: first waiter" {
    style.fill: "#EF9A9A"
    style.font-size: 12
  }
  m4: "0xD8 │ mutex.wait_list.prev│ ptr       │ 8 B│ list_head: last waiter" {
    style.fill: "#EF9A9A"
    style.font-size: 12
  }
  m5: "0xE0 │ (padding to 64 B)  │ —         │32 B│ remainder of cache line unused" {
    style.fill: "#EEEEEE"
    style.font-size: 12
  }
  mutex_isolation_note: |md
    ✅ **False-sharing isolation achieved**
    `mydevice_mutex` occupies its own cache line
    [0xC0–0xFF].  CPU0 acquiring the mutex (writing
    `mutex.owner`) does **not** invalidate the cache
    line containing `buffer_data_len` [0x08] on CPU1.
    Without this separation, every lock/unlock would
    bounce CL0 between CPUs even when `buffer_data_len`
    itself hasn't changed → ~20–40 extra cycles per op.
  | {
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.font-size: 11
  }
}
# ──────────────────────────────────────────────────────────
# CACHE LINE 4  [0x100 – 0x13F]  wait_queue_head_t × 2
# ──────────────────────────────────────────────────────────
cl4: "Cache Line 4  [0x100 – 0x13F]  64 bytes  — read_queue + write_queue" {
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
    font-size: 13
    bold: true
  }
  w0: "0x100│ read_queue.lock     │spinlock_t │ 4 B│ IRQ-safe; protects read_queue.head" {
    style.fill: "#A5D6A7"
    style.font-size: 12
  }
  w1: "0x104│ (spinlock padding)  │ —         │ 4 B│ alignment" {
    style.fill: "#EEEEEE"
    style.font-size: 12
  }
  w2: "0x108│ read_queue.head.next│ ptr       │ 8 B│ first sleeping reader task entry" {
    style.fill: "#A5D6A7"
    style.font-size: 12
  }
  w3: "0x110│ read_queue.head.prev│ ptr       │ 8 B│ last sleeping reader task entry" {
    style.fill: "#A5D6A7"
    style.font-size: 12
  }
  w4: "0x118│ write_queue.lock    │spinlock_t │ 4 B│ IRQ-safe; protects write_queue.head" {
    style.fill: "#66BB6A"
    style.font-size: 12
    style.font-color: white
  }
  w5: "0x11C│ (spinlock padding)  │ —         │ 4 B│ alignment" {
    style.fill: "#EEEEEE"
    style.font-size: 12
  }
  w6: "0x120│ write_queue.head.next│ptr       │ 8 B│ first sleeping writer task entry" {
    style.fill: "#66BB6A"
    style.font-size: 12
    style.font-color: white
  }
  w7: "0x128│ write_queue.head.prev│ptr       │ 8 B│ last sleeping writer task entry" {
    style.fill: "#66BB6A"
    style.font-size: 12
    style.font-color: white
  }
  w8: "0x130│ (unused / future)   │ —         │16 B│ remainder of cache line" {
    style.fill: "#EEEEEE"
    style.font-size: 12
  }
  wq_note: |md
    ⏳ **Wait queue access pattern**
    Both queues share one cache line.  `wake_up_interruptible`
    acquires `queue.lock` (spinlock), walks `queue.head` list,
    sets each waiter `TASK_RUNNING`.  Both queues landing on
    one cache line means the second `poll_wait()` call in
    `.poll` is a L1 hit after the first.
  | {
    style.fill: "#DCEDC8"
    style.stroke: "#558B2F"
    style.font-size: 11
  }
}
# ──────────────────────────────────────────────────────────
# kernel_buffer → slab allocation (off-diagram, shown by pointer)
# ──────────────────────────────────────────────────────────
slab_page: "Slab-allocated buffer  (separate physical page)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    stroke-dash: 4
    font-size: 13
  }
  s0: "0x000│ [valid FIFO data]   │ uint8[] │N B   │ indices [0, buffer_data_len)" {
    style.fill: "#90CAF9"
    style.font-size: 12
  }
  s1: "  N  │ [free space]        │ uint8[] │M B   │ indices [N, buffer_size), M=buf_size-N" {
    style.fill: "#4CAF50"
    style.font-color: white
    style.font-size: 12
  }
  slab_note: |md
    `kzalloc(buffer_size, GFP_KERNEL)` → SLUB slab or
    page allocator (for sizes > 4096).  Memory is physically
    contiguous within the slab object.  The `kernel_buffer`
    pointer in CL0 (offset 0x00) points here.
    First access (cold): L3 or DRAM miss (~100–300 cycles).
    Subsequent accesses (warm): L1/L2 hit (~4–12 cycles).
  | {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
    style.font-size: 11
  }
}
# ──────────────────────────────────────────────────────────
# MESI Protocol Annotation
# ──────────────────────────────────────────────────────────
mesi: "MESI Cache Coherency Protocol — Inter-CPU Impact" {
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
    font-size: 13
    bold: true
  }
  scenario_a: |md
    **Scenario A — Concurrent writer + reader (no mutex = RACE)**
    1. CPU0 (writer): holds CL0 in **Modified** state; updates `buffer_data_len = 50`
    2. CPU1 (reader): holds CL0 in **Shared** state; reads stale `buffer_data_len = 0`
    3. CPU0 stores → CPU1's CL0 copy is **Invalidated** (MESIF protocol)
    4. CPU1 re-fetches CL0 from L3 → pays ~30–60 cycle coherence penalty
    5. **Result without mutex**: CPU1 may read `0` then `50` or any torn intermediate
       → data corruption / infinite wait / wrong EOF
  | {
    style.fill: "#FFCCBC"
    style.stroke: "#BF360C"
    style.font-size: 11
  }
  scenario_b: |md
    **Scenario B — With mutex (correct M4 implementation)**
    1. CPU0 acquires mutex: `cmpxchg(mutex.owner, 0, task_ptr)` → bus lock on CL3
       CL3 transitions M on CPU0; invalidated on all other CPUs
    2. CPU0 writes `buffer_data_len` in CL0 → CL0 Modified on CPU0
    3. CPU0: `mutex_unlock` → memory barrier (`smp_mb`) ensures CL0 write
       is globally visible before CL3 is released
    4. CPU1 acquires mutex: fetches CL3 (was Invalidated) from L3 → pays 1 miss
    5. CPU1 reads `buffer_data_len` from CL0: fetches updated CL0 from L3 → pays 1 miss
    6. **Correct**: CPU1 is guaranteed to see CPU0's write; no torn reads
    **Total coherence cost per lock/unlock pair**: ~2 cache-line round-trips ≈ 60–120 cycles
  | {
    style.fill: "#DCEDC8"
    style.stroke: "#1B5E20"
    style.font-size: 11
  }
  scenario_c: |md
    **Scenario C — False sharing (what WOULD happen if mutex shared CL0)**
    If `mydevice_mutex` were placed at offset 0x20 (inside CL0):
    • Every `mutex_lock` / `mutex_unlock` by any CPU writes `mutex.owner` in CL0
    • This invalidates CL0 on all other CPUs — including their cached copies
      of `buffer_data_len` and `buffer_size`
    • Even a CPU that only wants to READ `buffer_data_len` must re-fetch CL0
      after every lock operation by any other CPU
    • At 4 concurrent readers + 4 writers: CL0 bounces between 8 CPUs
      continuously → ~8 × 60 = 480 extra cycles per round-trip just for false sharing
    **M4's layout puts mutex in CL3 → false sharing eliminated**
  | {
    style.fill: "#FFF9C4"
    style.stroke: "#F57F17"
    style.font-size: 11
  }
}
# ──────────────────────────────────────────────────────────
# Legend
# ──────────────────────────────────────────────────────────
legend: "Legend" {
  near: bottom-center
  style: {
    fill: white
    stroke: "#757575"
    stroke-width: 1
    font-size: 11
  }
  l_orange: "█ Orange: buffer state (hot path — read/write per syscall)" {
    style.fill: "#FF9800"
    style.font-color: white
    style.font-size: 11
  }
  l_blue: "█ Blue: atomic counters (LOCK XADD — no mutex needed)" {
    style.fill: "#2196F3"
    style.font-color: white
    style.font-size: 11
  }
  l_purple: "█ Purple: kernel infrastructure pointers (write-once at init)" {
    style.fill: "#9C27B0"
    style.font-color: white
    style.font-size: 11
  }
  l_red: "█ Red: mutex fields (CL3 — isolated to prevent false sharing)" {
    style.fill: "#F44336"
    style.font-color: white
    style.font-size: 11
  }
  l_green: "█ Green: wait queue entries (CL4 — both queues share one cache line)" {
    style.fill: "#4CAF50"
    style.font-color: white
    style.font-size: 11
  }
  l_gray: "░ Gray: padding / alignment / unused" {
    style.fill: "#EEEEEE"
    style.font-size: 11
  }
}
# ──────────────────────────────────────────────────────────
# CONNECTIONS
# ──────────────────────────────────────────────────────────
cl0.f0 -> slab_page: "dereference: kernel_buffer points here\n(separate physical page, may be in different cache set)" {
  style.stroke: "#1565C0"
  style.stroke-dash: 4
  style.stroke-width: 2
  style.font-size: 10
}
cl0 -> cl1: "offset 0x40: my_cdev begins" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 2
  style.font-size: 10
}
cl1 -> cl2: "offset 0x80: my_cdev continued" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 2
  style.font-size: 10
}
cl2 -> cl3: "offset 0xC0: mydevice_mutex (★ isolated cache line)" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.font-size: 10
}
cl3 -> cl4: "offset 0x100: wait queue heads" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.font-size: 10
}
mesi -> cl0: "CL0: primary contention point for buffer state" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
  style.font-size: 10
}
mesi -> cl3: "CL3: mutex contention point (separate = no false sharing)" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
  style.font-size: 10
}