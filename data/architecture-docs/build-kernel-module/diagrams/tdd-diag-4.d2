vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
insmod_proc: "insmod(1)\nprocess"
finit_mod: "finit_module(2)\nsyscall handler"
param_sub: "module_param\nsubsystem"
buffer_var: "static int\nbuffer_size"
init_fn: "hello_init()\n__init"
sysfs_ko: "kobject /\nsysfs layer"
attr_file: "/sys/module/hello\n/parameters/\nbuffer_size"
user_cat: "user: cat(1)\nor echo(1)"
insmod_proc -> finit_mod: "finit_module(fd,\n\"buffer_size=8192\", 0)"
step1: {
  label: "① Parse param string"
  insmod_proc -> insmod_proc
}
finit_mod -> param_sub: "parse_args(\"buffer_size=8192\",\n module_param list)"
param_sub -> param_sub: "find registration:\nmodule_param(buffer_size, int, 0444)"
param_sub -> buffer_var: "param_set_int() →\n*buffer_size = 8192"
buffer_var -> param_sub: "write 8192 to\nstatic storage ✓"
step2: {
  label: "② module_init — value already set"
}
finit_mod -> init_fn: "call hello_init()"
init_fn -> buffer_var: "read buffer_size\n(already 8192)"
buffer_var -> init_fn: "8192"
init_fn -> init_fn: "validate: 1 ≤ 8192 ≤ 1048576 ✓\nprintk(KERN_INFO\n\"buffer_size=8192\")"
init_fn -> finit_mod: "return 0 (success)"
step3: {
  label: "③ sysfs kobject creation — mode 0444"
}
finit_mod -> sysfs_ko: "module_param_sysfs_setup()\ncreate kobject attrs"
sysfs_ko -> attr_file: "create attr:\nmode=0444 (r--r--r--)\nparam_get=param_get_int\nparam_set=NULL (0444→no setter)"
attr_file -> sysfs_ko: "inode created ✓"
sysfs_ko -> finit_mod: "sysfs ready"
finit_mod -> insmod_proc: "return 0 → module live"
step4: {
  label: "④ Runtime read — 0444 allows any user"
}
user_cat -> attr_file: "open + read\n/sys/module/hello/parameters/buffer_size"
attr_file -> sysfs_ko: "sysfs_kf_seq_show()"
sysfs_ko -> buffer_var: "param_get_int() →\nread *buffer_size"
buffer_var -> sysfs_ko: "8192"
sysfs_ko -> attr_file: "seq_printf → \"8192\\n\""
attr_file -> user_cat: "\"8192\" (3 bytes + newline)"
step5: {
  label: "⑤ Runtime write — 0444 BLOCKS write"
}
user_cat -> attr_file: "echo 999 >\n/sys/.../buffer_size\n(attempt write)" {
  style.stroke: red
  style.stroke-dash: 4
}
attr_file -> user_cat: "EACCES (-13)\nPermission denied\n[param_set is NULL;\nmode bits 0444 deny write]" {
  style.stroke: red
}
contrast: {
  label: "⑥ Contrast: 0644 mode — write IS allowed"
}
note_0644: "If declared: module_param(buffer_size, int, 0644)\n→ kobject attr mode = 0644 (rw-r--r--)\n→ param_set = param_set_int (registered)\n→ root may: echo 16384 > /sys/.../buffer_size\n→ param_set_int writes 16384 into buffer_size\n→ value live in module immediately\n(no buffer realloc — M1 has no buffer)" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.font-size: 13
  near: bottom-center
}