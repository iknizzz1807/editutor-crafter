vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}
direction: down
title: |md
  ## printk Log Levels: KERN_* → Ring Buffer → dmesg / Console Routing
| {near: top-center}
# ── Source layer ──────────────────────────────────────────────────────────────
sources: "Call Sites" {
  style.fill: "#f0f0f0"
  style.stroke: "#999999"
  style.border-radius: 6
  raw: |md
    **Direct printk()**
    c
    printk(KERN_ERR
      "hello: failed\n");
    
    *Two adjacent string literals —*
    *C token concatenation, not two args*
  | {
    style.fill: "#ffffff"
    style.stroke: "#cccccc"
    style.border-radius: 4
  }
  wrapper: |md
    **pr_* convenience wrappers**
    c
    pr_emerg("...\n");   // → KERN_EMERG
    pr_alert("...\n");   // → KERN_ALERT
    pr_crit("...\n");    // → KERN_CRIT
    pr_err("...\n");     // → KERN_ERR
    pr_warn("...\n");    // → KERN_WARNING
    pr_notice("...\n");  // → KERN_NOTICE
    pr_info("...\n");    // → KERN_INFO
    pr_debug("...\n");   // → KERN_DEBUG
    
    *Compile-time macro: prepends level string*
    *pr_debug() is no-op unless DEBUG defined*
  | {
    style.fill: "#ffffff"
    style.stroke: "#cccccc"
    style.border-radius: 4
  }
}
# ── Level encoding ─────────────────────────────────────────────────────────────
levels: "KERN_* Level Encoding (bits 15-8 of first byte)" {
  style.fill: "#f8f8f8"
  style.stroke: "#aaaaaa"
  style.border-radius: 6
  grid-columns: 1
  grid-gap: 2
  l0: |md
    **KERN_EMERG  (0)**  `"\x010"` — System unusable
  | { style.fill: "#7b0000"; style.font-color: "#ffffff"; style.border-radius: 3 }
  l1: |md
    **KERN_ALERT  (1)**  `"\x011"` — Act immediately
  | { style.fill: "#b30000"; style.font-color: "#ffffff"; style.border-radius: 3 }
  l2: |md
    **KERN_CRIT   (2)**  `"\x012"` — Critical condition
  | { style.fill: "#cc3300"; style.font-color: "#ffffff"; style.border-radius: 3 }
  l3: |md
    **KERN_ERR    (3)**  `"\x013"` — Error condition
  | { style.fill: "#e05000"; style.font-color: "#ffffff"; style.border-radius: 3 }
  l4: |md
    **KERN_WARNING(4)**  `"\x014"` — Warning; recoverable
  | { style.fill: "#cc8800"; style.font-color: "#ffffff"; style.border-radius: 3 }
  l5: |md
    **KERN_NOTICE (5)**  `"\x015"` — Normal but significant
  | { style.fill: "#4a7c00"; style.font-color: "#ffffff"; style.border-radius: 3 }
  l6: |md
    **KERN_INFO   (6)**  `"\x016"` — Informational
  | { style.fill: "#1a6ea0"; style.font-color: "#ffffff"; style.border-radius: 3 }
  l7: |md
    **KERN_DEBUG  (7)**  `"\x017"` — Debug (compiled out unless DEBUG)
  | { style.fill: "#555555"; style.font-color: "#ffffff"; style.border-radius: 3 }
}
# ── Ring buffer ────────────────────────────────────────────────────────────────
ringbuf: "Kernel Log Ring Buffer" {
  style.fill: "#e8f0fe"
  style.stroke: "#3c5fa0"
  style.stroke-width: 2
  style.border-radius: 8
  desc: |md
    **Circular buffer in kernel memory**
    Size: 512 KB – 4 MB (CONFIG_LOG_BUF_SHIFT)
    Oldest entries overwritten when full
    Each record: timestamp + level + message text
    Atomic write — printk is NMI-safe
  | {
    style.fill: "#dce8fd"
    style.stroke: "#6688cc"
    style.border-radius: 4
  }
  struct: |md
    
    struct printk_record {
        u64  ts_nsec;       // timestamp
        u16  text_len;      // message length
        u8   facility;      // always 0 for kernel
        u8   level;         // 0–7
        char text[];        // NUL-terminated message
    }
    
  | {
    style.fill: "#f0f4ff"
    style.stroke: "#8899cc"
    style.border-radius: 4
    style.font: mono
  }
}
# ── Console loglevel gate ──────────────────────────────────────────────────────
gate: "Console Log Level Gate" {
  style.fill: "#fff8e0"
  style.stroke: "#c0a000"
  style.stroke-width: 2
  style.border-radius: 6
  rule: |md
    **Rule:** message printed to console
    **only if** `msg_level < console_loglevel`
    *(lower number = higher severity)*
    Read/write via:
    `cat /proc/sys/kernel/printk`
    → `4  4  1  7`
    → `current  default  min  boot`
    Default console_loglevel = **4 (WARNING)**
    → EMERG, ALERT, CRIT, ERR appear on console
    → WARNING, NOTICE, INFO, DEBUG do NOT
  | {
    style.fill: "#fffacc"
    style.stroke: "#d4aa00"
    style.border-radius: 4
  }
}
# ── Output sinks ───────────────────────────────────────────────────────────────
sinks: "Output Destinations" {
  style.fill: "#f0f8f0"
  style.stroke: "#559955"
  style.border-radius: 6
  console: "System Console / VT" {
    style.fill: "#1a1a1a"
    style.font-color: "#33ff33"
    style.border-radius: 4
    txt: |md
      **tty0 / serial console**
      Immediate output during boot
      Only messages that pass
      the console_loglevel gate
      Hardware: UART, VGA framebuffer
    | {
      style.fill: "#222222"
      style.font-color: "#ccffcc"
      style.border-radius: 3
    }
  }
  kmsg: "/dev/kmsg" {
    style.fill: "#e8f8e8"
    style.stroke: "#448844"
    style.border-radius: 4
    txt: |md
      **Character device — always written**
      No level filtering applied
      Userspace daemons (journald, syslogd)
      read records in structured format
      `read()` returns one record per call
      `write()` injects synthetic log entries
    | {
      style.fill: "#f0fff0"
      style.stroke: "#66aa66"
      style.border-radius: 3
    }
  }
  dmesg: "dmesg command" {
    style.fill: "#e8eeff"
    style.stroke: "#4455aa"
    style.border-radius: 4
    txt: |md
      **Reads ring buffer via syslog(2) syscall**
      `dmesg`           → dump all
      `dmesg -w`        → follow (tail -f style)
      `dmesg -T`        → human timestamps
      `dmesg -l err`    → filter by level
      `dmesg | grep hello` → grep module msgs
      No level filtering — shows everything
    | {
      style.fill: "#f0f2ff"
      style.stroke: "#6677bb"
      style.border-radius: 3
    }
  }
  journal: "systemd-journald" {
    style.fill: "#fef0e8"
    style.stroke: "#aa6633"
    style.border-radius: 4
    txt: |md
      **Reads /dev/kmsg continuously**
      Persistent across reboots
      `journalctl -k`   → kernel messages
      `journalctl -kf`  → follow kernel log
      Stores in binary journal format
    | {
      style.fill: "#fff4ee"
      style.stroke: "#cc8855"
      style.border-radius: 3
    }
  }
}
# ── Wrapper expansion note ─────────────────────────────────────────────────────
concat_note: |md
  **C Token Concatenation — how pr_info() expands:**
  `pr_info("loaded\n")`
  → preprocessor expands to →
  `printk(KERN_INFO "loaded\n")`
  → two adjacent string literals merge to →
  `printk("\x016" "loaded\n")`
  → single string: `"\x016loaded\n"`
  The `\x01` byte is `KERN_SOH`; digit `6` is the level.
  *No runtime overhead — pure compile-time substitution.*
| {
  near: bottom-center
  style.fill: "#f8f8f8"
  style.stroke: "#aaaaaa"
  style.border-radius: 6
}
# ── Connections ────────────────────────────────────────────────────────────────
sources.raw -> levels: "printk(KERN_ERR \"...\") call" {
  style.stroke: "#666666"
  style.stroke-width: 2
}
sources.wrapper -> levels: "pr_err() → KERN_ERR prepended at compile time" {
  style.stroke: "#666666"
  style.stroke-width: 2
  style.stroke-dash: 4
}
levels -> ringbuf: "Structured record written atomically\n(level byte + timestamp + text)" {
  style.stroke: "#3c5fa0"
  style.stroke-width: 3
  style.animated: true
}
ringbuf -> gate: "Every message evaluated\nagainst console_loglevel" {
  style.stroke: "#c0a000"
  style.stroke-width: 2
}
gate -> sinks.console: "PASS: msg_level < console_loglevel\n(e.g. KERN_ERR=3 < default=4)" {
  style.stroke: "#cc3300"
  style.stroke-width: 2
  style.font-color: "#cc3300"
}
gate -> sinks.console: "FAIL: msg_level ≥ console_loglevel\n(e.g. KERN_INFO=6 ≥ 4 → suppressed)" {
  style.stroke: "#999999"
  style.stroke-width: 1
  style.stroke-dash: 6
  style.font-color: "#999999"
}
ringbuf -> sinks.kmsg: "ALL messages — no filtering\nStructured binary records" {
  style.stroke: "#448844"
  style.stroke-width: 2
  style.animated: true
}
ringbuf -> sinks.dmesg: "syslog(SYSLOG_ACTION_READ_ALL)\nor /dev/kmsg read" {
  style.stroke: "#4455aa"
  style.stroke-width: 2
}
sinks.kmsg -> sinks.journal: "Continuous read() of /dev/kmsg\nOne record per syscall" {
  style.stroke: "#aa6633"
  style.stroke-width: 1
  style.stroke-dash: 3
}