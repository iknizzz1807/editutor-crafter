vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

direction: right

title: |md
  # Major/Minor Number Registry and /dev/ Node Lifetime
  **Flow:** `alloc_chrdev_region` → `cdev_add` → `class_create` → `device_create` → **udev** → `/dev/mydevice`
| {near: top-center}

# ─── REGISTRATION PHASE ───────────────────────────────────────────────────────
registration: "Registration Phase (Kernel Module Init)" {
  style: {
    fill: "#f0f4ff"
    stroke: "#7b9ef0"
    stroke-width: 2
    border-radius: 8
  }

  alloc_fn: "alloc_chrdev_region(&dev_num, 0, 1, 'mydevice')" {
    shape: rectangle
    style: {
      fill: "#b39ddb"
      font-color: "#1a1a2e"
      bold: true
      border-radius: 4
    }
  }

  chrdevs: "kernel chrdevs[] table" {
    shape: rectangle
    style: {
      fill: "#7c4dff"
      font-color: white
      bold: true
      border-radius: 4
    }
    entry: |md
      **Slot Major=251**
      - Name: "mydevice"
      - Ops: (none yet)
      - fops: NULL
    |
  }

  cdev_init_fn: "cdev_init(&my_cdev, &mydevice_fops)" {
    shape: rectangle
    style: {
      fill: "#b39ddb"
      font-color: "#1a1a2e"
      bold: true
      border-radius: 4
    }
  }

  cdev_add_fn: "cdev_add(&my_cdev, dev_num, 1)" {
    shape: rectangle
    style: {
      fill: "#b39ddb"
      font-color: "#1a1a2e"
      bold: true
      border-radius: 4
    }
  }

  cdev_struct: "struct cdev my_cdev" {
    shape: rectangle
    style: {
      fill: "#ff6d00"
      font-color: white
      bold: true
      border-radius: 4
    }
    fields: |md
      **Internal State**
      - `ops` → `&mydevice_fops`
      - `owner` → `THIS_MODULE`
      - `dev` → `MKDEV(251, 0)`
      - `count` → 1
      - `kobj` (embedded)
    |
  }

  alloc_fn -> chrdevs.entry: "1. allocates major=251" {
    style.stroke: "#7c4dff"
    style.bold: true
  }
  cdev_init_fn -> cdev_struct: "2. initializes" {
    style.stroke: "#ff6d00"
  }
  cdev_add_fn -> chrdevs.entry: "3. binds cdev to slot" {
    style.stroke: "#ff6d00"
    style.bold: true
  }
  cdev_add_fn -> cdev_struct: "reads" {
    style.stroke: "#ff6d00"
    style.stroke-dash: 4
  }
}

# ─── SYSFS / UDEV PHASE ──────────────────────────────────────────────────────
sysfs_phase: "Sysfs + udev Event Phase" {
  style: {
    fill: "#fff8e1"
    stroke: "#f9a825"
    stroke-width: 2
    border-radius: 8
  }

  class_create_fn: "class_create(THIS_MODULE, 'mydevice')" {
    shape: rectangle
    style: {
      fill: "#f9a825"
      font-color: "#1a1a2e"
      bold: true
      border-radius: 4
    }
  }

  sysfs_class: "/sys/class/mydevice/" {
    shape: rectangle
    style: {
      fill: "#ffe082"
      font-color: "#1a1a2e"
      border-radius: 4
      stroke: "#f9a825"
    }
  }

  device_create_fn: "device_create(cls, NULL, dev_num, NULL, 'mydevice')" {
    shape: rectangle
    style: {
      fill: "#f9a825"
      font-color: "#1a1a2e"
      bold: true
      border-radius: 4
    }
  }

  sysfs_dev_file: "/sys/class/mydevice/mydevice/" {
    shape: rectangle
    style: {
      fill: "#ffe082"
      font-color: "#1a1a2e"
      border-radius: 4
      stroke: "#f9a825"
    }
    dev_attr: |md
      **dev** → "251:0"
      **uevent** (trigger)
      **subsystem** → char
    |
  }

  netlink_event: "Netlink Uevent: ACTION=add" {
    shape: oval
    style: {
      fill: "#fff3e0"
      font-color: "#e65100"
      stroke: "#ff6d00"
      stroke-dash: 3
    }
  }

  class_create_fn -> sysfs_class: "creates" {
    style.stroke: "#f9a825"
    style.bold: true
  }
  device_create_fn -> sysfs_dev_file.dev_attr: "populates" {
    style.stroke: "#f9a825"
    style.bold: true
  }
  device_create_fn -> netlink_event: "broadcasts" {
    style.stroke: "#ff6d00"
    style.stroke-dash: 3
  }
}

# ─── UDEV DAEMON ─────────────────────────────────────────────────────────────
udev_phase: "Userspace udev Phase" {
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
    stroke-width: 2
    border-radius: 8
  }

  udev_daemon: "systemd-udevd daemon" {
    shape: rectangle
    style: {
      fill: "#4caf50"
      font-color: white
      bold: true
      border-radius: 4
    }
  }

  udev_rule: "Rule Evaluation (KERNEL=='mydevice')" {
    shape: rectangle
    style: {
      fill: "#a5d6a7"
      font-color: "#1a1a2e"
      border-radius: 4
      stroke: "#2e7d32"
    }
  }

  mknod_call: "mknod /dev/mydevice c 251 0" {
    shape: rectangle
    style: {
      fill: "#388e3c"
      font-color: white
      bold: true
      border-radius: 4
    }
  }

  udev_daemon -> udev_rule: "evaluates"
  udev_rule -> mknod_call: "executes" {
    style.stroke: "#2e7d32"
    style.bold: true
  }
}

# ─── /dev/ NODE ──────────────────────────────────────────────────────────────
dev_node: "/dev/mydevice" {
  shape: rectangle
  style: {
    fill: "#0d47a1"
    font-color: white
    bold: true
    font-size: 18
    border-radius: 6
    shadow: true
  }
  attrs: |md
    **Inode Data**
    - Type: char (c)
    - Maj: 251  Min: 0
    - Mode: 0666
    - dev_t: 0xFB00
  |
}

# ─── READ-ONLY VIEW ─────────────────────────────────────────────────────────
proc_view: "/proc/devices (View)" {
  shape: rectangle
  style: {
    fill: "#e1f5fe"
    stroke: "#0288d1"
    stroke-width: 2
    border-radius: 6
    stroke-dash: 4
  }
  content: |md
    **Character devices:**
    1 mem
    ...
    **251 mydevice**
  |
}

# ─── CLEANUP PHASE ────────────────────────────────────────────────────────────
cleanup: "Cleanup Phase (Module Exit)" {
  style: {
    fill: "#fce4ec"
    stroke: "#c62828"
    stroke-width: 2
    border-radius: 8
  }

  device_destroy_fn: "device_destroy()" {
    shape: rectangle
    style: { fill: "#ef9a9a"; bold: true }
  }

  class_destroy_fn: "class_destroy()" {
    shape: rectangle
    style: { fill: "#ef9a9a"; bold: true }
  }

  cdev_del_fn: "cdev_del(&my_cdev)" {
    shape: rectangle
    style: { fill: "#ef9a9a"; bold: true }
  }

  unreg_fn: "unregister_chrdev_region()" {
    shape: rectangle
    style: { fill: "#ef9a9a"; bold: true }
  }

  udev_rm: "/dev/node unlinked" {
    shape: oval
    style: {
      fill: "#ffcdd2"
      font-color: "#c62828"
      stroke: "#c62828"
      stroke-dash: 3
    }
  }
}

# ─── CONNECTIONS ─────────────────────────────────────────────────────────────

registration.cdev_add_fn -> sysfs_phase.class_create_fn: "Step 3: Proceed to sysfs" {
  style.stroke: "#888"
  style.stroke-dash: 3
}

sysfs_phase.netlink_event -> udev_phase.udev_daemon: "Netlink Message" {
  style.stroke: "#ff6d00"
  style.animated: true
}

udev_phase.mknod_call -> dev_node: "Virtual File creation" {
  style.stroke: "#2e7d32"
  style.bold: true
  style.stroke-width: 2
}

registration.chrdevs -> proc_view: "Virtual expose" {
  style.stroke: "#0288d1"
  style.stroke-dash: 5
}

sysfs_phase.sysfs_dev_file.dev_attr -> udev_phase.udev_daemon: "Read Major:Minor" {
  style.stroke: "#f9a825"
  style.stroke-dash: 3
}

# ─── ANNOTATIONS ─────────────────────────────────────────────────────────────
open_path: |md
  ### VFS open() path:
  1. `open("/dev/mydevice")` → reads maj=251 from inode
  2. Kernel looks up `chrdevs[251]`
  3. Finds `my_cdev.ops` → `&mydevice_fops`
  4. Execution enters module's `open()` handler
| {
  near: bottom-center
  style: {
    fill: "#f3e5f5"
    stroke: "#7b1fa2"
    stroke-dash: 3
  }
}

cleanup_order: |md
  ### Destruction Chain (LIFO):
  1. `device_destroy()` → udev rm
  2. `class_destroy()` → sysfs rm
  3. `cdev_del()` → fops unlink
  4. `unregister_chrdev_region()`
| {
  near: bottom-right
  style: { fill: "#fce4ec"; stroke: "#c62828" }
}