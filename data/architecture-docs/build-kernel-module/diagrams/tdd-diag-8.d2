vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## `struct file_operations` — Memory Layout and VFS Dispatch
  Each field is a function pointer (8 bytes on x86-64). VFS checks for NULL before dispatch.
| {near: top-center}
# ─── Legend ───
legend: {
  near: bottom-right
  style: {
    fill: "#f8f8f8"
    stroke: "#aaaaaa"
    border-radius: 6
  }
  set_m2: "■ Set in M2" {
    shape: text
    style.font-color: "#1a6fba"
    style.bold: true
  }
  set_m3: "■ Added in M3" {
    shape: text
    style.font-color: "#7c3aed"
    style.bold: true
  }
  set_m4: "■ Added in M4" {
    shape: text
    style.font-color: "#059669"
    style.bold: true
  }
  null_field: "□ NULL → default/error" {
    shape: text
    style.font-color: "#888888"
    style.bold: true
  }
}
# ─── struct file_operations memory layout ───
fops: "struct file_operations   [sizeof ≈ 280 bytes on x86-64, 35 pointers × 8 B]" {
  style: {
    fill: "#e8eaf6"
    stroke: "#3949ab"
    stroke-width: 2
    border-radius: 8
    bold: true
    font-size: 14
  }
  # ── Cache line 0: bytes 0–63 ──
  cl0: "── Cache Line 0 (bytes 0x00 – 0x3F) ──────────────────────────────" {
    shape: text
    style.italic: true
    style.font-color: "#555555"
    style.font-size: 11
  }
  f_owner: "offset 0x00 │ .owner   │ 8 B │ struct module *   │ = THIS_MODULE" {
    style: {
      fill: "#bbdefb"
      stroke: "#1565c0"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_llseek: "offset 0x08 │ .llseek  │ 8 B │ fn ptr            │ = NULL → default_llseek" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_read: "offset 0x10 │ .read    │ 8 B │ fn ptr            │ = mydevice_read   [M2]" {
    style: {
      fill: "#bbdefb"
      stroke: "#1565c0"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_write: "offset 0x18 │ .write   │ 8 B │ fn ptr            │ = mydevice_write  [M2]" {
    style: {
      fill: "#bbdefb"
      stroke: "#1565c0"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_read_iter: "offset 0x20 │ .read_iter│ 8 B │ fn ptr           │ = NULL" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_write_iter: "offset 0x28 │.write_iter│ 8 B │ fn ptr           │ = NULL" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_iterate_shared: "offset 0x30 │.iterate_shared│ 8 B │ fn ptr     │ = NULL" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_poll: "offset 0x38 │ .poll    │ 8 B │ fn ptr            │ = NULL → always-ready [M2/M3] / mydevice_poll [M4]" {
    style: {
      fill: "#d1fae5"
      stroke: "#065f46"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  # ── Cache line 1: bytes 64–127 ──
  cl1: "── Cache Line 1 (bytes 0x40 – 0x7F) ──────────────────────────────" {
    shape: text
    style.italic: true
    style.font-color: "#555555"
    style.font-size: 11
  }
  f_unlocked_ioctl: "offset 0x40 │.unlocked_ioctl│ 8 B │ fn ptr │ = NULL → -ENOTTY [M2] / mydevice_ioctl [M3]" {
    style: {
      fill: "#ede9fe"
      stroke: "#5b21b6"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_compat_ioctl: "offset 0x48 │.compat_ioctl  │ 8 B │ fn ptr │ = NULL" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_mmap: "offset 0x50 │ .mmap   │ 8 B │ fn ptr            │ = NULL → -ENODEV" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_open: "offset 0x58 │ .open   │ 8 B │ fn ptr            │ = mydevice_open   [M2]" {
    style: {
      fill: "#bbdefb"
      stroke: "#1565c0"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_flush: "offset 0x60 │ .flush  │ 8 B │ fn ptr            │ = NULL" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_release: "offset 0x68 │ .release│ 8 B │ fn ptr            │ = mydevice_release [M2]" {
    style: {
      fill: "#bbdefb"
      stroke: "#1565c0"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_fsync: "offset 0x70 │ .fsync  │ 8 B │ fn ptr            │ = NULL" {
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  f_ellipsis: "│  … (remaining 19 fields, offsets 0x78–0x118) …" {
    shape: text
    style.italic: true
    style.font-color: "#888888"
    style.font-size: 12
  }
  cl0 -> f_owner: "" { style.opacity: 0 }
  f_owner -> f_llseek: "" { style.opacity: 0 }
  f_llseek -> f_read: "" { style.opacity: 0 }
  f_read -> f_write: "" { style.opacity: 0 }
  f_write -> f_read_iter: "" { style.opacity: 0 }
  f_read_iter -> f_write_iter: "" { style.opacity: 0 }
  f_write_iter -> f_iterate_shared: "" { style.opacity: 0 }
  f_iterate_shared -> f_poll: "" { style.opacity: 0 }
  f_poll -> cl1: "" { style.opacity: 0 }
  cl1 -> f_unlocked_ioctl: "" { style.opacity: 0 }
  f_unlocked_ioctl -> f_compat_ioctl: "" { style.opacity: 0 }
  f_compat_ioctl -> f_mmap: "" { style.opacity: 0 }
  f_mmap -> f_open: "" { style.opacity: 0 }
  f_open -> f_flush: "" { style.opacity: 0 }
  f_flush -> f_release: "" { style.opacity: 0 }
  f_release -> f_fsync: "" { style.opacity: 0 }
  f_fsync -> f_ellipsis: "" { style.opacity: 0 }
}
# ─── VFS NULL-check dispatch logic ───
vfs_dispatch: "VFS Dispatch Logic (kernel/fs/read_write.c, fs/ioctl.c, …)" {
  style: {
    fill: "#fff9c4"
    stroke: "#f9a825"
    stroke-width: 2
    border-radius: 8
    font-size: 13
    bold: true
  }
  vfs_read_check: |go
    // vfs_read():
    if (!file->f_op->read &&
        !file->f_op->read_iter)
        return -EINVAL;
  | {
    style.fill: "#fffde7"
    style.stroke: "#f9a825"
    style.font: mono
    style.font-size: 11
    style.border-radius: 4
  }
  vfs_write_check: |go
    // vfs_write():
    if (!file->f_op->write &&
        !file->f_op->write_iter)
        return -EINVAL;
  | {
    style.fill: "#fffde7"
    style.stroke: "#f9a825"
    style.font: mono
    style.font-size: 11
    style.border-radius: 4
  }
  vfs_ioctl_check: |go
    // do_vfs_ioctl():
    if (!file->f_op->unlocked_ioctl)
        return -ENOTTY;
  | {
    style.fill: "#fffde7"
    style.stroke: "#f9a825"
    style.font: mono
    style.font-size: 11
    style.border-radius: 4
  }
  vfs_poll_check: |go
    // do_pollfd():
    if (!file->f_op->poll)
        // assume always-ready:
        mask = DEFAULT_POLLMASK;
  | {
    style.fill: "#fffde7"
    style.stroke: "#f9a825"
    style.font: mono
    style.font-size: 11
    style.border-radius: 4
  }
}
# ─── Syscall sources ───
syscalls: "Syscall Entry Points" {
  style: {
    fill: "#fce4ec"
    stroke: "#c62828"
    stroke-width: 2
    border-radius: 8
    font-size: 13
    bold: true
  }
  sc_open: "open(2) / openat(2)" {
    style.fill: "#ffcdd2"
    style.stroke: "#c62828"
    style.border-radius: 4
    style.font: mono
    style.font-size: 12
  }
  sc_read: "read(2) / pread64(2)" {
    style.fill: "#ffcdd2"
    style.stroke: "#c62828"
    style.border-radius: 4
    style.font: mono
    style.font-size: 12
  }
  sc_write: "write(2) / pwrite64(2)" {
    style.fill: "#ffcdd2"
    style.stroke: "#c62828"
    style.border-radius: 4
    style.font: mono
    style.font-size: 12
  }
  sc_ioctl: "ioctl(2)" {
    style.fill: "#ffcdd2"
    style.stroke: "#c62828"
    style.border-radius: 4
    style.font: mono
    style.font-size: 12
  }
  sc_poll: "poll(2) / select(2) / epoll_wait(2)" {
    style.fill: "#ffcdd2"
    style.stroke: "#c62828"
    style.border-radius: 4
    style.font: mono
    style.font-size: 12
  }
  sc_close: "close(2)" {
    style.fill: "#ffcdd2"
    style.stroke: "#c62828"
    style.border-radius: 4
    style.font: mono
    style.font-size: 12
  }
}
# ─── Handler implementations ───
handlers: "mydevice Driver Handlers" {
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
    stroke-width: 2
    border-radius: 8
    font-size: 13
    bold: true
  }
  h_open: "mydevice_open()\ntry_module_get + atomic_inc(&open_count)" {
    style.fill: "#c8e6c9"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    style.font-size: 11
  }
  h_read: "mydevice_read()\ncopy_to_user, f_pos advance, EOF→0" {
    style.fill: "#c8e6c9"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    style.font-size: 11
  }
  h_write: "mydevice_write()\ncopy_from_user, buffer_data_len update" {
    style.fill: "#c8e6c9"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    style.font-size: 11
  }
  h_ioctl: "mydevice_ioctl()  [M3]\nRESIZE / CLEAR / STATUS" {
    style.fill: "#b2dfdb"
    style.stroke: "#00695c"
    style.border-radius: 4
    style.font-size: 11
  }
  h_poll: "mydevice_poll()  [M4]\npoll_wait × 2 + mask" {
    style.fill: "#b2dfdb"
    style.stroke: "#00695c"
    style.border-radius: 4
    style.font-size: 11
  }
  h_release: "mydevice_release()\nmodule_put + atomic_dec(&open_count)" {
    style.fill: "#c8e6c9"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    style.font-size: 11
  }
}
# ─── NULL-default outcomes ───
null_outcomes: "NULL Field → Default Kernel Behavior" {
  style: {
    fill: "#fafafa"
    stroke: "#9e9e9e"
    stroke-dash: 5
    border-radius: 8
    font-size: 12
  }
  n_llseek: ".llseek = NULL → default_llseek()\nf_pos manipulation still works" {
    style.fill: "#f5f5f5"
    style.stroke: "#9e9e9e"
    style.border-radius: 4
    style.font-size: 11
  }
  n_ioctl: ".unlocked_ioctl = NULL → -ENOTTY\n(\"Inappropriate ioctl for device\")" {
    style.fill: "#f5f5f5"
    style.stroke: "#9e9e9e"
    style.border-radius: 4
    style.font-size: 11
  }
  n_poll: ".poll = NULL → DEFAULT_POLLMASK\n(fd always reported ready — misleading)" {
    style.fill: "#f5f5f5"
    style.stroke: "#9e9e9e"
    style.border-radius: 4
    style.font-size: 11
  }
  n_mmap: ".mmap = NULL → -ENODEV\n(mmap(2) returns ENODEV)" {
    style.fill: "#f5f5f5"
    style.stroke: "#9e9e9e"
    style.border-radius: 4
    style.font-size: 11
  }
}
# ─── Syscall → VFS check connections ───
syscalls.sc_open -> vfs_dispatch: "" {
  style.stroke: "#c62828"
  style.stroke-width: 1
}
syscalls.sc_read -> vfs_dispatch.vfs_read_check: "vfs_read()" {
  style.stroke: "#c62828"
  style.stroke-width: 1
}
syscalls.sc_write -> vfs_dispatch.vfs_write_check: "vfs_write()" {
  style.stroke: "#c62828"
  style.stroke-width: 1
}
syscalls.sc_ioctl -> vfs_dispatch.vfs_ioctl_check: "do_vfs_ioctl()" {
  style.stroke: "#c62828"
  style.stroke-width: 1
}
syscalls.sc_poll -> vfs_dispatch.vfs_poll_check: "do_pollfd()" {
  style.stroke: "#c62828"
  style.stroke-width: 1
}
syscalls.sc_close -> vfs_dispatch: "" {
  style.stroke: "#c62828"
  style.stroke-width: 1
}
# ─── VFS check → fops fields ───
vfs_dispatch.vfs_read_check -> fops.f_read: "f_op->read" {
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.stroke-dash: 3
}
vfs_dispatch.vfs_write_check -> fops.f_write: "f_op->write" {
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.stroke-dash: 3
}
vfs_dispatch.vfs_ioctl_check -> fops.f_unlocked_ioctl: "f_op->unlocked_ioctl" {
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.stroke-dash: 3
}
vfs_dispatch.vfs_poll_check -> fops.f_poll: "f_op->poll" {
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.stroke-dash: 3
}
vfs_dispatch -> fops.f_open: "f_op->open" {
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.stroke-dash: 3
}
vfs_dispatch -> fops.f_release: "f_op->release" {
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.stroke-dash: 3
}
# ─── fops fields → handler implementations ───
fops.f_open -> handlers.h_open: "dispatch" {
  style.stroke: "#1565c0"
  style.stroke-width: 2
}
fops.f_read -> handlers.h_read: "dispatch" {
  style.stroke: "#1565c0"
  style.stroke-width: 2
}
fops.f_write -> handlers.h_write: "dispatch" {
  style.stroke: "#1565c0"
  style.stroke-width: 2
}
fops.f_release -> handlers.h_release: "dispatch" {
  style.stroke: "#1565c0"
  style.stroke-width: 2
}
fops.f_unlocked_ioctl -> handlers.h_ioctl: "dispatch [M3]" {
  style.stroke: "#5b21b6"
  style.stroke-width: 2
}
fops.f_poll -> handlers.h_poll: "dispatch [M4]" {
  style.stroke: "#059669"
  style.stroke-width: 2
}
# ─── NULL fields → default outcomes ───
fops.f_llseek -> null_outcomes.n_llseek: "NULL" {
  style.stroke: "#9e9e9e"
  style.stroke-width: 1
  style.stroke-dash: 5
}
fops.f_unlocked_ioctl -> null_outcomes.n_ioctl: "NULL in M2\n→ -ENOTTY" {
  style.stroke: "#9e9e9e"
  style.stroke-width: 1
  style.stroke-dash: 5
}
fops.f_poll -> null_outcomes.n_poll: "NULL in M2/M3\n→ always-ready" {
  style.stroke: "#9e9e9e"
  style.stroke-width: 1
  style.stroke-dash: 5
}
fops.f_mmap -> null_outcomes.n_mmap: "NULL → -ENODEV" {
  style.stroke: "#9e9e9e"
  style.stroke-width: 1
  style.stroke-dash: 5
}
# ─── Cache line size annotation ───
cache_note: |md
  **Cache Line Note**
  Function pointers shown: 8 fields × 8 B = 64 B
  Cache line 0 (0x00–0x3F): owner, llseek, read, write, read_iter, write_iter, iterate_shared, poll
  Cache line 1 (0x40–0x7F): unlocked_ioctl, compat_ioctl, mmap, open, flush, release, fsync, fasync
  Total struct: ≈ 280 B (35 pointers) = ~5 cache lines
  Hot path fields (open/read/write/release) reside in lines 0–1 → spatial locality on repeated dispatch
| {
  near: bottom-left
  style: {
    fill: "#f3f4f6"
    stroke: "#6b7280"
    stroke-dash: 3
    border-radius: 6
    font-size: 11
  }
}