vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

direction: down

title: ||md
  # copy_from_user / copy_to_user: SMAP Sequence and Address Validation
  ### Step-by-step algorithm — x86-64 Linux, SMAP-enabled CPU
|| {
  near: top-center
  style: {
    font-size: 18
    bold: true
  }
}

# ─────────────────────────────────────────────────────────────
# LEGEND / COLOR KEY (top-right)
# ─────────────────────────────────────────────────────────────
legend: {
  near: top-right
  style: {
    fill: "#f8f8f8"
    stroke: "#999"
    border-radius: 6
  }
  content: ||md
    ### Legend
    - 🟦 **Normal path**: Success flow
    - 🟥 **Error path**: Fault or rejection
    - 🟨 **CPU state**: Hardware instruction
    - 🟩 **Return**: Logic exit point
    - 🟪 **Mechanism**: OS/Hardware bridge
  ||
}

# ─────────────────────────────────────────────────────────────
# LEFT COLUMN — copy_from_user(dst_kernel, src_user, n)
# ─────────────────────────────────────────────────────────────
cfu_col: "copy_from_user(dst_kernel, src_user, n)" {
  style: {
    fill: "#E8F0FE"
    stroke: "#4A6FBF"
    stroke-width: 2
    border-radius: 8
  }

  s1: "Step 1: access_ok(src_user, n)" {
    style: {
      fill: "#C8D8F8"
      stroke: "#4A6FBF"
      stroke-width: 2
    }
    tooltip: "Non-blocking address validation"
    detail: ||md
      **Logic:** `(src_user + n) <= TASK_SIZE_MAX`
      - Rejects kernel pointers (0xFFFF...)
      - Rejects overflowed ranges
      - Rejects NULL/low-mem if SMAP/PAN enabled
      **Cost:** O(1) integer arithmetic.
    ||
  }

  s1_fail: "access_ok FAILED" {
    style: {
      fill: "#FFCCCC"
      stroke: "#CC0000"
      font-color: "#CC0000"
    }
    ret_n: "Return n" {
      tooltip: "0 bytes copied"
      style.fill: "#FFEEEE"
    }
  }

  s2: "Step 2: STAC Instruction" {
    style: {
      fill: "#FFFACC"
      stroke: "#C8A000"
      bold: true
    }
    detail: ||md
      **Set Alignment Check (AC) flag in RFLAGS.**
      SMAP (Supervisor Mode Access Prevention) is **disabled** 
      for current CPU core. Ring 0 can now read userspace.
    ||
  }

  s3: "Step 3: __copy_user Loop" {
    style: {
      fill: "#C8D8F8"
      stroke: "#4A6FBF"
    }
    detail: ||md
      **Core Loop:** `rep movsq` or optimized `MOV` sequence.
      Reads from `[src_user]` -> Writes to `[dst_kernel]`.
      Each instruction address is registered in `__ex_table`.
    ||
  }

  s4_pfault: "Step 4: Fault Detected?" {
    shape: diamond
    style: {
      fill: "#FFE4B5"
      stroke: "#C07000"
    }
  }

  s4_fixup: "Step 4a: Exception Handler" {
    style: {
      fill: "#E8D0FF"
      stroke: "#7030A0"
    }
    detail: ||md
      **Exception Table (ex_table) Logic:**
      1. CPU Trap → #PF (Page Fault).
      2. Kernel checks faulting RIP against `.ex_table`.
      3. Match found? Redirect RIP to `.fixup` section.
      4. Fixup code calculates `residual = n - copied`.
    ||
  }

  s5: "Step 5: CLAC Instruction" {
    style: {
      fill: "#FFFACC"
      stroke: "#C8A000"
      bold: true
    }
    detail: ||md
      **Clear AC flag in RFLAGS.**
      SMAP is **re-enabled**. Ring 0 will now #GP fault if it 
      touches userspace pointers outside this narrow window.
    ||
  }

  s6: "Step 6: Final Return" {
    style: {
      fill: "#CCFFCC"
      stroke: "#006600"
    }
    ret_val: "Return [Residual Bytes]" {
      tooltip: "0 = success, >0 = failed count"
    }
  }

  s1 -> s1_fail: "FAIL (Address in Kernel Space)" {
    style: { stroke: "#CC0000"; stroke-dash: 3 }
  }
  s1 -> s2: "PASS" { style.stroke: "#006600" }
  s2 -> s3
  s3 -> s4_pfault
  s4_pfault -> s4_fixup: "Yes (e.g. Page Not Present)" {
    style: { stroke: "#7030A0"; stroke-dash: 3 }
  }
  s4_pfault -> s5: "No (Success)" { style.stroke: "#006600" }
  s4_fixup -> s5
  s5 -> s6
}

# ─────────────────────────────────────────────────────────────
# CENTER COLUMN — CPU Hardware State
# ─────────────────────────────────────────────────────────────
smap_hw: "CPU Execution Context" {
  style: {
    fill: "#FFF8E8"
    stroke: "#C8A000"
    stroke-width: 2
  }

  armed: "SMAP ACTIVE\n(AC Flag = 0)" {
    shape: circle
    style: { fill: "#FFFACC"; stroke: "#C8A000"; stroke-width: 3 }
  }

  disarmed: "SMAP OVERRIDDEN\n(AC Flag = 1)" {
    shape: circle
    style: { fill: "#FFE4B5"; stroke: "#C07000"; stroke-width: 3 }
  }

  armed -> disarmed: "STAC (Safe Zone Start)" { style.stroke: "#C07000" }
  disarmed -> armed: "CLAC (Safe Zone End)" { style.stroke: "#C07000" }

  gp_fault: "ILLEGAL ACCESS" {
    shape: hexagon
    style: { fill: "#FFAAAA"; stroke: "#CC0000" }
  }
  armed -> gp_fault: "Ring 0 attempts\nU-pointer access" {
    style: { stroke: "#CC0000"; stroke-dash: 5 }
  }
}

# ─────────────────────────────────────────────────────────────
# RIGHT COLUMN — copy_to_user(dst_user, src_kernel, n)
# ─────────────────────────────────────────────────────────────
ctu_col: "copy_to_user(dst_user, src_kernel, n)" {
  style: {
    fill: "#E8F8EE"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }

  t1: "Step 1: access_ok(dst_user, n)" {
    style.fill: "#C8ECD4"
    detail: "Ensures destination is in the user-permitted memory range."
  }
  
  t1_fail: "access_ok FAILED" {
    style.fill: "#FFCCCC"
  }

  t2: "Step 2: STAC" {
    style.fill: "#FFFACC"
  }

  t3: "Step 3: Write Loop" {
    style.fill: "#C8ECD4"
    detail: "Copies from Kernel Buffer to User Buffer."
  }

  t4: "Step 4: CLAC" {
    style.fill: "#FFFACC"
  }

  t5: "Step 5: Return residual" {
    style.fill: "#CCFFCC"
  }

  t1 -> t1_fail: "FAIL" { style.stroke: "#CC0000" }
  t1 -> t2: "PASS"
  t2 -> t3
  t3 -> t4: "Success or Fixup"
  t4 -> t5
}

# ─────────────────────────────────────────────────────────────
# DATA TABLES & MECHANISMS
# ─────────────────────────────────────────────────────────────
trap_box: "API Semantics" {
  style.fill: "#FFF3CD"
  content: ||md
    ### Return Code Contract
    | Return Value | Meaning | Driver Action |
    | :--- | :--- | :--- |
    | **0** | Full success | Continue |
    | **1..n** | Partial copy | Return `-EFAULT` |
    | **n** | No data copied | Return `-EFAULT` |

    **Warning:** `copy_from_user` does **not** return a standard 0/-ERR negative code.
  ||
}

extable_mech: "Exception Table Mechanism" {
  style.fill: "#F0E8FF"
  style.stroke: "#7030A0"
  content: ||md
    ### How Fixup Works
    When a `#PF` occurs in kernel mode:
    1. OS searches `.ex_table` for the faulting RIP.
    2. Example Entry:
       - `fault_addr`: `0xffffffff81001234` (The MOV instruction)
       - `fixup_addr`: `0xffffffff8100abcd` (The Recovery code)
    3. The CPU's Instruction Pointer is moved to `fixup_addr`.
    4. Fixup code sets the return register to the remaining byte count and jumps to the end of the function.
  ||
}

# ─────────────────────────────────────────────────────────────
# CROSS-CONNECTIONS
# ─────────────────────────────────────────────────────────────
cfu_col.s2 -> smap_hw.disarmed: "AC=1"
cfu_col.s5 -> smap_hw.armed: "AC=0"
ctu_col.t2 -> smap_hw.disarmed: "AC=1"
ctu_col.t4 -> smap_hw.armed: "AC=0"

cfu_col.s4_fixup -> extable_mech: "RIP Redirect" {
  style.stroke: "#7030A0"
  style.stroke-dash: 3
}

cfu_col.s6 -> trap_box: "Check Logic" {
  style.stroke: "#888"
  style.stroke-dash: 2
}