direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Alignment Padding Visualization
  Microscopic view of section merging with 16-byte alignment
| {near: top-center}
formula_box: {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  width: 500
  label: ""
  formula_content: |md
    **Padding Formula:**
    
    padding = (alignment - (current_offset % alignment)) % alignment
    Example:
      current_offset = 0x1046
      alignment      = 16 (0x10)
      padding        = (16 - (0x1046 % 16)) % 16
                     = (16 - 6) % 16
                     = 10 (0xA)
    Aligned offset = current_offset + padding = 0x1050
    
  |
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_merge: {
    direction: down
    label: "BEFORE MERGE"
    input_sections: {
      direction: right
      style.fill: transparent
      sec_a: {
        direction: down
        label: "main.o/.text"
        width: 180
        bytes_a: {
          grid-columns: 16
          grid-gap: 0
          style.fill: transparent
          a00: {label: ""; width: 28; height: 20; style.fill: "#4CAF50"; style.stroke: "#2E7D32"}
          a01: {label: ""; width: 28; height: 20; style.fill: "#4CAF50"; style.stroke: "#2E7D32"}
