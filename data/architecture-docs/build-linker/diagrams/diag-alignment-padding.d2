          a10: {label: ""; width: 28; height: 20; style.fill: "#81C784"; style.stroke: "#2E7D32"}
          a11: {label: ""; width: 28; height: 20; style.fill: "#81C784"; style.stroke: "#2E7D32"}
          a12: {label: ""; width: 28; height: 20; style.fill: "#A5D6A7"; style.stroke: "#2E7D32"}
          a13: {label: ""; width: 28; height: 20; style.fill: "#A5D6A7"; style.stroke: "#2E7D32"}
          a14: {label: ""; width: 28; height: 20; style.fill: "#A5D6A7"; style.stroke: "#2E7D32"}
          a15: {label: ""; width: 28; height: 20; style.fill: "#A5D6A7"; style.stroke: "#2E7D32"}
        }
        size_label_a: |md
          16 bytes (0x10)
          align: 16
        |
      }
      sec_b: {
        direction: down
        label: "utils.o/.text"
        width: 180
        bytes_b: {
          grid-columns: 16
          grid-gap: 0
          style.fill: transparent
          b00: {label: ""; width: 28; height: 20; style.fill: "#2196F3"; style.stroke: "#1565C0"}
          b01: {label: ""; width: 28; height: 20; style.fill: "#2196F3"; style.stroke: "#1565C0"}
          b02: {label: ""; width: 28; height: 20; style.fill: "#2196F3"; style.stroke: "#1565C0"}
          b03: {label: ""; width: 28; height: 20; style.fill: "#2196F3"; style.stroke: "#1565C0"}
          b04: {label: ""; width: 28; height: 20; style.fill: "#42A5F5"; style.stroke: "#1565C0"}
          b05: {label: ""; width: 28; height: 20; style.fill: "#42A5F5"; style.stroke: "#1565C0"}
          b06: {label: ""; width: 28; height: 20; style.fill: "#42A5F5"; style.stroke: "#1565C0"}
          b07: {label: ""; width: 28; height: 20; style.fill: "#42A5F5"; style.stroke: "#1565C0"}
        }
        size_label_b: |md
          8 bytes (0x8)
          align: 16
        |
      }
    }
  }
}
arrow_merge: {
  shape: text
  near: center-left
  label: |md
    **MERGE**
    ↓
  |
  style.font-size: 24
  style.bold: true
}
