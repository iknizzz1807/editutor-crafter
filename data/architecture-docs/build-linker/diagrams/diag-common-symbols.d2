direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # COMMON Symbol Merging: Tentative Definitions
| {near: top-center}
row_sources: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  source_a: file1.c {
    width: 280
    code: |c
      // Tentative definition
      // No initializer = COMMON
      int buffer[100];
      // 400 bytes, alignment 4
    |
    style.fill: "#E8F4E8"
  }
  source_b: file2.c {
    width: 280
    code: |c
      // Also tentative
      // Larger size declaration
      int buffer[200];
      // 800 bytes, alignment 4
    |
    style.fill: "#E8E8F4"
  }
}
row_symbols: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sym_a: {
    label: "file1.o: Symbol Entry"
    width: 280
    shape: sql_table
    f0: "st_name | idx → 'buffer'"
    f1: "st_info | STB_GLOBAL"
    f2: "st_shndx | SHN_COMMON (0xFFF2)"
    f3: "st_value | 4 (alignment)"
    f4: "st_size | 400 bytes"
    note: "No section assigned yet"
  }
  sym_b: {
    label: "file2.o: Symbol Entry"
    width: 280
    shape: sql_table
    f0: "st_name | idx → 'buffer'"
    f1: "st_info | STB_GLOBAL"
    f2: "st_shndx | SHN_COMMON (0xFFF2)"
    f3: "st_value | 4 (alignment)"
    f4: "st_size | 800 bytes"
    note: "No section assigned yet"
  }
}
sym_a -> merge_box: "collect"
sym_b -> merge_box: "collect"
merge_box: {
  label: "COMMON Resolution Rules"
  width: 400
  rule1: |md
    **Rule: Largest Size Wins**
    When multiple COMMON symbols with the same name:
    - Compare all `st_size` values
    - Allocate the **maximum** size
    - Use **maximum** alignment
    - Single instance in output .bss
  |
  result: {
    label: "Merged Result: buffer"
    shape: sql_table
    f0: "final_size | 800 bytes"
    f1: "final_align | 4"
    f2: "section | .bss"
    f3: "binding | STB_GLOBAL"
    note: "400-byte def absorbed"
  }
  result.style.fill: "#FFF9E6"
}
row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  explicit_bss: {
    label: "Explicit .bss Definition"
    width: 320
    code: |c
      // file1.c - explicit zero-init
      int buffer[100] = {0};
      // Goes directly to .bss
      // st_shndx = .bss section index
      // file2.c - tentative
      int buffer[200];
      // Still COMMON
      // Result: explicit wins!
      // buffer = 400 bytes (file1)
    |
    style.fill: "#FFE6E6"
  }
  behavior_table: {
    label: "Resolution Priority"
    shape: sql_table
    h0: "Definition Type | Priority | Outcome"
    r0: "Strong (.data/.bss) | HIGHEST | Always wins"
    r1: "COMMON | MEDIUM | Merged, largest wins"
    r2: "Weak | LOWEST | First wins if no strong"
    note: "Strong + COMMON = Strong wins"
  }
  behavior_table.style.fill: "#F0F0F0"
}
merge_box -> output_layout: "allocate in .bss"
output_layout: {
  label: "Output .bss Section Layout"
  width: 500
  layout: {
    shape: sql_table
    f0: "0x0000 | buffer[800] | from COMMON merge"
    f1: "0x0320 | (next symbol) | ..."
    sz: "Total .bss size includes largest COMMON"
  }
  note: |md
    **Key Insight:**
    COMMON symbols don't occupy file space.
    They reserve **virtual address space** only.
    Loader zero-fills the entire .bss region.
  |
}
legend: {
  near: bottom-right
  label: "Symbol Types"
  shape: sql_table
  c0: "SHN_COMMON (0xFFF2) | Tentative definition"
  c1: "Section index | Explicit definition"
  c2: "SHN_UNDEF (0) | Reference only"
}
source_a -> sym_a: "compile"
source_b -> sym_b: "compile"
merge_box -> row_comparison: "compare with explicit"