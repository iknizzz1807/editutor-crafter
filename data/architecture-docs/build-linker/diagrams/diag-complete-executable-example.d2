direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Complete Executable Walkthrough
  **Detailed Linker Logic: main.o + helper.o → a.out**
| {near: top-center}

row_inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  main_obj: {
    direction: down
    label: "main.o (Object File)"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    
    main_header: {
      shape: sql_table
      label: "ELF Header (main.o)"
      f0: "0x00 | Magic    | 7F 45 4C 46"
      f1: "0x04 | Class    | 02 (64-bit)"
      f2: "0x05 | Data     | 01 (LE)"
      f3: "0x10 | Type     | 0001 (ET_REL)"
      f4: "0x12 | Machine  | 003E (x86-64)"
      f5: "0x18 | Entry    | 0x00000000"
      f6: "0x20 | SHoff    | 0x000000C8"
      sz: "Total Header: 64 bytes"
    }
    
    main_text: {
      shape: sql_table
      label: ".text Section (Code)"
      f0: "0x40 | 55 48 89 E5 | push rbp; mov rbp,rsp"
      f1: "0x44 | E8 00 00 00 | call <helper_ptr>"
      f2: "0x49 | 31 C0 5D C3 | xor eax,eax; pop rbp; ret"
      note: "E8 is 'call' opcode. Next 4 bytes are 0 (relocation target)"
    }
    
    main_symtab: {
      shape: sql_table
      label: ".symtab (Symbols)"
      s0: "[1] | main.c | FILE"
      s1: "[2] | .text  | SECTION | idx=1"
      s2: "[3] | main   | GLOBAL FUNC | .text+0x0"
      s3: "[4] | helper | GLOBAL UNDEF | external"
    }
    
    main_rela: {
      shape: sql_table
      label: ".rela.text (Relocations)"
      r0: "Offset | 0x0005 | Patch location"
      r1: "Type   | R_X86_64_PC32 | PC-relative 32bit"
      r2: "Symbol | helper (idx 4)"
      r3: "Addend | -4 | Adjustment for RIP"
    }
  }

  helper_obj: {
    direction: down
    label: "helper.o (Object File)"
    style.fill: "#FFF4E8"
    style.stroke: "#D4760E"
    
    helper_header: {
      shape: sql_table
      label: "ELF Header (helper.o)"
      f0: "0x00 | Magic | 7F 45 4C 46"
      f3: "0x10 | Type  | 0001 (ET_REL)"
      f4: "0x12 | Machine | 003E (x86-64)"
    }
    
    helper_text: {
      shape: sql_table
      label: ".text Section (helper)"
      f0: "0x40 | 55 48 89 E5 | push rbp; mov rbp,rsp"
      f1: "0x44 | 90 90 90 90 | nop; nop; nop; nop"
      f2: "0x48 | 5D C3       | pop rbp; ret"
      sz: "Size: 12 bytes"
    }
    
    helper_symtab: {
      shape: sql_table
      label: ".symtab (Symbols)"
      s0: "[2] | .text  | SECTION"
      s1: "[3] | helper | GLOBAL FUNC | .text+0x0"
    }
    
    helper_note: {
      label: "No relocations needed for helper.o"
      shape: rectangle
      style.fill: "#F0F0F0"
      style.stroke-dash: 3
    }
  }
}

row_m1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m1_merge: {
    direction: down
    label: "MILESTONE 1: Section Merging"
    style.fill: "#E8FCE8"
    style.stroke: "#2E8B57"
    
    merge_op: {
      shape: class
      label: "Linker Engine: Merge"
      +group_by_name(sections): "void"
      +calc_padding(align): "uint64_t"
      +assign_offsets(nodes): "void"
    }
    
    output_text: {
      shape: sql_table
      label: "Combined .text Layout"
      m0: "main.o/.text   | offset=0x00 | size=13"
      m1: "ALIGN PADDING  | offset=0x0D | size=3"
      m2: "helper.o/.text | offset=0x10 | size=12"
      total: "Total Segment Size: 28 bytes"
    }
  }
}

row_m2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m2_resolve: {
    direction: down
    label: "MILESTONE 2: Symbol Resolution"
    style.fill: "#FCE8F8"
    style.stroke: "#9B2D8B"
    
    resolve_op: {
      shape: class
      label: "Linker Engine: Symbol Resolver"
      +scan_all_symtabs(): "void"
      +resolve_undefined(): "int"
      +assign_virtual_addresses(): "void"
    }
    
    global_symtab: {
      shape: sql_table
      label: "Resolved Global Symbol Table"
      g0: "main   | ADDR: 0x401000 | From main.o"
      g1: "helper | ADDR: 0x401010 | From helper.o"
      status: "Result: All symbols defined."
    }
    
    addr_calc: {
      shape: sql_table
      label: "Base VAddr Selection"
      a0: "Image Base | 0x00400000"
      a1: "Text Offset | 0x00001000"
      a2: "Start VAddr | 0x00401000"
    }
  }
}

row_m3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m3_reloc: {
    direction: down
    label: "MILESTONE 3: Relocation Patching"
    style.fill: "#F8FCE8"
    style.stroke: "#8B8B00"
    
    reloc_calc: {
      label: "Patch Calculation: main calls helper"
      width: 450
      code: |'c
        // Patch Site: 0x401000 + 0x05 (main.o text offset 5)
        P = 0x401005; // Address of the field to patch
        S = 0x401010; // Address of symbol 'helper'
        A = -4;       // Relocation addend (x86-64 RIP adjustment)

        // Formula for R_X86_64_PC32: S + A - P
        Result = 0x401010 + (-4) - 0x401005
        Result = 0x401010 - 0x401009 = 0x00000007
      '|
    }
    
    patch_viz: {
      shape: sql_table
      label: "Binary Patch Result"
      b0: "Before | E8 00 00 00 00 | call 0x0"
      b1: "After  | E8 07 00 00 00 | call +0x7"
      note: "Relative jump from 0x40100A (next instr) to 0x401011?"
      note2: "Correction: RIP is after 4-byte imm: 0x401005+4=0x401009"
      note3: "Target = 0x401009 + 0x07 = 0x401010 (Start of helper)"
    }
  }
}

row_m4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m4_exec: {
    direction: down
    label: "MILESTONE 4: Final Executable Construction"
    style.fill: "#FCE8E8"
    style.stroke: "#CD5C5C"
    
    elf_header_out: {
      shape: sql_table
      label: "Final ELF Header (a.out)"
      f0: "e_type    | 0002 (ET_EXEC)"
      f1: "e_entry   | 0x00401000 (main)"
      f2: "e_phoff   | 64 (Start of Phdrs)"
      f3: "e_phnum   | 1 (One LOAD segment)"
    }
    
    phdr_out: {
      shape: sql_table
      label: "Program Header (Phdr)"
      p0: "p_type   | PT_LOAD (Loadable)"
      p1: "p_flags  | R E (Read + Execute)"
      p2: "p_vaddr  | 0x00401000"
      p3: "p_offset | 0x00001000"
      p4: "p_filesz | 0x1C (28 bytes)"
      p5: "p_align  | 0x1000 (4KB Page)"
    }
  }
}

row_final: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  final_exec: {
    direction: down
    label: "Executable File (a.out)"
    style.fill: "#F0F0F0"
    
    hexdump: {
      shape: sql_table
      label: "a.out Binary Dump"
      h0: "0x1000 | 55 48 89 E5 E8 07 00 00 | main code starts"
      h1: "0x1008 | 00 31 C0 5D C3 00 00 00 | call is now patched"
      h2: "0x1010 | 55 48 89 E5 90 90 90 90 | helper code starts"
      h3: "0x1018 | 5D C3                 | helper returns"
    }
  }
  
  verify: {
    direction: down
    label: "Verification Suite"
    style.fill: "#E8E8F8"
    
    readelf_h: {
      label: '$ readelf -h a.out'
      width: 400
      code: |'
        ELF Header:
          Type: EXEC (Executable file)
          Entry point address: 0x401000
          Number of program headers: 1
      '|
    }
    
    readelf_l: {
      label: '$ readelf -l a.out'
      width: 400
      code: |'
        Program Headers:
          Type   Offset   VirtAddr   FileSiz Flags
          LOAD   0x001000 0x00401000 0x00001c R E
      '|
    }
    
    run: {
      label: '$ ./a.out; echo $?'
      width: 400
      code: |'
        (Process finished)
        0
      '|
    }
  }
}

row_inputs -> row_m1: "Load Symbols"
row_m1 -> row_m2: "Map Virtual Mem"
row_m2 -> row_m3: "Apply Formula"
row_m3 -> row_m4: "Seal ELF"
row_m4 -> row_final: "Write to Disk"
final_exec -> verify: "Audit"