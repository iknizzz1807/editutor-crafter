direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # ELF Executable File Structure
  Layout: ELF header → Program headers → Segment data → Section headers (optional)
| {near: top-center}
row_headers: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  file_layout: {
    direction: down
    label: "File Layout (on disk)"
    elf_header: {
      label: "ELF Header (64 bytes)"
      width: 300
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      fields: {
        shape: sql_table
        label: "Elf64_Ehdr"
        f0: "0x00 | e_ident[16]  | Magic: 0x7f ELF..."
        f1: "0x10 | e_type       | ET_EXEC = 2"
        f2: "0x12 | e_machine    | EM_X86_64 = 62"
        f3: "0x14 | e_version    | 1"
        f4: "0x18 | e_entry      | 0x401000"
        f5: "0x20 | e_phoff      | 64 (0x40)"
        f6: "0x28 | e_shoff      | 0x2000"
        f7: "0x30 | e_flags      | 0"
        f8: "0x34 | e_ehsize     | 64"
        f9: "0x36 | e_phentsize  | 56"
        f10: "0x38 | e_phnum      | 2"
        f11: "0x3A | e_shentsize  | 64"
        f12: "0x3C | e_shnum      | 6"
        f13: "0x3E | e_shstrndx   | 5"
        sz: "Total: 64 bytes"
      }
    }
    phdr_table: {
      label: "Program Header Table (112 bytes)"
      width: 300
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      phdr_text: {
        shape: sql_table
        label: "PT_LOAD #1 (Text)"
        p0: "p_type   | PT_LOAD = 1"
        p1: "p_flags  | PF_R | PF_X"
        p2: "p_offset | 0x1000"
        p3: "p_vaddr  | 0x401000"
        p4: "p_paddr  | 0x401000"
        p5: "p_filesz | 0x200"
        p6: "p_memsz  | 0x200"
        p7: "p_align  | 0x1000"
      }
      phdr_data: {
        shape: sql_table
        label: "PT_LOAD #2 (Data)"
        p0: "p_type   | PT_LOAD = 1"
        p1: "p_flags  | PF_R | PF_W"
        p2: "p_offset | 0x3000"
        p3: "p_vaddr  | 0x403000"
        p4: "p_paddr  | 0x403000"
        p5: "p_filesz | 0x100"
        p6: "p_memsz  | 0x200"
        p7: "p_align  | 0x1000"
      }
    }
    padding1: {
      label: "Padding\n(0x1000 - 0xB0 = 0xF50 bytes)"
      width: 300
      style.fill: "#F5F5F5"
      style.stroke: "#BDBDBD"
      style.stroke-dash: 3
    }
    text_segment: {
      label: "Text Segment Content (0x200 bytes)\n.text + .rodata + .eh_frame"
      width: 300
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      text_sections: {
        shape: sql_table
        label: "Sections in Text Segment"
        s0: ".text     | code"
        s1: ".rodata   | read-only data"
        s2: ".eh_frame | unwind info"
      }
    }
    padding2: {
      label: "Padding to page boundary\n(0xE00 bytes)"
      width: 300
      style.fill: "#F5F5F5"
      style.stroke: "#BDBDBD"
      style.stroke-dash: 3
    }
    data_segment: {
      label: "Data Segment Content (0x100 bytes)\n.data (file-backed)"
      width: 300
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      data_sections: {
        shape: sql_table
        label: "Sections in Data Segment"
        s0: ".data | initialized globals"
        s1: ".bss  | (no file content)"
        note: ".bss: p_memsz > p_filesz"
      }
    }
    padding3: {
      label: "Padding / Optional\n(section headers space)"
      width: 300
      style.fill: "#F5F5F5"
      style.stroke: "#BDBDBD"
      style.stroke-dash: 3
    }
    shdr_table: {
      label: "Section Header Table (optional)\n384 bytes for 6 sections"
      width: 300
      style.fill: "#E1BEE7"
      style.stroke: "#9C27B0"
      style.stroke-dash: 5
      shdr_note: {
        shape: sql_table
        label: "Elf64_Shdr entries"
        s0: "[0] SHT_NULL"
        s1: "[1] .text    | SHT_PROGBITS"
        s2: "[2] .rodata  | SHT_PROGBITS"
        s3: "[3] .data    | SHT_PROGBITS"
        s4: "[4] .bss     | SHT_NOBITS"
        s5: "[5] .shstrtab| SHT_STRTAB"
        note: "Loader ignores these"
      }
    }
  }
  memory_layout: {
    direction: down
    label: "Memory Layout (after load)"
    mem_reserved: {
      label: "Reserved / Unmapped\n(0x000000 - 0x400FFF)"
      width: 300
      height: 80
      style.fill: "#FAFAFA"
      style.stroke: "#9E9E9E"
      style.stroke-dash: 3
    }
    mem_text: {
      label: "Text Segment (mmap'd RX)\n0x401000 - 0x4011FF\n\nMapped from file offset 0x1000\nSize: p_memsz = 0x200"
      width: 300
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    mem_gap: {
      label: "Unmapped gap\n(0x401200 - 0x402FFF)"
      width: 300
      height: 60
      style.fill: "#FAFAFA"
      style.stroke: "#9E9E9E"
      style.stroke-dash: 3
    }
    mem_data: {
      label: "Data Segment (mmap'd RW)\n0x403000 - 0x4031FF\n\nMapped from file offset 0x3000\np_filesz=0x100, p_memsz=0x200"
      width: 300
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.stroke-width: 2
    }
    mem_bss: {
      label: ".bss Extension (zero-filled)\n0x403100 - 0x4031FF\n\nNOT in file\nLoader zeroes this region"
      width: 300
      style.fill: "#FFE0B2"
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    mem_stack: {
      label: "Stack (grows down)\n0x7FFFFFFFxxxx\n\nKernel allocates"
      width: 300
      style.fill: "#B3E5FC"
      style.stroke: "#03A9F4"
      style.stroke-dash: 5
    }
  }
}
file_layout -> memory_layout: "mmap()" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
file_layout.elf_header -> memory_layout.mem_text: "e_entry → 0x401000" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
file_layout.phdr_table.phdr_text -> memory_layout.mem_text: "p_vaddr" {
  style.stroke: "#4CAF50"
}
file_layout.phdr_table.phdr_data -> memory_layout.mem_data: "p_vaddr" {
  style.stroke: "#F44336"
}
file_layout.text_segment -> memory_layout.mem_text: "RX pages" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
file_layout.data_segment -> memory_layout.mem_data: "RW pages" {
  style.stroke: "#F44336"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  direction: right
  l1: {
    label: "Loader reads"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
  l2: {
    label: "File-backed"
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  l3: {
    label: "Zero-filled"
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
  }
  l4: {
    label: "Optional/ignored"
    style.fill: "#E1BEE7"
    style.stroke: "#9C27B0"
    style.stroke-dash: 5
  }
}
key_insight: |md
  **Key Insight:** The loader only reads **Program Headers** (PT_LOAD segments).
  Section headers are for linkers/debuggers — a stripped executable has none.
  **Alignment Rule:** `p_offset % p_align == p_vaddr % p_align`
  This ensures mmap() can map file pages directly to memory pages.
| {near: bottom-center}