direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # ELF Object File Anatomy (ET_REL)
  Relocatable `.o` file structure — linker's input format
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_panel: {
    direction: down
    elf_header: {
      shape: sql_table
      label: "Elf64_Ehdr (64 bytes) — offset 0x00"
      f0: "0x00 | uint8_t[16]  | e_ident"
      f1: "0x10 | uint16_t    | e_type = ET_REL (1)"
      f2: "0x12 | uint16_t    | e_machine = EM_X86_64"
      f3: "0x14 | uint32_t    | e_version = 1"
      f4: "0x18 | uint64_t    | e_entry = 0"
      f5: "0x20 | uint64_t    | e_phoff = 0"
      f6: "0x28 | uint64_t    | e_shoff"
      f7: "0x30 | uint32_t    | e_flags"
      f8: "0x34 | uint16_t    | e_ehsize = 64"
      f9: "0x36 | uint16_t    | e_phnum = 0"
      f10: "0x38 | uint16_t   | e_shentsize = 64"
      f11: "0x3A | uint16_t   | e_shnum"
      f12: "0x3C | uint16_t   | e_shstrndx"
      sz: "Total: 64 bytes"
    }
    sections_label: {
      label: "Section Data (variable offset)"
      style.fill: "#E8F4E8"
    }
    section_text: {
      shape: sql_table
      label: ".text (SHT_PROGBITS)"
      desc: "0x40 | SHF_ALLOC | SHF_EXECINSTR"
      content: "Executable machine code"
      sz: "Size: varies (code bytes)"
    }
    section_text.style.fill: "#FFE4E4"
    section_rodata: {
      shape: sql_table
      label: ".rodata (SHT_PROGBITS)"
      desc: "SHF_ALLOC (read-only)"
      content: "String literals, const data"
      sz: "Size: varies"
    }
    section_rodata.style.fill: "#E4E4FF"
    section_data: {
      shape: sql_table
      label: ".data (SHT_PROGBITS)"
      desc: "SHF_ALLOC | SHF_WRITE"
      content: "Initialized global/static vars"
      sz: "Size: varies"
    }
    section_data.style.fill: "#FFF4E4"
    section_bss: {
      shape: sql_table
      label: ".bss (SHT_NOBITS)"
      desc: "SHF_ALLOC | SHF_WRITE"
      content: "No file content! Size in memory only"
      sz: "File size: 0 bytes"
    }
    section_bss.style.fill: "#F0F0F0"
  }
  right_panel: {
    direction: down
    section_symtab: {
      shape: sql_table
      label: ".symtab (SHT_SYMTAB)"
      desc: "Symbol table entries"
      e0: "[0] NULL entry"
      e1: "[1] source.c | STT_FILE | LOCAL"
      e2: "[2] .text   | STT_SECTION | LOCAL"
      e3: "[3] func1   | STT_FUNC | GLOBAL"
      e4: "[4] var1    | STT_OBJECT | GLOBAL"
      e5: "[5] extern  | STT_NOTYPE | UNDEF"
      sz: "Each: Elf64_Sym (24 bytes)"
    }
    section_strtab: {
      shape: sql_table
      label: ".strtab (SHT_STRTAB)"
      desc: "String table for symbol names"
      s0: "0x00 | \\0"
      s1: "0x01 | source.c\\0"
      s2: "0x0A | func1\\0"
      s3: "0x10 | var1\\0"
      s4: "0x15 | extern\\0"
      sz: "Null-terminated strings"
    }
    section_rela: {
      shape: sql_table
      label: ".rela.text (SHT_RELA)"
      desc: "Relocations for .text section"
      r0: "Elf64_Rela entry 1"
      r1: "Elf64_Rela entry 2"
      r2: "..."
      sz: "Each: 24 bytes"
    }
    section_rela.style.fill: "#FFF0F5"
    section_shstrtab: {
      shape: sql_table
      label: ".shstrtab (SHT_STRTAB)"
      desc: "Section name string table"
      n0: ".text\\0"
      n1: ".data\\0"
      n2: ".bss\\0"
      n3: ".symtab\\0"
      n4: ".strtab\\0"
      n5: ".rela.text\\0"
      sz: "Referenced by e_shstrndx"
    }
    section_shstrtab.style.fill: "#F5F5DC"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sht_label: {
    label: "Section Header Table (at e_shoff)"
    style.fill: "#E0E0E0"
  }
  sht: {
    shape: sql_table
    label: "Elf64_Shdr[] array"
    h0: "[0]  NULL section"
    h1: "[1]  .text    → offset, size, flags"
    h2: "[2]  .rodata  → offset, size, flags"
    h3: "[3]  .data    → offset, size, flags"
    h4: "[4]  .bss     → offset, size=0, SHT_NOBITS"
    h5: "[5]  .symtab  → sh_link → .strtab"
    h6: "[6]  .strtab  → symbol name strings"
    h7: "[7]  .rela.text → sh_info → .text idx"
    h8: "[8]  .shstrtab → section name strings"
    sz: "Each entry: 64 bytes"
  }
}
legend: {
  near: bottom-center
  label: "Key Relationships"
  dir: down
  l1: "e_shstrndx → index of .shstrtab (section names)"
  l2: ".symtab sh_link → .strtab index (symbol names)"
  l3: ".rela.text sh_info → .text section index"
  l4: ".bss: SHT_NOBITS means NO file content"
}
legend.style.fill: "#FFFACD"
elf_header -> section_text: "sh_offset"
elf_header -> sht: "e_shoff"
section_symtab -> section_strtab: "sh_link"
section_rela -> section_text: "sh_info targets"