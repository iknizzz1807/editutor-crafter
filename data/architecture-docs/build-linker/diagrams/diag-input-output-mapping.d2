direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Input-to-Output Offset Mapping Table
  ### Linker's Internal Lookup: "Where did this input byte end up?"
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_sections: {
    direction: down
    label: "INPUT OBJECT FILES"
    main_o: {
      label: "main.o (linker.c:parse_obj)"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      main_text: {
        shape: sql_table
        label: ".text section"
        f0: "0x00 | .byte | push rbp"
        f1: "0x01 | 3     | mov rbp,rsp"
        f2: "0x04 | 5     | call helper"
        f3: "0x09 | 2     | xor eax"
        f4: "0x0B | 2     | pop rbp"
        f5: "0x0D | 1     | ret"
        sz: "Size: 14 bytes"
      }
      main_data: {
        shape: sql_table
        label: ".data section"
        f0: "0x00 | 8     | counter: .quad"
        f1: "0x08 | 4     | flags: .long"
        sz: "Size: 12 bytes"
      }
    }
    utils_o: {
      label: "utils.o"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      utils_text: {
        shape: sql_table
        label: ".text section"
        f0: "0x00 | 3  | helper: mov"
        f1: "0x03 | 5  | call compute"
        f2: "0x08 | 1  | ret"
        sz: "Size: 9 bytes"
      }
      utils_rodata: {
        shape: sql_table
        label: ".rodata section"
        f0: "0x00 | 6  | \"Error\\0\""
        f1: "0x06 | 8  | align 8"
        f2: "0x0E | 16 | format_str"
        sz: "Size: 30 bytes"
      }
    }
    lib_o: {
      label: "lib.o"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      lib_text: {
        shape: sql_table
        label: ".text section"
        f0: "0x00 | 4  | compute: imul"
        f1: "0x04 | 2  | add"
        f2: "0x06 | 1  | ret"
        sz: "Size: 7 bytes"
      }
      lib_bss: {
        shape: sql_table
        label: ".bss section"
        f0: "0x00 | 64 | buffer: .skip"
        f1: "0x40 | 16 | temp: .space"
        note: "SHT_NOBITS (no file data)"
        sz: "Size: 80 bytes (mem only)"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mapping_table: {
    direction: down
    label: "MAPPING TABLE STRUCTURE"
    struct_def: {
      shape: class
      label: "SectionMapping (linker.h)"
      -source_file: "char[256]"
      -section_name: "char[64]"
      -input_offset: "uint64_t"
      -input_size: "uint64_t"
      -output_offset: "uint64_t"
      -padding_before: "uint64_t"
      +lookup(ctx, file, sec, off): "uint64_t"
    }
    hash_table: {
      label: "MappingHash (O(1) lookup)"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#9C27B0"
      hash_desc: |md
        **Hash Key**: `"filename:section_name"`
        
        uint32_t hash = 5381;
        for (char *p = key; *p; p++)
          hash = hash * 33 + *p;
        
      |
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mapping_data: {
    direction: down
    label: "MAPPING TABLE ENTRIES"
    text_mappings: {
      shape: sql_table
      label: "Output Section: .text"
      style.fill: "#E3F2FD"
      m0: "\"main.o:.text\"    | 0x0000 | 14 | 0x0000 | 0"
      m1: "\"utils.o:.text\"   | 0x0000 | 9  | 0x0010 | 2"
      m2: "\"lib.o:.text\"     | 0x0000 | 7  | 0x0020 | 5"
      note: "Total: 36 bytes (0x24)"
    }
    rodata_mappings: {
      shape: sql_table
      label: "Output Section: .rodata"
      style.fill: "#FFF8E1"
      m0: "\"utils.o:.rodata\" | 0x0000 | 30 | 0x0000 | 0"
      note: "Total: 30 bytes (0x1E)"
    }
    data_mappings: {
      shape: sql_table
      label: "Output Section: .data"
      style.fill: "#E8F5E9"
      m0: "\"main.o:.data\"    | 0x0000 | 12 | 0x0000 | 0"
      note: "Total: 12 bytes (0x0C)"
    }
    bss_mappings: {
      shape: sql_table
      label: "Output Section: .bss"
      style.fill: "#FFEBEE"
      m0: "\"lib.o:.bss\"      | 0x0000 | 80 | 0x0000 | 0"
      note: "Total: 80 bytes (mem, no file)"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lookup_example: {
    direction: down
    label: "LOOKUP QUERY EXAMPLE"
    style.fill: "#F5F5F5"
    query_box: {
      shape: rectangle
      style.fill: "#FFFDE7"
      style.stroke: "#FBC02D"
      width: 400
      query_code: |'c
        // Relocation in main.o at .text+0x05
        // needs to find where that byte ended up
        uint64_t output_offset;
        lookup_output_offset(ctx,
          "main.o",      // source file
          ".text",       // section name  
          0x05,          // input offset
          &output_offset // OUT: 0x0005
        );
        // Result: relocation site is at
        // output .text offset 0x0005
      '|
    }
    result_box: {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 400
      result_text: |md
        **Query Result**:
        - Input: `main.o:.text @ 0x05`
        - Mapping found: `output_offset = 0x0005`
        - Final vaddr: `0x401000 + 0x0005 = 0x401005`
        The `call helper` instruction's offset field
        is at virtual address **0x401006**
      |
    }
  }
  padding_calc: {
    direction: down
    label: "PADDING CALCULATION"
    pad_struct: {
      shape: class
      label: "Alignment Math (linker.c)"
      +align_up(off, align): "uint64_t"
      +calc_padding(off, align): "uint64_t"
    }
    pad_code: {
      label: "Alignment Functions"
      width: 380
      code: |'c
        uint64_t calc_padding(uint64_t off, 
                              uint64_t align) {
          if (align <= 1) return 0;
          uint64_t rem = off % align;
          return rem ? (align - rem) : 0;
        }
        uint64_t align_up(uint64_t off, 
                          uint64_t align) {
          return (off + align - 1) & ~(align - 1);
        }
        // Example: align_up(0x0E, 8) = 0x10
        // utils.o:.text(9) ends at 0x0E
        // lib.o needs 16-byte align → pad 2
      '|
    }
    pad_visual: {
      shape: rectangle
      style.fill: "#FFF3E0"
      pad_diagram: |md
        **.text Layout Visualization:**
        
        0x00: [main.o/.text  14 bytes]
        0x0E: [padding  2 bytes] ← align to 16
        0x10: [utils.o/.text   9 bytes]
        0x19: [padding  7 bytes] ← align to 32
        0x20: [lib.o/.text     7 bytes]
        0x27: (end of .text)
        
      |
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_sections: {
    direction: down
    label: "OUTPUT SECTIONS (After Merge)"
    out_text: {
      shape: sql_table
      label: "Output .text (vaddr: 0x401000)"
      style.fill: "#E3F2FD"
      f0: "0x0000-0x000D | main.o code"
      f1: "0x000E-0x000F | padding"
      f2: "0x0010-0x0018 | utils.o code"
      f3: "0x0019-0x001F | padding"
      f4: "0x0020-0x0026 | lib.o code"
      sz: "Total: 39 bytes (0x27)"
    }
    out_rodata: {
      shape: sql_table
      label: "Output .rodata (vaddr: 0x402000)"
      style.fill: "#FFF8E1"
      f0: "0x0000-0x001D | utils.o strings"
      sz: "Total: 30 bytes (0x1E)"
    }
    out_data: {
      shape: sql_table
      label: "Output .data (vaddr: 0x403000)"
      style.fill: "#E8F5E9"
      f0: "0x0000-0x000B | main.o globals"
      sz: "Total: 12 bytes (0x0C)"
    }
    out_bss: {
      shape: sql_table
      label: "Output .bss (vaddr: 0x404000)"
      style.fill: "#FFEBEE"
      f0: "0x0000-0x004F | lib.o buffer (zero-fill)"
      note: "SHT_NOBITS: file_size=0, mem_size=80"
      sz: "Total: 80 bytes (mem only)"
    }
  }
  relocation_use: {
    direction: down
    label: "RELOCATION PROCESSING USE"
    use_desc: {
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      use_text: |md
        **Why This Table Exists:**
        Relocation entries reference **input section offsets**:
        
        Relocation: main.o, .text+0x05, R_X86_64_PC32
        
        The linker must translate to **output section offset**:
        
        1. Lookup: (main.o, .text, 0x05) → output 0x05
        2. Get output section vaddr: .text = 0x401000
        3. Site vaddr: 0x401000 + 0x05 = 0x401005
        4. Patch location in output buffer
        
        **Without this mapping, relocations cannot be applied.**
      |
    }
    flow_diagram: {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      flow_text: |md
        **Data Flow During Relocation:**
        
        Input File        Mapping Table        Output Buffer
        ─────────        ────────────        ─────────────
        main.o           
        └─ .text         
           └─ off 0x05 ──→ lookup() ────────→ buf + 0x1005
              (reloc)         ↓                  (patch here)
                          returns 0x05
        
      |
    }
  }
}
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  legend_text: |md
    **Legend:**
    - 🔵 Blue: Code sections (.text)
    - 🟡 Yellow: Read-only data (.rodata)
    - 🟢 Green: Initialized data (.data)
    - 🔴 Red: Uninitialized data (.bss)
    - Padding shown in lighter shade
    **Key Insight:** The mapping table is the linker's 
    "source of truth" for where every input byte lands.
  |
}
input_sections.main_o -> mapping_data.text_mappings: "register" {style.stroke-dash: 3}
input_sections.utils_o -> mapping_data.text_mappings: "register" {style.stroke-dash: 3}
input_sections.lib_o -> mapping_data.text_mappings: "register" {style.stroke-dash: 3}
mapping_data.text_mappings -> output_sections.out_text: "produces"
mapping_data.rodata_mappings -> output_sections.out_rodata: "produces"
mapping_data.data_mappings -> output_sections.out_data: "produces"
mapping_data.bss_mappings -> output_sections.out_bss: "produces"
lookup_example -> mapping_table: "queries"