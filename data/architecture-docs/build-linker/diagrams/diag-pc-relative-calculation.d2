direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## R_X86_64_PC32 Relocation Calculation
  PC-Relative 32-bit Offset Patching
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    direction: down
    label: "Step 1: Input Data"
    reloc_entry: {
      shape: sql_table
      label: "Relocation Entry (.rela.text)"
      f0: "r_offset  | 0x101"
      f1: "r_info    | sym=foo, type=R_X86_64_PC32"
      f2: "r_addend  | -4"
      sz: "Total: 24 bytes (ELF64_Rela)"
    }
    symbols: {
      shape: sql_table
      label: "Symbol Resolution"
      s0: "foo | 0x402000 | function in .text"
      s1: "Site | 0x401100 | call instruction"
    }
  }
  step2: {
    direction: down
    label: "Step 2: Identify Patch Location"
    width: 340
    code_box: {
      label: "x86-64 call instruction encoding"
      code: |'asm
        # Address: 0x401100
        E8 xx xx xx xx    # call foo (rel32)
        #    ^-- r_offset = 0x101
        #        (patch site = instruction + 1)
      '|
      width: 320
    }
    encoding: {
      shape: sql_table
      label: "Instruction Layout"
      b0: "0x401100 | E8      | opcode (call rel32)"
      b1: "0x401101 | xx      | rel32[0]  <-- PATCH HERE"
      b2: "0x401102 | xx      | rel32[1]"
      b3: "0x401103 | xx      | rel32[2]"
      b4: "0x401104 | xx      | rel32[3]"
      b5: "0x401105 | ...     | next instruction"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step3: {
    direction: down
    label: "Step 3: Apply PC-Relative Formula"
    width: 380
    formula_box: {
      label: "R_X86_64_PC32 Formula"
      code: |'c
        computed = S + A - P
        where:
          S = Symbol address     = 0x402000
          A = Addend             = -4 (0xFFFFFFFC)
          P = Patch site address = 0x401101
      '|
      width: 360
    }
    calc_box: {
      label: "Calculation"
      code: |'c
        computed = 0x402000 + (-4) - 0x401101
                = 0x402000 - 0x401105
                = 0x00000EFB
      '|
      width: 360
    }
    result: {
      shape: sql_table
      label: "Result"
      r0: "Computed value | 0x00000EFB"
      r1: "Fits in int32? | YES (within range)"
      r2: "Little-endian  | FB 0E 00 00"
    }
  }
  step4: {
    direction: down
    label: "Step 4: Write Patch (Little-Endian)"
    width: 340
    patch: {
      shape: sql_table
      label: "Output Buffer at 0x401101"
      p0: "[0] | 0xFB | rel32 byte 0 (LSB)"
      p1: "[1] | 0x0E | rel32 byte 1"
      p2: "[2] | 0x00 | rel32 byte 2"
      p3: "[3] | 0x00 | rel32 byte 3 (MSB)"
    }
    verify_box: {
      label: "Runtime Verification"
      code: |'asm
        # When call executes:
        # RIP = 0x401105 (next instruction)
        # rel32 = 0x00000EFB
        # Target = RIP + rel32
        #        = 0x401105 + 0xEFb
        #        = 0x402000 ✓
      '|
      width: 320
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step5: {
    direction: down
    label: "Step 5: Final Linked Code"
    before: {
      shape: class
      label: "Before Relocation"
      b0: "0x401100: E8 00 00 00 00"
      b1: "           call (placeholder)"
    }
    arrow1: {
      label: "patch"
      width: 60
    }
    after: {
      shape: class
      label: "After Relocation"
      a0: "0x401100: E8 FB 0E 00 00"
      a1: "           call 0x402000"
    }
    arrow2: {
      label: "jumps to"
      width: 60
    }
    target: {
      shape: class
      label: "Target Function"
      t0: "0x402000: foo:"
      t1: "           push rbp"
      t2: "           ..."
    }
  }
}
step1.reloc_entry -> step2.encoding: "offset maps to"
step2 -> step3: "resolve symbol"
step3 -> step4: "compute & write"
step4 -> step5.after: "patch applied"
legend: {
  near: bottom-right
  label: "Key Insight"
  insight: |md
    **Why addend = -4?**
    When `call` executes, RIP points to the *next* instruction
    (0x401105), not the patch site (0x401101).
    The formula `S + A - P` accounts for this:
    - Without addend: `0x402000 - 0x401101 = 0xEFF` ❌
    - With -4: `0x402000 - 4 - 0x401101 = 0xEFB` ✓
    The -4 skips past the 4-byte rel32 field itself.
  |
}