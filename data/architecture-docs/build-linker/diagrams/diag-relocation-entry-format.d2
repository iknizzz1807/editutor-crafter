direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Relocation Entry Structure
  `Elf64_Rela` — 24 bytes total
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rela_struct: {
    label: "Elf64_Rela (elf.h)"
    shape: sql_table
    f0: "0x00 | uint64_t | r_offset"
    f1: "0x08 | uint64_t | r_info"
    f2: "0x10 | int64_t  | r_addend"
    sz: "Total: 24 bytes"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  r_info_breakdown: {
    label: "r_info Bit Layout (64-bit)"
    shape: sql_table
    hi: "Bits 63:32 | uint32_t | Symbol Index"
    lo: "Bits 31:00 | uint32_t | Relocation Type"
    note: "Packed in single uint64_t"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  extraction: {
    label: "Extraction Macros"
    shape: class
    +ELF64_R_SYM: "(i) >> 32"
    +ELF64_R_TYPE: "(i) & 0xFFFFFFFF"
    +ELF64_R_INFO: "(sym, type) ((sym)<<32 | (type))"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  example: {
    label: "Example: R_X86_64_PC32 for symbol 5"
    width: 400
    code: |'c
      // Symbol index = 5, Type = R_X86_64_PC32 (2)
      r_info = (5 << 32) | 2 = 0x0000000500000002
      ELF64_R_SYM(r_info)  = 5  // Symbol table index
      ELF64_R_TYPE(r_info) = 2  // PC-relative 32-bit
    '|
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fields: {
    label: "Field Semantics"
    shape: sql_table
    f0: "r_offset | Where to patch | Section-relative byte offset"
    f1: "r_info   | What + How    | Symbol index + relocation type"
    f2: "r_addend | Adjustment    | Added to symbol address"
  }
}
row1 -> row2: "r_info expands to"
row2 -> row3: "extract with"
row3 -> row4: "example"
row4 -> fields: "applies to"
legend: {
  near: bottom-right
  label: "Relocation Types (x86-64)"
  shape: sql_table
  t0: "R_X86_64_64   | 1 | Direct 64-bit absolute"
  t1: "R_X86_64_PC32 | 2 | PC-relative 32-bit signed"
  t2: "R_X86_64_32   | 10 | Direct 32-bit zero-extended"
  t3: "R_X86_64_32S  | 11 | Direct 32-bit sign-extended"
}