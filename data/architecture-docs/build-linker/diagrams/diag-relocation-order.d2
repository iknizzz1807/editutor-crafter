direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Relocation Processing Order {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
sequence: {
  shape: sequence_diagram
  linker: Linker
  sections: Section Merger
  symbols: Symbol Resolver
  relocs: Relocation Processor
  linker.t1 -> sections.t1: merge_all_sections()
  sections.t1 -> sections.t1: "Group .text, .data, .rodata"
  sections.t1 -> sections.t1: "Build mapping table"
  sections.t1 -> linker.t1: "mappings ready"
  linker.t2 -> symbols.t1: resolve_symbols()
  symbols.t1 -> symbols.t1: "Parse .symtab"
  symbols.t1 -> symbols.t1: "Resolve undefined refs"
  symbols.t1 -> symbols.t1: "Assign final addresses"
  symbols.t2 -> linker.t2: "global_syms populated"
  linker.t3 -> relocs.t1: process_relocations()
  relocs.t1 -> symbols.t2: "lookup_symbol(helper)"
  symbols.t2 -> relocs.t1: "0x400080"
  relocs.t1 -> relocs.t1: "Compute: 0x400080 - 0x400105"
  relocs.t1 -> relocs.t1: "Patch bytes at offset"
  relocs.t2 -> linker.t3: "all fixups applied"
}
why_order_matters: Why Order Matters {
  style.fill: "#E8F4FD"
  step1: "1. Section Merging" {
    width: 280
    desc: |md
      - Determines where each input
        section ends up in output
      - Builds mapping table:
        (file, section, offset) → output_offset
      - Required for: translating
        relocation site addresses
    |
  }
  step2: "2. Symbol Resolution" {
    width: 280
    desc: |md
      - Parses all .symtab entries
      - Resolves cross-file references
      - Assigns final virtual address
        to every symbol
      - Required for: relocation
        target address lookup
    |
  }
  step3: "3. Relocation Processing" {
    width: 280
    desc: |md
      - DEPENDS ON BOTH above
      - Needs mapping table to find
        relocation site in output
      - Needs symbol table to find
        target address
      - Cannot proceed without either
    |
  }
  step1 -> step2: "must complete"
  step2 -> step3: "must complete"
}
wrong_order: What Goes Wrong {
  style.fill: "#FDECE8"
  bad1: "Process relocations BEFORE symbols" {
    width: 340
    code: |'c
      // Looking up 'helper'...
      GlobalSymbol *s = lookup("helper");
      // s == NULL or s->state == UNDEF
      // ERROR: Cannot compute patch!
    '|
  }
  bad2: "Process relocations BEFORE mapping" {
    width: 340
    code: |'c
      // Relocation at input offset 0x20
      // Where is this in output???
      // mapping table is empty!
      // ERROR: Cannot find patch site
    '|
  }
  bad1 -> bad2: {
    style.stroke: transparent
  }
}
dependency_formula: Relocation Formula Dependencies {
  style.fill: "#F0FDF4"
  formula_box: {
    width: 400
    label: "PC-Relative Relocation Formula"
    formula: |md
      
      patch_value = symbol_address + addend - site_address
                    ^^^^^^^^^^^^^^         ^^^^^^^^^^^^
                    from symbol            from section
                    resolution (M2)        merging (M1)
      
    |
  }
  arrow1: "symbol_address" {
    shape: text
    style.font-color: blue
  }
  arrow1 -> formula_box: {
    style.stroke: blue
    style.stroke-dash: 3
  }
  arrow2: "site_address" {
    shape: text
    style.font-color: green
  }
  arrow2 -> formula_box: {
    style.stroke: green
    style.stroke-dash: 3
  }
}
sequence -> why_order_matters: "Dependencies"
why_order_matters -> wrong_order: "Violations"
why_order_matters -> dependency_formula: "Why it matters"