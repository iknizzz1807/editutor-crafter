direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  check_style: {
    style: {
      stroke-width: 3
    }
  }
  input_node: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
    }
  }
  logic_step: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
}

title: |md
  # Overflow Detection: R_X86_64_32 Truncation
| {
  near: top-center
}

row_inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  symbol_addr: {
    label: "Symbol Address (64-bit)"
    class: input_node
    width: 250
    code: |'c
      // Source: symtab.c
      uint64_t sym_addr = 0x7FFF12345678;
    '|
  }

  addend: {
    label: "Addend (64-bit)"
    class: input_node
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 250
    code: |'c
      // Source: relocation section
      int64_t addend = 0x0000EDCBA988;
    '|
  }
}

row_inputs -> compute: "uint64_t | ADD"

compute: {
  label: "Compute 64-bit Result (linker.c:relocate)"
  class: logic_step
  width: 450
  code: |'c
    uint64_t result = sym_addr + addend;
    // Example Target: R_X86_64_32 (32-bit zero-extended)
    // Range: [0, 4294967295]
    // result = 0x80000000 (2GB+1) -> Overflow if signed!
  '|
}

compute -> check: "result"

check: {
  shape: diamond
  label: "value in range?\n[0, 2^32-1]"
  width: 180
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
}

check -> ok: "YES"
check -> err: "NO"

row_results: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ok: {
    label: "Relocation Success"
    width: 300
    code: |'c
      // Truncate to 32 bits
      uint32_t val32 = (uint32_t)result;
      memcpy(loc, &val32, 4);
    '|
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }

  err: {
    label: "Relocation Overflow"
    width: 300
    code: |'c
      // Diagnostic Error
      error("relocation R_X86_64_32 overflow");
      error("value 0x%lx out of range", result);
      exit(1);
    '|
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
}

(check -> ok)[0].class: check_style
(check -> err)[0].class: check_style
(check -> err)[0].style.stroke: "#D32F2F"
(check -> err)[0].style.stroke-dash: 4

legend: {
  label: "Relocation Limits (R_X86_64_32)"
  near: bottom-right
  direction: right
  
  valid: {
    label: "Valid: [0, 0xFFFFFFFF]"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  
  invalid: {
    label: "Invalid: > 32-bits"
    shape: rectangle
    style.fill: "#FFCDD2"
  }
}