direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Relocation Patching: Before/After"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  context_before: {
    direction: down
    label: "BEFORE Linking"
    section_before: {
      label: ".text section bytes"
      shape: rectangle
      width: 420
      header_row: {
        direction: right
        offset_label: {
          label: "Offset"
          shape: text
          style.bold: true
          style.font: mono
        }
        bytes_label: {
          label: "Raw Bytes"
          shape: text
          style.bold: true
          style.font: mono
        }
        meaning_label: {
          label: "Instruction"
          shape: text
          style.bold: true
          style.font: mono
        }
      }
      row1: {
        direction: right
        offset1: {
          label: "0x100"
          shape: text
          style.font: mono
          width: 60
        }
        bytes1: {
          label: "55"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
          width: 40
        }
        meaning1: {
          label: "push rbp"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
      row2: {
        direction: right
        offset2: {
          label: "0x101"
          shape: text
          style.font: mono
        }
        bytes2: {
          label: "48 89 E5"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
        meaning2: {
          label: "mov rbp, rsp"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
      row3: {
        direction: right
        offset3: {
          label: "0x104"
          shape: text
          style.font: mono
        }
        bytes3: {
          label: "E8"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
        meaning3: {
          label: "call (opcode)"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
      row4: {
        direction: right
        offset4: {
          label: "0x105"
          shape: text
          style.font: mono
          style.fill: "#FFCDD2"
        }
        bytes4: {
          label: "00 00 00 00"
          shape: text
          style.font: mono
          style.bold: true
          style.fill: "#FFCDD2"
        }
        meaning4: {
          label: "PLACEHOLDER (to helper)"
          shape: text
          style.font: mono
          style.bold: true
          style.fill: "#FFCDD2"
        }
      }
      row5: {
        direction: right
        offset5: {
          label: "0x109"
          shape: text
          style.font: mono
        }
        bytes5: {
          label: "31 C0"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
        meaning5: {
          label: "xor eax, eax"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
    }
    relocation_entry: {
      label: "Relocation Entry"
      shape: class
      r_offset: "0x0005"
      r_type: "R_X86_64_PC32"
      r_sym: "helper"
      r_addend: "-4"
    }
    status_before: {
      label: "Status: Awaiting symbol resolution"
      shape: text
      style: {
        font-color: "#C62828"
        bold: true
        italic: true
      }
    }
  }
}
arrow_transform: {
  label: "Linker\nPatches"
  shape: text
  style: {
    font-size: 20
    bold: true
    font-color: "#1565C0"
  }
}
calc_box: {
  label: "Relocation Calculation"
  width: 450
  formula: |'c
    // R_X86_64_PC32 formula:
    computed = symbol_addr + addend - site_addr
             = 0x401200  + (-4)   - 0x401105
             = 0x401200 - 0x401109
             = 0x00000EF7
    // Little-endian encoding:
    // 0x00000EF7 → F7 0E 00 00
  '|
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  context_after: {
    direction: down
    label: "AFTER Linking"
    section_after: {
      label: ".text section bytes"
      shape: rectangle
      width: 420
      header_row2: {
        direction: right
        offset_label2: {
          label: "Offset"
          shape: text
          style.bold: true
          style.font: mono
        }
        bytes_label2: {
          label: "Raw Bytes"
          shape: text
          style.bold: true
          style.font: mono
        }
        meaning_label2: {
          label: "Instruction"
          shape: text
          style.bold: true
          style.font: mono
        }
      }
      row1a: {
        direction: right
        offset1a: {
          label: "0x100"
          shape: text
          style.font: mono
        }
        bytes1a: {
          label: "55"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
        meaning1a: {
          label: "push rbp"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
      row2a: {
        direction: right
        offset2a: {
          label: "0x101"
          shape: text
          style.font: mono
        }
        bytes2a: {
          label: "48 89 E5"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
        meaning2a: {
          label: "mov rbp, rsp"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
      row3a: {
        direction: right
        offset3a: {
          label: "0x104"
          shape: text
          style.font: mono
        }
        bytes3a: {
          label: "E8"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
        meaning3a: {
          label: "call (opcode)"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
      row4a: {
        direction: right
        offset4a: {
          label: "0x105"
          shape: text
          style.font: mono
          style.fill: "#C8E6C9"
        }
        bytes4a: {
          label: "F7 0E 00 00"
          shape: text
          style.font: mono
          style.bold: true
          style.fill: "#C8E6C9"
        }
        meaning4a: {
          label: "PATCHED (+0xEF7 bytes)"
          shape: text
          style.font: mono
          style.bold: true
          style.fill: "#C8E6C9"
        }
      }
      row5a: {
        direction: right
        offset5a: {
          label: "0x109"
          shape: text
          style.font: mono
        }
        bytes5a: {
          label: "31 C0"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
        meaning5a: {
          label: "xor eax, eax"
          shape: text
          style.font: mono
          style.fill: "#E8F5E9"
        }
      }
    }
    verification: {
      label: "Verification"
      shape: class
      at_exec: "RIP at execution: 0x401109"
      offset_val: "Offset in code: 0x00000EF7"
      target: "Target: 0x401109 + 0xEF7 = 0x401000"
      result: "✓ Jumps to helper()"
    }
    status_after: {
      label: "Status: Ready to execute"
      shape: text
      style: {
        font-color: "#2E7D32"
        bold: true
        italic: true
      }
    }
  }
}
memory_map: {
  label: "Memory Layout Reference"
  shape: rectangle
  width: 500
  addr_table: {
    shape: sql_table
    label: "Virtual Addresses"
    row1: "0x401100 | main() | call site"
    row2: "0x401105 | +0x5   | patch location"
    row3: "0x401109 | +0x9   | next instruction (RIP)"
    row4: "0x402000 | helper() | call target"
  }
}
legend: {
  near: bottom-center
  direction: right
  key_red: {
    label: "Red = Placeholder (needs patching)"
    shape: text
    style.font-color: "#C62828"
  }
  key_green: {
    label: "Green = Patched (ready to run)"
    shape: text
    style.font-color: "#2E7D32"
  }
}
context_before -> calc_box: "read\nrelocation"
calc_box -> context_after: "write\nbytes"