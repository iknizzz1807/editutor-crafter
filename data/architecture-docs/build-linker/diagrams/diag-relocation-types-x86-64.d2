direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # x86-64 Relocation Type Reference
| {near: top-center}
# ============================================
# ROW 1: Reference Table
# ============================================
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Main reference table
  reloc_table: {
    shape: sql_table
    label: "Relocation Types (x86-64 ELF)"
    # Header row simulation
    hdr_type: "Type | Bits | Signed | Overflow Check | Formula"
    # R_X86_64_64
    r64: "R_X86_64_64 | 64 | No | None | S + A"
    # R_X86_64_PC32
    rpc32: "R_X86_64_PC32 | 32 | Yes | INT32_MIN..MAX | S + A - P"
    # R_X86_64_32
    r32: "R_X86_64_32 | 32 | No | 0..UINT32_MAX | S + A"
    # R_X86_64_32S
    r32s: "R_X86_64_32S | 32 | Yes | INT32_MIN..MAX | S + A"
    # Legend
    legend: "Legend: S=sym_addr, A=addend, P=patch_site_addr"
  }
}
# ============================================
# ROW 2: Visual breakdown of each type
# ============================================
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # R_X86_64_64 box
  type_64: {
    label: "R_X86_64_64"
    width: 320
    desc: |md
      **Absolute 64-bit address**
      - Full virtual address fits
      - No overflow possible
      - Used for: function pointers,
        vtables, global refs in data
    |
    formula: {
      shape: rectangle
      label: "patch = symbol + addend"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    example: {
      label: "Example: Function Pointer"
      code: |'c
        // .data section
        void (*cb)(void) = helper;
        // Relocation:
        // offset=0, type=R_X86_64_64
        // sym=helper, addend=0
        // patch: 8 bytes at offset 0
      '|
      width: 300
    }
  }
  # R_X86_64_PC32 box
  type_pc32: {
    label: "R_X86_64_PC32"
    width: 320
    desc: |md
      **PC-relative 32-bit offset**
      - Distance from instruction
      - Signed: can be negative
      - Used for: call, jmp, RIP-rel
    |
    formula: {
      shape: rectangle
      label: "patch = sym + addend - site"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    example: {
      label: "Example: call Instruction"
      code: |'c
        // call helper at 0x401004
        // E8 XX XX XX XX (5 bytes)
        // site = 0x401005 (after E8)
        // helper at 0x401020
        // addend = -4 (RIP points past)
        // patch = 0x401020-4-0x401005
        //       = 0x17 (little-endian)
      '|
      width: 300
    }
  }
}
# ============================================
# ROW 3: Remaining two types
# ============================================
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # R_X86_64_32 box
  type_32: {
    label: "R_X86_64_32"
    width: 320
    desc: |md
      **Absolute 32-bit (zero-extended)**
      - Truncates to low 32 bits
      - Must fit in 0..0xFFFFFFFF
      - Used for: legacy 32-bit code,
        small model data refs
    |
    formula: {
      shape: rectangle
      label: "patch = (uint32_t)(sym + addend)"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    warning: {
      label: "⚠️ Overflow Error"
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      desc: |md
        If (sym + addend) > 0xFFFFFFFF
        → linker must report error
      |
    }
  }
  # R_X86_64_32S box
  type_32s: {
    label: "R_X86_64_32S"
    width: 320
    desc: |md
      **Absolute 32-bit (sign-extended)**
      - Interprets value as signed
      - Must fit in INT32_MIN..MAX
      - Used for: medium code model,
        absolute addressing in code
    |
    formula: {
      shape: rectangle
      label: "patch = (int32_t)(sym + addend)"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    warning: {
      label: "⚠️ Overflow Error"
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      desc: |md
        If (sym + addend) outside
        -2147483648..2147483647
        → linker must report error
      |
    }
  }
}
# ============================================
# ROW 4: Visual: PC-relative calculation
# ============================================
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pc32_visual: {
    direction: down
    label: "R_X86_64_PC32: Visual Calculation"
    memory_layout: {
      direction: right
      code_region: {
        label: ".text section"
        style.fill: "#E8F5E9"
        instr_before: {
          label: "0x401000: 55"
          style.fill: transparent
        }
        call_opcode: {
          label: "0x401004: E8"
          style.fill: "#C8E6C9"
          desc: "call opcode"
        }
        call_offset: {
          label: "0x401005: XX XX XX XX"
          style.fill: "#81C784"
          style.font-color: white
          desc: "← patch site (P)"
        }
        next_instr: {
          label: "0x401009: ..."
          style.fill: transparent
        }
      }
      arrow_to_target: {
        shape: rectangle
        width: 80
        label: "→ offset →"
        style.fill: transparent
        style.stroke: transparent
        style.font-color: "#1976D2"
      }
      target_region: {
        label: "Target"
        style.fill: "#E3F2FD"
        helper_func: {
          label: "0x401020: helper:"
          style.fill: "#BBDEFB"
          desc: "← symbol addr (S)"
        }
      }
    }
    calc_box: {
      label: "Calculation"
      style.fill: "#F5F5F5"
      formula: |md
        S = 0x401020 (helper address)
        A = -4 (addend: RIP points to next instr)
        P = 0x401005 (patch site address)
        **Result = S + A - P**
        = 0x401020 + (-4) - 0x401005
        = 0x401020 - 0x401009
        = **0x17** (stored little-endian as 17 00 00 00)
        **Verify:** RIP after call = 0x401009
        RIP + 0x17 = 0x401020 ✓
      |
    }
  }
}
# ============================================
# ROW 5: Usage decision guide
# ============================================
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  usage_guide: {
    direction: down
    label: "When to Use Each Type"
    width: 700
    decision_table: {
      shape: sql_table
      label: "Decision Guide"
      hdr: "Scenario | Recommended Type | Why"
 row1: "call/jmp to function | R_X86_64_PC32 | RIP-relative, no base needed"
      row2: "Function pointer in .data | R_X86_64_64 | Full 64-bit address"
      row3: "Global var ref in code | R_X86_64_PC32 | RIP-relative load/store"
      row4: "Vtable entry | R_X86_64_64 | Full pointer needed"
      row5: "Small model abs addr | R_X86_64_32S | Code <2GB, sign-extend OK"
    }
  }
  overflow_box: {
    direction: down
    label: "Overflow Detection"
    width: 350
    check_32: {
      label: "32-bit Unsigned (R_X86_64_32)"
      code: |'c
        uint64_t val = sym + addend;
        if (val > UINT32_MAX) {
          error("relocation overflow");
        }
      '|
    }
    check_32s: {
      label: "32-bit Signed (R_X86_64_32S)"
      code: |'c
        int64_t val = sym + addend;
        if (val > INT32_MAX || 
            val < INT32_MIN) {
          error("relocation overflow");
        }
      '|
    }
    check_pc32: {
      label: "PC-relative (R_X86_64_PC32)"
      code: |'c
        int64_t offset = sym + addend - site;
        if (offset > INT32_MAX || 
            offset < INT32_MIN) {
          error("PC-relative overflow");
        }
      '|
    }
  }
}
# ============================================
# Legend / footer
# ============================================
legend_footer: {
  near: bottom-center
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  content: |md
    **Key Terms:**
    - **S (Symbol)**: Final virtual address of the target symbol
    - **A (Addend)**: Constant adjustment from relocation entry
    - **P (Patch Site)**: Virtual address where relocation is applied
    - **RIP**: Instruction pointer register (points to next instruction during execution)
  |
}