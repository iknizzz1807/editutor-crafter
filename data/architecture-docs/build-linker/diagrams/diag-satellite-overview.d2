direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    input: "#E8F4FD"
    m1: "#FFF3E0"
    m2: "#E8F5E9"
    m3: "#FCE4EC"
    m4: "#EDE7F6"
    output: "#C8E6C9"
    header: "#1565C0"
    data: "#2E7D32"
    meta: "#7B1FA2"
    error: "#C62828"
  }
}

header_node: {
  label: "Linker Pipeline: Satellite View"
  note: "Four-stage transformation from object files to executable"
  style.font-size: 24
  style.bold: true
  style.stroke: transparent
  style.fill: transparent
}

# ============================================
# ROW 1: INPUT OBJECT FILES
# ============================================
row_inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  obj_file_a: {
    label: "main.o (Relocatable)"
    style.fill: ${colors.input}
    elf_hdr_a: {
      label: "ELF Header\ne_type: ET_REL"
      shape: rectangle
    }
    sec_tab_a: {
      label: "Sections\n.text, .data\n.symtab"
      shape: rectangle
    }
    sym_a: {
      label: "Symbols\nmain (G)\nhelper (U)"
      shape: rectangle
    }
    reloc_a: {
      label: "Relocations\ncall <helper>"
      shape: rectangle
    }
    elf_hdr_a -> sec_tab_a
    sec_tab_a -> sym_a
    sec_tab_a -> reloc_a
  }
  
  obj_file_b: {
    label: "utils.o (Relocatable)"
    style.fill: ${colors.input}
    elf_hdr_b: {
      label: "ELF Header\ne_type: ET_REL"
      shape: rectangle
    }
    sec_tab_b: {
      label: "Sections\n.text, .bss\n.symtab"
      shape: rectangle
    }
    sym_b: {
      label: "Symbols\nhelper (G)\nbuffer (C)"
      shape: rectangle
    }
    reloc_b: {
      label: "Relocations\nlea <msg>"
      shape: rectangle
    }
    elf_hdr_b -> sec_tab_b
    sec_tab_b -> sym_b
    sec_tab_b -> reloc_b
  }
}

# ============================================
# ROW 2: MILESTONE 1 - SECTION MERGING
# ============================================
row_m1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m1_stage: {
    label: "M1: Section Merging (linker.c)"
    style.fill: ${colors.m1}
    style.stroke: "#E65100"
    style.stroke-width: 2
    
    m1_process: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      m1_parse: "Parse ELF"
      m1_filter: "Filter ALLOC"
      m1_group: "Group by Name"
      m1_concat: "Concat Sections"
      
      m1_parse -> m1_filter -> m1_group -> m1_concat
    }
    
    m1_data: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      out_sec: {
        shape: sql_table
        label: "struct OutputSection"
        f0: "0x00 | char[64]  | name"
        f1: "0x40 | uint64_t | flags"
        f2: "0x48 | uint64_t | align"
        f3: "0x50 | uint64_t | file_size"
        f4: "0x58 | uint64_t | mem_size"
        f5: "0x60 | uint64_t | virtual_addr"
        sz: "Total: 104 bytes"
      }
      mapping: {
        shape: sql_table
        label: "struct InputSectionMap"
        f0: "0x00 | void*      | input_ptr"
        f1: "0x08 | uint64_t   | out_offset"
        f2: "0x10 | uint64_t   | size"
        sz: "Total: 24 bytes"
      }
    }
  }
}

# ============================================
# ROW 3: MILESTONE 2 - SYMBOL RESOLUTION
# ============================================
row_m2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m2_stage: {
    label: "M2: Symbol Resolution"
    style.fill: ${colors.m2}
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    
    m2_process: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      m2_extract: "Extract Syms"
      m2_resolve: "Resolve Conflict"
      m2_assign: "Assign Addrs"
      m2_extract -> m2_resolve -> m2_assign
    }
    
    m2_rules: {
      shape: class
      label: "Resolution Logic"
      style.fill: "#C8E6C9"
      +Strong_Strong: "Error"
      +Strong_Weak: "Strong Wins"
      +Weak_Weak: "First Wins"
      +Common: "Largest Wins"
    }
    
    m2_output: {
      shape: sql_table
      label: "Global Symbol Table"
      style.fill: "#C8E6C9"
      f0: "0x00 | char[64] | name"
      f1: "0x40 | uint8_t  | binding"
      f2: "0x48 | uint64_t | final_vaddr"
      sz: "Total: 80 bytes/entry"
    }
  }
}

# ============================================
# ROW 4: MILESTONE 3 - RELOCATION PROCESSING
# ============================================
row_m3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m3_stage: {
    label: "M3: Relocation Processing"
    style.fill: ${colors.m3}
    style.stroke: "#AD1457"
    style.stroke-width: 2
    
    m3_process: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      m3_lookup: "Sym Lookup"
      m3_compute: "Calc Patch"
      m3_write: "Apply Patch"
      m3_lookup -> m3_compute -> m3_write
    }
    
    m3_logic: {
      label: "Relocation Formulas"
      style.fill: "#F8BBD9"
      formulas: |'md
        S: Sym Addr, A: Addend, P: Site
        R_X86_64_64:   *loc = S + A
        R_X86_64_PC32: *loc = S + A - P
      '|
    }
    
    m3_buffer: {
      shape: sql_table
      label: "Patched Buffer"
      style.fill: "#F8BBD9"
      f0: "0x401000 | 0x55       | push rbp"
      f1: "0x401005 | 0xE8 <off> | call helper"
      note: "Address 0x401005 is now resolved"
    }
  }
}

# ============================================
# ROW 5: MILESTONE 4 - EXECUTABLE GENERATION
# ============================================
row_m4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m4_stage: {
    label: "M4: Executable Generation"
    style.fill: ${colors.m4}
    style.stroke: "#6A1B9A"
    style.stroke-width: 2
    
    m4_process: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      m4_phdr: "Build PHDRs"
      m4_ehdr: "Build EHDR"
      m4_write: "Final Write"
      m4_phdr -> m4_ehdr -> m4_write
    }
    
    m4_layout: {
      shape: sql_table
      label: "ELF64 Executable Layout"
      style.fill: "#D1C4E9"
      f0: "0x0000 | Elf64_Ehdr | Entry Point"
      f1: "0x0040 | Elf64_Phdr | Segment Map"
      f2: "0x1000 | .text      | Code (RX)"
      f3: "0x2000 | .data      | Data (RW)"
    }
  }
}

# ============================================
# ROW 6: OUTPUT EXECUTABLE
# ============================================
row_output: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  executable: {
    label: "Executable (a.out)"
    style.fill: ${colors.output}
    style.stroke: "#1B5E20"
    style.stroke-width: 3
    
    out_ehdr: {
      shape: sql_table
      label: "Elf64_Ehdr"
      f0: "e_type  | 2 (ET_EXEC)"
      f1: "e_entry | 0x401000"
      f2: "e_phnum | 2"
    }
    
    out_phdr: {
      shape: sql_table
      label: "Elf64_Phdr (TEXT)"
      f0: "p_type  | 1 (PT_LOAD)"
      f1: "p_flags | 5 (R|X)"
      f2: "p_vaddr | 0x401000"
    }
  }
  
  loader: {
    label: "OS Loader (execve)"
    style.fill: "#B3E5FC"
    execution_logic: |'md
      1. mmap() PT_LOAD segments
      2. Zero initialize .bss
      3. Set CPU registers (RIP=e_entry)
      4. Jump to code
    '|
  }
}

# ============================================
# CONNECTIONS
# ============================================
row_inputs -> row_m1.m1_stage: "Object Data"
row_m1.m1_stage -> row_m2.m2_stage: "Mapped Layout"
row_m2.m2_stage -> row_m3.m3_stage: "Symbol Values"
row_m1.m1_stage -> row_m3.m3_stage: "Raw Bytes" { style.stroke-dash: 4 }
row_m3.m3_stage -> row_m4.m4_stage: "Patched Code"
row_m4.m4_stage -> row_output.executable: "Final ELF"
row_output.executable -> row_output.loader: "execve()"

# ============================================
# LEGEND
# ============================================
legend: {
  label: "Pipeline Legend"
  direction: right
  style.fill: "#FAFAFA"
  
  l1: "Relocatable" { style.fill: ${colors.input} }
  l2: "Linking Phase" { style.fill: ${colors.m1} }
  l3: "Executable" { style.fill: ${colors.output} }
}
legend.near: bottom-right