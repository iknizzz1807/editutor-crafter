direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Section Flags and Consistency {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  flag_overview: {
    direction: down
    label: Section Flag Bitmask (sh_flags)
    shf_alloc: {
      shape: sql_table
      label: "SHF_ALLOC (0x02)"
      bit: "Bit 1 | Section occupies memory during execution"
      meaning: "If set: section is loaded into virtual address space"
      sections: "Examples: .text, .data, .rodata, .bss"
      skip: "If clear: metadata only (.symtab, .strtab, .rela.*)"
    }
    shf_write: {
      shape: sql_table
      label: "SHF_WRITE (0x01)"
      bit: "Bit 0 | Section is writable at runtime"
      meaning: "If set: process can modify contents"
      sections: "Examples: .data, .bss"
      skip2: "If clear: read-only (.text, .rodata)"
    }
    shf_execinstr: {
      shape: sql_table
      label: "SHF_EXECINSTR (0x04)"
      bit: "Bit 2 | Section contains executable code"
      meaning: "If set: CPU can fetch instructions from here"
      sections2: "Examples: .text, .init, .fini"
      skip3: "If clear: data only (.data, .rodata, .bss)"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  section_matrix: {
    direction: down
    label: Common Section Types and Flags
    text_row: {
      direction: right
      text_label: ".text" {
        width: 80
        style.fill: "#E8F5E9"
      }
      text_flags: "SHF_ALLOC | SHF_EXECINSTR" {
        width: 200
        style.fill: "#E8F5E9"
      }
      text_perm: "R-X (read + execute)" {
        width: 150
        style.fill: "#E8F5E9"
      }
    }
    rodata_row: {
      direction: right
      rodata_label: ".rodata" {
        width: 80
        style.fill: "#E3F2FD"
      }
      rodata_flags: "SHF_ALLOC" {
        width: 200
        style.fill: "#E3F2FD"
      }
      rodata_perm: "R-- (read only)" {
        width: 150
        style.fill: "#E3F2FD"
      }
    }
    data_row: {
      direction: right
      data_label: ".data" {
        width: 80
        style.fill: "#FFF3E0"
      }
      data_flags: "SHF_ALLOC | SHF_WRITE" {
        width: 200
        style.fill: "#FFF3E0"
      }
      data_perm: "RW- (read + write)" {
        width: 150
        style.fill: "#FFF3E0"
      }
    }
    bss_row: {
      direction: right
      bss_label: ".bss" {
        width: 80
        style.fill: "#FCE4EC"
      }
      bss_flags: "SHF_ALLOC | SHF_WRITE" {
        width: 200
        style.fill: "#FCE4EC"
      }
      bss_perm: "RW- (read + write, zeroed)" {
        width: 150
        style.fill: "#FCE4EC"
      }
    }
    symtab_row: {
      direction: right
      symtab_label: ".symtab" {
        width: 80
        style.fill: "#ECEFF1"
      }
      symtab_flags: "(none - metadata)" {
        width: 200
        style.fill: "#ECEFF1"
      }
      symtab_perm: "Not loaded" {
        width: 150
        style.fill: "#ECEFF1"
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  conflict_scenario: {
    direction: down
    label: Flag Conflict Scenario
    before: {
      direction: right
      label: Input Files
      file_a: {
        label: "main.o"
        style.fill: "#C8E6C9"
        rodata_a: {
          label: ".rodata"
          code: |'c
            const char *msg = "hello";
            // Compiler emits:
            // .section .rodata
            // flags: SHF_ALLOC
          '|
          width: 280
        }
      }
      file_b: {
        label: "legacy.o"
        style.fill: "#FFCDD2"
        rodata_b: {
          label: ".rodata (BUG!)"
          code2: |'c
            char *msg = "world";  // missing const!
            // Bug: compiler may emit:
            // .section .rodata,"aw"
            // flags: SHF_ALLOC | SHF_WRITE
          '|
          width: 280
          style.fill: "#FFCDD2"
        }
      }
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  resolution_strategies: {
    direction: down
    label: Conflict Resolution Strategies
    strategy1: {
      label: "Strategy 1: Union of Flags (Permissive)"
      code3: |'c
        // Merge flags: out->flags |= input->flags
        // Result: .rodata gets SHF_ALLOC | SHF_WRITE
        // Consequence: rodata becomes writable!
        // Security: Relaxing permissions is safe-ish
      '|
      width: 320
      style.fill: "#FFF9C4"
    }
    strategy2: {
      label: "Strategy 2: Error on Mismatch (Strict)"
      code4: |'c
        // Reject if flags differ:
        // "error: section '.rodata' has conflicting flags"
        // Consequence: link fails, user must fix code
        // Safety: Catches bugs at link time
      '|
      width: 320
      style.fill: "#FFCDD2"
    }
    strategy3: {
      label: "Strategy 3: Warn and Union (Pragmatic)"
      code5: |'c
        // Warn: "warning: .rofoo flags differ"
        // Merge with union of flags
        // Most real linkers use this approach
        // GNU ld: warn, then use union
      '|
      width: 320
      style.fill: "#C8E6C9"
    }
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  merge_logic: {
    direction: down
    label: Section Merge Logic (linker.c)
    merge_func: {
      shape: class
      label: "Section Merger"
      -ctx: "LinkerContext*"
      -out: "OutputSection*"
      -input: "InputSection*"
      +merge_section_flags(): "int"
      +validate_flag_compatibility(): "bool"
      +compute_output_flags(): "uint64_t"
    }
    code_block: {
      label: "Flag Merge Implementation"
      code6: |'c
        int merge_section_flags(OutputSection *out, 
                                InputSection *in,
                                const char *filename) {
          // First input: adopt its flags
          if (out->mapping_count == 0) {
            out->flags = in->flags;
            return 0;
          }
          // Check for conflicts
          uint64_t diff = out->flags ^ in->flags;
          if (diff & (SHF_WRITE | SHF_EXECINSTR)) {
            // Critical flag mismatch
            fprintf(stderr, 
              "warning: section '%s' flags mismatch\n",
              in->name);
            fprintf(stderr, "  existing: 0x%lx\n", out->flags);
            fprintf(stderr, "  new: 0x%lx from %s\n", 
                    in->flags, filename);
          }
          // Union merge (permissive)
          out->flags |= in->flags;
          return 0;
        }
      '|
      width: 380
    }
  }
}
row6: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  segment_impact: {
    direction: down
    label: Impact on Segment Assignment
    before_merge: {
      direction: right
      label: Before Flag Merge
      seg1: {
        label: "Text Segment (R-X)"
        style.fill: "#E8F5E9"
        content1: ".text"
        content2: ".rodata (read-only)"
      }
      arrow1: "->"
      seg2: {
        label: "Data Segment (RW-)"
        style.fill: "#FFF3E0"
        content3: ".data"
        content4: ".bss"
      }
    }
    after_merge: {
      direction: right
      label: After .rodata Becomes Writable"
      seg3: {
        label: "Text Segment (R-X)"
        style.fill: "#E8F5E9"
        content5: ".text"
      }
      arrow2: "->"
      seg4: {
        label: "Data Segment (RW-)"
        style.fill: "#FFF3E0"
        content6: ".rodata (NOW WRITABLE!)"
        content7: ".data"
        content8: ".bss"
        style.stroke: "#D32F2F"
      }
    }
    warning: {
      label: "Security Warning"
      code7: |'c
        // Writable .rodata breaks security assumptions:
        // - String literals can be modified at runtime
        // - Const data is no longer truly const
        // - RELRO protection may be weakened
        // 
        // This is why strict mode exists!
      '|
      width: 340
      style.fill: "#FFEBEE"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  label: Legend
  green: {
    shape: rectangle
    label: ""
    width: 20
    height: 20
    style.fill: "#C8E6C9"
  }
  green_label: "Code sections (executable)" {
    width: 160
  }
  blue: {
    shape: rectangle
    label: ""
    width: 20
    height: 20
    style.fill: "#BBDEFB"
  }
  blue_label: "Read-only data" {
    width: 120
  }
  orange: {
    shape: rectangle
    label: ""
    width: 20
    height: 20
    style.fill: "#FFE0B2"
  }
  orange_label: "Writable data" {
    width: 120
  }
  red: {
    shape: rectangle
    label: ""
    width: 20
    height: 20
    style.fill: "#FFCDD2"
  }
  red_label: "Conflict/Error" {
    width: 120
  }
}
file_a -> file_b: "Same section name\nDifferent flags" {
  style.stroke-dash: 4
  style.stroke: "#D32F2F"
}
resolution_strategies -> merge_logic: "Implementation"
merge_logic -> segment_impact: "Affects segment\nplacement"