direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Section Merging Data Flow
  Three input object files → merged output with alignment padding
| {near: top-center}
row_inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_a: {
    direction: down
    label: "a.o"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    a_text: {
      shape: sql_table
      label: ".text (a.o)"
      f0: "0x00 | code | main()"
      f1: "0x10 | code | helper()"
      sz: "Size: 32 bytes\nAlign: 16"
    }
    a_data: {
      shape: sql_table
      label: ".data (a.o)"
      f0: "0x00 | int | counter"
      f1: "0x04 | int | flags"
      sz: "Size: 8 bytes\nAlign: 4"
    }
  }
  input_b: {
    direction: down
    label: "b.o"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    b_text: {
      shape: sql_table
      label: ".text (b.o)"
      f0: "0x00 | code | process()"
      f1: "0x20 | code | validate()"
      sz: "Size: 48 bytes\nAlign: 16"
    }
    b_data: {
      shape: sql_table
      label: ".data (b.o)"
      f0: "0x00 | char[64] | buffer"
      sz: "Size: 64 bytes\nAlign: 8"
    }
  }
  input_c: {
    direction: down
    label: "c.o"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    c_text: {
      shape: sql_table
      label: ".text (c.o)"
      f0: "0x00 | code | cleanup()"
      sz: "Size: 16 bytes\nAlign: 16"
    }
    c_rodata: {
      shape: sql_table
      label: ".rodata (c.o)"
      f0: "0x00 | char* | msg"
      sz: "Size: 24 bytes\nAlign: 8"
    }
  }
}
row_arrow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arrow_container: {
    style.fill: transparent
    style.stroke: transparent
    merge_label: "MERGE + ALIGN" {
      shape: text
      style.font-size: 20
      style.bold: true
      style.font-color: "#333"
    }
  }
}
row_output: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_text: {
    direction: down
    label: "Output .text"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    out_text_table: {
      shape: sql_table
      label: "Merged .text Section"
      a: "0x0000-0x001F | a.o/.text | 32 bytes"
      pad1: "0x0020-0x002F | PADDING | 16 bytes (align 16)"
      b: "0x0030-0x005F | b.o/.text | 48 bytes"
      c: "0x0060-0x006F | c.o/.text | 16 bytes"
      total: "Total: 112 bytes | vaddr: 0x401000"
    }
    mapping_text: {
      label: "Offset Mapping Table"
      shape: class
      +a_text: "(a.o, .text, 0x00) → 0x0000"
      +b_text: "(b.o, .text, 0x00) → 0x0030"
      +c_text: "(c.o, .text, 0x00) → 0x0060"
    }
  }
  output_data: {
    direction: down
    label: "Output .data/.rodata"
    style.fill: "#FFECB3"
    style.stroke: "#FF8F00"
    out_data_table: {
      shape: sql_table
      label: "Merged .data Section"
      a: "0x0000-0x0007 | a.o/.data | 8 bytes"
      pad1: "0x0008-0x000F | PADDING | 8 bytes (align 8)"
      b: "0x0010-0x004F | b.o/.data | 64 bytes"
      total: "Total: 80 bytes | vaddr: 0x402000"
    }
    out_rodata_table: {
      shape: sql_table
      label: "Merged .rodata Section"
      c: "0x0000-0x0017 | c.o/.rodata | 24 bytes"
      total: "Total: 24 bytes | vaddr: 0x403000"
    }
    mapping_data: {
      label: "Offset Mapping Table"
      shape: class
      +a_data: "(a.o, .data, 0x00) → 0x0000"
      +b_data: "(b.o, .data, 0x00) → 0x0010"
      +c_rodata: "(c.o, .rodata, 0x00) → 0x0000"
    }
  }
}
input_a.a_text -> output_text.out_text_table: "text | merge" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
}
input_b.b_text -> output_text.out_text_table: "text | merge" {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
input_c.c_text -> output_text.out_text_table: "text | merge" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
input_a.a_data -> output_data.out_data_table: "data | merge" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
}
input_b.b_data -> output_data.out_data_table: "data | merge" {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
input_c.c_rodata -> output_data.out_rodata_table: "rodata | merge" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#F5F5F5"
  style.stroke: "#999"
  style.border-radius: 8
  l1: "a.o" {style.fill: "#E8F4FD"}
  l2: "b.o" {style.fill: "#FFF3E0"}
  l3: "c.o" {style.fill: "#F3E5F5"}
  l4: "padding" {
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
    style.stroke-dash: 3
  }
}