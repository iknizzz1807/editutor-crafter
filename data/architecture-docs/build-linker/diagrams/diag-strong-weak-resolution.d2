direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_container: {
  style.stroke: transparent
  style.fill: transparent
  title: |md
    # Linker Symbol Resolution Logic
    ### Strong (STB_GLOBAL) vs Weak (STB_WEAK)
  |
}

flow_logic: {
  direction: down
  
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    start: {
      shape: oval
      label: "Symbol\nEncountered"
      style.fill: "#E8F5E9"
    }
  }

  row2: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    check_defined: {
      shape: diamond
      label: "Already in\nSymbol Table?"
      width: 160
      height: 100
      style.fill: "#FFF3E0"
    }
  }

  row3: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    check_new_type: {
      shape: diamond
      label: "Is New\nSTRONG?"
      width: 140
      height: 90
      style.fill: "#FFF3E0"
    }
    
    add_to_table: {
      shape: rectangle
      label: "Add to Table\n(STB_GLOBAL or WEAK)"
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
    }
  }

  row4: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    check_existing_type: {
      shape: diamond
      label: "Existing is\nSTRONG?"
      width: 140
      height: 90
      style.fill: "#FFF3E0"
    }
  }

  row5: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    collision_path: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      error_dup: "ERROR: Multiple Strong" {
        shape: rectangle
        style.fill: "#FFEBEE"
        style.stroke: "#D32F2F"
        style.font-color: "#C62828"
        style.bold: true
      }
      
      keep_existing: "KEEP: Existing Strong" {
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#388E3C"
      }
    }
  }

  row6: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    weak_path: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      override_weak: "OVERRIDE: Strong Wins" {
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#388E3C"
      }
      
      pick_first: "KEEP: First Weak" {
        shape: rectangle
        style.fill: "#FFF8E1"
        style.stroke: "#F57C00"
      }
    }
  }

  # Logic Connections
  start -> check_defined: "ELF Symbol"
  
  check_defined -> check_new_type: "No"
  check_new_type -> add_to_table: "Define"
  
  check_defined -> check_existing_type: "Yes"
  
  check_existing_type -> collision_path: "Yes"
  collision_path -> error_dup: "New is STRONG"
  collision_path -> keep_existing: "New is WEAK"
  
  check_existing_type -> weak_path: "No (Existing Weak)"
  weak_path -> override_weak: "New is STRONG"
  weak_path -> pick_first: "New is WEAK"
}

data_matrix: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  resolution_matrix: {
    shape: sql_table
    label: "Symbol Resolution Matrix"
    header: "Existing \\ New | New STRONG | New WEAK"
    r1: "STRONG | ERROR (STB_GLOBAL) | Keep Existing"
    r2: "WEAK | Override w/ Strong | Keep First Weak"
    r3: "UNDEF | Define Strong | Define Weak"
    note: "Linker Rule: Strong symbols always override weak ones."
  }
}

examples_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  ex_strong: {
    label: "Multiple Strong (Error)"
    code: |'c
      // a.c
      int x = 10; 
      // b.c
      int x = 20;
      // ld: duplicate symbol 'x'
    '|
  }
  
  ex_weak_override: {
    label: "Weak Override (Success)"
    code: |'c
      // libc.a (weak)
      void* malloc(size_t);
      // my_malloc.c (strong)
      void* malloc(size_t) { ... }
      // Result: My malloc used.
    '|
  }
  
  ex_dual_weak: {
    label: "Dual Weak (LIFO)"
    code: |'c
      // f1.c (weak)
      int y = 1;
      // f2.c (weak)
      int y = 2;
      // Result: y = 1 (first found)
    '|
  }
}

legend: {
  near: bottom-right
  strong: "STB_GLOBAL" {
    style.fill: "#4CAF50"
    style.font-color: white
  }
  weak: "STB_WEAK" {
    style.fill: "#FF9800"
    style.font-color: white
  }
}

# Horizontal positioning within rows
flow_logic.row1.start -> flow_logic.row2.check_defined
flow_logic.row5.collision_path.error_dup -> flow_logic.row5.collision_path.keep_existing: {style.stroke: transparent}
flow_logic.row6.weak_path.override_weak -> flow_logic.row6.weak_path.pick_first: {style.stroke: transparent}