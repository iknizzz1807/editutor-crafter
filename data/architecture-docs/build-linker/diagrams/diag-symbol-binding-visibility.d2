direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Symbol Binding & Visibility Matrix"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: {
  label: "Inter-File Resolution Rules in Symbol Table"
  near: top-center
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}
grid-rows: 5
grid-columns: 5
grid-gap: 0
classes: {
  header: {
    style: {
      fill: "#2C3E50"
      font-color: white
      bold: true
      font-size: 14
      stroke: "#1A252F"
      stroke-width: 2
    }
  }
  binding_header: {
    style: {
      fill: "#34495E"
      font-color: white
      bold: true
      font-size: 13
      stroke: "#2C3E50"
    }
  }
  local_row: {
    style: {
      fill: "#ECF0F1"
      font-size: 12
      stroke: "#BDC3C7"
    }
  }
  global_row: {
    style: {
      fill: "#E8F6F3"
      font-size: 12
      stroke: "#A3E4D7"
    }
  }
  weak_row: {
    style: {
      fill: "#FEF9E7"
      font-size: 12
      stroke: "#F9E79F"
    }
  }
  yes_cell: {
    style: {
      fill: "#D5F5E3"
      font-color: "#1E8449"
      bold: true
      font-size: 12
      stroke: "#82E0AA"
    }
  }
  no_cell: {
    style: {
      fill: "#FADBD8"
      font-color: "#922B21"
      bold: true
      font-size: 12
      stroke: "#F1948A"
    }
  }
  partial_cell: {
    style: {
      fill: "#FCF3CF"
      font-color: "#9A7D0A"
      bold: true
      font-size: 12
      stroke: "#F7DC6F"
    }
  }
}
corner: "" {
  class: header
  style.fill: "#1A252F"
}
h_default: "STV_DEFAULT\n(0)" {
  class: header
  tooltip: "Normal visibility, visible to all"
}
h_internal: "STV_INTERNAL\n(1)" {
  class: header
  tooltip: "Hidden outside defining module"
}
h_hidden: "STV_HIDDEN\n(2)" {
  class: header
  tooltip: "Not visible outside defining module"
}
h_protected: "STV_PROTECTED\n(3)" {
  class: header
  tooltip: "Visible but cannot be preempted"
}
b_local: "STB_LOCAL\n(0)" {
  class: binding_header
  tooltip: "File-local symbol, static linkage"
}
b_global: "STB_GLOBAL\n(1)" {
  class: binding_header
  tooltip: "Strong global symbol, visible externally"
}
b_weak: "STB_WEAK\n(2)" {
  class: binding_header
  tooltip: "Weak symbol, can be overridden"
}
cell_local_default: "NO\n\nStatic only" {
  class: no_cell
  tooltip: "LOCAL symbols never participate in inter-file resolution regardless of visibility"
}
cell_local_internal: "NO\n\nStatic only" {
  class: no_cell
  tooltip: "LOCAL symbols never participate in inter-file resolution regardless of visibility"
}
cell_local_hidden: "NO\n\nStatic only" {
  class: no_cell
  tooltip: "LOCAL symbols never participate in inter-file resolution regardless of visibility"
}
cell_local_protected: "NO\n\nStatic only" {
  class: no_cell
  tooltip: "LOCAL symbols never participate in inter-file resolution regardless of visibility"
}
cell_global_default: "YES\n\nFull export" {
  class: yes_cell
  tooltip: "GLOBAL + DEFAULT = standard external linkage, participates in resolution"
}
cell_global_internal: "NO\n\nHidden" {
  class: no_cell
  tooltip: "INTERNAL overrides GLOBAL binding for visibility"
}
cell_global_hidden: "NO\n\nHidden" {
  class: no_cell
  tooltip: "HIDDEN overrides GLOBAL binding for visibility"
}
cell_global_protected: "PARTIAL\n\nNo preemption" {
  class: partial_cell
  tooltip: "Visible externally but cannot be interposed by another definition"
}
cell_weak_default: "YES\n\nFallback" {
  class: yes_cell
  tooltip: "WEAK + DEFAULT = participates but can be overridden by strong GLOBAL"
}
cell_weak_internal: "NO\n\nHidden" {
  class: no_cell
  tooltip: "INTERNAL overrides WEAK binding for visibility"
}
cell_weak_hidden: "NO\n\nHidden" {
  class: no_cell
  tooltip: "HIDDEN overrides WEAK binding for visibility"
}
cell_weak_protected: "PARTIAL\n\nNo preemption" {
  class: partial_cell
  tooltip: "Visible as fallback, cannot be interposed"
}
legend_container: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  legend_title: "Legend" {
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
  legend_yes: "YES = Participates in inter-file resolution" {
    class: yes_cell
  }
  legend_no: "NO = File-local only, never exported" {
    class: no_cell
  }
  legend_partial: "PARTIAL = Visible but protected from interposition" {
    class: partial_cell
  }
}
legend_container.near: bottom-center
binding_rules: {
  label: "Binding Resolution Rules"
  direction: down
  rule1: {
    label: "1. STB_LOCAL → Never exported"
    width: 400
    code: |'c
      // Static functions/variables stay file-local
      static int counter = 0;
      static void helper(void) { ... }
      // Visibility flags have NO effect on LOCAL symbols
    '|
  }
  rule2: {
    label: "2. STB_GLOBAL + STV_DEFAULT → Standard export"
    width: 400
    code: |'c
      // Normal external linkage
      int global_var = 42;
      void exported_func(void) { ... }
      // Participates fully in inter-file resolution
    '|
  }
  rule3: {
    label: "3. STB_WEAK + STV_DEFAULT → Conditional export"
    width: 400
    code: |'c
      // Weak definition (fallback if no strong)
      __attribute__((weak)) void hook(void) { }
      // Overridden by strong GLOBAL with same name
    '|
  }
  rule4: {
    label: "4. STV_HIDDEN/INTERNAL → Force local visibility"
    width: 400
    code: |'c
      // HIDDEN forces symbol to be file-local
      __attribute__((visibility("hidden")))
      int internal_state = 0;
      // Even GLOBAL binding becomes non-exported
    '|
  }
  rule5: {
    label: "5. STV_PROTECTED → Export without preemption"
    width: 400
    code: |'c
      // Visible but cannot be interposed by LD_PRELOAD
      __attribute__((visibility("protected")))
      void critical_path(void) { ... }
      // Ensures this definition is always used
    '|
  }
}
resolution_flow: {
  label: "Inter-File Resolution Decision"
  direction: down
  start: {
    shape: oval
    label: "Symbol encountered\nin object file"
  }
  check_binding: {
    shape: diamond
    label: "STB_LOCAL?"
  }
  skip_local: {
    shape: rectangle
    label: "Skip: never participates\nin inter-file resolution"
    style.fill: "#FADBD8"
  }
  check_visibility: {
    shape: diamond
    label: "STV_DEFAULT or\nSTV_PROTECTED?"
  }
  check_weak: {
    shape: diamond
    label: "STB_WEAK?"
  }
  strong_global: {
    shape: rectangle
    label: "Strong definition:\nOverrides any WEAK,\nerror if duplicate GLOBAL"
    style.fill: "#D5F5E3"
  }
  weak_global: {
    shape: rectangle
    label: "Weak definition:\nFallback only, overridden\nby strong GLOBAL"
    style.fill: "#FCF3CF"
  }
  skip_hidden: {
    shape: rectangle
    label: "Skip: visibility overrides binding"
    style.fill: "#FADBD8"
  }
  start -> check_binding
  check_binding -> skip_local: "Yes" {
    style.stroke: "#E74C3C"
  }
  check_binding -> check_visibility: "No" {
    style.stroke: "#27AE60"
  }
  check_visibility -> skip_hidden: "No (HIDDEN/INTERNAL)" {
    style.stroke: "#E74C3C"
  }
  check_visibility -> check_weak: "Yes" {
    style.stroke: "#27AE60"
  }
  check_weak -> weak_global: "Yes" {
    style.stroke: "#F39C12"
  }
  check_weak -> strong_global: "No (GLOBAL)" {
    style.stroke: "#27AE60"
  }
}
visibility_detail: {
  label: "Visibility Levels (st_other field)"
  shape: sql_table
  v0: "STV_DEFAULT (0) | Normal external visibility | Can be preempted"
  v1: "STV_INTERNAL (1) | Hidden outside module | Similar to HIDDEN"
  v2: "STV_HIDDEN (2) | Not in dynamic symtab | Force local scope"
  v3: "STV_PROTECTED (3) | Visible externally | No interposition"
  note: "Visibility is orthogonal to binding but can restrict export"
}