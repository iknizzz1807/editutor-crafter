direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # ELF64 Symbol Table Entry Structure
  `struct Elf64_Sym` — 24 bytes total
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  st_name: {
    shape: sql_table
    label: "st_name (Elf64_Sym +0x00)"
    f0: "0x00 | uint32_t | string table index"
    f1: "0x04 | — | —"
    desc: "Offset into .strtab where symbol name is stored"
    size: "4 bytes"
  }
  st_info: {
    shape: sql_table
    label: "st_info (Elf64_Sym +0x04)"
    f0: "0x04 | uint8_t | type + binding"
    f1: "High 4 bits: STB_* (binding)"
    f2: "Low 4 bits: STT_* (type)"
    size: "1 byte"
  }
  st_other: {
    shape: sql_table
    label: "st_other (Elf64_Sym +0x05)"
    f0: "0x05 | uint8_t | visibility"
    f1: "Usually 0 (STV_DEFAULT)"
    size: "1 byte"
  }
  st_shndx: {
    shape: sql_table
    label: "st_shndx (Elf64_Sym +0x06)"
    f0: "0x06 | uint16_t | section index"
    f1: "SHN_UNDEF=0, SHN_ABS=0xFFF1"
    f2: "SHN_COMMON=0xFFF2"
    size: "2 bytes"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  st_value: {
    shape: sql_table
    label: "st_value (Elf64_Sym +0x08)"
    f0: "0x08 | uint64_t | value / address"
    f1: "Object file: section offset"
    f2: "Executable: virtual address"
    f3: "Undefined: 0"
    size: "8 bytes"
  }
  st_size: {
    shape: sql_table
    label: "st_size (Elf64_Sym +0x10)"
    f0: "0x10 | uint64_t | symbol size"
    f1: "Function: code bytes"
    f2: "Variable: data bytes"
    f3: "Unknown: 0"
    size: "8 bytes"
  }
}
row1.st_name -> row2.st_value: "offsets continue"
legend: {
  near: bottom-center
  label: "Field Relationships"
  direction: right
  binding_types: {
    label: "st_info Binding (STB_*)"
    shape: rectangle
    code: |'c
      STB_LOCAL  = 0  // File-private
      STB_GLOBAL = 1  // Visible externally
      STB_WEAK   = 2  // Low priority
    '|
  }
  symbol_types: {
    label: "st_info Type (STT_*)"
    shape: rectangle
    code: |'c
      STT_NOTYPE  = 0  // Unspecified
      STT_OBJECT  = 1  // Data variable
      STT_FUNC    = 2  // Function
      STT_SECTION = 3  // Section symbol
      STT_FILE    = 4  // Source file
    '|
  }
  section_indices: {
    label: "st_shndx Special Values"
    shape: rectangle
    code: |'c
      SHN_UNDEF  = 0      // Undefined
      SHN_ABS    = 0xFFF1 // Absolute
      SHN_COMMON = 0xFFF2 // Common
    '|
  }
}
memory_layout: {
  label: "Memory Layout (24 bytes, little-endian)"
  bytes_00_03: {
    shape: rectangle
    label: "Bytes 0-3\nst_name"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
  }
  bytes_04: {
    shape: rectangle
    label: "Byte 4\nst_info"
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
  }
  bytes_05: {
    shape: rectangle
    label: "Byte 5\nst_other"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
  bytes_06_07: {
    shape: rectangle
    label: "Bytes 6-7\nst_shndx"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  bytes_08_0F: {
    shape: rectangle
    label: "Bytes 8-15\nst_value"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
  bytes_10_17: {
    shape: rectangle
    label: "Bytes 16-23\nst_size"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
}
example: {
  label: "Example: Symbol 'helper' in utils.o"
  example_table: {
    shape: sql_table
    label: "Elf64_Sym for 'helper'"
    name: "st_name = 0x15 → .strtab+0x15 = 'helper\\0'"
    info: "st_info = 0x12 → STB_GLOBAL | STT_FUNC"
    other: "st_other = 0x00 → STV_DEFAULT"
    shndx: "st_shndx = 1 → .text section"
    value: "st_value = 0x0000 → offset 0 in .text"
    size: "st_size = 0x0020 → 32 bytes of code"
  }
  note: |md
    The symbol `helper` is a **global function** defined at
    offset 0x00 in section 1 (.text), with a size of 32 bytes.
    Its name string "helper" is stored at offset 0x15 in .strtab.
  |
}