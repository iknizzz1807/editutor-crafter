direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Trace Example: Linking main.c and utils.c
  Complete walkthrough of all 4 milestones with actual values
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  source_files: {
    direction: down
    label: "Source Files"
    main_c: {
      label: "main.c"
      width: 280
      code: |'c
        extern void helper(void);
        int main() {
            helper();
            return 0;
        }
      '|
    }
    utils_c: {
      label: "utils.c"
      width: 280
      code: |'c
        void helper(void) {
            // implementation
        }
      '|
    }
  }
  compiler_box: {
    direction: down
    label: "Compilation"
    gcc: {
      shape: rectangle
      label: "gcc -c main.c utils.c"
      width: 200
    }
    object_files: {
      direction: right
      label: "Object Files"
      main_o: {
        label: "main.o"
        shape: cylinder
      }
      utils_o: {
        label: "utils.o"
        shape: cylinder
      }
    }
  }
}
row1.source_files -> row1.compiler_box.gcc: "compile"
row1.compiler_box.gcc -> row1.compiler_box.object_files
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m1: {
    direction: down
    label: "MILESTONE 1: Section Merging"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    main_o_sections: {
      shape: class
      label: "main.o Sections"
      -text_size: "13 bytes"
      -text_align: "16"
      -text_offset: "0x0"
    }
    utils_o_sections: {
      shape: class
      label: "utils.o Sections"
      -text_size: "12 bytes"
      -text_align: "16"
      -text_offset: "0x0"
    }
    merge_op: {
      label: "MERGE"
      shape: diamond
      width: 80
    }
    output_text: {
      shape: sql_table
      label: "Output .text Section"
      row1: "0x00 | main.o/.text | 13 bytes"
      row2: "0x10 | padding      | 3 bytes"
      row3: "0x13 | utils.o/.text | 12 bytes"
      row4: "Total: 28 bytes (0x1C)"
    }
    mapping: {
      shape: sql_table
      label: "Section Mapping Table"
      row1: "main.o/.text+0  | out .text+0x00"
      row2: "utils.o/.text+0 | out .text+0x13"
    }
    main_o_sections -> merge_op
    utils_o_sections -> merge_op
    merge_op -> output_text
    output_text -> mapping
  }
  m2: {
    direction: down
    label: "MILESTONE 2: Symbol Resolution"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    main_syms: {
      shape: sql_table
      label: "main.o Symbols (.symtab)"
      row1: "[0] | (null)    | LOCAL  | UNDEF"
      row2: "[1] | main.c    | LOCAL  | FILE"
      row3: "[2] | .text     | LOCAL  | SEC:1"
      row4: "[3] | main      | GLOBAL | .text+0x0 | size=13"
      row5: "[4] | helper    | GLOBAL | UNDEF (ref)"
    }
    utils_syms: {
      shape: sql_table
      label: "utils.o Symbols (.symtab)"
      row1: "[0] | (null)    | LOCAL  | UNDEF"
      row2: "[1] | utils.c   | LOCAL  | FILE"
      row3: "[2] | .text     | LOCAL  | SEC:1"
      row4: "[3] | helper    | GLOBAL | .text+0x0 | size=12"
    }
    resolve_op: {
      label: "RESOLVE"
      shape: diamond
      width: 80
    }
    global_symtab: {
      shape: sql_table
      label: "Global Symbol Table"
      row1: "main   | 0x401000 | DEFINED | strong"
      row2: "helper | 0x401013 | DEFINED | strong"
      note: "helper: ref from main.o, def in utils.o"
    }
    main_syms -> resolve_op
    utils_syms -> resolve_op
    resolve_op -> global_symtab
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m3: {
    direction: down
    label: "MILESTONE 3: Relocation Processing"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    main_o_disasm: {
      label: "main.o Disassembly (before)"
      width: 320
      code: |'asm
        0000 <main>:
           0: 55                push   rbp
           1: 48 89 e5          mov    rbp,rsp
           4: e8 00 00 00 00    call   9 <main+0x9>
           9: 31 c0             xor    eax,eax
           b: 5d                pop    rbp
           c: c3                ret
      '|
    }
    reloc_entry: {
      shape: sql_table
      label: "Relocation Entry (main.o)"
      row1: "r_offset  | 0x5"
      row2: "r_info    | sym=4, type=R_X86_64_PC32"
      row3: "r_addend  | -4"
      row4: "Target    | symbol 'helper'"
    }
    calc_box: {
      label: "PC-Relative Calculation"
      width: 340
      code: |'text
        site_vaddr    = 0x401000 + 0x5 = 0x401005
        symbol_vaddr  = 0x401013 (helper)
        addend        = -4
        computed = symbol + addend - site
                = 0x401013 + (-4) - 0x401005
                = 0x0000000A (10 bytes forward)
      '|
    }
    patched_disasm: {
      label: "Patched Disassembly (after)"
      width: 340
      code: |'asm
        00401000 <main>:
           401000: 55                push   rbp
           401001: 48 89 e5          mov    rbp,rsp
           401004: e8 0a 00 00 00    call   401013 <helper>
           401009: 31 c0             xor    eax,eax
           40100b: 5d                pop    rbp
           40100c: c3                ret
      '|
    }
    main_o_disasm -> reloc_entry
    reloc_entry -> calc_box
    calc_box -> patched_disasm
  }
  m4: {
    direction: down
    label: "MILESTONE 4: Executable Generation"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    elf_header: {
      shape: sql_table
      label: "ELF Header (64 bytes)"
      row1: "e_ident[0-3] | 7F 45 4C 46 (magic)"
      row2: "e_ident[4]   | 02 (ELFCLASS64)"
      row3: "e_ident[5]   | 01 (ELFDATA2LSB)"
      row4: "e_type       | 02 (ET_EXEC)"
      row5: "e_machine    | 3E (EM_X86_64)"
      row6: "e_entry      | 00 10 40 00 (0x401000)"
      row7: "e_phoff      | 40 (64 bytes)"
      row8: "e_phnum      | 01 (1 segment)"
    }
    prog_header: {
      shape: sql_table
      label: "Program Header (56 bytes)"
      row1: "p_type   | 01 (PT_LOAD)"
      row2: "p_flags  | 05 (PF_R | PF_X)"
      row3: "p_offset | 00 10 00 00 (0x1000)"
      row4: "p_vaddr  | 00 10 40 00 (0x401000)"
      row5: "p_filesz | 1C 00 00 00 (28 bytes)"
      row6: "p_memsz  | 1C 00 00 00 (28 bytes)"
      row7: "p_align  | 00 10 00 00 (0x1000)"
    }
    file_layout: {
      shape: class
      label: "Final File Layout"
      -offset_0x0000: "ELF Header (64 bytes)"
      -offset_0x0040: "Program Header (56 bytes)"
      -offset_0x0078: "Padding (3928 bytes)"
      -offset_0x1000: ".text content (28 bytes)"
      -total: "4124 bytes"
    }
    elf_header -> prog_header
    prog_header -> file_layout
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  verification: {
    direction: down
    label: "Verification"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    verify_commands: {
      label: "Terminal Verification"
      width: 380
      code: |'bash
        $ ./mylinker main.o utils.o -o program
        Parsing main.o...
        Parsing utils.o...
        Merging sections...
        Resolving symbols...
        Processing relocations...
        Writing executable...
        Entry point: 0x401000 (main)
        Wrote executable: program (4124 bytes)
        $ chmod +x program
        $ ./program; echo $?
        0
      '|
    }
    verify_tools: {
      label: "Inspection Tools"
      width: 380
      code: |'bash
        $ file program
        ELF 64-bit LSB executable, x86-64
        $ readelf -h program | grep Entry
        Entry point address: 0x401000
        $ objdump -d program
        0000000000401000 <main>:
          401000: 55                   push   rbp
          401001: 48 89 e5             mov    rbp,rsp
          401004: e8 0a 00 00 00       call   401013
          ...
      '|
    }
    verify_commands -> verify_tools
  }
  dataflow: {
    direction: down
    label: "Data Flow Summary"
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    flow: {
      shape: class
      label: "Information Flow Between Milestones"
      -m1_output: "Section mapping: input→output offsets"
      -m2_needs: "Mapping to compute symbol addresses"
      -m2_output: "Global symbol table with final addrs"
      -m3_needs: "Symbol addrs to compute relocation values"
      -m3_output: "Patched section data with resolved refs"
      -m4_needs: "Patched data + entry point symbol"
      -m4_output: "Valid ELF executable file"
    }
  }
}
row2.m1 -> row2.m2: "mapping table" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
row2.m2 -> row3.m3: "symbol addresses" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
}
row3.m3 -> row3.m4: "patched sections" {
  style.stroke: "#FF9800"
  style.stroke-width: 3
}
row3.m4 -> row4.verification: "executable" {
  style.stroke: "#9C27B0"
  style.stroke-width: 3
}
row2.m2 -> row3.m4: "e_entry lookup" {
  style.stroke: "#2196F3"
  style.stroke-dash: 4
}
legend: {
  near: bottom-right
  label: "Color Legend"
  m1_color: {
    shape: rectangle
    label: "M1: Section Merge"
    style.fill: "#E8F5E9"
  }
  m2_color: {
    shape: rectangle
    label: "M2: Symbol Resolution"
    style.fill: "#E3F2FD"
  }
  m3_color: {
    shape: rectangle
    label: "M3: Relocation Processing"
    style.fill: "#FFF3E0"
  }
  m4_color: {
    shape: rectangle
    label: "M4: Executable Generation"
    style.fill: "#F3E5F5"
  }
}