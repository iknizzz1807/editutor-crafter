direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Undefined Symbol Detection Flow (Milestone 2)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
legend: {
  near: bottom-right
  style.fill: "#f5f5f5"
  style.stroke: "#cccccc"
  label: "Legend"
  l1: {
    shape: text
    label: |md
      **Colors:**
      • Green = Definition found
      • Red = Error state
      • Yellow = Pending state
      • Blue = Data collection
    |
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase1: {
    direction: down
    label: "Phase 1: Symbol Collection"
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    start: {
      shape: oval
      label: "Start"
      style.fill: "#4caf50"
      style.font-color: white
    }
    parse_obj: {
      label: "Parse Object File"
      width: 200
      code: |'c
        for each input .o file:
          read .symtab section
          extract all symbols
      '|
    }
    classify: {
      shape: diamond
      label: "Symbol\nType?"
      width: 120
    }
    local_sym: {
      label: "Record Local Symbol\n(private to file)"
      style.fill: "#c8e6c9"
    }
    global_def: {
      label: "Add to Global Table\nstate = DEFINED\nis_strong = (binding==GLOBAL)"
      style.fill: "#c8e6c9"
    }
    undef_ref: {
      label: "Add to Global Table\nstate = UNDEF\nref_count++"
      style.fill: "#fff9c4"
    }
    common_sym: {
      label: "Handle COMMON\nmerge by largest size"
      style.fill: "#c8e6c9"
    }
    more_files: {
      shape: diamond
      label: "More\nFiles?"
      width: 100
    }
    start -> parse_obj: "begin"
    parse_obj -> classify: "each symbol"
    classify -> local_sym: "STB_LOCAL"
    classify -> global_def: "STB_GLOBAL\ndefined"
    classify -> undef_ref: "SHN_UNDEF"
    classify -> common_sym: "SHN_COMMON"
    local_sym -> more_files
    global_def -> more_files
    undef_ref -> more_files
    common_sym -> more_files
    more_files -> parse_obj: "yes"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase2: {
    direction: down
    label: "Phase 2: Resolution Check"
    style.fill: "#fff3e0"
    style.stroke: "#f57c00"
    scan_table: {
      label: "Scan Global\nSymbol Table"
      width: 180
    }
    check_state: {
      shape: diamond
      label: "State =\nUNDEF?"
      width: 120
    }
    check_binding: {
      shape: diamond
      label: "Binding =\nWEAK?"
      width: 120
    }
    resolve_zero: {
      label: "Resolve to 0\nstate = RESOLVED\n(weak undefined OK)"
      style.fill: "#c8e6c9"
    }
    gen_error: {
      label: "Generate Error"
      style.fill: "#ffcdd2"
      width: 220
    }
    error_details: {
      label: "Error Information"
      shape: class
      +symbol_name: "char[64]"
      +ref_count: "int"
      +referencing_files: "char**"
      +suggestions: "char**"
    }
    next_sym: {
      shape: diamond
      label: "More\nSymbols?"
      width: 100
    }
    all_done: {
      shape: oval
      label: "All Symbols\nResolved"
      style.fill: "#4caf50"
      style.font-color: white
    }
    link_fail: {
      shape: oval
      label: "Link Failed"
      style.fill: "#f44336"
      style.font-color: white
    }
    scan_table -> check_state
    check_state -> check_binding: "yes"
    check_state -> next_sym: "no\n(defined)"
    check_binding -> resolve_zero: "yes"
    check_binding -> gen_error: "no\n(strong undef)"
    gen_error -> error_details: "collect info"
    error_details -> link_fail
    resolve_zero -> next_sym
    next_sym -> scan_table: "yes"
    next_sym -> all_done: "no"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase3: {
    direction: down
    label: "Phase 3: Error Reporting"
    style.fill: "#ffebee"
    style.stroke: "#c62828"
    err_example: {
      label: "Error Output Format"
      width: 380
      code: |'text
        ld: error: undefined symbol 'missing_func'
        >>> referenced by main.o
        >>>   main.c:15 (in function 'run')
        >>> referenced by utils.o
        >>>   utils.c:42 (in function 'process')
        >>> did you mean: helper_func, missing_func2?
      '|
      style.fill: "#fff8e1"
    }
    ref_tracking: {
      label: "Reference Tracking\n(why we track ref_count)"
      shape: class
      +ref_count: "int — how many files reference"
      +source_file_idx: "int — first reference source"
      +all_references: "RelocInfo[] — all call sites"
    }
    suggest: {
      label: "Suggestion Algorithm"
      width: 280
      code: |'c
        // Find similar symbol names
        for each defined symbol:
          if (levenshtein(name, undef) < threshold)
            add to suggestions
        show top 3 matches
      '|
    }
    err_example -> ref_tracking
    ref_tracking -> suggest
  }
}
phase1.more_files -> phase2.scan_table: "no\nall files\nprocessed" {
  style.stroke: "#1976d2"
  style.stroke-width: 3
}
data_structures: {
  direction: right
  label: "Key Data Structures"
  global_sym_struct: {
    shape: sql_table
    label: "GlobalSymbol (linker.h)"
    f0: "0x00 | char[64]      | name"
    f1: "0x40 | SymbolState   | state"
    f2: "0x44 | uint8_t       | binding"
    f3: "0x45 | uint8_t       | is_strong"
    f4: "0x48 | int           | ref_count"
    f5: "0x4C | int           | source_file_idx"
    f6: "0x50 | uint64_t      | final_address"
    sz: "Total: ~88 bytes"
  }
  sym_state_enum: {
    shape: sql_table
    label: "SymbolState (enum)"
    s0: "0 | SYM_UNDEF    | referenced, not defined"
    s1: "1 | SYM_DEFINED  | has definition"
    s2: "2 | SYM_COMMON   | tentative (merge needed)"
    s3: "3 | SYM_RESOLVED | final address assigned"
  }
  binding_enum: {
    shape: sql_table
    label: "Symbol Binding (st_info)"
    b0: "0 | STB_LOCAL  | file-private"
    b1: "1 | STB_GLOBAL | visible to all"
    b2: "2 | STB_WEAK   | fallback definition"
  }
}
flow_notes: {
  label: "Critical Points"
  n1: {
    label: |md
      **1. Collection Order Matters**
      Process all definitions before checking for undefined symbols.
      An undefined symbol in file A might be defined in file B.
    |
  }
  n2: {
    label: |md
      **2. Weak Undefined = OK**
      Weak undefined symbols resolve to address 0.
      Code can check `if (&symbol)` for availability.
    |
  }
  n3: {
    label: |md
      **3. Reference Tracking**
      `ref_count` enables "defined but unused" warnings
      and provides context for undefined symbol errors.
    |
  }
}
phase1.classify.style.fill: "#bbdefb"
phase2.check_state.style.fill: "#ffe0b2"
phase2.check_binding.style.fill: "#ffe0b2"
phase2.gen_error.style.fill: "#ffcdd2"
phase3.err_example.style.fill: "#fff8e1"