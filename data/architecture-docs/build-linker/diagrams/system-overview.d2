direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

# --- ROW 1: FRONTEND & MERGING ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_m1: {
    direction: down
    label: "MILESTONE 1: Section Merging [M1]"

    elf_ehdr: {
      shape: sql_table
      label: "struct Elf64_Ehdr (01_elf_types.h)"
      e_ident: "uint8_t[16] | +0x00: Magic, Class, Data"
      e_type: "uint16_t   | +0x10: ET_REL=1"
      e_machine: "uint16_t   | +0x12: EM_X86_64=62"
      e_shoff: "uint64_t   | +0x28: Section header offset"
      e_shnum: "uint16_t   | +0x3C: Section count"
      e_shstrndx: "uint16_t   | +0x3E: String table index"
      sz: "Total: 64 bytes (1 cache line)"
    }

    elf_shdr: {
      shape: sql_table
      label: "struct Elf64_Shdr (01_elf_types.h)"
      sh_name: "uint32_t | +0x00: Name index"
      sh_type: "uint32_t | +0x04: SHT_PROGBITS=1"
      sh_flags: "uint64_t | +0x08: SHF_ALLOC=0x2"
      sh_addr: "uint64_t | +0x10: Target vaddr"
      sh_offset: "uint64_t | +0x18: File offset"
      sh_size: "uint64_t | +0x20: Section size"
      sh_addralign: "uint64_t | +0x30: Alignment"
      sz: "Total: 64 bytes"
    }

    parser: {
      shape: class
      label: "ELF Parser (03_elf_parser.c)"
      +parse_object_file(path, out): "int"
      -read_headers(f, obj): "int"
      -validate_magic(ehdr): "bool"
      -load_sections(f, obj): "int"
    }

    merger: {
      shape: class
      label: "Section Merger (06_section_merger.c)"
      +linker_merge_sections(ctx): "int"
      +linker_assign_vaddrs(ctx): "int"
      -calc_padding(curr, align): "uint64_t"
      -get_output_sec(ctx, name): "OutputSection*"
    }
  }

  layer_m2: {
    direction: down
    label: "MILESTONE 2: Symbol Resolution [M2]"

    elf_sym: {
      shape: sql_table
      label: "struct Elf64_Sym (11_symbol_types.h)"
      st_name: "uint32_t | +0x00: Name index"
      st_info: "uint8_t  | +0x04: Bind + Type"
      st_shndx: "uint16_t | +0x06: Section index"
      st_value: "uint64_t | +0x08: Offset/Addr"
      st_size: "uint64_t | +0x10: Symbol size"
      sz: "Total: 24 bytes"
    }

    global_sym: {
      shape: sql_table
      label: "struct GlobalSymbol (11_symbol_types.h)"
      name: "char*    | Symbol name"
      state: "SymState | UNDEF, DEFINED"
      vaddr: "uint64_t | Resolved address"
      is_weak: "bool    | STB_WEAK flag"
      src_obj: "ObjectFile* | Def source"
      sz: "Total: ~48 bytes"
    }

    resolver: {
      shape: class
      label: "Symbol Resolver (17_symbol_resolver.c)"
      +collect_symbols(ctx): "int"
      +resolve_all(ctx): "int"
      -handle_conflict(sym, new): "void"
      -match_undefs(ctx): "int"
    }
  }
}

# --- ROW 2: RELOCATION & OUTPUT ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_m3: {
    direction: down
    label: "MILESTONE 3: Relocation Processing [M3]"

    elf_rela: {
      shape: sql_table
      label: "struct Elf64_Rela (21_relocation_types.h)"
      r_off: "uint64_t | +0x00: Site offset"
      r_info: "uint64_t | +0x08: Sym + Type"
      r_add: "int64_t  | +0x10: Addend"
      sz: "Total: 24 bytes"
    }

    patch_calc: {
      shape: class
      label: "Patch Calculator (27_patch_calculator.c)"
      +calc_64(S, A): "uint64_t"
      +calc_pc32(S, A, P): "int32_t"
      +calc_32(S, A): "uint32_t"
      -check_overflow(val, sz): "bool"
    }

    patch_writer: {
      shape: class
      label: "Patch Writer (29_patch_writer.c)"
      +apply_reloc(buf, rela, sym_addr, site_vaddr): "int"
      -write_32(buf, off, val): "void"
      -write_64(buf, off, val): "void"
    }
  }

  layer_m4: {
    direction: down
    label: "MILESTONE 4: Executable Generation [M4]"

    elf_phdr: {
      shape: sql_table
      label: "struct Elf64_Phdr (33_elf_exec_types.h)"
      p_type: "uint32_t | +0x00: PT_LOAD=1"
      p_flags: "uint32_t | +0x04: PF_R|PF_W|PF_X"
      p_offset: "uint64_t | +0x08: File offset"
      p_vaddr: "uint64_t | +0x10: Virtual address"
      p_filesz: "uint64_t | +0x20: Size in file"
      p_memsz: "uint64_t | +0x28: Size in memory"
      p_align: "uint64_t | +0x30: 0x1000 (Page)"
      sz: "Total: 56 bytes"
    }

    exec_writer: {
      shape: class
      label: "Executable Writer (43_exec_writer.c)"
      +write_elf_binary(path, ctx): "int"
      -build_phdrs(ctx, phdrs): "void"
      -write_load_segments(f, ctx): "int"
      -finalize_header(ehdr, ctx): "void"
    }
  }
}

# --- ROW 3: CONTEXT & PIPELINE ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  context_layer: {
    direction: down
    label: "GLOBAL STATE"

    linker_ctx: {
      shape: sql_table
      label: "struct LinkerContext (09_linker_context.h)"
      objs: "ObjectFile** | Input list"
      obj_count: "int         | Count"
      out_secs: "OutputSection* | Merged list"
      sym_tab: "HashTable*    | Global symbols"
      out_buf: "uint8_t*      | Binary buffer"
      vaddr_base: "uint64_t   | 0x400000"
      sz: "Total: ~128 bytes"
    }
  }

  pipeline: {
    shape: class
    label: "Linker Pipeline (main.c)"
    +main(argc, argv): "int"
    -step1_parse(): "void"
    -step2_merge(): "void"
    -step3_resolve(): "void"
    -step4_relocate(): "void"
    -step5_emit(): "void"
  }
}

# --- CONNECTIONS ---
row1.layer_m1.parser -> row3.context_layer.linker_ctx: "Populates"
row1.layer_m1.merger -> row1.layer_m1.elf_shdr: "Merges"
row1.layer_m2.resolver -> row1.layer_m2.global_sym: "Resolves"
row2.layer_m3.patch_writer -> row2.layer_m3.patch_calc: "Uses"
row2.layer_m3.patch_writer -> row3.context_layer.linker_ctx: "Patches out_buf"
row2.layer_m4.exec_writer -> row2.layer_m4.elf_phdr: "Writes"

row3.pipeline -> row1.layer_m1.parser: "Phase 1"
row3.pipeline -> row1.layer_m1.merger: "Phase 2"
row3.pipeline -> row1.layer_m2.resolver: "Phase 3"
row3.pipeline -> row2.layer_m3.patch_writer: "Phase 4"
row3.pipeline -> row2.layer_m4.exec_writer: "Phase 5"

# --- MILESTONE INDEX ---
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | Section Merging | Elf64_Shdr, merge, assign vaddrs"
  m2: "M2 | Symbol Resolution | GlobalSymbolTable, resolve undefs"
  m3: "M3 | Relocation | Elf64_Rela, calculate S+A-P, patch buffer"
  m4: "M4 | Generation | Elf64_Phdr, PT_LOAD, entry point, write ELF"
}