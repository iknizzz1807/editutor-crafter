vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Section Merging Module Architecture
  *ELF Object File → Parsed Sections → Merged Output*
| {near: top-center}
direction: right
# ============================================================================
# INPUT LAYER: Object File Parsing
# ============================================================================
ObjectFile: {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  header: |md
    **ObjectFile**
    `04_section_types.h`
  |
  fields: {
    shape: class
    +filename: "char[256]"
    +ehdr: "Elf64_Ehdr"
    +sections: "InputSection*"
    +section_count: "uint16_t"
    +shstrtab: "char*"
  }
  methods: {
    shape: class
    style.fill: "#FFF3E0"
    parse_object_file(): ParseError
    object_file_destroy(): void
    parse_symbols(): SymbolError
    parse_relocations(): RelocError
  }
}
InputSection: {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  header: |md
    **InputSection**
    `04_section_types.h`
  |
  fields: {
    shape: class
    +name: "char[64]"
    +type: "uint32_t"
    +flags: "uint64_t"
    +align: "uint64_t"
    +size: "uint64_t"
    +file_offset: "uint64_t"
    +data: "uint8_t*"
    +original_index: "uint32_t"
  }
  type_info: |md
    **Section Types**
    - SHT_PROGBITS (1): .text, .data, .rodata
    - SHT_NOBITS (8): .bss (no file data)
    - SHT_SYMTAB (2): Symbol table
    - SHT_STRTAB (3): String table
    - SHT_RELA (4): Relocations
  |
}
# ============================================================================
# PROCESSING LAYER: Section Filtering & Categorization
# ============================================================================
SectionFilter: {
  style.fill: "#FFF8E1"
  style.stroke: "#F9A825"
  label: "Section Filter\n& Categorizer"
  filter_logic: |md
    **is_section_mergeable()**
    
    sh_type != SHT_NULL
    AND sh_flags & SHF_ALLOC
    AND sh_addralign is power-of-2
    
  |
  categories: {
    shape: class
    style.fill: "#E8F5E9"
    SEC_CAT_CODE: ".text (ALLOC|EXEC)"
    SEC_CAT_RODATA: ".rodata (ALLOC only)"
    SEC_CAT_DATA: ".data (ALLOC|WRITE)"
    SEC_CAT_BSS: ".bss (ALLOC|WRITE, NOBITS)"
  }
}
# ============================================================================
# OUTPUT LAYER: Merged Sections
# ============================================================================
OutputSection: {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  header: |md
    **OutputSection**
    `04_section_types.h`
  |
  fields: {
    shape: class
    +name: "char[64]"
    +flags: "uint64_t"
    +align: "uint64_t"
    +file_size: "uint64_t"
    +mem_size: "uint64_t"
    +file_offset: "uint64_t"
    +virtual_addr: "uint64_t"
    +mappings: "SectionMapping*"
    +mapping_count: "size_t"
    +data: "uint8_t*"
    +is_nobits: "int"
  }
  size_note: |md
    **Size Distinction**
    - `file_size`: Bytes in output file
    - `mem_size`: Bytes in memory
    - For .bss: `file_size=0`, `mem_size>0`
  |
}
SectionMapping: {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  header: |md
    **SectionMapping**
    `04_section_types.h`
  |
  fields: {
    shape: class
    +source_file: "char[256]"
    +section_name: "char[64]"
    +input_size: "uint64_t"
    +output_offset: "uint64_t"
    +padding_before: "uint64_t"
    +source_data: "uint8_t*"
    +source_section_idx: "uint32_t"
  }
  purpose: |md
    **Critical for Relocation**
    Maps `(file, section, offset)` → output offset
    Used by M3 to translate relocation sites
  |
}
# ============================================================================
# CONTEXT: Global Linker State
# ============================================================================
LinkerContext: {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  header: |md
    **LinkerContext**
    `09_linker_context.h`
  |
  fields: {
    shape: class
    +inputs: "ObjectFile*"
    +input_count: "size_t"
    +outputs: "OutputSection*"
    +output_count: "size_t"
    +mapping: "MappingTable"
    +base_address: "uint64_t"
    +total_file_size: "uint64_t"
    +total_mem_size: "uint64_t"
  }
  note: |md
    **Central State**
    Owned by main(), passed to all phases
  |
}
MappingTable: {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  header: |md
    **MappingTable**
    `07_mapping_table.h`
  |
  fields: {
    shape: class
    +entries: "MappingHashEntry*"
    +capacity: "size_t"
    +count: "size_t"
  }
  lookup: {
    shape: class
    style.fill: "#FFF3E0"
    key: '"filename:section_name"'
    translate_offset(): MapError
    translate_to_vaddr(): MapError
  }
}
# ============================================================================
# ALIGNMENT UTILITIES
# ============================================================================
AlignmentUtils: {
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  label: "Alignment Math\n`06_section_merger.c`"
  functions: |md
    c
    calc_padding(current, align):
      if align <= 1: return 0
      rem = current % align
      return rem ? align - rem : 0
    align_up(value, align):
      if align <= 1: return value
      return (value + align - 1) 
             & ~(align - 1)
    
  |
}
# ============================================================================
# RELATIONSHIPS
# ============================================================================
ObjectFile.fields -> InputSection.fields: "owns array\n(n sections)" {
  style.stroke: "#2E86AB"
  target-arrowhead.shape: triangle
  source-arrowhead: 1..n
}
ObjectFile -> SectionFilter: "process each\nsection" {
  style.stroke-dash: 3
  style.stroke: "#F9A825"
}
SectionFilter -> OutputSection: "group by name\nmerge flags" {
  style.stroke: "#1565C0"
}
OutputSection.fields -> SectionMapping.fields: "owns array\n(n mappings)" {
  style.stroke: "#7B1FA2"
  target-arrowhead.shape: triangle
}
LinkerContext.fields -> ObjectFile.fields: "owns\ninputs[]" {
  style.stroke: "#C62828"
  target-arrowhead.shape: triangle
}
LinkerContext.fields -> OutputSection.fields: "owns\noutputs[]" {
  style.stroke: "#C62828"
  target-arrowhead.shape: triangle
}
LinkerContext.fields -> MappingTable.fields: "owns\nmapping" {
  style.stroke: "#7B1FA2"
  target-arrowhead.shape: triangle
}
SectionMapping.fields -> InputSection.fields: "references\nsource data" {
  style.stroke-dash: 3
  style.stroke: "#7B1FA2"
}
AlignmentUtils -> OutputSection: "computes\npadding" {
  style.stroke-dash: 3
  style.stroke: "#00838F"
}
# ============================================================================
# DATA FLOW ANNOTATION
# ============================================================================
DataFlow: {
  near: bottom-center
  flow: |md
    **Data Flow:**
    1. `parse_object_file()` → ObjectFile with InputSection array
    2. `is_section_mergeable()` filters to allocatable sections
    3. Sections grouped by name across all inputs
    4. `calc_padding()` + `align_up()` compute placements
    5. SectionMapping records input→output translation
    6. MappingTable enables O(1) lookup for relocation
  |
}
# ============================================================================
# KEY INVARIANTS BOX
# ============================================================================
Invariants: {
  near: bottom-right
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  label: |md
    **Module Invariants**
    1. Every allocatable input section maps to exactly one output section
    2. `output_offset` never violates `align` constraint
    3. `.bss`: `file_size=0`, `mem_size>0`
    4. Mapping table is complete before M2/M3 run
    5. `p_offset % p_align == p_vaddr % p_align` (page alignment)
  |
}