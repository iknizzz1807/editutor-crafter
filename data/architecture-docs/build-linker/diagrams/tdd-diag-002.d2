direction: right
layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B59B6"
    section_table: "#3498DB"
    section_data: "#2ECC71"
    struct: "#E67E22"
    string: "#1ABC9C"
    padding: "#BDC3C7"
  }
}

classes: {
  file_block: {
    style: {
      fill: "#F8F9FA"
      stroke: "#BDC3C7"
      stroke-width: 2
      border-radius: 4
    }
  }
  process_arrow: {
    style: {
      stroke-width: 2
      animated: true
      stroke: "#3498DB"
    }
  }
  data_arrow: {
    style: {
      stroke-width: 2
      stroke: "#2ECC71"
    }
  }
  struct_box: {
    style: {
      fill: "#E67E22"
      stroke: "#D35400"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  header_box: {
    style: {
      fill: "#9B59B6"
      stroke: "#8E44AD"
      stroke-width: 2
      font-color: white
    }
  }
  section_box: {
    style: {
      fill: "#2ECC71"
      stroke: "#27AE60"
      stroke-width: 2
      font-color: white
    }
  }
}

title: |md
  # ELF Object File Parsing Data Flow
  Raw .o file → Parsed ObjectFile struct
  *Intel Manual Grade Specification*
| {
  near: top-center
}

# Input: Raw Object File Layout
raw_file: {
  label: "Binary: Raw Object File"
  class: file_block
  content: |md
    | Offset | Size | Content |
    | :--- | :--- | :--- |
    | 0x0000 | 64B | **ELF64_Ehdr** (File Header) |
    | ... | var | Program Headers (Optional) |
    | e_shoff | N*64B | **ELF64_Shdr[]** (Section Table) |
    | sh_offset[i] | var | Section Content (.text, .data) |
    | sh_offset[n] | var | **.shstrtab** (Section Names) |
  |
}

# Step 1: Parse ELF Header
step1: {
  label: "1. EHdr Extraction"
  class: header_box
  shape: diamond
  tooltip: |md
    ### Seek: 0x0
    - `e_ident[4] == [0x7f, 'E', 'L', 'F']`
    - `e_type == 1` (ET_REL)
    - `e_machine == 62` (EM_X86_64)
    - **Capture:** `e_shoff`, `e_shnum`, `e_shstrndx`
  |
}

# ELF Header Struct Definition
elf_header: {
  label: "struct Elf64_Ehdr"
  class: struct_box
  shape: class
  e_ident: "unsigned char [16]"
  e_type: "uint16_t // ET_REL"
  e_machine: "uint16_t // EM_X86_64"
  e_version: "uint32_t"
  e_entry: "uint64_t"
  e_phoff: "uint64_t"
  e_shoff: "uint64_t // Offset to Section Headers"
  e_flags: "uint32_t"
  e_ehsize: "uint16_t // 64 bytes"
  e_phentsize: "uint16_t"
  e_phnum: "uint16_t"
  e_shentsize: "uint16_t // 64 bytes"
  e_shnum: "uint16_t // N Sections"
  e_shstrndx: "uint16_t // Name table index"
}

# Step 2: Locate Section Header Table
step2: {
  label: "2. Locate SHDR Table"
  class: header_box
  shape: diamond
  tooltip: |md
    ### fseek(e_shoff)
    Read `e_shnum` entries of 64 bytes each.
    Entry `[e_shstrndx]` provides the metadata 
    required to find strings.
  |
}

# Section Header Table Representation
section_table: {
  label: "Section Header Table (Raw)"
  class: file_block
  content: |md
    | Index | Name | Type | Offset |
    | :--- | :--- | :--- | :--- |
    | 0 | NULL | SHT_NULL | 0x0 |
    | 1 | .text | SHT_PROGBITS | 0x40 |
    | ... | ... | ... | ... |
    | e_shstrndx | .shstrtab | SHT_STRTAB | 0x1F00 |
  |
}

# Step 3: Load Section Name String Table
step3: {
  label: "3. String Resolve"
  class: header_box
  shape: diamond
  tooltip: |md
    ### Load .shstrtab
    1. Read Header at `section_table[e_shstrndx]`
    2. Read `sh_size` bytes from `sh_offset`
    3. `sh_name` in headers is index into this buffer
  |
}

# String Table Content
shstrtab: {
  label: "Buffer: .shstrtab"
  class: section_box
  content: |md
    `0x00` \0
    `0x01` . s y m t a b \0
    `0x09` . s t r t a b \0
    `0x11` . s h s t r t a b \0
    `0x1B` . t e x t \0
  |
}

# Step 4: Parse Each Section Header
step4: {
  label: "4. Section Loop"
  class: header_box
  shape: diamond
  tooltip: |md
    ### Validation Logic
    For `i` from 1 to `e_shnum`:
    - Name = `&shstrtab[sh_name]`
    - Type = `sh_type`
    - Verify `sh_addralign` is power of 2
  |
}

# Section Header Struct Definition
section_header: {
  label: "struct Elf64_Shdr"
  class: struct_box
  shape: class
  sh_name: "uint32_t // String table offset"
  sh_type: "uint32_t // SHT_PROGBITS, etc"
  sh_flags: "uint64_t // SHF_WRITE, etc"
  sh_addr: "uint64_t // Virtual addr"
  sh_offset: "uint64_t // File offset"
  sh_size: "uint64_t // Size in bytes"
  sh_link: "uint32_t // Link"
  sh_info: "uint32_t"
  sh_addralign: "uint64_t"
  sh_entsize: "uint64_t"
}

# Step 5: Data Ingestion
step5: {
  label: "5. Heap Allocation"
  class: section_box
  shape: diamond
  tooltip: |md
    ### Memory Mapping
    If `sh_type == SHT_NOBITS` (.bss):
      `ptr = calloc(sh_size)`
    Else:
      `ptr = malloc(sh_size)`
      `fread(ptr, 1, sh_size, fp)`
  |
}

# Memory-Resident Sections
sections_container: {
  label: "Internal: InputSection[]"
  class: file_block
  grid-columns: 2
  
  text_sec: ".text (Executable)" {
    class: section_box
    tooltip: "malloc + fread"
    style.bold: true
  }
  data_sec: ".data (Writable)" {
    class: section_box
    tooltip: "malloc + fread"
  }
  bss_sec: ".bss (Zero-init)" {
    class: section_box
    tooltip: "calloc only"
    style.stroke-dash: 3
  }
  sym_sec: ".symtab (Symbols)" {
    class: section_box
    tooltip: "24-byte structs"
  }
}

# Parsed Object
object_file: {
  label: "struct ObjectFile"
  class: struct_box
  shape: class
  filename: "char*"
  header: "Elf64_Ehdr"
  sections: "InputSection**"
  section_count: "uint16_t"
  shstrtab: "char* // Raw string pool"
}

# Connection Logic: Procedural Flow
raw_file -> step1: "fread(64)" {class: process_arrow}
step1 -> elf_header: "populate fields" {class: data_arrow}
elf_header -> step2: "use e_shoff" {class: data_arrow}
step2 -> section_table: "fread(num * size)" {class: process_arrow}
section_table -> step3: "use index e_shstrndx" {class: data_arrow}
step3 -> shstrtab: "buffer allocation" {class: process_arrow}
shstrtab -> step4: "resolve strings" {class: data_arrow}
step4 -> section_header: "iterate entries" {class: data_arrow}
section_header -> step5: "sh_offset / sh_size" {class: data_arrow}
step5 -> sections_container: "load segments" {class: process_arrow}
sections_container -> object_file: "final assembly" {class: data_arrow}

# Annotations / Legend
legend: {
  label: |md
    ### ELF Implementation Legend
    - **Purple Boxes**: Control flow / Header logic
    - **Orange Boxes**: Memory structure (RAM)
    - **Green Boxes**: Allocated section data
    - **Blue Animated**: Disk I/O (fseek/fread)
    - **Dashed Box**: No file content (.bss)
  |
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FDFEFE"
    stroke: "#BDC3C7"
  }
}