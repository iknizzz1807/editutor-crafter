vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#D0BCFF"
    data: "#B0C4DE"
    padding: "#D3D3D3"
    pointer: "#FFCC99"
    offset_bg: "#F5F5F5"
    critical: "#FF6666"
  }
}

title: |md
  # ELF64 Header Memory Layout (Intel x86-64)
  **Total Size: 64 bytes (0x00 - 0x3F)**
  *Layout compliant with System V ABI / LSB 5.0*
| {near: top-center}

ELF_Header: {
  shape: rectangle
  style: {
    stroke: "#333333"
    stroke-width: 4
    fill: "#FFFFFF"
    # Dashed indicates cache line boundary (64B)
    stroke-dash: 5
  }

  grid-columns: 3
  grid-gap: 0

  # Header labels for the grid
  h_off: "Offset" { style: { bold: true; fill: "#E0E0E0" } }
  h_field: "Field Description / Value" { style: { bold: true; fill: "#E0E0E0" } }
  h_size: "Size" { style: { bold: true; fill: "#E0E0E0" } }

  # --- ROW 0x00: e_ident ---
  r00_o: "0x00" { style.fill: "${colors.offset_bg}" }
  r00_f: {
    label: "e_ident[16]\nMagic: 7F 45 4C 46 (ELF)\nClass: 2 (64-bit), Data: 1 (LSB)\nVersion: 1, OSABI: 0, ABI Ver: 0"
    style.fill: "${colors.header}"
  }
  r00_s: "16B" { style.fill: "${colors.padding}" }

  # --- ROW 0x10: e_type ---
  r10_o: "0x10" { style.fill: "${colors.offset_bg}" }
  r10_f: {
    label: "e_type\nuint16_t (Object file type)\n1=REL, 2=EXEC, 3=DYN, 4=CORE"
    style.fill: "${colors.data}"
  }
  r10_s: "2B" { style.fill: "${colors.padding}" }

  # --- ROW 0x12: e_machine ---
  r12_o: "0x12" { style.fill: "${colors.offset_bg}" }
  r12_f: {
    label: "e_machine\nuint16_t (Architecture)\n62 = EM_X86_64"
    style.fill: "${colors.data}"
  }
  r12_s: "2B" { style.fill: "${colors.padding}" }

  # --- ROW 0x14: e_version ---
  r14_o: "0x14" { style.fill: "${colors.offset_bg}" }
  r14_f: {
    label: "e_version\nuint32_t (Object file version)\n1 = EV_CURRENT"
    style.fill: "${colors.data}"
  }
  r14_s: "4B" { style.fill: "${colors.padding}" }

  # --- ROW 0x18: e_entry ---
  r18_o: "0x18" { style.fill: "${colors.offset_bg}" }
  r18_f: {
    label: "e_entry [POINTER]\nuint64_t (Entry point virtual address)\ne.g. 0x0000000000401000"
    style.fill: "${colors.pointer}"
    style.bold: true
  }
  r18_s: "8B" { style.fill: "${colors.padding}" }

  # --- ROW 0x20: e_phoff ---
  r20_o: "0x20" { style.fill: "${colors.offset_bg}" }
  r20_f: {
    label: "e_phoff [OFFSET]\nuint64_t (Program header table offset)\nStart of segment map"
    style.fill: "${colors.pointer}"
    style.bold: true
  }
  r20_s: "8B" { style.fill: "${colors.padding}" }

  # --- ROW 0x28: e_shoff ---
  r28_o: "0x28" { style.fill: "${colors.offset_bg}" }
  r28_f: {
    label: "e_shoff [OFFSET]\nuint64_t (Section header table offset)\n0 if non-linking"
    style.fill: "${colors.pointer}"
  }
  r28_s: "8B" { style.fill: "${colors.padding}" }

  # --- ROW 0x30: e_flags ---
  r30_o: "0x30" { style.fill: "${colors.offset_bg}" }
  r30_f: {
    label: "e_flags\nuint32_t (Processor-specific flags)\nx86-64: Typically 0"
    style.fill: "${colors.data}"
  }
  r30_s: "4B" { style.fill: "${colors.padding}" }

  # --- ROW 0x34: e_ehsize ---
  r34_o: "0x34" { style.fill: "${colors.offset_bg}" }
  r34_f: {
    label: "e_ehsize\nuint16_t (ELF header size)\nFixed at 64 bytes"
    style.fill: "${colors.data}"
  }
  r34_s: "2B" { style.fill: "${colors.padding}" }

  # --- ROW 0x36: e_phentsize ---
  r36_o: "0x36" { style.fill: "${colors.offset_bg}" }
  r36_f: {
    label: "e_phentsize\nuint16_t (Size of one program header)\nUsually 56 bytes"
    style.fill: "${colors.data}"
  }
  r36_s: "2B" { style.fill: "${colors.padding}" }

  # --- ROW 0x38: e_phnum ---
  r38_o: "0x38" { style.fill: "${colors.offset_bg}" }
  r38_f: {
    label: "e_phnum\nuint16_t (Number of program headers)\nTotal segments to load"
    style.fill: "${colors.data}"
    style.bold: true
  }
  r38_s: "2B" { style.fill: "${colors.padding}" }

  # --- ROW 0x3A: e_shentsize ---
  r3a_o: "0x3A" { style.fill: "${colors.offset_bg}" }
  r3a_f: {
    label: "e_shentsize\nuint16_t (Size of one section header)\nUsually 64 bytes"
    style.fill: "${colors.data}"
  }
  r3a_s: "2B" { style.fill: "${colors.padding}" }

  # --- ROW 0x3C: e_shnum ---
  r3c_o: "0x3C" { style.fill: "${colors.offset_bg}" }
  r3c_f: {
    label: "e_shnum\nuint16_t (Number of section headers)\nLinking data count"
    style.fill: "${colors.data}"
  }
  r3c_s: "2B" { style.fill: "${colors.padding}" }

  # --- ROW 0x3E: e_shstrndx ---
  r3e_o: "0x3E" { style.fill: "${colors.offset_bg}" }
  r3e_f: {
    label: "e_shstrndx\nuint16_t (Section name string table index)\nSHN_UNDEF if none"
    style.fill: "${colors.data}"
  }
  r3e_s: "2B" { style.fill: "${colors.padding}" }
}

legend: {
  near: bottom-left
  grid-columns: 2
  grid-gap: 15
  l_ident: "Identification (Magic)" { style.fill: "${colors.header}" }
  l_data: "File Metadata" { style.fill: "${colors.data}" }
  l_addr: "Offsets / Pointers" { style.fill: "${colors.pointer}" }
  l_size: "Field Size Metadata" { style.fill: "${colors.padding}" }
}

implementation_note: |md
  ### ABI Requirements for x86-64 Implementation:
  1. **Endianness**: Fields larger than 1 byte must use **Little Endian** (EI_DATA = 1).
  2. **Cache Optimization**: This entire structure occupies exactly one **64-byte cache line**, minimizing misses during initial parsing.
  3. **Address Alignment**: `e_entry` usually points to the `.text` segment start, which requires alignment with the system's 4KB page size.
  4. **Dynamic Loading**: `e_phoff` is used by the OS loader (ld.so) to locate the program header table immediately; `e_phnum` dictates the loop count for mapping segments.
| {near: bottom-right}