vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  # Technical Design Artist - Instruction Compliant Colors
  colors: {
    header: "#673AB7" # Purple
    data: "#0288D1"   # Blue
    offset: "#EF6C00" # Orange
    padding: "#9E9E9E" # Gray
    text_light: "#FFFFFF"
    desc_bg: "#F5F5F5"
  }
}

title: |md
  # ELF64 Section Header Entry (Elf64_Shdr)
  ### sizeof = 64 bytes (One Cache Line)
| {near: top-center}

direction: right

memory_layout: {
  grid-columns: 3
  grid-gap: 0
  
  # Styling for cache line boundary
  style: {
    stroke: black
    stroke-width: 2
    stroke-dash: 5 # Indicates 64B cache line boundary
  }

  # --- HEADER ROW ---
  h_off: "Byte Offset" {
    style: {
      fill: ${colors.header}
      font-color: ${colors.text_light}
      bold: true
    }
  }
  h_field: "Field Mapping" {
    style: {
      fill: ${colors.header}
      font-color: ${colors.text_light}
      bold: true
    }
  }
  h_size: "Size" {
    style: {
      fill: ${colors.header}
      font-color: ${colors.text_light}
      bold: true
    }
  }

  # --- ROW 0: sh_name (4B) ---
  off_00: "0x00" { style.fill: ${colors.offset} }
  sh_name: "sh_name" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Index into section header string table"
  }
  sz_4a: "4B" { style.fill: ${colors.padding} }

  # --- ROW 1: sh_type (4B) ---
  off_04: "0x04" { style.fill: ${colors.offset} }
  sh_type: "sh_type" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Section classification (SHT_PROGBITS, etc)"
  }
  sz_4b: "4B" { style.fill: ${colors.padding} }

  # --- ROW 2: sh_flags (8B) ---
  off_08: "0x08" { style.fill: ${colors.offset} }
  sh_flags: "sh_flags" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Section attributes (SHF_WRITE, SHF_ALLOC, etc)"
  }
  sz_8a: "8B" { style.fill: ${colors.padding} }

  # --- ROW 3: sh_addr (8B) ---
  off_10: "0x10" { style.fill: ${colors.offset} }
  sh_addr: "sh_addr" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Virtual address in memory"
  }
  sz_8b: "8B" { style.fill: ${colors.padding} }

  # --- ROW 4: sh_offset (8B) ---
  off_18: "0x18" { style.fill: ${colors.offset} }
  sh_offset: "sh_offset" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Offset in file image"
  }
  sz_8c: "8B" { style.fill: ${colors.padding} }

  # --- ROW 5: sh_size (8B) ---
  off_20: "0x20" { style.fill: ${colors.offset} }
  sh_size: "sh_size" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Size of section in bytes"
  }
  sz_8d: "8B" { style.fill: ${colors.padding} }

  # --- ROW 6: sh_link (4B) ---
  off_28: "0x28" { style.fill: ${colors.offset} }
  sh_link: "sh_link" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Section index link"
  }
  sz_4c: "4B" { style.fill: ${colors.padding} }

  # --- ROW 7: sh_info (4B) ---
  off_2c: "0x2C" { style.fill: ${colors.offset} }
  sh_info: "sh_info" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Extra section-specific information"
  }
  sz_4d: "4B" { style.fill: ${colors.padding} }

  # --- ROW 8: sh_addralign (8B) ---
  off_30: "0x30" { style.fill: ${colors.offset} }
  sh_addralign: "sh_addralign" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Address alignment boundary"
  }
  sz_8e: "8B" { style.fill: ${colors.padding} }

  # --- ROW 9: sh_entsize (8B) ---
  off_38: "0x38" { style.fill: ${colors.offset} }
  sh_entsize: "sh_entsize" { 
    style: { fill: ${colors.data}; font-color: ${colors.text_light}; font: mono }
    tooltip: "Size of entries if section holds a table"
  }
  sz_8f: "8B" { style.fill: ${colors.padding} }
}

# Documentation / Engineering Details
field_descriptions: {
  direction: down
  style.fill: ${colors.desc_bg}
  
  sh_name_note: |md
    ### sh_name (Elf64_Word)
    Offset into the section header string table (`.shstrtab`) section, giving the name of this section.
  |
  
  sh_type_note: |md
    ### sh_type (Elf64_Word)
    Categorizes the section's contents and semantics.
    - `0`: SHT_NULL
    - `1`: SHT_PROGBITS
    - `2`: SHT_SYMTAB
    - `3`: SHT_STRTAB
  |

  sh_flags_note: |md
    ### sh_flags (Elf64_Xword)
    1-bit flags describing miscellaneous attributes.
    - `0x1`: SHF_WRITE
    - `0x2`: SHF_ALLOC
    - `0x4`: SHF_EXECINSTR
  |
}

# Corrected Size Summary using Advanced Block String Delimiters to prevent collision with Markdown tables
size_summary: ||md
### Total Size: 64 bytes (0x40)
The structure represents a single entry in the Section Header Table.

| Offset Range | Bytes | Field Cluster |
| :--- | :--- | :--- |
| 0x00 - 0x07 | 8 | Identifiers (Name/Type) |
| 0x08 - 0x27 | 32 | Memory & File Geometry |
| 0x28 - 0x2F | 8 | Linkage/Metadata |
| 0x30 - 0x3F | 16 | Alignment & Entry sizing |
|| {
  near: bottom-center
  style.font-size: 14
}

# Cross references
memory_layout.sh_name -> field_descriptions.sh_name_note: { style.stroke: ${colors.offset}; style.animated: true }
memory_layout.sh_type -> field_descriptions.sh_type_note: { style.stroke: ${colors.offset} }
memory_layout.sh_flags -> field_descriptions.sh_flags_note: { style.stroke: ${colors.offset} }