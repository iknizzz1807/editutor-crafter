direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    text: "#4A90D9"
    data: "#50C878"
    rodata: "#9B59B6"
    bss: "#E67E22"
    padding: "#BDC3C7"
    header: "#2C3E50"
  }
}

title: |'md
# Input Section to Output Section Mapping
### Intel-Grade Technical Specification: Section Merging & Alignment
This diagram illustrates how a Linker (LD) aggregates sections from multiple input files into a unified segment layout, applying padding to satisfy CPU alignment requirements.
'|
title.near: top-center

classes: {
  inputFile: {
    style: {
      fill: "#F8F9FA"
      stroke: "#DEE2E6"
      stroke-width: 2
      border-radius: 4
    }
  }
  inputSection: {
    style: {
      stroke-width: 1
      border-radius: 2
    }
  }
  outputSection: {
    style: {
      stroke-width: 2
      border-radius: 4
      shadow: true
    }
  }
  padding: {
    style: {
      fill: "#BDC3C7"
      stroke: "#7F8C8D"
      stroke-dash: 3
    }
  }
  mappingArrow: {
    style: {
      stroke-width: 2
      animated: true
    }
  }
}

Input_Files: {
  class: inputFile
  label: "Relocatable Object Files (.o)"
  
  main_o: "main.o" {
    class: inputFile
    style.fill: "#FFFFFF"
    text_main: ".text\n(120B)" {
      class: inputSection
      style.fill: "${colors.text}"
      style.font-color: white
    }
    data_main: ".data\n(32B)" {
      class: inputSection
      style.fill: "${colors.data}"
      style.font-color: white
    }
  }

  utils_o: "utils.o" {
    class: inputFile
    style.fill: "#FFFFFF"
    text_utils: ".text\n(80B)" {
      class: inputSection
      style.fill: "${colors.text}"
      style.font-color: white
    }
    rodata_utils: ".rodata\n(64B)" {
      class: inputSection
      style.fill: "${colors.rodata}"
      style.font-color: white
    }
    bss_utils: ".bss\n(16B)" {
      class: inputSection
      style.fill: "${colors.bss}"
      style.font-color: white
    }
  }
}

Mapping_Process: {
  style.fill: "transparent"
  style.stroke: "transparent"
  label: |'md
## Section Merging Logic
1.  **Grouping**: Collect all input sections with identical names (e.g., all `.text`).
2.  **Ordering**: Arrange by file order as specified in linker script or command line.
3.  **Alignment**: Calculate `pos = align_up(current_pos, section_align)`.
4.  **Padding**: Insert null bytes if `pos > current_pos`.
5.  **Relocation**: Record the new `Output Offset` for symbol resolution.
  '|
}

Output_Sections: {
  label: "Executable Layout (Output Sections)"
  style.fill: "#FAFBFC"
  style.stroke: "#D1D5DA"
  style.stroke-width: 2

  out_text: ".text (Executable Code)" {
    class: outputSection
    style.fill: "${colors.text}"
    style.font-color: white
    style.stroke: "#2980B9"
    
    layout: |'md
**Virtual Address: 0x401000**
| Component | Range | Size |
| :--- | :--- | :--- |
| `main.o:.text` | 0x00 - 0x77 | 120B |
| `[PADDING]` | 0x78 - 0x7F | 8B |
| `utils.o:.text` | 0x80 - 0xCF | 80B |
**Total Section Size: 208 bytes (0xD0)**
    '|
    layout.shape: text
  }

  out_rodata: ".rodata (Read-Only Data)" {
    class: outputSection
    style.fill: "${colors.rodata}"
    style.font-color: white
    style.stroke: "#7D3C98"
    
    layout: |'md
**Virtual Address: 0x4010D0**
| Component | Range | Size |
| :--- | :--- | :--- |
| `utils.o:.rodata` | 0x00 - 0x3F | 64B |
**Total Section Size: 64 bytes (0x40)**
    '|
    layout.shape: text
  }

  out_data: ".data (Initialized Data)" {
    class: outputSection
    style.fill: "${colors.data}"
    style.font-color: white
    style.stroke: "#27AE60"
    
    layout: |'md
**Virtual Address: 0x403000**
| Component | Range | Size |
| :--- | :--- | :--- |
| `main.o:.data` | 0x00 - 0x1F | 32B |
**Total Section Size: 32 bytes (0x20)**
    '|
    layout.shape: text
  }

  out_bss: ".bss (Zero-Initialized)" {
    class: outputSection
    style.fill: "${colors.bss}"
    style.font-color: white
    style.stroke: "#D35400"
    
    layout: |'md
**Virtual Address: 0x403020**
| Component | Range | Size |
| :--- | :--- | :--- |
| `utils.o:.bss` | 0x00 - 0x0F | 16B |
**File Size: 0B | Memory Size: 16B**
    '|
    layout.shape: text
  }
}

Mapping_Table: {
  style.fill: "#2C3E50"
  style.stroke: "#1A252F"
  style.font-color: white
  style.border-radius: 4
  header: "INTERNAL LINKER SYMBOL TABLE (ILST)" {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
  }
  content: |'md
| Input Section | Output Section | Output Offset | Size |
| :--- | :--- | :--- | :--- |
| main.o:.text | .text | 0x0000 | 0x78 |
| utils.o:.text | .text | 0x0080 | 0x50 |
| utils.o:.rodata| .rodata | 0x0000 | 0x40 |
| main.o:.data | .data | 0x0000 | 0x20 |
| utils.o:.bss | .bss | 0x0000 | 0x10 |

**Translation Function:**
`target_vaddr = section.vaddr + mapping.offset + sym.offset`
  '|
  content.shape: text
}

Alignment_Logic: {
  style.fill: "#FFF9E6"
  style.stroke: "#F1C40F"
  style.border-radius: 4
  label: "Padding Calculation"
  
  formula: |'c
// Kernel-style alignment macro
#define ALIGN_UP(addr, size) \
    (((addr) + (size) - 1) & ~((size) - 1))

// LD implementation
uint64_t calculate_padding(uint64_t curr, uint64_t align) {
    uint64_t next = ALIGN_UP(curr, align);
    return next - curr;
}
  '|
  formula.shape: code
}

Virtual_Address_Map: {
  style.fill: "#E8F6F3"
  style.stroke: "#1ABC9C"
  style.border-radius: 4
  content: |'md
### Segment Assignment (ELF Program Header)
| Segment | VAddr Start | VAddr End | Perms |
| :--- | :--- | :--- | :--- |
| **TEXT** | 0x401000 | 0x401110 | R-E |
| **DATA** | 0x403000 | 0x403030 | RW- |

*Note: .text and .rodata are merged into the Read-Only Segment.*
*Note: .data and .bss are merged into the Read-Write Segment.*
  '|
  content.shape: text
}

# Mapping Connections
Input_Files.main_o.text_main -> Output_Sections.out_text: "Offset 0x00" {
  class: mappingArrow
  style.stroke: "${colors.text}"
}
Input_Files.utils_o.text_utils -> Output_Sections.out_text: "Offset 0x80" {
  class: mappingArrow
  style.stroke: "${colors.text}"
}
Input_Files.utils_o.rodata_utils -> Output_Sections.out_rodata: "Offset 0x00" {
  class: mappingArrow
  style.stroke: "${colors.rodata}"
}
Input_Files.main_o.data_main -> Output_Sections.out_data: "Offset 0x00" {
  class: mappingArrow
  style.stroke: "${colors.data}"
}
Input_Files.utils_o.bss_utils -> Output_Sections.out_bss: "Offset 0x00" {
  class: mappingArrow
  style.stroke: "${colors.bss}"
}

# Logical Data Flow
Input_Files -> Mapping_Table: "Collect Metadata" { style.stroke-dash: 5 }
Mapping_Table -> Output_Sections: "Apply Offsets" { style.stroke-dash: 5 }
Alignment_Logic -> Mapping_Table: "Supply Padding" { style.stroke-dash: 5 }

legend: {
  near: bottom-center
  style.fill: white
  style.stroke: "#DEE2E6"
  content: |'md
**Color Code:** 
🟦 `.text` (Code) | 🟩 `.data` (Init) | 🟪 `.rodata` (Const) | 🟧 `.bss` (Zero) | ⬜ Padding
  '|
  content.shape: text
}