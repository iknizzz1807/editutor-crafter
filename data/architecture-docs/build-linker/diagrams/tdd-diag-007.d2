direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: |md
  # Section Merging State Machine (ELF64 Linker)
  **Intel Manual Quality Technical Specification**
  *State transitions for SHT_PROGBITS and SHT_NOBITS merging logic.*
| {near: top-center}

# -----------------------------------------------------------------------------------------
# State Definitions
# -----------------------------------------------------------------------------------------

IDLE: {
  shape: circle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 4
    font-color: "#1B5E20"
    bold: true
  }
  label: "● IDLE"
  tooltip: "Linker context initialized. Waiting for input object stream."
}

PARSING_FILE: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    font-color: "#0D47A1"
    border-radius: 8
  }
  
  header: "FILE_PARSE_UNIT" {
    style: { bold: true; underline: true }
  }

  validate_magic: {
    shape: diamond
    label: "Check e_ident\n[0..4] == 0x7F'ELF'"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
    }
  }
  
  read_shdr: {
    shape: rectangle
    label: "Read shoff + (shnum * shentsize)\nExtract Section Header Table"
    style.fill: "#BBDEFB"
  }

  validate_magic -> read_shdr: "PASS"
}

PROCESSING_SECTION: {
  shape: rectangle
  label: "ITERATE_SECTIONS"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
    font-color: "#4A148C"
    border-radius: 8
  }

  check_type: {
    shape: diamond
    label: "sh_type ∈\n{PROGBITS, NOBITS}?"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
    }
  }

  check_alloc: {
    shape: diamond
    label: "sh_flags &\nSHF_ALLOC?"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
    }
  }

  check_type -> check_alloc: "YES"
}

MERGING_SECTION: {
  shape: rectangle
  label: "MERGE_LOGIC_UNIT"
  style: {
    fill: "#FFF8E1"
    stroke: "#F57C00"
    stroke-width: 2
    font-color: "#E65100"
    border-radius: 8
  }

  alignment_logic: {
    shape: rectangle
    label: "padding = (sh_addralign - (current_off % sh_addralign)) % sh_addralign"
    style.fill: "#FFE082"
    style.font: mono
  }

  mapping_logic: {
    shape: rectangle
    label: "Record Input(sh_offset) → Output(sh_addr + padding)"
    style.fill: "#FFE082"
  }

  alignment_logic -> mapping_logic
}

COMPLETE: {
  shape: circle
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 4
    font-color: "#1B5E20"
    double-border: true
    bold: true
  }
  label: "COMPLETE"
}

# -----------------------------------------------------------------------------------------
# Error States (Sinks)
# -----------------------------------------------------------------------------------------

ERROR_HANDLER: {
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
    stroke-width: 2
    font-color: "#B71C1C"
  }

  E01: "PARSE_ERR_MAGIC" { shape: rectangle; style.fill: "#EF9A9A" }
  E02: "PARSE_ERR_ARCH" { shape: rectangle; style.fill: "#EF9A9A" }
  E03: "MERGE_ERR_ALIGN" { shape: rectangle; style.fill: "#EF9A9A" }
}

# -----------------------------------------------------------------------------------------
# Transitions (Main Path)
# -----------------------------------------------------------------------------------------

IDLE -> PARSING_FILE: "Trigger: next_file_ptr" {
  style: { stroke: "#1565C0"; stroke-width: 3; animated: true }
}

PARSING_FILE -> PROCESSING_SECTION: "Action: Load SectionTable\nInit idx=0" {
  style: { stroke: "#7B1FA2"; stroke-width: 2 }
}

PROCESSING_SECTION -> MERGING_SECTION: "Guard: [Type Match] && [Alloc Flag]" {
  style: { stroke: "#F57C00"; stroke-width: 2 }
}

MERGING_SECTION -> PROCESSING_SECTION: "idx++\nUpdate Output.vsize" {
  style: { stroke: "#7B1FA2"; stroke-dash: 3 }
}

PROCESSING_SECTION -> PROCESSING_SECTION: "idx++\nDiscard non-alloc" {
  style: { stroke: "#9E9E9E"; stroke-dash: 5 }
}

PROCESSING_SECTION -> PARSING_FILE: "Guard: idx == shnum\nAction: Close handle" {
  style: { stroke: "#1565C0"; stroke-dash: 3 }
}

PARSING_FILE -> COMPLETE: "Guard: EOF input_list" {
  style: { stroke: "#2E7D32"; stroke-width: 3 }
}

# -----------------------------------------------------------------------------------------
# Transitions (Error Path)
# -----------------------------------------------------------------------------------------

PARSING_FILE -> ERROR_HANDLER.E01: "Magic Mismatch" {
  style: { stroke: "#C62828"; stroke-dash: 2 }
}

PARSING_FILE -> ERROR_HANDLER.E02: "e_machine != EM_X86_64" {
  style: { stroke: "#C62828"; stroke-dash: 2 }
}

MERGING_SECTION -> ERROR_HANDLER.E03: "Alignment Conflict" {
  style: { stroke: "#C62828"; stroke-dash: 2 }
}

# -----------------------------------------------------------------------------------------
# Annotations (Fixed Positioning for ELK)
# -----------------------------------------------------------------------------------------

IDLE_annotation: |md
  ### Pre-conditions
  - `OutputSectionTable` is empty.
  - `ImageBase` = 0x400000.
  - `GlobalOffsetTable` initialized.
| {
  near: top-left
  shape: text
  style.font-size: 11
}

MERGE_annotation: |md
  ### Alignment Math
  - `sh_addralign` must be power of 2.
  - `Output.size` += `Input.size` + `padding`.
| {
  near: bottom-center
  shape: text
  style.font-size: 11
}

POST_annotation: |md
  ### Post-conditions
  - `.text`, `.data`, `.bss` mapping established.
  - `SymbolTable` ready for resolution.
| {
  near: bottom-right
  shape: text
  style.font-size: 11
}

# -----------------------------------------------------------------------------------------
# Legend
# -----------------------------------------------------------------------------------------

legend: {
  near: top-right
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
  
  L1: "Input Transition" {
    shape: text
    style.font-color: "#1565C0"
  }
  L2: "Internal State Switch" {
    shape: text
    style.font-color: "#7B1FA2"
  }
  L3: "Logical Exception" {
    shape: text
    style.font-color: "#C62828"
  }
}