vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B59B6"
    data: "#3498DB"
    pointer: "#E67E22"
    free: "#2ECC71"
    gray: "#7F8C8D"
    bg: "#F8F9F9"
  }
}

title: |md
  # InputSection Struct Memory Layout
  **Total Size: 0x6C (108 bytes)**
| {near: top-center}

direction: down

struct_layout: {
  grid-columns: 1
  grid-gap: 0
  
  style: {
    stroke: "#2C3E50"
    stroke-width: 2
    fill: ${colors.bg}
  }

  # Row 0: name[64] - Takes exactly one full cache line (64B)
  name_row: {
    grid-columns: 3
    grid-gap: 0
    
    offset: "0x00" {
      width: 60
      style: {
        fill: ${colors.gray}
        font-color: white
        bold: true
      }
    }
    field: "char name[64]" {
      width: 300
      style: {
        fill: ${colors.header}
        font-color: white
        bold: true
      }
    }
    size: "64 bytes" {
      width: 100
      style: {
        fill: ${colors.data}
        font-color: white
        bold: true
      }
    }
  }

  cache_boundary: "" {
    height: 2
    style: {
      stroke-dash: 5
      stroke: "#E74C3C"
    }
  }

  # Row 1: type
  type_row: {
    grid-columns: 3
    grid-gap: 0
    offset: "0x40" {
      width: 60
      style: {
        fill: ${colors.gray}
        font-color: white
      }
    }
    field: "uint32_t type" {
      width: 300
      style: {
        fill: ${colors.header}
        font-color: white
      }
    }
    size: "4 bytes" {
      width: 100
      style: {
        fill: ${colors.data}
        font-color: white
      }
    }
  }

  # Row 2: flags
  flags_row: {
    grid-columns: 3
    grid-gap: 0
    offset: "0x44" {
      width: 60
      style: {
        fill: ${colors.gray}
        font-color: white
      }
    }
    field: "uint64_t flags" {
      width: 300
      style: {
        fill: ${colors.header}
        font-color: white
      }
    }
    size: "8 bytes" {
      width: 100
      style: {
        fill: ${colors.data}
        font-color: white
      }
    }
  }

  # Row 3: align
  align_row: {
    grid-columns: 3
    grid-gap: 0
    offset: "0x4C" {
      width: 60
      style: {
        fill: ${colors.gray}
        font-color: white
      }
    }
    field: "uint64_t align" {
      width: 300
      style: {
        fill: ${colors.header}
        font-color: white
      }
    }
    size: "8 bytes" {
      width: 100
      style: {
        fill: ${colors.data}
        font-color: white
      }
    }
  }

  # Row 4: size
  size_row: {
    grid-columns: 3
    grid-gap: 0
    offset: "0x54" {
      width: 60
      style: {
        fill: ${colors.gray}
        font-color: white
      }
    }
    field: "uint64_t size" {
      width: 300
      style: {
        fill: ${colors.header}
        font-color: white
      }
    }
    size: "8 bytes" {
      width: 100
      style: {
        fill: ${colors.data}
        font-color: white
      }
    }
  }

  # Row 5: *data pointer
  data_row: {
    grid-columns: 3
    grid-gap: 0
    offset: "0x5C" {
      width: 60
      style: {
        fill: ${colors.gray}
        font-color: white
      }
    }
    field: "uint8_t *data" {
      width: 300
      style: {
        fill: ${colors.pointer}
        font-color: white
        bold: true
      }
    }
    size: "8 bytes" {
      width: 100
      style: {
        fill: ${colors.data}
        font-color: white
      }
    }
  }

  # Row 6: file_offset
  fileoff_row: {
    grid-columns: 3
    grid-gap: 0
    offset: "0x64" {
      width: 60
      style: {
        fill: ${colors.gray}
        font-color: white
      }
    }
    field: "uint64_t file_offset" {
      width: 300
      style: {
        fill: ${colors.header}
        font-color: white
      }
    }
    size: "8 bytes" {
      width: 100
      style: {
        fill: ${colors.data}
        font-color: white
      }
    }
  }
}

legend: {
  near: bottom-right
  direction: right
  
  header_box: "Field Name" {
    style: { fill: ${colors.header}; font-color: white }
  }
  data_box: "Size Meta" {
    style: { fill: ${colors.data}; font-color: white }
  }
  ptr_box: "Memory Pointer" {
    style: { fill: ${colors.pointer}; font-color: white }
  }
  off_box: "Byte Offset" {
    style: { fill: ${colors.gray}; font-color: white }
  }
}

summary: |`md
  ### Implementation Notes
  | Field | Offset | Size (Bytes) | Alignment |
  | :--- | :--- | :--- | :--- |
  | `name` | 0x00 | 64 | 1 |
  | `type` | 0x40 | 4 | 4 |
  | `flags` | 0x44 | 8 | 8 |
  | `align` | 0x4C | 8 | 8 |
  | `size` | 0x54 | 8 | 8 |
  | `*data` | 0x5C | 8 | 8 |
  | `file_offset` | 0x64 | 8 | 8 |

  **Total Size:** 108 Bytes (0x6C). 
  *Note: The first 64 bytes form a complete cache line.*
`| {
  near: bottom-center
}