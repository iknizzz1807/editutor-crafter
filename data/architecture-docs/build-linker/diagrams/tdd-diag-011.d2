vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    data: "#5C9AD2"
    bss: "#6BC97A"
    free: "#E8E8E8"
    pointer: "#F5A623"
    flow: "#7EB3D2"
    accent: "#E85D75"
  }
}

title: |md
  # .bss Special Handling Data Flow
  ### SHT_NOBITS Section Processing
| {near: top-center}

direction: right

input_object: "Input Object File\n(.o)" {
  style.fill: "${colors.header}"
  style.stroke: "#6B4FB3"
  style.font-color: white
  
  elf_header: "ELF Header" {
    style.fill: "#B8A5E0"
    style.stroke: "#6B4FB3"
  }
  text_section: ".text Section\nSHT_PROGBITS\nSHF_ALLOC | SHF_EXECINSTR" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  data_section: ".data Section\nSHT_PROGBITS\nSHF_ALLOC | SHF_WRITE" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  bss_section: ".bss Section\nSHT_NOBITS\nSHF_ALLOC | SHF_WRITE" {
    style.fill: "${colors.bss}"
    style.stroke: "#3D8A4D"
    style.stroke-dash: 4
  }
  section_headers: "Section Header Table" {
    style.fill: "#C9BEE0"
    style.stroke: "#6B4FB3"
  }
}

parsing: "Parsing Phase\n(No File Read for .bss)" {
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  
  read_text: "Read .text data\nfile_offset → buffer" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  read_data: "Read .data data\nfile_offset → buffer" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  skip_bss: "SKIP .bss data\nSHT_NOBITS detected" {
    style.fill: "${colors.bss}"
    style.stroke: "#3D8A4D"
    style.stroke-dash: 4
    style.italic: true
  }
  metadata_only: "Extract metadata only:\n• sh_size = mem size\n• sh_addralign\n• sh_flags" {
    style.fill: "#E8F5E9"
    style.stroke: "#3D8A4D"
  }
}

input_object.text_section -> parsing.read_text: "data pointer\n+size bytes" {
  style.stroke: "${colors.data}"
  style.stroke-width: 2
}
input_object.data_section -> parsing.read_data: "data pointer\n+size bytes" {
  style.stroke: "${colors.data}"
  style.stroke-width: 2
}
input_object.bss_section -> parsing.skip_bss: "NO data read\n(metadata only)" {
  style.stroke: "${colors.bss}"
  style.stroke-width: 2
  style.stroke-dash: 4
}
input_object.bss_section -> parsing.metadata_only: "sh_size, sh_flags,\nsh_addralign" {
  style.stroke: "${colors.bss}"
  style.stroke-width: 2
}

merging: "Section Merging\n(Track Separately)" {
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  
  output_text: "Output .text\nfile_size = mem_size\n= sum of input sizes" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  output_data: "Output .data\nfile_size = mem_size\n= sum of input sizes" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  output_bss: "Output .bss\nfile_size = 0\nmem_size = sum of input sizes" {
    style.fill: "${colors.bss}"
    style.stroke: "#3D8A4D"
    style.stroke-dash: 4
    style.bold: true
  }
  mapping: "Mapping Table\n.bss entries:\n• output_offset tracked\n• NO source_data pointer" {
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
}

parsing.read_text -> merging.output_text
parsing.read_data -> merging.output_data
parsing.skip_bss -> merging.output_bss: "size only\nNO buffer" {
  style.stroke-dash: 4
}
parsing.metadata_only -> merging.mapping

segment: "Segment Construction\n(p_memsz > p_filesz)" {
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  
  text_segment: "Text Segment\nPT_LOAD\np_filesz = p_memsz" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  data_segment: "Data Segment\nPT_LOAD\np_filesz < p_memsz" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
    style.bold: true
  }
  bss_region: ".bss Region\np_memsz - p_filesz\n= zero-fill size" {
    style.fill: "${colors.bss}"
    style.stroke: "#3D8A4D"
    style.stroke-dash: 4
  }
}

merging.output_text -> segment.text_segment
merging.output_data -> segment.data_segment
merging.output_bss -> segment.bss_region: "extends mem_size\nNO file content" {
  style.stroke-dash: 4
}

loader: "Load Time\n(OS Loader)" {
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  
  mmap_text: "mmap() .text\nfrom file\nR-X permissions" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  mmap_data: "mmap() .data\nfrom file\nRW- permissions" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  zero_fill: "Zero-fill .bss\np_memsz - p_filesz bytes\n(anonymous memory)" {
    style.fill: "${colors.bss}"
    style.stroke: "#3D8A4D"
    style.bold: true
  }
}

segment.text_segment -> loader.mmap_text: "file bytes\n→ memory"
segment.data_segment -> loader.mmap_data: "file bytes\n→ memory"
segment.bss_region -> loader.zero_fill: "NO file I/O\nmemset(0)" {
  style.stroke-dash: 4
  style.stroke: "${colors.accent}"
  style.stroke-width: 2
}

memory: "Process Memory Layout" {
  style.fill: "#FAFAFA"
  style.stroke: "#666666"
  
  vaddr_text: "0x401000: .text\nCode + rodata\nLoaded from file" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  vaddr_data: "0x403000: .data\nInitialized globals\nLoaded from file" {
    style.fill: "${colors.data}"
    style.stroke: "#3A6BA8"
  }
  vaddr_bss: "0x403100: .bss\nUninitialized globals\nZero-filled by loader" {
    style.fill: "${colors.bss}"
    style.stroke: "#3D8A4D"
    style.stroke-dash: 4
  }
}

loader.mmap_text -> memory.vaddr_text
loader.mmap_data -> memory.vaddr_data
loader.zero_fill -> memory.vaddr_bss

legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#CCCCCC"
  style.border-radius: 4
  
  file_backed: "File-backed section" {
    style.fill: "${colors.data}"
  }
  nobits_section: "SHT_NOBITS (.bss)" {
    style.fill: "${colors.bss}"
    style.stroke-dash: 4
  }
  arrow_solid: "Data transfer"
  arrow_dashed: "Metadata only / Zero-fill"
}

key_invariants: |md
  ## Key Invariants
  **During Parsing:**
  - `.bss.data = NULL` (no allocation)
  - `.bss.size = sh_size` (tracked)
  
  **During Merging:**
  - `file_size` = sum of non-NOBITS sections
  - `mem_size` = sum of ALL allocatable sections
  
  **In Output Section:**
  - `.bss.file_size = 0`
  - `.bss.mem_size > 0`
  
  **In Data Segment:**
  - `p_filesz` = .data size only
  - `p_memsz` = .data + .bss size
| {near: bottom-center}