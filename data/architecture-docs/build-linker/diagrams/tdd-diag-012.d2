vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5E8"
    entry: "#D4E5F7"
    collision: "#FFF3CD"
    null: "#F5F5F5"
    pointer: "#C3E6CB"
    output: "#F8D7DA"
    index: "#E2E3E5"
  }
}
title: |md
  # Mapping Table Hash Structure
  **Key: "filename:section_name" → SectionMapping* → OutputSection***
| {near: top-center}
direction: right
# Hash Table Container
hash_table: "MappingTable" {
  style.fill: ${colors.header}
  style.stroke: "#6B5B6B"
  style.stroke-width: 2
  style.border-radius: 8
  # Table metadata
  header_row: {
    grid-columns: 4
    style.fill: "#D4C4D4"
    cap_label: "capacity = 16"
    count_label: "count = 5"
    load_label: "load_factor = 0.31"
    hash_label: "hash(key) % capacity"
    cap_label.style.fill: transparent
    count_label.style.fill: transparent
    load_label.style.fill: transparent
    hash_label.style.fill: transparent
    *.style.font-size: 14
    *.style.bold: true
  }
  # Entries array
  entries: "entries[]" {
    grid-rows: 8
    grid-columns: 3
    grid-gap: 0
    # Column headers
    idx_h: "Index" {style.fill: ${colors.index}; style.bold: true}
    key_h: "Hash Key" {style.fill: ${colors.index}; style.bold: true}
    value_h: "Value" {style.fill: ${colors.index}; style.bold: true}
    # Row 0 - Empty
    r0_idx: "0" {style.fill: ${colors.null}; style.font: mono}
    r0_key: "" {style.fill: ${colors.null}}
    r0_val: "NULL" {style.fill: ${colors.null}; style.font-color: "#999"}
    # Row 1 - Entry
    r1_idx: "1" {style.fill: ${colors.entry}; style.font: mono}
    r1_key: |md
      "main.o:.text"
      hash = 0x3A2F
    | {style.fill: ${colors.entry}; style.font-size: 12}
    r1_val: "→ Entry 1" {style.fill: ${colors.pointer}; style.bold: true}
    # Row 2 - Collision chain
    r2_idx: "2" {style.fill: ${colors.collision}; style.font: mono}
    r2_key: |md
      "utils.o:.text"
      hash = 0x3A31
      (collision!)
    | {style.fill: ${colors.collision}; style.font-size: 11}
    r2_val: "→ Entry 2" {style.fill: ${colors.pointer}; style.bold: true}
    # Row 3 - Empty
    r3_idx: "3" {style.fill: ${colors.null}; style.font: mono}
    r3_key: "" {style.fill: ${colors.null}}
    r3_val: "NULL" {style.fill: ${colors.null}; style.font-color: "#999"}
    # Row 4 - Tombstone
    r4_idx: "4" {style.fill: "#FFE5E5"; style.font: mono}
    r4_key: "TOMBSTONE" {style.fill: "#FFE5E5"; style.font-color: "#CC0000"; style.italic: true}
    r4_val: "(deleted)" {style.fill: "#FFE5E5"; style.font-color: "#999"}
    # Row 5 - Empty
    r5_idx: "5" {style.fill: ${colors.null}; style.font: mono}
    r5_key: "" {style.fill: ${colors.null}}
    r5_val: "NULL" {style.fill: ${colors.null}; style.font-color: "#999"}
    # Row 6 - Entry
    r6_idx: "6" {style.fill: ${colors.entry}; style.font: mono}
    r6_key: |md
      "utils.o:.data"
      hash = 0x7B16
    | {style.fill: ${colors.entry}; style.font-size: 12}
    r6_val: "→ Entry 3" {style.fill: ${colors.pointer}; style.bold: true}
    # Row 7 - Empty
    r7_idx: "7" {style.fill: ${colors.null}; style.font: mono}
    r7_key: "" {style.fill: ${colors.null}}
    r7_val: "NULL" {style.fill: ${colors.null}; style.font-color: "#999"}
  }
}
# SectionMapping Details
mapping_details: "SectionMapping Entries" {
  style.fill: ${colors.pointer}
  style.stroke: "#5A8A5A"
  style.stroke-width: 2
  entry1: "Entry 1: main.o:.text" {
    style.fill: "#E8F5E9"
    e1_fields: {
      shape: class
      source_file: "char[256]"
      section_name: "char[64]"
      input_size: "uint64_t = 0x80"
      output_offset: "uint64_t = 0x0000"
      padding_before: "uint64_t = 0"
      source_data: "uint8_t*"
    }
  }
  entry2: "Entry 2: utils.o:.text" {
    style.fill: "#FFF8E1"
    e2_fields: {
      shape: class
      source_file: "char[256]"
      section_name: "char[64]"
      input_size: "uint64_t = 0x40"
      output_offset: "uint64_t = 0x0080"
      padding_before: "uint64_t = 0"
      source_data: "uint8_t*"
    }
  }
  entry3: "Entry 3: utils.o:.data" {
    style.fill: "#E8F5E9"
    e3_fields: {
      shape: class
      source_file: "char[256]"
      section_name: "char[64]"
      input_size: "uint64_t = 0x20"
      output_offset: "uint64_t = 0x0000"
      padding_before: "uint64_t = 0"
      source_data: "uint8_t*"
    }
  }
}
# OutputSection Reference
output_section: "OutputSection" {
  style.fill: ${colors.output}
  style.stroke: "#8B5A5A"
  style.stroke-width: 2
  text_section: ".text Section" {
    style.fill: "#FCE4EC"
    text_fields: {
      shape: class
      name: "char[64] = \".text\""
      flags: "uint64_t = SHF_ALLOC|SHF_EXECINSTR"
      align: "uint64_t = 16"
      file_size: "uint64_t = 0xC0"
      mem_size: "uint64_t = 0xC0"
      virtual_addr: "uint64_t = 0x401000"
      data: "uint8_t*"
    }
  }
  data_section: ".data Section" {
    style.fill: "#FCE4EC"
    data_fields: {
      shape: class
      name: "char[64] = \".data\""
      flags: "uint64_t = SHF_ALLOC|SHF_WRITE"
      align: "uint64_t = 8"
      file_size: "uint64_t = 0x20"
      mem_size: "uint64_t = 0x20"
      virtual_addr: "uint64_t = 0x403000"
      data: "uint8_t*"
    }
  }
}
# Collision Resolution Explanation
collision_logic: "Linear Probing Logic" {
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.border-radius: 8
  probe_code: |go
    // Lookup with linear probing
    func lookup(key string) *Entry {
      idx := hash(key) % capacity
      for entries[idx].key != "" {
        if entries[idx].key == key {
          return &entries[idx]
        }
        idx = (idx + 1) % capacity  // Wrap around
      }
      return nil  // Not found
    }
  | {shape: code; style.fill: "#FFFDE7"}
  probe_steps: |md
    **Collision Resolution Steps:**
    1. Hash "utils.o:.text" → 0x3A31
    2. 0x3A31 % 16 = 1 (collision with main.o:.text)
    3. Probe: (1+1) % 16 = 2 ✓ (empty slot found)
    4. Insert at index 2
  | {style.fill: "#FFFDE7"}
}
# Connections
hash_table.entries.r1_val -> mapping_details.entry1: "mapping*"
hash_table.entries.r2_val -> mapping_details.entry2: "mapping*"
hash_table.entries.r6_val -> mapping_details.entry3: "mapping*"
mapping_details.entry1 -> output_section.text_section: "output*"
mapping_details.entry2 -> output_section.text_section: "output*"
mapping_details.entry3 -> output_section.data_section: "output*"
# Collision arrow (dashed to show probing path)
hash_table.entries.r1_key -> hash_table.entries.r2_key: "probe →" {
  style.stroke-dash: 3
  style.stroke: "#FF8F00"
  style.animated: true
}
# Legend
legend: {
  near: bottom-center
  leg_title: "Legend" {style.bold: true; style.fill: transparent}
  grid-columns: 4
  l1: "Entry" {style.fill: ${colors.entry}}
  l2: "Collision" {style.fill: ${colors.collision}}
  l3: "NULL" {style.fill: ${colors.null}}
  l4: "Tombstone" {style.fill: "#FFE5E5"}
}
# Stats box
stats: "Hash Table Statistics" {
  style.fill: "#E3F2FD"
  near: top-right
  s_content: |md
    **Performance Characteristics:**
    - Insert: O(1) average, O(n) worst
    - Lookup: O(1) average, O(n) worst
    - Delete: O(1) average (tombstone)
    **Memory Layout:**
    - Entry pointer: 8 bytes
    - Total overhead: capacity × 8 bytes
    - Target load factor: < 0.7
  |
}