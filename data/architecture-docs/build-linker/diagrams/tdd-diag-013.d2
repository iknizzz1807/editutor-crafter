vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B5B95"
    valid: "#88B04B"
    warning: "#F7CAC9"
    error: "#FF6F61"
    neutral: "#92A8D1"
    row_header: "#F5F5F5"
  }
}
title: |md
  # Section Flag Validation Matrix
  ### Decision Matrix for Merging Sections with Different Flag Combinations
| {near: top-center}
direction: right
# Legend
legend: {
  label: "Flag Legend"
  flag_alloc: "SHF_ALLOC (0x02)\nSection occupies memory"
  flag_write: "SHF_WRITE (0x01)\nSection is writable"
  flag_exec: "SHF_EXECINSTR (0x04)\nSection is executable"
  flag_alloc.style.fill: ${colors.neutral}
  flag_write.style.fill: "#FFB7B2"
  flag_exec.style.fill: "#B5EAD7"
  status_valid: "✓ VALID\nMerge allowed"
  status_warn: "⚠ WARN\nMerge with caution"
  status_error: "✗ ERROR\nMerge rejected"
  status_valid.style.fill: ${colors.valid}
  status_warn.style.fill: ${colors.warning}
  status_error.style.fill: ${colors.error}
}
# Main Decision Matrix
matrix: {
  label: "Flag Compatibility Matrix\n\nRows: Section A Flags | Columns: Section B Flags"
  # Column Headers
  col_none: "NONE\n(0x00)" {style.fill: ${colors.row_header}}
  col_alloc: "ALLOC\n(0x02)" {style.fill: ${colors.neutral}}
  col_write: "ALLOC|WRITE\n(0x03)" {style.fill: "#FFB7B2"}
  col_exec: "ALLOC|EXEC\n(0x06)" {style.fill: "#B5EAD7"}
  col_rw: "ALLOC|WRITE|EXEC\n(0x07)" {style.fill: "#C7CEEA"}
  col_none -> col_alloc -> col_write -> col_exec -> col_rw: {style.opacity: 0}
  # Row 1: NONE
  row_none: "NONE\n(0x00)" {style.fill: ${colors.row_header}}
  cell_none_none: "✓" {style.fill: ${colors.valid}}
  cell_none_alloc: "⚠" {style.fill: ${colors.warning}; label: "⚠\nA becomes\nALLOC"}
  cell_none_write: "⚠" {style.fill: ${colors.warning}; label: "⚠\nA becomes\nALLOC|WRITE"}
  cell_none_exec: "⚠" {style.fill: ${colors.warning}; label: "⚠\nA becomes\nALLOC|EXEC"}
  cell_none_rw: "⚠" {style.fill: ${colors.warning}; label: "⚠\nA becomes\nR|W|X"}
  row_none -> cell_none_none -> cell_none_alloc -> cell_none_write -> cell_none_exec -> cell_none_rw: {style.opacity: 0}
  # Row 2: ALLOC
  row_alloc: "ALLOC\n(0x02)" {style.fill: ${colors.neutral}}
  cell_alloc_none: "⚠" {style.fill: ${colors.warning}; label: "⚠\nB becomes\nALLOC"}
  cell_alloc_alloc: "✓" {style.fill: ${colors.valid}; label: "✓\n.rodata"}
  cell_alloc_write: "✓" {style.fill: ${colors.valid}; label: "✓\n.data\n(ro→rw)"}
  cell_alloc_exec: "✓" {style.fill: ${colors.valid}; label: "✓\n.text\n(ro→rx)"}
  cell_alloc_rw: "✓" {style.fill: ${colors.valid}; label: "✓\n.data\n(ro→rwx)"}
  row_alloc -> cell_alloc_none -> cell_alloc_alloc -> cell_alloc_write -> cell_alloc_exec -> cell_alloc_rw: {style.opacity: 0}
  # Row 3: ALLOC|WRITE
  row_write: "ALLOC|WRITE\n(0x03)" {style.fill: "#FFB7B2"}
  cell_write_none: "⚠" {style.fill: ${colors.warning}; label: "⚠\nB becomes\nALLOC|WRITE"}
  cell_write_alloc: "✓" {style.fill: ${colors.valid}; label: "✓\n.data\n(rw←ro)"}
  cell_write_write: "✓" {style.fill: ${colors.valid}; label: "✓\n.data"}
  cell_write_exec: "✗" {style.fill: ${colors.error}; label: "✗\nW^X\nVIOLATION"}
  cell_write_rw: "✗" {style.fill: ${colors.error}; label: "✗\nW^X\nVIOLATION"}
  row_write -> cell_write_none -> cell_write_alloc -> cell_write_write -> cell_write_exec -> cell_write_rw: {style.opacity: 0}
  # Row 4: ALLOC|EXEC
  row_exec: "ALLOC|EXEC\n(0x06)" {style.fill: "#B5EAD7"}
  cell_exec_none: "⚠" {style.fill: ${colors.warning}; label: "⚠\nB becomes\nALLOC|EXEC"}
  cell_exec_alloc: "✓" {style.fill: ${colors.valid}; label: "✓\n.text\n(rx←ro)"}
  cell_exec_write: "✗" {style.fill: ${colors.error}; label: "✗\nW^X\nVIOLATION"}
  cell_exec_exec: "✓" {style.fill: ${colors.valid}; label: "✓\n.text"}
  cell_exec_rw: "✗" {style.fill: ${colors.error}; label: "✗\nW^X\nVIOLATION"}
  row_exec -> cell_exec_none -> cell_exec_alloc -> cell_exec_write -> cell_exec_exec -> cell_exec_rw: {style.opacity: 0}
  # Row 5: ALLOC|WRITE|EXEC
  row_rw: "ALLOC|WRITE|EXEC\n(0x07)" {style.fill: "#C7CEEA"}
  cell_rw_none: "⚠" {style.fill: ${colors.warning}; label: "⚠\nB becomes\nR|W|X"}
  cell_rw_alloc: "✓" {style.fill: ${colors.valid}; label: "✓\n(rwx←ro)"}
  cell_rw_write: "✗" {style.fill: ${colors.error}; label: "✗\nW^X\nVIOLATION"}
  cell_rw_exec: "✗" {style.fill: ${colors.error}; label: "✗\nW^X\nVIOLATION"}
  cell_rw_rw: "⚠" {style.fill: ${colors.warning}; label: "⚠\nSecurity\nRisk"}
  row_rw -> cell_rw_none -> cell_rw_alloc -> cell_rw_write -> cell_rw_exec -> cell_rw_rw: {style.opacity: 0}
}
# Decision Rules
rules: {
  label: "Merging Rules"
  rule1: {
    label: "Rule 1: Flag Union\nMerged section gets union of all flags"
    style.fill: ${colors.neutral}
  }
  rule2: {
    label: "Rule 2: W^X Enforcement\nWRITE + EXEC = ERROR\n(Write XOR Execute)"
    style.fill: ${colors.error}
  }
  rule3: {
    label: "Rule 3: Non-ALLOC Warning\nNon-ALLOC merged with ALLOC\ngets ALLOC flag (may affect layout)"
    style.fill: ${colors.warning}
  }
  rule4: {
    label: "Rule 4: Same Permissions\nSections with same flags\nalways merge cleanly"
    style.fill: ${colors.valid}
  }
  rule1 -> rule2 -> rule3 -> rule4: {style.opacity: 0}
}
# Section Type Examples
examples: {
  label: "Typical Section Flag Assignments"
  text: ".text\nALLOC|EXEC\n(0x06)" {style.fill: "#B5EAD7"}
  rodata: ".rodata\nALLOC\n(0x02)" {style.fill: ${colors.neutral}}
  data: ".data\nALLOC|WRITE\n(0x03)" {style.fill: "#FFB7B2"}
  bss: ".bss\nALLOC|WRITE\n(0x03)" {style.fill: "#FFB7B2"}
  debug: ".debug_*\nNONE\n(0x00)" {style.fill: ${colors.row_header}}
  text -> rodata -> data -> bss -> debug: {style.opacity: 0}
}
# Merge Decision Flow
flow: {
  label: "Merge Decision Flow"
  start: "Input Section A\n+ Input Section B"
  check_alloc: "Both ALLOC?" {
    shape: diamond
    style.fill: ${colors.neutral}
  }
  check_wx: "WRITE ∧ EXEC?" {
    shape: diamond
    style.fill: ${colors.warning}
  }
  result_warn: "⚠ WARN\nAssign union of flags\nNon-ALLOC becomes ALLOC"
  result_valid: "✓ MERGE\nUnion flags to output"
  result_error: "✗ REJECT\nW^X violation\nCannot merge"
  start -> check_alloc
  check_alloc -> check_wx: "Yes"
  check_alloc -> result_warn: "No" {label: "No"}
  check_wx -> result_valid: "No" {label: "No"}
  check_wx -> result_error: "Yes"
  result_warn.style.fill: ${colors.warning}
  result_valid.style.fill: ${colors.valid}
  result_error.style.fill: ${colors.error}
}
legend -> matrix -> rules
rules -> examples -> flow