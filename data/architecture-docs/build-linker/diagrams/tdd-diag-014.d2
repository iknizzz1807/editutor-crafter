vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # File Offset vs Virtual Address Assignment
  **Technical Specification: ELF Program Header Mapping Logic**
  *Constraint: (p_offset % p_align) == (p_vaddr % p_align)*
| {near: top-center}

direction: right

classes: {
  header: {
    style: {
      fill: "#E8D5E0"
      stroke: "#7B5E7B"
      bold: true
      stroke-width: 2
    }
  }
  code_seg: {
    label: ""
    style: {
      fill: "#D4E8D4"
      stroke: "#5E8A5E"
      stroke-width: 2
    }
  }
  data_seg: {
    label: ""
    style: {
      fill: "#D4E0E8"
      stroke: "#5E7A8A"
      stroke-width: 2
    }
  }
  bss_seg: {
    label: ""
    style: {
      fill: "#E8E8D4"
      stroke: "#8A8A5E"
      stroke-dash: 3
    }
  }
  padding_area: {
    style: {
      fill: "#F5F5F5"
      stroke: "#CCCCCC"
      stroke-dash: 2
    }
  }
  address_label: {
    shape: text
    style: {
      font: mono
      font-size: 12
      font-color: "#D4A84B"
    }
  }
  offset_label: {
    shape: text
    style: {
      font: mono
      font-size: 12
      font-color: "#4B7FD4"
    }
  }
  table_header: {
    style: {
      fill: "#333333"
      stroke: "#000000"
      bold: true
      font-color: "#FFFFFF"
      font-size: 12
    }
  }
  table_cell: {
    style: {
      stroke: "#AAAAAA"
      font-size: 11
      font: mono
    }
  }
}

# ============================================================================
# PHYSICAL FILE LAYOUT (DISK STORAGE)
# ============================================================================
file_storage: "ELF BINARY ON DISK" {
  style.stroke-width: 4

  meta: {
    elf_hdr: "ELF Header\nOff: 0x0000 | Size: 64B" { class: header }
    phdrs: "Program Headers\nOff: 0x0040 | Size: N×56B" { class: header }
    elf_hdr -> phdrs: "contiguous"
  }

  pad_to_page: "Zero Padding\n(Align to 0x1000)" { class: padding_area }

  text_segment: "TEXT SEGMENT (R-X)" {
    class: code_seg
    txt_content: ".text Section\nExecutable Machine Code" { style.stroke-width: 1 }
    ro_content: ".rodata Section\nConstants & Strings" { style.stroke-width: 1 }
    txt_content -> ro_content: "ordered"
  }

  data_segment: "DATA SEGMENT (RW-)" {
    class: data_seg
    data_content: ".data Section\nInitialized Globals" { style.stroke-width: 1 }
  }

  meta -> pad_to_page -> text_segment -> data_segment: "File Offset Increase"
}

# ============================================================================
# VIRTUAL MEMORY LAYOUT (PROCESS SPACE)
# ============================================================================
virtual_memory: "PROCESS VIRTUAL ADDRESS SPACE" {
  style.stroke-width: 4

  text_vma: "LOADED TEXT (R-X)\nBase: 0x400000" {
    class: code_seg
    v_txt: ".text VMA"
    v_ro: ".rodata VMA"
    v_txt -> v_ro
  }

  vma_gap: "Address Gap\n(Unmapped Pages)" { class: padding_area }

  data_vma: "LOADED DATA (RW-)" {
    class: data_seg
    v_data: ".data VMA"
    v_bss: ".bss (Zeroed)" { class: bss_seg }
    v_data -> v_bss: "p_memsz > p_filesz"
  }

  text_vma -> vma_gap -> data_vma: "Address Increase"
}

# ============================================================================
# SYSTEM MAPPINGS (THE MMAP BRIDGE)
# ============================================================================
file_storage.text_segment -> virtual_memory.text_vma: "mmap(addr=0x401000, len, prot=R|X, offset=0x1000)" {
  style: {
    stroke: "#5E8A5E"
    stroke-width: 2
    stroke-dash: 5
    animated: true
  }
}

file_storage.data_segment -> virtual_memory.data_vma: "mmap(addr=0x403000, len, prot=R|W, offset=0x2000)" {
  style: {
    stroke: "#5E7A8A"
    stroke-width: 2
    stroke-dash: 5
    animated: true
  }
}

# ============================================================================
# TECHNICAL DETAILS & CONSTRAINTS
# ============================================================================
alignment_logic: "Alignment Mathematics" {
  near: top-right
  
  formula: |md
    ### The Golden Rule of Linking
    To allow the kernel to map the file using huge pages or standard pages efficiently:
    
    `p_offset % PageSize == p_vaddr % PageSize`
    
    Where `PageSize` is usually `0x1000` (4KB).
  | { style.fill: "#FFF8E7" }

  calc: {
    grid-rows: 3
    grid-columns: 1
    
    t1: "TEXT: 0x1000 % 0x1000 == 0x401000 % 0x1000 (0 == 0)" { style.font: mono }
    d1: "DATA: 0x2000 % 0x1000 == 0x403000 % 0x1000 (0 == 0)" { style.font: mono }
    result: "STATUS: ALIGNMENT VALIDATED" { style.bold: true; style.font-color: green }
  }
}

program_header_table: "Program Header View (readelf -l)" {
  grid-columns: 7
  grid-gap: 0
  
  h1: "Type"; h2: "Offset"; h3: "VirtAddr"; h4: "FileSiz"; h5: "MemSiz"; h6: "Flg"; h7: "Align"
  h*.class: table_header
  
  r1_1: "LOAD"; r1_2: "0x001000"; r1_3: "0x00401000"; r1_4: "0x0005E0"; r1_5: "0x0005E0"; r1_6: "R E"; r1_7: "0x1000"
  r2_1: "LOAD"; r2_2: "0x002000"; r2_3: "0x00403000"; r2_4: "0x000120"; r2_5: "0x000300"; r2_6: "RW "; r2_7: "0x1000"
  r*.class: table_cell
}

# ============================================================================
# BSS LOGIC ANNOTATION
# ============================================================================
bss_infographic: |md
  ## Understanding .bss
  - **File:** Size is 0. Does not occupy disk space.
  - **Memory:** Size is defined by `p_memsz - p_filesz`.
  - **Action:** Loader allocates zeroed pages at the end of the data segment.
| {
  near: bottom-right
  style.fill: "#E8E8D4"
  style.stroke: "#8A8A5E"
}

# Offset and Vaddr annotations using tooltips for ELK compliance
file_storage.meta.elf_hdr.tooltip: "Absolute Offset: 0x0000"
file_storage.text_segment.tooltip: "File Offset: 0x1000 (Page Aligned)"
virtual_memory.text_vma.tooltip: "Virtual Address: 0x401000"
virtual_memory.data_vma.tooltip: "Virtual Address: 0x403000"

legend: {
  near: bottom-left
  c: "Code Segment" { class: code_seg }
  d: "Data Segment" { class: data_seg }
  b: "BSS Segment" { class: bss_seg }
  p: "Padding" { class: padding_area }
}