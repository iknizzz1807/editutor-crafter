vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |'md
# Symbol Resolution Module Architecture
**Milestone 2: Building the Global Address Book**
'| {
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# =============================================================================
# DATA STRUCTURES
# =============================================================================
DataStructures: {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  
  # Symbol struct from input object file
  Symbol: {
    shape: class
    style.fill: "#FFF5E6"
    style.stroke: "#E07A5F"
    
    # Offsets in bytes
    "0x00: name": "char[256]"
    "0x100: type": "uint8_t"
    "0x101: binding": "uint8_t"
    "0x102: visibility": "uint8_t"
    "0x103: padding": "uint8_t"
    "0x104: section_idx": "uint16_t"
    "0x108: value": "uint64_t"
    "0x110: size": "uint64_t"
    "0x118: source_file_idx": "int"
    "0x120: final_addr": "uint64_t"
    
    label: "struct Symbol (Input Object)"
  }

  # GlobalSymbol in unified table
  GlobalSymbol: {
    shape: class
    style.fill: "#E6F3E6"
    style.stroke: "#4A7C59"
    
    "0x00: name_ptr": "char*"
    "0x08: type": "uint8_t"
    "0x09: binding": "uint8_t"
    "0x0A: state": "SymbolState"
    "0x0B: is_strong": "uint8_t"
    "0x0C: source_idx": "int"
    "0x10: section_idx": "uint16_t"
    "0x18: section_off": "uint64_t"
    "0x20: final_addr": "uint64_t"
    "0x28: common_size": "uint64_t"
    "0x30: common_align": "uint64_t"
    "0x38: ref_count": "int"
    
    label: "struct GlobalSymbol (Unified)"
  }

  # Global Symbol Table (Hash Table)
  GlobalSymbolTable: {
    shape: class
    style.fill: "#F0E6F6"
    style.stroke: "#7B4B94"
    
    "0x00: entries": "GlobalSymbol**"
    "0x08: capacity": "size_t"
    "0x10: count": "size_t"
    "0x18: tombstones": "size_t"
    
    label: "struct GlobalSymbolTable"
  }

  Symbol -> GlobalSymbol: "merges into" {
    style.stroke-dash: 3
  }
  GlobalSymbolTable -> GlobalSymbol: "points to"
}

# =============================================================================
# SYMBOL STATE ENUM
# =============================================================================
SymbolState: {
  style.fill: "#FFF9E6"
  style.stroke: "#D4A373"
  
  UNDEF: "Referenced but not defined" {
    style.fill: "#FFBABA"
  }
  DEFINED: "Has definition (strong/weak)" {
    style.fill: "#C2FFC2"
  }
  COMMON: "COMMON awaiting allocation" {
    style.fill: "#D1D1FF"
  }
  RESOLVED: "Final address assigned" {
    style.fill: "#FFFFFF"
    style.double-border: true
  }

  UNDEF -> DEFINED: "Strong definition found"
  DEFINED -> RESOLVED: "Section layout complete"
  COMMON -> RESOLVED: "Allocated in .bss"
}

# =============================================================================
# HASH TABLE MECHANISM
# =============================================================================
HashTable: {
  style.fill: "#FCECE8"
  style.stroke: "#C44536"
  
  HashFunction: {
    shape: rectangle
    style.fill: "#FFEEDD"
    label: |'md
**djb2 Hash Algorithm**
c
uint32_t hash(char *str) {
  uint32_t h = 5381;
  while (*str)
    h = (h << 5) + h + *str++;
  return h;
}

'|
  }
  
  CollisionResolution: {
    shape: rectangle
    style.fill: "#FFEEDD"
    label: |'md
**Linear Probing Logic**
1. idx = hash % capacity
2. if (occupied && !match)
   idx = (idx + 1) % capacity
3. if (tombstone) reuse slot
'|
  }
  
  HashFunction -> CollisionResolution: "index generation"
}

# =============================================================================
# RESOLUTION METHODS
# =============================================================================
ResolutionMethods: {
  style.fill: "#E6F0FA"
  style.stroke: "#3D5A80"
  
  CollectSymbols: "collect_all_symbols()" { shape: rectangle; style.fill: "#D4E5F7" }
  ProcessLocal: "process_local_symbol()" { shape: rectangle; style.fill: "#D4E5F7" }
  ProcessGlobal: "process_global_symbol()" { shape: rectangle; style.fill: "#D4E5F7" }
  ProcessCommon: "process_common_symbol()" { shape: rectangle; style.fill: "#D4E5F7" }
  CheckUndefined: "check_undefined_symbols()" { shape: rectangle; style.fill: "#D4E5F7" }
  AssignAddresses: "assign_symbol_addresses()" { shape: rectangle; style.fill: "#D4E5F7" }

  CollectSymbols -> ProcessLocal
  ProcessLocal -> ProcessGlobal
  ProcessGlobal -> ProcessCommon
  ProcessCommon -> CheckUndefined
  CheckUndefined -> AssignAddresses
}

# =============================================================================
# RESOLUTION RULES
# =============================================================================
ResolutionRules: {
  style.fill: "#F5F0E6"
  style.stroke: "#8B7355"
  
  Rule1: {
    shape: rectangle
    label: |'md
**Strong + Strong**
STB_GLOBAL duplication
*Result: Linker Error*
'|
    style.fill: "#FFD6D6"
    style.stroke: "#C44536"
  }
  
  Rule2: {
    shape: rectangle
    label: |'md
**Strong + Weak**
STB_GLOBAL vs STB_WEAK
*Result: Strong wins*
'|
    style.fill: "#D6FFD6"
    style.stroke: "#4A7C59"
  }
  
  Rule3: {
    shape: rectangle
    label: |'md
**Weak + Weak**
Multiple STB_WEAK
*Result: First found wins*
'|
    style.fill: "#FFFACD"
    style.stroke: "#B8860B"
  }
  
  Rule4: {
    shape: rectangle
    label: |'md
**COMMON Merge**
SHN_COMMON symbols
*Result: Max size wins*
'|
    style.fill: "#E6E6FA"
    style.stroke: "#7B4B94"
  }
}

# =============================================================================
# PIPELINE FLOW
# =============================================================================
InputFiles: {
  style.fill: "#F0F0F0"
  style.stroke: "#666666"
  ObjectFile1: "main.o" { shape: document }
  ObjectFile2: "utils.o" { shape: document }
}

GlobalTableInstance: {
  style.fill: "#E6F3E6"
  style.stroke: "#4A7C59"
  label: |'md
**Runtime Table State**
| Name | Binding | Address |
|:-----|:--------|:--------|
| _start| GLOBAL | 0x401000 |
| exit  | GLOBAL | 0x401020 |
| data_v| WEAK   | 0x403000 |
| heap  | COMMON | 0x000000 |
'|
}

InputFiles -> DataStructures.Symbol: "Scanner parses ELF"
DataStructures.GlobalSymbolTable -> GlobalTableInstance: "Populates"
ResolutionMethods -> ResolutionRules: "Consults priority"

# =============================================================================
# LEGEND
# =============================================================================
Legend: {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#CCCCCC"
  
  L: Local {
    shape: circle
    style.fill: "#FFF5E6"
    style.stroke: "#E07A5F"
  }
  G: Global {
    shape: circle
    style.fill: "#E6F3E6"
    style.stroke: "#4A7C59"
  }
  W: Weak {
    shape: circle
    style.fill: "#F0E6F6"
    style.stroke: "#7B4B94"
  }
  C: COMMON {
    shape: circle
    style.fill: "#FFF9E6"
    style.stroke: "#D4A373"
  }
}