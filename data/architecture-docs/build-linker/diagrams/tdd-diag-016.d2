direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B5B95"
    data: "#4ECDC4"
    ptr: "#F39C12"
    meta: "#95A5A6"
    padding: "#D5D8DC"
    border: "#2C3E50"
  }
}

title: |'md
# Elf64_Sym Entry Memory Layout
**Total Size: 24 bytes** (0x18) — Standard Symbol Table Entry for 64-bit ELF
'| {
  near: top-center
}

# -----------------------------------------------------------------------------------------
# Memory Visualization Strip
# -----------------------------------------------------------------------------------------
elf_structure: {
  grid-columns: 3
  grid-gap: 0
  style.stroke-width: 0
  style.fill: transparent

  # Offset Column (Left Margin)
  offsets: {
    grid-columns: 1
    vertical-gap: 0
    style.stroke-width: 0
    
    o00: "0x00" { shape: text; style.font-color: "${colors.header}"; style.bold: true; height: 60 }
    o04: "0x04" { shape: text; style.font-color: "${colors.data}"; style.bold: true; height: 40 }
    o05: "0x05" { shape: text; style.font-color: "${colors.meta}"; style.bold: true; height: 40 }
    o06: "0x06" { shape: text; style.font-color: "${colors.ptr}"; style.bold: true; height: 40 }
    o08: "0x08" { shape: text; style.font-color: "${colors.ptr}"; style.bold: true; height: 100 }
    o10: "0x10" { shape: text; style.font-color: "${colors.header}"; style.bold: true; height: 100 }
    o18: "0x18" { shape: text; style.font-color: "#000000"; style.bold: true; height: 20 }
  }

  # Symbol Table Entry Fields (Center)
  sym_entry: {
    grid-columns: 1
    vertical-gap: 0
    style.stroke: "${colors.border}"
    style.stroke-width: 2

    st_name: {
      label: "st_name\n(uint32_t)"
      width: 400
      height: 60
      style.fill: "${colors.header}"
      style.font-color: white
      tooltip: "Index into string table for symbol name"
    }
    st_info: {
      label: "st_info (unsigned char)"
      width: 400
      height: 40
      style.fill: "${colors.data}"
      style.font-color: white
      tooltip: "Type and Binding attributes"
    }
    st_other: {
      label: "st_other (unsigned char)"
      width: 400
      height: 40
      style.fill: "${colors.meta}"
      style.font-color: white
      tooltip: "Visibility attributes"
    }
    st_shndx: {
      label: "st_shndx (uint16_t)"
      width: 400
      height: 40
      style.fill: "${colors.ptr}"
      style.font-color: white
      tooltip: "Section index"
    }
    st_value: {
      label: "st_value\n(uint64_t / Elf64_Addr)"
      width: 400
      height: 100
      style.fill: "${colors.ptr}"
      style.font-color: white
      tooltip: "Value (Address or offset)"
    }
    st_size: {
      label: "st_size\n(uint64_t / uint64_t)"
      width: 400
      height: 100
      style.fill: "${colors.header}"
      style.font-color: white
      tooltip: "Size of the associated object"
    }
    footer_mark: {
      label: ""
      height: 20
      style.stroke-width: 0
      style.fill: transparent
    }
  }

  # Size Column (Right Margin)
  sizes: {
    grid-columns: 1
    vertical-gap: 0
    style.stroke-width: 0

    s4: "4 bytes" { shape: text; height: 60 }
    s1a: "1 byte" { shape: text; height: 40 }
    s1b: "1 byte" { shape: text; height: 40 }
    s2: "2 bytes" { shape: text; height: 40 }
    s8a: "8 bytes" { shape: text; height: 100 }
    s8b: "8 bytes" { shape: text; height: 100 }
  }
}

# -----------------------------------------------------------------------------------------
# Documentation Panels
# -----------------------------------------------------------------------------------------
docs: {
  grid-columns: 2
  grid-gap: 30
  style.stroke-width: 0
  style.fill: transparent

  descriptions: {
    style.fill: "#F8F9FA"
    style.stroke: "#DEE2E6"
    style.border-radius: 8
    
    label: |'md
### Structure Field Reference
| Field | Type | Offset | Description |
| :--- | :--- | :--- | :--- |
| **st_name** | `uint32_t` | 0x00 | Index into `.strtab` section. |
| **st_info** | `unsigned char` | 0x04 | High 4 bits: Binding; Low 4 bits: Type. |
| **st_other** | `unsigned char` | 0x05 | Symbol visibility (default, hidden, etc). |
| **st_shndx** | `uint16_t` | 0x06 | Section index symbol resides in. |
| **st_value** | `uint64_t` | 0x08 | Virtual address or section offset. |
| **st_size** | `uint64_t` | 0x10 | Size in bytes of the symbol. |
'|
  }

  macros: {
    style.fill: "#E1F5FE"
    style.stroke: "#01579B"
    style.border-radius: 8
    
    label: |'md
### Bitfield Manipulation (Elf64)
c
// Accessing st_info
#define ELF64_ST_BIND(i)   ((i) >> 4)
#define ELF64_ST_TYPE(i)   ((i) & 0xf)

// Accessing st_other
#define ELF64_ST_VISIBILITY(o) ((o) & 0x03)

'|
  }

  binding_table: {
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.border-radius: 8
    label: |'md
### ST_BIND Values
| Val | Name | Meaning |
|:---|:---|:---|
| 0 | `STB_LOCAL` | Not visible outside object file |
| 1 | `STB_GLOBAL` | Visible to all combined files |
| 2 | `STB_WEAK` | Global, but overrideable |
'|
  }

  type_table: {
    style.fill: "#E8F5E9"
    style.stroke: "#1B5E20"
    style.border-radius: 8
    label: |'md
### ST_TYPE Values
| Val | Name | Meaning |
|:---|:---|:---|
| 0 | `STT_NOTYPE` | Type is not specified |
| 1 | `STT_OBJECT` | Data object (variable, array) |
| 2 | `STT_FUNC` | Function or executable code |
| 3 | `STT_SECTION` | Symbol associated with section |
| 4 | `STT_FILE` | Symbol is source file name |
'|
  }
}

# -----------------------------------------------------------------------------------------
# Spatial Relationship
# -----------------------------------------------------------------------------------------
elf_structure -> docs: {
  style.stroke-width: 0
}