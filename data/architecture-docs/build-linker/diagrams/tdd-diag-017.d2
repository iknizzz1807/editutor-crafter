direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F97316"
    text: "#10B981"
    process: "#6366F1"
    padding: "#64748B"
  }
}

title: |md
  # Symbol Table Parsing Data Flow
  ## Milestone 2: Symbol Resolution Module (TDD-017)
  *Target: Elf64_Sym (24B) -> Internal Symbol Struct Mapping*
| {near: top-center}

# Input: Raw ELF Sections from Binary
input_container: "ELF Input Sections" {
  style.fill: "#F8FAFC"
  style.stroke: "#CBD5E1"
  style.stroke-width: 2

  symtab_section: ".symtab Section" {
    style.fill: "${colors.data}"
    style.font-color: white
    width: 250
    symtab_bytes: ||md
      **Raw Bytes (Elf64_Sym × N)**
      *Byte Offset Layout per Entry:*
      - 0x00: st_name (uint32)
      - 0x04: st_info (uchar)
      - 0x05: st_other (uchar)
      - 0x06: st_shndx (uint16)
      - 0x08: st_value (uint64)
      - 0x10: st_size (uint64)
      *Total Size: 24 Bytes*
    ||
  }

  strtab_section: ".strtab Section" {
    style.fill: "${colors.text}"
    style.font-color: white
    width: 250
    strtab_content: ||md
      **String Table Content**
      *Null-terminated strings*
      
      Offset | Data
      -------|------
      0x00   | \0
      0x01   | m a i n \0
      0x06   | h e l p e r \0
      0x0D   | g l o b a l _ v a r \0
      0x18   | _ s t a r t \0
    ||
  }
}

# Processing Stage 1: Parsing Logic
parse_stage: "Processing: Raw Entry Parser" {
  style.fill: "#F1F5F9"
  style.stroke: "#94A3B8"

  parse_label: "Parse Elf64_Sym Entries" {
    shape: hexagon
    style.fill: "${colors.process}"
    style.font-color: white
  }

  elf64_sym_array: "Memory: Elf64_Sym Array" {
    style.fill: "${colors.data}"
    style.font-color: white
    width: 300
    
    entry_0: ||md
      **[0] NULL Symbol**
      - st_name: 0
      - st_info: 0
      - st_shndx: SHN_UNDEF
    ||
    
    entry_1: ||md
      **[1] main**
      - st_name: 0x01
      - st_info: 0x12 (GLOBAL|FUNC)
      - st_shndx: 1
      - st_value: 0x401000
    ||

    entry_2: ||md
      **[2] helper**
      - st_name: 0x06
      - st_info: 0x10 (GLOBAL|NOTYPE)
      - st_shndx: SHN_UNDEF
    ||
  }
}

# Processing Stage 2: Symbol Resolution
resolve_stage: "Processing: Name Resolver" {
  style.fill: "#F1F5F9"
  style.stroke: "#94A3B8"

  resolve_label: "Resolve Symbol Names" {
    shape: hexagon
    style.fill: "${colors.process}"
    style.font-color: white
  }

  lookup_process: "Lookup in .strtab" {
    shape: diamond
    style.fill: "${colors.pointer}"
    style.font-color: white
    width: 220
    lookup_detail: ||md
      **Name Resolution Protocol:**
      1. Fetch `st_name` (4-byte index)
      2. Base Addr = `sh_offset` of .strtab
      3. Target = `Base + st_name`
      4. `strcpy` into `Symbol.name`
    ||
  }
}

# Output: Structured Data Objects
output_container: "Application Symbol Table" {
  style.fill: "#F8FAFC"
  style.stroke: "#CBD5E1"
  style.stroke-width: 2

  symbol_array: "Parsed Symbol Structs" {
    style.fill: "${colors.header}"
    style.font-color: white
    width: 320
    
    symbol_0: ||md
      **Internal Symbol [0]**
      - name: "(null)"
      - type: STT_NOTYPE
      - binding: STB_LOCAL
      - defined: FALSE
    ||
    
    symbol_1: ||md
      **Internal Symbol [1]**
      - name: "main"
      - type: STT_FUNC
      - binding: STB_GLOBAL
      - addr: 0x401000
      - size: 26
    ||

    symbol_2: ||md
      **Internal Symbol [2]**
      - name: "helper"
      - type: STT_NOTYPE
      - binding: STB_GLOBAL
      - defined: FALSE (External)
    ||
  }
}

# Implementation Logic Detail
field_detail: "Field Extraction & Logic Mapping" {
  style.fill: "#FEF3C7"
  style.stroke: "#F59E0B"
  width: 400
  extraction_table: ||md
    ### Elf64_Sym -> Internal Symbol Mapping

    | ELF Source Field | Target Field | Extraction Logic |
    | :--- | :--- | :--- |
    | `st_name` | `name` | `(char*)(strtab + st_name)` |
    | `st_info >> 4` | `binding` | `ELF64_ST_BIND(val)` |
    | `st_info & 0xF`| `type` | `ELF64_ST_TYPE(val)` |
    | `st_other & 0x3`| `visibility`| `ELF64_ST_VISIBILITY(val)`|
    | `st_shndx` | `section_idx` | Direct Cast (uint16) |
    | `st_value` | `address` | Direct Cast (uint64) |

    **Binding Macro Reference:**
    c
    #define ELF64_ST_BIND(i)   ((i) >> 4)
    #define ELF64_ST_TYPE(i)   ((i) & 0xf)
    
  ||
}

# Data Flow Connections
input_container.symtab_section -> parse_stage.parse_label: "raw sym entries\nstream (24B blocks)"
input_container.strtab_section -> resolve_stage.lookup_process: "string pointer\nreference"

parse_stage.parse_label -> parse_stage.elf64_sym_array: "populate struct array"
parse_stage.elf64_sym_array -> resolve_stage.resolve_label: "pass Elf64_Sym[]"

resolve_stage.resolve_label -> resolve_stage.lookup_process: "per-symbol string lookup"
resolve_stage.lookup_process -> output_container.symbol_array: "emit resolved symbols"

# Side annotation/Mapping reference
field_detail -> parse_stage.elf64_sym_array: "logic spec" {
  style.stroke-dash: 3
  style.stroke: "${colors.pointer}"
}

# Legend
legend: {
  near: bottom-right
  style.fill: "#F8FAFC"
  style.stroke: "#CBD5E1"
  
  legend_title: "Data Flow Legend" {
    style.bold: true
  }
  
  input_legend: "Raw Binary Data" {
    style.fill: "${colors.data}"
    shape: square
  }
  process_legend: "Logic / Transformation" {
    style.fill: "${colors.process}"
    shape: hexagon
  }
  output_legend: "Resolved Application State" {
    style.fill: "${colors.header}"
    shape: square
  }
}