vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header-bg: "#E8E4F0"
    local-bg: "#D4EDDA"
    global-bg: "#FFF3CD"
    weak-bg: "#F8D7DA"
    notype-bg: "#E2E3E5"
    object-bg: "#CCE5FF"
    func-bg: "#D4EDDA"
    section-bg: "#FFF3CD"
    file-bg: "#F8D7DA"
  }
}

title: |md
  # Symbol Binding and Type Classification
  ## st_info Byte: High Nibble (Binding) × Low Nibble (Type)
| {near: top-center}

direction: right

# Main container to house the grid and provide a stable anchor
SymbolMapping: {
  style: {
    stroke-width: 0
    fill: transparent
  }

  matrix: {
    grid-rows: 5
    grid-columns: 6
    grid-gap: 0

    # --- ROW 0: HEADERS (STT_TYPE) ---
    corner: "BINDING \\ TYPE" {
      style: {
        fill: "${colors.header-bg}"
        stroke: "#666"
        font-size: 12
        bold: true
      }
    }
    h_notype: "STT_NOTYPE\n(0)" {
      style: {
        fill: "${colors.header-bg}"
        stroke: "#666"
        font-size: 11
        bold: true
      }
    }
    h_object: "STT_OBJECT\n(1)" {
      style: {
        fill: "${colors.header-bg}"
        stroke: "#666"
        font-size: 11
        bold: true
      }
    }
    h_func: "STT_FUNC\n(2)" {
      style: {
        fill: "${colors.header-bg}"
        stroke: "#666"
        font-size: 11
        bold: true
      }
    }
    h_section: "STT_SECTION\n(3)" {
      style: {
        fill: "${colors.header-bg}"
        stroke: "#666"
        font-size: 11
        bold: true
      }
    }
    h_file: "STT_FILE\n(4)" {
      style: {
        fill: "${colors.header-bg}"
        stroke: "#666"
        font-size: 11
        bold: true
      }
    }

    # --- ROW 1: STB_LOCAL ---
    r_local: "STB_LOCAL\n(0)\nFile Scope" {
      style: {
        fill: "${colors.local-bg}"
        stroke: "#666"
        font-size: 10
        bold: true
      }
    }
    local_notype: |md
      **0x00**
      Unnamed local
      label/debug
    | {
      style: {
        fill: "${colors.local-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    local_object: |md
      **0x01**
      `static int x;`
      Local variable
    | {
      style: {
        fill: "${colors.local-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    local_func: |md
      **0x02**
      `static void f()`
      Local function
    | {
      style: {
        fill: "${colors.local-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    local_section: |md
      **0x03**
      Section symbol
      Relocation base
    | {
      style: {
        fill: "${colors.local-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    local_file: |md
      **0x04**
      Source file name
      First in .symtab
    | {
      style: {
        fill: "${colors.local-bg}"
        stroke: "#999"
        font-size: 9
      }
    }

    # --- ROW 2: STB_GLOBAL ---
    r_global: "STB_GLOBAL\n(1)\nGlobal Scope" {
      style: {
        fill: "${colors.global-bg}"
        stroke: "#666"
        font-size: 10
        bold: true
      }
    }
    global_notype: |md
      **0x10**
      Rare: undefined
      or absolute
    | {
      style: {
        fill: "${colors.global-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    global_object: |md
      **0x11**
      `int global;`
      Global variable
      **STRONG**
    | {
      style: {
        fill: "${colors.global-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    global_func: |md
      **0x12**
      `void func()`
      Global function
      **STRONG**
    | {
      style: {
        fill: "${colors.global-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    global_section: |md
      **0x13**
      (Unused)
      Section refs use
      LOCAL
    | {
      style: {
        fill: "#F0F0F0"
        stroke: "#999"
        font-size: 9
        font-color: "#999"
      }
    }
    global_file: |md
      **0x14**
      (Unused)
      File symbols
      always LOCAL
    | {
      style: {
        fill: "#F0F0F0"
        stroke: "#999"
        font-size: 9
        font-color: "#999"
      }
    }

    # --- ROW 3: STB_WEAK ---
    r_weak: "STB_WEAK\n(2)\nWeak Binding" {
      style: {
        fill: "${colors.weak-bg}"
        stroke: "#666"
        font-size: 10
        bold: true
      }
    }
    weak_notype: |md
      **0x20**
      Weak undefined
      Resolves to 0
    | {
      style: {
        fill: "${colors.weak-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    weak_object: |md
      **0x21**
      `__weak int x;`
      Fallback variable
    | {
      style: {
        fill: "${colors.weak-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    weak_func: |md
      **0x22**
      `__weak void f()`
      Fallback function
      Overridable
    | {
      style: {
        fill: "${colors.weak-bg}"
        stroke: "#999"
        font-size: 9
      }
    }
    weak_section: |md
      **0x23**
      (Unused)
    | {
      style: {
        fill: "#F0F0F0"
        stroke: "#999"
        font-size: 9
        font-color: "#999"
      }
    }
    weak_file: |md
      **0x24**
      (Unused)
    | {
      style: {
        fill: "#F0F0F0"
        stroke: "#999"
        font-size: 9
        font-color: "#999"
      }
    }

    # --- ROW 4: EXAMPLES ---
    r_examples: "Common\nExamples" {
      style: {
        fill: "#E8E4F0"
        stroke: "#666"
        font-size: 10
        bold: true
      }
    }
    ex_notype: |md
      Undefined ref:
      `st_shndx=0`
      (SHN_UNDEF)
    | {
      style: {
        fill: "#E8E4F0"
        stroke: "#999"
        font-size: 9
      }
    }
    ex_object: |md
      Data symbols
      `int buffer[100]`
      (may be COMMON)
    | {
      style: {
        fill: "#E8E4F0"
        stroke: "#999"
        font-size: 9
      }
    }
    ex_func: |md
      Code symbols
      `_start`, `main`
      Entry points
    | {
      style: {
        fill: "#E8E4F0"
        stroke: "#999"
        font-size: 9
      }
    }
    ex_section: |md
      `.text`, `.data`
      Used in relocs
      `S + A` formula
    | {
      style: {
        fill: "#E8E4F0"
        stroke: "#999"
        font-size: 9
      }
    }
    ex_file: |md
      `main.c`
      `utils.c`
      Debug info
    | {
      style: {
        fill: "#E8E4F0"
        stroke: "#999"
        font-size: 9
      }
    }
  }
}

# Side legend for documentation
legend: {
  near: center-right
  direction: down
  
  structure: |md
    ## st_info Byte Structure
    
    The `st_info` byte packing:
    ┌───────────┬───────────┐
    │  Binding  │    Type   │
    │  (4 bits) │  (4 bits) │
    └───────────┴───────────┘
       High         Low
      Nibble       Nibble
  | {shape: text}
  
  extraction: |`md
    ## Extraction Macros (C)
    c
    #define ELF64_ST_BIND(i)   ((i) >> 4)
    #define ELF64_ST_TYPE(i)   ((i) & 0xF)
    #define ELF64_ST_INFO(b,t) (((b)<<4)|((t)&0xF))
    
  `| {shape: text}
  
  resolution: |md
    ## Linker Resolution Rules
    **STRONG (STB_GLOBAL):**
    - Strong + Strong = Linker Error
    - Strong + Weak = Strong Wins
    - Strong + Undefined = Symbol Defined
    
    **WEAK (STB_WEAK):**
    - Weak + Weak = First one wins
    - Weak + Undefined = Weak defined
    - Weak undefined = Resolves to 0 (NULL)
  | {shape: text}
}

# Footer annotation regarding symbol table layout
footer_note: |`md
  **Symbol Table Ordering Requirements:**
  1. Index 0 is always the `STN_UNDEF` null symbol.
  2. Symbols with `STB_LOCAL` binding must precede all `STB_GLOBAL` and `STB_WEAK` symbols.
  3. The `.symtab` section header's `sh_info` field holds the index of the first non-local symbol.
`| {
  near: bottom-center
  shape: text
  style: {
    font-size: 11
    font-color: "#444"
    italic: true
  }
}