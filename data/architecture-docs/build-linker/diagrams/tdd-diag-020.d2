vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header: "#7B68EE"
    data: "#4A90D9"
    free: "#50C878"
    error: "#E74C3C"
    success: "#27AE60"
    decision: "#F39C12"
    start: "#9B59B6"
    padding: "#D3D3D3"
  }
}

title: |'md
  # Duplicate Symbol Detection Algorithm
  ## Linker Resolution & Conflict Detection Logic
'| {near: top-center}

direction: down

# Symbol Memory Representation (Intel Manual Quality Layout)
symbol_entry_layout: {
  label: "MEMORY LAYOUT: Symbol Entry (32 Bytes)"
  near: top-right
  
  0x00: "Name Index (Offset into String Table)" {
    style.fill: "#DDA0DD"
    width: 250
  }
  0x04: "Value (Address or Offset)" {
    style.fill: "#ADD8E6"
    width: 250
  }
  0x0C: "Size" {
    style.fill: "#ADD8E6"
    width: 250
  }
  0x10: "Info (Binding/Type)" {
    style.fill: "#FFA07A"
    width: 250
  }
  0x11: "Other (Visibility)" {
    style.fill: "#90EE90"
    width: 250
  }
  0x12: "Section Index" {
    style.fill: "#F0E68C"
    width: 250
  }
}

# Start node
start: "EVENT: NEW SYMBOL RECEIVED\n(name, binding, section)" {
  shape: circle
  style.fill: ${colors.start}
  style.font-color: white
  style.bold: true
}

# Step 1: Lookup existing
step1_lookup: {
  label: "STEP 1: Symbol Table Probe"
  style.fill: ${colors.header}
  style.font-color: white
  
  lookup_action: "ptr = hash_table_lookup(global_table, sym_name)" {
    shape: rectangle
    style.fill: ${colors.data}
    style.font-color: white
  }
  
  lookup_result: "Status: pointer or NULL" {
    shape: rectangle
    style.fill: ${colors.free}
    style.font-color: black
    style.stroke-dash: 3
  }
}

# Decision 1: Exists?
decision1_exists: "Global\nDefinition\nExists?" {
  shape: diamond
  style.fill: ${colors.decision}
  style.font-color: white
  style.bold: true
}

# Step 2: Check existing.is_strong
step2_check_existing: {
  label: "STEP 2: Analyze Existing Symbol"
  style.fill: ${colors.header}
  style.font-color: white
  
  check_existing: "is_existing_strong = (global->st_shndx != SHN_UNDEF)\nAND (global->binding == STB_GLOBAL)" {
    shape: rectangle
    style.fill: ${colors.data}
    style.font-color: white
  }
}

# Decision 2: Existing strong?
decision2_existing_strong: "Existing is\nSTRONG?" {
  shape: diamond
  style.fill: ${colors.decision}
  style.font-color: white
  style.bold: true
}

# Step 3: Check new.is_strong
step3_check_new: {
  label: "STEP 3: Analyze New Symbol"
  style.fill: ${colors.header}
  style.font-color: white
  
  check_new: "is_new_strong = (sym->st_shndx != SHN_UNDEF)\nAND (sym->binding == STB_GLOBAL)" {
    shape: rectangle
    style.fill: ${colors.data}
    style.font-color: white
  }
}

# Decision 3: New strong?
decision3_new_strong: "New is\nSTRONG?" {
  shape: diamond
  style.fill: ${colors.decision}
  style.font-color: white
  style.bold: true
}

# Error case
error_duplicate: {
  label: "FATAL: DUPLICATE SYMBOL"
  style.fill: ${colors.error}
  style.font-color: white
  style.bold: true
  
  error_msg: |'md
    **ERROR: SYM_RES_CONFLICT**
    
    c
    fprintf(stderr, 
      "duplicate symbol: %s\n"
      "  obj A: %s (STRONG)\n"
      "  obj B: %s (STRONG)\n",
      name, obj_a, obj_b);
    
  '| {
    shape: rectangle
    style.fill: "#FFE6E6"
    style.stroke: ${colors.error}
    style.stroke-width: 3
  }
}

# Success cases
success_define: "ACTION: OVERRIDE\nUse new definition" {
  shape: rectangle
  style.fill: ${colors.success}
  style.font-color: white
  style.bold: true
  style.stroke-width: 2
}

success_keep: "ACTION: IGNORE\nKeep current definition" {
  shape: rectangle
  style.fill: ${colors.success}
  style.font-color: white
  style.bold: true
  style.stroke-width: 2
}

success_first: "ACTION: INITIALIZE\nInsert into Global Table" {
  shape: rectangle
  style.fill: ${colors.success}
  style.font-color: white
  style.bold: true
  style.stroke-width: 2
}

# Connections
start -> step1_lookup
step1_lookup -> decision1_exists

decision1_exists -> success_first: "NO" {
  style.stroke: ${colors.success}
  style.font-color: ${colors.success}
  style.bold: true
}

decision1_exists -> step2_check_existing: "YES" {
  style.stroke: ${colors.data}
  style.font-color: ${colors.data}
  style.bold: true
}

step2_check_existing -> decision2_existing_strong

decision2_existing_strong -> step3_check_new: "YES" {
  style.stroke: ${colors.decision}
  style.font-color: ${colors.decision}
}

decision2_existing_strong -> success_define: "NO\n(Weak existing)" {
  style.stroke: ${colors.success}
  style.font-color: ${colors.success}
}

step3_check_new -> decision3_new_strong

decision3_new_strong -> error_duplicate: "YES" {
  style.stroke: ${colors.error}
  style.font-color: ${colors.error}
  style.bold: true
}

decision3_new_strong -> success_keep: "NO\n(New is weak)" {
  style.stroke: ${colors.success}
  style.font-color: ${colors.success}
}

error_duplicate -> terminate: "ABORT" {
  style.stroke: ${colors.error}
  style.animated: true
}

terminate: "PROCESS TERMINATED\n(Status 1)" {
  shape: circle
  style.fill: ${colors.error}
  style.font-color: white
  style.bold: true
}

# Legend
legend: {
  near: bottom-right
  label: "Logic Component Legend"
  
  step: "Computational Block" {
    style.fill: ${colors.data}
    style.font-color: white
  }
  decision: "Conditional Branch" {
    shape: diamond
    style.fill: ${colors.decision}
    style.font-color: white
  }
  terminal: "Resolution End-State" {
    style.fill: ${colors.success}
    style.font-color: white
  }
  error: "Critical Failure" {
    style.fill: ${colors.error}
    style.font-color: white
  }
}

# Algorithm summary box
summary: |'md
  ## Symbol Resolution Matrix
  
  | Existing Sym | Incoming Sym | Linker Action |
  | :--- | :--- | :--- |
  | **Strong** | **Strong** | ❌ **Error: Duplicate** |
  | **Strong** | **Weak** | ✅ Keep Existing |
  | **Weak** | **Strong** | ✅ Replace with New |
  | **Weak** | **Weak** | ✅ Keep First Found |
  | **None** | **Any** | ✅ Create Entry |

  ### Rule of Thumb:
  *Strong symbols win over weak ones. Multiple strong symbols in the global scope are illegal.*
'| {
  near: bottom-left
  style.stroke: "#333"
  style.stroke-width: 1
  style.fill: "#F9F9F9"
}