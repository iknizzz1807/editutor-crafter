vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 25
  }
}

title: |md
  # COMMON Symbol Merging Flow
  **Specification**: ELF Symbol Resolution for Tentative Definitions (SHN_COMMON)
  *SHT_COMMON Detection → Size Comparison → Largest Wins → .bss Allocation*
| {near: top-center}

direction: right

classes: {
  header_box: {
    style: {
      stroke-width: 2
      border-radius: 4
      shadow: true
    }
  }
  symbol_logic: {
    shape: rectangle
    style: {
      stroke-width: 1
      font-size: 13
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FFFFFF"
    }
  }
  memory_field: {
    style: {
      font: mono
    }
  }
}

# Stage 1: SHT_COMMON Detection
detection: {
  label: "STAGE 1: Input Analysis & Identification"
  class: header_box
  style.fill: "#E8D5E8"
  style.stroke: "#7B4D7B"

  # FIX: Removed newline from the primary label of the sql_table
  input_sym: "Elf64_Sym: Input Symbol Structure" {
    shape: sql_table
    style.fill: "#7B4D7B" # Header color
    
    st_name: "0x00: st_name (uint32)" {constraint: "4B"}
    st_info: "0x04: st_info (uchar)" {constraint: "1B"}
    st_other: "0x05: st_other (uchar)" {constraint: "1B"}
    st_shndx: "0x06: st_shndx (uint16)" {
      constraint: "2B"
      style.bold: true
      style.fill: "#D5B8D5"
    }
    st_value: "0x08: st_value (uint64)" {constraint: "8B"}
    st_size: "0x10: st_size (uint64)" {constraint: "8B"}
    
    tooltip: "sizeof=24 bytes"
  }

  check_section: "Check st_shndx == SHN_COMMON?"
  check_section.shape: diamond
  check_section.style.fill: "#F5F0F5"

  is_common: "Tentative Definition (SHN_COMMON 0xFFF2)" {
    class: symbol_logic
    style.fill: "#C8A8C8"
    style.stroke: "#7B4D7B"
    style.bold: true
  }

  not_common: "Standard Definition (SHT_PROGBITS)" {
    class: symbol_logic
    style.fill: "#E0E0E0"
  }

  input_sym.st_shndx -> check_section: "Read 2 Bytes"
  
  check_section -> is_common: "Match"
  check_section -> not_common: "Mismatch"
}

# Stage 2: Global Symbol Table Resolution
comparison: {
  label: "STAGE 2: Global Symbol Conflict Resolution"
  class: header_box
  style.fill: "#D5E8D5"
  style.stroke: "#4D7B4D"

  lookup: "Global Hash Table Lookup" {
    style.fill: "#E8F5E8"
  }

  check_exists: "Entry Exists?"
  check_exists.shape: diamond
  check_exists.style.fill: "#E8F5E8"

  first_common: "New Global Entry: SYM_STATE_COMMON" {
    class: symbol_logic
    style.fill: "#A8D8A8"
    style.bold: true
  }

  compare_sizes: "Update logic: size = MAX(S1, S2)"
  compare_sizes.shape: diamond
  compare_sizes.style.fill: "#E8F5E8"

  keep_largest: "Update size to New (Larger)" {
    class: symbol_logic
    style.fill: "#88C888"
    style.bold: true
  }

  keep_existing: "Retain Existing (Larger)" {
    class: symbol_logic
    style.fill: "#C8E8C8"
  }

  lookup -> check_exists
  check_exists -> first_common: "NULL (First)"
  check_exists -> compare_sizes: "Exists"
  
  compare_sizes -> keep_largest: "New > Existing"
  compare_sizes -> keep_existing: "New <= Existing"
}

# Stage 3: Linking Semantic Rules
rules: {
  label: "STAGE 3: Merging Precedence Rules"
  class: header_box
  style.fill: "#E8E8D5"
  style.stroke: "#7B7B4D"

  rule_box: {
    grid-columns: 1
    style.fill: "#F5F5E0"
    
    rule1: "RULE 1: COMMON + COMMON" {
      style.bold: true
    }
    rule1_desc: "Result: Largest size wins. Alignment = MAX(AlignA, AlignB)." {
      style.font-size: 11
    }
    
    rule2: "RULE 2: STRONG + COMMON" {
      style.bold: true
    }
    rule2_desc: "Result: Strong (initialized) wins. COMMON is ignored/merged." {
      style.font-size: 11
    }
    
    rule3: "RULE 3: WEAK + COMMON" {
      style.bold: true
    }
    rule3_desc: "Result: COMMON wins over WEAK; COMMON promotes to Strong." {
      style.font-size: 11
    }
  }
}

# Stage 4: Layout and .bss mapping
allocation: {
  label: "STAGE 4: Final Binary Layout (.bss)"
  class: header_box
  style.fill: "#D5D5E8"
  style.stroke: "#4D4D7B"

  resolution_phase: "Resolution Complete" {
    style.fill: "#E8E8F5"
  }

  find_bss: "Target: .bss (SHT_NOBITS)" {
    style.fill: "#E8E8F5"
  }

  align: "Apply Alignment: ALIGN(p, sym.align)" {
    style.fill: "#C8C8E8"
  }

  allocate: "MAP TO VIRTUAL ADDR" {
    class: symbol_logic
    style.fill: "#A8A8D8"
    style.bold: true
  }

  update_bss: ".bss.sh_size += sym.size" {
    style.fill: "#C8C8E8"
  }

  mark_resolved: "STATE: RESOLVED" {
    class: symbol_logic
    style.fill: "#8888C8"
    style.bold: true
  }

  resolution_phase -> find_bss
  find_bss -> align
  align -> allocate
  allocate -> update_bss
  update_bss -> mark_resolved
}

# Real-world Scenario Example
example: {
  label: "PRACTICAL EXAMPLE: Variable 'buffer'"
  style.fill: "#F9F9F9"
  style.stroke: "#888888"

  file1: "file1.o: int buf[100]; (400B)" {
    style.fill: "#FFE8E8"
  }
  file2: "file2.o: int buf[200]; (800B)" {
    style.fill: "#E8FFE8"
  }
  file3: "file3.o: int buf[50]; (200B)" {
    style.fill: "#E8E8FF"
  }

  result_node: "RESULT: buf in .bss\nSize: 800 Bytes\nType: STT_OBJECT" {
    style.fill: "#FFFFD0"
    style.bold: true
    style.double-border: true
  }

  file1 -> result_node: "COMMON"
  file2 -> result_node: "COMMON (MAX)"
  file3 -> result_node: "COMMON"
}

# Global Connections
detection.is_common -> comparison.lookup: "Queue for resolution"
comparison.keep_largest -> rules.rule_box: "Final Size Known"
comparison.keep_existing -> rules.rule_box: "Final Size Known"
rules.rule_box -> allocation.resolution_phase: "Pass symbols to Layout"

# Data Structure Visualization
data_struct: {
  label: "LINKER INTERNAL DATA"
  style.fill: "#F0F0F0"
  
  global_sym: "Linker_Symbol_Entry {" {
    shape: code
    content: "  name: 'buffer'\n  state: SYM_STATE_COMMON\n  common_size: 800\n  common_align: 16\n  st_value: 0x403010  // Set during Stage 4"
    style.fill: "#FFFFFF"
  }
  
  output_bss: "Section_Header .bss {" {
    shape: code
    content: "  sh_type: SHT_NOBITS\n  sh_flags: SHF_ALLOC | SHF_WRITE\n  sh_size: 0x320      // 800 bytes total\n  sh_offset: 0x1000   // No disk space used"
    style.fill: "#FFFFFF"
  }
}

# Legend for Visual Parsing
legend: {
  near: bottom-right
  label: "Legend"
  
  st1: "Stage 1: Logic Analysis" { style.fill: "#E8D5E8" }
  st2: "Stage 2: Table Operations" { style.fill: "#D5E8D5" }
  st3: "Stage 3: Linking Rules" { style.fill: "#E8E8D5" }
  st4: "Stage 4: Binary Layout" { style.fill: "#D5D5E8" }
}

insight: |md
  ### Implementation Note: SHT_NOBITS
  - COMMON symbols do not exist in any section of the input object file.
  - The `st_shndx` value `0xFFF2` is a "special index" indicating tentative placement.
  - The Linker must manually reserve space in the `.bss` section for the resulting global definition.
  - Runtime: OS `mmap`s anonymous memory to fulfill the `.bss` segment requirements.
| {
  near: bottom-center
  style: {
    fill: "#FFF8DC"
    stroke: "#DAA520"
    border-radius: 8
  }
}