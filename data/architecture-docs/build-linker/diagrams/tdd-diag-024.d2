title: {
  label: ||md
    # GlobalSymbol Struct Memory Layout
    **Total Size**: 144 Bytes (0x90) | **Alignment**: 8-byte
  ||
  shape: text
  near: top-center
}

GlobalSymbol: {
  style: {
    fill: white
    stroke: "#2C3E50"
    stroke-width: 2
  }

  table_header: {
    label: ||md
      **Offset** | **Field Name** | **Data Type [Size]** | **Technical Description**
    ||
    shape: text
    style.font: mono
    style.bold: true
  }

  mem_map: {
    grid-columns: 4
    grid-gap: 0

    # HEADERS
    h1: "OFFSET" {style: {fill: "${vars.colors.bg_light}"; stroke: "${vars.colors.intel_border}"; bold: true}}
    h2: "FIELD" {style: {fill: "${vars.colors.bg_light}"; stroke: "${vars.colors.intel_border}"; bold: true}}
    h3: "TYPE [BYTES]" {style: {fill: "${vars.colors.bg_light}"; stroke: "${vars.colors.intel_border}"; bold: true}}
    h4: "DESCRIPTION" {style: {fill: "${vars.colors.bg_light}"; stroke: "${vars.colors.intel_border}"; bold: true}}

    # Row 0: name[0-31]
    f00_off: "0x00" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f00_name: "name[0..31]" {style: {fill: "${vars.colors.data_blue}"; font-color: white; font: mono; bold: true}}
    f00_type: "char[32]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f00_desc: "Symbol name string buffer (Part 1/2)" {style.fill: white}

    # Row 1: name[32-63]
    f01_off: "0x20" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f01_name: "name[32..63]" {style: {fill: "${vars.colors.data_blue}"; font-color: white; font: mono; bold: true}}
    f01_type: "char[32]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f01_desc: "Symbol name string buffer (Part 2/2)" {style.fill: white}

    # CACHE LINE BOUNDARY AT 0x40 (64B)
    cache_line_1: "---" {grid-columns: 4; style: {stroke-dash: 5; opacity: 0.5}}

    # Row 2: Symbol Type
    f02_off: "0x40" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f02_name: "type" {style: {fill: "${vars.colors.flag_green}"; font-color: white; font: mono; bold: true}}
    f02_type: "uint8_t [1]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f02_desc: "ELF Symbol Type (STT_FUNC, STT_OBJECT, etc.)" {style.fill: white}

    # Row 3: Binding
    f03_off: "0x41" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f03_name: "binding" {style: {fill: "${vars.colors.flag_green}"; font-color: white; font: mono; bold: true}}
    f03_type: "uint8_t [1]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f03_desc: "ELF Binding (STB_LOCAL, STB_GLOBAL, STB_WEAK)" {style.fill: white}

    # Row 4: Resolution State
    f04_off: "0x42" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f04_name: "state" {style: {fill: "${vars.colors.flag_green}"; font-color: white; font: mono; bold: true}}
    f04_type: "uint8_t [1]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f04_desc: "Internal Linker State (UNDEF -> RESOLVED)" {style.fill: white}

    # Row 5: Padding
    f05_off: "0x43" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f05_name: "_pad1" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f05_type: "uint8_t [5]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f05_desc: "Alignment padding to 0x48 (8-byte boundary)" {style.fill: white}

    # Row 6: Source Tracking
    f06_off: "0x48" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f06_name: "source_file_idx" {style: {fill: "${vars.colors.pointer_orange}"; font-color: white; font: mono; bold: true}}
    f06_type: "int32_t [4]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f06_desc: "Reference into LinkerContext.inputs_v[]" {style.fill: white}

    f07_off: "0x4C" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f07_name: "source_sym_idx" {style: {fill: "${vars.colors.pointer_orange}"; font-color: white; font: mono; bold: true}}
    f07_type: "int32_t [4]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f07_desc: "Symbol index within the source .symtab" {style.fill: white}

    # Row 7: Section Indexing
    f08_off: "0x50" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f08_name: "section_idx" {style: {fill: "${vars.colors.pointer_orange}"; font-color: white; font: mono; bold: true}}
    f08_type: "uint16_t [2]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f08_desc: "Target input section index" {style.fill: white}

    f09_off: "0x52" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f09_name: "_pad2" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f09_type: "uint8_t [6]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f09_desc: "Alignment padding to 0x58" {style.fill: white}

    # Row 8: 64-bit Values
    f10_off: "0x58" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f10_name: "section_offset" {style: {fill: "${vars.colors.data_blue}"; font-color: white; font: mono; bold: true}}
    f10_type: "uint64_t [8]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f10_desc: "st_value: Offset relative to section start" {style.fill: white}

    f11_off: "0x60" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f11_name: "final_address" {style: {fill: "${vars.colors.data_blue}"; font-color: white; font: mono; bold: true}}
    f11_type: "uint64_t [8]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f11_desc: "Absolute Virtual Address in Output" {style.fill: white}

    f12_off: "0x68" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f12_name: "size" {style: {fill: "${vars.colors.data_blue}"; font-color: white; font: mono; bold: true}}
    f12_type: "uint64_t [8]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f12_desc: "st_size: Total byte size of symbol" {style.fill: white}

    # Row 9: COMMON Data
    f13_off: "0x70" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f13_name: "common_size" {style: {fill: "${vars.colors.data_blue}"; font-color: white; font: mono; bold: true}}
    f13_type: "uint64_t [8]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f13_desc: "COMMON: Largest encountered size" {style.fill: white}

    f14_off: "0x78" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f14_name: "common_align" {style: {fill: "${vars.colors.data_blue}"; font-color: white; font: mono; bold: true}}
    f14_type: "uint64_t [8]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f14_desc: "COMMON: Strictest alignment constraint" {style.fill: white}

    # CACHE LINE BOUNDARY AT 0x80 (128B)
    cache_line_2: "---" {grid-columns: 4; style: {stroke-dash: 5; opacity: 0.5}}

    # Row 10: Logic Flags
    f15_off: "0x80" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f15_name: "is_strong" {style: {fill: "${vars.colors.flag_green}"; font-color: white; font: mono; bold: true}}
    f15_type: "int32_t [4]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f15_desc: "Conflict resolution priority bit" {style.fill: white}

    f16_off: "0x84" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f16_name: "ref_count" {style: {fill: "${vars.colors.flag_green}"; font-color: white; font: mono; bold: true}}
    f16_type: "int32_t [4]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f16_desc: "Active reference tracking (for GC)" {style.fill: white}

    # Row 11: First Reference Pointer
    f17_off: "0x88" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f17_name: "first_ref_file" {style: {fill: "${vars.colors.pointer_orange}"; font-color: white; font: mono; bold: true}}
    f17_type: "int32_t [4]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f17_desc: "File index of first site to reference" {style.fill: white}

    f18_off: "0x8C" {style: {fill: "${vars.colors.header_purple}"; font-color: white; font: mono}}
    f18_name: "first_ref_sym" {style: {fill: "${vars.colors.pointer_orange}"; font-color: white; font: mono; bold: true}}
    f18_type: "int32_t [4]" {style: {fill: "${vars.colors.padding_gray}"; font: mono}}
    f18_desc: "Local index in first_ref_file's table" {style.fill: white}
  }
}

legend: {
  near: bottom-center
  style: {
    fill: white
    stroke: "#2C3E50"
    stroke-width: 1
  }
  
  legend_label: {
    label: "**Memory Layout Color Key**"
    shape: text
  }
  
  lg: {
    grid-columns: 2
    grid-gap: 10
    
    lg1_box: "" {style.fill: "${vars.colors.header_purple}"; width: 24; height: 16}
    lg1_txt: "Byte Offset (Hex)" {shape: text}
    
    lg2_box: "" {style.fill: "${vars.colors.data_blue}"; width: 24; height: 16}
    lg2_txt: "Data (Addresses/Sizes)" {shape: text}
    
    lg3_box: "" {style.fill: "${vars.colors.pointer_orange}"; width: 24; height: 16}
    lg3_txt: "Indices/Reference Tracking" {shape: text}
    
    lg4_box: "" {style.fill: "${vars.colors.flag_green}"; width: 24; height: 16}
    lg4_txt: "State/Flags/Logic" {shape: text}
    
    lg5_box: "" {style.fill: "${vars.colors.padding_gray}"; width: 24; height: 16}
    lg5_txt: "Type Info/Internal Padding" {shape: text}
  }
}

notes: {
  label: |md
    ### Implementation Specification:
    - **Resolution**: The `state` field is the primary driver for the linker's resolution loop.
    - **Conflict Logic**: `is_strong` allows deterministic selection between multiple definitions (STB_WEAK vs STB_GLOBAL).
    - **COMMON Management**: `common_size` and `common_align` are aggregated during the first pass to determine `.bss` section expansion.
    - **Relocation Phase**: `final_address` is strictly read-only after the address assignment phase of the linker completes.
  |
  shape: text
  near: bottom-right
  style: {
    fill: "#FDF6E3"
    stroke: "#D4C4A8"
  }
}