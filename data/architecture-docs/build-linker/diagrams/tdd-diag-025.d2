vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
File1: "main.o"
File2: "utils.o"
File3: "lib.o"
GlobalTable: "Global Symbol Table"
# File 1 processing
File1 -> GlobalTable: "Parse .symtab\nExtract symbol entries"
GlobalTable -> GlobalTable: "Process symbol [1]: main"
GlobalTable -> GlobalTable: "  binding=STB_GLOBAL\n  section=.text\n  offset=0x0"
GlobalTable -> GlobalTable: "  → lookup('main')\n  → NOT FOUND\n  → CREATE entry\n  → state=DEFINED\n  → is_strong=1"
GlobalTable -> GlobalTable: "Process symbol [2]: helper"
GlobalTable -> GlobalTable: "  binding=STB_GLOBAL\n  section=SHN_UNDEF"
GlobalTable -> GlobalTable: "  → lookup('helper')\n  → NOT FOUND\n  → CREATE entry\n  → state=UNDEF\n  → ref_count=1"
# File 2 processing
File2 -> GlobalTable: "Parse .symtab\nExtract symbol entries"
GlobalTable -> GlobalTable: "Process symbol [1]: helper"
GlobalTable -> GlobalTable: "  binding=STB_GLOBAL\n  section=.text\n  offset=0x0"
GlobalTable -> GlobalTable: "  → lookup('helper')\n  → FOUND (state=UNDEF)"
GlobalTable -> GlobalTable: "  → Rule: Strong defines UNDEF\n  → state=DEFINED\n  → is_strong=1"
GlobalTable -> GlobalTable: "Process symbol [2]: buffer"
GlobalTable -> GlobalTable: "  binding=STB_GLOBAL\n  section=SHN_COMMON\n  size=400"
GlobalTable -> GlobalTable: "  → lookup('buffer')\n  → NOT FOUND\n  → CREATE entry\n  → state=COMMON\n  → common_size=400"
GlobalTable -> GlobalTable: "Process symbol [3]: config"
GlobalTable -> GlobalTable: "  binding=STB_WEAK\n  section=.data\n  offset=0x0"
GlobalTable -> GlobalTable: "  → lookup('config')\n  → NOT FOUND\n  → CREATE entry\n  → state=DEFINED\n  → is_strong=0"
# File 3 processing
File3 -> GlobalTable: "Parse .symtab\nExtract symbol entries"
GlobalTable -> GlobalTable: "Process symbol [1]: buffer"
GlobalTable -> GlobalTable: "  binding=STB_GLOBAL\n  section=SHN_COMMON\n  size=800"
GlobalTable -> GlobalTable: "  → lookup('buffer')\n  → FOUND (state=COMMON)"
GlobalTable -> GlobalTable: "  → Rule: COMMON merge\n  → max(400, 800)\n  → common_size=800"
GlobalTable -> GlobalTable: "Process symbol [2]: config"
GlobalTable -> GlobalTable: "  binding=STB_GLOBAL\n  section=.data\n  offset=0x0"
GlobalTable -> GlobalTable: "  → lookup('config')\n  → FOUND (state=DEFINED, weak)"
GlobalTable -> GlobalTable: "  → Rule: Strong overrides Weak\n  → is_strong=1\n  → update source"
GlobalTable -> GlobalTable: "Process symbol [3]: internal_fn"
GlobalTable -> GlobalTable: "  binding=STB_LOCAL\n  section=.text"
GlobalTable -> GlobalTable: "  → LOCAL symbol\n  → resolve immediately\n  → NOT added to global"
# Final verification
GlobalTable -> GlobalTable: "=== RESOLUTION COMPLETE ==="
GlobalTable -> GlobalTable: "Verify all symbols:"
GlobalTable -> GlobalTable: "  main: DEFINED ✓"
GlobalTable -> GlobalTable: "  helper: DEFINED ✓"
GlobalTable -> GlobalTable: "  buffer: COMMON ✓"
GlobalTable -> GlobalTable: "  config: DEFINED ✓"
GlobalTable -> GlobalTable: "No undefined non-weak symbols\n→ Resolution successful"
File1: |md
  **main.o symbols:**
  - main (GLOBAL, .text+0)
  - helper (GLOBAL, UNDEF)
|
File2: |md
  **utils.o symbols:**
  - helper (GLOBAL, .text+0)
  - buffer (GLOBAL, COMMON)
  - config (WEAK, .data+0)
|
File3: |md
  **lib.o symbols:**
  - buffer (GLOBAL, COMMON)
  - config (GLOBAL, .data+0)
  - internal_fn (LOCAL, .text+0)
|