vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Weak Undefined Symbol Resolution
## Link-Time Binding & Runtime NULL Check Pattern
'| {
  near: top-center
}

direction: right

# --- MODULE 1: COMPILATION UNITS ---
Weak_Symbol_Definition: {
  label: "Weak Symbol Source\n(ELF Binding: STB_WEAK)"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }
  
  weak_code: |'c
// weak_def.c
__attribute__((weak))
void* malloc(size_t n) {
    return NULL; // Fallback implementation
}
'|
  weak_code.style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font: mono
    font-size: 11
  }
}

Strong_Override: {
  label: "Strong Override Source\n(ELF Binding: STB_GLOBAL)"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
  }
  
  strong_code: |'c
// strong_def.c
void* malloc(size_t n) {
    return custom_alloc(n); // Takes precedence
}
'|
  strong_code.style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font: mono
    font-size: 11
  }
}

# --- MODULE 2: RELOCATION LOGIC ---
Runtime_Check: {
  label: "Consumer NULL Check Pattern"
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
  }
  
  check_code: |'c
// main.c
extern __attribute__((weak)) int optional_feature;

void init() {
    // If symbol is undefined weak, 
    // the address resolves to 0x0
    if (&optional_feature != NULL) {
        enable_module(optional_feature);
    }
}
'|
  check_code.style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font: mono
    font-size: 11
  }
}

# --- MODULE 3: THE RESOLUTION TABLE (FIXED SYNTAX) ---
Resolution_Table: {
  label: "Linker Resolution Truth Table"
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
  }
  
  # Using block quote with tick to prevent MD table pipes from terminating block
  table_content: |'md
| Symbol Configuration | Linker Resolution | &Symbol Value | Runtime Check Result |
| :------------------- | :---------------- | :------------ | :------------------- |
| **Only Weak Def**    | Binds to Weak     | `0xWeakAddr`  | `TRUE` (Safe)        |
| **Strong Override**  | Binds to Strong   | `0xStngAddr`  | `TRUE` (Safe)        |
| **Weak Undefined**   | Resolves to 0     | `0x00000000`  | `FALSE` (Skipped)    |
| **Strong Undefined** | Linker Error      | `N/A`         | `PANIC` (Link Fail)  |
'|
  table_content.style: {
    fill: "#FFFFFF"
    stroke: "#9E9E9E"
    font-size: 12
  }
}

# --- MODULE 4: RESOLUTION PIPELINE ---
Resolution_Flow: {
  label: "Linker Binding Algorithm"
  
  step1: "1. Scan Symbol Tables" {
    tooltip: "Parser identifies STB_WEAK vs STB_GLOBAL"
    style.fill: "#E8F5E9"
  }
  step2: "2. Resolve Definitions" {
    tooltip: "Priority: Global > Weak"
    style.fill: "#E3F2FD"
  }
  step3: "3. Handle Missing?" {
    shape: diamond
    style.fill: "#FFF3E0"
  }
  step4: "4. Assign 0x0 (NULL)" {
    tooltip: "ABI requirement for Weak Undef"
    style.fill: "#FFEBEE"
  }
  step5: "5. Write Relocations" {
    tooltip: "Final address patch in text/data"
    style.fill: "#E8F5E9"
  }

  step1 -> step2 -> step3
  step3 -> step4: "Is WEAK?"
  step3 -> step5: "Resolved"
  step4 -> step5
}

# --- CONNECTIONS & ANNOTATIONS ---
Strong_Override -> Runtime_Check: "Overrides Weak\nBinding (Linker)" {
  style.stroke: "#2196F3"
  style.font-color: "#2196F3"
  style.bold: true
}

Weak_Symbol_Definition -> Runtime_Check: "Provides Fallback\nif missing" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}

Runtime_Check -> Resolution_Table: "Implementation"
Resolution_Flow -> Resolution_Table: "Process Logic"

legend: {
  near: bottom-right
  label: |'md
### ELF Standard (gABI)
**Rule:** If a symbol is `WEAK` and no definition is found 
during linking, the linker shall not issue an error. 
Instead, it shall resolve the symbol to address **0**.
'|
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
    font-size: 12
  }
}