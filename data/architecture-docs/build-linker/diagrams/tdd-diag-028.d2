vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Relocation Processing Module Architecture
  **Integration: Symbol Table → Patch Calculator → Output Buffer**
|
# ============================================================================
# INPUT DATA STRUCTURES
# ============================================================================
Input_Section: {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  label: "Input Section Data\n(.text, .data, .rodata)"
}
Relocation_Entry: {
  shape: class
  style.fill: "#E4DBFE"
  style.stroke: "#7C3AED"
  offset: "uint64_t r_offset"
  sym_idx: "uint32_t sym_idx"
  type: "uint32_t type"
  addend: "int64_t r_addend"
  target_section_idx: "int target_section_idx"
  source_file: "char source_file[256]"
}
# ============================================================================
# RESOLUTION PIPELINE
# ============================================================================
Resolution_Pipeline: {
  style.fill: "#F3F4F6"
  style.stroke: "#9CA3AF"
  style.stroke-dash: 3
  Site_Translator: {
    shape: hexagon
    style.fill: "#C7F1FF"
    label: "Site Translator\n\ntranslate_relocation_site()\n\ninput_offset → output_offset\ninput_section → output_section"
  }
  Symbol_Resolver: {
    shape: hexagon
    style.fill: "#C7F1FF"
    label: "Symbol Resolver\n\nresolve_relocation_symbol()\n\nsym_idx → symbol_vaddr"
  }
}
# ============================================================================
# SYMBOL TABLE INTEGRATION
# ============================================================================
Global_Symbol_Table: {
  shape: cylinder
  style.fill: "#FCE7C6"
  style.stroke: "#D97706"
  label: "Global Symbol Table\n(Milestone 2)\n\nname → final_address"
}
Symbol_Types: {
  style.fill: "#FEF3C7"
  Named_Symbol: "Named Symbol\nlookup in global table"
  Section_Symbol: "Section Symbol\nSTT_SECTION → section vaddr"
  Weak_Undef: "Weak Undefined\n→ address 0"
  Absolute: "Absolute (SHN_ABS)\n→ st_value directly"
}
# ============================================================================
# MAPPING TABLE INTEGRATION
# ============================================================================
Mapping_Table: {
  shape: cylinder
  style.fill: "#D1FAE5"
  style.stroke: "#059669"
  label: "Mapping Table\n(Milestone 1)\n\n(file, section, offset)\n→ output_offset"
}
# ============================================================================
# PATCH CALCULATOR
# ============================================================================
Patch_Calculator: {
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  Dispatcher: {
    shape: diamond
    label: "Type\nDispatcher\ncalculate_patch_value()"
  }
  R_64: {
    label: "R_X86_64_64\n\n*loc = S + A\n\n64-bit absolute"
    style.fill: "#BFDBFE"
  }
  R_PC32: {
    label: "R_X86_64_PC32\n\n*loc = S + A - P\n\n32-bit PC-relative"
    style.fill: "#BFDBFE"
  }
  R_32: {
    label: "R_X86_64_32\n\n*loc = S + A\n\n32-bit unsigned"
    style.fill: "#BFDBFE"
    style.opacity: 0.6
  }
  R_32S: {
    label: "R_X86_64_32S\n\n*loc = S + A\n\n32-bit signed"
    style.fill: "#BFDBFE"
    style.opacity: 0.6
  }
}
Overflow_Checker: {
  shape: diamond
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  label: "Overflow\nChecker\n\nINT32_MIN ≤ val ≤ INT32_MAX"
}
# ============================================================================
# OUTPUT BUFFER
# ============================================================================
Output_Buffer: {
  style.fill: "#D1FAE5"
  style.stroke: "#059669"
  Buffer_Header: {
    shape: rectangle
    label: "Output Buffer\n\nuint8_t *buffer\nsize_t buffer_size"
    style.fill: "#A7F3D0"
  }
  Patch_Location: {
    shape: rectangle
    label: "Patch Location\n\nbuffer[site_file_offset]\n+= computed_value"
    style.fill: "#6EE7B7"
  }
}
# ============================================================================
# CONNECTIONS - DATA FLOW
# ============================================================================
Input_Section -> Relocation_Entry: "parsed from\n.rela.* sections"
Relocation_Entry -> Resolution_Pipeline.Site_Translator: "r_offset,\ntarget_section"
Resolution_Pipeline.Site_Translator -> Mapping_Table: "lookup\n(file, section, offset)"
Mapping_Table -> Resolution_Pipeline.Site_Translator: "output_offset,\noutput_section"
Resolution_Pipeline.Site_Translator -> Resolution_Pipeline: {
  style.stroke-dash: 3
  label: "site_vaddr\nsite_file_offset"
}
Relocation_Entry -> Resolution_Pipeline.Symbol_Resolver: "sym_idx"
Resolution_Pipeline.Symbol_Resolver -> Global_Symbol_Table: "lookup by name"
Global_Symbol_Table -> Resolution_Pipeline.Symbol_Resolver: "final_address"
Resolution_Pipeline.Symbol_Resolver -> Symbol_Types: "classify"
Symbol_Types -> Resolution_Pipeline.Symbol_Resolver: "symbol_vaddr"
Resolution_Pipeline -> Patch_Calculator.Dispatcher: "site_vaddr,\nsymbol_vaddr,\naddend, type"
Patch_Calculator.Dispatcher -> Patch_Calculator.R_64: "type == 1"
Patch_Calculator.Dispatcher -> Patch_Calculator.R_PC32: "type == 2"
Patch_Calculator.Dispatcher -> Patch_Calculator.R_32: "type == 10"
Patch_Calculator.Dispatcher -> Patch_Calculator.R_32S: "type == 11"
Patch_Calculator.R_64 -> Overflow_Checker: "computed_value"
Patch_Calculator.R_PC32 -> Overflow_Checker: "computed_value"
Patch_Calculator.R_32 -> Overflow_Checker: "computed_value\n(unsigned check)"
Patch_Calculator.R_32S -> Overflow_Checker: "computed_value"
Overflow_Checker -> Output_Buffer.Patch_Location: "write_le32/64()"
Output_Buffer.Patch_Location -> Output_Buffer.Buffer_Header: "modify in place"
# ============================================================================
# LEGEND
# ============================================================================
Legend: {
  near: bottom-right
  Data_Structure: {
    shape: rectangle
    style.fill: "#E4DBFE"
  }
  Function: {
    shape: hexagon
    style.fill: "#C7F1FF"
  }
  Storage: {
    shape: cylinder
    style.fill: "#FCE7C6"
  }
  Decision: {
    shape: diamond
    style.fill: "#FEE2E2"
  }
}
# ============================================================================
# KEY FORMULAS ANNOTATION
# ============================================================================
Formulas: {
  near: top-right
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  label: |md
    **Relocation Formulas:**
    - **S** = Symbol address (symbol_vaddr)
    - **A** = Addend (r_addend)
    - **P** = Place/PC (site_vaddr)
    `R_X86_64_64`:   `*loc = S + A`
    `R_X86_64_PC32`: `*loc = S + A - P`
  |
}