vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5E0"
    field1: "#B8D4E8"
    field2: "#D4E8B8"
    field3: "#E8D4B8"
    bits: "#F5F5F5"
    label: "#333333"
  }
}
title: |md
  # Elf64_Rela Entry Memory Layout
  **Total Size: 24 bytes (0x18)**
| {near: top-center}
direction: right
container: {
  label: "Elf64_Rela Structure"
  style.fill: transparent
  style.stroke: "#666666"
  style.stroke-width: 2
  r_offset: {
    label: "r_offset\nuint64_t"
    style.fill: "${colors.field1}"
    width: 180
    height: 80
  }
  r_info: {
    label: "r_info\nuint64_t"
    style.fill: "${colors.field2}"
    width: 180
    height: 80
    r_info_detail: {
      direction: right
      style.fill: transparent
      sym_idx: {
        label: "Symbol Index\n(Bits 63:32)"
        style.fill: "#C8E8C8"
        width: 140
        height: 60
      }
      type: {
        label: "Relocation Type\n(Bits 31:0)"
        style.fill: "#E8E8C8"
        width: 140
        height: 60
      }
    }
  }
  r_addend: {
    label: "r_addend\nint64_t"
    style.fill: "${colors.field3}"
    width: 180
    height: 80
  }
}
offset_annotations: {
  style.fill: transparent
  style.stroke: transparent
  off0: {
    shape: text
    label: "0x00"
    style.font-color: "${colors.label}"
    style.font-size: 14
  }
  off8: {
    shape: text
    label: "0x08"
    style.font-color: "${colors.label}"
    style.font-size: 14
  }
  off10: {
    shape: text
    label: "0x10"
    style.font-color: "${colors.label}"
    style.font-size: 14
  }
  off18: {
    shape: text
    label: "0x18"
    style.font-color: "${colors.label}"
    style.font-size: 14
  }
}
size_annotations: {
  style.fill: transparent
  style.stroke: transparent
  size8_1: {
    shape: text
    label: "8 bytes"
    style.font-color: "${colors.label}"
    style.font-size: 12
  }
  size8_2: {
    shape: text
    label: "8 bytes"
    style.font-color: "${colors.label}"
    style.font-size: 12
  }
  size8_3: {
    shape: text
    label: "8 bytes"
    style.font-color: "${colors.label}"
    style.font-size: 12
  }
}
macros: {
  style.fill: "#F0F0F0"
  style.stroke: "#999999"
  style.stroke-dash: 2
  title: |md
    ### Extraction Macros
  | {shape: text}
  sym_macro: {
    label: "ELF64_R_SYM(i) = (i) >> 32"
    shape: code
    style.fill: "#E8E8E8"
    style.font: mono
    style.font-size: 11
  }
  type_macro: {
    label: "ELF64_R_TYPE(i) = (i) & 0xFFFFFFFF"
    shape: code
    style.fill: "#E8E8E8"
    style.font: mono
    style.font-size: 11
  }
}
field_descriptions: {
  grid-columns: 1
  style.fill: transparent
  style.stroke: transparent
  desc1: |md
    **r_offset**: Byte offset within target section where patch applies
  | {shape: text}
  desc2: |md
    **r_info**: Packed field: symbol index (which symbol to resolve) + type (how to compute patch)
  | {shape: text}
  desc3: |md
    **r_addend**: Signed value added to symbol address in relocation formula
  | {shape: text}
}
example: {
  style.fill: "#FFF8E8"
  style.stroke: "#CC9900"
  title: |md
    ### Example: call helper (R_X86_64_PC32)
  | {shape: text}
  values: {
    direction: right
    style.fill: transparent
    ex_offset: {
      label: "r_offset = 0x05"
      shape: code
      style.fill: "#FFE8C8"
      style.font: mono
      style.font-size: 11
    }
    ex_info: {
      label: "r_info = 0x0000000300000002\n(sym=3, type=R_X86_64_PC32)"
      shape: code
      style.fill: "#E8FFC8"
      style.font: mono
      style.font-size: 10
    }
    ex_addend: {
      label: "r_addend = -4"
      shape: code
      style.fill: "#C8E8FF"
      style.font: mono
      style.font-size: 11
    }
  }
  formula: |md
    **Formula**: `*loc = S + A - P`  
    Where: S = symbol address, A = addend, P = site address
  | {shape: text}
}
offset_annotations.off0 -> container.r_offset
offset_annotations.off8 -> container.r_info
offset_annotations.off10 -> container.r_addend
offset_annotations.off18 -> container.r_addend {style.stroke: transparent}
container.r_offset -> size_annotations.size8_1 {style.stroke: transparent}
container.r_info -> size_annotations.size8_2 {style.stroke: transparent}
container.r_addend -> size_annotations.size8_3 {style.stroke: transparent}