direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: {
  label: |md
    # TECHNICAL DESIGN: Relocation Processing Data Flow
    *Intel Manual Quality Spec — Binary Patching Sequence*
    **Layout Engine:** ELK | **ISA:** x86_64 | **Format:** ELF64
  |
  near: top-center
}

# Input stage: SHT_RELA and .symtab
input_stage: {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  
  label: "INPUT STAGE: ELF STRUCTURES"

  rela_section: {
    label: ".rela.text Section\n(Elf64_Rela Array)"
    shape: cylinder
    style.fill: "#E1BEE7"
    
    header: "HEADER: Offset 0x0000 (sizeof=24)" {
      style.fill: "#9C27B0"
      style.font-color: white
    }

    entry0: {
      label: "Entry[0] @ +0x00\n------------------\nr_offset: 0x0005 (8B)\nr_info:   0x300000002 (8B)\nr_addend: -4 (8B)"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.font-size: 11
      style.font: mono
    }
    
    entry1: {
      label: "Entry[1] @ +0x18\n------------------\nr_offset: 0x0010 (8B)\nr_info:   0x500000001 (8B)\nr_addend: 0 (8B)"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.font-size: 11
      style.font: mono
    }
    
    footer: "..." {style.stroke-dash: 3}
  }

  symtab: {
    label: ".symtab\n(Symbol Table)"
    shape: cylinder
    style.fill: "#E8EAF6"
    
    sym3: {
      label: "[3] helper (LOCAL)\nValue: 0x0020 (8B)\nSize:  0x15 (8B)\nInfo:  STB_LOCAL (1B)"
      shape: rectangle
      style.fill: "#C5CAE9"
      style.font-size: 11
      style.font: mono
    }
    
    sym5: {
      label: "[5] global_var (GLOBAL)\nValue: 0x0000 (8B)\nSize:  0x08 (8B)\nInfo:  STB_GLOBAL (1B)"
      shape: rectangle
      style.fill: "#C5CAE9"
      style.font-size: 11
      style.font: mono
    }
  }
}

# Parse stage: Internal object representation
parse_stage: {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  label: "STAGE 1: PARSING & DESERIALIZATION"
  
  reloc_array: {
    label: "Internal Relocation Object List"
    shape: rectangle
    style.fill: "#A5D6A7"
    
    r1: {
      label: |md
        **RelocObj[0]**
        - Offset: 0x0005
        - SymIdx: 3 (helper)
        - Type: R_X86_64_PC32 (2)
        - Addend: -4
      |
      style.font-size: 10
      style.font: mono
    }
    
    r2: {
      label: |md
        **RelocObj[1]**
        - Offset: 0x0010
        - SymIdx: 5 (global_var)
        - Type: R_X86_64_64 (1)
        - Addend: 0
      |
      style.font-size: 10
      style.font: mono
    }
  }
}

# Translation stage: File offset to Virtual Address
translate_stage: {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  label: "STAGE 2: VIRTUAL ADDRESS MAPPING"
  
  mapping_table: {
    label: "Load Segment Map"
    shape: rectangle
    style.fill: "#90CAF9"
    
    map_entry: {
      label: |md
        **Section Mapping**
        .text (file: 0x1000) -> VAddr: 0x401000
        .data (file: 0x2000) -> VAddr: 0x403000
      |
      style.font-size: 10
      style.font: mono
    }
  }
  
  result1: {
    label: |md
      **Calculated Site P**
      site_vaddr (P) = 0x401005
      file_off = 0x1005
    |
    shape: rectangle
    style.fill: "#BBDEFB"
    style.font: mono
    style.font-size: 11
  }
}

# Symbol resolution stage: Finalizing S
symbol_stage: {
  style.fill: "#F3E5F5"
  style.stroke: "#6A1B9A"
  label: "STAGE 3: SYMBOL RESOLUTION"
  
  global_symtab: {
    label: "Global Linker Symbol Table"
    shape: rectangle
    style.fill: "#CE93D8"
    
    gs1: {
      label: "helper [RESOLVED]\nS = 0x401020"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.font: mono
      style.font-size: 11
    }
    
    gs2: {
      label: "global_var [RESOLVED]\nS = 0x403000"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.font: mono
      style.font-size: 11
    }
  }
}

# Computation stage: Apply ISA formulas
compute_stage: {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  label: "STAGE 4: FORMULA CALCULATION"
  
  pc32_calc: {
    label: |md
      **PC32 Calculation**
      Formula: `S + A - P`
      S (Symbol): 0x401020
      A (Addend): -4
      P (Place):  0x401005
      Result:     **0x17**
    |
    shape: rectangle
    style.fill: "#FFE0B2"
    style.font: mono
    style.font-size: 11
    style.stroke: "#FB8C00"
    style.stroke-width: 2
  }
  
  overflow_check: {
    label: "Safety Boundary Check\n\nVerify result fits in 32-bits\nRange: [-2^31, 2^31-1]"
    shape: diamond
    style.fill: "#FFF9C4"
    style.font-size: 10
  }
}

# Write stage: Binary patching
write_stage: {
  style.fill: "#F1F8E9"
  style.stroke: "#33691E"
  label: "STAGE 5: BUFFER PATCHING"
  
  output_buffer: {
    label: "Mmap'd Output Buffer (Memory Layout)"
    shape: cylinder
    style.fill: "#C8E6C9"
    
    before: {
      label: "OFFSET 0x1005:\n[E8] [00 00 00 00] (Initial NOP/Zero)"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.font: mono
      style.font-size: 11
    }
    
    after: {
      label: "OFFSET 0x1005:\n[E8] [17 00 00 00] (Patched CALL)"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.font: mono
      style.font-size: 11
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
  }
  
  write_func: {
    label: "write_le32(ptr, 0x17)"
    shape: rectangle
    style.fill: "#A5D6A7"
    style.font-size: 12
    style.font: mono
  }
}

# Flow connections
input_stage.rela_section -> parse_stage.reloc_array: "1. Deserialization" {
  style.stroke: "#616161"
  style.stroke-width: 2
}

parse_stage.reloc_array -> translate_stage.mapping_table: "2. Lookup Section VA" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}

translate_stage.mapping_table -> translate_stage.result1: "3. Compute P" {
  style.stroke: "#1565C0"
}

parse_stage.reloc_array -> symbol_stage.global_symtab: "4. Resolve Symbol Index" {
  style.stroke: "#6A1B9A"
  style.stroke-dash: 3
}

symbol_stage.global_symtab -> compute_stage.pc32_calc: "5. S Parameter" {
  style.stroke: "#6A1B9A"
}

translate_stage.result1 -> compute_stage.pc32_calc: "6. P Parameter" {
  style.stroke: "#1565C0"
}

compute_stage.pc32_calc -> compute_stage.overflow_check: "7. Integer Result" {
  style.stroke: "#EF6C00"
}

compute_stage.overflow_check -> write_stage.write_func: "8. Commit Patch" {
  style.stroke: "#33691E"
}

write_stage.write_func -> write_stage.output_buffer: "9. Atomic Store LE" {
  style.stroke: "#1B5E20"
  style.stroke-width: 3
}

# Annotations & Legends
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  
  header: "FIELD TYPES & DEFINITIONS"
  
  p: "P (Place): VAddr of field being relocated" {
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  s: "S (Symbol): Value of the symbol in VSpace" {
    shape: rectangle
    style.fill: "#CE93D8"
  }
  a: "A (Addend): Constant added to S by reloc" {
    shape: rectangle
    style.fill: "#FFF9C4"
  }
}

anno_formula: {
  label: |md
    ### ELF Relocation Reference (x86_64)
    - **R_X86_64_64**: `*loc = S + A` (Direct 64-bit)
    - **R_X86_64_PC32**: `*loc = S + A - P` (Relative 32-bit)
    - **R_X86_64_PLT32**: `*loc = L + A - P` (Procedure Linkage)
    - **R_X86_64_GOTPCREL**: `G + GOT + A - P`
  |
  near: top-right
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  style.font-size: 11
}

cache_line: {
  label: "64-BYTE ALIGNMENT BOUNDARY"
  near: bottom-left
  style.stroke-dash: 5
  style.stroke: "#BDBDBD"
  style.font-size: 10
  style.font-color: "#757575"
}