layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |||md
  # R_X86_64_PC32: PC-Relative Relocation Calculation
  Formula: `patch_value = S + A - P`
  Where: **S** = symbol_address, **A** = addend, **P** = site_virtual_address (Place)
| {
  near: top-center
  shape: text
}

direction: right

# --- Container: Input Parameters ---
inputs: "INPUT PARAMETERS (64-BIT)" {
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
    shadow: true
  }

  S: |md
    **S** (symbol_address)
    Target symbol's virtual address
    Type: `uint64_t`
  | {
    style.fill: "#BBDEFB"
  }
  
  A: |md
    **A** (addend)
    Signed adjustment value
    Type: `int64_t`
  | {
    style.fill: "#BBDEFB"
  }
  
  P: |md
    **P** (site_virtual_address)
    Relocation site's virtual address
    Type: `uint64_t`
  | {
    style.fill: "#BBDEFB"
  }
}

# --- Container: Calculation Step ---
calc: "STEP 1: CALCULATE RAW VALUE" {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
  }

  logic: |md
    c
    int64_t computed;
    computed = (int64_t)(S + A - P);
    
    **Example Trace:**
    - **S**: 0x401020 (helper)
    - **A**: -4 (inst size adj)
    - **P**: 0x401005 (site)
    
    `0x401020 + (-4) - 0x401005 = 0x17`
  | {
    style.fill: "#FFE0B2"
  }
}

# --- Container: Overflow Check ---
overflow: "STEP 2: OVERFLOW DETECTION" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-width: 2
  }

  check: |md
    **Range Validation**
    Verify if `computed` fits in `int32_t`:
    `if (computed < -2147483648 || computed > 2147483647)`
  |||
  
  overflow_gate: "OVERFLOW DETECTED?" {
    shape: diamond
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      font-color: "#B71C1C"
      bold: true
    }
  }
  
  error_exit: "ERROR: RELOC_ERR_OVERFLOW" {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      font-color: "#C62828"
      double-border: true
    }
  }
# REMOVED (extra closing brace): }

# --- Container: Write Step ---
write_op: "STEP 3: APPLY PATCH" {
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }

  mem_layout: "Relocation Site (P) Memory Map" {
    style.fill: white
    
    header: "0x00: Header" {
      style.fill: "#E1BEE7"
    }
    byte0: "P+0: 0x17" {
      style.fill: "#BBDEFB"
    }
    byte1: "P+1: 0x00" {
      style.fill: "#BBDEFB"
    }
    byte2: "P+2: 0x00" {
      style.fill: "#BBDEFB"
    }
    byte3: "P+3: 0x00" {
      style.fill: "#BBDEFB"
    }
    padding: "0x04: Padding" {
      style.fill: "#F5F5F5"
    }
  }

  code: |md
    **Little-Endian Write**
    c
    *(int32_t*)P = (int32_t)computed;
    
  |
}

# --- Container: Verification ---
verify: "RUNTIME VERIFICATION" {
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
  }

  trace: |md
    **CPU Resolution Logic**
    1. `RIP_base` = `P + 4` (0x401009)
    2. `Offset` = `*(int32_t*)P` (0x17)
    3. `Target` = `RIP_base + Offset`
    4. `Target` = `0x401009 + 0x17 = 0x401020`
    **Status: OK ✓**
  |
}

# --- Flow Connections ---
inputs -> calc: "64-bit Values" {
  style.stroke: "#2196F3"
}

calc -> overflow.check: "Offset" {
  style.stroke: "#FF9800"
}

overflow.check -> overflow.overflow_gate

overflow.overflow_gate -> overflow.error_exit: "TRUE (Abort)" {
  style: {
    stroke: "#D32F2F"
    font-color: "#D32F2F"
    stroke-width: 2
  }
}

overflow.overflow_gate -> write_op: "FALSE (Pass)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    animated: true
  }
}

write_op -> verify: "Memory Patched" {
  style.stroke: "#9C27B0"
}

# --- Legend ---
legend: ||md
  **PC-Relative Legend**
  - **S**: Symbol (Where we want to go)
  - **A**: Addend (Fixed adjustment)
  - **P**: Place (Where the patch is written)
  - **PC**: Program Counter (RIP on x86_64)
| {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
  }
}
||