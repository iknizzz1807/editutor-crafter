direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 25
  }
}

# ---------------------------------------------------------------------------------
# Intel-Grade Technical Styles
# ---------------------------------------------------------------------------------
classes: {
  header_style: {
    style: {
      font-size: 18
      bold: true
      fill: "#2C3E50"
      font-color: white
    }
  }
  reloc_table: {
    shape: sql_table
    style: {
      fill: "#E8F8FF"
      stroke: "#2980B9"
      stroke-width: 2
    }
  }
  calc_engine: {
    style: {
      fill: "#FEF9E7"
      stroke: "#F1C40F"
      stroke-width: 3
      double-border: true
    }
  }
  memory_block: {
    style: {
      font: mono
      stroke: "#7F8C8D"
    }
  }
  hex_active: {
    style: {
      fill: "#E74C3C"
      font-color: white
      bold: true
    }
  }
}

# ---------------------------------------------------------------------------------
# DIAGRAM CONTENT
# ---------------------------------------------------------------------------------

TITLE: {
  shape: text
  near: top-center
  label: ||md
    # Input to Output Offset Translation
    ### Relocation Site Mapping Algorithm — TDD Spec 033
    **Revision:** 1.0.4 | **Target:** x86_64 ELF Static Linker
  ||
}

# STEP 1: ELF METADATA IDENTIFICATION
step1: {
  label: "STEP 1: Identify Relocation Site (Input Space)"
  
  rela_struct: {
    shape: sql_table
    label: "Elf64_Rela (24 Bytes)"
    r_offset: "0x00: uint64" {constraint: "0x0000000000000005"}
    r_info: "0x08: uint64" {constraint: "SymIdx=42, Type=R_X86_64_PC32"}
    r_addend: "0x10: int64" {constraint: "-4"}
    class: reloc_table
  }
  
  input_text: "Input .text (obj.o)" {
    shape: rectangle
    style.fill: "#FDFEFE"
    style.stroke-dash: 3
    
    b0: "0x00: [ 48 89 E5 ]"
    b1: "0x03: [ 90 90 ]"
    target_site: "0x05: [ E8 00 00 00 00 ]" {
      style.fill: "#F9E79F"
      style.stroke: "#D4AC0D"
      style.bold: true
    }
    b2: "0x0A: [ 5D C3 ]"
  }
  
  rela_struct.r_offset -> input_text.target_site: "Offset Pointer" {
    style: {
      stroke: "#E67E22"
      stroke-width: 2
      animated: true
    }
  }
}

# STEP 2: LINKER MAPPING TABLE
step2: {
  label: "STEP 2: Query Section Mapping Table"
  
  mapping_table: {
    shape: sql_table
    label: "Linker Global Section Map"
    entry1: "obj.o:.text" {constraint: "Out_VA: 0x401000, Size: 0x100"}
    entry2: "lib.a:.text" {constraint: "Out_VA: 0x401100, Size: 0x240"}
    entry3: "crt.o:.init" {constraint: "Out_VA: 0x401340, Size: 0x20"}
    style.fill: "#EAFAF1"
    style.stroke: "#27AE60"
  }
  
  active_mapping: {
    shape: class
    label: "Calculated Base"
    base_vaddr: "0x401000 (Section Start)"
    perms: "PROT_READ | PROT_EXEC"
    alignment: "16-byte aligned"
    class: calc_engine
  }
  
  mapping_table.entry1 -> active_mapping: "Match Section ID"
}

# STEP 3: VIRTUAL ADDRESS CALCULATION
step3: {
  label: "STEP 3: Virtual Address Translation Logic"
  
  math_box: {
    shape: rectangle
    class: calc_engine
    label: ||md
      ### Translation Logic
      **Formula:** `Target_VA = Map.Base + Reloc.Offset`
      
      | Component | Hex Value |
      | :--- | :--- |
      | Section Base | `0x00401000` |
      | Reloc Offset | `+ 0x00000005` |
      | **Result VA** | `0x00401005` |
    ||
  }
}

# STEP 4: OUTPUT PAGE LAYOUT
step4: {
  label: "STEP 4: Output Virtual Memory Layout"
  
  v_mem: "Virtual Address Space (Executable)" {
    style.fill: "#FBFCFC"
    
    page_start: "VADDR: 0x401000" {
      style.stroke-width: 5
      style.stroke: black
    }
    
    code_seg: ".text Segment (RX)" {
      style.fill: "#EBEDEF"
      
      prefix: "0x401000: [ 48 89 E5 90 90 ]"
      
      patch_site: "0x401005: [ E8 ?? ?? ?? ?? ]" {
        shape: circle
        style: {
          fill: "#EC7063"
          font-color: white
          bold: true
          stroke-width: 3
        }
      }
      
      suffix: "0x40100A: [ ... ]"
    }
    
    page_start -- code_seg.prefix
  }
}

# STEP 5: FINAL STATE TRANSITION
step5: {
  label: "STEP 5: Memory Patch Application (Pwrite64)"
  
  comparison: {
    grid-columns: 2
    
    before: {
      label: "STATE: UNPATCHED"
      content: |md
        **Address:** `0x401005`
        **Instruction:** `call <placeholder>`
        **Hex:** `E8 00 00 00 00`
      |
      style: {
        fill: "#FADBD8"
        stroke: "#C0392B"
      }
    }
    
    after: {
      label: "STATE: PATCHED"
      content: |md
        **Address:** `0x401005`
        **Instruction:** `call helper_func`
        **Hex:** `E8 1B 00 00 00`
        *Computed Rel32 offset*
      |
      style: {
        fill: "#D5F5E3"
        stroke: "#229954"
      }
    }
    
    before -> after: "Atomic Write" {
      style: {
        stroke-width: 4
        stroke: "#2980B9"
        animated: true
      }
    }
  }
}

# ---------------------------------------------------------------------------------
# Global Flow Orchestration
# ---------------------------------------------------------------------------------
step1 -> step2: "provide r_offset"
step2 -> step3: "provide section_base"
step3 -> step4: "provide absolute_va"
step4 -> step5: "trigger patch"

# ---------------------------------------------------------------------------------
# Footer Legend & Constraints
# ---------------------------------------------------------------------------------
legend: {
  shape: rectangle
  near: bottom-right
  style: {
    fill: "#F4F6F7"
    stroke-dash: 2
  }
  label: |md
    ### Implementation Constraints
    1. **Alignment**: Patch target must be 4-byte aligned for performance.
    2. **Overflow**: Rel32 calculation must fit in signed `int32`.
    3. **Page Boundary**: If relocation crosses page, linker must handle `mprotect`.
    4. **Byte Order**: Little-Endian (LSB at lowest address).
  |
}

# Explicit Byte Offset Annotation
(step4.v_mem.code_seg.prefix -> step4.v_mem.code_seg.patch_site): "Relative Delta = 0x05" {
  style: {
    stroke: "#7F8C8D"
    stroke-dash: 4
    font-size: 10
  }
}