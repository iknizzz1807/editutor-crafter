vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  stage_container: {
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
  symbol_class: {
    shape: class
    style: {
      fill: white
      font-size: 14
    }
  }
  note_text: {
    shape: text
    style: {
      font-size: 12
      italic: true
    }
  }
}

title: |md
  # Section Symbol Resolution Flow
  **STT_SECTION Symbol → Final Virtual Address**
  *Technical Specification for Linker Symbol Resolution Stage*
| {near: top-center}

direction: right

# ============================================================================
# STAGE 1: Input Symbol
# ============================================================================
stage1_input: {
  label: "1. STT_SECTION Symbol"
  class: stage_container
  style.fill: "#E8E8E8"
  style.stroke: "#666666"

  sym: {
    class: symbol_class
    label: "Elf64_Sym"
    "st_name": "0 (no name)"
    "st_info": "STT_SECTION (3)"
    "st_shndx": "2 (section index)"
    "st_value": "0x10 (offset)"
    "st_size": "0"
  }
  
  note: |md
    **Context:**
    - Section symbols have no name
    - `st_shndx` identifies the source section
    - `st_value` is the offset within section
  |
}

# ============================================================================
# STAGE 2: Section Lookup
# ============================================================================
stage2_section: {
  label: "2. Input Section Lookup"
  class: stage_container
  style.fill: "#B8D4E8"
  style.stroke: "#4A90A4"

  input_section: {
    class: symbol_class
    label: "InputSection"
    "name": '".rodata"'
    "type": "SHT_PROGBITS"
    "size": "0x100"
    "origin": "object_file.o"
  }
  
  note: |md
    **Logic:**
    `target = obj->sections[sym->st_shndx]`
    Find the literal section object by index.
  |
}

# ============================================================================
# STAGE 3: Output Section Resolution
# ============================================================================
stage3_output: {
  label: "3. Output Section Resolution"
  class: stage_container
  style.fill: "#C8E6C8"
  style.stroke: "#4CAF50"

  output_section: {
    class: symbol_class
    label: "OutputSection"
    "name": '".rodata"'
    "virtual_addr": "0x401100"
    "file_offset": "0x1100"
  }
  
  mapping: {
    class: symbol_class
    label: "SectionMapping"
    "output_offset": "0x00"
    "padding_before": "0"
  }
  
  note: |md
    **Mapping:**
    Lookup input name in the 
    global merged output sections.
  |
}

# ============================================================================
# STAGE 4: Address Calculation
# ============================================================================
stage4_calc: {
  label: "4. Address Calculation"
  class: stage_container
  style.fill: "#FFE4B5"
  style.stroke: "#E6A800"

  formula: {
    shape: rectangle
    width: 300
    style.fill: "#FFF8DC"
    label: |md
      ### Calculation Formula:
      `final_vaddr = output_section.vaddr`
      `           + mapping.output_offset`
      `           + symbol.value`
      
      **Example Trace:**
      `= 0x401100 (Base)`
      `+ 0x00 (Mapping)`
      `+ 0x10 (Offset)`
      `= 0x401110`
    |
  }
  
  breakdown: {
    shape: rectangle
    width: 300
    style.fill: "#FFFACD"
    label: |md
      **Logic Components:**
      - `vaddr`: Linker-assigned base
      - `output_offset`: Alignment/Merge pos
      - `symbol.value`: Internal offset
    |
  }
}

# ============================================================================
# STAGE 5: Final Result
# ============================================================================
stage5_result: {
  label: "5. Resolved Address"
  class: stage_container
  style.fill: "#D4B8E8"
  style.stroke: "#8B5CF6"

  resolved: {
    class: symbol_class
    label: "ResolvedRelocation"
    "symbol_vaddr": "0x401110"
    "is_valid": "true"
  }
  
  usage: |md
    **Application:**
    Used in relocation patch:
    `*patch_site = final_vaddr + addend`
  |
}

# ============================================================================
# Flow Connections
# ============================================================================
stage1_input.sym -> stage2_section.input_section: "lookup index" {
  style.stroke: "#4A90A4"
  style.stroke-width: 2
}

stage2_section.input_section -> stage3_output.output_section: "match name" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

stage3_output -> stage4_calc: "provide base" {
  style.stroke: "#E6A800"
  style.stroke-width: 2
}

stage1_input -> stage4_calc: "provide offset" {
  style.stroke: "#E6A800"
  style.stroke-width: 2
  style.stroke-dash: 3
}

stage4_calc -> stage5_result: "final_vaddr" {
  style.stroke: "#8B5CF6"
  style.stroke-width: 3
}

# ============================================================================
# Memory Visualization
# ============================================================================
memory_view: {
  label: "Binary Image Memory Layout"
  style.fill: "#F5F5F5"
  style.stroke: "#999999"

  memory: {
    shape: rectangle
    width: 400
    height: 300
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    
    header: {
      label: "ELF Header / Program Headers"
      style.fill: "#EEEEEE"
      height: 40
    }
    
    text_section: {
      label: ".text Section (RX)"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      height: 60
    }
    
    rodata_section: {
      label: ".rodata (Base: 0x401100)"
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      height: 100
      
      target_symbol: {
        label: "➤ Symbol Location [0x401110]"
        style.fill: "#FFCDD2"
        style.stroke: "#D32F2F"
        style.font: mono
        style.bold: true
      }
    }
    
    data_section: {
      label: ".data (RW)"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      height: 60
    }
  }
}

# Legend
legend: {
  near: bottom-right
  item1: "STT_SECTION: symbol references the start of a section"
  item2: "st_value: relative byte offset from that section start"
  item3: "Resolution: output_vaddr + mapping_offset + st_value"
}