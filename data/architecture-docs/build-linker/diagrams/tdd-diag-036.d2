vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

title: |md
  # Overflow Detection for 32-bit Relocations
  **R_X86_64_PC32 / R_X86_64_32S Range Validation**
  *Intel® 64 and IA-32 Architectures Software Developer’s Manual*
| {
  near: top-center
}

classes: {
  computation: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 6
    }
  }
  check: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
    }
  }
  error: {
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 3
      border-radius: 6
      font-color: "#C62828"
      bold: true
    }
  }
  success: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 6
    }
  }
  range_box: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      border-radius: 4
      font: mono
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 14
      font-color: "#424242"
    }
  }
}

# Computation Phase
compute: "Computed Value\n(64-bit signed accumulator)" {
  class: computation
  formula: |md
    ### Calculation Logic
    **R_X86_64_PC32 (32-bit PC-relative):**
    `val = S + A - P`
    
    **R_X86_64_32S (32-bit signed absolute):**
    `val = S + A`
    
    *Where:*
    - **S**: Symbol Address (0x0000000000000000 - 0xFFFFFFFFFFFFFFFF)
    - **A**: Addend (Signed 64-bit)
    - **P**: Relocation Site Address (Place)
  |
}

# Range Constants
range_info: "32-bit Signed Limits" {
  class: range_box
  values: |md
    **INT32_MAX:** `+2,147,483,647` 
    *(0x000000007FFFFFFF)*
    
    **INT32_MIN:** `-2,147,483,648` 
    *(0xFFFFFFFF80000000)*
  |
}

# Upper Bound Check
check_upper: "val > 0x7FFFFFFF?" {
  class: check
  tooltip: "Check for positive overflow"
}

# Lower Bound Check  
check_lower: "val < -2147483648?" {
  class: check
  tooltip: "Check for negative underflow"
}

# Overflow Error
overflow_error: "RELOCATION OVERFLOW" {
  class: error
  details: |md
    ## TERMINAL ERROR
    **Relocation type:** `R_X86_64_PC32`
    **Status:** Out of Range
    
    **Reasoning:**
    The calculated offset between the call site and the target symbol 
    exceeds the maximum displacement reachable by a 32-bit signed 
    immediate (±2GB).
    
    **Linker Action:** 
    1. Log symbol name and section
    2. Abort binary generation
  |
}

# Success Path
apply_patch: "Commit 32-bit Patch" {
  class: success
  action: |md
    ### Bitwise Commit
    - Truncate `val` to 32 bits
    - Format: Little-Endian
    - Target: `*(int32_t*)site_ptr = (int32_t)val;`
  |
}

# Connections
compute -> check_upper: "Result (i64)"

check_upper -> overflow_error: "Yes\n(Overflow)" {
  style: {
    stroke: "#D32F2F"
    stroke-width: 3
    animated: true
  }
}

check_upper -> check_lower: "No" {
  style.stroke: "#2E7D32"
}

check_lower -> overflow_error: "Yes\n(Underflow)" {
  style: {
    stroke: "#D32F2F"
    stroke-width: 3
    animated: true
  }
}

check_lower -> apply_patch: "No\n(In Range)" {
  style: {
    stroke: "#1976D2"
    stroke-width: 3
  }
}

# Visual references for range constants
range_info -> check_upper: {
  style.stroke-dash: 3
  style.stroke: "#7B1FA2"
  style.opacity: 0.5
}
range_info -> check_lower: {
  style.stroke-dash: 3
  style.stroke: "#7B1FA2"
  style.opacity: 0.5
}

# Documentation Annotations using constant cardinal positions
example_overflow: |md
  ## Validation Examples
  
  ### Case A: PC-Relative Success
  - Symbol (S): `0x401000`
  - Site (P): `0x400000`
  - Computed: `0x1000` (4096)
  - Result: **PASS** (Fits in 32-bit)
  
  ### Case B: Absolute 32S Failure
  - Symbol (S): `0x100000000` (Above 4GB)
  - Computed: `0x100000000`
  - Result: **FAIL** (Requires 64-bit addr)
  
  ### Case C: Negative Wrap
  - S = `0x100`, P = `0x80000000`
  - Computed: `-0x7FFFFF00`
  - Result: **PASS** (Within -2GB)
| {
  near: bottom-right
  class: annotation
}

formula_ref: |md
  ## ISA Constraints
  The `PC32` relocation is typically used 
  for instructions like:
  - `CALL (Opcode E8)`
  - `JMP (Opcode E9)`
  
  These instructions use a **32-bit signed 
  relative displacement** from the end of 
  the current instruction. If the target 
  is further than 2^31-1 bytes away, 
  this logic triggers the overflow abort.
| {
  near: top-right
  class: annotation
}