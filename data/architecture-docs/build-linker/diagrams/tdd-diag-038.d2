vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Little-Endian Patch Write
  ## Byte-level Memory Layout Spec (TDD-038)
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------
# 1. REGISTER VIEW (LOGICAL MSB -> LSB)
# -----------------------------------------------------------------------------
value: CPU Register (32-bit GPR) {
  tooltip: "Value: 0x12345678"
  style: {
    fill: "#E1BEE7" # Purple (Header)
    stroke: "#7B1FA2"
    stroke-width: 2
  }

  bits3124: "Byte 3 (MSB)\n[0x12]" {
    tooltip: "Bits 31-24 | 0b00010010"
    style.fill: "#7DC9F2"
    style.font-color: black
    width: 140
    height: 70
  }
  bits2316: "Byte 2\n[0x34]" {
    tooltip: "Bits 23-16 | 0b00110100"
    style.fill: "#6CB6EF"
    style.font-color: black
    width: 140
    height: 70
  }
  bits1508: "Byte 1\n[0x56]" {
    tooltip: "Bits 15-8 | 0b01010110"
    style.fill: "#5BA3EC"
    style.font-color: white
    width: 140
    height: 70
  }
  bits0700: "Byte 0 (LSB)\n[0x78]" {
    tooltip: "Bits 7-0 | 0b01111000"
    style.fill: "#4A90D9"
    style.font-color: white
    width: 140
    height: 70
  }

  bits3124 -> bits2316 -> bits1508 -> bits0700 {style.opacity: 0}
}

# -----------------------------------------------------------------------------
# 2. PHYSICAL MEMORY VIEW (RAM SEQUENCE)
# -----------------------------------------------------------------------------
buffer: Output Memory Buffer (RAM) {
  style.fill: "#F5F5F5"
  style.stroke: "#666666"
  style.stroke-width: 2
  style.double-border: true

  slot0: "Offset +0x0\n[0x78]" {
    tooltip: "Addr: 0x1000 | Size: 1 Byte"
    style.fill: "#4A90D9"
    style.font-color: white
    style.stroke: "#2E5A87"
    style.bold: true
    width: 120
    height: 90
  }
  slot1: "Offset +0x1\n[0x56]" {
    tooltip: "Addr: 0x1001 | Size: 1 Byte"
    style.fill: "#5BA3EC"
    style.font-color: white
    style.stroke: "#2E5A87"
    width: 120
    height: 90
  }
  slot2: "Offset +0x2\n[0x34]" {
    tooltip: "Addr: 0x1002 | Size: 1 Byte"
    style.fill: "#6CB6EF"
    style.font-color: black
    style.stroke: "#2E5A87"
    width: 120
    height: 90
  }
  slot3: "Offset +0x3\n[0x12]" {
    tooltip: "Addr: 0x1003 | Size: 1 Byte"
    style.fill: "#7DC9F2"
    style.font-color: black
    style.stroke: "#2E5A87"
    width: 120
    height: 90
  }

  padding: "Padding\n[0x00]" {
    style.fill: "#E0E0E0"
    style.font-color: "#757575"
    style.stroke-dash: 3
    width: 120
    height: 90
  }

  slot0 -> slot1 -> slot2 -> slot3 -> padding {
    style.stroke-dash: 3
    style.stroke: "#999999"
  }
}

# -----------------------------------------------------------------------------
# 3. SERIALIZATION LOGIC (LITTLE-ENDIAN FLOW)
# -----------------------------------------------------------------------------
value.bits0700 -> buffer.slot0: "1. Write LSB to low addr" {
  style.stroke: "#FF8F00" # Orange (Pointer/Flow)
  style.stroke-width: 3
  style.animated: true
}
value.bits1508 -> buffer.slot1: "2" {
  style.stroke: "#FFB300"
  style.stroke-width: 2
}
value.bits2316 -> buffer.slot2: "3" {
  style.stroke: "#FFC107"
  style.stroke-width: 2
}
value.bits3124 -> buffer.slot3: "4. Write MSB to high addr" {
  style.stroke: "#FFD54F"
  style.stroke-width: 2
}

# -----------------------------------------------------------------------------
# 4. IMPLEMENTATION DETAILS
# -----------------------------------------------------------------------------
code: |md
  ### Little-Endian Memory Serialization Spec
  
  **Algorithm Trace:**
  1. Extract Byte 0 (bits 0..7) via `value & 0xFF` -> Store at `base + 0`
  2. Extract Byte 1 (bits 8..15) via `(value >> 8) & 0xFF` -> Store at `base + 1`
  3. Extract Byte 2 (bits 16..23) via `(value >> 16) & 0xFF` -> Store at `base + 2`
  4. Extract Byte 3 (bits 24..31) via `(value >> 24) & 0xFF` -> Store at `base + 3`

  **C Implementation:**
  c
  uint32_t val = 0x12345678;
  uint8_t *mem = (uint8_t*)ptr;
  mem[0] = (val >> 0)  & 0xFF; // 0x78 (LSB)
  mem[1] = (val >> 8)  & 0xFF; // 0x56
  mem[2] = (val >> 16) & 0xFF; // 0x34
  mem[3] = (val >> 24) & 0xFF; // 0x12 (MSB)
  
  *Architecture: x86-64, ARM (Little-Endian mode)*
| {
  near: bottom-center
  style.fill: "#FFFFFF"
  style.stroke: "#BBBBBB"
  style.font-size: 14
}

# -----------------------------------------------------------------------------
# 5. METADATA & POINTERS
# -----------------------------------------------------------------------------
metadata: {
  near: center-right
  
  lsb_def: "LSB: Least Significant Byte" {
    shape: text
    style.font-color: "#1565C0"
    style.italic: true
  }
  msb_def: "MSB: Most Significant Byte" {
    shape: text
    style.font-color: "#0D47A1"
    style.italic: true
  }
  size_info: "Total Size: 4 Bytes (32-bits)" {
    shape: text
    style.bold: true
  }
}

addresses: {
  near: center-right
  style.fill: transparent
  style.stroke-width: 0
  
  ptr_start: "Base Pointer (uintptr_t 0x1000)" {
    shape: text
    icon: https://icons.terrastruct.com/material%2Fnavigation%2Farrow_forward.svg
    style.font-color: "#E65100" # Orange (Pointer)
    style.bold: true
  }
}

buffer.slot0 -> addresses.ptr_start {
  style: {
    stroke: "#E65100"
    stroke-dash: 5
    opacity: 0.5
  }
}

# -----------------------------------------------------------------------------
# 6. FIXED: MARKERS & BOUNDARIES (FIXED CONSTANT NEAR)
# -----------------------------------------------------------------------------
markers: {
  near: top-right # Fixed from object-ref to constant
  
  lsb_tag: "LSB (Byte 0) is mapped to low address" {
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    style.border-radius: 5
  }

  msb_tag: "MSB (Byte 3) is mapped to high address" {
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    style.border-radius: 5
  }
}

cache_line: "64B Cache Line Boundary (Representative)" {
  near: bottom-right # Fixed from object-ref to constant
  style: {
    stroke: "#BDBDBD"
    stroke-dash: 4
    fill: transparent
    font-size: 10
  }
}