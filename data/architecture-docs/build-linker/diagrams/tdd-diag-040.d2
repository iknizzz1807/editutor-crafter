vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    c2: "#C7F1FF"
    c3: "#B5AFF6"
    c4: "#DEE1EB"
    c5: "#88DCF7"
    c6: "#E4DBFE"
  }
}

title: |md
  # Executable Generation Module Architecture
  Milestone 4: Transforming Linked Data to Runnable ELF
| {near: top-center}

# ============================================================================
# MAIN DATA STRUCTURES
# ============================================================================
DataStructures: {
  style.fill: "${colors.c6}"
  
  OutputSegment: {
    shape: class
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    p_type: uint32
    p_flags: uint32
    p_offset: uint64
    p_vaddr: uint64
    p_paddr: uint64
    p_filesz: uint64
    p_memsz: uint64
    p_align: uint64
    name: "char[32]"
    is_valid: int
  }
  
  ExecutableLayout: {
    shape: class
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    elf_header_offset: uint64
    phdr_offset: uint64
    phdr_size: uint64
    content_offset: uint64
    total_file_size: uint64
    entry_point: uint64
    phnum: uint16
    has_text_segment: int
    has_data_segment: int
  }
  
  Elf64_Ehdr: {
    shape: class
    style.fill: "#D4E6F1"
    style.stroke: "#2874A6"
    e_ident: "uint8[16]"
    e_type: uint16
    e_machine: uint16
    e_version: uint32
    e_entry: uint64
    e_phoff: uint64
    e_shoff: uint64
    e_flags: uint32
    e_ehsize: uint16
    e_phentsize: uint16
    e_phnum: uint16
    e_shentsize: uint16
    e_shnum: uint16
    e_shstrndx: uint16
  }
  
  Elf64_Phdr: {
    shape: class
    style.fill: "#D4E6F1"
    style.stroke: "#2874A6"
    p_type: uint32
    p_flags: uint32
    p_offset: uint64
    p_vaddr: uint64
    p_paddr: uint64
    p_filesz: uint64
    p_memsz: uint64
    p_align: uint64
  }
  
  ExecStats: {
    shape: class
    style.fill: "#E8DAEF"
    style.stroke: "#7D3C98"
    text_segment_size: size_t
    data_segment_size: size_t
    bss_size: size_t
    total_file_size: size_t
    entry_address: uint64
    entry_symbol: "char*"
  }
}

# ============================================================================
# MODULE LAYER
# ============================================================================
ModuleLayer: {
  style.fill: "${colors.c4}"
  
  # Segment Builder Module
  SegmentBuilder: {
    style.fill: "${colors.c2}"
    style.stroke: "#2874A6"
    init: "segment_init(seg)"
    build_text: "build_text_segment(ctx, seg)"
    build_data: "build_data_segment(ctx, seg)"
    calc_offset: "calculate_segment_offset(seg, base, out)"
    validate: "segment_validate_alignment(seg)"
    overlap: "segments_overlap(segs, count)"
    build_all: "build_all_segments(ctx, segs, count)"
  }
  
  # ELF Header Module
  ELFHeader: {
    style.fill: "${colors.c5}"
    style.stroke: "#148F77"
    init: "elf_header_init(hdr)"
    set_entry: "elf_header_set_entry(hdr, vaddr)"
    set_phdr: "elf_header_set_phdr_info(hdr, off, cnt)"
    validate: "elf_header_validate(hdr)"
    write: "elf_header_write(hdr, buf)"
  }
  
  # Program Header Module
  ProgramHeader: {
    style.fill: "${colors.c5}"
    style.stroke: "#148F77"
    init: "program_header_init(phdr, seg)"
    write: "program_header_write(phdr, buf, off)"
    write_all: "program_headers_write_all(segs, cnt, buf)"
  }
  
  # Entry Point Module
  EntryPoint: {
    style.fill: "#F9E79F"
    style.stroke: "#B7950B"
    find: "find_entry_point(ctx)"
    get_addr: "get_entry_point_address(ctx, addr, name)"
    validate: "validate_entry_point(ctx, sym)"
    report: "report_entry_point(ctx)"
  }
  
  # Exec Writer Module
  ExecWriter: {
    style.fill: "${colors.c3}"
    style.stroke: "#5B2C6F"
    calc_layout: "calculate_executable_layout(ctx, layout)"
    build_buf: "build_executable_buffer(ctx, buf, size, layout, segs, cnt)"
    write_file: "write_executable(ctx, path, stats)"
    get_stats: "get_executable_stats(ctx, segs, cnt, stats)"
    verify: "verify_executable(path)"
  }
}

# ============================================================================
# EXTERNAL DEPENDENCIES (From Previous Milestones)
# ============================================================================
Dependencies: {
  style.fill: "#F5B7B1"
  style.stroke: "#922B21"
  style.stroke-dash: 3
  
  LinkerContext: {
    style.fill: "#FADBD8"
    inputs: "ObjectFile*"
    input_count: size_t
    outputs: "OutputSection*"
    output_count: size_t
    global_syms: GlobalSymbolTable
    mapping: MappingTable
    output_buffer: "uint8_t*"
    base_address: uint64_t
  }
  
  OutputSection: {
    style.fill: "#FADBD8"
    name: "char[64]"
    flags: uint64_t
    virtual_addr: uint64_t
    file_offset: uint64_t
    file_size: uint64_t
    mem_size: uint64_t
    data: "uint8_t*"
  }
  
  GlobalSymbol: {
    style.fill: "#FADBD8"
    name: "char[256]"
    state: SymbolState
    final_address: uint64_t
    binding: uint8_t
  }
}

# ============================================================================
# OUTPUT FILE
# ============================================================================
Output: {
  style.fill: "#82E0AA"
  style.stroke: "#1E8449"
  ELF_File: {
    shape: cylinder
    label: "Executable\n(ET_EXEC)"
  }
}

# ============================================================================
# CONNECTIONS: Data Flow
# ============================================================================
# Dependencies feed into module layer
Dependencies.LinkerContext -> ModuleLayer.SegmentBuilder: "ctx (sections, flags, vaddrs)"
Dependencies.LinkerContext -> ModuleLayer.EntryPoint: "ctx (symbol table)"
Dependencies.LinkerContext -> ModuleLayer.ExecWriter: "ctx (output_buffer)"

# Data structures used by modules
DataStructures.OutputSegment -> ModuleLayer.SegmentBuilder: "segment struct"
DataStructures.Elf64_Ehdr -> ModuleLayer.ELFHeader: "header struct"
DataStructures.Elf64_Phdr -> ModuleLayer.ProgramHeader: "phdr struct"
DataStructures.ExecutableLayout -> ModuleLayer.ExecWriter: "layout struct"
DataStructures.ExecStats -> ModuleLayer.ExecWriter: "stats output"

# Internal module flow
ModuleLayer.SegmentBuilder -> ModuleLayer.ProgramHeader: "OutputSegment[]"
ModuleLayer.EntryPoint -> ModuleLayer.ELFHeader: "entry vaddr"
ModuleLayer.ELFHeader -> ModuleLayer.ExecWriter: "Elf64_Ehdr"
ModuleLayer.ProgramHeader -> ModuleLayer.ExecWriter: "Elf64_Phdr[]"

# Final output
ModuleLayer.ExecWriter -> Output.ELF_File: "write_executable()"

# ============================================================================
# ANNOTATIONS
# ============================================================================
Legend: {
  near: bottom-right
  style.fill: white
  style.stroke: black
  Note1: |md
    **Key Invariants:**
    - `p_offset % p_align == p_vaddr % p_align`
    - Entry point from `_start` or `main`
    - `p_memsz >= p_filesz` (for .bss)
  |
}

Constants: {
  near: bottom-left
  style.fill: "#F8F9F9"
  style.stroke: "#7F8C8D"
  Note2: |md
    **Constants:**
    - `PAGE_SIZE = 0x1000`
    - `PT_LOAD = 1`
    - `PF_R = 0x4`, `PF_W = 0x2`, `PF_X = 0x1`
    - `ET_EXEC = 2`, `EM_X86_64 = 62`
  |
}