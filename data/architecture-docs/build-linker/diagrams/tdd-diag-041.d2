vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # Complete ELF Executable File Layout
    ## Technical Implementation Specification (x86_64)
  '|
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

direction: right

classes: {
  header_cls: {
    style: {
      fill: "#9B59B6"
      font-color: white
      bold: true
      stroke: "#8E44AD"
      stroke-width: 2
    }
  }
  phdr_cls: {
    style: {
      fill: "#3498DB"
      font-color: white
      bold: true
      stroke: "#2980B9"
    }
  }
  padding_cls: {
    style: {
      fill: "#BDC3C7"
      font-color: "#2C3E50"
      stroke: "#95A5A6"
      stroke-dash: 3
    }
  }
  text_seg_cls: {
    style: {
      fill: "#27AE60"
      font-color: white
      bold: true
      stroke: "#1E8449"
    }
  }
  data_seg_cls: {
    style: {
      fill: "#E74C3C"
      font-color: white
      bold: true
      stroke: "#C0392B"
    }
  }
  offset_label: {
    shape: text
    style: {
      font: mono
      font-size: 14
      font-color: "#7F8C8D"
    }
  }
  vaddr_cls: {
    style: {
      stroke: "#D35400"
      stroke-width: 2
      fill: "#FAE5D3"
    }
  }
}

main_view: {
  style: {
    stroke-width: 0
    fill: transparent
  }

  file_layout: {
    label: "Physical File Layout (On Disk)"
    style: {
      fill: "#F8F9F9"
      stroke: "#34495E"
      stroke-width: 3
    }

    off_0000: "Offset 0x0000" { class: offset_label }
    
    elf_header: {
      label: |'md
        **ELF Header (Ehdr)**
        *Size: 64 bytes*
        ---
        `e_ident`: \x7F ELF ...
        `e_type`: ET_EXEC (2)
        `e_machine`: EM_X86_64 (62)
        `e_entry`: 0x401000
        `e_phoff`: 64 (0x40)
        `e_shoff`: 0 (No sections)
        `e_phnum`: 2
        `e_phentsize`: 56
      '|
      class: header_cls
      width: 320
      height: 220
    }

    off_0040: "Offset 0x0040" { class: offset_label }

    phdr_table: {
      label: "Program Header Table (Phdr)\n112 bytes total (2 * 56B)"
      style: {
        fill: "#D5E8F7"
        stroke: "#2980B9"
      }
      
      phdr_0: {
        label: |'md
          **[0] PT_LOAD (Text)**
          `p_type`: PT_LOAD
          `p_flags`: R | X (5)
          `p_offset`: 0x1000
          `p_vaddr`: 0x401000
          `p_filesz`: 0x200
          `p_memsz`: 0x200
          `p_align`: 0x1000
        '|
        class: phdr_cls
        width: 280
      }
      
      phdr_1: {
        label: |'md
          **[1] PT_LOAD (Data)**
          `p_type`: PT_LOAD
          `p_flags`: R | W (6)
          `p_offset`: 0x2000
          `p_vaddr`: 0x403000
          `p_filesz`: 0x100
          `p_memsz`: 0x200 (.bss)
          `p_align`: 0x1000
        '|
        class: phdr_cls
        width: 280
      }
    }

    off_00B0: "Offset 0x00B0" { class: offset_label }

    padding_align: {
      label: "Alignment Padding\n(0x00B0 - 0x0FFF)\nSize: 3920 bytes"
      class: padding_cls
      width: 320
      height: 100
    }

    off_1000: "Offset 0x1000" { 
      class: offset_label 
      style.bold: true
      style.font-color: black 
    }

    text_segment: {
      label: |'md
        **Text Segment (Code)**
        *Size: 0x200 bytes*
        ---
        `.text` (Entry point at +0)
        `.rodata` (Read-only constants)
      '|
      class: text_seg_cls
      width: 320
      height: 150
    }

    off_1200: "Offset 0x1200" { class: offset_label }

    padding_2: {
      label: "Alignment Padding\n(0x1200 - 0x1FFF)\nSize: 3584 bytes"
      class: padding_cls
      width: 320
      height: 80
    }

    off_2000: "Offset 0x2000" { 
      class: offset_label 
      style.bold: true
      style.font-color: black 
    }

    data_segment: {
      label: |'md
        **Data Segment (Vars)**
        *Size on Disk: 0x100 bytes*
        ---
        `.data` (Initialized globals)
        *Kernel allocates extra 0x100*
        *for .bss at runtime*
      '|
      class: data_seg_cls
      width: 320
      height: 150
    }

    off_2100: "0x2100 (EOF)" { class: offset_label }

    elf_header -> phdr_table: "e_phoff pointers" { style.stroke-dash: 3 }
    phdr_table -> padding_align -> text_segment -> padding_2 -> data_segment
  }

  memory_layout: {
    label: "Process Virtual Address Space"
    style: {
      fill: "#FEF9E7"
      stroke: "#D35400"
      stroke-dash: 5
      stroke-width: 3
    }

    vaddr_start: "Vaddr 0x401000" { class: offset_label }
    
    text_mem: {
      label: |'md
        **Text Segment (RX)**
        ---
        Mapping: File[0x1000:0x1200]
        Vaddr: 0x401000 - 0x4011FF
        Permissions: R-X
      '|
      class: text_seg_cls
      width: 300
      height: 120
    }

    gap_v: {
      label: "--- Page Boundary (4KB) ---\n0x402000"
      shape: text
      style.font-color: "#E67E22"
      style.font: mono
      style.bold: true
    }

    vaddr_data: "Vaddr 0x403000" { class: offset_label }

    data_mem: {
      label: |'md
        **Data Segment (RW)**
        ---
        Mapping: File[0x2000:0x2100]
        Vaddr: 0x403000 - 0x4030FF (.data)
        Vaddr: 0x403100 - 0x4031FF (.bss)
        Permissions: RW-
      '|
      class: data_seg_cls
      width: 300
      height: 150
    }

    text_mem -> gap_v -> data_mem
  }
}

main_view.file_layout -> main_view.memory_layout: "execve() Load Map" {
  style: {
    stroke: orange
    stroke-width: 4
    animated: true
  }
}

alignment_note: {
  label: |'md
    ### Memory Mapping Logic
    The ELF `p_align` (0x1000) field enforces that:
    `p_vaddr % p_align == p_offset % p_align`
    
    This allows the kernel to use the same relative offset within a physical 
    page for both the disk file and the RAM page, enabling **Demand Paging**.
  '|
  shape: text
  near: bottom-left
  style: {
    fill: "#FEF9E7"
    stroke: "#F1C40F"
    stroke-width: 2
  }
}

size_summary: {
  label: |'md
    ### Static File Breakdown
    | Segment | File Range | Size |
    | :--- | :--- | :--- |
    | ELF Header | 0x0000 - 0x003F | 64 B |
    | Program Headers | 0x0040 - 0x00AF | 112 B |
    | Padding (Align) | 0x00B0 - 0x0FFF | 3920 B |
    | **Text Segment** | 0x1000 - 0x11FF | 512 B |
    | Padding (Align) | 0x1200 - 0x1FFF | 3584 B |
    | **Data Segment** | 0x2000 - 0x20FF | 256 B |
    | **TOTAL FILE** | | **8,448 B** |
  '|
  shape: text
  near: bottom-right
  style: {
    fill: "#EAFAF1"
    stroke: "#27AE60"
    stroke-width: 2
  }
}