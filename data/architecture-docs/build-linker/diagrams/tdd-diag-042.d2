vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header: "#6d28d9"
    text_sec: "#2563eb"
    rodata_sec: "#0891b2"
    data_sec: "#059669"
    bss_sec: "#d97706"
    segment_rx: "#1e3a8a"
    segment_rw: "#064e3b"
    logic_bg: "#fffbeb"
    logic_border: "#b45309"
    padding: "#f1f5f9"
  }
}

title: ||md
  # ELF Binary: Sections to Segments Mapping
  ### Engineering Specification: Linker Aggregation & Loader View
|| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# =============================================================================
# INPUT SECTIONS (LINKER VIEW / OBJECT FILES)
# =============================================================================
linker_view: "Input Sections (.o / Linker View)" {
  style: {
    fill: "#f8fafc"
    stroke: "${colors.header}"
    stroke-width: 4
    stroke-dash: 0
    border-radius: 10
  }

  sec_text: ".text" {
    label: ||md
      ### .text (Executable)
      **sh_flags:** SHF_ALLOC | SHF_EXEC
      **Offset:** 0x0000
      **Size:** 0x1240
      **Align:** 16
    ||
    style: {
      fill: "${colors.text_sec}"
      stroke: "#1e40af"
      font-color: white
    }
  }

  sec_rodata: ".rodata" {
    label: |md
      ### .rodata (Read-Only)
      **sh_flags:** SHF_ALLOC
      **Offset:** 0x1240
      **Size:** 0x0600
      **Align:** 8
    |
    style: {
      fill: "${colors.rodata_sec}"
      stroke: "#0e7490"
      font-color: white
    }
  }

  padding_align: "Padding / Alignment" {
    style: {
      fill: "${colors.padding}"
      stroke: "#cbd5e1"
      stroke-dash: 3
    }
  }

  sec_data: ".data" {
    label: ||md
      ### .data (Initialized)
      **sh_flags:** SHF_ALLOC | SHF_WRITE
      **Offset:** 0x1840
      **Size:** 0x0200
      **Align:** 16
    ||
    style: {
      fill: "${colors.data_sec}"
      stroke: "#047857"
      font-color: white
    }
  }

  sec_bss: ".bss" {
    label: ||md
      ### .bss (Uninitialized)
      **sh_type:** SHT_NOBITS
      **sh_flags:** SHF_ALLOC | SHF_WRITE
      **Offset:** 0x1A40
      **Size:** 0x0400
    ||
    style: {
      fill: "${colors.bss_sec}"
      stroke: "#b45309"
      font-color: white
    }
  }
}

# =============================================================================
# MAPPING LOGIC (TRANSFORMATION RULES)
# =============================================================================
mapping_rules: "Linker Aggregation Logic" {
  label: |md
    ## Segment Construction Predicates
    ---
    ### Rule 1: Code/Constant Consolidation
    `IF !(sh_flags & SHF_WRITE) -> PT_LOAD [RX]`
    
    ### Rule 2: Data/BSS Consolidation
    `IF (sh_flags & SHF_WRITE) -> PT_LOAD [RW]`
    
    ### Rule 3: Alignment Requirements
    - Page size alignment (typically 4KB / 0x1000)
    - Virtual address continuity
  |
  style: {
    fill: "${colors.logic_bg}"
    stroke: "${colors.logic_border}"
    stroke-width: 2
    border-radius: 15
    font-size: 14
  }
}

# =============================================================================
# OUTPUT SEGMENTS (LOADER VIEW / EXECUTABLE)
# =============================================================================
loader_view: "Output Segments (Loader View / Executable)" {
  style: {
    fill: "#f8fafc"
    stroke: "${colors.header}"
    stroke-width: 4
    border-radius: 10
  }

  seg_load_rx: "PT_LOAD [RX]" {
    label: ||md
      ## Segment 0: Text/RO
      **p_vaddr:** 0x400000
      **p_filesz:** 0x1840
      **p_memsz:** 0x1840
      **p_flags:** PF_R | PF_X
    ||
    style: {
      fill: "${colors.segment_rx}"
      stroke: "#1e3a8a"
      font-color: white
    }
  }

  page_boundary: "Page Boundary (4096B)" {
    style: {
      stroke: black
      stroke-width: 2
      stroke-dash: 5
      fill: "#e2e8f0"
    }
  }

  seg_load_rw: "PT_LOAD [RW]" {
    label: ||md
      ## Segment 1: Data/BSS
      **p_vaddr:** 0x402000
      **p_filesz:** 0x0200
      **p_memsz:** 0x0600
      **p_flags:** PF_R | PF_W
      *Note: p_memsz > p_filesz due to BSS*
    ||
    style: {
      fill: "${colors.segment_rw}"
      stroke: "#064e3b"
      font-color: white
    }
  }
}

# =============================================================================
# CONNECTIONS & DATA FLOW
# =============================================================================

# Flow from Sections to Rules
linker_view.sec_text -> mapping_rules: "Passes Rule 1"
linker_view.sec_rodata -> mapping_rules: "Passes Rule 1"
linker_view.sec_data -> mapping_rules: "Passes Rule 2"
linker_view.sec_bss -> mapping_rules: "Passes Rule 2"

# Flow from Rules to Segments
mapping_rules -> loader_view.seg_load_rx: "Create RX Bundle" {
  style: {
    stroke: "${colors.text_sec}"
    stroke-width: 4
    animated: true
  }
}

mapping_rules -> loader_view.seg_load_rw: "Create RW Bundle" {
  style: {
    stroke: "${colors.data_sec}"
    stroke-width: 4
    animated: true
  }
}

# Logical Mappings (High Detail)
linker_view.sec_text -> loader_view.seg_load_rx
linker_view.sec_rodata -> loader_view.seg_load_rx
(linker_view.sec_text -> loader_view.seg_load_rx)[0]: {
  style: { stroke-width: 2; stroke: "${colors.text_sec}" }
}
(linker_view.sec_rodata -> loader_view.seg_load_rx)[0]: {
  style: { stroke-width: 2; stroke: "${colors.rodata_sec}" }
}

# BSS Special Case
linker_view.sec_bss -> loader_view.seg_load_rw: "Allocates Virtual Space" {
  style: {
    stroke: "${colors.bss_sec}"
    stroke-width: 3
    stroke-dash: 5
  }
}

# =============================================================================
# ANNOTATIONS & LEGEND
# =============================================================================
legend: "Memory Spec Legend" {
  near: bottom-right
  
  l1: "File-Backed Data" {
    style: {
      stroke: "#2563eb"
      stroke-width: 2
    }
  }
  
  l2: "Runtime Allocation Only (NOBITS)" {
    style: {
      stroke: "${colors.bss_sec}"
      stroke-width: 2
      stroke-dash: 5
    }
  }

  l3: "Execution Flow / Linker Step" {
    style: {
      stroke: "#64748b"
      animated: true
    }
  }
}

# Internal alignment note
loader_view.seg_load_rx -- loader_view.seg_load_rw: "Page Alignment Gap" {
  style: {
    stroke: "#94a3b8"
    stroke-dash: 2
  }
}

# Layout hint removed (near cannot be set to shape ID with elk layout)