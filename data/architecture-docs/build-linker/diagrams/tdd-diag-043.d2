vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Elf64_Phdr Program Header Memory Layout
  **Total Size: 56 bytes (0x38)**
| {near: top-center}

direction: right

# ------------------------------------------------------------------------------------------
# Main Memory Layout Table
# ------------------------------------------------------------------------------------------
header_container: {
  grid-columns: 3
  grid-gap: 0
  
  # Row 1: Header
  offset_h: "Offset" { style: { fill: "#6B5B95"; font-color: white; bold: true; stroke: "#5A4A84" } }
  field_h: "Field Name (ELF64 Program Header)" { style: { fill: "#6B5B95"; font-color: white; bold: true; stroke: "#5A4A84" } }
  size_h: "Size" { style: { fill: "#6B5B95"; font-color: white; bold: true; stroke: "#5A4A84" } }

  # Row 2: p_type
  off_00: "0x00" { style: { fill: "#E8E8E8"; font: mono } }
  p_type: "p_type (Segment Type)" { style: { fill: "#88B04B"; font-color: white; bold: true } }
  p_type_sz: "4 bytes (uint32)" { style: { fill: "#A8D86D"; font-color: "#2D5016" } }

  # Row 3: p_flags
  off_04: "0x04" { style: { fill: "#E8E8E8"; font: mono } }
  p_flags: "p_flags (Segment Flags)" { style: { fill: "#88B04B"; font-color: white; bold: true } }
  p_flags_sz: "4 bytes (uint32)" { style: { fill: "#A8D86D"; font-color: "#2D5016" } }

  # Row 4: p_offset
  off_08: "0x08" { style: { fill: "#E8E8E8"; font: mono } }
  p_offset: "p_offset (File Offset)" { style: { fill: "#5B5EA6"; font-color: white; bold: true } }
  p_offset_sz: "8 bytes (uint64)" { style: { fill: "#7B7EC6"; font-color: white } }

  # Row 5: p_vaddr
  off_10: "0x10" { style: { fill: "#E8E8E8"; font: mono } }
  p_vaddr: "p_vaddr (Virtual Address)" { style: { fill: "#5B5EA6"; font-color: white; bold: true } }
  p_vaddr_sz: "8 bytes (uint64)" { style: { fill: "#7B7EC6"; font-color: white } }

  # Row 6: p_paddr
  off_18: "0x18" { style: { fill: "#E8E8E8"; font: mono } }
  p_paddr: "p_paddr (Physical Address)" { style: { fill: "#5B5EA6"; font-color: white; bold: true } }
  p_paddr_sz: "8 bytes (uint64)" { style: { fill: "#7B7EC6"; font-color: white } }

  # Row 7: p_filesz
  off_20: "0x20" { style: { fill: "#E8E8E8"; font: mono } }
  p_filesz: "p_filesz (Size in File)" { style: { fill: "#EFC050"; font-color: "#3D3200"; bold: true } }
  p_filesz_sz: "8 bytes (uint64)" { style: { fill: "#F5D78E"; font-color: "#3D3200" } }

  # Row 8: p_memsz
  off_28: "0x28" { style: { fill: "#E8E8E8"; font: mono } }
  p_memsz: "p_memsz (Size in Memory)" { style: { fill: "#EFC050"; font-color: "#3D3200"; bold: true } }
  p_memsz_sz: "8 bytes (uint64)" { style: { fill: "#F5D78E"; font-color: "#3D3200" } }

  # Row 9: p_align
  off_30: "0x30" { style: { fill: "#E8E8E8"; font: mono } }
  p_align: "p_align (Alignment)" { style: { fill: "#9B2335"; font-color: white; bold: true } }
  p_align_sz: "8 bytes (uint64)" { style: { fill: "#C84763"; font-color: white } }

  # Termination marker
  off_38: "0x38" { style: { fill: "#2C3E50"; font-color: white; font: mono; bold: true } }
  footer: "END OF Elf64_Phdr" { style: { fill: "#2C3E50"; font-color: white; bold: true } }
  footer_sz: "56 Bytes Total" { style: { fill: "#2C3E50"; font-color: white; bold: true } }
}

# ------------------------------------------------------------------------------------------
# Detailed Descriptions
# ------------------------------------------------------------------------------------------
descriptions: {
  direction: right
  p_type_desc: |md
    **p_type**
    - `PT_NULL` (0): Unused
    - `PT_LOAD` (1): Loadable segment
    - `PT_DYNAMIC` (2): Dynamic linking info
    - `PT_INTERP` (3): Path to interpreter
  | { style.fill: "#F0F8E8"; style.stroke: "#88B04B" }

  p_flags_desc: |md
    **p_flags**
    - `PF_X` (0x1): Execute
    - `PF_W` (0x2): Write
    - `PF_R` (0x4): Read
  | { style.fill: "#F0F8E8"; style.stroke: "#88B04B" }

  vaddr_desc: |md
    **Addresses**
    - `p_vaddr`: Target virtual address
    - `p_paddr`: Physical address (system dependent, often ignored on Linux)
  | { style.fill: "#E8E4F0"; style.stroke: "#5B5EA6" }

  memsz_desc: |md
    **Memory vs File Size**
    - If `p_memsz > p_filesz`, the extra bytes are defined to hold zeros (e.g., `.bss` section).
  | { style.fill: "#FFF8E8"; style.stroke: "#EFC050" }
}

# ------------------------------------------------------------------------------------------
# Byte Level Breakdown Visualization
# ------------------------------------------------------------------------------------------
byte_breakdown: {
  label: "Byte-Level Layout (First 16 Bytes)"
  
  row1: {
    grid-columns: 9
    grid-gap: 0
    b0: "00" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    b1: "01" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    b2: "02" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    b3: "03" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    b4: "04" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    b5: "05" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    b6: "06" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    b7: "07" {style.fill: "#88B04B"; style.font: mono; style.font-color: white}
    l1: "p_type | p_flags" {style.stroke: transparent; style.bold: true}
  }
  row2: {
    grid-columns: 9
    grid-gap: 0
    b8: "08" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    b9: "09" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    b10: "0A" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    b11: "0B" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    b12: "0C" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    b13: "0D" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    b14: "0E" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    b15: "0F" {style.fill: "#5B5EA6"; style.font: mono; style.font-color: white}
    l2: "p_offset" {style.stroke: transparent; style.bold: true}
  }
}

# ------------------------------------------------------------------------------------------
# Struct Reference
# ------------------------------------------------------------------------------------------
struct_ref: |md
  ### C Definition (elf.h)
  c
  typedef struct {
      uint32_t p_type;    /* Segment type */
      uint32_t p_flags;   /* Segment flags */
      uint64_t p_offset;  /* Segment file offset */
      uint64_t p_vaddr;   /* Segment virtual address */
      uint64_t p_paddr;   /* Segment physical address */
      uint64_t p_filesz;  /* Segment size in file */
      uint64_t p_memsz;   /* Segment size in memory */
      uint64_t p_align;   /* Segment alignment */
  } Elf64_Phdr;
  
| {near: bottom-center}

# ------------------------------------------------------------------------------------------
# Legend
# ------------------------------------------------------------------------------------------
legend: {
  label: "Legend"
  grid-columns: 2
  l1: "Control/Flags (32-bit)" { style.fill: "#88B04B"; style.font-color: white }
  l2: "Addressing (64-bit)" { style.fill: "#5B5EA6"; style.font-color: white }
  l3: "Allocation/Size (64-bit)" { style.fill: "#EFC050"; style.font-color: "#3D3200" }
  l4: "Constraints/Align" { style.fill: "#9B2335"; style.font-color: white }
}

# Visual Connections
header_container.p_type -> descriptions.p_type_desc: "Types"
header_container.p_flags -> descriptions.p_flags_desc: "Flags"
header_container.p_vaddr -> descriptions.vaddr_desc
header_container.p_memsz -> descriptions.memsz_desc