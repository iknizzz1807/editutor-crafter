direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# 1. DOCUMENT HEADER (Intel Manual Quality Style)
header: {
  label: |md
    ### FIGURE 4.5: ELF64 ENTRY POINT RESOLUTION LOGIC
    **Subsystem:** Linker / Executable Synthesis
    **Specification:** System V ABI / ELF-64 Object File Format
    **Implementation:** Symbol Table Probe -> Header Patching
  |
  style: {
    stroke: "#4A148C"
    fill: "#F3E8FF"
    stroke-width: 2
    border-radius: 2
  }
}

# 2. MEMORY LAYOUT DIAGRAM (ELF64_Ehdr)
# Per Instruction 1: Headers=Purple, Data=Blue, Byte offsets on left, sizes on right
elf_layout: {
  label: "MEMORY LAYOUT: ELF64_Ehdr (64 Bytes)"
  
  # Byte Map 0x00-0x3F
  # [Offset] : [Field Name] : [Size]
  ident: "0x00 : e_ident[16] : 16B" {
    style.fill: "#E9D5FF" # Purple Header
  }
  type: "0x10 : e_type : 2B" {
    style.fill: "#DBEAFE" # Blue Data
  }
  machine: "0x12 : e_machine : 2B" {
    style.fill: "#DBEAFE"
  }
  version: "0x14 : e_version : 4B" {
    style.fill: "#DBEAFE"
  }
  
  # Target field - highlighted as per instruction #3
  e_entry: "0x18 : e_entry : 8B" {
    label: "0x18 : e_entry : 8B (VIRTUAL ADDR)"
    style: {
      fill: "#FEF08A" # Highlighted for action
      stroke: "#A16207"
      stroke-width: 3
      bold: true
    }
  }
  
  phoff: "0x20 : e_phoff : 8B" {
    style.fill: "#DBEAFE"
  }
  shoff: "0x28 : e_shoff : 8B" {
    style.fill: "#DBEAFE"
  }
  flags: "0x30 : e_flags : 4B" {
    style.fill: "#DBEAFE"
  }
  ehsize: "0x34 : e_ehsize : 2B" {
    style.fill: "#E2E8F0" # Gray Padding/Meta
  }
  phentsize: "0x36 : e_phentsize : 2B" {
    style.fill: "#E2E8F0"
  }
  phnum: "0x38 : e_phnum : 2B" {
    style.fill: "#E2E8F0"
  }
  shentsize: "0x3A : shentsize : 2B" {
    style.fill: "#E2E8F0"
  }
  shnum: "0x3C : e_shnum : 2B" {
    style.fill: "#E2E8F0"
  }
  shstrndx: "0x3E : e_shstrndx : 2B" {
    style.fill: "#E2E8F0"
  }

  ident -> type -> machine -> version -> e_entry -> phoff -> shoff -> flags -> ehsize -> phentsize -> phnum -> shentsize -> shnum -> shstrndx
}

# 3. ALGORITHM STATE DIAGRAM (Numbered TDD Spec)
logic_flow: {
  label: "ENTRY POINT RESOLUTION ALGORITHM"
  
  step_01: "1. Probe '.symtab' for '_start'" {
    shape: diamond
    style.fill: "#F0F9FF"
    style.stroke: "#0369A1"
  }

  step_02: "2. Symbol '_start' Resolved?" {
    shape: diamond
    style.fill: "#FFFBEB"
  }

  step_03_bind: "3A. Bind CRT0 Entry\ne_entry = sym.st_value" {
    style: {
      fill: "#DCFCE7"
      stroke: "#166534"
      stroke-width: 4
      bold: true
    }
  }

  step_04_fallback: "4. Probe '.symtab' for 'main'" {
    shape: diamond
    style.fill: "#F0F9FF"
  }

  step_05: "5. Symbol 'main' Resolved?" {
    shape: diamond
    style.fill: "#FFFBEB"
  }

  step_06_bind: "6. Bind Hosted Entry\ne_entry = sym.st_value" {
    style: {
      fill: "#DCFCE7"
      stroke: "#166534"
      stroke-width: 2
    }
  }

  step_07_err: "7. FATAL: Undefined Entry" {
    style: {
      fill: "#FEE2E2"
      stroke: "#B91C1C"
      font-color: "#991B1B"
      stroke-width: 5
    }
  }

  step_08_commit: "8. Commit VMA to ELF Header\n(Offset 0x18)" {
    style: {
      fill: "#ECFDF5"
      stroke: "#059669"
      stroke-width: 4
      double-border: true
    }
  }

  # Transition Logic
  step_01 -> step_02
  step_02 -> step_03_bind: "YES" { style.stroke: "#22C55E"; style.stroke-width: 4 }
  step_02 -> step_04_fallback: "NO" { style.stroke: "#EF4444"; style.stroke-dash: 5 }
  
  step_04_fallback -> step_05
  step_05 -> step_06_bind: "YES" { style.stroke: "#22C55E" }
  step_05 -> step_07_err: "NO" { style.stroke: "#B91C1C"; style.stroke-width: 4 }
  
  step_03_bind -> step_08_commit
  step_06_bind -> step_08_commit
}

# 4. CROSS-COMPONENT DATA FLOW
# Final 8-byte commit to the memory layout field
logic_flow.step_08_commit -> elf_layout.e_entry: "Write 64-bit Address" {
  style: {
    stroke: "#15803D"
    animated: true
    stroke-width: 3
  }
}

# 5. TECHNICAL ANNOTATIONS
note_vma: |md
  ### RESOLUTION INVARIANTS
  - Address must be in `PT_LOAD` segment
  - Must be aligned to instruction boundary
  - `st_shndx` cannot be `SHN_UNDEF`
| {
  near: logic_flow.step_03_bind
  style: {
    font-size: 11
    stroke-dash: 3
    fill: "#F8FAFC"
    stroke: "#94A3B8"
  }
}

# 6. ARCHITECTURE CLASSES & GLOBALS
classes: {
  technical_note: {
    shape: sticky_note
    style: {
      fill: "#FEFCE8"
      stroke: "#EAB308"
      font-size: 10
    }
  }
}

note_linker: |md
  **Linker Context:**
  Entry point overrides:
  1. `-e <symbol>` cmd line
  2. `ENTRY(<symbol>)` script
  3. Default `_start`
| {
  near: header
  class: technical_note
}

# Footer detail
footer: "sizeof(ELF64_Ehdr) = 64 Bytes | Pointer: 0x18 | Little-Endian" {
  shape: text
  near: elf_layout
  style.italic: true
  style.font-color: "#64748B"
}

# Layout Engine Guidance
logic_flow.step_07_err -> note_vma: { style.stroke: transparent }

# Global Arrow Styling
(*** -> ***)[*]: {
  style: {
    stroke-width: 2
    font-size: 12
  }
}