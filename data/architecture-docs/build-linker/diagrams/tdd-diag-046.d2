layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  near: top-center
  label: |||md
# ELF Segment Building Algorithm (v2.4)
## Phdr Mapping, Memory Bounds & Alignment Logic
  |
}

# --- STYLE CLASSES ---

classes: {
  process: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 4
    }
  }
  decision: {
    shape: diamond
    width: 240
    height: 140
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
    }
  }
  state_box: {
    shape: sql_table
    style: {
      fill: "#ECEFF1"
      stroke: "#455A64"
      font-size: 14
    }
  }
  segment_text: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 3
    }
  }
  segment_data: {
    style: {
      fill: "#F1F8E9"
      stroke: "#33691E"
      stroke-width: 3
    }
  }
}

