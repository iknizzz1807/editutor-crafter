vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5B7"
    data_section: "#B5D8EB"
    bss_section: "#C8E6C9"
    loader: "#FFE0B2"
    arrow_normal: "#1565C0"
    arrow_zero: "#4CAF50"
    arrow_animated: "#FF9800"
  }
}
title: |md
  # p_memsz vs p_filesz for .bss
  **Data segment handling of uninitialized data**
| {near: top-center}
direction: right
file_layout: "Executable File Layout" {
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.border-radius: 8
  elf_header: "ELF Header\n64 bytes" {
    style.fill: "${colors.header}"
    style.stroke: "#8D6E63"
    width: 120
    height: 60
  }
  phdr: "Program Headers\n(PT_LOAD entries)" {
    style.fill: "${colors.header}"
    style.stroke: "#8D6E63"
    width: 120
    height: 60
  }
  text_segment: "Text Segment\n(Code + RO Data)\np_filesz = p_memsz" {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    width: 140
    height: 80
  }
  data_segment_file: "Data Segment\n(File Content)\n┌─────────────┐\n│   .data     │\n│  256 bytes  │\n└─────────────┘\np_filesz = 256" {
    style.fill: "${colors.data_section}"
    style.stroke: "#0288D1"
    width: 140
    height: 100
  }
  padding: "Padding\n(0x1000 aligned)" {
    style.fill: "#F5F5F5"
    style.stroke: "#BDBDBD"
    style.stroke-dash: 3
    width: 80
    height: 40
  }
  elf_header -> phdr: "offset 0x40"
  phdr -> text_segment: "offset 0x1000"
  text_segment -> padding
  padding -> data_segment_file: "offset 0x2000"
}
program_header: "Program Header Entry\n(Data Segment)" {
  style.fill: "#FFF8E1"
  style.stroke: "#FFA000"
  style.border-radius: 8
  width: 200
  phdr_table: {
    p_type: "p_type: PT_LOAD (1)"
    p_flags: "p_flags: PF_R | PF_W (6)"
    p_offset: "p_offset: 0x2000"
    p_vaddr: "p_vaddr: 0x403000"
    p_paddr: "p_paddr: 0x403000"
    p_filesz: "p_filesz: 256 bytes\n(.data only)" {
      style.fill: "${colors.data_section}"
      style.bold: true
    }
    p_memsz: "p_memsz: 512 bytes\n(.data + .bss)" {
      style.fill: "${colors.bss_section}"
      style.bold: true
    }
    p_align: "p_align: 0x1000"
  }
}
memory_layout: "Memory Layout After Loading" {
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.border-radius: 8
  vaddr_data: "Virtual Address: 0x403000" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 14
    style.italic: true
  }
  data_in_mem: ".data Section\n(Initialized)\n256 bytes\n─────────────\nMapped from file\noffset 0x2000" {
    style.fill: "${colors.data_section}"
    style.stroke: "#0288D1"
    width: 140
    height: 90
  }
  bss_in_mem: ".bss Section\n(Uninitialized)\n256 bytes\n─────────────\nZero-filled by\nloader" {
    style.fill: "${colors.bss_section}"
    style.stroke: "#388E3C"
    width: 140
    height: 90
  }
  total_mem: "Total: 512 bytes\n(p_memsz)" {
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    style.border-radius: 4
    width: 120
  }
  vaddr_data -> data_in_mem
  data_in_mem -> bss_in_mem: "+ 256 bytes"
  bss_in_mem -> total_mem
}
loader_action: "Loader Actions" {
  style.fill: "${colors.loader}"
  style.stroke: "#E65100"
  style.border-radius: 8
  width: 180
  step1: "1. mmap() file region\n   offset 0x2000, size 256" {
    shape: text
    style.font-size: 12
  }
  step2: "2. Map to vaddr 0x403000\n   with RW permissions" {
    shape: text
    style.font-size: 12
  }
  step3: "3. Zero-fill remaining\n   (p_memsz - p_filesz)" {
    shape: text
    style.font-size: 12
    style.bold: true
    style.fill: "${colors.bss_section}"
  }
}
formula: "Size Relationship" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.border-radius: 8
  width: 200
  formula_text: |md
    
    p_filesz = .data size
             = 256 bytes
    p_memsz = .data + .bss size
            = 256 + 256
            = 512 bytes
    Zero-fill = p_memsz - p_filesz
              = 512 - 256
              = 256 bytes
    
  |
}
file_layout -> program_header: "Describes" {
  style.stroke: "${colors.arrow_normal}"
  style.stroke-width: 2
}
file_layout.data_segment_file -> memory_layout.data_in_mem: "mmap()\nfile content" {
  style.stroke: "${colors.arrow_normal}"
  style.stroke-width: 2
  style.animated: true
}
memory_layout -> loader_action: "performed by" {
  style.stroke: "#757575"
  style.stroke-dash: 3
}
loader_action -> memory_layout.bss_in_mem: "zero-fill" {
  style.stroke: "${colors.arrow_zero}"
  style.stroke-width: 2
  style.animated: true
}
program_header -> formula: "defines" {
  style.stroke: "#757575"
  style.stroke-dash: 3
}
legend: "Legend" {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 4
  width: 150
  file_data: ".data (in file)" {
    style.fill: "${colors.data_section}"
  }
  zero_fill: ".bss (zero-filled)" {
    style.fill: "${colors.bss_section}"
  }
  loader_op: "Loader operation" {
    style.fill: "${colors.loader}"
  }
}