vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    text-bg: "#E3F2FD"
    text-border: "#1976D2"
    data-bg: "#FFF3E0"
    data-border: "#F57C00"
    enforce-bg: "#FFEBEE"
    enforce-border: "#D32F2F"
    header-purple: "#673AB7"
  }
}

title: ||md
  # Segment Permission Assignment
  ### W^X (Write XOR Execute) Security Model Enforcement
  *Memory Management Unit & OS Loader Logic*
|| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
  }
}

direction: right

text_segment: "ELF Segment: LOAD (Text)\nVirtual Address: 0x400000" {
  style: {
    fill: "${colors.text-bg}"
    stroke: "${colors.text-border}"
    stroke-width: 4
    border-radius: 8
  }
  
  p_flags: "p_flags [0x5]" {
    tooltip: "PF_R | PF_X"
    style: {
      fill: white
      stroke: "${colors.text-border}"
      stroke-dash: 2
      bold: true
    }
    bitmask: "Binary: 101" {
      style.font: mono
    }
  }

  permissions: ||md
    **Permissions Mapping (mmap)**
    - `PROT_READ`: ✓
    - `PROT_WRITE`: ✗
    - `PROT_EXEC`: ✓
  || {
    style: {
      fill: white
      stroke: "${colors.text-border}"
    }
  }

  sections: ".text (Executable Code)\n.rodata (Read-Only Data)\n.hash / .dynsym" {
    style: {
      fill: "#BBDEFB"
      stroke: "${colors.text-border}"
      double-border: true
    }
  }
}

data_segment: "ELF Segment: LOAD (Data)\nVirtual Address: 0x600000" {
  style: {
    fill: "${colors.data-bg}"
    stroke: "${colors.data-border}"
    stroke-width: 4
    border-radius: 8
  }

  p_flags2: "p_flags [0x6]" {
    tooltip: "PF_R | PF_W"
    style: {
      fill: white
      stroke: "${colors.data-border}"
      stroke-dash: 2
      bold: true
    }
    bitmask2: "Binary: 110" {
      style.font: mono
    }
  }

  permissions2: ||md
    **Permissions Mapping (mmap)**
    - `PROT_READ`: ✓
    - `PROT_WRITE`: ✓
    - `PROT_EXEC`: ✗
  || {
    style: {
      fill: white
      stroke: "${colors.data-border}"
    }
  }

  sections2: ".data (Initialized Globals)\n.bss (Zero-Initialized)\n.got / .plt.got" {
    style: {
      fill: "#FFE0B2"
      stroke: "${colors.data-border}"
      double-border: true
    }
  }
}

w_xor_x: "W^X Logic Gate\nEnforcement Engine" {
  style: {
    fill: "${colors.enforce-bg}"
    stroke: "${colors.enforce-border}"
    stroke-width: 3
    border-radius: 12
    double-border: true
  }

  rule: ||md
    **Security Invariant:**
    `∀ page p: (Writable(p) ⊕ Executable(p))`
    
    **Transition Rule:**
    Memory must be immutable before it 
    can be marked as executable.
  || {
    style: {
      fill: white
      stroke: "${colors.enforce-border}"
      font-size: 14
    }
  }

  kernel_check: "mmap() / mprotect()\nValidation Path" {
    style: {
      fill: "#FFCDD2"
      stroke: "${colors.enforce-border}"
      stroke-dash: 3
    }
  }
}

forbidden: "CRITICAL VIOLATION:\nRWX Segment Detected\n(PF_R | PF_W | PF_X)" {
  style: {
    fill: "#B71C1C"
    font-color: white
    stroke: black
    stroke-width: 5
    stroke-dash: 5
    shadow: true
  }
  
  exploit_risk: "Vulnerable to:\n• Stack/Heap Shellcode\n• JIT Spraying\n• Buffer Overflow Code Injection" {
    style: {
      fill: white
      font-color: red
      bold: true
      stroke: red
    }
  }
}

# Connections
text_segment.sections -> w_xor_x: "Code Loading\n(RX)" {
  style: {
    stroke: "${colors.text-border}"
    stroke-width: 2
  }
}

data_segment.sections2 -> w_xor_x: "State Loading\n(RW)" {
  style: {
    stroke: "${colors.data-border}"
    stroke-width: 2
  }
}

w_xor_x -> forbidden: "ILLEGAL REQUEST:\n(PROT_WRITE & PROT_EXEC)" {
  style: {
    stroke: red
    stroke-width: 4
    stroke-dash: 2
    animated: true
  }
}

legend: ||md
  ### Bitwise Reference Manual
  | Flag | Constant | Value | Description |
  | :--- | :--- | :--- | :--- |
  | **PF_X** | 1 << 0 | `0x1` | Execute Permission |
  | **PF_W** | 1 << 1 | `0x2` | Write Permission |
  | **PF_R** | 1 << 2 | `0x4` | Read Permission |

  ### Common ELF Phdr Combinations
  | Name | Flags | Hex | Security Status |
  | :--- | :--- | :--- | :--- |
  | Text/RO | R + X | `0x5` | **SAFE** (W^X Compliant) |
  | Data/RW | R + W | `0x6` | **SAFE** (W^X Compliant) |
  | RWX | R+W+X | `0x7` | **FORBIDDEN** (Exploitable) |
|| {
  near: bottom-center
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    border-radius: 8
    font-size: 12
  }
}

annotations: |md
  **Implementation Note:**
  Modern CPUs enforce this via the **NX (No-Execute)** or **XD (Execute Disable)** bit in the Page Table Entry (PTE).
  The OS kernel prevents `mmap` calls that violate the W^X policy unless explicitly overridden (e.g., legacy apps or specific JIT engines).
| {
  near: bottom-right
  style.font-size: 10
}