vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Executable File Write Sequence (ELF64)
  *Intel Manual Quality Specification*
| {near: top-center}

write_process: {
  shape: sequence_diagram

  # Participants
  Linker: "Linker Engine\n(Logic)"
  Buffer: "uint8_t* Buffer\n(Source Memory)"
  File: "FILE* Output\n(Disk IO)"

  # Phase 1: File Opening
  Linker."1. Open output file"
  Linker -> File: "fopen(path, \"wb\")"
  Linker <- File: "FILE* handle"

  # Phase 2: Write ELF Header
  Linker."2. Write ELF64 Header (64 bytes)"
  Buffer -> File: "write Elf64_Ehdr {\n  e_ident[16] = 7F 45 4C 46 02 01...\n  e_type = ET_EXEC (2)\n  e_machine = EM_X86_64 (62)\n  e_entry = 0x401000\n  e_phoff = 64\n  e_phnum = 2\n}"
  Linker <- File: "64 bytes written\nftell = 0x40"

  # Phase 3: Write Program Headers
  Linker."3. Write Program Header Table"
  Buffer -> File: "write Elf64_Phdr[0] {\n  p_type = PT_LOAD (1)\n  p_flags = PF_R|PF_X (5)\n  p_offset = 0x1000\n  p_vaddr = 0x401000\n  p_filesz = 0x200\n  p_memsz = 0x200\n  p_align = 0x1000\n}"
  Linker <- File: "56 bytes written"
  
  Buffer -> File: "write Elf64_Phdr[1] {\n  p_type = PT_LOAD (1)\n  p_flags = PF_R|PF_W (6)\n  p_offset = 0x2000\n  p_vaddr = 0x403000\n  p_filesz = 0x100\n  p_memsz = 0x200  \n  p_align = 0x1000\n}"
  Linker <- File: "56 bytes written\nftell = 0x70"

  # Phase 4: Seek to First Segment
  Linker."4. Seek to text segment offset"
  Linker -> File: "fseek(file, 0x1000, SEEK_SET)"
  Linker <- File: "position = 0x1000"

  # Phase 5: Write Text Segment
  Linker."5. Write text segment content"
  Buffer -> File: "write(text_segment_data, 0x200)"
  Linker <- File: "0x200 bytes written\nftell = 0x1200"

  # Phase 6: Seek to Data Segment
  Linker."6. Seek to data segment offset"
  Linker -> File: "fseek(file, 0x2000, SEEK_SET)"
  Linker <- File: "position = 0x2000"

  # Phase 7: Write Data Segment
  Linker."7. Write data segment content"
  Buffer -> File: "write(data_segment_data, 0x100)"
  Linker <- File: "0x100 bytes written\nftell = 0x2100"

  # Phase 8: Close File
  Linker."8. Close file handle"
  Linker -> File: "fclose(file)"
  Linker <- File: "success"

  # Phase 9: Set Permissions
  Linker."9. Set executable permissions"
  Linker -> File: "chmod(path, 0755)"
  Linker <- File: "0 (success)"

  # Final State
  File."Executable ready:\n- File size: 0x2100 (8448 bytes)\n- Entry: 0x401000 (_start)\n- 2 PT_LOAD segments\n- Permissions: rwxr-xr-x"
}

# Styling to Intel standard
write_process.Linker.style.fill: "#E1F5FE"
write_process.Buffer.style.fill: "#FFF9C4"
write_process.File.style.fill: "#E8F5E9"

(write_process.Buffer -> write_process.File)[*].style.stroke: "#1976D2"
(write_process.Linker -> write_process.File)[*].style.stroke: "#388E3C"