direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    text_seg: "#8B5CF6"
    data_seg: "#3B82F6"
    free_seg: "#10B981"
    padding_seg: "#6B7280"
    bss_seg: "#94A3B8"
    ptr_orange: "#F59E0B"
    page_boundary: "#000000"
  }
}

# Virtual Address Space Layout (ELF x86_64)
# Designed for technical engineering specification - Process Memory Map After execve

title: {
  label: |md
    # Virtual Address Space Layout (ELF x86_64)
    ### Process Memory Map After `execve`
  |
  near: top-center
}

vas: "Virtual Address Space [sizeof=0x800000000000]" {
  style: {
    fill: "#F8FAFC"
    stroke: "#1E293B"
    stroke-width: 2
  }

  low: "0x0000000000000000 (NULL)" {
    shape: text
    style: {
      font-size: 14
      font-color: "#64748B"
    }
  }

  # Text Segment
  text_segment: {
    label: "Text Segment (RX) | Offset: 0x401000"
    style: {
      fill: ${colors.text_seg}
      stroke: ${colors.page_boundary}
      stroke-width: 4
      font-color: white
      bold: true
    }
    
    content: {
      label: |md
        **Page Boundary (Bold)**
        - .text (Executable Code)
        - .rodata (Constants)
        - .eh_frame (Unwind Info)
      |
      style.font-size: 12
    }
    
    size_note: "Size: 4096B (1 Page)" {
      near: right-center
      shape: text
      style.font-color: "#475569"
    }
  }

  # Segment Padding
  gap1: "Padding / Alignment Gap" {
    style: {
      fill: ${colors.padding_seg}
      opacity: 0.2
      stroke-dash: 5
      font-color: "#64748B"
      italic: true
    }
    size_note: "Size: 4096B" {
      near: right-center
      shape: text
    }
  }

  # Data Segment
  data_segment: {
    label: "Data Segment (RW) | Offset: 0x403000"
    style: {
      fill: ${colors.data_seg}
      stroke: ${colors.page_boundary}
      stroke-width: 4
      font-color: white
      bold: true
    }
    
    content: {
      label: |md
        **Page Boundary (Bold)**
        - .data (Initialized Globals)
        - .bss (Zero-filled Globals)
      |
      style.font-size: 12
    }

    size_note: "Size: 4096B (1 Page)" {
      near: right-center
      shape: text
      style.font-color: "#475569"
    }
  }

  # Stack and Heap Region
  stack_heap: "Unallocated Memory (Free)" {
    style: {
      fill: ${colors.free_seg}
      opacity: 0.15
      stroke-dash: 2
      font-color: "#475569"
    }
    
    note: {
      label: |md
        *Heap grows UP* ↑  
        *Stack grows DOWN* ↓
      |
      shape: text
    }
  }

  high: "0x00007FFFFFFFFFFF (USER_MAX)" {
    shape: text
    style: {
      font-size: 14
      font-color: "#64748B"
    }
  }
}

# Linear Sequence for memory stacking
vas.low -> vas.text_segment
vas.text_segment -> vas.gap1
vas.gap1 -> vas.data_segment
vas.data_segment -> vas.stack_heap
vas.stack_heap -> vas.high

# Technical Callouts
entry_pointer: "RIP Entry" {
  icon: arrow-right
  near: vas.text_segment
  style: {
    stroke: ${colors.ptr_orange}
    stroke-width: 3
    font-color: ${colors.ptr_orange}
    bold: true
  }
}

bss_expansion: {
  label: |md
    ### .bss Allocation
    Loader expands `p_memsz` > `p_filesz`.
    Runtime delta zeroed out.
  |
  near: vas.data_segment
  style: {
    fill: "#F1F5F9"
    stroke: ${colors.padding_seg}
    font-size: 11
  }
}

alignment_check: {
  label: |md
    **ELF Alignment Logic**
    `vaddr % align == offset % align`
    `0x401000 % 4k == 0x1000 % 4k`
  |
  near: top-right
  style: {
    stroke: "#CBD5E1"
    fill: "#F8FAFC"
    font-size: 10
  }
}

# Legend for manual reference
legend: "Memory Layout Reference" {
  near: bottom-center
  grid-columns: 4
  
  l1: "Text (RX)" {
    style.fill: ${colors.text_seg}
    style.font-color: white
  }
  l2: "Data (RW)" {
    style.fill: ${colors.data_seg}
    style.font-color: white
  }
  l3: "Padding" {
    style.fill: ${colors.padding_seg}
    style.opacity: 0.5
  }
  l4: "Free/Heap" {
    style.fill: ${colors.free_seg}
    style.opacity: 0.5
  }
}

# Styling Globs
vas.text_segment.content.style.bold: false
vas.data_segment.content.style.bold: false