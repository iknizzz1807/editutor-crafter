vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# DIAGRAM: OS LOADER MMAP OPERATION (ELF-x86_64)
# Technical specification for segment mapping and process initialization.

loader_process: {
  shape: sequence_diagram

  User: User Process {
    style.fill: "#C7F1FF"
  }
  Loader: ld-linux.so {
    style.fill: "#B5AFF6"
  }
  ELF: "ELF File\n(Disk Asset)" {
    style.fill: "#E4DBFE"
  }
  Kernel: Linux Kernel {
    style.fill: "#C7F1FF"
  }
  Memory: "Virtual Address Space" {
    style.fill: "#DEE1EB"
  }

  # --- Phase 1: Initiation ---
  User.t1 -> Loader.t1: "execve(\"./program\")"
  Loader.t1: "Bootstrap dynamic linker"

  # --- Phase 2: Metadata Acquisition ---
  Loader.t1 -> ELF.t1: "open(path, O_RDONLY)"
  ELF.t1 -> Loader.t1: "ret: fd=3"
  
  Loader.t1 -> ELF.t2: "read(fd, buf, 64)"
  ELF.t2 -> Loader.t1: "EHDR Data"
  
  Loader."EHDR Analysis: Entry: 0x401000, PH-Offset: 64, PH-Num: 8"

  # --- Phase 3: Segment Mapping (Text Segment) ---
  Loader.t1 -> Loader.t2: "parse_phdr(PT_LOAD[0])"

  Loader.t2 -> Kernel.t1: "mmap(0x401000, 0x1200)" {
    tooltip: "prot: PROT_READ|PROT_EXEC, flags: MAP_FIXED|MAP_PRIVATE, offset: 0x1000"
  }

  Kernel.t1 -> Memory.t1: "Alloc VMA [0x401000-0x402200)"
  Memory.t1 -> Kernel.t1: "SUCCESS"
  
  Kernel.t1 -> Loader.t2: "ret: 0x401000"

  # --- Phase 4: Segment Mapping (Data/BSS Segment) ---
  Loader.t2 -> Kernel.t2: "mmap(0x403000, 0x200)" {
    tooltip: "prot: PROT_READ|PROT_WRITE, offset: 0x2000"
  }

  Kernel.t2 -> Memory.t2: "Map [0x2000-0x2100) -> [0x403000-0x403100)"
  
  Kernel.t2 -> Memory.t3: "Anon Map [0x403100-0x403200)"
  Memory.t3 -> Kernel.t2: "Zeroed (.bss)"

  Kernel.t2 -> Loader.t2: "ret: 0x403000"

  # --- Phase 5: Control Transfer ---
  Loader.t2 -> Loader.t3: "setup_stack_and_vdso()"
  
  Loader.t3 -> Kernel.t3: "arch_prctl(ARCH_SET_FS, ...)"
  Kernel.t3 -> Loader.t3: "OK"

  Loader.t3 -> User.t2: "JMP 0x401000 (e_entry)"
  User.t2: "Execute Application Code"
}

# --- Style Overrides for Critical Paths ---

loader_process.Kernel -> loader_process.Memory.style: {
  stroke: purple
  stroke-width: 2
}

loader_process.Kernel -> loader_process.Memory.style: {
  stroke: orange
  stroke-width: 2
}

loader_process.Loader -> loader_process.User.style: {
  stroke: green
  stroke-width: 3
  animated: true
}

# --- Detailed Technical Metadata (Appendix) ---

loader_logic_appendix: {
  label: ||md
  ### Dynamic Linker Implementation
  c
  // phdr processing loop
  for (i = 0; i < e_phnum; i++) {
      if (ph[i].p_type == PT_LOAD) {
          void* map = mmap(
              (void*)ph[i].p_vaddr,
              ph[i].p_memsz,
              elf_prot(ph[i].p_flags),
              MAP_FIXED | MAP_PRIVATE,
              fd, ph[i].p_offset
          );
          if (ph[i].p_memsz > ph[i].p_filesz) {
              memset(map + ph[i].p_filesz, 0, 
                     ph[i].p_memsz - ph[i].p_filesz);
          }
      }
  }
  
  ||
  near: loader_process.Loader
}

kernel_vma_appendix: {
  label: |md
  ### Kernel VMA Descriptor
  - **vm_start:** `p_vaddr`
  - **vm_end:** `p_vaddr + p_memsz`
  - **vm_page_prot:** Derived from `p_flags`
  - **vm_file:** FD 3 (if `p_filesz > 0`)
  |
  near: loader_process.Kernel
}

final_memory_layout: {
  label: ||md
  ### Final Virtual Address Layout
  | V-Addr Range | Size | Section | Prot |
  | :--- | :--- | :--- | :--- |
  | `0x401000-0x402200` | `0x1200` | `.text` | `R-X` |
  | `0x403000-0x403100` | `0x100` | `.data` | `RW-` |
  | `0x403100-0x403200` | `0x100` | `.bss` | `RW-` |
  ||
  near: loader_process.Memory
}