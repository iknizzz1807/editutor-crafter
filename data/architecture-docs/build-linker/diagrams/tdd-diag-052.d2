layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Minimal Executable Example Trace
    Complete walkthrough: `_start.s` → `as` → `ld` → `a.out` → CPU Execution
  |
  near: top-center
  style.font-size: 24
}

# =============================================================================
# STEP 1: SOURCE ASSEMBLY
# =============================================================================
step1_container: "Step 1: Source Assembly" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  
  source_code: {
    shape: code
    language: asm
    label: |asm
      ; minimal.s - Exit with code 42
      .section .text
      .globl _start
      _start:
          mov $42, %rdi    ; status = 42
          mov $60, %rax    ; syscall: exit
          syscall
    |
  }
  
  source_note: {
    shape: sticky_note
    label: |md
      **Freestanding x86_64 Assembly**
      - No Standard Library (libc)
      - Raw Linux System Call interface
      - Entry Point defined as `_start`
    |
  }
}

# =============================================================================
# STEP 2: ASSEMBLE TO OBJECT FILE
# =============================================================================
step2_container: "Step 2: Assemble to Object" {
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  
  as_cmd: {
    shape: code
    language: bash
    label: |bash
      $ as -o _start.o minimal.s
    |
  }
  
  obj_structure: {
    label: "File: _start.o (Relocatable)"
    style.fill: "#BBDEFB"
    
    header: {
      label: "ELF Header (64B)"
      style.fill: "#90CAF9"
      tooltip: "Type: ET_REL (Object)"
    }
    
    text_section: {
      label: ".text (Machine Code)"
      style.fill: "#81D4FA"
      bytes: {
        shape: code
        label: |text
          BF 2A 00 00 00  ; mov $42, %edi
          B8 3C 00 00 00  ; mov $60, %eax
          0F 05           ; syscall
        |
      }
    }
    
    symtab: {
      label: ".symtab (Symbols)"
      style.fill: "#80DEEA"
      table: |md
        | Name | Value | Binding |
        | :--- | :--- | :--- |
        | `_start` | 0x0 | GLOBAL |
      |
    }
  }
  
  obj_note: {
    shape: sticky_note
    label: |md
      **Relocatable Output**
      - Addresses are zero-relative
      - Sections are not yet mapped to VMA
    |
  }
}

# =============================================================================
# STEP 3: LINKER PROCESSING PIPELINE
# =============================================================================
step3_container: "Step 3: Linker Pipeline (ld)" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  
  m1_merge: {
    label: "M1: Section Layout"
    style.fill: "#FFE0B2"
    description: |md
      - Collect .text from all .o
      - Assign Start VMA: 0x401000
    |
  }
  
  m2_resolve: {
    label: "M2: Symbol Binding"
    style.fill: "#FFCC80"
    description: |md
      - Find `_start` in `_start.o`
      - Set Entry: 0x401000
    |
  }
  
  m3_reloc: {
    label: "M3: Relocation"
    style.fill: "#FFB74D"
    content: "No external symbols to patch"
  }
  
  m4_exec: {
    label: "M4: ELF Generation"
    style.fill: "#FFA726"
    content: "Building Program Headers (Phdr)"
  }
  
  m1_merge -> m2_resolve -> m3_reloc -> m4_exec
}

# =============================================================================
# STEP 4: GENERATED EXECUTABLE STRUCTURE
# =============================================================================
step4_container: "Step 4: Executable Binary (a.out)" {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  
  exec_layout: {
    label: "Binary Map: a.out"
    style.fill: "#E1BEE7"
    grid_display: {
      shape: code
      label: |text
        Offset    Field              VMA         Size
        0x0000    ELF Header         -           64B
        0x0040    Program Header     -           56B
        ...       ...                ...         ...
        0x1000    .text (Code)       0x401000    12B
      |
    }
  }
  
  phdr_details: {
    label: "Program Header (PT_LOAD)"
    style.fill: "#CE93D8"
    content: |md
      - **Type:** LOAD
      - **VAddr:** 0x401000
      - **Flags:** R X (Read + Exec)
      - **Align:** 0x1000
    |
  }
  
  exec_layout -> phdr_details
}

# =============================================================================
# STEP 5: VERIFICATION
# =============================================================================
step5_container: "Step 5: Verification" {
  style.fill: "#E0F2F1"
  style.stroke: "#009688"
  
  readelf: {
    label: "readelf -h a.out"
    style.fill: "#B2DFDB"
    output_box: {
      shape: code
      label: |text
        Class: ELF64
        Entry point: 0x401000
        Type: EXEC (Executable file)
      |
    }
  }
  
  objdump: {
    label: "objdump -d a.out"
    style.fill: "#80CBC4"
    output_box: {
      shape: code
      label: |text
        0000000000401000 <_start>:
          401000: bf 2a 00 00 00   mov $0x2a,%edi
          401005: b8 3c 00 00 00   mov $0x3c,%eax
          40100a: 0f 05            syscall
      |
    }
  }
  
  readelf -> objdump
}

# =============================================================================
# STEP 6: EXECUTION
# =============================================================================
step6_container: "Step 6: OS Loading & CPU State" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  
  kernel_loader: {
    label: "Linux Execve()"
    style.fill: "#FFCDD2"
    details: |md
      1. Map File(0x1000) -> RAM(0x401000)
      2. Initialize Stack (argc, argv)
      3. Set instruction pointer: RIP = 0x401000
    |
  }
  
  cpu_execution: {
    label: "CPU Cycle Trace"
    style.fill: "#EF9A9A"
    trace_log: {
      shape: code
      label: |text
        [FETCH] 0x401000 -> EDI=42
        [FETCH] 0x401005 -> EAX=60
        [FETCH] 0x40100A -> SYSCALL(60, 42)
      |
    }
  }
  
  terminal: {
    label: "Terminal Result"
    style.fill: "#E57373"
    shape: code
    language: bash
    label: |bash
      $ ./a.out
      $ echo $?
      42
    |
  }
  
  kernel_loader -> cpu_execution -> terminal
}

# =============================================================================
# GLOBAL CONNECTORS
# =============================================================================
step1_container -> step2_container: "as"
step2_container -> step3_container: "ld"
step3_container -> step4_container: "write"
step4_container -> step5_container: "audit"
step5_container -> step6_container: "execve()"

summary: {
  label: |md
    ### Execution Summary
    - **Total Code Size:** 12 Bytes
    - **Entry Point:** 0x401000 (VMA)
    - **Isolation:** Static (No Shared Libs)
    - **Exit Code:** 42
  |
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
}