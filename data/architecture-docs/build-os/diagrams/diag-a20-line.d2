direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  shape: text
  label: "A20 Line Enable Methods"
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  before: {
    direction: down
    label: "Before (A20 Disabled)"
    style.stroke: "#C0392B"
    cpu_before: {
      label: "CPU Address Bus"
      width: 280
      addr_gen: {
        label: "Address Generator"
        width: 260
        shape: rectangle
        code: |'c
          // CPU outputs 0x100000
          // (1MB + 0)
          addr_bus = 0x100000;
        '|
      }
    }
    a20_gate_off: {
      label: "A20 Gate"
      shape: diamond
      width: 120
      style: {
        fill: "#E74C3C"
        stroke: "#C0392B"
        stroke-width: 3
      }
      status: {
        label: "OPEN"
        style: {
          fill: transparent
          stroke: transparent
          font-color: "#C0392B"
          bold: true
          font-size: 16
        }
      }
    }
    memory_wrap: {
      label: "Physical RAM"
      width: 280
      wrap_note: {
        label: "Address wraps around!"
        width: 260
        style.fill: "#FADBD8"
        code: |'c
          // A20=0 forces wrap
          // 0x100000 -> 0x000000
          // Bit 20 masked out
          actual = addr & 0x0FFFFF;
        '|
      }
    }
    cpu_before.addr_gen -> a20_gate_off: "21-bit addr"
    a20_gate_off -> memory_wrap.wrap_note: "20-bit (wrapped)"
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  after: {
    direction: down
    label: "After (A20 Enabled)"
    style.stroke: "#27AE60"
    cpu_after: {
      label: "CPU Address Bus"
      width: 280
      addr_gen2: {
        label: "Address Generator"
        width: 260
        shape: rectangle
        code: |'c
          // CPU outputs 0x100000
          // Full address preserved
          addr_bus = 0x100000;
        '|
      }
    }
    a20_gate_on: {
      label: "A20 Gate"
      shape: diamond
      width: 120
      style: {
        fill: "#2ECC71"
        stroke: "#27AE60"
        stroke-width: 3
      }
      status2: {
        label: "CLOSED"
        style: {
          fill: transparent
          stroke: transparent
          font-color: "#27AE60"
          bold: true
          font-size: 16
        }
      }
    }
    memory_full: {
      label: "Physical RAM"
      width: 280
      full_note: {
        label: "Full address range!"
        width: 260
        style.fill: "#D5F5E3"
        code: |'c
          // A20=1, no wrap
          // 0x100000 -> 0x100000
          // Can access >1MB
          actual = addr;  // 4GB max
        '|
      }
    }
    cpu_after.addr_gen2 -> a20_gate_on: "21-bit addr"
    a20_gate_on -> memory_full.full_note: "21-bit (full)"
  }
}
before -> after: {
  label: "Enable A20"
  style: {
    stroke: "#3498DB"
    stroke-width: 3
    animated: true
  }
}
methods_title: {
  near: bottom-left
  shape: text
  label: "Three Methods to Enable A20:"
  style: {
    font-size: 20
    bold: true
  }
}
methods: {
  near: bottom-left
  direction: down
  label: "Enable Methods"
  method1: {
    label: "Method 1: BIOS INT 15h (Safest)"
    width: 380
    style.fill: "#D5F5E3"
    code: |'asm
      ; Try BIOS first
      mov ax, 0x2401    ; AH=24h, AL=01
      int 0x15          ; BIOS A20 service
      jc .try_next      ; Failed if carry set
    '|
  }
  method2: {
    label: "Method 2: Fast A20 (Port 0x92)"
    width: 380
    style.fill: "#D6EAF8"
    code: |'asm
      ; System Control Port A
      in al, 0x92
      test al, 2        ; Check if already on
      jnz .done
      or al, 2          ; Set A20 bit
      and al, 0xFE      ; Clear reset bit!
      out 0x92, al
    '|
  }
  method3: {
    label: "Method 3: Keyboard Controller"
    width: 380
    style.fill: "#FCF3CF"
    code: |'asm
      ; 8042 KBC - slow but reliable
      call kbd_wait      ; Wait for input buf
      mov al, 0xD1       ; Write output port
      out 0x64, al
      call kbd_wait
      mov al, 0xDF       ; A20 enable bit
      out 0x60, al
    '|
  }
}
ports_ref: {
  near: bottom-right
  direction: down
  label: "Port Reference"
  port_table: {
    shape: sql_table
    label: "A20 Control Ports"
    p0: "0x60 | KBC Data     | Read/Write"
    p1: "0x64 | KBC Command  | Write only"
    p2: "0x92 | Fast A20     | R/W bit 1"
    p3: "0x92 | Reset ctrl   | Bit 0=0 safe!"
  }
}
history_note: {
  near: bottom-right
  label: "Historical Context"
  width: 320
  style.fill: "#F5EEF8"
  note: |md
    **Why A20 exists:**
    The 8086 (1978) had only 20 address
    lines. Addresses above 1MB would
    wrap around to 0.
    Some early software relied on this!
    When the 286 added more address
    lines, IBM added a gate to disable
    A20 for compatibility.
    Modern CPUs don't need it, but the
    gate remains for legacy support.
  |
}