direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # x86 Boot Sequence Timeline
| {near: top-center}
legend: {
  near: bottom-right
  mode_16: "16-bit Real Mode" {
    shape: rectangle
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
  }
  mode_32: "32-bit Protected Mode" {
    shape: rectangle
    style.fill: "#98FB98"
    style.stroke: "#228B22"
  }
  transition: "Mode Transition" {
    shape: diamond
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage1: "Stage 1: Power-On" {
    direction: down
    label: "Power-On (t=0ms)"
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    cpu_state: {
      shape: class
      label: "CPU State"
      CS: "0xF000"
      IP: "0xFFF0"
      Mode: "16-bit Real"
    }
    action1: |md
      CPU loads entry point
      from BIOS ROM
    | {
      shape: rectangle
      width: 160
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage2: "Stage 2: BIOS POST" {
    direction: down
    label: "BIOS POST (t=1-500ms)"
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    bios_actions: {
      shape: class
      label: "BIOS Actions"
      step1: "+Memory Test"
      step2: "+Hardware Init"
      step3: "+Boot Device Search"
    }
    action2: |md
      Searches for bootable
      disk (sector 0)
    | {
      shape: rectangle
      width: 160
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage3: "Stage 3: MBR Load" {
    direction: down
    label: "MBR Load (t=500ms)"
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    mbr_load: {
      shape: class
      label: "BIOS Action"
      dst: "0x7C00"
      size: "512 bytes"
      src: "Disk Sector 0"
    }
    mbr_state: {
      shape: sql_table
      label: "Memory at 0x7C00"
      row1: "0x7C00 | Boot code"
      row2: "0x7DBE | Partition table"
      row3: "0x7DFE | 0x55 0xAA (sig)"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage4: "Stage 4: Bootloader" {
    direction: down
    label: "Bootloader (t=501ms)"
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    boot_actions: {
      shape: class
      label: "Bootloader Tasks"
      step1: "+Enable A20 line"
      step2: "+Load kernel from disk"
      step3: "+Setup GDT"
      step4: "+Enter protected mode"
    }
    gdt_setup: {
      shape: sql_table
      label: "GDT (Global Descriptor Table)"
      entry0: "0x00 | Null Descriptor"
      entry1: "0x08 | Kernel Code (base=0, limit=4GB)"
      entry2: "0x10 | Kernel Data (base=0, limit=4GB)"
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage5: "Mode Transition" {
    direction: down
    label: "CR0.PG Enable"
    shape: diamond
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
    transition_code: {
      label: "Critical Sequence"
      width: 200
      code: |'asm
        cli              ; Disable ints
        lgdt [gdt_desc]  ; Load GDT
        mov eax, cr0
        or eax, 1        ; Set PE bit
        mov cr0, eax     ; Enable PM
        jmp 0x08:pm_entry ; Far jump
      '|
    }
    warning: |md
      **CRITICAL**: Must far-jump
      to flush pipeline and
      load new CS selector
    | {
      shape: callout
      style.fill: "#FF6B6B"
      style.font-color: white
    }
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage6: "Stage 6: Protected Mode" {
    direction: down
    label: "Protected Mode (t=502ms)"
    style.fill: "#98FB98"
    style.stroke: "#228B22"
    pm_state: {
      shape: class
      label: "CPU State (32-bit)"
      CS: "0x08 (Kernel Code Sel)"
      DS: "0x10 (Kernel Data Sel)"
      Mode: "32-bit Protected"
      Paging: "Disabled"
    }
    pm_actions: {
      shape: class
      label: "PM Entry Actions"
      step1: "+Load segment regs"
      step2: "+Setup 32-bit stack"
      step3: "+Copy kernel to 1MB"
      step4: "+Jump to kernel"
    }
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage7: "Stage 7: Kernel Entry" {
    direction: down
    label: "Kernel Entry (t=503ms)"
    style.fill: "#98FB98"
    style.stroke: "#228B22"
    entry_asm: {
      shape: sql_table
      label: "entry.asm (_start)"
      row1: "cli | Disable interrupts"
      row2: "cld | Clear direction flag"
      row3: "rep stosb | Zero BSS section"
      row4: "call kernel_main | Enter C code"
    }
    kernel_main: {
      shape: class
      label: "kernel.c (kernel_main)"
      init1: "+vga_init()"
      init2: "+serial_init()"
      init3: "+idt_init()"
      init4: "+pic_init()"
      init5: "+timer_init()"
    }
  }
}
row8: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage8: "Stage 8: Running Kernel" {
    direction: down
    label: "Running Kernel"
    style.fill: "#98FB98"
    style.stroke: "#228B22"
    final_state: {
      shape: class
      label: "Final CPU State"
      CS: "0x08 (32-bit flat)"
      DS: "0x10 (32-bit flat)"
      SS: "0x10 (32-bit flat)"
      EIP: "kernel_main + offset"
      EFLAGS: "0x202 (IF=1)"
    }
    memory_map: {
      shape: sql_table
      label: "Memory Layout"
      row1: "0x000000 | IVT (1KB)"
      row2: "0x007C00 | Bootloader (512B)"
      row3: "0x0B8000 | VGA Buffer"
      row4: "0x100000 | Kernel (1MB+)"
    }
  }
}
stage1 -> stage2: "BIOS entry"
stage2 -> stage3: "Read sector 0"
stage3 -> stage4: "Jump 0x7C00"
stage4 -> stage5: "Setup complete"
stage5 -> stage6: "CR0.PE = 1"
stage6 -> stage7: "jmp 0x100000"
stage7 -> stage8: "kernel_main running"
time_axis: |md
  **Timeline**: 0ms → 500ms → 501ms → 502ms → 503ms → Running
| {near: bottom-center}