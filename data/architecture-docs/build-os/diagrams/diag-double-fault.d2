direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # x86 Fault Escalation Chain
  Exception → Handler Fault → Double Fault → Triple Fault → Reset
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  normal: {
    direction: down
    label: "Normal Execution"
    code: {
      width: 280
      code: |'c
        void process_data(int *ptr) {
          int x = *ptr;    // Crash here!
          // ptr = NULL
        }
      '|
    }
  }
  arrow1: {
    shape: text
    label: |md
      **NULL ptr**
      **dereference**
    |
  }
}
arrow1 -> ex1: "Exception 14\n(Page Fault)"
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ex1: {
    direction: down
    label: "Exception Handler"
    style.fill: "#FFE4E1"
    style.stroke: "#8B0000"
    handler1: {
      label: "page_fault_handler()"
      width: 300
      code: |'c
        void page_fault_handler(regs_t *r) {
          uint32_t addr;
          asm("mov %%cr2, %0" : "=r"(addr));
          char buf[32];        // Stack buffer
          kprintf(buf);        // BUG: buf uninitialized!
          // ...crashes accessing garbage
        }
      '|
    }
  }
}
ex1 -> ex2: "Handler faults\n(Exception during exception)"
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ex2: {
    direction: down
    label: "Double Fault (Vector 8)"
    style.fill: "#FF6B6B"
    style.stroke: "#8B0000"
    style.font-color: white
    df_box: {
      label: "CPU detects: Exception while handling exception"
      shape: rectangle
      width: 320
      style.fill: "#FFCCCC"
      style.stroke: "#8B0000"
      style.font-color: black
    }
    df_handler: {
      label: "double_fault_handler()"
      width: 300
      code: |'c
        void double_fault_handler(regs_t *r) {
          // CRITICAL: Must be bulletproof!
          // If this faults, we triple fault
          vga_print("DOUBLE FAULT");
          // BUG: What if VGA not init?
          // BUG: What if stack corrupt?
          halt();  // Safe: stop here
        }
      '|
    }
  }
}
ex2 -> ex3: "Double fault\nhandler crashes"
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ex3: {
    direction: down
    label: "Triple Fault"
    style.fill: "#4A0000"
    style.stroke: "#000000"
    style.font-color: white
    style.bold: true
    tf_box: {
      label: "CPU: No more handlers to call"
      shape: diamond
      width: 280
      style.fill: "#660000"
      style.stroke: "#000000"
      style.font-color: white
    }
    tf_result: {
      label: |md
        **Three consecutive faults:**
        1. Original exception
        2. Fault in handler → Double Fault
        3. Fault in double fault handler → TRIPLE FAULT
      |
      shape: rectangle
      width: 320
      style.fill: "#330000"
      style.stroke: "#000000"
      style.font-color: "#FF6666"
    }
  }
}
ex3 -> reset: "CPU gives up\nImmediate action"
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  reset: {
    direction: down
    label: "System Reset"
    style.fill: "#000000"
    style.stroke: "#FF0000"
    style.font-color: "#FF0000"
    style.bold: true
    reset_box: {
      label: |md
        ## **CPU RESET**
        *No error message*
        *No stack trace*
        *No debugging info*
        Just silence and reboot.
      |
      shape: rectangle
      width: 280
      style.fill: "#1A1A1A"
      style.stroke: "#FF0000"
      style.font-color: "#FF4444"
    }
  }
}
legend: {
  near: bottom-right
  label: "Fault Chain Rules"
  style.fill: "#F5F5F5"
  style.stroke: "#666666"
  rules: |md
    **Vector 8 (Double Fault) triggers when:**
    - Exception occurs during:
      - Handling another exception
      - Loading IDT entry
      - Stack operation (SS fault)
    **Triple Fault = System Reset**
    - No software recovery possible
    - CPU asserts RESET line
    **Safe Double Fault Handler:**
    - Use separate stack (TSS.ESP0)
    - No function calls
    - Direct VGA memory write
    - Infinite halt loop
  |
}
stack_view: {
  near: bottom-left
  label: "Stack State During Escalation"
  normal_stack: {
    label: "Normal"
    shape: rectangle
    width: 120
    stack1: |md
      
      EIP (return)
      EBP
      locals...
      
    |
    style.fill: "#E8F5E9"
  }
  fault_stack: {
    label: "After Page Fault"
    shape: rectangle
    width: 140
    stack2: |md
      
      SS (if ring change)
      ESP (if ring change)
      EFLAGS
      CS
      EIP ← fault point
      Error Code
      Handler's frame...
      
    |
    style.fill: "#FFF3E0"
  }
  df_stack: {
    label: "After Double Fault"
    shape: rectangle
    width: 160
    stack3: |md
      
      (potentially corrupt!)
      EFLAGS
      CS  
      EIP
      Error Code (0)
      DF handler frame...
      
    |
    style.fill: "#FFEBEE"
  }
  normal_stack -> fault_stack -> df_stack
}
prevention: {
  near: center-right
  label: "Prevention Strategies"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  content: |md
    **1. Separate Interrupt Stack**
    c
    tss.esp0 = kernel_stack_top;
    // CPU loads this on ring transition
    
    **2. Bulletproof Double Fault Handler**
    nasm
    isr8:  ; Double fault (vector 8)
      cli
      mov eax, 0xB8000    ; Direct VGA
      mov byte [eax], 'D'
      mov byte [eax+2], 'F'
      .halt:
        hlt
        jmp .halt
    
    **3. Stack Canary**
    c
    // Check stack before deep calls
    if (esp < STACK_MIN) panic();
    
    **4. QEMU Debug Flag**
    bash
    qemu -no-reboot -d int
    # Stops on triple fault
    # Check /tmp/qemu.log
    
  |
}
normal -> ex1 -> ex2 -> ex3 -> reset: "escalation"