direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # CPU Exception Types and Error Codes (Vectors 0-31)
|
title.near: top-center

# Row 1: Exceptions 0-7 (Faults/Traps, No Error Codes)
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  exc0: {
    shape: rectangle
    label: "#0 DIVIDE ERROR"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    cause: "Cause: DIV/IDIV divisor=0"
    err: "No Error Code"
  }
  exc1: {
    shape: rectangle
    label: "#1 DEBUG"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    cause: "Cause: Debug trap/breakpoint"
    err: "No Error Code"
  }
  exc2: {
    shape: rectangle
    label: "#2 NMI"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    cause: "Cause: Non-maskable interrupt"
    err: "No Error Code"
  }
  exc3: {
    shape: rectangle
    label: "#3 BREAKPOINT"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    cause: "Cause: INT 3 instruction"
    err: "No Error Code"
  }
  exc4: {
    shape: rectangle
    label: "#4 OVERFLOW"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    cause: "Cause: INTO with OF set"
    err: "No Error Code"
  }
  exc5: {
    shape: rectangle
    label: "#5 BOUND"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    cause: "Cause: BOUND range exceeded"
    err: "No Error Code"
  }
  exc6: {
    shape: rectangle
    label: "#6 INVALID OPCODE"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    cause: "Cause: UD2 or undefined opcode"
    err: "No Error Code"
  }
  exc7: {
    shape: rectangle
    label: "#7 DEVICE N/A"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    cause: "Cause: FPU missing"
    err: "No Error Code"
  }
}

# Row 2: Exceptions 8-15 (Includes Heavy Faults with Error Codes)
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  exc8: {
    shape: rectangle
    label: "#8 DOUBLE FAULT"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: Nested Exception"
    err: "PUSHES ERROR CODE (0)"
  }
  exc9: {
    shape: rectangle
    label: "#9 COP SEG OVERRUN"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    cause: "Cause: FPU segment limit"
    err: "No Error Code"
  }
  exc10: {
    shape: rectangle
    label: "#10 INVALID TSS"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: Task switch error"
    err: "PUSHES ERROR CODE"
  }
  exc11: {
    shape: rectangle
    label: "#11 SEG NOT PRESENT"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: Loading P=0 selector"
    err: "PUSHES ERROR CODE"
  }
  exc12: {
    shape: rectangle
    label: "#12 STACK FAULT"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: SS limit violation"
    err: "PUSHES ERROR CODE"
  }
  exc13: {
    shape: rectangle
    label: "#13 GEN PROTECTION"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: Privilege/Selector error"
    err: "PUSHES ERROR CODE"
  }
  exc14: {
    shape: rectangle
    label: "#14 PAGE FAULT"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: PTE/PDE invalid"
    err: "PUSHES ERROR CODE"
  }
  exc15: {
    shape: rectangle
    label: "#15 RESERVED"
    style.fill: "#ECEFF1"
    style.stroke: "#90A4AE"
    style.stroke-dash: 4
    note: "Do not use"
  }
}

# Row 3: Exceptions 16-31
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  exc16: {
    shape: rectangle
    label: "#16 x87 FPU ERROR"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    cause: "Cause: FPU pending exception"
    err: "No Error Code"
  }
  exc17: {
    shape: rectangle
    label: "#17 ALIGN CHECK"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: Misaligned memory"
    err: "PUSHES ERROR CODE"
  }
  exc18: {
    shape: rectangle
    label: "#18 MACHINE CHECK"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    cause: "Cause: Internal HW error"
    err: "No Error Code"
  }
  exc19: {
    shape: rectangle
    label: "#19 SIMD FP"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    cause: "Cause: SSE/AVX exception"
    err: "No Error Code"
  }
  exc20: {
    shape: rectangle
    label: "#20 VIRTUALIZATION"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    cause: "Cause: VMX transition"
    err: "No Error Code"
  }
  exc21: {
    shape: rectangle
    label: "#21 CONTROL PROT"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    cause: "Cause: CET Shadow Stack"
    err: "PUSHES ERROR CODE"
  }
  exc22_31: {
    shape: rectangle
    label: "#22-31 RESERVED"
    style.fill: "#ECEFF1"
    style.stroke: "#90A4AE"
    style.stroke-dash: 4
    style.multiple: true
    note: "Intel reserved"
  }
}

# Data Structures (Implementation Ready)
row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  error_code_detail: {
    shape: sql_table
    label: "Page Fault Error Code (#14)"
    r0: "Bit | Name | Description"
    r1: "0   | P    | Present (0=not present, 1=protection violation)"
    r2: "1   | W/R  | Access (0=read, 1=write)"
    r3: "2   | U/S  | Mode (0=supervisor, 1=user)"
    r4: "3   | RSVD | Reserved bit set (1=violation)"
    r5: "4   | I/D  | Fetch (1=instruction fetch)"
    r6: "5   | PK   | Protection Key violation"
    r7: "6   | SS   | Shadow Stack access violation"
    r8: "15  | SGX  | Enclave-specific fault"
    total: "Bits 31:16 are Reserved"
  }

  stack_behavior: {
    shape: sql_table
    label: "Stack Frame (CPU Pushes)"
    r0: "Offset | Content | Description"
    r1: "0x14   | SS      | Stack Segment (privilege change only)"
    r2: "0x10   | ESP     | Stack Pointer (privilege change only)"
    r3: "0x0C   | EFLAGS  | Processor Flags"
    r4: "0x08   | CS      | Code Segment"
    r5: "0x04   | EIP     | Return Instruction Pointer"
    r6: "0x00   | ERROR   | Fault Error Code (if vector 8, 10-14, 17, 21)"
    note: "NOTE: ISR must pop ERROR CODE before IRET"
  }
}

legend: {
  label: "Vector Classification"
  fault: "Green: Fault/Trap (Restartable/Debug)"
  abort: "Red: Heavy Fault (Pushes Error Code)"
  critical: "Pink: Abort/Double Fault (System Stop)"
  gray: "Dashed: Reserved"
}
legend.near: bottom-right

row1 -> row2: "Vectors 0-7"
row2 -> row3: "Vectors 8-15"
row3 -> row4: "Format Details"