direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # GDT Entry Layout and Bit Fields
  Global Descriptor Table — 8-byte Segment Descriptor Structure
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  entry_structure: {
    direction: down
    label: "Segment Descriptor (8 bytes)"
    byte_grid: {
      grid-columns: 8
      grid-gap: 2
      b0: "Byte 0" {style.fill: "#E8F4FD"}
      b1: "Byte 1" {style.fill: "#D4E9F7"}
      b2: "Byte 2" {style.fill: "#C0DEF3"}
      b3: "Byte 3" {style.fill: "#ACD3EF"}
      b4: "Byte 4" {style.fill: "#98C8EB"}
      b5: "Byte 5" {style.fill: "#84BDE7"}
      b6: "Byte 6" {style.fill: "#70B2E3"}
      b7: "Byte 7" {style.fill: "#5CA7DF"}
    }
    field_layout: {
      direction: down
      label: "Field Layout (32-bit view)"
      width: 600
      high_dword: {
        shape: sql_table
        label: "Bytes 7-4 (High DWORD)"
        f7: "31-24 | Base[31:24]     | Physical base address (high)"
        f6: "23-20 | Flags          | G | D | L | AVL"
        f5: "19-16 | Limit[19:16]   | Segment limit (high)"
        f4: "15    | Present        | P = 1 for valid segment"
        f3: "14-13 | DPL            | Descriptor Privilege Level"
        f2: "12    | S              | 0=system, 1=code/data"
        f1: "11-8  | Type           | Segment type bits"
        f0: "7-0   | Base[23:16]    | Physical base (mid)"
      }
      low_dword: {
        shape: sql_table
        label: "Bytes 3-0 (Low DWORD)"
        f3: "31-16 | Base[15:0]     | Physical base address (low)"
        f1: "15-0  | Limit[15:0]    | Segment limit (low)"
      }
    }
  }
  access_byte: {
    direction: down
    label: "Access Byte (Byte 5)"
    width: 350
    bits: {
      shape: sql_table
      label: "Bit Fields"
      b7: "7   | P   | Present (1=valid)"
      b6: "6-5 | DPL | Privilege (00=Ring0, 11=Ring3)"
      b4: "4   | S   | System (0=system, 1=code/data)"
      b3: "3   | E/X | Executable (code) / Direction (data)"
      b2: "2   | R/W | Readable (code) / Writable (data)"
      b1: "1   | C/A | Conforming (code) / Accessed (data)"
      b0: "0   | A   | Accessed (set by CPU on access)"
    }
    type_codes: {
      shape: sql_table
      label: "Common Type Values"
      t1: "0x9A | Kernel Code | P=1 DPL=0 S=1 Type=1010"
      t2: "0x92 | Kernel Data | P=1 DPL=0 S=1 Type=0010"
      t3: "0xFA | User Code   | P=1 DPL=3 S=1 Type=1010"
      t4: "0xF2 | User Data   | P=1 DPL=3 S=1 Type=0010"
      t5: "0x89 | TSS         | P=1 DPL=0 S=0 Type=1001"
    }
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  flags_byte: {
    direction: down
    label: "Flags Byte (Byte 6, bits 7-4)"
    width: 320
    flag_bits: {
      shape: sql_table
      label: "Flag Bits"
      g: "7 | G | Granularity (0=byte, 1=4KB pages)"
      d: "6 | D | Default size (0=16-bit, 1=32-bit)"
      l: "5 | L | Long mode (1=64-bit, must be 0 for 32-bit)"
      a: "4 | A | Available for OS use"
    }
    granularity: {
      shape: sql_table
      label: "Limit Calculation"
      byte: "G=0: limit = Limit[19:0] bytes (max 1MB)"
      page: "G=1: limit = Limit[19:0] × 4096 (max 4GB)"
      example: "0xFFFFF + G=1 → 4GB segment"
    }
  }
  gdt_entries: {
    direction: down
    label: "GDT Entries (MyOS)"
    width: 480
    entries: {
      shape: sql_table
      label: "Required Segment Descriptors"
      idx: "Index | Selector | Type       | Value (hex)        | Purpose"
      n0: "0     | —        | Null       | 0x0000000000000000 | Required by CPU"
      kcs: "1     | 0x08     | Kernel CS  | 0x00CF9A000000FFFF | Code, Ring 0, 4GB"
      kds: "2     | 0x10     | Kernel DS  | 0x00CF92000000FFFF | Data, Ring 0, 4GB"
      ucs: "3     | 0x18     | User CS    | 0x00CFFA000000FFFF | Code, Ring 3, 4GB"
      uds: "4     | 0x20     | User DS    | 0x00CFF2000000FFFF | Data, Ring 3, 4GB"
      tss: "5     | 0x28     | TSS        | varies             | Task State Segment"
    }
  }
}
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  entry_decode: {
    direction: down
    label: "Entry Decode: Kernel Code (0x00CF9A000000FFFF)"
    width: 600
    decode_table: {
      shape: sql_table
      label: "Field Breakdown"
      base: "Base    | 0x00000000     | Starts at physical 0"
      limit: "Limit   | 0xFFFFF        | 1048575 units"
      gran: "G=1     | 4KB granularity| 0xFFFFF × 4096 = 4GB"
      size: "D=1     | 32-bit         | Default operand size"
      pres: "P=1     | Present        | Valid segment"
      dpl: "DPL=00  | Ring 0         | Kernel privilege"
      sys: "S=1     | Code/Data      | Not system segment"
      typ: "Type=A  | 1010b          | Executable, Readable"
    }
    flat_model: {
      label: "Flat Memory Model"
      width: 380
      code: |'c
        // All segments: base=0, limit=4GB
        // Effective addressing: linear = virtual
        // Protection via paging, not segmentation
        mov ax, 0x08    // Kernel code selector
        mov ds, ax      // Actually points to same as 0x10!
        // Both cover 0x00000000-0xFFFFFFFF
      '|
    }
  }
  selector_format: {
    direction: down
    label: "Segment Selector Format"
    width: 300
    sel_bits: {
      shape: sql_table
      label: "16-bit Selector"
      idx: "15-3  | Index    | GDT entry number (0-8191)"
      ti: "2     | TI       | Table (0=GDT, 1=LDT)"
      rpl: "1-0   | RPL      | Requested Privilege Level"
    }
    examples: {
      shape: sql_table
      label: "Selector Examples"
      ex1: "0x08 = 00001 0 00 | Index=1, GDT, RPL=0"
      ex2: "0x10 = 00010 0 00 | Index=2, GDT, RPL=0"
      ex3: "0x1B = 00011 0 11 | Index=3, GDT, RPL=3 (user CS)"
      ex4: "0x23 = 00100 0 11 | Index=4, GDT, RPL=3 (user DS)"
    }
  }
}
legend: {
  near: bottom-center
  grid-columns: 4
  grid-gap: 20
  l1: "Ring 0 = Kernel" {style.fill: "#ACE1AF"}
  l2: "Ring 3 = User" {style.fill: "#FFD699"}
  l3: "System Segment" {style.fill: "#D4D4D4"}
  l4: "Null/Reserved" {style.fill: "#F0F0F0"}
}