direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Identity Mapping vs Higher-Half Kernel
    **Why both mappings are needed during boot**
  |
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
row: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  before: {
    direction: down
    label: "BEFORE: Identity Mapping Only"
    before_desc: {
      label: |md
        **During boot transition:**
        - Virtual = Physical (1:1 mapping)
        - Kernel at 0x00100000 virtual = 0x00100000 physical
        - Simple, but no user space separation
      |
      width: 280
    }
    before_vspace: {
      direction: down
      label: "Virtual Address Space (32-bit)"
      style.fill: "#E8F4FD"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      v_null_before: {
        shape: rectangle
        label: "0x00000000\nNULL / Unmapped"
        width: 200
        height: 60
        style.fill: "#F5F5F5"
        style.stroke: "#999999"
        style.stroke-dash: 3
      }
      v_kernel_before: {
        shape: rectangle
        label: "0x00100000\nKernel Code\n(identity-mapped)"
        width: 200
        height: 80
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      v_free_before: {
        shape: rectangle
        label: "0x00200000 - 0xBFFFFFFF\nFree / User Space"
        width: 200
        height: 100
        style.fill: "#E3F2FD"
        style.stroke: "#1976D2"
      }
      v_vga_before: {
        shape: rectangle
        label: "0x000B8000\nVGA Buffer"
        width: 200
        height: 50
        style.fill: "#FF9800"
        style.stroke: "#E65100"
      }
    }
    arrow_before: {
      label: "Page Tables\n(Identity)"
      shape: text
      style: {
        font-size: 16
        bold: true
      }
    }
    before_pspace: {
      direction: down
      label: "Physical Address Space (RAM)"
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      style.stroke-width: 2
      p_null_before: {
        shape: rectangle
        label: "0x00000000\nBIOS / Reserved"
        width: 200
        height: 60
        style.fill: "#FFEBEE"
        style.stroke: "#C62828"
      }
      p_kernel_before: {
        shape: rectangle
        label: "0x00100000\nKernel Binary\n(loaded here by bootloader)"
        width: 200
        height: 80
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      p_free_before: {
        shape: rectangle
        label: "0x00200000+\nFree Physical RAM"
        width: 200
        height: 100
        style.fill: "#E8F5E9"
        style.stroke: "#388E3C"
      }
    }
  }
  after: {
    direction: down
    label: "AFTER: Higher-Half Kernel"
    after_desc: {
      label: |md
        **After paging fully enabled:**
        - Kernel at 0xC0100000 virtual
        - Low addresses free for user processes
        - Each process gets its own address space
      |
      width: 280
    }
    after_vspace: {
      direction: down
      label: "Virtual Address Space (32-bit)"
      style.fill: "#E8F4FD"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      v_user_after: {
        shape: rectangle
        label: "0x00000000 - 0xBFFFFFFF\nUser Process Space\n(3GB for applications)"
        width: 200
        height: 80
        style.fill: "#E1BEE7"
        style.stroke: "#7B1FA2"
      }
      v_kernmem_after: {
        shape: rectangle
        label: "0xC0000000\nKernel Memory Start"
        width: 200
        height: 40
        style.fill: "#90CAF9"
        style.stroke: "#1565C0"
      }
      v_kernel_after: {
        shape: rectangle
        label: "0xC0100000\nKernel Code\n(higher-half mapping)"
        width: 200
        height: 80
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      v_kernend_after: {
        shape: rectangle
        label: "0xC0400000+\nKernel Heap"
        width: 200
        height: 50
        style.fill: "#80DEEA"
        style.stroke: "#00838F"
      }
    }
    arrow_after: {
      label: "Page Tables\n(Offset + Identity)"
      shape: text
      style: {
        font-size: 16
        bold: true
      }
    }
    after_pspace: {
      direction: down
      label: "Physical Address Space (RAM)"
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      style.stroke-width: 2
      p_null_after: {
        shape: rectangle
        label: "0x00000000\nBIOS / Reserved"
        width: 200
        height: 40
        style.fill: "#FFEBEE"
        style.stroke: "#C62828"
      }
      p_kernel_after: {
        shape: rectangle
        label: "0x00100000\nKernel Binary\n(same physical location)"
        width: 200
        height: 80
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      p_user_after: {
        shape: rectangle
        label: "0x00200000+\nUser Process Pages\n(allocated dynamically)"
        width: 200
        height: 60
        style.fill: "#E1BEE7"
        style.stroke: "#7B1FA2"
      }
      p_free_after: {
        shape: rectangle
        label: "Physical frames\nmanaged by PMM"
        width: 200
        height: 50
        style.fill: "#E8F5E9"
        style.stroke: "#388E3C"
      }
    }
  }
}
mapping_section: {
  direction: down
  label: "Virtual-to-Physical Mappings"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  map_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    map_identity: {
      direction: down
      label: "Identity Map (Boot Time)"
      style.fill: "#E3F2FD"
      id_entry1: {
        shape: rectangle
        label: "0x000B8000 → 0x000B8000"
        width: 180
        style.fill: "#FF9800"
        style.font-color: white
      }
      id_entry2: {
        shape: rectangle
        label: "0x00100000 → 0x00100000"
        width: 180
        style.fill: "#4CAF50"
        style.font-color: white
      }
      id_entry3: {
        shape: rectangle
        label: "0x00100000 → 0x00100000"
        width: 180
        style.fill: "#4CAF50"
        style.font-color: white
      }
      id_note: {
        label: |md
          Virtual = Physical
          (bits 31:22 = 0, bits 21:12 = same)
        |
        shape: text
        style.font-size: 12
      }
    }
    map_higher: {
      direction: down
      label: "Higher-Half Map (Post-Boot)"
      style.fill: "#E8F5E9"
      hh_entry1: {
        shape: rectangle
        label: "0xC0000000 → 0x00000000"
        width: 180
        style.fill: "#2196F3"
        style.font-color: white
      }
      hh_entry2: {
        shape: rectangle
        label: "0xC0100000 → 0x00100000"
        width: 180
        style.fill: "#4CAF50"
        style.font-color: white
      }
      hh_entry3: {
        shape: rectangle
        label: "0xC0400000 → 0x????????"
        width: 180
        style.fill: "#80DEEA"
      }
      hh_note: {
        label: |md
          Virtual = Physical + 0xC0000000
          (subtract 0xC0000000 to get physical)
        |
        shape: text
        style.font-size: 12
      }
    }
  }
}
why_section: {
  direction: down
  label: "Why Both Are Needed"
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  why_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    step1: {
      direction: down
      label: "Step 1: Boot"
      width: 200
      step1_code: {
        label: |'c
// CPU executing at 0x100000
// CR3 = page_dir_phys
mov eax, cr0
or eax, 0x80000000  // PG bit
mov cr0, eax
// MUST have identity map!
// Next instruction fetch uses
// virtual 0x100000
        '|
        width: 180
        style.fill: "#E8F5E9"
        style.font: mono
        style.font-size: 11
      }
    }
    arrow_step: {
      label: "→"
      shape: text
      style: {
        font-size: 32
        bold: true
      }
    }
    step2: {
      direction: down
      label: "Step 2: Transition"
      width: 200
      step2_code: {
        label: |'c
// After paging enabled,
// set up higher-half mappings
vmm_map_page(0xC0100000, 
             0x00100000, 
             PAGE_WRITABLE);
// Kernel now accessible at
// BOTH addresses temporarily
        '|
        width: 180
        style.fill: "#E3F2FD"
        style.font: mono
        style.font-size: 11
      }
    }
    arrow_step2: {
      label: "→"
      shape: text
      style: {
        font-size: 32
        bold: true
      }
    }
    step3: {
      direction: down
      label: "Step 3: Full Higher-Half"
      width: 200
      step3_code: {
        label: |'c
// Eventually remove identity
// map for kernel region
// User processes get full
// 0x00000000-0xBFFFFFFF
// Kernel always at 0xC0000000+
        '|
        width: 180
        style.fill: "#F3E5F5"
        style.font: mono
        style.font-size: 11
      }
    }
  }
}
critical_section: {
  direction: down
  label: "Critical Insight"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
  }
  critical_box: {
    label: |md
      **The Problem:** When CR0.PG is set, the CPU immediately starts translating ALL addresses through page tables.
      If the code at `EIP=0x100000` isn't mapped to `virtual 0x100000`, the CPU cannot fetch the next instruction → **instant page fault → triple fault → reset.**
      **The Solution:** Identity-map the first 4MB BEFORE enabling paging. This ensures the currently executing code remains accessible after paging is enabled.
    |
    width: 600
    style.fill: "#FFCDD2"
  }
}
before_vspace.v_null_before -> before_pspace.p_null_before: "0x00000000"
before_vspace.v_kernel_before -> before_pspace.p_kernel_before: "0x00100000"
before_vspace.v_vga_before -> before_pspace.p_null_before: "0x000B8000"
after_vspace.v_kernel_after -> after_pspace.p_kernel_after: "0xC0100000 → 0x00100000"
after_vspace.v_kernmem_after -> after_pspace.p_null_after: "0xC0000000 → 0x00000000"
after_vspace.v_user_after -> after_pspace.p_user_after: "User pages (varies)"