direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "IDT Entry Structure and Gate Types" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  idt_entry: {
    direction: down
    label: "IDT Gate Descriptor (8 bytes)"
    byte_layout: {
      shape: sql_table
      label: "Gate Descriptor Layout"
      b7: "7     | Offset 31:16    | Handler address high"
      b6: "6     | P|DPL|0|Type|0|0|0| Access byte"
      b5: "5     | 0x00            | Reserved (must be 0)"
      b4: "4     | Segment Selector| Code segment (e.g., 0x08)"
      b3: "3     | Offset 15:0     | Handler address low"
      b2: "2     | Offset 15:0     | Handler address low"
      b1: "1     | Segment Selector| Code segment"
      b0: "0     | Offset 15:0     | Handler address low"
      sz: "Total: 8 bytes"
    }
    width: 320
  }
  access_byte: {
    direction: down
    label: "Access Byte (Byte 6)"
    bits: {
      shape: sql_table
      label: "Access Byte Fields"
      bit7: "7     | P      | Present (1=valid)"
      bit6_5: "6-5   | DPL    | Descriptor Privilege Level"
      bit4: "4     | S=0    | System segment (gates)"
      bit3_0: "3-0   | Type   | Gate type (see below)"
      note: "DPL: 00=Ring0, 11=Ring3 callable"
    }
    width: 300
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  gate_types: {
    direction: down
    label: "Gate Types (Type Field)"
    interrupt_gate: {
      shape: sql_table
      label: "Interrupt Gate (0xE)"
      t0: "Type  | 1110 (0xE)"
      t1: "IF    | Cleared (CLI)"
      t2: "Use   | Hardware interrupts"
      t3: "Behavior | CPU disables interrupts on entry"
    }
    trap_gate: {
      shape: sql_table
      label: "Trap Gate (0xF)"
      t0: "Type  | 1111 (0xF)"
      t1: "IF    | Unchanged"
      t2: "Use   | Software interrupts, syscalls"
      t3: "Behavior | Interrupts remain enabled"
    }
    task_gate: {
      shape: sql_table
      label: "Task Gate (0x5)"
      t0: "Type  | 0101 (0x5)"
      t1: "Stack | Hardware task switch"
      t2: "Use   | Rarely used (legacy)"
      t3: "Behavior | CPU loads TSS, full context switch"
    }
  }
  dpl_values: {
    direction: down
    label: "DPL Values"
    dpl_table: {
      shape: sql_table
      label: "Privilege Level Config"
      r0: "DPL=00 | Ring 0 only (kernel)"
      r3: "DPL=11 | Any ring (user callable)"
      ex1: "0x8E   | Int gate, Ring0 (IRQs)"
      ex2: "0x8F   | Trap gate, Ring0 (exceptions)"
      ex3: "0xEE   | Int gate, Ring3 (syscalls)"
      ex4: "0xEF   | Trap gate, Ring3 (user traps)"
    }
    width: 280
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  comparison: {
    direction: down
    label: "Interrupt vs Trap Gate"
    int_flow: {
      label: "Interrupt Gate Flow"
      width: 300
      code: |'c
        CPU receives interrupt
        Push EFLAGS, CS, EIP
        Clear IF (disable interrupts)
        Load handler from IDT
        Handler runs (interrupts off)
        Handler sends EOI
        iret (restores IF)
      '|
    }
    trap_flow: {
      label: "Trap Gate Flow"
      width: 300
      code: |'c
        CPU receives interrupt
        Push EFLAGS, CS, EIP
        IF unchanged (stay enabled)
        Load handler from IDT
        Handler runs (interrupts on)
        Nested interrupts possible
        iret (IF as it was)
      '|
    }
  }
}
interrupt_gate.style.fill: "#E8F5E9"
trap_gate.style.fill: "#E3F2FD"
task_gate.style.fill: "#FFEBEE"
int_flow.style.stroke: "#4CAF50"
trap_flow.style.stroke: "#2196F3"
interrupt_gate -> int_flow: "Used for" {
  style.stroke-dash: 3
}
trap_gate -> trap_flow: "Used for" {
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  legend_title: "Common IDT Entry Values" {
    shape: text
    style.bold: true
  }
  irq: "IRQ handlers: type=0x8E, DPL=0, selector=0x08"
  exc: "Exceptions: type=0x8E/0x8F, DPL=0, selector=0x08"
  sys: "Syscall (int 0x80): type=0xEE, DPL=3, selector=0x08"
  note2: "DPL=3 allows user-mode (Ring 3) to invoke via INT instruction" {
    shape: text
    style.italic: true
    style.font-size: 12
  }
}