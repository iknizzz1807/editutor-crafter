direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # PS/2 Keyboard Scancode Flow
  IRQ1 → Port 0x60 → Make/Break Detection → ASCII Lookup → Buffer
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  keyboard: {
    label: "Keyboard Controller (i8042)"
    width: 200
    key_press: {
      label: "Key Press Event"
      shape: oval
      style.fill: "#E8F5E9"
    }
    scancode_gen: {
      label: "Generate Scancode"
      width: 180
      code: |'c
        // Scancode Set 1
        A press:   0x1E
        A release: 0x9E
        Shift:    0x2A
      '|
    }
    key_press -> scancode_gen: "switch"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pic: {
    label: "8259 PIC"
    width: 180
    irq1: {
      label: "IRQ1 Line"
      shape: hexagon
      style.fill: "#FFECB3"
    }
    vector: {
      label: "Vector 33"
      shape: parallelogram
      style.fill: "#FFF9C4"
      note: "IRQ1 + 0x20 offset"
    }
    irq1 -> vector: "INT req"
    eoi: {
      label: "EOI Wait"
      shape: diamond
      style.fill: "#FFCDD2"
    }
    vector -> eoi: "in-service"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cpu: {
    label: "CPU Core"
    width: 220
    idt_lookup: {
      label: "IDT[33] Lookup"
      shape: rectangle
      style.fill: "#E1BEE7"
    }
    push_frame: {
      label: "Push Stack Frame"
      shape: rectangle
      style.fill: "#CE93D8"
      frame: |md
        - EFLAGS
        - CS (0x08)
        - EIP (return)
        - Error Code (0)
      |
    }
    idt_lookup -> push_frame: "handler"
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  isr: {
    label: "ISR Handler (isr_keyboard)"
    width: 240
    read_port: {
      label: "Read Port 0x60"
      shape: rectangle
      style.fill: "#B3E5FC"
      code: |'c
        uint8_t sc = inb(0x60);
        // Example:
        // 0x1E = 'A' Make
        // 0x9E = 'A' Break
      '|
    }
    check_break: {
      label: "Make/Break Check"
      shape: diamond
      style.fill: "#81D4FA"
    }
    read_port -> check_break: "u8 scancode"
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scancode_table: {
    label: "Scancode Set 1 Table"
    shape: sql_table
    row1: "0x1E | A | a"
    row2: "0x30 | B | b"
    row3: "0x2E | C | c"
    row4: "0x2A | L-Shift | (mod)"
    row5: "0x36 | R-Shift | (mod)"
    row6: "0x3A | CapsLock | (toggle)"
    row7: "0x9E | A release | break"
    note: "Index = scancode & 0x7F"
  }
  shift_table: {
    label: "Shifted Mapping Table"
    shape: sql_table
    row1: "0x1E | A | A"
    row2: "0x30 | B | B"
    row3: "0x2E | C | C"
    row4: "0x02 | 1 | !"
    row5: "0x03 | 2 | @"
    row6: "0x04 | 3 | #"
    note: "Used when shift_held == true"
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  conversion: {
    label: "ASCII Conversion Logic"
    width: 280
    modifier_check: {
      label: "Check State"
      shape: rectangle
      style.fill: "#C8E6C9"
      code: |'c
        bool shift = L_shift || R_shift;
        if (sc & 0x80) {
          update_modifiers(sc);
          return;
        }
      '|
    }
    lookup: {
      label: "Table Lookup"
      shape: rectangle
      style.fill: "#A5D6A7"
      code: |'c
        if (shift)
          ascii = shift_table[sc];
        else
          ascii = normal_table[sc];
      '|
    }
    modifier_check -> lookup: "char index"
  }
}

row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  buffer: {
    label: "Ring Buffer (keyboard.c)"
    width: 320
    struct: {
      shape: sql_table
      label: "struct kbd_buffer"
      f1: "0x00 | char[256] | data"
      f2: "0x100 | uint32 | head"
      f3: "0x104 | uint32 | tail"
      sz: "Total: 264 bytes"
    }
    visual: {
      label: "Buffer Visualization"
      width: 200
      state: |md
        [a][b][c][ ][ ][ ][ ]
         ^        ^
         tail     head
      |
    }
  }
}

row8: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  api: {
    label: "Kernel API (keyboard.h)"
    width: 280
    methods: {
      shape: class
      +keyboard_getc(): "char"
      +keyboard_available(): "bool"
      +keyboard_peek(): "char"
      -update_modifiers(sc): "void"
      -pic_send_eoi(irq): "void"
    }
  }
}

keyboard.scancode_gen -> pic.irq1: "IRQ1 signal"
pic.vector -> cpu.idt_lookup: "INT 0x21"
cpu.push_frame -> isr.read_port: "EIP jump"
isr.check_break -> scancode_table: "index"
isr.check_break -> shift_table: "index" {
  style.stroke-dash: 4
}
scancode_table -> conversion.modifier_check: "scancode"
shift_table -> conversion.lookup: "scancode"
conversion.lookup -> buffer.struct: "push char"
buffer.visual -> api.methods: "pop char"

eoi_flow: {
  label: "PIC EOI Protocol"
  near: bottom-right
  style.fill: "#FFF3E0"
  logic: |'c
    // MUST send EOI to PIC 
    // at end of ISR
    outb(0x20, 0x20); 
  '|
}

example_flow: {
  label: "Trace: Press 'A'"
  near: bottom-left
  style.fill: "#E3F2FD"
  trace: |md
    1. HW: Key 'A' → 0x1E
    2. PIC: Signal IRQ1
    3. CPU: vector 0x21 → IDT
    4. ISR: inb(0x60) gets 0x1E
    5. ISR: 0x1E < 0x80 (Make)
    6. MAP: table[0x1E] → 'a'
    7. BUF: buffer[head++] = 'a'
    8. PIC: send_eoi(1)
    9. CPU: iret
  |
}