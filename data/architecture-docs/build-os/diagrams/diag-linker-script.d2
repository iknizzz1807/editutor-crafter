direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Kernel Linker Script Section Layout
  **Physical Load Address: 0x00100000 (1 MB)**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_stack: {
    direction: down
    label: "Memory Image (Stacked View)"
    text_section: {
      label: ".text (Executable Code)"
      shape: rectangle
      width: 400
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
      text_detail: {
        shape: sql_table
        label: "Section: .text (kernel/*.o)"
        addr: "0x00100000 | VMA: 0xC0100000 | uint8_t[]"
        entry: "ENTRY(_start) - kernel entry point"
        content: "All executable code from .text sections"
        align: "ALIGN(4K) - 4KB page boundary"
        size: "~50-200 KB (varies by kernel size)"
      }
    }
    rodata_section: {
      label: ".rodata (Read-Only Data)"
      shape: rectangle
      width: 400
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      style.stroke-width: 2
      rodata_detail: {
        shape: sql_table
        label: "Section: .rodata (const data)"
        addr: "0x0010XXXX | VMA: 0xC010XXXX | const"
        content: "String literals, const variables"
        strings: "kprintf format strings, error msgs"
        align: "ALIGN(4K) - 4KB page boundary"
        size: "~4-20 KB"
      }
    }
    data_section: {
      label: ".data (Initialized Data)"
      shape: rectangle
      width: 400
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      style.stroke-width: 2
      data_detail: {
        shape: sql_table
        label: "Section: .data (rw initialized)"
        addr: "0x0010YYYY | VMA: 0xC010YYYY | rw-"
        content: "Initialized global/static variables"
        example: "tick_count, current_process ptr"
        align: "ALIGN(4K) - 4KB page boundary"
        size: "~1-10 KB"
      }
    }
    bss_section: {
      label: ".bss (Uninitialized Data)"
      shape: rectangle
      width: 400
      style.fill: "#FCE4EC"
      style.stroke: "#C2185B"
      style.stroke-width: 2
      bss_detail: {
        shape: sql_table
        label: "Section: .bss (rw uninitialized)"
        addr: "0x0010ZZZZ | VMA: 0xC010ZZZZ | rw-"
        content: "Zero-initialized globals (entry.asm zeroes)"
        symbols: "__bss_start ... __bss_end"
        example: "idt[256], frame_bitmap, process_list"
        align: "ALIGN(4K) - 4KB page boundary"
        size: "~100-500 KB (large arrays)"
      }
    }
    end_marker: {
      label: "_kernel_end Symbol"
      shape: diamond
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      width: 200
      note: "First free address after kernel\nPMM bitmap placed here"
    }
  }
  text_section -> rodata_section: "next section"
  rodata_section -> data_section: "next section"
  data_section -> bss_section: "next section"
  bss_section -> end_marker: "end of kernel"
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  addr_translation: {
    direction: down
    label: "Address Translation"
    phys_block: {
      label: "Physical Memory Layout"
      shape: rectangle
      style.fill: "#FAFAFA"
      style.stroke: "#424242"
      style.stroke-dash: 3
      phys_table: {
        shape: sql_table
        label: "Physical Addresses (LMA)"
        text_start: "0x00100000 | .text start"
        text_end: "0x0010XXXX | .text end"
        rodata: "0x0010XXXX | .rodata"
        data: "0x0010YYYY | .data"
        bss: "0x0010ZZZZ | .bss"
        kernel_end: "0x0010WWWW | _kernel_end"
      }
    }
    virt_block: {
      label: "Virtual Memory Layout (Higher-Half)"
      shape: rectangle
      style.fill: "#E8EAF6"
      style.stroke: "#3F51B5"
      virt_table: {
        shape: sql_table
        label: "Virtual Addresses (VMA)"
        text_start: "0xC0100000 | .text start"
        text_end: "0xC010XXXX | .text end"
        rodata: "0xC010XXXX | .rodata"
        data: "0xC010YYYY | .data"
        bss: "0xC010ZZZZ | .bss"
        kernel_end: "0xC010WWWW | _kernel_end"
        offset: "VMA = LMA + 0xC0000000"
      }
    }
    phys_block -> virt_block: "Higher-Half Mapping\n+0xC0000000" {
      style.stroke: "#3F51B5"
      style.stroke-width: 2
    }
  }
  linker_script: {
    direction: down
    label: "Linker Script (linker.ld)"
    script_box: {
      shape: rectangle
      width: 420
      style.fill: "#263238"
      style.font-color: "#ECEFF1"
      style.font: mono
      code: |'ld
        /* kernel/linker.ld */
        ENTRY(_start)
        KERNEL_VIRTUAL_BASE  = 0xC0000000;
        KERNEL_PHYSICAL_BASE = 0x00100000;
        SECTIONS
        {
          . = KERNEL_VIRTUAL_BASE + 0x10000;
          .text ALIGN(4K) : 
            AT(ADDR(.text) - KERNEL_VIRTUAL_BASE)
          {
            *(.text)
            *(.text.*)
          }
          .rodata ALIGN(4K) : 
            AT(ADDR(.rodata) - KERNEL_VIRTUAL_BASE)
          {
            *(.rodata)
            *(.rodata.*)
          }
          .data ALIGN(4K) : 
            AT(ADDR(.data) - KERNEL_VIRTUAL_BASE)
          {
            *(.data)
          }
          .bss ALIGN(4K) : 
            AT(ADDR(.bss) - KERNEL_VIRTUAL_BASE)
          {
            __bss_start = .;
            *(COMMON)
            *(.bss)
            __bss_end = .;
          }
          _kernel_end = .;
        }
      '|
    }
  }
}
legend: {
  near: bottom-right
  label: "Section Permissions"
  perm_table: {
    shape: sql_table
    label: "Memory Protection"
    text: ".text | r-x | Executable code"
    rodata: ".rodata | r-- | Read-only data"
    data: ".data | rw- | Read-write data"
    bss: ".bss | rw- | Zero-init storage"
  }
}
note_align: {
  label: "ALIGN(4K) ensures each section starts on a page boundary (4096 bytes).\nThis is required for paging: each section can have different permissions."
  shape: rectangle
  width: 450
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
  style.stroke-dash: 2
  near: bottom-center
}