direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Multi-Process Demo: Memory Layout
  Three kernel-mode processes sharing address space with separate stacks and PCBs
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  shared_space: {
    direction: down
    label: "Shared Kernel Address Space (0x00000000 - 0xFFFFFFFF)"
    code_region: {
      label: "Shared Code (kernel text)"
      shape: rectangle
      width: 280
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      code_note: |'c
        // All processes execute same kernel code
        // scheduler_tick(), context_switch(), etc.
      '|
    }
    vga_region: {
      label: "VGA Text Buffer (0xB8000)"
      shape: rectangle
      width: 280
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      vga_layout: {
        shape: sql_table
        label: "80x25 Character Grid"
        row0: "Row 10 | Process A writes here"
        row1: "Row 12 | Process B writes here"
        row2: "Row 14 | Process C writes here"
        row3: "Other rows | Available"
      }
    }
    pmm_region: {
      label: "Physical Memory Manager"
      shape: rectangle
      width: 280
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      pmm_note: "Bitmap allocator\nShared frame tracking"
    }
    code_region -> vga_region: "All processes\nwrite here" {
      style.stroke: "#2196F3"
      style.stroke-dash: 3
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  process_a: {
    direction: down
    label: "Process A (PID 1)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    pcb_a: {
      shape: sql_table
      label: "PCB_A (process.h)"
      f0: "0x00 | uint32_t  | pid = 1"
      f1: "0x04 | char[32]  | name = 'ProcessA'"
      f2: "0x24 | state     | RUNNING"
      f3: "0x28 | uint32_t  | time_slice = 10"
      f4: "0x2C | uint32_t  | eax, ebx, ecx, edx"
      f5: "0x3C | uint32_t  | esi, edi, ebp, esp"
      f6: "0x4C | uint32_t  | eip (saved PC)"
      f7: "0x50 | uint32_t  | eflags"
      f8: "0x54 | uint32_t  | page_directory"
      f9: "0x58 | uint32_t  | kernel_stack"
      sz: "Total: ~92 bytes"
    }
    stack_a: {
      shape: rectangle
      label: "Kernel Stack A\n8KB @ unique addr"
      width: 180
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.stroke-width: 2
    }
    code_a: {
      label: "void process_a()"
      shape: code
      width: 200
      code: |'c
        while (1) {
          vga_put_char_at('A', 
            color, x, 10);
          scheduler_yield();
        }
      '|
    }
  }
  process_b: {
    direction: down
    label: "Process B (PID 2)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    pcb_b: {
      shape: sql_table
      label: "PCB_B (process.h)"
      f0: "0x00 | uint32_t  | pid = 2"
      f1: "0x04 | char[32]  | name = 'ProcessB'"
      f2: "0x24 | state     | READY"
      f3: "0x28 | uint32_t  | time_slice = 10"
      f4: "0x2C | uint32_t  | eax, ebx, ecx, edx"
      f5: "0x3C | uint32_t  | esi, edi, ebp, esp"
      f6: "0x4C | uint32_t  | eip (saved PC)"
      f7: "0x50 | uint32_t  | eflags"
      f8: "0x54 | uint32_t  | page_directory"
      f9: "0x58 | uint32_t  | kernel_stack"
      sz: "Total: ~92 bytes"
    }
    stack_b: {
      shape: rectangle
      label: "Kernel Stack B\n8KB @ unique addr"
      width: 180
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    code_b: {
      label: "void process_b()"
      shape: code
      width: 200
      code: |'c
        while (1) {
          vga_put_char_at('B', 
            color, x, 12);
          scheduler_yield();
        }
      '|
    }
  }
  process_c: {
    direction: down
    label: "Process C (PID 3)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    pcb_c: {
      shape: sql_table
      label: "PCB_C (process.h)"
      f0: "0x00 | uint32_t  | pid = 3"
      f1: "0x04 | char[32]  | name = 'ProcessC'"
      f2: "0x24 | state     | READY"
      f3: "0x28 | uint32_t  | time_slice = 10"
      f4: "0x2C | uint32_t  | eax, ebx, ecx, edx"
      f5: "0x3C | uint32_t  | esi, edi, ebp, esp"
      f6: "0x4C | uint32_t  | eip (saved PC)"
      f7: "0x50 | uint32_t  | eflags"
      f8: "0x54 | uint32_t  | page_directory"
      f9: "0x58 | uint32_t  | kernel_stack"
      sz: "Total: ~92 bytes"
    }
    stack_c: {
      shape: rectangle
      label: "Kernel Stack C\n8KB @ unique addr"
      width: 180
      style.fill: "#BBDEFB"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
    code_c: {
      label: "void process_c()"
      shape: code
      width: 200
      code: |'c
        while (1) {
          vga_put_char_at('C', 
            color, x, 14);
          scheduler_yield();
        }
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scheduler: {
    direction: down
    label: "Scheduler State"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    ready_queue: {
      shape: class
      label: "Ready Queue (Circular)"
      head: "process_t *head"
      current: "process_t *current"
    }
    queue_state: {
      label: "Current State"
      shape: rectangle
      width: 300
      style.fill: "#E1BEE7"
      state_text: |md
        **Running:** PCB_A (PID 1)
        **Next:** PCB_B (PID 2) → PCB_C (PID 3) → PCB_A
        **Time Slice:** 10 ticks (100ms @ 100Hz)
      |
    }
  }
  context_switch_box: {
    direction: down
    label: "Context Switch (context_switch.asm)"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    switch_flow: {
      shape: code
      width: 320
      code: |'asm
  ; 1. Save current to old->PCB
  mov [eax+12], ebx  ; save EBX
  mov [eax+24], esi  ; save ESI
  mov [eax+28], edi  ; save EDI
  mov [eax+32], ebp  ; save EBP
  mov [eax+36], esp  ; save ESP
  ; 2. Load new from new->PCB
  mov ebx, [edx+12]  ; restore EBX
  mov esi, [edx+24]  ; restore ESI
  mov edi, [edx+28]  ; restore EDI
  mov ebp, [edx+32]  ; restore EBP
  mov esp, [edx+36]  ; switch stacks!
  ret                ; jump to new EIP
      '|
    }
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: "Red = Process A resources"
  l2: "Green = Process B resources"
  l3: "Blue = Process C resources"
  l4: "Purple = Scheduler state"
  l5: "Yellow = Context switch"
  l1.style.fill: "#FFCDD2"
  l2.style.fill: "#C8E6C9"
  l3.style.fill: "#BBDEFB"
  l4.style.fill: "#E1BEE7"
  l5.style.fill: "#FFF9C4"
}
process_a.pcb_a -> process_a.stack_a: "kernel_stack\npoints to" {
  style.stroke: "#F44336"
  style.stroke-width: 2
}
process_b.pcb_b -> process_b.stack_b: "kernel_stack\npoints to" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
process_c.pcb_c -> process_c.stack_c: "kernel_stack\npoints to" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
scheduler.ready_queue -> process_a.pcb_a: "current" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  style.stroke-dash: 3
}
process_a.code_a -> shared_space.vga_region: "vga_put_char_at('A', ..., row=10)" {
  style.stroke: "#F44336"
  style.animated: true
}
process_b.code_b -> shared_space.vga_region: "vga_put_char_at('B', ..., row=12)" {
  style.stroke: "#4CAF50"
  style.animated: true
}
process_c.code_c -> shared_space.vga_region: "vga_put_char_at('C', ..., row=14)" {
  style.stroke: "#2196F3"
  style.animated: true
}
process_a.pcb_a -> process_b.pcb_b: "next" {
  style.stroke-dash: 3
}
process_b.pcb_b -> process_c.pcb_c: "next" {
  style.stroke-dash: 3
}
process_c.pcb_c -> process_a.pcb_a: "next (circular)" {
  style.stroke-dash: 3
}