direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Page Directory Entry (PDE) Bit Fields
    4 bytes (32 bits) — Points to a Page Table
  |
  near: top-center
  shape: text
  style.font-size: 18
}
pde_layout: {
  label: "PDE Memory Layout (Little-Endian)"
  style.fill: "#E8F4F8"
  style.stroke: "#2B6CB0"
  style.stroke-width: 2
  byte_grid: {
    grid-columns: 4
    grid-gap: 4
    byte3: {
      label: "Byte 3\n(Bits 31-24)"
      shape: rectangle
      width: 120
      height: 60
      style.fill: "#BEE3F8"
      style.stroke: "#2B6CB0"
      code: |'c
        Base Addr [31:24]
      '|
    }
    byte2: {
      label: "Byte 2\n(Bits 23-16)"
      shape: rectangle
      width: 120
      height: 60
      style.fill: "#C6F6D5"
      style.stroke: "#276749"
      code: |'c
        Base [23:16]
        | G | PS | A
      '|
    }
    byte1: {
      label: "Byte 1\n(Bits 15-8)"
      shape: rectangle
      width: 120
      height: 60
      style.fill: "#FED7D7"
      style.stroke: "#C53030"
      code: |'c
        AVL | Base
        [15:12] | PCD
      '|
    }
    byte0: {
      label: "Byte 0\n(Bits 7-0)"
      shape: rectangle
      width: 120
      height: 60
      style.fill: "#FEEBC8"
      style.stroke: "#C05621"
      code: |'c
        PWT | U/S
        | R/W | P
      '|
    }
  }
}
bit_breakdown: {
  label: "Bit Field Breakdown"
  direction: down
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    bit31_12: {
      label: "Bits 31-12: Page Table Base Address"
      shape: rectangle
      width: 350
      style.fill: "#BEE3F8"
      style.stroke: "#2B6CB0"
      desc: |md
        **20 bits** — Physical address of the  
        page table (4KB aligned)  
        Only bits 31-12 stored;  
        bits 11-0 are implicitly 0
      |
    }
  }
  row2: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    bit11_9: {
      label: "Bits 11-9: Available (AVL)"
      shape: rectangle
      width: 180
      style.fill: "#E9D8FD"
      style.stroke: "#6B46C1"
      desc: |md
        **3 bits** — Available for  
        OS use (ignored by CPU)
      |
    }
    bit8: {
      label: "Bit 8: Global (G)"
      shape: rectangle
      width: 160
      style.fill: "#C6F6D5"
      style.stroke: "#276749"
      desc: |md
        **1 bit** — Prevents TLB  
        flush on CR3 reload  
        (if PGE enabled in CR4)
      |
    }
  }
  row3: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    bit7: {
      label: "Bit 7: Page Size (PS)"
      shape: rectangle
      width: 160
      style.fill: "#C6F6D5"
      style.stroke: "#276749"
      desc: |md
        **1 bit**  
        0 = 4KB pages  
        1 = 4MB pages
      |
    }
    bit6: {
      label: "Bit 6: Accessed (A)"
      shape: rectangle
      width: 160
      style.fill: "#C6F6D5"
      style.stroke: "#276749"
      desc: |md
        **1 bit** — Set by CPU  
        on first access to page  
        (software clears it)
      |
    }
  }
  row4: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    bit5: {
      label: "Bit 5: Cache Disable (PCD)"
      shape: rectangle
      width: 170
      style.fill: "#FED7D7"
      style.stroke: "#C53030"
      desc: |md
        **1 bit**  
        0 = page cacheable  
        1 = page not cached
      |
    }
    bit4: {
      label: "Bit 4: Write-Through (PWT)"
      shape: rectangle
      width: 170
      style.fill: "#FED7D7"
      style.stroke: "#C53030"
      desc: |md
        **1 bit**  
        0 = write-back caching  
        1 = write-through caching
      |
    }
  }
  row5: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    bit3: {
      label: "Bit 3: Reserved"
      shape: rectangle
      width: 140
      style.fill: "#E2E8F0"
      style.stroke: "#64748B"
      desc: |md
        **1 bit** — Must be 0  
        (ignored on read)
      |
    }
    bit2: {
      label: "Bit 2: User/Supervisor (U/S)"
      shape: rectangle
      width: 170
      style.fill: "#FEEBC8"
      style.stroke: "#C05621"
      desc: |md
        **1 bit**  
        0 = Ring 0 only  
        1 = Ring 3 can access
      |
    }
  }
  row6: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    bit1: {
      label: "Bit 1: Read/Write (R/W)"
      shape: rectangle
      width: 160
      style.fill: "#FEEBC8"
      style.stroke: "#C05621"
      desc: |md
        **1 bit**  
        0 = read-only  
        1 = read/write
      |
    }
    bit0: {
      label: "Bit 0: Present (P)"
      shape: rectangle
      width: 160
      style.fill: "#FEEBC8"
      style.stroke: "#C05621"
      desc: |md
        **1 bit**  
        0 = page table not in  
        memory (page fault)  
        1 = page table present
      |
    }
  }
}
example: {
  label: "Example PDE Value"
  style.fill: "#F7FAFC"
  style.stroke: "#A0AEC0"
  hex_value: {
    label: "0x00C01027"
    shape: rectangle
    width: 200
    style.fill: "#2D3748"
    style.font-color: "#68D391"
    style.font: mono
    style.font-size: 24
  }
  decode: {
    label: "Decoded Fields"
    shape: rectangle
    width: 380
    fields: |md
      
      Base Address = 0x00C01000 (Page Table at 12MB)
      AVL          = 0
      G            = 0 (not global)
      PS           = 0 (4KB pages)
      A            = 0 (not accessed)
      PCD          = 0 (cacheable)
      PWT          = 0 (write-back)
      U/S          = 1 (user accessible)
      R/W          = 1 (writable)
      P            = 1 (present)
      
    |
  }
  hex_value -> decode: "decodes to"
}
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: transparent
  legend_content: {
    grid-columns: 4
    grid-gap: 8
    addr: {
      label: "Address Fields"
      shape: rectangle
      style.fill: "#BEE3F8"
    }
    ctrl: {
      label: "Control Bits"
      shape: rectangle
      style.fill: "#C6F6D5"
    }
    cache: {
      label: "Cache Bits"
      shape: rectangle
      style.fill: "#FED7D7"
    }
    perm: {
      label: "Permission Bits"
      shape: rectangle
      style.fill: "#FEEBC8"
    }
  }
}