direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: |'md
    # Page Table Entry (PTE) Structure
    **32-bit x86 — 4 bytes per entry**
  '|
  style: {
    stroke-width: 0
    fill: transparent
  }
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  pte_field_definitions: {
    shape: sql_table
    label: "PTE Bit Field Definitions (Intel x86 Manual)"
    
    header: "Bits | Field | Description / Values"
    bit0: "0 | P | Present: 1=in memory, 0=not present"
    bit1: "1 | R/W | Read/Write: 1=writable, 0=read-only"
    bit2: "2 | U/S | User/Supervisor: 1=user, 0=kernel"
    bit3: "3 | PWT | Page Write-Through: 1=WT, 0=WB"
    bit4: "4 | PCD | Page Cache Disable: 1=no cache"
    bit5: "5 | A | Accessed: Set by CPU on read"
    bit6: "6 | D | Dirty: Set by CPU on write"
    bit7: "7 | PAT | Page Attribute Table: Memory type"
    bit8: "8 | G | Global: 1=not flushed on CR3 reload"
    bits9_11: "9..11 | Avail | For OS use (3 bits)"
    bits12_31: "12..31 | PFA | Physical Frame Address (20 bits)"
    
    footer: "Total Size: 32 bits (4 bytes)"
  }

  byte_layout: {
    direction: down
    label: "Memory Layout (Little-Endian Order)"
    
    byte3: {
      shape: sql_table
      label: "Byte 3 [Bits 31:24]"
      row: "0x03 | uint8_t | Physical Frame Addr [31:24]"
    }
    byte2: {
      shape: sql_table
      label: "Byte 2 [Bits 23:16]"
      row: "0x02 | uint8_t | Physical Frame Addr [23:16]"
    }
    byte1: {
      shape: sql_table
      label: "Byte 1 [Bits 15:8]"
      row1: "0x01 | [15:12] | Physical Frame Addr [15:12]"
      row2: "0x01 | [11:9]  | Available for OS use"
      row3: "0x01 | [8]     | Global Bit (G)"
    }
    byte0: {
      shape: sql_table
      label: "Byte 0 [Bits 7:0]"
      row1: "0x00 | [7]     | PAT Bit"
      row2: "0x00 | [6]     | Dirty (D)"
      row3: "0x00 | [5]     | Accessed (A)"
      row4: "0x00 | [4]     | Cache Disable (PCD)"
      row5: "0x00 | [3]     | Write-Through (PWT)"
      row6: "0x00 | [2]     | User/Supervisor (U/S)"
      row7: "0x00 | [1]     | Read/Write (R/W)"
      row8: "0x00 | [0]     | Present (P)"
    }
    
    byte3 -> byte2
    byte2 -> byte1
    byte1 -> byte0
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  bit_visual: {
    label: "32-Bit Linear Bitmask (Hardware View)"
    direction: right
    
    frame_addr: "Physical Frame Base Address (Bits 12-31)" {
      style.fill: "#98FB98"
    }
    
    os_bits: "OS Use (9-11)" {
      style.fill: "#D3D3D3"
    }
    
    status_bits: "G / PAT / D / A (5-8)" {
      style.fill: "#FFA07A"
    }
    
    cache_bits: "PCD / PWT (3-4)" {
      style.fill: "#F0E68C"
    }
    
    access_bits: "U/S / R/W / P (0-2)" {
      style.fill: "#90EE90"
    }
    
    frame_addr -- os_bits
    os_bits -- status_bits
    status_bits -- cache_bits
    cache_bits -- access_bits
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  example_case: {
    direction: down
    label: "Example: Kernel RW Page (0x00CFF023)"
    
    ex_breakdown: {
      shape: class
      label: "Binary Decomposition"
      frame_addr_val: "0x00CFF (Base: 0x00CFF000)"
      avail_val: "0x0"
      control_val: "0x023"
      flags: "P=1, R/W=1, U/S=0, A=1"
    }

    ex_code: {
      label: "OS Kernel C Implementation"
      width: 450
      code: |'c
        #define PTE_P   0x001
        #define PTE_W   0x002
        #define PTE_U   0x004
        #define PTE_A   0x020

        // Mapping 4KB physical frame to page table
        void set_pte(uint32_t *table, int idx, uint32_t phys_addr) {
            table[idx] = (phys_addr & 0xFFFFF000) | PTE_P | PTE_W | PTE_A;
        }
      '|
    }
  }

  legend_box: {
    label: "Field Category Legend"
    grid-columns: 5
    l1: "Address" { style.fill: "#98FB98" }
    l2: "OS Bits" { style.fill: "#D3D3D3" }
    l3: "CPU Status" { style.fill: "#FFA07A" }
    l4: "Caching" { style.fill: "#F0E68C" }
    l5: "Permissions" { style.fill: "#90EE90" }
  }
}

legend_box.near: bottom-right