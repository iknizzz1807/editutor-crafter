direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "32-bit Virtual Address Translation (x86 Architecture)"
  near: top-center
  shape: rectangle
  style: {
    fill: "#F0F8FF"
    stroke: "#4682B4"
    stroke-width: 2
    font-size: 24
    bold: true
  }
}

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  virt_addr: "Virtual Address (32-bit)" {
    direction: right
    style.fill: "#E8F4FD"
    
    dir_idx: {
      label: "Dir Index (10 bits)"
      shape: rectangle
      width: 120
      style: {
        fill: "#FFE4B5"
        stroke: "#D2691E"
        font: mono
      }
      info: "Bits 31-22"
    }
    pt_idx: {
      label: "PT Index (10 bits)"
      shape: rectangle
      width: 120
      style: {
        fill: "#B5E8B5"
        stroke: "#228B22"
        font: mono
      }
      info: "Bits 21-12"
    }
    offset: {
      label: "Page Offset (12 bits)"
      shape: rectangle
      width: 140
      style: {
        fill: "#E8B5E8"
        stroke: "#8B008B"
        font: mono
      }
      info: "Bits 11-0"
    }
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  cr3_box: "Control Register" {
    direction: down
    style.fill: "#F0F0F0"
    cr3: {
      shape: rectangle
      label: "CR3 (PDBR)"
      width: 160
      style: {
        fill: "#FFFACD"
        stroke: "#B8860B"
        font: mono
        bold: true
      }
      note: "Holds Phys Addr of PD"
    }
  }

  pd_box: "Page Directory (Level 1)" {
    direction: down
    style.fill: "#FFE4B5"
    pd_array: {
      shape: sql_table
      label: "Directory Entries (4KB)"
      row0: "0x000 | 4 bytes | PDE 0"
      row1: "0x004 | 4 bytes | PDE 1"
      d1: "...   | ...     | ..."
      target: "0x3FC | 4 bytes | PDE [dir_idx]"
      row1023: "0xFFC | 4 bytes | PDE 1023"
      total: "Total: 1024 Entries"
    }
    pde_entry: {
      label: "PDE Format"
      shape: sql_table
      bits_p: "Bit 0    | P | Present"
      bits_rw: "Bit 1    | W | Read/Write"
      bits_us: "Bit 2    | U | User/Super"
      bits_addr: "Bits 12-31 | Page Table Physical Address"
    }
  }

  pt_box: "Page Table (Level 2)" {
    direction: down
    style.fill: "#B5E8B5"
    pt_array: {
      shape: sql_table
      label: "Table Entries (4KB)"
      row0: "0x000 | 4 bytes | PTE 0"
      row1: "0x004 | 4 bytes | PTE 1"
      d2: "...   | ...     | ..."
      target: "0x4FC | 4 bytes | PTE [pt_idx]"
      row1023: "0xFFC | 4 bytes | PTE 1023"
      total: "Total: 1024 Entries"
    }
    pte_entry: {
      label: "PTE Format"
      shape: sql_table
      bits_p: "Bit 0    | P | Present"
      bits_rw: "Bit 1    | W | Read/Write"
      bits_us: "Bit 2    | U | User/Super"
      bits_d: "Bit 6    | D | Dirty"
      bits_addr: "Bits 12-31 | Physical Frame Address"
    }
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  phys_mem_container: "Main Memory" {
    direction: down
    style.fill: "#E8B5E8"
    frame: {
      shape: rectangle
      label: "Physical Frame (4KB)"
      width: 250
      height: 120
      style: {
        fill: "#E8B5E8"
        stroke: "#8B008B"
        stroke-width: 2
      }
      content: {
        label: "Target Memory Location"
        shape: rectangle
        style: {
          fill: white
          font-size: 12
        }
      }
    }
    frame_layout: {
      label: "Address Offset Logic"
      shape: sql_table
      b0: "frame_addr + 0x000 | Byte 0"
      d3: "...                | ..."
      off: "frame_addr + offset| Target Byte"
      b4095: "frame_addr + 0xFFF | Byte 4095"
    }
  }
}

# Connection Logic
row2.cr3_box.cr3 -> row2.pd_box.pd_array: "Page Dir Base" {
  style: {
    stroke: "#B8860B"
    stroke-width: 2
  }
}

row1.virt_addr.dir_idx -> row2.pd_box.pd_array.target: "Select PDE" {
  style: {
    stroke: "#D2691E"
    stroke-dash: 3
  }
}

row2.pd_box.pd_array.target -> row2.pt_box.pt_array: "Table Base" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
  }
}

row1.virt_addr.pt_idx -> row2.pt_box.pt_array.target: "Select PTE" {
  style: {
    stroke: "#228B22"
    stroke-dash: 3
  }
}

row2.pt_box.pt_array.target -> row3.phys_mem_container.frame: "Frame Base" {
  style: {
    stroke: "#8B008B"
    stroke-width: 2
  }
}

row1.virt_addr.offset -> row3.phys_mem_container.frame_layout.off: "Byte Offset" {
  style: {
    stroke: "#8B008B"
    stroke-dash: 3
  }
}

# Footer and Legend
legend: {
  near: bottom-right
  label: "Translation Performance"
  style.fill: "#F5F5F5"
  tlb_hit: {
    shape: rectangle
    label: "TLB Hit: ~1 cycle (Hardware Cache)"
    style.fill: "#90EE90"
  }
  tlb_miss: {
    shape: rectangle
    label: "TLB Miss: ~30 cycles (MMU Walk)"
    style.fill: "#FFB6C1"
  }
  page_fault: {
    shape: rectangle
    label: "Page Fault: ~1ms+ (Disk I/O)"
    style.fill: "#FF6B6B"
  }
}

formula: {
  near: bottom-center
  shape: rectangle
  label: |'md
    **Calculation:** `PhysAddr = (PTE.FrameAddr << 12) | Offset`
    - Each Page Directory covers 4GB (1024 * 4MB)
    - Each Page Table covers 4MB (1024 * 4KB)
    - Page size is fixed at 4096 bytes (2^12)
  '|
  style: {
    fill: "#F0F8FF"
    stroke: "#4682B4"
    font-size: 14
  }
}