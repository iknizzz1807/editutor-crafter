direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Process Control Block (PCB)
  Memory layout: 120+ bytes per process
| {near: top-center}
pcb: {
  shape: sql_table
  label: "struct process_t (process.h)"
  f00: "0x00 | uint32_t  | pid"
  f04: "0x04 | char[32] | name"
  state: "0x24 | process_state_t | state"
  f28: "0x28 | uint32_t | priority"
  f2c: "0x2C | uint32_t | time_slice"
  eax: "0x30 | uint32_t | eax"
  ebx: "0x34 | uint32_t | ebx"
  ecx: "0x38 | uint32_t | ecx"
  edx: "0x3C | uint32_t | edx"
  esi: "0x40 | uint32_t | esi"
  edi: "0x44 | uint32_t | edi"
  ebp: "0x48 | uint32_t | ebp"
  esp: "0x4C | uint32_t | esp"
  eip: "0x50 | uint32_t | eip"
  eflags: "0x54 | uint32_t | eflags"
  pd: "0x58 | uint32_t | page_directory"
  kstack: "0x5C | uint32_t | kernel_stack"
  ustack: "0x60 | uint32_t | user_stack"
  entry: "0x64 | uint32_t | entry_point"
  next: "0x68 | process_t* | next"
  prev: "0x6C | process_t* | prev"
  total: "Total: ~112 bytes"
}
state_enum: {
  shape: sql_table
  label: "enum process_state_t"
  s0: "0 | PROCESS_STATE_READY"
  s1: "1 | PROCESS_STATE_RUNNING"
  s2: "2 | PROCESS_STATE_BLOCKED"
  s3: "3 | PROCESS_STATE_TERMINATED"
}
legend: {
  near: bottom-center
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  ident: {
    label: "Identification"
    style.fill: "#B5D8F0"
  }
  sched: {
    label: "Scheduling"
    style.fill: "#C8E6C9"
  }
  regs: {
    label: "Registers"
    style.fill: "#FFE0B2"
  }
  mem: {
    label: "Memory"
    style.fill: "#F8BBD9"
  }
  links: {
    label: "List Pointers"
    style.fill: "#D1C4E9"
  }
}
pcb.f00.style.fill: "#B5D8F0"
pcb.f04.style.fill: "#B5D8F0"
pcb.state.style.fill: "#C8E6C9"
pcb.f28.style.fill: "#C8E6C9"
pcb.f2c.style.fill: "#C8E6C9"
pcb.eax.style.fill: "#FFE0B2"
pcb.ebx.style.fill: "#FFE0B2"
pcb.ecx.style.fill: "#FFE0B2"
pcb.edx.style.fill: "#FFE0B2"
pcb.esi.style.fill: "#FFE0B2"
pcb.edi.style.fill: "#FFE0B2"
pcb.ebp.style.fill: "#FFE0B2"
pcb.esp.style.fill: "#FFE0B2"
pcb.eip.style.fill: "#FFE0B2"
pcb.eflags.style.fill: "#FFE0B2"
pcb.pd.style.fill: "#F8BBD9"
pcb.kstack.style.fill: "#F8BBD9"
pcb.ustack.style.fill: "#F8BBD9"
pcb.entry.style.fill: "#F8BBD9"
pcb.next.style.fill: "#D1C4E9"
pcb.prev.style.fill: "#D1C4E9"
pcb -> state_enum: "state enum"