direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "PIT Channel 0 Timer Configuration" {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  registers: {
    direction: down
    label: "PIT I/O Ports (8254)"
    cmd_reg: {
      shape: sql_table
      label: "Command Register (0x43)"
      f0: "0x43 | Write Only | Mode/Channel select"
    }
    ch0: {
      shape: sql_table
      label: "Channel 0 Data (0x40)"
      f0: "0x40 | R/W | Divisor low byte"
      f1: "0x40 | R/W | Divisor high byte"
      note: "Connected to IRQ0"
    }
    cmd_reg -> ch0: "configures"
  }

  cmd_byte: {
    direction: down
    label: "Command Byte Format"
    bits: {
      shape: sql_table
      label: "0x36 = 00110110b"
      b7: "Bit 7-6 | 00 | Channel 0 select"
      b6: "Bit 5-4 | 11 | Access mode: lobyte/hibyte"
      b5: "Bit 3-1 | 011 | Mode 3: Square wave"
      b4: "Bit 0   | 0   | Binary (not BCD)"
    }
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  formula: {
    label: "Frequency Calculation"
    width: 400
    calc: |'md
      **Base Frequency:** 1,193,182 Hz (≈1.193 MHz)
      **Formula:**
      
      divisor = 1193182 / desired_freq
      
      **Common Divisors:**
      | Freq | Divisor | Hex |
      |------|---------|-----|
      | 100 Hz | 11931 | 0x2E9B |
      | 1000 Hz | 1193 | 0x04A9 |
      | 18.2 Hz | 65535 | 0xFFFF |
    '|
  }

  programming: {
    direction: down
    label: "Programming Sequence"
    step1: {
      label: "Step 1: Send Command"
      code: |'c
        outb(0x43, 0x36);  // Ch0, lobyte/hibyte, mode3
      '|
      width: 320
    }
    step2: {
      label: "Step 2: Send Divisor Low"
      code: |'c
        outb(0x40, divisor & 0xFF);
      '|
      width: 320
    }
    step3: {
      label: "Step 3: Send Divisor High"
      code: |'c
        outb(0x40, (divisor >> 8) & 0xFF);
      '|
      width: 320
    }
    step1 -> step2 -> step3
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  waveform: {
    direction: down
    label: "Mode 3 Square Wave Output"
    out_high: {
      label: "OUT high"
      width: 300
      style.fill: "#90EE90"
    }
    out_low: {
      label: "OUT low"
      width: 300
      style.fill: "#FFB6C1"
    }
    irq: {
      label: "IRQ0 on rising edge"
      width: 300
      style.fill: "#87CEEB"
    }
    out_high2: {
      label: "OUT high"
      width: 300
      style.fill: "#90EE90"
    }
    
    out_high -> out_low -> out_high2: "Period: 2 x divisor / 1.193MHz" {
      style.stroke-dash: 3
    }
    
    characteristics: {
      label: "Mode 3 Characteristics"
      note: |'md
        **Mode 3 (Square Wave):**
        - Counter decrements by 2 each clock
        - Output toggles at midpoint
        - Symmetric 50% duty cycle
        - Ideal for periodic interrupts
      '|
    }
  }

  channels: {
    direction: down
    label: "8254 Channel Usage"
    c0: {
      shape: sql_table
      label: "Channel 0 (0x40)"
      f0: "System Timer | IRQ0 | Mode 3"
      style.fill: "#E8F5E9"
    }
    c1: {
      shape: sql_table
      label: "Channel 1 (0x41)"
      f0: "DRAM Refresh | Legacy | Unused"
      style.fill: "#FFF3E0"
    }
    c2: {
      shape: sql_table
      label: "Channel 2 (0x42)"
      f0: "PC Speaker | Port 0x61 | Mode 3"
      style.fill: "#E3F2FD"
    }
  }
}

row2.formula -> row3.waveform: "produces"
row1.registers.ch0 -> row3.waveform: "triggers" {
  style.stroke: red
  style.animated: true
}