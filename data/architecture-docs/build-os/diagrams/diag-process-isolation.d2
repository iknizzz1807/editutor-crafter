direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Process Memory Isolation via Page Tables
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  process_a: {
    direction: down
    label: "Process A"
    pa_va: {
      label: "Virtual Address Space"
      direction: down
      pa_code: {
        shape: sql_table
        label: "Code/Data"
        f0: "0x08048000 | .text"
        f1: "0x0804A000 | .data"
        f2: "0x0804C000 | heap"
        f3: "0xBFFFF000 | stack"
      }
      pa_pd: {
        shape: sql_table
        label: "Page Directory"
        f0: "Entry 32 | PT@0x125000"
        f1: "Entry 768+ | Kernel PTs"
        f2: "User entries | U/S=1"
      }
    }
  }
  process_b: {
    direction: down
    label: "Process B"
    pb_va: {
      label: "Virtual Address Space"
      direction: down
      pb_code: {
        shape: sql_table
        label: "Code/Data"
        f0: "0x08048000 | .text"
        f1: "0x0804A000 | .data"
        f2: "0x0804C000 | heap"
        f3: "0xBFFFF000 | stack"
      }
      pb_pd: {
        shape: sql_table
        label: "Page Directory"
        f0: "Entry 32 | PT@0x347000"
        f1: "Entry 768+ | Kernel PTs"
        f2: "User entries | U/S=1"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  physical: {
    direction: down
    label: "Physical RAM"
    phys_frames: {
      shape: sql_table
      label: "Physical Frames"
      f0: "0x00000000 | BIOS/VGA"
      f1: "0x00100000 | Kernel"
      f2: "0x00200000 | Kernel Heap"
      f3: "0x00500000 | Proc A PTs"
      f4: "0x00501000 | Proc A Code"
      f5: "0x00600000 | Proc B PTs"
      f6: "0x00601000 | Proc B Code"
    }
  }
  kernel_space: {
    direction: down
    label: "Kernel Space (0xC0000000+)"
    style.fill: "#E8E8E8"
    kernel_mapping: {
      shape: sql_table
      label: "Shared Kernel Pages"
      f0: "Entries 768-1023"
      f1: "All processes map these"
      f2: "U/S=0 (supervisor)"
      f3: "Same physical frames"
    }
  }
}
process_a.pa_va.pa_pd -> process_a.pa_va.pa_code: "translates"
process_b.pb_va.pb_pd -> process_b.pb_va.pb_code: "translates"
process_a.pa_va.pa_code.f0 -> physical.phys_frames.f4: "0x08048000 → 0x00501000"
process_b.pb_va.pb_code.f0 -> physical.phys_frames.f6: "0x08048000 → 0x00601000"
kernel_space.kernel_mapping -> process_a.pa_va.pa_pd: "mapped in all"
kernel_space.kernel_mapping -> process_b.pb_va.pb_pd: "mapped in all"
note_isolation: |md
  **Key Point:** Same virtual addresses (0x08048000)  
  map to **different physical frames** for each process.  
  Process A cannot access Process B's memory because  
  its page tables don't contain those mappings.  
  Kernel pages are shared but U/S=0 (supervisor-only).
| {near: bottom-center}