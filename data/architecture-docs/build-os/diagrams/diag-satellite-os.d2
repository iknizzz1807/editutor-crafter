d2
direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "MyOS Kernel Architecture Map" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  hw: "Hardware Layer" {
    shape: rectangle
    style.fill: "#FFE4E1"
  }
  boot: "Boot Layer" {
    shape: rectangle
    style.fill: "#E6F3FF"
  }
  kern: "Kernel Core" {
    shape: rectangle
    style.fill: "#E8F5E9"
  }
  mem: "Memory Subsystem" {
    shape: rectangle
    style.fill: "#FFF8E1"
  }
  proc: "Process Subsystem" {
    shape: rectangle
    style.fill: "#F3E5F5"
  }
}
layer_hw: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  cpu: "CPU\nx86-32" {
    shape: rectangle
    style.fill: "#FFE4E1"
    style.stroke: "#B22222"
    width: 120
  }
  ram: "Physical RAM\n(512 MB)" {
    shape: cylinder
    style.fill: "#FFE4E1"
    style.stroke: "#B22222"
  }
  devices: "Hardware\nDevices" {
    shape: rectangle
    style.fill: "#FFE4E1"
    style.stroke: "#B22222"
    width: 120
  }
}
layer_boot: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  bios: "BIOS/UEFI\nROM" {
    shape: document
    style.fill: "#E6F3FF"
    style.stroke: "#0066CC"
  }
  mbr: "Bootloader\n(MBR 512B)\nboot/boot.asm" {
    shape: rectangle
    style.fill: "#E6F3FF"
    style.stroke: "#0066CC"
    width: 140
  }
  gdt_boot: "GDT Setup\nboot/gdt.asm" {
    shape: rectangle
    style.fill: "#E6F3FF"
    style.stroke: "#0066CC"
    width: 120
  }
}
layer_core: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  entry: "Kernel Entry\nkernel/entry.asm\n_start → kernel_main()" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    width: 180
  }
  idt: "IDT Manager\nkernel/idt.c\n256 interrupt vectors" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    width: 150
  }
  pic: "PIC Driver\nkernel/pic.c\nIRQ remap 32-47" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    width: 130
  }
}
layer_mem: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  pmm: "Physical Memory\nkernel/pmm.c\nBitmap allocator" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F9A825"
    width: 140
  }
  vmm: "Virtual Memory\nkernel/vmm.c\nPage tables, CR3" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F9A825"
    width: 140
  }
  kheap: "Kernel Heap\nkernel/kheap.c\nkmalloc/kfree" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F9A825"
    width: 130
  }
}
layer_proc: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  process: "Process Manager\nkernel/process.c\nPCB, create/terminate" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 150
  }
  sched: "Scheduler\nkernel/scheduler.c\nRound-robin, 10ms slice" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 150
  }
  tss: "TSS Manager\nkernel/tss.c\nRing 0→3 transitions" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 130
  }
}
layer_support: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  syscall: "System Calls\nkernel/syscall.c\nINT 0x80, DPL=3" {
    shape: rectangle
    style.fill: "#E0F2F1"
    style.stroke: "#00695C"
    width: 140
  }
  drivers: "Device Drivers\nVGA, Serial, Keyboard\nTimer (PIT)" {
    shape: rectangle
    style.fill: "#E0F2F1"
    style.stroke: "#00695C"
    width: 150
  }
  kprintf: "Kernel I/O\nkernel/kprintf.c\nFormatted output" {
    shape: rectangle
    style.fill: "#E0F2F1"
    style.stroke: "#00695C"
    width: 130
  }
}
layer_hw -> layer_boot: "POST, load MBR"
layer_boot -> layer_core: "Protected mode\njmp 0x08:0x100000"
layer_core -> layer_mem: "Setup complete"
layer_mem -> layer_proc: "Memory ready"
layer_proc -> layer_support: "Processes running"
cpu -> bios: "RESET\nCS:IP=F000:FFF0"
bios -> mbr: "Load sector 0\nto 0x7C00"
mbr -> gdt_boot: "Enable A20\nLoad kernel"
gdt_boot -> entry: "Set CR0.PG\nFar jump to 32-bit"
entry -> idt: "BSS zeroed\nCall kernel_main()"
idt -> pic: "Load IDT\nlidt [idt_ptr]"
pic -> pmm: "Remap IRQs\n0x20-0x2F"
pmm -> vmm: "Bitmap ready\nFrame allocation"
vmm -> kheap: "Page tables\nIdentity map 4MB"
kheap -> process: "kmalloc works\nDynamic allocation"
process -> sched: "PCB created\nPID assigned"
sched -> tss: "Ready queue\nTime slicing"
tss -> syscall: "TSS.ESP0 set\nUser mode entry"
syscall -> drivers: "INT 0x80\nUser→Kernel"
drivers -> kprintf: "IRQ handlers\nI/O ports"
idt.link: "layers.idt_detail"
pmm.link: "layers.pmm_detail"
vmm.link: "layers.vmm_detail"
sched.link: "layers.scheduler_detail"
layers: {
  idt_detail: {
    title: "IDT Structure Detail" {
      near: top-center
    }
    idt_table: "Interrupt Descriptor Table\n256 × 8-byte entries" {
      shape: class
      entries: "[0-19] CPU Exceptions"
      entries_div: "[0] Divide Error"
      entries_pf: "[14] Page Fault"
      entries_irq: "[32-47] Hardware IRQs"
      entries_sys: "[0x80] System Calls"
    }
  }
  pmm_detail: {
    title: "Physical Memory Layout" {
      near: top-center
    }
    mem_layout: {
      shape: sql_table
      label: "Physical Memory Map"
      r0: "0x000000-0x0003FF | IVT (1KB)"
      r1: "0x0007C00-0x0007DFF | Bootloader (512B)"
      r2: "0x000A000-0x000BFFF | VGA Buffer (128KB)"
      r3: "0x00100000-0x001FFFFF | Kernel (~1MB)"
      r4: "0x00200000+ | Free frames (bitmap)"
    }
  }
  vmm_detail: {
    title: "Virtual Memory Layout" {
      near: top-center
    }
    virt_layout: {
      shape: sql_table
      label: "Virtual Address Space"
      r0: "0x00000000-0xBFFFFFFF | User Space (3GB)"
      r1: "0xC0000000-0xC03FFFFF | Kernel (4MB identity)"
      r2: "0xC0400000+ | Kernel Heap"
      r3: "0xFFC00000+ | Page Tables (recursive)"
    }
  }
  scheduler_detail: {
    title: "Scheduler State Machine" {
      near: top-center
    }
    state_ready: "READY" {
      shape: circle
      style.fill: "#C8E6C9"
    }
    state_running: "RUNNING" {
      shape: circle
      style.fill: "#FFCDD2"
    }
    state_blocked: "BLOCKED" {
      shape: circle
      style.fill: "#BBDEFB"
    }
    state_term: "TERMINATED" {
      shape: circle
      style.fill: "#BDBDBD"
    }
    state_ready -> state_running: "scheduled"
    state_running -> state_ready: "time slice expired"
    state_running -> state_blocked: "I/O wait"
    state_blocked -> state_ready: "I/O complete"
    state_running -> state_term: "exit()"
  }
}