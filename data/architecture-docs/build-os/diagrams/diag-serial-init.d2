direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: "Serial Port Initialization Sequence (COM1 Base: 0x3F8)"
  near: top-center
  style.stroke: transparent
  style.fill: transparent
  style.font-size: 24
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  reg_map: {
    direction: down
    label: "COM1 Register Map (serial.h)"
    ports: {
      shape: sql_table
      label: "Port Offsets and Register Access"
      r0: "0x00 | DATA | R/W"
      r1: "0x01 | INT_ENABLE | R/W"
      r2: "0x02 | FIFO_CTRL | W"
      r3: "0x03 | LINE_CTRL | R/W"
      r4: "0x04 | MODEM_CTRL | R/W"
      r5: "0x05 | LINE_STATUS | R"
      note: "DLAB=1: Offsets 0 and 1 switch to Divisor Latch"
    }
  }
  
  divisor: {
    direction: down
    label: "Baud Rate Divisor Selection"
    calc: {
      shape: sql_table
      label: "115200 Baud Calculation"
      base: "Base Frequency | 115200 Hz"
      div: "Divisor | 1 (0x0001)"
      low: "Low Byte | 0x01 maps to Port 0x3F8"
      high: "High Byte | 0x00 maps to Port 0x3F9"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  # Renamed from 'steps' to 'init_logic' to avoid D2 reserved composition keyword
  init_logic: {
    direction: down
    label: "Initialization Sequence (serial_init.c)"
    width: 500
    
    seq1: {
      label: "Step 1: Disable Interrupts"
      code: |'c
        outb(COM1 + INT_ENABLE, 0x00);
        // Port 0x3F9 <- 0x00
      '|
      width: 400
    }
    
    seq2: {
      label: "Step 2: Enable DLAB"
      code: |'c
        outb(COM1 + LINE_CTRL, 0x80);
        // Port 0x3FB <- 0x80
        // Bit 7 (DLAB) = 1: Divisor access
      '|
      width: 400
    }
    
    seq3: {
      label: "Step 3: Set Baud Divisor"
      code: |'c
        outb(COM1 + DATA, 0x01);       // LSB
        outb(COM1 + INT_ENABLE, 0x00); // MSB
        // Set 115200 baud
      '|
      width: 400
    }
    
    seq4: {
      label: "Step 4: Set 8N1 and Clear DLAB"
      code: |'c
        outb(COM1 + LINE_CTRL, 0x03);
        // Port 0x3FB <- 0x03
        // 8 data, no parity, 1 stop
      '|
      width: 400
    }
    
    seq5: {
      label: "Step 5: Enable/Clear FIFO"
      code: |'c
        outb(COM1 + FIFO_CTRL, 0xC7);
        // Port 0x3FA <- 0xC7
        // 14-byte trigger threshold
      '|
      width: 400
    }
    
    seq6: {
      label: "Step 6: Hardware Loopback Check"
      code: |'c
        outb(COM1 + MODEM_CTRL, 0x1E);
        outb(COM1 + DATA, 0xAE);
        if (inb(COM1 + DATA) != 0xAE) return false;
        outb(COM1 + MODEM_CTRL, 0x0F);
      '|
      width: 400
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  lcr_bits: {
    direction: down
    label: "LINE_CTRL Register (0x3FB) Detail"
    bits: {
      shape: sql_table
      label: "Bit Field Layout"
      b0: "Bit 0-1 | Word Length (11=8 bits)"
      b2: "Bit 2 | Stop Bits (0=1 stop)"
      b3: "Bit 3 | Parity Enable (0=Disabled)"
      b4: "Bit 4 | Even Parity Select"
      b7: "Bit 7 | DLAB Access Control"
      cfg: "Config: 0x03 (8-bit, No Parity, 1 Stop)"
    }
  }
  
  fcr_bits: {
    direction: down
    label: "FIFO_CTRL Register (0x3FA) Detail"
    bits2: {
      shape: sql_table
      label: "Bit Field Layout"
      b0: "Bit 0 | Enable FIFO"
      b1: "Bit 1 | Clear RX FIFO"
      b2: "Bit 2 | Clear TX FIFO"
      b3: "Bit 3 | DMA Mode"
      b6: "Bit 6-7 | Trigger (11=14 bytes)"
      cfg: "Config: 0xC7 (Enable + Clear Both + 14B)"
    }
  }
}

# Sequence progression connections
row2.init_logic.seq1 -> row2.init_logic.seq2: "next"
row2.init_logic.seq2 -> row2.init_logic.seq3: "DLAB=1"
row2.init_logic.seq3 -> row2.init_logic.seq4: "baud latched"
row2.init_logic.seq4 -> row2.init_logic.seq5: "DLAB=0"
row2.init_logic.seq5 -> row2.init_logic.seq6: "FIFO ready"

row2.init_logic.seq6: {
  style.fill: "#ACE1AF"
  style.stroke: "#2E8B57"
}