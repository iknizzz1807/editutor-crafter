direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # INT 0x80 System Call Interface
    User → Kernel transition mechanism
  |
  near: top-center
  shape: text
}
row_user: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  user_code: {
    direction: down
    label: "User Process (Ring 3)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    setup: {
      label: "1. Setup Registers"
      width: 280
      code: |'c
        // User code
        mov eax, 2      // syscall #
        mov ebx, 1      // fd
        mov ecx, buf    // buffer
        mov edx, len    // count
        int 0x80        // trap!
      '|
    }
    regs_box: {
      label: "Registers Before INT"
      shape: class
      +eax: "2 (SYS_WRITE)"
      +ebx: "1 (fd)"
      +ecx: "buf pointer"
      +edx: "len (count)"
    }
  }
}
row_transition: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  transition: {
    direction: down
    label: "CPU Transition"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    int_gate: {
      label: "2. INT 0x80"
      width: 260
      code: |'c
        // CPU actions:
        // 1. Push SS, ESP (user stack)
        // 2. Push EFLAGS
        // 3. Push CS, EIP (return addr)
        // 4. Load CS:EIP from IDT[0x80]
        // 5. Switch to Ring 0 stack
        //    (from TSS.ESP0)
      '|
    }
    stack_before: {
      label: "User Stack (before)"
      shape: sql_table
      label2: "(grows down)"
      f0: "0x1000 | ... | user data"
      f1: "0x0FFC | return_addr | from call"
    }
    stack_after: {
      label: "Kernel Stack (after)"
      shape: sql_table
      note: "TSS.ESP0 provides this"
      f0: "0x9000 | SS (0x23) | user seg"
      f1: "0x8FFC | ESP | user stack ptr"
      f2: "0x8FF8 | EFLAGS | saved flags"
      f3: "0x8FF4 | CS (0x1B) | user code"
      f4: "0x8FF0 | EIP | return addr"
      sz: "CPU pushed 20 bytes"
    }
  }
}
row_kernel: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  kernel_code: {
    direction: down
    label: "Kernel (Ring 0)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    entry: {
      label: "3. syscall_entry.asm"
      width: 300
      code: |'nasm
        syscall_asm_entry:
            pusha           ; save all regs
            push ds, es     ; save segments
            mov ax, 0x10    ; kernel data
            mov ds, ax
            push esp        ; arg to handler
            call syscall_handler
            ; ... restore ...
            iret            ; return to user
      '|
    }
    dispatcher: {
      label: "4. syscall_handler()"
      width: 300
      code: |'c
        void syscall_handler(regs *r) {
          int num = r->eax;  // syscall #
          int a1 = r->ebx;   // arg 1
          int a2 = r->ecx;   // arg 2
          int a3 = r->edx;   // arg 3
          r->eax = syscall_table[num](a1,a2,a3);
        }
      '|
    }
    table_box: {
      label: "syscall_table[]"
      shape: sql_table
      idx0: "0 | sys_exit"
      idx1: "1 | sys_read"
      idx2: "2 | sys_write"
      idx3: "3 | sys_yield"
      idx4: "4 | sys_getpid"
      note: "indexed by EAX"
    }
    handler: {
      label: "5. sys_write()"
      width: 300
      code: |'c
        int sys_write(int fd, 
                      char *buf, 
                      int count) {
          // fd=1 = stdout
          for (int i=0; i<count; i++)
            vga_put_char(buf[i]);
          return count; // in EAX
        }
      '|
    }
  }
}
row_return: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  return_flow: {
    direction: down
    label: "Return Path"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    iret_box: {
      label: "6. iret Instruction"
      width: 280
      code: |'c
        // iret pops from stack:
        // 1. EIP  (return addr)
        // 2. CS   (user code seg)
        // 3. EFLAGS
        // 4. ESP  (user stack)
        // 5. SS   (user data seg)
        // Then: Ring 3, user code!
      '|
    }
    user_result: {
      label: "Result in User"
      shape: class
      label2: "(EAX contains return value)"
      +eax: "count (bytes written)"
      +ebx: "1 (unchanged)"
      +ecx: "buf (unchanged)"
      +edx: "len (unchanged)"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  ring3: "Ring 3 (User)" {
    style.fill: "#E8F5E9"
    width: 120
  }
  ring0: "Ring 0 (Kernel)" {
    style.fill: "#E3F2FD"
    width: 120
  }
  hw: "Hardware/CPU" {
    style.fill: "#FFF3E0"
    width: 120
  }
}
row_user.user_code.setup -> row_transition.transition.int_gate: "trigger" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_transition.transition.int_gate -> row_kernel.kernel_code.entry: "IDT lookup" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
row_kernel.kernel_code.entry -> row_kernel.kernel_code.dispatcher: "call" {
  style.stroke: "#2196F3"
}
row_kernel.kernel_code.dispatcher -> row_kernel.kernel_code.table_box: "dispatch" {
  style.stroke-dash: 3
  style.stroke: "#2196F3"
}
row_kernel.kernel_code.dispatcher -> row_kernel.kernel_code.handler: "invoke" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
row_kernel.kernel_code.handler -> row_return.return_flow.iret_box: "return" {
  style.stroke: "#9C27B0"
}
row_return.return_flow.iret_box -> row_return.return_flow.user_result: "resume" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
row_transition.transition.stack_before -> row_transition.transition.stack_after: "TSS.ESP0" {
  label: "stack switch"
  style.stroke: "#FF9800"
  style.stroke-dash: 4
}