direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # System Call Dispatch Table
  **INT 0x80 Handler → syscall_table[] → Function Implementations**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  user_code: {
    direction: down
    label: "User Mode (Ring 3)"
    user_call: {
      label: "System Call Invocation"
      width: 320
      code: |'c
        // User code triggers INT 0x80
        // EAX = syscall number
        // EBX, ECX, EDX = arguments
        // sys_write(1, "Hello", 5)
        mov eax, 2        // SYS_WRITE
        mov ebx, 1        // fd = stdout
        mov ecx, msg      // buf
        mov edx, 5        // count
        int 0x80          // Trap to kernel
        // sys_exit(0)
        mov eax, 0        // SYS_EXIT
        mov ebx, 0        // status
        int 0x80
      '|
    }
    registers: {
      shape: sql_table
      label: "CPU Registers at INT 0x80"
      r0: "EAX | syscall_num | 2 (write) or 0 (exit)"
      r1: "EBX | arg1       | fd or status"
      r2: "ECX | arg2       | buf pointer"
      r3: "EDX | arg3       | count"
      sz: "32-bit registers"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  idt_entry: {
    direction: down
    label: "IDT Entry 0x80"
    gate: {
      shape: sql_table
      label: "Trap Gate (kernel/idt.c)"
      f0: "0x00 | Offset Low  | handler & 0xFFFF"
      f1: "0x02 | Selector    | 0x08 (kernel CS)"
      f2: "0x04 | Zero        | 0x00"
      f3: "0x05 | Type/Attr   | 0xEE (DPL=3, trap)"
      f4: "0x06 | Offset High | handler >> 16"
      sz: "DPL=3 allows user-mode invocation"
    }
    type_bits: {
      label: "Type Byte 0xEE Breakdown"
      width: 300
      code: |'c
        0xEE = 11101110b
        Bit 7:   P=1 (Present)
        Bits6-5: DPL=11 (Ring 3 can call)
        Bit 4:   S=0 (System segment)
        Bits3-0: Type=1110 (32-bit trap gate)
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  asm_stub: {
    direction: down
    label: "Assembly Entry Stub"
    stub: {
      label: "syscall_asm_entry (syscall_entry.asm)"
      width: 340
      code: |'nasm
        syscall_asm_entry:
            pusha              ; Save EAX,ECX,EDX,EBX,ESP,EBP,ESI,EDI
            mov ax, ds
            push ax            ; Save DS
            mov ax, es
            push ax            ; Save ES
            mov ax, 0x10       ; Load kernel DS
            mov ds, ax
            mov es, ax
            push esp           ; Pass regs* pointer
            call syscall_handler
            add esp, 4
            pop ax             ; Restore ES
            mov es, ax
            pop ax             ; Restore DS
            mov ds, ax
            popa               ; Restore registers
            iret               ; Return to user mode
      '|
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c_handler: {
    direction: down
    label: "C Handler (kernel/syscall.c)"
    handler: {
      label: "syscall_handler(registers_t *regs)"
      width: 380
      code: |'c
        void syscall_handler(registers_t *regs) {
            int syscall_num = regs->eax;
            int arg1 = regs->ebx;
            int arg2 = regs->ecx;
            int arg3 = regs->edx;
            int result = -1;
            if (syscall_num >= 0 && 
                syscall_num < NUM_SYSCALLS) {
                syscall_func_t func = 
                    syscall_table[syscall_num];
                if (func != NULL) {
                    result = func(arg1, arg2, arg3);
                }
            }
            regs->eax = result;  // Return value
        }
      '|
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dispatch_table: {
    direction: down
    label: "Dispatch Table (syscall_table[])"
    table: {
      shape: sql_table
      label: "syscall_table[] Array (kernel/syscall.c)"
      f0: "0 | sys_exit    | (int status)"
      f1: "1 | sys_read    | (int fd, char *buf, int count)"
      f2: "2 | sys_write   | (int fd, const char *buf, int count)"
      f3: "3 | sys_yield   | (void)"
      f4: "4 | sys_getpid  | (void)"
      f5: "5 | NULL        | (unimplemented)"
      f6: "... | ... | ..."
      sz: "Indexed by EAX value"
    }
    typedef: {
      label: "Function Pointer Type"
      width: 300
      code: |'c
        typedef int (*syscall_func_t)(
            int arg1, 
            int arg2, 
            int arg3
        );
        static syscall_func_t syscall_table[] = {
            [SYS_EXIT]   = (syscall_func_t)sys_exit,
            [SYS_READ]   = (syscall_func_t)sys_read,
            [SYS_WRITE]  = (syscall_func_t)sys_write,
            [SYS_YIELD]  = (syscall_func_t)sys_yield,
            [SYS_GETPID] = (syscall_func_t)sys_getpid,
        };
      '|
    }
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  implementations: {
    direction: down
    label: "System Call Implementations"
    sys_write_impl: {
      label: "sys_write(fd, buf, count)"
      width: 380
      code: |'c
        int sys_write(int fd, const char *buf, int count) {
            // Only stdout(1) and stderr(2) supported
            if (fd != 1 && fd != 2) return -1;
            // Write to VGA console
            for (int i = 0; i < count; i++) {
                vga_put_char(buf[i], 
                    vga_color_attr(
                        VGA_COLOR_LIGHT_GREY,
                        VGA_COLOR_BLACK
                    ));
            }
            return count;  // Bytes written
        }
      '|
    }
    sys_exit_impl: {
      label: "sys_exit(status)"
      width: 380
      code: |'c
        int sys_exit(int status) {
            process_t *current = 
                process_get_current();
            if (current != NULL) {
                kprintf(
                    "Process %d exited "
                    "with status %d\n",
                    current->pid, status
                );
                process_terminate(current);
                scheduler_yield(); // Never returns
            }
            return 0;
        }
      '|
    }
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  defines: {
    direction: down
    label: "System Call Numbers"
    defines_table: {
      shape: sql_table
      label: "kernel/syscall.h"
      d0: "SYS_EXIT   | 0"
      d1: "SYS_READ   | 1"
      d2: "SYS_WRITE  | 2"
      d3: "SYS_YIELD  | 3"
      d4: "SYS_GETPID | 4"
      sz: "#define constants"
    }
  }
}
# Connections
user_code.user_call -> idt_entry.gate: "int 0x80" {
  style.stroke: "#6666FF"
  style.stroke-width: 2
  style.animated: true
}
idt_entry.gate -> asm_stub.stub: "jmp CS:EIP" {
  style.stroke: "#6666FF"
}
asm_stub.stub -> c_handler.handler: "call" {
  style.stroke: "#6666FF"
}
c_handler.handler -> dispatch_table.table: "syscall_table[num]" {
  style.stroke: "#66AA66"
  style.stroke-width: 2
}
dispatch_table.table -> implementations.sys_write_impl: "index 2" {
  style.stroke: "#66AA66"
  label: "EAX=2"
}
dispatch_table.table -> implementations.sys_exit_impl: "index 0" {
  style.stroke: "#AA6666"
  label: "EAX=0"
}
# Legend
legend: {
  near: bottom-right
  label: "Data Flow"
  flow_user: "User → Kernel" {
    shape: text
    style.font-color: "#6666FF"
  }
  flow_dispatch: "Dispatch Lookup" {
    shape: text
    style.font-color: "#66AA66"
  }
  flow_exit: "Exit Path" {
    shape: text
    style.font-color: "#AA6666"
  }
}