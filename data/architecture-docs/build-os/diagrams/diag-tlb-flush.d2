direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TLB Flush Methods
  Translation Lookaside Buffer invalidation strategies
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  invlpg: {
    direction: down
    label: "invlpg (Single Page)"
    width: 300
    desc: |md
      **Use Case:**  
      Modify one page table entry  
      (map, unmap, change permissions)
      **Latency:** ~10-20 cycles  
      **Scope:** One virtual page
    |
    code: |'c
      // Invalidate single TLB entry
      static inline void flush_tlb_page(
          uint32_t virt) {
        __asm__ volatile (
          "invlpg (%0)"
          : 
          : "r"(virt)
          : "memory"
        );
      }
    '|
    when: |md
      **When to use:**
      - `mmap()` single page
      - `munmap()` single page
      - Change page protections
      - Copy-on-write fault
    |
  }
  cr3_reload: {
    direction: down
    label: "CR3 Reload (Full TLB)"
    width: 300
    desc: |md
      **Use Case:**  
      Address space switch  
      (context switch to new process)
      **Latency:** ~100-500 cycles  
      **Scope:** All non-global pages
    |
    code: |'c
      // Flush entire TLB via CR3 reload
      static inline void flush_tlb_all(void) {
        uint32_t cr3;
        __asm__ volatile (
          "mov %%cr3, %0\n"
          "mov %0, %%cr3"
          : "=r"(cr3)
          :
          : "memory"
        );
      }
    '|
    when: |md
      **When to use:**
      - Context switch (process A → B)
      - `exec()` load new binary
      - Major page table rebuild
      - Security-sensitive flush
    |
  }
  invlpga: {
    direction: down
    label: "invlpga (ASID-Specific)"
    width: 300
    desc: |md
      **Use Case:**  
      PCID/ASID-aware flush  
      (modern x86-64 with PCID)
      **Latency:** ~15-30 cycles  
      **Scope:** Pages for specific ASID
    |
    code: |'c
      // ASID-specific TLB flush (x86-64)
      static inline void flush_tlb_asid(
          uint64_t virt, uint16_t asid) {
        __asm__ volatile (
          "invlpg [%0, %1]"
          :
          : "r"(virt), "r"((uint64_t)asid)
          : "memory"
        );
      }
    '|
    when: |md
      **When to use:**
      - Kernel updates user page
      - Cross-address-space shootdown
      - Paravirtualized guests
      - Fine-grained isolation
    |
  }
}
