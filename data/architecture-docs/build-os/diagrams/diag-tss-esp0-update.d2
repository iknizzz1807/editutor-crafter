direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TSS.ESP0 Update on Context Switch
  Why the kernel stack pointer must change when switching processes
| {near: top-center}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  process_a: {
    direction: down
    label: "Process A (Running)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    user_stack_a: {
      label: "User Stack"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 120
      height: 80
    }
    kernel_stack_a: {
      label: "Kernel Stack A\n0x90000"
      shape: rectangle
      style.fill: "#A5D6A7"
      width: 120
      height: 120
      contents: |md
        Saved EIP, CS, EFLAGS
        Saved EAX, EBX, ECX...
        [growing down]
      |
    }
    user_stack_a -> kernel_stack_a: "Ring 3→0\ntransition" {
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
  }
  tss_before: {
    direction: down
    label: "TSS (Before Switch)"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    tss_struct_before: {
      shape: sql_table
      label: "Task State Segment"
      f0: "0x00 | link     | 0"
      f1: "0x04 | ESP0     | 0x90000"
      f2: "0x08 | SS0      | 0x10"
      f3: "0x0C | ESP1     | —"
      f4: "...  | ...      | ..."
      f5: "0x66 | iomap    | 104"
    }
    note_before: {
      label: "ESP0 points to\nProcess A's kernel stack"
      shape: callout
      style.fill: "#FFE0B2"
    }
    tss_struct_before.ESP0 -> process_a.kernel_stack_a: "correct" {
      style.stroke: "#2E7D32"
      style.stroke-width: 3
    }
  }
  process_b: {
    direction: down
    label: "Process B (Ready)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-dash: 3
    user_stack_b: {
      label: "User Stack"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 120
      height: 80
    }
    kernel_stack_b: {
      label: "Kernel Stack B\n0x88000"
      shape: rectangle
      style.fill: "#90CAF9"
      width: 120
      height: 120
      contents: |md
        Saved context
        from last switch
        [frozen state]
      |
    }
    user_stack_b -> kernel_stack_b: "interrupt" {
      style.stroke-dash: 3
      style.stroke: "#1565C0"
    }
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  process_a_after: {
    direction: down
    label: "Process A (Ready)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-dash: 3
    style.opacity: 0.6
    kernel_stack_a_frozen: {
      label: "Kernel Stack A\n0x90000"
      shape: rectangle
      style.fill: "#A5D6A7"
      width: 120
      height: 120
      contents: |md
        [FROZEN]
        Full register state
        saved for resume
      |
    }
  }
  tss_after: {
    direction: down
    label: "TSS (After Switch)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    tss_struct_after: {
      shape: sql_table
      label: "Task State Segment"
      f0: "0x00 | link     | 0"
      f1: "0x04 | ESP0     | 0x88000"
      f2: "0x08 | SS0      | 0x10"
      f3: "0x0C | ESP1     | —"
      f4: "...  | ...      | ..."
      f5: "0x66 | iomap    | 104"
    }
    note_after: {
      label: "ESP0 updated to\nProcess B's kernel stack"
      shape: callout
      style.fill: "#C8E6C9"
    }
    tss_struct_after.ESP0 -> process_b_after.kernel_stack_b: "correct" {
      style.stroke: "#2E7D32"
      style.stroke-width: 3
    }
  }
  process_b_after: {
    direction: down
    label: "Process B (Running)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    user_stack_b_after: {
      label: "User Stack"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 120
      height: 80
    }
    kernel_stack_b: {
      label: "Kernel Stack B\n0x88000"
      shape: rectangle
      style.fill: "#90CAF9"
      width: 120
      height: 120
      contents: |md
        Active stack
        for syscalls/interrupts
      |
    }
    user_stack_b_after -> kernel_stack_b: "Ring 3→0\nuses TSS.ESP0" {
      style.stroke: "#1565C0"
      style.stroke-width: 2
    }
  }
}
row_before -> row_after: "context_switch()\n1. Save A's registers\n2. Update TSS.ESP0 = 0x88000\n3. Load CR3 (if different)\n4. Restore B's registers\n5. ret to B's EIP" {
  style.stroke: "#6A1B9A"
  style.stroke-width: 2
  style.font-color: "#6A1B9A"
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  correct: {
    label: "Correct: ESP0 → current process kernel stack"
    shape: rectangle
    style.fill: "#C8E6C9"
    width: 200
  }
  wrong: {
    label: "Bug: Stale ESP0 → wrong stack → corruption"
    shape: rectangle
    style.fill: "#FFCDD2"
    width: 200
  }
}
danger_section: {
  near: bottom-center
  label: "What Happens if TSS.ESP0 is NOT Updated"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  scenario: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    wrong_tss: {
      label: "Stale TSS"
      shape: sql_table
      f0: "ESP0 | 0x90000"
      f1: "(Process A's stack!)"
    }
    process_b_trap: {
      label: "Process B executes\nINT 0x80 (syscall)"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    corruption: {
      label: "CPU pushes to 0x90000\n(overwrites Process A's saved state!)"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.stroke-width: 2
    }
    wrong_tss -> process_b_trap: "CPU reads\nstale ESP0" {
      style.stroke: "#C62828"
      style.stroke-dash: 3
    }
    process_b_trap -> corruption: "push SS, ESP, EFLAGS,\nCS, EIP to WRONG stack" {
      style.stroke: "#C62828"
      style.stroke-width: 2
    }
  }
  result: {
    label: |md
      **Result**: When Process A resumes, its saved registers are corrupted.
      Process B's syscall clobbered Process A's kernel stack.
      This causes random crashes, silent data corruption, or triple faults.
    |
    shape: rectangle
    style.fill: "#FFCDD2"
    width: 600
  }
}
code_example: {
  near: bottom-center
  label: "Correct Implementation"
  code: |'c
    // In context_switch (assembly or C wrapper)
    void context_switch(process_t *old, process_t *new) {
        // 1. Save old process state to its PCB
        old->esp = current_esp;
        old->eip = return_address;
        // ... save other registers ...
        // 2. CRITICAL: Update TSS.ESP0 before restoring new process
        //    This ensures ring transitions use correct kernel stack
        tss.esp0 = new->kernel_stack_top;  // <-- MUST DO THIS!
        // 3. Switch page directory if needed
        if (new->page_directory != old->page_directory) {
            load_cr3(new->page_directory);
        }
        // 4. Restore new process state and resume
        restore_registers_and_jump(new);
    }
  '|
  shape: rectangle
  style.fill: "#E8F5E9"
  width: 650
}