direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- Header Section ---
header: {
  style.stroke: transparent
  style.fill: transparent
  title: "Task State Segment (TSS) Layout" {
    shape: rectangle
    style: {
      font-size: 28
      bold: true
      underline: true
      stroke: transparent
      fill: transparent
    }
  }
}
header.near: top-center

# --- Data Structure Layout ---
tss_layout: {
  shape: sql_table
  label: "struct tss_t (tss.h)"
  f00: "0x00 | uint16_t | link"
  f02: "0x02 | uint16_t | _pad0"
  f04: "0x04 | uint32_t | esp0 // Kernel Stack Pointer"
  f08: "0x08 | uint16_t | ss0 // Kernel Stack Segment"
  f0a: "0x0A | uint16_t | _pad1"
  f0c: "0x0C | uint32_t | esp1"
  f10: "0x10 | uint16_t | ss1"
  f12: "0x12 | uint16_t | _pad2"
  f14: "0x14 | uint32_t | esp2"
  f18: "0x18 | uint16_t | ss2"
  f1a: "0x1A | uint16_t | _pad3"
  f1c: "0x1C | uint32_t | cr3 // Page Directory Base"
  f20: "0x20 | uint32_t | eip"
  f24: "0x24 | uint32_t | eflags"
  f28: "0x28 | uint32_t | eax"
  f2c: "0x2C | uint32_t | ecx"
  f30: "0x30 | uint32_t | edx"
  f34: "0x34 | uint32_t | ebx"
  f38: "0x38 | uint32_t | esp"
  f3c: "0x3C | uint32_t | ebp"
  f40: "0x40 | uint32_t | esi"
  f44: "0x44 | uint32_t | edi"
  f48: "0x48 | uint16_t | es"
  f4a: "0x4A | uint16_t | _pad4"
  f4c: "0x4C | uint16_t | cs"
  f4e: "0x4E | uint16_t | _pad5"
  f50: "0x50 | uint16_t | ss"
  f52: "0x52 | uint16_t | _pad6"
  f54: "0x54 | uint16_t | ds"
  f56: "0x56 | uint16_t | _pad7"
  f58: "0x58 | uint16_t | fs"
  f5a: "0x5A | uint16_t | _pad8"
  f5c: "0x5C | uint16_t | gs"
  f5e: "0x5E | uint16_t | _pad9"
  f60: "0x60 | uint16_t | ldtr"
  f62: "0x62 | uint16_t | _pad10"
  f64: "0x64 | uint16_t | _pad11"
  f66: "0x66 | uint16_t | iomap_base"
  total: "Total: 104 bytes (0x68)"
}

# --- Functional Groupings ---
row_logic: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right

  critical_fields: {
    label: "Critical Fields for Ring 3 -> Ring 0 Transitions"
    esp0_box: {
      label: "ESP0 (0x04)"
      width: 280
      code: |'c
        // Kernel stack pointer
        // CPU loads this on
        // Ring 3 -> Ring 0 transition
        tss.esp0 = proc->kernel_stack;
      '|
    }
    ss0_box: {
      label: "SS0 (0x08)"
      width: 280
      code: |'c
        // Kernel stack segment
        // Always 0x10 (kernel data)
        tss.ss0 = 0x10;
      '|
    }
    iomap_box: {
      label: "IOMAP_BASE (0x66)"
      width: 280
      code: |'c
        // I/O permission bitmap
        // >= 104 means no bitmap
        tss.iomap_base = 104;
      '|
    }
  }
}

# --- Privilege Transition Logic ---
ring_transition: {
  label: "Privilege Transition Flow (Ring 3 to 0)"
  direction: right
  
  user_stack: {
    label: "User Stack (Ring 3)"
    us_content: {
      shape: sql_table
      label: "User Stack"
      u1: "SS (0x23)"
      u2: "ESP (user_sp)"
      u3: "EFLAGS"
      u4: "CS (0x1B)"
      u5: "EIP (after int)"
    }
    style.fill: "#E8F5E9"
  }

  transition: "Hardware Switch" {
    shape: package
    cpu_action: {
      label: "CPU Hardware Actions"
      width: 320
      code: |'c
        1. Read TSS.SS0, TSS.ESP0
        2. Switch to SS0:ESP0
        3. Push user SS, ESP, EFLAGS
        4. Push user CS, EIP
        5. Load CS:EIP from IDT
        6. Start handler
      '|
    }
  }

  kernel_stack: {
    label: "Kernel Stack (Ring 0)"
    ks_content: {
      shape: sql_table
      label: "Kernel Stack Frame"
      k1: "User SS"
      k2: "User ESP"
      k3: "EFLAGS"
      k4: "User CS"
      k5: "User EIP"
      k6: "Error Code (opt)"
      k7: "trapframe_t"
    }
    style.fill: "#FFEBEE"
  }
  
  user_stack -> transition: "INT 0x80 / SYSCALL"
  transition -> kernel_stack: "Privilege Escallation"
}

# --- Segment Management ---
gdt_tss_mgmt: {
  direction: right
  label: "GDT Descriptor & Initialization"
  
  gdt_entry: {
    shape: sql_table
    label: "GDT Entry (TSS Selector 0x28)"
    b7: "Byte 7 | Base 31:24"
    b6: "Byte 6 | G|D|L|A|Limit 19:16"
    b5: "Byte 5 | P|DPL|0|Type (0x89)"
    b4: "Byte 4 | Base 23:16"
    b3: "Byte 3 | Base 15:0"
    b2: "Byte 2 | Limit 15:0"
    b1: "Byte 1 | (high)"
    b0: "Byte 0 | (low)"
  }
  
  init_logic: {
    label: "Initialization Sequence"
    width: 350
    code: |'c
      // 1. Setup GDT Entry for TSS
      set_tss_gate(5, &tss_obj);
      // 2. Load Task Register
      ltr(0x28);
      // 3. Update ESP0 on switch
      tss.esp0 = kstack_top;
    '|
  }
  
  gdt_entry -> init_logic: "ltr instruction"
}

# --- Context Switching Context ---
context_switch_update: {
  label: "Per-Context-Switch TSS Update"
  flow: {
    direction: right
    step1: {
      label: "1. Next Proc"
      code: |'c
        next = scheduler_pick();
      '|
      width: 180
    }
    step2: {
      label: "2. Update TSS"
      code: |'c
        tss.esp0 = next->kstack;
      '|
      width: 180
    }
    step3: {
      label: "3. Page Table"
      code: |'c
        lcr3(next->pgdir);
      '|
      width: 180
    }
    step4: {
      label: "4. Switch"
      code: |'c
        swtch(&old, next);
      '|
      width: 180
    }
  }
  step1 -> step2 -> step3 -> step4
}

# --- Modern Usage Notes ---
unused_fields: {
  label: "Legacy vs. Modern Usage"
  direction: right
  unused_table: {
    shape: sql_table
    label: "Software Context Switching (Linux/xv6)"
    uf1: "link | UNUSED (HW chain)"
    uf2: "esp1/ss1 | UNUSED (Ring 1)"
    uf3: "esp2/ss2 | UNUSED (Ring 2)"
    uf4: "cr3 | UNUSED (SW loads)"
    uf5: "registers | UNUSED (SW saves)"
    uf6: "ldtr | UNUSED"
  }
  note_box: {
    label: "Design Rationale"
    width: 350
    code: |'c
      // Hardware task switching is slow.
      // Modern OSes use a SINGLE TSS
      // per CPU to handle the Ring 3 
      // stack transition, then switch 
      // actual registers in software.
    '|
  }
  unused_table -> note_box
}

# --- Global Legend ---
legend_container: {
  shape: rectangle
  style.stroke: "#333333"
  style.fill: "#F5F5F5"
  
  color1: "Green = Ring 3 (User)" {
    shape: text
    style.font-color: "#2E7D32"
  }
  color2: "Red = Ring 0 (Kernel)" {
    shape: text
    style.font-color: "#C62828"
  }
  color3: "Blue = Critical Transition Data" {
    shape: text
    style.font-color: "#1565C0"
  }
}
legend_container.near: bottom-right

# --- Main Flow Connections ---
tss_layout -> row_logic
row_logic -> ring_transition
ring_transition -> gdt_tss_mgmt
gdt_tss_mgmt -> context_switch_update
context_switch_update -> unused_fields