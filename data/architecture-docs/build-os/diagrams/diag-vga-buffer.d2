direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # VGA Text Mode Buffer Structure
    Memory-mapped at 0xB8000 | 80x25 grid | 4000 bytes total
  '|
}
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  vga_grid: "80x25 Character Grid" {
    direction: down
    style.fill: "#1a1a2e"
    style.stroke: "#4a4a6a"
    style.stroke-width: 2

    header: "VGA Text Buffer @ 0xB8000" {
      style.fill: "#16213e"
      style.font-color: "#e8e8e8"
      style.stroke: "#4a4a6a"
    }

    cell_row: {
      direction: right
      style.fill: transparent
      style.stroke: transparent

      c0: "[0,0]" { 
        width: 60; height: 40
        style.fill: "#0f3460"; style.font-color: "#e94560"; style.stroke: "#e94560" 
      }
      c1: "[1,0]" { 
        width: 60; height: 40
        style.fill: "#0f3460"; style.font-color: "#00ff88"; style.stroke: "#00ff88" 
      }
      c2: "[2,0]" { 
        width: 60; height: 40
        style.fill: "#0f3460"; style.font-color: "#ffd700"; style.stroke: "#ffd700" 
      }
      gap: "---" { 
        style.fill: transparent; style.stroke: transparent; style.font-color: "#666" 
      }
      c79: "[79,0]" { 
        width: 60; height: 40
        style.fill: "#0f3460"; style.font-color: "#00bfff"; style.stroke: "#00bfff" 
      }
    }

    footer: "Rows 0 to 24 (4000 bytes)" {
      style.fill: "#0a0a1a"
      style.font-color: "#555"
      style.stroke: "#333"
    }
  }

  spacer1: { width: 40; style.fill: transparent; style.stroke: transparent }

  cell_detail: "Single Cell (2 bytes)" {
    direction: down
    style.fill: "#1e1e2e"
    style.stroke: "#6272a4"

    memory_layout: {
      shape: sql_table
      label: "Memory Layout (little-endian)"
      byte0: "0x00 | uint8_t | char_code // ASCII"
      byte1: "0x01 | uint8_t | attr_byte // Color"
      total: "Total: 2 bytes per cell"
    }

    logic: {
      label: "Example: Red 'A' on Blue"
      code: |'c
        uint16_t *buf = (uint16_t*)0xB8000;
        int offset = (y * 80 + x);
        // ASCII 'A' = 0x41
        // Red (4) on Blue (1) = 0x14
        buf[offset] = 0x1441;
      '|
      width: 280
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  attr_byte: "Attribute Byte Breakdown" {
    direction: down
    style.fill: "#1e1e2e"
    style.stroke: "#6272a4"

    bit_fields: {
      shape: sql_table
      label: "Bit Field Layout"
      f7: "Bit 7    | Blink      | 1=blink"
      f64: "Bits 6-4 | Background | 0-7 colors"
      f3: "Bit 3    | Bright     | 1=bright fg"
      f20: "Bits 2-0 | Foreground | 0-7 colors"
    }

    attr_example: {
      label: "Value 0x1F Breakdown"
      code: |'c
        Blink:     0 (steady)
        Bg:       001 (Blue)
        Bright:    1 (bold)
        Fg:      111 (White)
      '|
      width: 200
    }
  }

  spacer2: { width: 40; style.fill: transparent; style.stroke: transparent }

  color_palette: "Standard VGA Palette" {
    direction: down
    style.fill: "#1e1e2e"
    style.stroke: "#6272a4"
    
    palette_grid: {
      grid-columns: 4
      grid-gap: 4
      c0: "0: Black" { style.fill: "#000000"; style.font-color: "#888" }
      c1: "1: Blue" { style.fill: "#0000AA" }
      c2: "2: Green" { style.fill: "#00AA00" }
      c3: "3: Cyan" { style.fill: "#00AAAA" }
      c4: "4: Red" { style.fill: "#AA0000" }
      c5: "5: Magenta" { style.fill: "#AA00AA" }
      c6: "6: Brown" { style.fill: "#AA5500" }
      c7: "7: L.Gray" { style.fill: "#AAAAAA" }
      c8: "8: D.Gray" { style.fill: "#555555" }
      c9: "9: L.Blue" { style.fill: "#5555FF" }
      c10: "10: L.Green" { style.fill: "#55FF55" }
      c11: "11: L.Cyan" { style.fill: "#55FFFF" }
      c12: "12: L.Red" { style.fill: "#FF5555" }
      c13: "13: L.Magenta" { style.fill: "#FF55FF" }
      c14: "14: Yellow" { style.fill: "#FFFF55" }
      c15: "15: White" { style.fill: "#FFFFFF"; style.font-color: "#000" }
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  address_calc: "Memory Addressing" {
    direction: down
    style.fill: "#1e1e2e"
    style.stroke: "#6272a4"
    
    formula: {
      label: "Offset Formula"
      code: |'c
        // Base address 0xB8000
        offset = (row * 80 + column) * 2;
        addr = 0xB8000 + offset;
        
        // Byte 0: ASCII code
        // Byte 1: Attribute
      '|
      width: 280
    }

    buffer_info: {
      shape: sql_table
      label: "Buffer Dimensions"
      cols: "80 columns"
      rows: "25 rows"
      total: "4000 bytes (0xFA0)"
    }
  }

  spacer3: { width: 40; style.fill: transparent; style.stroke: transparent }

  code_example: "C Implementation" {
    direction: down
    style.fill: "#1e1e2e"
    style.stroke: "#6272a4"

    vga_c: {
      label: "vga_driver.c"
      code: |'c
        #define VGA_BUF ((uint16_t*)0xB8000)
        
        void vga_put(int x, int y, char c, uint8_t color) {
          const int idx = y * 80 + x;
          VGA_BUF[idx] = (uint16_t)c | (uint16_t)color << 8;
        }
      '|
      width: 320
    }
  }
}

legend: "Reference Key" {
  direction: right
  style.fill: "#282a36"
  style.stroke: "#6272a4"
  k1: "Char: ASCII (0-255)" { style.stroke: transparent; style.font-color: "#888" }
  k2: "Fg: Foreground (0-2)" { style.stroke: transparent; style.font-color: "#888" }
  k3: "Bg: Background (4-6)" { style.stroke: transparent; style.font-color: "#888" }
  k4: "Blink: Bit 7" { style.stroke: transparent; style.font-color: "#888" }
}
legend.near: bottom-center