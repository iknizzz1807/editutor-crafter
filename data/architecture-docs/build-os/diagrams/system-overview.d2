direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
    pad: 20
  }
}
title: |md
  # Build Your Own OS — Complete System Blueprint
  A 32-bit x86 kernel from bootloader to preemptive multitasking
| {
  near: top-center
  shape: text
  style.font-size: 28
}
row_boot: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  layer_boot: {
    direction: down
    label: "BOOTLOADER (boot/)  [M1]"
    boot_asm: {
      shape: class
      label: "boot.asm (512 bytes MBR)"
      +org: "0x7C00"
      +entry: "start"
      -cli: "disable interrupts"
      -setup_segments: "DS=ES=SS=0, SP=0x7C00"
      -enable_a20: "call a20.asm"
      -load_kernel: "call load_kernel.asm"
      -setup_gdt: "call gdt.asm"
      -enter_pm: "set CR0.PE, far jmp"
    }
    a20_asm: {
      shape: class
      label: "a20.asm"
      +enable_a20: "void"
      -test_a20: "returns AX=1 if enabled"
      -kbd_wait_input: "wait port 0x64"
      -kbd_wait_output: "wait port 0x64"
    }
    gdt_asm: {
      shape: sql_table
      label: "gdt.asm — GDT Entries (40 bytes)"
      null_desc: "dq 0 | Index 0"
      kernel_code: "dq 0x00CF9A000000FFFF | Sel 0x08"
      kernel_data: "dq 0x00CF92000000FFFF | Sel 0x10"
      user_code: "dq 0x00CFFA000000FFFF | Sel 0x18"
      user_data: "dq 0x00CFF2000000FFFF | Sel 0x20"
      descriptor: "dw limit; dd base | 6 bytes"
    }
  }
  layer_kernel_entry: {
    direction: down
    label: "KERNEL ENTRY (kernel/)  [M1]"
    entry_asm: {
      shape: class
      label: "entry.asm"
      +_start: "global entry point"
      -zero_bss: "rep stosb __bss_start to __bss_end"
      -call_main: "call kernel_main"
      -halt: "cli; hlt loop"
    }
    linker_ld: {
      shape: sql_table
      label: "linker.ld — Memory Layout"
      entry: "_start"
      text: ".text at 0x100000 | 4KB aligned"
      rodata: ".rodata | 4KB aligned"
      data: ".data | 4KB aligned"
      bss: "__bss_start to __bss_end | 4KB aligned"
      kernel_end: "_kernel_end symbol"
    }
  }
}
row_drivers: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  layer_vga: {
    direction: down
    label: "VGA DRIVER  [M1]"
    vga_state: {
      shape: sql_table
      label: "vga.c — State (8 bytes)"
      cursor_x: "int | current column"
      cursor_y: "int | current row"
      current_color: "uint8_t | attribute"
    }
    vga_funcs: {
      shape: class
      label: "vga.c — Functions"
      +vga_init: "void"
      +vga_clear: "void"
      +vga_put_char_at: "void (char c, uint8_t color, int x, int y)"
      +vga_put_char: "void (char c, uint8_t color)"
      +vga_write: "void (const char *str, uint8_t color)"
      -scroll: "void | move lines up"
      -update_cursor: "void | ports 0x3D4/0x3D5"
    }
  }
  layer_serial: {
    direction: down
    label: "SERIAL DRIVER  [M1]"
    serial_regs: {
      shape: sql_table
      label: "serial.c — COM1 Ports"
      data: "0x3F8 | RBR/THR"
      ier: "0x3F9 | Interrupt Enable"
      fcr: "0x3FA | FIFO Control"
      lcr: "0x3FB | Line Control"
      lsr: "0x3FD | Line Status"
    }
    serial_funcs: {
      shape: class
      label: "serial.c — Functions"
      +serial_init: "bool | 115200 baud 8N1"
      +serial_put_char: "void (char c)"
      +serial_write: "void (const char *str)"
      -is_transmit_empty: "bool | check LSR bit 5"
    }
  }
  layer_kprintf: {
    direction: down
    label: "KPRINTF  [M1]"
    kprintf_funcs: {
      shape: class
      label: "kprintf.c"
      +kprintf: "int (const char *fmt, ...)"
      +kvprintf: "int (const char *fmt, va_list)"
      -print_char: "void (char c) | VGA + serial"
      -print_uint: "void (uint32_t val, int base)"
      -print_int: "void (int32_t val)"
    }
    format_specs: {
      shape: sql_table
      label: "Format Specifiers"
      c: "char"
      s: "const char* | (null) if NULL"
      d_i: "int32_t | signed decimal"
      u: "uint32_t | unsigned"
      x_X: "uint32_t | hex lower/upper"
      p: "void* | 0x prefix"
    }
  }
}
row_interrupts: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  layer_idt: {
    direction: down
    label: "INTERRUPTS (kernel/)  [M2]"
    idt_entry: {
      shape: sql_table
      label: "IDT Entry (8 bytes) — idt.h"
      offset_low: "uint16_t | bits 15:0"
      selector: "uint16_t | 0x08 kernel CS"
      zero: "uint8_t | must be 0"
      type_attr: "uint8_t | P DPL S Type"
      offset_high: "uint16_t | bits 31:16"
    }
    idt_types: {
      shape: sql_table
      label: "Gate Types"
      interrupt: "0x8E | DPL=0, IF cleared"
      trap: "0x8F | DPL=0, IF unchanged"
      user_int: "0xEE | DPL=3, syscall gate"
    }
    registers_t: {
      shape: sql_table
      label: "registers_t (76+ bytes) — interrupts.h"
      gs_fs_es_ds: "uint32_t | segment regs"
      edi_esi_ebp: "uint32_t | pusha order"
      esp_ebx_edx: "uint32_t | pusha order"
      ecx_eax: "uint32_t | pusha order"
      int_no: "uint32_t | vector number"
      err_code: "uint32_t | CPU error code"
      eip_cs_eflags: "uint32_t | CPU pushed"
      useresp_ss: "uint32_t | if Ring 3→0"
    }
    idt_funcs: {
      shape: class
      label: "idt.c — Functions"
      +idt_init: "void | 256 entries, lidt"
      +idt_set_gate: "void (uint8_t num, uint32_t handler, uint16_t sel, uint8_t type)"
      +idt_load: "void (uint32_t idt_ptr) | asm"
    }
  }
  layer_pic: {
    direction: down
    label: "PIC 8259  [M2]"
    pic_ports: {
      shape: sql_table
      label: "PIC Ports"
      master_cmd: "0x20 | command"
      master_data: "0x21 | mask/ICW2-4"
      slave_cmd: "0xA0 | command"
      slave_data: "0xA1 | mask/ICW2-4"
    }
    pic_init_seq: {
      shape: sql_table
      label: "Initialization Sequence"
      icw1: "0x11 to both | init + need ICW4"
      icw2_m: "0x20 | master IRQ0→32"
      icw2_s: "0x28 | slave IRQ8→40"
      icw3_m: "0x04 | slave on IRQ2"
      icw3_s: "0x02 | slave ID=2"
      icw4: "0x01 | 8086 mode"
    }
    pic_funcs: {
      shape: class
      label: "pic.c — Functions"
      +pic_init: "void | remap IRQs 32-47"
      +pic_send_eoi: "void (uint8_t irq)"
      +pic_mask_irq: "void (uint8_t irq)"
      +pic_unmask_irq: "void (uint8_t irq)"
    }
  }
  layer_timer: {
    direction: down
    label: "PIT TIMER  [M2]"
    pit_regs: {
      shape: sql_table
      label: "PIT 8253/8254"
      channel0: "0x40 | data port"
      mode_reg: "0x43 | command byte"
      base_freq: "1193182 Hz | ~1.193 MHz"
    }
    timer_state: {
      shape: sql_table
      label: "timer.c — State"
      tick_count: "volatile uint64_t | global"
    }
    timer_funcs: {
      shape: class
      label: "timer.c — Functions"
      +timer_init: "void (uint32_t freq)"
      +timer_get_ticks: "uint64_t"
      +timer_get_seconds: "uint64_t"
      +timer_sleep_ms: "void (uint32_t ms)"
    }
  }
  layer_keyboard: {
    direction: down
    label: "KEYBOARD  [M2]"
    kb_state: {
      shape: sql_table
      label: "keyboard.c — State"
      buffer: "char[256] | circular"
      read_pos: "volatile uint32_t"
      write_pos: "volatile uint32_t"
      left_shift: "volatile bool"
      right_shift: "volatile bool"
      caps_lock: "volatile bool"
    }
    kb_funcs: {
      shape: class
      label: "keyboard.c — Functions"
      +keyboard_init: "void | IRQ1 vector 33"
      +keyboard_getchar: "char | blocking"
      +keyboard_try_getchar: "char | non-blocking"
      +keyboard_has_char: "bool"
      -keyboard_handler: "void (registers_t*)"
      -buffer_put: "void (char c)"
    }
  }
}
row_memory: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  layer_pmm: {
    direction: down
    label: "PHYSICAL MEMORY (kernel/)  [M3]"
    pmm_state: {
      shape: sql_table
      label: "pmm.c — State"
      frame_bitmap: "uint32_t* | 1 bit per 4KB frame"
      total_frames: "uint32_t | memory/4KB"
      free_frames: "uint32_t | available"
      bitmap_size: "uint32_t | uint32_t elements"
    }
    pmm_macros: {
      shape: sql_table
      label: "Bitmap Macros"
      index: "bit/32 | which uint32_t"
      offset: "bit%32 | which bit"
      set: "bitmap[index] |= (1 << offset)"
      clear: "bitmap[index] &= ~(1 << offset)"
      test: "bitmap[index] & (1 << offset)"
    }
    pmm_funcs: {
      shape: class
      label: "pmm.c — Functions"
      +pmm_init: "void (uint32_t total_kb)"
      +pmm_alloc_frame: "void* | linear search"
      +pmm_free_frame: "void (void* frame)"
      +pmm_mark_used: "void (uint32_t addr, uint32_t size)"
      +pmm_get_free_count: "uint32_t"
    }
  }
  layer_vmm: {
    direction: down
    label: "VIRTUAL MEMORY  [M3]"
    page_tables: {
      shape: sql_table
      label: "Page Table Entry (4 bytes)"
      present: "bit 0 | P"
      writable: "bit 1 | R/W"
      user: "bit 2 | U/S"
      accessed: "bit 5 | A"
      dirty: "bit 6 | D"
      frame_addr: "bits 12-31 | 4KB aligned"
    }
    virt_addr: {
      shape: sql_table
      label: "Virtual Address Decomposition"
      pd_index: "bits 31-22 | 10 bits"
      pt_index: "bits 21-12 | 10 bits"
      offset: "bits 11-0 | 12 bits"
      coverage: "PD: 4GB, PT: 4MB, Page: 4KB"
    }
    vmm_funcs: {
      shape: class
      label: "vmm.c — Functions"
      +vmm_init: "void | identity map, enable paging"
      +vmm_map_page: "void (uint32_t virt, uint32_t phys, uint32_t flags)"
      +vmm_unmap_page: "void (uint32_t virt)"
      +vmm_get_physical: "uint32_t (uint32_t virt)"
      +vmm_flush_tlb: "void (uint32_t virt) | invlpg"
      +vmm_flush_tlb_all: "void | reload CR3"
    }
  }
  layer_kheap: {
    direction: down
    label: "KERNEL HEAP  [M3]"
    block_header: {
      shape: sql_table
      label: "block_header_t (12 bytes)"
      size: "uint32_t | data area size"
      free: "uint8_t | 1=free, 0=allocated"
      magic: "uint8_t | 0xA1 alloc, 0xF1 free"
      _pad: "uint8_t[2] | alignment"
      next: "block_header_t* | free list"
    }
    heap_state: {
      shape: sql_table
      label: "kheap.c — State"
      heap_start: "uint8_t* | 0xC0400000"
      heap_end: "uint8_t* | current end"
      heap_max: "uint8_t* | 16MB limit"
      free_list: "block_header_t* | head"
    }
    kheap_funcs: {
      shape: class
      label: "kheap.c — Functions"
      +kheap_init: "void | initial 1MB"
      +kmalloc: "void* (uint32_t size) | align 8"
      +kfree: "void (void* ptr)"
      -find_free_block: "block_header_t* (uint32_t size)"
      -split_block: "void (block_header_t*, uint32_t)"
      -expand_heap: "void (uint32_t min_size)"
    }
  }
}
row_process: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  layer_pcb: {
    direction: down
    label: "PROCESS CONTROL BLOCK  [M4]"
    pcb_struct: {
      shape: sql_table
      label: "process_t (112 bytes) — process.h"
      pid: "uint32_t | offset 0x00"
      name: "char[32] | offset 0x04"
      state: "process_state_t | offset 0x24"
      priority: "uint32_t | offset 0x28"
      time_slice: "uint32_t | offset 0x2C"
      eax_ebx_ecx_edx: "uint32_t | 0x30-0x3C"
      esi_edi_ebp_esp: "uint32_t | 0x40-0x4C"
      eip: "uint32_t | offset 0x50"
      eflags: "uint32_t | offset 0x54"
      page_directory: "uint32_t | offset 0x58"
      kernel_stack: "uint32_t | offset 0x5C"
      user_stack: "uint32_t | offset 0x60"
      next_prev: "process_t* | 0x68-0x6C"
    }
    pcb_funcs: {
      shape: class
      label: "process.c — Functions"
      +process_init: "void"
      +process_create: "process_t* (const char* name, void* entry, bool user)"
      +process_terminate: "void (process_t* proc)"
      +process_get_current: "process_t*"
      +process_get_by_pid: "process_t* (uint32_t pid)"
    }
  }
  layer_tss: {
    direction: down
    label: "TASK STATE SEGMENT  [M4]"
    tss_struct: {
      shape: sql_table
      label: "tss_t (104 bytes) — tss.h"
      link: "uint16_t + pad | 0x00"
      esp0: "uint32_t | 0x04 ★ kernel stack"
      ss0: "uint16_t + pad | 0x08 = 0x10"
      esp1_ss1: "uint32_t + uint16_t | unused"
      esp2_ss2: "uint32_t + uint16_t | unused"
      cr3_eip_eflags: "uint32_t | 0x1C-0x24"
      eax_ecx_edx_ebx: "uint32_t | 0x28-0x34"
      esp_ebp_esi_edi: "uint32_t | 0x38-0x44"
      es_cs_ss_ds: "uint16_t + pad | 0x48-0x54"
      fs_gs_ldtr: "uint16_t + pad | 0x58-0x60"
      iomap_base: "uint16_t | 0x64 = 104"
    }
    tss_funcs: {
      shape: class
      label: "tss.c — Functions"
      +tss_init: "void | GDT index 5, TR=0x28"
      +tss_update_esp0: "void (uint32_t esp0)"
    }
  }
  layer_scheduler: {
    direction: down
    label: "SCHEDULER  [M4]"
    scheduler_state: {
      shape: sql_table
      label: "scheduler.c — State"
      ready_queue: "process_t* | circular list"
      current: "process_t* | running process"
      tick_count: "uint32_t | total ticks"
    }
    scheduler_funcs: {
      shape: class
      label: "scheduler.c — Functions"
      +scheduler_init: "void"
      +scheduler_add: "void (process_t* proc)"
      +scheduler_remove: "void (process_t* proc)"
      +scheduler_tick: "void (registers_t* regs)"
      +scheduler_yield: "void"
      +scheduler_block: "void (process_t* proc)"
      +scheduler_unblock: "void (process_t* proc)"
    }
    context_switch: {
      shape: class
      label: "context_switch.asm"
      args: "old: process_t*, new: process_t*"
      save: "EBX,ECX,EDX,ESI,EDI,EBP,ESP,EIP,EFLAGS"
      load_cr3: "if new->page_directory != 0"
      update_tss: "TSS.ESP0 = new->kernel_stack"
      restore: "all registers, ret to new->eip"
    }
  }
  layer_syscall: {
    direction: down
    label: "SYSTEM CALLS  [M4]"
    syscall_nums: {
      shape: sql_table
      label: "System Call Numbers"
      sys_exit: "0 | terminate process"
      sys_read: "1 | read from fd"
      sys_write: "2 | write to fd"
      sys_yield: "3 | voluntary yield"
      sys_getpid: "4 | get process ID"
    }
    syscall_iface: {
      shape: sql_table
      label: "INT 0x80 Interface"
      eax: "syscall number"
      ebx: "arg1"
      ecx: "arg2"
      edx: "arg3"
      return: "eax = result"
      idt_gate: "0xEE | DPL=3"
    }
    syscall_funcs: {
      shape: class
      label: "syscall.c — Functions"
      +syscall_init: "void | IDT entry 0x80"
      +syscall_handler: "void (registers_t* regs)"
      +sys_exit: "int (int status)"
      +sys_write: "int (int fd, const char* buf, int count)"
      +sys_read: "int (int fd, char* buf, int count)"
      +sys_yield: "int"
      +sys_getpid: "int"
    }
  }
}
row_usermode: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  label: "USER MODE TRANSITION  [M4]"
  iret_stack: {
    shape: sql_table
    label: "iret Stack Frame"
    ss: "0x23 | user data | RPL=3"
    esp: "user_stack | top of user stack"
    eflags: "0x202 | IF=1"
    cs: "0x1B | user code | RPL=3"
    eip: "entry_point | process start"
  }
  usermode_funcs: {
    shape: class
    label: "usermode.c"
    +jump_to_user_mode: "void (uint32_t entry, uint32_t stack)"
    sequence: "cli; load 0x23; push frame; iret"
  }
}
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | build-os-m1 | Bootloader, GDT, Kernel Entry"
  m2: "M2 | build-os-m2 | Interrupts, Exceptions, Keyboard"
  m3: "M3 | build-os-m3 | Physical/Virtual Memory, Heap"
  m4: "M4 | build-os-m4 | Processes, Preemptive Scheduling"
}
connections: {
  boot_flow: boot_asm -> entry_asm: "jmp 0x08:0x100000"
  entry_to_main: entry_asm -> kprintf_funcs: "call kernel_main"
  vga_serial: vga_funcs -> serial_funcs: "kprintf outputs to both"
  irq_routing: pic_init_seq -> idt_funcs: "IRQs → vectors 32-47"
  timer_irq: timer_funcs -> pic_funcs: "IRQ0 | vector 32"
  kb_irq: kb_funcs -> pic_funcs: "IRQ1 | vector 33"
  pmm_to_vmm: pmm_funcs -> vmm_funcs: "pmm_alloc_frame() for page tables"
  vmm_to_kheap: vmm_funcs -> kheap_funcs: "vmm_map_page for heap expansion"
  process_to_pmm: pcb_funcs -> pmm_funcs: "allocate PCB, stacks, page dir"
  scheduler_to_switch: scheduler_funcs -> context_switch: "context_switch(old, new)"
  switch_to_tss: context_switch -> tss_funcs: "update TSS.ESP0"
  user_to_syscall: iret_stack -> syscall_iface: "int 0x80 from Ring 3"
  syscall_to_process: syscall_funcs -> pcb_funcs: "get current_process"
}