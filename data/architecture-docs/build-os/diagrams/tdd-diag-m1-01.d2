vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
  colors: {
    success: "#2E7D32"
    failure: "#C62828"
    warning: "#E65100"
    active: "#1565C0"
    neutral: "#455A64"
    bg_success: "#E8F5E9"
    bg_active: "#E3F2FD"
    bg_failure: "#FFEBEE"
    bg_warning: "#FFF3E0"
  }
}

title: |md
  # x86 Boot Sequence State Machine
  **From Power-On Reset to 32-bit Protected Mode Kernel Entry**
  *Technical Specification: Real Mode -> Protected Mode Transition*
| {near: top-center}

classes: {
  state: {
    shape: rectangle
    style: {
      stroke-width: 2
      font-size: 16
      border-radius: 4
      shadow: true
    }
  }
  success_state: {
    shape: rectangle
    style: {
      stroke-width: 2
      font-size: 16
      border-radius: 4
      shadow: true
      fill: ${colors.bg_success}
      stroke: ${colors.success}
      font-color: ${colors.success}
    }
  }
  active_state: {
    shape: rectangle
    style: {
      stroke-width: 3
      font-size: 16
      border-radius: 4
      shadow: true
      fill: ${colors.bg_active}
      stroke: ${colors.active}
      font-color: ${colors.active}
      bold: true
    }
  }
  failure_state: {
    shape: rectangle
    style: {
      stroke-width: 2
      font-size: 16
      border-radius: 4
      shadow: true
      fill: ${colors.bg_failure}
      stroke: ${colors.failure}
      font-color: ${colors.failure}
      font: mono
    }
  }
  terminal: {
    shape: circle
    style: {
      stroke-width: 3
    }
  }
  transition: {
    style: {
      stroke-width: 2
      font-size: 11
      animated: false
    }
  }
  failure_transition: {
    style: {
      stroke-width: 2
      font-size: 11
      stroke: ${colors.failure}
      stroke-dash: 4
    }
  }
  success_transition: {
    style: {
      stroke-width: 2
      font-size: 11
      stroke: ${colors.success}
    }
  }
  critical_transition: {
    style: {
      stroke-width: 3
      font-size: 12
      stroke: ${colors.warning}
      bold: true
      animated: true
    }
  }
}

# -----------------------------------------------------------------------------
# States
# -----------------------------------------------------------------------------

power_on: ● {
  class: terminal
  style.fill: ${colors.success}
  style.stroke: ${colors.success}
  label: ""
}

bios_post: "BIOS POST\n(Power-On Self-Test)" {
  class: success_state
  tooltip: |md
    **CPU Initial State:**
    - EIP: 0xFFF0, CS: 0xF000 (Physical: 0xFFFF0)
    - Hardware discovery (PCI, USB)
    - Interrupt Vector Table (IVT) setup at 0x0000
    - Searches CMOS/NVRAM for boot order
  |
}

mbr_load: "MBR Load\n(Physical 0x7C00)" {
  class: success_state
  tooltip: |md
    **BIOS INT 13h Operation:**
    - Loads first 512-byte sector to memory
    - Destination: 0x0000:0x7C00
    - Validates signature 0x55, 0xAA at offset 510
  |
}

bootloader_exec: "Stage 1\nBootloader" {
  class: active_state
  tooltip: |md
    **Environment: 16-bit Real Mode**
    - CS:IP = 0x0000:0x7C00
    - DL = Boot Drive ID
    - Stack (SS:SP) must be manually configured
    - 1 MB addressable limit (20-bit)
  |
}

a20_enable: "A20 Line\nEnablement" {
  class: success_state
  tooltip: |md
    **Memory Access Above 1MB:**
    1. BIOS INT 15h, ax=2401h
    2. Keyboard Controller (Port 0x64/0x60)
    3. Fast A20 (Port 0x92 bit 1)
  |
}

gdt_load: "GDT Definition\n& Load (LGDT)" {
  class: success_state
  tooltip: |md
    **Global Descriptor Table:**
    - Define Null, Code, Data segments
    - Base: 0x0, Limit: 0xFFFFF, G=1 (4KB granularity)
    - Load GDTR with pointer to descriptor
  |
}

cr0_pe_set: "CR0.PE = 1\n(Enter Protected Mode)" {
  class: active_state
  style.fill: ${colors.bg_warning}
  style.stroke: ${colors.warning}
  style.font-color: ${colors.warning}
  tooltip: |md
    **Protection Enable Bit:**
    - cli (Clear Interrupts)
    - mov eax, cr0; or eax, 1; mov cr0, eax
    - **CRITICAL:** CPU is in 32-bit mode, but CS still points to 16-bit segment
  |
}

far_jump: "Far Jump\n(flush pipeline)" {
  class: active_state
  tooltip: |md
    **Instruction Synchronization:**
    - jmp 0x08:PM_ENTRY
    - 0x08 = Selector for Code Segment in GDT
    - Flushes instruction prefetch/pipeline
    - Serializes CPU state
  |
}

protected_mode: "32-bit Protected Mode\nEnvironment" {
  class: success_state
  style.fill: "#C8E6C9"
  style.bold: true
  tooltip: |md
    **Hardware Context:**
    - 32-bit registers (EAX, ESP, etc.)
    - Segment Registers (DS, ES, SS) = 0x10 (Data Selector)
    - Full 4GB address space access
  |
}

kernel_entry: "Kernel Entry\n(kmain)" {
  class: success_state
  style.fill: "#A5D6A7"
  style.bold: true
  tooltip: |md
    **High-Level Language Entry:**
    - Stack pointer (ESP) pointing to safe RAM
    - GDT/IDT finalized
    - C/C++ global constructors called (if applicable)
  |
}

# -----------------------------------------------------------------------------
# Failure States
# -----------------------------------------------------------------------------

triple_fault: "TRIPLE FAULT\n(CPU RESET)" {
  class: failure_state
  tooltip: |md
    **Fatal Exception Chain:**
    - Double fault fails to be handled
    - CPU enters shutdown cycle
    - Result: Instant hardware reboot
  |
}

a20_failed: "A20 FAIL\n(Halt)" {
  class: failure_state
  tooltip: "Memory wraparound test failed. Cannot address > 1MB."
}

disk_error: "DISK READ ERROR\n(Halt)" {
  class: failure_state
  tooltip: "BIOS INT 13h returned CF=1 or invalid MBR signature."
}

running: "●" {
  class: terminal
  style.fill: ${colors.success}
  style.stroke: ${colors.success}
  label: "OS KERNEL RUNNING"
}

# -----------------------------------------------------------------------------
# Transitions
# -----------------------------------------------------------------------------

power_on -> bios_post: "RESET Vector\n0xFFFF0" {class: success_transition}

bios_post -> mbr_load: "Check Boot Device" {class: success_transition}
bios_post -> disk_error: "No bootable media" {class: failure_transition}

mbr_load -> bootloader_exec: "Verify [510]==0x55\n[511]==0xAA" {class: success_transition}
mbr_load -> disk_error: "Invalid signature" {class: failure_transition}

bootloader_exec -> a20_enable: "Load Kernel Sectors\nInitialize Segments" {class: success_transition}
bootloader_exec -> disk_error: "INT 13h Failure" {class: failure_transition}

a20_enable -> gdt_load: "Wraparound Test\nSucceeded" {class: success_transition}
a20_enable -> a20_failed: "All 3 methods fail" {class: failure_transition}

gdt_load -> cr0_pe_set: "LGDT [Pointer]\nCLI (Disable IRQs)" {class: success_transition}
gdt_load -> triple_fault: "Bad GDT Pointer" {class: failure_transition}

cr0_pe_set -> far_jump: "CR0 |= 0x01" {class: critical_transition}
cr0_pe_set -> triple_fault: "No Far Jump\n(Instruction Sync Error)" {class: failure_transition}

far_jump -> protected_mode: "Reload CS Register\n(Selector 0x08)" {class: success_transition}
far_jump -> triple_fault: "Invalid Code Segment\n(GPF Exception)" {class: failure_transition}

protected_mode -> kernel_entry: "Setup Stack\nZero BSS" {class: success_transition}

kernel_entry -> running: "Transfer Control" {class: success_transition}

# -----------------------------------------------------------------------------
# Annotations & Legend
# -----------------------------------------------------------------------------

legend: {
  near: bottom-left
  style.stroke: ${colors.neutral}
  
  l1: "Success Path" {
    shape: text
    style.font-color: ${colors.success}
  }
  l1_line: "" {
    style.stroke: ${colors.success}
    style.stroke-width: 2
  }
  
  l2: "Failure/Illegal" {
    shape: text
    style.font-color: ${colors.failure}
  }
  l2_line: "" {
    style.stroke: ${colors.failure}
    style.stroke-dash: 4
  }
  
  l3: "Critical Sync" {
    shape: text
    style.font-color: ${colors.warning}
  }
  l3_line: "" {
    style.stroke: ${colors.warning}
    style.stroke-width: 3
  }
  
  l1_line -> l1
  l2_line -> l2
  l3_line -> l3
}

# Fixed: Using layout constants for 'near' as ELK does not support object-relative positioning
note_real: |md
  ### Phase 1: Real Mode
  - 16-bit addressing
  - 1MB Segment:Offset
  - BIOS interrupts available
| {
  near: top-left
  shape: text
  style.font-color: ${colors.neutral}
}

note_prot: |md
  ### Phase 2: Protected Mode
  - 32-bit registers
  - GDT Memory Protection
  - Flat 4GB Memory Space
| {
  near: top-right
  shape: text
  style.font-color: ${colors.neutral}
}