vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
# GDT Entry Bit Layout (8 bytes)
Decoding kernel code (`0x00CF9A000000FFFF`) and kernel data (`0x00CF92000000FFFF`)
  '|
  near: top-center
}

direction: right

# Main GDT Layout (Memory Offset Representation)
gdt_entry: {
  label: "Global Descriptor Table Entry (64-bit)"
  grid-rows: 1
  grid-columns: 8
  grid-gap: 0

  b7: {
    label: |'md
**Byte 7**
Base [31:24]
    '|
    style.fill: "#E8D5E0"
  }
  b6: {
    label: |'md
**Byte 6**
Flags | Limit [19:16]
    '|
    style.fill: "#D5E8D4"
  }
  b5: {
    label: |'md
**Byte 5**
Access Byte
    '|
    style.fill: "#FFE6CC"
  }
  b4: {
    label: |'md
**Byte 4**
Base [23:16]
    '|
    style.fill: "#E8D5E0"
  }
  b3: {
    label: |'md
**Byte 3**
Base [15:8]
    '|
    style.fill: "#E8D5E0"
  }
  b2: {
    label: |'md
**Byte 2**
Base [7:0]
    '|
    style.fill: "#E8D5E0"
  }
  b1: {
    label: |'md
**Byte 1**
Limit [15:8]
    '|
    style.fill: "#DAE8FC"
  }
  b0: {
    label: |'md
**Byte 0**
Limit [7:0]
    '|
    style.fill: "#DAE8FC"
  }
}

# Bit-level expansion of control bytes
details: {
  grid-columns: 1
  
  byte6_detail: {
    label: "Byte 6: Control Flags & Limit (High)"
    grid-columns: 8
    grid-gap: 0
    
    g: { label: "**G**\nGran."; style.fill: "#D5E8D4" }
    db: { label: "**D/B**\nSize"; style.fill: "#D5E8D4" }
    l: { label: "**L**\nLong"; style.fill: "#D5E8D4" }
    avl: { label: "**AVL**\nAvail"; style.fill: "#D5E8D4" }
    lim19: { label: "**Lim**\nbit 19"; style.fill: "#DAE8FC" }
    lim18: { label: "**Lim**\nbit 18"; style.fill: "#DAE8FC" }
    lim17: { label: "**Lim**\nbit 17"; style.fill: "#DAE8FC" }
    lim16: { label: "**Lim**\nbit 16"; style.fill: "#DAE8FC" }
  }

  byte5_detail: {
    label: "Byte 5: Access Byte"
    grid-columns: 8
    grid-gap: 0
    
    p: { label: "**P**\nPres."; style.fill: "#F8CECC" }
    dpl1: { label: "**DPL**\nbit 1"; style.fill: "#FFF2CC" }
    dpl0: { label: "**DPL**\nbit 0"; style.fill: "#FFF2CC" }
    s: { label: "**S**\nSys"; style.fill: "#E1D5E7" }
    t3: { label: "**Type**\nbit 3"; style.fill: "#FFE6CC" }
    t2: { label: "**Type**\nbit 2"; style.fill: "#FFE6CC" }
    t1: { label: "**Type**\nbit 1"; style.fill: "#FFE6CC" }
    t0: { label: "**Type**\nbit 0"; style.fill: "#FFE6CC" }
  }
}

# Concrete Implementation Examples
examples: {
  grid-columns: 2
  
  kernel_code: {
    label: "Kernel Code Descriptor"
    raw: {
      label: |'md
**Value:** `0x00CF9A000000FFFF`

| Byte | Val | Field |
|---|---|---|
| 0-1 | FFFF | Limit [15:0] |
| 2-4 | 000000 | Base [23:0] |
| 5 | 9A | Access (P:1, DPL:0, S:1, Type:10) |
| 6 | CF | Flags (G:1, D:1, L:0, AVL:0) |
| 7 | 00 | Base [31:24] |
      '|
    }
    decode: {
      label: |'md
**Decoded State:**
- **Base:** `0x00000000`
- **Limit:** `0xFFFFF` (4GB via G=1)
- **Type:** Execute/Read
- **Privilege:** Ring 0
      '|
    }
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }

  kernel_data: {
    label: "Kernel Data Descriptor"
    raw: {
      label: |'md
**Value:** `0x00CF92000000FFFF`

**Access Byte 0x92 (10010010):**
- P=1 (Present)
- DPL=00 (Kernel)
- S=1 (Code/Data)
- Type=2 (Data Read/Write)
      '|
    }
    decode: {
      label: |'md
**Decoded State:**
- **Base:** `0x00000000`
- **Limit:** `4GB`
- **Type:** Data R/W
- **Granularity:** Page (4KB)
      '|
    }
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}

legend: {
  label: Legend
  grid-columns: 2
  base_color: "Base Address Bits" { style.fill: "#E8D5E0" }
  limit_color: "Segment Limit Bits" { style.fill: "#DAE8FC" }
  access_color: "Access Control" { style.fill: "#FFE6CC" }
  flags_color: "Attribute Flags" { style.fill: "#D5E8D4" }
  dpl_color: "Privilege (DPL)" { style.fill: "#FFF2CC" }
  sys_color: "System Flag" { style.fill: "#E1D5E7" }
}

# Internal Connections
gdt_entry.b6 -> details.byte6_detail: "Expansion"
gdt_entry.b5 -> details.byte5_detail: "Expansion"

examples.kernel_code -> examples.kernel_data: "GDT Memory Order" {
  style.stroke-dash: 3
}