vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: {
  shape: text
  label: |'md
# x86 Global Descriptor Table (GDT)
## Memory Segmentation & Protection Architecture
  '|
  near: top-center
}

direction: right

classes: {
  segment-desc: {
    shape: class
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 4
    }
  }
  kernel-seg: {
    style: {
      fill: "#DBEAFE"
      stroke: "#1D4ED8"
      bold: true
    }
  }
  user-seg: {
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      bold: true
    }
  }
  tss-desc: {
    style: {
      fill: "#F3E8FF"
      stroke: "#7C3AED"
    }
  }
  selector-box: {
    shape: class
    style: {
      fill: "#F1F5F9"
      stroke: "#64748B"
    }
  }
}

GDT_Container: "Global Descriptor Table (GDT)" {
  style: {
    fill: "#F8FAFC"
    stroke: "#334155"
    stroke-width: 2
    shadow: true
  }
  
  tooltip: "sizeof = N * 8 bytes"

  Entry_0: "Null Descriptor" {
    class: segment-desc
    label: "Offset 0x00: Null Descriptor (8 Bytes)"
    data: "0x0000000000000000"
  }

  Entry_1: "Kernel Code" {
    class: [segment-desc; kernel-seg]
    label: "Offset 0x08: Kernel Code Segment"
    base: "0x00000000 (32-bit)"
    limit: "0xFFFFF (G=1 -> 4GB)"
    access: "0x9A (P=1, DPL=0, Code)"
    flags: "0xC (L=0, DB=1, G=1)"
  }

  Entry_2: "Kernel Data" {
    class: [segment-desc; kernel-seg]
    label: "Offset 0x10: Kernel Data Segment"
    base: "0x00000000"
    limit: "0xFFFFF"
    access: "0x92 (P=1, DPL=0, Data)"
    flags: "0xC"
  }

  Entry_3: "User Code" {
    class: [segment-desc; user-seg]
    label: "Offset 0x18: User Code Segment"
    base: "0x00000000"
    limit: "0xFFFFF"
    access: "0xFA (P=1, DPL=3, Code)"
    flags: "0xC"
  }

  Entry_4: "User Data" {
    class: [segment-desc; user-seg]
    label: "Offset 0x20: User Data Segment"
    base: "0x00000000"
    limit: "0xFFFFF"
    access: "0xF2 (P=1, DPL=3, Data)"
    flags: "0xC"
  }

  Entry_5: "TSS" {
    class: [segment-desc; tss-desc]
    label: "Offset 0x28: Task State Segment"
    base: "TSS_ADDR"
    limit: "0x0067 (104 Bytes)"
    access: "0x89 (P=1, DPL=0, TSS32)"
  }

  Entry_0 -> Entry_1 -> Entry_2 -> Entry_3 -> Entry_4 -> Entry_5: {
    style: {
      stroke-width: 0
    }
  }
}

Selector_Logic: {
  Selector_Format: "Segment Selector (16-bit)" {
    class: selector-box
    bits_15_3: "Index (13-bits)"
    bit_2: "TI (0=GDT, 1=LDT)"
    bits_1_0: "RPL (Privilege Level)"
  }

  Calculation: {
    shape: text
    label: |'md
### Selector Calculation
`Selector = (Index << 3) | RPL`
    '|
    style.fill: "#FFFBEB"
  }

  Selector_Format -> Calculation
}

Values: "Selector Values" {
  grid-columns: 1
  style.fill: transparent
  
  K_CS: "0x08 (Idx: 1, RPL: 0)" { class: kernel-seg }
  K_DS: "0x10 (Idx: 2, RPL: 0)" { class: kernel-seg }
  U_CS: "0x1B (Idx: 3, RPL: 3)" { class: user-seg }
  U_DS: "0x23 (Idx: 4, RPL: 3)" { class: user-seg }
  TSS_S: "0x28 (Idx: 5, RPL: 0)" { class: tss-desc }
}

GDT_Container.Entry_1 -> Values.K_CS: "Selector Mapping"
GDT_Container.Entry_2 -> Values.K_DS
GDT_Container.Entry_3 -> Values.U_CS
GDT_Container.Entry_4 -> Values.U_DS
GDT_Container.Entry_5 -> Values.TSS_S

Access_Byte_Detail: {
  style.fill: "#F5F3FF"
  style.stroke: "#6D28D9"
  
  label: |'md
### Access Byte Bitfields
| Bit | Name | Description |
| :--- | :--- | :--- |
| 7 | **P** | Present (must be 1 for valid) |
| 6-5 | **DPL** | Descriptor Privilege Level (0-3) |
| 4 | **S** | Descriptor Type (0=System, 1=Code/Data) |
| 3 | **E** | Executable (1=Code, 0=Data) |
| 2 | **DC** | Direction/Conforming |
| 1 | **RW** | Readable/Writeable |
| 0 | **A** | Accessed bit |
  '|
}

Access_Byte_Detail -> GDT_Container.Entry_1: "Type: 0x9A" {
  style.stroke-dash: 3
}
Access_Byte_Detail -> GDT_Container.Entry_3: "Type: 0xFA" {
  style.stroke-dash: 3
}

Privilege: "Protection Rings" {
  Ring0: "Ring 0 (Kernel)" {
    shape: circle
    style.fill: "#DBEAFE"
  }
  Ring3: "Ring 3 (User)" {
    shape: circle
    style.fill: "#FEF3C7"
  }
  
  Ring0 -> Ring3: "SYSRET / IRET"
  Ring3 -> Ring0: "SYSCALL / INT"
}

Values.K_CS -> Privilege.Ring0
Values.U_CS -> Privilege.Ring3

Legend: {
  near: bottom-right
  K: "Kernel Segment" { 
    class: kernel-seg 
  }
  U: "User Segment" { 
    class: user-seg 
  }
  S: "System Segment" { 
    class: tss-desc 
  }
}