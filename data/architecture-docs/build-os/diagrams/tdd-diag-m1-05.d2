vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Protected Mode Entry Sequence
  Critical steps from real mode (16-bit) to protected mode (32-bit)
|
shape: sequence_diagram
# Participants
CPU: CPU
CR0: CR0 Register
GDTR: GDTR Register
CS: CS Register
DS_ES_FS_GS_SS: DS,ES,FS,GS,SS
ESP: ESP Register
Pipeline: Pipeline
# Step 1: Disable Interrupts
CPU -> CPU: "cli"
CPU."Disable interrupts (IDT invalid in PM)"
# Step 2: Load GDT
CPU -> GDTR: "lgdt [gdt_descriptor]"
GDTR."Load GDT base and limit"
# Step 3: Set PE bit
CPU -> CR0: "mov eax, cr0\nor eax, 1\nmov cr0, eax"
CR0."PE bit set = Protected Mode enabled"
# Step 4: Far Jump (CRITICAL)
CPU -> CS: "jmp 0x08:protected_entry"
CS."Load CS with 32-bit selector\nFlush pipeline\nBegin 32-bit decoding"
# Step 5: Load Data Segments
CPU -> DS_ES_FS_GS_SS: "mov ax, 0x10\nmov ds, ax\nmov es, ax\nmov fs, ax\nmov gs, ax\nmov ss, ax"
DS_ES_FS_GS_SS."All data segments = kernel data"
# Step 6: Set Stack
CPU -> ESP: "mov esp, 0x90000"
ESP."32-bit stack pointer set"
# Success
CPU."=== PROTECTED MODE ACTIVE ==="
# Failure scenarios
skip_far_jump: {
  CPU_skip: CPU
  CR0_skip: CR0
  CPU_skip -> CR0_skip: "mov cr0, eax (PE set)"
  CR0_skip."CS still has 16-bit real mode value!"
  CR0_skip -> CPU_skip: "Next instruction fetched with wrong descriptor"
  CPU_skip."*** TRIPLE FAULT ***"
  CPU_skip."Pipeline has 16-bit code\nbut CPU expects 32-bit"
}
skip_segment_load: {
  CPU_seg: CPU
  DS_seg: DS
  CPU_seg -> DS_seg: "(skip loading DS)"
  DS_seg."DS still = real mode value (0x0000)"
  DS_seg -> CPU_seg: "Any memory access uses wrong segment"
  CPU_seg."*** GENERAL PROTECTION FAULT ***\nor memory corruption"
}
skip_cli: {
  CPU_int: CPU
  CPU_int."Interrupts still enabled"
  CPU_int -> CPU_int: "IRQ fires during mode switch"
  CPU_int."*** TRIPLE FAULT ***\nNo valid IDT in protected mode"
}