vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    method1: "#3B82F6"
    method2: "#10B981"
    method3: "#F59E0B"
    test: "#EF4444"
    success: "#22C55E"
    error: "#DC2626"
  }
}
title: |md
  # A20 Line Enable Methods
  Three fallback strategies to enable memory addressing above 1MB
| {near: top-center}
direction: right
methods_container: {
  method1_bios: {
    label: "Method 1: BIOS INT 15h\n(Safest)"
    style.fill: "${colors.method1}"
    style.font-color: white
    style.stroke: "#1E40AF"
    step1_1: "mov ax, 0x2401" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step1_2: "int 0x15" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step1_3: "jc .try_fast_a20" {
      shape: diamond
      style.fill: "#FEF3C7"
    }
    step1_1 -> step1_2 -> step1_3
    step1_3 -> call_test: "CF=0"
    step1_3 -> method2_start: "CF=1\n(Failed)" {
      style.stroke: "${colors.error}"
      style.stroke-dash: 3
    }
  }
  method2_port: {
    label: "Method 2: Fast A20\n(Port 0x92)"
    style.fill: "${colors.method2}"
    style.font-color: white
    style.stroke: "#047857"
    step2_1: "in al, 0x92" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step2_2: "test al, 2\n(Already enabled?)" {
      shape: diamond
      style.fill: "#FEF3C7"
    }
    step2_3: "or al, 2\nand al, 0xFE" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step2_4: "out 0x92, al" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step2_1 -> step2_2
    step2_2 -> call_test: "Yes" {
      style.stroke: "${colors.success}"
    }
    step2_2 -> step2_3: "No"
    step2_3 -> step2_4 -> call_test
  }
  method3_kbd: {
    label: "Method 3: Keyboard Controller\n(8042 - Slow but Reliable)"
    style.fill: "${colors.method3}"
    style.font-color: white
    style.stroke: "#B45309"
    step3_1: "Wait for input\nbuffer empty" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step3_2: "out 0x64, 0xD0\n(Read output port)" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step3_3: "Read current\nvalue from 0x60" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step3_4: "or al, 2\n(Set A20 bit)" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step3_5: "out 0x64, 0xD1\n(Write output port)" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step3_6: "out 0x60, al" {
      shape: rectangle
      style.fill: white
      style.font-color: black
    }
    step3_1 -> step3_2 -> step3_3 -> step3_4 -> step3_5 -> step3_6 -> call_test
  }
  method2_start: method2_port
}
test_section: {
  call_test: "test_a20()" {
    shape: hexagon
    style.fill: "${colors.test}"
    style.font-color: white
  }
  test_detail: {
    label: |md
      **Wraparound Test:**
      - Write to 0x0000:0x0500
      - Write to 0xFFFF:0x0510
      - If values match → A20 disabled
      - If different → A20 enabled
    |
    shape: rectangle
    style.fill: "#F3F4F6"
    style.stroke: "#9CA3AF"
  }
  a20_enabled: "A20 Enabled ✓\nContinue boot" {
    shape: rectangle
    style.fill: "${colors.success}"
    style.font-color: white
  }
  a20_failed: "HALT:\nAll methods failed" {
    shape: rectangle
    style.fill: "${colors.error}"
    style.font-color: white
  }
  call_test -> test_detail
  test_detail -> a20_enabled: "Test passes"
  test_detail -> a20_failed: "All methods fail"
}
method2_start -> method3_kbd: "Test fails" {
  style.stroke: "${colors.error}"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  label: |md
    **Port Reference:**
    - 0x60: Keyboard data
    - 0x64: Keyboard command
    - 0x92: System Control Port A
  |
  shape: rectangle
  style.fill: "#F9FAFB"
  style.stroke: "#E5E7EB"
  style.stroke-dash: 2
}