vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # VGA Text Mode Buffer Structure
  **Memory-mapped I/O (MMIO) at 0xB8000**
| {near: top-center}

direction: right

# --- OVERVIEW SECTION ---
buffer_overview: {
  label: "VGA Buffer (CGA Compatible Mode)"
  shape: cylinder
  style.fill: "#E8D4F8"
  style.stroke: "#7B4B94"
  style.stroke-width: 3
  
  description: |md
    - **Physical Start:** 0xB8000
    - **End Address:** 0xB8F9F
    - **Resolution:** 80 columns × 25 rows
    - **Cell Count:** 2,000 characters
    - **Total Size:** 4,000 bytes (0x0FA0)
  |
}

# --- MEMORY LAYOUT SECTION ---
buffer_layout: {
  label: "Buffer Memory Segmentation"
  
  grid-columns: 1
  grid-gap: 0

  header: {
    label: "Physical Address: 0xB8000"
    style.fill: "#E8D4F8"
    style.bold: true
    style.stroke-width: 2
  }

  row0: {
    label: "Row 0 [Offset +0x000] - 160 Bytes"
    style.fill: "#E6F3FF"
    style.stroke: "#2E6B99"
  }
  
  row1: {
    label: "Row 1 [Offset +0x0A0] - 160 Bytes"
    style.fill: "#B3D9FF"
    style.stroke: "#2E6B99"
  }
  
  row2: {
    label: "Row 2 [Offset +0x140] - 160 Bytes"
    style.fill: "#E6F3FF"
    style.stroke: "#2E6B99"
  }
  
  ellipsis: {
    label: "..."
    style.fill: white
    style.stroke-dash: 3
  }
  
  row24: {
    label: "Row 24 [Offset +0xF00] - 160 Bytes"
    style.fill: "#B3D9FF"
    style.stroke: "#2E6B99"
  }

  formula_box: |'md
    ### Address Mapping (Row/Col)
    c
    // Calculate cell index (0 - 1999)
    uint32_t index = (y * 80) + x;
    
    // Calculate byte offset (0 - 3998)
    uint32_t offset = index * 2;
    
    // Access via uint16_t pointer
    uint16_t* vga = (uint16_t*)0xB8000;
    vga[index] = (attribute << 8) | character;
    
  '| {
    style.fill: "#FFF9E6"
    style.stroke: "#C9A227"
  }
}

# --- DETAILED CELL STRUCTURE ---
cell_structure: {
  label: "VGA Cell (16-bit Word)"
  style.fill: "#E6F3FF"
  style.stroke: "#2E6B99"
  style.double-border: true

  byte_0: {
    label: "Byte 0 (Offset +0)\nASCII Character Code"
    shape: rectangle
    style.fill: "#B3D9FF"
    style.stroke: "#2E6B99"
  }
  
  byte_1: {
    label: "Byte 1 (Offset +1)\nAttribute Byte (Colors)"
    shape: rectangle
    style.fill: "#FFF0E6"
    style.stroke: "#B35900"
  }
}

# --- ATTRIBUTE BYTE BIT-FIELD ---
attribute_byte: {
  label: "Attribute Byte (8-bit) Specification"
  style.fill: "#FFF0E6"
  style.stroke: "#B35900"

  bit_layout: {
    shape: class
    bit_7: "Bit 7: Blink (1) or BG Intensity (0)"
    bit_6_4: "Bits 6-4: Background Color (RGB)"
    bit_3: "Bit 3: Foreground Intensity (Bright)"
    bit_2_0: "Bits 2-0: Foreground Color (RGB)"
  }

  bit_map: |'md
    | Bit | 7 | 6 | 5 | 4 | 3 | 2 | 1 | 0 |
    | :--- | :---: | :---: | :---: | :---: | :---: | :---: | :---: | :---: |
    | **Function** | BLNK | BR | BG | BB | INT | FR | FG | FB |
    
    - **BLNK:** Blink (if enabled in Control Reg)
    - **INT:** Foreground Intensity (Bold)
    - **RGB:** Red, Green, Blue components
  '|

  example: |'md
    **Example: 0x1F (Bright White on Blue)**
    - Binary: `0001 1111`
    - Blink: 0
    - BG: 001 (Blue)
    - Intensity: 1 (Bright)
    - FG: 111 (White)
  '|
}

# --- VGA COLOR PALETTE ---
color_palette: {
  label: "Standard 16-Color Palette"
  grid-columns: 4
  grid-gap: 4
  
  c0: "0: Black" { style.fill: "#000000"; style.font-color: white }
  c1: "1: Blue" { style.fill: "#0000AA"; style.font-color: white }
  c2: "2: Green" { style.fill: "#00AA00"; style.font-color: white }
  c3: "3: Cyan" { style.fill: "#00AAAA"; style.font-color: white }
  
  c4: "4: Red" { style.fill: "#AA0000"; style.font-color: white }
  c5: "5: Magenta" { style.fill: "#AA00AA"; style.font-color: white }
  c6: "6: Brown" { style.fill: "#AA5500"; style.font-color: white }
  c7: "7: L-Grey" { style.fill: "#AAAAAA"; style.font-color: black }
  
  c8: "8: D-Grey" { style.fill: "#555555"; style.font-color: white }
  c9: "9: L-Blue" { style.fill: "#5555FF"; style.font-color: white }
  c10: "10: L-Green" { style.fill: "#55FF55"; style.font-color: black }
  c11: "11: L-Cyan" { style.fill: "#55FFFF"; style.font-color: black }
  
  c12: "12: L-Red" { style.fill: "#FF5555"; style.font-color: black }
  c13: "13: L-Mag" { style.fill: "#FF55FF"; style.font-color: black }
  c14: "14: Yellow" { style.fill: "#FFFF55"; style.font-color: black }
  c15: "15: White" { style.fill: "#FFFFFF"; style.font-color: black }
}

# --- CURSOR & CONTROL SECTION ---
cursor_tracking: {
  label: "Hardware Cursor Control"
  style.fill: "#E6FFE6"
  style.stroke: "#2E8B57"

  io_ports: {
    shape: class
    "0x3D4": "CRT Controller Index Port"
    "0x3D5": "CRT Controller Data Port"
    "Idx 0x0E": "Cursor Location High (8-bits)"
    "Idx 0x0F": "Cursor Location Low (8-bits)"
  }

  update_sequence: |'md
    ### Update Cursor Position
    asm
    ; pos is index (0-1999)
    mov dx, 03D4h
    mov al, 0Eh     ; High byte index
    out dx, al
    inc dx          ; Data port 03D5h
    mov al, bh      ; High byte of pos
    out dx, al
    
    mov dx, 03D4h
    mov al, 0Fh     ; Low byte index
    out dx, al
    inc dx
    mov al, bl      ; Low byte of pos
    out dx, al
    
  '|
}

# --- CONNECTIONS ---
buffer_overview -> buffer_layout: "MMIO Region"
buffer_layout.row0 -> cell_structure: "Cell Detail"
cell_structure.byte_1 -> attribute_byte: "Bit-fields"
attribute_byte -> color_palette: "Decodes to"
cursor_tracking -> buffer_layout: "Registers"

# --- LEGEND ---
legend: {
  near: bottom-right
  style.fill: "#F0F0F0"
  style.stroke: "#666"
  style.stroke-width: 1
  
  purple: "VGA Header" { style.fill: "#E8D4F8" }
  blue: "Memory Data" { style.fill: "#E6F3FF" }
  orange: "Attributes" { style.fill: "#FFF0E6" }
  green: "I/O Hardware" { style.fill: "#E6FFE6" }
}