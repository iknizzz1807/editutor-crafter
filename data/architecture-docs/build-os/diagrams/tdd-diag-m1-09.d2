vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    register: "#E8F4FD"
    data: "#D4EDDA"
    control: "#FFF3CD"
    status: "#F8D7DA"
    dlab: "#E2E3E5"
    highlight: "#FFD700"
    header: "#6F42C1"
    padding: "#6C757D"
  }
}

title: |'md
# Serial Port Register Map (COM1 @ 0x3F8)
## 8250/16550 UART Programming Interface Reference
'| {near: top-center}

direction: right

registers: {
  style.stroke-width: 2
  
  offset_0: "+0 (0x3F8)" {
    shape: rectangle
    style.fill: ${colors.data}
    tooltip: "Data / Divisor Low"
    
    RBR: "RBR (Read, DLAB=0)" {
      style.fill: ${colors.register}
      tooltip: "Receiver Buffer Register"
    }
    THR: "THR (Write, DLAB=0)" {
      style.fill: ${colors.register}
      tooltip: "Transmit Holding Register"
    }
    DLL: "DLL (R/W, DLAB=1)" {
      style.fill: ${colors.dlab}
      tooltip: "Divisor Latch Low Byte"
    }
  }

  offset_1: "+1 (0x3F9)" {
    shape: rectangle
    style.fill: ${colors.control}
    
    IER: "IER (DLAB=0)" {
      style.fill: ${colors.register}
      tooltip: "Interrupt Enable Register"
    }
    DLM: "DLM (DLAB=1)" {
      style.fill: ${colors.dlab}
      tooltip: "Divisor Latch High Byte"
    }
  }

  offset_2: "+2 (0x3FA)" {
    shape: rectangle
    style.fill: ${colors.control}
    
    IIR: "IIR (Read Only)" {
      style.fill: ${colors.register}
    }
    FCR: "FCR (Write Only)" {
      style.fill: ${colors.register}
    }
  }

  offset_3: "+3 (0x3FB)" {
    shape: rectangle
    style.fill: ${colors.control}
    LCR: "LCR (Line Control)" {
      style.fill: ${colors.register}
      style.stroke: ${colors.highlight}
      style.stroke-width: 4
    }
  }

  offset_4: "+4 (0x3FC)" {
    shape: rectangle
    style.fill: ${colors.control}
    MCR: "MCR (Modem Control)" {
      style.fill: ${colors.register}
    }
  }

  offset_5: "+5 (0x3FD)" {
    shape: rectangle
    style.fill: ${colors.status}
    LSR: "LSR (Line Status)" {
      style.fill: ${colors.register}
    }
  }

  offset_6: "+6 (0x3FE)" {
    shape: rectangle
    style.fill: ${colors.status}
    MSR: "MSR (Modem Status)" {
      style.fill: ${colors.register}
    }
  }

  offset_7: "+7 (0x3FF)" {
    shape: rectangle
    style.fill: ${colors.control}
    SCR: "SCR (Scratch)" {
      style.fill: ${colors.register}
    }
  }

  offset_0 -> offset_1 -> offset_2 -> offset_3 -> offset_4 -> offset_5 -> offset_6 -> offset_7: "offset +1" {
    style.stroke-dash: 3
    style.opacity: 0.5
  }
}

dlab_sequence: {
  label: "DLAB Baud Rate Sequence"
  
  step1: |'md
  **Step 1: Set DLAB=1**
  Access Divisor Latches
  `outb(0x3FB, 0x80)`
  LCR Bit 7 -> 1
  '| {
    shape: rectangle
    style.fill: ${colors.dlab}
  }

  step2: |'md
  **Step 2: Write Divisor**
  Clock: 1.8432 MHz
  Target: 115200 Baud
  `Divisor = 1`
  `outb(0x3F8, 0x01)` (DLL)
  `outb(0x3F9, 0x00)` (DLM)

  | Baud | Divisor |
  | :--- | :--- |
  | 9600 | 12 |
  | 38400 | 3 |
  | 115200| 1 |
  '| {
    shape: rectangle
    style.fill: ${colors.data}
  }

  step3: |'md
  **Step 3: Reset DLAB & 8N1**
  `outb(0x3FB, 0x03)`
  LCR = 0x03
  - DLAB = 0 (Normal Mode)
  - 8 Data, No Parity, 1 Stop
  '| {
    shape: rectangle
    style.fill: ${colors.control}
  }

  step1 -> step2 -> step3: "Initialization Flow"
}

fifo_config: {
  label: "FIFO Configuration (FCR)"

  fcr_write: |'md
  **FCR Write (0x3FA)**
  `outb(0x3FA, 0xC7)`
  - Bit 7-6: 11 (14B trigger)
  - Bit 2: Clear Tx FIFO
  - Bit 1: Clear Rx FIFO
  - Bit 0: Enable FIFO
  '| {
    shape: rectangle
    style.fill: ${colors.control}
  }

  trigger_levels: |'md
  **Trigger Levels**
  - 00: 1 Byte
  - 01: 4 Bytes
  - 10: 8 Bytes
  - 11: 14 Bytes
  '| {
    shape: rectangle
    style.fill: ${colors.register}
  }

  fcr_write -> trigger_levels: "Logic" { style.stroke-dash: 3 }
}

loopback_test: {
  label: "Loopback Verification"
  
  setup: "1. MCR Bit 4=1 (Enable Loopback)" { style.fill: ${colors.control} }
  write_test: "2. Write 0xAE to THR" { style.fill: ${colors.data} }
  read_verify: "3. Read RBR: Expect 0xAE" { style.fill: ${colors.status} }
  restore: "4. MCR Bit 4=0 (Normal Mode)" { style.fill: ${colors.control} }

  setup -> write_test -> read_verify -> restore: "test sequence" {
    style.animated: true
  }
}

transmit_flow: {
  label: "Transmit Data Path"
  
  check_lsr: |'md
  **Poll LSR (0x3FD)**
  Wait for Bit 5 (THRE)
  '| {
    shape: diamond
    style.fill: ${colors.status}
  }

  write_thr: |'md
  **Write THR (0x3F8)**
  `outb(0x3F8, data)`
  '| {
    shape: rectangle
    style.fill: ${colors.data}
  }

  hardware_tx: "UART Hardware Shift Out" {
    style.fill: ${colors.register}
  }

  check_lsr -> write_thr: "THR Empty"
  write_thr -> hardware_tx: "Serializing"
  hardware_tx -> check_lsr: "Next Byte" { style.stroke-dash: 3 }
}

# Global Layout Connections
registers -> dlab_sequence: "1. Init Baud" { style.stroke-width: 2 }
dlab_sequence -> fifo_config: "2. Config Buffers" { style.stroke-width: 2 }
fifo_config -> loopback_test: "3. Self-Test" { style.stroke-dash: 5 }
loopback_test -> transmit_flow: "4. Ready" { style.stroke: "#28A745" }

legend: {
  near: bottom-center
  label: |'md
  ### Serial Programming Reference
  - 🟩 **Data**: RBR, THR, DLL, DLM
  - 🟨 **Control**: IER, FCR, LCR, MCR
  - 🟥 **Status**: LSR, MSR
  - **DLAB**: Divisor Latch Access Bit (LCR bit 7)
  '|
}