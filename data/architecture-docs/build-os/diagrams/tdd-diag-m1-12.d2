direction: right
title: |md
  # Kernel Architecture Map
| {near: top-center}
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  bootloader: {
    style: {
      fill: "#E8D5B7"
      stroke: "#8B4513"
      font-color: "#5D3A1A"
    }
  }
  kernel_core: {
    style: {
      fill: "#B8D4E8"
      stroke: "#2E5984"
      font-color: "#1A3A5C"
    }
  }
  memory: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      font-color: "#1B5E20"
    }
  }
  process: {
    style: {
      fill: "#E1BEE7"
      stroke: "#6A1B9A"
      font-color: "#4A148C"
    }
  }
  hardware: {
    shape: diamond
    style: {
      fill: "#FFCCBC"
      stroke: "#D84315"
      font-color: "#BF360C"
    }
  }
  subsystem: {
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      font-color: "#F57F17"
      stroke-dash: 3
    }
  }
}
Boot: Bootloader (M1) {
  class: bootloader
  boot.asm: "Real Mode Entry\n0x7C00"
  a20.asm: "A20 Line Enable"
  gdt.asm: "GDT Setup\n5 Segments"
  load_kernel.asm: "Disk Read\nLBA 2+"
  protected.asm: "Mode Switch\nCR0.PE=1"
}
Kernel: Kernel Core {
  class: kernel_core
  Entry: Entry Point {
    entry.asm: "BSS Zeroing\n_stack setup"
    main.c: "kernel_main()"
  }
  Console: Console I/O {
    vga.c: "VGA Text Mode\n0xB8000"
    serial.c: "COM1 Debug\n0x3F8"
    kprintf.c: "Formatted Output"
  }
  Interrupts: Interrupt System (M2) {
    idt.c: "IDT 256 Entries"
    pic.c: "PIC 8259 Remap\nIRQ→32-47"
    interrupts.c: "ISR Dispatch"
    idt_stubs.asm: "Assembly Stubs"
  }
  Timer: Timer (M2) {
    timer.c: "PIT Channel 0\n100Hz Ticks"
  }
  Input: Keyboard (M2) {
    keyboard.c: "PS/2 Driver\nScancode→ASCII"
  }
}
Memory: Memory Management (M3) {
  class: memory
  PMM: Physical Memory {
    pmm.c: "Bitmap Allocator\n1 bit/frame"
  }
  VMM: Virtual Memory {
    vmm.c: "Page Tables\n2-Level x86"
  }
  Heap: Kernel Heap {
    kheap.c: "Linked List\nkmalloc/kfree"
  }
  PageFault: Page Faults {
    pagefault.c: "CR2 Handler\nDiagnostics"
  }
}
Process: Process Management (M4) {
  class: process
  PCB: Process Control {
    process.c: "PCB Allocation\nState Tracking"
  }
  Scheduler: Scheduler {
    scheduler.c: "Round-Robin\nTimer Preempt"
  }
  Context: Context Switch {
    context_switch.asm: "Register Save\nCR3 + TSS.ESP0"
  }
  UserMode: User Mode {
    usermode.c: "Ring 3 Entry\niret"
  }
  TSS: Task State {
    tss.c: "TSS Setup\nESP0 for Ring 3→0"
  }
  Syscall: System Calls {
    syscall.c: "INT 0x80\nDPL=3 Gate"
    syscall_entry.asm: "User→Kernel\nStub"
  }
}
Hardware: Hardware Interfaces {
  class: hardware
  CPU: "CPU\nx86 32-bit"
  PIC: "PIC 8259\nIRQ Router"
  PIT: "PIT 8254\nTimer"
  KBD: "Keyboard\n8042"
  VGA: "VGA Text\n0xB8000"
  Serial: "Serial COM1\n0x3F8"
}
Boot -> Kernel.Entry: "jmp 0x08:0x100000\nprotected mode"
Kernel.Entry -> Kernel.Console: "init"
Kernel.Entry -> Kernel.Interrupts: "init\nIDT + PIC"
Kernel.Interrupts -> Kernel.Timer: "IRQ0 handler"
Kernel.Interrupts -> Kernel.Input: "IRQ1 handler"
Kernel.Timer -> Process.Scheduler: "scheduler_tick()"
Process.Scheduler -> Process.Context: "yield()"
Process.Context -> Memory.VMM: "CR3 switch"
Process.Context -> Process.TSS: "TSS.ESP0 update"
Process.UserMode -> Process.Syscall: "INT 0x80"
Process.Syscall -> Kernel.Console: "sys_write"
Hardware.CPU -> Boot: "BIOS loads MBR"
Hardware.PIC -> Kernel.Interrupts: "IRQs 0-15"
Hardware.PIT -> Kernel.Timer: "Channel 0"
Hardware.KBD -> Kernel.Input: "Scancodes"
Kernel.Console -> Hardware.VGA: "MMIO writes"
Kernel.Console -> Hardware.Serial: "I/O ports"
Memory.PMM -> Memory.VMM: "frame alloc"
Memory.VMM -> Memory.Heap: "page mapping"
Process.PCB -> Memory.Heap: "kmalloc PCB"
Process.PCB -> Memory.VMM: "per-process PD"
Boot.style.stroke-width: 3
Kernel.style.stroke-width: 3
Memory.style.stroke-width: 3
Process.style.stroke-width: 3