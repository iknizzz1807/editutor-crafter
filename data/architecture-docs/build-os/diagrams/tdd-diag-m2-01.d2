layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header: "#D1C4E9"
    data_blue: "#BBDEFB"
    data_green: "#C8E6C9"
    padding: "#F5F5F5"
    pointer: "#FFE0B2"
    border: "#455A64"
  }
}

title: |md
  # x86 IDT Entry (Gate Descriptor)
  **Size: 8 Bytes (64 bits)**
| {near: top-center}

direction: right

# 1. Main 8-Byte Layout
idt_descriptor: {
  label: "Memory Layout: 8-Byte Descriptor"
  
  grid-columns: 1
  grid-gap: 0

  # Byte 6-7
  offset_high: {
    label: "Offset [31:16]\n(Bytes 6-7)"
    style.fill: ${colors.data_green}
  }
  # Byte 5
  byte_5: {
    label: "Access Rights / Type Attribute\n(Byte 5)"
    style.fill: ${colors.header}
  }
  # Byte 4
  byte_4: {
    label: "Reserved / Zero (0x00)\n(Byte 4)"
    style.fill: ${colors.padding}
  }
  # Byte 2-3
  selector: {
    label: "Segment Selector\n(Bytes 2-3)"
    style.fill: ${colors.data_blue}
  }
  # Byte 0-1
  offset_low: {
    label: "Offset [15:0]\n(Bytes 0-1)"
    style.fill: ${colors.data_green}
  }

  # Offset annotations as tooltips
  offset_high.tooltip: "Offset +6"
  byte_5.tooltip: "Offset +5"
  byte_4.tooltip: "Offset +4"
  selector.tooltip: "Offset +2"
  offset_low.tooltip: "Offset +0"
}

# 2. Type/Attribute Breakdown (Bit level)
type_attr_detail: {
  label: "Byte 5: Type / Attribute Bitfield Breakdown"
  
  bits: {
    shape: sql_table
    style.stroke: ${colors.border}
    
    "Bit 7": "P" {constraint: "Present Flag (1=Valid)"}
    "Bits 6-5": "DPL" {constraint: "Privilege Level (0-3)"}
    "Bit 4": "S" {constraint: "Storage Segment (0 for Gates)"}
    "Bits 3-0": "Type" {constraint: "Gate Type (E=Interrupt, F=Trap)"}
  }
}

# 3. Gate Type Comparison Table (Using Grid for multi-column)
gate_comparison: {
  label: "Standard Gate Configurations"
  
  grid-columns: 6
  grid-gap: 0

  # Header
  h1: "Gate Name" {style: {bold: true; fill: "#CFD8DC"}}
  h2: "Hex" {style: {bold: true; fill: "#CFD8DC"}}
  h3: "P" {style: {bold: true; fill: "#CFD8DC"}}
  h4: "DPL" {style: {bold: true; fill: "#CFD8DC"}}
  h5: "Type" {style: {bold: true; fill: "#CFD8DC"}}
  h6: "Operation" {style: {bold: true; fill: "#CFD8DC"}}

  # Row 1: Interrupt Gate (Kernel)
  r1c1: "Interrupt Gate"
  r1c2: "0x8E"
  r1c3: "1"
  r1c4: "00 (Ring 0)"
  r1c5: "1110"
  r1c6: "Disable IF, Jump to Offset"

  # Row 2: User Interrupt (Syscall)
  r2c1: "User Gate"
  r2c2: "0xEE"
  r2c3: "1"
  r2c4: "11 (Ring 3)"
  r2c5: "1110"
  r2c6: "Allow INT 0x80"

  # Row 3: Trap Gate
  r3c1: "Trap Gate"
  r3c2: "0x8F"
  r3c3: "1"
  r3c4: "00 (Ring 0)"
  r3c5: "1111"
  r3c6: "Keep IF, Jump to Offset"
}

# 4. Decoding Logic
binary_decoding: {
  label: "Binary Decoding: 0x8E vs 0xEE"
  
  gate_0x8e: {
    label: "0x8E (1000 1110b)"
    shape: rectangle
    style: { fill: "#E3F2FD"; stroke: "#1976D2" }
    content: |md
      **Present:** 1
      **DPL:** 00 (Kernel Only)
      **S:** 0 (System)
      **Type:** 1110 (Int Gate)
    |
  }

  gate_0xee: {
    label: "0xEE (1110 1110b)"
    shape: rectangle
    style: { fill: "#FFF3E0"; stroke: "#F57C00" }
    content: |md
      **Present:** 1
      **DPL:** 11 (User Accessible)
      **S:** 0 (System)
      **Type:** 1110 (Int Gate)
    |
  }
}

# 5. Handler Address Reconstruction
addr_calc: {
  label: "32-bit Handler Address Reconstruction"
  
  high: "Offset [31:16]" {style.fill: ${colors.data_green}}
  low: "Offset [15:0]" {style.fill: ${colors.data_green}}
  
  combiner: {
    shape: diamond
    label: "Shift & OR"
  }
  
  final: "32-bit Linear Address" {
    style: { fill: "#4CAF50"; font-color: white; bold: true }
  }

  high -> combiner: "<< 16"
  low -> combiner: "| (OR)"
  combiner -> final
}

# Connections and Structural Flow
idt_descriptor.byte_5 -> type_attr_detail
type_attr_detail -> gate_comparison
gate_comparison -> binary_decoding

idt_descriptor.offset_high -> addr_calc.high {style.stroke: orange}
idt_descriptor.offset_low -> addr_calc.low {style.stroke: orange}

# Styling for connectivity
(idt_descriptor.byte_5 -> type_attr_detail)[0].style.stroke-dash: 5
(gate_comparison -> binary_decoding)[0].style.stroke-dash: 5

legend: {
  near: bottom-right
  k: "Kernel-Only (DPL 0)" {style.fill: "#E3F2FD"}
  u: "User-Callable (DPL 3)" {style.fill: "#FFF3E0"}
  off: "Address Component" {style.fill: ${colors.data_green}}
}