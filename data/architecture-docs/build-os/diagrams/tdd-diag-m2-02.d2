vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT TITLE ---
title: |md
  # Interrupt Stack Frame (x86-32)
  Hardware and Software State Transitions
| {
  near: top-center
  style.font-size: 24
  style.bold: true
}

# --- ADDRESS DIRECTION INDICATOR ---
address_labels: {
  shape: text
  near: center-left
  label: |md
    **Memory Address**
    ↑ High (+44)
    │
    │ (Grows Down)
    │
    ↓ Low (+0)
  |
}

# --- STACK STATE 1: HARDWARE PUSHED ---
before: {
  label: |md
    ### [1] CPU Hardware Push
    *Initial state at ISR Entry*
  |
  style.fill: "#E8F4FD"
  style.stroke: "#2563EB"
  style.stroke-width: 2

  before_stack: {
    grid-rows: 8
    grid-gap: 0
    
    ss: "SS (user) [esp+20]" {
      style.fill: "#FDE68A" # Yellow: Privilege
      style.stroke: "#D97706"
      style.font: mono
      width: 250
    }
    esp_u: "ESP (user) [esp+16]" {
      style.fill: "#FDE68A"
      style.stroke: "#D97706"
      style.font: mono
    }
    eflags: "EFLAGS [esp+12]" {
      style.fill: "#BBF7D0" # Green: Standard
      style.stroke: "#16A34A"
      style.font: mono
    }
    cs: "CS [esp+8]" {
      style.fill: "#BBF7D0"
      style.stroke: "#16A34A"
      style.font: mono
    }
    eip: "EIP [esp+4]" {
      style.fill: "#BBF7D0"
      style.stroke: "#16A34A"
      style.font: mono
      style.bold: true
    }
    err: "Error Code [esp+0]" {
      style.fill: "#FECACA" # Red: Error
      style.stroke: "#DC2626"
      style.font: mono
      label: "Error Code (optional)"
    }
    ptr_note: "← CPU ESP" {
      shape: text
      style.font-color: "#DC2626"
      style.bold: true
    }
  }
}

# --- TRANSITION ---
arrow1: "pusha\npush ds,es,fs,gs" {
  style.stroke: "#6B7280"
  style.stroke-width: 3
  style.font: mono
}

# --- STACK STATE 2: FULL CONTEXT ---
after: {
  label: |md
    ### [2] Full Context Pushed
    *Ready for C Handler*
  |
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.stroke-width: 2

  after_stack: {
    grid-rows: 18
    grid-gap: 0
    
    # Re-mapped offsets for full frame
    ss2: "SS (user) [esp+68]" {
      style.fill: "#FDE68A"
      style.stroke: "#D97706"
      style.font: mono
      width: 250
    }
    esp2: "ESP (user) [esp+64]" {
      style.fill: "#FDE68A"
      style.stroke: "#D97706"
      style.font: mono
    }
    eflags2: "EFLAGS [esp+60]" { style.fill: "#BBF7D0"; style.stroke: "#16A34A"; style.font: mono }
    cs2: "CS [esp+56]" { style.fill: "#BBF7D0"; style.stroke: "#16A34A"; style.font: mono }
    eip2: "EIP [esp+52]" { style.fill: "#BBF7D0"; style.stroke: "#16A34A"; style.font: mono }
    err2: "Error Code [esp+48]" { style.fill: "#FECACA"; style.stroke: "#DC2626"; style.font: mono }
    
    # Segment Regs (Software Pushed)
    gs: "GS [esp+44]" { style.fill: "#C4B5FD"; style.stroke: "#7C3AED"; style.font: mono }
    fs: "FS [esp+40]" { style.fill: "#C4B5FD"; style.stroke: "#7C3AED"; style.font: mono }
    es: "ES [esp+36]" { style.fill: "#C4B5FD"; style.stroke: "#7C3AED"; style.font: mono }
    ds: "DS [esp+32]" { style.fill: "#C4B5FD"; style.stroke: "#7C3AED"; style.font: mono }
    
    # PUSHA result (EAX is at lowest addr)
    eax: "EAX [esp+28]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    ecx: "ECX [esp+24]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    edx: "EDX [esp+20]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    ebx: "EBX [esp+16]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    esp_p: "ESP (orig) [esp+12]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    ebp: "EBP [esp+8]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    esi: "ESI [esp+4]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    edi: "EDI [esp+0]" { style.fill: "#E0E7FF"; style.stroke: "#4F46E5"; style.font: mono }
    
    ptr_note2: "← Software ESP" {
      shape: text
      style.font-color: "#DC2626"
      style.bold: true
    }
  }
}

# --- FOOTER / DETAILS ---
details: {
  near: bottom-center
  style.fill: "#F3F4F6"
  style.stroke: "#6B7280"
  label: |md
    ### Implementation Notes
    *   **Privilege Change:** CPU loads ESP0/SS0 from TSS before pushing SS:ESP.
    *   **No Privilege Change:** SS:ESP are NOT pushed by hardware.
    *   **Error Codes:** Pushed for vectors 8, 10-14, 17. ISR must `add esp, 4` before `iret`.
    *   **pusha:** Pushes EAX, ECX, EDX, EBX, ESP, EBP, ESI, EDI (stack grows down).
  |
}

# --- ROOT LEVEL LEGENDS (Fixes Compilation Error) ---
legend_box: {
  near: bottom-left
  label: |md
    **Color Key:**
    🟡 Ring Transition State
    🟢 Standard Hardware Context
    🔴 Exception Data
    🟣 Segment Registers
    🔵 General Purpose Registers
  |
  style.stroke-dash: 3
}

# --- CONNECTIONS ---
before -> arrow1
arrow1 -> after
before -> details: "System State" { style.stroke-dash: 5 }