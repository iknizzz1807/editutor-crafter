vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # x86 ISR (Interrupt Service Routine) Entry and Exit Flow
  *Technical implementation guide for context switching and stack frame management*
|| {near: top-center}

direction: right

# ---------------------------------------------------------------------------------------
# ENTRY PHASE: Ring 3 -> Ring 0 Transition and Context Preservation
# ---------------------------------------------------------------------------------------
entry_phase: Entry Phase {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 4

  cpu_push: CPU Hardware Push {
    style.fill: "#FFE5B4"
    style.stroke: "#D68910"
    shape: sequence_diagram
    
    hw: Hardware
    stack: Kernel Stack
    
    hw -> stack: "SS (if priv change)"
    hw -> stack: "ESP (if priv change)"
    hw -> stack: "EFLAGS"
    hw -> stack: "CS"
    hw -> stack: "EIP (return address)"
    hw -> stack: "Error Code (Vector dependent)"
  }

  stub_push: Assembly Stub {
    style.fill: "#D4EDDA"
    style.stroke: "#1E8449"
    shape: sequence_diagram
    
    asm: ISR Stub
    stack: Kernel Stack
    
    asm -> asm: "cli (Disable Interrupts)"
    asm -> stack: "push 0 (Dummy Error if needed)"
    asm -> stack: "push vector_number"
  }

  save_context: Save All GPRs {
    style.fill: "#D1F2EB"
    style.stroke: "#138D75"
    shape: sequence_diagram
    
    asm: PUSHA
    stack: Kernel Stack
    
    asm -> stack: "EAX"
    asm -> stack: "ECX"
    asm -> stack: "EDX"
    asm -> stack: "EBX"
    asm -> stack: "ESP (original)"
    asm -> stack: "EBP"
    asm -> stack: "ESI"
    asm -> stack: "EDI"
  }

  seg_push: Save Segment Selectors {
    style.fill: "#D6EAF8"
    style.stroke: "#2E86C1"
    shape: sequence_diagram
    
    asm: PUSH Segments
    stack: Kernel Stack
    
    asm -> stack: "DS"
    asm -> stack: "ES"
    asm -> stack: "FS"
    asm -> stack: "GS"
  }

  call_c: Dispatch to C {
    style.fill: "#C3E6CB"
    load_kds: "mov ax, 0x10 (Kernel Data)\nmov ds, ax; mov es, ax"
    push_esp: "push esp (pointer to regs)"
    call_handler: "call interrupt_handler"
  }

  cpu_push -> stub_push -> save_context -> seg_push -> call_c
}

# ---------------------------------------------------------------------------------------
# EXIT PHASE: Context Restoration and IRET
# ---------------------------------------------------------------------------------------
exit_phase: Exit Phase {
  style.fill: "#FDE8E8"
  style.stroke: "#C0392B"
  style.stroke-width: 4

  cleanup_arg: Cleanup Stack Arg {
    style.fill: "#F5B7B1"
    add_esp_4: "add esp, 4"
    description: "Pop the pointer to the registers struct passed to C"
  }

  pop_segs: Restore Segments {
    style.fill: "#FADBD8"
    shape: sequence_diagram
    
    asm: POP Segments
    stack: Kernel Stack
    
    stack -> asm: "GS"
    stack -> asm: "FS"
    stack -> asm: "ES"
    stack -> asm: "DS"
  }

  popa_regs: Restore GPRs {
    style.fill: "#FADBD8"
    shape: sequence_diagram
    
    stack: Kernel Stack
    asm: POPA
    
    stack -> asm: "EDI"
    stack -> asm: "ESI"
    stack -> asm: "EBP"
    stack -> asm: "ESP (ignored)"
    stack -> asm: "EBX"
    stack -> asm: "EDX"
    stack -> asm: "ECX"
    stack -> asm: "EAX"
  }

  remove_frame: Remove ISR Frame {
    style.fill: "#F5B7B1"
    add_esp_8: "add esp, 8"
    description: "Cleans vector_number and dummy_error from stack"
  }

  iret_return: Hardware Return {
    style.fill: "#E74C3C"
    style.font-color: white
    iret_ins: "IRET"
    description: "Restores EIP, CS, EFLAGS from stack. Switches stack if ring change."
  }

  cleanup_arg -> pop_segs -> popa_regs -> remove_frame -> iret_return
}

# ---------------------------------------------------------------------------------------
# Layout and Legend
# ---------------------------------------------------------------------------------------

entry_phase.call_c.call_handler -> exit_phase.cleanup_arg: "handler returns" {
  style.stroke: "#2980B9"
  style.stroke-width: 3
  style.animated: true
}

stack_layout: Interrupt Stack Frame Layout {
  near: center-right
  style.fill: "#FFFFFF"
  style.stroke: "#333333"
  style.stroke-width: 2
  
  content: ||md
    ### Memory Layout (High -> Low)
    | Offset | Field | Source |
    | :--- | :--- | :--- |
    | +48 | SS | Hardware (Ring change) |
    | +44 | ESP | Hardware (Ring change) |
    | +40 | EFLAGS | Hardware |
    | +36 | CS | Hardware |
    | +32 | EIP | Hardware |
    | +28 | Error Code / Dummy | Hardware/Stub |
    | +24 | Vector Number | Stub |
    | +20 | EAX | PUSHA |
    | +16 | ECX | PUSHA |
    | +12 | EDX | PUSHA |
    | +8  | EBX | PUSHA |
    | +4  | ESP (val at PUSHA) | PUSHA |
    | +0  | EBP | PUSHA |
    | -4  | ESI | PUSHA |
    | -8  | EDI | PUSHA |
    | -12 | DS/ES/FS/GS | manual push |
  ||
}

legend: Diagram Legend {
  near: bottom-center
  style.fill: "#F8F9FA"
  
  cpu: "CPU Hardware Logic" { style.fill: "#FFE5B4" }
  stub: "Assembly Glue Code" { style.fill: "#D4EDDA" }
  c_code: "C Handler Logic" { style.fill: "#C3E6CB" }
  critical: "IRET Instruction" { style.fill: "#E74C3C"; style.font-color: white }
  
  cpu -> stub -> c_code -> critical
}