vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # PIC 8259 Master/Slave Cascade Architecture
  Dual PIC configuration for IRQ routing
| {near: top-center}
direction: right
classes: {
  pic_chip: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      border-radius: 8
    }
  }
  irq_line: {
    shape: rectangle
    width: 80
    height: 30
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      border-radius: 4
    }
  }
  port_label: {
    shape: text
    style: {
      font: mono
      font-size: 14
    }
  }
  signal_line: {
    style: {
      stroke: "#2E86AB"
      stroke-width: 2
    }
  }
  eoi_flow: {
    style: {
      stroke: "#4CAF50"
      stroke-width: 3
      animated: true
    }
  }
  cascade_line: {
    style: {
      stroke: "#9C27B0"
      stroke-width: 3
      stroke-dash: 5
    }
  }
}
master_pic: "PIC Master (8259)" {
  class: pic_chip
  ports: "I/O Ports" {
    shape: rectangle
    style.fill: "#BBDEFB"
    cmd_port: "Command: 0x20" {class: port_label}
    data_port: "Data: 0x21" {class: port_label}
  }
  irqs: "IRQ Lines (0-7)" {
    grid-columns: 2
    irq0: "IRQ0\nTimer" {class: irq_line}
    irq1: "IRQ1\nKeyboard" {class: irq_line}
    irq2: "IRQ2\nCascade" {
      class: irq_line
      style: {
        fill: "#E1BEE7"
        stroke: "#9C27B0"
        stroke-width: 3
      }
    }
    irq3: "IRQ3\nCOM2" {class: irq_line}
    irq4: "IRQ4\nCOM1" {class: irq_line}
    irq5: "IRQ5\nLPT2" {class: irq_line}
    irq6: "IRQ6\nFloppy" {class: irq_line}
    irq7: "IRQ7\nLPT1" {class: irq_line}
  }
  int_output: "INT → CPU" {
    shape: diamond
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  irqs.irq0 -> int_output
  irqs.irq1 -> int_output
  irqs.irq3 -> int_output
  irqs.irq4 -> int_output
  irqs.irq5 -> int_output
  irqs.irq6 -> int_output
  irqs.irq7 -> int_output
}
slave_pic: "PIC Slave (8259)" {
  class: pic_chip
  ports2: "I/O Ports" {
    shape: rectangle
    style.fill: "#BBDEFB"
    cmd_port2: "Command: 0xA0" {class: port_label}
    data_port2: "Data: 0xA1" {class: port_label}
  }
  irqs2: "IRQ Lines (8-15)" {
    grid-columns: 2
    irq8: "IRQ8\nRTC" {class: irq_line}
    irq9: "IRQ9\nFree" {class: irq_line}
    irq10: "IRQ10\nFree" {class: irq_line}
    irq11: "IRQ11\nFree" {class: irq_line}
    irq12: "IRQ12\nMouse" {class: irq_line}
    irq13: "IRQ13\nFPU" {class: irq_line}
    irq14: "IRQ14\nPrimary ATA" {class: irq_line}
    irq15: "IRQ15\nSecondary ATA" {class: irq_line}
  }
  int_output2: "INT → Master IRQ2" {
    shape: diamond
    style: {
      fill: "#E1BEE7"
      stroke: "#9C27B0"
    }
  }
  irqs2.irq8 -> int_output2
  irqs2.irq9 -> int_output2
  irqs2.irq10 -> int_output2
  irqs2.irq11 -> int_output2
  irqs2.irq12 -> int_output2
  irqs2.irq13 -> int_output2
  irqs2.irq14 -> int_output2
  irqs2.irq15 -> int_output2
}
cpu_block: "CPU" {
  shape: hexagon
  style: {
    fill: "#FFCDD2"
    stroke: "#D32F2F"
    stroke-width: 3
  }
}
vector_table: "IDT Vectors" {
  shape: rectangle
  style.fill: "#FFF9C4"
  v32_39: "IRQ0-7 → Vectors 32-39" {class: port_label}
  v40_47: "IRQ8-15 → Vectors 40-47" {class: port_label}
}
eoi_master: "EOI to Master\n(IRQ0-7)" {
  shape: diamond
  style: {
    fill: "#C8E6C9"
    stroke: "#4CAF50"
  }
}
eoi_both: "EOI to Both\n(IRQ8-15)" {
  shape: diamond
  style: {
    fill: "#C8E6C9"
    stroke: "#4CAF50"
  }
}
master_pic.int_output -> cpu_block: "INT signal\n(vector 32-39)" {class: signal_line}
slave_pic.int_output2 -> master_pic.irqs.irq2: "Cascade INT\n(slave IRQ pending)" {class: cascade_line}
cpu_block -> vector_table: "Look up handler" {style.stroke-dash: 3}
handler_block: "ISR Handler" {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    border-radius: 8
  }
  step1: "1. Handle device" {shape: text}
  step2: "2. Send EOI" {shape: text}
}
cpu_block -> handler_block: "Jump to ISR" {style.stroke-dash: 3}
handler_block -> eoi_master: "IRQ 0-7" {class: eoi_flow}
handler_block -> eoi_both: "IRQ 8-15" {class: eoi_flow}
eoi_master -> master_pic.ports.cmd_port: "outb(0x20, 0x20)\nSingle EOI" {
  class: eoi_flow
  label: "EOI (0x20)"
}
eoi_both -> slave_pic.ports2.cmd_port2: "outb(0xA0, 0x20)\nSlave EOI first" {
  class: eoi_flow
  label: "EOI Slave"
}
eoi_both -> master_pic.ports.cmd_port: "outb(0x20, 0x20)\nThen Master EOI" {
  class: eoi_flow
  label: "EOI Master"
}
legend: |md
  ## EOI Protocol
  **IRQ 0-7 (Master only):**
  
  outb(0x20, 0x20);  // EOI to master
  
  **IRQ 8-15 (Slave → Master):**
  
  outb(0xA0, 0x20);  // EOI to slave first
  outb(0x20, 0x20);  // EOI to master second
  
  **Why both?** Slave's INT output is 
  physically wired to Master's IRQ2.
  Master must also clear its IRQ2 ISR bit.
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
}
init_sequence: "Initialization Sequence (ICW1-4)" {
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    border-radius: 8
  }
  icw1: "ICW1: 0x11 → Init + need ICW4" {shape: text}
  icw2_m: "ICW2 Master: 0x20 → IRQ0=vec32" {shape: text}
  icw2_s: "ICW2 Slave: 0x28 → IRQ8=vec40" {shape: text}
  icw3_m: "ICW3 Master: 0x04 → Slave on IRQ2" {shape: text}
  icw3_s: "ICW3 Slave: 0x02 → Slave ID=2" {shape: text}
  icw4: "ICW4: 0x01 → 8086 mode" {shape: text}
}
master_pic <-> init_sequence: "Config" {style.stroke-dash: 3; style.opacity: 0.5}
slave_pic <-> init_sequence: "Config" {style.stroke-dash: 3; style.opacity: 0.5}