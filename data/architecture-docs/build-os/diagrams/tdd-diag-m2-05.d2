vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # PIC 8259A Remapping Sequence
  Master (0x20/0x21) and Slave (0xA0/0xA1) Initialization
'| {
  near: top-center
}

direction: right

# --- CLASSES ---
classes: {
  port: {
    shape: hexagon
    style: {
      font-size: 14
      bold: true
    }
  }
  icw_logic: {
    style: {
      border-radius: 4
      stroke-width: 2
    }
  }
}

# --- HARDWARE BLOCKS ---
master_pic: Master PIC {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  
  cmd_port: 0x20 (Command) {
    class: port
    style.fill: "#BBDEFB"
  }
  data_port: 0x21 (Data) {
    class: port
    style.fill: "#BBDEFB"
  }
}

slave_pic: Slave PIC {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  
  cmd_port: 0xA0 (Command) {
    class: port
    style.fill: "#FFE0B2"
  }
  data_port: 0xA1 (Data) {
    class: port
    style.fill: "#FFE0B2"
  }
}

# --- INITIALIZATION CONTROL WORDS (ICW) DETAILS ---
icw_definition: Initialization Logic {
  icw1_box: ICW1 - Initialization {
    class: icw_logic
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    content: |'md
      ### Byte: 0x11 (00010001b)
      | Bit | Name | Value | Description |
      |---|---|---|---|
      | 0 | IC4 | 1 | ICW4 needed |
      | 1 | SNGL | 0 | Cascade mode |
      | 2 | ADI | 0 | Call address interval |
      | 3 | LTIM | 0 | Edge triggered |
      | 4 | INIT | 1 | Start Initialization |
    '|
  }

  icw2_box: ICW2 - Vector Offsets {
    class: icw_logic
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    
    master_offset: |'md
      **Master Base: 0x20**
      - IRQ 0..7 maps to 0x20..0x27
      - (Decimal 32..39)
    '|
    
    slave_offset: |'md
      **Slave Base: 0x28**
      - IRQ 8..15 maps to 0x28..0x2F
      - (Decimal 40..47)
    '|
  }

  icw3_box: ICW3 - Cascading {
    class: icw_logic
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    
    master_cascade: |'md
      **Master: 0x04**
      Bit 2 = 1 (Binary 00000100)
      Indicates Slave is on IRQ2
    '|
    
    slave_id: |'md
      **Slave: 0x02**
      ID = 2
      Identifies self to Master IRQ
    '|
  }

  icw4_box: ICW4 - Environmental {
    class: icw_logic
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    content: |'md
      ### Byte: 0x01 (00000001b)
      | Bit | Name | Description |
      |---|---|---|
      | 0 | uPM | 1 = 8086/88 Mode |
      | 1 | AEOI | 0 = Normal EOI |
      | 2 | M/S | 0 = Slave (if buffered) |
      | 3 | BUF | 0 = Non-buffered |
      | 4 | SFNM | 0 = Fully Nested |
    '|
  }
}

# --- SEQUENCE DIAGRAM (CALL ORDER) ---
sequence_flow: {
  shape: sequence_diagram
  style.fill: "#F5F5F5"
  
  cpu: CPU {shape: person}
  master: Master PIC
  slave: Slave PIC
  
  cpu -> master: outb(0x20, 0x11) {label: "Write ICW1: Init"}
  cpu -> slave: outb(0xA0, 0x11) {label: "Write ICW1: Init"}
  
  cpu -> master: outb(0x21, 0x20) {label: "Write ICW2: Offset 0x20"}
  cpu -> slave: outb(0xA1, 0x28) {label: "Write ICW2: Offset 0x28"}
  
  cpu -> master: outb(0x21, 0x04) {label: "Write ICW3: Slave IRQ map"}
  cpu -> slave: outb(0xA1, 0x02) {label: "Write ICW3: ID code"}
  
  cpu -> master: outb(0x21, 0x01) {label: "Write ICW4: 8086 Mode"}
  cpu -> slave: outb(0xA1, 0x01) {label: "Write ICW4: 8086 Mode"}
}

# --- LOGICAL CONNECTIONS ---
master_pic.cmd_port -> icw_definition.icw1_box: "Initialization Command"
master_pic.data_port -> icw_definition.icw2_box: "Data parameters"
master_pic.data_port -> icw_definition.icw3_box: "Cascade bitmask"
master_pic.data_port -> icw_definition.icw4_box: "Operating mode"

# --- MAPPING RESULT ---
vector_map: Final Vector Map {
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  irq_range: ||md
    | Controller | IRQ Range | Exception Conflict | New Vector |
    |---|---|---|---|
    | Master | 0-7 | 0x00-0x1F (Avoided) | **0x20-0x27** |
    | Slave | 8-15 | 0x00-0x1F (Avoided) | **0x28-0x2F** |
  ||
}

# --- ERROR FIXED NOTE ---
# Changed "near: icw4_box" to "near: bottom-right" to comply with ELK layout engine
warning_note: |'md
  ### CRITICAL IMPLEMENTATION DETAIL
  **Strict Sequence Requirement**: 
  The 8259A state machine requires ICW1-ICW4 to be written in exact order. 
  A write to the Data Port (0x21/0xA1) immediately following ICW1 
  is internally routed to the ICW2 register.
'| {
  near: bottom-right
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    font-color: "#B71C1C"
    bold: true
  }
}

# --- CASCADE DIAGRAM ---
cascade: Cascade Physical Logic {
  near: top-right
  m_irq2: Master IRQ2 Pin {
    shape: circle
    style.fill: orange
  }
  s_int: Slave INT Pin {
    shape: circle
    style.fill: orange
  }
  m_irq2 <-> s_int: Physical Cascade Line
}