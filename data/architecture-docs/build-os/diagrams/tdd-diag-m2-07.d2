layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#673AB7"
    data: "#2196F3"
    padding: "#9E9E9E"
    pointer: "#FF9800"
    pit_orange: "#E65100"
    cpu_blue: "#2E86AB"
    logic_teal: "#009688"
  }
}

title: {
  shape: text
  label: |md
    # PIT Channel 0 Programming Sequence
    ### Intel 8253/8254 Programmable Interval Timer
    **Oscillator Frequency:** 1.193182 MHz | **Target Frequency:** 100 Hz (10ms)
  |
  near: top-center
}

# --- PORT I/O MEMORY MAP ---

port_map: {
  label: "I/O Port Mapping (0x40 - 0x43)"
  shape: sql_table
  style: {
    fill: white
    stroke: "#333333"
    stroke-width: 2
  }
  
  "0x40": "Channel 0 Data Register" {constraint: "R/W (Counter)"}
  "0x41": "Channel 1 Data Register" {constraint: "R/W (RAM Refresh)"}
  "0x42": "Channel 2 Data Register" {constraint: "R/W (PC Speaker)"}
  "0x43": "Mode/Command Register" {
    constraint: "Write Only"
    style.fill: "#FFEBEE"
  }
}

# --- COMMAND BYTE SPECIFICATION (0x36) ---

command_spec: {
  label: "Command Byte Breakdown: 0x36 (00110110b)"
  
  grid_container: {
    grid-columns: 4
    grid-gap: 0
    
    h1: "Select Channel" { style: { bold: true; fill: "#CFD8DC" } }
    h2: "Access Mode" { style: { bold: true; fill: "#CFD8DC" } }
    h3: "Operating Mode" { style: { bold: true; fill: "#CFD8DC" } }
    h4: "BCD/Binary" { style: { bold: true; fill: "#CFD8DC" } }
    
    b1: "Bits 7-6" { style.font-size: 10 }
    b2: "Bits 5-4" { style.font-size: 10 }
    b3: "Bits 3-1" { style.font-size: 10 }
    b4: "Bit 0" { style.font-size: 10 }
    
    v1: "00\n(Channel 0)" { style.fill: "#FFCDD2" }
    v2: "11\n(LSB then MSB)" { style.fill: "#C8E6C9" }
    v3: "011\n(Mode 3)" { style.fill: "#BBDEFB" }
    v4: "0\n(16-bit Binary)" { style.fill: "#FFF9C4" }
  }
  
  footer: {
    shape: text
    label: |md
      **Mode 3:** Square Wave Generator.
      Decrements by 2 per clock pulse.
    |
    style.font-size: 12
  }
}

# --- SYSTEM COMPONENTS ---

cpu: CPU {
  shape: circle
  icon: https://icons.terrastruct.com/tech/053-cpu.svg
  style: {
    fill: "${vars.colors.cpu_blue}"
    font-color: white
  }
}

pit: PIT 8254 Logic {
  style: {
    fill: "#FFF3E0"
    stroke: "${vars.colors.pit_orange}"
    stroke-width: 2
  }
  
  logic_core: {
    latch: 16-bit Counter Register {
      grid-columns: 2
      grid-gap: 0
      msb: "0x00" { style.fill: "#F3E5F5" }
      lsb: "0x00" { style.fill: "#F3E5F5" }
    }
    
    divider: Frequency Divider {
      shape: diamond
      style.fill: "#E0F2F1"
    }
  }
}

# --- PROGRAMMING SEQUENCE ---

cpu -> port_map."0x43": "1. Set Control Word (0x36)" {
  style: {
    stroke: "${vars.colors.pointer}"
    stroke-width: 3
    animated: true
  }
}

port_map."0x43" -> command_spec: "Initializes Channel 0" {
  style.stroke-dash: 3
}

cpu -> port_map."0x40": "2. Send LSB (0x9B)" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    animated: true
  }
}

cpu -> port_map."0x40": "3. Send MSB (0x2E)" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}

# Targeted updates to visualize register state after Step 3
(cpu -> port_map."0x40")[0] -> pit.logic_core.latch.lsb: "Update LSB" {
  style.stroke: "#2E7D32"
}

(cpu -> port_map."0x40")[1] -> pit.logic_core.latch.msb: "Update MSB" {
  style.stroke: "#1565C0"
}

pit.logic_core.latch.lsb.style.fill: "#A5D6A7"
pit.logic_core.latch.msb.style.fill: "#90CAF9"
pit.logic_core.latch.lsb.label: "0x9B"
pit.logic_core.latch.msb.label: "0x2E"

pit.logic_core.latch -> pit.logic_core.divider: "Load Divisor: 11,931"

# --- CLOCK AND OUTPUT ---

osc: Crystal Oscillator {
  label: "1.193182 MHz"
  shape: circle
  style: {
    fill: "#FAFAFA"
    stroke-dash: 2
  }
}

osc -> pit.logic_core.divider: "Base Clock"

irq0: IRQ0 Interrupt {
  shape: parallelogram
  label: "System Timer (100 Hz)"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    bold: true
  }
}

pit.logic_core.divider -> irq0: "Toggles Line"

# --- CALCULATIONS & SPECS ---

calc_ref: {
  label: |md
    ### Reference: Divisor Calculation
    $f_{base} = 1,193,182 \text{ Hz}$
    $f_{target} = 100 \text{ Hz}$

    $Divisor = \frac{1,193,182}{100} = 11,931$
    
    **Hex Conversion:**
    $11,931 \rightarrow \mathbf{0x2E9B}$
    - LSB: **0x9B**
    - MSB: **0x2E**
  |
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
    border-radius: 5
  }
}

mode_ref: {
  label: |md
    ### Mode 3: Square Wave
    - $N = Divisor$
    - High for: $\lceil N/2 \rceil$ counts
    - Low for: $\lfloor N/2 \rfloor$ counts
    - Counter reloads automatically.
  |
  style: {
    fill: "#E1F5FE"
    stroke: "#0288D1"
    border-radius: 5
  }
}

# Layout constraints
calc_ref.near: bottom-right
mode_ref.near: bottom-left
command_spec.near: port_map."0x43"