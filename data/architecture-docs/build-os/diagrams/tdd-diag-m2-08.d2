vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Keyboard Scancode Processing Flow (Intel 8042 Context)
  **IRQ1 → Port 0x60 → Make/Break Logic → Translation Tables → Circular Buffer**
  *Technical Specification: Scancode Set 1 Parsing & Modifier State Tracking*
| {near: top-center}

direction: right

# ---------------------------------------------------------------------------------
# HARDWARE LAYER: PIC & 8042 Controller
# ---------------------------------------------------------------------------------

Hardware: {
  IRQ1: Interrupt Request 1 {
    shape: circle
    style: {
      fill: "#FF6B6B"
      stroke: "#C0392B"
      stroke-width: 4
      font-color: white
      bold: true
      shadow: true
    }
  }

  Keyboard_Controller: {
    label: "Intel 8042 PS/2 Controller"
    style: {
      fill: "#E8E8E8"
      stroke: "#7F8C8D"
      stroke-dash: 3
    }
    
    Port_0x60: {
      label: "I/O Port 0x60 (R)\n[Output Buffer Register]"
      shape: hexagon
      style: {
        fill: "#F39C12"
        stroke: "#D68910"
        font-color: white
        bold: true
      }
    }
    
    Scancode_Byte: {
      label: "Scancode Byte Layout"
      grid-columns: 2
      style.fill: "#FDEBD0"
      
      bit7: "Bit [7]\nBreak Flag" {
        style.fill: "#FAD7A0"
        style.bold: true
      }
      bit0_6: "Bits [6:0]\nScancode ID" {
        style.fill: "#FDEBD0"
      }
    }
  }
}

# ---------------------------------------------------------------------------------
# PARSING LOGIC: Kernel ISR (Interrupt Service Routine)
# ---------------------------------------------------------------------------------

ISR_Parsing: {
  Bit7_Check: {
    shape: diamond
    label: "Verify MSB\n(Bit 7 set?)"
    style: {
      fill: "#9B59B6"
      stroke: "#7D3C98"
      font-color: white
    }
  }

  Make_Code: {
    label: "MAKE CODE\n(Key Pressed)\nCode & 0x7F"
    style: {
      fill: "#27AE60"
      stroke: "#1E8449"
      font-color: white
      bold: true
    }
  }

  Break_Code: {
    label: "BREAK CODE\n(Key Released)\nCode | 0x80"
    style: {
      fill: "#7F8C8D"
      stroke: "#566573"
      font-color: white
    }
  }
}

# ---------------------------------------------------------------------------------
# STATE MANAGEMENT: Modifiers & Caps
# ---------------------------------------------------------------------------------

State_Engine: {
  Modifier_Check: {
    shape: diamond
    label: "Is Scancode\nModifier?"
    style: {
      fill: "#3498DB"
      stroke: "#2980B9"
      font-color: white
    }
  }

  Modifier_State: "Kernel Global Keyboard State" {
    style: {
      fill: "#D4E6F1"
      stroke: "#3498DB"
      stroke-dash: 5
    }
    
    Shift: {
      label: "L_SHIFT (0x2A)\nR_SHIFT (0x36)"
      shape: circle
      style: {
        fill: "#85C1E9"
        stroke: "#3498DB"
      }
    }
    
    Ctrl: {
      label: "CTRL (0x1D)"
      shape: circle
      style: {
        fill: "#85C1E9"
        stroke: "#3498DB"
      }
    }
    
    Alt: {
      label: "ALT (0x38)"
      shape: circle
      style: {
        fill: "#85C1E9"
        stroke: "#3498DB"
      }
    }
    
    CapsLock: {
      label: "CAPS_LOCK (0x3A)"
      shape: circle
      style: {
        fill: "#F9E79F"
        stroke: "#F1C40F"
        double-border: true
      }
    }
  }
}

# ---------------------------------------------------------------------------------
# TRANSLATION: ASCII Lookups
# ---------------------------------------------------------------------------------

Lookup_Tables: {
  label: "Translation Tables (Set 1)"
  style: {
    fill: "#E8DAEF"
    stroke: "#9B59B6"
  }
  
  Normal_Table: {
    label: "scancode_to_ascii[128]"
    shape: class
    style: {
      fill: "#D5DBDB"
      stroke: "#7F8C8D"
    }
    "0x1E": "0x61 ('a')"
    "0x30": "0x62 ('b')"
    "0x2E": "0x63 ('c')"
    "..." : "..."
  }
  
  Shift_Table: {
    label: "scancode_to_ascii_shift[128]"
    shape: class
    style: {
      fill: "#D5F5E3"
      stroke: "#27AE60"
    }
    "0x1E": "0x41 ('A')"
    "0x30": "0x42 ('B')"
    "0x2E": "0x43 ('C')"
    "..." : "..."
  }
}

Caps_Logic: {
  shape: diamond
  label: "Case Transformation\n(Shift ^ CapsLock)"
  style: {
    fill: "#F1C40F"
    stroke: "#D4AC0D"
    font-color: "#1A5276"
  }
}

ASCII_Result: {
  label: "FINAL ASCII CHAR\n(AL Register)"
  style: {
    fill: "#1ABC9C"
    stroke: "#16A085"
    font-color: white
    bold: true
  }
}

# ---------------------------------------------------------------------------------
# DATA SINK: Ring Buffer
# ---------------------------------------------------------------------------------

Kernel_Data: {
  Keyboard_Buffer: {
    label: "tty_input_buffer\n(Circular / Lockless)"
    shape: cylinder
    style: {
      fill: "#2ECC71"
      stroke: "#27AE60"
      font-color: white
      shadow: true
    }
    
    Buffer_Struct: {
      shape: sql_table
      head: "uint16_t" {constraint: "Read Pointer"}
      tail: "uint16_t" {constraint: "Write Pointer"}
      data: "uint8_t[256]" {constraint: "Raw ASCII Data"}
    }
  }
}

EOI_Signal: {
  label: "IRQ ACK (EOI)\noutb(0x20, 0x20)"
  shape: oval
  style: {
    fill: "#E74C3C"
    stroke: "#C0392B"
    font-color: white
    bold: true
  }
}

# ---------------------------------------------------------------------------------
# CONNECTIONS (SEQUENTIAL FLOW)
# ---------------------------------------------------------------------------------

Hardware.IRQ1 -> Hardware.Keyboard_Controller: "ASSERT IRQ Line" {
  style: {
    stroke: "#C0392B"
    stroke-width: 3
    animated: true
  }
}

Hardware.Keyboard_Controller.Port_0x60 -> Hardware.Keyboard_Controller.Scancode_Byte: "FETCH DATA"
Hardware.Keyboard_Controller.Scancode_Byte -> ISR_Parsing.Bit7_Check

ISR_Parsing.Bit7_Check -> ISR_Parsing.Make_Code: "Bit 7 == 0 (Make)" {
  style: {
    stroke: "#27AE60"
    stroke-width: 2
  }
}

ISR_Parsing.Bit7_Check -> ISR_Parsing.Break_Code: "Bit 7 == 1 (Break)" {
  style: {
    stroke: "#7F8C8D"
    stroke-width: 2
    stroke-dash: 3
  }
}

ISR_Parsing.Make_Code -> State_Engine.Modifier_Check

State_Engine.Modifier_Check -> State_Engine.Modifier_State.Shift: "Scan 0x2A/0x36" {
  style: { stroke: "#3498DB"; stroke-dash: 3 }
}
State_Engine.Modifier_Check -> State_Engine.Modifier_State.Ctrl: "Scan 0x1D" {
  style: { stroke: "#3498DB"; stroke-dash: 3 }
}
State_Engine.Modifier_Check -> State_Engine.Modifier_State.CapsLock: "Scan 0x3A" {
  style: { stroke: "#F1C40F"; stroke-dash: 3 }
}

State_Engine.Modifier_Check -> Lookup_Tables.Normal_Table: "Map to ASCII" {
  style: { stroke: "#9B59B6" }
}

Lookup_Tables.Normal_Table -> Caps_Logic: "Base ASCII"
Lookup_Tables.Shift_Table -> Caps_Logic: "Shifted ASCII" {
  style: { stroke: "#27AE60" }
}

Caps_Logic -> ASCII_Result: "XOR Case Logic"
ASCII_Result -> Kernel_Data.Keyboard_Buffer: "Enqueue Byte" {
  style: {
    stroke: "#16A085"
    stroke-width: 2
  }
}

ISR_Parsing.Break_Code -> EOI_Signal: "Update State & Return" {
  style: { stroke: "#7F8C8D"; stroke-dash: 5 }
}

Kernel_Data.Keyboard_Buffer -> EOI_Signal: "Complete ISR" {
  style: {
    stroke: "#E74C3C"
    stroke-width: 2
  }
}

# ---------------------------------------------------------------------------------
# DOCUMENTATION ANNOTATIONS
# ---------------------------------------------------------------------------------

Hardware_Spec: {
  label: |md
    ### Scancode Set 1 (IBM PC/XT)
    - **Make**: Byte read directly from 0x60.
    - **Break**: Make code with bit 7 (0x80) set.
    - **Timing**: Controller status bit 0 must be 1 before reading 0x60.
  |
  near: top-left
  style: {
    fill: "#FEF9E7"
    stroke: "#F9E79F"
    stroke-dash: 3
  }
}

Buffer_Spec: {
  label: |md
    ### Buffer Management
    - **Atomic**: Interrupts must be disabled (`cli/sti`) during tail updates.
    - **Overflow**: If `(tail + 1) % 256 == head`, the buffer is full; drop input.
    - **Consumption**: TTY driver reads via `head` index.
  |
  near: bottom-right
  style: {
    fill: "#E8F8F5"
    stroke: "#1ABC9C"
    stroke-dash: 3
  }
}

Logic_Spec: {
  # Fix: Use |'md ... '| to escape pipe characters in Markdown tables
  label: |'md
    ### Transformation Matrix
    | Key | Shift | Caps | Result |
    |---|---|---|---|
    | 'a' | 0 | 0 | 'a' |
    | 'a' | 1 | 0 | 'A' |
    | 'a' | 0 | 1 | 'A' |
    | 'a' | 1 | 1 | 'a' |
  '|
  near: bottom-left
  style: {
    fill: "#FEF9E7"
    stroke: "#F1C40F"
    stroke-dash: 3
  }
}