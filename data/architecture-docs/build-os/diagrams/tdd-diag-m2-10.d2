vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Exception Handler Register Dump
  CPU Exception → ISR → Full Register State Output
| {near: top-center}
# Exception Entry
exception_trigger: "Exception Occurs" {
  shape: oval
  style.fill: "#FFB4AB"
  style.stroke: "#BA1A1A"
  style.font-color: "#690003"
}
# CPU Hardware Actions
cpu_section: "CPU Hardware" {
  style.fill: "#FCE7C6"
  style.stroke: "#D6962D"
  push_stack: "Push to Stack" {
    shape: rectangle
    style.fill: "#FFE4B5"
  }
  stack_frame: "Stack Frame" {
    shape: rectangle
    grid-rows: 6
    grid-gap: 0
    eip_entry: "EIP (return address)"
    cs_entry: "CS (code segment)"
    eflags_entry: "EFLAGS"
    err_label: "Error Code" {
      style.fill: "#FFCDD2"
      style.bold: true
    }
    spacer: "(only vectors 8,10-14,17)" {
      style.fill: "#FFF9C4"
      style.font-size: 12
      style.italic: true
    }
    ss_esp_note: "SS:ESP (if Ring 3→0)" {
      style.fill: "#E1BEE7"
      style.italic: true
    }
  }
  load_handler: "Load IDT[n] → CS:EIP" {
    shape: rectangle
    style.fill: "#B5AFF6"
  }
}
# ISR Assembly Stub
isr_section: "ISR Assembly Stub" {
  style.fill: "#C7F1FF"
  style.stroke: "#0077B6"
  save_general: "pusha" {
    shape: rectangle
    tooltip: "EAX, ECX, EDX, EBX, ESP, EBP, ESI, EDI"
  }
  save_segments: "push DS,ES,FS,GS" {
    shape: rectangle
    tooltip: "Save all segment registers"
  }
  load_kernel_ds: "mov ax, 0x10\nmov ds,ax; mov es,ax" {
    shape: rectangle
    style.fill: "#B5AFF6"
  }
  call_handler: "call interrupt_handler" {
    shape: rectangle
    style.fill: "#88DCF7"
    style.bold: true
  }
}
# C Handler
handler_section: "C Handler (interrupts.c)" {
  style.fill: "#ACE1AF"
  style.stroke: "#2E7D32"
  dispatch: "Lookup handler[n]" {
    shape: diamond
  }
  exception_check: "vector < 32?" {
    shape: diamond
    style.fill: "#FFF9C4"
  }
  handle_exception: "handle_exception()" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.bold: true
  }
}
# Register Dump Output
output_section: "Console Output" {
  style.fill: "#263238"
  style.stroke: "#455A64"
  style.font-color: "#ECEFF1"
  header: "========== EXCEPTION ==========" {
    shape: text
    style.fill: transparent
    style.font-color: "#EF5350"
    style.bold: true
    style.font-size: 18
  }
  exception_name: "Exception: [NAME]" {
    shape: text
    style.fill: transparent
    style.font-color: "#FFA726"
    style.bold: true
  }
  error_code_line: "Error Code: 0xXXXXXXXX" {
    shape: text
    style.fill: transparent
    style.font-color: "#FFCC80"
  }
  cpu_regs: "CPU State" {
    shape: rectangle
    style.fill: "#37474F"
    style.stroke: "#607D8B"
    grid-columns: 2
    grid-gap: 4
    eip_line: "EIP: 0xXXXXXXXX"
    cs_line: "CS:  0xXXXX"
    eflags_line: "EFLAGS: 0xXXXXXXXX"
    spacer1: ""
    eax_line: "EAX: 0xXXXXXXXX"
    ebx_line: "EBX: 0xXXXXXXXX"
    ecx_line: "ECX: 0xXXXXXXXX"
    edx_line: "EDX: 0xXXXXXXXX"
    esi_line: "ESI: 0xXXXXXXXX"
    edi_line: "EDI: 0xXXXXXXXX"
    ebp_line: "EBP: 0xXXXXXXXX"
    esp_line: "ESP: 0xXXXXXXXX"
  }
  cr2_section: "Page Fault Only" {
    shape: rectangle
    style.fill: "#7B1FA2"
    style.stroke: "#E1BEE7"
    style.font-color: "#F3E5F5"
    cr2_label: "CR2: Faulting Address" {
      shape: text
      style.fill: transparent
      style.font-color: "#E1BEE7"
      style.bold: true
    }
    cr2_value: "CR2: 0xXXXXXXXX" {
      shape: text
      style.fill: transparent
      style.font-color: "#CE93D8"
      style.font-size: 16
      style.bold: true
    }
    error_decode: "Error Code Decode" {
      shape: text
      style.fill: transparent
      style.font-color: "#BA68C8"
    }
    decode_bits: |md
      P: 0=not present, 1=protection
      W: 0=read, 1=write
      U: 0=kernel, 1=user
    | {
      shape: text
      style.fill: transparent
      style.font-color: "#AB47BC"
      style.font-size: 12
    }
  }
  halt_line: "System halted." {
    shape: text
    style.fill: transparent
    style.font-color: "#EF5350"
    style.italic: true
  }
}
# CR2 Register (Page Fault Special)
cr2_reg: "CR2 Register" {
  shape: cylinder
  style.fill: "#E1BEE7"
  style.stroke: "#7B1FA2"
  tooltip: "CPU stores faulting linear address here"
}
# Exception Names Table
exception_table: "Exception Names (vectors 0-31)" {
  shape: sql_table
  vec: int {constraint: primary_key}
  name: string
  error_code: string
}
exception_table.vec: [0; 1; 2; 3; 6; 8; 13; 14; 18]
exception_table.name: ["Divide Error"; "Debug"; "NMI"; "Breakpoint"; "Invalid Opcode"; "Double Fault"; "General Protection"; "Page Fault"; "Machine Check"]
exception_table.error_code: ["No"; "No"; "No"; "No"; "No"; "Yes"; "Yes"; "Yes"; "No"]
# Data Flow Connections
exception_trigger -> cpu_section.push_stack: "triggers"
cpu_section.push_stack -> cpu_section.stack_frame: "builds frame"
cpu_section.stack_frame -> cpu_section.load_handler: "then"
cpu_section.load_handler -> isr_section.save_general: "jumps to ISR"
isr_section.save_general -> isr_section.save_segments: "then"
isr_section.save_segments -> isr_section.load_kernel_ds: "then"
isr_section.load_kernel_ds -> isr_section.call_handler: "with ESP arg"
isr_section.call_handler -> handler_section.dispatch: "calls"
handler_section.dispatch -> handler_section.exception_check: "no custom handler"
handler_section.exception_check -> handler_section.handle_exception: "yes (vector<32)"
handler_section.handle_exception -> output_section.header: "prints"
output_section.header -> output_section.exception_name: "→"
output_section.exception_name -> output_section.error_code_line: "→"
output_section.error_code_line -> output_section.cpu_regs: "→"
# Page Fault Special Path
cr2_reg -> output_section.cr2_section: "read on vector 14" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
  style.animated: true
}
output_section.cpu_regs -> output_section.cr2_section: "if int_no==14" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
output_section.cr2_section -> output_section.halt_line: "→"
# Legend
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  cpu_hw: "CPU Hardware" {
    shape: rectangle
    style.fill: "#FCE7C6"
  }
  isr_asm: "Assembly Stub" {
    shape: rectangle
    style.fill: "#C7F1FF"
  }
  c_handler: "C Handler" {
    shape: rectangle
    style.fill: "#ACE1AF"
  }
  output: "Console Output" {
    shape: rectangle
    style.fill: "#263238"
    style.font-color: white
  }
  special: "Page Fault Path" {
    shape: rectangle
    style.fill: "#E1BEE7"
  }
}