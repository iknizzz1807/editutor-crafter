direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: |md
  # Double Fault Prevention Strategy
  ## Exception 8 (Double Fault) Handling & Register Context
| {near: top-center}

# --- CLASSES FOR CONSISTENCY ---
classes: {
  hardware_level: {
    style: {
      fill: "#eceff1"
      stroke: "#455a64"
      stroke-width: 2
      double-border: true
    }
  }
  fault_escalation: {
    style: {
      fill: "#ffebee"
      stroke: "#c62828"
      stroke-width: 2
    }
  }
  recovery_logic: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
      stroke-width: 2
    }
  }
  bit_field: {
    shape: sql_table
    style: {
      fill: "#fff3e0"
      stroke: "#ef6c00"
    }
  }
}

# --- 1. NORMAL EXCEPTION FLOW ---
normal_exception: {
  label: "NORMAL EXCEPTION FLOW (IDT VECTOR 0-31)"
  class: hardware_level
  
  exc_trigger: "Exception Occurs\n(e.g., Divide by 0)" {
    shape: circle
    style.fill: "#c8e6c9"
  }
  idt_lookup: "IDT Lookup\n(Gate Descriptor)" {
    tooltip: "CPU finds gate for Vector"
    shape: rectangle
  }
  handler_run: "Standard ISR\n(saves state)" {
    shape: rectangle
  }
  resume: "iret\nResume Task" {
    shape: circle
    style.fill: "#a5d6a7"
  }
  
  exc_trigger -> idt_lookup: "Hardware Trap"
  idt_lookup -> handler_run: "CS:EIP Update"
  handler_run -> resume: "Pop Registers"
}

# --- 2. THE PROBLEM: FAULT ESCALATION ---
problem: {
  label: "EXCEPTION STACKING (FAULT ESCALATION)"
  class: fault_escalation
  
  exc1: "Exception #1\n(e.g., Page Fault)" {
    style.fill: "#ffcdd2"
  }
  handler1: "Primary Handler\nActive Context"
  
  exc2: "Exception #2\n(Fault in Handler)" {
    style.fill: "#ef9a9a"
    style.bold: true
  }
  
  handler2: "Double Fault Handler\n(Missing/Faulting)" {
    style.fill: "#ef9a9a"
  }
  
  triple: "EXCEPTION #3\nTRIPLE FAULT" {
    shape: diamond
    style.fill: "#e53935"
    style.font-color: white
    style.bold: true
  }
  
  cpu_reset: "CPU RESET\n(Hardware Reboot)" {
    shape: circle
    style.fill: "#b71c1c"
    style.font-color: white
    icon: https://icons.terrastruct.com/essentials%2F102-power.svg
  }
  
  exc1 -> handler1: "Push [EFLAGS, CS, EIP]"
  handler1 -> exc2: "Recursive Fault"
  exc2 -> handler2: "Attempt Vector 8"
  handler2 -> triple: "Gate Fail"
  triple -> cpu_reset: "Shutdown Signal"
}

# --- 3. THE SOLUTION: HANDLED DOUBLE FAULT ---
solution: {
  label: "MANAGED DOUBLE FAULT (RECOVERY/DIAGNOSTIC)"
  class: recovery_logic
  
  df_trigger: "Vector 8\nDOUBLE FAULT" {
    style.fill: "#bbdefb"
    style.bold: true
    shape: parallelogram
  }
  
  df_entry: "ASM ISR Stub\n(Context Save)"
  df_c_handler: "C Logic:\ndouble_fault_handler()"
  
  error_decode_proc: {
    label: "Error Code Parsing"
    style.fill: "#90caf9"
    bit0: "EXT Bit"
    bit1: "IDT Bit"
    bit2: "TI Bit"
    bits3_15: "Selector Index"
    bit0 -> bit1 -> bit2 -> bits3_15
  }
  
  diagnostic: "DUMP CPU STATE:\n• CR2 (Fault Addr)\n• ESP/EBP (Stack)\n• EIP (Instruction)" {
    style.fill: "#64b5f6"
    shape: cylinder
  }
  
  halt_forever: "KERNEL HALT\n(cli; hlt; jmp $)" {
    shape: diamond
    style.fill: "#1976d2"
    style.font-color: white
    style.bold: true
  }
  
  df_trigger -> df_entry -> df_c_handler -> error_decode_proc
  error_decode_proc -> diagnostic -> halt_forever
}

# --- 4. BIT-FIELD SPECIFICATION ---
error_code_bits: "Intel Exception Error Code (Selector Format)" {
  shape: sql_table
  class: bit_field
  "00:00": "EXT (External Event)" {constraint: "1 bit"}
  "01:01": "IDT (Descriptor Table)" {constraint: "1 bit"}
  "02:02": "TI (GDT/LDT Table)" {constraint: "1 bit"}
  "15:03": "Selector Index" {constraint: "13 bits"}
}

# --- 5. COMPARATIVE ANALYSIS BOARD ---
comparison: {
  label: "TRIPLE FAULT VS HANDLED DOUBLE FAULT"
  style.fill: "#f3e5f5"
  style.stroke: "#9c27b0"
  
  triple_fault: {
    label: "Scenario: No Handler 8"
    e1: "exc1"
    e2: "exc2"
    e3: "exc3"
    reset: "HARD REBOOT" {style.stroke: red; style.bold: true}
    
    e1 -> e2 -> e3: "Escalation"
    e3 -> reset
  }
  
  handled_df: {
    label: "Scenario: Valid Handler 8"
    ex1: "exc1"
    ex2: "exc2"
    df_handler: "Trapped #DF"
    debug: "SYSTEM STABLE\n(Emergency CLI)" {style.stroke: green}
    
    ex1 -> ex2 -> df_handler
    df_handler -> debug
  }
}

# --- 6. IMPLEMENTATION DETAILS ---
# Using |' ... '| to prevent $ characters or braces from triggering D2 substitutions/maps
no_iret_note: |'md
### CRITICAL DESIGN INVARIANT
**NO iret IN VECTOR 8**

Double Faults are essentially non-recoverable because the CPU state is inconsistent. 
Attempting to return (iret) using a corrupted stack or EIP context will immediately 
trigger a **Triple Fault**.
'| {
  style.fill: "#1565c0"
  style.font-color: white
}

asm_implementation: |'nasm
; Double Fault (Vector 8) Entry Point
isr8:
    cli              ; Disable all interrupts
    push byte 0      ; Double fault pushes its own error code, 
                     ; but we push 0 if dummy required
    push byte 8      ; Push ISR number (Vector 8)
    jmp isr_common   ; Jump to generic C-wrapper

; Diagnostic C Logic Implementation
void double_fault_handler(regs_t *r) {
    kprintf("--- CPU PANIC: DOUBLE FAULT ---\n");
    kprintf("Error Code: 0x%x\n", r->err_code);
    kprintf("CS:EIP: %x:%x\n", r->cs, r->eip);
    kprintf("ESP: %x | CR2: %x\n", r->esp, get_cr2());
    // No return allowed
    for(;;) { 
        __asm__("hlt"); 
    }
}
'|

# --- 7. GLOBAL ROUTING & ANNOTATIONS ---
normal_exception -> problem: "Handler Stack Overflow\nor Double Page Fault" {
  style.stroke: red
  style.stroke-dash: 5
  source-arrowhead: cross
}

problem -> solution: "Prevention Strategy:\nIST (Interrupt Stack Table)\nor Task Gate" {
  style.stroke: "#2196f3"
  style.stroke-width: 4
}

solution -> error_code_bits: "Parsed by"
solution -> comparison: "Enables System Stability"
asm_implementation -> solution: "C-Implementation" {
  style.stroke-dash: 3
}

# Positioning
no_iret_note.near: solution.halt_forever
asm_implementation.near: solution
error_code_bits.near: solution.error_decode_proc