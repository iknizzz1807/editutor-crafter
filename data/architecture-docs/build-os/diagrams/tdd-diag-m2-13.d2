vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    intel_reserved: "#8E24AA" # Purple: Intel Reserved Exceptions
    irq_data: "#1E88E5"       # Blue: Hardware IRQ Data
    success: "#43A047"        # Green: Valid Mapping
    padding: "#757575"        # Gray: Unused/Reserved Padding
    warning: "#FB8C00"        # Orange: Special Handling
    danger: "#E53935"         # Red: Conflict State
    header: "#4527A0"
  }
}

title: |md
  # x86 Interrupt Mapping & PIC Remapping
  **Technical Specification: IRQ Vector Displacement**
  *Reference: Intel® 64 and IA-32 Architectures Software Developer’s Manual, Vol 3A*
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# STATE 1: DEFAULT CONFIGURATION (CONFLICT)
# -----------------------------------------------------------------------------------------
before_remap: State: BIOS Default Mapping (Conflict) {
  style: {
    fill: "#FFF5F5"
    stroke: ${colors.danger}
    stroke-width: 4
    stroke-dash: 5
  }
  
  # Replacement for the broken near object: Integrated conflict marker
  conflict_marker: "⚠️ CRITICAL HARDWARE/SOFTWARE CONFLICT" {
    style: {
      fill: ${colors.danger}
      font-color: white
      bold: true
      stroke: black
      stroke-width: 2
      border-radius: 5
    }
  }

  summary: ||md
    ### Vector Range Conflict
    **Master PIC:** Base Offset 0x08
    **Slave PIC:** Base Offset 0x70
    **Result:** Hardware IRQs overlap with CPU Exceptions (0x00 - 0x1F).
    *Example: IRQ0 (Timer) and Vector 0x08 (Double Fault) are indistinguishable.*
  ||

  master_pic_ports: Master PIC (0x20/0x21) {
    shape: sql_table
    style.fill: ${colors.irq_data}
    header: "IRQ Line | Pin | Physical Source"
    irq0: "IRQ 0 | Pin 0 | PIT Timer"
    irq1: "IRQ 1 | Pin 1 | Keyboard"
    irq2: "IRQ 2 | Pin 2 | Slave Cascade"
    irq3: "IRQ 3 | Pin 3 | COM2"
    irq4: "IRQ 4 | Pin 4 | COM1"
  }

  idt_segment_1: Interrupt Descriptor Table (Conflicts) {
    shape: sql_table
    header: "Vector | CPU Usage / Hardware Overlap"
    v0: "0x00 | Divide-by-zero" {style.fill: ${colors.padding}}
    v7: "0x07 | Device Not Available" {style.fill: ${colors.padding}}
    v8: "0x08 | DOUBLE FAULT (CPU) / IRQ 0 (Timer)" {
      style.fill: ${colors.danger}
      style.bold: true
      style.font-color: white
    }
    v9: "0x09 | Coprocessor Segment Overrun / IRQ 1" {
      style.fill: ${colors.danger}
      style.font-color: white
    }
    v13: "0x0D | GENERAL PROTECTION FAULT / IRQ 5" {
      style.fill: ${colors.danger}
      style.font-color: white
    }
    v31: "0x1F | Reserved by Intel" {style.fill: ${colors.padding}}
  }

  # Conflict path visualization
  master_pic_ports.irq0 -> idt_segment_1.v8: "COLLISION: IRQ 0 -> Vector 0x08" {
    style: {
      stroke: ${colors.danger}
      stroke-width: 5
      animated: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# TRANSITION: THE INITIALIZATION COMMAND WORD (ICW) SEQUENCE
# -----------------------------------------------------------------------------------------
pic_init_logic: PIC Remapping Sequence (ICW) {
  shape: package
  style.fill: "#FAFAFA"
  style.stroke: ${colors.warning}
  
  step1: "ICW1 (0x11): Start Initialization"
  step2: "ICW2 Master (0x20): Set Base Offset to 32" {
    style.bold: true
    style.fill: ${colors.success}
    style.font-color: white
  }
  step3: "ICW2 Slave (0x28): Set Base Offset to 40" {
    style.bold: true
    style.fill: ${colors.success}
    style.font-color: white
  }
  step4: "ICW3: Define Cascade (Master: 0x04, Slave: 0x02)"
  step5: "ICW4 (0x01): Set 8086/88 Mode"
  
  step1 -> step2 -> step3 -> step4 -> step5
}

# -----------------------------------------------------------------------------------------
# STATE 2: REMAPPED CONFIGURATION (SUCCESS)
# -----------------------------------------------------------------------------------------
after_remap: State: Protected Mode Ready (Remapped) {
  style: {
    fill: "#F1F8E9"
    stroke: ${colors.success}
    stroke-width: 4
  }
  
  summary: ||md
    ### Clean Vector Range
    **New Master Base:** 0x20 (Vector 32)
    **New Slave Base:** 0x28 (Vector 40)
    **Safe Range:** IRQs map to 32-47, avoiding CPU Reserved space.
  ||

  # The Linear Address Space Layout
  vector_mapping: {
    grid-columns: 1
    
    cpu_reserved: Intel Reserved Space (0-31) {
      style: {
        fill: ${colors.intel_reserved}
        font-color: white
      }
      v0: "0x00 - 0x1F: Dedicated Exceptions (Non-Maskable)"
      v8: "0x08: Double Fault (Exclusively Exception)"
    }

    hardware_vectors: User Defined / Hardware IRQs (32-47) {
      style: {
        fill: ${colors.success}
        font-color: white
        bold: true
      }
      v32: "0x20: Master IRQ 0 (Timer)"
      v33: "0x21: Master IRQ 1 (Keyboard)"
      v40: "0x28: Slave IRQ 8 (RTC)"
      v47: "0x2F: Slave IRQ 15"
    }
  }

  pic_out: Hardware Output Lines {
    shape: sql_table
    header: "Physical IRQ Source | Target Vector"
    irq0: "IRQ 0 | 0x20 (32)"
    irq8: "IRQ 8 | 0x28 (40)"
  }

  # Valid Mapping Path
  pic_out.irq0 -> vector_mapping.hardware_vectors.v32: "Valid Mapping (Offset +32)" {
    style: {
      stroke: ${colors.success}
      stroke-width: 3
    }
  }
  pic_out.irq8 -> vector_mapping.hardware_vectors.v40: "Valid Mapping (Offset +32)" {
    style: {
      stroke: ${colors.success}
      stroke-width: 3
    }
  }
}

# -----------------------------------------------------------------------------------------
# DOCUMENTATION AND FLOW
# -----------------------------------------------------------------------------------------

# Documentation Legend
tech_notes: ||md
  ### x86 PIC Remapping Logic (Intel 8259A)
  The PIC is programmed via **Initialization Command Words (ICW)** to shift the IRQ base offsets.
  
  | Port | Function | Register | Description |
  | :--- | :--- | :--- | :--- |
  | **0x20** | Master Command | ICW1 | Init, Pulse, Level |
  | **0x21** | Master Data | ICW2 | **Base Vector Offset** |
  | **0xA0** | Slave Command | ICW1 | Init sequence |
  | **0xA1** | Slave Data | ICW2 | **Base Vector Offset** |
  
  **Translation Formula:** `CPU_Vector = Physical_IRQ_Pin + ICW2_Base_Address`
|| {near: bottom-center}

# Flow Connections between states
before_remap -> pic_init_logic: "Issue Initialization Sequence" {
  style: {
    stroke-width: 2
    stroke: ${colors.warning}
  }
}
pic_init_logic -> after_remap: "PIC Internal Offsets Re-latched" {
  style: {
    stroke-width: 2
    stroke: ${colors.success}
  }
}

# Global Style Overrides for Technical Readability
***.style.font-size: 16
(*** -> ***)[*]: {
  style.font-size: 14
  style.font-color: "#333333"
}