vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Virtual Address Decomposition (x86 32-bit)
  ## Two-Level Page Table Translation
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# ADDRESS REPRESENTATION & BIT POSITIONING
# -----------------------------------------------------------------------------------------

addr_container: {
  style: {
    stroke-width: 0
    fill: transparent
  }

  virtual_addr: {
    label: "32-bit Virtual Address: 0xC0101234"
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 4
      font: mono
      font-size: 24
      bold: true
    }
  }

  bit_markers: {
    grid-columns: 3
    grid-gap: 0
    
    b31_22: "[31:22]" { shape: text; style.font-size: 14; style.font: mono }
    b21_12: "[21:12]" { shape: text; style.font-size: 14; style.font: mono }
    b11_0: "[11:0]"   { shape: text; style.font-size: 14; style.font: mono }
  }
}

# -----------------------------------------------------------------------------------------
# DECOMPOSITION GRID (BIT EXTRACTION)
# -----------------------------------------------------------------------------------------

decomposition: {
  grid-columns: 3
  grid-gap: 20
  
  pd_index: {
    label: "Page Directory Index\n(10 bits)\nOffset: 31-22"
    tooltip: "Extracts high-order bits to find the Page Table"
    style: {
      fill: "#DBEAFE"
      stroke: "#2563EB"
      stroke-width: 3
      border-radius: 4
    }
    width: 200
    height: 100
  }
  
  pt_index: {
    label: "Page Table Index\n(10 bits)\nOffset: 21-12"
    tooltip: "Extracts middle bits to find the Physical Frame"
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 3
      border-radius: 4
    }
    width: 200
    height: 100
  }
  
  offset: {
    label: "Page Offset\n(12 bits)\nOffset: 11-0"
    tooltip: "Direct offset into the 4KB physical page"
    style: {
      fill: "#D1FAE5"
      stroke: "#059669"
      stroke-width: 3
      border-radius: 4
    }
    width: 200
    height: 100
  }
}

# -----------------------------------------------------------------------------------------
# MATHEMATICAL PROOFS & BINARY DATA
# -----------------------------------------------------------------------------------------

# Fixed Markdown Table using Advanced Block Strings |'md ... '|
calculation: {
  label: |'md
    ### Step-by-Step Translation (Value: 0xC0101234)
    | Field | Bit Range | Calculation | Hex Result | Decimal |
    | :--- | :---: | :--- | :---: | :---: |
    | **PD Index** | 31-22 | `(0xC0101234 >> 22) & 0x3FF` | `0x300` | 768 |
    | **PT Index** | 21-12 | `(0xC0101234 >> 12) & 0x3FF` | `0x101` | 257 |
    | **Offset**   | 11-0  | `0xC0101234 & 0xFFF`         | `0x234` | 564 |
  '|
  shape: rectangle
  style: {
    fill: "#FFFFFF"
    stroke: "#9CA3AF"
    stroke-width: 2
    border-radius: 8
    shadow: true
  }
}

binary_view: {
  label: |'md
    ### Binary Alignment
    text
    Hex:      C    0    1    0    1    2    3    4
    Binary: 1100 0000 0001 0000 0001 0010 0011 0100
            [--PD Index--] [--PT Index--] [---Offset---]
            1100000000     0100000001     001000110100
    
  '|
  style: {
    fill: "#F8FAFC"
    stroke: "#64748B"
    font: mono
  }
}

# -----------------------------------------------------------------------------------------
# HARDWARE STRUCTURES (PAGE TABLES)
# -----------------------------------------------------------------------------------------

pd_lookup: {
  label: "Page Directory (CR3 Points Here)"
  shape: cylinder
  style: {
    fill: "#DBEAFE"
    stroke: "#2563EB"
    stroke-width: 2
  }
  entry_768: {
    label: "PDE [768]\n(0x300)"
    style: {
      fill: "#2563EB"
      font-color: white
      bold: true
    }
  }
}

pt_lookup: {
  label: "Page Table"
  shape: cylinder
  style: {
    fill: "#FEF3C7"
    stroke: "#D97706"
    stroke-width: 2
  }
  entry_257: {
    label: "PTE [257]\n(0x101)"
    style: {
      fill: "#D97706"
      font-color: white
      bold: true
    }
  }
}

physical_addr: {
  label: "Target Physical Address\n[Physical Frame Base] + [Offset]"
  style: {
    fill: "#D1FAE5"
    stroke: "#059669"
    stroke-width: 4
    bold: true
    double-border: true
  }
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS & DATA FLOW
# -----------------------------------------------------------------------------------------

addr_container.virtual_addr -> decomposition.pd_index: "Extract 10msb" {
  style: { stroke: "#2563EB"; stroke-width: 2 }
}
addr_container.virtual_addr -> decomposition.pt_index: "Extract bits 21:12" {
  style: { stroke: "#D97706"; stroke-width: 2 }
}
addr_container.virtual_addr -> decomposition.offset: "Extract 12lsb" {
  style: { stroke: "#059669"; stroke-width: 2 }
}

decomposition.pd_index -> pd_lookup.entry_768: "Index into PD" {
  style: { stroke: "#2563EB"; stroke-width: 2 }
}

pd_lookup.entry_768 -> pt_lookup: "PDE contains\nPT Base Address" {
  style: { stroke: "#2563EB"; stroke-dash: 4 }
}

decomposition.pt_index -> pt_lookup.entry_257: "Index into PT" {
  style: { stroke: "#D97706"; stroke-width: 2 }
}

pt_lookup.entry_257 -> physical_addr: "PTE contains\nPhysical Frame" {
  style: { stroke: "#D97706"; stroke-dash: 4 }
}

decomposition.offset -> physical_addr: "Add as Byte Offset" {
  style: { stroke: "#059669"; stroke-width: 3 }
}

# -----------------------------------------------------------------------------------------
# METADATA & LEGEND
# -----------------------------------------------------------------------------------------

coverage_specs: {
  label: |md
    ### Architectural Coverage
    - **Total Address Space**: 4 GB (2^32)
    - **Page Directory**: 1024 PDEs (4 MB coverage per PDE)
    - **Page Table**: 1024 PTEs (4 KB coverage per PTE)
    - **Page Size**: 4096 Bytes
  |
  style: {
    fill: "#F3E8FF"
    stroke: "#9333EA"
    border-radius: 8
  }
}

legend: {
  near: bottom-right
  label: |md
    ### Field Color Mapping
    - 🟦 **Blue**: Directory Translation Path
    - 🟨 **Yellow**: Table Translation Path
    - 🟩 **Green**: Direct Offset Path
  |
  style: {
    fill: "#FAFAFA"
    stroke: "#E2E8F0"
    font-size: 12
  }
}