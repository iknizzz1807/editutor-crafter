direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Intel-Style Architectural Classes
classes: {
  register: {
    shape: rectangle
    style: {
      fill: "#E8D5B7"
      stroke: "#8B7355"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  memory_struct: {
    shape: rectangle
    style: {
      fill: "#D4E6F1"
      stroke: "#2874A6"
      stroke-width: 2
    }
  }
  cache_unit: {
    shape: hexagon
    style: {
      fill: "#D5F5E3"
      stroke: "#1E8449"
      stroke-width: 2
    }
  }
  timing_metric: {
    shape: rectangle
    style: {
      fill: "#FADBD8"
      stroke: "#C0392B"
      stroke-dash: 3
      font: mono
      font-size: 14
    }
  }
  logic_gate: {
    shape: diamond
    style: {
      fill: "#EBDEF0"
      stroke: "#8E44AD"
    }
  }
}

# 1. VIRTUAL ADDRESS DECOMPOSITION
va: Virtual Address (32-bit): 0xC0101234 {
  style.fill: "#FEF9E7"
  style.stroke: "#F1C40F"
  
  grid: {
    grid-columns: 3
    dir: "Directory Index (10 bits)\nBits [31:22]\nValue: 0x300" {
      style.fill: "#F9E79F"
      style.font: mono
    }
    tab: "Table Index (10 bits)\nBits [21:12]\nValue: 0x101" {
      style.fill: "#FAD7A0"
      style.font: mono
    }
    off: "Byte Offset (12 bits)\nBits [11:0]\nValue: 0x234" {
      style.fill: "#F5CBA7"
      style.font: mono
    }
  }
}

# 2. CPU CORE & REGISTERS
cpu: CPU Core {
  cr3: "CR3 (PDBR)\n[31:12] = 0x00100\n[11:0] = Flags" {
    class: register
  }
  mmu: MMU Logic {
    class: logic_gate
  }
}

# 3. TRANSLATION LOOKASIDE BUFFER
tlb: TLB (L1 DTLB) {
  style.fill: "#EAFAF1"
  hit_logic: {
    label: |md
      **TLB HIT** ✓
      Virtual Page: 0xC0101
      Physical Frame: 0x00100
    |
    class: cache_unit
  }
  miss_logic: "TLB MISS ✗\nBegin Hardware Walk" {
    style: {
      fill: "#FDEDEC"
      stroke: "#E74C3C"
      font-color: "#E74C3C"
      bold: true
    }
  }
}

# 4. MEMORY HIERARCHY - PAGE STRUCTURES
paging_structures: Paging Hierarchy (RAM) {
  
  page_directory: Page Directory (4KB) {
    class: memory_struct
    pde_entry: "PDE at 0x00100C00\nValue: 0x00151003\nBase -> 0x00151000" {
      style.fill: "#D6EAF8"
      style.stroke: "#2E86C1"
    }
  }

  page_table: Page Table (4KB) {
    class: memory_struct
    pte_entry: "PTE at 0x00151404\nValue: 0x00100007\nBase -> 0x00100000" {
      style.fill: "#D6EAF8"
      style.stroke: "#2E86C1"
    }
  }
}

# 5. PHYSICAL MEMORY
physical_ram: Physical RAM {
  target_frame: "Physical Frame: 0x00100\nBase Address: 0x00100000" {
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
    style.stroke-width: 3
  }
  
  resolved_address: "FINAL PHYSICAL ADDRESS\n0x00100234" {
    style: {
      fill: "#27AE60"
      font-color: white
      bold: true
      font-size: 20
      double-border: true
    }
  }
}

# 6. PERFORMANCE & TIMING
metrics: Latency Analysis {
  near: bottom-right
  l1_hit: "L1 TLB Hit\n1-4 Cycles" { class: timing_metric }
  walk_lat: "Page Walk Latency\n30-150 Cycles" { class: timing_metric }
  pf_lat: "Page Fault (I/O)\n~10^6 Cycles" { class: timing_metric }
}

# --- FLOW CONNECTIONS ---

# Virtual Address Deconstruction to MMU
va.grid.dir -> cpu.mmu: "Top 10 Bits"
va.grid.tab -> cpu.mmu: "Middle 10 Bits"
va.grid.off -> physical_ram.resolved_address: "Direct Offset (12b)" {
  style.stroke: orange
  style.stroke-width: 2
}

# MMU parallel check
cpu.cr3 -> cpu.mmu: "Root Pointer"
cpu.mmu -> tlb: "Lookup Tag"

# TLB Outcomes
tlb.hit_logic -> physical_ram.target_frame: "Bypass Walk (Fast Path)" {
  style: {
    stroke: "#27AE60"
    stroke-width: 4
    animated: true
  }
}

tlb.miss_logic -> paging_structures.page_directory.pde_entry: "1. Calculate PDE Address" {
  style.stroke-dash: 5
}

# The Walk
paging_structures.page_directory.pde_entry -> paging_structures.page_table.pte_entry: "2. Extract PT Base" {
  style.stroke: "#2980B9"
}
paging_structures.page_table.pte_entry -> physical_ram.target_frame: "3. Extract Frame Base" {
  style.stroke: "#2980B9"
}

# Final Result
physical_ram.target_frame -> physical_ram.resolved_address: "Concatenate"

# Legend/Annotation
note: |md
  ### Architectural Specifications
  - **Mode:** 32-bit Protected Mode (Non-PAE).
  - **PDE/PTE Size:** 4 Bytes.
  - **CR3:** Bits [31:12] point to Page Directory base (Physical).
  - **PDE Calculation:** CR3 + (Directory_Index * 4).
  - **PTE Calculation:** PDE.Base + (Table_Index * 4).
| {
  near: top-right
  style: {
    fill: "#FCF3CF"
    stroke: "#F1C40F"
  }
}