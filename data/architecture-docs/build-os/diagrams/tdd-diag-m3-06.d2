layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    pad: 40
  }
  colors: {
    used: "#E74C3C"
    free: "#27AE60"
    bitmap: "#9B59B6"
    kernel: "#3498DB"
    reserved: "#95A5A6"
    text_main: "#2C3E50"
    ptr: "#E67E22"
    padding: "#BDC3C7"
  }
}

title: |md
  # Physical Memory Manager (PMM) Initialization
  ### Physical Memory Map and Frame Allocation Strategy
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

memory_layout: Physical Memory Layout (4GB Address Space) {
  style.stroke-width: 4
  style.fill: "#F8F9F9"
  
  region_reserved: "0x00000000 - 0x000FFFFF" {
    label: |md
      ### Lower Memory (1MB)
      - **IVT/BDA/VGA/BIOS**
      - **Frames:** 0 to 255
      - **Status:** **RESERVED/USED**
    |
    style: {
      fill: "${colors.reserved}"
      stroke: "#7F8C8D"
      stroke-width: 2
    }
  }

  region_kernel: "0x00100000 - [K_END]" {
    label: |md
      ### Kernel Binary
      - `.text`, `.data`, `.bss`
      - **Start:** 1MB (Fixed)
      - **Status:** **USED**
    |
    style: {
      fill: "${colors.kernel}"
      stroke: "#2980B9"
      stroke-width: 2
    }
  }

  region_padding: "Padding" {
    label: "4KB Page Alignment Padding"
    style: {
      fill: "${colors.padding}"
      stroke-dash: 5
    }
  }

  region_bitmap: "[P_ALIGN(K_END)]" {
    label: |md
      ### PMM Bitmap
      - 1 bit per 4KB frame
      - **Size:** 128 KB
      - **Status:** **USED**
    |
    style: {
      fill: "${colors.bitmap}"
      stroke: "#8E44AD"
      stroke-dash: 3
    }
  }

  region_free: "[BM_END] - 0xFFFFFFFF" {
    label: |md
      ### Available RAM
      - **Range:** Post-Bitmap to EOF
      - **Status:** **FREE**
    |
    style: {
      fill: "${colors.free}"
      stroke: "#1E8449"
    }
  }
}

bitmap_logic: Bitmap Implementation Details {
  style.stroke: "${colors.bitmap}"
  
  structure: {
    shape: sql_table
    "uint32_t bitmap[]": "Memory Layout" {constraint: "Array"}
    "Index [0]": "Bits 0-31 (0x0 - 0x1FFFF)" {constraint: "0xFFFFFFFF"}
    "Index [1]": "Bits 32-63 (0x20000 - 0x3FFFF)" {constraint: "0x00000000"}
    "Index [N]": "Bit i = Frame (i * 4096)" {constraint: "State"}
  }

  macros: |c
    /* Frame Access Logic */
    #define PAGE_SIZE 4096
    #define BITMAP_IDX(f) ((f) / 32)
    #define BITMAP_OFF(f) ((f) % 32)

    void pmm_mark_used(uintptr_t addr) {
        uint32_t frame = addr / PAGE_SIZE;
        bitmap[BITMAP_IDX(frame)] |= (1 << BITMAP_OFF(frame));
    }
  | {
    style.font-size: 14
  }
  
  structure -> macros: "API Access"
}

init_flow: Initialization Sequence (Step-by-Step) {
  style.fill: "#F4F6F7"

  s1: "1. Detect Memory" {
    tooltip: "Query E820 Map"
    style.fill: "#D4EFDF"
  }
  s2: "2. Calculate Bitmap" {
    label: "2. Size = (Total_RAM / 4096) / 8"
    style.fill: "#D4EFDF"
  }
  s3: "3. Locate Bitmap" {
    label: "3. Place @ PAGE_ALIGN(kernel_end)"
    style.fill: "#D4EFDF"
  }
  s4: "4. Zero Fill" {
    label: "4. memset(bitmap, 0, size)"
    style.fill: "#D4EFDF"
  }
  s5: "5. Mark Low Mem" {
    label: "5. Mark 0x0 - 0x100000 USED"
    style: {
      fill: "${colors.used}"
      font-color: white
      bold: true
    }
  }
  s6: "6. Mark Kernel" {
    label: "6. Mark Kernel + Bitmap USED"
    style: {
      fill: "${colors.used}"
      font-color: white
      bold: true
    }
  }

  s1 -> s2 -> s3 -> s4 -> s5 -> s6
}

pmm_state: PMM_Manager (Post-Init State) {
  shape: class
  
  "uint32_t* bitmap": "0x0010A000"
  "size_t total_frames": "1048576"
  "size_t used_frames": "288 (LowMem + Kernel)"
  "size_t free_frames": "1048288"
  
  "+ pmm_init(mmap)": "void"
  "+ pmm_alloc_frame()": "uintptr_t"
  "+ pmm_free_frame(ptr)": "void"
}

# Architectural relationships
memory_layout -> init_flow: "Defines Address Constraints"
init_flow -> bitmap_logic: "Writes Initial Bitmask"
bitmap_logic -> pmm_state: "Populates Data Structure"
init_flow -> pmm_state: "Sets Runtime Statistics"

legend: |md
  ### Engineering Specs
  - **Memory Model:** Flat physical addressing (Pre-Paging).
  - **Alignment:** 4096B (Page) strict requirement.
  - **Reserved Frames:** 0-255 are non-allocatable (Hardware protection).
  - **Bitmap Density:** 1 bit = 4KB. 128KB bitmap covers 4GB RAM.
| {
  near: bottom-right
  style: {
    stroke: "#2C3E50"
    fill: "#FEF9E7"
    border-radius: 5
  }
}