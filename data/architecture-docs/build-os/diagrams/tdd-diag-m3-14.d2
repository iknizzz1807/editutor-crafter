vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header-bg: "#E8E4F0"
    header-border: "#7C6FA0"
    size-field: "#C5E8B7"
    free-field: "#FFE5B4"
    magic-field: "#B4D4FF"
    pointer-field: "#FFB4B4"
    padding: "#F0F0F0"
    allocated-magic: "#FF6B6B"
    free-magic: "#4ECDC4"
  }
}
title: |md
  # Kernel Heap Block Header
  `block_header_t` — 12 bytes (8-byte aligned)
| {near: top-center}
direction: right
block_header: {
  label: block_header_t
  style: {
    fill: transparent
    stroke: "transparent"
  }
  fields: {
    grid-columns: 4
    grid-gap: 0
    style.fill: transparent
    # Row 1: Field names
    f_name: "Field" {
      style: {
        fill: ${colors.header-bg}
        bold: true
        font-size: 20
      }
    }
    offset_name: "Offset" {
      style: {
        fill: ${colors.header-bg}
        bold: true
        font-size: 20
      }
    }
    size_name: "Size" {
      style: {
        fill: ${colors.header-bg}
        bold: true
        font-size: 20
      }
    }
    desc_name: "Description" {
      style: {
        fill: ${colors.header-bg}
        bold: true
        font-size: 20
      }
    }
    # Row 2: size field
    size_field: "size" {
      style: {
        fill: ${colors.size-field}
        font: mono
        font-size: 18
      }
    }
    size_offset: "0x00" {
      style: {
        fill: ${colors.size-field}
        font: mono
        font-size: 18
      }
    }
    size_bytes: "4 bytes" {
      style: {
        fill: ${colors.size-field}
        font: mono
        font-size: 18
      }
    }
    size_desc: "Data area size (excludes header)" {
      style: {
        fill: ${colors.size-field}
        font-size: 16
      }
    }
    # Row 3: free field
    free_field: "free" {
      style: {
        fill: ${colors.free-field}
        font: mono
        font-size: 18
      }
    }
    free_offset: "0x04" {
      style: {
        fill: ${colors.free-field}
        font: mono
        font-size: 18
      }
    }
    free_bytes: "1 byte" {
      style: {
        fill: ${colors.free-field}
        font: mono
        font-size: 18
      }
    }
    free_desc: "1 = free block, 0 = allocated" {
      style: {
        fill: ${colors.free-field}
        font-size: 16
      }
    }
    # Row 4: magic field
    magic_field: "magic" {
      style: {
        fill: ${colors.magic-field}
        font: mono
        font-size: 18
      }
    }
    magic_offset: "0x05" {
      style: {
        fill: ${colors.magic-field}
        font: mono
        font-size: 18
      }
    }
    magic_bytes: "1 byte" {
      style: {
        fill: ${colors.magic-field}
        font: mono
        font-size: 18
      }
    }
    magic_desc: "0xA1 allocated, 0xF1 free" {
      style: {
        fill: ${colors.magic-field}
        font: mono
        font-size: 16
      }
    }
    # Row 5: padding
    pad_field: "_pad[2]" {
      style: {
        fill: ${colors.padding}
        font: mono
        font-size: 18
      }
    }
    pad_offset: "0x06" {
      style: {
        fill: ${colors.padding}
        font: mono
        font-size: 18
      }
    }
    pad_bytes: "2 bytes" {
      style: {
        fill: ${colors.padding}
        font: mono
        font-size: 18
      }
    }
    pad_desc: "Alignment padding" {
      style: {
        fill: ${colors.padding}
        font-size: 16
      }
    }
    # Row 6: next pointer
    next_field: "next" {
      style: {
        fill: ${colors.pointer-field}
        font: mono
        font-size: 18
      }
    }
    next_offset: "0x08" {
      style: {
        fill: ${colors.pointer-field}
        font: mono
        font-size: 18
      }
    }
    next_bytes: "4 bytes" {
      style: {
        fill: ${colors.pointer-field}
        font: mono
        font-size: 18
      }
    }
    next_desc: "Next block in free list" {
      style: {
        fill: ${colors.pointer-field}
        font-size: 16
      }
    }
  }
}
memory_layout: {
  label: "Memory Layout (12 bytes total)"
  style: {
    fill: transparent
    stroke: ${colors.header-border}
    stroke-width: 2
  }
  grid-columns: 6
  grid-gap: 0
  # Byte addresses
  addr0: "0x00" {style: {fill: ${colors.size-field}; font: mono; font-size: 14}}
  addr4: "0x04" {style: {fill: ${colors.free-field}; font: mono; font-size: 14}}
  addr5: "0x05" {style: {fill: ${colors.magic-field}; font: mono; font-size: 14}}
  addr6: "0x06" {style: {fill: ${colors.padding}; font: mono; font-size: 14}}
  addr8: "0x08" {style: {fill: ${colors.pointer-field}; font: mono; font-size: 14}}
  addr12: "0x0C" {style: {fill: white; font: mono; font-size: 14}}
  # Content row
  c_size: "size\n(4B)" {style: {fill: ${colors.size-field}; bold: true; font-size: 16}}
  c_free: "free\n(1B)" {style: {fill: ${colors.free-field}; bold: true; font-size: 16}}
  c_magic: "magic\n(1B)" {style: {fill: ${colors.magic-field}; bold: true; font-size: 16}}
  c_pad: "_pad\n(2B)" {style: {fill: ${colors.padding}; font-size: 16}}
  c_next: "next ptr\n(4B)" {style: {fill: ${colors.pointer-field}; bold: true; font-size: 16}}
  c_data: "DATA..." {style: {fill: white; font-size: 16; italic: true}}
}
magic_values: {
  label: "Magic Byte Values"
  style: {
    fill: transparent
    stroke: ${colors.header-border}
    stroke-dash: 3
  }
  grid-columns: 2
  grid-gap: 10
  alloc_label: "ALLOCATED" {
    style: {
      fill: ${colors.allocated-magic}
      bold: true
      font-size: 18
    }
  }
  alloc_value: "0xA1 (1010 0001)" {
    style: {
      fill: ${colors.allocated-magic}
      font: mono
      font-size: 16
    }
  }
  free_label: "FREE" {
    style: {
      fill: ${colors.free-magic}
      bold: true
      font-size: 18
    }
  }
  free_value: "0xF1 (1111 0001)" {
    style: {
      fill: ${colors.free-magic}
      font: mono
      font-size: 16
    }
  }
}
code_example: |md
  c
  typedef struct block_header {
      uint32_t size;              // Data area size
      uint8_t  free;              // 1=free, 0=allocated
      uint8_t  magic;             // 0xA1 or 0xF1
      uint8_t  _pad[2];           // Alignment
      struct block_header *next;  // Free list link
  } block_header_t;               // Total: 12 bytes
  
| {near: bottom-center}
# Connection arrows
block_header -> memory_layout: "Layout"
memory_layout -> magic_values: "Values"
# Annotations
annotation: |md
  **Key Points:**
  - Header is 12 bytes, data area follows immediately
  - User receives pointer at `header + 12`
  - To get header from pointer: `hdr = ptr - 12`
  - Magic enables corruption detection
| {near: center-right}