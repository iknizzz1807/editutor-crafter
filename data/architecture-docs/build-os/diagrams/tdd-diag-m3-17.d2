vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  # Technical Design Artist Palette
  colors: {
    header_v: "#7B68EE" # Purple for Virtual
    header_p: "#6C3483" # Dark Purple for Physical
    text_sec: "#2E86C1" # Blue for Code
    rodata_sec: "#5DADE2" # Light Blue for RO
    data_sec: "#28B463" # Green for Data
    bss_sec: "#F4D03F" # Yellow for BSS
    padding: "#AEB6BF" # Gray for Alignment Padding
    pointer: "#E67E22" # Orange for Address Mapping
    virtual_bg: "#FBFCFC"
    physical_bg: "#FEF9E7"
  }
}

title: |md
  # TECHNICAL SPECIFICATION: HIGHER-HALF KERNEL MEMORY LAYOUT
  ## Linker Strategy: VMA (Virtual) vs LMA (Physical) Redirection
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# CLASSES: INTEL MANUAL STYLE
# -----------------------------------------------------------------------------------------
classes: {
  memory_segment: {
    width: 450
    style: {
      stroke: "#2C3E50"
      stroke-width: 2
      font-size: 14
      bold: true
      font-color: white
      shadow: true
    }
  }
  address_label: {
    shape: text
    style: {
      font: mono
      font-size: 12
      font-color: "#1B2631"
    }
  }
  container_box: {
    style: {
      stroke-width: 4
      border-radius: 10
      double-border: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# ADDRESS SPACE DEFINITION
# -----------------------------------------------------------------------------------------
memory_map: {
  
  # --- VIRTUAL MEMORY (VMA) ---
  # Base: 0xC0000000 (3GB Mark)
  # -----------------------------------------------------------------------------------------
  virtual_space: {
    label: "VIRTUAL ADDRESS SPACE (VMA)\nExecution Target / Symbol Addresses"
    class: container_box
    style.fill: "${colors.virtual_bg}"
    style.stroke: "#2E86C1"

    v_header: "VMA LAYOUT" {
      style.fill: "${colors.header_v}"
      style.font-color: white
    }

    # Offsets and Fields
    offset_v0: "0xC0100000" { class: address_label }
    v_text: ".text (Kernel Code)" {
      class: memory_segment
      style.fill: "${colors.text_sec}"
      tooltip: "Executable instructions. VMA = LMA + 0xC0000000"
    }
    size_v0: "Size: 154 KB" { shape: text; style.font-size: 10 }

    offset_v1: "0xC0126800" { class: address_label }
    v_rodata: ".rodata (Strings/Constants)" {
      class: memory_segment
      style.fill: "${colors.rodata_sec}"
    }
    size_v1: "Size: 42 KB" { shape: text; style.font-size: 10 }

    # Page Alignment Gap (4KB boundary)
    v_padding: "ALIGN(4K)" {
      class: memory_segment
      style.fill: "${colors.padding}"
      style.stroke-dash: 3
    }

    offset_v2: "0xC0132000" { class: address_label }
    v_data: ".data (Global Vars)" {
      class: memory_segment
      style.fill: "${colors.data_sec}"
    }
    size_v2: "Size: 12 KB" { shape: text; style.font-size: 10 }

    offset_v3: "0xC0135000" { class: address_label }
    v_bss: ".bss (Zero-Init)" {
      class: memory_segment
      style.fill: "${colors.bss_sec}"
      style.font-color: "#1B2631"
    }
    size_v3: "Size: 1.2 MB" { shape: text; style.font-size: 10 }

    v_header -> offset_v0 -> v_text -> offset_v1 -> v_rodata -> v_padding -> offset_v2 -> v_data -> offset_v3 -> v_bss
    v_text -> size_v0
    v_rodata -> size_v1
    v_data -> size_v2
    v_bss -> size_v3
  }

  # --- PHYSICAL RAM (LMA) ---
  # Base: 0x00100000 (1MB Mark)
  # -----------------------------------------------------------------------------------------
  physical_ram: {
    label: "PHYSICAL MEMORY (LMA)\nLoad Target / Binary Image on Disk"
    class: container_box
    style.fill: "${colors.physical_bg}"
    style.stroke: "#D35400"

    p_header: "LMA LAYOUT" {
      style.fill: "${colors.header_p}"
      style.font-color: white
    }

    offset_p0: "0x00100000" { class: address_label }
    p_text: ".text (Load Image)" {
      class: memory_segment
      style.fill: "${colors.text_sec}"
      style.fill-pattern: lines
    }

    offset_p1: "0x00126800" { class: address_label }
    p_rodata: ".rodata (Load Image)" {
      class: memory_segment
      style.fill: "${colors.rodata_sec}"
      style.fill-pattern: lines
    }

    offset_p2: "0x00132000" { class: address_label }
    p_data: ".data (Load Image)" {
      class: memory_segment
      style.fill: "${colors.data_sec}"
      style.fill-pattern: lines
    }

    offset_p3: "0x00135000" { class: address_label }
    p_bss_reserved: ".bss (Space Only)" {
      class: memory_segment
      style.fill: "${colors.bss_sec}"
      style.stroke-dash: 5
      style.font-color: "#1B2631"
      tooltip: "BSS takes no space in binary, only reserved in RAM"
    }

    p_header -> offset_p0 -> p_text -> offset_p1 -> p_rodata -> offset_p2 -> p_data -> offset_p3 -> p_bss_reserved
  }
}

# -----------------------------------------------------------------------------------------
# MAPPING CONNECTIONS & ANNOTATIONS
# -----------------------------------------------------------------------------------------

# Linker Redirection Arrows
memory_map.virtual_space.v_text -> memory_map.physical_ram.p_text: "AT(ADDR(.text) - 0xC0000000)" {
  style: {
    stroke: "${colors.pointer}"
    stroke-width: 4
    stroke-dash: 5
    animated: true
  }
}

memory_map.virtual_space.v_data -> memory_map.physical_ram.p_data: "Physical Backing" {
  style: {
    stroke: "${colors.pointer}"
    stroke-width: 2
    stroke-dash: 3
  }
}

# -----------------------------------------------------------------------------------------
# TECHNICAL DOCUMENTATION
# -----------------------------------------------------------------------------------------

linker_logic: |go
  /* Linker Script Syntax: Higher-Half Kernel */
  SECTIONS {
    /* 1. Set Virtual Counter to 3GB + 1MB */
    . = 0xC0100000;

    /* 2. Map Code to VMA, redirect Load to LMA */
    .text : AT(ADDR(.text) - 0xC0000000) {
      *(.text)
    }

    /* 3. Initialized data also redirected */
    .data : AT(ADDR(.data) - 0xC0000000) {
      *(.data)
    }

    /* 4. BSS: Only VMA location matters */
    .bss : AT(ADDR(.bss) - 0xC0000000) {
      *(.bss)
      *(COMMON)
    }
  }
| {
  near: bottom-left
  style: {
    stroke: "#34495E"
    fill: "#F8F9F9"
    font-size: 14
  }
}

# FIXED: Moved connections outside the SQL Table container to prevent "cannot enter itself" errors
execution_flow: {
  near: bottom-right
  label: "Kernel Boot Sequence (Higher-Half Transition)"
  shape: sql_table
  
  step1: "1. Bootloader Phase" { label: "Binary loaded to Phys: 0x00100000 (1MB)" }
  step2: "2. Early Paging"   { label: "Identity maps [0..4MB] and [3GB..3GB+4MB]" }
  step3: "3. Jump to Higher" { label: "EIP redirected to 0xC010xxxx (Virtual address)" }
  step4: "4. Cleanup"        { label: "Remove lower-half identity mapping" }
}

execution_flow.step1 -> execution_flow.step2: "Entry"
execution_flow.step2 -> execution_flow.step3: "Enable PG"
execution_flow.step3 -> execution_flow.step4: "Virtual Env"

legend_box: {
  near: bottom-center
  VMA: "Execution Address (Virtual)" {
    style.fill: "${colors.text_sec}"
  }
  LMA: "Load Address (Physical Image)" {
    style.fill: "${colors.text_sec}"
    style.fill-pattern: lines
  }
}

page_note: |md
  ### Cache & Page Alignment
  - Kernel sections are aligned to **4096B** (1 page).
  - This allows setting individual page permissions (NX, RO).
  - Dashed Gray areas indicate internal fragmentation for alignment.
| {
  near: memory_map.virtual_space.v_padding
  style.fill: "#FDFEFE"
}