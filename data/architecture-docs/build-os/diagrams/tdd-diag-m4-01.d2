vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Process Control Block (PCB) Layout
  Total Size: 112 bytes (0x70)
| {near: top-center}
PCB: {
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  style.border-radius: 8
  # Identification Section
  identification: {
    style.fill: "#16213e"
    style.stroke: "#0f3460"
    style.border-radius: 4
    label: |md
      **Identification**
      Offsets 0x00 - 0x27 (40 bytes)
    |
    pid: {
      label: |md
        **pid**
        `uint32_t`
        Offset: 0x00-0x03 (4 bytes)
        Unique process identifier
      |
      style.fill: "#e94560"
      style.stroke: "#ff6b6b"
      style.font-color: white
    }
    name: {
      label: |md
        **name[32]**
        `char[32]`
        Offset: 0x04-0x23 (32 bytes)
        Process name (null-terminated)
      |
      style.fill: "#e94560"
      style.stroke: "#ff6b6b"
      style.font-color: white
    }
    state: {
      label: |md
        **state**
        `process_state_t`
        Offset: 0x24-0x27 (4 bytes)
        READY/RUNNING/BLOCKED/TERMINATED
      |
      style.fill: "#e94560"
      style.stroke: "#ff6b6b"
      style.font-color: white
    }
  }
  # Scheduling Section
  scheduling: {
    style.fill: "#16213e"
    style.stroke: "#0f3460"
    style.border-radius: 4
    label: |md
      **Scheduling State**
      Offsets 0x28 - 0x2F (8 bytes)
    |
    priority: {
      label: |md
        **priority**
        `uint32_t`
        Offset: 0x28-0x2B (4 bytes)
        Scheduling priority (future use)
      |
      style.fill: "#0f4c75"
      style.stroke: "#3282b8"
      style.font-color: white
    }
    time_slice: {
      label: |md
        **time_slice**
        `uint32_t`
        Offset: 0x2C-0x2F (4 bytes)
        Remaining ticks (10 = 100ms)
      |
      style.fill: "#0f4c75"
      style.stroke: "#3282b8"
      style.font-color: white
    }
  }
  identification -> scheduling
  # Saved Registers Section
  registers: {
    style.fill: "#16213e"
    style.stroke: "#0f3460"
    style.border-radius: 4
    label: |md
      **Saved Register State**
      Offsets 0x30 - 0x57 (40 bytes)
      ★ MUST match assembly offsets exactly
    |
    eax: {
      label: |md
        **EAX** @ 0x30
        Saved accumulator
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    ebx: {
      label: |md
        **EBX** @ 0x34
        Saved base register
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    ecx: {
      label: |md
        **ECX** @ 0x38
        Saved counter
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    edx: {
      label: |md
        **EDX** @ 0x3C
        Saved data register
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    esi: {
      label: |md
        **ESI** @ 0x40
        Saved source index
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    edi: {
      label: |md
        **EDI** @ 0x44
        Saved destination index
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    ebp: {
      label: |md
        **EBP** @ 0x48
        Saved base pointer
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    esp: {
      label: |md
        **ESP** @ 0x4C
        ★ Stack pointer (critical)
      |
      style.fill: "#fdcb6e"
      style.stroke: "#f39c12"
      style.font-color: black
    }
    eip: {
      label: |md
        **EIP** @ 0x50
        ★ Instruction pointer (critical)
      |
      style.fill: "#fdcb6e"
      style.stroke: "#f39c12"
      style.font-color: black
    }
    eflags: {
      label: |md
        **EFLAGS** @ 0x54
        Saved flags (IF, etc.)
      |
      style.fill: "#00b894"
      style.stroke: "#00cec9"
      style.font-color: white
    }
    eax -> ebx -> ecx -> edx -> esi -> edi -> ebp -> esp -> eip -> eflags
  }
  scheduling -> registers
  # Memory Management Section
  memory: {
    style.fill: "#16213e"
    style.stroke: "#0f3460"
    style.border-radius: 4
    label: |md
      **Memory Management**
      Offsets 0x58 - 0x5F (12 bytes)
    |
    page_directory: {
      label: |md
        **page_directory**
        `uint32_t`
        Offset: 0x58-0x5B (4 bytes)
        Physical address of CR3
        0 = use kernel's PD
      |
      style.fill: "#6c5ce7"
      style.stroke: "#a29bfe"
      style.font-color: white
    }
    kernel_stack: {
      label: |md
        **kernel_stack**
        `uint32_t`
        Offset: 0x5C-0x5F (4 bytes)
        ★ TSS.ESP0 for Ring 3→0
      |
      style.fill: "#fdcb6e"
      style.stroke: "#f39c12"
      style.font-color: black
    }
    user_stack: {
      label: |md
        **user_stack**
        `uint32_t`
        Offset: 0x60-0x63 (4 bytes)
        User mode ESP
      |
      style.fill: "#6c5ce7"
      style.stroke: "#a29bfe"
      style.font-color: white
    }
    page_directory -> kernel_stack -> user_stack
  }
  registers -> memory
  # Entry Point
  entry: {
    style.fill: "#16213e"
    style.stroke: "#0f3460"
    style.border-radius: 4
    label: |md
      **Entry Point**
      Offset 0x64-0x67 (4 bytes)
    |
    entry_point: {
      label: |md
        **entry_point**
        `uint32_t`
        Offset: 0x64-0x67 (4 bytes)
        Initial EIP for process
      |
      style.fill: "#6c5ce7"
      style.stroke: "#a29bfe"
      style.font-color: white
    }
  }
  memory -> entry
  # Linked List Pointers
  pointers: {
    style.fill: "#16213e"
    style.stroke: "#0f3460"
    style.border-radius: 4
    label: |md
      **Linked List Pointers**
      Offsets 0x68 - 0x6F (8 bytes)
    |
    next: {
      label: |md
        **next**
        `process_t*`
        Offset: 0x68-0x6B (4 bytes)
        Next process in list
      |
      style.fill: "#b2bec3"
      style.stroke: "#dfe6e9"
      style.font-color: black
    }
    prev: {
      label: |md
        **prev**
        `process_t*`
        Offset: 0x6C-0x6F (4 bytes)
        Previous process in list
      |
      style.fill: "#b2bec3"
      style.stroke: "#dfe6e9"
      style.font-color: black
    }
    next -> prev
  }
  entry -> pointers
}
# Assembly Offset Reference
offsets: {
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  style.border-radius: 8
  label: |md
    **Assembly Offset Macros**
    Must match `struct process` exactly
  |
  code: |go
    // kernel/process.h
    #define PCB_PID           0x00
    #define PCB_NAME          0x04
    #define PCB_STATE         0x24
    #define PCB_PRIORITY      0x28
    #define PCB_TIME_SLICE    0x2C
    #define PCB_EAX           0x30
    #define PCB_EBX           0x34
    #define PCB_ECX           0x38
    #define PCB_EDX           0x3C
    #define PCB_ESI           0x40
    #define PCB_EDI           0x44
    #define PCB_EBP           0x48
    #define PCB_ESP           0x4C  // ★
    #define PCB_EIP           0x50  // ★
    #define PCB_EFLAGS        0x54
    #define PCB_PAGE_DIR      0x58
    #define PCB_KSTACK        0x5C  // ★
    #define PCB_USER_STACK    0x60
    #define PCB_ENTRY_POINT   0x64
    #define PCB_NEXT          0x68
    #define PCB_PREV          0x6C
    #define PCB_SIZE          0x70
  |
}
# Legend
legend: {
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  style.border-radius: 8
  near: bottom-right
  label: |md
    **Legend**
  |
  critical: {
    label: |md
      ★ Critical fields
      Must be correct for context switch
    |
    style.fill: "#fdcb6e"
    style.stroke: "#f39c12"
    style.font-color: black
  }
  registers: {
    label: "Register save area"
    style.fill: "#00b894"
    style.stroke: "#00cec9"
    style.font-color: white
  }
  memory: {
    label: "Memory management"
    style.fill: "#6c5ce7"
    style.stroke: "#a29bfe"
    style.font-color: white
  }
  identification: {
    label: "Process identification"
    style.fill: "#e94560"
    style.stroke: "#ff6b6b"
    style.font-color: white
  }
  scheduling: {
    label: "Scheduling state"
    style.fill: "#0f4c75"
    style.stroke: "#3282b8"
    style.font-color: white
  }
  pointers: {
    label: "List pointers"
    style.fill: "#b2bec3"
    style.stroke: "#dfe6e9"
    style.font-color: black
  }
  critical -> registers -> memory -> identification -> scheduling -> pointers
}
# Warning note
warning: {
  near: bottom-center
  label: |md
    ⚠️ **CRITICAL**: PCB field offsets MUST match assembly macros exactly.
    Any mismatch will cause context switch to save/restore wrong data,
    leading to random crashes, register corruption, or triple faults.
    Always verify with: `_Static_assert(offsetof(process_t, eax) == PCB_EAX, "...")`
  |
  style.fill: "#2d132c"
  style.stroke: "#e94560"
  style.font-color: white
}