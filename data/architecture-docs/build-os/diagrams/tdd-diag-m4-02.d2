vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: {
  shape: text
  label: |md
    # Context Switch Assembly Flow
    **Technical Specification: Kernel-Level State Transition (x86 Architecture)**
    *Design Artist Ref: M4-02 | Implementation Tier: Intel-Grade*
  |
  style.font-size: 24
  near: top-center
}

# Documentation Legend
legend: {
  near: top-left
  save_op: "Save Operation (PUSHAD/MOV)" {
    style: {
      stroke: "#FF0000"
      stroke-width: 4
      fill: "#FFD0D0"
    }
  }
  restore_op: "Restore Operation (POPAD/IRET)" {
    style: {
      stroke: "#00FF00"
      stroke-width: 4
      fill: "#D5E8D4"
    }
  }
}

context_switch_flow: {
  shape: sequence_diagram

  # Participants (Intel x86 Execution Context)
  cpu: CPU Core {
    shape: person
    style.fill: "#D0E7FF"
    tooltip: "Execution Unit (ALU/Registers)"
  }
  proc_a: Process A (Ring 3) {
    style.fill: "#FFD0D0"
    tooltip: "Userland Application A"
  }
  pcb_a: PCB_A (Ring 0) {
    shape: cylinder
    style.fill: "#E1D5E7"
    tooltip: "Task State Segment / Memory Offset 0xFFFF0000"
  }
  pcb_b: PCB_B (Ring 0) {
    shape: cylinder
    style.fill: "#E1D5E7"
    tooltip: "Task State Segment / Memory Offset 0xFFFF2000"
  }
  proc_b: Process B (Ring 3) {
    style.fill: "#D5E8D4"
    tooltip: "Userland Application B"
  }

  # 1. TRAP / INTERRUPT
  proc_a -> cpu: "IRQ 0 (Timer Tick) -> 0x20 Vector"
  cpu -> cpu: "Vector to INT 0x80 Handler: kernel_entry"

  # 2. SAVE STATE (Process A)
  cpu -> pcb_a: "PUSHAD: EAX...EDI (Offset 0x00)" {
    style.stroke: red
    style.bold: true
  }
  cpu -> pcb_a: "MOV [PCB_A+0x24], CR3 (Page Dir)" {
    style.stroke: red
  }
  cpu -> pcb_a: "Save EFLAGS [0x28], CS [0x2C], EIP [0x30]" {
    style.stroke: red
  }
  pcb_a -> pcb_a: "State Captured: ESP_A Saved"

  # 3. KERNEL SCHEDULER (Dispatch Logic)
  cpu -> cpu: "schedule(): select next_task = PCB_B"
  cpu -> cpu: "Switch ESP to PCB_B.kernel_stack_ptr"
  cpu -> cpu: "Set TSS.esp0 = PCB_B.kernel_top"

  # 4. RESTORE STATE (Process B)
  pcb_b -> cpu: "MOV CR3, [PCB_B+0x24] (TLB Flush)" {
    style.stroke: green
    style.bold: true
  }
  pcb_b -> cpu: "POPAD: Load Process B GPRs" {
    style.stroke: green
  }
  pcb_b -> cpu: "LSS ESP, [PCB_B+0x04] (Stack Restore)" {
    style.stroke: green
  }
  cpu -> cpu: "Context: CR3=0x3F20, ESP=0xBC00"

  # 5. EXECUTION RESUME
  cpu -> proc_b: "IRET (Pop EFLAGS, CS, EIP)"
  proc_b -> proc_b: "Process B: Entry Point + Offset 0x442"
  proc_b -> proc_b: "Instruction Pipeline Resumed"
  
  cpu -> proc_b: "Context Switch Latency: ~1.2μs"
  cpu -> cpu: "Pipeline Restored"
}

# Metadata annotations
context_switch_flow.pcb_a.style.stroke: "#A020F0"
context_switch_flow.pcb_a.style.stroke-width: 2
context_switch_flow.pcb_b.style.stroke: "#A020F0"
context_switch_flow.pcb_b.style.stroke-width: 2

# Component Details
notes: {
  shape: text
  near: bottom-left
  label: |md
    ## PCB Register Layout ( x86_32 )
    | Offset | Content | Size | Description |
    | :--- | :--- | :--- | :--- |
    | `0x00` | **EDI/ESI** | 8B | Index Registers |
    | `0x08` | **EBP/ESP** | 8B | Stack Frame Pointers |
    | `0x10` | **EBX/EDX** | 8B | General Data |
    | `0x18` | **ECX/EAX** | 8B | Counter / Accumulator |
    | `0x20` | **EIP** | 4B | **Next Instruction Pointer** |
    | `0x24` | **CR3** | 4B | **Page Directory Base (MMU)** |
    | `0x28` | **EFLAGS** | 4B | Processor State Flags |
  |
}

# Physical Memory Map Visual
mem_layout: {
  near: bottom-right
  grid-rows: 3
  grid-gap: 0
  
  header: "PCB_B Segment: 0xFFFF2000" { 
    style.fill: "#E1D5E7"
    style.bold: true 
  }
  
  reg_block: {
    grid-rows: 4
    grid-columns: 2
    grid-gap: 2
    
    off1: "0x00: GPRs" { style.fill: "#D0E7FF" }
    data1: "8 x 32-bit" { style.fill: "#FFFFFF" }
    
    off2: "0x20: EIP" { style.fill: "#FFD0D0" }
    data2: "0x00401A20" { style.fill: "#FFFFFF" }
    
    off3: "0x24: CR3" { style.fill: "#D5E8D4" }
    data3: "0x00003F20" { style.fill: "#FFFFFF" }
    
    off4: "0x28: Flags" { style.fill: "#F0F0F0" }
    data4: "0x00000202" { style.fill: "#FFFFFF" }
  }
  
  footer: "Total Size: 64 Bytes (Aligned)" { 
    style.font-size: 10
    style.italic: true 
    style.fill: "#F5F5F5"
  }
}