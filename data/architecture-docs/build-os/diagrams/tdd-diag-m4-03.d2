direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- GLOBAL STYLES & CLASSES ---
classes: {
  header_purple: {
    style: {
      fill: "#D1C4E9"
      stroke: "#512DA8"
      stroke-width: 2
    }
  }
  header_green: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  data_blue: {
    style: {
      fill: "#BBDEFB"
    }
  }
  pointer_orange: {
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
      bold: true
    }
  }
  padding_gray: {
    style: {
      fill: "#EEEEEE"
      font-color: "#9E9E9E"
    }
  }
  mmu_yellow: {
    style: {
      fill: "#FFF9C4"
    }
  }
}

# --- TITLE ---
title: |md
  # Context Switch: Architectural State Preservation
  **Intel x86 (32-bit) Register Save/Restore Sequence**
  *Total PCB Size: 48 Bytes (including alignment padding) | Interrupt Latency Path Highlighted*
|
title.shape: text
title.near: top-center
title.style: {
  font-size: 28
  underline: true
  bold: true
}

# --- PROCESS CONTROL BLOCKS (Memory Layout) ---
pcbs: {
  label: "Kernel Memory: Process Control Blocks (PCBs)"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 4

  old_pcb: {
    label: "Process A Context (Outgoing Task)"
    shape: sql_table
    class: header_purple
    
    "0x00": EAX (GPR) {constraint: 4B; class: data_blue}
    "0x04": EBX (GPR) {constraint: 4B; class: data_blue}
    "0x08": ECX (GPR) {constraint: 4B; class: data_blue}
    "0x0C": EDX (GPR) {constraint: 4B; class: data_blue}
    "0x10": ESI (Index) {constraint: 4B; class: data_blue}
    "0x14": EDI (Index) {constraint: 4B; class: data_blue}
    "0x18": EBP (Base Ptr) {constraint: 4B; class: data_blue}
    "0x1C": ESP (Stack) ★ {constraint: 4B; class: pointer_orange}
    "0x20": EIP (Instr) ★ {constraint: 4B; class: pointer_orange}
    "0x24": EFLAGS (Stat) {constraint: 4B; class: data_blue}
    "0x28": CR3 (PDBR) {constraint: 4B; class: mmu_yellow}
    "0x2C": Padding {constraint: 4B; class: padding_gray}
  }

  new_pcb: {
    label: "Process B Context (Incoming Task)"
    shape: sql_table
    class: header_green
    
    "0x00": EAX (GPR) {constraint: 4B; class: data_blue}
    "0x04": EBX (GPR) {constraint: 4B; class: data_blue}
    "0x08": ECX (GPR) {constraint: 4B; class: data_blue}
    "0x0C": EDX (GPR) {constraint: 4B; class: data_blue}
    "0x10": ESI (Index) {constraint: 4B; class: data_blue}
    "0x14": EDI (Index) {constraint: 4B; class: data_blue}
    "0x18": EBP (Base Ptr) {constraint: 4B; class: data_blue}
    "0x1C": ESP (Target) ★ {constraint: 4B; class: pointer_orange}
    "0x20": EIP (Resume) ★ {constraint: 4B; class: pointer_orange}
    "0x24": EFLAGS (Stat) {constraint: 4B; class: data_blue}
    "0x28": CR3 (New Dir) {constraint: 4B; class: mmu_yellow}
    "0x2C": Padding {constraint: 4B; class: padding_gray}
  }
}

# --- HARDWARE STATE ---
hardware: Hardware Units {
  cpu: {
    label: "CPU Execution Core"
    shape: rectangle
    style.fill: "#FFFFFF"
    
    registers: {
      label: "Architectural Register File"
      shape: rectangle
      style.fill: "#FFFDE7"
      
      eax: "EAX"
      ebx: "EBX"
      esp: "ESP (Stack Ptr)" {style.stroke: "#D32F2F"; style.stroke-width: 4}
      eip: "EIP (Instruction Ptr)" {style.stroke: "#D32F2F"; style.stroke-width: 4}
      cr3: "CR3 (Page Dir)" {style.fill: "#FFF9C4"}
    }
  }

  mmu: "Memory Management Unit" {
    shape: square
    style.fill: "#E0F2F1"
    tlb: "TLB Cache" {
      shape: rectangle
      style.fill: "#B2DFDB"
    }
  }
}

# --- STATE TRANSITION LOGIC ---
switch_logic: {
  label: "Context Switch Sequence (Kernel Space)"
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"
  style.stroke-dash: 5
  
  step1: "1. Trap Entry (HW Save)" {
    tooltip: "Hardware auto-saves EFLAGS, CS, EIP to kernel stack"
    style.fill: "#FFE082"
    style.bold: true
  }
  step2: "2. Save Old State" {
    tooltip: "Kernel software pushes GPRs into Process A PCB"
    style.fill: "#A5D6A7"
  }
  step3: "3. Stack Pivot" {
    tooltip: "MOV ESP, [new_pcb.0x1C]"
    style.fill: "#EF9A9A"
    style.stroke: "#B71C1C"
    style.bold: true
  }
  step4: "4. Address Space Switch" {
    tooltip: "MOV CR3, [new_pcb.0x28] -> Triggers TLB Invalidation"
    style.fill: "#A5D6A7"
  }
  step5: "5. Resume Execution" {
    tooltip: "Restore new process registers and IRET to new EIP"
    style.fill: "#90CAF9"
    style.bold: true
  }
}

# --- CONNECTIONS & DATA FLOW ---

# 1. Trigger
hardware.cpu -> switch_logic.step1: "Timer Interrupt" {
  style.stroke-width: 2
}

# 2. Save Sequence
switch_logic.step2 -> hardware.cpu.registers: "Fetch GPRs"
hardware.cpu.registers -> pcbs.old_pcb: "Serialized Write" {
  style.stroke: "#FB8C00"
  style.stroke-width: 3
  style.animated: true
}

# 3. Pivot Logic
switch_logic.step3 -> hardware.cpu.registers.esp: "LSS / MOV ESP" {
  style.stroke: "#D32F2F"
  style.stroke-width: 4
}
switch_logic.step4 -> hardware.cpu.registers.cr3: "Reload CR3"
hardware.cpu.registers.cr3 -> hardware.mmu.tlb: "Flush TLB" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 3
}

# 4. Restore Sequence
pcbs.new_pcb -> hardware.cpu.registers: "Parallel Restore" {
  style.stroke: "#1976D2"
  style.stroke-width: 3
  style.animated: true
}
switch_logic.step5 -> hardware.cpu.registers.eip: "IRET Jump" {
  style.stroke: "#388E3C"
  style.stroke-width: 3
}

# --- LEGEND & ANNOTATIONS ---
legend: {
  near: bottom-right
  pointer: "★ Critical Path (ESP/EIP)" {
    class: pointer_orange
    style.stroke: "#D32F2F"
  }
  gpr: "General Purpose Registers" {
    class: data_blue
  }
  sys: "MMU / Control Registers" {
    class: mmu_yellow
  }
}

# Pointers
pcbs.old_pcb."0x1C" -> hardware.cpu.registers.esp: "Saved Stack" {style.stroke: "#FF5252"; style.stroke-dash: 5}
pcbs.new_pcb."0x20" -> hardware.cpu.registers.eip: "Resume EIP" {style.stroke: "#4CAF50"; style.stroke-dash: 5}

notes: |md
  ### OS Implementation Notes
  - **Memory Layout:** Each PCB block is 48 bytes total (0x00-0x2F).
  - **Alignment:** 4-byte boundaries observed for all register fields.
  - **Atomic Pivot:** The switch from Process A's stack to Process B's stack happens at Step 3.
  - **Memory Isolation:** CR3 update forces hardware to switch Page Tables, effectively changing the memory view.
|
notes.shape: sticky_note
notes.near: bottom-left