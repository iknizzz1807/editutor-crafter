vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Ring 3 → Ring 0 Stack Transition
  *Intel x86 Privilege Level Switch (Interrupt/Exception)*
| {
  near: top-center
  shape: text
}

# -----------------------------------------------------------------------------
# Classes & Styles
# -----------------------------------------------------------------------------
classes: {
  memory_segment: {
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
  kernel_mem: {
    style: {
      fill: "#E1BEE7" # Purple Header/Kernel
      stroke: "#7B1FA2"
    }
  }
  user_mem: {
    style: {
      fill: "#BBDEFB" # Blue Data/User
      stroke: "#1976D2"
    }
  }
  cpu_internal: {
    style: {
      fill: "#FFE0B2" # Orange Pointers
      stroke: "#F57C00"
    }
  }
  stack_pushed: {
    style: {
      fill: "#C8E6C9" # Green New Data
      bold: true
    }
  }
}

# -----------------------------------------------------------------------------
# Hardware Components
# -----------------------------------------------------------------------------
Hardware: {
  CPU: {
    shape: rectangle
    class: cpu_internal
    Registers: {
      CS: "0x1B (Ring 3)"
      EIP: "Instruction Pointer"
      SS: "0x23 (Ring 3)"
      ESP: "User Stack Pointer"
      EFLAGS: "0x202 (IF=1)"
    }
  }

  TSS: Task State Segment {
    class: kernel_mem
    tooltip: "Task State Segment (TSS) used to find Kernel Stack"
    SS0: "0x10 (Kernel Data)"
    ESP0: "0xC0102000 (Top of Kernel Stack)"
  }
}

# -----------------------------------------------------------------------------
# Memory Layouts
# -----------------------------------------------------------------------------
Memory: {
  User_Space: {
    class: user_mem
    User_Stack: {
      label: "User Stack (Ring 3)"
      shape: cylinder
    }
  }

  Kernel_Space: {
    class: kernel_mem
    
    Kernel_Stack_Frame: {
      shape: sql_table
      label: "Kernel Stack (After Transition)"
      
      0x00: "User SS (0x23)" {constraint: "High Address"}
      0x04: "User ESP"
      0x08: "EFLAGS"
      0x0C: "User CS (0x1B)"
      0x10: "User EIP (Return Address)"
      0x14: "Error Code (Optional)" {style.fill: "#FFCDD2"}
      0x18: "General Purpose Regs (stub)" {style.fill: "#F0F0F0"}
      0xXX: "ESP points here" {constraint: "Low Address"}
    }
  }
}

# -----------------------------------------------------------------------------
# The Transition Sequence
# -----------------------------------------------------------------------------
Hardware.CPU.Registers -> Memory.User_Space.User_Stack: "1. Normal Ring 3 Execution"

Hardware.CPU -> Hardware.TSS: "2. INT 0x80 / Exception occurs\nLookup TSS.SS0 and TSS.ESP0" {
  style: {
    stroke: red
    stroke-width: 3
    animated: true
  }
}

Hardware.TSS -> Memory.Kernel_Space.Kernel_Stack_Frame: "3. CPU switches to Kernel Stack" {
  style.stroke-dash: 5
}

Hardware.CPU -> Memory.Kernel_Space.Kernel_Stack_Frame: "4. Hardware Pushes Context" {
  source-arrowhead: triangle
  target-arrowhead: * {
    shape: diamond
  }
}

# Annotations
Legend: {
  near: bottom-right
  Header: { style.fill: "#E1BEE7"; label: "Kernel / Header" }
  Data: { style.fill: "#BBDEFB"; label: "User / Data" }
  Pointers: { style.fill: "#FFE0B2"; label: "CPU / Internal" }
  Pushed: { style.fill: "#C8E6C9"; label: "Hardware Pushed" }
}

explanation: |md
  ### The Hardware Mechanism (CPL 3 -> 0)
  1. **Detection**: CPU detects interrupt or exception.
  2. **TSS Lookup**: CPU accesses the Task Register (TR) to find the current TSS.
  3. **Stack Switch**: SS and ESP are loaded with `TSS.SS0` and `TSS.ESP0`.
  4. **Push Sequence**:
     - `User SS` (pushed to new stack)
     - `User ESP`
     - `EFLAGS`
     - `User CS`
     - `User EIP`
     - `Error Code` (if applicable)
  5. **Handler**: CPU loads new `CS:EIP` from IDT.
| {
  near: center-left
  shape: text
}