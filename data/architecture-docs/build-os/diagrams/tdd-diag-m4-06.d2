vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    pcb_ready: "#E8F5E9"
    pcb_running: "#FFF3E0"
    pcb_header: "#1565C0"
    queue_arrow: "#2E7D32"
    time_slice: "#F57C00"
    tick: "#7B1FA2"
    mem_offset: "#546E7A"
  }
}

title: ||md
  # Round-Robin Scheduler: Circular Ready Queue
  ### Technical Implementation Specification (Module 4.6)
|| {near: top-center}

# Timer Interrupt Flow
timer_box: {
  label: "Timer Interrupt\n(IRQ0 @ 100Hz)"
  shape: rectangle
  style: {
    fill: "${colors.tick}"
    stroke: "#4A148C"
    font-color: white
    bold: true
    shadow: true
  }
}

tick_action: {
  label: ||md
    **scheduler_tick()**
    ───────────────────────────────────
    *Entry point: `kernel/sched.c:142`*
    
    1. `tick_count++`
    2. `current->time_slice--`
    3. **IF** `time_slice == 0`:
       → `scheduler_yield()`
  ||
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "${colors.tick}"
    border-radius: 4
  }
}

timer_box -> tick_action: "IRQ Handler" {
  style.stroke: "${colors.tick}"
  style.stroke-width: 2
}

# Circular Ready Queue
queue_section: {
  label: "Ready Queue (Circular Doubly-Linked List)"
  style: {
    stroke: "#90A4AE"
    stroke-dash: 5
    fill: "#F1F8E9"
  }

  # PCB A (Running)
  pcb_a: {
    label: ||md
      ### PCB_A (Running)
      | Offset | Field | Value |
      | :--- | :--- | :--- |
      | 0x00 | **pid** | 1 |
      | 0x04 | **state** | **TASK_RUNNING** |
      | 0x08 | **time_slice** | **0** ⚠️ |
      | 0x0C | **eip** | 0x00101234 |
      | 0x10 | **esp** | 0x0008FFC0 |
      | 0x14 | **next** | ptr → PCB_B |
    ||
    shape: rectangle
    style: {
      fill: "${colors.pcb_running}"
      stroke: "${colors.pcb_header}"
      stroke-width: 4
      bold: true
    }
  }

  # PCB B (Ready)
  pcb_b: {
    label: ||md
      ### PCB_B (Ready)
      | Offset | Field | Value |
      | :--- | :--- | :--- |
      | 0x00 | **pid** | 2 |
      | 0x04 | **state** | TASK_READY |
      | 0x08 | **time_slice** | 10 |
      | 0x0C | **eip** | 0x00102500 |
      | 0x10 | **esp** | 0x00097FC0 |
    ||
    shape: rectangle
    style: {
      fill: "${colors.pcb_ready}"
      stroke: "${colors.pcb_header}"
      stroke-width: 2
    }
  }

  # PCB C (Ready)
  pcb_c: {
    label: ||md
      ### PCB_C (Ready)
      | Offset | Field | Value |
      | :--- | :--- | :--- |
      | 0x00 | **pid** | 3 |
      | 0x04 | **state** | TASK_READY |
      | 0x08 | **time_slice** | 10 |
      | 0x0C | **eip** | 0x00103800 |
      | 0x10 | **esp** | 0x0009FFC0 |
    ||
    shape: rectangle
    style: {
      fill: "${colors.pcb_ready}"
      stroke: "${colors.pcb_header}"
      stroke-width: 2
    }
  }

  # State transition annotation
  state_note: {
    label: ||md
      **Pre-emption Target:**
      PCB_A transition:
      RUNNING → READY
      time_slice: 0 → 10
    ||
    shape: text
    style: {
      font-color: "#E65100"
      italic: true
      bold: true
    }
  }

  # Circular links
  pcb_a -> pcb_b: "next" {
    style.stroke: "${colors.queue_arrow}"
    style.stroke-width: 3
    target-arrowhead.shape: triangle
  }
  pcb_b -> pcb_c: "next" {
    style.stroke: "${colors.queue_arrow}"
    style.stroke-width: 3
    target-arrowhead.shape: triangle
  }
  pcb_c -> pcb_a: "next" {
    style.stroke: "${colors.queue_arrow}"
    style.stroke-width: 3
    target-arrowhead.shape: triangle
  }

  # Prev links (dashed)
  pcb_a -> pcb_c: "prev" {
    style.stroke: "#78909C"
    style.stroke-dash: 4
    target-arrowhead.shape: arrow
  }
  pcb_c -> pcb_b: "prev" {
    style.stroke: "#78909C"
    style.stroke-dash: 4
    target-arrowhead.shape: arrow
  }
  pcb_b -> pcb_a: "prev" {
    style.stroke: "#78909C"
    style.stroke-dash: 4
    target-arrowhead.shape: arrow
  }
}

# Ready queue head pointer
ready_queue_head: {
  label: "ready_queue\n→ PCB_B"
  shape: rectangle
  style: {
    fill: "#BBDEFB"
    stroke: "#1565C0"
    bold: true
    border-radius: 8
  }
}
ready_queue_head -> queue_section.pcb_b: "Next Schedule Target" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.stroke-dash: 5
}

# Current process pointer
current_ptr: {
  label: "current_process\n→ PCB_A"
  shape: rectangle
  style: {
    fill: "${colors.pcb_running}"
    stroke: "#E65100"
    bold: true
    border-radius: 8
  }
}
current_ptr -> queue_section.pcb_a: "CPU Context" {
  style.stroke: "#E65100"
  style.stroke-width: 3
}

# Yield Decision
yield_box: {
  label: ||md
    **scheduler_yield()**
    ───────────────────────────────────
    1. Set `current->state = TASK_READY`
    2. Reset `current->time_slice = 10`
    3. `next = current->next`
    4. `next->state = TASK_RUNNING`
    5. Update `ready_queue = next`
    6. **context_switch(current, next)**
  ||
  shape: rectangle
  style: {
    fill: "#FFECB3"
    stroke: "${colors.time_slice}"
    stroke-width: 2
  }
}

tick_action -> yield_box: "PREEMPT" {
  style.stroke: "${colors.time_slice}"
  style.stroke-width: 3
  style.bold: true
}

# Context Switch
context_switch_box: {
  label: ||md
    **context_switch(old, new)**
    ───────────────────────────────────
    *Save Stack:*
    PUSH EFLAGS, CS, EIP, EAX...
    
    *Update Kernel Pointers:*
    1. Save ESP to `old->esp`
    2. Load ESP from `new->esp`
    3. Update CR3 Control Register
    4. Update `TSS.esp0` for Ring 0 switch
    
    *Restore:*
    POP registers...
    IRET (Interrupt Return)
  ||
  shape: rectangle
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
    bold: true
    shadow: true
  }
}

yield_box -> context_switch_box: "Execute Switch" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}

# Legend
legend: {
  near: bottom-right
  label: ||md
    ### Round-Robin Legend
    | Icon | Meaning |
    | :--- | :--- |
    | 🟢 | PCB in **READY** state |
    | 🟠 | PCB in **RUNNING** state |
    | ──→ | `next` Pointer (FWD) |
    | ╌╌→ | `prev` Pointer (BWD) |
    | ⚠️ | Slice Expired (Preempt) |
  ||
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    border-radius: 4
  }
}