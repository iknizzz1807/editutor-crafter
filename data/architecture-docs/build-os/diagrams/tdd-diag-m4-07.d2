direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 40
  }
}

# -----------------------------------------------------------------------------------------
# INTERRUPT FLOW: HARDWARE TO KERNEL HANDLER
# -----------------------------------------------------------------------------------------
Interrupt_Path: {
  label: "Hardware Interrupt Path (IRQ1)"
  
  "User Key Press": {
    shape: person
    icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
    tooltip: "Asynchronous hardware event"
  }
  
  "Keyboard Controller": {
    shape: square
    style.fill: "#d1ecf1"
    tooltip: "Intel 8042 Microcontroller"
  }
  
  "8259A PIC": {
    shape: rectangle
    label: "8259A PIC\n(Master/Slave)"
    style: {
      fill: "#f8f9fa"
      stroke-width: 2
    }
  }

  "CPU INTR Pin": {
    shape: circle
    style.fill: "#f8d7da"
  }

  "IDT Handler [0x21]": {
    shape: parallelogram
    style: {
      fill: "#e8f4fd"
      double-border: true
    }
    tooltip: "Interrupt Descriptor Table entry"
  }

  "User Key Press" -> "Keyboard Controller": "Scan Code" {
    style.stroke: orange
  }
  "Keyboard Controller" -> "8259A PIC": "Voltage High (IRQ 1)"
  "8259A PIC" -> "CPU INTR Pin": "INT 0x21" {
    style.animated: true
  }
  "CPU INTR Pin" -> "IDT Handler [0x21]": "Vector lookup" {
    label: "EIP = IDT[33].offset"
  }
}

# -----------------------------------------------------------------------------------------
# SCHEDULER TICK DECISION STATE MACHINE
# -----------------------------------------------------------------------------------------
Scheduler: {
  label: "Kernel Scheduler: Context Switch FSM"
  
  # START NODE
  INIT: "" {
    shape: circle
    style.fill: black
    width: 20
    height: 20
  }

  IDLE: {
    label: "IDLE\nCPU Halted"
    tooltip: "HLT state: No runnable threads"
    style: {
      stroke-dash: 5
      fill: "#f8f9fa"
    }
  }

  READY: {
    label: "READY\nIn RunQueue"
    style: {
      stroke-width: 2
      fill: "#e3f2fd"
    }
  }

  RUNNING: {
    label: "RUNNING\nCPU Ownership"
    style: {
      stroke: "#2ecc71"
      stroke-width: 5
      shadow: true
      fill: "#e8f5e9"
    }
  }

  SWITCHING: {
    label: "SWITCHING\nContext Save/Restore"
    style: {
      fill: "#f1c40f"
      bold: true
      stroke-width: 3
    }
  }

  EXPIRED: {
    label: "EXPIRED\nQuantum End"
    style: {
      stroke: "#e74c3c"
      fill: "#fdf2f2"
    }
  }

  # Transitions with Guard/Action semantics
  INIT -> IDLE
  
  IDLE -> READY: "IRQ0 (Timer) [task_count > 0]\nAction: **wakeup()**" {
    style: {
      stroke: "#3498db"
      font-color: "#2980b9"
    }
  }
  
  READY -> RUNNING: "Schedule Event [highest_priority]\nAction: **load_cr3(); switch_stack()**" {
    target-arrowhead: triangle
  }
  
  RUNNING -> RUNNING: "Timer Tick [quantum > 0]\nAction: **quantum--**" {
    style: {
      stroke-dash: 3
      animated: true
      stroke: "#27ae60"
    }
  }

  RUNNING -> SWITCHING: "Timer Tick [quantum == 0]\nAction: **push_regs(); save_esp()**" {
    style: {
      bold: true
      stroke: "#d35400"
    }
  }
  
  SWITCHING -> EXPIRED: "Checkpoint Save [ESP updated]\nAction: **enqueue(expired_list)**"
  
  EXPIRED -> READY: "Epoch Reset [active_queue == empty]\nAction: **swap_queues()**"
  
  SWITCHING -> RUNNING: "Restore [New Task Loaded]\nAction: **pop_regs(); iret**" {
    style.stroke: "#27ae60"
  }

  # Illegal Transitions for Logic Validation
  IDLE -> RUNNING: "ILLEGAL: DIRECT_EXEC" {
    style: {
      stroke: red
      stroke-dash: 5
      opacity: 0.5
    }
  }
}

# -----------------------------------------------------------------------------------------
# MEMORY LAYOUT: TASK CONTROL BLOCK (TCB)
# -----------------------------------------------------------------------------------------
TCB_Layout: {
  label: "Task Control Block (TCB) - Memory Structure (0x20 Bytes)"

  grid-columns: 3
  grid-rows: 8
  grid-gap: 0

  # Table Header
  "Offset" { style: { bold: true; fill: "#6f42c1"; font-color: white } }
  "Field Component" { style: { bold: true; fill: "#6f42c1"; font-color: white } }
  "Byte Size" { style: { bold: true; fill: "#6f42c1"; font-color: white } }

  # Data Segments
  "0x00" { style.fill: "#e9ecef" }
  "Kernel ESP (ESP0)" { 
    style: {
        fill: "#cfe2ff"
        stroke: "#0d6efd"
    } 
  }
  "4B" { style.fill: "#e9ecef" }

  "0x04" { style.fill: "#e9ecef" }
  "Page Directory (CR3)" { 
    style: {
        fill: "#cfe2ff"
        stroke: "#0d6efd"
    } 
  }
  "4B" { style.fill: "#e9ecef" }

  "0x08" { style.fill: "#e9ecef" }
  "Process ID (PID)" { 
    style: {
        fill: "#fff3cd"
        stroke: "#ffc107"
    } 
  }
  "4B" { style.fill: "#e9ecef" }

  "0x0C" { style.fill: "#e9ecef" }
  "Priority Level" { 
    style: {
        fill: "#fff3cd"
        stroke: "#ffc107"
    } 
  }
  "1B" { style.fill: "#e9ecef" }

  "0x0D" { style.fill: "#e9ecef" }
  "Time Slice (Quantum)" { 
    style: {
        fill: "#f8d7da"
        stroke: "#dc3545"
    } 
  }
  "4B" { style.fill: "#e9ecef" }

  "0x11" { style.fill: "#e9ecef" }
  "Reserved / Align" { 
    style: {
        fill: "#e2e3e5"
        stroke: "#adb5bd"
    } 
  }
  "15B" { style.fill: "#e9ecef" }

  # Footer Row
  "Total" { style: { italic: true; fill: "#ced4da" } }
  "Aligned to Cache Line" { style: { italic: true; fill: "#ced4da" } }
  "32B" { style: { italic: true; fill: "#ced4da" } }
}

# -----------------------------------------------------------------------------------------
# IMPLEMENTATION CONSTRAINTS & INVARIANTS
# -----------------------------------------------------------------------------------------
Specification: {
  shape: rectangle
  style: {
    fill: "#ffffff"
    stroke: "#495057"
    stroke-dash: 2
    border-radius: 10
  }
  
  content: |md
    ### Scheduler Critical Invariants
    1. **Context Atomicity:** All code within the `SWITCHING` block must execute with `EFLAGS.IF = 0` (Interrupts disabled) to prevent re-entrant scheduling.
    2. **CR3 Reloading:** The Page Directory Base Register (`CR3`) must be reloaded if `next_task->mm != current_task->mm`, triggering a TLB flush.
    3. **TSS Update:** `tss.esp0` must point to the top of the *new* task's kernel stack to handle future interrupts/traps from ring 3.
    
    ### Implementation Constants
    - **HZ:** 100 (10ms resolution)
    - **DEFAULT_PRIO:** 20 (NICE value)
    - **MAX_TASKS:** 4096 (PID_MAX)
    
    ### Call Trace
    `timer_interrupt` (asm)
      -> `scheduler_tick` (c)
        -> `switch_to(next)` (inline asm)
  |
}

# Global Styling and Glob Rules
***.style.font: mono
(Scheduler -> Scheduler)[*].style.animated: true

# State Specific Formatting
Scheduler.SWITCHING.style.stroke: "#d4ac0d"
Scheduler.RUNNING.style.stroke: "#1b5e20"
Scheduler.EXPIRED.style.font-color: "#b71c1c"

# Layout Cleanup
TCB_Layout.** {
  style.font-size: 13
}

# Documentation Position Fixes (Manual grouping instead of 'near' on grids)
Internals_Wrapper: {
    style.stroke-width: 0
    style.fill: transparent
    
    TCB_Layout
    Specification
}

Scheduler -> Internals_Wrapper: "Modifies state" {
    style.stroke-dash: 2
    style.opacity: 0.3
}