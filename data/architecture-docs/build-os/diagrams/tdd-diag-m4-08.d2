vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Intel x86-32: User Mode Entry via IRET
  ### Privilege Level Transition (Ring 0 → Ring 3)
  *Mechanism for Task Switching and User-space Initialization*
| {near: top-center}

direction: right

# ----------------------------------------------------------------------------
# 1. MEMORY LAYOUT: KERNEL STACK BEFORE IRET
# ----------------------------------------------------------------------------
kernel_stack: "Kernel Stack Memory (SS0:ESP0)" {
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#F0F0F0"
  }

  stack_header: "Stack Frame Header" {
    style.fill: "#DDA0DD" # Purple (Header)
  }

  mem_ss: "Offset +20 | SS (User Data Selector) | 4 Bytes" {
    label: "0x00000023 (GDT Index 4, RPL 3)"
    style.fill: "#ADD8E6" # Blue (Data)
  }
  
  mem_esp: "Offset +16 | ESP (User Stack Pointer) | 4 Bytes" {
    label: "0x40000000 (User Stack Base)"
    style.fill: "#ADD8E6" # Blue (Data)
  }

  mem_eflags: "Offset +12 | EFLAGS Register | 4 Bytes" {
    label: "0x00000202 (IF=1, Reserved=2)"
    style.fill: "#ADD8E6" # Blue (Data)
  }

  mem_cs: "Offset +08 | CS (User Code Selector) | 4 Bytes" {
    label: "0x0000001B (GDT Index 3, RPL 3)"
    style.fill: "#ADD8E6" # Blue (Data)
  }

  mem_eip: "Offset +04 | EIP (User Entry Point) | 4 Bytes" {
    label: "0x08048000 (_start address)"
    style.fill: "#ADD8E6" # Blue (Data)
    style.bold: true
  }

  padding: "Offset +00 | Free / Padding Space" {
    style.fill: "#D3D3D3" # Gray (Padding)
  }

  esp_pointer: "ESP0" {
    shape: circle
    style.fill: "#FFA500" # Orange (Pointer)
    style.font-color: white
  }
  
  esp_pointer -> mem_eip: "Points to EIP"
}

# ----------------------------------------------------------------------------
# 2. ARCHITECTURE: CPU REGISTERS & PRIVILEGE STATE
# ----------------------------------------------------------------------------
cpu_core: "Intel 80386+ Execution Core" {
  style.fill: white
  
  registers: "CPU Register File" {
    cs_reg: "CS (Code Segment)" {
      label: "Current: 0x08 (Ring 0)"
      style.fill: "#E1EBEE"
    }
    ss_reg: "SS (Stack Segment)" {
      label: "Current: 0x10 (Ring 0)"
      style.fill: "#E1EBEE"
    }
    eip_reg: "EIP (Instr Pointer)" {
      style.fill: "#E1EBEE"
    }
    eflags_reg: "EFLAGS" {
      style.fill: "#E1EBEE"
    }
    cpl_indicator: "CPL (Current Privilege Level)" {
      shape: diamond
      label: "CPL = 0"
      style.fill: "#FF6B6B"
      style.font-color: white
    }
  }

  iret_logic: "IRET Micro-code Execution" {
    shape: rectangle
    style.fill: "#FFD700"
    style.double-border: true
    
    op1: "1. POP EIP"
    op2: "2. POP CS"
    op3: "3. Update CPL to CS.RPL"
    op4: "4. POP EFLAGS"
    op5: "5. IF CPL Change: POP ESP, POP SS"
  }
}

# ----------------------------------------------------------------------------
# 3. TRANSITION SEQUENCE
# ----------------------------------------------------------------------------
kernel_stack.mem_eip -> cpu_core.iret_logic.op1: "Fetch"
kernel_stack.mem_cs -> cpu_core.iret_logic.op2: "Fetch"
kernel_stack.mem_eflags -> cpu_core.iret_logic.op4: "Fetch"
kernel_stack.mem_esp -> cpu_core.iret_logic.op5: "Fetch if RPL=3"
kernel_stack.mem_ss -> cpu_core.iret_logic.op5: "Fetch if RPL=3"

# ----------------------------------------------------------------------------
# 4. POST-TRANSITION STATE (RING 3)
# ----------------------------------------------------------------------------
user_mode_state: "Post-Transition: User Mode (Ring 3)" {
  style.fill: "#E0FFE0" # Green (Result/Free-flow)
  
  final_cs: "CS: 0x1B" {
    tooltip: "RPL 3"
    style.fill: "#ADD8E6"
  }
  final_ss: "SS: 0x23" {
    tooltip: "RPL 3"
    style.fill: "#ADD8E6"
  }
  final_cpl: "CPL: 3" {
    shape: diamond
    style.fill: "#32CD32"
    style.font-color: white
  }
}

cpu_core.iret_logic -> user_mode_state: "Atomic State Swap" {
  style.stroke: "#228B22"
  style.stroke-width: 3
  style.animated: true
}

# ----------------------------------------------------------------------------
# 5. USER SPACE CONTEXT
# ----------------------------------------------------------------------------
user_space: "Address Space (Ring 3)" {
  style.stroke-dash: 5
  
  code_seg: "User Code Section" {
    shape: parallelogram
    label: ".text @ 0x08048000"
    style.fill: "#B5D8EB"
  }
  
  stack_seg: "User Stack Section" {
    shape: cylinder
    label: "Stack @ 0x40000000"
    style.fill: "#B5D8EB"
  }
}

user_mode_state -> user_space.code_seg: "Next Instruction Fetch"
user_mode_state -> user_space.stack_seg: "Stack Push/Pop Access"

# ----------------------------------------------------------------------------
# 6. ANNOTATIONS & IMPLEMENTATION NOTES
# ----------------------------------------------------------------------------
implementation_notes: |md
  ### Hardware Transition Logic
  - **Atomicity**: The `IRET` instruction is atomic. No interrupt can occur during the register swap.
  - **Privilege Validation**: The CPU verifies that the `CS` selector on the stack has a higher numeric value (lower privilege) than the current `CPL`.
  - **Stack Switching**: Because the privilege level changes from 0 to 3, the CPU must switch from the Kernel Stack (`SS0:ESP0`) to the User Stack specified in the frame.
  - **TSS Role**: Although not shown here, the `TSS` (Task State Segment) must contain a valid `ESP0` and `SS0` so that the CPU can return to the kernel on the next interrupt/syscall.
| {near: bottom-right}

legend: "Intel x86 Legend" {
  near: bottom-left
  header: "Purple: Stack Header / Metadata" { style.fill: "#DDA0DD" }
  data_field: "Blue: Data / Registers" { style.fill: "#ADD8E6" }
  padding_field: "Gray: Padding / Unused" { style.fill: "#D3D3D3" }
  pointer_field: "Orange: Stack Pointer (ESP)" { style.fill: "#FFA500" }
}