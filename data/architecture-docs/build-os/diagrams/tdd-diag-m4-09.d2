vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    user-space: "#E8F4FD"
    kernel-space: "#FEE2E2"
    pd-frame: "#DBEAFE"
    shared-kernel: "#FECACA"
    cr3-arrow: "#DC2626"
    user-arrow: "#2563EB"
    bit-p: "#10B981"
    bit-w: "#F59E0B"
    bit-u: "#3B82F6"
    padding: "#F3F4F6"
  }
}

title: |md
  # x86-32 Process Page Directory Isolation
  **Architectural Spec:** Two-level paging. Each process context (Task) maintains a unique 4KB Page Directory (PD).
  - **User Space:** [0x00000000, 0xBFFFFFFF] (Entries 0-767) - Private per process.
  - **Kernel Space:** [0xC0000000, 0xFFFFFFFF] (Entries 768-1023) - Shared/Global mapping.
| {near: top-center}

direction: right

legend: {
  near: bottom-left
  shape: rectangle
  style.fill: white
  style.stroke: "#E5E7EB"
  style.stroke-width: 2
  
  header: "Memory Classification" { shape: text; style.bold: true }
  
  user_legend: "User Space (Private)" {
    style.fill: ${colors.user-space}
    style.stroke: "#93C5FD"
  }
  kernel_legend: "Kernel Space (Shared)" {
    style.fill: ${colors.kernel-space}
    style.stroke: "#FCA5A5"
  }
  entry_format: "PDE Format (32-bit)" {
    shape: sql_table
    address: "Physical Address of PT [31:12]"
    avail: "AVL [11:9]"
    flags: "G|PS|0|A|PCD|PWT|U/S|W/R|P"
  }
}

process_a: "Process A context_t" {
  style.fill: "#F0FDF4"
  style.stroke: "#86EFAC"
  style.stroke-width: 2

  cr3_a: "Register CR3 (PDBR)" {
    shape: hexagon
    label: "CR3: 0x00152000\n(PD Physical Base)"
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
  }

  pd_a: "Page Directory A\nSize: 4096 Bytes" {
    style.fill: ${colors.pd-frame}
    style.stroke: "#93C5FD"
    
    user_entries: "User PDEs [0..767]" {
      style.fill: ${colors.user-space}
      style.stroke: "#93C5FD"
      
      code_entry: "VA: 0x08048000" {
        label: "PDE[32]: -> Phys PT_A_1\nFlags: P=1, W=0, U=1"
      }
      stack_entry: "VA: 0xBFFFF000" {
        label: "PDE[767]: -> Phys PT_A_Stack\nFlags: P=1, W=1, U=1"
      }
    }

    kernel_entries: "Kernel PDEs [768..1023]" {
      style.fill: ${colors.shared-kernel}
      style.stroke: "#FCA5A5"
      style.stroke-dash: 2
      
      k_shared: "VA: 0xC0000000" {
        label: "PDE[768]: -> Phys PT_Kernel\nFlags: P=1, W=1, U=0"
      }
    }
  }
}

process_b: "Process B context_t" {
  style.fill: "#FDF4FF"
  style.stroke: "#E879F9"
  style.stroke-width: 2

  cr3_b: "Register CR3 (PDBR)" {
    shape: hexagon
    label: "CR3: 0x00153000\n(PD Physical Base)"
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
  }

  pd_b: "Page Directory B\nSize: 4096 Bytes" {
    style.fill: ${colors.pd-frame}
    style.stroke: "#93C5FD"
    
    user_entries: "User PDEs [0..767]" {
      style.fill: ${colors.user-space}
      style.stroke: "#93C5FD"
      
      code_entry: "VA: 0x08048000" {
        label: "PDE[32]: -> Phys PT_B_1\nFlags: P=1, W=0, U=1"
      }
      stack_entry: "VA: 0xBFFFF000" {
        label: "PDE[767]: -> Phys PT_B_Stack\nFlags: P=1, W=1, U=1"
      }
    }

    kernel_entries: "Kernel PDEs [768..1023]" {
      style.fill: ${colors.shared-kernel}
      style.stroke: "#FCA5A5"
      style.stroke-dash: 2
      
      k_shared: "VA: 0xC0000000" {
        label: "PDE[768]: -> Phys PT_Kernel\nFlags: P=1, W=1, U=0"
      }
    }
  }
}

physical_ram: "Physical Memory Map" {
  style.fill: "#F9FAFB"
  style.stroke: "#374151"
  style.stroke-width: 3

  kernel_reserved: "Kernel Image\n[Phys: 0x00100000]" {
    style.fill: ${colors.kernel-space}
    style.stroke: "#DC2626"
    style.double-border: true
  }
  
  pd_pool: "Page Directory Pool (Non-paged)" {
    pd_a_phys: "Phys: 0x00152000\n[PD_A Page]" { style.fill: ${colors.pd-frame} }
    pd_b_phys: "Phys: 0x00153000\n[PD_B Page]" { style.fill: ${colors.pd-frame} }
  }

  user_frames: "User Pages (RAM)" {
    frame_a: "Phys: 0x0A241000\n(Proc A Code)" { style.fill: ${colors.user-space} }
    frame_b: "Phys: 0x0B552000\n(Proc B Code)" { style.fill: ${colors.user-space} }
  }
}

context_switch: "Kernel Scheduler: switch_to()" {
  style.fill: "#F3E8FF"
  style.stroke: "#A855F7"
  asm: |go
  // Logical logic for x86 CR3 Switch
  func SwitchContext(nextThread *Thread) {
      newPD := nextThread.PD_PhysicalAddress
      currentCR3 := readCR3()
      
      if newPD != currentCR3 {
          // Setting CR3 flushes TLB automatically
          // unless Global (G) bit is set in entries
          writeCR3(newPD) 
      }
  }
  |
}

isolation_note: |md
  ### Architectural Invariants
  - **Context Isolation:** While Process A and B use the same Virtual Addresses (e.g., `0x08048000`), their CR3 registers point to different Physical PDs.
  - **Memory Safety:** Process A cannot generate a physical address pointing to Process B's user data because its Page Directory lacks any PTE pointers to those frames.
  - **Shared Kernel:** Both PDs contain identical pointers in the [768..1023] range, mapping the same physical kernel frames into every process address space.
| {
  near: bottom-right
  shape: rectangle
  style.fill: "#FFFBEB"
  style.stroke: "#F59E0B"
  style.border-radius: 5
}

# Mapping Logic
process_a.cr3_a -> physical_ram.pd_pool.pd_a_phys: "Load PDBR" {
  style.stroke: "#6B7280"
  style.stroke-dash: 3
}

process_b.cr3_b -> physical_ram.pd_pool.pd_b_phys: "Load PDBR" {
  style.stroke: "#6B7280"
  style.stroke-dash: 3
}

process_a.pd_a.kernel_entries.k_shared -> physical_ram.kernel_reserved: "Shared Mapping" {
  style.stroke: ${colors.cr3-arrow}
  style.stroke-width: 2
}

process_b.pd_b.kernel_entries.k_shared -> physical_ram.kernel_reserved: "Shared Mapping" {
  style.stroke: ${colors.cr3-arrow}
  style.stroke-width: 2
}

process_a.pd_a.user_entries.code_entry -> physical_ram.user_frames.frame_a: "Private Mapping" {
  style.stroke: ${colors.user-arrow}
}

process_b.pd_b.user_entries.code_entry -> physical_ram.user_frames.frame_b: "Private Mapping" {
  style.stroke: ${colors.user-arrow}
}

# Context Switch Path
process_a.cr3_a -> context_switch: "Interrupt/Yield" {
  style.stroke: "#94A3B8"
  style.stroke-dash: 4
}

context_switch -> process_b.cr3_b: "Reload CR3" {
  style.stroke: ${colors.cr3-arrow}
  style.stroke-width: 3
  style.animated: true
}

# Visual Boundary
boundary: "" {
  style.stroke: "#EF4444"
  style.stroke-width: 5
  style.stroke-dash: 10
  style.fill: transparent
}

process_a.pd_a.user_entries -> process_b.pd_b.user_entries: "ISOLATION BARRIER" {
  style.stroke: "#EF4444"
  style.stroke-width: 6
  # Corrected stroke-dash from 15 to 10 to comply with D2 limits (0-10)
  style.stroke-dash: 10
}