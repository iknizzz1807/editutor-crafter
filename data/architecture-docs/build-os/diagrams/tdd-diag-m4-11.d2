vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # System Call Dispatch Table
  `INT 0x80` → `EAX=syscall#` → `table[EAX](args)` → `EAX=result`
| {near: top-center}

direction: right

# 1. MEMORY LAYOUT: Dispatch Table
syscall_table: {
  label: "System Call Dispatch Table (Global Offset Table / .data section)"
  grid-columns: 5
  grid-gap: 0

  # Header Row
  h_idx: "Offset/Index" { style: { fill: "#D1C4E9"; bold: true; font-size: 14 } }
  h_num: "EAX Code" { style: { fill: "#D1C4E9"; bold: true; font-size: 14 } }
  h_sym: "Symbolic Name" { style: { fill: "#D1C4E9"; bold: true; font-size: 14 } }
  h_ptr: "Function Pointer" { style: { fill: "#D1C4E9"; bold: true; font-size: 14 } }
  h_arg: "Args (EBX, ECX, EDX)" { style: { fill: "#D1C4E9"; bold: true; font-size: 14 } }

  # Row 0: SYS_EXIT
  r0_0: "0x00" { style.fill: "#E3F2FD" }
  r0_1: "0" { style.fill: "#E3F2FD" }
  r0_2: "SYS_EXIT" { style.fill: "#E3F2FD" }
  r0_3: "&sys_exit" { style.fill: "#E3F2FD" }
  r0_4: "status" { style.fill: "#E3F2FD" }

  # Row 1: SYS_READ
  r1_0: "0x04" { style.fill: "#E3F2FD" }
  r1_1: "1" { style.fill: "#E3F2FD" }
  r1_2: "SYS_READ" { style.fill: "#E3F2FD" }
  r1_3: "&sys_read" { style.fill: "#E3F2FD" }
  r1_4: "fd, buf, count" { style.fill: "#E3F2FD" }

  # Row 2: SYS_WRITE
  r2_0: "0x08" { style.fill: "#E3F2FD" }
  r2_1: "2" { style.fill: "#E3F2FD" }
  r2_2: "SYS_WRITE" { style.fill: "#E3F2FD" }
  r2_3: "&sys_write" { style.fill: "#E3F2FD" }
  r2_4: "fd, buf, count" { style.fill: "#E3F2FD" }

  # Row 3: SYS_YIELD
  r3_0: "0x0C" { style.fill: "#E3F2FD" }
  r3_1: "3" { style.fill: "#E3F2FD" }
  r3_2: "SYS_YIELD" { style.fill: "#E3F2FD" }
  r3_3: "&sys_yield" { style.fill: "#E3F2FD" }
  r3_4: "void" { style.fill: "#E3F2FD" }

  # Row 4: SYS_GETPID
  r4_0: "0x10" { style.fill: "#E3F2FD" }
  r4_1: "4" { style.fill: "#E3F2FD" }
  r4_2: "SYS_GETPID" { style.fill: "#E3F2FD" }
  r4_3: "&sys_getpid" { style.fill: "#E3F2FD" }
  r4_4: "void" { style.fill: "#E3F2FD" }

  style: {
    stroke: "#512DA8"
    stroke-width: 2
    double-border: true
  }
}

# 2. ALGORITHM: Dispatch Flow
dispatch_flow: {
  label: "Kernel System Call Dispatcher (ASM/C Transition)"
  
  entry: "1. syscall_asm_entry\n(pusha, ds, es, fs, gs)" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
  
  read_eax: "2. Validate Range\n(cmp eax, NR_SYSCALLS)" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
  
  bounds_check: "EAX < 5?" {
    shape: diamond
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  
  lookup: "3. Index Table\n(call [syscall_table + eax*4])" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
  
  call_handler: "4. Execute Handler\n(Pass Pointer to Registers)" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
  }
  
  error: "INVALID_SYSCALL\n(return -ENOSYS)" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.font-color: "#C62828"
  }
  
  store_result: "5. Update EAX on Stack\n(regs->eax = result)" {
    shape: rectangle
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
  }
  
  exit: "6. iret\n(Restore User Context)" {
    shape: rectangle
    style.fill: "#F1F8E9"
    style.stroke: "#558B2F"
  }

  entry -> read_eax
  read_eax -> bounds_check
  bounds_check -> lookup: "VALID" { style.stroke: "#2E7D32" }
  bounds_check -> error: "OUT OF BOUNDS" { style.stroke: "#C62828"; style.stroke-dash: 3 }
  lookup -> call_handler
  call_handler -> store_result
  error -> store_result
  store_result -> exit
}

# 3. INTERFACE: Register Layout
register_interface: {
  label: "User/Kernel Register Interface"
  
  user_regs: {
    shape: sql_table
    label: "User Space State (Ring 3)"
    EAX: "Syscall ID" {constraint: "Input"}
    EBX: "Argument 1" {constraint: "Input"}
    ECX: "Argument 2" {constraint: "Input"}
    EDX: "Argument 3" {constraint: "Input"}
    ESP: "User Stack"
    style.fill: "#FCE4EC"
    style.stroke: "#AD1457"
  }

  kernel_stack: {
    shape: sql_table
    label: "Kernel Stack Frame (struct pt_regs)"
    offset_44: "GS/FS/ES/DS"
    offset_24: "EDI/ESI/EBP/ESP"
    offset_12: "EBX/EDX/ECX"
    offset_08: "EAX (Return Value)" {style.fill: "#FFFF00"}
    offset_00: "EIP/CS/EFLAGS (iret)"
    style.fill: "#E1F5FE"
    style.stroke: "#0277BD"
  }

  user_regs -> kernel_stack: "Hardware Interrupt\n+ pusha" {
    style.stroke-dash: 5
  }
}

# 4. IMPLEMENTATIONS: Handler Logic
handler_impl: {
  label: "C Handler Implementations"
  sys_exit: "sys_exit(int status)\n- Terminate Process\n- Wake Parent" {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  sys_write: "sys_write(int fd, char* buf, int count)\n- Verify Buffer Range\n- Output to Console/VGA" {
    style.fill: "#B3E5FC"
    style.stroke: "#0288D1"
  }
  sys_getpid: "sys_getpid()\n- return current->pid" {
    style.fill: "#E1BEE7"
    style.stroke: "#8E24AA"
  }
}

# 5. IDT CONFIG
idt: {
  idt_entry: "IDT Vector 0x80\n(Trap Gate)" {
    shape: rectangle
    style.fill: "#EDE7F6"
    style.stroke: "#5E35B1"
    style.bold: true
  }
  
  attributes: |md
    **IDT Entry 128:**
    - Selector: 0x08 (Kernel Code)
    - Offset: &syscall_asm_entry
    - DPL: 3 (User Accessible)
    - P: 1 (Present)
    - Type: 0x0F (32-bit Trap)
  | {
    shape: text
    style.font-size: 12
  }
}

# GLOBAL CONNECTIONS
idt.idt_entry -> dispatch_flow.entry: "Software Int\nint 0x80" {
  style.stroke: "#5E35B1"
  style.stroke-width: 3
}

syscall_table -> dispatch_flow.lookup: "Lookup via EAX" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  style.stroke-dash: 3
}

dispatch_flow.call_handler -> handler_impl: "C Function Call" {
  style.stroke: "#F57F17"
}

dispatch_flow.exit -> register_interface.user_regs: "iret to Ring 3" {
  style.stroke: "#558B2F"
  style.stroke-dash: 5
}

legend: |md
  ### Call Sequence Details
  1. **User Mode:** Load syscall ID into EAX, Args into EBX/ECX/EDX. Execute `int $0x80`.
  2. **CPU Action:** Switches to Kernel Stack, pushes SS, ESP, EFLAGS, CS, EIP.
  3. **ASM Entry:** Pushes all registers (`pusha`) creating `struct pt_regs` on stack.
  4. **Dispatch:** Checks `EAX` bounds, calls `syscall_table[EAX]`.
  5. **Handler:** Runs C logic, returns integer value.
  6. **Return:** Dispatcher saves return value into the `EAX` slot on the stack.
  7. **Exit:** `popa` restores registers (with new EAX), `iret` returns to user EIP.
| {
  near: bottom-center
  shape: text
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
}