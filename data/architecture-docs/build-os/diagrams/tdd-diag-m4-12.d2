vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#4A148E"
    kernel: "#C7F1FF"
    user: "#B5AFF6"
    free: "#E4DBFE"
    code: "#C7F1FF"
    data: "#B5AFF6"
    stack: "#E4DBFE"
    unused: "#DEE1EB"
    tss: "#ACE1AF"
    pcb: "#F6C889"
    pd: "#E4DBFE"
    pt: "#F6C889"
  }
}

title: OS Kernel Architecture Map {
  near: top-center
  style: {
    fill: "${colors.header}"
    font-color: white
    font-size: 24
  }
}

# Main hardware components
cpu: CPU {
  style.fill: "${colors.kernel}"
}

gdt: Global Descriptor Table {
  style.fill: "${colors.code}"
  width: 120
}

idt: Interrupt Descriptor Table {
  style.fill: "${colors.data}"
  width: 120
}

tss: Task State Segment {
  style.fill: "${colors.tss}"
  width: 120
}

# Memory hierarchy
memory: Physical Memory {
  style.fill: "${colors.data}"
  width: 160
}

pmm: Physical Memory Manager {
  style.fill: "${colors.unused}"
}

vmm: Virtual Memory Manager {
  style.fill: "${colors.unused}"
}

kheap: Kernel Heap {
  style.fill: "${colors.unused}"
}

# Process management
scheduler: Round-Robin Scheduler {
  style.fill: "${colors.stack}"
}

process_list: Process List {
  style.fill: "${colors.pcb}"
}

current_process: Current Process {
  style.fill: "${colors.pcb}"
  style.bold: true
}

# Hardware interfaces
pic: PIC (8259) {
  style.fill: "${colors.tss}"
}

pit: PIT Timer {
  style.fill: "${colors.tss}"
}

keyboard: PS/2 Keyboard {
  style.fill: "${colors.unused}"
}

# Boot sequence
bios: BIOS/UEFI {
  style.fill: "${colors.unused}"
}

bootloader: Bootloader {
  style.fill: "${colors.code}"
}

kernel: Kernel {
  style.fill: "${colors.code}"
  width: 180
}

# System calls
syscall: INT 0x80 Handler {
  style.fill: "${colors.code}"
  width: 120
}

# Connections
bios -> bootloader: Loads MBR
bootloader -> gdt: Initializes
bootloader -> idt: Loads IDT
bootloader -> kernel: Jumps to kernel
gdt -> idt: Required for IDT setup
cpu -> pic: IRQ lines
pic -> idt: Interrupt vectors
idt -> kernel: Dispatch ISRs
keyboard -> pic: IRQ1
pit -> pic: IRQ0
kernel -> memory: Memory operations
kernel -> pmm: Frame allocation
kernel -> vmm: Page mapping
kernel -> kheap: Heap allocation
kernel -> scheduler: Process management
scheduler -> process_list: Select process
scheduler -> cpu: Context switch
process_list -> current_process: Track running
syscall -> kernel: System calls
current_process -> kernel: Current context
kernel -> memory: Page table updates
cpu -> tss: Ring transitions

# Legend
legend: {
  near: bottom-right
  style.fill: transparent
  style.stroke: "#666"

  bios_component: {
    label: "BIOS/UEFI"
    style.fill: "${colors.unused}"
  }
  hardware: {
    label: "Hardware"
    style.fill: "${colors.tss}"
  }
  memory_mgmt: {
    label: "Memory Management"
    style.fill: "${colors.data}"
  }
  process_mgmt: {
    label: "Process Management"
    style.fill: "${colors.stack}"
  }
  boot_flow: {
    label: "Boot Flow"
    style.fill: "${colors.code}"
    style.stroke-dash: 3
  }
  irq_flow: {
    label: "IRQ Flow"
    style.fill: "${colors.kernel}"
    style.stroke-dash: 3
  }
  syscall_flow: {
    label: "System Calls"
    style.fill: "${colors.user}"
    style.stroke-dash: 3
  }
}