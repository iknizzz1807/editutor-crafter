vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    pcb: "#E8D5B7"
    stack_used: "#8B9DC3"
    stack_free: "#D8E2E8"
    tss: "#D4A5A5"
    cpu: "#9B8AA6"
    text_dark: "#2C3E50"
  }
}
title: |md
  # Kernel Stack per Process
  Each process has an 8KB kernel stack. PCB points to top.
  On user→kernel transition, CPU switches to this stack.
  TSS.ESP0 updated on every context switch.
| {near: top-center}
direction: right
Process_A: {
  label: "Process A\n(PCB)"
  style.fill: "${colors.pcb}"
  style.stroke: "#8B7355"
  style.stroke-width: 2
  pid: "pid: 1"
  name: "name: \"ProcessA\""
  state: "state: RUNNING"
  kernel_stack_ptr: |md
    **kernel_stack**
    0x00902000
    (top of stack)
  |
  kernel_stack_ptr.style.fill: "#F5E6D3"
  kernel_stack_ptr.style.stroke: "#8B7355"
  kernel_stack_ptr.style.bold: true
  page_dir: "page_directory: 0x00158000"
}
Process_A_Kernel_Stack: {
  label: "Process A Kernel Stack\n(8KB = 0x2000 bytes)"
  style.fill: "${colors.stack_free}"
  style.stroke: "#5D6D7E"
  style.stroke-width: 2
  stack_top: "0x00902000 (top)\n← kernel_stack points here"
  stack_top.style.fill: "${colors.stack_used}"
  stack_top.style.bold: true
  stack_top.style.font-color: "${colors.text_dark}"
  used_region: |md
    **Used region**
    (grows downward)
    - Saved registers
    - Return addresses
    - Local variables
    - Function call frames
  |
  used_region.style.fill: "${colors.stack_used}"
  used_region.style.stroke: "#5D6D7E"
  free_region: "Free space\n(available for\nfuture calls)"
  free_region.style.fill: "${colors.stack_free}"
  free_region.style.stroke-dash: 3
  stack_bottom: "0x00900000 (bottom)\nStack base"
  stack_bottom.style.fill: "#E8E8E8"
  stack_bottom.style.stroke: "#5D6D7E"
  arrow_annotation: |md
    Stack grows
    this way ↓
  |
  arrow_annotation.shape: text
  arrow_annotation.style.italic: true
  arrow_annotation.style.font-color: "#666666"
}
TSS: {
  label: "Task State Segment (TSS)"
  style.fill: "${colors.tss}"
  style.stroke: "#922B21"
  style.stroke-width: 2
  esp0: |md
    **esp0: 0x00902000**
    (Process A kernel stack)
  |
  esp0.style.fill: "#F5D5D5"
  esp0.style.bold: true
  esp0.style.stroke: "#922B21"
  ss0: "ss0: 0x0010\n(kernel data segment)"
  other_fields: "other fields...\n(esp1, esp2, cr3, etc.)"
}
CPU: {
  label: "CPU on Ring 3→0 Transition"
  style.fill: "${colors.cpu}"
  style.stroke: "#6C5B7B"
  style.stroke-width: 2
  action: |md
    1. User executes `int $0x80`
    2. CPU looks up IDT entry
    3. Sees Ring 0 handler
    4. **Reads TSS.ESP0**
    5. **Switches to kernel stack**
    6. Pushes: SS, ESP, EFLAGS, CS, EIP
    7. Jumps to handler
  |
  action.style.fill: "#E8E0ED"
}
Process_A.kernel_stack_ptr -> Process_A_Kernel_Stack.stack_top: "PCB stores\ntop address" {
  style.stroke: "#8B7355"
  style.stroke-width: 2
  style.bold: true
}
TSS.esp0 -> Process_A_Kernel_Stack.stack_top: "TSS.ESP0 =\nkernel_stack" {
  style.stroke: "#922B21"
  style.stroke-width: 2
  style.stroke-dash: 5
}
CPU -> TSS.esp0: "CPU reads\non privilege\nchange" {
  style.stroke: "#6C5B7B"
  style.stroke-width: 2
  style.animated: true
}
Context_Switch_Flow: {
  label: "Context Switch Updates TSS.ESP0"
  style.fill: "#F9F9F9"
  style.stroke: "#AAAAAA"
  style.stroke-dash: 3
  step1: "1. scheduler_yield() selects Process B"
  step2: "2. tss_update_esp0(Process B→kernel_stack)"
  step3: "3. TSS.ESP0 = Process B stack top"
  step4: "4. context_switch() saves A, loads B"
  step1 -> step2 -> step3 -> step4 {
    style.stroke: "#888888"
    style.stroke-dash: 2
  }
}
Memory_Layout_Table: {
  label: "Memory Layout Summary"
  shape: sql_table
  process: "Process"
  kernel_stack_base: "Stack Base"
  kernel_stack_top: "Stack Top (ESP0)"
  size: "Size"
  process -- kernel_stack_base -- kernel_stack_top -- size
  "Process A" -- "0x00900000" -- "0x00902000" -- "8KB"
  "Process B" -- "0x00902000" -- "0x00904000" -- "8KB"
  "Process C" -- "0x00904000" -- "0x00906000" -- "8KB"
}
notes: |md
  **Key Points:**
  - Each process gets its own 8KB kernel stack
  - Stack allocated via `kmalloc()` in `process_create()`
  - PCB's `kernel_stack` field stores the TOP address
  - TSS.ESP0 updated on EVERY context switch
  - Without correct ESP0, Ring 3→0 would corrupt stack
  - Stack overflow corrupts adjacent process's stack
| {
  near: bottom-center
  shape: text
  style.font-size: 14
}