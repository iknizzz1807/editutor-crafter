vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Multi-Process Demo Memory Layout
  **4 Concurrent Processes with Memory Isolation**
| {near: top-center}

direction: right

# =============================================================================
# KERNEL MEMORY REGION
# =============================================================================
kernel_space: "Kernel Space (Ring 0)" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2

  kernel_code: "Kernel Code\n.text @ 0x00100000" {
    style.fill: "#D4E6F1"
    style.stroke: "#2874A6"
  }

  kernel_heap: "Kernel Heap\nkmalloc() pool\n@ 0xC0400000" {
    style.fill: "#D5F5E3"
    style.stroke: "#1E8449"
  }

  pmm_bitmap: "PMM Bitmap\n~128KB @ _kernel_end" {
    style.fill: "#FCF3CF"
    style.stroke: "#B7950B"
  }

  kernel_stack: "Kernel Stack\nESP = 0x90000" {
    style.fill: "#FADBD8"
    style.stroke: "#922B21"
  }
}

# =============================================================================
# PROCESS CONTROL BLOCKS
# =============================================================================
pcb_region: "Process Control Blocks (112 bytes each)" {
  style.fill: "#F4ECF7"
  style.stroke: "#6C3483"
  style.stroke-width: 2

  pcb_a: "PCB_A {\n  pid: 1\n  name: \"ProcessA\"\n  state: RUNNING\n  time_slice: 10\n  page_dir: 0 (kernel)\n  k_stack: 0xC0402000\n}" {
    style.fill: "#FADBD8"
    style.stroke: "#C0392B"
    style.bold: true
  }

  pcb_b: "PCB_B {\n  pid: 2\n  name: \"ProcessB\"\n  state: READY\n  time_slice: 7\n  page_dir: 0 (kernel)\n  k_stack: 0xC0404000\n}" {
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
  }

  pcb_c: "PCB_C {\n  pid: 3\n  name: \"ProcessC\"\n  state: READY\n  time_slice: 3\n  page_dir: 0 (kernel)\n  k_stack: 0xC0406000\n}" {
    style.fill: "#D6EAF8"
    style.stroke: "#2E86C1"
  }

  pcb_user: "PCB_User {\n  pid: 4\n  name: \"UserTest\"\n  state: READY\n  time_slice: 10\n  page_dir: 0x00300000\n  k_stack: 0xC0408000\n  u_stack: 0x080FFFFF\n}" {
    style.fill: "#F9E79F"
    style.stroke: "#D68910"
  }

  pcb_a -- pcb_b -- pcb_c -- pcb_user: "process_list (doubly-linked)" {
    style.stroke-dash: 3
    style.stroke: "#6C3483"
  }
}

# =============================================================================
# KERNEL PROCESS STACKS
# =============================================================================
kernel_stacks: "Kernel Process Stacks (8KB each)" {
  style.fill: "#FDEBD0"
  style.stroke: "#BA4A00"
  style.stroke-width: 2

  stack_a: "Stack A\n0xC0400000-\n0xC0402000\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ 8KB     в”Ӯ\nв”Ӯ grows   в”Ӯ\nв”Ӯ down    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n     вҶ‘\n   ESP" {
    style.fill: "#FADBD8"
    style.stroke: "#C0392B"
    shape: hexagon
  }

  stack_b: "Stack B\n0xC0402000-\n0xC0404000\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ 8KB     в”Ӯ\nв”Ӯ grows   в”Ӯ\nв”Ӯ down    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
    shape: hexagon
  }

  stack_c: "Stack C\n0xC0404000-\n0xC0406000\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ 8KB     в”Ӯ\nв”Ӯ grows   в”Ӯ\nв”Ӯ down    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#D6EAF8"
    style.stroke: "#2E86C1"
    shape: hexagon
  }

  stack_user: "Stack User\n0xC0406000-\n0xC0408000\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ 8KB     в”Ӯ\nв”Ӯ grows   в”Ӯ\nв”Ӯ down    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n     вҶ‘\nTSS.ESP0" {
    style.fill: "#F9E79F"
    style.stroke: "#D68910"
    shape: hexagon
  }
}

# =============================================================================
# VGA TEXT MODE BUFFER
# =============================================================================
vga_buffer: "VGA Text Buffer @ 0xB8000 (80Г—25 = 2000 chars)" {
  style.fill: "#1C2833"
  style.stroke: "#17202A"
  style.stroke-width: 2
  style.font-color: "#ECF0F1"

  row_0_9: "Rows 0-9\n\nProcess A Output\n'A' characters\nprinted at row 10" {
    style.fill: "#2C3E50"
    style.font-color: "#BDC3C7"
  }

  row_10_11: "Row 10-11\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  A A A A A A A A A A A A A A   в”Ӯ  вҶҗ Process A (RED)\nв”Ӯ  count++ every 1000000 loops   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#C0392B"
    style.font-color: "#FFFFFF"
    style.bold: true
  }

  row_12_13: "Row 12-13\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  B B B B B B B B B B B B B B   в”Ӯ  вҶҗ Process B (GREEN)\nв”Ӯ  count++ every 1000000 loops   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#27AE60"
    style.font-color: "#FFFFFF"
    style.bold: true
  }

  row_14_15: "Row 14-15\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ  C C C C C C C C C C C C C C   в”Ӯ  вҶҗ Process C (BLUE)\nв”Ӯ  count++ every 1000000 loops   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#2E86C1"
    style.font-color: "#FFFFFF"
    style.bold: true
  }

  row_16_24: "Rows 16-24\n\nUser Process Output\nvia sys_write()\n\"Hello from user mode!\"" {
    style.fill: "#2C3E50"
    style.font-color: "#BDC3C7"
  }
}

# =============================================================================
# USER PROCESS ADDRESS SPACE
# =============================================================================
user_space: "User Process Address Space (Ring 3, PID 4)" {
  style.fill: "#FEF9E7"
  style.stroke: "#B7950B"
  style.stroke-width: 2

  user_code: "User Code\n@ 0x08048000\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ entry_point    в”Ӯ\nв”Ӯ sys_write(1,..)в”Ӯ\nв”Ӯ sys_getpid()   в”Ӯ\nв”Ӯ sys_exit(0)    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#F9E79F"
    style.stroke: "#D68910"
  }

  user_stack_region: "User Stack\n@ 0x08000000-\n0x08100000 (64KB)\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ 64KB           в”Ӯ\nв”Ӯ grows down     в”Ӯ\nв”Ӯ                в”Ӯ\nв”Ӯ     вҶ‘          в”Ӯ\nв”Ӯ   ESP (user)   в”Ӯ\nв”Ӯ = 0x080FFFFF   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#FCF3CF"
    style.stroke: "#B7950B"
    shape: hexagon
  }

  user_pd: "Page Directory\n@ 0x00300000 (phys)\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Entry 0-767:   в”Ӯ\nв”Ӯ   0 (unmapped) в”Ӯ\nв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\nв”Ӯ Entry 768-1023:в”Ӯ\nв”Ӯ   Kernel copy  в”Ӯ\nв”Ӯ   (U/S=0)      в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
    style.fill: "#E8DAEF"
    style.stroke: "#7D3C98"
  }
}

# =============================================================================
# PAGE DIRECTORY ISOLATION
# =============================================================================
page_dirs: "Page Directories (Physical Memory)" {
  style.fill: "#E8DAEF"
  style.stroke: "#7D3C98"
  style.stroke-width: 2

  kernel_pd_box: "Kernel PD\n@ 0x001XX000\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ 0-767: identityв”Ӯ\nв”Ӯ   + higher-halfв”Ӯ\nв”Ӯ 768-1023: kern в”Ӯ\nв”Ӯ   (U/S=0)      в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n\nUsed by: Process A, B, C\n(page_dir = 0 means kernel PD)" {
    style.fill: "#D4E6F1"
    style.stroke: "#2874A6"
  }

  user_pd_box: "User PD\n@ 0x00300000\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ 0-767: user    в”Ӯ\nв”Ӯ   code/stack   в”Ӯ\nв”Ӯ 768-1023: kern в”Ӯ\nв”Ӯ   (U/S=0) вҳ…    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n\nвҳ… Isolation: user cannot\n   access kernel entries" {
    style.fill: "#F9E79F"
    style.stroke: "#D68910"
    style.bold: true
  }
}

# =============================================================================
# SCHEDULER STATE
# =============================================================================
scheduler: "Scheduler State" {
  style.fill: "#E8F8F5"
  style.stroke: "#117A65"
  style.stroke-width: 2

  ready_queue: "Ready Queue (Circular)\n\n     current\n        вҶ“\n    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n    в”Ӯ   A   в”Ӯ вҶҗ RUNNING\n    в””в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”ҳ\n        в”Ӯ\n    в”Ңв”Җв”Җв”ҖвҶ“в”Җв”Җв”Җв”җ\n    в”Ӯ   B   в”Ӯ вҶҗ READY\n    в””в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”ҳ\n        в”Ӯ\n    в”Ңв”Җв”Җв”ҖвҶ“в”Җв”Җв”Җв”җ\n    в”Ӯ   C   в”Ӯ вҶҗ READY\n    в””в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”ҳ\n        в”Ӯ\n    в”Ңв”Җв”Җв”ҖвҶ“в”Җв”Җв”Җв”җ\n    в”Ӯ User  в”Ӯ вҶҗ READY\n    в””в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”ҳ\n        в”Ӯ\n    (back to A)\n\nTime slices: 10 ticks each\nTimer: 100Hz = 10ms/slice" {
    style.fill: "#D1F2EB"
    style.stroke: "#117A65"
  }

  tss_box: "Task State Segment\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ esp0 = 0xC0408000   в”Ӯ вҶҗ Updated on\nв”Ӯ ss0  = 0x10         в”Ӯ    context switch\nв”Ӯ iomap = 104         в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n\nRing 3вҶ’0 transition uses\nTSS.ESP0 as kernel stack" {
    style.fill: "#FADBD8"
    style.stroke: "#C0392B"
  }
}

# =============================================================================
# CONNECTIONS
# =============================================================================
# PCB to Stack connections
pcb_a -> stack_a: "k_stack" {style.stroke: "#C0392B"; style.stroke-dash: 2}
pcb_b -> stack_b: "k_stack" {style.stroke: "#27AE60"; style.stroke-dash: 2}
pcb_c -> stack_c: "k_stack" {style.stroke: "#2E86C1"; style.stroke-dash: 2}
pcb_user -> stack_user: "k_stack" {style.stroke: "#D68910"; style.stroke-dash: 2}

# Process A writes to VGA row 10
stack_a -> vga_buffer.row_10_11: "vga_put_char_at('A',...)" {
  style.stroke: "#C0392B"
  style.stroke-width: 2
  style.animated: true
  label: "Direct VGA\naccess\n(0xB8000)"
}

# Process B writes to VGA row 12
stack_b -> vga_buffer.row_12_13: "vga_put_char_at('B',...)" {
  style.stroke: "#27AE60"
  style.stroke-width: 2
  style.animated: true
  label: "Direct VGA\naccess\n(0xB8000)"
}

# Process C writes to VGA row 14
stack_c -> vga_buffer.row_14_15: "vga_put_char_at('C',...)" {
  style.stroke: "#2E86C1"
  style.stroke-width: 2
  style.animated: true
  label: "Direct VGA\naccess\n(0xB8000)"
}

# User process uses syscall
user_space.user_code -> vga_buffer.row_16_24: "sys_write(1, msg, len)" {
  style.stroke: "#D68910"
  style.stroke-width: 2
  style.stroke-dash: 5
  label: "INT 0x80\nsyscall"
}

# User PD isolation
user_pd -> user_space.user_pd: "CR3=0x00300000" {
  style.stroke: "#7D3C98"
  style.stroke-dash: 3
}

# Scheduler to PCBs
scheduler.ready_queue -> pcb_region: "selects next" {
  style.stroke: "#117A65"
  style.stroke-dash: 3
}

# TSS update
pcb_user -> scheduler.tss_box: "tss_update_esp0()" {
  style.stroke: "#C0392B"
  style.stroke-dash: 2
  label: "Before\niret to\nuser mode"
}

# =============================================================================
# LEGEND
# =============================================================================
legend: |md
  ## Legend
  **Memory Colors:**
  - рҹ”ҙ Red: Process A / Current Running / TSS
  - рҹҹў Green: Process B / Heap
  - рҹ”ө Blue: Process C / Kernel Code
  - рҹҹЎ Yellow: User Process (Ring 3)
  - рҹҹЈ Purple: Page Directories

  **Line Types:**
  - Solid: Direct memory access
  - Dashed: Pointer/reference
  - Animated: Active data flow

  **Key Concepts:**
  1. Kernel processes A, B, C share kernel page directory
  2. Each process has 8KB kernel stack
  3. User process has isolated page directory
  4. TSS.ESP0 updated on every context switch
  5. Round-robin: 10ms time slices at 100Hz
| {near: bottom-center}

# =============================================================================
# MEMORY LAYOUT SUMMARY
# =============================================================================
memory_summary: "Physical Memory Map Summary" {
  shape: rectangle
  style.fill: "#F4F6F6"
  style.stroke: "#566573"
  style.stroke-width: 2
  near: bottom-right
  layout: |md
    Physical Address    Size      Purpose
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    0x00000000-0x000FFFFF  1MB    Reserved (BIOS, VGA)
    0x00100000-0x001XXXXX  ~XXX   Kernel binary
    0x001YYYYY-0x001ZZZZZ  128KB  PMM bitmap
    0x00200000-0x002FFFFF  1MB    Free (available)
    0x00300000-0x00300FFF  4KB    User Page Directory вҳ…
    0x00301000-0x003FFFFF  ~1MB   Free (available)
    ...                           More free frames
    
    **Virtual Address Space:**
    
    0x00000000-0xBFFFFFFF   User space (per-process)
    0xC0000000-0xC03FFFFF   Kernel identity map (4MB)
    0xC0400000-0xC1400000   Kernel heap (16MB max)
  |
}