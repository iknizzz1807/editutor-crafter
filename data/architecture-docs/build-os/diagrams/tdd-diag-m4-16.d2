vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # Process State Machine
| {near: top-center}
# States
READY: {
  shape: circle
  style: {
    fill: "#4CAF50"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: white
    shadow: true
  }
  tooltip: "Process is in the run queue, waiting for CPU time"
}
RUNNING: {
  shape: circle
  style: {
    fill: "#2196F3"
    stroke: "#1565C0"
    stroke-width: 3
    font-color: white
    shadow: true
  }
  tooltip: "Process is currently executing on the CPU"
}
BLOCKED: {
  shape: circle
  style: {
    fill: "#FF9800"
    stroke: "#EF6C00"
    stroke-width: 3
    font-color: white
    shadow: true
  }
  tooltip: "Process is waiting for I/O, event, or resource"
}
TERMINATED: {
  shape: circle
  style: {
    fill: "#9E9E9E"
    stroke: "#616161"
    stroke-width: 3
    font-color: white
    shadow: true
  }
  tooltip: "Process has exited and is awaiting cleanup"
}
# Initial state marker
NULL: {
  shape: circle
  style: {
    fill: transparent
    stroke: "#333"
    stroke-width: 2
  }
  width: 40
}
# Transitions
NULL -> READY: {
  label: "process_create()"
  style: {
    stroke: "#333"
    stroke-width: 2
    font-size: 14
  }
  source-arrowhead: {
    shape: circle
    style.filled: true
  }
}
READY -> RUNNING: {
  label: "scheduler_dispatch()"
  style: {
    stroke: "#2196F3"
    stroke-width: 3
    animated: true
    font-size: 14
  }
}
RUNNING -> READY: {
  label: "scheduler_yield()\ntime_slice expired"
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    animated: true
    font-size: 14
  }
}
RUNNING -> BLOCKED: {
  label: "scheduler_block()\nI/O wait, sleep"
  style: {
    stroke: "#FF9800"
    stroke-width: 2
    font-size: 14
  }
}
BLOCKED -> READY: {
  label: "scheduler_unblock()\nI/O complete, event"
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
    font-size: 14
  }
}
RUNNING -> TERMINATED: {
  label: "sys_exit(status)\nprocess_terminate()"
  style: {
    stroke: "#9E9E9E"
    stroke-width: 2
    font-size: 14
  }
}
# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#E0E0E0"
    stroke-dash: 2
    border-radius: 8
  }
  legend_title: |md
    ### Legend
  |
  trans_preempt: "───▶ Preemptive (timer)" {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 12
    }
  }
  trans_coop: "───▶ Cooperative (yield)" {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 12
    }
  }
  trans_terminal: "───▶ Terminal transition" {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 12
    }
  }
}
# State invariants
invariants: {
  near: bottom-left
  style: {
    fill: "#FFF3E0"
    stroke: "#FFB74D"
    border-radius: 8
  }
  inv_title: |md
    ### State Invariants
  |
  inv_content: |md
    - **READY**: Process PCB in run queue
    - **RUNNING**: `current_process == PCB`
    - **BLOCKED**: Removed from run queue
    - **TERMINATED**: PCB awaiting `kfree()`
  |
}
# Illegal transitions note
illegal: {
  near: top-right
  style: {
    fill: "#FFEBEE"
    stroke: "#EF5350"
    border-radius: 8
  }
  illegal_title: |md
    ### ⚠️ Illegal Transitions
  |
  illegal_content: |md
    - `TERMINATED → *` (no return)
    - `READY → BLOCKED` (must run first)
    - `BLOCKED → RUNNING` (must go via READY)
    - `NULL → RUNNING` (must be created)
  |
}