direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Process Isolation via Page Tables
  ### Memory Protection & Privilege Levels (Ring 0 vs Ring 3)
| {near: top-center}

kernel_space: "Privilege Separation (CPU Protection Rings)" {
  style.stroke-width: 4
  
  kernel_mem_container: "Kernel Memory (Ring 0)" {
    style.fill: "#E8D4B8"
    style.stroke: "#7B5E7A"
    style.double-border: true
    
    kernel_memory: {
      label: "Kernel Image & Data\nLinear: 0xC0000000 - 0xFFFFFFFF"
      code: "System Code" {
        style.fill: "#C7A4D8"
      }
      structures: "Process Control Blocks" {
        style.fill: "#B89FE8"
      }
    }
  }

  user_space: "User Space (Ring 3)" {
    user_proc_a: "Process A" {
      style.fill: "#A8E6CF"
      style.stroke: "#5A9E68"
      stack_a: "Stack"
      heap_a: "Heap"
      code_a: "Code"
    }
    user_proc_b: "Process B" {
      style.fill: "#FFE4B5"
      style.stroke: "#E6B84D"
      stack_b: "Stack"
      heap_b: "Heap"
      code_b: "Code"
    }
    user_proc_c: "Process C" {
      style.fill: "#B5D8FF"
      style.stroke: "#5A8AE6"
      stack_c: "Stack"
      heap_c: "Heap"
      code_c: "Code"
    }
  }
}

page_tables: "Memory Management Unit (Page Tables)" {
  style.fill: "#F0F0F0"
  style.stroke: "#999999"
  style.stroke-dash: 3

  pd_a: "Page Directory A (CR3_A)" {
    style.fill: "#A8E6CF"
    entry_a_kernel: "Kernel Entries [768-1023]" {
      label: "Kernel Entries\n[768-1023]\nSupervisor Only\n(U/S=0)"
      style.fill: "#C7A4D8"
      style.font-color: white
    }
    entry_a_user: "User Entries [0-767]" {
      label: "User Entries\n[0-767]\nProcess A Private\n(U/S=1)"
      style.fill: "#E8F4E8"
    }
  }

  pd_b: "Page Directory B (CR3_B)" {
    style.fill: "#FFE4B5"
    entry_b_kernel: "Kernel Entries [768-1023]" {
      label: "Kernel Entries\nShared Mapping\n(U/S=0)"
      style.fill: "#C7A4D8"
      style.font-color: white
    }
    entry_b_user: "User Entries [0-767]" {
      label: "User Entries\n[0-767]\nProcess B Private\n(U/S=1)"
      style.fill: "#FFF4E0"
    }
  }

  pd_c: "Page Directory C (CR3_C)" {
    style.fill: "#B5D8FF"
    entry_c_kernel: "Kernel Entries [768-1023]" {
      label: "Kernel Entries\nShared Mapping\n(U/S=0)"
      style.fill: "#C7A4D8"
      style.font-color: white
    }
    entry_c_user: "User Entries [0-767]" {
      label: "User Entries\n[0-767]\nProcess C Private\n(U/S=1)"
      style.fill: "#E0F0FF"
    }
  }
}

isolation_check: "Isolation Verification Logic" {
  style.fill: "#FFE0E0"
  style.stroke: "#CC0000"
  style.double-border: true

  attempt: "Access Violation" {
    label: "Process A tries to\naccess kernel memory\nvia syscall-less pointer"
    style.fill: "#FFCCCC"
  }
  result: "CPU Exception" {
    label: "Page Fault!\nError Code: 0x5\nU/S bit = 0\n(supervisor-only)"
    style.fill: "#FF9999"
    style.font-color: white
    style.bold: true
  }
}

# Explicit Access Path Connections
kernel_space.user_space.user_proc_a.code_a -> page_tables.pd_a.entry_a_user: "Virtual Addr Translation"
kernel_space.user_space.user_proc_b.code_b -> page_tables.pd_b.entry_b_user: "Virtual Addr Translation"
kernel_space.user_space.user_proc_c.code_c -> page_tables.pd_c.entry_c_user: "Virtual Addr Translation"

page_tables.pd_a.entry_a_kernel -> kernel_space.kernel_mem_container.kernel_memory: "Restricted Map" {
  style.stroke: "#7B5E7A"
  style.stroke-width: 2
}
page_tables.pd_b.entry_b_kernel -> kernel_space.kernel_mem_container.kernel_memory: "Restricted Map"
page_tables.pd_c.entry_c_kernel -> kernel_space.kernel_mem_container.kernel_memory: "Restricted Map"

# Security Breach Simulation
isolation_check.attempt -> kernel_space.kernel_mem_container.kernel_memory: "ILLEGAL ACCESS" {
  style.stroke: "#CC0000"
  style.stroke-dash: 5
  style.animated: true
  style.stroke-width: 4
}

kernel_space.kernel_mem_container.kernel_memory -> isolation_check.result: "Hardware Trap\n(Ring 3 -> Ring 0)" {
  style.stroke: "#CC0000"
  style.bold: true
}

legend: |md
  ### Key Isolation Mechanism (MMU Enforcement)
  - **Context Switching**: Each process has a unique `CR3` register value pointing to its private Page Directory.
  - **Shared Kernel Space**: Entries 768-1023 are identical across all directories to allow kernel services, but protected by the `U/S` (User/Supervisor) bit.
  - **Privilege Level (CPL)**: The CPU checks the `CPL` against the page's `U/S` bit. If `CPL=3` and `U/S=0`, the MMU generates an exception.
  - **Memory Safety**: Process A cannot even "see" Process B's memory because it is not mapped in `PD_A`.
| {near: bottom-center}