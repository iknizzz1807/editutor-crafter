direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # CAP Theorem: Raft's Position
  Consistency + Partition Tolerance = **CP System**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cap_triangle: {
    direction: down
    label: CAP Triangle
    c_vertex: {
      shape: circle
      label: Consistency
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      style.stroke-width: 3
    }
    a_vertex: {
      shape: circle
      label: Availability
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      style.stroke-width: 2
    }
    p_vertex: {
      shape: circle
      label: Partition\nTolerance
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      style.stroke-width: 3
    }
    raft_position: {
      shape: circle
      label: "**Raft**\n(CP)"
      style.fill: "#C8E6C9"
      style.stroke: "#1B5E20"
      style.stroke-width: 4
      style.bold: true
    }
    ca_systems: {
      shape: circle
      label: CA\n(single-node)
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      style.stroke-dash: 3
    }
    ap_systems: {
      shape: circle
      label: AP\n(eventual)
      style.fill: "#FFECB3"
      style.stroke: "#FF6F00"
      style.stroke-dash: 3
    }
    c_vertex -- a_vertex: {
      style.stroke: "#90A4AE"
      style.stroke-dash: 3
    }
    a_vertex -- p_vertex: {
      style.stroke: "#90A4AE"
      style.stroke-dash: 3
    }
    p_vertex -- c_vertex: {
      style.stroke: "#90A4AE"
      style.stroke-dash: 3
    }
  }
  legend: {
    label: System Types
    style.fill: "#FAFAFA"
    style.stroke: "#E0E0E0"
    cp_legend: "CP: Consistency + Partition Tolerance"
    ap_legend: "AP: Availability + Partition Tolerance"
    ca_legend: "CA: Consistency + Availability (no partitions)"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  raft_behavior: {
    label: Raft During Partition
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    minority: {
      label: Minority Partition
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      status: "**UNAVAILABLE**\nCannot reach quorum\nCannot elect leader\nCannot commit writes"
    }
    majority: {
      label: Majority Partition
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      status: "**AVAILABLE**\nHas quorum (3 of 5)\nCan elect leader\nCan commit writes"
    }
    minority -> majority: "Network\nPartition" {
      style.stroke: "#B71C1C"
      style.stroke-dash: 5
      style.stroke-width: 2
    }
  }
  comparison: {
    label: System Comparison
    style.fill: "#FAFAFA"
    style.stroke: "#E0E0E0"
    raft_row: {
      direction: right
      raft_icon: "**Raft**" {
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
        shape: rectangle
      }
      raft_type: "CP"
      raft_trait: "Linearizable reads"
      raft_cost: "Unavailable during partition"
    }
    cassandra_row: {
      direction: right
      cass_icon: "**Cassandra**" {
        style.fill: "#FFECB3"
        style.stroke: "#FF6F00"
        shape: rectangle
      }
      cass_type: "AP"
      cass_trait: "Eventual consistency"
      cass_cost: "May return stale data"
    }
    postgres_row: {
      direction: right
      pg_icon: "**PostgreSQL**" {
        style.fill: "#F3E5F5"
        style.stroke: "#7B1FA2"
        shape: rectangle
      }
      pg_type: "CA"
      pg_trait: "Strong consistency"
      pg_cost: "No network partitions"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  key_insight: {
    label: Key Insight
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    insight: |md
      **Raft chooses Consistency over Availability**
      During a network partition:
      - Minority side: Blocks all operations (cannot confirm leadership)
      - Majority side: Continues normally (has quorum)
      This is the **correct choice** for:
      - Coordination tasks (locks, configuration)
      - Financial transactions
      - Metadata management
      Trade-off: System may be temporarily unavailable
      to prevent data inconsistency.
    |
  }
}
raft_behavior.minority.status.style.fill: "#FFCDD2"
raft_behavior.majority.status.style.fill: "#C8E6C9"