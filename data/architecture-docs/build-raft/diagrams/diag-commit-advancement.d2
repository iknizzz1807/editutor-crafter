direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Commit Index Advancement Rules
  **Leader-only operation with Figure 8 safety constraint**
| {near: top-center}
row_conditions: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cond1: {
    label: "Condition 1"
    width: 200
    check: "N > commitIndex"
    desc: |md
      Target index must be
      **higher** than current
      commitIndex
    |
  }
  cond2: {
    label: "Condition 2"
    width: 200
    check: "majority(matchIndex) >= N"
    desc: |md
      Entry replicated to
      **quorum** of nodes
      (≥ ⌈(N+1)/2⌉)
    |
  }
  cond3: {
    label: "Condition 3"
    width: 200
    style.stroke: "#E53935"
    style.stroke-width: 3
    check: "log[N].term == currentTerm"
    desc: |md
      Entry is from
      **current term**
      (Figure 8 fix!)
    |
    warning: "CRITICAL"
  }
}
cond1.check: {
  shape: diamond
  width: 160
  style.fill: "#E8F5E9"
}
cond2.check: {
  shape: diamond
  width: 160
  style.fill: "#E8F5E9"
}
cond3.check: {
  shape: diamond
  width: 160
  style.fill: "#FFEBEE"
}
cond3.warning: {
  shape: callout
  style.fill: "#FFCDD2"
  style.stroke: "#E53935"
}
leader_check: {
  label: "Leader evaluates\ncommitIndex candidate N"
  shape: oval
  style.fill: "#E3F2FD"
}
all_check: {
  label: "All 3 conditions\nmet?"
  shape: diamond
  width: 140
  style.fill: "#FFF9C4"
}
advance: {
  label: "commitIndex = N"
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.bold: true
}
indirect_commit: {
  label: "Transitive Commit\n(previous-term entries)"
  width: 300
  desc: |md
    Entries at indices **< N** from
    **previous terms** are now
    **indirectly committed**
    Example: If commitIndex advances to 10
    and log[8].term < currentTerm,
    entry 8 is now committed
  |
  style.fill: "#F3E5F5"
}
no_advance: {
  label: "Cannot commit N"
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke-dash: 3
}
leader_check -> cond1.check: "check"
cond1.check -> cond2.check: "✓ pass"
cond2.check -> cond3.check: "✓ pass"
cond3.check -> all_check: "✓ pass"
all_check -> advance: "YES"
advance -> indirect_commit: "triggers"
all_check -> no_advance: "NO" {
  style.stroke-dash: 4
}
figure8_box: {
  label: "Figure 8 Safety Rule"
  width: 500
  style.stroke: "#E53935"
  style.stroke-width: 2
  style.fill: "#FFF3E0"
  problem: {
    label: "The Problem"
    width: 220
    code: |'c
      // WRONG: Commit any
      // majority-replicated entry
      if count >= majority {
        commitIndex = N  // BUG!
      }
    '|
  }
  solution: {
    label: "The Fix"
    width: 220
    code: |'c
      // CORRECT: Only current-term
      if log[N].Term == currentTerm 
         && count >= majority {
        commitIndex = N  // Safe
      }
    '|
  }
  reason: |md
    **Why?** An entry from a previous term replicated to majority is **NOT safe to commit directly**. A new leader could overwrite it.
    Committing a **current-term entry** proves this leader was elected by majority → majority acknowledged this log → previous entries are safe.
  |
}
legend: {
  near: bottom-right
  label: "Legend"
  green: "✓ Condition satisfied"
  red: "⚠ Critical safety check"
  purple: "Indirect commit (transitive)"
}
legend.green: {shape: text; style.font-color: "#388E3C"}
legend.red: {shape: text; style.font-color: "#E53935"}
legend.purple: {shape: text; style.font-color: "#7B1FA2"}
cond3 -> figure8_box: "why this matters" {
  style.stroke: "#E53935"
  style.stroke-dash: 5
}