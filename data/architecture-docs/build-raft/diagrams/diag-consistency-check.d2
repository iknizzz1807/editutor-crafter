direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "Log Consistency Check — Inductive Proof"
  explanation: |'md
    ### The Inductive Proof of Log Equality
  '|
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  leader: {
    direction: down
    label: "Leader (term 4)"
    leader_log: {
      shape: sql_table
      label: "leader.log"
      e1: "1 | 1 | cmd A"
      e2: "2 | 1 | cmd B"
      e3: "3 | 3 | cmd C"
      e4: "4 | 3 | cmd D"
      e5: "5 | 3 | cmd E"
      e6: "6 | 4 | cmd F"
      e7: "7 | 4 | cmd G"
      note: "prevLogIndex=5"
    }
    leader_state: {
      shape: class
      label: "Leader State (per-follower)"
      "-nextIndex[F]": "7"
      "-matchIndex[F]": "0"
    }
  }

  rpc_box: {
    direction: down
    label: "AppendEntries RPC"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    args: {
      shape: class
      label: "AppendEntriesArgs"
      "+term": "4"
      "+leaderId": "L"
      "+prevLogIndex": "5"
      "+prevLogTerm": "3"
      "+entries": "[{6,4,F}, {7,4,G}]"
      "+leaderCommit": "5"
    }
    arrow_down: {
      shape: text
      label: "↓"
      style.font-size: 24
    }
  }

  follower: {
    direction: down
    label: "Follower (term 4)"
    follower_log: {
      shape: sql_table
      label: "follower.log"
      f1: "1 | 1 | cmd A"
      f2: "2 | 1 | cmd B"
      f3: "3 | 3 | cmd C"
      f4: "4 | 3 | cmd D"
      f5: "5 | 3 | cmd E"
      f6: "6 | 2 | cmd X"
      f7: "7 | 2 | cmd Y"
      note: "log[5].term = 3 ✓"
    }
    check_result: {
      shape: diamond
      label: "Check\nlog[5].term\n== 3?"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  proof: {
    direction: down
    label: "Inductive Proof"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    base: {
      label: "Base Case"
      width: 300
      code: |'text
        If log[1] matches (same index/term),
        then logs are identical at index 1.
        ✓ Established by first AppendEntries.
      '|
    }
    inductive: {
      label: "Inductive Step"
      width: 300
      code: |'text
        Assume: logs identical up to index N.
        Prove: if log[N+1] matches,
        logs identical up to N+1.
        Proof: prevLogIndex check guarantees
        log[N] matches.
      '|
    }
    conclusion: {
      label: "Conclusion"
      width: 300
      code: |'text
        prevLogIndex=5 check proves:
        "We agree up to index 5"
        = "Safe to append entries 6+"
      '|
    }
  }

  outcomes: {
    direction: down
    label: "Three Outcomes"
    match_outcome: {
      label: "MATCH: log[5].term == 3"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      code: |'go
        if log[5].term == args.prevLogTerm {
          log = log[:6] // Truncate divergence
          log.append(args.entries...)
          reply.success = true
        }
      '|
      width: 320
    }
    mismatch_outcome: {
      label: "MISMATCH: log[5].term != 3"
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      code: |'go
        reply.success = false
        reply.conflictTerm = log[5].term
        reply.conflictIndex = first(log[5].term)
        // Leader will decrement nextIndex
      '|
      width: 320
    }
    missing_outcome: {
      label: "MISSING: len(log) <= 5"
      style.fill: "#FFF9C4"
      style.stroke: "#FFC107"
      code: |'go
        reply.success = false
        reply.conflictIndex = len(log)
        reply.conflictTerm = -1
        // Leader retries from len(log)
      '|
      width: 320
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  git_analogy: {
    direction: down
    label: "Git Fast-Forward Analogy"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    git_box: {
      width: 400
      code: |'text
        Git: "HEAD must be an ancestor 
             to fast-forward"
        Raft: "Entry at prevLogIndex must 
              match leader to append"
        Inductive safety: no history 
        divergence possible.
      '|
    }
  }
  sequence: {
    direction: down
    label: "Retry Sequence on Mismatch"
    style.fill: "#E0F2F1"
    style.stroke: "#009688"
    seq: {
      width: 400
      code: |'text
        Attempt 1: prevLogIndex=6 -> Reject
        Attempt 2: prevLogIndex=5 -> Reject
        Attempt 3: prevLogIndex=4 -> Accept!
        (log[4].term matches)
        Result: Logs converge to leader.
      '|
    }
  }
}

row1.leader.leader_state -> row1.rpc_box.args: "construct"
row1.rpc_box -> row1.follower.follower_log: "send"
row1.follower.follower_log -> row1.follower.check_result: "verify"

row1.follower.check_result -> row2.outcomes.match_outcome: "YES"
row1.follower.check_result -> row2.outcomes.mismatch_outcome: "NO (term diff)"
row1.follower.check_result -> row2.outcomes.missing_outcome: "NO (too short)"

legend: {
  near: bottom-right
  label: "Key Insight"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  insight: |'md
    The consistency check is **O(1)** — it only 
    checks ONE entry. By induction, that single 
    check proves the ENTIRE prefix matches.
  '|
}