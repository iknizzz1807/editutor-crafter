direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Raft Election Sequence (diag-election-sequence)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
success_case: "SUCCESS CASE: Candidate wins majority" {
  direction: down
  row_timeline: "" {
    direction: right
    style: {
      stroke: transparent
      fill: transparent
    }
    timeline: {
      direction: down
      width: 60
      style.fill: transparent
      t0: {
        label: "T=0"
        shape: text
        style.font-size: 14
      }
      t1: {
        label: "T=1"
        shape: text
        style.font-size: 14
      }
      t2: {
        label: "T=2"
        shape: text
        style.font-size: 14
      }
      t3: {
        label: "T=3"
        shape: text
        style.font-size: 14
      }
      t4: {
        label: "T=4"
        shape: text
        style.font-size: 14
      }
      t5: {
        label: "T=5"
        shape: text
        style.font-size: 14
      }
      t6: {
        label: "T=6"
        shape: text
        style.font-size: 14
      }
    }
    nodes_col: "" {
      direction: right
      style: {
        stroke: transparent
        fill: transparent
      }
      follower_a: {
        direction: down
        label: "Follower A"
        width: 180
        style.fill: "#E8F5E9"
        step0: {
          label: "Follower"
          shape: oval
          style.fill: "#A5D6A7"
        }
        step1: {
          label: "timeout!"
          shape: diamond
          style.fill: "#FFCC80"
        }
        step2: {
          label: "Candidate\nT=6, votedFor=A"
          shape: oval
          style.fill: "#FFB74D"
        }
        step3: {
          label: "votes=1"
          shape: rectangle
          style.fill: "#FFF9C4"
        }
        step4: {
          label: "votes=2"
          shape: rectangle
          style.fill: "#FFF9C4"
        }
        step5: {
          label: "votes=3\nMAJORITY!"
          shape: rectangle
          style.fill: "#81C784"
          style.stroke: "#2E7D32"
          style.stroke-width: 3
        }
        step6: {
          label: "LEADER"
          shape: hexagon
          style.fill: "#4CAF50"
          style.font-color: white
          style.bold: true
        }
      }
      follower_b: {
        direction: down
        label: "Follower B"
        width: 180
        style.fill: "#E3F2FD"
        b0: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#90CAF9"
        }
        b1: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#90CAF9"
        }
        b2: {
          label: "receives\nRequestVote"
          shape: rectangle
          style.fill: "#BBDEFB"
        }
        b3: {
          label: "grants vote\nvotedFor=A"
          shape: rectangle
          style.fill: "#81C784"
        }
        b4: {
          label: "Follower"
          shape: oval
          style.fill: "#90CAF9"
        }
        b5: {
          label: "receives\nheartbeat"
          shape: rectangle
          style.fill: "#BBDEFB"
        }
        b6: {
          label: "Follower\nT=6"
          shape: oval
          style.fill: "#90CAF9"
        }
      }
      follower_c: {
        direction: down
        label: "Follower C"
        width: 180
        style.fill: "#FCE4EC"
        c0: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#F48FB1"
        }
        c1: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#F48FB1"
        }
        c2: {
          label: "receives\nRequestVote"
          shape: rectangle
          style.fill: "#F8BBD9"
        }
        c3: {
          label: "grants vote\nvotedFor=A"
          shape: rectangle
          style.fill: "#81C784"
        }
        c4: {
          label: "Follower"
          shape: oval
          style.fill: "#F48FB1"
        }
        c5: {
          label: "receives\nheartbeat"
          shape: rectangle
          style.fill: "#F8BBD9"
        }
        c6: {
          label: "Follower\nT=6"
          shape: oval
          style.fill: "#F48FB1"
        }
      }
      follower_d: {
        direction: down
        label: "Follower D"
        width: 180
        style.fill: "#F3E5F5"
        d0: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#CE93D8"
        }
        d1: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#CE93D8"
        }
        d2: {
          label: "receives\nRequestVote"
          shape: rectangle
          style.fill: "#E1BEE7"
        }
        d3: {
          label: "rejects\n(log stale)"
          shape: rectangle
          style.fill: "#EF9A9A"
        }
        d4: {
          label: "Follower"
          shape: oval
          style.fill: "#CE93D8"
        }
        d5: {
          label: "receives\nheartbeat"
          shape: rectangle
          style.fill: "#E1BEE7"
        }
        d6: {
          label: "Follower\nT=6"
          shape: oval
          style.fill: "#CE93D8"
        }
      }
      follower_e: {
        direction: down
        label: "Follower E"
        width: 180
        style.fill: "#FFF8E1"
        e0: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#FFE082"
        }
        e1: {
          label: "Follower\nT=5"
          shape: oval
          style.fill: "#FFE082"
        }
        e2: {
          label: "network\npartitioned"
          shape: rectangle
          style.fill: "#FFCC80"
          style.stroke-dash: 3
        }
        e3: {
          label: "(no vote)"
          shape: rectangle
          style.fill: "#FFCC80"
          style.stroke-dash: 3
        }
        e4: {
          label: "partitioned"
          shape: rectangle
          style.fill: "#FFCC80"
          style.stroke-dash: 3
        }
        e5: {
          label: "(no heartbeat)"
          shape: rectangle
          style.fill: "#FFCC80"
          style.stroke-dash: 3
        }
        e6: {
          label: "Candidate\nT=6"
          shape: oval
          style.fill: "#FFB74D"
          style.stroke-dash: 3
        }
      }
    }
  }
  # RPC arrows
  follower_a.step2 -> follower_b.b2: "RequestVote\n{T:6, id:A, lastIdx:5, lastTerm:5}" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  follower_a.step2 -> follower_c.c2: "RequestVote\n{T:6, id:A, lastIdx:5, lastTerm:5}" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  follower_a.step2 -> follower_d.d2: "RequestVote\n{T:6, id:A, lastIdx:5, lastTerm:5}" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  follower_a.step2 -> follower_e.e2: "RequestVote (lost)" {
    style: {
      stroke: "#BDBDBD"
      stroke-dash: 5
    }
  }
  follower_b.b3 -> follower_a.step4: "VoteGranted=true" {
    style: {
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
  follower_c.c3 -> follower_a.step4: "VoteGranted=true" {
    style: {
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
  follower_d.d3 -> follower_a.step4: "VoteGranted=false" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  follower_a.step6 -> follower_b.b5: "AppendEntries\n{heartbeat, T:6}" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  follower_a.step6 -> follower_c.c5: "AppendEntries\n{heartbeat, T:6}" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  follower_a.step6 -> follower_d.d5: "AppendEntries\n{heartbeat, T:6}" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  follower_a.step6 -> follower_e.e5: "(partitioned)" {
    style: {
      stroke: "#BDBDBD"
      stroke-dash: 5
    }
  }
}
split_vote_case: "SPLIT-VOTE CASE: Randomized resolution" {
  direction: down
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
  split_row: "" {
    direction: right
    style: {
      stroke: transparent
      fill: transparent
    }
    split_timeline: {
      direction: down
      width: 60
      style.fill: transparent
      st0: {
        label: "T=0"
        shape: text
        style.font-size: 14
      }
      st1: {
        label: "T=1"
        shape: text
        style.font-size: 14
      }
      st2: {
        label: "T=2"
        shape: text
        style.font-size: 14
      }
      st3: {
        label: "T=3"
        shape: text
        style.font-size: 14
      }
      st4: {
        label: "T=4"
        shape: text
        style.font-size: 14
      }
      st5: {
        label: "..."
        shape: text
        style.font-size: 14
      }
      st6: {
        label: "T=N"
        shape: text
        style.font-size: 14
      }
    }
    split_nodes: "" {
      direction: right
      style: {
        stroke: transparent
        fill: transparent
      }
      split_a: {
        direction: down
        label: "Node A"
        width: 150
        style.fill: "#FFEBEE"
        sa0: {
          label: "Follower"
          shape: oval
          style.fill: "#EF9A9A"
        }
        sa1: {
          label: "timeout!\nT=6"
          shape: diamond
          style.fill: "#FFCC80"
        }
        sa2: {
          label: "Candidate\nvotes=1"
          shape: oval
          style.fill: "#FFB74D"
        }
        sa3: {
          label: "votes=2\n(no majority)"
          shape: rectangle
          style.fill: "#FFCDD2"
        }
        sa4: {
          label: "split vote!"
          shape: diamond
          style.fill: "#FF5252"
          style.font-color: white
        }
        sa5: {
          label: "new timeout\n(random)"
          shape: rectangle
          style.fill: "#FFCC80"
        }
        sa6: {
          label: "LEADER\nT=7"
          shape: hexagon
          style.fill: "#4CAF50"
          style.font-color: white
        }
      }
      split_b: {
        direction: down
        label: "Node B"
        width: 150
        style.fill: "#E3F2FD"
        sb0: {
          label: "Follower"
          shape: oval
          style.fill: "#90CAF9"
        }
        sb1: {
          label: "timeout!\nT=6"
          shape: diamond
          style.fill: "#FFCC80"
        }
        sb2: {
          label: "Candidate\nvotes=1"
          shape: oval
          style.fill: "#FFB74D"
        }
        sb3: {
          label: "votes=2\n(no majority)"
          shape: rectangle
          style.fill: "#BBDEFB"
        }
        sb4: {
          label: "split vote!"
          shape: diamond
          style.fill: "#FF5252"
          style.font-color: white
        }
        sb5: {
          label: "waiting..."
          shape: rectangle
          style.fill: "#E3F2FD"
        }
        sb6: {
          label: "Follower\nT=7"
          shape: oval
          style.fill: "#90CAF9"
        }
      }
      split_c: {
        direction: down
        label: "Node C"
        width: 150
        style.fill: "#E8F5E9"
        sc0: {
          label: "Follower"
          shape: oval
          style.fill: "#A5D6A7"
        }
        sc1: {
          label: "receives\nfrom A"
          shape: rectangle
          style.fill: "#C8E6C9"
        }
        sc2: {
          label: "votes for A"
          shape: rectangle
          style.fill: "#81C784"
        }
        sc3: {
          label: "Follower"
          shape: oval
          style.fill: "#A5D6A7"
        }
        sc4: {
          label: "no leader"
          shape: rectangle
          style.fill: "#FFCDD2"
        }
        sc5: {
          label: "receives\nheartbeat"
          shape: rectangle
          style.fill: "#C8E6C9"
        }
        sc6: {
          label: "Follower\nT=7"
          shape: oval
          style.fill: "#A5D6A7"
        }
      }
    }
  }
  # Split vote arrows
  split_a.sa2 -> split_b.sb2: "both timeout\nsimultaneously!" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  split_a.sa2 -> split_c.sc1: "RequestVote" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  split_b.sb2 -> split_c.sc1: "RequestVote" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  split_a.sa6 -> split_b.sb5: "heartbeat\n(randomized delay\nbreaks tie)" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  split_a.sa6 -> split_c.sc5: "heartbeat" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  leg_title: {
    label: "Legend"
    shape: text
    style.bold: true
  }
  leg1: {
    label: "Follower"
    shape: oval
    style.fill: "#90CAF9"
  }
  leg2: {
    label: "Candidate"
    shape: oval
    style.fill: "#FFB74D"
  }
  leg3: {
    label: "Leader"
    shape: hexagon
    style.fill: "#4CAF50"
    style.font-color: white
  }
  leg4: {
    label: "Timeout Event"
    shape: diamond
    style.fill: "#FFCC80"
  }
  leg5: {
    label: "Granted Vote"
    shape: rectangle
    style.fill: "#81C784"
  }
  leg6: {
    label: "Rejected Vote"
    shape: rectangle
    style.fill: "#EF9A9A"
  }
  leg7: {
    label: "Network Loss"
    shape: rectangle
    style: {
      fill: "#FFCC80"
      stroke-dash: 3
    }
  }
}
# Key algorithm steps annotation
algorithm_box: {
  near: bottom-right
  label: "Key Algorithm Steps"
  width: 350
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    border-radius: 8
  }
  alg: |md
    1. **Election Timeout**: 150-300ms random
       - Breaks symmetry without coordination
    2. **Candidate Transition**: term++, vote for self
       - Persist `votedFor` BEFORE sending RPCs
    3. **RequestVote RPC**: parallel to all peers
       - Include `lastLogTerm`, `lastLogIndex`
    4. **Vote Granting**: check log up-to-date
       - Compare term first, then index
    5. **Majority Check**: votes >= (N/2 + 1)
       - 5-node cluster: need 3 votes
    6. **Leader Heartbeat**: immediate on election
       - Establish authority, suppress elections
    7. **Split Vote Resolution**: random timeouts
       - First to timeout in next round wins
  |
}