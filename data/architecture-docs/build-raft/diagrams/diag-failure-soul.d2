direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Global Classes for failure severity and status
classes: {
  danger: {
    style: {
      fill: "#FFB4B4"
      stroke: "#D32F2F"
      stroke-width: 2
      bold: true
    }
  }
  warning: {
    style: {
      fill: "#FFF3CD"
      stroke: "#DAA520"
      stroke-dash: 5
    }
  }
  info: {
    style: {
      fill: "#E8F4FD"
      stroke: "#3182CE"
      stroke-dash: 2
    }
  }
  header: {
    style: {
      fill: "#4A5568"
      font-color: "#ffffff"
      bold: true
    }
  }
}

# Header Section
header_section: {
  style.stroke: transparent
  style.fill: transparent
  
  title: |md
    # Raft Failure Mode Analysis (raft.go)
    Analysis of distributed consensus resilience, timing constraints, and recovery procedures.
  | {
    shape: rectangle
    width: 600
    style.fill: "#F8FAFC"
  }
}

# 1. Failure Mode Analysis Matrix
analysis_matrix: {
  shape: sql_table
  label: "Failure Mode Analysis Matrix (Internal Specification)"
  
  h: "Failure Mode | Detection Method | Impact | Recovery | Window"
  h.class: header
  
  row1: "Leader Crash | Heartbeat Timeout | Liveness Loss | New Election | 150-300ms"
  row1.class: danger
  
  row2: "Follower Crash | AppendEntries Fail | Quorum Reduction | Log Catch-up | 100-200ms"
  row2.class: warning
  
  row3: "Network Partition | Vote Timeout | Partial Unavailable | Term Bump | Variable"
  row3.class: danger
  
  row4: "Message Loss | Sequence Gap | Minimal Latency | Retransmission | < 50ms"
  row4.class: info
  
  summary: "Total Analyzed: 7 failure scenarios | Status: Quorum Verified"
}

# 2. Failure Propagation Flows
flows_row: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right
  
  leader_failure: {
    label: "Leader Failure Propagation"
    direction: down
    
    t0: "Detection" {
      class: danger
      code: |'go
        if elapsed > electionTimeout {
            becomeCandidate()
        }
      '|
    }
    
    t1: "Election Phase" {
      class: warning
      code: |'go
        rf.currentTerm++
        rf.votedFor = rf.me
        sendRequestVote(peers)
      '|
    }
    
    t2: "Recovery" {
      class: info
      code: |'go
        if votes > len(peers)/2 {
            becomeLeader()
            sendInitialHeartbeats()
        }
      '|
    }
    
    t0 -> t1: "Timeout | fire"
    t1 -> t2: "Quorum | granted"
  }

  partition_failure: {
    label: "Network Partition Propagation"
    direction: down
    
    p0: "Split Brain" {
      class: danger
      code: |'go
        // Minority Side
        commits_halted = true
        read_only = true
      '|
    }
    
    p1: "Heal & Merge" {
      class: warning
      code: |'go
        if peer.Term > rf.currentTerm {
            rf.stepDown(peer.Term)
        }
      '|
    }
    
    p2: "Consistency" {
      class: info
      code: |'go
        // Revert uncommitted
        rf.log = rf.log[:matchIndex]
      '|
    }
    
    p0 -> p1: "Connectivity | UP"
    p1 -> p2: "HigherTerm | sync"
  }
}

# 3. Recovery Strategy Logic
recovery_strategies_row: "" {
  label: "Recovery Implementation Details"
  style.stroke: transparent
  style.fill: transparent
  direction: right
  
  log_replay: {
    shape: rectangle
    label: "Strategy: Log Replay"
    class: warning
    code: |'go
      for i := lastApplied; i < commitIndex; i++ {
          applyToStateMachine(rf.log[i])
      }
    '|
  }
  
  snapshot: {
    shape: rectangle
    label: "Strategy: Snapshot"
    class: info
    code: |'go
      if nextIndex < rf.log[0].Index {
          sendInstallSnapshot(peer)
      }
    '|
  }
  
  append_entries: {
    shape: rectangle
    label: "Strategy: AppendEntries"
    class: info
    code: |'go
      args.PrevLogIndex = rf.nextIndex[p]-1
      args.Entries = rf.log[rf.nextIndex[p]:]
    '|
  }
}

# Connections between sections
analysis_matrix -> flows_row: "Failure Trigger"
flows_row -> recovery_strategies_row: "Resolution Path"

# Legend
legend: {
  shape: rectangle
  label: "System Health Legend"
  
  crit: "Critical (Halt)" {
    class: danger
  }
  deg: "Degraded (Slow)" {
    class: warning
  }
  nom: "Nominal (Retry)" {
    class: info
  }
}

legend.near: bottom-right