direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Figure 8: The Subtle Safety Bug — Raft Log Safety" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  phase1: "Phase 1: Term 2 — Entry Replicated but NOT Committed" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    t2_timeline: {
      label: "Leader S1 (Term 2)"
      width: 320
      code: |'go
        // S1 is leader in term 2
        // Replicates entry at index 2 to S1, S2
        log[1] = {term: 1, cmd: "a"}
        log[2] = {term: 2, cmd: "x"}
        // Only on S1, S2 (2 of 5 nodes)
        // NOT a majority — NOT committed!
        commitIndex = 1  // stuck at 1
      '|
    }
    t2_cluster: "Cluster State (5 nodes)" {
      direction: right
      grid-columns: 5
      grid-gap: 8
      s1_t2: "S1\n[L]\n[1:1, 2:2]\ncommit=1" {
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        style.stroke-width: 3
      }
      s2_t2: "S2\n[F]\n[1:1, 2:2]\ncommit=1" {
        style.fill: "#E3F2FD"
      }
      s3_t2: "S3\n[F]\n[1:1]\ncommit=1" {
        style.fill: "#FFECB3"
      }
      s4_t2: "S4\n[F]\n[1:1]\ncommit=1" {
        style.fill: "#FFECB3"
      }
      s5_t2: "S5\n[F]\n[1:1]\ncommit=1" {
        style.fill: "#FFECB3"
      }
    }
    t2_note: {
      shape: text
      label: "Entry {term:2, idx:2, cmd:x} on 2/5 nodes — NOT majority, NOT committed"
      style.font-color: "#E65100"
      style.bold: true
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  phase2: "Phase 2: Term 3 — Different Entry at Index 2 Committed" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    t3_timeline: {
      label: "Leader S5 (Term 3)"
      width: 320
      code: |'go
        // S5 elected in term 3
        // S5's log has [1:1] only
        // S5 appends NEW entry at index 2
        log[2] = {term: 3, cmd: "y"}  // DIFFERENT!
        // Replicates to S3, S4, S5 (majority!)
        // Commits entry at index 2
        commitIndex = 2  // advances!
      '|
    }
    t3_cluster: "Cluster State — S1, S2 CRASHED" {
      direction: right
      grid-columns: 5
      grid-gap: 8
      s1_t3: "S1\n[DEAD]" {
        style.fill: "#FFCDD2"
        style.stroke-dash: 3
      }
      s2_t3: "S2\n[DEAD]" {
        style.fill: "#FFCDD2"
        style.stroke-dash: 3
      }
      s3_t3: "S3\n[F]\n[1:1, 3:2]\ncommit=2" {
        style.fill: "#C8E6C9"
      }
      s4_t3: "S4\n[F]\n[1:1, 3:2]\ncommit=2" {
        style.fill: "#C8E6C9"
      }
      s5_t3: "S5\n[L]\n[1:1, 3:2]\ncommit=2" {
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        style.stroke-width: 3
      }
    }
    t3_note: {
      shape: text
      label: "Entry {term:3, idx:2, cmd:y} on 3/5 nodes — MAJORITY — COMMITTED!"
      style.font-color: "#2E7D32"
      style.bold: true
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  phase3: "Phase 3: Term 4 — The Danger Zone" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    t4_timeline: {
      label: "Leader S1 Recovered (Term 4) — DANGER!"
      width: 320
      code: |'go
        // S1 restarts, S5 crashes
        // S1's log: [1:1, 2:2] — old entry!
        // S1 elected in term 4 (log is "up to date")
        // BUG: If S1 commits entry at index 3
        // without Figure 8 check...
        log[3] = {term: 4, cmd: "z"}
        // Entry at idx 2 is {term:2, cmd:"x"}
        // But cluster had committed {term:3, cmd:"y"}!
        // SAFETY VIOLATION if we commit term 2 entry
      '|
    }
    t4_cluster: "Cluster State — S5 CRASHED, S1 LEADER" {
      direction: right
      grid-columns: 5
      grid-gap: 8
      s1_t4: "S1\n[L]\n[1:1, 2:2]\nOLD LOG" {
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        style.stroke-width: 3
      }
      s2_t4: "S2\n[F]\n[1:1, 2:2]\nOLD LOG" {
        style.fill: "#FFCDD2"
      }
      s3_t4: "S3\n[F]\n[1:1, 3:2]\nCORRECT" {
        style.fill: "#C8E6C9"
      }
      s4_t4: "S4\n[F]\n[1:1, 3:2]\nCORRECT" {
        style.fill: "#C8E6C9"
      }
      s5_t4: "S5\n[DEAD]" {
        style.fill: "#FFCDD2"
        style.stroke-dash: 3
      }
    }
    t4_warning: {
      shape: callout
      label: "S1 has {term:2, cmd:x} at index 2\nCluster committed {term:3, cmd:y}\nIf S1 overwrites, COMMITTED DATA LOST!"
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  solution: "The Fix: Figure 8 Safety Rule" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    width: 680
    fix_code: {
      label: "Commit Rule (Raft Paper §5.4)"
      width: 640
      code: |'go
        // maybeAdvanceCommitIndex — CORRECT implementation
        func (rf *RaftNode) maybeAdvanceCommitIndex() {
          for N := rf.logLastIndex(); N > rf.commitIndex; N-- {
            // CRITICAL: Only commit entries from CURRENT term
            if rf.log[N].Term != rf.currentTerm {
              continue  // Skip previous-term entries!
            }
            // Count followers with this entry
            count := 1  // Self
            for i := range rf.matchIndex {
              if rf.matchIndex[i] >= N {
                count++
              }
            }
            if count >= majority {
              rf.commitIndex = N
              // Previous entries committed TRANSITIVELY
              break
            }
          }
        }
      '|
    }
    fix_explanation: {
      shape: text
      label: "Previous-term entries are committed INDIRECTLY when a current-term entry is committed after them.\n\nWhen S1 (term 4) commits entry {term:4, idx:3}, entries before it become committed.\nBut S1 must first overwrite S3/S4's {term:3, idx:2} entry via AppendEntries consistency check."
      style.font-size: 14
    }
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  proof: "Why This Works: Transitive Commit" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    width: 680
    proof_diagram: {
      direction: right
      before: "Before Term 4 Commit" {
        direction: down
        style.fill: transparent
        style.stroke: transparent
        b_label: {
          shape: text
          label: "S1's log:"
          style.bold: true
        }
        b_log: {
          direction: right
          grid-columns: 3
          grid-gap: 4
          b_e1: "[1:1]" {
            style.fill: "#C8E6C9"
            width: 60
          }
          b_e2: "[2:2]" {
            style.fill: "#FFCDD2"
            width: 60
            style.stroke: "#F44336"
            style.stroke-width: 2
          }
          b_e3: "[4:3]" {
            style.fill: "#E3F2FD"
            width: 60
          }
        }
        b_note: {
          shape: text
          label: "Entry [2:2] NOT committed\n(different from cluster's [3:2])"
          style.font-color: "#C62828"
        }
      }
      arrow_box: {
        shape: text
        label: "→"
        style.font-size: 32
      }
      after: "After Term 4 Commit" {
        direction: down
        style.fill: transparent
        style.stroke: transparent
        a_label: {
          shape: text
          label: "After S1 replicates to majority:"
          style.bold: true
        }
        a_log: {
          direction: right
          grid-columns: 3
          grid-gap: 4
          a_e1: "[1:1]" {
            style.fill: "#C8E6C9"
            width: 60
          }
          a_e2: "[4:2]" {
            style.fill: "#C8E6C9"
            width: 60
          }
          a_e3: "[4:3]" {
            style.fill: "#C8E6C9"
            width: 60
          }
        }
        a_note: {
          shape: text
          label: "S1 overwrites with {term:4}\nCommits {term:4, idx:3}\n→ entries 1,2,3 all committed"
          style.font-color: "#2E7D32"
        }
      }
    }
    proof_text: {
      shape: text
      label: "The AppendEntries consistency check forces S3/S4 to truncate their {term:3, idx:2} entry\nand replace it with S1's entry. Only THEN can S1 commit. This ensures:\n\n1. No committed entry is ever overwritten (leader completeness)\n2. Old {term:3, cmd:y} is discarded BEFORE commit proceeds\n3. Linearizability maintained — clients never see both 'x' and 'y' at index 2"
      style.font-size: 13
    }
  }
}
legend: "Legend" {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  leg_leader: "[L] = Leader" {
    style.stroke: "#4CAF50"
    style.stroke-width: 3
  }
  leg_follower: "[F] = Follower" {
    style.fill: "#E3F2FD"
  }
  leg_dead: "[DEAD] = Crashed" {
    style.fill: "#FFCDD2"
    style.stroke-dash: 3
  }
  leg_danger: "RED = Safety Risk" {
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
  }
  leg_safe: "GREEN = Committed" {
    style.fill: "#C8E6C9"
  }
}
phase1 -> phase2: "S1 crashes\nS5 elected (term 3)" {
  style.stroke-width: 2
  style.stroke: "#666"
}
phase2 -> phase3: "S5 crashes\nS1 restarts, elected (term 4)" {
  style.stroke-width: 2
  style.stroke: "#666"
}
phase3 -> solution: "Figure 8 Rule\nPrevents Bug" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.bold: true
}