direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Follower Restart Catch-Up
  **Persistence + nextIndex tracking handle recovery automatically**
| {near: top-center}
timeline: {
  grid-rows: 6
  grid-columns: 5
  grid-gap: 0
  class: header
  hdr_time: "Time"
  hdr_leader: "Leader"
  hdr_follower: "Follower (crashed)"
  hdr_others: "Other Followers"
  hdr_state: "System State"
  class: phase
  phase1: "T0\nInitial"
  phase2: "T1\nCrash"
  phase3: "T2\nGap"
  phase4: "T3\nRestart"
  phase5: "T4\nCaught Up"
  class: leader
  l1: "commitIndex=5\nlog[1..5]"
  l2: "Detect timeout\nno response"
  l3: "Continues replication\nto others"
  l4: "Sends AppendEntries\nnextIndex[F]=4"
  l5: "Receives ACK\nmatchIndex[F]=5"
  class: follower
  f1: "commitIndex=3\nlog[1..3]\nApplied 1..3"
  f2: "**CRASH**\n"
  f3: "(down)"
  f4: "Restart\nRestore from disk:\nlog[1..3]\ncommitIndex=3"
  f5: "Appends 4,5\ncommitIndex=5\nCaught up!"
  class: others
  o1: "All synced\ncommitIndex=5"
  o2: "Continue normally"
  o3: "commitIndex=7\nlog[1..7]"
  o4: "Receive entries 6,7\ncommitIndex=7"
  o5: "All nodes\ncommitIndex=7"
  class: state
  s1: "Cluster healthy\n5 nodes, leader L"
  s2: "1 node down\n4 nodes available\n(> majority)"
  s3: "Leader commits 6,7\nFollower log gap: 4,5,6,7"
  s4: "Follower re-joins\nConsistency check:\nprevLogIndex=3 ✓"
  s5: "Full consistency\nrestored"
}
leader-box: {
  label: "Leader's View of Follower"
  width: 400
  content: |md
    **nextIndex tracking:**
    - Before crash: `nextIndex[follower] = 4`
    - After crash: unchanged (optimistic)
    - On rejection: decrement and retry
    - On success: `matchIndex[follower] = N`
  |
}
persistence-box: {
  label: "Persistence Guarantees Recovery"
  width: 400
  content: |md
    **Follower's persisted state:**
    
    currentTerm: 2
    votedFor: ""
    log: [{term:1, cmd:"a"}, 
          {term:1, cmd:"b"}, 
          {term:2, cmd:"c"}]
    commitIndex: 3
    
    Restored from disk on restart.
  |
}
appendentries-flow: {
  label: "AppendEntries RPC (T4)"
  width: 500
  content: |md
    
    Args {
      term: 2
      prevLogIndex: 3
      prevLogTerm: 2
      entries: [{term:2, cmd:"d"}, {term:2, cmd:"e"}]
      leaderCommit: 5
    }
    
    **Consistency check passes:** follower has log[3].term == 2 ✓
    Follower appends entries 4 and 5, updates commitIndex.
  |
}
leader-box -> appendentries-flow: "sends"
persistence-box -> timeline: "enables"
appendentries-flow -> timeline: "catches up"
legend: {
  near: bottom-center
  grid-columns: 2
  grid-gap: 20
  l1: |md
    **Green**: Success path / caught up
  |
  l2: |md
    **Red**: Crash point
  |
}
timeline.phase1.style.fill: "#e8f5e9"
timeline.phase2.style.fill: "#ffebee"
timeline.phase5.style.fill: "#e8f5e9"