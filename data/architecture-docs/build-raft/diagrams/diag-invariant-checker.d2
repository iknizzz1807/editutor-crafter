direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Invariant Checker Architecture
  Continuous Safety Verification for Raft Clusters
| {
  near: top-center
}

row_test_harness: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  test_harness: Test Harness {
    direction: down
    style.fill: "#E8F4E8"
    style.stroke: "#2D5A2D"
    style.stroke-width: 2
    
    chaos_ctrl: ChaosController {
      shape: class
      label: "ChaosController (chaos.go)"
      -cluster: "*Cluster"
      -running: "bool"
      -killProb: "float64"
      -partitionProb: "float64"
      +Start(): "void"
      +Stop(): "void"
      +killRandomNode(): "void"
      +createPartition(): "void"
      +healPartition(): "void"
    }
    
    cmd_submitter: CommandSubmitter {
      shape: class
      label: "CommandSubmitter (submitter.go)"
      -rate: "int"
      -stopCh: "chan struct{}"
      +Submit(cmd): "bool"
    }
    
    chaos_ctrl -> cmd_submitter: "Trigger | coordinate"
  }
}

row_network: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  network: SimulatedNetwork {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2
    
    net_label: {
      shape: rectangle
      label: |md
        **Controllable Network Layer**
        - Inject partitions between node groups
        - Add latency to specific links
        - Drop/delay/duplicate messages
      |
    }
    
    net_class: NetworkController {
      shape: class
      label: "NetworkController (network.go)"
      -partitions: "[][]int"
      -latency: "map[edge]Duration"
      -dropRate: "float64"
      +Partition(g1, g2): "void"
      +HealAll(): "void"
      +SetLatency(e, d): "void"
      +DropMessages(rate): "void"
    }
  }
}

row_cluster: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cluster: RaftCluster {
    direction: right
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    
    node0: TracedNode {
      direction: down
      style.fill: "#BBDEFB"
      n0_state: {
        shape: sql_table
        label: "Node 0 (raft.go)"
        t0: "0x00 | int | term"
        s0: "0x04 | enum | state"
        ci0: "0x08 | int | commitIndex"
        la0: "0x0C | int | lastApplied"
        log0: "0x10 | []Ptr | log"
        sz: "Total: 32 bytes (header)"
      }
    }
    node1: TracedNode {
      direction: down
      style.fill: "#BBDEFB"
      n1_state: {
        shape: sql_table
        label: "Node 1"
        t1: "0x00 | int | term"
        s1: "0x04 | enum | state"
        ci1: "0x08 | int | commitIndex"
        la1: "0x0C | int | lastApplied"
      }
    }
    node2: TracedNode {
      direction: down
      style.fill: "#BBDEFB"
      n2_state: {
        shape: sql_table
        label: "Node 2"
        t2: "0x00 | int | term"
        s2: "0x04 | enum | state"
        ci2: "0x08 | int | commitIndex"
        la2: "0x0C | int | lastApplied"
      }
    }
    node3: TracedNode {
      direction: down
      style.fill: "#BBDEFB"
      n3_state: {
        shape: sql_table
        label: "Node 3"
        t3: "0x00 | int | term"
        s3: "0x04 | enum | state"
        ci3: "0x08 | int | commitIndex"
        la3: "0x0C | int | lastApplied"
      }
    }
    node4: TracedNode {
      direction: down
      style.fill: "#BBDEFB"
      n4_state: {
        shape: sql_table
        label: "Node 4"
        t4: "0x00 | int | term"
        s4: "0x04 | enum | state"
        ci4: "0x08 | int | commitIndex"
        la4: "0x0C | int | lastApplied"
      }
    }
    
    node0 -- node1 -- node2 -- node3 -- node4: "RPC | virtual" {
      style.stroke-dash: 3
    }
  }
}

row_checker: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  checker: InvariantChecker {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 3
    
    checker_class: {
      shape: class
      label: "Checker Engine (checker.go)"
      -nodes: "[]*RaftNode"
      -violations: "[]Violation"
      -running: "bool"
      -tickInterval: "time.Duration"
      +Start(): "void"
      +Stop(): "void"
      +CheckAll(): "error"
      +HasViolations(): "bool"
    }
    
    invariants: {
      direction: right
      label: "Four Safety Invariants"
      inv1: "1. Election Safety" {
        shape: diamond
        style.fill: "#FFCDD2"
      }
      inv2: "2. Leader Completeness" {
        shape: diamond
        style.fill: "#FFCDD2"
      }
      inv3: "3. Log Matching" {
        shape: diamond
        style.fill: "#FFCDD2"
      }
      inv4: "4. State Machine Safety" {
        shape: diamond
        style.fill: "#FFCDD2"
      }
    }
    checker_class -> invariants: "10ms | tick"
  }
}

row_output: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  violation_handler: ViolationHandler {
    direction: right
    style.fill: "#FCE4EC"
    style.stroke: "#AD1457"
    style.stroke-width: 2
    
    on_violation: {
      label: "On Violation Detected"
      shape: step
    }
    
    capture: {
      label: "Capture State"
      code: |'go
        state := map[string]interface{}{
          "term": node.currentTerm,
          "state": node.state,
          "commitIndex": node.commitIndex,
          "log": node.log,
          "timestamp": time.Now(),
        }
      '|
    }
    
    log_violation: {
      label: "Log Violation"
      code: |'go
        fmt.Printf("[INVARIANT VIOLATION] %s: %s\n",
                   v.Type, v.Message)
        violations = append(violations, v)
      '|
    }
    
    halt_test: {
      label: "Halt Test"
      code: |'go
        if strict {
          t.Fatalf("Safety violation: %v", err)
        }
      '|
    }
    
    report: {
      label: "Generate Report"
      code: |'go
        // Detailed state dump for debugging
        for _, node := range nodes {
          dumpNodeState(node)
        }
      '|
    }
    
    on_violation -> capture -> log_violation -> halt_test -> report
  }
}

# Core Data Flow
row_test_harness.test_harness -> row_network.network: "Control | Partition"
row_network.network -> row_cluster.cluster: "Deliver | RPCs"

# State Observation (Checking Loop)
row_cluster.cluster.node0.n0_state -> row_checker.checker: "Snapshot | poll"
row_cluster.cluster.node1.n1_state -> row_checker.checker: "Snapshot"
row_cluster.cluster.node2.n2_state -> row_checker.checker: "Snapshot"
row_cluster.cluster.node3.n3_state -> row_checker.checker: "Snapshot"
row_cluster.cluster.node4.n4_state -> row_checker.checker: "Snapshot"

# Violation Path
row_checker.checker -> row_output.violation_handler: "error | signal" {
  style.stroke: red
  style.stroke-width: 2
}

# Corrected Annotation and Legend using root-level constant 'near'
legend_box: {
  label: "Checking Frequency"
  continuous: {
    label: |md
      **Continuous Checking**
      - Not just end-of-test
      - After every RPC event
      - After every timer tick
      - Catches transient violations
    |
    style.fill: "#E8F5E9"
  }
}
legend_box.near: bottom-right

annotation_timing: {
  shape: callout
  label: |md
    **Key Insight**: Safety violations can be
    transient. A system might briefly have two
    leaders in one term, then "self-heal."
    The checker catches these moments.
  |
  style.fill: "#FFF9C4"
}
annotation_timing.near: top-right