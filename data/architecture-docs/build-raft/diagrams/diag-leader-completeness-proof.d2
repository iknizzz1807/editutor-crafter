direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER ---
header: {
  label: "Raft Consensus: Leader Completeness Proof Sketch"
  style: {
    font-size: 24
    bold: true
    fill: "#fdfdfd"
    stroke-width: 0
  }
}

# --- ROW 1: STATE TRANSITION ---
timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: {
    label: "T1: Entry E Committed"
    direction: down
    cluster: {
      label: "Quorum M1 (Term 1)"
      style.fill: "#E8F5E9"
      n1: "N1 (Leader)" { shape: circle; style.fill: "#C8E6C9"; style.stroke-width: 3 }
      n2: "N2" { shape: circle; style.fill: "#C8E6C9" }
      n3: "N3" { shape: circle; style.fill: "#C8E6C9" }
      n4: "N4" { shape: circle; style.fill: "#FFCDD2" }
      n5: "N5" { shape: circle; style.fill: "#FFCDD2" }
    }
    note: {
      label: |'md
        **Majority M1 = {N1, N2, N3}**
        - Entry E is replicated on stable storage
        - Term of entry = T1
      '|
    }
  }

  event: {
    shape: parallelogram
    label: "CRASH & ELECTION\nN1 fails; Term T1 -> T2"
    style.fill: "#FFF3E0"
    style.stroke: "#FB8C00"
  }

  step2: {
    label: "T2: New Leader Election"
    direction: down
    cluster: {
      label: "Quorum M2 (Term 2)"
      style.fill: "#E3F2FD"
      n1_off: "N1 (Down)" { shape: circle; style.fill: "#BDBDBD"; style.stroke-dash: 3 }
      n2: "N2" { shape: circle; style.fill: "#BBDEFB" }
      n3: "N3" { shape: circle; style.fill: "#BBDEFB" }
      n4: "N4" { shape: circle; style.fill: "#FFCDD2" }
      n5: "N5 (Candidate)" { shape: circle; style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.stroke-width: 4 }
    }
    note: {
      label: |'md
        **N5 Wins Election T2**
        - Quorum M2 = {N2, N3, N5}
        - Intersection M1 ∩ M2 = {N2, N3}
      '|
    }
  }
}

# --- ROW 2: MATHEMATICAL PROOF & SAFETY LOGIC ---
proof_logic: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step3: {
    label: "Logic: Quorum Intersection"
    direction: down
    intersection_table: {
      shape: sql_table
      label: "Quorum Overlap (M1 ∩ M2)"
      m1: "Quorum M1 | {N1, N2, N3} (E is here)"
      m2: "Quorum M2 | {N2, N3, N5} (Voters)"
      overlap: "RESULT | Intersection = {N2, N3} // Not Empty"
      style.fill: "#F3E5F5"
    }
    note: {
      label: |'md
        **Pigeonhole Principle**
        In Raft, any two majorities must overlap.
        At least one node (N2 or N3) has 
        Entry E AND voted for N5.
      '|
    }
  }

  step4: {
    label: "Check: Up-to-Date Property"
    direction: down
    safety_check: {
      style.fill: "#FFF9C4"
      code: |'go
        // Voter V (N2 or N3) in RequestVote:
        if cand.lastLogTerm < v.lastLogTerm {
          return Reject // Candidate log is older
        }
        if cand.lastLogTerm == v.lastLogTerm && 
           cand.lastLogIndex < v.lastLogIndex {
          return Reject // Candidate log is shorter
        }
        return GrantVote
      '|
    }
    note: {
      label: |'md
        **Safety Guard**
        Since Voter V has E, N5's log must 
        be at least as complete as V's log
        to receive V's vote.
      '|
    }
  }
}

# --- ROW 3: FINAL CONTRADICTION ---
conclusion_box: {
  label: "Formal Contradiction Proof"
  direction: down
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
  }
  
  proof_sequence: {
    shape: sql_table
    label: "Logical Sequence"
    s1: "1. Assume | N5 elected but missing entry E"
    s2: "2. Fact | N5 received votes from M2 quorum"
    s3: "3. Fact | Intersection M1 ∩ M2 contains node V"
    s4: "4. Fact | V has E and V granted vote to N5"
    s5: "5. Fact | RequestVote rules: N5.log >= V.log"
    s6: "6. Result | N5 must have E (Assumption 1 is False)"
  }
  
  final_statment: {
    label: "Q.E.D. Entry E is guaranteed to be in N5's log."
    style: {
      bold: true
      font-size: 18
      fill: transparent
    }
  }
}

timeline -> proof_logic: "Apply Intersection"
proof_logic -> conclusion_box: "Contradiction Check"

legend: {
  near: bottom-right
  label: "Legend"
  has_e: "Contains Entry E" {
    style.fill: "#C8E6C9"
    shape: circle
  }
  no_e: "Entry E Missing" {
    style.fill: "#FFCDD2"
    shape: circle
  }
  voter: "Voter for N5" {
    style.fill: "#BBDEFB"
    shape: circle
  }
}