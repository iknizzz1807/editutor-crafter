direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Leader Failover Sequence
  Seamless transition from crashed leader to new leader
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    direction: down
    t0: {
      label: "T0: Initial State"
      width: 380
      state: |md
        **5-node cluster**
        - Leader L (term 3)
        - Followers A, B, C, D
        - 50 entries committed
        - commitIndex = 50
      |
    }
  }
  cluster_t0: {
    label: "Cluster State"
    leader_L: {
      label: "L (Leader)"
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    followers: {
      direction: right
      A: {
        label: "A"
        shape: circle
        style.fill: "#E8E8E8"
      }
      B: {
        label: "B"
        shape: circle
        style.fill: "#E8E8E8"
      }
      C: {
        label: "C"
        shape: circle
        style.fill: "#E8E8E8"
      }
      D: {
        label: "D"
        shape: circle
        style.fill: "#E8E8E8"
      }
    }
    leader_L -> followers.A: heartbeat
    leader_L -> followers.B: heartbeat
    leader_L -> followers.C: heartbeat
    leader_L -> followers.D: heartbeat
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline_t1: {
    direction: down
    t1: {
      label: "T1: Leader Crashes"
      width: 380
      state: |md
        **Leader L crashes**
        - Crashes after committing entry 50
        - Entry 51 in-flight (lost)
        - Followers miss heartbeats
        - Election timers start
      |
    }
  }
  cluster_t1: {
    label: "Cluster State"
    leader_dead: {
      label: "L (CRASHED)"
      shape: hexagon
      style.fill: "#FF6B6B"
      style.stroke: "#8B0000"
      style.stroke-dash: 5
    }
    followers_t1: {
      direction: right
      A_t1: {
        label: "A\n⏱️"
        shape: circle
        style.fill: "#FFE4B5"
      }
      B_t1: {
        label: "B\n⏱️"
        shape: circle
        style.fill: "#FFE4B5"
      }
      C_t1: {
        label: "C\n⏱️"
        shape: circle
        style.fill: "#FFE4B5"
      }
      D_t1: {
        label: "D\n⏱️"
        shape: circle
        style.fill: "#FFE4B5"
      }
    }
    leader_dead -- followers_t1.A_t1: "✗ no heartbeat" {
      style.stroke: "#FF6B6B"
      style.stroke-dash: 4
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline_t2: {
    direction: down
    t2: {
      label: "T2: Election Timeout"
      width: 380
      state: |md
        **Election timeout fires**
        - First follower times out
        - Becomes candidate (term 4)
        - Votes for self
        - Sends RequestVote to peers
      |
    }
  }
  cluster_t2: {
    label: "Election in Progress"
    candidate: {
      label: "B (Candidate)\nterm=4"
      shape: diamond
      style.fill: "#FFD700"
      style.stroke: "#DAA520"
    }
    other_followers: {
      direction: right
      A_t2: {
        label: "A"
        shape: circle
        style.fill: "#E8E8E8"
      }
      C_t2: {
        label: "C"
        shape: circle
        style.fill: "#E8E8E8"
      }
      D_t2: {
        label: "D"
        shape: circle
        style.fill: "#E8E8E8"
      }
    }
    candidate -> other_followers.A_t2: "RequestVote\nterm=4" {
      style.stroke: "#FFD700"
      style.bold: true
    }
    candidate -> other_followers.C_t2: "RequestVote\nterm=4" {
      style.stroke: "#FFD700"
      style.bold: true
    }
    candidate -> other_followers.D_t2: "RequestVote\nterm=4" {
      style.stroke: "#FFD700"
      style.bold: true
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline_t3: {
    direction: down
    t3: {
      label: "T3: Votes Collected"
      width: 380
      state: |md
        **Majority reached**
        - B receives votes: B, C, D
        - 3 of 5 = majority ✓
        - B becomes leader (term 4)
        - Initializes nextIndex/matchIndex
      |
    }
  }
  cluster_t3: {
    label: "New Leader Elected"
    new_leader: {
      label: "B (Leader)\nterm=4"
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    voters: {
      direction: right
      A_t3: {
        label: "A\nvoted B"
        shape: circle
        style.fill: "#E8E8E8"
      }
      C_t3: {
        label: "C\nvoted B"
        shape: circle
        style.fill: "#90EE90"
      }
      D_t3: {
        label: "D\nvoted B"
        shape: circle
        style.fill: "#90EE90"
      }
    }
    voters.C_t3 -> new_leader: "Vote ✓" {
      style.stroke: "#228B22"
    }
    voters.D_t3 -> new_leader: "Vote ✓" {
      style.stroke: "#228B22"
    }
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline_t4: {
    direction: down
    t4: {
      label: "T4: No-Op Commit"
      width: 380
      state: |md
        **No-op entry committed**
        - B appends no-op (term 4)
        - Replicates to majority
        - Commits no-op
        - **Previous entries now safe**
        - Figure 8 rule satisfied
      |
    }
  }
  cluster_t4: {
    label: "No-Op Replication"
    leader_t4: {
      label: "B (Leader)"
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    followers_t4: {
      direction: right
      A_t4: {
        label: "A"
        shape: circle
        style.fill: "#E8E8E8"
      }
      C_t4: {
        label: "C"
        shape: circle
        style.fill: "#E8E8E8"
      }
      D_t4: {
        label: "D"
        shape: circle
        style.fill: "#E8E8E8"
      }
    }
    leader_t4 -> followers_t4.A_t4: "AppendEntries\n[no-op, term=4]" {
      style.stroke: "#4169E1"
    }
    leader_t4 -> followers_t4.C_t4: "AppendEntries\n[no-op, term=4]" {
      style.stroke: "#4169E1"
    }
    leader_t4 -> followers_t4.D_t4: "AppendEntries\n[no-op, term=4]" {
      style.stroke: "#4169E1"
    }
    note: {
      label: "No-op commit seals\nentries 1-50"
      shape: callout
      style.fill: "#FFFACD"
    }
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline_t5: {
    direction: down
    t5: {
      label: "T5: Client Redirect"
      width: 380
      state: |md
        **Client redirected**
        - Client retries to A
        - A returns WrongLeader
        - A provides leader hint: B
        - Client sends to B
        - Request succeeds
      |
    }
  }
  client_flow: {
    label: "Client Redirect Flow"
    client: {
      label: "Client"
      shape: person
      style.fill: "#87CEEB"
    }
    follower_A: {
      label: "A (Follower)"
      shape: circle
      style.fill: "#E8E8E8"
    }
    leader_B: {
      label: "B (Leader)"
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    client -> follower_A: "Submit cmd51" {
      label: "① retry"
      style.stroke: "#FF6B6B"
      style.stroke-dash: 4
    }
    follower_A -> client: "WrongLeader\nleaderId=B" {
      label: "② redirect"
      style.stroke: "#FFD700"
    }
    client -> leader_B: "Submit cmd51" {
      label: "③ success"
      style.stroke: "#228B22"
      style.bold: true
    }
  }
}

row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline_t6: {
    direction: down
    t6: {
      label: "T6: Normal Operation"
      width: 380
      state: |md
        **Full recovery complete**
        - Commands 51-100 submitted
        - All replicated and committed
        - All nodes consistent
        - commitIndex = 100
        - **Client sees no data loss**
      |
    }
  }
  final_state: {
    label: "Final Cluster State"
    final_leader: {
      label: "B (Leader)\nterm=4\nlog[1..100]"
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    final_followers: {
      direction: right
      A_final: {
        label: "A\nlog[1..100]"
        shape: circle
        style.fill: "#90EE90"
      }
      C_final: {
        label: "C\nlog[1..100]"
        shape: circle
        style.fill: "#90EE90"
      }
      D_final: {
        label: "D\nlog[1..100]"
        shape: circle
        style.fill: "#90EE90"
      }
    }
    final_leader -> final_followers.A_final: "replicate"
    final_leader -> final_followers.C_final: "replicate"
    final_leader -> final_followers.D_final: "replicate"
  }
}

row1 -> row2: "crash" {
  style.stroke: "#FF6B6B"
  style.bold: true
}
row2 -> row3: "timeout" {
  style.stroke: "#FFD700"
}
row3 -> row4: "elect" {
  style.stroke: "#228B22"
  style.bold: true
}
row4 -> row5: "no-op" {
  style.stroke: "#4169E1"
}
row5 -> row6: "redirect" {
  style.stroke: "#FFD700"
}
row6 -> row7: "recover" {
  style.stroke: "#228B22"
  style.bold: true
}

legend: {
  label: "Legend"
  l1: {
    label: "Leader"
    shape: hexagon
    style.fill: "#90EE90"
  }
  l2: {
    label: "Candidate"
    shape: diamond
    style.fill: "#FFD700"
  }
  l3: {
    label: "Crashed"
    shape: hexagon
    style.fill: "#FF6B6B"
    style.stroke-dash: 5
  }
  l4: {
    label: "Follower"
    shape: circle
    style.fill: "#E8E8E8"
  }
}
legend.near: bottom-center

key_invariants: {
  label: "Key Safety Properties"
  inv1: "✓ Election Safety: Only one leader per term"
  inv2: "✓ Leader Completeness: New leader has entries 1-50"
  inv3: "✓ Log Matching: All logs converge"
  inv4: "✓ State Machine: All apply same commands"
  style.fill: "#F0FFF0"
  style.stroke: "#228B22"
}
key_invariants.near: bottom-right