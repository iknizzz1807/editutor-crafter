direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Log Backtracking Optimization
  ConflictTerm/ConflictIndex reduces round trips from O(log length) to O(1)
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  naive: {
    direction: down
    label: "Naive Backtracking"
    step1: {
      label: "Attempt 1"
      width: 320
      leader1: {
        shape: class
        label: "Leader"
        nextIndex: "6"
        log: "[1:1, 2:2, 2:3, 2:4, 2:5, 3:6]"
      }
      follower1: {
        shape: class
        label: "Follower"
        log: "[1:1, 2:2, 2:3, 2:4, 2:5]"
      }
      rpc1: |'go
        AppendEntries{
          PrevLogIndex: 5
          PrevLogTerm:  2
          Entries: [{3:6}]
        }
      '|
      rpc1.width: 280
      reply1: |'go
        Reply{
          Success: false
          // No conflict info
        }
      '|
      reply1.width: 280
      note1: |md
        Follower's log[5].term = 2
        Leader sent PrevLogTerm = 2
        ✓ Match! But follower has
        no entry 6 to compare...
      |
      note1.width: 300
      leader1 -> rpc1: "send"
      rpc1 -> follower1
      follower1 -> reply1: "reject"
      reply1 -> leader1: "nextIndex--"
    }
    step2: {
      label: "Attempt 2"
      width: 320
      leader2: {
        shape: class
        label: "Leader"
        nextIndex: "5"
      }
      rpc2: |'go
        AppendEntries{
          PrevLogIndex: 4
          PrevLogTerm:  2
          Entries: [{2:5}, {3:6}]
        }
      '|
      rpc2.width: 280
      reply2: |'go
        Reply{
          Success: false
          // Still no conflict info
        }
      '|
      reply2.width: 280
      note2: |md
        Follower's log[5].term = 2
        Leader sends entry {2:5}
        Terms match! No conflict...
        But we still retry blindly.
      |
      note2.width: 300
      leader2 -> rpc2: "send"
      reply2 -> leader2: "nextIndex--"
    }
    step3: {
      label: "Attempt 3 (Success)"
      width: 320
      leader3: {
        shape: class
        label: "Leader"
        nextIndex: "4"
      }
      rpc3: |'go
        AppendEntries{
          PrevLogIndex: 3
          PrevLogTerm:  2
          Entries: [{2:4}, {2:5}, {3:6}]
        }
      '|
      rpc3.width: 280
      reply3: |'go
        Reply{
          Success: true
        }
      '|
      reply3.width: 280
      note3: |md
        Finally succeeds!
        But required 3 round trips
        for just 3 entries difference.
      |
      note3.width: 300
      leader3 -> rpc3: "send"
      reply3 -> leader3: "success"
    }
    step1 -> step2: "retry"
    step2 -> step3: "retry"
    summary1: {
      label: |md
        **Problem**: If follower is 1000 entries behind,
        this requires 1000 round trips!
      |
      width: 340
      style.fill: "#ffcccc"
      style.stroke: "#cc0000"
    }
    step3 -> summary1
  }
  optimized: {
    direction: down
    label: "Optimized Backtracking"
    opt_step1: {
      label: "Single Attempt"
      width: 380
      opt_leader1: {
        shape: class
        label: "Leader"
        nextIndex: "6"
        log: "[1:1, 2:2, 2:3, 2:4, 2:5, 3:6]"
      }
      opt_follower1: {
        shape: class
        label: "Follower"
        log: "[1:1, 2:2, 2:3, 3:4, 3:5]"
      }
      opt_rpc1: |'go
        AppendEntries{
          PrevLogIndex: 5
          PrevLogTerm:  2
          Entries: [{3:6}]
        }
      '|
      opt_rpc1.width: 280
      opt_reply1: |'go
        Reply{
          Success: false
          ConflictTerm:  3  // log[5].term
          ConflictIndex: 4  // first index
                            // with term 3
        }
      '|
      opt_reply1.width: 280
      opt_note1: |md
        Follower's log[5].term = **3**
        Leader sent PrevLogTerm = **2**
        ✗ Mismatch! Follower sends:
        - ConflictTerm = 3
        - ConflictIndex = 4
      |
      opt_note1.width: 340
      opt_leader1 -> opt_rpc1: "send"
      opt_rpc1 -> opt_follower1
      opt_follower1 -> opt_reply1: "reject + info"
    }
    opt_step2: {
      label: "Leader Analysis"
      width: 380
      analysis: {
        label: "Leader receives ConflictTerm=3, ConflictIndex=4"
        width: 360
        code: |'go
          // Leader searches log for ConflictTerm
          for i := lastLogIndex; i > 0; i-- {
            if log[i].Term == 3 {  // ConflictTerm
              nextIndex = i + 1    // Skip to after
              break
            }
          }
          // Found log[6].term = 3
          // Set nextIndex = 7 (already there!)
          // Or if no match: nextIndex = ConflictIndex
        '|
      }
      result: {
        label: |md
          **Leader logic**:
          1. Search log for ConflictTerm (3)
          2. If found → nextIndex = index + 1
          3. If not found → nextIndex = ConflictIndex
          In this case: log[6].term = 3, but follower
          only has entries 1-5. The divergence is at
          index 4 where follower has term 3 entry.
        |
        width: 360
      }
      analysis -> result
    }
    opt_step3: {
      label: "Corrected Attempt"
      width: 380
      opt_leader3: {
        shape: class
        label: "Leader"
        nextIndex: "4"
      }
      opt_rpc3: |'go
        AppendEntries{
          PrevLogIndex: 3
          PrevLogTerm:  2
          Entries: [{2:4}, {2:5}, {3:6}]
        }
      '|
      opt_rpc3.width: 280
      opt_reply3: |'go
        Reply{
          Success: true
        }
      '|
      opt_reply3.width: 280
      opt_note3: |md
        Leader jumps directly to the right index
        using conflict information.
        **1 round trip instead of 3!**
      |
      opt_note3.width: 340
      opt_leader3 -> opt_rpc3: "send"
      reply3_opt -> opt_leader3: "success"
    }
    opt_step1 -> opt_step2: "analyze"
    opt_step2 -> opt_step3: "retry at correct index"
    summary2: {
      label: |md
        **Benefit**: Even if follower is 10,000 entries
        behind, catch-up happens in ~2-3 round trips.
      |
      width: 380
      style.fill: "#ccffcc"
      style.stroke: "#00cc00"
    }
    opt_step3 -> summary2
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  comparison: {
    label: "Round Trip Comparison"
    naive_bar: {
      label: "Naive (decrement by 1)"
      width: 500
      bar1: {
        shape: rectangle
        width: 450
        height: 30
        style.fill: "#ffcccc"
        style.stroke: "#cc0000"
      }
      count1: "1000 entries behind = 1000 round trips"
    }
    opt_bar: {
      label: "Optimized (conflict info)"
      width: 500
      bar2: {
        shape: rectangle
        width: 20
        height: 30
        style.fill: "#ccffcc"
        style.stroke: "#00cc00"
      }
      count2: "1000 entries behind = ~2-3 round trips"
    }
    naive_bar -> opt_bar: "Improvement"
  }
  impl: {
    label: "Implementation: Follower Response"
    width: 420
    code: |'go
      // In AppendEntries handler, on rejection:
      if len(log)-1 < args.PrevLogIndex {
        // Log too short
        reply.ConflictIndex = len(log)
        reply.ConflictTerm = -1
      } else if log[args.PrevLogIndex].Term != args.PrevLogTerm {
        // Term mismatch - find conflict info
        conflictTerm := log[args.PrevLogIndex].Term
        reply.ConflictTerm = conflictTerm
        // Find first index with this term
        conflictIndex := args.PrevLogIndex
        for conflictIndex > 0 && 
            log[conflictIndex].Term == conflictTerm {
          conflictIndex--
        }
        reply.ConflictIndex = conflictIndex + 1
      }
    '|
  }
}
legend: {
  near: bottom-right
  term2: {
    label: "term:2 entries"
    shape: rectangle
    style.fill: "#e6f3ff"
    style.stroke: "#0066cc"
  }
  term3: {
    label: "term:3 entries"
    shape: rectangle
    style.fill: "#ffe6e6"
    style.stroke: "#cc0000"
  }
  mismatch: {
    label: "Divergence point"
    shape: diamond
    style.fill: "#ffffcc"
    style.stroke: "#cc9900"
  }
}