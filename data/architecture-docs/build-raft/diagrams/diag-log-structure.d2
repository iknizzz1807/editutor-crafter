row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  legend: {
    direction: down
    label: "Legend"
    style: {
      fill: "#f8f9fa"
      stroke: "#dee2e6"
      border-radius: 8
    }
    leg_committed: {
      shape: rectangle
      label: "Committed (majority replicated)\nSafe to apply to state machine"
      width: 280
      style.fill: "#d4edda"
    }
    leg_uncommitted: {
      shape: rectangle
      label: "Uncommitted (replication in progress)\nMay be overwritten by new leader"
      width: 280
      style.fill: "#fff3cd"
    }
    leg_pointers: {
      shape: rectangle
      label: "Pointers track log progress\ncommitIndex >= lastApplied always"
      width: 280
      style.fill: "#e2e3e5"
    }
  }
  indexing: {
    direction: down
    label: "Indexing Convention (raft.h)"
    convention: {
      shape: class
      label: "Indexing Convention"
      -log: "[]LogEntry // Go slice (0-indexed)"
      -dummy: "LogEntry{Term:0} // log[0] = dummy"
      -real_start: "Real entries start at log[1]"
      -logEntry(i): "(LogEntry, bool) // 1-indexed access"
      -logLastIndex(): "int // returns len(log)-1"
      -logTerm(i): "int // term at logical index i"
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  code_example: {
    direction: down
    label: "LogEntry Structure (raft.h)"
    width: 450
    struct_def: {
      shape: sql_table
      label: "struct LogEntry (raft.h)"
      f0: "0x00 | int         | Term    // Term when leader received this"
      f1: "0x08 | interface{} | Command // State machine command"
      f2: "0x10 | int         | Index   // Position in log (1-indexed)"
      sz: "Total: ~32 bytes per entry"
    }
  }
  access_funcs: {
    direction: down
    label: "Access Functions (raft.c)"
    width: 420
    code: |'go
      // logEntry returns entry at logical index (1-indexed)
      func (rf *RaftNode) logEntry(i int) (LogEntry, bool) {
          if i <= 0 || i >= len(rf.log) {
              return LogEntry{}, false
          }
          return rf.log[i], true  // Direct: log[1] = index 1
      }
      // logLastIndex returns highest log index
      func (rf *RaftNode) logLastIndex() int {
          return len(rf.log) - 1  // dummy at 0
      }
      // logTerm returns term at logical index
      func (rf *RaftNode) logTerm(i int) int {
          if entry, ok := rf.logEntry(i); ok {
              return entry.Term
          }
          return -1  // Invalid index
      }
    '|
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  why_indexing: {
    direction: down
    label: "Why 1-Indexed with Dummy Entry?"
    style: {
      fill: "#e7f3ff"
      stroke: "#0066cc"
      border-radius: 8
    }
    reason1: {
      shape: rectangle
      label: "1. Matches Raft paper notation directly\n   Paper uses 1-indexed logs throughout"
      width: 380
      style.fill: transparent
    }
    reason2: {
      shape: rectangle
      label: "2. Simplifies RPC field mapping\n   prevLogIndex = 0 means \"no previous entry\""
      width: 380
      style.fill: transparent
    }
    reason3: {
      shape: rectangle
      label: "3. Avoids off-by-one errors in comparisons\n   Index N in paper = log[N] in code"
      width: 380
      style.fill: transparent
    }
  }
  invariant_box: {
    direction: down
    label: "Key Invariants"
    style: {
      fill: "#f8d7da"
      stroke: "#dc3545"
      border-radius: 8
    }
    inv1: {
      shape: rectangle
      label: "commitIndex >= lastApplied (always)"
      width: 320
      style.fill: transparent
    }
    inv2: {
      shape: rectangle
      label: "Entries applied sequentially (1, 2, 3, ...)"
      width: 320
      style.fill: transparent
    }
    inv3: {
      shape: rectangle
      label: "Committed entries never overwritten"
      width: 320
      style.fill: transparent
    }
    inv4: {
      shape: rectangle
      label: "log[0] is always the dummy entry"
      width: 320
      style.fill: transparent
    }
  }
}
commit_ptr -> log_visual.committed_block.idx10: "points to" {
  style: {
    stroke: "#28a745"
    stroke-width: 3
  }
}
applied_ptr -> log_visual.committed_block.idx8: "points to" {
  style: {
    stroke: "#17a2b8"
    stroke-width: 3
  }
}
last_ptr -> log_visual.uncommitted_block.idx15: "points to" {
  style: {
    stroke: "#6c757d"
    stroke-width: 3
  }
}