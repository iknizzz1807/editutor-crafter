direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Log Up-to-Date Comparison {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  log_a: {
    label: "Log A (Candidate A)"
    width: 350
    header_a: {
      style: {
        fill: "#E8F4FD"
        stroke: "#2196F3"
        stroke-width: 2
      }
      label: "lastLogIndex = 10\nlastLogTerm = 3"
    }
    entries_a: {
      shape: sql_table
      label: "Log A Entries"
      e1: "1 | 1 | cmd1"
      e2: "2 | 1 | cmd2"
      e3: "3 | 1 | cmd3"
      e4: "4 | 2 | cmd4"
      e5: "5 | 2 | cmd5"
      e6: "6 | 2 | cmd6"
      e7: "7 | 2 | cmd7"
      e8: "8 | 3 | cmd8"
      e9: "9 | 3 | cmd9"
      e10: "10 | 3 | cmd10"
      style: {
        fill: "#FAFAFA"
        stroke: "#BDBDBD"
      }
    }
    entries_a.e10.style.fill: "#BBDEFB"
  }
  vs: {
    shape: text
    label: "VS"
    width: 60
    style: {
      font-size: 24
      bold: true
      font-color: "#666666"
    }
  }
  log_b: {
    label: "Log B (Candidate B)"
    width: 350
    header_b: {
      style: {
        fill: "#E8F5E9"
        stroke: "#4CAF50"
        stroke-width: 2
      }
      label: "lastLogIndex = 8\nlastLogTerm = 4"
    }
    entries_b: {
      shape: sql_table
      label: "Log B Entries"
      e1: "1 | 1 | cmd1"
      e2: "2 | 1 | cmd2"
      e3: "3 | 1 | cmd3"
      e4: "4 | 2 | cmd4"
      e5: "5 | 2 | cmd5"
      e6: "6 | 2 | cmd6"
      e7: "7 | 2 | cmd7"
      e8: "8 | 4 | cmd8"
      style: {
        fill: "#FAFAFA"
        stroke: "#BDBDBD"
      }
    }
    entries_b.e8.style.fill: "#C8E6C9"
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  comparison: {
    label: "Comparison Algorithm"
    width: 760
    step1: {
      label: "Step 1: Compare lastLogTerm"
      width: 720
      code: |'go
  if candidateLastTerm != myLastTerm {
      return candidateLastTerm > myLastTerm
  }
  // Log A: lastLogTerm = 3
  // Log B: lastLogTerm = 4
  // 4 > 3 → Log B is MORE up-to-date
      '|
      style: {
        fill: "#FFF3E0"
        stroke: "#FF9800"
        stroke-width: 2
      }
    }
    result: {
      label: "RESULT"
      width: 720
      winner: {
        shape: rectangle
        label: "Log B WINS\n(despite being shorter)"
        style: {
          fill: "#C8E6C9"
          stroke: "#4CAF50"
          stroke-width: 3
          font-size: 18
          bold: true
        }
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  explanation: {
    label: "Why Compare Term First?"
    width: 760
    reason: {
      width: 720
      style: {
        fill: "#F3E5F5"
        stroke: "#9C27B0"
        stroke-width: 2
      }
      label: |md
  **Entries from later terms imply the node saw a later leader.**
  - Log B's entry at index 8 has term 4
  - Log A's entry at index 10 has term 3
  - Term 4 means Log B participated in a later election
  - A later leader would have a more complete view
  - Log A's extra entries (9-10) are from an **old** leader
  - Electing Log A could **overwrite** Log B's term-4 entry
  - That entry might have been committed!
      |
    }
    danger: {
      width: 720
      style: {
        fill: "#FFEBEE"
        stroke: "#F44336"
        stroke-width: 2
      }
      label: |md
  **DANGER: If Log A became leader**
  Log A would replicate entries 8, 9, 10 (all term 3)
  This would **overwrite** Log B's entry at index 8 (term 4)
  If that term-4 entry was already committed...
  **SAFETY VIOLATION: Committed entry lost!**
      |
    }
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  step2_box: {
    label: "Step 2: Only If Terms Equal"
    width: 760
    step2: {
      width: 720
      code: |'go
  // Only reached if lastLogTerm is equal
  return candidateLastIndex >= myLastIndex
  // Longer log wins when terms are equal
      '|
      style: {
        fill: "#E3F2FD"
        stroke: "#2196F3"
        stroke-width: 2
      }
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
  l1: {
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#BBDEFB"
  }
  l1_label: {
    shape: text
    label: "Highest term in Log A"
  }
  l2: {
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#C8E6C9"
  }
  l2_label: {
    shape: text
    label: "Highest term in Log B (winner)"
  }
}
log_a.entries_a.e1.label: "Index | Term | Command"
log_b.entries_b.e1.label: "Index | Term | Command"