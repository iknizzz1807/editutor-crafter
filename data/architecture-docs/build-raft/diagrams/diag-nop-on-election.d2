direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "No-Op on Leader Election (raft/leader_election.go)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
legend: {
  near: bottom-right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  style.stroke-dash: 3
  desc: |md
    **Why No-Op?**
    New leader may have entries from
    previous terms replicated to majority
    but NOT committed (Figure 8 rule).
    No-op from current term commits →
    transitively commits all prior entries.
  |
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leader: {
    direction: down
    label: "New Leader (Term T)"
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    state1: {
      label: "1. Elected"
      width: 280
      code: |'go
        // becomeLeader() called
        rf.state = Leader
        rf.currentTerm = T
      '|
    }
    state2: {
      label: "2. Append No-Op"
      width: 280
      code: |'go
        // Commit no-op from current term
        noOp := &NoOpCommand{}
        entry := LogEntry{
          Term:    rf.currentTerm,  // T
          Command: noOp,
          Index:   lastLogIndex + 1,
        }
        rf.log = append(rf.log, entry)
        rf.persist()
      '|
    }
    state3: {
      label: "3. Replicate"
      width: 280
      code: |'go
        // Send AppendEntries to all
        for _, peer := range peers {
          go rf.sendAppendEntries(peer, args)
        }
      '|
    }
    state4: {
      label: "4. Commit"
      width: 280
      code: |'go
        // On majority ACK:
        // log[N].term == T (current)
        // Figure 8 condition met!
        rf.commitIndex = N
        // Prior entries committed too
      '|
    }
    state5: {
      label: "5. Ready"
      width: 280
      style.fill: "#c3e6cb"
      code: |'go
        // Now safe to serve clients
        // All committed entries preserved
        return true
      '|
    }
    state1 -> state2 -> state3 -> state4 -> state5
  }
  followers: {
    direction: down
    label: "Followers"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    f1: {
      label: "Follower 1"
      shape: rectangle
      width: 180
      log_f1: {
        shape: sql_table
        label: "Log (F1)"
        e1: "idx: 5 | term: T-1 | cmd: 'x=1'"
        e2: "idx: 6 | term: T-1 | cmd: 'y=2'"
        e3: "idx: 7 | term: T   | cmd: NO-OP"
      }
    }
    f2: {
      label: "Follower 2"
      shape: rectangle
      width: 180
      log_f2: {
        shape: sql_table
        label: "Log (F2)"
        e1: "idx: 5 | term: T-1 | cmd: 'x=1'"
        e2: "idx: 6 | term: T-1 | cmd: 'y=2'"
        e3: "idx: 7 | term: T   | cmd: NO-OP"
      }
    }
    f1 -> f2
  }
}
leader_log: {
  direction: right
  label: "Leader Log State"
  before: {
    label: "Before No-Op"
    log_before: {
      shape: sql_table
      label: "Log (Election)"
      e5: "idx: 5 | term: T-1 | cmd: 'x=1'"
      e6: "idx: 6 | term: T-1 | cmd: 'y=2'"
      note1: "entries 5,6 on majority"
      note2: "NOT committed (prev term)"
    }
  }
  arrow: {
    shape: text
    label: "→"
    style.font-size: 32
  }
  after: {
    label: "After No-Op Committed"
    log_after: {
      shape: sql_table
      label: "Log (Committed)"
      e5: "idx: 5 | term: T-1 | cmd: 'x=1'"
      e6: "idx: 6 | term: T-1 | cmd: 'y=2'"
      e7: "idx: 7 | term: T   | cmd: NO-OP"
      commit: "commitIndex = 7"
    }
    log_after.style.fill: "#d4edda"
  }
  before -> arrow -> after
}
row1 -> leader_log: " "
leader.state3 -> followers.f1: "AppendEntries\n(no-op)" {
  style.stroke: "#007bff"
  style.stroke-width: 2
}
leader.state3 -> followers.f2: "AppendEntries\n(no-op)" {
  style.stroke: "#007bff"
  style.stroke-width: 2
}
followers.f1 -> leader.state4: "ACK" {
  style.stroke: "#28a745"
  style.stroke-dash: 3
}
followers.f2 -> leader.state4: "ACK" {
  style.stroke: "#28a745"
  style.stroke-dash: 3
}
invariant_box: {
  label: "Figure 8 Safety Rule"
  style.fill: "#f8d7da"
  style.stroke: "#dc3545"
  width: 600
  rule: |md
    **Raft Paper Figure 8 Constraint:**
    Leader can only directly commit entries from **current term**.
    Previous-term entries are committed **indirectly** when a
    current-term entry at a higher index is committed.
    
    if log[N].term == rf.currentTerm {
        // Safe to commit N
        // All entries < N are now committed too
    }
    
  |
}