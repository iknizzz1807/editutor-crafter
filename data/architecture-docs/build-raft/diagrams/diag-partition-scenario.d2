direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Network Partition During Election
  CAP Trade-off: Consistency preserved, Availability maintained in majority
| {
  near: top-center
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
    font-size: 28
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  minority_partition: {
    direction: down
    label: "Minority Partition"
    style: {
      fill: "#FFE4E1"
      stroke: "#DC143C"
      stroke-width: 3
      stroke-dash: 5
      border-radius: 12
    }
    node1: {
      label: "Node 1"
      shape: circle
      style: {
        fill: "#FFB6C1"
        stroke: "#DC143C"
        stroke-width: 2
      }
      tooltip: |md
        **State**: Candidate (term T)
        **Votes**: 1 (self only)
        **Status**: Cannot reach majority
      |
    }
    node2: {
      label: "Node 2"
      shape: circle
      style: {
        fill: "#FFB6C1"
        stroke: "#DC143C"
        stroke-width: 2
      }
      tooltip: |md
        **State**: Follower (term T-1)
        **Vote**: Voted for Node 1
        **Status": Waiting for leader
      |
    }
    partition_label: |md
      **❌ CANNOT ELECT**
      2 nodes < 3 (majority)
      *Partitioned from cluster*
    | {
      shape: rectangle
      style: {
        fill: transparent
        stroke: transparent
        font-color: "#8B0000"
      }
    }
  }
  partition_wall: {
    label: |md
      # ═══════════════
      # NETWORK PARTITION
      # ═══════════════
      # 
      # Messages dropped
      # between groups
      # 
      # ═══════════════
    |
    shape: rectangle
    width: 120
    style: {
      fill: "#2F2F2F"
      stroke: "#1A1A1A"
      stroke-width: 4
      font-color: "#FF6347"
      font-size: 12
      bold: true
    }
  }
  majority_partition: {
    direction: down
    label: "Majority Partition"
    style: {
      fill: "#E8F5E9"
      stroke: "#228B22"
      stroke-width: 3
      border-radius: 12
    }
    node3: {
      label: "Node 3\n★ LEADER"
      shape: circle
      style: {
        fill: "#90EE90"
        stroke: "#228B22"
        stroke-width: 3
        shadow: true
      }
      tooltip: |md
        **State**: Leader (term T+1)
        **Votes**: 3 (self + 4 + 5)
        **Status**: Elected successfully
      |
    }
    node4: {
      label: "Node 4"
      shape: circle
      style: {
        fill: "#98FB98"
        stroke: "#228B22"
        stroke-width: 2
      }
    }
    node5: {
      label: "Node 5"
      shape: circle
      style: {
        fill: "#98FB98"
        stroke: "#228B22"
        stroke-width: 2
      }
    }
    partition_label2: |md
      **✓ ELECTED LEADER**
      3 nodes = majority of 5
      *Cluster operational*
    | {
      shape: rectangle
      style: {
        fill: transparent
        stroke: transparent
        font-color: "#006400"
      }
    }
  }
}
majority_partition.node3 -> majority_partition.node4: "heartbeat"
majority_partition.node3 -> majority_partition.node5: "heartbeat"
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  quorum_math: {
    label: |md
      ## Quorum Calculation
      **Cluster size**: 5 nodes
      **Majority**: ⌈(5+1)/2⌉ = **3 nodes**
      ### Partition {1, 2}
      - Has: 2 nodes
      - Needs: 3 votes
      - Result: **Cannot elect** ❌
      ### Partition {3, 4, 5}
      - Has: 3 nodes
      - Needs: 3 votes
      - Result: **Can elect** ✓
    |
    shape: rectangle
    style: {
      fill: "#F5F5DC"
      stroke: "#DAA520"
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
  cap_analysis: {
    label: |md
      ## CAP Theorem Analysis
      **C**onsistency: ✓ Preserved
      - Only one partition can commit
      - Minority cannot diverge
      **A**vailability: ✓ Partial
      - Majority partition: available
      - Minority partition: unavailable
      **P**artition Tolerance: ✓ Required
      - Network failures are inevitable
      ### Raft's Choice
      Raft is a **CP system**:
      - Prefers consistency over availability
      - Minority partition becomes unavailable
      - But system state never diverges
    |
    shape: rectangle
    style: {
      fill: "#E6E6FA"
      stroke: "#9370DB"
      stroke-width: 2
      border-radius: 8
    }
  }
}
recovery_flow: {
  direction: right
  label: "Partition Recovery Sequence"
  step1: {
    label: "1. Partition Heals"
    style: {
      fill: "#FFFACD"
      stroke: "#DAA520"
      border-radius: 8
    }
  }
  step2: {
    label: "2. Node 1 receives\nAppendEntries\n(term T+1 > term T)"
    style: {
      fill: "#FFFACD"
      stroke: "#DAA520"
      border-radius: 8
    }
  }
  step3: {
    label: "3. Node 1 steps\ndown to Follower\nupdates term to T+1"
    style: {
      fill: "#FFFACD"
      stroke: "#DAA520"
      border-radius: 8
    }
  }
  step4: {
    label: "4. Node 3 continues\nas sole leader\ncluster unified"
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      border-radius: 8
    }
  }
  step1 -> step2 -> step3 -> step4: {
    style: {
      stroke: "#4A4A4A"
      stroke-width: 2
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#F8F8F8"
    stroke: "#CCCCCC"
    border-radius: 8
  }
  legend_title: "Legend" {
    style: {
      bold: true
      underline: true
    }
  }
  leader_icon: {
    shape: circle
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      stroke-width: 3
    }
  }
  leader_label: "Leader (elected)"
  follower_icon: {
    shape: circle
    style: {
      fill: "#98FB98"
      stroke: "#228B22"
    }
  }
  follower_label: "Follower"
  candidate_icon: {
    shape: circle
    style: {
      fill: "#FFB6C1"
      stroke: "#DC143C"
    }
  }
  candidate_label: "Candidate (failed)"
}