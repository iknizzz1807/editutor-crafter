direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  content: |md
    # Partition Test Scenarios
    Testing Raft under network partitions
  |
  near: top-center
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scenario1: {
    direction: down
    label: "Scenario 1: Leader Isolated"

    phase1_before: {
      label: "Before Partition"
      direction: right
      nodes1: {
        direction: right
        grid-columns: 5
        grid-gap: 10
        style.fill: "#e8f5e9"
        n1_1: "1\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
        n1_2: "2" {shape: circle}
        n1_3: "3" {shape: circle}
        n1_4: "4" {shape: circle}
        n1_5: "5" {shape: circle}
      }
    }

    phase1_part: {
      label: "Partition: [1] vs [2,3,4,5]"
      direction: right
      minority1: {
        label: "Minority\n(Cannot elect)"
        style.fill: "#ffebee"
        style.stroke: "#f44336"
        style.stroke-dash: 3
        n1_1p: "1\nL?" {shape: circle; style.fill: "#f44336"; style.font-color: white; style.opacity: 0.6}
      }
      majority1: {
        label: "Majority\n(Can elect)"
        style.fill: "#e8f5e9"
        style.stroke: "#4caf50"
        direction: right
        grid-columns: 2
        grid-gap: 5
        n1_2p: "2" {shape: circle}
        n1_3p: "3" {shape: circle}
        n1_4p: "4" {shape: circle}
        n1_5p: "5" {shape: circle}
        new_leader1: "New Leader\n(elected)" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
      }
    }

    phase1_after: {
      label: "After Heal"
      direction: right
      healed1: {
        direction: right
        grid-columns: 5
        grid-gap: 10
        style.fill: "#e3f2fd"
        h1_1: "1\nF" {shape: circle; style.fill: "#2196f3"; style.font-color: white}
        h1_2: "2" {shape: circle}
        h1_3: "3\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
        h1_4: "4" {shape: circle}
        h1_5: "5" {shape: circle}
      }
    }

    minority1 -> majority1: "Partition" {style.stroke: "#f44336"; style.stroke-dash: 5}
    phase1_before -> phase1_part
    phase1_part -> phase1_after: "Heal" {style.stroke: "#4caf50"}
  }

  scenario2: {
    direction: down
    label: "Scenario 2: Cluster Split [2,3]"

    phase2_before: {
      label: "Before Partition"
      direction: right
      nodes2: {
        direction: right
        grid-columns: 5
        grid-gap: 10
        style.fill: "#e8f5e9"
        n2_1: "1\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
        n2_2: "2" {shape: circle}
        n2_3: "3" {shape: circle}
        n2_4: "4" {shape: circle}
        n2_5: "5" {shape: circle}
      }
    }

    phase2_part: {
      label: "Partition: [1,2] vs [3,4,5]"
      direction: right
      minority2: {
        label: "Minority (2)\nCannot elect"
        style.fill: "#ffebee"
        style.stroke: "#f44336"
        style.stroke-dash: 3
        direction: right
        grid-gap: 5
        n2_1p: "1\nL?" {shape: circle; style.fill: "#f44336"; style.font-color: white; style.opacity: 0.6}
        n2_2p: "2" {shape: circle; style.opacity: 0.6}
      }
      majority2: {
        label: "Majority (3)\nCan elect"
        style.fill: "#e8f5e9"
        style.stroke: "#4caf50"
        direction: right
        grid-columns: 2
        grid-gap: 5
        n2_3p: "3" {shape: circle}
        n2_4p: "4" {shape: circle}
        n2_5p: "5\nNew L" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
      }
    }

    phase2_after: {
      label: "After Heal"
      direction: right
      healed2: {
        direction: right
        grid-columns: 5
        grid-gap: 10
        style.fill: "#e3f2fd"
        h2_1: "1\nF" {shape: circle; style.fill: "#2196f3"; style.font-color: white}
        h2_2: "2\nF" {shape: circle; style.fill: "#2196f3"; style.font-color: white}
        h2_3: "3" {shape: circle}
        h2_4: "4" {shape: circle}
        h2_5: "5\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
      }
    }

    minority2 -> majority2: "Partition" {style.stroke: "#f44336"; style.stroke-dash: 5}
    phase2_before -> phase2_part
    phase2_part -> phase2_after: "Heal" {style.stroke: "#4caf50"}
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scenario3: {
    direction: down
    label: "Scenario 3: Cascading Partitions"

    cascade_step1: {
      label: "Step 1: [1,2] vs [3,4,5]"
      direction: right
      c1_min: {
        label: "Minority"
        style.fill: "#ffebee"
        style.stroke-dash: 3
        direction: right
        c1_1: "1" {shape: circle; style.opacity: 0.6}
        c1_2: "2" {shape: circle; style.opacity: 0.6}
      }
      c1_maj: {
        label: "Majority"
        style.fill: "#e8f5e9"
        direction: right
        c1_3: "3" {shape: circle}
        c1_4: "4" {shape: circle}
        c1_5: "5\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
      }
    }

    cascade_step2: {
      label: "Step 2: [1] vs [2,3] vs [4,5]"
      direction: right
      c2_iso: {
        label: "Isolated"
        style.fill: "#ffcdd2"
        c2_1: "1" {shape: circle; style.opacity: 0.4}
      }
      c2_mid: {
        label: "2 nodes\nNo quorum"
        style.fill: "#fff9c4"
        direction: right
        c2_2: "2" {shape: circle; style.opacity: 0.7}
        c2_3: "3" {shape: circle; style.opacity: 0.7}
      }
      c2_pair: {
        label: "2 nodes\nNo quorum"
        style.fill: "#fff9c4"
        direction: right
        c2_4: "4" {shape: circle; style.opacity: 0.7}
        c2_5: "5\nL?" {shape: circle; style.fill: "#ff9800"; style.font-color: white; style.opacity: 0.7}
      }
    }

    cascade_step3: {
      label: "Step 3: Heal All"
      direction: right
      healed_c: {
        direction: right
        grid-columns: 5
        grid-gap: 10
        style.fill: "#e3f2fd"
        hc_1: "1" {shape: circle}
        hc_2: "2" {shape: circle}
        hc_3: "3\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
        hc_4: "4" {shape: circle}
        hc_5: "5" {shape: circle}
      }
    }

    c1_min -> c1_maj: "Split 1" {style.stroke: "#f44336"; style.stroke-dash: 5}
    cascade_step1 -> cascade_step2: "Further split" {style.stroke: "#ff9800"; style.stroke-dash: 3}
    cascade_step2 -> cascade_step3: "Heal all" {style.stroke: "#4caf50"}
  }

  scenario4: {
    direction: down
    label: "Scenario 4: Heal After Election"

    step4_1: {
      label: "1. Original Leader Active"
      nodes4_1: {
        direction: right
        grid-columns: 5
        grid-gap: 10
        style.fill: "#e8f5e9"
        s4_1a: "1\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
        s4_2a: "2" {shape: circle}
        s4_3a: "3" {shape: circle}
        s4_4a: "4" {shape: circle}
        s4_5a: "5" {shape: circle}
      }
    }

    step4_2: {
      label: "2. Leader 1 Isolated"
      direction: right
      iso4: {
        label: "Isolated"
        style.fill: "#ffebee"
        style.stroke-dash: 3
        s4_1b: "1\nL\nstale" {shape: circle; style.fill: "#f44336"; style.font-color: white}
      }
      maj4: {
        label: "Elects New Leader"
        style.fill: "#e8f5e9"
        direction: right
        grid-columns: 2
        s4_2b: "2" {shape: circle}
        s4_3b: "3\nNew L" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
        s4_4b: "4" {shape: circle}
        s4_5b: "5" {shape: circle}
      }
    }

    step4_3: {
      label: "3. Commands to New Leader"
      maj4_cmds: {
        label: "Majority Partition\nProcesses Commands"
        style.fill: "#e8f5e9"
        cmd_list: |md
          - cmd1: committed
          - cmd2: committed
          - cmd3: committed
        |
      }
    }

    step4_4: {
      label: "4. Heal: Old Leader Steps Down"
      direction: down
      final4: {
        direction: right
        grid-columns: 5
        grid-gap: 10
        style.fill: "#e3f2fd"
        f4_1: "1\nF" {shape: circle; style.fill: "#2196f3"; style.font-color: white}
        f4_2: "2" {shape: circle}
        f4_3: "3\nL" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
        f4_4: "4" {shape: circle}
        f4_5: "5" {shape: circle}
      }
      note4: |md
        Node 1:
        - Sees higher term
        - Steps down to Follower
        - Catches up log
      |
    }

    iso4 -> maj4: "Partition" {style.stroke: "#f44336"; style.stroke-dash: 5}
    step4_1 -> step4_2
    step4_2 -> step4_3
    step4_3 -> step4_4: "Heal" {style.stroke: "#4caf50"}
  }
}

legend: {
  near: bottom-center
  direction: right
  style.fill: "#f5f5f5"
  style.stroke: "#bdbdbd"
  leg_leader: "Leader" {shape: circle; style.fill: "#4caf50"; style.font-color: white}
  leg_follower: "Follower" {shape: circle; style.fill: "#2196f3"; style.font-color: white}
  leg_stale: "Stale Leader" {shape: circle; style.fill: "#f44336"; style.font-color: white}
  leg_partitioned: "Partitioned" {shape: circle; style.fill: "#ff9800"; style.font-color: white}
}

summary: {
  near: bottom-right
  label: "Expected Behaviors"
  content: |'md
    | Scenario | Minority | Majority | On Heal |
    |----------|----------|----------|---------|
    | Leader Isolated | No election | New leader | Old L -> F |
    | Split [2,3] | No election | New leader | Sync logs |
    | Cascading | Multiple partitions | Fragmented | Full sync |
    | Heal After Elect | Stale leader | New leader + cmds | Step down |
  '|
}