direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Persistent State Layout
  Raft State Serialization Format (raft_state.bin)
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  memory: {
    direction: down
    label: "In-Memory Structure (raft.go)"
    raft_state: {
      shape: class
      label: "struct RaftNode"
      -currentTerm: "uint64"
      -votedFor: "string"
      -log: "[]LogEntry"
    }
    log_entry: {
      shape: class
      label: "struct LogEntry"
      -Term: "uint64"
      -Command: "interface{}"
      -Index: "int"
    }
    raft_state -> log_entry: "contains"
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  disk: {
    direction: down
    label: "On-Disk Binary Format (little-endian)"
    header: {
      shape: sql_table
      label: "Header Section"
      f0: "0x00 | uint64   | currentTerm     // 8 bytes"
      f1: "0x08 | uint32   | votedForLen     // 4 bytes"
      f2: "0x0C | uint8[N] | votedFor        // N bytes (node ID)"
      sz: "Header: 12 + N bytes"
    }
    log_section: {
      shape: sql_table
      label: "Log Section"
      l0: "0x00 | uint32   | logLen          // 4 bytes (entry count)"
      l1: "0x04 | Entry[0] | term + cmd      // variable"
      l2: "0x?? | Entry[1] | term + cmd      // variable"
      l3: "0x?? | ...      | ...             // variable"
      sz: "Log: 4 + sum(entry sizes) bytes"
    }
    entry_format: {
      shape: sql_table
      label: "LogEntry Format (each)"
      e0: "0x00 | uint64   | term            // 8 bytes"
      e1: "0x08 | uint32   | commandLen      // 4 bytes"
      e2: "0x0C | uint8[M] | command         // M bytes (serialized)"
      sz: "Entry: 12 + M bytes"
    }
    header -> log_section: "followed by"
    log_section -> entry_format: "each entry"
  }
}
row1 -> row2: "persist()\nfsync()"
legend: {
  near: bottom-right
  style.fill: "#f5f5f5"
  style.stroke: "#cccccc"
  note: |md
    **Critical Requirements:**
    1. **Atomic Write**: Use temp file + atomic rename
    2. **fsync()**: Call before rename to ensure durability
    3. **Order**: Persist BEFORE responding to RPCs
    4. **Recovery**: Read all fields on startup before any RPC
    **Total Size**: 12 + N + 4 + Σ(12 + Mᵢ) bytes
  |
}