direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Quorum Intersection Proof
  **Why at most one leader can be elected per term**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  election1: Election 1 {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    majority1_label: Majority (3/5 nodes)
    venn1: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      n1: "1" {
        shape: circle
        style.fill: "#81C784"
        style.stroke: "#388E3C"
        style.font-color: white
        style.bold: true
      }
      n2: "2" {
        shape: circle
        style.fill: "#81C784"
        style.stroke: "#388E3C"
        style.font-color: white
        style.bold: true
      }
      n3: "3" {
        shape: circle
        style.fill: "#FFB74D"
        style.stroke: "#F57C00"
        style.font-color: white
        style.bold: true
        style.shadow: true
      }
    }
    candidate1: |md
      Candidate A receives votes from:
      **{1, 2, 3}** → Becomes Leader
    |
  }
  election2: Election 2 {
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    majority2_label: Majority (3/5 nodes)
    venn2: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      n3b: "3" {
        shape: circle
        style.fill: "#FFB74D"
        style.stroke: "#F57C00"
        style.font-color: white
        style.bold: true
        style.shadow: true
      }
      n4: "4" {
        shape: circle
        style.fill: "#64B5F6"
        style.stroke: "#1976D2"
        style.font-color: white
        style.bold: true
      }
      n5: "5" {
        shape: circle
        style.fill: "#64B5F6"
        style.stroke: "#1976D2"
        style.font-color: white
        style.bold: true
      }
    }
    candidate2: |md
      Candidate B receives votes from:
      **{3, 4, 5}** → Becomes Leader
    |
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  intersection_box: The Intersection {
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
    style.stroke-width: 3
    style.border-radius: 8
    node3_highlight: "Node 3" {
      shape: circle
      width: 80
      style.fill: "#FFB74D"
      style.stroke: "#E65100"
      style.stroke-width: 3
      style.font-color: white
      style.bold: true
      style.font-size: 20
      style.shadow: true
    }
    explanation: |md
      **Node 3 voted in BOTH elections!**
      This is **IMPOSSIBLE** because:
      - `votedFor` is set on first vote
      - Node cannot change vote in same term
      - Therefore: `{1,2,3}` and `{3,4,5}` cannot both be valid
    |
  }
  math_box: Mathematical Proof {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
    style.border-radius: 8
    formula: |md
      **Quorum Intersection Requirement:**
      
      2Q - N ≥ 1
      
      For N=5 nodes, majority Q=3:
      
      2(3) - 5 = 1 ✓
      
      Any two majorities share ≥1 node.
    |
    implication: |md
      **Implication for Election Safety:**
      1. Candidate needs Q votes to win
      2. Two candidates need 2Q votes total
      3. But only N nodes exist
      4. Since 2Q > N, votes must overlap
      5. Overlapping node cannot vote twice
      6. **At most one candidate wins**
    |
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cluster_view: 5-Node Cluster View {
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    style.stroke-width: 2
    cluster_label: "Both majorities in one view"
    cluster_nodes: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      cn1: "1" {
        shape: circle
        style.fill: "#81C784"
        style.stroke: "#388E3C"
        style.font-color: white
        tooltip: "Voted for A only"
      }
      cn2: "2" {
        shape: circle
        style.fill: "#81C784"
        style.stroke: "#388E3C"
        style.font-color: white
        tooltip: "Voted for A only"
      }
      cn3: "3" {
        shape: circle
        style.fill: "#FFB74D"
        style.stroke: "#E65100"
        style.stroke-width: 3
        style.font-color: white
        style.bold: true
        tooltip: "CRITICAL: Cannot vote for both!"
      }
      cn4: "4" {
        shape: circle
        style.fill: "#64B5F6"
        style.stroke: "#1976D2"
        style.font-color: white
        tooltip: "Voted for B only"
      }
      cn5: "5" {
        shape: circle
        style.fill: "#64B5F6"
        style.stroke: "#1976D2"
        style.font-color: white
        tooltip: "Voted for B only"
      }
    }
    legend_row: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      leg_a: {
        shape: circle
        width: 20
        style.fill: "#81C784"
      }
      leg_a_label: "Majority 1"
      leg_b: {
        shape: circle
        width: 20
        style.fill: "#64B5F6"
      }
      leg_b_label: "Majority 2"
      leg_i: {
        shape: circle
        width: 20
        style.fill: "#FFB74D"
        style.stroke-width: 2
        style.stroke: "#E65100"
      }
      leg_i_label: "Intersection"
    }
  }
  persistence_note: Critical Requirement {
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2
    style.border-radius: 8
    warning: |md
      ### ⚠️ Persistence is Essential
      If Node 3 crashes and restarts without
      persisting `votedFor`:
      1. Node 3 votes for Candidate A
      2. Node 3 crashes (before persisting)
      3. Node 3 restarts (`votedFor` is empty)
      4. Node 3 votes for Candidate B
      **SAFETY VIOLATION: Two leaders!**
    |
    fix: |md
      **Fix:** Persist `votedFor` to disk
      **BEFORE** responding to RequestVote.
    |
  }
}
election1 -> election2: "Same Term\nDifferent Candidates" {
  style.stroke-dash: 4
  style.stroke: "#9E9E9E"
}
cluster_view -> persistence_note: "Crucial for safety" {
  style.stroke-dash: 3
  style.stroke: "#C62828"
}