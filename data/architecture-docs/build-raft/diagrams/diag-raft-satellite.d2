direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    election: "#E8F5E9"
    replication: "#E3F2FD"
    snapshotting: "#FFF3E0"
    client: "#F3E5F5"
    safety: "#FFEBEE"
    arrow: "#546E7A"
  }
}
title: |md
  # Raft Consensus: Complete System Architecture
  Five interconnected milestones forming a production-ready distributed consensus system
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  election: Election & Persistence {
    direction: down
    style.fill: ${colors.election}
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    label: "**M1: Leader Election & Persistence**"
    core_concept: {
      shape: rectangle
      style.fill: "#C8E6C9"
      label: "**Core Problem**\nWho coordinates the cluster?"
    }
    components: {
      direction: down
      label: "**Components**"
      term_epoch: {
        shape: rectangle
        label: "**Term-Based Epochs**\nLogical clock for leadership"
        style.fill: white
      }
      randomized_timeout: {
        shape: rectangle
        label: "**Randomized Timeouts**\n150-300ms breaks symmetry"
        style.fill: white
      }
      request_vote: {
        shape: rectangle
        label: "**RequestVote RPC**\nLog up-to-date check"
        style.fill: white
      }
      persistence: {
        shape: rectangle
        label: "**Persistent State**\ncurrentTerm, votedFor, log"
        style.fill: white
        style.stroke: "#D32F2F"
        style.stroke-dash: 3
      }
    }
    state_machine: {
      direction: right
      label: "**Node States**"
      follower: {
        shape: circle
        label: "Follower"
        style.fill: "#81C784"
      }
      candidate: {
        shape: diamond
        label: "Candidate"
        style.fill: "#FFB74D"
      }
      leader: {
        shape: hexagon
        label: "Leader"
        style.fill: "#64B5F6"
      }
      follower -> candidate: "timeout"
      candidate -> leader: "majority"
      candidate -> follower: "lose/higher term"
      leader -> follower: "higher term"
    }
    key_invariant: {
      shape: rectangle
      style.fill: "#FFCDD2"
      label: "**Safety Invariant**\nAt most ONE leader per term\n(via quorum intersection)"
    }
  }
  replication: Log Replication {
    direction: down
    style.fill: ${colors.replication}
    style.stroke: "#2196F3"
    style.stroke-width: 2
    label: "**M2: Log Replication**"
    core_concept: {
      shape: rectangle
      style.fill: "#BBDEFB"
      label: "**Core Problem**\nHow do we agree on commands?"
    }
    components: {
      direction: down
      label: "**Components**"
      append_entries: {
        shape: rectangle
        label: "**AppendEntries RPC**\nHeartbeat + log entries"
        style.fill: white
      }
      consistency_check: {
        shape: rectangle
        label: "**Consistency Check**\nprevLogIndex/prevLogTerm"
        style.fill: white
      }
      commit_tracking: {
        shape: rectangle
        label: "**Commit Tracking**\nnextIndex[], matchIndex[]"
        style.fill: white
      }
      figure8: {
        shape: rectangle
        label: "**Figure 8 Rule**\nOnly commit current-term entries"
        style.fill: white
        style.stroke: "#D32F2F"
        style.stroke-dash: 3
      }
    }
    log_structure: {
      direction: right
      label: "**Log Structure**"
      log_entry: {
        shape: sql_table
        label: "LogEntry"
        f1: "0x00 | int         | Term"
        f2: "0x08 | interface{} | Command"
        f3: "0x10 | int         | Index"
        sz: "Variable size"
      }
    }
    key_invariant: {
      shape: rectangle
      style.fill: "#FFCDD2"
      label: "**Safety Invariant**\nCommitted entries NEVER overwritten\n(leader completeness)"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  snapshotting: Log Compaction {
    direction: down
    style.fill: ${colors.snapshotting}
    style.stroke: "#FF9800"
    style.stroke-width: 2
    label: "**M3: Snapshotting**"
    core_concept: {
      shape: rectangle
      style.fill: "#FFE0B2"
      label: "**Core Problem**\nUnbounded log growth"
    }
    components: {
      direction: down
      label: "**Components**"
      snapshot_data: {
        shape: rectangle
        label: "**Snapshot Structure**\nlastIncludedIndex + Term + State"
        style.fill: white
      }
      offset_arithmetic: {
        shape: rectangle
        label: "**Offset Arithmetic**\nlogicalIndex - lastIncludedIndex"
        style.fill: white
        style.stroke: "#D32F2F"
        style.stroke-dash: 3
      }
      install_snapshot: {
        shape: rectangle
        label: "**InstallSnapshot RPC**\nFor lagging followers"
        style.fill: white
      }
      atomicity: {
        shape: rectangle
        label: "**Atomic Persistence**\nSnapshot THEN truncate"
        style.fill: white
      }
    }
    snapshot_visual: {
      direction: right
      label: "**Snapshot + Log**"
      snapshot_box: {
        shape: cylinder
        label: "Snapshot\n[1..N]"
        style.fill: "#FFCC80"
      }
      log_box: {
        shape: rectangle
        label: "Log\n[N+1..M]"
        style.fill: "#FFE0B2"
      }
      snapshot_box -> log_box: "continues"
    }
    key_invariant: {
      shape: rectangle
      style.fill: "#FFCDD2"
      label: "**Safety Invariant**\nRecovery from snapshot + log\npreserves all committed state"
    }
  }
  client: Client Interface {
    direction: down
    style.fill: ${colors.client}
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    label: "**M4: Client Interface**"
    core_concept: {
      shape: rectangle
      style.fill: "#E1BEE7"
      label: "**Core Problem**\nExternal access to Raft"
    }
    components: {
      direction: down
      label: "**Components**"
      leader_redirect: {
        shape: rectangle
        label: "**Leader Redirect**\nWrongLeader + leaderId hint"
        style.fill: white
      }
      deduplication: {
        shape: rectangle
        label: "**Duplicate Detection**\n(clientId, sequenceNumber)"
        style.fill: white
      }
      linearizable_read: {
        shape: rectangle
        label: "**Linearizable Reads**\nReadIndex / No-op commit"
        style.fill: white
        style.stroke: "#D32F2F"
        style.stroke-dash: 3
      }
      kv_state_machine: {
        shape: rectangle
        label: "**KV State Machine**\nPut / Get / Delete"
        style.fill: white
      }
    }
    session_state: {
      shape: sql_table
      label: "ClientSession (replicated)"
      f1: "clientId | string"
      f2: "lastSequence | int64"
      f3: "lastResponse | interface{}"
      f4: "lastActive | time.Time"
    }
    key_invariant: {
      shape: rectangle
      style.fill: "#FFCDD2"
      label: "**Safety Invariant**\nExactly-once semantics\n(linearizability)"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  safety: Safety Verification {
    direction: down
    style.fill: ${colors.safety}
    style.stroke: "#F44336"
    style.stroke-width: 3
    label: "**M5: Safety & Testing**"
    core_concept: {
      shape: rectangle
      style.fill: "#FFCDD2"
      label: "**Core Problem**\nProving correctness under chaos"
    }
    invariants: {
      direction: down
      label: "**Four Safety Invariants**"
      inv1: {
        shape: rectangle
        label: "**1. Election Safety**\n≤1 leader per term"
        style.fill: "#FFCDD2"
      }
      inv2: {
        shape: rectangle
        label: "**2. Leader Completeness**\nNew leader has all committed"
        style.fill: "#FFCDD2"
      }
      inv3: {
        shape: rectangle
        label: "**3. Log Matching**\nSame (index,term) → same prefix"
        style.fill: "#FFCDD2"
      }
      inv4: {
        shape: rectangle
        label: "**4. State Machine Safety**\nSame index → same command"
        style.fill: "#FFCDD2"
      }
    }
    testing: {
      direction: right
      label: "**Testing Infrastructure**"
      chaos: {
        shape: rectangle
        label: "**Chaos Controller**\nKills, Partitions, Heals"
        style.fill: "#FFAB91"
      }
      stress: {
        shape: rectangle
        label: "**Stress Test**\n10min, 10K commands"
        style.fill: "#FFAB91"
      }
      checker: {
        shape: rectangle
        label: "**Invariant Checker**\nContinuous verification"
        style.fill: "#FFAB91"
      }
    }
    key_output: {
      shape: rectangle
      style.fill: "#D32F2F"
      style.font-color: white
      label: "**Acceptance Criteria**\n1000 randomized election tests\nZero invariant violations"
    }
  }
}
# Dependencies (arrows between milestones)
election -> replication: "enables\n(leader needed)" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
}
replication -> snapshotting: "requires\n(log grows)" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
}
replication -> client: "exposes\n(commands)" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
}
snapshotting -> client: "enables\n(long-running)" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
}
election -> safety: "validates\n(election safety)" {
  style.stroke: ${colors.arrow}
  style.stroke-dash: 4
}
replication -> safety: "validates\n(log matching)" {
  style.stroke: ${colors.arrow}
  style.stroke-dash: 4
}
snapshotting -> safety: "validates\n(recovery)" {
  style.stroke: ${colors.arrow}
  style.stroke-dash: 4
}
client -> safety: "validates\n(linearizability)" {
  style.stroke: ${colors.arrow}
  style.stroke-dash: 4
}
# Legend
legend: {
  near: bottom-center
  direction: right
  style.fill: white
  style.stroke: "#BDBDBD"
  label: "**Legend**"
  dep_solid: {
    shape: rectangle
    label: "───▶  Enables/Requires"
    style.stroke: transparent
  }
  dep_dashed: {
    shape: rectangle
    label: "- - -▶  Validates"
    style.stroke: transparent
  }
  critical: {
    shape: rectangle
    label: "┄┄┄  Critical Safety Property"
    style.stroke: transparent
  }
}