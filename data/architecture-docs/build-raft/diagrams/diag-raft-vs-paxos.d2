direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  header: {
    style: {
      underline: true
      bold: true
      fill: "#EEEEEE"
    }
  }
  column_label: {
    style: {
      bold: true
      font-size: 20
    }
  }
}

title: {
  content: |'md
    # Consensus Algorithm Comparison
    Raft vs Multi-Paxos vs Zab
  '|
  shape: rectangle
  near: top-center
  style.stroke: transparent
  style.fill: transparent
}

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  raft_col: {
    direction: down
    label: "Raft (raft.c)"
    class: column_label
    raft_core: {
      label: "Core Model"
      style.fill: "#E8F5E9"
      leader: "Strong Leader Model: All requests -> leader"
      terms: "Term-Based Epochs: Monotonic clock"
      understandability: "Design Goal: Understandability First"
    }
    raft_mechanics: {
      label: "Key Mechanics"
      style.fill: "#C8E6C9"
      election: "Leader Election: Randomized timeouts"
      replication: "Log Replication: AppendEntries RPC"
      commit: "Commit Rule: Current-term logic"
    }
    raft_state: {
      label: "State Machine"
      style.fill: "#A5D6A7"
      shape: class
      -state: "Follower | Candidate | Leader"
      -currentTerm: "int"
      -votedFor: "string"
      -log: "[]LogEntry"
      +RequestVote(args): "Reply"
      +AppendEntries(args): "Reply"
    }
  }

  paxos_col: {
    direction: down
    label: "Multi-Paxos (paxos.h)"
    class: column_label
    paxos_core: {
      label: "Core Model"
      style.fill: "#E3F2FD"
      any_node: "Leader-Agnostic: Any proposer can act"
      ballots: "Ballot Numbers: (id, counter)"
      correctness: "Design Goal: Prove Correctness"
    }
    paxos_mechanics: {
      label: "Key Mechanics"
      style.fill: "#BBDEFB"
      prepare: "Phase 1: Prepare (Promise logic)"
      accept: "Phase 2: Accept (Quorum ack)"
      learn: "Learning: Global convergence"
    }
    paxos_state: {
      label: "State Machine"
      style.fill: "#90CAF9"
      shape: class
      -promisedBallot: "BallotNum"
      -acceptedBallot: "BallotNum"
      -acceptedValue: "Value"
      +Prepare(ballot): "Promise"
      +Accept(ballot, value): "Accepted"
    }
  }

  zab_col: {
    direction: down
    label: "Zab (ZooKeeper)"
    class: column_label
    zab_core: {
      label: "Core Model"
      style.fill: "#FFF3E0"
      primary: "Primary-Backup: Leader is Primary"
      epochs: "Epoch Numbers: Term equivalent"
      zxids: "Zxid: (epoch, counter)"
    }
    zab_mechanics: {
      label: "Key Mechanics"
      style.fill: "#FFE0B2"
      discovery: "Leader Discovery: Find max Zxid"
      sync: "Synchronization: Log alignment"
      broadcast: "Atomic Broadcast: Leader-driven"
    }
    zab_state: {
      label: "State Machine"
      style.fill: "#FFCC80"
      shape: class
      -state: "LOOKING | FOLLOWING | LEADING"
      -currentEpoch: "int"
      -lastZxid: "Zxid"
      -leader: "LeaderAddr"
      +FollowerHandler(s): "void"
      +ProcessTxn(zxid): "void"
    }
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  comparison: {
    direction: down
    label: "Comparison Matrix"
    grid-rows: 6
    grid-columns: 4
    grid-gap: 0
    header_algo: "Algorithm" {class: header}
    header_leader: "Leadership" {class: header}
    header_clock: "Logical Clock" {class: header}
    header_use: "Production Use" {class: header}
    raft_row: "Raft"
    raft_lead: "Strong leader"
    raft_clock: "Terms (int)"
    raft_use: "etcd, Consul"
    paxos_row: "Multi-Paxos"
    paxos_lead: "Stable proposer"
    paxos_clock: "Ballot (id, seq)"
    paxos_use: "Spanner, Chubby"
    zab_row: "Zab"
    zab_lead: "Primary process"
    zab_clock: "Epoch + Zxid"
    zab_use: "ZooKeeper"
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  mental_model: {
    direction: down
    label: "Mental Models"
    raft_mental: {
      label: "Raft: State Machine"
      desc: |'md
        - Single state machine per node
        - Transitions: Follower -> Candidate -> Leader
        - Focus: "What is my current state?"
      '|
      style.fill: "#E8F5E9"
    }
    paxos_mental: {
      label: "Paxos: Quorum Negotiation"
      desc: |'md
        - Proposers compete for quorum
        - Consensus via two-phase commit
        - Focus: "Can I convince the majority?"
      '|
      style.fill: "#E3F2FD"
    }
    zab_mental: {
      label: "Zab: Primary-Backup"
      desc: |'md
        - Leader = primary process
        - Replicates state to followers
        - Focus: "Primary decides, others follow."
      '|
      style.fill: "#FFF3E0"
    }
  }
}

row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  insight_box: {
    direction: down
    label: "Key Design Insight"
    width: 700
    insight: |'md
      ## Raft's Design Philosophy
      Raft was explicitly designed for **understandability**, not novelty.

      ### What Raft borrowed from predecessors:
      - **Paxos**: Quorum-based voting.
      - **Viewstamped Replication**: View numbers -> Terms.
      - **Zab**: Strong leader model, Epoch concepts.

      ### Raft's Innovations:
      1. **Decomposition**: Separated leader election, replication, and safety.
      2. **Reduced States**: Only 3 roles (Follower, Candidate, Leader).
      3. **Deterministic**: Minimized non-determinism using randomized timeouts.
      4. **Safety Rule**: Term-first log commitment for election safety.
    '|
    style.fill: "#FAFAFA"
    style.stroke: "#666"
    style.stroke-dash: 3
  }
}

raft_col -> paxos_col: "Mechanism | Equivalence" {
  style.stroke-dash: 5
  style.stroke: "#666"
}
paxos_col -> zab_col: "Mechanism | Equivalence" {
  style.stroke-dash: 5
  style.stroke: "#666"
}