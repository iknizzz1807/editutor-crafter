direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Log Indexing with Snapshot Offset {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  before: BEFORE SNAPSHOT {
    direction: down
    style.fill: white
    log_before: {
      shape: sql_table
      label: "log[] (Physical Array)"
      r0: "0   | -        | (dummy)"
      r1: "1   | 1        | cmd_001"
      r2: "2   | 1        | cmd_002"
      r3: "... | ...      | ..."
      r4: "100 | 3        | cmd_100"
      r5: "101 | 3        | cmd_101"
      r6: "102 | 4        | cmd_102"
      r7: "103 | 4        | cmd_103"
    }
    note1: {
      label: "All entries 1-103 in memory"
      shape: rectangle
      style: {
        fill: lightyellow
        stroke: orange
        stroke-dash: 3
      }
    }
  }
  arrow1: {
    shape: text
    label: "→"
    style: {
      font-size: 40
      bold: true
    }
  }
  trigger: {
    direction: down
    style.fill: transparent
    t1: {
      label: "snapshotThreshold = 100"
      shape: rectangle
      style: {
        fill: lavender
        stroke: purple
        stroke-dash: 3
      }
    }
    t2: {
      label: "Snapshot at index 100"
      shape: rectangle
      style: {
        fill: lavender
        stroke: purple
      }
    }
    t3: {
      label: "Truncate entries 1-100"
      shape: rectangle
      style: {
        fill: mistyrose
        stroke: red
      }
    }
  }
  arrow2: {
    shape: text
    label: "→"
    style: {
      font-size: 40
      bold: true
    }
  }
  after: AFTER SNAPSHOT {
    direction: down
    style.fill: white
    snapshot_state: {
      shape: sql_table
      label: "Snapshot Metadata"
      f1: "lastIncludedIndex | 100"
      f2: "lastIncludedTerm  | 3"
      f3: "stateMachineData | {k:v...}"
    }
    log_after: {
      shape: sql_table
      label: "log[] (Physical Array)"
      r0: "0   | -        | (dummy)"
      r1: "1   | 4        | cmd_102"
      r2: "2   | 4        | cmd_103"
    }
    note2: {
      label: "Only entries 101-103 in memory"
      shape: rectangle
      style: {
        fill: lightgreen
        stroke: green
        stroke-dash: 3
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  formula_box: {
    label: "Index Translation Formula"
    direction: down
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 8
    }
    formula_title: {
      label: "Every Log Access Must Translate:"
      shape: rectangle
      style: {
        fill: transparent
        stroke: transparent
        bold: true
        font-size: 16
      }
    }
    formula1: {
      label: "physicalIndex = logicalIndex - lastIncludedIndex"
      shape: rectangle
      style: {
        fill: white
        stroke: blue
        font: mono
        font-size: 18
        bold: true
      }
    }
    formula2: {
      label: "logicalIndex = physicalIndex + lastIncludedIndex"
      shape: rectangle
      style: {
        fill: white
        stroke: blue
        font: mono
        font-size: 18
        bold: true
      }
    }
  }
  mapping_box: {
    label: "Mapping Table (lastIncludedIndex=100)"
    direction: down
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      border-radius: 8
    }
    mapping_table: {
      shape: sql_table
      label: "Logical → Physical"
      m1: "100 | N/A (in snapshot)"
      m2: "101 | 1"
      m3: "102 | 2"
      m4: "103 | 3"
    }
    access_before: {
      label: "log[100] → ERROR (before snapshot)"
      shape: rectangle
      style: {
        fill: "#FFEBEE"
        stroke: red
        font: mono
      }
    }
    access_after: {
      label: "log[102] → log[2] = cmd_103"
      shape: rectangle
      style: {
        fill: "#E8F5E9"
        stroke: green
        font: mono
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  helper_funcs: {
    label: "Required Helper Functions (raft/node.go)"
    direction: down
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      border-radius: 8
    }
    func1: {
      label: "logIndexToSlice(logicalIndex int) int"
      width: 400
      code: |'go
        func (rf *RaftNode) logIndexToSlice(logicalIndex int) int {
            if logicalIndex <= rf.lastIncludedIndex {
                return -1  // In snapshot or invalid
            }
            return logicalIndex - rf.lastIncludedIndex
        }
      '|
    }
    func2: {
      label: "sliceToLogIndex(sliceIndex int) int"
      width: 400
      code: |'go
        func (rf *RaftNode) sliceToLogIndex(sliceIndex int) int {
            return rf.lastIncludedIndex + sliceIndex
        }
      '|
    }
    func3: {
      label: "logEntry(logicalIndex int) (LogEntry, bool)"
      width: 400
      code: |'go
        func (rf *RaftNode) logEntry(logicalIndex int) (LogEntry, bool) {
            if logicalIndex == rf.lastIncludedIndex {
                return LogEntry{Term: rf.lastIncludedTerm}, true
            }
            if logicalIndex < rf.lastIncludedIndex {
                return LogEntry{}, false  // Before snapshot
            }
            sliceIdx := rf.logIndexToSlice(logicalIndex)
            if sliceIdx < 0 || sliceIdx >= len(rf.log) {
                return LogEntry{}, false
            }
            return rf.log[sliceIdx], true
        }
      '|
    }
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  affected_ops: {
    label: "Operations Affected by Offset"
    direction: down
    style: {
      fill: "#FFF8E1"
      stroke: "#FFC107"
      stroke-width: 2
      border-radius: 8
    }
    op1: {
      shape: class
      label: "All Log Access Points"
      -len_log: "len(rf.log) - 1 → rf.logLastIndex()"
      -log_term: "rf.log[i].Term → rf.logTerm(i)"
      -log_entry: "rf.log[i] → rf.logEntry(i)"
      +logLastIndex: "int"
      +logTerm: "(int) int"
      +logEntry: "(int) (LogEntry, bool)"
    }
    op2: {
      shape: class
      label: "RPC Handlers"
      +AppendEntries: "(args, reply) error"
      +RequestVote: "(args, reply) error"
      +InstallSnapshot: "(args, reply) error"
    }
    op3: {
      shape: class
      label: "Leader State"
      -nextIndex: "[]int (logical indices)"
      -matchIndex: "[]int (logical indices)"
      +becomeLeader: "()"
      +maybeAdvanceCommitIndex: "()"
    }
  }
  warning_box: {
    direction: down
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 3
      border-radius: 8
    }
    warning_title: {
      label: "⚠️ Common Pitfall"
      shape: rectangle
      style: {
        fill: transparent
        stroke: transparent
        bold: true
        font-size: 18
        font-color: red
      }
    }
    wrong: {
      label: "WRONG: Direct array access"
      code: |'go
        // This breaks after snapshot!
        lastLogIndex := len(rf.log) - 1
        term := rf.log[args.PrevLogIndex].Term
      '|
      width: 350
    }
    correct: {
      label: "CORRECT: Use helper functions"
      code: |'go
        // Works before and after snapshot
        lastLogIndex := rf.logLastIndex()
        term := rf.logTerm(args.PrevLogIndex)
      '|
      width: 350
    }
  }
}
row1 -> row2: "Translation Required" {
  style: {
    stroke: blue
    stroke-width: 2
    stroke-dash: 5
  }
}
row2 -> row3: "Implementation" {
  style: {
    stroke: purple
    stroke-width: 2
  }
}
row3 -> row4: "Pervasive Change" {
  style: {
    stroke: orange
    stroke-width: 2
  }
}
legend: {
  near: bottom-right
  direction: right
  style: {
    fill: white
    stroke: gray
    border-radius: 4
  }
  l1: {
    label: "Logical Index"
    shape: rectangle
    style.fill: lightblue
  }
  l2: {
    label: "Physical Index"
    shape: rectangle
    style.fill: lightgreen
  }
  l3: {
    label: "In Snapshot"
    shape: rectangle
    style.fill: lavender
  }
}