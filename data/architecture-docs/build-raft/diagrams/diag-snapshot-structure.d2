direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: "Snapshot Structure & Recovery Architecture"
  style: {
    font-size: 28
    bold: true
    fill: "#F0F0F0"
    stroke-width: 0
  }
}

row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  snapshot_container: "Snapshot Storage (raft.go)" {
    style: { fill: "#E8D5B7"; stroke: "#8B6914"; stroke-width: 2 }
    
    metadata: {
      shape: sql_table
      label: "SnapshotMetadata"
      f1: "0x00 | int32 | LastIncludedIndex // 10000"
      f2: "0x04 | int32 | LastIncludedTerm  // 3"
      sz: "Total: 8 bytes"
    }
    
    state_blob: {
      label: "State Machine Data"
      code: |'json
        {
          "account_bal": 500,
          "kv_store": {"x": 5, "y": 10}
        }
      '|
    }
  }

  log_pre: "Log State (PRE-COMPACTION)" {
    style: { fill: "#FFD6D6"; stroke: "#8B0000"; stroke-width: 2 }
    
    entries: {
      shape: class
      label: "RaftLog (Linear)"
      e1: "[1] term:1 cmd:set_x_1"
      e2: "[2] term:1 cmd:set_y_2"
      dots: "[...] Growth: Unbounded"
      e9999: "[9999] term:3 cmd:del_z"
      e10000: "[10000] term:3 cmd:set_x_5"
    }
  }
}

transition: {
  shape: parallelogram
  label: "Compact: Discard 1..10000"
  style: { fill: "#FFF4E0"; stroke: "#D4A017"; stroke-dash: 5 }
}

row2: "" {
  direction: right
  style: { fill: transparent; stroke: transparent }

  log_post: "Log State (POST-COMPACTION)" {
    style: { fill: "#D6FFD6"; stroke: "#006400"; stroke-width: 2 }
    
    compacted: {
      shape: class
      label: "Log (Compacted)"
      e10001: "[10001] term:4 cmd:noop"
      e10002: "[10002] term:4 cmd:inc_x"
      dots: "[...] Growth: Controlled"
    }
    
    mapping_note: {
      label: "Offset Calculation"
      note: "Index [10001] maps to log[0]"
      style: { font-size: 14; italic: true }
    }
  }

  recovery: "Node Restart Recovery" {
    style: { fill: "#D6E8FF"; stroke: "#004080"; stroke-width: 2 }
    
    load: {
      label: "1. Load Snapshot"
      width: 250
      code: |'go
        data := persister.ReadSnapshot()
        rf.lastIncludedIndex = meta.Index
      '|
    }
    
    apply: {
      label: "2. Restore Machine"
      width: 250
      code: |'go
        // Overwrites current memory state
        kv.ApplySnapshot(data)
      '|
    }
    
    replay: {
      label: "3. Replay Log"
      width: 250
      code: |'go
        for i := rf.lastIncludedIndex + 1;
            i <= rf.commitIndex; i++ {
          rf.applyToStateMachine(rf.log[i])
        }
      '|
    }
    
    load -> apply -> replay: "Sequence"
  }
}

# Connections
row1.snapshot_container.metadata -> row1.log_pre.entries: "Truncation Point" {
  style: { stroke: "#8B6914"; stroke-dash: 4 }
}

row1.log_pre -> transition: "Raft.Snapshot()"
transition -> row2.log_post: "Apply"

legend: {
  label: "Legend & Color Codes"
  near: bottom-right
  style: { fill: "#F9F9F9"; stroke: "#CCCCCC" }
  
  l1: "Persisted on Disk" { style: { fill: "#E8D5B7" } }
  l2: "Volatile / Ephemeral" { style: { fill: "#FFD6D6" } }
  l3: "Recovery Path" { style: { fill: "#D6E8FF" } }
}