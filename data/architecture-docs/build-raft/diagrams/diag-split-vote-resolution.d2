direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  shape: rectangle
  style.stroke: transparent
  style.fill: transparent
  content: |md
    # Raft: Split Vote Resolution
    Randomized timeouts break the livelock deadlock.
  |
}

timeline: {
  grid-columns: 1
  grid-gap: 20

  phase1: {
    label: "T=0ms: Split Vote Deadlock"
    direction: right
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    
    candidates: {
      direction: down
      label: "Candidates (no majority)"
      c1: {
        label: "Node 1\nTerm 5"
        shape: circle
        style.fill: "#FFB3B3"
        style.stroke: "#CC0000"
        width: 80
      }
      c3: {
        label: "Node 3\nTerm 5"
        shape: circle
        style.fill: "#FFB3B3"
        style.stroke: "#CC0000"
        width: 80
      }
    }

    votes: {
      direction: down
      label: "Vote Distribution"
      v1: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        n1: "1" { shape: circle; style.fill: "#90EE90"; width: 30 }
        n2: "2" { shape: circle; style.fill: "#90EE90"; width: 30 }
        txt: "Node 1 votes" { shape: text }
      }
      v2: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        n3: "3" { shape: circle; style.fill: "#87CEEB"; width: 30 }
        n4: "4" { shape: circle; style.fill: "#87CEEB"; width: 30 }
        txt: "Node 3 votes" { shape: text }
      }
      v3: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        n5: "5" { shape: circle; style.fill: "#D3D3D3"; width: 30 }
        txt: "Node 5 (abstains)" { shape: text }
      }
    }

    summary: {
      label: "Result: 2-2-1 split"
      note: "No majority (need 3)"
      shape: diamond
      style.fill: "#FFD700"
    }
  }

  phase2: {
    label: "T=150-300ms: Randomized Timeouts"
    direction: right
    style.fill: "#FFF8DC"
    style.stroke: "#DAA520"
    
    timeout1: {
      label: "Node 1 Timer"
      bar: "█████████░" { shape: rectangle; style.font: mono; style.fill: "#FFB3B3" }
      fire: "Fires at 187ms" { shape: text; style.bold: true; style.font-color: "#CC0000" }
    }
    
    timeout3: {
      label: "Node 3 Timer"
      bar: "█████████████░" { shape: rectangle; style.font: mono; style.fill: "#FFB3B3" }
      fire: "Fires at 243ms" { shape: text; style.bold: true; style.font-color: "#CC0000" }
    }

    insight: {
      shape: callout
      label: "Key Insight"
      content: |md
        Range [150-300ms] 
        ensures retry stagger.
        P(simultaneous) ≈ 0.
      |
    }
  }

  phase3: {
    label: "T=187ms: New Election Round (Term 6)"
    direction: right
    style.fill: "#F0FFF0"
    style.stroke: "#228B22"

    n1_action: {
      direction: down
      node: "Node 1\nCandidate T=6" { shape: circle; style.fill: "#90EE90"; width: 80 }
      rpc: "RequestVote(Term=6)" { shape: parallelogram; style.fill: "#E8F5E9" }
    }

    voter_status: {
      direction: down
      label: "Vote Ledger"
      v1: "Node 1: Votes self" { shape: rectangle; style.fill: "#90EE90" }
      v2: "Node 2: Grants vote" { shape: rectangle; style.fill: "#90EE90" }
      v5: "Node 5: Grants vote" { shape: rectangle; style.fill: "#90EE90" }
    }

    result: {
      label: "3/5 = MAJORITY"
      shape: oval
      style.fill: "#32CD32"
      style.font-color: white
      style.bold: true
    }
  }

  phase4: {
    label: "T=200ms: Leader Established"
    direction: right
    style.fill: "#E8F5E9"
    style.stroke: "#228B22"

    leader: "Node 1\nLEADER T=6" {
      shape: circle
      style.fill: "#228B22"
      style.font-color: white
      style.bold: true
      width: 100
    }

    msg: "AppendEntries (Heartbeat)" { shape: parallelogram; style.fill: "#E8F5E9" }

    cluster: {
      direction: right
      style.stroke: transparent
      f2: "2" { shape: circle; style.fill: "#ADD8E6"; width: 30 }
      f3: "3" { shape: circle; style.fill: "#ADD8E6"; width: 30 }
      f4: "4" { shape: circle; style.fill: "#ADD8E6"; width: 30 }
      f5: "5" { shape: circle; style.fill: "#ADD8E6"; width: 30 }
    }
  }
}

timeline.phase1 -> timeline.phase2: "Election Timeout"
timeline.phase2 -> timeline.phase3: "Node 1 Fires"
timeline.phase3 -> timeline.phase4: "Quorum Met"

analysis: {
  label: "Mathematical Proof of Livelock Avoidance"
  shape: rectangle
  style.fill: "#F5F5F5"
  content: |'md
    ## Probability of Split Vote
    In a cluster of **N** nodes with **K** candidates:
    P(split) ≈ (N! / (k!(N-k)!)) * (1/k)^(N-1)
    
    For 5 nodes, 2 candidates: **62.5%** risk per round.
    
    ## Resolution Time
    With randomization [T_min, T_max]:
    - Without randomization: **Infinite (Livelock)**
    - With randomization: **E[T] = 1.5 rounds**
  '|
}

legend: {
  label: "Map Legend"
  shape: rectangle
  near: bottom-right
  
  items: {
    direction: down
    style.stroke: transparent
    i1: {
      direction: right
      style.stroke: transparent
      ico: "" { shape: circle; style.fill: "#FFB3B3"; width: 15 }
      txt: "Candidate" { shape: text }
    }
    i2: {
      direction: right
      style.stroke: transparent
      ico: "" { shape: circle; style.fill: "#228B22"; width: 15 }
      txt: "Leader" { shape: text }
    }
    i3: {
      direction: right
      style.stroke: transparent
      ico: "" { shape: circle; style.fill: "#ADD8E6"; width: 15 }
      txt: "Follower" { shape: text }
    }
    i4: {
      direction: right
      style.stroke: transparent
      ico: "" { shape: circle; style.fill: "#90EE90"; width: 15 }
      txt: "Voted" { shape: text }
    }
  }
}