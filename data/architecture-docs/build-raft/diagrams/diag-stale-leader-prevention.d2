direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Stale Leader Prevention
  Linearizable reads require confirming leadership before responding
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    direction: down
    label: ""
    width: 180
    t0: {
      label: "T0: Initial State"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 160
      desc: |md
        5-node cluster
        Leader A (term 5)
        Quorum: 3 nodes
      |
    }
    t1: {
      label: "T1: Partition Occurs"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      width: 160
      desc: |md
        [A] isolated from
        [B, C, D, E]
        Network partition
      |
    }
    t2: {
      label: "T2: New Election"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      width: 160
      desc: |md
        Majority [B,C,D,E]
        elects C as leader
        Term advances to 6
      |
    }
    t3: {
      label: "T3: Write + Read"
      shape: rectangle
      style.fill: "#FCE4EC"
      style.stroke: "#E91E63"
      width: 160
      desc: |md
        Client writes x=10
        to leader C (term 6)
        Client reads from A
      |
    }
    t4: {
      label: "T4: Leadership Check"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#9C27B0"
      width: 160
      desc: |md
        A sends heartbeat
        Gets no majority OR
        discovers term 6 > 5
        A steps down
      |
    }
    t5: {
      label: "T5: Correct Response"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 160
      desc: |md
        A returns WrongLeader
        Client redirects to C
        Gets x=10 (correct)
      |
    }
  }
  clusters: {
    direction: down
    label: ""
    cluster_before: {
      label: "Before Partition (Term 5)"
      direction: right
      style.fill: "#F5F5F5"
      style.stroke: "#9E9E9E"
      node_a_before: {
        label: "A\nLeader\nTerm 5"
        shape: circle
        style.fill: "#4CAF50"
        style.font-color: white
      }
      node_b_before: {
        label: "B"
        shape: circle
        style.fill: "#BBDEFB"
      }
      node_c_before: {
        label: "C"
        shape: circle
        style.fill: "#BBDEFB"
      }
      node_d_before: {
        label: "D"
        shape: circle
        style.fill: "#BBDEFB"
      }
      node_e_before: {
        label: "E"
        shape: circle
        style.fill: "#BBDEFB"
      }
      node_a_before -- node_b_before: {style.stroke-dash: 2}
      node_a_before -- node_c_before: {style.stroke-dash: 2}
      node_a_before -- node_d_before: {style.stroke-dash: 2}
      node_a_before -- node_e_before: {style.stroke-dash: 2}
    }
    cluster_partitioned: {
      label: "After Partition (Term 6)"
      direction: right
      style.fill: "#FAFAFA"
      style.stroke: "#9E9E9E"
      minority: {
        label: "Minority\nPartition"
        direction: down
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        node_a_part: {
          label: "A\nOLD Leader\nTerm 5"
          shape: circle
          style.fill: "#FFCDD2"
          style.stroke: "#F44336"
          style.stroke-width: 3
        }
      }
      majority: {
        label: "Majority Partition"
        direction: down
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        node_b_part: {
          label: "B"
          shape: circle
          style.fill: "#C8E6C9"
        }
        node_c_part: {
          label: "C\nNEW Leader\nTerm 6"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        node_d_part: {
          label: "D"
          shape: circle
          style.fill: "#C8E6C9"
        }
        node_e_part: {
          label: "E"
          shape: circle
          style.fill: "#C8E6C9"
        }
        node_c_part -- node_b_part
        node_c_part -- node_d_part
        node_c_part -- node_e_part
        node_b_part -- node_d_part
      }
      minority -- majority: {
        label: "PARTITIONED"
        style.stroke: "#F44336"
        style.stroke-width: 4
        style.stroke-dash: 8
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  flow: {
    label: "ReadIndex Protocol"
    direction: down
    step1: {
      label: "1. Client Read Request"
      width: 350
      code: |'go
        // Client sends read to node A
        // A thinks it's leader (term 5)
        func (rf *RaftNode) Read(args *ReadArgs) {
            if rf.state != Leader {
                return WrongLeader
            }
            // A doesn't know it's deposed!
        }
      '|
    }
    step2: {
      label: "2. Leader Confirms via Heartbeat"
      width: 350
      code: |'go
        // ReadIndex: confirm leadership
        readIndex := rf.commitIndex
        // Send heartbeat to majority
        for _, peer := range peers {
            go rf.sendHeartbeat(peer)
        }
        // Wait for majority acknowledgment
      '|
    }
    step3: {
      label: "3. Discovery of Higher Term"
      width: 350
      code: |'go
        // Old leader A receives response
        if reply.Term > rf.currentTerm {
            // Term 6 > Term 5!
            rf.currentTerm = reply.Term
            rf.state = Follower
            rf.votedFor = ""
            rf.persist()
            // A steps down immediately
        }
      '|
    }
    step4: {
      label: "4. Client Redirected"
      width: 350
      code: |'go
        // A responds to client
        reply.WrongLeader = true
        reply.LeaderHint = "C" // or unknown
        // Client retries to C
        response := client.Read(key)
        // Gets x=10 (correct value)
      '|
    }
    step1 -> step2 -> step3 -> step4
  }
  explanation: {
    label: "Why This Works"
    direction: down
    width: 300
    invariant: {
      label: "Safety Invariant"
      shape: rectangle
      style.fill: "#E8F5E9"
      width: 280
      content: |md
        **ReadIndex Guarantee:**
        A read is only served after
        confirming leadership via
        majority quorum acknowledgment.
        If the old leader cannot reach
        a majority, it cannot confirm
        leadership and must reject
        the read.
      |
    }
    why: {
      label: "Key Insight"
      shape: rectangle
      style.fill: "#E3F2FD"
      width: 280
      content: |md
        The old leader *thinks* it's
        the leader, but the ReadIndex
        protocol **proves** it's not.
        Without this check, client
        would receive stale data
        (x=5 instead of x=10).
      |
    }
    cap: {
      label: "CAP Tradeoff"
      shape: rectangle
      style.fill: "#FFF3E0"
      width: 280
      content: |md
        Raft chooses **Consistency**
        over **Availability**.
        The partitioned leader is
        **unavailable** for reads—
        it cannot serve them safely.
        This is correct behavior!
      |
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  old_leader: {
    label: "Old Leader"
    shape: circle
    style.fill: "#FFCDD2"
    width: 60
  }
  new_leader: {
    label: "New Leader"
    shape: circle
    style.fill: "#4CAF50"
    style.font-color: white
    width: 60
  }
  partition: {
    label: "Partition"
    shape: rectangle
    style.stroke: "#F44336"
    style.stroke-dash: 4
    style.fill: transparent
    width: 60
  }
}
row1.timeline.t0 -> row1.clusters.cluster_before: "Initial"
row1.timeline.t1 -> row1.clusters.cluster_partitioned: "After partition"