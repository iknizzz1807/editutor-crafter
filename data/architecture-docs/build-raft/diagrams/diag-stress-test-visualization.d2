direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    timeline_bg: "#1a1a2e"
    timeline_fg: "#eaeaea"
    healthy_green: "#00d26a"
    warning_yellow: "#ffc107"
    danger_red: "#ff5252"
    partition_shade: "#ff5252"
    throughput_blue: "#4fc3f7"
    checkpoint_green: "#00e676"
    axis_gray: "#666666"
  }
}

# --- HEADER SECTION ---
header: {
  shape: package
  label: "Raft Consensus Stress Test Visualization (node_stress_test.go)"
  info: {
    shape: rectangle
    label: |'md
      ## Raft Stress Test Timeline (10 minutes)
      **100 nodes | 10,000 commands | Continuous chaos injection**
    '|
  }
}

# --- TIMELINE VISUALIZATION ---
timeline_container: {
  label: "Timeline metrics (Time: 0-10m)"
  style.fill: ${colors.timeline_bg}
  style.stroke: "#333"
  style.stroke-width: 2
  width: 1400

  # X-Axis Row
  timeline_header: {
    style.fill: transparent
    style.stroke: transparent
    direction: right
    time_axis_label: "Time (minutes)" {
      style.font-color: ${colors.timeline_fg}
      style.font-size: 14
    }
    time_markers: {
      style.fill: transparent
      style.stroke: transparent
      direction: right
      t0: "0" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t1: "1" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t2: "2" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t3: "3" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t4: "4" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t5: "5" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t6: "6" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t7: "7" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t8: "8" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t9: "9" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
      t10: "10" { style.font-color: ${colors.axis_gray}; style.font-size: 11 }
    }
  }

  # Throughput Row
  throughput_section: {
    label: "Throughput (cmds/sec)"
    style.fill: "#0d0d1a"
    style.stroke: ${colors.throughput_blue}
    style.stroke-width: 1
    
    graph_area: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      throughput_baseline: {
        label: "~100 cmd/s baseline"
        width: 600
        height: 80
        style.fill: ${colors.throughput_blue}
        style.opacity: 0.2
        style.stroke: ${colors.axis_gray}
        style.stroke-dash: 2
      }
      
      drop_1: "↓ 40%" {
        width: 150
        height: 48
        style.fill: ${colors.danger_red}
        style.font-color: ${colors.danger_red}
      }
      
      recovery_peak: {
        label: "Auto-recovery"
        width: 300
        height: 90
        style.fill: ${colors.healthy_green}
        style.opacity: 0.3
      }
      
      drop_2: "↓ 60%" {
        width: 200
        height: 32
        style.fill: ${colors.danger_red}
        style.font-color: ${colors.danger_red}
      }
    }
  }

  # Chaos Row
  partition_section: {
    label: "Network Partitions & Events"
    style.fill: "#0d0d1a"
    style.stroke: ${colors.warning_yellow}
    
    events: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      p1: "Partition 1 (S1-S40)" {
        width: 180
        style.fill: ${colors.partition_shade}
        style.opacity: 0.2
        style.stroke: ${colors.danger_red}
        style.font-color: ${colors.danger_red}
      }
      
      k1: "☠ Node Kill" {
        width: 100
        style.fill: transparent
        style.stroke: ${colors.danger_red}
        style.font-color: ${colors.danger_red}
      }
      
      p2: "Partition 2 (Quorum Loss)" {
        width: 250
        style.fill: ${colors.partition_shade}
        style.opacity: 0.2
        style.stroke: ${colors.danger_red}
        style.font-color: ${colors.danger_red}
      }
      
      chk: "✓ Safety Check" {
        width: 120
        style.fill: transparent
        style.stroke: ${colors.checkpoint_green}
        style.font-color: ${colors.checkpoint_green}
      }
    }
  }
}

# --- STATS SUMMARY ---
stats_container: {
  label: "Final Test Results Summary"
  width: 1400
  style.fill: "#0d0d1a"
  style.stroke: "#444"
  style.stroke-width: 2
  direction: right

  stats_commands: {
    label: "Command Consistency"
    style.stroke: ${colors.throughput_blue}
    
    submitted: {
      label: "Submitted"
      val: {
        label: "10,247"
        style.font-size: 18
        style.bold: true
      }
    }
    committed: {
      label: "Committed"
      val: {
        label: "10,247 (100%)"
        style.font-color: ${colors.healthy_green}
        style.bold: true
      }
    }
  }

  stats_latency: {
    label: "Commit Latency"
    style.stroke: ${colors.warning_yellow}
    
    p99: {
      label: "p99 Latency"
      val: {
        label: "847ms"
        style.font-color: ${colors.warning_yellow}
      }
    }
    max: {
      label: "Max Latency"
      val: {
        label: "2.3s"
        style.font-color: ${colors.danger_red}
      }
    }
  }

  stats_chaos_summary: {
    label: "Chaos Resilience"
    style.stroke: ${colors.danger_red}
    
    node_kills: {
      label: "Node Kills"
      val: { label: "47" }
    }
    partitions: {
      label: "Partitions"
      val: { label: "12" }
    }
    violations: {
      label: "Violations"
      val: {
        label: "0 ✓"
        style.font-color: ${colors.healthy_green}
        style.bold: true
      }
    }
  }
}

# --- SAFETY INVARIANTS ---
safety_invariants: {
  label: "Protocol Invariant Checks"
  width: 1400
  style.fill: "#0d0d1a"
  style.stroke: ${colors.checkpoint_green}
  direction: right

  election_safety: {
    label: "Election Safety"
    details: {
      label: "At most 1 leader per term"
      style.font-color: ${colors.healthy_green}
    }
    status: "PASS (0 violations)"
  }

  log_matching: {
    label: "Log Matching"
    details: {
      label: "Index+Term unique to content"
      style.font-color: ${colors.healthy_green}
    }
    status: "PASS (0 violations)"
  }

  leader_completeness: {
    label: "Leader Completeness"
    details: {
      label: "Committed logs persist"
      style.font-color: ${colors.healthy_green}
    }
    status: "PASS (0 violations)"
  }

  final_verdict: {
    label: "Final Verdict"
    style.fill: ${colors.healthy_green}
    style.font-color: "#000"
    style.bold: true
    status: "100% STABLE"
  }
}

# --- LEGEND ---
legend: {
  direction: right
  style.stroke: "#444"
  style.fill: "#0d0d1a"

  leg_t: {
    label: "Throughput"
    style.fill: ${colors.throughput_blue}
    width: 20; height: 10
  }
  leg_p: {
    label: "Partition"
    style.fill: ${colors.partition_shade}
    style.opacity: 0.2
    style.stroke: ${colors.danger_red}
    width: 20; height: 10
  }
  leg_k: {
    label: "☠ Node Kill"
    style.font-color: ${colors.danger_red}
    style.stroke: transparent
    style.fill: transparent
  }
  leg_v: {
    label: "✓ Safety Passed"
    style.font-color: ${colors.checkpoint_green}
    style.stroke: transparent
    style.fill: transparent
  }
}

legend.near: bottom-center