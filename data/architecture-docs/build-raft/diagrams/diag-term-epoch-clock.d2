direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Terms as Logical Clocks
  Distributed epoch numbers that only increase
| {near: top-center}
row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  node_a_col: {
    direction: down
    label: ""
    node_a_header: {
      label: "Node A"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      style.font-color: "#1565C0"
      style.bold: true
    }
    node_a_t1: {
      label: "Term 3"
      shape: circle
      style.fill: "#BBDEFB"
      style.stroke: "#2196F3"
      width: 80
    }
    node_a_transition: {
      label: "Receives RPC\nfrom B (term 5)"
      shape: diamond
      style.fill: "#FFECB3"
      style.stroke: "#FF9800"
      width: 100
    }
    node_a_t2: {
      label: "Term 5"
      shape: circle
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      width: 80
    }
    node_a_state: {
      label: "State: Follower\n(stepped down)"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.stroke-dash: 3
    }
    node_a_header -> node_a_t1 -> node_a_transition -> node_a_t2 -> node_a_state
  }
  node_b_col: {
    direction: down
    label: ""
    node_b_header: {
      label: "Node B"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      style.font-color: "#1565C0"
      style.bold: true
    }
    node_b_t1: {
      label: "Term 4"
      shape: circle
      style.fill: "#BBDEFB"
      style.stroke: "#2196F3"
      width: 80
    }
    node_b_transition: {
      label: "Wins election\nincrements to 5"
      shape: diamond
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      width: 100
    }
    node_b_t2: {
      label: "Term 5"
      shape: circle
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      width: 80
    }
    node_b_state: {
      label: "State: Leader\n(sends heartbeats)"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    node_b_header -> node_b_t1 -> node_b_transition -> node_b_t2 -> node_b_state
  }
  node_c_col: {
    direction: down
    label: ""
    node_c_header: {
      label: "Node C"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      style.font-color: "#1565C0"
      style.bold: true
    }
    node_c_t1: {
      label: "Term 3"
      shape: circle
      style.fill: "#BBDEFB"
      style.stroke: "#2196F3"
      width: 80
    }
    node_c_transition: {
      label: "Receives\nAppendEntries"
      shape: diamond
      style.fill: "#E1BEE7"
      style.stroke: "#9C27B0"
      width: 100
    }
    node_c_t2: {
      label: "Term 5"
      shape: circle
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      width: 80
    }
    node_c_state: {
      label: "State: Follower\n(reset timer)"
      shape: rectangle
      style.fill: "#E1BEE7"
      style.stroke: "#9C27B0"
    }
    node_c_header -> node_c_t1 -> node_c_transition -> node_c_t2 -> node_c_state
  }
}
node_b_col.node_b_t2 -> node_a_col.node_a_transition: "AppendEntries RPC\nterm=5, leaderId=B" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.animated: true
}
node_b_col.node_b_t2 -> node_c_col.node_c_transition: "AppendEntries RPC\nterm=5, leaderId=B" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
row_properties: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  term_properties: {
    label: "Term Properties"
    prop1: {
      label: "1. Monotonically Increasing"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    prop2: {
      label: "2. Never Decrease"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    prop3: {
      label: "3. Carried in Every RPC"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    prop4: {
      label: "4. Higher Term Wins"
      shape: rectangle
      style.fill: "#FFCDD2"
    }
    prop1 -> prop2 -> prop3 -> prop4
  }
  comparison: {
    label: "Logical vs Physical Clocks"
    logical: {
      label: "Logical (Terms)"
      shape: rectangle
      style.fill: "#E8F4FD"
      l1: "No clock drift"
      l2: "Deterministic ordering"
      l3: "Survives partitions"
      l4: "Explicit in protocol"
    }
    physical: {
      label: "Physical Clocks"
      shape: rectangle
      style.fill: "#FFECB3"
      p1: "Clock drift exists"
      p2: "NTP sync required"
      p3: "Partition breaks sync"
      p4: "Subtle bugs"
    }
  }
}
row_code: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  term_handler: {
    label: "Term Handler (raft.go)"
    width: 400
    code: |'go
      func (rf *Raft) checkTerm(rpcTerm int) bool {
          if rpcTerm > rf.currentTerm {
              rf.currentTerm = rpcTerm
              rf.votedFor = ""   // Reset vote
              rf.state = Follower
              rf.persist()       // BEFORE responding
              return true
          }
          return false
      }
    '|
  }
  rpc_fields: {
    label: "RPC Fields (All Include Term)"
    request_vote: {
      shape: sql_table
      label: "RequestVoteArgs"
      f1: "Term | int | Candidate's term"
      f2: "CandidateId | string | Who wants vote"
      f3: "LastLogIndex | int | Log position"
      f4: "LastLogTerm | int | Log term"
    }
    append_entries: {
      shape: sql_table
      label: "AppendEntriesArgs"
      f1: "Term | int | Leader's term"
      f2: "LeaderId | string | For redirect"
      f3: "PrevLogIndex | int | Consistency check"
      f4: "PrevLogTerm | int | Consistency check"
      f5: "Entries | []LogEntry | Data"
      f6: "LeaderCommit | int | Commit point"
    }
  }
}
row_timeline -> row_properties: "Enables" {
  style.stroke-dash: 3
}
row_properties -> row_code: "Implemented via" {
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  label: "Legend"
  green: "Green = Term 5 (current)"
  green.shape: rectangle
  green.style.fill: "#C8E6C9"
  blue: "Blue = Term 3-4 (older)"
  blue.shape: rectangle
  blue.style.fill: "#BBDEFB"
  orange: "Orange = Transition point"
  orange.shape: rectangle
  orange.style.fill: "#FFECB3"
}