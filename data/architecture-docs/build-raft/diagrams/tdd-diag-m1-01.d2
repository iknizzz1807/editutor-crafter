direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 50
  }
}

# --- DOCUMENT HEADER ---
TitleCard: {
  shape: text
  label: |md
    # Raft Consensus Algorithm: Node State Machine
    **Reference:** IEEE Specification / Diego Ongaro's Raft Paper
    *Intel Technical Design Standard - Layout v2.1*
  |
  near: top-center
  style: {
    font-size: 32
    bold: true
  }
}

# --- GLOBAL CLASSES ---
classes: {
  state_node: {
    shape: circle
    width: 400
    height: 400
    style: {
      stroke-width: 5
      shadow: true
      font-size: 14
    }
  }
  illegal_edge: {
    style: {
      stroke: "#D32F2F"
      stroke-dash: 5
      stroke-width: 3
      opacity: 0.8
    }
  }
  transition_label: {
    style: {
      font-size: 16
      bold: true
    }
  }
}

# --- STATE DEFINITIONS ---
Follower: {
  class: state_node
  label: |md
    ### 1. FOLLOWER
    ---
    **Volatile State:**
    - `commitIndex`: 0
    - `lastApplied`: 0
    ---
    **Invariants:**
    - Responds to RPCs from candidates and leaders.
    - On timeout: convert to candidate.
    - If `term T > currentTerm`: set `currentTerm = T`, convert to follower.
  |
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
  }
}

Candidate: {
  class: state_node
  label: |md
    ### 2. CANDIDATE
    ---
    **Election Logic:**
    - On conversion: `currentTerm++`
    - Vote for self
    - Reset election timer
    - Send `RequestVote` RPCs
    ---
    **Invariants:**
    - Votes for self.
    - If majority received: convert to leader.
    - If RPC from new leader: convert to follower.
  |
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
  }
}

Leader: {
  class: state_node
  label: |md
    ### 3. LEADER
    ---
    **Periodic Actions:**
    - Upon election: send heartbeats.
    - Maintain `nextIndex[]` and `matchIndex[]` for all followers.
    ---
    **Volatile State:**
    - `nextIndex[]`: (init to leader last log index + 1)
    - `matchIndex[]`: (init to 0)
  |
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
  }
}

# --- INITIALIZATION ---
StartNode: ● {
  shape: circle
  width: 40
  height: 40
  style.fill: black
}
StartNode -> Follower: "Server Startup" {
  style.stroke-width: 4
}

# --- TRANSITIONS ---

# Follower to Candidate
Follower -> Candidate: "Election timeout,\nStart Election" {
  class: transition_label
  style: {
    stroke: "#E65100"
    stroke-width: 4
    animated: true
  }
}

# Candidate to Candidate (Split Vote)
Candidate -> Candidate: "Election timeout,\nStart new election" {
  class: transition_label
  style: {
    stroke: "#E65100"
    stroke-dash: 3
  }
}

# Candidate to Leader
Candidate -> Leader: "Received votes from\nmajority of servers" {
  class: transition_label
  style: {
    stroke: "#1565C0"
    stroke-width: 5
  }
}

# Candidate to Follower (Higher Term)
Candidate -> Follower: "Discover higher term\nor newer leader" {
  class: transition_label
  style: {
    stroke: "#616161"
    stroke-dash: 2
  }
}

# Leader to Follower
Leader -> Follower: "Discover server\nwith higher term" {
  class: transition_label
  style: {
    stroke: "#D32F2F"
    stroke-dash: 6
    stroke-width: 3
  }
}

# --- ILLEGAL TRANSITIONS ---
Follower -> Leader: "ILLEGAL" { 
  class: illegal_edge 
  style.font-color: "#D32F2F"
}
Leader -> Candidate: "ILLEGAL" { 
  class: illegal_edge 
  style.font-color: "#D32F2F"
}

# --- PERSISTENT STATE MEMORY LAYOUT ---
PersistentStorage: {
  label: "MEMORY LAYOUT: PERSISTENT STATE (On-Disk Stable Storage)"
  near: bottom-center
  
  grid-columns: 1
  grid-gap: 20
  
  VisualMap: {
    grid-columns: 4
    grid-gap: 0
    
    H1: "Offset" { style.bold: true; style.fill: gray }
    H2: "Field" { style.bold: true; style.fill: gray }
    H3: "Type" { style.bold: true; style.fill: gray }
    H4: "Size" { style.bold: true; style.fill: gray }
    
    R1C1: "0x00"
    R1C2: "currentTerm" { style.fill: "#D1C4E9" }
    R1C3: "uint64"
    R1C4: "8B"
    
    R2C1: "0x08"
    R2C2: "votedFor" { style.fill: "#D1C4E9" }
    R2C3: "uint32"
    R2C4: "4B"

    R3C1: "0x0C"
    R3C2: "logLength" { style.fill: "#D1C4E9" }
    R3C3: "uint64"
    R3C4: "8B"

    R4C1: "0x14"
    R4C2: "logEntries" { style.fill: "#B3E5FC" }
    R4C3: "Pointer"
    R4C4: "8B"
  }
  
  Details: |md
    - **currentTerm**: Latest term server has seen (monotonic).
    - **votedFor**: CandidateId that received vote in current term (or null).
    - **log[]**: Log entries; each entry contains command for state machine, and term when entry was received by leader.
  |
}

# --- TIMING SPECIFICATIONS ---
Timing_Constraints: {
  near: top-right
  label: |md
    ### TIMING CONSTRAINTS
    ---
    Equation: $T_{broadcast} \ll T_{election} \ll T_{MTBF}$
    
    - **Heartbeat Interval:** ~50ms
    - **Election Timeout:** 150ms - 300ms
    - **Implementation Note:** Election timeouts must be randomized to prevent split votes in Candidate state.
  |
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    border-radius: 10
  }
}

# --- LEGEND ---
DiagramLegend: {
  label: "Control Flow & Transition Logic"
  near: bottom-right
  style.fill: "#F5F5F5"
  
  L1: "━━▶ Valid State Transition" { shape: text }
  L2: "┈┈▶ Higher Term Discovery" { shape: text }
  L3: "━ ━▶ ILLEGAL Transition Path" { 
    shape: text
    style.font-color: "#D32F2F" 
  }
  L4: "🌀 Animated: High Priority Path" { shape: text }
}