vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
Candidate
Follower1: Follower 1
Follower2: Follower 2
Follower3: Follower 3
# Step 1: Election timeout fires
Candidate -> Candidate: Election timeout fires
# Step 2: Transition to candidate
Candidate.t1 -> Candidate.t1: "1. Transition to Candidate\n   Increment term\n   Vote for self\n   Persist state"
# Step 3: Send RequestVote RPCs in parallel
Candidate.t2 -> Follower1.t1: "2a. RequestVote(term, candidateId, lastLogIndex, lastLogTerm)"
Candidate.t2 -> Follower2.t1: "2b. RequestVote(term, candidateId, lastLogIndex, lastLogTerm)"
Candidate.t2 -> Follower3.t1: "2c. RequestVote(term, candidateId, lastLogIndex, lastLogTerm)"
# Step 4: Followers check and grant vote
Follower1.t2 -> Candidate.t3: "3a. VoteGranted=true" {
  style.stroke: green
  style.bold: true
}
Follower2.t2 -> Candidate.t3: "3b. VoteGranted=true" {
  style.stroke: green
  style.bold: true
}
Follower3.t2 -> Candidate.t3: "3c. VoteGranted=true" {
  style.stroke: green
  style.bold: true
}
# Step 5: Majority achieved, become leader
Candidate.t4 -> Candidate.t4: "4. Majority achieved\n   (3/5 votes)\n   Transition to Leader"
# Step 6: Send immediate heartbeats
Candidate.t5 -> Follower1.t3: "5a. AppendEntries (heartbeat)"
Candidate.t5 -> Follower2.t3: "5b. AppendEntries (heartbeat)"
Candidate.t5 -> Follower3.t3: "5c. AppendEntries (heartbeat)"
# Annotations
Candidate."Vote Count: 1 (self) + 3 (peers) = 4/5"