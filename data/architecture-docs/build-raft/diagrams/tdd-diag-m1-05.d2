direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Raft Protocol: Log Up-to-Date Comparison
  *Safety Property: Implementation of RequestVote RPC restriction*
| {near: top-center}

compare_box: {
  label: "Decision Matrix (Section 5.4.1)"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2

  term_compare: {
    shape: rectangle
    label: "1. Term Comparison (Primary)"
    style.fill: "#BBDEFB"
    
    term_gt: "Candidate.lastLogTerm > Self.lastLogTerm" {
      label: "Result: UP-TO-DATE ✓"
      style.font-color: "#2E7D32"
      style.bold: true
    }
    term_lt: "Candidate.lastLogTerm < Self.lastLogTerm" {
      label: "Result: STALE ✗"
      style.font-color: "#C62828"
    }
    term_eq: "Candidate.lastLogTerm == Self.lastLogTerm" {
      label: "Action: Check Index →"
      style.italic: true
    }
  }

  index_compare: {
    shape: rectangle
    label: "2. Index Comparison (Secondary)"
    style.fill: "#BBDEFB"
    
    idx_ge: "Candidate.lastLogIndex >= Self.lastLogIndex" {
      label: "Result: UP-TO-DATE ✓"
      style.font-color: "#2E7D32"
      style.bold: true
    }
    idx_lt: "Candidate.lastLogIndex < Self.lastLogIndex" {
      label: "Result: STALE ✗"
      style.font-color: "#C62828"
    }
  }

  term_compare.term_eq -> index_compare: "Same Term" {
    style.stroke-dash: 3
    style.stroke: "#1976D2"
  }
}

example_box: {
  label: "Implementation Test Scenarios"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"

  case1: {
    shape: rectangle
    label: "Scenario 1: Term Superiority"
    c1_leader: "Local Node\nlastTerm=2, lastIndex=5"
    c1_candidate: "Candidate Req\nlastTerm=3, lastIndex=2"
    c1_result: "UP-TO-DATE (✓ Granted)\nReason: Term 3 > Term 2" {
      style.font-color: "#2E7D32"
    }
    c1_leader -> c1_candidate: "Compare" {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
  }

  case2: {
    shape: rectangle
    label: "Scenario 2: Log Completeness (Same Term)"
    c2_leader: "Local Node\nlastTerm=2, lastIndex=5"
    c2_candidate: "Candidate Req\nlastTerm=2, lastIndex=7"
    c2_result: "UP-TO-DATE (✓ Granted)\nReason: Index 7 >= 5" {
      style.font-color: "#2E7D32"
    }
    c2_leader -> c2_candidate: "Compare" {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
  }

  case3: {
    shape: rectangle
    label: "Scenario 3: Short Stale Log (Tie)"
    c3_leader: "Local Node\nlastTerm=2, lastIndex=5"
    c3_candidate: "Candidate Req\nlastTerm=2, lastIndex=3"
    c3_result: "STALE (✗ Denied)\nReason: Index 3 < 5" {
      style.font-color: "#C62828"
    }
    c3_leader -> c3_candidate: "Compare" {
      style.stroke: "#F44336"
      style.stroke-width: 2
    }
  }
}

edge_case: {
  near: bottom-center
  shape: text
  label: |md
    ### CRITICAL SAFETY INSIGHT
    Raft determines which of two logs is more up-to-date by comparing the index and term of the last entries in the logs. 
    **Rule:** If the logs have last entries with different terms, then the log with the later term is more up-to-date. If the logs end with the same term, then whichever log is longer is more up-to-date.
  |
}

compare_box.style.border-radius: 8
example_box.style.border-radius: 8

case1.style.fill: "#E8F5E9"
case2.style.fill: "#E8F5E9"
case3.style.fill: "#FFEBEE"

# Legend
legend: {
  near: bottom-right
  Up: "Up-to-Date" {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  Stale: "Stale" {
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
}