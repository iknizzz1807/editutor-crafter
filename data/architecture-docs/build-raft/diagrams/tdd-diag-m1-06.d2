vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Quorum Intersection Proof
  **Property: At most one leader per term**
'| {near: top-center}

direction: right

cluster: "5-Node Cluster (N=5)" {
  style.fill: white
  style.stroke: "#CBD6E0"
  style.stroke-width: 2
  
  node_a: "A" {
    shape: circle
    style.fill: "#FFE0F5"
    style.stroke: "#7939A8"
    style.font-color: "#7939A8"
    style.bold: true
    tooltip: "Member of Quorum 1"
  }
  node_b: "B" {
    shape: circle
    style.fill: "#FFE0F5"
    style.stroke: "#7939A8"
    style.font-color: "#7939A8"
    style.bold: true
    tooltip: "Member of Quorum 1"
  }
  node_c: "C" {
    shape: circle
    style.fill: "#FFF9C9"
    style.stroke: "#9D341E"
    style.font-color: "#9D341E"
    style.bold: true
    style.double-border: true
    tooltip: "Intersection Node (Member of Q1 & Q2)"
  }
  node_d: "D" {
    shape: circle
    style.fill: "#E8F4FD"
    style.stroke: "#3B82F6"
    style.font-color: "#3B82F6"
    style.bold: true
    tooltip: "Member of Quorum 2"
  }
  node_e: "E" {
    shape: circle
    style.fill: "#E8F4FD"
    style.stroke: "#3B82F6"
    style.font-color: "#3B82F6"
    style.bold: true
    tooltip: "Member of Quorum 2"
  }

  grid-columns: 5
  grid-gap: 40
}

proof: {
  style.fill: transparent
  style.stroke: transparent

  step1: "Election 1" {
    shape: rectangle
    style.fill: "#FFE0F5"
    style.stroke: "#7939A8"
    style.font-color: "#7939A8"
    label: |'md
      ### Candidate X wins Term 5
      **Quorum Q1: {A, B, C}**
      - A votes for X [OK]
      - B votes for X [OK]
      - C votes for X [OK]
      **Result: X becomes Leader**
    '|
  }

  step2: "Election 2 (Term 5)" {
    shape: rectangle
    style.fill: "#E8F4FD"
    style.stroke: "#3B82F6"
    style.font-color: "#3B82F6"
    label: |'md
      ### Candidate Y attempts Term 5
      **Quorum Q2: {C, D, E}**
      - C: "Already voted for X in T5!"
      - D votes for Y [OK]
      - E votes for Y [OK]
      **Result: 2 Votes < Majority (3)**
    '|
  }

  step3: "Intersection Logic" {
    shape: rectangle
    style.fill: "#FFF9C9"
    style.stroke: "#9D341E"
    style.font-color: "#9D341E"
    label: |'md
      ### The Pigeonhole Principle
      Any two majorities (Q1, Q2) of N nodes 
      must share at least one node:
      **Overlap ≥ 1**
      
      Since a node (C) can vote at most
      once per term, it cannot grant 
      the vote needed for a second leader.
    '|
  }

  conclusion: "Safety Verification" {
    shape: rectangle
    style.fill: "#ACE1AF"
    style.stroke: "#167c3c"
    style.font-color: "#167c3c"
    label: |'md
      ### Conclusion
      **Safety Guaranteed.**
      Election quorums are mutually 
      exclusive for a single term.
      No split-brain is possible 
      within the same Term ID.
    '|
  }

  step1 -> step2 -> step3 -> conclusion: {
    style.stroke: "#666"
    style.stroke-width: 2
    style.animated: true
  }
}

legend: {
  near: bottom-center
  style.fill: white
  style.stroke: "#CBD6E0"
  label: |'md
    **Diagram Legend**
    - 🟣 Nodes in Quorum 1 (Majority for Candidate X)
    - 🔵 Nodes in Quorum 2 (Majority for Candidate Y)
    - 🟡 Overlap Node (Prevents dual-leadership)
  '|
}

math: {
  near: bottom-right
  style.fill: "#F6F9FC"
  style.stroke: "#CBD6E0"
  label: |'md
    ### Quorum Intersection Formula
    For cluster size **N**, majority **Q** is:
    `Q = floor(N/2) + 1`

    **Intersection Proof:**
    `Overlap = (Q1 + Q2) - N`
    `Overlap = (3 + 3) - 5 = 1`

    | N | Majority (Q) | Min Overlap |
    |---|--------------|-------------|
    | 3 | 2            | 1           |
    | 5 | 3            | 1           |
    | 7 | 4            | 1           |
    | 9 | 5            | 1           |
  '|
}