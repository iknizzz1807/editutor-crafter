vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 50
  }
}

direction: right

title: {
  label: |md
    # Raft Persistence Flow
    **"Persist BEFORE Respond" Protocol**
    *Intel Manual Quality Spec v1.0*
  |
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    font-color: "#C41E3A"
  }
}

# -----------------------------------------------------------------------------------------
# Core State Machine Containers
# -----------------------------------------------------------------------------------------

request_box: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
    border-radius: 8
  }
  label: |md
    ### RPC ENTRY
    **RPC Request Received**
    - `RequestVote`
    - `AppendEntries`
    ---
    *Validation: term checks, log consistency*
  |
}

decision: {
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
  label: |md
    **Modifies**
    **Persistent State?**
  |
}

persist_box: {
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 4
    double-border: true
  }
  label: |md
    ### STEP 1: PERSIST
    `rf.persist()`
    ---
    **Memory Layout (Little Endian)**
    0x00 | `currentTerm` | 8 bytes
    0x08 | `votedFor`    | 8 bytes
    0x10 | `log_length`  | 4 bytes
    0x14 | `log_data[]`  | Var bytes
    ---
    **I/O: io.Writer -> fsync()**
  |
}

response_box: {
  shape: rectangle
  style: {
    fill: "#E8EAF6"
    stroke: "#5C6BC0"
    stroke-width: 2
    border-radius: 8
  }
  label: |md
    ### STEP 2: RESPOND
    **Finalize RPC Reply**
    - `reply.VoteGranted = true`
    - `reply.Success = true`
    ---
    *Unlock mutex & Return*
  |
}

# -----------------------------------------------------------------------------------------
# Storage Architecture
# -----------------------------------------------------------------------------------------

storage: {
  label: |md
    ### STABLE STORAGE
    (Non-Volatile)
    `raft_state.bin`
    **Fsync Latency Barrier**
  |
  shape: cylinder
  style: {
    fill: "#ECEFF1"
    stroke: "#607D8B"
  }
}

# -----------------------------------------------------------------------------------------
# Flow Definitions
# -----------------------------------------------------------------------------------------

request_box -> decision: "Parse & Mutate" {
  style: {
    font-size: 14
    stroke-width: 2
  }
}

decision -> persist_box: "Yes (State Changed)" {
  style: {
    stroke: "#388E3C"
    stroke-width: 4
    bold: true
  }
}

decision -> response_box: "No (Read-Only)" {
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 3
    opacity: 0.6
  }
}

persist_box -> storage: "Blocking fsync()" {
  style: {
    stroke: "#388E3C"
    stroke-width: 4
    bold: true
    animated: true
  }
}

storage -> persist_box: "I/O Complete" {
  style: {
    stroke-dash: 5
    stroke: "#388E3C"
  }
}

persist_box -> response_box: "On Success" {
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------------------
# Annotations and Safety Analysis
# -----------------------------------------------------------------------------------------

failure_box: {
  label: |md
    ### SAFETY ANALYSIS: CRASH RECOVERY
    | Failure Point | System Outcome |
    | :--- | :--- |
    | **Crash before Persist** | Node reboots with old state. RPC never replied. Safety preserved. |
    | **Crash during Persist** | Atomic rename ensures file is valid or old. No partial writes. |
    | **Crash after Respond** | State already on disk. Node reboots in correct state. |
  |
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FFA000"
    border-radius: 8
  }
  near: bottom-left
}

persist_label: {
  label: |md
    **CRITICAL BARRIER**
    Execution MUST block here
    until bits hit the platter.
  |
  # FIX: ELK requires constant values for near.
  near: top-right
  shape: text
  style: {
    font-color: "#D32F2F"
    bold: true
    font-size: 14
  }
}

# -----------------------------------------------------------------------------------------
# Legend and Invariants
# -----------------------------------------------------------------------------------------

legend: {
  shape: rectangle
  style: {
    fill: white
    stroke: "#BDBDBD"
    stroke-dash: 2
  }
  label: |md
    ### RAFT INVARIANTS
    - **Persistence** occurs before **Visibility** (RPC Reply).
    - Failure to persist must result in zero-effect (no response).
    - `fsync` is required to survive power loss, not just OS crashes.
  |
  near: bottom-right
}

# -----------------------------------------------------------------------------------------
# Layout Polish
# -----------------------------------------------------------------------------------------

(decision -> persist_box)[0].source-arrowhead: triangle
(persist_box -> storage)[0].target-arrowhead: diamond
(persist_box -> response_box)[0].target-arrowhead: arrow

persist_box.style.fill: "#C8E6C9"
persist_box.style.bold: true
response_box.style.bold: true