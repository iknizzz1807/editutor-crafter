vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    candidate: "#E8D4F8"
    follower: "#D4E8F8"
    leader: "#D4F8E8"
    timeout_bar: "#FFE4B5"
    split_vote: "#FFB6C1"
    resolved: "#90EE90"
    header: "#333333"
    rpc_req: "#FF4500"
    rpc_res: "#1E90FF"
    alert_border: "#B22222"
    success_border: "#228B22"
  }
}

title: |md
  # RAFT PROTOCOL: SPLIT VOTE RESOLUTION
  **Technical Specification: Randomized Election Timeouts**
  *Scenario: 5-Node Cluster (Majority=3). Term 2 ends in split; Term 3 resolves via timing offset.*
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 14
  }
}

# -----------------------------------------------------------------------------
# Main Visualization Container
# -----------------------------------------------------------------------------
raft_simulation: {
  direction: right

  # The Timeline Grid
  timeline: {
    grid-rows: 8
    grid-columns: 4
    grid-gap: 0
    style.stroke-width: 1

    # Row 0 - Headers (Phases)
    phase_label: "STATE / PHASE" {
      style: { fill: "#222222"; font-color: white; bold: true; font-size: 16 }
    }
    p1: "PHASE 1: SIMULTANEOUS START" {
      style: { fill: "#444444"; font-color: white; bold: true }
    }
    p2: "PHASE 2: SPLIT VOTE (TERM 2)" {
      style: { fill: "${colors.split_vote}"; font-color: black; bold: true }
    }
    p3: "PHASE 3: RESOLUTION (TERM 3)" {
      style: { fill: "${colors.resolved}"; font-color: black; bold: true }
    }

    # Row 1 - Timing Metadata
    time_label: "ELAPSED TIME (ms)" {
      style: { fill: "#EEEEEE"; bold: true; font: mono }
    }
    t0: "T = 0ms" { style: { fill: "#EEEEEE"; font: mono } }
    t1: "T = 150ms" { style: { fill: "#EEEEEE"; font: mono } }
    t2: "T = 200ms - 350ms" { style: { fill: "#EEEEEE"; font: mono } }

    # Row 2 - Node A (Fastest Timeout)
    nodeA_label: "NODE A\n(Timeout: 200ms)" {
      style: { fill: "${colors.candidate}"; stroke-width: 2 }
    }
    nodeA_t0: "STATE: CANDIDATE\nTerm: 2\nVotes: [A]" {
      style: { fill: "${colors.candidate}"; bold: true }
    }
    nodeA_t1: "STATE: CANDIDATE\nVotes: [A, C]\n(No Majority)" {
      style: { fill: "${colors.split_vote}"; stroke: red; stroke-dash: 3 }
    }
    nodeA_t2: "STATE: **LEADER**\n**Term: 3**\n**Votes: [A, C, D, E]**" {
      style: { 
        fill: "${colors.leader}"
        double-border: true 
        font-color: red
        bold: true
      }
    }

    # Row 3 - Node B (Mid Timeout)
    nodeB_label: "NODE B\n(Timeout: 250ms)" {
      style: { fill: "${colors.candidate}"; stroke-width: 2 }
    }
    nodeB_t0: "STATE: CANDIDATE\nTerm: 2\nVotes: [B]" {
      style: { fill: "${colors.candidate}"; bold: true }
    }
    nodeB_t1: "STATE: CANDIDATE\nVotes: [B, D]\n(No Majority)" {
      style: { fill: "${colors.split_vote}"; stroke: red; stroke-dash: 3 }
    }
    nodeB_t2: "STATE: **FOLLOWER**\n**Term: 3**\nTimer Cancelled" {
      style: { 
        fill: "${colors.follower}"
        stroke-dash: 2 
        font-color: red
        bold: true
      }
    }

    # Row 4 - Node C
    nodeC_label: "NODE C\n(Follower)" {
      style: { fill: "${colors.follower}" }
    }
    nodeC_t0: "STATE: FOLLOWER\nVotedFor: null" {
      style: { fill: "${colors.follower}" }
    }
    nodeC_t1: "GrantVote -> A\nTerm: 2" {
      style: { fill: "${colors.follower}" }
    }
    nodeC_t2: "**GrantVote -> A**\n**Term: 3**" {
      style: { 
        fill: "${colors.leader}"
        font-color: red
        bold: true 
      }
    }

    # Row 5 - Node D
    nodeD_label: "NODE D\n(Follower)" {
      style: { fill: "${colors.follower}" }
    }
    nodeD_t0: "STATE: FOLLOWER\nVotedFor: null" {
      style: { fill: "${colors.follower}" }
    }
    nodeD_t1: "GrantVote -> B\nTerm: 2" {
      style: { fill: "${colors.follower}" }
    }
    nodeD_t2: "**GrantVote -> A**\n**Term: 3**" {
      style: { 
        fill: "${colors.leader}"
        font-color: red
        bold: true 
      }
    }

    # Row 6 - Node E
    nodeE_label: "NODE E\n(Follower)" {
      style: { fill: "${colors.follower}" }
    }
    nodeE_t0: "STATE: FOLLOWER\nRPC Delayed" {
      style: { fill: "${colors.follower}" }
    }
    nodeE_t1: "IDLE (Term 2)\nDid not vote" {
      style: { fill: "${colors.follower}" }
    }
    nodeE_t2: "**GrantVote -> A**\n**Term: 3**" {
      style: { 
        fill: "${colors.leader}"
        font-color: red
        bold: true 
      }
    }

    # Row 7 - Legend/System Status
    status_label: "SYSTEM STATUS" {
      style: { fill: "#DDDDDD"; bold: true }
    }
    s0: "Synchronized"
    s1: "SPLIT VOTE (FAILURE)" {
      style: { fill: "${colors.split_vote}"; font-color: red; bold: true }
    }
    s2: "ELECTION SUCCESS" {
      style: { fill: "${colors.resolved}"; font-color: green; bold: true }
    }
  }

  # Sidebar container for annotations
  annotations: {
    direction: down
    
    split_vote_alert: "CRITICAL: SPLIT VOTE\nNo majority found in Term 2\n(A:2, B:2, Idle:1)" {
      style: {
        fill: "${colors.split_vote}"
        stroke: "${colors.alert_border}"
        stroke-width: 4
        bold: true
        font-size: 16
        shadow: true
      }
    }

    resolution_result: "RESOLVED: LEADER ELECTED\nTerm 3 Logic: ${T_A} < T_B$\nVotes: [A, C, D, E] = 4/5" {
      style: {
        fill: "${colors.resolved}"
        stroke: "${colors.success_border}"
        stroke-width: 4
        bold: true
        font-size: 16
        shadow: true
      }
    }

    protocol_logic: |md
      ### Raft Safety Properties
      - **Term Symmetry**: Term 2 created a tie $(2=2)$.
      - **Reschedule**: Randomized timers reset on failure.
      - **Preemption**: Node A (200ms) wakes first in Term 3.
      - **Inversion**: Followers reset `VotedFor` on new Term.
      - **Convergence**: Node A reaches majority before B times out.
    | {
      style: {
        fill: "#FFFFFF"
        stroke: "#BBBBBB"
        border-radius: 5
      }
    }
  }
}

# -----------------------------------------------------------------------------
# Secondary Protocol Reference (Logic Diagram)
# -----------------------------------------------------------------------------
protocol_fsm: {
  label: "RAFT ELECTION STATE MACHINE"
  direction: down
  
  start: ● { shape: circle }
  f1: "Step 1: Increment Term"
  f2: "Step 2: Transition to Candidate"
  f3: "Step 3: Broadcast RequestVote"
  f4: "Step 4: Await Majority?"
  
  win: "LEADER STATE" { style.fill: "${colors.leader}" }
  fail: "SPLIT / TIMEOUT" { style.fill: "${colors.split_vote}"; stroke: red }
  
  start -> f1
  f1 -> f2
  f2 -> f3
  f3 -> f4
  
  f4 -> win: Majority Granted (N/2 + 1)
  f4 -> fail: Election Timer Expires
  fail -> f1: Start New Term
  
  style: {
    stroke: "#444444"
    fill: "#F9F9F9"
    font: mono
  }
}

# -----------------------------------------------------------------------------
# Global Styling and Inter-Grid Flow
# -----------------------------------------------------------------------------
***.style.font: mono

# Flow logic indicators (Direct Paths)
(raft_simulation.timeline.nodeA_t0 -> raft_simulation.timeline.nodeC_t1): "RPC RequestVote" { 
  style.stroke: "${colors.rpc_req}"
  style.stroke-dash: 2 
}
(raft_simulation.timeline.nodeB_t0 -> raft_simulation.timeline.nodeD_t1): "RPC RequestVote" { 
  style.stroke: "${colors.rpc_req}"
  style.stroke-dash: 2 
}
(raft_simulation.timeline.nodeA_t2 -> raft_simulation.timeline.nodeD_t2): "Term 3 RPC" { 
  style.stroke: "${colors.rpc_req}"
  style.animated: true
}

footer: "© 2024 Dist-Systems Technical Design Art - Raft Specification v1.3" {
  shape: text
  near: bottom-right
  style.font-size: 10
  style.italic: true
}