layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    header: "#7C3AED"
    data: "#3B82F6"
    free: "#10B981"
    padding: "#9CA3AF"
    pointer: "#F59E0B"
    leader: "#EF4444"
    follower: "#6B7280"
    candidate: "#F97316"
    partition: "#DC2626"
    success: "#059669"
    background: "#F9FAFB"
  }
}

title: |md
  # Raft Election Safety: Partition Scenario
  *At most one leader per term via quorum intersection*
| 
title.shape: text
title.near: top-center
title.style: {
  font-size: 24
  bold: true
}

direction: right

Phase1: "1. Initial State" {
  style: {
    fill: "#F3F4F6"
    stroke: "#9CA3AF"
    stroke-width: 2
  }
  Cluster: "5-Node Cluster (Healthy)" {
    style.fill: white
    N1: "Node 1\nFollower\nTerm: 3" {
      style.fill: ${colors.follower}
      style.font-color: white
    }
    N2: "Node 2\nFollower\nTerm: 3" {
      style.fill: ${colors.follower}
      style.font-color: white
    }
    N3: "Node 3\nLeader\nTerm: 3" {
      style.fill: ${colors.leader}
      style.font-color: white
      style.bold: true
      style.double-border: true
    }
    N4: "Node 4\nFollower\nTerm: 3" {
      style.fill: ${colors.follower}
      style.font-color: white
    }
    N5: "Node 5\nFollower\nTerm: 3" {
      style.fill: ${colors.follower}
      style.font-color: white
    }
    N3 -> N1: Heartbeat { style.stroke: ${colors.data} }
    N3 -> N2: Heartbeat { style.stroke: ${colors.data} }
    N3 -> N4: Heartbeat { style.stroke: ${colors.data} }
    N3 -> N5: Heartbeat { style.stroke: ${colors.data} }
  }
}

Phase2: "2. Network Partition" {
  style: {
    fill: "#FEF2F2"
    stroke: ${colors.partition}
    stroke-width: 2
  }
  
  Minority: "Minority Partition\n[Isolated Leader]" {
    style.fill: "#FEE2E2"
    style.stroke-dash: 5
    N3_iso: "Node 3\nLeader (isolated)\nTerm: 3" {
      style.fill: ${colors.leader}
      style.font-color: white
      style.stroke: ${colors.partition}
      style.stroke-width: 4
    }
    Note: "Isolation Impact" {
      shape: text
      label: |md
        - Heartbeats timeout
        - Cannot reach majority
        - Write Quorum: 1/5 (Failed)
      |
    }
  }

  Majority: "Majority Partition\n[Quorum Available]" {
    style.fill: "#DCFCE7"
    N1_maj: "Node 1\nFollower\nTerm: 3" { style.fill: ${colors.follower}; style.font-color: white }
    N2_maj: "Node 2\nFollower\nTerm: 3" { style.fill: ${colors.follower}; style.font-color: white }
    N4_maj: "Node 4\nFollower\nTerm: 3" { style.fill: ${colors.follower}; style.font-color: white }
    N5_maj: "Node 5\nFollower\nTerm: 3" { style.fill: ${colors.follower}; style.font-color: white }
    
    N1_maj <-> N2_maj
    N4_maj <-> N5_maj
    N2_maj <-> N4_maj
  }

  Minority -- Majority: "NETWORK PARTITION" {
    style: {
      stroke: ${colors.partition}
      stroke-width: 6
      stroke-dash: 3
      font-color: ${colors.partition}
      bold: true
    }
  }
}

Phase1 -> Phase2: "Event: Physical Link Failure" {
  style.stroke: ${colors.partition}
  style.animated: true
}

Phase3: "3. Election in Majority" {
  style: {
    fill: "#FEF3C7"
    stroke: ${colors.candidate}
    stroke-width: 2
  }
  MajAfter: "Majority Partition (Term 4)" {
    style.fill: "#DCFCE7"
    N1_elect: "Node 1\nCANDIDATE\nTerm: 4" {
      style.fill: ${colors.candidate}
      style.font-color: white
      style.bold: true
      style.shadow: true
    }
    N2_elect: "Node 2\nVoted: Node 1\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    N4_elect: "Node 4\nVoted: Node 1\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    N5_elect: "Node 5\nVoted: Node 1\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    
    N1_elect -> N2_elect: "RequestVote(T4)" { style.stroke: ${colors.candidate} }
    N1_elect -> N4_elect: "RequestVote(T4)" { style.stroke: ${colors.candidate} }
    N1_elect -> N5_elect: "RequestVote(T4)" { style.stroke: ${colors.candidate} }
  }
  VoteCount: |md
    **Quorum Check: 3/5 Required**
    1. Node 1: Self ✓
    2. Node 2: OK ✓
    3. Node 4: OK ✓
    **Result: SUCCESS**
  | 
  VoteCount.shape: text
}

Phase2 -> Phase3: "Timer: Election Timeout" {
  style.stroke: ${colors.candidate}
  style.animated: true
}

Phase4: "4. Dual-Leader State" {
  style: {
    fill: "#DCFCE7"
    stroke: ${colors.success}
    stroke-width: 2
  }
  Minority4: "Partition A (Stale)" {
    style.fill: "#FEE2E2"
    N3_stale: "Node 3\nLeader (Stale)\nTerm: 3" {
      style.fill: "#9CA3AF"
      style.font-color: white
      style.opacity: 0.7
    }
  }
  Majority4: "Partition B (New Leader)" {
    style.fill: "#DCFCE7"
    N1_leader: "Node 1\nLEADER\nTerm: 4" {
      style.fill: ${colors.leader}
      style.font-color: white
      style.bold: true
    }
    N2_follower: "Node 2\nFollower\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    N4_follower: "Node 4\nFollower\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    N5_follower: "Node 5\nFollower\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    
    N1_leader -> N2_follower: Heartbeat(T4)
    N1_leader -> N4_follower: Heartbeat(T4)
  }
  SafetyNote: |md
    ### Safety Guarantee
    Node 3 remains leader but cannot commit
    any entries because it cannot reach a
    majority quorum. System remains safe.
  |
  SafetyNote.shape: text
}

Phase3 -> Phase4: "Outcome: Node 1 Promoted" {
  style.stroke: ${colors.success}
}

Phase5: "5. Partition Healed" {
  style: {
    fill: "#F0FDF4"
    stroke: ${colors.success}
    stroke-width: 3
  }
  HealedCluster: "Recovered Cluster" {
    style.fill: white
    N1_final: "Node 1\nLEADER\nTerm: 4" { style.fill: ${colors.leader}; style.font-color: white; style.bold: true }
    N2_final: "Node 2\nFollower\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    N3_final: "Node 3\nFollower\nTerm: 4" { 
      style.fill: ${colors.follower}
      style.font-color: white
      style.stroke: ${colors.success}
      style.stroke-width: 3
    }
    N4_final: "Node 4\nFollower\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    N5_final: "Node 5\nFollower\nTerm: 4" { style.fill: ${colors.follower}; style.font-color: white }
    
    N1_final -> N3_final: "AppendEntries(T4)" {
      style.stroke: ${colors.success}
      style.bold: true
    }
  }
  RecoveryMsg: |md
    **Step-down Logic:**
    Node 3 discovers Term 4 > Term 3.
    It immediately reverts to Follower.
  |
  RecoveryMsg.shape: text
}

Phase4 -> Phase5: "Event: Link Restored" {
  style.stroke: ${colors.success}
  style.animated: true
}

Legend: "Legend" {
  near: bottom-right
  style.fill: white
  style.stroke: "#E5E7EB"
  L1: "Leader" {
    shape: rectangle
    style.fill: ${colors.leader}
    style.font-color: white
  }
  L2: "Follower" {
    shape: rectangle
    style.fill: ${colors.follower}
    style.font-color: white
  }
  L3: "Candidate" {
    shape: rectangle
    style.fill: ${colors.candidate}
    style.font-color: white
  }
}

QuorumExplain: |md
  ## Quorum Intersection Guarantee
  **Cluster Size (N) = 5**
  **Majority (Q) = 3**
  
  Mathematically: $Q > N/2$
  Any two subsets of size $Q$ must overlap by at least:
  $(2 \times Q) - N$ nodes.
  $(2 \times 3) - 5 = 1$ node.
  
  This overlap ensures that an old leader cannot 
  exist in the same term as a new leader.
|
QuorumExplain.shape: text
QuorumExplain.near: bottom-left
QuorumExplain.style.font-size: 14