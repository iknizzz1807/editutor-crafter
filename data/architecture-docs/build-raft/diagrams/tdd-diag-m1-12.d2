direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: |'md
    # Raft Failure Mode Analysis
    ## Comprehensive failure scenarios with recovery paths
  '|
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# ============================================
# SCENARIO 1: Candidate Crashes Mid-Election
# ============================================
Scenario1: {
  label: "Scenario 1: Candidate Crashes Mid-Election"
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#f9f9f9"
  }

  Header1: {
    shape: text
    label: |'md
      ### Timeline: Candidate receives 2 votes, needs 3 (5-node cluster)
    '|
  }

  S1_Before: "Before Crash" {
    style.fill: "#E8F5E9"
    Candidates: {
      shape: sequence_diagram
      C: Candidate (Node A)
      F1: Follower 1
      F2: Follower 2
      F3: Follower 3
      
      C -> F1: "RequestVote(term=5)"
      C <- F1: "VoteGranted"
      C -> F2: "RequestVote(term=5)"
      C <- F2: "VoteGranted"
      C -> F3: "RequestVote(term=5)"
      
      C."State: votes=2/3"
    }
    
    State1: {
      label: |'md
        **Node A Internal State**
        - term: 5
        - state: Candidate
        - votedFor: self
        - votes: 2/3
      '|
    }
  }

  S1_Crash: "CRASH POINT" {
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 4
    
    CrashMarker: {
      shape: text
      label: |'md
        ### 💥 Node A Crashes
        1. Vote request to F3 never finishes
        2. F3's response (if any) is lost
        3. **No heartbeats** are sent to cluster
      '|
    }
  }

  S1_Recovery: "Recovery Path" {
    style.fill: "#E3F2FD"
    
    RecoverySteps: {
      shape: text
      label: |'md
        **T+150ms:** F1's election timeout fires
        **T+155ms:** F1 → Candidate (term=6)
        **T+160ms:** F1 sends RequestVote(T=6) to F2, F3, F4
        **T+170ms:** F1 wins majority, becomes Leader
      '|
    }
    
    Result: {
      style.fill: "#C8E6C9"
      label: |'md
        **Result:** System recovers
        - New leader elected in term 6
        - Safety maintained
        - Node A stays down until restart
      '|
    }
  }

  S1_Before -> S1_Crash: "Crash Occurs"
  S1_Crash -> S1_Recovery: "Timeout triggers\nnew election"
}

# ============================================
# SCENARIO 2: Follower Crashes After Vote
# ============================================
Scenario2: {
  label: "Scenario 2: Follower Crashes After Voting"
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#f9f9f9"
  }

  Header2: {
    shape: text
    label: |'md
      ### Timeline: Follower votes, then crashes before sending RPC response
    '|
  }

  S2_Before: "1. Voting Sequence" {
    style.fill: "#E8F5E9"
    VoteSeq: {
      shape: sequence_diagram
      C: Candidate
      F: Follower (Node B)
      
      C -> F: "RequestVote(term=5)"
      F."1. Check currentTerm ✓"
      F."2. Check votedFor == null ✓"
      F."3. Set votedFor = Candidate"
      F."4. persist() to disk"
    }
    
    FollowerState: {
      shape: text
      label: |'md
        **Disk State (Persisted):**
        - currentTerm: 5
        - votedFor: "Candidate"
      '|
    }
  }

  S2_Crash: "2. CRASH POINT" {
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    
    Explanation: {
      shape: text
      label: |'md
        ### 💥 Follower Crashes
        - Happens **after** persistence
        - Happens **before** network reply
        - RPC times out at Candidate
      '|
    }
  }

  S2_Recovery: "3. Recovery & Restart" {
    style.fill: "#E3F2FD"
    
    RecoverySeq: {
      shape: sequence_diagram
      C2: Other Candidate
      F: Follower (Restarted)
      
      F."readPersist() from disk"
      F."votedFor = 'Candidate'"
      
      C2 -> F: "RequestVote(term=5)"
      C2 <- F: "VoteGranted=FALSE" {
        style.stroke: red
        style.stroke-width: 2
      }
      F."Reject: Already voted\nin this term"
    }
    
    Result2: {
      style.fill: "#C8E6C9"
      label: |'md
        **Result:** Safety preserved
        - Persistence ensures Node B
        - cannot vote twice in Term 5.
      '|
    }
  }

  S2_Before -> S2_Crash: "Network Timeout"
  S2_Crash -> S2_Recovery: "Follower Restarts"
}

# ============================================
# SCENARIO 3: Network Partition
# ============================================
Scenario3: {
  label: "Scenario 3: Network Partition (Split Vote)"
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#f9f9f9"
  }

  S3_Initial: "Cluster Topology" {
    style.fill: "#E8F5E9"
    Cluster: {
      GroupA: {
        label: "Minority (Group A)"
        N1: Node 1
        N2: Node 2
        N1 <-> N2
        style.stroke: orange
      }
      GroupB: {
        label: "Majority (Group B)"
        N3: Node 3
        N4: Node 4
        N5: Node 5
        N3 <-> N4 <-> N5
        style.stroke: green
      }
    }
  }

  S3_Partition: "Election During Partition" {
    style.fill: "#FFF3E0"
    
    A_Side: {
      shape: text
      label: |'md
        **Minority Attempt:**
        - N1 becomes candidate
        - Reaches N2 (2 votes)
        - Majority required: 3
        - **Outcome:** Term timeout
      '|
    }
    
    B_Side: {
      shape: text
      label: |'md
        **Majority Attempt:**
        - N3 becomes candidate
        - Reaches N4, N5 (3 votes)
        - Majority reached!
        - **Outcome:** N3 is Leader
      '|
    }

    GroupA: Minority Side
    GroupB: Majority Side
    GroupA <-> GroupB: "PARTITION" {
      style.stroke: red
      style.stroke-dash: 5
      style.animated: true
    }
  }

  S3_Heal: "Partition Heals" {
    style.fill: "#E3F2FD"
    Convergence: {
      shape: sequence_diagram
      OldL: N1 (Term 5 Candidate)
      NewL: N3 (Term 6 Leader)
      
      NewL -> OldL: "AppendEntries(Term 6)"
      OldL."term 6 > my term 5"
      OldL."Step Down to Follower"
      OldL -> NewL: "Ack"
    }
  }

  S3_Initial -> S3_Partition: "Link Failure"
  S3_Partition -> S3_Heal: "Network Healed"
}

# ============================================
# SCENARIO 4: Stale Vote Arrival
# ============================================
Scenario4: {
  label: "Scenario 4: Stale Vote Arrival"
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#f9f9f9"
  }
  
  S4_Logic: {
    label: "Handling Delayed RPCs"
    style.fill: "#E3F2FD"
    
    CodeBlock: {
      shape: text
      label: |'go
      func (rf *Raft) handleVoteResponse(term int, reply *RequestVoteReply) {
          rf.mu.Lock()
          defer rf.mu.Unlock()

          if rf.currentTerm != term || rf.state != Candidate {
              // PROTECT: Ignore if term changed or stepped down
              return 
          }
          // Process vote...
      }
      '|
    }
  }

  S4_Sequence: {
    shape: sequence_diagram
    A: Candidate (Term 5)
    B: Follower
    C: Candidate (Term 6)
    
    A -> B: "RequestVote(T=5)"
    B."B's response is severely delayed"
    C -> B: "RequestVote(T=6)"
    C <- B: "Vote(T=6)"
    B -> A: "[Delayed] VoteGranted(T=5)"
    A."Check: currentTerm (6) != RPC term (5)"
    A."Discard Stale Vote"
  }
}

# ============================================
# SUMMARY & MATRIX
# ============================================
Summary: {
  label: "Failure Analysis Matrix"
  style: {
    fill: "#f9f9f9"
    stroke-width: 2
  }
  RecoveryMatrix: {
    shape: text
    label: |'md
      | Scenario | Detection | Recovery Mechanism | Safety Guard |
      | :--- | :--- | :--- | :--- |
      | **Candidate Crash** | Election Timeout | New election by remaining nodes | Quorum intersection |
      | **Follower Crash** | RPC Timeout | Restart + Read persistence | `votedFor` on disk |
      | **Leader Crash** | Heartbeat Timeout | Followers trigger new election | Term increments |
      | **Partition** | Lack of Quorum | Higher-term majority wins | `N/2 + 1` requirement |
      | **Stale Vote** | Term Mismatch | Term check on response arrival | `rf.currentTerm` match |
    '|
  }
  
  Invariants: {
    style.fill: "#E8F5E9"
    label: |'md
      ### Core Safety Invariants
      1. **Election Safety:** Only one leader per term.
      2. **Leader Completeness:** New leaders must have all committed entries.
      3. **Persistence:** State is flushed to disk before responding.
    '|
  }
}

# LEGEND
Legend: {
  near: bottom-right
  style.fill: "#fefefe"
  
  Key: {
    shape: text
    label: |'md
      **Color Codes:**
      - 🟢 Green: Safe / Healthy
      - 🔴 Red: Failure / Crash
      - 🔵 Blue: Recovery Path
      - 🟡 Yellow: Transient State
    '|
  }
}

# Connectivity between major blocks
Scenario1 -> Scenario2: "Next Case"
Scenario2 -> Scenario3: "Next Case"
Scenario3 -> Scenario4: "Next Case"
Scenario4 -> Summary: "Conclusion"