direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#7C3AED"
    data: "#3B82F6"
    free: "#22C55E"
    padding: "#9CA3AF"
    pointer: "#F97316"
  }
}
title: |md
  # Log Structure & Indexing Convention
| {near: top-center}
memory_layout: {
  grid-columns: 3
  grid-gap: 0
  style.fill: "#1F2937"
  style.stroke: "#374151"
  style.font-color: "#F9FAFB"
  style.font-size: 14
  header: |md
    **Logical Index**
  | {
    style.fill: ${colors.header}
    style.font-color: white
    style.bold: true
  }
  slice: |md
    **Array Index**
  | {
    style.fill: ${colors.pointer}
    style.font-color: white
    style.bold: true
  }
  entry: |md
    **Log Entry**
  | {
    style.fill: ${colors.data}
    style.font-color: white
    style.bold: true
  }
  idx_0: "0" {style.fill: ${colors.padding}; style.font-size: 16}
  idx_1: "1" {style.fill: ${colors.header}; style.font-size: 16}
  idx_2: "2" {style.fill: ${colors.header}; style.font-size: 16}
  idx_3: "3" {style.fill: ${colors.header}; style.font-size: 16}
  idx_4: "4" {style.fill: ${colors.header}; style.font-size: 16}
  idx_5: "5" {style.fill: ${colors.header}; style.font-size: 16}
  slice_0: "log[0]" {style.fill: ${colors.pointer}; style.font-size: 14}
  slice_1: "log[1]" {style.fill: ${colors.pointer}; style.font-size: 14}
  slice_2: "log[2]" {style.fill: ${colors.pointer}; style.font-size: 14}
  slice_3: "log[3]" {style.fill: ${colors.pointer}; style.font-size: 14}
  slice_4: "log[4]" {style.fill: ${colors.pointer}; style.font-size: 14}
  slice_5: "log[5]" {style.fill: ${colors.pointer}; style.font-size: 14}
  entry_0: |md
    **DUMMY**
    Term: 0
    Cmd: nil
  | {style.fill: ${colors.padding}; style.font-size: 12}
  entry_1: |md
    Term: 1
    Cmd: "set x=1"
  | {style.fill: ${colors.data}; style.font-size: 12}
  entry_2: |md
    Term: 1
    Cmd: "set y=2"
  | {style.fill: ${colors.data}; style.font-size: 12}
  entry_3: |md
    Term: 2
    Cmd: "set z=3"
  | {style.fill: ${colors.data}; style.font-size: 12}
  entry_4: |md
    Term: 2
    Cmd: "del x"
  | {style.fill: ${colors.data}; style.font-size: 12}
  entry_5: |md
    Term: 3
    Cmd: "set w=4"
  | {style.fill: ${colors.data}; style.font-size: 12}
}
note_1: |md
  **Key Insight:** log[0] is a dummy entry
  - Enables 1-indexed access per Raft paper
  - `log[i].Index == i` always holds
  - `lastLogIndex = len(log) - 1`
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#1F2937"
  style.stroke: ${colors.header}
  style.font-color: "#F9FAFB"
  style.border-radius: 8
}
note_2: |md
  **Translation:**
  - `logEntry(logicalIndex)` → `log[logicalIndex]`
  - `logLastIndex()` → `len(log) - 1`
  - When snapshot at index K:
    - New: `log[0]` = dummy
    - New: `log[1]` = old `log[K+1]`
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#1F2937"
  style.stroke: ${colors.pointer}
  style.font-color: "#F9FAFB"
  style.border-radius: 8
}