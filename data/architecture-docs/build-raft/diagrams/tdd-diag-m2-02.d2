layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F59E0B"
    free: "#10B981"
    padding: "#6B7280"
    text: "#1F2937"
    border: "#D1D5DB"
    bg: "#F9FAFB"
  }
}

direction: down

title: |md
  # AppendEntries RPC Structure & Memory Layout
  *Raft Consensus Algorithm - Protocol Specification*
| {near: top-center}

# -----------------------------------------------------------------------------
# 1. LOGICAL STRUCTURE (Grid View)
# -----------------------------------------------------------------------------
RPC_Definition: {
  grid-columns: 2
  grid-gap: 40
  style.fill: "${colors.bg}"
  style.stroke: "${colors.border}"

  args: AppendEntriesArgs {
    grid-rows: 7
    grid-gap: 0
    
    h: |md
      **AppendEntriesArgs** (Request)
    | {
      style: {
        fill: "${colors.header}"
        font-color: white
        bold: true
      }
    }
    
    f1: "0x00 | Term (int64) | 8B" { style.fill: "${colors.data}"; style.font-color: white }
    f2: "0x08 | LeaderId (string) | 16B" { style.fill: "${colors.data}"; style.font-color: white }
    f3: "0x18 | PrevLogIndex (int64) | 8B" { style.fill: "${colors.data}"; style.font-color: white }
    f4: "0x20 | PrevLogTerm (int64) | 8B" { style.fill: "${colors.data}"; style.font-color: white }
    f5: "0x28 | Entries ([]LogEntry) | 24B" { style.fill: "${colors.pointer}"; style.font-color: white }
    f6: "0x40 | LeaderCommit (int64) | 8B" { style.fill: "${colors.data}"; style.font-color: white }
  }

  reply: AppendEntriesReply {
    grid-rows: 6
    grid-gap: 0
    
    h: |md
      **AppendEntriesReply** (Response)
    | {
      style: {
        fill: "${colors.header}"
        font-color: white
        bold: true
      }
    }
    
    r1: "0x00 | Term (int64) | 8B" { style.fill: "${colors.data}"; style.font-color: white }
    r2: "0x08 | Success (bool) | 1B" { style.fill: "${colors.free}"; style.font-color: white }
    r3: "0x09 | Padding | 7B" { style.fill: "${colors.padding}"; style.font-color: white }
    r4: "0x10 | ConflictTerm (int64) | 8B" { style.fill: "${colors.data}"; style.font-color: white }
    r5: "0x18 | ConflictIndex (int64) | 8B" { style.fill: "${colors.data}"; style.font-color: white }
  }
}

# -----------------------------------------------------------------------------
# 2. FIELD SPECIFICATIONS (Implementation Detail)
# -----------------------------------------------------------------------------
Spec_Tables: {
  direction: right
  grid-columns: 1
  grid-gap: 20

  header_row: {
    grid-columns: 3
    grid-gap: 0
    h1: "**Field Name**" { style.fill: "${colors.header}"; style.font-color: white; width: 180 }
    h2: "**Type**" { style.fill: "${colors.header}"; style.font-color: white; width: 120 }
    h3: "**Implementation Logic / Invariants**" { style.fill: "${colors.header}"; style.font-color: white; width: 400 }
  }

  args_table: {
    grid-columns: 3
    grid-gap: 0
    
    f1: "Term" { style.fill: white }
    t1: "int64" { style.fill: "${colors.bg}" }
    d1: "Leader's term. Receiver updates term if Term > currentTerm."
    
    f2: "LeaderId" { style.fill: white }
    t2: "string" { style.fill: "${colors.bg}" }
    d2: "Receiver redirects clients to this ID."
    
    f3: "PrevLogIndex" { style.fill: white }
    t3: "int64" { style.fill: "${colors.bg}" }
    d3: "Index of log entry immediately preceding new ones."
    
    f4: "PrevLogTerm" { style.fill: white }
    t4: "int64" { style.fill: "${colors.bg}" }
    d4: "Term of PrevLogIndex entry. Must match receiver's log."
    
    f5: "Entries" { style.fill: white }
    t5: "[]LogEntry" { style.fill: "${colors.bg}" }
    d5: "Log entries to store (empty for heartbeat)."
    
    f6: "LeaderCommit" { style.fill: white }
    t6: "int64" { style.fill: "${colors.bg}" }
    d6: "Leader's commitIndex. Used to update follower's local commitIndex."
  }
}

# -----------------------------------------------------------------------------
# 3. NETWORK SEQUENCE & AGENTS
# -----------------------------------------------------------------------------
Network_Interaction: {
  direction: right
  
  # FIXED: Using reliable icon URLs from official documentation patterns
  leader: Raft Leader {
    shape: image
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    width: 80
    height: 80
  }
  
  follower: Raft Follower {
    shape: image
    # FIXED: Replaced 403-forbidden URL with known-good EC2 path
    icon: https://icons.terrastruct.com/aws%2FCompute%2F_Instance%2FAmazon-EC2_C4-Instance_light-bg.svg
    width: 80
    height: 80
  }

  leader -> follower: "AppendEntries(Term, LeaderId, PrevIdx, ...)" {
    style: {
      stroke: "${colors.data}"
      stroke-width: 3
      animated: true
    }
  }
  
  follower -> leader: "Success: bool, Term: int64" {
    style: {
      stroke: "${colors.free}"
      stroke-width: 2
      stroke-dash: 5
    }
  }
}

# -----------------------------------------------------------------------------
# 4. TECHNICAL ANNOTATIONS
# -----------------------------------------------------------------------------
protocol_notes: |md
  ### Log Matching Property
  1. If follower does not find entry in log with **PrevLogIndex** and **PrevLogTerm**, it must refuse new entries (`Success = false`).
  2. If an existing entry conflicts with a new one (same index but different terms), delete the existing entry and all that follow it.
  3. Append any new entries not already in the log.
  4. If `LeaderCommit > commitIndex`, set `commitIndex = min(LeaderCommit, index of last new entry)`.

  ### Optimization: Conflict Fast-Path
  Followers return `ConflictTerm` and `ConflictIndex` to allow the leader to bypass multiple failed RPCs and decrement `nextIndex` by an entire term at once.
| {
  near: bottom-center
  style: {
    fill: "#FFFBEB"
    stroke: "#F59E0B"
    stroke-width: 1
    border-radius: 8
  }
}

# Global Style Overrides
***.style.font-size: 14
***.style.font: mono