vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5F2"
    leader: "#D4EDDA"
    follower: "#D1ECF1"
    success: "#28A745"
    failure: "#DC3545"
    tracking: "#FFC107"
    text: "#495057"
  }
}

title: |md
  # nextIndex and matchIndex Tracking
  Leader-side arrays tracking follower replication progress
| {near: top-center}

direction: right

leader_election: "Step 1: Leader Election" {
  style.fill: ${colors.header}
  style.stroke: "#9B59B6"
  style.stroke-width: 2

  init_box: ||md
    **becomeLeader() initialization:**
    go
    lastLogIndex := len(log) - 1
    // Optimistic: assume followers are up-to-date
    nextIndex[i] = lastLogIndex + 1
    // Pessimistic: we know nothing yet
    matchIndex[i] = 0
    
  || {shape: text}

  init_arrays: "Initial State\n(5-node cluster)" {
    style.fill: ${colors.leader}
    arr_next: "nextIndex[]" {
      shape: sql_table
      0: int {constraint: primary_key}
      1: int {constraint: primary_key}
      2: int {constraint: primary_key}
      3: int {constraint: primary_key}
      style.fill: ${colors.tracking}
    }
    arr_match: "matchIndex[]" {
      shape: sql_table
      0: int {constraint: primary_key}
      1: int {constraint: primary_key}
      2: int {constraint: primary_key}
      3: int {constraint: primary_key}
      style.fill: ${colors.tracking}
    }
    arr_next.0: "11"
    arr_next.1: "11"
    arr_next.2: "11"
    arr_next.3: "11"
    arr_match.0: "0"
    arr_match.1: "0"
    arr_match.2: "0"
    arr_match.3: "0"
  }

  note_init: |md
    - `nextIndex`: What to send **next** (optimistic)
    - `matchIndex`: What we **know** is replicated (pessimistic)
    - Leader's log has 10 entries (lastLogIndex = 10)
    - nextIndex = 11 means "try from index 11"
  | {shape: text}
}

success_case: "Step 2: Successful AppendEntries" {
  style.fill: "#D4EDDA"
  style.stroke: ${colors.success}
  style.stroke-width: 2

  success_desc: |md
    **Follower accepts entries:**
    
    AppendEntries(prevLogIndex=10, entries=[11,12])
    Response: Success=true
  | {shape: text}

  success_update: "Update on Success" {
    style.fill: "#C3E6CB"
    update_box: ||md
      go
      // In handleAppendEntriesReply()
      matchIndex[i] = prevLogIndex + len(entries)
      // = 10 + 2 = 12
      nextIndex[i] = matchIndex[i] + 1
      // = 12 + 1 = 13
      
    || {shape: text}

    after_success: "After Success" {
      style.fill: ${colors.leader}
      arr_next2: "nextIndex[]" {
        shape: sql_table
        0: int {constraint: primary_key}
        style.fill: ${colors.tracking}
      }
      arr_match2: "matchIndex[]" {
        shape: sql_table
        0: int {constraint: primary_key}
        style.fill: ${colors.success}
        style.font-color: white
      }
      arr_next2.0: "13"
      arr_match2.0: "12"
    }
  }

  invariant: |md
    **Invariant:** `matchIndex[i] < nextIndex[i]` always
    - matchIndex = last confirmed index
    - nextIndex = next to try (matchIndex + 1)
  | {shape: text}
}

failure_case: "Step 3: AppendEntries Rejection" {
  style.fill: "#F8D7DA"
  style.stroke: ${colors.failure}
  style.stroke-width: 2

  failure_desc: |md
    **Follower rejects (log mismatch):**
    
    AppendEntries(prevLogIndex=10, prevLogTerm=3)
    Response: Success=false
             ConflictTerm=2
             ConflictIndex=5
  | {shape: text}

  failure_update: "Update on Failure" {
    style.fill: "#F5C6CB"
    update_box2: ||md
      go
      // handleRejection() with optimization
      if reply.ConflictTerm >= 0 {
        // Search leader log for ConflictTerm
        idx := findLastIndexOfTerm(reply.ConflictTerm)
        if idx >= 0 {
          nextIndex[i] = idx + 1
          // = 5 + 1 = 6
        } else {
          nextIndex[i] = reply.ConflictIndex
        }
      }
      // matchIndex NOT updated on failure!
      
    || {shape: text}

    after_failure: "After Rejection" {
      style.fill: ${colors.leader}
      arr_next3: "nextIndex[]" {
        shape: sql_table
        0: int {constraint: primary_key}
        style.fill: ${colors.failure}
        style.font-color: white
      }
      arr_match3: "matchIndex[]" {
        shape: sql_table
        0: int {constraint: primary_key}
        style.fill: ${colors.tracking}
      }
      arr_next3.0: "6"
      arr_match3.0: "0"
    }
  }

  note_failure: |md
    **Key insight:**
    - `nextIndex` decremented (optimistic → reality)
    - `matchIndex` unchanged (still don't know)
    - Optimization skips many round trips
  | {shape: text}
}

follower_logs: "Follower Log States Over Time" {
  style.fill: ${colors.follower}
  style.stroke: "#17A2B8"
  style.stroke-width: 2

  follower_a: "Follower A\n(Caught Up)" {
    style.fill: "#CCE5FF"
    log_a: "Log State" {
      shape: sequence_diagram
      style.fill: transparent
      T1: "Term 1"
      T2: "Term 2"
      T3: "Term 3"
      T1 -> T2: "indices 1-4"
      T2 -> T3: "indices 5-8"
      T3 -> T3: "indices 9-12"
    }
    state_a: |md
      - matchIndex[A] = 12 ✓
      - nextIndex[A] = 13
      - Fully synchronized
    | {shape: text}
  }

  follower_b: "Follower B\n(Divergent Log)" {
    style.fill: "#FFF3CD"
    log_b: "Log State" {
      entries_b: "Entries" {
        shape: sql_table
        idx: int
        term: int
        style.fill: ${colors.failure}
        style.font-color: white
      }
      entries_b.idx: "1,2,3,4,5,6,7,8"
      entries_b.term: "1,1,1,2,2,2,2,2"
    }
    state_b: |md
      - matchIndex[B] = 0 ✗
      - nextIndex[B] = 6 (after backtrack)
      - Divergent at index 5
      - Needs entries 6-12 after sync
    | {shape: text}
  }

  follower_c: "Follower C\n(Stale/Behind)" {
    style.fill: "#D6D8DB"
    log_c: "Log State" {
      entries_c: "Entries" {
        shape: sql_table
        idx: int
        term: int
        style.fill: "#6C757D"
        style.font-color: white
      }
      entries_c.idx: "1,2,3,4,5"
      entries_c.term: "1,1,1,2,2"
    }
    state_c: |md
      - matchIndex[C] = 5
      - nextIndex[C] = 6
      - Missing entries 6-12
      - No divergence, just behind
    | {shape: text}
  }
}

tracking_summary: "Leader Tracking Arrays (Final)" {
  style.fill: ${colors.header}
  style.stroke: "#6F42C1"
  style.stroke-width: 3

  final_arrays: "Complete State" {
    style.fill: ${colors.leader}
    final_next: "nextIndex[]" {
      shape: sql_table
      follower: string {constraint: primary_key}
      value: int
      style.fill: ${colors.tracking}
    }
    final_match: "matchIndex[]" {
      shape: sql_table
      follower: string {constraint: primary_key}
      value: int
      style.fill: "#6C757D"
      style.font-color: white
    }
    final_next.follower: "A, B, C"
    final_next.value: "13, 6, 6"
    final_match.follower: "A, B, C"
    final_match.value: "12, 0, 5"
  }

  leader_log: "Leader Log" {
    entries_leader: "Log (indices 1-12)" {
      shape: sql_table
      idx: int
      term: int
      style.fill: "#28A745"
      style.font-color: white
    }
    entries_leader.idx: "1-4, 5-8, 9-12"
    entries_leader.term: "T1, T2, T3"
  }

  summary: ||md
    **Tracking Array Semantics:**
    | Array | Meaning | Update Trigger |
    |-------|---------|----------------|
    | `nextIndex[i]` | Next entry to send | Init: lastLog+1; Decr: rejection; Incr: success |
    | `matchIndex[i]` | Last confirmed replicated | Init: 0; Update: AE success only |
    
    **Use in Commit Advancement:**
    go
    for N := lastLogIndex; N > commitIndex; N-- {
      if log[N].Term != currentTerm { continue }
      count := 1 // leader
      for i := range matchIndex {
        if matchIndex[i] >= N { count++ }
      }
      if count >= majority {
        commitIndex = N
        break
      }
    }
    
  || {shape: text}
}

leader_election -> success_case: "Follower A\naccepts" {style.stroke: ${colors.success}; style.stroke-width: 2}
leader_election -> failure_case: "Follower B\nrejects" {style.stroke: ${colors.failure}; style.stroke-width: 2; style.stroke-dash: 3}
success_case -> follower_logs.follower_a: "state matches" {style.stroke: ${colors.success}; style.stroke-dash: 2}
failure_case -> follower_logs.follower_b: "backtrack needed" {style.stroke: ${colors.failure}; style.stroke-dash: 2}
follower_logs -> tracking_summary: "aggregate\ntracking" {style.stroke: "#6F42C1"; style.stroke-width: 2}