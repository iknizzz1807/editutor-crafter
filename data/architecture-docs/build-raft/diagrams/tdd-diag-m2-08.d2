vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

title: |md
  # Raft Replication Data Flow (Implementation Specification)
  **Workflow Lifecycle:** Client Request → Local Log Append → Parallel Peer RPCs → Quorum Calculation → Global Commit → State Machine Apply
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    font-color: "#1A237E"
  }
}

# --- ACTORS & NODES ---

Client: {
  shape: person
  label: "External Client\n[gRPC/HTTP]"
  icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

Leader: "Raft Leader (Node 1)" {
  tooltip: "Current Cluster Primary"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 3
    double-border: true
  }

  SubmitCommand: {
    shape: rectangle
    label: "SubmitCommand(cmd)\n[Entry Point]"
    style: {
      fill: "#BBDEFB"
      bold: true
      stroke: "#1976D2"
    }
  }

  Log: "Replicated Log [Memory/Disk]" {
    shape: sql_table
    style.fill: "#90CAF9"
    style.stroke: "#1565C0"
    
    Index_0: "Idx: 0 | Term: 1 | Cmd: Set X=1"
    Index_1: "Idx: 1 | Term: 1 | Cmd: Set Y=2"
    Index_2: "Idx: 2 | Term: 2 | Cmd: Set Z=3 [NEW]" {
      style: {
        fill: "#42A5F5"
        bold: true
        font-color: white
      }
    }
  }

  PendingMap: {
    shape: cylinder
    label: "pendingCommands\nMap[LogIndex → chan Result]"
    style.fill: "#64B5F6"
    style.font: mono
  }

  SubmitCommand -> Log.Index_2: "1. Append to Log\n[Uncommitted State]" {
    style.stroke: "#1976D2"
    style.bold: true
  }
  Log.Index_2 -> PendingMap: "2. Track Client\nResponse Channel" {
    style.stroke-dash: 3
    style.stroke: "#1976D2"
  }
}

Replication: "Parallel Replication Layer" {
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
    stroke-dash: 4
    stroke-width: 2
  }

  Follower2: "Node 2 [Follower]\nStatus: Healthy" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FB8C00"
  }
  Follower3: "Node 3 [Follower]\nStatus: Healthy" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FB8C00"
  }
  Follower4: "Node 4 [Follower]\nStatus: Slow/Lagging" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FB8C00"
  }
  Follower5: "Node 5 [Zombie]\nStatus: Partitioned" {
    shape: rectangle
    style.fill: "#BDBDBD"
    style.opacity: 0.4
    style.stroke: "#757575"
  }
}

QuorumCheck: {
  shape: diamond
  label: "Majority\n(N/2 + 1)\nACKed?"
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    bold: true
    stroke-width: 2
  }
}

Commit: "Commitment Pipeline" {
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }

  AdvanceCommit: "Update commitIndex" {
    shape: rectangle
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      bold: true
    }
  }

  Figure8: "Safety Verification\n(Log[N].Term == Current)" {
    shape: rectangle
    style: {
      fill: "#CE93D8"
      stroke: "#7B1FA2"
      stroke-dash: 2
      font: mono
    }
  }

  AdvanceCommit -> Figure8: "Final Validation" {
    style.stroke: "#7B1FA2"
  }
}

Apply: "State Machine Engine" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
  }

  ApplyLoop: "Application Loop\n(lastApplied < commitIndex)" {
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      bold: true
    }
  }

  KVStore: "KV Store Provider\nApply(Set Z=3)" {
    shape: cylinder
    style: {
      fill: "#EF9A9A"
      stroke: "#B71C1C"
      font-size: 14
    }
  }

  Notify: "Signal Response\n(chan <- Success)" {
    shape: rectangle
    style: {
      fill: "#E57373"
      stroke: "#B71C1C"
    }
  }

  ApplyLoop -> KVStore: "Invoke Callback"
  KVStore -> Notify: "Execution Result"
}

Response: {
  shape: rectangle
  label: "RPC Response Object\n{ Success: true, Term: 2 }"
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 4
  }
}

# --- SYSTEM WIRING ---

Client -> Leader.SubmitCommand: "RPC Request (Command)" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

Leader.Log -> Replication: "3. AppendEntries RPCs\n(Broadcast in Parallel)" {
  style: {
    stroke: "#1976D2"
    stroke-width: 2
    animated: true
  }
}

Replication.Follower2 -> QuorumCheck: "ACK (Index 2)"
Replication.Follower3 -> QuorumCheck: "ACK (Index 2)"
Replication.Follower4 -> QuorumCheck: "ACK (Index 2)"

QuorumCheck -> Commit.AdvanceCommit: "YES (Quorum Met)" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  label: "4. Persist commitIndex"
}

Commit -> Apply.ApplyLoop: "5. Signal applyCond\n(Async Apply)" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  style.animated: true
}

Apply.Notify -> Response: "6. Resolve Promise/Channel" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}

Response -> Client: "Return Final Result" {
  style: {
    stroke: "#2E7D32"
    stroke-dash: 5
    stroke-width: 2
  }
}

# --- DOCUMENTATION OVERLAYS ---

# Fixed: Using constant position for ELK compatibility
Invariants: |md
  ### Raft Cluster Invariants
  - **Leader Completeness**: Committed entries must persist across leader elections.
  - **State Machine Safety**: One entry per index across all machines.
  - **Sequential Application**: `lastApplied` strictly monotonic; entries applied in index order.
  - **Safety Threshold**: Majority Quorum (N/2 + 1) required for progress.
| {
  near: bottom-left
  shape: text
  style: {
    font-size: 14
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
    border-radius: 10
    font-color: "#424242"
  }
}

# --- DIAGRAM LEGEND ---

Legend: {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#BDBDBD"
  style.stroke-width: 1
  style.shadow: true

  AnimatedLine: {
    shape: rectangle
    label: "══▶ Active Network Flow"
    style.animated: true
    style.stroke: "#1976D2"
    width: 160
  }
  
  DashedLine: {
    shape: rectangle
    label: "--- Internal Async Signaling"
    style.stroke-dash: 4
    style.stroke: "#7B1FA2"
    width: 160
  }
  
  SafetyCheck: {
    shape: rectangle
    label: "Box with Dash = Safety Logic"
    style.stroke-dash: 2
    style.fill: "#CE93D8"
    width: 160
  }
}