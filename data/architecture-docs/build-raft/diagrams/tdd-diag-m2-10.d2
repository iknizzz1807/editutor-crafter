vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Leader Failover Sequence (Raft Consensus)
  *Engineering Specification: Module 2, Failover Transition*
  *States: S1 (Follower), S2 (Candidate), S3 (Leader)*
'| {
  near: top-center
  style.font-size: 32
}

# --- STYLING CLASSES ---
classes: {
  leader_node: {
    style: {
      fill: "#D5F5E3"
      stroke: "#229954"
      stroke-width: 4
      double-border: true
    }
  }
  follower_node: {
    style: {
      fill: "#EBF5FB"
      stroke: "#2E86C1"
      stroke-width: 2
    }
  }
  candidate_node: {
    style: {
      fill: "#FEF9E7"
      stroke: "#D4AC0D"
      stroke-width: 3
      stroke-dash: 3
    }
  }
  failed_node: {
    style: {
      fill: "#FADBD8"
      stroke: "#CB4335"
      stroke-width: 2
      opacity: 0.6
    }
  }
  call: {
    style: {
      font-size: 14
      font-color: "#1B2631"
      stroke: "#2E4053"
    }
  }
}

# --- PARTICIPANTS ---
raft_sequence: {
  shape: sequence_diagram
  
  User: {
    shape: person
    style.fill: "#FDFEFE"
  }
  L1: "Leader (Node A)" {
    class: leader_node
    tooltip: "Term 3 Leader"
  }
  F1: "Follower (Node B)" {
    class: follower_node
    tooltip: "Target Successor"
  }
  F2: "Follower (Node C)" {
    class: follower_node
  }
  F3: "Follower (Node D)" {
    class: follower_node
  }
  F4: "Follower (Node E)" {
    class: follower_node
  }

  # --- PHASE 1: NORMAL OPS ---
  Phase_1: "Normal Operation (Term 3)" {
    User -> L1: "Submit(cmd_1..50)" { class: call }
    L1 -> F1: "AppendEntries(T:3, prev:44, entries:[45-50])"
    L1 -> F2: "AppendEntries(T:3, prev:44, entries:[45-50])"
    L1 -> F3: "AppendEntries(T:3, prev:44, entries:[45-50])"
    L1 -> F4: "AppendEntries(T:3, prev:44, entries:[45-50])"
    
    L1 <- F1: "Success(matchIdx:50)"
    L1 <- F2: "Success(matchIdx:50)"
    L1 <- F3: "Success(matchIdx:48)"
    L1 <- F4: "Success(matchIdx:50)"

    L1.Commit: "commitIndex = 50" {
      style.font-color: green
      style.bold: true
    }
  }

  # --- PHASE 2: CRASH ---
  Phase_2: "Leader Failure" {
    L1: { class: failed_node }
    L1.Crash: "*** CRASH (Node A Unreachable) ***" {
      style: {
        fill: "#E74C3C"
        font-color: white
        bold: true
      }
    }
    
    F1.note_crash: |'md
      **Timeout Path:**
      Heartbeats cease.
      Followers start 
      randomized election 
      timers (150-300ms).
    '|
  }

  # --- PHASE 3: ELECTION ---
  Phase_3: "Election (Term 4)" {
    F1: { class: candidate_node }
    F1.Timeout: "Election Timeout Triggered"
    F1.Incr: "**Term = 4**" { style.font-color: red }
    
    F1 -> F2: "RequestVote(term:4, lastLogIdx:50, lastLogTerm:3)"
    F1 -> F3: "RequestVote(term:4, lastLogIdx:50, lastLogTerm:3)"
    F1 -> F4: "RequestVote(term:4, lastLogIdx:50, lastLogTerm:3)"
    
    F1 <- F2: "VoteGranted(true)"
    F1 <- F3: "VoteGranted(true)" 
    F1 <- F4: "VoteGranted(true)"
  }

  # --- PHASE 4: NEW LEADER ---
  Phase_4: "New Leader Established" {
    F1: { class: leader_node }
    F1.Claim: "Majority (4/5) Recv"
    
    # Raft Requirement: No-op for commit safety
    F1 -> F2: "AppendEntries(term:4, entries:[No-Op])"
    F1 -> F3: "AppendEntries(term:4, entries:[No-Op])"
    F1 -> F4: "AppendEntries(term:4, entries:[No-Op])"
    
    F1 <- F2: "Success"
    F1 <- F4: "Success"
    F1.Comm: "**commitIndex = 51**" { style.bold: true }
  }

  # --- PHASE 5: RECOVERY ---
  Phase_5: "Catch-up Lagging Followers" {
    F1 -> F3: "AppendEntries(prevIdx:50, prevTerm:3)"
    F1 <- F3: "Conflict(Reject, matchIdx:48)"
    
    F1.Adjust: "nextIndex[F3] = 49"
    
    F1 -> F3: "AppendEntries(prevIdx:48, entries:[49,50,51])"
    F1 <- F3: "Success(matchIdx:51)"
  }
}

# --- DOCUMENTATION OVERLAYS ---

summary: {
  label: |'md
    ## Failover Protocol Analysis
    
    ### 1. Safety Analysis
    - **Election Safety:** F1 elected because its log is at least as up-to-date as the majority.
    - **Leader Completeness:** Entry 50 (Term 3) was committed by Node A and exists on F1, F2, F4. F1 ensures it is never overwritten.
    - **Log Matching:** Phase 5 shows the consistency check and back-step mechanism for lagging Node D.
    
    ### 2. State Transition
    - **T+0ms:** Leader Crashes
    - **T+150ms:** F1 transitions Follower ➔ Candidate
    - **T+165ms:** F1 transitions Candidate ➔ Leader (Term 4)
  '|
  style: {
    fill: "#F4F6F7"
    stroke: "#7F8C8D"
    border-radius: 10
  }
  near: bottom-center
}

legend: {
  label: |'md
    ### Legend & Symbols
    | Shape | Meaning |
    | :--- | :--- |
    | 🟢 **Double Border** | Active Leader |
    | 🔵 **Solid Blue** | Active Follower |
    | 🟡 **Dashed Yellow** | Candidate State |
    | 🔴 **Muted Red** | Failed/Offline |
    | **AE** | AppendEntries RPC |
    | **RV** | RequestVote RPC |
  '|
  style: {
    fill: "#FFFFFF"
    stroke: "#ABB2B9"
    border-radius: 5
  }
  near: bottom-right
}

# --- GLOBAL STYLING OVERRIDE ---
(raft_sequence.** -> raft_sequence.**)[*]: {
  style: {
    # CORRECTED: stroke-width must be an integer between 0 and 15
    stroke-width: 2
    font-size: 13
  }
}