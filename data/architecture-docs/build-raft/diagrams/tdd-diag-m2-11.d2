vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## Follower Restart Catch-Up Sequence
  Timeline: killed follower restarts, recovers from disk, catches up via AppendEntries
| {near: top-center}

direction: right

# Timeline phases
step1: {
  label: "1. Normal Operation"
  leader_t1: Leader {
    style: {
      fill: "#B6DDF6"
      stroke: "#4A90D9"
    }
    log_t1: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6]
      commitIndex=6
      
    |
  }
  followerA_t1: Follower A {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    logA_t1: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6]
      commitIndex=6
      
    |
  }
  followerB_t1: Follower B {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    logB_t1: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4]
      commitIndex=4
      
    |
  }
  disk_t1: Disk {
    shape: cylinder
    style: {
      fill: "#E8E8E8"
      stroke: "#666"
    }
    persist_t1: |md
      **Persisted**
      
      term=2, votedFor=""
      log=[1:1][1:2][1:3][2:4]
      lastIncludedIndex=0
      
    |
  }
  leader_t1 -> followerA_t1: "AppendEntries\nentries: [2:5][2:6]"
  leader_t1 -> followerB_t1: "AppendEntries\nentries: [2:5][2:6]"
  followerB_t1 -> disk_t1: "persist()" {
    style: {
      stroke-dash: 3
    }
  }
}

step2: {
  label: "2. Follower B Killed"
  leader_t2: Leader {
    style: {
      fill: "#B6DDF6"
      stroke: "#4A90D9"
    }
    log_t2: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      
    |
  }
  followerA_t2: Follower A {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    logA_t2: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      
    |
  }
  followerB_t2: Follower B {
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
      stroke-width: 3
      opacity: 0.5
    }
    dead_label: |md
      **💀 CRASHED**
      
      Process killed
      In-memory state lost
      
    |
  }
  disk_t2: Disk {
    shape: cylinder
    style: {
      fill: "#E8E8E8"
      stroke: "#666"
    }
    persist_t2: |md
      **Persisted (Intact)**
      
      term=2, votedFor=""
      log=[1:1][1:2][1:3][2:4]
      lastIncludedIndex=0
      
    |
  }
  leader_t2 -> followerA_t2: "AppendEntries\nentries: [2:7][2:8]"
  leader_t2 -> followerB_t2: "❌ RPC timeout" {
    style: {
      stroke: red
      stroke-dash: 5
    }
  }
  disk_t2 -- followerB_t2: "survives crash" {
    style: {
      stroke-dash: 3
      stroke: green
    }
  }
}

step3: {
  label: "3. Follower B Restarts"
  leader_t3: Leader {
    style: {
      fill: "#B6DDF6"
      stroke: "#4A90D9"
    }
    log_t3: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      nextIndex[B] = 9
      
    |
  }
  followerA_t3: Follower A {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    logA_t3: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      
    |
  }
  followerB_t3: Follower B {
    style: {
      fill: "#FFF9C4"
      stroke: "#FFA000"
      stroke-width: 3
    }
    restart_label: |md
      **🔄 RESTARTING**
      
      readPersist() from disk
      Restore: term=2, log=[1:1..2:4]
      State: Follower
      commitIndex=4
      
    |
  }
  disk_t3: Disk {
    shape: cylinder
    style: {
      fill: "#E8E8E8"
      stroke: "#666"
    }
    persist_t3: |md
      **Reading...**
      
      term=2, votedFor=""
      log=[1:1][1:2][1:3][2:4]
      
    |
  }
  disk_t3 -> followerB_t3: "restore state" {
    style: {
      stroke: purple
      bold: true
    }
  }
}

step4: {
  label: "4. Leader Sends AppendEntries"
  leader_t4: Leader {
    style: {
      fill: "#B6DDF6"
      stroke: "#4A90D9"
    }
    log_t4: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      nextIndex[B] = 5
      
    |
  }
  followerA_t4: Follower A {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    logA_t4: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      
    |
  }
  followerB_t4: Follower B {
    style: {
      fill: "#FFF9C4"
      stroke: "#FFA000"
    }
    logB_t4: |md
      **Log State (Behind)**
      
      [1:1][1:2][1:3][2:4]
      commitIndex=4
      lastApplied=4
      
    |
  }
  ae_args: AppendEntries {
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
    }
    args_content: |md
      **Args**
      
      term=2
      prevLogIndex=4
      prevLogTerm=2
      entries=[2:5][2:6][2:7][2:8]
      leaderCommit=8
      
    |
  }
  leader_t4 -> ae_args: "construct" {
    style: {
      stroke-dash: 3
    }
  }
  ae_args -> followerB_t4: "RPC" {
    style: {
      stroke: "#7B1FA2"
      bold: true
    }
  }
}

step5: {
  label: "5. Consistency Check Passes"
  leader_t5: Leader {
    style: {
      fill: "#B6DDF6"
      stroke: "#4A90D9"
    }
    log_t5: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      
    |
  }
  followerA_t5: Follower A {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    logA_t5: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      
    |
  }
  followerB_t5: Follower B {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    check_label: |md
      **Consistency Check**
      
      prevLogIndex=4 ✓
      log[4].term=2 ✓
      prevLogTerm=2 ✓
      → Append entries [2:5..2:8]
      → persist()
      → commitIndex=8
      
    |
  }
  ae_reply: AppendEntriesReply {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    reply_content: |md
      **Reply**
      
      term=2
      success=true
      
    |
  }
  followerB_t5 -> ae_reply: "response"
  ae_reply -> leader_t5: {
    style: {
      stroke: green
      bold: true
    }
  }
}

step6: {
  label: "6. Catch-Up Complete"
  leader_t6: Leader {
    style: {
      fill: "#B6DDF6"
      stroke: "#4A90D9"
    }
    log_t6: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      matchIndex[B]=8 ✓
      
    |
  }
  followerA_t6: Follower A {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    logA_t6: |md
      **Log State**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      lastApplied=8
      
    |
  }
  followerB_t6: Follower B {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
      stroke-width: 3
    }
    final_label: |md
      **✅ CAUGHT UP**
      
      [1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      commitIndex=8
      lastApplied=8
      All entries replicated!
      
    |
  }
  disk_t6: Disk {
    shape: cylinder
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    persist_t6: |md
      **Persisted**
      
      term=2, votedFor=""
      log=[1:1][1:2][1:3][2:4][2:5][2:6][2:7][2:8]
      
    |
  }
  followerB_t6 -> disk_t6: "persist()" {
    style: {
      stroke: green
    }
  }
}

# Flow arrows between steps
step1 -> step2: "Node B killed" {
  style: {
    stroke: red
    bold: true
  }
}
step2 -> step3: "Restart" {
  style: {
    stroke: orange
    bold: true
  }
}
step3 -> step4: "Recovery" {
  style: {
    stroke: purple
  }
}
step4 -> step5: "RPC" {
  style: {
    stroke: "#7B1FA2"
  }
}
step5 -> step6: "Apply" {
  style: {
    stroke: green
    bold: true
  }
}

# Legend
legend: {
  near: bottom-center
  legend_title: Legend
  l1: Leader {
    style: {
      fill: "#B6DDF6"
    }
  }
  l2: Healthy Follower {
    style: {
      fill: "#C8E6C9"
    }
  }
  l3: Recovering {
    style: {
      fill: "#FFF9C4"
    }
  }
  l4: Dead {
    style: {
      fill: "#FFCDD2"
      opacity: 0.5
    }
  }
  l5: Disk {
    shape: cylinder
    style: {
      fill: "#E8E8E8"
    }
  }
}