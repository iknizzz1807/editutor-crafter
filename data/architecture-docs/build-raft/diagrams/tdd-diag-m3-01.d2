vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B59B6"
    data: "#3498DB"
    metadata: "#27AE60"
    pointer: "#E67E22"
    padding: "#95A5A6"
    free: "#2ECC71"
    text: "#2C3E50"
  }
}
title: |md
  # Snapshot Structure
  Point-in-time capture of state machine state
| {near: top-center}
direction: right
snapshot_format: {
  label: "Snapshot File Format"
  header_row: {
    shape: rectangle
    label: |md
      **Snapshot File Layout (JSON with binary data)**
    |
    style.fill: transparent
    style.stroke: transparent
  }
  magic: {
    label: |md
      **Magic**
      Offset: 0x00
      Size: 4 bytes
      Value: "RAFT" (0x52414654)
    |
    style.fill: ${colors.header}
    style.stroke: ${colors.text}
    width: 200
  }
  version: {
    label: |md
      **Version**
      Offset: 0x04
      Size: 4 bytes
      Format version = 1
    |
    style.fill: ${colors.header}
    style.stroke: ${colors.text}
    width: 200
  }
  metadata_len: {
    label: |md
      **MetadataLen**
      Offset: 0x08
      Size: 4 bytes
      Length of JSON metadata
    |
    style.fill: ${colors.metadata}
    style.stroke: ${colors.text}
    width: 200
  }
  metadata: {
    label: |md
      **Metadata (JSON)**
      Offset: 0x0C
      Size: M bytes
      json
      {
        "lastIncludedIndex": 10000,
        "lastIncludedTerm": 5
      }
      
    |
    style.fill: ${colors.metadata}
    style.stroke: ${colors.text}
    width: 200
    height: 160
  }
  data_len: {
    label: |md
      **DataLen**
      Offset: 0x0C+M
      Size: 4 bytes
      Length of snapshot data
    |
    style.fill: ${colors.data}
    style.stroke: ${colors.text}
    width: 200
  }
  data: {
    label: |md
      **Data (State Machine)**
      Offset: 0x10+M
      Size: D bytes
      Application-specific
      serialized state
    |
    style.fill: ${colors.data}
    style.stroke: ${colors.text}
    width: 200
    height: 120
  }
  checksum: {
    label: |md
      **Checksum**
      Offset: 0x10+M+D
      Size: 4 bytes
      CRC32 of all bytes
    |
    style.fill: ${colors.padding}
    style.stroke: ${colors.text}
    width: 200
  }
  total: {
    label: |md
      **Total: 20 + M + D bytes**
    |
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 14
    style.bold: true
  }
  header_row -> magic -> version -> metadata_len -> metadata -> data_len -> data -> checksum -> total
}
metadata_struct: {
  label: "SnapshotMetadata Struct"
  struct_def: {
    shape: class
    label: ""
    lastIncludedIndex: "int `json:\"lastIncludedIndex\"`"
    lastIncludedTerm: "int `json:\"lastIncludedTerm\"`"
  }
  struct_def.style.fill: ${colors.metadata}
  struct_def.style.stroke: ${colors.text}
  desc: |md
    **Raft-specific metadata**
    - `lastIncludedIndex`: Index of last log entry in snapshot
    - `lastIncludedTerm`: Term of entry at lastIncludedIndex
    Both fields are CRITICAL for:
    - Log offset translation
    - AppendEntries consistency check at boundary
  |
  style.fill: transparent
  style.stroke: transparent
}
snapshot_struct: {
  label: "Snapshot Struct (Go)"
  go_struct: {
    shape: class
    label: ""
    Metadata: "SnapshotMetadata"
    Data: "[]byte"
  }
  go_struct.style.fill: ${colors.header}
  go_struct.style.stroke: ${colors.text}
  desc: |md
    **Complete snapshot structure**
    go
    type Snapshot struct {
        Metadata SnapshotMetadata
        Data     []byte  // State machine state
    }
    
    - `Metadata`: Raft protocol info
    - `Data`: Opaque to Raft (application-defined)
  |
  style.fill: transparent
  style.stroke: transparent
}
byte_example: {
  label: "Example: Snapshot at Index 100"
  example_box: {
    shape: rectangle
    label: |md
      
      Offset    Hex Bytes              ASCII/Value
      ─────────────────────────────────────────────
      0x00      52 41 46 54            "RAFT"
      0x04      01 00 00 00            version=1
      0x08      26 00 00 00            metaLen=38
      0x0C      7B 22 6C 61 73 74...   {"lastIncludedIndex":...
                49 6E 63 6C 75 64...
                65 64 49 6E 64 65...
                78 22 3A 31 30 30...
                2C 22 6C 61 73 74...
                49 6E 63 6C 75 64...
                65 64 54 65 72 6D...
                22 3A 31 7D          ...,"lastIncludedTerm":1}
      0x2E      04 00 00 00            dataLen=4
      0x32      74 65 73 74            "test"
      0x36      XX XX XX XX            CRC32
      
    |
    style.fill: "#1E1E1E"
    style.font-color: "#D4D4D4"
    style.font: mono
    style.stroke: ${colors.text}
    width: 420
  }
}
legend: {
  label: "Field Legend"
  header_legend: {
    label: "Header\nMagic + Version"
    style.fill: ${colors.header}
    style.stroke: ${colors.text}
    width: 120
    height: 50
  }
  meta_legend: {
    label: "Metadata\nRaft protocol info"
    style.fill: ${colors.metadata}
    style.stroke: ${colors.text}
    width: 120
    height: 50
  }
  data_legend: {
    label: "Data\nState machine state"
    style.fill: ${colors.data}
    style.stroke: ${colors.text}
    width: 120
    height: 50
  }
  padding_legend: {
    label: "Checksum\nCRC32 integrity"
    style.fill: ${colors.padding}
    style.stroke: ${colors.text}
    width: 120
    height: 50
  }
  header_legend -> meta_legend -> data_legend -> padding_legend
}
atomicity: {
  label: "Atomic Write Pattern"
  step1: {
    label: |md
      **Step 1: Write to temp file**
      
      raft-snapshot.bin.tmp
      
    |
    style.fill: ${colors.data}
    style.stroke: ${colors.text}
    width: 180
  }
  step2: {
    label: |md
      **Step 2: fsync temp file**
      Ensures data reaches disk
    |
    style.fill: ${colors.metadata}
    style.stroke: ${colors.text}
    width: 180
  }
  step3: {
    label: |md
      **Step 3: Atomic rename**
      
      .tmp → raft-snapshot.bin
      
    |
    style.fill: ${colors.header}
    style.stroke: ${colors.text}
    width: 180
  }
  step4: {
    label: |md
      **Step 4: fsync directory**
      Ensures rename is durable
    |
    style.fill: ${colors.pointer}
    style.stroke: ${colors.text}
    width: 180
  }
  step1 -> step2 -> step3 -> step4
}
invariants: {
  label: "Invariants"
  inv_box: |md
    **Critical Properties:**
    1. **Atomicity**: Snapshot is persisted BEFORE log truncation
       - Crash recovery: old log OR new snapshot exists
       - Never partial/corrupt state
    2. **Consistency**: `lastIncludedIndex` matches actual coverage
       - Snapshot represents entries 1..lastIncludedIndex
       - Log contains entries lastIncludedIndex+1..N
    3. **Recoverability**: State machine can restore from Data field
       - Application implements `RestoreSnapshot([]byte) error`
       - Session state included for deduplication continuity
  |
  style.fill: "#F8F9FA"
  style.stroke: ${colors.text}
  style.stroke-width: 2
}
snapshot_format -> metadata_struct
metadata_struct -> snapshot_struct
snapshot_struct -> byte_example
byte_example -> legend
legend -> atomicity
atomicity -> invariants