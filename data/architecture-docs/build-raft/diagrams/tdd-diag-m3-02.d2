vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: |'md'
    # Log Indexing with Snapshot Offset
    ### Logical-to-Physical Index Translation via `lastIncludedIndex` Subtraction
    **sizeof(LogEntry) = 24 bytes (8B Term + 16B Command Interface)**
  '|
  near: top-center
}

# -----------------------------------------------------------------------------------------
# CLASSES & STYLES
# -----------------------------------------------------------------------------------------
classes: {
  mem_header: {
    style: {
      fill: "#9C27B0"
      font-color: white
      bold: true
    }
  }
  log_data: {
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      font: mono
    }
  }
  metadata: {
    style: {
      fill: "#E0E0E0"
      stroke: "#757575"
      font: mono
    }
  }
  code_block: {
    style: {
      fill: "#263238"
      font-color: "#ECEFF1"
      font: mono
    }
  }
}

# -----------------------------------------------------------------------------------------
# BEFORE SNAPSHOT STATE
# -----------------------------------------------------------------------------------------
before_snapshot: {
  label: "STATE A: BEFORE SNAPSHOT (lastIncludedIndex = 0)"
  style: {
    fill: "#F1F8E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }

  header: "Memory Layout: rf.log[]" { class: mem_header }

  log_array: {
    grid-columns: 1
    grid-gap: 5
    
    e0: "offset 0x00 | [0] Sentinel (T:0) | 24B" { class: metadata }
    e1: "offset 0x18 | [1] Cmd: A (T:1)    | 24B" { class: log_data }
    e2: "offset 0x30 | [2] Cmd: B (T:1)    | 24B" { class: log_data }
    e3: "offset 0x48 | [3] Cmd: C (T:1)    | 24B" { class: log_data }
    e4: "offset 0x60 | [4] Cmd: D (T:2)    | 24B" { class: log_data }
    e5: "offset 0x78 | [5] Cmd: E (T:2)    | 24B" { class: log_data }
    
    # Cache line indicators (64B boundary)
# REMOVED (reserved keyword in edge):     e0 -> e1.style.stroke-dash: 2
# REMOVED (reserved keyword in edge):     e2 -> e3.style.stroke-dash: 2
  }

  indices: {
    label: "Index Mapping"
    logical: "Logical: [0, 1, 2, 3, 4, 5]" { style.font-color: "#1565C0" }
    physical: "Physical: [0, 1, 2, 3, 4, 5]" { style.font-color: "#D84315" }
  }
  
  translation: "Formula: sliceIdx = logicalIdx - 0" {
    style: { bold: true; fill: "#FFF3E0"; stroke: "#FF9800" }
  }
}

# -----------------------------------------------------------------------------------------
# TRANSITION STEP
# -----------------------------------------------------------------------------------------
step_compact: "1. Snapshot & Compact up to Index 3" {
  shape: parallelogram
  style: {
    fill: "#FFECB3"
    stroke: "#FF8F00"
    bold: true
  }
}

# -----------------------------------------------------------------------------------------
# AFTER SNAPSHOT STATE
# -----------------------------------------------------------------------------------------
after_snapshot: {
  label: "STATE B: AFTER SNAPSHOT (lastIncludedIndex = 3)"
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
    stroke-width: 2
  }

  snapshot_file: "SNAPSHOT BINARY (Indices 1..3)" {
    shape: cylinder
    style: { fill: "#F8BBD0"; double-border: true }
  }

  log_array: {
    grid-columns: 1
    grid-gap: 5

    e0: "offset 0x00 | [0] Metadata (T:1) | 24B" { 
      class: metadata
      style.stroke: "#D32F2F"
      style.stroke-width: 3
    }
    e1: "offset 0x18 | [1] Cmd: D (T:2)    | 24B" { class: log_data }
    e2: "offset 0x30 | [2] Cmd: E (T:2)    | 24B" { class: log_data }
  }

  indices: {
    label: "Translation Mapping (Offset)"
    logical: "Logical: [3, 4, 5]" { style.font-color: "#1565C0" }
    physical: "Physical: [0, 1, 2]" { style.font-color: "#D84315" }
  }

  translation: "Formula: sliceIdx = logicalIdx - 3" {
    style: { bold: true; fill: "#FFF3E0"; stroke: "#FF9800" }
  }
  
  reclaimed: "RECLAIMED: 72 Bytes" {
    style: { fill: "#C8E6C9"; stroke: "#2E7D32"; stroke-dash: 3 }
  }
}

# -----------------------------------------------------------------------------------------
# IMPLEMENTATION LOGIC
# -----------------------------------------------------------------------------------------
access_functions: {
  label: "Raft Log Access Implementation"
  style.fill: "#F5F5F5"
  
  # Using unique delimiters |' ... '| to handle nested pipes in Go code (||)
  func1: {
    label: |'go'
      func logIndexToSlice(logicalIndex int) int {
        if logicalIndex < rf.lastIncludedIndex {
          return -1 // Entry is in snapshot
        }
        return logicalIndex - rf.lastIncludedIndex
      }
    '|
    class: code_block
  }

  func2: {
    label: |'go'
      func logEntry(logicalIndex int) (LogEntry, bool) {
        if logicalIndex == rf.lastIncludedIndex {
          return LogEntry{Term: rf.lastIncludedTerm}, true
        }
        sliceIdx := logIndexToSlice(logicalIndex)
        // Note: logical indices are 1-based, log[0] is metadata
        if sliceIdx < 0 || sliceIdx >= len(rf.log) {
          return LogEntry{}, false
        }
        return rf.log[sliceIdx], true
      }
    '|
    class: code_block
  }

  func3: {
    label: |'go'
      func logLastIndex() int {
        // Logical index of the very last entry
        return rf.lastIncludedIndex + len(rf.log) - 1
      }
    '|
    class: code_block
  }
}

# -----------------------------------------------------------------------------------------
# EXAMPLES AND INVARIANTS
# -----------------------------------------------------------------------------------------
examples: {
  label: "Translation Examples (lastIncludedIndex = 3)"
  style.fill: "#E1F5FE"

  ex1: {
    label: |'md'
      **Target: Logical Index 5**
      1. `sliceIdx` = 5 - 3 = 2
      2. Access `rf.log[2]`
      3. Content: `{Term: 2, Cmd: E}`
    '|
  }
  ex2: {
    label: |'md'
      **Target: Logical Index 3**
      1. `logicalIndex == lastIncludedIndex`
      2. Special case: Access Metadata
      3. Return Term 1 from `rf.log[0]`
    '|
  }
}

invariant_box: {
  label: |'md'
    ### Snapshot Offset Invariants
    1. **Sentinel Invariant**: `rf.log[0]` is the snapshot metadata.
    2. **Mapping Invariant**: `rf.log[1]` is always `lastIncludedIndex + 1`.
    3. **Range Invariant**: Physical log size is `len(rf.log)`.
    4. **Memory Constraint**: Memory freed is `(lastIncludedIndex) * sizeof(LogEntry)`.
  '|
  style: {
    fill: "#FFFDE7"
    stroke: "#F9A825"
    font: mono
  }
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS
# -----------------------------------------------------------------------------------------
before_snapshot.log_array -> step_compact -> after_snapshot.snapshot_file: "Snapshot(3)" {
  style: { stroke: "#FF8F00"; stroke-width: 4; animated: true }
}

after_snapshot.log_array -> access_functions: "Logic implementation" {
  style.stroke-dash: 5
}

access_functions -> examples: "Execution trace" {
  style.stroke: "#1565C0"
}

invariant_box.near: bottom-center