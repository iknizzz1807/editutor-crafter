vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    partition: "#FFE4E1"
    healthy: "#E8F5E9"
    snapshot: "#E1BEE7"
    sync: "#FFF3E0"
    caught: "#E8F5E9"
    leader: "#1976D2"
    follower: "#388E3C"
    partitioned: "#D32F2F"
  }
}

title: |md
  # Slow Follower Catch-Up via InstallSnapshot
| {near: top-center}

direction: right

timeline: {
  grid-rows: 6
  grid-columns: 6
  grid-gap: 0
  
  # Row 1: Time labels
  t0: "T=0" {style: {fill: transparent; font-size: 20; bold: true}}
  t1: "T=1" {style: {fill: transparent; font-size: 20; bold: true}}
  t2: "T=2" {style: {fill: transparent; font-size: 20; bold: true}}
  t3: "T=3" {style: {fill: transparent; font-size: 20; bold: true}}
  t4: "T=4" {style: {fill: transparent; font-size: 20; bold: true}}
  t5: "T=5" {style: {fill: transparent; font-size: 20; bold: true}}
  
  # Row 2: Phase labels
  phase0: |md
    **Initial**
    **State**
  | {style: {fill: "${colors.healthy}"; font-size: 16}}
  phase1: |md
    **Partition**
    **F0 Isolated**
  | {style: {fill: "${colors.partition}"; font-size: 16}}
  phase2: |md
    **Commands**
    **to L**
    **(150 entries)**
  | {style: {fill: "${colors.partition}"; font-size: 16}}
  phase3: |md
    **Leader**
    **Snapshots**
    **at idx 100**
  | {style: {fill: "${colors.snapshot}"; font-size: 16}}
  phase4: |md
    **Partition**
    **Healed**
    **InstallSnapshot**
  | {style: {fill: "${colors.sync}"; font-size: 16}}
  phase5: |md
    **F0 Caught**
    **Up**
  | {style: {fill: "${colors.caught}"; font-size: 16}}
  
  # Row 3: Leader state
  l0: {
    label: "L: log[1..10]\ncommit=10"
    style: {fill: "${colors.leader}"; font-color: white; border-radius: 4}
  }
  l1: {
    label: "L: log[1..10]\ncommit=10"
    style: {fill: "${colors.leader}"; font-color: white; border-radius: 4}
  }
  l2: {
    label: "L: log[1..160]\ncommit=160"
    style: {fill: "${colors.leader}"; font-color: white; border-radius: 4}
  }
  l3: {
    label: "L: snap@100\nlog[101..160]\ncommit=160"
    style: {fill: "${colors.snapshot}"; font-color: "#4A148C"; border-radius: 4; stroke-width: 2; stroke: "#7B1FA2"}
  }
  l4: {
    label: "L: snap@100\nlog[101..160]"
    style: {fill: "${colors.sync}"; font-color: "#E65100"; border-radius: 4}
  }
  l5: {
    label: "L: snap@100\nlog[101..160]"
    style: {fill: "${colors.leader}"; font-color: white; border-radius: 4}
  }
  
  # Row 4: Follower 1-3 state
  f0: {
    label: "F1-3: log[1..10]\ncommit=10"
    style: {fill: "${colors.follower}"; font-color: white; border-radius: 4}
  }
  f1: {
    label: "F1-3: log[1..10]\ncommit=10"
    style: {fill: "${colors.follower}"; font-color: white; border-radius: 4}
  }
  f2: {
    label: "F1-3: log[1..160]\ncommit=160"
    style: {fill: "${colors.follower}"; font-color: white; border-radius: 4}
  }
  f3: {
    label: "F1-3: snap@100\nlog[101..160]"
    style: {fill: "${colors.snapshot}"; font-color: "#4A148C"; border-radius: 4}
  }
  f4: {
    label: "F1-3: snap@100\nlog[101..160]"
    style: {fill: "${colors.follower}"; font-color: white; border-radius: 4}
  }
  f5: {
    label: "F1-3: snap@100\nlog[101..160]"
    style: {fill: "${colors.follower}"; font-color: white; border-radius: 4}
  }
  
  # Row 5: Follower 0 (partitioned)
  p0: {
    label: "F0: log[1..10]\ncommit=10"
    style: {fill: "${colors.follower}"; font-color: white; border-radius: 4}
  }
  p1: {
    label: "F0: log[1..10]\n**PARTITIONED**"
    style: {fill: "${colors.partitioned}"; font-color: white; border-radius: 4; stroke-width: 2; stroke: "#B71C1C"}
  }
  p2: {
    label: "F0: log[1..10]\n**PARTITIONED**"
    style: {fill: "${colors.partitioned}"; font-color: white; border-radius: 4; stroke-width: 2; stroke: "#B71C1C"}
  }
  p3: {
    label: "F0: log[1..10]\n**PARTITIONED**"
    style: {fill: "${colors.partitioned}"; font-color: white; border-radius: 4; stroke-width: 2; stroke: "#B71C1C"}
  }
  p4: {
    label: "F0: receiving\nInstallSnapshot"
    style: {fill: "${colors.sync}"; font-color: "#E65100"; border-radius: 4; stroke-width: 2; stroke: "#FF6D00"}
  }
  p5: {
    label: "F0: snap@100\nlog[101..160]\n**CAUGHT UP**"
    style: {fill: "${colors.caught}"; font-color: "#1B5E20"; border-radius: 4; stroke-width: 2; stroke: "#2E7D32"}
  }
  
  # Row 6: Network state
  n0: {
    label: "All connected"
    style: {fill: "transparent"; font-size: 14}
  }
  n1: {
    label: "F0 isolated"
    style: {fill: "${colors.partition}"; font-size: 14; border-radius: 4}
  }
  n2: {
    label: "F0 isolated"
    style: {fill: "${colors.partition}"; font-size: 14; border-radius: 4}
  }
  n3: {
    label: "F0 isolated"
    style: {fill: "${colors.partition}"; font-size: 14; border-radius: 4}
  }
  n4: {
    label: "Healed\nInstallSnapshot\ntransfer"
    style: {fill: "${colors.sync}"; font-size: 14; border-radius: 4}
  }
  n5: {
    label: "All synced"
    style: {fill: "${colors.caught}"; font-size: 14; border-radius: 4}
  }
}

# Flow arrows
arrow1: timeline.l1 -> timeline.l2: "+150 cmds" {
  style: {stroke: "${colors.leader}"; stroke-width: 2; animated: true}
}
arrow2: timeline.p1 -> timeline.p2: "no updates\n(partitioned)" {
  style: {stroke: "${colors.partitioned}"; stroke-width: 2; stroke-dash: 4}
}
arrow3: timeline.l2 -> timeline.l3: "snapshot()\nat idx 100" {
  style: {stroke: "#7B1FA2"; stroke-width: 2}
}
arrow4: timeline.f2 -> timeline.f3: "snapshot()" {
  style: {stroke: "#7B1FA2"; stroke-width: 2}
}
arrow5: timeline.l4 -> timeline.p4: "InstallSnapshot\n(lastIncIdx=100)" {
  style: {stroke: "#FF6D00"; stroke-width: 3; animated: true}
}
arrow6: timeline.p4 -> timeline.p5: "restore\napply\ntrunc log" {
  style: {stroke: "#2E7D32"; stroke-width: 2}
}

# Legend
legend: {
  near: bottom-center
  grid-columns: 4
  grid-gap: 20
  leg_leader: "Leader" {style: {fill: "${colors.leader}"; font-color: white; border-radius: 4}}
  leg_follower: "Follower" {style: {fill: "${colors.follower}"; font-color: white; border-radius: 4}}
  leg_partitioned: "Partitioned" {style: {fill: "${colors.partitioned}"; font-color: white; border-radius: 4}}
  leg_snapshot: "Has Snapshot" {style: {fill: "${colors.snapshot}"; font-color: "#4A148C"; border-radius: 4}}
}

# Key events annotation
events: {
  near: bottom-right
  event1: |md
    ### Key Events:
    1. **T=1**: Network partition isolates F0
    2. **T=2**: 150 commands submitted to leader
       - F1-3 receive via AppendEntries
       - F0 receives nothing (partitioned)
    3. **T=3**: Log exceeds threshold (100)
       - Leader snapshots at index 100
       - F1-3 also snapshot
       - Leader's log: [snap@100, 101..160]
    4. **T=4**: Partition heals
       - Leader sees F0's nextIndex=11 <= lastIncIdx=100
       - Leader sends InstallSnapshot RPC
    5. **T=5**: F0 receives and applies snapshot
       - Persists snapshot to disk
       - Restores state machine
       - Discards old log[1..10]
       - Receives log[101..160] via AppendEntries
       - **Caught up!**
  | {style: {fill: "#FAFAFA"; border-radius: 8; stroke-width: 1; stroke: "#E0E0E0"}}
}