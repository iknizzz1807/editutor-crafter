vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Recovery from Snapshot + Log
  Step-by-step process on node restart
| {near: top-center}

direction: right

# Step 1: IO Layer
step1: "1. Read Snapshot from Disk" {
  direction: down
  style.fill: "#E8D5F0"
  style.stroke: "#7B4B94"
  style.stroke-width: 2

  disk_snapshot: "Snapshot File\n(raft-snapshot.bin)" {
    shape: cylinder
    style.fill: "#D4B8E0"
    metadata: "Metadata:\n• lastIncludedIndex: 10000\n• lastIncludedTerm: 5"
    data: "Data:\n• State machine state\n• Session state"
  }

  note1: |md
    **Storage Invariant**
    Atomic read ensures either complete
    snapshot or none at all.
  | {
    style.stroke-dash: 3
  }
}

# Step 2: Application Layer
step2: "2. Restore State Machine" {
  direction: down
  style.fill: "#B8D4E8"
  style.stroke: "#4B7B94"
  style.stroke-width: 2

  state_machine: "State Machine\n(KVStore)" {
    shape: rectangle
    style.fill: "#A0C4D8"
    kv_data: "data: {key1: val1, key2: val2, ...}"
    sessions: "sessions: {client1: {lastSeq: 50, ...}, ...}"
  }

  note2: |md
    **Interface Call**
    `RestoreSnapshot(data)` called
    with snapshot Data field.
  | {
    style.stroke-dash: 3
  }
}

# Step 3: Protocol State
step3: "3. Update Metadata" {
  direction: down
  style.fill: "#D4E8B8"
  style.stroke: "#7B944B"
  style.stroke-width: 2

  raft_state: "RaftNode State" {
    shape: class
    style.fill: "#C4D8A0"
    lastIncIdx: "lastIncludedIndex = 10000"
    lastIncTerm: "lastIncludedTerm = 5"
    commitIdx: "commitIndex = 10000"
    lastApp: "lastApplied = 10000"
  }

  note3: |md
    **Index Invariant**
    All indices set to at least
    `lastIncludedIndex`.
  | {
    style.stroke-dash: 3
  }
}

# Step 4: Log Loading
step4: "4. Read Remaining Log" {
  direction: down
  style.fill: "#E8D4B8"
  style.stroke: "#947B4B"
  style.stroke-width: 2

  disk_log: "Raft State File\n(raft-state.json)" {
    shape: cylinder
    style.fill: "#D8C4A0"
    log_entries: "Log entries:\n[10001: term5, cmd10001]\n[10002: term5, cmd10002]\n[10003: term5, cmd10003]\n..."
  }

  note4: |md
    **Truncation Rule**
    Log contains only entries AFTER
    `lastIncludedIndex`.
  | {
    style.stroke-dash: 3
  }
}

# Step 5: Execution
step5: "5. Replay Log Entries" {
  direction: down
  style.fill: "#E8B8D4"
  style.stroke: "#944B7B"
  style.stroke-width: 2

  apply_loop: "Apply Loop" {
    shape: rectangle
    style.fill: "#D8A0C4"
    loop_logic: |md
      go
      for lastApplied < commitIndex {
        lastApplied++
        entry := log[lastApplied - offset]
        stateMachine.Apply(entry.Command)
      }
      
    |
  }

  note5: |md
    **Consistency**
    Sequential application from
    `lastIncludedIndex+1` to `commitIndex`.
  | {
    style.stroke-dash: 3
  }
}

# Step 6: Final State
step6: "6. Resume Operation" {
  direction: down
  style.fill: "#B8E8D4"
  style.stroke: "#4B947B"
  style.stroke-width: 2

  running_node: "Running RaftNode" {
    shape: rectangle
    style.fill: "#A0D8C4"
    state: "state = Follower"
    timer: "Election timer active"
    rpc: "Ready for RPCs"
  }

  note6: |md
    **Availability**
    Node rejoins cluster with
    consistent application state.
  | {
    style.stroke-dash: 3
  }
}

# Transitions
step1 -> step2: "Snapshot loaded" {style.stroke: "#7B4B94"; style.stroke-width: 2}
step2 -> step3: "SM restored" {style.stroke: "#4B7B94"; style.stroke-width: 2}
step3 -> step4: "Metadata set" {style.stroke: "#7B944B"; style.stroke-width: 2}
step4 -> step5: "Log loaded" {style.stroke: "#947B4B"; style.stroke-width: 2}
step5 -> step6: "Entries applied" {style.stroke: "#944B7B"; style.stroke-width: 2}

# Legend and Invariants
legend: {
  near: bottom-center
  style.fill: "#F1F1F1"
  style.stroke: "#333333"
  
  header: "RECOVERY INVARIANTS" {
    shape: text
    style.bold: true
    style.font-size: 16
  }
  
  inv1: "1. Snapshot persisted BEFORE log truncation (atomic guarantee)"
  inv2: "2. Log entries exist only for indices > lastIncludedIndex"
  inv3: "3. Final SM State = Snapshot(data) + Replay(Log[lastIncludedIndex+1:])"
  inv4: "4. CommitIndex persistence ensures no committed data is lost"
  
  header -> inv1 -> inv2 -> inv3 -> inv4: {style.stroke: transparent}
}