direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 40
  }
  colors: {
    header: "#6B46C1"
    metadata: "#2563EB"
    data: "#059669"
    checksum: "#DC2626"
    padding: "#94A3B8"
    text_light: "#F9FAFB"
    border_dark: "#111827"
  }
}

title: {
  label: |md
    # Snapshot Persistence Format
    ### Raft State Machine Atomic Disk Layout
  |
  near: top-center
  style: {
    font-size: 24
    stroke-width: 0
    fill: transparent
  }
}

# -----------------------------------------------------------------------------
# Main Memory Layout Stack
# -----------------------------------------------------------------------------
snapshot_storage: "Disk Persistence Layout (Big-Endian Representation)" {
  grid-columns: 1
  grid-gap: 0
  
  style: {
    stroke: "#111827"
    stroke-width: 4
  }

  header_block: {
    label: |md
      ### 0x00: SYSTEM HEADER (Fixed 16B)
      | Offset | Field | Size | Description |
      | :--- | :--- | :--- | :--- |
      | **0x00** | Magic | 4B | `0x52 0x41 0x46 0x54` ("RAFT") |
      | **0x04** | Version | 4B | `0x00 0x00 0x00 0x01` |
      | **0x08** | MetaLen (M) | 4B | Length of Metadata segment |
      | **0x0C** | DataLen (D) | 4B | Length of Application Data |
    |
    width: 850
    style: {
      fill: "#6B46C1"
      font-color: "#F9FAFB"
      stroke: "#111827"
      stroke-width: 2
    }
  }

  metadata_segment: {
    label: |md
      ### 0x10: SNAPSHOT METADATA (M Bytes)
      | Offset | Field | Size | Description |
      | :--- | :--- | :--- | :--- |
      | **0x10** | JSON Blob | M B | Serialized Raft State (Term, Index, Conf) |
    |
    width: 850
    style: {
      fill: "#2563EB"
      font-color: "#F9FAFB"
      stroke: "#111827"
      stroke-width: 2
      stroke-dash: 2
    }
  }

  data_segment: {
    label: |md
      ### 0x10 + M: STATE MACHINE PAYLOAD (D Bytes)
      | Offset | Field | Size | Description |
      | :--- | :--- | :--- | :--- |
      | **0x10+M** | Binary Payload | D B | Application State (Opaque) |
      
      *Note: Padding to 4KB alignment should be handled at the filesystem level.*
    |
    width: 850
    style: {
      fill: "#059669"
      font-color: "#F9FAFB"
      stroke: "#111827"
      stroke-width: 2
    }
  }

  checksum_block: {
    label: |md
      ### EOF - 4: INTEGRITY
      | Offset | Field | Size | Description |
      | :--- | :--- | :--- | :--- |
      | **End-4** | CRC32 | 4B | IEEE 802.3 Polynomial Checksum |
    |
    width: 850
    style: {
      fill: "#DC2626"
      font-color: "#F9FAFB"
      stroke: "#111827"
      stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------
# JSON Schema for Metadata
# -----------------------------------------------------------------------------
metadata_schema: {
  shape: sql_table
  label: "Metadata JSON Structure"
  near: bottom-left
  style: {
    stroke: "#2563EB"
    fill: "#EFF6FF"
    stroke-width: 2
  }

  lastIndex: "uint64" {constraint: PK}
  lastTerm: "uint64"
  confIndex: "uint64"
  votedFor: "string"
  membership: "[]string"
}

# -----------------------------------------------------------------------------
# Implementation Spec Details
# -----------------------------------------------------------------------------
spec_info: {
  near: right-center
  label: |md
    ### Persistence Logic
    - **Byte Order**: Little-endian preferred for field storage
    - **Atomic Guarantee**:
      1. Write to `*.tmp`
      2. `fsync()` file data
      3. `rename()` to `*.bin`
      4. `fsync()` directory
    - **Validation**:
      `computed_crc = crc32(buffer[0..End-4])`
  |
  style: {
    fill: "#F8FAFC"
    stroke: "#64748B"
    stroke-dash: 4
    font-size: 14
    border-radius: 8
  }
}

# -----------------------------------------------------------------------------
# Legend & Connections
# -----------------------------------------------------------------------------
legend: {
  near: bottom-center
  grid-columns: 4
  grid-gap: 30
  
  header_leg: "Fixed Header (Purple)" { style.fill: "#6B46C1"; style.font-color: "#FFFFFF" }
  meta_leg: "Metadata (Blue)" { style.fill: "#2563EB"; style.font-color: "#FFFFFF" }
  data_leg: "Data (Green)" { style.fill: "#059669"; style.font-color: "#FFFFFF" }
  check_leg: "Integrity (Red)" { style.fill: "#DC2626"; style.font-color: "#FFFFFF" }
}

snapshot_storage.metadata_segment -> metadata_schema: "Parsed into" {
  style: {
    stroke: "#2563EB"
    stroke-dash: 5
    animated: true
  }
}

# Annotations for Intel Manual style
snapshot_storage.header_block.magic_pos: "0x00" {
  near: outside-left-center
  style.font-size: 12
}
snapshot_storage.metadata_segment.meta_pos: "0x10" {
  near: outside-left-center
  style.font-size: 12
}
snapshot_storage.checksum_block.eof_pos: "EOF-4" {
  near: outside-left-center
  style.font-size: 12
}