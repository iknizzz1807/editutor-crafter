layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    header: "#E4DBFE"
    component: "#C7F1FF"
    interface: "#DEE1EB"
    data: "#88DCF7"
    padding: "#D1D5DB"
    pointer: "#FB923C"
  }
}

title: |md
  # Snapshot Module Architecture
  **Milestone 3: Log Compaction & Persistence**
| {near: top-center}

direction: right

# Main container: RaftNode Memory Layout & Logic
RaftNode: {
  style.fill: "${colors.header}"
  style.stroke: "#8B5CF6"
  style.stroke-width: 2
  label: "RaftNode (struct)\nsizeof=128 bytes"

  # Core Raft state with explicit memory layout
  coreState: {
    style.fill: "${colors.component}"
    label: Core State (Volatile)
    
    log: {
      shape: cylinder
      label: "Log (Slice Header)\nOffset: 0 | Size: 24B\n[ptr, len, cap]"
      style.fill: "${colors.data}"
    }
    commitIndex: {
      label: "commitIndex (int64)\nOffset: 24 | Size: 8B"
      shape: hexagon
      style.fill: "${colors.data}"
    }
    lastApplied: {
      label: "lastApplied (int64)\nOffset: 32 | Size: 8B"
      shape: hexagon
      style.fill: "${colors.data}"
    }
    padding: {
      label: "Padding\n8B"
      style.fill: "${colors.padding}"
      style.stroke-dash: 3
    }
  }

  # Snapshot fields
  snapshotFields: {
    style.fill: "${colors.header}"
    label: Snapshot Metadata (Persistent)
    
    lastIncludedIndex: {
      label: "lastIncludedIndex\nOffset: 48 | Size: 8B"
      shape: hexagon
      style.fill: "${colors.data}"
    }
    lastIncludedTerm: {
      label: "lastIncludedTerm\nOffset: 56 | Size: 8B"
      shape: hexagon
      style.fill: "${colors.data}"
    }
    snapshotPtr: {
      label: "snapshot (*Snapshot)\nOffset: 64 | Size: 8B"
      shape: hexagon
      style.fill: "${colors.pointer}"
    }
  }

  # Log access methods (Logical to Physical mapping)
  logAccess: {
    style.fill: "${colors.interface}"
    label: "Abstraction Layer: Index Translation"
    logEntry: {
      label: "logEntry(logicalIndex uint64) -> (LogEntry, bool)"
    }
    logTerm: {
      label: "logTerm(logicalIndex uint64) -> int"
    }
    logIndexToSlice: {
      label: "physicalIndex = logicalIndex - lastIncludedIndex"
      style.font: mono
    }
  }

  coreState.log -> snapshotFields.lastIncludedIndex: "truncation\nboundary" {
    style.stroke-dash: 3
    style.stroke: "#8B5CF6"
  }
}

# SnapshotManager: Background Orchestration
SnapshotManager: {
  style.fill: "${colors.header}"
  style.stroke: "#8B5CF6"
  style.stroke-width: 2
  label: SnapshotManager (Loop)

  trigger: {
    label: "Condition Check:\nif (len(log) > threshold)"
    style.fill: "${colors.component}"
    shape: diamond
  }
  creator: {
    label: "takeSnapshotLocked(index)\n1. Lock -> 2. Copy -> 3. Truncate"
    style.fill: "${colors.component}"
  }
  threshold: {
    label: "Max Log Size\nint64: 10,000"
    shape: hexagon
    style.fill: "${colors.data}"
  }
  
  trigger -> creator: "logical_idx > lastIncIdx"
}

# SnapshotStore: IO Operations
SnapshotStore: {
  style.fill: "${colors.interface}"
  style.stroke: "#6B7280"
  style.stroke-width: 2
  label: SnapshotStore (Storage Engine)

  save: {
    label: "SaveSnapshot(data []byte, meta Metadata)"
    style.fill: "${colors.component}"
  }
  atomic: {
    shape: diamond
    label: "Atomic Write\n(Sync -> Rename)"
    style.fill: "#F59E0B"
  }
  
  save -> atomic: "TempFile Write"
}

# LogTruncator: Slice manipulation
LogTruncator: {
  style.fill: "${colors.interface}"
  style.stroke: "#6B7280"
  style.stroke-width: 2
  label: LogTruncator (Memory Management)

  truncate: {
    label: "Discard Prefix\n[1 : lastIncludedIdx]"
    style.fill: "#EF4444"
    style.font-color: white
  }
  rebuild: {
    label: "Compact Slice\n[dummy] + suffix"
    style.fill: "${colors.component}"
  }
}

# StateMachine Interface
StateMachineSnapshot: {
  style.fill: "${colors.interface}"
  style.stroke: "#10B981"
  style.stroke-width: 2
  shape: class
  label: "StateMachine (SM) Interface"
  snapshot: "+ Snapshot() ([]byte, error)"
  restore: "+ Restore(data []byte) error"
}

# Data Definitions
Snapshot: {
  shape: class
  style.fill: "${colors.header}"
  label: "Snapshot (Serialized Payload)"
  metadata: "Header: SnapshotMetadata"
  data: "Payload: []byte (State Blob)"
}

SnapshotMetadata: {
  shape: class
  style.fill: "${colors.interface}"
  label: "SnapshotMetadata"
  lastIdx: "LastIndex: int64"
  lastTerm: "LastTerm: int64"
}

# InstallSnapshot RPC Logic
InstallSnapshot: {
  style.fill: "${colors.component}"
  style.stroke: "#3B82F6"
  label: InstallSnapshot (Replication)
  
  handler: {
    label: "RPC: HandleInstallSnapshot"
    style.fill: "${colors.header}"
  }
  check: {
    label: "nextIndex < lastIncludedIndex?"
    shape: diamond
    style.fill: "#F59E0B"
  }
}

# Connections
RaftNode.snapshotFields.snapshotPtr -> Snapshot: "references" {style.stroke: orange}
Snapshot -> SnapshotMetadata: "contains"
RaftNode -> SnapshotManager.trigger: "triggers on append"

SnapshotManager.creator -> StateMachineSnapshot.snapshot: "1. Pull SM State"
StateMachineSnapshot.snapshot -> Snapshot: "fills payload"
SnapshotManager.creator -> SnapshotStore.save: "2. Persist to Disk"
SnapshotStore.save -> LogTruncator.truncate: "3. Cleanup In-Mem Log" {style.stroke: red}
LogTruncator.rebuild -> RaftNode.coreState.log: "4. Update Log Header"

InstallSnapshot.check -> InstallSnapshot.handler: "send full snapshot"
InstallSnapshot.handler -> SnapshotStore.save: "remote save"
InstallSnapshot.handler -> StateMachineSnapshot.restore: "apply to SM"

# Annotations (Fixed Compilation Error)
annotation1: |md
  ### Atomicity Guarantee (ACID)
  1. **Write to Temp**: Write buffer to disk.
  2. **fsync()**: Ensure physical persistence.
  3. **Rename**: Atomic file swap.
  4. **Truncate**: Only discard log if rename succeeds.
| {
  near: top-right
  shape: text
}

annotation2: |md
  ### Index Mapping Formula
  Logical Index (User View): `L`
  Physical Index (Array View): `P`
  `P = L - lastIncludedIndex`
  Note: `log[0]` is a sentinel entry.
| {
  near: bottom-left
  shape: text
}

annotation3: |md
  ### Snapshot Trigger
  go
  if uncompactedEntries > threshold {
      go sm.takeSnapshot(commitIndex)
  }
  
| {
  near: top-left
  shape: text
}

# Explicit Links for Annotations
annotation1 -- SnapshotStore: {style.stroke-dash: 5}
annotation2 -- RaftNode.logAccess: {style.stroke-dash: 5}
annotation3 -- SnapshotManager.trigger: {style.stroke-dash: 5}

# Legend
legend: {
  near: bottom-right
  style.fill: "${colors.interface}"
  
  manager_type: {
    label: "Manager / Orchestrator"
    style.fill: "${colors.header}"
  }
  comp_type: {
    label: "Logic Component"
    style.fill: "${colors.component}"
  }
  data_type: {
    label: "Persistent Data / Fields"
    shape: hexagon
    style.fill: "${colors.data}"
  }
  critical_type: {
    label: "Atomic / Critical Action"
    shape: diamond
    style.fill: "#F59E0B"
  }
}