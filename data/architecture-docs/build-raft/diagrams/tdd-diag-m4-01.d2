vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

shape: sequence_diagram

# ---------------------------------------------------------------------------------
# PARTICIPANT DEFINITIONS
# ---------------------------------------------------------------------------------
Client: Client {
  shape: person
  icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
}

Follower: Follower {
  style: {
    fill: "#f5f5f5"
    stroke: "#757575"
  }
}

Leader: Leader {
  style: {
    bold: true
    fill: "#e3f2fd"
    stroke: "#2196f3"
    stroke-width: 2
  }
}

StateMachine: State Machine {
  style: {
    fill: "#f3e5f5"
    stroke: "#9c27b0"
  }
}

# ---------------------------------------------------------------------------------
# STEP 1: DISCOVERY & REDIRECTION
# ---------------------------------------------------------------------------------
Client -> Follower: "SubmitCommand {clientId, seqNum, cmd}" {
  style.stroke: "#2196f3"
  style.stroke-width: 2
}

Follower -> Client: "WrongLeader=true, leaderId='leader-1'" {
  style: {
    stroke: "#ff9800"
    stroke-dash: 3
  }
}

# Proper D2 sequence note syntax replaces the invalid 'note' keyword in the edge map
Follower."Redirect to known leader (leader-1)"

# ---------------------------------------------------------------------------------
# STEP 2: LEADER LOG PERSISTENCE
# ---------------------------------------------------------------------------------
Client -> Leader: "SubmitCommand {clientId, seqNum, cmd} (retry)" {
  style.stroke: "#2196f3"
  style.stroke-width: 2
}

Leader.log: "Log Append"
Leader -> Leader.log: "Append entry[N] to local log" {
  style.stroke: "#757575"
}

Leader.log -> Leader.disk: "fsync()"
Leader.disk: "Disk Persist" {
  style.stroke: "#757575"
}

# ---------------------------------------------------------------------------------
# STEP 3: PARALLEL REPLICATION (CONSENSUS)
# ---------------------------------------------------------------------------------
# Launch async replication requests
Leader.disk -> Follower.a: "AppendEntries {term, prevIdx, entry[N], leaderCommit}" {
  style.animated: true
  style.stroke: "#4caf50"
}
Leader.disk -> Follower.b: "AppendEntries {term, prevIdx, entry[N], leaderCommit}" {
  style.animated: true
  style.stroke: "#4caf50"
}

# Acknowledge replication
Follower.a -> Leader.consensus: "Success {matchIndex=N}" {
  style.stroke: "#4caf50"
}
Follower.b -> Leader.consensus: "Success {matchIndex=N}" {
  style.stroke: "#4caf50"
}

# ---------------------------------------------------------------------------------
# STEP 4: COMMITMENT & DETERMINISTIC EXECUTION
# ---------------------------------------------------------------------------------
Leader.consensus: "Commit Logic"
Leader.consensus -> Leader.consensus: "Verify majority (matchIndex >= N)"
Leader.consensus -> Leader.consensus: "advance commitIndex = N"

Leader.consensus -> StateMachine.exec: "ApplyEntry(index=N, data=cmd)" {
  style: {
    stroke: "#9c27b0"
    stroke-width: 2
  }
}

StateMachine.exec: "Executor"
StateMachine.exec -> StateMachine.exec: "Lookup Session(clientId)"
StateMachine.exec -> StateMachine.exec: "Check Duplicate (seqNum)"
StateMachine.exec -> StateMachine.exec: "State Transition: S_old -> S_new"
StateMachine.exec -> StateMachine.exec: "Cache response in Session"

StateMachine.exec -> Leader.reply: "Response {status: OK, result}" {
  style.stroke: "#9c27b0"
}

# ---------------------------------------------------------------------------------
# STEP 5: CLIENT ACKNOWLEDGEMENT
# ---------------------------------------------------------------------------------
Leader.reply -> Client: "RPC Success=true, Response {result}" {
  style: {
    stroke: "#4caf50"
    stroke-width: 3
    bold: true
  }
}

# ---------------------------------------------------------------------------------
# DOCUMENTATION GROUP (LEGEND)
# ---------------------------------------------------------------------------------
Legend: "Protocol Key" {
  style.stroke-dash: 5
  
  Blue: "Client Ingress (RPC)" {
    style.font-color: "#2196f3"
    style.stroke: "#2196f3"
  }
  Orange: "Raft Redirection" {
    style.font-color: "#ff9800"
    style.stroke: "#ff9800"
  }
  Green: "Log Replication (RPC)" {
    style.font-color: "#4caf50"
    style.stroke: "#4caf50"
  }
  Purple: "State Machine Ops" {
    style.font-color: "#9c27b0"
    style.stroke: "#9c27b0"
  }
}