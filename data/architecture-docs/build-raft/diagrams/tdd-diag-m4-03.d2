vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

# --- GLOBAL CLASSES ---
classes: {
  algorithm_step: {
    style: {
      stroke-width: 2
      border-radius: 8
      fill: "#FFFFFF"
      shadow: true
    }
  }
  node_header: {
    style: {
      fill: "#E1BEE7" # Purple Header
      bold: true
      stroke-width: 2
    }
  }
  data_obj: {
    style: {
      fill: "#BBDEFB" # Blue Data
    }
  }
  success_state: {
    style: {
      fill: "#C8E6C9" # Green Success
      stroke: "#2E7D32"
    }
  }
  annotation_note: {
    shape: text
    style: {
      font-size: 14
      italic: true
    }
  }
  internal_logic: {
    style: {
      fill: "#F5F5F5"
      stroke-dash: 5
      font: mono
    }
  }
}

title: |'md
  # Linearizable Read via ReadIndex (Raft Algorithm)
  **Design Spec:** Intel-Manual-Grade Technical Reference
  **Constraint:** Serve reads without Raft log I/O, ensuring result visibility of all prior commits.
'| {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

# --- ALGORITHM STATE: STEP 1 ---
step1: {
  label: "1. Client Read Request Initiation"
  class: algorithm_step
  
  client1: Client {
    shape: person
    class: data_obj
  }
  
  leader1: Leader Node {
    class: node_header
    state: |'md
      ### RAFT VOLATILE STATE
      | Offset | Field | Value |
      | :--- | :--- | :--- |
      | 0x00 | **commitIndex** | 100 |
      | 0x08 | **lastApplied** | 100 |
      | 0x10 | **nextIndex[]** | [101, 101, 101] |
      | 0x20 | **matchIndex[]**| [100, 100, 100] |
    '|
  }
  
  client1 -> leader1: "Read(key='x')" {
    style.stroke: "#1976D2"
    style.stroke-width: 3
    style.animated: true
  }
}

# --- ALGORITHM STATE: STEP 2 ---
step2: {
  label: "2. Atomic ReadIndex Snapshot"
  class: algorithm_step

  leader2: Leader Node {
    class: node_header
    state: |'md
      ### LATCH COMMIT INDEX
      **ReadIndex** := **<font color="red">100</font>**
      
      *Invariants:*
      1. Must be from current term (Term 5).
      2. Serves as the lower bound for linearizability.
    '|
  }
  
  note2: |'md
    ### READ_INDEX_SNAPSHOT
    The leader captures the current 
    `commitIndex` as the version bound. 
    Any data returned must be at least 
    as recent as this index.
  '| {
    class: annotation_note
  }
}

# --- ALGORITHM STATE: STEP 3 ---
step3: {
  label: "3. Quorum Heartbeat Broadcast"
  class: algorithm_step

  leader3: Leader Node {
    class: node_header
    msg: |'md
      **AppendEntries (HB)**
      - Term: 5
      - LeaderID: 0
      - PrevLogIndex: 100
      - CommitIndex: 100
    '|
  }
  
  followers3: Cluster {
    style.fill: "#F5F5F5"
    f1: F1
    f2: F2
    f3: F3
  }
  
  leader3 -> followers3.f1: "Heartbeat"
  leader3 -> followers3.f2: "Heartbeat"
  leader3 -> followers3.f3: "Heartbeat" {
    style.stroke: "#FB8C00" # Orange Messages
    style.stroke-dash: 3
    style.animated: true
  }
}

# --- ALGORITHM STATE: STEP 4 ---
step4: {
  label: "4. Quorum Leadership Verification"
  class: algorithm_step

  leader4: Leader Node {
    class: node_header
    check: |'md
      ### QUORUM STATUS
      | Node | Responded | Term Match |
      | :--- | :--- | :--- |
      | 0 (Self) | [X] | [X] |
      | 1 (Peer) | [X] | [X] |
      | 2 (Peer) | [X] | [X] |
      | 3 (Peer) | [ ] | [ ] |
      
      **STATUS: <font color="green">LEADERSHIP_CONFIRMED</font>**
    '|
  }
  
  f1_ack: F1_Peer { class: success_state }
  f2_ack: F2_Peer { class: success_state }
  
  f1_ack -> leader4: "ACK (Term 5)"
  f2_ack -> leader4: "ACK (Term 5)"
  
  quorum_logic: |'md
    ### ANTI-PARTITION SHIELD
    Heartbeat success proves majority 
    acknowledgment, preventing stale 
    reads from a deposed leader in 
    a network partition.
  '| {
    class: annotation_note
  }
}

# --- ALGORITHM STATE: STEP 5 ---
step5: {
  label: "5. Local Apply Loop Synchronization"
  class: algorithm_step

  leader5: Leader Node {
    class: node_header
    apply_check: |'md
      ### SPIN WAIT: LOG APPLICATION
      go
      // Blocking wait for apply loop
      for lastApplied < ReadIndex {
          wait(apply_signal)
      }
      
      **Current lastApplied:** 100
      **Target ReadIndex:** 100
      **STATE: READY**
    '|
  }
  
  sm5: State Machine {
    shape: cylinder
    class: data_obj
  }
  
  leader5 -> sm5: "Yield to Index 100" {
    style.stroke: "#7B1FA2"
    style.stroke-dash: 5
  }
}

# --- ALGORITHM STATE: STEP 6 ---
step6: {
  label: "6. Linearizable Response"
  class: algorithm_step

  leader6: Leader Node {
    class: success_state
    label: "Leader (State: Responding)"
  }
  
  client6: Client {
    shape: person
    class: data_obj
  }
  
  sm6: State Machine {
    shape: cylinder
    class: data_obj
    data: |'md
      ### MEMORY LAYOUT (k=x)
      | Offset | Field | Value |
      | :--- | :--- | :--- |
      | 0x440 | Key | "x" |
      | 0x448 | Value | "v1" |
      | 0x450 | Ver | 100 |
    '|
  }
  
  leader6 -> sm6: "Read('x')"
  sm6 -> leader6: "v1"
  leader6 -> client6: "Success(v1)" {
    style.stroke: "#2E7D32"
    style.stroke-width: 4
  }
}

# --- PROTOCOL SEQUENCE ---
summary: {
  label: "ReadIndex Protocol Sequence Definition"
  style.fill: "#F8F9FA"
  style.stroke-width: 2
  
  flow: {
    shape: sequence_diagram
    C: Client { class: data_obj }
    L: Leader { class: node_header }
    F: Quorum { style.fill: "#F5F5F5" }
    SM: StateMachine { class: data_obj }
    
    C -> L: "Get(key)"
    L -> L: "Snapshot ReadIndex" {
      style.stroke: "#E65100"
    }
    L -> F: "Heartbeat(Term)"
    F -> L: "Ack(Term)"
    L -> L: "Wait(lastApplied >= ReadIndex)"
    L -> SM: "Query State"
    SM -> L: "Result Data"
    L -> C: "Response(Data)"
  }
}

# --- ARCHITECTURAL STEP PROGRESSION ---
step1 -> step2: "1. Capture"
step2 -> step3: "2. Validate"
step3 -> step4: "3. Quorum"
step4 -> step5: "4. Apply"
step5 -> step6: "5. Return"
step6 -> summary: "Final Specification"

# Global edge styling for progression
(step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> summary)[*]: {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5
  style.stroke-width: 2
}