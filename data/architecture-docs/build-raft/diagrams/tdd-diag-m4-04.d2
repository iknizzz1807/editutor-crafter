vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Stale Leader Prevention via ReadIndex
  Partitioned old leader cannot confirm leadership - read blocked or redirected
| {near: top-center}

direction: right

# Timeline phases sequence diagram for time labels
phase_labels: {
  shape: sequence_diagram
  T0: "T=0"
  T1: "T=1"
  T2: "T=2"
  T3: "T=3"
  T4: "T=4"
}

# Phase 1: Initial State - Single Leader
phase1: "T=0: Normal Operation" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  
  cluster_healthy: "5-Node Cluster (Healthy)" {
    style.fill: white
    L1: "Leader L1\nTerm 3" {
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    F1: "F1" {shape: rectangle; style.fill: "#BBDEFB"}
    F2: "F2" {shape: rectangle; style.fill: "#BBDEFB"}
    F3: "F3" {shape: rectangle; style.fill: "#BBDEFB"}
    F4: "F4" {shape: rectangle; style.fill: "#BBDEFB"}
    
    L1 -> F1: heartbeat
    L1 -> F2: heartbeat
    L1 -> F3: heartbeat
    L1 -> F4: heartbeat
  }
  
  note1: |md
    ### Phase Summary
    - Leader L1 in term 3
    - All nodes in sync
    - Client can read/write
  | {
    style.stroke-dash: 3
  }
}

# Phase 2: Partition Occurs
phase2: "T=1: Network Partition" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 2
  
  partition_minority: "Minority Partition [L1]" {
    style.fill: "#FFCDD2"
    style.stroke-dash: 3
    L1_isolated: "L1 (Isolated)\nTerm 3" {
      shape: rectangle
      style.fill: "#FF5722"
      style.font-color: white
    }
  }
  
  partition_majority: "Majority Partition [F1,F2,F3,F4]" {
    style.fill: "#C8E6C9"
    F1_maj: "F1" {shape: rectangle; style.fill: "#BBDEFB"}
    F2_maj: "F2" {shape: rectangle; style.fill: "#BBDEFB"}
    F3_maj: "F3" {shape: rectangle; style.fill: "#BBDEFB"}
    F4_maj: "F4" {shape: rectangle; style.fill: "#BBDEFB"}
  }
  
  partition_minority -> partition_majority: "✗ NETWORK CUT ✗" {
    style.stroke: red
    style.stroke-width: 3
    style.stroke-dash: 5
    style.animated: true
    style.font-color: red
    style.bold: true
  }
  
  note2: |md
    ### Phase Summary
    - L1 isolated from majority
    - L1 still thinks it's leader
    - Majority has quorum (4 nodes)
  | {
    style.stroke-dash: 3
  }
}

# Phase 3: New Leader Elected
phase3: "T=2: New Leader in Majority" {
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  
  minority_stale: "Minority (Stale)" {
    style.fill: "#FFCDD2"
    style.stroke-dash: 3
    L1_stale: "L1 (Stale)\nTerm 3" {
      shape: rectangle
      style.fill: "#9E9E9E"
      style.font-color: white
    }
  }
  
  majority_new: "Majority (New Leader)" {
    style.fill: "#C8E6C9"
    L2_new: "NEW LEADER L2\nTerm 4" {
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    F1_new: "F1" {shape: rectangle; style.fill: "#BBDEFB"}
    F3_new: "F3" {shape: rectangle; style.fill: "#BBDEFB"}
    F4_new: "F4" {shape: rectangle; style.fill: "#BBDEFB"}
    
    L2_new -> F1_new: heartbeat (term 4)
    L2_new -> F3_new: heartbeat (term 4)
    L2_new -> F4_new: heartbeat (term 4)
  }
  
  note3: |md
    ### Phase Summary
    - Majority elected L2 in term 4
    - L1 still thinks term 3, still leader
    - L1 doesn't know it's been deposed
  | {
    style.stroke-dash: 3
  }
}

# Phase 4: Client Read to Stale Leader
phase4: "T=3: Client Read to Stale Leader" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  
  client_box: "Client" {
    shape: rectangle
    style.fill: "#E1BEE7"
    client_icon: "👤" {shape: text}
  }
  
  stale_partition: "Minority (Stale Leader)" {
    style.fill: "#FFCDD2"
    style.stroke-dash: 3
    L1_read: "L1 (Stale)\nTerm 3" {
      shape: rectangle
      style.fill: "#FF5722"
      style.font-color: white
    }
    readindex_state: |md
      **ReadIndex Process:**
      1. Record commitIndex = N
      2. Send heartbeat to majority
      3. Wait for quorum ACK
    | {
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
    }
  }
  
  majority_partition: "Majority" {
    style.fill: "#C8E6C9"
    L2_maj: "L2\nTerm 4" {
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
    }
    followers_maj: "F1,F3,F4" {
      shape: rectangle
      style.fill: "#BBDEFB"
    }
  }
  
  client_box -> L1_read: "Read(key='x')" {
    style.stroke: purple
    style.bold: true
  }
  L1_read -> majority_partition: "Heartbeat (term 3)" {
    style.stroke: red
    style.stroke-dash: 5
    label: "✗ BLOCKED ✗"
    style.font-color: red
  }
  
  note4: |md
    ### Phase Summary
    - L1 receives read request
    - L1 tries ReadIndex quorum check
    - Heartbeats blocked by partition
    - **No majority ACK possible**
  | {
    style.stroke-dash: 3
  }
}

# Phase 5: ReadIndex Timeout
phase5: "T=4: ReadIndex Timeout - Request Failed" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 2
  
  client_failed: "Client" {
    shape: rectangle
    style.fill: "#E1BEE7"
  }
  
  stale_leader: "L1 (Stale)\nTerm 3" {
    shape: rectangle
    style.fill: "#9E9E9E"
    style.font-color: white
  }
  
  timeout_result: |md
    **ReadIndex Result:**
    ❌ Confirmations: 1 (self only)
    ❌ Required: 3 (majority of 5)
    ❌ Status: TIMEOUT
    **Response to Client:**
    
    WrongLeader: true
    LeaderId: ""  (unknown)
    Success: false
    Error: "leadership confirmation timeout"
    
  | {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    style.stroke-width: 2
  }
  
  client_failed -> stale_leader: "Read Request"
  stale_leader -> timeout_result: "After electionTimeoutMax\nNo quorum ACK"
  
  note5: |md
    ### Phase Summary
    - Linearizability Preserved
    - Client retries to new leader
    - No stale data returned
  | {
    style.stroke-dash: 3
  }
}

# Success Path Comparison
success_path: "T=4 (Alternative): Client Retries to New Leader" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  
  client_retry: "Client" {
    shape: rectangle
    style.fill: "#E1BEE7"
  }
  
  new_leader_good: "Leader L2\nTerm 4" {
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
  }
  
  majority_good: "Majority [L2,F1,F3,F4]" {
    style.fill: "#C8E6C9"
    followers_good: "Followers" {
      shape: rectangle
      style.fill: "#BBDEFB"
    }
  }
  
  success_result: |md
    **ReadIndex Success:**
    ✓ Confirmations: 3+ (majority)
    ✓ Required: 3
    ✓ Status: CONFIRMED
    **Response:**
    
    WrongLeader: false
    Success: true
    Value: "current_value"
    
  | {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  
  client_retry -> new_leader_good: "Read(key='x')\n(retry)"
  new_leader_good -> majority_good: "Heartbeat"
  majority_good -> new_leader_good: "ACK ✓"
  new_leader_good -> success_result: "Leadership confirmed\nReturn current value"
  
  note_success: |md
    ### Success Path Summary
    1. First request to L1 fails (WrongLeader)
    2. Client discovers L2
    3. Retry to L2 succeeds
  | {
    style.stroke-dash: 3
  }
}

# Flow arrows between phases
phase1 -> phase2: "Network\nFailure" {style.stroke: red; style.bold: true}
phase2 -> phase3: "Election\nTimeout" {style.stroke: blue}
phase3 -> phase4: "Client\nRequest" {style.stroke: purple}
phase4 -> phase5: "ReadIndex\nTimeout" {style.stroke: red; style.bold: true}

# Legend
legend: "Legend" {
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  near: bottom-left
  leg1: "● Leader (valid)" {shape: text; style.fill: "#4CAF50"}
  leg2: "● Leader (stale)" {shape: text; style.fill: "#FF5722"}
  leg3: "● Follower" {shape: text; style.fill: "#BBDEFB"}
  leg4: "--- Partition" {shape: text}
  leg5: "✗ Blocked" {shape: text; style.fill: red}
  leg6: "✓ Success" {shape: text; style.fill: green}
}

# Key invariant box
invariant_box: |md
  ## Safety Invariant: Linearizability
  **Guarantee:** Once a write is acknowledged, all subsequent reads see that write.
  
  **ReadIndex ensures:**
  1. Leader confirms it's still leader via heartbeat quorum
  2. If partitioned, quorum check fails
  3. Stale leader cannot serve reads
  4. Client must retry to valid leader
  
  **Without ReadIndex:** Stale leader could return stale data, violating linearizability.
| {
  near: bottom-right
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
}