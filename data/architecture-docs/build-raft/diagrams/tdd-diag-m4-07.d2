vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# ClientCommand RPC Message Layout
*Technical Specification - Raft Implementation (Module 4)*
'| {near: top-center}

direction: right

# Global classes for consistency
classes: {
  fixed_field: {
    style: {
      fill: "#DBEAFE"
      stroke: "#93C5FD"
      stroke-width: 1
    }
  }
  var_field: {
    style: {
      fill: "#BFDBFE"
      stroke: "#60A5FA"
      stroke-width: 1
    }
  }
  bool_field: {
    style: {
      fill: "#FEF3C7"
      stroke: "#FCD34D"
      stroke-width: 1
    }
  }
  header_row: {
    style: {
      fill: "#6D28D9"
      font-color: white
      stroke: "#4C1D95"
      bold: true
    }
  }
}

Request: "ClientCommandArgs (RPC Request)" {
  style.fill: "#F3F4F6"
  style.stroke: "#2563EB"
  style.stroke-width: 2
  grid-columns: 1
  grid-gap: 0

  header_r: {
    class: header_row
    label: |'md **Offset** | **Field Name** | **Type** | **Size** '|
  }

  client_id_len: {
    class: fixed_field
    label: |'md **0** | ClientIdLen | int64 | 8 bytes '|
  }

  client_id: {
    class: var_field
    label: |'md **8** | ClientId | bytes | *L1* (UTF-8) '|
  }

  seq_num: {
    class: fixed_field
    label: |'md **8 + L1** | SequenceNumber | int64 | 8 bytes '|
  }

  cmd_type: {
    class: fixed_field
    label: |'md **16 + L1** | CommandType | int64 | 8 bytes '|
  }

  cmd_len: {
    class: fixed_field
    label: |'md **24 + L1** | CommandLen | int64 | 8 bytes '|
  }

  cmd_data: {
    class: var_field
    label: |'md **32 + L1** | Command | bytes | *L2* (JSON) '|
  }

  total_r: {
    label: |'md **Total: 32 + L1 + L2 bytes** '|
    style: {
      fill: "#1E40AF"
      font-color: white
      stroke: "#1E3A8A"
      bold: true
    }
  }
}

Response: "ClientCommandReply (RPC Response)" {
  style.fill: "#FFFBEB"
  style.stroke: "#D97706"
  style.stroke-width: 2
  grid-columns: 1
  grid-gap: 0

  header_w: {
    class: header_row
    label: |'md **Offset** | **Field Name** | **Type** | **Size** '|
  }

  success: {
    class: bool_field
    label: |'md **0** | Success | bool | 1 byte '|
  }

  leader_len: {
    class: fixed_field
    label: |'md **1** | LeaderIdLen | int64 | 8 bytes '|
  }

  leader_id: {
    class: var_field
    label: |'md **9** | LeaderId | bytes | *L1* (UTF-8) '|
  }

  wrong_leader: {
    class: bool_field
    label: |'md **9 + L1** | WrongLeader | bool | 1 byte '|
  }

  resp_len: {
    class: fixed_field
    label: |'md **10 + L1** | ResponseLen | int64 | 8 bytes '|
  }

  resp_data: {
    class: var_field
    label: |'md **18 + L1** | Response | bytes | *R* (JSON) '|
  }

  err_len: {
    class: fixed_field
    label: |'md **18 + L1 + R** | ErrorLen | int64 | 8 bytes '|
  }

  err_data: {
    class: var_field
    label: |'md **26 + L1 + R** | Error | bytes | *E* (UTF-8) '|
  }

  total_w: {
    label: |'md **Total: 26 + L1 + R + E bytes** '|
    style: {
      fill: "#92400E"
      font-color: white
      stroke: "#78350F"
      bold: true
    }
  }
}

legend: {
  near: bottom-center
  grid-columns: 2
  grid-gap: 15
  
  l1: "Fixed-width (8B)" {
    class: fixed_field
  }
  l2: "Variable-length" {
    class: var_field
  }
  l3: "Control (1B)" {
    class: bool_field
  }
  l4: "Table Header" {
    class: header_row
  }
}

Request -> Response: "RPC Lifecycle" {
  style: {
    stroke: "#6B7280"
    stroke-dash: 3
    animated: true
  }
}