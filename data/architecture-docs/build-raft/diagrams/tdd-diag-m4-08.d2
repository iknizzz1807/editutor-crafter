vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # No-Op Commit for Linearizable Read
  Alternative to ReadIndex: append no-op entry, wait for commit and apply, then serve read
  **Trade-off**: Simpler implementation, higher latency (full replication vs heartbeat quorum)
| {near: top-center}
direction: right
# === TIMELINE CONTAINER ===
timeline: {
  grid-rows: 5
  grid-columns: 1
  grid-gap: 0
  # Row 1: Leader
  leader_header: "LEADER" {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      bold: true
      font-size: 18
    }
  }
  # Row 2: Leader Timeline
  leader_timeline: {
    style.fill: transparent
    direction: right
    # Step 1: Receive Read
    step1: "① Read Request" {
      shape: rectangle
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
        stroke-width: 2
      }
    }
    # Step 2: Create No-Op
    step2: "② Append No-Op\nEntry to Log" {
      shape: rectangle
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
        stroke-width: 2
      }
    }
    # Step 3: Replicate
    step3: "③ Replicate to\nFollowers" {
      shape: rectangle
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
    }
    # Step 4: Commit
    step4: "④ Commit\n(Majority ACK)" {
      shape: rectangle
      style: {
        fill: "#F3E5F5"
        stroke: "#7B1FA2"
        stroke-width: 2
      }
    }
    # Step 5: Apply & Read
    step5: "⑤ Apply No-Op\n→ Serve Read" {
      shape: rectangle
      style: {
        fill: "#4CAF50"
        stroke: "#1B5E20"
        stroke-width: 2
        font-color: white
        bold: true
      }
    }
    step1 -> step2 -> step3 -> step4 -> step5: {
      style.stroke: "#666"
      style.stroke-width: 2
    }
  }
  # Row 3: Follower Header
  follower_header: "FOLLOWERS (F1, F2, F3, F4)" {
    style: {
      fill: "#F5F5F5"
      stroke: "#757575"
      stroke-width: 2
      bold: true
      font-size: 18
    }
  }
  # Row 4: Follower Timeline
  follower_timeline: {
    style.fill: transparent
    direction: right
    f1: "Receive\nAppendEntries" {
      shape: rectangle
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
      }
    }
    f2: "Append to\nLocal Log" {
      shape: rectangle
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
      }
    }
    f3: "Persist\nto Disk" {
      shape: rectangle
      style: {
        fill: "#FFF8E1"
        stroke: "#F57F17"
      }
    }
    f4: "Send ACK\nto Leader" {
      shape: rectangle
      style: {
        fill: "#F3E5F5"
        stroke: "#7B1FA2"
      }
    }
    f5: "Receive\nCommit Index" {
      shape: rectangle
      style: {
        fill: "#4CAF50"
        stroke: "#1B5E20"
        font-color: white
      }
    }
    f1 -> f2 -> f3 -> f4 -> f5: {
      style.stroke: "#999"
      style.stroke-dash: 3
    }
  }
  # Row 5: Annotations
  annotations: |md
    **Latency**: ~2-3 RTT (Replication + Commit + Apply)
    **Guarantee**: Once no-op applied, leader is confirmed and all prior entries are committed
  | {
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
    style.border-radius: 8
  }
}
# === LOG STATE DIAGRAM ===
log_states: {
  label: "Log State Progression"
  direction: right
  before: "Before:\n[1:1][1:2][1:3]...[T:N]" {
    shape: rectangle
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      font: mono
      font-size: 12
    }
  }
  arrow1: "→" {
    shape: text
    style.font-size: 24
    style.bold: true
  }
  after_append: "After Append:\n[1:1][1:2]...[T:N][T+1:N+1]\n↑ No-Op Entry" {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      font: mono
      font-size: 12
    }
  }
  arrow2: "→" {
    shape: text
    style.font-size: 24
    style.bold: true
  }
  after_commit: "After Commit:\n[1:1][1:2]...[T:N][T+1:N+1]\n      ↑ COMMITTED" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      font: mono
      font-size: 12
      bold: true
    }
  }
}
# === COMPARISON TABLE ===
comparison: {
  label: "ReadIndex vs No-Op Commit"
  readindex: "ReadIndex" {
    shape: rectangle
    width: 200
    ri_title: "ReadIndex" {
      style.bold: true
      style.fill: "#BBDEFB"
    }
    ri_latency: |md
      **Latency**: ~1 RTT
      (heartbeat quorum only)
    |
    ri_complexity: |md
      **Complexity**: Higher
      (track pending reads, quorum confirmation)
    |
    ri_guarantee: |md
      **Guarantee**: Leadership confirmed
      via heartbeat acknowledgment
    |
    style.fill: white
    style.stroke: "#1565C0"
  }
  noop: "No-Op Commit" {
    shape: rectangle
    width: 200
    noop_title: "No-Op Commit" {
      style.bold: true
      style.fill: "#C8E6C9"
    }
    noop_latency: |md
      **Latency**: ~2-3 RTT
      (full replication + commit + apply)
    |
    noop_complexity: |md
      **Complexity**: Lower
      (reuse existing commit path)
    |
    noop_guarantee: |md
      **Guarantee**: Entry committed
      transitively commits all prior
    |
    style.fill: white
    style.stroke: "#2E7D32"
  }
  readindex <-> noop: "Trade-off" {
    style.stroke-dash: 5
    style.stroke: "#666"
  }
}
# === SAFETY EXPLANATION ===
safety: {
  label: "Why This Ensures Linearizability"
  explanation: |md
    ### Safety Guarantee
    Once the no-op entry is **committed**:
    1. **Leader Confirmed**: Only the legitimate leader could have committed an entry 
       in term T+1 (requires majority acknowledgment)
    2. **No Stale Leader**: A partitioned leader cannot commit, so ReadIndex timeout 
       would catch this
    3. **Prior Entries Sealed**: By Figure 8 rule, committing the no-op transitively 
       commits all entries before it
    4. **Read Sees All Writes**: Any write acknowledged before this read started is 
       now committed and will be visible
  | {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      border-radius: 8
    }
  }
  figure8_note: |md
    **Figure 8 Connection**: The no-op entry from the current term serves as the 
    "seal" that makes all previous entries (from any term) safely committed.
  | {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      border-radius: 8
    }
  }
  explanation -> figure8_note: {
    style.stroke: "#999"
    style.stroke-dash: 3
  }
}
# === PSEUDOCODE ===
pseudocode: |go
  // ReadWithNoOp - Simpler linearizable read
  func (rf *RaftNode) ReadWithNoOp(key string) (interface{}, error) {
      rf.mu.Lock()
      // Step 1: Check leadership
      if rf.state != Leader {
          rf.mu.Unlock()
          return nil, ErrWrongLeader
      }
      // Step 2: Create and append no-op entry
      noOp := &NoOpCommand{}
      entry := LogEntry{
          Term:    rf.currentTerm,
          Command: noOp,
          Index:   rf.logLastIndex() + 1,
      }
      rf.log = append(rf.log, entry)
      rf.persist()
      noOpIndex := entry.Index
      // Step 3: Register for notification
      responseCh := make(chan struct{}, 1)
      rf.pendingNoOps[noOpIndex] = responseCh
      rf.mu.Unlock()
      // Step 4: Wait for no-op to be applied (with timeout)
      select {
      case <-responseCh:
          // No-op applied, leadership confirmed
          rf.mu.RLock()
          value := rf.stateMachine.Get(key)
          rf.mu.RUnlock()
          return value, nil
      case <-time.After(rf.electionTimeoutMax * 2):
          // Timeout - likely lost leadership
          rf.mu.Lock()
          delete(rf.pendingNoOps, noOpIndex)
          rf.mu.Unlock()
          return nil, ErrWrongLeader
      }
  }
| {
  style: {
    fill: "#263238"
    font-color: "#ECEFF1"
    font: mono
    font-size: 11
    border-radius: 8
  }
}