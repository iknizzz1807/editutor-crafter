vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Session State Replication
  Session state is part of the replicated state machine, ensuring deduplication
  survives leader changes and is included in snapshots.
| {near: top-center}

direction: right

classes: {
  node: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
  leader: {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
      stroke-width: 3
    }
  }
  session_box: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-dash: 3
    }
  }
  snapshot: {
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
    }
  }
}

Client: {
  shape: person
  label: Client
  style.fill: "#E3F2FD"
}

Cluster: {
  direction: right
  
  Leader1: "Leader (Term 1)" {
    class: leader
    shape: rectangle
    
    Log1: Log {
      shape: rectangle
      style.fill: "#BBDEFB"
      e1: "Entry 1\n{cmd: 'put x=1'}\nseq: 5"
      e2: "Entry 2\n{cmd: 'put y=2'}\nseq: 6"
      e3: "Entry 3\n{cmd: 'put z=3'}\nseq: 7"
    }
    
    SessionState1: "Session State" {
      class: session_box
      shape: rectangle
      sessionA: "Client-A\nlastSeq: 5\nlastResp: OK"
      sessionB: "Client-B\nlastSeq: 6\nlastResp: OK"
    }
    
    StateMachine1: "KV Store" {
      shape: cylinder
      style.fill: "#FFECB3"
      data: "x=1, y=2, z=3"
    }
  }
  
  Leader1.Log1 -> Leader1.StateMachine1: Apply
  Leader1.Log1 -> Leader1.SessionState1: Update
  Leader1.SessionState1 <-> Leader1.StateMachine1: "Dedup Check"
}

Follower2: "Follower A" {
  class: node
  Log2: "Log (Replicated)" {
    shape: rectangle
    style.fill: "#BBDEFB"
    e1f: "Entry 1\n{cmd: 'put x=1'}\nseq: 5"
    e2f: "Entry 2\n{cmd: 'put y=2'}\nseq: 6"
    e3f: "Entry 3\n{cmd: 'put z=3'}\nseq: 7"
  }
  SessionState2: "Session State\n(Replicated)" {
    class: session_box
    shape: rectangle
    content2: "Client-A: seq=5\nClient-B: seq=6"
  }
  StateMachine2: "KV Store" {
    shape: cylinder
    style.fill: "#FFECB3"
  }
}

Follower3: "Follower B" {
  class: node
  Log3: "Log (Replicated)" {
    shape: rectangle
    style.fill: "#BBDEFB"
    e1g: "Entry 1\n{cmd: 'put x=1'}\nseq: 5"
    e2g: "Entry 2\n{cmd: 'put y=2'}\nseq: 6"
    e3g: "Entry 3\n{cmd: 'put z=3'}\nseq: 7"
  }
  SessionState3: "Session State\n(Replicated)" {
    class: session_box
    shape: rectangle
    content3: "Client-A: seq=5\nClient-B: seq=6"
  }
  StateMachine3: "KV Store" {
    shape: cylinder
    style.fill: "#FFECB3"
  }
}

Client -> Cluster.Leader1: "SubmitCommand\n{clientId: 'A', seq: 5, cmd: 'put x=1'}"
Cluster.Leader1 -> Follower2: "AppendEntries\n(entries + sessions)"
Cluster.Leader1 -> Follower3: "AppendEntries\n(entries + sessions)"

Follower2.Log2 -> Follower2.SessionState2: "Apply updates"
Follower2.SessionState2 -> Follower2.StateMachine2: "Dedup & apply"

Follower3.Log3 -> Follower3.SessionState3: "Apply updates"
Follower3.SessionState3 -> Follower3.StateMachine3: "Dedup & apply"

SnapshotFlow: "Snapshot Inclusion" {
  near: bottom-center
  direction: right
  Snapshot: "Snapshot File" {
    class: snapshot
    shape: rectangle
    metadata: "Metadata\n{lastIdx: 1000, lastTerm: 5}"
    kvdata: "KV Data\n{x=1, y=2, ...}"
    sessions: "Session State\n{Client-A: seq=5, Client-B: seq=6}"
  }
  Note: |md
    Session state is included in
    snapshots for deduplication
    continuity across recovery.
  | {shape: text}
}

Cluster.Leader1.SessionState1 -> SnapshotFlow.Snapshot: "Included in snapshot"

LeaderChangeScenario: "Leader Change Scenario" {
  near: bottom-right
  direction: down
  Step1: "1. Leader1 crashes" {
    shape: rectangle
    style.fill: "#FFCDD2"
  }
  Step2: "2. Follower2 elected\n(Term 2)" {
    shape: rectangle
    class: leader
  }
  Step3: "3. Client retries\nseq=5 to new leader" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  Step4: "4. Dedup check:\nseq=5 <= lastSeq=5\n→ Return cached response" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.bold: true
  }
  Step1 -> Step2 -> Step3 -> Step4
}

DedupFlow: "Duplicate Detection Flow" {
  near: top-right
  direction: down
  Input: "Apply(ClientCmd)" {
    shape: oval
    style.fill: "#E1F5FE"
  }
  Check: "Lookup Session\n{clientId → session}" {
    shape: diamond
    style.fill: "#FFF9C4"
  }
  Duplicate: "seq <= lastSeq?" {
    shape: diamond
    style.fill: "#FFF9C4"
  }
  CacheHit: "Return\ncached response" {
    shape: rectangle
    style.fill: "#A5D6A7"
  }
  Apply: "Apply command\nUpdate session" {
    shape: rectangle
    style.fill: "#90CAF9"
  }
  Input -> Check
  Check -> Duplicate: "Session found"
  Duplicate -> CacheHit: "YES"
  Duplicate -> Apply: "NO"
  Apply -> CacheHit
}

Key: {
  near: bottom-left
  direction: right
  LeaderKey: Leader {
    class: leader
  }
  FollowerKey: Follower {
    class: node
  }
  SessionKey: "Session State" {
    class: session_box
  }
  SnapshotKey: Snapshot {
    class: snapshot
  }
}

Annotation: |md
  ## Key Invariants
  1. **Session State is Replicated**: Part of state machine, survives
     leader changes because it goes through Raft consensus.
  2. **Deduplication Works Across Leaders**: When leader changes,
     new leader has same session state → no double-execution.
  3. **Snapshots Include Sessions**: After snapshot recovery,
     deduplication continues to work correctly.
  4. **Exactly-Once Semantics**: Client retries are safe because
     (clientId, sequenceNumber) uniquely identifies each operation.
| {near: center-left}