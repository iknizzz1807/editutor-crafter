vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Pending Commands Tracker
  **Leader-side response coordination mechanism**
| {near: top-center}
direction: right
Client: {
  shape: person
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
}
Leader: {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  SubmitHandler: {
    shape: rectangle
    label: "SubmitCommand()\nHandler"
    style.fill: "#FFE0B2"
  }
  PendingMap: {
    label: "pendingCommands\nmap[int]chan *CommandResult"
    shape: cylinder
    style.fill: "#FFCC80"
    style.stroke: "#E65100"
  }
  LogArray: {
    label: "log []LogEntry"
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
  }
  SubmitHandler -> PendingMap: "3. Register\nresponseCh" {style.stroke: "#1565C0"}
  SubmitHandler -> LogArray: "2. Append entry" {style.stroke: "#2E7D32"}
}
ApplyLoop: {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  ApplyHandler: {
    shape: rectangle
    label: "Apply Loop\n(lastApplied < commitIndex)"
    style.fill: "#C8E6C9"
  }
  StateMachine: {
    label: "StateMachine\n.Apply()"
    shape: rectangle
    style.fill: "#A5D6A7"
  }
  ApplyHandler -> StateMachine: "Apply command" {style.stroke: "#388E3C"}
  ApplyHandler -> Leader.PendingMap: "4. Notify\nvia channel" {
    style.stroke: "#D32F2F"
    style.bold: true
  }
}
TimeoutHandler: {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  Timer: {
    shape: circle
    label: "Timeout\nTimer"
    style.fill: "#FFCDD2"
  }
  Timer -> Leader.PendingMap: "5. Cleanup\non timeout" {
    style.stroke: "#B71C1C"
    style.stroke-dash: 3
  }
}
Client -> Leader.SubmitHandler: "1. SubmitCommand\n(args, reply)" {
  style.stroke: "#1565C0"
  style.animated: true
}
Leader.PendingMap -> Client: "6. Response\ndelivered" {
  style.stroke: "#1565C0"
  style.stroke-dash: 5
}
StateMachine -> Client: "Response via\nresponseCh" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  step1: "1. Client submits command"
  step2: "2. Leader appends to log"
  step3: "3. Channel registered in pendingCommands"
  step4: "4. Apply loop notifies via channel"
  step5: "5. Timeout cleans up if no response"
  step6: "6. Response delivered to client"
}
Lifecycle: {
  near: bottom-right
  label: "Entry Lifecycle"
  shape: rectangle
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  |md
  
  pendingCommands[index] lifecycle:
  CREATE: SubmitCommand()
    ch := make(chan *CommandResult, 1)
    pendingCommands[entry.Index] = ch
  NOTIFY: Apply loop
    response := stateMachine.Apply(entry)
    select {
    case ch <- response:
    default: // channel full, client timed out
    }
    delete(pendingCommands, index)
  CLEANUP: Timeout
    delete(pendingCommands, index)
  
  |
}
DataStructure: {
  near: top-right
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  |md
  go
  type RaftNode struct {
    pendingCommands map[int]chan *CommandResult
    // Key: log index
    // Value: response channel
  }
  type CommandResult struct {
    Response interface{}
    Error    error
  }
  
  |
}
ThreadSafety: {
  near: bottom-left
  shape: rectangle
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  |md
  **Thread Safety**
  - `rf.mu` protects `pendingCommands` map
  - Register: `rf.mu.Lock()` held
  - Notify: `rf.mu.Lock()` held in apply loop
  - Channel send: non-blocking (buffered, size 1)
  |
}