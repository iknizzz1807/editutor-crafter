direction: right
title: |md
  # Raft Safety Invariants
| {near: top-center}
invariant_box: {
  style.fill: "#E8F4F8"
  style.stroke: "#7C3AED"
  style.stroke-width: 2
  style.border-radius: 8
  style.shadow: true
  inv1: {
    label: |md
      ## 1. Election Safety
      **At most one leader per term**
      - Quorum intersection guarantees overlap
      - Any two majorities share ≥1 node
      - That node cannot vote twice
    |
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    style.border-radius: 6
  }
  inv2: {
    label: |md
      ## 2. Leader Completeness
      **Committed entries in all leaders**
      - Log up-to-date check in RequestVote
      - New leader must have all committed entries
      - Prevents data loss
    |
    style.fill: "#FEF3C7"
    style.stroke: "#A855F7"
    style.border-radius: 6
  }
  inv3: {
    label: |md
      ## 3. Log Matching
      **Same (index, term) → same prefix**
      - Inductive consistency check
      - prevLogIndex/prevLogTerm verification
      - Logs converge
    |
    style.fill: "#D1FAE5"
    style.stroke: "#EC4899"
    style.border-radius: 6
  }
  inv4: {
    label: |md
      ## 4. State Machine Safety
      **Same index → same command**
      - Sequential application
      - Deterministic execution
      - Client observes consistency
    |
    style.fill: "#CCFBF1"
    style.stroke: "#14B8A6"
    style.border-radius: 6
  }
}
cluster_box: {
  label: "5-Node Cluster"
  style.fill: "#F9FAFB"
  style.stroke: "#9CA3AF"
  style.stroke-dash: 4
  style.border-radius: 8
  n1: {shape: circle; style.fill: "#BBF7D0"; label: "F"}
  n2: {shape: circle; style.fill: "#BBF7D0"; label: "F"}
  n3: {shape: circle; style.fill: "#FDE68A"; label: "L"; style.stroke: "#F59E0B"; style.stroke-width: 3}
  n4: {shape: circle; style.fill: "#BBF7D0"; label: "F"}
  n5: {shape: circle; style.fill: "#BBF7D0"; label: "F"}
  n1 -- n2 -- n3 -- n4 -- n5
}
leader_term: {
  label: |md
    **Term 3 Leader**
    - Single coordinator
    - Elected via majority vote
    - Maintains authority via heartbeats
  |
  style.fill: "#FEF3C7"
  style.border-radius: 6
  style.stroke: "#A855F7"
}
log_match: {
  label: |md
    **Log Matching Property**
    
    If log[i].term == log[i].term
       across nodes
    Then log[1..i-1] identical
    
  |
  style.fill: "#D1FAE5"
  style.border-radius: 6
  style.stroke: "#EC4899"
  style.font: mono
}
state_machine: {
  label: |md
    **State Machine Application**
    
    for i := 1..commitIndex {
      apply(log[i].command)
    }
    
  |
  style.fill: "#CCFBF1"
  style.border-radius: 6
  style.stroke: "#14B8A6"
  style.font: mono
}
invariant_box.inv1 -> cluster_box.n3: enforces
invariant_box.inv2 -> leader_term
invariant_box.inv3 -> log_match
invariant_box.inv4 -> state_machine
cluster_box.n3 -> leader_term: current leader
log_match -> state_machine: ensures