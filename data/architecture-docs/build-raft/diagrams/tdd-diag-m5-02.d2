vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

"System Design Specifications": {
  "Invariant Checker Architecture": {
    shape: sequence_diagram
    
    # ---------------------------------------------------------------------------
    # Participant Definitions (Lifelines)
    # ---------------------------------------------------------------------------
    tr: Test Runner {
      shape: person
      label: "Test Runner\n(Orchestrator)"
      style: {
        fill: "#DEE1EB"
        stroke: "#2B3467"
        stroke-width: 2
      }
    }
    
    ic: Invariant Checker {
      label: "Invariant Checker\n(Safety Monitor)"
      style: {
        fill: "#C6E6FB"
        stroke: "#007BFF"
        stroke-width: 2
      }
    }
    
    cc: Chaos Controller {
      label: "Chaos Controller\n(Fault Injector)"
      style: {
        fill: "#FCE7C6"
        stroke: "#F39C12"
        stroke-width: 2
      }
    }
    
    cl: Target Cluster {
      label: "Target Cluster\n(SUT)"
      style: {
        fill: "#D4F0D1"
        stroke: "#27AE60"
        stroke-width: 2
        multiple: true
      }
    }

    # ---------------------------------------------------------------------------
    # 1. Initialization Phase
    # ---------------------------------------------------------------------------
    Initialization: {
      style: {
        stroke: "#7F8C8D"
        stroke-dash: 2
      }
      
      tr -> ic: Start (64B config_params)
      ic."Establish polling interval & safety predicates"
      
      ic -> tr: ACK (started: 8B) {
        style.stroke-dash: 3
      }
      
      tr -> cc: Start (chaos_profile_v1)
      cc."Load fault models (Network, Disk, CPU)"
      
      cc -> tr: ACK (started: 8B) {
        style.stroke-dash: 3
      }
      
      tr -> cl: Boot Cluster (nodes=5, v1.2.0)
      cl -> tr: Status (running, quorum=ready) {
        style.stroke-dash: 3
      }
    }

    # ---------------------------------------------------------------------------
    # 2. Main Test Loop
    # ---------------------------------------------------------------------------
    "Main Execution Loop": {
      label: "Main Execution Loop: Duration T"
      
      "Parallel: Monitoring & Chaos": {
        label: "Parallel: Invariant Monitoring & Chaos Injection"
        style.fill: "#F8F9F9"
        
        "Loop: State Verification": {
          label: "Loop: State Verification [Tick Rate: 100ms]"
          
          tr -> ic: trigger_check()
          ic -> cl: snapshot_all_nodes()
          
          "Violation Logic": {
            label: "alt: Violation Detection"
            ic -> ic: record_violation(state_diff) {
              label: "LOG VIOLATION: CRITICAL FAILURE"
              style: {
                stroke: "#E74C3C"
                font-color: "#E74C3C"
                bold: true
              }
            }
          }
        }

        "Loop: Fault Injection": {
          label: "Loop: Fault Injection [Interval: Poisson Process]"
          
          tr -> cc: tick(current_time)
          cc -> cl: inject_random_failure()
          
          "Failure Modes": {
            label: "alt: Failure Modes"
            cc -> cl: partition_between(nodes_A, nodes_B) {
              label: "Create Network Partition"
              style.stroke: "#D35400"
            }
            cc -> cl: kill_node(node_id) {
              label: "SIGKILL [Hard Reset]"
              style.stroke: "#C0392B"
            }
            cc -> cl: restart_node(node_id) {
              label: "SIGTERM + START [Graceful]"
              style.stroke: "#2980B9"
            }
          }
        }
      }
    }

    # Execution duration marker
    tr -> tr: wait(test_duration) {
      label: "Execution window: 600s"
      style.stroke: "#2C3E50"
    }

    # ---------------------------------------------------------------------------
    # 3. Teardown Phase
    # ---------------------------------------------------------------------------
    Teardown: {
      style: {
        stroke: "#E74C3C"
        stroke-dash: 2
      }
      
      tr -> cc: stop()
      cc -> cl: heal_all_partitions()
      cc -> cl: start_all_nodes()
      
      tr -> ic: stop_and_dump_stats()
      ic -> tr: final_report.json (1.2MB) {
        style.stroke-dash: 3
      }
      tr."Aggregated safety metrics & WAL summary"
      
      tr -> cl: shutdown_infrastructure()
    }
  }

  # ---------------------------------------------------------------------------
  # Documentation & Technical Specifications
  # ---------------------------------------------------------------------------
  implementation_notes: |md
    ### Implementation Grade Specs
    - **Persistence**: Violations are written to WAL (Write-Ahead Log) before reporting.
    - **Recovery**: Chaos Controller implements an 'Auto-Heal' policy on exit to prevent infrastructure leaks.
    - **Safety**: Invariant Checker utilizes read-only RPCs; zero-side-effect guarantee on Target Cluster.
    - **Timing**: `trigger_check` latency must be < 50% of the tick interval to prevent drift.
    - **Size**: Average payload per check is ~256KB for a 5-node cluster state.
  | {
    shape: rectangle
    style: {
      stroke: "#222222"
      stroke-width: 2
      fill: "#FFFFFF"
      font-size: 14
    }
  }

  # Fixed absolute path for 'near' positioning
  implementation_notes.near: "System Design Specifications"."Invariant Checker Architecture"
}

# ---------------------------------------------------------------------------
# Global Styling for Sequence diagram internal elements
# ---------------------------------------------------------------------------
"System Design Specifications"."Invariant Checker Architecture".**: {
  style: {
    stroke: "#222222"
    stroke-width: 2
    font-size: 14
    font-color: "#1A1A1A"
  }
}

("System Design Specifications"."Invariant Checker Architecture".** -> "System Design Specifications"."Invariant Checker Architecture".**)[*]: {
  style: {
    stroke: "#34495E"
    font-size: 12
    font-color: "#2C3E50"
  }
}

# Specific lifeline color overrides for visual clarity
"System Design Specifications"."Invariant Checker Architecture".tr.style.stroke: "#2B3467"
"System Design Specifications"."Invariant Checker Architecture".ic.style.stroke: "#007BFF"
"System Design Specifications"."Invariant Checker Architecture".cc.style.stroke: "#F39C12"
"System Design Specifications"."Invariant Checker Architecture".cl.style.stroke: "#27AE60"