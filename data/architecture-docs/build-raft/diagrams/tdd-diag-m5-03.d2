vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Election Safety Check Algorithm
  **Invariant: At most one leader per term**
| {near: top-center}
step_1: {
  label: "Step 1: Collect Leaders by Term"
  nodes_group: {
    label: "Cluster Nodes"
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    node_A: "Node A\nLeader\nTerm: 3" {
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.bold: true
    }
    node_B: "Node B\nLeader\nTerm: 3" {
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.bold: true
    }
    node_C: "Node C\nFollower\nTerm: 3" {
      style.fill: "#D3D3D3"
    }
    node_D: "Node D\nFollower\nTerm: 3" {
      style.fill: "#D3D3D3"
    }
    node_E: "Node E\nFollower\nTerm: 3" {
      style.fill: "#D3D3D3"
    }
  }
  collection: {
    label: "Collection Process"
    style.fill: "#FFF8DC"
    style.stroke: "#DAA520"
    iterate: |md
      go
      leadersByTerm := make(map[int][]string)
      for _, node := range nodes {
          if node.State == Leader {
              term := node.CurrentTerm
              leadersByTerm[term] = append(
                  leadersByTerm[term], 
                  node.ID
              )
          }
      }
      
    |
  }
  result_map: {
    label: "Result: leadersByTerm"
    style.fill: "#E6E6FA"
    style.stroke: "#9370DB"
    term_3: "Term 3 → [Node A, Node B]" {
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
      style.bold: true
    }
  }
  nodes_group -> collection: "iterate"
  collection -> result_map: "build map"
}
step_2: {
  label: "Step 2: Verify At Most One Leader Per Term"
  verification: {
    label: "Verification Loop"
    style.fill: "#E0FFFF"
    style.stroke: "#008B8B"
    code: |md
      go
      for term, leaders := range leadersByTerm {
          if len(leaders) > 1 {
              // VIOLATION DETECTED!
              return error
          }
      }
      
    |
  }
  check_visual: {
    label: "Term-by-Term Check"
    style.fill: "#F5F5F5"
    term_check_1: {
      label: "Check Term 3"
      style.fill: "#FFB6C1"
      count: "len(leaders) = 2" {
        style.fill: "#FF6347"
        style.font-color: "white"
        style.bold: true
      }
      threshold: "threshold = 1" {
        style.fill: "#90EE90"
      }
      comparison: "2 > 1 → VIOLATION!" {
        style.fill: "#FF0000"
        style.font-color: "white"
        style.bold: true
      }
    }
  }
  verification -> check_visual: "evaluate"
}
step_3: {
  label: "Step 3: Report Violation"
  violation_report: {
    label: "Violation Record"
    style.fill: "#FFE4E1"
    style.stroke: "#DC143C"
    style.stroke-width: 3
    type: "Type: ViolationElectionSafety" {
      style.fill: "#FF6B6B"
      style.font-color: "white"
      style.bold: true
    }
    message: |md
      **Message:**
      "ELECTION SAFETY VIOLATION: term 3 has 2 leaders: [Node A, Node B]"
    | {
      style.fill: "#FFF0F0"
    }
    timestamp: "Timestamp: 2024-01-15T10:30:00Z"
    state_snapshot: "State Snapshot: Captured" {
      style.fill: "#FFFACD"
    }
  }
  error_return: {
    label: "Error Return"
    style.fill: "#FF4444"
    style.font-color: "white"
    style.bold: true
    return_val: "return fmt.Errorf(violation_message)"
  }
  violation_report -> error_return: "propagate"
}
flow: {
  label: "Algorithm Flow"
  start: "START" {
    shape: circle
    style.fill: "#90EE90"
  }
  collect: "Collect\nLeaders" {
    shape: rectangle
    style.fill: "#87CEEB"
  }
  check: "Check Each\nTerm" {
    shape: diamond
    style.fill: "#FFD700"
  }
  more_than_one: "len(leaders) > 1?" {
    shape: diamond
    style.fill: "#FFA500"
  }
  report: "Report\nViolation" {
    shape: rectangle
    style.fill: "#FF6347"
    style.font-color: "white"
  }
  continue: "Continue\nNext Term" {
    shape: rectangle
    style.fill: "#98FB98"
  }
  success: "RETURN nil\n(Safe)" {
    shape: circle
    style.fill: "#32CD32"
  }
  fail: "RETURN error\n(Violation)" {
    shape: circle
    style.fill: "#DC143C"
    style.font-color: "white"
  }
  start -> collect
  collect -> check
  check -> more_than_one
  more_than_one -> report: "YES"
  more_than_one -> continue: "NO"
  continue -> check: "more terms"
  check -> success: "all checked"
  report -> fail
}
invariant_box: {
  label: "INVARIANT"
  style.fill: "#4169E1"
  style.font-color: "white"
  style.bold: true
  text: |md
    **Election Safety**
    At most one leader can be elected in a given term.
    *Enforced by:* Quorum intersection — any two majorities overlap by at least one node, and that node cannot vote twice in the same term.
  |
}
step_1 -> step_2 -> step_3