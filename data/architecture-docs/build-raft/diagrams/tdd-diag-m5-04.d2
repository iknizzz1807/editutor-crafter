vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

direction: right

# -----------------------------------------------------------------------------------------
# GLOBAL TITLE & HEADER
# -----------------------------------------------------------------------------------------
title: {
  shape: text
  label: |md
    # Leader Completeness Proof Sketch
    **Invariant:** Committed entries are guaranteed to be present in all future leaders.
  |
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
    bold: true
  }
}

# -----------------------------------------------------------------------------------------
# CLUSTER TOPOLOGY SECTION
# -----------------------------------------------------------------------------------------
cluster: 5-Node Cluster (N=5) {
  style: {
    fill: "#F8F9FA"
    stroke: "#D1D5DB"
    stroke-dash: 3
    stroke-width: 2
    border-radius: 12
  }
  
  node_a: A {
    tooltip: "In M1"
    style: { fill: "#B5D8F7"; stroke: "#4A90D9" }
  }
  node_b: B {
    tooltip: "In M1"
    style: { fill: "#B5D8F7"; stroke: "#4A90D9" }
  }
  node_c: C {
    label: "C (Witness Node)"
    tooltip: "Intersection Node: M1 ∩ M2"
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 4
      double-border: true
    }
  }
  node_d: D {
    tooltip: "In M2"
    style: { fill: "#FFE0B2"; stroke: "#F69E03" }
  }
  node_e: E {
    tooltip: "In M2"
    style: { fill: "#FFE0B2"; stroke: "#F69E03" }
  }

  node_a -> node_b -> node_c -> node_d -> node_e: {style.stroke-width: 0}
}

# -----------------------------------------------------------------------------------------
# QUORUM DEFINITIONS
# -----------------------------------------------------------------------------------------
m1_quorum: {
  label: |md
    ### M1: Commit Quorum
    - Entry replicated to majority
    - Nodes: {A, B, C}
    - $|M_1| = \lfloor N/2 \rfloor + 1 = 3$
  |
  near: top-left
  style: {
    fill: "#E3F2FD"
    stroke: "#4A90D9"
    stroke-width: 2
    border-radius: 8
  }
}

m2_quorum: {
  label: |md
    ### M2: Election Quorum
    - Candidate needs majority votes
    - Nodes: {C, D, E}
    - $|M_2| = \lfloor N/2 \rfloor + 1 = 3$
  |
  near: top-right
  style: {
    fill: "#FFF8E1"
    stroke: "#F69E03"
    stroke-width: 2
    border-radius: 8
  }
}

# -----------------------------------------------------------------------------------------
# PROOF LOGIC PIPELINE
# -----------------------------------------------------------------------------------------
proof_pipeline: Logic Flow Pipeline {
  style: {
    fill: "#FFFFFF"
    stroke: "#9E9E9E"
    stroke-width: 1
    padding: 20
  }

  step1: {
    label: |md
      **1. Majority Persistence**
      Entry E is committed on majority **M1**.
      $|M_1| \ge 3$ nodes possess E.
    |
    style.stroke: "#4A90D9"
  }

  step2: {
    label: |md
      **2. Election Requirement**
      New leader **L** wins via majority **M2**.
      L must receive votes from $\ge 3$ nodes.
    |
    style.stroke: "#F69E03"
  }

  step3: {
    label: |md
      **3. Quorum Intersection**
      By Pigeonhole Principle: **M1 ∩ M2 ≠ ∅**.
      Node **C** exists in both sets.
    |
    style: {
      stroke: "#2E7D32"
      stroke-width: 3
      bold: true
    }
  }

  step4: {
    label: |md
      **4. Log Comparison Rule**
      C only votes for L if $Log_L \ge Log_C$.
      Since C has E, L must also have E.
    |
    style.stroke: "#2E7D32"
  }

  conclusion: {
    shape: hexagon
    label: |md
      **Theorem Proved**
      Entry E is guaranteed in Leader L's log.
    |
    style: {
      fill: "#C8E6C9"
      font-color: "#1B5E20"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }

  step1 -> step2 -> step3 -> step4 -> conclusion
}

# -----------------------------------------------------------------------------------------
# INTERSECTION CALLOUT
# -----------------------------------------------------------------------------------------
intersection_callout: {
  label: |md
    ### Quorum Intersection $M_1 \cap M_2 = \{C\}$
    **Witness node C guarantees:**
    1. It holds committed entry E.
    2. It enforces the "Up-to-Date" check.
    3. It bridges Term $T$ to Term $T+1$.
  |
  near: center-right
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }
}

# -----------------------------------------------------------------------------------------
# MATH CARDINALITY
# -----------------------------------------------------------------------------------------
math_box: {
  label: |md
    ### Mathematical Cardinality
    - $N = 5$
    - $|M_1| = 3, |M_2| = 3$
    - $|M_1 \cap M_2| = |M_1| + |M_2| - |M_1 \cup M_2|$
    - $|M_1 \cap M_2| \ge 3 + 3 - 5 = 1$
  |
  near: bottom-center
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
    font: mono
    border-radius: 4
  }
}

# -----------------------------------------------------------------------------------------
# SYSTEM CONNECTIONS
# -----------------------------------------------------------------------------------------
cluster.node_c -> m1_quorum: "Participates in M1" {style.stroke-dash: 5}
cluster.node_c -> m2_quorum: "Participates in M2" {style.stroke-dash: 5}

cluster -> proof_pipeline: "Formal Proof Mapping" {
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 5
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------------------
# FINAL ANNOTATION
# -----------------------------------------------------------------------------------------
annotation_box: {
  label: |md
    ### The Witness Mechanism
    The overlap ensures that any
    node elected as leader must
    have communicated with at least
    one node containing the latest
    committed log entry.
  |
  near: bottom-right
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    border-radius: 8
  }
}