vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Violation State Capture
  ### Snapshot at moment of invariant violation detection
| {near: top-center}
violation_capture: {
  shape: rectangle
  style.fill: "#2C2C2C"
  style.stroke: "#E53935"
  style.stroke-width: 3
  metadata: {
    shape: rectangle
    style.fill: "#424242"
    style.stroke: "#E53935"
    style.stroke-width: 2
    label: |md
      ## Violation Metadata
      **ID:** `1234567890123`
      **Timestamp:** `2024-01-15T10:30:45.123456789Z`
      **Type:** `ViolationElectionSafety`
      **Message:**
      
      Term 5 has 2 leaders: [node-0, node-1]
      
      **Check Cycle:** `1547`
    |
  }
  captured_state: {
    shape: rectangle
    style.fill: "#1E1E1E"
    style.stroke: "#757575"
    label: |md
      ## Captured Cluster State
    |
    # Node states captured
    node_0: {
      shape: rectangle
      style.fill: "#8B0000"
      style.stroke: "#FF5722"
      style.stroke-width: 2
      header: {
        label: |md
          ### node-0 [LEADER] ⚠️
        |
      }
      state_grid: {
        grid-columns: 2
        grid-gap: 0
        style.fill: "#2C2C2C"
        term_label: "Term:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        term_value: "5" {style.fill: "#1E1E1E"; style.font-color: "#FF5722"; style.bold: true}
        state_label: "State:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        state_value: "Leader" {style.fill: "#1E1E1E"; style.font-color: "#FF5722"; style.bold: true}
        commit_label: "commitIndex:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        commit_value: "100" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        applied_label: "lastApplied:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        applied_value: "100" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        voted_label: "votedFor:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        voted_value: "\"\"" {style.fill: "#1E1E1E"; style.font-color: "#BDBDBD"}
        loglen_label: "logLen:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        loglen_value: "101" {style.fill: "#1E1E1E"; style.font-color: "#64B5F6"}
      }
      log_snapshot: {
        shape: rectangle
        style.fill: "#1565C0"
        style.stroke: "#64B5F6"
        style.stroke-width: 2
        label: |md
          **Log Snapshot (first/last 3)**
          
          [1] term=1 cmd="init"
          [2] term=1 cmd="set x=1"
          [3] term=1 cmd="set y=2"
          ...
          [99] term=4 cmd="delete z"
          [100] term=4 cmd="set w=5"
          [101] term=5 cmd="noop" ← own term
          
        |
      }
      leader_arrays: {
        shape: rectangle
        style.fill: "#2E7D32"
        style.stroke: "#81C784"
        style.stroke-width: 2
        label: |md
          **nextIndex[]:** `[102, 98, 101, 100, 99]`
          **matchIndex[]:** `[0, 95, 100, 98, 97]`
        |
      }
    }
    node_1: {
      shape: rectangle
      style.fill: "#8B0000"
      style.stroke: "#FF5722"
      style.stroke-width: 2
      header: {
        label: |md
          ### node-1 [LEADER] ⚠️
        |
      }
      state_grid: {
        grid-columns: 2
        grid-gap: 0
        style.fill: "#2C2C2C"
        term_label: "Term:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        term_value: "5" {style.fill: "#1E1E1E"; style.font-color: "#FF5722"; style.bold: true}
        state_label: "State:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        state_value: "Leader" {style.fill: "#1E1E1E"; style.font-color: "#FF5722"; style.bold: true}
        commit_label: "commitIndex:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        commit_value: "95" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        applied_label: "lastApplied:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        applied_value: "95" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        voted_label: "votedFor:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        voted_value: "\"\"" {style.fill: "#1E1E1E"; style.font-color: "#BDBDBD"}
        loglen_label: "logLen:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        loglen_value: "96" {style.fill: "#1E1E1E"; style.font-color: "#64B5F6"}
      }
      log_snapshot: {
        shape: rectangle
        style.fill: "#1565C0"
        style.stroke: "#64B5F6"
        style.stroke-width: 2
        label: |md
          **Log Snapshot (first/last 3)**
          
          [1] term=1 cmd="init"
          [2] term=1 cmd="set x=1"
          [3] term=1 cmd="set y=2"
          ...
          [94] term=4 cmd="get a"
          [95] term=4 cmd="set b=3"
          [96] term=5 cmd="noop" ← own term
          
        |
      }
      leader_arrays: {
        shape: rectangle
        style.fill: "#2E7D32"
        style.stroke: "#81C784"
        style.stroke-width: 2
        label: |md
          **nextIndex[]:** `[97, 0, 95, 94, 93]`
          **matchIndex[]:** `[0, 0, 95, 92, 90]`
        |
      }
    }
    node_2: {
      shape: rectangle
      style.fill: "#1B5E20"
      style.stroke: "#4CAF50"
      style.stroke-width: 1
      header: {
        label: |md
          ### node-2 [FOLLOWER]
        |
      }
      state_grid: {
        grid-columns: 2
        grid-gap: 0
        style.fill: "#2C2C2C"
        term_label: "Term:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        term_value: "5" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        state_label: "State:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        state_value: "Follower" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        commit_label: "commitIndex:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        commit_value: "100" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        applied_label: "lastApplied:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        applied_value: "100" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        voted_label: "votedFor:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        voted_value: "\"node-0\"" {style.fill: "#1E1E1E"; style.font-color: "#FFC107"}
        loglen_label: "logLen:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        loglen_value: "101" {style.fill: "#1E1E1E"; style.font-color: "#64B5F6"}
      }
    }
    node_3: {
      shape: rectangle
      style.fill: "#1B5E20"
      style.stroke: "#4CAF50"
      style.stroke-width: 1
      header: {
        label: |md
          ### node-3 [FOLLOWER]
        |
      }
      state_grid: {
        grid-columns: 2
        grid-gap: 0
        style.fill: "#2C2C2C"
        term_label: "Term:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        term_value: "5" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        state_label: "State:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        state_value: "Follower" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        commit_label: "commitIndex:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        commit_value: "98" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        applied_label: "lastApplied:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        applied_value: "98" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        voted_label: "votedFor:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        voted_value: "\"node-1\"" {style.fill: "#1E1E1E"; style.font-color: "#FFC107"}
        loglen_label: "logLen:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        loglen_value: "99" {style.fill: "#1E1E1E"; style.font-color: "#64B5F6"}
      }
    }
    node_4: {
      shape: rectangle
      style.fill: "#1B5E20"
      style.stroke: "#4CAF50"
      style.stroke-width: 1
      header: {
        label: |md
          ### node-4 [FOLLOWER]
        |
      }
      state_grid: {
        grid-columns: 2
        grid-gap: 0
        style.fill: "#2C2C2C"
        term_label: "Term:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        term_value: "5" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        state_label: "State:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        state_value: "Follower" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        commit_label: "commitIndex:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        commit_value: "97" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        applied_label: "lastApplied:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        applied_value: "97" {style.fill: "#1E1E1E"; style.font-color: "#4CAF50"}
        voted_label: "votedFor:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        voted_value: "\"node-0\"" {style.fill: "#1E1E1E"; style.font-color: "#FFC107"}
        loglen_label: "logLen:" {style.fill: "#424242"; style.font-color: "#BDBDBD"}
        loglen_value: "98" {style.fill: "#1E1E1E"; style.font-color: "#64B5F6"}
      }
    }
  }
  stack_trace: {
    shape: rectangle
    style.fill: "#263238"
    style.stroke: "#607D8B"
    style.font: mono
    style.font-size: 12
    label: |md
      ### Stack Trace (Debugging)
      
      goroutine 42 [running]:
      rafttest.(*InvariantChecker).CheckElectionSafety()
        /rafttest/04_invariant_election.go:45 +0x1a3
      rafttest.(*InvariantChecker).runLoop()
        /rafttest/03_invariant_checker.go:89 +0x245
      created by rafttest.(*InvariantChecker).Start
        /rafttest/03_invariant_checker.go:67 +0x98
      
    |
  }
}
# Legend
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  label: |md
    **Legend**
    🔴 Red = Violating node (LEADER in same term)
    🟢 Green = Normal node (FOLLOWER)
    🟡 Yellow = Vote relationships
    🔵 Blue = Log data
  |
}
# Memory layout annotation
memory_layout: {
  near: bottom-right
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  label: |md
    **Memory Layout (per node)**
    
    NodeState {
      NodeId      string    ~16 bytes
      Term        int       8 bytes
      State       string    ~8 bytes
      CommitIndex int       8 bytes
      LastApplied int       8 bytes
      LogLen      int       8 bytes
      LogEntries  []Entry   var
      VotedFor    string    ~16 bytes
    }
    ~72 bytes + log entries
    
  |
}