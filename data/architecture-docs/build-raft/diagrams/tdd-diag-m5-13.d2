direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------------------
# SATELLITE VIEW: RAFT DISTRIBUTED CONSENSUS
# Level 1: Node Internal Logic (Deterministic State Machines & WAL)
# Level 2: Cluster Coordination (Leader Election & Quorum Logic)
# Level 3: Network Reality (Fault Injection via Jepsen Nemesis)
# -----------------------------------------------------------------------------------------

Satellite_View: {
  
  # LEVEL 1: THE SINGLE NODE (Deep Abstraction)
  Level_1: Node Internal Architecture {
    style: {
      stroke: "#333333"
      stroke-width: 4
      fill: "#f8f9fa"
    }

    State_Machine: {
      shape: rectangle
      label: "Deterministic\nState Machine"
      style: {
        fill: "#e1d5e7" # Header/Control (Purple)
        3d: true
      }
    }

    Volatile_State: {
      shape: sql_table
      label: "Volatile State (RAM)"
      style.fill: "#e1d5e7" # Header (Purple)
      commitIndex: uint64 {
        label: "commitIndex | Offset 0x00 | 8B"
        style.fill: "#dae8fc" # Data (Blue)
      }
      lastApplied: uint64 {
        label: "lastApplied | Offset 0x08 | 8B"
        style.fill: "#dae8fc" # Data (Blue)
      }
    }

    Persistent_Storage: "Persistent Memory (WAL)" {
      style.fill: "#fff2cc"
      
      Log_Entry_Layout: {
        shape: sql_table
        label: "Log Entry Format (sizeof=24B)"
        style.fill: "#e1d5e7" # Header (Purple)
        term: uint64 {
          label: "Term | 8B"
          style.fill: "#dae8fc" # Data (Blue)
        }
        index: uint64 {
          label: "Index | 8B"
          style.fill: "#dae8fc" # Data (Blue)
        }
        data: bytes {
          label: "Command Payload | Var"
          style.fill: "#dae8fc" # Data (Blue)
        }
      }

      HardState: {
        shape: sql_table
        label: "HardState (Atomic Write)"
        style.fill: "#e1d5e7" # Header (Purple)
        currentTerm: uint64 {style.fill: "#dae8fc"}
        votedFor: nodeID {style.fill: "#dae8fc"}
      }
    }

    Persistent_Storage.HardState.currentTerm -> Volatile_State.commitIndex: "Informs"
    Volatile_State.lastApplied -> State_Machine: "Apply Command"
  }

  # LEVEL 2: CLUSTER COORDINATION
  Level_2: Consensus Group {
    style.stroke: "#2b78e4"
    style.stroke-dash: 5
    
    Leader: Node A {
      shape: person
      style.fill: "#d5e8d4" # Success/Active (Green)
    }

    Follower_1: Node B {
      shape: person
      style.fill: "#f5f5f5"
    }

    Follower_2: Node C {
      shape: person
      style.fill: "#f5f5f5"
    }

    Quorum_Logic: "Quorum = floor(N/2) + 1" {
      style: {
        font-size: 14
        bold: true
        italic: true
        stroke-dash: 2
      }
    }

    Leader -> Follower_1: AppendEntries (Heartbeat)
    Leader -> Follower_2: AppendEntries (Log Replication)
  }

  # LEVEL 3: NETWORK REALITY (JEPSEN LAYER)
  Level_3: Unreliable Network {
    style.stroke: "#b85450" # Faults (Red)
    
    Partition_A: {
      label: "Partition A (Majority)"
      Node_A: "Raft Node A"
      Node_B: "Raft Node B"
      style.fill: "#fff2cc"
    }

    Partition_B: {
      label: "Partition B (Minority)"
      Node_C: "Raft Node C"
      style.fill: "#f8cecc"
    }

    Network_Bridge: {
      shape: cloud
      label: "Async FIFO Channel"
      
      Fault_Injector: {
        shape: diamond
        label: "Nemesis"
        tooltip: "Injects Partitions, Latency, and Packet Loss"
        style.fill: "#ff0000"
        style.font-color: "#ffffff"
      }
    }

    Partition_A <-> Network_Bridge: "TCP/GRPC"
    Partition_B <-> Network_Bridge: "!! PACKET DROP !!" {
      style.stroke: "#ff0000"
      style.stroke-width: 2
      style.animated: true
    }
  }
}

# Fixed: Using constant near values for ELK compatibility
Annotation: |md
  ### Raft Implementation Specifications
  - **Persistence**: Must fsync HardState before responding to RPCs.
  - **Safety**: Election restriction ensures Leader contains all committed entries.
  - **Liveness**: Randomized election timeouts [150ms, 300ms] prevent split votes.
| {
  near: bottom-center
}

# Memory Layout Details: Exact Byte Offsets & Alignment
Memory_Map: {
  shape: sql_table
  label: "WAL Byte Offsets & Cache Alignment"
  style.fill: "#e1d5e7" # Header (Purple)
  "0x00-0x08": "CRC32 Checksum (8B)" {style.fill: "#dae8fc"}
  "0x08-0x10": "Term (LE uint64) (8B)" {style.fill: "#dae8fc"}
  "0x10-0x18": "Index (LE uint64) (8B)" {style.fill: "#dae8fc"}
  "0x18-0x20": "Data Length (N) (8B)" {style.fill: "#dae8fc"}
  "0x20-0x20+N": "Payload (Command) (N bytes)" {style.fill: "#dae8fc"}
  "Padding": "Alignment to 64B Cache Line" {style.fill: "#eeeeee"}
}

# Cross-Level Connections showing how concepts map
Satellite_View.Level_1.Persistent_Storage -> Satellite_View.Level_2.Leader: "Drives behavior"
Satellite_View.Level_2.Quorum_Logic -> Satellite_View.Level_3.Partition_A: "Maintains Availability"

# Fixed: Using constant near values for ELK compatibility
Cache_Line_Boundary: "64B CACHE LINE BOUNDARY" {
  shape: text
  near: bottom-right
  style: {
    stroke-dash: 5
    font-size: 10
    italic: true
  }
}

# Global Theme and Globs for Consistency
***.style.font-size: 14
(*** -> ***)[*]: {
  style.stroke-width: 2
}