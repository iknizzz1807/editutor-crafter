vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Stress Test Result Report Structure
  *Technical Specification for Raft Implementation Verification*
| {near: top-center}

report: "StressTestResult JSON" {
  style: {
    stroke: "#DEE2E6"
    stroke-width: 4
    fill: "#F8F9FA"
    shadow: true
  }

  header: "Report Metadata" {
    style: {
      fill: "#6C5CE7"
      stroke: "#5B4BD5"
      font-color: white
    }
    
    duration: |md
      **Duration**: `"10m0s"`
      *Total wall-clock execution time of the test suite.*
    | {
      style.fill: "#E8E4F8"
      style.font-color: black
    }
    
    timestamp: |md
      **Timestamp**: `1705314600`
      *Unix epoch of completion.*
    | {
      style.fill: "#E8E4F8"
      style.font-color: black
    }
  }

  commands: "Command Statistics" {
    style: {
      fill: "#00B894"
      stroke: "#00A383"
      font-color: white
    }
    
    submitted: |md
      **CommandsSubmitted**: `10000`
      *Total client requests attempted against the cluster.*
    | {
      style.fill: "#E8F8F5"
      style.font-color: black
    }
    
    committed: |md
      **CommandsCommitted**: `9850`
      *Requests that reached a quorum and were indexed.*
    | {
      style.fill: "#E8F8F5"
      style.font-color: black
    }
    
    applied: |md
      **CommandsApplied**: `9850`
      *State machine transitions executed locally.*
    | {
      style.fill: "#E8F8F5"
      style.font-color: black
    }
  }

  cluster: "Cluster Events" {
    style: {
      fill: "#0984E3"
      stroke: "#0874D0"
      font-color: white
    }
    
    leaders: |md
      **LeaderChanges**: `15`
      *Count of Term increments resulting in new leaders.*
    | {
      style.fill: "#E3F2FD"
      style.font-color: black
    }
    
    partitions: |md
      **PartitionsInjected**: `8`
      *Partial or total network partitions created by nemesis.*
    | {
      style.fill: "#E3F2FD"
      style.font-color: black
    }
    
    kills: |md
      **KillsInjected**: `25`
      *SIGKILL events triggered against Raft nodes.*
    | {
      style.fill: "#E3F2FD"
      style.font-color: black
    }
    
    restarts: |md
      **RestartsInjected**: `25`
      *Nodes successfully recovered from storage snapshots.*
    | {
      style.fill: "#E3F2FD"
      style.font-color: black
    }
  }

  violations: "Safety Verification" {
    style: {
      fill: "#D63031"
      stroke: "#C52F2E"
      font-color: white
    }
    
    count: |md
      **InvariantViolations**: `0`
      *Critical failures (e.g., Election Safety, Log Matching).*
    | {
      style.fill: "#FFEBEE"
      style.font-color: black
    }
  }

  perf: "Performance Metrics" {
    style: {
      fill: "#F39C12"
      stroke: "#E08E0B"
      font-color: white
    }
    
    p50: |md
      **CommitLatencyP50**: `85ms`
      *Median time from submission to commit.*
    | {
      style.fill: "#FFF8E1"
      style.font-color: black
    }
    
    p99: |md
      **CommitLatencyP99**: `195ms`
      *Tail latency during high contention/partitions.*
    | {
      style.fill: "#FFF8E1"
      style.font-color: black
    }
  }
}

violation_detail: "Violation Detail Structure" {
  near: center-right
  style: {
    fill: "#FFEBEE"
    stroke: "#D63031"
    stroke-width: 2
  }
  
  detail_text: |md
    ### JSON Schema: `violations[]`
    json
    {
      "violations": [
        {
          "id": 1234567890,
          "timestamp": "2024-01-15T10:30:00Z",
          "type": "ElectionSafety",
          "message": "Term 5 has 2 leaders",
          "state": {
            "node-0": {"term": 5, "state": "Leader"},
            "node-1": {"term": 5, "state": "Leader"}
          }
        }
      ]
    }
    
  |
}

legend: "Field Legend & Thresholds" {
  near: bottom-center
  
  header: "Color Coding Map" {
    style.fill: "#F8F9FA"
    meta: "Metadata (Purple)" { style.fill: "#6C5CE7"; style.font-color: white }
    cmd: "Command Stats (Green)" { style.fill: "#00B894"; style.font-color: white }
    evt: "Injected Events (Blue)" { style.fill: "#0984E3"; style.font-color: white }
    safe: "Safety Check (Red)" { style.fill: "#D63031"; style.font-color: white }
    perf_legend: "Latency (Orange)" { style.fill: "#F39C12"; style.font-color: white }
  }
  
  criteria: "Pass/Fail Criteria" {
    style.fill: "#E8F5E9"
    content: |md
      ### Verification Requirements
      1.  `InvariantViolations == 0` (MANDATORY)
      2.  `CommandsCommitted >= 90%` of `Submitted`
      3.  `P99 Latency < 500ms` during stability
    |
  }
}

# Relationships / Flow
report.commands -> report.cluster: "Correlates drops with events"
report.cluster -> report.violations: "Stress triggers bugs"
report.violations -> violation_detail: "Explains errors when count > 0" {
  style.stroke: red
  style.animated: true
}
report -> legend: "Interpretation rules"