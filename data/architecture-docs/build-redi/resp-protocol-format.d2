direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # RESP Wire Protocol Format
  ## Redis Serialization Protocol — Byte-Level Structure
|

resp_types: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  simple_string: {
    label: "Simple String (+)"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    format: {
      shape: sql_table
      label: "Format"
      b0: "+"
      b1: "payload"
      b2: "\\r\\n"
      note: "+OK\\r\\n"
    }
  }

  error: {
    label: "Error (-)"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2

    format: {
      shape: sql_table
      label: "Format"
      b0: "-"
      b1: "error message"
      b2: "\\r\\n"
      note: "-ERR unknown command\\r\\n"
    }
  }

  integer: {
    label: "Integer (:)"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    format: {
      shape: sql_table
      label: "Format"
      b0: ":"
      b1: "integer value"
      b2: "\\r\\n"
      note: ":1000\\r\\n"
    }
  }

  bulk_string: {
    label: "Bulk String ($)"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2

    format: {
      shape: sql_table
      label: "Format"
      h0: "$"
      h1: "byte-count"
      h2: "\\r\\n"
      h3: "data bytes"
      h4: "\\r\\n"
      note1: "$-1\\r\\n"
      note2: "$0\\r\\n\\r\\n"
    }
  }

  array: {
    label: "Array (*)"
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2

    format: {
      shape: sql_table
      label: "Format"
      h0: "*"
      h1: "element-count"
      h2: "\\r\\n"
      h3: "elements..."
      h4: "(any RESP type)"
      note: "*2\\r\\n$3\\r\\nSET\\r\\n$3\\r\\nkey\\r\\n"
    }
  }
}

encoding_rules: {
  label: "Length Encoding Rules"
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  style.stroke-width: 2

  rules: {
    shape: sql_table
    label: "Variable-Length Integer"
    r0: "0-11 bytes | 1 byte | Top 2 bits = 00"
    r1: "12-127 bytes | 1 byte | Top 2 bits = 01"
    r2: "128-16383 | 2 bytes | Top 2 bits = 10"
    r3: "16384+ | 5 bytes | Top 2 bits = 11"
  }
}

crlf_info: {
  label: "CRLF Delimiter"
  shape: rectangle
  style.fill: "#E0E0E0"
  style.stroke: "#424242"

  info: {
    shape: sql_table
    label: "CRLF = \\r\\n"
    c0: "0x0D (13) | Carriage Return"
    c1: "0x0A (10) | Line Feed"
    c2: "Used to terminate | all RESP types"
  }
}

null_handling: {
  label: "Null Values"
  shape: rectangle
  style.fill: "#FFECB3"
  style.stroke: "#FFC107"

  nulls: {
    shape: sql_table
    label: "Null Representations"
    n0: "Bulk String | $-1\\r\\n"
    n1: "Array | *-1\\r\\n"
    n2: "Null Bulk String | $-1\\r\\n"
  }
}

examples: {
  label: "Command Examples"
  shape: rectangle
  style.fill: "#E1F5FE"
  style.stroke: "#03A9F4"
  style.stroke-width: 2

  ex_table: {
    shape: sql_table
    label: "Common Commands"
    e0: "GET key | *2\\r\\n$3\\r\\nGET\\r\\n$3\\r\\nkey\\r\\n"
    e1: "SET key val | *3\\r\\n$3\\r\\nSET\\r\\n$3\\r\\nkey\\r\\n$3\\r\\nval\\r\\n"
    e2: "PING | *1\\r\\n$4\\r\\nPING\\r\\n"
    e3: "DEL key | *2\\r\\n$3\\r\\nDEL\\r\\n$3\\r\\nkey\\r\\n"
  }
}

legend: {
  near: bottom-center
  label: "Legend"
  l1: "Green = Success strings | Purple = Arrays"
  l2: "Red = Errors | Orange = Bulk strings"
  l3: "Blue = Integers | Gray = Encoding rules"
}

resp_types.simple_string.format -> encoding_rules: "length prefix"
resp_types.bulk_string.format -> null_handling: "null handling"
resp_types.array.format -> examples: "contains elements"
resp_types.error.format -> crlf_info: "uses CRLF"