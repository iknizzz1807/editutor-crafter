direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "RESP Parser State Machine" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

subtitle: "Incremental RESP Frame Parsing with Partial Read Handling" {
  near: top-center
  shape: text
  style.font-size: 14
  style.italic: true
  style.font-color: "#666"
}

legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  start_state: "Start State" {
    shape: circle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  
  process_state: "Processing State" {
    shape: circle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  
  complete_state: "Complete State" {
    shape: circle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
  }
  
  error_state: "Error State" {
    shape: circle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  parser_overview: {
    label: "RESP Protocol Overview"
    shape: rectangle
    width: 300
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
    style.stroke-width: 1
    style.border-radius: 8
    
    intro: |md
      Redis Serialization Protocol (RESP)
      - Binary-safe wire format
      - Simple types: Simple String,
        Bulk String, Integer, Array
      - Stream-oriented: partial reads
        must be handled correctly
    |
  }
  
  parser_context: {
    label: "Parser Context"
    shape: class
    width: 280
    
    +read_buffer: "sds"
    +buffer_pos: "size_t"
    +buffer_len: "size_t"
    +current_state: "ParseState"
    +frame_complete: "bool"
    +error_msg: "sds"
    
    context_fields: {
      offset: 0
      limit: 50
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  state_machine: {
    label: "State Machine Flow"
    direction: down
    width: 600
    
    WAIT_TYPE: {
      label: "WAIT_TYPE\n(buffer: empty)"
      shape: circle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 3
      width: 120
      height: 80
    }
    
    READ_SIMPLE: {
      label: "READ_SIMPLE\n(String/Integer)"
      shape: circle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      width: 120
      height: 80
    }
    
    READ_BULK_LEN: {
      label: "READ_BULK_LEN\n(after $)"
      shape: circle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      width: 120
      height: 80
    }
    
    READ_BULK_DATA: {
      label: "READ_BULK_DATA\n(accumulate N bytes)"
      shape: circle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      width: 120
      height: 80
    }
    
    READ_ARRAY: {
      label: "READ_ARRAY\n(count elements)"
      shape: circle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      width: 120
      height: 80
    }
    
    PARSE_ELEM: {
      label: "PARSE_ELEM\n(recursive)"
      shape: circle
      style.fill: "#F3E5F5"
      style.stroke: "#9C27B0"
      style.stroke-width: 2
      width: 120
      height: 80
    }
    
    COMPLETE: {
      label: "COMPLETE\n(frame ready)"
      shape: circle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.stroke-width: 3
      width: 120
      height: 80
    }
    
    ERROR: {
      label: "ERROR\n(invalid format)"
      shape: circle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      style.stroke-width: 3
      width: 120
      height: 80
    }
    
    WAIT_TYPE -> READ_SIMPLE: "+" | "-"
    WAIT_TYPE -> READ_BULK_LEN: "$"
    WAIT_TYPE -> READ_ARRAY: "*"
    
    READ_SIMPLE -> COMPLETE: "\\r\\n found"
    READ_SIMPLE -> READ_SIMPLE: "accumulate"
    
    READ_BULK_LEN -> READ_BULK_DATA: "length read"
    READ_BULK_LEN -> ERROR: "not a number"
    READ_BULK_DATA -> READ_BULK_DATA: "more bytes needed"
    READ_BULK_DATA -> COMPLETE: "N bytes + \\r\\n"
    
    READ_ARRAY -> PARSE_ELEM: "element count"
    PARSE_ELEM -> PARSE_ELEM: "parse nested"
    PARSE_ELEM -> READ_ARRAY: "next element"
    PARSE_ELEM -> COMPLETE: "all elements"
    
    COMPLETE -> WAIT_TYPE: "reset for next"
    ERROR -> WAIT_TYPE: "reset"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  partial_read_example: {
    label: "Partial Read Handling Example"
    width: 450
    
    example_code: |'c
      // Client sends: *2\r\n$3\r\nSET\r\n$5\r\nmykey\r\n
      // Network delivers in chunks:
      
      // Chunk 1: "*2\r\n$3\r"
      //   -> WAIT_TYPE sees '*', transitions to READ_ARRAY
      //   -> buffer contains "*2\r\n$3\r"
      //   -> state=READ_ARRAY, need more data
      
      // Chunk 2: "SET\r\n$5\r\nmy"
      //   -> READ_ARRAY parses "2" elements
      //   -> Now need to parse 2 elements
      //   -> First element: starts with '$', read bulk
      //   -> Second element: starts with '$', read bulk
      //   -> buffer accumulates "SET\r\n$5\r\nmy"
      
      // Chunk 3: "key\r\n"
      //   -> Completes second bulk string
      //   -> All elements parsed -> COMPLETE
    '|
    width: 430
  }
  
  data_structures: {
    label: "Key Parser Structures"
    shape: sql_table
    width: 320
    
    s0: "ParseResult | resp_result_t | Parsed frame"
    s1: "ParseState  | enum        | Current state"
    s2: "FrameType   | enum        | + - $ * :"
    s3: "sds         | buffer      | Accumulated"
    s4: "size_t     | remaining   | Bytes needed"
    s5: "int         | element_cnt | Array size"
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  transition_table: {
    label: "State Transitions Summary"
    width: 500
    
    transitions: {
      shape: sql_table
      
      t0: "Input Char | Current State | Next State | Action"
      t1: "+/-/ :    | WAIT_TYPE      | READ_SIMPLE | Set simple type"
      t2: "$         | WAIT_TYPE      | READ_BULK_LEN | Start bulk parse"
      t3: "*         | WAIT_TYPE      | READ_ARRAY | Start array parse"
      t4: '\\r\\n       | READ_SIMPLE    | COMPLETE | Frame complete"
      t5: "\\r\\n       | READ_BULK_LEN  | READ_BULK_DATA | Use length"
      t6: "\\r\\n       | READ_BULK_DATA | COMPLETE | Validate length"
      t7: "\\r\\n       | READ_ARRAY     | PARSE_ELEM | Init element loop"
      t8: "-          | any ERROR      | WAIT_TYPE | Reset on error"
    }
  }
  
  key_points: {
    label: "Implementation Key Points"
    width: 350
    
    points: |md
      **Buffer Management:**
      - Append received data to read_buffer
      - Never discard incomplete frames
      
      **State Persistence:**
      - Store parser state in Client struct
      - Resume from exact state on next read
      
      **Frame Detection:**
      - Check for complete frame after each state transition
      - Use remaining_bytes counter for bulk strings
      
      **Error Handling:**
      - Detect protocol errors early
      - Reset parser, disconnect client on fatal error
    |
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  integration_note: {
    label: "Integration with Event Loop"
    width: 600
    
    note_code: |'c
      // In handle_io_event (Milestone 2):
      
      void handle_client_read(Client* c) {
          char buf[4096];
          ssize_t n = read(c->fd, buf, sizeof(buf));
          
          if (n <= 0) {
              client_disconnect(c);  // EOF or error
              return;
          }
          
          // Append to parser buffer
          c->read_buffer = sdscatlen(
              c->read_buffer, buf, n);
          
          // Parse until no more complete frames
          while (1) {
              ParseResult result = 
                  resp_parse_frame(
                      c->read_buffer,
                      &c->parser_pos);
              
              if (result.status == INCOMPLETE) {
                  break;  // Need more data
              }
              
              if (result.status == ERROR) {
                  // Protocol error
                  send_error(c, result.error_msg);
                  client_disconnect(c);
                  return;
              }
              
              // Complete frame - execute command
              execute_command(c, server, 
                  result.argv, result.argc);
              
              // Clear parsed portion
              c->read_buffer = 
                  sdsrange(c->read_buffer, 
                      result.consumed, -1);
              c->parser_pos = 0;
          }
      }
    '|
    width: 580
  }
}

style.fill: "#FAFAFA"
style.stroke: "#424242"
style.stroke-width: 1