direction: down

title: "RESP Format Types" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

subtitle: "Redis Serialization Protocol Wire Format" {
  near: top-center
  shape: text
  style.font-size: 14
  style.italic: true
  style.font-color: "#666"
}

# Row 1: Simple Types Overview
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  simple_string: {
    label: 'Simple String'
    width: 180
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    
    format: |md
      **Format:** +... CRLF
      **Example:** +OK CRLF
    |
  }

  error: {
    label: 'Error'
    width: 180
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    
    format: |md
      **Format:** -... CRLF
      **Example:** -ERR unknown CRLF
    |
  }

  integer: {
    label: 'Integer'
    width: 180
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    
    format: |md
      **Format:** :number CRLF
      **Example:** :1000 CRLF
    |
  }
}

# Row 2: Complex Types
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  bulk_string: {
    label: 'Bulk String'
    width: 250
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    
    format: |md
      **Format:** $len CRLF data CRLF
      **Example:** $5 CRLF hello CRLF
      **Null:** $-1 CRLF
    |
  }

  array: {
    label: 'Array'
    width: 250
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    
    format: |md
      **Format:** *count CRLF ...elements...
      **Example:** *2 CRLF $3 CRLF SET CRLF $5 CRLF mykey CRLF
      **Null:** *-1 CRLF
      **Empty:** *0 CRLF
    |
  }
}

# Row 3: Type Detection Flow
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  detection_flow: {
    label: 'Type Detection Flow'
    direction: down
    width: 400

    start: {
      label: 'Read First Byte'
      shape: circle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }

    check_plus: {
      label: 'Is "+"?'
      shape: diamond
      style.fill: "#FFF9C4"
      style.stroke: "#FFC107"
    }

    check_minus: {
      label: 'Is "-"?'
      shape: diamond
      style.fill: "#FFF9C4"
      style.stroke: "#FFC107"
    }

    check_colon: {
      label: 'Is ":"?'
      shape: diamond
      style.fill: "#FFF9C4"
      style.stroke: "#FFC107"
    }

    check_dollar: {
      label: 'Is "$"?'
      shape: diamond
      style.fill: "#FFF9C4"
      style.stroke: "#FFC107"
    }

    check_star: {
      label: 'Is "*"?'
      shape: diamond
      style.fill: "#FFF9C4"
      style.stroke: "#FFC107"
    }

    simple_string_type: {
      label: 'Simple String'
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }

    error_type: {
      label: 'Error'
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
    }

    integer_type: {
      label: 'Integer'
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }

    bulk_string_type: {
      label: 'Bulk String'
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }

    array_type: {
      label: 'Array'
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#9C27B0"
    }

    # Connections
    start -> check_plus
    check_plus -> simple_string_type: 'yes'
    check_plus -> check_minus: 'no'
    check_minus -> error_type: 'yes'
    check_minus -> check_colon: 'no'
    check_colon -> integer_type: 'yes'
    check_colon -> check_dollar: 'no'
    check_dollar -> bulk_string_type: 'yes'
    check_dollar -> check_star: 'no'
    check_star -> array_type: 'yes'
  }

  # Common Patterns - use code block to avoid substitution issues
  common_patterns: {
    label: 'Common Command Patterns'
    width: 350
    
    pattern_code: |'c
      Command     RESP Encoding
      ----------  ------------------
      PING        *1 $4 PING
      SET k v     *3 $3 SET $1 k $1 v
      GET k       *2 $3 GET $1 k
      DEL k       *2 $3 DEL $1 k
    '|
    width: 330
  }
}

# Row 4: Error Format Detail
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  resp_types_error_format: {
    label: 'Error Response Format'
    width: 400

    error_detail: {
      shape: sql_table

      e0: 'Field | Description'
      e1: 'Prefix | - (hyphen)'
      e2: 'Message | Error description'
      e3: 'Terminator | CRLF'
      e4: 'Example | -ERR syntax error'
    }
  }

  notes: {
    label: 'Implementation Notes'
    width: 350

    notes_content: |md
      **Error Handling:**
      - Parse errors set resp_types_error.format
      - Use single-quoted strings for labels with special chars
      - Single quotes are literal - avoid substitution issues

      **Buffer Boundaries:**
      - Check for CRLF terminator in simple/bulk strings
      - Array elements are parsed recursively
      - Track remaining bytes for bulk strings
    |
  }
}

style.fill: "#FAFAFA"
style.stroke: "#424242"
style.stroke-width: 1
