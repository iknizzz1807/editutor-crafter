direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

title: |md
  # TCP Socket Lifecycle
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  app: Application {
    label: "Application Layer"
    direction: down
    socket_creation: "socket() creates FD" {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    bind_listen: "bind() + listen()" {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
  }
  kernel: Kernel {
    label: "Kernel (OS)"
    direction: down
    tcp_state: "TCP State Machine" {
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
    }
    socket_buf: "Socket Buffers" {
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lifecycle: "Socket Lifecycle" {
    direction: down
    listen_state: "LISTEN" {
      shape: circle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
    syn_recv: "SYN-RECEIVED" {
      shape: circle
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
    }
    established: "ESTABLISHED" {
      shape: circle
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
      style.animated: true
    }
    fin_wait: "FIN-WAIT" {
      shape: circle
      style.fill: "#FFCC80"
      style.stroke: "#EF6C00"
    }
    time_wait: "TIME-WAIT" {
      shape: circle
      style.fill: "#FFAB91"
      style.stroke: "#E64A19"
    }
    closed: "CLOSED" {
      shape: circle
      style.fill: "#EF9A9A"
      style.stroke: "#C62828"
    }
  }
  fd_mgmt: "FD Management" {
    direction: down
    fd_alloc: "FD Allocation" {
      shape: sql_table
      label: "file_descriptor"
      f0: "0x00 | int | fd"
      f1: "0x04 | void* | file_ops"
      f2: "0x08 | RefCount | refcount"
      sz: "Total: 24 bytes"
    }
    fd_release: "FD Release" {
      shape: step
      label: "cleanup on disconnect"
      width: 200
      code: |'c
        close(fd);
        // - Remove from epoll
        // - Free read buffer
        // - Free client struct
        // - Decrement refcount
      '|
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cleanup_notes: "Resource Cleanup" {
    direction: down
    tcp_cleanup: "TCP Cleanup" {
      shape: rectangle
      label: "On Disconnect"
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
    }
    mem_cleanup: "Memory Cleanup" {
      shape: rectangle
      label: "Buffers & Structs"
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
    }
    event_cleanup: "Event Loop Cleanup" {
      shape: rectangle
      label: "epoll_ctl DEL"
      style.fill: "#E8EAF6"
      style.stroke: "#283593"
    }
  }
}

listen_state -> syn_recv: "SYN / SYN-ACK"
syn_recv -> established: "ACK"
established -> fin_wait: "FIN"
fin_wait -> time_wait: "FIN-ACK"
time_wait -> closed: "2MSL timeout"
closed -> listen_state: "server restart"

app.socket_creation -> kernel.tcp_state: "syscall"
kernel.socket_buf -> fd_mgmt.fd_alloc: "tracks FD"
lifecycle.fd_mgmt: "Uses"
lifecycle.fd_release -> row3.tcp_cleanup: "triggers cleanup"