direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

title: Gossip Protocol for Cluster State (redis-cluster)

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  node1: Redis Node 1 {
    shape: class
    label: "Node 1 (redis-server.c)"
    -cluster_link: "*clusterLink"
    -cluster_msg: "clusterMsg*"
    -ping_interval: "int"
    -pong_received: "uint64_t"
    +sendPing(): "void"
    +handleGossip(msg): "void"
    +updateClusterState(): "void"
  }

  node2: Redis Node 2 {
    shape: class
    label: "Node 2 (redis-server.c)"
    -cluster_link: "*clusterLink"
    -cluster_msg: "clusterMsg*"
    -ping_interval: "int"
    -pong_received: "uint64_t"
    +sendPing(): "void"
    +handleGossip(msg): "void"
    +updateClusterState(): "void"
  }

  node3: Redis Node 3 {
    shape: class
    label: "Node 3 (redis-server.c)"
    -cluster_link: "*clusterLink"
    -cluster_msg: "clusterMsg*"
    -ping_interval: "int"
    -pong_received: "uint64_t"
    +sendPing(): "void"
    +handleGossip(msg): "void"
    +updateClusterState(): "void"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  gossip_msg: Gossip Message {
    shape: sql_table
    label: "clusterMsg (cluster.h)"
    f0: "0x00 | uint32_t  | type"
    f1: "0x04 | uint32_t  | count"
    f2: "0x08 | uint64_t  | ping_ms"
    f3: "0x10 | clusterMsgDataGossip[] | gossip"
    sz: "Total: variable (16 + N*gossip)"
  }

  gossip_entry: Gossip Entry {
    shape: sql_table
    label: "clusterMsgDataGossip (cluster.h)"
    f0: "0x00 | uint64_t  | nodeid"
    f1: "0x08 | uint32_t  | ping"
    f2: "0x0C | uint32_t  | pong"
    f3: "0x10 | uint16_t  | port"
    f4: "0x12 | uint16_t  | flags"
    f5: "0x14 | char[30]  | ip"
    sz: "Total: 48 bytes"
  }
}

arrow1: row1.node1 -> row1.node2: "clusterMsg | PING" {
  style.stroke: blue
  style.animated: true
}

arrow2: row1.node2 -> row1.node3: "clusterMsg | PING" {
  style.stroke: blue
  style.animated: true
}

arrow3: row1.node3 -> row1.node1: "clusterMsg | PING" {
  style.stroke: blue
  style.animated: true
}

arrow4: row1.node1 -> row2.gossip_msg: "serializes" {
  style.stroke: purple
}

arrow5: row2.gossip_msg -> row2.gossip_entry: "array of" {
  style.stroke: purple
}

flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: "1. Node selects random peer" {
    shape: rectangle
    style.fill: "#E3F2FD"
  }

  step2: "2. Send PING with cluster info" {
    shape: rectangle
    style.fill: "#E3F2FD"
  }

  step3: "3. Receiver updates state" {
    shape: rectangle
    style.fill: "#E8F5E9"
  }

  step4: "4. Propagate via gossip" {
    shape: rectangle
    style.fill: "#FFF3E0"
  }
}

flow.step1 -> flow.step2: "random selection"
flow.step2 -> flow.step3: "handlePING"
flow.step3 -> flow.step4: "broadcast"

row1 -> flow: "timing: every ping_interval ms" {
  style.stroke-dash: 3
  style.stroke: gray
}