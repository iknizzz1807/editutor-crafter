direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Key-to-Slot Mapping with Hash Tags"
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  key_input: "Key Input" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    label: "user:1001:profile"
    width: 180
  }

  arrow1: "" {
    style.stroke: "#1976D2"
    style.stroke-width: 2
    style.animated: true
  }

  hash_tag_extraction: "Hash Tag\nExtraction" {
    shape: class
    label: "Extract {...}"
    width: 160
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    parse_rule: "{...} block"
    first_brace: "First {...}"
    no_brace: "Full key"
  }

  arrow2: "" {
    style.stroke: "#E65100"
    style.stroke-width: 2
  }

  crc16_compute: "CRC16\nComputation" {
    shape: class
    label: "CRC16(x) mod 16384"
    width: 180
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    poly: "Polynomial: 0x1021"
    result: "0x2A3B → 10811"
  }
}

explanation: "Hash Tags ensure multiple keys map to same slot for MGET/MSET operations" {
  near: bottom-center
  shape: text
  style.font-size: 14
  style.italic: true
  style.font-color: "#666666"
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  same_slot_examples: "Same Slot Examples" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    width: 250

    example1: '"user{1001}:name" -> slot 10811'
    example2: '"user{1001}:profile" -> slot 10811'
    example3: '"user{1001}:order" -> slot 10811'
  }

  different_slot_examples: "Different Slot Examples" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    width: 250

    example1: '"user{1001}:name" -> slot 10811'
    example2: '"user{1002}:name" -> slot 9234'
    example3: '"user:1001:name" (no tag) -> slot 4567'
  }
}

arrow_down: "" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
}

rules: "Hash Tag Parsing Rules" {
  shape: sql_table
  label: "Parsing Rules"
  rule1: "1. Find first {...} block in key"
  rule2: "2. If found: CRC16(hash_tag) mod 16384"
  rule3: "3. If not found: CRC16(full_key) mod 16384"
  rule4: "4. Empty {...} = empty string for CRC16"
}

key_input -> hash_tag_extraction: "extract {...}"
hash_tag_extraction -> crc16_compute: "tag or full key"
crc16_compute -> same_slot_examples: "slot 10811"
crc16_compute -> different_slot_examples: "different tags"