direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Slot Migration Process
| {near: top-center}

legend: {
  near: bottom-right
  style.fill: white
  style.stroke: gray
  
  l1: "Migration Active" {
    shape: rectangle
    style.fill: yellow
  }
  l2: "Completed" {
    shape: rectangle
    style.fill: green
  }
  l3: "ASK Redirect" {
    shape: rectangle
    style.fill: purple
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  source_node: "Source Node (slot 5000)" {
    shape: class
    label: "Source Node (slot 5000)"
    -node_id: "node:aabbcc"
    -ip: "192.168.1.10"
    -port: "6379"
    -slots_owned: "[0-4999, 5000-5460]"
    -migrating_slot: "5000"
    +migrate_keys(slot, target): "void"
    +handle_asking(client): "void"
  }
  
  target_node: "Target Node (slot 5000)" {
    shape: class
    label: "Target Node (slot 5000)"
    -node_id: "node:ddeeff"
    -ip: "192.168.1.20"
    -port: "6379"
    -slots_owned: "[5461-10922]"
    -importing_slot: "5000"
    +import_keys(slot, source): "void"
    + ASK Response: "MOVED/ASK"
  }
}

row1.source_node -> row1.target_node: "CLUSTER SETSLOT 5000 IMPORTING" {
  style.stroke: purple
  style.stroke-dash: 3
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  client_phase1: "Client: GET key1" {
    shape: rectangle
    style.fill: white
  }
  
  redirect_flow: "ASK Redirect Flow" {
    shape: diamond
    style.fill: yellow
    
    sr1: "1. Client -> Source: GET key1"
    sr2: "2. Source: key in migrating slot?"
    sr3: "3. Source -> Client: ASK 5000 target:6380"
    sr4: "4. Client -> Target: ASKING"
    sr5: "5. Target -> Client: Value (if exists)"
  }
  
  client_phase2: "Client: ASKING + GET key1" {
    shape: rectangle
    style.fill: white
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  key_transfer: "Key Transfer Sequence" {
    shape: diamond
    style.fill: yellow
    
    kt1: "Source: GETKEYS slot 5000"
    kt2: "For each key: MIGRATE target 6380"
    kt3: "MIGRATE sends key value + TTL"
    kt4: "Target: SET key value + TTL"
    kt5: "Source: DEL key (after confirm)"
  }
  
  migration_complete: "Migration Completion" {
    shape: diamond
    style.fill: green
    
    mc1: "Source: CLUSTER SETSLOT 5000 NODE target"
    mc2: "Source: CLUSTER SETSLOT 5000 MIGRATING (clear)"
    mc3: "Target: CLUSTER SETSLOT 5000 IMPORTING (clear)"
    mc4: "Target: CLUSTER SETSLOT 5000 NODE myself"
    mc5: "Gossip: Propagate new topology"
  }
}

arrow1: row1.source_node -> row2.client_phase1: "1. Initial Request" {
  style.stroke: blue
  style.stroke-dash: 3
}

arrow2: row2.client_phase1 -> row2.redirect_flow: "2. Key in migrating slot" {
  style.stroke: blue
}

arrow3: row2.redirect_flow -> row2.client_phase2: "3. Follow ASK" {
  style.stroke: purple
}

arrow4: row2.redirect_flow -> row3.key_transfer: "4. Background Transfer" {
  style.stroke: blue
  style.stroke-dash: 3
}

arrow5: row3.key_transfer -> row3.migration_complete: "5. All Keys Moved" {
  style.stroke: green
}

arrow6: row3.migration_complete -> row1.target_node: "6. Slot Ownership" {
  style.stroke: green
  style.stroke-dash: 3
}

note: "ASK vs MOVED: ASK is temporary during migration, MOVED is permanent topology update" {
  shape: rectangle
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  style.font-size: 14
}