direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # MOVED vs ASK Redirects
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  moved_section: {
    label: "MOVED Redirect"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2

    description: "Permanent redirection"
    style1: "Slot has COMPLETELY migrated"
    style2: "Client should update routing cache"
    style3: "Next request goes to new node"

    format: |'c
      -MOVED\r\n
      <slot> <node:port>\r\n
    '|

    example: |'c
      -MOVED\r\n
      1234 127.0.0.1:7001\r\n
    '|
  }

  ask_section: {
    label: "ASK Redirect"
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
    style.stroke-width: 2

    description: "Migration in progress"
    style1: "Key is being migrated"
    style2: "Ask target node for the key"
    style3: "But RETRY original node first"

    format: |'c
      -ASK\r\n
      <slot> <node:port>\r\n
    '|

    example: |'c
      -ASK\r\n
      1234 127.0.0.1:7002\r\n
    '|
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  client: {
    label: "Client"
    shape: person
    style.fill: "#BBDEFB"
  }

  original_node: {
    label: "Original Node"
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2

    slot_info: "Slot 1234"
  }

  target_node: {
    label: "Target Node"
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2

    slot_info: "Slot 1234 (migrating)"
  }
}

client -> original_node: "GET key" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}

note_moved: "MOVED: Update routing cache" {
  shape: callout
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
original_node -> client: "-MOVED" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

client -> target_node: "GET key (updated)" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 3
}
target_node -> client: "value" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

note_ask: "ASK: Ask target, retry original" {
  shape: callout
  style.fill: "#FFF8E1"
  style.stroke: "#F57C00"
}

client2: {
  label: "Client"
  shape: person
  style.fill: "#BBDEFB"
}

original_node2: {
  label: "Original Node (migrating)"
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
}

target_node2: {
  label: "Target Node (importing)"
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
}

client2 -> original_node2: "GET key" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}

original_node2 -> client2: "-ASK" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}

client2 -> target_node2: "ASKING key" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
  style.stroke-dash: 5
}

target_node2 -> client2: "value" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}

client2 -> original_node2: "GET key (retry)" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}

original_node2 -> client2: "value" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}

row1.moved_section -> row2.client: "Permanent" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
row1.ask_section -> client2: "Temporary" {
  style.stroke: "#F57C00"
  style.stroke-dash: 3
}

legend: {
  near: bottom-center
  direction: right

  legend_moved: "MOVED" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }

  legend_ask: "ASK" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
  }
}