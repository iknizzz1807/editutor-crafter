direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

legend: {
  near: bottom-center
  direction: right
  style.stroke: transparent
  style.fill: transparent
  node_legend_a: "Node A (slots 0-54_60)" {
    shape: text
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  node_legend_b: "Node B (slots 5_461-10921)" {
    shape: text
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  node_legend_c: "Node C (slots 10922-16_383)" {
    shape: text
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}

title: "Redis Cluster: Hash Slot Distribution (16_384)" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

input: "user:123:profile" {
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#666"
  label.near: top-center
}

crc16_calc: {
  label: "CRC16(key) Mod 16_384"
  width: 280
  code: |'c
    // CRC16 with polynomial 0x1021
    // XMODEM polynomial used by Redis
    uint16_t hash = 0;
    for each byte in key:
      hash ^= byte
      for i in 0..7:
        if hash & 1:
          hash = (hash >> 1) ^ 0x1021
        else:
          hash >>= 1
    return hash % 16384
  '|
}