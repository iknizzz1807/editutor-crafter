direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # epoll/kqueue Data Structures
  I/O Multiplexing: Linux vs BSD/macOS
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  linux_side: {
    label: "Linux: epoll"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    
    epoll_instance: {
      label: "struct eventpoll"
      shape: rectangle
      style.fill: white
      style.stroke: "#1565C0"
      
      rbr: "rb_root rbr         // RB-tree of registered fds"
      rdthead: "list_head rdthead   // Ready list (双向链表)"
      ovflist: "epitem* ovflist     // Overflow event list"
      rdlock: "spinlock_t lock     // Protects ready list"
    }
    
    ops: {
      label: "epoll_ctl operations"
      shape: rectangle
      style.fill: white
      style.stroke: "#1565C0"
      
      add_op: "+ADD | EPOLL_CTL_ADD"
      mod_op: "+MOD | EPOLL_CTL_MOD"
      del_op: "+DEL | EPOLL_CTL_DEL"
      
      add_op -> epoll_instance: "rb_insert(fdt, rbr)"
      mod_op -> epoll_instance: "rb_replace(fdt, rbr)"
      del_op -> epoll_instance: "rb_erase(fdt, rbr)"
    }
    
    wait_mechanism: {
      label: "epoll_wait()"
      shape: rectangle
      style.fill: white
      style.stroke: "#1565C0"
      
      wait_sig: |'c
        int epoll_wait(int epfd,
          struct epoll_event* events,
          int maxevents,
          int timeout_ms);
      '|
      width: 300
    }
    
    trigger_modes: {
      label: "Trigger Modes"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      
      level_t: {
        label: "LEVEL (default)"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: green
        desc_lt: |'c
          Fires every poll cycle while data available.
          No need to rearm after handling.
          Compatible with blocking I/O.
        '|
        width: 220
      }
      
      edge_t: {
        label: "EDGE (EPOLLET flag)"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: red
        desc_et: |'c
          Fires once on state change.
          Must drain socket buffer fully.
          Better for high-performance apps.
        '|
        width: 220
      }
    }
    
    wait_mechanism -> trigger_modes: "returns ready fd events"
  }
  
  bsd_side: {
    label: "BSD/macOS: kqueue"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    
    kqueue_state: {
      label: "struct kqueue"
      shape: rectangle
      style.fill: white
      style.stroke: "#2E7D32"
      
      kq_fds: "struct kfd[] fds  // Array of fds"
      kq_pids: "pid_t pid        // Owner process"
      kq_state: "int state       // KQ_SELF"
    }
    
    operations: {
      label: "EV_SET operations"
      shape: rectangle
      style.fill: white
      style.stroke: "#2E7D32"
      
      ev_set_ops: |'c
        EV_SET(&kev, fd, EVFILT_READ,
          EV_ADD | EV_ENABLE, 0, 0, NULL);
        
        kevent(kq, &kev, 1, NULL, 0, NULL);
      '|
      width: 280
    }
    
    kevent_wait: {
      label: "kevent()"
      shape: rectangle
      style.fill: white
      style.stroke: "#2E7D32"
      
      kevent_sig: |'c
        int kevent(int kq,
          const struct kevent* changelist,
          int nchanges,
          struct kevent* eventlist,
          int nevents,
          const struct timespec* timeout);
      '|
      width: 320
    }
    
    trigger_bsd: {
      label: "Trigger Modes"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      
      level_b: {
        label: "Level (no flags)"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: green
      }
      
      edge_b: {
        label: "Edge (EV_CLEAR)"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: red
      }
    }
    
    kevent_wait -> trigger_bsd: "returns ready kevents"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  epoll_item_detail: {
    label: "struct epitem"
    shape: sql_table
    label: "struct epitem (epitem.h)"
    e0: "0x00 | int            | fd         // File descriptor"
    e1: "0x04 | epoll_event    | event      // User-supplied events"
    e2: "0x08 | rb_node        | rbn        // RB-tree node"
    e3: "0x0C | list_head      | rdlink     // Ready list link"
    e4: "0x10 | epitem*        | next       // Overflow list next"
    e5: "0x14 | int            | epfd       // Owning epoll fd"
    sz: "Total: 24 bytes"
  }
  
  epoll_event_detail: {
    label: "struct epoll_event"
    shape: sql_table
    label: "struct epoll_event (sys/epoll.h)"
    ev0: "0x00 | uint32_t | events  // EPOLLIN|EPOLLOUT|EPOLLET"
    ev1: "0x04 | data_t   | data   // union {void*; int; uint32_t}"
    sz: "Total: 8 bytes"
  }
  
  kevent_detail: {
    label: "struct kevent"
    shape: sql_table
    label: "struct kevent (sys/event.h)"
    k0: "0x00 | uint64_t | ident    // File descriptor"
    k1: "0x08 | int16_t  | filter   // EVFILT_READ|WRITE|TIMER"
    k2: "0x0A | uint16_t | flags    // EV_ADD|DELETE|CLEAR|ONESHOT"
    k3: "0x0C | uint32_t | fflags   // Filter-specific flags"
    k4: "0x10 | int64_t  | data     // Filter-specific data"
    k5: "0x18 | void*    | udata    // User-supplied pointer"
    sz: "Total: 24 bytes"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  trigger_semantics: {
    label: "Edge vs Level Triggering"
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#455A64"
    
    level_behavior: {
      label: "Level-Triggered Behavior"
      shape: rectangle
      style.fill: white
      
      timeline_lt: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        
        cyc1: "Poll 1"
        cyc2: "Poll 2"
        cyc3: "Poll 3"
        
        ready_lt: "Data Avail"
        ready_lt.style.fill: yellow
        ready_lt.width: 60
        
        ev1_lt: "epoll_wait"
        ev1_lt.style.fill: red
        
        ev2_lt: "epoll_wait"
        ev2_lt.style.fill: red
        
        ev3_lt: "epoll_wait"
        ev3_lt.style.fill: red
      }
      
      note_lt: "Fires every cycle while data present"
      note_lt.style.fill: "#C8E6C9"
      note_lt.width: 200
    }
    
    edge_behavior: {
      label: "Edge-Triggered Behavior"
      shape: rectangle
      style.fill: white
      
      timeline_et: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        
        cyc1_e: "Poll 1"
        cyc2_e: "Poll 2"
        cyc3_e: "Poll 3"
        
        newdata: "New Data!"
        newdata.style.fill: yellow
        newdata.width: 60
        
        ev1_et: "ONCE"
        ev1_et.style.fill: red
        
        drain: "Drain"
        drain.style.fill: orange
        drain.width: 50
        
        noev: "no event"
        noev.style.fill: gray
        noev.width: 60
      }
      
      note_et: "Single fire on transition"
      note_et.style.fill: "#FFCDD2"
      note_et.width: 200
    }
  }
  
  comparison_table: {
    label: "Feature Comparison"
    shape: sql_table
    label: "epoll vs kqueue Comparison"
    f0: "Ops  | epoll_ctl ADD/MOD/DEL | EV_SET + kevent"
    f1: "Wait | epoll_wait             | kevent"
    f2: "Edge | EPOLLET flag           | EV_CLEAR flag"
    f3: "Level| Default                | Default (no flag)"
    f4: "Data | epoll_event.events     | kevent.ident + filter"
    f5: "One  | EPOLLONESHOT           | EV_ONESHOT"
    f6: "UDATA| epoll_event.data.ptr   | kevent.udata"
    f7: "Size | 16384 fds (max)        | unlimited"
  }
  
  operation_flow: {
    label: "Operation Flow"
    shape: rectangle
    style.fill: white
    style.stroke: "#455A64"
    
    flow_steps: {
      label: "ADD flow"
      shape: rectangle
      style.fill: "#E3F2FD"
      
      step1: "1. User calls epoll_ctl(ADD)"
      step2: "2. Alloc struct epitem"
      step3: "3. Insert into RB-tree (rbr)"
      step4: "4. Call file ops->poll()"
      step5: "5. If ready, add to rdthead"
      step6: "6. Return 0"
      
      step1.style.fill: white
      step2.style.fill: white
      step3.style.fill: white
      step4.style.fill: white
      step5.style.fill: white
      step6.style.fill: white
    }
    
    wait_flow: {
      label: "WAIT flow"
      shape: rectangle
      style.fill: "#E8F5E9"
      
      wstep1: "1. User calls epoll_wait()"
      wstep2: "2. Lock rdthead"
      wstep3: "3. Pop epitem from ready list"
      wstep4: "4. Copy to user events[]"
      wstep5: "5. Unlock and return count"
      
      wstep1.style.fill: white
      wstep2.style.fill: white
      wstep3.style.fill: white
      wstep4.style.fill: white
      wstep5.style.fill: white
    }
  }
}

legend: {
  label: "Legend"
  shape: rectangle
  style.fill: white
  style.stroke: black
  
  red_box: "" {
    label: "Events"
    shape: rectangle
    style.fill: red
    style.stroke: transparent
    width: 30
    height: 20
  }
  
  yellow_box: "" {
    label: "State"
    shape: rectangle
    style.fill: yellow
    style.stroke: transparent
    width: 30
    height: 20
  }
  
  orange_box: "" {
    label: "Operation"
    shape: rectangle
    style.fill: orange
    style.stroke: transparent
    width: 30
    height: 20
  }
  
  green_box: "" {
    label: "Behavior"
    shape: rectangle
    style.fill: green
    style.stroke: transparent
    width: 30
    height: 20
  }
  
  gray_box: "" {
    label: "No Event"
    shape: rectangle
    style.fill: gray
    style.stroke: transparent
    width: 30
    height: 20
  }
}
legend.near: bottom-right