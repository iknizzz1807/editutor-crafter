direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Non-blocking Socket Behavior
  |
  shape: text
  near: top-center
}

layer_transport: {
  label: "TRANSPORT LAYER"
  direction: down
  
  socket_states: {
    shape: sql_table
    label: "Socket State Flags"
    f0: "0x00 | int | fd"
    f1: "0x04 | uint32_t | events (EPOLLIN|EPOLLOUT)"
    f2: "0x08 | sds | read_buffer"
    f3: "0x10 | sds | write_buffer"
    f4: "0x18 | bool | non_blocking"
    sz: "Total: 24 bytes"
  }
  
  return_values: {
    shape: class
    label: "Return Values (man 2 recv)"
    recv_len: "ssize_t (bytes read or -1)"
    send_len: "ssize_t (bytes written or -1)"
    standard: "recv: >0=data, 0=EOF, -1=error"
    blocking: "send: >0=written, 0=blocked, -1=error"
  }
}

layer_states: {
  label: "STATE MACHINE"
  direction: right
  
  idle: {
    label: "IDLE"
    shape: circle
    style.fill: "#E8E8E8"
  }
  
  readable: {
    label: "READABLE\n(EPOLLIN)"
    shape: circle
    style.fill: "#90EE90"
  }
  
  writable: {
    label: "WRITABLE\n(EPOLLOUT)"
    shape: circle
    style.fill: "#87CEEB"
  }
  
  error: {
    label: "ERROR"
    shape: circle
    style.fill: "#FFB6C1"
  }
  
  closed: {
    label: "CLOSED"
    shape: circle
    style.fill: "#808080"
    style.font-color: white
  }
  
  idle -> readable: "data arrives"
  readable -> writable: "write pending"
  writable -> idle: "write complete"
  error -> closed: "disconnect"
  readable -> closed: "peer close"
}

layer_eagain: {
  label: "EAGAIN HANDLING"
  direction: down
  
  code_recv: {
    label: "recv() Flow"
    width: 380
    code: |'c
      char buf[16384];
      ssize_t n;
      
      // Non-blocking mode
      n = recv(fd, buf, sizeof(buf), 0);
      if (n == -1) {
        if (errno == EAGAIN || errno == EWOULDBLOCK) {
          // No data available, retry later
          return 0;
        }
        // Actual error
        return -1;
      }
      return n;
    '|
  }
  
  code_send: {
    label: "send() Flow"
    width: 380
    code: |'c
      const char* buf = "hello";
      ssize_t n;
      
      n = send(fd, buf, strlen(buf), 0);
      if (n == -1) {
        if (errno == EAGAIN || errno == EWOULDBLOCK) {
          // Buffer full, retry later
          return 0;
        }
        // Actual error
        return -1;
      }
      return n;
    '|
  }
}

layer_transport -> layer_states: "state transition"
layer_states -> layer_eagain: "EAGAIN"
layer_eagain.code_recv -> layer_transport.return_values: "validate"