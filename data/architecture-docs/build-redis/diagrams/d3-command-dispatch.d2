direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Command Dispatch Flow
| {near: top-center}

legend: {
  near: bottom-center
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  input: "Input Data" {
    shape: rectangle
    style.fill: "#E3F2FD"
  }
  process: "Processing" {
    shape: rectangle
    style.fill: "#FFF3E0"
  }
  output: "Output" {
    shape: rectangle
    style.fill: "#E8F5E9"
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  input_stage: {
    label: "1. Input"
    direction: down
    
    recv_bytes: {
      label: "recv() bytes"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.border-radius: 8
    }
    
    resp_parser: {
      label: "RESP Parser"
      shape: rectangle
      style.fill: "#BBDEFB"
      style.border-radius: 8
      width: 160
    }
  }
  
  arrow1: "" {
    style.stroke: "#1976D2"
    style.stroke-width: 3
    style.stroke-dash: 0
  }
  
  lookup_stage: {
    label: "2. Name Lookup"
    direction: down
    
    cmd_buffer: {
      label: "Command Buffer"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.border-radius: 8
    }
    
    cmd_table: {
      label: "Command Table (dict)"
      shape: sql_table
      label: "Command Table"
      name: "string | command name"
      handler: "func* | handler ptr"
      arity: "int | arg count"
      f0: "+get: command_get | 2"
      f1: "+set: command_set | -3"
      f2: "+del: command_del | -2"
      f3: "+ping: command_ping | 1"
      f4: "..."
      sz: "O(1) lookup via hash"
    }
  }
  
  arrow2: "" {
    style.stroke: "#F57C00"
    style.stroke-width: 3
    style.stroke-dash: 0
  }
  
  validation_stage: {
    label: "3. Validation"
    direction: down
    
    arity_check: {
      label: "Arity Check"
      shape: diamond
      style.fill: "#FFE0B2"
      style.border-radius: 4
      width: 140
    }
    
    type_check: {
      label: "Type Check"
      shape: diamond
      style.fill: "#FFCC80"
      style.border-radius: 4
      width: 140
    }
    
    auth_check: {
      label: "Auth Check"
      shape: diamond
      style.fill: "#FFB74D"
      style.border-radius: 4
      width: 140
    }
  }
}

row1.arrow1 -> row1.lookup_stage: "command name" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}

row1.lookup_stage -> row1.validation_stage: "RedisCommand*" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  arrow_enter: "argc, argv" {
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  
  handler_stage: {
    label: "4. Handler Execution"
    direction: down
    
    cmd_handler: {
      label: "Command Handler"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.border-radius: 8
      width: 200
      code: |'c
        void command_get(Client* c, 
                         RedisServer* s, 
                         int argc, 
                         sds* argv) {
          // 1. Validate args
          // 2. Fetch from dict
          // 3. Check TTL
          // 4. Serialize response
        }
      '|
    }
    
    data_layer: {
      label: "Data Layer (dict)"
      shape: cylinder
      style.fill: "#FFECB3"
      style.border-radius: 4
      width: 160
    }
  }
  
  arrow_exit: "result" {
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  
  output_stage: {
    label: "5. Response Output"
    direction: down
    
    resp_builder: {
      label: "RESP Serializer"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.border-radius: 8
      width: 160
    }
    
    write_buffer: {
      label: "Write Buffer"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.border-radius: 8
    }
    
    send_bytes: {
      label: "send() to client"
      shape: rectangle
      style.fill: "#A5D6A7"
      style.border-radius: 8
    }
  }
}

row1.validation_stage -> row2.handler_stage: "validated args" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}

row2.handler_stage -> row2.output_stage: "response data" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}

error_path: "ERROR" {
  shape: diamond
  style.fill: "#FFCDD2"
  style.stroke: "#E53935"
  style.stroke-width: 2
}

error_path -> row2.output_stage: "error response" {
  style.stroke: "#E53935"
  style.stroke-width: 2
  style.stroke-dash: 4
}