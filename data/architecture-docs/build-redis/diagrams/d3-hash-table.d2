direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # In-Memory Hash Table Structure
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  dict_entry: {
    shape: sql_table
    label: "dictEntry (dict.h)"
    f0: "0x00 | void*   | key"
    f1: "0x08 | void*   | val"
    f2: "0x10 | dictEntry* | next  // collision chain"
    f3: "0x18 | uint64_t | siphash(key)"
    sz: "Total: 24 bytes (3 cache lines)"
  }

  bucket_array: {
    shape: sql_table
    label: "dict->ht_table[0] (dict.c)"
    f0: "0x00 | dictEntry* | bucket[0]"
    f1: "0x08 | dictEntry* | bucket[1]"
    fn: "0x... | dictEntry* | bucket[n-1]"
    note: "Array of pointers, 8 bytes each"
    sz: "Total: n * 8 bytes"
  }

  dict_struct: {
    shape: sql_table
    label: "struct dict (dict.h)"
    f0: "0x00 | dictType*   | type"
    f1: "0x08 | void**    | ht_table[2]"
    f2: "0x18 | long      | rehashidx  // -1 = idle"
    f3: "0x20 | long      | iterators"
    f4: "0x28 | size_t    | size      // power of 2"
    f5: "0x30 | size_t    | sizemask  // size-1"
    f6: "0x38 | size_t    | used"
    sz: "Total: 64 bytes (fits in cache line)"
  }
}

dict_struct.ht_table -> bucket_array: "ht_table[0] | pointer"
bucket_array.bucket -> dict_entry: "bucket[i] | points to first entry"

annotation: "" {
  near: bottom-right
  style.stroke: transparent
  style.fill: transparent

  note1: { shape: text; label: "Red = hot path (siphash + key lookup)" }
  note2: { shape: text; label: "Green = fixed-width chaining" }
  note3: { shape: text; label: "Key is stored as null-terminated string" }
  note4: { shape: text; label: "Value can be string | list | set | zset | hash" }
}