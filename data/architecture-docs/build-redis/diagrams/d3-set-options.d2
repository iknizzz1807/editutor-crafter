direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

SET_OPTIONS: {
  shape: class
  label: "SET Command Options"
  -key: "sds"
  -value: "sds"
  -nx: "bool"
  -xx: "bool"
  -expiresecs: "int64_t"
  -expireseconds: "int64_t"
  +set_with_options(key, value, nx, xx, ex, px): "int"
}

flag_parse: {
  label: "Flag Parser"
  width: 300
  code: |'c
    for (int i = 1; i < argc; i++) {
      if (!strcmp(argv[i], "NX")) opt->nx = true;
      else if (!strcmp(argv[i], "XX")) opt->xx = true;
      else if (!strcmp(argv[i], "EX")) opt->ex = atoi(argv[++i]);
      else if (!strcmp(argv[i], "PX")) opt->px = atoi(argv[++i]);
    }
  '|
}

flag_parse -> SET_OPTIONS: "options struct"
SET_OPTIONS -> result: "status"