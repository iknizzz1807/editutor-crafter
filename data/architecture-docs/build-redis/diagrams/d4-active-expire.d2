direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # Active Expiration Algorithm
  Time-bounded probabilistic key cleanup
| {near: top-center}

step1_enter: {
  label: "Step 1: Enter Active Expire Cycle"
  shape: step
  style.fill: "#E4DBFE"
  note: "Called from event loop every ~100ms"
}

step2_sample: {
  label: "Step 2: Sample 20 Random Keys"
  shape: step
  style.fill: "#C7F1FF"
  code: |'c
    for (int i = 0; i < 20; i++) {
      sampleRandomKey();
    }
  '|
}

step3_check: {
  label: "Step 3: Check Each Key's TTL"
  shape: step
  style.fill: "#B3E7FF"
}

step4_skip: {
  label: "Step 4: If TTL > 0, Skip"
  shape: step
  style.fill: "#CCFFE5"
}

step5_delete: {
  label: "Step 5: Delete if TTL <= 0"
  shape: step
  style.fill: "#FFCCE5"
}

step6_repeat: {
  label: "Step 6: Repeat Next Cycle"
  shape: step
  style.fill: "#FFE5CC"
}

step1_enter -> step2_sample -> step3_check
step3_check -> step4_skip
step4_skip -> step5_delete
step5_delete -> step6_repeat
step6_repeat -> step1_enter
step4_skip -> step6_repeat
