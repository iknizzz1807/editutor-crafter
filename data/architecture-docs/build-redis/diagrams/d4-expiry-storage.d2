direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  redis_object: {
    shape: sql_table
    label: "RedisObject (redis.h)"
    f0: "0x00 | ObjectType | type"
    f1: "0x04 | uint32_t  | refcount"
    f2: "0x08 | union    | data"
    f3: "0x10 | int64_t  | expire_at // -1 = no expire"
    f4: "0x18 | uint64_t | access_time // for LRU"
    sz: "Total: 24 bytes (aligned)"
  }
  
  storage_format: {
    shape: sql_table
    label: "Expiration Storage"
    f0: "| Format    | int64_t milliseconds     |"
    f1: "| Range    | 0 to INT64_MAX        |"
    f2: "| No-TTL   | -1 (sentinel value)   |"
    f3: "| Unit    | Unix ms (not seconds) |"
    note: "Absolute, not relative TTL"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  ttl_command: {
    shape: class
    label: "TTL Command (expire.c)"
    +ttl(key): "int64_t // -1=no expiry, -2=key not found"
    +pttl(key): "int64_t // milliseconds remaining"
    +expire(key, seconds): "int // 1=set, 0=not found"
    +persist(key): "int // 1=removed, 0=not_found"
    -calculate_remaining(expire_at): "int64_t"
    -is_expired(expire_at): "bool"
  }
  
  clock_system: {
    shape: class
    label: "Clock System (server.c)"
    +get_current_time_ms(): "uint64_t"
    +get_monotonic_time_ms(): "uint64_t"
    +update_server_time(): "void"
    -real_time_ms: "uint64_t"
    -monotonic_ms: "uint64_t"
    -last_update: "time_t"
    note: "Wall clock for expiry, monotonic for stats"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  lazy_expire: {
    shape: class
    label: "Lazy Expiration (expire.c)"
    +check_on_access(obj, key): "void // deletes if expired"
    +get_value(key): "RedisObject* // returns NULL if expired"
    +get_string(key): "sds // returns NULL if expired"
    note: "Checked on every GET/SET/HGET access"
  }
  
  active_expire: {
    shape: class
    label: "Active Expiration (expire.c)"
    +active_expire_cycle(): "int // keys expired this cycle"
    +sample_and_expire(sample_size): "int"
    -EXPIRECHECK_SIZE: "100 // keys per cycle"
    -EXPIRECHECK_RATE: "100 // cycles per second"
    note: "Probabilistic, time-bounded sampling"
  }
}

row1 -> row2.ttl_command: "expire_at | read"
row1 -> row2.clock_system: "time source | provides"
row2.ttl_command -> row2.ttl_command: "calculate | expire_at - now"
row2.ttl_command -> row3.lazy_expire: "calls | on access"
row2.ttl_command -> row3.active_expire: "triggers | periodically"

legend: {
  near: bottom-center
  l1: |md
    **Storage Format:**
    - Absolute Unix timestamp in milliseconds
    - -1 sentinel = no expiration
    - Survives clock adjustments
  |
  l2: |md
    **Clock Handling:**
    - Real-time clock: wall time for expiry checks
    - Monotonic: time deltas for stats/latency
    - NTP adjustment handled correctly
  |
  l3: |md
    **Expiration Triggers:**
    - Lazy: on key access (GET/SET)
    - Active: probabilistic sampling
  |
}