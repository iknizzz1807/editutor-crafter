direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Lazy Expiration Flow {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  client: Client {
    shape: person
    style.fill: "#C7F1FF"
    label: redis-cli
  }

  command_dispatcher: Command Dispatcher {
    shape: rectangle
    style.fill: "#E4DBFE"
    style.border-radius: 8
    label: command_dispatch()
  }

  hash_table: Hash Table {
    shape: class
    label: "Dict (dict.c)"
    -table: "HashEntry*"
    -size: "size_t"
    -used: "size_t"
    +dictFind(d, key): "dictEntry*"
    +dictDelete(d, key): "int"
  }
}

client -> command_dispatcher: "GET key" {
  style.stroke: "#88DCF7"
  style.stroke-width: 2
}

command_dispatcher -> hash_table: "dictFind(key)" {
  style.stroke: "#B5AFF6"
  style.stroke-width: 2
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  check_expired: "" {
    style.stroke: transparent
    style.fill: transparent
    direction: right

    decision: Check Expiry {
      shape: diamond
      style.fill: "#FFF9C9"
      style.stroke: "#F69E03"
      label: "expire_at != -1\n&&\nexpire_at <= now?"
    }

    expire_yes: Expired {
      shape: rectangle
      style.fill: "#FE7070"
      style.stroke: "#F69E03"
      label: "Delete Key\n& Return nil"
    }

    expire_no: Valid {
      shape: rectangle
      style.fill: "#ACE1AF"
      style.stroke: "#3D9069"
      label: "Return Value"
    }
  }

  redis_object: RedisObject {
    shape: sql_table
    label: "struct RedisObject"
    f0: "type | ObjectType"
    f1: "refcount | uint32_t"
    f2: "data | union{}"
    f3: "expire_at | int64_t"
  }
}

hash_table -> check_expired.decision: "found" {
  style.stroke: "#B5AFF6"
  style.stroke-width: 2
}

check_expired.decision -> check_expired.expire_yes: "YES" {
  style.stroke: "#FE7070"
  style.stroke-width: 2
}

check_expired.decision -> check_expired.expire_no: "NO" {
  style.stroke: "#ACE1AF"
  style.stroke-width: 2
}

hash_table -> redis_object: "dictEntry->val" {
  style.stroke: "#B5AFF6"
  style.stroke-width: 1
  style.stroke-dash: 3
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  result: Result {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#88DCF7"
    label: "(nil) or value"
  }
}

check_expired.expire_yes -> result: "nil" {
  style.stroke: "#FE7070"
  style.stroke-width: 2
}

check_expired.expire_no -> result: "value" {
  style.stroke: "#ACE1AF"
  style.stroke-width: 2
}

legend: "" {
  near: bottom-center
  direction: right
  style.stroke: transparent
  style.fill: transparent

  l1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    style.opacity: 0
    label1: |md
      **Legend**
    |
    label1.shape: text
  }

  l2: Check {
    shape: diamond
    style.fill: "#FFF9C9"
    style.stroke: "#F69E03"
    label: "Decision"
  }

  l3: Delete {
    shape: rectangle
    style.fill: "#FE7070"
    style.stroke: "#F69E03"
    label: "Expired"
  }

  l4: Return {
    shape: rectangle
    style.fill: "#ACE1AF"
    style.stroke: "#3D9069"
    label: "Valid"
  }
}