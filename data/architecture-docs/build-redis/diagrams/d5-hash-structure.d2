direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Hash Implementation: Nested Hash Table
| {near: top-center}

classes: {
  header: {
    style.fill: "#B5AFF6"
    style.font-color: white
    style.bold: true
  }
  dataflow: {
    style.stroke: blue
    style.stroke-width: 2
  }
  operation: {
    style.fill: "#88DCF7"
    style.stroke: "#0066CC"
  }
  warning: {
    style.fill: "#FFE7CB"
    style.stroke: orange
  }
  comparison: {
    style.fill: "#E8F5E9"
    style.stroke: green
  }
}

comparison_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  nested_approach: {
    label: "NESTED HASH TABLE"
    style.bold: true
    style.font-size: 18
    
    storage_layer: {
      label: "Storage Layer"
      style.fill: "#E8F5E9"
      
      main_dict: {
        label: "Dict (main_db.dict)\n-key: sds\n-value: RedisObject*"
        shape: rectangle
        style.fill: white
        style.stroke: "#0066CC"
        
        nested_detail: {
          label: "RedisObject->data.hash"
          
          inner_dict: {
            label: "Dict (inner field table)\n-key: sds (field)\n-value: sds (value)"
            shape: rectangle
            style.fill: white
            style.stroke: green
          }
        }
      }
    }
    
    hset_op: {
      label: "HSET Operation"
      shape: rectangle
      style.fill: "#C7F1FF"
      
      step1: |'c
        1. dictFetchValue(db, "user:1")
           -> returns RedisObject*
      '|
      step2: |'c
        2. Check type == OBJ_TYPE_HASH
           If not, return WRONGTYPE error
      '|
      step3: |'c
        3. dictReplace(inner_dict, "name", "Alice")
           -> O(1) hash lookup in inner dict
      '|
      step4: |'c
        4. Return: (integer) number of fields set
      '|
    }
    
    hget_op: {
      label: "HGET Operation"
      shape: rectangle
      style.fill: "#C7F1FF"
      
      step1: |'c
        1. dictFetchValue(db, "user:1")
           -> returns RedisObject*
      '|
      step2: |'c
        2. Check type == OBJ_TYPE_HASH
           If null, return null bulk string
      '|
      step3: |'c
        3. dictFetchValue(inner_dict, "name")
           -> returns sds value
      '|
      step4: |'c
        4. Return: bulk string with value
      '|
    }
  }

  vs_label: "vs" {
    shape: text
    style.font-size: 24
    style.bold: true
  }

  flat_approach: {
    label: "FLAT KEY CONCATENATION"
    style.bold: true
    style.font-size: 18
    
    storage_layer2: {
      label: "Storage Layer"
      style.fill: "#FFE7CB"
      
      flat_dict: {
        label: "Dict (main_db.dict)\n\"user:1:name\": sds\n\"user:1:age\": sds\n\"user:1:city\": sds"
        shape: rectangle
        style.fill: white
        style.stroke: orange
      }
      
      problem: {
        shape: rectangle
        style.fill: "#FFCCCC"
        style.stroke: red
        label: "PROBLEMS"
        
        p1: "No type tracking per logical key"
        p2: "DEL \"user:1\" leaves orphaned fields"
        p3: "No atomic multi-field operations"
        p4: "Key namespace pollution"
      }
    }
    
    example: {
      label: "Example: FLAT"
      code: |'c
        SET user:1:name "Alice"
        SET user:1:age "30"
        -- Problem: How to know these belong together?
        -- Problem: DEL user:1 doesn't delete age/city
        -- Problem: No HGETALL equivalent
      '|
    }
  }
}

hset_op -> main_dict: "SET key \"user:1\"" {
  style.stroke: blue
}
main_dict -> nested_detail: "Returns RedisObject*" {
  style.stroke: green
  style.stroke-dash: 3
}
nested_detail -> inner_dict: "Access inner->dict" {
  style.stroke: green
  style.stroke-dash: 3
}
inner_dict -> hget_op: "dictReplace(field, value)" {
  style.stroke: blue
}

comparison_row.nested_approach.hset_op -> comparison_row.nested_approach.main_dict: "1. Lookup key" {
  style.stroke: blue
}
comparison_row.nested_approach.main_dict -> comparison_row.nested_approach.nested_detail.inner_dict: "2. Access inner dict" {
  style.stroke: blue
  style.stroke-dash: 3
}
comparison_row.nested_approach.nested_detail.inner_dict -> comparison_row.flat_approach.problem: "AVOIDS" {
  style.stroke: green
  style.stroke-dash: 5
}

legend: {
  near: bottom-center
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  l1: "Nested: Type-safe, atomic, O(1) field ops" {
    style.fill: "#E8F5E9"
    shape: rectangle
  }
  l2: "Flat: No isolation, orphaned keys" {
    style.fill: "#FFE7CB"
    shape: rectangle
  }
}

comparison_row.nested_approach.storage_layer.style.fill: "#E8F5E9"
comparison_row.flat_approach.storage_layer2.style.fill: "#FFF3E0"