direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

legend: {
  near: bottom-center
  shape: rectangle
  style.fill: white
  style.stroke: gray
  style.stroke-dash: 3
  l1: "Hash Set (O(1))" {
    style.fill: "#90EE90"
  }
  l2: "List Alternative (O(n))" {
    style.fill: "#FFB6C1"
  }
}

main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  overview: "Set Implementation (Hash Set)" {
    shape: rectangle
    style.fill: "#E8F4FD"
    style.stroke: "#4A90D9"
    style.font-size: 24
    style.bold: true
  }
  
  set_visual: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    set_container: "Redis Set" {
      shape: class
      label: "Set (set.h)"
      +sadd(member): "long long"
      +srem(member): "long long"
      +sismember(member): "int"
      +smembers(): "sds[]"
      +scard(): "size_t"
      -dict: "dict*"
    }
    
    vs: "vs" {
      shape: text
      style.font-size: 30
      style.bold: true
    }
    
    list_alternative: "List Alternative (BAD)" {
      shape: class
      label: "List (broken)"
      +sadd_check_exists: "O(n) scan"
      +sismember: "O(n) scan"
      +check_duplicate: "O(n) full scan"
      -data: "list*"
    }
  }
  
  arrow1: overview -> set_container: "Core Structure"
}

main2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  dict_structure: "Internal: Hash Table (dict)" {
    shape: class
    label: "dict (dict.c)"
    -table: "dictEntry[][]"
    -size: "size_t"
    -used: "size_t"
    -rehash_idx: "int"
    +dictAdd(key, val): "int"
    +dictReplace(key, val): "int"
    +dictFind(key): "dictEntry*"
    +dictDelete(key): "int"
  }
  
  arrow2: set_visual -> dict_structure: "Uses"
}

main3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  sadd_flow: "SADD Uniqueness Enforcement" {
    shape: class
    label: "SADD Flow"
    width: 350
    code: |'c
      1. hash(key) -> slot
      2. dictFind(key) -> entry?
      3. if NULL: dictAdd() -> OK
         if exists: return 0 (not added)
      4. return count of NEW elements
    '|
  }
  
  compare: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    
    o1_row: "O(1) Operations:" {
      style.stroke: transparent
      style.fill: transparent
      style.bold: true
      style.font-color: green
    }
    o1_list: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      sadd_o1: "SADD" { style.font-color: green }
      sis_o1: "SISMEMBER" { style.font-color: green }
      srem_o1: "SREM" { style.font-color: green }
      scard_o1: "SCARD" { style.font-color: green }
    }
    
    on_row: "O(n) Operations:" {
      style.stroke: transparent
      style.fill: transparent
      style.bold: true
      style.font-color: red
    }
    on_list: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      smem_on: "SMEMBERS" { style.font-color: red }
    }
  }
}

main4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  collision_detail: "Collision Handling" {
    shape: class
    label: "dictEntry (collision)"
    key: "sds"
    v: "void*"
    next: "dictEntry*"
  }
  
  collision_explain: "Chaining (separate chaining)" {
    shape: rectangle
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
    width: 280
    text: |md
      **Hash Collision Resolution:**
      - Each bucket is a linked list
      - New entries appended to bucket head
      - Lookup scans chain until match
      - Load factor ~0.75 triggers resize
    |
  }
}

main5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  type_error: "Type Safety (CRITICAL)" {
    shape: class
    label: "Type Error Check"
    +check_type(key, OBJ_TYPE_SET): "void"
    error_msg: "WRONGTYPE Operation against a key\nholding the wrong kind of value"
  }
  
  safety_note: "" {
    shape: rectangle
    style.fill: "#FFE4E1"
    style.stroke: "#FF6347"
    width: 300
    text: |md
      **Why Type Tags Matter:**
      - SET key "value" vs SET key {a,b,c}
      - Must reject LPUSH on existing string
      - Without type: LPUSH corrupts memory
      - WRONGTYPE preserves existing data
    |
  }
}

set_container -> dict_structure: "Embedded dict"
dict_structure -> collision_detail: "Entry has chain"
sadd_flow -> compare: "O(1) uniqueness"
type_error -> safety_note: "Enforces"

style.fill: "#F5F5F5"