direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Type System and WRONGTYPE Error
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  redis_object: {
    label: "RedisObject (object.h)"
    shape: sql_table
    f0: "0x00 | ObjectType | type"
    f1: "0x04 | uint32_t  | refcount"
    f2: "0x08 | sds       | string"
    f3: "0x08 | list*     | list"
    f4: "0x08 | Set*      | set"
    f5: "0x08 | Hash*     | hash"
    f6: "0x10 | int64_t   | expire_at"
    sz: "Total: 24 bytes"
  }

  type_enum: {
    label: "ObjectType Enum"
    shape: sql_table
    t0: "OBJ_TYPE_NONE   = 0  | not set"
    t1: "OBJ_TYPE_STRING = 1  | SET/GET"
    t2: "OBJ_TYPE_LIST   = 2  | LPUSH/LPOP"
    t3: "OBJ_TYPE_SET    = 3  | SADD/SMEM"
    t4: "OBJ_TYPE_HASH   = 4  | HSET/HGET"
  }
}

row1.redis_object -> row1.type_enum: "type field | validates"

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  command_handler: {
    label: "Command Handler (command.c)"
    shape: class
    label: "Command Handler"
    +command_lpush(c, argv): "void"
    +command_lpop(c, argv): "void"
    +command_sadd(c, argv): "void"
    +command_hset(c, argv): "void"
    +getObjectByType(d, key, type): "RedisObject*"
  }

  type_check: {
    label: "Type Validation Flow"
    shape: rectangle
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    tc1: "1. Fetch key from dict"
    tc2: "2. Check obj->type == expected"
    tc3: "3. If mismatch → WRONGTYPE error"
    tc4: "4. If match → proceed with op"
  }
}

row1.type_enum -> row2.command_handler: "type enum | defines"

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  lpush_flow: {
    label: "LPUSH Command Flow"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    lf1: "LPUSH key element"
    lf2: "dictFetchValue(db, key)"
    lf3: "obj != NULL && obj->type != LIST?"
    lf4: "YES → typeErrorReply(c, LIST)"
    lf5: "NO → listAddNodeHead()"
  }

  wrongtype_error: {
    label: "WRONGTYPE Error Response"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    we1: "Error: WRONGTYPE"
    we2: "Operation against a key"
    we3: "holding the wrong kind"
    we4: "of value"
    we5: "key NOT modified"
  }
}

row2.command_handler -> row3.lpush_flow: "command | executes"
row3.lpush_flow -> row3.wrongtype_error: "type mismatch | triggers"
row3.wrongtype_error: {
  style.stroke: "#C62828"
  style.stroke-dash: 4
}
row3.wrongtype_error -> row2.command_handler: "data intact | confirms" {
  style.stroke: green
}

legend: {
  near: bottom-center
  direction: right

  legend_green: {
    label: "Data Intact"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: green
  }

  legend_red: {
    label: "Type Mismatch"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: red
    style.stroke-dash: 4
  }
}