direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## Automatic Save Triggers (Milestone 6)
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  input_layer: {
    label: "Client Commands"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    
    write_cmds: "SET/DEL/INCR\nLPUSH/SADD"
  }
  
  counter_logic: {
    label: "Change Tracking"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    
    dirty_counter: "dirty++"
    dirty_var: "dirty: 0"
  }
}

row1.input_layer -> row1.counter_logic: "write command"

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  time_check: {
    label: "Time Accumulator"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    
    last_save: "last_save: 1234567890"
    now: "now: 1234567950"
    elapsed: "elapsed: 60s"
  }
  
  threshold_check: {
    label: "Threshold Rules"
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    
    rule1: "save 900 1"
    rule2: "save 300 10"
    rule3: "save 60 10000"
  }
}

row1.counter_logic -> row2.time_check: "dirty++"

row2.time_check -> row2.threshold_check: "elapsed >= seconds?"

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  bg_save_check: {
    label: "BGSAVE Status Check"
    shape: diamond
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    
    is_running: "bgsave_child\n== -1 ?"
  }
  
  fork_process: {
    label: "fork() BGSAVE"
    shape: rectangle
    style.fill: "#E1F5FE"
    style.stroke: "#0277BD"
    
    code: |'c
      pid_t pid = fork();
      if (pid == 0) {
        rdbSave("dump.rdb", db);
        _exit(0);
      }
    '|
    width: 220
  }
}

row2.threshold_check -> row3.bg_save_check: "dirty >= changes?"

row3.bg_save_check -> row3.fork_process: "yes & not running"

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  child_save: {
    label: "Child Process"
    shape: rectangle
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
    
    save_steps: "1. Write temp.rdb\n2. fsync()\n3. rename()"
  }
  
  parent_continue: {
    label: "Parent Continues"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    
    event_loop: "Event loop never blocks"
    serve_clients: "Serves clients normally"
  }
}

row3.fork_process -> row4.child_save: "pid == 0"
row3.fork_process -> row4.parent_continue: "pid > 0"

legend: {
  near: bottom-center
  style.fill: white
  style.stroke: "#90A4AE"
  
  legend_trigger: "Trigger Condition"
  legend_action: "Action"
  legend_state: "State"
  
  legend_trigger.style.fill: "#F3E5F5"
  legend_action.style.fill: "#E8F5E9"
  legend_state.style.fill: "#FFF3E0"
}

row2.threshold_check -> row3.bg_save_check: "dirty >= 1 && elapsed >= 900s" {
  style.font-size: 11
  style.stroke: "#7B1FA2"
}