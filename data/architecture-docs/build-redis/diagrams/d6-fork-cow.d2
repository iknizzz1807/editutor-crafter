direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Fork with Copy-on-Write (COW)
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  parent_container: {
    label: "Parent Process (Redis Server)"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2

    parent_pt: {
      label: "Page Table"
      shape: sql_table
      style.fill: white
      p0: "Page0 → Phys:0x1000 (r)"
      p1: "Page1 → Phys:0x2000 (r)"
      p2: "Page2 → Phys:0x3000 (r)"
      p3: "Page3 → Phys:0x4000 (r)"
    }

    parent_memory: {
      label: "Physical Memory (Shared Pages)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      style.stroke-width: 2

      phys_page0: "0x1000 | Hash Table | keys: [a-z]"
      phys_page1: "0x2000 | String: counter | 42"
      phys_page2: "0x3000 | List: queue | [...]"
      phys_page3: "0x4000 | Set: users | {alice,bob}"
    }

    parent_event_loop: {
      label: "Event Loop"
      shape: class
      style.fill: white
      +handle_client: "fd -> cmd"
      +reactor_wait: "epoll_wait()"
      +process_command: "cmd -> result"
    }

    parent_pt -> parent_memory: "maps to" {
      style.stroke-dash: 3
      style.stroke: "#1976D2"
    }
  }

  arrow1: "➜" {
    style.opacity: 0
  }

  child_container: {
    label: "Child Process (BGSAVE)"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    style.stroke-width: 2

    child_pt: {
      label: "Page Table"
      shape: sql_table
      style.fill: white
      p0: "Page0 → Phys:0x1000 (r)"
      p1: "Page1 → Phys:0x2000 (r)"
      p2: "Page2 → Phys:0x3000 (r)"
      p3: "Page3 → Phys:0x4000 (r)"
    }

    child_note: {
      label: "READS shared pages (no copy)"
      shape: text
      style.font-color: "#388E3C"
      style.font-size: 14
      style.italic: true
    }

    rdb_writer: {
      label: "RDB Writer"
      shape: class
      style.fill: white
      +rdb_save: "dict -> file"
      +write_entry: "key -> RDB"
    }

    child_pt -> phys_page_in_parent: "maps to same" {
      style.stroke-dash: 3
      style.stroke: "#388E3C"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  write_trigger: {
    label: "Step 1: Write Triggers COW"
    shape: diamond
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    style.stroke-width: 2

    client_cmd: {
      label: "Client sends: SET counter 100"
      shape: text
      style.font-size: 12
    }

    kernel_action: {
      label: "Kernel: page fault"
      shape: text
      style.font-size: 12
    }
  }

  arrow2: "➜" {
    style.opacity: 0
  }

  page_copy: {
    label: "Page Copy-on-Write"
    shape: rectangle
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
    style.stroke-width: 2

    old_page: "Phys:0x2000 (original)" {
      style.stroke-dash: 5
      style.opacity: 0.5
    }

    new_page: "Phys:0x5000 (copy)" {
      style.fill: "#FFECB3"
    }

    arrow_cp: "copy" {
      style.stroke: "#FBC02D"
      style.stroke-width: 2
      style.animated: true
    }
  }

  arrow3: "➜" {
    style.opacity: 0
  }

  separation: {
    label: "Step 2: Private Copies"
    shape: diamond
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"

    parent_phys: "Parent: Phys:0x5000"
    child_phys: "Child: Phys:0x2000 (unchanged)"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  benefit_1: {
    label: "Why Non-Blocking?"
    shape: rectangle
    style.fill: white
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    bullet1: "• fork() is instant (metadata only)"
    bullet2: "• Child reads without locks"
    bullet3: "• Parent never blocked"
    bullet4: "• Pages copied only on write"
  }

  note_box: {
    label: "CRITICAL: Both page tables initially point to SAME physical pages marked READ-ONLY. The kernel copies only when a write occurs."
    shape: text
    style.font-size: 14
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
}

parent_container -> child_container: "fork()" {
  style.stroke: "#9C27B0"
  style.stroke-width: 3
  style.animated: true
}

write_trigger -> page_copy: "SET counter 100" {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}

legend: {
  near: bottom-center
  label: "Legend"
  shape: text
  style.font-size: 16
  style.bold: true
}

style: {
  fill: "#FAFAFA"
  stroke: "#424242"
}