direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # RDB Binary File Format
| {
  near: top-center
}

rdb_file: RDB File {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  header: Header {
    label: "Header (13 bytes)"
    shape: rectangle
    style.fill: "#E8D5B7"
    style.stroke: "#8B7355"
    
    magic: Magic String {
      shape: sql_table
      label: "Magic: 'REDIS0011'"
      f0: "0x00 | uint8[9] | \"REDIS0011\""
      f1: "        | 9 bytes  | Version marker"
    }
    
    version: Version {
      shape: sql_table
      label: "Version: 0011"
      f0: "0x09 | uint8[4] | \"0011\""
      f1: "        | 4 bytes  | Format version"
    }
  }
  
  database: Database Section {
    label: "Database Section (variable)"
    shape: rectangle
    style.fill: "#C7E8B8"
    style.stroke: "#5D8A3E"
    
    aux: Auxiliary Fields {
      shape: sql_table
      label: "0xFE: Auxiliary (optional)"
      f0: "0xFE | opcode    | Metadata key-value"
      f1: "     | string    | e.g. redis-ver, redis-bits"
    }
    
    db_selector: DB Selector {
      shape: sql_table
      label: "0xFB: Database Selector"
      f0: "0xFB | opcode    | Select DB number"
      f1: "     | varint    | DB index (0-15)"
    }
    
    resize: Resize DB {
      shape: sql_table
      label: "0xFB: Resize Hint"
      f0: "     | varint    | Hashtable size hint"
      f1: "     | varint    | Expiry hashtable size"
    }
    
    key_value_pairs: Key-Value Pairs {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      expiry: Expiry (optional) {
        shape: sql_table
        label: "Expiry Timestamp"
        f0: "0xFC | opcode    | Expire in ms"
        f1: "     | uint64    | Unix timestamp (ms)"
        f2: "-----|-----------|------------------"
        f3: "0xFD | opcode    | Expire in seconds"
        f4: "     | uint32    | Unix timestamp (s)"
      }
      
      type: Type Tag {
        shape: sql_table
        label: "Type Opcode"
        f0: "0x00 | String    | OBJ_TYPE_STRING"
        f1: "0x01 | List      | OBJ_TYPE_LIST"
        f2: "0x02 | Set       | OBJ_TYPE_SET"
        f3: "0x03 | Hash      | OBJ_TYPE_HASH"
        f4: "0x04 | ZSet      | OBJ_TYPE_ZSET"
      }
      
      key: Key {
        shape: sql_table
        label: "Key (length-prefixed)"
        f0: "varint | length   | Key length"
        f1: "       | bytes[n] | Key data (binary-safe)"
      }
      
      value: Value (type-specific) {
        shape: sql_table
        label: "Value Encoding"
        string: "len + data | String bytes"
        list: "count + elements (each: len + data)"
        set: "count + members (each: len + data)"
        hash: "count + field-value pairs"
        zset: "count + score-member pairs"
      }
    }
  }
  
  footer: Footer {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    
    eof: EOF Marker {
      shape: sql_table
      label: "EOF Marker"
      f0: "0xFF | opcode    | End of file"
      f1: "     | 1 byte    | Always 0xFF"
    }
    
    checksum: Checksum {
      shape: sql_table
      label: "CRC64 Checksum"
      f0: "     | uint64    | CRC64 of entire file"
      f1: "     | 8 bytes   | Data integrity"
    }
  }
}

header -> database: "data section"
database -> footer: "final section"

legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  h: Header Section {
    shape: rectangle
    style.fill: "#E8D5B7"
  }
  
  d: Data Section {
    shape: rectangle
    style.fill: "#C7E8B8"
  }
  
  f: Footer Section {
    shape: rectangle
    style.fill: "#D4E8F0"
  }
}

note: |md
  **Variable-length integer encoding:**
  - `11`xxxxxx: 1 byte (0-63)
  - `10`xxxxxxxxxxxxxx: 2 bytes (0-16383)
  - `01`xxxxxxxxxxxxxx: 4 bytes
  - `00`xxxxxxxxxxxxxx: 8 bytes
| {
  shape: rectangle
  style.fill: "#FFF9E6"
  style.stroke: "#E6C200"
  style.border-radius: 5
}