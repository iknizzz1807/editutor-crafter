direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  clients: {
    shape: rectangle
    label: "Clients"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  
  event_loop: {
    shape: class
    label: "EventLoop (event.c)"
    -epoll_fd: "int"
    -server_fd: "int"
    -clients: "dict"
    -running: "bool"
    +run: "void"
    +handle_io: "void"
    +handle_time: "void"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
  
  clients -> event_loop: "commands | write"
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  save_path: {
    direction: down
    label: "SAVE Path (Blocking)"
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    
    block1: {
      label: "1. SAVE received"
      shape: step
      style.fill: "#FFCDD2"
    }
    
    block2: {
      label: "2. Iterate hash table"
      shape: step
      code: |'c
        dictIterator* di = dictGetIterator(db->dict);
        dictEntry* de;
        while ((de = dictNext(di))) {
          // serialize key-value
        }
      '|
      width: 300
      style.fill: "#FFCDD2"
    }
    
    block3: {
      label: "3. Write RDB directly"
      shape: step
      code: |'c
        FILE* fp = fopen("dump.rdb", "wb");
        // write magic, version, kvs
        fclose(fp);
      '|
      width: 300
      style.fill: "#FFCDD2"
    }
    
    block1 -> block2: "1"
    block2 -> block3: "2"
  }
  
  bgsave_path: {
    direction: down
    label: "BGSAVE Path (Non-Blocking)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    
    fork_step1: {
      label: "1. BGSAVE received"
      shape: step
      style.fill: "#BBDEFB"
    }
    
    fork_step2: {
      label: "2. fork() child process"
      shape: step
      code: |'c
        pid_t pid = fork();
        if (pid == 0) {
          // child: read memory
        }
      '|
      width: 280
      style.fill: "#BBDEFB"
    }
    
    fork_step3: {
      label: "3. Child reads via COW"
      shape: step
      code: |'c
        // Pages shared R/O from parent
        // Copy-on-write on write attempt
        dictIterator* di = dictGetIterator(db);
        // serialize each key-value
      '|
      width: 280
      style.fill: "#BBDEFB"
    }
    
    fork_step4: {
      label: "4. Write temp file"
      shape: step
      code: |'c
        FILE* tmp = fopen("dump.rdb.tmp", "wb");
        // write serialized data
        fclose(tmp);
      '|
      width: 280
      style.fill: "#BBDEFB"
    }
    
    fork_step1 -> fork_step2: "1"
    fork_step2 -> fork_step3: "2"
    fork_step3 -> fork_step4: "3"
  }
  
  save_path -> bgsave_path: "parallel"
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  atomic_rename: {
    shape: class
    label: "Atomic Rename"
    -tmp_file: "char*"
    -final_file: "char*"
    +perform: "int"
    code: |'c
      // Step 1: Write to temp.rdb.tmp
      // Step 2: rename(tmp, final)
      // POSIX: atomic or fails completely
    '|
    width: 280
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
  
  fork_step4 -> atomic_rename: "4. temp file"
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  rdb_file: {
    shape: cylinder
    label: "dump.rdb"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  
  atomic_rename -> rdb_file: "atomic rename | complete"
}

clients -> save_path: "SAVE command"
clients -> bgsave_path: "BGSAVE command"

legend: {
  near: bottom-right
  shape: rectangle
  label: "Legend"
  style.fill: "#F5F5F5"
  
  blocking: {
    shape: text
    label: "Blocking event loop"
    style.font-color: "#D32F2F"
  }
  
  non_blocking: {
    shape: text
    label: "Non-blocking (fork)"
    style.font-color: "#1976D2"
  }
  
  cow: {
    shape: text
    label: "Copy-on-write semantics"
    style.font-color: "#388E3C"
  }
}