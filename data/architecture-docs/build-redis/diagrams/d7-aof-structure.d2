direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

aof_structure: "AOF Persistence Architecture" {
  style.fill: transparent
  style.stroke: transparent
  
  direction: right
  
  write_path: "Write Path" {
    style.fill: transparent
    style.stroke: transparent
    
    command_execution: {
      shape: rectangle
      label: "Command Execution"
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      style.stroke-width: 2
      
      code: |'c
        processCommand()
        - Parse RESP
        - Validate
        - Execute
      '|
      width: 200
    }
    
    aof_append: {
      shape: rectangle
      label: "AOF Append"
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.stroke-width: 2
      
      code: |'c
        aof_append_command()
        - Build RESP string
        - fwrite() to file
        - fsync() based on policy
      '|
      width: 220
    }
    
    fsync_policy: {
      shape: diamond
      label: "fsync Policy"
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
      style.stroke-width: 2
      
      always: "always: fsync every write"
      everysec: "everysec: fsync 1x/sec"
      no: "no: OS-buffered only"
    }
  }
  
  aof_file: "AOF File on Disk" {
    style.fill: transparent
    style.stroke: transparent
    
    direction: down
    
    file_format: "RESP Format" {
      shape: rectangle
      label: "RESP Wire Format"
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      
      code: |'c
        *3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n
        
        *3 = Array of 3 elements
        $3 = Bulk string, 3 bytes
        SET = command
        $3 = key (3 bytes)
        $5 = value (5 bytes)
      '|
      width: 280
    }
    
    file_growth: {
      shape: sql_table
      label: "File Growth Over Time"
      style.fill: "#FFF8E1"
      style.stroke: "#FF8F00"
      
      header: "Timeline | Size | Commands"
      state1: "T0 (initial) | 45B | SET k1 v1"
      state2: "T0+1sec | 90B | SET k1 v1, SET k1 v2"
      state3: "T0+10sec | 225B | SET k1 v1...v5 (1 key overwritten 5x)"
      state4: "T0+60sec | 1.1KB | SET k1 v1...v20"
      problem: "PROBLEM: 20 lines for 1 key's final state!"
    }
  }
  
  rewrite_path: "Rewrite Path" {
    style.fill: transparent
    style.stroke: transparent
    
    direction: right
    
    trigger: {
      shape: diamond
      label: "Rewrite Trigger"
      style.fill: "#FFEBEE"
      style.stroke: "#D32F2F"
      style.stroke-width: 2
      
      auto_growth: "auto: size > base * 2"
      manual: "manual: BGREWRITEAOF"
    }
    
    snapshot_phase: {
      shape: rectangle
      label: "Snapshot Phase (fork)"
      style.fill: "#E1F5FE"
      style.stroke: "#0288D1"
      style.stroke-width: 2
      
      code: |'c
        fork()
        - Child reads DB state
        - Walks hash table
        - Writes: SET key value (final state)
        - Ignores: expired keys
      '|
      width: 220
    }
    
    rewrite_buffer: {
      shape: rectangle
      label: "Rewrite Buffer"
      style.fill: "#F1F8E9"
      style.stroke: "#558B2F"
      style.stroke-width: 2
      
      code: |'c
        During rewrite:
        - New commands → old AOF
        - New commands → buffer
        
        On completion:
        - Append buffer → new AOF
        - Atomic rename
      '|
      width: 200
    }
    
    result: {
      shape: sql_table
      label: "Rewrite Result"
      style.fill: "#E8EAF6"
      style.stroke: "#3F51B5"
      
      header: "Before | After"
      before: "1.1KB (20 SET lines) | 45B (1 SET)"
      reduction: "96% reduction |"
    }
  }
}

command_execution -> aof_append: "cmd" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}

aof_append -> fsync_policy: "write complete" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}

aof_append -> aof_file.file_format: "RESP string" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  style.animated: true
}

aof_file.file_growth -> rewrite_path.trigger: "size > threshold" {
  style.stroke: "#FF8F00"
  style.stroke-dash: 5
}

rewrite_path.trigger -> rewrite_path.snapshot_phase: "trigger" {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}

rewrite_path.snapshot_phase -> rewrite_path.rewrite_buffer: "intermediate cmds" {
  style.stroke: "#558B2F"
  style.stroke-width: 2
}

rewrite_path.rewrite_buffer -> aof_file: "compact AOF" {
  style.stroke: "#3F51B5"
  style.stroke-width: 3
}

legend: {
  near: bottom-center
  shape: rectangle
  style.fill: white
  style.stroke: "#CFD8DC"
  
  data_flow: "Data Flow" {
    shape: text
    style.fill: transparent
    style.stroke: transparent
  }
  control: "Control Flow" {
    shape: text
    style.fill: transparent
    style.stroke: transparent
    style.stroke-dash: 5
  }
  hot: "Hot Path" {
    shape: text
    style.fill: transparent
    style.stroke: transparent
    style.animated: true
  }
}

data_flow -> legend.data_flow
(rewrite_path.trigger -> rewrite_path.snapshot_phase)[0].style.stroke-dash: 5

*.style.font-size: 14
*.style.font: mono