direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Startup Recovery Priority" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

decision_check: "Check Persistence\nConfiguration" {
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}

aof_enabled_check: "AOF Enabled?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
}

aof_exists_check: "AOF File\nExists?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
}

rdb_exists_check: "RDB File\nExists?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
}

load_aof: {
  label: "Load AOF\n(Preferred)"
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.bold: true
}

load_rdb: {
  label: "Load RDB\n(Fallback)"
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.bold: true
}

no_persistence: "Start Fresh\n(No Persistence)" {
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
}

aof_replay: {
  label: "AOF Replay\n(Execute Commands)"
  shape: rectangle
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
}

rdb_replay: {
  label: "RDB Load\n(Restore Snapshot)"
  shape: rectangle
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
}

server_ready: "Server Ready\nAccept Clients" {
  shape: rectangle
  style.fill: "#C5E1A5"
  style.stroke: "#7CB342"
  style.bold: true
}

decision_check -> aof_enabled_check: "Config Check" {
  style.stroke-width: 2
}

aof_enabled_check -> aof_exists_check: "yes" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

aof_enabled_check -> rdb_exists_check: "no" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 4
}

aof_exists_check -> load_aof: "yes" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

aof_exists_check -> rdb_exists_check: "no" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.stroke-dash: 4
}

rdb_exists_check -> load_rdb: "yes" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

rdb_exists_check -> no_persistence: "no" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

load_aof -> aof_replay: "Parse & Execute" {
  style.stroke-width: 2
}

load_rdb -> rdb_replay: "Reconstruct State" {
  style.stroke-width: 2
}

aof_replay -> server_ready: "State Restored" {
  style.stroke-width: 2
}

rdb_replay -> server_ready: "State Restored" {
  style.stroke-width: 2
}

no_persistence -> server_ready: "Empty Database" {
  style.stroke-width: 2
}

legend: {
  near: bottom-center
  shape: rectangle
  style.fill: white
  style.stroke: "#E0E0E0"
  style.border-radius: 5
  
  preference: "AOF > RDB" {
    shape: text
    style.font-size: 14
    style.fill: "#333"
  }
  reason: "AOF has more recent data" {
    shape: text
    style.font-size: 12
    style.fill: "#666"
  }
}