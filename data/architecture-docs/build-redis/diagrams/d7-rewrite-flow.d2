direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: BGREWRITEAOF Process {
  near: top-center
  shape: text
  style.font-size: 32
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  parent: Parent Event Loop {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2

    label: "Parent Process (Event Loop)"

    client_cmds: "+ write commands"
    aof_append: "+ appends to AOF"
    continues: "continues serving clients"
  }

  parent -> child: "fork()" {
    style.stroke: "#FF6F00"
    style.stroke-width: 3
  }

  child: Child Rewrite Process {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2

    label: "Child Process"

    iterates: "iterates database"
    snapshot: "snapshot current state"
    compact: "write SET for each key"
    temp: "write to temp.aof"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  parent2: "" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 1
    style.opacity: 0.5

    new_write: "New write command arrives"
    to_old: "+ to old AOF file"
    to_buffer: "+ to rewrite buffer"
  }

  parent2 -> old_aof: "concurrent write" {
    style.stroke: "#1565C0"
    style.stroke-dash: 5
    style.stroke-width: 2
  }

  old_aof: Old AOF (Growing) {
    shape: cylinder
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2

    label: "Old AOF File\\n(keeps growing)"
    lines: "1M+ lines"
  }

  old_aof -> buffer: "captures" {
    style.stroke: "#FF6F00"
    style.stroke-dash: 5
    style.stroke-width: 2
  }

  buffer: Rewrite Buffer {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    style.stroke-width: 2

    label: "Rewrite Buffer"
    size: "stores new cmds during rewrite"
  }
}

row1 -> row2: "parallel" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  append: Append Rewrite Buffer {
    shape: step
    style.fill: "#FFF8E1"
    style.stroke: "#EF6C00"
    style.stroke-width: 2

    label: "Step 3: Append\\nRewrite Buffer"

    read: "read buffer"
    append_new: "append to new AOF"
  }

  append -> new_aof: "+ buffer" {
    style.stroke: "#EF6C00"
    style.stroke-width: 2
  }

  new_aof: New Compact AOF {
    shape: cylinder
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2

    label: "New Compact AOF\\n(only final state)"
    lines: "~1 line per key"
  }

  new_aof -> final: "atomic rename" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }

  final: "Final AOF" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#1B5E20"
    style.stroke-width: 3

    label: "Old AOF replaced\\natomically"
  }
}

legend: Legend {
  near: bottom-center

  parent_leg: Parent Process {
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }

  child_leg: Child Process {
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }

  concurrent: Concurrent Writes {
    style.stroke-dash: 5
  }

  arrow_leg: "atomic" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
}

legend.near: bottom-center