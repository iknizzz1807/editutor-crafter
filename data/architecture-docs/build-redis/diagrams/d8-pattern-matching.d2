direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Pattern Subscription Matching (Milestone 8)" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

overview: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  input: "PUBLISH channel" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  
  pattern_matcher: "Pattern Matcher" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  
  output: "Deliver to\nmatching clients" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
  
  input -> pattern_matcher: "news.sports"
  pattern_matcher -> output: "Deliver"
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  glob_syntax: "Glob Syntax Reference" {
    shape: sql_table
    label: "Glob Pattern Syntax"
    star: "*  -> matches any chars"
    qmark: "?  -> matches single char"
    brackets: "[] -> matches char class"
  }
  
  psub_storage: "PSUBSCRIBE Storage" {
    shape: sql_table
    label: "Pattern Subscription Table"
    pattern: "sds pattern"
    news_star: "news.*  -> [c1,c2,c3]"
    user_q: "user:?  -> [c4]"
    log_brackets: "log[0-9] -> [c5,c6]"
  }
  
  glob_syntax -> psub_storage: "patterns registered"
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  algorithm: "Matching Algorithm" {
    label: "pubsub_pattern_matches()"
    width: 400
    code: |'c
    int match(sds pattern, sds channel) {
      for (pi=0, ci=0; pi < len && ci < len; ) {
        if (pattern[pi] == '*') {
          // skip multiple chars
          while (ci < len && pattern[pi+1] != '.')
            ci++;
        } else if (pattern[pi] == '?') {
          ci++; // match any
        } else {
          if (pattern[pi] != channel[ci]) return 0;
          ci++;
        }
        pi++;
      }
      return pi == len && ci == len;
    }
  '|
  }
  
  wildcard_handling: "Wildcard Handling" {
    shape: sql_table
    label: "Wildcard Pattern Rules"
    star_rule: "* -> greedy, stops at '.'"
    qmark_rule: "? -> one char, no '.' constraint"
    nested_star: "news.*.* -> 2+ segments"
  }
  
  algorithm -> wildcard_handling: "match logic"
}