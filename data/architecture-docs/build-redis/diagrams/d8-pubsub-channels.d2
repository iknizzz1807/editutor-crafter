direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Pub/Sub Channel Management Architecture
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  client_state: {
    label: "Client State (client.h)"
    shape: class
    -fd: "int"
    -subscriptions: "PubSubSubscription[]"
    -subscription_count: "size_t"
    -pubsub_state: "PubSubState"
    -output_buffer: "sds"
    +subscribe(channel): "void"
    +unsubscribe(channel): "void"
  }

  arrow_sub: "SUBSCRIBE" {
    style.stroke: blue
    style.stroke-width: 2
  }

  pubsub_state: {
    label: "PubSubState (pubsub.c)"
    shape: class
    -channels: "dict"
    -channel_count: "size_t"
  }
}

row1.client_state -> row1.pubsub_state: "" {
  target-arrowhead: 1
  style: {
    stroke: blue
  }
}