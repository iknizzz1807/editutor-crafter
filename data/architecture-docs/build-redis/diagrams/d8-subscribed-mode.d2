direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: "Subscribed Client State Mode" {
  near: top-center
  style.font-size: 28
}

legend: {
  near: bottom-right
  style.fill: transparent
  style.stroke: transparent
  
  normal_label: "Normal Mode" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.font-color: "#2E7D32"
  }
  
  subscribed_label: "Subscribed Mode" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.font-color: "#E65100"
  }
  
  allowed: "Allowed Commands" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  
  restricted: "Restricted (Error)" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  normal_state: {
    label: "NORMAL MODE"
    shape: rectangle
    width: 180
    height: 80
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    style.font-color: "#2E7D32"
    style.font-size: 16
    style.bold: true
    
    desc: "Regular client state"
    desc.style.font-size: 11
    desc.style.font-color: "#666"
  }
  
  arrow_to_sub: "" {
    style.stroke: "#FF9800"
    style.stroke-width: 2
    
    label: "SUBSCRIBE\nPSUBSCRIBE"
    label.style.font-size: 11
    label.style.fill: "#FF9800"
  }
  
  subscribed_state: {
    label: "SUBSCRIBED MODE"
    shape: rectangle
    width: 200
    height: 100
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 3
    style.font-color: "#E65100"
    style.font-size: 16
    style.bold: true
    
    mode_desc: "Push-based message stream"
    mode_desc.style.font-size: 11
    mode_desc.style.font-color: "#666"
  }
  
  arrow_from_sub: "" {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    
    label: "UNSUBSCRIBE\nPUNSUBSCRIBE"
    label.style.font-size: 11
    label.style.fill: "#4CAF50"
  }
}

row1.normal_state -> row1.subscribed_state: "" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}

row1.subscribed_state -> row1.normal_state: "" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  allowed_box: {
    label: "ALLOWED COMMANDS\nIN SUBSCRIBED MODE"
    shape: rectangle
    width: 220
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    style.font-size: 14
    
    cmds: "• SUBSCRIBE\n• PSUBSCRIBE\n• UNSUBSCRIBE\n• PUNSUBSCRIBE\n• PING"
    cmds.style.font-size: 12
    cmds.style.font-color: "#1565C0"
  }
  
  vs_label: "vs"
  vs_label.style.font-size: 20
  vs_label.style.bold: true
  
  restricted_box: {
    label: "RESTRICTED COMMANDS\n(Returns Error)"
    shape: rectangle
    width: 220
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    style.font-size: 14
    
    err_cmds: "• GET\n• SET\n• DEL\n• INCR\n• LPUSH\n• Any other"
    err_cmds.style.font-size: 12
    err_cmds.style.font-color: "#C62828"
    
    error_msg: "ERR only (P)SUBSCRIBE /\n(P)UNSUBSCRIBE / PING\nallowed in this mode"
    error_msg.style.font-size: 10
    error_msg.style.font-color: "#666"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  why_needed: {
    label: "WHY THIS MATTERS"
    shape: rectangle
    width: 300
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    
    explanation: |md
      • Response stream changes fundamentally
      
      • Normal: one response per command
      
      • Subscribed: messages arrive asynchronously
      
      • Mixed responses would corrupt parsing
      
      • Enforced at protocol level
    |
    explanation.style.font-size: 11
    explanation.style.font-color: "#4A148C"
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  flow_diagram: {
    label: "Message Flow in Subscribed Mode"
    shape: rectangle
    width: 350
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    style.stroke-width: 2
    
    client: "Client"
    client.shape: person
    
    server: "Redis Server"
    server.shape: rectangle
    server.style.fill: "#FFF"
    
    channel: "Channel"
    channel.shape: rectangle
    channel.style.fill: "#E1F5FE"
    
    msg_format: |md
      Format: *3
      $7
      message
      $channel
      $message
    |
    msg_format.style.font-size: 10
    
    client -> server: "SUBSCRIBE news.sports"
    server -> client: "+subscribe (confirmation)"
    channel:news.sports: Publisher
    channel:news.sports -> server: "PUBLISH news.sports msg"
    server -> client: "+message (push)"
  }
}

note1: "When client subscribes, enters SUBSCRIBED mode" {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  style.font-size: 12
  style.font-color: "#5D4037"
}

note2: "Only subscription commands + PING allowed" {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  style.font-size: 12
  style.font-color: "#5D4037"
}

note3: "Must unsubscribe before regular commands" {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  style.font-size: 12
  style.font-color: "#5D4037"
}

note1 -> row1.normal_state: ""
note2 -> row2.allowed_box: ""
note3 -> row2.restricted_box: ""