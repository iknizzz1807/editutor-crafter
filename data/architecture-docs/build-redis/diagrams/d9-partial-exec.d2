direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "MULTI/EXEC: Partial Transaction Failure" {
  near: top-center
  shape: text
  style.font-size: 28
  style.underline: true
}

client: "Client" {
  shape: person
  style.fill: "#E8F4FD"
}

txn_container: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  state_idle: "Idle" {
    shape: circle
    style.fill: "#90EE90"
    label: "IDLE\n(no transaction)"
  }
  
  state_multi: "Multi" {
    shape: circle
    style.fill: "#87CEEB"
    label: "MULTI\n(command queuing)"
  }
  
  state_exec: "Exec" {
    shape: circle
    style.fill: "#DDA0DD"
    label: "EXEC\n(executing)"
  }
}

result_container: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  result_success: "Valid Command\nResult" {
    shape: sql_table
    style.fill: "#90EE90"
    label: "+OK | value"
  }
  
  result_error: "Error Command\nResult" {
    shape: sql_table
    style.fill: "#FF6B6B"
    label: "-ERR WRONGTYPE | key"
  }
  
  result_nil: "Nil Result" {
    shape: sql_table
    style.fill: "#D3D3D3"
    label: "(nil)"
  }
}

flow: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  
  step1: {
    label: "1. MULTI"
    width: 200
    code: |'c
      client->server: "MULTI"
      server: txn_state = MULTI
      server->client: "+OK"
    '|
  }
  
  step2: {
    label: "2. Queue Commands"
    width: 250
    code: |'c
      client->server: "SET key1 val1"
      server: queue[0] = SET
      server->client: "+QUEUED"
      
      client->server: "SET key2 val2"
      server: queue[1] = SET
      server->client: "+QUEUED"
      
      client->server: "SET key3 wrong_type"
      server: queue[2] = SET  // will fail
      server->client: "+QUEUED"
    '|
  }
  
  step3: {
    label: "3. EXEC"
    width: 300
    code: |'c
      client->server: "EXEC"
      
      // Execute queue[0]: SET key1 val1
      // Execute queue[1]: SET key2 val2  
      // Execute queue[2]: SET key3 wrong_type -> ERROR
      
      // NO ROLLBACK - all commands run
      // Partial results returned
    '|
  }
  
  step4: {
    label: "4. Response Array"
    width: 350
    code: |'c
      server->client: [
        1) "+OK",           // SET key1 succeeded
        2) "+OK",           // SET key2 succeeded
        3) "-ERR WRONGTYPE" // SET key3 FAILED
      ]
      
      // Important:
      // - Commands 1,2 already executed
      // - Command 3 returned error
      // - Commands 4+ (if any) would still run
      // - NO automatic rollback
    '|
    style.fill: "#FFFACD"
  }
}

client -> step1: "MULTI"
step1 -> step2: "queued commands"
step2 -> step3: "EXEC"
step3 -> step4: "execute all"
step4 -> result_container: "mixed results"

note_rollback: "Key Insight: No Rollback" {
  shape: callout
  style.fill: "#FFE4E1"
  near: bottom-center
  label: "NO ROLLBACK\n\nRedis does NOT undo successful commands.\nIf cmd3 fails, cmd1 & cmd2 already committed.\nResult array shows partial success/failure."
}