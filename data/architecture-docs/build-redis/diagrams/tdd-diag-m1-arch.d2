# TCP Server Architecture - Milestone 1

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

# =============================================================================
# MAIN SERVER STRUCTURES
# =============================================================================

RedisServer: {
  # Socket management
  listen_fd: "server socket fd"
  ipfd: "client socket array (10)"
  ipfd_count: "socket count"
  
  # Configuration
  config: ServerConfig: "port, backlog, max_clients"
  
  # Database (keys stored here)
  db: RedisDb: "key->value storage"
  
  # Client registry
  clients: dict: "fd -> Client mapping"
  
  # Metrics
  total_connections: "uint64"
  total_disconnections: "uint64"
  commands_processed: "uint64"
}

ServerConfig: {
  port: 6379
  backlog: 128
  max_clients: 10000
  bind_address: "NULL=all interfaces"
  
  style.fill: "#E8F4FD"
  style.border-radius: 8
}

RedisDb: {
  dict: "main keyspace"
  expires: "key->expiry mapping"
  id: 0
  
  style.fill: "#F0F0E8"
}

# =============================================================================
# CLIENT CONNECTION STRUCTURES
# =============================================================================

Client: {
  # Connection
  fd: "socket file descriptor"
  id: "unique client ID"
  state: ClientState: "CONNECTED/READING/WRITING"
  
  # I/O Buffers
  read_buffer: "input bytes"
  read_capacity: 16384
  read_offset: "parse position"
  
  write_buffer: "output bytes"
  write_capacity: 16384
  write_offset: "send position"
  
  # Parsing
  argc: "argument count"
  argv: "argument array"
  
  # Metadata
  remote_ip: "client IP"
  remote_port: "client port"
  connected_at: "timestamp"
  last_activity: "timestamp"
  
  # References
  server: RedisServer
  loop: EventLoop
  
  style.fill: "#FEF3E8"
}

ClientState: {
  shape: sql_table
  CONNECTED: initial
  READING: "waiting for data"
  PROCESSING: "executing command"
  WRITING: "sending response"
  DISCONNECTED: "cleaned up"
}

# =============================================================================
# EVENT LOOP FOUNDATION
# =============================================================================

EventLoop: {
  epoll_fd: "epoll instance"
  
  # Client management
  clients: "Client** array indexed by fd"
  client_capacity: "allocated size"
  num_clients: "connected count"
  
  # Time events
  time_events: "timer list"
  next_timer_id: "monotonic counter"
  
  # State
  state: RUNNING/STOPPING/STOPPED
  current_time_ms: "timestamp"
  
  # Metrics
  total_events_processed: "count"
  total_commands_executed: "count"
  
  style.fill: "#E8F8EF"
}

# =============================================================================
# RESPONSE BUILDER
# =============================================================================

ResponseBuilder: {
  shape: class
  
  add_reply_sds(): "(sds) -> void"
  add_reply_status(): "(char*) -> void"
  add_reply_error(): "(char*) -> void"
  add_reply_integer(): "(long long) -> void"
  add_reply_bulk_string(): "(sds) -> void"
  add_reply_array(): "(int count) -> void"
}

# =============================================================================
# RELATIONSHIPS
# =============================================================================

RedisServer -> ServerConfig: "contains"
RedisServer -> RedisDb: "contains"
RedisServer -> Client: "manages multiple"
RedisServer -> EventLoop: "uses"
Client -> RedisServer: "references"
Client -> ResponseBuilder: "produces responses"

# =============================================================================
# DATA FLOW - TCP CONNECTION LIFECYCLE
# =============================================================================

TCP_Socket: {
  label: |md
  **TCP Server Lifecycle**
  
  1. socket() - create socket
  2. bind() - attach to port 6379
  3. listen() - queue backlog
  4. accept() - get client connection
  5. read() - get client data
  6. parse() - RESP protocol
  7. execute() - run command
  8. write() - send response
  |
  shape: text
  near: top-center
  
  style.fill: white
  style.font-color: "#333"
  style.font-size: 18
}

TCP_Socket -> RedisServer: "1. bind/listen"

TCP_Socket -> Client: "2. accept()"

Client -> ResponseBuilder: "PING → PONG"

# =============================================================================
# CONFIGURATION CONSTANTS
# =============================================================================

Config: {
  shape: sql_table
  DEFAULT_PORT: int: {constraint: primary_key}
  DEFAULT_BACKLOG: int
  READ_BUFFER_SIZE: int
  WRITE_BUFFER_SIZE: int
  MAX_CLIENTS: int
  
  DEFAULT_PORT: 6379
  DEFAULT_BACKLOG: 128
  READ_BUFFER_SIZE: 16384
  WRITE_BUFFER_SIZE: 16384
  MAX_CLIENTS: 10000
  
  style.fill: "#F5F5F5"
}

# =============================================================================
# INTERFACE CONTRACTS
# =============================================================================

NetworkInterface: {
  shape: class
  
  create_server(): "(port) -> RedisServer*"
  accept_connection(): "() -> Client*"
  close_client(): "(Client*) -> void"
  run_loop(): "(EventLoop*) -> void"
  
  set_nonblocking(): "(fd) -> void"
  set_cloexec(): "(fd) -> void"
}

CommandHandler: {
  shape: class
  
  pingCommand(): "(Client*, Server*, int argc, sds* argv) -> void"
  echoCommand(): "(Client*, Server*, int argc, sds* argv) -> void"
}

NetworkInterface -> CommandHandler: "routes to"

# =============================================================================
# INITIALIZATION SEQUENCE
# =============================================================================

Init: {
  label: |md
  **Server Startup Sequence**
  
  1. ServerConfig init (port, backlog)
  2. RedisServer create
  3. EventLoop create 
  4. socket(AF_INET, SOCK_STREAM)
  5. setsockopt(SO_REUSEADDR)
  6. bind(port)
  7. listen(backlog)
  8. EventLoop run()
  |
  shape: text
  
  style.fill: "#FFF8F0"
  style.font-size: 14
}

Init -> RedisServer: "creates"
Init -> EventLoop: "creates"
RedisServer -> TCP_Socket: "binds to"