vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
  }
}

socket: Socket Layer {
  label: "OS Socket Layer"
  shape: rectangle
  style.fill: "#E8E8E8"
}

kernel: Kernel {
  label: "OS Kernel"
  shape: rectangle
  style.fill: "#D4E8D4"
}

server: RedisServer {
  label: "Redis Server\n(Milestone 1)"
  shape: rectangle
  style.fill: "#D4D4E8"
}

client: Client {
  label: "redis-cli Client"
  shape: rectangle
  style.fill: "#E8D4D4"
}

resp_parser: RESPParser {
  label: "RESP Parser"
  shape: rectangle
  style.fill: "#D4E8E8"
}

connection_flow: {
  shape: sequence_diagram
  
  "*1. Create socket" -> socket: "socket(AF_INET, SOCK_STREAM)"
  
  socket -> socket: "setsockopt()"
  socket -> kernel: "bind(port 6379)"
  
  socket -> kernel: "listen(backlog=128)"
  
  kernel: "Wait for connections (epoll_wait)"
  
  kernel -> kernel: "Client connects"
  kernel -> server: "Returns ready event"
  
  server -> server: "accept()"
  
  server -> client: "accept() returns client_fd"
  
  client -> "*2. Send RESP command\n*PING\\r\\n"
  
  client -> kernel: "write(client_fd, data)"
  kernel -> server: "Data available event"
  
  server -> resp_parser: "recv() -> buffer"
  server -> resp_parser: "Parse RESP frame"
  
  resp_parser -> server: "Complete command parsed"
  
  server -> server: "Dispatch to handler"
  server -> server: "Execute PING command"
  
  server -> resp_parser: "Encode +PONG\\r\\n"
  
  server -> kernel: "write(client_fd, response)"
  kernel -> client: "Response available"
  
  client -> "*3. Receive response\n+PONG\\r\\n"
  
  client -> "*N. More commands..."
  kernel -> kernel: "Read loop (steps 2-8)"
  
  client -> "*X. DISCONNECT"
  
  client -> kernel: "close()"
  kernel -> server: "EOF event"
  
  server -> server: "Cleanup client"
  server -> kernel: "close(client_fd)"
  kernel -> kernel: "Remove from epoll"
}

socket_annotation: |`md
  **Socket Creation**
  socket(AF_INET, SOCK_STREAM) creates TCP stream socket
`|
bind_annotation: |`md
  **bind()**
  Associates socket with port 6379
`|
listen_annotation: |`md
  **listen()**
  TCP listen backlog for incoming connections
`|
accept_annotation: |`md
  **accept()**
  Blocking call - returns when client connects
`|
resp_annotation: |`md
  **RESP Protocol**
  Parses *1\\r\\n$4\\r\\nPING\\r\\n format
`|
connection_notes: |md
  ## Key States:
  1. Listen socket created (non-blocking)
  2. Register socket + client fds in epoll
  3. Loop: epoll_wait() → handle I/O
  4. Per-client read buffer (16KB)
  5. RESP parser with state machine
  6. Cleanup: close + remove from epoll
|