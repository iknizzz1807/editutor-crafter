vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right

classes: {
  box: {
    shape: rectangle
    style.stroke-width: 2
  }
  arrow_data: {
    style.stroke: blue
    style.stroke-width: 2
  }
  arrow_control: {
    style.stroke: orange
    style.stroke-width: 1.5
    style.stroke-dash: 3
  }
  process: {
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
  }
  buffer: {
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
  socket: {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
  resp: {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
}

title: |md
  # RESP Serialization Flow
| {near: top-center}
Client_Command: Command Result {
  style.class: box
  label.near: top-center
}
resp_encoder: RESP Encoder {
  style.class: process
  
  Encoding_Format: "RESP Type → Encoded String" {
    style.font-size: 14
    style.fill: white
    style.fill-pattern: dots
  }
  
  Integer: "+123\\r\\n" {
    style: {
      font-color: "#7B1FA2"
      font: mono
    }
  }
  String: "+OK\\r\\n" {
    style: {
      font-color: "#7B1FA2"
      font: mono
    }
  }
  BulkString: "$5\\r\\nvalue\\r\\n" {
    style: {
      font-color: "#7B1FA2"
      font: mono
    }
  }
  Array: "*2\\r\\n+foo\\r\\n:42\\r\\n" {
    style: {
      font-color: "#7B1FA2"
      font: mono
    }
  }
  Error: "-ERR message\\r\\n" {
    style: {
      font-color: red
      font: mono
    }
  }
  Null: "$-1\\r\\n" {
    style: {
      font-color: "#7B1FA2"
      font: mono
    }
  }
}
write_buffer: Write Buffer (Client) {
  style.class: buffer
  
  Buffer_Struct: {
    style: {
      font: mono
      font-size: 14
    }
  }
  
  fields: "uint8_t* buffer" {
    style: {
      font: mono
      font-size: 12
    }
  }
  capacity: "size_t capacity" {
    style: {
      font: mono
      font-size: 12
    }
  }
  used: "size_t used" {
    style: {
      font: mono
      font-size: 12
    }
  }
  offset: "size_t offset" {
    style: {
      font: mono
      font-size: 12
    }
  }
  
  Growth: "capacity *= 2 (on overflow)" {
    style.font-size: 12
    style.italic: true
  }
}
socket_write: Socket Write {
  style.class: socket
  
  Steps: {
    "1: _send()_call"
    "2: _Partial_write_handling"
    "3: _EPOLLOUT_event"
  }
  
  NonBlocking: "O_NONBLOCK socket" {
    style.font-size: 12
    style.italic: true
  }
  
  EAGAIN: "Buffer full → retry later" {
    style.font-size: 12
    style.italic: true
  }
}

Client_Command -> resp_encoder: "1. Command executes" {
  style.class: arrow_data
}

resp_encoder -> write_buffer: "2. resp_serialize()" {
  style.class: arrow_data
  
  call: "addReplyString(client, resp)" {
    style.font-size: 11
    style.font-color: gray
  }
}

write_buffer -> socket_write: "3. epoll detects writable" {
  style.class: arrow_data
  
  trigger: "EPOLLOUT event" {
    style.font-size: 11
    style.font-color: gray
  }
}

socket_write -> Client: "4. Data on wire" {
  style.class: arrow_data
  
  result: "TCP packet sent" {
    style.font-size: 11
    style.font-color: gray
  }
}

write_buffer.growth_label: "send_buffer:send_offset"
write_buffer -> write_buffer.growth_label: "Buffer full?" {
  style.class: arrow_control
  style.stroke-dash: 4
}

write_buffer.growth_label -> write_buffer: "Expand & retry" {
  style.class: arrow_control
  style.stroke-dash: 4
}

legend: Legend {
  near: bottom-center
  
  Data_Flow
  Control_Flow
}

Client_Command_ref: {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}

write_buffer_ref: {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}

socket_write_ref: {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}