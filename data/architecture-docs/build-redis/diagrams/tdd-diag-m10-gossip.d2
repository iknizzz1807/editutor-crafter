vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

# Gossip Protocol State Machine

"Gossip Protocol" {
  # States
  "GOSSIP_SEND": {
    style.fill: "#E8D5F2"
    label: "GOSSIP_SEND\n(Send PING to random peers)"
    invariant: |md
      - timer triggers gossip interval
      - select 1-3 random cluster nodes
      - build ping message with slot info
      - set ping_sent timestamp
    |
  }
  
  "GOSSIP_RECEIVE": {
    style.fill: "#D5E8F2"
    label: "GOSSIP_RECEIVE\n(Process incoming pong)"
    invariant: |md
      - receive pong from target node
      - verify message format
      - update pong_received timestamp
      - calculate ping latency
    |
  }
  
  "GOSSIP_UPDATE": {
    style.fill: "#F2E8D5"
    label: "GOSSIP_UPDATE\n(Update cluster state)"
    invariant: |md
      - parse gossip entries
      - add/update nodes in registry
      - update slot ownership
      - reset fail state if recovering
    |
  }
  
  "GOSSIP_CONVERGE": {
    style.fill: "#E8F2D5"
    label: "GOSSIP_CONVERGE\n(Consistent cluster view)"
    invariant: |md
      - all nodes reachable
      - slot ownership synchronized
      - no conflicting information
      - ready for next cycle
    |
  }
  
  "GOSSIP_FAIL": {
    style.fill: "#F2D5D5"
    label: "GOSSIP_FAIL\n(Node failure detected)"
    invariant: |md
      - no pong for timeout
      - mark node as FAIL
      - broadcast fail message
      - trigger failover if master
    |
    shape: circle
  }
  
  # Transitions
  GOSSIP_SEND -> GOSSIP_RECEIVE: "pong_received\nafter ping_latency" {
    style.stroke: "#4A90D9"
    style.stroke-width: 2
    style.animated: true
  }
  
  GOSSIP_RECEIVE -> GOSSIP_UPDATE: "valid pong\nmessage received" {
    style.stroke: "#4A90D9"
    style.stroke-width: 2
  }
  
  GOSSIP_UPDATE -> GOSSIP_CONVERGE: "all gossip\nentries processed" {
    style.stroke: "#7CB342"
    style.stroke-width: 2
  }
  
  GOSSIP_CONVERGE -> GOSSIP_SEND: "next gossip\ninterval" {
    style.stroke: "#666"
    style.stroke-width: 2
    style.stroke-dash: 5
  }
  
  # Failure detection path
  GOSSIP_RECEIVE -> GOSSIP_FAIL: "no pong\n(timeout exceeded)" {
    style.stroke: "#E53935"
    style.stroke-width: 2
  }
  
  # Recovery path
  GOSSIP_FAIL -> GOSSIP_UPDATE: "recovered\nnode sends pong" {
    style.stroke: "#7CB342"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
  
  # Loop back from fail
  GOSSIP_FAIL -> GOSSIP_SEND: "continue\ngossip cycle" {
    style.stroke: "#666"
    style.stroke-dash: 3
  }
  
  # Illegal transitions
  GOSSIP_SEND -> GOSSIP_UPDATE: "skip receive" {
    style.stroke: "#E53935"
    style.stroke-dash: 2
    style.stroke-width: 3
  }
  
  GOSSIP_UPDATE -> GOSSIP_SEND: "incomplete" {
    style.stroke: "#E53935"
    style.stroke-dash: 2
    style.stroke-width: 3
  }
}

# Legend
"Legend": {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#CCC"
  style.border-radius: 8
  
  "Send": {
    style.fill: "#E8D5F2"
  }
  "Receive": {
    style.fill: "#D5E8F2"
  }
  "Update": {
    style.fill: "#F2E8D5"
  }
  "Converge": {
    style.fill: "#E8F2D5"
  }
  "Fail": {
    style.fill: "#F2D5D5"
  }
}