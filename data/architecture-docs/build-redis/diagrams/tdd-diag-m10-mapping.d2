# Key-to-Slot Algorithm - CRC16 Hash Slot Mapping
# Demonstrates: Extract hash tag if present -> CRC16 -> mod 16384

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: |md
  **Key-to-Slot Algorithm**
  Hash Tag Extraction -> CRC16 -> Slot Mapping
| {near: top-center}

# Input Key Examples
input_keys: Input Keys {
  grid-rows: 1
  grid-columns: 4
  grid-gap: 30
  
  "foo1": foo
  "user1": "{user}:1"
  "user2": "{user:id}"
  "nobre": "no{brace"
}

# Hash Tag Detection Step
hash_tag_detection: Hash Tag Detection {
  style.fill: "#E8F4FC"
  style.stroke: "#2980B9"
  style.stroke-width: 2
  
  decision_1: {
    shape: diamond
    width: 180
    label: "Has { ?"
  }
  
  yes_label: YES {style.font-color: green}
  no_label: NO {style.font-color: red}
  not_found_label: "{ not found" {style.font-color: "#7F8C8D"}
}

# Branch for keys WITH hash tag
with_hash_tag: With Hash Tag {
  label: "Has { Found"
  style.fill: "#D4EFDF"
  
  find_brace: {
    label: "Find } after {"
  }
  
  empty_check: {
    shape: diamond
    width: 150
    label: "Found } ?"
  }
  
  has_content: "tag > 0" {style.font-color: green}
  empty_tag: "tag = 0" {style.font-color: red}
  
  extract: {
    label: "Extract between { and }"
  }
}

# Branch for keys WITHOUT hash tag
without_hash_tag: Without Hash Tag {
  label: "No { Found"
  style.fill: "#FADBD8"
  
  use_full: {
    label: "Use full key"
  }
}

# CRC16 Computation
crc16_step: CRC16 Computation {
  label: CRC16 Hash Function
  style.fill: "#FCF3CF"
  style.stroke: "#D68910"
  style.stroke-width: 2
  
  lookup: {
    label: "CRC16 Lookup Table"
  }
  
  poly: {
    label: "CRC / poly"
  }
}

# Connections
input_keys."foo1" -> hash_tag_detection.decision_1
input_keys."user1" -> hash_tag_detection.decision_1
input_keys."user2" -> hash_tag_detection.decision_1
input_keys."nobre" -> hash_tag_detection.decision_1

hash_tag_detection.decision_1 -> hash_tag_detection.yes_label: YES
hash_tag_detection.decision_1 -> hash_tag_detection.no_label: NO

hash_tag_detection.yes_label -> with_hash_tag.find_brace
hash_tag_detection.no_label -> without_hash_tag.use_full

with_hash_tag.find_brace -> with_hash_tag.empty_check
with_hash_tag.empty_check -> with_hash_tag.has_content: YES
with_hash_tag.empty_check -> with_hash_tag.empty_tag: NO

with_hash_tag.has_content -> with_hash_tag.extract
with_hash_tag.empty_tag -> crc16_step
with_hash_tag.extract -> crc16_step

without_hash_tag.use_full -> crc16_step

crc16_step.lookup -> crc16_step.poly
