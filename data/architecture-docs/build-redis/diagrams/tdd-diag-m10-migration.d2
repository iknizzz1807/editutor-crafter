# Slot Migration Flow

vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

shape: sequence_diagram

client: Client
source_node: Source Node
target_node: Target Node

Start: {
  client -> source_node: "GET {slotkey}"
}

source_node -> source_node: "Check slot 5000 ownership"

source_node -> client: "Value found, return value"

Migration Initiation: {
  "# Start slot migration (CLUSTER command)"
}

source_node -> target_node: "CLUSTER SETSLOT 5000 MIGRATING" {
  style.stroke: blue
  style.animated: true
}

target_node -> target_node: "Mark slot 5000 as IMPORTING"

target_node -> source_node: "OK" {
  style.stroke: green
}

Client Retry: {
  client -> source_node: "GET {slotkey}" {
    style.stroke: blue
  }
}

source_node -> source_node: "Check key not found, slot 5000 is MIGRATING"

source_node -> client: "-ASK 5000 {target_node_ip}:7002" {
  style.stroke: red
}

client -> client: "Client stores ASKING flag"

client -> target_node: "ASKING" {
  style.stroke: blue
  style.animated: true
}

target_node -> client: "+OK" {
  style.stroke: green
}

client -> target_node: "GET {slotkey}" {
  style.stroke: blue
  style.stroke-dash: 3
}

target_node -> target_node: "Execute command in IMPORTING slot context"

target_node -> client: "Value (from migrated node)" {
  style.stroke: green
}

Migration Complete: {
  source_node -> target_node: "CLUSTER SETSLOT 5000 NODE" {
    style.stroke: blue
    style.animated: true
  }
}

target_node -> target_node: "Mark slot 5000 as fully owned"

target_node -> source_node: "OK" {
  style.stroke: green
}

source_node -> source_node: "Clear MIGRATING state"

Post Migration: {
  client -> target_node: "GET {slotkey}" {
    style.stroke: blue
  }
}

target_node -> target_node: "Slot 5000 owned by me (MOVED handled implicitly)"

target_node -> client: |md
  # Key now owned by target node
| {
  style.stroke: green
}