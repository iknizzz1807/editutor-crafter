vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
  slot: "5000"
  owner_ip: "127.0.0.2"
  owner_port: "7002"
}

shape: sequence_diagram

Client: Client
NodeA: Node A
NodeB: Node B

Client -> NodeA: "GET key1"
NodeA: "Calculate slot = CRC16(key1) % 16384"
NodeA: "Lookup slot_owner[slot] -> Node B owns slot"

NodeA -> Client: "-MOVED ${slot} ${owner_ip}:${owner_port}"

Client: "Update routing table"
Client -> NodeB: "GET key1"

NodeB -> Client: "+value1"

Client: "Client retries directly to Node B"

steps: {
  1: {
    label: "GET key1"
    "CRC16(\"key1\") = 12345"
    "12345 & 16383 = 5000"
  }
  2: {
    label: "slot_owner[5000] = Node B"
    "Node A doesn't own slot 5000"
  }
  3: {
    label: "Return: -MOVED 5000 127.0.0.2:7002"
    "Format: -MOVED <slot> <ip>:<port>"
  }
}