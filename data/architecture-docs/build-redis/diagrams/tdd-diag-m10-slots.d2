vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: "16384 Hash Slot Distribution"

# Cluster state showing slot array and node mapping
cluster_state: "ClusterState\n(sizeof≈132KB)" {
  # Slot owner array - maps each slot to a node pointer
  slot_owner_array: "slot_owner[16384]\n← 16,384 × 8B = 131,072 bytes" {
    width: 400
    height: 300
    
    slots_0_5460: "0-5460\nslots[0:5460]" {
      style.fill: "#4ECDC4"
      style.stroke: "#2A9D8F"
    }
    slots_5461_8191: "5461-8191\nslots[5461:8191]" {
      style.fill: "#4ECDC4"
      style.stroke: "#2A9D8F"
    }
    slots_8192_10921: "8192-10921\nslots[8192:10921]" {
      style.fill: "#4ECDC4"
      style.stroke: "#2A9D8F"
    }
    slots_10922_16383: "10922-16383\nslots[10922:16383]" {
      style.fill: "#4ECDC4"
      style.stroke: "#2A9D8F"
    }
    
    # Show contiguous ranges mapping to nodes
    slots_0_5460 -> node_A: "slot 0-5460 → node A"
    slots_5461_8191 -> node_B: "slot 5461-8191 → node B"
    slots_8192_10921 -> node_C: "slot 8192-10921 → node C"
    slots_10922_16383 -> node_D: "slot 10922-16383 → node D"
  }
  
  # Node pointers (orange)
  node_A: "node_A\n(127.0.0.1:7001)\nSlot range: 0-5460" {
    shape: cylinder
    style.fill: "#F4A261"
    style.stroke: "#E76F51"
    width: 120
    height: 80
  }
  
  node_B: "node_B\n(127.0.0.2:7001)\nSlot range: 5461-8191" {
    shape: cylinder
    style.fill: "#F4A261"
    style.stroke: "#E76F51"
    width: 120
    height: 80
  }
  
  node_C: "node_C\n(127.0.0.3:7001)\nSlot range: 8192-10921" {
    shape: cylinder
    style.fill: "#F4A261"
    style.stroke: "#E76F51"
    width: 120
    height: 80
  }
  
  node_D: "node_D\n(127.0.0.4:7001)\nSlot range: 10922-16383" {
    shape: cylinder
    style.fill: "#F4A261"
    style.stroke: "#E76F51"
    width: 120
    height: 80
  }
  
  # NULL slot owners (unassigned - would show as free)
  unused_slots: "Unassigned Slots\n(may be migrating or uncovered)" {
    shape: rectangle
    style.fill: "#90BE6F"
    style.stroke: "#52796B"
    style.stroke-dash: 3
    style.opacity: 0.3
  }
}

# Arrow showing the slot → node pointer flow
slot_owner_array.unused_slots: "NULL entries\n→ unassigned" {
  style.stroke-dash: 5
}

# Memory layout legend
legend: "Memory Layout Legend" {
  near: bottom-right
  
  header_slot: "slot array (blue)" {
    shape: rectangle
    style.fill: "#4ECDC4"
  }
  
  node_ptr: "node pointer (orange)" {
    shape: cylinder
    style.fill: "#F4A261"
  }
  
  free: "unassigned (green dashed)" {
    shape: rectangle
    style.fill: "#90BE6F"
    style.stroke-dash: 3
  }
}

|md **Legend:**
  - **16,384 slots** = 2^14 (power of 2 for fast modulo)
  - **slot_owner[slot]** = O(1) lookup array
  - Each entry = 8 bytes → **131,072 bytes total**
  - Slot owner = node pointer (NULL if unassigned)
  - Contiguous ranges partition the keyspace
|

style: {
  fill: "#F8F9FA"
  stroke: "#DEE1EB"
}

# Page boundary reference
cache_line_note: |md **Cache Line Boundary (64B)**: Each 64 slots = one cache line| {
  near: top-right
  shape: text
  style.opacity: 0.5
}