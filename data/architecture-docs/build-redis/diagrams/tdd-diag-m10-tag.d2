vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

# Hash Tag Extraction Algorithm

input_key: "user:123:profile"
scanner: {
  label: "SCAN FOR '{'"
  shape: diamond
  style.fill: "#E8F4FD"
  
  step1: {
    label: "Found '{' at index 5"
    shape: rectangle
    style.fill: "#E8F8E8"
  }
}

scanner -> step1: "char == '{'?"

step1 -> finder: "Found opening brace"
finder: {
  label: "FIND '}' AFTER '{'"
  shape: diamond
  style.fill: "#E8F4FD"
  
  step2: {
    label: "Found '}' at index 10"
    shape: rectangle
    style.fill: "#E8F8E8"
  }
}

finder -> step2: "char == '}'?"

step2 -> validator: "Closing brace found"
validator: {
  label: "VALIDATE TAG CONTENT\n(tag between { } )"
  shape: diamond
  style.fill: "#E8F4FD"
  
  step3: {
    label: "tag = 'user:123'\n(len > 0)"
    shape: rectangle
    style.fill: "#E8F8E8"
  }
}

validator -> step3: "end > start + 1?"

step3 -> hasher: "Valid tag extracted"
hasher: {
  label: "CRC16(tag) & 0x3FFF\nSlot Calculation"
  shape: diamond
  style.fill: "#FFF8E8"
  
  step4: {
    label: "CRC16('user:123') = 0x1234\n0x1234 & 0x3FFF = 4660"
    shape: rectangle
    style.fill: "#FFFDE8"
  }
}

hasher -> step4: "Apply hash function"

step4 -> output: "Slot: 4660"

output: {
  label: "RESULT"
  shape: rectangle
  style.fill: "#F0E8FF"
  style.bold: true
  
  result: "slot: 4660"
}

output.result.style.bold: true

# Fallback path
fallback_key: {
  label: "NO VALID { }\nUSE FULL KEY"
  shape: diamond
  style.fill: "#FFE8E8"
  
  fallback_hash: {
    label: "CRC16(full_key) & 0x3FFF"
    shape: rectangle
    style.fill: "#FFF0F0"
  }
}

validator -> fallback_key: "NOT VALID"

fallback_key -> fallback_hash: "No tag found"
fallback_hash -> output: "Same process"

# Legend
legend: {
  label: "LEGEND"
  near: top-right
  
  diamond_process: {
    label: "Decision"
    shape: diamond
    style.fill: "#E8F4FD"
  }
  
  rect_action: {
    label: "Action"
    shape: rectangle
    style.fill: "#E8F8E8"
  }
  
  rect_result: {
    label: "Result"
    shape: rectangle
    style.fill: "#FFF8E8"
    style.bold: true
  }
}

# Examples
examples: {
  label: "EXAMPLES"
  
  ex1: "key{tag}rest → hash(tag)"
  ex2: "{user}:profile → hash(user)"
  ex3: "plainkey → hash(plainkey)"
  ex4: "{}key → hash(plainkey)"
  ex5: "a{b}c{d}e → hash(b)"
}

# Connection styles
scanner -> finder: {style.stroke-dash: 3}
finder -> validator: {style.stroke-dash: 3}
validator -> hasher: {style.stroke-dash: 3}
step3 -> hasher: {style.stroke: green}
validator -> fallback_key: {style.stroke: red; style.stroke-dash: 3}
fallback_key -> fallback_hash: {style.stroke-dash: 3}
fallback_hash -> output: {style.stroke-dash: 3}