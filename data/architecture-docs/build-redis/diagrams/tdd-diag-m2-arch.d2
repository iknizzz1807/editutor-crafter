vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

direction: right

title: |md
  # Event Loop Architecture
  Milestone 2: Single-Threaded I/0 Multiplexing
|

EventLoop: {
  epoll_fd: epoll file descriptor {
    shape: cylinder
    style.fill: "#E8F4FD"
    style.stroke: "#1E3A5F"
  }
  
  ready_events: "epoll_event[1024]" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65C00"
  }
  
  num_ready: int {
    style.fill: "#E0F2F1"
    style.stroke: "#004D40"
  }
  
  clients: "Client*[fd]" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#1B5E20"
  }
  
  client_capacity: size_t {
    style.fill: "#F3E5F5"
    style.stroke: "#4A148C"
  }
  
  num_clients: size_t {
    style.fill: "#F3E5F5"
    style.stroke: "#4A148C"
  }
  
  time_events: TimeEvent {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FF6F00"
  }
  
  next_timer_id: uint64_t {
    style.fill: "#FCE4EC"
    style.stroke: "#880E4F"
  }
  
  current_time_ms: uint64_t {
    style.fill: "#E0F7FA"
    style.stroke: "#006064"
  }
  
  last_time_ms: uint64_t {
    style.fill: "#E0F7FA"
    style.stroke: "#006064"
  }
  
  state: EventLoopState {
    style.fill: "#F5F5F5"
    style.stroke: "#212121"
  }
  
  metrics: EventMetrics {
    style.fill: "#ECEFF1"
    style.stroke: "#455A64"
  }

  epoll_fd -> ready_events
  ready_events -> num_ready
  num_ready -> clients
  client_capacity -> num_clients
  last_time_ms -> current_time_ms
  current_time_ms -> time_events
}

"Time Wheel / Timer System": {
  shape: rectangle
  
  TimeEvent: {
    shape: class
    id: uint64_t
    when: uint64_t
    callback: TimeEventCallback
    user_data: void
    is_periodic: bool
    interval_ms: uint64_t
    next: TimeEvent
  }
  
  TimerWheel: {
    head: TimeEvent
  }
  
  TimeEvent.next -> TimeEvent
}

"Client Array (indexed by fd)": {
  shape: rectangle
  
  clients: {
    grid-columns: 4
    grid-gap: 10
    
    client_0: Client {
      shape: person
      style.fill: "#C8E6C9"
    }
    client_1: Client {
      shape: person
      style.fill: "#C8E6C9"
    }
    client_2: Client {
      shape: person
      style.fill: "#C8E6C9"
    }
    client_n: "..."
  }
  
  "fd -> Client* O(1)"
}

"IO Event Processing": {
  shape: rectangle
  
  EPOLLIN: {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  
  EPOLLOUT: {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  
  EPOLLERR: {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  
  EPOLLHUP: {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  
  EPOLLET: {
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
}

"Event Loop Cycle": {
  shape: sequence_diagram
  
  wait: epoll_wait
  process: process_ready_events
  timers: process_time_events
  repeat: loop continues
  
  wait -> process
  process -> timers
  timers -> repeat
  repeat -> wait
}

EventLoop.clients -> "Client Array (indexed by fd)"
EventLoop.time_events -> "Time Wheel / Timer System"
EventLoop.epoll_fd -> "IO Event Processing"
EventLoop.ready_events -> "IO Event Processing"