# Event Loop Iteration Flow
# From Milestone 2: Single-Threaded Event Loop

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

"1. Wait for Events": {
  shape: sequence_diagram
  
  EventLoop: Event Loop {
    shape: person
  }
  
  epoll: epoll_wait {
    shape: cylinder
  }
  
  Timeout: Timeout Calculator {
    shape: rectangle
  }
  
  EventLoop -> epoll: "1. Wait(timeout_ms)"
  epoll -> EventLoop: "2. Returns ready events"
  
  "Calculate Next Timeout": {
    Timeout: "Get next timer"
    EventLoop -> Timeout: "Calculate timeout"
    Timeout -> EventLoop: "timeout_ms"
  }
}

"2. Process I/O Events": {
  shape: sequence_diagram
  
  EventLoop: Event Loop
  
  Client1: Client1
  Client2: Client2
  ServerSocket: Listen Socket
  
  Accept: "accept connection" {
    ServerSocket -> EventLoop: "EPOLLIN"
    EventLoop -> Client1: "Accept"
    Client1 -> EventLoop: "Connected"
  }
  
  "Read Command": {
    Client1 -> EventLoop: "EPOLLIN"
    EventLoop -> Client1: "read from socket"
    Client1 -> EventLoop: "returns data"
  }
  
  "Handle Write": {
    EventLoop -> Client2: "EPOLLOUT"
    Client2 -> EventLoop: "write to socket"
  }
}

"3. Process Time Events": {
  shape: sequence_diagram
  
  EventLoop: Event Loop
  
  Timer: "Expired Timers" {
    shape: rectangle
  }
  
  Callback1: Timer Callback1
  Callback2: Timer Callback2
  
  "Check Expired": {
    Timer: "Time events to fire"
    EventLoop -> Timer: "process_time_events()"
  }
  
  "Execute Callbacks": {
    Timer -> Callback1: "timer1 fired"
    Callback1 -> EventLoop: "executed"
    
    Timer -> Callback2: "timer2 fired"
    Callback2 -> EventLoop: "executed"
  }
}

EventLoopIteration: "Main Loop" {
  shape: sequence_diagram
  
  Start: Begin
  
  Step1: "1. Calculate Timeout" {
    style.fill: "#E8F4EA"
  }
  
  Step2: "2. epoll_wait" {
    style.fill: "#D4E8F4"
  }
  
  Step3: "3. Process Time Events" {
    style.fill: "#D4E8F4"
  }
  
  Step4: "4. Process I/O Events" {
    style.fill: "#D4E8F4"
  }
  
  Step5: "5. Check Shutdown" {
    style.fill: "#F4E8E8"
  }
  
  Start -> Step1
  Step1 -> Step2: "next_timer - current_time"
  Step2 -> Step3: "num_ready > 0"
  Step2 -> Step4: "num_ready == 0"
  Step3 -> Step4: "after timer processing"
  Step4 -> Step5: "all events processed"
  Step5 -> Step1: "continue"
  Step5 -> End: "stop flag set"
  
  End: End
  
  # Annotations
  "timeout_ms calculation": |md
    - If no timers: timeout_ms = -1 (block forever)
    - If timers: timeout_ms = next_timer - current_time
    - Maximum: 1000ms default
  |
  
  "I/O event handling": |md
    - Read: parse command from buffer
    - Execute: run command handler  
    - Write: flush response buffer
    - Handle HUP/ERR: disconnect client
  |
  
  "time event handling": |md
    - Check each timer in list
    - If expired: invoke callback
    - For periodic: reschedule with new time
    - For one-shot: remove from list
  |
}

"Edge Cases": {
  shape: sequence_diagram
  
  Normal: "Normal Return"
  Timeout: "Timeout (no events)"
  Signal: "Signal (EINTR)"
  Error: "Error"
  
  Normal -> "Continue": "Events ready, process them"
  Timeout -> "Continue": "No events, loop back"
  Signal -> "Retry": "Interrupted, restart wait"
  Error -> "Log": "Log error, continue"
}