vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

style: {
  fill: white
  stroke: "#2D3748"
  stroke-width: 2
}

title: |md
  **Event Loop Memory Layout** — Milestone 2
  - 64B cache lines (dashed), 4096B pages (bold)
  - Pointers=Orange, Size annotations right-aligned
| {near: top-center}

event_loop: EventLoop {
  label: "struct EventLoop"
  style.fill: "#E9D8FD"
  style.stroke: "#805AD5"
  
  epoll_fd: "epoll_fd: int"
  
  ready_events: "ready_events: epoll_event[1024]"
  
  num_ready: "num_ready: int"
  
  clients: "clients: Client*[16 KB]"
  
  client_capacity: "client_capacity: size_t"
  
  num_clients: "num_clients: size_t"
  
  time_events: "time_events: TimeEvent*"
  
  next_timer_id: "next_timer_id: uint64_t"
  
  current_time_ms: "current_time_ms: uint64_t"
  
  last_time_ms: "last_time_ms: uint64_t"
  
  state: "state: enum"
  
  total_events_processed: "total_events_processed: uint64_t"
  
  total_commands_executed: "total_commands_executed: uint64_t"
  
  padding_0: {
    label: "padding: 12 bytes"
    style.fill: "#E2E8F0"
    style.stroke-dash: 2
  }
}

client_0: 0x1000
client_1: 0x2000
client_n: 0xN000

clients -> client_0: "0x1000"
clients -> client_1: "0x2000"
clients -> client_n: "0xN000"

time_event_0: 0x1080
time_event_1: 0x10F0

time_events -> time_event_0: "0x1080"
time_events -> time_event_1: "0x10F0"
time_event_0 -> time_event_1: next

client_array_detail: {
  label: "Client* Array (indexed by fd)"
  style.fill: "#FEEBC8"
  style.stroke: "#DD6B20"
  
  client_0: "index 0: 0x1000"
  client_1: "index 1: 0x2000"
  client_2: "index 2: NULL"
  client_3: "index 3: NULL"
  client_n: "index N: ..."
}

time_event_heap: {
  label: "TimeEvent Sorted List"
  style.fill: "#FED7E2"
  style.stroke: "#B83280"
  
  head: "head: 0x1080"
  node_1: "Event #1: when=1000ms"
  node_2: "Event #2: when=2500ms"
  
  node_1 -> node_2: next
}

client_structure: Client {
  label: "struct Client"
  style.fill: "#FED7D7"
  style.stroke: "#9B2C2C"
  
  fd: "fd: int"
  id: "id: uint64_t"
  state: "state: ClientState"
  
  read_buffer: "read_buffer: uint8_t*"
  read_capacity: "read_capacity: size_t"
  read_used: "read_used: size_t"
  read_offset: "read_offset: size_t"
  
  write_buffer: "write_buffer: uint8_t*"
  write_capacity: "write_capacity: size_t"
  write_used: "write_used: size_t"
  write_offset: "write_offset: size_t"
  
  argc: "argc: int"
  argv: "argv: sds*"
  
  remote_ip: "remote_ip: char[46]"
  remote_port: "remote_port: uint16_t"
  connected_at: "connected_at: time_t"
  last_activity: "last_activity: time_t"
  loop: "loop: EventLoop*"
  response_queue: "response_queue: sds"
}

event_loop -> event_loop.ready_events: "ready_events[1024]"
event_loop -> event_loop.clients: "indexed by fd"
event_loop -> event_loop.time_events: "sorted by when"

size_annotation_1: |md **Key**: 1/0.5/0.25 cache lines| {near: top-right; style.font-size: 10}
size_annotation_2: |md Total: ~176 bytes + buffers| {near: bottom-right; style.font-size: 10}

legend: Legend {
  label: Legend
  near: bottom-left
  
  header: Header {
    label: "(Purple)"
    style.fill: "#D6BCFA"
  }
  pointers: Pointers {
    label: "(Orange)"
    style.fill: "#FEEBC8"
  }
  data: Data {
    label: "(Blue)"
    style.fill: "#BEE3F8"
  }
  free: Free {
    label: "(Green)"
    style.fill: "#C6F6D5"
  }
  padding: Padding {
    label: "(Gray)"
    style.fill: "#E2E8F0"
    style.stroke-dash: 2
  }
}