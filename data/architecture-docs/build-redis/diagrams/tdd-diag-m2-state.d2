# Client State Machine (Milestone 1)

vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

title: "Client Connection State Machine"
title.style.font-size: 28
title.style.bold: true
title.style.font-color: "#3D4F7C"

style: {
  fill: "#F6F9FC"
  stroke: "#CBD6E0"
  stroke-width: 2
}

# Client States

connected: Connect {
  label: "CONNECTED\n(socket accepted)"
  shape: circle
  style.fill: "#B6DDF6"
  style.stroke: "#5A9BD4"
  style.stroke-width: 3
  width: 100
  height: 100
}

reading: Read {
  label: "READING\n(parsing RESP)"
  shape: circle
  style.fill: "#FFF9C9"
  style.stroke: "#F4B76C"
  style.stroke-width: 3
  width: 100
  height: 100
}

processing: Process {
  label: "PROCESSING\n(executing command)"
  shape: circle
  style.fill: "#E4DBFE"
  style.stroke: "#8B7FE3"
  style.stroke-width: 3
  width: 100
  height: 100
}

writing: Write {
  label: "WRITING\n(response queued)"
  shape: circle
  style.fill: "#C7F1FF"
  style.stroke: "#5ABAE3"
  style.stroke-width: 3
  width: 100
  height: 100
}

disconnected: Disconnect {
  label: "DISCONNECTED\n(cleanup complete)"
  shape: circle
  style.fill: "#FFE7CB"
  style.stroke: "#F69E03"
  style.stroke-width: 3
  width: 100
  height: 100
}

# State transitions with labels

connected -> reading: accept() returns\nsocket readable
reading -> processing: complete RESP\nframe parsed
processing -> writing: command\nexecuted
writing -> connected: buffer flushed\nsocket writable
writing -> reading: more data\narrived
disconnected: connected: socket closed\nEOF/error
disconnected: reading: TCP error or\nclient disconnect

# Legend

legend: {
  label: Legend
  shape: text
  near: bottom-center
  style.font-size: 14
  
  new_states: New Client Connection
  new_states.shape: square
  new_states.style.fill: "#B6DDF6"
  
  processing_states: Active Processing
  processing_states.shape: square
  processing_states.style.fill: "#E4DBFE"
  
  cleanup: Cleanup/Final
  cleanup.shape: square
  cleanup.style.fill: "#FFE7CB"
}

legend.new_states -> legend.processing_states: |md
  Client lifecycle: CONNECTED → READING → PROCESSING → WRITING → (loop back) → DISCONNECTED
| {
  style.stroke-dash: 5
  style.stroke: gray
}

legend.processing_states -> legend.cleanup: |md
  Events: socket readable, command ready, response buffered, full response sent
| {
  style.stroke-dash: 5
  style.stroke: gray
}