# Command Dispatch Flow - Intel Manual Quality
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}
direction: right

client_send: Client sends RESP {
  shape: circle
  style.fill: "#E8F4FD"
  style.stroke: "#1E88E5"
  style.stroke-width: 2
}

parser: RESP Parser {
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.border-radius: 8
}

parser_details: |md
  1. Read socket buffer
  2. Parse RESP frame
  3. Extract argc/argv
  4. Handle partial reads
| {
  shape: rectangle
  style.fill: "#FFF3E0"
  style.opacity: 0.8
  style.font-size: 10
  style.font-color: "#666"
}

parser_check: |md
  Check:
  - Complete frame?
  - Valid RESP syntax?
  - Bulk string length?
| {
  shape: diamond
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  width: 100
  height: 80
}

command_lookup: Command Lookup {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  style.border-radius: 8
}

cmd_lookup_details: |md
  1. argv[0] to lowercase
  2. hash table lookup
  3. O(1) with perfect hash
  4. Return cmd struct
| {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.opacity: 0.8
  style.font-size: 10
  style.font-color: "#666"
}

lookup_result: command not found {
  shape: diamond
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  width: 120
  height: 90
}

command_found: Found {
  shape: oval
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  width: 80
}

arity_ckeck: Arity Validation {
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.border-radius: 8
}

arity_details: |md
  Check: argc matches arity
  - arity > 0: exact count
  - arity < 0: at least N args
| {
  shape: rectangle
  style.fill: "#F3E5F5"
  style.opacity: 0.8
  style.font-size: 10
  style.font-color: "#666"
}

arity_invalid: Arity mismatch {
  shape: diamond
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  width: 120
  height: 90
}

arity_valid: Valid {
  shape: oval
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  width: 80
}

client_send -> parser
parser -> parser_details
parser -> parser_check
parser_check -> command_lookup
command_lookup -> cmd_lookup_details
command_lookup -> lookup_result: "not found?" {
  style.stroke-dash: 3
}
command_lookup -> command_found: "found"
command_found -> arity_ckeck
arity_ckeck -> arity_details
arity_ckeck -> arity_invalid: "mismatch?" {
  style.stroke-dash: 3
}
arity_ckeck -> arity_valid: "valid"