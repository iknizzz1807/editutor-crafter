vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

# SDS String Memory Layout
# Binary-safe string with explicit length tracking

# SDS header structure for short strings (TYPE_8)
'SDS Header (TYPE_8)': {
  len: '1 byte' {
    shape: rectangle
    style.fill: '#9B59B6'
    style.font-color: white
    tooltip: 'Current string length (bytes)'
  }
  alloc: '1 byte' {
    shape: rectangle
    style.fill: '#9B59B6'
    style.font-color: white
    tooltip: 'Allocated buffer size (excluding header + null)'
  }
  flags: '1 byte' {
    shape: rectangle
    style.fill: '#9B59B6'
    style.font-color: white
    tooltip: 'Lower 3 bits = type, upper 5 bits = length (for TYPE_5)'
  }
  
  header_total: '3 bytes' {
    shape: text
    style.font-size: 14
    style.font-color: gray
  }
}

# The buffer section - Blue
'String Data Buffer': {
  buf_start: |md
    **binary-safe data:**
    - Can contain null bytes
    - Uses len, NOT strlen()
    - Example: '\\x01\\x00\\x02\\x03' = 4 bytes
  | {
    shape: rectangle
    style.fill: '#3498DB'
    style.font-color: white
    width: 160
    height: 60
  }
  
  null_term: '1 byte' {
    shape: rectangle
    style.fill: '#BDC3C7'
    style.font-color: black
    tooltip: 'Null terminator (not counted in len)'
  }
}

# Memory layout diagram with exact offsets
'Full Memory Layout (TYPE_8, len=5)': {
  offset_0: '0x00' {
    shape: text
    style.font-size: 10
    style.font-color: gray
  }
  len_field: 'len = 5' {
    shape: rectangle
    style.fill: '#9B59B6'
    style.font-color: white
    width: 40
    height: 25
  }
  
  offset_1: '0x01' {
    shape: text
    style.font-size: 10
    style.font-color: gray
  }
  alloc_field: 'alloc = 6' {
    shape: rectangle
    style.fill: '#9B59B6'
    style.font-color: white
    width: 40
    height: 25
  }
  
  offset_2: '0x02' {
    shape: text
    style.font-size: 10
    style.font-color: gray
  }
  flags_field: 'flags = 1' {
    shape: rectangle
    style.fill: '#9B59B6'
    style.font-color: white
    width: 40
    height: 25
  }
  
  offset_3: '0x03' {
    shape: text
    style.font-size: 10
    style.font-color: gray
  }
  
  data_0: 'h' {
    shape: rectangle
    style.fill: '#3498DB'
    style.font-color: white
    width: 20
    height: 25
  }
  data_1: 'e' {
    shape: rectangle
    style.fill: '#3498DB'
    style.font-color: white
    width: 20
    height: 25
  }
  data_2: 'l' {
    shape: rectangle
    style.fill: '#3498DB'
    style.font-color: white
    width: 20
    height: 25
  }
  data_3: 'l' {
    shape: rectangle
    style.fill: '#3498DB'
    style.font-color: white
    width: 20
    height: 25
  }
  data_4: 'o' {
    shape: rectangle
    style.fill: '#3498DB'
    style.font-color: white
    width: 20
    height: 25
  }
  null_0: '\\0' {
    shape: rectangle
    style.fill: '#BDC3C7'
    style.font-color: black
    width: 20
    height: 25
  }
  
  binary_safe_example: |md
    **Binary-safe example:**
    `sds s = sdsnewlen("\\x89PNG\\r\\n\\x1a\\n", 8);`
    `sdslen(s)` returns **8** (not 1!)
  | {
    shape: rectangle
    style.fill: '#E8F6F3'
    style.stroke: '#1ABC9C'
    style.stroke-width: 2
    width: 200
    height: 70
  }
}

# SDS_TYPE comparison table
'Header Size Comparison': {
  shape: sql_table
  
  Type: string
  AllocRange: string
  HeaderSize: string
  
  TYPE_5: '5 bits (embedded)'
  '0-31': '3 bytes'
  
  TYPE_8: '8 bits'
  '32-255': '4 bytes'
  
  TYPE_16: '16 bits'
  '256-65535': '6 bytes'
  
  TYPE_32: '32 bits'
  '65536+': '10 bytes'
}