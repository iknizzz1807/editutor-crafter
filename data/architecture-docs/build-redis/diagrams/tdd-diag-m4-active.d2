vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

title: "Active Expiration State Machine" {
  near: top-center
}

direction: right

Sampling: {
  label: "1. SAMPLING"
  style.fill: "#E8F5E9"
  shape: rectangle
  width: 160
  height: 80
}

sampling_note: |md
  Sample 20 random
  keys from DB
| {
  near: bottom-center
  style.fill: "#E8F5E9"
}

DeletionCheck: {
  label: "2. DELETION\nCHECK"
  style.fill: "#FFF3E0"
  shape: rectangle
  width: 160
  height: 80
}

check_note: |md
  For each sampled key:
  • Check if expired
  • Delete if yes
| {
  near: bottom-center
  style.fill: "#FFF3E0"
}

RepeatCondition: {
  label: "3. REPEAT\nCONDITION"
  style.fill: "#E3F2FD"
  shape: diamond
  width: 160
  height: 100
}

condition_text: |md
  >25% of sample
  expired?
| {
  near: center-left
  style.fill: "#E3F2FD"
}

Sleep: {
  label: "4. SLEEP"
  style.fill: "#F3E5F5"
  shape: rectangle
  width: 140
  height: 80
}

sleep_note: |md
  Wait 100ms
  before next cycle
| {
  near: bottom-center
  style.fill: "#F3E5F5"
}

Sampling -> DeletionCheck: "After sampling" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}

DeletionCheck -> RepeatCondition: "After checking\nall sampled keys" {
  style.stroke: "#EF6C00"
  style.stroke-width: 3
}

RepeatCondition -> Sampling: "YES (>25%)" {
  style.stroke: "#1565C0"
  style.stroke-width: 3
}

RepeatCondition -> Sleep: "NO (≤25%)" {
  source-arrowhead: {
    shape: diamond
    style.fill: "#7B1FA2"
  }
  style.stroke: "#7B1FA2"
  style.stroke-width: 3
  style.stroke-dash: 5
}

Sleep -> Sampling: "Wake up" {
  style.stroke: "#6A1B9A"
  style.stroke-width: 3
  style.stroke-dash: 5
}

Legend: {
  near: bottom-left
  style.fill: white
  style.stroke: "#424242"
  style.border-radius: 5
  
  sampling_legend: "Sampling" {
    style.fill: "#E8F5E9"
  }
  check_legend: "Deletion Check" {
    style.fill: "#FFF3E0"
  }
  condition_legend: "Repeat Condition" {
    style.fill: "#E3F2FD"
  }
  sleep_legend: "Sleep" {
    style.fill: "#F3E5F5"
  }
}

Implementation: |md
  **Implementation Details:**
  • Samples 20 keys per cycle (configurable)
  • If >25% expired → immediate repeat
  • If ≤25% expired → sleep 100ms
  • Runs within event loop (non-blocking)
  • Lazy expiration + active = complete TTL system
| {
  near: bottom-right
  style.fill: "#FFFDE7"
  style.border-radius: 5
}

style: {
  fill: white
}