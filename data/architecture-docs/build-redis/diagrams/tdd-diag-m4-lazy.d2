# Lazy Expiration Flow - Data Flow Diagram

shape: sequence_diagram

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

Client -> Server: GET mykey {
  label: "Request key 'mykey'"
}

Server: {
  lookup: "1. Look up key in hash table"
  
  lookup -> lookup: dictFetch(server.db.dict, key)
}

Server -> lookup: "Key found?" {
  style.stroke-dash: 3
  style.stroke: gray
}

# Branch: No key found
Server: "2a. Key NOT found" {
  style: {
    fill: "#FFE0F5"
    stroke: "#7939A8"
  }
}

Server -> Client: '$-1\r\n' {
  label: "Return null (nil)"
  style: {
    stroke: red
  }
}

# Branch: Key found
lookup -> expiry_check: "Key found, checking expiry" {
  style.stroke: green
}

Server: "2b. Check expire_at field" {
  style: {
    fill: "#FFF9C9"
    stroke: "#9D341E"
  }
}

expiry_check -> expiry_check: expire_at != -1 ? {
  style.stroke-dash: 3
}

# Branch: No expiration
expiry_check: "No expiry (expire_at = -1)" {
  style: {
    fill: "#E6FFFA"
    stroke: "#00A055"
  }
}

expiry_check -> value_return: "Return value" {
  style.stroke: green
}

Server -> Client: '$value_length\r\nvalue' {
  label: "Return string value"
  style: {
    stroke: green
  }
}

# Branch: Has expiration - check if expired
expiry_check: "Has expiry, checking current time" {
  style: {
    fill: "#FFF9C9"
    stroke: "#9D341E"
  }
}

expiry_check -> current_time: "Current time (ms)" {
  style.stroke-dash: 3
  style.stroke: gray
}

current_time -> expired_check: expired