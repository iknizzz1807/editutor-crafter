vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

timestamp_layout: "Timestamp Storage Layout (8 bytes)" {
  style.font-size: 28
  style.bold: true

  header: "RedisObject Expiry Field" {
    style.fill: "#9B59B6"
    style.stroke: "#8E44AD"
    
    expire_at: "expire_at" {
      label: "|md\n**expire_at**\nint64_t (8 bytes)\n-1 = no expiry\n>0 = Unix ms|"
      shape: rectangle
      width: 200
      style.fill: "#3498DB"
      style.stroke: "#2980B9"
    }
  }
}

annotation_1: |md
  **Memory Layout Notes:**
  • Field offset: 0x18 (after type/encoding/lru/refcount/ptr)
  • Total RedisObject size: 24 bytes
  • Timestamp is absolute (Unix epoch ms), not relative TTL
  • -1 stored as 0xFFFFFFFFFFFFFFFF (signed int64 max)
  | {
  style.font-size: 14
  near: top-left
}

value_examples: "Expiry Value Examples" {
  style.fill: "#ECF0F1"
  
  no_expiry: "-1 (no expiry)" {
    style.fill: "#2ECC71"
    width: 120
  }
  
  valid_ts: "1704067200000" {
    style.fill: "#3498DB"
    width: 140
  }
  
  expired: "1704067200000" {
    style.fill: "#E74C3C"
    width: 140
    style.font-color: white
  }
}

structure_relationship: "Position in RedisObject" {
  style.fill: "#FEF9E7"
  
  redis_object: "RedisObject (24 bytes total)" {
    style.fill: "#ECF0F1"
    
    type_encoding: "type:4 | encoding:4 | lru:24" {
      style.fill: "#9B59B6"
      width: 200
    }
    
    refcount: "refcount (4 bytes)" {
      style.fill: "#9B59B6"
      width: 120
    }
    
    ptr: "ptr (8 bytes)" {
      style.fill: "#E67E22"
      width: 100
    }
    
    expire_at: "expire_at (8 bytes)" {
      style.fill: "#3498DB"
      width: 140
    }
  }
}

page_alignment: "Page Alignment (4096B)" {
  style.fill: white
  
  page_4kb: "4KB Page Boundary" {
    shape: rectangle
    width: 800
    height: 100
    style.fill: transparent
    style.stroke: black
    style.stroke-width: 3
  }
  
  obj_1: "Obj 1 (24B)" {
    style.fill: "#9B59B6"
    width: 60
    style.border-radius: 4
  }
  
  obj_2: "Obj 2 (24B)" {
    style.fill: "#9B59B6"
    width: 60
    style.border-radius: 4
  }
  
  obj_n: "Obj N..." {
    style.fill: "#9B59B6"
    width: 60
    style.border-radius: 4
  }
  
  padding: "Padding (to 4KB)" {
    style.fill: "#BDC3C7"
    width: 200
  }
  
  obj_1 -> obj_2 -> obj_n -> padding
}

timestamp_layout.header -> structure_relationship.redis_object.expire_at: "same field"