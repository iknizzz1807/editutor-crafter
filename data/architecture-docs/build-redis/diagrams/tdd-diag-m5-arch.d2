vars: {
  theme-id: 4
  layout-engine: elk
}

title: "Data Types Architecture" {
  near: top-center
  style.font-size: 28
}

list_architecture: "List (Doubly-Linked)" {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  
  list_struct: "list struct" {
    shape: sql_table
    head: "head: ListNode*"
    tail: "tail: ListNode*"
    len: "len: size_t"
    dup: "dup: fn* (optional)"
    free: "free: fn* (optional)"
    match: "match: fn* (optional)"
  }
  
  listnode: "listNode struct" {
    shape: sql_table
    value: "value: sds (binary-safe)"
    prev: "prev: ListNode*"
    next: "next: ListNode*"
  }
  
  list_struct.head -> listnode: "points to first"
  list_struct.tail -> listnode: "points to last"
}

set_architecture: "Set (Hash Set)" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  
  set_struct: "set struct" {
    shape: sql_table
    dict: "dict: dict* (key=member, val=NULL)"
  }
  
  dict_detail: "dict (from Milestone 3)" {
    shape: sql_table
    type: "type: setDictType"
    ht0: "ht[0]: dictht"
    ht1: "ht[1]: dictht (rehashing)"
    rehashidx: "rehashidx: int"
    iterators: "iterators: int"
  }
  
  dictht_detail: "dictht (hash table)" {
    shape: sql_table
    table: "table: dictEntry**"
    size: "size: size_t (buckets)"
    used: "used: size_t (entries)"
    mask: "mask: size_t (size-1)"
  }
  
  dict_detail.type -> set_struct.dict: "implements"
  dict_detail.ht0 -> dictht_detail: "contains"
}

hash_architecture: "Hash (Nested Dict)" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  
  hash_struct: "hash struct" {
    shape: sql_table
    dict: "dict: dict* (key=field, val=value)"
  }
  
  dict_inner: "dict (inner - field→value)" {
    shape: sql_table
    type: "type: hashDictType"
    ht0: "ht[0]: dictht"
    ht1: "ht[1]: dictht"
  }
  
  inner_dictht: "dictht (field-value entries)" {
    shape: sql_table
    table: "table: dictEntry**"
    size: "size: size_t"
    used: "used: size_t"
  }
  
  dict_inner.ht0 -> inner_dictht: "contains"
}

list_architecture.list_struct.head -> list_architecture.listnode: "head"
list_architecture.list_struct.tail -> list_architecture.listnode: "tail"
list_architecture.listnode.next -> list_architecture.listnode: "next"
list_architecture.listnode.prev -> list_architecture.listnode: "prev"

set_architecture.set_struct.dict -> set_architecture.dict_detail: "uses"
set_architecture.dict_detail.ht0 -> set_architecture.dictht_detail: "bucket array"

hash_architecture.hash_struct.dict -> hash_architecture.dict_inner: "uses"
hash_architecture.dict_inner.ht0 -> hash_architecture.inner_dictht: "entries"

list_architecture -> set_architecture: "sds for elements" {
  style.stroke: "#757575"
  style.stroke-dash: 3
}

set_architecture -> hash_architecture: "both use dict" {
  style.stroke: "#757575"
  style.stroke-dash: 3
}

complexity: "Operation Complexity" {
  near: bottom-left
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  style.stroke-width: 1
  
  list_ops: "List: O(1)" {
    shape: text
    style.font-size: 12
  }
  
  set_ops: "Set: O(1) avg" {
    shape: text
    style.font-size: 12
  }
  
  hash_ops: "Hash: O(1) avg" {
    shape: text
    style.font-size: 12
  }
}

**.style.border-radius: 4
***.style.font-size: 11
***.style.font: mono