# Hash Set Memory Layout: Collision Handling via Chaining

vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
    pad: 0
  }
}

style.fill: "#F0F0F0"
style.stroke: "#333333"
style.stroke-width: 2

title: "Hash Set Memory Layout - Dict with Chaining Collision Handling" {
  shape: text
  near: top-center
}

hash_set_layout: {

  set_header: {
    shape: sql_table
    style.fill: "#9B59B6"
    style.opacity: 0.3
    width: 180
    height: 100
    label: "set struct, sizeof=24"

    dict_ptr: {
      label: "dict* ptr, 0x00"
      style.fill: "#E67E22"
      style.opacity: 0.4
    }
  }

  set_header.dict_ptr -> dict_container: "ptr" {
    style.stroke-dash: 4
    style.stroke: "#E67E22"
  }

  dict_container: {
    shape: sql_table
    style.fill: "#9B59B6"
    style.opacity: 0.3
    width: 280
    height: 140
    label: "dict, sizeof=48"

    type: {
      label: "type* ptr, 0x00"
      style.fill: "#E67E22"
      style.opacity: 0.4
    }
    ht0: {
      label: "ht[2] array, 0x08"
      style.fill: "#E67E22"
      style.opacity: 0.4
    }
    ht1: {
      label: "ht[1], 0x28"
      style.fill: "#2C3E50"
      style.opacity: 0.2
    }
    rehashidx: {
      label: "rehashidx, 0x48"
      style.fill: "#BDC3C7"
      style.opacity: 0.4
    }
  }

  dict_container.ht0 -> bucket_array: "ht[0].table" {
    style.stroke-dash: 4
    style.stroke: "#3498DB"
  }

  bucket_array: {
    label: "bucket[4] array, sizeof=32 bytes"
    shape: sql_table
    style.fill: "#3498DB"
    style.opacity: 0.2
    width: 320
    height: 100

    bucket_0: {
      label: "dictEntry*, 0x00 -> NULL"
      style.fill: "#2ECC71"
      style.opacity: 0.4
    }
    bucket_1: {
      label: "dictEntry*, 0x08"
      style.fill: "#27AE60"
      style.opacity: 0.4
    }
    bucket_2: {
      label: "dictEntry*, 0x10 -> head"
      style.fill: "#27AE60"
      style.opacity: 0.4
      style.bold: true
    }
    bucket_3: {
      label: "dictEntry*, 0x18 -> NULL"
      style.fill: "#2ECC71"
      style.opacity: 0.4
    }
  }

  bucket_array.bucket_2 -> entry_head: " -> entry1" {
    style.stroke: "#27AE60"
    style.stroke-width: 2
  }

  entry_head: {
    label: "dictEntry, sizeof=32"
    shape: sql_table
    style.fill: "#F39C12"
    style.opacity: 0.3
    width: 280
    height: 120

    key: {
      label: "key: key1, 0x00 -> sds"
      style.fill: "#E74C3C"
      style.opacity: 0.4
    }
    value: {
      label: "val: NULL (sets store key only)"
      style.fill: "#95A5A6"
      style.opacity: 0.3
    }
    next: {
      label: "next: *entry2, 0x18 -> chain"
      style.fill: "#3498DB"
      style.opacity: 0.4
    }
  }

  entry_head.next -> entry2: " -> entry2"

  entry2: {
    label: "dictEntry, key: key2"
    shape: sql_table
    style.fill: "#F39C12"
    style.opacity: 0.3
    width: 200
    height: 80

    key2: {
      label: "key: key2"
      style.fill: "#E74C3C"
      style.opacity: 0.4
    }
    next_null: {
      label: "next: NULL (end of chain)"
      style.fill: "#BDC3C7"
      style.opacity: 0.3
    }
  }

}

legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#333333"
  style.stroke-width: 1
  label: |md
  ### Legend
  - **Purple**: Header/Structure definitions
  - **Blue**: Data structures, arrays
  - **Orange**: Pointers/references
  - **Green**: Active entries
  - **Red**: Keys
  - Gray: NULL/Empty slots
  |
}

offsets_label: {
  near: bottom-left
  label: |md
  ### Byte Offsets

  **Set (24 bytes)**
  - 0x00-0x07: dict* ptr

  **Dict (48 bytes)**
  - 0x00-0x07: type*
  - 0x08-0x27: ht[2] (32 bytes)
  - 0x28-0x2F: ht[1]
  - 0x30-0x33: rehashidx

  **Bucket Array (32 bytes)**
  - 0x00-0x07: bucket[0]*
  - 0x08-0x0F: bucket[1]*
  - 0x10-0x17: bucket[2]* (chained)
  - 0x18-0x1F: bucket[3]*

  **dictEntry (32 bytes)**
  - 0x00-0x07: key (sds)
  - 0x08-0x0F: value (NULL)
  - 0x10-0x17: next* (chain)

  **64B cache line: --- dashed**
  |
}

sds_label: {
  near: bottom-center
  label: |md
  ### SDS String Header
  - 3 bytes header (+len, +alloc, +flags)
  - Flexible array: key bytes
  - Total overhead: ~12 bytes/key
  |
}