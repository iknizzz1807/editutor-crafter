vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

"Type Checking Flow": {
  direction: right

  Input: "User Input" {
    shape: person
    style.fill: "#E6EBF1"
  }

  Parser -> TypeChecker: parse & type check
  TypeChecker -> TypeError: type error
  TypeError -> User: report error
  TypeChecker -> AST: valid AST
  AST -> CodeGen: generate code

  Input -> Parser: input
  TypeError -> Parser: retry

  Input: {
    style.fill: "#E6EBF1"
    style.stroke: "#525F7F"
  }

  Parser: {
    style.fill: "#B6DDF6"
    style.stroke: "#2E5C8A"
  }

  TypeChecker: {
    style.fill: "#DEE1EB"
    style.stroke: "#525F7F"
  }

  TypeError: {
    style.fill: "#FFE7CB"
    style.stroke: "#9E2146"
  }

  AST: {
    shape: rectangle
    style.fill: "#FFF9C9"
    style.stroke: "#9D341E"
  }

  CodeGen: {
    style.fill: "#ACE1AF"
    style.stroke: "#2E7D32"
  }
}