# Automatic Save Trigger Algorithm - Milestone 6

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

style: {
  fill: "#F8F9FA"
  stroke: "#343A40"
  font-size: 14
}

direction: right

# Title
title: |md
  # Automatic Save Trigger Algorithm
| {near: top-center}

# Event Loop tick trigger
trigger: "Event Loop Tick\n(every 100ms)" {
  shape: circle
  style.fill: "#E9ECEF"
  style.stroke: "#6C757D"
  width: 80
  height: 80
}

# Check dirty counter
check_dirty: "Check Dirty Counter" {
  shape: diamond
  style.fill: "#FFF3CD"
  style.stroke: "#FFC107"
  width: 120
  height: 100
}

# Get current time
get_time: "Get Current Time" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  width: 100
  height: 50
}

# Save point 1 (900s, >=1 change) - most lenient
save_point_900: "Save Point: 900s / 1 change" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  width: 120
  height: 50
  label: |md
    Rule: 900 seconds
    Min: 1 change
  |
}

# Save point 2 (300s, >=10 changes)
save_point_300: "Save Point: 300s / 10 changes" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  width: 120
  height: 50
  label: |md
    Rule: 300 seconds
    Min: 10 changes
  |
}

# Save point 3 (60s, >=10000 changes) - most aggressive
save_point_60: "Save Point: 60s / 10000 changes" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  width: 120
  height: 50
  label: |md
    Rule: 60 seconds
    Min: 10000 changes
  |
}

# Time condition check
time_check_900: "time >= 900s?" {
  shape: diamond
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  width: 90
  height: 70
}

time_check_300: "time >= 300s?" {
  shape: diamond
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  width: 90
  height: 70
}

time_check_60: "time >= 60s?" {
  shape: diamond
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  width: 90
  height: 70
}

# Change condition check
change_check_1: "changes >= 1?" {
  shape: diamond
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  width: 90
  height: 70
}

change_check_10: "changes >= 10?" {
  shape: diamond
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  width: 90
  height: 70
}

change_check_10000: "changes >= 10000?" {
  shape: diamond
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  width: 90
  height: 70
}

# Condition met - trigger BGSAVE
trigger_bgsave: "Trigger BGSAVE" {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.bold: true
  width: 100
  height: 50
  label: |md
    **Trigger BGSAVE**
  |
}

# Condition not met - no action
no_action: "No Action" {
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  width: 80
  height: 40
  label: "Continue"
}

# BGSAVE already running check
bgsave_running: "BGSAVE\nRunning?" {
  shape: diamond
  style.fill: "#FFF8E1"
  style.stroke: "#FF9800"
  width: 80
  height: 70
}

# Update last save time
update_last_save: "Update last_save_time" {
  shape: rectangle
  style.fill: "#E0F7FA"
  style.stroke: "#00BCD4"
  width: 120
  height: 40
}

# Algorithm complete
complete: "Complete" {
  shape: circle
  style.fill: "#CFD8DC"
  style.stroke: "#607D8B"
  width: 60
  height: 60
}

# Connections from trigger
trigger -> check_dirty: "tick"

# Check dirty -> get_time: "dirty > 0"
get_time -> save_point_900: "query time"

# Save point 900 evaluation
save_point_900 -> time_check_900: "check"
time_check_900 -> change_check_1: "YES: time >= 900s"
change_check_1 -> trigger_bgsave: "YES: changes >= 1"
change_check_1 -> save_point_300: "NO: check next rule"
time_check_900 -> no_action: "NO: time < 900s"