vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

shape: sequence_diagram

# Actors
Parent Process
Kernel
Child Process

# Main flow - Copy-on-W rite Fork Flow

# Step 1: BGSAVE command triggers fork
Parent Process -> Kernel: fork()
Kernel -> Kernel: create child process
# Step 2: Kernel creates child with shared read-only pages
Kernel -> Parent Process: return child PID
Kernel -> Child Process: create page table
Child Process