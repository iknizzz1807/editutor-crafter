opcode_table: Type Encodings {
  shape: sql_table
  style.fill: "#D5E6F3"
  style.stroke: "#2980B9"
  style.stroke-width: 2
  position: 350, 50

  type_00: 0
  type_01: 1
  type_02: 2
  type_03: 3
  type_04: 4
}

