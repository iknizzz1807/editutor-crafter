## Footer

footer: File Footer {
  shape: sql_table
  style.fill: "#D5E6F3"
  style.stroke: "#8E44AD"
  style.stroke-width: 2
  position: 0, 600

  eof_0xFF: string
  crc64: string
}

## Complete File Structure Diagram

structure_diagram: Complete File Structure {
  position: 600, 50

  section1: |md **MAGIC + VERSION (0x00-0x08)** | {
    style.fill: "#E6D5F3"
    style.stroke: "#8E44AD"
  }

  section2: |md **OPCODE (TYPE or EXPIRY) + KEY + VALUE** | {
    style.fill: "#F3E6D5"
    style.stroke: "#E67E22"
  }

  section3: |md **... more KEY-VALUE pairs ...** | {
    style.fill: "#F3E6D5"
    style.stroke: "#E67E22"
    style.stroke-dash: 3
  }

  section4: |md **EOF MARKER (0xFF)** | {
    style.fill: "#D5E6F3"
    style.stroke: "#8E44AD"
  }

  section5: |md **CRC64 CHECKSUM** | {
    style.fill: "#D5E6F3"
    style.stroke: "#8E44AD"
    style.stroke-dash: 3
  }

  section1 -> section2: "Repeat"
  section2 -> section3: "Repeat for each key-value"
  section3 -> section4: "Repeat"
  section4 -> section5: "Optional"
}

legend: Legend {
