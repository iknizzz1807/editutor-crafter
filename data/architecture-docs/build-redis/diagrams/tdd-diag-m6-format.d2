  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

direction: right

title: RDB Binary File Format {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

## File Header (Offset 0x00)

header_magic: "MAGIC STRING (9 bytes): REDIS0011" {
  shape: sql_table
  style.fill: "#E6D5F3"
  style.stroke: "#8E44AD"
  style.stroke-width: 2
  position: 0, 50

  REDIS: string
  version: string
  total: string
}

