vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

"SAVE/BGSAVE State Machine": {
  style.font-size: 24
  style.bold: true
  near: top-center
}

direction: right

idle: IDLE {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  label.near: bottom-center
  description: |md
    ## IDLE State
    - No save in progress
    - Server accepting commands normally
    - ready for SAVE or BGSAVE
  |
}

saving: SAVING {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 3
  label.near: bottom-center
  description: |md
    ## SAVING State
    - Save in progress
    - SAVE: blocks event loop
    - BGSAVE: fork() child process
    - Client commands continue (non-blocking)
  |
}

complete: COMPLETE {
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  style.stroke-width: 3
  label.near: bottom-center
  description: |md
    ## COMPLETE State
    - Save finished
    - Either success or failure
    - Updates last_save_time
    - Resets dirty counter
  |
}

error: ERROR {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 3
  label.near: bottom-center
  description: |md
    ## ERROR State
    - Save failed
    - Disk full, corruption, fork failed
    - Logs error, does not crash
  |
}

idle -> saving: "SAVE\nBGSAVE" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  style.animated: true
  label.near: top-center
}

saving -> complete: "Save\nComplete" {
  style.stroke: "#FF9800"
  style.stroke-width: 3
  style.animated: true
  label.near: top-center
}

saving -> error: "Save\nFailed" {
  style.stroke: "#F44336"
  style.stroke-width: 3
  style.stroke-dash: 5
  label.near: top-center
}

complete -> idle: "Ready\nNext" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.stroke-dash: 3
  label.near: top-center
}

error -> idle: "Reset\nState" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 3
  label.near: top-center
}

idle -> saving: "BGSAVE" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  label.near: bottom-center
}

legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#CCC"
  
  "Manual Trigger": {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  
  "Auto Trigger": {
    style.stroke: "#9C27B0"
    style.stroke-width: 2
  }
  
  "Error Path": {
    style.stroke: "#F44336"
    style.stroke-dash: 5
  }
  
  "Reset Path": {
    style.stroke: "#2196F3"
    style.stroke-dash: 3
  }
}

note1: |md
  **BGSAVE**: Uses fork() with copy-on-write
  - Child reads parent memory (read-only shared)
  - Parent continues serving clients
  - No blocking
| {
  near: bottom-center
  style.fill: "#E1BEE7"
  style.stroke: "#8E24AA"
}

note2: |md
  **Triggers**:
  - SAVE command (manual)
  - BGSAVE command (manual)
  - Auto-save (time + changes)
| {
  near: top-center
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
}