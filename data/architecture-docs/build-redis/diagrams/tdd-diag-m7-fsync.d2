vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

style.fill: "#f8f9fa"
style.stroke: "#dee2e6"

configuration: {
  label: "Configuration"
  policy: "fsync Policy"
  shape: sql_table
  
  always: "fsync always" {
    style.fill: "#e74c3c"
    style.stroke: "#c0392b"
  }
  
  everysec: "fsync everysec" {
    style.fill: "#f39c12"
    style.stroke: "#d68910"
  }
  
  no_policy: "fsync no" {
    style.fill: "#27ae60"
    style.stroke: "#1e8449"
  }
}

fsync_fsm: {
  label: "fsync Policy State Machine"
  shape: sequence_diagram
  style.font-size: 32

  IDLE_NO_WRITE: Idle (No Writes) {
    style.fill: "#ecf0f1"
  }
  
  BUFFERING: Buffering Writes {
    style.fill: "#d5f5e3"
  }
  
  ALWAYS_PENDING: fsync always Pending {
    style.fill: "#fadbd8"
  }
  
  EVERYSEC_WAITING: Everysec Timer {
    style.fill: "#fdebd0"
  }
  
  FSYNC_IN_PROGRESS: fsync In Progress {
    style.fill: "#d4e6f1"
  }
  
  DATA_SAFE: Data on Disk {
    style.fill: "#d1f2eb"
  }
}

configuration -> ALWAYS_PENDING: "CONFIG SET aof-fsync always"
configuration -> EVERYSEC_WAITING: "CONFIG SET aof-fsync everysec"
configuration -> IDLE_NO_WRITE: "CONFIG SET aof-fsync no"

IDLE_NO_WRITE -> BUFFERING: "Write Command Executes"
BUFFERING -> DATA_SAFE: "Write Command Completes"

BUFFERING -> ALWAYS_PENDING: "CONFIG: always"

ALWAYS_PENDING -> BUFFERING: "fsync() completes"

BUFFERING -> EVERYSEC_WAITING: "CONFIG: everysec"

EVERYSEC_WAITING -> DATA_SAFE: "1 second timer fires"

EVERYSEC_WAITING -> BUFFERING: "fsync() completes"

BUFFERING -> DATA_SAFE: "Config: no"

DATA_SAFE -> IDLE_NO_WRITE: "All buffers flushed"

EVERYSEC_WAITING -> FSYNC_IN_PROGRESS: "Every 1 second" {
  style.stroke-dash: 3
}

start -> IDLE_NO_WRITE: "Server Start"

transitions: |md
  **Command Completion Triggers:**
  
  1. Write command executes
  2. AOF writes to buffer (stdio + OS)
  3. Based on policy:
     - always → immediate fsync
     - everysec → queue for timer
     - no → let OS handle
  4. Timer fires → fsync
| {
  near: center-right
  shape: rectangle
}

timeout_events: |md
  **Timeout Events:**
  
  - everysec default: 1000ms timer
  - fsync() blocks ~10ms (HDD), ~0.1ms (SSD)
  - if fsync takes >2s → log warning
| {
  near: bottom-center
  shape: rectangle
}

legend_box: Legend {
  near: top-right
  shape: rectangle
  
  always_legend: "always (strongest durability)" {
    style.fill: "#e74c3c"
    style.stroke: "#c0392b"
  }
  
  everysec_legend: "everysec (recommended)" {
    style.fill: "#f39c12"
    style.stroke: "#d68910"
  }
  
  no_legend: "no (fastest, least safe)" {
    style.fill: "#27ae60"
    style.stroke: "#1e8449"
  }
}

***.style.font-size: 18
***.style.border-radius: 8
***.style.stroke-width: 2