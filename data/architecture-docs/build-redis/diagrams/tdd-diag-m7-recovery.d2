# Startup Recovery Priority Flowchart

vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

# Legend
Legend: {
  near: bottom-right
  shape: rectangle
  style.fill: white
  style.stroke: "#888888"
  
  Check: Decision {
    shape: diamond
    style.fill: "#FFE082"
    style.stroke: "#FFA000"
  }
  
  Load: Process {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  
  Exit: End {
    shape: circle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
}

# Main Flowchart
startup_recovery: "Startup Recovery Priority" {
  style.font-size: 28
  style.bold: true
  
  # Start
  Start: Server starts {
    shape: circle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
  
  # Check AOF enabled
  Check_AOF_enabled: AOF enabled in config? {
    shape: diamond
    style.fill: "#FFE082"
    style.stroke: "#FFA000"
  }
  
  # AOF enabled path
  AOF_enabled: Yes - AOF enabled {
    shape: rectangle
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
  }
  
  # Check AOF file exists
  Check_AOF_exists: AOF file exists? {
    shape: diamond
    style.fill: "#FFE082"
    style.stroke: "#FFA000"
  }
  
  # Load AOF
  Load_AOF: |md
    **Load AOF file**
    Parse RESP commands
    reconstruct database
    most recent data
  | {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.font-size: 16
  }
  
  # AOF loaded, exit
  Exit_AOF: Ready - AOF loaded {
    shape: circle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  
  # No AOF file
  No_AOF_file: No AOF file {
    shape: rectangle
    style.fill: "#FFECB3"
    style.stroke: "#FFA000"
  }
  
  # AOF not enabled path
  AOF_disabled: No - AOF disabled {
    shape: rectangle
    style.fill: "#FFECB3"
    style.stroke: "#FFA000"
  }
  
  # Check RDB exists
  Check_RDB_exists: RDB file exists? {
    shape: diamond
    style.fill: "#FFE082"
    style.stroke: "#FFA000"
  }
  
  # Load RDB
  Load_RDB: |md
    **Load RDB file**
    Parse RDB binary format
    reconstruct database
    point-in-time snapshot
  | {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.font-size: 16
  }
  
  # No RDB file
  No_RDB_file: No RDB file {
    shape: rectangle
    style.fill: "#FFECB3"
    style.stroke: "#FFA000"
  }
  
  # Start fresh
  Fresh_start: Start with empty DB {
    shape: circle
    style.fill: "#E0E0E0"
    style.stroke: "#757575"
  }
  
  # Arrows
  Start -> Check_AOF_enabled: "Begin"
  
  Check_AOF_enabled -> AOF_enabled: Yes
  Check_AOF_enabled -> AOF_disabled: No
  
  AOF_enabled -> Check_AOF_exists: "Check"
  
  Check_AOF_exists -> Load_AOF: Yes
  Check_AOF_exists -> No_AOF_file: No
  
  Load_AOF -> Exit_AOF: "Complete"
  
  No_AOF_file -> Check_RDB_exists: "Fallback to RDB"
  
  AOF_disabled -> Check_RDB_exists: "Check RDB"
  
  Check_RDB_exists -> Load_RDB: Yes
  Check_RDB_exists -> No_RDB_file: No
  
  Load_RDB -> Exit_AOF: "Use RDB data"
  
  No_RDB_file -> Fresh_start: "No persistence"
}

# Annotation explaining the priority logic
note: |md
  **Recovery Priority Rationale:**
  
  AOF (Append-Only File) records every write command since the last snapshot.
  RDB is a point-in-time snapshot that may be minutes or hours old.
  
  If both exist, loading AOF recovers MORE data - all changes since the last RDB save.
  
  Priority: **AOF > RDB > Empty**
| {
  near: top-center
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.font-size: 12
}