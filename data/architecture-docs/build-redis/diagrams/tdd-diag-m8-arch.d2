vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

direction: right

title: |md
  # Pub/Sub Architecture
| {near: top-center}

pubsub: Pub/Sub Subsystem {
  style.fill: "#E8F4F8"
  style.stroke: "#2E86AB"
  style.stroke-width: 2

  channels: "Channels (dict)" {
    shape: sql_table
    channel_name: "key" {constraint: primary_key}
    subscribers: "dict"
  }
}

publisher: Publisher {
  style.fill: "#E8F8E8"
  style.stroke: "#2EAB3A"
  style.stroke-width: 2
}

subscriber: Subscriber {
  style.fill: "#F8E8E8"
  style.stroke: "#AB2E2E"
  style.stroke-width: 2
}

message_broker: Message Broker {
  style.fill: "#F8F8E8"
  style.stroke: "#ABAB2E"
  style.stroke-width: 2
}

publisher -> message_broker: publish
message_broker -> channels: route
channels -> subscriber: deliver