vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

Legend: {
  style: {
    fill: white
  }
  
  Header: Header Fields {
    shape: rectangle
    style.fill: "#9B59B6"
  }
  Data: Data Fields {
    shape: rectangle
    style.fill: "#3498DB"
  }
  Pointer: Pointers {
    shape: rectangle
    style.fill: "#E67E22"
  }
  Padding: Padding {
    shape: rectangle
    style.fill: "#BDC3C7"
  }
}

Title: |md
# Pub/Sub Channel Subscription Structure
| {near: top-center}

Channel_Structure: {

  channel_struct: "PubSubChannel" {
    style.fill: "#9B59B6"
    style.bold: true
    
    name_offset: "0x00" {
      label: "name: sds\n8 bytes"
      style.fill: "#E67E22"
    }
    
    subs_offset: "0x08" {
      label: "subscribers: dict*\n8 bytes"
      style.fill: "#E67E22"
    }
    
    count_offset: "0x10" {
      label: "subscriber_count\n8 bytes"
      style.fill: "#3498DB"
    }
    
    padding1: "0x18" {
      label: "padding"
      style.fill: "#BDC3C7"
    }
  }
  
  gap1: " " {style.opacity: 0}
  
  subs_dict: "subscribers dict*" {
    style.fill: white
    style.stroke: "#E67E22"
    style.stroke-width: 2
    
    dict_ptr: "0x00" {
      label: "dict ptr →\n0x1000"
      style.fill: "#E67E22"
    }
  }
  
  channel_struct.subs_offset -> subs_dict: "pointer" {
    style.stroke: "#E67E22"
    style.stroke-dash: 3
  }
}

Subscribers_Dict: {
  style.fill: white
  style.stroke: "#3498DB"
  style.stroke-width: 2
  
  dict_header: "dict struct" {
    style.fill: "#9B59B6"
    
    type_ptr: "0x00" {
      label: "type: dictType*\n8 bytes"
      style.fill: "#E67E22"
    }
    priv_ptr: "0x08" {
      label: "privdata: void*\n8 bytes"
      style.fill: "#E67E22"
    }
    ht0: "0x10" {
      label: "ht[0]: dictht\n40 bytes"
      style.fill: "#3498DB"
    }
    ht1: "0x38" {
      label: "ht[1]: dictht\n40 bytes"
      style.fill: "#3498DB"
    }
    rehashidx: "0x60" {
      label: "rehashidx: int\n4 bytes"
      style.fill: "#3498DB"
    }
    iterators: "0x64" {
      label: "iterators: int\n4 bytes"
      style.fill: "#3498DB"
    }
    pad: "0x68" {
      label: "padding"
      style.fill: "#BDC3C7"
    }
  }
  
  buckets: "ht[0].table (buckets)" {
    style.fill: "#ECF0F1"
    
    bucket0: "[0x00]" {
      label: "[0]: Client*\n8 bytes"
      style.fill: "#E67E22"
    }
    bucket1: "[0x08]" {
      label: "[1]: Client*\n8 bytes"
      style.fill: "#E67E22"
    }
    bucket2: "[0x10]" {
      label: "[2]: NULL\n8 bytes"
      style.fill: "#2ECC71"
    }
    bucket3: "[0x18]" {
      label: "[3]: Client*\n8 bytes"
      style.fill: "#E67E22"
    }
    bucketN: "[...]" {
      label: "[N]: ..."
      style.fill: "#BDC3C7"
    }
  }
  
  dict_header.ht0 -> buckets: "buckets ptr" {
    style.stroke: "#E67E22"
    style.stroke-dash: 3
  }
}

Client_Pointers: {
  style.fill: white
  style.stroke: "#E67E22"
  style.stroke-width: 2
  
  title: "Client Pointers (in bucket array)" {
    style.bold: true
  }
  
  client_a: "Client A (fd=5)" {
    style.fill: "#E67E22"
    ip: "127.0.0.1:54321"
    state: "SUBSCRIBED"
  }
  
  client_b: "Client B (fd=8)" {
    style.fill: "#E67E22"
    ip: "127.0.0.1:54322"
    state: "SUBSCRIBED"
  }
  
  client_c: "Client C (fd=12)" {
    style.fill: "#E67E22"
    ip: "127.0.0.1:54323"
    state: "SUBSCRIBED"
  }
}

Channel_Structure -> Subscribers_Dict: "1 dict per channel" {
  style.stroke: "#3498DB"
  style.stroke-width: 2
}

Subscribers_Dict -> Client_Pointers: "dict→clients" {
  style.stroke: "#E67E22"
  style.stroke-width: 2
}

md_note: |md
  **Key Relationships:**
  
  1. **Channel name** (SDS string) - binary-safe channel identifier
  
  2. **Subscriber dict** - Hash table mapping client IDs to Client* pointers
     - O(1) add/remove/check membership
     - Uses client fd as key
  
  3. **Client pointers** - Direct pointers to active client structs
     - Used for message delivery
     - Enables O(1) broadcast to all subscribers
  
  **Message Flow:**
  
  PUBLISH channel msg
    → lookup channel in pubsub.channels
    → iterate subscribers dict
    → append to each client's pubsub_buffer
    → mark fd writable in epoll
| {near: bottom-center}