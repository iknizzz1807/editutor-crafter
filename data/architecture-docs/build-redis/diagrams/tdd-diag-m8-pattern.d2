# Pattern Subscription Structure - PubSubPattern and Glob Matching

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: "Pattern Subscription Structure - PubSubPattern & Glob Matching Logic"

patterns: Patterns Subscriptions {
  style.fill: white
  style.stroke: "#6B4C9A"
  style.stroke-width: 2
  
  pattern_dict: Dictionary {
    style.fill: "#E8D4F5"
    
    "news.*": {
      style.fill: "#D4B8E8"
      
      pattern_name: "Pattern: news.*" {
        shape: text
        style.fill: "#9B59B6"
        style.font-color: white
        style.bold: true
      }
      
      name_field: {
        shape: sql_table
        style.fill: "#9B59B6"
        style.font-color: white
        n: "char[40]" {constraint: "40 bytes"}
      }
      
      subscriber_count: "uint16_t | 2 bytes"
      subscriber_dict: Dictionary {
        style.fill: "#D4B8E8"
        columns: 2
        
        "client_1001": client_a | "0x10"
        "client_1002": client_b | "0x18"
        "client_1003": client_c | "0x20"
      }
      
      messages_matched: "uint64_t | 8 bytes"
      created_at: "time_t | 8 bytes"
    }
    
    "user.*": {
      style.fill: "#C9A4E0"
      style.multiple: true
      
      pattern_name: "Pattern: user.*" {
        shape: text
        style.fill: "#9B59B6"
        style.font-color: white
      }
    }
    
    "log[0-9]": {
      style.fill: "#C9A4E0"
      style.multiple: true
      
      pattern_name: "Pattern: log[0-9]" {
        shape: text
        style.fill: "#9B59B6"
        style.font-color: white
      }
    }
  }
  
  stats: "Stats: Total Patterns: 3, Total Subscribers: 5" {
    style.fill: white
    style.font-size: 16
  }
}

matching_logic: "Glob Matching Engine" {
  style.fill: "#F5E4D4"
  style.stroke: orange
  style.stroke-width: 2
  style.border-radius: 8
  
  input: "Input: news.sports" {
    shape: cylinder
    style.fill: "#FAD7A0"
  }
  
  pattern: "Pattern: news.*" {
    shape: parallelogram
    style.fill: "#EAE"
  }
  
  rules: Rules {
    shape: sql_table
    style.fill: white
    
    r1: "* -> Match any sequence"
    r2: "? -> Match single char"
    r3: "[] -> Character class"
    r4: "[^] -> Negate class"
  }
  
  result: "Result: MATCH" {
    shape: circle
    style.fill: green
    style.font-size: 24
  }
  
  no_match: "No Match:" {
    shape: circle
    style.fill: red
    style.opacity: 0.5
  }
  
  input -> rules: "Parse pattern"
  pattern -> rules: "Compile regex"
  rules -> result: "Check: MATCH"
  no_match -> result: "fallback"
}

flow: "Matching Flow" {
  channel: "news.sports"
  
  step1: "Parse: extract 'news.sports'"
  step2: "Compare with news.*"
  step3: "MATCH!"
  
  channel -> step1 -> step2 -> step3: "" {
    style.stroke: green
    style.stroke-width: 3
  }
}

memory: "Memory Layout" {
  grid-columns: 4
  grid-gap: 5
  
  fields: Field {
    shape: sql_table
    style.fill: white
    
    f1: "pattern_name"
    f2: "subscriber_dict"
    f3: "subscriber_count"
    f4: "messages_matched"
    f5: "created_at"
  }
  
  types: Type {
    shape: sql_table
    style.fill: white
    
    t1: "char[40]"
    t2: "dict*"
    t3: "uint16_t"
    t4: "uint64_t"
    t5: "time_t"
  }
  
  sizes: Size {
    shape: sql_table
    style.fill: white
    
    s1: "40"
    s2: "8"
    s3: "2"
    s4: "8"
    s5: "8"
  }
  
  offsets: Offset {
    shape: sql_table
    style.fill: white
    
    o1: "0x00"
    o2: "0x28"
    o3: "0x30"
    o4: "0x38"
    o5: "0x40"
  }
}

patterns.pattern_dict -> matching_logic.pattern: "Apply pattern matching"
matching_logic.result -> patterns.stats: "Deliver message if match"

style: {
  fill: "#FAFAFA"
  stroke: "#333"
  stroke-width: 1
}

classes: {
  header: {
    style.fill: "#9B59B6"
    style.font-color: white
    style.bold: true
  }
  data: {
    style.fill: "#3498DB"
    style.font-color: white
  }
  reference: {
    style.fill: "#27AE60"
    style.stroke: green
  }
  pointer: {
    style.fill: "#E67E22"
    style.stroke: orange
    style.stroke-dash: 5
  }
}