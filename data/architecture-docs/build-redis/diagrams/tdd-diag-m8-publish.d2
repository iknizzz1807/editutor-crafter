shape: sequence_diagram

# Participants
publisher: Publisher Client
server: Redis Server
pubsub: PubSub Subsystem
channel: Channel "news.sports"
pattern: Pattern "*"
subscriber1: Subscriber A
subscriber2: Subscriber B
subscriber3: Subscriber Pattern

# PUBLISH Flow - Main Group
"PUBLISH Flow": {

  # Step 1: Client sends PUBLISH command
  publisher -> server: "PUBLISH news.sports 'score update'"
  
  # Step 2: Server receives and parses command
  server -> pubsub: "lookup channel 'news.sports'"
  
  # Step 3: Find channel in pubsub structure
  pubsub -> pubsub: "dictFind(channels, 'news.sports')"
  
  # Channel found
  pubsub -> server: "Channel found"
  
  # Step 4: Iterate through channel subscribers
  "Iterate Channel Subscribers": {
    server -> channel: "get subscribers list"
    channel -> pubsub: "dictIterator over subscribers"
    
    # Deliver to first subscriber
    pubsub -> subscriber1: "format message"
    subscriber1: "append to buffer"
    subscriber1: "check buffer limit"
    
    # Deliver to second subscriber
    pubsub -> subscriber2: "format message"
    subscriber2: "append to buffer"
    subscriber2: "check buffer limit"
  }
  
  # Step 5: Also check pattern subscriptions
  "Check Pattern Subscriptions": {
    server -> pattern: "iterate pattern list"
    
    # Check if pattern matches channel
    pattern: "pubsubPatternMatches('*', 'news.sports')"
    pattern -> pubsub: "returns true"
    
    # If matches, iterate pattern subscribers
    "Deliver to Pattern Subscribers": {
      pubsub -> subscriber3: "format pmessage"
      subscriber3: "append to buffer"
    }
  }
  
  # Step 6: Return count to publisher
  server -> publisher: "integer: 3 (total receivers)"
}

# Annotations for key details
key_components: |md
  **Key Components:**
  - Channel subscribers stored in dict
  - Pattern matching uses glob syntax (*, ?, [])
  - Per-client buffer prevents slow subscriber blocking
  - PMESSAGE format for pattern subscribers
| {
  near: bottom-right
}

# Style
style: {
  fill: "#F6F9FC"
  stroke: "#CBD6E0"
}

# Participant styling
publisher.style.fill: "#E6EBF1"
server.style.fill: "#E6EBF1"
pubsub.style.fill: "#E1F5FE"
channel.style.fill: "#E1F5FE"
pattern.style.fill: "#E1F5FE"
subscriber1.style.fill: "#E8F5E9"
subscriber2.style.fill: "#E8F5E9"
subscriber3.style.fill: "#E8F5E9"