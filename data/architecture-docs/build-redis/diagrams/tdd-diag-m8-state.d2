# Client Pub/Sub State Machine
vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

# Use no shape declaration - let ELK handle layout

client_pubsub_state: Client Pub/Sub State Machine {
  normal: NORMAL Mode {
    shape: circle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
  }
  
  subscribed: SUBSCRIBED Mode {
    shape: circle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 3
  }
  
  error_state: Error State {
    shape: circle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 3
  }
}

# State transitions
normal -> subscribed: SUBSCRIBE

subscribed -> normal: UNSUBSCRIBE\nALL

subscribed -> subscribed: Partial\nUnsubscribe

subscribed -> error_state: Other\nCommand {
  style.stroke: red
  style.stroke-dash: 5
}

error_state -> subscribed: Error\nSent {
  style.stroke-dash: 3
}

# Notes on state transitions
style: {
  font-size: 14
}

# Legend
legend: {
  near: bottom-right
  label: LEGEND
  
  state_normal: NORMAL {
    style.fill: "#E8F5E9"
  }
  state_subscribed: SUBSCRIBED {
    style.fill: "#E3F2FD"
  }
}