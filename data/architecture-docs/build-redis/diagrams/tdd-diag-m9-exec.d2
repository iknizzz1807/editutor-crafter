vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

shape: sequence_diagram

Client
Command_Dispatch
Transaction_State
Watch_Registry
Key_Database
Command_Executor
Response_Formatter

Client.1 -> Command_Dispatch.1: EXEC {
  style.stroke: blue
  style.stroke-width: 3
}

Command_Dispatch.1 -> Transaction_State.1: Check transaction mode {
  style.stroke: purple
}

Transaction_State.1 -> Watch_Registry.1: "Any watched keys modified?" {
  style.stroke: orange
}

Watch_Registry.1 -> Watch_Registry.1: "Compare key versions" {
  style.stroke-dash: 3
}

alt-watch-failed {
  Watch_Registry.2 -> Transaction_State.2: "YES - key modified" {
    style.stroke: red
    style.stroke-width: 3
  }

  Transaction_State.2 -> Command_Dispatch.2: "txn_aborted=1" {
    style.stroke: red
  }

  Command_Dispatch.2 -> Client.2: "$-1 (nil)" {
    style.stroke: red
    style.fill: "#FFE7CB"
  }
}

Watch_Registry.3 -> Transaction_State.3: "NO - all versions match" {
  style.stroke: green
}

Transaction_State.3 -> Transaction_State.3: "Get first queued command" {
  style.stroke-dash: 3
}

loop-execute {
  Transaction_State.4 -> Command_Executor.1: "Execute queued cmd #1" {
    style.stroke: blue
  }

  Command_Executor.1 -> Key_Database.1: "Read/Write operation" {
    style.stroke: green
  }

  Key_Database.1 -> Command_Executor.1: Result {
    style.stroke: green
  }

  Command_Executor.1 -> Response_Formatter.1: "Append to array" {
    style.stroke: purple
  }

  Transaction_State.4 -> Transaction_State.4: "Next command (loop)" {
    style.stroke-dash: 3
  }
}

Transaction_State.5 -> Response_Formatter.1: "All commands executed" {
  style.stroke: blue
  style.stroke-width: 3
}

Response_Formatter.1 -> Client.1: "*3 $3 :1 +value" {
  style.stroke: blue
  style.fill: "#C7F1FF"
  style.bold: true
}

legend_box: |md
  ## EXEC Flow Legend

  **Watch Check**: Before execution, verify no watched keys were modified by other clients

  **Watch Failure**: If any watched key changed, return nil (no results)

  **Queued Execution**: Each queued command executes in order; errors don't abort

  **Array Response**: Results returned as RESP array - one element per command
| {
  near: bottom-center
  shape: rectangle
  style.fill: white
  style.border-radius: 5
  style.stroke: gray
  style.stroke-width: 1
  style.font-size: 14
}

loop-execute.style.fill: "#E4DBFE"
loop-execute.style.stroke: "#B5AFF6"
alt-watch-failed.style.fill: "#FFE7CB"
alt-watch-failed.style.stroke: red

step1: |md **1. EXEC received** | {
  shape: text
  near: Client.1
  style.font-size: 11
  style.fill: white
}

step2: |md **2. Check transaction** | {
  shape: text
  near: Transaction_State.1
  style.font-size: 11
  style.fill: white
}

step3: |md **3. Verify WATCH** | {
  shape: text
  near: Watch_Registry.1
  style.font-size: 11
  style.fill: white
}

step4: |md **4. Execute all queued** | {
  shape: text
  near: loop-execute
  style.font-size: 11
  style.fill: white
}

step5: |md **5. Return results** | {
  shape: text
  near: Response_Formatter.1
  style.font-size: 11
  style.fill: white
}