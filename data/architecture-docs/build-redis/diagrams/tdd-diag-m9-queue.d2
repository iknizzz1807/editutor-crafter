vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
  }
}

"Command Queuing Flow": {
  shape: sequence_diagram
  
  Client: {
    label: Client
    style.fill: "#E8F4FD"
  }
  
  Dispatcher: {
    label: Command\nDispatcher
    style.fill: "#F0E6FF"
  }
  
  Transaction: {
    label: Transaction\nState
    style.fill: "#FFE6E6"
  }
  
  Queue: {
    label: Command\nQueue
    style.fill: "#E6FFE6"
  }
  
  Database: {
    label: Database
    style.fill: "#FFF4E6"
  }
  
  Client -> Dispatcher: "MULTI"
  
  Dispatcher -> Transaction: "check txn_state"
  Transaction -> Dispatcher: "NONE → MULTI"
  
  Dispatcher -> Transaction: "set state=MULTI"
  Transaction -> Dispatcher: "OK"
  
  Dispatcher -> Client: "+OK"
  
  Client -> Dispatcher: "SET key value"
  
  Dispatcher -> Transaction: "check state"
  Transaction -> Dispatcher: "state=MULTI"
  
  Dispatcher -> Queue: "queueCommand(SET key value)"
  Queue -> Dispatcher: "queued"
  
  Dispatcher -> Client: "+QUEUED"
  
  Client -> Dispatcher: "INCR counter"
  
  Dispatcher -> Transaction: "check state"
  Transaction -> Dispatcher: "state=MULTI"
  
  Dispatcher -> Queue: "queueCommand(INCR counter)"
  Queue -> Dispatcher: "queued"
  
  Dispatcher -> Client: "+QUEUED"
  
  Client -> Dispatcher: "GET key"
  
  Dispatcher -> Transaction: "check state"
  Transaction -> Dispatcher: "state=MULTI"
  
  Dispatcher -> Queue: "queueCommand(GET key)"
  Queue -> Dispatcher: "queued"
  
  Dispatcher -> Client: "+QUEUED"
  
  Client -> Dispatcher: "EXEC"
  
  Dispatcher -> Queue: "execute all"
  
  Queue -> Database: "SET key value"
  Database -> Queue: "OK"
  
  Queue -> Database: "INCR counter"
  Database -> Queue: "1"
  
  Queue -> Database: "GET key"
  Database -> Queue: "value"
  
  Queue -> Dispatcher: "[OK, 1, value]"
  
  Dispatcher -> Client: '*3\r\n+OK\r\n:1\r\n$5\r\nvalue\r\n'
  
  Dispatcher -> Transaction: "clear state"
  Transaction -> Dispatcher: "cleared"
}

note1: |md
  **Flow Summary:**
  1. MULTI sets txn_state=MULTI
  2. Commands queue instead of execute
  3. Each returns +QUEUED
  4. EXEC runs all queued commands
  5. Returns array of results
| {
  near: "Command Queuing Flow"
  style.font-size: 14
}

style: {
  fill: "#FAFAFA"
  stroke: "#333"
  stroke-width: 2
}