direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Complete Shell Data Flow: Input → Kernel
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  raw_input: {
    label: "Raw Input"
    width: 280
    code: |'bash
      ls -la | grep foo > out.txt &
    '|
    style.fill: "#E8F4E8"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lexer: {
    label: "Lexer (lexer.c)"
    width: 320
    state_machine: {
      label: "State Machine"
      shape: diamond
      style.fill: "#FFF3CD"
    }
    states: {
      label: "States"
      shape: sql_table
      f0: "LEX_DEFAULT"
      f1: "LEX_IN_SINGLE_QUOTE"
      f2: "LEX_IN_DOUBLE_QUOTE"
      f3: "LEX_IN_ESCAPE"
    }
    code: |"c
      while (pos < len) {
        int c = input[pos++];
        if (state == LEX_DEFAULT) {
          if (c == '\"') state = LEX_IN_DOUBLE_QUOTE;
          else if (c == '\'') state = LEX_IN_SINGLE_QUOTE;
          else if (is_meta(c)) emit_token(c);
        }
      }
    "|
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  token_stream: {
    label: "Token Array (lexer.h)"
    width: 380
    shape: sql_table
    t0: "0x00 | TOK_WORD | 'ls'"
    t1: "0x10 | TOK_WORD | '-la'"
    t2: "0x20 | TOK_PIPE | NULL"
    t3: "0x30 | TOK_WORD | 'grep'"
    t4: "0x40 | TOK_WORD | 'foo'"
    t5: "0x50 | TOK_REDIR_OUT | NULL"
    t6: "0x60 | TOK_WORD | 'out.txt'"
    t7: "0x70 | TOK_AMPERSAND | NULL"
    t8: "0x80 | TOK_EOF | NULL"
    style.fill: "#E3F2FD"
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parser: {
    label: "Parser (parser.c)"
    width: 340
    desc: |'md
      **Recursive Descent**
      Precedence (low to high):
      1. `;` (list)
      2. `&` (background)
      3. `&&` `||` (logical)
      4. `|` (pipeline)
    '|
    code: |"c
      ASTNode* parse_pipeline(Parser *p) {
        ASTNode* node = parse_simple_cmd(p);
        while (match(p, TOK_PIPE)) {
          ASTNode* right = parse_simple_cmd(p);
          node = new_pipe_node(node, right);
        }
        return node;
      }
    "|
    style.fill: "#F3E5F5"
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ast: {
    label: "Abstract Syntax Tree"
    direction: down
    style.fill: "#FFF8E1"
    bg_node: {
      label: "NODE_BACKGROUND"
      shape: diamond
      style.fill: "#FFCCBC"
    }
    pipe_node: {
      label: "NODE_PIPELINE"
      shape: hexagon
      style.fill: "#FFCCBC"
    }
    cmd1: {
      label: "SIMPLE_CMD (ls)"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    cmd2: {
      label: "SIMPLE_CMD (grep)"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    bg_node -> pipe_node: "command"
    pipe_node -> cmd1: "left"
    pipe_node -> cmd2: "right"
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  expander: {
    label: "Expander (expand.c)"
    width: 380
    phases: {
      label: "Expansion Pipeline"
      shape: sql_table
      p1: '1. Tilde | ~ to $HOME'
      p2: '2. Param | $VAR to value'
      p3: '3. Command | $(cmd) to out'
      p4: '4. Split | Field separation'
      p5: '5. Glob | *.txt to files'
      p6: '6. Quotes | Strip wrappers'
    }
    style.fill: "#E0F7FA"
  }
}

row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  transformed_ast: {
    label: "Transformed AST (Final)"
    direction: down
    style.fill: "#F1F8E9"
    bg2: {
      label: "NODE_BACKGROUND"
      shape: diamond
      style.fill: "#FFCCBC"
    }
    pipe2: {
      label: "NODE_PIPELINE"
      shape: hexagon
      style.fill: "#FFCCBC"
    }
    cmd1x: {
      label: "CMD: [/bin/ls, -la]"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    cmd2x: {
      label: "CMD: [/bin/grep, foo]"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    bg2 -> pipe2: "target"
    pipe2 -> cmd1x: "in"
    pipe2 -> cmd2x: "out"
  }
}

row8: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  executor: {
    label: "Executor (execute.c)"
    width: 400
    code: |"c
      void run_pipe(Node* n, int in_fd, int out_fd) {
        int p[2]; pipe(p);
        if (fork() == 0) {
          dup2(in_fd, 0); 
          dup2(p[1], 1);
          execvp(n->left->argv[0], n->left->argv);
        }
        run_cmd(n->right, p[0], out_fd);
      }
    "|
    style.fill: "#FCE4EC"
  }
}

row9: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  syscalls: {
    label: "System Calls"
    direction: right
    style.fill: transparent
    fork_box: {
      label: "fork()"
      code: |"c
        pid_t fork(void);
        // Creates child proc
      "|
      style.fill: "#BBDEFB"
    }
    pipe_box: {
      label: "pipe()"
      code: |"c
        int pipe(int fds[2]);
        // Unidirectional link
      "|
      style.fill: "#BBDEFB"
    }
    dup2_box: {
      label: "dup2()"
      code: |"c
        int dup2(int old, int new);
        // Clone file desc
      "|
      style.fill: "#BBDEFB"
    }
  }
}

row10: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel: {
    label: "Kernel Space"
    direction: right
    style.fill: "#ECEFF1"
    process_table: {
      label: "Process Table"
      shape: sql_table
      p0: "PID 1234 | shell | PGID 1234"
      p1: "PID 1235 | ls | PGID 1235"
      p2: "PID 1236 | grep | PGID 1235"
    }
    fd_table: {
      label: "FD Table Map"
      shape: sql_table
      ls_fd: "ls: 1 to pipe_write"
      grep_fd: "grep: 0 to pipe_read"
      file_fd: "grep: 1 to out.txt"
    }
  }
}

row1.raw_input -> row2.lexer: "char* | scan"
row2.lexer -> row3.token_stream: "Token[] | emit"
row3.token_stream -> row4.parser: "Token | next"
row4.parser -> row5.ast: "Node* | build"
row5.ast -> row6.expander: "Node* | visit"
row6.expander -> row7.transformed_ast: "Node* | mutate"
row7.transformed_ast -> row8.executor: "Node* | walk"
row8.executor -> row9.syscalls: "trap | invoke"
row9.syscalls -> row10.kernel: "context | switch"

legend: {
  near: bottom-right
  shape: sql_table
  label: "Legend: Data Types"
  l1: "char* | Raw C-string"
  l2: "Token | Lexeme structure"
  l3: "ASTNode* | Recursive tree"
  l4: "int fd | File descriptor"
}
legend.l1.style.fill: "#E8F4E8"
legend.l2.style.fill: "#E3F2FD"
legend.l3.style.fill: "#FFF8E1"
legend.l4.style.fill: "#BBDEFB"