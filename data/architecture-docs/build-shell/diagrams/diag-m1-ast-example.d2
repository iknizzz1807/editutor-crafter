direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  container_node: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 8
    }
  }
  leaf_node: {
    style: {
      fill: "#F0FDF4"
      stroke: "#16A34A"
      stroke-width: 2
      border-radius: 6
    }
  }
  flag_node: {
    shape: diamond
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
    }
  }
}

title: {
  label: "AST for Command: ls -la | grep foo > out.txt &"
  near: top-center
}

ast_section: {
  style.stroke: transparent
  style.fill: transparent
  
  tree: {
    direction: down

    node_bg: {
      label: "NODE_BACKGROUND (&)"
      class: container_node
    }

    node_pipe: {
      label: "NODE_PIPELINE (|)"
      class: container_node
    }

    node_bg -> node_pipe: "child"

    cmd1: {
      label: "NODE_SIMPLE_CMD (ls -la)"
      class: leaf_node
      argv: {
        shape: sql_table
        label: "argv (0x10040)"
        a0: "0x00 | char* | \"ls\""
        a1: "0x08 | char* | \"-la\""
        a2: "0x10 | char* | NULL"
        sz: "argc: 2 | Total: 24 bytes"
      }
    }

    cmd2: {
      label: "NODE_SIMPLE_CMD (grep foo)"
      class: leaf_node
      argv: {
        shape: sql_table
        label: "argv (0x10080)"
        b0: "0x00 | char* | \"grep\""
        b1: "0x08 | char* | \"foo\""
        b2: "0x10 | char* | NULL"
        sz: "argc: 2 | Total: 24 bytes"
      }
      
      redir: {
        label: "REDIR_OUT (> out.txt)"
        class: flag_node
        data: {
          shape: sql_table
          label: "struct Redirect (shell.h)"
          f0: "0x00 | int   | type (STDOUT)"
          f1: "0x04 | int   | target_fd (1)"
          f2: "0x08 | char* | path (\"out.txt\")"
          f3: "0x10 | void* | next (NULL)"
          sz: "Total: 24 bytes"
        }
      }
    }

    node_pipe -> cmd1: "cmds[0]"
    node_pipe -> cmd2: "cmds[1]"
    cmd2 -> cmd2.redir: "redirects"
  }
}

footer_section: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  execution_logic: {
    label: "Execution Steps (shell.c:exec_ast)"
    style.fill: "#FFFBEB"
    style.stroke: "#F59E0B"
    step1: "1. Parent fork()s background child"
    step2: "2. Child pipe()s for CMD1 to CMD2"
    step3: "3. fork() both command processes"
    step4: "4. CMD2 child dup2()s out.txt to FD 1"
    step5: "5. execvp() replaces process images"
    step1 -> step2 -> step3 -> step4 -> step5
  }

  legend: {
    label: "Component Legend"
    style.fill: "#F9FAFB"
    l1: "Control Structures" { class: container_node }
    l2: "Command Execution" { class: leaf_node }
    l3: "I/O Redirection" { class: flag_node }
  }
}

ast_section -> footer_section: {
  style.stroke: transparent
}

legend.near: bottom-right
execution_logic.near: bottom-left