direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # AST Node Hierarchy
  Abstract Syntax Tree for Shell Command Parsing
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ast_node: {
    shape: class
    label: "ASTNode (ast.h)"
    +type: "NodeType"
    +line: "int"
    +column: "int"
    +accept(v): "void"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  command_node: {
    shape: class
    label: "CommandNode (ast.h)"
    -argv: "char**"
    -argc: "int"
    -redirects: "Redirect*"
    +get_arg(i): "char*"
    +expand(): "int"
  }
  pipeline_node: {
    shape: class
    label: "PipelineNode (ast.h)"
    -commands: "ASTNode**"
    -num_commands: "int"
    +add_command(c): "void"
    +first(): "ASTNode*"
    +last(): "ASTNode*"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  list_node: {
    shape: class
    label: "ListNode (ast.h)"
    -left: "ASTNode*"
    -right: "ASTNode*"
    -separator: "SeparatorType"
    +is_background(): "bool"
  }
  if_node: {
    shape: class
    label: "IfNode (ast.h)"
    -condition: "ASTNode*"
    -then_body: "ASTNode*"
    -else_body: "ASTNode*"
    +has_else(): "bool"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  while_node: {
    shape: class
    label: "WhileNode (ast.h)"
    -condition: "ASTNode*"
    -body: "ASTNode*"
    -is_until: "bool"
    +should_continue(): "bool"
  }
  for_node: {
    shape: class
    label: "ForNode (ast.h)"
    -variable: "char*"
    -word_list: "ASTNode*"
    -body: "ASTNode*"
    +iterate(): "char**"
  }
  func_node: {
    shape: class
    label: "FunctionDefNode (ast.h)"
    -name: "char*"
    -body: "ASTNode*"
    -arity: "int"
    +invoke(args): "int"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  visitor: {
    shape: class
    label: "ASTVisitor (visitor.h)"
    +visit_command(n): "int"
    +visit_pipeline(n): "int"
    +visit_list(n): "int"
    +visit_if(n): "int"
    +visit_while(n): "int"
    +visit_for(n): "int"
    +visit_function(n): "int"
  }
  executor: {
    shape: class
    label: "Executor (execute.c)"
    -shell: "Shell*"
    -last_status: "int"
    +visit_command(n): "int"
    +visit_pipeline(n): "int"
    +visit_list(n): "int"
    +visit_if(n): "int"
    +visit_while(n): "int"
    +visit_for(n): "int"
    +visit_function(n): "int"
  }
}
ast_node -> command_node: "type: NODE_SIMPLE_CMD"
ast_node -> pipeline_node: "type: NODE_PIPELINE"
ast_node -> list_node: "type: NODE_LIST"
ast_node -> if_node: "type: NODE_IF"
ast_node -> while_node: "type: NODE_WHILE"
ast_node -> for_node: "type: NODE_FOR"
ast_node -> func_node: "type: NODE_FUNCTION_DEF"
visitor -> executor: "implements"
executor -> ast_node: "visits"
legend: {
  near: bottom-right
  note: |md
    **Node Type Enum (ast.h)**
    
    typedef enum {
      NODE_SIMPLE_CMD,
      NODE_PIPELINE,
      NODE_LIST,
      NODE_IF,
      NODE_WHILE,
      NODE_FOR,
      NODE_FUNCTION_DEF,
      NODE_SUBSHELL,
      NODE_BRACE_GROUP,
      NODE_AND,
      NODE_OR
    } NodeType;
    
  |
}