direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Lexer State Machine {
  style.font-size: 32
  style.bold: true
  near: top-center
  shape: text
}
subtitle: Quote Handling for `echo "hello\"world"` {
  style.font-size: 18
  style.italic: true
  style.font-color: "#666666"
  near: top-center
  shape: text
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_diagram: {
    direction: down
    label: "State Transition Diagram (lexer.c)"
    default: {
      shape: circle
      label: "DEFAULT"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 3
    }
    single_quote: {
      shape: circle
      label: "IN_SINGLE\n_QUOTE"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.stroke-width: 2
    }
    double_quote: {
      shape: circle
      label: "IN_DOUBLE\n_QUOTE"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
    escape: {
      shape: circle
      label: "IN_ESCAPE"
      style.fill: "#FCE4EC"
      style.stroke: "#E91E63"
      style.stroke-width: 2
    }
    default -> single_quote: {
      label: "' (single quote)"
      style.stroke: "#FF9800"
      style.stroke-width: 2
    }
    single_quote -> default: {
      label: "' (closing)"
      style.stroke: "#FF9800"
      style.stroke-width: 2
    }
    default -> double_quote: {
      label: "\" (double quote)"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
    double_quote -> default: {
      label: "\" (closing)"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
    default -> escape: {
      label: "\\ (backslash)"
      style.stroke: "#E91E63"
      style.stroke-width: 2
    }
    double_quote -> escape: {
      label: "\\"
      style.stroke: "#E91E63"
      style.stroke-width: 2
    }
    escape -> default: {
      label: "any char"
      style.stroke: "#E91E63"
      style.stroke-dash: 3
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  token_trace: {
    label: "Token Trace: `echo \"hello\\\"world\"`"
    direction: down
    style.fill: "#FAFAFA"
    style.stroke: "#E0E0E0"
    step0: {
      label: "Step 0: Initialize"
      width: 400
      code: |'c
        Lexer lex = {
          .input = "echo \"hello\\\"world\"",
          .pos = 0,
          .state = LEX_DEFAULT
        };
      '|
    }
    step1: {
      label: "Step 1: Read 'echo'"
      width: 400
      code: |'c
        // DEFAULT state: read word until space
        // pos=0→4, token="echo"
        // Classify: TOK_WORD (not a keyword)
      '|
    }
    step2: {
      label: "Step 2: Skip space, see '\"'"
      width: 400
      code: |'c
        // DEFAULT: c='"'
        // Transition: DEFAULT → IN_DOUBLE_QUOTE
        lex.state = LEX_IN_DOUBLE_QUOTE;
        lex.pos++;  // skip opening "
      '|
    }
    step3: {
      label: "Step 3: Accumulate in double quote"
      width: 400
      code: |'c
        // IN_DOUBLE_QUOTE: read 'h','e','l','l','o'
        // token buffer: "hello"
        // pos now at '\\' (backslash before ")
      '|
    }
    step4: {
      label: "Step 4: Handle escape in double quote"
      width: 400
      code: |'c
        // IN_DOUBLE_QUOTE: c='\\', next='"'
        // Escape sequence: \" → literal "
        append_char(&token, '"');  // Add " to token
        lex.pos += 2;  // skip \" 
        // Stay in IN_DOUBLE_QUOTE
      '|
    }
    step5: {
      label: "Step 5: Continue and close"
      width: 400
      code: |'c
        // IN_DOUBLE_QUOTE: read 'w','o','r','l','d'
        // token buffer: "hello\"world"
        // See closing '"'
        lex.state = LEX_DEFAULT;
        // Return TOK_WORD with value "hello\"world"
      '|
    }
    result: {
      label: "Final Token Stream"
      width: 400
      shape: sql_table
      t0: "0 | TOK_WORD | \"echo\""
      t1: "1 | TOK_WORD | \"hello\\\"world\""
      t2: "2 | TOK_EOF  | NULL"
    }
    step0 -> step1 -> step2 -> step3 -> step4 -> step5 -> result
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rules: {
    label: "Quote Handling Rules (POSIX)"
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    single_quote_rules: {
      label: "Single Quotes '...'"
      width: 350
      code: |'c
        // Everything is LITERAL
        // No variable expansion: $HOME stays $HOME
        // No escape sequences: \n stays \n
        // Only ' ends the string
        // Example:
        // 'hello\n$HOME' → literal 12 chars
      '|
    }
    double_quote_rules: {
      label: "Double Quotes \"...\""
      width: 350
      code: |'c
        // Variables ARE expanded: $HOME → /home/user
        // Spaces preserved (no word splitting)
        // Escape sequences work for:
        //   \$  → literal $
        //   \"  → literal "
        //   \\  → literal \
        //   \`  → literal `
        //   \n  → newline (in some shells)
        // Example:
        // "hello $USER" → "hello alice"
      '|
    }
    escape_rules: {
      label: "Escape Character \\"
      width: 350
      code: |'c
        // Outside quotes: escapes next char
        //   \  → literal space (no split)
        //   \n → literal n (NOT newline!)
        //   \$ → literal $
        // Inside double quotes: limited set
        // Inside single quotes: literal backslash
        //   (no escaping in single quotes!)
      '|
    }
    single_quote_rules -> double_quote_rules -> escape_rules
  }
  edge_cases: {
    label: "Edge Cases & Common Bugs"
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    bug1: {
      label: "Bug #1: Unterminated Quote"
      width: 350
      code: |'c
        // Input: echo "hello
        // Lexer reaches EOF while in DOUBLE_QUOTE
        // Result: TOK_ERROR, value="Unterminated quote"
        if (lex->pos >= lex->len && 
            lex->state != LEX_DEFAULT) {
          *type = TOK_ERROR;
          *value = "Unterminated quote";
          return -1;
        }
      '|
    }
    bug2: {
      label: "Bug #2: State After Token"
      width: 350
      code: |'c
        // CRITICAL: Reset state between tokens!
        // Wrong: state carries over
        //   echo "a"b → TOK_WORD("ab") WRONG!
        // Right: reset to DEFAULT after each token
        //   echo "a"b → 3 tokens: echo, a, b
        // After returning a token:
        lex->state = LEX_DEFAULT;
      '|
    }
    bug3: {
      label: "Bug #3: Mixed Quote Concatenation"
      width: 350
      code: |'c
        // POSIX allows: "hello"'world'"!"
        // This is ONE token: helloworld!
        // Must track quote transitions WITHIN token
        // Lexer continues reading same token
        // when transitioning between quote states
        // Only return token when unquoted terminator
      '|
    }
    bug1 -> bug2 -> bug3
  }
}
row1 -> row2: "State machine drives\ncharacter processing" {
  style.stroke-dash: 3
  style.stroke: "#9E9E9E"
}
row2 -> row3: "Apply rules at each\nstate transition" {
  style.stroke-dash: 3
  style.stroke: "#9E9E9E"
}
legend: {
  near: bottom-right
  label: "State Color Legend"
  style.fill: white
  style.stroke: "#BDBDBD"
  item1: {
    shape: circle
    label: ""
    width: 20
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  item1_label: "DEFAULT (initial state)"
  item2: {
    shape: circle
    label: ""
    width: 20
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  item2_label: "IN_SINGLE_QUOTE"
  item3: {
    shape: circle
    label: ""
    width: 20
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  item3_label: "IN_DOUBLE_QUOTE"
  item4: {
    shape: circle
    label: ""
    width: 20
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
  }
  item4_label: "IN_ESCAPE"
}