direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  style.stroke: transparent
  style.fill: transparent
  title: "Parser Error Recovery Flow (parser.c)" {
    shape: text
    style.font-size: 28
    style.bold: true
  }
}

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  token_stream: {
    label: "Token Stream Input"
    style.fill: "#E8F4FD"
    t1: "TOK_WORD: 'cmd1'"
    t2: "TOK_PIPE: '|'"
    t3: "TOK_PIPE: '|'"
    t4: "TOK_WORD: 'cmd2'"
    t5: "TOK_EOF"
    t1 -> t2 -> t3 -> t4 -> t5
  }

  parser_state: {
    label: "Parser State"
    style.fill: "#FFF3E0"
    current: "current: parse_pipeline()"
    expecting: "expecting: command after PIPE"
    found: "found: TOK_PIPE"
    current -> expecting -> found
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  error_detect: {
    shape: diamond
    label: "Token matches expected type?"
    style.fill: "#FFCDD2"
  }

  error_generate: {
    label: "Generate Error"
    style.fill: "#FFCDD2"
    msg: {
      content: |'md
        **syntax error near**
        **unexpected token `|`**
        
        cmd1 | | cmd2
              ^
      '|
    }
    context: "Location: line 1, col 8"
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  sync_point: {
    label: "Synchronization Point"
    style.fill: "#C8E6C9"
    strategy: {
      content: |'md
        **Recovery Strategy:**
        1. Skip unexpected token
        2. Scan for sync token
        3. Resume parsing
      '|
    }
    sync_list: "Sync: ; | \n ) }"
  }

  recovery: {
    label: "Recovery Actions"
    style.fill: "#C8E6C9"
    skip: "Skip second PIPE"
    scan: "Scan to TOK_WORD: 'cmd2'"
    resume: "Resume: parse_simple_command()"
    skip -> scan -> resume
  }
}

row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  continue_parse: {
    label: "Continue Parsing"
    style.fill: "#E1BEE7"
    state: "Parser State (Recovered)"
    next: "Next: parse 'cmd2' as command"
    ast_partial: "AST: cmd1 | (error) | cmd2"
    state -> next -> ast_partial
  }

  result: {
    label: "Final Result"
    style.fill: "#E1BEE7"
    status: "Return: NULL (parse failed)"
    ast: "Partial AST freed"
    error_msg: "error_message set for REPL"
    status -> ast -> error_msg
  }
}

# Connections
row1.token_stream.t2 -> row1.parser_state.current: "consume |"
row1.parser_state.found -> row2.error_detect: "check TOK_PIPE"
row2.error_detect -> row2.error_generate: "Mismatch" {
  style.stroke: red
  style.stroke-dash: 4
}
row2.error_generate -> row3.sync_point: "initiate recovery"
row3.sync_point.sync_list -> row3.recovery.skip
row3.recovery.resume -> row4.continue_parse.state
row4.continue_parse.ast_partial -> row4.result.status

legend: {
  label: "Legend"
  near: bottom-right
  direction: right
  l1: "Error path" { style.fill: "#FFCDD2" }
  l2: "Recovery" { style.fill: "#C8E6C9" }
  l3: "Result" { style.fill: "#E1BEE7" }
}

notes: {
  label: "Implementation Notes (parser.c)"
  near: bottom-left
  style.fill: "#F5F5F5"
  code: |'c
    static void parser_error(Parser* p, const char* msg) {
        p->has_error = true;
        asprintf(&p->error_message, 
            "syntax error near token `%s': %s",
            p->current_value, msg);
    }
    // Recovery: skip to sync point
    while (!is_sync_token(p->current_type) && p->current_type != TOK_EOF) {
        advance_token(p);
    }
  '|
}