direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    literal: "#E8F5E9"
    operator: "#E3F2FD"
    redirection: "#FFF3E0"
    keyword: "#F3E5F5"
    delimiter: "#FAFAFA"
    control: "#FFEBEE"
  }
}
title: {
  label: "Token Type Taxonomy\nShell Lexer Classification (lexer.h)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  literals: {
    direction: down
    label: "LITERALS"
    style.fill: ${colors.literal}
    TOK_WORD: {
      shape: sql_table
      label: "TOK_WORD"
      desc: "Commands, arguments,\nvariable names, filenames"
      example: "echo, -la, file.txt"
    }
    TOK_EOF: {
      shape: sql_table
      label: "TOK_EOF"
      desc: "End of input stream"
      example: "(null)"
    }
    TOK_ERROR: {
      shape: sql_table
      label: "TOK_ERROR"
      desc: "Lexical error marker"
      example: "unterminated quote"
    }
  }
  operators: {
    direction: down
    label: "OPERATORS"
    style.fill: ${colors.operator}
    pipe_semi: {
      direction: right
      label: "Pipeline / List"
      TOK_PIPE: {
        shape: sql_table
        label: "TOK_PIPE |"
        prec: "Precedence: 4\n(highest)"
      }
      TOK_SEMICOLON: {
        shape: sql_table
        label: "TOK_SEMICOLON ;"
        prec: "Precedence: 1\n(lowest)"
      }
    }
    TOK_AMPERSAND: {
      shape: sql_table
      label: "TOK_AMPERSAND &"
      prec: "Precedence: 2\nAssociativity: N/A"
      note: "Background execution"
    }
    TOK_NEWLINE: {
      shape: sql_table
      label: "TOK_NEWLINE \\n"
      prec: "Same as ;"
      note: "Command terminator"
    }
  }
  redirections: {
    direction: down
    label: "REDIRECTIONS"
    style.fill: ${colors.redirection}
    TOK_REDIR_IN: {
      shape: sql_table
      label: "TOK_REDIR_IN <"
      target: "stdin ← file"
    }
    TOK_REDIR_OUT: {
      shape: sql_table
      label: "TOK_REDIR_OUT >"
      target: "stdout → file (truncate)"
    }
    TOK_REDIR_APPEND: {
      shape: sql_table
      label: "TOK_REDIR_APPEND >>"
      target: "stdout → file (append)"
    }
    TOK_REDIR_ERR: {
      shape: sql_table
      label: "TOK_REDIR_ERR 2>"
      target: "stderr → file"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  keywords: {
    direction: down
    label: "KEYWORDS (Control Flow)"
    style.fill: ${colors.keyword}
    conditional: {
      direction: right
      label: "Conditional"
      TOK_IF: {
        shape: sql_table
        label: "TOK_IF"
        kw: "if"
      }
      TOK_THEN: {
        shape: sql_table
        label: "TOK_THEN"
        kw: "then"
      }
      TOK_ELSE: {
        shape: sql_table
        label: "TOK_ELSE"
        kw: "else"
      }
      TOK_FI: {
        shape: sql_table
        label: "TOK_FI"
        kw: "fi"
      }
    }
    loops: {
      direction: right
      label: "Loops"
      TOK_WHILE: {
        shape: sql_table
        label: "TOK_WHILE"
        kw: "while"
      }
      TOK_DO: {
        shape: sql_table
        label: "TOK_DO"
        kw: "do"
      }
      TOK_DONE: {
        shape: sql_table
        label: "TOK_DONE"
        kw: "done"
      }
      TOK_FOR: {
        shape: sql_table
        label: "TOK_FOR"
        kw: "for"
      }
      TOK_IN: {
        shape: sql_table
        label: "TOK_IN"
        kw: "in"
      }
    }
  }
  delimiters: {
    direction: down
    label: "DELIMITERS"
    style.fill: ${colors.delimiter}
    TOK_LPAREN: {
      shape: sql_table
      label: "TOK_LPAREN ("
      usage: "Subshell start\nFunction def"
    }
    TOK_RPAREN: {
      shape: sql_table
      label: "TOK_RPAREN )"
      usage: "Subshell end\nFunction def"
    }
  }
  precedence: {
    direction: down
    label: "Operator Precedence"
    style.fill: ${colors.control}
    prec_table: {
      shape: sql_table
      label: "Precedence Hierarchy (parser.c)"
      p1: "1 (lowest)  | ; newline   | List (sequential)"
      p2: "2           | &           | Background"
      p3: "3           | && ||       | Logical (left-assoc)"
      p4: "4 (highest) | |           | Pipeline"
      note: "Higher binds tighter: a | b && c = (a | b) && c"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  l1: {
    label: "Literals"
    style.fill: ${colors.literal}
  }
  l2: {
    label: "Operators"
    style.fill: ${colors.operator}
  }
  l3: {
    label: "Redirections"
    style.fill: ${colors.redirection}
  }
  l4: {
    label: "Keywords"
    style.fill: ${colors.keyword}
  }
  l5: {
    label: "Delimiters"
    style.fill: ${colors.delimiter}
  }
}
arrows: {
  operators -> redirections: "can follow\nany command" {
    style.stroke-dash: 3
  }
  keywords.TOK_IF -> keywords.TOK_THEN: "requires" {
    style.stroke: purple
  }
  keywords.TOK_WHILE -> keywords.TOK_DO: "requires" {
    style.stroke: purple
  }
  delimiters.TOK_LPAREN <-> delimiters.TOK_RPAREN: "matched pair" {
    style.stroke: blue
    style.stroke-dash: 4
  }
}