direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Shell Expansion Phase Pipeline
  POSIX-defined 6-stage transformation
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_box: {
    label: "Input Word"
    width: 280
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    raw_input: |'bash
echo ~/src/$PROJECT/*.c
    '|
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase1: {
    label: "Phase 1: Tilde Expansion"
    width: 280
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    desc: |md
      `~` → `$HOME`
      `~user` → user's home
    |
    result: |'bash
echo /home/user/src/$PROJECT/*.c
    '|
    result.style.fill: "#FFE0B2"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase2: {
    label: "Phase 2: Parameter Expansion"
    width: 280
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    desc: |md
      `$VAR`, `${VAR}`
      `$?`, `$$`, `$1`..`$9`
    |
    result: |'bash
echo /home/user/src/myapp/*.c
    '|
    result.style.fill: "#C8E6C9"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase3: {
    label: "Phase 3: Command Substitution"
    width: 280
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    desc: |md
      `$(cmd)` or `` `cmd` ``
      Recursive shell invocation
    |
    result: |'bash
echo /home/user/src/myapp/*.c
    '|
    result.style.fill: "#E1BEE7"
    note: "(no substitution in this word)"
    note.style.font-size: 12
    note.style.italic: true
    note.style.fill: transparent
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase4: {
    label: "Phase 4: Field Splitting"
    width: 280
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    desc: |md
      Split on IFS (space/tab/newline)
      Only results of expansions
    |
    result: |'bash
["/home/user/src/myapp/*.c"]
    '|
    result.style.fill: "#B2EBF2"
    note: "(single word - no IFS chars)"
    note.style.font-size: 12
    note.style.italic: true
    note.style.fill: transparent
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase5: {
    label: "Phase 5: Glob Expansion"
    width: 280
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    desc: |md
      `*`, `?`, `[...]` → filenames
      Alphabetically sorted
    |
    result: |'bash
["/home/user/src/myapp/main.c",
 "/home/user/src/myapp/util.c"]
    '|
    result.style.fill: "#FFCDD2"
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase6: {
    label: "Phase 6: Quote Removal"
    width: 280
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
    desc: |md
      Remove unescaped `'` and `"`
      Remove unquoted `\`
    |
    result: |'bash
["/home/user/src/myapp/main.c",
 "/home/user/src/myapp/util.c"]
    '|
    result.style.fill: "#EEEEEE"
  }
}
row_output: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_box: {
    label: "Final argv[]"
    width: 280
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2
    final: |'c
argv[0] = "echo"
argv[1] = "/home/user/src/myapp/main.c"
argv[2] = "/home/user/src/myapp/util.c"
argv[3] = NULL
    '|
  }
}
row_input.input_box -> row1.phase1: "word" {
  style.stroke: "#666"
  style.stroke-width: 2
}
row1.phase1 -> row2.phase2: "transformed" {
  style.stroke: "#666"
  style.stroke-width: 2
}
row2.phase2 -> row3.phase3: "transformed" {
  style.stroke: "#666"
  style.stroke-width: 2
}
row3.phase3 -> row4.phase4: "transformed" {
  style.stroke: "#666"
  style.stroke-width: 2
}
row4.phase4 -> row5.phase5: "word[]" {
  style.stroke: "#666"
  style.stroke-width: 2
}
row5.phase5 -> row6.phase6: "expanded[]" {
  style.stroke: "#666"
  style.stroke-width: 2
}
row6.phase6 -> row_output.output_box: "final argv" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
legend: {
  near: bottom-right
  label: "Key Insight"
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  content: |md
    **Quote State Matters**
    Phases only operate on text that
    wasn't quoted in an earlier phase:
    - `"~/src"` → no tilde expansion
    - `"$VAR"` → expands (double quote)
    - `'$VAR'` → literal (single quote)
    - `"*.c"` → no glob expansion
  |
}