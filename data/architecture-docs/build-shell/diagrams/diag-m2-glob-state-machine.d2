direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: |md
    # Glob Pattern Matching State Machine
    Implementation Blueprint for `glob_match(pattern, string)`
    Pattern: `file*.c` → Input: `file_test.c`
  |
  style: {
    stroke-width: 0
    fill: transparent
  }
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  states_container: {
    label: "NFA State Representation (glob_nfa.c)"
    direction: right
    style.fill: "#F9F9F9"
    
    s0: {
      shape: circle
      label: "S0\nSTART"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    s1: {
      shape: circle
      label: "S1\nLIT"
      style.fill: "#E3F2FD"
    }
    s2: {
      shape: circle
      label: "S2\nSTAR"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.stroke-width: 3
    }
    s3: {
      shape: circle
      label: "S3\nLIT"
      style.fill: "#E3F2FD"
    }
    s4: {
      shape: circle
      label: "S4\nDOT"
      style.fill: "#E3F2FD"
    }
    s5: {
      shape: circle
      label: "S5\nLIT"
      style.fill: "#E3F2FD"
    }
    s6: {
      shape: circle
      label: "S6\nACCEPT"
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
      style.double-border: true
    }

    s0 -> s1: "'f' | match"
    s1 -> s2: "'ile' | match"
    s2 -> s2: "* | consume" {
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    s2 -> s3: "'.' | peek"
    s3 -> s4: "'.' | consume"
    s4 -> s5: "'c' | match"
    s5 -> s6: "\\0 | EOF"
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  data_layout: {
    direction: right
    label: "Memory Layouts"

    pattern_table: {
      shape: sql_table
      label: "Pattern Buffer (pattern.h)"
      p0: "0x00 | char 'f' | LITERAL"
      p1: "0x01 | char 'i' | LITERAL"
      p2: "0x02 | char 'l' | LITERAL"
      p3: "0x03 | char 'e' | LITERAL"
      p4: "0x04 | char '*' | WILDCARD_ANY"
      p5: "0x05 | char '.' | LITERAL"
      p6: "0x06 | char 'c' | LITERAL"
      p7: "0x07 | char \\0  | EOP"
      sz: "Total: 8 bytes"
    }

    string_table: {
      shape: sql_table
      label: "Input String (input.c)"
      c0: "0x00 | 'f' | ✓ Match"
      c1: "0x01 | 'i' | ✓ Match"
      c2: "0x02 | 'l' | ✓ Match"
      c3: "0x03 | 'e' | ✓ Match"
      c4: "0x04 | '_' | Consumed by *"
      c5: "0x05 | 't' | Consumed by *"
      c6: "0x06 | 'e' | Consumed by *"
      c7: "0x07 | 's' | Consumed by *"
      c8: "0x08 | 't' | Consumed by *"
      c9: "0x09 | '.' | ✓ Match"
      c10: "0x0A | 'c' | ✓ Match"
      c11: "0x0B | \\0  | Match End"
      sz: "Total: 12 bytes"
    }
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  logic_implementation: {
    label: "Backtracking & Wildcard Logic (glob.c)"
    direction: down
    
    bt_struct: {
      shape: sql_table
      label: "struct BacktrackFrame"
      f0: "0x00 | const char* | p_star // Last * pos"
      f1: "0x08 | const char* | s_star // String backtrack pos"
      sz: "Total: 16 bytes"
    }

    bt_algorithm: {
      label: "Matching Loop Logic"
      width: 450
      code: |'c
        while (*str) {
          if (*pat == *str || *pat == '?') {
            pat++; str++;
          } else if (*pat == '*') {
            p_star = pat++; s_star = str;
          } else if (p_star) {
            pat = p_star + 1;
            str = ++s_star;
          } else return NO_MATCH;
        }
      '|
    }
  }

  extra_features: {
    label: "Parsing & Optimization"
    direction: down
    style.fill: "#FFFDE7"

    cc_parser: {
      shape: class
      label: "CharClassParser (glob.c)"
      -pattern: "const char*"
      -pos: "size_t"
      -negate: "bool"
      +parse_class(p): "CharClass*"
      +match(c): "bool"
      +free(cc): "void"
    }

    ec_consecutive_stars: {
      label: "Collapse ** Wildcards"
      width: 350
      code: |'c
        // ** and *** are same as *
        while (*pat == '*' && 
               *(pat+1) == '*') {
          pat++; // skip extras
        }
      '|
    }
  }
}

states_container -> data_layout: "maps to"
data_layout -> logic_implementation: "read by"
extra_features -> logic_implementation: "provides utils"