direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # Job State Machine
  Process lifecycle under shell job control
| {near: top-center}
states: {
  direction: right
  running: {
    shape: circle
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      font-color: white
    }
  }
  stopped: {
    shape: circle
    style: {
      fill: "#FFC107"
      stroke: "#F57C00"
      font-color: black
    }
  }
  done: {
    shape: circle
    style: {
      fill: "#9E9E9E"
      stroke: "#616161"
      font-color: white
    }
  }
}
running -> running: "continue (loop)"
running -> stopped: "SIGTSTP (Ctrl+Z)" {
  style: {
    stroke: "#F57C00"
    stroke-dash: 3
  }
}
running -> done: "exit / SIGKILL" {
  style: {
    stroke: "#616161"
  }
}
stopped -> running: "SIGCONT (fg/bg)" {
  style: {
    stroke: "#2E7D32"
  }
}
stopped -> done: "SIGKILL" {
  style: {
    stroke: "#C62828"
    stroke-dash: 3
  }
}
job_table_running: {
  label: "Job Table (Running)"
  shape: sql_table
  r1: "job_id | int"
  r2: "pgid | pid_t"
  r3: "state | JOB_RUNNING"
  r4: "command | char*"
  r5: "is_foreground | bool"
  r6: "exit_status | -"
}
job_table_stopped: {
  label: "Job Table (Stopped)"
  shape: sql_table
  r1: "job_id | int"
  r2: "pgid | pid_t"
  r3: "state | JOB_STOPPED"
  r4: "command | char*"
  r5: "stop_signal | SIGTSTP"
  r6: "is_foreground | false"
}
job_table_done: {
  label: "Job Table (Done)"
  shape: sql_table
  r1: "job_id | int"
  r2: "pgid | pid_t"
  r3: "state | JOB_DONE"
  r4: "command | char*"
  r5: "exit_status | 0-255"
  r6: "needs_report | true"
}
job_table_running -> job_table_stopped: "WIFSTOPPED(status)" {
  style.stroke-dash: 3
  style.stroke: "#F57C00"
}
job_table_stopped -> job_table_running: "WIFCONTINUED(status)" {
  style.stroke-dash: 3
  style.stroke: "#2E7D32"
}
job_table_running -> job_table_done: "WIFEXITED(status)" {
  style.stroke-dash: 3
  style.stroke: "#616161"
}
job_table_stopped -> job_table_done: "WIFSIGNALED(status)" {
  style.stroke-dash: 3
  style.stroke: "#C62828"
}
sigchld_handler: {
  label: "SIGCHLD Handler (shell/signal.c)"
  width: 400
  code: |'c
    void reap_children(void) {
      while ((pid = waitpid(-1, &status, 
                            WNOHANG | WUNTRACED | WCONTINUED)) > 0) {
        if (WIFEXITED(status))   job->state = JOB_DONE;
        if (WIFSIGNALED(status)) job->state = JOB_DONE;
        if (WIFSTOPPED(status))  job->state = JOB_STOPPED;
        if (WIFCONTINUED(status))job->state = JOB_RUNNING;
      }
    }
  '|
}
sigchld_handler -> job_table_running: "updates"
transition_actions: {
  direction: right
  label: "Transition Actions"
  on_stop: {
    label: "On STOPPED"
    code: |'c
      take_terminal_back();
      restore_terminal_modes();
      job->is_foreground = false;
      printf("[%d]+ Stopped %s\n", ...);
    '|
    width: 300
  }
  on_fg: {
    label: "On fg (resume foreground)"
    code: |'c
      kill(-job->pgid, SIGCONT);
      job->is_foreground = true;
      give_terminal_to(job->pgid);
      wait_for_job(job);
    '|
    width: 300
  }
  on_bg: {
    label: "On bg (resume background)"
    code: |'c
      kill(-job->pgid, SIGCONT);
      job->is_foreground = false;
      printf("[%d] %s &\n", ...);
    '|
    width: 300
  }
  on_done: {
    label: "On DONE"
    code: |'c
      job->needs_report = true;
      // Report printed at next prompt
      // Job removed from table after report
    '|
    width: 300
  }
}
legend: {
  near: bottom-right
  legend_running: "Running" {
    shape: circle
    style.fill: "#4CAF50"
    width: 20
  }
  legend_stopped: "Stopped" {
    shape: circle
    style.fill: "#FFC107"
    width: 20
  }
  legend_done: "Done" {
    shape: circle
    style.fill: "#9E9E9E"
    width: 20
  }
}