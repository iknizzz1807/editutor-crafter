direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Process Groups and Terminal Control
  Kernel-level view of job control architecture
| {near: top-center}
# Layer 1: Hardware/Terminal
layer_terminal: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  terminal_driver: {
    label: "Terminal Driver\n(ptm/pts)"
    shape: rectangle
    style.fill: "#E8D4F0"
    style.stroke: "#7B4B94"
    style.stroke-width: 2
    state: {
      shape: sql_table
      label: "Terminal State (tty_struct)"
      f0: "foreground_pgid | 1234"
      f1: "session_sid     | 1000"
      f2: "c_cc[VINTR]     | ^C (0x03)"
      f3: "c_cc[VSUSP]     | ^Z (0x1A)"
    }
    signal_gen: {
      label: "Signal Generation"
      width: 300
      code: |'c
        // kernel: tty_input.c
        if (c == termios.c_cc[VINTR]) {
          // Ctrl+C pressed
          kill_pgrp(tty->pgrp, SIGINT);
        }
        if (c == termios.c_cc[VSUSP]) {
          // Ctrl+Z pressed  
          kill_pgrp(tty->pgrp, SIGTSTP);
        }
      '|
    }
  }
}
# Layer 2: Process Groups
layer_processes: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  shell_pg: {
    label: "Shell Process Group\nPGID = 1234"
    style.fill: "#B8E6B8"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    shell_proc: {
      shape: class
      label: "Shell (mysh)"
      +pid: "1234"
      +pgid: "1234 (leader)"
      +sid: "1000"
      +state: "RUNNING"
      +tty: "/dev/pts/0"
    }
    shell_code: {
      label: "Shell Signal Setup"
      width: 320
      code: |'c
        // Shell ignores terminal signals
        signal(SIGINT,  SIG_IGN);
        signal(SIGTSTP, SIG_IGN);
        signal(SIGTTOU, SIG_IGN);
        signal(SIGTTIN, SIG_IGN);
      '|
    }
  }
  job_pg: {
    label: "Job Process Group\nPGID = 5678"
    style.fill: "#FFE0B2"
    style.stroke: "#E65100"
    style.stroke-width: 2
    job_leader: {
      shape: class
      label: "Pipeline Leader"
      +pid: "5678"
      +pgid: "5678 (leader)"
      +ppid: "1234"
      +state: "RUNNING"
    }
    job_child: {
      shape: class
      label: "Pipeline Child"
      +pid: "5679"
      +pgid: "5678"
      +ppid: "1234"
      +state: "RUNNING"
    }
  }
  bg_job_pg: {
    label: "Background Job\nPGID = 9001"
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.stroke-width: 2
    style.stroke-dash: 4
    bg_proc: {
      shape: class
      label: "Background Process"
      +pid: "9001"
      +pgid: "9001 (leader)"
      +ppid: "1234"
      +state: "RUNNING"
    }
  }
}
# Layer 3: Kernel Process Table
layer_kernel: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  process_table: {
    label: "Kernel Process Table"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    task_structs: {
      shape: sql_table
      label: "task_struct entries"
      r0: "PID  | PGID | SID  | State     | pgrp_entry"
      r1: "1234 | 1234 | 1000 | RUNNING   | pg_head →"
      r2: "5678 | 5678 | 1000 | RUNNING   | pg_head →"
      r3: "5679 | 5678 | 1000 | RUNNING   | pg_next →"
      r4: "9001 | 9001 | 1000 | RUNNING   | pg_head →"
    }
    pg_list: {
      label: "Process Group Lists"
      width: 350
      code: |'c
        // Each PGID has a linked list
        // of member processes
        struct pid_link {
          struct hlist_head pg_head;
        };
        // PGID 5678: [5678] -> [5679] -> NULL
        // PGID 1234: [1234] -> NULL
        // PGID 9001: [9001] -> NULL
      '|
    }
  }
}
# Connections
terminal_driver.state -> shell_pg: "tcgetpgrp()\nreturns 1234" {
  style.stroke: "#7B4B94"
  style.stroke-width: 2
}
terminal_driver.state -> job_pg: "tcgetpgrp()\nreturns 5678" {
  style.stroke: "#E65100"
  style.stroke-width: 3
  style.animated: true
  label: "FOREGROUND"
}
terminal_driver.signal_gen -> job_pg: "SIGINT\n(delivered to PGID 5678)" {
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.stroke-dash: 4
}
terminal_driver.signal_gen -> shell_pg: "NO SIGNAL\n(shell PGID != foreground)" {
  style.stroke: "#9E9E9E"
  style.stroke-width: 1
  style.stroke-dash: 3
}
shell_pg -> job_pg: "setpgid(5678, 5678)\nCreate new process group" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
shell_pg -> bg_job_pg: "setpgid(9001, 9001)\nBackground job" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.stroke-dash: 4
}
shell_pg.shell_code -> terminal_driver: "tcsetpgrp(tty_fd, 5678)\nGive terminal to job" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
  label: "Transfer control"
}
job_pg.job_leader -> job_pg.job_child: "setpgid(0, 5678)\nJoin parent's group" {
  style.stroke: "#E65100"
  style.stroke-dash: 2
}
process_table -> job_pg: "kill_pgrp(5678, SIGINT)\nSignal all members" {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}
# Legend
legend: {
  near: bottom-center
  label: "Signal Flow Legend"
  key_foreground: "━━━▶ Foreground job (receives signals)" {
    style.stroke: "#E65100"
    style.font-color: "#E65100"
  }
  key_signal: "- - -▶ SIGINT delivery" {
    style.stroke: "#D32F2F"
    style.font-color: "#D32F2F"
    style.stroke-dash: 4
  }
  key_background: "- - -  Background (no terminal)" {
    style.stroke: "#C62828"
    style.font-color: "#C62828"
    style.stroke-dash: 4
  }
  key_nosig: "━━━   No signal (PGID mismatch)" {
    style.stroke: "#9E9E9E"
    style.font-color: "#9E9E9E"
  }
}
# Flow annotation
flow_seq: {
  near: top-right
  label: "Ctrl+C Sequence"
  width: 280
  step1: "1. User presses Ctrl+C"
  step2: "2. Terminal driver reads 0x03"
  step3: "3. Lookup: tty->pgrp = 5678"
  step4: "4. kill_pgrp(5678, SIGINT)"
  step5: "5. All PIDs in 5678 receive SIGINT"
  step6: "6. Shell (PGID 1234) unaffected"
  step1 -> step2 -> step3 -> step4 -> step5 -> step6 {
    style.stroke: "#666"
    style.stroke-width: 1
  }
}