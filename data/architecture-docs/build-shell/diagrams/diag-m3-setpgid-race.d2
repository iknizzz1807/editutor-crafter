direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # setpgid() Race Condition and Solution
  Both parent AND child must call setpgid() to guarantee correct process group membership
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  race: {
    direction: down
    label: "RACE CONDITION"
    parent_bad: {
      label: "Parent Process"
      width: 300
      style.fill: "#ffebee"
      style.stroke: "#c62828"
      fork_bad: {
        label: "fork()"
        shape: oval
        style.fill: "#ffcdd2"
      }
      setpgid_bad: {
        label: "setpgid(pid, pid)"
        shape: rectangle
        style.fill: "#ffcdd2"
        width: 180
      }
      wait_bad: {
        label: "waitpid(pid, ...)"
        shape: rectangle
        style.fill: "#ffcdd2"
        width: 180
      }
      fork_bad -> setpgid_bad: "child PID\nreturned"
      setpgid_bad -> wait_bad: "group\nestablished"
    }
    child_bad: {
      label: "Child Process"
      width: 300
      style.fill: "#fff3e0"
      style.stroke: "#ef6c00"
      child_fork_bad: {
        label: "fork() returns 0"
        shape: oval
        style.fill: "#ffe0b2"
      }
      exec_bad: {
        label: "execvp(cmd, args)"
        shape: rectangle
        style.fill: "#ffcc80"
        width: 180
      }
      running_bad: {
        label: "Running in\nWRONG GROUP!"
        shape: diamond
        style.fill: "#ff8a65"
        style.stroke: "#d84315"
        style.font-color: "#bf360c"
        width: 140
      }
      child_fork_bad -> exec_bad: "immediately"
      exec_bad -> running_bad: "exec succeeds\nbefore parent's\nsetpgid()"
    }
  }
  race_arrow: {
    shape: text
    label: |md
      **Race Window:**
      Child execs before parent
      calls setpgid()
      Child remains in shell's
      process group → receives
      signals meant for shell!
    |
  }
}
timeline_bad: {
  label: "Timeline (Race Occurs)"
  direction: right
  style.fill: transparent
  style.stroke: transparent
  t1: {
    label: "t0"
    shape: circle
    style.fill: "#e0e0e0"
    width: 40
  }
  t2: {
    label: "t1"
    shape: circle
    style.fill: "#ffcc80"
    width: 40
  }
  t3: {
    label: "t2"
    shape: circle
    style.fill: "#ffcdd2"
    width: 40
  }
  t4: {
    label: "t3"
    shape: circle
    style.fill: "#ff8a65"
    width: 40
  }
  t1 -> t2: "child execs"
  t2 -> t3: "parent calls\nsetpgid (too late!)"
  t3 -> t4: "child in wrong\ngroup receives SIGINT"
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  solution: {
    direction: down
    label: "SOLUTION: Double setpgid()"
    parent_good: {
      label: "Parent Process"
      width: 300
      style.fill: "#e8f5e9"
      style.stroke: "#2e7d32"
      fork_good: {
        label: "fork()"
        shape: oval
        style.fill: "#c8e6c9"
      }
      setpgid_parent: {
        label: |'c
          setpgid(pid, pid);
          // May succeed or get EACCES
          // if child raced first
        '|
        shape: rectangle
        style.fill: "#a5d6a7"
        width: 220
      }
      wait_good: {
        label: "waitpid(pid, ...)"
        shape: rectangle
        style.fill: "#c8e6c9"
        width: 180
      }
      fork_good -> setpgid_parent: "child PID\nreturned"
      setpgid_parent -> wait_good: "group guaranteed\n(whichever ran first)"
    }
    child_good: {
      label: "Child Process"
      width: 300
      style.fill: "#e3f2fd"
      style.stroke: "#1565c0"
      child_fork_good: {
        label: "fork() returns 0"
        shape: oval
        style.fill: "#bbdefb"
      }
      setpgid_child: {
        label: |'c
          setpgid(0, 0);
          // 0,0 means "use my PID"
          // Child sets itself as
          // group leader
        '|
        shape: rectangle
        style.fill: "#90caf9"
        width: 220
      }
      exec_good: {
        label: "execvp(cmd, args)"
        shape: rectangle
        style.fill: "#64b5f6"
        width: 180
      }
      running_good: {
        label: "Running in\nCORRECT GROUP"
        shape: diamond
        style.fill: "#81c784"
        style.stroke: "#2e7d32"
        style.font-color: "#1b5e20"
        width: 140
      }
      child_fork_good -> setpgid_child: "immediately"
      setpgid_child -> exec_good: "group established"
      exec_good -> running_good: "exec in\ncorrect group"
    }
  }
  solution_arrow: {
    shape: text
    label: |md
      **Race Eliminated:**
      Whichever runs first
      (parent or child) creates
      the process group.
      Second call is harmless
      no-op → group already
      exists.
    |
  }
}
timeline_good: {
  label: "Timeline (Race Eliminated)"
  direction: right
  style.fill: transparent
  style.stroke: transparent
  tg1: {
    label: "t0"
    shape: circle
    style.fill: "#e0e0e0"
    width: 40
  }
  tg2: {
    label: "t1"
    shape: circle
    style.fill: "#90caf9"
    width: 40
  }
  tg3: {
    label: "t2"
    shape: circle
    style.fill: "#a5d6a7"
    width: 40
  }
  tg4: {
    label: "t3"
    shape: circle
    style.fill: "#81c784"
    width: 40
  }
  tg1 -> tg2: "child calls\nsetpgid(0,0)"
  tg2 -> tg3: "parent calls\nsetpgid(pid,pid)"
  tg3 -> tg4: "both succeed\nor one gets EACCES\n(group exists)"
}
code_block: {
  label: "Implementation Code"
  width: 700
  code: |'c
    // PARENT PROCESS (after fork)
    // Put child in its own process group
    // Use child's PID as the new PGID
    if (setpgid(child_pid, child_pid) < 0 && errno != EACCES) {
        perror("setpgid (parent)");
        // EACCES is OK: child already set the group
        // Other errors are fatal
    }
    // CHILD PROCESS (after fork, before exec)
    // ALSO call setpgid to win the race
    // 0,0 means "use my PID as PGID"
    if (setpgid(0, 0) < 0) {
        perror("setpgid (child)");
        _exit(1);
    }
    // Now safe to exec - we're in correct group
    execvp(cmd, args);
  '|
}
error_handling: {
  label: "EACCES Handling"
  width: 700
  style.fill: "#fff8e1"
  style.stroke: "#f9a825"
  explanation: |md
    **EACCES** is returned when:
    - An attempt is made to change the process group ID of one of the children
      of the calling process and the child has already performed an `execve()`
    **In our case:** If the child's `setpgid(0,0)` ran first and the child
    has already called `execvp()`, the parent's `setpgid(pid, pid)` will
    return -1 with `errno = EACCES`.
    This is **NOT an error** — the group was already established by the child!
    We only fail on other errors (EPERM, ESRCH, EINVAL).
  |
}
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: "#bdbdbd"
  l1: {
    shape: circle
    style.fill: "#ff8a65"
    width: 20
  }
  l1_label: "Race condition (bad)"
  l2: {
    shape: circle
    style.fill: "#81c784"
    width: 20
  }
  l2_label: "Correct behavior (good)"
  l1 -> l1_label
  l2 -> l2_label
}
race.parent_bad -> race.child_bad: "fork()" {style.stroke-dash: 3}
solution.parent_good -> solution.child_good: "fork()" {style.stroke-dash: 3}