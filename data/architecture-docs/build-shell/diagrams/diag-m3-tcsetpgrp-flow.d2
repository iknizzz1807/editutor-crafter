direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Terminal Control Transfer Flow
  The tcsetpgrp() Dance
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  shell_idle: {
    label: "Shell Idle"
    shape: rectangle
    width: 160
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    state: |md
      - Shell holds terminal
      - shell_pgid = tcgetpgrp()
      - Prompt displayed
    |
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  launch: {
    label: "Launch Foreground Job"
    shape: rectangle
    width: 160
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
    state: |md
      - fork() child process
      - Child: setpgid(0, 0)
      - Parent: setpgid(pid, pid)
    |
  }
}
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  setpgid_box: {
    label: "setpgid(pid, pid)"
    shape: rectangle
    width: 180
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
    }
    detail: |md
      Creates new process group
      Job's PGID = child's PID
      Child becomes group leader
    |
  }
}
row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  tcsetpgrp_give: {
    label: "tcsetpgrp(STDIN_FILENO, job_pgid)"
    shape: rectangle
    width: 240
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
    }
    detail: |md
      Transfer terminal control
      Foreground PGID = job_pgid
      SIGTTOU sent if not foreground
    |
  }
}
row5: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  waitpid_box: {
    label: "waitpid(-1, &status, WUNTRACED)"
    shape: rectangle
    width: 220
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    detail: |md
      Shell blocks waiting for:
      - Job exits (WIFEXITED)
      - Job stopped (WIFSTOPPED)
      - Signal via self-pipe
    |
  }
}
row6: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  decision: {
    label: "Job State?"
    shape: diamond
    width: 140
    style: {
      fill: "#FFFDE7"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
}
row7: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  exited: {
    label: "Exited"
    shape: oval
    width: 100
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  stopped: {
    label: "Stopped (SIGTSTP)"
    shape: oval
    width: 140
    style.fill: "#FFECB3"
    style.stroke: "#FFA000"
  }
}
row8: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  tcsetpgrp_reclaim: {
    label: "tcsetpgrp(STDIN_FILENO, shell_pgid)"
    shape: rectangle
    width: 240
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
    }
    detail: |md
      Reclaim terminal control
      Restore shell as foreground
      Ignore SIGTTOU during call
    |
  }
}
row9: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  restore: {
    label: "tcsetattr(TCSADRAIN, &saved_modes)"
    shape: rectangle
    width: 260
    style: {
      fill: "#E0F7FA"
      stroke: "#00838F"
      stroke-width: 2
    }
    detail: |md
      Restore terminal settings
      (job may have changed them)
    |
  }
}
row10: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  prompt: {
    label: "Show Prompt"
    shape: rectangle
    width: 140
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    state: |md
      - Print "$ "
      - Report background jobs
      - Ready for input
    |
  }
}
# Main flow arrows
shell_idle -> launch: "User enters\ncommand"
launch -> setpgid_box: "fork()\ncompleted"
setpgid_box -> tcsetpgrp_give: "New PGID\nestablished"
tcsetpgrp_give -> waitpid_box: "Terminal\ntransferred"
waitpid_box -> decision: "Child state\nchange"
decision -> exited: "WIFEXITED"
decision -> stopped: "WIFSTOPPED"
exited -> tcsetpgrp_reclaim: "Job done"
stopped -> tcsetpgrp_reclaim: "Job suspended"
tcsetpgrp_reclaim -> restore: "Shell regains\ncontrol"
restore -> prompt: "Terminal\nrestored"
# SIGTTOU handling box
sigttou_box: {
  label: "SIGTTOU Handling"
  width: 280
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-dash: 4
  }
  content: |md
    If shell calls tcsetpgrp() while NOT
    in foreground, kernel sends SIGTTOU.
    **Solution:** signal(SIGTTOU, SIG_IGN)
    before tcsetpgrp() calls.
    This prevents shell from being
    stopped when reclaiming terminal.
  |
}
sigttou_box.near: bottom-right
# Connection from tcsetpgrp boxes to SIGTTOU note
tcsetpgrp_give -> sigttou_box: "may trigger\nSIGTTOU" {
  style: {
    stroke-dash: 3
    stroke: "#D32F2F"
  }
}
tcsetpgrp_reclaim -> sigttou_box: "may trigger\nSIGTTOU" {
  style: {
    stroke-dash: 3
    stroke: "#D32F2F"
  }
}
# Key insight box
key_insight: {
  label: "Critical Sequence"
  width: 300
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
  }
  content: |md
    **Why the order matters:**
    1. setpgid() MUST happen before tcsetpgrp()
       — PGID must exist before we can set it as foreground
    2. Both parent AND child call setpgid()
       — Avoids race condition
    3. SIGTTOU must be ignored
       — Shell needs to call tcsetpgrp() even if not currently foreground
  |
}
key_insight.near: bottom-left
# Legend
legend: {
  label: "Flow Legend"
  width: 200
  style.fill: transparent
  solid: "───  Normal flow"
  dashed: "- - -  Error/signal path"
  solid.style.fill: transparent
  solid.shape: text
  dashed.style.fill: transparent
  dashed.shape: text
}
legend.near: top-right