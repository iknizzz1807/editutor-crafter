direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Exit Status as Boolean Semantics"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
comparison_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c_bool: {
    label: "C Language"
    shape: sql_table
    f0: "0 | false"
    f1: "1 (or any non-zero) | true"
    f2: "if (x) → true when x ≠ 0"
    note: "0 is FALSITY"
  }
  shell_bool: {
    label: "Shell / Unix"
    shape: sql_table
    f0: "0 | true / success"
    f1: "1-255 | false / failure"
    f2: "if cmd; then → true when exit 0"
    note: "0 is TRUTH"
  }
}
comparison_row -> explanation: "OPPOSITE conventions!"
explanation: {
  label: "Why if [ 0 ]; then is ALWAYS true"
  width: 500
  trace: {
    label: "Execution Trace"
    code: |'bash
# User types:
if [ 0 ]; then echo "yes"; fi
# What actually happens:
# 1. Shell parses: IF(SIMPLE_CMD([, 0, ]))
# 2. Executes condition: /usr/bin/[ with args "0" "]"
# 3. The [ command: tests if "0" is a non-empty string
# 4. "0" is non-empty → test succeeds → exits 0
# 5. Shell sees exit 0 → condition TRUE → runs then-body
# [ 0 ] does NOT test numeric zero!
# It tests: is the string "0" non-empty?
# Answer: YES → exit 0 → TRUE
    '|
    width: 480
  }
}
explanation -> true_cmd_example: "Contrast with:"
true_cmd_example: {
  label: "The true and false Commands"
  width: 500
  impl: {
    label: "Implementation (exit status only)"
    code: |'c
// /usr/bin/true
int main(void) {
    return 0;  // Exit 0 = success = TRUE
}
// /usr/bin/false  
int main(void) {
    return 1;  // Exit 1 = failure = FALSE
}
    '|
    width: 480
  }
}
true_cmd_example -> if_flow: "Flow: if true; then body; fi"
if_flow: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    label: "1. Shell sees"
    code: "if true; then echo hi; fi"
    width: 200
  }
  step2: {
    label: "2. Execute condition"
    code: "execvp(\"true\", ...)"
    width: 200
  }
  step3: {
    label: "3. true exits"
    code: "exit(0)"
    width: 150
    style.fill: "#90EE90"
  }
  step4: {
    label: "4. Shell checks"
    code: "status == 0? → YES"
    width: 180
  }
  step5: {
    label: "5. Execute body"
    code: "echo hi"
    width: 150
    style.fill: "#90EE90"
  }
}
legend: {
  near: bottom-center
  label: "Key Insight"
  insight: {
    shape: text
    label: "The shell does NOT evaluate boolean expressions. It runs COMMANDS and checks their exit status. The [ command is just a program that performs tests and exits 0 (true) or 1 (false)."
  }
}
comparison_row.c_bool.style.fill: "#FFE4E1"
comparison_row.shell_bool.style.fill: "#E0FFE0"