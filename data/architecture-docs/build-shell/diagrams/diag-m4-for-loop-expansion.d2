direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # for Loop Word List Expansion
  `for f in *.c; do echo $f; done`
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  source: {
    direction: down
    label: "Source Code"
    code: |'bash
      for f in *.c; do
          echo $f
      done
    '|
    width: 280
  }
  arrow1: {
    label: "Parse"
    shape: text
  }
  ast: {
    label: "AST Node"
    shape: class
    type: "NodeType"
    variable: "char*"
    word_list: "ASTNode*"
    body: "ASTNode*"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  expansion_box: {
    label: "Phase: Word List Expansion (ONCE)"
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    before: {
      label: "Before Expansion"
      shape: sql_table
      word: "word_list"
      value: "[\"*.c\"]"
      note: "Raw token from parser"
    }
    arrow: {
      label: "glob_expand()"
      shape: text
    }
    after: {
      label: "After Expansion"
      shape: sql_table
      word: "word_list"
      idx0: "0 | main.c"
      idx1: "1 | util.c"
      idx2: "2 | test.c"
      count: "word_count = 3"
    }
    note: |md
      **Key Insight**: Glob expansion happens
      **BEFORE** loop iteration begins.
      The pattern `*.c` is NOT re-evaluated
      on each iteration.
    |
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  iter_header: {
    label: "Iteration Loop"
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    iter_check: {
      label: "Iteration Check"
      width: 300
      code: |'c
        for (int i = 0; i < word_count; i++) {
            setenv(variable, words[i], 1);
            execute_ast(body);
        }
      '|
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  iter1: {
    label: "i = 0"
    direction: down
    style.fill: "#E3F2FD"
    assign1: {
      label: "setenv(\"f\", \"main.c\", 1)"
      shape: rectangle
      width: 200
    }
    body1: {
      label: "execute body"
      code: |'bash
        echo $f
        # Output: main.c
      '|
      width: 180
    }
    assign1 -> body1: "then"
  }
  iter2: {
    label: "i = 1"
    direction: down
    style.fill: "#E3F2FD"
    assign2: {
      label: "setenv(\"f\", \"util.c\", 1)"
      shape: rectangle
      width: 200
    }
    body2: {
      label: "execute body"
      code: |'bash
        echo $f
        # Output: util.c
      '|
      width: 180
    }
    assign2 -> body2: "then"
  }
  iter3: {
    label: "i = 2"
    direction: down
    style.fill: "#E3F2FD"
    assign3: {
      label: "setenv(\"f\", \"test.c\", 1)"
      shape: rectangle
      width: 200
    }
    body3: {
      label: "execute body"
      code: |'bash
        echo $f
        # Output: test.c
      '|
      width: 180
    }
    assign3 -> body3: "then"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output: {
    label: "Final Output"
    style.fill: "#FCE4EC"
    result: |md
      
      main.c
      util.c
      test.c
      
    |
  }
}
source -> ast: "parse"
ast -> expansion_box.before: "word_list"
expansion_box.before -> expansion_box.after: "expand"
expansion_box.after -> iter_header.iter_check: "words[]"
iter_header -> iter1: "i=0"
iter1 -> iter2: "i=1"
iter2 -> iter3: "i=2"
iter3 -> output: "done"
legend: {
  near: bottom-right
  direction: down
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  exp: "Green = Expansion Phase" {
    style.fill: "#E8F5E9"
  }
  loop: "Orange = Loop Control" {
    style.fill: "#FFF3E0"
  }
  iter: "Blue = Iteration Steps" {
    style.fill: "#E3F2FD"
  }
}