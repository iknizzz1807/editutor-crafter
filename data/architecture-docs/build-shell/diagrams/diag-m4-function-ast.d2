direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Shell Function Definition and Dispatch
  |
  near: top-center
  shape: text
  style.font-size: 32
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  def_section: {
    direction: down
    label: "Function Definition"
    func_def_node: {
      shape: sql_table
      label: "ASTNode (NODE_FUNCTION_DEF)"
      f0: "0x00 | NodeType | NODE_FUNCTION_DEF"
      f1: "0x08 | char*    | name (\"myfunc\")"
      f2: "0x10 | ASTNode* | body (→ compound_list)"
      sz: "Total: 24 bytes (plus body AST)"
    }
    func_def_node.style.fill: "#E8F4E8"
  }

  table_section: {
    direction: down
    label: "Function Table"
    func_table: {
      shape: sql_table
      label: "static Function* function_table"
      header: "Key: Name | Value: ASTNode* body"
      row1: "\"cd\" | → builtin_cd_ast"
      row2: "\"myfunc\" | → user_func_ast"
      row3: "\"helper\" | → helper_func_ast"
      note: "Linked list: Function.next pointers"
    }
    func_table.style.fill: "#FFF8E8"
  }

  def_section -> table_section: "register_function() | store name/body" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  dispatch_section: {
    direction: down
    label: "Function Invocation"
    simple_cmd: {
      shape: sql_table
      label: "ASTNode (NODE_SIMPLE_CMD)"
      f0: "0x00 | char*  | argv[0] (\"myfunc\")"
      f1: "0x08 | char** | argv[1..n] (args)"
      f2: "0x10 | int    | argc (n+1)"
    }
    simple_cmd.style.fill: "#E8E8F4"
  }

  lookup_section: {
    direction: down
    label: "Dispatch Logic"
    dispatch_decision: {
      shape: diamond
      label: "is_builtin() or find_function()?"
      width: 220
    }
    builtin_path: {
      label: "Builtins"
      shape: rectangle
    }
    func_path: {
      label: "Function Table Lookup"
      shape: rectangle
      style.fill: "#FFF8E8"
    }
    exec_path: {
      label: "execvp() PATH search"
      shape: rectangle
      style.fill: "#F4E8E8"
    }
    dispatch_decision -> builtin_path: "yes (cd, exit)" {
      style.stroke: "#1565C0"
    }
    dispatch_decision -> func_path: "yes (user funcs)" {
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
    dispatch_decision -> exec_path: "no (external)" {
      style.stroke: "#C62828"
      style.stroke-dash: 4
    }
  }

  binding_section: {
    direction: down
    label: "Parameter Binding"
    param_binding: {
      shape: sql_table
      label: "Positional Parameters"
      f0: "\$0 | char* | \"myfunc\""
      f1: "\$1 | char* | argv[1]"
      f2: "\$2 | char* | argv[2]"
      f3: "... | ... | ..."
      f4: "\$9 | char* | argv[9]"
      f5: "\$# | int | argc - 1"
      note: "Saved on call, restored on return"
    }
    param_binding.style.fill: "#F0F4FF"
  }

  execution_section: {
    direction: down
    label: "Body Execution"
    body_exec: {
      shape: rectangle
      label: "execute_ast(func->body)"
      width: 220
    }
    body_exec.style.fill: "#E8F4E8"
    return_box: {
      label: "return status"
      shape: rectangle
    }
  }
}

row1 -> row2: "User invokes myfunc" {
  style.stroke: "#666666"
  style.stroke-width: 2
}

simple_cmd -> dispatch_decision: "execute_simple_command()"
func_path -> param_binding: "Function found"
param_binding -> body_exec: "set_params()"
body_exec -> return_box: "exec_ast()"

dispatch_flow: |md
  **Dispatch Order (POSIX):**
  1. Special builtins (exit, return, break, continue)
  2. Functions (lookup in function_table)
  3. External commands (PATH search via execvp)

  **Key Insight:** Function lookup happens BEFORE PATH search. 
  A function can shadow an external command.
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#F5F5F5"
  width: 450
}

memory_layout: {
  direction: right
  label: "Memory Layout During Call"
  before_call: {
    shape: sql_table
    label: "Before Call"
    b0: "\$1..\$9 | old positional"
    b1: "depth | 0"
  }
  during_call: {
    shape: sql_table
    label: "During Call"
    d0: "\$1..\$9 | new args"
    d1: "depth | 1"
    d2: "saved_p | → old params"
  }
  after_call: {
    shape: sql_table
    label: "After Return"
    a0: "\$1..\$9 | restored"
    a1: "depth | 0"
  }
  before_call -> during_call: "call" {
    style.stroke: "#2E7D32"
  }
  during_call -> after_call: "return" {
    style.stroke: "#1565C0"
  }
}
memory_layout.near: bottom-left

code_example: {
  label: "Dispatch Logic (execute.c)"
  code: |'c
    if (is_special_builtin(argv[0])) {
        return execute_builtin(node);
    }
    Function* func = find_function(argv[0]);
    if (func != NULL) {
        // Function found - execute body
        return execute_function_call(func, argv, argc);
    }
    return execute_external(node);
  '|
  width: 420
}
code_example.near: bottom-right