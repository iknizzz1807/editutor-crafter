direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # if Statement AST and Evaluation
  `if cmd1; then cmd2; else cmd3; fi`
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  ast_section: {
    direction: down
    label: "AST Structure (parser output)"
    if_node: {
      shape: class
      label: "ASTNode (NODE_IF)"
      type: "NodeType: NODE_IF"
      condition: "ASTNode*"
      then_body: "ASTNode*"
      else_body: "ASTNode*"
    }
    if_node -> condition_node: "condition"
    if_node -> then_node: "then_body"
    if_node -> else_node: "else_body"
    condition_node: {
      shape: class
      label: "CommandNode"
      type: "NodeType: SIMPLE_CMD"
      argv: "char**"
      argc: "int"
    }
    then_node: {
      shape: class
      label: "CommandNode"
      type: "NodeType: SIMPLE_CMD"
      argv: "char**"
      argc: "int"
    }
    else_node: {
      shape: class
      label: "CommandNode"
      type: "NodeType: SIMPLE_CMD"
      argv: "char**"
      argc: "int"
    }
  }
  eval_section: {
    direction: down
    label: "Evaluation Flow (executor.c)"
    start: {
      shape: oval
      label: "execute_if(node)"
    }
    exec_cond: {
      shape: rectangle
      label: "Execute condition command"
      code: |'c
        status = execute_ast(node->condition);
        // Fork, execvp, waitpid
      '|
    }
    check_status: {
      shape: diamond
      label: "status == 0?"
    }
    exec_then: {
      shape: rectangle
      label: "Execute then_body"
      code: |'c
        return execute_ast(node->then_body);
      '|
      style.fill: "#d4edda"
    }
    exec_else: {
      shape: rectangle
      label: "Execute else_body"
      code: |'c
        return execute_ast(node->else_body);
      '|
      style.fill: "#f8d7da"
    }
    return_status: {
      shape: oval
      label: "return status"
    }
    start -> exec_cond
    exec_cond -> check_status: "WEXITSTATUS"
    check_status -> exec_then: "YES (success)"
    check_status -> exec_else: "NO (failure)"
    exec_then -> return_status
    exec_else -> return_status
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  exit_status_box: {
    label: "Exit Status Convention"
    note: |md
      **0 = success (true)**
      - Command completed without error
      - Condition "holds"
      **Non-zero = failure (false)**
      - 1: General error
      - 2: Misuse of command
      - 126: Cannot execute
      - 127: Command not found
      - 128+N: Killed by signal N
    |
  }
  code_example: {
    label: "Implementation (executor.c)"
    code: |'c
      int execute_if(ASTNode* node) {
          ASTIf* if_data = &node->data.if_stmt;
          // Execute condition command
          int status = execute_ast(if_data->condition);
          // 0 = true (success), non-zero = false
          if (status == 0) {
              // Condition succeeded
              return execute_ast(if_data->then_body);
          } else {
              // Condition failed
              if (if_data->else_body) {
                  return execute_ast(if_data->else_body);
              }
              return 0;  // No else: success
          }
      }
    '|
  }
}
legend: {
  near: bottom-center
  label: "Key Insight"
  insight: |md
    The `if` statement does **not** evaluate boolean expressions.
    It **runs commands** and checks their exit status.
    - `if cmd1` → Execute cmd1, check if it exits 0
    - `[ 5 -gt 3 ]` → The `[` command exits 0 (true)
    - `[ 3 -gt 5 ]` → The `[` command exits 1 (false)
  |
}