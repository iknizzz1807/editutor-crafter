direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # The `test` / `[` Command Internals
    **The shell doesn't evaluate conditions — it runs programs**
  |
  near: top-center
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_panel: {
    direction: down
    external_cmd: {
      label: "External Command"
      shape: rectangle
      width: 280
      binary_path: {
        shape: class
        label: "/usr/bin/[ (test.c)"
        +path: "/usr/bin/["
        +also: "/usr/bin/test"
        +type: "ELF executable"
        +size: "~60KB"
      }
      synopsis: {
        label: "Synopsis"
        shape: rectangle
        width: 260
        code: |'bash
  [ expression ]
  test expression
        '|
      }
    }
  }
  right_panel: {
    direction: down
    internal_view: {
      label: "What the Shell Sees"
      shape: rectangle
      width: 320
      parsing: {
        label: |md
          **Shell parses this:**
          bash
          if [ 5 -gt 3 ]; then ... fi
          
        |
        shape: rectangle
        width: 300
        style.fill: "#E8F4E8"
      }
      argv_array: {
        label: "argv[] passed to /usr/bin/["
        shape: sql_table
        argv0: "0 | char* | \"[\""
        argv1: "1 | char* | \"5\""
        argv2: "2 | char* | \"-gt\""
        argv3: "3 | char* | \"3\""
        argv4: "4 | char* | \"]\""
        note: "Trailing ] is REQUIRED"
      }
      exit_status: {
        label: "Exit Status"
        shape: rectangle
        width: 300
        code: |'bash
  0  = true  (condition holds)
  1  = false (condition fails)
  2  = error (invalid syntax)
        '|
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  operators: {
    label: "Supported Operators"
    shape: rectangle
    width: 900
    int_ops: {
      label: "Integer Comparison"
      shape: sql_table
      op_eq: "-eq | equal"
      op_ne: "-ne | not equal"
      op_lt: "-lt | less than"
      op_gt: "-gt | greater than"
      op_le: "-le | less or equal"
      op_ge: "-ge | greater or equal"
    }
    str_ops: {
      label: "String Comparison"
      shape: sql_table
      op_str_eq: "=  | equal"
      op_str_ne: "!= | not equal"
      op_str_z: "-z | zero length"
      op_str_n: "-n | non-zero length"
    }
    file_ops: {
      label: "File Tests"
      shape: sql_table
      op_f: "-f | regular file exists"
      op_d: "-d | directory exists"
      op_e: "-e | exists (any type)"
      op_r: "-r | readable"
      op_w: "-w | writable"
      op_x: "-x | executable"
      op_s: "-s | non-zero size"
    }
    bool_ops: {
      label: "Boolean Logic"
      shape: sql_table
      op_not: "!   | negation"
      op_and: "-a  | AND (deprecated)"
      op_or: "-o  | OR (deprecated)"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  example_flow: {
    label: "Execution Flow"
    shape: rectangle
    width: 900
    step1: {
      label: "1. User Input"
      code: |'bash
  if [ "$x" -gt 5 ]; then
      echo "big"
  fi
      '|
      width: 200
    }
    step2: {
      label: "2. Shell Parses"
      code: |'bash
  # Condition is a SIMPLE_CMD
  argv[0] = "["
  argv[1] = "$x"  # expanded!
  argv[2] = "-gt"
  argv[3] = "5"
  argv[4] = "]"
      '|
      width: 220
    }
    step3: {
      label: "3. Shell Forks & Execs"
      code: |'c
  pid = fork();
  if (pid == 0) {
      execvp("[", argv);
      // runs /usr/bin/[
  }
  waitpid(pid, &status, 0);
      '|
      width: 220
    }
    step4: {
      label: "4. [ Command Logic"
      code: |'c
  // Inside /usr/bin/[
  int a = atoi(argv[1]); // 5
  int b = atoi(argv[3]); // 5
  if (a > b) exit(0);    // true
  else exit(1);          // false
      '|
      width: 200
    }
  }
}
row1.external_cmd -> row2.operators
row2.operators -> row3.example_flow
legend: {
  near: bottom-right
  label: |md
    **Key Insight:** The `[` character is not shell syntax.
    It's an external program at `/usr/bin/[`.
    The shell just runs it and checks exit status.
  |
  shape: rectangle
  style.fill: "#FFF9E6"
  style.stroke: "#E6C200"
  width: 320
}