direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "Here-Document Variable Expansion Modes"
  shape: rectangle
  style: {
    fill: "#2C3E50"
    font-color: white
    stroke-width: 0
    border-radius: 4
  }
  note: "Comparison of shell behavior for unquoted vs. quoted delimiters"
}

modes: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  expand_mode: {
    direction: down
    label: "Expansion Mode (Default)"
    header: "Syntax: <<EOF"
    
    expand_syntax: {
      label: "Input Command"
      width: 320
      code: |'bash
        # Delimiter is NOT quoted
        cat <<EOF
        echo "User: $USER"
        echo "Home: $HOME"
        EOF
      '|
    }

    expand_desc: {
      label: "Shell Processing Logic"
      width: 320
      description: |md
        1. **Parameter Expansion**: `$VAR` replaced.
        2. **Command Substitution**: `$(cmd)` executed.
        3. **Arithmetic Expansion**: `$((1+1))` evaluated.
        4. **Escape Sequences**: `\` followed by `$`, `` ` ``, `"`, `\`, or `<newline>` is removed.
      |
    }

    expand_transform: {
      label: "Runtime Transformation"
      width: 350
      direction: down
      
      expand_before: {
        label: "Source Buffer"
        width: 300
        code: |'bash
          echo "Home: $HOME"
        '|
        style.fill: "#E8F4E8"
        style.stroke: "#4CAF50"
      }
      
      expand_after: {
        label: "Evaluated Output"
        width: 300
        code: |'bash
          echo "Home: /home/alice"
        '|
        style.fill: "#C8E6C9"
        style.stroke: "#388E3C"
        style.bold: true
      }
      
      expand_before -> expand_after: 'Expands $vars' {
        style.stroke: "#388E3C"
      }
    }

    expand_output: {
      label: "Standard Output (Stdout)"
      width: 320
      code: |'bash
        $ cat <<EOF
        > echo "Home: $HOME"
        > EOF
        echo "Home: /home/alice"
      '|
      style.fill: "#F5F5F5"
    }

    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }

  literal_mode: {
    direction: down
    label: "Literal Mode (Quoted)"
    header: "Syntax: <<'EOF'"
    
    literal_syntax: {
      label: "Input Command"
      width: 320
      code: |'bash
        # Delimiter is QUOTED
        cat <<'EOF'
        echo "User: $USER"
        echo "Home: $HOME"
        EOF
      '|
    }

    literal_desc: {
      label: "Shell Processing Logic"
      width: 320
      description: |md
        1. **No Parameter Expansion**: `$VAR` is literal.
        2. **No Subshell Execution**: `$(...)` is literal.
        3. **No Backslash Processing**: All characters preserved.
        4. **Raw Stream**: Entire body is treated as a static string.
      |
    }

    literal_transform: {
      label: "Runtime Transformation"
      width: 350
      direction: down
      
      literal_before: {
        label: "Source Buffer"
        width: 300
        code: |'bash
          echo "Home: $HOME"
        '|
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
      }
      
      literal_after: {
        label: "Static Output"
        width: 300
        code: |'bash
          echo "Home: $HOME"
        '|
        style.fill: "#FFE0B2"
        style.stroke: "#F57C00"
        style.bold: true
      }
      
      literal_before -> literal_after: 'No expansion' {
        style.stroke: "#F57C00"
      }
    }

    literal_output: {
      label: "Standard Output (Stdout)"
      width: 320
      code: |'bash
        $ cat <<'EOF'
        > echo "Home: $HOME"
        > EOF
        echo "Home: $HOME"
      '|
      style.fill: "#F5F5F5"
    }

    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
  }
}

comparison: {
  label: "POSIX Technical Implementation Matrix"
  matrix: {
    shape: sql_table
    label: "Shell Expansion Rules (Context: USER=alice)"
    h: |'Mode | Delimiter Syntax | Variable Resolution ($USER)'|
    r1: |'Expand | <<EOF | alice'|
    r2: |'Literal | <<"EOF" | $USER'|
    r3: |'Literal | <<'EOF' | $USER'|
    r4: |'Literal | <<\EOF | $USER'|
    r5: |'Literal | <<'E'OF | $USER'|
    note: "Rule: If ANY part of the delimiter is quoted, expansion is suppressed."
  }
}

implementation_guides: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  expand_use: {
    label: "Preferred for Local Scripting"
    width: 320
    cases: |md
      - Generating dynamic config files
      - Injecting Environment Variables
      - Templating SQL with current timestamps
    |
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }

  literal_use: {
    label: "Preferred for Remote Provisioning"
    width: 320
    cases: |md
      - Sending code via SSH (prevent local expansion)
      - Embedding code with $ signs (Perl, PHP, Python)
      - Writing binary-safe text streams
    |
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
  }
}

legend_box: {
  label: "POSIX.1-2017 Quoting Rules"
  content: |'md
    **Expansion Suppression Delimiters:**
    - `<<'EOF'` (Single quotes)
    - `<<"EOF"` (Double quotes)
    - `<<\EOF` (Backslash escape)
    - `<<E'O'F` (Mixed quoting)
  '|
  style.fill: "#FDFEFE"
  style.stroke: "#BDC3C7"
}
legend_box.near: bottom-right

header -> modes: "Execution Path"
modes -> comparison: "Logic Verification"
comparison -> implementation_guides: "Best Practices"