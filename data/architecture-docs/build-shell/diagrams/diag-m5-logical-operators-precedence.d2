direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    pipe: "#3B82F6"
    logical: "#8B5CF6"
    list: "#6B7280"
    exec: "#10B981"
    skip: "#EF4444"
  }
}

header: {
  label: "Logical Operator Precedence & Short-Circuit Evaluation"
  style: {
    font-size: 24
    bold: true
    stroke: transparent
    fill: transparent
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  precedence: {
    direction: down
    label: "Operator Precedence (High -> Low)"
    p1: {
      label: "| (pipe)"
      shape: rectangle
      style.fill: ${colors.pipe}
      style.font-color: white
      style.bold: true
    }
    arrow1: {
      shape: triangle
      style.fill: "#9CA3AF"
      height: 20
      width: 20
    }
    p2: {
      label: "&&  ||"
      shape: rectangle
      style.fill: ${colors.logical}
      style.font-color: white
      style.bold: true
    }
    arrow2: {
      shape: triangle
      style.fill: "#9CA3AF"
      height: 20
      width: 20
    }
    p3: {
      label: ";  &  newline"
      shape: rectangle
      style.fill: ${colors.list}
      style.font-color: white
      style.bold: true
    }
    note: {
      label: "&& and || have EQUAL precedence. Left-associative."
      shape: callout
      style.fill: "#FEF3C7"
      style.stroke: "#F59E0B"
      style.font-size: 12
    }
    p1 -> arrow1 -> p2 -> arrow2 -> p3
    p2 -> note: {
      style.stroke-dash: 3
      style.stroke: "#F59E0B"
    }
  }

  parse_tree: {
    direction: down
    label: "Parse Tree: cmd1 | cmd2 && cmd3 ; cmd4"
    tree_container: {
      root_node: {
        label: "LIST (;)"
        shape: rectangle
        style.fill: ${colors.list}
        style.font-color: white
        style.bold: true
        
        ast_left: {
          label: "AND (&&)"
          shape: rectangle
          style.fill: ${colors.logical}
          style.font-color: white
          style.bold: true
          
          pipeline: {
            label: "PIPE (|)"
            shape: rectangle
            style.fill: ${colors.pipe}
            style.font-color: white
            style.bold: true
            c1: "cmd1"
            c2: "cmd2"
            c1 -> c2: "stdout"
          }
          ast_cmd3: "cmd3"
          pipeline -> ast_cmd3: "status"
        }
        ast_cmd4: "cmd4"
        ast_left -> ast_cmd4: "status"
      }
    }
    bracket: {
      shape: rectangle
      style.fill: "#F3F4F6"
      style.stroke: "#D1D5DB"
      text: |'md
        **Parse Order:**
        1. `cmd1 | cmd2` -> pipeline
        2. `(pipeline) && cmd3` -> AND
        3. `(AND) ; cmd4` -> LIST
      '|
    }
    tree_container -> bracket: {
      style.stroke-dash: 3
      style.stroke: "#9CA3AF"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  shortcircuit: {
    direction: down
    label: "Short-Circuit Trace: false && expensive"
    
    step1: {
      label: "T1: Evaluate Left Operand"
      shape: step
      style.fill: "#E5E7EB"
      code: |'bash
        false
        # Process exits with status 1
      '|
      width: 300
    }
    
    step2: {
      label: "T2: Check && Guard"
      shape: diamond
      style.fill: ${colors.skip}
      style.font-color: white
    }

    check_note: {
      label: "Status != 0? YES (status 1) Short-circuit!"
      shape: rectangle
      style.fill: "#FEE2E2"
      style.font-color: black
      style.font-size: 11
    }
    
    step3: {
      label: "T3: SKIPPED"
      shape: step
      style.fill: "#D1FAE5"
      style.stroke: ${colors.exec}
      style.stroke-width: 2
      code: |'bash
        expensive_command
        # NO SYSCALL / NO FORK
      '|
      width: 300
    }
    
    result: {
      label: "Final Exit Status: 1"
      shape: rectangle
      style.fill: ${colors.skip}
      style.font-color: white
      style.bold: true
    }
    
    step1 -> step2 -> step3 -> result
    step2 -> check_note: { style.stroke-dash: 2 }
  }

  semantics: {
    direction: down
    label: "Short-Circuit Semantics"
    
    and_box: {
      label: "AND (&&) Control Flow"
      shape: rectangle
      style.fill: ${colors.logical}
      style.font-color: white
      note: "Success (0) -> exec next | Fail (!=0) -> skip"
    }
    
    or_box: {
      label: "OR (||) Control Flow"
      shape: rectangle
      style.fill: ${colors.logical}
      style.font-color: white
      note: "Success (0) -> skip | Fail (!=0) -> exec next"
    }
    
    implementation: {
      label: "C Logic (Simplified)"
      shape: rectangle
      style.fill: "#F3F4F6"
      body: |'c
        int exec_and(ASTNode* n) {
          int s = execute(n->left);
          return (s == 0) ? execute(n->right) : s;
        }
        int exec_or(ASTNode* n) {
          int s = execute(n->left);
          return (s != 0) ? execute(n->right) : 0;
        }
      '|
      width: 400
    }
    
    and_box -> or_box -> implementation
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  patterns: {
    direction: down
    label: "Common Usage Patterns"
    
    cond_chain: {
      label: "Conditional Chaining"
      shape: rectangle
      style.fill: "#DBEAFE"
      body: |'bash
        # Atomic dir change
        mkdir -p "$d" && cd "$d" || exit 1
      '|
      width: 350
    }
    
    guard_logic: {
      label: "Guard Logic"
      shape: rectangle
      style.fill: "#DBEAFE"
      body: |'bash
        # Exec only if file exists
        [ -f "$f" ] && process "$f"
      '|
      width: 350
    }
    
    trap_warning: {
      label: "Precedence Trap: Shell != C"
      shape: callout
      style.fill: "#FEE2E2"
      style.stroke: ${colors.skip}
      text: "Sh: a || b && c -> (a || b) && c"
    }
    
    cond_chain -> guard_logic -> trap_warning
  }

  errexit_behavior: {
    direction: down
    label: "Interaction with set -e"
    
    logic_suppression: {
      label: "errexit Suppression"
      shape: rectangle
      style.fill: "#FEF3C7"
      style.stroke: "#F59E0B"
      note: "Ignored for &&/|| left side, if/while, and ! prefix."
    }
    
    safety_example: {
      label: "Safety Example"
      shape: rectangle
      style.fill: "#F3F4F6"
      code: |'bash
        set -e
        false && echo "skip" # No exit
        if false; then :; fi  # No exit
        false # EXIT HERE
      '|
      width: 350
    }
    
    logic_suppression -> safety_example
  }
}

legend_node: {
  label: "Logic Legend"
  shape: rectangle
  style.fill: "#F9FAFB"
  
  l1: "Pipe |" { style.fill: ${colors.pipe}; style.font-color: white }
  l2: "Logical && ||" { style.fill: ${colors.logical}; style.font-color: white }
  l3: "Executed" { style.fill: ${colors.exec}; style.font-color: white }
  l4: "Skipped" { style.fill: ${colors.skip}; style.font-color: white }
}

legend_node.near: bottom-right

row1 -> row2: "Hierarchy"
row2 -> row3: "Patterns"