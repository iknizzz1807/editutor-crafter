direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "set -e Interaction with Conditionals"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  execution_trace: {
    direction: down
    label: "Execution Trace"
    step1: {
      label: "1. Shell parses set -e"
      width: 280
      code: |'bash
        shell_options.errexit = true
      '|
    }
    step2: {
      label: "2. Parse if statement"
      width: 280
      code: |'bash
        NODE_IF {
          condition: SIMPLE_CMD(false)
          then_body: SIMPLE_CMD(echo, never)
        }
      '|
    }
    step3: {
      label: "3. Execute condition (false)"
      width: 280
      code: |'c
        status = execute_ast(cond, true);
        // in_condition = true
        // false exits 1
      '|
      style.fill: "#FFF9C4"
    }
    step4: {
      label: "4. Check errexit"
      width: 280
      code: |'c
        check_errexit(1, node, true);
        // in_condition=true → SUPPRESSED
        // Shell continues!
      '|
      style.fill: "#C8E6C9"
    }
    step5: {
      label: "5. Evaluate if result"
      width: 280
      code: |'c
        if (status != 0) {
          // Skip then_body
          // No else_body
        }
        return 0; // if succeeds
      '|
    }
    result: {
      label: "Result: Shell continues normally"
      shape: diamond
      style: {
        fill: "#81C784"
        stroke: "#388E3C"
        font-color: white
        bold: true
      }
    }
    step1 -> step2 -> step3 -> step4 -> step5 -> result
  }
  suppression_rules: {
    direction: down
    label: "errexit Suppression Rules"
    rule_header: {
      label: "Commands that DO NOT trigger -e exit"
      shape: rectangle
      width: 340
      style: {
        fill: "#FFECB3"
        stroke: "#FF8F00"
        bold: true
        font-size: 16
      }
    }
    rule1: {
      shape: sql_table
      label: "Condition Positions"
      r1: "if CONDITION | Condition evaluated for truth"
      r2: "while CONDITION | Loop condition check"
      r3: "until CONDITION | Until condition check"
      r4: "elif CONDITION | Elif condition check"
    }
    rule2: {
      shape: sql_table
      label: "Logical Operators"
      r1: "LEFT && RIGHT | Left side suppressed"
      r2: "LEFT || RIGHT | Left side suppressed"
      r3: "! COMMAND | Negated command suppressed"
    }
    rule3: {
      shape: sql_table
      label: "Pipeline Exceptions"
      r1: "cmd1 | cmd2 | Only LAST cmd triggers -e"
      r2: "set -o pipefail | All stages can trigger"
    }
    rule_header -> rule1 -> rule2 -> rule3
  }
}
row1.execution_trace -> row1.suppression_rules: "referenced by" {
  style.stroke-dash: 3
  style.stroke: "#9E9E9E"
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  code_flow: {
    direction: down
    label: "Code Flow Analysis"
    source: {
      label: "Source Code"
      code: |'bash
        #!/bin/sh
        set -e           # Enable errexit
        if false; then   # false exits 1
          echo never     # NOT executed
        fi               # Shell continues!
        echo "reached"   # This prints!
      '|
      width: 300
    }
    vs_header: {
      label: "Behavior Comparison"
      shape: rectangle
      width: 600
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
        bold: true
      }
    }
    without_if: {
      direction: right
      label: ""
      box1: {
        label: "WITHOUT if wrapper"
        code: |'bash
          set -e
          false      # exits 1
          echo x     # NEVER runs
        '|
        width: 260
        style.fill: "#FFCDD2"
      }
      arrow: {
        label: "vs"
        shape: text
        style.font-size: 20
      }
      box2: {
        label: "WITH if wrapper"
        code: |'bash
          set -e
          if false; then
            echo x
          fi          # continues
          echo y      # RUNS
        '|
        width: 260
        style.fill: "#C8E6C9"
      }
      box1 -> arrow -> box2
    }
    source -> vs_header -> without_if
  }
  impl_detail: {
    direction: down
    label: "Implementation Detail"
    check_func: {
      shape: class
      label: "check_errexit (executor.c)"
      -status: "int"
      -node: "ASTNode*"
      -in_condition: "bool"
      +check_errexit(s, n, ic): "void"
    }
    logic: {
      label: "Suppression Logic"
      code: |'c
        void check_errexit(int status, ASTNode* node, 
                           bool in_condition) {
          if (!shell_options.errexit) return;
          if (status == 0) return;
          // Check suppression conditions
          if (in_condition) return;  // if/while
          if (node->type == NODE_AND) return;
          if (node->type == NODE_OR) return;
          // Not suppressed: EXIT shell
          exit(status);
        }
      '|
      width: 340
    }
    insight: {
      label: "Key Insight"
      shape: callout
      width: 340
      style.fill: "#E1BEE7"
    }
    insight: |md
      In conditionals, **failure is information, not error**.
      The `if` statement needs to know if the condition
      succeeded or failed — both are valid outcomes.
    |
    check_func -> logic -> insight
  }
}
row2.code_flow -> row2.impl_detail
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  l1: "Suppressed" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  l2: "Evaluated" {
    shape: rectangle
    style.fill: "#FFF9C4"
  }
  l3: "Triggers exit" {
    shape: rectangle
    style.fill: "#FFCDD2"
  }
}