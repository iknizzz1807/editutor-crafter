direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    lexer_fill: "#E3F2E7"
    parser_fill: "#FFF3E0"
    executor_fill: "#E8F5E8"
    ast_fill: "#F5E0E8"
    jobs_fill: "#E0F8F1"
    signals_fill: "#FFFACD"
    terminal_fill: "#E6E6E6"
  }
}

title: {
  label: "set -x Tracing Implementation (shell.c)"
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}

shell_core: {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  frontend: "Frontend (Pipeline)" {
    direction: down
    lexer_box: {
      shape: class
      label: "Lexer (lexer.c)"
      style.fill: ${colors.lexer_fill}
      -input: "char*"
      -pos: "size_t"
      -len: "size_t"
      -state: "LexerState"
      -current_token: "char*"
      -token_capacity: "size_t"
      +lexer_next_token(l): "Token"
    }

    parser_box: {
      shape: class
      label: "Parser (parser.c)"
      style.fill: ${colors.parser_fill}
      -lexer: "Lexer*"
      -current_type: "TokenType"
      -current_value: "char*"
      -has_error: "bool"
      +parse_command_line(p): "Node*"
      +parse_pipeline(p): "Node*"
    }
  }

  middle: "Execution Logic" {
    direction: down
    ast_box: {
      shape: class
      label: "AST (ast.c)"
      style.fill: ${colors.ast_fill}
      +NODE_SIMPLE_CMD: "Simple Command"
      +NODE_PIPELINE: "Pipeline"
      +NODE_LIST: "Command List"
      +NODE_BACKGROUND: "Background (&)"
      +NODE_IF: "if Statement"
    }

    executor_box: {
      shape: class
      label: "Executor (executor.c)"
      style.fill: ${colors.executor_fill}
      -last_exit_status: "int"
      -shell_pid: "pid_t"
      -job_table: "Job*"
      +execute_node(node): "int"
      +execute_simple_cmd(cmd): "int"
      -print_trace(argv): "void"
    }
  }

  backend: "OS Integration" {
    direction: down
    job_table_box: {
      shape: class
      label: "Job Table (jobs.c)"
      style.fill: ${colors.jobs_fill}
      -job_list: "Job*"
      -next_job_id: "int"
      +job_add(pgid, cmd): "Job*"
      +job_update_status(pid, status): "void"
    }

    signal_handler: {
      shape: class
      label: "Signal Handler (signals.c)"
      style.fill: ${colors.signals_fill}
      -sig_pipe: "int[2]"
      +init_signals(): "void"
      +handle_child(sig): "void"
    }

    terminal_control: {
      shape: class
      label: "Terminal Control (terminal.c)"
      style.fill: ${colors.terminal_fill}
      -shell_pgid: "pid_t"
      -saved_modes: "struct termios"
      +give_terminal_to(pgid): "void"
    }
  }
}

# Implementation details for Tracing (Below the core architecture)
implementation_section: {
  style.fill: transparent
  style.stroke: transparent
  
  trace_implementation: {
    label: "Trace Printing Logic (executor.c:64)"
    code: |'c
      void print_trace(char** argv) {
          if (!shell_flags.xtrace) return;
          fprintf(stderr, "+");
          for (int i = 0; argv[i]; i++) {
              fprintf(stderr, " %s", argv[i]);
          }
          fprintf(stderr, "\n");
      }
    '|
    width: 400
  }
}

# Flow Connections
shell_core.frontend.lexer_box -> shell_core.frontend.parser_box: "TokenStream"
shell_core.frontend.parser_box -> shell_core.middle.ast_box: "AST nodes"
shell_core.middle.ast_box -> shell_core.middle.executor_box: "Node*"
shell_core.middle.executor_box -> implementation_section.trace_implementation: "argv if set -x"

shell_core.middle.executor_box -> shell_core.backend.job_table_box: "fork/exec"
shell_core.middle.executor_box -> shell_core.backend.signal_handler: "setup"
shell_core.middle.executor_box -> shell_core.backend.terminal_control: "tcsetpgrp"

shell_core.backend.signal_handler -> shell_core.backend.job_table_box: "SIGCHLD"
shell_core.backend.signal_handler -> shell_core.backend.terminal_control: "restore"

legend: {
  label: "Legend: xtrace Implementation"
  note: "set -x logic resides in executor_box::print_trace"
}
legend.near: bottom-right