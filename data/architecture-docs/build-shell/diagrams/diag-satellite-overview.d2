direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Shell Architecture Satellite Map
  System-wide view of all shell subsystems and their interactions
| {near: top-center}

row_happy_path: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  lexer: {
    direction: down
    label: "Lexer Subsystem\n(lexer.c)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    input: {
      shape: rectangle
      label: "Input Stream"
      width: 120
    }
    state_machine: {
      shape: rectangle
      label: "State Machine\nLEX_DEFAULT\nLEX_IN_SINGLE_QUOTE\nLEX_IN_DOUBLE_QUOTE\nLEX_IN_ESCAPE"
      width: 160
    }
    tokens: {
      shape: rectangle
      label: "Token Stream\nTOK_WORD, TOK_PIPE\nTOK_REDIR_*, TOK_IF\nTOK_WHILE, TOK_FOR"
      width: 140
    }
    input -> state_machine: "char by char"
    state_machine -> tokens: "TokenType + value"
    link: "layers.lexer_detail"
  }

  parser: {
    direction: down
    label: "Parser Subsystem\n(parser.c)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    token_stream: {
      shape: rectangle
      label: "Token Stream"
      width: 100
    }
    recursive_descent: {
      shape: rectangle
      label: "Recursive Descent\nparse_list()\nparse_background()\nparse_pipeline()\nparse_simple_cmd()"
      width: 150
    }
    ast_nodes: {
      shape: rectangle
      label: "AST Nodes\nNODE_SIMPLE_CMD\nNODE_PIPELINE\nNODE_IF, NODE_WHILE\nNODE_SUBSHELL"
      width: 140
    }
    token_stream -> recursive_descent: "consume"
    recursive_descent -> ast_nodes: "build tree"
    link: "layers.parser_detail"
  }

  executor: {
    direction: down
    label: "Executor Subsystem\n(executor.c)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    ast_input: {
      shape: rectangle
      label: "AST Root"
      width: 80
    }
    dispatcher: {
      shape: rectangle
      label: "Node Dispatcher\nswitch(node->type)\nexecute_*()"
      width: 130
    }
    process_ops: {
      shape: rectangle
      label: "Process Ops\nfork/exec/wait\ndup2, pipe\ntcsetpgrp"
      width: 120
    }
    ast_input -> dispatcher: "walk tree"
    dispatcher -> process_ops: "system calls"
    link: "layers.executor_detail"
  }
}

row_happy_path.lexer.tokens -> row_happy_path.parser.token_stream: "TokenType[]"
row_happy_path.parser.ast_nodes -> row_happy_path.executor.ast_input: "ASTNode*"

row_transform: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  expander: {
    direction: down
    label: "Expander Layer\n(expander.c)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    raw_word: {
      shape: rectangle
      label: "Raw Word\n\"\$HOME/*.txt\""
      width: 120
    }
    pipeline_phases: {
      shape: rectangle
      label: "6-Phase Pipeline\n1. Tilde ~\n2. Parameter \$VAR\n3. Cmd Subst \$(...)\n4. Field Split\n5. Glob *\n6. Quote Remove"
      width: 160
    }
    expanded: {
      shape: rectangle
      label: "Expanded Args\n[\"/home/user\", \"/home/user/a.txt\", \"/home/user/b.txt\"]"
      width: 180
    }
    raw_word -> pipeline_phases: "transform"
    pipeline_phases -> expanded: "char**"
    link: "layers.expander_detail"
  }
}

row_async: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  job_control: {
    direction: down
    label: "Job Control\n(job.c)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    job_table: {
      shape: class
      label: "Job Table"
      job_id: "int"
      pgid: "pid_t"
      state: "JobState"
      command: "char*"
      is_foreground: "bool"
    }
    job_ops: {
      shape: rectangle
      label: "Operations\ncreate_job()\nfind_job_by_*()\nremove_job()\ncleanup_done()"
      width: 140
    }
    builtins_jobs: {
      shape: rectangle
      label: "Builtins\nfg %1\nbg %1\njobs"
      width: 100
    }
    job_table -> job_ops
    job_ops -> builtins_jobs
    link: "layers.job_control_detail"
  }

  signals: {
    direction: down
    label: "Signal Handling\n(signal.c)"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    sigchld: {
      shape: rectangle
      label: "SIGCHLD Handler\n(Async-Signal-Safe)\nwrite(pipe[1], 'C', 1)"
      width: 160
    }
    self_pipe: {
      shape: rectangle
      label: "Self-Pipe Trick\npipe[0] → select()\npipe[1] ← handler"
      width: 130
    }
    reap: {
      shape: rectangle
      label: "Reap Children\nwaitpid(-1, WNOHANG)\nLoop until 0"
      width: 140
    }
    sigchld -> self_pipe: "notify"
    self_pipe -> reap: "safe context"
    link: "layers.signal_detail"
  }

  terminal: {
    direction: down
    label: "Terminal Control\n(terminal.c)"
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    process_groups: {
      shape: rectangle
      label: "Process Groups\nsetpgid(pid, pgid)\ngetpgid(pid)"
      width: 140
    }
    tc_transfer: {
      shape: rectangle
      label: "Terminal Transfer\ntcsetpgrp(fd, pgid)\ntcgetattr/tcsetattr"
      width: 150
    }
    modes: {
      shape: rectangle
      label: "Terminal Modes\nstruct termios\nsave/restore"
      width: 130
    }
    process_groups -> tc_transfer: "foreground"
    tc_transfer -> modes: "preserve"
    link: "layers.terminal_detail"
  }
}

row_control_flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  control_flow: {
    direction: down
    label: "Control Flow AST\n(control.c)"
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    if_node: {
      shape: sql_table
      label: "NODE_IF"
      cond: "condition | ASTNode*"
      then: "then_body | ASTNode*"
      else: "else_body | ASTNode*"
    }
    while_node: {
      shape: sql_table
      label: "NODE_WHILE"
      cond: "condition | ASTNode*"
      body: "body | ASTNode*"
      is_until: "is_until | bool"
    }
    for_node: {
      shape: sql_table
      label: "NODE_FOR"
      var: "variable | char*"
      words: "word_list | ASTNode*"
      body: "body | ASTNode*"
    }
    link: "layers.control_flow_detail"
  }

  functions: {
    direction: down
    label: "Shell Functions\n(function.c)"
    style.fill: "#FBE9E7"
    style.stroke: "#FF5722"
    func_def: {
      shape: sql_table
      label: "Function Definition"
      name: "name | char*"
      body: "body | ASTNode*"
      next: "next | Function*"
    }
    scope: {
      shape: rectangle
      label: "Dynamic Scope\nlocal vars stack\npositional params \$1-\$9"
      width: 150
    }
    func_def -> scope: "isolation"
    link: "layers.function_detail"
  }
}

row_advanced: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  subshell: {
    direction: down
    label: "Subshell & Groups\n(subshell.c)"
    style.fill: "#F1F8E9"
    style.stroke: "#8BC34A"
    subshell_node: {
      shape: rectangle
      label: "NODE_SUBSHELL ( )\nfork() → isolated\nchild executes\n_exit(status)"
      width: 140
    }
    brace_node: {
      shape: rectangle
      label: "NODE_BRACE_GROUP { }\nNo fork\nIn-place execution\nChanges persist"
      width: 150
    }
    link: "layers.subshell_detail"
  }

  logical: {
    direction: down
    label: "Logical Operators\n(logical.c)"
    style.fill: "#EDE7F6"
    style.stroke: "#673AB7"
    and_node: {
      shape: rectangle
      label: "NODE_AND (&&)\nShort-circuit\nLeft fails → skip right"
      width: 140
    }
    or_node: {
      shape: rectangle
      label: "NODE_OR (||)\nShort-circuit\nLeft succeeds → skip right"
      width: 150
    }
    link: "layers.logical_detail"
  }

  heredoc: {
    direction: down
    label: "Here-Documents\n(heredoc.c)"
    style.fill: "#FFFDE7"
    style.stroke: "#FFEB3B"
    heredoc_struct: {
      shape: sql_table
      label: "HereDoc"
      delim: "delimiter | char*"
      content: "content | char*"
      expand: "expand_vars | bool"
      strip: "strip_tabs | bool"
    }
    pipe_impl: {
      shape: rectangle
      label: "Pipe Implementation\nNo temp files\nwrite(pipe[1], content)\ndup2(pipe[0], stdin)"
      width: 160
    }
    heredoc_struct -> pipe_impl
    link: "layers.heredoc_detail"
  }
}

row_happy_path.lexer -> row_transform.expander: "TOK_WORD\nneeds expansion"
row_transform.expander -> row_happy_path.executor: "expanded\nargv[]"
row_happy_path.executor -> row_async.job_control: "create_job(pgid,\ncmd, foreground)"
row_async.job_control -> row_async.terminal: "tcsetpgrp for\nforeground jobs"
row_async.signals -> row_async.job_control: "SIGCHLD →\nupdate job state"
row_async.terminal -> row_async.signals: "SIGTTOU\nignored"
row_happy_path.executor -> row_control_flow.control_flow: "execute_if()\nexecute_while()\nexecute_for()"
row_control_flow.control_flow -> row_control_flow.functions: "function calls"
row_happy_path.executor -> row_advanced.subshell: "execute_subshell()\nexecute_brace_group()"
row_happy_path.executor -> row_advanced.logical: "execute_and()\nexecute_or()"
row_happy_path.executor -> row_advanced.heredoc: "apply_heredocs()"

legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  title: "Subsystem Links"
  detail_link: {
    shape: rectangle
    label: "Each box links to\ndetailed diagram\nvia layers.*"
    width: 140
  }
  flow: {
    shape: rectangle
    label: "Arrows show data\nflow and control\ndependencies"
    width: 130
  }
}

layers: {
  lexer_detail: {
    label: Lexer State Machine
    direction: down
    states: {
      label: "Lexer States"
      default: "LEX_DEFAULT"
      single: "LEX_IN_SINGLE_QUOTE"
      double: "LEX_IN_DOUBLE_QUOTE"
      escape: "LEX_IN_ESCAPE"
    }
    transitions: {
      label: "State Transitions"
      code: |'c
        ' -> LEX_IN_SINGLE_QUOTE
        " -> LEX_IN_DOUBLE_QUOTE
        \  -> LEX_IN_ESCAPE
        ' inside ' -> LEX_DEFAULT
        " inside " -> LEX_DEFAULT
        any after \ -> LEX_DEFAULT
      '|
    }
  }
  parser_detail: {
    label: Parser Precedence
    direction: down
    precedence: {
      label: "Operator Precedence (lowest to highest)"
      list: "1. ; newline (list)"
      background: "2. & (background)"
      logical: "3. && || (logical)"
      pipeline: "4. | (pipeline)"
      primary: "5. commands, ( ), { }"
    }
  }
  executor_detail: {
    label: Executor Dispatch
    direction: down
    dispatch: |'c
      switch (node->type) {
        case NODE_SIMPLE_CMD:
          return execute_simple_command(node);
        case NODE_PIPELINE:
          return execute_pipeline(node);
        case NODE_SUBSHELL:
          return execute_subshell(node);
        case NODE_IF:
          return execute_if(node);
        // ... etc
      }
    '|
  }
  expander_detail: {
    label: Expansion Phases
    direction: down
    phases: {
      p1: "1. Tilde: ~ → \$HOME"
      p2: "2. Parameter: \$VAR → value"
      p3: "3. Command: \$(cmd) → output"
      p4: "4. Field Split: IFS"
      p5: "5. Glob: * → filenames"
      p6: "6. Quote Removal"
    }
  }
  job_control_detail: {
    label: Job State Machine
    direction: down
    states: {
      running: "JOB_RUNNING"
      stopped: "JOB_STOPPED (Ctrl+Z)"
      done: "JOB_DONE (exit)"
    }
    running -> stopped: "SIGTSTP"
    stopped -> running: "SIGCONT (fg/bg)"
    running -> done: "exit/signal"
  }
  signal_detail: {
    label: Signal Handling
    direction: down
    handler: |'c
      void sigchld_handler(int sig) {
        char c = 'C';
        write(signal_pipe[1], &c, 1);
      }
    '|
  }
  terminal_detail: {
    label: Terminal Control
    direction: down
    flow: |'c
      // Give terminal to job
      tcsetpgrp(STDIN_FILENO, job_pgid);
      // Wait for job
      // Take terminal back
      tcsetpgrp(STDIN_FILENO, shell_pgid);
      tcsetattr(STDIN_FILENO, TCSADRAIN, 
                &shell_terminal_modes);
    '|
  }
  control_flow_detail: {
    label: Control Flow Execution
    direction: down
    if_exec: |'c
      int execute_if(ASTNode* node) {
        int status = execute_ast(condition);
        if (status == 0) {
          return execute_ast(then_body);
        } else if (else_body) {
          return execute_ast(else_body);
        }
        return 0;
      }
    '|
  }
  function_detail: {
    label: Function Scope
    direction: down
    scope_info: |md
      **Dynamic Scoping**
      - `local` creates stack entry
      - Variables restored on return
      - $1, $2, ... are positional params
    |
  }
  subshell_detail: {
    label: Subshell vs Brace
    direction: down
    comparison: |md
      **Subshell ( )**: Fork → isolated
      - cd, export, variables: NOT visible
      - File offsets: SHARED
      **Brace { }**: No fork
      - All changes persist
    |
  }
  logical_detail: {
    label: Short-Circuit Eval
    direction: down
    logic: |'c
      // && : right only if left == 0
      if (execute_ast(left) == 0)
        return execute_ast(right);
      // || : right only if left != 0
      if (execute_ast(left) != 0)
        return execute_ast(right);
    '|
  }
  heredoc_detail: {
    label: Here-Doc Implementation
    direction: down
    impl: |'c
      pipe(pipefd);
      write(pipefd[1], content, len);
      close(pipefd[1]);
      dup2(pipefd[0], STDIN_FILENO);
      close(pipefd[0]);
    '|
  }
}