    }
    heredoc_funcs: {
      shape: class
      label: "Here-Document Functions"
      +heredoc_create(delimiter, quoted, strip): "HereDoc*"
      +heredoc_append_line(hd, line): "int"
      +heredoc_finalize(hd): "void"
      +heredoc_free(hd): "void"
      +apply_heredocs(heredocs, state): "int"
      +heredoc_expand_content(content, state): "char*"
      +parse_heredoc(p, cmd_node): "int"
      +read_heredoc_content(p, hd): "int"
    }
    heredoc_syntax: {
      shape: sql_table
      label: "Here-Document Syntax"
      basic: "<<EOF | Expand vars"
      quoted: "<<'EOF' | Literal"
      strip: "<<-EOF | Strip tabs"
      here_string: "<<< word | Single line"
    }
  }
  layer_options: {
    direction: down
    label: "SHELL OPTIONS  (60_shell_options.h - 63_xtrace.c)  [M5]"
    shell_options: {
      shape: class
      label: "struct ShellOptions"
      +errexit: "bool"
      +xtrace: "bool"
      +verbose: "bool"
      +nounset: "bool"
      +pipefail: "bool"
      +ignoreeof: "bool"
      +monitor: "bool"
      +posix: "bool"
      sz: "Total: 8 bytes"
    }
    errexit: {
      shape: class
      label: "set -e (errexit)"
      +g_errexit_context: "ErrexitContext"
      +check_errexit(status, node, state): "void"
      +errexit_push(ctx): "ErrexitContext"
      +errexit_pop(prev): "void"
      suppressed: "Suppressed in conditions"
    }
    xtrace: {
      shape: class
      label: "set -x (xtrace)"
      +trace_command(node): "void"
      +ast_to_string(node): "char*"
      +needs_quoting(word): "bool"
      prefix: "PS4 (default: '+ ')"
    }
    options_enum: {
      shape: sql_table
      label: "enum ErrexitContext"
      normal: "0 | Errexit active"
      condition: "1 | In if/while condition"
      logical: "2 | In && or || operand"
      negated: "3 | After ! operator"
    }
  }
  layer_shell_state: {
    direction: down
    label: "SHELL STATE  (12_shell.h, 13_shell.c)  [M1]"
    shell_state: {
      shape: class
      label: "struct ShellState"
      +last_exit_status: "int"
      +shell_pid: "pid_t"
      +interactive: "bool"
      +original_tmodes: "struct termios"
      +script_name: "char*"
    }
    shell_funcs: {
      shape: class
      label: "Shell Functions"
      +shell_init(argc, argv): "ShellState"
      +shell_run_interactive(state): "int"
      +shell_run_script(state, filename): "int"
      +shell_cleanup(state): "void"
    }
    repl: {
      shape: sql_table
      label: "REPL Loop"
      step1: "1. Print prompt"
      step2: "2. Read line (getline)"
      step3: "3. Lex + Parse"
      step4: "4. Execute AST"
      step5: "5. Update last_exit_status"
      step6: "6. Free AST, repeat"
    }
  }
}
