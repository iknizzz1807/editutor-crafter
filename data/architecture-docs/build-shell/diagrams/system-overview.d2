      -error_message: "char*"
      -error_line: "int"
      -error_column: "int"
      +parser_create(lexer): "Parser"
      +parser_destroy(parser): "void"
      +parser_parse(parser): "ASTNode*"
      +parser_has_error(parser): "bool"
      +parser_error_message(parser): "const char*"
    }
    parser_layout: {
      shape: sql_table
      label: "Parser Memory Layout"
      lexer: "0x00 | Lexer* | 8 bytes"
      current_type: "0x08 | TokenType | 4 bytes"
      current_value: "0x10 | char* | 8 bytes"
      has_error: "0x18 | bool | 1 byte"
      error_message: "0x20 | char* | 8 bytes"
      error_line: "0x28 | int | 4 bytes"
      error_column: "0x2C | int | 4 bytes"
      sz: "Total: 48 bytes"
    }
    parse_funcs: {
      shape: class
      label: "Parser Functions"
      +parse_list(p): "ASTNode*"
      +parse_pipeline(p): "ASTNode*"
      +parse_simple_command(p): "ASTNode*"
      +parse_if(p): "ASTNode*  [M4]"
      +parse_while(p, is_until): "ASTNode*  [M4]"
      +parse_for(p): "ASTNode*  [M4]"
      +parse_subshell(p): "ASTNode*  [M5]"
      +parse_brace_group(p): "ASTNode*  [M5]"
      +parse_logical_expr(p): "ASTNode*  [M5]"
    }
  }
  layer_executor: {
    direction: down
    label: "EXECUTOR  (08_executor.h, 09_executor.c)  [M1-M5]"
    executor: {
      shape: class
      label: "Execution Functions"
      +execute_ast(node, state): "int"
      +execute_simple_command(node, state): "int"
      +execute_pipeline(node, state): "int  [M2]"
      +execute_if(node, state): "int  [M4]"
      +execute_while(node, state): "int  [M4]"
      +execute_for(node, state): "int  [M4]"
      +execute_subshell(node, state): "int  [M5]"
      +execute_brace_group(node, state): "int  [M5]"
      +execute_and(node, state): "int  [M5]"
      +execute_or(node, state): "int  [M5]"
      +is_builtin(name): "bool"
      +execute_builtin(argv, state): "int"
    }
    fork_exec: {
      shape: class
      label: "fork/exec/wait Pattern"
      +fork(): "pid_t"
      +execvp(cmd, argv): "void"
      +waitpid(pid, status, opts): "pid_t"
      +dup2(oldfd, newfd): "int"
      +_exit(status): "void  CRITICAL"
      note1: "Use _exit() in child after exec fail"
      note2: "exit() flushes parent's buffers"
    }
  }
  layer_builtins: {
    direction: down
    label: "BUILTINS  (10_builtins.h, 11_builtins.c)  [M1-M5]"
    builtin_registry: {
      shape: sql_table
      label: "Builtin Registry"
      cd: "builtin_cd | Changes cwd"
      exit: "builtin_exit | Terminates shell"
      export: "builtin_export | Sets env var"
      pwd: "builtin_pwd | Prints cwd"
      unset: "builtin_unset | Removes env var"
      jobs: "builtin_jobs | Lists jobs  [M3]"
      fg: "builtin_fg | Foreground job  [M3]"
      bg: "builtin_bg | Background job  [M3]"
      break: "builtin_break | Exit loop  [M4]"
      continue: "builtin_continue | Next iter  [M4]"
      return: "builtin_return | Func exit  [M4]"
      local: "builtin_local | Local var  [M4]"
      set: "builtin_set_extended | Options  [M5]"
      true: "builtin_true | Returns 0  [M4]"
      false: "builtin_false | Returns 1  [M4]"
    }
    builtin_struct: {
      shape: class
      label: "struct Builtin"
      +name: "const char*"
      +func: "int (*)(char**, ShellState*)"
      +help_text: "const char*"
    }
  }
}
