layer_executor -> layer_signal: "setup_shell_signals()  [M3]"
layer_executor -> layer_jobctrl: "create_process_group()  [M3]"
layer_signal -> layer_jobtable: "reap_children()"
layer_jobtable -> layer_jobctrl: "Job updates"
layer_function -> layer_localvars: "local_mark/pop"
layer_function -> layer_positional: "positional_save/restore"
layer_script -> layer_parser: "Parse each line"
layer_heredoc -> layer_executor: "apply_heredocs()  [M5]"
layer_options -> layer_executor: "check_errexit()  [M5]"
