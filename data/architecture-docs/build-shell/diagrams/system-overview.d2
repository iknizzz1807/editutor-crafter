row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_types: {
    direction: down
    label: "TYPES & ENUMS  (01_types.h)  [M1]"
    token_type: {
      shape: sql_table
      label: "enum TokenType"
      TOK_WORD: "0 | Regular word"
      TOK_PIPE: "1 | |"
      TOK_REDIR_IN: "2 | <"
      TOK_REDIR_OUT: "3 | >"
      TOK_REDIR_APPEND: "4 | >>"
      TOK_REDIR_ERR: "5 | 2>"
      TOK_AMPERSAND: "6 | &"
      TOK_SEMICOLON: "7 | ;"
      TOK_NEWLINE: "8 | \\n"
      TOK_LPAREN: "9 | ("
      TOK_RPAREN: "10 | )"
      TOK_IF: "11 | if keyword"
      TOK_WHILE: "12 | while keyword"
      TOK_FOR: "13 | for keyword"
      TOK_EOF: "28 | End of input"
      sz: "Total: 4 bytes (int32)"
    }
    lexer_state: {
      shape: sql_table
      label: "enum LexerState"
      LEX_DEFAULT: "0 | Normal state"
      LEX_IN_SINGLE_QUOTE: "1 | Inside '...'"
      LEX_IN_DOUBLE_QUOTE: "2 | Inside \"...\""
      LEX_IN_ESCAPE: "3 | After backslash"
      sz: "Total: 4 bytes (int32)"
    }
    node_type: {
      shape: sql_table
      label: "enum NodeType"
      NODE_SIMPLE_CMD: "0 | ls -la"
      NODE_PIPELINE: "1 | cmd1 | cmd2"
      NODE_LIST: "2 | cmd1 ; cmd2"
      NODE_BACKGROUND: "3 | cmd &"
      NODE_IF: "4 | if/elif/else/fi"
      NODE_WHILE: "5 | while/until loop"
      NODE_FOR: "6 | for loop"
      NODE_SUBSHELL: "7 | (cmd)"
      NODE_BRACE_GROUP: "8 | { cmd; }"
      NODE_AND: "9 | && operator"
      NODE_OR: "10 | || operator"
      NODE_FUNCTION_DEF: "11 | name() { }"
      sz: "Total: 4 bytes (int32)"
    }
    job_state: {
      shape: sql_table
      label: "enum JobState  [M3]"
      JOB_RUNNING: "0 | Currently executing"
      JOB_STOPPED: "1 | Suspended (SIGTSTP)"
      JOB_DONE: "2 | Terminated"
      sz: "Total: 4 bytes (int32)"
    }
  }
  layer_lexer: {
    direction: down
    label: "LEXER  (02_lexer.h, 03_lexer.c)  [M1]"
    lexer: {
      shape: class
      label: "struct Lexer"
      -input: "const char*"
      -pos: "size_t"
      -len: "size_t"
      -state: "LexerState"
      -current_token: "char*"
      -token_capacity: "size_t"
      -token_len: "size_t"
      -line_number: "int"
      -column: "int"
      +lexer_create(input, len): "Lexer"
      +lexer_destroy(lexer): "void"
      +lexer_next_token(lexer, type, value): "int"
      +lexer_peek(lexer): "char"
      +lexer_at_end(lexer): "bool"
    }
    lexer_layout: {
      shape: sql_table
      label: "Lexer Memory Layout (64-bit)"
      input: "0x00 | char* | 8 bytes"
      pos: "0x08 | size_t | 8 bytes"
      len: "0x10 | size_t | 8 bytes"
      state: "0x18 | LexerState | 4 bytes"
      current_token: "0x20 | char* | 8 bytes"
      token_capacity: "0x28 | size_t | 8 bytes"
      token_len: "0x30 | size_t | 8 bytes"
      line_number: "0x38 | int | 4 bytes"
      column: "0x3C | int | 4 bytes"
      sz: "Total: 64 bytes (1 cache line)"
    }
  }
  layer_ast: {
    direction: down
    label: "AST NODES  (06_ast.h, 06_ast.c)  [M1-M5]"
    ast_node: {
      shape: class
      label: "struct ASTNode"
      +type: "NodeType"
      +flags: "uint32_t"
      +data.cmd: "SimpleCommand"
      +data.pipeline: "Pipeline"
      +data.list: "CommandList"
      +data.if_stmt: "ASTIf"
      +data.while_loop: "ASTWhile"
      +data.for_loop: "ASTFor"
      +data.unary: "ASTUnary"
      +data.binary: "ASTBinary"
      +ast_create_node(type): "ASTNode*"
      +ast_free(node): "void"
      +ast_create_simple_command(): "ASTNode*"
      +ast_add_argument(node, arg): "int"
      +ast_add_redirect(node, type, target): "int"
    }
    ast_layout: {
      shape: sql_table
      label: "ASTNode Memory Layout"
      type: "0x00 | NodeType | 4 bytes"
      flags: "0x04 | uint32_t | 4 bytes"
      data_union: "0x08 | union | 24 bytes max"
      sz: "Total: 32 bytes (half cache line)"
    }
    simple_cmd: {
      shape: class
      label: "struct SimpleCommand"
      +argv: "char**"
      +argc: "int"
      +argv_capacity: "int"
      +redirects: "Redirect*"
      +heredocs: "HereDoc*  [M5]"
      sz: "Total: 24 bytes"
    }
    redirect: {
      shape: class
      label: "struct Redirect"
      +type: "RedirectType"
      +target: "char*"
      +source_fd: "int"
      +next: "Redirect*"
      sz: "Total: 24 bytes"
    }
  }
}
row2: "" {
