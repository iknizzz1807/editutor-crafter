vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

direction: right

title: |md
  # Lexer State Machine: Shell Quote Handling
  ## Implementation Specification for Lexical Analysis Logic
  *State transitions, invariants, and escape sequence handling.*
| {near: top-center}

# -----------------------------------------------------------------------------
# STATE DEFINITIONS
# -----------------------------------------------------------------------------

LEX_DEFAULT: {
  label: "LEX_DEFAULT\n(State ID: 0x01)"
  shape: circle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 4
    font-color: "#1B5E20"
    bold: true
  }
  tooltip: "Standard tokenization mode. Recognizes whitespace separators and operators."
}

LEX_IN_SINGLE_QUOTE: {
  label: "LEX_IN_SINGLE_QUOTE\n(State ID: 0x02)"
  shape: circle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 4
    font-color: "#0D47A1"
    bold: true
  }
  tooltip: "Inside single quotes. Variable expansion and backslash escapes are disabled."
}

LEX_IN_DOUBLE_QUOTE: {
  label: "LEX_IN_DOUBLE_QUOTE\n(State ID: 0x03)"
  shape: circle
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 4
    font-color: "#BF360C"
    bold: true
  }
  tooltip: "Inside double quotes. Variables (\$) are expanded; specific characters are escapable."
}

LEX_IN_ESCAPE: {
  label: "LEX_IN_ESCAPE\n(State ID: 0x04)"
  shape: circle
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 4
    font-color: "#4A148C"
    bold: true
  }
  tooltip: "Escaped character mode. The subsequent character is treated as a literal."
}

# -----------------------------------------------------------------------------
# STATE TRANSITIONS
# -----------------------------------------------------------------------------

# Transitions from LEX_DEFAULT
# Fixed: Using double-quote block |"..."| because the content contains a single quote '
LEX_DEFAULT -> LEX_IN_SINGLE_QUOTE: |"md ' (single quote) "| {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}

LEX_DEFAULT -> LEX_IN_DOUBLE_QUOTE: |"md \" (double quote) "| {
  style: {
    stroke: "#E65100"
    stroke-width: 2
    animated: true
  }
}

LEX_DEFAULT -> LEX_IN_ESCAPE: |"md \\ (backslash) "| {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    animated: true
  }
}

# Transitions from LEX_IN_SINGLE_QUOTE
LEX_IN_SINGLE_QUOTE -> LEX_DEFAULT: |"md ' (matching quote) "| {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}

# Transitions from LEX_IN_DOUBLE_QUOTE
LEX_IN_DOUBLE_QUOTE -> LEX_DEFAULT: |"md \" (matching quote) "| {
  style: {
    stroke: "#E65100"
    stroke-width: 2
    animated: true
  }
}

LEX_IN_DOUBLE_QUOTE -> LEX_IN_ESCAPE: |"md \\ (escape char) "| {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    animated: true
  }
}

# Transitions from LEX_IN_ESCAPE
LEX_IN_ESCAPE -> LEX_DEFAULT: "any char\n(return from global escape)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    animated: true
  }
}

LEX_IN_ESCAPE -> LEX_IN_DOUBLE_QUOTE: "any char\n(return to double-quote context)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    animated: true
    stroke-dash: 2
  }
}

# -----------------------------------------------------------------------------
# INTERNAL PROCESSING (SELF-LOOPS)
# -----------------------------------------------------------------------------

LEX_DEFAULT -> LEX_DEFAULT: "accumulate: [a-zA-Z0-9_]\nwhitespace: flush_token()\nops: [|&<>;()]" {
  style: {
    stroke: "#66BB6A"
    stroke-dash: 3
  }
}

LEX_IN_SINGLE_QUOTE -> LEX_IN_SINGLE_QUOTE: |"md consume literal: any char except ' "| {
  style: {
    stroke: "#64B5F6"
    stroke-dash: 3
  }
}

# Fixed: Escaping $ to prevent "substitutions must begin on {" error
LEX_IN_DOUBLE_QUOTE -> LEX_IN_DOUBLE_QUOTE: |md
accumulate literal
expand: \${VAR} or \$VAR
| {
  style: {
    stroke: "#FFB74D"
    stroke-dash: 3
  }
}

# -----------------------------------------------------------------------------
# DOCUMENTATION & LEGEND
# -----------------------------------------------------------------------------

legend: {
  near: bottom-center
  label: |md
    ## Lexical State Machine Reference
    
    ### State Behaviors & Invariants
    - **LEX_DEFAULT**: Characters are classified as word-parts, operators, or whitespace. This is the starting entry point for the parser.
    - **LEX_IN_SINGLE_QUOTE**: Total literal mode. Neither backslash nor dollar sign has any special meaning. The only way to exit is the closing single quote.
    - **LEX_IN_DOUBLE_QUOTE**: Partial literal mode. Supports variable expansion via \$.
    - **LEX_IN_ESCAPE**: Transient state. Forces the literal value of the next byte into the current buffer, then returns to the previous state context.

    ### Escape Sequences (Inside Double Quotes)
    When in `LEX_IN_DOUBLE_QUOTE`, the backslash `\` escapes only:
    - \$ (Dollar sign)
    - \" (Double quote)
    - \\ (Backslash)
    - \` (Backtick)
    - \n (Newline - line continuation)
  |
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-width: 2
    font: mono
    font-size: 14
    border-radius: 5
  }
}

# Initial state entry
initial: ● {
  shape: circle
  style: {
    fill: "#4CAF50"
    stroke: "#2E7D32"
  }
}

initial -> LEX_DEFAULT: "Start Input" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 4
  }
}

# Error condition placeholder
ILLEGAL_TRANSITION: "ILLEGAL" {
  shape: text
  style: {
    font-color: red
    bold: true
  }
}

LEX_IN_SINGLE_QUOTE -> ILLEGAL_TRANSITION: "EOF before closing quote" {
  style: {
    stroke: red
    stroke-dash: 5
  }
}