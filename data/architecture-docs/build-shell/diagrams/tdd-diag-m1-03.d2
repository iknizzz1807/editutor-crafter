vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    word: "#4A90D9"
    operator: "#E67E22"
    keyword: "#9B59B6"
    special: "#27AE60"
    error: "#E74C3C"
  }
}
Token Taxonomy: {
  label: ""
  Tokens: {
    shape: circle
    style.fill: "#ECF0F1"
    style.stroke: "#BDC3C7"
  }
  Tokens -> Word Tokens
  Tokens -> Operator Tokens
  Tokens -> Keyword Tokens
  Tokens -> Special Tokens
  Word Tokens: {
    style.fill: ${colors.word}
    style.stroke: "#2980B9"
    style.font-color: white
    TOK_WORD: {
      label: "TOK_WORD"
      shape: rectangle
      style.fill: ${colors.word}
    }
    TOK_WORD -> example1
    TOK_WORD -> example2
    TOK_WORD -> example3
    example1: |md
      `"echo"`
    | {shape: text; style.font-color: white}
    example2: |md
      `"hello world"`
    | {shape: text; style.font-color: white}
    example3: |md
      `"$HOME"`
    | {shape: text; style.font-color: white}
  }
  Operator Tokens: {
    style.fill: ${colors.operator}
    style.stroke: "#D35400"
    style.font-color: white
    Control: {
      label: "Control Operators"
      style.fill: ${colors.operator}
      TOK_PIPE: {label: "TOK_PIPE\n|"; style.fill: "#D35400"}
      TOK_AMPERSAND: {label: "TOK_AMPERSAND\n&"; style.fill: "#D35400"}
      TOK_SEMICOLON: {label: "TOK_SEMICOLON\n;"; style.fill: "#D35400"}
      TOK_NEWLINE: {label: "TOK_NEWLINE\n\\n"; style.fill: "#D35400"}
    }
    Redirection: {
      label: "Redirection Operators"
      style.fill: ${colors.operator}
      TOK_REDIR_IN: {label: "TOK_REDIR_IN\n<"; style.fill: "#D35400"}
      TOK_REDIR_OUT: {label: "TOK_REDIR_OUT\n>"; style.fill: "#D35400"}
      TOK_REDIR_APPEND: {label: "TOK_REDIR_APPEND\n>>"; style.fill: "#D35400"}
      TOK_REDIR_ERR: {label: "TOK_REDIR_ERR\n2>"; style.fill: "#D35400"}
    }
    Grouping: {
      label: "Grouping Operators"
      style.fill: ${colors.operator}
      TOK_LPAREN: {label: "TOK_LPAREN\n("; style.fill: "#D35400"}
      TOK_RPAREN: {label: "TOK_RPAREN\n)"; style.fill: "#D35400"}
    }
  }
  Keyword Tokens: {
    style.fill: ${colors.keyword}
    style.stroke: "#8E44AD"
    style.font-color: white
    Conditional: {
      label: "Conditional"
      style.fill: ${colors.keyword}
      TOK_IF: {style.fill: "#8E44AD"}
      TOK_THEN: {style.fill: "#8E44AD"}
      TOK_ELSE: {style.fill: "#8E44AD"}
      TOK_ELIF: {style.fill: "#8E44AD"}
      TOK_FI: {style.fill: "#8E44AD"}
    }
    Loop: {
      label: "Loop"
      style.fill: ${colors.keyword}
      TOK_WHILE: {style.fill: "#8E44AD"}
      TOK_UNTIL: {style.fill: "#8E44AD"}
      TOK_FOR: {style.fill: "#8E44AD"}
      TOK_IN: {style.fill: "#8E44AD"}
      TOK_DO: {style.fill: "#8E44AD"}
      TOK_DONE: {style.fill: "#8E44AD"}
    }
  }
  Special Tokens: {
    style.fill: ${colors.special}
    style.stroke: "#1E8449"
    style.font-color: white
    TOK_EOF: {
      label: "TOK_EOF\nEnd of Input"
      style.fill: ${colors.special}
    }
    TOK_ERROR: {
      label: "TOK_ERROR\nLexical Error"
      style.fill: ${colors.error}
      style.stroke: "#C0392B"
    }
  }
}
legend: {
  near: bottom-right
  style.fill: transparent
  word_legend: {
    shape: rectangle
    label: "Words (Blue)"
    style.fill: ${colors.word}
    style.font-color: white
  }
  op_legend: {
    shape: rectangle
    label: "Operators (Orange)"
    style.fill: ${colors.operator}
    style.font-color: white
  }
  kw_legend: {
    shape: rectangle
    label: "Keywords (Purple)"
    style.fill: ${colors.keyword}
    style.font-color: white
  }
  sp_legend: {
    shape: rectangle
    label: "Special (Green)"
    style.fill: ${colors.special}
    style.font-color: white
  }
}