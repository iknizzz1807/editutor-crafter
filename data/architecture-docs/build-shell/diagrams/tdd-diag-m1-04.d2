vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Lexer Memory Layout
  **Total Size: 64 bytes (1 cache line)**
| {near: top-center}
Lexer: {
  grid-rows: 1
  grid-columns: 2
  fields: {
    grid-rows: 9
    grid-columns: 2
    grid-gap: 0
    header_offset: |md
      **Offset**
    | {class: header}
    header_field: |md
      **Field**
    | {class: header}
    header_type: |md
      **Type**
    | {class: header}
    header_size: |md
      **Size**
    | {class: header}
    header_desc: |md
      **Description**
    | {class: header}
    o1: "0x00"
    f1: "input"
    t1: "const char*"
    s1: "8"
    d1: "Pointer to source string"
    o2: "0x08"
    f2: "pos"
    t2: "size_t"
    s2: "8"
    d2: "Current index in input"
    o3: "0x10"
    f3: "len"
    t3: "size_t"
    s3: "8"
    d3: "Length of input string"
    o4: "0x18"
    f4: "state"
    t4: "LexerState"
    s4: "4"
    d4: "Current state machine state"
  }
  fields2: {
    grid-rows: 5
    grid-columns: 2
    grid-gap: 0
    o5: "0x20"
    f5: "current_token"
    t5: "char*"
    s5: "8"
    d5: "Buffer for token accumulation"
    o6: "0x28"
    f6: "token_capacity"
    t6: "size_t"
    s6: "8"
    d6: "Allocated size of buffer"
    o7: "0x30"
    f7: "token_len"
    t7: "size_t"
    s7: "8"
    d7: "Used size of buffer"
    o8: "0x38"
    f8: "line_number"
    t8: "int"
    s8: "4"
    d8: "Current line (1-indexed)"
    o9: "0x3C"
    f9: "column"
    t9: "int"
    s9: "4"
    d9: "Current column (1-indexed)"
  }
  fields.class: memcell
  fields2.class: memcell
}
cache_line: {
  label: "Cache Line Boundary (64 bytes)"
  shape: rectangle
  style: {
    stroke-dash: 4
    stroke: "#666"
    fill: transparent
  }
}
hot_fields: |md
  ### Hot Fields (Same Cache Line)
  - `pos` (0x08) — accessed every character
  - `state` (0x18) — checked per character
  - `token_len` (0x30) — updated per append
  **Cache Behavior:** Entire struct fits in one cache line.
  Sequential access to `pos`, `state`, `token_len` during
  tokenization maintains excellent locality.
| {near: bottom-center}
classes: {
  header: {
    style: {
      bold: true
      fill: "#E8E8E8"
      stroke: "#999"
    }
  }
  memcell: {
    style: {
      font: mono
      font-size: 14
    }
  }
}