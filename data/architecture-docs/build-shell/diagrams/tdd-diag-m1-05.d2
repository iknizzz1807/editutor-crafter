vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    cmd: "#10B981"
    redirect: "#F59E0B"
    operator: "#EF4444"
    padding: "#6B7280"
  }
}

direction: down

title: |'md
  # Abstract Syntax Tree (AST)
  ## Command: `ls -la | grep foo > out.txt &`
  **Precedence: BACKGROUND > PIPELINE > REDIRECT > SIMPLE_COMMAND**
'| {
  near: top-center
}

# -----------------------------------------------------------------------------
# BACKGROUND NODE (Root)
# -----------------------------------------------------------------------------
node_bg: {
  label: |'md
    ### NODE_BACKGROUND
    **Type:** AST_TYPE_BG
    **Operator:** `&`
  '|
  tooltip: "sizeof=32 bytes | offset 0: type | offset 4: child_ptr"
  style: {
    fill: ${colors.operator}
    stroke: "#991B1B"
    font-color: white
    bold: true
    stroke-width: 4
  }
}

# -----------------------------------------------------------------------------
# PIPELINE NODE
# -----------------------------------------------------------------------------
node_pipe: {
  label: |'md
    ### NODE_PIPELINE
    **Type:** AST_TYPE_PIPELINE
    **Pipe Count:** 1
  '|
  tooltip: "sizeof=32 bytes | offset 0: type | offset 4: cmd_list_ptr"
  style: {
    fill: ${colors.header}
    stroke: "#6D28D9"
    font-color: white
  }
}

# -----------------------------------------------------------------------------
# COMMAND 1: ls -la
# -----------------------------------------------------------------------------
cmd_ls: {
  label: |'md
    ### SIMPLE_CMD: ls
    **argc:** 2
  '|
  tooltip: "sizeof=32 bytes | offset 4: argv_ptr | offset 8: redir_ptr"
  style: {
    fill: ${colors.cmd}
    stroke: "#047857"
    font-color: white
  }

  argv_data: {
    shape: text
    label: |'md
      **argv[0]:** 0x4001 "ls"
      **argv[1]:** 0x4004 "-la"
      **argv[2]:** 0x0000 (NULL)
    '|
    style: {
      font-size: 11
      font-color: "#064E3B"
    }
  }
}

# -----------------------------------------------------------------------------
# COMMAND 2: grep foo
# -----------------------------------------------------------------------------
cmd_grep: {
  label: |'md
    ### SIMPLE_CMD: grep
    **argc:** 2
  '|
  tooltip: "sizeof=32 bytes | offset 4: argv_ptr"
  style: {
    fill: ${colors.cmd}
    stroke: "#047857"
    font-color: white
  }

  argv_data: {
    shape: text
    label: |'md
      **argv[0]:** 0x5001 "grep"
      **argv[1]:** 0x5006 "foo"
      **argv[2]:** 0x0000 (NULL)
    '|
    style: {
      font-size: 11
      font-color: "#064E3B"
    }
  }
}

# -----------------------------------------------------------------------------
# REDIRECT NODE (Attached to cmd_grep)
# -----------------------------------------------------------------------------
node_redir: {
  label: |'md
    ### REDIRECT
    **Type:** REDIR_OUT (`>`)
    **FD:** 1 (STDOUT)
  '|
  tooltip: "sizeof=24 bytes | offset 4: target_path_ptr | offset 8: next_redir"
  style: {
    fill: ${colors.redirect}
    stroke: "#B45309"
    font-color: white
  }
  
  meta: {
    shape: text
    label: |'md
      **Target:** "out.txt"
      **Append:** FALSE
    '|
    style: {
      font-size: 11
      font-color: "#78350F"
    }
  }
}

# -----------------------------------------------------------------------------
# CONNECTIONS (OWNERSHIP & REFS)
# -----------------------------------------------------------------------------
node_bg -> node_pipe: "child" {
  style: {
    stroke: "#991B1B"
    stroke-width: 3
  }
}

node_pipe -> cmd_ls: "cmds[0]" {
  style: {
    stroke: "#6D28D9"
    stroke-width: 3
  }
}

node_pipe -> cmd_grep: "cmds[1]" {
  style: {
    stroke: "#6D28D9"
    stroke-width: 3
  }
}

cmd_grep -> node_redir: "redirects" {
  style: {
    stroke: "#B45309"
    stroke-width: 2
    stroke-dash: 5
  }
}

# -----------------------------------------------------------------------------
# LEGEND & STATS
# -----------------------------------------------------------------------------
legend: {
  near: bottom-right
  label: "Node Definition Registry"
  style: {
    fill: "#F3F4F6"
    stroke: "#D1D5DB"
    double-border: true
  }
  
  l1: "BACKGROUND_NODE" { style.fill: ${colors.operator}; style.font-color: white }
  l2: "PIPELINE_NODE" { style.fill: ${colors.header}; style.font-color: white }
  l3: "SIMPLE_CMD" { style.fill: ${colors.cmd}; style.font-color: white }
  l4: "REDIRECT_NODE" { style.fill: ${colors.redirect}; style.font-color: white }
}

mem_spec: |'md
  ### Memory Layout Spec
  - **Alignment:** 8-byte boundary
  - **Pointers:** 64-bit (8 bytes)
  - **Total Allocations:**
    - `ASTNode` (32B) x 4
    - `RedirNode` (24B) x 1
    - `String Table` (~64B)
  - **Status:** Validated
'| {
  near: bottom-left
  style: {
    fill: "#F9FAFB"
    stroke: "#E5E7EB"
    font-size: 12
    font-color: "#374151"
  }
}