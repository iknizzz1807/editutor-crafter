vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # fork/exec/wait Process Lifecycle
  *Standard POSIX Process State Transition Diagram (Intel Manual Grade)*
| {near: top-center}

# --- GLOBAL STYLES & CLASSES ---
classes: {
  parent_state: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      font-size: 14
    }
  }
  child_state: {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
      font-size: 14
    }
  }
  syscall_transition: {
    style: {
      font-size: 12
      bold: true
      stroke-width: 2
      font-color: "#333333"
    }
  }
  technical_note: {
    shape: document
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      font-size: 11
      stroke-width: 1
    }
  }
}

# --- PROCESS LOGIC ---
direction: right

Kernel_Space: "KERNEL SPACE (Ring 0)" {
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    stroke-dash: 3
    stroke-width: 1
  }
  
  scheduler: "Process Scheduler" {
    shape: circle
    style.fill: white
  }
}

Parent_Process: {
  label: "PARENT PROCESS SPACE (PID: N)"
  style: {
    fill: "#F8F9FA"
    stroke: "#2196F3"
    stroke-dash: 5
    border-radius: 10
  }

  parent_start: "1. PARENT: Running" {
    class: parent_state
    tooltip: "Original execution context (Stack/Heap/Registers)"
  }
  
  parent_forking: "2. PARENT: Forking" {
    class: parent_state
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  
  parent_waiting: "4. PARENT: Waiting" {
    class: parent_state
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    tooltip: "Blocked in waitpid() syscall"
  }
  
  parent_reaped: "7. PARENT: Reaped" {
    class: parent_state
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
  }
  
  parent_continue: "8. PARENT: Continues" {
    class: parent_state
  }

  parent_start -> parent_forking: "SYSCALL: fork()" {class: syscall_transition}
  parent_forking -> parent_waiting: "Result: child_pid > 0" {class: syscall_transition}
  parent_waiting -> parent_reaped: "SIGCHLD / unblocked" {class: syscall_transition}
  parent_reaped -> parent_continue: "WEXITSTATUS(status)" {class: syscall_transition}

  # Internal Annotations for Elk Engine
  fork_details: |md
    **fork() Mechanics**
    - Returns Child_PID to Parent
    - Copy-on-Write (COW) Memory
    - Duplicates File Descriptors
    - Retains signal mask
  | { class: technical_note }
  
  wait_details: |md
    **waitpid() Blocking**
    - Parent: TASK_INTERRUPTIBLE
    - Context switch to other tasks
    - Kernel collects rusage/exit code
    - Cleans up Child Task Struct
  | { class: technical_note }

  parent_forking -- fork_details: {style.stroke-dash: 3}
  parent_waiting -- wait_details: {style.stroke-dash: 3}
}

Child_Process: {
  label: "CHILD PROCESS SPACE (PID: N+1)"
  style: {
    fill: "#FFF5F5"
    stroke: "#F44336"
    stroke-dash: 5
    border-radius: 10
  }

  child_created: "3. CHILD: Created" {
    class: child_state
    tooltip: "Duplicate of parent memory; fork() returns 0"
  }
  
  child_exec: "3a. CHILD: execvp()" {
    class: child_state
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
  }
  
  child_running: "5. CHILD: Running" {
    class: child_state
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  
  child_exit: "6. CHILD: Exiting" {
    class: child_state
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
  }
  
  child_zombie: "6a. CHILD: ZOMBIE" {
    class: child_state
    style: {
      bold: true
      stroke-dash: 4
      font-color: "#D32F2F"
    }
    tooltip: "Entry in task table remains"
  }

  child_created -> child_exec: "SYSCALL: execvp()" {class: syscall_transition}
  child_exec -> child_running: "image replaced" {class: syscall_transition}
  child_running -> child_exit: "main() returns / exit()" {class: syscall_transition}
  child_exit -> child_zombie: "kernel retains exit status" {class: syscall_transition}

  # Internal Annotations for Elk Engine
  exec_details: |md
    **execvp() Transformation**
    - PID remains unchanged
    - Stack/Heap re-initialized
    - .text segment (binary) replaced
    - Close-on-exec FDs closed
  | { class: technical_note }

  child_exec -- exec_details: {style.stroke-dash: 3}
}

# --- CROSS-PROCESS TRANSITIONS ---
Parent_Process.parent_forking -> Child_Process.child_created: "CLONE" {
  label: "fork() Success\n(Ret 0 in Child)"
  style: {
    stroke: "#9C27B0"
    stroke-width: 3
    stroke-dash: 4
    animated: true
  }
}

Child_Process.child_zombie -> Parent_Process.parent_reaped: "SIGCHLD" {
  label: "Kernel notifies Parent\nwaitpid() returns"
  style: {
    stroke: "#F44336"
    stroke-width: 3
    animated: true
  }
}

# --- KERNEL INTERACTION ---
Parent_Process.parent_waiting -> Kernel_Space.scheduler: "Sleep"
Child_Process.child_running -> Kernel_Space.scheduler: "Time Slice"

# --- SAFETY NOTES ---
note_exit: |md
  ### ⚠️ IMPLEMENTATION SAFETY
  If `execvp()` fails, call `_exit()` NOT `exit()`.
  
  **Reasoning:**
  Standard `exit()` flushes stdio buffers and runs `atexit()`
  handlers. Since a child process after `fork()` shares the
  file descriptors and memory state with the parent (until COW),
  a failed child calling `exit()` might flush buffers that
  contain parent data, leading to duplicate output or
  premature closure of shared resources.
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 3
    bold: true
    font-size: 12
  }
}

# --- LEGEND ---
legend: {
  near: bottom-right
  Parent: "Parent Context" { class: parent_state }
  Child: "Child Context" { class: child_state }
  Zombie: "Zombie (Terminated)" { 
    class: child_state
    style.stroke-dash: 4 
  }
  Note: "Tech Specification" { class: technical_note }
}