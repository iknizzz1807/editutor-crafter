vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    stack: "#E8D5B7"
    heap: "#B8D4E8"
    data: "#D4E8B8"
    code: "#E8B8D4"
    free: "#F0F0F0"
    pointer: "#FFB366"
    lifetime: "#666666"
  }
}
title: |md
  # Shell Process Memory Layout
  Process address space showing allocation zones and data lifetimes
| {near: top-center}
direction: right
memory_layout: {
  label: "Virtual Address Space (64-bit)"
  # Memory regions as vertical stack
  grid-rows: 6
  grid-columns: 1
  grid-gap: 0
  # Code/Text segment
  code_segment: |md
    ## Text Segment (0x400000)
    **Read-only executable code**
    - Shell binary code
    - Lexer functions
    - Parser functions
    - Executor functions
    - Builtin implementations
  | {
    style.fill: ${colors.code}
    style.stroke: "#8B668B"
    style.font-color: "#333"
  }
  # Data segment
  data_segment: |md
    ## Data Segment (0x600000)
    **Initialized global/static data**
    - Global variables: `g_job_control`, `g_options`
    - Function table: `g_functions`
    - Static strings (builtin names, error messages)
    - Builtin array: `builtins[]`
  | {
    style.fill: ${colors.data}
    style.stroke: "#668B66"
    style.font-color: "#333"
  }
  # Heap - main allocation zone
  heap_segment: |md
    ## Heap (grows upward ↑)
    **Dynamic allocations via malloc()**
    ### Input Line Buffer
    - `char* line` from `getline()`
    - Size: Variable (typical 1KB-4KB)
    - Lifetime: One REPL iteration
    - Owner: Main loop
    ### Token Strings
    - `char* value` from `strdup()` in lexer
    - Size: Word length + 1
    - Lifetime: Until parser consumes
    - Owner: Lexer, freed by parser
    ### AST Nodes
    - `ASTNode*` from `create_node()`
    - Size: 32 bytes per node + union data
    - Lifetime: Until `free_ast()` after execution
    - Owner: Parser, freed by executor
    ### argv Arrays
    - `char** argv` in SimpleCommand
    - Size: argc * sizeof(char*) + strings
    - Lifetime: Same as containing AST node
    - Owner: AST node (freed recursively)
    ### Expansion Results
    - `ExpandResult.words[]` arrays
    - Size: Variable (glob can produce many)
    - Lifetime: During expansion phase
    - Owner: `expand_result_free()`
  | {
    style.fill: ${colors.heap}
    style.stroke: "#4A6B8A"
    style.font-color: "#333"
  }
  # Stack
  stack_segment: |md
    ## Stack (grows downward ↓)
    **Automatic/local variables**
    ### REPL Loop Frame
    - `char* line`, `size_t line_cap`
    - `int last_exit_status`
    ### Lexer Frame
    - `Lexer lexer` struct (64 bytes)
    - `TokenType type`, `char* value`
    ### Parser Frame
    - `Parser parser` struct (48 bytes)
    - Recursive descent call frames
    ### Executor Frame
    - `ASTNode* node`, `ShellState* state`
    - `pid_t pid`, `int status`
    - `waitpid()` return values
    ### Function Call Frames
    - Saved positional params
    - Local variable marks
    - `jmp_buf` for return
  | {
    style.fill: ${colors.stack}
    style.stroke: "#8B7355"
    style.font-color: "#333"
  }
  # Shared libraries / kernel boundary
  shared_segment: |md
    ## Shared Libraries & Kernel
    **Memory-mapped regions**
    - libc.so (malloc, fork, exec)
    - libreadline (if used)
    - Kernel syscall interface
    - Pipe buffers (64KB in kernel)
  | {
    style.fill: ${colors.free}
    style.stroke: "#999"
    style.font-color: "#666"
    style.stroke-dash: 3
  }
}
# Detailed ownership diagram
ownership: {
  label: "Data Ownership & Lifetime"
  direction: right
  lifecycle: {
    label: "REPL Iteration Lifecycle"
    phase1: {
      label: "1. Read"
      shape: rectangle
      style.fill: "#E8D5B7"
    }
    phase2: {
      label: "2. Lex"
      shape: rectangle
      style.fill: "#B8D4E8"
    }
    phase3: {
      label: "3. Parse"
      shape: rectangle
      style.fill: "#D4E8B8"
    }
    phase4: {
      label: "4. Execute"
      shape: rectangle
      style.fill: "#E8B8D4"
    }
    phase5: {
      label: "5. Free"
      shape: rectangle
      style.fill: "#F0F0F0"
    }
    phase1 -> phase2 -> phase3 -> phase4 -> phase5
  }
  data_flow: {
    label: "Data Flow & Ownership Transfer"
    input_line: {
      label: "Input Line\n---\nALLOC: getline()\nSIZE: variable\nFREE: main loop"
      shape: rectangle
      style.fill: ${colors.stack}
    }
    tokens: {
      label: "Token Strings\n---\nALLOC: lexer (strdup)\nSIZE: word length\nFREE: parser (after AST)"
      shape: rectangle
      style.fill: ${colors.heap}
    }
    ast: {
      label: "AST Nodes\n---\nALLOC: parser\nSIZE: 32B + children\nFREE: free_ast()"
      shape: rectangle
      style.fill: ${colors.heap}
    }
    argv: {
      label: "argv Arrays\n---\nALLOC: parser\nSIZE: argc * ptr\nFREE: free_ast()"
      shape: rectangle
      style.fill: ${colors.heap}
    }
    expanded: {
      label: "Expanded Words\n---\nALLOC: expand_word()\nSIZE: variable\nFREE: after exec"
      shape: rectangle
      style.fill: ${colors.heap}
    }
    input_line -> tokens: "lexing"
    tokens -> ast: "parsing"
    ast -> argv: "contained in"
    ast -> expanded: "M2: expansion"
    # Free arrows
    input_line -> phase5: {
      style.stroke: ${colors.lifetime}
      style.stroke-dash: 3
    }
    tokens -> phase5: {
      style.stroke: ${colors.lifetime}
      style.stroke-dash: 3
    }
    ast -> phase5: {
      style.stroke: ${colors.lifetime}
      style.stroke-dash: 3
    }
  }
}
# Memory layout detail
layout_detail: {
  label: "Detailed Heap Layout (Example)"
  direction: down
  heap_block: {
    label: ""
    shape: rectangle
    width: 500
    # Visual representation of heap
    style.fill: "linear-gradient(to bottom, #B8D4E8 0%, #B8D4E8 20%, #D4E8B8 20%, #D4E8B8 60%, #F0F0F0 60%, #F0F0F0 100%)"
    style.stroke: "#333"
    style.stroke-width: 2
  }
  legend: {
    direction: right
    grid-columns: 3
    l1: "█ Input/Stack" {
      style.fill: ${colors.stack}
      shape: rectangle
      width: 30
      height: 20
    }
    l2: "█ AST Nodes" {
      style.fill: "#D4E8B8"
      shape: rectangle
      width: 30
      height: 20
    }
    l3: "█ Free Space" {
      style.fill: ${colors.free}
      shape: rectangle
      width: 30
      height: 20
    }
  }
  # Memory addresses
  addresses: |md
    
    Address         Content              Owner
    ────────────────────────────────────────────
    0x555555600000  [Input line buffer]  getline
    0x555555601000  [Token: "echo"]      lexer
    0x555555601010  [Token: "hello"]     lexer
    0x555555601020  [ASTNode: SIMPLE]    parser
    0x555555601040  [argv[0]: "echo"]    AST
    0x555555601050  [argv[1]: "hello"]   AST
    0x555555601060  [Redirect: NULL]     AST
    ...
    0x555555700000  [Heap break]
    
  |
}
# Key invariants
invariants: {
  label: "Memory Invariants"
  near: bottom-center
  inv: |md
    ### Ownership Rules
    1. **Input line**: Allocated by `getline()`, freed by main loop at end of iteration
    2. **Token strings**: Allocated by lexer via `strdup()`, freed by parser after consuming or on error
    3. **AST nodes**: Allocated by `create_node()`, freed by `free_ast()` after execution
    4. **argv arrays**: Allocated during parsing, freed recursively by `free_ast()`
    5. **Expansion results**: Allocated by `expand_word()`, freed by `expand_result_free()`
    ### Lifetime Boundaries
    - **REPL iteration**: Input line → tokens → AST → execute → free all
    - **No leaks**: Every `malloc` has matching `free`
    - **No use-after-free**: Clear pointers after freeing in structs
    - **Child processes**: Use `_exit()` not `exit()` to avoid double-free of stdio buffers
  | {
    shape: rectangle
    style.fill: "#FFFACD"
    style.stroke: "#B8860B"
    style.font: mono
    style.font-size: 14
  }
}