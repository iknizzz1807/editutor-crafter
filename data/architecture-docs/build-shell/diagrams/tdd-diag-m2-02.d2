vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    data: "#6B9BD1"
    pointer: "#E8A854"
    closed: "#888888"
    active: "#4CAF50"
    pipe_read: "#E57373"
    pipe_write: "#64B5F6"
    bg: "#F5F5F5"
    padding: "#E0E0E0"
  }
}

# --- GLOBAL STYLES ---
*.style: {
  font: mono
}

title_block: {
  label: ||md
    # File Descriptor Table During Pipeline Setup
    `cmd1 | cmd2 | cmd3` — Before and After `dup2()` and `close()`
  ||
  shape: text
  near: top-center
}

direction: right

# --- PHASE 1 ---
step1: {
  label: "PHASE 1: Initial State (After fork, before dup2)"
  style: {
    stroke-dash: 5
    fill: "#FDFDFD"
  }

  parent_initial: {
    label: "Parent Process (PID=1000)"
    style: {
      fill: "${colors.header}"
      stroke-width: 4
    }

    fd_table_init: {
      label: "File Descriptor Table (Kernel Struct)"
      grid-columns: 3
      grid-gap: 0
      style.fill: "${colors.bg}"

      h1: "Offset" { style: { bold: true; fill: "${colors.padding}" } }
      h2: "FD #" { style: { bold: true; fill: "${colors.padding}" } }
      h3: "File Object Pointer / Target" { style: { bold: true; fill: "${colors.padding}" } }

      off0: "0x00" { style.stroke-dash: 0 }
      fd0: "0" { style.fill: "${colors.data}" }
      desc0: "stdin → /dev/tty"

      off1: "0x08"
      fd1: "1" { style.fill: "${colors.data}" }
      desc1: "stdout → /dev/tty"

      off2: "0x10"
      fd2: "2" { style.fill: "${colors.data}" }
      desc2: "stderr → /dev/tty"

      off3: "0x18"
      fd3: "3" { style.fill: "${colors.pipe_read}" }
      desc3: "pipe0[0] (read-end)"

      off4: "0x20"
      fd4: "4" { style.fill: "${colors.pipe_write}" }
      desc4: "pipe0[1] (write-end)"

      off5: "0x28"
      fd5: "5" { style.fill: "${colors.pipe_read}" }
      desc5: "pipe1[0] (read-end)"

      off6: "0x30"
      fd6: "6" { style.fill: "${colors.pipe_write}" }
      desc6: "pipe1[1] (write-end)"
    }
  }

  child1_initial: {
    label: "Child 1 (cmd1) (PID=1001)"
    style.fill: "${colors.data}"
    c1_fd_table: {
      label: "Inherited FD Table"
      style.fill: "${colors.bg}"
      c1f0: "fd 0: stdin"
      c1f1: "fd 1: stdout"
      c1f3: "fd 3: pipe0[R]"
      c1f4: "fd 4: pipe0[W]"
    }
  }

  child2_initial: {
    label: "Child 2 (cmd2) (PID=1002)"
    style.fill: "${colors.data}"
    c2_fd_table: {
      label: "Inherited FD Table"
      style.fill: "${colors.bg}"
      c2f0: "fd 0: stdin"
      c2f3: "fd 3: pipe0[R]"
      c2f4: "fd 4: pipe0[W]"
      c2f5: "fd 5: pipe1[R]"
      c2f6: "fd 6: pipe1[W]"
    }
  }

  parent_initial -> child1_initial: fork()
  child1_initial -> child2_initial: fork()
}

# --- PHASE 2 ---
step2: {
  label: "PHASE 2: After dup2() and close() in Children"
  style: {
    stroke-dash: 5
    fill: "#FDFDFD"
  }

  parent_final: {
    label: "Parent (Post-Cleanup)"
    style.fill: "${colors.header}"
    p_fd_final: {
      label: "File Descriptor Table"
      style.fill: "${colors.bg}"
      p0: "fd 0" { label: "stdin"; style.fill: "${colors.active}" }
      p1: "fd 1" { label: "stdout"; style.fill: "${colors.active}" }
      p3: "fd 3" { label: "CLOSED"; style.fill: "${colors.closed}" }
      p4: "fd 4" { label: "CLOSED"; style.fill: "${colors.closed}" }
      p5: "fd 5" { label: "CLOSED"; style.fill: "${colors.closed}" }
      p6: "fd 6" { label: "CLOSED"; style.fill: "${colors.closed}" }
    }
    p_note: {
      label: ||md
        **Cleanup Rule:**
        Parent must close ALL pipe
        ends to allow EOF signals.
      ||
      shape: text
      style.font-size: 10
    }
  }

  child1_final: {
    label: "Child 1 (cmd1)"
    style.fill: "${colors.active}"
    c1_fd_final: {
      label: "Post-dup2() Table"
      style.fill: "${colors.bg}"
      c1f0_f: "fd 0" { label: "stdin"; style.fill: "${colors.active}" }
      c1f1_f: "fd 1" {
        label: "STDOUT -> pipe0[W]"
        style: {
          fill: "${colors.pipe_write}"
          bold: true
          stroke-width: 3
        }
      }
      c1f3_f: "fd 3" { label: "CLOSED"; style.fill: "${colors.closed}" }
      c1f4_f: "fd 4" { label: "CLOSED"; style.fill: "${colors.closed}" }
    }
    c1_note: {
      label: ||md
        `dup2(fd4, 1)`
        `close(fd3); close(fd4);`
      ||
      shape: text
      style.font-size: 10
    }
  }

  child2_final: {
    label: "Child 2 (cmd2)"
    style.fill: "${colors.active}"
    c2_fd_final: {
      label: "Post-dup2() Table"
      style.fill: "${colors.bg}"
      c2f0_f: "fd 0" {
        label: "STDIN -> pipe0[R]"
        style: {
          fill: "${colors.pipe_read}"
          bold: true
          stroke-width: 3
        }
      }
      c2f1_f: "fd 1" {
        label: "STDOUT -> pipe1[W]"
        style: {
          fill: "${colors.pipe_write}"
          bold: true
          stroke-width: 3
        }
      }
      c2f3_f: "fd 3" { label: "CLOSED"; style.fill: "${colors.closed}" }
      c2f4_f: "fd 4" { label: "CLOSED"; style.fill: "${colors.closed}" }
    }
    c2_note: {
      label: ||md
        `dup2(fd3, 0); dup2(fd6, 1);`
        `close(all_others);`
      ||
      shape: text
      style.font-size: 10
    }
  }

  parent_final -> child1_final: execvp()
  child1_final -> child2_final: execvp()
}

# --- KERNEL ABSTRACTION ---
kernel_space: {
  label: "Kernel Memory: Pipe Buffers"
  style.fill: "#E1F5FE"

  pipe0: {
    label: "Pipe 0 Object (Size: 64KB)"
    tooltip: "Buffered communication: cmd1 -> cmd2"
    style: {
      fill: "${colors.pipe_read}"
      stroke: "${colors.pipe_write}"
      multiple: true
      stroke-width: 2
    }
  }
  pipe1: {
    label: "Pipe 1 Object (Size: 64KB)"
    tooltip: "Buffered communication: cmd2 -> cmd3"
    style: {
      fill: "${colors.pipe_read}"
      stroke: "${colors.pipe_write}"
      multiple: true
      stroke-width: 2
    }
  }
}

# --- DATA FLOW CONNECTIONS ---
child1_final.c1_fd_final.c1f1_f -> kernel_space.pipe0: "write(1, ...)" {
  style.stroke: "${colors.pipe_write}"
  style.stroke-width: 2
}
kernel_space.pipe0 -> child2_final.c2_fd_final.c2f0_f: "read(0, ...)" {
  style.stroke: "${colors.pipe_read}"
  style.stroke-width: 2
}
child2_final.c2_fd_final.c2f1_f -> kernel_space.pipe1: "write(1, ...)" {
  style.stroke: "${colors.pipe_write}"
  style.stroke-width: 2
}

# --- LEGEND ---
legend: {
  label: "Memory Map Legend"
  near: bottom-right
  l1: "Active I/O" { style.fill: "${colors.active}" }
  l2: "Pipe Read End (fd 3/5)" { style.fill: "${colors.pipe_read}" }
  l3: "Pipe Write End (fd 4/6)" { style.fill: "${colors.pipe_write}" }
  l4: "Closed Entry" { style.fill: "${colors.closed}" }
}

# --- WARNING BOX ---
warning_box: {
  label: ||md
    ### ⚠️ CRITICAL IMPLEMENTATION DETAIL
    If any pipe write-end (e.g., `fd4`) remains open in the **Parent**
    or in **Child 2**, **Child 2** will never receive EOF on its `stdin`.
    The `read()` loop in `cmd2` will hang indefinitely waiting for
    data that will never arrive because the reference count > 0.
  ||
  shape: text
  near: bottom-center
  style: {
    font-color: "#C62828"
    bold: true
    stroke: "#C62828"
    fill: "#FFEBEE"
  }
}
