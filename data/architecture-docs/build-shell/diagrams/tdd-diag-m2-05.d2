layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: |md
  # Redirection Order Matters
  ## Technical Analysis of File Descriptor Duplication
  **`> file 2>&1` vs `2>&1 > file`**
| {near: top-center}

# === CLASSES FOR INTEL-MANUAL QUALITY ===
classes: {
  fd_table: {
    shape: sql_table
    style: {
      stroke: "#2196F3"
      stroke-width: 2
      font: mono
    }
  }
  sys_call: {
    shape: parallelogram
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  process_boundary: {
    style: {
      stroke: "#9E9E9E"
      stroke-dash: 5
      border-radius: 10
    }
  }
  pointer_active: {
    style: {
      stroke: "#FF9800"
      stroke-width: 3
      animated: true
    }
  }
}

# === CORRECT ORDER: > file 2>&1 ===
correct: {
  label: "EXECUTION SEQUENCE A: > file 2>&1 (Corrected Redirection)"
  class: process_boundary
  style.fill: "#F1F8E9"

  step1: {
    label: "PHASE 1: STDOUT Redirection"
    
    fd_table_before: {
      class: fd_table
      header: "Initial State"
      "fd[0] (stdin)": "0x0A (tty)"
      "fd[1] (stdout)": "0x0B (tty)"
      "fd[2] (stderr)": "0x0B (tty)"
    }

    op_open: {
      class: sys_call
      label: "fd_out = open('file', O_WRONLY)"
    }

    op_dup1: {
      class: sys_call
      label: "dup2(fd_out, 1)"
    }

    fd_table_after: {
      class: fd_table
      header: "Post Step 1"
      "fd[0] (stdin)": "0x0A (tty)"
      "fd[1] (stdout)": "0x0C (file) ◄"
      "fd[2] (stderr)": "0x0B (tty)"
      style.fill: "#C8E6C9"
    }

    fd_table_before -> op_open -> op_dup1 -> fd_table_after
  }

  step2: {
    label: "PHASE 2: STDERR Redirection"

    fd_table_start: {
      class: fd_table
      header: "Step 2 Start"
      "fd[1] (stdout)": "0x0C (file)"
      "fd[2] (stderr)": "0x0B (tty)"
    }

    op_dup2: {
      class: sys_call
      label: "dup2(1, 2)"
    }

    fd_table_final: {
      class: fd_table
      header: "Final Kernel FD State"
      "fd[0] (stdin)": "0x0A (tty)"
      "fd[1] (stdout)": "0x0C (file) ✓"
      "fd[2] (stderr)": "0x0C (file) ✓"
      style.fill: "#A5D6A7"
    }

    fd_table_start -> op_dup2 -> fd_table_final
  }

  step1 -> step2: "Sequence: Left-to-Right Parser"

  result_correct: {
    label: "RESULT: SYNC SUCCESS\nBoth streams merged into file offset"
    shape: diamond
    style.fill: "#4CAF50"
    style.font-color: white
  }
  step2 -> result_correct
}

# === WRONG ORDER: 2>&1 > file ===
wrong: {
  label: "EXECUTION SEQUENCE B: 2>&1 > file (Broken Redirection)"
  class: process_boundary
  style.fill: "#FFEBEE"

  step1_w: {
    label: "PHASE 1: STDERR Copy (Premature)"

    fd_table_before_w: {
      class: fd_table
      header: "Initial State"
      "fd[1] (stdout)": "0x0B (tty)"
      "fd[2] (stderr)": "0x0B (tty)"
    }

    op_dup_w: {
      class: sys_call
      label: "dup2(1, 2)"
    }

    fd_table_after_w: {
      class: fd_table
      header: "Post Step 1 (No-op)"
      "fd[1] (stdout)": "0x0B (tty)"
      "fd[2] (stderr)": "0x0B (tty) ⚠"
      style.fill: "#FFCDD2"
    }

    note_w: |md
      **Snapshotted current fd[1] target.**
      Since fd[1] still points to TTY,
      fd[2] is explicitly bound to TTY.
    | {shape: text; style.font-size: 10}

    fd_table_before_w -> op_dup_w -> fd_table_after_w
    fd_table_after_w -> note_w
  }

  step2_w: {
    label: "PHASE 2: STDOUT Redirection (Too Late)"

    fd_table_start_w: {
      class: fd_table
      header: "Step 2 Start"
      "fd[1] (stdout)": "0x0B (tty)"
      "fd[2] (stderr)": "0x0B (tty)"
    }

    op_open_w: {
      class: sys_call
      label: "dup2(open(file), 1)"
    }

    fd_table_final_w: {
      class: fd_table
      header: "Final Kernel FD State"
      "fd[0] (stdin)": "0x0A (tty)"
      "fd[1] (stdout)": "0x0C (file) ✓"
      "fd[2] (stderr)": "0x0B (tty) ✗"
      style.fill: "#EF9A9A"
    }

    fd_table_start_w -> op_open_w -> fd_table_final_w
  }

  step1_w -> step2_w: "Sequence: Left-to-Right Parser"

  result_wrong: {
    label: "RESULT: DIVERGENT STREAMS\nstderr remains on terminal"
    shape: diamond
    style.fill: "#F44336"
    style.font-color: white
  }
  step2_w -> result_wrong
}

# === MEMORY & LOGIC INSIGHT ===
key_insight: {
  label: |md
    ### Low-Level Mechanism: File Descriptor Duplication
    When the shell executes `dup2(oldfd, newfd)`, it copies the **pointer value** 
    stored in the process's file descriptor table.
    
    1.  **Correct Order**: fd[1] is pointed to 'file' (0x0C). Then fd[2] copies 0x0C.
    2.  **Wrong Order**: fd[2] copies fd[1]'s current value (0x0B, the TTY). Subsequent changes to fd[1] do not affect fd[2].
    
    *Memory Analogy: This is a **Pass-by-Value** copy of the underlying `struct file *` pointer.*
  | 
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 3
    border-radius: 8
  }
}

# Layout Connections
correct -> key_insight: "Architectural Root Cause"
key_insight -> wrong: "Application of Principle"

(correct -> key_insight)[0].style.stroke-dash: 5
(key_insight -> wrong)[0].style.stroke-dash: 5