vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Shell Expansion Phase Pipeline
  POSIX-defined order with data transformations
'| {
  near: top-center
  style.font-size: 24
}

direction: right

# -----------------------------------------------------------------------------------------
# INPUT DEFINITION
# -----------------------------------------------------------------------------------------
input: 'Input Word\n"~user/$HOME/*.txt"' {
  shape: rectangle
  style: {
    fill: "#E8E8E8"
    stroke: "#666666"
    stroke-width: 2
    font: mono
    font-size: 14
  }
}

# -----------------------------------------------------------------------------------------
# EXPANSION PHASES
# -----------------------------------------------------------------------------------------

p1_tilde: {
  label: "Phase 1\nTilde Expansion"
  style: {
    fill: "#E4DBFE"
    stroke: "#B5AFF6"
    stroke-width: 2
  }
  header: |'md
    **~ → $HOME**
    **~user → user's home**
  '|
  
  engine: "expand_tilde()" {
    shape: hexagon
    style.fill: "#C9B8F0"
  }
  
  details: {
    rule1: "Only at word start" {shape: text}
    rule2: "~user → getpwnam()" {shape: text}
  }
}

p2_param: {
  label: "Phase 2\nParameter Expansion"
  style: {
    fill: "#C7F1FF"
    stroke: "#5CB8E8"
    stroke-width: 2
  }
  header: |'md
    **$VAR, ${VAR}**
    **$?, $$, $1-$9**
  '|
  
  engine: "expand_parameter()" {
    shape: hexagon
    style.fill: "#9EE2FF"
  }
  
  special: '$? → exit_status\n$$ → shell_pid\n$0 → script_name' {
    shape: text
    style.font: mono
  }
}

p3_cmdsub: {
  label: "Phase 3\nCommand Substitution"
  style: {
    fill: "#FCE7C6"
    stroke: "#ED800C"
    stroke-width: 2
  }
  header: |'md
    **$(cmd) or `cmd`**
    **Recursive shell execution**
  '|
  
  engine: "expand_cmd_sub()" {
    shape: hexagon
    style.fill: "#F9D8A7"
  }
  
  fork_process: "fork() + pipe()\ncapture stdout" {
    shape: rectangle
    style: {
      fill: "#FFF5E6"
      stroke-dash: 3
    }
  }
  rule: "Strip trailing newlines" {shape: text}
}

p4_field: {
  label: "Phase 4\nField Splitting"
  style: {
    fill: "#ACE1AF"
    stroke: "#4CAF50"
    stroke-width: 2
  }
  header: |'md
    **Split on IFS**
    **Whitespace by default**
  '|
  
  engine: "field_split()" {
    shape: hexagon
    style.fill: "#8FD69E"
  }
  
  ifs_config: 'IFS=":" → split on colons' {
    shape: text
    style.font: mono
  }
  
  security: "Quoted results are NOT split" {
    shape: text
    style: {
      font-color: "#D32F2F"
      bold: true
    }
  }
}

p5_glob: {
  label: "Phase 5\nGlob Expansion"
  style: {
    fill: "#FFCCBC"
    stroke: "#FF5722"
    stroke-width: 2
  }
  header: |'md
    ***, ?, [...]**
    **Pathname generation**
  '|
  
  engine: "expand_glob()" {
    shape: hexagon
    style.fill: "#FFAB91"
  }
  
  syntax: "* → any string\n? → any char\n[a-z] → range" {
    shape: text
    style.font: mono
  }
  
  behavior: {
    nomatch: "No match → literal pattern" {
      shape: text
      style.font-color: "#1976D2"
    }
    dotfiles: "Leading . requires explicit match" {
      shape: text
    }
  }
}

p6_quotes: {
  label: "Phase 6\nQuote Removal"
  style: {
    fill: "#E1BEE7"
    stroke: "#9C27B0"
    stroke-width: 2
  }
  header: |'md
    **Strip delimiters**
    **Final string cleanup**
  '|
  
  engine: "remove_quotes()" {
    shape: hexagon
    style.fill: "#CE93D8"
  }
  
  preserved: "Content preserved\ndelimiters removed" {shape: text}
}

# -----------------------------------------------------------------------------------------
# OUTPUT DEFINITION
# -----------------------------------------------------------------------------------------
output: 'Expanded Words\n["/home/user", "/home/user/file1.txt"]' {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
    font: mono
    font-size: 12
  }
}

# -----------------------------------------------------------------------------------------
# PIPELINE CONNECTIONS
# -----------------------------------------------------------------------------------------
input -> p1_tilde: "raw word stream" {
  style: {
    stroke-width: 2
    animated: true
  }
}

p1_tilde -> p2_param: "tilde resolved" {
  style.stroke-width: 2
}

p2_param -> p3_cmdsub: "variables expanded" {
  style.stroke-width: 2
}

p3_cmdsub -> p4_field: "command output injected" {
  style: {
    stroke-width: 2
    stroke-dash: 3
  }
}

p4_field -> p5_glob: "split into fields" {
  style.stroke-width: 2
}

p5_glob -> p6_quotes: "paths matched" {
  style.stroke-width: 2
}

p6_quotes -> output: "final strings" {
  style: {
    stroke-width: 2
    animated: true
  }
}

# -----------------------------------------------------------------------------------------
# DOCUMENTATION BLOCKS (ROOT LEVEL)
# -----------------------------------------------------------------------------------------

example_trace: {
  label: "Transformation Trace"
  near: bottom-center
  content: |'md
    ### Example Expansion Trace: `echo ~/$USER/*.txt`
    
    1. **Original**: `~/$USER/*.txt`
    2. **Tilde**: `/home/alice/$USER/*.txt`
    3. **Parameter**: `/home/alice/alice/*.txt`
    4. **Cmd Sub**: (no change)
    5. **Field Split**: `["/home/alice/alice/*.txt"]` (1 field)
    6. **Glob**: `["/home/alice/alice/notes.txt", "/home/alice/alice/todo.txt"]`
    7. **Quote Removal**: (clean strings)
  '|
  style: {
    stroke: "#ED800C"
    fill: "#FFF9C9"
  }
}

critical_notes: {
  label: "Implementation Constraints"
  near: top-right
  content: |'md
    ### Order of Operations
    - **Globbing follows Splitting**: Parameters containing spaces are split before globs are evaluated.
    - **Quotes inhibit expansion**: `"*.txt"` prevents Phase 5.
    - **Single quotes**: `'...'` literal strings prevent Phase 1-5.
    
    bash
    VAR="a b c"
    echo $VAR    # 3 arguments passed
    echo "$VAR"  # 1 argument passed
    
  '|
  style: {
    stroke: "#9C27B0"
    fill: "#F3E5F5"
  }
}