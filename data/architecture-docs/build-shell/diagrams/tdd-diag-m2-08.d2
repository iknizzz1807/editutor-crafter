vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

direction: right

title: |md
  # Glob Pattern Matching State Machine
  Recursive pattern matching for `*`, `?`, `[...]` against filenames
| {near: top-center}

# --- State Definitions ---
START: {
  shape: circle
  label: "●"
  tooltip: "Entry Point: Initialize pattern pointer i=0, string pointer j=0"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

MATCH_CHAR: "Match Literal" {
  tooltip: "Invariant: pattern[i] is a standard literal character. Comparison: pattern[i] == string[j]"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
  }
}

MATCH_STAR: "Match *" {
  tooltip: "Wildcard *: Skip consecutive *, then non-deterministically try matching 0, 1, ... N characters"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
  }
}

MATCH_QUESTION: "Match ?" {
  tooltip: "Wildcard ?: Consume exactly one character from the target string"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
}

MATCH_CLASS: "Match [...]" {
  tooltip: "Bracket Expression: Match single char against set, range (a-z), or negation [!abc]"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
  }
}

SUCCESS: "MATCH COMPLETE" {
  shape: circle
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 4
    double-border: true
  }
}

FAIL: "NO MATCH" {
  shape: circle
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
    stroke-width: 3
  }
}

# --- Transition Logic (Triggers + Guards + Actions) ---

# Entry logic
START -> MATCH_CHAR: "p[i] ∈ [a-zA-Z0-9]"
START -> MATCH_STAR: "p[i] == '*'"
START -> MATCH_QUESTION: "p[i] == '?'"
START -> MATCH_CLASS: "p[i] == '['"
START -> SUCCESS: "EOF(p) ∧ EOF(s)"
START -> FAIL: "EOF(p) ∧ ¬EOF(s)"

# Literal Matching Logic
MATCH_CHAR -> MATCH_CHAR: "[p[i]==s[j]] ∧ p[i+1] literal"
MATCH_CHAR -> MATCH_STAR: "[p[i]==s[j]] ∧ p[i+1]=='*'"
MATCH_CHAR -> MATCH_QUESTION: "[p[i]==s[j]] ∧ p[i+1]=='?'"
MATCH_CHAR -> MATCH_CLASS: "[p[i]==s[j]] ∧ p[i+1]=='['"
MATCH_CHAR -> SUCCESS: "[p[i]==s[j]] ∧ EOF(p+1) ∧ EOF(s+1)"
MATCH_CHAR -> FAIL: "p[i] ≠ s[j]" {
  style: {
    stroke: red
    stroke-dash: 3
  }
}

# Wildcard * Logic (Backtracking)
MATCH_STAR -> MATCH_STAR: "consume s[j]; j++\n(Recursive Branch)"
MATCH_STAR -> MATCH_CHAR: "p[i+1] is literal\ntry match s[j]"
MATCH_STAR -> SUCCESS: "p[i] is last ∧ match s[j...]"

# Wildcard ? Logic
MATCH_QUESTION -> MATCH_CHAR: "¬EOF(s) ∧ p[i+1] literal"
MATCH_QUESTION -> MATCH_STAR: "¬EOF(s) ∧ p[i+1]=='*'"
MATCH_QUESTION -> MATCH_QUESTION: "¬EOF(s) ∧ p[i+1]=='?'"
MATCH_QUESTION -> MATCH_CLASS: "¬EOF(s) ∧ p[i+1]=='['"
MATCH_QUESTION -> SUCCESS: "¬EOF(s) ∧ EOF(p+1)"
MATCH_QUESTION -> FAIL: "EOF(s)" {
  label: "ILLEGAL: ? requires char"
  style: {
    stroke: red
    stroke-dash: 5
    bold: true
  }
}

# Character Class Logic
MATCH_CLASS -> MATCH_CHAR: "s[j] ∈ Class ∧ p[i+N] literal"
MATCH_CLASS -> MATCH_STAR: "s[j] ∈ Class ∧ p[i+N]=='*'"
MATCH_CLASS -> MATCH_QUESTION: "s[j] ∈ Class ∧ p[i+N]=='?'"
MATCH_CLASS -> MATCH_CLASS: "s[j] ∈ Class ∧ p[i+N]=='['"
MATCH_CLASS -> SUCCESS: "s[j] ∈ Class ∧ EOF(p+N)"
MATCH_CLASS -> FAIL: "s[j] ∉ Class ∨ EOF(s)" {
  style: {
    stroke: red
  }
}

# --- Documentation ---
legend: {
  near: bottom-center
  label: |md
    ### Wildcard Operational Semantics
    - **`*`**: Greedy matching. Internal implementation typically uses recursive calls to handle multiple stars or backtracking on failure.
    - **`?`**: Matches any single octet except for the null terminator.
    - **`[...]`**:
      - `[a-z]`: Range match (locale dependent).
      - `[!a-z]`: Negated match (matches any char NOT in range).
    - **Backtracking**: If a path reaches **FAIL**, the engine pops the last **MATCH_STAR** state and increments the string pointer `j`.
  |
  style: {
    stroke: "#CCC"
    fill: "#FAFAFA"
  }
}