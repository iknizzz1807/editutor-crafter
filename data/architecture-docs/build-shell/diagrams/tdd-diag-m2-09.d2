layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Pipeline Data Flow: `cmd1 | cmd2 | cmd3`
    ### Concurrent Execution & Kernel Pipe Synchronization
  |
  near: top-center
}

direction: right

# ---------------------------------------------------------------------------------------
# Styling Classes
# ---------------------------------------------------------------------------------------
classes: {
  process: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 4
    }
  }
  fd_node: {
    shape: hexagon
    width: 130
    height: 60
    style: {
      font-size: 11
      bold: true
    }
  }
  kernel_buffer: {
    shape: cylinder
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 3
    }
  }
  data_stream: {
    style: {
      stroke: "#2E7D32"
      stroke-width: 4
      animated: true
    }
  }
  annotation_box: {
    style: {
      stroke-dash: 3
      border-radius: 8
      font-size: 12
    }
  }
}

# ---------------------------------------------------------------------------------------
# User Space Container
# ---------------------------------------------------------------------------------------
user_space: "User Space (Ring 3)" {
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 5
  }

  cmd1: {
    label: "Process: cmd1 (Writer)"
    class: process
    fd0: "stdin (fd 0)" {
      class: fd_node
      style.fill: "#BBDEFB"
    }
    fd1: "stdout (fd 1)" {
      class: fd_node
      style.fill: "#90CAF9"
    }
    
    info: {
      label: |md
        **PID: 1001**
        - Role: Data Producer
        - Mode: Blocking Write
      |
      shape: rectangle
      style.fill: transparent
      style.stroke-width: 0
    }
  }

  cmd2: {
    label: "Process: cmd2 (Filter)"
    class: process
    fd0: "stdin (fd 0)" {
      class: fd_node
      style.fill: "#BBDEFB"
    }
    fd1: "stdout (fd 1)" {
      class: fd_node
      style.fill: "#90CAF9"
    }
    
    info: {
      label: |md
        **PID: 1002**
        - Role: Transformation
        - Mode: Sync IO
      |
      shape: rectangle
      style.fill: transparent
      style.stroke-width: 0
    }
  }

  cmd3: {
    label: "Process: cmd3 (Consumer)"
    class: process
    fd0: "stdin (fd 0)" {
      class: fd_node
      style.fill: "#BBDEFB"
    }
    fd1: "stdout (fd 1)" {
      class: fd_node
      style.fill: "#90CAF9"
    }
    
    info: {
      label: |md
        **PID: 1003**
        - Role: Final Sink
        - Mode: Read-Loop
      |
      shape: rectangle
      style.fill: transparent
      style.stroke-width: 0
    }
  }
}

# ---------------------------------------------------------------------------------------
# Kernel Space Container
# ---------------------------------------------------------------------------------------
kernel_space: "Kernel Space (Ring 0)" {
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    stroke-width: 3
  }

  pipe0: {
    label: |md
      **Pipe Buffer [0]**
      Circular Ring Buffer
      Size: 64 KB
    |
    class: kernel_buffer
    tooltip: "Memory allocated in kernel pages"
  }

  pipe1: {
    label: |md
      **Pipe Buffer [1]**
      Circular Ring Buffer
      Size: 64 KB
    |
    class: kernel_buffer
    tooltip: "Memory allocated in kernel pages"
  }
}

terminal: "TTY /dev/pts/0" {
  shape: display
  style: {
    fill: "#263238"
    font-color: "#ECEFF1"
  }
}

# ---------------------------------------------------------------------------------------
# Data Flow Connections
# ---------------------------------------------------------------------------------------
user_space.cmd1.fd1 -> kernel_space.pipe0: "SYS_WRITE" {
  class: data_stream
}

kernel_space.pipe0 -> user_space.cmd2.fd0: "SYS_READ" {
  class: data_stream
}

user_space.cmd2.fd1 -> kernel_space.pipe1: "SYS_WRITE" {
  class: data_stream
}

kernel_space.pipe1 -> user_space.cmd3.fd0: "SYS_READ" {
  class: data_stream
}

user_space.cmd3.fd1 -> terminal: "TTY Write" {
  class: data_stream
  style.stroke: "#90CAF9"
}

# ---------------------------------------------------------------------------------------
# Technical Annotations
# ---------------------------------------------------------------------------------------
sigpipe_note: {
  label: |md
    ### SIGPIPE Flow Control
    If a reader (cmd3) terminates:
    1. `pipe[1]` read end count drops to 0.
    2. `cmd2` next `write()` returns **EPIPE**.
    3. Kernel delivers **SIGPIPE** to `cmd2`.
    4. Error propagates upstream.
  |
  near: kernel_space.pipe1
  class: annotation_box
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
}

concurrency_note: {
  label: |md
    ### Scheduling Semantics
    - Parallelism: Processes run on 
      separate CPU cores.
    - Blocking: Producer sleeps if 
      buffer is full; Consumer 
      sleeps if buffer is empty.
  |
  near: user_space.cmd2
  class: annotation_box
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}

# ---------------------------------------------------------------------------------------
# Legend
# ---------------------------------------------------------------------------------------
legend: {
  label: "Manual Legend"
  near: bottom-right
  style.stroke-dash: 0
  style.fill: white
  
  l_proc: {
    label: "Process Node"
    class: process
  }
  l_buf: {
    label: "Kernel Pipe"
    class: kernel_buffer
  }
  l_fd: {
    label: "Descriptor"
    class: fd_node
    style.fill: "#BBDEFB"
  }
}