vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Process Groups and Terminal Control
  *tcsetpgrp() designates which process group receives terminal signals*
| {near: top-center}

classes: {
  process_group: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
    }
  }
  shell_pgid: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 3
    }
  }
  job_pgid: {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
  foreground: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 3
      shadow: true
    }
  }
  process: {
    shape: rectangle
    style: {
      fill: white
      stroke: "#666"
      border-radius: 4
    }
  }
  terminal: {
    shape: diamond
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  signal: {
    style: {
      stroke: red
      stroke-dash: 3
      animated: true
    }
  }
  control: {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
}

direction: right

terminal: "Controlling\nTerminal\n(/dev/tty)" {
  class: terminal
  near: top-center
  current_fg: |md
    **Foreground PGID:**
    `tcgetpgrp()`
  |
}

spacer1: "" {style.opacity: 0}

pgid_table: {
  label: "Process Group Table"
  
  shell_row: {
    label: "Shell PGID\n(e.g., 1000)"
    class: [shell_pgid; foreground]
    shell_proc: "shell\nPID=1000\nPGID=1000" {
      class: process
    }
  }
  
  job_row: {
    label: "Job PGID\n(e.g., 2000)"
    class: [job_pgid]
    cmd1: "cmd1\nPID=2000\nPGID=2000" {
      class: process
    }
    cmd2: "cmd2\nPID=2001\nPGID=2000" {
      class: process
    }
    cmd3: "cmd3\nPID=2002\nPGID=2000" {
      class: process
    }
    cmd1 -> cmd2 -> cmd3: "same pipe" {
      style.stroke-dash: 2
    }
  }
}

terminal -> pgid_table.shell_row: "tcsetpgrp(STDIN, 1000)\nShell is foreground" {
  class: control
  label.near: center-right
}

terminal -> pgid_table.job_row: "tcsetpgrp(STDIN, 2000)\nJob is foreground" {
  class: control
  style.stroke: "#E65100"
  label.near: center-right
}

legend: {
  near: bottom-center
  fg_marker: "■ Foreground Process Group" {
    shape: text
    style.font-color: "#2E7D32"
  }
  signal_label: "~~~> Terminal Signal (SIGINT, SIGTSTP)" {
    shape: text
    style.font-color: red
  }
  ctrl_label: "───> tcsetpgrp() call" {
    shape: text
    style.font-color: "#1565C0"
  }
}

explanation: |'md
## How Terminal Control Works
**1. Shell startup:**

c
shell_pgid = getpgrp();         // Shell's own PGID
tcsetpgrp(STDIN, shell_pgid);   // Take terminal control


**2. Job launch:**

c
pid = fork();
setpgid(pid, pid);              // New process group (PGID = PID)
tcsetpgrp(STDIN, job_pgid);     // Give terminal to job
wait_for_job();
tcsetpgrp(STDIN, shell_pgid);   // Reclaim terminal


**3. Signal delivery:**
- Ctrl+C → Terminal sends **SIGINT** to foreground PGID
- Ctrl+Z → Terminal sends **SIGTSTP** to foreground PGID
- **All processes** in the group receive the signal

## Key Insight
The terminal doesn't send signals to individual processes — it sends to the **entire foreground process group**. This is why `cmd1 | cmd2 | cmd3` all stop when you press Ctrl+Z.
'| {
  near: bottom-center
}