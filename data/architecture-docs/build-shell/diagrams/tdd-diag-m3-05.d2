vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
# Participants
signal_handler: SIGCHLD Handler
self_pipe: Self-Pipe
main_loop: Main Loop
reaper: reap_children()
job_table: Job Table
# Initial state annotation
signal_handler."async-signal-safe\n(only write())"
main_loop."select() on pipe fd"
# Signal arrival and handler execution
note1: Signal arrives {
  signal_handler -> self_pipe: write(pipe_fd, "C", 1) {
    style.stroke: red
    style.bold: true
  }
  self_pipe."data available"
}
# Main loop wake-up
note2: select() returns {
  main_loop <- self_pipe: pipe_fd readable
}
# Pipe draining
main_loop -> self_pipe: read() until empty {
  style.stroke-dash: 3
  style.stroke: blue
}
# Child reaping
main_loop -> reaper: reap_children() {
  style.stroke: green
}
# Reaping loop
note3: waitpid loop {
  reaper -> reaper: waitpid(-1, &status, WNOHANG|WUNTRACED|WCONTINUED) {
    style.stroke: purple
    style.stroke-dash: 5
  }
  reaper -> job_table: update_job_state(pid, status) {
    style.stroke: orange
  }
  reaper -> reaper: loop until no children {
    style.stroke: purple
    style.stroke-dash: 5
  }
}
# State updates shown
job_table."state = DONE/STOPPED/RUNNING"
# Return to main loop
reaper -> main_loop: return reaped_count {
  style.stroke: green
}
main_loop."continue REPL"
# Legend annotation
legend: |md
  **Critical Invariants:**
  - Handler uses ONLY `write()` (async-signal-safe)
  - `waitpid()` loops until returns 0 (multiple children)
  - Job table modifications block SIGCHLD
  - Main loop handles all non-safe operations
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#666"
}