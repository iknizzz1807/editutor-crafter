vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
  colors: {
    running: "#4CAF50"
    stopped: "#FF9800"
    done: "#9E9E9E"
    illegal: "#F44336"
  }
}

title: "Job State Machine" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

states: {
  RUNNING: "RUNNING" {
    shape: circle
    style: {
      fill: ${colors.running}
      stroke: "#2E7D32"
      stroke-width: 3
      font-color: white
      bold: true
    }
  }
  STOPPED: "STOPPED" {
    shape: circle
    style: {
      fill: ${colors.stopped}
      stroke: "#E65100"
      stroke-width: 3
      font-color: white
      bold: true
    }
  }
  DONE: "DONE" {
    shape: circle
    style: {
      fill: ${colors.done}
      stroke: "#616161"
      stroke-width: 3
      font-color: white
      bold: true
    }
  }
}

# Entry node
initial: ● {
  near: top-left
  shape: circle
  width: 20
  style.fill: black
}

# Standard valid transitions
initial -> states.RUNNING: "fork()" {
  style: {
    stroke-width: 2
    stroke: black
  }
}

states.RUNNING -> states.STOPPED: "SIGTSTP\nSIGSTOP\nSIGTTIN\nSIGTTOU" {
  style: {
    stroke-width: 2
    stroke: "#E65100"
  }
}

states.STOPPED -> states.RUNNING: "SIGCONT\n(via fg/bg)" {
  style: {
    stroke-width: 2
    stroke: ${colors.running}
  }
}

states.RUNNING -> states.DONE: "exit(N)\nSIGTERM\nSIGKILL" {
  style: {
    stroke-width: 2
    stroke: ${colors.done}
  }
}

states.STOPPED -> states.DONE: "SIGKILL" {
  style: {
    stroke-width: 2
    stroke: ${colors.done}
    stroke-dash: 3
  }
}

# Explicitly marking illegal transitions as red dashed as per specification
states.DONE -> states.RUNNING: "ILLEGAL" {
  style: {
    stroke: ${colors.illegal}
    stroke-dash: 5
    stroke-width: 2
  }
}

illegal_transitions: {
  label: "ILLEGAL TRANSITIONS"
  near: bottom-right
  style: {
    fill: "#FFEBEE"
    stroke: ${colors.illegal}
    stroke-width: 2
    border-radius: 8
  }
  il1: "DONE → ANY STATE" {
    shape: text
    style.font-color: ${colors.illegal}
  }
  il2: "RUNNING → RUNNING" {
    shape: text
    style.font-color: ${colors.illegal}
  }
  il3: "DONE → RUNNING" {
    shape: text
    style.font-color: ${colors.illegal}
  }
  il4: "DONE → STOPPED" {
    shape: text
    style.font-color: ${colors.illegal}
  }
}

invariants: |md
  ### State Invariants
  - **DONE** is terminal; no valid outgoing transitions.
  - **SIGKILL** is a global sink, forcing any state to `DONE`.
  - **STOPPED** requires an external `SIGCONT` to re-enter `RUNNING`.
  - Terminal control and process context are released upon entry to `DONE`.
| {
  near: bottom-left
  shape: text
  style: {
    font-size: 14
    font-color: "#424242"
  }
}

legend: {
  near: top-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  legend_title: "Legend" {
    shape: text
    style: {
      bold: true
      underline: true
    }
  }
  l1: "● Initial Entry" {
    shape: text
  }
  l2: "──▶ Standard Transition" {
    shape: text
  }
  l3: "─ ─▶ Async/Forced" {
    shape: text
    style.font-color: ${colors.done}
  }
  l4: "─ ─▶ ILLEGAL" {
    shape: text
    style.font-color: ${colors.illegal}
  }
}