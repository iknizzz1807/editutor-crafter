vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |'md
  # if Statement AST and Evaluation
  **Exit Status 0 = True (branch to then)**
  **Exit Status ≠0 = False (branch to else)**
'| {near: top-center}

classes: {
  ast_node: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      font: mono
      border-radius: 4
    }
  }
  condition: {
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
      border-radius: 4
    }
  }
  body: {
    style: {
      fill: "#D1FAE5"
      stroke: "#059669"
      stroke-width: 2
      border-radius: 4
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 2
    }
  }
  flow: {
    style: {
      stroke: "#6B7280"
      stroke-width: 2
      font: mono
      font-size: 12
    }
  }
  true_flow: {
    style: {
      stroke: "#059669"
      stroke-width: 3
      animated: true
    }
  }
  false_flow: {
    style: {
      stroke: "#DC2626"
      stroke-width: 2
      stroke-dash: 4
    }
  }
}

# === AST STRUCTURE (LEFT SIDE) ===
ast_section: "AST Structure (Syntax Tree)" {
  if_node: "NODE_IF\n{\n  condition: ASTNode*\n  then_body: ASTNode*\n  else_body: ASTNode* (nullable)\n}" {
    class: ast_node
    shape: rectangle
    width: 320
  }

  if_node -> condition_ref: "condition" {
    class: flow
    style.stroke: "#D97706"
  }
  if_node -> then_ref: "then_body" {
    class: flow
    style.stroke: "#059669"
  }
  if_node -> else_ref: "else_body" {
    class: flow
    style.stroke: "#6B7280"
  }

  condition_ref: "Command AST\n(e.g., SIMPLE_CMD)" {
    class: condition
    width: 180
  }
  then_ref: "Compound List\n(then branch)" {
    class: body
    width: 180
  }
  else_ref: "Compound List\n(else branch)\n[or nested IF for elif]" {
    class: body
    width: 200
    style.stroke-dash: 3
  }
}

# === EVALUATION FLOW (RIGHT SIDE) ===
eval_section: "Evaluation Flow (Runtime)" {
  start: "●" {
    shape: circle
    style.fill: "#2563EB"
    width: 30
  }
  exec_cond: "Execute\ncondition\ncommand" {
    class: condition
    width: 140
  }
  get_status: 'Get exit status\n\$?' {
    class: ast_node
    width: 120
    tooltip: 'The special variable $? represents the exit status of the last executed command.'
  }
  decision: "status == 0?" {
    class: decision
    width: 140
    height: 100
  }
  exec_then: "Execute\nthen_body" {
    class: body
    width: 140
    style.fill: "#86EFAC"
  }
  exec_else: "Execute\nelse_body\n(if present)" {
    class: body
    width: 140
    style.fill: "#FCA5A5"
  }
  return_status: "Return body's\nexit status" {
    class: ast_node
    width: 140
  }
  end: "●" {
    shape: circle
    style.fill: "#6B7280"
    width: 30
  }

  start -> exec_cond {
    class: flow
  }
  exec_cond -> get_status: "status" {
    class: flow
  }
  get_status -> decision {
    class: flow
  }

  decision -> exec_then: "YES\n(0 = true)" {
    class: true_flow
    target-arrowhead: triangle
  }
  decision -> exec_else: "NO\n(≠0 = false)" {
    class: false_flow
    target-arrowhead: triangle
  }

  exec_then -> return_status {
    class: true_flow
  }
  exec_else -> return_status {
    class: false_flow
  }
  return_status -> end {
    class: flow
  }
}

# === EXAMPLE (BOTTOM) ===
example: "Example trace: if false; then echo a; elif true; then echo b; else echo c; fi" {
  ex_ast: "AST Representation" {
    outer_if: "IF #1" {
      class: ast_node
      style.fill: "#DBEAFE"
    }
    outer_if_cond: "false\n→ exits 1" {
      class: condition
    }
    outer_if_then: "echo a" {
      class: body
      style.opacity: 0.4
    }
    outer_if_else: "IF #2 (elif)" {
      class: ast_node
      style.fill: "#DBEAFE"
    }
    inner_if_cond: "true\n→ exits 0" {
      class: condition
    }
    inner_if_then: "echo b\n← EXECUTED" {
      class: body
      style.fill: "#86EFAC"
      style.bold: true
      style.stroke-width: 4
    }
    inner_if_else: "echo c" {
      class: body
      style.opacity: 0.4
    }

    outer_if -> outer_if_cond
    outer_if -> outer_if_then
    outer_if -> outer_if_else
    outer_if_else -> inner_if_cond
    outer_if_else -> inner_if_then
    outer_if_else -> inner_if_else
  }

  ex_trace: |'md
    ### Execution Trace
    1. **Execute `false`**: The shell calls the binary/builtin `false`, which returns exit status **1**.
    2. **Evaluate Condition**: `1 ≠ 0`, therefore the condition is logically **FALSE**.
    3. **Branching**: Skip `then_body` ("echo a"), jump to `else_body`.
    4. **Evaluate Else**: The else body is a nested IF.
    5. **Execute `true`**: Returns exit status **0**.
    6. **Branching**: `0 == 0`, therefore the condition is logically **TRUE**.
    7. **Execute Then**: Runs `echo b`.
    8. **Result**: Output is `b`.
  '| {
    width: 400
  }
}

# === KEY INSIGHT BOX ===
insight: |'md
  ### Key Insight: Commands as Conditions
  The shell does **not** evaluate boolean expressions in the traditional C/Java sense.
  It **executes commands** and checks their integer exit status (\$?).

  | Command Type | Example | Exit Status (\$?) | Logic |
  | :--- | :--- | :--- | :--- |
  | Logic Utility | `true` | 0 | True |
  | Logic Utility | `false` | 1 | False |
  | Test Command | `[ 5 -gt 3 ]` | 0 | True |
  | Standard Binary | `grep "foo" file` | 0 (if found) | True |

  - Any command in the PATH can serve as an `if` condition!
'| {
  near: bottom-center
  style: {
    fill: "#F3E8FF"
    stroke: "#9333EA"
    stroke-width: 2
    border-radius: 8
  }
  width: 650
}
