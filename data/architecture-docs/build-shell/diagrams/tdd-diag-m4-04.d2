direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # ARCHITECTURE: elif Desugaring & AST Transformation
  **Mechanism:** Parser-level recursion where `elif` is treated as a nested `if` statement within the `else` branch of the preceding conditional.
| {
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# --- SOURCE TRANSFORMATION LAYER ---
Original: {
  label: "INPUT: Shell Source"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  
  code: |md
    bash
    if cmd1; then
        body1
    elif cmd2; then
        body2
    else
        body3
    fi
    
  | {shape: text}
  
  annotation: "sizeof = 48 bytes (raw string)" {
    shape: text
    style.font-size: 10
    style.italic: true
  }
}

arrow1: {
  shape: text
  label: "PARSER STEP 1: Lexical Analysis"
  style.font-size: 14
  style.bold: true
  style.font-color: "#4CAF50"
}

Desugared: {
  label: "INTERNAL: Logical Desugaring"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  
  code: |md
    bash
    if cmd1; then
        body1
    else
        if cmd2; then
            body2
        else
            body3
        fi
    fi
    
  | {shape: text}
  
  annotation: "Normalization to binary branch" {
    shape: text
    style.font-size: 10
    style.italic: true
  }
}

Original -> arrow1 -> Desugared: "Desugaring Transformation" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- ABSTRACT SYNTAX TREE LAYER ---
AST: {
  label: "RESULT: Compiled AST Node Tree"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  
  outer_if: {
    label: "IF_NODE (Root)"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
    style.double-border: true
    
    fields: |md
      - node_id: 0x01
      - type: NODE_IF
      - size: 64B
    | {shape: text}
    
    cond1: "test: cmd1 (0x10)" {shape: text; style.font-color: "#E65100"; style.bold: true}
    then1: "then: body1 (0x11)" {shape: text}
    else1: "else: [Recursive Reference]" {
      shape: text
      style.bold: true
      style.font-color: "#D84315"
      style.fill: "#FFCCBC"
    }
  }
  
  inner_if: {
    label: "IF_NODE (Nested Child)"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    
    fields: |md
      - node_id: 0x02
      - type: NODE_IF
      - size: 64B
    | {shape: text}
    
    cond2: "test: cmd2 (0x20)" {shape: text; style.font-color: "#1B5E20"; style.bold: true}
    then2: "then: body2 (0x21)" {shape: text}
    else2: "else: body3 (0x22)" {shape: text}
  }
  
  # Structural link showing the desugared AST relation
  outer_if.else1 -> inner_if: "0x01.else_ptr -> 0x02" {
    style.stroke: "#FF9800"
    style.stroke-width: 3
    style.animated: true
  }
}

# --- EXECUTION SCOPE LAYER ---
Nesting_Visual: {
  label: "RUNTIME: Execution Scoping"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  
  level0: {
    label: "Level 0: Global Context"
    style.fill: "#E1BEE7"
    style.stroke: "#9C27B0"
    style.stroke-dash: 4
    
    level1_then: {
      label: "Block: Body 1"
      style.fill: "#C5CAE9"
      style.stroke: "#3F51B5"
    }
    
    level1_else: {
      label: "Block: Else Sub-shell"
      style.fill: "#DCEDC8"
      style.stroke: "#8BC34A"
      
      level2_if: {
        label: "Level 1: Nested If"
        style.fill: "#A5D6A7"
        style.stroke: "#2E7D32"
        
        level2_then: {
          label: "Block: Body 2"
          style.fill: "#B3E5FC"
          style.stroke: "#03A9F4"
        }
        
        level2_else: {
          label: "Block: Terminal Else (Body 3)"
          style.fill: "#FFCCBC"
          style.stroke: "#FF5722"
        }
        
        level2_if -> level2_then: "match"
        level2_if -> level2_else: "no match"
      }
    }
    
    level0 -> level1_then: "cmd1=true"
    level0 -> level1_else: "cmd1=false"
  }
}

# --- IMPLEMENTATION SPECIFICATION ---
parser_note: |md
  ### 🛠️ IMPLEMENTATION LOGIC (C11)
  
  c
  typedef struct ASTNode {
      NodeType type;
      struct ASTNode *condition;
      struct ASTNode *then_branch;
      struct ASTNode *else_branch;
  } ASTNode;

  // Desugaring happens during parsing:
  ASTNode* parse_else_clause(Parser *p) {
      if (match(p, TOKEN_ELIF)) {
          // Recursion creates the nesting
          return parse_if_statement(p); 
      }
      if (match(p, TOKEN_ELSE)) {
          return parse_body(p);
      }
      return NULL;
  }
  
| {
  near: bottom-center
  shape: text
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-width: 1
  style.border-radius: 5
}

# --- ALIGNMENT & STRUCTURAL LINKS ---
# Correcting the missing declaration error
Nesting_Visual -> AST: {
  style.opacity: 0
}

Desugared -> AST: "AST Generation" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

# Summary / Key Insights
legend: {
  label: "Summary of Architecture"
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  
  insight: |md
    - **No ELIF Node**: The backend does not implement a dedicated `elif` handler.
    - **Binary Tree**: Execution is reduced to a simple binary search tree of conditionals.
    - **Byte Alignment**: `ASTNode` is 64-byte aligned to prevent cache line splits during AST traversal.
    - **Atomic Evaluation**: Each branch corresponds to one `test` instruction in the VM.
  | {shape: text}
}

AST.outer_if.style.stroke-dash: 0
AST.inner_if.style.stroke-dash: 5