vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# WHILE LOOP AST STRUCTURE
while_ast: {
  label: "NODE_WHILE\nAST Structure"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  while_node: "ASTNode\nNodeType: NODE_WHILE" {
    shape: rectangle
    style.fill: "#2E86AB"
    style.font-color: white
    style.bold: true
  }
  data: "data.while_loop" {
    shape: rectangle
    style.fill: "#A8DADC"
  }
  condition: "condition\nASTNode*\n(Command to execute)" {
    shape: rectangle
    style.fill: "#F4A261"
    style.stroke: "#E76F51"
  }
  body: "body\nASTNode*\n(Compound list)" {
    shape: rectangle
    style.fill: "#2A9D8F"
    style.font-color: white
  }
  is_until: "is_until: bool\n(false=while, true=until)" {
    shape: rectangle
    style.fill: "#E9ECEF"
  }
  while_node -> data
  data -> condition
  data -> body
  data -> is_until
}
# EXECUTION FLOW
execution_flow: {
  label: "while Loop Execution Flow"
  style.fill: "#F8F9FA"
  style.stroke: "#6C757D"
  start: "START\nloop_enter()" {
    shape: circle
    style.fill: "#28A745"
    style.font-color: white
  }
  setup_break: "setjmp(break_target)" {
    shape: rectangle
    style.fill: "#FFE082"
    style.stroke: "#FF8F00"
  }
  setup_continue: "setjmp(continue_target)" {
    shape: rectangle
    style.fill: "#FFE082"
    style.stroke: "#FF8F00"
  }
  check_condition: "EXECUTE\ncondition" {
    shape: diamond
    style.fill: "#F4A261"
    style.stroke: "#E76F51"
  }
  eval_condition: "status == 0?\n(for while)" {
    shape: diamond
    style.fill: "#B8D4E3"
  }
  exec_body: "EXECUTE\nbody" {
    shape: rectangle
    style.fill: "#2A9D8F"
    style.font-color: white
  }
  continue_jump: "continue called?\n(longjmp)" {
    shape: diamond
    style.fill: "#E9ECEF"
    style.stroke: "#6C757D"
  }
  break_jump: "break called?\n(longjmp)" {
    shape: diamond
    style.fill: "#E9ECEF"
    style.stroke: "#6C757D"
  }
  exit_loop: "loop_exit()\nRETURN last_status" {
    shape: rectangle
    style.fill: "#DC3545"
    style.font-color: white
  }
  end: "END" {
    shape: circle
    style.fill: "#6C757D"
    style.font-color: white
  }
  start -> setup_break: "enter loop" {
    style.stroke: "#28A745"
    style.stroke-width: 2
  }
  setup_break -> setup_continue
  setup_continue -> check_condition: "check condition"
  check_condition -> eval_condition: "get exit status"
  eval_condition -> exec_body: "YES (status==0)" {
    style.stroke: "#28A745"
    style.bold: true
    label: "YES\n(continue)"
  }
  eval_condition -> exit_loop: "NO (status!=0)" {
    style.stroke: "#DC3545"
    label: "NO\n(exit loop)"
  }
  exec_body -> continue_jump: "body complete"
  continue_jump -> check_condition: "NO" {
    style.stroke-dash: 3
    label: "NO\n(next iteration)"
  }
  continue_jump -> check_condition: "YES\n(jumped)" {
    style.stroke: "#FF8F00"
    style.stroke-dash: 5
    style.animated: true
  }
  setup_break -> break_jump: "break longjmp" {
    style.stroke: "#DC3545"
    style.stroke-dash: 5
    style.animated: true
  }
  break_jump -> exit_loop: "break triggered"
  exit_loop -> end
}
# UNTIL VARIANT
until_variant: {
  label: "until Loop Variant"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  note: |md
    **until** inverts the condition logic:
    - `while`: loop **while** condition succeeds (exit 0)
    - `until`: loop **until** condition succeeds (exit 0)
    c
    if (while_data->is_until) {
      // until: loop while condition FAILS
      should_continue = (cond_status != 0);
    } else {
      // while: loop while condition SUCCEEDS
      should_continue = (cond_status == 0);
    }
    
  | {
    shape: rectangle
    style.fill: white
    style.stroke: "#E65100"
  }
}
# LOOP CONTROL FLOW
loop_control: {
  label: "break/continue Control Flow"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  iteration: "Normal Iteration" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  break_path: "break → longjmp(break_target)" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  continue_path: "continue → longjmp(continue_target)" {
    shape: rectangle
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
  iteration -> break_path: "break N" {
    style.stroke: "#C62828"
    style.stroke-dash: 3
  }
  iteration -> continue_path: "continue N" {
    style.stroke: "#F9A825"
    style.stroke-dash: 3
  }
  break_path -> exit: "exit loop immediately"
  continue_path -> check: "jump to condition check"
}
# MEMORY LAYOUT
memory: {
  label: "ASTWhile Memory Layout (24 bytes)"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  offset_0: "0x00: condition (ASTNode*) - 8 bytes" {
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  offset_8: "0x08: body (ASTNode*) - 8 bytes" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  offset_16: "0x10: is_until (bool) - 1 byte\n+ 7 bytes padding" {
    shape: rectangle
    style.fill: "#FFF9C4"
  }
  offset_0 -> offset_8 -> offset_16
}
# CONNECTIONS BETWEEN SECTIONS
while_ast -> execution_flow: "parsed AST\nexecuted by" {
  style.stroke: "#6C757D"
  style.stroke-dash: 3
}
execution_flow -> loop_control: "control flow\nmodified by" {
  style.stroke: "#6C757D"
  style.stroke-dash: 3
}