vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # for Loop Word List Expansion
  **Word list expanded ONCE at loop start, then iterated**
| {near: top-center}
# Input: AST with raw word list
input_section: {
  label: "AST Node: NODE_FOR"
  shape: rectangle
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  variable: |md
    variable: `"file"`
  | {shape: text}
  word_list: |md
    word_list: `["*.txt", "$DIR/data"]`
    (raw tokens from parser)
  | {shape: text}
  body: |md
    body: `{ echo "Processing $file"; }`
  | {shape: text}
}
# Phase 1: Expansion
expansion_phase: {
  label: "PHASE 1: Word List Expansion\n(executed ONCE before iteration)"
  shape: rectangle
  style.fill: "#C7F1FF"
  style.stroke: "#4A90D9"
  style.stroke-width: 2
  step1_tilde: {
    label: "1. Tilde Expansion"
    shape: rectangle
    style.fill: white
    entry: |md
      `"~user/docs/*.txt"`
    | {shape: text}
    result: |md
      `"/home/user/docs/*.txt"`
    | {shape: text}
    style.stroke-dash: 3
  }
  step2_param: {
    label: "2. Parameter Expansion"
    shape: rectangle
    style.fill: white
    entry: |md
      `"$DIR/data"`
    | {shape: text}
    result: |md
      `"/project/data"` (if DIR=/project)
    | {shape: text}
  }
  step3_cmdsub: {
    label: "3. Command Substitution"
    shape: rectangle
    style.fill: white
    entry: |md
      `"$(echo test)"`
    | {shape: text}
    result: |md
      `"test"`
    | {shape: text}
    style.stroke-dash: 3
  }
  step4_field: {
    label: "4. Field Splitting (IFS)"
    shape: rectangle
    style.fill: white
    entry: |md
      `"a b c"` (unquoted result)
    | {shape: text}
    result: |md
      `["a", "b", "c"]` (3 words)
    | {shape: text}
  }
  step5_glob: {
    label: "5. Glob Expansion"
    shape: rectangle
    style.fill: white
    entry: |md
      `"*.txt"`
    | {shape: text}
    result: |md
      `["a.txt", "b.txt", "c.txt"]`
    | {shape: text}
  }
}
# Expanded word array
word_array: {
  label: "Expanded Word Array\n(in memory, iteration source)"
  shape: cylinder
  style.fill: "#E4DBFE"
  style.stroke: "#8B5CF6"
  style.stroke-width: 2
  words: |md
    
    words[0] = "a.txt"
    words[1] = "b.txt"  
    words[2] = "c.txt"
    words[3] = "/project/data"
    word_count = 4
    
  | {shape: text}
}
# Iteration loop
iteration_loop: {
  label: "ITERATION LOOP\n(each word → one body execution)"
  shape: rectangle
  style.fill: "#FCE7C6"
  style.stroke: "#ED800C"
  style.stroke-width: 2
  iter_header: {
    label: "for (i = 0; i < word_count; i++)"
    shape: text
    style.font: mono
    style.bold: true
  }
  # Iteration 1
  iter1: {
    label: "Iteration 1 (i=0)"
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    assign1: |md
      **setenv("file", "a.txt")**
    | {shape: text}
    exec1: |md
      execute_ast(body)
      → `echo "Processing a.txt"`
    | {shape: text}
  }
  # Iteration 2
  iter2: {
    label: "Iteration 2 (i=1)"
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    assign2: |md
      **setenv("file", "b.txt")**
    | {shape: text}
    exec2: |md
      execute_ast(body)
      → `echo "Processing b.txt"`
    | {shape: text}
  }
  # Iteration 3
  iter3: {
    label: "Iteration 3 (i=2)"
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    assign3: |md
      **setenv("file", "c.txt")**
    | {shape: text}
    exec3: |md
      execute_ast(body)
      → `echo "Processing c.txt"`
    | {shape: text}
  }
  # Iteration 4
  iter4: {
    label: "Iteration 4 (i=3)"
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    assign4: |md
      **setenv("file", "/project/data")**
    | {shape: text}
    exec4: |md
      execute_ast(body)
      → `echo "Processing /project/data"`
    | {shape: text}
  }
  # More iterations indicator
  more_iters: {
    label: "... (continue until i >= word_count)"
    shape: text
    style.italic: true
    style.font-color: "#666666"
  }
}
# Output
output_section: {
  label: "Output"
  shape: rectangle
  style.fill: white
  style.stroke: "#333333"
  output: |md
    
    Processing a.txt
    Processing b.txt
    Processing c.txt
    Processing /project/data
    
  | {shape: text}
}
# Key insight box
key_insight: {
  label: |md
    ## 🔑 Key Insight
    **Expansion happens ONCE at loop start**
    bash
    files="*.txt"
    for f in $files; do
        # $files was expanded to ["a.txt", "b.txt"]
        # Creating new .txt files here does NOT
        # add them to the iteration!
        touch new.txt
    done
    # Loop iterates only over original expansion
    
    Modifying the loop variable inside the body
    does NOT affect which values are iterated:
    bash
    for i in 1 2 3; do
        i=100  # Changes $i
        echo $i  # Prints: 100, 100, 100
    done
    # But loop still runs 3 times!
    
  |
  shape: rectangle
  style.fill: "#FFF9C9"
  style.stroke: "#F59E03"
  near: bottom-center
}
# Flow connections
input_section -> expansion_phase: "expand_word_list()"
expansion_phase -> word_array: "store results"
word_array -> iteration_loop: "iterate"
iteration_loop.iter1 -> iteration_loop.iter2: "i++"
iteration_loop.iter2 -> iteration_loop.iter3: "i++"
iteration_loop.iter3 -> iteration_loop.iter4: "i++"
iteration_loop.iter4 -> iteration_loop.more_iters: "i++"
iteration_loop -> output_section: "stdout"