vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    jump_buf: "#E8F5E9"
    loop_depth: "#E3F2FD"
    break_target: "#FFEBEE"
    continue_target: "#FFF3E0"
    active: "#4CAF50"
    code: "#263238"
  }
}
title: |md
  # break/continue with setjmp/longjmp
  Jump buffer array indexed by loop depth
| {near: top-center}
direction: right
Jump_Buffer_Array: {
  label: "Jump Buffer Arrays\n(globals)"
  style.fill: ${colors.jump_buf}
  Break_Targets: {
    label: "g_loop_break_targets[MAX_LOOP_DEPTH]"
    style.fill: ${colors.break_target}
    style.stroke: "#C62828"
    buf0: "buf[0]" {style.fill: "#FFCDD2"}
    buf1: "buf[1]" {style.fill: "#FFCDD2"}
    buf2: "buf[2]" {style.fill: "#FFCDD2"}
    buf3: "..." {shape: text}
    bufN: "buf[63]" {style.fill: "#FFCDD2"}
  }
  Continue_Targets: {
    label: "g_loop_continue_targets[MAX_LOOP_DEPTH]"
    style.fill: ${colors.continue_target}
    style.stroke: "#E65100"
    cbuf0: "buf[0]" {style.fill: "#FFE0B2"}
    cbuf1: "buf[1]" {style.fill: "#FFE0B2"}
    cbuf2: "buf[2]" {style.fill: "#FFE0B2"}
    cbuf3: "..." {shape: text}
    cbufN: "buf[63]" {style.fill: "#FFE0B2"}
  }
  Depth_Counter: {
    label: "g_loop_depth"
    style.fill: ${colors.loop_depth}
    style.stroke: "#1565C0"
    value: "= 2 (current depth)"
  }
}
Loop_Execution: {
  label: "Loop Execution Flow"
  style.fill: "#FAFAFA"
  enter: "loop_enter()\n  depth++"
  setup_break: "setjmp(break_targets[depth])"
  setup_continue: "setjmp(continue_targets[depth])"
  execute_body: "execute body"
  normal_exit: "loop_exit()\n  depth--"
  enter -> setup_break
  setup_break -> setup_continue
  setup_continue -> execute_body
  execute_body -> normal_exit: "loop completes"
}
Break_Continue_Flow: {
  label: "break/continue Execution"
  style.fill: "#FAFAFA"
  builtin_check: {
    label: "builtin_break/builtin_continue"
    style.fill: "#ECEFF1"
    check_depth: "if (depth == 0)\n  error: not in loop"
    parse_count: "count = argv[1] ?: 1"
    validate: "if (count > depth)\n  error: bad loop count"
    target: "target = depth - count"
    check_depth -> parse_count
    parse_count -> validate
    validate -> target
  }
  break_jump: {
    label: "break: longjmp"
    style.fill: ${colors.break_target}
    style.stroke: "#C62828"
    style.stroke-width: 3
    break_code: "longjmp(break_targets[target], LOOP_BREAK)"
  }
  continue_jump: {
    label: "continue: longjmp"
    style.fill: ${colors.continue_target}
    style.stroke: "#E65100"
    style.stroke-width: 3
    continue_code: "longjmp(continue_targets[target], LOOP_CONTINUE)"
  }
  target -> break_code
  target -> continue_jump
}
Return_Flow: {
  label: "setjmp Return Values"
  style.fill: "#E8F5E9"
  initial: "setjmp returns 0\n(initial call)"
  break_return: "setjmp returns LOOP_BREAK\n(after longjmp from break)"
  continue_return: "setjmp returns LOOP_CONTINUE\n(after longjmp from continue)"
  initial -> break_return: "break called"
  initial -> continue_return: "continue called"
}
Jump_Target_Indexing: {
  label: "Jump Target Indexing"
  style.fill: "#F5F5F5"
  legend: |md
    **Loop Depth = 2, break 1:**
    - target = depth - count = 2 - 1 = **1**
    - longjmp(break_targets[1], LOOP_BREAK)
    **Loop Depth = 3, break 2:**
    - target = depth - count = 3 - 2 = **1**
    - longjmp(break_targets[1], LOOP_BREAK)
    - Exits 2 loops, lands at depth 1
  |
}
Connections: {
  Loop_Execution.setup_break -> Jump_Buffer_Array.Break_Targets.buf1: "setjmp saves\ncontext to buf[1]" {
    style.stroke: "#C62828"
    style.stroke-dash: 3
  }
  Break_Continue_Flow.break_jump.break_code -> Loop_Execution.setup_break: "longjmp restores\ncontext from buf[1]" {
    style.stroke: "#C62828"
    style.stroke-width: 3
    style.animated: true
  }
  Break_Continue_Flow.continue_jump.continue_code -> Loop_Execution.setup_continue: "longjmp restores\ncontext from buf[1]" {
    style.stroke: "#E65100"
    style.stroke-width: 3
    style.animated: true
  }
  Jump_Buffer_Array.Depth_Counter -> Loop_Execution.enter: "reads/writes\ng_loop_depth" {
    style.stroke: "#1565C0"
    style.stroke-dash: 3
  }
}
State_Transition: {
  label: "State on setjmp Return"
  style.fill: "#E3F2FD"
  state: {
    label: "After longjmp returns to setjmp"
    style.fill: white
    stack: "Stack unwound to loop entry point"
    depth: "g_loop_depth = target_depth + 1"
    result: "setjmp returns jump code (1 or 2)"
  }
}
Nested_Example: {
  label: "Nested Loop Example (depth=2)"
  style.fill: "#FFF8E1"
  code: |md
    c
    for i in 1 2; do        // depth=1
      for j in a b; do      // depth=2
        if [ $j = "a" ]; then
          break             // target = 2-1 = 1
        fi                  // longjmp(break[1])
      done
    done
    
  |
  inner_loop: "Inner loop at depth=2"
  outer_loop: "Outer loop at depth=1"
  break_path: "break → longjmp(break_targets[1])\n→ returns to outer loop entry"
  inner_loop -> break_path: "break"
  break_path -> outer_loop: "exits inner loop"
}
annotations: {
  near: bottom-center
  text: |md
    **Key Invariants:**
    - `setjmp` is called at loop entry (saves context to buffer)
    - `longjmp` restores context from buffer, setjmp returns jump_code
    - Both parent and child loops have separate jump buffer slots
    - `break N` exits N loops by jumping to `break_targets[depth - N]`
    - `continue` jumps to `continue_targets[depth - 1]` (innermost loop)
  |
  shape: text
  style.fill: "#E8F5E9"
  style.border-radius: 8
}