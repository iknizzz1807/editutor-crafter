vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Shell Function Scope Model
  **Dynamic Scoping: Variables resolved at call time, not definition time**
| {near: top-center}
direction: right
Global_Scope: {
  label: "Global Scope\n(Level 0)"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  x: |md
    **x = "global"**
    *Visible to all*
  |
  y: |md
    **y = "global_y"**
  |
}
Function_f: {
  label: "Function f() Call\n(Level 1)"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  x_masked: |md
    **local x = "f_local"**
    *Masks global x*
  |
  z: |md
    **z = "f_z"**
    *New variable*
  |
  call_g: |md
    **Calls g()**
  |
}
Function_g: {
  label: "Function g() Call\n(Level 2)"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  x_visible: |md
    **Sees: x = "f_local"**
    *Not "global"!*
  |
  y_visible: |md
    **Sees: y = "global_y"**
    *From global scope*
  |
  z_visible: |md
    **Sees: z = "f_z"**
    *From f's scope*
  |
  local_w: |md
    **local w = "g_local"**
    *Only in g*
  |
}
Global_Scope -> Function_f: "f()" {style.stroke: "#1565C0"; style.stroke-width: 2}
Function_f -> Function_g: "g()" {style.stroke: "#E65100"; style.stroke-width: 2}
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  title: |md
    ### Scope Rules
  |
  dynamic: |md
    **Dynamic Scope**: Variable lookup walks up the **call stack**
    - g() sees f's `local x`, not global `x`
    - g() sees global `y` (no masking)
  |
  local_keyword: |md
    **`local` keyword**: Creates scope mask
    - Saves previous value
    - Restores on function exit
  |
  restoration: |md
    **Automatic Restoration**
    - When f() returns: `x` → "global"
    - When g() returns: `w` removed
  |
}
example_trace: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  title: |md
    ### Execution Trace
  |
  code: |md
    bash
    x=global
    f() {
        local x=f_local
        echo "f sees: $x"  # f_local
        g
        echo "f after g: $x"  # f_local
    }
    g() {
        echo "g sees: $x"  # f_local!
        local w=g_local
    }
    f
    echo "global after f: $x"  # global
    
  |
}
scope_stack: {
  near: center-left
  style.fill: "#FAFAFA"
  style.stroke: "#757575"
  title: |md
    ### Variable Lookup Stack
    *(Bottom = Global, Top = Current)*
  |
  stack_visual: {
    grid-rows: 3
    grid-gap: 0
    level_2: {
      label: "Level 2 (g)"
      style.fill: "#FFF3E0"
      w: "w = g_local"
    }
    level_1: {
      label: "Level 1 (f)"
      style.fill: "#E3F2FD"
      x_masked: "x = f_local"
      z_var: "z = f_z"
    }
    level_0: {
      label: "Level 0 (Global)"
      style.fill: "#E8F5E9"
      x_global: "x = global (masked)"
      y_global: "y = global_y"
    }
  }
  lookup_arrow: {
    shape: text
    label: |md
      **Lookup x:**
      1. Check g's locals → not found
      2. Check f's locals → **found: "f_local"**
      3. (don't check global)
    |
  }
}
comparison: {
  near: top-right
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  title: |md
    ### Lexical vs Dynamic Scope
  |
  lexical: |md
    **Lexical (Static) Scope**
    - Variables resolved at **definition** time
    - g() would see global `x`
    - Used by: Python, JavaScript, C
  |
  dynamic_scope: |md
    **Dynamic Scope** (Shell)
    - Variables resolved at **call** time
    - g() sees f's `x` (caller's scope)
    - More flexible, harder to reason about
  |
}