vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # TDD-SPEC: Function Definition, Registration, and Dispatch
  *Technical Architecture Reference: Shell Execution Environment*
| {
  near: top-center
  shape: text
}

# Main Execution Sequence
shell_engine: {
  shape: sequence_diagram

  # Participants with technical type signatures
  User: {
    shape: person
    label: "Process Owner\n(STDIN/STDOUT)"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  
  Parser: {
    shape: rectangle
    label: "Lexer/Parser\n(Grammar: POSIX)"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  
  FunctionTable: {
    shape: cylinder
    label: "Function Table\n(In-Memory Hash Map)"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  
  Executor: {
    shape: rectangle
    label: "Command Executor\n(Eval Loop)"
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
    }
  }
  
  ExternalCmd: {
    shape: rectangle
    label: "System Binaries\n(\$PATH /usr/bin/*)"
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
    }
  }

  # --- PHASE 1: DEFINITION ---
  User -> Parser: "1. INPUT: f() { echo hello; }" {
    style: {
      bold: true
      font-color: "#1B5E20"
    }
  }
  
  Parser -> Parser: "2. GENERATE_AST\n(Node: FUNC_DEF)" {
    style.stroke-dash: 3
  }
  
  Parser -> FunctionTable: "3. REGISTER(key='f', val=0x7FFF10)" {
    label: "Store entry"
    style: {
      stroke: "#7B1FA2"
      stroke-width: 3
    }
  }
  
  FunctionTable -> FunctionTable: "4. HASH_INSERT\nbucket[hash('f') % 64]" {
    style.stroke-dash: 2
  }
  
  Parser -> User: "5. PROMPT (PS1)" {
    style.stroke-dash: 5
  }

  # --- PHASE 2: SUCCESSFUL DISPATCH ---
  User -> Executor: "6. CALL: f World" {
    style.bold: true
  }
  
  Executor -> FunctionTable: "7. LOOKUP('f')" {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  
  FunctionTable -> Executor: "8. RETURN: AST_PTR(0x7FFF10)" {
    style: {
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  
  Executor -> Executor: "9. EXEC_AST(0x7FFF10)\nArgs: ['World']" {
    style: {
      fill: "#E8F5E9"
      stroke-dash: 3
    }
  }
  
  Executor -> User: "10. STDOUT: 'Hello World'"

  # --- PHASE 3: ERROR PATH (EXTERNAL DISPATCH) ---
  User -> Executor: "11. CALL: grep pattern" {
    style: {
      stroke: "#C62828"
      stroke-dash: 4
    }
  }
  
  Executor -> FunctionTable: "12. LOOKUP('grep')" {
    style.stroke: "#C62828"
  }
  
  FunctionTable -> Executor: "13. RETURN: NULL" {
    style.stroke: "#C62828"
  }
  
  Executor -> ExternalCmd: "14. execvp('grep', ...)" {
    label: "Fallthrough to \$PATH"
    style: {
      stroke: "#C62828"
      stroke-dash: 5
    }
  }
  
  ExternalCmd -> Executor: "15. SIGCHLD (Exit: 0)" {
    style.stroke: "#C62828"
  }
}

# Documentation Blocks - Fixed by escaping the dollar sign to prevent substitution error
lookup_order: |md
  ### EXECUTION LOOKUP HIERARCHY
  The shell resolves commands in a strict priority order:
  1. **Built-ins**: Commands internal to binary (e.g., `cd`, `set`).
  2. **Functions**: **Resolved via Memory Hash Table** (ast_ptr).
  3. **Executables**: Files located via \$PATH traversal.
| {
  near: bottom-left
  shape: text
  style: {
    font-size: 14
    stroke: "#B0BEC5"
    fill: "#FAFAFA"
  }
}

mem_layout: |md
  ### FUNCTION TABLE ARCHITECTURE
  - **Bucket Count**: 64 (Fixed)
  - **Collision Policy**: Chaining (Linked List)
  - **Key Encoding**: UTF-8 String
  - **Value**: `64-bit Virtual Memory Address`
  - **Persistence**: volatile (cleared on process exit)
| {
  near: bottom-right
  shape: text
  style: {
    font-size: 14
    stroke: "#B0BEC5"
    fill: "#FAFAFA"
  }
}

# Stylistic Overrides
(shell_engine -> shell_engine)[*].style.stroke: "#546E7A"