layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
  # Color palette mapping for Technical Design consistency
  colors: {
    header: "#B19CD9"   # Purple (Manual Headers)
    process: "#ADD8E6"  # Blue (Logic/Data)
    decision: "#FFF2CC" # Yellow (Decision/Logic)
    io: "#C7F1FF"       # Light Blue (File I/O)
    error: "#F8CECC"    # Red (Fault States)
    terminal: "#D9D9D9" # Gray (Exit States)
    pointer: "#FFB347"  # Orange (Pointers/Offsets)
    success: "#90EE90"  # Green (Success Paths)
  }
}

title: {
  label: |md
    # Script File Execution Flow
    **Component: Interpreter Entry & Main Loop**
    *Specification: POSIX Shell-like Interpreter (TDD-M4-10)*
  |
  near: top-center
  style: {
    font-size: 28
    bold: true
    fill: "white"
    stroke-width: 0
  }
}

direction: down

# --- PIPELINE COMPONENTS ---

interpreter: Interpreter State Machine {
  style: {
    stroke: "#444444"
    stroke-width: 2
    fill: "#FDFDFD"
  }

  start: {
    shape: circle
    label: "●"
    tooltip: "Entry Point: Main Interpreter Invocation"
    style: {
      fill: "${colors.success}"
      stroke-width: 2
    }
  }

  initialization: Startup Phase {
    open_file: "fopen(filename, \"r\")\n[Stream Initiation]" {
      shape: rectangle
      style: {
        fill: "${colors.io}"
        stroke-width: 2
        border-radius: 4
      }
    }

    file_check: "Is Stream Valid?\n(file != NULL)" {
      shape: diamond
      style: {
        fill: "${colors.decision}"
        stroke-width: 2
      }
    }

    read_first_line: "getline(&line, &cap, file)\n[Peek first 2 bytes]" {
      shape: rectangle
      style: {
        fill: "${colors.io}"
        stroke-width: 2
      }
    }

    shebang_check: "strncmp(line, \"#!\", 2) == 0?" {
      shape: diamond
      style: {
        fill: "${colors.decision}"
        stroke-width: 2
      }
    }

    skip_shebang: "Increment File Pointer\nUpdate 'saw_shebang' state" {
      shape: rectangle
      style: {
        fill: "${colors.process}"
        stroke-width: 2
      }
    }

    rewind_file: "rewind(file)\nReset Offset to 0" {
      shape: rectangle
      style: {
        fill: "${colors.process}"
        stroke-width: 2
      }
    }

    set_positional: "Initialize Shell State\nMap \$0...\$n Argv" {
      shape: rectangle
      style: {
        fill: "${colors.process}"
        stroke-width: 2
      }
    }
  }

  main_loop: Execution Loop (Per Line) {
    style: {
      stroke: "${colors.header}"
      stroke-dash: 5
      fill: "#FAFAFF"
    }

    read_line: "getline(&line, &cap, file)" {
      shape: rectangle
      style: {
        fill: "${colors.io}"
        stroke-width: 2
        double-border: true
      }
    }

    eof_check: "EOF Reached?\n(feof || len < 0)" {
      shape: diamond
      style: {
        fill: "${colors.decision}"
        stroke-width: 2
      }
    }

    logic: Parsing & Processing {
      continuation_check: "Line ends with '\\'?" {
        shape: diamond
        style: {
          fill: "${colors.decision}"
          stroke-width: 2
        }
      }

      accumulate: "Buffer += line[0:-1]\nRe-enter getline()" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-width: 2
        }
      }

      comment_check: "First Non-Whitespace == '#'" {
        shape: diamond
        style: {
          fill: "${colors.decision}"
          stroke-width: 2
        }
      }

      skip_comment: "Discard Line Buffer\nRelease temp pointers" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-width: 2
        }
      }

      empty_check: "Buffer is Empty/Whitespace?" {
        shape: diamond
        style: {
          fill: "${colors.decision}"
          stroke-width: 2
        }
      }

      skip_empty: "Recycle Loop" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-width: 2
        }
      }

      free_line: "free(temp_buf)\nClear Inter-iteration data" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-dash: 3
        }
      }

      lexer_init: "Lexer_Init(line_ptr)" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-width: 2
        }
      }

      parser_exec: "Parser_Run() -> AST" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-width: 2
        }
      }

      parse_error_check: "Syntax Valid?" {
        shape: diamond
        style: {
          fill: "${colors.decision}"
          stroke-width: 2
        }
      }
    }

    execution: Runtime {
      execute_ast: "last_status = Execute(ast)" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-width: 2
          bold: true
        }
      }

      free_ast: "AST_Destroy(ast)\n[Recursive GC]" {
        shape: rectangle
        style: {
          fill: "${colors.process}"
          stroke-dash: 3
        }
      }
    }
  }

  shutdown: Cleanup Phase {
    cleanup: "fclose(file)\nfree(global_buffers)" {
      shape: rectangle
      style: {
        fill: "${colors.process}"
        stroke-width: 2
      }
    }

    return_status: "Return last_status" {
      shape: rectangle
      style: {
        fill: "${colors.terminal}"
        stroke-width: 2
      }
    }

    end_success: "●" {
      shape: circle
      style: {
        fill: "${colors.success}"
        stroke-width: 2
      }
    }
  }

  error_handling: Error Terminal {
    error_not_found: "fprintf(stderr, ...)\nEXIT_FAILURE (127)" {
      shape: rectangle
      style: {
        fill: "${colors.error}"
        stroke-width: 3
        stroke: "#B85450"
      }
    }

    end_error: "✖" {
      shape: circle
      style: {
        fill: "${colors.error}"
        stroke: "#B85450"
        stroke-width: 2
      }
    }
  }
}

# --- EDGE DEFINITIONS ---

interpreter.start -> interpreter.initialization.open_file
interpreter.initialization.open_file -> interpreter.initialization.file_check

interpreter.initialization.file_check -> interpreter.initialization.read_first_line: "File Found"
interpreter.initialization.file_check -> interpreter.error_handling.error_not_found: "ENOENT"
interpreter.error_handling.error_not_found -> interpreter.error_handling.end_error

interpreter.initialization.read_first_line -> interpreter.initialization.shebang_check
interpreter.initialization.shebang_check -> interpreter.initialization.skip_shebang: "True"
interpreter.initialization.shebang_check -> interpreter.initialization.rewind_file: "False"

interpreter.initialization.skip_shebang -> interpreter.initialization.set_positional
interpreter.initialization.rewind_file -> interpreter.initialization.set_positional
interpreter.initialization.set_positional -> interpreter.main_loop.read_line

interpreter.main_loop.read_line -> interpreter.main_loop.eof_check
interpreter.main_loop.eof_check -> interpreter.shutdown.cleanup: "EOF"
interpreter.main_loop.eof_check -> interpreter.main_loop.logic.continuation_check: "Data"

interpreter.main_loop.logic.continuation_check -> interpreter.main_loop.logic.accumulate: "Yes (\\)"
interpreter.main_loop.logic.continuation_check -> interpreter.main_loop.logic.comment_check: "No"
interpreter.main_loop.logic.accumulate -> interpreter.main_loop.read_line

interpreter.main_loop.logic.comment_check -> interpreter.main_loop.logic.skip_comment: "Is Comment"
interpreter.main_loop.logic.comment_check -> interpreter.main_loop.logic.empty_check: "Command"
interpreter.main_loop.logic.skip_comment -> interpreter.main_loop.logic.free_line

interpreter.main_loop.logic.empty_check -> interpreter.main_loop.logic.skip_empty: "Whitespace"
interpreter.main_loop.logic.empty_check -> interpreter.main_loop.logic.lexer_init: "Valid"
interpreter.main_loop.logic.skip_empty -> interpreter.main_loop.logic.free_line
interpreter.main_loop.logic.free_line -> interpreter.main_loop.read_line

interpreter.main_loop.logic.lexer_init -> interpreter.main_loop.logic.parser_exec
interpreter.main_loop.logic.parser_exec -> interpreter.main_loop.logic.parse_error_check
interpreter.main_loop.logic.parse_error_check -> interpreter.main_loop.execution.execute_ast: "Success"
interpreter.main_loop.logic.parse_error_check -> interpreter.main_loop.logic.free_line: "Syntax Err"

interpreter.main_loop.execution.execute_ast -> interpreter.main_loop.execution.free_ast
interpreter.main_loop.execution.free_ast -> interpreter.main_loop.logic.free_line

interpreter.shutdown.cleanup -> interpreter.shutdown.return_status
interpreter.shutdown.return_status -> interpreter.shutdown.end_success

# --- TECHNICAL ANNOTATIONS (Fixed substitutions) ---

note_continuation: ||md
  **Backslash Escaping**
  Implementation must strip the
  trailing slash and newline,
  then prompt for PS2 if interactive.
|| {
  shape: text
  near: bottom-left
  style.font-size: 14
}

note_shebang: ||md
  **Kernel Divergence**
  When executed via execve(), the
  OS handles the #! line. When run as
  sh script.sh, the interpreter must
  manually treat it as a comment.
|| {
  shape: text
  near: top-right
  style.font-size: 14
}

note_positional: ||md
  **Context Setup**
  - \$0: Script Path
  - \$1..\$n: Arguments
  - \$\#: Count
  - \$\$: PID
|| {
  shape: text
  near: top-left
  style.font-size: 14
}

note_lexer_state: ||md
  **Lexer Context**
  The lexer is ephemeral per line
  unless a multi-line string/heredoc
  is encountered.
|| {
  shape: text
  near: bottom-right
  style.font-size: 14
}
