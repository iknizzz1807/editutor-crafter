vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    repl: "#E8F5E9"
    lexer: "#E3F2FD"
    parser: "#FFF3E0"
    executor: "#FCE4EC"
    job_control: "#F3E5F5"
    signals: "#FFEBEE"
    expansion: "#E0F7FA"
    builtin: "#FFF8E1"
    ast: "#ECEFF1"
    header: "#673AB7"
    padding: "#BDBDBD"
    illegal: "#D32F2F"
  }
}

title: |md
  # Shell Complete Architecture (POSIX.1)
  **Specification v2.1** - Detailed Byte Layouts and State Transitions
  *Implementation-grade design for REPL, Lexer, Parser, and Execution Engine.*
| {near: top-center}

direction: right

# ============================================
# USER INPUT LAYER
# ============================================
User_Input: {
  style.fill: ${colors.repl}
  Terminal: {
    shape: rectangle
    style.fill: white
    style.stroke: "#4CAF50"
    label: "TTY Interface (Termios)"
    "stdin (fd 0)"
    "stdout (fd 1)"
    "stderr (fd 2)"
    tooltip: "Canonical/Non-canonical mode control"
  }
  Signal_Generator: {
    shape: diamond
    style.fill: ${colors.signals}
    label: "Hardware Interrupts\n(tty signals)"
    "SIGINT (0x02)"
    "SIGTSTP (0x12)"
    "SIGQUIT (0x03)"
  }
}

# ============================================
# REPL - READ-EVAL-PRINT LOOP
# ============================================
REPL: {
  style.fill: ${colors.repl}
  style.stroke: "#4CAF50"
  style.stroke-width: 2

  Read: {
    shape: rectangle
    style.fill: white
    label: "read_input(): char*"
    "getline() syscall"
    "Line Buffer [4096B]"
  }
  Eval: {
    shape: rectangle
    style.fill: white
    label: "eval_input(char*): int"
    "Entry into Lexer/Parser"
  }
  Print: {
    shape: rectangle
    style.fill: white
    # ESCAPED: \$ to avoid substitution error
    label: "update_prompt()\nLast Status: \$?"
    "PWD / User expansion"
  }
  Loop: {
    shape: circle
    style.fill: "#C8E6C9"
    label: "Main Loop\nwhile(alive)"
  }
  Read -> Eval -> Print -> Loop -> Read
}

# ============================================
# LEXER - LEXICAL ANALYSIS
# ============================================
Lexer: {
  style.fill: ${colors.lexer}
  style.stroke: "#2196F3"
  style.stroke-width: 2

  Input_Buffer: {
    shape: sql_table
    label: "Lexer Buffer Layout"
    00: "input_ptr (char*)" {constraint: "8B"}
    08: "pos (size_t)" {constraint: "8B"}
    16: "len (size_t)" {constraint: "8B"}
    24: "eof_reached (int)" {constraint: "4B"}
    28: "padding" {style.fill: ${colors.padding}; constraint: "4B"}
  }

  State_Machine: {
    style.fill: white
    LEX_DEFAULT: "Start/Neutral"
    LEX_IN_SINGLE_QUOTE: "Literal (')"
    LEX_IN_DOUBLE_QUOTE: "Partial (double-quote)"
    LEX_IN_ESCAPE: "Escape (\\)"

    LEX_DEFAULT -> LEX_IN_SINGLE_QUOTE: "quote_char == \"'\""
    LEX_IN_SINGLE_QUOTE -> LEX_DEFAULT: "quote_char == \"'\""
    LEX_DEFAULT -> LEX_IN_ESCAPE: "char == '\\'"
    LEX_IN_ESCAPE -> LEX_DEFAULT: "any_char"

    LEX_IN_SINGLE_QUOTE -> LEX_IN_DOUBLE_QUOTE: "ILLEGAL" {
      style.stroke: ${colors.illegal}
      style.stroke-dash: 3
    }
  }

  Token_Stream: {
    shape: sql_table
    label: "Token Memory [sizeof=32B]"
    00: "token_type (enum)" {constraint: "4B"}
    04: "padding" {style.fill: ${colors.padding}; constraint: "4B"}
    08: "value (char*)" {constraint: "8B"}
    16: "line_no (int)" {constraint: "4B"}
    20: "col_no (int)" {constraint: "4B"}
    24: "next (struct Token*)" {constraint: "8B"}
  }
  Input_Buffer -> State_Machine -> Token_Stream
}

# ============================================
# PARSER - RECURSIVE DESCENT
# ============================================
Parser: {
  style.fill: ${colors.parser}
  style.stroke: "#FF9800"
  style.stroke-width: 2

  Precedence_Levels: {
    style.fill: white
    direction: down
    label: "Grammar Rules (Bottom-Up)"
    "1. Lists (';', '&', '\\n')"
    "2. Pipelines ('|')"
    "3. Logical ('&&', '||')"
    "4. Simple Command"
  }

  Parse_Functions: {
    style.fill: white
    "parse_list() -> ASTNode*"
    "parse_pipeline() -> ASTNode*"
    "parse_simple_cmd() -> ASTNode*"
  }

  Error_Recovery: {
    shape: diamond
    style.fill: "#FFECB3"
    label: "Syntax Error Handling"
    "yyerror()"
    "tok_next() recovery"
  }
  Precedence_Levels -> Parse_Functions -> Error_Recovery
}

# ============================================
# AST - ABSTRACT SYNTAX TREE
# ============================================
AST: {
  style.fill: ${colors.ast}
  style.stroke: "#607D8B"
  style.stroke-width: 2

  Node_Types: {
    style.fill: white
    grid-columns: 3
    grid-gap: 5
    "NODE_CMD": {style.fill: "#CFD8DC"}
    "NODE_PIPE": {style.fill: "#B0BEC5"}
    "NODE_LIST": {style.fill: "#90A4AE"}
    "NODE_REDIR": {style.fill: "#78909C"}
    "NODE_IF": {style.fill: "#CFD8DC"}
    "NODE_WHILE": {style.fill: "#B0BEC5"}
  }

  Memory_Layout: {
    shape: sql_table
    label: "ASTNode Structure (sizeof=48B)"
    00: "type (enum)" {constraint: "4B"}
    04: "padding" {style.fill: ${colors.padding}; constraint: "4B"}
    08: "data (union args/redir)" {constraint: "16B"}
    24: "left_child (node*)" {constraint: "8B"}
    32: "right_child (node*)" {constraint: "8B"}
    40: "metadata_ptr" {constraint: "8B"}
    "---": "Cache Line Boundary (64B)" {style.stroke-dash: 5}
  }
  Node_Types -> Memory_Layout
}

# ============================================
# EXPANSION PIPELINE
# ============================================
Expansion: {
  style.fill: ${colors.expansion}
  style.stroke: "#00BCD4"
  style.stroke-width: 2

  Phases: {
    style.fill: white
    direction: down
    label: "Expansion Steps (POSIX Order)"
    Tilde: "1. ~ -> /home/user"
    # ESCAPED: \$ to avoid substitution errors
    Param: "2. \$VAR / \${VAR}"
    CmdSub: "3. \$(cmd) / `cmd`"
    Split: "4. Field Splitting (IFS)"
    Glob: "5. Pathname expansion"
    Quotes: "6. Quote Removal"
    Tilde -> Param -> CmdSub -> Split -> Glob -> Quotes
  }
  Context: {
    shape: rectangle
    style.fill: white
    label: "ExpansionContext"
    "int exit_status"
    "pid_t shell_pid"
    "char** environment"
  }
  Phases -> Context
}

# ============================================
# EXECUTOR - AST WALKER
# ============================================
Executor: {
  style.fill: ${colors.executor}
  style.stroke: "#E91E63"
  style.stroke-width: 2

  Dispatch: {
    shape: diamond
    style.fill: white
    label: "execute_node(ASTNode*)"
    "Visitor Pattern"
  }
  Fork_Exec: {
    style.fill: white
    label: "External Command flow"
    "fork() -> pid"
    "execve(path, args, env)"
    "waitpid(pid, &status)"
  }
  Redirection: {
    style.fill: "#F8BBD9"
    label: "I/O Management"
    "dup2(oldfd, newfd)"
    "pipe(fds[2])"
  }
  Dispatch -> Fork_Exec
  Dispatch -> Redirection
}

# ============================================
# JOB CONTROL & SIGNALS
# ============================================
Job_Control: {
  style.fill: ${colors.job_control}
  style.stroke: "#9C27B0"
  style.stroke-width: 2

  Job_Table: {
    shape: sql_table
    label: "Job Entry [128B]"
    00: "pgid (pid_t)" {constraint: "4B"}
    04: "status (enum)" {constraint: "4B"}
    08: "command (char*)" {constraint: "8B"}
    16: "tmodes (termios)" {constraint: "64B"}
  }
  Process_Mgmt: {
    style.fill: white
    "setpgid(pid, pgid)"
    "tcsetpgrp(0, pgid)"
  }
  Job_Table -> Process_Mgmt
}

Signals: {
  style.fill: ${colors.signals}
  style.stroke: "#F44336"
  style.stroke-width: 2

  Handlers: {
    style.fill: white
    "SIGCHLD: waitpid(-1, WNOHANG)"
    "SIGINT: handler_interrupt()"
  }
  Self_Pipe: {
    style.fill: white
    label: "Self-Pipe Trick (Async-Safe)"
    "Handler -> write(pipe_fd, 1)"
    "Main Loop -> select/poll(pipe_fd)"
  }
  Handlers -> Self_Pipe
}

# ============================================
# MAIN FLOW CONNECTIONS
# ============================================
User_Input.Terminal -> REPL.Read: "Raw char stream"
User_Input.Signal_Generator -> Signals.Handlers: "Async Event"

REPL.Eval -> Lexer.Input_Buffer: "Pass Buffer"
Lexer.Token_Stream -> Parser.Parse_Functions: "Token Stream"
Parser.Parse_Functions -> AST.Node_Types: "Construct Tree"
AST.Memory_Layout -> Executor.Dispatch: "Root Pointer"

Executor.Dispatch -> Expansion.Phases: "Expand Cmd Arguments"
Executor.Dispatch -> Job_Control.Process_Mgmt: "Process Isolation"

Signals.Self_Pipe -> REPL.Loop: "Wakeup/Interrupt"

# ============================================
# ANNOTATIONS & SPECS
# ============================================
spec_mem: |md
  ### Memory Layout Specs
  - **Token**: 32 bytes aligned
  - **ASTNode**: 48 bytes (Fits in 64B Cache Line)
  - **JobEntry**: 128 bytes (2 Cache Lines)
| {near: bottom-left}

spec_exec: |md
  ### Execution Context
  - External binaries use `execve`
  - Builtins (cd, export) run in parent process
  - Pipelines use `pipe(2)` before `fork(2)`
| {near: bottom-right}
