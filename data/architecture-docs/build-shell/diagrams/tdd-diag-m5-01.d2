vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    free: "#10B981"
    pointer: "#F59E0B"
    changed: "#EF4444"
    fork: "#EC4899"
    process: "#6366F1"
    mem_shared: "#60A5FA"
    mem_cow: "#F472B6"
    isolation: "#1E293B"
  }
}

title: |md
  # Subshell vs Brace Group: The Fork Boundary
  *Technical Specification: Process Isolation & Memory Inheritance*
| {near: top-center}

direction: right

# ==========================================
# SUBSHELL (cmd) - Creates fork boundary
# ==========================================
subshell_section: {
  label: "( cmd ) - SUBSHELL (Explicit Fork)"
  style: {
    fill: "#F3E8FF"
    stroke: ${colors.fork}
    stroke-width: 4
    border-radius: 10
  }

  parent_ctx: "Parent Process\nPID: 1234\nAddr Space: 0x0000-0xFFFF" {
    style: {
      fill: ${colors.process}
      font-color: white
      bold: true
    }
  }

  fork_op: "syscall: fork()" {
    shape: diamond
    style: {
      fill: ${colors.fork}
      font-color: white
    }
  }

  subshell_child: "Child Process\nPID: 1235 (FORKED)\n[Copy-on-Write Memory Segment]" {
    style: {
      fill: ${colors.fork}
      font-color: white
      stroke-dash: 4
      stroke-width: 2
    }
  }

  state_change: "Exec: cd /tmp\nUpdate: $PWD = /tmp\n(Local MMU Update)" {
    style: {
      fill: ${colors.changed}
      font-color: white
      double-border: true
    }
  }

  exit_proc: "exit(0)\nRelease Child Paging Tables" {
    shape: circle
    style: {
      fill: "#1F2937"
      font-color: white
    }
  }

  parent_wait: "waitpid(1235)\nCollect Status (0)" {
    style: {
      fill: ${colors.process}
      font-color: white
    }
  }

  result_summary: "RESULT: PID 1234\n$PWD remains /home/user" {
    shape: text
    style: {
      font-color: ${colors.changed}
      bold: true
      font-size: 18
    }
  }

  # Workflow
  parent_ctx -> fork_op: "clone() flags"
  fork_op -> subshell_child: "New Task Struct"
  fork_op -> parent_wait: "Parent blocks"
  subshell_child -> state_change: "Independent Stack"
  state_change -> exit_proc: "Free heap/stack"
  exit_proc -> parent_wait: "SIGCHLD"
  parent_wait -> result_summary: "Shell returns"

  subshell_note: |md
    ### FORK BOUNDARY (ISOLATION)
    **Memory Inheritance (vfork/fork):**
    - `chdir()` affects only Child's `task_struct`
    - Variables in Child stack are COW (Copy-On-Write)
    - File Descriptors are cloned (dup) but independent offsets
  | {
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
      font-size: 12
    }
  }
}

# ==========================================
# BRACE GROUP { cmd; } - No fork
# ==========================================
brace_section: {
  label: "{ cmd; } - BRACE GROUP (Inline Execution)"
  style: {
    fill: "#ECFDF5"
    stroke: ${colors.free}
    stroke-width: 4
    border-radius: 10
  }

  main_shell: "Current Process\nPID: 1234\nAddr Space: 0x0000-0xFFFF" {
    style: {
      fill: ${colors.free}
      font-color: white
      bold: true
    }
  }

  inline_exec: "Exec: cd /tmp\nUpdate: $PWD = /tmp\n(Global Process State)" {
    style: {
      fill: ${colors.changed}
      font-color: white
      double-border: true
    }
  }

  main_cont: "Continue Execution\nSame Context / Same Stack" {
    style: {
      fill: ${colors.free}
      font-color: white
    }
  }

  final_state: "RESULT: PID 1234\n$PWD is /tmp" {
    shape: text
    style: {
      font-color: ${colors.free}
      bold: true
      font-size: 18
    }
  }

  # Workflow
  main_shell -> inline_exec: "No syscall clone"
  inline_exec -> main_cont: "Memory Mutation"
  main_cont -> final_state

  brace_note: |md
    ### NO BOUNDARY (MUTATION)
    **Execution Context:**
    - Inline execution within Current Shell process
    - Directory changes affect shell global state
    - Shell variables are modified in-place
    - Redirections persist if not handled
  | {
    style: {
      fill: "#D1FAE5"
      stroke: "#059669"
      stroke-width: 2
      font-size: 12
    }
  }
}

# Boundary Definition
subshell_section -> brace_section: "MEMORY BOUNDARY: FORK vs STACK" {
  style: {
    stroke: ${colors.header}
    stroke-width: 4
    stroke-dash: 5
    font-color: ${colors.header}
    bold: true
  }
}

# ==========================================
# Technical Legend & Code Examples
# ==========================================
footer_container: {
  style.stroke-width: 0
  
  legend: {
    label: "Execution Trace Legend"
    style: {
      fill: white
      stroke: "#E5E7EB"
      border-radius: 8
    }
    fork_color: "Process Fork (New PID Context)" {
      style.fill: ${colors.fork}
      style.font-color: white
    }
    mutate_color: "State Mutation (Internal)" {
      style.fill: ${colors.changed}
      style.font-color: white
    }
    shared_color: "Shared Address Space" {
      style.fill: ${colors.free}
      style.font-color: white
    }
  }

  examples: {
    grid-columns: 2
    style.stroke-width: 0

    sub_code: |go
    // Subshell Logic (C equivalent)
    pid_t pid = fork();
    if (pid == 0) {
        // Child context
        chdir("/tmp");
        exit(0);
    } else {
        // Parent context
        wait(NULL);
        // PWD is unchanged here
    }
    | {
      label: "Subshell: Linux Internals"
      style.font: mono
      style.fill: "#1F2937"
      style.font-color: "#F9FAFB"
    }

    brace_code: |go
    // Brace Logic (C equivalent)
    // No fork() - Executed in main thread
    chdir("/tmp");
    // State is modified permanently 
    // for the entire process lifespan
    char buf[256];
    getcwd(buf, 256); // Returns "/tmp"
    | {
      label: "Brace: Stack Execution"
      style.font: mono
      style.fill: "#1F2937"
      style.font-color: "#F9FAFB"
    }
  }
}

# Fixed positioning for root-level shapes
footer_container.near: bottom-center