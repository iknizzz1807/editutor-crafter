layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |'md
# Logical Operators: Shell vs C Precedence
*Technical Specification of Parser Associativity and Execution Flow*
'|
title.shape: text
title.near: top-center
title.style.font-size: 28

# --- GLOBAL CLASSES ---
classes: {
  header_text: {
    shape: text
    style: {
      font-size: 20
      bold: true
      font-color: "#4A148C"
    }
  }
  logic_gate: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 4
    }
  }
  memory_segment: {
    style: {
      font: mono
      stroke-width: 1
    }
  }
}

# --- SECTION 1: POSIX SHELL LOGIC ---
shell_semantics: "SECTION 0x01: POSIX Shell Semantics" {
  style: {
    fill: "#F3F9FF"
    stroke: "#2E86AB"
    stroke-width: 3
    border-radius: 10
  }

  desc: "Precedence Rule: && == || (Strict Left-to-Right)"
  desc.class: header_text

  example_a: "Case A: Execution Chaining" {
    expr: "true || false && echo reached"
    expr.style.font: mono
    expr.style.font-size: 18
    expr.style.bold: true

    sequence: {
      shape: sequence_diagram
      style.fill: "#FFFFFF"
      
      shell: "Shell Parser"
      eval: "Logic Evaluator"
      stdout: "Terminal"

      shell -> eval: "1. Scan: true || false"
      eval -> eval: "Result: 0 (Success/True)"
      eval -> eval: "Short-circuit: Skip 'false' branch"
      shell -> eval: "2. Scan: [Result] && echo reached"
      eval -> stdout: "3. Action: Success && Exec(echo)"
      stdout -> shell: "Output: 'reached'"
    }
    
    note: |'md
    **Observation:** In Shell, the `&&` does not "pull" the `false` towards it. 
    It evaluates the result of `(true || false)` and then evaluates `&&`.
    '|
  }

  example_b: "Case B: Short-Circuit Failure" {
    expr: "false && true || echo reached"
    expr.style.font: mono
    
    flow: {
      shape: sequence_diagram
      shell: "Shell Parser"
      eval: "Logic Evaluator"
      
      shell -> eval: "1. Evaluate: false && true"
      eval -> eval: "Result: 1 (Failure)"
      eval -> eval: "Short-circuit: Skip 'true'"
      shell -> eval: "2. Evaluate: [Result] || echo"
      eval -> eval: "Action: Failure || Exec(echo)"
    }
    result: "STATUS: reached is printed"
    result.style.font-color: red
  }
}

# --- SECTION 2: C-STYLE LOGIC ---
c_semantics: "SECTION 0x02: C / Java / Python Semantics" {
  style: {
    fill: "#FFF8F0"
    stroke: "#E65100"
    stroke-width: 3
    border-radius: 10
  }

  desc: "Precedence Rule: && (High) > || (Low)"
  desc.class: header_text

  ast_comparison: "Abstract Syntax Tree (AST)" {
    c_style: "C-Style AST: true || (false && ...)" {
      root: "|| (OR)" {
        lhs: "true (LHS)"
        rhs: "&& (AND)" {
          r_lhs: "false"
          r_rhs: "action()"
        }
      }
      root.style.fill: "#FFE0B2"
      root -> lhs: "1st Eval"
      root -> rhs: "2nd Eval (PRUNED)"
    }
  }

  example_c: "Case C: AST Pruning" {
    expr: "true || false && action()"
    expr.style.font: mono

    explanation: |'md
    **Execution Steps:**
    1. Root `||` evaluates LHS (`true`).
    2. Because LHS is `true`, the `||` operator short-circuits.
    3. The entire RHS branch `(false && action())` is never visited.
    4. **Result:** `action()` is **NOT** called.
    '|
    
    comparison: "CRITICAL DIFFERENCE" {
      style.fill: "#FFEBEE"
      shell: "Shell: prints 'reached'"
      cstyle: "C: skips 'action()'"
    }
  }
}

# --- SECTION 3: MEMORY LAYOUT OF OPERATOR TABLE ---
# Intel-manual quality byte layout
precedence_table: "Table 0xAF: Operator Precedence & Offset Mapping" {
  
  header: {
    grid-columns: 5
    grid-gap: 0
    
    h1: "Offset (Byte)" { class: memory_segment; style.fill: "#D1C4E9" }
    h2: "Operator" { class: memory_segment; style.fill: "#D1C4E9" }
    h3: "Shell Rank" { class: memory_segment; style.fill: "#D1C4E9" }
    h4: "C Rank" { class: memory_segment; style.fill: "#D1C4E9" }
    h5: "Size (Bits)" { class: memory_segment; style.fill: "#D1C4E9" }

    # Row 1
    r1_off: "0x00" { class: memory_segment }
    r1_op: "( )" { class: memory_segment }
    r1_s: "1" { class: memory_segment }
    r1_c: "1" { class: memory_segment }
    r1_sz: "N/A" { class: memory_segment }

    # Row 2
    r2_off: "0x08" { class: memory_segment }
    r2_op: "&&" { class: memory_segment; style.fill: "#BBDEFB" }
    r2_s: "2" { class: memory_segment; style.fill: "#BBDEFB" }
    r2_c: "2" { class: memory_segment; style.fill: "#BBDEFB" }
    r2_sz: "16" { class: memory_segment; style.fill: "#BBDEFB" }

    # Row 3 (Divergence Start)
    r3_off: "0x10" { class: memory_segment }
    r3_op: "||" { class: memory_segment; style.fill: "#BBDEFB" }
    r3_s: "2 (EQUAL)" { class: memory_segment; style.fill: "#BBDEFB"; style.bold: true; style.font-color: red }
    r3_c: "3 (LOWER)" { class: memory_segment; style.fill: "#BBDEFB"; style.bold: true; style.font-color: green }
    r3_sz: "16" { class: memory_segment; style.fill: "#BBDEFB" }

    # Row 4
    r4_off: "0x18" { class: memory_segment }
    r4_op: ";" { class: memory_segment; style.fill: "#C8E6C9" }
    r4_s: "3" { class: memory_segment; style.fill: "#C8E6C9" }
    r4_c: "N/A" { class: memory_segment; style.fill: "#C8E6C9" }
    r4_sz: "8" { class: memory_segment; style.fill: "#C8E6C9" }
  }

  footer: "Total Structure Size: 32 Bytes (Half Cache Line)" {
    near: bottom-center
    style.font-size: 14
  }
}

# --- ANNOTATIONS ---
shell_semantics -> c_semantics: "Parser Conflict" {
  style: {
    stroke: "#D32F2F"
    stroke-width: 4
    stroke-dash: 5
    animated: true
  }
}

warning: "SYSTEMS WARNING" {
  near: bottom-right
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    border-radius: 8
  }
  content: |'md
  ### ⚠️ Ambiguity Risk
  When writing Shell scripts: 
  **NEVER** mix `&&` and `||` without explicit grouping.
  
  Use: `{ cmd1 || cmd2; } && cmd3`
  
  Shell parses `A || B && C` as `(A || B) && C`.
  '|
}

# Cache Line Visual Representation
cache_boundary: "" {
  near: precedence_table
  style: {
    stroke-dash: 5
    stroke: grey
    fill: transparent
  }
  label: "64B Cache Line Boundary"
}