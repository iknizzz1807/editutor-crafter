vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
Parent
Child
Pipe_R: "Pipe Read End"
Pipe_W: "Pipe Write End"
Parent."1. Parse <<EOF delimiter"
Parent."2. Read heredoc content lines"
Parent."3. Create pipe(pipefd[2])"
Parent.t1 -> Child.t1: "4. fork()"
# Parent path: write content to pipe
Parent.t2 -> Pipe_W.t1: "5. write(pipefd[1], content)"
Parent.t3 -> Pipe_W.t2: "6. close(pipefd[1])"
Parent.t4 -> Child.t2: "7. waitpid(child_pid)"
# Child path: set up stdin from pipe
Child.t1 -> Child.t3: "5. close(pipefd[1])"
Child.t3 -> Pipe_R.t1: "6. dup2(pipefd[0], STDIN_FILENO)"
Child.t4 -> Pipe_R.t2: "7. close(pipefd[0])"
Child.t5 -> Child.t6: "8. execvp(command)"
# Data flow: pipe provides stdin to child
Pipe_R.t1 -> Child.t6: "stdin reads from pipe"
Parent.t4 <- Child.t6: "9. Child exits, parent reaps"