vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6a0dad"
    data: "#007bff"
    process: "#28a745"
    error: "#dc3545"
    padding: "#6c757d"
    pointer: "#fd7e14"
  }
}

# -----------------------------------------------------------------------------
# MODULE 1: LEXER STATE MACHINE (QUOTE HANDLING)
# -----------------------------------------------------------------------------
lexer_states: "LEXER: Quote Handling State Machine" {
  style.stroke: "${colors.header}"
  style.stroke-width: 4

  LEX_DEFAULT: "LEX_DEFAULT\n(Word/Op parsing)" {
    shape: circle
    style.fill: "#f8f9fa"
    tooltip: "Default state: Scanning for delimiters, pipes, or command starts."
  }
  LEX_SINGLE: "LEX_IN_SINGLE_QUOTE\n(Literal interpret)" {
    shape: circle
    style.fill: "#fff3cd"
    tooltip: "Strong quoting: No expansion performed until closing quote."
  }
  LEX_DOUBLE: "LEX_IN_DOUBLE_QUOTE\n(Partial expansion)" {
    shape: circle
    style.fill: "#d1ecf1"
    tooltip: "Weak quoting: Variable expansion (\$) and backticks still active."
  }
  LEX_ESCAPE: "LEX_IN_ESCAPE\n(Next char literal)" {
    style.fill: "#f8d7da"
    style.double-border: true
  }

  LEX_DEFAULT -> LEX_SINGLE: "'" {
    style.stroke: "${colors.data}"
    style.bold: true
  }
  LEX_SINGLE -> LEX_DEFAULT: "'" {
    style.stroke: "${colors.data}"
  }

  LEX_DEFAULT -> LEX_DOUBLE: "\"" {
    style.stroke: "${colors.pointer}"
    style.bold: true
  }
  LEX_DOUBLE -> LEX_DEFAULT: "\"" {
    style.stroke: "${colors.pointer}"
  }

  LEX_DEFAULT -> LEX_ESCAPE: "\\" {
    style.stroke: "${colors.error}"
  }
  LEX_ESCAPE -> LEX_DEFAULT: "Any char" {
    style.stroke: "${colors.error}"
  }

  LEX_DOUBLE -> LEX_ESCAPE: "\\" {
    style.stroke: "${colors.error}"
  }
  LEX_ESCAPE -> LEX_DOUBLE: "\$, \", \\" {
    style.stroke: "${colors.error}"
  }
}

# -----------------------------------------------------------------------------
# MODULE 2: PIPELINE FD LAYOUT & DATA FLOW
# -----------------------------------------------------------------------------
pipeline_exec: "PIPELINE EXECUTION: ls | grep .c" {
  style.fill: "#fdfdfe"

  kernel_pipes: "Kernel Space Pipes" {
    pipe_0: "Pipe A Buffer (64KB)" {
      shape: cylinder
      style.fill: "${colors.data}"
    }
  }

  process_1: "Process: ls (PID 1234)" {
    style.fill: "#e2e3e5"
    fd_table: {
      shape: sql_table
      "0": "stdin | tty_in"
      "1": "stdout | pipe_0[write]"
      "2": "stderr | tty_err"
    }
  }

  process_2: "Process: grep (PID 1235)" {
    style.fill: "#e2e3e5"
    fd_table: {
      shape: sql_table
      "0": "stdin | pipe_0[read]"
      "1": "stdout | tty_out"
      "2": "stderr | tty_err"
    }
  }

  process_1.fd_table."1" -> kernel_pipes.pipe_0: "write(fd=1)" {
    style.stroke: "${colors.data}"
    style.animated: true
  }
  kernel_pipes.pipe_0 -> process_2.fd_table."0": "read(fd=0)" {
    style.stroke: "${colors.data}"
    style.animated: true
  }

  annotation: |md
    ### Pipeline Implementation Details
    1. **pipe()**: Parent calls `pipe(fds[2])`.
    2. **fork()**: Parent creates two child processes.
    3. **dup2()**:
       - P1: `dup2(fds[1], 1)` (Stdout to pipe write)
       - P2: `dup2(fds[0], 0)` (Stdin to pipe read)
    4. **close()**: All unused pipe ends closed in both children and parent to ensure EOF signal.
  |
}

# -----------------------------------------------------------------------------
# MODULE 3: SIGNAL HANDLING (SELF-PIPE PATTERN)
# -----------------------------------------------------------------------------
signal_logic: "Signal Handling: The Self-Pipe Pattern" {
  direction: right

  user_space: "User Space (Main Loop)" {
    select_call: "select/poll/epoll" {
      shape: hexagon
      style.fill: "${colors.process}"
    }
    reap_logic: "reap_children()" {
      style.stroke: "${colors.pointer}"
      style.stroke-width: 2
    }
  }

  signal_handler: "SIGCHLD Handler" {
    style.fill: "${colors.error}"
    style.font-color: white
    write_op: "write(self_pipe[1], 'C')" {
      style.bold: true
    }
  }

  pipe_primitive: "Self-Pipe" {
    shape: cylinder
    style.fill: "${colors.data}"
  }

  signal_handler.write_op -> pipe_primitive: "Async-Safe Write"
  pipe_primitive -> user_space.select_call: "Wakeup"
  user_space.select_call -> user_space.reap_logic: "Read 'C', trigger waitpid()"
}

# -----------------------------------------------------------------------------
# MODULE 4: CONTROL FLOW AST (IF/WHILE)
# -----------------------------------------------------------------------------
ast_structure: "AST Implementation: if/while/for" {
  node_if: "AST_NODE_IF" {
    shape: sql_table
    type: "IF"
    cond: "Ptr -> ASTNode (test)"
    then_node: "Ptr -> ASTNode (body)"
    else_node: "Ptr -> ASTNode (body)"
  }

  node_while: "AST_NODE_WHILE" {
    shape: sql_table
    type: "WHILE"
    cond: "Ptr -> ASTNode (test)"
    body: "Ptr -> ASTNode (loop)"
  }

  node_cmd: "AST_NODE_SIMPLE" {
    shape: sql_table
    type: "CMD"
    argv: "char** (args)"
    redirs: "Ptr -> RedirList"
  }

  node_if.cond -> node_cmd: "test -f file"
  node_if.then_node -> node_cmd: "echo 'found'"
  node_while.body -> node_if: "Nested logic"
}

# -----------------------------------------------------------------------------
# MODULE 5: LOGICAL OPERATOR PRECEDENCE (&& / ||)
# -----------------------------------------------------------------------------
logical_prec: "Logical Precedence (Left-Associative)" {
  direction: down

  input_text: "cmd1 && cmd2 || cmd3" {
    shape: text
    style.font-size: 20
    style.bold: true
  }

  ast_tree: "Parsed AST Hierarchy" {
    root: "OR (||)"
    and_node: "AND (&&)"
    cmd1: "cmd1"
    cmd2: "cmd2"
    cmd3: "cmd3"

    root -> and_node
    root -> cmd3
    and_node -> cmd1
    and_node -> cmd2
  }

  evaluation: "Evaluation Logic" {
    step_1: "Run cmd1"
    step_2: "If success, run cmd2"
    step_3: "If (cmd1 && cmd2) fails, run cmd3"

    step_1 -> step_2: "status == 0" { style.stroke: "${colors.process}" }
    step_2 -> step_3: "result != 0" { style.stroke: "${colors.error}" }
  }
}

# -----------------------------------------------------------------------------
# MODULE 6: HERE-DOCUMENT (PIPE-BASED)
# -----------------------------------------------------------------------------
heredoc_logic: "Here-Document Implementation (<<EOF)" {
  style.stroke: "${colors.header}"

  parent: "Parent Shell" {
    step1: "1. Parse <<EOF until delimiter"
    step2: "2. Create anonymous pipe"
    step3: "3. write() content to pipe[1]"
    step4: "4. fork() child"
    step5: "5. close(pipe[1])"
  }

  child: "Child Process (e.g., cat)" {
    step1: "1. dup2(pipe[0], STDIN)"
    step2: "2. close(pipe[0])"
    step3: "3. execvp()"
  }

  pipe: "Heredoc Pipe" {
    shape: cylinder
    style.fill: "${colors.data}"
  }

  parent.step3 -> pipe: "Write data block" { style.animated: true }
  pipe -> child.step1: "Mapped to STDIN"

  isolation_rule: |md
    **Variable Expansion Rules:**
    - If delimiter is unquoted (`<<EOF`): Expand `\$VAR` and `` `cmd` ``.
    - If delimiter is quoted (`<<'EOF'`): Treat content as literal string.
  |
}

# -----------------------------------------------------------------------------
# MEMORY LAYOUT: AST NODE
# -----------------------------------------------------------------------------
memory_map: "ASTNode Memory Layout (Total Size = 48 bytes)" {
  grid-columns: 1
  grid-gap: 0

  header: "0x00: Node Type (enum, 4 bytes) + Flags (4 bytes)" {
    width: 500
    style.fill: "${colors.header}"
    style.font-color: white
  }

  union_field: "0x08: Union Data (AST_NODE_IF / CMD / PIPE) (32 bytes)" {
    style.fill: "${colors.data}"
    style.font-color: white
  }

  ptr_left: "0x28: Left Child Ptr (ASTNode*) (8 bytes)" {
    style.fill: "${colors.pointer}"
    style.font-color: white
  }

  ptr_right: "0x30: Right Child Ptr (ASTNode*) (8 bytes)" {
    style.fill: "${colors.pointer}"
    style.font-color: white
  }

  padding: "0x38: Alignment / Future-proofing Padding (8 bytes)" {
    style.fill: "${colors.padding}"
    style.font-color: white
  }
}
