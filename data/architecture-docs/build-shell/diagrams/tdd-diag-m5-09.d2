vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    dispatch: "#4A90D9"
    simple: "#50C878"
    pipeline: "#FF6B6B"
    list: "#9B59B6"
    bg: "#F39C12"
    subshell: "#E74C3C"
    brace: "#1ABC9C"
    logical: "#3498DB"
    control: "#9B59B6"
    loop: "#E91E63"
  }
}

title: |md
  # Complete Executor Switch
  ### AST Node Dispatch Architecture
|
title.near: top-center

executor: "execute_ast(node, state)" {
  style: {
    fill: "${colors.dispatch}"
    stroke: "#2C3E50"
    stroke-width: 4
    font-color: white
    shadow: true
  }
  
  switch: "switch (node->type)" {
    shape: rectangle
    style: {
      fill: white
      stroke: "${colors.dispatch}"
      stroke-dash: 3
      font-color: black
      bold: true
    }
  }
}

# Simple Command Handler
simple_cmd: NODE_SIMPLE_CMD {
  style: {
    fill: "${colors.simple}"
    stroke: "#2ECC71"
    font-color: white
  }
  action: |md
    **execute_simple_command()**
    1. Expand words (globbing, variables)
    2. Check `is_builtin(argv[0])`
    3. If builtin: Run in-process
    4. Else: `fork()` -> `execve()`
    5. Parent: `waitpid()` for child
    6. Return exit status [0-255]
  |
}

# Pipeline Handler
pipeline: NODE_PIPELINE {
  style: {
    fill: "${colors.pipeline}"
    stroke: "#C0392B"
    font-color: white
  }
  action: |md
    **execute_pipeline()**
    1. Init `pipes[N-1][2]`
    2. Loop N nodes:
       - `pipe(p_fd)`
       - `fork()` -> `dup2()` pipe ends
       - Close unused FDs
    3. Wait for all PIDs in group
    4. Return status of **tail** command
  |
}

# Command List Handler
list: NODE_LIST {
  style: {
    fill: "${colors.list}"
    stroke: "#8E44AD"
    font-color: white
  }
  action: |md
    **Sequential Execution**
    1. Traverse AST left child
    2. Block until completion
    3. Discard return status
    4. Traverse AST right child
    5. Return right child's status
    *Used for ';' separator*
  |
}

# Background Handler
background: NODE_BACKGROUND {
  style: {
    fill: "${colors.bg}"
    stroke: "#D68910"
    font-color: white
  }
  action: |md
    **execute_background()**
    1. `fork()` child process
    2. Register job in `job_table`
    3. Child: `setpgid(0, 0)`
    4. Child: `execute_ast()`
    5. Parent: Print job ID and PID
    6. Return status 0 immediately
  |
}

# Subshell Handler
subshell: NODE_SUBSHELL {
  style: {
    fill: "${colors.subshell}"
    stroke: "#922B21"
    font-color: white
  }
  action: |md
    **execute_subshell()**
    1. `fork()` to isolate env
    2. Child: Full AST execution
    3. Child: `_exit(final_status)`
    4. Parent: `waitpid()`
    5. Env changes (CWD, vars) lost
    *Syntax: ( cmd_list )*
  |
}

# Brace Group Handler
brace_group: NODE_BRACE_GROUP {
  style: {
    fill: "${colors.brace}"
    stroke: "#16A085"
    font-color: white
  }
  action: |md
    **execute_brace_group()**
    1. Call `execute_ast(child)`
    2. Run in current process context
    3. Return child status
    4. Env changes **persist** in parent
    *Syntax: { cmd_list; }*
  |
}

# Logical AND/OR
and_op: NODE_AND {
  style: {
    fill: "${colors.logical}"
    stroke: "#2980B9"
    font-color: white
  }
  action: |md
    **execute_and()**
    1. Execute Left
    2. If status == 0: Execute Right
    3. Else: Short-circuit (skip Right)
    4. Return final executed status
  |
}

or_op: NODE_OR {
  style: {
    fill: "${colors.logical}"
    stroke: "#2980B9"
    font-color: white
  }
  action: |md
    **execute_or()**
    1. Execute Left
    2. If status != 0: Execute Right
    3. Else: Short-circuit (skip Right)
    4. Return final executed status
  |
}

# Control Flow: IF
if_stmt: NODE_IF {
  style: {
    fill: "${colors.control}"
    stroke: "#7D3C98"
    font-color: white
  }
  action: |md
    **execute_if()**
    1. Run `condition_ast`
    2. If status == 0: 
       - Run `then_ast`
    3. Else: 
       - Run `else_ast` (if present)
    4. Return body exit status
  |
}

# Control Flow: WHILE
while_loop: NODE_WHILE {
  style: {
    fill: "${colors.loop}"
    stroke: "#C2185B"
    font-color: white
  }
  action: |md
    **execute_while()**
    1. Set `jmp_buf` for break/cont
    2. Loop:
       - Run `cond_ast`
       - If status != 0: `break`
       - Run `body_ast`
    3. Return 0 or last body status
  |
}

# Control Flow: FOR
for_loop: NODE_FOR {
  style: {
    fill: "${colors.loop}"
    stroke: "#C2185B"
    font-color: white
  }
  action: |md
    **execute_for()**
    1. Expand `word_list`
    2. For each word in list:
       - Update env variable
       - Run `body_ast`
    3. Support break/continue `longjmp`
    4. Return last body status
  |
}

# Error Handler
node_default: "default:" {
  style: {
    fill: "#7F8C8D"
    stroke: "#566573"
    font-color: white
  }
  action: |md
    **Unknown Node Type**
    1. Log error to `stderr`
    2. Free AST resources
    3. Return 1 (Generic Failure)
  |
}

# Structural Connections
executor.switch -> simple_cmd: "case" { style.stroke: "${colors.simple}" }
executor.switch -> pipeline: "case" { style.stroke: "${colors.pipeline}" }
executor.switch -> list: "case" { style.stroke: "${colors.list}" }
executor.switch -> background: "case" { style.stroke: "${colors.bg}" }
executor.switch -> subshell: "case" { style.stroke: "${colors.subshell}" }
executor.switch -> brace_group: "case" { style.stroke: "${colors.brace}" }
executor.switch -> and_op: "case" { style.stroke: "${colors.logical}" }
executor.switch -> or_op: "case" { style.stroke: "${colors.logical}" }
executor.switch -> if_stmt: "case" { style.stroke: "${colors.control}" }
executor.switch -> while_loop: "case" { style.stroke: "${colors.loop}" }
executor.switch -> for_loop: "case" { style.stroke: "${colors.loop}" }
executor.switch -> node_default: "default" { 
  style: {
    stroke: "#7F8C8D"
    stroke-dash: 3
  }
}

returns: |md
  ## POSIX Return Value Convention
  - **0**: SUCCESS (Logical TRUE)
  - **1**: General error
  - **2**: Misuse of builtins
  - **126**: Command found but not executable
  - **127**: Command not found
  - **128+N**: Fatal signal N (e.g., 130 = SIGINT)
|
returns.near: bottom-right