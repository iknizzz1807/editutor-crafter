direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## GROUP BY Execution — Hash Aggregation
  `SELECT city, COUNT(*), AVG(age) FROM users GROUP BY city`
| {near: top-center}
input_rows: "① Input Rows (users)" {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.border-radius: 6
  tbl: {
    shape: sql_table
    label: "users (scan order)"
    r1: "row 1 | city='NYC'     | age=25"
    r2: "row 2 | city='LA'      | age=30"
    r3: "row 3 | city='NYC'     | age=35"
    r4: "row 4 | city='LA'      | age=20"
    r5: "row 5 | city='Chicago' | age=40"
    r6: "row 6 | city='NYC'     | age=28"
  }
}
hash_dispatch: "② hash(city) → Bucket Assignment" {
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.border-radius: 6
  fn: {
    shape: hexagon
    label: "hash(city) % N\n→ bucket_id"
    style.fill: "#F9A825"
    style.font-color: white
  }
}
after_r1: "③ After row 1 — NYC,25 inserted" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 6
  b: {
    shape: sql_table
    label: "Hash Table State"
    nyc1: "NYC     | count=1 | sum=25"
    la1:  "LA      | —       | —"
    chi1: "Chicago | —       | —"
  }
}
after_r2: "④ After row 2 — LA,30 inserted" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 6
  b: {
    shape: sql_table
    label: "Hash Table State"
    nyc2: "NYC     | count=1 | sum=25"
    la2:  "LA      | count=1 | sum=30"
    chi2: "Chicago | —       | —"
  }
}
after_r3: "⑤ After row 3 — NYC,35 merged into bucket" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 6
  b: {
    shape: sql_table
    label: "Hash Table State  (NYC bucket updated)"
    nyc3: "NYC     | count=2 | sum=60  ← count++, sum+=35"
    la3:  "LA      | count=1 | sum=30"
    chi3: "Chicago | —       | —"
  }
}
after_r4: "⑥ After row 4 — LA,20 merged into bucket" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 6
  b: {
    shape: sql_table
    label: "Hash Table State  (LA bucket updated)"
    nyc4: "NYC     | count=2 | sum=60"
    la4:  "LA      | count=2 | sum=50  ← count++, sum+=20"
    chi4: "Chicago | —       | —"
  }
}
after_r5: "⑦ After row 5 — Chicago,40 inserted" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 6
  b: {
    shape: sql_table
    label: "Hash Table State  (Chicago bucket created)"
    nyc5: "NYC     | count=2 | sum=60"
    la5:  "LA      | count=2 | sum=50"
    chi5: "Chicago | count=1 | sum=40  ← new bucket"
  }
}
final_state: "⑧ After row 6 — NYC,28 merged · All rows consumed" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.stroke-width: 2
  style.border-radius: 6
  b: {
    shape: sql_table
    label: "Final Hash Table"
    nyc_f: "NYC     | count=3 | sum=88  ← count++, sum+=28"
    la_f:  "LA      | count=2 | sum=50"
    chi_f: "Chicago | count=1 | sum=40"
  }
}
finalize: "⑨ Finalize each bucket: avg = sum / count" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.border-radius: 6
  fn: {
    shape: hexagon
    label: "for each bucket:\navg = sum / count\nemit (city, count, avg)"
    style.fill: "#E65100"
    style.font-color: white
  }
}
output_rows: "⑩ Output — one row per distinct city" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.border-radius: 6
  tbl: {
    shape: sql_table
    label: "Result Set"
    hdr:  "city    | COUNT(*) | AVG(age)"
    o1:   "NYC     | 3        | 29.33"
    o2:   "LA      | 2        | 25.00"
    o3:   "Chicago | 1        | 40.00"
  }
}
accumulator_note: {
  shape: sql_table
  label: "Accumulator Rules (applied per row)"
  a1: "new city  → create bucket  : count=1, sum=age"
  a2: "seen city → update bucket  : count++, sum+=age"
  a3: "finalize  → emit result    : city, count, sum/count"
}
accumulator_note.near: bottom-right
input_rows -> hash_dispatch: "sequential scan"
hash_dispatch -> after_r1: "row 1 → NYC"
hash_dispatch -> after_r2: "row 2 → LA"
after_r1 -> after_r3: "row 3 → NYC hit"
after_r2 -> after_r3: "state carries forward"
after_r3 -> after_r4: "row 4 → LA hit"
after_r4 -> after_r5: "row 5 → Chicago miss"
after_r5 -> final_state: "row 6 → NYC hit"
final_state -> finalize: "all 6 rows processed"
finalize -> output_rows: "3 result rows"