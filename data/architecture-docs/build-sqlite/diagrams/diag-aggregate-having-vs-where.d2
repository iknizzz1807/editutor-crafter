direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
step1: "① INPUT — users table (8 rows)" {
  direction: down
  style.fill: "#F5F5F5"
  style.stroke: "#757575"
  style.border-radius: 8
  tbl: {
    shape: sql_table
    label: "users  (name | city | age)"
    alice: "NYC  |  25"
    bob:   "NYC  |  19  ← will be dropped"
    carol: "NYC  |  22"
    dave:  "LA   |  30"
    eve:   "LA   |  18  ← will be dropped"
    frank: "LA   |  28"
    grace: "LA   |  31"
    hank:  "CHI  |  24"
  }
}
step2: "② WHERE age > 20  —  ROW-LEVEL filter, runs BEFORE any grouping" {
  direction: right
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  style.border-radius: 8
  kept: {
    shape: sql_table
    label: "KEPT — 6 rows survive  (age > 20)"
    style.fill: "#C8E6C9"
    alice: "NYC  |  25"
    carol: "NYC  |  22"
    dave:  "LA   |  30"
    frank: "LA   |  28"
    grace: "LA   |  31"
    hank:  "CHI  |  24"
  }
  dropped: {
    shape: sql_table
    label: "DROPPED — 2 rows removed  (age <= 20)"
    style.fill: "#FFCDD2"
    bob: "NYC  |  19  excluded from all groups"
    eve: "LA   |  18  excluded from all groups"
  }
}
step3: "③ GROUP BY city  —  bucket the 6 surviving rows  (Bob and Eve already gone)" {
  direction: right
  style.fill: "#EDE7F6"
  style.stroke: "#7B1FA2"
  style.border-radius: 8
  g_nyc: {
    shape: sql_table
    label: "city = NYC"
    alice: "NYC  |  25"
    carol: "NYC  |  22"
    count: "COUNT(*) = 2"
  }
  g_la: {
    shape: sql_table
    label: "city = LA"
    dave:  "LA   |  30"
    frank: "LA   |  28"
    grace: "LA   |  31"
    count: "COUNT(*) = 3"
  }
  g_chi: {
    shape: sql_table
    label: "city = CHI"
    hank:  "CHI  |  24"
    count: "COUNT(*) = 1"
  }
}
step4: "④ HAVING COUNT(*) > 2  —  GROUP-LEVEL filter, runs AFTER aggregation" {
  direction: right
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.border-radius: 8
  pass: {
    shape: sql_table
    label: "PASSES HAVING  (count > 2)"
    style.fill: "#C8E6C9"
    la: "city=LA   |  COUNT(*)=3   3 > 2 PASS"
  }
  fail: {
    shape: sql_table
    label: "FAILS HAVING  (count not > 2)"
    style.fill: "#FFCDD2"
    nyc: "city=NYC  |  COUNT(*)=2   2 > 2 FAIL"
    chi: "city=CHI  |  COUNT(*)=1   1 > 2 FAIL"
  }
}
result: "⑤ FINAL OUTPUT" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.border-radius: 8
  style.bold: true
  out: {
    shape: sql_table
    label: "SELECT city, COUNT(*)"
    la_row: "LA   |   3"
  }
}
why_note: "WHY HAVING Cannot Replace WHERE — Counter-Example" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.border-radius: 8
  counter: {
    shape: sql_table
    label: "Remove WHERE: all 8 rows enter GROUP BY — groups change"
    p1: "NYC: Alice + Bob + Carol  — COUNT = 3  (was 2 with WHERE)"
    p2: "LA:  Dave + Eve + Frank + Grace  — COUNT = 4  (was 3 with WHERE)"
    p3: "CHI: Hank  — COUNT = 1"
    p4: "HAVING COUNT > 2 would return: NYC(3) AND LA(4)  — WRONG"
    p5: "Correct result with WHERE is only: LA(3)"
    p6: "WHERE filters ROWS before counting — HAVING filters COUNTS after"
  }
}
step1 -> step2: "WHERE age > 20" {
  style.stroke: "#FF8F00"
  style.stroke-width: 3
}
step2 -> step3: "GROUP BY city" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 3
}
step3 -> step4: "HAVING COUNT(*) > 2" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}
step4 -> result: "SELECT city, COUNT(*)" {
  style.stroke: "#1565C0"
  style.stroke-width: 3
}
result -> why_note: "key insight" {
  style.stroke-dash: 5
  style.stroke: "#E65100"
  style.font-color: "#E65100"
}