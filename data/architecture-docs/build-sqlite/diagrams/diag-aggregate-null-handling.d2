direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
input_data: "Input Dataset" {
  style.fill: "#F0F4FF"
  style.stroke: "#3D5A80"
  style.border-radius: 8
  table: {
    shape: sql_table
    label: "employees.bonus — 5 rows"
    r1: "row_id=1 | bonus=100  | non-NULL"
    r2: "row_id=2 | bonus=200  | non-NULL"
    r3: "row_id=3 | bonus=NULL | NULL"
    r4: "row_id=4 | bonus=300  | non-NULL"
    r5: "row_id=5 | bonus=NULL | NULL"
    note: "3 non-NULL values (100,200,300) | 2 NULL values | 5 rows total"
  }
}
aggregates: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  agg1: "COUNT(*) = 5" {
    style.fill: "#D4EDDA"
    style.stroke: "#155724"
    style.border-radius: 8
    detail: {
      shape: sql_table
      label: "COUNT(*) — counts every row"
      r1: "row 1: COUNTED"
      r2: "row 2: COUNTED"
      r3: "row 3: COUNTED  (NULL is irrelevant)"
      r4: "row 4: COUNTED"
      r5: "row 5: COUNTED  (NULL is irrelevant)"
      res: "= 5   all rows, no exceptions"
    }
  }
  agg2: "COUNT(bonus) = 3" {
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    style.border-radius: 8
    detail: {
      shape: sql_table
      label: "COUNT(col) — skips NULLs"
      r1: "row 1: COUNTED  (100)"
      r2: "row 2: COUNTED  (200)"
      r3: "row 3: SKIPPED  bonus IS NULL"
      r4: "row 4: COUNTED  (300)"
      r5: "row 5: SKIPPED  bonus IS NULL"
      res: "= 3   non-NULL rows only"
    }
  }
  agg3: "SUM(bonus) = 600" {
    style.fill: "#D1ECF1"
    style.stroke: "#0C5460"
    style.border-radius: 8
    detail: {
      shape: sql_table
      label: "SUM — accumulates non-NULL"
      r1: "row 1: +100"
      r2: "row 2: +200"
      r3: "row 3: (skip — NULL)"
      r4: "row 4: +300"
      r5: "row 5: (skip — NULL)"
      res: "= 600   (100 + 200 + 300)"
    }
  }
  agg4: "AVG(bonus) = 200.0" {
    style.fill: "#F8D7DA"
    style.stroke: "#721C24"
    style.border-radius: 8
    detail: {
      shape: sql_table
      label: "AVG = SUM / COUNT(col)  NOT / COUNT(*)"
      r1: "numerator:   SUM(bonus)   = 600"
      r2: "denominator: COUNT(bonus) = 3   (non-NULL)"
      r3: "NOT COUNT(*) = 5  (all rows)"
      r4: "600 / 3 = 200.0  CORRECT"
      r5: "600 / 5 = 120.0  WRONG — would dilute with NULLs"
      res: "= 200.0   always returns REAL"
    }
  }
}
insight: "Correctness Summary" {
  style.fill: "#E2E3E5"
  style.stroke: "#383D41"
  style.border-radius: 8
  comparison: {
    shape: sql_table
    label: "Why COUNT(*) and COUNT(col) diverge"
    h1: "Function      | Counts NULLs | Result | Return Type"
    r1: "COUNT(*)      | YES          | 5      | INTEGER"
    r2: "COUNT(bonus)  | NO           | 3      | INTEGER"
    r3: "SUM(bonus)    | NO           | 600    | REAL"
    r4: "AVG(bonus)    | NO (both!)   | 200.0  | REAL  always"
    r5: "MIN(bonus)    | NO           | 100    | same as input"
    r6: "MAX(bonus)    | NO           | 300    | same as input"
    warn: "KEY: AVG denominator = COUNT(col) = 3, not COUNT(*) = 5"
  }
}
empty_rule: "Edge Case: Empty Input (no rows match WHERE)" {
  style.fill: "#FEF9E7"
  style.stroke: "#9B870C"
  style.border-radius: 8
  empty_table: {
    shape: sql_table
    label: "SELECT agg(bonus) FROM t WHERE 1=0"
    r1: "COUNT(*)     => 0     not NULL — COUNT is special"
    r2: "COUNT(bonus) => 0     not NULL — COUNT is special"
    r3: "SUM(bonus)   => NULL  not 0 — no values to sum"
    r4: "AVG(bonus)   => NULL  not 0 — denominator is 0"
    r5: "MIN(bonus)   => NULL  not 0 — no values seen"
    r6: "MAX(bonus)   => NULL  not 0 — no values seen"
    note: "COUNT alone returns 0 for empty input — all others return NULL"
  }
}
input_data -> aggregates: "5 rows fed to each aggregate"
aggregates -> insight: "results compared"
insight -> empty_rule: "special case: zero matching rows"