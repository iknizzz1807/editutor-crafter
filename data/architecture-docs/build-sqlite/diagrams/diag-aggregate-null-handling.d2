direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Aggregate NULL Handling — Before / After
| {near: top-center}
input_table: {
  shape: sql_table
  label: "Input Table: ages (5 rows)"
  r1: "row 1 | age = 25   | INTEGER"
  r2: "row 2 | age = NULL | ABSENT"
  r3: "row 3 | age = 30   | INTEGER"
  r4: "row 4 | age = NULL | ABSENT"
  r5: "row 5 | age = 35   | INTEGER"
  style.fill: "#BBDEFB"
  style.stroke: "#1976D2"
}
comparison_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wrong_side: "WRONG — Naive Approach" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    style.border-radius: 8
    wrong_table: {
      shape: sql_table
      label: "Naive Aggregation (WRONG)"
      a1: "COUNT(*)   | 5  (all rows)"
      a2: "COUNT(age) | 5  (WRONG: counts NULLs)"
      a3: "SUM(age)   | 90"
      a4: "AVG naive  | 90 / 5 = 18.0  ✗ WRONG"
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
    }
    wrong_code: "Mistake: NULL treated as 0 or counted" {
      width: 320
      style.fill: "#FFEBEE"
      style.stroke: "#E53935"
      style.border-radius: 6
      explain: |md
        **Error:** divides SUM by total row count
        `AVG = SUM(age) / COUNT_ALL = 90 / 5 = 18.0`
        NULL is not zero — it is the **absence of a value**.
        Including NULLs in the denominator is wrong.
      |
    }
  }
  correct_side: "CORRECT — SQL Standard Behavior" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    style.border-radius: 8
    correct_table: {
      shape: sql_table
      label: "SQL Standard Aggregation (CORRECT)"
      a1: "COUNT(*)   | 5   (all rows, incl NULL)"
      a2: "COUNT(age) | 3   (non-NULL rows only)"
      a3: "SUM(age)   | 90  (25 + 30 + 35)"
      a4: "AVG(age)   | 30.0 = 90 / 3  ✓ CORRECT"
      a5: "MIN(age)   | 25"
      a6: "MAX(age)   | 35"
      style.fill: "#C8E6C9"
      style.stroke: "#43A047"
    }
    correct_code: "SQL skips NULLs in column aggregates" {
      width: 340
      style.fill: "#E8F5E9"
      style.stroke: "#43A047"
      style.border-radius: 6
      explain: |md
        **Rule:** aggregate functions skip NULL values
        `AVG(age) = SUM(age) / COUNT(age) = 90 / 3 = 30.0`
        `COUNT(*)` counts rows; `COUNT(col)` counts non-NULLs.
        They diverge whenever NULLs are present.
      |
    }
  }
}
edge_case: "Edge Case — All-NULL Column" {
  direction: right
  style.fill: "#FFF8E1"
  style.stroke: "#F9A825"
  style.border-radius: 8
  null_input: {
    shape: sql_table
    label: "Input: all-NULL column"
    n1: "row 1 | score = NULL"
    n2: "row 2 | score = NULL"
    n3: "row 3 | score = NULL"
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
  }
  null_results: {
    shape: sql_table
    label: "Aggregate results"
    r1: "COUNT(*)     | 3     rows exist"
    r2: "COUNT(score) | 0     no non-NULL values"
    r3: "SUM(score)   | NULL  not 0"
    r4: "AVG(score)   | NULL  not 0"
    r5: "MIN(score)   | NULL"
    r6: "MAX(score)   | NULL"
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  null_note: "SUM / AVG return NULL when no values qualify" {
    width: 300
    style.fill: "#FFF3E0"
    style.stroke: "#FF6F00"
    style.border-radius: 6
    explain: |md
      `SUM(NULL, NULL, NULL)` → **NULL** (nothing to sum)
      `AVG(NULL, NULL, NULL)` → **NULL** (0 ÷ 0 is undefined)
      Developers often expect **0** — use
      `COALESCE(SUM(col), 0)` to get 0 explicitly.
    |
  }
  null_input -> null_results: "aggregate"
}
input_table -> comparison_row.wrong_side: "5 rows fed in"
input_table -> comparison_row.correct_side: "5 rows fed in"
comparison_row -> edge_case: "extreme: all values absent"