direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Implementation-Ready Standard: State Evolution of B-Tree Node Split
# Standard: Intel CPU Manual / Research Paper Quality

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state1: "STATE 1 — Leaf Page at Capacity (btree.c)" {
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.border-radius: 8
    
    page5_full: {
      shape: sql_table
      label: "Page 5 — TABLE_LEAF (4096 bytes, FULL)"
      style.fill: "#dc3545"
      style.font-color: white
      header: "0x00 | struct PageHdr | flags=0x0D, count=6, content_offset=3952"
      ptr_arr: "0x08 | uint16_t[6] | cell_ptr = [4072, 4048, 4024, 4000, 3976, 3952]"
      free_space: "0x14 | void* | [RESERVED_FREE_SPACE: 0 bytes]"
      slot0: "0xF88 | cell | key=10 | payload=24B"
      slot1: "0xFA0 | cell | key=20 | payload=24B"
      slot2: "0xFB8 | cell | key=30 | payload=24B"
      slot3: "0xFD0 | cell | key=40 | payload=24B"
      slot4: "0xFE8 | cell | key=50 | payload=24B"
      slot5: "0xFFF | cell | key=60 | payload=24B"
      footer: "Total: 4096 bytes | pin_count=1 | is_dirty=1"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state2: "STATE 2 — INSERT rowid=35 Triggers Overflow" {
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 8
    
    new_cell: {
      shape: sql_table
      label: "Incoming Cell (rowid=35)"
      style.fill: "#dc3545"
      style.font-color: white
      data: "SQL: INSERT INTO t VALUES (35, 'data')"
      encoded: "raw = [len: 1B][rowid: 35][payload: 22B]"
      size: "required = 24 bytes + 2B pointer = 26 bytes"
    }

    overflow_check: {
      shape: sql_table
      label: "page_insert_cell() Check (page.c)"
      style.fill: "#721c24"
      style.font-color: white
      call: "page_insert_cell(p5, cell, 24, pos=2)"
      calc: "available = p5->content_offset - (8 + count*2)"
      result: "available (0) < required (26) → ERR_FULL"
      action: "INVOKE: leaf_split(bp, p5, cell, 24, rowid=35)"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state3: "STATE 3 — Buffer Pool Allocation (buffer_pool.c)" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 8

    bp_alloc: {
      shape: class
      label: "BufferPool (buffer_pool.c)"
      style.fill: "#155724"
      style.font-color: white
      -frames: "Frame[1000]"
      -free_list: "List<FrameId>"
      -next_page_id: "7"
      +buffer_pool_new_page(bp, out_page): "int (RC_OK)"
      +buffer_pool_pin(bp, page_id): "void*"
    }

    page7_init: {
      shape: sql_table
      label: "Page 7 — Freshly Allocated (page.c:init)"
      style.fill: "#28a745"
      style.font-color: white
      hdr: "0x00 | uint8_t | type = 0x0D (LEAF)"
      cnt: "0x01 | uint16_t | cell_count = 0"
      off: "0x03 | uint16_t | content_start = 4096"
      free: "free_space = 4088 bytes (Empty)"
    }
    
    bp_alloc -> page7_init: "PageId=7 | alloc"
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state4: "STATE 4 — Keys Distributed (btree.c:split)" {
    style.fill: "#cce5ff"
    style.stroke: "#004085"
    style.border-radius: 8

    scratch: {
      shape: sql_table
      label: "Scratch Buffer (Sorted Union)"
      style.fill: "#495057"
      style.font-color: white
      s0: "idx 0 | rowid: 10"
      s1: "idx 1 | rowid: 20"
      s2: "idx 2 | rowid: 30"
      s3: "idx 3 | rowid: 35 (NEW)"
      s4: "idx 4 | rowid: 40"
      s5: "idx 5 | rowid: 50"
      s6: "idx 6 | rowid: 60"
      split_pt: "SPLIT AT IDX 3 (Separator = 35)"
    }

    page5_left: {
      shape: sql_table
      label: "Page 5 — LEFT (Re-init)"
      style.fill: "#0069d9"
      style.font-color: white
      slots: "rowids: [10, 20, 30]"
      count: "n_cells = 3"
      free: "~1700B available"
    }

    page7_right: {
      shape: sql_table
      label: "Page 7 — RIGHT (Populated)"
      style.fill: "#17a2b8"
      style.font-color: white
      slots: "rowids: [35, 40, 50, 60]"
      count: "n_cells = 4"
      free: "~1600B available"
    }
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state5: "STATE 5 — Separator Promotion (btree.c)" {
    style.fill: "#e2d9f3"
    style.stroke: "#6f42c1"
    style.border-radius: 8

    split_res: {
      shape: sql_table
      label: "SplitResult (struct)"
      style.fill: "#6f42c1"
      style.font-color: white
      sep_key: "separator_key = 35"
      l_pg_id: "left_page_id = 5"
      r_pg_id: "right_page_id = 7"
    }

    parent_page2: {
      shape: sql_table
      label: "Page 2 — INTERNAL (Updated)"
      style.fill: "#4b0082"
      style.font-color: white
      cell_n: "cell 1 | left_child=5 | key=35"
      r_child: "right_child = 7"
      note: "Promoted 35 to split path"
    }

    complete: {
      shape: sql_table
      label: "Transaction Complete (0)"
      style.fill: "#198754"
      style.font-color: white
      stat_l: "Page 5: keys [10,20,30]"
      stat_r: "Page 7: keys [35,40,50,60]"
      stat_p: "Page 2: Updated with child 7"
      journal: "Dirty: pg5, pg7, pg2"
    }
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  cascade: "CASCADING SPLIT — Parent Overflow Path" {
    style.fill: "#fff3cd"
    style.stroke: "#856404"
    style.border-radius: 8
    style.stroke-dash: 5

    cascade_internal: {
      shape: sql_table
      label: "Parent Page 2 FULL"
      style.fill: "#fd7e14"
      style.font-color: white
      trig: "insert(pg2, key=35) -> ERR_FULL"
      act: "internal_split(pg2) -> New pg8"
      prom: "Promote median to grandparent"
    }

    root_split: {
      shape: sql_table
      label: "Root Split (Height +1)"
      style.fill: "#c85200"
      style.font-color: white
      depth: "Reached Root (Page 1)"
      new_root: "Alloc Page 9 -> New Root"
      link: "pg9.cell[0].child = old_root"
      meta: "Update btree->root_id = 9"
    }
  }
}

state1 -> state2: "key=35"
state2 -> state3: "ERR_FULL"
state3 -> state4: "leaf_split"
state4 -> state5: "promote(35)"
state5 -> cascade: "if pg2 full" {
  style.stroke-dash: 5
}