direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
cell_overview: {
  shape: sql_table
  label: "TABLE_LEAF Cell Layout (btree.c) — 15 bytes total"
  f0: "Byte 0     | varint 1 byte  | payload_size = 13  (0x0D)"
  f1: "Byte 1     | varint 1 byte  | rowid = 42          (0x2A)"
  f2: "Bytes 2-14 | bytes[13]      | payload = header + column data"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  record_header: {
    shape: sql_table
    label: "Payload: Record Header (4 bytes)"
    h0: "Byte 0x00 | varint 0x04 | header_size = 4  (self-inclusive)"
    h1: "Byte 0x01 | varint 0x17 | serial_type[name]  = 23 = TEXT len=5"
    h2: "Byte 0x02 | varint 0x01 | serial_type[age]   = 1  = INT8"
    h3: "Byte 0x03 | varint 0x13 | serial_type[city]  = 19 = TEXT len=3"
  }
  record_data: {
    shape: sql_table
    label: "Payload: Record Data (9 bytes)"
    d0: "Bytes 0x04-0x08 | 5 bytes | name = 'Alice'  41 6C 69 63 65"
    d1: "Byte  0x09      | 1 byte  | age  = 30       1E"
    d2: "Bytes 0x0A-0x0C | 3 bytes | city = 'NYC'    4E 59 43"
    total: "Total data = 9 bytes  (4 header + 9 data = 13 payload)"
  }
}
serial_type_ref: {
  shape: sql_table
  label: "Serial Type Codec — type code encodes type AND size (no schema lookup needed)"
  s0: "Code 0          | NULL    | 0 data bytes — value is absent"
  s1: "Code 1          | INT8    | 1 byte, big-endian signed    <- age=30 uses this"
  s2: "Code 2          | INT16   | 2 bytes, big-endian signed"
  s3: "Code 4          | INT32   | 4 bytes, big-endian signed"
  s4: "Code 6          | INT64   | 8 bytes, big-endian signed"
  s5: "Code 7          | FLOAT64 | 8 bytes, IEEE 754 big-endian"
  s6: "Code 8          | INT 0   | 0 data bytes — value is integer 0"
  s7: "Code 9          | INT 1   | 0 data bytes — value is integer 1"
  s8: "Code N odd N>=13  | TEXT  | (N-13)/2 bytes UTF-8  <- name: (23-13)/2=5"
  s9: "Code N even N>=12 | BLOB  | (N-12)/2 bytes raw   <- city: (19-13)/2=3"
}
varint_detail: {
  shape: sql_table
  label: "Varint Encoding — values <128 fit in 1 byte (high bit = continuation flag)"
  v0: "Value   13 -> 0x0D      | 1 byte  | payload_size"
  v1: "Value   42 -> 0x2A      | 1 byte  | rowid (fits in 7 bits: high bit = 0)"
  v2: "Value    4 -> 0x04      | 1 byte  | header_size"
  v3: "Value   23 -> 0x17      | 1 byte  | serial_type for name='Alice'"
  v4: "Value    1 -> 0x01      | 1 byte  | serial_type for age=30"
  v5: "Value   19 -> 0x13      | 1 byte  | serial_type for city='NYC'"
  v6: "Value  128 -> 0x81 0x00 | 2 bytes | continuation bit set on byte 0"
}
cell_overview -> row1.record_header: "payload[0..3]"
cell_overview -> row1.record_data: "payload[4..12]"
row1.record_header.h1 -> row1.record_data.d0: "type 23 -> 5 bytes"
row1.record_header.h2 -> row1.record_data.d1: "type 1 -> 1 byte"
row1.record_header.h3 -> row1.record_data.d2: "type 19 -> 3 bytes"
row1.record_header -> serial_type_ref: "decode rules"
varint_detail -> cell_overview: "encodes payload_size + rowid"