direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  page: {
    style: {
      border-radius: 8
      font-size: 14
    }
  }
  hot: {
    style: {
      fill: "#FFEAEA"
      stroke: "#CC3333"
      stroke-width: 2
    }
  }
  cold: {
    style: {
      fill: "#F0F0F0"
      stroke: "#999999"
    }
  }
  found: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }
  arrow_hot: {
    style: {
      stroke: "#CC3333"
      stroke-width: 3
    }
  }
  arrow_skip: {
    style: {
      stroke: "#999999"
      stroke-dash: 4
    }
  }
}
title: B-tree Point Lookup: find rowid = 73 {
  style: {
    font-size: 22
    bold: true
    fill: transparent
    stroke: transparent
  }
}
# ============================================================
# LEVEL 0: ROOT PAGE (page 2)
# ============================================================
root: {
  label: "Root Page (page 2) — INTERNAL"
  class: [page; hot]
  header: {
    shape: sql_table
    label: "Page Header (root)"
    type: "0x05 | TABLE_INTERNAL"
    cell_count: "3"
    right_child: "page 9"
  }
  ptrs: {
    label: "Cell Pointer Array (sorted by key)"
    shape: sql_table
    ptr0: "ptr[0] → cell @ 0x0F80 | key=25"
    ptr1: "ptr[1] → cell @ 0x0F60 | key=50"
    ptr2: "ptr[2] → cell @ 0x0F40 | key=75"
  }
  search: {
    label: "Binary Search for rowid=73"
    width: 380
    style: {
      fill: "#FFF9C4"
      font-size: 13
    }
    code: |'c
      // mid=1: key[1]=50, 73>50 → go right
      // mid=2: key[2]=75, 73<=75 → left_child of cell[2]
      // Result: descend to left_child = page 7
    '|
  }
  cells: {
    label: "Cell Content Area (grows ↑ from bottom)"
    direction: right
    style.fill: transparent
    style.stroke: transparent
    cell0: {
      label: "Cell 0"
      class: cold
      shape: sql_table
      left_child: "page 3"
      key: "rowid = 25"
    }
    cell1: {
      label: "Cell 1"
      class: cold
      shape: sql_table
      left_child: "page 5"
      key: "rowid = 50"
    }
    cell2: {
      label: "Cell 2"
      class: hot
      shape: sql_table
      left_child: "page 7"
      key: "rowid = 75"
    }
  }
  header -> ptrs: "read cell count"
  ptrs -> search: "binary search"
  search -> cells.cell2: "73 <= 75"
}
# ============================================================
# LEVEL 1: INTERNAL PAGE (page 7)
# ============================================================
internal: {
  label: "Internal Page (page 7) — INTERNAL"
  class: [page; hot]
  header: {
    shape: sql_table
    label: "Page Header (internal)"
    type: "0x05 | TABLE_INTERNAL"
    cell_count: "2"
    right_child: "page 14"
  }
  ptrs: {
    label: "Cell Pointer Array (sorted by key)"
    shape: sql_table
    ptr0: "ptr[0] → cell @ 0x0F80 | key=60"
    ptr1: "ptr[1] → cell @ 0x0F60 | key=70"
  }
  search: {
    label: "Binary Search for rowid=73"
    width: 380
    style: {
      fill: "#FFF9C4"
      font-size: 13
    }
    code: |'c
      // mid=0: key[0]=60, 73>60 → go right
      // mid=1: key[1]=70, 73>70 → past all cells
      // Result: descend to right_child = page 14
    '|
  }
  cells: {
    label: "Cell Content Area"
    direction: right
    style.fill: transparent
    style.stroke: transparent
    cell0: {
      label: "Cell 0"
      class: cold
      shape: sql_table
      left_child: "page 11"
      key: "rowid = 60"
    }
    cell1: {
      label: "Cell 1"
      class: cold
      shape: sql_table
      left_child: "page 12"
      key: "rowid = 70"
    }
    right_child_box: {
      label: "right_child"
      class: hot
      shape: sql_table
      page: "page 14"
      range: "rows with rowid > 70"
    }
  }
  header -> ptrs: "read cell count"
  ptrs -> search: "binary search"
  search -> cells.right_child_box: "73 > 70"
}
# ============================================================
# LEVEL 2: LEAF PAGE (page 14)
# ============================================================
leaf: {
  label: "Leaf Page (page 14) — TABLE LEAF"
  class: [page; hot]
  header: {
    shape: sql_table
    label: "Page Header (leaf)"
    type: "0x0D | TABLE_LEAF"
    cell_count: "5"
    content_start: "0x0E00"
  }
  ptrs: {
    label: "Cell Pointer Array (sorted by rowid)"
    shape: sql_table
    ptr0: "ptr[0] → cell @ 0x0F80 | rowid=71"
    ptr1: "ptr[1] → cell @ 0x0F40 | rowid=72"
    ptr2: "ptr[2] → cell @ 0x0F00 | rowid=73 ✓"
    ptr3: "ptr[3] → cell @ 0x0EC0 | rowid=74"
    ptr4: "ptr[4] → cell @ 0x0E80 | rowid=75"
  }
  search: {
    label: "Binary Search for rowid=73"
    width: 380
    style: {
      fill: "#FFF9C4"
      font-size: 13
    }
    code: |'c
      // mid=2: key[2]=73, 73==73 → FOUND!
      // Cell pointer = 0x0F00
      // Parse cell at offset 0x0F00
    '|
  }
  found_cell: {
    label: "Cell at 0x0F00 — rowid=73 (FOUND)"
    class: found
    shape: sql_table
    payload_size: "varint | 42 bytes"
    rowid: "varint | 73"
    record_header: "hdr_size=4 | serial types: [1, 23, 4]"
    col0_id: "0x49 | int8 | 73"
    col1_name: "'Alice Chen' | text(10)"
    col2_salary: "0x0000C350 | int32 | 50000"
    total: "Total cell: 48 bytes"
  }
  header -> ptrs: "read cell count"
  ptrs -> search: "binary search"
  search -> found_cell: "exact match"
}
# ============================================================
# CONNECTIONS: Traversal path
# ============================================================
root.cells.cell2 -> internal: "follow left_child = page 7" {
  class: arrow_hot
  style.animated: true
}
internal.cells.right_child_box -> leaf: "follow right_child = page 14" {
  class: arrow_hot
  style.animated: true
}
# Skipped paths (gray dashed)
root.cells.cell0 -> skip1: "pages 3-4 skipped" {
  class: arrow_skip
}
root.cells.cell1 -> skip2: "pages 5-6 skipped" {
  class: arrow_skip
}
skip1: {
  label: "rowid <= 25"
  style: {
    fill: "#F5F5F5"
    stroke: "#CCCCCC"
    font-size: 12
    font-color: "#999999"
  }
}
skip2: {
  label: "26 <= rowid <= 50"
  style: {
    fill: "#F5F5F5"
    stroke: "#CCCCCC"
    font-size: 12
    font-color: "#999999"
  }
}
internal.cells.cell0 -> skip3: "" {
  class: arrow_skip
}
internal.cells.cell1 -> skip4: "" {
  class: arrow_skip
}
skip3: {
  label: "rowid <= 60"
  style: {
    fill: "#F5F5F5"
    stroke: "#CCCCCC"
    font-size: 12
    font-color: "#999999"
  }
}
skip4: {
  label: "61 <= rowid <= 70"
  style: {
    fill: "#F5F5F5"
    stroke: "#CCCCCC"
    font-size: 12
    font-color: "#999999"
  }
}
# ============================================================
# COST SUMMARY
# ============================================================
cost: {
  label: "Lookup Cost Summary"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    border-radius: 8
    font-size: 13
  }
  detail: {
    shape: sql_table
    label: "I/O Analysis"
    pages_read: "3 pages read (root + internal + leaf)"
    comparisons: "~5 comparisons total (log2 of cells per page)"
    buffer_pool: "Root + internal likely cached (hot pages)"
    worst_case: "Cold cache: 3 x fetch_page = 3 x ~100us (SSD)"
    best_case: "Warm cache: 3 x ~10ns (buffer pool hit)"
    rows_skipped: "Skipped ~99.99% of rows (only visited 3 of ~14000 pages)"
  }
}