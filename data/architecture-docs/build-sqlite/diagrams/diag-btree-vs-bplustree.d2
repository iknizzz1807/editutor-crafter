direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "B-tree vs B+tree: Same 15 Keys, Different Structure" {
  style.font-size: 28
  style.bold: true
  style.underline: true
  near: top-center
}
classes: {
  internal_bt: {
    style.fill: "#E8D5F5"
    style.stroke: "#7B2D8E"
    style.border-radius: 6
    style.font-size: 13
  }
  leaf_bt: {
    style.fill: "#F5E6D0"
    style.stroke: "#B8860B"
    style.border-radius: 6
    style.font-size: 13
  }
  internal_bpt: {
    style.fill: "#D5E8F5"
    style.stroke: "#2D5F8E"
    style.border-radius: 6
    style.font-size: 13
  }
  leaf_bpt: {
    style.fill: "#D0F5D0"
    style.stroke: "#2D8E2D"
    style.border-radius: 6
    style.font-size: 13
  }
  link_arrow: {
    style.stroke: "#2D8E2D"
    style.stroke-width: 3
    style.animated: true
  }
  data_indicator: {
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    style.border-radius: 4
    style.font-size: 11
    style.italic: true
  }
  comparison_box: {
    style.fill: "#F8F9FA"
    style.stroke: "#6C757D"
    style.border-radius: 8
  }
}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  btree_side: "B-tree (Table Storage)" {
    direction: down
    style.fill: "#FDF2F8"
    style.stroke: "#7B2D8E"
    style.border-radius: 10
    style.font-size: 20
    style.bold: true
    note_bt: "Data stored in ALL nodes (internal + leaf)" {
      style.fill: "#FCE4EC"
      style.stroke: "#C62828"
      style.font-size: 12
      style.italic: true
      style.border-radius: 4
    }
    bt_root: {
      shape: sql_table
      label: "Root (page 1)"
      class: internal_bt
      k1: "key=20 | rowid=20 | record: {Alice, 30}"
      k2: "key=50 | rowid=50 | record: {Eve, 28}"
      fanout: "Fanout: 3 children (keys + data consume space)"
    }
    bt_row2: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      bt_left: {
        shape: sql_table
        label: "Internal (page 2)"
        class: internal_bt
        k1: "key=5  | rowid=5  | record: {Bob, 25}"
        k2: "key=10 | rowid=10 | record: {Carol, 22}"
        fanout: "Fanout: 3"
      }
      bt_mid: {
        shape: sql_table
        label: "Internal (page 3)"
        class: internal_bt
        k1: "key=30 | rowid=30 | record: {Dan, 35}"
        k2: "key=40 | rowid=40 | record: {Fay, 29}"
        fanout: "Fanout: 3"
      }
      bt_right: {
        shape: sql_table
        label: "Internal (page 4)"
        class: internal_bt
        k1: "key=60 | rowid=60 | record: {Gus, 40}"
        k2: "key=80 | rowid=80 | record: {Hal, 33}"
        fanout: "Fanout: 3"
      }
    }
    bt_row3: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      bt_l1: {
        shape: sql_table
        label: "Leaf (page 5)"
        class: leaf_bt
        k1: "key=1  | record: {Ian, 21}"
        k2: "key=3  | record: {Jan, 27}"
      }
      bt_l2: {
        shape: sql_table
        label: "Leaf (page 6)"
        class: leaf_bt
        k1: "key=7  | record: {Kay, 24}"
        k2: "key=8  | record: {Leo, 31}"
      }
      bt_l3: {
        shape: sql_table
        label: "Leaf (page 7)"
        class: leaf_bt
        k1: "key=15 | record: {Mia, 26}"
      }
      bt_l4: {
        shape: sql_table
        label: "Leaf (page 8)"
        class: leaf_bt
        k1: "key=25 | record: {Ned, 38}"
      }
      bt_l5: {
        shape: sql_table
        label: "Leaf (page 9)"
        class: leaf_bt
        k1: "key=35 | record: {Ora, 23}"
      }
      bt_l6: {
        shape: sql_table
        label: "Leaf (page 10)"
        class: leaf_bt
        k1: "key=55 | record: {Pat, 42}"
      }
      bt_l7: {
        shape: sql_table
        label: "Leaf (page 11)"
        class: leaf_bt
        k1: "key=70 | record: {Qin, 36}"
        k2: "key=90 | record: {Ray, 29}"
      }
    }
    bt_root -> bt_row2.bt_left: "keys < 20"
    bt_root -> bt_row2.bt_mid: "20 < keys < 50"
    bt_root -> bt_row2.bt_right: "keys > 50"
    bt_row2.bt_left -> bt_row3.bt_l1: "< 5"
    bt_row2.bt_left -> bt_row3.bt_l2: "5-10"
    bt_row2.bt_left -> bt_row3.bt_l3: "> 10"
    bt_row2.bt_mid -> bt_row3.bt_l4: "< 30"
    bt_row2.bt_mid -> bt_row3.bt_l5: "30-40"
    bt_row2.bt_mid -> bt_row3.bt_l6: "> 40"
    bt_row2.bt_right -> bt_row3.bt_l7: "< 60"
    bt_stats: {
      shape: sql_table
      label: "B-tree Stats"
      class: data_indicator
      s1: "Total pages: 11"
      s2: "Height: 3 levels"
      s3: "Max fanout: 3 (data in nodes reduces fanout)"
      s4: "Point lookup: may stop at internal node"
      s5: "Range scan: zigzag traversal up and down tree"
      s6: "No leaf links -- range scan requires stack"
      s7: "Used by: SQLite table storage (rowid lookup)"
    }
  }
  bptree_side: "B+tree (Index Storage)" {
    direction: down
    style.fill: "#F0F7FF"
    style.stroke: "#2D5F8E"
    style.border-radius: 10
    style.font-size: 20
    style.bold: true
    note_bpt: "Data stored ONLY in leaf nodes (internals are signposts)" {
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      style.font-size: 12
      style.italic: true
      style.border-radius: 4
    }
    bpt_root: {
      shape: sql_table
      label: "Root (page 1) -- keys only, NO data"
      class: internal_bpt
      k1: "sep=10 | child_left=pg2"
      k2: "sep=30 | child_mid=pg3"
      k3: "sep=60 | child_right=pg4"
      k4: "right_child=pg5"
      fanout: "Fanout: 5 (no data payload -- more keys fit)"
    }
    bpt_row2: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      bpt_i1: {
        shape: sql_table
        label: "Internal (page 2) -- keys only"
        class: internal_bpt
        k1: "sep=3 | child=pg6"
        k2: "sep=7 | child=pg7"
        k3: "right_child=pg8"
        fanout: "Fanout: 4"
      }
      bpt_i2: {
        shape: sql_table
        label: "Internal (page 3) -- keys only"
        class: internal_bpt
        k1: "sep=20 | child=pg9"
        k2: "right_child=pg10"
        fanout: "Fanout: 3"
      }
      bpt_i3: {
        shape: sql_table
        label: "Internal (page 4) -- keys only"
        class: internal_bpt
        k1: "sep=40 | child=pg11"
        k2: "sep=50 | child=pg12"
        k3: "right_child=pg13"
        fanout: "Fanout: 4"
      }
      bpt_i4: {
        shape: sql_table
        label: "Internal (page 5) -- keys only"
        class: internal_bpt
        k1: "sep=80 | child=pg14"
        k2: "right_child=pg15"
        fanout: "Fanout: 3"
      }
    }
    bpt_row3: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      bpt_lf1: {
        shape: sql_table
        label: "Leaf pg6"
        class: leaf_bpt
        k1: "key=1 | rowid=1"
        k2: "key=3 | rowid=3"
      }
      bpt_lf2: {
        shape: sql_table
        label: "Leaf pg7"
        class: leaf_bpt
        k1: "key=5 | rowid=5"
        k2: "key=7 | rowid=7"
      }
      bpt_lf3: {
        shape: sql_table
        label: "Leaf pg8"
        class: leaf_bpt
        k1: "key=8  | rowid=8"
        k2: "key=10 | rowid=10"
      }
      bpt_lf4: {
        shape: sql_table
        label: "Leaf pg9"
        class: leaf_bpt
        k1: "key=15 | rowid=15"
        k2: "key=20 | rowid=20"
      }
      bpt_lf5: {
        shape: sql_table
        label: "Leaf pg10"
        class: leaf_bpt
        k1: "key=25 | rowid=25"
        k2: "key=30 | rowid=30"
      }
      bpt_lf6: {
        shape: sql_table
        label: "Leaf pg11"
        class: leaf_bpt
        k1: "key=35 | rowid=35"
        k2: "key=40 | rowid=40"
      }
      bpt_lf7: {
        shape: sql_table
        label: "Leaf pg12"
        class: leaf_bpt
        k1: "key=50 | rowid=50"
        k2: "key=55 | rowid=55"
      }
      bpt_lf8: {
        shape: sql_table
        label: "Leaf pg13"
        class: leaf_bpt
        k1: "key=60 | rowid=60"
      }
      bpt_lf9: {
        shape: sql_table
        label: "Leaf pg14"
        class: leaf_bpt
        k1: "key=70 | rowid=70"
        k2: "key=80 | rowid=80"
      }
      bpt_lf10: {
        shape: sql_table
        label: "Leaf pg15"
        class: leaf_bpt
        k1: "key=90 | rowid=90"
      }
    }
    bpt_root -> bpt_row2.bpt_i1: "< 10"
    bpt_root -> bpt_row2.bpt_i2: "10-29"
    bpt_root -> bpt_row2.bpt_i3: "30-59"
    bpt_root -> bpt_row2.bpt_i4: "> 60"
    bpt_row2.bpt_i1 -> bpt_row3.bpt_lf1: "< 3"
    bpt_row2.bpt_i1 -> bpt_row3.bpt_lf2: "3-6"
    bpt_row2.bpt_i1 -> bpt_row3.bpt_lf3: "> 7"
    bpt_row2.bpt_i2 -> bpt_row3.bpt_lf4: "< 20"
    bpt_row2.bpt_i2 -> bpt_row3.bpt_lf5: "> 20"
    bpt_row2.bpt_i3 -> bpt_row3.bpt_lf6: "< 40"
    bpt_row2.bpt_i3 -> bpt_row3.bpt_lf7: "40-49"
    bpt_row2.bpt_i3 -> bpt_row3.bpt_lf8: "> 50"
    bpt_row2.bpt_i4 -> bpt_row3.bpt_lf9: "< 80"
    bpt_row2.bpt_i4 -> bpt_row3.bpt_lf10: "> 80"
    # Leaf chain links
    bpt_row3.bpt_lf1 -> bpt_row3.bpt_lf2: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf2 -> bpt_row3.bpt_lf3: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf3 -> bpt_row3.bpt_lf4: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf4 -> bpt_row3.bpt_lf5: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf5 -> bpt_row3.bpt_lf6: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf6 -> bpt_row3.bpt_lf7: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf7 -> bpt_row3.bpt_lf8: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf8 -> bpt_row3.bpt_lf9: "next" {
      class: link_arrow
    }
    bpt_row3.bpt_lf9 -> bpt_row3.bpt_lf10: "next" {
      class: link_arrow
    }
    bpt_stats: {
      shape: sql_table
      label: "B+tree Stats"
      class: data_indicator
      s1: "Total pages: 15 (more pages, but shallower at scale)"
      s2: "Height: 3 levels"
      s3: "Max fanout: 5 (no data in internals -- more keys fit)"
      s4: "Point lookup: always descends to leaf"
      s5: "Range scan: follow leaf chain sequentially"
      s6: "Leaf links enable fast BETWEEN / ORDER BY"
      s7: "Used by: SQLite secondary indexes, PostgreSQL, InnoDB"
    }
  }
}
comparison: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  cmp_table: {
    shape: sql_table
    label: "Head-to-Head Comparison (C, 4KB pages, 8-byte keys)"
    style.fill: "#FFFFFF"
    style.stroke: "#343A40"
    style.font-size: 14
    h1: "Property | B-tree | B+tree"
    r1: "Data location | All nodes | Leaves only"
    r2: "Internal node payload | key + row data (100B) | key + child ptr (12B)"
    r3: "Keys per internal page | ~35 (with 100B rows) | ~340 (keys only)"
    r4: "3-level capacity | 35^3 = 42,875 rows | 340^3 = 39,304,000 rows"
    r5: "Point lookup I/O | 1-3 pages (may hit internal) | Always 3 pages (must reach leaf)"
    r6: "Range scan WHERE k BETWEEN 20 AND 50 | Zigzag traversal (touch every level) | Descend once then follow leaf chain"
    r7: "Leaf connectivity | None (use parent stack) | Doubly-linked list"
    r8: "Write cost | One insert per node level | One insert per node level"
    r9: "Best for | Rowid point lookups (table storage) | Range scans and secondary indexes"
  }
  when_to_use: {
    shape: sql_table
    label: "When to Use Each (SQLite Strategy)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.font-size: 14
    u1: "B-tree for TABLES | Key = rowid (integer) | Fast: SELECT * FROM t WHERE rowid = 42"
    u2: "B-tree for TABLES | Row data lives IN the node | No double lookup needed for rowid access"
    u3: "B+tree for INDEXES | Key = indexed column value | Fast: WHERE age BETWEEN 20 AND 30 (leaf chain)"
    u4: "B+tree for INDEXES | Leaf stores (col_value, rowid) | Double lookup: index leaf -> rowid -> table B-tree"
    u5: "B+tree for INDEXES | Higher fanout = shallower tree | 340^3 = 39M keys in 3 levels vs 35^3 = 43K"
  }
}