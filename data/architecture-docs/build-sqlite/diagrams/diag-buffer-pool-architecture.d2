direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bp: {
    shape: class
    label: "BufferPool (buffer_pool.c)"
    -fd: "int"
    -frames: "Frame*"
    -pool_size: "int"
    -next_page_id: "PageId"
    -page_table: "PageTableEntry**"
    -page_table_size: "int"
    -lru_head: "int"
    -lru_tail: "int"
    -stats: "BufferPoolStats"
    +buffer_pool_fetch(bp, page_id): "uint8_t*"
    +buffer_pool_unpin(bp, page_id, dirty): "void"
    +buffer_pool_new_page(bp, page_id_out): "uint8_t*"
    +buffer_pool_flush_page(bp, page_id): "int"
    +buffer_pool_flush_all(bp): "int"
    +buffer_pool_destroy(bp): "void"
    +buffer_pool_get_stats(bp, out): "void"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  page_table_box: {
    label: "PageTable — Hash Map (page_id → frame_idx)"
    direction: down
    style.fill: "#E8F4FD"
    style.stroke: "#1565C0"
    entry_struct: {
      shape: sql_table
      label: "PageTableEntry (page_table.c)"
      f0: "0x00 | PageId            | page_id"
      f1: "0x04 | int               | frame_index"
      f2: "0x08 | PageTableEntry*   | next  (collision chain)"
      sz: "Total: 12 bytes per entry"
    }
    hash_details: {
      label: "Hash: (page_id × 2654435761) mod table_size\nLoad factor ≈ 0.5  |  table_size = pool_size × 2\nSeparate chaining resolves collisions\nO(1) avg lookup · insert · remove"
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
    }
  }
  frame_arr_box: {
    label: "Frame Array — frames[pool_size] (buffer_pool.h)"
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#E65100"
    frame_struct: {
      shape: sql_table
      label: "Frame (buffer_pool.h)"
      f0: "0x0000 | PageId        | page_id      (UINT32_MAX = empty)"
      f1: "0x0004 | uint8_t[4096] | data         (page bytes)"
      f2: "0x1004 | int           | pin_count    (0 = evictable)"
      f3: "0x1008 | int           | is_dirty     (1 = modified)"
      f4: "0x100C | int           | lru_prev     (frame idx or -1)"
      f5: "0x1010 | int           | lru_next     (frame idx or -1)"
      sz: "Total: 4120 bytes/frame  |  1000 frames ≈ 4.0 MB RAM"
    }
    pool_note: {
      label: "Frames allocated once at create time — fixed memory footprint\nSQLite PRAGMA cache_size controls pool_size at runtime"
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lru_box: {
    label: "LRU Doubly-Linked List (embedded in Frame[])"
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#6A1B9A"
    lru_layout: {
      shape: sql_table
      label: "LRU List Structure"
      r0: "bp.lru_head → frame[i]   (most recently used)"
      r1: "  frame[i].lru_prev = -1   (head sentinel)"
      r2: "  frame[i].lru_next = j"
      r3: "frame[j].lru_prev  = i"
      r4: "  frame[j].lru_next = k    (mid-list node)"
      r5: "bp.lru_tail → frame[z]   (least recently used)"
      r6: "  frame[z].lru_next = -1   (tail sentinel)"
    }
    lru_ops: {
      shape: sql_table
      label: "LRU Operations — all O(1)"
      op1: "lru_move_to_head(idx)   3 pointer updates"
      op2: "evict_lru()             read bp.lru_tail"
      op3: "lru_insert_head(idx)    set head links"
      op4: "lru_remove(idx)         splice out node"
    }
    evict_rule: {
      label: "INVARIANT: pin_count > 0 → never evicted\nDirty eviction: pwrite() before frame reuse\nClean eviction: direct reuse, no disk write"
      style.fill: "#EDE7F6"
      style.stroke: "#6A1B9A"
    }
  }
  disk_box: {
    label: "Disk Manager Interface"
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#1B5E20"
    disk_ops: {
      shape: class
      label: "DiskManager (POSIX calls)"
      +pread(fd, buf, PAGE_SIZE, offset): "ssize_t"
      +pwrite(fd, buf, PAGE_SIZE, offset): "ssize_t"
      +fsync(fd): "int"
      +lseek(fd, 0, SEEK_END): "off_t"
    }
    page_addr: {
      shape: sql_table
      label: "Linear Page Addressing"
      r0: "page_id=0   offset=0x00000   (byte 0)"
      r1: "page_id=1   offset=0x01000   (byte 4096)"
      r2: "page_id=N   offset=N × PAGE_SIZE"
      r3: "new page    pwrite past EOF extends file"
    }
    io_note: {
      label: "pread/pwrite: atomic positional I/O\nNo lseek race — thread-safe by design\nO_RDWR | O_CREAT on db_open()"
      style.fill: "#F1F8E9"
      style.stroke: "#1B5E20"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fetch_flow: {
    label: "FetchPage(page_id) Execution Path"
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#B71C1C"
    hot_path: {
      shape: sql_table
      label: "STEP 1 — Page Table Lookup (hot path)"
      s1: "bucket = (page_id × 2654435761) mod table_size"
      s2: "walk chain until entry.page_id == page_id"
      s3: "  HIT:  frame_idx = entry.frame_index"
      s4: "        frames[frame_idx].pin_count++"
      s5: "        lru_move_to_head(frame_idx)"
      s6: "        return &frames[frame_idx].data[0]"
    }
    cold_path: {
      shape: sql_table
      label: "STEP 2 — Cache Miss Path (cold)"
      s1:  "frame_idx = find_free_frame()  or  evict_lru()"
      s2:  "if evicting dirty frame:"
      s3:  "  pwrite(fd, frame.data, PAGE_SIZE, old_offset)"
      s4:  "  page_table_remove(old_page_id)"
      s5:  "offset = page_id × PAGE_SIZE"
      s6:  "pread(fd, frames[frame_idx].data, PAGE_SIZE, offset)"
      s7:  "frames[frame_idx].page_id   = page_id"
      s8:  "frames[frame_idx].pin_count = 1"
      s9:  "frames[frame_idx].is_dirty  = 0"
      s10: "page_table_insert(page_id, frame_idx)"
      s11: "lru_insert_head(frame_idx)"
      s12: "return &frames[frame_idx].data[0]"
    }
  }
  perf_and_stats: {
    direction: down
    style.fill: "#F9FBE7"
    style.stroke: "#827717"
    perf: {
      shape: sql_table
      label: "FetchPage Latency (4 KB page)"
      p1: "Hot  L2 hit:    ~10 ns    pin_count++ only"
      p2: "Warm OS cache:  ~1 µs     kernel copy"
      p3: "Cold NVMe:      ~100 µs   random read"
      p4: "Cold HDD:       ~5 ms     seek + rotation"
      p5: "hit_rate > 99%  → memory-speed queries"
    }
    stats_struct: {
      shape: sql_table
      label: "BufferPoolStats (buffer_pool.h)"
      f0: "0x00 | uint64_t | fetches       (total FetchPage calls)"
      f1: "0x08 | uint64_t | hits          (found in pool)"
      f2: "0x10 | uint64_t | misses        (loaded from disk)"
      f3: "0x18 | uint64_t | evictions     (frames evicted)"
      f4: "0x20 | uint64_t | dirty_writes  (dirty pages written)"
      sz: "Total: 40 bytes  |  hit_rate = hits / fetches"
    }
  }
}
row1.bp -> row2.page_table_box: "page_id | hash"
row1.bp -> row2.frame_arr_box: "frames[] | direct"
row2.page_table_box -> row2.frame_arr_box: "frame_idx | resolve"
row2.frame_arr_box -> row3.lru_box: "access | move_to_head"
row2.frame_arr_box -> row3.disk_box: "cache miss | pread"
row3.disk_box -> row2.frame_arr_box: "uint8_t[4096] | fill"
row3.lru_box -> row2.frame_arr_box: "evict tail | reclaim" {
  style.stroke-dash: 4
}
row1.bp -> row4.fetch_flow: "FetchPage | traverse"
row2.frame_arr_box -> row4.perf_and_stats.stats_struct: "metrics | update"