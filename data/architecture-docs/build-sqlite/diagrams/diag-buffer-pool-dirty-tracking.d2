direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
classes: {
  state: {
    style: {
      border-radius: 99
      font-size: 16
      bold: true
    }
  }
  guard: {
    style: {
      font-size: 13
      italic: true
    }
  }
}
title: Dirty Page Lifecycle (buffer_pool.c) {
  style: {
    font-size: 22
    bold: true
    fill: transparent
    stroke: transparent
  }
}
# ─── States ───
row_top: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  not_loaded: NOT IN POOL {
    class: state
    style.fill: "#E8E8E8"
    style.stroke: "#999"
  }
  clean: CLEAN (in pool) {
    class: state
    style.fill: "#B2DFDB"
    style.stroke: "#00796B"
  }
}
row_mid: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pinned_dirty: PINNED + DIRTY {
    class: state
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  unpinned_dirty: UNPINNED + DIRTY {
    class: state
    style.fill: "#FFE0B2"
    style.stroke: "#E65100"
  }
}
row_bot: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  writing_back: WRITE-BACK {
    class: state
    style.fill: "#E1BEE7"
    style.stroke: "#6A1B9A"
  }
  evicted: EVICTED {
    class: state
    style.fill: "#E8E8E8"
    style.stroke: "#999"
  }
}
# ─── Transitions ───
row_top.not_loaded -> row_top.clean: "fetch_page()" {
  style.stroke: "#00796B"
  style.stroke-width: 2
}
row_top.clean -> row_mid.pinned_dirty: "B-tree modifies page" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
row_mid.pinned_dirty -> row_mid.unpinned_dirty: "unpin_page(dirty=true)" {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
row_mid.unpinned_dirty -> row_bot.writing_back: "evict or flush_all()" {
  style.stroke: "#6A1B9A"
  style.stroke-width: 2
}
row_bot.writing_back -> row_top.clean: "pwrite + is_dirty=false" {
  style.stroke: "#00796B"
  style.stroke-width: 2
}
row_bot.writing_back -> row_bot.evicted: "page_table_remove()" {
  style.stroke: "#999"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row_bot.evicted -> row_top.not_loaded: "frame reclaimed" {
  style.stroke: "#999"
  style.stroke-dash: 4
}
# Re-pin from clean
row_top.clean -> row_mid.pinned_dirty: " " {
  style.opacity: 0
}
# Self-loop: re-fetch a clean page increments pin
row_top.clean -> row_top.clean: "fetch_page() hit\npin_count++" {
  style.stroke: "#00796B"
  style.stroke-dash: 3
}
# Self-loop: multiple modifications while pinned
row_mid.pinned_dirty -> row_mid.pinned_dirty: "more B-tree writes\npin_count unchanged" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
# Pin count detail panel
pin_detail: Pin Count Rules (buffer_pool.h) {
  shape: sql_table
  label: "Pin Count Rules (buffer_pool.h)"
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  r0: "Operation          | pin_count effect"
  r1: "fetch_page()       | +1 (caller holds lease)"
  r2: "unpin_page()       | -1 (caller releases)"
  r3: "evict candidate    | must be 0 (NEVER evict pinned)"
  r4: "flush_page()       | unchanged (page stays in pool)"
  r5: "buffer_pool_destroy| flush all dirty, ignore pins"
}
# Write-ordering note
write_order: Write Ordering Invariant {
  shape: sql_table
  label: "Write Ordering (txn_manager.c)"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  r0: "Step | Action"
  r1: "1    | txn_journal_page() — save original to journal"
  r2: "2    | fsync(journal_fd)"
  r3: "3    | disk_write_page() — write dirty page to DB"
  r4: "4    | fsync(db_fd) — on commit only"
  r5: "INVARIANT | journal fsync BEFORE any DB write"
}
pin_detail -> row_mid.pinned_dirty: "governs eviction safety" {
  style.stroke-dash: 5
  style.stroke: "#F9A825"
  style.opacity: 0.5
}
write_order -> row_bot.writing_back: "enforced before write-back" {
  style.stroke-dash: 5
  style.stroke: "#1565C0"
  style.opacity: 0.5
}