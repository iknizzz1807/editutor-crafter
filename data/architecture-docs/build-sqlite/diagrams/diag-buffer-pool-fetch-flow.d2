direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## FetchPage — Hit vs Miss Data Walk
  Buffer Pool Manager · C Implementation
|
entry: FetchPage(page_id) {
  shape: rectangle
  style: {
    fill: "#e8f4f8"
    stroke: "#2c7bb6"
    stroke-width: 2
    font-size: 14
    bold: true
  }
  code: {
    shape: code
    language: c
    label: |c
      Frame *fetch_page(BufPool *pool, page_id_t pid);
    |
  }
}
lookup: page_table_lookup(pool, page_id) {
  shape: diamond
  style: {
    fill: "#fff3cd"
    stroke: "#d4a017"
    stroke-width: 2
    font-size: 13
  }
}
paths: "" {
  style: {
    fill: transparent
    stroke: transparent
  }
  hit_path: CACHE HIT {
    style: {
      fill: "#f0faf0"
      stroke: "#27ae60"
      stroke-width: 2
      border-radius: 8
    }
    h1: hash_lookup returns frame_index {
      shape: rectangle
      style: {
        fill: "#d5f5e3"
        stroke: "#27ae60"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          int fi = ht_get(pool->page_table, pid);
          // fi >= 0  →  HIT
        |
      }
    }
    h2: Increment pin_count {
      shape: rectangle
      style: {
        fill: "#d5f5e3"
        stroke: "#27ae60"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          Frame *f = &pool->frames[fi];
          f->pin_count++;
        |
      }
    }
    h3: lru_move_to_head(pool->lru, fi) {
      shape: rectangle
      style: {
        fill: "#d5f5e3"
        stroke: "#27ae60"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          /* unlink node, relink at head */
          lru_move_to_head(pool->lru, fi);
        |
      }
    }
    h4: return frame->data {
      shape: rectangle
      style: {
        fill: "#27ae60"
        stroke: "#1e8449"
        font-color: white
        font-size: 13
        bold: true
      }
      code: {
        shape: code
        language: c
        label: |c
          return f->data;   /* hot path done */
        |
      }
    }
    h1 -> h2
    h2 -> h3
    h3 -> h4
  }
  miss_path: CACHE MISS {
    style: {
      fill: "#fff8f0"
      stroke: "#e67e22"
      stroke-width: 2
      border-radius: 8
    }
    m1: hash_lookup returns -1 {
      shape: rectangle
      style: {
        fill: "#fde8cc"
        stroke: "#e67e22"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          int fi = ht_get(pool->page_table, pid);
          // fi == -1  →  MISS
        |
      }
    }
    m2: lru_evict_tail → victim frame_index {
      shape: rectangle
      style: {
        fill: "#fde8cc"
        stroke: "#e67e22"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          int victim = lru_evict_tail(pool->lru);
          Frame *f   = &pool->frames[victim];
          assert(f->pin_count == 0);
        |
      }
    }
    dirty_check: f->is_dirty? {
      shape: diamond
      style: {
        fill: "#fde8cc"
        stroke: "#c0392b"
        stroke-width: 2
        font-size: 12
      }
    }
    m3_dirty: Write-back dirty page to disk {
      shape: parallelogram
      style: {
        fill: "#fadbd8"
        stroke: "#c0392b"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          off_t off = (off_t)f->page_id * PAGE_SIZE;
          pwrite(pool->fd, f->data, PAGE_SIZE, off);
          f->is_dirty = false;
        |
      }
    }
    m4_remove: page_table_remove + lru_remove {
      shape: rectangle
      style: {
        fill: "#fde8cc"
        stroke: "#e67e22"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          ht_remove(pool->page_table, f->page_id);
          lru_remove(pool->lru, victim);
        |
      }
    }
    m5_read: pread() — load new page from disk {
      shape: parallelogram
      style: {
        fill: "#fdebd0"
        stroke: "#e67e22"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          off_t off = (off_t)pid * PAGE_SIZE;
          pread(pool->fd, f->data, PAGE_SIZE, off);
        |
      }
    }
    m6_meta: Install frame metadata {
      shape: rectangle
      style: {
        fill: "#fde8cc"
        stroke: "#e67e22"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          f->page_id   = pid;
          f->pin_count = 1;
          f->is_dirty  = false;
        |
      }
    }
    m7_insert: page_table_insert + lru_insert_head {
      shape: rectangle
      style: {
        fill: "#fde8cc"
        stroke: "#e67e22"
        font-size: 12
      }
      code: {
        shape: code
        language: c
        label: |c
          ht_put(pool->page_table, pid, victim);
          lru_insert_head(pool->lru, victim);
        |
      }
    }
    m8: return frame->data {
      shape: rectangle
      style: {
        fill: "#e67e22"
        stroke: "#ca6f1e"
        font-color: white
        font-size: 13
        bold: true
      }
      code: {
        shape: code
        language: c
        label: |c
          return f->data;   /* cold path done */
        |
      }
    }
    m1 -> m2
    m2 -> dirty_check
    dirty_check -> m3_dirty: "YES — dirty" {
      style.stroke: "#c0392b"
      style.font-color: "#c0392b"
      style.bold: true
    }
    dirty_check -> m4_remove: "NO — clean" {
      style.stroke: "#27ae60"
      style.font-color: "#27ae60"
    }
    m3_dirty -> m4_remove
    m4_remove -> m5_read
    m5_read -> m6_meta
    m6_meta -> m7_insert
    m7_insert -> m8
  }
}
legend: "" {
  near: bottom-right
  style: {
    fill: "#fafafa"
    stroke: "#aaaaaa"
    border-radius: 6
    font-size: 11
  }
  label: |md
    **Legend**
    🟩 Cache HIT — O(1), no I/O
    🟧 Cache MISS — evict → optional write-back → pread
    ◇  Decision point
    ▱  Disk I/O (pread / pwrite)
    pin_count guards against evicting live frames
  |
}
entry -> lookup
lookup -> paths.hit_path.h1: "HIT  (fi ≥ 0)" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.font-color: "#27ae60"
  style.bold: true
}
lookup -> paths.miss_path.m1: "MISS  (fi = -1)" {
  style.stroke: "#e67e22"
  style.stroke-width: 2
  style.font-color: "#e67e22"
  style.bold: true
}