direction: down
vars: {
  d2-config: {
    layout-engine: elk
  }
}
title: {
  label: "LRU Eviction — State Evolution\nBuffer Pool Manager · 5 Frames"
  shape: text
  style.font-size: 20
  style.bold: true
}
legend: {
  label: "■ Pinned (protected)  □ Unpinned  ✦ Dirty  → MRU ··· LRU"
  shape: text
  style.font-size: 12
  style.italic: true
}
# ─────────────────────────────────────────────
# STATE 0 — Initial: pool empty
# ─────────────────────────────────────────────
s0: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  op: {
    label: "Initial State\nPool empty · 5 free frames"
    shape: text
    style.font-size: 13
    style.bold: true
  }
  pool: {
    label: "Buffer Pool Frames"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.border-radius: 6
    f0: { label: "Frame 0\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
    f1: { label: "Frame 1\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
    f2: { label: "Frame 2\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
    f3: { label: "Frame 3\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
    f4: { label: "Frame 4\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
  }
  lru: {
    label: "LRU List (MRU → LRU)\n[ empty ]"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.border-radius: 6
    shape: rectangle
  }
}
# ─────────────────────────────────────────────
# STATE 1 — FetchPage(P1), FetchPage(P2), FetchPage(P3)
# ─────────────────────────────────────────────
s1: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  op: {
    label: "FetchPage(P1) · FetchPage(P2) · FetchPage(P3)\nCache miss → load from disk · pin_count=1 each"
    shape: text
    style.font-size: 13
    style.bold: true
    style.fill: "#d1ecf1"
  }
  pool: {
    label: "Buffer Pool Frames"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.border-radius: 6
    f0: { label: "Frame 0\nPage P1\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f1: { label: "Frame 1\nPage P2\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f2: { label: "Frame 2\nPage P3\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f3: { label: "Frame 3\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
    f4: { label: "Frame 4\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
  }
  lru: {
    label: "LRU List (MRU → LRU)\n[ P3 → P2 → P1 ]\nAll pinned · none evictable"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.border-radius: 6
    shape: rectangle
  }
}
# ─────────────────────────────────────────────
# STATE 2 — UnpinPage(P1), UnpinPage(P2) · write to P3 (dirty)
# ─────────────────────────────────────────────
s2: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  op: {
    label: "UnpinPage(P1) · UnpinPage(P2) · Write(P3)\nP1, P2 become evictable · P3 marked dirty"
    shape: text
    style.font-size: 13
    style.bold: true
    style.fill: "#d4edda"
  }
  pool: {
    label: "Buffer Pool Frames"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.border-radius: 6
    f0: { label: "Frame 0\nPage P1\npin=0 · clean"; style.fill: "#d4edda"; style.stroke: "#28a745"; shape: rectangle }
    f1: { label: "Frame 1\nPage P2\npin=0 · clean"; style.fill: "#d4edda"; style.stroke: "#28a745"; shape: rectangle }
    f2: { label: "Frame 2\nPage P3\npin=1 · ✦ DIRTY"; style.fill: "#fff3cd"; style.stroke: "#e67e00"; shape: rectangle }
    f3: { label: "Frame 3\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
    f4: { label: "Frame 4\n[ FREE ]"; style.fill: "#e9ecef"; style.stroke: "#ced4da"; shape: rectangle }
  }
  lru: {
    label: "LRU List (MRU → LRU)\n[ P2 → P1 ]\nEvictable: P2(MRU), P1(LRU-tail)"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.border-radius: 6
    shape: rectangle
  }
}
# ─────────────────────────────────────────────
# STATE 3 — FetchPage(P4), FetchPage(P5) · pool nearly full
# ─────────────────────────────────────────────
s3: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  op: {
    label: "FetchPage(P4) · FetchPage(P5)\nUse free frames · LRU list grows"
    shape: text
    style.font-size: 13
    style.bold: true
    style.fill: "#d1ecf1"
  }
  pool: {
    label: "Buffer Pool Frames"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.border-radius: 6
    f0: { label: "Frame 0\nPage P1\npin=0 · clean"; style.fill: "#d4edda"; style.stroke: "#28a745"; shape: rectangle }
    f1: { label: "Frame 1\nPage P2\npin=0 · clean"; style.fill: "#d4edda"; style.stroke: "#28a745"; shape: rectangle }
    f2: { label: "Frame 2\nPage P3\npin=1 · ✦ DIRTY"; style.fill: "#fff3cd"; style.stroke: "#e67e00"; shape: rectangle }
    f3: { label: "Frame 3\nPage P4\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f4: { label: "Frame 4\nPage P5\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
  }
  lru: {
    label: "LRU List (MRU → LRU)\n[ P5 → P4 → P2 → P1 ]\nEvictable: P5,P4,P2 (unpinned after unpin)\nLRU-tail = P1 (oldest unpinned)"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.border-radius: 6
    shape: rectangle
  }
}
# ─────────────────────────────────────────────
# STATE 4 — FetchPage(P6) triggers EVICTION of P1 (LRU tail)
# ─────────────────────────────────────────────
s4: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  op: {
    label: "FetchPage(P6) — Pool FULL · No free frames\nEvict LRU tail (P1, clean) → load P6 into Frame 0"
    shape: text
    style.font-size: 13
    style.bold: true
    style.fill: "#f8d7da"
  }
  pool: {
    label: "Buffer Pool Frames"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.border-radius: 6
    f0: { label: "Frame 0\nPage P6  ← EVICTED P1\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f1: { label: "Frame 1\nPage P2\npin=0 · clean"; style.fill: "#d4edda"; style.stroke: "#28a745"; shape: rectangle }
    f2: { label: "Frame 2\nPage P3\npin=1 · ✦ DIRTY"; style.fill: "#fff3cd"; style.stroke: "#e67e00"; shape: rectangle }
    f3: { label: "Frame 3\nPage P4\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f4: { label: "Frame 4\nPage P5\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
  }
  lru: {
    label: "LRU List (MRU → LRU)\n[ P6 → P5 → P4 → P2 ]\nP1 evicted (LRU tail, clean · no write-back needed)"
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 6
    shape: rectangle
  }
  evict_note: {
    label: "P1 was clean → evict silently\n(no disk write needed)"
    shape: text
    style.font-size: 11
    style.italic: true
    style.fill: "#dc3545"
  }
}
# ─────────────────────────────────────────────
# STATE 5 — FetchPage(P7) triggers EVICTION of P2 (dirty · write-back!)
# ─────────────────────────────────────────────
s5: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  op: {
    label: "UnpinPage(P3) · FetchPage(P7) — Evict LRU tail (P2)\nP2 is DIRTY → write-back to disk before eviction"
    shape: text
    style.font-size: 13
    style.bold: true
    style.fill: "#f8d7da"
  }
  pool: {
    label: "Buffer Pool Frames"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.border-radius: 6
    f0: { label: "Frame 0\nPage P6\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f1: { label: "Frame 1\nPage P7  ← EVICTED P2\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f2: { label: "Frame 2\nPage P3\npin=0 · ✦ DIRTY"; style.fill: "#fff3cd"; style.stroke: "#e67e00"; shape: rectangle }
    f3: { label: "Frame 3\nPage P4\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
    f4: { label: "Frame 4\nPage P5\npin=1 · clean"; style.fill: "#cce5ff"; style.stroke: "#004085"; shape: rectangle }
  }
  lru: {
    label: "LRU List (MRU → LRU)\n[ P7 → P6 → P5 → P4 → P3 ]\nP2 evicted after write-back"
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 6
    shape: rectangle
  }
  writeback: {
    label: "✦ DIRTY PAGE WRITE-BACK\nP2 flushed to disk first\nthen frame reused for P7"
    shape: rectangle
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.border-radius: 8
    style.font-size: 12
    style.bold: true
  }
  disk: {
    label: "💾 Disk Storage\nP2 persisted"
    shape: cylinder
    style.fill: "#e2e3e5"
    style.stroke: "#6c757d"
  }
  writeback -> disk: {
    label: "flush dirty page"
    style.stroke: "#dc3545"
    style.stroke-width: 2
    style.stroke-dash: 4
  }
}
# ─────────────────────────────────────────────
# Transitions between states
# ─────────────────────────────────────────────
s0 -> s1: {
  label: "FetchPage(P1,P2,P3)\ncache miss × 3"
  style.stroke: "#0066cc"
  style.stroke-width: 2
}
s1 -> s2: {
  label: "UnpinPage(P1,P2)\nWrite(P3) → dirty"
  style.stroke: "#28a745"
  style.stroke-width: 2
}
s2 -> s3: {
  label: "FetchPage(P4,P5)\nfree frames used"
  style.stroke: "#0066cc"
  style.stroke-width: 2
}
s3 -> s4: {
  label: "FetchPage(P6)\npool full → EVICT P1"
  style.stroke: "#dc3545"
  style.stroke-width: 3
  style.bold: true
}
s4 -> s5: {
  label: "UnpinPage(P3) · FetchPage(P7)\nEVICT P2 → WRITE-BACK"
  style.stroke: "#dc3545"
  style.stroke-width: 3
  style.bold: true
}