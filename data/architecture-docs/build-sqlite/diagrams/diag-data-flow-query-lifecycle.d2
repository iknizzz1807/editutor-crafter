direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
sql_input: {
  label: "SQL Text (user input)"
  shape: document
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.font-color: "#0D47A1"
  style.bold: true
  width: 560
  query: |`c
    SELECT age FROM users WHERE id = 42;
  `|
}
layer_tokenizer: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tokenizer_box: {
    label: "Tokenizer (tokenizer.c)"
    shape: hexagon
    style.fill: "#7B1FA2"
    style.font-color: white
    style.bold: true
    width: 200
  }
  token_stream: {
    label: "Token Stream"
    shape: sql_table
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    t0: "TOKEN_SELECT     | 'SELECT' | line=1 col=1"
    t1: "TOKEN_IDENTIFIER | 'age'    | line=1 col=8"
    t2: "TOKEN_FROM       | 'FROM'   | line=1 col=12"
    t3: "TOKEN_IDENTIFIER | 'users'  | line=1 col=17"
    t4: "TOKEN_WHERE      | 'WHERE'  | line=1 col=23"
    t5: "TOKEN_IDENTIFIER | 'id'     | line=1 col=29"
    t6: "TOKEN_EQ         | '='      | line=1 col=32"
    t7: "TOKEN_INTEGER    | '42'     | line=1 col=34"
    t8: "TOKEN_SEMICOLON  | ';'      | line=1 col=36"
    t9: "TOKEN_EOF        | ''       | line=1 col=37"
  }
}
layer_parser: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parser_box: {
    label: "Parser (parser.c)"
    shape: hexagon
    style.fill: "#7B1FA2"
    style.font-color: white
    style.bold: true
    width: 200
  }
  ast_node: {
    label: "AST: SelectStatement (parser.h)"
    shape: sql_table
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    n0: "type         | NODE_SELECT"
    n1: "table_name   | char* 'users'"
    n2: "columns[0]   | NODE_IDENTIFIER 'age'"
    n3: "col_count    | 1"
    n4: "where_expr   | NODE_BINARY_EXPR"
    n5: "  .op        | TOKEN_EQ"
    n6: "  .left      | NODE_IDENTIFIER 'id'"
    n7: "  .right     | NODE_LITERAL_INT 42"
    n8: "order_by     | NULL"
    n9: "limit_expr   | NULL"
  }
}
layer_compiler: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  compiler_box: {
    label: "VDBE Compiler (vdbe.c)"
    shape: hexagon
    style.fill: "#E65100"
    style.font-color: white
    style.bold: true
    width: 200
  }
  bytecode: {
    label: "Bytecode Program (Program*)"
    shape: sql_table
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    b0: "addr=0 | OpenTable  | cur=0  p4='users'"
    b1: "addr=1 | Rewind     | cur=0  jump=8"
    b2: "addr=2 | Column     | cur=0  col=0  out=r1"
    b3: "addr=3 | Integer    | val=42 out=r2"
    b4: "addr=4 | Ne         | r1 r2  jump=7"
    b5: "addr=5 | Column     | cur=0  col=1  out=r3"
    b6: "addr=6 | ResultRow  | r3  count=1"
    b7: "addr=7 | Next       | cur=0  jump=2"
    b8: "addr=8 | Halt       | rc=SQLITE_OK"
  }
}
layer_vm: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vm_box: {
    label: "VDBE Execute (vdbe.c: vdbe_run)"
    shape: hexagon
    style.fill: "#B71C1C"
    style.font-color: white
    style.bold: true
    width: 200
  }
  register_file: {
    label: "Register File (regs[1024]) — at OP_ResultRow"
    shape: sql_table
    style.fill: "#FFEBEE"
    style.stroke: "#B71C1C"
    r0: "reg[1] | VAL_INTEGER | i=42   (col 'id'  read from row)"
    r1: "reg[2] | VAL_INTEGER | i=42   (literal constant)"
    r2: "reg[3] | VAL_INTEGER | i=25   (col 'age' — MATCH)"
    r3: "pc     | int         | 6      (halted at ResultRow)"
    r4: "cursor[0].leaf_page  | 47"
    r5: "cursor[0].slot       | 3"
  }
}
layer_cursor: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cursor_box: {
    label: "BTreeCursor (btree.c)"
    shape: hexagon
    style.fill: "#1B5E20"
    style.font-color: white
    style.bold: true
    width: 200
  }
  cursor_state: {
    label: "BTreeCursor (btree.h)"
    shape: sql_table
    style.fill: "#E8F5E9"
    style.stroke: "#1B5E20"
    c0: "root_page_id  | PageId | 3          (from sqlite_master)"
    c1: "leaf_page_id  | PageId | 47         (after B-tree descent)"
    c2: "slot          | int    | 3          (cell index in leaf)"
    c3: "at_end        | int    | 0"
    c4: "write_mode    | int    | 0          (read-only)"
    c5: "descent_path  | 3 -> 18 -> 47       (root->internal->leaf)"
  }
}
layer_btree: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  btree_box: {
    label: "B-tree Descent (btree.c)"
    shape: hexagon
    style.fill: "#1B5E20"
    style.font-color: white
    style.bold: true
    width: 200
  }
  page_header: {
    label: "Leaf Page Header (page 47)"
    shape: sql_table
    style.fill: "#E8F5E9"
    style.stroke: "#1B5E20"
    p0: "byte[0]    | uint8_t  | 0x0D       (PAGE_TYPE_TABLE_LEAF)"
    p1: "byte[1-2]  | uint16_t | 0x0000     (first_freeblock=0)"
    p2: "byte[3-4]  | uint16_t | 0x0027     (cell_count=39)"
    p3: "byte[5-6]  | uint16_t | 0x0140     (cell_content_area=320)"
    p4: "byte[7]    | uint8_t  | 0x00       (fragmented_bytes=0)"
    p5: "byte[8-11] | uint32_t | 0x00000000 (right_child_page=0)"
    p6: "ptr[3]     | uint16_t | 0x0BD0     (cell[3] at offset 3024)"
  }
}
layer_buffer_pool: {
  direction: down
  style.stroke: "#0D47A1"
  style.fill: "#E8EAF6"
  style.border-radius: 8
  bp_label: {
    label: "Buffer Pool (buffer_pool.c)"
    shape: text
    style.font-color: "#0D47A1"
    style.bold: true
    style.font-size: 15
  }
  bp_box: {
    label: "buffer_pool_fetch(page_id=47)"
    shape: hexagon
    style.fill: "#0D47A1"
    style.font-color: white
    style.bold: true
    width: 220
  }
  cache_hit: {
    label: "PATH A — CACHE HIT (page 47 warm)"
    shape: sql_table
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    h0: "frames[12].page_id   | 47"
    h1: "frames[12].pin_count | 0 -> 1  (pinned)"
    h2: "frames[12].is_dirty  | false"
    h3: "LRU move to head     | O(1)"
    h4: "return               | frames[12].data  (~10 ns)"
  }
  cache_miss: {
    label: "PATH B — CACHE MISS (page 47 cold)"
    shape: sql_table
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    m0: "page_table lookup | NOT FOUND"
    m1: "evict_lru()       | frame[7] evicted (unpinned LRU)"
    m2: "pread(fd, buf,    | 4096, offset=47*4096=192512)"
    m3: "bytes_read        | 4096"
    m4: "pin_count         | 0 -> 1"
    m5: "return            | frame[7].data    (~100 µs NVMe)"
  }
  bp_box -> cache_hit: "HIT" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  bp_box -> cache_miss: "MISS" {
    style.stroke: "#607D8B"
    style.stroke-dash: 4
  }
}
layer_disk: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  disk_box: {
    label: "OS pread() / Disk"
    shape: cylinder
    style.fill: "#37474F"
    style.font-color: white
    style.bold: true
    width: 200
  }
  raw_bytes: {
    label: "Raw Page Bytes (file offset 0x2F010, page 47)"
    shape: sql_table
    style.fill: "#ECEFF1"
    style.stroke: "#37474F"
    d0: "0x0000 | 0D 00 00 27 01 40 00 00 | page header (8 bytes)"
    d1: "0x0008 | 00 00 00 00             | right_child=0"
    d2: "0x000C | ... 0B D0 ...           | cell ptr array (39x2 bytes)"
    d3: "0x0BD0 | 27                      | payload_size varint = 39"
    d4: "0x0BD1 | 2A                      | rowid varint = 42"
    d5: "0x0BD2 | 09                      | hdr_size varint = 9"
    d6: "0x0BD3 | 01                      | serial_type[0]=1 (1-byte int)"
    d7: "0x0BD4 | 06                      | serial_type[1]=6 (8-byte int)"
    d8: "0x0BD5 | 2A                      | col0(id)  = 0x2A = 42"
    d9: "0x0BD6 | 00 00 00 00 00 00 00 19 | col1(age) = 0x19 = 25"
  }
}
layer_decode: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  decode_box: {
    label: "Record Decoder (btree.c)"
    shape: hexagon
    style.fill: "#4A148C"
    style.font-color: white
    style.bold: true
    width: 200
  }
  record_decode: {
    label: "record_decode_column(payload, col_idx=1)"
    shape: sql_table
    style.fill: "#EDE7F6"
    style.stroke: "#4A148C"
    r0: "payload_ptr     | page_data + 0x0BD0 + varint(size) + varint(rowid)"
    r1: "header_size     | varint_decode -> 9  (header occupies 9 bytes)"
    r2: "serial_type[0]  | varint_decode -> 1  (1-byte signed int)"
    r3: "serial_type[1]  | varint_decode -> 6  (8-byte signed int)"
    r4: "skip col0       | advance 1 byte      (size of serial_type=1)"
    r5: "data_offset_col1| payload_ptr + 9 + 1 = payload_ptr + 10"
    r6: "read 8 BE bytes | 00 00 00 00 00 00 00 19"
    r7: "int64 result    | 0x19 = 25"
    r8: "output Value    | { .type=VAL_INTEGER, .i=25 }"
  }
}
result_output: {
  label: "Result Returned to Caller"
  shape: document
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.font-color: "#1B5E20"
  style.bold: true
  width: 560
  row: |`c
    /* OP_ResultRow fires: reg[3] = VAL_INTEGER(25) */
    callback(result_row, ncols=1, values=["25"], names=["age"]);
    /* 1 row matched. Pages read: 3 (root=3, internal=18, leaf=47) */
    /* Subsequent identical query: 0 disk reads (buffer pool warm) */
  `|
}
sql_input -> layer_tokenizer.tokenizer_box: "char* sql" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.animated: true
}
layer_tokenizer.tokenizer_box -> layer_tokenizer.token_stream: "lexer_next_token()" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 1
}
layer_tokenizer.token_stream -> layer_parser.parser_box: "Token[]" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  style.animated: true
}
layer_parser.parser_box -> layer_parser.ast_node: "parse_select()" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 1
}
layer_parser.ast_node -> layer_compiler.compiler_box: "AstNode*" {
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.animated: true
}
layer_compiler.compiler_box -> layer_compiler.bytecode: "compile(ast)" {
  style.stroke: "#E65100"
  style.stroke-width: 1
}
layer_compiler.bytecode -> layer_vm.vm_box: "Program*" {
  style.stroke: "#B71C1C"
  style.stroke-width: 2
  style.animated: true
}
layer_vm.vm_box -> layer_vm.register_file: "vdbe_execute(prog)" {
  style.stroke: "#B71C1C"
  style.stroke-width: 1
}
layer_vm.register_file -> layer_cursor.cursor_box: "OP_OpenTable" {
  style.stroke: "#1B5E20"
  style.stroke-width: 2
  style.animated: true
}
layer_cursor.cursor_box -> layer_cursor.cursor_state: "btree_cursor_open(root=3)" {
  style.stroke: "#1B5E20"
  style.stroke-width: 1
}
layer_cursor.cursor_state -> layer_btree.btree_box: "btree_search(key=42)" {
  style.stroke: "#1B5E20"
  style.stroke-width: 2
  style.animated: true
}
layer_btree.btree_box -> layer_btree.page_header: "land on page 47 slot 3" {
  style.stroke: "#1B5E20"
  style.stroke-width: 1
}
layer_btree.page_header -> layer_buffer_pool.bp_box: "buffer_pool_fetch(47)" {
  style.stroke: "#0D47A1"
  style.stroke-width: 2
  style.animated: true
}
layer_buffer_pool.cache_miss -> layer_disk.disk_box: "pread(fd, buf, 4096, 192512)" {
  style.stroke: "#37474F"
  style.stroke-width: 2
  style.animated: true
}
layer_disk.disk_box -> layer_disk.raw_bytes: "4096 bytes" {
  style.stroke: "#37474F"
  style.stroke-width: 1
}
layer_disk.raw_bytes -> layer_decode.decode_box: "uint8_t* page_data" {
  style.stroke: "#4A148C"
  style.stroke-width: 2
  style.animated: true
}
layer_buffer_pool.cache_hit -> layer_decode.decode_box: "uint8_t* frame_ptr" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.animated: true
}
layer_decode.decode_box -> layer_decode.record_decode: "record_decode_column(1)" {
  style.stroke: "#4A148C"
  style.stroke-width: 1
}
layer_decode.record_decode -> result_output: "Value { VAL_INTEGER, i=25 }" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.animated: true
}
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 4
  width: 280
  l1: "Purple  = tokenizer / parser layer" {
    shape: text
    style.font-color: "#7B1FA2"
    style.bold: true
  }
  l2: "Orange  = VDBE compiler" {
    shape: text
    style.font-color: "#E65100"
    style.bold: true
  }
  l3: "Red     = VM execution / hot path" {
    shape: text
    style.font-color: "#B71C1C"
    style.bold: true
  }
  l4: "Green   = B-tree / cursor / result" {
    shape: text
    style.font-color: "#1B5E20"
    style.bold: true
  }
  l5: "Blue    = buffer pool / cache" {
    shape: text
    style.font-color: "#0D47A1"
    style.bold: true
  }
  l6: "Gray    = OS / disk I/O" {
    shape: text
    style.font-color: "#37474F"
    style.bold: true
  }
}