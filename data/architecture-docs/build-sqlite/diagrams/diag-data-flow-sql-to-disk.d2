direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  layer: {
    style: {
      border-radius: 8
      font-size: 16
    }
  }
  transform: {
    style: {
      fill: "#E8F4FD"
      border-radius: 6
      font-size: 14
    }
  }
  data: {
    style: {
      fill: "#FFF3E0"
      border-radius: 4
      font-size: 13
      italic: true
    }
  }
  hot: {
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      font-size: 14
    }
  }
  safe: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      font-size: 14
    }
  }
}
# ============================================================
# INPUT
# ============================================================
sql_input: {
  label: "Raw SQL Input"
  class: layer
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  raw: |'md
    INSERT INTO users VALUES (42, 'Alice', 30);
  '|
  raw.style.fill: "#EDE7F6"
  raw.width: 420
}
# ============================================================
# TOKENIZER
# ============================================================
tokenizer: {
  label: "1. Tokenizer (lexer.c)"
  class: layer
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  fsm: {
    label: "Finite State Machine"
    class: transform
    desc: |md
      - Dispatch on first char
      - peek() / advance() per char
      - Case-insensitive keyword check
    |
  }
  tokens: {
    shape: sql_table
    label: "Token Stream"
    t0: "KW   | INSERT  | L1:C1"
    t1: "KW   | INTO    | L1:C8"
    t2: "IDENT| users   | L1:C13"
    t3: "KW   | VALUES  | L1:C19"
    t4: "LPAR | (       | L1:C26"
    t5: "INT  | 42      | L1:C27"
    t6: "COMMA| ,       | L1:C29"
    t7: "STR  | 'Alice' | L1:C31"
    t8: "COMMA| ,       | L1:C39"
    t9: "INT  | 30      | L1:C41"
    t10: "RPAR | )       | L1:C43"
    t11: "SEMI | ;       | L1:C44"
    t12: "EOF  |         | L1:C45"
  }
  fsm -> tokens: "emit Token[]"
}
# ============================================================
# PARSER
# ============================================================
parser: {
  label: "2. Parser — Recursive Descent (parser.c)"
  class: layer
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  dispatch: {
    label: "Dispatch"
    class: transform
    desc: |md
      - peek() token type
      - parse_insert() called
      - expect(KW "INTO"), expect(IDENT)
      - parse_expression() per value
    |
  }
  ast: {
    label: "AST: NODE_INSERT"
    class: transform
    style.fill: "#C8E6C9"
    fields: {
      shape: sql_table
      label: "Insert Node Fields"
      f0: "table_name  | 'users' (heap-alloc)"
      f1: "column_names| NULL (omitted)"
      f2: "row_count   | 1"
      f3: "values_per_row | 3"
    }
    vals: {
      label: "Value Expressions"
      style.fill: "#DCEDC8"
      v0: "NODE_LITERAL(INT, '42')"
      v1: "NODE_LITERAL(STR, 'Alice')"
      v2: "NODE_LITERAL(INT, '30')"
    }
  }
  dispatch -> ast: "build tree"
}
# ============================================================
# COMPILER
# ============================================================
compiler: {
  label: "3. Bytecode Compiler (compiler.c)"
  class: layer
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  walk: {
    label: "AST Walk"
    class: transform
    desc: |md
      - Lookup 'users' in catalog
      - root_page=5, 3 columns
      - alloc_register() for each value
      - alloc_cursor() for write
    |
  }
  program: {
    shape: sql_table
    label: "Bytecode Program (VdbeOp[])"
    i0: "0 | Init        | 0  | 1  | 0  | Start"
    i1: "1 | OpenWrite   | 0  | 5  | 3  | users (root=5)"
    i2: "2 | NewRowid    | 0  | 1  | 0  | auto-inc -> r1"
    i3: "3 | Integer     | 42 | 2  | 0  | 42 -> r2"
    i4: "4 | String8     | 0  | 3  | 0  | 'Alice' -> r3"
    i5: "5 | Integer     | 30 | 4  | 0  | 30 -> r4"
    i6: "6 | MakeRecord  | 2  | 3  | 5  | r2..r4 -> record r5"
    i7: "7 | Insert      | 0  | 5  | 1  | cursor 0, rec r5, key r1"
    i8: "8 | Close       | 0  | 0  | 0  | close cursor"
    i9: "9 | Halt        | 0  | 0  | 0  | done"
  }
  walk -> program: "emit()"
}
# ============================================================
# VM
# ============================================================
vm: {
  label: "4. Virtual Machine — VDBE (vm.c)"
  class: layer
  style.fill: "#FCE4EC"
  style.stroke: "#C62828"
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    loop: {
      label: "Fetch-Decode-Execute Loop"
      class: transform
      desc: |md
        while (!halted):
          op = ops[pc]
          switch (op.opcode):
            case OP_INSERT: ...
          pc++
      |
    }
    regs: {
      shape: sql_table
      label: "Register File"
      r1: "r1 | INT  | 42  (rowid)"
      r2: "r2 | INT  | 42  (col 0)"
      r3: "r3 | STR  | 'Alice' (col 1)"
      r4: "r4 | INT  | 30  (col 2)"
      r5: "r5 | BLOB | [serialized record]"
    }
  }
  record_detail: {
    label: "MakeRecord: Serialization (record.c)"
    class: transform
    style.fill: "#FFCDD2"
    format: {
      shape: sql_table
      label: "Record Binary Format"
      h0: "0x00 | varint | 06     | header_size = 6 bytes"
      h1: "0x01 | varint | 01     | serial_type: 8-bit int (col 0)"
      h2: "0x02 | varint | 17     | serial_type: text len=2 -> (2*2+13=17)"
      h3: "0x03 | varint | 01     | serial_type: 8-bit int (col 2)"
      v0: "0x04 | 1 byte | 0x2A   | value: 42"
      v1: "0x05 | 5 bytes| Alice  | value: 'Alice'"
      v2: "0x0A | 1 byte | 0x1E   | value: 30"
      sz: "Total: 11 bytes"
    }
  }
  row1.loop -> record_detail: "OP_MakeRecord"
}
# ============================================================
# B-TREE
# ============================================================
btree: {
  label: "5. B-Tree Storage Engine (btree.c)"
  class: layer
  style.fill: "#E0F2F1"
  style.stroke: "#00695C"
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    search: {
      label: "btree_insert()"
      class: transform
      desc: |md
        1. Search root -> internal -> leaf
           (compare rowid at each level)
        2. Find correct leaf page
        3. Check free space
        4. Write cell or split node
      |
    }
    cell: {
      shape: sql_table
      label: "Table Leaf Cell"
      c0: "varint | 0B        | payload_size = 11"
      c1: "varint | 2A        | rowid = 42"
      c2: "bytes  | [record]  | 11 bytes of record data"
      sz: "Total cell: ~14 bytes"
    }
  }
  page: {
    label: "Slotted Page (leaf, page_id=7)"
    style.fill: "#B2DFDB"
    style.stroke: "#00695C"
    layout: {
      shape: sql_table
      label: "Page Layout (4096 bytes)"
      h: "0x00-0x07 | Page Header    | type=0x0D, cells=47, content=1842"
      p: "0x08-0x69 | Cell Ptr Array | [1842][1870][1899]...[4082] sorted by rowid"
      f: "0x6A-0x731| FREE SPACE     | ~1770 bytes available"
      c: "0x732-0xFFF| Cell Content  | cells packed bottom-up"
    }
  }
  row1.search -> page: "page_insert_cell()"
  split_note: {
    label: "If page full: split leaf, promote median key to parent, possibly split parent recursively"
    style.fill: "#FFECB3"
    style.stroke: "#F57F17"
    style.font-size: 12
    style.italic: true
  }
  page -> split_note: {style.stroke-dash: 4}
}
# ============================================================
# BUFFER POOL
# ============================================================
buffer_pool: {
  label: "6. Buffer Pool Manager (buffer_pool.c)"
  class: layer
  style.fill: "#EDE7F6"
  style.stroke: "#4527A0"
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    fetch: {
      label: "fetch_page(pool, 7)"
      class: transform
      desc: |md
        1. Hash page_id=7 -> page_table
        2. HIT: return frame ptr, pin++
        3. MISS: evict LRU (if dirty,
           journal + write-back first),
           pread() from disk, pin=1
      |
    }
    frame: {
      shape: sql_table
      label: "Frame Metadata"
      f0: "page_id    | 7"
      f1: "pin_count  | 1 (held by B-tree)"
      f2: "is_dirty   | true (modified)"
      f3: "lru_prev   | frame 12"
      f4: "lru_next   | frame 3"
      f5: "data ptr   | -> 4096-byte buffer"
    }
  }
  unpin: {
    label: "unpin_page(pool, 7, dirty=true)"
    class: transform
    style.fill: "#D1C4E9"
    desc: |md
      pin_count-- (now 0)
      is_dirty = true
      Page eligible for LRU eviction
      but stays cached for future hits
    |
  }
  row1.fetch -> row1.frame: "return uint8_t*"
  row1.frame -> unpin: "B-tree done"
}
# ============================================================
# DISK I/O + TRANSACTION
# ============================================================
disk: {
  label: "7. Disk I/O + Transaction Protocol"
  class: layer
  style.fill: "#EFEBE9"
  style.stroke: "#4E342E"
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    journal: {
      label: "Rollback Journal"
      class: hot
      desc: |md
        BEFORE db write:
        1. pread() original page 7
        2. write() to .db-journal
        3. fsync(.db-journal)
      |
    }
    db_write: {
      label: "Database Write"
      class: safe
      desc: |md
        AFTER journal fsync:
        4. pwrite(fd, page_data,
           4096, 7*4096)
        5. fsync(db_fd)
      |
    }
    commit: {
      label: "Commit Point"
      class: safe
      style.fill: "#C8E6C9"
      style.stroke: "#1B5E20"
      style.bold: true
      desc: |md
        6. unlink(.db-journal)
        7. fsync(directory)
        Transaction is permanent
      |
    }
  }
  row1.journal -> row1.db_write: "barrier"
  row1.db_write -> row1.commit: "barrier"
  ordering: {
    shape: sql_table
    label: "Write Ordering Invariant"
    r0: "journal write -> journal fsync -> db write -> db fsync -> journal delete"
    r1: "Violating this order = unrecoverable corruption on crash"
  }
}
# ============================================================
# PHYSICAL STORAGE
# ============================================================
storage: {
  label: "8. Physical Storage"
  class: layer
  style.fill: "#F5F5F5"
  style.stroke: "#616161"
  file: {
    shape: sql_table
    label: "Database File: users.db"
    p0: "Page 0 | File header + sqlite_master root"
    p1: "Page 1 | sqlite_master leaf (schema rows)"
    p5: "Page 5 | users table root (internal node)"
    p6: "Page 6 | users leaf page (rowids 1-40)"
    p7: "Page 7 | users leaf page (rowids 41-80) <- NEW CELL HERE"
    p8: "Page 8 | users leaf page (rowids 81-120)"
    p9: "Page 9 | idx_users_age root"
    sz: "Total: 40960 bytes (10 pages x 4096)"
  }
  hw: {
    label: "Hardware Path"
    style.fill: "#EEEEEE"
    path: {
      shape: sql_table
      label: "pwrite() -> kernel -> device"
      s0: "User space  | pwrite(fd, buf, 4096, 28672) | ~50ns"
      s1: "Syscall     | trap to kernel mode           | ~200ns"
      s2: "Page cache  | copy to kernel buffer         | ~400ns"
      s3: "Block layer | submit bio request            | ~1us"
      s4: "NVMe driver | DMA to controller             | ~5us"
      s5: "SSD FTL     | map LBA -> NAND page          | ~20us"
      s6: "NAND write  | program flash cells           | ~50-200us"
      s7: "fsync       | flush volatile cache          | ~100us"
      total: "Total latency per page: ~100-400us"
    }
  }
}
# ============================================================
# CONNECTIONS (layer to layer)
# ============================================================
sql_input -> tokenizer: "const char* sql" {style.stroke: "#7B1FA2"}
tokenizer -> parser: "Token tokens[12]" {style.stroke: "#1565C0"}
parser -> compiler: "AstNode* (NODE_INSERT)" {style.stroke: "#2E7D32"}
compiler -> vm: "Program (10 VdbeOp)" {style.stroke: "#E65100"}
vm -> btree: "btree_cursor_insert(key=42, record)" {style.stroke: "#C62828"}
btree -> buffer_pool: "fetch_page(pool, 7) / unpin_page(7, dirty)" {style.stroke: "#00695C"}
buffer_pool -> disk: "evict or flush_all()" {style.stroke: "#4527A0"}
disk -> storage: "pwrite() + fsync()" {style.stroke: "#4E342E"}