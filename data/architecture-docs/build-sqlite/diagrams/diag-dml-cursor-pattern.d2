direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row_struct: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cursor_struct: {
    shape: sql_table
    label: "struct BTreeCursor (btree.h)"
    f0: "0x00 | BTree*   | bt          // owning B-tree"
    f1: "0x08 | int      | write_mode  // 0=read 1=write"
    f2: "0x0C | PageId   | leaf_page_id"
    f3: "0x10 | int      | slot        // cell index in leaf"
    f4: "0x14 | int      | at_end      // 1 if exhausted"
    f5: "0x18 | uint8_t* | current_page // pinned page ptr"
    sz: "Total: 32 bytes"
    style.fill: "#dbeafe"
  }
  parent_stack: {
    shape: sql_table
    label: "PathEntry[] stack (btree.c)"
    s0: "slot 0 | PageId | root page"
    s1: "slot 1 | PageId | internal page"
    s2: "slot 2 | PageId | leaf page   ← top"
    s3: "depth  | int    | stack depth (0..31)"
    note: "Max depth: 32 (covers 2^(32*log2_b) rows)"
    style.fill: "#fef9c3"
  }
}
row_ops: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_first: {
    label: "btree_cursor_rewind (btree.c)"
    width: 320
    code: |`c
      PageId cur = bt->root_page_id;
      while (page_type(cur) != LEAF) {
        cur = first_child(cur); // leftmost
      }
      cursor->leaf_page_id = cur;
      cursor->slot = 0;
    `|
    style.fill: "#dcfce7"
    style.border-radius: 6
  }
  op_next: {
    label: "btree_cursor_next (btree.c)"
    width: 360
    code: |`c
      cursor->slot++;
      if (cursor->slot < cell_count(leaf)) {
        return 1; // same leaf
      }
      // ascend stack → descend next subtree
      PageId sib = right_sibling(leaf);
      if (sib == 0) { cursor->at_end=1; return 0; }
      cursor->leaf_page_id = sib;
      cursor->slot = 0; return 1;
    `|
    style.fill: "#dcfce7"
    style.border-radius: 6
  }
  op_seek: {
    label: "btree_search (btree.c)"
    width: 360
    code: |`c
      PageId cur = bt->root_page_id;
      while (page_type(cur) != LEAF) {
        int child = bsearch_keys(cur, rowid);
        stack_push(path, cur);
        cur = child_ptr(cur, child);
      }
      int slot = bsearch_leaf(cur, rowid);
      // O(log N) page reads
    `|
    style.fill: "#dcfce7"
    style.border-radius: 6
  }
}
row_btree: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tree_vis: {
    direction: down
    label: "B-tree Traversal (3-level example)"
    style.fill: "#f8fafc"
    style.border-radius: 8
    root_page: {
      shape: sql_table
      label: "Page 1 — TABLE_INTERNAL (root)"
      k0: "cell[0] | left_child=2 | key=500"
      k1: "cell[1] | left_child=3 | key=1000"
      rc: "right_child = 4"
      style.fill: "#e0e7ff"
    }
    row_internal: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      int_left: {
        shape: sql_table
        label: "Page 2 — TABLE_INTERNAL"
        k0: "cell[0] | left_child=5 | key=250"
        rc: "right_child = 6"
        style.fill: "#e0e7ff"
      }
      int_mid: {
        shape: sql_table
        label: "Page 3 — TABLE_INTERNAL"
        k0: "cell[0] | left_child=7 | key=750"
        rc: "right_child = 8"
        style.fill: "#e0e7ff"
      }
      int_right: {
        shape: sql_table
        label: "Page 4 — TABLE_INTERNAL"
        k0: "cell[0] | left_child=9 | key=1500"
        rc: "right_child = 10"
        style.fill: "#e0e7ff"
      }
    }
    row_leaves: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      leaf_a: {
        shape: sql_table
        label: "Page 5 — TABLE_LEAF ← cursor here"
        c0: "cell[0] | rowid=1  | record_data"
        c1: "cell[1] | rowid=42 | record_data"
        c2: "slot ptr ↑ cursor->slot = 1"
        style.fill: "#bbf7d0"
        style.stroke: "#16a34a"
      }
      leaf_b: {
        shape: sql_table
        label: "Page 6 — TABLE_LEAF"
        c0: "cell[0] | rowid=251 | record_data"
        c1: "cell[1] | rowid=499 | record_data"
        style.fill: "#bbf7d0"
      }
      leaf_c: {
        shape: sql_table
        label: "Page 7 — TABLE_LEAF"
        c0: "cell[0] | rowid=501 | record_data"
        style.fill: "#bbf7d0"
      }
    }
    root_page -> row_internal.int_left: "left child"
    root_page -> row_internal.int_mid: "mid child"
    root_page -> row_internal.int_right: "right child"
    row_internal.int_left -> row_leaves.leaf_a: "left child"
    row_internal.int_left -> row_leaves.leaf_b: "right child"
    row_internal.int_mid -> row_leaves.leaf_c: "left child"
  }
  vdbe_ops: {
    shape: sql_table
    label: "VDBE Opcode → Cursor API"
    v0: "OP_REWIND  | btree_cursor_rewind(cur)"
    v1: "OP_NEXT    | btree_cursor_next(cur)"
    v2: "OP_COLUMN  | btree_cursor_column(cur, col, val)"
    v3: "OP_ROWID   | btree_cursor_rowid(cur)"
    v4: "SeekRowid  | btree_search(bt, rowid, slot)"
    v5: "OP_CLOSE   | btree_cursor_close(cur)"
    style.fill: "#fae8ff"
  }
}
row_struct.cursor_struct -> row_struct.parent_stack: "path stack"
row_struct.cursor_struct -> row_ops.op_first: "rewind()"
row_struct.cursor_struct -> row_ops.op_next: "next()"
row_struct.cursor_struct -> row_ops.op_seek: "seek(rowid)"
row_ops.op_first -> row_btree.tree_vis.root_page: "descend leftmost"
row_ops.op_seek -> row_btree.tree_vis.root_page: "bsearch root→leaf"
row_ops.op_next -> row_btree.tree_vis.row_leaves.leaf_a: "slot++ or sibling"
row_btree.tree_vis -> row_btree.vdbe_ops: "cursor API"