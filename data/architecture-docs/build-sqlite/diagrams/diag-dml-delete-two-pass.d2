direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  danger_title: "❌  SINGLE-PASS DELETE  (Iterator Invalidation)" {
    style.fill: "#5c1a1a"
    style.font-color: "#ffffff"
    style.border-radius: 6
    style.bold: true
    style.font-size: 14
  }
  safe_title: "✅  TWO-PASS DELETE  (Safe)" {
    style.fill: "#1a3d1a"
    style.font-color: "#ffffff"
    style.border-radius: 6
    style.bold: true
    style.font-size: 14
  }
}
main_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  danger_track: "" {
    direction: down
    style.fill: "#2a0a0a"
    style.stroke: "#cc3333"
    style.border-radius: 8
    d_s1: "State 1 — Cursor Active on Leaf" {
      direction: right
      style.fill: "#1a0505"
      style.stroke: "#884444"
      style.border-radius: 6
      d_leaf1: "Leaf Page 7" {
        shape: sql_table
        label: "Leaf Page 7  (page.h)"
        cell_count: "cell_count | 3  (uint16)"
        s0: "slot[0] → offset | rowid=10 | Alice"
        s1: "slot[1] → offset | rowid=20 | Bob  ← cursor HERE"
        s2: "slot[2] → offset | rowid=30 | Carol"
        pad: "free_space | 1842 bytes remaining"
      }
      d_cur1: "BTreeCursor" {
        shape: class
        label: "BTreeCursor  (btree.h)"
        leaf_page_id: "uint32_t  = 7"
        slot: "int       = 1  (points Bob)"
        at_end: "int       = 0"
        write_mode: "int       = 1"
      }
    }
    d_arrow1: "DELETE WHERE rowid=20 fires mid-loop" {
      shape: diamond
      style.fill: "#cc3333"
      style.font-color: "#ffffff"
      style.bold: true
    }
    d_s2: "State 2 — Cell Pointer Array Shifts" {
      direction: right
      style.fill: "#1a0505"
      style.stroke: "#884444"
      style.border-radius: 6
      d_leaf2: "Leaf Page 7 shifted" {
        shape: sql_table
        label: "Leaf Page 7  AFTER page_delete_cell(slot=1)"
        cell_count: "cell_count | 2  (was 3)"
        s0: "slot[0] → offset | rowid=10 | Alice"
        s1: "slot[1] → offset | rowid=30 | Carol  ← SHIFTED LEFT"
        orphan: "slot[2] → GONE  (memmove erased pointer)"
        frag: "fragmented_bytes | += sizeof(Bob cell)"
      }
      d_cur2: "BTreeCursor STALE" {
        shape: class
        label: "BTreeCursor  (STALE)"
        leaf_page_id: "uint32_t  = 7  (unchanged)"
        slot: "int       = 1  (NOT updated!)"
        at_end: "int       = 0  (NOT updated!)"
        style.fill: "#cc0000"
        style.font-color: "#ffffff"
      }
    }
    d_arrow2: "btree_cursor_next() called" {
      shape: diamond
      style.fill: "#884400"
      style.font-color: "#ffffff"
    }
    d_s3: "State 3 — Undefined Behaviour" {
      direction: down
      style.fill: "#2a0a0a"
      style.stroke: "#ff4444"
      style.border-radius: 6
      d_bug: "Iterator Invalidation Bug" {
        shape: class
        label: "Iterator Invalidation Bug  (btree.c)"
        err1: "slot=1 now reads rowid=30 (Carol) — skipped!"
        err2: "rowid=20 (Bob) was NEVER yielded to caller"
        err3: "If WHERE matched Carol too: slot advances past cell_count=2 → UB"
        err4: "Symptom: rows silently skipped or SIGSEGV"
        style.fill: "#880000"
        style.font-color: "#ffcccc"
      }
      d_rule: "Root Cause" {
        shape: class
        label: "Root Cause"
        r1: "memmove shifts ptr_array[slot..N-1] left by 2 bytes"
        r2: "cursor.slot not adjusted after shift"
        r3: "Same class as Java ConcurrentModificationException"
        r4: "C++ iterator invalidation on std::vector::erase()"
        style.fill: "#440000"
        style.font-color: "#ffaaaa"
      }
    }
  }
  safe_track: "" {
    direction: down
    style.fill: "#0a1a0a"
    style.stroke: "#33cc33"
    style.border-radius: 8
    s_s1: "State 1 — Pass 1 Begins  (read-only cursor)" {
      direction: right
      style.fill: "#051005"
      style.stroke: "#448844"
      style.border-radius: 6
      s_leaf1: "Leaf Page 7 unmodified" {
        shape: sql_table
        label: "Leaf Page 7  (page.h)"
        cell_count: "cell_count | 3"
        s0: "slot[0] | rowid=10 | Alice"
        s1: "slot[1] | rowid=20 | Bob   ← matches WHERE"
        s2: "slot[2] | rowid=30 | Carol ← matches WHERE"
        pad: "free_space | 1842 bytes"
      }
      s_list1: "rowids_to_delete empty" {
        shape: sql_table
        label: "rowids_to_delete[]  (vdbe.c)"
        cap: "capacity | 16  (int64_t[])"
        cnt: "count    | 0"
        r0: "[0]      | —  (empty)"
      }
    }
    s_arrow1: "btree_cursor_rewind() → scan all rows" {
      shape: step
      style.fill: "#1a4d1a"
      style.font-color: "#ccffcc"
    }
    s_s2: "State 2 — Pass 1 Complete  (rowids collected)" {
      direction: right
      style.fill: "#051005"
      style.stroke: "#448844"
      style.border-radius: 6
      s_leaf2: "Leaf Page 7 untouched" {
        shape: sql_table
        label: "Leaf Page 7  (untouched during scan)"
        cell_count: "cell_count | 3  (unchanged)"
        s0: "slot[0] | rowid=10 | Alice"
        s1: "slot[1] | rowid=20 | Bob"
        s2: "slot[2] | rowid=30 | Carol"
      }
      s_list2: "rowids_to_delete populated" {
        shape: sql_table
        label: "rowids_to_delete[]  POPULATED"
        cap: "capacity | 16"
        cnt: "count    | 2"
        r0: "[0]      | 20  (Bob)"
        r1: "[1]      | 30  (Carol)"
      }
      s_cur_closed: "scan_cursor closed" {
        shape: class
        label: "scan_cursor  CLOSED"
        leaf_page_id: "uint32_t = INVALID"
        slot: "int      = 0"
        at_end: "int      = 1"
        style.fill: "#224422"
        style.font-color: "#aaffaa"
      }
    }
    s_arrow2: "btree_cursor_close() then loop rowids_to_delete[]" {
      shape: step
      style.fill: "#1a4d1a"
      style.font-color: "#ccffcc"
    }
    s_s3: "State 3 — Pass 2  (delete by rowid, no cursor held)" {
      direction: right
      style.fill: "#051005"
      style.stroke: "#448844"
      style.border-radius: 6
      s_leaf3: "btree_delete_by_rowid calls" {
        shape: sql_table
        label: "btree_delete_by_rowid()  (btree.c)"
        step1: "call(bt, 20) → btree_search → leaf=7 slot=1 → page_delete_cell"
        step2: "call(bt, 30) → btree_search → leaf=7 slot=1 → page_delete_cell"
        note: "Each call opens fresh internal cursor — no stale state"
        note2: "OP_FLUSH_DELETES opcode drives this loop  (vdbe.c)"
      }
      s_safe_note: "Why This Is Safe" {
        shape: class
        label: "Why This Is Safe"
        r1: "No cursor held across any delete call"
        r2: "btree_delete_by_rowid() does its own tree descent"
        r3: "rowids[] is plain int64_t array — no pointer into B-tree"
        r4: "OP_DELETE_ROW appends rowid; OP_FLUSH_DELETES executes"
        style.fill: "#004400"
        style.font-color: "#aaffaa"
      }
    }
    s_s4: "State 4 — Correct Final State" {
      direction: down
      style.fill: "#051005"
      style.stroke: "#44aa44"
      style.border-radius: 6
      s_leaf4: "Leaf Page 7 final" {
        shape: sql_table
        label: "Leaf Page 7  (correct final state)"
        cell_count: "cell_count | 1"
        s0: "slot[0] | rowid=10 | Alice  ← only survivor"
        frag: "fragmented_bytes | reclaimed on next compaction"
      }
    }
  }
}
legend_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: "Key Functions" {
    shape: class
    label: "Key Functions  (btree.c / page.c)"
    fn1: "page_delete_cell(page, slot)      → O(N) memmove on ptr array"
    fn2: "btree_delete_by_rowid(bt, rowid)  → search + delete, no cursor"
    fn3: "btree_cursor_next(cur)            → advances slot (assumes stable layout)"
    fn4: "OP_DELETE_ROW opcode             → appends rowid to vm.delete_rowids[]"
    fn5: "OP_FLUSH_DELETES opcode          → calls btree_delete_by_rowid() in loop"
    style.fill: "#0f0f1a"
    style.stroke: "#666688"
    style.border-radius: 6
  }
}
title_row.danger_title -> main_row.danger_track
title_row.safe_title -> main_row.safe_track
main_row.danger_track.d_s1 -> main_row.danger_track.d_arrow1: "btree_cursor_next() + delete"
main_row.danger_track.d_arrow1 -> main_row.danger_track.d_s2: "memmove shifts cell pointer array"
main_row.danger_track.d_s2 -> main_row.danger_track.d_arrow2: "cursor.slot unchanged"
main_row.danger_track.d_arrow2 -> main_row.danger_track.d_s3: "slot now STALE"
main_row.safe_track.s_s1 -> main_row.safe_track.s_arrow1: "scan_cursor reads only — no writes"
main_row.safe_track.s_arrow1 -> main_row.safe_track.s_s2: "rowids collected into int64_t[]"
main_row.safe_track.s_s2 -> main_row.safe_track.s_arrow2: "cursor closed — B-tree unlocked"
main_row.safe_track.s_arrow2 -> main_row.safe_track.s_s3: "no cursor in scope during deletes"
main_row.safe_track.s_s3 -> main_row.safe_track.s_s4: "all rowids deleted safely"