direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
sql_input: {
  shape: rectangle
  label: "INSERT INTO users (name, age) VALUES ('Bob', 25)"
  style.fill: "#E8F4FD"
  style.stroke: "#2980B9"
  style.bold: true
  style.font-size: 13
}
bytecode: {
  label: "VDBE Bytecode Program"
  style.fill: "#F8F9FA"
  style.stroke: "#6C757D"
  style.font-size: 11
  op0: {
    shape: sql_table
    label: "Compiled Instructions"
    r0: "0 | OpenTable  | cursor=0, table='users', write=1"
    r1: "1 | Null       | dest=reg[4]  ← rowid slot"
    r2: "2 | String8    | dest=reg[2], value='Bob'"
    r3: "3 | Integer    | dest=reg[3], value=25"
    r4: "4 | MakeRecord | src=reg[2], count=2, dest=reg[5]"
    r5: "5 | NewRowid   | cursor=0, dest=reg[4]"
    r6: "6 | Insert     | cursor=0, record=reg[5], rowid=reg[4]"
    r7: "7 | Halt       | rc=0"
  }
}
sql_input -> bytecode: "tokenize → parse → codegen"
step1_open: {
  label: "OP_OpenTable — acquire write cursor"
  style.fill: "#EAF6FF"
  style.stroke: "#3498DB"
  style.border-radius: 6
  detail: {
    shape: sql_table
    label: "cursor.c: btree_cursor_open()"
    r0: "root_page = schema_find_table(db, \"users\") → page 7"
    r1: "cursors[0] = btree_cursor_open(bp, 7, WRITE)"
    r2: "cursor.state = CURSOR_VALID"
  }
}
bytecode -> step1_open: "execute"
step2_null: {
  label: "OP_Null — clear rowid slot"
  style.fill: "#FFF3CD"
  style.stroke: "#FFC107"
  style.border-radius: 6
  regstate: {
    shape: sql_table
    label: "Registers after OP_Null"
    r0: "reg[2] | UNSET       |"
    r1: "reg[3] | UNSET       |"
    r2: "reg[4] | VAL_NULL    | rowid: to be assigned"
    r3: "reg[5] | UNSET       |"
  }
}
step1_open -> step2_null: "cursor ready"
step3_str: {
  label: "OP_String8 — load 'Bob' into reg[2]"
  style.fill: "#E8F8F5"
  style.stroke: "#27AE60"
  style.border-radius: 6
  regstate: {
    shape: sql_table
    label: "Registers after OP_String8"
    r0: "reg[2] | VAL_TEXT    | ptr=0x7f3a, len=3, enc=UTF8"
    r1: "reg[3] | UNSET       |"
    r2: "reg[4] | VAL_NULL    |"
  }
}
step2_null -> step3_str: "next op"
step4_int: {
  label: "OP_Integer — load 25 into reg[3]"
  style.fill: "#E8F8F5"
  style.stroke: "#27AE60"
  style.border-radius: 6
  regstate: {
    shape: sql_table
    label: "Registers after OP_Integer"
    r0: "reg[2] | VAL_TEXT    | 'Bob'  (3 bytes)"
    r1: "reg[3] | VAL_INTEGER | 25"
    r2: "reg[4] | VAL_NULL    | (rowid: pending)"
  }
}
step3_str -> step4_int: "next op"
step5_rowid: {
  label: "OP_NewRowid — btree_next_rowid(cursor=0)"
  style.fill: "#F3E5F5"
  style.stroke: "#8E44AD"
  style.border-radius: 6
  algo: {
    shape: sql_table
    label: "btree.c: rightmost-leaf scan"
    r0: "cur_page = root (page 7)"
    r1: "while page_type != TABLE_LEAF:"
    r2: "  cur_page = interior_header.right_child"
    r3: "→ land on leaf page 23"
    r4: "last_cell = cell_at(page, header.cell_count-1)"
    r5: "max_rowid = varint_decode(last_cell + payload_len)"
    r6: "→ max_rowid = 41  →  return 42"
  }
  regstate: {
    shape: sql_table
    label: "Registers after OP_NewRowid"
    r0: "reg[4] | VAL_INTEGER | 42  ← assigned rowid"
  }
}
step4_int -> step5_rowid: "next op"
step6_record: {
  label: "OP_MakeRecord — record_encode(reg[2..3], ncols=2)"
  style.fill: "#FFF8E1"
  style.stroke: "#F39C12"
  style.border-radius: 6
  serial_types: {
    shape: sql_table
    label: "record.c: serial type computation"
    h0: "Column | Value | SerialType  | DataBytes"
    h1: "name   | 'Bob' | 19 (TEXT,3) | 3 bytes"
    h2: "age    | 25    | 1  (INT8)   | 1 byte"
    h3: "header_size = 1+1+1 = 3 bytes (incl. hdr_len varint)"
    h4: "payload = header(3B) + data(4B) = 7 bytes"
  }
  binary_layout: {
    shape: sql_table
    label: "Binary Record — 7 bytes"
    b0: "offset 0 | 0x03 | header_size varint = 3"
    b1: "offset 1 | 0x13 | serial_type[0] = 19 (TEXT len=3)"
    b2: "offset 2 | 0x01 | serial_type[1] = 1  (INT8)"
    b3: "offset 3 | 0x42 | 'B'"
    b4: "offset 4 | 0x6F | 'o'"
    b5: "offset 5 | 0x62 | 'b'"
    b6: "offset 6 | 0x19 | 25 (0x19)"
  }
  regstate: {
    shape: sql_table
    label: "Registers after OP_MakeRecord"
    r0: "reg[5] | VAL_BLOB | ptr → 7-byte encoded record"
    r1: "reg[4] | VAL_INTEGER | 42"
  }
}
step5_rowid -> step6_record: "rowid=42"
step7_cell: {
  label: "btree_insert — build TABLE_LEAF cell"
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
  style.border-radius: 6
  cell_layout: {
    shape: sql_table
    label: "Leaf Cell Layout — 9 bytes total"
    c0: "offset 0 | 0x07 | payload_size varint = 7"
    c1: "offset 1 | 0x2A | rowid varint = 42 (0x2A)"
    c2: "offset 2-8 | 7 bytes payload"
    c3: "cell total = 1+1+7 = 9 bytes"
    c4: "ptr entry  = 2 bytes  →  total slot = 11 bytes"
  }
}
step6_record -> step7_cell: "reg[5]=blob(7B)"
step8_bpool: {
  label: "buffer_pool_get_for_write(bp, page_id=23)"
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  style.border-radius: 6
  bpool_check: {
    shape: sql_table
    label: "buffer_pool.c: cache lookup"
    r0: "page_id=23 | hash bucket | frame=7  CACHE HIT"
    r1: "frames[7].pin_count: 0 → 1"
    r2: "lru_move_to_head(frame=7)"
    r3: "txn_journal_page(db, 23, frame_data)  ← pre-image"
    r4: "fsync(journal_fd)                      ← durability"
    r5: "returns: frames[7].data  (4096-byte page buffer)"
  }
  page_header: {
    shape: sql_table
    label: "Page 23 Header — before insert"
    h0: "page_type    | 0x0D (TABLE_LEAF)"
    h1: "cell_count   | 38"
    h2: "content_area | 0x0A2C (offset 2604)"
    h3: "free_space   | 2604 − (8 + 38×2) = 2520 bytes"
    h4: "Need 11B (9 cell + 2 ptr) → fits ✓"
  }
}
step7_cell -> step8_bpool: "descend B-tree to leaf"
decision: {
  shape: diamond
  label: "Page 23\nfree space\n≥ 11 bytes?"
  style.fill: "#FFF8E1"
  style.stroke: "#F39C12"
  style.font-size: 13
}
step8_bpool -> decision: "free=2520B, need=11B"
path_fits: {
  label: "Path A — direct insert"
  style.fill: "#F1F8E9"
  style.stroke: "#558B2F"
  style.border-radius: 8
  insert_cell: {
    shape: sql_table
    label: "page_insert_cell(page, cell, pos=38)"
    r0: "content_area -= 9          → 2604−9 = 2595"
    r1: "memcpy(page+2595, cell, 9) ← write payload"
    r2: "memmove(ptrs+39×2, ptrs+38×2, 0)"
    r3: "ptr[38] = 0x0A23           ← points to offset 2595"
    r4: "header.cell_count = 39"
    r5: "header.content_area = 0x0A23 (2595)"
  }
  page_after: {
    shape: sql_table
    label: "Page 23 Header — after insert"
    h0: "page_type    | 0x0D (TABLE_LEAF)"
    h1: "cell_count   | 39  (was 38)"
    h2: "content_area | 0x0A23 (2595)"
    h3: "ptr[38]      | 0x0A23 → rowid=42 cell"
    h4: "free_space   | 2520 − 11 = 2509 bytes"
  }
}
path_split: {
  label: "Path B — page full → leaf split"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.border-radius: 8
  split_trigger: {
    shape: sql_table
    label: "leaf_split(bp, page_id=23, new_cell, rowid=42)"
    r0: "right_id = buffer_pool_new_page(bp) → page 89"
    r1: "page_init(right, TABLE_LEAF)"
    r2: "collect all cells (38) + new cell → sorted by rowid"
    r3: "split_point = (38+1)/2 = 19"
    r4: "left  (page 23): cells 0..18  rowids  1..20"
    r5: "right (page 89): cells 0..19  rowids 21..42"
  }
  split_result: {
    shape: sql_table
    label: "After Split — separator promoted to parent"
    r0: "separator_key = 21  (min rowid of right leaf)"
    r1: "parent interior cell: [left_ptr=23][key=21]"
    r2: "parent.right_child_ptr → page 89"
    r3: "both pages dirty in buffer pool"
  }
}
decision -> path_fits: "YES — 2520 ≥ 11" {
  style.stroke: "#2E7D32"
  style.font-color: "#2E7D32"
  style.bold: true
}
decision -> path_split: "NO — page full" {
  style.stroke: "#C62828"
  style.font-color: "#C62828"
  style.stroke-dash: 5
  style.bold: true
}
confirm: {
  label: "buffer_pool_unpin + register snapshot"
  style.fill: "#E8F4FD"
  style.stroke: "#2980B9"
  style.border-radius: 6
  unpin: {
    shape: sql_table
    label: "buffer_pool.c: release page"
    r0: "frames[7].is_dirty = 1"
    r1: "frames[7].pin_count-- → 0"
    r2: "page stays in pool at LRU head"
    r3: "physical write deferred to eviction / COMMIT flush"
  }
  final_regs: {
    shape: sql_table
    label: "Register File — after OP_Insert"
    r0: "reg[2] | VAL_TEXT    | 'Bob'"
    r1: "reg[3] | VAL_INTEGER | 25"
    r2: "reg[4] | VAL_INTEGER | 42   ← confirmed rowid"
    r3: "reg[5] | VAL_BLOB    | 7-byte record (in-frame)"
    r4: "cursor | CURSOR_VALID | write, positioned at rowid 42"
  }
}
path_fits -> confirm: "cell written"
path_split -> confirm: "split complete, rowid=42 in page 89"
halt: {
  label: "OP_Halt — INSERT complete"
  style.fill: "#2C3E50"
  style.stroke: "#2C3E50"
  style.font-color: "#FFFFFF"
  style.border-radius: 8
  style.bold: true
  summary: {
    shape: sql_table
    label: "Execution Summary"
    s1: "SQL parsed       | INSERT INTO users (name, age) VALUES ('Bob', 25)"
    s2: "Rowid assigned   | 42  (rightmost-leaf MAX+1)"
    s3: "Record encoded   | 7 bytes  (varint header + UTF-8 + INT8)"
    s4: "Cell written     | 9 bytes at page offset 0x0A23"
    s5: "Buffer pool      | page 23 dirty, pin_count=0"
    s6: "Journal          | pre-image of page 23 fsynced before write"
    s7: "B-tree state     | 39 cells in leaf page 23"
  }
}
confirm -> halt: "OP_Halt"