direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## DML Write Path — INSERT / UPDATE / DELETE
  Buffer pool interaction at every step
| {near: top-center}
dml_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  insert_col: "INSERT Path" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#4caf50"
    style.border-radius: 8
    i1: "1 · Serialize Row" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    i2: "2 · Compile record bytes" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    i3: "3 · Search B-tree leaf\n(btree_search)" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    i4: "4 · fetch_page(leaf)\npin_count++" {
      style.fill: "#bbdefb"
      style.border-radius: 4
    }
    i5_dec: "Page has\nroom?" {
      shape: diamond
      style.fill: "#fff9c4"
    }
    i6_yes: "5a · page_insert_cell\nwrite pointer + data" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    i6_no: "5b · btree_split_leaf\nalloc new page" {
      style.fill: "#ffccbc"
      style.border-radius: 4
    }
    i7_split: "6 · Promote median key\nto parent page" {
      style.fill: "#ffccbc"
      style.border-radius: 4
    }
    i8_root: "Root split?\nNew root page" {
      shape: diamond
      style.fill: "#fff9c4"
    }
    i9: "7 · mark_page_dirty\nunpin_page(dirty=true)" {
      style.fill: "#bbdefb"
      style.border-radius: 4
    }
    i10: "8 · Maintain all indexes\none insert per index B+tree" {
      style.fill: "#e8f5e9"
      style.border-radius: 4
    }
    i11: "DONE — row visible\nafter commit" {
      shape: oval
      style.fill: "#4caf50"
      style.font-color: white
    }
    i1 -> i2: "cols + types"
    i2 -> i3: "cell_buf"
    i3 -> i4: "leaf page_id"
    i4 -> i5_dec: "page pinned"
    i5_dec -> i6_yes: "YES"
    i5_dec -> i6_no: "NO — full"
    i6_no -> i7_split: "split"
    i7_split -> i8_root: "promote"
    i8_root -> i6_yes: "NO"
    i8_root -> i6_yes: "YES → alloc root"
    i6_yes -> i9: "cell written"
    i9 -> i10: "dirty flagged"
    i10 -> i11: "indexes ok"
  }
  update_col: "UPDATE Path" {
    direction: down
    style.fill: "#fff8e1"
    style.stroke: "#ff9800"
    style.border-radius: 8
    u1: "1 · Pass 1 — Scan\nCollect matching rowids" {
      style.fill: "#ffe082"
      style.border-radius: 4
    }
    u2: "2 · Store rowids in\nephemeral B-tree" {
      style.fill: "#ffe082"
      style.border-radius: 4
    }
    u3: "3 · Pass 2 — For each rowid\nOP_SEEK_ROWID" {
      style.fill: "#ffe082"
      style.border-radius: 4
    }
    u4: "4 · fetch_page(leaf)\npin_count++" {
      style.fill: "#bbdefb"
      style.border-radius: 4
    }
    u5: "5 · Read old column values\nfor index maintenance" {
      style.fill: "#fff8e1"
      style.border-radius: 4
    }
    u6: "6 · Apply SET values\nto register array" {
      style.fill: "#ffe082"
      style.border-radius: 4
    }
    u7_dec: "Indexed col\nchanged?" {
      shape: diamond
      style.fill: "#fff9c4"
    }
    u8_idx: "7a · index_btree_delete\nold key + rowid" {
      style.fill: "#ffccbc"
      style.border-radius: 4
    }
    u9_idx: "7b · index_btree_insert\nnew key + rowid" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    u10: "8 · OP_DELETE old cell\nmark space fragmented" {
      style.fill: "#ffccbc"
      style.border-radius: 4
    }
    u11: "9 · Serialize new record\nOP_INSERT new cell" {
      style.fill: "#c8e6c9"
      style.border-radius: 4
    }
    u12_dec: "Page full after\nre-insert?" {
      shape: diamond
      style.fill: "#fff9c4"
    }
    u13_split: "10 · btree_split_leaf" {
      style.fill: "#ffccbc"
      style.border-radius: 4
    }
    u14: "11 · mark_page_dirty\nunpin_page(dirty=true)" {
      style.fill: "#bbdefb"
      style.border-radius: 4
    }
    u15: "DONE — updated row\nvisible after commit" {
      shape: oval
      style.fill: "#ff9800"
      style.font-color: white
    }
    u1 -> u2: "rowid"
    u2 -> u3: "iterate"
    u3 -> u4: "page_id"
    u4 -> u5: "page pinned"
    u5 -> u6: "old values"
    u6 -> u7_dec: "diff check"
    u7_dec -> u8_idx: "YES"
    u7_dec -> u10: "NO"
    u8_idx -> u9_idx: "delete ok"
    u9_idx -> u10: "insert ok"
    u10 -> u11: "cell removed"
    u11 -> u12_dec: "cell size"
    u12_dec -> u13_split: "YES — full"
    u12_dec -> u14: "NO"
    u13_split -> u14: "split done"
    u14 -> u15: "dirty flagged"
  }
  delete_col: "DELETE Path" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#f44336"
    style.border-radius: 8
    d1: "1 · Pass 1 — Scan\nCollect matching rowids" {
      style.fill: "#f8bbd0"
      style.border-radius: 4
    }
    d2: "2 · Save rowids to\nephemeral B-tree" {
      style.fill: "#f8bbd0"
      style.border-radius: 4
    }
    d3: "3 · Pass 2 — For each rowid\nOP_SEEK_ROWID" {
      style.fill: "#f8bbd0"
      style.border-radius: 4
    }
    d4: "4 · Read old column values\nfor index cleanup" {
      style.fill: "#fce4ec"
      style.border-radius: 4
    }
    d5: "5 · For each index:\nindex_btree_delete(old_key, rowid)" {
      style.fill: "#ffccbc"
      style.border-radius: 4
    }
    d6: "6 · fetch_page(leaf)\npin_count++" {
      style.fill: "#bbdefb"
      style.border-radius: 4
    }
    d7: "7 · Remove cell pointer\nfrom slot array\nshift array left" {
      style.fill: "#f8bbd0"
      style.border-radius: 4
    }
    d8: "8 · Add freed bytes to\nfragmented_bytes counter" {
      style.fill: "#f8bbd0"
      style.border-radius: 4
    }
    d9_dec: "fragmented_bytes\n> 25% of page?" {
      shape: diamond
      style.fill: "#fff9c4"
    }
    d10_defrag: "9a · page_defragment\nrewrite cells contiguously" {
      style.fill: "#ffccbc"
      style.border-radius: 4
    }
    d11_dec: "Cell count <\nhalf full?" {
      shape: diamond
      style.fill: "#fff9c4"
    }
    d12_merge: "9b · merge with\nsibling page (optional)" {
      style.fill: "#e0e0e0"
      style.border-radius: 4
      style.stroke-dash: 4
    }
    d13: "10 · mark_page_dirty\nunpin_page(dirty=true)" {
      style.fill: "#bbdefb"
      style.border-radius: 4
    }
    d14: "DONE — row invisible\nafter commit" {
      shape: oval
      style.fill: "#f44336"
      style.font-color: white
    }
    d1 -> d2: "rowid"
    d2 -> d3: "iterate"
    d3 -> d4: "old values"
    d4 -> d5: "index keys"
    d5 -> d6: "indexes clean"
    d6 -> d7: "page pinned"
    d7 -> d8: "cell_count--"
    d8 -> d9_dec: "frag check"
    d9_dec -> d10_defrag: "YES — compact"
    d9_dec -> d11_dec: "NO"
    d10_defrag -> d11_dec: "compacted"
    d11_dec -> d12_merge: "YES — sparse"
    d11_dec -> d13: "NO"
    d12_merge -> d13: "merged"
    d13 -> d14: "dirty flagged"
  }
}
bp_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  buffer_pool: "Buffer Pool — buffer_pool.c" {
    shape: sql_table
    f1: "fetch_page(pool, page_id)       | pin frame; load from disk on miss"
    f2: "unpin_page(pool, page_id, dirty) | decrement pin_count; set dirty flag"
    f3: "mark_page_dirty(pool, page_id)  | frame.is_dirty = true"
    f4: "buffer_pool_new_page(pool)       | extend file; return fresh page_id"
    f5: "evict_frame()                   | dirty → journal/WAL write before reuse"
    f6: "flush_all()                     | fsync journal → write dirty → fsync db"
    style.fill: "#e3f2fd"
  }
  txn_note: "Transaction Write Guarantees" {
    shape: sql_table
    r1: "Journal mode   | journal fsync BEFORE any db page write"
    r2: "WAL mode       | append frame to WAL; fsync on commit frame only"
    r3: "Crash recovery | journal → undo;  WAL → redo to last commit"
    style.fill: "#fce4ec"
  }
}
dml_row.insert_col.i4 -> bp_row.buffer_pool: "fetch leaf"
dml_row.insert_col.i9 -> bp_row.buffer_pool: "dirty | unpin"
dml_row.update_col.u4 -> bp_row.buffer_pool: "fetch leaf"
dml_row.update_col.u14 -> bp_row.buffer_pool: "dirty | unpin"
dml_row.delete_col.d6 -> bp_row.buffer_pool: "fetch leaf"
dml_row.delete_col.d13 -> bp_row.buffer_pool: "dirty | unpin"
bp_row.buffer_pool -> bp_row.txn_note: "write ordering"