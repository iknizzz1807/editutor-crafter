direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
query: "SELECT name FROM users WHERE age = 25" {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    font-color: "#e0e0ff"
    stroke: "#6c63ff"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    bold: true
  }
}
phase1: Index B+tree Traversal — 3 page reads {
  style: {
    fill: "#0d1b2a"
    stroke: "#3a86ff"
    stroke-width: 2
    border-radius: 8
    font-color: "#3a86ff"
    bold: true
  }
  row1: "" {
    style: {
      fill: transparent
      stroke: transparent
    }
    root_idx: Index Root Page {
      shape: sql_table
      style: {
        fill: "#0a2240"
        stroke: "#3a86ff"
        font-color: "#ccd6f6"
      }
      page_type: "btree_interior (index)"
      page_id: "page 42"
      entry_0: "age < 20  → left child"
      entry_1: "20 ≤ age < 30 → page 87"
      entry_2: "age ≥ 30  → right child"
    }
    internal_idx: Index Internal Page {
      shape: sql_table
      style: {
        fill: "#0a2240"
        stroke: "#3a86ff"
        font-color: "#ccd6f6"
      }
      page_type: "btree_interior (index)"
      page_id: "page 87"
      entry_0: "age=23 → page 91"
      entry_1: "age=25 → page 94"
      entry_2: "age=27 → page 98"
    }
    leaf_idx: Index Leaf Page {
      shape: sql_table
      style: {
        fill: "#0a2240"
        stroke: "#3a86ff"
        font-color: "#ccd6f6"
      }
      page_type: "btree_leaf (index)"
      page_id: "page 94"
      cell_0: "age=25, rowid=3301"
      cell_1: "age=25, rowid=7042  ◀ match"
      cell_2: "age=25, rowid=8819"
      next_leaf: "→ page 95"
    }
  }
}
rowid_extract: rowid = 7042 {
  shape: rectangle
  style: {
    fill: "#2d1b69"
    stroke: "#8b5cf6"
    stroke-width: 2
    border-radius: 6
    font-color: "#e9d5ff"
    bold: true
    font-size: 13
  }
}
phase2: Table B-tree Traversal — 3 page reads {
  style: {
    fill: "#1a0d0d"
    stroke: "#ff6b6b"
    stroke-width: 2
    border-radius: 8
    font-color: "#ff6b6b"
    bold: true
  }
  row2: "" {
    style: {
      fill: transparent
      stroke: transparent
    }
    root_tbl: Table Root Page {
      shape: sql_table
      style: {
        fill: "#2a0d0d"
        stroke: "#ff6b6b"
        font-color: "#ffd6d6"
      }
      page_type: "btree_interior (table)"
      page_id: "page 1"
      entry_0: "rowid ≤ 4000 → page 12"
      entry_1: "4001 ≤ rowid ≤ 8000 → page 33"
      entry_2: "rowid > 8000 → page 57"
    }
    internal_tbl: Table Internal Page {
      shape: sql_table
      style: {
        fill: "#2a0d0d"
        stroke: "#ff6b6b"
        font-color: "#ffd6d6"
      }
      page_type: "btree_interior (table)"
      page_id: "page 33"
      entry_0: "rowid ≤ 6000 → page 38"
      entry_1: "6001 ≤ rowid ≤ 7500 → page 41"
      entry_2: "rowid > 7500 → page 44"
    }
    leaf_tbl: Table Leaf Page {
      shape: sql_table
      style: {
        fill: "#2a0d0d"
        stroke: "#ff6b6b"
        font-color: "#ffd6d6"
      }
      page_type: "btree_leaf (table)"
      page_id: "page 41"
      cell_0: "rowid=7040 | name='Bob'   | age=31"
      cell_1: "rowid=7041 | name='Carol' | age=19"
      cell_2: "rowid=7042 | name='Alice' | age=25  ◀"
      cell_3: "rowid=7043 | name='Dave'  | age=22"
    }
  }
}
result: Row: (rowid=7042, name='Alice', age=25) {
  shape: rectangle
  style: {
    fill: "#0d2e1a"
    stroke: "#22c55e"
    stroke-width: 2
    border-radius: 6
    font-color: "#bbf7d0"
    bold: true
    font-size: 13
  }
}
io_cost: I/O Cost Summary {
  style: {
    fill: "#1c1c1c"
    stroke: "#facc15"
    stroke-width: 2
    border-radius: 8
    font-color: "#facc15"
    bold: true
  }
  detail: "" {
    shape: sql_table
    style: {
      fill: "#1c1c1c"
      stroke: "#facc15"
      font-color: "#fef9c3"
    }
    index_reads: "Index B+tree: 3 page reads (root → internal → leaf)"
    table_reads: "Table B-tree: 3 page reads (root → internal → leaf)"
    total: "Total: 6 page reads per point query"
    note: "Table reads = random I/O (rowid ≠ sequential offset)"
  }
}
covering: Covering Index Eliminates Second Traversal {
  style: {
    fill: "#0d1f0d"
    stroke: "#4ade80"
    stroke-width: 2
    border-radius: 8
    font-color: "#4ade80"
    bold: true
  }
  detail: "" {
    shape: sql_table
    style: {
      fill: "#0d1f0d"
      stroke: "#4ade80"
      font-color: "#bbf7d0"
    }
    standard_idx: "CREATE INDEX idx_age ON users(age)"
    result_std: "  → stores (age, rowid) only → needs table lookup"
    covering_idx: "CREATE INDEX idx_age_name ON users(age, name)"
    result_cov: "  → stores (age, name, rowid) → name found in leaf"
    benefit: "Covering index: 3 reads total, no table B-tree descent"
  }
}
query -> phase1.row1.root_idx: "page read 1" {
  style: {
    stroke: "#3a86ff"
    font-color: "#3a86ff"
  }
}
phase1.row1.root_idx -> phase1.row1.internal_idx: "page read 2" {
  style: {
    stroke: "#3a86ff"
    font-color: "#3a86ff"
  }
}
phase1.row1.internal_idx -> phase1.row1.leaf_idx: "page read 3" {
  style: {
    stroke: "#3a86ff"
    font-color: "#3a86ff"
  }
}
phase1.row1.leaf_idx -> rowid_extract: "extract rowid" {
  style: {
    stroke: "#8b5cf6"
    font-color: "#8b5cf6"
  }
}
rowid_extract -> phase2.row2.root_tbl: "page read 4" {
  style: {
    stroke: "#ff6b6b"
    font-color: "#ff6b6b"
  }
}
phase2.row2.root_tbl -> phase2.row2.internal_tbl: "page read 5" {
  style: {
    stroke: "#ff6b6b"
    font-color: "#ff6b6b"
  }
}
phase2.row2.internal_tbl -> phase2.row2.leaf_tbl: "page read 6" {
  style: {
    stroke: "#ff6b6b"
    font-color: "#ff6b6b"
  }
}
phase2.row2.leaf_tbl -> result: "deserialize row" {
  style: {
    stroke: "#22c55e"
    font-color: "#22c55e"
  }
}
result -> io_cost: "cost model" {
  style: {
    stroke: "#facc15"
    font-color: "#facc15"
    stroke-dash: 4
  }
}
result -> covering: "optimization" {
  style: {
    stroke: "#4ade80"
    font-color: "#4ade80"
    stroke-dash: 4
  }
}