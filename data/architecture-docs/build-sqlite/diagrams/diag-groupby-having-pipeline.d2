direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
phase1: "PHASE 1 — ACCUMULATION" {
  style.fill: "#EEF4FF"
  style.stroke: "#7B9CD4"
  style.border-radius: 8
  direction: down
  scan: "Table B-tree Scan" {
    style.fill: "#C7E0FF"
    style.stroke: "#3A7BD5"
    style.border-radius: 6
    shape: rectangle
  }
  where_filter: "WHERE Filter — per-row" {
    style.fill: "#FFF9C9"
    style.stroke: "#C9A000"
    style.border-radius: 6
    shape: rectangle
  }
  where_note: "PRE-AGGREGATION\\noperates on individual raw rows\\ncannot reference aggregate results" {
    style.fill: "#FFFDE0"
    style.stroke: "#C9A000"
    style.font-color: "#7A5F00"
    style.font-size: 12
    style.italic: true
    shape: rectangle
  }
  hash_step: "Hash Group Lookup\\nfind_or_create GroupEntry" {
    style.fill: "#E8D5FF"
    style.stroke: "#7B3FA0"
    style.border-radius: 6
    shape: rectangle
  }
  acc_step: "Accumulator Step\\nOP_AGG_GROUP_STEP per aggregate" {
    style.fill: "#D5F0FF"
    style.stroke: "#1A7FAD"
    style.border-radius: 6
    shape: rectangle
  }
  loop_back: "More rows?" {
    shape: diamond
    style.fill: "#FFECD2"
    style.stroke: "#C85000"
  }
  scan -> where_filter: "raw row"
  where_filter -> hash_step: "row passes" {
    style.stroke: "#3AB060"
  }
  where_filter -> loop_back: "row rejected" {
    style.stroke: "#CC4444"
    style.stroke-dash: 4
  }
  where_filter -> where_note: "" {
    style.stroke: "#C9A000"
    style.stroke-dash: 3
  }
  hash_step -> acc_step: "GroupEntry*"
  acc_step -> loop_back: "done"
  loop_back -> scan: "yes — next row" {
    style.stroke: "#3A7BD5"
    style.stroke-dash: 3
  }
}
phase_boundary: "— All rows consumed · Hash table fully populated —" {
  style.fill: "#F0F0F0"
  style.stroke: "#AAAAAA"
  style.font-color: "#555555"
  style.italic: true
  style.border-radius: 4
  shape: rectangle
}
phase2: "PHASE 2 — OUTPUT ITERATION" {
  style.fill: "#F0FFF4"
  style.stroke: "#4CAF50"
  style.border-radius: 8
  direction: down
  group_iter: "Group Hash Table Iterator\\nOP_AGG_GROUP_ITER" {
    style.fill: "#E8D5FF"
    style.stroke: "#7B3FA0"
    style.border-radius: 6
    shape: rectangle
  }
  finalize: "Accumulator Finalize\\nOP_AGG_GROUP_VAL → register" {
    style.fill: "#D5F0FF"
    style.stroke: "#1A7FAD"
    style.border-radius: 6
    shape: rectangle
  }
  having_filter: "HAVING Filter — per-group" {
    style.fill: "#FFE8CC"
    style.stroke: "#B86800"
    style.border-radius: 6
    shape: rectangle
  }
  having_note: "POST-AGGREGATION\\noperates on finalized aggregate values\\nCAN reference COUNT(*), AVG(x), SUM(x)" {
    style.fill: "#FFF0D5"
    style.stroke: "#B86800"
    style.font-color: "#7A4A00"
    style.font-size: 12
    style.italic: true
    shape: rectangle
  }
  project: "Project Output Columns\\nOP_AGG_GROUP_KEY + OP_AGG_GROUP_VAL" {
    style.fill: "#C7E0FF"
    style.stroke: "#3A7BD5"
    style.border-radius: 6
    shape: rectangle
  }
  result_row: "Emit Result Row\\nOP_RESULT_ROW → result_callback()" {
    style.fill: "#C8F0C8"
    style.stroke: "#2D8A2D"
    style.border-radius: 6
    shape: rectangle
  }
  more_groups: "More groups?" {
    shape: diamond
    style.fill: "#FFECD2"
    style.stroke: "#C85000"
  }
  group_iter -> finalize: "GroupEntry*"
  finalize -> having_filter: "agg Value[]"
  having_filter -> project: "group passes" {
    style.stroke: "#3AB060"
  }
  having_filter -> more_groups: "group rejected" {
    style.stroke: "#CC4444"
    style.stroke-dash: 4
  }
  having_filter -> having_note: "" {
    style.stroke: "#B86800"
    style.stroke-dash: 3
  }
  project -> result_row: "output registers"
  result_row -> more_groups: "emitted"
  more_groups -> group_iter: "yes — advance" {
    style.stroke: "#7B3FA0"
    style.stroke-dash: 3
  }
}
done: "OP_HALT" {
  shape: oval
  style.fill: "#2D8A2D"
  style.font-color: "#FFFFFF"
  style.stroke: "#1A5A1A"
}
contrast: "WHERE vs HAVING — Execution Phase Contrast" {
  style.fill: "#FFF8F0"
  style.stroke: "#C85000"
  style.border-radius: 8
  direction: right
  where_col: "WHERE (pre-aggregation)" {
    style.fill: "#FFF9C9"
    style.stroke: "#C9A000"
    style.border-radius: 6
    shape: rectangle
    w1: "Runs in PHASE 1 — scan loop" {
      style.font-size: 13
    }
    w2: "Input: individual raw row" {
      style.font-size: 13
    }
    w3: "Cannot reference COUNT(*), SUM(x)" {
      style.font-size: 13
    }
    w4: "Rejects rows BEFORE they enter groups" {
      style.font-size: 13
    }
  }
  having_col: "HAVING (post-aggregation)" {
    style.fill: "#FFF0D5"
    style.stroke: "#B86800"
    style.border-radius: 6
    shape: rectangle
    h1: "Runs in PHASE 2 — group iteration" {
      style.font-size: 13
    }
    h2: "Input: finalized aggregate result" {
      style.font-size: 13
    }
    h3: "CAN reference COUNT(*), AVG(x)" {
      style.font-size: 13
    }
    h4: "Rejects entire GROUPS from output" {
      style.font-size: 13
    }
  }
}
phase1 -> phase_boundary: "all rows processed"
phase_boundary -> phase2: "begin group iteration"
phase2.more_groups -> done: "no — all groups exhausted" {
  style.stroke: "#2D8A2D"
}