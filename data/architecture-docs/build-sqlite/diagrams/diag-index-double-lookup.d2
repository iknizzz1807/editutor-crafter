direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
sql_query: {
  label: "SELECT * FROM users WHERE name = 'Alice'"
  shape: rectangle
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
    bold: true
    border-radius: 8
  }
  q: |`sql
    SELECT * FROM users WHERE name = 'Alice';
    -- Index: CREATE INDEX idx_name ON users(name)
    -- Planner: idx_name covers predicate → INDEX SCAN
    -- Strategy: descent idx_name B+tree → extract rowid → descent table B-tree
  `|
}
cost_banner: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  index_cost: {
    label: "Index Scan Cost"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    style.border-radius: 6
    c1: "~6 page reads total"
    c2: "3 index pages + 3 table pages"
    c3: "~100µs (cold cache)"
  }
  vs_label: {
    label: "vs"
    shape: circle
    style.fill: "#FF9800"
    style.font-color: white
    style.bold: true
    width: 56
    height: 56
  }
  scan_cost: {
    label: "Full Table Scan Cost"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    style.border-radius: 6
    c1: "~10,000 page reads"
    c2: "Read every leaf page"
    c3: "~500ms (cold cache)"
  }
}
phase1_header: {
  label: "PHASE 1 — Index B+tree Traversal  (idx_name)"
  shape: rectangle
  style.fill: "#7B1FA2"
  style.font-color: white
  style.bold: true
  style.border-radius: 6
}
idx_tree: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  idx_root: {
    label: "idx_name Root  (idx_pg 1)"
    shape: sql_table
    style.fill: "#CE93D8"
    style.stroke: "#7B1FA2"
    style.stroke-width: 3
    r0: "type      | INDEX_INTERNAL"
    r1: "sep[0]    | 'Carol'  → left_child = pg 4"
    r2: "sep[1]    | 'Frank'  → left_child = pg 5"
    r3: "right_ptr | pg 6  (keys > 'Frank')"
    r4: "seek      | 'Alice' < 'Carol' → go pg 4"
    r5: "buffer    | HOT — pinned, ~10 ns"
  }
  idx_internal: {
    label: "idx_name Internal  (idx_pg 4)"
    shape: sql_table
    style.fill: "#CE93D8"
    style.stroke: "#7B1FA2"
    r0: "type      | INDEX_INTERNAL"
    r1: "sep[0]    | 'Alice'  → left_child = pg 9"
    r2: "sep[1]    | 'Bob'    → left_child = pg 10"
    r3: "right_ptr | pg 11"
    r4: "seek      | 'Alice' <= 'Alice' → go pg 9"
    r5: "buffer    | WARM — likely cached, ~50 ns"
  }
  idx_leaf: {
    label: "idx_name Leaf  (idx_pg 9)"
    shape: sql_table
    style.fill: "#EDE7F6"
    style.stroke: "#7B1FA2"
    r0: "type      | INDEX_LEAF"
    r1: "slot[0]   | key='Alan'   rowid=88"
    r2: "slot[1]   | key='Alice'  rowid=42  ◀ MATCH"
    r3: "slot[2]   | key='Alina'  rowid=61"
    r4: "right_sib | idx_pg 10  (range scans continue here)"
    r5: "buffer    | COLD — 1 page read = 50 µs"
  }
}
rowid_box: {
  label: "Extracted Rowid"
  shape: rectangle
  style.fill: "#E65100"
  style.font-color: white
  style.bold: true
  style.border-radius: 8
  style.shadow: true
  r1: "rowid = 42"
  r2: "decoded from idx_pg 9 slot[1] payload"
  r3: "varint_decode(cell_ptr + hdr_len, &vlen)"
}
phase2_header: {
  label: "PHASE 2 — Table B-tree Lookup by Rowid=42  (users)"
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.bold: true
  style.border-radius: 6
}
tbl_tree: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tbl_root: {
    label: "users Root  (tbl_pg 1)"
    shape: sql_table
    style.fill: "#90CAF9"
    style.stroke: "#1565C0"
    style.stroke-width: 3
    r0: "type      | TABLE_INTERNAL"
    r1: "sep[0]    | rowid=25 → left_child = pg 2"
    r2: "sep[1]    | rowid=75 → left_child = pg 3"
    r3: "right_ptr | pg 7  (rowid > 75)"
    r4: "seek      | 42 <= 75 → go pg 2"
    r5: "buffer    | HOT — pinned, ~10 ns"
  }
  tbl_internal: {
    label: "users Internal  (tbl_pg 2)"
    shape: sql_table
    style.fill: "#90CAF9"
    style.stroke: "#1565C0"
    r0: "type      | TABLE_INTERNAL"
    r1: "sep[0]    | rowid=35 → left_child = pg 8"
    r2: "sep[1]    | rowid=50 → left_child = pg 12"
    r3: "right_ptr | pg 13"
    r4: "seek      | 42 <= 50 → go pg 12"
    r5: "buffer    | WARM — likely cached, ~50 ns"
  }
  tbl_leaf: {
    label: "users Leaf  (tbl_pg 12)"
    shape: sql_table
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
    r0: "type      | TABLE_LEAF"
    r1: "slot[0]   | rowid=38 → record(name='Al'...)"
    r2: "slot[1]   | rowid=42 → record  ◀ TARGET"
    r3: "slot[2]   | rowid=45 → record(name='Bo'...)"
    r4: "buffer    | COLD — 1 page read = 50 µs"
  }
}
record_decode: {
  label: "Record Deserialization  (tbl_pg 12, slot[1])"
  shape: sql_table
  style.fill: "#1B5E20"
  style.font-color: white
  style.stroke: "#388E3C"
  style.stroke-width: 2
  r0: "layout    | [payload_len: varint][rowid: varint][payload: bytes]"
  r1: "hdr_size  | 4 bytes (varint)"
  r2: "serial[0] | 0x0D → TEXT len=5   col: name"
  r3: "serial[1] | 0x04 → INT32        col: age"
  r4: "serial[2] | 0x23 → TEXT len=17  col: email"
  r5: "data[0]   | 'Alice'             (5 bytes)"
  r6: "data[1]   | 30                  (4 bytes big-endian)"
  r7: "data[2]   | 'alice@example.com' (17 bytes)"
}
result_row: {
  label: "Query Result"
  shape: sql_table
  style.fill: "#004D40"
  style.font-color: white
  style.stroke: "#00BFA5"
  style.stroke-width: 3
  style.shadow: true
  r0: "rowid | 42"
  r1: "name  | Alice"
  r2: "age   | 30"
  r3: "email | alice@example.com"
}
page_budget: {
  label: "Page Read Budget — Index Scan vs Full Table Scan"
  shape: sql_table
  style.fill: "#212121"
  style.font-color: white
  style.stroke: "#FF9800"
  style.stroke-width: 2
  h0: "Operation             | Pages  | Cache | Latency"
  r1: "idx_name root  pg 1   |    1   | HOT   | ~10 ns"
  r2: "idx_name internal pg4 |    1   | WARM  | ~50 ns"
  r3: "idx_name leaf  pg 9   |    1   | COLD  | ~50 µs"
  r4: "users root     pg 1   |    1   | HOT   | ~10 ns"
  r5: "users internal pg 2   |    1   | WARM  | ~50 ns"
  r6: "users leaf     pg 12  |    1   | COLD  | ~50 µs"
  r7: "── INDEX SCAN TOTAL   |    6   | mixed | ~100 µs"
  r8: "── FULL TABLE SCAN    | 10,000 | cold  | ~500 ms"
  r9: "── SPEEDUP            | 1667×  | —     | index wins"
}
sql_query -> cost_banner: "query planner evaluates strategies"
cost_banner -> phase1_header: "choose index scan"
phase1_header -> idx_tree: "descend idx_name B+tree"
idx_tree.idx_root -> idx_tree.idx_internal: "'Alice' < 'Carol' → left child pg 4"
idx_tree.idx_internal -> idx_tree.idx_leaf: "'Alice' <= 'Alice' → left child pg 9"
idx_tree -> rowid_box: "slot[1] matched: ('Alice', rowid=42)"
rowid_box -> phase2_header: "hand off rowid=42"
phase2_header -> tbl_tree: "descend users B-tree"
tbl_tree.tbl_root -> tbl_tree.tbl_internal: "42 <= 75 → left child pg 2"
tbl_tree.tbl_internal -> tbl_tree.tbl_leaf: "42 <= 50 → left child pg 12"
tbl_tree -> record_decode: "fetch pg 12 slot[1] payload"
record_decode -> result_row: "all columns deserialized"
result_row -> page_budget: "6 pages read, not 10,000"