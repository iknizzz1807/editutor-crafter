direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

trigger: "INSERT INTO users (name, age, status)\nVALUES ('Alice', 25, 'active')" {
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    stroke: "#cba6f7"
    stroke-width: 2
    font-color: "#cdd6f4"
    font-size: 13
    border-radius: 6
  }
}

amplification: "Write Amplification: 1 logical INSERT → 3 physical B-tree writes" {
  shape: rectangle
  style: {
    fill: "#181825"
    stroke: "#f38ba8"
    stroke-width: 2
    stroke-dash: 4
    font-color: "#f38ba8"
    font-size: 13
    border-radius: 4
  }
}

table_section: "① Table B-tree (rowid-keyed)" {
  style: {
    fill: "#1e1e2e"
    stroke: "#89b4fa"
    stroke-width: 1
    border-radius: 8
    font-color: "#89b4fa"
    font-size: 12
  }
  direction: right

  before: "Before INSERT" {
    style: {
      fill: "#181825"
      stroke: "#45475a"
      border-radius: 6
      font-color: "#a6adc8"
      font-size: 11
    }
    page: "Leaf Page #3 (table: users)" {
      shape: sql_table
      style: {
        fill: "#11111b"
        stroke: "#45475a"
        font-color: "#cdd6f4"
      }
      hdr: "Page Header (8 B) | type=0x0d  ncells=2"
      ptr0: "ptr[0] = 0x0FA0 | → cell rowid=3"
      ptr1: "ptr[1] = 0x0F30 | → cell rowid=5"
      gap: "… free space …"
      cell1: "cell: rowid=5 | name='Bob'  age=30 status='active'"
      cell0: "cell: rowid=3 | name='Carol' age=22 status='inactive'"
    }
  }

  after: "After INSERT (rowid=7 assigned)" {
    style: {
      fill: "#181825"
      stroke: "#a6e3a1"
      border-radius: 6
      font-color: "#a6e3a1"
      font-size: 11
    }
    page: "Leaf Page #3 (table: users)" {
      shape: sql_table
      style: {
        fill: "#11111b"
        stroke: "#a6e3a1"
        font-color: "#cdd6f4"
      }
      hdr: "Page Header (8 B) | type=0x0d  ncells=3"
      ptr0: "ptr[0] = 0x0FA0 | → cell rowid=3"
      ptr1: "ptr[1] = 0x0F30 | → cell rowid=5"
      ptr2: "ptr[2] = 0x0EB0 | → cell rowid=7  ← NEW"
      gap: "… free space …"
      cell_new: "cell: rowid=7 | name='Alice' age=25 status='active'" {
        style: {
          stroke: "#a6e3a1"
          font-color: "#a6e3a1"
        }
      }
      cell1: "cell: rowid=5 | name='Bob'  age=30 status='active'"
      cell0: "cell: rowid=3 | name='Carol' age=22 status='inactive'"
    }
  }
}

idx_age_section: "② Index B+tree (idx_users_age)" {
  style: {
    fill: "#1e1e2e"
    stroke: "#f9e2af"
    stroke-width: 1
    border-radius: 8
    font-color: "#f9e2af"
    font-size: 12
  }
  direction: right

  before: "Before INSERT" {
    style: {
      fill: "#181825"
      stroke: "#45475a"
      border-radius: 6
      font-color: "#a6adc8"
      font-size: 11
    }
    page: "Leaf Page #9 (idx: age)" {
      shape: sql_table
      style: {
        fill: "#11111b"
        stroke: "#45475a"
        font-color: "#cdd6f4"
      }
      hdr: "Page Header (8 B) | type=0x0d  ncells=2"
      ptr0: "ptr[0] = 0x0F80 | → entry (22, rowid=3)"
      ptr1: "ptr[1] = 0x0F10 | → entry (30, rowid=5)"
      gap: "… free space …"
      cell1: "entry: age=30 | rowid=5"
      cell0: "entry: age=22 | rowid=3"
      next: "right_ptr → Page #10 | (next leaf)"
    }
  }

  after: "After INSERT" {
    style: {
      fill: "#181825"
      stroke: "#a6e3a1"
      border-radius: 6
      font-color: "#a6e3a1"
      font-size: 11
    }
    page: "Leaf Page #9 (idx: age)" {
      shape: sql_table
      style: {
        fill: "#11111b"
        stroke: "#a6e3a1"
        font-color: "#cdd6f4"
      }
      hdr: "Page Header (8 B) | type=0x0d  ncells=3"
      ptr0: "ptr[0] = 0x0F80 | → entry (22, rowid=3)"
      ptr1: "ptr[1] = 0x0F50 | → entry (25, rowid=7)  ← NEW"
      ptr2: "ptr[2] = 0x0F10 | → entry (30, rowid=5)"
      gap: "… free space …"
      cell1: "entry: age=30 | rowid=5"
      cell_new: "entry: age=25 | rowid=7" {
        style: {
          stroke: "#a6e3a1"
          font-color: "#a6e3a1"
        }
      }
      cell0: "entry: age=22 | rowid=3"
      next: "right_ptr → Page #10 | (next leaf)"
    }
  }
}

idx_status_section: "③ Index B+tree (idx_users_status)" {
  style: {
    fill: "#1e1e2e"
    stroke: "#fab387"
    stroke-width: 1
    border-radius: 8
    font-color: "#fab387"
    font-size: 12
  }
  direction: right

  before: "Before INSERT" {
    style: {
      fill: "#181825"
      stroke: "#45475a"
      border-radius: 6
      font-color: "#a6adc8"
      font-size: 11
    }
    page: "Leaf Page #14 (idx: status)" {
      shape: sql_table
      style: {
        fill: "#11111b"
        stroke: "#45475a"
        font-color: "#cdd6f4"
      }
      hdr: "Page Header (8 B) | type=0x0d  ncells=2"
      ptr0: "ptr[0] = 0x0F90 | → entry ('active',  rowid=5)"
      ptr1: "ptr[1] = 0x0F20 | → entry ('inactive',rowid=3)"
      gap: "… free space …"
      cell1: "entry: status='inactive' | rowid=3"
      cell0: "entry: status='active'   | rowid=5"
    }
  }

  after: "After INSERT" {
    style: {
      fill: "#181825"
      stroke: "#a6e3a1"
      border-radius: 6
      font-color: "#a6e3a1"
      font-size: 11
    }
    page: "Leaf Page #14 (idx: status)" {
      shape: sql_table
      style: {
        fill: "#11111b"
        stroke: "#a6e3a1"
        font-color: "#cdd6f4"
      }
      hdr: "Page Header (8 B) | type=0x0d  ncells=3"
      ptr0: "ptr[0] = 0x0F90 | → entry ('active',  rowid=5)"
      ptr1: "ptr[1] = 0x0F60 | → entry ('active',  rowid=7)  ← NEW"
      ptr2: "ptr[2] = 0x0F20 | → entry ('inactive',rowid=3)"
      gap: "… free space …"
      cell1: "entry: status='inactive' | rowid=3"
      cell_new: "entry: status='active'  | rowid=7" {
        style: {
          stroke: "#a6e3a1"
          font-color: "#a6e3a1"
        }
      }
      cell0: "entry: status='active'   | rowid=5"
    }
  }
}

trigger -> amplification: "" {
  style: {
    stroke: "#f38ba8"
    stroke-width: 2
  }
}

amplification -> table_section: "① btree_insert | rowid=7" {
  style: {
    stroke: "#89b4fa"
    stroke-width: 2
    font-color: "#89b4fa"
  }
}

amplification -> idx_age_section: "② age_insert | age=25" {
  style: {
    stroke: "#f9e2af"
    stroke-width: 2
    font-color: "#f9e2af"
  }
}

amplification -> idx_status_section: "③ status_insert | active" {
  style: {
    stroke: "#fab387"
    stroke-width: 2
    font-color: "#fab387"
  }
}

table_section.before -> table_section.after: "cell append" {
  style: {
    stroke: "#a6e3a1"
    stroke-width: 2
    stroke-dash: 3
    font-color: "#a6e3a1"
  }
}

idx_age_section.before -> idx_age_section.after: "entry insert" {
  style: {
    stroke: "#a6e3a1"
    stroke-width: 2
    stroke-dash: 3
    font-color: "#a6e3a1"
  }
}

idx_status_section.before -> idx_status_section.after: "entry insert" {
  style: {
    stroke: "#a6e3a1"
    stroke-width: 2
    stroke-dash: 3
    font-color: "#a6e3a1"
  }
}