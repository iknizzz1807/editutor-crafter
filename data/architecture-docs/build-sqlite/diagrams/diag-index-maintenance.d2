direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Index Maintenance — Write Amplification on INSERT / DELETE
  1 SQL write → 1 table B-tree write + 1 index B+tree write per index
| {near: top-center}
ins: "INSERT INTO users VALUES (4, 'Dave', 28)" {
  direction: down
  style.fill: "#f9fbe7"
  style.stroke: "#7cb342"
  style.border-radius: 8
  ins_row: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    ins_bef: "BEFORE INSERT" {
      direction: down
      style.fill: "#fafafa"
      style.stroke: "#bdbdbd"
      style.border-radius: 6
      ins_b_tbl: {
        shape: sql_table
        label: "users — Table B-tree Leaf  (btree.c)"
        r1: "rowid=1 | 'Alice' | age=25"
        r2: "rowid=2 | 'Bob'   | age=30"
        r3: "rowid=3 | 'Carol' | age=22"
        count: "3 rows  ·  ~180 B payload"
      }
      ins_b_idx: {
        shape: sql_table
        label: "idx_age — Index B+tree Leaf  (btree.c)"
        e1: "age=22 | rowid=3"
        e2: "age=25 | rowid=1"
        e3: "age=30 | rowid=2"
        count: "3 entries  ·  sorted by key"
      }
    }
    ins_aft: "AFTER INSERT" {
      direction: down
      style.fill: "#f1f8e9"
      style.stroke: "#2e7d32"
      style.border-radius: 6
      ins_a_tbl: {
        shape: sql_table
        label: "users — Table B-tree Leaf  (btree.c)"
        r1: "rowid=1 | 'Alice' | age=25"
        r2: "rowid=2 | 'Bob'   | age=30"
        r3: "rowid=3 | 'Carol' | age=22"
        r4_new: "rowid=4 | 'Dave'  | age=28  ← NEW"
        count: "4 rows  ·  btree_insert() called"
      }
      ins_a_idx: {
        shape: sql_table
        label: "idx_age — Index B+tree Leaf  (btree.c)"
        e1: "age=22 | rowid=3"
        e2: "age=25 | rowid=1"
        e3_new: "age=28 | rowid=4  ← NEW"
        e4: "age=30 | rowid=2"
        count: "4 entries  ·  index_insert() called"
      }
    }
  }
  ins_cost: "Write cost per INSERT:  1 btree_insert()  +  1 index_insert()  =  2 B-tree writes" {
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
    style.border-radius: 4
    style.font-size: 13
  }
}
ins.ins_row.ins_bef.ins_b_tbl -> ins.ins_row.ins_aft.ins_a_tbl: "btree_insert(rowid=4)" {
  style.stroke: "#2e7d32"
  style.stroke-width: 2
}
ins.ins_row.ins_bef.ins_b_idx -> ins.ins_row.ins_aft.ins_a_idx: "index_insert(age=28, rowid=4)" {
  style.stroke: "#2e7d32"
  style.stroke-width: 2
}
del: "DELETE FROM users WHERE rowid = 2  — removes Bob (age=30)" {
  direction: down
  style.fill: "#fce4ec"
  style.stroke: "#b71c1c"
  style.border-radius: 8
  del_row: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    del_bef: "BEFORE DELETE" {
      direction: down
      style.fill: "#fafafa"
      style.stroke: "#bdbdbd"
      style.border-radius: 6
      del_b_tbl: {
        shape: sql_table
        label: "users — Table B-tree Leaf  (btree.c)"
        r1: "rowid=1 | 'Alice' | age=25"
        r2_target: "rowid=2 | 'Bob'   | age=30  ← TARGET"
        r3: "rowid=3 | 'Carol' | age=22"
        r4: "rowid=4 | 'Dave'  | age=28"
        count: "4 rows  ·  btree_search(rowid=2) reads age first"
      }
      del_b_idx: {
        shape: sql_table
        label: "idx_age — Index B+tree Leaf  (btree.c)"
        e1: "age=22 | rowid=3"
        e2: "age=25 | rowid=1"
        e3: "age=28 | rowid=4"
        e4_target: "age=30 | rowid=2  ← TARGET"
        count: "4 entries  ·  seek (age=30, rowid=2)"
      }
    }
    del_aft: "AFTER DELETE" {
      direction: down
      style.fill: "#fff8e1"
      style.stroke: "#e65100"
      style.border-radius: 6
      del_a_tbl: {
        shape: sql_table
        label: "users — Table B-tree Leaf  (btree.c)"
        r1: "rowid=1 | 'Alice' | age=25"
        r3: "rowid=3 | 'Carol' | age=22"
        r4: "rowid=4 | 'Dave'  | age=28"
        count: "3 rows  ·  btree_delete_by_rowid(2)"
      }
      del_a_idx: {
        shape: sql_table
        label: "idx_age — Index B+tree Leaf  (btree.c)"
        e1: "age=22 | rowid=3"
        e2: "age=25 | rowid=1"
        e3: "age=28 | rowid=4"
        count: "3 entries  ·  index_delete(age=30, rowid=2)"
      }
    }
  }
  del_read_note: "READ FIRST: btree_search(rowid=2) fetches age=30 before any write — index key must be known to remove it" {
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.border-radius: 4
    style.font-size: 12
  }
  del_cost: "Write cost per DELETE:  1 btree_delete_by_rowid()  +  1 index_delete()  =  2 B-tree writes" {
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
    style.border-radius: 4
    style.font-size: 13
  }
}
del.del_row.del_bef.del_b_tbl -> del.del_row.del_aft.del_a_tbl: "btree_delete_by_rowid(2)" {
  style.stroke: "#b71c1c"
  style.stroke-width: 2
  style.stroke-dash: 4
}
del.del_row.del_bef.del_b_idx -> del.del_row.del_aft.del_a_idx: "index_delete(age=30, rowid=2)" {
  style.stroke: "#b71c1c"
  style.stroke-width: 2
  style.stroke-dash: 4
}
wa_summary: "Write Amplification Factor  (index_maintain.c)" {
  direction: down
  style.fill: "#ede7f6"
  style.stroke: "#4527a0"
  style.border-radius: 8
  formula: {
    shape: sql_table
    label: "Cost Model:  writes_per_dml = 1 + num_indexes"
    no_idx: "0 indexes | 1 B-tree write  ·  baseline"
    one_idx: "1 index   | 2 B-tree writes  ·  2× amplification"
    three_idx: "3 indexes | 4 B-tree writes  ·  4× amplification"
    five_idx: "5 indexes | 6 B-tree writes  ·  6× amplification"
    splits: "Page split | each insert may cascade — additional I/O per level"
    bulk_tip: "Bulk load  | DROP indexes → load → re-CREATE: 10–100× faster"
  }
}