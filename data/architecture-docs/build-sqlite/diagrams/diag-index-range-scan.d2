direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Index Range Scan — WHERE price BETWEEN 10 AND 50
  Descent to first key ≥ 10, then sequential leaf-chain traversal
| {near: top-center}
root_page: "Root Page (idx_price, page 1)" {
  shape: sql_table
  label: "INDEX INTERNAL — Root"
  style.fill: "#C7DCFF"
  style.font-color: "#1a1a2e"
  sep1: "key < 20  | → left child  | page 2"
  sep2: "key < 50  | → mid child   | page 3"
  sep3: "key ≥ 50  | → right child | page 4"
}
row_internal: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  int_left: "Internal Page 2" {
    shape: sql_table
    label: "INDEX INTERNAL"
    style.fill: "#C7DCFF"
    sep1: "key < 10  | → leaf page 10"
    sep2: "key ≥ 10  | → leaf page 11"
  }
  int_mid: "Internal Page 3" {
    shape: sql_table
    label: "INDEX INTERNAL"
    style.fill: "#C7DCFF"
    sep1: "key < 35  | → leaf page 12"
    sep2: "key ≥ 35  | → leaf page 13"
  }
  int_right: "Internal Page 4" {
    shape: sql_table
    label: "INDEX INTERNAL"
    style.fill: "#C7DCFF"
    style.opacity: 0.4
    sep1: "key ≥ 50  | → leaf page 14"
  }
}
row_leaves: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leaf_skip: "Leaf Page 10 (skipped)" {
    shape: sql_table
    label: "INDEX LEAF — page 10"
    style.fill: "#E0E0E0"
    style.font-color: "#888888"
    r1: "key=3  | rowid=201 | (< 10)"
    r2: "key=5  | rowid=89  | (< 10)"
    r3: "key=8  | rowid=155 | (< 10)"
    note: "all keys < 10 — skip"
  }
  leaf_start: "Leaf Page 11 — SCAN START" {
    shape: sql_table
    label: "INDEX LEAF — page 11  ◀ DESCENT LANDS HERE"
    style.fill: "#D4EDDA"
    style.font-color: "#155724"
    style.stroke: "#28a745"
    style.stroke-width: 3
    r1: "key=10 | rowid=42  | ✓ MATCH (first ≥ 10)"
    r2: "key=15 | rowid=77  | ✓ MATCH"
    r3: "key=18 | rowid=303 | ✓ MATCH"
    note: "next_leaf → page 12"
  }
  leaf_mid: "Leaf Page 12 — CONTINUE" {
    shape: sql_table
    label: "INDEX LEAF — page 12"
    style.fill: "#D4EDDA"
    style.font-color: "#155724"
    style.stroke: "#28a745"
    style.stroke-width: 2
    r1: "key=20 | rowid=511 | ✓ MATCH"
    r2: "key=30 | rowid=88  | ✓ MATCH"
    r3: "key=40 | rowid=201 | ✓ MATCH"
    r4: "key=50 | rowid=19  | ✓ MATCH (last ≤ 50)"
    note: "next_leaf → page 13"
  }
  leaf_stop: "Leaf Page 13 — STOP" {
    shape: sql_table
    label: "INDEX LEAF — page 13  ✗ STOP HERE"
    style.fill: "#F8D7DA"
    style.font-color: "#721c24"
    style.stroke: "#dc3545"
    style.stroke-width: 3
    r1: "key=55 | rowid=400 | ✗ STOP (55 > 50)"
    r2: "key=70 | rowid=512 | — (not read)"
    r3: "key=90 | rowid=99  | — (not read)"
    note: "scan terminates: key > 50"
  }
}
row_rowid_lookup: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  double_lookup: "Double Lookup per Match" {
    shape: sql_table
    label: "TABLE B-TREE  (products)"
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    rl1: "rowid=42  → fetch row → (price=10, name='Widget A')"
    rl2: "rowid=77  → fetch row → (price=15, name='Widget B')"
    rl3: "rowid=303 → fetch row → (price=18, name='Widget C')"
    rl4: "rowid=511 → fetch row → (price=20, name='Widget D')"
    rl5: "rowid=88  → fetch row → (price=30, name='Widget E')"
    rl6: "rowid=201 → fetch row → (price=40, name='Widget F')"
    rl7: "rowid=19  → fetch row → (price=50, name='Widget Z')"
    note: "7 total rowid lookups for 7 matching keys"
  }
}
legend: "" {
  shape: sql_table
  label: "Legend"
  style.fill: "#F8F9FA"
  l1: "Blue arrows   | B+tree descent (root → internal → leaf)"
  l2: "Green border  | Active scan path — keys in range [10, 50]"
  l3: "Green arrows  | Leaf chain traversal (next_leaf pointer)"
  l4: "Red border    | Stop condition — first key exceeding 50"
  l5: "Gray fill     | Skipped page — all keys below range start"
  l6: "Orange box    | Table heap lookup per matched rowid"
}
legend.near: bottom-right
root_page -> row_internal.int_left: "descent: price < 20 branch" {
  style.stroke: "#4a90d9"
  style.stroke-width: 2
}
root_page -> row_internal.int_mid: "not taken" {
  style.stroke: "#4a90d9"
  style.stroke-dash: 4
  style.opacity: 0.3
}
root_page -> row_internal.int_right: "not taken" {
  style.stroke: "#4a90d9"
  style.stroke-dash: 4
  style.opacity: 0.3
}
row_internal.int_left -> row_leaves.leaf_skip: "key < 10 (skip)" {
  style.stroke: "#aaaaaa"
  style.stroke-dash: 3
  style.opacity: 0.4
}
row_internal.int_left -> row_leaves.leaf_start: "key ≥ 10  ◀ taken" {
  style.stroke: "#28a745"
  style.stroke-width: 3
}
row_internal.int_mid -> row_leaves.leaf_mid: "continues scan" {
  style.stroke: "#aaaaaa"
  style.stroke-dash: 4
  style.opacity: 0.25
}
row_leaves.leaf_start -> row_leaves.leaf_mid: "next_leaf ptr  →" {
  style.stroke: "#28a745"
  style.stroke-width: 2
  style.animated: true
}
row_leaves.leaf_mid -> row_leaves.leaf_stop: "next_leaf ptr  →" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
  style.animated: true
}
row_leaves.leaf_start -> row_rowid_lookup.double_lookup: "rowids: 42, 77, 303" {
  style.stroke: "#e67e00"
  style.stroke-dash: 3
  style.stroke-width: 1
}
row_leaves.leaf_mid -> row_rowid_lookup.double_lookup: "rowids: 511, 88, 201, 19" {
  style.stroke: "#e67e00"
  style.stroke-dash: 3
  style.stroke-width: 1
}