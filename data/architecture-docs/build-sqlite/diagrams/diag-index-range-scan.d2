direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
query_ctx: "SELECT * FROM users WHERE name BETWEEN 'A' AND 'D'" {
  shape: rectangle
  style.fill: "#f0f0f5"
  style.stroke: "#9090b0"
  style.border-radius: 8
  style.font-size: 13
  style.bold: true
}
idx_tree: "INDEX B+tree  (idx_users_name)" {
  direction: down
  style.fill: "#ede8fc"
  style.stroke: "#B5AFF6"
  style.border-radius: 8
  idx_root: "Root — page 1  (INDEX_INTERNAL)" {
    shape: sql_table
    style.fill: "#B5AFF6"
    sep1: "key='D'  | left_child=7  | right_child=19"
    sep2: "key='H'  | left_child=13 | right_child=27"
  }
  idx_int: "Internal — page 7  (INDEX_INTERNAL)" {
    shape: sql_table
    style.fill: "#c8b8f8"
    sep1: "key='B'  | left_child=10"
    sep2: "key='C'  | left_child=11"
    rptr: "right_child=12"
  }
  idx_root -> idx_int: "seek 'A'" {
    style.stroke: "#6c3fc6"
    style.stroke-width: 2
  }
}
leaf_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leaf_a: "Leaf — page 10  (INDEX_LEAF)" {
    shape: sql_table
    style.fill: "#C7F1FF"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    e1: "'Alice'  | rowid=3"
    e2: "'Anna'   | rowid=7"
    e3: "'Arthur' | rowid=12"
    sib: "right_sibling → page 11"
  }
  leaf_b: "Leaf — page 11  (INDEX_LEAF)" {
    shape: sql_table
    style.fill: "#C7F1FF"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    e1: "'Bob'    | rowid=1"
    e2: "'Brenda' | rowid=9"
    e3: "'Carol'  | rowid=5"
    sib: "right_sibling → page 12"
  }
  leaf_c: "Leaf — page 12  (INDEX_LEAF)" {
    shape: sql_table
    style.fill: "#C7F1FF"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    e1: "'David'  | rowid=6"
    e2: "'Diana'  | rowid=11"
    sib: "right_sibling → page 13"
    bound: "last match: key <= 'D'"
  }
  leaf_stop: "Leaf — page 13  (INDEX_LEAF)" {
    shape: sql_table
    style.fill: "#DEE1EB"
    style.stroke: "#9E9E9E"
    e1: "'Earl'   | rowid=2"
    e2: "'Eve'    | rowid=8"
    stop: "STOP — 'Earl' > 'D'"
  }
}
leaf_row.leaf_a -> leaf_row.leaf_b: "sibling | O(1)" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.animated: true
}
leaf_row.leaf_b -> leaf_row.leaf_c: "sibling | O(1)" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.animated: true
}
leaf_row.leaf_c -> leaf_row.leaf_stop: "sibling" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 4
}
table_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tbl_p1: "Table — page 3  (TABLE_LEAF)" {
    shape: sql_table
    style.fill: "#fff8f0"
    style.stroke: "#e65100"
    r1: "rowid=1  | 'Bob'    | age=30"
    r3: "rowid=3  | 'Alice'  | age=25"
    r7: "rowid=7  | 'Anna'   | age=22"
  }
  tbl_p2: "Table — page 6  (TABLE_LEAF)" {
    shape: sql_table
    style.fill: "#fff8f0"
    style.stroke: "#e65100"
    r5: "rowid=5  | 'Carol'  | age=28"
    r6: "rowid=6  | 'David'  | age=32"
    r9: "rowid=9  | 'Brenda' | age=27"
  }
  tbl_p3: "Table — page 9  (TABLE_LEAF)" {
    shape: sql_table
    style.fill: "#fff8f0"
    style.stroke: "#e65100"
    r11: "rowid=11 | 'Diana'  | age=31"
    r12: "rowid=12 | 'Arthur' | age=29"
  }
}
query_ctx -> idx_tree: "evaluate predicate" {
  style.stroke: "#6c3fc6"
}
idx_tree -> leaf_row.leaf_a: "land on first leaf" {
  style.stroke: "#6c3fc6"
  style.stroke-width: 2
}
leaf_row.leaf_a -> table_row.tbl_p1: "rowids 3,7 | random" {
  style.stroke: "#e53935"
  style.stroke-dash: 4
}
leaf_row.leaf_a -> table_row.tbl_p3: "rowid=12 | random" {
  style.stroke: "#e53935"
  style.stroke-dash: 4
}
leaf_row.leaf_b -> table_row.tbl_p1: "rowid=1 | random" {
  style.stroke: "#e53935"
  style.stroke-dash: 4
}
leaf_row.leaf_b -> table_row.tbl_p2: "rowids 9,5 | random" {
  style.stroke: "#e53935"
  style.stroke-dash: 4
}
leaf_row.leaf_c -> table_row.tbl_p2: "rowid=6 | random" {
  style.stroke: "#e53935"
  style.stroke-dash: 4
}
leaf_row.leaf_c -> table_row.tbl_p3: "rowid=11 | random" {
  style.stroke: "#e53935"
  style.stroke-dash: 4
}
seq_note: "Sequential leaf scan: 3 page reads  O(K) where K = matching leaf pages" {
  shape: rectangle
  style.fill: "#e3f5ff"
  style.stroke: "#2196F3"
  style.border-radius: 6
  style.font-size: 12
}
rand_note: "Random table lookups: up to 7 page reads  one per distinct rowid page" {
  shape: rectangle
  style.fill: "#fff0e6"
  style.stroke: "#e65100"
  style.border-radius: 6
  style.font-size: 12
}
legend: "Color Key" {
  shape: rectangle
  style.fill: "#f9f9fb"
  style.stroke: "#cccccc"
  style.border-radius: 6
  l1: "Blue animated  — sequential leaf chain traversal"
  l2: "Red dashed     — random table B-tree lookups"
  l3: "Purple         — index tree descent  O(log N) = 2 reads"
  l4: "Gray leaf      — STOP node  key exceeds upper bound"
}
legend.near: bottom-right