direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
program: {
  shape: sql_table
  label: "VDBE Bytecode — Nested Loop JOIN: orders JOIN customers ON orders.cust_id = customers.id"
  h:   "addr | opcode     | p1    | p2  | p3  | semantics"
  i0:  "0    | OpenTable  | c=0   | 0   | 0   | cursor 0 = 'orders'    (outer relation)"
  i1:  "1    | OpenTable  | c=1   | 0   | 0   | cursor 1 = 'customers' (inner relation)"
  i2:  "2    | Rewind     | c=0   | 10  | 0   | outer: position first; empty → Halt (10)"
  i3:  "3    | Rewind     | c=1   | 9   | 0   | inner: position first; empty → outer Next (9)"
  i4:  "4    | Column     | c=0   | 2   | r1  | r1 = orders.cust_id   (outer join key)"
  i5:  "5    | Column     | c=1   | 0   | r2  | r2 = customers.id     (inner join key)"
  i6:  "6    | Ne         | r1    | 8   | r2  | r1 != r2: no match, jump 8 (skip emit)"
  i7:  "7    | ResultRow  | r3    | 4   | 0   | EMIT 4 columns — matched join pair"
  i8:  "8    | Next       | c=1   | 4   | 0   | inner advance: more rows → jump 4"
  i9:  "9    | Next       | c=0   | 3   | 0   | outer advance: more rows → jump 3"
  i10: "10   | Halt       | 0     | 0   | 0   | all pairs processed — VM stops"
}
open_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  open_outer: "addr 0: OpenTable cursor=0 (orders)" {
    style.fill: "#0d3b8e"
    style.font-color: "#90caf9"
    style.stroke: "#1565c0"
    style.stroke-width: 2
    width: 280
  }
  open_inner: "addr 1: OpenTable cursor=1 (customers)" {
    style.fill: "#0d3b8e"
    style.font-color: "#90caf9"
    style.stroke: "#1565c0"
    style.stroke-width: 2
    width: 290
  }
  open_outer -> open_inner: "PC: 0→1"
}
outer_rewind: "addr 2: Rewind  cursor=0  (orders)" {
  style.fill: "#e65100"
  style.font-color: white
  style.bold: true
  style.stroke: "#bf360c"
  style.stroke-width: 3
}
inner_loop: "INNER LOOP — cursor 1 = customers" {
  direction: down
  style.fill: "#0a1f0c"
  style.stroke: "#2ea043"
  style.stroke-width: 3
  style.border-radius: 8
  inner_rewind: "addr 3: Rewind  cursor=1  (customers)" {
    style.fill: "#2ea043"
    style.font-color: white
    style.bold: true
  }
  col_pair: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    col_a: "addr 4: Column  c=0  col=2  →  r1 = orders.cust_id" {
      style.fill: "#2d6a30"
      style.font-color: white
      style.stroke: "#4caf50"
      width: 280
    }
    col_b: "addr 5: Column  c=1  col=0  →  r2 = customers.id" {
      style.fill: "#2d6a30"
      style.font-color: white
      style.stroke: "#4caf50"
      width: 280
    }
    col_a -> col_b: "PC: 4→5"
  }
  join_cmp: "addr 6: Ne  r1  r2  —  join condition: cust_id = id ?" {
    style.fill: "#e65100"
    style.font-color: white
    style.bold: true
    style.stroke: "#ff6d00"
    style.stroke-width: 2
  }
  result_row: "addr 7: ResultRow  r3  N=4  —  EMIT MATCHED PAIR" {
    style.fill: "#4a148c"
    style.font-color: white
    style.bold: true
    style.stroke: "#ce93d8"
    style.stroke-width: 2
    style.double-border: true
  }
  inner_next: "addr 8: Next  cursor=1  (inner advance)" {
    style.fill: "#1b5e20"
    style.font-color: "#a5d6a7"
    style.bold: true
    style.stroke: "#2ea043"
    style.stroke-width: 2
  }
  inner_rewind -> col_pair: "inner positioned at first row"
  col_pair -> join_cmp: "r1 and r2 loaded into registers"
  join_cmp -> result_row: "r1 == r2  (MATCH)" {
    style.stroke: "#ce93d8"
    style.stroke-width: 2
  }
  join_cmp -> inner_next: "r1 != r2  (no match, skip emit)" {
    style.stroke-dash: 4
    style.stroke: "#ff6d00"
  }
  result_row -> inner_next: "PC: 7→8"
}
outer_next: "addr 9: Next  cursor=0  (outer advance)" {
  style.fill: "#bf360c"
  style.font-color: white
  style.bold: true
  style.stroke: "#e65100"
  style.stroke-width: 3
}
halt: "addr 10: Halt — execution complete" {
  style.fill: "#7f0000"
  style.font-color: "#ef9a9a"
  style.bold: true
  style.stroke: "#f85149"
  style.stroke-width: 3
  style.double-border: true
}
legend: {
  shape: sql_table
  label: "Color Legend"
  l1: "Blue   | OpenTable: cursor initialization phase"
  l2: "Orange | Outer loop control — cursor 0 (orders)"
  l3: "Green  | Inner loop control — cursor 1 (customers)"
  l4: "Purple | ResultRow: joined pair emitted to result set"
  l5: "Red    | Halt: VM execution terminates"
  l6: "Dashed | Loop-back jump (PC set by p2 operand)"
}
legend.near: bottom-right
open_row -> outer_rewind: "PC: 1→2"
outer_rewind -> inner_loop.inner_rewind: "outer row exists (fall-through)" {
  style.stroke: "#e65100"
  style.stroke-width: 2
}
outer_rewind -> halt: "p2=10  outer table empty" {
  style.stroke-dash: 4
  style.stroke: "#f85149"
}
inner_loop.inner_next -> outer_next: "inner exhausted (fall-through to addr 9)" {
  style.stroke: "#2ea043"
}
inner_loop.inner_next -> inner_loop.col_pair.col_a: "p2=4  more inner rows → jump back" {
  style.stroke-dash: 4
  style.stroke: "#4caf50"
  style.stroke-width: 2
}
outer_next -> inner_loop.inner_rewind: "p2=3  reset inner cursor for next outer row" {
  style.stroke-dash: 4
  style.stroke: "#e65100"
  style.stroke-width: 2
}
outer_next -> halt: "outer exhausted (fall-through to addr 10)" {
  style.stroke: "#f85149"
}