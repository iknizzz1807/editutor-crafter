direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Join Order Optimization: DP Planner Picks Smallest Intermediate Results" {
  near: top-center
  shape: rectangle
  style.font-size: 13
  style.bold: true
  style.fill: "#EBF5FB"
  style.stroke: "#2471A3"
  style.border-radius: 3
}
r1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tbl_a: {
    shape: sql_table
    label: "Table A  ·  orders"
    r_a: "100,000 rows"
    n_cust: "NDV(cust_id) = 1,000"
    n_prod: "NDV(prod_id) = 5,000"
    pg_a: "1,429 pages on disk"
  }
  tbl_b: {
    shape: sql_table
    label: "Table B  ·  customers"
    r_b1: "500 rows total"
    r_b2: "25 rows after WHERE country = 'DE'"
    n_idb: "NDV(id) = 500"
    pg_b: "8 pages on disk"
    style.fill: "#A9DFBF"
  }
  tbl_c: {
    shape: sql_table
    label: "Table C  ·  products"
    r_c: "10,000 rows"
    n_idc: "NDV(id) = 5,000"
    pg_c: "143 pages on disk"
  }
}
r2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  opt: "PLAN 1 — CHOSEN:  (B_filtered ⋈ A) ⋈ C" {
    direction: down
    style.stroke: "#1E8449"
    style.stroke-width: 3
    style.fill: "#F4FFF6"
    s1o: {
      shape: sql_table
      label: "Step 1: B_filtered ⋈ A  (apply WHERE filter first)"
      f1o: "Formula: 25 x 100,000 / max(500, 1000)"
      e1o: "= 2,500,000 / 1,000 = 2,500 rows"
      note_o: "Filtered B drives join — tiny input set"
      style.fill: "#D5F5E3"
    }
    i1o: {
      shape: sql_table
      label: "Intermediate Result AB  — SMALL"
      ir_o: "~2,500 rows"
      ip_o: "~36 pages in buffer pool"
      perf_o: "Filter-first keeps intermediate tiny"
      style.fill: "#A9DFBF"
      style.stroke: "#1E8449"
    }
    s2o: {
      shape: sql_table
      label: "Step 2: AB_intermediate ⋈ C"
      f2o: "Formula: 2,500 x 10,000 / max(1000, 5000)"
      e2o: "= 25,000,000 / 5,000 = 5,000 rows"
      style.fill: "#D5F5E3"
    }
    res_o: {
      shape: sql_table
      label: "FINAL RESULT — OPTIMAL"
      rr_o: "5,000 rows"
      rc_o: "Cost: 36 + 143 = 179 page reads"
      rv_o: "CHOSEN — minimum estimated I/O"
      style.fill: "#1E8449"
      style.font-color: "#FFFFFF"
    }
    s1o -> i1o: "2,500 rows"
    i1o -> s2o: "2,500 rows in"
    s2o -> res_o: "5,000 rows out"
  }
  sub: "PLAN 2 — REJECTED:  (A ⋈ C) ⋈ B_filtered" {
    direction: down
    style.stroke: "#C0392B"
    style.stroke-width: 3
    style.fill: "#FFF5F5"
    s1s: {
      shape: sql_table
      label: "Step 1: A ⋈ C  (no early filter!)"
      f1s: "Formula: 100,000 x 10,000 / max(5000, 5000)"
      e1s: "= 1,000,000,000 / 5,000 = 200,000 rows"
      note_s: "Full tables joined — no predicate pushdown"
      style.fill: "#FADBD8"
    }
    i1s: {
      shape: sql_table
      label: "Intermediate Result AC  — LARGE  (80x bigger!)"
      ir_s: "~200,000 rows"
      ip_s: "~2,858 pages in buffer pool"
      perf_s: "Massive intermediate thrashes buffer pool"
      style.fill: "#F1948A"
      style.stroke: "#C0392B"
    }
    s2s: {
      shape: sql_table
      label: "Step 2: AC_intermediate ⋈ B_filtered"
      f2s: "Formula: 200,000 x 25 / max(1000, 500)"
      e2s: "= 5,000,000 / 1,000 = 5,000 rows"
      style.fill: "#FADBD8"
    }
    res_s: {
      shape: sql_table
      label: "FINAL RESULT — SUBOPTIMAL"
      rr_s: "5,000 rows  (same result!)"
      rc_s: "Cost: 2,858 + 8 = 2,866 page reads"
      rv_s: "REJECTED — 16x more expensive"
      style.fill: "#C0392B"
      style.font-color: "#FFFFFF"
    }
    s1s -> i1s: "200,000 rows"
    i1s -> s2s: "200,000 rows in"
    s2s -> res_s: "5,000 rows out"
  }
}
r3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  err: {
    shape: sql_table
    label: "Cardinality Error Compounding"
    e1: "Actual B_filtered = 25 rows (correct)"
    e2: "Stale ANALYZE: estimated = 50 rows  (2x error)"
    e3: "Join 1 estimate: 50x100K/1000 = 5,000  (actual 2,500 — 2x off)"
    e4: "Join 2 estimate: 5Kx10K/5000 = 10,000  (actual 5,000 — 2x off)"
    e5: "Error multiplies at each join boundary: 2x => 4x => 8x for 3 joins"
    e6: "One stale statistic can cascade to wrong plan choice entirely"
    e7: "Fix: run ANALYZE after bulk INSERT or DELETE operations"
    style.fill: "#FEF9E7"
    style.stroke: "#F39C12"
  }
  dp: {
    shape: sql_table
    label: "DP Optimizer: cost(S) = min over all binary splits of S"
    d1: "Enumerate all subsets bottom-up  (2^n states for n tables)"
    d2: "cost({B_filt, A, C}) — try all splits:"
    d3: "  split (B_filt)+(A,C):   8 + 2,866 = 2,874 page reads"
    d4: "  split (B_filt,A)+(C):   179 + 143 =   322 page reads  WINNER"
    d5: "  split (B_filt,C)+(A):   214 + 1,429 = 1,643 page reads"
    d6: "  split (A,C)+(B_filt):  2,866 + 8  = 2,874 page reads"
    d7: "Winner: join B_filtered+A first — smallest intermediate at each step"
    style.fill: "#EBF5FB"
    style.stroke: "#2471A3"
  }
}
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: "#FDFEFE"
  style.stroke: "#BDC3C7"
  style.border-radius: 3
  label: "Green = chosen optimal plan  |  Red = rejected suboptimal plan\nFormula: rows(A join B) = rows(A) x rows(B) / max(NDV_A, NDV_B)\nCost unit = estimated page reads (disk I/O)\nNDV = Number of Distinct Values in join column"
}
r1 -> r2: "planner receives table stats"
r2 -> r3: "both plans evaluated"