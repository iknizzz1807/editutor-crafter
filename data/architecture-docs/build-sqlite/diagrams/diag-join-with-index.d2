direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
cmp: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  no_idx: "WITHOUT INDEX — O(n × m)" {
    direction: down
    style.fill: "#fff5f5"
    style.stroke: "#cc3333"
    style.stroke-width: 2
    style.border-radius: 8
    outer_a: {
      shape: sql_table
      label: "orders — outer table (join driver)"
      n_rows: "n = 100,000 rows"
      n_pages: "~1,400 leaf pages"
      scan_io: "1,400 seq reads — one-time cost"
    }
    loop_a: "INNER LOOP — runs 100,000 times" {
      style.fill: "#ffe0e0"
      style.stroke: "#cc3333"
      style.stroke-dash: 5
      style.border-radius: 4
      inner_a: {
        shape: sql_table
        label: "customers — FULL SCAN per outer row"
        m_rows: "m = 10,000 rows per scan"
        m_pages: "~140 pages per iteration"
        io_pat: "Random I/O — no spatial locality"
        iter_cost: "140 × 100,000 = 14,000,000 reads"
      }
    }
    total_a: {
      shape: sql_table
      label: "Total I/O Cost — No Index"
      outer_io: "Outer scan: 1,400 pages (sequential)"
      inner_io: "Inner scans: 14,000,000 pages (random)"
      grand: "Grand total: ~14,001,400 page reads"
      wall: "SSD at 100 μs/read ≈ 23 minutes"
      style.fill: "#ffcccc"
    }
  }
  with_idx: "WITH INDEX ON JOIN COLUMN — O(n × log m)" {
    direction: down
    style.fill: "#f5fff5"
    style.stroke: "#228822"
    style.stroke-width: 2
    style.border-radius: 8
    outer_b: {
      shape: sql_table
      label: "orders — outer table (join driver)"
      n_rows: "n = 100,000 rows"
      n_pages: "~1,400 leaf pages"
      scan_io: "1,400 seq reads — one-time cost"
    }
    loop_b: "INNER LOOP — runs 100,000 times" {
      style.fill: "#e0ffe0"
      style.stroke: "#228822"
      style.stroke-dash: 5
      style.border-radius: 4
      idx_b: {
        shape: sql_table
        label: "idx_customers_id — B+tree SEEK per outer row"
        h: "Tree height: 3 levels (fan-out ~340 keys/page)"
        l1: "L1 root: 1 I/O (hot-cached after 1st lookup)"
        l2: "L2 internal: 1 I/O (frequently cached)"
        l3: "L3 leaf: 1 I/O — rowid + heap fetch"
        iter_cost: "3 × 100,000 = 300,000 reads"
      }
    }
    total_b: {
      shape: sql_table
      label: "Total I/O Cost — With Index"
      outer_io: "Outer scan: 1,400 pages (sequential)"
      inner_io: "Index seeks: 300,000 pages (random)"
      grand: "Grand total: ~301,400 page reads"
      wall: "SSD at 100 μs/read ≈ 30 seconds"
      style.fill: "#ccffcc"
    }
  }
}
speedup: {
  shape: sql_table
  label: "JOIN PERFORMANCE COMPARISON"
  ratio: "14,001,400 ÷ 301,400 = 46× fewer page reads with index"
  time_no: "No index: ~23 minutes on NVMe SSD"
  time_yes: "With index: ~30 seconds on NVMe SSD"
  crossover: "Rule of thumb: index wins when < ~20% of inner rows match"
  formula: "O(n × m) random I/O  →  O(n × log m) seeks"
  style.fill: "#ffffcc"
  style.stroke: "#999900"
  style.stroke-width: 2
}
cmp.no_idx.outer_a -> cmp.no_idx.loop_a: "drive inner loop"
cmp.no_idx.loop_a -> cmp.no_idx.total_a: "14M page reads"
cmp.with_idx.outer_b -> cmp.with_idx.loop_b: "drive inner loop"
cmp.with_idx.loop_b -> cmp.with_idx.total_b: "300K page reads"
cmp.no_idx.total_a -> speedup: "no-index cost" {
  style.stroke: "#cc3333"
  style.stroke-width: 2
}
cmp.with_idx.total_b -> speedup: "index cost" {
  style.stroke: "#228822"
  style.stroke-width: 2
}