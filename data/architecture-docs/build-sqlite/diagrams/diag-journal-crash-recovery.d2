direction: down
title: "Crash Recovery — Before/After" {
  shape: text
  style.font-size: 22
  style.bold: true
  style.font-color: "#1e293b"
}
row: "" {
  style.fill: transparent
  style.stroke: transparent
  direction: right
  before: "BEFORE — Crash Mid-COMMIT" {
    style.fill: "#fff1f2"
    style.stroke: "#f43f5e"
    style.stroke-width: 2
    style.border-radius: 10
    direction: down
    crash_label: "⚡ Process killed between step 4 and step 5" {
      shape: text
      style.font-size: 13
      style.italic: true
      style.font-color: "#be123c"
    }
    commit_steps: "COMMIT Protocol" {
      shape: class
      "✅ Step 1": "fsync journal (original pages saved)"
      "✅ Step 2": "update DB header"
      "✅ Step 3": "flush dirty pages → database"
      "✅ Step 4": "fsync database"
      "💥 Step 5": "DELETE journal ← CRASH HERE"
    }
    commit_steps.style.fill: "#ffe4e6"
    commit_steps.style.stroke: "#f43f5e"
    commit_steps."💥 Step 5".style.font-color: "#be123c"
    db_file: "mydb.db" {
      shape: sql_table
      page_1: "page 1 — MODIFIED (new data)"
      page_7: "page 7 — MODIFIED (new data)"
      page_15: "page 15 — MODIFIED (new data)"
      free_list: "page 3 — unchanged"
    }
    db_file.style.fill: "#fecdd3"
    db_file.style.stroke: "#f43f5e"
    journal_file: "mydb.db-journal  ← HOT JOURNAL" {
      shape: sql_table
      header: "28-byte header (magic + page count)"
      rec_1: "page 1 — ORIGINAL image + checksum"
      rec_7: "page 7 — ORIGINAL image + checksum"
      rec_15: "page 15 — ORIGINAL image + checksum"
    }
    journal_file.style.fill: "#fef9c3"
    journal_file.style.stroke: "#eab308"
    journal_file.style.stroke-width: 2
    inconsistent: "⚠  Database is INCONSISTENT" {
      shape: text
      style.font-size: 13
      style.bold: true
      style.font-color: "#b45309"
    }
    atomic_check: "journal EXISTS  →  commit is INCOMPLETE" {
      shape: text
      style.font-size: 12
      style.italic: true
      style.font-color: "#7c3aed"
    }
    crash_label -> commit_steps
    commit_steps -> db_file: "dirty pages written"
    commit_steps -> journal_file: "journal fsynced\nbefore any DB write" {
      style.stroke-dash: 4
      style.stroke: "#eab308"
    }
    db_file -> inconsistent
    journal_file -> inconsistent
    inconsistent -> atomic_check
  }
  after: "AFTER — Recovery via txn_recover()" {
    style.fill: "#f0fdf4"
    style.stroke: "#22c55e"
    style.stroke-width: 2
    style.border-radius: 10
    direction: down
    open_call: "db_open(\"mydb.db\")" {
      shape: class
      "1": "call txn_recover(db)"
      "2": "check: journal file present?"
      "3": "journal found → rollback required"
    }
    open_call.style.fill: "#dcfce7"
    open_call.style.stroke: "#16a34a"
    recover_steps: "txn_recover() — Hot Journal Rollback" {
      shape: class
      "Step A": "open + validate journal header"
      "Step B": "for each record: verify checksum"
      "Step C": "seek db to page offset"
      "Step D": "write ORIGINAL page image back"
      "Step E": "fsync database file"
      "Step F": "unlink journal file"
      "Step G": "invalidate buffer pool pages"
    }
    recover_steps.style.fill: "#bbf7d0"
    recover_steps.style.stroke: "#16a34a"
    db_restored: "mydb.db  — RESTORED" {
      shape: sql_table
      page_1: "page 1 — ORIGINAL (pre-txn)"
      page_7: "page 7 — ORIGINAL (pre-txn)"
      page_15: "page 15 — ORIGINAL (pre-txn)"
      free_list: "page 3 — unchanged"
    }
    db_restored.style.fill: "#bbf7d0"
    db_restored.style.stroke: "#16a34a"
    journal_gone: "mydb.db-journal — DELETED" {
      shape: class
      "status": "file unlinked by txn_recover()"
    }
    journal_gone.style.fill: "#dcfce7"
    journal_gone.style.stroke: "#86efac"
    journal_gone.style.stroke-dash: 4
    consistent: "✅  Database is CONSISTENT\n(pre-transaction state)" {
      shape: text
      style.font-size: 13
      style.bold: true
      style.font-color: "#15803d"
    }
    atomic_check2: "journal ABSENT  →  commit is COMPLETE" {
      shape: text
      style.font-size: 12
      style.italic: true
      style.font-color: "#7c3aed"
    }
    open_call -> recover_steps: "hot journal detected"
    recover_steps -> db_restored: "original pages\nwritten back"
    recover_steps -> journal_gone: "journal deleted\nafter fsync"
    db_restored -> consistent
    journal_gone -> consistent
    consistent -> atomic_check2
  }
}
separator: "────────────────────────────────────────────────────────────────────────" {
  shape: text
  style.font-color: "#94a3b8"
  style.font-size: 11
}
invariant: "Write-Order Invariant: journal fsync → database write → journal delete" {
  shape: text
  style.font-size: 13
  style.bold: true
  style.font-color: "#4f46e5"
}
invariant2: "If journal exists at open() time → the commit was never finished → roll back unconditionally" {
  shape: text
  style.font-size: 12
  style.italic: true
  style.font-color: "#4f46e5"
}
separator -> invariant
invariant -> invariant2