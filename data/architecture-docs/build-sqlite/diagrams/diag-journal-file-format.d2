direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Rollback Journal File Format — Structure Layout {
  shape: package
  style: {
    stroke-width: 0
    fill: transparent
    font-size: 24
    bold: true
  }
}

# ── Row 1: Header and Algorithm ───────────────────────────────────────────
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  header: {
    shape: sql_table
    label: "Journal Header (journal_hdr_t)"
    col: "Offset | Size | Field | Notes"
    magic: "0x00 | 8 B | Magic Number | 0xD9D505F9 20A163D7"
    page_count: "0x08 | 4 B | Page Count | -1=Open; >=0=Committed"
    nonce: "0x0C | 4 B | Nonce | Random checksum seed"
    sector_size: "0x10 | 4 B | Sector Size | Device sector (e.g. 512)"
    page_size: "0x14 | 4 B | Page Size | DB page size (e.g. 4096)"
    reserved: "0x18 | 4 B | Reserved | Padding (Zero)"
    total: "Total: 28 bytes"
  }

  checksum_algo: {
    shape: sql_table
    label: "Checksum Algorithm (Journal Checksum)"
    col: "Step | Operation | Detail"
    s1: "1 | Seed = Nonce | Per-transaction seed"
    s2: "2 | Seed += PageNo | Incorporate page identity"
    s3: "3 | Word Loop | Iterate 4-byte words in page"
    s4: "4 | Seed += W | Big-endian word accumulation"
    s5: "5 | Finalize | Written after page_data"
  }
}

# ── Row 2: Page Records ──────────────────────────────────────────────────
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  rec1: {
    shape: sql_table
    label: "Page Record 1"
    col: "Offset | Size | Field | Notes"
    page_no: "0x1C | 4 B | Page Number | 1-based DB index"
    page_data: "0x20 | 4096 B | Original Page | Data before modification"
    checksum: "0x1020 | 4 B | Checksum | Sum(nonce, page_no, data)"
  }

  rec2: {
    shape: sql_table
    label: "Page Record 2"
    col: "Offset | Size | Field | Notes"
    page_no: "0x1024 | 4 B | Page Number | Next modified index"
    page_data: "0x1028 | 4096 B | Original Page | Data before modification"
    checksum: "0x2028 | 4 B | Checksum | Independent checksum"
  }

  ellipsis: {
    label: "... N records total"
    shape: step
    style.italic: true
  }
}

# ── Row 3: Lifecycle and Recovery ────────────────────────────────────────
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  lifecycle: {
    shape: sql_table
    label: "Write-Order Lifecycle"
    col: "Step | Action | Safety Invariant"
    l1: "1 | Header (count=-1) | Mark journal as open"
    l2: "2 | Append Records | Capture original data"
    l3: "3 | fsync journal | MUST complete before step 4"
    l4: "4 | Modify DB Pages | Journal covers undo path"
    l5: "5 | Header (count>=0) | Commit transaction in journal"
    l6: "6 | fsync & delete | DB now consistent"
  }

  recovery: {
    shape: sql_table
    label: "Crash Recovery (pager.c)"
    col: "Trigger | Recovery Action"
    r1: "Journal Exists | Validate magic number"
    r2: "page_count == -1 | Restore all valid records"
    r3: "page_count >= 0 | Restore exactly page_count"
    r4: "Checksum Fail | Stop replay (Partial Rollback)"
    r5: "Finished | Delete journal file"
  }
}

# ── Connections ───────────────────────────────────────────────────────────
row1.header -> row2.rec1: "28 B | offset"
row2.rec1 -> row2.rec2: "sequential"
row2.rec2 -> row2.ellipsis: "sequential"

row2.rec1 -> row1.checksum_algo: "validates" {
  style.stroke-dash: 4
}

row3.lifecycle -> row1.header: "updates" {
  style.stroke: "#059669"
}

row3.lifecycle -> row3.recovery: "triggers" {
  style.stroke: "#dc2626"
  style.stroke-dash: 4
}

# ── Styles ────────────────────────────────────────────────────────────────
row1.header.style: {
  fill: "#dbeafe"
  stroke: "#2563eb"
  stroke-width: 2
}
row2.rec1.style: {
  fill: "#dcfce7"
  stroke: "#16a34a"
  stroke-width: 2
}
row2.rec2.style: {
  fill: "#dcfce7"
  stroke: "#16a34a"
  stroke-width: 2
}
row1.checksum_algo.style: {
  fill: "#f3e8ff"
  stroke: "#7c3aed"
  stroke-width: 2
}
row3.lifecycle.style: {
  fill: "#f0fdf4"
  stroke: "#059669"
  stroke-width: 2
}
row3.recovery.style: {
  fill: "#fff1f2"
  stroke: "#dc2626"
  stroke-width: 2
}