direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# Transaction State Machine (pager.c)
# -----------------------------------------------------------------------------

row_states: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  idle: {
    label: "IDLE_STATE"
    style: {
      fill: "#E8F5E9"
      stroke: "#43A047"
      stroke-width: 2
      border-radius: 10
    }
    
    marker: TXN_STATE_NONE {
      shape: oval
      label: "TXN_STATE_NONE"
      style: {
        fill: "#A5D6A7"
        stroke: "#2E7D32"
        bold: true
      }
    }

    ops: {
      shape: sql_table
      label: "Valid Operations (pager.h)"
      begin_op: "BEGIN | acquire PAGER_SHARED lock"
      select_op: "SELECT | read-only, no journal"
      dml_auto: "DML | implicit BEGIN + PAGER_RESERVED"
      commit_err: "COMMIT | ERR: No transaction"
      rollback_err: "ROLLBACK | ERR: No transaction"
    }
  }

  active: {
    label: "ACTIVE_STATE"
    style: {
      fill: "#E3F2FD"
      stroke: "#1E88E5"
      stroke-width: 2
      border-radius: 10
    }

    marker: TXN_STATE_ACTIVE {
      shape: oval
      label: "TXN_STATE_ACTIVE"
      style: {
        fill: "#90CAF9"
        stroke: "#1565C0"
        bold: true
      }
    }

    ops: {
      shape: sql_table
      label: "Valid Operations (pager.h)"
      dml_op: "DML | write page to journal, then modify"
      select_op: "SELECT | reads from buffer pool/journal"
      commit_op: "COMMIT | flush pool + fsync + unlink"
      rollback_op: "ROLLBACK | restore from journal + fsync"
      begin_err: "BEGIN | ERR: Nesting not allowed"
      sync_rule: "Write-Ahead | Journal MUST fsync first"
    }
  }

  hot: {
    label: "HOT_JOURNAL_RECOVERY"
    style: {
      fill: "#FFEBEE"
      stroke: "#E53935"
      stroke-width: 2
      border-radius: 10
    }

    marker: RECOVERY_REQUIRED {
      shape: oval
      label: "HOT_JOURNAL_DETECTED"
      style: {
        fill: "#EF9A9A"
        stroke: "#B71C1C"
        bold: true
      }
    }

    # Renamed from 'steps' to avoid D2 keyword conflict
    recovery_flow: {
      shape: sql_table
      label: "Recovery Algorithm (txn_recover)"
      s1: "0x00 | magic | 0xd9d505f920a163d7"
      s2: "0x08 | nonce | verify 32-bit txn id"
      s3: "0x0C | restore | restore_from_journal()"
      s4: "0x?? | verify | checksum per-page frame"
      s5: "0x?? | write | pwrite() to database file"
      s6: "0x?? | sync | fsync(db_fd) durable"
      s7: "0x?? | clean | unlink(.db-journal)"
      block: "BLOCK | All concurrent reads blocked"
    }
  }
}

# Commitment Protocol Details
# -----------------------------------------------------------------------------

commit_protocol: {
  shape: sql_table
  label: "Commit Write Ordering (pager_commit)"
  step1: "1: flush_dirty_pages() | Buffer -> OS"
  step2: "2: fsync(db_fd) | OS Cache -> Disk"
  step3: "3: unlink(journal) | Atomic deletion"
  step4: "4: unlock(LOCK_UN) | Release file lock"
  recovery_note: "CRASH before Step 3 | HOT_JOURNAL trigger"
}

# State Transitions
# -----------------------------------------------------------------------------

row_states.idle -> row_states.active: "BEGIN | acquire SHARED" {
  style: {
    stroke: "#43A047"
    stroke-width: 2
    bold: true
  }
}

row_states.active -> row_states.idle: "COMMIT | Success" {
  style: {
    stroke: "#1E88E5"
    stroke-width: 2
    bold: true
  }
}

row_states.active -> row_states.idle: "ROLLBACK | Restore pages" {
  style: {
    stroke: "#FB8C00"
    stroke-width: 2
    stroke-dash: 4
  }
}

row_states.active -> row_states.hot: "CRASH | Kill/Power loss" {
  style: {
    stroke: "#E53935"
    stroke-width: 3
    stroke-dash: 4
    animated: true
  }
}

row_states.hot -> row_states.idle: "RECOVER | db_open()" {
  style: {
    stroke: "#8E24AA"
    stroke-width: 2
    bold: true
  }
}

row_states.active -> commit_protocol: "Invoke COMMIT" {
  style: {
    stroke: "#546E7A"
    stroke-dash: 3
    opacity: 0.6
  }
}