direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
header: "Rollback Journal — Write Ordering & Crash Safety" {
  shape: rectangle
  style.fill: "#1A237E"
  style.font-color: white
  style.font-size: 15
  style.bold: true
  style.border-radius: 4
  width: 820
}
invariant: "INVARIANT: Journal entry must reach physical disk BEFORE any DB page is modified" {
  shape: rectangle
  style.fill: "#B71C1C"
  style.font-color: white
  style.font-size: 12
  style.bold: true
  style.border-radius: 4
  width: 820
}
r1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op1: "① BEGIN Transaction" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 3
    style.bold: true
    style.border-radius: 8
    width: 310
    lock: "Acquire write lock (flock LOCK_EX)" {
      style.fill: "#BBDEFB"
      style.font-size: 11
    }
    jstate: "journal_fd = -1  (lazy: no file yet)" {
      style.fill: "#BBDEFB"
      style.font-size: 11
      style.font: mono
    }
    pgcnt: "Record page_count for rollback sizing" {
      style.fill: "#BBDEFB"
      style.font-size: 11
    }
  }
  c1: "⚡ Crash at ①" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-dash: 5
    style.border-radius: 6
    width: 380
    db1: "DB File: UNCHANGED — zero writes issued" {
      style.fill: "#FCE4EC"
      style.font-size: 11
    }
    j1: "Journal: DOES NOT EXIST" {
      style.fill: "#FCE4EC"
      style.font-size: 11
    }
    rec1: "✓ SAFE — No journal found on restart\nDB is already consistent, nothing to undo" {
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.font-size: 11
      style.bold: true
    }
  }
}
r2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op2: "② pwrite(journal_fd, original_page, 4096, offset)" {
    shape: rectangle
    style.fill: "#E8EAF6"
    style.stroke: "#3949AB"
    style.stroke-width: 2
    style.border-radius: 8
    width: 310
    fmt: "[page_no: 4B] [data: 4096B] [checksum: 4B]" {
      style.fill: "#C5CAE9"
      style.font-size: 10
      style.font: mono
    }
    jnote: "Creates journal file on first write\nWrites to OS page cache (not yet durable)" {
      style.fill: "#C5CAE9"
      style.font-size: 11
    }
  }
  c2: "⚡ Crash at ② (mid-journal-write)" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-dash: 5
    style.border-radius: 6
    width: 380
    db2: "DB File: UNCHANGED — write never reached DB" {
      style.fill: "#FCE4EC"
      style.font-size: 11
    }
    j2: "Journal: PARTIAL — checksum validation fails" {
      style.fill: "#FCE4EC"
      style.font-size: 11
    }
    rec2: "✓ SAFE — Invalid journal discarded on restart\nDB was never touched; no restore needed" {
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.font-size: 11
      style.bold: true
    }
  }
}
r3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op3: "③ fsync(journal_fd)  ← CRITICAL BARRIER" {
    shape: rectangle
    style.fill: "#1A237E"
    style.font-color: white
    style.stroke: "#0D47A1"
    style.stroke-width: 3
    style.bold: true
    style.border-radius: 8
    width: 310
    dur3: "Original page is now PHYSICALLY DURABLE\non the storage medium" {
      style.fill: "#283593"
      style.font-color: white
      style.font-size: 11
      style.bold: true
    }
    gate3: "DB file write is FORBIDDEN until this returns" {
      style.fill: "#283593"
      style.font-color: white
      style.font-size: 11
    }
  }
  c3: "⚡ Crash at ③ (after fsync returns)" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-dash: 5
    style.border-radius: 6
    width: 380
    db3: "DB File: UNCHANGED — no DB write yet issued" {
      style.fill: "#FCE4EC"
      style.font-size: 11
    }
    j3: "Journal: VALID and PHYSICALLY DURABLE" {
      style.fill: "#FFF9C4"
      style.stroke: "#F57F17"
      style.font-size: 11
      style.bold: true
    }
    rec3: "✓ SAFE — Restore from journal (effective no-op)\nDB page matches original; journal deleted" {
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.font-size: 11
      style.bold: true
    }
  }
}
r4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op4: "④ pwrite(db_fd, modified_page, 4096, page_offset)" {
    shape: rectangle
    style.fill: "#E8EAF6"
    style.stroke: "#3949AB"
    style.stroke-width: 2
    style.border-radius: 8
    width: 310
    where4: "Overwrites page at correct file offset in DB" {
      style.fill: "#C5CAE9"
      style.font-size: 11
    }
    risk4: "TORN PAGE risk: sector size < page size" {
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.font-size: 11
    }
  }
  c4: "⚡ Crash at ④ (torn page possible)" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-dash: 5
    style.border-radius: 6
    width: 380
    db4: "DB File: TORN PAGE\n(first sectors new, last sectors old)" {
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.font-size: 11
      style.bold: true
    }
    j4: "Journal: VALID and PHYSICALLY DURABLE" {
      style.fill: "#FFF9C4"
      style.stroke: "#F57F17"
      style.font-size: 11
      style.bold: true
    }
    rec4: "✓ SAFE — Restore from journal\npwrite(original_page) → torn page overwritten" {
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.font-size: 11
      style.bold: true
    }
  }
}
r5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op5: "⑤ fsync(db_fd)  ← SECOND BARRIER" {
    shape: rectangle
    style.fill: "#1A237E"
    style.font-color: white
    style.stroke: "#0D47A1"
    style.stroke-width: 3
    style.bold: true
    style.border-radius: 8
    width: 310
    dur5: "Modified page is now PHYSICALLY DURABLE\non the storage medium" {
      style.fill: "#283593"
      style.font-color: white
      style.font-size: 11
      style.bold: true
    }
    gate5: "Journal deletion FORBIDDEN until this returns" {
      style.fill: "#283593"
      style.font-color: white
      style.font-size: 11
    }
  }
  c5: "⚡ Crash at ⑤ (after fsync returns)" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-dash: 5
    style.border-radius: 6
    width: 380
    db5: "DB File: Modified page DURABLE on disk" {
      style.fill: "#FFF9C4"
      style.stroke: "#F57F17"
      style.font-size: 11
    }
    j5: "Journal: VALID, DURABLE, still exists" {
      style.fill: "#FFF9C4"
      style.stroke: "#F57F17"
      style.font-size: 11
    }
    rec5: "✓ SAFE — Journal found; restore original\nTx rolls back (user never saw COMMIT return)" {
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.font-size: 11
      style.bold: true
    }
  }
}
r6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op6: "⑥ unlink(journal_path)  → COMMITTED" {
    shape: rectangle
    style.fill: "#1B5E20"
    style.font-color: white
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    style.bold: true
    style.border-radius: 8
    width: 310
    atomic6: "Atomic filesystem op (unlink is atomic)" {
      style.fill: "#2E7D32"
      style.font-color: white
      style.font-size: 11
    }
    meaning6: "No journal = COMMITTED\nJournal exists = INCOMPLETE" {
      style.fill: "#2E7D32"
      style.font-color: white
      style.font-size: 11
      style.bold: true
    }
  }
  c6: "After ⑥ — Fully Committed" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
    style.border-radius: 6
    width: 380
    db6: "DB File: Modified page DURABLE and CURRENT" {
      style.fill: "#C8E6C9"
      style.font-size: 11
    }
    j6: "Journal: DELETED (commit point passed)" {
      style.fill: "#C8E6C9"
      style.font-size: 11
    }
    rec6: "✓ DURABLE — Transaction fully committed\nNo recovery action on restart" {
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
      style.font-size: 11
      style.bold: true
    }
  }
}
inv_note: "The two fsync barriers (③ and ⑤) enforce write ordering.\nWithout ③: DB could be written before journal is durable — crash loses undo info — CORRUPT.\nWithout ⑤: Journal could be deleted before DB write is durable — data silently lost after COMMIT." {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#F9A825"
  style.stroke-width: 2
  style.font-size: 11
  style.border-radius: 4
  width: 820
}
r1.op1 -> r2.op2: "page dirty"
r2.op2 -> r3.op3: "written to cache"
r3.op3 -> r4.op4: "BARRIER ③ — journal durable" {
  style.stroke: "#1A237E"
  style.stroke-width: 3
  style.bold: true
}
r4.op4 -> r5.op5: "written to cache"
r5.op5 -> r6.op6: "BARRIER ⑤ — DB page durable" {
  style.stroke: "#1A237E"
  style.stroke-width: 3
  style.bold: true
}
r1.op1 -> r1.c1: "⚡" {
  style.stroke-dash: 5
  style.stroke: "#C62828"
  style.stroke-width: 2
}
r2.op2 -> r2.c2: "⚡" {
  style.stroke-dash: 5
  style.stroke: "#C62828"
  style.stroke-width: 2
}
r3.op3 -> r3.c3: "⚡" {
  style.stroke-dash: 5
  style.stroke: "#C62828"
  style.stroke-width: 2
}
r4.op4 -> r4.c4: "⚡" {
  style.stroke-dash: 5
  style.stroke: "#C62828"
  style.stroke-width: 2
}
r5.op5 -> r5.c5: "⚡" {
  style.stroke-dash: 5
  style.stroke: "#C62828"
  style.stroke-width: 2
}
r6.op6 -> r6.c6: "✓" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}