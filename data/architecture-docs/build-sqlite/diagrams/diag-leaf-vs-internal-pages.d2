direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Leaf Page vs Internal Page Structure {
  style.font-size: 24
  style.bold: true
  style.fill: transparent
  style.stroke: transparent
}
pages: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leaf: Table B-Tree Leaf Page (type 0x0D) {
    direction: down
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.border-radius: 8
    header: {
      shape: sql_table
      label: "Page Header (8 bytes)"
      f0: "0x00 | uint8_t  | page_type = 0x0D (leaf)"
      f1: "0x01 | uint16_t | first_freeblock"
      f2: "0x03 | uint16_t | cell_count = 3"
      f3: "0x05 | uint16_t | cell_content_start"
      f4: "0x07 | uint8_t  | fragmented_bytes"
      note: "No right_child field (leaf has no children)"
    }
    ptrs: {
      shape: sql_table
      label: "Cell Pointer Array (2 bytes each, sorted by rowid)"
      p0: "0x08 | uint16_t | cell_ptr[0] → offset 3842"
      p1: "0x0A | uint16_t | cell_ptr[1] → offset 3720"
      p2: "0x0C | uint16_t | cell_ptr[2] → offset 3590"
      grows: "Array grows DOWNWARD as cells are added"
    }
    free: Free Space {
      style.fill: "#E0E0E0"
      style.stroke: "#9E9E9E"
      style.font-color: "#757575"
      style.font-size: 14
      width: 300
      height: 80
    }
    cell2: {
      shape: sql_table
      label: "Cell 2 (at offset 3590)"
      c0: "varint | payload_size = 42"
      c1: "varint | rowid = 3"
      c2: "--- Record Header ---"
      c3: "varint | header_size = 5"
      c4: "varint | serial_type = 4 (int32)"
      c5: "varint | serial_type = 23 (text len 5)"
      c6: "--- Record Body ---"
      c7: "4 bytes | id = 3 (big-endian int32)"
      c8: "5 bytes | name = 'Carol' (raw text)"
    }
    cell1: {
      shape: sql_table
      label: "Cell 1 (at offset 3720)"
      c0: "varint | payload_size = 42"
      c1: "varint | rowid = 2"
      c2: "--- Record ---"
      c3: "4 bytes | id = 2"
      c4: "3 bytes | name = 'Bob'"
    }
    cell0: {
      shape: sql_table
      label: "Cell 0 (at offset 3842)"
      c0: "varint | payload_size = 44"
      c1: "varint | rowid = 1"
      c2: "--- Record ---"
      c3: "4 bytes | id = 1"
      c4: "5 bytes | name = 'Alice'"
    }
    header -> ptrs
    ptrs -> free
    free -> cell2
    cell2 -> cell1
    cell1 -> cell0
  }
  internal: Table B-Tree Internal Page (type 0x05) {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.border-radius: 8
    header: {
      shape: sql_table
      label: "Page Header (12 bytes)"
      f0: "0x00 | uint8_t  | page_type = 0x05 (internal)"
      f1: "0x01 | uint16_t | first_freeblock"
      f2: "0x03 | uint16_t | cell_count = 2"
      f3: "0x05 | uint16_t | cell_content_start"
      f4: "0x07 | uint8_t  | fragmented_bytes"
      f5: "0x08 | uint32_t | right_child = page 7"
      note: "4 extra bytes for right_child pointer"
    }
    ptrs: {
      shape: sql_table
      label: "Cell Pointer Array (2 bytes each, sorted by separator key)"
      p0: "0x0C | uint16_t | cell_ptr[0] → offset 4080"
      p1: "0x0E | uint16_t | cell_ptr[1] → offset 4068"
      grows: "Array grows DOWNWARD"
    }
    free: Free Space {
      style.fill: "#E0E0E0"
      style.stroke: "#9E9E9E"
      style.font-color: "#757575"
      style.font-size: 14
      width: 300
      height: 120
    }
    cell1: {
      shape: sql_table
      label: "Cell 1 (at offset 4068)"
      c0: "uint32_t | left_child = page 5 (BE)"
      c1: "varint   | separator rowid = 200"
      sz: "Total: ~8 bytes (no row data!)"
    }
    cell0: {
      shape: sql_table
      label: "Cell 0 (at offset 4080)"
      c0: "uint32_t | left_child = page 3 (BE)"
      c1: "varint   | separator rowid = 100"
      sz: "Total: ~6 bytes (no row data!)"
    }
    header -> ptrs
    ptrs -> free
    free -> cell1
    cell1 -> cell0
  }
}
routing: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  routing_title: Routing Logic for Internal Page {
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.border-radius: 8
    logic: {
      shape: sql_table
      label: "Search Decision Tree"
      r0: "if rowid <= 100 | follow cell[0].left_child → page 3"
      r1: "if 100 < rowid <= 200 | follow cell[1].left_child → page 5"
      r2: "if rowid > 200 | follow header.right_child → page 7"
      r3: "--- Key Insight ---"
      r4: "Internal cells carry ONLY separator keys + child pointers"
      r5: "No row data means higher fanout (more keys per page)"
    }
  }
}
tree: Resulting B-Tree Structure {
  direction: down
  style.fill: "#FAFAFA"
  style.stroke: "#616161"
  style.border-radius: 8
  root: Internal Page {
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
    style.font-size: 14
    content: |md
      sep: 100, 200
      children: [pg3, pg5, pg7]
    |
  }
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    pg3: Leaf (page 3) {
      style.fill: "#BBDEFB"
      style.stroke: "#2196F3"
      style.font-size: 13
      content: |md
        rowid 1: (1, 'Alice')
        rowid 50: (50, 'Dave')
        rowid 100: (100, 'Eve')
      |
    }
    pg5: Leaf (page 5) {
      style.fill: "#BBDEFB"
      style.stroke: "#2196F3"
      style.font-size: 13
      content: |md
        rowid 101: (101, 'Frank')
        rowid 150: (150, 'Grace')
        rowid 200: (200, 'Hank')
      |
    }
    pg7: Leaf (page 7) {
      style.fill: "#BBDEFB"
      style.stroke: "#2196F3"
      style.font-size: 13
      content: |md
        rowid 201: (201, 'Iris')
        rowid 300: (300, 'Jack')
        rowid 500: (500, 'Kate')
      |
    }
  }
  root -> row1.pg3: "rowid <= 100" {
    style.stroke: "#4CAF50"
    style.font-color: "#4CAF50"
    style.bold: true
  }
  root -> row1.pg5: "100 < rowid <= 200" {
    style.stroke: "#FF9800"
    style.font-color: "#FF9800"
    style.bold: true
  }
  root -> row1.pg7: "rowid > 200" {
    style.stroke: "#F44336"
    style.font-color: "#F44336"
    style.bold: true
  }
}
comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leaf_summary: Leaf Cell Anatomy {
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.border-radius: 6
    detail: {
      shape: sql_table
      label: "Leaf Cell = Key + Full Row"
      r0: "payload_size | varint (total record bytes)"
      r1: "rowid | varint (B-tree sort key)"
      r2: "record_header | serial types for each column"
      r3: "record_body | column values (variable length)"
      r4: "--- Typical Size ---"
      r5: "~50-200 bytes per cell (depends on row width)"
      r6: "~40-80 cells per 4096-byte page"
    }
  }
  internal_summary: Internal Cell Anatomy {
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
    style.border-radius: 6
    detail: {
      shape: sql_table
      label: "Internal Cell = Key + Child Pointer"
      r0: "left_child | uint32_t (4 bytes, page number)"
      r1: "rowid | varint (separator key)"
      r2: "--- That is ALL ---"
      r3: "No payload_size, no record, no row data"
      r4: "--- Typical Size ---"
      r5: "~6-12 bytes per cell"
      r6: "~340-680 cells per 4096-byte page (HIGH FANOUT)"
    }
  }
  fanout: Fanout Impact {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.border-radius: 6
    detail: {
      shape: sql_table
      label: "Why Internal Pages Are Small"
      r0: "Leaf: 70 rows/page | tree height for 1M rows = 5"
      r1: "Internal: 340 keys/page | 340^2 = 115K in 2 levels"
      r2: "Internal: 340 keys/page | 340^3 = 39M in 3 levels"
      r3: "--- Result ---"
      r4: "3 page reads to find any row among 39 million"
      r5: "Each page read = one buffer pool fetch (~10ns hit)"
    }
  }
}
pages -> routing: "type flag 0x0D vs 0x05 controls interpretation"
routing -> tree: "internal pages route searches to correct leaf"
tree -> comparison: "cell format determines fanout and tree height"