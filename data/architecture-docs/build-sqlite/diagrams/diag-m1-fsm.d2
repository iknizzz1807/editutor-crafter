direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
# State Machine Title
title: |md
  # SQL Tokenizer Finite State Machine
| {near: top-center}
# Legend
legend: {
  near: bottom-right
  style.fill: transparent
  style.stroke: transparent
  start_style: {
    shape: circle
    style.fill: "#90EE90"
    label: "Start State"
  }
  process_style: {
    shape: rectangle
    style.fill: "#87CEEB"
    label: "Processing State"
  }
  end_style: {
    shape: circle
    style.fill: "#FFB6C1"
    label: "End/Emit State"
  }
}
# Main state flow
tokenizer_fsm: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # START state
  START: {
    shape: circle
    style.fill: "#90EE90"
    style.bold: true
    label: "START"
  }
  # Identifier/Keyword path
  IDENTIFIER: {
    shape: rectangle
    style.fill: "#87CEEB"
    label: "IDENTIFIER\n(letter/underscore)"
    +is_letter: "bool"
    +is_digit: "bool"
    +is_underscore: "bool"
    +lookup_keyword: "KeywordType"
  }
  # String literal path
  STRING: {
    shape: rectangle
    style.fill: "#DDA0DD"
    label: "STRING\n(single quote)"
    +handle_quote: "'' → '"
    +handle_newline: "error"
    +handle_eof: "error"
  }
  # Double-quoted identifier
  DOUBLE_QUOTE: {
    shape: rectangle
    style.fill: "#DDA0DD"
    label: "QUOTED_ID\n(double quote)"
    +handle_quote: '"" → "'
    +handle_newline: "error"
  }
  # Number path
  NUMBER: {
    shape: rectangle
    style.fill: "#F0E68C"
    label: "NUMBER\n(digit)"
    +is_hex: "0x prefix"
    +is_float: ". detected"
    +is_sci_notation: "e/E detected"
  }
  # Operator path
  OPERATOR: {
    shape: rectangle
    style.fill: "#FFA07A"
    label: "OPERATOR"
    +check_two_char: "lookahead"
    +check_three_char: "lookahead"
  }
  # Punctuation
  PUNCTUATION: {
    shape: rectangle
    style.fill: "#ADD8E6"
    label: "PUNCTUATION\n(){},;.!"
  }
  # END state
  END: {
    shape: circle
    style.fill: "#FFB6C1"
    style.bold: true
    label: "EMIT TOKEN"
  }
  # Transitions
  START -> IDENTIFIER: "a-z, A-Z, _"
  START -> STRING: "'"
  START -> DOUBLE_QUOTE: '"'
  START -> NUMBER: "0-9"
  START -> OPERATOR: "= < > ! + - * / % & | ^ ~"
  START -> PUNCTUATION: "( ) , ; ."
  START -> END: "EOF"
  IDENTIFIER -> IDENTIFIER: "letter/digit/_"
  IDENTIFIER -> END: "whitespace/operator"
  STRING -> STRING: "content"
  STRING -> STRING: "'' → ' (escaped)"
  STRING -> END: "' (closing)"
  DOUBLE_QUOTE -> DOUBLE_QUOTE: "content"
  DOUBLE_QUOTE -> DOUBLE_QUOTE: '"" → " (escaped)'
  DOUBLE_QUOTE -> END: '" (closing)'
  NUMBER -> NUMBER: "digit"
  NUMBER -> NUMBER: ". (float)"
  NUMBER -> NUMBER: "e/E (sci)"
  NUMBER -> NUMBER: "x/X (hex)"
  NUMBER -> END: "non-digit"
  OPERATOR -> OPERATOR: "= after < > !"
  OPERATOR -> END: "complete"
  PUNCTUATION -> END: "emit"
}
# Detailed state explanation
explanation: "" {
  near: bottom-left
  style.fill: transparent
  style.stroke: transparent
  notes: |md
    ## Key Rules:
    1. **Case insensitive**: keywords matched case-insensitively
    2. **Escaped quotes**: '' becomes ', "" becomes "
    3. **Multi-char operators**: <=, >=, !=, <>
    4. **Hex numbers**: 0xFF format
    5. **Scientific notation**: 1e10, 1.5e-3
  |
}