direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "SQL Token Type Taxonomy" {
  near: top-center
}
tokens: Tokens {
  style.fill: "#E8F4FD"
  style.stroke: "#1E88E5"
  style.stroke-width: 3
  keywords: Keywords {
    style.fill: "#E1F5FE"
    style.stroke: "#039BE5"
    dml: DML {
      label: "DML (Data Manipulation)"
      SELECT: "SELECT, INSERT, UPDATE, DELETE"
      INSERT: ""
      UPDATE: ""
      DELETE: ""
    }
    ddl: DDL {
      label: "DDL (Data Definition)"
      CREATE: "CREATE, DROP, ALTER"
      DROP: ""
      ALTER: ""
    }
    other: Other {
      label: "Other Keywords"
      FROM: "FROM, WHERE, JOIN"
      WHERE: ""
      JOIN: ""
      AND: ""
      OR: ""
      ORDER: ""
      BY: ""
      GROUP: ""
      HAVING: ""
    }
  }
  identifiers: Identifiers {
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
    unquoted: Unquoted {
      label: "Unquoted"
      style.fill: "#C8E6C9"
      example: "users, table_name, col1"
      rules: "[a-zA-Z_][a-zA-Z0-9_]*"
    }
    quoted: Quoted {
      label: "Quoted (Double Quotes)"
      style.fill: "#A5D6A7"
      example: "\"my table\", \"column-name\""
      rules: "Double quotes preserve case/spaces"
    }
  }
  literals: Literals {
    style.fill: "#FFF3E0"
    style.stroke: "#FB8C00"
    string: String {
      label: "String Literal"
      style.fill: "#FFE0B2"
      example: "'hello world', 'it''s'"
      syntax: "'...''...'"
    }
    integer: Integer {
      label: "Integer"
      style.fill: "#FFCC80"
      example: "42, -7, 0xFF"
      base: "Decimal, Hexadecimal"
    }
    float: Float {
      label: "Floating Point"
      style.fill: "#FFB74D"
      example: "3.14, 1e10, -2.5e-3"
      notation: "Scientific notation supported"
    }
    blob: Blob {
      label: "BLOB"
      style.fill: "#FFA726"
      example: "X'0123456789ABCDEF'"
      format: "Hexadecimal in single quotes"
    }
  }
  operators: Operators {
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    comparison: Comparison {
      label: "Comparison"
      style.fill: "#F8BBD0"
      eq: "= (equals)"
      ne: "<>, != (not equal)"
      lt: "< (less than)"
      gt: "> (greater than)"
      le: "<= (less or equal)"
      ge: ">= (greater or equal)"
    }
    logical: Logical {
      label: "Logical"
      style.fill: "#F48FB1"
      AND: "AND"
      OR: "OR"
      NOT: "NOT"
    }
    arithmetic: Arithmetic {
      label: "Arithmetic"
      style.fill: "#F06292"
      plus: "+ (add)"
      minus: "- (subtract)"
      mul: "* (multiply)"
      div: "/ (divide)"
      mod: "% (modulo)"
    }
    bitwise: Bitwise {
      label: "Bitwise"
      style.fill: "#EC407A"
      shift: "<<, >> (shift)"
      and: "& (bitwise AND)"
      or: "| (bitwise OR)"
    }
  }
  punctuation: Punctuation {
    style.fill: "#F3E5F5"
    style.stroke: "#8E24AA"
    parens: Parentheses {
      label: "Parentheses"
      style.fill: "#E1BEE7"
      lparen: "( - opening"
      rparen: ") - closing"
    }
    separators: Separators {
      label: "Separators"
      style.fill: "#CE93D8"
      comma: ", (comma)"
      semicolon: "; (semicolon)"
      dot: ". (dot)"
    }
  }
  special: Special {
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    wildcard: Wildcard {
      label: "Wildcard"
      style.fill: "#CFD8DC"
      star: "* (all columns)"
    }
    eof: EOF {
      label: "End of Input"
      style.fill: "#B0BEC5"
      end: "<EOF> - end of token stream"
    }
  }
}
# Connections showing hierarchy
tokens.keywords -> tokens.identifiers: "Token Stream"
tokens.identifiers -> tokens.literals: "Classification"
tokens.literals -> tokens.operators: "Parser Input"
tokens.operators -> tokens.punctuation: "Valid SQL"
tokens.punctuation -> tokens.special: "AST Nodes"
# Legend
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: gray
  style.stroke-dash: 3
  kw: Keywords {
    shape: text
    style.font-color: "#039BE5"
  }
  id: Identifiers {
    shape: text
    style.font-color: "#43A047"
  }
  lit: Literals {
    shape: text
    style.font-color: "#FB8C00"
  }
  op: Operators {
    shape: text
    style.font-color: "#E91E63"
  }
  pun: Punctuation {
    shape: text
    style.font-color: "#8E24AA"
  }
}