direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # WAL Checkpoint Process (SQLite Implementation)
| {near: top-center}

# --- PRIMARY WORKFLOW LAYER ---
checkpoint_logic: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1_lock: "1. Acquire Exclusive Lock" {
    shape: rectangle
    style.fill: "#FFE0F5"
    style.stroke: "#7939A8"
    width: 220
    height: 100
    note: "sqlite3WalCheckpoint(PASSIVE)"
  }

  step2_find: "2. Find Last Committed" {
    shape: rectangle
    style.fill: "#E1F5FE"
    style.stroke: "#0277BD"
    width: 220
    height: 100
    note: "Scan WAL-Index for mxFrame"
  }

  step3_copy: "3. Copy to Main DB" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    width: 220
    height: 100
    note: "Sequential Page Migration"
  }

  step4_truncate: "4. Truncate / Reset" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    width: 220
    height: 100
    note: "Zero frame count in header"
  }

  step5_release: "5. Release Lock" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 220
    height: 100
    note: "Allow New Writers"
  }

  step1_lock -> step2_find: "Exclusive Access"
  step2_find -> step3_copy: "Map Frames"
  step3_copy -> step4_truncate: "Sync Complete"
  step4_truncate -> step5_release: "Cleanup"
}

# --- PERSISTENCE LAYER ---
storage_layer: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  wal_file: {
    shape: sql_table
    label: "WAL File (journal.wal)"
    header: "0x00 | WAL Header (24 bytes)"
    f1: "0x18 | Frame 1 | Data + Header"
    f2: "0x.. | Frame 2 | Data + Header"
    fn: "0x.. | Frame N | Last Committed"
    total: "Threshold: 1000 frames"
  }

  db_file: {
    shape: sql_table
    label: "Main Database (db.sqlite)"
    p1: "Page 1 | B-Tree Root"
    p2: "Page 2 | Internal Node"
    p3: "Page 3 | Leaf Data"
    state: "Status: PERSISTENT"
  }
}

# --- CONTROL LOGIC ---
trigger_system: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  auto_checkpoint: {
    label: "Auto-Checkpoint Trigger"
    threshold: "Frame Count >= 1000" {
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      style.stroke-dash: 3
    }
    counter: "WAL Write Counter" {
      style.fill: "#FFECB3"
      style.stroke: "#FF8F00"
    }
  }

  buffer_pool: {
    label: "Pager / Buffer Pool"
    dirty_pages: "Dirty Page List"
    cache: "LRU Cache"
    style.fill: "#FFF8E1"
    style.stroke: "#F9A825"
  }
}

# --- SYSTEM WIRING ---

# Data Flow during Checkpoint
storage_layer.wal_file -> checkpoint_logic.step2_find: "Read mxFrame"
checkpoint_logic.step3_copy -> storage_layer.db_file: "PWRITE Page Data"
trigger_system.buffer_pool -> storage_layer.db_file: "fsync() barrier"

# Trigger Flow
trigger_system.auto_checkpoint.counter -> trigger_system.auto_checkpoint.threshold: "eval"
trigger_system.auto_checkpoint.threshold -> checkpoint_logic.step1_lock: "Invoke Checkpoint"

# Legend
legend: {
  near: bottom-right
  style.fill: "#f9f9f9"
  style.stroke: "#cccccc"
  
  l1: "Exclusive Lock" { style.fill: "#FFE0F5" }
  l2: "Read Operation" { style.fill: "#E1F5FE" }
  l3: "Write Operation" { style.fill: "#E8F5E9" }
  l4: "State Reset" { style.fill: "#FFF3E0" }
}

# Formatting Connections
checkpoint_logic -> storage_layer: "I/O Pipeline" {
  style.stroke-width: 2
}

storage_layer -> trigger_system: "Monitoring" {
  style.stroke-dash: 5
}