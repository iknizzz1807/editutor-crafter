direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# WAL Snapshot Isolation - Reader/Writer Concurrency
title: "WAL Snapshot Isolation: Readers Never Block Writers (sqlite3.c)" {
  shape: text
  style.font-size: 28
  style.bold: true
}

# Row 1: Timeline representation
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    label: "Execution Timeline"
    shape: rectangle
    style.fill: "#E8E8E8"
    style.font-size: 16
    style.bold: true
    t0: "T0" {shape: text}
    t1: "T1" {shape: text}
    t2: "T2" {shape: text}
    t3: "T3" {shape: text}
    t4: "T4" {shape: text}
    t5: "T5" {shape: text}
    t6: "T6" {shape: text}
    t0 -> t1: "Reader A starts\n(captures mxWalFrame)"
    t1 -> t2: "Writer modifies\n(appends frames)"
    t2 -> t3: "Writer commits\n(updates wal-index)"
    t3 -> t4: "Reader A reads\n(uses old snapshot)"
    t4 -> t5: "Writer modifies\n(appends more)"
    t5 -> t6: "Reader A consistency\n(sees same old data)"
  }
}

# Row 2: Key components - WAL structure
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  wal_structure: {
    shape: sql_table
    label: "WAL File Structure (wal.h)"
    header: "0x00 | WAL_HEADER | magic, salt, chksum"
    f100: "0x20 | FRAME_100   | Page 42 (Version A)"
    f101: "0x420| FRAME_101   | Page 17 (Version B)"
    f102: "0x820| FRAME_102   | Page 23 (Version B)"
    f103: "0xC20| FRAME_103   | Page 42 (Version B)"
    f104: "0x1020| FRAME_104  | Page 99 (Version B)"
    f105: "0x1420| FRAME_105  | COMMIT marker"
    total: "Total WAL Size: 5184 bytes"
  }

  frame_states: {
    label: "Frame Metadata"
    shape: sql_table
    committed_100: "Frame 100 | Committed (Pre-Snapshot)"
    committed_101: "Frame 101 | Committed (Writer Local)"
    committed_102: "Frame 102 | Committed (Writer Local)"
    committed_103: "Frame 103 | Committed (Writer Local)"
    committed_104: "Frame 104 | Committed (Writer Local)"
    committed_105: "Frame 105 | WAL_COMMIT"
  }
}

# Row 3: Reader snapshot and access
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  reader_a: {
    label: "Reader A Context (pager.c)"
    shape: class
    -mxWalFrame: "uint32_t = 100"
    -pSnapshot: "WalSnapshot*"
    -iTable: "int = 0"
    +get_snapshot(pWal): "int"
    +find_frame(pgno): "u32"
  }

  reader_view: {
    label: "Reader A's Isolation View"
    shape: sql_table
    sees_100: "Page 42 | Maps to Frame 100 (Ver A)"
    sees_42: "Page 42 | Ignore Frame 103 (ID > 100)"
    sees_17: "Page 17 | Read from DB (not in WAL snapshot)"
    not_sees: "Isolation Guard | mxWalFrame Filter Active"
  }

  writer: {
    label: "Writer Context (wal.c)"
    shape: class
    -iCurrentFrame: "uint32_t = 105"
    -pWriteLock: "WalLock*"
    -syncFlags: "u8"
    +append_frame(pPage): "int"
    +commit(pWal): "int"
  }
}

# Row 4: Snapshot isolation rules
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  rules: {
    label: "Snapshot Isolation Rules"
    shape: sql_table
    r1: "Rule 1 | FrameID <= Snapshot -> Reader sees frame"
    r2: "Rule 2 | FrameID > Snapshot -> Reader ignores frame"
    r3: "Rule 3 | Commit Marker -> Signals valid txn in WAL"
    r4: "Rule 4 | No Blocking -> Readers use SHM-lock for snapshots"
  }

  comparison: {
    label: "Rollback Journal vs WAL (Concurrency)"
    shape: sql_table
    rb: "Rollback Journal | Readers BLOCKED during write"
    wal: "WAL Mode | Readers CONCURRENT with writer"
    rb_ex: "Rollback Journal | Exclusive PENDING/RESERVED lock"
    wal_iso: "WAL Mode | Snapshot isolation (Read-Uncommitted opt)"
  }
}

# Row 5: Key insight
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  insight: {
    label: "Implementation Insight"
    shape: rectangle
    style.fill: "#E0F2F1"
    style.stroke: "#009688"
    style.stroke-width: 3
    style.font-size: 16
    style.bold: true
    text1: "1. Reader captures mxWalFrame=100 from SHM file header"
    text2: "2. Writer appends frames 101-105 to WAL file and updates SHM"
    text3: "3. Reader searches SHM for pgno, ignoring any FrameID > 100"
    text4: "4. Result: Reader gets atomic, consistent view without locking writer"
    text1.style.fill: "#B2DFDB"
    text2.style.fill: "#B2DFDB"
    text3.style.fill: "#80CBC4"
    text4.style.fill: "#4DB6AC"
  }
}

# Arrows connecting components
row1 -> row2: "WAL contains frames in sequential order"
row2 -> row3: "FindPage: check if frame <= snapshot"
row3 -> row4: "Snapshot Filter: (Frame <= 100)"
row4 -> row5: "Ensures repeatable reads"

# Global Styles
*: {
  style.font-size: 12
}

# Cleanup container strokes
row1: { style.stroke: transparent }
row2: { style.stroke: transparent }
row3: { style.stroke: transparent }
row4: { style.stroke: transparent }
row5: { style.stroke: transparent }