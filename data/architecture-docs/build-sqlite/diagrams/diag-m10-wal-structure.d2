direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
wal_file_overview: "WAL File Format (Append-Only Log)" {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 3
  header_note: |md
    WAL = Write-Ahead Logging
    Append-only: frames written sequentially
    Frames checkpointed to main .db on checkpoint
  |
}
# WAL File Header
wal_file_header: "WAL File Header (32 bytes)" {
  shape: sql_table
  label: "WAL File Header"
  magic: "0x00-0x03 | uint32 | magic: 0x377f0682"
  page_size: "0x04-0x07 | uint32 | page_size: 4096"
  checkpoint_seq: "0x08-0x0B | uint32 | checkpoint sequence"
  salt_1: "0x0C-0x0F | uint32 | random salt for checksum"
  salt_2: "0x10-0x13 | uint32 | second salt"
  checksum_1: "0x14-0x17 | uint32 | header checksum"
  checksum_2: "0x18-0x1B | uint32 | header checksum"
  frame_count: "0x1C-0x1F | uint32 | frames in WAL"
  header_total: "Total: 32 bytes"
}
# Single WAL Frame
wal_frame: "WAL Frame (4132 bytes)" {
  shape: sql_table
  label: "Single WAL Frame"
  page_number: "0x0000-0x0003 | uint32 | database page number"
  commit_frame: "0x0004-0x0007 | uint32 | 1 if commits txn"
  frame_size: "0x0008-0x000B | uint32 | page size (4096)"
  salt_1: "0x000C-0x000F | uint32 | salt for checksum"
  salt_2: "0x0010-0x0013 | uint32 | second salt"
  checksum_1: "0x0014-0x0017 | uint32 | frame checksum"
  checksum_2: "0x0018-0x001B | uint32 | frame checksum"
  page_data_start: "0x001C-0x101B | uint8[4096] | page content"
  frame_total: "Frame Total: 4132 bytes"
}
# Commit Frame Indicator
commit_indicator: "Commit Frame" {
  shape: sql_table
  label: "Transaction Commit Marker"
  description: "Special frame indicating committed transaction"
  frame_header: "commit_frame = 1 (at offset 0x04)"
  checksum_1: "0x0014-0x0017 | uint32 | valid checksum"
  checksum_2: "0x0018-0x001B | uint32 | valid checksum"
  page_content: "0x001C-0x101B | (not written)"
  note: "Tells readers: all prior frames committed"
}
# Frame Sequence
frame_sequence: "WAL Frame Sequence (Append-Only)" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  frame_1: "Frame 1: Page 42" {
    shape: rectangle
    style.fill: "#FFCC80"
    label: "Page 42 | Modified Data"
  }
  frame_2: "Frame 2: Page 17" {
    shape: rectangle
    style.fill: "#FFCC80"
    label: "Page 17 | Modified Data"
  }
  frame_3: "Frame N: Page X" {
    shape: rectangle
    style.fill: "#FFCC80"
    label: "Page X | Modified Data"
  }
  commit_frame: "Commit Frame" {
    shape: rectangle
    style.fill: "#81C784"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    label: "COMMIT | commit_frame=1"
  }
  frame_1 -> frame_2: "append"
  frame_2 -> frame_3: "append"
  frame_3 -> commit_frame: "append"
}
# Checkpoint Operation
checkpoint_op: "Checkpoint Operation" {
  shape: sql_table
  label: "Checkpoint Flow"
  step1: "1. Read frames from WAL sequentially"
  step2: "2. Verify checksums (skip corrupt)"
  step3: "3. Write pages to main .db at correct offsets"
  step4: "4. fsync main database"
  step5: "5. Truncate WAL (or start new WAL)"
  result: "WAL cleared, .db updated"
}
# Key Differences
key_diffs: "Key Format Differences" {
  shape: sql_table
  label: "Regular vs Commit Frame"
  regular_frame: "Regular Frame | commit_frame = 0"
  commit_frame: "Commit Frame | commit_frame = 1"
  checksum: "Both have: valid checksum in header"
  page_content: "Commit frame may skip writing page (marker only)"
}
# Connections
wal_file_header -> wal_frame: "Each frame is 4132 bytes"
wal_frame -> frame_sequence: "Sequential frames"
commit_indicator -> frame_sequence: "commit_frame flag"
frame_sequence -> checkpoint_op: "On checkpoint"
checkpoint_op -> key_diffs: "Format rules"