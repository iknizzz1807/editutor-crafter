direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "NULL Handling in SQL Aggregates" {
  near: top-center
  style.font-size: 28
  style.bold: true
}
# Main comparison table
null_handling_table: {
  shape: sql_table
  label: "Aggregate NULL Handling Summary"
  behavior: "Includes NULL?"
  count_star: "✓ YES"
  count_col: "✗ NO (ignores NULLs)"
  sum: "✗ NO (ignores NULLs)"
  avg: "✗ NO (ignores NULLs)"
  min: "✗ NO (ignores NULLs)"
  max: "✗ NO (ignores NULLs)"
  empty_result: "Empty Table Result"
  count_star_empty: "0"
  count_col_empty: "0"
  sum_empty: "NULL"
  avg_empty: "NULL"
  min_empty: "NULL"
  max_empty: "NULL"
}
# COUNT examples
count_examples: {
  label: "COUNT Examples"
  shape: sql_table
  input: "Input Values"
  result: "Result"
  explanation: "Explanation"
  count_star_ex: "[1, 2, NULL, 4, NULL]"
  count_star_result: "5"
  count_star_expl: "COUNT(*) includes NULLs"
  count_col_ex: "[1, 2, NULL, 4, NULL]"
  count_col_result: "3"
  count_col_expl: "COUNT(col) ignores NULLs"
}
# SUM examples
sum_examples: {
  label: "SUM Examples"  
  shape: sql_table
  input: "Input Values"
  result: "Result"
  explanation: "Explanation"
  sum_ex: "[1, 2, NULL, 4]"
  sum_result: "7"
  sum_expl: "1 + 2 + 4 = 7 (NULL ignored)"
  sum_all_null: "[NULL, NULL, NULL]"
  sum_all_null_result: "NULL"
  sum_all_null_expl: "All NULL → returns NULL"
}
# AVG examples
avg_examples: {
  label: "AVG Examples"
  shape: sql_table
  input: "Input Values"
  result: "Result"
  explanation: "Explanation"
  avg_ex: "[1, 2, NULL, 4]"
  avg_result: "2.333"
  avg_expl: "(1+2+4)/3 = 7/3 (NULL ignored, counts 3)"
  avg_all_null: "[NULL, NULL, NULL]"
  avg_all_null_result: "NULL"
  avg_all_null_expl: "All NULL → returns NULL"
}
# Key rules box
key_rules: {
  label: "Key SQL Rules"
  shape: rectangle
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  rule1: "COUNT(*) counts EVERY row"
  rule2: "COUNT(col) ignores NULLs"
  rule3: "SUM/AVG ignore NULLs entirely"
  rule4: "All NULLs → SUM/AVG return NULL"
  rule5: "Empty table → COUNT=0, others=NULL"
}
# Visual representation of NULL ignoring
visual: {
  label: "NULL is NOT Zero"
  shape: rectangle
  style.fill: "#F8D7DA"
  style.stroke: "#721C24"
  example: "| 1 | 2 | NULL | 4 |"
  equals: "SUM = 1 + 2 + 4 = 7"
  not: "≠ 1 + 2 + 0 + 4 = 7 (wrong!)"
}
# Arrow connections
null_handling_table.count_star -> count_examples.count_star_ex: "Examples"
null_handling_table.sum -> sum_examples.sum_ex: "Examples"
null_handling_table.avg -> avg_examples.avg_result: "Examples"
key_rules -> visual: "Visual" {
  style.stroke-dash: 3
}