direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Statement (abstract base)
statement: {
  shape: sql_table
  label: "Statement (ast.h)"
  f0: "ASTNodeType | type"
  f1: "int         | line"
  f2: "int         | column"
}
# Statement -> SelectStatement
statement -> select: ""
# Statement -> InsertStatement
statement -> insert: ""
# Statement -> CreateTableStatement  
statement -> create: ""
# SelectStatement
select: {
  shape: sql_table
  label: "SelectStatement"
  f0: "ColumnRef[]   | columns"
  f1: "int          | column_count"
  f2: "char*        | table_name"
  f3: "Expression*  | where_clause"
  f4: "OrderByItem* | order_by"
  f5: "int          | order_by_count"
  f6: "Expression*  | limit"
}
# InsertStatement
insert: {
  shape: sql_table
  label: "InsertStatement"
  f0: "char*    | table_name"
  f1: "char**   | column_names"
  f2: "int      | column_count"
  f3: "Expr**   | values"
  f4: "int      | value_row_count"
  f5: "int      | values_per_row"
}
# CreateTableStatement
create: {
  shape: sql_table
  label: "CreateTableStatement"
  f0: "char*     | table_name"
  f1: "ColumnDef*| columns"
  f2: "int       | column_count"
}
# Expression types - grouped separately
expression_group: {
  direction: right
  # Expression (base)
  expression: {
    shape: sql_table
    label: "Expression"
    f0: "ASTNodeType | type"
    f1: "int        | line"
    f2: "int        | column"
  }
  expression -> binary: ""
  expression -> unary: ""
  expression -> literal: ""
  expression -> identifier: ""
  # BinaryExpression
  binary: {
    shape: sql_table
    label: "BinaryExpression"
    f0: "BinaryOperator | op"
    f1: "Expression*    | left"
    f2: "Expression*    | right"
  }
  # UnaryExpression
  unary: {
    shape: sql_table
    label: "UnaryExpression"
    f0: "UnaryOperator | op"
    f1: "Expression*   | operand"
  }
  # Literal
  literal: {
    shape: sql_table
    label: "LiteralValue"
    f0: "DataType    | type"
    f1: "union        | value"
    f2: "int64_t     | integer_value"
    f3: "double      | float_value"
    f4: "char*       | string_value"
  }
  # Identifier / ColumnRef
  identifier: {
    shape: sql_table
    label: "ColumnRef"
    f0: "char* | name"
    f1: "bool  | is_wildcard"
  }
}
# Supporting types
supporting: {
  direction: right
  # ColumnRef
  columnref: {
    shape: sql_table
    label: "ColumnRef"
    f0: "char* | name"
    f1: "bool  | is_wildcard"
  }
  # OrderByItem
  orderby: {
    shape: sql_table
    label: "OrderByItem"
    f0: "Expression*    | expr"
    f1: "OrderDirection | direction"
  }
  # ColumnDef
  coldef: {
    shape: sql_table
    label: "ColumnDef"
    f0: "char*             | name"
    f1: "DataType          | type"
    f2: "ColumnConstraint  | constraints"
  }
}
# Connect supporting types to statements
select -> columnref: "columns[]"
select -> orderby: "order_by[]"
create -> coldef: "columns[]"