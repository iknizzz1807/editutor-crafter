direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "SQL Operator Precedence Climbing" {
  near: top-center
  shape: text
  style.font-size: 28
}

# Input expression container
row_input: {
  style.stroke: transparent
  style.fill: transparent
  input_expr: "a = 1 AND b = 2 OR c = 3" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2
  }
}

# Logic mapping row
row_logic: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  precedence_levels: {
    direction: down
    label: "Precedence Levels"
    level_or: "Level 4: OR (lowest)" {
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      style.stroke-width: 2
    }
    level_and: "Level 3: AND" {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.stroke-width: 2
    }
    level_compare: "Level 2: Comparison" {
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
      style.stroke-width: 2
    }
    level_not: "Level 1: NOT (highest)" {
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#D32F2F"
      style.stroke-width: 2
    }
  }

  parser_functions: {
    direction: down
    label: "Recursive Descent Implementation"
    parse_or_fn: "parse_or() handles OR" {
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
    }
    parse_and_fn: "parse_and() handles AND" {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
    }
    parse_compare_fn: "parse_comparison() handles comparison" {
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
    }
    parse_unary_fn: "parse_unary() handles NOT" {
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#D32F2F"
    }
  }
}

# Mapping relationships
precedence_levels.level_or -> parser_functions.parse_or_fn: "lowest"
precedence_levels.level_and -> parser_functions.parse_and_fn
precedence_levels.level_compare -> parser_functions.parse_compare_fn
precedence_levels.level_not -> parser_functions.parse_unary_fn: "highest"

# Execution flow row
row_flow: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: "1. parse_or() calls parse_and()" {
    shape: step
    style.fill: "#F3E5F5"
    width: 220
  }
  step2: "2. parse_and() calls parse_comparison()" {
    shape: step
    style.fill: "#E8F5E9"
    width: 220
  }
  step3: "3. parse_comparison() parses: a=1" {
    shape: step
    style.fill: "#FFF3E0"
    width: 220
  }
  step4: "4. Return AND result (a=1 AND b=2)" {
    shape: step
    style.fill: "#E8F5E9"
    width: 220
  }
  step5: "5. Return OR result (unit OR c=3)" {
    shape: step
    style.fill: "#F3E5F5"
    width: 220
  }
  step1 -> step2 -> step3 -> step4 -> step5: "Parsing sequence"
}

# Result visualization row
row_result: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ast_tree: {
    label: "Resulting AST (Abstract Syntax Tree)"
    or_node: "OR" {
      shape: circle
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      style.stroke-width: 2
    }
    and_node: "AND" {
      shape: circle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.stroke-width: 2
    }
    leaf_a: "a = 1" {
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
    }
    leaf_b: "b = 2" {
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
    }
    leaf_c: "c = 3" {
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
    }

    or_node -> and_node: "left child"
    or_node -> leaf_c: "right child"
    and_node -> leaf_a: "left child"
    and_node -> leaf_b: "right child"
  }

  grouping_result: {
    label: "Evaluated Result"
    correct_grouping: "(a = 1 AND b = 2) OR c = 3" {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.stroke-width: 3
      style.font-size: 18
      style.bold: true
    }
  }
}

# Insights
insight: |md
  ### Precedence Rule
  1. **AND** binds tighter than **OR**.
  2. The parser climbs down the recursive tree.
  3. `parse_or` waits for `parse_and` to return.
  4. Resulting grouping: `(a=1 AND b=2) OR c=3`
| {
  shape: callout
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  width: 350
}
insight.near: bottom-right

# Simple Legend
legend: {
  direction: right
  style.stroke: "#CCCCCC"
  label: "Legend"
  or_c: "OR Level" { style.fill: "#F3E5F5" }
  and_c: "AND Level" { style.fill: "#E8F5E9" }
  cmp_c: "Compare" { style.fill: "#FFF3E0" }
}
legend.near: bottom-left

row_input -> row_logic: "Input"
row_logic -> row_flow: "Analysis"
row_flow -> row_result: "Construction"