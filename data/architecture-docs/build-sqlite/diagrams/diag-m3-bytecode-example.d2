direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SELECT Bytecode Trace
  **Query:** `SELECT * FROM t WHERE id = 1`
|
# Bytecode Sequence Row
bytecode_flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Step 1
  step1: "1" {
    shape: step
    label: "OpenTable"
    detail: |c
      OpenTable(0, "t")
    |
  }
  arrow1: step1 -> step2 {
    label: "cursor=0"
  }
  # Step 2
  step2: "2" {
    shape: step
    label: "Rewind"
    detail: |c
      Rewind(0)
    |
  }
  arrow2: step2 -> step3 {
    label: "goto row 0"
  }
  # Step 3
  step3: "3" {
    shape: step
    label: "Column"
    detail: |c
      Column(0, 0, 1)
      # cursor=0, col=0, reg=1
    |
  }
  arrow3: step3 -> step4 {
    label: "load id"
  }
  # Step 4
  step4: "4" {
    shape: step
    label: "Integer"
    detail: |c
      Integer(1, 2)
      # value=1, reg=2
    |
  }
  arrow4: step4 -> step5 {
    label: "const=1"
  }
  # Step 5
  step5: "5" {
    shape: step
    label: "Eq"
    detail: |c
      Eq(reg1, reg2, reg3)
      # id == 1?
    |
  }
  arrow5: step5 -> step6 {
    label: "result"
  }
  # Step 6
  step6: "6" {
    shape: step
    label: "IfNot"
    detail: |c
      IfNot(reg3, -4)
      # skip if false
    |
  }
  arrow6: step6 -> step7 {
    label: "false→loop"
  }
  # Step 7
  step7: "7" {
    shape: step
    label: "ResultRow"
    detail: |c
      ResultRow(reg1, 1)
      # output register 1
    |
  }
  arrow7: step7 -> step8 {
    label: "emit"
  }
  # Step 8
  step8: "8" {
    shape: step
    label: "Next"
    detail: |c
      Next(0, -7)
      # cursor 0, jump to step 1
    |
  }
  arrow8: step8 -> step9 {
    label: "next row"
  }
  # Step 9
  step9: "9" {
    shape: step
    label: "Halt"
    detail: |c
      Halt(0, 0, 0)
    |
  }
}
# Register State Table
register_state: "Register State at Each Step" {
  shape: sql_table
  label: "Execution Register State"
  step: "Step"
  pc: "PC"
  opcode: "Opcode"
  reg0: "R0"
  reg1: "R1 (id)"
  reg2: "R2 (const)"
  reg3: "R3 (result)"
  r4: "R4"
  row0: "0 | 0 | OpenTable | - | - | - | - | -"
  row1: "1 | 1 | Rewind | - | - | - | - | -"
  row2: "2 | 2 | Column | - | @id=5 | - | - | -"
  row3: "3 | 3 | Integer | - | 5 | 1 | - | -"
  row4: "4 | 4 | Eq | - | 5 | 1 | true | -"
  row5: "5 | 5 | IfNot | - | 5 | 1 | true | -"
  row6: "6 | 6 | ResultRow | - | 5 | 1 | true | -"
  row7: "7 | 7 | Next | - | 5 | 1 | true | -"
  row8: "8 | 8 | Halt | - | - | - | - | -"
}
# Legend
legend: "Legend" {
  near: bottom-center
  shape: sql_table
  label: "Color Semantics"
  green: "Green = True / Match"
  red: "Red = False / No Match"
  blue: "Blue = Data Flow"
  yellow: "Yellow = Conditional"
  lbl1: "PC = Program Counter"
  lbl2: "R0-R4 = Virtual Registers"
  lbl3: "@id = Memory reference"
}