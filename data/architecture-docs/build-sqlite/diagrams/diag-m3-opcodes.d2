direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: VDBE Opcode Categories | operand format: p1, p2, p3
# Cursor Operations - Table/Index Navigation
cursor_ops: {
  label: "Cursor Operations"
  style.fill: "#E3F2FD"
  OpenTable: {
    shape: sql_table
    label: "OP_OpenTable"
    p1: "cursor_id | int"
    p2: "flags | int"
    p3: "table_name | string"
    desc: "Open cursor to table B-tree"
  }
  OpenWrite: {
    shape: sql_table
    label: "OP_OpenWrite"
    p1: "cursor_id | int"
    p3: "table_name | string"
    desc: "Open cursor for writes"
  }
  Rewind: {
    shape: sql_table
    label: "OP_Rewind"
    p1: "cursor_id | int"
    p2: "target_addr | addr"
    desc: "Position cursor at first row"
  }
  Next: {
    shape: sql_table
    label: "OP_Next"
    p1: "cursor_id | int"
    p2: "target_addr | addr"
    desc: "Advance to next row"
  }
  Close: {
    shape: sql_table
    label: "OP_Close"
    p1: "cursor_id | int"
    desc: "Close cursor"
  }
}
# Record Operations - Row Data
record_ops: {
  label: "Record Operations"
  style.fill: "#FFF3E0"
  Column: {
    shape: sql_table
    label: "OP_Column"
    p1: "cursor_id | int"
    p2: "column_idx | int"
    p3: "dest_reg | reg"
    desc: "Load column into register"
  }
  MakeRecord: {
    shape: sql_table
    label: "OP_MakeRecord"
    p1: "reg_start | reg"
    p2: "col_count | int"
    p3: "dest_reg | reg"
    desc: "Serialize values to record"
  }
  ResultRow: {
    shape: sql_table
    label: "OP_ResultRow"
    p1: "reg_start | reg"
    p2: "col_count | int"
    desc: "Emit result row"
  }
  Insert: {
    shape: sql_table
    label: "OP_Insert"
    p1: "cursor_id | int"
    p3: "record_reg | reg"
    desc: "Insert record into table"
  }
}
# Control Flow - Program Flow
control_ops: {
  label: "Control Flow"
  style.fill: "#E8F5E9"
  Goto: {
    shape: sql_table
    label: "OP_Goto"
    p1: "target_addr | addr"
    desc: "Unconditional jump"
  }
  If: {
    shape: sql_table
    label: "OP_If"
    p1: "condition_reg | reg"
    p2: "target_addr | addr"
    desc: "Branch if true"
  }
  IfNot: {
    shape: sql_table
    label: "OP_IfNot"
    p1: "condition_reg | reg"
    p2: "target_addr | addr"
    desc: "Branch if false"
  }
  Halt: {
    shape: sql_table
    label: "OP_Halt"
    p1: "err_code | int"
    p2: "err_type | int"
    desc: "Stop execution"
  }
}
# Comparison Operations - Boolean Logic
comparison_ops: {
  label: "Comparison Operations"
  style.fill: "#FCE4EC"
  Eq: {
    shape: sql_table
    label: "OP_Eq"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left == right"
  }
  Ne: {
    shape: sql_table
    label: "OP_Ne"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left != right"
  }
  Lt: {
    shape: sql_table
    label: "OP_Lt"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left < right"
  }
  Le: {
    shape: sql_table
    label: "OP_Le"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left <= right"
  }
  Gt: {
    shape: sql_table
    label: "OP_Gt"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left > right"
  }
  Ge: {
    shape: sql_table
    label: "OP_Ge"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left >= right"
  }
  And: {
    shape: sql_table
    label: "OP_And"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left AND right"
  }
  Or: {
    shape: sql_table
    label: "OP_Or"
    p1: "left_reg | reg"
    p2: "right_reg | reg"
    p3: "dest_reg | reg"
    desc: "left OR right"
  }
  Not: {
    shape: sql_table
    label: "OP_Not"
    p1: "src_reg | reg"
    p3: "dest_reg | reg"
    desc: "NOT src"
  }
}
# Aggregation - GROUP BY
aggregation_ops: {
  label: "Aggregation"
  style.fill: "#F3E5F5"
  AggStep: {
    shape: sql_table
    label: "OP_AggStep"
    p1: "agg_reg | reg"
    p2: "col_count | int"
    p3: "func_ptr | *func"
    desc: "Process agg function"
  }
  AggFinal: {
    shape: sql_table
    label: "OP_AggFinal"
    p1: "agg_reg | reg"
    p2: "col_count | int"
    desc: "Finalize aggregates"
  }
  AggInit: {
    shape: sql_table
    label: "OP_AggInit"
    p1: "agg_reg | reg"
    desc: "Initialize aggregator"
  }
}
# Constant Operations - Immediate Values
constant_ops: {
  label: "Constants"
  style.fill: "#FFFDE7"
  Integer: {
    shape: sql_table
    label: "OP_Integer"
    p1: "value | int64"
    p3: "dest_reg | reg"
    desc: "Load integer constant"
  }
  String: {
    shape: sql_table
    label: "OP_String"
    p1: "value | int"
    p3: "dest_reg | reg"
    desc: "Load string constant"
  }
  Null: {
    shape: sql_table
    label: "OP_Null"
    p1: "type | int"
    p3: "dest_reg | reg"
    desc: "Load NULL value"
  }
}
# Legend
legend: {
  label: "Operand Types"
  near: bottom-right
  style.fill: "#ECEFF1"
  int: "Integer value"
  addr: "Jump target address"
  reg: "Register number"
  string: "String pointer"
  "*func": "Function pointer"
}
cursor_ops -> record_ops: "read/write"
record_ops -> control_ops: "flow"
control_ops -> comparison_ops: "evaluate"
comparison_ops -> aggregation_ops: "group"
aggregation_ops -> constant_ops: "values"