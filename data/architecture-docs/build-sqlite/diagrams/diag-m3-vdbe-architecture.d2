direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "VDBE Architecture (Virtual Database Engine)" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}
# Main execution loop
vdbe_loop: "VDBE Execution Loop" {
  direction: right
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  pc: "Program Counter\n(PC Register)" {
    shape: class
    style.fill: "#BBDEFB"
    label: "PC Register"
    -pc: "uint32_t"
    +get_pc(): "uint32_t"
    +set_pc(v): "void"
    +advance(): "void"
  }
  fetch: "Instruction Fetch" {
    shape: class
    style.fill: "#BBDEFB"
    label: "Fetch Unit"
    -program: "Program*"
    -pc: "uint32_t"
    +fetch(): "Instruction"
  }
  decode: "Decode (Opcode)" {
    shape: class
    style.fill: "#BBDEFB"
    label: "Decode Unit"
    -opcode: "Opcode"
    -p1: "int32_t"
    -p2: "int32_t"
    -p3: "void*"
    +decode(i): "void"
  }
  execute: "Execute (Switch)" {
    shape: class
    style.fill: "#BBDEFB"
    label: "Execute Unit"
    -opcode: "Opcode"
    +execute(): "int"
  }
  pc -> fetch: "next addr"
  fetch -> decode: "raw bytes"
  decode -> execute: "decoded"
}
# Loop arrow back to PC
execute -> pc: "loop" {
  style.stroke-dash: 4
  style.stroke: "#757575"
}
# Register File section
register_file: "Register File" {
  shape: class
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  label: "Register File (256+ regs)"
  -regs: "Register[256]"
  -capacity: "int"
  +get(r): "Register*"
  +set(r, v): "void"
  +clear(): "void"
}
# Register types
reg_types: "Register Types" {
  shape: sql_table
  style.fill: "#FFE0B2"
  style.stroke: "#E65100"
  label: "Value Types"
  r0: "REG_NULL    | NULL value"
  r1: "REG_INTEGER | int64_t"
  r2: "REG_FLOAT   | double"
  r3: "REG_STRING  | char*"
  r4: "REG_BLOB    | void*"
  r5: "REG_COLUMN  | lazy ref"
}
# Cursor Interface section
cursor_interface: "Cursor Interface" {
  shape: class
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  label: "Storage Cursor API"
  -pool: "BufferPool*"
  +open(t): "Cursor*"
  +close(c): "void"
  +search(c, k): "bool"
  +next(c): "bool"
  +prev(c): "bool"
  +get_col(c, i): "Value*"
}
# Cursor Operations
cursor_ops: "Cursor Operations" {
  shape: sql_table
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  label: "OpCodes → Cursor"
  op1: "OP_OPEN_TABLE  | cursor = open(table)"
  op2: "OP_REWIND      | cursor to first row"
  op3: "OP_NEXT        | cursor++"
  op4: "OP_COLUMN       | load col to reg"
  op5: "OP_RESULT_ROW  | emit result"
  op6: "OP_CLOSE        | cursor close"
}
# Data flow arrows
execute -> register_file: "read/write\nregisters"
execute -> cursor_interface: "table/index\naccess"
# Storage layer
storage: "Storage Layer" {
  shape: class
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  label: "B-Tree / Buffer Pool"
  -buffer_pool: "BufferPool*"
  +get_page(n): "uint8_t*"
  +put_page(n, d): "void"
  +flush(): "void"
}
cursor_interface -> storage: "page I/O\nrequests"
# Example instruction flow
example_flow: "Example: SELECT * FROM users WHERE id = 1" {
  shape: sequence_diagram
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  width: 500
  vm: VDBE
  cur: Cursor
  buf: "Buffer Pool"
  vm -> cur: "OP_OPEN_TABLE \"users\""
  cur -> buf: "get_page(root)"
  vm -> cur: "OP_REWIND"
  vm -> cur: "OP_SEARCH id=1"
  cur -> buf: "get_page(leaf)"
  vm -> cur: "OP_COLUMN 0 -> R1"
  vm -> cur: "OP_COLUMN 1 -> R2"
  vm -> vm: "OP_RESULT_ROW R1,R2"
}
# Legend
legend: "Legend" {
  near: bottom-right
  shape: rectangle
  style.fill: white
  style.stroke: "#BDBDBD"
  item1: "Blue = Execution Control" {
    style.fill: "#E3F2FD"
  }
  item2: "Orange = Data Storage" {
    style.fill: "#FFF3E0"
  }
  item3: "Green = I/O Operations" {
    style.fill: "#E8F5E9"
  }
  item4: "Purple = Persistence" {
    style.fill: "#F3E5F5"
  }
}
# Connect example to main flow
execute -> example_flow: "bytecode\nexample"