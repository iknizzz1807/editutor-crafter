direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Buffer Pool Hit Rate Calculation Architecture
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Input flow
  vdbe_request: "VDBE Request" {
    shape: parallelogram
    style.fill: "#E3F2FD"
  }
  fetchpage_node: "FetchPage Function" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 3
  }
  hash_lookup: "Hash Table Lookup" {
    shape: diamond
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}
row1.vdbe_request -> row1.fetchpage_node: "page_number" {
  style.stroke: "#1976D2"
}
row1.fetchpage_node -> row1.hash_lookup: "Check cache" {
  style.stroke: "#FF9800"
}
# Cache hit path
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cache_hit: "CACHE HIT" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.font-color: "#2E7D32"
    style.bold: true
  }
  hit_counter: "hits++" {
    shape: rectangle
    style.fill: "#DCEDC8"
    style.stroke: "#8BC34A"
  }
  return_page: "Return cached page" {
    shape: parallelogram
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
}
row1.hash_lookup -> row2.cache_hit: "Found in cache" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}
row2.cache_hit -> row2.hit_counter: "increment" {
  style.stroke: "#4CAF50"
}
row2.hit_counter -> row2.return_page: "page data" {
  style.stroke: "#4CAF50"
}
# Cache miss path
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cache_miss: "CACHE MISS" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    style.font-color: "#C62828"
    style.bold: true
  }
  disk_read: "Disk Read" {
    shape: cylinder
    style.fill: "#BBDEFB"
    style.stroke: "#2196F3"
  }
  miss_counter: "misses++" {
    shape: rectangle
    style.fill: "#FFECB3"
    style.stroke: "#FFC107"
  }
  allocate_frame: "Allocate frame" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
  }
}
row1.hash_lookup -> row3.cache_miss: "Not found" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
}
row3.cache_miss -> row3.disk_read: "Load from disk" {
  style.stroke: "#F44336"
}
row3.disk_read -> row3.allocate_frame: "page data" {
  style.stroke: "#F44336"
}
row3.allocate_frame -> row3.miss_counter: "frame ready" {
  style.stroke: "#F44336"
}
# Hit rate calculation
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  formula_box: {
    shape: sql_table
    label: "Hit Rate Formula"
    hit_rate: "hit_rate = hits / (hits + misses)"
    example: "950 / (950 + 50) = 0.95 = 95%"
    interpretation: "Higher is better"
  }
  stats_struct: {
    shape: sql_table
    label: "BufferPoolStats Structure"
    field1: "uint64_t | hits"
    field2: "uint64_t | misses"
    field3: "uint64_t | evictions"
    field4: "uint64_t | dirty_writes"
    field5: "double | hit_rate"
  }
}
# Performance impact visualization
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  performance_impact: {
    shape: sql_table
    label: "Performance Impact"
    high: "90%+ hit rate | ~microseconds/page"
    medium: "70-90% hit rate | ~milliseconds/page"
    low: "<70% hit rate | Slow queries"
  }
  optimization: {
    shape: sql_table
    label: "Optimization Strategies"
    strategy1: "Increase | buffer pool size"
    strategy2: "Optimize | query access patterns"
    strategy3: "Add indexes | to reduce scans"
    strategy4: "Monitor | hit rate metrics"
  }
}
# Arrows showing flow completion
row2.return_page -> row5: "Page returned to VDBE" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 5
}
row3.miss_counter -> row5: "Page cached, returned" {
  style.stroke: "#F44336"
  style.stroke-dash: 5
}
# Stats to formula connection
row4.stats_struct -> row4.formula_box: "provides" {
  style.stroke: "#9C27B0"
}