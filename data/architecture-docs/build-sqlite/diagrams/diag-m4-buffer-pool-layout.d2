direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

title: {
  shape: package
  label: "Catalog of Architectural Patterns (Reference v1.0)"
  style: {
    fill: "#f5f5f5"
    stroke-width: 4
    bold: true
    font-size: 24
  }
}

# --- ROW 1: MVC & CLIENT-SERVER ---
row_1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  mvc: {
    label: "1. Model-View-Controller (MVC)"
    style.fill: "#e3f2fd"
    
    diagram: {
      direction: down
      style.stroke-dash: 2
      controller: "Controller (input_handler.go)" {
        shape: rectangle
        tooltip: "Processes user commands"
      }
      model: "Model (data_store.go)" {
        shape: cylinder
        tooltip: "State and business logic"
      }
      view: "View (renderer.js)" {
        shape: rectangle
        tooltip: "User Interface representation"
      }
      
      controller -> model: "Update | call()"
      model -> view: "Notify | callback()"
      view -> controller: "Input | event"
    }

    details: |md
      **Usage:** Web frameworks (Rails, Django)
      - **Model**: Domain logic & data.
      - **View**: Presentation layer.
      - **Controller**: Routing & input logic.
    |
  }

  client_server: {
    label: "2. Client-Server"
    style.fill: "#fff3e0"

    diagram: {
      direction: right
      style.stroke-dash: 2
      clients: {
        c1: "Browser" {shape: person}
        c2: "Mobile App" {shape: person}
      }
      server: "Application Server" {
        shape: cylinder
        style.fill: "#ffe0b2"
      }
      
      clients.c1 -> server: "HTTPS/1.1 | GET"
      clients.c2 -> server: "gRPC | Push"
      server -> clients.c1: "200 OK | HTML"
    }

    details: |md
      **Usage:** Distributed Systems
      - **Clients**: Request resources.
      - **Server**: Provides services/data.
      - Highly centralized management.
    |
  }
}

# --- ROW 2: LAYERED & MICROSERVICES ---
row_2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layered: {
    label: "3. Layered Architecture (N-Tier)"
    style.fill: "#f3e5f5"

    diagram: {
      direction: down
      style.stroke-dash: 2
      pres: "Presentation (UI)"
      biz: "Business (Services)"
      data: "Data Access (DAO)"
      db: "Persistence (Postgres)" {shape: cylinder}

      pres -> biz: "Desealized DTO"
      biz -> data: "Entity"
      data -> db: "SQL"
    }

    details: |md
      **Usage:** Enterprise Applications
      - **Strict**: Layer *n* only calls *n-1*.
      - **Loose**: Layers can skip neighbors.
      - Simplifies testing and replacement.
    |
  }

  microservices: {
    label: "4. Microservices"
    style.fill: "#e8f5e9"

    diagram: {
      direction: right
      style.stroke-dash: 2
      api: "API Gateway" {shape: parallelogram}
      s1: "Auth Svc" {shape: package}
      s2: "Order Svc" {shape: package}
      s3: "Stock Svc" {shape: package}
      
      api -> s1: "JWT Verify"
      api -> s2: "REST"
      s2 -> s3: "gRPC | sync"
    }

    details: |md
      **Usage:** Large Scale Cloud Apps
      - Independent deployment units.
      - Technology agnostic (Polyglot).
      - Fault isolation between domains.
    |
  }
}

# --- ROW 3: P2P & EVENT-DRIVEN ---
row_3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  p2p: {
    label: "5. Peer-to-Peer (P2P)"
    style.fill: "#fafafa"

    diagram: {
      direction: down
      style.stroke-dash: 2
      n1: "Node A (Seed)" {shape: circle}
      n2: "Node B (Leech)" {shape: circle}
      n3: "Node C (Peer)" {shape: circle}
      
      n1 <-> n2: "BitTorrent"
      n2 <-> n3: "Gossip Protocol"
      n3 <-> n1: "TCP/IP"
    }

    details: |md
      **Usage:** File Sharing, Blockchain
      - No central authority.
      - Nodes are both clients and servers.
      - Massive scalability/resilience.
    |
  }

  event_driven: {
    label: "6. Event-Driven"
    style.fill: "#fffde7"

    diagram: {
      direction: right
      style.stroke-dash: 2
      pub: "Producer"
      bus: "Kafka Cluster" {
        shape: queue
        style.fill: "#fff9c4"
      }
      sub: "Consumer"
      
      pub -> bus: "ProducerRecord | send()"
      bus -> sub: "ConsumerRecord | poll()"
    }

    details: |md
      **Usage:** Real-time Analytics, IoT
      - Decouples time and space.
      - Async messaging patterns.
      - Pub/Sub or Event Streaming.
    |
  }
}

# --- ROW 4: BLACKBOARD & MASTER-SLAVE ---
row_4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  blackboard: {
    label: "7. Blackboard Pattern"
    style.fill: "#efebe9"

    diagram: {
      direction: down
      style.stroke-dash: 2
      bb: "Shared Blackboard (State)" {
        shape: rectangle
        style.stroke-width: 3
      }
      ks: {
        direction: right
        ks1: "Expert A" {shape: person}
        ks2: "Expert B" {shape: person}
      }
      ctrl: "Controller" {shape: hexagon}

      ks.ks1 <-> bb: "Read/Write"
      ks.ks2 <-> bb: "Update"
      ctrl -> ks.ks1: "Invoke"
      ctrl -> ks.ks2: "Invoke"
    }

    details: |md
      **Usage:** AI, Speech Recognition
      - Knowledge Sources (KS) act on data.
      - Opportunistic problem solving.
    |
  }

  master_slave: {
    label: "8. Master-Slave"
    style.fill: "#fce4ec"

    diagram: {
      direction: down
      style.stroke-dash: 2
      master: "Master Node" {
        shape: rectangle
        style.bold: true
      }
      slaves: {
        direction: right
        s1: "Slave 1"
        s2: "Slave 2"
      }
      
      master -> slaves.s1: "Job Split"
      master -> slaves.s2: "Job Split"
      slaves.s1 -> master: "Partial Result"
      slaves.s2 -> master: "Partial Result"
    }

    details: |md
      **Usage:** MapReduce, DB Replication
      - Master coordinates work.
      - Slaves perform compute/storage.
    |
  }
}

# --- ROW 5: BROKER & PIPE-FILTER ---
row_5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  broker: {
    label: "9. Broker Pattern"
    style.fill: "#e0f2f1"

    diagram: {
      direction: right
      style.stroke-dash: 2
      client: "Client Proxy"
      broker_node: "Service Broker" {
        shape: hexagon
        style.fill: "#b2dfdb"
      }
      service: "Server Proxy"
      
      client -> broker_node: "Remote Call"
      broker_node -> service: "Location Map"
    }

    details: |md
      **Usage:** Distributed Objects (CORBA)
      - Decouples client from server location.
      - Handles marshaling and routing.
    |
  }

  pipe_filter: {
    label: "10. Pipe-and-Filter"
    style.fill: "#f1f8e9"

    diagram: {
      direction: right
      style.stroke-dash: 2
      f1: "Filter (Parser)" {shape: step}
      f2: "Filter (Filter)" {shape: step}
      f3: "Filter (Writer)" {shape: step}
      
      f1 -> f2: "Byte Stream"
      f2 -> f3: "Transformed Data"
    }

    details: |md
      **Usage:** Data Pipelines, Compilers
      - Filters process data incrementally.
      - Pipes act as buffers between steps.
    |
  }
}

# --- GLOBAL LAYOUT FLOW ---
title -> row_1: "Initial Layer"
row_1 -> row_2: "Secondary Layer"
row_2 -> row_3: "Third Layer"
row_3 -> row_4: "Fourth Layer"
row_4 -> row_5: "Final Layer"