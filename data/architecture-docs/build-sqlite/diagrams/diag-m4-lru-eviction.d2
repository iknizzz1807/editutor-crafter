direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: LRU Eviction Algorithm {
  shape: text
  style.font-size: 28
  style.bold: true
}
# Row 1: Core Data Structures
row1_components: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Hash Table
  hash_table: "Hash Table" {
    shape: sql_table
    label: "page_to_frame (O(1) lookup)"
    key: "page_id (uint32)"
    value: "Frame*"
    note: "Maps DB page → frame"
  }
  # Frame Table
  frame_table: "Frame Table" {
    shape: sql_table
    label: "Frame Array [0..N-1]"
    f0: "0 | page_number | uint32"
    f1: "1 | data[4096] | uint8[]"
    f2: "2 | is_dirty | bool"
    f3: "3 | pin_count | int"
    f4: "4 | prev | Frame*"
    f5: "5 | next | Frame*"
    f6: "6 | last_access | uint64"
  }
}
# Arrows connecting components
row1_components.hash_table -> row1_components.frame_table: "lookup"
# Row 2: LRU List Visualization
row2_lru: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # MRU end
  mru_end: "MRU" {
    shape: rectangle
    style.fill: "#90EE90"
    style.bold: true
    label: "MRU (Most Recently Used)"
  }
  # LRU Chain
  lru_chain: "LRU Doubly-Linked List" {
    direction: right
    frame_n3: "Frame N-3" {
      shape: rectangle
      style.fill: "#E0E0E0"
      label: "frame[n-3]\npage=42\npins=0"
    }
    frame_n2: "Frame N-2" {
      shape: rectangle
      style.fill: "#E0E0E0"
      label: "frame[n-2]\npage=17\npins=1"
    }
    frame_n1: "Frame N-1 (EVICT CANDIDATE)" {
      shape: rectangle
      style.fill: "#FFE0E0"
      style.stroke: red
      style.stroke-width: 3
      label: "frame[n-1]\npage=99\npins=0\nEVICT THIS"
    }
    lru_end: "LRU" {
      shape: rectangle
      style.fill: "#FFB6C1"
      style.bold: true
      label: "LRU (Least Recently Used)"
    }
  }
}
# Connections in LRU chain
row2_lru.mru_end -> row2_lru.lru_chain.frame_n3: "most recent access"
row2_lru.lru_chain.frame_n3 -> row2_lru.lru_chain.frame_n2: "prev | next"
row2_lru.lru_chain.frame_n2 -> row2_lru.lru_chain.frame_n1: "prev | next"
row2_lru.lru_chain.frame_n1 -> row2_lru.lru_end: "oldest access"
# Row 3: Eviction Process Flow
row3_flow: "Eviction Process" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Step 1
  step1: "1. Select LRU" {
    shape: rectangle
    style.fill: "#FFFACD"
    label: "1. SELECT TAIL\n(pin_count=0)"
  }
  # Step 2
  step2: "2. Check Dirty" {
    shape: rectangle
    style.fill: "#FFFACD"
    label: "2. CHECK DIRTY\nis_dirty?"
  }
  # Step 3
  step3: "3. Write If Dirty" {
    shape: rectangle
    style.fill: "#FFE4B5"
    label: "3. IF DIRTY:\nwrite to disk"
  }
  # Step 4
  step4: "4. Hash Remove" {
    shape: rectangle
    style.fill: "#FFFACD"
    label: "4. REMOVE from\nhash table"
  }
  # Step 5
  step5: "5. Unlink" {
    shape: rectangle
    style.fill: "#FFFACD"
    label: "5. UNLINK\nfrom list"
  }
  # Step 6
  step6: "6. Insert New" {
    shape: rectangle
    style.fill: "#98FB98"
    label: "6. INSERT new page\nat HEAD (MRU)"
  }
}
row3_flow.step1 -> row3_flow.step2: "pin_count == 0?"
row3_flow.step2 -> row3_flow.step3: "YES"
row3_flow.step2 -> row3_flow.step4: "NO (dirty)"
row3_flow.step3 -> row3_flow.step4: "fsync()"
row3_flow.step4 -> row3_flow.step5: "hash_remove()"
row3_flow.step5 -> row3_flow.step6: "unlink()"
row3_flow.step6 -> row2_lru.mru_end: "link to MRU"
# Row 4: Pin Count Mechanism
row4_pin: "Pin Count Prevents Eviction" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Pin scenario
  pinned_frame: "Pinned Frame" {
    shape: rectangle
    style.fill: "#87CEEB"
    style.stroke: blue
    style.stroke-width: 2
    label: "frame[k]\npage=55\npin_count=2\n🚫 CANNOT EVICT"
  }
  # Arrow showing protection
  protect_arrow: "pin_count > 0" {
    shape: text
    style.font-size: 14
    style.font-color: blue
  }
  # Eviction skip
  skip_frame: "Skip to Next" {
    shape: rectangle
    style.fill: "#FFFACD"
    label: "frame[k+1]\npin_count=0\n✅ CAN EVICT"
  }
}
row4_pin.pinned_frame -> row4_pin.protect_arrow -> row4_pin.skip_frame: "skip pinned frames"
# Row 5: Code Reference
row5_code: "Key Operations" {
  width: 600
  get_op: |c
    buffer_pool_get(page_id):
      1. hash_lookup(page_id) → frame?
      2. YES: update_lru(frame), return data
      3. NO: get_free_frame() or evict()
  '|
  evict_op: |c
    buffer_pool_evict():
      1. find_unpinned_tail()
      2. if dirty: write_page()
      3. hash_remove(page_id)
      4. unlink_from_lru()
      5. load_new_page()
      6. insert_at_head()
  '|
}
row5_code.get_op -> row5_code.evict_op: "cache miss → evict" {
  style.stroke-dash: 3
}
# Legend
legend: "Color Legend" {
  near: bottom-right
  direction: right
  green: "MRU / Free" {
    shape: text
    style.fill: "#90EE90"
  }
  yellow: "In Use" {
    shape: text
    style.fill: "#FFFACD"
  }
  red: "LRU Candidate" {
    shape: text
    style.fill: "#FFE0E0"
  }
  blue: "Pinned (Protected)" {
    shape: text
    style.fill: "#87CEEB"
  }
}
legend.near: bottom-right