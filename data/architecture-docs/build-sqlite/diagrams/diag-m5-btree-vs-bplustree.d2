direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "B-tree vs B+tree Structure Comparison" {
  near: top-center
  style.font-size: 28
  style.bold: true
}
# Row containers for side-by-side comparison
row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # B-tree (Table) section
  btree_section: "B-tree (Table Storage)" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2
    btree_root: "Root Node (0x1000)" {
      shape: sql_table
      style.fill: "#BBDEFB"
      label: "ROOT | rowid=100 | payload: {name:'Alice', age:30}"
      row1: "Key: 100 | Data: {Alice, 30, ...}"
      row2: "Key: 200 | Data: {Bob, 25, ...}"
      row3: "Key: 300 | Data: {Carol, 35, ...}"
      sz: "Size: 4096 bytes"
    }
    btree_arrow1: "Points to children" {
      style.stroke: "#1976D2"
      style.stroke-dash: 3
    }
    btree_internal: "Internal Node" {
      shape: sql_table
      style.fill: "#90CAF9"
      label: "INTERNAL | child_page=5"
      row1: "Key: 100 | Child: Page 5"
      row2: "Key: 200 | Child: Page 6"
      row3: "Key: 300 | Child: Page 7"
    }
    btree_arrow2: "Points to children" {
      style.stroke: "#1976D2"
      style.stroke-dash: 3
    }
    btree_leaf: "Leaf Nodes" {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      leaf1: "Leaf Page 5" {
        shape: sql_table
        style.fill: "#64B5F6"
        label: "LEAF | rowid: 100-150"
        row1: "rowid=100 | {Alice, 30, alice@email.com}"
        row2: "rowid=120 | {Dave, 28, dave@email.com}"
        row3: "rowid=145 | {Eve, 32, eve@email.com}"
      }
      leaf2: "Leaf Page 6" {
        shape: sql_table
        style.fill: "#64B5F6"
        label: "LEAF | rowid: 151-200"
        row1: "rowid=151 | {Frank, 40, frank@email.com}"
        row2: "rowid=180 | {Grace, 27, grace@email.com}"
      }
    }
    btree_legend: "" {
      shape: text
      label: "Data stored in ALL nodes (root, internal, leaves)"
      style.font-color: "#D32F2F"
      style.font-size: 14
      style.bold: true
    }
  }
  # B+tree (Index) section
  bplustree_section: "B+tree (Index Storage)" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
    bptree_root: "Root Node (0x2000)" {
      shape: sql_table
      style.fill: "#C8E6C9"
      label: "ROOT (Index)"
      row1: "Key: 100 | Child: Page 10"
      row2: "Key: 200 | Child: Page 11"
      row3: "Key: 300 | Child: Page 12"
      note: "NO row data, only keys"
    }
    bptree_arrow1: "Points to children" {
      style.stroke: "#388E3C"
      style.stroke-dash: 3
    }
    bptree_internal: "Internal Node" {
      shape: sql_table
      style.fill: "#A5D6A7"
      label: "INTERNAL (Index)"
      row1: "Key: 100 | Child: Page 10"
      row2: "Key: 200 | Child: Page 11"
      note: "NO row data, only keys"
    }
    bptree_arrow2: "Points to children" {
      style.stroke: "#388E3C"
      style.stroke-dash: 3
    }
    bptree_leaves: "Leaf Nodes (Linked)" {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      bpleaf1: "Leaf Page 10" {
        shape: sql_table
        style.fill: "#81C784"
        label: "LEAF INDEX"
        row1: "key=100 | rowid=100"
        row2: "key=120 | rowid=120"
        row3: "key=145 | rowid=145"
        next: "→ Page 11"
      }
      bpleaf2: "Leaf Page 11" {
        shape: sql_table
        style.fill: "#81C784"
        label: "LEAF INDEX"
        row1: "key=151 | rowid=151"
        row2: "key=180 | rowid=180"
        prev: "← Page 10"
        next: "→ Page 12"
      }
      bpleaf3: "Leaf Page 12" {
        shape: sql_table
        style.fill: "#81C784"
        label: "LEAF INDEX"
        row1: "key=250 | rowid=250"
        row2: "key=300 | rowid=300"
        prev: "← Page 11"
      }
    }
    bptree_legend: "" {
      shape: text
      label: "Data ONLY in leaves | Leaves linked for range scan"
      style.font-color: "#D32F2F"
      style.font-size: 14
      style.bold: true
    }
  }
}
# Comparison notes at bottom
comparison: "Key Differences" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.border-radius: 8
  diff1: "✓ B-tree: Point lookup faster (data at every level)"
  diff2: "✓ B+tree: Range scan faster (leaves linked)"
  diff3: "✓ B-tree: Less disk I/O for point queries"
  diff4: "✓ B+tree: Better scan performance (sequential leaf access)"
  diff5: "SQLite uses B-tree for tables, B+tree for indexes"
}
row -> comparison: "Use Case Summary"