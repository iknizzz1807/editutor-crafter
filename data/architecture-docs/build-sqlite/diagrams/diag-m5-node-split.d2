direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Title
title: "B-tree Node Split: Before and After" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}
# Row 1: Before state
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Full page before split
  full_page: {
    label: "Before: Full Page (N cells)"
    shape: sql_table
    style.fill: "#FFE4B5"
    style.stroke: "#8B4513"
    style.stroke-width: 3
    header: "Leaf Page (page 5)"
    cell_0: "key[0] → rowid[0]"
    cell_1: "key[1] → rowid[1]"
    cell_2: "key[2] → rowid[2]"
    cell_3: "key[3] → rowid[3]"
    cell_4: "key[4] → rowid[4]"
    cell_5: "key[5] → rowid[5]"
    cell_6: "key[6] → rowid[6]"
    cell_N_2: "key[N-2] → rowid[N-2]"
    cell_N_1: "key[N-1] → rowid[N-1]"
    split_indicator: "↑ SPLIT HERE (median key[N/2])"
  }
}
# Arrow from before to after
row1 -> row2: "Split Operation" {
  style.stroke: blue
  style.stroke-width: 3
  style.animated: true
}
# Row 2: After state - showing the split result
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Left page after split
  left_page: {
    label: "After: Left Page"
    shape: sql_table
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    style.stroke-width: 2
    header: "Leaf Page (page 5)"
    l_cell_0: "key[0] → rowid[0]"
    l_cell_1: "key[1] → rowid[1]"
    l_cell_2: "key[2] → rowid[2]"
    l_cell_3: "key[3] → rowid[3]"
    l_cell_N2: "key[N/2-1] → rowid[N/2-1]"
    count: "N/2 cells (floor)"
  }
  # Median key being promoted
  median_promotion: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    median_key: {
      label: "median key[N/2]"
      shape: rectangle
      style.fill: "#FF6B6B"
      style.stroke: "#C0392B"
      style.stroke-width: 2
    }
    arrow_down: "" {
      style.stroke: red
      style.stroke-dash: 4
      style.stroke-width: 2
    }
  }
  # Right page after split
  right_page: {
    label: "After: Right Page (NEW)"
    shape: sql_table
    style.fill: "#87CEEB"
    style.stroke: "#4169E1"
    style.stroke-width: 2
    header: "Leaf Page (page N+1)"
    r_cell_N2: "key[N/2+1] → rowid[N/2+1]"
    r_cell_N2_1: "key[N/2+2] → rowid[N/2+2]"
    r_cell_N2_2: "key[N/2+3] → rowid[N/2+3]"
    r_cell_N_1: "key[N-1] → rowid[N-1]"
    count: "N/2 cells (ceil)"
  }
}
# Row 3: Parent update
row2 -> row3: "Promote to Parent" {
  style.stroke: red
  style.stroke-width: 2
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # Original parent
  old_parent: {
    label: "Before Split"
    shape: sql_table
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    header: "Internal Page (page 2)"
    p_cell_0: "key[10] → page[3]"
    p_cell_1: "key[20] → page[4]"
    p_cell_2: "key[30] → page[5]"
    p_cell_3: "key[40] → page[6]"
  }
  arrow_to_new: "→" {
    style.stroke: blue
    style.stroke-width: 3
  }
  # New parent with promoted key
  new_parent: {
    label: "After Split"
    shape: sql_table
    style.fill: "#DDA0DD"
    style.stroke: "#8B008B"
    style.stroke-width: 2
    header: "Internal Page (page 2)"
    np_cell_0: "key[10] → page[3]"
    np_cell_1: "key[20] → page[4]"
    np_cell_2: "key[30] → page[5]"
    np_promoted: "key[M] → page[N+1]  ⚠️ NEW"
    np_cell_3: "key[40] → page[6]"
  }
}
# Row 4: Cascading split note
row3 -> row4: "" {
  style.opacity: 0
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cascade_note: {
    shape: callout
    label: "Cascading Split: If parent is full, recursively split parent and propagate up to root"
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
    style.stroke-width: 2
    style.stroke-dash: 5
  }
}
# Legend
legend: {
  near: bottom-right
  direction: down
  label: "Legend"
  style.fill: white
  style.stroke: gray
  left_legend: "Left Page (original)" {
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  right_legend: "Right Page (new)" {
    shape: rectangle
    style.fill: "#87CEEB"
    style.stroke: "#4169E1"
  }
  promoted_legend: "Promoted Key" {
    shape: rectangle
    style.fill: "#FF6B6B"
    style.stroke: "#C0392B"
  }
}
# Connections between components
full_page -> median_promotion.median_key: "Split key" {
  style.stroke: red
  style.stroke-dash: 4
}
median_promotion.median_key -> left_page: "< N/2 keys" {
  style.stroke: green
}
median_promotion.median_key -> right_page: ">= N/2 keys" {
  style.stroke: blue
}
# Annotations for cell counts
full_page.cell_N_1.style.font-color: red
full_page.cell_N_1: "key[N-1] → rowid[N-1]  ⚠️ FULL!" {
  style.font-color: red
  style.bold: true
}
left_page.count.style.font-size: 14
left_page.count.style.font-color: "#228B22"
right_page.count.style.font-size: 14
right_page.count.style.font-color: "#4169E1"
new_parent.np_promoted.style.fill: "#FFB6C1"