direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
page_layout: "4096-byte Database Page Layout" {
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
  header_region: "Page Header (Bytes 0-99)" {
    shape: sql_table
    label: "Page Header | Offset | Size"
    b0: "0x00 | 2 bytes | page_type (0x0D=leaf, 0x05=internal)"
    b2: "0x02 | 2 bytes | first_freeblock offset"
    b4: "0x04 | 2 bytes | cell_count (number of cells)"
    b6: "0x06 | 2 bytes | cell_content_start (grows downward)"
    b8: "0x08 | 1 byte  | fragmented_free_bytes"
    b9: "0x09 | 91 bytes| reserved / right_child (internal)"
    header_total: "Total Header: 100 bytes"
  }
  arrow1: "" {
    style.stroke: transparent
    style.fill: transparent
  }
  cell_pointers: "Cell Pointer Array (Grows Backward ↓)" {
    shape: sql_table
    label: "Cell Pointers | From End of Header"
    ptr_n_minus_1: "Cell[N-1] | 2 bytes | Offset to last cell"
    ptr_n_minus_2: "Cell[N-2] | 2 bytes | Offset to 2nd-last cell"
    ptr_1: "Cell[1] | 2 bytes | Offset to 2nd cell"
    ptr_0: "Cell[0] | 2 bytes | Offset to 1st cell"
    note: "Each pointer = 2 bytes | Total = 2 × cell_count"
  }
  arrow2: "" {
    style.stroke: transparent
    style.fill: transparent
  }
  free_space: "Free Space (Grows ↓→)" {
    shape: rectangle
    label: "Free Space | Grows from both directions"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-dash: 4
    width: 300
    note: "Bidirectional growth: pointers grow up, content grows down"
  }
  arrow3: "" {
    style.stroke: transparent
    style.fill: transparent
  }
  cell_content: "Cell Content Area (Grows Forward ↑)" {
    shape: sql_table
    label: "Cell Content | Grows Upward from Page End"
    cell_n: "Cell[N] | Variable | Last cell (newest)"
    cell_2: "Cell[2] | Variable | Third cell"
    cell_1: "Cell[1] | Variable | Second cell"
    cell_0: "Cell[0] | Variable | First cell (oldest)"
    cell_structure: "Each Cell: payload_size + rowid/key + data"
  }
  arrow4: "" {
    style.stroke: transparent
    style.fill: transparent
  }
  memory_map: "Full 4096-byte Memory Map" {
    shape: sql_table
    label: "Byte Range | Contents | Description"
    bytes_0_99: "0x0000 - 0x0063 | Page Header | 100 bytes fixed"
    bytes_100_199: "0x0064 - 0x00C7 | Cell Pointers | 2 × cell_count bytes"
    free_middle: "0x00C8 - 0x0FF7 | Free Space | Grows bidirectionally"
    content_end: "0x0FF8 - 0x1000 | Cell Content | Grows upward"
    total: "Total: 4096 bytes (1 page)"
  }
  legend: "Key Properties" {
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 14
    prop1: "• Cell pointers: 2 bytes each, stored at end of header"
    prop2: "• Cell content: stored at cell_content_start, grows down"
    prop3: "• Free space: gap between pointer array and content"
    prop4: "• Slotted page: enables variable-length records"
  }
}
# Relationships
page_layout.header_region -> page_layout.cell_pointers: "Pointers at fixed offset"
page_layout.cell_pointers -> page_layout.free_space: "Free in middle"
page_layout.free_space -> page_layout.cell_content: "Content grows up"
page_layout.cell_pointers -> page_layout.cell_content: "Pointers → content" {
  style.stroke-dash: 3
  style.stroke: gray
  label: "Pointer = offset to cell"
}
page_layout.cell_pointers -> page_layout.memory_map: "Summary view" {
  style.stroke-dash: 3
  style.stroke: gray
}