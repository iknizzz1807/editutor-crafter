direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "System Catalog Structure (sqlite_master)" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}
# System Catalog Table (sqlite_master equivalent)
catalog: "sqlite_master (System Catalog)" {
  shape: sql_table
  label: "sqlite_master"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  type: "TEXT | PRIMARY KEY"
  name: "TEXT | PRIMARY KEY"
  tbl_name: "TEXT"
  rootpage: "INTEGER"
  sql: "TEXT"
}
# Catalog Entry Structure
catalog_entry: "Catalog Entry Details" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  entry_fields: "Entry Fields (for users table):" {
    shape: sql_table
    label: "Sample Row"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    type_val: "\"table\""
    name_val: "\"users\""
    tbl_name_val: "\"users\""
    rootpage_val: "2"
    sql_val: "\"CREATE TABLE users...\""
  }
}
catalog -> catalog_entry.entry_fields: "sample entry" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
# CREATE TABLE Flow
create_flow: "CREATE TABLE Flow" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  sql_input: "SQL: CREATE TABLE users (id INT, name TEXT)" {
    shape: document
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
  parser: "Parser" {
    shape: class
    label: "Parser"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    +parse_statement(sql): "ASTNode*"
  }
  catalog_insert: "Catalog Insert" {
    shape: class
    label: "Catalog"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    +insert(schema_row): "bool"
  }
  btree_create: "B-tree Create" {
    shape: class
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
    +create(root_page): "BTree*"
  }
}
sql_input -> parser: "1. Parse SQL" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
parser -> catalog_insert: "2. Extract schema" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
catalog_insert -> catalog: "3. Insert row into sqlite_master" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
catalog_insert -> btree_create: "4. Create table B-tree" {
  style.stroke: "#F57F17"
  style.stroke-width: 2
}
# Query Compilation Flow
query_flow: "Query Compilation Flow" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  select_query: "SELECT * FROM users WHERE id = 1" {
    shape: document
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
  parser_q: "Parser" {
    shape: class
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    +parse(): "AST"
  }
  catalog_lookup: "Catalog Lookup" {
    shape: class
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    +lookup(table_name): "root_page"
  }
  compiler: "VDBE Compiler" {
    shape: class
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
    +compile(ast): "Program*"
  }
  execution: "Execution" {
    shape: class
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    +execute(program): "Results"
  }
}
select_query -> parser_q: "1. Parse query" {
  style.stroke: "#1565C0"
}
parser_q -> catalog_lookup: "2. Resolve table: 'users'" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
catalog_lookup -> catalog: "3. SELECT rootpage WHERE name='users'" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
catalog -> catalog_lookup: "4. Return rootpage=2" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 3
}
catalog_lookup -> compiler: "5. Compile with root_page=2" {
  style.stroke: "#F57F17"
  style.stroke-width: 2
}
compiler -> execution: "6. Execute bytecode" {
  style.stroke: "#C62828"
}
# Legend
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: white
  style.stroke: "#BDBDBD"
  style.stroke-width: 1
  legend_title: "Legend" {
    shape: text
    style.font-size: 14
    style.bold: true
  }
  parse_legend: "Parsing" {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  catalog_legend: "Catalog" {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
  storage_legend: "Storage" {
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
  }
  execute_legend: "Execution" {
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
  parse_legend -> catalog_legend: "flow" {
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
  }
  catalog_legend -> storage_legend: "flow" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  storage_legend -> execute_legend: "flow" {
    style.stroke: "#F57F17"
    style.stroke-width: 2
  }
}
catalog_entry: "" {
  style.fill: transparent
  style.stroke: transparent
}
catalog_entry -> catalog: "stores metadata for all schema objects" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 5
  style.font-color: "#666"
}