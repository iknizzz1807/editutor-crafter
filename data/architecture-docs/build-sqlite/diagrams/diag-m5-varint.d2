direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Varint Encoding: Variable-Length Integer Representation
| {near: top-center}
# Row 1: Concept Overview
overview: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  what_is_varint: |md
    ## What is Varint?
    Varints encode integers using 1-9 bytes:
    - 7 data bits per byte
    - 1 continuation bit (0x80)
    - Continuation bit = 1 → more bytes follow
    - Continuation bit = 0 → last byte
  | {
    shape: rectangle
    width: 320
  }
  why_varint: |md
    ## Why Varint?
    Saves space for small integers:
    - 0-127 → 1 byte (vs 8 bytes fixed)
    - 128-16383 → 2 bytes (vs 8 bytes fixed)
    - Typical database IDs use 1-2 bytes
    - ~75% space savings for small values
  | {
    shape: rectangle
    width: 300
  }
}
# Row 2: Bit Layout
bit_layout: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  byte_n_structure: {
    shape: sql_table
    label: "Single Byte Structure"
    bit7: "b7 | Continuation Bit (0x80)"
    bit6_0: "b6-b0 | 7 bits of data"
    continuation_1: "1 = more bytes follow"
    continuation_0: "0 = last byte"
  }
  multi_byte_flow: {
    shape: sql_table
    label: "Multi-Byte Encoding Flow"
    byte1: "Byte 1: 7 data bits + cont=1"
    byte2: "Byte 2: 7 data bits + cont=1"
    byte3: "Byte 3: 7 data bits + cont=1"
    byte_n: "..."
    byte9: "Byte 9: 7 data bits + cont=0"
  }
}
# Row 3: Example 300 Encoding
example_300: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  encoding_300: {
    shape: sql_table
    label: "Example: Encoding 300"
    decimal: "Decimal: 300"
    binary: "Binary: 100101100"
    note: "9 bits, needs 2 bytes"
  }
  byte_breakdown: {
    shape: sql_table
    label: "300 = 0xAC 0x02"
    byte1_hex: "Byte 1: 0xAC (10101100)"
    byte1_bits: "b7=1 cont | 0101100 data"
    byte2_hex: "Byte 2: 0x02 (00000010)"
    byte2_bits: "b7=0 last | 0000010 data"
    calculation: "0xAC + (0x02 << 7) = 172 + 128 = 300"
  }
  fixed_comparison: {
    shape: sql_table
    label: "vs Fixed 8-Byte Encoding"
    varint_bytes: "Varint: 2 bytes"
    fixed_bytes: "Fixed: 8 bytes"
    savings: "Savings: 75%"
    note: "Varint wins for small integers"
  }
}
# Row 4: Practical Examples
practical_examples: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  common_values: {
    shape: sql_table
    label: "Common Value Encodings"
    value_1: "1 → 0x01 (1 byte)"
    value_127: "127 → 0x7F (1 byte)"
    value_128: "128 → 0x80 0x01 (2 bytes)"
    value_300: "300 → 0xAC 0x02 (2 bytes)"
    value_16383: "16383 → 0xFF 0x7F (2 bytes)"
    value_16384: "16384 → 0x80 0x80 0x01 (3 bytes)"
  }
  database_usage: {
    shape: sql_table
    label: "Database Usage"
    rowid: "Rowid: 1, 2, 3... (1-2 bytes typically)"
    page_offset: "Page offsets: < 1M (2-3 bytes)"
    string_length: "String lengths: varies (1-3 bytes)"
    column_count: "Column counts: varies (1-2 bytes)"
  }
}
# Row 5: Encoding Process
process: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  encoding_algorithm: {
    shape: class
    label: "Encoding Algorithm"
    +encode_varint: "(value): *uint8"
    -while_value: "value >= 0x80"
    -output_byte: "(value & 0x7F) | 0x80"
    -value_shift: "value >>= 7"
    -final_byte: "value & 0x7F"
  }
  decoding_algorithm: {
    shape: class
    label: "Decoding Algorithm"
    +decode_varint: "(*uint8): uint64"
    -result: "result = 0"
    -shift: "shift = 0"
    -while_byte: "byte & 0x80 != 0"
    -extract: "result |= (byte & 0x7F) << shift"
    -shift_add: "shift += 7"
    -final: "result | (byte << shift)"
  }
}
overview -> bit_layout: "Encodes integers efficiently"
bit_layout -> example_300: "Example demonstrates encoding"
example_300 -> practical_examples: "Common database values"
practical_examples -> process: "Implementation algorithms"