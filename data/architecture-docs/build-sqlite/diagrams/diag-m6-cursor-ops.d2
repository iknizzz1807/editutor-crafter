direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
# ============== ROW 1: Cursor API Interface ==============
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cursor_api: "Cursor API" {
    shape: class
    label: "Cursor Interface"
    +open(table_id): "Cursor*"
    +rewind: "void"
    +next: "bool"
    +search(key): "bool"
    +getRow: "Row*"
    +close: "void"
    style.fill: "#E8F4FD"
    style.stroke: "#1E90FF"
    style.stroke-width: 2
  }
  cursor_state: "Cursor State" {
    shape: sql_table
    label: "Cursor State"
    f0: "page_number | uint32 | Current page"
    f1: "cell_index  | uint16 | Position in page"
    f2: "is_valid   | bool   | At valid row?"
    f3: "at_end     | bool   | Past last row?"
    style.fill: "#FFF8DC"
  }
}
# ============== ROW 2: B-tree Traversal ==============
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  btree_traversal: "B-tree Traversal Flow" {
    direction: right
    style.fill: "#F0FFF0"
    step1: "1. Open" {
      label: "Open(table_id)"
      shape: rectangle
      style.fill: "#90EE90"
    }
    step2: "2. Rewind" {
      label: "Rewind() → Root"
      shape: rectangle
      style.fill: "#90EE90"
    }
    step3: "3. Descend" {
      label: "Descend to Leaf"
      shape: rectangle
      style.fill: "#90EE90"
    }
    step4: "4. First Row" {
      label: "Cell[0]"
      shape: rectangle
      style.fill: "#90EE90"
    }
    arrow1: step1 -> step2: "init"
    arrow2: step2 -> step3: "if interior"
    arrow3: step3 -> step4: "goto leaf"
  }
  btree_structure: "B-tree Structure" {
    direction: right
    style.fill: "#FFF0F5"
    root: "Root Page" {
      shape: rectangle
      label: "Root (pg 1)"
      style.fill: "#DDA0DD"
    }
    interior: "Interior Pages" {
      direction: right
      style.fill: transparent
      int1: "Int (pg 2)" {
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      int2: "Int (pg 3)" {
        shape: rectangle
        style.fill: "#DDA0DD"
      }
    }
    leaves: "Leaf Pages" {
      direction: right
      style.fill: transparent
      leaf1: "Leaf (pg 10)" {
        shape: sql_table
        label: "Leaf: rows 1-100"
        r1: "rowid=1 | data..."
        r2: "rowid=2 | data..."
        r3: "rowid=3 | data..."
        style.fill: "#98FB98"
      }
      leaf2: "Leaf (pg 11)" {
        shape: sql_table
        label: "Leaf: rows 101-200"
        r1: "rowid=101 | data..."
        r2: "rowid=102 | data..."
        style.fill: "#98FB98"
      }
    }
    # Tree structure connections
    root -> int1: "keys < 50"
    root -> int2: "keys >= 50"
    int1 -> leaf1: "ptr"
    int2 -> leaf2: "ptr"
  }
}
# ============== ROW 3: Row Processing with WHERE ==============
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  processing_loop: "Processing Loop" {
    shape: sequence_diagram
    style.fill: "#F5F5F5"
    cursor: Cursor
    filter: "WHERE Filter"
    output: "Result Set"
    cursor.t1: cursor -> filter: "Row (rowid=42)"
    filter: filter -> filter: "Evaluate WHERE clause"
    filter -> output: "Pass?" {
      style.stroke-dash: 3
    }
    cursor.t2: cursor -> filter: "Next Row"
  }
  where_clause: "WHERE Integration" {
    direction: right
    style.fill: "#FFEFD5"
    eval_flow: "Expression Evaluation" {
      shape: class
      label: "Filter Logic"
      -expr: "Expression*"
      -row: "Row*"
      +evaluate: "ThreeValued"
      +and: "ThreeValued"
      +or: "ThreeValued"
      style.fill: "#FFE4B5"
    }
    tpcodes: "Bytecode Opcodes" {
      shape: sql_table
      label: "Filter Ops"
      op1: "Column   | Load column value"
      op2: "Integer  | Load constant"
      op3: "Gte     | Compare >="
      op4: "And     | Boolean AND"
      op5: "IfNot   | Skip if false"
    }
  }
}
# ============== ARROWS BETWEEN ROWS ==============
row1 -> row2: "Creates & manages"
row2 -> row3: "Returns rows for filtering"
# ============== LEGEND ==============
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#CCCCCC"
  l1: "State" {
    shape: text
    style.font-color: "#333"
  }
  l2: "Action" {
    shape: text
    style.font-color: green
  }
  l3: "Data" {
    shape: text
    style.font-color: blue
  }
}