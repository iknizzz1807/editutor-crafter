direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Title Container
header: {
  shape: rectangle
  style.stroke: transparent
  style.fill: transparent
  title: |md
    # INSERT/UPDATE/DELETE Execution Flow
    *From SQL Input to B-Tree Storage*
  |
}

# Shared Frontend Path
shared_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  sql_input: "SQL Input" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.bold: true
  }

  parser: "Parser (tokenize.c)" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
  }

  compiler: "Code Generator (build.c)" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }

  vdbe: "VDBE VM (vdbe.c)" {
    shape: rectangle
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    style.bold: true
  }

  sql_input -> parser: "Query String"
  parser -> compiler: "AST / Parse Tree"
  compiler -> vdbe: "Bytecode Ops"
}

# Parallel Execution Flows
flows_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  # INSERT Branch
  insert_branch: "INSERT Execution Path" {
    direction: down
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
    style.stroke-width: 3
    style.border-radius: 8
    
    i1: "1. Op_OpenWrite" {
      shape: rectangle
      style.fill: "#B3E5FC"
      width: 160
    }
    i2: "2. Op_MakeRecord" {
      shape: rectangle
      style.fill: "#B3E5FC"
      width: 160
    }
    i3: "3. Op_IdxInsert" {
      shape: rectangle
      style.fill: "#81D4FA"
      width: 160
    }
    i4: "4. Index Updates" {
      shape: rectangle
      style.fill: "#4FC3F7"
      width: 160
    }
    i5: "5. Log Entry (WAL)" {
      shape: rectangle
      style.fill: "#29B6F6"
      width: 160
    }

    i1 -> i2 -> i3 -> i4 -> i5
  }

  # UPDATE Branch
  update_branch: "UPDATE Execution Path" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
    style.stroke-width: 3
    style.border-radius: 8

    u1: "1. Op_OpenWrite" {
      shape: rectangle
      style.fill: "#FFECB3"
      width: 160
    }
    u2: "2. Op_SeekRowid" {
      shape: rectangle
      style.fill: "#FFECB3"
      width: 160
    }
    u3: "3. Op_Column (Read)" {
      shape: rectangle
      style.fill: "#FFE082"
      width: 160
    }
    u4: "4. Op_Insert (New)" {
      shape: rectangle
      style.fill: "#FFD54F"
      width: 160
    }
    u5: "5. Mark Page Dirty" {
      shape: rectangle
      style.fill: "#FFCA28"
      width: 160
    }

    u1 -> u2 -> u3 -> u4 -> u5
  }

  # DELETE Branch
  delete_branch: "DELETE Execution Path" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    style.border-radius: 8

    d1: "1. Op_OpenWrite" {
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 160
    }
    d2: "2. Op_NotExists (Seek)" {
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 160
    }
    d3: "3. Op_Delete" {
      shape: rectangle
      style.fill: "#EF9A9A"
      width: 160
    }
    d4: "4. Rebalance B-Tree" {
      shape: rectangle
      style.fill: "#E57373"
      width: 160
    }
    d5: "5. Index Cleanup" {
      shape: rectangle
      style.fill: "#EF5350"
      width: 160
    }

    d1 -> d2 -> d3 -> d4 -> d5
  }
}

# Storage Infrastructure Layer
storage_row: "Storage Layer (pager.c / btree.c)" {
  direction: right
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 3
  style.border-radius: 8

  buffer_pool: "Pager Cache" {
    shape: rectangle
    style.fill: "#E1BEE7"
  }
  
  btree_pages: "B+Tree Pages" {
    shape: rectangle
    style.fill: "#CE93D8"
  }
  
  wal_log: "WAL / Journal File" {
    shape: cylinder
    style.fill: "#AB47BC"
    style.stroke: "#7B1FA2"
  }

  buffer_pool -> btree_pages: "Page I/O"
  btree_pages -> wal_log: "Commit Log"
}

# Global Routing
shared_row.vdbe -> flows_row: "Execute"

insert_branch.i5 -> storage_row.wal_log: "Log Record" {
  style.stroke: "#0288D1"
  style.stroke-dash: 4
}

update_branch.u5 -> storage_row.buffer_pool: "Modify" {
  style.stroke: "#FFA000"
  style.stroke-dash: 4
}

delete_branch.d5 -> storage_row.btree_pages: "Remove" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 4
}

# Legend Metadata
legend: {
  near: bottom-right
  direction: down
  
  l1: "INSERT Path" {
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
  }
  l2: "UPDATE Path" {
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
  }
  l3: "DELETE Path" {
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
  }
}