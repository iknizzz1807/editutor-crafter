direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_box: {
  label: "Row Record Deserialization Architecture"
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#E3F2FD"
    stroke-width: 2
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  input_label: "Input Layer" {
    shape: parallelogram
    label: "Serialized Cell Payload"
    style: {
      font-size: 16
      bold: true
      fill: "#BBDEFB"
    }
  }
  
  serialized_bytes: {
    shape: sql_table
    label: "Byte Stream (raw bytes)"
    header: "Offset | Component | Sample"
    r1: "0x00 | payload_len | varint"
    r2: "0x.. | rowid       | varint"
    r3: "0x.. | col1_type   | 1-byte"
    r4: "0x.. | col1_val    | dynamic"
    r5: "0x.. | col2_type   | 1-byte"
    footer: "Continues for N columns"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  header_proc: "Step 1: Header Parser" {
    direction: down
    
    payload_decode: {
      label: "varint_decode(payload_length)"
      code: |'c
        // Bit 7 is continuation
        // 0x97 0x01 -> 151
        b0 = bytes[0] & 0x7F; // 23
        b1 = bytes[1] & 0x7F; // 1
        val = b0 | (b1 << 7); // 151
      '|
    }
    
    rowid_decode: {
      label: "varint_decode(rowid)"
      code: |'c
        // 0x0A -> 10
        b0 = bytes[offset++];
        rowid = b0 & 0x7F;
      '|
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  col_logic: {
    shape: sql_table
    label: "Step 2: Column Iterator (StateMachine)"
    f1: "READ_TYPE  | Read 1-byte marker"
    f2: "READ_VALUE | Dispatch to handler"
    f3: "NEXT_COL   | Increment offset"
    f4: "DONE       | Offset >= payload_len"
  }

  type_map: {
    shape: sql_table
    label: "Type Handler Registry"
    t0: "0x00 | NULL    | Skip read"
    t1: "0x01 | INTEGER | varint_signed"
    t2: "0x02 | FLOAT   | 8-byte double"
    t3: "0x03 | TEXT    | len:varint + data"
    t4: "0x04 | BLOB    | len:varint + data"
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  full_record: {
    shape: sql_table
    label: "Deserialized Internal Buffer"
    r0: "ID: 42"
    r1: "C1: 'Alice' (TEXT)"
    r2: "C2: 30 (INT)"
    r3: "C3: 'active' (TEXT)"
  }

  projection: {
    shape: sql_table
    label: "Projected Result (SELECT C1, C2)"
    p1: "C1: 'Alice' [Keep]"
    p2: "C2: 30      [Keep]"
    style.fill: "#C8E6C9"
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  final_struct: {
    shape: class
    label: "Row (sqlite_row.h)"
    -rowid: "uint64_t"
    -col_count: "uint16_t"
    -values: "Value*"
    +get_int(idx): "int64_t"
    +get_text(idx): "char*"
  }
}

# Global Layout Connections
row1 -> row2: "Read Header"
row2 -> row3: "Enter Loop"
row3 -> row4: "Populate"
row4 -> row5: "Return Struct"

# Annotations (Root Level)
ann_performance: |md
  ### Efficiency Constraints
  - **Zero-Copy**: Return pointers into the page buffer where possible.
  - **Late Projection**: Skip decoding columns not found in the projection bitmask.
  - **Varint Overhead**: Max 9 bytes for 64-bit integers.
| {
  near: center-right
  shape: rectangle
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
  }
}

legend_box: {
  near: bottom-right
  shape: rectangle
  label: "Execution Legend"
  
  flow: "Blue: Data Flow" {
    style.font-color: blue
  }
  proj: "Green: Projected Data" {
    style.font-color: darkgreen
  }
  warn: "Yellow: Metadata/Header" {
    style.font-color: brown
  }
}

type_color_key: {
  near: bottom-left
  shape: sql_table
  label: "Type Marker Legend"
  int: "0x01 | blue fill   | Integer"
  flt: "0x02 | cyan fill   | Float"
  txt: "0x03 | green fill  | Text"
  blb: "0x04 | orange fill | Blob"
}

# Style filters
row4.projection.p1.style.fill: "#A5D6A7"
row4.projection.p2.style.fill: "#A5D6A7"
row3.type_map.t3.style.fill: "#E8F5E9"
row3.type_map.t1.style.fill: "#E3F2FD"