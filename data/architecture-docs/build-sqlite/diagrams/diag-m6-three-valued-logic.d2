direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "SQL Three-Valued Logic Truth Tables" {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}
# Three-valued logic explanation
explanation: |md
  SQL uses **three-valued logic**: TRUE, FALSE, and NULL (unknown).
  Every comparison can result in NULL, not just TRUE or FALSE.
  NULL = NULL evaluates to NULL (not TRUE!) — use IS NULL instead.
| {
  near: top-center
  style.font-size: 14
  style.fill: "#FFF8E1"
}
# Main container for truth tables
truth_tables: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  # AND Truth Table
  and_table: "AND (∧)" {
    shape: sql_table
    label: "AND (conjunction)"
    T: "TRUE"
    F: "FALSE"
    N: "NULL"
    t_row: "T ∧ T = T | T ∧ F = F | T ∧ N = N"
    f_row: "F ∧ T = F | F ∧ F = F | F ∧ N = F"
    n_row: "N ∧ T = N | N ∧ F = F | N ∧ N = N"
    style.fill: "#E3F2FD"
  }
  # OR Truth Table
  or_table: "OR (∨)" {
    shape: sql_table
    label: "OR (disjunction)"
    T: "TRUE"
    F: "FALSE"
    N: "NULL"
    t_row: "T ∨ T = T | T ∨ F = T | T ∨ N = T"
    f_row: "F ∨ T = T | F ∨ F = F | F ∨ N = N"
    n_row: "N ∨ T = T | N ∨ F = N | N ∨ N = N"
    style.fill: "#E8F5E9"
  }
  # NOT Truth Table
  not_table: "NOT (¬)" {
    shape: sql_table
    label: "NOT (negation)"
    input: "Input"
    t_row: "¬TRUE = FALSE"
    f_row: "¬FALSE = TRUE"
    n_row: "¬NULL = NULL"
    style.fill: "#FCE4EC"
  }
}
# Key insights
insights: "Key Insights" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  # NULL = NULL never matches
  null_equality: "NULL Equality" {
    shape: sql_table
    label: "NULL Comparison"
    correct: "WHERE x IS NULL → checks for NULL"
    wrong: "WHERE x = NULL → NEVER matches!"
    note: "NULL = NULL evaluates to NULL (unknown), not TRUE"
    style.fill: "#FFEBEE"
  }
  # WHERE clause filters
  where_filter: "WHERE Clause Behavior" {
    shape: sql_table
    label: "WHERE Filters"
    true_pass: "TRUE → row passes filter"
    false_skip: "FALSE → row is skipped"
    null_skip: "NULL → row is skipped (unknown)"
    style.fill: "#FFF3E0"
  }
}
# Arrow connections
and_table -> null_equality: "Explains why"
or_table -> where_filter: "Controls filtering"
not_table -> null_equality: "Negation rules"
# Bottom note about practical implications
bottom_note: |md
  **Practical Impact:**
  • WHERE status = 'active' OR premium = TRUE
  If status is NULL and premium is FALSE:
  → (NULL) OR (FALSE) = NULL → row is SKIPPED!
  This is why `WHERE x IS NULL` is required for NULL checks.
| {
  near: bottom-center
  style.font-size: 16
  style.fill: "#ECEFF1"
  style.bold: true
}