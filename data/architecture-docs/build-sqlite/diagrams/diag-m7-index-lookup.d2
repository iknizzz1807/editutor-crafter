direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Index Lookup Execution: WHERE name = 'Alice'
title: {
  label: "Index Lookup Execution: WHERE name = 'Alice'"
  shape: text
  style.font-size: 28
  style.bold: true
}

# Row 1: Query and Overview
query_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sql_query: {
    shape: rectangle
    label: "SQL Query"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    sql_text: |sql
      SELECT * FROM users
      WHERE name = 'Alice';
    |
  }
  pages_read: {
    shape: rectangle
    label: "I/O Performance Metrics"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    comparison: |'md
      **Index Scan: 5 pages**
      - Index root: 1
      - Index path: 3
      - Table leaf: 1
      **vs Full Scan: 1000 pages**
      Efficiency: 200x speedup
    '|
  }
}

# Row 2: Index B+tree Traversal
index_traversal: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  index_root: {
    shape: sql_table
    label: "Index Root Page (Page 1)"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    row0: "key: name | val: rowid_ptr"
    row1: "Aaron | ptr -> Page 2"
    row2: "Amy | ptr -> Page 5"
    row3: "Bob | ptr -> Page 9"
    total: "4KB Page | Root Node"
  }
  index_interior: {
    shape: sql_table
    label: "Index Interior Page (Page 5)"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    row0: "child_page | max_name_in_child"
    row1: "Page 10 | Alex"
    row2: "Page 12 | Alice"
    row3: "Page 15 | Dave"
    total: "4KB Page | Interior Node"
  }
  index_leaf: {
    shape: sql_table
    label: "Index Leaf Page (Page 12)"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    row0: "key: name | val: rowid"
    row1: "Alice | 42"
    row2: "Alice | 137"
    row3: "Alice | 256"
    status: "✓ Match Found: rowid 42"
  }
}

# Row 3: Transition Step
index_to_table: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lookup_transition: {
    shape: rectangle
    label: "Row Retrieval Logic"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    step1: "1. Capture rowid [42] from Index"
    step2: "2. Probe Table B+tree with Primary Key"
  }
}

# Row 4: Table B+tree Lookup
table_lookup: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  table_root: {
    shape: sql_table
    label: "Table Root (Page 0)"
    style.fill: "#E1F5FE"
    style.stroke: "#0277BD"
    row0: "range: rowid | val: page_ptr"
    row1: "1-100 | ptr -> Page 20"
    row2: "101-200 | ptr -> Page 25"
    row3: "rowid=42 -> Page 20"
  }
  table_leaf: {
    shape: sql_table
    label: "Table Leaf Page (Page 20)"
    style.fill: "#E1F5FE"
    style.stroke: "#0277BD"
    row0: "0x00 | rowid | 42"
    row1: "0x08 | name  | Alice"
    row2: "0x20 | email | alice@example.com"
    row3: "0x60 | age   | 28"
    status: "✓ Row returned to executor"
  }
}

# Row 5: Result
result_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  result_output: {
    shape: rectangle
    label: "Result Set Output"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    result: |'md
      | id | name  | email             | age |
      |:---|:------|:------------------|:----|
      | 42 | Alice | alice@example.com | 28  |
    '|
  }
  summary: {
    shape: rectangle
    label: "Plan Summary"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    summary_text: |'md
      **Execution Summary:**
      - Strategy: Index Seek
      - Index Pages: 3
      - Table Pages: 2
      - Total I/O: 5 pages
    '|
  }
}

# Connections
query_row -> index_traversal: "Predicate: name='Alice'"
index_traversal -> index_to_table: "Map rowid=42"
index_to_table -> table_lookup: "Probe PK=42"
table_lookup -> result_row: "Success"

# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  index_color: "Index B+tree Pages" {
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
  table_color: "Table B+tree Pages" {
    style.fill: "#E1F5FE"
    style.stroke: "#0277BD"
  }
  process_color: "Process Stage" {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
}