direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Title
title: Secondary Index B+tree for CREATE INDEX idx ON t(name) {
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}
# Row 1: Overview of Index Structure
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  index_overview: "Index B+tree Structure" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2
    width: 200
    height: 120
    label: "Index B+tree\n(root page 5)"
  }
  leaf_link: Leaf-to-Leaf Link {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    width: 180
    height: 80
    label: "Leaves Linked\n(Next/Prev Pointers)"
  }
  double_lookup: Double Lookup Flow {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
    width: 180
    height: 80
    label: "1. Index → rowid\n2. rowid → Table"
  }
}
row1.index_lookup -> row1.double_lookup: "index scan" {
  style.stroke: green
}
# Row 2: Leaf Node Detail
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leaf_structure: "Leaf Node (Page 10)" {
    shape: sql_table
    label: "Index B+tree Leaf (page 10)"
    row0: "name_value (TEXT) | rowid (INT)"
    row1: "--- --- --- | ---"
    row2: "Alice | 1"
    row3: "Bob | 2"
    row4: "Carol | 5"
    row5: "David | 8"
    row6: "next_page: 11 | (link to next leaf)"
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    style.stroke-width: 2
    width: 350
  }
  leaf_cell: "Leaf Cell Format" {
    shape: sql_table
    label: "Single Cell (name_value)"
    row0: "0x00 | payload_size (varint)"
    row1: "0x02 | name_value (N bytes)"
    row2: "varint | rowid (8 bytes)"
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
    width: 280
  }
}
row1.index_lookup -> row2.leaf_structure: "index lookup" {
  style.stroke-dash: 3
}
# Row 3: Internal Node Structure
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  internal_structure: "Internal Node (Page 5)" {
    shape: sql_table
    label: "Index B+tree Internal (root)"
    row0: "separator_key | child_page"
    row1: "--- | ---"
    row2: "Carol | 10"
    row3: "--- | 11"
    row4: "right_child: 12 | (rightmost pointer)"
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    style.stroke-width: 2
    width: 300
  }
  search_flow: "Search: name = 'Bob'" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 250
    height: 150
    label: |md
      **Search Flow:**
      1. Compare 'Bob' with separator 'Carol'
      2. 'Bob' < 'Carol' → go left
      3. Follow child_page 10
      4. Scan leaf for 'Bob'
      5. Get rowid = 2
    |
  }
}
row2.leaf_structure -> row3.internal_structure: "child" {
  style.stroke: blue
  style.stroke-dash: 3
}
# Row 4: Double Lookup Process
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1_index: "Step 1: Index Lookup" {
    shape: sql_table
    label: "1. Index Search → rowid"
    row0: "Operation"
    row1: "B+tree search for 'Bob'"
    row2: "Found: rowid = 2"
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
    width: 220
  }
  arrow1: "→" {
    shape: text
    style.font-size: 32
    style.bold: true
    style.font-color: "#666"
  }
  step2_table: "Step 2: Table Lookup" {
    shape: sql_table
    label: "2. Table Lookup → row"
    row0: "Operation"
    row1: "B-tree search for rowid=2"
    row2: "Get: {name='Bob', age=25}"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    width: 220
  }
  arrow2: "→" {
    shape: text
    style.font-size: 32
    style.bold: true
    style.font-color: "#666"
  }
  result: Final Result {
    shape: rectangle
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    style.bold: true
    label: "SELECT * FROM t\nWHERE name = 'Bob'\n\n→ {id:2, name:'Bob', age:25}"
    width: 180
  }
}
row3.internal_structure -> row4.step1_index: "found rowid" {
  style.stroke: green
  style.stroke-dash: 3
}
# Row 5: Range Scan Example
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  range_query: "Range Query: name > 'Bob' AND name < 'David'" {
    shape: rectangle
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"
    width: 280
    label: |md
      **Range Scan Steps:**
      1. Find first key > 'Bob' (Carol, rowid=5)
      2. Follow next_page link to leaf 11
      3. Get David (rowid=8)
      4. Return rowids: [5, 8]
    |
  }
  leaf_chain: Leaf Chain {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    leaf10: "Leaf 10" {
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FF8F00"
      label: "A-C\n[1,2,5]"
      width: 80
      height: 50
    }
    leaf11: "Leaf 11" {
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FF8F00"
      label: "D-F\n[8,12]"
      width: 80
      height: 50
    }
    leaf12: "Leaf 12" {
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FF8F00"
      label: "G-Z\n[15,20]"
      width: 80
      height: 50
    }
    leaf10 -> leaf11: "next" {
      style.stroke: "#FF9800"
      style.stroke-width: 2
      source-arrowhead: triangle
      target-arrowhead: triangle
    }
    leaf11 -> leaf12: "next" {
      style.stroke: "#FF9800"
      style.stroke-width: 2
      source-arrowhead: triangle
      target-arrowhead: triangle
    }
  }
}
row4.result -> row5.range_query: "extends to" {
  style.stroke-dash: 3
  style.opacity: 0.5
}
# Legend
legend: {
  near: bottom-right
  direction: right
  style.fill: white
  style.stroke: "#CCC"
  style.stroke-dash: 3
  legend_index: Index B+tree {
    shape: text
    style.font-color: "#1976D2"
  }
  legend_table: Table B-tree {
    shape: text
    style.font-color: "#388E3C"
  }
  legend_lookup: Lookup Flow {
    shape: text
    style.font-color: "#E91E63"
  }
}