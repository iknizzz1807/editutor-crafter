direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# TITLE SECTION
# -----------------------------------------------------------------------------
title: "EXPLAIN Plan Output: SELECT * FROM t JOIN u ON t.id = u.tid WHERE t.x = 5" {
  shape: text
  style.font-size: 28
  style.bold: true
}
title.near: top-center

# -----------------------------------------------------------------------------
# PLAN HIERARCHY (Execution Tree)
# -----------------------------------------------------------------------------
plan_hierarchy: {
  direction: down
  style.stroke: transparent
  style.fill: transparent

  header: {
    shape: sql_table
    label: "EXPLAIN Output Columns (VDBE)"
    id: "id      | Node ID (depth-first order)"
    parent: "parent  | Parent Node ID"
    opcode: "opcode  | Operation Type"
    params: "p1..p3  | Operation Parameters"
    comment: "comment | Index or Search Details"
    style.fill: "#E8F4FD"
  }

  row_0: {
    shape: sql_table
    label: "Node 0 (Root)"
    f0: "0 | null | COMPOUND SUBQUERY"
    f1: "5 | 0 | null"
    f2: "Execute compound SELECT"
  }

  row_1: {
    shape: sql_table
    label: "Node 1 (Scan)"
    f0: "1 | 0 | SCAN"
    f1: "0 | 6 | 0"
    f2: "USING INDEX idx_x"
  }

  row_2: {
    shape: sql_table
    label: "Node 2 (Search)"
    f0: "2 | 1 | SEARCH"
    f1: "1 | 3 | u.tid=t.id"
    f2: "USING INTEGER PRIMARY KEY"
  }

  row_3: {
    shape: sql_table
    label: "Node 3 (Result)"
    f0: "3 | 2 | RESULT"
    f1: "0 | 4 | 2"
    f2: "t.*, u.*"
  }

  header -> row_0: "sqlite3_step() | init"
  row_0 -> row_1: "Cursor 0 | scan"
  row_1 -> row_2: "Correlated | join"
  row_2 -> row_3: "Yield | row"
}

# -----------------------------------------------------------------------------
# SUPPORTING METADATA ROW
# -----------------------------------------------------------------------------
metadata: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  notes: {
    shape: sql_table
    label: "Column Reference Guide"
    col_id: "id      | Execution sequence"
    col_parent: "parent  | Tree parent (0=none)"
    col_notused: "not_used| Unused branch flag"
    col_opcode: "opcode  | Operation (SCAN/SEARCH)"
    col_p1: "p1      | Table/Cursor index"
    col_p2: "p2      | Column count/Jump"
    col_p3: "p3      | Index name or filter"
    style.fill: "#F0F0F0"
  }

  data_flow: {
    label: "Execution Interpretation"
    direction: down
    step1: "1. Filter t.x=5" {
      style.fill: "#FFB6C1"
    }
    step2: "2. idx_x lookup" {
      style.fill: "#90EE90"
    }
    step3: "3. JOIN u by tid" {
      style.fill: "#87CEEB"
    }
    step4: "4. Return results" {
      style.fill: "#DDA0DD"
    }
    step1 -> step2: "Filter first"
    step2 -> step3: "Join logic"
    step3 -> step4: "Project columns"
  }
}

# -----------------------------------------------------------------------------
# LEGEND AND LOGIC
# -----------------------------------------------------------------------------
legend: {
  label: "Plan Legend"
  idx_x_legend: "idx_x" {
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: green
  }
  pk_lookup_legend: "PRIMARY KEY" {
    shape: rectangle
    style.fill: "#87CEEB"
    style.stroke: blue
  }
  correlation_note: |md
    **Plan Interpretation:**
    - Root (0): COMPOUND SUBQUERY
    - Child (1): SCAN t via INDEX idx_x
    - Grandchild (2): SEARCH u via tid=t.id
    - Result (3): Combine t.*, u.*
  | {
    width: 450
  }
}
legend.near: bottom-right

# Connections between layout sections
plan_hierarchy -> metadata: "Implementation Logic"