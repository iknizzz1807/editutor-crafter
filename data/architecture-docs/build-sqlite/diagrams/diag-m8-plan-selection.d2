direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "Query Plan Selection & Optimization Pipeline"
  style: {
    font-size: 24
    bold: true
  }
}

# --- LAYER 1: Analysis & Routing ---
analysis_layer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  parser_out: {
    label: "Parse Tree (AST)"
    shape: rectangle
    style.fill: "#E3F2FD"
  }

  analyze: {
    label: "Query Analyzer (analyze.c)"
    shape: rectangle
    style.fill: "#E8F5E9"
  }

  routing_decision: {
    label: "Is Multi-table?"
    shape: diamond
    style.fill: "#FFF3E0"
  }

  parser_out -> analyze: "AST"
  analyze -> routing_decision: "Metadata"
}

# --- LAYER 2: Planning Paths ---
planning_paths: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  single_table_env: "Single Table Logic" {
    direction: down
    style.fill: "#F1F8E9"
    style.stroke-dash: 5

    get_stats: {
      label: "Stat Lookup"
      shape: rectangle
    }

    stats_struct: {
      shape: sql_table
      label: "struct StatEntry (catalog.h)"
      f0: "0x00 | uint64_t | row_count"
      f1: "0x08 | uint32_t | page_count"
      f2: "0x0C | float    | n_distinct"
      sz: "Total: 16 bytes"
    }

    enumerate: {
      label: "Enumerate Paths"
      shape: rectangle
    }

    get_stats -> stats_struct: "Lookup"
    get_stats -> enumerate: "Stats"
  }

  multi_table_env: "Join Optimizer" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke-dash: 5

    join_gen: {
      label: "Order Enumerator"
      shape: rectangle
    }

    join_algo: {
      label: "Join Logic"
      code: |'c
        // Dynamic Programming
        for (int i = 1; i < (1 << n); i++) {
          best_plan[i] = find_cheapest_join(i);
        }
      '|
    }

    join_gen -> join_algo: "n! Space"
  }

  routing_decision -> single_table_env.get_stats: "No"
  routing_decision -> multi_table_env.join_gen: "Yes"
}

# --- LAYER 3: Cost Modeling ---
cost_modeling: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  table_scan_cost: {
    label: "Cost: Table Scan"
    shape: rectangle
    style.fill: "#FFCCBC"
    code: |'c
      cost = pages * seq_io_factor;
      // 10,000 * 1.0
      return 10000;
    '|
  }

  index_scan_cost: {
    label: "Cost: Index Scan"
    shape: rectangle
    style.fill: "#B2DFDB"
    code: |'c
      cost = (idx_pages + matched) * rand_io;
      // (50 + 1000) * 4.0
      return 4200;
    '|
  }

  single_table_env.enumerate -> table_scan_cost: "Full Scan"
  single_table_env.enumerate -> index_scan_cost: "Index Seek"
}

# --- LAYER 4: Comparison & Execution ---
selection_layer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  compare_node: {
    label: "Cost Comparator"
    shape: diamond
    style.fill: "#E0E0E0"
  }

  selected_plan: {
    label: "Selected Plan"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.stroke-width: 3
  }

  table_scan_cost -> compare_node: "10000"
  index_scan_cost -> compare_node: "4200"
  multi_table_env.join_algo -> compare_node: "Min(JoinCost)"

  compare_node -> selected_plan: "Winner"
}

# --- FINAL OUTPUT ---
vdbe_generation: {
  label: "VDBE Bytecode Generator (codegen.c)"
  shape: rectangle
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
  style.stroke-width: 3
}

selected_plan -> vdbe_generation: "OpTree"

# --- LEGEND ---
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 4

  header: |md
    **Query Planner Legend**
  |
  
  l1: "Blue Arrow | Data Flow" {
    style.font-color: blue
    style.stroke: blue
  }
  
  l2: "Diamond | Decision Node" {
    style.font-color: "#FF9800"
  }
  
  l3: "Green Box | Final Selection" {
    style.font-color: "#2E7D32"
    style.bold: true
  }
}

# Global Overrides for compliance
***.style.font-size: 14
(*** -> ***)[*]: {
  style.stroke: blue
}