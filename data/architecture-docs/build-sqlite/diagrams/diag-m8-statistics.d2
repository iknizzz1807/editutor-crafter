direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
analyze_flow: {
  label: "ANALYZE: Statistics Collection Flow"
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  step1: "1. ANALYZE Command" {
    style.fill: "#FFF3E0"
    cmd: |sql
      ANALYZE t;
    '|
    style.font-size: 14
  }
  step2: "2. Table Scan" {
    style.fill: "#E8F5E9"
    table_scan: {
      shape: sql_table
      label: "Table: t"
      row0: "id (PK) | INTEGER"
      row1: "name      | TEXT"
      row2: "age       | INTEGER"
      row3: "..."
      row4: "Total: 10,000 rows"
    }
  }
  step3: "3. Index Analysis" {
    style.fill: "#F3E5F5"
    index_info: {
      shape: sql_table
      label: "Index: idx(name)"
      row0: "Column: name"
      row1: "Distinct Values: 50"
      row2: "Distribution: uniform"
    }
  }
  step4: "4. Histogram Build" {
    style.fill: "#FFFDE7"
    histogram: {
      shape: sql_table
      label: "Histogram: t.id"
      row0: "Range          | Count | Density"
      row1: "1-1000         | 1000  | 0.0001"
      row2: "1001-2000      | 1000  | 0.0001"
      row3: "2001-3000      | 1000  | 0.0001"
      row4: "..."
      row5: "9001-10000     | 1000  | 0.0001"
    }
  }
  step5: "5. Storage" {
    style.fill: "#ECEFF1"
    sqlite_stat: {
      shape: sql_table
      label: "sqlite_stat (System Catalog)"
      row0: "tbl | idx  | stat"
      row1: "t   | NULL | 10000"
      row2: "t   | idx  | 1000050"
      row3: "t   | idx  | {50 1 0}"
    }
  }
  step1 -> step2: "Scan table\n& index pages"
  step2 -> step3: "Extract\ncolumn values"
  step3 -> step4: "Compute\ndistribution"
  step4 -> step5: "Persist\nstatistics"
}
example_details: {
  label: "Example Statistics Results"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  table_stats: {
    shape: sql_table
    label: "Table Statistics (sqlite_stat)"
    row0: "tbl   | stat       | ..."
    row1: "t     | 10000      | (row count)"
  }
  index_stats: {
    shape: sql_table
    label: "Index Statistics"
    row0: "idx   | stat       | ..."
    row1: "idx   | 1000050    | (rows × density)"
    row2: "      | {50 1 0}  | (n_distinct, ..."
    note: "n_distinct=50, 1 sample, no empty)"
  }
  usage: {
    shape: sql_table
    label: "Query Planner Usage"
    row0: "Query                  | Plan Choice"
    row1: "WHERE id = 5000       | Index (selective: 0.01%)"
    row2: "WHERE id > 5000       | Index scan (50%)"
    row3: "WHERE name = 'X'      | Index (50 distinct)"
    row4: "WHERE age > 18         | Table scan (no index)"
  }
}
analyze_flow -> example_details: "Used by\nquery planner" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 4
}