direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "SQLite Crash Recovery: Hot Journal Rollback Procedure"
  style: {
    font-size: 24
    bold: true
  }
}

recovery_logic: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  flow: {
    direction: right
    label: "Recovery Pipeline (pager.c)"
    
    startup: "01: Pager Startup" {
      shape: circle
      style.fill: "#E8F5E9"
    }

    check_journal: "02: Journal Probe" {
      shape: diamond
      label: "Hot Journal\nDetected?"
    }

    read_journal: "03: Parse Header" {
      shape: sql_table
      label: "struct JournalHeader"
      f0: "0x00 | uint32_t | nPages"
      f1: "0x04 | uint32_t | magic"
      f2: "0x08 | uint32_t | cksum"
      sz: "Total: 12 bytes + Page Data"
    }

    restore_pages: "04: Page Restoration" {
      shape: step
      label: "Iterative Rollback"
      code: |'c
        for (i=0; i < nPages; i++) {
          read_page(journal_fd, &pg);
          write_page(db_fd, pg.id, pg.data);
          verify_checksum(pg.cksum);
        }
      '|
    }

    delete_journal: "05: Commit Rollback" {
      shape: rectangle
      label: "Unlink Journal\n(Atomic Finish)"
    }

    open_normal: "06: Operation Ready" {
      shape: circle
      style.fill: "#E1F5FE"
    }

    startup -> check_journal: "fstat | check"
    check_journal -> read_journal: "True | ROLLBACK"
    check_journal -> open_normal: "False | NORMAL"
    read_journal -> restore_pages: "JournalHeader | loop"
    restore_pages -> delete_journal: "EOF | fsync"
    delete_journal -> open_normal: "unlink() | 0"
  }

  notes: {
    direction: down
    style.stroke-dash: 3
    
    journal_definition: {
      shape: callout
      label: "Hot Journal Criteria"
      content: |md
        A journal is **hot** if:
        1. It exists on disk.
        2. The main DB file is not locked by another process.
        3. The journal header is valid.
      |
    }

    rollback_safety: {
      shape: callout
      label: "Atomic Integrity"
      content: |md
        Restoration must complete fully.
        If power fails *during* restoration,
        the next startup sees the same hot
        journal and restarts the process.
      |
    }
  }
}

legend: {
  shape: package
  label: "Flow Legend"
  direction: right
  
  s: "Critical Path" {
    style.stroke: "#4CAF50"
    style.stroke-width: 4
  }
  d: "Decision Point" {
    shape: diamond
    style.fill: "#FFF3E0"
  }
  a: "Data Structure" {
    shape: sql_table
  }
}

# Positioning via root-level constants
title.near: top-center
legend.near: bottom-center