direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Rollback Journal File Structure
journal_file: "" {
  style.fill: "#F0F4F8"
  style.stroke: "#2D3748"
  style.stroke-width: 3
  # Header section
  header: Journal Header (12 bytes) {
    shape: sql_table
    label: "Journal Header"
    magic: "0xD9052439 | Magic number"
    page_count: "uint32 | Pages stored"
    sector_size: "uint32 | Sector size"
    device_flags: "uint32 | Device info"
    style.fill: "#E2E8F0"
  }
  # Arrow from header to page entries
  header -> page_entries: "N page entries"
  # Page entries container
  page_entries: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    page1: Page Entry 1 (4096 bytes) {
      shape: sql_table
      label: "Page Entry 1"
      page_num: "uint32 | Page #"
      content: "4096 bytes | Original page"
      style.fill: "#BEE3F8"
    }
    page2: Page Entry 2 (4096 bytes) {
      shape: sql_table
      label: "Page Entry 2"
      page_num: "uint32 | Page #"
      content: "4096 bytes | Original page"
      style.fill: "#BEE3F8"
    }
    page_n: Page Entry N (4096 bytes) {
      shape: sql_table
      label: "Page Entry N"
      page_num: "uint32 | Page #"
      content: "4096 bytes | Original page"
      style.fill: "#BEE3F8"
      style.opacity: 0.7
    }
  }
}
# Write Ordering Flow
write_flow: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  step1: Step 1: Write Original {
    shape: rectangle
    label: "1. Write ORIGINAL pages\nto journal file"
    style.fill: "#FED7D7"
    style.stroke: "#C53030"
    style.stroke-width: 2
  }
  step2: Step 2: fsync Journal {
    shape: rectangle
    label: "2. fsync journal\n(DURABLE)"
    style.fill: "#FED7D7"
    style.stroke: "#C53030"
    style.stroke-width: 2
  }
  step3: Step 3: Modify Database {
    shape: rectangle
    label: "3. Modify pages\nin buffer pool"
    style.fill: "#C6F6D5"
    style.stroke: "#2F855A"
    style.stroke-width: 2
  }
  step4: Step 4: Write to Disk {
    shape: rectangle
    label: "4. Write dirty pages\nto database file"
    style.fill: "#C6F6D5"
    style.stroke: "#2F855A"
    style.stroke-width: 2
  }
  step5: Step 5: Delete Journal {
    shape: rectangle
    label: "5. Delete journal\n(COMMIT complete)"
    style.fill: "#C6F6D5"
    style.stroke: "#2F855A"
    style.stroke-width: 2
  }
  step1 -> step2: "fsync"
  step2 -> step3: "safe to modify"
  step3 -> step4: "modify"
  step4 -> step5: "commit"
}
# Recovery Flow
recovery: "" {
  style.fill: "#FAF5FF"
  style.stroke: "#6B46C1"
  style.stroke-width: 2
  title: Recovery Scenarios {
    shape: text
    style.font-size: 18
    style.font-color: "#6B46C1"
  }
  crash1: Crash Before fsync {
    shape: rectangle
    label: "Crash BEFORE fsync\n→ Ignore journal (incomplete)"
    style.fill: "#FEB2B2"
    style.stroke: "#C53030"
  }
  crash2: Crash After fsync {
    shape: rectangle
    label: "Crash AFTER fsync\n→ Restore from journal (rollback)"
    style.fill: "#FEB2B2"
    style.stroke: "#C53030"
  }
  success: Clean Shutdown {
    shape: rectangle
    label: "COMMIT succeeds\n→ Delete journal"
    style.fill: "#9AE6B4"
    style.stroke: "#276749"
  }
  crash1 -> recovery_result1: "" {
    style.stroke: "#C53030"
    style.stroke-dash: 3
  }
  crash2 -> recovery_result2: "" {
    style.stroke: "#C53030"
    style.stroke-dash: 3
  }
  success -> recovery_result3: "" {
    style.stroke: "#276749"
  }
  recovery_result1: Original DB intact {
    shape: text
    style.fill: white
  }
  recovery_result2: Rollback complete {
    shape: text
    style.fill: white
  }
  recovery_result3: Transaction durable {
    shape: text
    style.fill: white
  }
}
# Key Properties
properties: "" {
  style.fill: "#FFFAF0"
  style.stroke: "#DD6B20"
  style.stroke-width: 2
  title: Key Properties {
    shape: text
    style.font-size: 16
    style.font-color: "#DD6B20"
  }
  prop1: {
    shape: text
    label: "• Original page images (UNDO log)"
    style.font-size: 14
  }
  prop2: {
    shape: text
    label: "• fsync BEFORE database modification"
    style.font-size: 14
  }
  prop3: {
    shape: text
    label: "• No commit marker - absence = rollback"
    style.font-size: 14
  }
  prop4: {
    shape: text
    label: "• Simple recovery: check journal existence"
    style.font-size: 14
  }
}
# Layout connections
journal_file -> write_flow: "Write ordering"
write_flow -> recovery: "Recovery"
journal_file -> properties: "Properties"