direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Transaction State Machine
title.shape: text
title.near: top-center

# Legend for state classification
legend: {
  style.fill: transparent
  style.stroke: transparent
  l1: IDLE {
    shape: circle
    style.fill: "#C7F1FF"
    style.stroke: "#1E90FF"
  }
  l2: ACTIVE {
    shape: circle
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
  }
  l3: COMMITTING {
    shape: circle
    style.fill: "#E0FFFF"
    style.stroke: "#20B2AA"
  }
  l4: ROLLBACK {
    shape: circle
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
  }
}
legend.near: bottom-right

# Main Transaction State Machine
tx_state_machine: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  # IDLE state - Auto-commit mode
  idle: {
    shape: circle
    width: 150
    height: 150
    style.fill: "#C7F1FF"
    style.stroke: "#1E90FF"
    style.stroke-width: 3
    label: |'md
      **IDLE**
      Ready for queries
      Auto-Commit Mode
    '|
  }

  # ACTIVE state - Transaction in progress
  active: {
    shape: circle
    width: 150
    height: 150
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
    style.stroke-width: 3
    label: |'md
      **ACTIVE**
      In Transaction
      Journaling pages
    '|
  }

  # COMMITTING state - Commit in progress
  committing: {
    shape: circle
    width: 150
    height: 150
    style.fill: "#E0FFFF"
    style.stroke: "#20B2AA"
    style.stroke-width: 3
    label: |'md
      **COMMITTING**
      Writing Marker
      Fsyncing Journal
    '|
  }

  # ROLLING_BACK state - Rollback in progress
  rolling_back: {
    shape: circle
    width: 150
    height: 150
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
    style.stroke-width: 3
    label: |'md
      **ROLLING_BACK**
      Restoring pages
      Clearing Journal
    '|
  }

  # Internal Transitions
  idle -> active: BEGIN {
    style.stroke: "#DAA520"
    style.stroke-width: 3
  }
  active -> committing: COMMIT {
    style.stroke: "#20B2AA"
    style.stroke-width: 3
  }
  active -> rolling_back: ROLLBACK {
    style.stroke: "#CD5C5C"
    style.stroke-width: 3
  }
  committing -> idle: Durable {
    style.stroke: "#1E90FF"
    style.stroke-width: 2
  }
  rolling_back -> idle: Restored {
    style.stroke: "#1E90FF"
    style.stroke-width: 2
  }
  
  # Auto-commit path
  idle -> idle: SQL Statement {
    style.stroke: "#9370DB"
    style.stroke-dash: 5
    style.stroke-width: 2
  }
}

# Implementation detail note
note_journal: |'md
  **Rollback Journal Logic:**
  1. BEGIN: Start tracking
  2. Modify: Page -> Journal
  3. COMMIT: Fsync marker
  4. ROLLBACK: Restore original
'|
note_journal.shape: callout
note_journal.style.fill: "#F5F5F5"
note_journal.style.stroke: "#666666"
note_journal.near: top-right

note_journal -> tx_state_machine.active: "Implementation"