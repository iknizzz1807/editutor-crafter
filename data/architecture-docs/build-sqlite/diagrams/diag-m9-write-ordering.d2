direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Timeline container
write_ordering: "Write Ordering Guarantees (Rollback Journal)" {
  # Title explanation
  explanation: |md
    Critical sequence that prevents torn pages and ensures ACID
    Key: fsync(journal) MUST happen BEFORE writing to database
  | {
    shape: rectangle
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
  }
  # Phase 1: Transaction Start
  phase1: "1. BEGIN Transaction" {
    style.fill: "#D4EDDA"
    style.stroke: "#155724"
    txn_state: "State: ACTIVE"
    action: "Start tracking modifications"
  }
  # Phase 2: Read Page
  phase2: "2. Read Page into Buffer" {
    style.fill: "#D4EDDA"
    style.stroke: "#155724"
    action: "Load page from disk to memory"
  }
  # Phase 3: Modify in Buffer Pool
  phase3: "3. Modify in Buffer Pool" {
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    action: "Mark page as DIRTY"
    page_state: "Page: Modified (not yet written)"
  }
  # Phase 4: Write Original to Journal
  phase4: "4. Write ORIGINAL to Journal" {
    style.fill: "#CCE5FF"
    style.stroke: "#004085"
    action: "Store copy of original page"
    journal_content: "Journal: [original_page]"
  }
  # Phase 5: CRITICAL - fsync Journal
  phase5: "5. fsync(JOURNAL) ⭐ CRITICAL" {
    style.fill: "#28A745"
    style.stroke: "#1D7A2F"
    style.bold: true
    action: "Force original to disk"
    explanation: "This fsync GUARANTEES journal has backup BEFORE database is modified"
  }
  # Phase 6: Write Modified to Database
  phase6: "6. Write MODIFIED to Database" {
    style.fill: "#F8D7DA"
    style.stroke: "#721C24"
    action: "Overwrite with new content"
    risk: "Without step 5, crash here = CORRUPTION"
  }
  # Phase 7: fsync Database
  phase7: "7. fsync(DATABASE)" {
    style.fill: "#D4EDDA"
    style.stroke: "#155724"
    action: "Ensure database writes durable"
  }
  # Phase 8: Delete Journal
  phase8: "8. Delete Journal" {
    style.fill: "#D4EDDA"
    style.stroke: "#155724"
    action: "Remove rollback journal"
    state: "Transaction COMMITTED"
  }
  # Show the sequence
  phase1 -> phase2: "1. Load"
  phase2 -> phase3: "2. Modify"
  phase3 -> phase4: "3. Backup original"
  phase4 -> phase5: "4. fsync (ENSURES safety)"
  phase5 -> phase6: "5. Safe to modify DB"
  phase6 -> phase7: "6. Persist"
  phase7 -> phase8: "7. Cleanup"
}
# What happens if order is wrong?
consequence: "What Happens If Order Is WRONG?" {
  style.fill: "#F8D7DA"
  style.stroke: "#721C24"
  wrong_order: "If fsync(journal) AFTER database write:" {
    style.fill: "#F8D7DA"
    timeline: |md
      1. Write original to journal
      2. Write MODIFIED to database ← CRASH HERE
      3. fsync(journal) ← Too late!
      4. Original page LOST forever
    |
    result: "Result: TORN PAGE = PERMANENT CORRUPTION"
    fix: "Fix: fsync(journal) MUST be step 5 (before database write)"
  }
}
# Safe scenarios
safe_scenarios: "Safe Scenarios (With Correct Ordering)" {
  crash_before_fsync: "Crash BEFORE step 5 (fsync journal)" {
    scenario: "Journal incomplete or no journal"
    recovery: "Recovery: Use old database (transaction rolled back)"
    outcome: "✅ No corruption"
  }
  crash_after_fsync: "Crash AFTER step 5 (fsync journal)" {
    scenario: "Journal has original, DB may be partially written"
    recovery: "Recovery: Restore original from journal, rollback"
    outcome: "✅ No corruption"
  }
  crash_after_commit: "Crash AFTER step 7 (fsync DB)" {
    scenario: "Database has committed changes"
    recovery: "Recovery: Journal deleted, commit complete"
    outcome: "✅ Transaction durable"
  }
}
write_ordering.phase5 -> consequence: "⭐ Critical Step"
write_ordering -> safe_scenarios: "All scenarios safe"