direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

input_section: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  orders_tbl: {
    shape: sql_table
    label: "orders — outer table (3 rows)"
    style.fill: "#BBDEFB"
    o1: '0x00 | id=1 | total=$100'
    o2: '0x08 | id=2 | total=$200'
    o3: '0x10 | id=1 | total=$150'
  }

  algorithm: {
    label: "Nested Loop Join Execution (vm.c)"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 320
    code: |'c
      for (row_o : outer_table) {
        rewind(inner_cursor);
        while (row_i = next(inner_cursor)) {
          if (row_o.id == row_i.id) {
            emit_result(row_o, row_i);
          }
        }
      }
    '|
  }

  customers_tbl: {
    shape: sql_table
    label: "customers — inner table (4 rows)"
    style.fill: "#FFF9C4"
    c1: "0x00 | id=1 | Alice"
    c2: "0x0C | id=2 | Bob"
    c3: "0x18 | id=3 | Charlie"
    c4: "0x24 | id=4 | Diana"
  }
}

iter1: "Outer Iteration 1: orders.o1 (id=1)" {
  direction: right
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  i1c1: "o1 vs c1 | Match (1=1) | EMIT" {
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
    style.bold: true
  }
  i1c2: "o1 vs c2 | Skip (1!=2)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
  i1c3: "o1 vs c3 | Skip (1!=3)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
  i1c4: "o1 vs c4 | Skip (1!=4)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
}

iter2: "Outer Iteration 2: orders.o2 (id=2)" {
  direction: right
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  i2c1: "o2 vs c1 | Skip (2!=1)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
  i2c2: "o2 vs c2 | Match (2=2) | EMIT" {
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
    style.bold: true
  }
  i2c3: "o2 vs c3 | Skip (2!=3)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
  i2c4: "o2 vs c4 | Skip (2!=4)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
}

iter3: "Outer Iteration 3: orders.o3 (id=1)" {
  direction: right
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  i3c1: "o3 vs c1 | Match (1=1) | EMIT" {
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
    style.bold: true
  }
  i3c2: "o3 vs c2 | Skip (1!=2)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
  i3c3: "o3 vs c3 | Skip (1!=3)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
  i3c4: "o3 vs c4 | Skip (1!=4)" {
    style.fill: "#EEEEEE"
    style.stroke: "#BDBDBD"
    style.font-color: "#9E9E9E"
  }
}

output_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  output_tbl: {
    shape: sql_table
    label: "JOIN Result — SQLite VDBE Output"
    style.fill: "#E8F5E9"
    r1: 'o1 | id=1 | total=$100 | Alice'
    r2: 'o2 | id=2 | total=$200 | Bob'
    r3: 'o3 | id=1 | total=$150 | Alice'
    sz: "Total Emitted: 3 Rows"
  }

  stats: {
    shape: sql_table
    label: "Execution Statistics"
    style.fill: "#FFF3E0"
    s1: "Outer scans | 3"
    s2: "Inner rewinds | 3"
    s3: "Comparisons | 12 (N*M)"
    s4: "Cache Hits | 0 (No Index)"
    s5: "Complexity | O(N*M)"
  }
}

input_section -> iter1: "Next Row"
iter1 -> iter2: "Next Row"
iter2 -> iter3: "Next Row"

iter1.i1c1 -> output_row.output_tbl.r1: "EMIT" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
iter2.i2c2 -> output_row.output_tbl.r2: "EMIT" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
iter3.i3c1 -> output_row.output_tbl.r3: "EMIT" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}