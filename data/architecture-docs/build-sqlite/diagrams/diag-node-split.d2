direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  phase_container: {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 20
      bold: true
    }
  }
  page_table: {
    shape: sql_table
    style: {
      font-size: 14
      font: mono
    }
  }
  arrow_label: {
    style: {
      font-size: 13
      italic: true
    }
  }
  info_box: {
    style: {
      fill: "#FFF9C9"
      border-radius: 6
      font-size: 13
      stroke: "#E0D080"
    }
  }
}
# ============================================================
# PHASE 1: BEFORE — Full Leaf + Parent
# ============================================================
phase1: "PHASE 1 — Before Insert: Leaf Page is Full" {
  class: phase_container
  direction: right
  parent_before: {
    shape: sql_table
    label: "Internal Page (parent.c) — page 3"
    style.fill: "#E4DBFE"
    c0: "child_ptr | page 5"
    k1: "sep_key   | 25"
    c1: "child_ptr | page 7"
    k2: "sep_key   | 50"
    right: "right_child | page 9"
  }
  leaf_before: {
    shape: sql_table
    label: "Leaf Page (leaf.c) — page 7 [FULL]"
    style.fill: "#ACE1AF"
    r0: "rowid 26 | record: (26, 'Alice', 30)"
    r1: "rowid 30 | record: (30, 'Bob', 25)"
    r2: "rowid 35 | record: (35, 'Carol', 28)"
    r3: "rowid 40 | record: (40, 'Dave', 32)"
    r4: "rowid 45 | record: (45, 'Eve', 27)"
    r5: "rowid 48 | record: (48, 'Frank', 31)"
    cap: "Free space: 0 bytes — PAGE FULL"
    style.stroke: "#CC0000"
    style.stroke-width: 2
  }
  parent_before.c1 -> leaf_before: "child_ptr" {
    style.stroke: "#6A5ACD"
    style.stroke-width: 2
  }
}
# ============================================================
# PHASE 2: New Key Arrives — Triggers Split
# ============================================================
phase2: "PHASE 2 — INSERT rowid 33 Arrives (No Room)" {
  class: phase_container
  direction: right
  new_key: {
    label: "New Cell: rowid 33"
    style.fill: "#FE7070"
    style.font-color: white
    style.bold: true
    style.border-radius: 8
    style.shadow: true
    width: 220
  }
  decision: {
    shape: diamond
    label: "Fits in\nleaf page?"
    style.fill: "#FFFACD"
    width: 140
    height: 100
  }
  split_action: {
    label: "page_insert_cell()\nreturns -1\n→ SPLIT REQUIRED"
    style.fill: "#FFE0E0"
    style.stroke: "#CC0000"
    style.border-radius: 6
    width: 240
  }
  new_key -> decision: "insert attempt"
  decision -> split_action: "NO" {
    style.stroke: "#CC0000"
    style.stroke-width: 2
    style.bold: true
  }
}
# ============================================================
# PHASE 3: Split — Redistribute Cells
# ============================================================
phase3: "PHASE 3 — Leaf Splits Into Two Pages" {
  class: phase_container
  direction: right
  left_leaf: {
    shape: sql_table
    label: "Left Leaf (leaf.c) — page 7"
    style.fill: "#ACE1AF"
    r0: "rowid 26 | record: (26, 'Alice', 30)"
    r1: "rowid 30 | record: (30, 'Bob', 25)"
    r2: "rowid 33 | record: (33, 'NEW', 29)"
    cap: "Free space: ~2400 bytes"
    style.stroke: "#228B22"
    style.stroke-width: 2
  }
  split_line: {
    label: "SPLIT POINT\nMedian = rowid 35\n(promoted to parent)"
    style.fill: "#FFD700"
    style.stroke: "#B8860B"
    style.border-radius: 8
    style.font-size: 14
    style.bold: true
    width: 240
  }
  right_leaf: {
    shape: sql_table
    label: "Right Leaf (leaf.c) — page 10 [NEW]"
    style.fill: "#B6DDF6"
    r3: "rowid 35 | record: (35, 'Carol', 28)"
    r4: "rowid 40 | record: (40, 'Dave', 32)"
    r5: "rowid 45 | record: (45, 'Eve', 27)"
    r6: "rowid 48 | record: (48, 'Frank', 31)"
    cap: "Free space: ~1600 bytes"
    style.fill: "#B6DDF6"
    style.stroke: "#4682B4"
    style.stroke-width: 2
  }
  left_leaf -> split_line: "keys <= 33" {
    style.stroke: "#228B22"
  }
  split_line -> right_leaf: "keys >= 35" {
    style.stroke: "#4682B4"
  }
}
# ============================================================
# PHASE 4: After — Parent Updated with Promoted Key
# ============================================================
phase4: "PHASE 4 — After: Median Key Promoted to Parent" {
  class: phase_container
  direction: down
  parent_after: {
    shape: sql_table
    label: "Internal Page (parent.c) — page 3 [UPDATED]"
    style.fill: "#E4DBFE"
    c0: "child_ptr  | page 5"
    k1: "sep_key    | 25"
    c1: "child_ptr  | page 7"
    k2_new: "sep_key    | 35  ** PROMOTED **"
    c2_new: "child_ptr  | page 10  ** NEW **"
    k3: "sep_key    | 50"
    right: "right_child | page 9"
    style.stroke: "#6A5ACD"
    style.stroke-width: 2
  }
  children_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    left_final: {
      shape: sql_table
      label: "Leaf — page 7"
      style.fill: "#ACE1AF"
      r0: "rowid 26 | Alice"
      r1: "rowid 30 | Bob"
      r2: "rowid 33 | NEW"
    }
    right_final: {
      shape: sql_table
      label: "Leaf — page 10 [NEW]"
      style.fill: "#B6DDF6"
      r3: "rowid 35 | Carol"
      r4: "rowid 40 | Dave"
      r5: "rowid 45 | Eve"
      r6: "rowid 48 | Frank"
    }
  }
  parent_after.c1 -> children_row.left_final: "rowid <= 35" {
    style.stroke: "#228B22"
    style.stroke-width: 2
  }
  parent_after.c2_new -> children_row.right_final: "rowid > 35" {
    style.stroke: "#4682B4"
    style.stroke-width: 2
  }
}
# ============================================================
# LEGEND
# ============================================================
legend: {
  label: "Legend"
  style.fill: "#F8F8F8"
  style.border-radius: 8
  style.stroke: "#CCCCCC"
  style.font-size: 13
  green: "Green — left child (keys <= median)"
  blue: "Blue — right child / new page (keys >= median)"
  purple: "Purple — parent internal page"
  red: "Red — new inserted key / overflow trigger"
  yellow: "Yellow — promoted median key"
}
legend.near: bottom-right
# ============================================================
# FLOW CONNECTIONS BETWEEN PHASES
# ============================================================
phase1 -> phase2: "INSERT rowid 33" {
  style.stroke: "#FE7070"
  style.stroke-width: 3
  style.bold: true
}
phase2 -> phase3: "btree_split_leaf()" {
  style.stroke: "#B8860B"
  style.stroke-width: 3
  style.bold: true
}
phase3 -> phase4: "btree_insert_into_parent()" {
  style.stroke: "#6A5ACD"
  style.stroke-width: 3
  style.bold: true
}