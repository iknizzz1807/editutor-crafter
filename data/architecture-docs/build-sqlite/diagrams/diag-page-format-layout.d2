direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  header_style: {
    style: {
      fill: "#E8D5F5"
      stroke: "#7939A8"
      font-size: 14
      border-radius: 3
    }
  }
  pointer_style: {
    style: {
      fill: "#D5E8F5"
      stroke: "#2E6DA4"
      font-size: 13
      border-radius: 3
    }
  }
  free_style: {
    style: {
      fill: "#F0F0F0"
      stroke: "#999999"
      stroke-dash: 4
      font-size: 14
    }
  }
  cell_style: {
    style: {
      fill: "#D5F5E3"
      stroke: "#1E8449"
      font-size: 13
      border-radius: 3
    }
  }
  offset_style: {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 12
      font-color: "#666666"
      font: mono
    }
  }
}
title: Page Binary Layout — Slotted Page (4096 bytes) {
  style: {
    font-size: 22
    bold: true
    fill: transparent
    stroke: transparent
  }
}
page: "" {
  style: {
    fill: "#FAFAFA"
    stroke: "#333333"
    stroke-width: 2
    border-radius: 6
  }
  grid-rows: 9
  grid-gap: 0
  # ── Page Header (12 bytes for internal pages, 8 for leaf) ──
  hdr: Page Header (12 bytes — Internal Page) {
    style: {
      fill: "#E8D5F5"
      stroke: "#7939A8"
      stroke-width: 2
      font-size: 15
      bold: true
    }
  }
  hdr_detail: "" {
    grid-columns: 1
    grid-gap: 0
    style: {
      fill: "#F3EAF9"
      stroke: "#7939A8"
    }
    f0: {
      shape: sql_table
      label: "Page Header Fields"
      r0: "0x00 | uint8_t  | page_type       // 0x0D=leaf, 0x05=internal"
      r1: "0x01 | uint16_t | first_freeblock // BE, offset to first free block (0=none)"
      r2: "0x03 | uint16_t | cell_count      // BE, number of cells on this page"
      r3: "0x05 | uint16_t | cell_content_start // BE, offset to start of cell content"
      r4: "0x07 | uint8_t  | fragmented_bytes   // total fragmented free bytes"
      r5: "0x08 | uint32_t | right_child     // BE, right-most child page (internal only)"
      sz: "Total: 12 bytes (internal) / 8 bytes (leaf — no right_child)"
    }
  }
  # ── Cell Pointer Array ──
  ptr_array: Cell Pointer Array — grows downward from offset 0x0C {
    style: {
      fill: "#D5E8F5"
      stroke: "#2E6DA4"
      stroke-width: 2
      font-size: 14
      bold: true
    }
  }
  ptr_detail: "" {
    grid-columns: 1
    grid-gap: 0
    style: {
      fill: "#EAF2FA"
      stroke: "#2E6DA4"
    }
    ptrs: {
      shape: sql_table
      label: "Cell Pointers (2 bytes each, big-endian)"
      p0: "0x0C | uint16_t | cell_ptr[0] → offset of cell 0 in content area"
      p1: "0x0E | uint16_t | cell_ptr[1] → offset of cell 1 in content area"
      p2: "0x10 | uint16_t | cell_ptr[2] → offset of cell 2 in content area"
      pn: "...  | uint16_t | cell_ptr[N-1] → offset of cell N-1"
      note: "Pointers sorted by key order; cells in content area are NOT sorted"
      sz: "Size: cell_count * 2 bytes"
    }
  }
  # ── Free Space ──
  free_space: "" {
    style: {
      fill: "#F5F5F5"
      stroke: "#999999"
      stroke-dash: 5
      font-size: 16
      bold: true
    }
    label: |md
      FREE SPACE
      (unallocated region between pointer array and cell content)
    |
    height: 120
  }
  # ── Cell Content Area ──
  cell_area: Cell Content Area — grows upward from offset 0xFFF {
    style: {
      fill: "#D5F5E3"
      stroke: "#1E8449"
      stroke-width: 2
      font-size: 14
      bold: true
    }
  }
  cell_detail: "" {
    grid-columns: 1
    grid-gap: 0
    style: {
      fill: "#EAF9EE"
      stroke: "#1E8449"
    }
    cells: {
      shape: sql_table
      label: "Cell Content (variable-length cells, packed from bottom)"
      c_newest: "cell_content_start | ... | Cell N-1 (most recently inserted)"
      c_mid: "...                | ... | Cell 1"
      c_oldest: "near 0xFFF         | ... | Cell 0 (first inserted, near page bottom)"
      note: "Cells written in insertion order (not key order)"
    }
  }
  # ── Table Leaf Cell Format ──
  leaf_cell: "" {
    style: {
      fill: "#FFF9E6"
      stroke: "#B7950B"
      stroke-width: 2
      border-radius: 4
    }
    leaf_fmt: {
      shape: sql_table
      label: "Table B-tree Leaf Cell Format"
      f0: "varint | payload_size  // total bytes of record data"
      f1: "varint | rowid         // integer primary key"
      f2: "bytes  | record_data   // serialized column values"
      note: "Record: [header_size(varint)] [serial_type...] [values...]"
    }
  }
  # ── Table Internal Cell Format ──
  internal_cell: "" {
    style: {
      fill: "#FDEBD0"
      stroke: "#CA6F1E"
      stroke-width: 2
      border-radius: 4
    }
    int_fmt: {
      shape: sql_table
      label: "Table B-tree Internal Cell Format"
      f0: "4 bytes BE | left_child_page // page number of left subtree"
      f1: "varint     | rowid           // separator key"
      note: "No payload — internal nodes store only navigation keys"
    }
  }
  # ── Page Footer / End ──
  footer: "" {
    style: {
      fill: "#E0E0E0"
      stroke: "#666666"
      font-size: 13
      font: mono
    }
    label: "Offset 0xFFF (byte 4095) — End of 4096-byte page"
  }
}
# ── Offset annotations (outside page) ──
offsets: "" {
  direction: down
  style: {
    fill: transparent
    stroke: transparent
  }
  o0: "0x000" { class: offset_style }
  o1: "0x008 / 0x00C" { class: offset_style }
  o2: "0x00C + N*2" { class: offset_style }
  o3: "" {
    class: offset_style
    label: "(varies)"
    height: 60
  }
  o4: "cell_content_start" { class: offset_style }
  o5: "0xFFF" { class: offset_style }
}
# ── Growth direction arrows ──
growth: "" {
  direction: down
  style: {
    fill: transparent
    stroke: transparent
  }
  ptr_grow: "Pointer array\ngrows DOWN" {
    style: {
      fill: "#D5E8F5"
      stroke: "#2E6DA4"
      font-size: 13
      bold: true
      border-radius: 8
    }
  }
  cell_grow: "Cell content\ngrows UP" {
    style: {
      fill: "#D5F5E3"
      stroke: "#1E8449"
      font-size: 13
      bold: true
      border-radius: 8
    }
  }
  ptr_grow -> cell_grow: "FREE SPACE\nshrinks as page fills" {
    style: {
      stroke: "#CC0000"
      stroke-dash: 4
      font-color: "#CC0000"
      bold: true
    }
  }
}
# ── Key insight callout ──
insight: "" {
  style: {
    fill: "#FFF3CD"
    stroke: "#856404"
    border-radius: 8
    font-size: 13
  }
  label: |md
  **Bidirectional Growth Design**
  - Header + pointers: fixed position, grow toward middle
  - Cell data: packed from page end, grow toward middle
  - Page full when pointer array meets cell content area
  - Pointers are sorted by key; cells are insertion-ordered
  - Indirection via pointers enables compaction without external invalidation
  |
}
# ── Endianness note ──
endian: "" {
  style: {
    fill: "#F8D7DA"
    stroke: "#721C24"
    border-radius: 6
    font-size: 12
  }
  label: |md
  **Byte Order: Big-Endian**
  All multi-byte integers (uint16, uint32) stored
  big-endian for cross-platform portability
  |
}