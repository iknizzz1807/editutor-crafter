direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## AST Trace: SELECT name, age FROM users WHERE age > 21 AND city = 'NYC' ORDER BY name LIMIT 10
| {near: top-center}
select_root: {
  shape: sql_table
  label: "NODE_SELECT  (parser.h)"
  r1: "table_name   | \"users\""
  r2: "column_count | 2"
  r3: "where_expr   | NODE_BINARY_EXPR*  (AND)"
  r4: "order_count  | 1"
  r5: "limit_expr   | NODE_LITERAL_INT*  (10)"
  r6: "line:col     | 1:1"
}
select_root.style.fill: "#1A5276"
select_root.style.font-color: "#FFFFFF"
select_root.style.bold: true
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  col_list: {
    shape: sql_table
    label: "ColumnList  (2 items)"
    r1: "col[0] | NODE_IDENTIFIER*  name"
    r2: "col[1] | NODE_IDENTIFIER*  age"
  }
  from_clause: {
    shape: sql_table
    label: "FromClause  NODE_IDENTIFIER"
    r1: "name     | \"users\""
    r2: "tbl      | NULL"
    r3: "line:col | 1:22"
  }
  where_and: {
    shape: sql_table
    label: "WhereClause  NODE_BINARY_EXPR"
    r1: "op       | TOKEN_AND"
    r2: "left     | NODE_BINARY_EXPR*  (>)"
    r3: "right    | NODE_BINARY_EXPR*  (=)"
    r4: "line:col | 1:32"
  }
  order_item: {
    shape: sql_table
    label: "OrderByItem"
    r1: "expr      | NODE_IDENTIFIER*  name"
    r2: "ascending | true  (ASC)"
    r3: "line:col  | 1:60"
  }
  limit_lit: {
    shape: sql_table
    label: "LimitExpr  NODE_LITERAL_INT"
    r1: "value    | 10  (int64)"
    r2: "line:col | 1:73"
  }
}
row1.col_list.style.fill: "#6C3483"
row1.col_list.style.font-color: "#FFFFFF"
row1.from_clause.style.fill: "#6C3483"
row1.from_clause.style.font-color: "#FFFFFF"
row1.where_and.style.fill: "#A04000"
row1.where_and.style.font-color: "#FFFFFF"
row1.order_item.style.fill: "#6C3483"
row1.order_item.style.font-color: "#FFFFFF"
row1.limit_lit.style.fill: "#1E8449"
row1.limit_lit.style.font-color: "#FFFFFF"
row2a: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ident_name: {
    shape: sql_table
    label: "NODE_IDENTIFIER  col[0]"
    r1: "name     | \"name\""
    r2: "tbl      | NULL"
    r3: "line:col | 1:8"
  }
  ident_age: {
    shape: sql_table
    label: "NODE_IDENTIFIER  col[1]"
    r1: "name     | \"age\""
    r2: "tbl      | NULL"
    r3: "line:col | 1:13"
  }
}
row2b: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  gt_expr: {
    shape: sql_table
    label: "NODE_BINARY_EXPR  age > 21"
    r1: "op       | TOKEN_GT  (>)"
    r2: "left     | NODE_IDENTIFIER*  age"
    r3: "right    | NODE_LITERAL_INT*  21"
    r4: "line:col | 1:38"
  }
  eq_expr: {
    shape: sql_table
    label: "NODE_BINARY_EXPR  city = 'NYC'"
    r1: "op       | TOKEN_EQ  (=)"
    r2: "left     | NODE_IDENTIFIER*  city"
    r3: "right    | NODE_LITERAL_STR*  NYC"
    r4: "line:col | 1:47"
  }
}
row2b.gt_expr.style.fill: "#D35400"
row2b.gt_expr.style.font-color: "#FFFFFF"
row2b.eq_expr.style.fill: "#D35400"
row2b.eq_expr.style.font-color: "#FFFFFF"
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leaf_age: {
    shape: sql_table
    label: "NODE_IDENTIFIER  (left of >)"
    r1: "name     | \"age\""
    r2: "tbl      | NULL"
    r3: "line:col | 1:38"
  }
  leaf_21: {
    shape: sql_table
    label: "NODE_LITERAL_INT  (right of >)"
    r1: "value    | 21  (int64)"
    r2: "line:col | 1:44"
  }
  leaf_city: {
    shape: sql_table
    label: "NODE_IDENTIFIER  (left of =)"
    r1: "name     | \"city\""
    r2: "tbl      | NULL"
    r3: "line:col | 1:47"
  }
  leaf_nyc: {
    shape: sql_table
    label: "NODE_LITERAL_STR  (right of =)"
    r1: "raw      | 'NYC'"
    r2: "decoded  | NYC  (3 bytes)"
    r3: "line:col | 1:54"
  }
}
row3.leaf_21.style.fill: "#1E8449"
row3.leaf_21.style.font-color: "#FFFFFF"
row3.leaf_nyc.style.fill: "#1E8449"
row3.leaf_nyc.style.font-color: "#FFFFFF"
select_root -> row1.col_list: "columns[]"
select_root -> row1.from_clause: "table"
select_root -> row1.where_and: "where_expr"
select_root -> row1.order_item: "order_by[0]"
select_root -> row1.limit_lit: "limit"
row1.col_list -> row2a.ident_name: "col[0]"
row1.col_list -> row2a.ident_age: "col[1]"
row1.where_and -> row2b.gt_expr: "left"
row1.where_and -> row2b.eq_expr: "right"
row2b.gt_expr -> row3.leaf_age: "left"
row2b.gt_expr -> row3.leaf_21: "right"
row2b.eq_expr -> row3.leaf_city: "left"
row2b.eq_expr -> row3.leaf_nyc: "right"
legend: {
  shape: sql_table
  label: "Node Color Legend"
  l1: "Blue   | NODE_SELECT root"
  l2: "Purple | Clause nodes"
  l3: "Orange | BinaryExpr nodes"
  l4: "Green  | Literal leaf nodes"
  l5: "White  | Identifier leaf nodes"
}
legend.style.fill: "#2C3E50"
legend.style.font-color: "#ECF0F1"
legend.near: bottom-right