direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  title: "Parser Error — Invalid SQL Diagnostics (Before vs After)" {
    shape: rectangle
    style: {
      font-size: 16
      bold: true
      fill: "#EEF2FF"
      stroke: "#4F46E5"
      border-radius: 6
    }
  }
}
compare_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: "BEFORE — Parser hits unexpected FORM token" {
    direction: down
    style: {
      fill: "#FFF8F0"
      stroke: "#E65100"
      border-radius: 6
    }
    sql_in: {
      label: "SQL Input (typo: FORM instead of FROM)"
      width: 400
      code: |'c
        SELECT * FORM users;
                 ^^^^
        col 10: 'FORM' -> TOKEN_IDENTIFIER
        expected: TOKEN_FROM keyword
      '|
    }
    tokens: {
      shape: sql_table
      label: "Token[] array (tokenizer.h)"
      t0: "[0] TOKEN_SELECT     | SELECT | L1:C1"
      t1: "[1] TOKEN_STAR       | *      | L1:C8"
      t2: "[2] TOKEN_IDENTIFIER | FORM   | L1:C10  <-- cursor"
      t3: "[3] TOKEN_IDENTIFIER | users  | L1:C15"
      t4: "[4] TOKEN_SEMICOLON  | ;      | L1:C20"
      t5: "[5] TOKEN_EOF"
    }
    parse_state: {
      shape: sql_table
      label: "parse_select() execution (parser.c)"
      s0: "step 1 | consumed TOKEN_SELECT  OK"
      s1: "step 2 | consumed TOKEN_STAR    OK"
      s2: "step 3 | parser_expect(TOKEN_FROM)"
      s3: "peek   | TOKEN_IDENTIFIER (FORM)"
      s4: "check  | IDENTIFIER != FROM -> FAIL"
    }
    err_trigger: "parser_expect() returns 0 — writes error_msg" {
      shape: rectangle
      style: {
        fill: "#FF5722"
        font-color: white
        bold: true
        border-radius: 4
      }
    }
    sql_in -> tokens: "tokenize"
    tokens -> parse_state: "pos=2"
    parse_state -> err_trigger: "type mismatch"
  }
  after: "AFTER — Structured diagnostic produced" {
    direction: down
    style: {
      fill: "#F0FFF4"
      stroke: "#2E7D32"
      border-radius: 6
    }
    result_struct: {
      shape: sql_table
      label: "ParseResult (parser.h)"
      r0: "root       | NULL (AST not built)"
      r1: "had_error  | 1"
      r2: "error_line | 1"
      r3: "error_col  | 10"
      r4: "error_msg  | Expected FROM after column list,"
      r5: "           | got 'FORM' (TOKEN_IDENTIFIER)"
    }
    err_output: {
      label: "User-visible error (stderr)"
      width: 440
      code: |'c
        Parse error at line 1, column 10:
        Expected FROM after column list,
        got 'FORM' (TOKEN_IDENTIFIER)
        SELECT * FORM users;
                 ^--- here (col 10)
      '|
    }
    sync_state: {
      shape: sql_table
      label: "synchronize() panic-mode recovery (parser.c)"
      v0: "action    | consume until TOKEN_SEMICOLON"
      v1: "skipped   | FORM, users"
      v2: "consumed  | ;"
      v3: "had_error | reset to 0"
      v4: "result    | parser ready for next statement"
    }
    result_struct -> err_output: "format"
    err_output -> sync_state: "then recover"
  }
  before.err_trigger -> after.result_struct: "error path" {
    style: {
      stroke: "#9C27B0"
      stroke-width: 3
      stroke-dash: 4
    }
  }
}
title_row -> compare_row