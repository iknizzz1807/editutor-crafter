direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  error_highlight: {
    style.fill: "#FE7070"
    style.font-color: white
    style.bold: true
  }
  success: {
    style.fill: "#90EE90"
    style.stroke: "#2E8B57"
  }
  phase: {
    style.fill: "#f0f4ff"
    style.stroke: "#6772E5"
    style.border-radius: 8
  }
  token_box: {
    style.fill: "#fff"
    style.stroke: "#aab"
    style.border-radius: 4
    style.font: mono
  }
}
# ─── INPUT ───
input: {
  label: "Raw SQL Input"
  class: phase
  sql: {
    label: "SELECT * FORM users"
    style.font: mono
    style.font-size: 24
    style.bold: true
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"
    width: 400
  }
  annotation: {
    label: "Note: FORM is a typo — should be FROM"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.font-size: 14
    style.italic: true
  }
}
# ─── TOKENIZER ───
tokenizer: {
  label: "Tokenizer (lexer.c)"
  class: phase
  desc: {
    label: "Tokenizer succeeds — FORM is a valid identifier"
    style.italic: true
    style.fill: transparent
    style.stroke: transparent
  }
  tokens: {
    shape: sql_table
    label: "Token Stream Output"
    t0: "idx 0 | TOK_KEYWORD    | SELECT   | line 1, col 1"
    t1: "idx 1 | TOK_STAR       | *        | line 1, col 8"
    t2: "idx 2 | TOK_IDENTIFIER | FORM     | line 1, col 10"
    t3: "idx 3 | TOK_IDENTIFIER | users    | line 1, col 15"
    t4: "idx 4 | TOK_EOF        | (end)    | line 1, col 20"
    note: "FORM is NOT a keyword — classified as IDENTIFIER"
  }
}
input -> tokenizer: "lexer_tokenize_all()"
# ─── PARSER DISPATCH ───
parser_dispatch: {
  label: "Parser Dispatch (parser.c)"
  class: phase
  step1: {
    label: "parser_parse()"
    style.fill: "#E8EAF6"
    check: {
      label: "peek() → tokens[0]"
      style.font: mono
    }
    result: {
      label: "type == TOK_KEYWORD, text == 'SELECT'"
      style.font: mono
      style.font-size: 13
    }
    action: {
      label: "→ dispatch to parse_select()"
      class: success
    }
    check -> result
    result -> action
  }
}
tokenizer -> parser_dispatch: "Token array + count"
# ─── PARSE SELECT INTERNALS ───
parse_select: {
  label: "parse_select() — Step-by-Step Execution"
  class: phase
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    step_kw: {
      label: "Step 1: expect_keyword('SELECT')"
      class: success
      s1_detail: {
        label: "tokens[0] = KEYWORD 'SELECT' ✓\nadvance → current = 1"
        style.font: mono
        style.font-size: 12
      }
    }
    step_cols: {
      label: "Step 2: Parse Column List"
      class: success
      s2_detail: {
        label: "tokens[1] = TOK_STAR ✓\nWildcard node created\nadvance → current = 2"
        style.font: mono
        style.font-size: 12
      }
    }
  }
  step_from: {
    label: "Step 3: expect_keyword('FROM')"
    class: error_highlight
    width: 500
    mechanism: {
      shape: sql_table
      label: "expect_keyword() Internals"
      e1: "check_keyword(p, 'FROM')"
      e2: "peek() → tokens[2] = {type: TOK_IDENTIFIER, text: 'FORM'}"
      e3: "tok->type == TOK_KEYWORD?  NO — tok->type is TOK_IDENTIFIER"
      e4: "Even if type matched: strncasecmp('FORM','FROM',4) != 0"
      e5: "Result: check_keyword returns false"
      e6: "→ Falls through to parser_error()"
    }
  }
  row1 -> step_from: "current = 2"
}
parser_dispatch -> parse_select: "parse_select(p)"
# ─── ERROR GENERATION ───
error_gen: {
  label: "Error Generation (parser.c:parser_error)"
  class: phase
  error_call: {
    label: "parser_error(p, got_token, fmt, args)"
    style.font: mono
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
  error_state: {
    shape: sql_table
    label: "Parser State at Error Point"
    f0: "p->had_error      | false → true (first error wins)"
    f1: "p->current         | 2 (index of offending token)"
    f2: "got_token->type    | TOK_IDENTIFIER"
    f3: "got_token->start   | pointer to 'FORM' in source"
    f4: "got_token->length  | 4"
    f5: "got_token->line    | 1"
    f6: "got_token->col     | 10"
  }
  format: {
    label: "vsnprintf into p->error_msg"
    style.font: mono
    output: {
      label: |md
        **Generated Message:**
        `expected 'FROM', got 'FORM'`
      |
      style.fill: "#FFCDD2"
      style.stroke: "#B71C1C"
      style.border-radius: 6
    }
  }
  position: {
    shape: sql_table
    label: "Error Position Stored"
    p0: "p->error_line | 1"
    p1: "p->error_col  | 10"
    p2: "p->error_msg  | expected 'FROM', got 'FORM'"
  }
  error_call -> error_state: "extract token info"
  error_state -> format: "build message"
  format -> position: "store in parser"
}
parse_select -> error_gen: "expect_keyword('FROM') fails" {
  style.stroke: "#C62828"
  style.stroke-width: 3
}
# ─── PROPAGATION ───
propagation: {
  label: "Error Propagation Back to Caller"
  class: phase
  chain: {
    shape: sql_table
    label: "Return Chain (NULL propagation)"
    c0: "expect_keyword('FROM') | returns NULL"
    c1: "parse_select()         | checks NULL → returns NULL"
    c2: "parser_parse()         | receives NULL → returns NULL"
    c3: "sql_parse()            | checks p->had_error → true"
  }
  no_cascade: {
    label: "Subsequent 'errors' suppressed"
    style.fill: "#FFF9C4"
    style.stroke: "#F57F17"
    detail: {
      label: "parser_error() checks p->had_error\nIf already true → returns immediately\nPrevents cascading noise from\ntoken-stream misalignment"
      style.font-size: 13
      style.font: mono
    }
  }
  chain -> no_cascade
}
error_gen -> propagation: "return NULL"
# ─── FINAL OUTPUT ───
final_output: {
  label: "Final Error Report to User"
  class: phase
  report: {
    label: |md
      **stderr output:**
      
      Parse error at line 1, col 10: expected 'FROM', got 'FORM'
      
    |
    style.fill: "#FFCDD2"
    style.stroke: "#B71C1C"
    style.border-radius: 8
    width: 500
  }
  source_highlight: {
    label: "Source Position Visualization"
    style.fill: "#263238"
    style.font-color: "#ECEFF1"
    code: |'md
      SELECT * FORM users
               ^^^^
               col 10: expected keyword 'FROM'
    '|
  }
  no_ast: {
    label: "sql_parse() returns NULL — no AST produced"
    style.fill: "#FFAB91"
    style.stroke: "#BF360C"
    style.bold: true
  }
  report -> source_highlight: "position maps to source"
  source_highlight -> no_ast
}
propagation -> final_output: "fprintf(stderr, ...)"
# ─── LEGEND ───
legend: {
  label: "Legend"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.border-radius: 8
  green: "Green = step succeeded" {
    class: success
  }
  red: "Red = error detected / generated" {
    class: error_highlight
  }
  key_insight: {
    label: "Key Insight: FORM passes tokenization (valid identifier)\nbut fails parsing (wrong token type at wrong position)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.font-size: 13
  }
}
legend.near: bottom-right