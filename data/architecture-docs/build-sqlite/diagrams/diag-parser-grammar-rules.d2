direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  entry: {
    style: {
      fill: "#2D3436"
      font-color: "#FFFFFF"
      bold: true
      border-radius: 8
      shadow: true
    }
  }
  dispatcher: {
    style: {
      fill: "#6C5CE7"
      font-color: "#FFFFFF"
      bold: true
      border-radius: 6
    }
  }
  clause: {
    style: {
      fill: "#0984E3"
      font-color: "#FFFFFF"
      border-radius: 6
    }
  }
  expr: {
    style: {
      fill: "#00B894"
      font-color: "#FFFFFF"
      border-radius: 6
    }
  }
  leaf: {
    style: {
      fill: "#FDCB6E"
      font-color: "#2D3436"
      border-radius: 6
      stroke: "#F39C12"
      stroke-width: 2
    }
  }
  prec_label: {
    style: {
      fill: "#DFE6E9"
      font-color: "#636E72"
      border-radius: 4
      font-size: 13
      italic: true
    }
  }
}
# ── Top-Level Entry ──
parse_statement: "parse_statement()" {
  class: entry
  width: 260
}
# ── Statement Dispatchers ──
stmt_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parse_select: "parse_select()" {
    class: dispatcher
    width: 200
  }
  parse_insert: "parse_insert()" {
    class: dispatcher
    width: 200
  }
  parse_create: "parse_create_table()" {
    class: dispatcher
    width: 200
  }
}
parse_statement -> stmt_row.parse_select: "KEYWORD = SELECT"
parse_statement -> stmt_row.parse_insert: "KEYWORD = INSERT"
parse_statement -> stmt_row.parse_create: "KEYWORD = CREATE"
# ── SELECT Clause Parsers ──
select_clauses: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parse_column_list: "parse_column_list()" {
    class: clause
    width: 200
  }
  parse_from: "parse_from()" {
    class: clause
    width: 200
  }
  parse_where: "parse_where()" {
    class: clause
    width: 200
  }
  parse_order_by: "parse_order_by()" {
    class: clause
    width: 200
  }
  parse_limit: "parse_limit()" {
    class: clause
    width: 200
  }
}
stmt_row.parse_select -> select_clauses.parse_column_list: "step 1"
stmt_row.parse_select -> select_clauses.parse_from: "step 2"
stmt_row.parse_select -> select_clauses.parse_where: "step 3 (opt)"
stmt_row.parse_select -> select_clauses.parse_order_by: "step 4 (opt)"
stmt_row.parse_select -> select_clauses.parse_limit: "step 5 (opt)"
# ── Expression Parser: Precedence Climbing ──
# Each column list entry and WHERE/HAVING/ORDER BY call parse_expression
prec_note: "Precedence Climbing: Each level calls the next-tighter level" {
  class: prec_label
  width: 480
}
parse_expression: "parse_expression()" {
  class: expr
  width: 240
}
select_clauses.parse_column_list -> parse_expression: "each col"
select_clauses.parse_where -> parse_expression: "WHERE expr"
select_clauses.parse_order_by -> parse_expression: "each item"
# ── Precedence Levels (top = lowest precedence) ──
parse_or: "parse_or_expr()" {
  class: expr
  width: 240
}
parse_and: "parse_and_expr()" {
  class: expr
  width: 240
}
parse_not: "parse_not_expr()" {
  class: expr
  width: 240
}
parse_comparison: "parse_comparison()" {
  class: expr
  width: 240
}
parse_addition: "parse_addition()" {
  class: expr
  width: 240
}
parse_primary: "parse_primary()" {
  class: expr
  width: 240
  style.fill: "#00CEC9"
}
parse_expression -> parse_or: "delegates to"
parse_or -> parse_and: "calls for each operand" {
  style.stroke: "#00B894"
  style.stroke-width: 2
}
parse_and -> parse_not: "calls for each operand" {
  style.stroke: "#00B894"
  style.stroke-width: 2
}
parse_not -> parse_comparison: "calls (or recurses for NOT)" {
  style.stroke: "#00B894"
  style.stroke-width: 2
}
parse_comparison -> parse_addition: "calls for left and right" {
  style.stroke: "#00B894"
  style.stroke-width: 2
}
parse_addition -> parse_primary: "calls for each operand" {
  style.stroke: "#00B894"
  style.stroke-width: 2
}
# ── Precedence annotations ──
prec_or: "Prec 1 (lowest): OR" { class: prec_label; width: 180 }
prec_and: "Prec 2: AND" { class: prec_label; width: 180 }
prec_not: "Prec 3: NOT (unary)" { class: prec_label; width: 180 }
prec_cmp: "Prec 4: = < > <= >= !=" { class: prec_label; width: 180 }
prec_add: "Prec 5 (highest): + -" { class: prec_label; width: 180 }
parse_or -> prec_or: "" { style.stroke-dash: 4; style.opacity: 0.4 }
parse_and -> prec_and: "" { style.stroke-dash: 4; style.opacity: 0.4 }
parse_not -> prec_not: "" { style.stroke-dash: 4; style.opacity: 0.4 }
parse_comparison -> prec_cmp: "" { style.stroke-dash: 4; style.opacity: 0.4 }
parse_addition -> prec_add: "" { style.stroke-dash: 4; style.opacity: 0.4 }
# ── Primary: Leaf Token Types ──
primary_leaves: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tok_integer: "TOK_INTEGER\n42, 0, 999" { class: leaf; width: 140 }
  tok_float: "TOK_FLOAT\n3.14, 1e10" { class: leaf; width: 140 }
  tok_string: "TOK_STRING\n'hello'" { class: leaf; width: 140 }
  tok_null: "NULL\nkeyword literal" { class: leaf; width: 140 }
  tok_ident: "TOK_IDENTIFIER\ncol_name" { class: leaf; width: 140 }
  tok_colref: "table.column\ndot-qualified" { class: leaf; width: 140 }
  tok_paren: "( expression )\nrecursive!" { class: leaf; width: 140 }
}
parse_primary -> primary_leaves.tok_integer: "digit"
parse_primary -> primary_leaves.tok_float: "digit+dot"
parse_primary -> primary_leaves.tok_string: "quote"
parse_primary -> primary_leaves.tok_null: "NULL kw"
parse_primary -> primary_leaves.tok_ident: "letter/_"
parse_primary -> primary_leaves.tok_colref: "ident.ident"
parse_primary -> primary_leaves.tok_paren: "LPAREN"
# ── Recursive call back to parse_expression from parenthesized expr ──
primary_leaves.tok_paren -> parse_expression: "recurse" {
  style.stroke: "#E17055"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.animated: true
}
# ── INSERT / CREATE also call parse_expression ──
stmt_row.parse_insert -> parse_expression: "each VALUE" {
  style.stroke-dash: 4
  style.stroke: "#636E72"
}
# ── Column def parser for CREATE TABLE ──
parse_column_def: "parse_column_def()" {
  class: clause
  width: 200
}
stmt_row.parse_create -> parse_column_def: "each column" {
  style.stroke-dash: 4
  style.stroke: "#636E72"
}
col_def_detail: {
  shape: sql_table
  label: "Column Definition Parse Steps (parser.c)"
  step1: "1 | expect | TOK_IDENTIFIER (name)"
  step2: "2 | expect | TOK_KEYWORD (type: INTEGER, TEXT...)"
  step3: "3 | loop   | constraints: PRIMARY KEY, NOT NULL, UNIQUE"
}
parse_column_def -> col_def_detail: "structure"
# ── Legend ──
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#B2BEC3"
  style.border-radius: 8
  l1: "Black — entry point" { style.font-size: 13 }
  l2: "Purple — statement dispatchers" { style.font-size: 13 }
  l3: "Blue — clause parsers" { style.font-size: 13 }
  l4: "Green — expression precedence chain" { style.font-size: 13 }
  l5: "Yellow — leaf tokens (terminals)" { style.font-size: 13 }
  l6: "Red dashed — recursive call back up" { style.font-size: 13 }
}