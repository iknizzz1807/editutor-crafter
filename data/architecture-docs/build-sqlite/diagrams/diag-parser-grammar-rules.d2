direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  select_stmt: {
    shape: sql_table
    label: "SelectStmt (parser.c)"
    r0: "SELECT  | column_list"
    r1: "FROM    | table_ref"
    r2: "[WHERE] | expr"
    r3: "[ORDER BY] | order_by_item*"
    r4: "[LIMIT] | expr"
  }
  insert_stmt: {
    shape: sql_table
    label: "InsertStmt (parser.c)"
    r0: "INSERT INTO | table_ref"
    r1: "[(col, ...)] | column_list?"
    r2: "VALUES | ( expr, ... )"
  }
  create_stmt: {
    shape: sql_table
    label: "CreateTableStmt (parser.c)"
    r0: "CREATE TABLE | table_ref"
    r1: "( ... ) | column_def+"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  column_list: {
    shape: sql_table
    label: "column_list"
    r0: "* | wildcard"
    r1: "expr | projection"
    r2: ", expr | additional cols"
  }
  table_ref: {
    shape: sql_table
    label: "table_ref"
    r0: "TOKEN_IDENTIFIER | plain name"
    r1: "TOKEN_QUOTED_ID  | quoted name"
  }
  order_by_item: {
    shape: sql_table
    label: "order_by_item"
    r0: "expr | sort expression"
    r1: "[ASC|DESC] | direction"
  }
  column_def: {
    shape: sql_table
    label: "column_def"
    r0: "col_name  | TOKEN_IDENTIFIER"
    r1: "type_name | TOKEN_IDENTIFIER"
    r2: "[PRIMARY KEY] | constraint"
    r3: "[NOT NULL]    | constraint"
    r4: "[UNIQUE]      | constraint"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  expr: {
    shape: sql_table
    label: "expr — Pratt Parser entry (parser.c)"
    r0: "or_expr | min_bp = 0"
    r1: "LBP(OR)=10 | left-assoc"
    r2: "LBP(AND)=20 | left-assoc"
    r3: "LBP(cmp)=30 | non-assoc"
    r4: "LBP(+-)=40  | left-assoc"
    r5: "LBP(*/)=50  | left-assoc"
  }
  primary: {
    shape: sql_table
    label: "primary — leaf parse_primary() (parser.c)"
    r0: "TOKEN_INTEGER    | NODE_LITERAL_INT"
    r1: "TOKEN_FLOAT      | NODE_LITERAL_FLOAT"
    r2: "TOKEN_STRING     | NODE_LITERAL_STRING"
    r3: "TOKEN_NULL       | NODE_LITERAL_NULL"
    r4: "TOKEN_IDENTIFIER | NODE_IDENTIFIER"
    r5: "tbl.col          | NODE_COLUMN_REF"
    r6: "( expr )         | parenthesized"
    r7: "- primary        | NODE_UNARY_EXPR"
    r8: "NOT expr(bp=25)  | NODE_UNARY_EXPR"
  }
  binary_node: {
    shape: sql_table
    label: "NODE_BINARY_EXPR (parser.h)"
    r0: "0x00 | TokenType | op"
    r1: "0x04 | AstNode*  | left"
    r2: "0x0C | AstNode*  | right"
    r3: "0x14 | int       | line"
    r4: "0x18 | int       | column"
    r5: "Total | 28 bytes | —"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  precedence_table: {
    shape: sql_table
    label: "Binding Power Table (parser.c)"
    r0: "OR  | LBP=10 | loosest"
    r1: "AND | LBP=20 | tighter than OR"
    r2: "NOT | BP=25  | unary prefix"
    r3: "= != < > <= >= IS | LBP=30 | comparison"
    r4: "+ - | LBP=40 | additive"
    r5: "* / | LBP=50 | multiplicative"
    r6: "primary | — | leaf / no operator"
  }
  recovery_note: {
    shape: sql_table
    label: "Error Recovery (parser.c:synchronize)"
    r0: "TOKEN_ERROR     | emit at bad char"
    r1: "TOKEN_SEMICOLON | sync boundary"
    r2: "panic-mode      | consume to ';'"
    r3: "had_error=0     | reset for next stmt"
  }
}
row1.select_stmt -> row2.column_list: "column_list"
row1.select_stmt -> row2.table_ref: "table_ref"
row1.select_stmt -> row3.expr: "WHERE / LIMIT"
row1.select_stmt -> row2.order_by_item: "ORDER BY"
row1.insert_stmt -> row2.column_list: "col names"
row1.insert_stmt -> row2.table_ref: "table_ref"
row1.insert_stmt -> row3.expr: "VALUES"
row1.create_stmt -> row2.table_ref: "table_ref"
row1.create_stmt -> row2.column_def: "column_def+"
row2.order_by_item -> row3.expr: "sort expr"
row3.expr -> row3.primary: "parse_primary()"
row3.expr -> row3.binary_node: "BinaryOp node"
row3.primary -> row3.binary_node: "builds"
row3.expr -> row4.precedence_table: "LBP lookup"
row3.expr -> row4.recovery_note: "on parse error"