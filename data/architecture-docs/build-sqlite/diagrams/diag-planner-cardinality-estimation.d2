direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title_box: "Cardinality Estimation — Error Propagation Through a 3-Table Join" {
  shape: rectangle
  style.fill: "#1E1B4B"
  style.font-color: white
  style.bold: true
  style.font-size: 16
  style.border-radius: 6
}
stage0: "STAGE 0 — Individual Table Statistics (Before Join)" {
  direction: right
  style.fill: "#EEF2FF"
  style.stroke: "#6366F1"
  style.border-radius: 8
  tbl_a: {
    shape: sql_table
    label: "Table A  (orders.db)"
    estimated_row: "Estimated    | 100 rows"
    actual_row: "Actual       | 1,000 rows"
    error_row: "Error Factor | 10× underestimate"
    note_row: "Cause: stale ANALYZE (pre-bulk-load)"
    style.fill: "#FEF9C3"
    style.stroke: "#CA8A04"
  }
  tbl_b: {
    shape: sql_table
    label: "Table B  (customers.db)"
    estimated_row: "Estimated    | 5 rows per probe"
    actual_row: "Actual       | 50 rows per probe"
    error_row: "Error Factor | 10× underestimate"
    note_row: "Cause: correlated columns, no histogram"
    style.fill: "#FEF9C3"
    style.stroke: "#CA8A04"
  }
  tbl_c: {
    shape: sql_table
    label: "Table C  (products.db)"
    estimated_row: "Estimated    | 5 rows per probe"
    actual_row: "Actual       | 50 rows per probe"
    error_row: "Error Factor | 10× underestimate"
    note_row: "Cause: skewed distribution, no MCV list"
    style.fill: "#FEF9C3"
    style.stroke: "#CA8A04"
  }
}
stage1: "STAGE 1 — After JOIN: A ⋈ B  (First Error Multiplication)" {
  direction: right
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 8
  join1_est: {
    shape: sql_table
    label: "Planner Estimate  (WRONG)"
    rows_out: "Output Rows  | 500  rows"
    formula: "Formula      | est(A) × est(B) × join_sel"
    calculation: "Calculation  | 100 × 5 × 1.0 = 500"
    cost_est: "Cost Estim.  | 500 rows  → chose nested-loop"
    style.fill: "#FEF9C3"
    style.stroke: "#CA8A04"
  }
  join1_act: {
    shape: sql_table
    label: "Actual Runtime  (TRUTH)"
    rows_out: "Output Rows  | 50,000 rows"
    formula: "Formula      | act(A) × act(B) × join_sel"
    calculation: "Calculation  | 1,000 × 50 × 1.0 = 50,000"
    cost_est: "Impact       | nested-loop: 50,000 random reads"
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
  }
  join1_error: {
    shape: sql_table
    label: "Compounded Error"
    magnitude: "Error Factor | 100×  (10 × 10)"
    pattern: "Pattern      | base errors MULTIPLY"
    consequence: "Consequence  | plan grossly underpriced"
    style.fill: "#FEE2E2"
    style.stroke: "#991B1B"
    style.font-color: "#7F1D1D"
  }
  join1_est -> join1_act: "actual vs estimate"
  join1_act -> join1_error: "100× gap"
}
stage2: "STAGE 2 — After JOIN: (A ⋈ B) ⋈ C  (Final Error Catastrophe)" {
  direction: right
  style.fill: "#FFF1F2"
  style.stroke: "#BE123C"
  style.border-radius: 8
  join2_est: {
    shape: sql_table
    label: "Planner Estimate  (WRONG)"
    rows_out: "Output Rows  | 2,500 rows"
    formula: "Formula      | est(A⋈B) × est(C) × join_sel"
    calculation: "Calculation  | 500 × 5 × 1.0 = 2,500"
    cost_est: "Cost Estim.  | 2,500 rows  → plan approved"
    style.fill: "#FEF9C3"
    style.stroke: "#CA8A04"
  }
  join2_act: {
    shape: sql_table
    label: "Actual Runtime  (TRUTH)"
    rows_out: "Output Rows  | 2,500,000 rows"
    formula: "Formula      | act(A⋈B) × act(C) × join_sel"
    calculation: "Calculation  | 50,000 × 50 × 1.0 = 2,500,000"
    cost_est: "Impact       | query runs 1000× slower than predicted"
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
  }
  join2_error: {
    shape: sql_table
    label: "Compounded Error — CRITICAL"
    magnitude: "Error Factor | 1,000×  (10 × 10 × 10)"
    pattern: "Pattern      | errors compound exponentially with depth"
    consequence: "Consequence  | minutes instead of milliseconds"
    formula: "Formula      | err(N-table join) = Π(err_i)  for i=1..N"
    style.fill: "#4C0519"
    style.font-color: "#FCA5A5"
    style.stroke: "#9F1239"
  }
  join2_est -> join2_act: "actual vs estimate"
  join2_act -> join2_error: "1000× gap"
}
summary_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  why_matters: "Why Join Order Matters" {
    direction: down
    style.fill: "#0F172A"
    style.stroke: "#334155"
    style.border-radius: 8
    style.font-color: white
    wm1: "Correct order: filter small tables first" {
      style.fill: "#14532D"
      style.font-color: "#BBF7D0"
    }
    wm2: "Wrong order: large × large = exponential blowup" {
      style.fill: "#7F1D1D"
      style.font-color: "#FCA5A5"
    }
    wm3: "Fix: run ANALYZE after bulk data loads" {
      style.fill: "#1E3A5F"
      style.font-color: "#BAE6FD"
    }
    wm4: "Fix: use histogram-based statistics (equi-depth)" {
      style.fill: "#1E3A5F"
      style.font-color: "#BAE6FD"
    }
    wm5: "Fix: adaptive query re-optimization mid-execution" {
      style.fill: "#1E3A5F"
      style.font-color: "#BAE6FD"
    }
  }
  error_table: {
    shape: sql_table
    label: "Error Compounding Summary"
    h0: "Stage            | Estimated | Actual     | Error"
    r1: "Single table (A) | 100       | 1,000      | 10×"
    r2: "After A ⋈ B      | 500       | 50,000     | 100×"
    r3: "After (A⋈B) ⋈ C  | 2,500     | 2,500,000  | 1,000×"
    r4: "General: N tables| est       | act        | 10^N×"
    style.fill: "#0F172A"
    style.font-color: "#E2E8F0"
    style.stroke: "#475569"
  }
}
title_box -> stage0: "begin query planning"
stage0 -> stage1: "JOIN A ⋈ B  |  10× error × 10× error" {
  style.stroke: "#EA580C"
  style.stroke-width: 3
}
stage1 -> stage2: "JOIN (A⋈B) ⋈ C  |  100× error × 10× error" {
  style.stroke: "#BE123C"
  style.stroke-width: 3
}
stage2 -> summary_row: "final compounded error = 1,000×" {
  style.stroke: "#9F1239"
  style.stroke-width: 3
  style.stroke-dash: 4
}