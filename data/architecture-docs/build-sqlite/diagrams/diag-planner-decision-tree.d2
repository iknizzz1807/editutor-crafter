direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Query Planner Decision Flow — Data Walk" {
  shape: text
  style: {
    font-size: 22
    bold: true
    font-color: "#1a1a2e"
  }
}
query_input: "INPUT QUERY" {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    font-color: "#ffffff"
    bold: true
    border-radius: 6
    font-size: 14
  }
  sql: "SELECT name FROM users\nWHERE email = 'alice@example.com'" {
    shape: code
    style: {
      font-size: 12
    }
  }
}
step1: "STEP 1 — Enumerate Candidate Indexes" {
  shape: rectangle
  style: {
    fill: "#e8f4f8"
    stroke: "#2980b9"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    bold: true
    font-color: "#2980b9"
  }
  table_info: "Table: users" {
    shape: sql_table
    total_rows: "1,000,000 rows" {constraint: primary_key}
    rows_per_page: "DEFAULT = 40 rows/page"
    pages_total: "pages = 1,000,000 / 40 = 25,000"
  }
  candidates: "WHERE column: email" {
    shape: rectangle
    style: {
      fill: "#d6eaf8"
      border-radius: 4
      font-size: 12
    }
    found: "✓ idx_email ON users(email)" {
      shape: rectangle
      style: { fill: "#aed6f1"; border-radius: 3; font-size: 11 }
    }
    also: "✓ TABLE SCAN (always candidate)" {
      shape: rectangle
      style: { fill: "#aed6f1"; border-radius: 3; font-size: 11 }
    }
  }
}
step2: "STEP 2 — Estimate Selectivity from sqlite_stat1" {
  shape: rectangle
  style: {
    fill: "#f4ecf7"
    stroke: "#8e44ad"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    bold: true
    font-color: "#8e44ad"
  }
  stat_table: "sqlite_stat1" {
    shape: sql_table
    tbl: "users"
    idx: "idx_email"
    stat: "1000000 1000000"
  }
  formula: "estimate_selectivity()" {
    shape: rectangle
    style: { fill: "#e8daef"; border-radius: 4; font-size: 12 }
    eq_pred: "EQ predicate → selectivity = 1.0 / distinct_vals" {
      shape: rectangle
      style: { fill: "#d2b4de"; border-radius: 3; font-size: 11 }
    }
    result: "selectivity = 1.0 / 1,000,000 = 0.000001" {
      shape: rectangle
      style: { fill: "#d2b4de"; border-radius: 3; font-size: 11; bold: true }
    }
    matching: "estimated_rows = 1,000,000 × 0.000001 = 1 row" {
      shape: rectangle
      style: { fill: "#d2b4de"; border-radius: 3; font-size: 11 }
    }
  }
}
step3: "STEP 3 — Compute Cost per Access Path" {
  shape: rectangle
  style: {
    fill: "#fef9e7"
    stroke: "#d68910"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    bold: true
    font-color: "#d68910"
  }
  row_paths: paths_row {
    direction: right
    style: { fill: "transparent"; stroke: "transparent" }
    path_scan: "ACCESS_TABLE_SCAN" {
      shape: rectangle
      style: {
        fill: "#fdebd0"
        stroke: "#e59866"
        border-radius: 5
        font-size: 12
      }
      scan_formula: "cost = total_rows / rows_per_page" {
        shape: rectangle
        style: { fill: "#fad7a0"; border-radius: 3; font-size: 11 }
      }
      scan_calc: "cost = 1,000,000 / 40" {
        shape: rectangle
        style: { fill: "#fad7a0"; border-radius: 3; font-size: 11 }
      }
      scan_result: "cost = 25,000 pages" {
        shape: rectangle
        style: { fill: "#f0a30a"; font-color: "#ffffff"; bold: true; border-radius: 3; font-size: 12 }
      }
      scan_rows: "est_rows = 1,000,000" {
        shape: rectangle
        style: { fill: "#fad7a0"; border-radius: 3; font-size: 11 }
      }
    }
    path_idx: "ACCESS_INDEX_SCAN (idx_email)" {
      shape: rectangle
      style: {
        fill: "#d5f5e3"
        stroke: "#27ae60"
        border-radius: 5
        font-size: 12
      }
      idx_formula: "cost = log₂(depth) + leaf_pages\n     + matching_rows × RANDOM_IO / rows_per_page" {
        shape: rectangle
        style: { fill: "#a9dfbf"; border-radius: 3; font-size: 11 }
      }
      idx_vars: "depth=20, leaf_pages=1667, matching=1\nRANDOM_IO_COST_FACTOR=5" {
        shape: rectangle
        style: { fill: "#a9dfbf"; border-radius: 3; font-size: 11 }
      }
      idx_calc: "cost = log₂(20) + 1667 + 1×5/40\n     ≈ 4.32 + 1667 + 0.125" {
        shape: rectangle
        style: { fill: "#a9dfbf"; border-radius: 3; font-size: 11 }
      }
      idx_result: "cost ≈ 1,671 pages" {
        shape: rectangle
        style: { fill: "#1e8449"; font-color: "#ffffff"; bold: true; border-radius: 3; font-size: 12 }
      }
      idx_rows: "est_rows = 1" {
        shape: rectangle
        style: { fill: "#a9dfbf"; border-radius: 3; font-size: 11 }
      }
    }
  }
}
step4: "STEP 4 — Pick Minimum Cost Plan" {
  shape: rectangle
  style: {
    fill: "#eafaf1"
    stroke: "#1e8449"
    stroke-width: 3
    border-radius: 6
    font-size: 13
    bold: true
    font-color: "#1e8449"
  }
  comparison: cost_compare_row {
    direction: right
    style: { fill: "transparent"; stroke: "transparent" }
    loser: "✗ TABLE SCAN" {
      shape: rectangle
      style: {
        fill: "#fadbd8"
        stroke: "#e74c3c"
        stroke-width: 2
        border-radius: 5
        font-size: 12
        font-color: "#c0392b"
      }
      loser_cost: "cost = 25,000 pages" {
        shape: rectangle
        style: { fill: "#f1948a"; border-radius: 3; font-size: 12; bold: true }
      }
      loser_why: "25,000 >> 1,671 → REJECTED" {
        shape: rectangle
        style: { fill: "#fadbd8"; border-radius: 3; font-size: 11; font-color: "#922b21" }
      }
    }
    winner: "✓ INDEX SCAN — idx_email" {
      shape: rectangle
      style: {
        fill: "#d5f5e3"
        stroke: "#1e8449"
        stroke-width: 3
        border-radius: 5
        font-size: 12
        font-color: "#145a32"
        bold: true
      }
      win_cost: "cost = 1,671 pages  ← MINIMUM" {
        shape: rectangle
        style: { fill: "#27ae60"; font-color: "#ffffff"; bold: true; border-radius: 3; font-size: 12 }
      }
      win_sel: "selectivity = 0.000001 | est_rows = 1" {
        shape: rectangle
        style: { fill: "#a9dfbf"; border-radius: 3; font-size: 11 }
      }
      win_struct: "chosen AccessPath {" {
        shape: rectangle
        style: { fill: "#a9dfbf"; border-radius: 3; font-size: 11; font-color: "#145a32" }
      }
      win_fields: "  type        = ACCESS_INDEX_SCAN\n  index_name  = \"idx_email\"\n  selectivity = 0.000001\n  cost        = 1671.445\n  est_rows    = 1\n}" {
        shape: code
        style: { font-size: 11 }
      }
    }
  }
}
step5: "STEP 5 — Generate VDBE Bytecode for Chosen Plan" {
  shape: rectangle
  style: {
    fill: "#eaf2ff"
    stroke: "#2471a3"
    stroke-width: 2
    border-radius: 6
    font-size: 13
    bold: true
    font-color: "#1a5276"
  }
  emit_row: bytecode_emit_row {
    direction: right
    style: { fill: "transparent"; stroke: "transparent" }
    compiler_box: "planner_emit_bytecode()" {
      shape: rectangle
      style: { fill: "#d6eaf8"; border-radius: 5; font-size: 12 }
      input: "input: chosen AccessPath\n       (ACCESS_INDEX_SCAN, idx_email)" {
        shape: rectangle
        style: { fill: "#aed6f1"; border-radius: 3; font-size: 11 }
      }
      branch: "switch(path->type)" {
        shape: rectangle
        style: { fill: "#aed6f1"; border-radius: 3; font-size: 11; font-color: "#1a5276" }
      }
    }
    bytecode_out: "Emitted VDBE Program" {
      shape: rectangle
      style: { fill: "#d6eaf8"; stroke: "#2471a3"; border-radius: 5; font-size: 12 }
      ops: "OP  Opcode        P1   P2   P3\n──────────────────────────────────────\n00  OpenTable     0    0    users\n01  OpenIndex     1    0    idx_email\n02  IndexSeek     1    8    'alice@...'\n03  IndexRowid    1    r1   —\n04  SeekRowid     0    8    r1\n05  Column        0    1    r2   ← name\n06  ResultRow     r2   1    —\n07  IndexNext     1    2    —\n08  Halt          —    —    —" {
        shape: code
        style: { font-size: 11 }
      }
    }
  }
}
output_plan: "QUERY PLAN OUTPUT" {
  shape: rectangle
  style: {
    fill: "#1a5276"
    font-color: "#ffffff"
    bold: true
    border-radius: 6
    font-size: 13
  }
  plan_text: "SEARCH TABLE users USING INDEX idx_email (email=?)\n  → Est. rows: 1  |  Est. cost: 1,671 pages  |  Selectivity: 0.000001" {
    shape: code
    style: { font-size: 12 }
  }
}
query_input -> step1: "parsed WHERE clause\nemail column identified" {
  style: { stroke: "#2980b9"; stroke-width: 2; font-size: 11 }
}
step1 -> step2: "candidates[]\n[TABLE_SCAN, idx_email]" {
  style: { stroke: "#8e44ad"; stroke-width: 2; font-size: 11 }
}
step2 -> step3: "selectivity = 0.000001\nest_rows = 1" {
  style: { stroke: "#d68910"; stroke-width: 2; font-size: 11 }
}
step3 -> step4: "AccessPath[] costs computed\ntable=25000, idx_email=1671" {
  style: { stroke: "#1e8449"; stroke-width: 2; font-size: 11 }
}
step4 -> step5: "best AccessPath selected\nACCESS_INDEX_SCAN, cost=1671" {
  style: { stroke: "#2471a3"; stroke-width: 2; font-size: 11; bold: true }
}
step5 -> output_plan: "VDBE program (9 opcodes)\nready for execution engine" {
  style: { stroke: "#1a5276"; stroke-width: 2; font-size: 11; bold: true }
}
legend: "LEGEND" {
  shape: rectangle
  style: {
    fill: "#f8f9fa"
    stroke: "#bdc3c7"
    border-radius: 5
    font-size: 12
    bold: true
  }
  leg_row: legend_items {
    direction: right
    style: { fill: "transparent"; stroke: "transparent" }
    l1: "■ Green = chosen / winner path" {
      shape: rectangle
      style: { fill: "#d5f5e3"; stroke: "#27ae60"; border-radius: 3; font-size: 11 }
    }
    l2: "■ Red = rejected path" {
      shape: rectangle
      style: { fill: "#fadbd8"; stroke: "#e74c3c"; border-radius: 3; font-size: 11 }
    }
    l3: "■ Blue = data flow" {
      shape: rectangle
      style: { fill: "#d6eaf8"; stroke: "#2980b9"; border-radius: 3; font-size: 11 }
    }
    l4: "■ Yellow = cost calculation" {
      shape: rectangle
      style: { fill: "#fdebd0"; stroke: "#d68910"; border-radius: 3; font-size: 11 }
    }
  }
}