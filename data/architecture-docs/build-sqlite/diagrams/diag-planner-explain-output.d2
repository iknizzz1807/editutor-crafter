direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "EXPLAIN Output — Table Scan vs Index Scan" {
  near: top-center
  shape: text
  style: {
    font-size: 20
    bold: true
  }
}
queries: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  q_low: "Query A — Low Selectivity" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.border-radius: 6
    sql: |'
      SELECT * FROM users WHERE gender = 'M';
      -- ~50% of rows match: 500,000 rows in 1M-row table
      -- 2 distinct values -> selectivity = 1/2 = 50%
    '|
    width: 420
  }
  q_high: "Query B — High Selectivity" {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.border-radius: 6
    sql: |'
      SELECT name FROM users
      WHERE email = 'alice@example.com';
      -- ~0.0001% match: 1 row in 1M-row table
      -- 1M distinct values -> selectivity = 1/1,000,000
    '|
    width: 420
  }
}
planner: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  decision_a: {
    shape: sql_table
    label: "Planner Decision — Query A"
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
    access_path: "Access path: FULL TABLE SCAN"
    index_used: "Index applied: none"
    distinct_vals: "Distinct values: 2  (M, F)"
    selectivity: "Selectivity: 50%   threshold: 20%"
    scan_cost: "Est. table scan cost: 25,000 page reads"
    index_cost: "Est. index scan cost: 2,500,006 page reads"
    verdict: "VERDICT: table scan wins (index too expensive)"
  }
  decision_b: {
    shape: sql_table
    label: "Planner Decision — Query B"
    style.fill: "#F1F8E9"
    style.stroke: "#388E3C"
    access_path: "Access path: INDEX SCAN"
    index_used: "Index applied: idx_users_email (UNIQUE)"
    distinct_vals: "Distinct values: 1,000,000"
    selectivity: "Selectivity: 0.0001%   threshold: 20%"
    scan_cost: "Est. table scan cost: 25,000 page reads"
    index_cost: "Est. index scan cost: 6 page reads"
    verdict: "VERDICT: index scan wins (6 vs 25,000 pages)"
  }
}
bytecode: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bc_scan: "Bytecode — TABLE SCAN" {
    style.fill: "#FFFDE7"
    style.stroke: "#FFB300"
    style.border-radius: 4
    width: 460
    code: |'
      addr  opcode       p1  p2   comment
      ----  -----------  --  ---  ---------------------------
        0   OpenTable     0   0   cursor 0 = table 'users'
        1   Rewind        0   7   seek to first row; empty->7
        2   Column        0   2   r1 = users.gender
        3   String8       0   2   r2 = literal 'M'
        4   Ne            1   6   if r1 != r2 skip to Next(6)
        5   ResultRow     3   5   emit columns [0..4]
        6   Next          0   2   advance cursor; more->addr 2
        7   Halt          0   0   end program
      Pattern: Rewind + Next loop over ALL rows
      No index opened. Sequential page access.
      Est. rows examined : 1,000,000
      Est. rows returned :   500,000
      Est. cost          :    25,000 page reads
    '|
  }
  bc_index: "Bytecode — INDEX SCAN + ROWID LOOKUP" {
    style.fill: "#F1F8E9"
    style.stroke: "#43A047"
    style.border-radius: 4
    width: 460
    code: |'
      addr  opcode        p1  p2   comment
      ----  ------------  --  ---  ---------------------------
        0   OpenTable      0   0   cursor 0 = table 'users'
        1   OpenIndex      1   0   cursor 1 = idx_users_email
        2   String8        0   2   r2 = 'alice@example.com'
        3   SeekGE         1  11   descend index to key >= r2
        4   IdxGT          1  11   if index key > r2 stop->11
        5   IndexRowid     1   4   r4 = rowid from index leaf
        6   SeekRowid      0  10   descend table to rowid r4
        7   Column         0   1   r5 = users.name
        8   ResultRow      5   1   emit column [name]
        9   Next           1   4   advance index cursor; more->4
       10   Goto           0   4   (loop back)
       11   Halt           0   0   end program
      Pattern: SeekGE/IdxGT + per-row Rowid lookup
      Double tree descent per result row.
      Est. rows examined :         1
      Est. rows returned :         1
      Est. cost          :   6 page reads (3 index + 3 table)
    '|
  }
}
costs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cost_a: {
    shape: sql_table
    label: "Cost Profile — TABLE SCAN"
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    pages_read: "Pages read: 25,000  (1M rows / 40 rows per page)"
    io_pattern: "I/O pattern: sequential (OS prefetch applies)"
    filter_work: "Filter work: Column + Ne comparison x 1,000,000"
    random_penalty: "Random I/O penalty: none"
    cold_estimate: "Cold cache latency: ~2,500 ms"
    warm_estimate: "Warm cache latency: ~250 ms"
    rule: "Wins when: selectivity >= ~20% (many rows match)"
  }
  cost_b: {
    shape: sql_table
    label: "Cost Profile — INDEX SCAN"
    style.fill: "#DCEDC8"
    style.stroke: "#558B2F"
    index_descent: "Index B-tree descent: 3 pages  (log_200 of 1M)"
    leaf_read: "Index leaf page read: 1 page"
    table_lookup: "Table rowid lookup: 2 pages  (root + leaf)"
    total_pages: "Total pages read: ~6"
    random_penalty: "Random I/O penalty: 5x factor applied in planner"
    cold_estimate: "Cold cache latency: ~0.6 ms"
    warm_estimate: "Warm cache latency: ~60 ns"
    rule: "Wins when: selectivity < ~20% (few rows match)"
  }
}
queries.q_low -> planner.decision_a: "analyze" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
queries.q_high -> planner.decision_b: "analyze" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
planner.decision_a -> bytecode.bc_scan: "compile" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
planner.decision_b -> bytecode.bc_index: "compile" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
bytecode.bc_scan -> costs.cost_a: "profile" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
bytecode.bc_index -> costs.cost_b: "profile" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}