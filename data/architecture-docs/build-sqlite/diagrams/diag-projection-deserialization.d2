direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Column Projection: SELECT col2, col4 FROM t
  Header parsed linearly to compute offsets; non-projected value bytes are never read.
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  record_mem: {
    shape: sql_table
    label: "Serialized Record in Memory"
    h0: "0x00 | varint(1B) | header_size = 0x0E  (14 bytes total header)"
    h1: "0x01 | varint(1B) | serial_type[0] = 4  → col0: INT-32 (4 bytes)"
    h2: "0x02 | varint(1B) | serial_type[1] = 21 → col1: TEXT len=4"
    h3: "0x03 | varint(1B) | serial_type[2] = 1  → col2: INT-8  (1 byte)  ★"
    h4: "0x04 | varint(1B) | serial_type[3] = 23 → col3: TEXT len=5"
    h5: "0x05 | varint(1B) | serial_type[4] = 6  → col4: INT-64 (8 bytes) ★"
    sep: "——————— header boundary at byte 0x0E ———————"
    v0: "0x0E | 4 bytes    | col0 value = 0x000000D2  [SKIPPED — never read]"
    v1: "0x12 | 4 bytes    | col1 value = 'name'      [SKIPPED — never read]"
    v2: "0x16 | 1 byte     | col2 value = 0x1E = 30   [DECODED ★ offset=0x16]"
    v3: "0x17 | 5 bytes    | col3 value = 'hello'     [SKIPPED — never read]"
    v4: "0x1C | 8 bytes    | col4 value = 0x1A = 26   [DECODED ★ offset=0x1C]"
    style.fill: "#0d1b2a"
    style.font-color: "#c8d8e8"
    style.stroke: "#4a6fa5"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step_a: {
    label: "Step 1 — Read Header Size"
    width: 420
    code: |'c
      int pos = 0;
      uint64_t header_size;
      pos += varint_decode(record + pos,
                           &header_size);
      // header_size = 14, pos = 1
      int value_off = (int)header_size; // 0x0E
    '|
    style.fill: "#1a2744"
    style.font-color: "#aac8ff"
    style.stroke: "#4a6fa5"
  }
  step_b: {
    label: "Step 2 — Scan Serial Types for col2 (col_idx=2)"
    width: 520
    code: |'c
      // col=0: st=4,  value_off += 4 → 0x12  (skipped)
      // col=1: st=21, value_off += 4 → 0x16  (skipped)
      // col=2: st=1,  col==col_idx → DECODE
      decode_value(record + 0x16, /*st=*/1, dest);
      // dest->i = 30
    '|
    style.fill: "#1a2744"
    style.font-color: "#aac8ff"
    style.stroke: "#4a6fa5"
  }
  step_c: {
    label: "Step 3 — Scan Serial Types for col4 (col_idx=4)"
    width: 520
    code: |'c
      // col=0: st=4,  value_off += 4 → 0x12  (skipped)
      // col=1: st=21, value_off += 4 → 0x16  (skipped)
      // col=2: st=1,  value_off += 1 → 0x17  (skipped)
      // col=3: st=23, value_off += 5 → 0x1C  (skipped)
      // col=4: st=6,  col==col_idx → DECODE
      decode_value(record + 0x1C, /*st=*/6, dest);
      // dest->i = 26
    '|
    style.fill: "#1a2744"
    style.font-color: "#aac8ff"
    style.stroke: "#4a6fa5"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  col0_skip: {
    shape: sql_table
    label: "col0 — SKIPPED"
    serial: "serial_type = 4   | parsed to get size=4"
    value_bytes: "bytes 0x0E..0x11  | NEVER read"
    style.fill: "#2a2a2a"
    style.font-color: "#777777"
    style.stroke: "#555555"
  }
  col1_skip: {
    shape: sql_table
    label: "col1 — SKIPPED"
    serial: "serial_type = 21  | parsed to get size=4"
    value_bytes: "bytes 0x12..0x15  | NEVER read"
    style.fill: "#2a2a2a"
    style.font-color: "#777777"
    style.stroke: "#555555"
  }
  col2_hit: {
    shape: sql_table
    label: "col2 — PROJECTED ★"
    serial: "serial_type = 1   | parsed → size = 1 byte"
    value_bytes: "byte  0x16        | READ → 0x1E = 30"
    result: "dest.type = COL_INTEGER  dest.i = 30"
    style.fill: "#0d2b0d"
    style.font-color: "#88ee88"
    style.stroke: "#00cc44"
    style.stroke-width: 2
  }
  col3_skip: {
    shape: sql_table
    label: "col3 — SKIPPED"
    serial: "serial_type = 23  | parsed to get size=5"
    value_bytes: "bytes 0x17..0x1B  | NEVER read"
    style.fill: "#2a2a2a"
    style.font-color: "#777777"
    style.stroke: "#555555"
  }
  col4_hit: {
    shape: sql_table
    label: "col4 — PROJECTED ★"
    serial: "serial_type = 6   | parsed → size = 8 bytes"
    value_bytes: "bytes 0x1C..0x23  | READ → 0x1A = 26"
    result: "dest.type = COL_INTEGER  dest.i = 26"
    style.fill: "#0d2b0d"
    style.font-color: "#88ee88"
    style.stroke: "#00cc44"
    style.stroke-width: 2
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cost_model: {
    shape: sql_table
    label: "Projection Cost vs Full Deserialize"
    hdr_parse: "header scan    | O(col_idx)       | parse varints 0..col_idx only"
    val_read: "value decode   | O(1)             | single read at computed offset"
    allocs: "allocations    | O(projected)     | only for TEXT/BLOB outputs"
    skipped_io: "skipped cols   | 0 bytes read     | value bytes never touched"
    full_cost: "full decode    | O(n) + O(n) mem  | all serial types + all values"
    speedup: "SELECT 2/5 cols | ~2.5x fewer allocs | 3 value regions untouched"
    style.fill: "#0d1b2a"
    style.font-color: "#c8d8e8"
    style.stroke: "#4a6fa5"
  }
  legend: {
    shape: sql_table
    label: "Legend"
    gray_col: "Gray box    | SKIPPED — serial type parsed, value bytes ignored"
    green_col: "Green box   | PROJECTED — value bytes read and decoded into dest"
    blue_step: "Blue step   | Algorithm step inside record_read_column()"
    offset_note: "value_off   | Running sum of skipped column sizes in header scan"
    style.fill: "#0d1b2a"
    style.font-color: "#c8d8e8"
    style.stroke: "#4a6fa5"
  }
}
row1 -> row2: "record ptr + col_idx passed to record_read_column()" {
  style.stroke: "#4a6fa5"
  style.font-color: "#4a6fa5"
}
row2 -> row3: "decoded ColumnValue written to dest" {
  style.stroke: "#00cc44"
  style.font-color: "#00cc44"
}
row3 -> row4: "access pattern summary" {
  style.stroke: "#888888"
  style.font-color: "#888888"
}