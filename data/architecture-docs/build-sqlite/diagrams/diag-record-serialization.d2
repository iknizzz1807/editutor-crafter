direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  header_byte: {
    style: {
      fill: "#E8D5F5"
      stroke: "#7939A8"
      font-size: 13
      border-radius: 3
    }
  }
  value_byte: {
    style: {
      fill: "#D5E8F5"
      stroke: "#2B6CB0"
      font-size: 13
      border-radius: 3
    }
  }
  offset_label: {
    style: {
      fill: "#F0F0F0"
      stroke: "#888"
      font-size: 11
      font-color: "#555"
      border-radius: 2
    }
  }
  section_label: {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 14
      bold: true
    }
  }
}
title: {
  label: "Record Serialization Format (record.c)"
  style: {
    font-size: 20
    bold: true
    fill: transparent
    stroke: transparent
  }
}
input_row: {
  label: "Input Row: id=42, name='Alice', age=30, score=3.14"
  style: {
    fill: "#FFF9E6"
    stroke: "#D4A017"
    font-size: 15
    bold: true
    border-radius: 6
  }
}
record_layout: "Complete Serialized Record (23 bytes)" {
  style: {
    fill: "#FAFAFA"
    stroke: "#333"
    border-radius: 8
  }
  header_section: "RECORD HEADER (6 bytes)" {
    direction: right
    style: {
      fill: "#F3E8FF"
      stroke: "#7939A8"
      border-radius: 6
    }
    hdr_size: {
      shape: sql_table
      label: "Byte 0: Header Size"
      b0: "0x06 | varint | header_size = 6"
      note: "Includes this byte + 4 type varints"
    }
    type_codes: {
      shape: sql_table
      label: "Bytes 1-5: Serial Type Codes"
      t1: "0x01 | varint | serial_type = 1 (8-bit int)"
      t2: "0x17 | varint | serial_type = 23 (TEXT len=5)"
      t3: "0x01 | varint | serial_type = 1 (8-bit int)"
      t4: "0x07 | varint | serial_type = 7 (IEEE 754 double)"
    }
  }
  value_section: "COLUMN VALUES (17 bytes)" {
    direction: right
    style: {
      fill: "#E8F0FE"
      stroke: "#2B6CB0"
      border-radius: 6
    }
    val_id: {
      shape: sql_table
      label: "Byte 6: id (int8)"
      v0: "0x2A | uint8 | 42 decimal"
      sz: "1 byte (serial_type 1)"
    }
    val_name: {
      shape: sql_table
      label: "Bytes 7-11: name (TEXT)"
      v1: "0x41 | char | 'A'"
      v2: "0x6C | char | 'l'"
      v3: "0x69 | char | 'i'"
      v4: "0x63 | char | 'c'"
      v5: "0x65 | char | 'e'"
      sz: "5 bytes (serial_type 23 → (23-13)/2 = 5)"
    }
    val_age: {
      shape: sql_table
      label: "Byte 12: age (int8)"
      v0: "0x1E | uint8 | 30 decimal"
      sz: "1 byte (serial_type 1)"
    }
    val_score: {
      shape: sql_table
      label: "Bytes 13-20: score (double)"
      v0: "0x40 | byte 0 | IEEE 754 big-endian"
      v1: "0x09 | byte 1 | 3.14 encoded as"
      v2: "0x1E | byte 2 | 0x40091EB851EB851F"
      v3: "0xB8 | byte 3 |"
      v4: "0x51 | byte 4 |"
      v5: "0xEB | byte 5 |"
      v6: "0x85 | byte 6 |"
      v7: "0x1F | byte 7 |"
      sz: "8 bytes (serial_type 7 → always 8)"
    }
  }
}
serial_type_ref: {
  shape: sql_table
  label: "Serial Type Code Reference"
  r0: "0       | NULL         | 0 bytes"
  r1: "1       | int8         | 1 byte"
  r2: "2       | int16 BE     | 2 bytes"
  r3: "3       | int24 BE     | 3 bytes"
  r4: "4       | int32 BE     | 4 bytes"
  r5: "5       | int48 BE     | 6 bytes"
  r6: "6       | int64 BE     | 8 bytes"
  r7: "7       | float64 BE   | 8 bytes"
  r8: "8       | constant 0   | 0 bytes"
  r9: "9       | constant 1   | 0 bytes"
  r10: "N>=12 even | BLOB len=(N-12)/2 | variable"
  r11: "N>=13 odd  | TEXT len=(N-13)/2  | variable"
}
varint_detail: "Varint Encoding Detail (varint.c)" {
  style: {
    fill: "#E6F9E6"
    stroke: "#2D8B2D"
    border-radius: 6
  }
  small: {
    shape: sql_table
    label: "Small Value: 42"
    b0: "Binary     | 00101010"
    b1: "High bit   | 0 (last byte)"
    b2: "Payload    | 0101010 = 42"
    b3: "Encoding   | 0x2A (1 byte)"
    b4: "Rule       | value <= 0x7F → 1 byte"
  }
  large: {
    shape: sql_table
    label: "Larger Value: 300"
    b0: "Binary     | 1_00101100"
    b1: "Byte 1     | 0x82 = 1_0000010 (continue)"
    b2: "Byte 2     | 0x2C = 0_0101100 (last)"
    b3: "Decode     | (0000010 << 7) | 0101100 = 300"
    b4: "Encoding   | 0x82 0x2C (2 bytes)"
    b5: "Rule       | 128 <= value <= 16383 → 2 bytes"
  }
  savings: {
    shape: sql_table
    label: "Space Savings vs Fixed-Width"
    s1: "Value 42   | varint: 1 byte  | int32: 4 bytes | saves 3"
    s2: "Value 300  | varint: 2 bytes | int32: 4 bytes | saves 2"
    s3: "Value 5    | varint: 1 byte  | int64: 8 bytes | saves 7"
    s4: "Per page   | ~50 rows × ~5 varints × 3 bytes saved ≈ 750 bytes"
  }
}
byte_map: "Byte Offset Map (complete record)" {
  style: {
    fill: "#FFF"
    stroke: "#333"
    border-radius: 4
  }
  map: {
    shape: sql_table
    label: "Offset → Content"
    o00: "0x00 | 0x06       | header_size = 6"
    o01: "0x01 | 0x01       | col 0 type: int8"
    o02: "0x02 | 0x17       | col 1 type: TEXT(5)"
    o03: "0x03 | 0x01       | col 2 type: int8"
    o04: "0x04 | 0x07       | col 3 type: float64"
    o05: "0x05 | -- end hdr | values start below"
    o06: "0x06 | 0x2A       | id = 42"
    o07: "0x07 | 41 6C 69 63 65 | name = 'Alice'"
    o0c: "0x0C | 0x1E       | age = 30"
    o0d: "0x0D | 40 09 1E B8 51 EB 85 1F | score = 3.14"
    tot: "Total: 21 bytes (header 6 + values 15)"
  }
}
input_row -> record_layout: "record_serialize()" {
  style.stroke: "#D4A017"
  style.stroke-width: 2
}
record_layout.header_section.hdr_size -> record_layout.header_section.type_codes: "parse sequentially" {
  style.stroke-dash: 4
  style.stroke: "#7939A8"
}
record_layout.header_section.type_codes -> record_layout.value_section.val_id: "type 1 → read 1 byte" {
  style.stroke: "#2B6CB0"
  style.stroke-dash: 4
}
record_layout.header_section.type_codes -> record_layout.value_section.val_name: "type 23 → read 5 bytes" {
  style.stroke: "#2B6CB0"
  style.stroke-dash: 4
}
record_layout.header_section.type_codes -> record_layout.value_section.val_age: "type 1 → read 1 byte" {
  style.stroke: "#2B6CB0"
  style.stroke-dash: 4
}
record_layout.header_section.type_codes -> record_layout.value_section.val_score: "type 7 → read 8 bytes" {
  style.stroke: "#2B6CB0"
  style.stroke-dash: 4
}
record_layout -> serial_type_ref: "type code lookup" {
  style.stroke-dash: 4
  style.stroke: "#888"
}
record_layout -> varint_detail: "integer encoding" {
  style.stroke-dash: 4
  style.stroke: "#2D8B2D"
}
record_layout -> byte_map: "flat byte view" {
  style.stroke-dash: 4
  style.stroke: "#333"
}