direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}
sql_input: "SQL Text Input" {
  shape: parallelogram
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.font-size: 14
  style.bold: true
}
frontend: "SQL Frontend" {
  style.fill: "#E8EAF6"
  style.stroke: "#3949AB"
  style.border-radius: 8
  pipeline: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    tokenizer: "Tokenizer\n(tokenizer.c)" {
      shape: rectangle
      style.fill: "#C5CAE9"
      style.stroke: "#3949AB"
      style.border-radius: 6
      ms: "M1" {
        shape: oval
        style.fill: "#3949AB"
        style.font-color: white
        style.stroke: "#3949AB"
        style.font-size: 11
        style.bold: true
      }
    }
    parser: "Parser / AST Builder\n(parser.c)" {
      shape: rectangle
      style.fill: "#C5CAE9"
      style.stroke: "#3949AB"
      style.border-radius: 6
      ms: "M2" {
        shape: oval
        style.fill: "#3949AB"
        style.font-color: white
        style.stroke: "#3949AB"
        style.font-size: 11
        style.bold: true
      }
    }
    planner: "Query Planner\n(planner.c)" {
      shape: rectangle
      style.fill: "#9FA8DA"
      style.stroke: "#1A237E"
      style.border-radius: 6
      ms: "M8" {
        shape: oval
        style.fill: "#1A237E"
        style.font-color: white
        style.stroke: "#1A237E"
        style.font-size: 11
        style.bold: true
      }
    }
    codegen: "Code Generator\n(compiler.c)" {
      shape: rectangle
      style.fill: "#C5CAE9"
      style.stroke: "#3949AB"
      style.border-radius: 6
      ms: "M3" {
        shape: oval
        style.fill: "#3949AB"
        style.font-color: white
        style.stroke: "#3949AB"
        style.font-size: 11
        style.bold: true
      }
    }
    tokenizer -> parser: "Token[]"
    parser -> planner: "AST"
    planner -> codegen: "Plan"
  }
}
vdbe: "VDBE — Virtual Machine (vdbe.c)" {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F57F17"
  style.border-radius: 8
  style.font-size: 15
  style.bold: true
  ms_row: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    ms3: "M3: Bytecode Compiler" {
      shape: oval
      style.fill: "#F57F17"
      style.font-color: white
      style.stroke: "#F57F17"
      style.font-size: 11
    }
    ms6: "M6: SELECT / DML Execution" {
      shape: oval
      style.fill: "#E65100"
      style.font-color: white
      style.stroke: "#E65100"
      style.font-size: 11
    }
  }
}
btree_layer: "Storage Engine — B-tree Layer" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 8
  components: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    btree: "Table B-tree\n(btree.c)" {
      shape: rectangle
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
      style.border-radius: 6
      ms_btree: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        ms5: "M5" {
          shape: oval
          style.fill: "#7B1FA2"
          style.font-color: white
          style.stroke: "#7B1FA2"
          style.font-size: 11
          style.bold: true
        }
        ms6b: "M6" {
          shape: oval
          style.fill: "#6A1B9A"
          style.font-color: white
          style.stroke: "#6A1B9A"
          style.font-size: 11
          style.bold: true
        }
      }
    }
    indexes: "Secondary Index B+trees\n(index.c)" {
      shape: rectangle
      style.fill: "#E1BEE7"
      style.stroke: "#4A148C"
      style.border-radius: 6
      ms7: "M7" {
        shape: oval
        style.fill: "#4A148C"
        style.font-color: white
        style.stroke: "#4A148C"
        style.font-size: 11
        style.bold: true
      }
    }
  }
}
pager_layer: "Buffer Pool, Transactions & Durability" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.border-radius: 8
  components: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    pager: "Buffer Pool / Pager\n(buffer_pool.c)" {
      shape: rectangle
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
      style.border-radius: 6
      ms4: "M4" {
        shape: oval
        style.fill: "#2E7D32"
        style.font-color: white
        style.stroke: "#2E7D32"
        style.font-size: 11
        style.bold: true
      }
    }
    txn_mgr: "Transaction Manager\n(transaction.c)" {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.border-radius: 6
      ms9a: "M9" {
        shape: oval
        style.fill: "#C62828"
        style.font-color: white
        style.stroke: "#C62828"
        style.font-size: 11
        style.bold: true
      }
    }
    journal: "Rollback Journal / WAL\n(journal.c, wal.c)" {
      shape: rectangle
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.border-radius: 6
      ms_dur: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        ms9b: "M9" {
          shape: oval
          style.fill: "#BF360C"
          style.font-color: white
          style.stroke: "#BF360C"
          style.font-size: 11
          style.bold: true
        }
        ms10: "M10" {
          shape: oval
          style.fill: "#870000"
          style.font-color: white
          style.stroke: "#870000"
          style.font-size: 11
          style.bold: true
        }
      }
    }
  }
}
osio: "OS I/O Interface — pread / pwrite / fsync (os.c)" {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"
  style.border-radius: 6
  style.font-size: 13
  style.bold: true
}
disk: "Physical Storage (SSD / HDD)" {
  shape: cylinder
  style.fill: "#CFD8DC"
  style.stroke: "#263238"
  style.multiple: true
}
sql_input -> frontend: "SQL text"
frontend -> vdbe: "Bytecode"
vdbe -> btree_layer.components.btree: "cursor ops"
vdbe -> btree_layer.components.indexes: "index ops"
btree_layer.components.btree -> pager_layer.components.pager: "page fetch / write"
btree_layer.components.indexes -> pager_layer.components.pager: "page fetch"
pager_layer.components.pager -> pager_layer.components.txn_mgr: "journal_page"
pager_layer.components.txn_mgr -> pager_layer.components.journal: "write ordering"
pager_layer.components.pager -> osio: "pread / pwrite"
pager_layer.components.journal -> osio: "fsync"
osio -> disk: "block I/O"