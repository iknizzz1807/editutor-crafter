direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  layer-container: {
    style: {
      fill: transparent
      stroke: transparent
    }
  }
  subsystem: {
    style: {
      border-radius: 8
      font-size: 16
      bold: true
    }
  }
  component: {
    style: {
      border-radius: 4
      font-size: 14
    }
  }
  hot-path: {
    style: {
      stroke: "#E74C3C"
      stroke-width: 2
      font-color: "#E74C3C"
    }
  }
  data-flow: {
    style: {
      stroke: "#3498DB"
      stroke-width: 2
    }
  }
  write-path: {
    style: {
      stroke: "#27AE60"
      stroke-width: 2
      stroke-dash: 4
    }
  }
}
# ============================================================
# INPUT
# ============================================================
sql_input: SQL Text Input {
  shape: parallelogram
  style: {
    fill: "#F8F9FA"
    stroke: "#6C757D"
    font-size: 18
    bold: true
  }
}
# ============================================================
# LAYER 1: SQL FRONTEND
# ============================================================
frontend: SQL Frontend {
  style: {
    fill: "#EBF5FB"
    stroke: "#2980B9"
    border-radius: 10
    font-size: 18
    bold: true
  }
  direction: right
  tokenizer: {
    label: "Tokenizer (lexer.c)\n[Milestone 1]"
    class: subsystem
    style.fill: "#D6EAF8"
    fsm: "Finite State Machine"
    token_types: "TokenType enum\n(KEYWORD, IDENTIFIER,\nINTEGER, STRING, ...)"
    peek_advance: "peek() / advance()\nlookahead"
    line_col: "Line:Col tracking"
  }
  parser: {
    label: "Parser (parser.c)\n[Milestone 2]"
    class: subsystem
    style.fill: "#D6EAF8"
    recursive_descent: "Recursive Descent"
    precedence: "Precedence Climbing\n(OR < AND < NOT\n< comparison < arithmetic)"
    ast_nodes: "AstNode tagged union\n(SELECT, INSERT,\nCREATE, UPDATE, DELETE)"
    error_report: "Error at line:col"
  }
  compiler: {
    label: "Bytecode Compiler (compiler.c)\n[Milestone 3]"
    class: subsystem
    style.fill: "#D6EAF8"
    ast_walk: "Single-pass AST walk"
    register_alloc: "Linear scan\nregister allocation"
    jump_patch: "Jump patching\n(forward references)"
    where_compile: "WHERE → inverted\nconditional jumps"
  }
  tokenizer -> parser: "Token[]"
  parser -> compiler: "AstNode*"
}
# ============================================================
# LAYER 2: QUERY PLANNER
# ============================================================
planner: Query Planner {
  label: "Query Planner (planner.c)\n[Milestone 8]"
  style: {
    fill: "#FEF9E7"
    stroke: "#F39C12"
    border-radius: 10
    font-size: 18
    bold: true
  }
  direction: right
  statistics: {
    label: "Statistics (ANALYZE)"
    class: component
    style.fill: "#FCF3CF"
    row_count: "row_count per table"
    page_count: "page_count (leaf pages)"
    ndv: "NDV (distinct values)"
    min_max: "min/max per index"
  }
  cost_model: {
    label: "Cost Model"
    class: component
    style.fill: "#FCF3CF"
    selectivity: "Selectivity estimation\n1/NDV (equality)\n(max-V)/(max-min) (range)"
    scan_cost: "scan_cost = page_count"
    idx_cost: "idx_cost = height +\nleaf_pages +\nest_rows * RANDOM_IO_FACTOR"
    threshold: "MAX_INDEX_SELECTIVITY = 0.20"
  }
  join_optimizer: {
    label: "Join Ordering (DP)"
    class: component
    style.fill: "#FCF3CF"
    dp_subsets: "Bitmask DP over\ntable subsets O(3^n)"
    cardinality: "|A ⋈ B| = |A|*|B| /\nmax(NDV_a, NDV_b)"
    join_cond_check: "Only join subsets\nwith join conditions"
  }
  statistics -> cost_model: "NDV, counts"
  cost_model -> join_optimizer: "per-table costs"
}
# ============================================================
# LAYER 3: VDBE (Virtual Database Engine)
# ============================================================
vdbe: VDBE — Virtual Database Engine {
  label: "VDBE Execution Engine (vdbe.c)\n[Milestones 3, 6, 11]"
  style: {
    fill: "#FDEDEC"
    stroke: "#E74C3C"
    border-radius: 10
    font-size: 18
    bold: true
  }
  direction: right
  program: {
    label: "Program"
    class: component
    style.fill: "#FADBD8"
    opcodes: "VdbeOp[] instruction array"
    string_pool: "String constant pool"
    agg_types: "AggType[] definitions"
  }
  vm_core: {
    label: "Fetch-Decode-Execute Loop"
    class: component
    style.fill: "#FADBD8"
    pc: "Program Counter (int pc)"
    registers: "Value registers[256]"
    dispatch: "switch(op->opcode)"
  }
  opcode_catalog: {
    label: "Opcode Catalog"
    class: component
    style.fill: "#FADBD8"
    control: "Init, Halt, Goto"
    cursor_ops: "OpenRead, Rewind,\nNext, Column, Close"
    record_ops: "MakeRecord, Insert,\nDelete, SeekRowid"
    compare: "Eq, Ne, Lt, Le,\nGt, Ge, IsNull"
    arith: "Add, Subtract,\nMultiply, Divide"
    agg_ops: "AggInit, AggStep,\nAggFinal, AggGroupStep"
    txn_ops: "Transaction\n(BEGIN/COMMIT/ROLLBACK)"
    idx_ops: "OpenIndexRead,\nIdxSeek, IdxRowid"
  }
  explain: {
    label: "EXPLAIN Output"
    class: component
    style.fill: "#FADBD8"
    format: "addr | opcode | p1 | p2 | p3 | comment"
    plan_info: "QUERY PLAN header\n(selectivity, cost,\naccess path)"
  }
  program -> vm_core: "VdbeOp*"
  vm_core -> opcode_catalog: "dispatch"
}
# ============================================================
# LAYER 4: CURSOR INTERFACE
# ============================================================
cursor_iface: Cursor Interface (Iterator Pattern) {
  style: {
    fill: "#F5EEF8"
    stroke: "#8E44AD"
    border-radius: 10
    font-size: 16
    bold: true
  }
  direction: right
  table_cursor: {
    label: "Table Cursor\n(BTreeCursor)"
    class: component
    style.fill: "#E8DAEF"
    ops: "open() → rewind() →\nnext() → column() →\nclose()"
    stack: "Parent chain stack\n(page_id, cell_idx)\nMAX_DEPTH=20"
  }
  index_cursor: {
    label: "Index Cursor\n[Milestone 7]"
    class: component
    style.fill: "#E8DAEF"
    idx_ops: "IdxSeek → IdxKey →\nIdxRowid → IdxNext"
    leaf_chain: "Follow leaf→leaf\npointers for range scan"
    double_lookup: "index B+tree → rowid\n→ table B-tree → row"
  }
  agg_engine: {
    label: "Aggregate Engine\n[Milestone 11]"
    class: component
    style.fill: "#E8DAEF"
    accumulators: "Accumulator:\ninit → step → finalize"
    group_ht: "GroupHashTable\n(key → Accumulator[])"
    null_handling: "COUNT(*): counts all\nSUM/AVG: skip NULL\nempty set → NULL"
    having: "HAVING: filter\ngroups post-aggregation"
  }
}
# ============================================================
# LAYER 5: STORAGE ENGINE
# ============================================================
storage: B-tree / B+tree Storage Engine {
  label: "Storage Engine (btree.c)\n[Milestone 5]"
  style: {
    fill: "#E8F8F5"
    stroke: "#1ABC9C"
    border-radius: 10
    font-size: 18
    bold: true
  }
  direction: right
  table_btree: {
    label: "Table B-tree"
    class: subsystem
    style.fill: "#D1F2EB"
    key: "Key: rowid (int64)"
    data: "Data: full row record\nin every node"
    leaf_type: "Leaf: 0x0D"
    internal_type: "Internal: 0x05"
  }
  index_bplustree: {
    label: "Index B+tree\n[Milestone 7]"
    class: subsystem
    style.fill: "#D1F2EB"
    key: "Key: (col_value, rowid)"
    data: "Data in leaves ONLY"
    leaf_link: "Leaves linked\nfor range scans"
    leaf_type: "Leaf: 0x0A"
    internal_type: "Internal: 0x02"
  }
  page_format: {
    label: "Slotted Page Layout"
    class: component
    style.fill: "#D1F2EB"
    header: "Page Header (8-12 bytes)\ntype | freeblock | cell_count\ncontent_start | frag_bytes"
    cell_ptrs: "Cell Pointer Array →\n(sorted by key, 2 bytes each)"
    free_space: "← FREE SPACE →"
    cell_content: "← Cell Content\n(grows from page end)"
  }
  record_format: {
    label: "Record Serialization"
    class: component
    style.fill: "#D1F2EB"
    layout: "[header_size varint]\n[serial_type varints...]\n[values...]"
    varints: "Varint encoding\n1-9 bytes per integer"
    serial_types: "0=NULL, 1-6=int(1-8B)\n7=float, 8=zero, 9=one\n>=12=blob, >=13=text"
    big_endian: "All multi-byte ints:\nbig-endian on disk"
  }
  node_ops: {
    label: "Node Operations"
    class: component
    style.fill: "#D1F2EB"
    search: "Binary search within page\nO(log cells_per_page)"
    insert: "page_insert_cell()\nbidirectional growth"
    split: "Split at median →\npromote key to parent\n→ recursive if parent full"
    delete: "Remove cell pointer\nmark fragmented bytes\ndefragment at threshold"
  }
}
# ============================================================
# LAYER 6: SYSTEM CATALOG
# ============================================================
catalog: System Catalog {
  label: "System Catalog (sqlite_master)\n[Milestone 5]"
  style: {
    fill: "#F4ECF7"
    stroke: "#8E44AD"
    border-radius: 8
    font-size: 16
    bold: true
  }
  direction: right
  master_table: {
    label: "sqlite_master\n(page 1 — always)"
    class: component
    style.fill: "#E8DAEF"
    schema: "type | name | tbl_name\nrootpage | sql"
    bootstrap: "Self-describing:\nschema stored as\nregular B-tree rows"
  }
  schema_cache: {
    label: "In-Memory Schema"
    class: component
    style.fill: "#E8DAEF"
    tables: "TableSchema[]\nname, root_page,\ncolumn_names, types,\nconstraints"
    indexes: "IndexSchema[]\nname, table, column,\nroot_page, is_unique"
  }
  master_table -> schema_cache: "loaded on\ndb_open()"
}
# ============================================================
# LAYER 7: BUFFER POOL
# ============================================================
buffer_pool: Buffer Pool Manager {
  label: "Buffer Pool (pager.c)\n[Milestone 4]"
  style: {
    fill: "#FDF2E9"
    stroke: "#E67E22"
    border-radius: 10
    font-size: 18
    bold: true
  }
  direction: right
  frame_array: {
    label: "Frame Array"
    class: component
    style.fill: "#FAE5CD"
    frames: "Frame[pool_size]\npage_id | data[4096]\nis_dirty | pin_count"
    data_block: "Contiguous aligned_alloc\nblock for all page data"
  }
  page_table: {
    label: "Page Table (Hash Map)"
    class: component
    style.fill: "#FAE5CD"
    hash: "page_id % prime → slot"
    probing: "Open addressing\nlinear probing"
    lookup: "O(1) average:\npage_id → frame_idx"
  }
  lru: {
    label: "LRU Eviction"
    class: component
    style.fill: "#FAE5CD"
    doubly_linked: "Doubly-linked list\nthrough frame array"
    head: "Head = most recently used"
    tail: "Tail = least recently used\n→ evict from here"
    invariant: "pin_count > 0 →\nNEVER evict"
  }
  api: {
    label: "Public API"
    class: component
    style.fill: "#FAE5CD"
    fetch: "fetch_page(page_id)\n→ uint8_t* (pinned)"
    unpin: "unpin_page(page_id, dirty)"
    flush: "flush_page() / flush_all()"
    new_page: "new_page() → page_id"
    stats: "hit_rate = hits/(hits+misses)"
  }
}
# ============================================================
# LAYER 8: TRANSACTION LAYER
# ============================================================
txn_layer: Transaction Layer (ACID) {
  style: {
    fill: "#FBEEE6"
    stroke: "#DC7633"
    border-radius: 10
    font-size: 18
    bold: true
  }
  direction: right
  rollback_journal: {
    label: "Rollback Journal\n[Milestone 9]"
    class: subsystem
    style.fill: "#F6DDCC"
    strategy: "UNDO log:\nstores old page data"
    protocol: "journal write →\njournal fsync →\ndb write →\ndb fsync →\njournal delete"
    commit_point: "unlink(.db-journal)\n= commit point"
    recovery: "Hot journal on open →\nrestore original pages"
    state_machine: "TXN_NONE →\nTXN_ACTIVE →\nTXN_DIRTY"
  }
  wal: {
    label: "Write-Ahead Log\n[Milestone 10]"
    class: subsystem
    style.fill: "#F6DDCC"
    strategy: "REDO log:\nstores new page data"
    append_only: "Sequential append\nto .db-wal file"
    commit_marker: "db_size > 0 in\nlast frame = commit"
    snapshot: "Readers get max_frame\nat BEGIN time\n→ snapshot isolation"
    checkpoint: "Copy WAL frames →\ndatabase file\nfsync → reset WAL"
    concurrent: "Readers NEVER\nblock writers"
  }
  wal_index: {
    label: "WAL Index"
    class: component
    style.fill: "#F6DDCC"
    mapping: "page_id → latest\nframe_number"
    snapshot_mgr: "ReaderSnapshot[]\nmax_frame per reader"
    min_reader: "min(reader.max_frame)\n= checkpoint boundary"
  }
  wal -> wal_index: "lookup"
}
# ============================================================
# LAYER 9: DISK I/O
# ============================================================
disk_io: OS / Disk I/O {
  style: {
    fill: "#F2F3F4"
    stroke: "#566573"
    border-radius: 10
    font-size: 18
    bold: true
  }
  direction: right
  syscalls: {
    label: "System Calls"
    class: component
    style.fill: "#D5D8DC"
    pread: "pread(fd, buf, 4096, offset)\nread page at offset"
    pwrite: "pwrite(fd, buf, 4096, offset)\nwrite page at offset"
    fsync_call: "fsync(fd)\nbarrier: all writes durable\nbefore this returns"
    fdatasync: "fdatasync(fd)\nskip metadata flush"
  }
  files: {
    label: "Database Files"
    class: component
    style.fill: "#D5D8DC"
    db_file: "database.db\n4096-byte pages\npage 0 = file header\npage 1 = sqlite_master"
    journal_file: "database.db-journal\nheader + page records\n(temporary, deleted\non commit)"
    wal_file: "database.db-wal\nheader + frames\n(append-only)"
    shm_file: "database.db-shm\nmmap'd WAL index\n(shared memory)"
  }
}
# ============================================================
# PHYSICAL STORAGE
# ============================================================
storage_hw: Persistent Storage {
  shape: cylinder
  style: {
    fill: "#ABB2B9"
    stroke: "#2C3E50"
    font-size: 16
    bold: true
    font-color: "#FFFFFF"
  }
  label: "SSD / HDD\nSequential: ~50μs (SSD)\nRandom: ~100μs (SSD)\nfsync: ~1ms"
}
# ============================================================
# DML OPERATIONS (cross-cutting)
# ============================================================
dml: DML Operations {
  label: "DML Execution\n[Milestone 6]"
  style: {
    fill: "#E8F6F3"
    stroke: "#1ABC9C"
    border-radius: 8
    font-size: 14
  }
  direction: right
  select_exec: {
    label: "SELECT"
    style.fill: "#D0ECE7"
    details: "Projection + WHERE\nThree-valued logic\n(TRUE/FALSE/NULL)"
  }
  insert_exec: {
    label: "INSERT"
    style.fill: "#D0ECE7"
    details: "Auto-increment rowid\nNOT NULL check\nIndex maintenance"
  }
  update_exec: {
    label: "UPDATE"
    style.fill: "#D0ECE7"
    details: "Two-pass:\n1) collect rowids\n2) delete + reinsert\nAvoids iterator\ninvalidation"
  }
  delete_exec: {
    label: "DELETE"
    style.fill: "#D0ECE7"
    details: "Two-pass:\n1) collect rowids\n2) seek + delete\nMark fragmented bytes"
  }
}
# ============================================================
# CONNECTIONS — DATA FLOW (top to bottom)
# ============================================================
sql_input -> frontend: "const char* sql" {
  class: data-flow
}
frontend.compiler -> planner: "AST for\ncost analysis" {
  class: data-flow
}
planner -> frontend.compiler: "AccessPlan\n(index or scan)" {
  class: data-flow
  style.stroke-dash: 4
}
frontend.compiler -> vdbe.program: "Program*\n(VdbeOp[])" {
  class: data-flow
}
vdbe.vm_core -> cursor_iface: "cursor opcodes" {
  class: hot-path
}
vdbe.vm_core -> dml: "DML opcodes" {
  class: hot-path
}
cursor_iface.table_cursor -> storage.table_btree: "B-tree traversal" {
  class: hot-path
}
cursor_iface.index_cursor -> storage.index_bplustree: "B+tree seek" {
  class: hot-path
}
cursor_iface.index_cursor -> storage.table_btree: "double lookup\n(rowid → row)" {
  style.stroke-dash: 4
  style.stroke: "#8E44AD"
}
dml -> storage: "insert / delete\n/ seek" {
  class: write-path
}
dml -> storage.index_bplustree: "index\nmaintenance" {
  class: write-path
}
storage -> catalog: "schema lookup" {
  style.stroke: "#8E44AD"
  style.stroke-dash: 3
}
storage -> buffer_pool.api: "fetch_page()\nunpin_page()" {
  class: hot-path
}
buffer_pool -> txn_layer: "journal before\ndirty page write" {
  class: write-path
}
txn_layer.rollback_journal -> disk_io.files.journal_file: "original pages" {
  class: write-path
}
txn_layer.wal -> disk_io.files.wal_file: "new page frames" {
  class: write-path
}
buffer_pool -> disk_io.syscalls: "pread / pwrite" {
  class: hot-path
}
disk_io.syscalls -> disk_io.files: "file I/O"
disk_io -> storage_hw: "block I/O" {
  style.stroke-width: 3
  style.stroke: "#2C3E50"
}
# ============================================================
# LEGEND
# ============================================================
legend: Legend {
  near: bottom-right
  style: {
    fill: "#FDFEFE"
    stroke: "#95A5A6"
    border-radius: 6
    font-size: 13
  }
  r: "Red solid — hot read path" {
    style.font-color: "#E74C3C"
  }
  b: "Blue solid — data flow" {
    style.font-color: "#3498DB"
  }
  g: "Green dashed — write path" {
    style.font-color: "#27AE60"
  }
  p: "Purple dashed — cross-reference" {
    style.font-color: "#8E44AD"
  }
  m: "Each box labeled with [Milestone N]" {
    style.font-color: "#566573"
  }
}