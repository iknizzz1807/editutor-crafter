direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
bytecode: {
  shape: sql_table
  label: "Compiled Bytecode Program — SELECT name FROM users WHERE age > 25"
  i0:  "addr 0  | Init      | p1=0  | p2=1  | p3=0 | jump to OpenRead"
  i1:  "addr 1  | OpenRead  | cur=0 | root=5| cols=3 | open users (root page 5, 3 cols)"
  i2:  "addr 2  | Rewind    | cur=0 | p2=10 | 0    | first leaf; jump Close if empty"
  i3:  "addr 3  | Column    | cur=0 | col=1 | R1   | age (col 1) → register R1"
  i4:  "addr 4  | Integer   | 25    | R2    | 0    | constant 25 → register R2"
  i5:  "addr 5  | IsNull    | R1    | p2=9  | 0    | if age IS NULL jump OP_NEXT"
  i6:  "addr 6  | Le        | R1    | p2=9  | R2   | if R1<=R2 jump addr 9 (skip row)"
  i7:  "addr 7  | Column    | cur=0 | col=0 | R3   | name (col 0) → register R3"
  i8:  "addr 8  | ResultRow | R3    | cnt=1 | 0    | emit R3 via callback"
  i9:  "addr 9  | Next      | cur=0 | p2=3  | 0    | advance cursor; loop to addr 3"
  i10: "addr 10 | Close     | cur=0 | 0     | 0    | close cursor"
  i11: "addr 11 | Halt      | 0     | 0     | 0    | done"
}
vm_init_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vm_init: {
    label: "VM Init Phase (addr 0 – 2)"
    code: |'c
      // OP_OPEN_READ: open B-tree cursor on root page 5
      cursor = btree_cursor_open(pool, root_page=5);
      // OP_REWIND: descend to leftmost leaf page
      empty = btree_cursor_rewind(cursor);
      // → cursor.page_id=5, cursor.cell_index=0
    '|
    width: 380
  }
  reg_file: {
    shape: sql_table
    label: "Register File (after addr 0-4 execute)"
    reg0: "R0 | scratch | (reserved)"
    reg1: "R1 | VAL_NULL | age slot  (filled per row)"
    reg2: "R2 | VAL_INTEGER = 25 | constant loaded once"
    reg3: "R3 | VAL_NULL | name slot (filled per row)"
  }
  vm_init -> reg_file: "PC → addr 3"
}
rows: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  row1: "Row 1  (rowid = 1)" {
    direction: down
    cell1: {
      shape: sql_table
      label: "B-tree Leaf Cell  (page 5, slot 0)"
      f_ps:  "payload_size | varint | 18 bytes total"
      f_rid: "rowid        | varint | 1"
      f_hdr: "header_size  | varint | 3 (3-byte header)"
      f_t0:  "serial_type[0] | varint=23 | TEXT len=5 bytes"
      f_t1:  "serial_type[1] | varint=1  | INT  1 byte"
      f_v0:  "value[0] | 5 bytes | Alice"
      f_v1:  "value[1] | 1 byte  | 0x1E = 30"
    }
    deser1: {
      label: "OP_COLUMN  cursor=0  col=1  →  R1"
      code: |'c
        record_read_column(page + cell_offset, col=1, &R1);
        // header[1] = serial_type=1 → INT 1 byte
        // value offset = skip TEXT(5 bytes) first
        // R1 = { VAL_INTEGER, i = 30 }
      '|
      width: 360
    }
    pred1: {
      label: "OP_LE  R1=30  <=  R2=25?"
      code: |'c
        result = tri_compare(R1=30, R2=25, OP_LE);
        // 30 <= 25  →  TRI_FALSE  →  no jump taken
        // age 30 > 25  ✓  PASSES the WHERE filter
      '|
      width: 360
      style.fill: "#d4f5d4"
      style.stroke: "#2d862d"
    }
    proj1: {
      label: "OP_COLUMN  cursor=0  col=0  →  R3"
      code: |'c
        record_read_column(page + cell_offset, col=0, &R3);
        // header[0] = serial_type=23 → TEXT 5 bytes
        // R3 = { VAL_STRING, s="Alice", len=5 }
      '|
      width: 360
    }
    emit1: {
      label: "OP_RESULT_ROW  R3  count=1  →  callback"
      code: |'c
        callback(&registers[R3], ncols=1, ctx);
        // output row: [ "Alice" ]
      '|
      width: 360
      style.fill: "#d4f5d4"
      style.stroke: "#2d862d"
    }
    cell1 -> deser1: "fetch_page(pool, 5)"
    deser1 -> pred1: "R1 = 30"
    pred1 -> proj1: "PASS"
    proj1 -> emit1: "R3 = Alice"
  }
  row2: "Row 2  (rowid = 2)" {
    direction: down
    cell2: {
      shape: sql_table
      label: "B-tree Leaf Cell  (page 5, slot 1)"
      f_ps:  "payload_size | varint | 16 bytes total"
      f_rid: "rowid        | varint | 2"
      f_hdr: "header_size  | varint | 3 (3-byte header)"
      f_t0:  "serial_type[0] | varint=19 | TEXT len=3 bytes"
      f_t1:  "serial_type[1] | varint=1  | INT  1 byte"
      f_v0:  "value[0] | 3 bytes | Bob"
      f_v1:  "value[1] | 1 byte  | 0x16 = 22"
    }
    deser2: {
      label: "OP_COLUMN  cursor=0  col=1  →  R1"
      code: |'c
        record_read_column(page + cell_offset, col=1, &R1);
        // buffer pool HIT (page 5 still pinned)
        // R1 = { VAL_INTEGER, i = 22 }
      '|
      width: 360
    }
    pred2: {
      label: "OP_LE  R1=22  <=  R2=25?"
      code: |'c
        result = tri_compare(R1=22, R2=25, OP_LE);
        // 22 <= 25  →  TRI_TRUE  →  jump to addr 9
        // age 22 NOT > 25  ✗  FAILS the WHERE filter
      '|
      width: 360
      style.fill: "#fde8e8"
      style.stroke: "#cc3333"
    }
    skip2: {
      label: "Jump to OP_NEXT  (addr 9)  —  row skipped"
      code: |'c
        // name column NOT loaded (OP_COLUMN col=0 skipped)
        // OP_RESULT_ROW NOT executed
        // PC = 9  →  advance cursor immediately
      '|
      width: 360
      style.fill: "#fde8e8"
      style.stroke: "#cc3333"
    }
    cell2 -> deser2: "buffer pool hit"
    deser2 -> pred2: "R1 = 22"
    pred2 -> skip2: "FAIL" {
      style.stroke: red
      style.stroke-dash: 4
    }
  }
  row3: "Row 3  (rowid = 3)" {
    direction: down
    cell3: {
      shape: sql_table
      label: "B-tree Leaf Cell  (page 5, slot 2)"
      f_ps:  "payload_size | varint | 18 bytes total"
      f_rid: "rowid        | varint | 3"
      f_hdr: "header_size  | varint | 3 (3-byte header)"
      f_t0:  "serial_type[0] | varint=23 | TEXT len=5 bytes"
      f_t1:  "serial_type[1] | varint=1  | INT  1 byte"
      f_v0:  "value[0] | 5 bytes | Carol"
      f_v1:  "value[1] | 1 byte  | 0x1C = 28"
    }
    deser3: {
      label: "OP_COLUMN  cursor=0  col=1  →  R1"
      code: |'c
        record_read_column(page + cell_offset, col=1, &R1);
        // buffer pool HIT (page 5 still pinned)
        // R1 = { VAL_INTEGER, i = 28 }
      '|
      width: 360
    }
    pred3: {
      label: "OP_LE  R1=28  <=  R2=25?"
      code: |'c
        result = tri_compare(R1=28, R2=25, OP_LE);
        // 28 <= 25  →  TRI_FALSE  →  no jump taken
        // age 28 > 25  ✓  PASSES the WHERE filter
      '|
      width: 360
      style.fill: "#d4f5d4"
      style.stroke: "#2d862d"
    }
    proj3: {
      label: "OP_COLUMN  cursor=0  col=0  →  R3"
      code: |'c
        record_read_column(page + cell_offset, col=0, &R3);
        // header[0] = serial_type=23 → TEXT 5 bytes
        // R3 = { VAL_STRING, s="Carol", len=5 }
      '|
      width: 360
    }
    emit3: {
      label: "OP_RESULT_ROW  R3  count=1  →  callback"
      code: |'c
        callback(&registers[R3], ncols=1, ctx);
        // output row: [ "Carol" ]
      '|
      width: 360
      style.fill: "#d4f5d4"
      style.stroke: "#2d862d"
    }
    cell3 -> deser3: "buffer pool hit"
    deser3 -> pred3: "R1 = 28"
    pred3 -> proj3: "PASS"
    proj3 -> emit3: "R3 = Carol"
  }
}
footer_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  op_next_box: {
    label: "OP_NEXT  (addr 9)  —  Loop Control"
    code: |'c
      has_more = btree_cursor_next(cursor);
      // increments cell_index within leaf page
      // if cell_index >= cell_count: ascend + descend next leaf
      if (has_more) pc = 3;  // loop back to OP_COLUMN
      else          pc++;    // fall through to OP_CLOSE
    '|
    width: 400
  }
  result_stream: {
    shape: sql_table
    label: "Result Stream  (user callback receives these rows)"
    hdr:  "seq | name  | age | predicate result"
    out1: "1   | Alice | 30  | 30 > 25  PASS  emitted"
    out2: "2   | Carol | 28  | 28 > 25  PASS  emitted"
    excl: "—   | Bob   | 22  | 22 > 25  FAIL  skipped at OP_LE"
  }
  op_next_box -> result_stream: "2 rows emitted"
}
legend: {
  shape: sql_table
  label: "Color Legend"
  pass_color: "GREEN fill  | PASS  | predicate TRI_FALSE  →  row reaches ResultRow"
  fail_color: "RED fill    | FAIL  | predicate TRI_TRUE   →  jump to OP_NEXT"
  dashed_arr: "Dashed red arrow | short-circuit | OP_LE jump bypasses Column + ResultRow"
}
legend.near: bottom-right
bytecode -> vm_init_row: "execute_sql() pipeline"
vm_init_row -> rows: "cursor at leaf page 5, cell_index=0"
rows -> footer_row: "OP_NEXT after each row"
rows.row1.emit1 -> footer_row.result_stream: "Alice" {
  style.stroke: "#2d862d"
}
rows.row3.emit3 -> footer_row.result_stream: "Carol" {
  style.stroke: "#2d862d"
}
rows.row2.skip2 -> footer_row.op_next_box: "jump addr 9" {
  style.stroke: "#cc3333"
  style.stroke-dash: 4
}