direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row_title: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  title_box: "Selectivity Estimation with Statistics (query_planner.c)" {
    style.font-size: 18
    style.bold: true
    style.fill: "#E8F4F8"
    style.stroke: "#2980B9"
    style.border-radius: 6
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  analyze_phase: "ANALYZE Phase (analyze.c)" {
    direction: down
    style.fill: "#EAF4E8"
    style.stroke: "#27AE60"
    style.border-radius: 6
    scan_table: "Full Table Scan" {
      style.fill: "#D5EFD0"
      style.border-radius: 4
    }
    stats_collected: {
      shape: sql_table
      label: "Statistics Collected"
      r1: "table_name  | TEXT    | 'users'"
      r2: "row_count   | INTEGER | 10,000"
      r3: "page_count  | INTEGER | 143"
      r4: "col_name    | TEXT    | 'status'"
      r5: "distinct_ct | INTEGER | 100  (NDV)"
      r6: "null_count  | INTEGER | 0"
      r7: "min_value   | TEXT    | 'active'"
      r8: "max_value   | TEXT    | 'suspended'"
    }
    scan_table -> stats_collected: "pread pages"
  }
  planner_input: "Query Planner Input (query_planner.c)" {
    direction: down
    style.fill: "#EEF2FB"
    style.stroke: "#2C3E84"
    style.border-radius: 6
    query_ast: {
      shape: sql_table
      label: "Parsed WHERE Clause"
      q1: "op    | =       | equality"
      q2: "left  | status  | column ref"
      q3: "right | active  | string literal"
    }
    index_avail: {
      shape: sql_table
      label: "Available Index"
      i1: "index_name | idx_status"
      i2: "table      | users"
      i3: "column     | status"
      i4: "root_page  | 17"
      i5: "is_unique  | false"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  selectivity_engine: "Selectivity Estimation Engine" {
    direction: down
    style.fill: "#FEF9E7"
    style.stroke: "#F39C12"
    style.border-radius: 6
    formula_node: "Equality Selectivity Formula" {
      style.fill: "#FDF2CA"
      style.border-radius: 4
      formula: |md
        **selectivity = 1 / NDV**
        selectivity = 1 / 100 = **0.01  (1%)**
      |
    }
    estimation_result: {
      shape: sql_table
      label: "Estimation Result"
      e1: "predicate      | status = 'active'"
      e2: "selectivity    | 0.01  (1.0%)"
      e3: "estimated_rows | 10000 × 0.01 = 100"
      e4: "index_usable   | true"
      e5: "sel_cap_check  | 0.01 < 0.20 → eligible"
    }
  }
  cost_model: "I/O Cost Model (cost_model.c)" {
    direction: down
    style.fill: "#FDEDEC"
    style.stroke: "#C0392B"
    style.border-radius: 6
    constants: {
      shape: sql_table
      label: "Cost Constants"
      c1: "RANDOM_IO_FACTOR | 4.0× sequential"
      c2: "index_height     | 2 pages  (log340(100))"
      c3: "idx_leaf_pages   | 1 page   (100/200)"
      c4: "table_page_count | 143 pages"
    }
    formula_idx: "Index Scan Cost" {
      style.fill: "#FADBD8"
      style.border-radius: 4
      code: |'c
        // index_height + idx_leaf_pages
        //   + est_rows × RANDOM_IO_FACTOR
        cost_idx = 2 + 1
                 + 100 × 4.0
        cost_idx = 403 pages
      '|
      width: 340
    }
    formula_scan: "Table Scan Cost" {
      style.fill: "#FADBD8"
      style.border-radius: 4
      code: |'c
        // read every leaf page sequentially
        cost_scan = page_count
        cost_scan = 143 pages
      '|
      width: 340
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  decision_box: "Plan Decision (query_planner.c)" {
    direction: right
    style.fill: "#EBF5FB"
    style.stroke: "#1A5276"
    style.border-radius: 6
    winner: "Cost Comparison Result" {
      style.fill: "#FDEBD0"
      style.stroke: "#CA6F1E"
      style.border-radius: 8
      style.bold: true
      detail: |md
        **cost_idx (403) vs cost_scan (143)**
        403 > 143 → **TABLE SCAN wins** at 1% sel
        *Re-scenario with 1000 NDV:*
        sel = 1/1000 = 0.1%,  est_rows = 10
        cost_idx = 2+1+(10×4) = **43**
        43 < 143 → **INDEX SCAN wins**
      |
    }
    plan_output: {
      shape: sql_table
      label: "AccessPlan Output (NDV=100)"
      p1: "uses_index     | false"
      p2: "index_name     | —"
      p3: "selectivity    | 0.01"
      p4: "estimated_rows | 100"
      p5: "cost           | 143.0 (scan)"
      p6: "sel eligible   | yes (0.01 < 0.20)"
      p7: "cost decision  | idx(403) > scan(143)"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  explain_out: "EXPLAIN Output (explain.c)" {
    direction: down
    style.fill: "#F4ECF7"
    style.stroke: "#6C3483"
    style.border-radius: 6
    explain_scan: "NDV=100 → Table Scan chosen" {
      style.fill: "#EAD9F5"
      style.border-radius: 4
      code: |'c
        QUERY PLAN
          SCAN TABLE users
          (est_rows=100, sel=0.0100, cost=143.0)
        addr  opcode    p1  p2  comment
        0     Init       0   1  Start
        1     OpenRead   0   5  open: users
        2     Rewind     0   9  reset cursor
        3     Column     0   2  r1 ← status
        4     String8    0   2  r2 ← 'active'
        5     Ne         1   8  skip if ≠
        6     ResultRow  ...
        7     Next       0   3  loop
        8     Halt
      '|
      width: 480
    }
    explain_idx: "NDV=1000 → Index Scan chosen" {
      style.fill: "#D7BDE2"
      style.border-radius: 4
      code: |'c
        QUERY PLAN
          SEARCH users USING INDEX idx_status
          (est_rows=10, sel=0.0010, cost=43.0)
        addr  opcode         p1  p2  comment
        0     Init            0   1  Start
        1     OpenRead        0   5  open: users
        2     OpenIndexRead   1  17  open: idx_status
        3     String8         0   1  r1 ← 'active'
        4     IdxSeek         1  14  seek to key
        5     IdxKey          1   2  read idx val
        6     Ne              2  12  skip if ≠
        7     IdxRowid        1   4  rowid → r4
        8     SeekRowid       0   4  fetch table row
        9     Column          0   0  output col
        10    ResultRow       5   1  emit row
        11    IdxNext         1   5  advance idx
        12    Halt
      '|
      width: 480
    }
  }
  crossover_legend: "Selectivity Crossover Analysis" {
    direction: down
    style.fill: "#FDFEFE"
    style.stroke: "#717D7E"
    style.border-radius: 6
    crossover_formula: "When Does Index Win?" {
      style.fill: "#F2F3F4"
      style.border-radius: 4
      code: |'c
        // Index cheaper when:
        // est_rows × RANDOM_IO_FACTOR < page_count
        // sel × rows × 4.0 < 143
        // sel < 143 / (10000 × 4.0)
        // sel < 0.0036  →  0.36%
        //
        // NDV threshold:
        // 1/NDV < 0.0036
        // NDV  > 278
        //
        // NDV=100  (1%)    → SCAN wins
        // NDV=278  (0.36%) → break-even
        // NDV=1000 (0.1%)  → INDEX wins
      '|
      width: 360
    }
    sel_table: {
      shape: sql_table
      label: "NDV → Cost → Decision"
      s1: "NDV=10    | sel=10%   | cost_idx=4043 | SCAN"
      s2: "NDV=100   | sel=1%    | cost_idx=403  | SCAN"
      s3: "NDV=278   | sel=0.36% | cost_idx=143  | TIE"
      s4: "NDV=1000  | sel=0.1%  | cost_idx=43   | INDEX"
      s5: "NDV=10000 | sel=0.01% | cost_idx=4    | INDEX"
    }
  }
}
row1.analyze_phase -> row2.selectivity_engine: "row_count=10000, NDV=100"
row1.planner_input -> row2.selectivity_engine: "WHERE status = 'active'"
row1.planner_input -> row2.cost_model: "index metadata"
row2.selectivity_engine -> row2.cost_model: "sel=0.01, est_rows=100"
row2.selectivity_engine -> row3.decision_box: "selectivity result"
row2.cost_model -> row3.decision_box: "cost_idx=403, cost_scan=143"
row3.decision_box -> row4.explain_out: "selected plan"
row3.decision_box -> row4.crossover_legend: "threshold analysis"