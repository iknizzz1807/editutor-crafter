direction: down
title: "Slotted Page — Bidirectional Growth" {
  shape: text
  near: top-center
  style.font-size: 22
  style.bold: true
}
states: {
  direction: right
  s0: {
    label: "State 0 — Empty Page"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.stroke-width: 2
    style.border-radius: 6
    page0: {
      direction: down
      header0: {
        label: "PAGE HEADER\nbyte 0–11  (12 bytes)\ntype | freeblock | cell_count=0\ncontent_area=4096 | frag=0"
        style.fill: "#4a6fa5"
        style.stroke: "#2c4a7a"
        style.font-color: "#ffffff"
        style.font-size: 11
        style.bold: true
        width: 200
        height: 72
      }
      free0: {
        label: "FREE SPACE\n\n4084 bytes available\n\n(byte 12 → 4095)"
        style.fill: "#e8f5e9"
        style.stroke: "#81c784"
        style.stroke-dash: 4
        style.font-size: 11
        style.font-color: "#388e3c"
        width: 200
        height: 260
      }
      footer0: {
        label: "── page end · byte 4095 ──"
        style.fill: "#dee2e6"
        style.stroke: "#adb5bd"
        style.font-size: 10
        style.font-color: "#6c757d"
        width: 200
        height: 24
      }
      header0 -> free0: {
        label: "ptr_array\ngrows ↓"
        style.stroke: "#1565c0"
        style.font-size: 10
        style.bold: true
        style.stroke-width: 2
      }
      free0 -> footer0: {
        label: "content\ngrows ↑"
        style.stroke: "#e53935"
        style.font-size: 10
        style.bold: true
        style.stroke-width: 2
      }
    }
  }
  s1: {
    label: "State 1 — 1 Cell Inserted"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.stroke-width: 2
    style.border-radius: 6
    page1: {
      direction: down
      header1: {
        label: "PAGE HEADER  (12 bytes)\ncell_count=1\ncontent_area=4052"
        style.fill: "#4a6fa5"
        style.stroke: "#2c4a7a"
        style.font-color: "#ffffff"
        style.font-size: 11
        style.bold: true
        width: 200
        height: 60
      }
      ptrs1: {
        label: "CELL POINTER ARRAY\n┌──────────┐\n│ ptr[0]=4052 │  2 bytes\n└──────────┘\nbyte 12–13"
        style.fill: "#bbdefb"
        style.stroke: "#1565c0"
        style.font-size: 10
        style.font-color: "#0d47a1"
        style.bold: false
        width: 200
        height: 64
      }
      free1: {
        label: "FREE SPACE\n\n4038 bytes\n(byte 14 → 4051)"
        style.fill: "#e8f5e9"
        style.stroke: "#81c784"
        style.stroke-dash: 4
        style.font-size: 11
        style.font-color: "#388e3c"
        width: 200
        height: 180
      }
      cell1: {
        label: "CELL CONTENT AREA\n┌─────────────────┐\n│ cell[0] · 44 bytes │\n│ key=1 · payload  │\n└─────────────────┘\nbyte 4052–4095"
        style.fill: "#ffe0b2"
        style.stroke: "#e65100"
        style.font-size: 10
        style.font-color: "#bf360c"
        style.bold: false
        width: 200
        height: 80
      }
      header1 -> ptrs1: {
        style.stroke: "#1565c0"
        style.stroke-width: 2
      }
      ptrs1 -> free1: {
        label: "↓ grows"
        style.stroke: "#1565c0"
        style.font-size: 10
        style.bold: true
        style.stroke-dash: 3
      }
      free1 -> cell1: {
        label: "↑ grows"
        style.stroke: "#e53935"
        style.font-size: 10
        style.bold: true
        style.stroke-dash: 3
      }
    }
  }
  s2: {
    label: "State N — Multiple Cells"
    style.fill: "#f8f9fa"
    style.stroke: "#adb5bd"
    style.stroke-width: 2
    style.border-radius: 6
    page2: {
      direction: down
      header2: {
        label: "PAGE HEADER  (12 bytes)\ncell_count=N\ncontent_area=3740"
        style.fill: "#4a6fa5"
        style.stroke: "#2c4a7a"
        style.font-color: "#ffffff"
        style.font-size: 11
        style.bold: true
        width: 200
        height: 60
      }
      ptrs2: {
        label: "CELL POINTER ARRAY\n ptr[0] · ptr[1] · ptr[2]\n ptr[3] · ptr[4] · ptr[5]\n · · · · ptr[N-1]\n2×N bytes · byte 12→(12+2N)"
        style.fill: "#bbdefb"
        style.stroke: "#1565c0"
        style.font-size: 10
        style.font-color: "#0d47a1"
        width: 200
        height: 80
      }
      free2: {
        label: "FREE SPACE\n\n~1800 bytes\n← shrinking from both ends →"
        style.fill: "#e8f5e9"
        style.stroke: "#81c784"
        style.stroke-dash: 4
        style.font-size: 11
        style.font-color: "#388e3c"
        width: 200
        height: 120
      }
      cells2: {
        label: "CELL CONTENT AREA\n┌────────────────┐\n│ cell[N-1]       │\n│ · · ·           │\n│ cell[1]         │\n│ cell[0] · byte 3740→4095 │\n└────────────────┘"
        style.fill: "#ffe0b2"
        style.stroke: "#e65100"
        style.font-size: 10
        style.font-color: "#bf360c"
        width: 200
        height: 120
      }
      header2 -> ptrs2: {
        style.stroke: "#1565c0"
        style.stroke-width: 2
      }
      ptrs2 -> free2: {
        label: "↓ growing"
        style.stroke: "#1565c0"
        style.font-size: 10
        style.bold: true
        style.stroke-dash: 3
      }
      free2 -> cells2: {
        label: "↑ growing"
        style.stroke: "#e53935"
        style.font-size: 10
        style.bold: true
        style.stroke-dash: 3
      }
    }
  }
  s3: {
    label: "State FULL — Split Required ⚠"
    style.fill: "#fff3e0"
    style.stroke: "#e53935"
    style.stroke-width: 3
    style.border-radius: 6
    page3: {
      direction: down
      header3: {
        label: "PAGE HEADER  (12 bytes)\ncell_count=M\ncontent_area=12+2×M"
        style.fill: "#4a6fa5"
        style.stroke: "#2c4a7a"
        style.font-color: "#ffffff"
        style.font-size: 11
        style.bold: true
        width: 200
        height: 60
      }
      ptrs3: {
        label: "CELL POINTER ARRAY\n ptr[0]…ptr[M-1]\n2×M bytes\nbyte 12 → (12+2M)"
        style.fill: "#bbdefb"
        style.stroke: "#e53935"
        style.stroke-width: 2
        style.font-size: 10
        style.font-color: "#0d47a1"
        width: 200
        height: 72
      }
      collision: {
        label: "▲▼ REGIONS MEET ▼▲\nfree_space = 0\ncell_content_area == 12 + 2×M\nNEW INSERT IMPOSSIBLE"
        style.fill: "#ffcdd2"
        style.stroke: "#b71c1c"
        style.stroke-width: 3
        style.font-size: 11
        style.font-color: "#b71c1c"
        style.bold: true
        width: 200
        height: 56
      }
      cells3: {
        label: "CELL CONTENT AREA\n cell[M-1]\n · · ·\n cell[0]\nbyte (12+2M) → 4095"
        style.fill: "#ffe0b2"
        style.stroke: "#e65100"
        style.stroke-width: 2
        style.font-size: 10
        style.font-color: "#bf360c"
        width: 200
        height: 120
      }
      split_note: {
        label: "→ TRIGGER PAGE SPLIT\nAllocate sibling page\nMigrate ⌈M/2⌉ cells right\nPromote median key to parent"
        style.fill: "#b71c1c"
        style.stroke: "#7f0000"
        style.font-color: "#ffffff"
        style.font-size: 11
        style.bold: true
        style.border-radius: 4
        width: 200
        height: 68
      }
      header3 -> ptrs3: {
        style.stroke: "#1565c0"
        style.stroke-width: 2
      }
      ptrs3 -> collision: {
        label: "↓ ptr end"
        style.stroke: "#e53935"
        style.font-size: 10
        style.bold: true
        style.stroke-width: 2
      }
      collision -> cells3: {
        label: "↑ content start"
        style.stroke: "#e53935"
        style.font-size: 10
        style.bold: true
        style.stroke-width: 2
      }
      cells3 -> split_note: {
        label: "overflow"
        style.stroke: "#b71c1c"
        style.stroke-width: 3
        style.bold: true
        style.font-size: 11
      }
    }
  }
}
legend: {
  label: "Legend"
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  style.border-radius: 4
  style.font-size: 11
  lh: {
    label: "■ Header (blue) — fixed 12 bytes"
    style.fill: "#4a6fa5"
    style.font-color: "#ffffff"
    style.font-size: 10
    width: 260
    height: 28
  }
  lp: {
    label: "■ Pointer Array (light blue) — 2 bytes × cell_count, grows ↓"
    style.fill: "#bbdefb"
    style.font-color: "#0d47a1"
    style.font-size: 10
    width: 260
    height: 28
  }
  lf: {
    label: "■ Free Space (green dashed) — shrinks as both regions grow"
    style.fill: "#e8f5e9"
    style.stroke: "#81c784"
    style.stroke-dash: 3
    style.font-color: "#388e3c"
    style.font-size: 10
    width: 260
    height: 28
  }
  lc: {
    label: "■ Cell Content (orange) — packed from page tail, grows ↑"
    style.fill: "#ffe0b2"
    style.font-color: "#bf360c"
    style.font-size: 10
    width: 260
    height: 28
  }
  ls: {
    label: "■ Collision / Split (red) — free=0, split triggered"
    style.fill: "#ffcdd2"
    style.stroke: "#b71c1c"
    style.font-color: "#b71c1c"
    style.font-size: 10
    width: 260
    height: 28
  }
  lh -> lp -> lf -> lc -> ls: {style.opacity: 0}
}
formula: {
  label: "free_space = cell_content_area_offset − (PAGE_HEADER_SIZE + cell_count × 2)\nPAGE_SIZE = 4096  ·  PAGE_HEADER_SIZE = 12  ·  ptr_entry = 2 bytes\ninsert requires: free_space ≥ cell_byte_length + 2"
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.font-size: 11
  style.font-color: "#0d47a1"
  style.border-radius: 4
  near: bottom-center
  width: 520
  height: 60
}
states.s0 -> states.s1: {
  label: "insert(key=1)\ncell_len=44 bytes\nfree: 4084→4038"
  style.stroke: "#4a6fa5"
  style.stroke-width: 2
  style.font-size: 10
  style.bold: false
}
states.s1 -> states.s2: {
  label: "insert(key=2…N)\neach: −(len+2) free\nptr_end moves ↓\ncontent moves ↑"
  style.stroke: "#4a6fa5"
  style.stroke-width: 2
  style.font-size: 10
}
states.s2 -> states.s3: {
  label: "insert(key=N+1)\nfree < cell_len+2\nOVERFLOW ⚠"
  style.stroke: "#e53935"
  style.stroke-width: 3
  style.font-size: 10
  style.bold: true
}