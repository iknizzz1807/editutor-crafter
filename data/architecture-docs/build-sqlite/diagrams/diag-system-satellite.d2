direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
# Title
title: |md
  # SQLite Architecture Overview
  Complete System: SQL Compiler + Storage Virtual Machine
| {near: top-center}
# Main flow - SQL compilation layer
sql_input: SQL Query {
  shape: parallelogram
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
tokenizer: Tokenizer {
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
}
parser: Parser {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
ast: "AST (Abstract\nSyntax Tree)" {
  shape: document
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
bytecode_compiler: "Bytecode\nCompiler" {
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 2
}
vdbe: VDBE {
  shape: rectangle
  style.fill: "#FFECB3"
  style.stroke: "#FF8F00"
  style.stroke-width: 3
}
# Storage layer
storage_engine: "Storage Engine" {
  style.fill: "#ECEFF1"
  style.stroke: "#546E7A"
  style.stroke-width: 2
  buffer_pool: "Buffer Pool" {
    style.fill: "#B2EBF2"
    style.stroke: "#00ACC1"
    style.stroke-width: 1
    lru_eviction: "LRU\nEviction"
    pin_counting: "Pin\nCounting"
    dirty_pages: "Dirty Page\nTracking"
  }
  btree: "B-tree\nStorage" {
    style.fill: "#C8E6C9"
    style.stroke: "#43A047"
    style.stroke-width: 1
    table_btree: "Table\nB-tree"
    index_bplustree: "Index\nB+tree"
    page_format: "Page\nFormat"
  }
}
disk: Disk {
  shape: cylinder
  style.fill: "#D7CCC8"
  style.stroke: "#795548"
  style.stroke-width: 2
}
# WAL component
wal: WAL {
  shape: rectangle
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
  style.stroke-width: 2
}
journal: "Rollback\nJournal" {
  shape: rectangle
  style.fill: "#FCE4EC"
  style.stroke: "#EC407A"
  style.stroke-width: 1
}
# Connections - Main flow
sql_input -> tokenizer: "Raw SQL"
tokenizer -> parser: "Tokens"
parser -> ast: "Parsed Tree"
ast -> bytecode_compiler: "AST"
bytecode_compiler -> vdbe: "Bytecode\nProgram"
# VDBE to Storage connections
vdbe -> storage_engine: "Cursor Ops"
storage_engine -> disk: "Page I/O"
# WAL connections
vdbe -> wal: "Write-Ahead\nLogging"
wal -> disk: "WAL File"
# Journal connection
vdbe -> journal: "Undo Log"
# Side labels for architecture
compiler_label: "SQL Compiler Tier" {
  shape: text
  style.font-size: 16
  style.font-color: "#37474F"
  style.bold: true
}
vm_label: "Storage VM Tier" {
  shape: text
  style.font-size: 16
  style.font-color: "#37474F"
  style.bold: true
}
# Show the two-tier architecture with a container
compiler_tier: "" {
  style.fill: transparent
  style.stroke: transparent
  sql_input
  tokenizer
  parser
  ast
  bytecode_compiler
  vdbe
}
vm_tier: "" {
  style.fill: transparent
  style.stroke: transparent
  storage_engine
  wal
  journal
  disk
}
# Annotation for key interfaces
interface_1: |md
  **SQL → Results**
  1. SQL text parsed
  2. Compiled to bytecode
  3. VDBE executes
  4. Storage accessed
| {
  shape: callout
  near: bottom-left
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 1
}
interface_2: |md
  **ACID Transactions**
  - Rollback Journal (undo)
  - WAL (redo)
  - Buffer pool caching
| {
  shape: callout
  near: bottom-right
  style.fill: "#E8F5E9"
  style.stroke: "#43A047"
  style.stroke-width: 1
}