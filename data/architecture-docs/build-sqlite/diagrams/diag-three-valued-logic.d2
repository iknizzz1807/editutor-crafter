vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: {
  label: "Three-Valued Logic (3VL) in SQL"
  near: top-center
  style: {
    font-size: 22
    bold: true
    fill: "#1e1e2e"
    font-color: "#cdd6f4"
    border-radius: 8
  }
}

legend: {
  near: top-right
  label: |'md
    **Legend**
    ✅ TRUE &nbsp; ❌ FALSE &nbsp; ⚠️ NULL
  '|
  style: {
    fill: "#313244"
    font-color: "#cdd6f4"
    border-radius: 6
    stroke: "#585b70"
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  and_table: {
    label: "AND Truth Table"
    style: {
      fill: "#1e1e2e"
      font-color: "#cdd6f4"
      border-radius: 8
      stroke: "#89b4fa"
      stroke-width: 2
    }
    grid: {
      label: |'md
        | AND | ✅ TRUE | ❌ FALSE | ⚠️ NULL |
        |---|---|---|---|
        | ✅ TRUE | ✅ TRUE | ❌ FALSE | ⚠️ NULL |
        | ❌ FALSE | ❌ FALSE | ❌ FALSE | ❌ FALSE |
        | ⚠️ NULL | ⚠️ NULL | ❌ FALSE | ⚠️ NULL |
      '|
      style: {
        fill: "#181825"
        font-color: "#cdd6f4"
        border-radius: 4
        stroke: "#313244"
      }
    }
  }

  or_table: {
    label: "OR Truth Table"
    style: {
      fill: "#1e1e2e"
      font-color: "#cdd6f4"
      border-radius: 8
      stroke: "#a6e3a1"
      stroke-width: 2
    }
    grid: {
      label: |'md
        | OR | ✅ TRUE | ❌ FALSE | ⚠️ NULL |
        |---|---|---|---|
        | ✅ TRUE | ✅ TRUE | ✅ TRUE | ✅ TRUE |
        | ❌ FALSE | ✅ TRUE | ❌ FALSE | ⚠️ NULL |
        | ⚠️ NULL | ✅ TRUE | ⚠️ NULL | ⚠️ NULL |
      '|
      style: {
        fill: "#181825"
        font-color: "#cdd6f4"
        border-radius: 4
        stroke: "#313244"
      }
    }
  }

  not_table: {
    label: "NOT Truth Table"
    style: {
      fill: "#1e1e2e"
      font-color: "#cdd6f4"
      border-radius: 8
      stroke: "#f38ba8"
      stroke-width: 2
    }
    grid: {
      label: |'md
        | Input | NOT |
        |---|---|
        | ✅ TRUE | ❌ FALSE |
        | ❌ FALSE | ✅ TRUE |
        | ⚠️ NULL | ⚠️ NULL |
      '|
      style: {
        fill: "#181825"
        font-color: "#cdd6f4"
        border-radius: 4
        stroke: "#313244"
      }
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  surprises: {
    label: "⚠️ Surprising Cases"
    style: {
      fill: "#2a1f2e"
      font-color: "#cdd6f4"
      border-radius: 8
      stroke: "#f9e2af"
      stroke-width: 2
    }
    cases: {
      label: |'md
        | Expression | Result | Why surprising? |
        |---|---|---|
        | NULL AND TRUE | ⚠️ NULL | TRUE cannot resolve unknown |
        | NULL AND FALSE | ❌ FALSE | FALSE dominates AND |
        | NULL OR FALSE | ⚠️ NULL | FALSE cannot resolve unknown |
        | NULL OR TRUE | ✅ TRUE | TRUE dominates OR |
        | NULL = NULL | ⚠️ NULL | Not TRUE — use IS NULL |
        | NULL <> NULL | ⚠️ NULL | Not FALSE — use IS NOT NULL |
      '|
      style: {
        fill: "#1e1527"
        font-color: "#cdd6f4"
        border-radius: 4
        stroke: "#45475a"
      }
    }
  }

  where_impact: {
    label: "WHERE Clause Evaluation"
    style: {
      fill: "#1e2a1e"
      font-color: "#cdd6f4"
      border-radius: 8
      stroke: "#a6e3a1"
      stroke-width: 2
    }
    rules: {
      label: |'md
        | Condition Result | Row Included? |
        |---|---|
        | ✅ TRUE | ✅ Yes — row returned |
        | ❌ FALSE | ❌ No — row filtered |
        | ⚠️ NULL | ❌ No — filtered (FALSE-ish) |
      '|
      style: {
        fill: "#141e14"
        font-color: "#cdd6f4"
        border-radius: 4
        stroke: "#313244"
      }
    }
    note: {
      label: |'md
        NULL in WHERE = silent row exclusion.
        Test nullable columns with IS NULL.
      '|
      style: {
        fill: "#1e2a1e"
        font-color: "#a6e3a1"
        border-radius: 4
        stroke: "#a6e3a1"
        italic: true
      }
    }
  }
}

null_eq: {
  label: |'md
    **The Golden Rule**
    `NULL` represents *unknown*, not *absent*.
    Any comparison with NULL yields NULL.
    Only `IS NULL` / `IS NOT NULL` resolve it.
  '|
  style: {
    fill: "#2a1f1f"
    font-color: "#f38ba8"
    border-radius: 8
    stroke: "#f38ba8"
    stroke-width: 2
    bold: true
  }
}
null_eq.near: bottom-right

row1 -> row2: "Logical flow" {
  style.stroke-dash: 5
  style.opacity: 0.3
}