direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Tokenizer Finite State Machine {
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#E8F0FE"
    border-radius: 8
  }
}
# ============================================================
# STATES
# ============================================================
row_start: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  start: START {
    shape: circle
    width: 120
    height: 120
    style: {
      fill: "#4CAF50"
      font-color: white
      bold: true
      font-size: 18
    }
  }
}
row_dispatch: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  in_ident: IN_IDENTIFIER {
    shape: oval
    style: {
      fill: "#2196F3"
      font-color: white
      bold: true
    }
  }
  in_number: IN_NUMBER {
    shape: oval
    style: {
      fill: "#FF9800"
      font-color: white
      bold: true
    }
  }
  in_string: IN_STRING {
    shape: oval
    style: {
      fill: "#9C27B0"
      font-color: white
      bold: true
    }
  }
  in_operator: IN_OPERATOR {
    shape: oval
    style: {
      fill: "#F44336"
      font-color: white
      bold: true
    }
  }
  in_quoted_id: IN_QUOTED_ID {
    shape: oval
    style: {
      fill: "#00BCD4"
      font-color: white
      bold: true
    }
  }
}
row_sub: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  keyword_check: Keyword\nLookup {
    shape: diamond
    style: {
      fill: "#FFF9C4"
      font-size: 14
      bold: true
    }
  }
  in_float: IN_FLOAT {
    shape: oval
    style: {
      fill: "#FF5722"
      font-color: white
      bold: true
    }
  }
  maybe_end_str: MAYBE_END\nSTRING {
    shape: diamond
    style: {
      fill: "#CE93D8"
      font-size: 13
      bold: true
    }
  }
  multi_char: MULTI_CHAR\nOPERATOR {
    shape: diamond
    style: {
      fill: "#EF9A9A"
      font-size: 13
      bold: true
    }
  }
  in_comment: IN_COMMENT {
    shape: oval
    style: {
      fill: "#78909C"
      font-color: white
      bold: true
    }
  }
}
row_emit: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  emit_kw: EMIT\nTOK_KEYWORD {
    shape: hexagon
    style: {
      fill: "#C8E6C9"
      bold: true
      font-size: 13
    }
  }
  emit_ident: EMIT\nTOK_IDENTIFIER {
    shape: hexagon
    style: {
      fill: "#BBDEFB"
      bold: true
      font-size: 13
    }
  }
  emit_int: EMIT\nTOK_INTEGER {
    shape: hexagon
    style: {
      fill: "#FFE0B2"
      bold: true
      font-size: 13
    }
  }
  emit_float: EMIT\nTOK_FLOAT {
    shape: hexagon
    style: {
      fill: "#FFCCBC"
      bold: true
      font-size: 13
    }
  }
  emit_string: EMIT\nTOK_STRING {
    shape: hexagon
    style: {
      fill: "#E1BEE7"
      bold: true
      font-size: 13
    }
  }
  emit_op: EMIT\nTOK_OPERATOR {
    shape: hexagon
    style: {
      fill: "#FFCDD2"
      bold: true
      font-size: 13
    }
  }
  emit_quoted: EMIT\nTOK_IDENTIFIER {
    shape: hexagon
    style: {
      fill: "#B2EBF2"
      bold: true
      font-size: 13
    }
  }
  emit_error: EMIT\nTOK_ERROR {
    shape: hexagon
    style: {
      fill: "#FF8A80"
      bold: true
      font-size: 13
    }
  }
}
# ============================================================
# TRANSITIONS FROM START
# ============================================================
row_start.start -> row_dispatch.in_ident: "[a-zA-Z_]" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
row_start.start -> row_dispatch.in_number: "[0-9]" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
row_start.start -> row_dispatch.in_string: "single quote (')" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
row_start.start -> row_dispatch.in_operator: "[=<>!+-*/]" {
  style.stroke: "#F44336"
  style.stroke-width: 2
}
row_start.start -> row_dispatch.in_quoted_id: "double quote (\")" {
  style.stroke: "#00BCD4"
  style.stroke-width: 2
}
row_start.start -> row_sub.in_comment: "-- (two dashes)" {
  style.stroke: "#78909C"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row_start.start -> row_emit.emit_error: "unrecognized char" {
  style.stroke: "#FF8A80"
  style.stroke-dash: 4
}
# ============================================================
# IN_IDENTIFIER transitions
# ============================================================
row_dispatch.in_ident -> row_dispatch.in_ident: "[a-zA-Z0-9_]" {
  style.stroke: "#2196F3"
  style.stroke-dash: 3
}
row_dispatch.in_ident -> row_sub.keyword_check: "non-alnum seen" {
  style.stroke: "#2196F3"
}
row_sub.keyword_check -> row_emit.emit_kw: "matches keyword\ntable" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_sub.keyword_check -> row_emit.emit_ident: "no match" {
  style.stroke: "#2196F3"
}
# ============================================================
# IN_NUMBER transitions
# ============================================================
row_dispatch.in_number -> row_dispatch.in_number: "[0-9]" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}
row_dispatch.in_number -> row_sub.in_float: "'.' followed by digit" {
  style.stroke: "#FF5722"
  style.stroke-width: 2
}
row_dispatch.in_number -> row_emit.emit_int: "non-digit seen" {
  style.stroke: "#FF9800"
}
row_sub.in_float -> row_sub.in_float: "[0-9] or [eE][+-]?" {
  style.stroke: "#FF5722"
  style.stroke-dash: 3
}
row_sub.in_float -> row_emit.emit_float: "non-digit seen" {
  style.stroke: "#FF5722"
}
# ============================================================
# IN_STRING transitions (escaped quote handling)
# ============================================================
row_dispatch.in_string -> row_dispatch.in_string: "any char except '" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
row_dispatch.in_string -> row_sub.maybe_end_str: "single quote (')" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
row_sub.maybe_end_str -> row_dispatch.in_string: "next char is '\n(escaped '')" {
  style.stroke: "#E040FB"
  style.stroke-width: 3
  style.font-color: "#9C27B0"
}
row_sub.maybe_end_str -> row_emit.emit_string: "next char is NOT '\n(string terminated)" {
  style.stroke: "#9C27B0"
}
# ============================================================
# IN_OPERATOR transitions (single vs multi-char)
# ============================================================
row_dispatch.in_operator -> row_sub.multi_char: "peek next char" {
  style.stroke: "#F44336"
}
row_sub.multi_char -> row_emit.emit_op: "<= >= != <>\n(2-char operator)" {
  style.stroke: "#F44336"
  style.stroke-width: 2
}
row_sub.multi_char -> row_emit.emit_op: "no follow-up\n(1-char: = < > + - * /)" {
  style.stroke: "#F44336"
}
# ============================================================
# IN_QUOTED_ID transitions
# ============================================================
row_dispatch.in_quoted_id -> row_dispatch.in_quoted_id: "any char except \"" {
  style.stroke: "#00BCD4"
  style.stroke-dash: 3
}
row_dispatch.in_quoted_id -> row_emit.emit_quoted: "closing double quote" {
  style.stroke: "#00BCD4"
}
row_dispatch.in_quoted_id -> row_emit.emit_error: "EOF (unterminated)" {
  style.stroke: "#FF8A80"
  style.stroke-dash: 4
}
# ============================================================
# IN_COMMENT transitions
# ============================================================
row_sub.in_comment -> row_sub.in_comment: "any char except newline" {
  style.stroke: "#78909C"
  style.stroke-dash: 3
}
row_sub.in_comment -> row_start.start: "newline or EOF\n(comment discarded)" {
  style.stroke: "#78909C"
}
# ============================================================
# ALL EMIT states return to START
# ============================================================
row_emit.emit_kw -> row_start.start: "reset" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}
row_emit.emit_ident -> row_start.start: "reset" {
  style.stroke: "#2196F3"
  style.stroke-dash: 3
}
row_emit.emit_int -> row_start.start: "reset" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}
row_emit.emit_float -> row_start.start: "reset" {
  style.stroke: "#FF5722"
  style.stroke-dash: 3
}
row_emit.emit_string -> row_start.start: "reset" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
row_emit.emit_op -> row_start.start: "reset" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
}
row_emit.emit_quoted -> row_start.start: "reset" {
  style.stroke: "#00BCD4"
  style.stroke-dash: 3
}
# ============================================================
# LEGEND
# ============================================================
legend: {
  label: "Legend"
  style: {
    fill: "#F5F5F5"
    border-radius: 8
    font-size: 14
  }
  l1: "Green circle = START state (reset point)" {
    style.font-size: 12
  }
  l2: "Colored ovals = scanning states (consuming chars)" {
    style.font-size: 12
  }
  l3: "Diamonds = decision points (lookahead required)" {
    style.font-size: 12
  }
  l4: "Hexagons = EMIT token and return to START" {
    style.font-size: 12
  }
  l5: "Dashed self-loops = stay in state, consume next char" {
    style.font-size: 12
  }
  l6: "Key insight: ' in START enters IN_STRING" {
    style.font-size: 12
    style.bold: true
  }
  l7: "  ' in IN_STRING enters MAYBE_END (disambiguation)" {
    style.font-size: 12
    style.bold: true
  }
  l8: "  '' in string = escaped quote, not terminator" {
    style.font-size: 12
    style.bold: true
  }
}
legend.near: bottom-right