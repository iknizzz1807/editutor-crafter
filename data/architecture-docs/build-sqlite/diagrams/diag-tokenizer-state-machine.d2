direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
start_node: "START" {
  shape: circle
  style.fill: "#4CAF50"
  style.font-color: white
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.bold: true
}
row_top: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  in_ident: "IN_IDENTIFIER\n(tokenizer.c)" {
    shape: oval
    style.fill: "#B3E5FC"
    style.stroke: "#0277BD"
  }
  in_string: "IN_STRING\n(scan_string)" {
    shape: oval
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  in_number: "IN_NUMBER\n(scan_number)" {
    shape: oval
    style.fill: "#FFF9C4"
    style.stroke: "#F57F17"
  }
  in_qident: "IN_QUOTED_IDENT\n(scan_quoted_id)" {
    shape: oval
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
}
row_mid: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  string_escape: "STRING_ESCAPE\n(seen first quote)" {
    shape: oval
    style.fill: "#EDE7F6"
    style.stroke: "#512DA8"
  }
  in_float: "IN_FLOAT\n(DECIMAL sub-state)" {
    shape: oval
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"
  }
  in_op: "IN_OPERATOR\n(< > ! =)" {
    shape: oval
    style.fill: "#FCE4EC"
    style.stroke: "#C62828"
  }
  in_kw_ident: "IN_KEYWORD_OR_IDENT\n(post word-scan)" {
    shape: oval
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
    style.stroke-dash: 4
  }
}
emit_token: "EMIT TOKEN\n(advance caller)" {
  shape: oval
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.bold: true
}
error_node: "ERROR\n(TOKEN_ERROR)" {
  shape: oval
  style.fill: "#FFCDD2"
  style.stroke: "#B71C1C"
  style.font-color: "#B71C1C"
  style.stroke-width: 2
}
start_node -> row_top.in_ident: "alpha | '_'"
start_node -> row_top.in_string: "' (single quote)"
start_node -> row_top.in_number: "digit [0-9]"
start_node -> row_top.in_qident: "\" (double quote)"
start_node -> row_mid.in_op: "< | > | ! | ="
start_node -> start_node: "whitespace\n(skip)"
start_node -> emit_token: "; , ( ) . + - * /"
start_node -> error_node: "unexpected char"
row_top.in_ident -> row_top.in_ident: "alpha | digit | '_'"
row_top.in_ident -> row_mid.in_kw_ident: "other (putback)"
row_mid.in_kw_ident -> emit_token: "match_keyword()\nTOKEN_KW or TOKEN_IDENT"
row_top.in_string -> row_top.in_string: "any non-quote char"
row_top.in_string -> row_mid.string_escape: "' (quote seen)"
row_top.in_string -> error_node: "EOF / NUL\n(unterminated)"
row_mid.string_escape -> row_top.in_string: "' (escaped '' → ')"
row_mid.string_escape -> emit_token: "other (closing quote)\nTOKEN_STRING"
row_top.in_number -> row_top.in_number: "digit [0-9]"
row_top.in_number -> row_mid.in_float: ". followed by digit\n(TOKEN_FLOAT path)"
row_top.in_number -> emit_token: "other (putback)\nTOKEN_INTEGER"
row_mid.in_float -> row_mid.in_float: "digit [0-9]"
row_mid.in_float -> emit_token: "other (putback)\nTOKEN_FLOAT"
row_top.in_qident -> row_top.in_qident: "any non-dquote char"
row_top.in_qident -> emit_token: "\" (closing dquote)\nTOKEN_QUOTED_ID"
row_top.in_qident -> error_node: "EOF / NUL\n(unterminated)"
row_mid.in_op -> emit_token: "= after <  → TOKEN_LTE\n= after >  → TOKEN_GTE\n= after !  → TOKEN_NEQ\n> after <  → TOKEN_NEQ (<>)\nother      → single-char op"
emit_token -> start_node: "next token\n(loop)"
legend: "Color Key" {
  near: bottom-right
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  entry1: "Green fill = initial state (START)" {
    shape: text
    style.font-color: "#2E7D32"
  }
  entry2: "Dashed border = classification state (not storage)" {
    shape: text
    style.font-color: "#0288D1"
  }
  entry3: "Red fill = error terminal" {
    shape: text
    style.font-color: "#B71C1C"
  }
  entry4: "Arrows labeled with char class triggers" {
    shape: text
    style.font-color: "#424242"
  }
}