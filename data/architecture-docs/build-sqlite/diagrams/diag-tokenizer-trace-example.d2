direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Token Stream Trace: SQL Tokenizer
| {near: top-center}
input_section: "Tokenizer Input (tokenizer.c)" {
  direction: down
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.border-radius: 6
  offset_map: {
    shape: sql_table
    label: "Byte Offset Map — Key Token Start Positions (src base pointer)"
    r01: "offset  0 | char S | SELECT keyword begins   | col  1"
    r02: "offset  7 | char n | identifier: name        | col  8"
    r03: "offset 11 | char , | comma punctuation       | col 12"
    r04: "offset 13 | char a | identifier: age         | col 14"
    r05: "offset 17 | char F | FROM keyword begins     | col 18"
    r06: "offset 22 | char u | identifier: users       | col 23"
    r07: "offset 28 | char W | WHERE keyword begins    | col 29"
    r08: "offset 34 | char a | identifier: age col ref | col 35"
    r09: "offset 38 | char > | two-char operator >=    | col 39"
    r10: "offset 41 | char 2 | integer literal 21      | col 42"
    r11: "offset 44 | char A | AND keyword begins      | col 45"
    r12: "offset 48 | char c | identifier: city        | col 49"
    r13: "offset 53 | char = | equality operator       | col 54"
    r14: "offset 55 | char ' | string literal begins   | col 56"
    r15: "offset 65 | NUL   | end of input string      | col 66"
  }
}
state_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sm_word: "scan_word() — Keywords and Identifiers" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.border-radius: 6
    width: 340
    sw_start: START {
      shape: circle
      style.fill: "#7B1FA2"
      style.font-color: white
    }
    sw_inword: IN_WORD {
      shape: circle
      style.fill: "#BA68C8"
      style.font-color: white
    }
    sw_kw: KEYWORD_TOKEN {
      shape: oval
      style.stroke-width: 3
      style.fill: "#2E7D32"
      style.font-color: white
    }
    sw_id: IDENTIFIER_TOKEN {
      shape: oval
      style.stroke-width: 3
      style.fill: "#1565C0"
      style.font-color: white
    }
    sw_start -> sw_inword: "isalpha(c) or c=='_'"
    sw_inword -> sw_inword: "isalnum(c) or c=='_'"
    sw_inword -> sw_kw: "non-alnum + match_keyword() hits"
    sw_inword -> sw_id: "non-alnum + match_keyword() miss"
    ex_note: "SELECT(len=6) -> TOKEN_SELECT  name(len=4) -> TOKEN_IDENTIFIER" {
      shape: callout
      style.fill: "#EDE7F6"
      style.font-size: 11
    }
  }
  sm_op: "scan_operator() — One and Two-char Operators" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
    style.border-radius: 6
    width: 360
    op_start: START {
      shape: circle
      style.fill: "#F57F17"
      style.font-color: white
    }
    op_saw_gt: SAW_GT {
      shape: circle
      style.fill: "#FFB300"
    }
    op_gte: GTE_TOKEN {
      shape: oval
      style.stroke-width: 3
      style.fill: "#2E7D32"
      style.font-color: white
    }
    op_gt: GT_TOKEN {
      shape: oval
      style.stroke-width: 3
      style.fill: "#C62828"
      style.font-color: white
    }
    op_eq: EQ_TOKEN {
      shape: oval
      style.stroke-width: 3
      style.fill: "#1565C0"
      style.font-color: white
    }
    op_start -> op_saw_gt: "advance(); c == '>'"
    op_start -> op_eq: "advance(); c == '='"
    op_saw_gt -> op_gte: "peek()=='=' then advance, emit 2 bytes"
    op_saw_gt -> op_gt: "peek()!='=' then emit 1 byte"
    op_note: ">= at offset 38: advance > then peek = -> GTE" {
      shape: callout
      style.fill: "#FFFDE7"
      style.font-size: 11
    }
  }
  sm_str: "scan_string() — String Literals with SQL Escape Sequences" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.border-radius: 6
    width: 380
    ss_start: START {
      shape: circle
      style.fill: "#2E7D32"
      style.font-color: white
    }
    ss_instr: IN_STRING {
      shape: circle
      style.fill: "#66BB6A"
    }
    ss_esc: POSSIBLE_ESCAPE {
      shape: circle
      style.fill: "#FFA726"
    }
    ss_done: STRING_TOKEN {
      shape: oval
      style.stroke-width: 3
      style.fill: "#1565C0"
      style.font-color: white
    }
    ss_err: ERROR_TOKEN {
      shape: oval
      style.stroke: red
      style.stroke-width: 3
      style.fill: "#FFEBEE"
      style.font-color: red
    }
    ss_start -> ss_instr: "opening single-quote consumed"
    ss_instr -> ss_esc: "c == single-quote"
    ss_instr -> ss_err: "c == NUL unterminated" {
      style.stroke-dash: 4
      style.stroke: red
    }
    ss_instr -> ss_instr: "any other char incl spaces"
    ss_esc -> ss_instr: "next==single-quote: SQL escape emit one quote"
    ss_esc -> ss_done: "next!=single-quote: closing quote token complete"
    ss_note: "New York len=10 zero-copy raw span; parser decodes escape later" {
      shape: callout
      style.fill: "#F1F8E9"
      style.font-size: 11
    }
  }
}
token_stream: {
  shape: sql_table
  label: "Output Token Stream — Token[] from lexer_tokenize_all() — parser calls lexer_next_token() sequentially"
  hdr: "idx | TokenType         | .start offset | .length | line | col | scan path"
  t0:  " 0  | TOKEN_SELECT      | src+0         |       6 |    1 |   1 | scan_word() + match_keyword() switch S"
  t1:  " 1  | TOKEN_IDENTIFIER  | src+7         |       4 |    1 |   8 | scan_word() value: name no keyword match"
  t2:  " 2  | TOKEN_COMMA       | src+11        |       1 |    1 |  12 | scan_punct() case comma"
  t3:  " 3  | TOKEN_IDENTIFIER  | src+13        |       3 |    1 |  14 | scan_word() value: age"
  t4:  " 4  | TOKEN_FROM        | src+17        |       4 |    1 |  18 | scan_word() + match_keyword() switch F"
  t5:  " 5  | TOKEN_IDENTIFIER  | src+22        |       5 |    1 |  23 | scan_word() value: users"
  t6:  " 6  | TOKEN_WHERE       | src+28        |       5 |    1 |  29 | scan_word() + match_keyword() switch W"
  t7:  " 7  | TOKEN_IDENTIFIER  | src+34        |       3 |    1 |  35 | scan_word() value: age column ref"
  t8:  " 8  | TOKEN_GTE         | src+38        |       2 |    1 |  39 | scan_operator >: peek = then advance GTE"
  t9:  " 9  | TOKEN_INTEGER     | src+41        |       2 |    1 |  42 | scan_number() raw span: 21 type INTEGER"
  t10: "10  | TOKEN_AND         | src+44        |       3 |    1 |  45 | scan_word() + match_keyword() switch A"
  t11: "11  | TOKEN_IDENTIFIER  | src+48        |       4 |    1 |  49 | scan_word() value: city"
  t12: "12  | TOKEN_EQ          | src+53        |       1 |    1 |  54 | scan_operator =: no lookahead needed"
  t13: "13  | TOKEN_STRING      | src+55        |      10 |    1 |  56 | scan_string(): raw span incl both quotes"
  t14: "14  | TOKEN_EOF         | src+65        |       0 |    1 |  66 | src==NUL sentinel returned on every call"
  style.fill: "#0D47A1"
  style.font-color: white
}
input_section -> state_row: "lexer_next_token() dispatches on first char"
state_row -> token_stream: "each scan_* returns Token{type,start,length,line,col}"