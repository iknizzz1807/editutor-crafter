direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header_container: {
  style.stroke: transparent
  style.fill: transparent
  title: |md
    # Torn Page Write Problem
    4KB page write interrupted at byte 0x0800 — top half new, bottom half old
  |
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  original_page: "Original Page (pre-write)" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
    style.border-radius: 4
    
    hdr: {
      shape: sql_table
      label: "Page Header (0x0000–0x0007)"
      type_field: "0x0000 | uint8_t  | page_type = 0x0D (leaf)"
      free_block: "0x0001 | uint16_t | first_freeblock = 0"
      cell_count: "0x0003 | uint16_t | cell_count = 47"
      content_st: "0x0005 | uint16_t | cell_content_start = 0x0A80"
      frag:       "0x0007 | uint8_t  | fragmented_bytes = 0"
      style.fill: "#C8E6C9"
    }
    
    data_region: {
      shape: sql_table
      label: "Cell Data Region (0x0008–0x07FF)"
      cells_hi: "0x0008 | bytes | cell_ptr_array[0..46]"
      content:  "0x0600 | bytes | cell_content rows 1..47"
      note:     "sz: 1984 bytes total"
      style.fill: "#C8E6C9"
    }
    
    free_region: {
      shape: sql_table
      label: "Free Space (0x0800–0x0FFF)"
      free1: "0x0800 | bytes | [FREE — 2048 bytes]"
      free2: "0x0FFF | —     | end of 4KB page"
      style.fill: "#E8F5E9"
    }
    
    orig_note: "State: Valid Checksum" {
      style.fill: "#A5D6A7"
      style.stroke: "#43A047"
      style.font-color: "#1B5E20"
      style.bold: true
    }
  }

  write_ops: "Write Operations Initiated" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.border-radius: 4
    
    ops_table: {
      shape: sql_table
      label: "pwrite() — 4KB to page 5"
      op1: "Step A | count 47 -> 48"
      op2: "Step B | start 0x0A80 -> 0x0A60"
      op3: "Step C | append ptr[47]"
      op4: "Step D | write cell at 0x0A60"
      op5: "Step E | shrink free area"
      style.fill: "#BBDEFB"
    }
    
    write_note: "OS 4KB write | 8 sectors" {
      style.fill: "#90CAF9"
      style.stroke: "#1976D2"
      style.font-color: "#0D47A1"
      style.bold: true
    }
  }

  new_page: "Intended New Page (Atomic)" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.border-radius: 4
    
    hdr_new: {
      shape: sql_table
      label: "Page Header — UPDATED"
      type_new:  "0x0000 | uint8_t  | page_type = 0x0D"
      count_new: "0x0003 | uint16_t | cell_count = 48"
      cst_new:   "0x0005 | uint16_t | cell_content_start = 0x0A60"
      style.fill: "#BBDEFB"
    }
    
    data_new: {
      shape: sql_table
      label: "Cell Data — UPDATED"
      ptrs_new: "0x0008 | bytes | ptr[0..47]"
      new_cell: "0x0A60 | bytes | cell rowid=48"
      style.fill: "#BBDEFB"
    }
    
    free_new: {
      shape: sql_table
      label: "Free Space — UPDATED"
      fn1: "0x0800 | bytes | [FREE — 2016 bytes]"
      style.fill: "#E3F2FD"
    }
    
    new_note: "Consistent if completed" {
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
      style.font-color: "#0D47A1"
      style.bold: true
    }
  }
}

crash_banner: "⚡  POWER FAILURE — Write Interrupted at Sector 4 (0x0800)  ⚡" {
  style.fill: "#B71C1C"
  style.font-color: "#FFFFFF"
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.bold: true
  style.border-radius: 6
  
  crash_context: {
    shape: sql_table
    label: "Physical Crash State"
    c1: "0x0000–0x07FF | COMMIT | Written to platter/NAND"
    c2: "0x0800–0x0FFF | LOST   | Volatile buffer discarded"
    c3: "Hardware      | NVMe   | Sector atomicity != Page atomicity"
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  torn_page: "☠  Torn Page — CORRUPT STATE" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    style.border-radius: 4
    
    torn_top: {
      shape: sql_table
      label: "Lower Sectors (0x0000–0x07FF) — NEW DATA"
      t1: "0x0003 | cell_count = 48"
      t2: "0x0005 | content_start = 0x0A60"
      t3: "0x0008 | ptr[47] = 0x0A60"
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
    }
    
    torn_boundary: "━━━━  TORN BOUNDARY 0x0800  ━━━━" {
      style.fill: "#B71C1C"
      style.font-color: "#FFFFFF"
      style.stroke: "#7F0000"
      style.bold: true
    }
    
    torn_bot: {
      shape: sql_table
      label: "Upper Sectors (0x0800–0x0FFF) — OLD DATA"
      b1: "0x0800 | OLD free space layout"
      b2: "0x0A60 | NO CELL DATA (stale sectors)"
      style.fill: "#FFCCBC"
      style.stroke: "#E64A19"
    }
    
    corrupt_note: "Error: Ptr 47 points to garbage" {
      style.fill: "#EF9A9A"
      style.stroke: "#C62828"
      style.font-color: "#B71C1C"
      style.bold: true
    }
  }

  journal_col: {
    direction: down
    style.stroke: transparent
    style.fill: transparent

    journal_file: "Rollback Journal (.db-journal)" {
      direction: down
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      style.border-radius: 4
      
      j_hdr: {
        shape: sql_table
        label: "Journal Header (fsynced)"
        jh1: "0x00 | MAGIC | 0xD9D505F920A163D7"
        jh2: "0x08 | nRec  | -1 (HOT)"
        style.fill: "#E1BEE7"
      }
      
      j_record: {
        shape: sql_table
        label: "Record: Page 5 (4KB Image)"
        jr1: "0x000 | uint32_t | pgno = 5"
        jr2: "0x004 | bytes    | PRE-WRITE DATA (all 4KB)"
        style.fill: "#CE93D8"
      }
      
      j_safety: "Original image safe in journal" {
        style.fill: "#9C27B0"
        style.font-color: "#FFFFFF"
        style.bold: true
      }
    }

    protocol_box: "Atomic Commit Protocol" {
      direction: down
      style.fill: "#E8EAF6"
      style.stroke: "#3F51B5"
      style.border-radius: 4
      
      # Renamed key 'steps' to 'protocol_steps' to avoid D2 reserved keyword conflict
      protocol_steps: {
        shape: sql_table
        label: "Ordering Requirements"
        s1: "1 | Write original image to journal"
        s2: "2 | fsync(journal) — BARRIER"
        s3: "3 | Write modified page to DB"
        s4: "4 | fsync(DB)"
        s5: "5 | Delete journal"
        style.fill: "#C5CAE9"
      }
      
      p_rule: "Journal exists? Rollback required" {
        style.fill: "#3F51B5"
        style.font-color: "#FFFFFF"
        style.bold: true
      }
    }

    recovered_page: "✓  Restored Page (Post-Rollback)" {
      direction: down
      style.fill: "#E8F5E9"
      style.stroke: "#43A047"
      style.border-radius: 4
      
      rec_detail: {
        shape: sql_table
        label: "Page 5 restored from Journal"
        r1: "0x0003 | cell_count = 47"
        r2: "0x0005 | content_start = 0x0A80"
        r3: "0x0800 | Sector 4 restored"
        style.fill: "#C8E6C9"
      }
      
      rec_note: "Identical to original" {
        style.fill: "#A5D6A7"
        style.stroke: "#43A047"
        style.font-color: "#1B5E20"
        style.bold: true
      }
    }
  }
}

# Connections
row1.original_page -> row1.write_ops: "Mutation"
row1.write_ops -> row1.new_page: "Intended"
row1.original_page -> row2.journal_col.journal_file: "1. Backup" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
row1.write_ops -> crash_banner: "Physical Fail" {
  style.stroke: "#D32F2F"
}
crash_banner -> row2.torn_page: "Split State"
row2.torn_page -> row2.journal_col.protocol_box: "Detection"
row2.journal_col.journal_file -> row2.journal_col.recovered_page: "Rollback" {
  style.stroke: "#7B1FA2"
  style.animated: true
}
row2.journal_col.protocol_box -> row2.journal_col.recovered_page: "Recovery Logic"

legend: "Red: Danger | Green: Consistent | Blue: Write Path | Purple: Journal" {
  near: bottom-right
  style.fill: "#EEEEEE"
  style.stroke: "#999999"
  style.border-radius: 4
}