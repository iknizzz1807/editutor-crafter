direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  transparent_row: {
    style.stroke: transparent
    style.fill: transparent
  }
}
title: VDBE Architecture Overview {
  style.font-size: 24
  style.bold: true
  style.fill: "#E8EAF6"
  style.border-radius: 8
}
# ─── SQL Frontend (upstream) ───
frontend: SQL Frontend {
  style.fill: "#F3E5F5"
  style.border-radius: 8
  style.stroke: "#7B1FA2"
  sql_input: "SQL Text" {
    style.fill: "#CE93D8"
    style.border-radius: 6
  }
  tokenizer: "Tokenizer (lexer.c)" {
    style.fill: "#E1BEE7"
  }
  parser: "Parser (parser.c)" {
    style.fill: "#E1BEE7"
  }
  compiler: "Bytecode Compiler (compiler.c)" {
    style.fill: "#E1BEE7"
  }
  sql_input -> tokenizer: "const char*"
  tokenizer -> parser: "Token[]"
  parser -> compiler: "AstNode*"
}
# ─── VDBE Core ───
vdbe: Virtual Database Engine (VDBE) {
  style.fill: "#E3F2FD"
  style.border-radius: 8
  style.stroke: "#1565C0"
  style.stroke-width: 3
  row1: "" {
    class: transparent_row
    direction: right
    program: {
      label: "Program (bytecode)"
      style.fill: "#BBDEFB"
      style.border-radius: 6
      instruction_array: {
        shape: sql_table
        label: "Instruction Array (VdbeOp[])"
        i0: "0 | Init       | p1=0  p2=1  p3=0"
        i1: "1 | OpenRead   | p1=0  p2=5  p3=3"
        i2: "2 | Rewind     | p1=0  p2=9  p3=0"
        i3: "3 | Column     | p1=0  p2=1  p3=2"
        i4: "4 | Integer    | p1=21 p2=3  p3=0"
        i5: "5 | Le         | p1=2  p2=8  p3=3"
        i6: "6 | Column     | p1=0  p2=0  p3=1"
        i7: "7 | ResultRow  | p1=1  p2=2  p3=0"
        i8: "8 | Next       | p1=0  p2=3  p3=0"
        i9: "9 | Close      | p1=0  p2=0  p3=0"
        i10: "10| Halt       | p1=0  p2=0  p3=0"
      }
      string_pool: {
        shape: sql_table
        label: "String Constant Pool"
        s0: "0 | 'active'"
        s1: "1 | 'users'"
        s2: "2 | 'Alice'"
      }
    }
    pc: {
      label: "Program Counter"
      style.fill: "#FFF9C4"
      style.border-radius: 6
      style.stroke: "#F9A825"
      style.stroke-width: 2
      pc_val: {
        shape: sql_table
        label: "PC State"
        current: "pc | int | 3 (current instruction)"
        halted: "halted | bool | false"
        halt_code: "halt_code | int | 0"
      }
    }
  }
  row2: "" {
    class: transparent_row
    direction: right
    registers: {
      label: "Register File"
      style.fill: "#C8E6C9"
      style.border-radius: 6
      style.stroke: "#2E7D32"
      reg_table: {
        shape: sql_table
        label: "Value registers[256]"
        r0: "r0 | (scratch)    | VAL_NULL"
        r1: "r1 | name column  | VAL_STRING 'Alice'"
        r2: "r2 | age column   | VAL_INTEGER 30"
        r3: "r3 | constant 21  | VAL_INTEGER 21"
        r4: "r4 | (available)  | VAL_NULL"
        dots: "... | 252 more   | VAL_NULL"
      }
    }
    cursors: {
      label: "Cursor Array"
      style.fill: "#FFE0B2"
      style.border-radius: 6
      style.stroke: "#E65100"
      cursor_table: {
        shape: sql_table
        label: "BTreeCursor* cursors[16]"
        c0: "cursor 0 | BTreeCursor* | users table (root pg 5)"
        c1: "cursor 1 | BTreeCursor* | idx_age index (root pg 8)"
        c2: "cursor 2 | BTreeCursor* | NULL (unused)"
        dots: "... | 13 more | NULL"
      }
      cursor_detail: {
        shape: class
        label: "BTreeCursor (cursor.h)"
        -tree: "BTree*"
        -page_id: "page_id_t"
        -cell_index: "int"
        -is_eof: "bool"
        -stack: "ParentEntry[20]"
        -stack_depth: "int"
        +rewind(): "bool"
        +next(): "bool"
        +column(col_idx, dest): "void"
        +rowid(): "int64_t"
        +seek(rowid): "void"
        +insert(key, record): "void"
        +delete_current(): "void"
      }
    }
  }
  row3: "" {
    class: transparent_row
    direction: right
    result_acc: {
      label: "Result Accumulator"
      style.fill: "#F8BBD0"
      style.border-radius: 6
      style.stroke: "#C2185B"
      callback: {
        shape: sql_table
        label: "Output Interface"
        cb_fn: "result_callback | void(*)(Value*, int, void*)"
        cb_ctx: "callback_ctx | void*"
        note: "Called on each OP_RESULT_ROW"
      }
      result_row: {
        shape: sql_table
        label: "Current Result Row"
        col0: "r1 | VAL_STRING | 'Alice'"
        col1: "r2 | VAL_INTEGER | 30"
        sep: "--- output as 2-column row ---"
      }
    }
    exec_loop: {
      label: "Fetch-Decode-Execute Loop"
      style.fill: "#FFF3E0"
      style.border-radius: 6
      style.stroke: "#E65100"
      style.stroke-width: 2
      loop_code: |'c
        while (!vm->halted) {
          VdbeOp *op = &prog->ops[vm->pc];
          switch (op->opcode) {
            case OP_COLUMN:  /* read from cursor */
            case OP_INTEGER: /* load constant */
            case OP_LE:      /* compare + jump */
            case OP_RESULT_ROW: /* emit row */
            case OP_NEXT:    /* advance cursor */
            case OP_HALT:    /* stop */
            ...
          }
          vm->pc++;
        }
      '|
      width: 340
    }
  }
  # ─── Internal connections ───
  row1.pc.pc_val -> row1.program.instruction_array: "indexes into" {
    style.stroke: "#F9A825"
    style.stroke-width: 2
  }
  row1.program.instruction_array -> row2.registers.reg_table: "p1/p2/p3 ref regs" {
    style.stroke: "#2E7D32"
  }
  row1.program.instruction_array -> row2.cursors.cursor_table: "p1 ref cursor" {
    style.stroke: "#E65100"
  }
  row2.cursors.cursor_table -> row2.cursors.cursor_detail: "each slot holds"
  row2.registers.reg_table -> row3.result_acc.result_row: "OP_RESULT_ROW reads regs" {
    style.stroke: "#C2185B"
    style.stroke-dash: 4
  }
  row3.result_acc.result_row -> row3.result_acc.callback: "invokes" {
    style.stroke: "#C2185B"
  }
  row3.exec_loop -> row1.pc.pc_val: "advances pc" {
    style.stroke: "#E65100"
    style.stroke-width: 2
    style.animated: true
  }
}
# ─── Storage Backend (downstream) ───
backend: Storage Backend {
  style.fill: "#E8F5E9"
  style.border-radius: 8
  style.stroke: "#2E7D32"
  direction: right
  btree: "B-tree / B+tree\n(btree.c)" {
    style.fill: "#A5D6A7"
  }
  buffer_pool: "Buffer Pool\n(pager.c)" {
    style.fill: "#A5D6A7"
  }
  disk: "Database File\n(OS I/O)" {
    shape: cylinder
    style.fill: "#81C784"
  }
  btree -> buffer_pool: "fetch_page()"
  buffer_pool -> disk: "pread / pwrite"
}
# ─── Cross-layer connections ───
frontend.compiler -> vdbe.row1.program: "Program*" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
vdbe.row2.cursors.cursor_detail -> backend.btree: "cursor ops" {
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.animated: true
}
vdbe.row3.result_acc.callback -> user_output: "row data" {
  style.stroke: "#C2185B"
  style.stroke-width: 2
}
user_output: "Client / Application" {
  shape: person
  style.fill: "#E0E0E0"
}
# ─── Legend ───
legend: {
  label: "Legend"
  style.fill: "#FAFAFA"
  style.border-radius: 6
  near: bottom-right
  direction: down
  l1: "Yellow — Program Counter (control flow)" {
    style.fill: "#FFF9C4"
    style.font-size: 13
  }
  l2: "Green — Register File (data values)" {
    style.fill: "#C8E6C9"
    style.font-size: 13
  }
  l3: "Orange — Cursor Array (B-tree iterators)" {
    style.fill: "#FFE0B2"
    style.font-size: 13
  }
  l4: "Pink — Result Output (callback)" {
    style.fill: "#F8BBD0"
    style.font-size: 13
  }
  l5: "Purple — SQL Frontend (upstream)" {
    style.fill: "#F3E5F5"
    style.font-size: 13
  }
}