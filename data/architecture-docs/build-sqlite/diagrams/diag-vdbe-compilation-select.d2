direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: AST to Bytecode — SELECT Compilation {
  style.font-size: 24
  style.bold: true
  near: top-center
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ast: AST {
    direction: down
    style.fill: "#f0f4ff"
    style.stroke: "#4a6fa5"
    style.border-radius: 8
    select_node: {
      shape: class
      label: "NODE_SELECT"
      +from_table: "\"users\" (root_page=5)"
      +column_count: "2"
      +columns: "[name, age]"
      +where_clause: "-> BINARY_EXPR"
      +limit: "-1 (none)"
    }
    columns_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      col0: {
        shape: class
        label: "NODE_IDENTIFIER"
        +name: "\"name\""
        +col_idx: "0"
      }
      col1: {
        shape: class
        label: "NODE_IDENTIFIER"
        +name: "\"age\""
        +col_idx: "1"
      }
    }
    where_node: {
      shape: class
      label: "NODE_BINARY_EXPR"
      +op: "TOK_GT (>)"
      +left: "-> IDENTIFIER"
      +right: "-> LITERAL"
    }
    where_children: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      where_left: {
        shape: class
        label: "NODE_IDENTIFIER"
        +name: "\"age\""
        +col_idx: "1"
      }
      where_right: {
        shape: class
        label: "NODE_LITERAL"
        +type: "TOK_INTEGER"
        +value: "\"21\""
      }
    }
    select_node -> columns_row: "columns[]"
    select_node -> where_node: "where_clause"
    where_node -> where_children: "left / right"
  }
  bytecode: Bytecode Program {
    direction: down
    style.fill: "#fff8f0"
    style.stroke: "#c47a2a"
    style.border-radius: 8
    op0: {
      shape: sql_table
      label: "Instruction Array"
      a0: "0  | Init         | 0  | 1  | 0  | Start"
      a1: "1  | OpenRead     | 0  | 5  | 3  | users"
      a2: "2  | Rewind       | 0  | 10 | 0  | jump if empty"
      a3: "3  | Column       | 0  | 1  | 2  | age -> r2"
      a4: "4  | Integer      | 21 | 3  | 0  | 21 -> r3"
      a5: "5  | IsNull       | 2  | 9  | 0  | skip if age NULL"
      a6: "6  | Le           | 2  | 9  | 3  | skip if age <= 21"
      a7: "7  | Column       | 0  | 0  | 1  | name -> r1"
      a8: "8  | ResultRow    | 1  | 2  | 0  | output r1,r2"
      a9: "9  | Next         | 0  | 3  | 0  | loop back"
      a10: "10 | Close        | 0  | 0  | 0  | close cursor"
      a11: "11 | Halt         | 0  | 0  | 0  | done"
    }
    regs: {
      shape: sql_table
      label: "Register File"
      r0: "r0 | (scratch)"
      r1: "r1 | name column value"
      r2: "r2 | age column value"
      r3: "r3 | constant 21"
    }
  }
}
mapping: Compilation Mapping {
  direction: down
  style.fill: "#f0fff0"
  style.stroke: "#4a8c4a"
  style.border-radius: 8
  m_row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    from_map: {
      label: "select.from_table = \"users\""
      style.fill: "#d0e0ff"
      style.font-size: 13
    }
    from_arrow: {
      label: "OpenRead 0, root=5, cols=3"
      style.fill: "#ffe0c0"
      style.font-size: 13
    }
    from_map -> from_arrow: "emits" {style.stroke: "#4a6fa5"}
  }
  m_row2: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    where_map: {
      label: "where: age > 21"
      style.fill: "#d0e0ff"
      style.font-size: 13
    }
    where_arrow: {
      label: "Column(age) + Integer(21) + IsNull + Le (inverted!)"
      style.fill: "#ffe0c0"
      style.font-size: 13
    }
    where_map -> where_arrow: "emits" {style.stroke: "#4a6fa5"}
  }
  m_row3: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    proj_map: {
      label: "columns: [name, age]"
      style.fill: "#d0e0ff"
      style.font-size: 13
    }
    proj_arrow: {
      label: "Column(name) + ResultRow(r1, 2)"
      style.fill: "#ffe0c0"
      style.font-size: 13
    }
    proj_map -> proj_arrow: "emits" {style.stroke: "#4a6fa5"}
  }
  note: {
    label: "Key: WHERE compiles BEFORE output columns (predicate pushdown)"
    style.fill: "#fffde0"
    style.font-size: 13
    style.italic: true
    style.border-radius: 4
  }
}
flow: Execution Flow {
  direction: down
  style.fill: "#fff0f0"
  style.stroke: "#a04040"
  style.border-radius: 8
  phase1: "INIT: pc=0, jump to OpenRead" {
    style.fill: "#e8e8e8"
  }
  phase2: "SCAN LOOP (addr 3-9)" {
    style.fill: "#c8e8c8"
    style.font-size: 14
  }
  phase2_detail: {
    shape: sql_table
    label: "Per-Row Logic"
    s1: "1. Load age from B-tree page (Column 0,1 -> r2)"
    s2: "2. Load constant 21 (Integer 21 -> r3)"
    s3: "3. NULL guard: if r2 is NULL -> skip to Next"
    s4: "4. Inverted cmp: if age <= 21 -> skip to Next"
    s5: "5. Load name (Column 0,0 -> r1) -- only if passed filter"
    s6: "6. Output r1,r2 via ResultRow callback"
    s7: "7. Next: advance cursor, loop to addr 3"
  }
  phase3: "CLEANUP: Close cursor, Halt" {
    style.fill: "#e8e8e8"
  }
  phase1 -> phase2: "OpenRead + Rewind"
  phase2 -> phase2_detail
  phase2_detail -> phase3: "cursor exhausted"
}
inversion_note: {
  label: "WHY INVERTED? The compiler emits Le (<=) instead of Gt (>).\nLe JUMPS when the condition FAILS, skipping ResultRow.\nThis avoids a separate boolean register + branch."
  style.fill: "#fff0f0"
  style.stroke: "#cc4444"
  style.font-size: 13
  style.border-radius: 6
  style.italic: true
  near: bottom-center
}
row1 -> mapping: "compile_select() walks AST once"
mapping -> flow: "VM executes flat instruction array"