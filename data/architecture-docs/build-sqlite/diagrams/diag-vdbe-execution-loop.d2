direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
ref_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  prog: {
    shape: sql_table
    label: "Bytecode Program (vdbe.c:execute) — SELECT * FROM users WHERE age > 18"
    i0: "PC 0 | OpenTable  c0        | open read cursor 0 on 'users' B-tree"
    i1: "PC 1 | Rewind     c0  p2=7  | seek first row; table empty->PC 7"
    i2: "PC 2 | Column  c0 col=1 r1  | r1 = c0.column(age)  <- HOT PATH"
    i3: "PC 3 | Integer    18   r2   | r2 = 18  (immediate constant)"
    i4: "PC 4 | Le      r1  p2=6 r2  | age<=18: JUMP to PC 6  (skip emit)"
    i5: "PC 5 | ResultRow  r3   N    | emit current row to result set"
    i6: "PC 6 | Next    c0  p2=2     | advance cursor; has_more->PC 2"
    i7: "PC 7 | Halt                 | execution complete"
  }
  btree: {
    shape: sql_table
    label: "users B-tree Leaf (page 3, 3 cells)"
    hdr: "slot | rowid | col 0: name | col 1: age"
    s0:  "  0  |   1   | Alice       |  15"
    s1:  "  1  |   2   | Bob         |  25"
    s2:  "  2  |   3   | Carol       |  10"
    sz:  "Cell: [payload_size varint][rowid varint][record bytes]"
  }
}
iter1_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  iter1_trace: {
    shape: sql_table
    label: "Iteration 1  c0=slot 0  rowid=1  age=15  WHERE FAILS — SKIP"
    style.fill: "#ffc107"
    t1: "PC 2 | Column    | r1 = 15   btree_cursor_column(c0, col=1)"
    t2: "PC 3 | Integer   | r2 = 18   OP_INTEGER p1=18 -> reg[r2]"
    t3: "PC 4 | Le        | 15 <= 18: TRUE -> JUMP fires  PC=6"
    t4: "PC 5 | BYPASSED  | ResultRow never reached this iteration"
    t5: "PC 6 | Next      | btree_cursor_next(c0): slot 0->1  has_more=1"
    t6: "jmp  | -> PC 2   | Next p2=2  re-enter loop body"
  }
  iter1_state: {
    shape: sql_table
    label: "VM State after Iteration 1"
    style.fill: "#ffc107"
    v1: "r1  | VAL_INTEGER | 15"
    v2: "r2  | VAL_INTEGER | 18"
    v3: "PC  | JUMPED      | 4 -> 6 -> 2"
    v4: "c0  | cursor slot | 1  (Bob row loaded next)"
    v5: "out | rows emitted| 0  (no output yet)"
  }
}
iter2_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  iter2_trace: {
    shape: sql_table
    label: "Iteration 2  c0=slot 1  rowid=2  age=25  WHERE PASSES — EMIT"
    style.fill: "#28a745"
    style.font-color: white
    t1: "PC 2 | Column    | r1 = 25   btree_cursor_column(c0, col=1)"
    t2: "PC 3 | Integer   | r2 = 18   OP_INTEGER p1=18 -> reg[r2]"
    t3: "PC 4 | Le        | 25 <= 18: FALSE -> no jump  fall-through PC=5"
    t4: "PC 5 | ResultRow | emit (Bob, 25) -> result  fputc row to output"
    t5: "PC 6 | Next      | btree_cursor_next(c0): slot 1->2  has_more=1"
    t6: "jmp  | -> PC 2   | Next p2=2  re-enter loop body"
  }
  iter2_state: {
    shape: sql_table
    label: "VM State after Iteration 2"
    style.fill: "#28a745"
    style.font-color: white
    v1: "r1  | VAL_INTEGER | 25"
    v2: "r2  | VAL_INTEGER | 18"
    v3: "PC  | NO JUMP     | 4 -> 5 -> 6 -> 2"
    v4: "c0  | cursor slot | 2  (Carol row loaded next)"
    v5: "out | rows emitted| 1  (Bob|25 written)"
  }
}
iter3_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  iter3_trace: {
    shape: sql_table
    label: "Iteration 3  c0=slot 2  rowid=3  age=10  WHERE FAILS + EOF"
    style.fill: "#ffc107"
    t1: "PC 2 | Column    | r1 = 10   btree_cursor_column(c0, col=1)"
    t2: "PC 3 | Integer   | r2 = 18   OP_INTEGER p1=18 -> reg[r2]"
    t3: "PC 4 | Le        | 10 <= 18: TRUE -> JUMP fires  PC=6"
    t4: "PC 5 | BYPASSED  | ResultRow never reached this iteration"
    t5: "PC 6 | Next      | btree_cursor_next(c0): slot 2->EOF  has_more=0"
    t6: "PC 7 | Halt      | Next p2=2 not taken (EOF): fall-through to Halt"
  }
  iter3_state: {
    shape: sql_table
    label: "VM State at Halt"
    style.fill: "#ffc107"
    v1: "r1  | VAL_INTEGER | 10"
    v2: "r2  | VAL_INTEGER | 18"
    v3: "PC  | JUMPED+EOF  | 4 -> 6 -> 7"
    v4: "c0  | cursor slot | EOF  (btree exhausted)"
    v5: "out | rows emitted| 1  (total: 1 of 3 rows passed)"
  }
}
result: {
  shape: sql_table
  label: "Result Set — SELECT * FROM users WHERE age > 18"
  style.fill: "#155724"
  style.font-color: white
  hdr: "name | age"
  r1:  "Bob  |  25"
  note: "Filtered: Alice (age=15) and Carol (age=10) excluded by Le jump"
}
legend: {
  shape: sql_table
  label: "Execution Key"
  l1: "Yellow header | WHERE fails: Le p2 JUMPS to PC 6, PC 5 bypassed"
  l2: "Green header  | WHERE passes: Le falls through, PC 5 ResultRow fires"
  l3: "Le inversion  | age>18 compiled as Le(<=): jump fires when NOT matching"
  l4: "Loop body     | PC 2->3->4->(5)->6->2  executes once per B-tree slot"
  l5: "Next semantics| has_more=1: jump to p2=2  has_more=0: fall-through to Halt"
}
legend.near: bottom-right
ref_row -> iter1_row: "Rewind | slot 0"
iter1_row -> iter2_row: "Next | slot 1"
iter2_row -> iter3_row: "Next | slot 2"
iter3_row -> result: "Halt | done"
iter2_row -> result: "emit | 1 row" {
  style.stroke: "#28a745"
  style.stroke-dash: 4
}