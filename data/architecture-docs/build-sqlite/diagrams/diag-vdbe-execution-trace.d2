direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: VDBE Virtual Machine Execution Trace {
  shape: text
  near: top-center
  style.font-size: 18
  style.bold: true
}

vm_state: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  vdbe_struct: {
    shape: sql_table
    label: "struct Vdbe (vdbeInt.h)"
    f0: "0x00 | int | pc // Program Counter"
    f1: "0x08 | Mem* | aMem // Register Array"
    f2: "0x10 | Op* | aOp // Instruction Array"
    f3: "0x18 | int | nOp // Total Instructions"
    f4: "0x20 | VdbeCursor** | apCsr // Table Cursors"
    sz: "Size: 168 bytes"
  }

  instruction_format: {
    shape: sql_table
    label: "struct VdbeOp (vdbe.h)"
    f0: "0x00 | uint8_t | opcode // e.g. OP_Column"
    f1: "0x01 | signed char | p4type"
    f2: "0x04 | int | p1 // Cursor ID"
    f3: "0x08 | int | p2 // Column index"
    f4: "0x0C | int | p3 // Dest register"
    f5: "0x10 | void* | p4 // Metadata"
    f6: "0x18 | int | p5"
    sz: "Size: 32 bytes"
  }
}

execution_logic: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  interpreter_loop: {
    label: "sqlite3VdbeExec Loop"
    code: |'c
      for(pc=p->pc; rc==SQLITE_OK; pc++){
        pOp = &p->aOp[pc];
        switch( pOp->opcode ){
          case OP_Column: {
            pC = p->apCsr[pOp->p1];
            rc = sqlite3VdbeColumn(pC, pOp->p2, &p->aMem[pOp->p3]);
            break;
          }
        }
      }
    '|
  }

  memory_stack: {
    shape: sql_table
    label: "VDBE Registers (aMem)"
    r0: "0x00 | Mem | Reg[0]: NULL"
    r1: "0x18 | Mem | Reg[1]: 42 (Int)"
    r2: "0x30 | Mem | Reg[2]: 'data' (Text)"
    r3: "0x48 | Mem | Reg[3]: NULL"
    total: "Total: nMem * 24 bytes"
  }
}

trace_data: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  op_trace: {
    shape: sql_table
    label: "Execution Trace (EXPLAIN output)"
    step1: "0 | Transaction | 0 | 1 | 0"
    step2: "1 | OpenRead | 0 | 2 | 0"
    step3: "2 | Rewind | 0 | 5 | 0"
    step4: "3 | Column | 0 | 1 | 2 // Target step"
    step5: "4 | Next | 0 | 3 | 0"
  }
}

# Connection logic for implementation understanding
vm_state.vdbe_struct.f2 -> vm_state.instruction_format: "Instruction fetch"
execution_logic.interpreter_loop -> trace_data.op_trace: "Fetches pc"
execution_logic.interpreter_loop -> execution_logic.memory_stack: "OP_Column writes to r2"
vm_state.vdbe_struct.f1 -> execution_logic.memory_stack: "Points to aMem"

legend: {
  near: bottom-right
  note: "VDBE is a register-based VM. Each Opcode consumes P1-P5 parameters."
}