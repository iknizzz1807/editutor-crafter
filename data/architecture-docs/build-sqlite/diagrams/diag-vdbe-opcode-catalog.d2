direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: VDBE Core Opcode Reference {
  style.font-size: 28
  style.bold: true
  style.underline: true
  near: top-center
}
instruction_format: {
  shape: sql_table
  label: "Instruction Format (vdbe.h)"
  opcode: "uint8_t  | opcode   // operation to perform"
  p1: "int      | p1       // register, cursor, or flag"
  p2: "int      | p2       // register, jump addr, or page"
  p3: "int      | p3       // register, count, or index"
  comment: "char*    | comment  // EXPLAIN annotation (debug)"
  sz: "Total: 20 bytes per instruction"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  table_ops: {
    shape: class
    label: "Table / Cursor Ops"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    +OP_OPEN_READ(p1 cursor, p2 root_page, p3 col_count): "void"
    +OP_OPEN_WRITE(p1 cursor, p2 root_page, p3 col_count): "void"
    +OP_REWIND(p1 cursor, p2 jump_if_empty): "void"
    +OP_NEXT(p1 cursor, p2 jump_to_loop): "void"
    +OP_CLOSE(p1 cursor): "void"
    +OP_SEEK_ROWID(p1 cursor, p2 rowid_reg): "void"
    +OP_NEW_ROWID(p1 cursor, p2 dest_reg): "void"
  }
  data_ops: {
    shape: class
    label: "Data / Record Ops"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    +OP_COLUMN(p1 cursor, p2 col_idx, p3 dest_reg): "void"
    +OP_ROWID(p1 cursor, p2 dest_reg): "void"
    +OP_MAKE_RECORD(p1 first_reg, p2 count, p3 dest_reg): "void"
    +OP_INSERT(p1 cursor, p2 record_reg, p3 key_reg): "void"
    +OP_DELETE(p1 cursor): "void"
    +OP_INTEGER(p1 value, p2 dest_reg): "void"
    +OP_STRING(p1 pool_idx, p2 dest_reg): "void"
    +OP_NULL(p2 dest_reg): "void"
    +OP_REAL(p1 pool_idx, p2 dest_reg): "void"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  control_ops: {
    shape: class
    label: "Control Flow Ops"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    +OP_INIT(p2 jump_addr): "void"
    +OP_HALT(p1 return_code): "void"
    +OP_GOTO(p2 target_addr): "void"
    +OP_ISNULL(p1 reg, p2 jump_addr): "void"
    +OP_NOT_NULL(p1 reg, p3 col_name_idx): "void"
    +OP_TRANSACTION(p1 op_type): "void // 0=BEGIN 1=COMMIT 2=ROLLBACK"
  }
  compare_ops: {
    shape: class
    label: "Comparison Ops (conditional jump)"
    style.fill: "#FCE4EC"
    style.stroke: "#C62828"
    +OP_EQ(p1 left_reg, p2 jump_addr, p3 right_reg): "void"
    +OP_NE(p1 left_reg, p2 jump_addr, p3 right_reg): "void"
    +OP_LT(p1 left_reg, p2 jump_addr, p3 right_reg): "void"
    +OP_LE(p1 left_reg, p2 jump_addr, p3 right_reg): "void"
    +OP_GT(p1 left_reg, p2 jump_addr, p3 right_reg): "void"
    +OP_GE(p1 left_reg, p2 jump_addr, p3 right_reg): "void"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_ops: {
    shape: class
    label: "Output Ops"
    style.fill: "#F3E5F5"
    style.stroke: "#6A1B9A"
    +OP_RESULT_ROW(p1 first_reg, p2 col_count): "void"
  }
  arith_ops: {
    shape: class
    label: "Arithmetic Ops"
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
    +OP_ADD(p1 left_reg, p2 right_reg, p3 dest_reg): "void"
    +OP_SUBTRACT(p1 left_reg, p2 right_reg, p3 dest_reg): "void"
    +OP_MULTIPLY(p1 left_reg, p2 right_reg, p3 dest_reg): "void"
    +OP_DIVIDE(p1 left_reg, p2 right_reg, p3 dest_reg): "void"
    +OP_COPY(p1 src_reg, p2 dest_reg): "void"
  }
  schema_ops: {
    shape: class
    label: "Schema / Index Ops"
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"
    +OP_CREATE_TABLE(p1 root_page_reg): "void"
    +OP_OPEN_INDEX_READ(p1 cursor, p2 root_page): "void"
    +OP_IDX_KEY(p1 cursor, p2 dest_reg): "void"
    +OP_IDX_ROWID(p1 cursor, p2 dest_reg): "void"
    +OP_OPEN_EPHEMERAL(p1 cursor): "void"
  }
}
example: {
  label: "EXPLAIN SELECT name FROM users WHERE age > 21"
  style.fill: "#263238"
  style.font-color: "#E0E0E0"
  style.border-radius: 8
  listing: {
    shape: sql_table
    label: "Bytecode Program (11 instructions)"
    style.fill: "#37474F"
    style.font-color: "#E0E0E0"
    i0: "0  | Init          | p2=1                  // jump to OpenRead"
    i1: "1  | OpenRead      | p1=0  p2=2  p3=3     // cursor 0, root pg 2, 3 cols"
    i2: "2  | Rewind        | p1=0  p2=9            // if empty jump to Close"
    i3: "3  | Column        | p1=0  p2=1  p3=2      // age -> r2"
    i4: "4  | Integer       | p1=21 p2=3             // 21 -> r3"
    i5: "5  | IsNull        | p1=2  p2=8             // skip if age NULL"
    i6: "6  | Le            | p1=2  p2=8  p3=3       // skip if age <= 21"
    i7: "7  | Column        | p1=0  p2=0  p3=1      // name -> r1"
    i8: "8  | ResultRow     | p1=1  p2=1             // output r1"
    i9: "9  | Next          | p1=0  p2=3             // loop back"
    i10: "10 | Close         | p1=0                   // close cursor"
    i11: "11 | Halt          | p1=0                   // done"
  }
}
instruction_format -> row1: "opcodes use this format" {
  style.stroke-dash: 4
  style.stroke: "#9E9E9E"
}
row1 -> row2
row2 -> row3
row3 -> example: "compiled bytecode" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
legend: {
  label: "Operand Convention"
  style.fill: "#F5F5F5"
  style.border-radius: 6
  convention: {
    shape: sql_table
    label: "p1 / p2 / p3 Meaning by Category"
    cursor_ops: "Cursor ops   | p1=cursor_id  p2=root_page or jump_addr  p3=col_count"
    data_ops: "Data ops     | p1=cursor_id  p2=col_idx or value       p3=dest_register"
    compare_ops: "Compare ops  | p1=left_reg   p2=jump_if_true           p3=right_reg"
    control_ops: "Control ops  | p1=flag       p2=target_addr            p3=unused"
    arith_ops: "Arithmetic   | p1=left_reg   p2=right_reg              p3=dest_reg"
  }
}
legend.near: bottom-right