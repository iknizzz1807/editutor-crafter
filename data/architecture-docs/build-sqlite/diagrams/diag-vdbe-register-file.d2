direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
init: "PC=1  OP_REWIND — cursor at first row" {
  style.fill: "#EDE7F6"
  style.border-radius: 6
  rf_init: {
    shape: sql_table
    label: "Register File — initial state (vdbe.c)"
    r0: "r0 | VAL_NULL | reserved — never used"
    r1: "r1 | VAL_NULL | uninitialized"
    r2: "r2 | VAL_NULL | uninitialized"
    r3: "r3 | VAL_NULL | uninitialized"
  }
}
col_age: "PC=2  OP_COLUMN  cursor=0  col_idx=2  dest=r1" {
  style.stroke: "#3949AB"
  style.stroke-width: 3
  style.border-radius: 6
  rf: {
    shape: sql_table
    label: "Register File after OP_COLUMN (age)"
    r0: "r0 | VAL_NULL    | reserved"
    r1: "r1 | VAL_INTEGER | 25    WRITTEN — age from leaf cell"
    r2: "r2 | VAL_NULL    | uninitialized"
    r3: "r3 | VAL_NULL    | uninitialized"
  }
  impl: "btree_cursor_column(cur, 2, &reg[1])" {
    style.fill: "#C5CAE9"
    style.border-radius: 4
    style.font-size: 12
  }
}
load_const: "PC=3  OP_INTEGER  p1=18  dest=r2" {
  style.stroke: "#5C6BC0"
  style.stroke-width: 3
  style.border-radius: 6
  rf: {
    shape: sql_table
    label: "Register File after OP_INTEGER"
    r0: "r0 | VAL_NULL    | reserved"
    r1: "r1 | VAL_INTEGER | 25    (age — unchanged)"
    r2: "r2 | VAL_INTEGER | 18    WRITTEN — instr->p1"
    r3: "r3 | VAL_NULL    | uninitialized"
  }
  impl: "reg[2].type=VAL_INTEGER; reg[2].i=18" {
    style.fill: "#C5CAE9"
    style.border-radius: 4
    style.font-size: 12
  }
}
cmp_op: "PC=4  OP_LE  ra=r1  rb=r2  jump=PC7" {
  shape: diamond
  style.fill: "#E65100"
  style.font-color: white
  style.stroke: "#BF360C"
  style.stroke-width: 2
}
cmp_reads: "OP_LE reads r1 and r2 — no register written" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.border-radius: 6
  how: {
    shape: sql_table
    label: "Comparison dispatch (vdbe.c)"
    step1: "READ  r1 = 25  (age from cursor)"
    step2: "READ  r2 = 18  (immediate constant)"
    step3: "cmp = value_compare(reg[1], reg[2]) = +1"
    step4: "cmp > 0 — NOT LE — fall-through to PC=5"
    step5: "cmp <= 0 — vm.pc = jump_addr (PC=7 OP_NEXT)"
  }
}
branch_skip: "SKIP — age <= 18 — row excluded by WHERE" {
  style.fill: "#B71C1C"
  style.font-color: white
  style.border-radius: 6
  note: "Jump to PC=7 (OP_NEXT). r3 stays NULL. Row not emitted." {
    style.fill: "#C62828"
    style.font-color: white
    style.border-radius: 4
    style.font-size: 12
  }
}
branch_match: "MATCH — age > 18 — row passes WHERE filter" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.border-radius: 6
  note: "Fall-through to PC=5. r1 and r2 still hold their values." {
    style.fill: "#C8E6C9"
    style.border-radius: 4
    style.font-size: 12
  }
}
col_name: "PC=5  OP_COLUMN  cursor=0  col_idx=1  dest=r3" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.border-radius: 6
  rf: {
    shape: sql_table
    label: "Register File after OP_COLUMN (name)"
    r0: "r0 | VAL_NULL    | reserved"
    r1: "r1 | VAL_INTEGER | 25    (age — unchanged)"
    r2: "r2 | VAL_INTEGER | 18    (constant — unchanged)"
    r3: "r3 | VAL_TEXT    | Alice WRITTEN — name from leaf cell"
  }
  impl: "btree_cursor_column(cur, 1, &reg[3])" {
    style.fill: "#C8E6C9"
    style.border-radius: 4
    style.font-size: 12
  }
  zero_copy: "r3.text.data points into pinned page (zero-copy)" {
    style.fill: "#A5D6A7"
    style.border-radius: 4
    style.font-size: 11
    style.italic: true
  }
}
result_row: "PC=6  OP_RESULT_ROW  start=r3  count=1" {
  style.fill: "#1B5E20"
  style.font-color: white
  style.border-radius: 6
  emit: "output: reg[3].text.data = \"Alice\" sent to caller" {
    style.fill: "#2E7D32"
    style.font-color: white
    style.border-radius: 4
    style.font-size: 12
  }
}
next_op: "PC=7  OP_NEXT  cursor=0  loop_to=PC2" {
  shape: oval
  style.fill: "#37474F"
  style.font-color: white
  style.stroke: "#263238"
  style.stroke-width: 2
}
legend: "Color Semantics" {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.border-radius: 8
  style.stroke: "#9E9E9E"
  blue_rule: "Blue border — register WRITE (OP_COLUMN, OP_INTEGER)" {
    style.font-color: "#3949AB"
    style.bold: true
  }
  orange_rule: "Orange — conditional branch opcode (OP_LE, OP_GT, OP_EQ)" {
    style.font-color: "#E65100"
    style.bold: true
  }
  red_rule: "Red — row excluded (predicate FALSE or NULL)" {
    style.font-color: "#B71C1C"
    style.bold: true
  }
  green_rule: "Green — row passes WHERE predicate" {
    style.font-color: "#2E7D32"
    style.bold: true
  }
  dash_rule: "Dashed arrow — back-edge (loop) or skip jump" {
    style.font-color: "#607D8B"
    style.bold: true
  }
}
init -> col_age: "OP_COLUMN fires"
col_age -> load_const: "OP_INTEGER fires"
load_const -> cmp_op: "OP_LE fires"
cmp_op -> cmp_reads: "inspect r1 and r2"
cmp_reads -> branch_skip: "r1 <= r2" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
  style.font-color: "#B71C1C"
}
cmp_reads -> branch_match: "r1 > r2" {
  style.stroke: "#2E7D32"
  style.font-color: "#2E7D32"
}
branch_match -> col_name: "OP_COLUMN fires"
col_name -> result_row: "OP_RESULT_ROW"
result_row -> next_op: "OP_NEXT"
branch_skip -> next_op: "jump to OP_NEXT" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
  style.font-color: "#B71C1C"
}
next_op -> col_age: "has_more=1 — loop back" {
  style.stroke: "#607D8B"
  style.stroke-dash: 4
  style.font-color: "#607D8B"
}