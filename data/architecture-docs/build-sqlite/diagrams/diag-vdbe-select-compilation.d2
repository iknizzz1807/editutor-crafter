direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
panels: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ast: "Abstract Syntax Tree  (parser.h  —  AstNode)" {
    direction: down
    style.fill: "#E8EAF6"
    style.stroke: "#5C6BC0"
    style.border-radius: 6
    select_node: "NODE_SELECT" {
      style.fill: "#283593"
      style.font-color: white
      style.bold: true
      style.border-radius: 4
    }
    col_name: "NODE_IDENTIFIER\nname  (columns[0])" {
      style.fill: "#1B5E20"
      style.font-color: white
      style.border-radius: 4
    }
    from_ref: "FROM  users\n(table_name  string)" {
      style.fill: "#4A148C"
      style.font-color: white
      style.border-radius: 4
    }
    where_gt: "NODE_BINARY_EXPR\n.op = TOKEN_GT" {
      style.fill: "#B71C1C"
      style.font-color: white
      style.border-radius: 4
    }
    age_id: "NODE_IDENTIFIER\nage  (binary.left)" {
      style.fill: "#BF360C"
      style.font-color: white
      style.border-radius: 4
    }
    lit_21: "NODE_LITERAL_INT\n.value = 21  (binary.right)" {
      style.fill: "#37474F"
      style.font-color: white
      style.border-radius: 4
    }
    select_node -> col_name: "columns[0]"
    select_node -> from_ref: "table_name"
    select_node -> where_gt: "where_expr"
    where_gt -> age_id: "binary.left"
    where_gt -> lit_21: "binary.right"
  }
  code: "VDBE Bytecode  —  compile_select()  (compiler.c)" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
    style.border-radius: 6
    i0: "0  OpenTable    cursor=0   p4=users" {
      style.font: mono
      style.fill: "#FFFDE7"
      style.stroke: "#4A148C"
      style.border-radius: 2
    }
    i1: "1  Rewind       cursor=0   p2=8(Halt)" {
      style.font: mono
      style.fill: "#FFFDE7"
      style.stroke: "#283593"
      style.border-radius: 2
    }
    i2: "2  Column       cursor=0   col_idx=1   dest=r1" {
      style.font: mono
      style.fill: "#FBE9E7"
      style.stroke: "#BF360C"
      style.border-radius: 2
    }
    i3: "3  Integer      val=21   dest=r2" {
      style.font: mono
      style.fill: "#ECEFF1"
      style.stroke: "#37474F"
      style.border-radius: 2
    }
    i4: "4  Gt           r1   p2=7(Next)   r2" {
      style.font: mono
      style.fill: "#FFEBEE"
      style.stroke: "#B71C1C"
      style.border-radius: 2
    }
    i5: "5  Column       cursor=0   col_idx=0   dest=r3" {
      style.font: mono
      style.fill: "#E8F5E9"
      style.stroke: "#1B5E20"
      style.border-radius: 2
    }
    i6: "6  ResultRow    start=r3   count=1" {
      style.font: mono
      style.fill: "#FFFDE7"
      style.stroke: "#283593"
      style.border-radius: 2
    }
    i7: "7  Next         cursor=0   p2=2(Column)" {
      style.font: mono
      style.fill: "#FFFDE7"
      style.stroke: "#283593"
      style.border-radius: 2
    }
    i8: "8  Halt" {
      style.font: mono
      style.fill: "#FFFDE7"
      style.stroke: "#283593"
      style.border-radius: 2
    }
  }
}
panels.ast.from_ref -> panels.code.i0: "emit OpenTable" {
  style.stroke: "#4A148C"
  style.font-color: "#4A148C"
  style.font-size: 11
}
panels.ast.select_node -> panels.code.i1: "emit Rewind" {
  style.stroke: "#283593"
  style.font-color: "#283593"
  style.font-size: 11
}
panels.ast.age_id -> panels.code.i2: "col_idx=1 (age)" {
  style.stroke: "#BF360C"
  style.font-color: "#BF360C"
  style.font-size: 11
}
panels.ast.lit_21 -> panels.code.i3: "emit Integer" {
  style.stroke: "#37474F"
  style.font-color: "#37474F"
  style.font-size: 11
}
panels.ast.where_gt -> panels.code.i4: "emit Gt" {
  style.stroke: "#B71C1C"
  style.font-color: "#B71C1C"
  style.font-size: 11
}
panels.ast.col_name -> panels.code.i5: "col_idx=0 (name)" {
  style.stroke: "#1B5E20"
  style.font-color: "#1B5E20"
  style.font-size: 11
}
panels.ast.select_node -> panels.code.i6: "emit ResultRow" {
  style.stroke: "#283593"
  style.font-color: "#283593"
  style.font-size: 11
}
panels.ast.select_node -> panels.code.i7: "emit Next" {
  style.stroke: "#283593"
  style.font-color: "#283593"
  style.font-size: 11
}
panels.ast.select_node -> panels.code.i8: "emit Halt" {
  style.stroke: "#283593"
  style.font-color: "#283593"
  style.font-size: 11
}