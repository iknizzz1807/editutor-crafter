direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row_actors: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  writer: "Writer Process (txn_commit)" {
    direction: down
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.border-radius: 6
    write_steps: {
      shape: sql_table
      label: "WAL Write Protocol"
      s1: "1 | BEGIN → acquire write lock"
      s2: "2 | modify pages in buffer pool"
      s3: "3 | wal_write_frame(page_no, data, non-commit)"
      s4: "4 | wal_write_frame(page_no, data, COMMIT)"
      s5: "5 | fsync(wal_fd)  ← single fsync"
      s6: "6 | release write lock"
      s7: "NO writes to .db file during txn"
    }
  }
  reader: "Reader Process (snapshot isolation)" {
    direction: down
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
    style.border-radius: 6
    read_steps: {
      shape: sql_table
      label: "WAL Read Protocol"
      s1: "1 | end_frame = wal_begin_read()"
      s2: "2 | buffer_pool_fetch(page_no)"
      s3: "3 | wal_find_frame(page_no, end_frame)"
      s4: "4 | if found → read WAL frame"
      s5: "5 | if not found → read main .db"
      s6: "6 | wal_end_read(end_frame)"
      s7: "NO locks between reader and writer"
    }
  }
  checkpoint_proc: "Checkpoint Process (PRAGMA wal_checkpoint)" {
    direction: down
    style.fill: "#fef9c3"
    style.stroke: "#ca8a04"
    style.border-radius: 6
    ckpt_steps: {
      shape: sql_table
      label: "Checkpoint Protocol"
      s1: "1 | acquire write lock"
      s2: "2 | limit = min(frame_count, min_reader_snapshot)"
      s3: "3 | for f in 0..limit: copy WAL frame to .db"
      s4: "4 | fsync(db_fd)"
      s5: "5 | increment checkpoint_seq, rotate salts"
      s6: "6 | reset WAL index, frame_count = 0"
      s7: "7 | release write lock"
    }
  }
}
row_files: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wal_file: ".db-wal  (Write-Ahead Log File)" {
    direction: down
    style.fill: "#f0f9ff"
    style.stroke: "#0284c7"
    style.border-radius: 6
    wal_hdr: {
      shape: sql_table
      label: "WAL Header (32 bytes)"
      f0: "0x00 | uint32 | magic = 0x377f0682"
      f1: "0x04 | uint32 | file_format = 3007000"
      f2: "0x08 | uint32 | page_size (e.g. 4096)"
      f3: "0x0C | uint32 | checkpoint_seq"
      f4: "0x10 | uint32 | salt1 (random, rotates on ckpt)"
      f5: "0x14 | uint32 | salt2 (random, rotates on ckpt)"
      f6: "0x18 | uint32 | cksum1 (cumulative header)"
      f7: "0x1C | uint32 | cksum2 (cumulative header)"
    }
    frame_n: {
      shape: sql_table
      label: "WAL Frame N  (24 + PAGE_SIZE bytes)"
      h0: "Hdr +0x00 | uint32      | page_no (1-based)"
      h1: "Hdr +0x04 | uint32      | db_size (0=non-commit, N=commit)"
      h2: "Hdr +0x08 | uint32      | salt1  (must match header)"
      h3: "Hdr +0x0C | uint32      | salt2  (must match header)"
      h4: "Hdr +0x10 | uint32      | cksum1 (cumulative running)"
      h5: "Hdr +0x14 | uint32      | cksum2 (cumulative running)"
      d0: "Data +0x18 | uint8[4096] | complete page image"
      note: "Offset = 32 + N * (24 + PAGE_SIZE)"
    }
    wal_props: {
      shape: sql_table
      label: "Sequential Append Properties"
      p0: "Writer appends frames at end of file"
      p1: "Random DB writes → sequential WAL writes"
      p2: "Cumulative checksum chains all frames"
      p3: "Salt rotation invalidates old-generation frames"
      p4: "Commit frame: db_size > 0, marks txn boundary"
    }
  }
  wal_index: ".db-shm  (WAL-Index / Shared Memory)" {
    direction: down
    style.fill: "#fdf4ff"
    style.stroke: "#9333ea"
    style.border-radius: 6
    idx_struct: {
      shape: sql_table
      label: "WalIndex Structure"
      f0: "slots[65536]    | WalIndexEntry[] | open-addr hash map"
      f1: "  .page_no      | uint32          | UINT32_MAX = empty"
      f2: "  .frame_idx    | uint32          | most recent frame"
      f3: "frame_count     | int             | total frames in WAL"
      f4: "write_lock      | int             | 1 = writer active"
      f5: "min_reader_snap | int             | oldest active snapshot"
    }
    idx_lookup: {
      shape: sql_table
      label: "Snapshot Isolation Lookup"
      s0: "end_frame = wal_begin_read() → frame_count snapshot"
      s1: "hash slot = (page_no * 2654435761) & 0xFFFF"
      s2: "if slots[h].page_no == page_no:"
      s3: "  if frame_idx < end_frame → return frame_idx"
      s4: "  else → scan WAL backward (frame beyond snapshot)"
      s5: "if empty slot → return -1 (not in WAL)"
      s6: "No locks needed — integer compare only"
    }
    idx_invariants: {
      shape: sql_table
      label: "WAL Index Invariants"
      i0: "Index only contains COMMITTED frames"
      i1: "Writer updates index AFTER wal_write_frame"
      i2: "Checkpoint clears index (memset UINT32_MAX)"
      i3: "Recovery rebuilds index by scanning WAL file"
    }
  }
}
row_maindb: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  main_db: ".db  (Main Database — last checkpointed state)" {
    direction: down
    style.fill: "#f0fdf4"
    style.stroke: "#15803d"
    style.border-radius: 6
    db_layout: {
      shape: sql_table
      label: "Database File Layout"
      p0: "Page 0 (byte     0) | DB header (100 bytes) + root page"
      p1: "Page 1 (byte  4096) | sqlite_master B-tree root"
      p2: "Page N (byte N*4K)  | B-tree pages for user tables"
      note0: "In WAL mode: file is STALE until checkpoint runs"
      note1: "Readers must check WAL before reading this file"
    }
    db_contrast: {
      shape: sql_table
      label: "WAL vs Rollback Journal"
      w0: "WAL | writer appends to .db-wal only (never touches .db mid-txn)"
      w1: "WAL | readers check WAL index first, then .db"
      w2: "WAL | 1 fsync at COMMIT (WAL only)"
      w3: "WAL | readers and writer run concurrently (no locks)"
      w4: "WAL | .db updated lazily at checkpoint"
      j0: "RJ  | writer modifies .db directly (after journaling old pages)"
      j1: "RJ  | readers go to .db directly (always current)"
      j2: "RJ  | 2 fsyncs at COMMIT (journal + .db)"
      j3: "RJ  | writer holds exclusive lock, blocks all readers"
      j4: "RJ  | .db-journal deleted on COMMIT"
    }
  }
}
row_actors.writer -> row_files.wal_file: "append frames" {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
  style.animated: true
}
row_actors.reader -> row_files.wal_index: "wal_find_frame" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
}
row_files.wal_index -> row_files.wal_file: "frame offset" {
  style.stroke: "#9333ea"
  style.stroke-dash: 4
}
row_files.wal_file -> row_maindb.main_db: "checkpoint copy" {
  style.stroke: "#ca8a04"
  style.stroke-width: 2
  style.animated: true
}
row_actors.checkpoint_proc -> row_files.wal_file: "read frames" {
  style.stroke: "#ca8a04"
  style.stroke-dash: 3
}
row_actors.checkpoint_proc -> row_maindb.main_db: "pwrite pages" {
  style.stroke: "#ca8a04"
  style.stroke-width: 2
}
row_actors.reader -> row_maindb.main_db: "fallback read" {
  style.stroke: "#16a34a"
  style.stroke-dash: 5
}