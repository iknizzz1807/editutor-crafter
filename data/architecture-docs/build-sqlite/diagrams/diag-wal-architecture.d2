direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 5
  }
}
row_actors: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  writer: "Writer Connection" {
    direction: down
    style.fill: "#1a3a5c"
    style.stroke: "#4a9eff"
    style.border-radius: 6
    style.font-color: white
    tx: {
      shape: class
      label: "Write Transaction (wal.c)"
      +begin(): "void"
      +write_frame(page, data): "int"
      +commit(): "int"
      +rollback(): "void"
    }
  }
  reader: "Reader Connection" {
    direction: down
    style.fill: "#1a4a2a"
    style.stroke: "#4aff7a"
    style.border-radius: 6
    style.font-color: white
    snap: {
      shape: class
      label: "Read Snapshot (wal.c)"
      +max_frame: "int"
      +begin_read(max_frame): "int"
      +fetch_page(page_id): "uint8_t*"
      +end_read(): "void"
    }
  }
  checkpoint: "Checkpoint Process" {
    direction: down
    style.fill: "#3a1a4a"
    style.stroke: "#cc88ff"
    style.border-radius: 6
    style.font-color: white
    ckpt: {
      shape: class
      label: "Checkpoint (wal.c)"
      +safe_frame: "int"
      +pages_written: "int"
      +run(pool, sm): "int"
      +auto_trigger(threshold): "void"
    }
  }
}
row_wal_layer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wal_file: "WAL File (.db-wal)" {
    direction: down
    style.fill: "#2a1a0a"
    style.stroke: "#ff8833"
    style.border-radius: 4
    wal_header: {
      shape: sql_table
      label: "WalHeader (wal.h)"
      f0: "0x00 | uint32_t | magic = 0x377F0682"
      f1: "0x04 | uint32_t | format_version"
      f2: "0x08 | uint32_t | page_size = 4096"
      f3: "0x0C | uint32_t | checkpoint_seq"
      f4: "0x10 | uint32_t | salt1 (changes per txn)"
      f5: "0x14 | uint32_t | salt2"
      f6: "0x18 | uint32_t | checksum1 (cumulative)"
      f7: "0x1C | uint32_t | checksum2 (cumulative)"
      sz: "Total: 32 bytes"
    }
    frame_layout: {
      shape: sql_table
      label: "WalFrameHeader (wal.h) — repeated N times"
      f0: "0x00 | uint32_t | page_id"
      f1: "0x04 | uint32_t | db_size (>0 = commit marker)"
      f2: "0x08 | uint32_t | salt1 (must match header)"
      f3: "0x0C | uint32_t | salt2 (must match header)"
      f4: "0x10 | uint32_t | checksum1 (cumulative chain)"
      f5: "0x14 | uint32_t | checksum2 (cumulative chain)"
      f6: "0x18 | uint8_t[4096] | page_data"
      sz: "Frame size: 24 + 4096 = 4120 bytes"
    }
    append_note: {
      shape: rectangle
      label: "APPEND-ONLY: never overwrite existing frames"
      style.fill: "#3a2a0a"
      style.stroke: "#ff8833"
      style.stroke-dash: 4
      style.font-color: "#ffcc88"
    }
  }
  wal_index: "WAL Index / Shared Memory (.db-shm)" {
    direction: down
    style.fill: "#1a2a3a"
    style.stroke: "#88ccff"
    style.border-radius: 4
    index_struct: {
      shape: sql_table
      label: "WalIndex in-memory (wal.c)"
      f0: "wal_index[page_id] | int    | latest frame# for page"
      f1: "wal_index_size     | int    | capacity of array"
      f2: "frame_count        | int    | total frames in WAL"
      f3: "checksum1          | uint32 | running state"
      f4: "checksum2          | uint32 | running state"
      f5: "min_reader_frame   | int    | oldest reader snapshot"
      sz: "Lookup: O(1) — direct array index by page_id"
    }
    snap_mgr: {
      shape: sql_table
      label: "SnapshotManager (wal.c)"
      f0: "readers[i].max_frame | int  | snapshot boundary"
      f1: "readers[i].is_active | bool | slot occupied"
      f2: "writer_max_frame     | int  | latest commit frame"
      f3: "MAX_READERS = 32     | const| max concurrency"
      sz: "Checkpoint safe up to: min(all active max_frame)"
    }
    lookup_note: {
      shape: rectangle
      label: "wal_index_get(page_id, max_frame): returns frame# or -1"
      style.fill: "#0a1a2a"
      style.stroke: "#88ccff"
      style.stroke-dash: 4
      style.font-color: "#aaddff"
    }
  }
}
row_db_file: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  spacer_left: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 200
  }
  main_db: "Main Database File (.db)" {
    direction: down
    style.fill: "#1a2a1a"
    style.stroke: "#44aa44"
    style.border-radius: 4
    db_state: {
      shape: rectangle
      label: "FROZEN during WAL-mode writes\nContains last checkpointed state\nAlways consistent — safe to read directly"
      style.fill: "#0a1a0a"
      style.stroke: "#44aa44"
      style.font-color: "#88cc88"
    }
    page_layout: {
      shape: sql_table
      label: "B-tree Page Layout (btree.h)"
      f0: "page 1 | sqlite_master catalog root"
      f1: "page 2 | first user table root"
      f2: "page N | ... more B-tree pages ..."
      f3: "page M | index B+tree root"
      sz: "Each page: 4096 bytes, managed by buffer pool"
    }
  }
}
row_actors.writer -> row_wal_layer.wal_file: "1. append frame | sequential write" {
  style.stroke: "#ff8833"
  style.stroke-width: 3
  style.animated: true
}
row_actors.writer -> row_wal_layer.wal_index: "2. wal_index_set(page_id, frame#)" {
  style.stroke: "#88ccff"
  style.stroke-width: 2
}
row_actors.writer -> row_wal_layer.wal_index: "3. commit: fsync WAL, writer_max_frame++" {
  style.stroke: "#ffcc44"
  style.stroke-dash: 5
}
row_actors.reader -> row_wal_layer.wal_index: "4. wal_index_get(page_id, max_frame)" {
  style.stroke: "#4aff7a"
  style.stroke-width: 2
}
row_wal_layer.wal_index -> row_wal_layer.wal_file: "5a. frame# found → pread(frame_offset)" {
  style.stroke: "#88ccff"
  style.stroke-dash: 3
}
row_wal_layer.wal_index -> row_db_file.main_db: "5b. frame# = -1 → fall back to .db" {
  style.stroke: "#44aa44"
  style.stroke-dash: 5
}
row_actors.checkpoint -> row_wal_layer.wal_file: "6. pread frames 0..safe_frame" {
  style.stroke: "#cc88ff"
  style.stroke-width: 2
}
row_actors.checkpoint -> row_db_file.main_db: "7. pwrite(page_id × 4096) | random I/O" {
  style.stroke: "#cc88ff"
  style.stroke-width: 3
  style.animated: true
}
row_actors.checkpoint -> row_wal_layer.wal_index: "8. clear index, frame_count = 0" {
  style.stroke: "#cc88ff"
  style.stroke-dash: 4
}
legend: {
  near: bottom-right
  style.fill: "#111111"
  style.stroke: "#555555"
  style.border-radius: 4
  title: "Legend" {
    style.bold: true
    style.font-color: white
  }
  w: "Orange  — Writer: append frames to WAL" {
    style.font-color: "#ff8833"
  }
  r: "Green   — Reader: check index, fall back to .db" {
    style.font-color: "#4aff7a"
  }
  c: "Purple  — Checkpoint: copy WAL → main DB" {
    style.font-color: "#cc88ff"
  }
  b: "Blue    — WAL Index: O(1) page→frame lookup" {
    style.font-color: "#88ccff"
  }
  key: "KEY: Readers NEVER block Writers in WAL mode" {
    style.font-color: "#ffdd44"
    style.bold: true
  }
}