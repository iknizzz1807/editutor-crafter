direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 5
  }
}
header: "WAL: Concurrent Readers + Writer vs. Rollback Journal Serialization" {
  style.fill: "#1565C0"
  style.font-color: white
  style.stroke: "#0D47A1"
  style.border-radius: 6
  style.bold: true
  style.font-size: 13
}
main_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  journal_col: "ROLLBACK JOURNAL MODE" {
    direction: down
    style.fill: "#FBE9E7"
    style.stroke: "#BF360C"
    style.stroke-width: 2
    style.border-radius: 8
    jt0: "T0: Initial State" {
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.border-radius: 4
    }
    jt1: "T1: Writer W — BEGIN" {
      style.fill: "#FF8A65"
      style.stroke: "#D84315"
      style.border-radius: 4
    }
    jt1_lock: "W acquires LOCK_EX on db file" {
      style.fill: "#E64A19"
      style.font-color: white
      style.stroke: "#BF360C"
      style.border-radius: 4
    }
    jt2: "T2: Reader R1 arrives" {
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.border-radius: 4
    }
    jt2_block: "R1 BLOCKED — waits for LOCK_EX" {
      style.fill: "#B71C1C"
      style.font-color: white
      style.stroke: "#7F0000"
      style.border-radius: 4
    }
    jt3: "T3: Reader R2 arrives" {
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.border-radius: 4
    }
    jt3_block: "R2 BLOCKED — waits for LOCK_EX" {
      style.fill: "#B71C1C"
      style.font-color: white
      style.stroke: "#7F0000"
      style.border-radius: 4
    }
    jt4: "T4: Writer W — COMMIT" {
      style.fill: "#FF8A65"
      style.stroke: "#D84315"
      style.border-radius: 4
    }
    jt4_unlock: "LOCK_EX released" {
      style.fill: "#FFAB91"
      style.stroke: "#BF360C"
      style.border-radius: 4
    }
    jt5: "T5: R1 and R2 proceed (serial, sequential)" {
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.border-radius: 4
    }
    j_verdict: "1 writer OR N readers — never both" {
      style.fill: "#FF7043"
      style.font-color: white
      style.stroke: "#BF360C"
      style.border-radius: 4
    }
    jt0 -> jt1: "BEGIN txn"
    jt1 -> jt1_lock: "flock(LOCK_EX)"
    jt1_lock -> jt2
    jt2 -> jt2_block: "flock() blocks"
    jt2_block -> jt3
    jt3 -> jt3_block: "flock() blocks"
    jt3_block -> jt4: "W finishes writes"
    jt4 -> jt4_unlock: "flock(LOCK_UN)"
    jt4_unlock -> jt5: "R1, R2 unblock"
    jt5 -> j_verdict
  }
  wal_col: "WAL MODE" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#1B5E20"
    style.stroke-width: 2
    style.border-radius: 8
    wt0: "T0: Initial State" {
      shape: sql_table
      label: "WAL State at T0"
      frame_count: "wal_frames: 0"
      wal_file: "wal_file: [header only]"
      db_file: "db_file: 100 committed pages"
    }
    wt1_w: "T1: Writer W — BEGIN WRITE TXN" {
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
      style.border-radius: 4
    }
    wt1_r1: "T1: Reader R1 starts — wal_begin_read()" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.border-radius: 4
    }
    wt1_snap: "R1 snapshot: end_frame = 0  (sees no WAL frames yet)" {
      style.fill: "#81C784"
      style.stroke: "#1B5E20"
      style.border-radius: 4
    }
    wt2_w: "T2: W appends frame[0]  (page_no=42, non-commit)" {
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
      style.border-radius: 4
    }
    wt2_r1: "T2: R1 reads page 42  wal_find_frame(42, end_frame=0)" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.border-radius: 4
    }
    wt2_detail: "WAL index: page42 → frame[0]  |  frame[0] index 0 ≥ end_frame 0 → NOT visible to R1" {
      style.fill: "#DCEDC8"
      style.stroke: "#558B2F"
      style.border-radius: 4
    }
    wt2_r1_result: "R1: wal_find_frame returns -1 → reads page 42 from main DB (pre-write snapshot)" {
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      style.border-radius: 4
    }
    wt3_w: "T3: W appends frame[1]  (page_no=77, COMMIT db_size=100)" {
      style.fill: "#66BB6A"
      style.stroke: "#1B5E20"
      style.border-radius: 4
    }
    wt3_r2: "T3: Reader R2 starts — wal_begin_read()" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.border-radius: 4
    }
    wt3_snap: "R2 snapshot: end_frame = 2  (sees frame[0] and frame[1], txn committed)" {
      style.fill: "#81C784"
      style.stroke: "#1B5E20"
      style.border-radius: 4
    }
    wt3_detail: "WAL index: page42 → frame[0],  page77 → frame[1]  |  both frames < end_frame 2 → VISIBLE to R2" {
      style.fill: "#DCEDC8"
      style.stroke: "#558B2F"
      style.border-radius: 4
    }
    wt4_r1_read: "T4: R1 reads page 42 (snap=0) → main DB  [pre-commit value]" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.border-radius: 4
    }
    wt4_r2_read: "T4: R2 reads page 42 (snap=2) → WAL frame[0]  [post-commit value]" {
      style.fill: "#1565C0"
      style.font-color: white
      style.stroke: "#0D47A1"
      style.border-radius: 4
    }
    wt4_w_cont: "T4: W continues appending next txn frames — no mutex needed" {
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
      style.border-radius: 4
    }
    w_verdict: "1 writer AND N readers simultaneously — no file-level lock contention" {
      style.fill: "#2E7D32"
      style.font-color: white
      style.stroke: "#1B5E20"
      style.border-radius: 4
    }
    wt0 -> wt1_w: "W acquires WAL write lock (only 1 writer at a time)"
    wt0 -> wt1_r1: "R1 arrives concurrently"
    wt1_r1 -> wt1_snap: "snapshot captured"
    wt1_w -> wt2_w: "append"
    wt1_snap -> wt2_r1: "R1 queries WAL index"
    wt2_r1 -> wt2_detail: "index lookup"
    wt2_detail -> wt2_r1_result: "not visible → fallback"
    wt2_w -> wt3_w: "commit write"
    wt2_r1_result -> wt3_r2: "R2 arrives"
    wt3_r2 -> wt3_snap: "snapshot captured"
    wt3_snap -> wt3_detail: "both frames visible"
    wt3_w -> wt4_w_cont
    wt3_detail -> wt4_r1_read: "R1 still active (old snap)"
    wt3_detail -> wt4_r2_read: "R2 active (new snap)"
    wt4_r1_read -> w_verdict
    wt4_r2_read -> w_verdict
    wt4_w_cont -> w_verdict
  }
}
legend: "Key Insight" {
  direction: right
  style.fill: "#ECEFF1"
  style.stroke: "#546E7A"
  style.border-radius: 6
  leg_blocked: "BLOCKED (journal mode)" {
    style.fill: "#B71C1C"
    style.font-color: white
    style.stroke: "#7F0000"
    style.border-radius: 4
  }
  leg_writer: "Writer active (WAL)" {
    style.fill: "#2E7D32"
    style.font-color: white
    style.stroke: "#1B5E20"
    style.border-radius: 4
  }
  leg_reader: "Reader active (WAL)" {
    style.fill: "#1565C0"
    style.font-color: white
    style.stroke: "#0D47A1"
    style.border-radius: 4
  }
  leg_snap: "Snapshot boundary" {
    style.fill: "#F57F17"
    style.font-color: white
    style.stroke: "#E65100"
    style.border-radius: 4
  }
  leg_insight: "WAL appends to a separate file; readers use end_frame snapshots for isolation; no reader ever blocks a writer." {
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.border-radius: 4
  }
}
header -> main_row
main_row -> legend