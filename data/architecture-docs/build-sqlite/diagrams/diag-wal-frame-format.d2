direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## WAL Frame Format — Byte-Level Layout & Integrity Chain
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wal_file: "WAL File (<db>.db-wal)" {
    direction: down
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    style.border-radius: 6
    wal_hdr: {
      shape: sql_table
      label: "WAL File Header (32 bytes)"
      style.fill: "#7986CB"
      style.font-color: white
      h0: "0x00 | uint32_t | magic = 0x377F0682"
      h1: "0x04 | uint32_t | format_version = 3007000"
      h2: "0x08 | uint32_t | page_size (e.g. 4096)"
      h3: "0x0C | uint32_t | checkpoint_seq"
      h4: "0x10 | uint32_t | salt1  (random, per-txn cycle)"
      h5: "0x14 | uint32_t | salt2  (random, per-txn cycle)"
      h6: "0x18 | uint32_t | checksum1 (of header fields)"
      h7: "0x1C | uint32_t | checksum2 (of header fields)"
    }
    frame0: {
      shape: sql_table
      label: "Frame 0 — non-commit (page write)"
      style.fill: "#5C6BC0"
      style.font-color: white
      style.stroke: "#3F51B5"
      fh0: "0x00 | uint32_t | page_id"
      fh1: "0x04 | uint32_t | db_size = 0  ← non-commit"
      fh2: "0x08 | uint32_t | salt1  (must match header)"
      fh3: "0x0C | uint32_t | salt2  (must match header)"
      fh4: "0x10 | uint32_t | checksum1  (cumulative)"
      fh5: "0x14 | uint32_t | checksum2  (cumulative)"
      fd0: "0x18 | uint8_t[4096] | raw page data"
      fz:  "Frame total: 24 + 4096 = 4120 bytes"
    }
    frameN: {
      shape: sql_table
      label: "Frame N — COMMIT FRAME"
      style.fill: "#43A047"
      style.font-color: white
      style.stroke: "#2E7D32"
      cf0: "0x00 | uint32_t | page_id"
      cf1: "0x04 | uint32_t | db_size > 0  ← COMMIT MARKER"
      cf2: "0x08 | uint32_t | salt1"
      cf3: "0x0C | uint32_t | salt2"
      cf4: "0x10 | uint32_t | checksum1  (cumulative)"
      cf5: "0x14 | uint32_t | checksum2  (cumulative)"
      cfd: "0x18 | uint8_t[4096] | raw page data"
      cfz: "db_size = database page count at commit time"
    }
  }
  frame_zoom: "Single Frame — Exploded View" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#F57F17"
    style.border-radius: 6
    frame_hdr_detail: {
      shape: sql_table
      label: "WalFrameHeader — 24 bytes (wal.h)"
      style.fill: "#FFA726"
      style.font-color: white
      f0: "0x00 | uint32_t | page_id      // page being written"
      f1: "0x04 | uint32_t | db_size      // 0 = non-commit"
      f2: "0x08 | uint32_t | salt1        // binds frame to txn"
      f3: "0x0C | uint32_t | salt2        // binds frame to txn"
      f4: "0x10 | uint32_t | checksum1   // running chain value"
      f5: "0x14 | uint32_t | checksum2   // running chain value"
      fz: "Header size: 24 bytes (WAL_FRAME_HEADER_SIZE)"
    }
    page_data_block: {
      shape: sql_table
      label: "Page Data — 4096 bytes"
      style.fill: "#42A5F5"
      style.font-color: white
      pd0: "0x18 | uint8_t[] | full B-tree page content"
      pd1: "Size = page_size declared in WAL file header"
      pd2: "Verbatim copy of the modified database page"
      pd3: "Included in cumulative checksum computation"
      pd4: "Read into db file on WAL replay / checkpoint"
    }
    cksum_algo: {
      shape: sql_table
      label: "wal_checksum() — Checksum Algorithm"
      style.fill: "#AB47BC"
      style.font-color: white
      ca0: "Inputs: prior (s1, s2)  +  data buffer"
      ca1: "Loop per 8-byte chunk:"
      ca2: "  s1 += data[i]   + s2"
      ca3: "  s2 += data[i+1] + s1"
      ca4: "Applied to: frame_header[0..23] + page_data[0..4095]"
      ca5: "Result stored at frame offsets 0x10 and 0x14"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  chain_note: "Cumulative Checksum Chain" {
    direction: down
    style.fill: "#FCE4EC"
    style.stroke: "#C62828"
    style.border-radius: 6
    chain_detail: {
      shape: sql_table
      label: "Each frame inherits prior frame checksum"
      style.fill: "#EF9A9A"
      c0: "seed       = WAL header checksum (cksum1, cksum2)"
      c1: "Frame 0    cksum = f(seed,          hdr0, page0)"
      c2: "Frame 1    cksum = f(frame0_cksum,  hdr1, page1)"
      c3: "Frame N    cksum = f(frameN-1_cksum,hdrN, pageN)"
      c4: "─────────────────────────────────────────────────"
      c5: "Corruption at frame K → all frames K..N fail"
      c6: "Recovery stops at first mismatch → safe truncation"
    }
  }
  salt_note: "Salt Values — Transaction Binding" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.border-radius: 6
    salt_detail: {
      shape: sql_table
      label: "How salts prevent stale-frame replay"
      style.fill: "#A5D6A7"
      s0: "salt1, salt2 randomised at each WAL reset / checkpoint"
      s1: "Every frame stores the current transaction salts"
      s2: "Recovery: frame.salt != header.salt → stop scan"
      s3: "Frames from prior transaction cycles are rejected"
      s4: "Protects against partial WAL wrapping or reuse"
    }
  }
  commit_note: "Commit Detection via db_size" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.border-radius: 6
    commit_detail: {
      shape: sql_table
      label: "How recovery identifies committed transactions"
      style.fill: "#90CAF9"
      k0: "Non-commit frame: db_size == 0"
      k1: "Commit frame:     db_size == total DB pages"
      k2: "Scan WAL forward; track last db_size > 0 offset"
      k3: "All frames after last commit = uncommitted → discard"
      k4: "On rollback: ftruncate(db, db_size * page_size)"
      k5: "Atomic commit: single frame write flips db_size"
    }
  }
}
wal_file.wal_hdr -> wal_file.frame0: "append frame 0" {
  style.stroke: "#3F51B5"
}
wal_file.frame0 -> wal_file.frameN: "append frames 1..N" {
  style.stroke: "#3F51B5"
}
wal_file.frame0 -> frame_hdr_detail: "zoom in" {
  style.stroke-dash: 4
  style.stroke: "#F57F17"
}
frame_hdr_detail -> page_data_block: "immediately followed by" {
  style.stroke: "#F57F17"
}
page_data_block -> cksum_algo: "feeds into checksum" {
  style.stroke: "#AB47BC"
}
cksum_algo -> frame_hdr_detail: "result stored at 0x10/0x14" {
  style.stroke: "#AB47BC"
  style.stroke-dash: 4
}
row1 -> row2: "integrity guarantees derived from layout" {
  style.stroke: "#607D8B"
  style.stroke-dash: 3
}
wal_file.frameN -> commit_note: "db_size > 0 → commit" {
  style.stroke: "#43A047"
  style.stroke-dash: 4
}
wal_file.frame0 -> chain_note: "cksum chain starts here" {
  style.stroke: "#C62828"
  style.stroke-dash: 4
}
wal_file.wal_hdr -> salt_note: "salt1, salt2 seeded here" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 4
}