direction: down
wal_file: WAL File {
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#495057"
  style.stroke-width: 2
}
wal_header: WAL Header (32 bytes) {
  shape: sql_table
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  magic: "Bytes 0–3 │ 0x377f0682 (magic number)"
  format_version: "Bytes 4–7 │ Format version (3007000)"
  page_size: "Bytes 8–11 │ Page size in bytes (e.g. 4096)"
  checkpoint_seq: "Bytes 12–15 │ Checkpoint sequence number"
  salt1: "Bytes 16–19 │ Salt-1 (random, changes each restart)"
  salt2: "Bytes 20–23 │ Salt-2 (random, changes each restart)"
  checksum1: "Bytes 24–27 │ Cumulative checksum over header (part 1)"
  checksum2: "Bytes 28–31 │ Cumulative checksum over header (part 2)"
}
frame_n: WAL Frame N (24 + PAGE_SIZE bytes) {
  shape: rectangle
  style.fill: "#f3e5f5"
  style.stroke: "#6a1b9a"
  style.stroke-width: 2
  frame_header: Frame Header (24 bytes) {
    shape: sql_table
    style.fill: "#e8d5f5"
    style.stroke: "#6a1b9a"
    pgno: "Bytes 0–3  │ Page number this frame stores"
    db_size: "Bytes 4–7  │ 0 = non-commit frame; N = commit (db page count)"
    salt1: "Bytes 8–11 │ Must match WAL header salt-1"
    salt2: "Bytes 12–15│ Must match WAL header salt-2"
    checksum1: "Bytes 16–19│ Cumulative checksum (chained from prior frame)"
    checksum2: "Bytes 20–23│ Cumulative checksum (chained from prior frame)"
  }
  page_data: Page Data (PAGE_SIZE bytes) {
    shape: sql_table
    style.fill: "#f3e5f5"
    style.stroke: "#6a1b9a"
    raw_page: "Bytes 24 … (24 + PAGE_SIZE − 1) │ Raw database page content"
  }
  frame_header -> page_data: checksum covers header + page data {
    style.stroke: "#6a1b9a"
    style.stroke-dash: 4
  }
}
commit_note: Commit vs Non-Commit {
  shape: sql_table
  style.fill: "#fff8e1"
  style.stroke: "#f57f17"
  non_commit: "db_size = 0 │ Intermediate write; transaction still open"
  commit: "db_size > 0 │ Final frame; db_size = total pages after commit"
}
chain_note: Checksum Chain (Corruption Detection) {
  shape: sql_table
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
  seed: "Frame 0     │ Checksum seeded from WAL header checksum pair"
  propagate: "Frame N     │ checksum(N) = f(checksum(N-1), header_N, page_N)"
  detect: "Validation  │ Any corrupt byte breaks the chain → frame rejected"
  salt_check: "Salt match  │ Wrong salt = stale generation → WAL reset boundary"
}
wal_file -> wal_header
wal_file -> frame_n
wal_file -> commit_note
wal_file -> chain_note
wal_header -> frame_n: checksum1/2 seeds frame-0 checksum {
  style.stroke: "#1565c0"
  style.stroke-dash: 3
}
frame_n.frame_header -> chain_note: cumulative chain {
  style.stroke: "#2e7d32"
  style.stroke-dash: 3
}