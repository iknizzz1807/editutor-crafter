direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
row_t1t2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t1: "T1 — Committed" {
    direction: down
    style.fill: "#bee3f8"
    style.stroke: "#2b6cb0"
    style.border-radius: 4
    f1: "frame  1  pg=42  non-commit"
    f2: "frame  2  pg=17  non-commit"
    f3: "frame  3  pg=88  non-commit"
    f4: "frame  4  pg=12  non-commit"
    f5: "frame  5  pg= 3  COMMIT  db_size=50" {
      style.fill: "#2b6cb0"
      style.font-color: white
    }
  }
  t2: "T2 — Committed" {
    direction: down
    style.fill: "#bee3f8"
    style.stroke: "#2b6cb0"
    style.border-radius: 4
    f6:  "frame  6  pg= 3  non-commit"
    f7:  "frame  7  pg=42  non-commit"
    f8:  "frame  8  pg=99  non-commit"
    f9:  "frame  9  pg= 5  non-commit"
    f10: "frame 10  pg= 7  COMMIT  db_size=52" {
      style.fill: "#2b6cb0"
      style.font-color: white
    }
  }
  r1_vis_note: "Visible to R1 and R2" {
    style.fill: "#bee3f8"
    style.stroke: "#2b6cb0"
    style.border-radius: 8
    v1: "Both readers started after T1 and T2 committed"
    v2: "T1 frames 1-5 and T2 frames 6-10 in both snapshots"
  }
}
r1: "Reader R1  —  snapshot_end = 10" {
  style.fill: "#2b6cb0"
  style.font-color: white
  style.border-radius: 8
  style.bold: true
  r1_sees: "Sees: T1 + T2  (frames 1 through 10)" {
    style.fill: "#ebf8ff"
    style.font-color: "#1a365d"
  }
  r1_lookup: "wal_find_frame(pg=42, end=10)  returns frame 7  (T2 version)" {
    style.fill: "#ebf8ff"
    style.font-color: "#1a365d"
  }
  r1_frozen: "Snapshot immutable — writer appends cannot change this view" {
    style.fill: "#ebf8ff"
    style.font-color: "#1a365d"
    style.italic: true
  }
}
row_t3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t3: "T3 — Committed" {
    direction: down
    style.fill: "#c6f6d5"
    style.stroke: "#276749"
    style.border-radius: 4
    f11: "frame 11  pg= 7  non-commit"
    f12: "frame 12  pg=33  non-commit"
    f13: "frame 13  pg=42  non-commit"
    f14: "frame 14  pg=71  non-commit"
    f15: "frame 15  pg= 8  COMMIT  db_size=55" {
      style.fill: "#276749"
      style.font-color: white
    }
  }
  r1_blocked: "R1 snapshot boundary — T3 invisible to R1" {
    style.fill: "#fed7d7"
    style.stroke: "#9b2c2c"
    style.border-radius: 4
    b1: "R1 end=10  —  frame 13 exceeds snapshot limit"
    b2: "wal_find_frame(pg=42, end=10) skips frame 13"
    b3: "Falls back to frame 7  (T2 version of page 42)"
  }
}
r2: "Reader R2  —  snapshot_end = 15" {
  style.fill: "#276749"
  style.font-color: white
  style.border-radius: 8
  style.bold: true
  r2_sees: "Sees: T1 + T2 + T3  (frames 1 through 15)" {
    style.fill: "#f0fff4"
    style.font-color: "#1a4731"
  }
  r2_lookup: "wal_find_frame(pg=42, end=15)  returns frame 13  (T3 version)" {
    style.fill: "#f0fff4"
    style.font-color: "#1a4731"
  }
  r2_frozen: "Snapshot immutable — writer frames 16+ invisible" {
    style.fill: "#f0fff4"
    style.font-color: "#1a4731"
    style.italic: true
  }
}
writer_zone: "Writer W1  —  IN PROGRESS  (invisible to R1 and R2)" {
  direction: right
  style.fill: "#fff5f5"
  style.stroke: "#9b2c2c"
  style.stroke-dash: 4
  style.border-radius: 4
  w1_frames: "Writer frames 16+" {
    direction: down
    style.fill: "#fed7d7"
    style.stroke: "#9b2c2c"
    style.stroke-dash: 4
    f16: "frame 16  pg= 8  non-commit"
    f17: "frame 17  pg=42  non-commit"
    no_commit: "— awaiting COMMIT —" {
      style.fill: "#9b2c2c"
      style.font-color: white
      style.stroke-dash: 4
    }
  }
  why_invis: "Why invisible to both readers" {
    style.fill: "#fff5f5"
    style.stroke: "#9b2c2c"
    w1: "R1: end=10  <  frame 16  — skipped"
    w2: "R2: end=15  <  frame 16  — skipped"
    w3: "No COMMIT frame yet  — transaction incomplete"
    w4: "WAL index pg=42 points to frame 17 (beyond both snapshots)"
  }
}
wal_index: {
  shape: sql_table
  label: "WAL Index  —  page_no to most-recent frame"
  page_3:  "frame  6  (T2 version)"
  page_5:  "frame  9  (T2 version)"
  page_7:  "frame 11  (T3 version)"
  page_8:  "frame 16  (W1 uncommitted)"
  page_12: "frame  4  (T1 version)"
  page_17: "frame  2  (T1 version)"
  page_33: "frame 12  (T3 version)"
  page_42: "frame 17  (W1 uncommitted — R1 resolves f7, R2 resolves f13)"
  page_71: "frame 14  (T3 version)"
  page_88: "frame  3  (T1 version)"
  page_99: "frame  8  (T2 version)"
  fc:      "frame_count = 17  (writer holds WAL write lock)"
}
row_t1t2 -> r1: "R1 calls wal_begin_read()"
r1 -> row_t3: "T3 commits while R1 is active"
row_t3 -> r2: "R2 calls wal_begin_read()"
r2 -> writer_zone: "W1 appends past R2 snapshot"
writer_zone -> wal_index: "index updated each appended frame"