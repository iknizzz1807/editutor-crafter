direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## WAL vs Rollback Journal — I/O Pattern Comparison
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  journal_box: "BEFORE — Rollback Journal Mode" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.border-radius: 6
    protocol: {
      shape: sql_table
      label: "Write Ordering Protocol (transaction.c)"
      s1: "① read original page into buffer pool"
      s2: "② pwrite(journal_fd, orig_page_4096B, journal_offset)"
      s3: "③ fsync(journal_fd) — BARRIER: journal durable before DB touch"
      s4: "④ pwrite(db_fd, modified_page, page_no * PAGE_SIZE)"
      s5: "⑤ fsync(db_fd) — BARRIER: DB pages durable"
      s6: "⑥ unlink(db-journal) — COMMIT POINT: journal deleted = committed"
    }
    files_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      journal_file: {
        shape: sql_table
        label: "mydb.db-journal  (undo log — random I/O)"
        style.fill: "#FFCCBC"
        style.stroke: "#BF360C"
        hdr: "Header | magic=0xd9d505f9 | nonce | page_count"
        p0: "Entry 0 | page_no=42 | 4096 bytes original | checksum"
        p1: "Entry 1 | page_no=77 | 4096 bytes original | checksum"
        p2: "Entry 2 | page_no=13 | 4096 bytes original | checksum"
        note: "Exists ONLY during active write transaction"
      }
      barrier_node: "fsync barrier" {
        shape: diamond
        style.fill: "#E65100"
        style.font-color: white
        style.stroke: "#BF360C"
      }
      db_file_before: {
        shape: sql_table
        label: "mydb.db  (modified IN-PLACE — random seeks)"
        style.fill: "#BBDEFB"
        style.stroke: "#1565C0"
        pg42: "page 42 | offset=168 KB | MODIFIED (random pwrite)"
        pg77: "page 77 | offset=308 KB | MODIFIED (random pwrite)"
        pg13: "page 13 | offset=52 KB  | MODIFIED (random pwrite)"
        lock: "EXCLUSIVE flock held for entire transaction duration"
      }
    }
    io_cost: {
      shape: sql_table
      label: "I/O Cost — Rollback Journal"
      c1: "journal pwrite(s) | random I/O to journal file | 1 call per unique page"
      c2: "fsync(journal_fd) | 5 ms HDD / 0.1 ms NVMe | mandatory before DB write"
      c3: "db pwrite(s) | random seeks across DB file | 1 call per dirty page"
      c4: "fsync(db_fd) | 5 ms HDD / 0.1 ms NVMe | mandatory before journal delete"
      c5: "fsyncs per COMMIT | 2 fsyncs total | DOUBLED latency vs WAL"
      c6: "1000 auto-commit INSERTs | 2000 fsyncs x 5 ms = 10 sec (HDD)"
    }
  }
  wal_box: "AFTER — WAL Mode" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.border-radius: 6
    protocol: {
      shape: sql_table
      label: "Write Ordering Protocol (wal.c)"
      s1: "① wal_write_frame(page_no, modified_page, is_commit=0)"
      s2: "② pwrite(wal_fd, frame_hdr+page_4096B, WAL_end) — APPEND"
      s3: "③ walindex_insert(shm, page_no, frame_idx) — update hash map"
      s4: "④ fsync(wal_fd) — SINGLE BARRIER on commit frame only"
      s5: "⑤ COMMIT DONE — main DB file never touched during txn"
      s6: "--- CHECKPOINT (background): copy WAL frames to db_fd ---"
    }
    files_row2: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      wal_file: {
        shape: sql_table
        label: "mydb.db-wal  (append-only sequential writes)"
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
        hdr: "WAL Hdr | magic=0x377f0682 | salt1 | salt2 | seq_no"
        f0: "Frame 0 | page_no=42 | db_size=0   | cksum chain (TXN 1)"
        f1: "Frame 1 | page_no=77 | db_size=100 | cksum COMMIT (TXN 1)"
        f2: "Frame 2 | page_no=13 | db_size=0   | cksum chain (TXN 2)"
        note: "Append-only — write pointer never moves backward"
      }
      wal_barrier: "fsync barrier" {
        shape: diamond
        style.fill: "#2E7D32"
        style.font-color: white
        style.stroke: "#1B5E20"
      }
      db_file_after: {
        shape: sql_table
        label: "mydb.db  (READ-ONLY until checkpoint)"
        style.fill: "#E3F2FD"
        style.stroke: "#90CAF9"
        style.stroke-dash: 5
        pg42: "page 42 | STALE — last checkpoint version on disk"
        pg77: "page 77 | STALE — last checkpoint version on disk"
        pg13: "page 13 | STALE — last checkpoint version on disk"
        readers: "Readers access freely — no write lock contention"
      }
    }
    io_cost2: {
      shape: sql_table
      label: "I/O Cost — WAL Mode"
      c1: "WAL pwrite(s) | SEQUENTIAL append — single stream, zero seeks"
      c2: "fsync(wal_fd) | 5 ms HDD / 0.1 ms NVMe | single barrier per commit"
      c3: "db pwrite(s) | ZERO during transaction | deferred to checkpoint"
      c4: "db fsync | ZERO during transaction | deferred to checkpoint"
      c5: "fsyncs per COMMIT | 1 fsync total | HALF the cost of journal"
      c6: "1000 auto-commit INSERTs | 1000 fsyncs x 5 ms = 5 sec (HDD)"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  concurrency_table: {
    shape: sql_table
    label: "Concurrency and Isolation Model"
    hdr: "Property | Rollback Journal | WAL Mode"
    r1: "Reader during write | BLOCKED by flock(LOCK_EX) | CONCURRENT via snapshot"
    r2: "Writer lock scope | Entire transaction | WAL append lock only"
    r3: "Isolation mechanism | Exclusive file lock | end_frame snapshot integer"
    r4: "Snapshot acquisition cost | Lock syscall | Single atomic int read"
    r5: "Writer blocks readers | YES | NO"
    r6: "Readers block writer | YES — LOCK_SH held | NO — snapshot only"
    r7: "Multiple readers simultaneously | YES (serialized) | YES (fully parallel)"
  }
  io_pattern_table: {
    shape: sql_table
    label: "I/O Pattern Deep Dive"
    hdr: "Operation | Journal Random I/O | WAL Sequential I/O"
    r1: "Write target | pwrite to page offset in DB file | pwrite append to WAL end"
    r2: "Seek pattern | N random seeks (1 per dirty page) | 1 seek to WAL EOF"
    r3: "HDD write throughput | ~200 pages/sec (random IOPS) | ~100 MB/s sequential"
    r4: "NVMe comparison | 300 MB/s random vs 3 GB/s seq | 3 GB/s sequential"
    r5: "Write amplification | 2 writes per page (journal + DB) | 1 write per page (WAL)"
    r6: "Post-commit overhead | None (journal unlinked) | Checkpoint copies WAL to DB"
    r7: "Read overhead | None — DB always current | Check WAL index on every read"
  }
}
journal_box.files_row.journal_file -> journal_box.files_row.barrier_node: "② pwrite + fsync" {
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.animated: true
}
journal_box.files_row.barrier_node -> journal_box.files_row.db_file_before: "④ random pwrite to DB" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
wal_box.files_row2.wal_file -> wal_box.files_row2.wal_barrier: "② sequential append + fsync" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.animated: true
}
wal_box.files_row2.wal_barrier -> wal_box.files_row2.db_file_after: "checkpoint only (deferred)" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 6
}