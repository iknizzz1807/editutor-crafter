direction: down
title: {
  label: "WAL vs Rollback Journal: Inverted Strategies"
  style.font-size: 28
  style.bold: true
  style.font-color: "#1e293b"
}
row: {
  style.fill: transparent
  style.stroke: transparent
  direction: right
  journal_col: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    direction: down
    journal_header: {
      label: "Rollback Journal"
      shape: rectangle
      style.fill: "#dc2626"
      style.font-color: "#ffffff"
      style.font-size: 20
      style.bold: true
      style.border-radius: 8
      style.stroke: "#991b1b"
    }
    journal_principle: {
      label: "UNDO LOG — stores OLD pages\nDatabase modified in-place"
      shape: rectangle
      style.fill: "#fef2f2"
      style.font-color: "#7f1d1d"
      style.font-size: 13
      style.bold: true
      style.stroke: "#fca5a5"
      style.border-radius: 6
    }
    journal_protocol: {
      label: "Write Protocol"
      shape: sql_table
      style.fill: "#fff5f5"
      style.stroke: "#f87171"
      style.font-color: "#1e293b"
      step1: "① Acquire EXCLUSIVE lock (block all readers)" {constraint: "🔒 lock"}
      step2: "② Copy OLD page → journal file" {constraint: "before-image"}
      step3: "③ fsync journal (durability guarantee)" {constraint: "fsync #1"}
      step4: "④ Write NEW data to database file" {constraint: "in-place write"}
      step5: "⑤ fsync database file" {constraint: "fsync #2"}
      step6: "⑥ COMMIT = delete journal file" {constraint: "cleanup"}
    }
    journal_files: {
      label: "File State During Write"
      shape: sql_table
      style.fill: "#fff5f5"
      style.stroke: "#f87171"
      style.font-color: "#1e293b"
      db_file: "database.db" {constraint: "BEING MUTATED ✏️"}
      jrn_file: "database.db-journal" {constraint: "OLD pages (before-images)"}
      wal_file: "(no WAL file)" {constraint: "—"}
    }
    journal_recovery: {
      label: "Crash Recovery"
      shape: rectangle
      style.fill: "#fef2f2"
      style.font-color: "#991b1b"
      style.font-size: 12
      style.stroke: "#fca5a5"
      style.border-radius: 6
      label: "Journal exists on restart?\n→ UNDO: copy OLD pages back to database\n→ Database restored to pre-transaction state"
    }
    journal_concurrency: {
      label: "Concurrency Model"
      shape: sql_table
      style.fill: "#ffe4e6"
      style.stroke: "#f43f5e"
      style.font-color: "#1e293b"
      writers: "Writers" {constraint: "EXCLUSIVE lock — blocks everyone"}
      readers: "Readers" {constraint: "❌ BLOCKED during write"}
      isolation: "Isolation" {constraint: "none (lock-based serialization)"}
      verdict: "Result" {constraint: "⚠️  Writers block all readers"}
    }
  }
  gap: {
    label: "vs"
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 32
    style.bold: true
    style.font-color: "#64748b"
    width: 60
  }
  wal_col: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    direction: down
    wal_header: {
      label: "WAL (Write-Ahead Log)"
      shape: rectangle
      style.fill: "#16a34a"
      style.font-color: "#ffffff"
      style.font-size: 20
      style.bold: true
      style.border-radius: 8
      style.stroke: "#14532d"
    }
    wal_principle: {
      label: "REDO LOG — stores NEW pages\nDatabase file frozen / untouched"
      shape: rectangle
      style.fill: "#f0fdf4"
      style.font-color: "#14532d"
      style.font-size: 13
      style.bold: true
      style.stroke: "#86efac"
      style.border-radius: 6
    }
    wal_protocol: {
      label: "Write Protocol"
      shape: sql_table
      style.fill: "#f0fff4"
      style.stroke: "#4ade80"
      style.font-color: "#1e293b"
      step1: "① Acquire WAL write lock (readers still run)" {constraint: "🔓 shared read"}
      step2: "② Append NEW page frames → WAL file" {constraint: "after-image"}
      step3: "③ Write commit frame to WAL" {constraint: "commit marker"}
      step4: "④ fsync WAL (single sync = durable)" {constraint: "fsync #1 only"}
      step5: "⑤ Database file untouched until checkpoint" {constraint: "frozen ❄️"}
      step6: "⑥ COMMIT = commit frame visible in WAL" {constraint: "no delete"}
    }
    wal_files: {
      label: "File State During Write"
      shape: sql_table
      style.fill: "#f0fff4"
      style.stroke: "#4ade80"
      style.font-color: "#1e293b"
      db_file: "database.db" {constraint: "FROZEN — not touched ❄️"}
      wal_file: "database.db-wal" {constraint: "NEW pages (after-images)"}
      shm_file: "database.db-shm" {constraint: "shared mmap index (max_frame)"}
    }
    wal_recovery: {
      label: "Crash Recovery"
      shape: rectangle
      style.fill: "#f0fdf4"
      style.font-color: "#14532d"
      style.font-size: 12
      style.stroke: "#86efac"
      style.border-radius: 6
      label: "WAL exists on restart?\n→ REDO: replay committed frames into database\n→ Uncommitted frames silently ignored"
    }
    wal_concurrency: {
      label: "Concurrency Model"
      shape: sql_table
      style.fill: "#dcfce7"
      style.stroke: "#22c55e"
      style.font-color: "#1e293b"
      writers: "Writers" {constraint: "append to WAL (no exclusive lock)"}
      readers: "Readers" {constraint: "✅ read database + WAL up to max_frame"}
      isolation: "Isolation" {constraint: "snapshot via max_frame per transaction"}
      verdict: "Result" {constraint: "✅ Readers and writers coexist"}
    }
  }
}
inversion_box: {
  label: "The Fundamental Inversion"
  shape: sql_table
  style.fill: "#fafafa"
  style.stroke: "#94a3b8"
  style.font-color: "#1e293b"
  style.font-size: 13
  safety_journal: "Journal safety" {constraint: "journal must be fsynced BEFORE database is written"}
  safety_wal: "WAL safety" {constraint: "WAL must be fsynced BEFORE commit is acknowledged"}
  protected_journal: "Journal protects" {constraint: "database file (stores undo path back)"}
  protected_wal: "WAL protects" {constraint: "nothing — database is never touched mid-tx"}
  reads_journal: "Journal reads" {constraint: "always go to database.db (may be mid-mutation)"}
  reads_wal: "WAL reads" {constraint: "union of database.db + WAL frames ≤ max_frame"}
  checkpoint: "Checkpoint" {constraint: "WAL only — merges WAL frames back into database (background)"}
}
row.journal_col.journal_header -> row.journal_col.journal_principle: {style.stroke: "#dc2626"; style.stroke-width: 2}
row.journal_col.journal_principle -> row.journal_col.journal_protocol: {style.stroke: "#dc2626"; style.stroke-width: 2}
row.journal_col.journal_protocol -> row.journal_col.journal_files: {style.stroke: "#f87171"; style.stroke-width: 1; style.stroke-dash: 3}
row.journal_col.journal_files -> row.journal_col.journal_recovery: {style.stroke: "#f87171"; style.stroke-width: 1}
row.journal_col.journal_recovery -> row.journal_col.journal_concurrency: {style.stroke: "#dc2626"; style.stroke-width: 2}
row.wal_col.wal_header -> row.wal_col.wal_principle: {style.stroke: "#16a34a"; style.stroke-width: 2}
row.wal_col.wal_principle -> row.wal_col.wal_protocol: {style.stroke: "#16a34a"; style.stroke-width: 2}
row.wal_col.wal_protocol -> row.wal_col.wal_files: {style.stroke: "#4ade80"; style.stroke-width: 1; style.stroke-dash: 3}
row.wal_col.wal_files -> row.wal_col.wal_recovery: {style.stroke: "#4ade80"; style.stroke-width: 1}
row.wal_col.wal_recovery -> row.wal_col.wal_concurrency: {style.stroke: "#16a34a"; style.stroke-width: 2}
row -> inversion_box: {
  label: "consequences"
  style.stroke: "#64748b"
  style.stroke-width: 2
  style.stroke-dash: 4
}