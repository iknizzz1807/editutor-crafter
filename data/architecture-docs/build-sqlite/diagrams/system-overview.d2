# D2 System Blueprint for Build Your Own SQLite (11 Milestones)
shape: sql_table
# MILESTONE 1: TOKENIZER
token.h:tokenizer {
  field: TokenType: enum (TK_INTEGER..TK_ERROR)
  field: KeywordType: enum
  field: Token: struct { type, start, len, line, col }
  field: KeywordHashTable: struct
  field: FSMState: enum (START, IN_TOKEN, IN_STRING, etc.)
}
shape: sql_table
tokenizer.c:tokenizer_impl {
  field: tokenizer: struct { input, len, pos, line, col }
  method: tokenize_input(): Token[] 
  method: next_token(): Token
  method: skip_whitespace(): void
  method: read_identifier(): Token
  method: read_number(): Token
  method: read_string(): Token
  method: hash_keyword(str): uint32
}
# MILESTONE 2: PARSER
shape: sql_table
ast.h:ast {
  field: ASTNodeType: enum (NODE_SELECT, NODE_INSERT, NODE_UPDATE, NODE_DELETE, NODE_CREATE_TABLE, NODE_DROP_TABLE, NODE_BINARY_EXPR, NODE_UNARY_EXPR, NODE_LITERAL, NODE_COLUMN_REF, NODE_TABLE_REF, NODE_ORDER_BY, NODE_GROUP_BY, NODE_LIMIT, etc.)
  field: SelectStatement: struct { columns[], from, where, group_by, order_by, limit, offset }
  field: InsertStatement: struct { table, columns[], values[] }
  field: UpdateStatement: struct { table, set_clauses[], where }
  field: DeleteStatement: struct { table, where }
  field: CreateTableStatement: struct { name, columns[], primary_key }
  field: ColumnDef: struct { name, type, not_null, default_val }
  field: Expr: struct { type, left, right, op, value }
  field: TableRef: struct { name, alias }
}
shape: sql_table
parser.h:parser {
  field: Parser: struct { tokens, current, prev_token, errors }
  field: Precedence: enum { PREC_LOWEST, PREC_AND, PREC_OR, PREC_EQ, PREC_CMP, PREC_ADD, PREC_MUL, PREC_UNARY }
  field: ParseResult: struct { ast, error_msg }
}
shape: sql_table
parser.c:parser_impl {
  method: parse_sql(sql): ParseResult
  method: parse_select(): SelectStatement
  method: parse_insert(): InsertStatement
  method: parse_create_table(): CreateTableStatement
  method: parse_expression(min_prec): Expr
  method: parse_column_list(): ColumnRef[]
  method: parse_table_name(): TableRef
  method: advance(): void
  method: expect(tok_type): Token
}
# MILESTONE 3: VDBE
shape: sql_table
vdbe.h:vdbe {
  field: Opcode: enum (OP_INTEGER, OP_STRING, OP_NULL, OP_EOF, OP_EQ, OP_NE, OP_LT, OP_GT, OP_LE, OP_GE, OP_ADD, OP_SUB, OP_MUL, OP_DIV, OP_MOD, OP_CONCAT, OP_LOAD, OP_STORE, OP_COLUMN, OP_RESULT_ROW, OP_GOTO, OP_IF_NOT, OP_HALT, OP_TRANSACTION, OP_COMMIT, OP_ROLLBACK, OP_OPEN_READ, OP_OPEN_WRITE, OP_NOTICE, OP_FUNCTION, OP_DUP, OP_DROP, etc.)
  field: Instruction: struct { opcode, p1, p2, p3, p4 }
  field: VDBE: struct { program[], pc, db, num_columns, rows_read, rows_written }
  field: VdbeFrame: struct { pc, stack, registers, cursor }
}
shape: sql_table
vm.c:vm_engine {
  method: vdbe_exec(vdbe): int
  method: step(vdbe): int
  method: exec_instruction(vdbe, instr): int
  method: op_integer(vdbe): void
  method: op_column(vdbe): void
  method: op_result_row(vdbe): void
  method: op_eq(vdbe): int
  method: op_jump(vdbe): void
}
shape: sql_table
vdbe_util.c:vdbe_util {
  method: vdbe_prepare(sql): VDBE
  method: vdbe_finalize(vdbe): int
  method: vdbe_reset(vdb): int
  method: bind_parameter(vdbe, idx, value): int
}
# MILESTONE 4: BUFFER POOL
shape: sql_table
buffer_pool.h:buffer_pool {
  field: BufferPool: struct { frames[], hash_table, lru_head, lru_tail, page_size, max_pages, num_pages, pins }
  field: Frame: struct { page_id, data, pin_count, ref_count, is_dirty, lru_prev, lru_next, hash_next }
  field: HashEntry: struct { page_id, frame, next }
}
shape: sql_table
buffer_pool.c:bp_impl {
  method: pool_init(path, max_pages): BufferPool
  method: pool_get_page(pool, page_id): Frame*
  method: pool_release_page(pool, frame): void
  method: pool_pin_page(pool, page_id): Frame*
  method: pool_unpin_page(pool, frame): void
  method: pool_flush(pool): void
  method: lru_evict(pool): Frame*
  method: hash_lookup(pool, page_id): Frame*
  method: hash_insert(pool, frame): void
}
# MILESTONE 5: B-TREE STORAGE
shape: sql_table
page.h:page_format {
  field: PageType: enum (PAGE_TYPE_LEAF_TABLE, PAGE_TYPE_INTERIOR_TABLE, PAGE_TYPE_LEAF_INDEX, PAGE_TYPE_INTERIOR_INDEX, PAGE_TYPE_LOCK_BYTE, PAGE_TYPE_FREELIST, PAGE_TYPE_POINTER_MAP)
  field: PageHeader: struct { page_type, first_freeblock, cell_count, cell_content_start, fragmented_bytes }
  field: CellPointer: struct { payload_size, rowid }
  field: LeafCell: struct { payload_size, rowid, payload }
  field: InteriorCell: struct { left_child, key_size, key }
}
shape: sql_table
cursor.h:cursor {
  field: Cursor: struct { table, page, cell_num, rowid, is_valid, key, column_cache }
  field: CursorFlags: enum (CURSOR_SEEK_EQ, CURSOR_SEEK_GE, CURSOR_SEEK_LE, CURSOR_LAST, CURSOR_FIRST)
  field: ColumnCache: struct { values, types, num_cached }
}
shape: sql_table
btree.c:btree_impl {
  method: btree_open(path): BTree
  method: btree_cursor(btree, table_root): Cursor*
  method: cursor_seek(cursor, key, flags): int
  method: cursor_next(cursor): int
  method: cursor_prev(cursor): int
  method: cursor_insert(cursor, key, payload): int
  method: cursor_delete(cursor): int
  method: btree_split_page(parent, child): void
  method: btree_merge_pages(left, right): void
  method: btree_balance(cursor): void
}
# MILESTONE 6: SELECT & DML
shape: sql_table
table.c:table_ops {
  method: table_create(db, name, columns): int
  method: table_drop(db, name): int
  method: table_insert(db, table, values): int
  method: table_update(db, table, set_clauses, where): int
  method: table_delete(db, table, where): int
  method: table_select(db, query): RowSet
}
shape: sql_table
where.c:where_clause {
  method: where_begin(query_plan): WhereInfo
  method: where_next(where_info): int
  method: expr_eval(expr, row): Value
  method: index_search(table, column, value): RowSet
  method: apply_where_clause(rows, where_expr): RowSet
}
# MILESTONE 7: SECONDARY INDEXES
shape: sql_table
index.h:index_format {
  field: Index: struct { name, table_name, root_page, columns[], unique }
  field: IndexEntry: struct { key, rowid, next }
  field: IndexInfo: struct { index, scan_type, range_start, range_end }
}
shape: sql_table
index.c:index_impl {
  method: index_create(db, name, table, columns, unique): int
  method: index_drop(db, name): int
  method: index_insert(index, key, rowid): int
  method: index_delete(index, key, rowid): int
  method: index_lookup(index, key): IndexCursor*
  method: index_scan(index): IndexCursor*
  method: index_optimize(index): void
}
# MILESTONE 8: QUERY PLANNER
shape: sql_table
query_planner.h:query_plan {
  field: QueryPlan: struct { table_scans[], index_scans[], join_order[], where_clauses }
  field: PlanNode: struct { type, table, index, cost, rows_estimate }
  field: CostEstimate: struct { io_cost, cpu_cost, total_cost, rows }
}
shape: sql_table
planner.c:query_planner_impl {
  method: plan_query(ast): QueryPlan
  method: choose_best_index(table, where): IndexInfo
  method: estimate_scan_cost(table, index): CostEstimate
  method: order_joins(tables): JoinOrder[]
  method: push_down_where(ast): void
  method: add_index_hints(plan, index): void
}
# MILESTONE 9: TRANSACTIONS
shape: sql_table
transaction.h:transaction {
  field: txn_state_t: enum (TXN_STATE_ACTIVE, TXN_STATE_COMMITTING, TXN_STATE_COMMITTED, TXN_STATE_ABORTED, TXN_STATE_PREPARED)
  field: Transaction: struct { id, state, snapshot, locks[], wal_position, start_time }
  field: Lock: struct { table, lock_type, transaction_id, mode }
  field: Snapshot: struct { txid, commit_id, active_txns[] }
}
shape: sql_table
journal.c:journal {
  method: journal_init(db): int
  method: journal_write_page(page): void
  method: journal_commit(txn): int
  method: journal_rollback(txn): int
  method: journal_checkpoint(): int
  method: recover_journal(db): void
}
shape: sql_table
lock_manager.c:lock_mgr {
  method: lock_acquire(txn, resource, mode): int
  method: lock_release(txn, resource): int
  method: lock_upgrade(txn, resource): int
  method: detect_deadlock(txn_set): bool
}
# MILESTONE 10: WAL MODE
shape: sql_table
wal.h:wal_format {
  field: WalHeader: struct { magic, format_version, page_size, checkpoint_seq, salt1, salt2, checksum1, checksum2 }
  field: WalFrame: struct { page_no, commit_size, salt1, salt2, checksum1, checksum2, page_data }
  field: WalIndex: struct { checkpoint, npages, pages[], locks }
}
shape: sql_table
wal.c:wal_impl {
  method: wal_open(db, path): Wal
  method: wal_close(wal): void
  method: wal_write_frame(wal, page, commit): int
  method: wal_read_frame(wal, page_no, frame): int
  method: wal_checkpoint(wal, mode): int
  method: wal_recovery(db, wal): void
  method: wal_append_lock(wal, txid): int
  method: compute_checksum(frame): uint64
}
# MILESTONE 11: AGGREGATES & JOINS
shape: sql_table
aggregate.h:aggregates {
  field: AggInfo: struct { functions[], contexts[], current_vals }
  field: AggFunc: struct { name, func, step_func, finalize_func, init_val }
  field: Value: struct { type, int_val, real_val, str_val, blob_val }
  field: TRIValue: enum (TRI_UNKNOWN, TRI_FALSE, TRI_TRUE)
}
shape: sql_table
join.c:join_impl {
  method: nested_loop_join(left, right, cond): ResultSet
  method: hash_join(left, right, cond): ResultSet
  method: merge_join(left, right, on_col): ResultSet
  method: cross_product(left, right): ResultSet
}
shape: sql_table
aggregate.c:agg_impl {
  method: agg_init(aggs): void
  method: agg_step(agg, value): void
  method: agg_finalize(agg): Value
  method: count_step(agg, val): void
  method: sum_step(agg, val): void
  method: avg_step(agg, val): void
  method: min_step(agg, val): void
  method: max_step(agg, val): void
  method: hash_aggregate(values): HashTable
}
# CORE DATABASE STRUCTURES
shape: sql_table
db.h:database {
  field: Database: struct { tables[], indexes[], connections[], wal, pool, lock_mgr, catalog }
  field: Table: struct { name, root_page, columns[], type }
  field: Catalog: struct { tables, indexes, views, triggers }
  field: Connection: struct { db, txn, flags, last_error }
}
# RELATIONSHIPS
tokenizer.c -> token.h: uses
parser.c -> ast.h: produces
parser.c -> parser.h: uses
parser.c -> tokenizer.c: feeds
vm.c -> vdbe.h: executes
vm.c -> vdbe_util.c: uses
btree.c -> page.h: uses
btree.c -> buffer_pool.c: reads
btree.c -> cursor.h: uses
index.c -> btree.c: builds_on
query_planner.c -> index.c: uses
query_planner.c -> where.c: uses
planner.c -> table.c: plans
planner.c -> join.c: optimizes
journal.c -> transaction.h: manages
journal.c -> buffer_pool.c: syncs
wal.c -> buffer_pool.c: mirrors
wal.c -> wal.h: uses
aggregate.c -> aggregate.h: implements
aggregate.c -> join.c: combines
# MILESTONE NAVIGATION
milestone1 [shape: diamond; label: "M1: Tokenizer"]
milestone2 [shape: diamond; label: "M2: Parser"]
milestone3 [shape: diamond; label: "M3: VDBE"]
milestone4 [shape: diamond; label: "M4: Buffer Pool"]
milestone5 [shape: diamond; label: "M5: B-Tree"]
milestone6 [shape: diamond; label: "M6: SELECT/DML"]
milestone7 [shape: diamond; label: "M7: Indexes"]
milestone8 [shape: diamond; label: "M8: Query Planner"]
milestone9 [shape: diamond; label: "M9: Transactions"]
milestone10 [shape: diamond; label: "M10: WAL"]
milestone11 [shape: diamond; label: "M11: Aggregates"]
milestone1 -> milestone2: "tokens"
milestone2 -> milestone3: "AST"
milestone3 -> milestone4: "I/O"
milestone4 -> milestone5: "pages"
milestone5 -> milestone6: "storage"
milestone6 -> milestone7: "lookup"
milestone7 -> milestone8: "optimize"
milestone8 -> milestone9: "ACID"
milestone9 -> milestone10: "concurrent"
milestone10 -> milestone11: "advanced"
# PACKAGE GROUPING
# SQL Engine Core
tokenizer.c -> parser.c
parser.c -> vm.c
# Storage Layer
buffer_pool.c -> btree.c
btree.c -> index.c
index.c -> table.c
# Query Processing
table.c -> where.c
where.c -> planner.c
planner.c -> join.c
join.c -> aggregate.c
# Transaction & Recovery
db.h -> transaction.h
transaction.h -> journal.c
journal.c -> lock_manager.c
journal.c -> wal.c
