direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_frontend: {
    direction: down
    label: "FRONTEND — LEXICAL + SYNTACTIC ANALYSIS"
    style.fill: "#EEF4FF"
    style.stroke: "#7B9FE0"
    token_type: {
      shape: sql_table
      label: "enum TokenType  (tokenizer.h)  [M1]"
      TOKEN_SELECT: "0x00 | keyword"
      TOKEN_INSERT: "0x01 | keyword"
      TOKEN_CREATE: "0x02 | keyword"
      TOKEN_IDENTIFIER: "0x10 | unquoted name"
      TOKEN_QUOTED_ID: "0x11 | double-quoted name"
      TOKEN_INTEGER: "0x12 | int literal"
      TOKEN_FLOAT: "0x13 | float literal"
      TOKEN_STRING: "0x14 | single-quoted str"
      TOKEN_NULL: "0x15 | NULL keyword"
      TOKEN_EQ: "0x20 | ="
      TOKEN_NEQ: "0x21 | != or <>"
      TOKEN_LT: "0x22 | <"
      TOKEN_GT: "0x23 | >"
      TOKEN_LTE: "0x24 | <="
      TOKEN_GTE: "0x25 | >="
      TOKEN_AND: "0x30 | AND"
      TOKEN_OR: "0x31 | OR"
      TOKEN_NOT: "0x32 | NOT"
      TOKEN_EOF: "0xFF | sentinel"
      TOKEN_ERROR: "0xFE | error"
    }
    token: {
      shape: sql_table
      label: "struct Token  (tokenizer.h)  [M1]"
      type: "TokenType   | 4 bytes"
      start: "const char* | ptr into source"
      length: "int         | lexeme byte count"
      line: "int         | 1-based line"
      column: "int         | 1-based column"
      sz: "Total: 24 bytes"
    }
    lexer: {
      shape: class
      label: "Lexer  tokenizer.c  [M1]"
      -source: "const char*"
      -current: "const char*"
      -line: "int"
      -column: "int"
      -start_line: "int"
      -start_col: "int"
      +lexer_init(l, source): "void"
      +lexer_next_token(l): "Token"
      +lexer_tokenize_all(src, count): "Token*"
      +token_type_name(t): "const char*"
      -advance(l): "char"
      -peek(l): "char"
      -peek_next(l): "char"
      -scan_number(l, start): "Token"
      -scan_word(l, start): "Token"
      -scan_string(l, start): "Token"
      -scan_quoted_id(l, start): "Token"
      -match_keyword(start, len): "TokenType"
      -skip_whitespace_and_comments(l): "void"
    }
    node_type: {
      shape: sql_table
      label: "enum NodeType  (parser.h)  [M2]"
      NODE_SELECT: "0x01 | SELECT stmt"
      NODE_INSERT: "0x02 | INSERT stmt"
      NODE_CREATE_TABLE: "0x03 | CREATE TABLE"
      NODE_BINARY_EXPR: "0x10 | left OP right"
      NODE_UNARY_EXPR: "0x11 | OP operand"
      NODE_LITERAL_INT: "0x12 | int64 value"
      NODE_LITERAL_FLOAT: "0x13 | double value"
      NODE_LITERAL_STRING: "0x14 | heap str"
      NODE_LITERAL_NULL: "0x15 | SQL NULL"
      NODE_IDENTIFIER: "0x16 | col name"
      NODE_COLUMN_REF: "0x17 | table.col"
      NODE_WILDCARD: "0x18 | SELECT *"
    }
    ast_node: {
      shape: sql_table
      label: "struct AstNode  (parser.h)  [M2]"
      type: "NodeType    | 4 bytes"
      line: "int         | source line"
      column: "int         | source col"
      union_select: "struct      | columns, table, where, order, limit"
      union_insert: "struct      | table, col_names, values"
      union_create: "struct      | table, ColumnDef[]"
      union_binary: "struct      | op, left*, right*"
      union_unary: "struct      | op, operand*"
      union_lit_int: "int64_t     | literal value"
      union_lit_float: "double      | literal value"
      union_lit_str: "char*,int   | decoded str"
      union_ident: "char*,char* | table, name"
      sz: "Total: ~48 bytes per node"
    }
    parser: {
      shape: class
      label: "Parser  parser.c  [M2]"
      -tokens: "Token*"
      -count: "int"
      -pos: "int"
      -error_msg: "char[256]"
      -error_line: "int"
      -error_col: "int"
      -had_error: "int"
      +parse_statement(sql): "ParseResult"
      +ast_free(node): "void"
      +ast_print(node, indent): "void"
      -parse_select(p): "AstNode*"
      -parse_insert(p): "AstNode*"
      -parse_create_table(p): "AstNode*"
      -parse_expression(p, min_bp): "AstNode*"
      -parse_primary(p): "AstNode*"
      -left_binding_power(op): "int"
      -parser_expect(p, type, ctx): "int"
      -synchronize(p): "void"
    }
    column_def: {
      shape: sql_table
      label: "struct ColumnDef  (parser.h)  [M2]"
      name: "char*  | heap-allocated"
      type_name: "char*  | INTEGER, TEXT, REAL, BLOB"
      is_primary_key: "int    | 1 if PK"
      is_not_null: "int    | 1 if NOT NULL"
      is_unique: "int    | 1 if UNIQUE"
      sz: "Total: ~32 bytes"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_execution: {
    direction: down
    label: "EXECUTION ENGINE — VDBE COMPILER + VIRTUAL MACHINE"
    style.fill: "#FFF8EE"
    style.stroke: "#D4A017"
    opcode: {
      shape: sql_table
      label: "enum Opcode  (vdbe.h)  [M3]"
      OP_OPEN_TABLE: "0x01 | open cursor"
      OP_REWIND: "0x02 | seek to first"
      OP_NEXT: "0x03 | advance cursor"
      OP_CLOSE: "0x04 | close cursor"
      OP_COLUMN: "0x05 | load column"
      OP_ROWID: "0x06 | load rowid"
      OP_MAKE_RECORD: "0x07 | serialize cols"
      OP_INSERT: "0x08 | write row"
      OP_INTEGER: "0x10 | load int imm"
      OP_INT64: "0x11 | load int64"
      OP_REAL: "0x12 | load double"
      OP_STRING8: "0x13 | load str ptr"
      OP_NULL: "0x14 | load NULL"
      OP_EQ: "0x20 | jump if ="
      OP_NE: "0x21 | jump if !="
      OP_LT: "0x22 | jump if <"
      OP_LE: "0x23 | jump if <="
      OP_GT: "0x24 | jump if >"
      OP_GE: "0x25 | jump if >="
      OP_IS_NULL: "0x26 | jump if NULL"
      OP_NOT_NULL: "0x27 | jump if !NULL"
      OP_ADD: "0x30 | arithmetic"
      OP_GOTO: "0x40 | unconditional jmp"
      OP_IF: "0x41 | jump if truthy"
      OP_IF_NOT: "0x42 | jump if falsy"
      OP_RESULT_ROW: "0x50 | emit output row"
      OP_HALT: "0xFF | stop execution"
    }
    instruction: {
      shape: sql_table
      label: "struct Instruction  (vdbe.h)  [M3]"
      opcode: "Opcode  | 4 bytes"
      p1: "int     | operand 1"
      p2: "int     | operand 2 / jump addr"
      p3: "int     | operand 3"
      p4_i64: "int64_t | large int (union)"
      p4_real: "double  | float val (union)"
      p4_str: "char*   | string ptr (union)"
      comment: "char*   | EXPLAIN annotation"
      sz: "Total: ~48 bytes"
    }
    value_type: {
      shape: sql_table
      label: "enum ValueType  (vdbe.h)  [M3]"
      VAL_NULL: "0 | SQL NULL"
      VAL_INTEGER: "1 | int64_t"
      VAL_REAL: "2 | double"
      VAL_TEXT: "3 | char* + len"
      VAL_BLOB: "4 | uint8* + len"
    }
    value: {
      shape: sql_table
      label: "struct Value  (vdbe.h)  [M3]"
      type: "ValueType | 4 bytes"
      i: "int64_t   | integer val (union)"
      r: "double    | real val (union)"
      text_data: "char*     | text ptr (union)"
      text_len: "int       | text length"
      blob_data: "uint8_t*  | blob ptr (union)"
      blob_len: "int       | blob length"
      sz: "Total: ~32 bytes"
    }
    program: {
      shape: class
      label: "Program  vdbe.c  [M3]"
      +instructions: "Instruction*"
      +count: "int"
      +capacity: "int"
      +plan_nodes: "PlanNode*"
      +plan_node_count: "int"
      +program_free(p): "void"
      +program_explain(p, out): "void"
    }
    vdbe_compiler: {
      shape: class
      label: "Compiler  vdbe.c  [M3]"
      -prog: "Program*"
      -next_reg: "int"
      -next_cursor: "int"
      -error: "char[256]"
      -had_error: "int"
      -db: "DB*"
      +compile(ast, err): "Program*"
      -compile_select(c, node): "void"
      -compile_insert(c, node): "void"
      -compile_create_table(c, node): "void"
      -compile_where(c, cursor, expr): "int"
      -compile_expr_into_reg(c, cur, expr, reg): "void"
      -emit(c, op, p1, p2, p3, cmt): "int"
      -patch_jump(c, addr): "void"
      -alloc_register(c): "int"
    }
    vdbe_state: {
      shape: class
      label: "VdbeState  vdbe.c  [M3-M6]"
      +cursors: "BTreeCursor*[16]"
      +regs: "Value[1024]"
      +pc: "int"
      +result_out: "FILE*"
      +db: "DB*"
      +error: "char[256]"
      +had_error: "int"
      +auto_commit: "int"
      +delete_rowids: "int64_t*"
      +delete_count: "int"
      +wal_reader_snapshot: "int"
      +vdbe_execute(prog, db, out): "int"
      -value_compare(a, b): "int"
      -value_is_truthy(v): "int"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_buffer: {
    direction: down
    label: "BUFFER POOL  (buffer_pool.c)  [M4]"
    style.fill: "#EEFAF0"
    style.stroke: "#3A9A5C"
    frame: {
      shape: sql_table
      label: "struct Frame  (buffer_pool.c)  [M4]"
      page_id: "PageId   | UINT32_MAX=empty"
      data: "uint8_t[4096] | page bytes"
      pin_count: "int      | active pins"
      is_dirty: "int      | modified flag"
      lru_prev: "int      | LRU list prev"
      lru_next: "int      | LRU list next"
      sz: "Total: ~4120 bytes per frame"
    }
    page_table_entry: {
      shape: sql_table
      label: "struct PageTableEntry  (buffer_pool.c)  [M4]"
      page_id: "PageId              | key"
      frame_index: "int                 | value"
      next: "PageTableEntry*     | chain"
      sz: "Total: ~16 bytes"
    }
    buf_pool_stats: {
      shape: sql_table
      label: "struct BufferPoolStats  (buffer_pool.h)  [M4]"
      fetches: "uint64_t | total FetchPage calls"
      hits: "uint64_t | cache hits"
      misses: "uint64_t | disk loads"
      evictions: "uint64_t | frames evicted"
      dirty_writes: "uint64_t | pages flushed"
    }
    buffer_pool: {
      shape: class
      label: "BufferPool  buffer_pool.c  [M4]"
      -fd: "int"
      -frames: "Frame*"
      -pool_size: "int"
      -next_page_id: "PageId"
      -page_table: "PageTableEntry**"
      -page_table_size: "int"
      -lru_head: "int"
      -lru_tail: "int"
      -stats: "BufferPoolStats"
      -db: "DB*"
      +buffer_pool_create(fd, frames): "BufferPool*"
      +buffer_pool_destroy(bp): "void"
      +buffer_pool_fetch(bp, page_id): "uint8_t*"
      +buffer_pool_get_for_write(bp, pid): "uint8_t*"
      +buffer_pool_unpin(bp, pid, dirty): "void"
      +buffer_pool_new_page(bp, pid_out): "uint8_t*"
      +buffer_pool_flush_page(bp, pid): "int"
      +buffer_pool_flush_all(bp): "int"
      +buffer_pool_invalidate_dirty(bp): "void"
      +buffer_pool_get_stats(bp, out): "void"
      -evict_lru(bp): "int"
      -lru_move_to_head(bp, idx): "void"
      -write_page_to_disk(bp, idx): "int"
    }
  }
  layer_btree: {
    direction: down
    label: "B-TREE STORAGE ENGINE  (btree.c)  [M5]"
    style.fill: "#FFF0F5"
    style.stroke: "#C0508A"
    page_type: {
      shape: sql_table
      label: "enum PageType  (btree.h)  [M5]"
      PAGE_TYPE_TABLE_LEAF: "0x0D | rows + rowids"
      PAGE_TYPE_TABLE_INTERNAL: "0x05 | separator keys"
      PAGE_TYPE_INDEX_LEAF: "0x0A | key,rowid pairs"
      PAGE_TYPE_INDEX_INTERNAL: "0x02 | index separators"
    }
    page_header: {
      shape: sql_table
      label: "struct PageHeader  (btree.h)  [M5]"
      page_type: "uint8_t  | offset 0"
      first_freeblock: "uint16_t | offset 1, BE"
      cell_count: "uint16_t | offset 3, BE"
      cell_content_area: "uint16_t | offset 5, BE"
      fragmented_bytes: "uint8_t  | offset 7"
      right_child: "uint32_t | offset 8, BE"
      sz: "Total: 12 bytes, big-endian"
    }
    btree: {
      shape: class
      label: "BTree  btree.c  [M5]"
      +bp: "BufferPool*"
      +root_page_id: "PageId"
      +table_name: "char*"
      +db: "DB*"
      +btree_open(bp, root): "BTree*"
      +btree_insert(bt, cols, n, rowid): "int"
      +btree_delete_by_rowid(bt, rowid): "int"
      +btree_search(bp, root, rowid, slot): "PageId"
      +btree_next_rowid(cur): "int64_t"
      +btree_approximate_row_count(db, tbl): "int64_t"
      -page_insert_cell(page, data, len, pos): "int"
      -page_delete_cell(page, idx): "void"
      -page_defragment(page): "void"
      -page_free_space(page): "uint16_t"
      -leaf_split(bp, lid, cell, len, rid, res): "void"
    }
    btree_cursor: {
      shape: class
      label: "BTreeCursor  btree.c  [M5-M6]"
      +bt: "BTree*"
      +leaf_page_id: "PageId"
      +slot: "int"
      +at_end: "int"
      +write_mode: "int"
      +current_page: "uint8_t*"
      +btree_cursor_open(db, root, write): "BTreeCursor*"
      +btree_cursor_rewind(cur): "int"
      +btree_cursor_next(cur): "int"
      +btree_cursor_column(cur, col, out): "void"
      +btree_cursor_rowid(cur): "int64_t"
      +btree_cursor_insert(cur, rowid, rec, len): "int"
      +btree_cursor_close(cur): "void"
    }
    record_codec: {
      shape: class
      label: "RecordCodec  btree.c  [M5]"
      +record_encode(cols, n, out_len): "uint8_t*"
      +record_decode_column(rec, len, col, out): "void"
      +varint_encode(val, buf): "int"
      +varint_decode(buf, bytes_read): "uint64_t"
      +varint_length(val): "int"
      -serial_type_for_value(v): "uint64_t"
      -serial_type_data_size(st): "int"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_schema: {
    direction: down
    label: "SCHEMA & INDEXES  (schema.c, index.c)  [M5-M7]"
    style.fill: "#F5F0FF"
    style.stroke: "#7B5EA7"
    schema_table: {
      shape: class
      label: "SchemaTable  schema.h  [M5]"
      +name: "char*"
      +columns: "ColumnDef*"
      +column_count: "int"
      +root_page_id: "PageId"
      +indexes: "IndexDescriptor*"
      +index_count: "int"
      +schema_load(db): "int"
      +schema_find_table(db, name): "PageId"
      +schema_get_table(db, name): "SchemaTable*"
      +schema_register_table(db, name, root, sql): "int"
      +schema_get_column_index(s, name): "int"
      +schema_next_rowid(db): "int64_t"
      +schema_update_root(db, tbl, root): "void"
    }
    index_descriptor: {
      shape: sql_table
      label: "struct IndexDescriptor  (schema.h)  [M7]"
      index_name: "char*   | heap string"
      table_name: "char*   | heap string"
      col_indices: "int*    | schema col indices"
      col_count: "int     | columns in index"
      root_page_id: "PageId  | B+tree root"
      is_unique: "int     | UNIQUE flag"
    }
    index_cursor: {
      shape: class
      label: "IndexCursor  index.c  [M7]"
      +index_bt: "BTree*"
      +leaf_page_id: "PageId"
      +slot: "int"
      +at_end: "int"
      +index_cursor_open(cur, bt): "void"
      +index_cursor_rewind(cur): "int"
      +index_cursor_next(cur): "int"
      +index_cursor_read_key(cur, out): "void"
      +index_cursor_read_rowid(cur): "int64_t"
      +index_cursor_seek_eq(cur, key): "int"
      +index_cursor_seek_ge(cur, key): "int"
      +index_cursor_close(cur): "void"
    }
    index_ops: {
      shape: class
      label: "IndexOps  index.c  [M7]"
      +index_insert(bt, key, rowid): "int"
      +index_delete(bt, key, rowid): "int"
      +index_contains_key(bt, key): "int"
      +index_check_unique(db, desc, key): "int"
      +index_build_from_table(db, desc): "int"
      +index_maintain_insert(db, s, cols, n, rid): "int"
      +index_maintain_delete(db, s, rowid): "int"
      +index_maintain_update(db, s, rid, old, new): "int"
    }
  }
  layer_planner: {
    direction: down
    label: "QUERY PLANNER & STATISTICS  (planner.c)  [M8]"
    style.fill: "#FFFBEE"
    style.stroke: "#B8860B"
    stat_entry: {
      shape: sql_table
      label: "struct StatEntry  (statistics.h)  [M8]"
      table_name: "char*   | heap string"
      index_name: "char*   | NULL=table-level"
      total_rows: "int64_t | row count"
      distinct_vals: "int64_t | distinct values"
    }
    stat_cache: {
      shape: class
      label: "StatCache  statistics.c  [M8]"
      +entries: "StatEntry*"
      +count: "int"
      +capacity: "int"
      +stat_cache_load(db, sc): "int"
      +stat_cache_free(sc): "void"
      +stat_table_rows(sc, tbl): "int64_t"
      +stat_index_distinct(sc, tbl, idx): "int64_t"
    }
    access_path: {
      shape: sql_table
      label: "struct AccessPath  (planner.h)  [M8]"
      type: "AccessType | TABLE_SCAN or INDEX_SCAN"
      index_name: "char*      | NULL for table scan"
      selectivity: "double     | fraction matched"
      cost: "double     | estimated page reads"
      estimated_rows: "int64_t    | rows in output"
    }
    plan_node: {
      shape: sql_table
      label: "struct PlanNode  (planner.h)  [M8]"
      table_name: "char*      | heap string"
      access_type: "AccessType | scan or index"
      index_name: "char*      | NULL if scan"
      estimated_rows: "double     | cardinality est."
      estimated_cost: "double     | page reads"
      selectivity: "double     | predicate sel."
    }
    planner: {
      shape: class
      label: "Planner  planner.c  [M8]"
      +planner_choose_access_path(db, tbl, pred, out): "void"
      +analyze_execute(db): "int"
      +planner_join_order_dp(db, tables, n, jp, fp, out): "int"
      +estimate_selectivity(sc, tbl, idx, op): "double"
      -cost_table_scan(sc, tbl): "double"
      -cost_index_scan(sc, tbl, idx, sel): "double"
      -find_usable_index(s, pred, op_out): "IndexDescriptor*"
      -analyze_count_rows(db, schema): "int64_t"
      -analyze_count_distinct(db, s, idx): "int64_t"
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_txn: {
    direction: down
    label: "TRANSACTIONS — ROLLBACK JOURNAL  (transaction.c)  [M9]"
    style.fill: "#FFF0E8"
    style.stroke: "#C05000"
    txn_state: {
      shape: sql_table
      label: "enum TxnState  (transaction.h)  [M9]"
      TXN_STATE_NONE: "0 | no active txn"
      TXN_STATE_ACTIVE: "1 | in-progress"
      TXN_STATE_COMMITTING: "2 | commit in flight"
      TXN_STATE_ROLLING_BACK: "3 | rollback in flight"
    }
    transaction: {
      shape: sql_table
      label: "struct Transaction  (transaction.h)  [M9]"
      state: "TxnState  | current state"
      journal_fd: "int       | journal file fd"
      journal_path: "char*     | path to .db-journal"
      page_count: "uint32_t  | pages at txn start"
      nonce: "uint32_t  | random for checksums"
      journaled_pages: "uint32_t* | sorted page IDs"
      journaled_count: "int       | num journaled"
      journaled_capacity: "int       | array capacity"
    }
    txn_ops: {
      shape: class
      label: "TxnOps  transaction.c  [M9]"
      +txn_begin(db): "int"
      +txn_commit(db): "int"
      +txn_rollback(db): "int"
      +txn_recover(db): "int"
      +txn_journal_page(db, pid, orig): "int"
      -txn_create_journal(db): "int"
      -txn_restore_from_journal(db): "int"
      -txn_page_is_journaled(db, pid): "int"
      -txn_mark_page_journaled(db, pid): "void"
      -journal_write_header(fd, pcount, nonce, psize): "int"
      -journal_checksum(nonce, pid, data): "uint32_t"
      -ensure_transaction(vm): "int"
      -maybe_auto_commit(vm): "int"
    }
  }
  layer_wal: {
    direction: down
    label: "WAL MODE  (wal.c)  [M10]"
    style.fill: "#E8F4FF"
    style.stroke: "#1A5FAA"
    wal_header: {
      shape: sql_table
      label: "struct WalHeader  (wal.h)  [M10]"
      magic: "uint32_t | 0x377f0682"
      file_format: "uint32_t | 3007000"
      page_size: "uint32_t | 4096, BE"
      checkpoint_seq: "uint32_t | monotonic, BE"
      salt1: "uint32_t | random resets per checkpoint"
      salt2: "uint32_t | random resets per checkpoint"
      cksum1: "uint32_t | cumulative checksum"
      cksum2: "uint32_t | cumulative checksum"
      sz: "Total: 32 bytes"
    }
    wal_frame_hdr: {
      shape: sql_table
      label: "struct WalFrameHdr  (wal.h)  [M10]"
      page_no: "uint32_t | 1-based page num, BE"
      db_size: "uint32_t | non-zero=commit frame"
      salt1: "uint32_t | must match WAL hdr"
      salt2: "uint32_t | must match WAL hdr"
      cksum1: "uint32_t | running checksum"
      cksum2: "uint32_t | running checksum"
      frame_data: "uint8_t[4096] | full page image"
      sz: "Total: WAL_FRAME_HDRSIZE(24) + PAGE_SIZE"
    }
    wal_index_entry: {
      shape: sql_table
      label: "struct WalIndexEntry  (wal.c)  [M10]"
      page_no: "uint32_t | UINT32_MAX=empty"
      frame_idx: "uint32_t | 0-based frame index"
      sz: "Total: 8 bytes per slot"
    }
    wal_index: {
      shape: sql_table
      label: "struct WalIndex  (wal.c)  [M10]"
      slots: "WalIndexEntry[65536] | open-address hash"
      frame_count: "int             | total frames written"
      write_lock: "int             | 1 if writer holds"
      min_reader_snapshot: "int             | oldest active snapshot"
    }
    wal: {
      shape: class
      label: "Wal  wal.c  [M10]"
      +fd: "int"
      +path: "char*"
      +index: "WalIndex"
      +header: "WalHeader"
      +run_cksum1: "uint32_t"
      +run_cksum2: "uint32_t"
      +write_lock: "int"
      +wal_open(db_path, page_size): "Wal*"
      +wal_close(wal): "void"
      +wal_begin_write(wal): "int"
      +wal_write_frame(wal, pno, data, commit, dbsz): "int"
      +wal_commit(wal): "int"
      +wal_begin_read(wal): "int"
      +wal_end_read(wal, snap): "void"
      +wal_find_frame(wal, pno, end_frame): "int"
      +wal_read_frame(wal, frame_idx, buf): "int"
      +wal_checkpoint(wal, db_fd): "int"
      +wal_recover(wal): "int"
      +wal_frame_count(wal): "int"
      -wal_checksum_bytes(data, n, c1, c2): "void"
      -walindex_insert(idx, pno, fidx): "void"
      -walindex_lookup(idx, pno, end): "int"
    }
  }
  layer_db: {
    direction: down
    label: "DATABASE HANDLE  (db.c)  [M1-M10]"
    style.fill: "#F0F0F0"
    style.stroke: "#555555"
    db: {
      shape: sql_table
      label: "struct DB  (db.h)  [M1-M10]"
      fd: "int           | main db file fd"
      path: "char*         | file path"
      bp: "BufferPool*   | buffer pool"
      wal: "Wal*          | NULL if journal mode"
      txn: "Transaction   | embedded txn state"
      stat_cache: "StatCache     | in-memory stats"
      journal_mode: "int           | JOURNAL or WAL"
      wal_auto_checkpoint: "int           | default 1000 frames"
      wal_reader_snapshot: "int           | end_frame for reads"
      error: "char[256]     | last error msg"
      schema_info: "SchemaTable*  | loaded on open"
      schema_count: "int           | table count"
    }
  }
}
milestone_index: {
  shape: sql_table
  label: "Milestone Index — Build Your Own SQLite"
  m1: "M1 | build-sqlite-m1 | SQL Tokenizer (tokenizer.h, tokenizer.c)"
  m2: "M2 | build-sqlite-m2 | SQL Parser and AST (parser.h, parser.c)"
  m3: "M3 | build-sqlite-m3 | VDBE Bytecode Compiler and VM (vdbe.h, vdbe.c)"
  m4: "M4 | build-sqlite-m4 | Buffer Pool Manager (buffer_pool.h, buffer_pool.c)"
  m5: "M5 | build-sqlite-m5 | B-tree Page Format and Table Storage (btree.h, btree.c)"
  m6: "M6 | build-sqlite-m6 | SELECT Execution and DML with three-valued logic"
  m7: "M7 | build-sqlite-m7 | Secondary Indexes (index.h, index.c)"
  m8: "M8 | build-sqlite-m8 | Query Planner and Statistics (planner.h, planner.c)"
  m9: "M9 | build-sqlite-m9 | Transactions and Rollback Journal (transaction.h, transaction.c)"
  m10: "M10 | build-sqlite-m10 | WAL Mode (wal.h, wal.c)"
  sqlite_master: "SYS | sqlite_master page 1 | system catalog (type,name,tbl_name,rootpage,sql)"
  page_fmt: "FMT | 4096-byte pages | big-endian, PageId=offset/4096"
  varint: "ENC | varint 1-9 bytes | SQLite Base-128 variable-length int"
}
# ── Frontend internal edges ──
row1.layer_frontend.lexer -> row1.layer_frontend.token: "returns Token"
row1.layer_frontend.token -> row1.layer_frontend.token_type: "type field"
row1.layer_frontend.parser -> row1.layer_frontend.lexer: "lexer_tokenize_all"
row1.layer_frontend.parser -> row1.layer_frontend.ast_node: "builds AstNode*"
row1.layer_frontend.ast_node -> row1.layer_frontend.node_type: "type field"
row1.layer_frontend.ast_node -> row1.layer_frontend.column_def: "union_create"
# ── Execution internal edges ──
row2.layer_execution.vdbe_compiler -> row2.layer_execution.program: "emit builds"
row2.layer_execution.program -> row2.layer_execution.instruction: "instructions[]"
row2.layer_execution.instruction -> row2.layer_execution.opcode: "opcode field"
row2.layer_execution.vdbe_state -> row2.layer_execution.program: "executes"
row2.layer_execution.vdbe_state -> row2.layer_execution.value: "regs[1024]"
row2.layer_execution.value -> row2.layer_execution.value_type: "type field"
row2.layer_execution.program -> row2.layer_execution.plan_node: "plan_nodes[]"
# ── Frontend → Execution ──
row2.layer_execution.vdbe_compiler -> row1.layer_frontend.ast_node: "AST input"
# ── Execution → Buffer Pool ──
row2.layer_execution.vdbe_state -> row3.layer_buffer.buffer_pool: "OP_COLUMN fetch"
# ── Buffer Pool internal edges ──
row3.layer_buffer.buffer_pool -> row3.layer_buffer.frame: "frames[] array"
row3.layer_buffer.buffer_pool -> row3.layer_buffer.page_table_entry: "page_table hash"
row3.layer_buffer.buffer_pool -> row3.layer_buffer.buf_pool_stats: "stats field"
# ── B-tree internal edges ──
row3.layer_btree.btree -> row3.layer_buffer.buffer_pool: "fetch / unpin"
row3.layer_btree.btree_cursor -> row3.layer_btree.btree: "bt field"
row3.layer_btree.btree -> row3.layer_btree.page_header: "read/write hdr"
row3.layer_btree.btree -> row3.layer_btree.page_type: "page_type field"
row3.layer_btree.record_codec -> row2.layer_execution.value: "Value[] cols encode"
row3.layer_btree.btree_cursor -> row3.layer_btree.record_codec: "decode column"
# ── Schema/Index edges ──
row4.layer_schema.schema_table -> row3.layer_btree.btree: "root_page_id open"
row4.layer_schema.schema_table -> row4.layer_schema.index_descriptor: "indexes[]"
row4.layer_schema.schema_table -> row1.layer_frontend.column_def: "columns[]"
row4.layer_schema.index_cursor -> row3.layer_buffer.buffer_pool: "WAL-aware fetch"
row4.layer_schema.index_ops -> row4.layer_schema.index_cursor: "seek / next"
row4.layer_schema.index_ops -> row4.layer_schema.schema_table: "maintain indexes"
# ── Planner edges ──
row4.layer_planner.stat_cache -> row4.layer_planner.stat_entry: "entries[]"
row4.layer_planner.planner -> row4.layer_planner.stat_cache: "lookup stats"
row4.layer_planner.planner -> row4.layer_planner.access_path: "output plan"
row4.layer_planner.access_path -> row4.layer_planner.plan_node: "used in Program"
row4.layer_planner.planner -> row4.layer_schema.index_descriptor: "find usable index"
row2.layer_execution.vdbe_compiler -> row4.layer_planner.planner: "access path query"
# ── Transaction edges ──
row5.layer_txn.transaction -> row5.layer_txn.txn_state: "state field"
row5.layer_txn.txn_ops -> row5.layer_txn.transaction: "mutates state"
row5.layer_txn.txn_ops -> row3.layer_buffer.buffer_pool: "journal before write"
row3.layer_buffer.buffer_pool -> row5.layer_txn.txn_ops: "txn_journal_page hook"
# ── WAL edges ──
row5.layer_wal.wal -> row5.layer_wal.wal_header: "header field"
row5.layer_wal.wal -> row5.layer_wal.wal_index: "index field"
row5.layer_wal.wal_index -> row5.layer_wal.wal_index_entry: "slots[65536]"
row5.layer_wal.wal_frame_hdr -> row5.layer_wal.wal_header: "salt must match"
# ── DB handle edges ──
row5.layer_db.db -> row5.layer_txn.transaction: "txn embedded"
row5.layer_db.db -> row5.layer_wal.wal: "wal ptr"
row5.layer_db.db -> row3.layer_buffer.buffer_pool: "bp ptr"
row5.layer_db.db -> row4.layer_planner.stat_cache: "stat_cache field"
row5.layer_db.db -> row4.layer_schema.schema_table: "schema_info[]"