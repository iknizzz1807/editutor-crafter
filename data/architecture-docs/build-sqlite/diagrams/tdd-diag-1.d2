vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # Tokenizer Finite State Machine
  Complete state transitions with character classes and emitted token types
| {near: top-center}

classes: {
  state: {
    style: {
      border-radius: 8
      font-size: 14
      bold: true
    }
  }
  accept: {
    style: {
      border-radius: 8
      font-size: 14
      bold: true
      fill: "#4CAF50"
      font-color: white
    }
  }
  error_state: {
    style: {
      border-radius: 8
      font-size: 14
      bold: true
      fill: "#F44336"
      font-color: white
    }
  }
  initial_point: {
    shape: circle
    style: {
      fill: "#1a1a2e"
      font-color: white
      bold: true
    }
  }
  emit: {
    style: {
      stroke-dash: 5
      font-color: "#666"
      font-size: 12
      italic: true
    }
  }
}

# ── States ──────────────────────────────────────────────

start: ● {
  shape: circle
  width: 30
  height: 30
  style.fill: "#1a1a2e"
  style.font-color: white
}

INITIAL: "INITIAL\n─────────────\nDispatch on\nfirst character" {
  class: state
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
  style.stroke-width: 3
}

IN_IDENT: "IN_IDENT\n─────────────\nAccumulating\n[a-zA-Z0-9_]" {
  class: state
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}

IN_NUMBER: "IN_NUMBER\n─────────────\nAccumulating\ndigits / dot / e" {
  class: state
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
}

IN_STRING: "IN_STRING\n─────────────\nInside '...'\nwith '' escape" {
  class: state
  style.fill: "#FCE4EC"
  style.stroke: "#C62828"
}

IN_QUOTED_ID: "IN_QUOTED_ID\n─────────────\nInside \"...\"\nidentifier" {
  class: state
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}

IN_LINE_COMMENT: "IN_LINE_COMMENT\n─────────────\nAfter --\nskipping to EOL" {
  class: state
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
}

IN_BLOCK_COMMENT: "IN_BLOCK_COMMENT\n─────────────\nAfter /*\nseeking */" {
  class: state
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
}

IN_OPERATOR: "IN_OPERATOR\n─────────────\n1-char lookahead\nfor multi-char ops" {
  class: state
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
}

IN_FLOAT: "IN_FLOAT\n─────────────\nAfter decimal dot\nor exponent 'e'" {
  class: state
  style.fill: "#FFF8E1"
  style.stroke: "#FFA000"
}

DONE: "DONE\n─────────────\nToken emitted\nReturn to caller" {
  class: accept
}

ERROR: "ERROR\n─────────────\nTOK_ERROR emitted\nAdvance 1 char" {
  class: error_state
}

EOF_STATE: "EOF\n─────────────\nTOK_EOF emitted\nIdempotent" {
  class: accept
  style.fill: "#263238"
  style.font-color: white
}

# ── Emit annotations ───────────────────────────────────

emit_kw_or_id: "→ TOK_KEYWORD\n  or TOK_IDENTIFIER\n  (bsearch kw_table)" {
  class: emit
  style.fill: transparent
  style.stroke: transparent
}

emit_int: "→ TOK_INTEGER" {
  class: emit
  style.fill: transparent
  style.stroke: transparent
}

emit_float: "→ TOK_FLOAT" {
  class: emit
  style.fill: transparent
  style.stroke: transparent
}

emit_string: "→ TOK_STRING" {
  class: emit
  style.fill: transparent
  style.stroke: transparent
}

emit_quoted: "→ TOK_QUOTED_ID" {
  class: emit
  style.fill: transparent
  style.stroke: transparent
}

emit_op: "→ TOK_EQ / TOK_NE\n  TOK_LT / TOK_LE\n  TOK_GT / TOK_GE\n  TOK_PIPE2 / etc." {
  class: emit
  style.fill: transparent
  style.stroke: transparent
}

emit_punct: "→ TOK_LPAREN\n  TOK_RPAREN\n  TOK_COMMA\n  TOK_SEMICOLON\n  TOK_DOT\n  TOK_STAR\n  TOK_PLUS etc." {
  class: emit
  style.fill: transparent
  style.stroke: transparent
}

# ── Transitions ─────────────────────────────────────────

start -> INITIAL: "lexer_next_token()" {
  style.stroke: "#1a1a2e"
  style.stroke-width: 2
}

# ── From INITIAL ──
INITIAL -> IN_IDENT: "[a-zA-Z] or '_'" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
INITIAL -> IN_NUMBER: "[0-9]" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}
INITIAL -> IN_STRING: "single quote  '" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
INITIAL -> IN_QUOTED_ID: "double quote  \"" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
INITIAL -> IN_OPERATOR: "< > ! | = (multi-char start)" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
INITIAL -> IN_LINE_COMMENT: "'--' (dash + dash)" {
  style.stroke: "#607D8B"
  style.stroke-width: 2
  style.stroke-dash: 3
}
INITIAL -> IN_BLOCK_COMMENT: "'/*' (slash + star)" {
  style.stroke: "#607D8B"
  style.stroke-width: 2
  style.stroke-dash: 3
}
INITIAL -> DONE: '( ) , ; . + * / % ~ ? : @ $ \n (single-char punctuation)' {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
INITIAL -> EOF_STATE: "NUL or pos >= length" {
  style.stroke: "#263238"
  style.stroke-width: 3
}
INITIAL -> ERROR: "unrecognized char\n(backtick, #, etc.)" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 5
}
INITIAL -> INITIAL: "whitespace [ \\t\\r\\n]\n(skip, update line/col)" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
}

# ── IN_IDENT transitions ──
IN_IDENT -> IN_IDENT: "[a-zA-Z0-9_]\n(continue accumulating)" {
  style.stroke: "#1976D2"
  style.stroke-dash: 3
}
IN_IDENT -> DONE: "other char (not consumed)\n─── keyword_lookup() ───" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
IN_IDENT -> emit_kw_or_id

# ── IN_NUMBER transitions ──
IN_NUMBER -> IN_NUMBER: "[0-9]\n(continue digits)" {
  style.stroke: "#F57C00"
  style.stroke-dash: 3
}
IN_NUMBER -> IN_FLOAT: "'.' followed by [0-9]\nor 'e'/'E'" {
  style.stroke: "#FFA000"
  style.stroke-width: 2
}
IN_NUMBER -> DONE: "non-digit, non-dot\n(not consumed)" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
IN_NUMBER -> emit_int

# ── IN_FLOAT transitions ──
IN_FLOAT -> IN_FLOAT: "[0-9] or [eE+-]\n(fractional / exponent)" {
  style.stroke: "#FFA000"
  style.stroke-dash: 3
}
IN_FLOAT -> DONE: "non-digit after fraction\nor exponent complete" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
IN_FLOAT -> emit_float

# ── IN_STRING transitions ──
IN_STRING -> IN_STRING: "any char except '\nor NUL (accumulate)" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
IN_STRING -> IN_STRING: "'' (escaped quote)\nconsume both, stay" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.font-color: "#C62828"
}
IN_STRING -> DONE: "closing ' (not '')\nstring complete" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
IN_STRING -> ERROR: "NUL / EOF before closing '\n→ unterminated string" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 5
}
IN_STRING -> emit_string

# ── IN_QUOTED_ID transitions ──
IN_QUOTED_ID -> IN_QUOTED_ID: "any char except \"\nor NUL" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}
IN_QUOTED_ID -> DONE: "closing \"\nidentifier complete" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
IN_QUOTED_ID -> ERROR: "NUL / EOF before closing \"\n→ unterminated quoted id" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 5
}
IN_QUOTED_ID -> emit_quoted

# ── IN_OPERATOR transitions ──
IN_OPERATOR -> DONE: "second char matches:\n<= >= != <> << >> ||\n→ emit 2-char token" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
IN_OPERATOR -> DONE: "second char does NOT match:\n< > ! (alone)\n→ emit 1-char token\n  (! alone → TOK_ERROR)" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.stroke-dash: 3
}
IN_OPERATOR -> emit_op

# ── IN_LINE_COMMENT transitions ──
IN_LINE_COMMENT -> IN_LINE_COMMENT: "any char except\n\\n and NUL\n(skip)" {
  style.stroke: "#607D8B"
  style.stroke-dash: 3
}
IN_LINE_COMMENT -> INITIAL: "'\\n' or EOF\ncomment ends\nrestart dispatch" {
  style.stroke: "#3F51B5"
  style.stroke-width: 2
}

# ── IN_BLOCK_COMMENT transitions ──
IN_BLOCK_COMMENT -> IN_BLOCK_COMMENT: "any char except\n'*/' sequence\n(skip, track line/col)" {
  style.stroke: "#607D8B"
  style.stroke-dash: 3
}
IN_BLOCK_COMMENT -> INITIAL: "'*/' found\ncomment ends\nrestart dispatch" {
  style.stroke: "#3F51B5"
  style.stroke-width: 2
}
IN_BLOCK_COMMENT -> ERROR: "NUL / EOF before '*/'\n→ unterminated block comment" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 5
}

# ── Terminal states ──
DONE -> INITIAL: "next call to\nlexer_next_token()" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5
}
ERROR -> INITIAL: "advance(1) past bad char\nnext call resumes" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5
}
EOF_STATE -> EOF_STATE: "repeated calls\nreturn TOK_EOF\n(idempotent)" {
  style.stroke: "#455A64"
  style.stroke-dash: 3
}
DONE -> emit_punct

# ── Legend ──
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 8
  grid-columns: 4
  grid-gap: 0
  solid: "─── Solid arrow" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
  }
  solid_desc: "Primary transition" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.italic: true
  }
  dash: "┄┄┄ Dashed arrow" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
  }
  dash_desc: "Self-loop / secondary" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.italic: true
  }
  green: "■ Green state" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#4CAF50"
  }
  green_desc: "Accept (token emitted)" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.italic: true
  }
  red: "■ Red state" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#F44336"
  }
  red_desc: "Error (TOK_ERROR)" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.italic: true
  }
}