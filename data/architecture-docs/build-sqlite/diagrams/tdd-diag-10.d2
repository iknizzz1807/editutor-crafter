vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  ## VM Execution Trace — `SELECT name FROM users WHERE id > 2`
  **3-row table:** (1,'alice'), (2,'bob'), (3,'carol')
|| {
  near: top-center
}

direction: down

classes: {
  pc-box: {
    style: {
      font: mono
      font-size: 14
      border-radius: 5
      stroke-width: 2
    }
  }
  active: {
    label: ""
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      bold: true
    }
  }
  skipped: {
    label: ""
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-dash: 3
    }
  }
  emit: {
    label: ""
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      bold: true
      font-size: 16
    }
  }
  halt: {
    label: ""
    style: {
      fill: "#F3E5F5"
      stroke: "#6A1B9A"
      bold: true
    }
  }
  reg: {
    style: {
      fill: "#FFF8E1"
      stroke: "#F57F17"
      font: mono
      font-size: 12
      border-radius: 3
    }
  }
  phase-header: {
    style: {
      fill: "#37474F"
      font-color: "#FFFFFF"
      bold: true
      font-size: 15
      border-radius: 6
    }
  }
}

# ────────────────────────────────────────
#  PROGRAM LISTING (reference)
# ────────────────────────────────────────
program: ||md
  ### Bytecode Program
  
  | addr | opcode | p1 | p2 | p3 | comment |
  | :--- | :--- | :--- | :--- | :--- | :--- |
  | 0 | **OpenRead** | 0 | 2 | 2 | cursor=0 root=2 cols=2 |
  | 1 | **Rewind** | 0 | 7 | 0 | if empty → Halt |
  | 2 | **Column** | 0 | 0 | 1 | id → r1 |
  | 3 | **Integer** | 2 | 2 | 0 | 2 → r2 |
  | 4 | **Le** | 1 | 6 | 2 | if r1 ≤ r2 → Next |
  | 5 | **Column** | 0 | 1 | 3 | name → r3 |
  | 6 | **ResultRow** | 3 | 1 | 0 | output r3 |
  | 7 | **Next** | 0 | 2 | 0 | advance; loop |
  | 8 | **Halt** | 0 | 0 | 0 | done |
|| {
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    border-radius: 8
    font-size: 13
  }
}

# ────────────────────────────────────────
#  ROW 1: id=1, name='alice'
# ────────────────────────────────────────
row1-header: "── Row 1: (id=1, name='alice') ──" {
  class: phase-header
}

program -> row1-header: "vm_execute() begins" {
  style: {
    stroke: "#37474F"
    bold: true
  }
}

r1-pc0: ||md
  **pc=0** `OP_OpenRead`
  cursor 0 → table root page 2
  (2 columns: id, name)
|| {
  class: [pc-box; active]
}

r1-pc1: ||md
  **pc=1** `OP_Rewind`
  cursor 0 → first row
  table not empty → fall through
|| {
  class: [pc-box; active]
}

r1-pc2: ||md
  **pc=2** `OP_Column(0, 0, r1)`
  read col 0 (id) from cursor 0
|| {
  class: [pc-box; active]
}

r1-reg-a: "r1 = **1** (INTEGER)" {
  class: reg
  style.font-color: "#C62828"
}

r1-pc3: ||md
  **pc=3** `OP_Integer(2, r2)`
  load constant 2
|| {
  class: [pc-box; active]
}

r1-reg-b: "r2 = **2** (INTEGER)" {
  class: reg
  style.font-color: "#C62828"
}

r1-pc4: ||md
  **pc=4** `OP_Le(r1, p2=7, r2)`
  r1(1) ≤ r2(2)?  → **TRUE**
  **JUMP to pc=7 (Next)**
|| {
  class: [pc-box; skipped]
}

r1-skip: ||md
  pc=5,6 **SKIPPED**
  (row filtered out — id=1 not > 2)
|| {
  class: [pc-box; skipped]
}

r1-pc7: ||md
  **pc=7** `OP_Next(0, p2=2)`
  advance cursor 0 → row 2 exists
  **JUMP back to pc=2**
|| {
  class: [pc-box; active]
}

row1-header -> r1-pc0
r1-pc0 -> r1-pc1: "pc++"
r1-pc1 -> r1-pc2: "pc++"
r1-pc2 -> r1-reg-a: "write" {
  style.stroke: "#F57F17"
  style.stroke-dash: 3
}
r1-pc2 -> r1-pc3: "pc++"
r1-pc3 -> r1-reg-b: "write" {
  style.stroke: "#F57F17"
  style.stroke-dash: 3
}
r1-pc3 -> r1-pc4: "pc++"
r1-pc4 -> r1-skip: "1 ≤ 2 → TRUE → jump" {
  style.stroke: "#C62828"
  style.bold: true
}
r1-skip -> r1-pc7: "pc = 7"
r1-pc7 -> row2-header: "has_next = true\npc = 2" {
  style.stroke: "#2E7D32"
  style.bold: true
  style.animated: true
}

# ────────────────────────────────────────
#  ROW 2: id=2, name='bob'
# ────────────────────────────────────────
row2-header: "── Row 2: (id=2, name='bob') ──" {
  class: phase-header
}

r2-pc2: ||md
  **pc=2** `OP_Column(0, 0, r1)`
  read col 0 (id) from cursor 0
|| {
  class: [pc-box; active]
}

r2-reg-a: "r1 = **2** (INTEGER)" {
  class: reg
  style.font-color: "#C62828"
}

r2-pc3: ||md
  **pc=3** `OP_Integer(2, r2)`
  load constant 2
|| {
  class: [pc-box; active]
}

r2-reg-b: "r2 = 2  (INTEGER)" {
  class: reg
}

r2-pc4: ||md
  **pc=4** `OP_Le(r1, p2=7, r2)`
  r1(2) ≤ r2(2)?  → **TRUE**
  **JUMP to pc=7 (Next)**
|| {
  class: [pc-box; skipped]
}

r2-skip: ||md
  pc=5,6 **SKIPPED**
  (row filtered out — id=2 not > 2)
|| {
  class: [pc-box; skipped]
}

r2-pc7: ||md
  **pc=7** `OP_Next(0, p2=2)`
  advance cursor 0 → row 3 exists
  **JUMP back to pc=2**
|| {
  class: [pc-box; active]
}

row2-header -> r2-pc2
r2-pc2 -> r2-reg-a: "write" {
  style.stroke: "#F57F17"
  style.stroke-dash: 3
}
r2-pc2 -> r2-pc3: "pc++"
r2-pc3 -> r2-reg-b: "write" {
  style.stroke: "#F57F17"
  style.stroke-dash: 3
}
r2-pc3 -> r2-pc4: "pc++"
r2-pc4 -> r2-skip: "2 ≤ 2 → TRUE → jump" {
  style.stroke: "#C62828"
  style.bold: true
}
r2-skip -> r2-pc7: "pc = 7"
r2-pc7 -> row3-header: "has_next = true\npc = 2" {
  style.stroke: "#2E7D32"
  style.bold: true
  style.animated: true
}

# ────────────────────────────────────────
#  ROW 3: id=3, name='carol'  ← MATCH
# ────────────────────────────────────────
row3-header: "── Row 3: (id=3, name='carol') ── ★ MATCH" {
  class: phase-header
  style.fill: "#1B5E20"
}

r3-pc2: ||md
  **pc=2** `OP_Column(0, 0, r1)`
  read col 0 (id) from cursor 0
|| {
  class: [pc-box; active]
}

r3-reg-a: "r1 = **3** (INTEGER)" {
  class: reg
  style.font-color: "#C62828"
}

r3-pc3: ||md
  **pc=3** `OP_Integer(2, r2)`
  load constant 2
|| {
  class: [pc-box; active]
}

r3-reg-b: "r2 = 2  (INTEGER)" {
  class: reg
}

r3-pc4: ||md
  **pc=4** `OP_Le(r1, p2=7, r2)`
  r1(3) ≤ r2(2)?  → **FALSE**
  **FALL THROUGH to pc=5**
|| {
  class: [pc-box; active]
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
}

r3-pc5: ||md
  **pc=5** `OP_Column(0, 1, r3)`
  read col 1 (name) from cursor 0
|| {
  class: [pc-box; active]
}

r3-reg-c: "r3 = **'carol'** (STRING)" {
  class: reg
  style.fill: "#BBDEFB"
  style.stroke: "#1565C0"
  style.font-color: "#0D47A1"
}

r3-pc6: ||md
  **pc=6** `OP_ResultRow(r3, 1)`
  emit 1 column starting at r3
|| {
  class: [pc-box; emit]
}

r3-output: ||md
  ### 📤 OUTPUT ROW
  | name    |
  |---------|
  | 'carol' |
|| {
  class: emit
  style.border-radius: 8
  style.shadow: true
}

r3-pc7: ||md
  **pc=7** `OP_Next(0, p2=2)`
  advance cursor 0 → **EOF**
  fall through to pc=8
|| {
  class: [pc-box; active]
}

row3-header -> r3-pc2
r3-pc2 -> r3-reg-a: "write" {
  style.stroke: "#F57F17"
  style.stroke-dash: 3
}
r3-pc2 -> r3-pc3: "pc++"
r3-pc3 -> r3-reg-b: "write" {
  style.stroke: "#F57F17"
  style.stroke-dash: 3
}
r3-pc3 -> r3-pc4: "pc++"
r3-pc4 -> r3-pc5: "3 ≤ 2 → FALSE\nfall through ✓" {
  style.stroke: "#2E7D32"
  style.bold: true
  style.stroke-width: 3
}
r3-pc5 -> r3-reg-c: "write" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}
r3-pc5 -> r3-pc6: "pc++"
r3-pc6 -> r3-output: "callback(r3, 1)" {
  style.stroke: "#1565C0"
  style.bold: true
  style.animated: true
}
r3-pc6 -> r3-pc7: "pc++"
r3-pc7 -> halt-block: "cursor EOF\nfall through" {
  style.stroke: "#6A1B9A"
  style.bold: true
}

# ────────────────────────────────────────
#  HALT
# ────────────────────────────────────────
halt-block: ||md
  **pc=8** `OP_Halt(0, 0, 0)`
  vm.halted = true
  halt_code = 0 (SQLITE_OK)
  **Execution complete.**
|| {
  class: [pc-box; halt]
  style.shadow: true
}

# ────────────────────────────────────────
#  REGISTER FILE SNAPSHOT (final state)
# ────────────────────────────────────────
registers: ||md
  ### Register File — Final State
  | Reg | Type    | Value   | Written By         |
  |-----|---------|---------|---------------------|
  | r0  | NULL    | —       | (reserved scratch)  |
  | r1  | INTEGER | 3       | OP_Column (id)      |
  | r2  | INTEGER | 2       | OP_Integer (const)  |
  | r3  | STRING  | 'carol' | OP_Column (name)    |
  | r4… | NULL | —     | (unused)            |
|| {
  style: {
    fill: "#FFF8E1"
    stroke: "#F57F17"
    border-radius: 8
    font-size: 13
  }
  near: bottom-center
}

# ────────────────────────────────────────
#  EXECUTION SUMMARY
# ────────────────────────────────────────
summary: ||md
  ### Execution Summary
  - **Opcodes fetched:** 17 total
  - **Rows scanned:** 3
  - **Rows emitted:** 1 (`carol`)
  - **OP_Le jumps:** 2 (filtered)
  - **OP_Next jumps:** 2 (looping)
  - **Memory:** All rows on same B-Tree leaf page.
|| {
  style: {
    fill: "#E8EAF6"
    stroke: "#283593"
    border-radius: 8
    font-size: 13
  }
  near: bottom-center
}