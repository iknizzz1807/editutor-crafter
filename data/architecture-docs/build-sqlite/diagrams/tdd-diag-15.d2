vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

direction: down

title: "B-tree Leaf Page Binary Layout (PAGE_TYPE_TABLE_LEAF = 0x0D)" {
  shape: text
  near: top-center
  style: {
    font-size: 22
    bold: true
    underline: true
  }
}

# ── Main Page Container ───────────────────────────────────
# Represents a standard 4096-byte database page
page: "SQLite B-Tree Page (4096 Bytes)" {
  grid-rows: 1
  grid-columns: 1
  grid-gap: 20
  width: 800
  style: {
    fill: "#F8F9FA"
    stroke: "#2C3E50"
    stroke-width: 4
    border-radius: 4
  }

  layout: "" {
    grid-rows: 7
    grid-columns: 1
    grid-gap: 0
    width: 760

    # ── Page Header (8 bytes) ──────────────────────────────
    # Colors: Header=Purple
    header: "Page Header" {
      grid-rows: 1
      grid-columns: 8
      grid-gap: 0
      h0: ||md
        **[0x00]**
        page_type
        `0x0D`
        1 byte
      || {
        width: 90
        style: {
          fill: "#9B59B6"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      h1: ||md
        **[0x01..0x02]**
        first_freeblock
        `u16 BE`
        2 bytes
      || {
        width: 110
        style: {
          fill: "#8E44AD"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      h2: ||md
        **[0x03..0x04]**
        cell_count (N)
        `u16 BE`
        2 bytes
      || {
        width: 110
        style: {
          fill: "#8E44AD"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      h3: ||md
        **[0x05..0x06]**
        cell_content_start
        `u16 BE`
        2 bytes
      || {
        width: 120
        style: {
          fill: "#8E44AD"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      h4: ||md
        **[0x07]**
        frag_free
        1 byte
      || {
        width: 90
        style: {
          fill: "#9B59B6"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      h5: "" { style.opacity: 0; width: 60; label: "" }
      h6: "" { style.opacity: 0; width: 80; label: "" }
      h7: ||md
        **Header**
        **8 bytes**
      || {
        width: 100
        style: {
          fill: "#6C3483"
          font-color: white
          font-size: 12
          bold: true
          border-radius: 4
        }
      }
    }

    # ── Boundary Marker ────────────────────────────────────
    hdr_end: ||md
      --- Offset 0x08: End of Fixed Header ---
    || {
      style: {
        fill: transparent
        stroke: transparent
        font-size: 10
        font-color: "#7F8C8D"
        italic: true
      }
    }

    # ── Cell Pointer Array (2*N bytes) ─────────────────────
    # Colors: Pointers=Orange
    ptrs: "Cell Pointer Array" {
      grid-rows: 1
      grid-columns: 8
      grid-gap: 0
      p0: ||md
        **[0x08..0x09]**
        ptr[0]
        `u16 BE`
      || {
        width: 100
        style: {
          fill: "#E67E22"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      p1: ||md
        **[0x0A..0x0B]**
        ptr[1]
        `u16 BE`
      || {
        width: 100
        style: {
          fill: "#D35400"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      p2: ||md
        **[0x0C..0x0D]**
        ptr[2]
        `u16 BE`
      || {
        width: 100
        style: {
          fill: "#E67E22"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      pdots: "···" {
        width: 60
        style: {
          fill: "#F0B27A"
          font-size: 16
          bold: true
          font-color: "#6E2C00"
        }
      }
      pn: ||md
        **[8+2(N-1)]**
        ptr[N-1]
        `u16 BE`
      || {
        width: 110
        style: {
          fill: "#D35400"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      ppad: "" { style.opacity: 0; width: 40; label: "" }
      pdir: ||md
        **Pointers grow**
        **downward →**
      || {
        width: 100
        style: {
          fill: "#FDEBD0"
          stroke: "#E67E22"
          font-size: 10
          font-color: "#6E2C00"
          italic: true
          border-radius: 4
        }
      }
      psize: ||md
        **Pointers**
        **2×N bytes**
      || {
        width: 100
        style: {
          fill: "#BA4A00"
          font-color: white
          font-size: 12
          bold: true
          border-radius: 4
        }
      }
    }

    # ── Boundary Marker ────────────────────────────────────
    ptr_end: ||md
      --- Offset 8 + 2N: Start of Unallocated Space ---
    || {
      style: {
        fill: transparent
        stroke: transparent
        font-size: 10
        font-color: "#7F8C8D"
        italic: true
      }
    }

    # ── Free Space (unallocated gap) ───────────────────────
    # Colors: Free=Green
    free: ||md
      ## ▓▓▓  UNALLOCATED  FREE  SPACE  ▓▓▓
      Offset range:  **8 + 2N**  ...  **cell_content_start − 1**
      Usable capacity = **cell_content_start − (8 + 2×N)** bytes
      
      *Note: Fragmentation can exist if cells are deleted without defragmentation.*
    || {
      height: 160
      style: {
        fill: "#27AE60"
        font-color: white
        font-size: 14
        bold: true
        border-radius: 0
        fill-pattern: dots
      }
    }

    # ── Cell Content Area (at the end of the page) ──────────
    # Colors: Data=Blue
    cells: "Cell Content Area (High Memory)" {
      grid-rows: 1
      grid-columns: 6
      grid-gap: 0
      cn: ||md
        **Cell N-1**
        (Newest)
      || {
        width: 120
        style: {
          fill: "#2980B9"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      cdots: "···" {
        width: 50
        style: {
          fill: "#85C1E9"
          font-size: 16
          bold: true
          font-color: "#1B4F72"
        }
      }
      c2: ||md
        **Cell 2**
      || {
        width: 100
        style: {
          fill: "#2471A3"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      c1: ||md
        **Cell 1**
      || {
        width: 100
        style: {
          fill: "#2980B9"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      c0: ||md
        **Cell 0**
        (First Inserted)
        *Offset: 0xFFF*
      || {
        width: 140
        style: {
          fill: "#1A5276"
          font-color: white
          font-size: 11
          bold: true
        }
      }
      cdir: ||md
        **← grows**
        **upward**
      || {
        width: 90
        style: {
          fill: "#D6EAF8"
          stroke: "#2980B9"
          font-size: 10
          font-color: "#1A5276"
          italic: true
          border-radius: 4
        }
      }
    }
  }
}

# ── Cell Internal Format Details ──────────────────────────
cell_fmt: "Table Leaf Cell Binary Format" {
  style: {
    fill: "#EBF5FB"
    stroke: "#2980B9"
    stroke-width: 2
    border-radius: 8
    font-size: 14
    bold: true
    font-color: "#1A5276"
  }
  layout: "" {
    grid-rows: 1
    grid-columns: 5
    grid-gap: 0
    f1: ||md
      **payload_size**
      varint
      (1–9 bytes)
    || {
      width: 130
      style: {
        fill: "#3498DB"
        font-color: white
        font-size: 11
        bold: true
      }
    }
    f2: ||md
      **rowid**
      varint
      (1–9 bytes)
    || {
      width: 120
      style: {
        fill: "#2471A3"
        font-color: white
        font-size: 11
        bold: true
      }
    }
    f3: ||md
      **Record Header**
      [hdr_size (varint)]
      [serial_types...]
    || {
      width: 160
      style: {
        fill: "#1F618D"
        font-color: white
        font-size: 11
        bold: true
      }
    }
    f4: ||md
      **Payload Data**
      (Column values)
    || {
      width: 130
      style: {
        fill: "#154360"
        font-color: white
        font-size: 11
        bold: true
      }
    }
    f5: ||md
      **Calculation:**
      Total = varint_len(payload_size)
      + varint_len(rowid)
      + payload_size
    || {
      width: 160
      style: {
        fill: "#D4E6F1"
        stroke: "#2980B9"
        font-size: 10
        font-color: "#1A5276"
        italic: true
        border-radius: 4
      }
    }
  }
}

# ── Page Capacity Summary ─────────────────────────────────
capacity: ||md
  ## Page Capacity Summary Table
  | Region | Offset Range | Size (bytes) |
  | :--- | :--- | :--- |
  | Page Header | 0x00 – 0x07 | **8** |
  | Cell Pointer Array | 0x08 – 0x08 + 2N − 1 | **2 × N** |
  | Free Space | 8 + 2N – cell_content_start − 1 | **cell_content_start − 8 − 2N** |
  | Cell Content Area | cell_content_start – 0x0FFF | **4096 − cell_content_start** |
  | **Total Page Size** | **0x0000 – 0x0FFF** | **4096** |

  **Usable bytes for data (Total - Fixed Header) = 4088 bytes.**
  *Split Condition: If `new_cell_size + 2 > available_free_space`, trigger B-tree page split.*
|| {
  style: {
    fill: "#FDFEFE"
    stroke: "#2C3E50"
    stroke-width: 1
    font-size: 12
    border-radius: 6
  }
}

# ── Footer Annotations ────────────────────────────────────
growth_rules: ||md
  ### Convergence Model
  - **Pointers** grow from low addresses to high addresses (downward).
  - **Cells** grow from high addresses to low addresses (upward).
  - When the regions meet, the page is full.
|| {
  near: bottom-center
  style: {
    fill: transparent
    stroke: transparent
    font-size: 13
    font-color: "#E74C3C"
    bold: true
  }
}

endian_warning: ||md
  ⚠ **ENGINEER NOTE:** All multi-byte integers are stored in **Big-Endian** format.
  Payload values use a custom **Varint** encoding (1 to 9 bytes).
|| {
  near: bottom-center
  style: {
    fill: "#FDEDEC"
    stroke: "#E74C3C"
    stroke-width: 2
    font-size: 12
    font-color: "#922B21"
    border-radius: 4
  }
}