title: |'md'
  ## Cell Binary Format with Varint Key
  Table B-tree Leaf Cell · Big-Endian · Variable Length
'| {
  near: top-center
}

direction: right

# ============================================================
# CELL OVERVIEW — TOP-LEVEL WIRE FORMAT
# ============================================================
cell: Cell Wire Format {
  style: {
    fill: "#E8EDF3"
    stroke: "#4A5568"
    border-radius: 8
    font-size: 16
  }
  grid-columns: 1
  layout: |'md'
    
    Offset   Size (bytes)       Field
    ──────   ──────────────     ─────────────────────────────────
    0        varint (1–9)       payload_size  (byte count of record body)
    +n       varint (1–9)       rowid         (integer primary key)
    +n+m     payload_size       record_payload (serialized row data)
    +n+m+p   4  (conditional)   overflow_page  (u32 BE, only if payload overflows page)
    
  '|
}

# ============================================================
# BYTE-LEVEL LAYOUT — CONCRETE EXAMPLE
# ============================================================
example: Concrete Example · rowid=300, payload=38 bytes, no overflow {
  style: {
    fill: "#F0FFF4"
    stroke: "#276749"
    border-radius: 8
  }
  grid-columns: 1
  
  bytes: {
    grid-columns: 10
    grid-gap: 0
    
    b0: |'md'
      **0x26**
      payload
      size=38
    '| { class: ps }
    
    b1: |'md'
      **0x82**
      rowid
      byte 0
    '| { class: rid }
    
    b2: |'md'
      **0x2C**
      rowid
      byte 1
    '| { class: rid }
    
    b3: |'md'
      **0x05**
      hdr_size
      =5
    '| { class: hdr }
    
    b4: |'md'
      **0x04**
      type:
      int32
    '| { class: tc }
    
    b5: |'md'
      **0x17**
      type:
      text(5)
    '| { class: tc }
    
    b6: |'md'
      **0x00**
      type:
      NULL
    '| { class: tc }
    
    b7: |'md'
      **0x00**
      **0x00**
      int32→
    '| { class: data }
    
    b8: |'md'
      **0x00**
      **0x2A**
      ←=42
    '| { class: data }
    
    b9: |'md'
      hello
      (5 B)
      ·····
    '| { class: data }
  }

  offsets: {
    grid-columns: 10
    grid-gap: 0
    
    o0: "off 0" { class: lbl }
    o1: "off 1" { class: lbl }
    o2: "off 2" { class: lbl }
    o3: "off 3" { class: lbl }
    o4: "off 4" { class: lbl }
    o5: "off 5" { class: lbl }
    o6: "off 6" { class: lbl }
    o7: "off 7" { class: lbl }
    o8: "off 9" { class: lbl }
    o9: "off 11" { class: lbl }
  }
}

# ============================================================
# VARINT ENCODING RULES
# ============================================================
varint: Varint Encoding Rules {
  style: {
    fill: "#FFF5E6"
    stroke: "#E67E22"
    border-radius: 8
    font-size: 14
  }
  grid-columns: 1
  rule: |'md'
    ### Bit Layout per Byte
    
    Byte format:  [C][b6][b5][b4][b3][b2][b1][b0]
                   │   └──────── 7 payload bits ──────┘
                   └─ Continuation: 1=more bytes follow
                                    0=this is the last byte
    
    **Exception:** The 9th byte (if reached) uses all 8 bits — no continuation bit.
    Total capacity: 7×8 + 8 = **64 bits** (full uint64_t).
  '|
  
  table: |'md'
    | Value Range         | Bytes | Encoding Pattern                     |
    |---------------------|-------|--------------------------------------|
    | 0 – 127             | 1     | `0xxxxxxx`                           |
    | 128 – 16 383        | 2     | `1xxxxxxx 0xxxxxxx`                  |
    | 16 384 – 2 097 151  | 3     | `1xxxxxxx 1xxxxxxx 0xxxxxxx`         |
    | 2 097 152 – 2²⁸−1   | 4     | `1xxxxxxx 1xxxxxxx 1xxxxxxx 0xxxxxxx`|
    | …                   | 5–8   | continuation pattern extends          |
    | > 2⁵⁶−1             | 9     | 8× `1xxxxxxx` + 1× `xxxxxxxx`        |
  '|
}

# ============================================================
# ROWID=300 ENCODING WALKTHROUGH
# ============================================================
walkthrough: "Example: rowid = 300" {
  style: {
    fill: "#FDF2E9"
    stroke: "#E67E22"
    border-radius: 8
    font-size: 14
  }
  grid-columns: 1
  # Renamed "steps" to "process" to avoid reserved keyword error inside container
  process: |'md'
    
    Step 1: 300 in binary = 1_0010_1100  (9 bits → needs 2 bytes)
    Step 2: Split into 7-bit groups (LSB first):
              group 0 (low):  010_1100  = 0x2C (44 decimal)
              group 1 (high): 000_0010  = 0x02 ( 2 decimal)
    Step 3: Encode MSB-first with continuation bits:
              byte 0: 1_0000010 = 0x82  (C=1: more bytes follow, payload=2)
              byte 1: 0_0101100 = 0x2C  (C=0: last byte,        payload=44)
    Step 4: Decode verification:
              result  = 0
              byte 0: result = (0 << 7) | (0x82 & 0x7F) = 0 | 2 = 2
                       C=1 → continue
              byte 1: result = (2 << 7) | (0x2C & 0x7F) = 256 | 44 = 300 ✓
                       C=0 → done.  Consumed: 2 bytes.
    
  '|
}

# ============================================================
# RECORD PAYLOAD INTERNAL FORMAT
# ============================================================
record: Record Payload Format {
  style: {
    fill: "#EBF5FB"
    stroke: "#2980B9"
    border-radius: 8
    font-size: 14
  }
  grid-columns: 1
  structure: |'md'
    ### Self-Describing Record Body
    
    ┌──────────────────── HEADER ─────────────────────┬──────── VALUES ────────┐
    │ header_size │ serial_type₀ │ serial_type₁ │ ... │ value₀ │ value₁ │ ... │
    │  (varint)   │   (varint)   │   (varint)   │     │ (N₀ B) │ (N₁ B) │     │
    └─────────────┴──────────────┴──────────────┴─────┴────────┴────────┴─────┘
         ↑                                                  ↑
    header_size includes itself                    size of each value is
    and all serial_type varints                    determined by its serial_type
    
  '|
  
  serial_types: |'md'
    ### Serial Type Codes
    | Code       | Meaning                | Value Size |
    |------------|------------------------|------------|
    | 0          | NULL                   | 0 bytes    |
    | 1          | 8-bit signed int       | 1 byte     |
    | 2          | 16-bit BE signed int   | 2 bytes    |
    | 3          | 24-bit BE signed int   | 3 bytes    |
    | 4          | 32-bit BE signed int   | 4 bytes    |
    | 5          | 48-bit BE signed int   | 6 bytes    |
    | 6          | 64-bit BE signed int   | 8 bytes    |
    | 7          | IEEE 754 double (BE)   | 8 bytes    |
    | 8          | Integer constant **0** | 0 bytes    |
    | 9          | Integer constant **1** | 0 bytes    |
    | N≥12, even | BLOB, size=(N−12)/2    | (N−12)/2   |
    | N≥13, odd  | TEXT, size=(N−13)/2    | (N−13)/2   |
  '|
}

# ============================================================
# OVERFLOW PAGE FIELD
# ============================================================
overflow: Overflow Page Pointer (conditional) {
  style: {
    fill: "#FDEDEC"
    stroke: "#E74C3C"
    border-radius: 8
    font-size: 14
  }
  grid-columns: 1
  detail: |'md'
    ### When Payload Exceeds Page Capacity
    
    If total_cell_size > usable_space_on_page:
      ┌─────────────────────────────────────────────────────┐
      │  ... partial record payload (fits on this page) ... │
      │  ┌──────────────────────────────────────────────┐   │
      │  │ overflow_page_number  (4 bytes, big-endian)  │   │
      │  │ Points to first overflow page containing     │   │
      │  │ the remainder of the record payload.         │   │
      │  │ That page may chain to further overflow      │   │
      │  │ pages via its own 4-byte next-page pointer.  │   │
      │  └──────────────────────────────────────────────┘   │
      └─────────────────────────────────────────────────────┘
    
    SQLite Overflow Threshold Logic:
    - If payload ≤ (usable-12) * 64/255 - 23, then stored entirely on page.
    - Otherwise, it uses overflow pages.
  '|
}

# ============================================================
# CONCRETE RECORD EXAMPLE ANNOTATION
# ============================================================
record_example: "Record Example: (42, 'hello', NULL)" {
  style: {
    fill: "#F4ECF7"
    stroke: "#8E44AD"
    border-radius: 8
    font-size: 14
  }
  grid-columns: 1
  breakdown: |'md'
    ### Column Values → Serial Types → Wire Bytes
    
    Column 0: INTEGER 42    → serial_type = 4  (32-bit int)  → 4 value bytes
    Column 1: TEXT "hello"  → serial_type = 23 (5×2+13)      → 5 value bytes
    Column 2: NULL          → serial_type = 0                 → 0 value bytes
    
    Header:
      header_size = 1 (itself) + 1 (type 4) + 1 (type 23) + 1 (type 0) = 4
    
    Wire layout:
      [0x04]                    ← header_size = 4
      [0x04]                    ← serial_type col 0
      [0x17]                    ← serial_type col 1
      [0x00]                    ← serial_type col 2
      [0x00][0x00][0x00][0x2A]  ← col 0: 42 as 32-bit BE
      [h][e][l][l][o]           ← col 1: "hello"
  '|
}

