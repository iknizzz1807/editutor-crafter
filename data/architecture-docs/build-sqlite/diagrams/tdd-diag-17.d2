vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # B-Tree Node Memory Layout: Table Leaf (0x0D) vs. Interior (0x05)
  ### SQLite Database File Format Reference (Architecture Specification)
| {near: top-center}

# ── GLOBAL CLASSES ──
classes: {
  header_style: {
    style: { fill: "#E8D5F5"; stroke: "#7B2D8E"; stroke-width: 2; border-radius: 4 }
  }
  pointer_style: {
    style: { fill: "#FFF3E0"; stroke: "#E65100"; stroke-width: 2; border-radius: 4 }
  }
  data_style: {
    style: { fill: "#BBDEFB"; stroke: "#1565C0"; stroke-width: 2; border-radius: 4 }
  }
  free_style: {
    style: { fill: "#C8E6C9"; stroke: "#2E7D32"; stroke-dash: 4; border-radius: 4 }
  }
  annotation_box: {
    style: { fill: "#FFF9C4"; stroke: "#FBC02D"; stroke-width: 1; border-radius: 8; font-size: 14 }
  }
}

# ── 1. PAGE MEMORY LAYOUT COMPARISON ──
formats: "Binary Memory Layout (Page Size = 4096 bytes)" {
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 12
  grid-columns: 2
  grid-gap: 50

  leaf_page: "Table B-Tree Leaf Node (Type 0x0D)" {
    tooltip: "Stores actual row data (payloads)"
    style: { fill: "#F1F8FF"; stroke: "#1565C0"; border-radius: 8; stroke-width: 2 }
    grid-rows: 4
    grid-gap: 0

    hdr: {
      class: header_style
      label: |md
        **Page Header (8 Bytes)**
        `0x00 [1B]` : **page_type = 0x0D** (Leaf)
        `0x01 [2B]` : **first_freeblock** (offset)
        `0x03 [2B]` : **cell_count** (N)
        `0x05 [2B]` : **cell_content_start** (offset)
        `0x07 [1B]` : **fragmented_free_bytes**
      |
    }
    ptrs: {
      class: pointer_style
      label: |md
        **Cell Pointer Array**
        `[Offset 0...2*N]`
        Array of 2-byte offsets to cell contents.
        Stored in Key (RowID) order.
        *Grows Downward* ↓
      |
    }
    free: {
      class: free_style
      label: |md
        **Unallocated / Free Space**
        Available for new cell pointers and cell data.
      |
    }
    cells: {
      class: data_style
      label: |md
        **Cell Content (Data Payloads)**
        *Grows Upward* ↑
        `[varint]` : Payload Size
        `[varint]` : RowID (Integer Primary Key)
        `[bytes]`  : Serialized Record Data
      |
    }
  }

  int_page: "Table B-Tree Interior Node (Type 0x05)" {
    tooltip: "Stores routing keys and page pointers"
    style: { fill: "#FFFDE7"; stroke: "#F57F17"; border-radius: 8; stroke-width: 2 }
    grid-rows: 4
    grid-gap: 0

    hdr: {
      class: header_style
      label: |md
        **Page Header (12 Bytes)**
        `0x00 [1B]` : **page_type = 0x05** (Interior)
        `0x01 [7B]` : (Shared fields: freeblock, count, etc.)
        `0x08 [4B]` : **right_child** (Page ID pointer) ★
      |
    }
    ptrs: {
      class: pointer_style
      label: |md
        **Cell Pointer Array**
        `[Offset 0...2*N]`
        Array of 2-byte offsets to separators.
        *Grows Downward* ↓
      |
    }
    free: {
      class: free_style
      label: |md
        **Unallocated / Free Space**
      |
    }
    cells: {
      class: pointer_style
      label: |md
        **Cell Content (Routing)**
        *Grows Upward* ↑
        `[4B]` : **left_child_page** (Page ID)
        `[varint]` : **separator_key** (Max RowID in subtree)
        *Note: No user data stored in Interior nodes*
      |
    }
  }
}

# ── 2. LOGICAL B-TREE SEARCH GRAPH ──
btree: "Physical Execution Flow: RowID Search (Level 0-2)" {
  style.fill: "#FDFDFD"
  style.stroke: "#9E9E9E"
  style.border-radius: 12

  root: "ROOT NODE (Pg 1)\nInterior" {
    class: header_style
    shape: rectangle
    style.double-border: true
  }

  level1: {
    style.stroke-dash: 5
    int2: "Interior (Pg 2)" { class: pointer_style }
    int3: "Interior (Pg 3)" { class: pointer_style }
    int4: "Interior (Pg 4)" { class: pointer_style }
  }

  leaves: {
    style.stroke: "#1565C0"
    pg5: "Leaf (Pg 5)\n[1 - 25]" { class: data_style }
    pg7: "Leaf (Pg 7)\n[26 - 50]" { class: data_style }
    pg8: "Leaf (Pg 8)\n[51 - 75]" { class: data_style }
    pg9: "Leaf (Pg 9)\n[76 - 100]" { class: data_style }
    pg10: "Leaf (Pg 10)\n[101 - 125]" { class: data_style }
    pg11: "Leaf (Pg 11)\n[126 - 150]" { class: data_style }
  }

  # Connections representing Physical Page Pointers
  root -> level1.int2: "Key ≤ 50"
  root -> level1.int3: "51 ≤ Key ≤ 100"
  root -> level1.int4: "Key > 100 (Rightmost)"

  level1.int2 -> leaves.pg5: "Key ≤ 25"
  level1.int2 -> leaves.pg7: "Key > 25"

  level1.int3 -> leaves.pg8: "Key ≤ 75"
  level1.int3 -> leaves.pg9: "Key > 75"

  level1.int4 -> leaves.pg10: "Key ≤ 125"
  level1.int4 -> leaves.pg11: "Key > 125"
}

# ── 3. ANNOTATIONS & LEGEND ──

# Fixed compilation error: Changed near: btree to near: bottom-center
path_descent: |md
  ### Algorithm: Cursor Search (rowid = 83)
  1.  **Traverse Page 1 (Root)**: 83 satisfies `51 ≤ Key ≤ 100`. Extract `left_child` pointer.
  2.  **Seek to Page 3 (Interior)**: Search Cell Pointers. 83 is greater than `separator_key = 75`.
  3.  **Follow Right Child**: Since 83 > all cell keys in Pg 3, follow the `right_child` header field to **Page 9**.
  4.  **Leaf Access (Page 9)**: Binary search the sorted Cell Pointer Array for RowID 83.
  5.  **Data Extraction**: Compute offset from pointer, parse Varints, and return **record_body**.
| {
  near: bottom-center
  class: annotation_box
}

legend: {
  near: bottom-right
  grid-columns: 1
  style: { fill: "#FFFFFF"; stroke: "#BDBDBD"; border-radius: 4; font-size: 11 }
  
  l1: "Node Header (Fixed Size)" { style.fill: "#E8D5F5" }
  l2: "Pointer Array (Navigation)" { style.fill: "#FFF3E0" }
  l3: "User Records (Payloads)" { style.fill: "#BBDEFB" }
  l4: "Unallocated Bytes" { style.fill: "#C8E6C9" }
}

# ── 4. STYLING THE ACTIVE SEARCH PATH ──
(btree.root -> btree.level1.int3)[0].style: {
  stroke: "#D32F2F"
  stroke-width: 5
  animated: true
}
(btree.level1.int3 -> btree.leaves.pg9)[0].style: {
  stroke: "#D32F2F"
  stroke-width: 5
  animated: true
}

btree.leaves.pg9.style: {
  stroke: "#D32F2F"
  stroke-width: 6
  shadow: true
  bold: true
}