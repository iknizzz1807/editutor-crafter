vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}
title: |md
  # Cursor Traversal Data Flow
  ## seek(key=50) → repeated next() calls
| {near: top-center}
classes: {
  page: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2980B9"
      border-radius: 6
      font-size: 13
    }
  }
  active: {
    style: {
      fill: "#FDEBD0"
      stroke: "#E67E22"
      border-radius: 6
      stroke-width: 2
      font-size: 13
    }
  }
  cursor-state: {
    style: {
      fill: "#F5EEF8"
      stroke: "#8E44AD"
      border-radius: 8
      font-size: 12
      bold: true
    }
  }
  bp: {
    style: {
      fill: "#E8F8F5"
      stroke: "#1ABC9C"
      border-radius: 6
      font-size: 12
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FEF9E7"
      stroke: "#F39C12"
      font-size: 11
    }
  }
  result: {
    style: {
      fill: "#D5F5E3"
      stroke: "#27AE60"
      border-radius: 6
      font-size: 13
      bold: true
    }
  }
  done: {
    style: {
      fill: "#FADBD8"
      stroke: "#E74C3C"
      border-radius: 6
      font-size: 13
      bold: true
    }
  }
}
# ============================================================
# PHASE 1: seek(key=50)
# ============================================================
seek_phase: "Phase 1 — seek(key=50)" {
  style: {
    fill: "#FAFAFA"
    stroke: "#BDC3C7"
    stroke-dash: 3
    font-size: 14
    bold: true
  }
  caller: "VM: OP_SEEK_ROWID\nbtree_cursor_seek(cur, 50)" {
    class: cursor-state
  }
  root_fetch: "fetch_page(page_id=2)\nRoot Page" {
    class: bp
  }
  root_page: "Root (Internal) Page 2\n┌────────────────────────┐\n│ type=0x05  cells=3     │\n│ [25] [50] [75]         │\n│  ↓    ↓    ↓    right  │\n│ p3   p4   p5    p6     │\n└────────────────────────┘\nBinary search: 50 ≤ 50 → left_child of cell[1] = p4" {
    class: page
  }
  interior_fetch: "fetch_page(page_id=4)\nInterior Page" {
    class: bp
  }
  interior_page: "Interior Page 4\n┌────────────────────────┐\n│ type=0x05  cells=2     │\n│ [38] [50]              │\n│  ↓    ↓    right       │\n│ p10  p11   p12         │\n└────────────────────────┘\nBinary search: 50 ≤ 50 → left_child of cell[1] = p11" {
    class: page
  }
  leaf_fetch: "fetch_page(page_id=11)\nLeaf Page" {
    class: bp
  }
  leaf_page: "Leaf Page 11\n┌──────────────────────────────┐\n│ type=0x0D  cells=8           │\n│ cell[0]: key=39              │\n│ cell[1]: key=41              │\n│ cell[2]: key=43              │\n│ cell[3]: key=45              │\n│ cell[4]: key=47              │\n│ cell[5]: key=50  ← FOUND    │\n│ cell[6]: key=52              │\n│ cell[7]: key=55              │\n└──────────────────────────────┘\nBinary search: cell[5].key == 50 → exact match" {
    class: active
  }
  stack_after_seek: "page_stack after seek:\n┌─────────────────────────────┐\n│ [0] root   page=2   ptr=1   │\n│ [1] interior page=4 ptr=1   │\n│ ─── (leaf is current) ───   │\n│ cur.page_id  = 11           │\n│ cur.cell_idx = 5            │\n│ cur.is_eof   = false        │\n└─────────────────────────────┘" {
    class: cursor-state
  }
  seek_result: "return 0 (FOUND)\ncursor positioned at\npage 11, cell 5, key=50" {
    class: result
  }
  caller -> root_fetch: "1. start at root_page" {
    style.stroke: "#2980B9"
    style.font-size: 11
  }
  root_fetch -> root_page: "pin_count++" {
    style.stroke: "#1ABC9C"
    style.font-size: 10
  }
  root_page -> interior_fetch: "2. push (page=2, ptr=1)\ndescend to child p4" {
    style.stroke: "#2980B9"
    style.font-size: 11
  }
  interior_fetch -> interior_page: "pin_count++" {
    style.stroke: "#1ABC9C"
    style.font-size: 10
  }
  interior_page -> leaf_fetch: "3. push (page=4, ptr=1)\ndescend to child p11" {
    style.stroke: "#2980B9"
    style.font-size: 11
  }
  leaf_fetch -> leaf_page: "pin_count++" {
    style.stroke: "#1ABC9C"
    style.font-size: 10
  }
  leaf_page -> stack_after_seek: "4. leaf reached\ncell_idx = 5 (key=50)" {
    style.stroke: "#8E44AD"
    style.font-size: 11
  }
  stack_after_seek -> seek_result: "5. exact match" {
    style.stroke: "#27AE60"
    style.font-size: 11
    style.bold: true
  }
  root_fetch -> root_page
  interior_fetch -> interior_page
  leaf_fetch -> leaf_page
}
# ============================================================
# PHASE 2: next() calls
# ============================================================
next_phase: "Phase 2 — Repeated next() Calls" {
  style: {
    fill: "#FAFAFA"
    stroke: "#BDC3C7"
    stroke-dash: 3
    font-size: 14
    bold: true
  }
  # ---------- next() #1: same leaf ----------
  next1: "next() call #1" {
    class: cursor-state
  }
  incr1: "cell_idx++ → 6" {
    style: {
      fill: "#EBF5FB"
      stroke: "#2980B9"
      border-radius: 4
      font-size: 12
    }
  }
  check1: "cell_idx(6) < cell_count(8)?" {
    class: decision
  }
  result1: "return 0 (OK)\nkey=52, page 11, cell 6\nNo page fetch needed\n(leaf still pinned)" {
    class: result
  }
  next1 -> incr1: "increment" {style.font-size: 10}
  incr1 -> check1
  check1 -> result1: "YES — same leaf page" {
    style.stroke: "#27AE60"
    style.font-size: 11
  }
  # ---------- next() #2: same leaf ----------
  next2: "next() call #2" {
    class: cursor-state
  }
  incr2: "cell_idx++ → 7" {
    style: {
      fill: "#EBF5FB"
      stroke: "#2980B9"
      border-radius: 4
      font-size: 12
    }
  }
  check2: "cell_idx(7) < cell_count(8)?" {
    class: decision
  }
  result2: "return 0 (OK)\nkey=55, page 11, cell 7\nNo page fetch needed" {
    class: result
  }
  next2 -> incr2: "increment" {style.font-size: 10}
  incr2 -> check2
  check2 -> result2: "YES — same leaf page" {
    style.stroke: "#27AE60"
    style.font-size: 11
  }
  # ---------- next() #3: leaf exhausted, cross page ----------
  next3: "next() call #3 — LEAF EXHAUSTED" {
    class: cursor-state
    style.stroke-width: 3
  }
  incr3: "cell_idx++ → 8" {
    style: {
      fill: "#FDEDEC"
      stroke: "#E74C3C"
      border-radius: 4
      font-size: 12
    }
  }
  check3: "cell_idx(8) ≥ cell_count(8)?" {
    class: decision
  }
  cross_page: "Cross-Page Traversal" {
    style: {
      fill: "#FDF2E9"
      stroke: "#E67E22"
      stroke-width: 2
      font-size: 13
      bold: true
    }
    pop1: "Pop stack:\n(page=4, ptr=1) → ptr++" {
      style: {
        fill: "#F5EEF8"
        stroke: "#8E44AD"
        border-radius: 4
        font-size: 11
      }
    }
    parent_check: "parent ptr(2) ≤\nparent cell_count(2)?" {
      class: decision
    }
    descend_right: "ptr=2 == cell_count\n→ follow right_child = p12" {
      style: {
        fill: "#EBF5FB"
        stroke: "#2980B9"
        border-radius: 4
        font-size: 11
      }
    }
    fetch_p12: "fetch_page(page_id=12)\nBuffer Pool lookup" {
      class: bp
    }
    new_leaf: "Leaf Page 12\n┌──────────────────────┐\n│ type=0x0D  cells=5   │\n│ cell[0]: key=57      │\n│ cell[1]: key=59      │\n│ cell[2]: key=61      │\n│ cell[3]: key=63      │\n│ cell[4]: key=65      │\n└──────────────────────┘" {
      class: active
    }
    new_stack: "Updated stack:\n┌─────────────────────────────┐\n│ [0] root   page=2   ptr=1   │\n│ [1] interior page=4 ptr=2   │\n│ ─── (leaf is current) ───   │\n│ cur.page_id  = 12           │\n│ cur.cell_idx = 0            │\n│ cur.is_eof   = false        │\n└─────────────────────────────┘" {
      class: cursor-state
    }
    pop1 -> parent_check: "check parent" {style.font-size: 10}
    parent_check -> descend_right: "YES — more children" {
      style.stroke: "#27AE60"
      style.font-size: 10
    }
    descend_right -> fetch_p12: "descend" {style.font-size: 10}
    fetch_p12 -> new_leaf: "pin_count++" {
      style.stroke: "#1ABC9C"
      style.font-size: 10
    }
    new_leaf -> new_stack: "position at cell[0]" {
      style.stroke: "#8E44AD"
      style.font-size: 10
    }
  }
  result3: "return 0 (OK)\nkey=57, page 12, cell 0" {
    class: result
  }
  next3 -> incr3: "increment" {style.font-size: 10}
  incr3 -> check3
  check3 -> cross_page.pop1: "YES — leaf exhausted\nunpin page 11" {
    style.stroke: "#E74C3C"
    style.font-size: 11
    style.stroke-width: 2
  }
  cross_page.new_stack -> result3: "positioned on new leaf" {
    style.stroke: "#27AE60"
    style.font-size: 11
  }
  # ---------- next() #N: tree exhausted ----------
  nextN: "next() call #N — TREE EXHAUSTED" {
    class: cursor-state
    style.stroke-width: 3
  }
  incrN: "cell_idx++ → cell_count\n(last leaf exhausted)" {
    style: {
      fill: "#FDEDEC"
      stroke: "#E74C3C"
      border-radius: 4
      font-size: 12
    }
  }
  checkN: "cell_idx ≥ cell_count?" {
    class: decision
  }
  pop_all: "Pop stack repeatedly:\n(page=4, ptr=3) → ptr++ > cells → pop\n(page=2, ptr=2) → ptr++ > cells → pop\nStack EMPTY" {
    style: {
      fill: "#FADBD8"
      stroke: "#E74C3C"
      border-radius: 4
      font-size: 11
    }
  }
  eof_result: "cur.is_eof = true\nreturn 1 (EOF)\nNo more rows" {
    class: done
  }
  nextN -> incrN: "increment" {style.font-size: 10}
  incrN -> checkN
  checkN -> pop_all: "YES — leaf exhausted" {
    style.stroke: "#E74C3C"
    style.font-size: 11
  }
  pop_all -> eof_result: "stack empty → DONE" {
    style.stroke: "#E74C3C"
    style.font-size: 11
    style.stroke-width: 2
    style.bold: true
  }
  # Sequential flow indicators
  result1 -> next2: "caller calls next()" {
    style.stroke-dash: 5
    style.stroke: "#95A5A6"
    style.font-size: 10
  }
  result2 -> next3: "caller calls next()" {
    style.stroke-dash: 5
    style.stroke: "#95A5A6"
    style.font-size: 10
  }
  result3 -> nextN: "... more next() calls ...\n(cells within page 12)" {
    style.stroke-dash: 5
    style.stroke: "#95A5A6"
    style.font-size: 10
  }
}
# ============================================================
# Buffer Pool Interaction Detail
# ============================================================
buffer_pool: "Buffer Pool — Page Access Protocol" {
  style: {
    fill: "#E8F8F5"
    stroke: "#1ABC9C"
    stroke-width: 2
    font-size: 14
    bold: true
  }
  bp_api: |md
    **Every page access goes through fetch_page(page_id):**
    
    uint8_t *fetch_page(pool, page_id):
      1. page_table_lookup(page_id)  → HIT or MISS
      2. HIT:  pin_count++, lru_move_to_head, return data*
      3. MISS: get_free_frame (free_stack or LRU evict)
               pread(fd, frame->data, 4096, page_id*4096)
               page_table_insert, lru_push_head
               pin_count = 1, return data*
    
    **Cursor pin/unpin discipline:**
    - seek(): fetches root, interior, leaf — unpins each
      after descending (only leaf stays conceptually active)
    - next() within same leaf: NO fetch needed (data cached)
    - next() cross-page: unpin old leaf, fetch new leaf
    - close(): unpin current leaf
  |
}
# ============================================================
# next() Algorithm Pseudocode
# ============================================================
algorithm: |md
  ## next() Algorithm (Pseudocode)
  c
  int btree_cursor_next(BTreeCursor *cur) {
      cur->cell_index++;
      // Case 1: more cells in current leaf
      page = fetch_page(pool, cur->page_id);
      cell_count = read_be16(page + 3);
      unpin_page(pool, cur->page_id, false);
      if (cur->cell_index < cell_count)
          return 0;  // OK — same page
      // Case 2: leaf exhausted — ascend via stack
      while (cur->stack_depth > 0) {
          cur->stack_depth--;
          parent = stack[stack_depth];
          parent.cell_index++;
          page = fetch_page(pool, parent.page_id);
          parent_cells = read_be16(page + 3);
          if (parent.cell_index <= parent_cells) {
              // More children — descend to next subtree
              child = (parent.cell_index == parent_cells)
                  ? read_be32(page + 8)  // right_child
                  : read_be32(page + cell_ptr); // left_child
              // Re-push parent with updated index
              stack[stack_depth++] = parent;
              unpin_page(pool, parent.page_id, false);
              // Descend to leftmost leaf of child
              descend_to_leftmost_leaf(cur, child);
              return 0;  // OK — new page
          }
          unpin_page(pool, parent.page_id, false);
      }
      // Case 3: stack empty — entire tree exhausted
      cur->is_eof = true;
      return 1;  // EOF
  }
  
| {
  near: bottom-center
  style: {
    fill: transparent
    stroke: "#BDC3C7"
    font-size: 11
  }
}
# ============================================================
# Top-level flow connections
# ============================================================
seek_phase -> next_phase: "cursor now positioned;\ncaller begins iteration" {
  style.stroke: "#8E44AD"
  style.stroke-width: 2
  style.font-size: 12
  style.stroke-dash: 3
}