vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}
title: |md
  # Token Struct Memory Layout (12 bytes)
  Zero-copy design — lexeme recovered via `&source[start..start+len]`
| {
  near: top-center
}
token_struct: Token Struct {
  grid-rows: 1
  grid-columns: 12
  grid-gap: 0
  b0: "type" {
    style: {
      fill: "#9B59B6"
      font-color: white
      font-size: 13
      bold: true
      border-radius: 0
      stroke: "#7D3C98"
    }
  }
  b1: "" {
    style: {
      fill: "#BDC3C7"
      stroke: "#95A5A6"
      border-radius: 0
    }
  }
  b2: "" {
    style: {
      fill: "#BDC3C7"
      stroke: "#95A5A6"
      border-radius: 0
    }
  }
  b3: "" {
    style: {
      fill: "#BDC3C7"
      stroke: "#95A5A6"
      border-radius: 0
    }
  }
  b4: "" {
    style: {
      fill: "#3498DB"
      stroke: "#2980B9"
      border-radius: 0
    }
  }
  b5: "" {
    style: {
      fill: "#3498DB"
      stroke: "#2980B9"
      border-radius: 0
    }
  }
  b6: "" {
    style: {
      fill: "#3498DB"
      stroke: "#2980B9"
      border-radius: 0
    }
  }
  b7: "start" {
    style: {
      fill: "#3498DB"
      font-color: white
      font-size: 13
      bold: true
      border-radius: 0
      stroke: "#2980B9"
    }
  }
  b8: "" {
    style: {
      fill: "#2ECC71"
      stroke: "#27AE60"
      border-radius: 0
    }
  }
  b9: "" {
    style: {
      fill: "#2ECC71"
      stroke: "#27AE60"
      border-radius: 0
    }
  }
  b10: "" {
    style: {
      fill: "#2ECC71"
      stroke: "#27AE60"
      border-radius: 0
    }
  }
  b11: "len" {
    style: {
      fill: "#2ECC71"
      font-color: white
      font-size: 13
      bold: true
      border-radius: 0
      stroke: "#27AE60"
    }
  }
}
