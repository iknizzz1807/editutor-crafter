      style.font-color: "#0d652d"
    }
    r3_in: "NULL" {
      style: {
        fill: "#f3e8fd"
        bold: true
        font-color: "#e37400"
      }
    }
    r3_out: "NULL" {
      style: {
        font-color: "#e37400"
        bold: true
        fill: "#fff3e0"
      }
    }
  }
  rule: |md
    **Rule:** NULL propagates
    `NOT NULL = NULL`
  | {
