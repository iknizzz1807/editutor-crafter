not_table: NOT Truth Table {
  style: {
    fill: "#f3e8fd"
    stroke: "#7b1fa2"
    border-radius: 8
    font-size: 20
    bold: true
  }
  grid: {
    grid-columns: 2
    grid-rows: 4
    grid-gap: 0
    style: {
      fill: "#ffffff"
      stroke: "#7b1fa2"
      font: mono
      font-size: 16
    }
    h_a: "A" {
      style: {
        fill: "#7b1fa2"
        font-color: "#ffffff"
        bold: true
      }
    }
    h_not: "NOT A" {
      style: {
        fill: "#7b1fa2"
        font-color: "#ffffff"
        bold: true
      }
    }
    r1_in: "TRUE" {
      style: {
        fill: "#f3e8fd"
        bold: true
      }
    }
    r1_out: "FALSE" {
      style.font-color: "#c5221f"
    }
    r2_in: "FALSE" {
      style: {
        fill: "#f3e8fd"
        bold: true
      }
    }
