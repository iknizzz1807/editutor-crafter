    }
    r3_nn: "NULL" {
      style: {
        font-color: "#e37400"
        bold: true
        fill: "#fff3e0"
      }
    }
  }
  rule: |md
    **Rule:** FALSE wins over NULL
    `FALSE AND <anything> = FALSE`
  | {
    style: {
      fill: "#fce8e6"
      stroke: "#c5221f"
      border-radius: 6
      font-size: 14
    }
  }
}
