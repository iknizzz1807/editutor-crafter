vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
  }
}
title: |md
  # Three-Valued Logic Truth Tables
  ## SQL NULL Propagation Rules
| {
  near: top-center
  style: {
    font-size: 28
    font-color: "#1a1a2e"
  }
}
direction: down
and_table: AND Truth Table {
  style: {
    fill: "#e8f0fe"
    stroke: "#4285f4"
    border-radius: 8
    font-size: 20
    bold: true
  }
  grid: {
    grid-columns: 4
    grid-rows: 5
    grid-gap: 0
    style: {
      fill: "#ffffff"
      stroke: "#4285f4"
      font: mono
      font-size: 16
    }
    h_and: "A AND B" {
      style: {
        fill: "#4285f4"
        font-color: "#ffffff"
        bold: true
      }
    }
    h_true: "B=TRUE" {
      style: {
        fill: "#4285f4"
        font-color: "#ffffff"
        bold: true
      }
    }
    h_false: "B=FALSE" {
      style: {
        fill: "#4285f4"
        font-color: "#ffffff"
        bold: true
      }
    }
    h_null: "B=NULL" {
      style: {
        fill: "#4285f4"
        font-color: "#ffffff"
        bold: true
      }
    }
    r1_label: "A=TRUE" {
      style: {
        fill: "#e8f0fe"
        bold: true
      }
    }
    r1_tt: "TRUE" {
      style.font-color: "#0d652d"
    }
    r1_tf: "FALSE" {
      style.font-color: "#c5221f"
    }
    r1_tn: "NULL" {
      style: {
        font-color: "#e37400"
        bold: true
        fill: "#fff3e0"
      }
    }
    r2_label: "A=FALSE" {
      style: {
        fill: "#e8f0fe"
        bold: true
      }
    }
    r2_ft: "FALSE" {
      style.font-color: "#c5221f"
    }
    r2_ff: "FALSE" {
      style.font-color: "#c5221f"
    }
    r2_fn: "FALSE" {
      style: {
        font-color: "#c5221f"
        fill: "#fce8e6"
        bold: true
      }
    }
    r3_label: "A=NULL" {
      style: {
        fill: "#e8f0fe"
        bold: true
      }
    }
    r3_nt: "NULL" {
      style: {
        font-color: "#e37400"
        bold: true
        fill: "#fff3e0"
      }
    }
    r3_nf: "FALSE" {
      style: {
        font-color: "#c5221f"
        fill: "#fce8e6"
        bold: true
