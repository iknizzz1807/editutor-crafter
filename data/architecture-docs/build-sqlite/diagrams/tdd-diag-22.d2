      fill: "#fff3e0"
      stroke: "#e37400"
      border-radius: 6
      font-size: 14
    }
  }
}
separator: "" {
  style: {
    fill: transparent
    stroke: transparent
  }
  width: 900
  height: 1
}
comparison_section: SQL Comparison: col = NULL {
  style: {
    fill: "#fff8e1"
    stroke: "#e37400"
    stroke-width: 3
    border-radius: 10
    font-size: 22
    bold: true
  }
  direction: right
  table_data: Table rows {
    style: {
      fill: "#ffffff"
      stroke: "#666"
      border-radius: 6
      font-size: 14
    }
    grid: {
      grid-columns: 3
      grid-rows: 4
      grid-gap: 0
      style: {
        fill: "#ffffff"
        stroke: "#999"
        font: mono
        font-size: 14
      }
      h_rid: "rowid" {
        style: {
          fill: "#666"
          font-color: "#fff"
          bold: true
        }
      }
      h_val: "val" {
        style: {
          fill: "#666"
          font-color: "#fff"
          bold: true
        }
      }
      h_result: "val = NULL" {
        style: {
          fill: "#666"
          font-color: "#fff"
          bold: true
        }
      }
      r1_id: "1"
      r1_val: "10"
      r1_cmp: "NULL → skip" {
        style: {
          fill: "#fce8e6"
          font-color: "#c5221f"
          bold: true
        }
      }
      r2_id: "2"
      r2_val: "NULL" {
        style: {
          font-color: "#e37400"
          bold: true
        }
      }
      r2_cmp: "NULL → skip" {
        style: {
          fill: "#fce8e6"
          font-color: "#c5221f"
          bold: true
        }
      }
      r3_id: "3"
      r3_val: "30"
      r3_cmp: "NULL → skip" {
        style: {
          fill: "#fce8e6"
          font-color: "#c5221f"
          bold: true
        }
      }
    }
  }
  arrow_to_result: "" {
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 40
  }
  result_box: |md
    **WHERE val = NULL**
    Result: **0 rows**
    Every comparison with NULL
    yields NULL (not TRUE).
    WHERE keeps only TRUE rows.
    ---
    `10 = NULL` → **NULL** → discard
    `NULL = NULL` → **NULL** → discard
    `30 = NULL` → **NULL** → discard
  | {
    style: {
      fill: "#fce8e6"
      stroke: "#c5221f"
      stroke-width: 2
      border-radius: 8
      font-size: 14
    }
  }
  table_data -> result_box: "all rows\ndiscarded" {
    style: {
      stroke: "#c5221f"
      stroke-width: 2
      font-color: "#c5221f"
      bold: true
    }
  }
}
isnull_section: OP_IsNull Bytecode Behavior {
  style: {
    fill: "#e3f2fd"
    stroke: "#1565c0"
    stroke-width: 3
    border-radius: 10
    font-size: 22
    bold: true
  }
  direction: right
  opcode_box: |md
    
    OP_IsNull  reg[p1], jump_addr
    
    **Semantics:**
    - If `reg[p1].type == VAL_NULL` → jump to `jump_addr`
    - If `reg[p1].type != VAL_NULL` → fall through to next instruction
  | {
    style: {
      fill: "#ffffff"
      stroke: "#1565c0"
      border-radius: 6
      font-size: 14
      font: mono
    }
  }
  bytecode_example: |md
    **Compiled WHERE age > 21 with NULL guard:**
    
    addr  opcode      p1  p2   p3   comment
    ----  ----------  --  ---  ---  ------------------
    3     Column      0   1    r2   age → r2
    4     Integer     21  0    r3   21 → r3
    5     IsNull      r2  8    0    if age NULL → skip
    6     IsNull      r3  8    0    if 21 NULL → skip
    7     Le          r2  8    r3   if age≤21 → skip
    8     Column      0   0    r1   name → r1 (output)
    9     ResultRow   r1  1    0    emit row
    10    Next        0   3    0    advance cursor
    
  | {
    style: {
      fill: "#f5f5f5"
      stroke: "#666"
      border-radius: 6
      font-size: 13
      font: mono
    }
  }
  opcode_box -> bytecode_example
  flow: {
    direction: down
    style: {
      fill: transparent
      stroke: transparent
    }
    null_path: "reg[p1] = NULL" {
      style: {
        fill: "#fff3e0"
        stroke: "#e37400"
        stroke-width: 2
        border-radius: 20
        font-size: 16
        bold: true
        font-color: "#e37400"
      }
    }
    jump_action: "→ JUMP to addr 8\n(skip ResultRow)" {
      style: {
        fill: "#fce8e6"
        stroke: "#c5221f"
        border-radius: 6
        font-size: 14
        bold: true
        font-color: "#c5221f"
      }
    }
    nonnull_path: "reg[p1] ≠ NULL" {
      style: {
        fill: "#e8f5e9"
        stroke: "#0d652d"
        stroke-width: 2
        border-radius: 20
        font-size: 16
        bold: true
        font-color: "#0d652d"
      }
    }
    fall_action: "→ FALL THROUGH\n(proceed to comparison)" {
      style: {
        fill: "#c8e6c9"
        stroke: "#0d652d"
        border-radius: 6
        font-size: 14
        bold: true
        font-color: "#0d652d"
      }
    }
    null_path -> jump_action: {
      style: {
        stroke: "#e37400"
        stroke-width: 2
      }
    }
    nonnull_path -> fall_action: {
      style: {
        stroke: "#0d652d"
        stroke-width: 2
      }
    }
  }
}
key_insight: |md
  ## Key Insight
  **WHERE keeps rows only when the predicate is TRUE.**
  Both FALSE and NULL cause the row to be discarded.
  This is why `WHERE col = NULL` returns 0 rows — use `WHERE col IS NULL` instead.
  The `OP_IsNull` guard prevents NULL operands from reaching comparison opcodes,
  ensuring rows with NULL columns are skipped before the comparison even fires.
| {
  near: bottom-center
  style: {
    fill: "#1a1a2e"
    font-color: "#e0e0e0"
    stroke: "#1a1a2e"
    border-radius: 10
    font-size: 15
  }
}