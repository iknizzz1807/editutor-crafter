vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: {
  label: |md
    # SQLite Dual B-tree Architecture: Secondary Index vs Table B-tree
    **Specification:** Secondary indexes store composite keys `(value, rowid)` with **no** record data.
    Main tables store `(rowid, full_record)`. A query on a non-indexed column via a secondary index
    triggers a **Double Lookup** (Index Seek → RowID Extract → Table Seek).
  |
  near: top-center
  style: {
    font-size: 18
    font-color: "#2c3e50"
    stroke-width: 0
    fill: transparent
  }
}

# ──────────────────────────────────────────────────────────────────────────
#  SYSTEM CATALOG: sqlite_master
# ──────────────────────────────────────────────────────────────────────────
catalog: "sqlite_master (Page 1)" {
  style: {
    fill: "#f8f9fa"
    stroke: "#34495e"
    stroke-width: 2
    border-radius: 8
    font-size: 16
    bold: true
  }

  schema_root: "Schema Root" {
    shape: sql_table
    style: { fill: "#e1bee7"; stroke: "#4b0082" }
    type: TEXT
    name: TEXT
    tbl_name: TEXT
    rootpage: INTEGER
    sql: TEXT
  }

  entry_table: "table | users | users | 5 | CREATE TABLE users..." {
    style: { fill: "#d1ecf1"; stroke: "#0c5460"; border-radius: 4; font-size: 12 }
  }

  entry_index: "index | idx_age | users | 12 | CREATE INDEX idx_age..." {
    style: { fill: "#d4edda"; stroke: "#155724"; border-radius: 4; font-size: 12 }
  }
}

# ──────────────────────────────────────────────────────────────────────────
#  TABLE B-TREE: THE CLUSTERED STORAGE (Primary Data)
# ──────────────────────────────────────────────────────────────────────────
table_btree: "Table B-tree (Clustered by rowid)" {
  style: {
    fill: "#e3f2fd"
    stroke: "#1565c0"
    stroke-width: 3
    border-radius: 12
    bold: true
  }

  t_node_5: "Root (Internal Node, Page 5)" {
    style: { fill: "#90caf9"; stroke: "#0d47a1"; bold: true }
    label: ||md
      | Ptr | Key (rowid separator) |
      |:---:|:---------------------:|
      | P6  | 50                    |
      | P7  | 100                   |
      | P8  | (Right Child)         |
    ||
  }

  t_node_6: "Leaf (Page 6)" {
    style: { fill: "#bbdefb"; stroke: "#1976d2" }

    layout: "Cell Byte Layout" {
      label: "0x00 Payload | 0x04 rowid\n0x08 Serial Header | 0x0C Data\n0x20 Padding"
      style: {
        font-size: 10
        fill: "#ffffff"
      }
    }

    data: "Records [rowid 1..49]" {
      label: ||md
        | rid | name  | age | email        |
        |:---:|:-----:|:---:|:-------------|
        | **1** | Alice | 30 | alice@db.com |
        | 2   | Bob   | 25  | bob@db.com   |
      ||
      style: {
        font-size: 11
        fill: "#e3f2fd"
      }
    }
  }

  t_node_5 -> t_node_6: "ptr: child < 50"
}

# ──────────────────────────────────────────────────────────────────────────
#  INDEX B-TREE: THE SECONDARY MAPPING (Value -> RowID)
# ──────────────────────────────────────────────────────────────────────────
index_btree: "Index B-tree (Secondary: age)" {
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
    stroke-width: 3
    border-radius: 12
    bold: true
  }

  idx_node_12: "Root (Internal Node, Page 12)" {
    style: { fill: "#a5d6a7"; stroke: "#1b5e20"; bold: true }
    label: ||md
      | Ptr | Key (age, rowid) |
      |:---:|:----------------:|
      | P13 | (28, 50)         |
      | P14 | (35, 51)         |
      | P15 | (Right Child)    |
    ||
  }

  idx_node_14: "Leaf (Page 14)" {
    style: { fill: "#c8e6c9"; stroke: "#388e3c" }

    layout: "Index Cell Layout" {
      label: "Secondary index cells carry NO row data.\nKey = [Payload_Size, RowID, {Header, age, rowid}]"
      style: {
        font-size: 10
        fill: "#ffffff"
      }
    }

    data: "Sorted Keys" {
      label: ||md
        | age | rowid | mapping |
        |:---:|:-----:|:--------|
        | 30  | **1** | Alice   |
        | 31  | 100   | Eve     |
        | 35  | 51    | Dave    |
      ||
      style: {
        font-size: 11
        fill: "#ffffff"
      }
    }
  }

  idx_node_12 -> idx_node_14: "ptr: 28 <= age < 35"
}

# ──────────────────────────────────────────────────────────────────────────
#  THE DOUBLE LOOKUP FLOW (EXECUTION PATH)
# ──────────────────────────────────────────────────────────────────────────
execution_flow: "EXECUTION: SELECT * FROM users WHERE age = 30" {
  style: {
    fill: "#fff3e0"
    stroke: "#e65100"
    stroke-dash: 5
    border-radius: 10
  }

  step_1: "1. Index Seek" {
    label: "Search Page 12 -> Page 14 for age=30"
    style: { fill: "#ffe0b2"; stroke: "#fb8c00" }
  }

  step_2: "2. Key Extraction" {
    label: "Extract RowID '1' from index leaf cell"
    style: { fill: "#ffe0b2"; stroke: "#fb8c00" }
  }

  step_3: "3. Table Seek" {
    label: "Point Lookup: Table Page 5 -> Page 6 for rowid=1"
    style: { fill: "#ffe0b2"; stroke: "#fb8c00" }
  }

  step_4: "4. Result" {
    label: "Return full tuple: (Alice, 30, ...)"
    style: { fill: "#ffe0b2"; stroke: "#fb8c00" }
  }

  step_1 -> step_2: "found entry"
  step_2 -> step_3: "seek by rowid"
  step_3 -> step_4: "reconstruct record"
}

# ──────────────────────────────────────────────────────────────────────────
#  CONNECTIONS & FLOW ANNOTATIONS
# ──────────────────────────────────────────────────────────────────────────

catalog.entry_table -> table_btree.t_node_5: "Points to Root Page 5" {
  style: { stroke: "#1565c0"; stroke-dash: 2 }
}
catalog.entry_index -> index_btree.idx_node_12: "Points to Root Page 12" {
  style: { stroke: "#2e7d32"; stroke-dash: 2 }
}

execution_flow.step_1 -> index_btree.idx_node_14.data: "Find age=30" {
  style: { stroke: "#e65100"; stroke-width: 2; animated: true }
}

execution_flow.step_3 -> table_btree.t_node_6.data: "Find rowid=1" {
  style: { stroke: "#e65100"; stroke-width: 2; animated: true }
}

comparison: "Structural Differences" {
  label: ||md
    | Feature      | Table B-tree          | Index B-tree           |
    | :---         | :---                  | :---                   |
    | **Key Type** | Integer (rowid)       | Composite (col, rowid) |
    | **Payload**  | Full Row Data         | No Data (Key Only)     |
    | **Access**   | Primary Lookup        | Secondary Lookup       |
    | **Logic**    | Clustered             | Non-Clustered          |
  ||
  near: bottom-right
  style: { fill: "#fdfefe"; stroke: "#7f8c8d"; font-size: 11 }
}

legend: "Legend" {
  near: bottom-left
  ptr: "P: Pointer (Page Offset)" { style: { font-color: "#e67e22"; bold: true } }
  key: "K: Key (B-tree Key)" { style: { font-color: "#2980b9"; bold: true } }
  val: "V: Value (Record)" { style: { font-color: "#27ae60"; bold: true } }
}
