vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Selectivity Estimation Decision Tree" {
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

entry: "estimate_selectivity(expr, stats, table, row_count)" {
  style: {
    fill: "#2D3748"
    font-color: "#FFFFFF"
    bold: true
    font-size: 18
    border-radius: 8
  }
}

stats_check: "stats available\nfor this column?" {
  shape: diamond
  style: {
    fill: "#4A5568"
    font-color: "#FFFFFF"
    font-size: 14
    bold: true
  }
}

entry -> stats_check

no_stats: "return 0.5\n(conservative default)" {
  style: {
    fill: "#E53E3E"
    font-color: "#FFFFFF"
    bold: true
    font-size: 14
    border-radius: 6
  }
}

stats_check -> no_stats: "NO" {
  style: {
    stroke: "#E53E3E"
    stroke-width: 2
    font-color: "#E53E3E"
    bold: true
  }
}

type_dispatch: "expr.type?" {
  shape: diamond
  style: {
    fill: "#2B6CB0"
    font-color: "#FFFFFF"
    font-size: 16
    bold: true
  }
}

stats_check -> type_dispatch: "YES" {
  style: {
    stroke: "#38A169"
    stroke-width: 2
    font-color: "#38A169"
    bold: true
  }
}

# ─── AND branch ───
and_branch: "NODE_AND" {
  style: {
    fill: "#553C9A"
    font-color: "#FFFFFF"
    bold: true
    font-size: 14
    border-radius: 4
  }
}

type_dispatch -> and_branch: "AND" {
  style.font-size: 13
  style.bold: true
}

and_recurse: |md
  **Independence assumption**
  
  sel_left  = estimate(expr.left)
  sel_right = estimate(expr.right)
| {
  style: {
    fill: "#E9D8FD"
    font-color: "#1A202C"
    border-radius: 6
  }
}

and_branch -> and_recurse

and_formula: "sel = sel_left × sel_right" {
  style: {
    fill: "#D6BCFA"
    font-color: "#1A202C"
    bold: true
    font-size: 15
    border-radius: 4
    font: mono
  }
}

and_recurse -> and_formula

and_example: |md
  **Example:** age > 21 AND status = 'active'
  sel(age>21) = 0.40, sel(status='active') = 0.25
  **result = 0.40 × 0.25 = 0.10**
| {
  style: {
    fill: "#FAF5FF"
    font-color: "#553C9A"
    border-radius: 4
    font-size: 12
  }
}

and_formula -> and_example

# ─── OR branch ───
or_branch: "NODE_OR" {
  style: {
    fill: "#2C7A7B"
    font-color: "#FFFFFF"
    bold: true
    font-size: 14
    border-radius: 4
  }
}

type_dispatch -> or_branch: "OR" {
  style.font-size: 13
  style.bold: true
}

or_recurse: |md
  **Inclusion-exclusion**
  
  sel_left  = estimate(expr.left)
  sel_right = estimate(expr.right)
| {
  style: {
    fill: "#E6FFFA"
    font-color: "#1A202C"
    border-radius: 6
  }
}

or_branch -> or_recurse

or_formula: "sel = sel_L + sel_R − sel_L × sel_R" {
  style: {
    fill: "#B2F5EA"
    font-color: "#1A202C"
    bold: true
    font-size: 14
    border-radius: 4
    font: mono
  }
}

or_recurse -> or_formula

or_equiv: |md
  Equivalent form:
  `sel = 1 − (1 − sel_L) × (1 − sel_R)`
  **Example:** sel_L=0.3, sel_R=0.2
  **result = 0.3 + 0.2 − 0.06 = 0.44**
| {
  style: {
    fill: "#F0FFF4"
    font-color: "#2C7A7B"
    border-radius: 4
    font-size: 12
  }
}

or_formula -> or_equiv

# ─── NOT branch ───
not_branch: "NODE_NOT /\nNODE_UNARY_OP(NOT)" {
  style: {
    fill: "#744210"
    font-color: "#FFFFFF"
    bold: true
    font-size: 13
    border-radius: 4
  }
}

type_dispatch -> not_branch: "NOT" {
  style.font-size: 13
  style.bold: true
}

not_formula: "sel = 1.0 − estimate(expr.operand)" {
  style: {
    fill: "#FEFCBF"
    font-color: "#744210"
    bold: true
    font-size: 14
    border-radius: 4
    font: mono
  }
}

not_branch -> not_formula

# ─── BINARY_OP branch ───
binop_branch: "NODE_BINARY_OP" {
  style: {
    fill: "#2B6CB0"
    font-color: "#FFFFFF"
    bold: true
    font-size: 14
    border-radius: 4
  }
}

type_dispatch -> binop_branch: "BinaryOp" {
  style.font-size: 13
  style.bold: true
}

op_check: "operator?" {
  shape: diamond
  style: {
    fill: "#3182CE"
    font-color: "#FFFFFF"
    font-size: 14
    bold: true
  }
}

binop_branch -> op_check

# ─── Equality ───
eq_path: "op = \"=\"" {
  style: {
    fill: "#276749"
    font-color: "#FFFFFF"
    bold: true
    font-size: 14
    border-radius: 4
  }
}

op_check -> eq_path: "=" {
  style.bold: true
  style.font-size: 14
}

eq_lookup: "ndv = stats.distinct_count\nfor this column" {
  style: {
    fill: "#C6F6D5"
    font-color: "#1A202C"
    border-radius: 6
    font-size: 13
  }
}

eq_path -> eq_lookup

eq_ndv_check: "ndv > 0?" {
  shape: diamond
  style: {
    fill: "#38A169"
    font-color: "#FFFFFF"
    font-size: 13
  }
}

eq_lookup -> eq_ndv_check

eq_formula: |md
  **sel = 1.0 / ndv**
  (uniform distribution)
| {
  style: {
    fill: "#9AE6B4"
    font-color: "#1A202C"
    bold: true
    font-size: 15
    border-radius: 4
  }
}

eq_ndv_check -> eq_formula: "YES" {
  style.stroke: "#38A169"
  style.bold: true
}

eq_default: "sel = 1.0 / 100\n= 0.01 (default NDV)" {
  style: {
    fill: "#FED7D7"
    font-color: "#9B2C2C"
    bold: true
    font-size: 13
    border-radius: 4
  }
}

eq_ndv_check -> eq_default: "NO" {
  style.stroke: "#E53E3E"
  style.bold: true
}

eq_example: |md
  **Example:** col has 50 distinct values
  `WHERE col = 'x'` → sel = 1/50 = **0.02**
  Est. rows = 0.02 × 100,000 = **2,000**
| {
  style: {
    fill: "#F0FFF4"
    font-color: "#276749"
    border-radius: 4
    font-size: 12
  }
}

eq_formula -> eq_example

# ─── Not-Equal ───
neq_path: "op = \"!=\"" {
  style: {
    fill: "#9B2C2C"
    font-color: "#FFFFFF"
    bold: true
    font-size: 14
    border-radius: 4
  }
}

op_check -> neq_path: "!=" {
  style.bold: true
  style.font-size: 14
}

neq_formula: "sel = 1.0 − (1.0 / ndv)" {
  style: {
    fill: "#FED7D7"
    font-color: "#9B2C2C"
    bold: true
    font-size: 14
    border-radius: 4
    font: mono
  }
}

neq_path -> neq_formula

# ─── Range ───
range_path: "op ∈ {<, <=, >, >=}" {
  style: {
    fill: "#C05621"
    font-color: "#FFFFFF"
    bold: true
    font-size: 13
    border-radius: 4
  }
}

op_check -> range_path: "< <= > >=" {
  style.bold: true
  style.font-size: 13
}

range_minmax: "min/max stats\navailable for column?" {
  shape: diamond
  style: {
    fill: "#DD6B20"
    font-color: "#FFFFFF"
    font-size: 13
  }
}

range_path -> range_minmax

range_default: "return 0.33\n(default range sel)" {
  style: {
    fill: "#E53E3E"
    font-color: "#FFFFFF"
    bold: true
    font-size: 13
    border-radius: 6
  }
}

range_minmax -> range_default: "NO\n(non-numeric\nor no stats)" {
  style.stroke: "#E53E3E"
  style.bold: true
  style.font-size: 11
}

range_compute: "Compute from\nvalue range" {
  style: {
    fill: "#FEEBC8"
    font-color: "#1A202C"
    bold: true
    border-radius: 6
  }
}

range_minmax -> range_compute: "YES\n(numeric col)" {
  style.stroke: "#38A169"
  style.bold: true
  style.font-size: 11
}

range_gt: |md
  **op = ">" or ">="**
  
  sel = (max − value) / (max − min)
| {
  style: {
    fill: "#FBD38D"
    font-color: "#1A202C"
    border-radius: 4
    font-size: 13
  }
}

range_lt: |md
  **op = "<" or "<="**
  
  sel = (value − min) / (max − min)
| {
  style: {
    fill: "#FBD38D"
    font-color: "#1A202C"
    border-radius: 4
    font-size: 13
  }
}

range_compute -> range_gt
range_compute -> range_lt

range_example: |md
  **Example:** min=10, max=100, `col > 60`
  sel = (100−60)/(100−10) = 40/90 ≈ **0.44**
| {
  style: {
    fill: "#FFFAF0"
    font-color: "#C05621"
    border-radius: 4
    font-size: 12
  }
}

range_gt -> range_example
range_lt -> range_example

# ─── IS NULL ───
isnull_path: "IS NULL check\n(NULL literal\nin comparison)" {
  style: {
    fill: "#4A5568"
    font-color: "#FFFFFF"
    bold: true
    font-size: 13
    border-radius: 4
  }
}

op_check -> isnull_path: "IS NULL" {
  style.bold: true
  style.font-size: 13
}

isnull_stats: "null_count in\ncolumn stats?" {
  shape: diamond
  style: {
    fill: "#718096"
    font-color: "#FFFFFF"
    font-size: 13
  }
}

isnull_path -> isnull_stats

isnull_formula: "sel = null_count / row_count" {
  style: {
    fill: "#CBD5E0"
    font-color: "#1A202C"
    bold: true
    font-size: 14
    border-radius: 4
    font: mono
  }
}

isnull_stats -> isnull_formula: "YES" {
  style.stroke: "#38A169"
  style.bold: true
}

isnull_default: "sel = 0.01\n(DEFAULT_NULL_FRACTION)" {
  style: {
    fill: "#FED7D7"
    font-color: "#9B2C2C"
    font-size: 13
    border-radius: 4
  }
}

isnull_stats -> isnull_default: "NO" {
  style.stroke: "#E53E3E"
  style.bold: true
}

# ─── Unknown expr ───
unknown_path: "unknown\nexpr type" {
  style: {
    fill: "#718096"
    font-color: "#FFFFFF"
    bold: true
    font-size: 13
    border-radius: 4
  }
}

type_dispatch -> unknown_path: "other" {
  style.font-size: 13
  style.stroke-dash: 3
}

unknown_result: "return 0.5\n(conservative)" {
  style: {
    fill: "#E53E3E"
    font-color: "#FFFFFF"
    bold: true
    font-size: 13
    border-radius: 6
  }
}

unknown_path -> unknown_result

# ─── Clamp box ───
clamp: |md
  ## Final Clamp (all paths)
  
  return CLAMP(sel, 0.001, 1.0)
  
  - Never return 0 (implies impossible query)
  - Never return > 1.0 (mathematical impossibility)
  - MIN_SELECTIVITY = 0.001
  - MAX_SELECTIVITY = 1.0
| {
  shape: rectangle
  style: {
    fill: "#1A202C"
    font-color: "#FFFFFF"
    bold: true
    font-size: 14
    border-radius: 8
    stroke: "#E53E3E"
    stroke-width: 3
  }
}

and_example -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
or_equiv -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
not_formula -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
eq_example -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
eq_default -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
neq_formula -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
range_example -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
range_default -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
isnull_formula -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
isnull_default -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
no_stats -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }
unknown_result -> clamp: "" { style.stroke-dash: 5; style.stroke: "#718096" }

# ─── Cost model connection ───
cost_model: |md
  ## → Feeds into Cost Model
  
  est_rows = sel × row_count
  idx_cost = tree_height + est_rows × 4.0
  scan_cost = page_count
  
  Planner picks **min(idx_cost, scan_cost)**
| {
  shape: rectangle
  style: {
    fill: "#2D3748"
    font-color: "#FFFFFF"
    font-size: 13
    border-radius: 8
    stroke: "#3182CE"
    stroke-width: 2
    double-border: true
  }
}

clamp -> cost_model: "selectivity value" {
  style: {
    stroke: "#3182CE"
    stroke-width: 3
    bold: true
    font-size: 14
    animated: true
  }
}