vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Dynamic Programming Join Ordering
  ## 3 Tables: A(100 rows), B(1000 rows), C(500 rows)
| {near: top-center}

direction: down

# ============================================================
# LEVEL 0 — BASE CASES (single tables)
# ============================================================
base_cases: "Level 0 — Base Cases (Single Tables)" {
  style.fill: "#E8F4FD"
  style.stroke: "#2B6CB0"
  style.border-radius: 8
  style.font-size: 20
  grid-columns: 3
  grid-gap: 20

  dp_a: |md
    **dp[{A}] = mask 001**
    ---
    Table: **A**
    Rows: 100
    Pages: 3
    ---
    **Cost = 3**
    Est. rows = 100
  | {
    style.fill: "#C6F6D5"
    style.stroke: "#276749"
    style.font-size: 16
    style.border-radius: 6
  }

  dp_b: |md
    **dp[{B}] = mask 010**
    ---
    Table: **B**
    Rows: 1000
    Pages: 30
    ---
    **Cost = 30**
    Est. rows = 1000
  | {
    style.fill: "#FEFCBF"
    style.stroke: "#975A16"
    style.font-size: 16
    style.border-radius: 6
  }

  dp_c: |md
    **dp[{C}] = mask 100**
    ---
    Table: **C**
    Rows: 500
    Pages: 15
    ---
    **Cost = 15**
    Est. rows = 500
  | {
    style.fill: "#FED7E2"
    style.stroke: "#97266D"
    style.font-size: 16
    style.border-radius: 6
  }
}

# ============================================================
# LEVEL 1 — TWO-TABLE SUBSETS
# ============================================================
two_table: "Level 1 — Two-Table Subsets" {
  style.fill: "#EDF2F7"
  style.stroke: "#4A5568"
  style.border-radius: 8
  style.font-size: 20
  grid-columns: 3
  grid-gap: 20

  # ---- dp[{A,B}] ----
  dp_ab: "dp[{A,B}] = mask 011" {
    style.fill: "#FFFFFF"
    style.stroke: "#2B6CB0"
    style.border-radius: 6
    header_ab: |md
      **Join: A.x = B.y**
      NDV_A = 100, NDV_B = 100
      Card = 100×1000 / max(100,100) = **1000**
    | {
      style.fill: "#EBF8FF"
      style.stroke: "#2B6CB0"
      style.font-size: 14
    }
    option_ab_1: |md
      **Option 1: A outer, B inner**
      cost = dp[A] + dp[B]
           + A.rows × B.pages
      cost = 3 + 30 + 100 × 30
      cost = 3 + 30 + 3000
      **= 3033**
    | {
      style.fill: "#C6F6D5"
      style.stroke: "#276749"
      style.font-size: 13
      style.border-radius: 4
      style.bold: true
    }
    option_ab_2: |md
      **Option 2: B outer, A inner**
      cost = dp[B] + dp[A]
           + B.rows × A.pages
      cost = 30 + 3 + 1000 × 3
      cost = 30 + 3 + 3000
      **= 3033**
    | {
      style.fill: "#FEFCBF"
      style.stroke: "#975A16"
      style.font-size: 13
      style.border-radius: 4
    }
    winner_ab: |md
      ✅ **Winner: A outer** (tie → smaller table)
      Cost = **3033**, Est. rows = **1000**
    | {
      style.fill: "#C6F6D5"
      style.stroke: "#22543D"
      style.font-size: 14
      style.bold: true
      style.border-radius: 4
    }
  }

  # ---- dp[{A,C}] ----
  dp_ac: "dp[{A,C}] = mask 101" {
    style.fill: "#FFFFFF"
    style.stroke: "#97266D"
    style.border-radius: 6
    header_ac: |md
      **Join: A.x = C.z** (if edge exists)
      NDV_A = 100, NDV_C = 100
      Card = 100×500 / max(100,100) = **500**
    | {
      style.fill: "#FFF5F7"
      style.stroke: "#97266D"
      style.font-size: 14
    }
    option_ac_1: |md
      **Option 1: A outer, C inner**
      cost = dp[A] + dp[C]
           + A.rows × C.pages
      cost = 3 + 15 + 100 × 15
      cost = 3 + 15 + 1500
      **= 1518**
    | {
      style.fill: "#C6F6D5"
      style.stroke: "#276749"
      style.font-size: 13
      style.border-radius: 4
      style.bold: true
    }
    option_ac_2: |md
      **Option 2: C outer, A inner**
      cost = dp[C] + dp[A]
           + C.rows × A.pages
      cost = 15 + 3 + 500 × 3
      cost = 15 + 3 + 1500
      **= 1518**
    | {
      style.fill: "#FED7E2"
      style.stroke: "#97266D"
      style.font-size: 13
      style.border-radius: 4
    }
    winner_ac: |md
      ✅ **Winner: A outer** (tie → smaller table)
      Cost = **1518**, Est. rows = **500**
    | {
      style.fill: "#C6F6D5"
      style.stroke: "#22543D"
      style.font-size: 14
      style.bold: true
      style.border-radius: 4
    }
  }

  # ---- dp[{B,C}] ----
  dp_bc: "dp[{B,C}] = mask 110" {
    style.fill: "#FFFFFF"
    style.stroke: "#975A16"
    style.border-radius: 6
    header_bc: |md
      **Join: B.y = C.z**
      NDV_B = 50, NDV_C = 50
      Card = 1000×500 / max(50,50) = **10000**
    | {
      style.fill: "#FFFFF0"
      style.stroke: "#975A16"
      style.font-size: 14
    }
    option_bc_1: |md
      **Option 1: B outer, C inner**
      cost = dp[B] + dp[C]
           + B.rows × C.pages
      cost = 30 + 15 + 1000 × 15
      cost = 30 + 15 + 15000
      **= 15045**
    | {
      style.fill: "#FEFCBF"
      style.stroke: "#975A16"
      style.font-size: 13
      style.border-radius: 4
    }
    option_bc_2: |md
      **Option 2: C outer, B inner**
      cost = dp[C] + dp[B]
           + C.rows × B.pages
      cost = 15 + 30 + 500 × 30
      cost = 15 + 30 + 15000
      **= 15045**
    | {
      style.fill: "#FED7E2"
      style.stroke: "#97266D"
      style.font-size: 13
      style.border-radius: 4
    }
    winner_bc: |md
      ✅ **Winner: C outer** (tie → smaller table)
      Cost = **15045**, Est. rows = **10000**
    | {
      style.fill: "#FED7E2"
      style.stroke: "#702459"
      style.font-size: 14
      style.bold: true
      style.border-radius: 4
    }
  }
}

# ============================================================
# LEVEL 2 — THREE-TABLE FULL SET
# ============================================================
three_table: "Level 2 — Full Set dp[{A,B,C}] = mask 111" {
  style.fill: "#FAF5FF"
  style.stroke: "#6B46C1"
  style.border-radius: 8
  style.font-size: 20

  candidates: "Candidate Partitions" {
    style.fill: "#F7FAFC"
    style.stroke: "#4A5568"
    style.border-radius: 6
    grid-columns: 3
    grid-gap: 16

    part1: |md
      **Partition 1**
      Left = {A} (mask 001)
      Right = {B,C} (mask 110)
      ---
      cost = dp[{A}] + dp[{B,C}]
           + A.rows × inner_probe
      cost = 3 + 15045
           + 100 × 15 *(C inner of BC)*
      **= 16548**
      Est. rows = card(A ⋈ BC)
    | {
      style.fill: "#FEFCBF"
      style.stroke: "#975A16"
      style.font-size: 13
      style.border-radius: 4
    }
    part2: |md
      **Partition 2**
      Left = {B} (mask 010)
      Right = {A,C} (mask 101)
      ---
      cost = dp[{B}] + dp[{A,C}]
           + B.rows × inner_probe
      cost = 30 + 1518
           + 1000 × 3 *(A inner of AC)*
      **= 4548**
      Est. rows = card(B ⋈ AC)
    | {
      style.fill: "#FEFCBF"
      style.stroke: "#975A16"
      style.font-size: 13
      style.border-radius: 4
    }
    part3: |md
      **Partition 3**
      Left = {C} (mask 100)
      Right = {A,B} (mask 011)
      ---
      cost = dp[{C}] + dp[{A,B}]
           + C.rows × inner_probe
      cost = 15 + 3033
           + 500 × 3 *(A inner of AB)*
      **= 4548**
      Est. rows = card(C ⋈ AB)
    | {
      style.fill: "#FEFCBF"
      style.stroke: "#975A16"
      style.font-size: 13
      style.border-radius: 4
    }
  }

  selection: "Optimal Plan Selection" {
    style.fill: "#F0FFF4"
    style.stroke: "#276749"
    style.border-radius: 6
    grid-columns: 1
    
    comparison: ||md
      | Partition | Left | Right | Total Cost |
      |-----------|------|-------|------------|
      | 1 | {A} | {B,C} | **16548** |
      | 2 | {B} | {A,C} | **4548** |
      | 3 | {C} | {A,B} | **4548** |
    || {
      style.fill: "#FFFFFF"
      style.font-size: 14
    }

    winner: |md
      ## ✅ WINNER: Partition 2 or 3 (tie at cost 4548)
      ### Selected: **{A,C} then B** or **{A,B} then C**
      Minimum cost = **4548**
    | {
      style.fill: "#C6F6D5"
      style.stroke: "#22543D"
      style.font-size: 16
      style.bold: true
      style.border-radius: 6
    }
  }
}

# ============================================================
# FINAL — COMPLETE DP TABLE SUMMARY
# ============================================================
dp_table: "Complete DP Table" {
  style.fill: "#1A202C"
  style.stroke: "#E2E8F0"
  style.border-radius: 8
  style.font-color: "#E2E8F0"
  style.font-size: 18

  summary: ||md
    | Mask | Subset | Optimal Cost | Est. Rows | Best Split |
    |------|--------|-------------|-----------|------------|
    | 001 | {A} | **3** | 100 | — (base) |
    | 010 | {B} | **30** | 1000 | — (base) |
    | 100 | {C} | **15** | 500 | — (base) |
    | 011 | {A,B} | **3033** | 1000 | L={A}, R={B} |
    | 101 | {A,C} | **1518** | 500 | L={A}, R={C} |
    | 110 | {B,C} | **15045** | 10000 | L={C}, R={B} |
    | **111** | **{A,B,C}** | **4548** | — | **L={B}, R={A,C}** |
  || {
    style.fill: "#2D3748"
    style.font-color: "#E2E8F0"
    style.font-size: 15
    style.border-radius: 6
  }
}

# ============================================================
# OPTIMAL PLAN TREE
# ============================================================
plan_tree: "Optimal Execution Plan Tree" {
  style.fill: "#FFFFF0"
  style.stroke: "#975A16"
  style.border-radius: 8
  style.font-size: 18

  nl_outer: "NESTED LOOP\ncost = 4548" {
    style.fill: "#6B46C1"
    style.font-color: white
    style.font-size: 16
    style.bold: true
    style.border-radius: 8
    style.shadow: true
  }
  b_scan: "SCAN B\n1000 rows\ncost = 30" {
    style.fill: "#FEFCBF"
    style.stroke: "#975A16"
    style.font-size: 14
    style.border-radius: 6
  }
  nl_inner: "NESTED LOOP\ncost = 1518" {
    style.fill: "#805AD5"
    style.font-color: white
    style.font-size: 14
    style.bold: true
    style.border-radius: 8
  }
  a_scan: "SCAN A\n100 rows\ncost = 3" {
    style.fill: "#C6F6D5"
    style.stroke: "#276749"
    style.font-size: 14
    style.border-radius: 6
  }
  c_scan: "SCAN C\n500 rows\ncost = 15" {
    style.fill: "#FED7E2"
    style.stroke: "#97266D"
    style.font-size: 14
    style.border-radius: 6
  }

  nl_outer -> b_scan: "outer\n(driving)" {
    style.stroke: "#276749"
    style.font-size: 12
    style.bold: true
  }
  nl_outer -> nl_inner: "inner\n(probed)" {
    style.stroke: "#97266D"
    style.font-size: 12
    style.stroke-dash: 3
  }
  nl_inner -> a_scan: "outer" {
    style.stroke: "#276749"
    style.font-size: 12
  }
  nl_inner -> c_scan: "inner" {
    style.stroke: "#97266D"
    style.font-size: 12
    style.stroke-dash: 3
  }
}

# ============================================================
# FLOW CONNECTIONS BETWEEN LEVELS
# ============================================================
base_cases -> two_table: "enumerate 2-table subsets" {
  style.stroke: "#4A5568"
  style.stroke-dash: 5
  style.font-size: 13
}
two_table -> three_table: "enumerate 3-table partitions\nusing 2-table sub-solutions" {
  style.stroke: "#4A5568"
  style.stroke-dash: 5
  style.font-size: 13
}
three_table -> dp_table: "record optimal in DP table" {
  style.stroke: "#6B46C1"
  style.stroke-dash: 5
  style.font-size: 13
}
dp_table -> plan_tree: "extract plan tree\nfrom dp[111]" {
  style.stroke: "#975A16"
  style.font-size: 13
  style.bold: true
  style.animated: true
}

# ============================================================
# ANNOTATION — KEY INSIGHT
# ============================================================
insight: |md
  ### Key Insight
  DP exploits **optimal substructure**: the best plan for
  {A,B,C} reuses the already-computed best plan for {A,C}.
  Complexity: **O(3ⁿ)** for n tables — tractable up to ~12 tables.
  Beyond that, switch to greedy or genetic algorithms.
| {
  near: bottom-center
  style.fill: "#EBF8FF"
  style.stroke: "#2B6CB0"
  style.font-size: 14
  style.border-radius: 8
}