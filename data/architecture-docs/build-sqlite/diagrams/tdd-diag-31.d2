vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
  }
}
shape: sequence_diagram
vm: VM (VDBE)
bp: BufferPool
jrnl: Journal File\n(.db-journal)
disk: Database File\n(.db)
dir: Directory\n(fsync target)
# ── PHASE 1: Page Modification with Journal-Before-Data ──
vm."Phase 1 — Page 7 Write" {
  style.font-size: 13
  style.bold: true
}
vm.t1 -> bp.t1: "write_page(7, new_data)" {
  style.stroke: "#2563EB"
  style.bold: true
}
bp."① Check journaled_pages[7]" {
  style.font-size: 12
  style.italic: true
}
bp.t1 -> bp.t1: "journaled_pages[7] == false\n→ must journal original first" {
  style.stroke: "#6B7280"
  style.stroke-dash: 3
}
bp.t2 -> disk.t1: "② pread(fd, buf, 4096,\n    7 × PAGE_SIZE)" {
  style.stroke: "#DC2626"
  style.bold: true
}
bp.t2 <- disk.t1: "original_bytes[4096]" {
  style.stroke: "#DC2626"
  style.stroke-dash: 5
}
bp.t3 -> jrnl.t1: "③ append_journal_entry(\n    page_id=7,\n    original_bytes[4096],\n    checksum)" {
  style.stroke: "#D97706"
  style.bold: true
}
bp.t4 -> jrnl.t2: "④ fsync(journal_fd)" {
  style.stroke: "#D97706"
  style.bold: true
}
bp.t4 <- jrnl.t2: "✓ journal entry durable" {
  style.stroke: "#16A34A"
  style.bold: true
}
bp."BARRIER: original bytes now\nsurvive power failure" {
  style.font-size: 12
  style.bold: true
  style.font-color: "#16A34A"
}
bp.t5 -> bp.t5: "⑤ memcpy(frame->data,\n    new_data, 4096)" {
  style.stroke: "#2563EB"
}
bp.t6 -> bp.t6: "⑥ frame->is_dirty = true\n   journaled_pages[7] = true" {
  style.stroke: "#2563EB"
}
bp.t6 <- vm.t6: " " {
  style.opacity: 0
}
# ── CRASH WINDOW ANNOTATION ──
vm."⚠ CRASH WINDOW" {
  style.font-size: 14
  style.bold: true
  style.font-color: "#DC2626"
}
vm."If crash between ⑤ and (A):\n• Database file: page 7 = old data\n  (new_data only in RAM, lost)\n• Journal file: contains original_bytes\n• Recovery: replay journal → restores\n  page 7 to original (no-op, already\n  original on disk) → consistent state" {
  style.font-size: 11
  style.font-color: "#DC2626"
}
# ── PHASE 2: COMMIT Sequence ──
vm."Phase 2 — COMMIT" {
  style.font-size: 13
  style.bold: true
}
vm.c0 -> bp.c0: "txn_commit()" {
  style.stroke: "#7C3AED"
  style.bold: true
}
bp.c0 -> jrnl.c0: "fsync(journal_fd)\nensure ALL entries durable" {
  style.stroke: "#D97706"
}
bp.c1 -> disk.c1: "(A) pwrite(fd, frame[7]->data,\n     4096, 7 × PAGE_SIZE)" {
  style.stroke: "#DC2626"
  style.bold: true
}
bp.c1 <- disk.c1: "✓ written" {
  style.stroke: "#DC2626"
  style.stroke-dash: 5
}
bp."flush all other dirty frames..." {
  style.font-size: 11
  style.italic: true
}
bp.c2 -> disk.c2: "(B) fsync(db_fd)" {
  style.stroke: "#DC2626"
  style.bold: true
}
bp.c2 <- disk.c2: "✓ all data pages durable" {
  style.stroke: "#16A34A"
  style.bold: true
}
bp.c3 -> jrnl.c3: "(C) close(journal_fd)\n    unlink(journal_path)" {
  style.stroke: "#D97706"
  style.bold: true
}
bp."═══ COMMIT POINT ═══\nJournal deleted = transaction\nis permanently committed" {
  style.font-size: 12
  style.bold: true
  style.font-color: "#7C3AED"
}
bp.c4 -> dir.c1: "(D) fsync(directory_fd)" {
  style.stroke: "#6B7280"
}
bp.c4 <- dir.c1: "✓ deletion durable" {
  style.stroke: "#6B7280"
  style.stroke-dash: 5
}
bp.c5 -> bp.c5: "state = TXN_NONE\nfree(journaled_pages)\njournal_entry_count = 0" {
  style.stroke: "#6B7280"
}
bp.c5 <- vm.c5: " " {
  style.opacity: 0
}
vm."COMMIT complete → return 0" {
  style.font-size: 12
  style.bold: true
  style.font-color: "#16A34A"
}