layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # WAL Frame Binary Layout
  Frame = 24-byte header + 4096-byte page data = **4120 bytes**
|| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# ============================================================
# WAL FILE LAYOUT (top-level overview)
# ============================================================
wal-file: "WAL File Binary Structure" {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
    font-color: "#e0e0e0"
    border-radius: 8
  }
  
  hdr: "WAL Header — 32 bytes (offset 0x0000)" {
    style: {
      fill: "#6a0dad"
      font-color: white
      bold: true
      font-size: 18
    }
  }
  f0: "Frame 0 — 4120 bytes (offset 0x0020)" {
    style: {
      fill: "#2a4a7f"
      font-color: white
      bold: true
      font-size: 16
    }
  }
  f1: "Frame 1 — 4120 bytes (offset 0x1038)" {
    style: {
      fill: "#2a5a6f"
      font-color: white
      bold: true
      font-size: 16
    }
  }
  fdots: "⋮ (Sequential Frames)" {
    style: {
      fill: "#1a1a2e"
      stroke: transparent
      font-color: "#888"
      font-size: 22
    }
  }
  fn: "Frame N — 4120 bytes (offset 0x0020 + N × 4120)" {
    style: {
      fill: "#2a4a7f"
      font-color: white
      bold: true
      font-size: 16
    }
  }

  hdr -> f0 -> f1 -> fdots -> fn
}

# ============================================================
# WAL HEADER — 32 bytes
# ============================================================
wal-header: "WAL Header (32 Bytes)" {
  style: {
    fill: "#1a0a2e"
    stroke: "#8b5cf6"
    stroke-width: 3
    border-radius: 8
    font-color: "#e0e0e0"
  }
  
  row0: "[0x00 – 0x03] magic: uint32 BE | 0x377F0682 (BE) or 0x377F0683 (LE)" {
    width: 700
    style: {
      fill: "#6a0dad"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  row1: "[0x04 – 0x07] format_version: uint32 BE | 3007000 (0x002DE5E8)" {
    width: 700
    style: {
      fill: "#7c3aed"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  row2: "[0x08 – 0x0B] page_size: uint32 BE | 4096 (0x00001000)" {
    width: 700
    style: {
      fill: "#6a0dad"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  row3: "[0x0C – 0x0F] checkpoint_seq: uint32 BE | Incremented each checkpoint" {
    width: 700
    style: {
      fill: "#7c3aed"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  row4: "[0x10 – 0x13] salt1: uint32 BE | Random for current WAL generation" {
    width: 700
    style: {
      fill: "#f97316"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  row5: "[0x14 – 0x17] salt2: uint32 BE | Random for current WAL generation" {
    width: 700
    style: {
      fill: "#ea580c"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  row6: "[0x18 – 0x1B] checksum1: uint32 BE | Cumulative cksum of bytes 0x00–0x17" {
    width: 700
    style: {
      fill: "#059669"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  row7: "[0x1C – 0x1F] checksum2: uint32 BE | Cumulative cksum of bytes 0x00–0x17" {
    width: 700
    style: {
      fill: "#047857"
      font-color: white
      font: mono
      font-size: 14
      border-radius: 4
    }
  }
  
  row0 -> row1 -> row2 -> row3 -> row4 -> row5 -> row6 -> row7
}

header-note: ||md
  **Header Checksum Scope:**
  Covers first 24 bytes (**0x00–0x17**).
  The checksum fields themselves (**0x18–0x1F**) are excluded.
  Salts bind every frame in this WAL to this specific header.
|| {
  near: top-right
  style: {
    fill: transparent
    stroke: transparent
    font-size: 13
    font-color: "#aaa"
  }
}

# ============================================================
# WAL FRAME — 4120 bytes
# ============================================================
frame: "WAL Frame Layout (4120 Bytes)" {
  style: {
    fill: "#0a1628"
    stroke: "#3b82f6"
    stroke-width: 3
    border-radius: 8
    font-color: "#e0e0e0"
  }
  
  frame-hdr: "Frame Header (24 Bytes)" {
    style: {
      fill: "#0f172a"
      stroke: "#60a5fa"
      stroke-width: 2
      border-radius: 6
      font-color: "#e0e0e0"
    }
    f0: "[0x00 – 0x03] page_number: uint32 BE | Target DB page ID" {
      width: 680
      style: {
        fill: "#1e40af"
        font-color: white
        font: mono
        font-size: 14
        border-radius: 4
      }
    }
    f1: "[0x04 – 0x07] db_size: uint32 BE | COMMIT marker if > 0 (Size of DB in pages)" {
      width: 680
      style: {
        fill: "#dc2626"
        font-color: white
        font: mono
        font-size: 14
        border-radius: 4
        bold: true
      }
    }
    f2: "[0x08 – 0x0B] salt1: uint32 BE | Must match WAL Header salt1" {
      width: 680
      style: {
        fill: "#f97316"
        font-color: white
        font: mono
        font-size: 14
        border-radius: 4
      }
    }
    f3: "[0x0C – 0x0F] salt2: uint32 BE | Must match WAL Header salt2" {
      width: 680
      style: {
        fill: "#ea580c"
        font-color: white
        font: mono
        font-size: 14
        border-radius: 4
      }
    }
    f4: "[0x10 – 0x13] checksum1: uint32 BE | Running total cksum1" {
      width: 680
      style: {
        fill: "#059669"
        font-color: white
        font: mono
        font-size: 14
        border-radius: 4
      }
    }
    f5: "[0x14 – 0x17] checksum2: uint32 BE | Running total cksum2" {
      width: 680
      style: {
        fill: "#047857"
        font-color: white
        font: mono
        font-size: 14
        border-radius: 4
      }
    }
    
    f0 -> f1 -> f2 -> f3 -> f4 -> f5
  }
  
  page-data: "[0x18 – 0x1017] page_data: 4096 bytes (PAGE_SIZE) | Raw Page Image" {
    width: 680
    height: 120
    style: {
      fill: "#1e3a5f"
      font-color: "#93c5fd"
      font: mono
      font-size: 15
      border-radius: 6
      stroke: "#3b82f6"
      stroke-width: 2
      fill-pattern: grain
    }
  }
  
  frame-hdr -> page-data
}

commit-note: ||md
  ### Transaction Boundaries
  | Value of `db_size` | Context |
  | :--- | :--- |
  | **0** | Intermediate frame (uncommitted) |
  | **> 0** | **COMMIT Frame** |

  Only frames up to the last valid Commit Frame are recovered. 
  `db_size` at commit specifies how many pages the DB file 
  contains after this transaction is applied.
|| {
  near: center-right
  style: {
    fill: "#2a0a0a"
    stroke: "#dc2626"
    stroke-width: 2
    font-size: 13
    font-color: "#fca5a5"
    border-radius: 6
  }
}

# ============================================================
# CHECKSUM CHAIN DIAGRAM
# ============================================================
chain: "Cumulative Checksum Propagation Chain" {
  style: {
    fill: "#0a1a0a"
    stroke: "#22c55e"
    stroke-width: 2
    border-radius: 8
    font-color: "#bbfbbf"
  }
  
  hdr-ck: "WAL Header\nInitial ck1=0, ck2=0\nOutput: (ck1_h, ck2_h)" {
    style: {
      fill: "#6a0dad"
      font-color: white
      font-size: 13
      font: mono
      border-radius: 6
    }
  }
  f0-ck: "Frame 0\nInput: (ck1_h, ck2_h)\nScope: [page_num, db_size] + [page_data]\nOutput: (ck1_0, ck2_0)" {
    style: {
      fill: "#1e40af"
      font-color: white
      font-size: 13
      font: mono
      border-radius: 6
    }
  }
  f1-ck: "Frame 1\nInput: (ck1_0, ck2_0)\nScope: [page_num, db_size] + [page_data]\nOutput: (ck1_1, ck2_1)" {
    style: {
      fill: "#2a5a6f"
      font-color: white
      font-size: 13
      font: mono
      border-radius: 6
    }
  }
  fn-ck: "Frame N\nInput: (ck1_n-1, ck2_n-1)\nOutput: (ck1_n, ck2_n)\n\nChain Fail = Invalid WAL" {
    style: {
      fill: "#7f1d1d"
      font-color: "#fca5a5"
      font-size: 13
      font: mono
      border-radius: 6
    }
  }
  
  hdr-ck -> f0-ck: "Seed Checksum" {
    style: {
      stroke: "#22c55e"
      stroke-width: 2
      font-color: "#86efac"
      font-size: 12
      animated: true
    }
  }
  f0-ck -> f1-ck: "Propagate" {
    style: {
      stroke: "#22c55e"
      stroke-width: 2
      font-color: "#86efac"
      font-size: 12
      animated: true
    }
  }
  f1-ck -> fn-ck: "..." {
    style: {
      stroke: "#22c55e"
      stroke-width: 2
      stroke-dash: 5
      font-color: "#86efac"
      font-size: 12
      animated: true
    }
  }
}

cksum-note: ||md
  ### Checksum Algorithm Specifics
  1.  Initialize with previous state (or 0 for header).
  2.  Sum 8 bytes (page_num, db_size) as `uint32` pairs.
  3.  Sum 4096 bytes (page_data) as `uint32` pairs.
  4.  Resulting `(ck1, ck2)` stored in frame header.
  
  **Note:** Salts (0x08–0x0F) are **NOT** checksummed inside the frame.
|| {
  near: bottom-center
  style: {
    fill: "#111"
    stroke: "#333"
    font-size: 13
    font-color: "#ccc"
    border-radius: 6
  }
}

sizes: ||md
  ### Component Geometry
  | Part | Size | Offset |
  | :--- | :--- | :--- |
  | WAL Header | 32 B | 0x0000 |
  | Frame Header | 24 B | 32 + (N * 4120) |
  | Page Payload | 4096 B | 32 + 24 + (N * 4120) |
  | **Total WAL** | **-** | **32 + (Count * 4120)** |
|| {
  near: bottom-right
  style: {
    fill: "#111827"
    stroke: "#374151"
    font-size: 13
    font-color: "#d1d5db"
    border-radius: 6
  }
}

legend: ||md
  ### Legend
  - 🟣 **Header Meta**: Purple
  - 🔵 **Page Content**: Blue
  - 🔴 **Commit Guard**: Red
  - 🟠 **Entropy Salt**: Orange
  - 🟢 **Integrity**: Green
|| {
  style: {
    fill: "#18181b"
    stroke: "#3f3f46"
    font-size: 13
    font-color: "#a1a1aa"
    border-radius: 6
  }
}