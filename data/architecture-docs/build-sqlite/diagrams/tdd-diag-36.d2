vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
direction: down
title: "WAL Mode vs Rollback Journal: Write Path Comparison" {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
rollback: Rollback Journal Mode {
  style: {
    fill: "#FFF5F5"
    stroke: "#C53030"
    border-radius: 8
    font-size: 20
    bold: true
  }
  direction: down
  rj-step1: "1. Page P needs modification" {
    style: {
      fill: "#FED7D7"
      font-size: 14
      border-radius: 5
    }
  }
  rj-step2: "2. Copy ORIGINAL P\nto journal file" {
    style: {
      fill: "#FC8181"
      font-color: white
      font-size: 14
      bold: true
      border-radius: 5
    }
  }
  rj-step3: "3. fsync(journal)" {
    style: {
      fill: "#E53E3E"
      font-color: white
      font-size: 13
      bold: true
      border-radius: 5
    }
  }
  rj-step4: "4. Write MODIFIED P\nto database file" {
    style: {
      fill: "#FC8181"
      font-color: white
      font-size: 14
      bold: true
      border-radius: 5
    }
  }
  rj-step5: "5. fsync(database)" {
    style: {
      fill: "#E53E3E"
      font-color: white
      font-size: 13
      bold: true
      border-radius: 5
    }
  }
  rj-step6: "6. COMMIT:\nDelete journal file" {
    style: {
      fill: "#9B2C2C"
      font-color: white
      font-size: 14
      bold: true
      border-radius: 5
    }
  }
  rj-step1 -> rj-step2: "read original" {
    style.stroke: "#C53030"
    style.font-size: 12
  }
  rj-step2 -> rj-step3: "barrier" {
    style.stroke: "#C53030"
    style.stroke-dash: 3
    style.font-size: 11
  }
  rj-step3 -> rj-step4: "safe to modify DB" {
    style.stroke: "#C53030"
    style.font-size: 12
  }
  rj-step4 -> rj-step5: "barrier" {
    style.stroke: "#C53030"
    style.stroke-dash: 3
    style.font-size: 11
  }
  rj-step5 -> rj-step6: "commit point" {
    style.stroke: "#9B2C2C"
    style.font-size: 12
    style.bold: true
  }
  rj-files: "Files During Transaction" {
    style: {
      fill: "#FFF5F5"
      stroke: "#E53E3E"
      border-radius: 5
      font-size: 13
    }
    rj-db: "database.db\n(MODIFIED in-place)" {
      style: {
        fill: "#FED7D7"
        font-size: 12
        border-radius: 4
      }
    }
    rj-jrnl: "database.db-journal\n(contains OLD pages)" {
      shape: cylinder
      style: {
        fill: "#FC8181"
        font-color: white
        font-size: 12
      }
    }
  }
}
wal: WAL Mode {
  style: {
    fill: "#F0FFF4"
    stroke: "#276749"
    border-radius: 8
    font-size: 20
    bold: true
  }
  direction: down
  w-step1: "1. Page P needs modification" {
    style: {
      fill: "#C6F6D5"
      font-size: 14
      border-radius: 5
    }
  }
  w-step2: "2. Append NEW version of P\nto WAL file (sequential)" {
    style: {
      fill: "#68D391"
      font-color: white
      font-size: 14
      bold: true
      border-radius: 5
    }
  }
  w-step3: "3. Database file\nNOT modified" {
    style: {
      fill: "#C6F6D5"
      font-size: 14
      italic: true
      border-radius: 5
    }
  }
  w-step4: "4. COMMIT:\nMark last frame with\ndb_size > 0 + fsync(WAL)" {
    style: {
      fill: "#276749"
      font-color: white
      font-size: 14
      bold: true
      border-radius: 5
    }
  }
  w-step5: "5. CHECKPOINT (later):\nCopy WAL frames →\ndatabase file" {
    style: {
      fill: "#48BB78"
      font-color: white
      font-size: 14
      bold: true
      border-radius: 5
      stroke-dash: 3
    }
  }
  w-step1 -> w-step2: "append-only" {
    style.stroke: "#276749"
    style.font-size: 12
  }
  w-step2 -> w-step3: "DB untouched" {
    style.stroke: "#276749"
    style.stroke-dash: 3
    style.font-size: 12
  }
  w-step3 -> w-step4: "commit point" {
    style.stroke: "#276749"
    style.font-size: 12
    style.bold: true
  }
  w-step4 -> w-step5: "deferred\n(async)" {
    style.stroke: "#276749"
    style.stroke-dash: 5
    style.animated: true
    style.font-size: 12
  }
  w-files: "Files During Transaction" {
    style: {
      fill: "#F0FFF4"
      stroke: "#48BB78"
      border-radius: 5
      font-size: 13
    }
    w-db: "database.db\n(UNTOUCHED — always consistent)" {
      style: {
        fill: "#C6F6D5"
        font-size: 12
        border-radius: 4
      }
    }
    w-wal: "database.db-wal\n(contains NEW pages)" {
      shape: cylinder
      style: {
        fill: "#68D391"
        font-color: white
        font-size: 12
      }
    }
    w-shm: "database.db-shm\n(WAL index — in-memory)" {
      style: {
        fill: "#9AE6B4"
        font-size: 11
        border-radius: 4
        stroke-dash: 3
      }
    }
  }
}
properties: "Key Properties Comparison" {
  style: {
    fill: "#EBF8FF"
    stroke: "#2B6CB0"
    border-radius: 8
    font-size: 18
    bold: true
  }
  grid-columns: 3
  grid-gap: 0
  hdr-prop: "Property" {
    style: {
      fill: "#2B6CB0"
      font-color: white
      font-size: 14
      bold: true
      underline: true
    }
  }
  hdr-rj: "Rollback Journal" {
    style: {
      fill: "#C53030"
      font-color: white
      font-size: 14
      bold: true
    }
  }
  hdr-wal: "WAL Mode" {
    style: {
      fill: "#276749"
      font-color: white
      font-size: 14
      bold: true
    }
  }
  p1: "Concurrency" {
    style.fill: "#EBF8FF"
    style.font-size: 13
    style.bold: true
  }
  r1: "Writers BLOCK readers\n(exclusive lock on DB file)" {
    style.fill: "#FFF5F5"
    style.font-size: 12
  }
  w1: "Readers DON'T block writers\n(snapshot isolation via max_frame)" {
    style.fill: "#F0FFF4"
    style.font-size: 12
  }
  p2: "Write I/O Pattern" {
    style.fill: "#EBF8FF"
    style.font-size: 13
    style.bold: true
  }
  r2: "RANDOM writes to DB file\n(pages scattered across file)" {
    style.fill: "#FFF5F5"
    style.font-size: 12
  }
  w2: "SEQUENTIAL appends to WAL\n(append-only — 2-10× faster)" {
    style.fill: "#F0FFF4"
    style.font-size: 12
  }
  p3: "Commit Mechanism" {
    style.fill: "#EBF8FF"
    style.font-size: 13
    style.bold: true
  }
  r3: "Delete journal file\n(unlink = commit point)" {
    style.fill: "#FFF5F5"
    style.font-size: 12
  }
  w3: "Append commit frame\nwith db_size > 0 + fsync" {
    style.fill: "#F0FFF4"
    style.font-size: 12
  }
  p4: "Crash Recovery" {
    style.fill: "#EBF8FF"
    style.font-size: 13
    style.bold: true
  }
  r4: "Read journal → restore\noriginal pages (UNDO)" {
    style.fill: "#FFF5F5"
    style.font-size: 12
  }
  w4: "Read WAL → replay\ncommitted frames (REDO)" {
    style.fill: "#F0FFF4"
    style.font-size: 12
  }
  p5: "File Lifecycle" {
    style.fill: "#EBF8FF"
    style.font-size: 13
    style.bold: true
  }
  r5: "Journal DELETED on commit\n(temporary file)" {
    style.fill: "#FFF5F5"
    style.font-size: 12
  }
  w5: "WAL GROWS until checkpoint\n(unbounded without checkpointing)" {
    style.fill: "#F0FFF4"
    style.font-size: 12
  }
  p6: "DB File State\nDuring Transaction" {
    style.fill: "#EBF8FF"
    style.font-size: 13
    style.bold: true
  }
  r6: "INCONSISTENT\n(partially modified pages)" {
    style.fill: "#FED7D7"
    style.font-size: 12
    style.font-color: "#9B2C2C"
    style.bold: true
  }
  w6: "ALWAYS CONSISTENT\n(never modified until checkpoint)" {
    style.fill: "#C6F6D5"
    style.font-size: 12
    style.font-color: "#276749"
    style.bold: true
  }
  p7: "Network FS Support" {
    style.fill: "#EBF8FF"
    style.font-size: 13
    style.bold: true
  }
  r7: "✅ Works\n(only needs file locking)" {
    style.fill: "#FFF5F5"
    style.font-size: 12
  }
  w7: "❌ Fails\n(needs shared memory for\nWAL index)" {
    style.fill: "#FFF5F5"
    style.font-size: 12
  }
}
inversion: |md
  **Core Insight:** WAL inverts the journal strategy.
  - Journal writes **OLD** data (undo log) → modifies DB in-place
  - WAL writes **NEW** data (redo log) → DB file untouched
  This single inversion enables concurrent readers.
| {
  near: bottom-center
  style: {
    fill: "#FFFFF0"
    stroke: "#D69E2E"
    stroke-width: 2
    font-size: 14
    border-radius: 8
  }
}