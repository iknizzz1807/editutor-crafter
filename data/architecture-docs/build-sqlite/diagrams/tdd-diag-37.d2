layout-engine: elk
theme-id: 0

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: |md
  # Aggregate Accumulator Architecture
  **GroupByMap** routes rows via group keys to specific **GroupEntry** slots.
  The finalize phase iterates across distinct groups, evaluating **HAVING** predicates before emission.
| {
  near: top-center
  style: {
    font-size: 20
    font-color: "#2D3748"
    stroke-width: 0
  }
}

# ──────────────────────────────────────────────
# AggAccumulator Interface Definition
# ──────────────────────────────────────────────
AggAccumulator: {
  shape: class
  label: "«trait»\nAggAccumulator"
  tooltip: "Virtual interface for all SQL aggregate functions"
  
  "+step(value: Value)": "void"
  "+finalize()": "Value"
  "+has_value()": "bool"
  "+reset()": "void"
  
  style: {
    fill: "#E9D8FD"
    stroke: "#6B46C1"
    font-color: "#1A202C"
    stroke-width: 2
    bold: true
  }
}

# ──────────────────────────────────────────────
# Concrete Accumulator Implementations
# ──────────────────────────────────────────────
accumulators: "Concrete Implementations" {
  style: {
    fill: transparent
    stroke: "#A0AEC0"
    stroke-dash: 3
  }

  CountStarAcc: {
    shape: class
    label: "CountStarAcc"
    "-count": "i64"
    "+step(val)": "count++"
    "+finalize()": "Integer"
    style.fill: "#C6F6D5"
  }

  SumAcc: {
    shape: class
    label: "SumAcc"
    "-sum": "f64"
    "-empty": "bool"
    "+step(val)": "sum += val"
    "+finalize()": "Real|Null"
    style.fill: "#BEE3F8"
  }

  AvgAcc: {
    shape: class
    label: "AvgAcc"
    "-sum": "f64"
    "-count": "i64"
    "+step(val)": "sum += val; count++"
    "+finalize()": "sum/count"
    style.fill: "#BEE3F8"
  }

  MinMaxAcc: {
    shape: class
    label: "MinMaxAcc"
    "-extreme": "Value"
    "+step(val)": "cmp(val, extreme)"
    "+finalize()": "Value"
    style.fill: "#FEFCBF"
  }
}

# ──────────────────────────────────────────────
# Inheritance (Realization)
# ──────────────────────────────────────────────
accumulators.CountStarAcc -> AggAccumulator: {
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: false
  style.stroke-dash: 3
}
accumulators.SumAcc -> AggAccumulator: {
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: false
  style.stroke-dash: 3
}
accumulators.AvgAcc -> AggAccumulator: {
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: false
  style.stroke-dash: 3
}
accumulators.MinMaxAcc -> AggAccumulator: {
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: false
  style.stroke-dash: 3
}

# ──────────────────────────────────────────────
# Memory Layout & Data Structures
# ──────────────────────────────────────────────
MemoryLayout: "GroupEntry Byte Layout (64B Cache Line aligned)" {
  grid-columns: 1
  style.stroke-dash: 5

  header: {
    grid-columns: 4
    grid-gap: 0
    
    o0: "Offset" {style.bold: true}
    f0: "Field" {style.bold: true}
    s0: "Size" {style.bold: true}
    c0: "Color" {style.bold: true}

    # Row 1: Key
    o1: "0x00"
    f1: "GroupKey (Value[])"
    s1: "32B"
    c1: " " {style.fill: "#BEE3F8"} # Blue: Data

    # Row 2: Pointer
    o2: "0x20"
    f2: "Accumulator**"
    s2: "8B"
    c2: " " {style.fill: "#FBD38D"} # Orange: Pointer

    # Row 3: Metadata
    o3: "0x28"
    f3: "agg_count (u32)"
    s3: "4B"
    c3: " " {style.fill: "#BEE3F8"}

    # Row 4: Flags
    o4: "0x2C"
    f4: "occupied (u8)"
    s4: "1B"
    c4: " " {style.fill: "#C6F6D5"} # Green: Flags

    # Row 5: Padding
    o5: "0x2D"
    f5: "Padding"
    s5: "19B"
    c5: " " {style.fill: "#EDF2F7"} # Gray: Padding
  }
}

GroupByMap: {
  shape: class
  label: "GroupByMap"
  "-ht": "GroupEntry*"
  "-cap": "u64"
  "+find_or_create(key)": "GroupEntry*"
  style.fill: "#E9D8FD"
}

GroupEntry: {
  shape: class
  label: "GroupEntry"
  "+key": "Value[N]"
  "+accs": "AggAccumulator[]"
  style.fill: "#FAF5FF"
}

GroupByMap -> GroupEntry: "manages"
GroupEntry -> AggAccumulator: "owns (0..N)" {
  source-arrowhead: 1
  target-arrowhead: "*" {
    shape: diamond
    style.filled: true
  }
}

# ──────────────────────────────────────────────
# Logic Flow Phases
# ──────────────────────────────────────────────
Phase1: "Phase 1: Accumulation Loop" {
  style.fill: "#F0FFF4"
  
  scan: "Table Scan" {shape: rectangle}
  lookup: "Hash Key\nLookup/Insert" {shape: hexagon}
  update: "Dispatch\nacc.step()" {shape: step}
  
  scan -> lookup -> update
  update -> scan: "Next Row" {style.animated: true}
}

Phase2: "Phase 2: Finalize & Emit" {
  style.fill: "#FFF5F5"
  
  iter: "Linear Entry Scan" {shape: rectangle}
  fin: "acc.finalize()" {shape: step}
  having: "HAVING Predicate" {shape: diamond}
  emit: "Emit Result" {shape: parallelogram}
  
  iter -> fin -> having
  having -> emit: "Pass"
  emit -> iter: "Next Group"
}

# ──────────────────────────────────────────────
# Cross-Container Connections
# ──────────────────────────────────────────────
Phase1.lookup -> GroupByMap: "find_or_create()"
Phase2.fin -> AggAccumulator: "virtual call"
Phase2.iter -> GroupByMap: "iterate entries"

# ──────────────────────────────────────────────
# Technical Annotation Table
# ──────────────────────────────────────────────
null_handling: |'md
  ### SQL Aggregate NULL Handling Rules
  
  | Aggregate | NULL Input Handling | Result on Empty Set |
  | :--- | :--- | :--- |
  | **COUNT(*)** | Counted (1) | 0 |
  | **COUNT(col)** | Skipped | 0 |
  | **SUM(col)** | Skipped | NULL |
  | **AVG(col)** | Skipped | NULL |
  | **MIN/MAX** | Skipped | NULL |
  
  **Internal Logic:**
  - `NULL` is treated as a distinct value for `GROUP BY` hashing.
  - `HAVING` filters operate on finalized registers after `AggAccumulator::finalize()`.
'| {
  near: bottom-center
  style: {
    fill: "#FFFFFF"
    stroke: "#CBD5E0"
    border-radius: 4
  }
}