layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # AST Node Type Hierarchy & Memory Layout
  **Technical Specification: Recursive-Descent Parser Output**
  *Every SQL statement is transformed into a tree of these structures.*
| {
  near: top-center
}

classes: {
  enum-box: {
    style: {
      fill: "#E8E0F0"
      stroke: "#6B4C9A"
      stroke-width: 2
      border-radius: 6
      font: mono
      bold: true
    }
  }
  struct-box: {
    style: {
      fill: "#D6EAFF"
      stroke: "#2B6CB0"
      border-radius: 6
      font: mono
    }
  }
  leaf-box: {
    style: {
      fill: "#E6F5E6"
      stroke: "#2E7D32"
      border-radius: 6
      font: mono
    }
  }
  memory-meta: {
    style: {
      font-size: 11
      font-color: "#4A5568"
      italic: true
    }
  }
}

# ─────────────────────────────────────────────
#  Core Node Structure (The Union Wrapper)
# ─────────────────────────────────────────────
AstNode: {
  shape: sql_table
  class: struct-box
  label: "AstNode (sizeof=128B)"
  
  # Byte Offsets | Field Name | Type/Size
  offset_00: "type : NodeType" {constraint: "4B (Discriminant)"}
  offset_04: "line : int32" {constraint: "4B"}
  offset_08: "col  : int32" {constraint: "4B"}
  offset_12: "padding : byte[4]" {style.fill: gray}
  offset_16: "next : pointer<AstNode>" {constraint: "8B (Sibling)"}
  offset_24: "payload : union branch" {constraint: "104B (Max Size)"}
}

NodeType: "NodeType (Enum)" {
  class: enum-box
  shape: class
  
  # Grouping values
  stmt_header: "— Statements —"
  NODE_SELECT: "1"
  NODE_INSERT: "2"
  NODE_CREATE: "3"
  
  expr_header: "— Expressions —"
  NODE_IDENT: "10"
  NODE_INT: "11"
  NODE_REAL: "12"
  NODE_STR: "13"
  NODE_BINOP: "20"
  NODE_UNOP: "21"
}

# Discriminant link
AstNode.offset_00 -> NodeType: "discriminates\npayload union" {
  style.stroke: "#6B4C9A"
  style.stroke-dash: 3
}

# ─────────────────────────────────────────────
#  Statement Payloads (Union Branches)
# ─────────────────────────────────────────────
stmts: Statement Variants {
  style.fill: "#F9F5FF"
  style.stroke: "#6B4C9A"
  style.stroke-dash: 5

  SelectStmt: {
    class: struct-box
    shape: class
    projections: "ptr<AstNode> (List)"
    table_name: "const char*"
    table_name_len: "int32"
    join_condition: "ptr<AstNode>"
    where_clause: "ptr<AstNode>"
    order_by: "ptr<AstNode>"
    "limit": "int32"
  }

  InsertStmt: {
    class: struct-box
    shape: class
    table_name: "const char*"
    columns: "ptr<AstNode> (List)"
    values: "ptr<AstNode> (List)"
  }

  CreateTableStmt: {
    class: struct-box
    shape: class
    table_name: "const char*"
    col_defs: "ptr<AstNode> (List)"
    if_not_exists: "uint8"
  }
}

# Connection from Tagged Union to Concrete Branch
AstNode.offset_24 -> stmts.SelectStmt: "Type=NODE_SELECT" { style.stroke: "#2B6CB0"; style.stroke-width: 2 }
AstNode.offset_24 -> stmts.InsertStmt: "Type=NODE_INSERT" { style.stroke: "#2B6CB0"; style.stroke-width: 2 }
AstNode.offset_24 -> stmts.CreateTableStmt: "Type=NODE_CREATE" { style.stroke: "#2B6CB0"; style.stroke-width: 2 }

# ─────────────────────────────────────────────
#  Expression Payloads
# ─────────────────────────────────────────────
exprs: Expression Variants {
  style.fill: "#F0FAF0"
  style.stroke: "#2E7D32"
  style.stroke-dash: 5

  BinaryOp: {
    class: struct-box
    shape: class
    operator: "char[4] (+, -, *, /)"
    "left": "ptr<AstNode>"
    "right": "ptr<AstNode>"
  }

  UnaryOp: {
    class: struct-box
    shape: class
    operator: "char[4]"
    operand: "ptr<AstNode>"
  }

  Literal: {
    class: leaf-box
    shape: class
    val_int: "int64"
    val_real: "double"
    val_str: "const char*"
  }

  ColumnRef: {
    class: struct-box
    shape: class
    table: "const char*"
    column: "const char*"
  }
}

AstNode.offset_24 -> exprs.BinaryOp: "Type=NODE_BINOP" { style.stroke: "#2E7D32"; style.stroke-width: 2 }
AstNode.offset_24 -> exprs.UnaryOp: "Type=NODE_UNOP" { style.stroke: "#2E7D32"; style.stroke-width: 2 }
AstNode.offset_24 -> exprs.Literal: "NODE_INT | NODE_REAL | NODE_STR" { style.stroke: "#2E7D32" }
AstNode.offset_24 -> exprs.ColumnRef: "Type=NODE_COL_REF" { style.stroke: "#2E7D32" }

# ─────────────────────────────────────────────
#  Recursive Ownership & Tree Links
# ─────────────────────────────────────────────

# Recursive Expr Links - Quoted keys used to avoid D2 reserved keyword collision (left/right)
exprs.BinaryOp."left" -> AstNode: "lhs" {
  source-arrowhead.label: "1"
  style.stroke: orange
  style.stroke-dash: 5
}

exprs.BinaryOp."right" -> AstNode: "rhs" {
  source-arrowhead.label: "2"
  style.stroke: orange
  style.stroke-dash: 5
}

exprs.UnaryOp.operand -> AstNode: "child" {
  style.stroke: orange
  style.stroke-dash: 5
}

# Statement Child Links
stmts.SelectStmt.projections -> AstNode: "list head" {
  style.stroke: orange
  style.stroke-dash: 5
}

# Sibling Link (linked list traversal)
AstNode.offset_16 -> AstNode: "next sibling" {
  style.stroke: "#F9A825"
  style.stroke-dash: 3
  target-arrowhead.shape: circle
}

# ─────────────────────────────────────────────
#  Documentation Notes
# ─────────────────────────────────────────────
memory_layout_note: |md
  ### Memory Layout Strategy
  - **Fixed Size:** All `AstNode` objects are 128 bytes to simplify pool allocation.
  - **Alignment:** 8-byte alignment enforced for pointers.
  - **Union:** The `payload` field overlaps for different stmt/expr types.
| {
  near: AstNode
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
}

traversal_note: |md
  ### Sibling Linked List
  Child nodes are NOT stored in arrays. 
  `SelectStmt.projections` points to the first node. 
  Each node uses its `next` pointer to reach the next sibling.
| {
  near: bottom-right
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}