vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Pratt Precedence Climbing Algorithm
  **Trace of `parse_expr(0)` on `a + b * c`**
| {
  near: top-center
}

direction: down

# ── Binding Power Reference Table ──────────────────────────
bp_table: Binding Power Table {
  grid-rows: 5
  grid-columns: 4
  grid-gap: 0
  
  h_op: "Operator" {
    style.bold: true
    style.fill: "#4A5568"
    style.font-color: "#FFFFFF"
  }
  h_lbp: "Left BP" {
    style.bold: true
    style.fill: "#4A5568"
    style.font-color: "#FFFFFF"
  }
  h_rbp: "Right BP" {
    style.bold: true
    style.fill: "#4A5568"
    style.font-color: "#FFFFFF"
  }
  h_assoc: "Assoc" {
    style.bold: true
    style.fill: "#4A5568"
    style.font-color: "#FFFFFF"
  }

  or: "OR" { style.fill: "#EDF2F7" }
  or_l: "1" { style.fill: "#EDF2F7" }
  or_r: "2" { style.fill: "#EDF2F7" }
  or_a: "left" { style.fill: "#EDF2F7" }

  and: "AND" { style.fill: "#FFFFFF" }
  and_l: "2" { style.fill: "#FFFFFF" }
  and_r: "3" { style.fill: "#FFFFFF" }
  and_a: "left" { style.fill: "#FFFFFF" }

  plus_minus: "+ −" { style.fill: "#E2E8F0" }
  pm_l: "4" { style.fill: "#E2E8F0" }
  pm_r: "5" { style.fill: "#E2E8F0" }
  pm_a: "left" { style.fill: "#E2E8F0" }

  mul_div: "* / %" { style.fill: "#BEE3F8" }
  md_l: "6" { style.fill: "#BEE3F8" }
  md_r: "7" { style.fill: "#BEE3F8" }
  md_a: "left" { style.fill: "#BEE3F8" }

  style.fill: "#F7FAFC"
  style.stroke: "#A0AEC0"
  style.border-radius: 6
}

# ── Input Token Stream ─────────────────────────────────────
input: Input Token Stream {
  grid-rows: 1
  grid-columns: 5
  grid-gap: 0
  
  t_a: "a" {
    style.fill: "#C6F6D5"
    style.font: mono
    style.bold: true
    width: 60
  }
  t_plus: "+" {
    style.fill: "#FEFCBF"
    style.font: mono
    style.bold: true
    width: 60
  }
  t_b: "b" {
    style.fill: "#C6F6D5"
    style.font: mono
    style.bold: true
    width: 60
  }
  t_star: "*" {
    style.fill: "#FEFCBF"
    style.font: mono
    style.bold: true
    width: 60
  }
  t_c: "c" {
    style.fill: "#C6F6D5"
    style.font: mono
    style.bold: true
    width: 60
  }
  
  style.fill: "#FFFFFF"
  style.stroke: "#718096"
  style.border-radius: 6
}

# ── Execution Trace ────────────────────────────────────────
# Container renamed from 'steps' to 'trace' to avoid keyword conflict
trace: Execution Trace {
  direction: down
  
  step1: "STEP 1 — parse_expr(min_bp=0)" {
    style.fill: "#EBF8FF"
    style.stroke: "#3182CE"
    style.border-radius: 8
    style.font-size: 16
    s1_detail: |md
      **Call** `parse_prefix()` → consume token `a`
      Return `IDENT("a")` as `left`
      
      left = IDENT("a")
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
  }

  step2: "STEP 2 — Check infix loop" {
    style.fill: "#EBF8FF"
    style.stroke: "#3182CE"
    style.border-radius: 8
    style.font-size: 16
    s2_detail: |md
      **Peek** next token: `+`
      **left_bp(+) = 4**  ≥  min_bp=0  →  **enter loop**
      **Consume** `+`
      
      op = "+"     left_bp = 4
      right_bp = left_bp + 1 = 5   (left-associative)
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
    s2_check: "4 ≥ 0 ✓  →  consume '+'" {
      style.fill: "#C6F6D5"
      style.font: mono
      style.bold: true
      style.border-radius: 4
    }
  }

  step3: "STEP 3 — Recursive call parse_expr(min_bp=5)" {
    style.fill: "#FEFCE8"
    style.stroke: "#D69E2E"
    style.border-radius: 8
    style.font-size: 16
    style.bold: true
    s3_detail: |md
      **New invocation** to parse the right-hand side of `+`
      This recursive call has **min_bp=5**, meaning only
      operators with left_bp ≥ 5 can capture operands.
      `+` has left_bp=4 < 5, so it **cannot** steal from this call.
      `*` has left_bp=6 ≥ 5, so it **can**.
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
  }

  step4: "STEP 4 — Inside parse_expr(5): parse primary 'b'" {
    style.fill: "#FFF5F5"
    style.stroke: "#E53E3E"
    style.border-radius: 8
    style.font-size: 16
    s4_detail: |md
      **Call** `parse_prefix()` → consume token `b`
      Return `IDENT("b")` as `left`
      
      left = IDENT("b")
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
  }

  step5: "STEP 5 — Inside parse_expr(5): check '*'" {
    style.fill: "#FFF5F5"
    style.stroke: "#E53E3E"
    style.border-radius: 8
    style.font-size: 16
    s5_detail: |md
      **Peek** next token: `*`
      **left_bp(*) = 6**  ≥  min_bp=5  →  **enter loop**
      **Consume** `*`
      
      op = "*"     left_bp = 6
      right_bp = left_bp + 1 = 7   (left-associative)
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
    s5_check: "6 ≥ 5 ✓  →  consume '*'" {
      style.fill: "#C6F6D5"
      style.font: mono
      style.bold: true
      style.border-radius: 4
    }
  }

  step6: "STEP 6 — Recursive call parse_expr(min_bp=7)" {
    style.fill: "#FAF5FF"
    style.stroke: "#805AD5"
    style.border-radius: 8
    style.font-size: 16
    s6_detail: |md
      **Call** `parse_prefix()` → consume token `c`
      **Peek** next token: `EOF` (or `;`)
      No operator with left_bp ≥ 7 → **exit loop immediately**
      Return `IDENT("c")`
      
      return IDENT("c")
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
  }

  step7: "STEP 7 — Back in parse_expr(5): build Mul node" {
    style.fill: "#FFF5F5"
    style.stroke: "#E53E3E"
    style.border-radius: 8
    style.font-size: 16
    s7_detail: |md
      **right** = `IDENT("c")` (from step 6)
      **Build** `Mul(left="b", right="c")`
      **Peek** next token: `EOF` — no operator ≥ 5
      **Exit loop**, return `Mul(b, c)`
      
      left = Mul(IDENT("b"), IDENT("c"))
      return left
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
  }

  step8: "STEP 8 — Back in parse_expr(0): build Add node" {
    style.fill: "#EBF8FF"
    style.stroke: "#3182CE"
    style.border-radius: 8
    style.font-size: 16
    s8_detail: |md
      **right** = `Mul(b, c)` (from step 7)
      **Build** `Add(left="a", right=Mul(b,c))`
      **Peek** next token: `EOF` — no operator ≥ 0
      **Exit loop**, return final AST
      
      return Add(IDENT("a"), Mul(IDENT("b"), IDENT("c")))
    | {
      style.fill: "#FFFFFF"
      style.border-radius: 4
    }
  }

  step1 -> step2
  step2 -> step3
  step3 -> step4: "enter recursive frame" {
    style.stroke: "#D69E2E"
    style.stroke-dash: 5
    style.bold: true
  }
  step4 -> step5
  step5 -> step6: "enter recursive frame" {
    style.stroke: "#805AD5"
    style.stroke-dash: 5
    style.bold: true
  }
  step6 -> step7: "return IDENT(c)" {
    style.stroke: "#805AD5"
    style.stroke-dash: 5
  }
  step7 -> step8: "return Mul(b,c)" {
    style.stroke: "#D69E2E"
    style.stroke-dash: 5
  }
}

# ── Final AST ──────────────────────────────────────────────
ast: Final AST {
  style.fill: "#F0FFF4"
  style.stroke: "#38A169"
  style.border-radius: 10
  style.font-size: 18
  style.bold: true

  add_node: "Add  (+)" {
    style.fill: "#FEFCBF"
    style.stroke: "#D69E2E"
    style.border-radius: 6
    style.bold: true
    style.font-size: 16
  }
  a_leaf: "a" {
    style.fill: "#C6F6D5"
    style.font: mono
    style.bold: true
    style.font-size: 18
    style.border-radius: 6
  }
  mul_node: "Mul  (*)" {
    style.fill: "#FEFCBF"
    style.stroke: "#D69E2E"
    style.border-radius: 6
    style.bold: true
    style.font-size: 16
  }
  b_leaf: "b" {
    style.fill: "#C6F6D5"
    style.font: mono
    style.bold: true
    style.font-size: 18
    style.border-radius: 6
  }
  c_leaf: "c" {
    style.fill: "#C6F6D5"
    style.font: mono
    style.bold: true
    style.font-size: 18
    style.border-radius: 6
  }

  add_node -> a_leaf: "left" {
    style.stroke: "#2D3748"
  }
  add_node -> mul_node: "right" {
    style.stroke: "#2D3748"
  }
  mul_node -> b_leaf: "left" {
    style.stroke: "#2D3748"
  }
  mul_node -> c_leaf: "right" {
    style.stroke: "#2D3748"
  }
}

# ── Key Insight Box ────────────────────────────────────────
insight: |md
  ### Why `*` binds tighter than `+`
  When `parse_expr(0)` encounters `+` (left_bp=4), it calls
  `parse_expr(5)` for the right side. Inside that call, `*`
  (left_bp=6) satisfies 6 ≥ 5 and **captures** `b` and `c`
  before returning. A second `+` would have left_bp=4 < 5
  and would **not** enter the loop — it would be left for the
  outer call to handle.

  **The right_bp = left_bp + 1 asymmetry is what creates
  left-associativity.** For right-associative operators,
  use right_bp = left_bp (same value).
| {
  style.fill: "#EBF4FF"
  style.stroke: "#4299E1"
  style.border-radius: 8
  near: bottom-center
}

# ── Layout connections ─────────────────────────────────────
input -> trace: "tokenize" {
  style.stroke: "#A0AEC0"
  style.stroke-dash: 3
}

trace -> ast: "final return" {
  style.stroke: "#38A169"
  style.bold: true
  style.animated: true
}