vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}
shape: sequence_diagram
caller: "Caller\n(compiler_compile)"
ps: "parse_statement()"
sel: "parse_select()"
tref: "parse_table_ref()"
pw: "parse_where()"
pex: "parse_expr(0)"
err: "ParseError Path" {
  style: {
    fill: "#FFF0F0"
    stroke: "#CC3333"
  }
}
# ─── Happy Path ───────────────────────────────────
caller -> ps: "parser_parse(p)" {
  style.bold: true
}
ps."peek(p) → TOK_KEYWORD"
ps -> ps: |md
  check: lexeme_equals(peek, "SELECT")?
  result: **true** → dispatch
|
ps -> sel: "parse_select(p)" {
  style.stroke: "#2255AA"
  style.bold: true
}
sel."advance(p)  // consume SELECT"
sel -> sel: |md
  parse projection list:
  peek → TOK_IDENTIFIER "a"
  advance → col_ref("a")
  peek → TOK_COMMA → advance
  peek → TOK_IDENTIFIER "b"
  advance → col_ref("b")
  peek → not COMMA → stop
|
sel -> sel: |md
  expect_keyword(p, "FROM", "SELECT")
  peek → TOK_KEYWORD "FROM" ✓
  advance → consume FROM
| {
  style.stroke: "#228B22"
}
sel -> tref: "parse_table_ref(p)" {
  style.stroke: "#2255AA"
}
tref."expect(p, TOK_IDENTIFIER, \"FROM\")"
tref."advance → Token{\"users\", line=1, col=15}"
tref -> sel: |md
  return table_name = "users"
  table_name_len = 5
| {
  style.stroke-dash: 5
}
sel -> sel: |md
  check: peek → TOK_KEYWORD "WHERE"?
  result: **true** → advance, enter WHERE
|
sel -> pw: "parse_where(p)" {
  style.stroke: "#2255AA"
}
pw -> pex: "parse_expr(p, min_bp=0)" {
  style.stroke: "#2255AA"
  style.bold: true
}
pex."// Pratt precedence climbing"
pex -> pex: |md
  **parse_prefix(p):**
  peek → TOK_IDENTIFIER "age"
  advance → col_ref("age")
  returns left = NODE_COLUMN_REF
|
pex -> pex: |md
  **infix loop:**
  peek → TOK_GT  (lbp=30, > min_bp=0)
  advance → consume ">"
  rbp = 31 (left-assoc: lbp+1)
|
pex -> pex: |md
  **parse_expr(p, min_bp=31):**
  parse_prefix → TOK_INTEGER_LIT "21"
  advance → NODE_INTEGER_LIT{21}
  peek → TOK_SEMICOLON (lbp=-1)
  return right = NODE_INTEGER_LIT
|
pex -> pex: |md
  construct NODE_BINARY_OP:
    op = ">"
    left = col_ref("age")
    right = int_lit(21)
|
pex -> pw: |md
  return NODE_BINARY_OP{">",
    col_ref("age"),
    int_lit(21)}
| {
  style.stroke-dash: 5
}
pw -> sel: |md
  where_clause = BINARY_OP
| {
  style.stroke-dash: 5
}
sel -> sel: |md
  check: peek → TOK_KEYWORD "ORDER"? **no**
  check: peek → TOK_KEYWORD "LIMIT"? **no**
  match_type(TOK_SEMICOLON) → advance
|
sel -> sel: |md
  **Construct SelectStmt:**
  .projections = [col_ref("a"), col_ref("b")]
  .table_name = "users"
  .where_clause = BINARY_OP{">"}
  .order_by = NULL
  .limit = -1
|
sel -> ps: |md
  return AstNode*
  type = NODE_SELECT
| {
  style.stroke-dash: 5
  style.bold: true
}
ps -> caller: |md
  return AstNode* (success)
  p->had_error == 0
| {
  style.stroke-dash: 5
  style.bold: true
}
# ─── Error Path ───────────────────────────────────
caller -> ps: |md
  parser_parse(p)
  SQL: "SELECT a FORM t"
| {
  style.stroke: "#CC3333"
  style.bold: true
}
ps -> sel: "parse_select(p)" {
  style.stroke: "#CC3333"
}
sel."parse projections → col_ref(\"a\")"
sel -> err: |md
  **expect_keyword(p, "FROM", "SELECT")**
  peek → TOK_KEYWORD "FORM"
  lexeme_equals("FORM","FROM") = **false**
| {
  style.stroke: "#CC3333"
  style.bold: true
  style.animated: true
}
err."parse_error(p, tok, msg)" {
  style.font-color: "#CC3333"
}
err -> err: |md
  p->had_error = 1
  p->error_line = 1
  p->error_col = 10
  p->error_msg =
    "[line 1, col 10] expected keyword
    'FROM' in SELECT (got 'FORM')"
| {
  style.stroke: "#CC3333"
}
err -> sel: |md
  return peek(p)
  (un-advanced token)
| {
  style.stroke: "#CC3333"
  style.stroke-dash: 5
}
sel -> sel: |md
  **if (p->had_error):**
  ast_free(node)  // cleanup partial
  return NULL
| {
  style.stroke: "#CC3333"
}
sel -> ps: "return NULL" {
  style.stroke: "#CC3333"
  style.stroke-dash: 5
}
ps -> caller: |md
  return NULL
  p->had_error == 1
  caller checks:
    parser_error_message(p)
| {
  style.stroke: "#CC3333"
  style.stroke-dash: 5
  style.bold: true
}