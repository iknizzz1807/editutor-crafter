vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    center: true
  }
}

# --- SHAPE DEFINITIONS ---
# Root container is a sequence diagram
shape: sequence_diagram

compiler: "Compiler\n(compile_select)" {
  shape: person
  style: {
    fill: "#E1F5FE"
    stroke: "#01579B"
    stroke-width: 2
    font-color: "#01579B"
    bold: true
  }
}

emitter: "emitter: Emitter\nemit(Program.ops[])" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    font-color: "#1B5E20"
    bold: true
  }
}

regalloc: "regalloc: RegisterAllocator\nalloc_register()" {
  style: {
    fill: "#F5F5F5"
    stroke: "#616161"
    font-color: "#212121"
    bold: true
  }
}

expr: "expr: ExpressionCompiler\ncompile_expr(recursive)" {
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
    font-color: "#E65100"
    bold: true
  }
}

patch: "patch: JumpPatcher\npatch_jump()" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    font-color: "#B71C1C"
    bold: true
  }
}

# --- COMPILATION PHASES ---

# Phase 1: Initialization and Setup
compiler."Step 1: compile_select(stmt) called"

compiler.t1 -> emitter.t1: "emit(OP_INIT, 0, 0, 0) → addr=0\n[p2 placeholder = 0]" {
  style: {
    stroke: "#0288D1"
    font-size: 11
  }
}

compiler.t2 -> emitter.t2: "emit(OP_OPEN_READ, cursor=0, root_page=5, ncols=3) → addr=1" {
  style: {
    stroke: "#0288D1"
    font-size: 11
  }
}

compiler."Step 2: patch_jump(prog, addr=0, target=1)\nOP_INIT.p2 updated to 1"

compiler.t3 -> emitter.t3: "emit(OP_REWIND, cursor=0, p2=0, 0) → addr=2\n[p2 placeholder for empty-jump]" {
  style: {
    stroke: "#0288D1"
    font-size: 11
  }
}

compiler."Step 3: record loop_top = 3\n(Address of first row-fetching instruction)"

# Phase 2: WHERE Clause Compilation
where_logic: Filtering Logic {
  compiler.t4 -> expr.t4: "compile_where(where_clause, cursor=0, table_idx=0)" {
    style.stroke: "#EF6C00"
  }
  
  expr.t5 -> regalloc.t5: "alloc_register() → r1" {
    style.stroke: "#757575"
    style.stroke-dash: 3
  }
  
  expr.t6 -> emitter.t6: "emit(OP_COLUMN, cursor=0, col=2, dest=r1)\naddr=3 [Load Column 'age']" {
    style.stroke: "#0288D1"
  }
  
  expr.t7 -> regalloc.t7: "alloc_register() → r2" {
    style.stroke: "#757575"
    style.stroke-dash: 3
  }
  
  expr.t8 -> emitter.t8: "emit(OP_INTEGER, val=21, dest=r2, 0)\naddr=4" {
    style.stroke: "#0288D1"
  }
  
  expr.t9 -> emitter.t9: "emit(OP_ISNULL, r1, p2=0, 0)\naddr=5 ★ JUMP HOLE #1" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
  
  expr.t10 -> emitter.t10: "emit(OP_ISNULL, r2, p2=0, 0)\naddr=6 ★ JUMP HOLE #2" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
  
  expr.t11 -> emitter.t11: "emit(OP_LE, r1, p2=0, r2)\naddr=7 ★ JUMP HOLE #3\n(Inverted: Jump if age <= 21)" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
  
  expr -> compiler: "Return jump_addrs=[5,6,7]\nn_jumps=3" {
    style.stroke: "#EF6C00"
    style.stroke-dash: 5
  }
}

# Phase 3: Column Projection
projection_logic: Projection Phase {
  compiler."Step 4: Determine projection register base (r3)"
  
  compiler.p1 -> regalloc.p1: "alloc_register() → r3" {
    style.stroke: "#757575"
  }
  
  compiler.p2 -> emitter.p2: "emit(OP_COLUMN, cursor=0, col=0, dest=r3)\naddr=8 [Load 'name']" {
    style.stroke: "#0288D1"
  }
  
  compiler.p3 -> regalloc.p3: "alloc_register() → r4" {
    style.stroke: "#757575"
  }
  
  compiler.p4 -> emitter.p4: "emit(OP_COLUMN, cursor=0, col=1, dest=r4)\naddr=9 [Load 'age']" {
    style.stroke: "#0288D1"
  }
}

# Phase 4: Output Processing
compiler.r1 -> emitter.r1: "emit(OP_RESULT_ROW, first_reg=r3, ncols=2, 0)\naddr=10" {
  style.stroke: "#0288D1"
}

# Phase 5: Loop Advancing
compiler.n1 -> emitter.n1: "emit(OP_NEXT, cursor=0, p2=3, 0)\naddr=11" {
  style: {
    stroke: "#2E7D32"
    bold: true
    stroke-width: 3
  }
}

# Phase 6: Backpatching (Critical Path)
backpatch_phase: Structural Linking {
  compiler."Step 5: BACKPATCHING\nTarget Address 11 (OP_NEXT) is now fixed"
  
  compiler.bp1 -> patch.bp1: "patch_jump(prog, addr=5, target=11)" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      animated: true
    }
  }
  
  compiler.bp2 -> patch.bp2: "patch_jump(prog, addr=6, target=11)" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      animated: true
    }
  }
  
  compiler.bp3 -> patch.bp3: "patch_jump(prog, addr=7, target=11)" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      animated: true
    }
  }
}

# Phase 7: Finalization and Cleanup
compiler.c1 -> emitter.c1: "emit(OP_CLOSE, cursor=0, 0, 0)\naddr=12" {
  style.stroke: "#0288D1"
}

compiler."Step 6: patch_jump(prog, addr=2, target=12)\nOP_REWIND.p2 = 12 (EOF Exit)"

compiler.h1 -> emitter.h1: "emit(OP_HALT, 0, 0, 0)\naddr=13" {
  style: {
    stroke: "#2E7D32"
    bold: true
    stroke-width: 4
  }
}

# --- DOCUMENTATION OVERLAYS ---

final_program: |'md
### Final Bytecode Program
| Addr | Opcode | P1 | P2 | P3 | Note |
| :--- | :--- | :--- | :--- | :--- | :--- |
| 0 | **Init** | 0 | 1 | 0 | Start at 1 |
| 1 | **OpenRead** | 0 | 5 | 3 | Table at Page 5 |
| 2 | **Rewind** | 0 | 12 | 0 | Exit if empty |
| 3 | **Column** | 0 | 2 | 1 | `loop_top`: Read Age |
| 4 | **Integer** | 21 | 2 | 0 | r2 = 21 |
| 5 | **IsNull** | 1 | 11 | 0 | Patched to Next |
| 6 | **IsNull** | 2 | 11 | 0 | Patched to Next |
| 7 | **Le** | 1 | 11 | 2 | Patched to Next |
| 8 | **Column** | 0 | 0 | 3 | Read Name |
| 9 | **Column** | 0 | 1 | 4 | Read Age |
| 10 | **ResultRow** | 3 | 2 | 0 | Emit r3, r4 |
| 11 | **Next** | 0 | 3 | 0 | Loop to 3 |
| 12 | **Close** | 0 | 0 | 0 | Cleanup |
| 13 | **Halt** | 0 | 0 | 0 | Terminate |
'|

final_program.near: bottom-right
final_program.style: {
  stroke: "#616161"
  fill: "#FAFAFA"
  font: mono
  shadow: true
}

annotations: |'md
**Compilation Invariants:**
- `loop_top` is recorded before any WHERE clause logic.
- Jumping logic is *inverted* to skip the projection on failure.
- `Backpatching` occurs once the loop footer (OP_NEXT) address is determined.
- Registers: `r0` (Scratch), `r1-r2` (Filtering), `r3-r4` (Projection).
'|

annotations.near: top-right
annotations.style: {
  fill: "#FFFDE7"
  stroke: "#FBC02D"
  font-size: 14
}