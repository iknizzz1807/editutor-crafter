direction: right
layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
  colors: {
    header: "#f3e5f5"
    lexical: "#e3f2fd"
    reserved: "#ffcdd2"
    special: "#b2dfdb"
    fsm_state: "#ce93d8"
    fsm_active: "#ab47bc"
    mem_header: "#e1bee7"
    mem_pointers: "#c8e6c9"
    mem_data: "#bbdefb"
    mem_free: "#eeeeee"
  }
}

# =============================================================================
# M1: TOKENIZATION - TOKEN TYPE TAXONOMY & FSM
# =============================================================================

token_taxonomy: Token Type Taxonomy {
  style.fill: ${colors.header}
  style.stroke-width: 2

  lexical_token: Lexical Tokens {
    shape: rectangle
    style.fill: ${colors.lexical}
    
    TK_INTEGER: "TK_INTEGER\nLiteral: [0-9]+" {
      style.fill: "#c8e6c9"
    }
    TK_FLOAT: "TK_FLOAT\nLiteral: [0-9]*\\.[0-9]+" {
      style.fill: "#c8e6c9"
    }
    TK_STRING: "TK_STRING\nLiteral: '[^']*'" {
      style.fill: "#c8e6c9"
    }
    TK_IDENTIFIER: "TK_IDENTIFIER\nPattern: [a-zA-Z_][a-zA-Z0-9_]*" {
      style.fill: "#ffccbc"
    }
    TK_OPERATOR: "TK_OPERATOR\n{+, -, *, /, =, <, >, <=, >=, !=}" {
      style.fill: "#fff9c4"
    }
    TK_PUNCTUATION: "TK_PUNCTUATION\n(, ), ;, .)" {
      style.fill: "#d1c4e9"
    }
  }

  reserved_words: Reserved Words {
    style.fill: ${colors.reserved}
    keywords: Keywords {
      dml_keywords: "DML: SELECT, INSERT, UPDATE, DELETE"
      ddl_keywords: "DDL: CREATE, DROP, ALTER"
      dcl_keywords: "DCL: GRANT, REVOKE"
      tcl_keywords: "TCL: BEGIN, COMMIT, ROLLBACK"
    }
  }

  special_tokens: Special Tokens {
    style.fill: ${colors.special}
    TK_EOF: "TK_EOF\nEnd of Input"
    TK_ERROR: "TK_ERROR\nLexical Error" {
      style.fill: "#ff8a80"
      style.bold: true
    }
  }
}

fsm_graph: Tokenizer FSM Transitions {
  style.fill: ${colors.header}
  
  START: "● START" { 
    shape: circle
    style.fill: ${colors.fsm_state} 
  }
  ID_START: "ID_START\n[a-zA-Z_]" { shape: diamond; style.fill: "#ba68c8" }
  IDENTIFIER: "IDENTIFIER\n[a-zA-Z0-9_]+" { 
    style.fill: ${colors.fsm_active}
    style.font-color: white 
  }
  CHECK_RESERVED: "IS_KEYWORD?" { shape: diamond; style.fill: "#9c27b0"; style.font-color: white }
  
  DIGIT_START: "DIGIT_START\n[0-9]" { shape: diamond; style.fill: "#7e57c2"; style.font-color: white }
  INTEGER: "INTEGER\n[0-9]+" { style.fill: "#5e35b1"; style.font-color: white }
  CHECK_FLOAT: "HAS_DOT?" { shape: diamond; style.fill: "#512da8"; style.font-color: white }
  FLOAT_FRAC: "FLOAT_FRAC\n.[0-9]+" { style.fill: "#4527a0"; style.font-color: white }
  
  QUOTE_START: "QUOTE\n['\"]" { shape: diamond; style.fill: "#f06292" }
  STRING_BODY: "STRING_BODY" { style.fill: "#ec407a"; style.font-color: white }
  QUOTE_END: "MATCHED?" { shape: diamond; style.fill: "#d81b60"; style.font-color: white }
  
  OP_START: "OP\n[=!<>]" { shape: diamond; style.fill: "#ffa726" }
  OP_COMPOUND: "COMPOUND?" { shape: diamond; style.fill: "#ff9800" }
  
  WS: "WHITESPACE" { style.fill: "#bdbdbd" }
  
  TOKEN_EMIT: "TOKEN_EMIT" { 
    shape: circle
    style.fill: "#4caf50"
    style.double-border: true
  }
  
  START -> ID_START: "[a-zA-Z_]"
  START -> DIGIT_START: "[0-9]"
  START -> QUOTE_START: "['\"]"
  START -> OP_START: "[=!<>]"
  START -> WS: "[ \\t\\n\\r]"
  
  ID_START -> IDENTIFIER: "Valid Char"
  IDENTIFIER -> IDENTIFIER: "[a-zA-Z0-9_]"
  IDENTIFIER -> CHECK_RESERVED: "Terminator"
  CHECK_RESERVED -> TOKEN_EMIT: "Emit Id/Key"
  
  DIGIT_START -> INTEGER: "Digit"
  INTEGER -> INTEGER: "[0-9]"
  INTEGER -> CHECK_FLOAT: "Dot or Term"
  CHECK_FLOAT -> FLOAT_FRAC: "'.'"
  CHECK_FLOAT -> TOKEN_EMIT: "Emit TK_INT"
  FLOAT_FRAC -> FLOAT_FRAC: "[0-9]"
  FLOAT_FRAC -> TOKEN_EMIT: "Emit TK_FLOAT"
  
  QUOTE_START -> STRING_BODY: "Non-quote"
  STRING_BODY -> STRING_BODY: "Any char"
  STRING_BODY -> QUOTE_END: "Quote"
  QUOTE_END -> TOKEN_EMIT: "Emit TK_STR"
  
  OP_START -> OP_COMPOUND: "Compnd prefix"
  OP_START -> TOKEN_EMIT: "Emit Single Op"
  OP_COMPOUND -> TOKEN_EMIT: "Emit Compnd Op"
  
  WS -> START: "Skip"
}

# =============================================================================
# M2: PARSE TREE STRUCTURE
# =============================================================================

parse_tree: SQL Abstract Syntax Tree {
  style.fill: "#e8eaf6"
  sql_statement: SQLStatement {
    select_stmt: SelectStmt {
      style.fill: "#5c6bc0"; style.font-color: white
      select_clause: "SELECT"
      select_list: SelectList {
        col_ref: "Column: id"
        agg_func: "COUNT(*)" {
          arg_list: "Arguments: *"
        }
      }
      from_clause: "FROM: users"
      where_clause: "WHERE" {
        binary_expr: "id = 5" {
          left: "Column: id"
          op: "="
          right: "Literal: 5"
        }
      }
    }
  }
}

# =============================================================================
# M3: MEMORY LAYOUT - B-TREE PAGE (4096B)
# =============================================================================

page_layout: SQLite B-Tree Leaf Page Layout {
  style.stroke-width: 2
  
  header: "PAGE HEADER (0x00 - 0x0F)" {
    style.fill: ${colors.mem_header}
    page_type: "0: page_type (1B) [0x0D=Leaf]"
    freeblock: "1: first_freeblock (2B)"
    cell_count: "3: cell_count (2B)"
    content_start: "5: cell_content_start (2B)"
    frag_bytes: "7: fragmented_bytes (1B)"
  }

  cell_pointers: "CELL POINTER ARRAY (0x10 - ...)" {
    style.fill: ${colors.mem_pointers}
    p0: "Ptr[0]: 0x0FF0"
    p1: "Ptr[1]: 0x0FE0"
    pn: "Ptr[N]: ..."
  }

  free_space: "UNALLOCATED FREE SPACE" {
    style.fill: ${colors.mem_free}
    style.stroke-dash: 5
  }

  cell_content: "CELL CONTENT AREA (Grows Up)" {
    style.fill: ${colors.mem_data}
    cell_n: "Cell N"
    cell_1: "Cell 1"
    cell_0: "Cell 0 (at 0x0FF0)" {
      payload_len: "Payload Length (Varint)"
      rowid: "RowID (Varint)"
      data: "Payload Data (Record Format)"
    }
  }

  cache_line_label: "--- Cache Line Boundary (64B) ---" {
    shape: text
    style.font-color: "#757575"
    style.italic: true
  }
}

# =============================================================================
# M5: BUFFER POOL & LRU CACHE
# =============================================================================

buffer_pool: Buffer Pool LRU Manager {
  style.fill: "#fff3e0"
  
  hash_table: "Page ID Hash Index" {
    style.fill: "#ffe0b2"
    slots: "Buckets [0...N]"
    mapping: "Page 42 -> Frame 0\nPage 7 -> Frame 1"
  }

  frame_list: LRU Frame Chain {
    direction: right
    MRU: "MRU (Most Recent)" { shape: circle; style.fill: "#4caf50" }
    
    frame0: "Frame 0\nPage: 42\nDirty: NO\nPin: 1" { style.fill: "#ffcc80" }
    frame1: "Frame 1\nPage: 7\nDirty: YES\nPin: 0" { style.fill: "#ffcc80" }
    frame_n: "Frame N\nPage: 99\nDirty: NO\nPin: 0" { 
      style.fill: "#ff8a65"
      style.stroke-dash: 5
      label: "EVICTION CANDIDATE"
    }

    LRU: "LRU (Oldest)" { shape: circle; style.fill: "#f44336" }
    
    MRU -> frame0 <-> frame1 <-> frame_n -> LRU
  }
}

# =============================================================================
# M7: TRANSACTION STATE MACHINE
# =============================================================================

transaction_fsm: Transaction State Transitions {
  style.fill: ${colors.header}
  
  IDLE: "● IDLE" { shape: circle; style.fill: "#e1bee7" }
  STARTED: "TRANSACTION_STARTED" { shape: diamond; style.fill: "#ce93d8" }
  READ_ONLY: "READ_ONLY_STATE" { style.fill: "#ba68c8"; style.font-color: white }
  READ_WRITE: "READ_WRITE_STATE\n(Dirty Frames)" { style.fill: "#9c27b0"; style.font-color: white }
  
  COMMITTING: "COMMIT_PHASE" { shape: diamond; style.fill: "#7b1fa2"; style.font-color: white }
  ROLLING_BACK: "ROLLBACK_PHASE" { shape: diamond; style.fill: "#6a1b9a"; style.font-color: white }
  
  IDLE -> STARTED: "BEGIN"
  STARTED -> READ_ONLY: "SELECT"
  READ_ONLY -> READ_WRITE: "INSERT / UPDATE"
  READ_WRITE -> COMMITTING: "COMMIT"
  READ_WRITE -> ROLLING_BACK: "ROLLBACK / ERROR"
  COMMITTING -> IDLE: "Journal Sync ✓"
  ROLLING_BACK -> IDLE: "Recovery ✓"
}

# =============================================================================
# M10: VDBE BYTECODE EXECUTION
# =============================================================================

vdbe_program: VDBE Select Execution {
  style.fill: "#fce4ec"
  
  instructions: "Opcode Stream" {
    i0: "0: Integer(5, P1)  -- Load constant 5"
    i1: "1: OpenRead(0, root=2) -- Open users table"
    i2: "2: SeekGE(0, label_1, P1) -- Seek to key >= 5"
    i3: "3: Column(0, 1, P2) -- Fetch 'name'"
    i4: "4: ResultRow(P2) -- Output row"
    i5: "5: Halt -- Success"
  }

  registers: Register Bank {
    r1: "P1: 5 (Integer)" { style.fill: "#f8bbd9" }
    r2: "P2: 'Alice' (String)" { style.fill: "#f8bbd9" }
  }
  
  instructions.i0 -> registers.r1: "Write"
  instructions.i3 -> registers.r2: "Load from B-Tree"
}

# =============================================================================
# ANNOTATIONS & LEGEND
# =============================================================================

legend: |md
  ### Implementation Notes
  - **Memory:** Byte offsets follow standard SQLite 3.x B-Tree format.
  - **Performance:** Cache alignment targets 64-byte boundaries.
  - **WAL:** Write-Ahead Log frames include 24-byte headers for checksumming.
|
legend.near: page_layout

performance_spec: Performance Targets {
  L1_cache: '"L1$": ~4 cycles'
  L2_cache: '"L2$": ~12 cycles'
  RAM: "Main Memory: ~100ns"
}

summary_table: |'md
| Milestone | Diagram Type | D2 Shape | Theme |
|-----------|--------------|----------|-------|
| M1 | Token taxonomy | flowchart/tree | Purple |
| M1 | FSM transitions | flowchart | Purple |
| M2 | Parse tree | tree | Blue |
| M3 | Page layout | rectangle | Neutral |
| M5 | Buffer pool | rectangle | Orange |
| M7 | Transaction FSM | flowchart | Purple |
| M10 | VDBE program | list/bank | Pink |
'| 
summary_table.near: performance_spec