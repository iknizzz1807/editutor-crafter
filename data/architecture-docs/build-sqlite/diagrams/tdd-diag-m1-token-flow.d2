vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- STYLES AND CLASSES ---
classes: {
  header_purple: { 
    style: { 
      fill: "#E1D5E7"
      stroke: "#9673A6"
      stroke-width: 2
      bold: true 
    } 
  }
  data_blue: { 
    style: { 
      fill: "#DAE8FC"
      stroke: "#6C8EBF"
      stroke-width: 2
    } 
  }
  padding_gray: { 
    style: { 
      fill: "#F5F5F5"
      stroke: "#666666"
      stroke-dash: 3
    } 
  }
  pointer_orange: { 
    style: { 
      fill: "#FFE6CC"
      stroke: "#D79B00"
      stroke-width: 2
    } 
  }
  state_active: {
    style: {
      stroke: "#FF0000"
      stroke-width: 4
      bold: true
      font-color: "#FF0000"
    }
  }
}

# --- TOKENIZATION ARCHITECTURE ---

TokenizationEngine: {
  label: "SQL Tokenizer Subsystem"
  style.fill: "#F8F9FA"
  
  Scanner: {
    shape: class
    # Visibility: + public, - private
    +source: "const char*"
    +cursor: "uint32_t"
    +next_cursor: "uint32_t"
    +current_char: "uint8_t"
    
    +readChar(): "void"
    +peekChar(): "uint8_t"
    +nextToken(): "Token"
    -scanIdentifier(): "string"
    -scanNumber(): "double"
  }

  TokenKind: {
    shape: sql_table
    label: "enum TokenKind : uint8_t"
    TK_SELECT: 0 {constraint: "0x00"}
    TK_FROM: 1 {constraint: "0x01"}
    TK_WHERE: 2 {constraint: "0x02"}
    TK_IDENT: 3 {constraint: "0x03"}
    TK_NUMBER: 4 {constraint: "0x04"}
    TK_EOF: 255 {constraint: "0xFF"}
  }
  
  TokenKind.** {
    &leaf: true
    style.fill: "#E1D5E7"
  }
}

# --- MEMORY LAYOUT: TOKEN OBJECT ---

TokenLayout: {
  label: "struct Token Memory Layout (16 Bytes)"
  shape: sql_table
  
  # Offsets as keys, Types as values, field names as constraints
  "00": "uint8_t" {constraint: "kind (type)"}
  "01": "uint8_t[3]" {constraint: "padding (alignment)"}
  "04": "uint32_t" {constraint: "line_number"}
  "08": "uint32_t" {constraint: "col_number"}
  "12": "char*" {constraint: "literal_ptr"}
}

# Apply styling to individual rows to meet Technical Design Artist requirements
TokenLayout."00".class: header_purple
TokenLayout."01".class: padding_gray
TokenLayout."04".class: data_blue
TokenLayout."08".class: data_blue
TokenLayout."12".class: pointer_orange

# --- ALGORITHM STATE: SCANNING "SELECT" ---

ScanningProcess: {
  label: "Algorithm State: Step 1 (Identifying 'S')"
  
  InputBuffer: {
    label: "Input String Buffer [RAM]"
    direction: right
    grid-columns: 8
    
    S: "S" { style.fill: "#FFCCCC"; style.bold: true; style.stroke: red }
    E: "E"
    L: "L"
    E2: "E"
    C: "C"
    T: "T"
    SP: " " { style.fill: "#F5F5F5" }
    AST: "*"
  }

  StateMachine: {
    shape: circle
    label: "FSM STATE:\nIDENT_START"
    class: state_active
  }

  InputBuffer.S -> StateMachine: "Consume char at cursor" {
    style.stroke: red
    style.bold: true
  }
  
  StateMachine -> TokenStream: "Emit(TK_SELECT)" {
    style.animated: true
  }
}

# --- TOKEN STREAM ---

TokenStream: {
  label: "Linear Token Stream (Output)"
  grid-columns: 4
  
  T0: "TOKEN(SELECT)\nKind: 0\nLine: 1" { class: data_blue }
  T1: "TOKEN(*)\nKind: 12\nLine: 1" { class: data_blue }
  T2: "TOKEN(FROM)\nKind: 1\nLine: 1" { class: data_blue }
  T3: "TOKEN(users)\nKind: 3\nLine: 1" { class: data_blue }
}

# --- CONNECTIONS ---

TokenizationEngine.Scanner -> ScanningProcess.InputBuffer: "ptr access" {
  source-arrowhead: triangle
  target-arrowhead: diamond
}

ScanningProcess.StateMachine -> TokenStream: "push_back()"

# Show logical link between abstract token and memory representation
TokenStream.T0 -> TokenLayout: "serialized to memory" {
  style.stroke-dash: 5
  style.stroke: orange
}

# --- ANNOTATIONS ---
# ELK does not support near: <ID>, so we use a constant position
# and descriptive label for engineering specification.

Annotations: {
  near: top-right
  size_info: |md
    ### Size Specs (TokenLayout)
    - **Total Size:** 16 bytes
    - **Alignment:** 4-byte boundary
    - **Cache Usage:** 25% of 64B line
    - **Growth:** Appends to Heap
  |
}

TokenizationEngine.Scanner.readChar -> ScanningProcess.StateMachine: "Triggers state transition" {
  style.stroke-dash: 3
}