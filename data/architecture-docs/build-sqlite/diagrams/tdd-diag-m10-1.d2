direction: right
layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#B5AFF6"
    data: "#C7F1FF"
    code: "#F6F9FC"
    logic: "#DEE1EB"
    padding: "#E6EBF1"
    pointer: "#F9D8A7"
  }
}

title: |md
  # SQLITE WAL (WRITE-AHEAD LOG) SPECIFICATION
  ### Implementation-Grade Technical Design
| {
  near: top-center
  shape: text
}

# ---------------------------------------------------------------------------------
# 1. PHYSICAL MEMORY LAYOUT: WAL FRAME HEADER
# ---------------------------------------------------------------------------------
wal_physical_layout: "WAL Frame Header & Page Layout" {
  style.fill: "#F1F1F1"
  
  header_table: "Binary Layout (24 Bytes Header)" {
    shape: sql_table
    style.fill: ${vars.colors.header}
    
    00_03: "page_number (Big Endian)" {
      type: "u32"
      constraint: "Offset +0 | 4B"
    }
    04_07: "commit_size (Pages in frame)" {
      type: "u32"
      constraint: "Offset +4 | 4B"
    }
    08_15: "transaction_id (Monotonic)" {
      type: "u64"
      constraint: "Offset +8 | 8B"
    }
    16_19: "salt1 (Anti-corruption)" {
      type: "u32"
      constraint: "Offset +16 | 4B"
    }
    20_23: "salt2 (Commit sequence)" {
      type: "u32"
      constraint: "Offset +20 | 4B"
    }
  }

  page_data: "Database Page Data" {
    style.fill: ${vars.colors.data}
    style.stroke-dash: 5
    label: "Page Payload (Offset 24 | typically 4096B)"
  }

  checksum_logic: |'cpp
    // WAL Checksum Algorithm (SQLITE_BIGENDIAN)
    // Computes CRC on Frame Header + Page Data
    static void wal_checksum(u8 *frame, int page_size, u32 *cksum_out) {
      u32 s1 = 0xdeadbeef, s2 = 0xfacebookd;
      // Header rotation (0-16 bytes)
      for (int i = 0; i < 16; i += 4) {
        s1 += (frame[i] << 24) | (frame[i+1] << 16) | (frame[i+2] << 8) | frame[i+3];
        s1 = (s1 >> 31) | (s1 << 1); 
      }
      // Full page content scan
      for (int i = 24; i < 24 + page_size; i += 4) {
        s2 += (frame[i] << 24) | (frame[i+1] << 16) | (frame[i+2] << 8) | frame[i+3];
        s2 = (s2 >> 31) | (s2 << 1);
      }
      cksum_out[0] = s1; cksum_out[1] = s2;
    }
  '| {
    near: header_table
    style.font: mono
  }

  header_table -> page_data: "Followed by (Offset 24)"
}

# ---------------------------------------------------------------------------------
# 2. SHARED MEMORY (SHM) INDEX STRUCTURE
# ---------------------------------------------------------------------------------
wal_index_shm: "WAL Index (Shared Memory)" {
  style.fill: ${vars.colors.data}
  
  shm_header: "SHM Content Header" {
    shape: sql_table
    salt1: u32
    salt2: u32
    sz_page: u32
  }
  
  idx_header: "Index Control Structure" {
    shape: sql_table
    mx_frame: "u32 (Highest Committed)"
    pin_cnt: "u32 (Active Readers)"
    txn_id: "u64 (Current Writer)"
  }
  
  lock_table: "Locking Primitives (Bitmap)" {
    grid-columns: 2
    grid-gap: 0
    L0: "WAL_LOCK_NONE (0)"
    L1: "WAL_LOCK_READER (1)"
    L2: "WAL_LOCK_WRITER (2)"
    L3: "WAL_LOCK_CHECKPOINTER (4)"
    L4: "WAL_LOCK_ALL (7)"
  }
}

# ---------------------------------------------------------------------------------
# 3. ALGORITHM STATE: CHECKPOINT OPERATIONS
# ---------------------------------------------------------------------------------
checkpoint_logic: "Checkpoint State Machine" {
  
  modes: "Checkpointing Modes" {
    shape: sql_table
    PASSIVE: "Non-blocking copy"
    FULL: "Block writers, force all"
    RESTART: "Reset WAL header"
    TRUNCATE: "ftruncate() to 0"
  }

  algorithm: |'md
    ### Passive Checkpoint Algorithm
    1. **Acquire** `WAL_LOCK_CHECKPOINTER` (bit 4)
    2. **Read** `mx_frame` from Index Header in SHM
    3. **Scan** frames 0...mx_frame:
       - If `txn_id` <= `committed_txn`:
         - `memcpy(page, db_file)` at P*PgSize
    4. **Release** Lock via SHM bitmap
    5. **Truncate** if mode == `TRUNCATE`
  '|
}

# ---------------------------------------------------------------------------------
# 4. SEQUENCE DIAGRAM: CONCURRENT READER PROTOCOL
# ---------------------------------------------------------------------------------
concurrency_flow: "Concurrency Sequence" {
  shape: sequence_diagram
  
  Reader: {shape: person}
  SHM_Index: {style.fill: ${vars.colors.data}}
  WAL_File: {style.fill: ${vars.colors.logic}}
  DB_File: {style.fill: ${vars.colors.logic}}

  Reader -> SHM_Index: "Register (pin_cnt++)"
  Reader -> SHM_Index: "Read Snapshot (mx_frame, salt)"
  SHM_Index -> Reader: "start_frame, end_frame"
  
  Reader -> WAL_File: "Binary Search for Page X"
  WAL_File -> Reader: "Return Latest Frame Page"
  
  Reader -> DB_File: "Fallback (if not in WAL)"
  
  Reader -> SHM_Index: "Unregister (pin_cnt--)"
}

# ---------------------------------------------------------------------------------
# 5. CRASH RECOVERY PROCEDURE
# ---------------------------------------------------------------------------------
recovery_procedure: "Recovery Workflow" {
  step1: "Read WAL Header"
  step2: "Validate Frame Checksums"
  step3: "Roll Forward Committed Txns"
  step4: "Truncate to last valid commit"
  
  step1 -> step2 -> step3 -> step4
  
  step2.style.stroke: red
  step2.tooltip: "Detects torn writes via CRC-32 rotation"
}

# ---------------------------------------------------------------------------------
# CONNECTIONS & INTER-COMPONENT LOGIC
# ---------------------------------------------------------------------------------
wal_physical_layout.header_table -> wal_index_shm.shm_header: "Sync Salt" {
  style.stroke: orange
  style.stroke-dash: 5
}

checkpoint_logic.modes -> wal_index_shm.lock_table: "Request Lock"

# Summary Table (Grid)
summary: "Feature Comparison: Rollback vs WAL" {
  near: recovery_procedure
  grid-rows: 4
  grid-columns: 3
  grid-gap: 0
  
  h1: "Feature" {style.bold: true; style.fill: ${vars.colors.logic}}
  h2: "Rollback Journal" {style.bold: true; style.fill: ${vars.colors.logic}}
  h3: "WAL Mode" {style.bold: true; style.fill: ${vars.colors.logic}}
  
  r1c1: "Concurrency"
  r1c2: "Exclusive Writer"
  r1c3: "Concurrent R/W"
  
  r2c1: "Sync Cost"
  r2c2: "1 fsync / commit"
  r2c3: "1 fsync / frame (batch)"
  
  r3c1: "Reads"
  r3c2: "Blocked by write"
  r3c3: "Never blocked"
}

# Layout constraints
wal_physical_layout -> wal_index_shm
wal_index_shm -> checkpoint_logic
checkpoint_logic -> concurrency_flow
concurrency_flow -> recovery_procedure

# Global Styling
***.style.font: mono
***.style.border-radius: 4
***.header_table.style.fill: ${vars.colors.header}
***.shm_header.style.fill: ${vars.colors.header}