vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

classes: {
  process: {
    shape: person
    style: {
      stroke-width: 2
      fill: "#DEE1EB"
      font-size: 14
      bold: true
    }
  }
  storage: {
    shape: cylinder
    style: {
      fill: "#C7F1FF"
      stroke-width: 2
    }
  }
  journal_file: {
    shape: rectangle
    style: {
      fill: "#E4DBFE"
      stroke-dash: 3
      stroke-width: 2
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 11
      italic: true
    }
  }
}

title: |md
  # SQLite Storage Engine Architecture
  ## Comparative Analysis: Rollback Journal vs. Write-Ahead Log (WAL)
  **Specification Version:** 1.0.4 | **Document Class:** Technical Deep Dive
|
title.near: top-center

rollback_mode: "Atomic Commit Model: Rollback Journal (Legacy)" {
  direction: right
  style: {
    stroke: "#FE7070"
    stroke-width: 4
    fill: "#FFF5F5"
    double-border: true
  }

  writer: "Writer Process\n[EXCLUSIVE LOCK]" {
    class: process
    tooltip: "Writes require exclusive file access"
  }
  
  reader: "Reader Process\n[BLOCKED]" {
    class: process
    tooltip: "Blocked during the mutation phase"
  }

  db_file: "Main Database\n(sqlite-db)\n[Master Storage]" {
    class: storage
  }

  journal: "Rollback Journal\n(sqlite-journal)\n[Hot Journal]" {
    class: journal_file
  }

  # Sequence of Operations
  writer -> journal: "1. PROLOGUE\nCopy original pages\nto journal file" {
    style: { stroke: "#f39c12"; stroke-width: 3 }
  }
  writer -> db_file: "2. MUTATION\nOverwrite DB pages\nwith new content" {
    style: { stroke: "#2980b9"; stroke-width: 3 }
  }
  
  recovery_path: "RECOVERY FLOW" {
    journal -> db_file: "On Crash:\nRestore original\nstate from journal" {
      source-arrowhead: triangle
      style: { 
        stroke: "#c0392b"
        stroke-dash: 5 
        stroke-width: 2
      }
    }
  }
  
  illegal_access: "LOCK CONTENTION" {
    reader -> db_file: "ILLEGAL:\nDatabase is locked" {
      style: { 
        stroke: "#e74c3c"
        stroke-dash: 3
        animated: true
      }
    }
  }

  note: |md
    ### Architectural Constraint: Writer Blocks Readers
    In this mode, the writer must directly modify the database file. To ensure atomicity, it saves the original "pre-change" pages into the journal. Because the database file is physically modified during the transaction, no readers can access it safely until the writer commits and releases the **EXCLUSIVE** lock.
    
    **State Invariant:** `JournalExists == TransactionInFlight`
  |
  note.near: bottom-center
  note.style.font-size: 12
  note.style.stroke: "#FE7070"
  note.style.border-radius: 8
}

wal_mode: "High-Concurrency Model: Write-Ahead Log (WAL)" {
  direction: right
  style: {
    stroke: "#44C7B1"
    stroke-width: 4
    fill: "#F0FFF4"
    double-border: true
  }

  writer: "Writer Process\n[WAL_WRITE_LOCK]" {
    class: process
    tooltip: "Appends to log file; non-blocking for readers"
  }

  reader: "Reader Process\n[SHARED_LOCK]" {
    class: process
    tooltip: "Consistent snapshot reading"
  }

  db_file: "Main Database\n(sqlite-db)\n[Baseline State]" {
    class: storage
  }

  wal_file: "Write-Ahead Log\n(sqlite-wal)\n[Delta Storage]" {
    class: journal_file
    style.fill: "#B5AFF6"
  }

  wal_shm: "WAL Index\n(sqlite-shm)\n[Shared Memory]" {
    shape: rectangle
    style: {
      fill: "#88DCF7"
      font-size: 10
      stroke-width: 1
    }
    tooltip: "Fast lookup table for page versions in WAL"
  }

  # Sequence of Operations
  writer -> wal_file: "1. APPEND\nWrite new versions\nto end of WAL" {
    style: { stroke: "#27ae60"; stroke-width: 3 }
  }
  
  reading_logic: "MULTI-VERSION CONCURRENCY" {
    reader -> db_file: "2a. Read Baseline\n(Original Pages)" {
      style: { stroke: "#2980b9"; stroke-dash: 4 }
    }
    reader -> wal_shm: "2b. Interrogate Index" {
      style: { stroke: "#2980b9"; stroke-width: 1 }
    }
    reader -> wal_file: "2c. Read Delta\n(Latest Versions)" {
      style: { stroke: "#2980b9"; stroke-width: 3 }
    }
  }

  checkpoint_process: "MAINTENANCE" {
    checkpoint: "Checkpoint Task" {
      shape: hexagon
      style: {
        stroke: "#e67e22"
        fill: "#fef5e7"
      }
    }
    wal_file -> checkpoint: "Collect Deltas"
    checkpoint -> db_file: "Flush to Baseline"
  }

  note: |md
    ### Architectural Advantage: Readers do not block Writers
    The main database file remains untouched during writes. New data is appended to the WAL file. Readers determine the "correct" version of a page by checking the WAL index (`-shm`). If a newer version exists in the WAL, it is used; otherwise, the baseline is read. 
    
    **State Invariant:** `DB_Baseline + WAL_Deltas == Current_State`
  |
  note.near: bottom-center
  note.style.font-size: 12
  note.style.stroke: "#44C7B1"
  note.style.border-radius: 8
}

# Connector for layout spacing
rollback_mode -- wal_mode: "Comparison Boundary" {
  style: {
    stroke-width: 0
    font-size: 0
  }
}

footer: |md
  **Implementation Note:** 
  - Rollback Journal is compatible with all filesystems (including network shares).
  - WAL mode requires `mmap()`, typically restricting it to local filesystems only.
|
footer.near: bottom-right