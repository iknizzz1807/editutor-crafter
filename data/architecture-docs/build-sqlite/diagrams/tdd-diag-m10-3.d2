direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# -----------------------------------------------------------------------------------------
# COMPONENT: Snapshot Isolation Flow (MVCC Sequence Diagram)
# -----------------------------------------------------------------------------------------
Snapshot Isolation Flow: {
  shape: sequence_diagram
  
  # Participants - Technical Specifications & Lifelines
  # Colors: TM=Blue, BTree=Purple, WAL=Orange
  Client: "Client Application" {
    shape: person
    style.fill: "#DEE1EB"
    tooltip: "Initiates ACID transactions with Snapshot Isolation"
  }
  TM: "Transaction Manager" {
    style.fill: "#C6E4FF"
    tooltip: "Manages Snapshot IDs and Commit/Abort logic"
  }
  BTree: "B-Tree Storage" {
    style.fill: "#E4DBFE"
    tooltip: "Primary Index (Clustered)"
  }
  WAL: "Version Store (WAL)" {
    style.fill: "#FFE4B5"
    tooltip: "Write-Ahead Log containing multi-version delta records"
  }

  # --- STEP 1: INITIALIZATION ---
  Client.t1 -> TM.t1: "BEGIN TRANSACTION"
  
  TM.t1."Isolation Level: SNAPSHOT" {
    style.italic: true
    style.font-size: 12
    style.font-color: "#444444"
  }
  
  TM.t1 -> TM.t1: "Capture SnapshotID\ncurr_tx_id = 0x0A22" {
    style: {
      stroke: red
      stroke-width: 3
      bold: true
    }
  }
  
  TM.t1 -> Client.t1: "OK (Snapshot 0x0A22)"

  # --- STEP 2: MULTI-VERSION READ ---
  # Demonstrating Version Visibility logic
  Client.t2 -> BTree.t2: "SELECT * FROM users WHERE id=1"
  
  BTree.t2 -> WAL.t2: "GET_VERSION(id=1, snapshot_id=0x0A22)"
  
  WAL.t2 -> WAL.t2: "Filter versions > 0x0A22\n(Skip Uncommitted)" {
    style.stroke-dash: 3
    style.stroke: "#666666"
  }
  
  WAL.t2 -> BTree.t2: "DataRecord{v=0x09FF, val='Alice'}"
  
  BTree.t2 -> Client.t2: "Result: 'Alice'"

  # --- STEP 3: CONCURRENT CONFLICT DETECTION ---
  # Note: Writes are buffered in private session memory before commit
  Group Write Operations: {
    label: "Local Session Buffer (Isolation Phase)"
    style.stroke: orange
    style.stroke-dash: 5
    style.fill: "#FFF9F0"
    
    Client.t3 -> BTree.t3: "UPDATE users SET val='Bob' WHERE id=1"
    
    BTree.t3 -> WAL.t3: "APPEND_PRIVATE(tx_id=0x0A22, key=1, val='Bob')"
    
    BTree.t3 -> Client.t3: "ACK (Buffered)"
  }

  # --- STEP 4: COMMIT SEQUENCE ---
  # Validation + Physical Log Merge
  Client.t4 -> TM.t4: "COMMIT"
  
  TM.t4 -> TM.t4: "Acquire EXCLUSIVE LOCK ▼" {
    style.bold: true
  }
  
  TM.t4 -> WAL.t4: "VALIDATE_CONFLICTS(tx_id=0x0A22)"
  
  WAL.t4 -> WAL.t4: "Check for overlapping\nwrites to key=1" {
    style: {
      stroke: red
      stroke-width: 3
      bold: true
    }
  }
  
  WAL.t4 -> TM.t4: "VALIDATION_SUCCESS"
  
  TM.t4 -> WAL.t4: "MERGE_TO_MAIN_LOG(tx_id=0x0A22)" {
    style.animated: true
    style.stroke: green
  }
  
  TM.t4 -> TM.t4: "Release LOCKS ▲"
  
  TM.t4 -> Client.t4: "TRANSACTION_SUCCESS (0x0A22 committed)"
}

# -----------------------------------------------------------------------------------------
# COMPONENT: Memory Layout Specs (Byte Offsets & Field Sizes)
# -----------------------------------------------------------------------------------------
Version Header Layout: {
  shape: sql_table
  near: top-right
  style.fill: "#F0F0F0"
  
  header: "Version Header Struct (24 Bytes)"
  offset_00: "TransactionID (uint64)" { constraint: "Offset +0 | 8B" }
  offset_08: "PreviousVersionPtr (uint64)" { constraint: "Offset +8 | 8B" }
  offset_16: "CRC32 / Checksum (uint32)" { constraint: "Offset +16 | 4B" }
  offset_20: "Flags (uint32)" { constraint: "Offset +20 | 4B" }
}

# -----------------------------------------------------------------------------------------
# COMPONENT: Technical Annotations for Engineering Implementation
# -----------------------------------------------------------------------------------------
# FIXED: Using constant 'bottom-center' for ELK compatibility
Annot: |md
  ### Snapshot Isolation (MVCC) Design Spec:
  
  1. **Snapshot Visibility Rule**: 
     - A version is visible if `CommitTS <= SnapshotID` AND `VersionID` is not in the `In-Flight` list.
  2. **WAL Append (`APPEND_PRIVATE`)**: 
     - Writes are kept in a per-connection delta-buffer (Shadow Pages) to prevent "Dirty Reads".
  3. **Validation Logic (First-Writer-Wins)**: 
     - At commit time, the WAL is scanned for any entries where `Key == ModifiedKey` and `CommitTS > StartTS`.
     - If detected, the transaction must **ABORT** with a Serialization Failure.
  4. **Physical Write Path**: 
     - `MERGE_TO_MAIN_LOG` requires a synchronous write to the journal before the Client receives the ACK.
| {
  near: bottom-center
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#FFFFFF"
    border-radius: 8
    font-size: 14
  }
}

# -----------------------------------------------------------------------------------------
# GLOBAL STYLING & GLOBS
# -----------------------------------------------------------------------------------------
(Snapshot Isolation Flow.** -> Snapshot Isolation Flow.**)[*]: {
  style: {
    stroke-width: 2
    font-size: 14
    font: mono
  }
}

# Legend for Memory Alignment
Memory Alignment Legend: {
  near: bottom-right
  style.fill: "#F4F4F4"
  
  cache_line: "64B Cache Line Boundary" {
    style.stroke-dash: 5
    style.stroke: grey
  }
  header_field: "Header Field" {
    style.fill: "#C6E4FF"
  }
  padding: "Alignment Padding" {
    style.fill: "#E0E0E0"
  }
}