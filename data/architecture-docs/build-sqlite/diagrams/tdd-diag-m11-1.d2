direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 20
  }
}

# --- STATE MACHINE DEFINITIONS ---

START: "●" {
  shape: circle
  width: 30
  height: 30
  style: {
    fill: "#333333"
    stroke-width: 0
  }
}

IDLE: "IDLE\n(State 0x00)" {
  shape: rectangle
  tooltip: "Awaiting SQL statement or Connection"
  style: {
    stroke-width: 2
    double-border: true
  }
  # Invariant: Database connection (sqlite3*) must be established.
}

LEXING_PARSING: "LEXING & PARSING\n(State 0x01)" {
  tooltip: "Tokenizing input and generating AST"
  style: {
    stroke-width: 4
  }
  # Invariant: Output AST must be valid and acyclic.
}

CODE_GENERATION: "QUERY_PLANNING\n(State 0x02)" {
  tooltip: "Query Optimizer generating VDBE opcodes"
  style: {
    stroke-width: 4
  }
  # Invariant: Bytecode generated must match Schema version.
}

VM_EXECUTION: "VM_EXECUTION\n(State 0x03)" {
  tooltip: "VDBE running bytecode instructions"
  style: {
    stroke-width: 4
    fill: "#eef2ff"
  }
  # Invariant: Program Counter (PC) incrementing per cycle.
}

B_TREE_IO: "B_TREE_IO\n(State 0x04)" {
  tooltip: "Interaction with Pager/Storage layer"
  shape: cylinder
  style: {
    fill: "#f0fdf4"
    stroke: "#166534"
  }
}

TRANSACTION_COMMIT: "TX_COMMIT\n(State 0x05)" {
  tooltip: "Atomic write to WAL/Journal"
  style: {
    bold: true
  }
}

FAULT: "FAULT_RECOVERY\n(State 0xFF)" {
  style: {
    fill: "#fee2e2"
    stroke: "#dc2626"
    font-color: "#dc2626"
    bold: true
  }
  shape: diamond
}

# --- TRANSITIONS ---

START -> IDLE: "sqlite3_open()"

IDLE -> LEXING_PARSING: "sqlite3_prepare_v2()" {
  tooltip: "Input: Raw UTF-8 String"
  style: {
    font-size: 14
    bold: true
  }
}

LEXING_PARSING -> CODE_GENERATION: "Valid AST" {
  tooltip: "Guard: [ast != null]"
}

LEXING_PARSING -> FAULT: "SQLITE_ERROR" {
  label: "Syntax Error"
  style: {
    stroke: "#dc2626"
    font-color: "#dc2626"
    stroke-width: 2
  }
}

CODE_GENERATION -> VM_EXECUTION: "OPCODES_LOADED" {
  tooltip: "Action: Initialize Program Counter (PC=0)"
}

VM_EXECUTION -> B_TREE_IO: "Op_Column / Op_Next" {
  label: "Page Request"
  style: {
    stroke-dash: 2
  }
}

B_TREE_IO -> VM_EXECUTION: "Page Ready" {
  label: "Data In Buffer"
  style: {
    stroke-dash: 2
  }
}

VM_EXECUTION -> TRANSACTION_COMMIT: "Op_Halt (OK)" {
  label: "sqlite3_step() -> DONE"
  tooltip: "Bytecode completion"
}

VM_EXECUTION -> FAULT: "SQLITE_CORRUPT" {
  label: "Schema Inconsistency"
  style: {
    stroke: "#dc2626"
    font-color: "#dc2626"
  }
}

TRANSACTION_COMMIT -> IDLE: "sqlite3_finalize()" {
  label: "SUCCESS_CLEANUP"
}

FAULT -> IDLE: "sqlite3_reset()" {
  label: "RECOVERY_SIGNAL"
  style: {
    stroke: "#2563eb"
    font-color: "#2563eb"
  }
}

# --- ILLEGAL TRANSITIONS (Security/Constraint Policy) ---

CODE_GENERATION -> IDLE: "ILLEGAL_ABORT" {
  style: {
    stroke: "#dc2626"
    stroke-dash: 5
    opacity: 0.6
  }
}

IDLE -> VM_EXECUTION: "ILLEGAL_BYPASS" {
  style: {
    stroke: "#dc2626"
    stroke-dash: 5
    opacity: 0.6
  }
}

# --- ANNOTATIONS ---

# FIXED: 'near' is now set to a constant 'bottom-right' for ELK compatibility
TechnicalSpec: |md
  ### SQLite Aggregate State Machine Technical Specification
  **Operational Invariants:**
  1. **Handle Validity:** No state transition can occur without a valid `sqlite3*` handle pointer.
  2. **Concurrency:** `B_TREE_IO` requires an acquired Pager lock (Shared/Reserved/Exclusive).
  3. **Integrity:** `TX_COMMIT` must be reached via `Op_Halt` to ensure journal/WAL integrity.
  4. **Isolation:** States 0x01 through 0x04 operate within a protected heap segment.

  **Error Recovery Protocol:**
  - Any non-OK result code in `VM_EXECUTION` forces an automatic `ROLLBACK` action.
  - Faults in `B_TREE_IO` (IOERR) trigger immediate transition to `FAULT_RECOVERY`.
  - Recovery from `FAULT` state requires a full `sqlite3_reset()` to clear the VM stack.

  **State Size Offsets (Internal):**
  - `IDLE`: 0 bytes overhead
  - `VM_EXECUTION`: ~4KB stack allocated
  - `B_TREE_IO`: Variable (Page Cache dependent)
| {
  near: bottom-right
  style: {
    stroke: "#6366f1"
    fill: "#f8fafc"
    font-size: 12
  }
}

# Legend for implementation engineers
Legend: {
  near: top-right
  style: {
    stroke: gray
    fill: "#ffffff"
  }
  
  S_Normal: "Primary Execution Flow" {
    style: {
      stroke-width: 4
    }
  }
  S_Storage: "Storage/IO Interaction" {
    shape: cylinder
  }
  S_Error: "Critical Error State" {
    style: {
      fill: "#fee2e2"
      stroke: "#dc2626"
    }
  }
  S_Illegal: "Forbidden Path" {
    style: {
      stroke: "#dc2626"
      stroke-dash: 5
    }
  }
}