vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# 1. STRUCT DEFINITIONS (MEMORY LAYOUT)
# -----------------------------------------------------------------------------
memory_layouts: {
  label: "Struct Memory Layouts (x86_64 Alignment)"
  
  agg_accumulator: {
    shape: sql_table
    label: "struct AggregateAccumulator | sizeof: 48 bytes"
    
    "00": "func_type (int32)" {constraint: "4 bytes"; style.fill: "#2563eb"; style.font-color: white}
    "04": "has_null (bool)" {constraint: "1 byte"; style.fill: "#2563eb"; style.font-color: white}
    "05": "padding" {constraint: "3 bytes"; style.fill: "#9ca3af"}
    "08": "*current_value (Value)" {constraint: "8 bytes (ptr)"; style.fill: "#ea580c"; style.font-color: white}
    "16": "count (int64)" {constraint: "8 bytes"; style.fill: "#2563eb"; style.font-color: white}
    "24": "*concat_buffer (SB)" {constraint: "8 bytes (ptr)"; style.fill: "#ea580c"; style.font-color: white}
    "32": "*extreme_value (Value)" {constraint: "8 bytes (ptr)"; style.fill: "#ea580c"; style.font-color: white}
    "40": "*next_acc" {constraint: "8 bytes (ptr)"; style.fill: "#ea580c"; style.font-color: white}
    
    style.stroke: "#6d28d9"
    style.stroke-width: 2
  }

  agg_group: {
    shape: sql_table
    label: "struct AggregateGroup | sizeof: 32 bytes"
    
    "00": "*group_key (KeyBuffer)" {constraint: "8 bytes (ptr)"; style.fill: "#ea580c"; style.font-color: white}
    "08": "*accumulators (List)" {constraint: "8 bytes (ptr)"; style.fill: "#ea580c"; style.font-color: white}
    "16": "row_count (int64)" {constraint: "8 bytes"; style.fill: "#2563eb"; style.font-color: white}
    "24": "*next (AggregateGroup)" {constraint: "8 bytes (ptr)"; style.fill: "#ea580c"; style.font-color: white}
    
    style.stroke: "#6d28d9"
    style.stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# 2. HASH TABLE ARCHITECTURE
# -----------------------------------------------------------------------------
hash_table_logic: {
  label: "GROUP BY Hash Table Implementation"

  input_row: {
    shape: sql_table
    label: "Input Row Registers"
    col_0: "Register P2 (Group Key 1)"
    col_1: "Register P2+1 (Group Key 2)"
    col_2: "Register P2+2 (Data for Sum)"
  }

  hash_func: "MurmurHash3 / XOR Folding" {
    shape: diamond
    style.fill: "#fef3c7"
  }

  buckets: {
    grid-rows: 8
    label: "Hash Buckets Array (AggContext->groups)"
    
    b0: "Bucket 0"
    b1: "Bucket 1"
    b2: "Bucket 2"
    b3: "Bucket 3"
    b4: "Bucket 4"
    b5: "Bucket 5"
    b6: "Bucket 6"
    b7: "Bucket 7"
    
    style.fill: "#f8fafc"
  }

  collision_chain_0: {
    label: "Collision Chain (Bucket 2)"
    
    group_a: {
      label: "AggregateGroup\nKey: {'USA'}"
      style.fill: "#dcfce7"
    }
    
    group_b: {
      label: "AggregateGroup\nKey: {'CAN'}"
      style.fill: "#dcfce7"
    }
    
    group_a -> group_b: "next pointer" {style.stroke: "#ea580c"}
  }

  accumulators_list: {
    label: "Per-Group Accumulators"
    
    acc_count: "COUNT(*)\nValue: 142" {style.fill: "#e0f2fe"}
    acc_sum: "SUM(salary)\nValue: 84200.50" {style.fill: "#e0f2fe"}
    
    acc_count -> acc_sum: "linked list"
  }
}

# -----------------------------------------------------------------------------
# 3. CONNECTIONS & FLOW
# -----------------------------------------------------------------------------

# Process flow: Hashing input to find group
hash_table_logic.input_row.col_0 -> hash_table_logic.hash_func: "1. Extract Keys"
hash_table_logic.input_row.col_1 -> hash_table_logic.hash_func

hash_table_logic.hash_func -> hash_table_logic.buckets.b2: "2. Hash Index (idx=2)" {
  style.stroke-dash: 3
  style.animated: true
}

# Bucket to Group lookup
hash_table_logic.buckets.b2 -> hash_table_logic.collision_chain_0.group_a: "3. Probe Chain" {
  style.stroke: "#ea580c"
  style.stroke-width: 2
}

# Group to Accumulator data update
hash_table_logic.collision_chain_0.group_a -> hash_table_logic.accumulators_list: "4. Update State" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
}

# Reference Memory Layouts
hash_table_logic.collision_chain_0.group_a -> memory_layouts.agg_group: "implements" {
  style.stroke-dash: 5
}
hash_table_logic.accumulators_list.acc_count -> memory_layouts.agg_accumulator: "implements" {
  style.stroke-dash: 5
}

# -----------------------------------------------------------------------------
# 4. ANNOTATIONS & STYLING
# -----------------------------------------------------------------------------

legend: |md
  ### Aggregate Step Mechanism
  1. **Extract**: VDBE identifies GROUP BY columns from registers.
  2. **Hash**: Combine column values into a single hash integer.
  3. **Lookup**: Traverse the bucket's linked list to find a matching `KeyBuffer`.
  4. **Initialize**: If not found, `malloc` new `AggregateGroup` and call `.init()` for all accumulators.
  5. **Step**: Call `.step()` on each accumulator with current row arguments.
| {
  near: top-right
}

***.style.font: mono
***.style.border-radius: 4