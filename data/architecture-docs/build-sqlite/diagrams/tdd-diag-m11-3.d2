direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# ---------------------------------------------------------------------------------------
# TDD DELIVERABLES OVERVIEW: Project Status Tracking
# ---------------------------------------------------------------------------------------
tdd_overview: {
  shape: rectangle
  label: "Build-SQLite TDD Implementation Roadmap\n(sizeof=Varies by Module)"
  grid-rows: 7
  grid-columns: 3
  grid-gap: 0
  
  # Header Row
  m_h: "Module ID" { style: { underline: true; bold: true; fill: "#f1f3f4" } }
  s_h: "Technical Scope" { style: { underline: true; bold: true; fill: "#f1f3f4" } }
  st_h: "Implementation Status" { style: { underline: true; bold: true; fill: "#f1f3f4" } }

  # Module 1
  m1: "m1: Tokenizer"
  m1_s: "Lexical Analysis (DFA for Literals & Keywords)"
  m1_st: "✓ COMPLETE" { style.fill: "#e8f5e9" }

  # Module 2
  m2: "m2: Parser"
  m2_s: "Recursive Descent & AST Construction"
  m2_st: "✓ COMPLETE" { style.fill: "#e8f5e9" }

  # Module 3
  m3: "m3: VDBE"
  m3_s: "Register-based VM & Bytecode Execution"
  m3_st: "✓ COMPLETE" { style.fill: "#e8f5e9" }

  # Module 4
  m4: "m4: Pager"
  m4_s: "Buffer Pool (LRU) & OS File I/O"
  m4_st: "✓ COMPLETE" { style.fill: "#e8f5e9" }

  # Module 5
  m5: "m5: B-Tree"
  m5_s: "Clustered Indexes, Cell Formatting, Pointers"
  m5_st: "✓ COMPLETE" { style.fill: "#e8f5e9" }

  # Module 6
  m6: "m6: Aggregates"
  m6_s: "3VL Logic, SUM/COUNT/MIN, NULL handling"
  m6_st: "✓ COMPLETE" { style.fill: "#e8f5e9" }
}

# ---------------------------------------------------------------------------------------
# MODULE 1: TOKENIZER DFA (IMPLEMENTATION GRADE)
# ---------------------------------------------------------------------------------------
tokenizer_fsm: {
  label: "m1: Tokenizer Finite State Machine (DFA)"
  style.fill: "#f8f9fa"

  START: {
    shape: circle
    label: "●"
    style.fill: "#000000"
    style.font-color: "#ffffff"
  }

  IDENT_KW: "IDENTIFIER / KEYWORD" {
    style: { 
      bold: true
      fill: "#e3f2fd"
      border-radius: 10
    }
    tooltip: "Includes SELECT, FROM, WHERE, etc."
  }
  
  NUMBER: "NUMERIC LITERAL" {
    style: { 
      bold: true
      fill: "#e3f2fd"
      border-radius: 10
    }
    tooltip: "Integer and Floating Point"
  }

  STRING: "STRING LITERAL" {
    style: { 
      bold: true
      fill: "#e3f2fd"
      border-radius: 10
    }
  }

  OPERATOR: "OPERATOR / SPECIAL" {
    style: {
      fill: "#fce4ec"
      border-radius: 10
    }
  }

  START -> IDENT_KW: "[a-zA-Z_]"
  IDENT_KW -> IDENT_KW: "[a-zA-Z0-9_]"
  IDENT_KW -> START: "[ \t\n\r] | [;(),]"

  START -> NUMBER: "[0-9]"
  NUMBER -> NUMBER: "[0-9.]"
  NUMBER -> START: "[ \t\n\r] | [;(),]"

  START -> STRING: "'"
  STRING -> STRING: "[^']"
  STRING -> START: "'"

  START -> OPERATOR: "[<>=!+-*/%]"
  OPERATOR -> START: "any"
}

# ---------------------------------------------------------------------------------------
# MODULE 10: WAL (WRITE-AHEAD LOG) BINARY LAYOUT
# ---------------------------------------------------------------------------------------
wal_structure: {
  label: "m10: Write-Ahead Log Memory Format (Intel Spec Quality)"
  
  wal_hdr: "WAL Header (32 Bytes)" {
    style.fill: "#D1C4E9"
    
    f00: "0x00: Magic (0x377f0682)" { 
      style: { font-size: 10; font-color: "#b71c1c"; bold: true }
    }
    f04: "0x04: Format Version (3007000)" { style.font-size: 10 }
    f08: "0x08: Page Size (Big-Endian)" { style.font-size: 10 }
    f0C: "0x0C: Checkpoint Seq" { style.font-size: 10 }
    f10: "0x10: Salt-1" { style.font-size: 10 }
    f14: "0x14: Salt-2" { style.font-size: 10 }
    f18: "0x18: Checksum-1" { style.font-size: 10 }
    f1C: "0x1C: Checksum-2" { style.font-size: 10 }
  }

  wal_frame_1: "WAL Frame 1" {
    frame_hdr: "Frame Header (24 Bytes)" {
      style.fill: "#D1C4E9"
      f00: "0x00: Page Number" { style.font-size: 10 }
      f04: "0x04: DB Size After" { style.font-size: 10 }
      f08: "0x08: Salt-1/2" { style.font-size: 10 }
      f10: "0x10: Checksum-1/2" { style.font-size: 10 }
    }
    page_data: "Database Page Content (4096 Bytes)" {
      style: { 
        fill: "#BBDEFB"
        stroke-dash: 5 
        stroke: "#1976D2"
      }
    }
  }

  wal_frame_2: "WAL Frame 2" {
    style.opacity: 0.6
    fh: "Frame Header (24B)" { style.fill: "#D1C4E9" }
    pd: "Page Data (4KB)" { style.fill: "#BBDEFB" }
  }

  wal_hdr -> wal_frame_1.frame_hdr: "follows header"
  wal_frame_1.page_data -> wal_frame_2.fh: "contiguous"
}

# ---------------------------------------------------------------------------------------
# MODULE 11: THREE-VALUED LOGIC (3VL) MATRIX
# ---------------------------------------------------------------------------------------
three_valued_logic: {
  label: "m11: Three-Valued Logic (3VL) AND Operator Matrix"
  grid-columns: 4
  grid-gap: 0

  # Header Row
  H1: "AND" { style: { bold: true; fill: "#eeeeee"; stroke: "#333333" } }
  H2: "TRUE" { style: { bold: true; fill: "#eeeeee"; stroke: "#333333" } }
  H3: "FALSE" { style: { bold: true; fill: "#eeeeee"; stroke: "#333333" } }
  H4: "NULL" { style: { bold: true; fill: "#eeeeee"; stroke: "#333333" } }

  # Row 1: TRUE
  R1L: "TRUE" { style: { bold: true; fill: "#eeeeee"; stroke: "#333333" } }
  R1C1: "TRUE" { style: { fill: "#e8f5e9"; stroke: "#333333" } }
  R1C2: "FALSE" { style: { fill: "#ffebee"; stroke: "#333333" } }
  R1C3: "NULL" { style: { fill: "#fff3e0"; stroke: "#333333" } }

  # Row 2: FALSE
  R2L: "FALSE" { style: { bold: true; fill: "#eeeeee"; stroke: "#333333" } }
  R2C1: "FALSE" { style: { fill: "#ffebee"; stroke: "#333333" } }
  R2C2: "FALSE" { style: { fill: "#ffebee"; stroke: "#333333" } }
  R2C3: "FALSE" { style: { fill: "#ffebee"; stroke: "#333333" } }

  # Row 3: NULL
  R3L: "NULL" { style: { bold: true; fill: "#eeeeee"; stroke: "#333333" } }
  R3C1: "NULL" { style: { fill: "#fff3e0"; stroke: "#333333" } }
  R3C2: "FALSE" { style: { fill: "#ffebee"; stroke: "#333333" } }
  R3C3: "NULL" { style: { fill: "#fff3e0"; stroke: "#333333" } }
}

# ---------------------------------------------------------------------------------------
# GLOBAL CONNECTIVITY & REFINEMENTS
# ---------------------------------------------------------------------------------------
tdd_overview -> tokenizer_fsm: "m1: Token Generation"
tokenizer_fsm -> three_valued_logic: "m11: Evaluates Logical Expressions"
three_valued_logic -> wal_structure: "m10: Persistence Layer"

# Global Formatting
***.style.font: mono
***.style.border-radius: 4
***.style.stroke: "#3c4043"
***.style.stroke-width: 1

# Explanatory Legend for Implementation
legend: {
  label: "Implementation Metadata"
  near: bottom-right
  note: |md
    ### Developer Checklist:
    1.  **Endianness**: All WAL integers (Header & Frame) must be stored in **Big-Endian**.
    2.  **Checksums**: Implement Fletcher-64 variant as per SQLite specification.
    3.  **3VL Rules**: `NULL AND FALSE` results in `FALSE`. `NULL AND TRUE` results in `NULL`.
    4.  **Buffer Flush**: WAL frames must be synced to disk before updating the checkpoint header.
  |
  style.fill: "#fffde7"
  style.stroke-dash: 2
}