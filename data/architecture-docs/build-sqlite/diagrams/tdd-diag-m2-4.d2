layout-engine: elk
theme-id: 6

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
  colors: {
    header: "#9b59b6"
    data: "#3498db"
    free: "#2ecc71"
    padding: "#95a5a6"
    pointer: "#e67e22"
    logic: "#f1c40f"
    background: "#ffffff"
  }
}

# --- SQL PARSE PIPELINE (SEQUENCE DIAGRAM) ---
sql_parse_pipeline: {
  label: "Module 1: SQL Parse & Compilation Pipeline"
  shape: sequence_diagram
  
  client: Client Session {
    shape: person
  }
  tokenizer: Tokenizer {
    tooltip: "Lexical Analyzer (DFA Based)"
    style.fill: "#E1F5FE"
  }
  parser: SQL Parser {
    tooltip: "LALR(1) Lemon Parser"
    style.fill: "#E1F5FE"
  }
  ast_builder: AST Builder {
    style.fill: "#E1F5FE"
  }
  optimizer: Query Optimizer {
    tooltip: "Cost-based query planner"
    style.fill: "#FFF9C4"
  }
  codegen: Code Generator {
    tooltip: "VDBE OpCode Emitter"
    style.fill: "#FFF9C4"
  }
  vdbe: VDBE {
    tooltip: "Virtual Database Engine"
    style.fill: "#C8E6C9"
    style.bold: true
  }

  client -> tokenizer: tokenize(sql_query) {
    tooltip: "Input String: 'SELECT * FROM users WHERE id = 1;'"
  }

  tokenizer_phase: {
    label: "Lexical Analysis"
    tokenizer -> tokenizer: get_next_token()
    tokenizer -> tokenizer: validate_literals()
    tokenizer -> tokenizer: resolve_keywords()
  }

  tokenizer -> parser: token_stream: List<Token>

  parsing_logic: {
    label: "Grammar & Tree Construction"
    parser -> parser: apply_lalr_rules()
    
    parser -> ast_builder: create_node(SELECT_STMT)
    ast_builder -> ast_builder: initialize_columns(ALL)
    ast_builder -> ast_builder: set_source("users")
    
    parser <- ast_builder: root_node: SelectAST
  }

  parser -> optimizer: optimize(root_node) {
    style.stroke: "#2ecc71"
    style.stroke-width: 2
  }

  planning_phase: {
    label: "Query Planning"
    optimizer -> optimizer: resolve_identifiers()
    optimizer -> optimizer: apply_constant_folding()
    optimizer -> optimizer: select_index(idx_users_id)
  }

  optimizer -> codegen: optimized_ast: SelectAST

  bytecode_gen: {
    label: "VDBE Code Generation"
    codegen -> codegen: emit_op(OP_Transaction)
    codegen -> codegen: emit_op(OP_OpenRead, P1=0, P2=2)
    codegen -> codegen: emit_op(OP_Integer, P1=1, P2=1)
    codegen -> codegen: emit_op(OP_SeekGE, P1=0, P2=12, P3=1)
  }

  codegen -> vdbe: program: List<VdbeOp> {
    style.stroke-width: 3
  }

  execution: {
    label: "VDBE Execution Loop"
    vdbe -> vdbe: prepare_stack()
    vdbe -> vdbe: step()
    vdbe -> vdbe: fetch_row()
  }

  vdbe -> client: result_set: RowCursor {
    style.stroke-dash: 5
    style.animated: true
  }
}

# --- VDBE INSTRUCTION MEMORY LAYOUT ---
vdbe_mem_spec: {
  label: "Module 2: VDBE OpCode Binary Layout (24-Byte Padded Struct)"
  
  grid-columns: 1
  grid-gap: 10

  visual_layout: {
    grid-rows: 1
    grid-gap: 0
    
    op: "OpCode\n(1B)" { style.fill: ${colors.header}; width: 40 }
    p1: "P1\n(4B)" { style.fill: ${colors.data}; width: 80 }
    p2: "P2\n(4B)" { style.fill: ${colors.data}; width: 80 }
    p3: "P3\n(4B)" { style.fill: ${colors.data}; width: 80 }
    p4: "P4 (pointer)\n(8B)" { style.fill: ${colors.pointer}; width: 160 }
    pad: "Padding\n(3B)" { style.fill: ${colors.padding}; width: 60 }
  }

  table_spec: {
    grid-rows: 7
    grid-columns: 5
    grid-gap: 0

    # Header Row
    h1: "Offset" { style.bold: true; style.fill: "#f8f9fa" }
    h2: "Field" { style.bold: true; style.fill: "#f8f9fa" }
    h3: "Type" { style.bold: true; style.fill: "#f8f9fa" }
    h4: "Size" { style.bold: true; style.fill: "#f8f9fa" }
    h5: "Description" { style.bold: true; style.fill: "#f8f9fa" }

    # Data Rows
    r1_1: "0x00"; r1_2: "OpCode"; r1_3: "uint8"; r1_4: "1"; r1_5: "Operation ID"
    r2_1: "0x01"; r2_2: "P1"; r2_3: "int32"; r2_4: "4"; r2_5: "Cursor Index"
    r3_1: "0x05"; r3_2: "P2"; r3_3: "int32"; r3_4: "4"; r3_5: "Jump Target"
    r4_1: "0x09"; r4_2: "P3"; r4_3: "int32"; r4_4: "4"; r4_5: "Register Index"
    r5_1: "0x0D"; r5_2: "P4"; r5_3: "void*"; r5_4: "8"; r5_5: "Auxiliary Data"
    r6_1: "0x15"; r6_2: "Padding"; r6_3: "uint8[3]"; r6_4: "3"; r6_5: "Alignment"

    # Row styles
    r1_2.style.fill: ${colors.header}
    r2_2.style.fill: ${colors.data}
    r3_2.style.fill: ${colors.data}
    r4_2.style.fill: ${colors.data}
    r5_2.style.fill: ${colors.pointer}
    r6_2.style.fill: ${colors.padding}
  }
  
  summary: "sizeof(VdbeOp) = 24 bytes | Cache-line aligned (64B) if array allocated." {
    shape: text
    style.italic: true
    style.font-size: 14
  }
}

# --- DOCUMENTATION PANEL ---
docs: {
  label: "Module 3: Implementation Technical Specification"
  content: |md
    ### 1. Tokenizer (Lexer)
    - **Engine**: Re2C-generated DFA.
    - **Output**: Circular buffer of token structs to avoid allocation spikes.

    ### 2. SQL Parser
    - **Algorithm**: LALR(1) via Lemon Parser generator.
    - **Memory**: Uses a custom `Lookahead` buffer and recursive descent for sub-expressions.

    ### 3. VDBE Virtual Machine
    - **Registers**: Standard VM contains 200+ registers per program.
    - **Instruction Flow**: `OP_SeekGE` performs a B-Tree search. If the key exists, the PC continues; otherwise, it jumps to `P2`.
    - **Alignment**: Structs are 8-byte aligned to ensure atomic pointer reads for `P4`.
  |
  shape: rectangle
  style.fill: "#fdfefe"
  style.stroke: "#bdc3c7"
}

# Layout constraints using neutral container instead of near on grid cells
# This prevents the "descendants of special objects" error
page_layout: {
  style.stroke-width: 0
  style.fill: transparent
  
  sql_parse_pipeline
  vdbe_mem_spec
  docs
}

# Apply global font
***.style.font: mono

# Connection Styling Fixes
(sql_parse_pipeline.codegen -> sql_parse_pipeline.vdbe)[0].label.style.bold: true
(sql_parse_pipeline.vdbe -> sql_parse_pipeline.client)[0].style.font-color: "#27ae60"