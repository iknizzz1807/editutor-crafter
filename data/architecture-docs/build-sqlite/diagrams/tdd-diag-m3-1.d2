layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# -----------------------------------------------------------------------------------------
# SECTION 1: MODULE DOCUMENTATION & OVERVIEW
# -----------------------------------------------------------------------------------------

documentation: {
  charter: {
    shape: rectangle
    label: |md
      ### 6.1 Module Charter
      **Purpose**: Implement secondary index support for O(log n) lookup.
      **Scope**: Creation, Maintenance, Scanning, Optimization.
    |
    style: {
      fill: "#f8f9fa"
      stroke-dash: 3
    }
  }

  file_structure: {
    label: |md
      ### 6.2 File Structure
      - `src/index/index.c`: Implementation
      - `src/index/index_cursor.c`: Cursors
      - `include/index_manager.h`: Catalog API
    |
  }
  file_structure.near: charter
}

# -----------------------------------------------------------------------------------------
# SECTION 2: DATA STRUCTURES (Memory Layouts & Byte Alignment)
# -----------------------------------------------------------------------------------------
# Intel-manual quality memory layout with explicit offsets

data_structures: {
  label: "Memory Layouts (sizeof=96 bytes)"
  
  IndexMetadata: {
    shape: sql_table
    style.fill: "#e3f2fd"
    
    00_03: "index_id" {constraint: "uint32_t (4B)"}
    04_07: "table_id" {constraint: "uint32_t (4B)"}
    08_15: "index_name_ptr" {constraint: "char* (8B)"}
    16_19: "root_page" {constraint: "uint32_t (4B)"}
    20_21: "column_count" {constraint: "uint16_t (2B)"}
    22_23: "padding_0" {style.fill: "#eeeeee"}
    24_31: "column_ids_ptr" {constraint: "uint16_t* (8B)"}
    32_32: "unique_flag" {constraint: "uint8_t (1B)"}
    33_33: "partial_flag" {constraint: "uint8_t (1B)"}
    34_39: "padding_1" {style.fill: "#eeeeee"}
    40_47: "expr_ptr" {constraint: "Expr* (8B)"}
    48_95: "stats_embedded" {constraint: "IndexStats (48B)"}
  }

  IndexEntry: {
    shape: sql_table
    style.fill: "#e3f2fd"
    00_07: "key_data_ptr" {constraint: "uint8_t* (8B)"}
    08_09: "key_length" {constraint: "uint16_t (2B)"}
    10_15: "padding" {style.fill: "#eeeeee"}
    16_23: "rowid" {constraint: "uint64_t (8B)"}
    24_27: "payload_len" {constraint: "uint32_t (4B)"}
  }
}

# -----------------------------------------------------------------------------------------
# SECTION 3: INTERFACE CONTRACTS
# -----------------------------------------------------------------------------------------

interfaces: {
  Management: {
    shape: class
    "index_create(uint32_t tid, uint16_t* cids, uint16_t count, uint8_t unq)": int
    "index_drop(uint32_t index_id)": int
    style.fill: "#f3e5f5"
  }
  
  Operations: {
    shape: class
    "index_open_cursor(uint32_t id, ScanType type, void* key)": "IndexCursor*"
    "index_next(IndexCursor* cur, uint64_t* rowid)": int
    "index_insert(uint32_t id, uint64_t rid, ColumnValue* vals)": int
    style.fill: "#f3e5f5"
  }
}

# -----------------------------------------------------------------------------------------
# SECTION 4: CORE ARCHITECTURE & LOGICAL FLOW
# -----------------------------------------------------------------------------------------

index_architecture: {
  label: "6.11 Logical Indexing Architecture"
  style.fill: "#f0f4f8"
  
  user_request: "SQL CREATE INDEX" { style.fill: "#fff3e0" }
  index_manager: "Index Manager" { style.fill: "#e8f5e9" }
  key_encoder: "Key Encoder" { style.fill: "#fce4ec" }
  btree_layer: "B-Tree Layer" { style.fill: "#f3e5f5" }
  cursor_api: "Cursor API" { style.fill: "#e0f7fa" }
  query_planner: "Query Planner" { style.fill: "#fff8e1" }
  
  user_request -> index_manager
  index_manager -> key_encoder
  key_encoder -> btree_layer
  btree_layer -> cursor_api
  query_planner -> index_manager: "Uses Meta"
}

index_scan_flow: {
  label: "6.12 Index Scan State Transition"
  style.fill: "#fafafa"
  
  start: "" {
    shape: circle
    style.fill: "#4caf50"
  }
  decision_init: "Init Scan?" {
    shape: diamond
    style.fill: "#ff9800"
  }
  fetch_key: "Fetch Key" {
    style.fill: "#2196f3"
  }
  btree_search: "B-Tree Search" {
    style.fill: "#9c27b0"
  }
  decision_found: "Key Found?" {
    shape: diamond
    style.fill: "#ff9800"
  }
  return_row: "Return RowID" {
    style.fill: "#4caf50"
  }
  decision_continue: "Continue?" {
    shape: diamond
    style.fill: "#ff9800"
  }
  end_node: "" {
    shape: circle
    style.fill: "#f44336"
    style.stroke-width: 4
  }
  
  start -> decision_init
  decision_init -> fetch_key: "Yes"
  decision_init -> end_node: "No"
  fetch_key -> btree_search
  btree_search -> decision_found
  decision_found -> return_row: "Yes"
  decision_found -> end_node: "No"
  return_row -> decision_continue
  decision_continue -> fetch_key: "Yes"
  decision_continue -> end_node: "No"
}

# -----------------------------------------------------------------------------------------
# SECTION 5: PHYSICAL MEMORY LAYOUT (Page Format)
# -----------------------------------------------------------------------------------------

index_page_format: {
  label: "6.13 Physical B-Tree Page Layout (4KB Page)"
  style.fill: "#ffffff"
  
  header: "0x0000: Page Header" {
    label: "Header (12B)\nType: 0x02\nFreePtr: Offset\nCellCount: N"
    style.fill: "#d1c4e9"
  }
  
  pointers: "0x000C: Pointer Array" {
    label: "Cell Pointers (2 * N Bytes)\nuint16_t cell_offset[N]"
    style.fill: "#bbdefb"
  }
  
  padding: "FREE SPACE" {
    label: "Unallocated Bytes\n(Growing Gap)"
    style.fill: "#eeeeee"
    style.stroke-dash: 5
  }
  
  cells: "0xNNNN: Cell Storage" {
    label: "Cell Data Area\n(Growing downwards from 0x0FFF)"
    style.fill: "#c8e6c9"
    cell_n: "Cell N (Last)"
    cell_0: "Cell 0 (First)"
  }
  
  header -> pointers
  pointers -> padding
  padding -> cells
}

# -----------------------------------------------------------------------------------------
# SECTION 6: ERROR HANDLING & RECOVERY
# -----------------------------------------------------------------------------------------

error_handling_docs: {
  content: ||md
    ### 6.6 Error Handling Matrix
    | Operation    | Error Code                | Recovery Action          |
    |--------------|---------------------------|--------------------------|
    | index_create | SQLITE_NOMEM              | Retry with smaller index |
    | index_insert | SQLITE_CONSTRAINT_UNIQUE  | Rollback, report error   |
    | index_open   | SQLITE_CORRUPT            | Mark index invalid       |
  ||
  style.fill: "#fffde7"
}
error_handling_docs.near: index_scan_flow

# -----------------------------------------------------------------------------------------
# GLOBAL STYLING
# -----------------------------------------------------------------------------------------

***.style.font-size: 14
(*** -> ***)[*]: {
  style.stroke: "#333333"
  style.stroke-width: 2
}