direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- CLASSES ---
classes: {
  memory_cell: {
    style: {
      font: mono
      stroke-width: 1
    }
  }
  highlight_change: {
    style: {
      stroke: red
      stroke-width: 4
      font-color: red
      bold: true
    }
  }
  active_instruction: {
    style: {
      fill: "#fff3bf"
      bold: true
    }
  }
  header_style: {
    style: {
      fill: "#e5dbff"
      bold: true
    }
  }
}

# --- DIAGRAM CONTAINER ---
Bytecode_Execution_Loop: {
  label: "Algorithm: Virtual Machine Bytecode Execution Loop (Step-by-Step Transition)"

  # ---------------------------------------------------------
  # STEP 1: FETCH & DECODE
  # ---------------------------------------------------------
  Step_1: {
    label: "Step 1: Fetch Instruction at PC"
    
    Register_File: {
      label: "CPU Registers"
      PC: "0x04 (Pointer)" {
        class: active_instruction
      }
      R0: "0x0000000A"
      R1: "0x00000014"
      Flags: "0x00"
    }

    Bytecode_Segment: {
      shape: sql_table
      label: "Code Segment (RAM)"
      0x00: "OP_PUSH_CONST | 0x0A" 
      0x02: "OP_PUSH_CONST | 0x14"
      0x04: "OP_ADD_REG    | R0, R1" { class: active_instruction }
      0x06: "OP_STORE_MEM  | 0xFF"
    }

    Internal_Bus: {
      IR: "Instruction Register: OP_ADD_REG" {
        style.fill: "#d0ebff"
      }
    }

    Register_File.PC -> Bytecode_Segment.0x04: "1. Pointer Ref" {
      style.stroke: orange
    }
    Bytecode_Segment.0x04 -> Internal_Bus.IR: "2. Fetch Data" {
      style.animated: true
    }
  }

  # ---------------------------------------------------------
  # STEP 2: EXECUTE & PC INCREMENT
  # ---------------------------------------------------------
  Step_2: {
    label: "Step 2: ALU Execution & State Commit"
    
    Register_File: {
      label: "CPU Registers"
      PC: "**0x06**" {
        class: highlight_change
      }
      R0: "**0x0000001E** (Sum)" {
        class: highlight_change
      }
      R1: "0x00000014"
      Flags: "**0x01 (Carry)**" {
        class: highlight_change
      }
    }

    ALU: {
      shape: parallelogram
      label: "ALU (Arithmetic Logic Unit)"
      Calculation: "0x0A + 0x14 = 0x1E"
      style.fill: "#ffc9c9"
    }

    Bytecode_Segment: {
      shape: sql_table
      label: "Code Segment (RAM)"
      0x00: "OP_PUSH_CONST | 0x0A"
      0x02: "OP_PUSH_CONST | 0x14"
      0x04: "OP_ADD_REG    | R0, R1"
      0x06: "OP_STORE_MEM  | 0xFF" { class: active_instruction }
    }

    ALU -> Register_File.R0: "3. Writeback Result" {
      style.stroke: red
      style.stroke-width: 2
    }
    Register_File.PC -> Bytecode_Segment.0x06: "4. Advance PC" {
      style.stroke: red
      style.stroke-dash: 3
    }
  }

  # Transition between steps
  Step_1 -> Step_2: "Trigger: Clock Cycle Pulse" {
    style: {
      stroke-width: 6
      stroke: "#40c057"
    }
  }
}

# --- MEMORY LAYOUT OVERVIEW ---
Memory_Map: {
  near: bottom-center
  shape: sql_table
  label: "Physical Memory Layout (sizeof=256B)"
  
  0x00_0x7F: "Code Segment (Read-Only)" {
    style.fill: "#b2f2bb"
  }
  0x80_0xBF: "Stack Segment (Growth ⬇)" {
    style.fill: "#a5d8ff"
  }
  0xC0_0xDF: "Padding / Reserved" {
    style.fill: "#dee2e6"
  }
  0xE0_0xFF: "Data Segment (Globals)" {
    style.fill: "#ffec99"
  }
}

Legend: {
  near: top-right
  PC_Pointer: "Instruction Pointer" { style.stroke: orange }
  Data_Flow: "Bus Data Movement" { style.animated: true }
  Modification: "State Changed This Step" { class: highlight_change }
}