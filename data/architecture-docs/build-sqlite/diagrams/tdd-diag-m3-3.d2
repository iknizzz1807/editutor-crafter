layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# WAL Checkpoint Process Flow
# Role: TECHNICAL DESIGN ARTIST - Implementation Grade
# High-fidelity sequence illustrating the SQLite WAL-to-DB migration (Checkpointing)
checkpoint_flow: {
  shape: sequence_diagram

  # Participants - Typed and Styled for Intel Manual Quality
  client: Client Application {
    shape: person
    style.fill: "#e1f5fe"
  }
  wal: WAL Manager {
    tooltip: "Orchestrates frame validation and page migration"
    style.fill: "#fff3e0"
    style.stroke-width: 4
  }
  log: WAL Log File {
    shape: cylinder
    label: "WAL Log\n(shm-mapped)"
    style.fill: "#fce4ec"
  }
  db: Database File {
    shape: cylinder
    label: "Main DB\n(Pager Layer)"
    style.fill: "#e8f5e9"
  }

  # --- Sequence Start ---

  client -> wal: "sqlite3_checkpoint(db, mode=PASSIVE)" {
    label: "API Entry: Begin Checkpoint"
  }

  # Lock Phase
  wal -> log: "Check WAL Header (32B)"
  
  "Acquire Resource Locks": {
    wal -> db: "Acquire EXCLUSIVE lock ▼" {
      style.stroke: orange
      style.stroke-width: 3
      style.animated: true
    }
    
    wal."**PENDING -> EXCLUSIVE**\nReserved range: 0x40000000"
  }

  # Migration Loop
  "Frame Transfer (1..N)": {
    wal -> log: "Read Frame Header (24B)" {
      tooltip: "Read pgno, commit_n, salt, checksums"
    }
    
    wal -> log: "Load Page Data (4096B)"
    
    wal -> wal: "Validate Checksum" {
      label: "64-bit CRC (salt1, salt2)"
    }

    wal -> db: "Write Page to Main DB" {
      style.stroke: blue
      style.stroke-width: 2
    }
    
    wal -> db: "fsync()" {
      label: "Persistence Barrier"
    }
  }

  # Cleanup and Truncate
  "Finalization": {
    wal -> log: "ftruncate(0)" {
      label: "Reset WAL Size"
    }
    
    wal -> log: "Update WAL header salts" {
      label: "Reset Generation ID"
    }

    wal -> db: "Release EXCLUSIVE lock ▲" {
      style.stroke: orange
      style.stroke-width: 3
    }
  }

  client <- wal: "SQLITE_OK" {
    label: "Return Status"
  }
}

# Implementation Grade Specification
ann: |md
  ### SQLite Checkpoint Implementation Specification
  - **Memory Offsets:** 
    - WAL header: 0-32B (checksums at 24-32B).
    - Frame header: 24B prefix containing `pgno` (4B) and `size` (4B).
  - **Concurrency Invariant:** EXCLUSIVE lock prevents `SQLITE_BUSY` on checkpoint thread by blocking new readers/writers.
  - **Persistence:** `fsync()` must occur before `ftruncate` to ensure data integrity.
  - **Error Path:** If `SQLITE_IOERR` occurs during migration, checkpoint aborts; WAL remains valid for subsequent retry.
| {
  near: bottom-center
  style: {
    font-size: 14
    stroke: gray
    fill: "#fafafa"
    border-radius: 4
  }
}

# Styling and Fixes
# Note: double-border removed from cylinder shapes to satisfy D2 compiler constraints
checkpoint_flow.client.style.stroke-width: 2
checkpoint_flow.wal.style.stroke-width: 4

# Visual emphasis for persistence layers using stroke weight instead of double-border
checkpoint_flow.log.style.stroke-width: 3
checkpoint_flow.db.style.stroke-width: 3

# Link Visual Cues using glob targeting for sequence connections
(checkpoint_flow.** -> checkpoint_flow.db)[*]: {
  style.stroke: "#1976d2"
}

(checkpoint_flow.** -> checkpoint_flow.log)[*]: {
  style.stroke: "#c2185b"
  style.stroke-dash: 2
}

# Critical path timing annotation
(checkpoint_flow.wal -> checkpoint_flow.db)[*]: {
  tooltip: "Write latency: O(pagesize)"
}