direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- CLASSES ---
classes: {
  header: {
    style: {
      font-size: 18
      bold: true
      stroke-width: 2
    }
  }
  bytecode_op: {
    style: {
      fill: "#fce4ec"
      stroke: "#880e4f"
      font: mono
      stroke-width: 2
    }
  }
  register_active: {
    style: {
      fill: "#e1f5fe"
      stroke: "#01579b"
      bold: true
    }
  }
}

# --- MAIN EXECUTION SEQUENCE ---
sqlite_execution: {
  shape: sequence_diagram
  label: "SQLite VDBE Bytecode Execution Sequence\nInstruction: SELECT * FROM users WHERE age >= 18"
  
  # Participants (Actors)
  user: User {
    shape: person
  }
  tokenizer: Tokenizer {
    class: header
    style.fill: "#e3f2fd"
  }
  parser: Parser {
    class: header
    style.fill: "#fff3e0"
  }
  compiler: Bytecode Compiler {
    class: header
    style.fill: "#e8f5e9"
  }
  vdbe: VDBE Executor {
    class: header
    style.fill: "#fce4ec"
  }
  btree: B-Tree Cursor {
    class: header
    style.fill: "#f3e5f5"
  }

  # Query Preparation Phase
  user -> tokenizer: "SELECT * FROM users\nWHERE age >= 18"
  tokenizer -> parser: "Stream: [TK_SELECT, TK_STAR, TK_FROM...]"
  parser -> compiler: "AST: SelectStmt { Where: Ge(age, 18) }"
  compiler -> vdbe: "Load Bytecode: [Transaction, OpenRead, Integer, ...]"

  # Execution Phase - Register-Based Virtual Machine Loop
  vdbe.exec: {
    vdbe -> btree: "OP_OpenRead (P1=0, P2=root_page_2)"
    vdbe -> vdbe: "OP_Integer (P1=18, P2=r[1])" { class: bytecode_op }
    
    # Loop over database rows
    loop: Row Iteration {
      vdbe -> btree: "OP_Rewind / OP_Next (Cursor 0)"
      btree -> vdbe: "Seek successful (Row found)"
      
      vdbe -> btree: "OP_Column (P1=0, P2=age_idx, P3=r[2])"
      btree -> vdbe: "Payload: 0x00000018 (dec 24)"
      
      vdbe -> vdbe: "OP_Ge (P1=r[2], P2=r[1], P3=r[3])" { class: bytecode_op }
      
      vdbe.check: Branch Logic {
        vdbe -> vdbe: "OP_IfNot (P1=r[3], P2=jump_target_next)" {
          style.stroke: red
          style.stroke-dash: 3
        }
        
        # Row matches condition
        match: Match Found (Projection) {
          vdbe -> btree: "OP_Column (P1=0, P2=id_idx, P3=r[4])"
          vdbe -> btree: "OP_Column (P1=0, P2=name_idx, P3=r[5])"
          vdbe -> user: "OP_ResultRow (P1=r[4], P2=2)"
        }
      }
    }

    vdbe -> btree: "OP_Close (Cursor 0)"
    vdbe -> vdbe: "OP_Halt (0)" {
      style.fill: "#cfd8dc"
    }
  }
}

# --- MEMORY LAYOUT ANNOTATION ---
# Registers represent the internal state machine memory
registers: VDBE Register File (Match State) {
  shape: sql_table
  style.fill: "#eceff1"
  near: bottom-right
  
  r1: "18" { constraint: "P2: Comparison Target" }
  r2: "24" { class: register_active; constraint: "P3: Current Column Value" }
  r3: "1 (TRUE)" { class: register_active; constraint: "P3: Comparison Result" }
  r4: "101" { constraint: "P3: Result Row Data (ID)" }
  r5: "'Alice'" { constraint: "P3: Result Row Data (Name)" }
}

# --- ARCHITECTURAL SPECIFICATION ---
docs: |md
  ### SQLite VDBE (Virtual Database Engine)
  - **Type**: Register-based VM (SQLite 3.x+).
  - **Instruction Format**: `Opcode P1 P2 P3 P4 P5`.
  - **Memory Model**: 
    - `Registers (r[N])`: Stores integers, floats, strings, or NULLs.
    - `Cursors`: Handles for B-Tree traversal.
  - **B-Tree Integration**: VDBE provides logic; B-Tree provides raw byte access to pages.
| {
  near: top-right
}

# Styling connections between functional blocks
registers.r2 -> sqlite_execution.vdbe.exec.loop: "State Ref" {
  style.stroke: orange
  style.stroke-dash: 2
}