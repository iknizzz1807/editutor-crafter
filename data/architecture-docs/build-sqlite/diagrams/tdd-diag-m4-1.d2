vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 20
  }
}

# --------------------------------------------------------------------------------------------
# BUFFER POOL STATE MACHINE: LSS-SPEC-M4-1
# --------------------------------------------------------------------------------------------
# Implementation Grade Specification for DB Engine Buffer Management
# Invariants:
# - PINNED: RefCount > 0. Frame is protected from eviction.
# - UNPINNED: RefCount == 0. Frame resides in LRU-K/Clock candidate list.
# - DIRTY: Page contents modified. Requires WAL flush (LSN check).
# --------------------------------------------------------------------------------------------

BUFFER_POOL_MANAGER: "Buffer Pool Manager\nsizeof=64 bytes (cache aligned)" {
  style: {
    stroke-width: 4
    fill: "#f8f9fa"
  }

  INITIAL: "" {
    shape: circle
    width: 20
    style.fill: black
  }

  UNPINNED: "UNPINNED" {
    tooltip: "Invariant: RefCount == 0. Frame resides in LRU-K candidate list."
    style: {
      fill: "#d4edda"
      stroke: "#28a745"
      stroke-width: 2
      double-border: true
    }
  }

  PINNED: "PINNED" {
    tooltip: "Invariant: RefCount > 0. Exclusive or Shared latch held."
    style: {
      fill: "#fff3cd"
      stroke: "#ffc107"
      stroke-width: 2
    }
  }

  DIRTY: "DIRTY" {
    tooltip: "Invariant: Memory state != Disk state. PageLSN > FlushedLSN."
    style: {
      fill: "#f8d7da"
      stroke: "#dc3545"
      stroke-width: 2
    }
  }

  EVICTING: "EVICTING" {
    tooltip: "Invariant: Synchronous I/O in progress. Frame locked for replacement."
    style: {
      fill: "#e2e3e5"
      stroke: "#6c757d"
      stroke-width: 2
      stroke-dash: 3
    }
  }

  # ------------------------------------------------------------------------------------------
  # STATE TRANSITIONS
  # ------------------------------------------------------------------------------------------

  INITIAL -> UNPINNED: "Power On\n[Guard: ShmAlloc Available]\nAction: init_pool_header()" {
    style.stroke: "#6c757d"
  }
  
  UNPINNED -> PINNED: "pin_frame(page_id)" {
    source-arrowhead: circle
    target-arrowhead: triangle
    label: "Trigger: Page Access\nAction: RefCount++"
    style: {
      font-size: 11
    }
  }

  PINNED -> UNPINNED: "unpin_frame(page_id)" {
    label: "Guard: RefCount == 1\nAction: Set RefCount=0"
    style: {
      stroke: "#007bff"
      font-size: 11
    }
  }

  PINNED -> DIRTY: "write_page()" {
    label: "Trigger: Memory Write\nAction: Set DirtyBit"
    style.font-size: 11
  }

  DIRTY -> PINNED: "pin_frame()" {
    label: "Trigger: Subsequent Access\nAction: RefCount++"
    style.font-size: 11
  }

  DIRTY -> UNPINNED: "flush_to_disk()" {
    label: "Trigger: Checkpoint/Flush\nGuard: PageLSN <= WalFlushedLSN\nAction: Clear DirtyBit"
    style: {
      stroke: "#28a745"
      font-size: 11
    }
  }

  UNPINNED -> EVICTING: "evict_victim()" {
    label: "Guard: Pool Saturation\nAction: Replacement Policy Select"
    style.font-size: 11
  }

  EVICTING -> UNPINNED: "io_complete()" {
    label: "Action: Update PageTable"
    style.font-size: 11
  }

  # ------------------------------------------------------------------------------------------
  # ILLEGAL OPERATIONS
  # ------------------------------------------------------------------------------------------
  
  EVICTING -> PINNED: "ILLEGAL" {
    style: {
      stroke: red
      stroke-dash: 5
      opacity: 0.5
    }
  }
}

# --------------------------------------------------------------------------------------------
# MEMORY LAYOUT SPECIFICATION (Intel Manual Quality)
# --------------------------------------------------------------------------------------------

BUFFER_FRAME_LAYOUT: "BufferFrame Memory Layout (Atomic Alignment)" {
  shape: sql_table
  style.fill: "#f1f1f1"

  # Row Definitions: Offset | Field/Type | Constraint/Size
  "0x00": "PageID (uint32)" { constraint: "4 Bytes" }
  "0x04": "PinCount (atomic_int)" { constraint: "4 Bytes" }
  "0x08": "DirtyBit (bool)" { constraint: "1 Byte" }
  "0x09": "Padding" { constraint: "7 Bytes" }
  "0x10": "PageLSN (uint64)" { constraint: "8 Bytes" }
  "0x18": "DataPtr (void*)" { constraint: "8 Bytes" }
  "0x20": "Data (Payload)" { constraint: "32 Bytes" }

  # Individual Cell Styling (Fixed: Styled outside the row children block)
  "0x00".style: { fill: "#6f42c1"; font-color: white }
  "0x04".style: { fill: "#6f42c1"; font-color: white }
  "0x08".style: { fill: "#6f42c1"; font-color: white }
  "0x09".style: { fill: gray; font-color: white }
  "0x10".style: { fill: "#007bff"; font-color: white }
  "0x18".style: { fill: orange; font-color: black }
  "0x20".style: { fill: "#d1ecf1"; stroke-dash: 5 }
}

# --------------------------------------------------------------------------------------------
# TECHNICAL METADATA & LEGEND
# --------------------------------------------------------------------------------------------

Legend: "Technical Specification" {
  near: bottom-right
  
  S1: "State Header" {
    style: { fill: "#6f42c1"; font-color: white }
  }
  S2: "Idle/Eligible" {
    style: { fill: "#d4edda"; stroke: "#28a745" }
  }
  S3: "Active (Pinned)" {
    style: { fill: "#fff3cd"; stroke: "#ffc107" }
  }
  S4: "Dirty (Modified)" {
    style: { fill: "#f8d7da"; stroke: "#dc3545" }
  }
}

Annotation: |md
  ### Engineering Implementation Notes
  
  1.  **Eviction Candidates**: The Replacement Policy (LRU-K/Clock) MUST ONLY scan frames in the `UNPINNED` state. Any frame with `RefCount > 0` is hard-locked.
  2.  **WAL Protocol (Write-Ahead Logging)**: A page in `DIRTY` state cannot transition to `EVICTING` or `UNPINNED` (via flush) until the corresponding Log Records up to `PageLSN` are confirmed on persistent storage.
  3.  **Concurrency Control**:
      -   `UNPINNED` -> `PINNED`: Atomic Increment on `RefCount`.
      -   `PINNED` -> `DIRTY`: Requires Exclusive Latch on the Page.
      -   `DIRTY` -> `UNPINNED`: Requires Shared Latch on Page and IO Lock.
  4.  **Memory Layout**: Total Pool Size = `(sizeof(Frame) * Count) + PageTableOverhead`. Alignment is 8-byte for LSN/Pointers.
| {
  near: top-right
}