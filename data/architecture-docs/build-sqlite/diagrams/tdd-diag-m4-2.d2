layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# SQLite Internal Memory Structures - Technical Specification

# --------------------------------------------------------------------------------
# 1. B-Tree Leaf Page Layout
# --------------------------------------------------------------------------------
leaf_page: {
  label: "B-Tree Leaf Page (Table) | Size: 4096B"
  shape: sql_table
  
  # Header Section
  header_type: "Offset 0 | u8: 0x0D" {
    tooltip: "Page Type: Leaf Table B-Tree Page"
    style.fill: "#f3e5f5"
  }
  header_freeblock: "Offset 1 | u16: First Freeblock" {
    tooltip: "Offset to the first freeblock, or 0 if none"
    style.fill: "#f3e5f5"
  }
  header_cell_count: "Offset 3 | u16: Cell Count" {
    tooltip: "Number of cells on this page"
    style.fill: "#f3e5f5"
  }
  header_content_start: "Offset 5 | u16: Content Start" {
    tooltip: "Offset to the first byte of cell content area"
    style.fill: "#f3e5f5"
  }
  header_frag_free: "Offset 7 | u8: Fragmented Free Bytes" {
    tooltip: "Total number of fragmented free bytes"
    style.fill: "#f3e5f5"
  }

  # Pointer Array
  ptr_array: "Offset 8+ | u16[N]: Cell Pointer Array" {
    tooltip: "Array of offsets to individual cells. Size = 2 * cell_count"
    style.fill: "#e8f5e9"
  }

  # Data Area
  unallocated: "Variable | Unallocated Space" {
    style.fill: "#eeeeee"
    style.stroke-dash: 3
  }

  cell_content: "Variable | Cell Content Area" {
    tooltip: "Grows upwards from the end of the page"
    style.fill: "#fff3e0"
  }
}

# --------------------------------------------------------------------------------
# 2. B-Tree Interior Page Layout
# --------------------------------------------------------------------------------
interior_page: {
  label: "B-Tree Interior Page (Table) | Size: 4096B"
  shape: sql_table

  header_type: "Offset 0 | u8: 0x05" {
    tooltip: "Page Type: Interior Table B-Tree Page"
    style.fill: "#f3e5f5"
  }
  header_freeblock: "Offset 1 | u16: First Freeblock" { style.fill: "#f3e5f5" }
  header_cell_count: "Offset 3 | u16: Cell Count" { style.fill: "#f3e5f5" }
  header_content_start: "Offset 5 | u16: Content Start" { style.fill: "#f3e5f5" }
  header_frag_free: "Offset 7 | u8: Fragmented Free Bytes" { style.fill: "#f3e5f5" }
  header_right_ptr: "Offset 8 | u32: Right Child Ptr" {
    tooltip: "Page number of the right-most child"
    style.fill: "#f3e5f5"
  }

  cell_structure: "Interior Cell Format" {
    tooltip: "[Left Child u32] [Key varint]"
    style.fill: "#e3f2fd"
  }
}

# --------------------------------------------------------------------------------
# 3. WAL Frame & Header
# --------------------------------------------------------------------------------
wal_spec: {
  wal_header: {
    label: "WAL File Header | 32 Bytes"
    shape: sql_table
    magic: "u32: Magic Number" { tooltip: "0x377f0682 or 0x377f0683" }
    version: "u32: Format Version" { tooltip: "Currently 3007000" }
    page_size: "u32: Page Size" { tooltip: "Database page size" }
    checkpoint_seq: "u32: Checkpoint Sequence"
    salt_1: "u32: Salt 1"
    salt_2: "u32: Salt 2"
    checksum_1: "u32: Checksum 1"
    checksum_2: "u32: Checksum 2"
    style.fill: "#e1f5fe"
  }

  wal_frame: {
    label: "WAL Frame | 24B Header + Page"
    shape: sql_table
    f_pgno: "u32: Page Number" { tooltip: "DB Page number for this frame" }
    f_commit: "u32: Commit Size" { tooltip: "DB size in pages if this is a commit" }
    f_salt1: "u32: Salt 1"
    f_salt2: "u32: Salt 2"
    f_cksum1: "u32: Checksum 1"
    f_cksum2: "u32: Checksum 2"
    page_data: "u8[PageSize]: raw data" { style.fill: "#fffde7" }
    style.fill: "#fce4ec"
  }
}

# --------------------------------------------------------------------------------
# 4. AST Node Structures
# --------------------------------------------------------------------------------
ast: {
  expr_node: {
    label: "Expression Node (Expr)"
    shape: sql_table
    op: "u8: Opcode" { tooltip: "TK_* value" }
    aff: "u8: Affinity" { tooltip: "SQLITE_AFF_*" }
    flags: "u32: Flags" { tooltip: "EP_* bits" }
    pLeft: "Expr*: Left Child"
    pRight: "Expr*: Right Child"
    pList: "ExprList*: Args"
    token: "Token: Value/Name" { tooltip: "String or numeric literal" }
  }

  select_node: {
    label: "Select Node (Select)"
    shape: sql_table
    op: "u8: Operation" { tooltip: "TK_SELECT etc" }
    ecol: "int: Column Count"
    pEList: "ExprList*: Results"
    pSrc: "SrcList*: FROM"
    pWhere: "Expr*: WHERE"
    pGroupBy: "ExprList*: GROUP BY"
    pHaving: "Expr*: HAVING"
    pOrderBy: "ExprList*: ORDER BY"
    pLimit: "Expr*: LIMIT"
  }
}

# --------------------------------------------------------------------------------
# 5. VDBE Instruction Structure
# --------------------------------------------------------------------------------
vdbe: {
  op_struct: {
    label: "VDBE Opcode (VdbeOp)"
    shape: sql_table
    opcode: "u8: Op" { tooltip: "OP_OpenRead, OP_Column, etc." }
    p1: "i32: P1" { tooltip: "Usually cursor index or register" }
    p2: "i32: P2" { tooltip: "Usually jump target or register" }
    p3: "i32: P3" { tooltip: "General purpose parameter" }
    p4: "void*: P4" { tooltip: "Strings, KeyInfo, or pointers" }
    p5: "u16: P5" { tooltip: "Flags (e.g., OPFLAG_CLEARCACHE)" }
    zComment: "char*: Debug Comment"
    style.fill: "#f1f8e9"
  }
}

# --------------------------------------------------------------------------------
# 6. Record Format
# --------------------------------------------------------------------------------
records: {
  format: {
    label: "SQLite Record Storage Format"
    shape: sql_table
    hdr_size: "varint: Header Length" { style.fill: "#e0f2f1" }
    type_0: "varint: Serial Type 0" { tooltip: "Defines col 0 size/type" }
    type_n: "varint: Serial Type N"
    data_0: "u8[N]: Data 0" { style.fill: "#fff9c4" }
    data_n: "u8[M]: Data N" { style.fill: "#fff9c4" }
  }
  
  serial_types: {
    label: "Common Serial Types"
    shape: sql_table
    t0: "0: NULL"
    t1: "1: 8-bit Integer"
    t4: "4: 32-bit Integer"
    t7: "7: Float (64-bit)"
    t_text: "N (odd): Text" { tooltip: "Size = (N-13)/2" }
    t_blob: "N (even): BLOB" { tooltip: "Size = (N-12)/2" }
  }
}

# --------------------------------------------------------------------------------
# 7. Rollback Journal
# --------------------------------------------------------------------------------
journal: {
  header: {
    label: "Journal Header"
    shape: sql_table
    magic: "u32: 0xd9b5224f"
    page_count: "u32: Page Count"
    random_nonce: "u32: Nonce"
    db_page_size: "u32: DB Page Size"
    style.fill: "#ffebee"
  }
  
  page_record: {
    label: "Journal Page Record"
    shape: sql_table
    pgno: "u32: Original Page #"
    data: "u8[PageSize]: Pre-image"
    checksum: "u32: Checksum"
  }
}

# --------------------------------------------------------------------------------
# Connections & Logic
# --------------------------------------------------------------------------------

leaf_page.header_cell_count -> leaf_page.ptr_array: "Defines size"
leaf_page.ptr_array -> leaf_page.cell_content: "Points to offset"

records.format.type_0 -> records.serial_types: "Defines parsing"

vdbe.op_struct.opcode -> ast.expr_node: "Generated from"

wal_spec.wal_header -> wal_spec.wal_frame: "Followed by"

# Styling Global
***.style.font-size: 14
***.style.border-radius: 4

# Page Boundary Markers
leaf_page.style.stroke-width: 4
interior_page.style.stroke-width: 4
wal_spec.wal_frame.style.stroke-width: 4