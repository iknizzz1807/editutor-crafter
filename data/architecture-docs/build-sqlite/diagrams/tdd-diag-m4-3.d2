layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  memory_block: {
    style: {
      stroke-width: 1
      border-radius: 0
      font-size: 14
    }
  }
  header: {
    style: {
      stroke-width: 1
      border-radius: 0
      font-size: 14
      fill: "#9b59b6"
      font-color: white
      bold: true
    }
  }
  data_field: {
    style: {
      stroke-width: 1
      border-radius: 0
      font-size: 14
      fill: "#3498db"
      font-color: white
    }
  }
  padding: {
    style: {
      stroke-width: 1
      border-radius: 0
      font-size: 14
      fill: "#bdc3c7"
    }
  }
  ptr_block: {
    style: {
      stroke-width: 1
      border-radius: 0
      font-size: 14
      fill: "#f39c12"
      font-color: white
    }
  }
  pointer_link: {
    source-arrowhead.shape: circle
    style: {
      stroke: "#e67e22"
      stroke-width: 2
    }
  }
  highlight_change: {
    style: {
      stroke: "#e74c3c"
      stroke-width: 4
      bold: true
    }
  }
}

# --------------------------------------------------------------------------------
# LRU EVICTION ALGORITHM STATE TRANSITION
# --------------------------------------------------------------------------------

LRU_Logic: {
  label: "LRU CACHE STATE TRANSITION ENGINE"
  
  # --- LEFT SIDE: BEFORE STATE ---
  Step_01_Before: {
    label: "T0: CACHE AT CAPACITY (N=3)"
    style.fill: "#fdfefe"
    style.stroke: "#7f8c8d"
    
    Hash_Table: {
      shape: sql_table
      label: "Global Hash Map [Key -> *LRU_Node]"
      0x00: "Key: 'A' | Ptr: 0xFF10"
      0x08: "Key: 'B' | Ptr: 0xFF20"
      0x10: "Key: 'C' | Ptr: 0xFF30"
    }

    List_View: {
      label: "Doubly Linked List (Priority Queue)"
      
      Head: "HEAD" {shape: circle; style.fill: "#2ecc71"}
      Tail: "TAIL" {shape: circle; style.fill: "#95a5a6"}

      Node_A: {
        shape: sql_table
        label: "Node A (MRU) @ 0xFF10"
        prev: "NULL"
        data: "Value: 1024"
        next: "0xFF20"
      }

      Node_B: {
        shape: sql_table
        label: "Node B @ 0xFF20"
        prev: "0xFF10"
        data: "Value: 2048"
        next: "0xFF30"
      }

      Node_C: {
        shape: sql_table
        label: "Node C (LRU Victim) @ 0xFF30"
        prev: "0xFF20"
        data: "Value: 4096"
        next: "NULL"
        style.fill: "#ecf0f1"
        style.stroke: "#e74c3c"
        style.stroke-dash: 3
      }

      Head -> Node_A: "points to MRU" {class: pointer_link}
      Node_A <-> Node_B: "0xFF10 <-> 0xFF20" {class: pointer_link}
      Node_B <-> Node_C: "0xFF20 <-> 0xFF30" {class: pointer_link}
      Node_C -> Tail: "Current LRU Victim" {class: pointer_link}
    }
  }

  # --- TRANSITION ARROW ---
  Step_01_Before -> Step_02_After: "1. Evict Node 'C' (Tail)\n2. Alloc Node 'D' (0xFF40)\n3. Prepend 'D' to MRU Position" {
    style: {
      stroke-width: 4
      animated: true
      font-size: 14
      font-color: "#e74c3c"
      bold: true
    }
  }

  # --- RIGHT SIDE: AFTER STATE ---
  Step_02_After: {
    label: "T1: NEW ITEM 'D' INSERTED"
    style.fill: "#fdfefe"
    style.stroke: "#7f8c8d"

    Hash_Table: {
      shape: sql_table
      label: "Global Hash Map [Updated]"
      0x00: "Key: 'A' | Ptr: 0xFF10"
      0x08: "Key: 'B' | Ptr: 0xFF20"
      0x10: "Key: 'D' | Ptr: 0xFF40" {style.font-color: "#e74c3c"; style.bold: true}
    }

    List_View: {
      label: "Doubly Linked List (MRU Prepend)"

      Head: "HEAD" {shape: circle; style.fill: "#2ecc71"}
      Tail: "TAIL" {shape: circle; style.fill: "#95a5a6"}

      Node_D: {
        shape: sql_table
        label: "Node D (NEW MRU) @ 0xFF40"
        prev: "NULL"
        data: "Value: 8192"
        next: "0xFF10"
        style.stroke: "#e74c3c"
        style.stroke-width: 4
      }

      Node_A: {
        shape: sql_table
        label: "Node A @ 0xFF10"
        prev: "0xFF40" {style.font-color: "#e74c3c"; style.bold: true}
        data: "Value: 1024"
        next: "0xFF20"
      }

      Node_B: {
        shape: sql_table
        label: "Node B (LRU) @ 0xFF20"
        prev: "0xFF10"
        data: "Value: 2048"
        next: "NULL" {style.font-color: "#e74c3c"; style.bold: true}
      }

      Head -> Node_D: "New Head" {class: pointer_link; style.stroke: "#e74c3c"}
      Node_D <-> Node_A: "New link" {class: pointer_link; style.stroke: "#e74c3c"}
      Node_A <-> Node_B: "Persistent" {class: pointer_link}
      Node_B -> Tail: "New Tail" {class: pointer_link}
    }
    
    Evicted_Garbage: "Free'd Mem: 0xFF30 (Node C)" {
      style: {
        stroke: "#bdc3c7"
        fill: "#f2f2f2"
        font-color: "#bdc3c7"
        stroke-dash: 5
      }
    }
  }
}

# --------------------------------------------------------------------------------
# DETAILED NODE MEMORY LAYOUT (Intel Manual Grade)
# --------------------------------------------------------------------------------

Memory_Layout_Spec: {
  label: "LRU_NODE BINARY STRUCTURE DEFINITION (sizeof=64 bytes)"
  near: bottom-center

  # Memory Ruler - Byte Offsets
  Offsets: {
    grid-columns: 1
    addr_00: "0x00" {shape: text}
    addr_08: "0x08" {shape: text}
    addr_10: "0x10" {shape: text}
    addr_18: "0x18" {shape: text}
    addr_20: "0x20" {shape: text}
    addr_40: "0x40" {shape: text}
  }

  Layout: {
    grid-columns: 1
    Header: "vtable_ptr / Object Metadata" {class: header; width: 450; height: 40}
    Pointers: {
      grid-columns: 2
      prev: "prev_node_ptr (8B)" {class: ptr_block; height: 40}
      next: "next_node_ptr (8B)" {class: ptr_block; height: 40}
    }
    Key: "Key Hash / Identifier (8B)" {class: data_field; height: 40}
    Value: "Value Payload / Data Pointer (32B)" {class: data_field; height: 120}
    Padding: "Alignment Padding / Reserved (8B)" {class: padding; height: 40}
    
    # Cache Line Decoration
    style.stroke-dash: 5
    style.stroke: "#7f8c8d"
  }

  Offsets.addr_00 -> Layout.Header
  Offsets.addr_08 -> Layout.Pointers.prev
  Offsets.addr_10 -> Layout.Pointers.next
  Offsets.addr_18 -> Layout.Key
  Offsets.addr_20 -> Layout.Value
  Offsets.addr_40 -> Layout.Padding

  Annotation: |md
    ### Binary Interface Control
    - **Alignment Requirements**: All members must be aligned to **8-byte boundaries** for 64-bit architecture pointer atomicity.
    - **L1 Cache Optimization**: This structure is explicitly sized to **64 bytes**, occupying exactly **one L1 Cache Line**.
    - **Hardware Prefetch**: Continuous allocation in the hash table arena ensures hardware prefetchers can load neighboring nodes efficiently.
  | {
    near: Memory_Layout_Spec.Layout
  }
}

# Global legend and annotations
Legend: {
  near: top-right
  Header: "Object Header / Metadata" {class: header}
  Pointers: "Doubly-Linked Pointers" {class: ptr_block}
  Data: "Key/Value Payload" {class: data_field}
  Free: "Deallocated / Garbage" {style.fill: "#f2f2f2"; style.stroke: "#bdc3c7"}
}