direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 25
  }
}

classes: {
  header_box: {
    style: {
      fill: "#6c4a7c"
      font-color: white
      bold: true
      stroke-width: 2
      border-radius: 0
    }
  }
  data_box: {
    style: {
      fill: "#2a4a6f"
      font-color: white
      border-radius: 2
      stroke-width: 1
    }
  }
  state_node: {
    shape: circle
    style: {
      stroke-width: 2
      bold: true
      font-size: 14
    }
  }
  logic_gate: {
    shape: diamond
    style: {
      fill: "#5a7a9f"
      font-color: white
      font-size: 12
    }
  }
  memory_segment: {
    style: {
      stroke: "#ffa500"
      stroke-dash: 3
      fill: "#fff4e6"
      font-color: "#d97706"
    }
  }
}

# ---------------------------------------------------------------------------------------
# MILESTONE 6: SECONDARY INDEXES (B-TREE STRUCTURE)
# ---------------------------------------------------------------------------------------
m6_secondary_indexes: {
  label: "Milestone 6: Secondary Index B-Tree & Pointer Layout"
  
  index_root: {
    label: "Index Root Page (Page 2)"
    class: header_box
    
    layout: |md
      | Offset | Field | Size |
      | :--- | :--- | :--- |
      | 0x00 | Page Type (0x0D) | 1B |
      | 0x01 | Freeblock Offset | 2B |
      | 0x03 | Cell Count | 2B |
      | 0x05 | Content Start | 2B |
      | 0x07 | Fragmented Bytes | 1B |
    |
    
    cell_ptr_array: "Cell Pointer Array [0x08 ... 0x0E]" {
      class: memory_segment
    }
  }

  index_interior: {
    label: "Index Interior Node (Page 5)"
    class: data_box
    content: "keys: [alice@.., bob@..]\nptrs: [page 10, page 12, page 15]"
  }

  index_leaf: {
    label: "Index Leaf Page (Page 10)"
    class: data_box
    records: |md
      **Leaf Cell Structure**
      - Length: Varint
      - RowID: Varint (Pointer to Table)
      - Key: String (Indexed Column)
    |
  }

  table_btree: {
    label: "Primary Table B-Tree (Clustered)"
    style.fill: "#3d2d4a"
    style.font-color: white
    table_leaf: "Leaf: rowid=1 → 'Alice|25|5000'\nLeaf: rowid=5 → 'Bob|30|7500'"
  }

  index_root -> index_interior: "traverse(key)"
  index_interior -> index_leaf: "binary_search"
  index_leaf -> table_btree: "seek_rowid(5)" {
    style: {
      stroke: "#ff6b6b"
      stroke-dash: 5
      stroke-width: 2
    }
  }
}

# ---------------------------------------------------------------------------------------
# MILESTONE 7: COST-BASED QUERY OPTIMIZER
# ---------------------------------------------------------------------------------------
m7_query_planner: {
  label: "Milestone 7: Query Planning & Cost Estimation"
  direction: right

  query_input: "SELECT name FROM users\nWHERE age > 25 AND city = 'NY'" {
    shape: parallelogram
    style.fill: "#1e3a5f"
    style.font-color: white
  }

  rewrite: "Optimizer Phase 1: Rewrite\n- Predicate Pushdown\n- Constant Folding" {
    class: data_box
  }

  plan_candidates: {
    label: "Candidate Physical Plans"
    class: data_box
    list: |md
      1. Table Scan (users)
      2. Index Scan (idx_age) + Filter
      3. Index Scan (idx_city) + Filter
    |
  }

  cost_estimator: {
    label: "Cost Estimator (VDBE Instruction Count)"
    class: data_box
    formula: "Cost = (Page_Reads * IO_Weight) + (Rows * CPU_Weight)"
  }

  chooser: "MIN(Plan_Cost)" {
    class: logic_gate
  }

  final_plan: "Selected Plan: SEARCH users USING INDEX idx_city" {
    style.fill: "#1a4a3f"
    style.font-color: white
    style.bold: true
    style.double-border: true
  }

  query_input -> rewrite -> plan_candidates -> cost_estimator -> chooser -> final_plan
}

# ---------------------------------------------------------------------------------------
# MILESTONE 8: TRANSACTION STATE & LOCKING
# ---------------------------------------------------------------------------------------
m8_transactions: {
  label: "Milestone 8: Transaction Isolation & Lock Lifecycle"
  
  START: { label: "● IDLE"; class: state_node; style.fill: "#2a5a4a"; style.font-color: white }
  READING: { label: "SHARED"; class: state_node; style.fill: "#2a5a5a"; style.font-color: white }
  MODIFYING: { label: "RESERVED"; class: state_node; style.fill: "#5a4a2a"; style.font-color: white }
  PENDING: { label: "PENDING"; class: state_node; style.fill: "#7a4a2a"; style.font-color: white }
  EXCLUSIVE: { label: "EXCLUSIVE"; class: state_node; style.fill: "#5a2a2a"; style.font-color: white }

  START -> READING: "1. BEGIN"
  READING -> MODIFYING: "2. write_op (pager_write)"
  MODIFYING -> PENDING: "3. COMMIT (flush_wal)"
  PENDING -> EXCLUSIVE: "4. acquire_exclusive_lock"
  EXCLUSIVE -> START: "5. release_all_locks"
  
  MODIFYING -> START: "ROLLBACK (truncate_journal)" {
    style.stroke: red
    style.stroke-dash: 2
  }

  lock_spec: |md
    **Lock Invariants**
    - SHARED: Many readers, 0 writers.
    - RESERVED: 1 writer (buffer), many readers.
    - EXCLUSIVE: 1 writer, 0 readers.
  | {
    near: EXCLUSIVE
    style.font-size: 11
  }
}

# ---------------------------------------------------------------------------------------
# MILESTONE 9: WAL (WRITE-AHEAD LOGGING)
# ---------------------------------------------------------------------------------------
m9_wal_mode: {
  label: "Milestone 9: WAL Architecture & Memory-Mapped Index"

  wal_file: {
    label: "WAL File (database-wal)"
    class: data_box
    header: "WAL Header: Magic=0x377f0682"
    f1: "Frame 1: Pg 32 | Salt | Checksum"
    f2: "Frame 2: Pg 104 | Salt | Checksum"
  }

  shm_index: {
    label: "WAL Index (database-shm)"
    class: memory_segment
    mapping: "mmap(Shared Memory Index)\nPage 32 → Frame 1\nPage 104 → Frame 2"
  }

  checkpoint: {
    label: "Checkpointer Thread"
    style.fill: "#4a3a2a"
    style.font-color: white
  }

  writer: "B-Tree Writer" { shape: person }
  reader: "B-Tree Reader" { shape: person }

  writer -> wal_file: "log_append(frame)"
  reader -> shm_index: "shm_get_frame(pgno)"
  shm_index -> wal_file: "read_offset(f.offset)"
  checkpoint -> wal_file: "checkpoint_all"
  checkpoint -> "Main DB File": "fsync(merged_pages)"
}

# ---------------------------------------------------------------------------------------
# MILESTONE 10: AGGREGATE ENGINE
# ---------------------------------------------------------------------------------------
m10_aggregates: {
  label: "Milestone 10: Aggregate Execution Engine"

  vdbe_op: "OP_Next: Row Loop" { class: header_box }
  
  accumulators: {
    label: "Accumulator Context"
    class: data_box
    slots: |md
      - Reg[1]: count (long)
      - Reg[2]: sum (double)
      - Reg[3]: running_avg (double)
    |
  }

  step_fn: "OP_Step(AggFunction)\nUpdate slots for current row" {
    style.fill: "#3a5a4a"
    style.font-color: white
  }

  finalize: "OP_Finalize\nCompute result from slots" {
    class: logic_gate
  }

  vdbe_op -> accumulators: "next_row"
  accumulators -> step_fn: "agg_step()"
  step_fn -> finalize: "EOF reached"
}

# ---------------------------------------------------------------------------------------
# MILESTONE 11: JOIN STRATEGIES
# ---------------------------------------------------------------------------------------
m11_joins: {
  label: "Milestone 11: Join Engine Implementation"

  planner: "Join Order Optimizer\n(N! complexity check)" { class: header_box }
  
  nest_loop: "Nested Loop Join (NLJ)\nOuter Scan -> Inner Index Seek" { class: data_box }
  
  cross_product: "Cross Product\nFull Cartesian (Warning: High Cost)" { 
    class: data_box
    style.fill: "#5a2a2a" 
  }

  planner -> nest_loop: "Ideal: Inner index exists"
  planner -> cross_product: "Fallback: No join condition"
}

# ---------------------------------------------------------------------------------------
# SUMMARY TABLE
# ---------------------------------------------------------------------------------------
summary_note: {
  label: |md
    ### Build-SQLite Implementation Summary
    | Milestone | Feature | Component |
    | :--- | :--- | :--- |
    | **m6** | Secondary Indexes | B-Tree / Payload / RowID |
    | **m7** | Query Planner | Cost Estimator / VDBE |
    | **m8** | Transactions | Pager Lock Manager / ACID |
    | **m9** | WAL Mode | Shared Memory / Checkpoint |
    | **m10** | Aggregates | State Accumulators / Step / Final |
    | **m11** | JOINs | Join Order / Nested Loops |
  |
  shape: rectangle
  near: m11_joins
  style: {
    fill: "#fff9c4"
    stroke: "#fbc02d"
    stroke-width: 2
    double-border: true
  }
}