direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- CLASSES FOR SEMANTIC STYLING ---
classes: {
  node_header: {
    style: {
      fill: "#E1D5E7" # Purple
      stroke: "#9673A6"
      bold: true
    }
  }
  data_field: {
    style: {
      fill: "#DAE8FC" # Blue
      stroke: "#6C8EBF"
    }
  }
  pointer_field: {
    style: {
      fill: "#FFE6CC" # Orange
      stroke: "#D79B00"
    }
  }
  metadata_field: {
    style: {
      fill: "#D5E8D4" # Green
      stroke: "#82B366"
    }
  }
  leaf_link: {
    style: {
      stroke: "#D79B00"
      stroke-width: 4
      stroke-dash: 5
      animated: true
    }
  }
}

btree_comparison: "B-Tree vs B+Tree Structure Comparison" {
  style.stroke-width: 0

  # ---------------------------------------------------------
  # SECTION 1: STANDARD B-TREE
  # Keys and Data stored in ALL nodes.
  # ---------------------------------------------------------
  btree: "Standard B-Tree (Data in Internal Nodes)" {
    internal: {
      shape: sql_table
      style.fill: white
      header: "Internal Node (Page 0x104)" {class: node_header}
      "00": "Flags: 0x01 (Internal)" {class: metadata_field}
      "04": "Pointer 0: 0x200" {class: pointer_field}
      "08": "Key 10: [Index Entry]" {style.bold: true}
      "12": "Data 10: [Payload Ptr]" {class: data_field}
      "16": "Pointer 1: 0x300" {class: pointer_field}
      "20": "Key 20: [Index Entry]" {style.bold: true}
      "24": "Data 20: [Payload Ptr]" {class: data_field}
      "28": "Pointer 2: 0x400" {class: pointer_field}
    }

    leaf_left: {
      shape: sql_table
      header: "Leaf Node (Page 0x200)" {class: node_header}
      "00": "Key 05" {style.bold: true}
      "04": "Data 05: [Payload]" {class: data_field}
    }

    leaf_right: {
      shape: sql_table
      header: "Leaf Node (Page 0x300)" {class: node_header}
      "00": "Key 15" {style.bold: true}
      "04": "Data 15: [Payload]" {class: data_field}
    }

    internal."04" -> leaf_left.header: "Child < 10"
    internal."16" -> leaf_right.header: "10 < Child < 20"
  }

  # ---------------------------------------------------------
  # SECTION 2: B+TREE (Optimized for Range Scans)
  # Internal nodes: Keys only. Leaf nodes: All Keys + Data + Next Ptr.
  # ---------------------------------------------------------
  bplus_tree: "B+Tree (Data in Leaf Nodes Only)" {
    internal: {
      shape: sql_table
      header: "Internal Node (Page 0xA01)" {class: node_header}
      "00": "Flags: 0x05 (Index)" {class: metadata_field}
      "04": "Key 100" {style.bold: true}
      "08": "Ptr Left: 0xB01" {class: pointer_field}
      "12": "Key 200" {style.bold: true}
      "16": "Ptr Mid: 0xB02" {class: pointer_field}
      "20": "Ptr Right: 0xB03" {class: pointer_field}
    }

    leaf_1: {
      shape: sql_table
      header: "Leaf Node (Page 0xB01)" {class: node_header}
      "00": "Key 10" {style.bold: true}
      "04": "Data 10" {class: data_field}
      "08": "Key 20" {style.bold: true}
      "12": "Data 20" {class: data_field}
      "16": "Next Leaf: 0xB02" {class: pointer_field}
    }

    leaf_2: {
      shape: sql_table
      header: "Leaf Node (Page 0xB02)" {class: node_header}
      "00": "Key 110" {style.bold: true}
      "04": "Data 110" {class: data_field}
      "08": "Key 120" {style.bold: true}
      "12": "Data 120" {class: data_field}
      "16": "Next Leaf: 0xB03" {class: pointer_field}
    }

    leaf_3: {
      shape: sql_table
      header: "Leaf Node (Page 0xB03)" {class: node_header}
      "00": "Key 210" {style.bold: true}
      "04": "Data 210" {class: data_field}
      "08": "Key 220" {style.bold: true}
      "12": "Data 220" {class: data_field}
      "16": "Next Leaf: NULL" {class: pointer_field}
    }

    # Navigation Pointers
    internal."08" -> leaf_1.header
    internal."16" -> leaf_2.header
    internal."20" -> leaf_3.header

    # Sequential Linked List Pointers (The "Plus" in B+Tree)
    leaf_1."16" -> leaf_2.header: {class: leaf_link}
    leaf_2."16" -> leaf_3.header: {class: leaf_link}
  }
}

# --- ROOT LEVEL POSITIONING ---
# Moved out of btree_comparison container to fix compiler error
legend: {
  near: bottom-right
  h: Header {class: node_header}
  d: Data/Payload {class: data_field}
  p: Child Pointer {class: pointer_field}
  m: Metadata {class: metadata_field}
}

comparison_text: |md
  ### Key Differences for Implementation:
  1. **Storage Efficiency**: B+Tree internal nodes store more keys per page because they lack data pointers, reducing tree height.
  2. **Scan Performance**: B+Tree supports $O(N)$ sequential access via the Leaf-Link pointers. B-Tree requires an in-order traversal.
  3. **Query Latency**: B-Tree can find a key in an internal node early. B+Tree always descends to the leaf.
| {
  near: bottom-center
  style.font-size: 14
}