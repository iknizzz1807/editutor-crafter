direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL STYLES ---
classes: {
  header_node: {
    style: {
      fill: "#6b4fbb"
      font-color: white
      bold: true
    }
  }
  logic_gate: {
    shape: diamond
    style: {
      fill: "#fff4dd"
      stroke: "#d4a017"
    }
  }
  data_storage: {
    shape: cylinder
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
    }
  }
  process_step: {
    shape: rectangle
    style: {
      border-radius: 5
      fill: "#f5f5f5"
    }
  }
}

# --- MILESTONE 8: QUERY PLANNING ---
query_planning: {
  label: "Milestone 8: Query Planner Cost Model & Optimization"
  
  cost_model: {
    label: "Cost Estimation Model"
    
    factors: {
      grid-columns: 3
      io: "I/O Cost\n(Page Reads)" {
        style.fill: "#bbdefb"
        tooltip: "Weight: 25.0 per page"
      }
      cpu: "CPU Cost\n(Row Ops)" {
        style.fill: "#c8e6c9"
        tooltip: "Weight: 1.2 per row"
      }
      fixed: "Fixed Cost\n(Setup)" {
        style.fill: "#ffecb3"
        tooltip: "Weight: 0.5 static"
      }
    }

    formula: "Total Cost = (N_PAGES * 25) + (N_ROWS * 1.2) + 0.5" {
      shape: parallelogram
      style.fill: "#fff9c4"
    }

    candidates: {
      seq: "Sequential Scan\nCost: 1000" { style.fill: "#ffcdd2" }
      idx: "Index Scan\nCost: 150" { style.fill: "#d1c4e9" }
      cover: "Index Only Scan\nCost: 80" { style.fill: "#c8e6c9" }
    }

    factors -> formula
    formula -> candidates.seq: "High Selectivity"
    formula -> candidates.idx: "Medium Selectivity"
    formula -> candidates.cover: "Optimal"
  }

  index_decision: {
    label: "Index Selection Logic"
    
    root: "WHERE clause\npresent?" { class: logic_gate }
    has_idx: "Column has\nindex?" { class: logic_gate }
    select: "Selectivity\n< 10%?" { class: logic_gate }

    scan_full: "Sequential Scan\n(Full Table)" { style.fill: "#ef9a9a" }
    scan_idx: "Index Scan\n(Range)" { style.fill: "#a5d6a7" }
    scan_cover: "Index Only Scan\n(Covering)" { style.fill: "#81c784"; style.double-border: true }

    root -> has_idx: "Yes"
    root -> scan_full: "No"
    has_idx -> select: "Yes"
    has_idx -> scan_full: "No"
    select -> scan_cover: "Yes"
    select -> scan_idx: "No"
  }
}

# --- MILESTONE 9: TRANSACTIONS ---
transactions: {
  label: "Milestone 9: Transaction Lifecycle & WAL Frames"

  state_machine: {
    label: "ACID State Transitions"
    
    NONE: { shape: circle; style.fill: "#eeeeee" }
    ACTIVE: { label: "ACTIVE\n(Open Handle)"; style.fill: "#c8e6c9" }
    COMMITTING: { label: "COMMITTING\n(Sync Phase)"; style.fill: "#fff9c4" }
    ROLLING_BACK: { label: "ROLLBACK\n(Undo Phase)"; style.fill: "#ffcdd2" }
    
    NONE -> ACTIVE: "BEGIN [DEFERRED|IMMEDIATE|EXCLUSIVE]"
    ACTIVE -> ACTIVE: "DML Statements (INSERT/UPDATE/DELETE)"
    ACTIVE -> COMMITTING: "COMMIT Request"
    ACTIVE -> ROLLING_BACK: "ROLLBACK / Critical Error"
    COMMITTING -> NONE: "WAL Sync Success"
    ROLLING_BACK -> NONE: "Journal Replay / Memory Clear"
  }

  wal_layout: {
    label: "WAL Frame Memory Layout (Intel Manual Quality)"
    
    frame_header: {
      shape: sql_table
      style.fill: "#e8eaf6"
      label: "WAL Frame Header (24 Bytes)"
      
      00: "Page Number" {constraint: "uint32"}
      04: "Commit Size" {constraint: "uint32"}
      08: "Salt 1" {constraint: "uint32"}
      12: "Salt 2" {constraint: "uint32"}
      16: "Checksum 1" {constraint: "uint32"}
      20: "Checksum 2" {constraint: "uint32"}
    }

    page_data: "Page Payload\n(4096 Bytes)" {
      shape: rectangle
      style.fill: "#fffde7"
      style.stroke-dash: 5
    }
    
    size_ann: "Total Frame Size: 4120 Bytes" {
      shape: text
      style.font: mono
    }

    frame_header -> page_data: "Precedes"
  }
}

# --- MILESTONE 10: WAL RECOVERY ---
recovery_checkpoint: {
  label: "Milestone 10: Checkpoint & Recovery"

  checkpoint_proc: {
    direction: down
    1: "Grab EXCLUSIVE lock on WAL-Index" { class: process_step }
    2: "Sync WAL frames to Disk (fsync)" { class: process_step }
    3: "Copy pages from WAL to main DB" { class: process_step }
    4: "Update DB Header (Change Counter)" { class: process_step }
    5: "Truncate WAL / Reset Checkpointer" { class: process_step }

    1 -> 2 -> 3 -> 4 -> 5
  }

  recovery_logic: {
    start: "Startup" { shape: circle }
    is_wal: "WAL File\nPresent?" { class: logic_gate }
    salt_match: "Salt Matches\nDB Header?" { class: logic_gate }
    valid: "Valid\nChecksum?" { class: logic_gate }
    
    start -> is_wal
    is_wal -> salt_match: "Yes"
    is_wal -> normal: "No"
    salt_match -> valid: "Yes"
    salt_match -> normal: "No (Stale)"
    valid -> apply: "Yes"
    valid -> normal: "No (Corrupt)"
    
    apply: "Apply Log to DB" { style.fill: "#a5d6a7" }
    normal: "Normal Boot" { style.fill: "#bbdefb" }
    apply -> normal
  }
}

# --- MILESTONE 11: AGGREGATES & JOINS ---
aggregates_joins: {
  label: "Milestone 11: Aggregation & Joins"

  hash_join: {
    label: "Hash Join Architecture"
    
    build: {
      label: "Build Phase"
      small_tab: "Inner Table\n(Smaller)" { class: data_storage }
      hash_func: "Hash(Key)" { shape: parallelogram }
      hash_map: "In-Memory Hash Map\n{Key -> RowPtr}" { style.fill: "#fff9c4" }
      
      small_tab -> hash_func -> hash_map
    }

    probe: {
      label: "Probe Phase"
      large_tab: "Outer Table\n(Larger)" { class: data_storage }
      lookup: "Key Match?" { class: logic_gate }
      result: "Join Result" { style.fill: "#c8e6c9" }
      
      large_tab -> lookup
      lookup -> result: "Match"
    }

    build.hash_map -> probe.lookup: "Probe"
  }

  agg_sm: {
    label: "Aggregation State Machine"
    
    INIT -> ACCUMULATE: "First Row"
    ACCUMULATE -> ACCUMULATE: "Next Row (Same Group)"
    ACCUMULATE -> FINALIZE: "Group Change / EOF"
    FINALIZE -> OUTPUT: "Compute final() (e.g., AVG = sum/count)"
    OUTPUT -> INIT: "Reset for next group"
  }
}

# --- SYSTEM ARCHITECTURE ---
sqlite_arch: {
  label: "SQLite Complete System Architecture"
  
  frontend: {
    label: "Frontend (Compiler)"
    tokenize: "Tokenizer" { class: process_step }
    parse: "Parser (Lemon)" { class: process_step }
    codegen: "Code Generator" { class: process_step }
    tokenize -> parse -> codegen
  }

  backend: {
    label: "Backend (Virtual Machine)"
    vdbe: "VDBE (Bytecode Engine)" { style.fill: "#ffe0b2" }
    btree: "B-Tree Manager" { style.fill: "#e1bee7" }
    pager: "Pager (Buffer Pool)" { style.fill: "#c5cae9" }
    os: "OS Interface (VFS)" { style.fill: "#b2dfdb" }
    
    vdbe -> btree -> pager -> os
  }

  storage: {
    db: "main.sqlite" { class: data_storage }
    wal: "main.wal" { class: data_storage }
    shm: "main.shm" { class: data_storage }
  }

  frontend.codegen -> backend.vdbe: "OpCodes"
  backend.os -> storage.db
  backend.os -> storage.wal
}

# --- FINAL SUMMARY ---
# FIXED: Changed 'near: sqlite_arch' to 'near: bottom-center' to comply with ELK layout rules.
summary_notes: |'md
  ### Build-SQLite Project Milestones
  | Milestone | Focus | Key Components |
  | :--- | :--- | :--- |
  | **M8** | Planning | Cost Estimator, Join Selection |
  | **M9** | Atomicity | WAL Frame Headers, ACID States |
  | **M10** | Durability | Checkpointing, Crash Recovery |
  | **M11** | Analytics | Hash Joins, Aggregation States |
'| {
  near: bottom-center
}