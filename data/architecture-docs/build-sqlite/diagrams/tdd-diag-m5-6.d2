vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 40
  }
}

# ----------------------------------------------------------------------------
# RECORD SERIALIZATION FORMAT (MILESTONE 5-6)
# Specification for Row Storage in B-Tree Leaf Cells
# ----------------------------------------------------------------------------

MemoryLayoutWrapper: {
  label: "SQLite B-Tree Record Format (Milestone 6)"
  style: {
    stroke-width: 2
    fill: "#fcfcfc"
    font-size: 18
    bold: true
  }

  RowFormat: {
    grid-columns: 3
    grid-gap: 0
    style.stroke-width: 0
    
    # ------------------------------------------------------------------------
    # TABLE HEADER
    # ------------------------------------------------------------------------
    header_offset: "BYTE OFFSET" {
      style: { font-size: 14; bold: true; border-radius: 0; fill: "#5e2ca5"; font-color: white }
    }
    header_field: "FIELD ARCHITECTURE / SEGMENT DESCRIPTION" {
      style: { font-size: 14; bold: true; border-radius: 0; fill: "#5e2ca5"; font-color: white }
    }
    header_size: "SIZE" {
      style: { font-size: 14; bold: true; border-radius: 0; fill: "#5e2ca5"; font-color: white }
    }

    # --- ROW METADATA (Purple: Header/Meta) ---
    offset_00: "0x00" { shape: text; style.font: mono }
    PayloadLen: "Payload Length (Varint)" {
      tooltip: "Total size of the cell excluding RowID. Encoded as a Varint (1-9 bytes)."
      style: { fill: "#d1b3ff"; stroke-width: 2; border-radius: 0 } 
    }
    size_00: "1-9 bytes" { shape: text; style.font: mono }

    offset_01: "0x..." { shape: text; style.font: mono }
    RowID: "RowID / Integer Primary Key" {
      tooltip: "Unique identifier for the row (B-Tree Key). Used for fast lookups."
      style: { fill: "#d1b3ff"; stroke-width: 2; border-radius: 0 } 
    }
    size_01: "1-9 bytes" { shape: text; style.font: mono }

    # --- RECORD HEADER (Purple: Header/Meta) ---
    offset_02: "0x..." { shape: text; style.font: mono }
    HeaderSize: "Record Header Size (Varint)" {
      tooltip: "Total size of the Record Header, including this field."
      style: { fill: "#d1b3ff"; stroke-width: 2; border-radius: 0 } 
    }
    size_02: "1-9 bytes" { shape: text; style.font: mono }

    offset_03: "0x..." { shape: text; style.font: mono }
    SerialTypes: "Serial Type Codes [Col 1..N]" {
      tooltip: "Array of Varints mapping data types to columns. Length depends on column count."
      style: { fill: "#d1b3ff"; stroke-dash: 2; border-radius: 0 } 
    }
    size_03: "N bytes" { shape: text; style.font: mono }

    # --- CACHE LINE BOUNDARY ---
    cl_boundary_L: " " { style.stroke-width: 0 }
    CacheLine1: "---------------- L1 CACHE LINE BOUNDARY (64B) ----------------" {
      style: {
        stroke-width: 0
        font-color: "#d32f2f"
        bold: true
        font-size: 12
      }
    }
    cl_boundary_R: " " { style.stroke-width: 0 }

    # --- PAYLOAD DATA (Blue: Data) ---
    offset_04: "0x40" { shape: text; style.font: mono }
    Col1: "Column 1 Data (Fixed: INT64)" {
      tooltip: "Stored as 8-byte big-endian integer. Corresponds to serial type 6."
      style: { fill: "#b3d9ff"; stroke-width: 2; border-radius: 0 } 
    }
    size_04: "8 bytes" { shape: text; style.font: mono }

    offset_05: "0x48" { shape: text; style.font: mono }
    Col2: "Column 2 Data (Var-length: TEXT)" {
      tooltip: "UTF-8 Encoded string data. Length calculated from serial type code."
      style: { fill: "#b3d9ff"; stroke-width: 2; border-radius: 0 } 
    }
    size_05: "Varies" { shape: text; style.font: mono }

    # --- POINTERS (Orange: Pointer) ---
    offset_06: "0x..." { shape: text; style.font: mono }
    OverflowPtr: "Overflow Page Pointer" {
      tooltip: "4-byte page number of the first page in the overflow chain."
      style: { fill: "#ffd9b3"; stroke-width: 2; border-radius: 0 } 
    }
    size_06: "4 bytes" { shape: text; style.font: mono }

    # --- ALIGNMENT & FREE SPACE (Gray/Green) ---
    offset_07: "0x..." { shape: text; style.font: mono }
    Padding: "Alignment Padding" {
      tooltip: "Zero-filled bytes used to align the next record to CPU word boundaries."
      style: { fill: "#e0e0e0"; stroke-dash: 3; border-radius: 0 } 
    }
    size_07: "0-7 bytes" { shape: text; style.font: mono }

    offset_08: "0x..." { shape: text; style.font: mono }
    FreeSpace: "Available Cell Space" {
      tooltip: "Unused space within the cell reserved for row growth or updates."
      style: { fill: "#b3ffb3"; font-color: "#2e7d32"; border-radius: 0 } 
    }
    size_08: "Remaining" { shape: text; style.font: mono }

    # --- PAGE END BOUNDARY ---
    pg_boundary_L: " " { style.stroke-width: 0 }
    PageBoundary: "================ PAGE BOUNDARY (4096B) ================" {
      style: {
        stroke-width: 0
        bold: true
        font-size: 14
        font-color: "#2c3e50"
      }
    }
    pg_boundary_R: " " { style.stroke-width: 0 }
  }
}

# Implementation Details Summary
# Fixed using |'md ... '| to allow internal pipe symbols
ImplementationDetails: |'md
  ### Serialization Specification (Milestone 6)
  
  **1. Variable Length Integers (Varints)**
  - SQLite Varints are 1-9 bytes. 
  - The MSB of the first 8 bytes is a continuation bit. 
  - The 9th byte carries 8 bits of payload.
  
  **2. Serial Type Code Mapping**
  | Code | Type | Width |
  | :--- | :--- | :--- |
  | 0 | NULL | 0 |
  | 1 | Int8 | 1 |
  | 2 | Int16 | 2 |
  | 3 | Int24 | 3 |
  | 4 | Int32 | 4 |
  | 5 | Int48 | 6 |
  | 6 | Int64 | 8 |
  | 7 | Float64 | 8 |
  | 8 | Const 0 | 0 |
  | 9 | Const 1 | 0 |
  | N >= 12 | BLOB/TEXT | (N-12)/2 or (N-13)/2 |
  
  **3. Overflow Mechanism**
  Spills to overflow pages if `PayloadLength > MaxLocal`.
  - `MaxLocal = (PageSize - 35)`
'| {
  near: bottom-left
  style.font-size: 12
}

# Visualization Legend
Legend: {
  near: bottom-right
  Header: "Header/Meta" { style.fill: "#d1b3ff" }
  Data: "Column Data" { style.fill: "#b3d9ff" }
  Pointer: "Pointers" { style.fill: "#ffd9b3" }
  Free: "Unused Space" { style.fill: "#b3ffb3" }
  Padding: "Padding" { style.fill: "#e0e0e0" }
}