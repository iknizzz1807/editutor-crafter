layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# VDBE ENGINE ARCHITECTURE SPECIFICATION
# Implementation-grade technical manual for Virtual Machine state and query execution.

vdbe_engine: {
  label: "VDBE Execution Engine (Virtual Machine)"
  style: {
    stroke-width: 2
    stroke: "#512da8" # Purple Header
  }

  vm_structure: {
    label: "VDBE VM Register & Cursor Model"
    style.fill: "#f8f9fa"
    
    header: "Program (Opcodes)" {
      shape: rectangle
      style.fill: "#ce93d8" # Purple Header
    }
    
    pc: "PC (u32)" {
      shape: circle
      style.fill: "#ffb74d" # Orange Pointer/PC
    }
    
    registers: "Registers r[N]\n(Mem Objects)" {
      shape: rectangle
      style.fill: "#90caf9" # Blue Data
    }
    
    cursors: "Cursor Array\n(B-Tree I/O)" {
      shape: rectangle
      style.fill: "#ffcc80" # Orange Cursors
    }
    
    cache: "Column Cache" {
      shape: rectangle
      style.fill: "#f3e5f5"
    }

    header -> pc: "fetch"
    pc -> registers: "ALU/Storage"
    pc -> cursors: "seek/next"
    cursors -> cache: "row-decode"
  }

  instruction_set: {
    label: "Instruction Set Architecture (ISA)"
    grid-columns: 2
    
    class_const: {
      label: |md
        ### Constants
        - **OP_Integer**: P1=val, P2=dest
        - **OP_String8**: P4=string, P2=dest
        - **OP_Null**: P2=dest
      |
      style.fill: "#c8e6c9"
    }
    
    class_io: {
      label: |md
        ### Data I/O
        - **OP_Column**: P1=cursor, P2=col, P3=dest
        - **OP_MakeRecord**: P1..P1+P2 -> P3
        - **OP_ResultRow**: P1=start, P2=count
      |
      style.fill: "#bbdefb"
    }
    
    class_flow: {
      label: |md
        ### Control Flow
        - **OP_Goto**: Jump to P2
        - **OP_Rewind**: Move P1 to start
        - **OP_Next**: P1++, jump P2 if !EOF
      |
      style.fill: "#ffccbc"
    }
    
    class_logic: {
      label: |md
        ### Comparison
        - **OP_Eq / OP_Ne**: P1 == P3 ? jump P2
        - **OP_Lt / OP_Le**: P1 < P3 ? jump P2
        - **OP_IdxGt**: Index comparison
      |
      style.fill: "#f8bbd0"
    }
  }

  execution_trace: {
    label: "Trace: SELECT id, name FROM users WHERE age > 25"
    
    s1: "0: OP_OpenRead (0, root=2)" { style.fill: "#e3f2fd" }
    s2: "1: OP_Integer (25, r[1])" { style.fill: "#e8f5e9" }
    s3: "2: OP_Rewind (0, @10)" { style.fill: "#fff3e0" }
    s4: "3: OP_Column (0, age, r[2])" { style.fill: "#fce4ec" }
    s5: "4: OP_Le (r[2], @9, r[1])" { style.fill: "#fff9c4" }
    s6: "5: OP_Column (0, id, r[3])" { style.fill: "#fce4ec" }
    s7: "6: OP_Column (0, name, r[4])" { style.fill: "#fce4ec" }
    s8: "7: OP_ResultRow (r[3], 2)" { style.fill: "#e1bee7" }
    s9: "8: OP_Next (0, @3)" { style.fill: "#b2dfdb" }
    s10: "9: OP_Halt (0, 0)" { style.fill: "#cfd8dc" }

    s1 -> s2 -> s3 -> s4 -> s5
    s5 -> s6: "age > 25" { style.stroke: green; style.stroke-width: 2 }
    s5 -> s9: "skip" { style.stroke: red; style.stroke-dash: 3 }
    s6 -> s7 -> s8 -> s9
    s9 -> s4: "loop" { style.animated: true }
    s9 -> s10: "EOF"
  }
}

btree_layout: {
  label: "B-Tree Physical Page Layout (Standard 4096B Page)"
  style.stroke-width: 4 # Page boundary bold
  
  leaf_page: {
    label: "Table B-Tree Leaf Node (Flag 0x0D)"
    
    page_header: {
      label: |md
        **Header (8 Bytes)**
        - `+0`: Page Type (0x0D)
        - `+1`: Freeblock Offset (u16)
        - `+3`: Cell Count (u16)
        - `+5`: Cell Content Offset (u16)
      |
      style.fill: "#ce93d8" # Header Purple
    }
    
    cell_pointers: "Cell Pointer Array [u16 * Count]" {
      style.fill: "#ffcc80" # Pointers Orange
    }
    
    unallocated: "Unallocated Free Space" {
      style.stroke-dash: 5
      style.fill: "#bdbdbd" # Padding Gray
    }
    
    cell_data: {
      label: |md
        **Cell Data Area (Descending)**
        - [Payload Size (Varint)]
        - [RowID (Varint)]
        - [Record Data...]
      |
      style.fill: "#90caf9" # Data Blue
    }
    
    page_header -> cell_pointers -> unallocated -> cell_data
  }

  interior_page: {
    label: "Table B-Tree Interior Node (Flag 0x05)"
    
    int_header: "Header (12 Bytes)\n+8: Right Child (u32)" {
      style.fill: "#ce93d8"
    }
    
    int_cells: "Interior Cells\n[Left-Child (u32) | Key (Varint)]" {
      style.fill: "#90caf9"
    }
    
    int_header -> int_cells
  }
}

record_serialization: {
  label: "SQLite Record Format & Serial Types"
  
  physical_record: {
    label: "Record Byte Stream"
    
    h_len: "Header Len (Varint)" { style.fill: "#90caf9" }
    t_array: "Serial Types [Varint...]" { style.fill: "#bbdefb" }
    data: "Data Payload" { style.fill: "#64b5f6" }
    
    h_len -> t_array -> data
  }

  serial_lookup: {
    label: |md
      ### Serial Type Legend
      | ID | Content | Size (Bytes) |
      | :-- | :-- | :-- |
      | 0 | NULL | 0 |
      | 1-4 | Signed Int | 1, 2, 3, 4 |
      | 5 | Signed Int | 6 |
      | 6 | Signed Int | 8 |
      | 7 | Float | 8 |
      | 8 | Integer 0 | 0 |
      | 9 | Integer 1 | 0 |
      | N>12 | BLOB | (N-12)/2 |
      | N>13 | STRING | (N-13)/2 |
    |
    style.fill: "#fffde7"
    style.font: mono
  }
}

lock_manager: {
  label: "Locking State Machine (Journal Mode)"
  
  start: "" { 
    shape: circle
    style.fill: black 
    width: 20
    height: 20
  }
  
  idle: "IDLE" {
    label: "IDLE\nNo locks"
    style.fill: "#eceff1"
  }
  
  shared: "SHARED" {
    label: "SHARED\nReaders active"
    style.fill: "#e3f2fd"
  }
  
  reserved: "RESERVED" {
    label: "RESERVED\nWriter intent"
    style.fill: "#fff3e0"
  }
  
  pending: "PENDING" {
    label: "PENDING\nBlocking readers"
    style.fill: "#fff9c4"
  }
  
  exclusive: "EXCLUSIVE" {
    label: "EXCLUSIVE\nWriting DB"
    style.fill: "#ffebee"
  }

  start -> idle
  idle -> shared: "READ_START"
  shared -> reserved: "BEGIN_WRITE"
  reserved -> pending: "COMMIT_REQ"
  pending -> exclusive: "WAIT_READERS"
  exclusive -> idle: "COMMIT_DONE"
  
  err_busy: "SQLITE_BUSY" {
    style.fill: "#ef5350"
    style.font-color: white
  }
  
  shared -> err_busy: "LOCK_CONFLICT" {
    style.stroke: red
    style.stroke-dash: 2
  }
}

# Documentation & Footer
metadata: {
  explanation: |md
    ### VDBE Engine Specification
    - **PC**: Program Counter tracks instruction offset in opcode array.
    - **Cursors**: Isolated B-Tree iterators maintaining Page pointers.
    - **Opcodes**: Direct mapping from SQL AST into VM bytecode.
    - **Record Encoding**: Uses Varints to minimize disk footprint.
  |
  explanation.near: bottom-center
}

# Logic Flows
vdbe_engine.vm_structure -> btree_layout: "Seek(RowID)"
btree_layout -> record_serialization: "Load Bytes"
lock_manager -> btree_layout: "Protects Pages"