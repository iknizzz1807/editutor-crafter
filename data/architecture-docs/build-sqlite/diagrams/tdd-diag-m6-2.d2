vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
    sketch: false
    pad: 20
  }
}

title: "SQLite Token Type Hierarchy & Lexical Analysis Taxonomy" {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# Root definition
Token: {
  shape: rectangle
  tooltip: "Base class for all lexical units in the SQLite engine"
  style: {
    fill: "#1a1a2e"
    stroke: "#e94560"
    stroke-width: 4
    font-size: 20
    font-color: "#ffffff"
    shadow: true
  }
}

Tokenizer: {
  label: "Lexical Analyzer (Tokenizer)"
  style: {
    fill: "#16213e"
    stroke: "#0f3460"
    stroke-width: 2
    border-radius: 10
  }

  SQL_TOKENS: {
    label: "Standard SQL Tokens"
    style: {
      fill: "#0f3460"
      stroke: "#533483"
      stroke-width: 3
    }

    Keyword: {
      label: "KEYWORD\n(SELECT, FROM, WHERE...)"
      style.fill: "#533483"
      style.stroke: "#e94560"
    }

    Identifier: {
      label: "IDENTIFIER\n(table/column names)"
      style.fill: "#533483"
      style.stroke: "#e94560"
    }

    Literal: {
      label: "LITERAL VALUES"
      style.fill: "#533483"
      style.stroke: "#e94560"
      
      StringLiteral: {
        label: "'string content'"
        style.fill: "#e94560"
        style.stroke: "#ffffff"
      }
      NumericLiteral: {
        label: "Integers & Floats\n(123, 3.14)"
        style.fill: "#e94560"
        style.stroke: "#ffffff"
      }
      BlobLiteral: {
        label: "Hex Blobs\nX'01AB'"
        style.fill: "#e94560"
        style.stroke: "#ffffff"
      }
    }

    Operator: {
      label: "OPERATORS"
      style.fill: "#533483"
      style.stroke: "#e94560"

      BinaryOp: {
        label: "Arithmetic\n+ - * / % ||"
        style.fill: "#e94560"
      }
      UnaryOp: {
        label: "Unary\n- + ~ NOT"
        style.fill: "#e94560"
      }
      Comparison: {
        label: "Logic\n= < > <= >="
        style.fill: "#e94560"
      }
    }

    Punctuation: {
      label: "SYMBOLS\n( ) , ; . * ="
      style.fill: "#533483"
      style.stroke: "#e94560"
    }

    Comment: {
      label: "COMMENTS"
      style.fill: "#533483"
      style.stroke: "#e94560"
      
      LineComment: {
        label: "-- single line"
        style.fill: "#16213e"
      }
      BlockComment: {
        label: "/* multi-line */"
        style.fill: "#16213e"
      }
    }

    Parameter: {
      # FIXED: Using single quotes to bypass substitution error for $var
      label: '? $var @var'
      tooltip: "Bound parameters for prepared statements"
      style.fill: "#533483"
      style.stroke: "#e94560"
    }

    EOF: {
      label: "END OF FILE"
      style.fill: "#e94560"
      style.stroke: "#ffffff"
      style.stroke-width: 2
    }
  }

  SPECIAL_TOKENS: {
    label: "Engine Control Tokens"
    style: {
      fill: "#0f3460"
      stroke: "#00d9ff"
      stroke-width: 3
    }

    TK_ILLEGAL: {
      label: "ILLEGAL CHARACTER"
      style.fill: "#ff0000"
      style.stroke: "#ffffff"
      style.bold: true
    }

    TK_SPACE: {
      label: "WHITESPACE"
      style.fill: "#16213e"
    }

    TK_NEWLINE: {
      label: "NEWLINE"
      style.fill: "#16213e"
    }
  }
}

# Establishing Relationships with full scope paths
Token -> Tokenizer: "Lexer categorizes input streams" {
  style.stroke-width: 3
}

Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.Keyword
Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.Identifier
Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.Literal: "contains"
Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.Operator
Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.Punctuation
Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.Comment
Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.Parameter
Tokenizer.SQL_TOKENS -> Tokenizer.SQL_TOKENS.EOF

Tokenizer.SQL_TOKENS.Literal -> Tokenizer.SQL_TOKENS.Literal.StringLiteral
Tokenizer.SQL_TOKENS.Literal -> Tokenizer.SQL_TOKENS.Literal.NumericLiteral
Tokenizer.SQL_TOKENS.Literal -> Tokenizer.SQL_TOKENS.Literal.BlobLiteral

Tokenizer.SQL_TOKENS.Operator -> Tokenizer.SQL_TOKENS.Operator.BinaryOp
Tokenizer.SQL_TOKENS.Operator -> Tokenizer.SQL_TOKENS.Operator.UnaryOp
Tokenizer.SQL_TOKENS.Operator -> Tokenizer.SQL_TOKENS.Operator.Comparison

Tokenizer.SQL_TOKENS.Comment -> Tokenizer.SQL_TOKENS.Comment.LineComment
Tokenizer.SQL_TOKENS.Comment -> Tokenizer.SQL_TOKENS.Comment.BlockComment

Tokenizer -> Tokenizer.SQL_TOKENS: "Normal Path" {
  style.stroke: green
}

Tokenizer -> Tokenizer.SPECIAL_TOKENS: "Internal/Exception Path" {
  style.stroke: "#00d9ff"
  style.stroke-dash: 5
}

legend: |md
  ### Tokenization Spec
  - **Identifiers**: Double quoted or bracketed.
  - **Keywords**: Case-insensitive in SQLite.
  - **Parameters**: Support for positional (?) and named ($) variables.
| {
  near: bottom-right
}