vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # Three-Valued Logic (3VL) Truth Tables
  ## Kleene Logic Specification (T, F, U)
| {
  near: top-center
  shape: text
}

# --- GLOBAL CLASSES ---
classes: {
  header_cell: {
    style: {
      fill: "#4b32a7"
      font-color: white
      bold: true
      stroke-width: 2
    }
  }
  value_cell: {
    style: {
      fill: "#f3e5f5"
      stroke: "#ce93d8"
      border-radius: 4
    }
  }
  state_true: {
    style: {
      fill: "#e8f5e9"
      stroke: "#4caf50"
      font-color: "#2e7d32"
      bold: true
    }
  }
  state_false: {
    style: {
      fill: "#ffebee"
      stroke: "#f44336"
      font-color: "#c62828"
      bold: true
    }
  }
  state_unknown: {
    style: {
      fill: "#fff3e0"
      stroke: "#ff9800"
      font-color: "#ef6c00"
      bold: true
    }
  }
}

# --- TRUTH TABLE MATRICES ---
Tables: {
  grid-columns: 2
  grid-gap: 40

  Conjunction: {
    label: "Logical AND (∧)"
    grid-columns: 4
    grid-rows: 4
    grid-gap: 0

    h_op: "A ∧ B" { class: header_cell }
    h_t: "T" { class: header_cell }
    h_f: "F" { class: header_cell }
    h_u: "U" { class: header_cell }

    r1_h: "T" { class: header_cell }
    tt: "T" { class: [value_cell; state_true] }
    tf: "F" { class: [value_cell; state_false] }
    tu: "U" { class: [value_cell; state_unknown] }

    r2_h: "F" { class: header_cell }
    ft: "F" { class: [value_cell; state_false] }
    ff: "F" { class: [value_cell; state_false] }
    fu: "F" { class: [value_cell; state_false] }

    r3_h: "U" { class: header_cell }
    ut: "U" { class: [value_cell; state_unknown] }
    uf: "F" { class: [value_cell; state_false] }
    uu: "U" { class: [value_cell; state_unknown] }
  }

  Disjunction: {
    label: "Logical OR (∨)"
    grid-columns: 4
    grid-rows: 4
    grid-gap: 0

    h_op: "A ∨ B" { class: header_cell }
    h_t: "T" { class: header_cell }
    h_f: "F" { class: header_cell }
    h_u: "U" { class: header_cell }

    r1_h: "T" { class: header_cell }
    tt: "T" { class: [value_cell; state_true] }
    tf: "T" { class: [value_cell; state_true] }
    tu: "T" { class: [value_cell; state_true] }

    r2_h: "F" { class: header_cell }
    ft: "T" { class: [value_cell; state_true] }
    ff: "F" { class: [value_cell; state_false] }
    fu: "U" { class: [value_cell; state_unknown] }

    r3_h: "U" { class: header_cell }
    ut: "T" { class: [value_cell; state_true] }
    uf: "U" { class: [value_cell; state_unknown] }
    uu: "U" { class: [value_cell; state_unknown] }
  }
}

# --- STATE TRANSITION: UNARY NOT ---
Negation_SM: {
  label: "Unary NOT (¬) State Machine"
  
  TRUE: "TRUE (T)" { class: state_true }
  FALSE: "FALSE (F)" { class: state_false }
  UNKNOWN: "UNKNOWN (U)" { class: state_unknown }

  TRUE -> FALSE: "¬T = F" {
    style: {
      stroke: "#f44336"
      stroke-width: 2
    }
  }
  FALSE -> TRUE: "¬F = T" {
    style: {
      stroke: "#4caf50"
      stroke-width: 2
    }
  }
  UNKNOWN -> UNKNOWN: "¬U = U" {
    style: {
      stroke-dash: 3
    }
  }
}

# --- EVALUATION FLOW ---
Evaluation_Sequence: {
  shape: sequence_diagram
  
  Parser: Logic Parser
  Evaluator: 3VL Evaluator
  Storage: State Vector
  
  Parser -> Evaluator: Evaluate("A ∧ B")
  Evaluator -> Storage: GetState("A")
  Evaluator <- Storage: Return(UNKNOWN)
  Evaluator -> Storage: GetState("B")
  Evaluator <- Storage: Return(FALSE)
  
  Evaluator -> Evaluator: Resolve(UNKNOWN ∧ FALSE)
  
  Parser <- Evaluator: Return(FALSE) {
    style.stroke: "#f44336"
  }
}

# --- FIELD LAYOUT ANNOTATION ---
Internal_State: {
  label: "Memory Representation of 3VL Value"
  shape: sql_table
  
  0x00: "Type Discriminator" { constraint: "uint8" }
  0x01: "Value (0=F, 1=T, 2=U)" { constraint: "uint8" }
  0x02: "Padding" { constraint: "0x00" }
  
  style: {
    fill: "#f3e5f5"
    stroke: "#4b32a7"
  }
}

Legend: {
  near: bottom-right
  
  T: "TRUE: Definite truth" { class: state_true }
  F: "FALSE: Definite falsehood" { class: state_false }
  U: "UNKNOWN: Missing or indeterminate" { class: state_unknown }
}

Negation_SM -> Tables: "Logic Definitions" {
  style: {
    stroke-dash: 5
    opacity: 0.5
  }
}