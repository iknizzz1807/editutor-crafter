vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# ============================================================
# TITLE AND GLOBAL ANNOTATIONS
# ============================================================
main_title: "SQLite Double Lookup Pattern" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    font-color: "#ffffff"
  }
}

sub_title: "Index B-tree (Search) -> RowID (Pointer) -> Table B-tree (Data Retrieval)" {
  near: top-center
  shape: text
  style: {
    font-size: 18
    italic: true
    font-color: "#cccccc"
  }
}

legend: "Diagram Legend" {
  near: top-right
  idx: "Index Entry" { style.fill: "#9b59b6" }
  ptr: "RowID Pointer" { style.fill: "#e67e22" }
  tbl: "Table Record" { style.fill: "#3498db" }
  free: "Free Space" { style.fill: "#27ae60" }
  pad: "Padding/Header" { style.fill: "#7f8c8d" }
}

# ============================================================
# PHASE 1: INDEX LOOKUP
# ============================================================
index_phase: "PHASE 1: INDEX SEARCH (B-TREE)" {
  style: {
    fill: "#1a1a2e"
    stroke: "#9b59b6"
    stroke-width: 4
  }

  idx_root: "Index Root Page (Interior)" {
    style.fill: "#2d1b4e"
    
    header: "Page Header (0x00 - 0x0C)" {
      style.fill: "#4a235a"
      label: |md
        **B-Tree Interior Header**
        - Offset 0: Type (0x05)
        - Offset 3: Cell Count (2)
        - Offset 8: Right Child (8)
      |
    }

    ptrs: "Cell Pointer Array" {
      p0: "0x000C: [0x0FA0] -> Key 50"
      p1: "0x000E: [0x0F40] -> Key 100"
      style.stroke: "#e67e22"
      style.font-color: "#e67e22"
    }

    cells: "Interior Cells (Physical)" {
      style.stroke-dash: 3
      cell0: "Ptr: Page 4096 | Key: user_id=50" {
        style.stroke: "#9b59b6"
        style.fill: "#3b1e5a"
      }
    }
  }

  idx_leaf: "Index Leaf Page (4096)" {
    style.fill: "#2d1b4e"
    
    header: "Page Header (0x00 - 0x08)" {
      style.fill: "#4a235a"
      label: |md
        **B-Tree Leaf Header**
        - Offset 0: Type (0x0D)
        - Offset 3: Cell Count (3)
        - Offset 5: Content Start (4040)
      |
    }

    entries: "Index Entries (Payloads)" {
      entry_42: "Index Payload [42]" {
        style: {
          fill: "#7d3c98"
          stroke: "#f39c12"
          stroke-width: 3
        }
        key: "Search Key: 42"
        rowid_ptr: "RowID Pointer: 42" {
          style.font-color: "#e67e22"
          style.bold: true
        }
      }
      entry_43: "Index Payload [43]" {
        key: "Search Key: 43"
        rowid_ptr: "RowID Pointer: 102"
      }
      free_space: "Unallocated Space" {
        style.fill: "#27ae60"
        style.opacity: 0.2
        style.stroke-dash: 5
      }
    }
  }

  idx_root.cells.cell0 -> idx_leaf: "B-Tree Traversal" {
    style: {
      stroke: "#e67e22"
      stroke-width: 2
      animated: true
    }
  }
}

# ============================================================
# EXTRACTION LAYER
# ============================================================
extraction_logic: {
  shape: diamond
  label: "RowID Extraction"
  style: {
    fill: "#2c3e50"
    stroke: "#e67e22"
    stroke-width: 3
  }
  target_id: "TARGET ROWID: 42" {
    style: {
      font-size: 20
      bold: true
      font-color: "#e67e22"
      stroke-width: 0
    }
  }
}

# ============================================================
# PHASE 2: TABLE LOOKUP
# ============================================================
table_phase: "PHASE 2: TABLE RETRIEVAL (ROWID B-TREE)" {
  style: {
    fill: "#1a1a2e"
    stroke: "#3498db"
    stroke-width: 4
  }

  tbl_leaf: "Table Leaf Page (8192)" {
    style.fill: "#1e3a5f"

    header: "Page Header (12 Bytes)" {
      style.fill: "#2874a6"
      label: |md
        **B-Tree Table Leaf**
        - Type: 0x0D (Table Leaf)
        - RowID Search Enabled
      |
    }

    cell_pointers: "Cell Offset Array" {
      ptr0: "0x0008: [0x0FC8] -> RowID 42"
      style.stroke: "#e67e22"
      style.font-color: "#e67e22"
    }

    record_area: "Physical Record Storage" {
      row_42: "Table Record (RowID 42)" {
        style: {
          fill: "#2980b9"
          stroke: "#3498db"
          stroke-width: 3
        }
        
        row_header: "Record Header" {
          style.fill: "#1f618d"
          label: "Serial Types: [Int8, Text(5), Int8, Text(6)]"
        }

        row_data: "Column Values" {
          id: "PK id: 42"
          username: "user: 'alice'" { style.bold: true }
          status: "state: 'active'"
          created: "ts: 1715432000"
        }
      }
      
      padding: "Padding (Alignment)" {
        style.fill: "#7f8c8d"
        style.stroke-dash: 2
        style.opacity: 0.5
      }
    }
  }
}

# ============================================================
# CONNECTIONS & DATA FLOW
# ============================================================

index_phase.idx_leaf.entries.entry_42.rowid_ptr -> extraction_logic.target_id: "1. Found Pointer" {
  style: {
    stroke: "#e67e22"
    stroke-width: 3
    animated: true
  }
}

extraction_logic.target_id -> table_phase.tbl_leaf.cell_pointers.ptr0: "2. Seek RowID" {
  style: {
    stroke: "#3498db"
    stroke-width: 3
    animated: true
  }
}

table_phase.tbl_leaf.cell_pointers.ptr0 -> table_phase.tbl_leaf.record_area.row_42: "3. Resolve Offset" {
  style: {
    stroke: "#3498db"
    stroke-dash: 2
  }
}

# ============================================================
# PHYSICAL MEMORY LAYOUT ANNOTATIONS
# ============================================================

memory_view: "Memory Layout (Physical)" {
  near: bottom-left
  style.fill: "#2d2d2d"
  
  bounds: {
    grid-rows: 4
    style.stroke: "#ffffff"
    
    b0: "0x0000: Page Start (Page Header)" { style.fill: "#4a235a" }
    b1: "0x000C: Cell Pointer Array" { style.fill: "#2d1b4e" }
    b2: "0x0F40: Unallocated Space (Free)" { 
      style.fill: "#27ae60"
      style.opacity: 0.3
    }
    b3: "0x1000: Page Boundary (4096B)" { 
      style.stroke: "#ffffff"
      style.stroke-width: 3
      style.bold: true
    }
  }
}

# ============================================================
# EXECUTION PIPELINE
# ============================================================

execution_pipeline: "Execution Steps" {
  grid-columns: 4
  near: bottom-center
  
  s1: "1. Scan Index" {
    style.fill: "#4a235a"
    style.bold: true
  }
  s2: "2. Extract ID" {
    style.fill: "#e67e22"
    style.bold: true
  }
  s3: "3. Locate Table" {
    style.fill: "#1f618d"
    style.bold: true
  }
  s4: "4. Return Row" {
    style.fill: "#2874a6"
    style.bold: true
  }
  
  s1 -> s2 -> s3 -> s4
}

# ============================================================
# GLOBAL STYLING
# ============================================================

***: {
  style: {
    font: mono
    font-color: "#ffffff"
    stroke: "#ffffff"
    border-radius: 4
  }
}

# Explicitly set shapes for components
index_phase.idx_leaf.entries.free_space.shape: square
table_phase.tbl_leaf.record_area.padding.shape: square

# Legend positioning refinement
legend.near: top-right
memory_view.near: bottom-left
execution_pipeline.near: bottom-center