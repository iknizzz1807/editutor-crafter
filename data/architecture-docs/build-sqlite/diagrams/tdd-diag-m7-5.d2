layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
    pad: 40
  }
}

# --- GLOBAL STYLES ---
*.style: {
  font: mono
  stroke-width: 2
  border-radius: 4
}

# --- CLASSES ---
classes: {
  header_box: {
    style: {
      fill: "#2d3748"
      stroke: "#4fd1c5"
      stroke-width: 3
      font-color: white
      bold: true
    }
  }
  row_id_field: {
    style: {
      fill: "#805ad5"
      stroke: "#b794f4"
      font-color: white
    }
  }
  col_a_field: {
    style: {
      fill: "#38a169"
      stroke: "#68d391"
      font-color: white
    }
  }
  col_b_field: {
    style: {
      fill: "#3182ce"
      stroke: "#63b3ed"
      font-color: white
    }
  }
  col_c_field: {
    style: {
      fill: "#dd6b20"
      stroke: "#f6ad55"
      font-color: white
    }
  }
  pointer_field: {
    style: {
      fill: "#d53f8c"
      stroke: "#ed64a6"
      font-color: white
    }
  }
  success_query: {
    style: {
      fill: "#f0fff4"
      stroke: "#38a169"
      font-color: "#22543d"
    }
  }
  fail_query: {
    style: {
      fill: "#fff5f5"
      stroke: "#e53e3e"
      font-color: "#742a2a"
    }
  }
}

# --- PHYSICAL MEMORY LAYOUT ---
"Physical Index Key Layout": {
  style.fill: "#f7fafc"
  style.stroke: "#cbd5e0"
  
  direction: right
  
  Offsets: {
    shape: rectangle
    style.stroke-width: 0
    style.fill: transparent
    
    o0: "0x00" { shape: text }
    o8: "0x08" { shape: text }
    oV1: "0x08+L1" { shape: text }
    oV2: "0x08+L1+L2" { shape: text }
    oPtr: "0x08+ΣL" { shape: text }
  }

  Layout: {
    grid-columns: 4
    grid-gap: 0
    
    RowID: "RowID\n(Implicit PK)\n8 Bytes" { class: row_id_field; width: 140; height: 80 }
    ColA: "Column A\n(Variable L1)" { class: col_a_field; width: 140; height: 80 }
    ColB: "Column B\n(Variable L2)" { class: col_b_field; width: 140; height: 80 }
    ColC: "Column C\n(Variable L3)" { class: col_c_field; width: 140; height: 80 }
  }
  
  Ptr: "Row Pointer (RID)\n64-bit Reference" { 
    class: pointer_field
    width: 200
    height: 40
  }

  Offsets.o0 -> Layout.RowID
  Offsets.o8 -> Layout.ColA
  Offsets.oV1 -> Layout.ColB
  Offsets.oV2 -> Layout.ColC
  Offsets.oPtr -> Ptr
}

# --- B-TREE PAGE LOGIC ---
"B-Tree Index Page (16KB)": {
  class: header_box
  
  PageHeader: "Page Header\nFlags, CRC, FreeSpace" { style.fill: "#4a5568" }
  
  Keys: {
    direction: right
    style.fill: "#1a202c"
    
    k1: "Key 1\n[a=5, b=10]" { class: col_a_field }
    k2: "Key 2\n[a=5, b=20]" { class: col_b_field }
    k3: "Key 3\n[a=10, b=5]" { class: row_id_field }
  }
  
  Pointers: {
    direction: right
    style.fill: "#1a202c"
    
    p1: "Child 0" { class: pointer_field }
    p2: "Child 1" { class: pointer_field }
    p3: "Child 2" { class: pointer_field }
    p4: "Child 3" { class: pointer_field }
  }
  
  Keys.k1 -> Pointers.p1
  Keys.k1 -> Pointers.p2
  Keys.k2 -> Pointers.p3
  Keys.k3 -> Pointers.p4
}

# --- QUERY OPTIMIZER SCENARIOS ---
"Query Scenarios & Leftmost Rule": {
  direction: down
  style.fill: "#edf2f7"

  Valid: {
    q1: "SELECT * FROM t WHERE a = ?" { class: success_query }
    q2: "SELECT * FROM t WHERE a = ? AND b = ?" { class: success_query }
    q3: "SELECT * FROM t WHERE a = ? AND b = ? AND c = ?" { class: success_query }
  }
  
  Invalid: {
    q4: "SELECT * FROM t WHERE b = ?" { class: fail_query }
    q5: "SELECT * FROM t WHERE b = ? AND c = ?" { class: fail_query }
    q6: "SELECT * FROM t WHERE c = ?" { class: fail_query }
  }
}

# --- CONNECTIONS ---
"Physical Index Key Layout".Ptr -> "B-Tree Index Page (16KB)": {
  style.stroke: "#e53e3e"
  style.stroke-width: 4
  style.animated: true
}

"B-Tree Index Page (16KB)" -> "Query Scenarios & Leftmost Rule": "Index Usage Determination" {
  style.stroke-dash: 5
}

# --- DOCUMENTATION ANNOTATION ---
Footer_Note: |md
  ### Leftmost Prefix Rule Reference
  Composite index on **(a, b, c)** can only be used if the query references a, or a AND b, or a AND b AND c. 
  
  *   **Range Scans**: Once a column uses a range operator (>, <, BETWEEN), subsequent columns in the index cannot be used for filtering.
  *   **Ordering**: The index maintains a physical sorted order: `sort(a) -> sort(b) -> sort(c)`.
| {
  near: bottom-center
  style: {
    stroke: "#4fd1c5"
    fill: "#f0fff4"
    font-size: 14
  }
}