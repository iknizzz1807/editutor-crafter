vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# M11: Aggregate State Machine & JOIN Algorithms
direction: down

# === AGGREGATE STATE MACHINE ===
aggregate_fsm: Aggregate Function State Machine {
  shape: rectangle
  style.fill: "#f8f0fc"
  style.stroke: "#6a1b9a"
  style.stroke-width: 2

  # States
  init: Init {
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    shape: circle
    label: "INIT\n(grp=0)"
  }
  running: Running {
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
    shape: circle
    label: "RUNNING\n(state!=NULL)"
  }
  finalize_state: Finalize {
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    shape: circle
    label: "FINALIZE\n(Output)"
  }

  # Transitions
  init -> running: "First row\nAggregateInit" {
    style.stroke: "#2e7d32"
    style.stroke-width: 2
    source-arrowhead.label: "+1"
  }
  running -> running: "Next row\nAggStep" {
    style.stroke: "#e65100"
    style.stroke-dash: 3
    source-arrowhead.label: "+1 each"
  }
  running -> finalize_state: "EOF\nAggFinal" {
    style.stroke: "#1565c0"
    style.stroke-width: 2
  }
  finalize_state -> init: "Reset" {
    style.stroke: "#6a1b9a"
    style.stroke-dash: 3
  }
}

# === AGGREGATE FUNCTION TYPES ===
agg_functions: Aggregate Functions {
  shape: rectangle
  style.fill: "#fce4ec"
  style.stroke: "#c2185b"

  count_star: "COUNT(*)" {
    style.fill: "#e1f5fe"
    style.stroke: "#0277bd"
    shape: rectangle
    label: "COUNT(*)\ninit: cnt=0\nstep: cnt++\nfinal: cnt"
  }
  count_col: "COUNT(col)" {
    style.fill: "#e1f5fe"
    style.stroke: "#0277bd"
    shape: rectangle
    label: "COUNT(col)\ninit: cnt=0\nstep: cnt+=col!=NULL\nfinal: cnt"
  }
  sum_func: "SUM(col)" {
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    shape: rectangle
    label: "SUM(col)\ninit: sum=NULL\nstep: sum+=col\nfinal: sum"
  }
  avg_func: "AVG(col)" {
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
    shape: rectangle
    label: "AVG(col)\ninit: sum=0,cnt=0\nstep: sum+=col,cnt++\nfinal: sum/cnt"
  }
  min_func: "MIN(col)" {
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
    shape: rectangle
    label: "MIN(col)\ninit: min=NULL\nstep: min=MIN(min,col)\nfinal: min"
  }
  max_func: "MAX(col)" {
    style.fill: "#fce4ec"
    style.stroke: "#c2185b"
    shape: rectangle
    label: "MAX(col)\ninit: max=NULL\nstep: max=MAX(max,col)\nfinal: max"
  }
}

# === GROUP BY PROCESSING ===
group_by_proc: GROUP BY Processing {
  shape: rectangle
  style.fill: "#e0f7fa"
  style.stroke: "#006064"

  sorter: Sorter {
    style.fill: "#b2ebf2"
    style.stroke: "#00838f"
    shape: cylinder
    label: "Sorter\nGROUP BY key\nSort-merge join\nkey: (col1,col2)"
  }
  group_check: Group Boundary Check {
    style.fill: "#80deea"
    style.stroke: "#006064"
    shape: diamond
    label: "Key Changed?\nprev_key != curr_key"
  }
  new_group: New Group {
    style.fill: "#4dd0e1"
    style.stroke: "#006064"
    shape: circle
    label: "New Group\nAggFinal + AggInit"
  }
}

# Group By Flow
group_by_proc.sorter -> group_by_proc.group_check: "Sorted rows" {
  style.stroke: "#00838f"
}
group_by_proc.group_check -> group_by_proc.new_group: "YES" {
  style.stroke: "#2e7d32"
  label: "Finalize prev"
}
group_by_proc.group_check -> group_by_proc.sorter: "NO" {
  style.stroke: "#e65100"
  style.stroke-dash: 3
  label: "Continue"
}

# === VDBE Opcodes for Aggregates ===
vdbe_agg: VDBE Aggregate Opcodes {
  shape: rectangle
  style.fill: "#fff8e1"
  style.stroke: "#ff6f00"

  AggInit: "AggInit P1 P2\nInit agg P1..P1+P2-1\nPC=P2 on first row" {
    style.fill: "#ffecb3"
    style.stroke: "#ff6f00"
  }
  AggStep: "AggStep P1 P2 P3\nStep agg: r[P3]=r[P1]+r[P3]\nPC+=P2 after" {
    style.fill: "#ffe082"
    style.stroke: "#ff6f00"
  }
  AggFinal: "AggFinal P1 P2 P3\nFinalize agg P1: result in r[P3]\nP2=0, P3=finalize fn" {
    style.fill: "#ffd54f"
    style.stroke: "#ff6f00"
  }
  AggGet: "AggGet P1 P2 P3\nLoad agg[reg P2] into r[P3]\nP1=0 for cached" {
    style.fill: "#ffcc80"
    style.stroke: "#ff6f00"
  }
  AggSet: "AggSet P1 P2 P3\nStore r[P3] into agg[reg P2]\nMark dirty" {
    style.fill: "#ffb74d"
    style.stroke: "#ff6f00"
  }
}

# === NESTED LOOP JOIN ===
nested_loop_join: Nested Loop Join Algorithm {
  shape: rectangle
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"

  outer_setup: Outer Setup {
    style.fill: "#e1bee7"
    style.stroke: "#7b1fa2"
    shape: rectangle
    label: "Open outer cursor\nRewind outer table\nIF EOF: return"
  }
  inner_setup: Inner Setup {
    style.fill: "#ce93d8"
    style.stroke: "#7b1fa2"
    shape: rectangle
    label: "Open inner cursor\nRewind inner table\nIF EOF: next outer"
  }
  match_check: Match Check {
    style.fill: "#ab47bc"
    style.stroke: "#7b1fa2"
    shape: diamond
    label: "WHERE join_cond\n(inner.col = outer.col)"
  }
  output_row: Output Row {
    style.fill: "#ba68c8"
    style.stroke: "#7b1fa2"
    shape: rectangle
    label: "Columns from both\nEmit result row"
  }
  advance_inner: Advance Inner {
    style.fill: "#9575cd"
    style.stroke: "#7b1fa2"
    shape: rectangle
    label: "inner.Next()\nIF NOT EOF: goto match"
  }
  advance_outer: Advance Outer {
    style.fill: "#7e57c2"
    style.stroke: "#7b1fa2"
    shape: rectangle
    label: "outer.Next()\nReopen inner cursor\nIF NOT EOF: goto inner_setup"
  }
}

# NLJ Flow
nested_loop_join.outer_setup -> nested_loop_join.inner_setup: "Not EOF" {
  style.stroke: "#7b1fa2"
}
nested_loop_join.inner_setup -> nested_loop_join.match_check: "Not EOF" {
  style.stroke: "#7b1fa2"
}
nested_loop_join.match_check -> nested_loop_join.output_row: "TRUE" {
  style.stroke: "#2e7d32"
  label: "Match"
}
nested_loop_join.match_check -> nested_loop_join.advance_inner: "FALSE" {
  style.stroke: "#c62828"
}
nested_loop_join.output_row -> nested_loop_join.advance_inner: "After emit" {
  style.stroke: "#7b1fa2"
}
nested_loop_join.advance_inner -> nested_loop_join.match_check: "Not EOF" {
  style.stroke: "#7b1fa2"
  style.stroke-dash: 3
}
nested_loop_join.advance_inner -> nested_loop_join.advance_outer: "EOF inner" {
  style.stroke: "#e65100"
}
nested_loop_join.advance_outer -> nested_loop_join.inner_setup: "Not EOF" {
  style.stroke: "#7b1fa2"
}
nested_loop_join.advance_outer -> join_done: "EOF outer" {
  style.stroke: "#7b1fa2"
}

join_done: DONE {
  style.fill: "#d1c4e9"
  style.stroke: "#7b1fa2"
  shape: circle
}

# === JOIN TYPES ===
join_types: JOIN Types {
  shape: rectangle
  style.fill: "#e8eaf6"
  style.stroke: "#303f9f"

  inner_join: "INNER JOIN" {
    style.fill: "#c5cae9"
    style.stroke: "#303f9f"
    shape: rectangle
    label: "INNER JOIN\nOnly matching rows\nA ∩ B"
  }
  left_join: "LEFT JOIN" {
    style.fill: "#b39ddb"
    style.stroke: "#303f9f"
    shape: rectangle
    label: "LEFT JOIN\nAll left + match right\nNULL right if no match\nA ∪ (A×B)left"
  }
  cross_join: "CROSS JOIN" {
    style.fill: "#9fa8da"
    style.stroke: "#303f9f"
    shape: rectangle
    label: "CROSS JOIN\nCartesian product\n|A| × |B| rows"
  }
  self_join: "SELF JOIN" {
    style.fill: "#7986cb"
    style.stroke: "#303f9f"
    shape: rectangle
    label: "SELF JOIN\nTable joined to itself\nRequires aliases"
  }
}

# === JOIN OPTIMIZATION ===
join_optimization: Join Optimization {
  shape: rectangle
  style.fill: "#e0f2f1"
  style.stroke: "#00695c"

  reorder: "Reorder Joins" {
    style.fill: "#b2dfdb"
    style.stroke: "#00695c"
    shape: rectangle
    label: "Join Reordering\nPut small tables first\nUse indexed columns"
  }
  index_usage: "Index Usage" {
    style.fill: "#80cbc4"
    style.stroke: "#00695c"
    shape: rectangle
    label: "Index Join\ninner: indexed column\nO(n log n) vs O(n²)"
  }
  hash_join_opt: "Hash Join" {
    style.fill: "#4db6ac"
    style.stroke: "#00695c"
    shape: rectangle
    label: "Hash Join\nBuild hash table\nProbe for matches\nO(A + B)"
  }
  merge_join: "Merge Join" {
    style.fill: "#26a69a"
    style.stroke: "#00695c"
    shape: rectangle
    label: "Merge Join\nBoth sorted on join key\nSingle pass merge\nO(A + B)"
  }
}

# === QUERY PLAN ===
query_plan: "Query Plan: SELECT dept, COUNT(*) FROM employees JOIN dept ON employees.dept_id = dept.id GROUP BY dept" {
  shape: rectangle
  style.fill: "#fafafa"
  style.stroke: "#424242"

  scan_type: "SCAN employees" {
    style.fill: "#eeeeee"
    style.stroke: "#424242"
    shape: rectangle
  }
  index_scan: "SEARCH dept USING INDEX" {
    style.fill: "#e0e0e0"
    style.stroke: "#424242"
    shape: rectangle
  }
  hash_join_plan: "HASH JOIN" {
    style.fill: "#bdbdbd"
    style.stroke: "#424242"
    shape: rectangle
  }
  group_by_plan: "GROUP BY dept" {
    style.fill: "#9e9e9e"
    style.stroke: "#424242"
    shape: rectangle
  }
  aggregate_plan: "AGGREGATE COUNT(*)" {
    style.fill: "#757575"
    style.stroke: "#424242"
    shape: rectangle
  }
}

# === COLUMN RESOLUTION ===
column_resolution: Column Resolution {
  shape: rectangle
  style.fill: "#fffde7"
  style.stroke: "#fbc02d"

  explicit: "Explicit (table.column)" {
    style.fill: "#fff9c4"
    style.stroke: "#fbc02d"
    shape: rectangle
    label: "explicit: t.col\nParse: t=alias\ncol=name\nLookup in t schema"
  }
  implicit: "Implicit (column only)" {
    style.fill: "#fff59d"
    style.stroke: "#fbc02d"
    shape: rectangle
    label: "implicit: col\nAmbiguous if in both\nError if in neither"
  }
  wildcard: Wildcard Resolution {
    style.fill: "#fff176"
    style.stroke: "#fbc02d"
    shape: rectangle
    label: "* expands to all columns\ntable.* expands to table cols\nt1.*, t2.* disambiguates"
  }
}

# Global Layout relationships
agg_functions -> aggregate_fsm: "uses" {
  style.stroke: "#6a1b9a"
  style.stroke-dash: 3
}
group_by_proc -> agg_functions: "feeds" {
  style.stroke: "#006064"
  style.stroke-dash: 3
}
nested_loop_join -> join_types: "implements" {
  style.stroke: "#7b1fa2"
  style.stroke-dash: 3
}
join_optimization -> nested_loop_join: "optimizes" {
  style.stroke: "#00695c"
  style.stroke-dash: 3
}
query_plan -> nested_loop_join: "produces" {
  style.stroke: "#424242"
  style.stroke-dash: 3
}
column_resolution -> query_plan: "resolves" {
  style.stroke: "#fbc02d"
  style.stroke-dash: 3
}