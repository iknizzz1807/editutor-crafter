direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# -----------------------------------------------------------------------------------------
# TECHNICAL SPECIFICATION CLASSES (Intel Manual Quality Styling)
# -----------------------------------------------------------------------------------------
classes: {
  changed_state: {
    style: {
      stroke: "#ff0000"
      stroke-width: 5
      font-color: "#ff0000"
      bold: true
      shadow: true
    }
  }
  header_row: {
    style: {
      fill: "#673ab7" # Purple Header per spec
      font-color: "#ffffff"
      bold: true
    }
  }
  system_table: {
    style: {
      fill: "#e8f5e9" # Green for Free/System structures
      stroke: "#2e7d32"
      stroke-width: 2
    }
  }
  memory_block: {
    style: {
      font: mono
      fill: "#e3f2fd" # Blue for Data/Memory
      stroke: "#1565c0"
    }
  }
  padding_block: {
    style: {
      fill: "#eeeeee" # Gray Padding per spec
      stroke: "#bdbdbd"
      stroke-dash: 2
    }
  }
  data_field: {
    style: {
      fill: "#bbdefb" # Blue Data per spec
    }
  }
}

# -----------------------------------------------------------------------------------------
# 1. MEMORY LAYOUT: SQLITE_STAT1 RECORD (ON-DISK PHYSICAL)
# -----------------------------------------------------------------------------------------
physical_layout: {
  stat1_record_layout: "sqlite_stat1 Record Payload (Serial Format)" {
    shape: sql_table
    style.fill: "#f3e5f5"

    header: "Byte Offset | Size | Field Name | Serial Type | Purpose" { class: header_row }
    
    field_0: "0x00 | 1-9B | Table Name Len | Varint | Payload Header (Serial Type)"
    field_1: "0x01 | 1-9B | Index Name Len | Varint | Payload Header (Serial Type)"
    field_2: "0x02 | 1-9B | Stat String Len| Varint | Payload Header (Serial Type)"
    
    data_0: "0x03 | NB | 'Users' | Text | Target Table Name" {
      class: data_field
    }
    data_1: "0x03+N | MB | 'idx_u_age' | Text | Target Index Name" {
      class: data_field
    }
    data_2: "0x03+N+M | LB | '100000 10 2' | Text | Computed Aggregates" {
      class: data_field
    }
    
    alignment_padding: "0xXX | 0-7B | Padding | 0x00 | Alignment to 8-byte boundary" {
      class: padding_block
    }

    tooltip: "sizeof = Header_Len + N + M + L + Padding"
  }
}

# -----------------------------------------------------------------------------------------
# 2. ALGORITHM STATE TRANSITIONS
# Wrapped in a non-grid container to allow 'near' positioning and avoid compilation error
# -----------------------------------------------------------------------------------------
stats_collection_wrapper: "ANALYZE: Statistics Collection Engine" {
  
  stats_grid: {
    grid-rows: 2
    grid-columns: 2
    grid-gap: 80

    # --- STEP 1: INITIAL STATE ---
    step_1: "1. Initialization" {
      style.stroke-dash: 4
      
      user_table: "User Table (B-Tree)" {
        shape: cylinder
        root_page: "Page 2"
        leaf_pages: "Pages 5, 8, 12"
      }

      sqlite_stat1: "sqlite_stat1 (System Table)" {
        class: system_table
        shape: sql_table
        header: "tbl | idx | stat" {class: header_row}
        row_empty: "NULL | NULL | NULL"
      }

      internal_memory: "VDBE Registers" {
        class: memory_block
        row_count: 0
        idx_count: 0
      }
    }

    # --- STEP 2: SCANNING ---
    step_2: "2. Full Table/Index Scan" {
      style.stroke-dash: 4

      user_table: "User Table (B-Tree)" {
        shape: cylinder
        root_page: "Page 2"
        leaf_pages: "Pages 5, 8, 12"
        cursor: "Scanning Leaf 8..." {class: changed_state}
      }

      internal_memory: "VDBE Registers" {
        class: memory_block
        row_count: 4200 {class: changed_state}
        current_key_uniqueness: "High" {class: changed_state}
      }

      user_table.cursor -> internal_memory.row_count: "Iterate & Increment" {
        style.stroke: red
        style.animated: true
      }
    }

    # --- STEP 3: AGGREGATION ---
    step_3: "3. Statistical Computation" {
      style.stroke-dash: 4

      logic: "Calculation Engine" {
        formula: |md
          **Stat String Generation**
          `stat = total_rows / unique_keys`
          `precision: integer floor`
        |
      }

      stat_buffer: "Result Buffer" {
        class: memory_block
        computed_stat: "'100000 10 2'" {class: changed_state}
      }

      internal_memory -> logic: "Input row counts"
      logic -> stat_buffer: "Format string"
    }

    # --- STEP 4: PERSISTENCE ---
    step_4: "4. System Table Update" {
      style.stroke-dash: 4

      sqlite_stat1: "sqlite_stat1 (System Table)" {
        class: system_table
        shape: sql_table
        header: "tbl | idx | stat" {class: header_row}
        row_data: "Users | idx_u_age | 100000 10 2" {class: changed_state}
      }

      journal: "Rollback Journal" {
        shape: package
        record: "Update Page 1 (stat1)"
      }

      stat_buffer.computed_stat -> sqlite_stat1.row_data: "INSERT OR REPLACE" {
        style.stroke: red
        style.bold: true
      }
    }
  }
}

# -----------------------------------------------------------------------------------------
# 3. VDBE OPCODE SEQUENCE
# -----------------------------------------------------------------------------------------
vdbe_engine: "VDBE Execution Trace: OP_Analyze" {
  shape: sequence_diagram
  
  OpOpenRead: "OP_OpenRead\n(P1=Cursor)"
  OpRewind: "OP_Rewind\n(P2=JumpEnd)"
  OpColumn: "OP_Column\n(P3=Extract)"
  OpNext: "OP_Next\n(P4=LoopBack)"
  OpInsert: "OP_Insert\n(P5=sqlite_stat1)"

  OpOpenRead.t1 -> OpRewind.t1: "Open B-Tree Cursor"
  
  iteration_loop: "Row iteration for stats aggregation" {
    OpRewind.t2 -> OpColumn.t2: "Extract P3 Key"
    OpColumn.t2 -> OpNext.t2: "Sample/Count"
    OpNext.t2 -> OpColumn.t3: "Increment B-Tree Cursor"
  }
  
  OpNext.t4 -> OpInsert.t4: "Flush Stats to stat1" {
    style.stroke: "#2e7d32"
    style.bold: true
  }
}

# -----------------------------------------------------------------------------------------
# 4. ANNOTATIONS
# FIXED: Pointing 'near' to the wrapper container, not the grid itself or its cells
# -----------------------------------------------------------------------------------------
implementation_annotation: |md
  ## Implementation Notes: Statistics Collection (ANALYZE)
  
  ### 1. Physical Representation
  `sqlite_stat1` is a standard B-Tree table. The `stat` column contains space-separated 
  integers representing the average selectivity of index columns.

  ### 2. Statistical Logic
  - `stat[0]`: Total row count in the table/index.
  - `stat[1]`: `Total / Distinct(Col1)`
  - `stat[2]`: `Total / Distinct(Col1, Col2)`

  ### 3. VDBE Performance
  The `OP_Analyze` logic requires a full scan. It performs `O(N)` I/O, where N is 
  the number of pages in the target index.
| {
  near: stats_collection_wrapper
  style.fill: "#fff9c4"
  style.stroke: "#fbc02d"
}

# Link physical layout to logical persistence
# Note: Connections from outside to specific grid cells are often restricted by layout engines.
# We connect to the parent container for robust compilation.
physical_layout.stat1_record_layout -> stats_collection_wrapper: "Physical Record Format" {
  style.stroke-dash: 5
  style.stroke: orange
}