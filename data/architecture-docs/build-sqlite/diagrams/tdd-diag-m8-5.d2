vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- GLOBAL CLASSES AND STYLING ---
# Colors: Header=Purple, Data=Blue, Free=Green, Padding=Gray, Pointers=Orange
classes: {
  header: {
    style: {
      fill: "#6f42c1"
      font-color: white
      bold: true
      font-size: 16
    }
  }
  mem_data: {
    style: {
      fill: "#cfe2ff"
      stroke: "#0d6efd"
      font: mono
    }
  }
  mem_ptr: {
    style: {
      fill: "#fff3cd"
      stroke: "#ffc107"
      font: mono
    }
  }
  mem_pad: {
    style: {
      fill: "#e2e3e5"
      stroke: "#6c757d"
      stroke-dash: 3
    }
  }
  interface_spec: {
    style: {
      fill: "#d1e7dd"
      stroke: "#198754"
      font: mono
      border-radius: 4
    }
  }
  algorithm_note: {
    style: {
      fill: "#f8d7da"
      stroke: "#dc3545"
      italic: true
      font-size: 12
    }
  }
}

# --- 1. MEMORY LAYOUT DIAGRAM ---
# Precise hardware-level mapping for byte-alignment verification
AggFunc_Memory_Layout: {
  label: "AggFunc Memory Layout (sizeof=16B, align=8)"
  tooltip: "Structure alignment verified for x86_64 ABI"
  
  grid-rows: 4
  grid-columns: 4
  grid-gap: 0
  
  # Row 1: Headers
  h_off: "Offset" { class: header }
  h_field: "Field" { class: header }
  h_type: "Type" { class: header }
  h_size: "Size" { class: header }
  
  # Row 2: type field (0x00)
  r1_off: "0x00" { class: mem_data }
  r1_f: "type" { class: mem_data }
  r1_t: "AggType (enum)" { class: mem_data }
  r1_s: "4 Bytes" { class: mem_data }
  
  # Row 3: colIdx field (0x04)
  r2_off: "0x04" { class: mem_data }
  r2_f: "colIdx" { class: mem_data }
  r2_t: "int32_t" { class: mem_data }
  r2_s: "4 Bytes" { class: mem_data }
  
  # Row 4: accum field (0x08) - Pointer/Union Data
  r3_off: "0x08" { class: mem_ptr; style.bold: true }
  r3_f: "accum.iVal / accum.rVal" { class: mem_ptr; style.bold: true }
  r3_t: "union (long long / double)" { class: mem_ptr; style.bold: true }
  r3_s: "8 Bytes" { class: mem_ptr; style.bold: true }
}

# Floating annotation for memory layout
AggFunc_Memory_Annotation: |md
  ### Hardware Context (AggFunc)
  - **Field `accum`** is 8-byte aligned (starts at 0x08).
  - Total object size: **16 Bytes**.
  - Fits exactly into **1/4th** of a standard **64B L1 Cache Line**.
  - **No Padding**: 4B (type) + 4B (colIdx) = 8B, which aligns perfectly with the next 8B union.
| {
  near: bottom-right
  style.stroke-width: 1
  style.fill: "#fdfdfe"
}

# --- 2. ARCHITECTURE DIAGRAM ---
Architecture: {
  label: "Structural Relationship: Aggregation & Join Contexts"
  
  AggType: {
    shape: class
    COUNT: 0
    SUM: 1
    AVG: 2
    MIN: 3
    MAX: 4
  }

  AggFunc: {
    shape: class
    type: AggType
    colIdx: int
    accum: union_val
    definition: "sizeof=16B"
    style.fill: "#6f42c1"
    style.font-color: white
  }

  AggInfo: {
    shape: class
    funcs: "*AggFunc"
    nFunc: int
    groupByCols: int
    currentGroup: int
    definition: "sizeof=32B"
  }

  JoinCtx: {
    shape: class
    leftCursor: "*Cursor"
    rightCursor: "*Cursor"
    onCondition: "*Expr"
    type: JoinType
    definition: "sizeof=48B"
  }

  AggInfo -> AggFunc: "owns [0..N]" { 
    style: {
      stroke-width: 3
      stroke: "#6f42c1"
    } 
  }
  JoinCtx -> AggType: "references" { 
    style: {
      stroke-dash: 5
      stroke: "#0d6efd"
    } 
  }
}

# --- 3. SEQUENCE DIAGRAM ---
Nested_Loop_Join_Algorithm: {
  shape: sequence_diagram
  label: "Execution Algorithm: Nested Loop Join"

  # Participants
  Outer: LeftRelation {
    shape: person
    style.fill: "#cfe2ff"
  }
  Evaluator: JoinLogic {
    style.fill: "#fff3cd"
    style.double-border: true
  }
  Inner: RightRelation {
    shape: person
    style.fill: "#cfe2ff"
  }
  Output: ResultSet {
    shape: cylinder
    style.fill: "#d1e7dd"
  }

  Outer -> Evaluator: "Fetch Next Row (R_outer)"
  
  Evaluator -> Inner: "Open/Reset Cursor"
  
  Loop_Block: {
    label: "FOR EACH row in InnerRelation"
    Inner -> Evaluator: "Return Row (R_inner)"
    
    Evaluator -> Evaluator: "eval(pCond, R_outer, R_inner)" {
      style: {
        font-color: red
        bold: true
        stroke: red
      }
    }
    
    Evaluator -> Output: "Emit Tuple(R_outer, R_inner)" {
      label: "If Match Found"
      style: {
        stroke: green
        stroke-width: 3
      }
    }
  }
  
  Evaluator -> Outer: "Request Next Outer Row"
}

# --- 4. INTERFACE CONTRACTS ---
Execution_Interfaces: {
  Agg_API: {
    label: "Aggregation Interface (AggFunc.h)"
    aggInit: "int aggInit(AggInfo *p, int n)" { class: interface_spec }
    aggStep: "int aggStep(AggInfo *p, Expr **args)" { class: interface_spec }
    aggFinal: "int aggFinal(AggInfo *p, Mem *out)" { class: interface_spec }
  }

  Join_API: {
    label: "Join Interface (JoinLogic.h)"
    joinExec: "int joinExec(JoinCtx *ctx, RS *res)" { class: interface_spec }
    joinNL: "int joinNL(JoinCtx *ctx, Expr *cond)" { class: interface_spec }
  }
}

# --- 5. TECHNICAL SPECIFICATIONS ---
Technical_Vectors: {
  label: "Validation Matrix: State Transition & Iteration Complexity"
  near: bottom-center
  
  spec_table: ||md
| ID | Logic Gate | Input | Expected Internal State Change | Alignment Check |
|:---|:---|:---|:---|:---|
| **T-10** | SUM | `int64` | `accum.iVal += row[colIdx]` | 8-byte atomic |
| **T-11** | AVG | `float64` | `count++`; `accum.rVal += row[colIdx]` | FPU context |
| **T-20** | NLJ | `Cross` | `nOuter * nInner` iterations | O(N*M) |
| **T-21** | NLJ | `Inner` | `match_count` emitted to `ResultSet` | Predicate match |
||
}

# --- CACHE EFFICIENCY VISUALIZER ---
Cache_Efficiency: {
  label: "Memory Locality Analysis"
  near: top-right
  
  L1_Cache: {
    label: "64-Byte L1 Cache Line"
    grid-columns: 4
    grid-gap: 5
    obj0: "AggFunc[0]" { style.fill: "#bbd6fe"; style.stroke-dash: 0; tooltip: "Bytes 0-15" }
    obj1: "AggFunc[1]" { style.fill: "#bbd6fe"; style.stroke-dash: 0; tooltip: "Bytes 16-31" }
    obj2: "AggFunc[2]" { style.fill: "#bbd6fe"; style.stroke-dash: 0; tooltip: "Bytes 32-47" }
    obj3: "AggFunc[3]" { style.fill: "#bbd6fe"; style.stroke-dash: 0; tooltip: "Bytes 48-63" }
  }
}

# --- TRACEABILITY CONNECTIONS ---

# Interface implementation links
Execution_Interfaces.Agg_API.aggStep -> Architecture.AggFunc: "Updates accum" {
  style: { stroke: orange; stroke-width: 2 }
}

Execution_Interfaces.Join_API.joinNL -> Nested_Loop_Join_Algorithm: "Strategy implementation" {
  style: { stroke: orange; stroke-dash: 5 }
}

# Logic mapping
Nested_Loop_Join_Algorithm -> Technical_Vectors: "Validates T-20 Complexity" {
  style.opacity: 0.3
}