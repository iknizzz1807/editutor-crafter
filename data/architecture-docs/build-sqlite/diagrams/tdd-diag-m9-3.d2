layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# 1. MEMORY LAYOUTS: WAL DATA STRUCTURES
# Exact byte offsets left margin, field sizes right margin.
# Purple=Header, Blue=Data, Green=Padding, Orange=Pointers/Metadata.

layouts: {
  wal_header: {
    shape: sql_table
    label: "WAL Header Layout (32 Bytes total) | sizeof=32"
    style.fill: "#E1D5E7" # Purple Header
    
    "00-03": "magic_number: 0x377f0682" {constraint: "4B"}
    "04-07": "file_format: 3007000" {constraint: "4B"}
    "08-11": "page_size: uint32" {constraint: "4B"}
    "12-15": "checkpoint_seq: uint32" {constraint: "4B"}
    "16-23": "salt_1 / salt_2" {constraint: "8B"}
    "24-31": "checksum_1 / checksum_2" {constraint: "8B"}
  }

  wal_frame: {
    shape: sql_table
    label: "WAL Frame Layout (Header + Page Data) | sizeof=24+page_size"
    
    # Header Section (Offsets 0-23)
    "00-03": "page_number: uint32" {constraint: "4B"; style.fill: "#E1D5E7"}
    "04-07": "for_commit: uint32" {constraint: "4B"; style.fill: "#E1D5E7"}
    "08-15": "salt: uint32[2]" {constraint: "8B"; style.fill: "#E1D5E7"}
    "16-23": "checksum: uint32[2]" {constraint: "8B"; style.fill: "#E1D5E7"}
    
    # Data Section (Offsets 24+)
    "24-end": "page_payload: [page_size] bytes" {constraint: "4096B"; style.fill: "#DAE8FC"}
    
    # Padding Section
    "tail": "sector_padding: zero-fill" {constraint: "VAR"; style.fill: "#D3D3D3"}
  }

  wal_index: {
    shape: sql_table
    label: "WalIndexHdr (Shared Memory Structure) | sizeof=48"
    style.fill: "#FFE6CC" # Orange Metadata
    
    "00-03": "version: uint32" {constraint: "4B"}
    "04-07": "unused: uint32" {constraint: "4B"}
    "08-11": "change_counter: uint32" {constraint: "4B"}
    "12-15": "is_init | endian | page_size" {constraint: "4B"}
    "16-19": "mx_frame: uint32 (Current WAL Tip)" {
      constraint: "4B"
      style: {
        font-color: red
        bold: true
      }
    }
    "20-23": "n_page: uint32 (Total DB Pages)" {constraint: "4B"}
  }
}

# 2. ARCHITECTURE: SYSTEM COMPONENTS
arch: {
  writer: Writer Process {
    shape: person
    style.fill: "#F8CECC"
  }

  shm: "wal-index (shm)" {
    shape: cylinder
    style.fill: "#FFF2CC"
    style.stroke-dash: 5
    label.near: top-center
  }

  wal_file: "WAL File (.wal)" {
    shape: queue
    style.fill: "#DAE8FC"
    f1: "Frame 1"
    f2: "Frame 2"
    f3: "Frame 3"
    f4: "..."
  }

  db_file: "Database File (.db)" {
    shape: cylinder
    style.fill: "#D5E8D4"
    p1: "Header"
    p2: "B-Tree Page"
    p3: "B-Tree Page"
  }

  writer -> shm: "Update mx_frame (Atomic 32-bit Store)"
  writer -> wal_file: "Append Frames (pwrite)"
  shm -> wal_file: "Mapped Reference"
  wal_file -> db_file: "Checkpoint (Backfill Operation)" {
    style.stroke-dash: 3
    source-arrowhead: * { shape: diamond }
  }
}

# 3. SEQUENCE DIAGRAM: WRITE ORDERING
write_ordering: {
  shape: sequence_diagram
  label: "WAL Write & Commit Transaction Sequence"

  writer: Writer { shape: person }
  wal: WAL File { style.fill: "#DAE8FC" }
  shm: SHM Index { style.fill: "#FFF2CC" }
  db: DB File { style.fill: "#D5E8D4" }

  writer -> wal: "wal_write_header() (if new file)"
  writer -> wal: "wal_append_frame(page_1, checksum_1)"
  writer -> wal: "wal_append_frame(page_2, checksum_2)"
  
  writer -> writer: "compute_wal_checksum(salt, header, data)"
  
  # CRITICAL DURABILITY POINT
  writer -> wal: "fsync() barrier" {
    style: {
      stroke: red
      stroke-width: 3
      bold: true
    }
  }
  wal -> writer: "ACK: Persistent on Platter"
  
  # ATOMIC COMMIT POINT
  writer -> shm: "Atomic Update: mx_frame = 2"
  shm -> writer: "SFENCE / Memory Barrier"
  
  writer -> writer: "Transaction Visible to Readers"

  checkpoint_proc: Checkpoint Process {
    writer -> shm: "Acquire Exclusive Checkpoint Lock"
    writer -> shm: "Read n_backfill"
    writer -> wal: "Read Frames [n_backfill + 1 ... mx_frame]"
    writer -> db: "Overwrite main DB pages"
    writer -> db: "fsync() DB"
    writer -> shm: "Update n_backfill = mx_frame"
    writer -> shm: "Release Checkpoint Lock"
  }
}

# 4. ALGORITHM STATE: HASH JOIN PIPELINE
hash_join: {
  grid-columns: 2
  grid-gap: 50
  
  build_phase: {
    label: "PHASE 1: BUILD (Inner Table Scan)"
    style.fill: "#F9F9F9"
    
    table_inner: {
      shape: sql_table
      r1: "Key: 0xA1 | Val: Data_1" { style.fill: "#FFEBCC" }
      r2: "Key: 0xB2 | Val: Data_2"
      r3: "Key: 0xC3 | Val: Data_3"
    }
    
    hash_func: "MurmurHash3(Key)" { 
      shape: diamond 
      style.fill: "#D5E8D4"
    }
    
    hash_table: {
      grid-columns: 2
      label: "In-Memory Hash Map"
      style.fill: "#FFF2CC"
      slot_0: "0xA1 -> [ptr_r1]" { style.stroke: red; style.stroke-width: 2 }
      slot_1: "EMPTY"
      slot_2: "0xB2 -> [ptr_r2]"
      slot_3: "0xC3 -> [ptr_r3]"
    }
    
    table_inner.r1 -> hash_func: "Stream"
    hash_func -> hash_table.slot_0: "Insert"
  }

  probe_phase: {
    label: "PHASE 2: PROBE (Outer Table Scan)"
    style.fill: "#F9F9F9"
    
    table_outer: {
      shape: sql_table
      o1: "FK: 0xA1 | Payload_A" { style.fill: "#D1E8FF" }
      o2: "FK: 0xD4 | Payload_D"
    }
    
    probe_func: "MurmurHash3(FK)" { 
      shape: diamond
      style.fill: "#D5E8D4"
    }
    
    result: "JOIN OUTPUT" {
      shape: sql_table
      style.fill: "#D5E8D4"
      match: "Row(0xA1) {Data_1, Payload_A}" { style.bold: true }
    }
    
    table_outer.o1 -> probe_func: "Scan"
    probe_func -> build_phase.hash_table.slot_0: "Lookup 0xA1" { 
      style.stroke: blue
      style.animated: true 
    }
    build_phase.hash_table.slot_0 -> result.match: "Emit on Match"
  }
}

# 5. DOCUMENTATION ANNOTATIONS
ann: |md
  ### SQLite WAL Implementation Specification
  - **Durability Guarantee**: The `mx_frame` update in SHM must only occur after the `fsync()` of the WAL file.
  - **Memory Layouts**: WAL frame header is exactly 24 bytes, followed by `page_size` data bytes.
  - **Write Barriers**: Sequence diagram highlights where hardware memory barriers (`SFENCE`) are required to prevent out-of-order stores from leaking a partial transaction to readers.
  - **Hash Join Constraints**: Built as a fixed-slot hash table with linked-list collision resolution (pointers indicated in build phase).
| {
  near: bottom-center
  style: {
    font-size: 14
    stroke: "#333333"
    fill: "#FDFDFD"
  }
}