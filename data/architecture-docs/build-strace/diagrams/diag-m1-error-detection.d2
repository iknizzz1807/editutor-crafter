direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## x86_64 Syscall Return Value Space — Errno Detection: The [-4096, -1] Range
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  number_line: "Return Value Space (signed 64-bit)" {
    direction: down
    style.fill: "#f8f9fa"
    style.stroke: "#aaaaaa"
    style.border-radius: 8
    pos_zone: "POSITIVE / ZERO — Always Success" {
      shape: sql_table
      label: "rax ∈ [0, +∞)  →  Success"
      r1: "0x0000000000000000 | 0          | read() = 0 bytes (EOF)"
      r2: "0x0000000000000001 | 1          | write() = 1 byte written"
      r3: "0x0000000000000003 | 3          | open() = fd 3"
      r4: "0x0000000000001000 | 4096       | mmap size / read count"
      r5: "0x7FFFFFFFFFFFFFFF | INT64_MAX  | lseek() large positive offset"
      style.fill: "#d4edda"
      style.stroke: "#28a745"
    }
    gap_note: "Ambiguous Zone (NOT used by kernel as error)" {
      shape: sql_table
      label: "rax ∈ [-2^63, -4096)  →  Valid negative OR unrelated"
      g1: "0x8000000000000000 | INT64_MIN  | NOT an errno — too large"
      g2: "0xFFFFFFFFFFFF0000 | -65536     | NOT an errno — outside range"
      g3: "0xFFFFFFFFFFFFF000 | -4096      | BOUNDARY — first INVALID errno slot"
      note: "kernel never uses values below -4095 as errno codes"
      style.fill: "#fff3cd"
      style.stroke: "#ffc107"
    }
    err_zone: "ERROR ZONE [-4095, -1]  →  Negated errno code" {
      shape: sql_table
      label: "rax ∈ [-4095, -1]  (0xFFFFFFFFFFFFF001 … 0xFFFFFFFFFFFFFFFF)"
      e1: "0xFFFFFFFFFFFFFFFF | -1   = EPERM   | Operation not permitted"
      e2: "0xFFFFFFFFFFFFFFFE | -2   = ENOENT  | No such file or directory"
      e3: "0xFFFFFFFFFFFFFFFD | -3   = ESRCH   | No such process"
      e4: "0xFFFFFFFFFFFFFFFC | -4   = EINTR   | Interrupted system call"
      e5: "0xFFFFFFFFFFFFFFF3 | -13  = EACCES  | Permission denied"
      e6: "0xFFFFFFFFFFFFFFEA | -22  = EINVAL  | Invalid argument"
      e7: "0xFFFFFFFFFFFFF001 | -4095 = ERESTARTSYS | restart boundary"
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
    }
  }
  check_logic: "Detection Logic (ptrace.c)" {
    direction: down
    style.fill: "#eef2ff"
    style.stroke: "#6c63ff"
    style.border-radius: 8
    wrong_check: "WRONG: Simple < 0 Check" {
      shape: sql_table
      label: "if (retval < 0)  ← BUG"
      w1: "Problem     | lseek() CAN return large positive"
      w2: "Problem     | mmap addr might look negative"
      w3: "Consequence | misclassifies valid returns as errors"
      w4: "Severity    | silent wrong errno output"
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
    }
    correct_check: "CORRECT: Range Check" {
      shape: sql_table
      label: "is_error_return() — reactor.c pattern"
      c1: "Condition   | retval >= -4095L"
      c2: "Condition   | retval < 0"
      c3: "Both true   | → it IS an error"
      c4: "errno code  | err = (int)(-retval)"
      c5: "errno name  | errno_name(err)"
      style.fill: "#d4edda"
      style.stroke: "#28a745"
    }
    code_box: "is_error_return (tracer.c)" {
      width: 380
      code: |'c
        static int is_error_return(long retval) {
            /* kernel errno range: [-4095, -1] */
            return (retval >= -4095L && retval < 0);
        }
      '|
    }
    wrong_check -> correct_check: "fix"
    correct_check -> code_box: "implements"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  common_errnos: "Common errno Mappings (x86_64 Linux)" {
    shape: sql_table
    label: "struct errno_map — errno-base.h subset"
    h0: "rax (signed) | rax (hex)           | errno sym  | strerror"
    m1: "-1           | 0xFFFFFFFFFFFFFFFF   | EPERM      | Operation not permitted"
    m2: "-2           | 0xFFFFFFFFFFFFFFFE   | ENOENT     | No such file or directory"
    m3: "-4           | 0xFFFFFFFFFFFFFFFC   | EINTR      | Interrupted system call"
    m4: "-9           | 0xFFFFFFFFFFFFFFF7   | EBADF      | Bad file descriptor"
    m5: "-11          | 0xFFFFFFFFFFFFFFF5   | EAGAIN     | Try again (non-block)"
    m6: "-12          | 0xFFFFFFFFFFFFFFF4   | ENOMEM     | Out of memory"
    m7: "-13          | 0xFFFFFFFFFFFFFFF3   | EACCES     | Permission denied"
    m8: "-14          | 0xFFFFFFFFFFFFFFF2   | EFAULT     | Bad address"
    m9: "-17          | 0xFFFFFFFFFFFFFFEF   | EEXIST     | File exists"
    ma: "-22          | 0xFFFFFFFFFFFFFFEA   | EINVAL     | Invalid argument"
    mb: "-28          | 0xFFFFFFFFFFFFFFE4   | ENOSPC     | No space left on device"
    mc: "-110         | 0xFFFFFFFFFFFFFF92   | ETIMEDOUT  | Connection timed out"
    md: "-4095        | 0xFFFFFFFFFFFFF001   | max errno  | boundary (ERESTARTSYS)"
    style.fill: "#eef2ff"
    style.stroke: "#6c63ff"
  }
  stop_type_impact: "Impact on Tracer Stop Handling" {
    shape: sql_table
    label: "Where errno detection is called (tracer loop)"
    s1: "Entry stop  | orig_rax read  | do NOT call is_error_return"
    s2: "Exit stop   | rax read       | CALL is_error_return(regs.rax)"
    s3: "On error    | print -1 ENAME | fprintf: = -1 ENOENT (msg)"
    s4: "On success  | print retval   | fprintf: = 3"
    s5: "Stats accum | error_count++  | only when is_error_return true"
    s6: "Filter gate | after stats    | filter does NOT affect stats"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
  }
}
row1.number_line.pos_zone -> row1.number_line.gap_note: "decreasing rax"
row1.number_line.gap_note -> row1.number_line.err_zone: "enters error zone at -4095"
row1.number_line.err_zone -> row1.check_logic.wrong_check: "raw rax value"
row2.common_errnos -> row2.stop_type_impact: "errno table | lookup"