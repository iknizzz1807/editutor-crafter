direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## ptrace Tracing Lifecycle — Fork → TRACEME → Exec → SIGTRAP → Loop
| {near: top-center}
row0: "" {
  style.stroke: transparent
  style.fill: transparent
  direction: right
  parent_col: "TRACER PROCESS (parent)" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.stroke-width: 2
    style.font-size: 13
    style.bold: true
    direction: down
    p1: "① fork()" {
      shape: step
      style.fill: "#bfdbfe"
      style.stroke: "#2563eb"
    }
    p2: "④ waitpid(child, &status, 0)" {
      shape: step
      style.fill: "#bfdbfe"
      style.stroke: "#2563eb"
    }
    p2_note: "status: WIFSTOPPED=true" {
      shape: sql_table
      label: "Post-exec SIGTRAP Stop"
      n1: "WIFSTOPPED(status) | true"
      n2: "WSTOPSIG(status)   | SIGTRAP (5)"
      n3: "status >> 16       | 0 (no ptrace event)"
    }
    p3: "⑥ PTRACE_SETOPTIONS" {
      shape: step
      style.fill: "#bfdbfe"
      style.stroke: "#2563eb"
    }
    p3_opts: "Options Bitmask" {
      shape: sql_table
      label: "PTRACE_SETOPTIONS flags"
      o1: "PTRACE_O_TRACESYSGOOD  | 0x01 — set bit7 on syscall stops"
      o2: "PTRACE_O_TRACEFORK     | 0x02 — auto-attach fork children"
      o3: "PTRACE_O_TRACEVFORK    | 0x04 — auto-attach vfork children"
      o4: "PTRACE_O_TRACECLONE    | 0x08 — auto-attach clone children"
      o5: "PTRACE_O_TRACEEXEC     | 0x10 — stop on execve completion"
    }
    p4: "⑦ PTRACE_SYSCALL(child, 0, 0)" {
      shape: step
      style.fill: "#bfdbfe"
      style.stroke: "#2563eb"
    }
    p4_note: "last arg=0: deliver no signal" {
      shape: rectangle
      style.fill: "#eff6ff"
      style.stroke: "#93c5fd"
      style.font-size: 11
    }
  }
  kernel_col: "LINUX KERNEL" {
    style.fill: "#fef3c7"
    style.stroke: "#d97706"
    style.stroke-width: 2
    style.font-size: 13
    style.bold: true
    direction: down
    k1: "fork() syscall handler" {
      shape: hexagon
      style.fill: "#fde68a"
      style.stroke: "#b45309"
    }
    k1_detail: "do_fork internals" {
      shape: sql_table
      label: "Kernel fork() work"
      r1: "alloc task_struct    | ~4KB allocation"
      r2: "copy_mm (COW)        | dup page table, mark read-only"
      r3: "copy fd table        | share open file descriptors"
      r4: "assign new PID       | e.g. 1235"
      r5: "set TASK_RUNNING     | child ready to schedule"
    }
    k2: "exec syscall handler" {
      shape: hexagon
      style.fill: "#fde68a"
      style.stroke: "#b45309"
    }
    k2_detail: "execve() work" {
      shape: sql_table
      label: "Kernel execve() work"
      e1: "flush old address space | unmap all vmas"
      e2: "load ELF binary          | map .text .data .bss"
      e3: "map stack segment        | fresh 8MB stack"
      e4: "map vDSO / ld.so         | dynamic linker"
      e5: "detect PT_PTRACED flag   | tracee has tracer"
      e6: "send SIGTRAP to child    | stops before 1st instruction"
      e7: "wake tracer waitpid      | parent unblocks"
    }
    k3: "PTRACE_SYSCALL handler" {
      shape: hexagon
      style.fill: "#fde68a"
      style.stroke: "#b45309"
    }
    k3_detail: "syscall stop machinery" {
      shape: sql_table
      label: "TIF_SYSCALL_TRACE flag"
      s1: "set TIF_SYSCALL_TRACE | in thread_info flags"
      s2: "child → TASK_RUNNING  | added to run queue"
      s3: "child hits syscall    | trap into kernel"
      s4: "kernel stops child    | TASK_TRACED state"
      s5: "notify tracer         | wake waitpid queue"
    }
  }
  child_col: "TRACEE PROCESS (child)" {
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
    style.stroke-width: 2
    style.font-size: 13
    style.bold: true
    direction: down
    c1: "② ptrace(PTRACE_TRACEME, 0, NULL, NULL)" {
      shape: step
      style.fill: "#bbf7d0"
      style.stroke: "#15803d"
    }
    c1_note: "TRACEME semantics" {
      shape: sql_table
      label: "What PTRACE_TRACEME does"
      t1: "sets PT_PTRACED       | in task_struct.ptrace"
      t2: "parent becomes tracer | kernel records relationship"
      t3: "must call before exec | after exec: code is replaced"
      t4: "returns 0 on success  | or -1 errno"
    }
    c2: "③ execvp(argv[0], argv)" {
      shape: step
      style.fill: "#bbf7d0"
      style.stroke: "#15803d"
    }
    c2_note: "execvp vs execve" {
      shape: rectangle
      style.fill: "#f0fdf4"
      style.stroke: "#86efac"
      style.font-size: 11
      label: "execvp: searches PATH — use for tracing named programs\nexecve: requires absolute path"
    }
    c3: "⑤ STOPPED before 1st instruction" {
      shape: step
      style.fill: "#fef9c3"
      style.stroke: "#ca8a04"
    }
    c3_note: "Child state at first stop" {
      shape: sql_table
      label: "Registers at post-exec SIGTRAP"
      r1: "RIP | entry point of new program"
      r2: "RSP | top of fresh 8MB stack"
      r3: "RAX | 0 (execve return value)"
      r4: "RDI | argc"
      r5: "RSI | argv ptr"
      r6: "RDX | envp ptr"
    }
    c4: "⑧ runs to first syscall" {
      shape: step
      style.fill: "#bbf7d0"
      style.stroke: "#15803d"
    }
  }
}
loop_box: "MAIN TRACING LOOP (repeats until child exits)" {
  style.fill: "#faf5ff"
  style.stroke: "#7c3aed"
  style.stroke-width: 2
  direction: right
  entry_stop: "SYSCALL-ENTRY STOP" {
    style.fill: "#ede9fe"
    style.stroke: "#7c3aed"
    direction: down
    es1: "waitpid(-1, &status, 0) returns" {
      shape: step
      style.fill: "#ddd6fe"
      style.stroke: "#6d28d9"
    }
    es2: "Registers at entry stop" {
      shape: sql_table
      label: "PTRACE_GETREGS → user_regs_struct"
      f1: "orig_rax | syscall number (e.g. 2 = open)"
      f2: "rax      | same as orig_rax at entry"
      f3: "rdi      | arg1"
      f4: "rsi      | arg2"
      f5: "rdx      | arg3"
      f6: "r10      | arg4 (NOT rcx — syscall ABI)"
      f7: "r8       | arg5"
      f8: "r9       | arg6"
      f9: "NOTE     | kernel has NOT executed syscall yet"
    }
    es3: "in_syscall toggle → 1\nrecord orig_rax, args\nprint syscall_name(args" {
      shape: rectangle
      style.fill: "#ede9fe"
      style.stroke: "#a78bfa"
      style.font-size: 11
      label: "Tracer action at entry"
    }
    es4: "PTRACE_SYSCALL(pid, 0, 0)" {
      shape: step
      style.fill: "#ddd6fe"
      style.stroke: "#6d28d9"
    }
  }
  exit_stop: "SYSCALL-EXIT STOP" {
    style.fill: "#ecfdf5"
    style.stroke: "#059669"
    direction: down
    xs1: "waitpid(-1, &status, 0) returns" {
      shape: step
      style.fill: "#d1fae5"
      style.stroke: "#047857"
    }
    xs2: "Registers at exit stop" {
      shape: sql_table
      label: "PTRACE_GETREGS → user_regs_struct"
      g1: "orig_rax | syscall number PRESERVED"
      g2: "rax      | return value (may be negative errno)"
      g3: "rdi-r9   | may be clobbered by kernel"
      g4: "ERROR    | retval in [-4095, -1] = -errno"
      g5: "SUCCESS  | retval >= 0 or large ptr"
    }
    xs3: "Error detection" {
      shape: sql_table
      label: "is_error_return(retval)"
      h1: "condition  | retval >= -4095L && retval < 0"
      h2: "error fmt  | ) = -1 ERRNO_NAME (strerror)"
      h3: "ok fmt     | ) = retval"
      h4: "WHY -4095  | valid negatives (mmap addrs) outside this range"
    }
    xs4: "in_syscall toggle → 0\nprint ) = retval newline\naccumulate timing stats" {
      shape: rectangle
      style.fill: "#ecfdf5"
      style.stroke: "#6ee7b7"
      style.font-size: 11
      label: "Tracer action at exit"
    }
    xs5: "PTRACE_SYSCALL(pid, 0, 0)" {
      shape: step
      style.fill: "#d1fae5"
      style.stroke: "#047857"
    }
  }
  signal_stop: "SIGNAL-DELIVERY STOP" {
    style.fill: "#fff1f2"
    style.stroke: "#e11d48"
    direction: down
    ss1: "WSTOPSIG(status) != SIGTRAP" {
      shape: diamond
      style.fill: "#ffe4e6"
      style.stroke: "#be123c"
    }
    ss2: "RE-INJECT: PTRACE_SYSCALL(pid, 0, stop_sig)" {
      shape: step
      style.fill: "#fda4af"
      style.stroke: "#be123c"
    }
    ss3: "SUPPRESS (NEVER): PTRACE_SYSCALL(pid, 0, 0)" {
      shape: step
      style.fill: "#fecdd3"
      style.stroke: "#e11d48"
      style.stroke-dash: 4
    }
    ss_warn: "Signal suppression effects" {
      shape: sql_table
      label: "Why you MUST re-inject signals"
      w1: "SIGTERM suppressed | program never exits cleanly"
      w2: "SIGCHLD suppressed | parent never reaps children"
      w3: "SIGALRM suppressed | timers stop working"
      w4: "SIGPIPE suppressed | writes to closed pipes hang"
    }
  }
}
term_box: "TERMINATION HANDLING" {
  style.fill: "#fff7ed"
  style.stroke: "#ea580c"
  style.stroke-width: 2
  direction: right
  exited: "WIFEXITED(status)" {
    style.fill: "#fed7aa"
    style.stroke: "#c2410c"
    direction: down
    ex1: "WEXITSTATUS(status)" {
      shape: rectangle
      style.fill: "#ffedd5"
    }
    ex2: "+++ exited with N +++" {
      shape: rectangle
      style.fill: "#ffedd5"
    }
  }
  signaled: "WIFSIGNALED(status)" {
    style.fill: "#fecaca"
    style.stroke: "#b91c1c"
    direction: down
    sg1: "WTERMSIG(status)" {
      shape: rectangle
      style.fill: "#fee2e2"
    }
    sg2: "+++ killed by SIGNAME +++" {
      shape: rectangle
      style.fill: "#fee2e2"
    }
  }
  cleanup: "Tracer Cleanup" {
    style.fill: "#e0f2fe"
    style.stroke: "#0284c7"
    direction: down
    cl1: "pid_map_remove(pid)" {
      shape: rectangle
      style.fill: "#bae6fd"
    }
    cl2: "num_active--" {
      shape: rectangle
      style.fill: "#bae6fd"
    }
    cl3: "if num_active==0: print_statistics()" {
      shape: rectangle
      style.fill: "#bae6fd"
    }
  }
}
cost_box: "HARDWARE COST PER TRACED SYSCALL" {
  style.fill: "#f8fafc"
  style.stroke: "#64748b"
  style.stroke-width: 1
  shape: sql_table
  label: "Observer Effect — why tracing slows programs 10x"
  c1: "untraced getpid()         | ~100 ns  | vDSO fast path, no ring-0 switch"
  c2: "ptrace entry context sw   | ~1-10 µs | CR3 load, TLB pressure, PCB save"
  c3: "PTRACE_GETREGS copy       | ~200 ns  | copy_to_user 168 bytes"
  c4: "ptrace exit context sw    | ~1-10 µs | CR3 restore, TLB partial flush"
  c5: "total per syscall         | ~2-20 µs | 20-200x actual syscall cost"
  c6: "ratio for ls /tmp         | ~10x     | 5ms untraced → 50ms traced"
}
row0.parent_col.p1 -> row0.kernel_col.k1: "fork() syscall" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
  style.animated: true
}
row0.kernel_col.k1 -> row0.child_col.c1: "child PID created\nCOW page table" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
}
row0.child_col.c1 -> row0.kernel_col.k1: "PTRACE_TRACEME\nsets PT_PTRACED" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
}
row0.child_col.c2 -> row0.kernel_col.k2: "execvp → execve syscall" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
  style.animated: true
}
row0.kernel_col.k2 -> row0.child_col.c3: "SIGTRAP delivered\nchild TASK_TRACED" {
  style.stroke: "#dc2626"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row0.kernel_col.k2 -> row0.parent_col.p2: "waitpid() unblocks\nWIFSTOPPED" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
}
row0.parent_col.p3 -> row0.kernel_col.k3: "PTRACE_SETOPTIONS\nset trace flags" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
}
row0.parent_col.p4 -> row0.kernel_col.k3: "PTRACE_SYSCALL\nresume child" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
  style.animated: true
}
row0.kernel_col.k3 -> row0.child_col.c4: "TIF_SYSCALL_TRACE set\nchild runs" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
}
row0 -> loop_box: "child hits first syscall | repeat" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
  style.animated: true
}
loop_box.entry_stop -> loop_box.exit_stop: "PTRACE_SYSCALL | kernel executes syscall" {
  style.stroke: "#059669"
  style.stroke-width: 2
  style.animated: true
}
loop_box.exit_stop -> loop_box.entry_stop: "PTRACE_SYSCALL | next syscall" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
  style.stroke-dash: 3
}
loop_box -> term_box: "WIFEXITED or WIFSIGNALED" {
  style.stroke: "#ea580c"
  style.stroke-width: 2
}
term_box -> cost_box: "session complete" {
  style.stroke: "#64748b"
}