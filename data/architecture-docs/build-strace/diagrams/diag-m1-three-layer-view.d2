direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Three-Level View: Tracer → Kernel → Tracee Interaction
  *Single syscall interception lifecycle with costs at each layer*
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tracer_hdr: "APPLICATION LAYER (Tracer Process)" {
    style.fill: "#1a3a5c"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
    width: 300
  }
  kernel_hdr: "KERNEL LAYER (ring 0)" {
    style.fill: "#3a1a5c"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
    width: 300
  }
  hw_hdr: "HARDWARE LAYER (CPU / MMU)" {
    style.fill: "#1a5c3a"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
    width: 300
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t1: "ptrace(PTRACE_SYSCALL, pid, 0, 0)" {
    shape: step
    style.fill: "#d0e8ff"
    style.stroke: "#1a3a5c"
    style.border-radius: 4
    width: 300
    cost1: "~1 µs (syscall overhead)"
  }
  k1: "Validate ptrace request" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost1: "~100 ns (task_struct check)"
  }
  h1: "ring 3 → ring 0 via SYSCALL instr" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost1: "~50–150 cycles (MSR_LSTAR jump)"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t2: "waitpid(-1, &status, 0)  [BLOCKS]" {
    shape: step
    style.fill: "#d0e8ff"
    style.stroke: "#1a3a5c"
    style.bold: true
    style.border-radius: 4
    width: 300
    cost2: "0 CPU cycles while sleeping"
  }
  k2: "Set TASK_TRACED on tracee" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost2: "1 write to task_struct flags"
  }
  h2: "Save RIP/RSP/RFLAGS to kernel stack" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost2: "~5–10 ns (stack write, L1 hit)"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  k3_pad: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 300
  }
  k3: "Scheduler resumes tracee (TASK_RUNNING)" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost3: "O(log N) rbtree pick, ~500 ns"
  }
  h3: "Context switch: CR3 load (tracee page table)" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost3: "TLB flush ~100–1000 ns (no PCID)"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tracee_hdr: "TRACEE executes in userspace" {
    shape: step
    style.fill: "#fff3d0"
    style.stroke: "#5c4a1a"
    style.bold: true
    style.border-radius: 4
    width: 300
    info: "rax=syscall_nr, rdi/rsi/rdx/r10/r8/r9=args"
  }
  k4: "TIF_SYSCALL_TRACE flag set in thread_info" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost4: "Checked at every syscall entry point"
  }
  h4: "Tracee executes SYSCALL instruction" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost4: "ring 3 → ring 0, saves RIP→rcx, RF→r11"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  entry_stop: "ENTRY STOP" {
    shape: diamond
    style.fill: "#ff9900"
    style.font-color: white
    style.bold: true
    style.stroke: "#cc6600"
    width: 300
  }
  k5: "ptrace_notify(SIGTRAP) — stop tracee" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost5: "Enqueue SIGCHLD to tracer wait queue"
  }
  h5: "Save all 168-byte register file to task_struct" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost5: "~10–20 ns (3 cache lines written)"
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t6: "waitpid returns: WIFSTOPPED, sig=SIGTRAP|0x80" {
    shape: step
    style.fill: "#d0e8ff"
    style.stroke: "#1a3a5c"
    style.border-radius: 4
    width: 300
    note6: "bit 7 set by PTRACE_O_TRACESYSGOOD"
  }
  k6: "Tracer woken via wait queue signal" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost6: "~500 ns scheduler pick for tracer"
  }
  h6: "Context switch: CR3 load (tracer page table)" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost6: "TLB flush again ~100–1000 ns"
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t7: "ptrace(PTRACE_GETREGS, pid, NULL, &regs)" {
    shape: step
    style.fill: "#d0e8ff"
    style.stroke: "#1a3a5c"
    style.border-radius: 4
    width: 300
    note7: "reads orig_rax=syscall_nr, rdi..r9=args"
  }
  k7: "copy_to_user: 168-byte register copy" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost7: "~30–60 ns (L2/L3 hit, 3 cache lines)"
  }
  h7: "DMA-less memcpy: kernel page → user page" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost7: "MOVQ x21 (one 8-byte write per register)"
  }
}
row8: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t8: "ptrace(PTRACE_SYSCALL, pid, 0, 0)  [resume]" {
    shape: step
    style.fill: "#d0e8ff"
    style.stroke: "#1a3a5c"
    style.border-radius: 4
    width: 300
    note8: "kernel executes actual syscall now"
  }
  k8: "Kernel executes syscall body (e.g. sys_read)" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost8: "100 ns (getpid) to 500 ms (blocking read)"
  }
  h8: "Writes return value into rax; orig_rax preserved" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost8: "orig_rax = saved syscall_nr; rax = retval"
  }
}
row9: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  exit_stop: "EXIT STOP" {
    shape: diamond
    style.fill: "#cc2200"
    style.font-color: white
    style.bold: true
    style.stroke: "#880000"
    width: 300
  }
  k9: "ptrace_notify again — stop at syscall exit" {
    shape: step
    style.fill: "#e8d0ff"
    style.stroke: "#3a1a5c"
    style.border-radius: 4
    width: 300
    cost9: "Same wait queue wakeup mechanism"
  }
  h9: "Second context switch back to tracer" {
    shape: step
    style.fill: "#d0ffe8"
    style.stroke: "#1a5c3a"
    style.border-radius: 4
    width: 300
    cost9: "~1–10 µs total round-trip overhead"
  }
}
row10: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t10: "Read rax=retval; print formatted syscall line" {
    shape: step
    style.fill: "#d0e8ff"
    style.stroke: "#1a3a5c"
    style.border-radius: 4
    width: 300
    note10: "check retval in [-4095,-1] for errno"
  }
  k10_pad: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 300
  }
  cost_box: "TOTAL OVERHEAD PER SYSCALL" {
    shape: rectangle
    style.fill: "#ffeecc"
    style.stroke: "#cc6600"
    style.bold: true
    style.border-radius: 4
    width: 300
    fast: "Fast syscall (getpid ~100 ns real)"
    traced: "Under ptrace: 2–20 µs measured"
    ratio: "Observer cost: 20x–200x slowdown"
    root: "2 context switches dominate cost"
  }
}
row_regs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  regs_table: "struct user_regs_struct (168 bytes)" {
    shape: sql_table
    label: "x86_64 Register Roles at Syscall Boundary"
    orig_rax: "syscall_nr (preserved) | orig_rax | entry+exit"
    rax_out:  "return value            | rax      | exit only"
    rdi:      "arg 1                   | rdi      | entry"
    rsi:      "arg 2                   | rsi      | entry"
    rdx:      "arg 3                   | rdx      | entry"
    r10:      "arg 4 (NOT rcx!)        | r10      | entry"
    r8:       "arg 5                   | r8       | entry"
    r9:       "arg 6                   | r9       | entry"
    rcx:      "clobbered by SYSCALL    | rcx      | return addr"
    r11:      "clobbered by SYSCALL    | r11      | saved RFLAGS"
    total:    "Total: 168 bytes — 3 cache lines (64 bytes each)"
  }
}
row0 -> row1: "Phase 1: Tracer resumes tracee"
row1 -> row2
row2 -> row3
row3 -> row4: "Phase 2: Tracee runs to syscall"
row4 -> row5
row5 -> row6: "Phase 3: Entry stop — tracer wakes"
row6 -> row7
row7 -> row8: "Phase 4: Kernel executes syscall"
row8 -> row9: "Phase 5: Exit stop — tracer wakes again"
row9 -> row10
row10 -> row_regs: "Register Reference"
row1.t1 -> row1.k1: "syscall" {
  style.stroke: "#1a3a5c"
  style.stroke-dash: 3
}
row1.k1 -> row1.h1: "ring transition" {
  style.stroke: "#3a1a5c"
  style.stroke-dash: 3
}
row5.entry_stop -> row5.k5: "TIF_SYSCALL_TRACE" {
  style.stroke: "#ff9900"
  style.stroke-width: 2
}
row5.k5 -> row5.h5: "register save" {
  style.stroke: "#3a1a5c"
  style.stroke-dash: 3
}
row9.exit_stop -> row9.k9: "TIF_SYSCALL_TRACE" {
  style.stroke: "#cc2200"
  style.stroke-width: 2
}
row5.entry_stop -> row9.exit_stop: "in_syscall toggle: 0→1→0" {
  style.stroke: "#ff9900"
  style.stroke-dash: 5
  style.stroke-width: 2
  style.animated: true
}