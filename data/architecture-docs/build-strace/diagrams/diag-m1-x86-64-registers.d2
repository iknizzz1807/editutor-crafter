direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## x86\_64 `struct user_regs_struct` — Register Layout and Syscall ABI
  Source: `<sys/user.h>` — used with `PTRACE_GETREGS` / `PTRACE_SETREGS`
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  reg_table: {
    shape: sql_table
    label: "struct user_regs_struct (sys/user.h) — 216 bytes total"
    f00: "0x00  |  0   | unsigned long long | r15"
    f01: "0x08  |  8   | unsigned long long | r14"
    f02: "0x10  | 16   | unsigned long long | r13"
    f03: "0x18  | 24   | unsigned long long | r12"
    f04: "0x20  | 32   | unsigned long long | rbp"
    f05: "0x28  | 40   | unsigned long long | rbx"
    f06: "0x30  | 48   | unsigned long long | r11"
    f07: "0x38  | 56   | unsigned long long | r10    ← ARG 4 (NOT rcx!)"
    f08: "0x40  | 64   | unsigned long long | r9     ← ARG 6"
    f09: "0x48  | 72   | unsigned long long | r8     ← ARG 5"
    f10: "0x50  | 80   | unsigned long long | rax    ← RETURN VALUE (exit stop)"
    f11: "0x58  | 88   | unsigned long long | rcx    ← CLOBBERED by syscall instr"
    f12: "0x60  | 96   | unsigned long long | rdx    ← ARG 3"
    f13: "0x68  | 104  | unsigned long long | rsi    ← ARG 2"
    f14: "0x70  | 112  | unsigned long long | rdi    ← ARG 1"
    f15: "0x78  | 120  | unsigned long long | orig_rax ← SYSCALL NR (preserved!)"
    f16: "0x80  | 128  | unsigned long long | rip"
    f17: "0x88  | 136  | unsigned long long | cs"
    f18: "0x90  | 144  | unsigned long long | eflags"
    f19: "0x98  | 152  | unsigned long long | rsp"
    f20: "0xa0  | 160  | unsigned long long | ss"
    f21: "0xa8  | 168  | unsigned long long | fs_base"
    f22: "0xb0  | 176  | unsigned long long | gs_base"
    f23: "0xb8  | 184  | unsigned long long | ds"
    f24: "0xc0  | 192  | unsigned long long | es"
    f25: "0xc8  | 200  | unsigned long long | fs"
    f26: "0xd0  | 208  | unsigned long long | gs"
    sz:  "Total: 216 bytes (27 × 8-byte fields)"
  }
  legend_col: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    abi_legend: "ABI: x86_64 Linux Syscall Convention" {
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      style.border-radius: 6
      row_nr: "Syscall NR  →  orig_rax  (0x78)" {
        style.font-color: "#B71C1C"
        style.bold: true
      }
      row_a1: "Argument 1  →  rdi       (0x70)" {
        style.font-color: "#1B5E20"
      }
      row_a2: "Argument 2  →  rsi       (0x68)" {
        style.font-color: "#1B5E20"
      }
      row_a3: "Argument 3  →  rdx       (0x60)" {
        style.font-color: "#1B5E20"
      }
      row_a4: "Argument 4  →  r10       (0x38)" {
        style.font-color: "#E65100"
        style.bold: true
      }
      row_a5: "Argument 5  →  r8        (0x48)" {
        style.font-color: "#1B5E20"
      }
      row_a6: "Argument 6  →  r9        (0x40)" {
        style.font-color: "#1B5E20"
      }
      row_rv: "Return val  →  rax       (0x50)" {
        style.font-color: "#4A148C"
        style.bold: true
      }
    }
    why_orig_rax: "WHY orig_rax EXISTS (offset 0x78)" {
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FF8F00"
      style.border-radius: 6
      step1: "1. User calls syscall(N)" {
        style.font-color: "#212121"
      }
      step2: "2. CPU: rcx ← RIP  (saves return addr)" {
        style.font-color: "#B71C1C"
        style.bold: true
      }
      step3: "   CPU: r11 ← RFLAGS" {
        style.font-color: "#B71C1C"
      }
      step4: "   → rcx CLOBBERED, unusable for arg4" {
        style.font-color: "#B71C1C"
        style.italic: true
      }
      step5: "3. Kernel saves rax → orig_rax" {
        style.font-color: "#1565C0"
        style.bold: true
      }
      step6: "4. Kernel writes -ENOSYS → rax" {
        style.font-color: "#B71C1C"
      }
      step7: "   (default: 'syscall not implemented')" {
        style.font-color: "#757575"
        style.italic: true
      }
      step8: "5. Kernel executes actual syscall" {
        style.font-color: "#1B5E20"
      }
      step9: "6. Kernel writes retval → rax" {
        style.font-color: "#4A148C"
        style.bold: true
      }
      step10: "   orig_rax still = syscall NR" {
        style.font-color: "#4A148C"
      }
      rule: "RULE: always use orig_rax to ID syscall" {
        style.font-color: "#B71C1C"
        style.bold: true
        style.underline: true
      }
    }
    c_abi_note: "C Function ABI vs Syscall ABI" {
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      style.border-radius: 6
      diff1: "C function arg4  →  rcx   (System V AMD64)" {
        style.font-color: "#880E4F"
      }
      diff2: "Syscall  arg4  →  r10   (Linux Syscall ABI)" {
        style.font-color: "#B71C1C"
        style.bold: true
      }
      diff3: "REASON: syscall instr clobbers rcx" {
        style.font-color: "#212121"
        style.italic: true
      }
      diff4: "C function  : rdi rsi rdx rcx r8 r9" {
        style.font-color: "#4A148C"
      }
      diff5: "Syscall ABI : rdi rsi rdx r10 r8 r9" {
        style.font-color: "#B71C1C"
        style.bold: true
      }
    }
    ptrace_read: "PTRACE_GETREGS Code Pattern (ptrace.h)" {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.border-radius: 6
      code1: "struct user_regs_struct regs;" {
        style.font: mono
      }
      code2: "ptrace(PTRACE_GETREGS, pid, NULL, &regs);" {
        style.font: mono
      }
      code3: "// AT ENTRY STOP:" {
        style.font: mono
        style.font-color: "#757575"
      }
      code4: "long nr  = (long)regs.orig_rax;  // syscall NR" {
        style.font: mono
        style.font-color: "#1B5E20"
      }
      code5: "long a1  = (long)regs.rdi;" {
        style.font: mono
        style.font-color: "#1B5E20"
      }
      code6: "long a4  = (long)regs.r10;  // NOT rcx!" {
        style.font: mono
        style.font-color: "#E65100"
      }
      code7: "// AT EXIT STOP:" {
        style.font: mono
        style.font-color: "#757575"
      }
      code8: "long ret = (long)regs.rax;   // return val" {
        style.font: mono
        style.font-color: "#4A148C"
      }
      code9: "long nr  = (long)regs.orig_rax; // still valid" {
        style.font: mono
        style.font-color: "#B71C1C"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  entry_exit: "Entry Stop vs Exit Stop — What Each Register Means" {
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#546E7A"
    style.border-radius: 6
    hdr: "Register State Across the Entry/Exit Boundary" {
      style.bold: true
    }
    tbl_hdr: "Register  |  Entry Stop (before kernel runs)  |  Exit Stop (after kernel runs)" {
      style.font: mono
      style.font-color: "#37474F"
    }
    tbl_01: "orig_rax  |  syscall number N                 |  syscall number N  (preserved!)" {
      style.font: mono
      style.font-color: "#1B5E20"
    }
    tbl_02: "rax       |  syscall number N  (same as above)|  return value (or -errno)" {
      style.font: mono
      style.font-color: "#4A148C"
    }
    tbl_03: "rdi       |  argument 1                       |  may be clobbered" {
      style.font: mono
      style.font-color: "#1565C0"
    }
    tbl_04: "rsi       |  argument 2                       |  may be clobbered" {
      style.font: mono
      style.font-color: "#1565C0"
    }
    tbl_05: "rdx       |  argument 3                       |  may be clobbered" {
      style.font: mono
      style.font-color: "#1565C0"
    }
    tbl_06: "r10       |  argument 4                       |  may be clobbered" {
      style.font: mono
      style.font-color: "#E65100"
    }
    tbl_07: "r8        |  argument 5                       |  may be clobbered" {
      style.font: mono
      style.font-color: "#1565C0"
    }
    tbl_08: "r9        |  argument 6                       |  may be clobbered" {
      style.font: mono
      style.font-color: "#1565C0"
    }
    tbl_09: "rcx       |  CLOBBERED (saved RIP by CPU)     |  CLOBBERED" {
      style.font: mono
      style.font-color: "#B71C1C"
    }
    tbl_10: "r11       |  CLOBBERED (saved RFLAGS by CPU)  |  CLOBBERED" {
      style.font: mono
      style.font-color: "#B71C1C"
    }
    warn: "CRITICAL: read arg registers at ENTRY only. Read rax (retval) at EXIT only." {
      style.font-color: "#B71C1C"
      style.bold: true
    }
  }
  error_range: "Error Return Convention — Kernel to Tracer" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.border-radius: 6
    hdr2: "Raw kernel retval in rax (at exit stop)" {
      style.bold: true
    }
    r1: "rax in [0, LONG_MAX]    →  SUCCESS  (print as-is)" {
      style.font: mono
      style.font-color: "#1B5E20"
    }
    r2: "rax in [-4095, -1]      →  ERROR    (-errno code)" {
      style.font: mono
      style.font-color: "#B71C1C"
    }
    r3: "rax < -4095             →  RARE: valid negative data" {
      style.font: mono
      style.font-color: "#E65100"
    }
    r4: "errno = (int)(-rax)     →  e.g. rax=-2 → ENOENT" {
      style.font: mono
      style.font-color: "#4A148C"
    }
    r5: "glibc wrapper: if (rax in [-4095,-1]) { errno=-rax; return -1; }" {
      style.font: mono
      style.font-color: "#37474F"
    }
    check: "is_error(rv): return rv >= -4095L && rv < 0;" {
      style.font: mono
      style.font-color: "#B71C1C"
      style.bold: true
    }
  }
}
row1 -> row2: "struct fields feed argument decoding" {
  style.stroke: "#607D8B"
  style.stroke-dash: 4
}