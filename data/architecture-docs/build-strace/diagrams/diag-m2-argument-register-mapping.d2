direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Syscall Argument Register Mapping (x86_64 Linux ABI)" {
  shape: rectangle
  style: {
    font-size: 18
    bold: true
    fill: transparent
    stroke: transparent
  }
}
title.near: top-center
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c_sig: {
    label: "C Function Signature (open.h)"
    shape: rectangle
    style.fill: "#e8f4fd"
    style.stroke: "#2980b9"
    style.bold: true
    pathname: {
      label: "arg1: const char *pathname"
      shape: rectangle
      style.fill: "#d6eaf8"
      style.stroke: "#2980b9"
    }
    flags: {
      label: "arg2: int flags"
      shape: rectangle
      style.fill: "#d6eaf8"
      style.stroke: "#2980b9"
    }
    mode: {
      label: "arg3: mode_t mode"
      shape: rectangle
      style.fill: "#d6eaf8"
      style.stroke: "#2980b9"
    }
    arg4: {
      label: "arg4: (hypothetical 4th arg)"
      shape: rectangle
      style.fill: "#fdebd0"
      style.stroke: "#e67e22"
    }
    arg5: {
      label: "arg5"
      shape: rectangle
      style.fill: "#fdebd0"
      style.stroke: "#e67e22"
    }
    arg6: {
      label: "arg6"
      shape: rectangle
      style.fill: "#fdebd0"
      style.stroke: "#e67e22"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  syscall_abi: "Syscall ABI (x86_64 Linux) — via syscall instruction" {
    shape: rectangle
    style.fill: "#eafaf1"
    style.stroke: "#27ae60"
    style.bold: true
    direction: right
    regs_col: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      rdi_box: {
        shape: sql_table
        label: "rdi — Arg 1"
        r1: "value  | const char *pathname"
        r2: "source | open() arg1"
        r3: "size   | 8 bytes (ptr)"
      }
      rsi_box: {
        shape: sql_table
        label: "rsi — Arg 2"
        r1: "value  | int flags"
        r2: "source | open() arg2"
        r3: "size   | 4 bytes (int, zero-ext to 8)"
      }
      rdx_box: {
        shape: sql_table
        label: "rdx — Arg 3"
        r1: "value  | mode_t mode"
        r2: "source | open() arg3"
        r3: "size   | 4 bytes (uint, zero-ext to 8)"
      }
    }
    r10_col: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      r10_box: {
        shape: sql_table
        label: "r10 — Arg 4 (SYSCALL ABI)"
        r1: "value  | 4th argument"
        r2: "note   | NOT rcx — see below"
        r3: "size   | 8 bytes"
        style.fill: "#fef9e7"
        style.stroke: "#f39c12"
      }
      r8_box: {
        shape: sql_table
        label: "r8  — Arg 5"
        r1: "value  | 5th argument"
        r2: "source | syscall arg5"
        r3: "size   | 8 bytes"
      }
      r9_box: {
        shape: sql_table
        label: "r9  — Arg 6"
        r1: "value  | 6th argument"
        r2: "source | syscall arg6"
        r3: "size   | 8 bytes"
      }
    }
    rax_col: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      rax_entry: {
        shape: sql_table
        label: "rax — Syscall Number (Entry)"
        r1: "value  | SYS_open = 2"
        r2: "source | syscall number table"
        r3: "size   | 8 bytes"
        style.fill: "#e8daef"
        style.stroke: "#8e44ad"
      }
      orig_rax: {
        shape: sql_table
        label: "orig_rax — Preserved by Kernel"
        r1: "value  | SYS_open = 2 (copy)"
        r2: "note   | saved before rax overwrite"
        r3: "read   | ptrace PTRACE_GETREGS"
        style.fill: "#e8daef"
        style.stroke: "#8e44ad"
      }
      rax_exit: {
        shape: sql_table
        label: "rax — Return Value (Exit)"
        r1: "value  | fd or -errno"
        r2: "range  | [-4095,-1]=error, else ok"
        r3: "read   | ptrace PTRACE_GETREGS"
        style.fill: "#fdedec"
        style.stroke: "#c0392b"
      }
    }
  }
  fn_abi: "C Function ABI (System V AMD64) — via call instruction" {
    shape: rectangle
    style.fill: "#fef9e7"
    style.stroke: "#f39c12"
    style.bold: true
    fn_regs: {
      shape: sql_table
      label: "C Calling Convention Register Order"
      a1: "Arg 1 | rdi | same as syscall"
      a2: "Arg 2 | rsi | same as syscall"
      a3: "Arg 3 | rdx | same as syscall"
      a4: "Arg 4 | rcx | DIFFERENT — syscall uses r10"
      a5: "Arg 5 | r8  | same as syscall"
      a6: "Arg 6 | r9  | same as syscall"
      ret: "Return | rax | same register"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  why_r10: "Why r10 Instead of rcx for Arg 4?" {
    shape: rectangle
    style.fill: "#fdedec"
    style.stroke: "#c0392b"
    style.bold: true
    explanation: {
      shape: sql_table
      label: "SYSCALL Instruction Hardware Behavior (Intel SDM)"
      e1: "Step 1 | CPU saves RIP (return addr) → rcx"
      e2: "Step 2 | CPU saves RFLAGS            → r11"
      e3: "Step 3 | CPU jumps to MSR_LSTAR       (kernel entry)"
      e4: "Result | rcx is CLOBBERED — holds return address, not arg4"
      e5: "Fix    | Kernel ABI uses r10 for arg4 instead of rcx"
      e6: "Risk   | Reading rcx for arg4 returns RIP — silent wrong data"
    }
  }
  tracer_note: "Tracer Correctness Rules (my_strace.c)" {
    shape: rectangle
    style.fill: "#eafaf1"
    style.stroke: "#27ae60"
    style.bold: true
    rules: {
      shape: sql_table
      label: "ptrace PTRACE_GETREGS field selection"
      r1: "Entry stop — syscall nr | regs.orig_rax | NOT regs.rax"
      r2: "Entry stop — arg1       | regs.rdi      | pathname ptr"
      r3: "Entry stop — arg2       | regs.rsi      | flags int"
      r4: "Entry stop — arg3       | regs.rdx      | mode uint"
      r5: "Entry stop — arg4       | regs.r10      | NOT regs.rcx"
      r6: "Entry stop — arg5       | regs.r8       |"
      r7: "Entry stop — arg6       | regs.r9       |"
      r8: "Exit stop  — retval     | regs.rax      | may be -errno"
      r9: "Exit stop  — syscall nr | regs.orig_rax | kernel preserved"
    }
  }
}
title -> row1: "" {
  style.stroke: transparent
}
row1 -> row2: "syscall instruction" {
  style.stroke: "#2980b9"
  style.bold: true
}
row2.syscall_abi -> row2.fn_abi: "vs" {
  style.stroke: "#e67e22"
  style.stroke-dash: 4
  style.bold: true
}
row2 -> row3: "implementation consequence" {
  style.stroke: "#27ae60"
  style.bold: true
}
row1.c_sig.pathname -> row2.syscall_abi.regs_col.rdi_box: "→ rdi" {
  style.stroke: "#2980b9"
  style.bold: true
}
row1.c_sig.flags -> row2.syscall_abi.regs_col.rsi_box: "→ rsi" {
  style.stroke: "#2980b9"
  style.bold: true
}
row1.c_sig.mode -> row2.syscall_abi.regs_col.rdx_box: "→ rdx" {
  style.stroke: "#2980b9"
  style.bold: true
}
row1.c_sig.arg4 -> row2.syscall_abi.r10_col.r10_box: "→ r10 (NOT rcx)" {
  style.stroke: "#e67e22"
  style.bold: true
  style.stroke-dash: 3
}
row1.c_sig.arg5 -> row2.syscall_abi.r10_col.r8_box: "→ r8" {
  style.stroke: "#2980b9"
}
row1.c_sig.arg6 -> row2.syscall_abi.r10_col.r9_box: "→ r9" {
  style.stroke: "#2980b9"
}
row2.syscall_abi.rax_col.rax_entry -> row2.syscall_abi.rax_col.orig_rax: "kernel saves" {
  style.stroke: "#8e44ad"
  style.bold: true
}
row2.syscall_abi.rax_col.orig_rax -> row2.syscall_abi.rax_col.rax_exit: "rax overwritten" {
  style.stroke: "#c0392b"
  style.stroke-dash: 4
}
row3.why_r10 -> row3.tracer_note: "therefore" {
  style.stroke: "#c0392b"
  style.bold: true
}