direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Bitmask Flag Decoding: open() flags = 0x242" {
  near: top-center
  style: {
    font-size: 20
    bold: true
    font-color: "#1a1a2e"
    stroke: transparent
    fill: transparent
  }
}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_val: {
    label: "Input Raw Value"
    shape: sql_table
    f0: "flags = 0x00000242"
    f1: "binary: 0000 0010 0100 0010"
    f2: "bits:   8    6    1"
    f3: "        ^    ^    ^"
  }
  flag_table: {
    label: "open() Flag Constants (fcntl.h)"
    shape: sql_table
    h0: "Constant     | Hex    | Bit"
    r1: "O_RDONLY     | 0x000  | none — zero value, special case"
    r2: "O_WRONLY     | 0x001  | bit 0"
    r3: "O_RDWR       | 0x002  | bit 1  ← match"
    r4: "O_CREAT      | 0x040  | bit 6  ← match"
    r5: "O_EXCL       | 0x080  | bit 7"
    r6: "O_TRUNC      | 0x200  | bit 9  ← match"
    r7: "O_APPEND     | 0x400  | bit 10"
    r8: "O_CLOEXEC    | 0x80000| bit 19"
  }
  input_val -> flag_table: "decode_flags()"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step_accmode: {
    label: "Step 1: Access Mode — bits [1:0]"
    shape: sql_table
    s1: "flags & O_ACCMODE    = 0x242 & 0x003 = 0x002"
    s2: "0x002 == O_RDWR      → emit \"O_RDWR\""
    s3: "remaining = 0x242 & ~0x003 = 0x240"
    style.stroke: "#6a0dad"
    style.fill: "#f3e8ff"
  }
  step_rdonly_note: {
    label: "O_RDONLY = 0 (Special Case)"
    shape: sql_table
    n1: "O_RDONLY has NO bits set"
    n2: "Normal AND loop: (val & 0) == 0 → ALWAYS true"
    n3: "Would spuriously print O_RDONLY for every value"
    n4: "FIX: handle access-mode bits FIRST via O_ACCMODE mask"
    n5: "Only print O_RDONLY when (flags & O_ACCMODE) == 0"
    style.stroke: "#cc0000"
    style.fill: "#fff0f0"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step_creat: {
    label: "Step 2: Test O_CREAT (0x040)"
    shape: sql_table
    s1: "remaining & O_CREAT  = 0x240 & 0x040 = 0x040  (nonzero)"
    s2: "match → emit \"|O_CREAT\""
    s3: "remaining &= ~0x040  → remaining = 0x200"
    style.stroke: "#006600"
    style.fill: "#eaffea"
  }
  step_trunc: {
    label: "Step 3: Test O_TRUNC (0x200)"
    shape: sql_table
    s1: "remaining & O_TRUNC  = 0x200 & 0x200 = 0x200  (nonzero)"
    s2: "match → emit \"|O_TRUNC\""
    s3: "remaining &= ~0x200  → remaining = 0x000"
    style.stroke: "#006600"
    style.fill: "#eaffea"
  }
  step_unknown: {
    label: "Step 4: Unknown Bits Check"
    shape: sql_table
    s1: "remaining = 0x000  → no unrecognized bits"
    s2: "if remaining != 0: emit \"|0x\" + hex(remaining)"
    s3: "Example: flags=0x342 → remaining=0x100 → \"|0x100\""
    style.stroke: "#b8860b"
    style.fill: "#fffbe6"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_str: {
    label: "Accumulated Output String"
    shape: sql_table
    o1: "After Step 1: \"O_RDWR\""
    o2: "After Step 2: \"O_RDWR|O_CREAT\""
    o3: "After Step 3: \"O_RDWR|O_CREAT|O_TRUNC\""
    o4: "Final output: O_RDWR|O_CREAT|O_TRUNC"
    style.stroke: "#004080"
    style.fill: "#e8f4ff"
  }
  edge_cases: {
    label: "Edge Cases Summary"
    shape: sql_table
    e0: "Case                | Handling"
    e1: "flags == 0          | check for O_RDONLY sentinel entry"
    e2: "O_RDONLY (val=0)    | handle via O_ACCMODE pre-check"
    e3: "unknown bits remain | print as hex suffix e.g. |0x100"
    e4: "multi-bit flag      | test (remaining & flag) == flag"
    e5: "first token         | no leading pipe; subsequent: prepend |"
    style.stroke: "#b8860b"
    style.fill: "#fffbe6"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  impl_logic: {
    label: "decode_flags() Core Logic (flag_decode.c)"
    width: 560
    code: |'c
      int first = 1;
      unsigned long remaining = value;
      /* Step 1: access mode (O_RDONLY/O_WRONLY/O_RDWR) */
      int acc = remaining & O_ACCMODE;
      switch (acc) {
        case O_RDONLY: printf("O_RDONLY"); break;
        case O_WRONLY: printf("O_WRONLY"); break;
        case O_RDWR:   printf("O_RDWR");   break;
      }
      remaining &= ~(unsigned long)O_ACCMODE;
      /* Step 2+: test each single-bit flag */
      for (size_t i = 0; i < nflags; i++) {
        if ((remaining & flags[i].value) == flags[i].value) {
          printf("|%s", flags[i].name);
          remaining &= ~flags[i].value;
        }
      }
      /* Step 4: unknown bits */
      if (remaining) printf("|0x%lx", remaining);
    '|
  }
}
row0 -> row1: "extract access-mode bits"
row1 -> row2: "iterate flag table"
row2 -> row3: "accumulate matches"
row3 -> row4: "C implementation"
row1.step_accmode -> row1.step_rdonly_note: "why O_ACCMODE first" {
  style.stroke-dash: 4
  style.stroke: "#cc0000"
}
row2.step_creat -> row2.step_trunc: "remaining=0x200" {
  style.stroke: "#006600"
}