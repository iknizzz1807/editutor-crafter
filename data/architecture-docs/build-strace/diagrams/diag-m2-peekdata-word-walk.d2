direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## PTRACE_PEEKDATA — Word-by-Word String Read: "/etc/passwd"
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tracee_mem: "Tracee Virtual Address Space (separate page table)" {
    direction: down
    style.fill: "#e8f4f8"
    style.stroke: "#4a90d9"
    style.stroke-width: 2
    word1: {
      shape: sql_table
      label: "Word 1 @ 0x7ffd1230 (8 bytes, little-endian)"
      b0: "byte[0] | 0x2f | '/'"
      b1: "byte[1] | 0x65 | 'e'"
      b2: "byte[2] | 0x74 | 't'"
      b3: "byte[3] | 0x63 | 'c'"
      b4: "byte[4] | 0x2f | '/'"
      b5: "byte[5] | 0x70 | 'p'"
      b6: "byte[6] | 0x61 | 'a'"
      b7: "byte[7] | 0x73 | 's'"
      style.fill: "#d4edda"
      style.stroke: "#28a745"
    }
    word2: {
      shape: sql_table
      label: "Word 2 @ 0x7ffd1238 (8 bytes, little-endian)"
      b0: "byte[0] | 0x73 | 's'"
      b1: "byte[1] | 0x77 | 'w'"
      b2: "byte[2] | 0x64 | 'd'"
      b3: "byte[3] | 0x00 | '\\0'  ← NULL TERMINATOR"
      b4: "byte[4] | 0x?? | garbage"
      b5: "byte[5] | 0x?? | garbage"
      b6: "byte[6] | 0x?? | garbage"
      b7: "byte[7] | 0x?? | garbage"
      style.fill: "#fff3cd"
      style.stroke: "#ffc107"
    }
  }
  tracer_side: "Tracer Process (your address space)" {
    direction: down
    style.fill: "#f0e6ff"
    style.stroke: "#7b2d8b"
    style.stroke-width: 2
    call1: {
      label: "Call 1: PTRACE_PEEKDATA"
      width: 380
      code: |'c
        errno = 0;
        long w = ptrace(PTRACE_PEEKDATA,
                  pid,
                  (void*)0x7ffd1230,
                  NULL);
        // w = 0x73617065637465 2f
        // little-endian: byte[0]='/'
        if (w == -1L && errno != 0)
          return -1; // real error
      '|
      style.fill: "#e9d8fd"
      style.stroke: "#7b2d8b"
    }
    scan1: {
      label: "Byte Scan — Word 1 (byte_offset=0)"
      width: 380
      code: |'c
        unsigned char *b = (unsigned char*)&w;
        // i=0: b[0]=0x2f '/' → out[0]
        // i=1: b[1]=0x65 'e' → out[1]
        // i=2: b[2]=0x74 't' → out[2]
        // i=3: b[3]=0x63 'c' → out[3]
        // i=4: b[4]=0x2f '/' → out[4]
        // i=5: b[5]=0x70 'p' → out[5]
        // i=6: b[6]=0x61 'a' → out[6]
        // i=7: b[7]=0x73 's' → out[7]
        // no '\0' found → advance addr
      '|
      style.fill: "#d4edda"
      style.stroke: "#28a745"
    }
    call2: {
      label: "Call 2: PTRACE_PEEKDATA"
      width: 380
      code: |'c
        errno = 0;
        w = ptrace(PTRACE_PEEKDATA,
                   pid,
                   (void*)0x7ffd1238,
                   NULL);
        // w = 0x????????00647773
        // little-endian: byte[0]='s'
        if (w == -1L && errno != 0)
          return -1; // real error
      '|
      style.fill: "#e9d8fd"
      style.stroke: "#7b2d8b"
    }
    scan2: {
      label: "Byte Scan — Word 2 (null found at i=3)"
      width: 380
      code: |'c
        b = (unsigned char*)&w;
        // i=0: b[0]=0x73 's' → out[8]
        // i=1: b[1]=0x77 'w' → out[9]
        // i=2: b[2]=0x64 'd' → out[10]
        // i=3: b[3]=0x00 '\0' → STOP!
        //   found_null = 1; break;
        // bytes[4..7] = garbage → ignored
        out[11] = '\0'; // null-terminate
        return 11;      // bytes written
      '|
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
    }
    result: {
      shape: sql_table
      label: "Assembled Output Buffer"
      r0: "out[0..3]  | 0x2f,0x65,0x74,0x63 | \"/etc\""
      r1: "out[4..7]  | 0x2f,0x70,0x61,0x73 | \"/pas\""
      r2: "out[8..10] | 0x73,0x77,0x64       | \"swd\""
      r3: "out[11]    | 0x00                 | null terminator"
      r4: "Total: 11 bytes | string = \"/etc/passwd\""
      style.fill: "#d4edda"
      style.stroke: "#28a745"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  align_note: "Word Alignment Rule" {
    direction: down
    style.fill: "#fff8e1"
    style.stroke: "#f0a500"
    style.stroke-width: 2
    align_table: {
      shape: sql_table
      label: "Alignment Calculation (addr=0x7ffd1230)"
      a0: "aligned_addr | addr & ~7ULL    | 0x7ffd1230 (already aligned)"
      a1: "byte_offset  | addr - aligned  | 0 (start at byte 0 of word)"
      a2: "next word    | aligned + 8     | 0x7ffd1238"
      a3: "Rule: always read word-aligned | then skip leading bytes"
    }
    misalign_ex: {
      shape: sql_table
      label: "Misaligned Example (addr=0x7ffd1233)"
      m0: "aligned_addr | 0x7ffd1233 & ~7 | 0x7ffd1230"
      m1: "byte_offset  | 0x1233 - 0x1230 | 3 (skip bytes 0,1,2)"
      m2: "First chars  | b[3]='c',b[4]='/' ... | starts mid-word"
    }
  }
  errno_note: "errno Disambiguation Protocol" {
    direction: down
    style.fill: "#fce8e8"
    style.stroke: "#dc3545"
    style.stroke-width: 2
    errno_table: {
      shape: sql_table
      label: "PTRACE_PEEKDATA Return Value: -1 Ambiguity"
      e0: "Case A: w==-1 AND errno!=0 | REAL ERROR  | addr unmapped / EFAULT"
      e1: "Case B: w==-1 AND errno==0 | VALID DATA  | 0xFFFFFFFFFFFFFFFF in mem"
      e2: "MUST: errno=0 before call  | THEN check  | errno after call"
      e3: "Never: if(w==-1) break     | WRONG — misses valid 0xFF...FF data"
    }
  }
}
row0.tracee_mem.word1 -> row0.tracer_side.call1: "PTRACE_PEEKDATA | 8 bytes"  {
  style.stroke: "#4a90d9"
  style.stroke-width: 2
  style.animated: true
}
row0.tracee_mem.word2 -> row0.tracer_side.call2: "PTRACE_PEEKDATA | 8 bytes" {
  style.stroke: "#4a90d9"
  style.stroke-width: 2
  style.animated: true
}
row0.tracer_side.call1 -> row0.tracer_side.scan1: "long word | scan bytes[0..7]" {
  style.stroke: "#7b2d8b"
}
row0.tracer_side.scan1 -> row0.tracer_side.call2: "no null found | addr += 8" {
  style.stroke: "#28a745"
}
row0.tracer_side.call2 -> row0.tracer_side.scan2: "long word | scan bytes[0..7]" {
  style.stroke: "#7b2d8b"
}
row0.tracer_side.scan2 -> row0.tracer_side.result: "null at i=3 | stop scan" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
}
row0 -> row1: "alignment + errno rules apply to every call" {
  style.stroke-dash: 4
  style.stroke: "#888"
}