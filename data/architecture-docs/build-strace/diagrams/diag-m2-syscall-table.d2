direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## x86_64 Syscall Table — Number → Name → Argument Signature
| {near: top-center}
legend: {
  near: bottom-right
  label: "Legend"
  style: {
    stroke: "#888"
    fill: "#f8f8f8"
    border-radius: 6
  }
  l1: "INT  = plain integer (read from register directly)" {
    style.font-color: "#1a5276"
    style.bold: false
  }
  l2: "STR* = string pointer (needs PTRACE_PEEKDATA loop)" {
    style.font-color: "#1e8449"
    style.bold: false
  }
  l3: "PTR* = struct pointer (deep decode or print as hex)" {
    style.font-color: "#7d3c98"
    style.bold: false
  }
  l4: "FLG  = bitmask flags (symbolic decode)" {
    style.font-color: "#b7950b"
    style.bold: false
  }
  l5: "FD   = file descriptor integer" {
    style.font-color: "#922b21"
    style.bold: false
  }
}
row_top: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  syscall_table: {
    shape: sql_table
    label: "syscall_names[] — arch/x86/entry/syscalls/syscall_64.tbl"
    style.fill: "#dce8f5"
    style.font-color: "#1a2b4a"
    hdr: "Nr  | Name          | nargs | arg1        | arg2        | arg3        | arg4       | arg5     | arg6"
    r0:  "0   | read          |   3   | FD fd       | PTR* buf    | INT count   |            |          |"
    r1:  "1   | write         |   3   | FD fd       | STR* buf    | INT count   |            |          |"
    r2:  "2   | open          |   3   | STR* path   | FLG flags   | INT mode    |            |          |"
    r3:  "3   | close         |   1   | FD fd       |             |             |            |          |"
    r4:  "4   | stat          |   2   | STR* path   | PTR* statbuf|             |            |          |"
    r5:  "5   | fstat         |   2   | FD fd       | PTR* statbuf|             |            |          |"
    r6:  "6   | lstat         |   2   | STR* path   | PTR* statbuf|             |            |          |"
    r7:  "7   | poll          |   3   | PTR* fds    | INT nfds    | INT timeout |            |          |"
    r8:  "8   | lseek         |   3   | FD fd       | INT offset  | INT whence  |            |          |"
    r9:  "9   | mmap          |   6   | PTR* addr   | INT length  | FLG prot    | FLG flags  | FD fd    | INT offset"
    r11: "11  | munmap        |   2   | PTR* addr   | INT length  |             |            |          |"
    r21: "21  | access        |   2   | STR* path   | INT mode    |             |            |          |"
    r57: "57  | fork          |   0   |             |             |             |            |          |"
    r59: "59  | execve        |   3   | STR* path   | PTR* argv   | PTR* envp   |            |          |"
    r60: "60  | exit          |   1   | INT status  |             |             |            |          |"
    r231:"231 | exit_group    |   1   | INT status  |             |             |            |          |"
    r257:"257 | openat        |   4   | FD dirfd    | STR* path   | FLG flags   | INT mode   |          |"
    sz:  "Total entries: ~335 (sparse; gaps are reserved numbers)"
  }
}
row_mid: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arg_types: {
    label: "Argument Type Decoder (arg_type_t — syscall_sig.h)"
    shape: class
    style.fill: "#fef9e7"
    style.stroke: "#b7950b"
    +ARG_NONE: "0 — argument slot unused"
    +ARG_FD: "1 — file descriptor, print as decimal"
    +ARG_INT: "2 — signed integer, print as decimal"
    +ARG_UINT: "3 — unsigned integer, print as decimal"
    +ARG_STR: "4 — char* in tracee memory → PTRACE_PEEKDATA loop"
    +ARG_PTR: "5 — generic pointer, print as 0xADDR"
    +ARG_OPEN_FLAGS: "6 — decode O_RDONLY or O_WRONLY or O_CREAT or..."
    +ARG_MMAP_PROT: "7 — decode PROT_READ or PROT_WRITE or PROT_EXEC"
    +ARG_MMAP_FLAGS: "8 — decode MAP_SHARED or MAP_PRIVATE or MAP_ANON"
  }
  peekdata_cost: {
    label: "PTRACE_PEEKDATA Cost (STR* decode)"
    shape: sql_table
    style.fill: "#fdfefe"
    style.stroke: "#1e8449"
    hdr:  "Operation                  | Cost"
    r1:   "memcpy 8 bytes (local)     | ~2 ns"
    r2:   "PTRACE_PEEKDATA (one word) | ~1-5 us"
    r3:   "TLB walk (tracee PTE)      | ~20-200 cycles"
    r4:   "copy_to_user (8 bytes)     | ~10 cycles"
    r5:   "Context switches per call  | 2 (tracer→kernel→tracer)"
    r6:   "Overhead vs local read     | 500-2500x slower"
    r7:   "filename: /etc/passwd (11B)| 2 PEEKDATA calls needed"
    r8:   "Alt: /proc/pid/mem pread() | 1 syscall for N bytes"
  }
}
row_bot: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  read_sig: {
    shape: sql_table
    label: "read(2) — syscall nr 0"
    style.fill: "#eaf4fb"
    style.stroke: "#1a5276"
    hdr:  "Arg | Register | Type | Decode Method"
    a1:   " 1  | rdi      | FD   | printf(\"%d\", rdi)"
    a2:   " 2  | rsi      | PTR* | print as 0xADDR (output buf)"
    a3:   " 3  | rdx      | INT  | printf(\"%llu\", rdx)"
    ret:  "ret | rax      | INT  | bytes read, or -errno"
  }
  open_sig: {
    shape: sql_table
    label: "open(2) — syscall nr 2"
    style.fill: "#eafaf1"
    style.stroke: "#1e8449"
    hdr:  "Arg | Register | Type       | Decode Method"
    a1:   " 1  | rdi      | STR*       | PTRACE_PEEKDATA loop → quoted string"
    a2:   " 2  | rsi      | FLG        | O_RDONLY or O_WRONLY or O_CREAT or ..."
    a3:   " 3  | rdx      | INT (mode) | printf(\"0%03o\", rdx) — octal"
    ret:  "ret | rax      | FD or -err | fd >= 0 success, else -errno"
  }
  mmap_sig: {
    shape: sql_table
    label: "mmap(2) — syscall nr 9"
    style.fill: "#f5eef8"
    style.stroke: "#7d3c98"
    hdr:  "Arg | Register | Type       | Decode Method"
    a1:   " 1  | rdi      | PTR*       | NULL or 0xADDR hint"
    a2:   " 2  | rsi      | INT        | length in bytes"
    a3:   " 3  | rdx      | FLG(prot)  | PROT_READ or PROT_WRITE or PROT_EXEC"
    a4:   " 4  | r10 (!)  | FLG(flags) | MAP_SHARED or MAP_PRIVATE or MAP_ANON"
    a5:   " 5  | r8       | FD         | fd (-1 for anonymous)"
    a6:   " 6  | r9       | INT        | offset (page-aligned)"
    ret:  "ret | rax      | PTR* or -err | mapped addr, or MAP_FAILED=-1"
    note: "r10 not rcx — syscall ABI differs from C ABI for arg4"
  }
}
row_top -> row_mid: "arg_type_t[] per syscall" {
  style.stroke: "#888"
  style.stroke-dash: 3
}
row_mid -> row_bot: "per-syscall decoders" {
  style.stroke: "#888"
  style.stroke-dash: 3
}