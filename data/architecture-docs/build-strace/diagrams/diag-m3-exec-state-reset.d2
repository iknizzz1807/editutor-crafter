direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## PTRACE_EVENT_EXEC: Memory Map Replacement (PID 1001)
  Same PID — Completely Different Process Image — All Cached Pointers Invalid
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: "BEFORE exec()  —  /usr/bin/bash" {
    direction: down
    style.fill: "#e8f4fd"
    style.stroke: "#2980b9"
    style.stroke-width: 2
    pid_before: {
      shape: sql_table
      label: "Process Identity (task_struct)"
      pid_row: "PID        | pid_t     | 1001"
      tgid_row: "TGID       | pid_t     | 1001"
      comm_row: "comm       | char[16]  | bash"
      state_row: "state      | long      | TASK_TRACED"
      cr3_row:  "CR3 (PGD)  | phys_addr | 0x1A3F000  (page table root)"
    }
    mem_before: {
      shape: sql_table
      label: "Virtual Memory Map — bash"
      vma1: "0x00400000–0x00C1FFFF | r-xp | /usr/bin/bash  (text)"
      vma2: "0x00C20000–0x00C22FFF | r--p | /usr/bin/bash  (rodata)"
      vma3: "0x00C23000–0x00C2FFFF | rw-p | /usr/bin/bash  (data/bss)"
      vma4: "0x05580000–0x05620000 | rw-p | heap  [brk=0x05620000]"
      vma5: "0x7F800000–0x7FFFFFFF | rw-p | libc-2.35.so + ld-linux"
      vma6: "0x7FFD0000–0x7FFDFFFF | rw-p | stack [grows down]"
      vma7: "0xFFFF0000            | r-xp | vDSO"
    }
    cached_before: {
      shape: sql_table
      label: "Tracer Cached State (pid_state_t)"
      c1: "in_syscall       | int      | 1  (mid-execve entry)"
      c2: "current_syscall  | long     | 59 (SYS_execve)"
      c3: "cached_str_ptr   | uint64_t | 0x7FFD3400  → '/tmp/data.txt'"
      c4: "entry_time.tv_ns | uint64_t | 1709458823912345678"
      c5: "outbuf           | char[]   | partial: execve(\"/usr/bin/python3\""
    }
    ptr_valid: "Pointer 0x7FFD3400 is VALID" {
      style.fill: "#27ae60"
      style.font-color: white
      style.stroke: "#1e8449"
      style.border-radius: 6
    }
  }
  arrow_col: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    exec_event: "PTRACE_EVENT_EXEC" {
      shape: hexagon
      style.fill: "#8e44ad"
      style.font-color: white
      style.stroke: "#6c3483"
      style.bold: true
    }
    what_kernel_does: {
      shape: sql_table
      label: "Kernel Actions During execve()"
      k1: "1. Flush all VMAs → munmap entire address space"
      k2: "2. Load ELF /usr/bin/python3 → new text/data VMAs"
      k3: "3. Allocate fresh stack at NEW random base (ASLR)"
      k4: "4. Map new heap starting at NEW brk address"
      k5: "5. Load new ld-linux, libc at NEW randomized addrs"
      k6: "6. Reset CR3 → new page table root (same PID, new PGD)"
      k7: "7. Deliver PTRACE_EVENT_EXEC to tracer"
      k8: "8. Syscall exit stop follows (execve returns 0)"
    }
    style.stroke: transparent
    style.fill: transparent
  }
  after: "AFTER exec()  —  /usr/bin/python3" {
    direction: down
    style.fill: "#fdf2e9"
    style.stroke: "#e74c3c"
    style.stroke-width: 2
    pid_after: {
      shape: sql_table
      label: "Process Identity (task_struct) — SAME PID"
      pid_row2: "PID        | pid_t     | 1001  (unchanged)"
      tgid_row2: "TGID       | pid_t     | 1001  (unchanged)"
      comm_row2: "comm       | char[16]  | python3  (CHANGED)"
      state_row2: "state      | long      | TASK_TRACED"
      cr3_row2:  "CR3 (PGD)  | phys_addr | 0x2B7C000  (NEW page table root)"
    }
    mem_after: {
      shape: sql_table
      label: "Virtual Memory Map — python3 (ENTIRELY NEW)"
      vma1b: "0x00400000–0x006FFFFF | r-xp | /usr/bin/python3 (text)"
      vma2b: "0x00700000–0x00701FFF | r--p | /usr/bin/python3 (rodata)"
      vma3b: "0x00702000–0x00709FFF | rw-p | /usr/bin/python3 (data/bss)"
      vma4b: "0x024A0000–0x024B0000 | rw-p | heap  [brk=0x024B0000]  DIFFERENT"
      vma5b: "0x7F200000–0x7F9FFFFF | rw-p | libpython3.so + libc (NEW addrs)"
      vma6b: "0x7FFA0000–0x7FFAFFFF | rw-p | stack  base=0x7FFA0000  DIFFERENT"
      vma7b: "0xFFFF0000            | r-xp | vDSO"
    }
    cached_after: {
      shape: sql_table
      label: "Tracer Cached State — MUST RESET"
      d1: "in_syscall       | int      | RESET → 0"
      d2: "current_syscall  | long     | RESET → 0"
      d3: "cached_str_ptr   | uint64_t | 0x7FFD3400 → STALE / INVALID"
      d4: "entry_time.tv_ns | uint64_t | RESET → 0"
      d5: "outbuf           | char[]   | RESET → empty"
    }
    ptr_invalid: "Pointer 0x7FFD3400 is INVALID" {
      shape: callout
      style.fill: "#c0392b"
      style.font-color: white
      style.stroke: "#922b21"
      style.bold: true
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  reset_code: "handle_exec_event() — Required Reset Logic (tracer.c)" {
    direction: down
    width: 520
    style.fill: "#fdfefe"
    style.stroke: "#7f8c8d"
    code: |'c
      static void handle_exec_event(pid_t pid, pid_map_t *map) {
          pid_state_t *state = pid_map_get(map, pid);
          /* PID is the same — but address space is brand new */
          state->in_syscall = 0;        /* reset toggle */
          memset(&state->current, 0,    /* stale syscall info */
                 sizeof(state->current));
          state->outbuf_len = 0;        /* discard partial line */
          /* entry_time meaningless — reset */
          memset(&state->entry_time, 0, sizeof(state->entry_time));
          fprintf(g_output,
              "[pid %d] +++ execve completed; address space replaced +++\n",
              pid);
      }
    '|
  }
  aslr_note: "ASLR: Why Addresses Change on Every exec()" {
    direction: down
    style.fill: "#f9f9f9"
    style.stroke: "#95a5a6"
    aslr_table: {
      shape: sql_table
      label: "Address Randomization per exec() (x86_64 Linux)"
      a1: "Stack base   | mmap_rnd_bits=28 | 256MB random offset  | rsp varies"
      a2: "Heap base    | brk randomized   | 16MB random offset   | brk varies"
      a3: "libs base    | mmap_rnd_bits=28 | 256MB random offset  | libc varies"
      a4: "PIE text     | exec_rnd_bits=8  | 16MB random offset   | main() varies"
      a5: "vDSO         | 1-page random    | fixed kernel mapping"
      note: "CONSEQUENCE: cached pointer 0x7FFD3400 maps to DIFFERENT physical page"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ptrace_stop_seq: "ptrace Stop Sequence Around execve()" {
    direction: down
    style.fill: "#eafaf1"
    style.stroke: "#1e8449"
    seq_table: {
      shape: sql_table
      label: "Event Timeline (from tracer waitpid perspective)"
      s1: "Stop 1 | SIGTRAP|0x80       | execve entry stop  | in_syscall→1  | read args: orig_rax=59"
      s2: "Stop 2 | SIGTRAP event=0x04 | PTRACE_EVENT_EXEC  | NOT a syscall stop — call handle_exec_event()"
      s3: "Stop 3 | SIGTRAP|0x80       | execve EXIT stop   | in_syscall→0  | rax=0 (success)"
      s4: "Stop 4 | SIGTRAP|0x80       | python3 first entry| in_syscall→1  | new program running"
      warn: "DANGER: if PTRACE_EVENT_EXEC mistakenly treated as syscall stop → toggle corruption"
    }
  }
  danger_box: "Use-After-exec Bug: Dereferencing Stale Pointer" {
    direction: down
    style.fill: "#fdedec"
    style.stroke: "#c0392b"
    danger_code: {
      width: 420
      code: |'c
        /* BAD: tracer reads cached ptr AFTER exec */
        /* cached_str_ptr = 0x7FFD3400 from old bash */
        errno = 0;
        long word = ptrace(PTRACE_PEEKDATA, pid,
                           (void*)0x7FFD3400, NULL);
        /* Result: EFAULT — page unmapped in python3 */
        /* OR: reads unrelated python3 stack data */
        /* Either way: WRONG data, silent corruption */
        /* CORRECT: reset cached_str_ptr on EXEC event */
        /* Never read stale pointers after exec */
      '|
    }
    danger_label: "EFAULT or Silent Garbage Read" {
      style.fill: "#c0392b"
      style.font-color: white
      style.border-radius: 4
    }
  }
}
legend: "" {
  direction: right
  style.stroke: "#bdc3c7"
  style.fill: "#f8f9f9"
  style.border-radius: 6
  l_valid: "Green = valid / safe" {
    style.fill: "#27ae60"
    style.font-color: white
    style.border-radius: 4
  }
  l_invalid: "Red = invalid / danger" {
    style.fill: "#c0392b"
    style.font-color: white
    style.border-radius: 4
  }
  l_event: "Purple = ptrace kernel event" {
    style.fill: "#8e44ad"
    style.font-color: white
    style.border-radius: 4
  }
  l_safe: "Green border = before (valid state)" {
    style.stroke: "#27ae60"
    style.stroke-width: 2
    style.border-radius: 4
  }
  l_danger2: "Red border = after (stale state)" {
    style.stroke: "#c0392b"
    style.stroke-width: 2
    style.border-radius: 4
  }
}
legend.near: bottom-center
row1.before.ptr_valid -> row1.arrow_col.exec_event: "0x7FFD3400 valid" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
row1.arrow_col.exec_event -> row1.after.ptr_invalid: "0x7FFD3400 stale" {
  style.stroke: "#c0392b"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row1.arrow_col.exec_event -> row1.arrow_col.what_kernel_does: "triggers"
row1 -> row2: "reset required" {
  style.stroke: "#8e44ad"
  style.stroke-width: 2
}
row2 -> row3: "sequence and danger" {
  style.stroke: "#7f8c8d"
}