direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Per-PID State Hash Map — Structure and Lookup
  `pid_map_t` · Open-Addressing · 64 slots · Fibonacci Hash · x86_64 Linux
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  struct_def: {
    label: "pid_state_t (pid_state.h)"
    shape: sql_table
    f0: "0x00 | pid_t          | pid           // 4 bytes"
    f1: "0x04 | int            | in_syscall    // 0=expect_entry, 1=expect_exit"
    f2: "0x08 | int            | active        // 0=slot_unused, 1=in_use"
    f3: "0x0C | int            | _pad          // align to 8"
    f4: "0x10 | long           | current_syscall_nr  // from orig_rax"
    f5: "0x18 | struct timespec| entry_time    // CLOCK_MONOTONIC at entry"
    f6: "0x20 |   time_t       |   tv_sec      // 8 bytes"
    f7: "0x28 |   long         |   tv_nsec     // 8 bytes"
    f8: "0x30 | char[512]      | outbuf        // partial line buffer"
    f9: "0x230| int            | outbuf_len    // bytes used"
    fa: "0x234| int            | _pad2"
    sz: "Total: 0x238 = 568 bytes per slot"
  }
  hash_fn: {
    label: "pid_hash() (pid_map.c)"
    shape: class
    note1: "// Fibonacci multiplicative hash"
    +pid_hash(pid): "size_t"
    code_a: "h = (uint32_t)pid * 2654435769u"
    code_b: "return h >> (32 - 6)  // top 6 bits"
    note2: "// 64-slot table → 6-bit index"
    note3: "// PID 1000 → slot 41"
    note4: "// PID 1001 → slot 41 (collision)"
    note5: "// PID 1002 → slot 42 (linear probe)"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  map_container: "pid_map_t  [64 slots × 568 bytes = 35.5 KB  —  fits in L2 cache]" {
    direction: right
    style.fill: "#e8f4fd"
    style.stroke: "#2980b9"
    style.stroke-width: 2
    slots_left: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      slot38: {
        label: "slot 38"
        shape: sql_table
        s_pid:  "pid       | 0       | (unused)"
        s_act:  "active    | 0       | —"
        s_isc:  "in_syscall| —       | —"
        style.stroke: "#95a5a6"
        style.fill: "#f2f3f4"
      }
      slot39: {
        label: "slot 39"
        shape: sql_table
        s_pid:  "pid       | 0       | (unused)"
        s_act:  "active    | 0       | —"
        s_isc:  "in_syscall| —       | —"
        style.stroke: "#95a5a6"
        style.fill: "#f2f3f4"
      }
      slot40: {
        label: "slot 40"
        shape: sql_table
        s_pid:  "pid       | 0       | (unused)"
        s_act:  "active    | 0       | —"
        s_isc:  "in_syscall| —       | —"
        style.stroke: "#95a5a6"
        style.fill: "#f2f3f4"
      }
    }
    slots_pid1000: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      slot41: "slot 41  ←  hash(1000) = 41" {
        shape: sql_table
        style.fill: "#fef9e7"
        style.stroke: "#f39c12"
        style.stroke-width: 2
        s_pid:  "pid            | 1000          | PID 1000"
        s_act:  "active         | 1             | IN USE"
        s_isc:  "in_syscall     | 1             | EXPECT EXIT STOP"
        s_nr:   "current_syscall| 1 (write)     | syscall at entry"
        s_ts:   "entry_time     | {1741200010,  | CLOCK_MONOTONIC"
        s_ts2:  "               |  823456789}   | ns portion"
        s_buf:  "outbuf         | [pid 1000] write(1, | partial line"
        s_blen: "outbuf_len     | 22            | bytes buffered"
      }
      slot41_note: "PID 1000: mid-write()" {
        style.fill: "#fdebd0"
        style.stroke: "#e67e22"
        style.border-radius: 6
        note_a: "Entry stop fired: orig_rax=1"
        note_b: "entry_time recorded"
        note_c: "outbuf has partial line"
        note_d: "Waiting for EXIT stop"
        note_e: "to complete the line"
      }
    }
    slots_pid1001: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      slot42: "slot 42  ←  hash(1001)=41, probe+1=42" {
        shape: sql_table
        style.fill: "#eafaf1"
        style.stroke: "#27ae60"
        style.stroke-width: 2
        s_pid:  "pid            | 1001          | PID 1001"
        s_act:  "active         | 1             | IN USE"
        s_isc:  "in_syscall     | 0             | EXPECT ENTRY STOP"
        s_nr:   "current_syscall| 0             | no syscall in flight"
        s_ts:   "entry_time     | {0, 0}        | not yet set"
        s_buf:  "outbuf         | (empty)       | no partial line"
        s_blen: "outbuf_len     | 0             | —"
      }
      slot42_note: "PID 1001: idle / between syscalls" {
        style.fill: "#d5f5e3"
        style.stroke: "#27ae60"
        style.border-radius: 6
        note_a: "Last exit stop completed"
        note_b: "Line was flushed to g_output"
        note_c: "Toggle reset to 0"
        note_d: "Ready for next entry stop"
      }
    }
    slots_pid1002: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      slot43: "slot 43  ←  hash(1002)=42, probe+1=43" {
        shape: sql_table
        style.fill: "#f5eef8"
        style.stroke: "#8e44ad"
        style.stroke-width: 2
        s_pid:  "pid            | 1002          | PID 1002 (new child)"
        s_act:  "active         | 1             | IN USE"
        s_isc:  "in_syscall     | 0             | EXPECT ENTRY STOP"
        s_nr:   "current_syscall| 0             | none yet"
        s_ts:   "entry_time     | {0, 0}        | not set"
        s_buf:  "outbuf         | (empty)       | —"
        s_blen: "outbuf_len     | 0             | —"
      }
      slot43_note: "PID 1002: just forked — initial SIGSTOP" {
        style.fill: "#e8daef"
        style.stroke: "#8e44ad"
        style.border-radius: 6
        note_a: "Created by PTRACE_EVENT_FORK"
        note_b: "PTRACE_SETOPTIONS applied"
        note_c: "First PTRACE_SYSCALL sent"
        note_d: "No syscalls traced yet"
        note_e: "in_syscall=0 is correct init"
      }
    }
    slots_right: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      slot44: {
        label: "slot 44"
        shape: sql_table
        s_pid:  "pid       | 0       | (unused)"
        s_act:  "active    | 0       | —"
        s_isc:  "in_syscall| —       | —"
        style.stroke: "#95a5a6"
        style.fill: "#f2f3f4"
      }
      slot45: {
        label: "slot 45"
        shape: sql_table
        s_pid:  "pid       | 0       | (unused)"
        s_act:  "active    | 0       | —"
        s_isc:  "in_syscall| —       | —"
        style.stroke: "#95a5a6"
        style.fill: "#f2f3f4"
      }
      slot46: {
        label: "slot 46"
        shape: sql_table
        s_pid:  "pid       | 0       | (unused)"
        s_act:  "active    | 0       | —"
        s_isc:  "in_syscall| —       | —"
        style.stroke: "#95a5a6"
        style.fill: "#f2f3f4"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lookup_flow: "pid_map_get(map, pid) — Lookup Algorithm" {
    direction: down
    style.fill: "#eaf2ff"
    style.stroke: "#2471a3"
    style.stroke-width: 2
    lf1: "1  idx = pid_hash(pid) AND 0x3F" {
      style.fill: "#d6eaf8"
      style.border-radius: 4
    }
    lf2: "2  slot = map->slots[idx]" {
      style.fill: "#d6eaf8"
      style.border-radius: 4
    }
    lf3: "3  if slot.active==0: init slot, return" {
      style.fill: "#d5f5e3"
      style.border-radius: 4
    }
    lf4: "4  if slot.pid==pid: return slot  (hit)" {
      style.fill: "#d5f5e3"
      style.border-radius: 4
    }
    lf5: "5  idx = (idx+1) AND 0x3F  (linear probe)" {
      style.fill: "#fef9e7"
      style.border-radius: 4
    }
    lf6: "6  goto 2  (max 64 iterations, abort on full)" {
      style.fill: "#fdebd0"
      style.border-radius: 4
    }
    lf1 -> lf2: "O(1)"
    lf2 -> lf3: "empty?"
    lf2 -> lf4: "match?"
    lf2 -> lf5: "collision"
    lf5 -> lf6
  }
  collision_note: "Collision: PID 1001 → hash=41 (taken by PID 1000) → probe to slot 42" {
    style.fill: "#fdebd0"
    style.stroke: "#e67e22"
    style.border-radius: 6
    cn1: "PID 1000: hash(1000) = (1000 * 2654435769) >> 26 = 41"
    cn2: "PID 1001: hash(1001) = (1001 * 2654435769) >> 26 = 41  COLLISION"
    cn3: "Linear probe: try slot 42 → empty → place PID 1001 at slot 42"
    cn4: "PID 1002: hash(1002) = 42 COLLISION → probe slot 43 → place there"
    cn5: "WARNING: zeroing slot on remove can break probe chains"
    cn6: "Safe at load < 50%: 3 active / 64 slots = 4.7% load factor"
  }
  mem_note: "Cache Geometry (x86_64)" {
    shape: sql_table
    style.fill: "#f0f0f0"
    style.stroke: "#7f8c8d"
    m1: "L1 cache  | 32 KB   | 4 cycles  | MISSES: table too large"
    m2: "L2 cache  | 256 KB  | 12 cycles | HIT: full table fits (35.5 KB)"
    m3: "L3 cache  | 8 MB    | 40 cycles | always hot"
    m4: "DRAM      | —       | 200 cycles| never needed for map ops"
    m5: "1 slot    | 568 B   | 9 cache lines (64B each)"
    m6: "hot slots | ~3×568B | 27 KB — mostly in L1 after warmup"
  }
}
row0 -> row1: "64 slots × sizeof(pid_state_t)"
row1 -> row2: "Lookup | Collision | Cache"
row0.struct_def -> row1.map_container.slots_pid1000.slot41: "pid=1000 maps here"
row0.struct_def -> row1.map_container.slots_pid1001.slot42: "pid=1001 probes here"
row0.struct_def -> row1.map_container.slots_pid1002.slot43: "pid=1002 probes here"
row0.hash_fn -> row1.map_container.slots_pid1000.slot41: "hash(1000)=41" {
  style.stroke: "#f39c12"
  style.stroke-width: 2
}
row0.hash_fn -> row1.map_container.slots_pid1001.slot42: "hash(1001)=41→42" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row0.hash_fn -> row1.map_container.slots_pid1002.slot43: "hash(1002)=42→43" {
  style.stroke: "#8e44ad"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row1.map_container.slots_pid1000.slot41 -> row1.map_container.slots_pid1000.slot41_note: "state"
row1.map_container.slots_pid1001.slot42 -> row1.map_container.slots_pid1001.slot42_note: "state"
row1.map_container.slots_pid1002.slot43 -> row1.map_container.slots_pid1002.slot43_note: "state"
row2.lookup_flow -> row2.collision_note: "collision example"
row2.lookup_flow -> row2.mem_note: "cache impact"