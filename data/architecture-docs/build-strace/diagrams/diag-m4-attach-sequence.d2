direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 104
  }
}
title: |md
  ## PTRACE_ATTACH Sequence — Attaching to a Running Process
| {near: top-center}
row_actors: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tracer_col: "Tracer Process" {
    style.fill: "#d0e8ff"
    style.stroke: "#3a7bd5"
    style.border-radius: 6
    style.bold: true
  }
  kernel_col: "Linux Kernel" {
    style.fill: "#ffe0cc"
    style.stroke: "#cc5500"
    style.border-radius: 6
    style.bold: true
  }
  target_col: "Target Process (pid=1234)" {
    style.fill: "#d6f5d6"
    style.stroke: "#2e7d32"
    style.border-radius: 6
    style.bold: true
  }
}
step1: "Step 1 — PTRACE_ATTACH" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t1: "" {
    label: "ptrace(PTRACE_ATTACH, 1234, 0, 0)"
    style.fill: "#d0e8ff"
    style.stroke: "#3a7bd5"
    style.border-radius: 4
    width: 320
  }
  k1: "" {
    label: "Validates permissions (UID match\nor CAP_SYS_PTRACE)\nSets PT_PTRACED in task_struct\nEnqueues SIGSTOP to target\nReturns 0 immediately"
    style.fill: "#ffe0cc"
    style.stroke: "#cc5500"
    style.border-radius: 4
    width: 280
  }
  tg1: "" {
    label: "Still RUNNING on CPU\n(SIGSTOP not yet delivered)"
    style.fill: "#d6f5d6"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    style.italic: true
    width: 260
  }
}
t1 -> k1: "ptrace(PTRACE_ATTACH) | syscall"
k1 -> tg1: "SIGSTOP | enqueue"
step2: "Step 2 — Kernel Delivers SIGSTOP to Target" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t2: "" {
    label: "MUST call:\nwaitpid(1234, status, 0)\nBLOCKS until target stops"
    style.fill: "#d0e8ff"
    style.stroke: "#3a7bd5"
    style.border-radius: 4
    style.bold: true
    width: 280
  }
  k2: "" {
    label: "Delivers SIGSTOP\nSets TASK_TRACED\nSends SIGCHLD to tracer\nWakes tracer waitpid"
    style.fill: "#ffe0cc"
    style.stroke: "#cc5500"
    style.border-radius: 4
    width: 260
  }
  tg2: "" {
    label: "STOPPED — TASK_TRACED\nWSTOPSIG == SIGSTOP\nFrozen before next instruction"
    style.fill: "#d6f5d6"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    width: 280
  }
}
k2 -> tg2: "SIGSTOP | deliver"
tg2 -> t2: "waitpid returns | pid=1234"
step3: "Step 3 — Set Options and Begin Tracing (CORRECT PATH)" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t3: "" {
    label: "ptrace(PTRACE_SETOPTIONS, 1234, 0,\n  PTRACE_O_TRACESYSGOOD\n  | PTRACE_O_TRACEFORK\n  | PTRACE_O_TRACECLONE)\npid_map_get(1234)  // init state\nstate->in_syscall = 0\nptrace(PTRACE_SYSCALL, 1234, 0, 0)"
    style.fill: "#d0e8ff"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    style.font: mono
    width: 400
  }
  k3: "" {
    label: "Sets ptrace_flags in task_struct\nTransitions target to TASK_RUNNING\nTarget runs until next syscall boundary"
    style.fill: "#ffe0cc"
    style.stroke: "#cc5500"
    style.border-radius: 4
    width: 300
  }
  tg3: "" {
    label: "RUNNING again\nwill stop at next\nsyscall entry or exit"
    style.fill: "#d6f5d6"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    width: 220
  }
}
t3 -> k3: "PTRACE_SETOPTIONS | set flags"
k3 -> tg3: "PTRACE_SYSCALL | resume"
race_box: "RACE CONDITION — Skip waitpid (WRONG PATH)" {
  style.fill: "#fff0f0"
  style.stroke: "#cc0000"
  style.stroke-width: 3
  style.border-radius: 6
  race_inner: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    r_t: "" {
      label: "ptrace(PTRACE_ATTACH, 1234)\n// NO waitpid — jump straight to:\nptrace(PTRACE_SYSCALL, 1234, 0, 0)"
      style.fill: "#ffcccc"
      style.stroke: "#cc0000"
      style.border-radius: 4
      style.font: mono
      width: 340
    }
    r_k: "" {
      label: "Target not yet STOPPED\n(SIGSTOP still in flight)\nReturns: -1 errno=ESRCH\nor -1 errno=EIO"
      style.fill: "#ffcccc"
      style.stroke: "#cc0000"
      style.border-radius: 4
      width: 280
    }
  }
  r_t -> r_k: "PTRACE_SYSCALL | fails"
  race_label: "" {
    label: "RULE: PTRACE_ATTACH is ASYNC. The target is NOT stopped when the call returns.\nAny ptrace operation before waitpid() succeeds will return ESRCH or EIO."
    style.fill: "#ffeeee"
    style.stroke: "#cc0000"
    style.border-radius: 4
  }
}
mid_syscall_box: "MID-SYSCALL ATTACH PROBLEM" {
  style.fill: "#fffff0"
  style.stroke: "#b8860b"
  style.stroke-width: 3
  style.border-radius: 6
  mid_header: "" {
    label: "Target was INSIDE a blocking syscall (e.g. read() waiting on stdin) when PTRACE_ATTACH fired"
    style.fill: "#fffacc"
    style.stroke: "#b8860b"
    style.border-radius: 4
  }
  mid_timeline: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    m_before: "" {
      label: "Target calls read(0, buf, 1024)\n→ blocks in kernel wait queue\n[SIGSTOP arrives]\n→ kernel interrupts read\n→ read returns EINTR"
      style.fill: "#fffacc"
      style.stroke: "#b8860b"
      style.border-radius: 4
      width: 300
    }
    m_state: "" {
      label: "First ptrace stop after attach:\nSYSCALL EXIT stop for read()\nrax = -EINTR = -4\norig_rax = 0 (SYS_read)\nBUT in_syscall == 0 (wrong!)"
      style.fill: "#fff0cc"
      style.stroke: "#cc7700"
      style.border-radius: 4
      style.bold: true
      width: 320
    }
    m_fix: "" {
      label: "CORRECT HANDLING:\nIf in_syscall==0 at EXIT stop:\n  print partial: syscall_name = retval\n  do NOT flip toggle\n  next stop will be normal ENTRY"
      style.fill: "#e8f5e9"
      style.stroke: "#2e7d32"
      style.border-radius: 4
      width: 300
    }
  }
  m_before -> m_state: "SIGSTOP interrupts | EINTR"
  m_state -> m_fix: "graceful handling"
  mid_struct: "" {
    label: "State Machine: in_syscall toggle"
    shape: sql_table
    r0: "Expected (normal start)     | ENTRY → EXIT → ENTRY → EXIT"
    r1: "Mid-syscall attach (actual) | EXIT (orphan) → ENTRY → EXIT"
    r2: "Fix                         | detect EXIT with in_syscall==0 → skip print"
  }
}
toggle_detail: "in_syscall Toggle State Machine" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  s_out: "in_syscall=0\n(between syscalls)" {
    shape: circle
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.bold: true
  }
  s_in: "in_syscall=1\n(inside syscall)" {
    shape: circle
    style.fill: "#fce4ec"
    style.stroke: "#c62828"
    style.bold: true
  }
  s_out -> s_in: "syscall ENTRY stop\nread orig_rax → syscall_nr\nclock_gettime(entry_time)"
  s_in -> s_out: "syscall EXIT stop\nread rax → retval\nprint full line"
  orphan_exit: "ORPHAN EXIT\n(mid-syscall attach)" {
    shape: diamond
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
    style.bold: true
  }
  s_out -> orphan_exit: "EXIT stop\nwith in_syscall==0" {
    style.stroke-dash: 4
    style.stroke: "#f9a825"
  }
  orphan_exit -> s_out: "print placeholder\ndo NOT flip toggle" {
    style.stroke-dash: 4
    style.stroke: "#2e7d32"
  }
}
regs_layout: "Register State at Mid-Syscall Attach Exit Stop" {
  shape: sql_table
  label: "struct user_regs_struct (at EXIT stop after mid-syscall attach)"
  f0: "orig_rax | long        | 0 = SYS_read  (preserved — use to name syscall)"
  f1: "rax      | long        | -4 = -EINTR   (return value: syscall interrupted)"
  f2: "rdi      | ullong      | 0             (arg1: fd — may be stale)"
  f3: "rsi      | ullong      | 0x7fff...     (arg2: buf ptr — stale, old addrspace)"
  f4: "rdx      | ullong      | 1024          (arg3: count — may be stale)"
  f5: "rip      | ullong      | kernel ret addr (not meaningful to tracer)"
  note: "Rule: at EXIT stop, ONLY rax and orig_rax are reliable. Args may be clobbered."
}
legend: "" {
  style.fill: "#f5f5f5"
  style.stroke: "#9e9e9e"
  style.border-radius: 6
  label: "Color Legend"
  l1: "Blue  = Tracer actions" { style.fill: "#d0e8ff"; style.stroke: "#3a7bd5"; style.border-radius: 4 }
  l2: "Orange = Kernel actions" { style.fill: "#ffe0cc"; style.stroke: "#cc5500"; style.border-radius: 4 }
  l3: "Green  = Target process / correct path" { style.fill: "#d6f5d6"; style.stroke: "#2e7d32"; style.border-radius: 4 }
  l4: "Red    = Wrong path / race condition" { style.fill: "#ffcccc"; style.stroke: "#cc0000"; style.border-radius: 4 }
  l5: "Yellow = Mid-syscall edge case" { style.fill: "#fffacc"; style.stroke: "#b8860b"; style.border-radius: 4 }
}
legend.near: bottom-right
row_actors -> step1
step1 -> step2
step2 -> step3
step3 -> race_box: "contrast with WRONG path" {
  style.stroke-dash: 4
  style.stroke: "#cc0000"
}
step3 -> mid_syscall_box: "attach mid-syscall edge case" {
  style.stroke-dash: 4
  style.stroke: "#b8860b"
}
mid_syscall_box -> toggle_detail
toggle_detail -> regs_layout