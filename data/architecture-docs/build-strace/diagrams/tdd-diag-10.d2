vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## PTRACE_PEEKDATA -1 Ambiguity: errno Disambiguation Protocol
  **Step-by-step decision tree — valid data vs. real error**
| {near: top-center}

# ─── WRONG APPROACH ───────────────────────────────────────────
wrong: "❌ WRONG APPROACH" {
  style.fill: "#fff0f0"
  style.stroke: "#cc2200"
  style.stroke-width: 3
  style.border-radius: 8

  w_call: |md
    `word = ptrace(PTRACE_PEEKDATA, pid, addr, NULL)`
  | {
    style.fill: "#ffd6d6"
    style.stroke: "#cc2200"
  }
  
  w_check: "word == -1?" {
    shape: diamond
    style.fill: "#ffb3b3"
    style.stroke: "#cc2200"
    style.bold: true
  }
  
  w_err: "Report ERROR ✗" {
    style.fill: "#cc2200"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
  }
  
  w_ok: "Use word as data ✓" {
    style.fill: "#4a9e4a"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
  }
  
  w_bug: |md
    **BUG:** string containing
    `0xFF 0xFF 0xFF 0xFF 0xFF 0xFF 0xFF 0xFF`
    followed by `\0` causes premature abort —
    word == -1 but it's VALID DATA!
  | {
    style.fill: "#ffe0b2"
    style.stroke: "#e65100"
    style.stroke-dash: 5
    style.font-color: "#b71c1c"
  }

  w_call -> w_check
  w_check -> w_err: "YES\n(always wrong!)" {
    style.stroke: "#cc2200"
    style.font-color: "#cc2200"
    style.bold: true
  }
  w_check -> w_ok: "NO" {
    style.stroke: "#4a9e4a"
  }
  w_err -> w_bug
}

# ─── CONCRETE TRIGGER EXAMPLE ─────────────────────────────────
example: "Concrete False-Positive Trigger" {
  style.fill: "#fff8e1"
  style.stroke: "#f57f17"
  style.stroke-width: 2
  style.border-radius: 8

  mem: |'md
    **Tracee memory at addr 0x7fff0000:**
    | Byte | +0 | +1 | +2 | +3 | +4 | +5 | +6 | +7 | +8 |
    |------|----|----|----|----|----|----|----|----|-----|
    | Val  | FF | FF | FF | FF | FF | FF | FF | FF | 00 |

    `PTRACE_PEEKDATA(addr)` returns word = `0xFFFFFFFFFFFFFFFF` = **-1L**
    This is **valid string data**, not an error!
    Next word at `addr+8` contains the null terminator `\0`.
  '| {
    style.fill: "#fff8e1"
    style.stroke: "#f57f17"
    style.font: mono
  }
}

# ─── CORRECT APPROACH ─────────────────────────────────────────
correct: "✅ CORRECT APPROACH" {
  style.fill: "#f0fff4"
  style.stroke: "#1b5e20"
  style.stroke-width: 3
  style.border-radius: 8

  step1: "Step 1: Clear errno IMMEDIATELY before call" {
    style.fill: "#1565c0"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
  }
  
  step1_code: |md
    `errno = 0;`
    *(no function calls between here and ptrace)*
  | {
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.font: mono
  }
  
  step2: "Step 2: Make the PTRACE_PEEKDATA call" {
    style.fill: "#1565c0"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
  }
  
  step2_code: |md
    `long word = ptrace(PTRACE_PEEKDATA, pid,`
    `                   (void*)(uintptr_t)aligned_addr, NULL);`
  | {
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.font: mono
  }
  
  step3: "Step 3: TWO-CONDITION check — both must be true for real error" {
    style.fill: "#1565c0"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
  }
  
  gate_neg: "word == -1L?" {
    shape: diamond
    style.fill: "#c8e6c9"
    style.stroke: "#1b5e20"
    style.bold: true
  }
  
  gate_errno: "errno != 0?" {
    shape: diamond
    style.fill: "#c8e6c9"
    style.stroke: "#1b5e20"
    style.bold: true
  }
  
  real_error: "REAL ERROR\nreturn -1" {
    style.fill: "#cc2200"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
    style.bold: true
  }
  
  valid_neg1: "VALID DATA\nword = 0xFFFFFFFFFFFFFFFF\nContinue scanning bytes" {
    style.fill: "#2e7d32"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
    style.bold: true
  }
  
  valid_pos: "VALID DATA (positive)\nContinue scanning bytes" {
    style.fill: "#2e7d32"
    style.font-color: white
    style.stroke-width: 0
    style.border-radius: 4
  }
  
  errno_causes: |md
    **errno set by kernel when:**
    - Address not mapped (`EFAULT` = 14)
    - Tracee exited (`ESRCH` = 3)
    - Permission denied (`EPERM` = 1)
    *errno stays 0 when word is legitimately -1*
  | {
    style.fill: "#fce4ec"
    style.stroke: "#880e4f"
    style.border-radius: 4
  }
  
  no_intervene: |md
    ⚠️ **CRITICAL:** No function calls
    between `errno = 0` and `ptrace()`.
    Even `fprintf()` can set errno!
  | {
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
    style.stroke-dash: 3
  }

  step1 -> step1_code
  step1_code -> step2
  step2 -> step2_code
  step2_code -> step3
  step3 -> gate_neg
  gate_neg -> gate_errno: "YES\nword == -1" {
    style.stroke: "#e65100"
    style.bold: true
  }
  gate_neg -> valid_pos: "NO\nword ≥ 0" {
    style.stroke: "#2e7d32"
  }
  gate_errno -> real_error: "YES\nerrno ≠ 0\n→ kernel set it" {
    style.stroke: "#cc2200"
    style.bold: true
  }
  gate_errno -> valid_neg1: "NO\nerrno == 0\n→ valid 0xFF…FF" {
    style.stroke: "#2e7d32"
    style.bold: true
  }
  real_error -> errno_causes
  step1_code -> no_intervene {style.stroke-dash: 4; style.stroke: "#e65100"}
}

# ─── SIDE-BY-SIDE STATE COMPARISON ───────────────────────────
states: "State Comparison: Same word=-1, Different errno" {
  style.fill: "#f3e5f5"
  style.stroke: "#6a1b9a"
  style.stroke-width: 2
  style.border-radius: 8
  grid-columns: 2

  case_a: "Case A: errno=0 after call" {
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.border-radius: 4
    ca_detail: |md
      **Before:** `errno = 0`
      **After:**  `word = -1L`, `errno = 0`
      → errno unchanged by ptrace
      → Kernel did NOT set errno
      → **-1L is valid tracee data**
      → Continue; scan byte[0..7] as `0xFF`
    |
  }
  
  case_b: "Case B: errno≠0 after call" {
    style.fill: "#ffebee"
    style.stroke: "#b71c1c"
    style.border-radius: 4
    cb_detail: |md
      **Before:** `errno = 0`
      **After:**  `word = -1L`, `errno = 14` (EFAULT)
      → errno WAS changed by ptrace
      → Kernel reported an error
      → **-1L is an error sentinel**
      → Abort; return -1 to caller
    |
  }
}

# ─── CONNECTIONS BETWEEN SECTIONS ─────────────────────────────
wrong -> example: "triggers on\nthis input" {
  style.stroke: "#e65100"
  style.stroke-dash: 5
  style.font-color: "#e65100"
}
example -> correct: "use this protocol\nto handle correctly" {
  style.stroke: "#1b5e20"
  style.bold: true
  style.font-color: "#1b5e20"
}
correct -> states: "illustrates\nboth outcomes" {
  style.stroke: "#6a1b9a"
  style.stroke-dash: 3
}