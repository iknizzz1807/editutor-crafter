vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right

title: |'md
  ## Syscall Argument Register Mapping
  ### From Signature Table → Registers → Formatters
'| {near: top-center}

# ─── Signature Table (Purple Header) ───────────────────────────────────
sig_table: "syscall_sigs[] Entry" {
  style: {
    fill: "#e8d5f5"
    stroke: "#7b2d8b"
    stroke-width: 2
    border-radius: 6
  }
  sig_open: |'md
    **open()**
    args[0] = ARG_STR
    args[1] = ARG_OPEN_FLAGS
    args[2] = ARG_UINT
    nargs = 3
  '| {style: {fill: "#f3e8ff"; stroke: "#7b2d8b"; border-radius: 4}}
  sig_mmap: |'md
    **mmap()**
    args[0] = ARG_PTR
    args[1] = ARG_UINT
    args[2] = ARG_MMAP_PROT
    args[3] = ARG_MMAP_FLAGS
    args[4] = ARG_FD
    args[5] = ARG_UINT
    nargs = 6
  '| {style: {fill: "#f3e8ff"; stroke: "#7b2d8b"; border-radius: 4}}
}

# ─── user_regs_struct (Blue Data) ──────────────────────────────────────
regs: "struct user_regs_struct\n(from PTRACE_GETREGS)" {
  style: {
    fill: "#dbeafe"
    stroke: "#1d4ed8"
    stroke-width: 2
    border-radius: 6
  }
  orig_rax: "orig_rax\nsyscall number" {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
    }
  }
  rdi: "rdi\narg 0  →  args[0]" {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
    }
  }
  rsi: "rsi\narg 1  →  args[1]" {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
    }
  }
  rdx: "rdx\narg 2  →  args[2]" {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
    }
  }
  r10: "r10\narg 3  →  args[3]" {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
      bold: true
    }
  }
  r8: "r8\narg 4  →  args[4]" {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
    }
  }
  r9: "r9\narg 5  →  args[5]" {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
    }
  }
  rcx_note: "rcx\n⚠ CLOBBERED — NOT arg 3" {
    style: {
      fill: "#fee2e2"
      stroke: "#dc2626"
      stroke-width: 2
      bold: true
    }
  }
  rax_ret: "rax\nreturn value (exit stop)" {
    style: {
      fill: "#d1fae5"
      stroke: "#065f46"
    }
  }
}

# ─── extract_args() ────────────────────────────────────────────────────
extract: "extract_args()\n&regs → syscall_info_t" {
  style: {
    fill: "#fef3c7"
    stroke: "#b45309"
    stroke-width: 2
    border-radius: 6
  }
  shape: rectangle
  info: |'md
    **syscall_info_t**
    syscall_nr  ← orig_rax
    args[0]     ← rdi
    args[1]     ← rsi
    args[2]     ← rdx
    args[3]     ← r10  ✓
    args[4]     ← r8
    args[5]     ← r9
    retval      ← rax (exit)
  '| {style: {fill: "#fffbeb"; stroke: "#b45309"; border-radius: 4}}
}

# ─── Formatters (Green Data) ───────────────────────────────────────────
formatters: "print_arg() Dispatch" {
  style: {
    fill: "#d1fae5"
    stroke: "#065f46"
    stroke-width: 2
    border-radius: 6
  }
  fmt_str: "ARG_STR\nread_string_from_tracee()\n→ \"\\\"path\\\"\"" {
    style: {fill: "#a7f3d0"; stroke: "#065f46"; border-radius: 4}
  }
  fmt_flags: "ARG_OPEN_FLAGS\nprint_open_flags()\n→ O_RDONLY|O_CLOEXEC" {
    style: {fill: "#a7f3d0"; stroke: "#065f46"; border-radius: 4}
  }
  fmt_uint: "ARG_UINT\nprintf(\"%llu\")\n→ 4096" {
    style: {fill: "#a7f3d0"; stroke: "#065f46"; border-radius: 4}
  }
  fmt_ptr: "ARG_PTR\nprintf(\"0x%llx\")\n→ NULL or 0x7f..." {
    style: {fill: "#a7f3d0"; stroke: "#065f46"; border-radius: 4}
  }
  fmt_prot: "ARG_MMAP_PROT\ndecode_flags()\n→ PROT_READ|PROT_WRITE" {
    style: {fill: "#a7f3d0"; stroke: "#065f46"; border-radius: 4}
  }
  fmt_mapflags: "ARG_MMAP_FLAGS\ndecode_flags()\n→ MAP_PRIVATE|MAP_ANON" {
    style: {fill: "#a7f3d0"; stroke: "#065f46"; border-radius: 4}
  }
  fmt_fd: "ARG_FD\nprintf(\"%d\")\n→ 3" {
    style: {fill: "#a7f3d0"; stroke: "#065f46"; border-radius: 4}
  }
}

# ─── rcx / syscall clobber annotation ─────────────────────────────────
clobber_note: |'md
  **Why r10 instead of rcx for arg 3?**
  The `syscall` instruction (x86_64) uses `rcx`
  to save the **return address (RIP)** before
  switching to kernel mode. rcx is destroyed.
  The kernel ABI therefore uses `r10` for arg 3.
  The C function ABI uses `rcx` for arg 4 — these
  are DIFFERENT conventions. Using `regs.rcx`
  for syscall arg 3 returns the **saved RIP value**,
  not the argument. This bug is silent.
'| {
  near: top-right
  style: {
    fill: "#fef2f2"
    stroke: "#dc2626"
    stroke-width: 2
    border-radius: 6
    font-size: 13
  }
}

# ─── Mapping Connections ─────────────────────────────────────────────
sig_table.sig_open -> regs.rdi: "args[0] = ARG_STR" {
  style: {stroke: "#7b2d8b"; stroke-dash: 3}
}
sig_table.sig_open -> regs.rsi: "args[1] = ARG_OPEN_FLAGS" {
  style: {stroke: "#7b2d8b"; stroke-dash: 3}
}
sig_table.sig_open -> regs.rdx: "args[2] = ARG_UINT" {
  style: {stroke: "#7b2d8b"; stroke-dash: 3}
}

sig_table.sig_mmap -> regs.r10: "args[3] = ARG_MMAP_FLAGS\n(uses r10, NOT rcx)" {
  style: {stroke: "#b45309"; stroke-width: 3; bold: true}
}
sig_table.sig_mmap -> regs.r8: "args[4] = ARG_FD" {
  style: {stroke: "#7b2d8b"; stroke-dash: 3}
}
sig_table.sig_mmap -> regs.r9: "args[5] = ARG_UINT" {
  style: {stroke: "#7b2d8b"; stroke-dash: 3}
}

# ─── regs → extract_args → syscall_info_t ─────────────────────────────
regs.orig_rax -> extract.info: "syscall_nr" {style: {stroke: "#1d4ed8"; stroke-width: 2}}
regs.rdi      -> extract.info: "args[0]"    {style.stroke: "#1d4ed8"}
regs.rsi      -> extract.info: "args[1]"    {style.stroke: "#1d4ed8"}
regs.rdx      -> extract.info: "args[2]"    {style.stroke: "#1d4ed8"}
regs.r10      -> extract.info: "args[3] ✓"  {style: {stroke: "#b45309"; stroke-width: 3; bold: true}}
regs.r8       -> extract.info: "args[4]"    {style.stroke: "#1d4ed8"}
regs.r9       -> extract.info: "args[5]"    {style.stroke: "#1d4ed8"}
regs.rax_ret  -> extract.info: "retval (exit stop)" {style: {stroke: "#065f46"; stroke-dash: 5}}

# ─── rcx is NOT forwarded (illegal path) ──────────────────────────────
regs.rcx_note -> extract.info: "ILLEGAL — never use\nfor arg 3" {
  style: {
    stroke: "#dc2626"
    stroke-width: 2
    stroke-dash: 5
    font-color: "#dc2626"
  }
  target-arrowhead: {
    shape: cross
    style.filled: true
  }
}

# ─── Association for clobber note callout ─────────────────────────────
clobber_note -> regs.rcx_note: {
  style: {
    stroke: "#dc2626"
    stroke-dash: 5
    opacity: 0.5
  }
  target-arrowhead: none
}

# ─── syscall_info_t args → formatters ─────────────────────────────────
extract.info -> formatters.fmt_str:      "args[0] → ARG_STR"        {style.stroke: "#065f46"}
extract.info -> formatters.fmt_flags:    "args[1] → ARG_OPEN_FLAGS"  {style.stroke: "#065f46"}
extract.info -> formatters.fmt_uint:     "args[2] → ARG_UINT"        {style.stroke: "#065f46"}
extract.info -> formatters.fmt_ptr:      "args[0] → ARG_PTR (mmap)"  {style: {stroke: "#065f46"; stroke-dash: 5}}
extract.info -> formatters.fmt_prot:     "args[2] → ARG_MMAP_PROT"   {style: {stroke: "#065f46"; stroke-dash: 5}}
extract.info -> formatters.fmt_mapflags: "args[3] → ARG_MMAP_FLAGS"  {style: {stroke: "#b45309"; stroke-width: 2; stroke-dash: 5}}
extract.info -> formatters.fmt_fd:       "args[4] → ARG_FD"          {style: {stroke: "#065f46"; stroke-dash: 5}}

# ─── ABI comparison callout (Corrected Block String) ──────────────────
abi_compare: |'md
  **ABI Comparison: syscall vs C function**
  | Arg | Syscall ABI | C function ABI (SysV) |
  |-----|-------------|----------------------|
  | 1   | rdi         | rdi                  |
  | 2   | rsi         | rsi                  |
  | 3   | rdx         | rdx                  |
  | **4** | **r10** ✓ | **rcx** ✗ for syscalls |
  | 5   | r8          | r8                   |
  | 6   | r9          | r9                   |
  `syscall` saves RIP → rcx; sysret restores from rcx+r11.
  Kernel therefore cannot use rcx for argument passing.
'| {
  near: bottom-center
  style: {
    fill: "#fffbeb"
    stroke: "#b45309"
    stroke-width: 2
    border-radius: 6
    font-size: 13
  }
}