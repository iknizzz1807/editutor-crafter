layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
  }
}

direction: down

title: {
  shape: text
  label: ||md
    ## Bitmask Flag Decoding: `open()` Flags — `0x80241`
    `O_WRONLY | O_CREAT | O_TRUNC | O_CLOEXEC`
  ||
  near: top-center
}

input: {
  label: |md
    **Input**
    `flags = 0x00080241`
    `O_ACCMODE = 0x3` (bits 0–1)
    `O_WRONLY  = 0x1`
    `O_RDWR    = 0x2`
    `O_CREAT   = 0x40`
    `O_TRUNC   = 0x200`
    `O_CLOEXEC = 0x80000`
  |
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    border-radius: 8
  }
}

why_special: {
  label: |md
    **Why O_RDONLY needs pre-extraction**
    `O_RDONLY = 0` → `flags & 0 == 0` is **always true**.
    Generic `decode_flags()` would spuriously match
    every flags value as O_RDONLY.
    **Solution:** extract 2-bit access mode field first,
    then run generic loop on remaining bits.
  |
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    border-radius: 8
    font-size: 13
  }
}

step1: {
  label: "STEP 1: Extract Access Mode"
  style: {
    fill: "#7B1FA2"
    font-color: white
    border-radius: 6
    bold: true
  }
}

step1_detail: {
  label: |md
    `access_mode = flags & O_ACCMODE`
    `= 0x00080241 & 0x3`
    `= 0x1`  → <span style="color:red">**O_WRONLY**</span>
    Switch on access_mode:
    • 0 → print `O_RDONLY`
    • 1 → print `O_WRONLY`  ✓
    • 2 → print `O_RDWR`
    • else → print `0x%x`
    Output so far: `O_WRONLY`
    first = 0 (have printed one token)
  |
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    border-radius: 4
    font-color: black
  }
}

step2: {
  label: "STEP 2: Clear Access Mode Bits"
  style: {
    fill: "#1565C0"
    font-color: white
    border-radius: 6
    bold: true
  }
}

step2_detail: {
  label: |md
    `rest = flags & ~O_ACCMODE`
    `= 0x00080241 & ~0x3`
    `= 0x00080241 & 0xFFFFFFFC`
    `= 0x00080240`
    <span style="color:red">**Bits 0–1 cleared.**</span>
    Remaining bits represent only
    creation/status flags — safe for
    the generic bit-test loop.
  |
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    border-radius: 4
    font-color: black
  }
}

step3: {
  label: "STEP 3: Iterate flag_entry_t Table"
  style: {
    fill: "#1B5E20"
    font-color: white
    border-radius: 6
    bold: true
  }
}

table_scan: {
  style: {
    fill: "#E8F5E9"
    stroke: "#1B5E20"
    border-radius: 4
  }
  
  row_creat: {
    label: ||md
      **Entry: O_CREAT = 0x40**
      Test: `rest & 0x40 == 0x40`?
      `0x00080240 & 0x40 = 0x40` <span style="color:red">**✓ MATCH**</span>
      → print `|O_CREAT`
      → `rest &= ~0x40` → `rest = 0x00080200`
    ||
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      border-radius: 3
    }
  }
  row_excl: {
    label: |md
      **Entry: O_EXCL = 0x80**
      Test: `rest & 0x80 == 0x80`?
      `0x00080200 & 0x80 = 0x0` <span style="color:gray">**✗ no match**</span>
    |
    style: {
      fill: "#FFEBEE"
      stroke: "#EF9A9A"
      border-radius: 3
    }
  }
  row_noctty: {
    label: |md
      **Entry: O_NOCTTY = 0x400**
      Test: `rest & 0x400 == 0x400`?
      `0x00080200 & 0x400 = 0x0` <span style="color:gray">**✗ no match**</span>
    |
    style: {
      fill: "#FFEBEE"
      stroke: "#EF9A9A"
      border-radius: 3
    }
  }
  row_trunc: {
    label: ||md
      **Entry: O_TRUNC = 0x200**
      Test: `rest & 0x200 == 0x200`?
      `0x00080200 & 0x200 = 0x200` <span style="color:red">**✓ MATCH**</span>
      → print `|O_TRUNC`
      → `rest &= ~0x200` → `rest = 0x00080000`
    ||
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      border-radius: 3
    }
  }
  row_append: {
    label: |md
      **Entry: O_APPEND = 0x400...**
      All: `rest & value = 0` <span style="color:gray">**✗ no match**</span>
    |
    style: {
      fill: "#FFEBEE"
      stroke: "#EF9A9A"
      border-radius: 3
    }
  }
  row_cloexec: {
    label: ||md
      **Entry: O_CLOEXEC = 0x80000**
      Test: `rest & 0x80000 == 0x80000`?
      `0x00080000 & 0x80000 = 0x80000` <span style="color:red">**✓ MATCH**</span>
      → print `|O_CLOEXEC`
      → `rest &= ~0x80000` → `rest = 0x00000000`
    ||
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      border-radius: 3
    }
  }
}

step4: {
  label: "STEP 4: Residual Bits Check"
  style: {
    fill: "#E65100"
    font-color: white
    border-radius: 6
    bold: true
  }
}

step4_detail: {
  label: ||md
    `if (rest != 0): print "|0x%lx" of rest`
    `rest = 0x00000000` → <span style="color:red">**no residual**</span>
    If unknown flags were present, e.g. `rest = 0x1000`,
    output would append `|0x1000`.
  ||
  style: {
    fill: "#FBE9E7"
    stroke: "#E65100"
    border-radius: 4
    font-color: black
  }
}

output: {
  label: ||md
    **Final Output**
    `O_WRONLY|O_CREAT|O_TRUNC|O_CLOEXEC`
    Complete symbolic representation.
    All bits accounted for. `rest = 0`.
  ||
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    border-radius: 8
    bold: true
  }
}

zero_case: {
  label: |md
    **O_RDONLY = 0 Special Case**
    If `flags = 0x00` (pure read-only):
    `access_mode = 0 & 0x3 = 0` → print `O_RDONLY`
    `rest = 0 & ~0x3 = 0`
    Loop: no entry has `0 & v == v` for any `v > 0`.
    Output: `O_RDONLY`
    **Without pre-extraction:** `(0 & 0) == 0` would match
    **every** zero-value entry in a generic bitmask loop.
  |
  style: {
    fill: "#FFF8E1"
    stroke: "#F9A825"
    border-radius: 8
    font-size: 13
  }
}

# Connections
input -> why_special: "Problem Context"
input -> step1: "flags = 0x80241" {
  style.stroke: "#7B1FA2"
  style.bold: true
}
step1 -> step1_detail
step1_detail -> step2: "Next Step" {
  style.stroke: "#1565C0"
  style.bold: true
}
step2 -> step2_detail
step2_detail -> step3: "rest = 0x80240" {
  style.stroke: "#1B5E20"
  style.bold: true
}
step3 -> table_scan
table_scan.row_creat -> table_scan.row_excl: "rest = 0x80200"
table_scan.row_excl -> table_scan.row_noctty
table_scan.row_noctty -> table_scan.row_trunc
table_scan.row_trunc -> table_scan.row_append: "rest = 0x80000"
table_scan.row_append -> table_scan.row_cloexec
table_scan.row_cloexec -> step4: "rest = 0x0" {
  style.stroke: "#E65100"
  style.bold: true
}
step4 -> step4_detail
step4_detail -> output: "Success" {
  style.stroke: "#2E7D32"
  style.bold: true
}
why_special -> zero_case: "Edge Case Logic"