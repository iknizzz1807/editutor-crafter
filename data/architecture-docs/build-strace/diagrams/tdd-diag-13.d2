vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

direction: right

# ── Classes ───────────────────────────────────────────────────
classes: {
  header_box: {
    style: {
      fill: "#7c3aed"
      font-color: white
      bold: true
      border-radius: 4
    }
  }
  struct_box: {
    style: {
      fill: "#ddd6fe"
      stroke: "#7c3aed"
      border-radius: 4
    }
  }
  dispatch_node: {
    style: {
      fill: "#1e40af"
      font-color: white
      bold: true
      border-radius: 6
      shadow: true
    }
  }
  formatter_leaf: {
    style: {
      fill: "#bfdbfe"
      stroke: "#1e40af"
      border-radius: 4
    }
  }
  flag_logic: {
    style: {
      fill: "#d1fae5"
      stroke: "#059669"
      border-radius: 4
    }
  }
}

# ── Memory Layout ─────────────────────────────────────────────
info_struct: {
  shape: sql_table
  label: "syscall_info_t | sizeof=64 bytes (one cache line)"
  style: {
    stroke: "#7c3aed"
    stroke-width: 2
    stroke-dash: 5
    fill: "#7c3aed" # Header
  }
  
  "0x00": "syscall_nr" {constraint: "8B (long)"}
  "0x08": "args[0] / rdi" {constraint: "8B (ull)"}
  "0x10": "args[1] / rsi" {constraint: "8B (ull)"}
  "0x18": "args[2] / rdx" {constraint: "8B (ull)"}
  "0x20": "args[3] / r10" {constraint: "8B (ull)"}
  "0x28": "args[4] / r8"  {constraint: "8B (ull)"}
  "0x30": "args[5] / r9"  {constraint: "8B (ull)"}
  "0x38": "retval / rax"  {constraint: "8B (long)"}
}

# Apply requested colors to memory fields
info_struct."0x00".style.fill: "#bfdbfe" # Data
info_struct."0x08".style.fill: "#fb923c" # Pointer/Arg
info_struct."0x10".style.fill: "#fb923c"
info_struct."0x18".style.fill: "#fb923c"
info_struct."0x20".style.fill: "#fb923c"
info_struct."0x28".style.fill: "#fb923c"
info_struct."0x30".style.fill: "#fb923c"
info_struct."0x38".style.fill: "#bfdbfe"

# ── Global Title ──────────────────────────────────────────────
title: {
  shape: text
  label: |md
    # Syscall Signature Table & Dispatch
    `syscall_sigs[]` → `lookup_sig()` → `print_arg()` → formatters
  |
  near: top-center
}

# ── Signature Table ───────────────────────────────────────────
sig_table: "syscall_sigs[]" {
  class: header_box

  sig_read: {
    label: |md
      **[0] "read"**
      nargs=3
      args: [FD, PTR, UINT]
    |
    class: struct_box
  }
  
  sig_write: {
    label: |md
      **[1] "write"**
      nargs=3
      args: [FD, STR, UINT]
    |
    class: struct_box
  }

  sig_open: {
    label: |md
      **[2] "open"**
      nargs=3
      args: [STR, FLAGS, OCTAL]
    |
    class: struct_box
  }

  sig_mmap: {
    label: |md
      **[9] "mmap"**
      nargs=6
      args: [PTR, UINT, PROT, FLAGS, FD, UINT]
    |
    class: struct_box
  }
}

# ── Enum & Lookup Logic ───────────────────────────────────────
arg_type_enum: "arg_type_t (enum)" {
  style.fill: "#e0e7ff"
  label: |md
    ARG_NONE = 0
    ARG_INT  = 1
    ARG_UINT = 2
    ARG_FD   = 3
    ARG_STR  = 4
    ARG_PTR  = 6
    ARG_OPEN_FLAGS = 7
    ARG_MMAP_PROT  = 8
  |
}

lookup_sig: "lookup_sig(nr)" {
  class: header_box
  tooltip: "O(N) linear scan using strcmp on syscall_sigs[i].name"
}

# ── Dispatcher ────────────────────────────────────────────────
dispatch: "print_arg(pid, type, val, out)" {
  class: dispatch_node
  label: "print_arg()\nswitch(type)"
}

# ── Formatters ────────────────────────────────────────────────
formatters: {
  fmt_int: "ARG_INT\nfprintf(out, \"%lld\", val)" { class: formatter_leaf }
  fmt_fd: "ARG_FD\nfprintf(out, \"%d\", val)" { class: formatter_leaf }
  fmt_hex: "ARG_PTR / HEX\nfprintf(out, \"0x%llx\", val)" { class: formatter_leaf }
  
  fmt_str: "ARG_STR (PTRACE_PEEKDATA)" {
    style.fill: "#fce7f3"
    s1: "read_string_from_tracee()"
    s2: "Loop PTRACE_PEEKDATA"
    s3: "Handle NUL / MaxLen"
    s1 -> s2 -> s3
  }

  fmt_flags: "ARG_FLAGS / PROT" {
    class: flag_logic
    accmode: "Mask bits 0-1\n(O_RDONLY etc)"
    loop: "Iterate bit-table\nprint '|' joined names"
    accmode -> loop
  }
}

# ── Call & Data Flow ──────────────────────────────────────────
info_struct -> lookup_sig: "syscall_nr\n(from orig_rax)" {
  style.stroke: "#fb923c"
}

sig_table -> lookup_sig: "search base"

lookup_sig -> dispatch: "Returns\nsyscall_sig_t*" {
  style.stroke-width: 2
}

dispatch -> formatters.fmt_int: "ARG_INT"
dispatch -> formatters.fmt_fd: "ARG_FD"
dispatch -> formatters.fmt_hex: "ARG_PTR"
dispatch -> formatters.fmt_str: "ARG_STR" {
  style.stroke: "#db2777"
  style.stroke-width: 2
}
dispatch -> formatters.fmt_flags: "ARG_OPEN_FLAGS\nARG_MMAP_PROT" {
  style.stroke: "#059669"
}

# Unknown syscall fallback
fallback: "Fallback (sig == NULL)" {
  style.fill: "#fef3c7"
  style.stroke: "#d97706"
  label: "Fallback:\nPrint args[0..5]\nas 0x%llx"
}

lookup_sig -> fallback: "No match" {
  style.stroke: "#d97706"
  style.stroke-dash: 3
}

# Constraint labels for technical determining
arg_type_enum -> dispatch: "Dispatches on type"
info_struct -> dispatch: "passes args[i]"