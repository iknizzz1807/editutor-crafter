layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: ||md
  ## Three-Level View: PTRACE_PEEKDATA Implementation
  Operation: Reading `/etc/passwd` (11 bytes) from tracee VA `0x7fff3a2b8000`
|| {near: top-center}

app_col: Application Layer (Tracer) {
  style.fill: "#e8f4f8"
  style.stroke: "#2980b9"
  style.stroke-width: 2

  memory_layout: ||md
    ### Tracee Virtual Memory
    | Offset | Byte | Field | Size |
    |:---|:---|:---|:---|
    | +0x0 | `/` | filename[0] | 1B |
    | +0x1 | `e` | filename[1] | 1B |
    | ... | ... | ... | ... |
    | +0x7 | `s` | filename[7] | 1B |
    | **+0x8** | `s` | **Next Word** | **8B** |
    | +0xb | `\0` | Terminator | 1B |
  || {
    style.fill: "#d6eaf8"
    style.stroke: "#2980b9"
  }

  logic: Logic Flow {
    aligned: ||md
      **1. Alignment**
      `addr = 0x7fff3a2b8000`
      `aligned_addr = addr & ~7`
    || { style.fill: "#d6eaf8" }

    calls: Loop: PTRACE_PEEKDATA {
      c1: ||md
        **Call 1** @ `+0x0`
        Result: `"/etc/pas"`
      || { style.fill: "#d6eaf8" }
      
      c2: ||md
        **Call 2** @ `+0x8`
        Result: `"swd\0????"`
        *Null found at index 3*
      || { style.fill: "#d6eaf8" }

      c1 -> c2: "No NULL"
    }

    aligned -> calls
  }
  
  memory_layout -> logic.aligned: "target addr"
}

kernel_col: Kernel Layer (Linux) {
  style.fill: "#fef9e7"
  style.stroke: "#d4ac0d"
  style.stroke-width: 2

  syscall_entry: ||md
    **ptrace_check_attach()**
    - Verify tracer-tracee relationship
    - Ensure `TASK_TRACED` state
  || { style.fill: "#fef3cd" }

  mm_access: ||md
    **access_process_vm()**
    - `get_user_pages_remote()`
    - CR3 Switch to Tracee PGD
  || { style.fill: "#fef3cd" }

  pagewalk: 4-Level Page Walk {
    style.fill: "#fde8a0"
    pml4: "PML4"
    pdp: "PDPT"
    pd: "PD"
    pt: "PT"
    
    pml4 -> pdp -> pd -> pt: "resolve phys addr"
  }

  syscall_entry -> mm_access
  mm_access -> pagewalk
}

hw_col: Hardware Layer (x86_64) {
  style.fill: "#f5eef8"
  style.stroke: "#7d3c98"
  style.stroke-width: 2

  mmu: Memory Management Unit {
    tlb: "TLB Lookup" { shape: diamond }
    cache: Cache Hierarchy {
      l1: "L1 (4c)"
      l2: "L2 (12c)"
      l3: "L3 (40c)"
      l1 -> l2 -> l3: "miss"
    }
    ram: "DRAM (~200c)" { 
      style.fill: "#f4d03f"
      style.stroke: "#b7950b"
    }
    
    tlb -> cache: "Hit"
    cache.l3 -> ram: "Miss"
  }

  cpu_exec: ||md
    **copy_to_user**
    Transfer 8-byte word from Kernel
    to Tracer's Userspace buffer
  || { style.fill: "#a9cce3" }
}

# Summary Table
cost_summary: ||md
  ### Latency Cost Analysis (3GHz CPU)
  | Component | Duration | Cycles | Notes |
  |:---|:---|:---|:---|
  | **Context Switch** | ~200 ns | 600 | Syscall overhead |
  | **TLB Miss Walk** | ~100 ns | 300 | 4-level DRAM access |
  | **L3 Cache Hit** | ~13 ns | 40 | Warm data access |
  | **Total per word** | **~1.2 µs** | **~3,600** | For 8 bytes |
  
  **Efficiency:** PTRACE is ~10,000x slower than local `memcpy`.
|| {
  near: bottom-center
  style.fill: "#ffffff"
  style.stroke: "#2c3e50"
  style.stroke-width: 2
}

# Cross-Layer Connections
app_col.logic.calls.c1 -> kernel_col.syscall_entry: "SYSCALL" {
  style.stroke: "#2980b9"
  style.stroke-width: 2
}

kernel_col.pagewalk.pt -> hw_col.mmu.tlb: "VA -> PA" {
  style.stroke: "#d4ac0d"
  style.stroke-width: 2
}

hw_col.cpu_exec -> app_col.logic.calls: "Return 8B" {
  style.stroke: "#27ae60"
  style.stroke-dash: 5
}