layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    pad: 20
  }
}

title: {
  shape: text
  label: |md
    # `pid_state_t` Memory Layout (x86_64)
    **sizeof = 608 bytes (9.5 cache lines)**
    *Alignment: 8-byte boundaries*
  |
  near: top-center
}

legend: {
  shape: rectangle
  near: top-right
  style.fill: "#f8fafc"
  label: |md
    **Memory Map Legend**
    <span style="color: #7c3aed">■</span> Header / Key Identifiers
    <span style="color: #1d4ed8">■</span> Critical Data Path
    <span style="color: #b45309">■</span> Pointers / Register Args
    <span style="color: #059669">■</span> Metrics / Timing
    <span style="color: #0e7490">■</span> Line Buffer (outbuf)
    <span style="color: #9ca3af">■</span> Padding
    --- Cache Line Boundary (64B)
  |
}

# --- MEMORY STRUCTURE ---

memory_map: {
  grid-columns: 1
  grid-gap: 0

  # --- Cache Line 0 (Hot Path) ---
  cl0: "CACHE LINE 0 [0x000 - 0x03F] (HOT PATH)" {
    style: {
      stroke: "#7c3aed"
      stroke-dash: 4
      stroke-width: 2
      font-size: 10
      bold: true
      fill: "#f5f3ff"
    }
  }

  f0: "0x000 | pid (pid_t) | 4 B" {
    style: { fill: "#f5f3ff"; stroke: "#7c3aed"; font: mono }
  }
  f1: "0x004 | active (int) | 4 B" {
    style: { fill: "#f5f3ff"; stroke: "#7c3aed"; font: mono }
  }
  f2: "0x008 | in_syscall (int) | 4 B" {
    style: { fill: "#f5f3ff"; stroke: "#7c3aed"; font: mono }
  }
  f3: "0x00C | outbuf_len (int) | 4 B" {
    style: { fill: "#eff6ff"; stroke: "#1d4ed8"; font: mono }
  }
  f4: "0x010 | current.syscall_nr (long) | 8 B" {
    style: { fill: "#eff6ff"; stroke: "#1d4ed8"; font: mono }
  }
  f5: "0x018 | current.args[0] (u64) | 8 B" {
    style: { fill: "#fffbeb"; stroke: "#b45309"; font: mono }
  }
  f6: "0x020 | current.args[1] (u64) | 8 B" {
    style: { fill: "#fffbeb"; stroke: "#b45309"; font: mono }
  }
  f7: "0x028 | current.args[2] (u64) | 8 B" {
    style: { fill: "#fffbeb"; stroke: "#b45309"; font: mono }
  }
  f8: "0x030 | current.args[3] (u64 - r10) | 8 B" {
    style: { fill: "#fffbeb"; stroke: "#b45309"; font: mono; bold: true }
  }
  f9: "0x038 | current.args[4] (u64) | 8 B" {
    style: { fill: "#fffbeb"; stroke: "#b45309"; font: mono }
  }

  # --- Cache Line 1 (Warm Path) ---
  cl1: "CACHE LINE 1 [0x040 - 0x07F] (WARM PATH)" {
    style: {
      stroke: "#1d4ed8"
      stroke-dash: 4
      stroke-width: 2
      font-size: 10
      bold: true
      fill: "#eff6ff"
    }
  }
  f10: "0x040 | current.args[5] (u64) | 8 B" {
    style: { fill: "#fffbeb"; stroke: "#b45309"; font: mono }
  }
  f11: "0x048 | current.retval (long) | 8 B" {
    style: { fill: "#eff6ff"; stroke: "#1d4ed8"; font: mono }
  }
  f12: "0x050 | entry_time.tv_sec (time_t) | 8 B" {
    style: { fill: "#f0fdf4"; stroke: "#059669"; font: mono }
  }
  f13: "0x058 | entry_time.tv_nsec (long) | 8 B" {
    style: { fill: "#f0fdf4"; stroke: "#059669"; font: mono }
  }
  f14: "0x060 | outbuf[0..31] (char[32]) | 32 B" {
    style: { fill: "#ecfeff"; stroke: "#0e7490"; font: mono }
  }

  # --- Cache Line 2-8 (Cold/Buffer) ---
  cl2: "CACHE LINE 2-9 [0x080 - 0x25F] (COLD - LINE BUFFER)" {
    style: {
      stroke: "#0e7490"
      stroke-dash: 4
      stroke-width: 2
      font-size: 10
      bold: true
      fill: "#ecfeff"
    }
  }
  f15: "0x080 | outbuf[32..511] (char[480]) | 480 B" {
    style: { fill: "#ecfeff"; stroke: "#0e7490"; font: mono; stroke-dash: 2 }
  }

  # --- Tail and Assertions ---
  f16: "0x260 | _padding (char[8]) | 8 B" {
    style: { fill: "#f3f4f6"; stroke: "#9ca3af"; font: mono }
  }
}

# --- ANNOTATIONS ---

annot_r10: {
  label: |md
    **⚠ x86_64 Syscall Convention**
    Argument 4 is passed in **r10**,
    not **rcx** (which is clobbered
    by the `syscall` instruction).
  |
  style: {
    fill: "#fffbeb"
    stroke: "#b45309"
    font-size: 11
  }
}

annot_cl0_info: {
  label: |md
    **Performance Hot Path**
    Fields f0-f9 fit in a single cache line.
    Accessed on every ptrace context switch.
  |
  style: {
    fill: "#f5f3ff"
    stroke: "#7c3aed"
    font-size: 11
  }
}

annot_total: {
  shape: rectangle
  near: bottom-left
  label: |md
    **Structure Summary**
    - `pid`: Process ID key
    - `current`: `syscall_info_t` trace data
    - `outbuf`: 512B per-process formatting buffer
    - Total Size: 608 Bytes
    - Alignment: 8-byte (x86_64 native)
  |
  style: {
    fill: "#f8fafc"
    stroke: "#334155"
  }
}

# --- LAYOUT CONNECTIONS ---

memory_map.f8 -> annot_r10: { 
  style.stroke: "#b45309"
  style.stroke-dash: 3 
}

memory_map.cl0 -> annot_cl0_info: { 
  style.stroke: "#7c3aed"
  style.stroke-dash: 3 
}

growth_indicator: {
  ptr_begin: "" { style.opacity: 0 }
  ptr_end: "" { style.opacity: 0 }
  ptr_begin -> ptr_end: "Memory Growth (Increasing Offsets)" {
    style.stroke-width: 2
  }
}

# Target all connections inside memory_map to be invisible
(memory_map.** -> memory_map.**)[*].style.stroke: transparent