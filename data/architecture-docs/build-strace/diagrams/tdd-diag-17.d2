vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: "pid_map_t — Fibonacci Hashing & Linear Probing Layout" {
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# ─────────────────────────────────────────────────────────────
# SECTION 1: Memory Layout of pid_state_t
# ─────────────────────────────────────────────────────────────
memory_layout: "Memory Layout: pid_state_t [sizeof=608 bytes]" {
  style.stroke: "#7B5EA7"
  style.stroke-width: 2
  
  header: "0x00: Header Fields" {
    style.fill: "#7B5EA7"
    style.font-color: white
    
    active: "active (uint32_t)" {
      style.fill: "#3A7BD5"
      tooltip: "0=Free, 1=Occupied"
    }
    pid: "pid (pid_t/int32)" {
      style.fill: "#3A7BD5"
    }
  }

  data: "0x08: Data Payload" {
    style.fill: "#3A7BD5"
    style.font-color: white
    
    task_ptr: "task_struct* (8B)" {
      style.fill: "#E8A020"
    }
    context: "strace_context_t (592B)" {
      style.fill: "#3A7BD5"
    }
  }

  padding: "0x260: Padding" {
    style.fill: "#9E9E9E"
    label: "608B Alignment Padding"
  }

  header.active -> header.pid: "offset +4"
  header.pid -> data.task_ptr: "offset +8"
  data.task_ptr -> data.context: "offset +16"
}

# ─────────────────────────────────────────────────────────────
# SECTION 2: Fibonacci Hash Function
# ─────────────────────────────────────────────────────────────
hash_section: "① Fibonacci Hash Pipeline" {
  style.fill: "#F8F0FF"
  style.stroke: "#7B5EA7"
  
  logic: ||md
    ### Knuth Multiplicative Hash
    `idx = (pid * 2654435769u) >> (32 - 6)`
    
    - **PIDs:** 1001, 1002, 1003
    - **Distribution:** Golden Ratio $\phi$ ensures max spread
    - **Mask:** `& 63` (for power-of-2 capacity)
  ||
  
  input: "PID: 1234" { shape: parallelogram }
  multiplier: "0x9E3779B9" { 
    tooltip: "Knuth Constant"
    style.fill: "#E8A020"
  }
  shift: ">> 26" { shape: diamond }
  result: "Slot 12" { style.bold: true }

  input -> multiplier -> shift -> result
}

# ─────────────────────────────────────────────────────────────
# SECTION 3: Open-Addressing Hash Map
# ─────────────────────────────────────────────────────────────
map_section: "② pid_map_t Array [64 Slots]" {
  style.fill: "#F0F4FF"
  style.stroke: "#3A7BD5"
  
  slot11: "Slot 11: [FREE]" { 
    style.fill: "#4CAF50"
    style.font-color: white
  }
  slot12: "Slot 12: [PID 1234]" {
    style.fill: "#3A7BD5"
    style.font-color: white
  }
  slot13: "Slot 13: [PID 5678]" {
    style.fill: "#E8A020" 
    style.font-color: white
    tooltip: "COLLISION: Probed from 12"
  }
  slot14: "Slot 14: [FREE]" {
    style.fill: "#4CAF50"
    style.font-color: white
  }

  slot11 -> slot12: "Next"
  slot12 -> slot13: "Linear Probe (+1)" {
    style.stroke: "#E8A020"
    style.stroke-width: 4
    style.animated: true
  }
  slot13 -> slot14: "Next"
}

# ─────────────────────────────────────────────────────────────
# SECTION 4: Removal Chain Persistence
# ─────────────────────────────────────────────────────────────
remove_logic: "③ Removal & Chain Integrity" {
  style.fill: "#FFEBEE"
  style.stroke: "#E53935"
  
  warning: ||md
    **Tombstone-free Policy:**
    Standard deletion zeros `active`. 
    Linear probing chains are technically broken, 
    but PIDs are transient.
  ||

  state_before: "Initial Chain" {
    s1: "PID A" { style.fill: "#3A7BD5"; style.font-color: white }
    s2: "PID B" { style.fill: "#3A7BD5"; style.font-color: white }
    s3: "PID C" { style.fill: "#3A7BD5"; style.font-color: white }
    s1 -> s2 -> s3: "Valid Probe"
  }

  state_after: "After remove(B)" {
    a1: "PID A" { style.fill: "#3A7BD5"; style.font-color: white }
    a2: "0x00" { style.fill: "#9E9E9E"; style.font-color: white }
    a3: "PID C (Unreachable)" { 
      style.fill: "#E53935"
      style.font-color: white
      style.stroke-dash: 5
    }
    a1 -> a2: "STOP" { style.stroke: red }
    a2 -> a3: "Chain Broken" { style.stroke: red; style.stroke-dash: 3 }
  }
}

# ─────────────────────────────────────────────────────────────
# SECTION 5: Performance & Constraints
# ─────────────────────────────────────────────────────────────
perf_section: "④ Performance Specifications" {
  style.fill: "#F9FBE7"
  style.stroke: "#8BC34A"
  
  stats: ||md
    | Metric | Target | Constraint |
    | :--- | :--- | :--- |
    | Load Factor | < 0.50 | Rehash at 32/64 |
    | Probe Len | < 1.5 | Fibonacci Distribution |
    | Memory | 38.5 KB | Fixed Allocation |
    | Latency | < 10ns | O(1) Average Case |
  ||
}

# Top-level Routing
hash_section -> map_section: "Hash Result"
map_section -> memory_layout: "Slot Access"
map_section -> remove_logic: "Free Constraint"
remove_logic -> perf_section: "Load Impact" { style.stroke-dash: 5 }