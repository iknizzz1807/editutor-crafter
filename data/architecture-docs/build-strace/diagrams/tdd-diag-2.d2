layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # Syscall Entry/Exit Double-Stop State Machine
  ### x86_64 ptrace · PTRACE_O_TRACESYSGOOD enabled
| {
  near: top-center
}

# ── Classes ───────────────────────────────────────────────────
classes: {
  state_node: {
    shape: rectangle
    style: {
      stroke-width: 3
      border-radius: 8
      bold: true
      font-size: 15
    }
  }
  illegal_node: {
    shape: rectangle
    style: {
      fill: "#3d0000"
      font-color: "#ff9999"
      stroke: "#cc0000"
      stroke-width: 2
      stroke-dash: 4
      border-radius: 6
      font-size: 12
      italic: true
    }
  }
}

# ── States ────────────────────────────────────────────────────
AWAIT_ENTRY: {
  class: state_node
  style.fill: "#3d1a6e"
  style.font-color: "#e8d5ff"
  style.stroke: "#9b59b6"
  
  inv: |md
    **Invariant**
    `in_syscall == 0`
    Next stop = entry stop
    `entry_time` = unset
  |
}

AWAIT_EXIT: {
  class: state_node
  style.fill: "#1a3a6e"
  style.font-color: "#d5e8ff"
  style.stroke: "#3498db"
  
  inv: |md
    **Invariant**
    `in_syscall == 1`
    `current.syscall_nr` = valid
    `entry_time` = set
  |
}

EXITED: {
  shape: circle
  style: {
    fill: "#6e1a1a"
    font-color: "#ffd5d5"
    stroke: "#e74c3c"
    stroke-width: 3
    bold: true
    font-size: 14
    double-border: true
  }
  label: "EXITED\n(terminal)"
}

# ── Transitions ───────────────────────────────────────────────
● -> AWAIT_ENTRY: "init\n`in_syscall = 0`" {
  style.stroke-dash: 3
}

AWAIT_ENTRY -> AWAIT_EXIT: {
  label: |md
    **trigger:** `waitpid` → `WIFSTOPPED` (sig=0x85)
    **guard:** `in_syscall == 0`
    **actions:**
    1. <span style="color:red">**in_syscall ← 1**</span>
    2. READ `orig_rax` → <span style="color:red">**current.syscall_nr**</span>
    3. READ `rdi..r9` → <span style="color:red">**current.args**</span>
    4. `clock_gettime` → <span style="color:red">**entry_time**</span>
  |
  style: {
    stroke: "#2ecc71"
    stroke-width: 3
  }
}

AWAIT_EXIT -> AWAIT_ENTRY: {
  label: |md
    **trigger:** `waitpid` → `WIFSTOPPED` (sig=0x85)
    **guard:** `in_syscall == 1`
    **actions:**
    1. <span style="color:red">**in_syscall ← 0**</span>
    2. READ `rax` → <span style="color:red">**current.retval**</span>
    3. Calculate <span style="color:red">**elapsed_ns**</span>
    4. `fputs(outbuf, g_output)`
  |
  style: {
    stroke: "#3498db"
    stroke-width: 3
  }
}

# ── Termination & Signals ─────────────────────────────────────
AWAIT_ENTRY -> EXITED: {
  label: "WIFEXITED / WIFSIGNALED"
  style: {
    stroke: "#e74c3c"
    stroke-dash: 5
  }
}

AWAIT_EXIT -> EXITED: {
  label: "WIFEXITED (Mid-Syscall Death)"
  style: {
    stroke: "#e74c3c"
    stroke-dash: 5
  }
}

AWAIT_ENTRY -> AWAIT_ENTRY: {
  label: "Signal Stop (sig != 0x85)\nPTRACE_SYSCALL(pid, sig)"
  style: {
    stroke: "#e67e22"
    stroke-dash: 3
  }
}

AWAIT_EXIT -> AWAIT_EXIT: {
  label: "Signal Stop (sig != 0x85)\nPTRACE_SYSCALL(pid, sig)"
  style: {
    stroke: "#e67e22"
    stroke-dash: 3
  }
}

# ── Illegal Transitions ───────────────────────────────────────
illegal_entry: "❌ ILLEGAL: read `rax` as return\nat ENTRY stop (rax contains syscall nr)" {
  class: illegal_node
}

illegal_exit: "❌ ILLEGAL: read `orig_rax` as retval\nat EXIT stop (orig_rax is preserved nr)" {
  class: illegal_node
}

AWAIT_ENTRY -> illegal_entry: "ILLEGAL" {
  style: {
    stroke: "#cc0000"
    stroke-dash: 5
    font-color: "#cc0000"
    bold: true
  }
}

AWAIT_EXIT -> illegal_exit: "ILLEGAL" {
  style: {
    stroke: "#cc0000"
    stroke-dash: 5
    font-color: "#cc0000"
    bold: true
  }
}

# ── Register Legend ───────────────────────────────────────────
legend: |'md
  ### Register Logic per PTRACE_SYSCALL Stop
  | Stop Type | Syscall ID | Args | Return Value |
  | :--- | :--- | :--- | :--- |
  | **ENTRY** (0x85) | `orig_rax` | `rdi, rsi, rdx, r10, r8, r9` | `rax` (N/A - contains nr) |
  | **EXIT** (0x85) | `orig_rax` | (clobbered) | `rax` (Result) |

  **Wait Status:**
  - `(status >> 8) == 0x85`: Target is at syscall entry/exit.
  - `(status >> 8) == SIGTRAP`: Standard trap (breakpoints).
  - `WIFEXITED(status)`: Process terminated normally.
'| {
  near: bottom-center
  style: {
    fill: "#1a1a2e"
    font-color: "#ccccdd"
    stroke: "#444466"
    border-radius: 6
  }
}