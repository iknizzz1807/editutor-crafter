vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## PTRACE_EVENT_EXEC: Memory Map Replacement and Per-PID State Reset
  PID 1234 calls execve() — kernel replaces entire address space before first instruction of new program
| {near: top-center}
# ─────────────────────── TIMELINE SPINE ───────────────────────
timeline: Event Sequence {
  style.fill: "#f0f4ff"
  style.stroke: "#3a3a8a"
  style.stroke-width: 2
  style.border-radius: 8
  t1: "① syscall-entry stop\nexecve() fired\norig_rax = 59" {
    style.fill: "#e8d5f5"
    style.stroke: "#7b2fa8"
    style.border-radius: 6
  }
  t2: "② Kernel executes execve()\nDestroys old page table\nLoads new ELF binary\nNew stack / heap / libs" {
    style.fill: "#ffd6d6"
    style.stroke: "#c0392b"
    style.border-radius: 6
    style.bold: true
  }
  t3: "③ PTRACE_EVENT_EXEC stop\nNew address space LIVE\nOld mappings GONE\nTracer notified" {
    style.fill: "#fff3cd"
    style.stroke: "#d4900a"
    style.border-radius: 6
  }
  t4: "④ Tracer calls\nhandle_exec_event()\nResets pid_state_t" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 6
  }
  t5: "⑤ syscall-exit stop\nfor execve()\nrax = 0 (success)\nin_syscall: 1→0" {
    style.fill: "#cce5ff"
    style.stroke: "#0056b3"
    style.border-radius: 6
  }
  t6: "⑥ New program runs\nfirst instruction\n(dynamic linker)" {
    style.fill: "#e2e3e5"
    style.stroke: "#6c757d"
    style.border-radius: 6
  }
  t1 -> t2: "PTRACE_SYSCALL\nresume" { style.stroke: "#7b2fa8"; style.stroke-dash: 3 }
  t2 -> t3: "kernel generates\nPTRACE_EVENT_EXEC" { style.stroke: "#c0392b" }
  t3 -> t4: "waitpid(-1)\nstatus>>16 = 4" { style.stroke: "#d4900a" }
  t4 -> t5: "PTRACE_SYSCALL\nresume (signal=0)" { style.stroke: "#28a745"; style.stroke-dash: 3 }
  t5 -> t6: "PTRACE_SYSCALL\nresume" { style.stroke: "#0056b3"; style.stroke-dash: 3 }
}
# ─────────────────────── BEFORE STATE ───────────────────────
before: "pid_state_t  [PID 1234]  BEFORE  PTRACE_EVENT_EXEC" {
  style.fill: "#fff8f8"
  style.stroke: "#c0392b"
  style.stroke-width: 2
  style.border-radius: 8
  header_row: {
    style.fill: "#7b2fa8"
    style.border-radius: 4
    label: "pid_state_t — layout excerpt  (offsets on x86_64)"
  }
  f_pid: "offset 0x00  pid = 1234  (pid_t)" {
    style.fill: "#f3e5ff"
    style.stroke: "#7b2fa8"
    style.border-radius: 4
  }
  f_active: "offset 0x04  active = 1" {
    style.fill: "#f3e5ff"
    style.stroke: "#7b2fa8"
    style.border-radius: 4
  }
  f_insyscall: "offset 0x08  in_syscall = 1  ← entry stop seen" {
    style.fill: "#ffd6d6"
    style.stroke: "#c0392b"
    style.stroke-width: 2
    style.border-radius: 4
    style.bold: true
  }
  f_outbuf: "offset 0x0C  outbuf_len = 28  ← partial line buffered" {
    style.fill: "#ffd6d6"
    style.stroke: "#c0392b"
    style.stroke-width: 2
    style.border-radius: 4
    style.bold: true
  }
  current_block: "offset 0x10  current  (syscall_info_t — 64 bytes)" {
    style.fill: "#ffe0e0"
    style.stroke: "#c0392b"
    style.border-radius: 6
    c_nr: "syscall_nr = 59  (execve)" {
      style.fill: "#ffc8c8"
      style.stroke: "#a93226"
      style.border-radius: 3
    }
    c_a0: "args[0] = 0x7fff_ab12_3400  ← ptr to \"/bin/ls\"  OLD VADDR" {
      style.fill: "#ffd6b3"
      style.stroke: "#e67e22"
      style.border-radius: 3
    }
    c_a1: "args[1] = 0x7fff_ab12_3480  ← ptr to argv[]      OLD VADDR" {
      style.fill: "#ffd6b3"
      style.stroke: "#e67e22"
      style.border-radius: 3
    }
    c_a2: "args[2] = 0x7fff_ab12_3500  ← ptr to envp[]      OLD VADDR" {
      style.fill: "#ffd6b3"
      style.stroke: "#e67e22"
      style.border-radius: 3
    }
    c_ret: "retval  = LONG_MIN  (unset)" {
      style.fill: "#ffc8c8"
      style.stroke: "#a93226"
      style.border-radius: 3
    }
  }
  entry_time: "offset 0x50  entry_time = {tv_sec=1710000001, tv_nsec=234567890}" {
    style.fill: "#f3e5ff"
    style.stroke: "#7b2fa8"
    style.border-radius: 4
  }
  outbuf_data: "offset 0x60  outbuf = \"[pid 1234] execve(\\\"/bin/ls\\\",...\"  (partial)" {
    style.fill: "#ffd6d6"
    style.stroke: "#c0392b"
    style.border-radius: 4
  }
  stale_warning: |md
    ⚠️  **ALL pointer-valued args are STALE after exec**
    The old page table is destroyed.
    PTRACE_PEEKDATA on these addresses → **EFAULT**
    The virtual addresses may be reused by the NEW program
    for completely different data — or not mapped at all.
  | {
    style.fill: "#fff3cd"
    style.stroke: "#d4900a"
    style.stroke-width: 2
    style.border-radius: 6
  }
}
# ─────────────────────── KERNEL TRANSITION ───────────────────────
kernel_action: "Kernel do_execve() — Address Space Replacement" {
  style.fill: "#1a1a2e"
  style.font-color: white
  style.border-radius: 8
  style.stroke: "#e94560"
  style.stroke-width: 3
  k1: "1. mm_release(): drops all VMAs from old mm_struct" {
    style.fill: "#16213e"
    style.font-color: "#f0f0f0"
    style.border-radius: 4
  }
  k2: "2. load_elf_binary(): maps new PT_LOAD segments" {
    style.fill: "#16213e"
    style.font-color: "#f0f0f0"
    style.border-radius: 4
  }
  k3: "3. CR3 register reloaded → TLB flushed" {
    style.fill: "#16213e"
    style.font-color: "#f0f0f0"
    style.border-radius: 4
  }
  k4: "4. ptrace_notify(SIGTRAP | (PTRACE_EVENT_EXEC<<8))\n   → tracee TASK_TRACED; tracer wakes" {
    style.fill: "#e94560"
    style.font-color: white
    style.border-radius: 4
    style.bold: true
  }
  k5: "5. status = 0x00040057  →  (status>>16)&0xff = 4 = PTRACE_EVENT_EXEC" {
    style.fill: "#16213e"
    style.font-color: "#f0f0f0"
    style.border-radius: 4
    style.font: mono
  }
  k1 -> k2
  k2 -> k3
  k3 -> k4
  k4 -> k5
}
# ─────────────────────── AFTER STATE ───────────────────────
after: "pid_state_t  [PID 1234]  AFTER  handle_exec_event()" {
  style.fill: "#f0fff4"
  style.stroke: "#28a745"
  style.stroke-width: 2
  style.border-radius: 8
  header_row2: {
    style.fill: "#28a745"
    style.border-radius: 4
    label: "pid_state_t — same slot, fields reset by handle_exec_event()"
  }
  f_pid2: "offset 0x00  pid = 1234  (unchanged)" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 4
  }
  f_active2: "offset 0x04  active = 1  (unchanged)" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 4
  }
  f_insyscall2: "offset 0x08  in_syscall = 1  ← KEPT at 1 (exec exit stop pending)" {
    style.fill: "#cce5ff"
    style.stroke: "#0056b3"
    style.stroke-width: 2
    style.border-radius: 4
    style.bold: true
  }
  f_outbuf2: "offset 0x0C  outbuf_len = 0  ← RESET: stale partial line discarded" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 4
    style.bold: true
  }
  current_block2: "offset 0x10  current  (syscall_info_t — memset to zero)" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 6
    c_nr2: "syscall_nr = 0  (zeroed)" {
      style.fill: "#b8dfc5"
      style.stroke: "#28a745"
      style.border-radius: 3
    }
    c_a02: "args[0] = 0x0000_0000_0000_0000  (zeroed)" {
      style.fill: "#b8dfc5"
      style.stroke: "#28a745"
      style.border-radius: 3
    }
    c_a12: "args[1] = 0x0000_0000_0000_0000  (zeroed)" {
      style.fill: "#b8dfc5"
      style.stroke: "#28a745"
      style.border-radius: 3
    }
    c_a22: "args[2] = 0x0000_0000_0000_0000  (zeroed)" {
      style.fill: "#b8dfc5"
      style.stroke: "#28a745"
      style.border-radius: 3
    }
    c_ret2: "retval  = 0  (zeroed)" {
      style.fill: "#b8dfc5"
      style.stroke: "#28a745"
      style.border-radius: 3
    }
  }
  entry_time2: "offset 0x50  entry_time = unchanged (irrelevant; outbuf_len==0 skips stats)" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 4
  }
  outbuf_data2: "offset 0x60  outbuf = \"\\0...\" (length 0; content irrelevant)" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.border-radius: 4
  }
  exit_stop_note: |md
    **⑤ exec syscall-exit stop (next stop after resuming):**
    - `in_syscall` = 1 → toggle → 0 (exit stop, normal)
    - `outbuf_len` == 0 → **skip print** (`<... execve resumed> = 0` path)
    - `rax` = 0 (execve success in new program)
    - `stats_record(59, 0, elapsed_ns)` called normally
    - Line emitted: `"[pid 1234] <... execve resumed>) = 0\n"`
  | {
    style.fill: "#cce5ff"
    style.stroke: "#0056b3"
    style.stroke-width: 2
    style.border-radius: 6
  }
}
# ─────────────────────── in_syscall TOGGLE DETAIL ───────────────────────
toggle_detail: "Why in_syscall = 1 is KEPT (not reset to 0)" {
  style.fill: "#fff9e6"
  style.stroke: "#d4900a"
  style.stroke-width: 2
  style.border-radius: 8
  tg1: "Entry stop  fires  →  in_syscall: 0 → 1" {
    style.fill: "#ffeeba"
    style.stroke: "#d4900a"
    style.border-radius: 4
  }
  tg2: "PTRACE_EVENT_EXEC fires  →  in_syscall stays 1\n(event stops NEVER flip the toggle)" {
    style.fill: "#ffd699"
    style.stroke: "#c0791a"
    style.stroke-width: 2
    style.border-radius: 4
    style.bold: true
  }
  tg3: "Exit stop  fires  →  in_syscall: 1 → 0  ✓ correct" {
    style.fill: "#ffeeba"
    style.stroke: "#d4900a"
    style.border-radius: 4
  }
  tg_wrong: "❌ IF reset to 0 at PTRACE_EVENT_EXEC:\n   Exit stop sees in_syscall==0 → flips to 1\n   → tracer thinks NEXT stop is an EXIT\n   → reads args as retval → GARBAGE output\n   → toggle permanently desynchronized" {
    style.fill: "#ffd6d6"
    style.stroke: "#c0392b"
    style.stroke-width: 2
    style.border-radius: 4
    style.italic: true
  }
  tg1 -> tg2
  tg2 -> tg3
}
# ─────────────────────── CODE SNIPPET ───────────────────────
code: |go
  /* handle_exec_event() — called from handle_ptrace_event()
   * when (status >> 16) & 0xff == PTRACE_EVENT_EXEC (4)    */
  static void handle_exec_event(pid_t pid, pid_map_t *map) {
      pid_state_t *state = pid_map_get(map, pid);
      /* Keep in_syscall = 1: exec exit stop is still coming.
       * Resetting to 0 would desync the toggle permanently.  */
      state->in_syscall = 1;   /* already 1; explicit for clarity */
      /* Discard stale partial line — old address space is gone;
       * any pointers in outbuf are meaningless.               */
      state->outbuf_len = 0;
      /* Zero all cached arg values — they pointed into the old
       * address space; PTRACE_PEEKDATA would return EFAULT.  */
      memset(&state->current, 0, sizeof(state->current));
      fprintf(g_output, "[pid %d] +++ execve completed +++\n", pid);
  }
  /* In handle_syscall_stop() — exit stop with outbuf_len == 0:   */
  if (state->outbuf_len == 0) {
      /* Mid-exec or mid-attach: no entry half was buffered.
       * Print the strace-style "<resumed>" indicator.         */
      long retval = (long)regs.rax;
      long nr     = (long)regs.orig_rax;
      fprintf(g_output, "[pid %d] <... %s resumed>) = %ld\n",
              pid, syscall_name(nr), retval);
      return;   /* skip stats_record — entry_time was not set cleanly */
  }
| {
  style.fill: "#1e1e2e"
  style.font-color: "#cdd6f4"
  style.border-radius: 8
  style.stroke: "#585b70"
  style.font: mono
}
# ─────────────────────── CONNECTIONS ───────────────────────
before -> kernel_action: "exec syscall\nentry stop ①" {
  style.stroke: "#c0392b"
  style.stroke-width: 2
}
kernel_action -> timeline.t3: "PTRACE_EVENT_EXEC\nstatus>>16 = 4 ③" {
  style.stroke: "#e94560"
  style.stroke-width: 2
}
timeline.t4 -> after: "memset(current, 0)\noutbuf_len = 0\nin_syscall kept = 1" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
before -> toggle_detail: "Why NOT reset\nin_syscall to 0" {
  style.stroke: "#d4900a"
  style.stroke-dash: 4
}
after -> toggle_detail: "in_syscall = 1\npreserved" {
  style.stroke: "#d4900a"
  style.stroke-dash: 4
}
after -> code: "implementation" {
  style.stroke: "#585b70"
  style.stroke-dash: 3
}