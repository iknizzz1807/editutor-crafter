vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## Per-PID Output Buffer: Preventing Line Interleaving
| {near: top-center}
wrong: WRONG — Direct fprintf to stderr {
  style: {
    fill: "#fff0f0"
    stroke: "#cc0000"
    stroke-width: 2
    border-radius: 8
  }
  w_step1: "① PID 1234 entry stop" {
    style.fill: "#ffe0e0"
    style.border-radius: 4
  }
  w_call1: |md
    `fprintf(stderr,`
    `"[pid 1234] open("`)`
  | {
    shape: rectangle
    style.fill: "#ffd0d0"
    style.font: mono
    style.border-radius: 4
  }
  w_step2: "② PID 1235 complete syscall" {
    style.fill: "#ffe0e0"
    style.border-radius: 4
  }
  w_call2: |md
    `fprintf(stderr,`
    `"[pid 1235] getpid() = 1235\n")`
  | {
    shape: rectangle
    style.fill: "#ffd0d0"
    style.font: mono
    style.border-radius: 4
  }
  w_step3: "③ PID 1234 exit stop" {
    style.fill: "#ffe0e0"
    style.border-radius: 4
  }
  w_call3: |md
    `fprintf(stderr,`
    `") = 3\n")`
  | {
    shape: rectangle
    style.fill: "#ffd0d0"
    style.font: mono
    style.border-radius: 4
  }
  w_result: MANGLED OUTPUT {
    style.fill: "#cc0000"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
  }
  w_output: |md
    
    [pid 1234] open([pid 1235] getpid() = 1235
    ) = 3
    
  | {
    shape: rectangle
    style.fill: "#ffe8e8"
    style.stroke: "#cc0000"
    style.border-radius: 4
  }
  w_step1 -> w_call1: "write #1\npartial line" {
    style.stroke: "#cc0000"
    style.stroke-width: 2
  }
  w_step2 -> w_call2: "write #2\ninterleaves!" {
    style.stroke: "#cc0000"
    style.stroke-width: 2
    style.bold: true
  }
  w_step3 -> w_call3: "write #3\nstray closer" {
    style.stroke: "#cc0000"
    style.stroke-width: 2
  }
  w_call1 -> w_result
  w_call2 -> w_result
  w_call3 -> w_result
  w_result -> w_output
}
correct: CORRECT — Per-PID outbuf + single fputs {
  style: {
    fill: "#f0fff4"
    stroke: "#00aa44"
    stroke-width: 2
    border-radius: 8
  }
  state1234: "pid_state_t[1234]" {
    style.fill: "#e6f4ea"
    style.stroke: "#00aa44"
    style.border-radius: 4
    buf1234: |md
      **outbuf[512]**
      `[pid 1234] open("/etc/passwd", O_RDONLY`
    | {
      style.fill: "#c8e6c9"
      style.font: mono
      style.border-radius: 4
    }
    len1234: "outbuf_len = 42" {
      style.fill: "#a5d6a7"
      style.font: mono
      style.border-radius: 4
    }
    buf1234 -> len1234: "snprintf fills\nno stderr write"
  }
  state1235: "pid_state_t[1235]" {
    style.fill: "#e6f4ea"
    style.stroke: "#00aa44"
    style.border-radius: 4
    buf1235: |md
      **outbuf[512]**
      `[pid 1235] getpid() = 1235\n`
    | {
      style.fill: "#c8e6c9"
      style.font: mono
      style.border-radius: 4
    }
    len1235: "outbuf_len = 0 (flushed)" {
      style.fill: "#a5d6a7"
      style.font: mono
      style.border-radius: 4
    }
    buf1235 -> len1235: "fputs → single\nwrite() call"
  }
  c_step1: "① PID 1234 entry stop" {
    style.fill: "#c8e6c9"
    style.border-radius: 4
  }
  c_snprintf1: |md
    `snprintf(state->outbuf, 512,`
    `"[pid 1234] open(\"...\", O_RDONLY"`)`
  | {
    shape: rectangle
    style.fill: "#b2dfdb"
    style.font: mono
    style.border-radius: 4
  }
  c_note1: "NO write to stderr\nstored in outbuf only" {
    shape: oval
    style.fill: "#e8f5e9"
    style.stroke: "#4caf50"
    style.font-color: "#2e7d32"
    style.bold: true
  }
  c_step2: "② PID 1235 exit stop (complete)" {
    style.fill: "#c8e6c9"
    style.border-radius: 4
  }
  c_complete1235: |md
    snprintf appends `") = 1235\n"`
    into outbuf → full line ready
  | {
    shape: rectangle
    style.fill: "#b2dfdb"
    style.border-radius: 4
  }
  c_fputs1235: |md
    `fputs(state1235->outbuf, stderr)`
    **ONE write() syscall**
    `≤ PIPE_BUF (4096 B) → atomic`
  | {
    shape: rectangle
    style.fill: "#00aa44"
    style.font-color: white
    style.font: mono
    style.border-radius: 4
    style.bold: true
  }
  c_step3: "③ PID 1234 exit stop" {
    style.fill: "#c8e6c9"
    style.border-radius: 4
  }
  c_complete1234: |md
    snprintf appends `") = 3\n"`
    into outbuf → full line ready
  | {
    shape: rectangle
    style.fill: "#b2dfdb"
    style.border-radius: 4
  }
  c_fputs1234: |md
    `fputs(state1234->outbuf, stderr)`
    **ONE write() syscall**
    `≤ PIPE_BUF (4096 B) → atomic`
  | {
    shape: rectangle
    style.fill: "#00aa44"
    style.font-color: white
    style.font: mono
    style.border-radius: 4
    style.bold: true
  }
  c_result: CLEAN OUTPUT {
    style.fill: "#00aa44"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
  }
  c_output: |md
    
    [pid 1235] getpid() = 1235
    [pid 1234] open("/etc/passwd", O_RDONLY) = 3
    
  | {
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#00aa44"
    style.border-radius: 4
  }
  c_step1 -> c_snprintf1: "entry: build\npartial line"
  c_snprintf1 -> state1234.buf1234: "writes into\noutbuf only" {
    style.stroke-dash: 4
    style.stroke: "#00aa44"
  }
  c_snprintf1 -> c_note1
  c_step2 -> c_complete1235: "exit: append\nretval + newline"
  c_complete1235 -> state1235.buf1235: "complete line"  {
    style.stroke-dash: 4
    style.stroke: "#00aa44"
  }
  c_complete1235 -> c_fputs1235: "flush now"
  c_step3 -> c_complete1234: "exit: append\nretval + newline"
  c_complete1234 -> state1234.buf1234: "complete line" {
    style.stroke-dash: 4
    style.stroke: "#00aa44"
  }
  c_complete1234 -> c_fputs1234: "flush now"
  c_fputs1235 -> c_result
  c_fputs1234 -> c_result
  c_result -> c_output
}
atomicity: |md
  ### Why Single write() Guarantees Atomicity
  - `fputs(buf, stderr)` → one `write(2, buf, len)` syscall
  - Linux: `write()` to same fd from **single-threaded** process = no concurrent writer
  - POSIX: `write()` ≤ `PIPE_BUF` (4096 bytes) to a **pipe/socket** is atomic
  - For regular files + single writer: stdio buffer aggregation is harmless
  - **Rule:** build entire line in `outbuf`; emit with one `fputs()` at exit stop only
| {
  near: bottom-center
  style.fill: "#fffde7"
  style.stroke: "#f9a825"
  style.stroke-width: 2
  style.border-radius: 8
}