vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
title: |md
  ## Syscall Timing: What You Actually Measure vs True Cost
  **Observer Effect** — `getpid()` under ptrace
| {near: top-center}
timeline: "Single getpid() Trace — One Entry/Exit Pair" {
  style.fill: "#f0f4ff"
  style.stroke: "#4a5a9a"
  style.border-radius: 8
  t0: "T0: tracee executes syscall instruction" {
    shape: hexagon
    style.fill: "#5a3e8a"
    style.font-color: white
    style.bold: true
  }
  entry_stop: "Entry Stop Fires\ntracee frozen → tracer wakes" {
    shape: parallelogram
    style.fill: "#7c5cbf"
    style.font-color: white
  }
  t1: "T1: clock_gettime(CLOCK_MONOTONIC, &entry_time)" {
    shape: rectangle
    style.fill: "#e8d5ff"
    style.stroke: "#7c5cbf"
    style.bold: true
    style.font-color: "#3a1a6a"
  }
  tracer_work: "Tracer: PTRACE_GETREGS + arg decoding" {
    shape: rectangle
    style.fill: "#ddd0f0"
    style.stroke: "#7c5cbf"
    style.font-color: "#3a1a6a"
  }
  t2: "T2: ptrace(PTRACE_SYSCALL) → context switch to tracee" {
    shape: parallelogram
    style.fill: "#b39ddb"
    style.font-color: "#1a0a3a"
    style.bold: true
  }
  actual_syscall: "T3: kernel executes getpid()\nActual cost: ~100 ns" {
    shape: rectangle
    style.fill: "#1a7a3a"
    style.font-color: white
    style.bold: true
  }
  t4: "T4: exit stop fires\ntracee frozen → tracer wakes" {
    shape: parallelogram
    style.fill: "#7c5cbf"
    style.font-color: white
  }
  t5: "T5: clock_gettime(CLOCK_MONOTONIC, &exit_time)" {
    shape: rectangle
    style.fill: "#e8d5ff"
    style.stroke: "#7c5cbf"
    style.bold: true
    style.font-color: "#3a1a6a"
  }
  t0 -> entry_stop: "SIGTRAP | 0x80\nstop delivered" {
    style.stroke: "#7c5cbf"
    style.bold: true
  }
  entry_stop -> t1: "tracer running" {
    style.stroke: "#7c5cbf"
  }
  t1 -> tracer_work: "timestamp captured" {
    style.stroke: "#9a80c0"
    style.stroke-dash: 3
  }
  tracer_work -> t2: "PTRACE_GETREGS done" {
    style.stroke: "#9a80c0"
    style.stroke-dash: 3
  }
  t2 -> actual_syscall: "tracee resumes\n~1–5 µs context switch" {
    style.stroke: "#c0a030"
    style.bold: true
  }
  actual_syscall -> t4: "kernel writes PID\nto rax; exit stop" {
    style.stroke: "#1a7a3a"
    style.bold: true
  }
  t4 -> t5: "tracer wakes\n~1–5 µs context switch" {
    style.stroke: "#7c5cbf"
  }
}
breakdown: "Elapsed = T5 − T1  (What stats_record() receives)" {
  style.fill: "#fff4e0"
  style.stroke: "#c07820"
  style.border-radius: 8
  component_a: "Component A: T2 − T1\nTracer overhead (entry side)\nPTRACE_GETREGS + arg decode\n~1–5 µs" {
    shape: rectangle
    style.fill: "#ffddaa"
    style.stroke: "#c07820"
    style.font-color: "#5a2800"
  }
  component_b: "Component B: T4 − T2\nActual kernel syscall execution\ngetpid() reads task_struct→pid\n~100 ns" {
    shape: rectangle
    style.fill: "#aaffaa"
    style.stroke: "#1a7a3a"
    style.font-color: "#0a3a0a"
    style.bold: true
  }
  component_c: "Component C: T5 − T4\nTracer overhead (exit side)\nContext switch back + GETREGS\n~1–5 µs" {
    shape: rectangle
    style.fill: "#ffddaa"
    style.stroke: "#c07820"
    style.font-color: "#5a2800"
  }
  total: "MEASURED = A + B + C\n= ~2–10 µs for getpid()\nACTUAL = B = ~100 ns\nRATIO = 20×–100× inflation" {
    shape: rectangle
    style.fill: "#c07820"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
  }
  component_a -> total: ""
  component_b -> total: ""
  component_c -> total: ""
}
meaning: "What the Statistics Mean (and Don't Mean)" {
  style.fill: "#f0fff0"
  style.stroke: "#1a7a3a"
  style.border-radius: 8
  useful: "✓ MEANINGFUL in stats output" {
    style.fill: "#ccffcc"
    style.stroke: "#1a7a3a"
    style.font-color: "#0a3a0a"
    style.bold: true
    u1: "call_count — perfectly accurate\none increment per completed syscall" {
      style.fill: "#eeffee"
      style.stroke: "#1a7a3a"
    }
    u2: "error_count — perfectly accurate\nis_error_return(retval) is exact" {
      style.fill: "#eeffee"
      style.stroke: "#1a7a3a"
    }
    u3: "relative ranking — meaningful\nif read() takes 10× more than write(),\nthat ratio reflects real behavior" {
      style.fill: "#eeffee"
      style.stroke: "#1a7a3a"
    }
    u4: "blocking syscalls — meaningful\nread() blocked 500 ms on disk I/O\nmeasures as ~500 ms (overhead << wait)" {
      style.fill: "#eeffee"
      style.stroke: "#1a7a3a"
    }
  }
  not_useful: "✗ NOT MEANINGFUL in stats output" {
    style.fill: "#ffe0e0"
    style.stroke: "#aa2020"
    style.font-color: "#5a0000"
    style.bold: true
    n1: "absolute ns values for fast syscalls\ngetpid() at 8 µs ≠ 'getpid costs 8 µs'" {
      style.fill: "#ffeeee"
      style.stroke: "#aa2020"
    }
    n2: "comparison with non-traced runs\nptrace trace ≠ perf stat output" {
      style.fill: "#ffeeee"
      style.stroke: "#aa2020"
    }
    n3: "usecs/call for syscalls < 1 µs\noverhead dominates; number is fictional" {
      style.fill: "#ffeeee"
      style.stroke: "#aa2020"
    }
  }
}
observer_law: |md
  **The Observer Effect Law:**  
  elapsed_ns = actual_syscall_time + 2 × ptrace_context_switch_cost  
  For fast syscalls: ptrace cost >> actual cost → numbers are misleading  
  For slow syscalls (I/O waits): actual cost >> ptrace cost → numbers are accurate  
  **Use counts and ratios. Distrust absolute times for fast syscalls.**
| {
  near: bottom-center
  style.fill: "#1a1a3a"
  style.font-color: white
  style.border-radius: 8
}
timeline -> breakdown: "elapsed_ns\npassed to stats_record()" {
  style.stroke: "#c07820"
  style.bold: true
  style.stroke-dash: 0
}
breakdown -> meaning: "interpret\nresults" {
  style.stroke: "#1a7a3a"
  style.stroke-dash: 3
}