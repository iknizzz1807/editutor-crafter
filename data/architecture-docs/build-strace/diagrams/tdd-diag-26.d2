vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## `g_stats[400]` — syscall_stats_t Array
  **Total: 400 × 24 = 9,600 bytes ≈ L1-resident**
| {near: top-center}
legend: |md
  **Colors:** Header=Purple · Hot Entry=Blue · Warm Entry=Blue(dim) · Cold=Green · Padding=Gray
| {near: bottom-center}
# ─── ARRAY CONTAINER ───────────────────────────────────────────────
array: "g_stats[STATS_TABLE_SIZE=400]  sizeof = 9,600 bytes" {
  style.fill: "#f8f5ff"
  style.stroke: "#7c3aed"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-size: 13
  style.bold: true
  # ─── HEADER ROW ─────────────────────────────────────────────────
  hdr: "syscall_stats_t layout  (24 bytes per entry, 3 fields × uint64_t)" {
    style.fill: "#7c3aed"
    style.font-color: white
    style.font-size: 12
    style.bold: true
    style.border-radius: 4
  }
  # ─── ENTRY 0 — read ─────────────────────────────────────────────
  e0: "Index 0 — read()" {
    style.fill: "#1d4ed8"
    style.font-color: white
    style.font-size: 12
    style.bold: true
    style.border-radius: 4
    f0_cc: "+0x00  call_count   uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f0_ec: "+0x08  error_count  uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f0_tn: "+0x10  total_ns     uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f0_sz: "sizeof = 24 bytes  [offset 0x0000]" {style.fill: "#1e3a8a"; style.font-color: "#93c5fd"; style.font-size: 10; style.italic: true}
  }
  # ─── ENTRY 1 — write ────────────────────────────────────────────
  e1: "Index 1 — write()" {
    style.fill: "#1d4ed8"
    style.font-color: white
    style.font-size: 12
    style.bold: true
    style.border-radius: 4
    f1_cc: "+0x00  call_count   uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f1_ec: "+0x08  error_count  uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f1_tn: "+0x10  total_ns     uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f1_sz: "sizeof = 24 bytes  [offset 0x0018]" {style.fill: "#1e3a8a"; style.font-color: "#93c5fd"; style.font-size: 10; style.italic: true}
  }
  # ─── ENTRY 2 — open ─────────────────────────────────────────────
  e2: "Index 2 — open()" {
    style.fill: "#1d4ed8"
    style.font-color: white
    style.font-size: 12
    style.bold: true
    style.border-radius: 4
    f2_cc: "+0x00  call_count   uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f2_ec: "+0x08  error_count  uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f2_tn: "+0x10  total_ns     uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f2_sz: "sizeof = 24 bytes  [offset 0x0030]" {style.fill: "#1e3a8a"; style.font-color: "#93c5fd"; style.font-size: 10; style.italic: true}
  }
  # ─── ENTRY 3 — close ────────────────────────────────────────────
  e3: "Index 3 — close()" {
    style.fill: "#1d4ed8"
    style.font-color: white
    style.font-size: 12
    style.bold: true
    style.border-radius: 4
    f3_cc: "+0x00  call_count   uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f3_ec: "+0x08  error_count  uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f3_tn: "+0x10  total_ns     uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f3_sz: "sizeof = 24 bytes  [offset 0x0048]" {style.fill: "#1e3a8a"; style.font-color: "#93c5fd"; style.font-size: 10; style.italic: true}
  }
  # ─── CACHE LINE BOUNDARY ────────────────────────────────────────
  cl1: "─ ─ ─ ─ ─ ─ ─ ─ ─ ─  64-byte L1 cache line boundary at +0x0040  ─ ─ ─ ─ ─ ─ ─ ─ ─ ─" {
    style.fill: "#fef3c7"
    style.font-color: "#92400e"
    style.font-size: 10
    style.italic: true
    style.border-radius: 2
    style.stroke-dash: 5
    style.stroke: "#d97706"
  }
  # ─── ENTRIES 4-8: warm ──────────────────────────────────────────
  e4_8: "Indices 4–8  (poll, lseek, mmap, mprotect, munmap)  [offsets 0x0060–0x00CF]" {
    style.fill: "#3b82f6"
    style.font-color: white
    style.font-size: 11
    style.border-radius: 4
    note4_8: "5 entries × 24 bytes = 120 bytes   ■ WARM — accessed on most programs" {
      style.fill: "#1d4ed8"
      style.font-color: "#bfdbfe"
      style.font-size: 10
    }
  }
  # ─── ENTRY 9 — mmap (hot) ───────────────────────────────────────
  e9: "Index 9 — mmap()  [offset 0x00D8]" {
    style.fill: "#1d4ed8"
    style.font-color: white
    style.font-size: 12
    style.bold: true
    style.border-radius: 4
    f9_cc: "+0x00  call_count   uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f9_ec: "+0x08  error_count  uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f9_tn: "+0x10  total_ns     uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
  }
  # ─── ENTRIES 10-99: mixed ───────────────────────────────────────
  cl2: "─ ─ ─ ─ ─ ─ ─ ─  64-byte cache line boundaries every 2.67 entries  ─ ─ ─ ─ ─ ─ ─ ─" {
    style.fill: "#fef3c7"
    style.font-color: "#92400e"
    style.font-size: 10
    style.italic: true
    style.border-radius: 2
    style.stroke-dash: 5
    style.stroke: "#d97706"
  }
  e10_99: "Indices 10–99  (brk, rt_sigaction … getgid, …)  [offsets 0x00F0–0x08FF]" {
    style.fill: "#3b82f6"
    style.font-color: white
    style.font-size: 11
    style.border-radius: 4
    note10_99: "90 entries × 24 bytes = 2,160 bytes   ■ WARM for common programs" {
      style.fill: "#1d4ed8"
      style.font-color: "#bfdbfe"
      style.font-size: 10
    }
  }
  # ─── ENTRIES 100-256: cool ──────────────────────────────────────
  e100_256: "Indices 100–256  (rare syscalls)  [offsets 0x0900–0x17FF]" {
    style.fill: "#9ca3af"
    style.font-color: white
    style.font-size: 11
    style.border-radius: 4
    style.border-radius: 4
    note100: "157 entries × 24 bytes = 3,768 bytes   □ COOL — occasional access" {
      style.fill: "#6b7280"
      style.font-color: "#e5e7eb"
      style.font-size: 10
    }
  }
  # ─── ENTRY 257 — openat (hot) ───────────────────────────────────
  e257: "Index 257 — openat()  [offset 0x1818]" {
    style.fill: "#1d4ed8"
    style.font-color: white
    style.font-size: 12
    style.bold: true
    style.border-radius: 4
    f257_cc: "+0x00  call_count   uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f257_ec: "+0x08  error_count  uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
    f257_tn: "+0x10  total_ns     uint64_t   8 bytes" {style.fill: "#2563eb"; style.font-color: white; style.font-size: 11}
  }
  # ─── ENTRIES 258-399: cold ──────────────────────────────────────
  e258_399: "Indices 258–399  (very rare syscalls)  [offsets 0x1830–0x25FF]" {
    style.fill: "#4ade80"
    style.font-color: "#14532d"
    style.font-size: 11
    style.border-radius: 4
    note258: "142 entries × 24 bytes = 3,408 bytes   □ COLD — rarely touched" {
      style.fill: "#16a34a"
      style.font-color: "#dcfce7"
      style.font-size: 10
    }
  }
  # ─── END SENTINEL ───────────────────────────────────────────────
  end_sentinel: "End of array  [offset 0x2580 = 9,600 bytes]" {
    style.fill: "#374151"
    style.font-color: "#d1d5db"
    style.font-size: 11
    style.border-radius: 4
  }
}
# ─── CACHE ANALYSIS PANEL ───────────────────────────────────────────
cache_panel: "Cache Behavior Analysis" {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-size: 13
  style.bold: true
  l1_note: |md
    **L1 Cache (32 KB typical)**
    9,600 bytes = **30% of L1 capacity**
    Entire g_stats[] fits in L1 after warmup
    Access latency: ~4 cycles per load/store
  | {style.fill: "#dcfce7"; style.font-size: 11}
  l2_note: |md
    **L2 Cache (256 KB typical)**
    g_stats[] is 3.75% of L2
    Cold-start: first access fetches 64-byte
    cache line covering 2.67 entries
  | {style.fill: "#bbf7d0"; style.font-size: 11}
  stats_record_cost: |md
    **stats_record() hot path cost:**
    1. Bounds check: `nr < STATS_TABLE_SIZE` → 1 cycle (branch predicted)
    2. Array index: `&g_stats[nr]` → 1 cycle (pointer arithmetic)
    3. `call_count++` → 1 L1 load + 1 store = ~4 cycles
    4. `is_error_return(retval)` → 2 comparisons = 2 cycles
    5. `error_count++` (conditional) → ~2 cycles
    6. `total_ns += elapsed_ns` → 1 L1 load + 1 store = ~4 cycles
    **Total: ~15 cycles ≈ 5 ns at 3 GHz (L1-hot)**
    vs. preceding ptrace context switch: ~3,000–10,000 cycles
  | {style.fill: "#f0fdf4"; style.font-size: 11}
}
# ─── ACCESS FREQUENCY PANEL ─────────────────────────────────────────
freq_panel: "Access Frequency by Syscall Index" {
  style.fill: "#fff7ed"
  style.stroke: "#ea580c"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-size: 12
  style.bold: true
  hot_label: "■ HOT  (indices 0–9, 257)" {style.fill: "#1d4ed8"; style.font-color: white; style.font-size: 11}
  warm_label: "■ WARM (indices 10–99)" {style.fill: "#3b82f6"; style.font-color: white; style.font-size: 11}
  cool_label: "□ COOL (indices 100–256)" {style.fill: "#9ca3af"; style.font-color: white; style.font-size: 11}
  cold_label: "□ COLD (indices 258–399)" {style.fill: "#4ade80"; style.font-color: "#14532d"; style.font-size: 11}
  working_set: |md
    **Working set for `ls /tmp`:**
    read(0), write(1), open(2), close(3),
    mmap(9), brk(12), openat(257), getdents64(217)
    → 8 entries × 24 bytes = **192 bytes = 3 cache lines**
    All 3 cache lines L1-resident after first access
  | {style.fill: "#fef3c7"; style.font-size: 11}
}
# ─── STATIC ASSERT PANEL ────────────────────────────────────────────
assert_panel: "Compile-Time Verification" {
  style.fill: "#faf5ff"
  style.stroke: "#7c3aed"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-size: 12
  a1: "_Static_assert(sizeof(syscall_stats_t) == 24, ...)" {style.fill: "#7c3aed"; style.font-color: white; style.font-size: 11}
  a2: "_Static_assert(sizeof(g_stats) == 9600, ...)" {style.fill: "#7c3aed"; style.font-color: white; style.font-size: 11}
  a3: "_Static_assert(STATS_TABLE_SIZE >= 400, ...)" {style.fill: "#7c3aed"; style.font-color: white; style.font-size: 11}
}
# ─── CONNECTIONS ────────────────────────────────────────────────────
cache_panel -> array: "fits entirely in L1 after warmup" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
  style.stroke-dash: 4
}
freq_panel -> array.e0: "most-accessed entry" {
  style.stroke: "#1d4ed8"
  style.stroke-width: 2
}
freq_panel -> array.e257: "openat: glibc default since Linux 2.6.16" {
  style.stroke: "#1d4ed8"
  style.stroke-width: 2
}
assert_panel -> array: "enforces layout at compile time" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
  style.stroke-dash: 4
}