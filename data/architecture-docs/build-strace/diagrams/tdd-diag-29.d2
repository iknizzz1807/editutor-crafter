vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  ## Clean Detach on SIGINT: Signal Handler → Flag → detach_all()
| {near: top-center}
# ─── SIGNAL HANDLER SIDE ───────────────────────────────────────────────────
sig_handler: "sigint_handler(int sig)" {
  style.fill: "#4a1942"
  style.stroke: "#c084fc"
  style.font-color: white
  style.border-radius: 6
  note: |md
    **Async-signal-safe ONLY**
    - No printf, fprintf, malloc, free
    - No ptrace, waitpid
    - Single atomic write to
      `volatile sig_atomic_t`
  | {
    shape: text
    style.font-size: 12
  }
}
sa_flags: "sigaction sa\n.sa_flags = 0\n(NO SA_RESTART)" {
  shape: rectangle
  style.fill: "#7c2d12"
  style.stroke: "#f97316"
  style.font-color: white
  style.border-radius: 4
  style.font-size: 12
}
g_interrupted_flag: "g_interrupted = 1" {
  shape: rectangle
  style.fill: "#7f1d1d"
  style.stroke: "#ef4444"
  style.stroke-width: 3
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
sig_handler -> g_interrupted_flag: "only action\n(atomic write)" {
  style.stroke: "#ef4444"
  style.bold: true
}
# ─── MAIN LOOP STATE MACHINE ────────────────────────────────────────────────
loop_top: "● Loop Top\nwhile (num_active > 0)" {
  shape: circle
  style.fill: "#1e3a5f"
  style.stroke: "#60a5fa"
  style.font-color: white
}
check_interrupted: "CHECK\ng_interrupted?" {
  shape: diamond
  style.fill: "#1e3a5f"
  style.stroke: "#60a5fa"
  style.font-color: white
  style.bold: true
}
call_waitpid: "waitpid(-1, &status, 0)\n[BLOCKING]" {
  shape: rectangle
  style.fill: "#0f2027"
  style.stroke: "#3b82f6"
  style.font-color: "#93c5fd"
  style.border-radius: 4
}
waitpid_result: "waitpid result?" {
  shape: diamond
  style.fill: "#1e3a5f"
  style.stroke: "#60a5fa"
  style.font-color: white
}
eintr_path: "errno == EINTR\n(SIGINT interrupted\nwaitpid)" {
  shape: rectangle
  style.fill: "#451a03"
  style.stroke: "#f97316"
  style.font-color: "#fed7aa"
  style.border-radius: 4
  style.font-size: 12
}
normal_dispatch: "Normal event\ndispatch\n(WIFEXITED /\nWIFSTOPPED /\netc.)" {
  shape: rectangle
  style.fill: "#1e3a5f"
  style.stroke: "#3b82f6"
  style.font-color: "#bfdbfe"
  style.border-radius: 4
  style.font-size: 12
}
# ─── SHUTDOWN PATH ──────────────────────────────────────────────────────────
print_msg: 'fprintf(g_output,\n"Tracer interrupted —\ndetaching...")' {
  shape: rectangle
  style.fill: "#3b0764"
  style.stroke: "#a855f7"
  style.font-color: white
  style.border-radius: 4
  style.font-size: 12
}
call_detach_all: "detach_all(&g_pid_map)" {
  shape: rectangle
  style.fill: "#3b0764"
  style.stroke: "#a855f7"
  style.stroke-width: 3
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
loop_exit: "break\n(loop exits)" {
  shape: rectangle
  style.fill: "#0f2027"
  style.stroke: "#6366f1"
  style.font-color: "#a5b4fc"
  style.border-radius: 4
}
post_exit: "print_statistics()\nfclose(g_output)\nfree(filter)" {
  shape: rectangle
  style.fill: "#0f2027"
  style.stroke: "#6366f1"
  style.font-color: "#a5b4fc"
  style.border-radius: 4
  style.font-size: 12
}
terminal: "● EXIT\nmain() returns 0" {
  shape: circle
  style.fill: "#14532d"
  style.stroke: "#22c55e"
  style.font-color: white
  style.double-border: true
}
# ─── detach_all() SEQUENCE ───────────────────────────────────────────────────
detach_all_body: "detach_all() — per active PID slot" {
  style.fill: "#1c1038"
  style.stroke: "#7c3aed"
  style.border-radius: 8
  iter: "FOR each slot i in g_pid_map\nIF !slot->active: continue\npid = slot->pid" {
    shape: rectangle
    style.fill: "#2e1065"
    style.stroke: "#7c3aed"
    style.font-color: "#ddd6fe"
    style.border-radius: 4
    style.font-size: 12
  }
  try_detach: "ptrace(PTRACE_DETACH,\npid, 0, 0)" {
    shape: rectangle
    style.fill: "#312e81"
    style.stroke: "#818cf8"
    style.font-color: white
    style.border-radius: 4
  }
  detach_ok: "detach_ok?" {
    shape: diamond
    style.fill: "#1e1b4b"
    style.stroke: "#818cf8"
    style.font-color: white
  }
  log_detached: 'fprintf(g_output,\n"Detached from pid %d\\n")' {
    shape: rectangle
    style.fill: "#14532d"
    style.stroke: "#22c55e"
    style.font-color: "#bbf7d0"
    style.border-radius: 4
    style.font-size: 12
  }
  check_errno: "errno == ESRCH\nor EIO?\n(process running)" {
    shape: diamond
    style.fill: "#1e1b4b"
    style.stroke: "#f59e0b"
    style.font-color: "#fde68a"
    style.font-size: 12
  }
  send_sigstop: "kill(pid, SIGSTOP)" {
    shape: rectangle
    style.fill: "#451a03"
    style.stroke: "#f97316"
    style.font-color: "#fed7aa"
    style.border-radius: 4
    style.font-size: 12
  }
  wnohang_loop: "waitpid(pid, &status, WNOHANG)\nRetry up to 100×\n(1ms sleep between attempts)" {
    shape: rectangle
    style.fill: "#1c1617"
    style.stroke: "#f97316"
    style.font-color: "#fed7aa"
    style.border-radius: 4
    style.font-size: 12
  }
  stopped_q: "WIFSTOPPED?\n(pid frozen)" {
    shape: diamond
    style.fill: "#1e1b4b"
    style.stroke: "#818cf8"
    style.font-color: white
    style.font-size: 12
  }
  retry_detach: "ptrace(PTRACE_DETACH,\npid, 0, 0) retry" {
    shape: rectangle
    style.fill: "#312e81"
    style.stroke: "#818cf8"
    style.font-color: white
    style.border-radius: 4
    style.font-size: 12
  }
  err_detach: "perror(PTRACE_DETACH)\nprocess may be gone" {
    shape: rectangle
    style.fill: "#450a0a"
    style.stroke: "#ef4444"
    style.font-color: "#fca5a5"
    style.border-radius: 4
    style.font-size: 12
  }
  other_err: "perror(...)\ncontinue to next PID" {
    shape: rectangle
    style.fill: "#450a0a"
    style.stroke: "#ef4444"
    style.font-color: "#fca5a5"
    style.border-radius: 4
    style.font-size: 12
  }
  next_slot: "continue\n(next slot)" {
    shape: rectangle
    style.fill: "#2e1065"
    style.stroke: "#7c3aed"
    style.font-color: "#ddd6fe"
    style.border-radius: 4
    style.font-size: 11
  }
  iter -> try_detach
  try_detach -> detach_ok
  detach_ok -> log_detached: "yes (== 0)" {style.stroke: "#22c55e"}
  detach_ok -> check_errno: "no (< 0)" {style.stroke: "#ef4444"}
  log_detached -> next_slot
  check_errno -> send_sigstop: "yes" {style.stroke: "#f97316"}
  check_errno -> other_err: "no\n(EPERM, etc.)" {style.stroke: "#ef4444"}
  other_err -> next_slot
  send_sigstop -> wnohang_loop
  wnohang_loop -> stopped_q
  stopped_q -> retry_detach: "yes" {style.stroke: "#22c55e"}
  stopped_q -> err_detach: "no (timeout\nor gone)" {style.stroke: "#ef4444"}
  retry_detach -> log_detached: "success" {style.stroke: "#22c55e"}
  retry_detach -> err_detach: "fail" {style.stroke: "#ef4444"}
  err_detach -> next_slot
}
# ─── SA_RESTART ANNOTATION ──────────────────────────────────────────────────
sa_restart_note: |md
  **WHY sa_flags = 0 (no SA_RESTART)**
  With `SA_RESTART`: kernel auto-restarts
  `waitpid` after SIGINT → never returns
  `EINTR` → loop never sees `g_interrupted`.
  Without `SA_RESTART`: `waitpid` returns
  `-1 / errno=EINTR` immediately → next
  iteration checks `g_interrupted` → detach.
| {
  near: bottom-right
  style.fill: "#1c1617"
  style.stroke: "#f97316"
  style.font-color: "#fed7aa"
  style.border-radius: 6
}
# ─── CONNECTIONS ────────────────────────────────────────────────────────────
sa_flags -> sig_handler: "registers handler\nSIGINT → sigint_handler\nno SA_RESTART" {
  style.stroke: "#f97316"
  style.stroke-dash: 3
  style.font-size: 11
}
loop_top -> check_interrupted
check_interrupted -> print_msg: "YES\ng_interrupted==1" {
  style.stroke: "#ef4444"
  style.stroke-width: 3
  style.bold: true
}
check_interrupted -> call_waitpid: "NO" {style.stroke: "#60a5fa"}
call_waitpid -> waitpid_result: "event or error"
waitpid_result -> eintr_path: "pid < 0\nerrno==EINTR" {style.stroke: "#f97316"}
waitpid_result -> normal_dispatch: "pid > 0\nnormal event" {style.stroke: "#60a5fa"}
eintr_path -> loop_top: "SIGINT delivered\nduring wait;\ng_interrupted now 1;\nretry loop" {
  style.stroke: "#f97316"
  style.stroke-dash: 4
  style.font-size: 11
}
normal_dispatch -> loop_top: "continue tracing" {
  style.stroke: "#60a5fa"
  style.stroke-dash: 3
}
print_msg -> call_detach_all
call_detach_all -> detach_all_body: "iterates all\nactive PID slots" {
  style.stroke: "#a855f7"
}
detach_all_body -> loop_exit: "all PIDs\ndetached" {style.stroke: "#a855f7"}
loop_exit -> post_exit
post_exit -> terminal
g_interrupted_flag -> check_interrupted: "flag visible\nto main loop\n(volatile ensures\nno register caching)" {
  style.stroke: "#ef4444"
  style.stroke-dash: 5
  style.font-size: 11
}