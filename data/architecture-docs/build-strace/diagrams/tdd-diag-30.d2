vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: "Argument Parsing: getopt Option Flow and tracer_opts_t Population" {
  shape: text
  near: top-center
  style: {
    font-size: 18
    bold: true
  }
}
argv: "argv[]" {
  shape: rectangle
  style: {
    fill: "#E8E8F0"
    stroke: "#555577"
    font: mono
    font-size: 13
  }
}
plus_prefix: |md
  **'+' in optstring**
  stops at first non-option
  → argv[optind] = program
| {
  shape: rectangle
  near: top-center
  style: {
    fill: "#FFF9C4"
    stroke: "#C8A000"
    font-size: 12
  }
}
getopt: "getopt(argc, argv, \"+o:p:e:c\")" {
  shape: hexagon
  style: {
    fill: "#D0D8F8"
    stroke: "#3344AA"
    bold: true
    font: mono
    font-size: 13
  }
}
argv -> getopt: "argc, argv" {
  style.stroke: "#3344AA"
  style.font-size: 12
}
opts_struct: "tracer_opts_t opts" {
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    bold: true
    font-size: 14
  }
  attach_pid: "attach_pid: pid_t" {
    style: {
      fill: "#E8F5E9"
      stroke: "#66BB6A"
      font: mono
      font-size: 12
    }
  }
  show_stats: "show_stats: int" {
    style: {
      fill: "#E8F5E9"
      stroke: "#66BB6A"
      font: mono
      font-size: 12
    }
  }
  output_file: "output_file: const char *" {
    style: {
      fill: "#E8F5E9"
      stroke: "#66BB6A"
      font: mono
      font-size: 12
    }
  }
  filter_str: "filter_str: const char *" {
    style: {
      fill: "#E8F5E9"
      stroke: "#66BB6A"
      font: mono
      font-size: 12
    }
  }
}
case_o: "case 'o':" {
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    font: mono
    font-size: 12
  }
}
case_p: "case 'p':" {
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    font: mono
    font-size: 12
  }
}
case_e: "case 'e':" {
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    font: mono
    font-size: 12
  }
}
case_c: "case 'c':" {
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    font: mono
    font-size: 12
  }
}
validate_p: "strtol(optarg)\n validate > 0\n && ≤ 4194304" {
  shape: rectangle
  style: {
    fill: "#FCE4EC"
    stroke: "#C62828"
    font: mono
    font-size: 11
  }
}
strip_trace: "strncmp(optarg, \"trace=\", 6)\nstrip prefix → ptr" {
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#6A1B9A"
    font: mono
    font-size: 11
  }
}
err_invalid_pid: "fprintf(stderr,\n\"Invalid PID\")\nexit(1)" {
  shape: rectangle
  style: {
    fill: "#FFCDD2"
    stroke: "#B71C1C"
    font: mono
    font-size: 11
  }
}
err_bad_e: "fprintf(stderr,\n\"Unsupported -e\")\nexit(1)" {
  shape: rectangle
  style: {
    fill: "#FFCDD2"
    stroke: "#B71C1C"
    font: mono
    font-size: 11
  }
}
getopt -> case_o: "-o optarg"
getopt -> case_p: "-p optarg"
getopt -> case_e: "-e optarg"
getopt -> case_c: "-c"
case_o -> opts_struct.output_file: "opts.output_file = optarg\n(ptr into argv)" {
  style.stroke: "#E65100"
  style.font-size: 11
}
case_p -> validate_p: "optarg"
validate_p -> opts_struct.attach_pid: "opts.attach_pid = (pid_t)pid_l\n[valid range]" {
  style.stroke: "#2E7D32"
  style.font-size: 11
}
validate_p -> err_invalid_pid: "out of range" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
  style.font-size: 11
}
case_e -> strip_trace: "optarg"
strip_trace -> opts_struct.filter_str: "opts.filter_str = optarg + 6\n[\"trace=\" stripped]" {
  style.stroke: "#6A1B9A"
  style.font-size: 11
}
strip_trace -> err_bad_e: "no \"trace=\" prefix" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
  style.font-size: 11
}
case_c -> opts_struct.show_stats: "opts.show_stats = 1" {
  style.stroke: "#E65100"
  style.font-size: 11
}
optind_box: "argv[optind]\n= program to exec" {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    font: mono
    font-size: 12
  }
}
getopt -> optind_box: "'+' stops at\nfirst non-option" {
  style.stroke: "#1565C0"
  style.font-size: 11
}
post_validate: "Post-parse Validation" {
  shape: rectangle
  style: {
    fill: "#F1F8E9"
    stroke: "#558B2F"
    bold: true
    font-size: 13
  }
}
opts_struct -> post_validate: "opts populated"
optind_box -> post_validate
check_no_prog: "attach_pid == 0\nAND optind >= argc?" {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    font: mono
    font-size: 12
  }
}
post_validate -> check_no_prog
err_no_prog: "fprintf(stderr,\n\"must specify -p PID\nor command\")\nexit(1)" {
  shape: rectangle
  style: {
    fill: "#FFCDD2"
    stroke: "#B71C1C"
    font: mono
    font-size: 11
  }
}
check_no_prog -> err_no_prog: "yes" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
  style.font-size: 11
}
strdup_box: "strdup(opts.filter_str)\n→ filter_copy\n[mutable copy for strtok]" {
  shape: rectangle
  style: {
    fill: "#EDE7F6"
    stroke: "#4527A0"
    font: mono
    font-size: 12
  }
}
parse_filter_box: "parse_filter(filter_copy)\n→ tokenize on ','\n→ g_filter.names[]\n→ g_filter.count" {
  shape: rectangle
  style: {
    fill: "#D1C4E9"
    stroke: "#4527A0"
    font: mono
    font-size: 12
  }
}
check_no_prog -> strdup_box: "no (valid args)\n[if filter_str != NULL]" {
  style.stroke: "#2E7D32"
  style.font-size: 11
}
strdup_box -> parse_filter_box
argv_safe: |md
  **argv memory protected**
  strtok writes '\0' into
  filter_copy, NOT argv
| {
  shape: rectangle
  near: bottom-center
  style: {
    fill: "#FFFDE7"
    stroke: "#F9A825"
    font-size: 11
  }
}
strdup_box -> argv_safe: "prevents corruption" {
  style.stroke-dash: 3
  style.stroke: "#F9A825"
  style.font-size: 10
}
run_tracer_fork: "run_child(argv + optind)\nrun_tracer(child, map, 1)" {
  shape: rectangle
  style: {
    fill: "#B2DFDB"
    stroke: "#00695C"
    font: mono
    font-size: 12
  }
}
run_tracer_attach: "attach_to_process(attach_pid)\nrun_tracer(attach_pid, map, 0)" {
  shape: rectangle
  style: {
    fill: "#B2DFDB"
    stroke: "#00695C"
    font: mono
    font-size: 12
  }
}
dispatch: "attach_pid == 0?" {
  shape: diamond
  style: {
    fill: "#E0F2F1"
    stroke: "#00695C"
    font: mono
    font-size: 12
  }
}
parse_filter_box -> dispatch: "g_filter ready"
check_no_prog -> dispatch: "no (if filter_str == NULL)"
dispatch -> run_tracer_fork: "yes → fork+exec" {
  style.stroke: "#00695C"
  style.font-size: 11
}
dispatch -> run_tracer_attach: "no → attach" {
  style.stroke: "#00695C"
  style.font-size: 11
}