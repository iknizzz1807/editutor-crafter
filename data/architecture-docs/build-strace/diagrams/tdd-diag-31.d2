vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
classes: {
  global: {
    style: {
      fill: "#E4DBFE"
      stroke: "#6B46C1"
      stroke-width: 2
      bold: true
    }
  }
  core: {
    style: {
      fill: "#C7F1FF"
      stroke: "#0369A1"
      stroke-width: 2
      bold: true
    }
  }
  timing: {
    style: {
      fill: "#DCFCE7"
      stroke: "#15803D"
      stroke-width: 2
    }
  }
  filter_node: {
    style: {
      fill: "#FEF9C3"
      stroke: "#A16207"
      stroke-width: 2
    }
  }
  output_node: {
    style: {
      fill: "#FFE4E6"
      stroke: "#BE123C"
      stroke-width: 2
    }
  }
  startup: {
    style: {
      fill: "#F0FDF4"
      stroke: "#166534"
      stroke-width: 1
      stroke-dash: 3
    }
  }
  shutdown: {
    style: {
      fill: "#FFF1F2"
      stroke: "#9F1239"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}
# ── Global state ──────────────────────────────────────────────────────────────
g_pid_map: "g_pid_map\npid_map_t[64]\n608 B × 64 = 38 KB" {
  class: global
  shape: cylinder
}
g_stats: "g_stats\nsyscall_stats_t[400]\n9,600 B — L1 resident" {
  class: global
  shape: cylinder
}
g_filter: "g_filter\nsyscall_filter_t\n{names**, count}" {
  class: global
}
g_output: "g_output\nFILE *\nstderr or file" {
  class: global
}
g_interrupted: "g_interrupted\nvolatile sig_atomic_t\n0 | 1" {
  class: global
}
# ── Startup flow ──────────────────────────────────────────────────────────────
startup: "STARTUP" {
  class: startup
  argc_argv: "argc / argv" {
    shape: parallelogram
    style.fill: "#F0FDF4"
  }
  parse_args: "parse_args()\ngetopt( \"+o:p:e:c\" )" {
    shape: rectangle
    style.fill: "#DCFCE7"
    style.stroke: "#15803D"
    style.bold: true
  }
  tracer_opts: "tracer_opts_t\n{attach_pid, show_stats,\noutput_file, filter_str}" {
    shape: rectangle
    style.fill: "#DCFCE7"
  }
  sigaction: "sigaction(SIGINT)\nsa.sa_flags = 0\n(no SA_RESTART)" {
    shape: rectangle
    style.fill: "#DCFCE7"
  }
  argc_argv -> parse_args
  parse_args -> tracer_opts
  tracer_opts -> sigaction
}
fork_path: "FORK + EXEC PATH\n(attach_pid == 0)" {
  class: startup
  fork_call: "fork()" { shape: rectangle; style.fill: "#F0FDF4" }
  run_child: "run_child(argv+optind)\nPTRACE_TRACEME\nexecvp()" { style.fill: "#F0FDF4" }
  consume_exec: "waitpid(child)\nconsume post-exec\nSIGTRAP" { style.fill: "#F0FDF4" }
  set_opts_fork: "PTRACE_SETOPTIONS\nTRACE_OPTIONS" { style.fill: "#F0FDF4" }
  fork_call -> run_child
  fork_call -> consume_exec
  consume_exec -> set_opts_fork
}
attach_path: "ATTACH PATH\n(-p PID)" {
  class: startup
  attach_proc: "attach_to_process\n(target_pid, map)" { style.fill: "#FFF7ED" }
  ptrace_attach: "ptrace(PTRACE_ATTACH)" { style.fill: "#FFF7ED" }
  waitpid_attach: "waitpid(target_pid)\nblock until SIGSTOP" { style.fill: "#FFF7ED" }
  set_opts_attach: "PTRACE_SETOPTIONS\nTRACE_OPTIONS" { style.fill: "#FFF7ED" }
  pid_map_create: "pid_map_get(map, pid)\nin_syscall = 0" { style.fill: "#FFF7ED" }
  attach_proc -> ptrace_attach -> waitpid_attach -> set_opts_attach -> pid_map_create
}
# ── Event loop ────────────────────────────────────────────────────────────────
event_loop: "EVENT LOOP — waitpid(-1)" {
  class: core
  waitpid_call: "waitpid(-1, &status, 0)\nblocks for ANY child" {
    style.fill: "#C7F1FF"
    style.stroke: "#0369A1"
    style.bold: true
  }
  check_interrupted: "g_interrupted?\ncheck before waitpid" {
    shape: diamond
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
  }
  decode_status: "Decode status\nsig = WSTOPSIG(status)\nevent = status >> 16" {
    style.fill: "#C7F1FF"
  }
  dispatch: "handle_stop(pid, status)" {
    style.fill: "#C7F1FF"
    style.bold: true
  }
  wifexited: "WIFEXITED\nWIFSIGNALED" {
    shape: diamond
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
  }
  pid_map_remove: "pid_map_remove(map, pid)\nnum_active--" {
    style.fill: "#FEE2E2"
  }
  event_dispatch: "event != 0?\nPTRACE_EVENT_*\nFORK/VFORK/CLONE/EXEC" {
    shape: diamond
    style.fill: "#C7F1FF"
  }
  syscall_stop: "sig == SIGTRAP|0x80\n(TRACESYSGOOD)" {
    shape: diamond
    style.fill: "#C7F1FF"
  }
  signal_reinject: "Signal-delivery stop\nptrace(PTRACE_SYSCALL,\n  pid, 0, sig)" {
    style.fill: "#FEF3C7"
  }
  handle_ptrace_event: "handle_ptrace_event\n(pid, event, map)" {
    style.fill: "#C7F1FF"
  }
  toggle: "state->in_syscall\n= !state->in_syscall" {
    style.fill: "#C7F1FF"
  }
  check_interrupted -> waitpid_call
  waitpid_call -> wifexited
  waitpid_call -> decode_status
  wifexited -> pid_map_remove: "yes"
  decode_status -> dispatch
  dispatch -> event_dispatch
  event_dispatch -> handle_ptrace_event: "yes"
  event_dispatch -> syscall_stop: "no"
  syscall_stop -> toggle: "0x85"
  syscall_stop -> signal_reinject: "other"
}
# ── Core handler: handle_syscall_stop ─────────────────────────────────────────
hss: "handle_syscall_stop(pid, state)" {
  class: core
  style.bold: true
  entry_branch: "in_syscall == 1?\nENTRY STOP" {
    shape: diamond
    style.fill: "#C7F1FF"
  }
  extract_args: "extract_args(&regs, &current)\nrdi,rsi,rdx,r10,r8,r9\n→ current.args[6]" {
    style.fill: "#C7F1FF"
  }
  clock_entry: "clock_gettime\n(CLOCK_MONOTONIC,\n&state->entry_time)" {
    class: timing
  }
  build_outbuf: "open_memstream → print_syscall_entry\n\"[pid N] name(args\"\n→ state->outbuf[512]" {
    style.fill: "#C7F1FF"
  }
  ptrace_getregs: "ptrace(PTRACE_GETREGS)\n→ user_regs_struct\norig_rax | rax" {
    style.fill: "#DBEAFE"
    style.stroke: "#1D4ED8"
  }
  exit_branch: "EXIT STOP\ncurrent.retval = rax" {
    style.fill: "#C7F1FF"
  }
  clock_exit: "clock_gettime\n(CLOCK_MONOTONIC,\n&exit_time)" {
    class: timing
  }
  diff_ns: "timespec_diff_ns\n(&entry_time, &exit_time)\n→ elapsed_ns ≥ 0" {
    class: timing
  }
  stats_call: "stats_record\n(syscall_nr, retval,\nelapsed_ns)" {
    class: timing
  }
  filter_check: "filter_matches\n(syscall_nr)?" {
    shape: diamond
    class: filter_node
  }
  discard: "discard:\noutbuf_len = 0\nreturn" {
    class: filter_node
  }
  mid_syscall_attach: "outbuf_len == 0?\n(mid-syscall attach)" {
    shape: diamond
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
  }
  print_resumed: "fprintf(g_output,\n\"<... name resumed>\")\n= retval" {
    class: output_node
  }
  append_exit: "snprintf → outbuf\n\") = retval\\n\"\nor \") = -1 ERRNO (...)\\n\"" {
    style.fill: "#C7F1FF"
  }
  fputs_out: "fputs(state->outbuf,\ng_output)\n— single write() call\n(atomic for single thread)" {
    class: output_node
    style.bold: true
  }
  reset_len: "outbuf_len = 0\nprepare next syscall" {
    style.fill: "#C7F1FF"
  }
  ptrace_getregs -> entry_branch
  entry_branch -> extract_args: "entry"
  entry_branch -> exit_branch: "exit"
  extract_args -> clock_entry
  clock_entry -> build_outbuf
  exit_branch -> clock_exit
  clock_exit -> diff_ns
  diff_ns -> stats_call
  stats_call -> filter_check
  filter_check -> discard: "no match"
  filter_check -> mid_syscall_attach: "match"
  mid_syscall_attach -> print_resumed: "len == 0"
  mid_syscall_attach -> append_exit: "len > 0"
  append_exit -> fputs_out
  fputs_out -> reset_len
}
# ── Timing sub-components ────────────────────────────────────────────────────
timing_detail: "CLOCK_MONOTONIC\nvDSO fast path\n5–20 ns per call\nmonotonicaly increasing\nNTP-immune" {
  class: timing
  style.font-size: 11
}
observer_note: |md
  **Observer Effect**
  elapsed_ns includes:
  - (a) actual kernel syscall time
  - (b) entry context-switch cost ~1–5 µs
  - (c) tracer GETREGS + decode
  - (d) exit context-switch cost ~1–5 µs
  Fast syscalls (getpid ~100 ns) measure
  20–100× inflated. I/O-bound reads
  (~10 ms) accurate to ~5%.
| {
  near: top-right
  style.fill: "#F0FDF4"
  style.font-size: 11
}
# ── Stats accumulator ─────────────────────────────────────────────────────────
stats_detail: "stats_record() impl\nif nr ∈ [0,400):\n  s = g_stats[nr]\n  s.call_count++\n  if is_error: s.error_count++\n  s.total_ns += elapsed_ns" {
  class: timing
  style.font-size: 11
  style.font: mono
}
# ── print_statistics ──────────────────────────────────────────────────────────
print_stats: "print_statistics(g_output)\n1. collect non-zero g_stats entries\n2. qsort by total_ns DESC\n3. fprintf table rows\n   % time | seconds | usecs/call | calls | errors | name\n4. fprintf totals row" {
  class: output_node
  style.font-size: 11
}
# ── Shutdown flow ─────────────────────────────────────────────────────────────
shutdown: "SHUTDOWN" {
  class: shutdown
  sigint_handler: "sigint_handler(int sig)\ng_interrupted = 1\n— only async-safe op —\n(no printf/malloc/ptrace)" {
    style.fill: "#FFF1F2"
    style.stroke: "#9F1239"
    style.bold: true
  }
  loop_exit: "main loop exits:\ng_interrupted == 1\nOR num_active == 0\nOR ECHILD" {
    shape: diamond
    style.fill: "#FFF1F2"
  }
  detach_all: "detach_all(map)\nfor each active slot:\n  PTRACE_DETACH\n  if ESRCH: SIGSTOP +\n  WNOHANG retry loop\n  (100 × 1 ms)" {
    style.fill: "#FFF1F2"
    style.stroke: "#9F1239"
  }
  stats_print_final: "print_statistics(g_output)\n(if show_stats == 1)" {
    class: output_node
  }
  fclose_out: "fclose(g_output)\n(if file, not stderr)\nflushes stdio buffer" {
    class: output_node
  }
  free_filter: "free(g_filter.names)\nfree(filter_copy)" {
    style.fill: "#FFF1F2"
  }
  sigint_handler -> loop_exit
  loop_exit -> detach_all: "interrupted"
  loop_exit -> stats_print_final: "normal exit"
  detach_all -> stats_print_final
  stats_print_final -> fclose_out -> free_filter
}
# ── PTRACE_EVENT handling ─────────────────────────────────────────────────────
ptrace_events: "handle_ptrace_event" {
  style.fill: "#C7F1FF"
  style.stroke: "#0369A1"
  fork_event: "PTRACE_EVENT_FORK\nVFORK / CLONE\n→ PTRACE_GETEVENTMSG\n→ new_pid\n→ pid_map_get(new_pid)\n→ PTRACE_SETOPTIONS\n→ PTRACE_SYSCALL(new_pid)\n→ num_active++" {
    style.fill: "#DBEAFE"
  }
  exec_event: "PTRACE_EVENT_EXEC\n→ state->in_syscall = 1\n→ outbuf_len = 0\n→ memset(&current)\n→ log execve completed" {
    style.fill: "#DBEAFE"
  }
  exit_event: "PTRACE_EVENT_EXIT\n→ PTRACE_GETEVENTMSG\n→ log pending status\n→ NO pid_map_remove\n  (process still alive)" {
    style.fill: "#DBEAFE"
  }
}
# ── Connections: startup → init ───────────────────────────────────────────────
startup.tracer_opts -> g_output: "output_file → fopen\nor keep stderr" {
  style.stroke-dash: 4
}
startup.tracer_opts -> g_filter: "filter_str → strdup\n→ parse_filter()" {
  style.stroke-dash: 4
}
startup.tracer_opts -> fork_path: "attach_pid == 0" {
  style.stroke-dash: 3
}
startup.tracer_opts -> attach_path: "attach_pid > 0" {
  style.stroke-dash: 3
}
fork_path.set_opts_fork -> g_pid_map: "pid_map_get(child)\nnum_active = 1"
attach_path.pid_map_create -> g_pid_map: "creates entry\nin_syscall = 0"
# ── Event loop wiring ─────────────────────────────────────────────────────────
fork_path -> event_loop: "PTRACE_SYSCALL(child_pid)\nenter event loop"
attach_path -> event_loop: "PTRACE_SYSCALL(target)\nenter event loop (consume_exec_stop=0)"
event_loop.toggle -> hss.ptrace_getregs: "handle_syscall_stop\n(pid, state)"
event_loop.handle_ptrace_event -> ptrace_events
event_loop.pid_map_remove -> g_pid_map: "memset slot\nactive = 0"
event_loop.check_interrupted -> shutdown.sigint_handler: "g_interrupted reads" {
  style.stroke-dash: 5
  style.stroke: "#DC2626"
}
# ── handle_syscall_stop → globals ────────────────────────────────────────────
hss.clock_entry -> timing_detail: "CLOCK_MONOTONIC"
hss.clock_exit -> timing_detail
hss.stats_call -> stats_detail
stats_detail -> g_stats: "accumulates"
hss.filter_check -> g_filter: "reads names[], count"
hss.fputs_out -> g_output: "single write()"
hss.print_resumed -> g_output
# ── g_pid_map → handler ───────────────────────────────────────────────────────
g_pid_map -> hss: "pid_map_get(pid)\n→ pid_state_t*\n  in_syscall\n  entry_time\n  current\n  outbuf[512]" {
  style.stroke: "#6B46C1"
}
# ── Signal handler ────────────────────────────────────────────────────────────
shutdown.sigint_handler -> g_interrupted: "g_interrupted = 1" {
  style.stroke: "#DC2626"
  style.stroke-width: 2
}
g_interrupted -> event_loop.check_interrupted: "checked each iteration" {
  style.stroke: "#DC2626"
  style.stroke-dash: 3
}
# ── Shutdown wiring ───────────────────────────────────────────────────────────
event_loop -> shutdown.loop_exit: "exits when\nnum_active == 0\nor ECHILD\nor g_interrupted"
shutdown.detach_all -> g_pid_map: "reads active slots\nPTRACE_DETACH each"
g_stats -> print_stats: "read at shutdown"
print_stats -> shutdown.stats_print_final
shutdown.stats_print_final -> g_output: "fprintf table"
# ── ptrace_events → global map ───────────────────────────────────────────────
ptrace_events.fork_event -> g_pid_map: "pid_map_get(new_pid)\nnew slot, num_active++"
ptrace_events.exec_event -> g_pid_map: "reset existing slot\nin_syscall=1, outbuf_len=0"
# ── Annotation: data flow summary ────────────────────────────────────────────
legend: |md
  **M4 Data Flow per syscall exit stop**
  1. `PTRACE_GETREGS` → `rax` (retval)
  2. `clock_gettime(MONOTONIC)` → `exit_time`
  3. `timespec_diff_ns(entry, exit)` → `elapsed_ns` ≥ 0
  4. `stats_record(nr, retval, elapsed_ns)` → **always** (filter-agnostic)
  5. `filter_matches(nr)` → suppress print if 0
  6. `snprintf` → `outbuf` → `fputs(g_output)` — **single write**
| {
  near: bottom-center
  style.fill: "#F8FAFC"
  style.stroke: "#94A3B8"
  style.font-size: 12
}