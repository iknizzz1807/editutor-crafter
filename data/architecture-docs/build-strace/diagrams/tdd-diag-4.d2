  nr_reg: "Syscall Number" {
    style.fill: "#2a0a5a"
    style.stroke: "#aa44ff"
    style.font-color: "#cc88ff"
    style.border-radius: 4
  }
  clob_reg: "Clobbered by CPU" {
    style.fill: "#3a3a1a"
    style.stroke: "#cc9900"
    style.font-color: "#ffcc44"
    style.border-radius: 4
  }
  other_reg: "Other Registers" {
    style.fill: "#2d2d4e"
    style.stroke: "#4a4a8a"
    style.font-color: "#aaaacc"
    style.border-radius: 4
  }
  size_note: "sizeof = 168 bytes · 3 cache lines" {
    style.fill: "#1a1a2e"
    style.stroke: "#4a4a8a"
    style.font-color: "#aaaacc"
    style.border-radius: 4
  }
}