annotations: Annotations {
  style: {
    fill: "#0d0d1a"
    stroke: "#4a4a8a"
    font-color: "#e0e0ff"
  }
  syscall_nr_ann: "Why orig_rax exists" {
    style.fill: "#1a0a2e"
    style.stroke: "#aa44ff"
    style.font-color: "#cc88ff"
    style.border-radius: 6
    label: |md
      **`orig_rax` vs `rax` — The Preservation Problem**
      At entry stop: `rax == orig_rax == syscall_number`
      At exit stop:  `rax = return_value`  ← kernel overwrites!
                     `orig_rax = syscall_number` ← preserved by kernel
      **Rule**: always use `orig_rax` to identify the syscall.
      Use `rax` only to read the return value at exit stop.
      `orig_rax = -1` signals "no syscall active" (signal restart logic).
    |
  }
  r10_vs_rcx_ann: "r10 vs rcx — Critical ABI Difference" {
    style.fill: "#1a2a0a"
    style.stroke: "#cc9900"
    style.font-color: "#ffcc44"
    style.border-radius: 6
    label: |md
      **Syscall ABI arg4 = r10   ≠   C ABI arg4 = rcx**
      The `syscall` instruction clobbers `rcx` to save the
      return address (RIP) for the `sysret` return path.
      Therefore the kernel CANNOT use `rcx` for arg4.
      It uses `r10` instead.
      Reading `regs->rcx` for arg4 returns the saved RIP —
      **silent wrong data**, not a crash.
      C func call:   rdi  rsi  rdx  **rcx**  r8   r9
      Syscall ABI:   rdi  rsi  rdx  **r10**  r8   r9
    |
  }
  cacheline_ann: "Cache Line Boundaries (64-byte)" {
    style.fill: "#0a1a2a"
    style.stroke: "#4488aa"
    style.font-color: "#88ccff"
    style.border-radius: 6
    label: |md
      **Cache line 0** `0x00–0x3F`: r15–r10 (args 4 in last 8B)
      **Cache line 1** `0x40–0x7F`: r9,r8,rax,rcx,rdx,rsi,rdi,orig_rax
      **Cache line 2** `0x80–0xBF`: rip,cs,eflags,rsp,ss,fs_base
      **Cache line 3** `0xC0–0xD7`: gs_base,ds,es,fs,gs  (last 24B)
      `PTRACE_GETREGS` fetches all 168 bytes (3 full + partial line).
      Hot fields (orig\_rax, rax, arg regs) all on **cache line 1**.
    |
  }
  stop_type_ann: "Which register to read at which stop" {
    style.fill: "#1a0d0d"
    style.stroke: "#ff6644"
    style.font-color: "#ffbbaa"
    style.border-radius: 6
    label: |md
      **Entry stop** (`in_syscall == 1` after toggle):
        Read `orig_rax` → syscall number
        Read `rdi,rsi,rdx,r10,r8,r9` → arguments 1–6
        `rax` equals `orig_rax` here (not yet overwritten)
      **Exit stop** (`in_syscall == 0` after toggle):
        Read `rax` → return value (may be negative errno)
        Read `orig_rax` → syscall number (still valid)
        Do NOT trust `rdi–r9` (may be clobbered by kernel)
      Error range: `rax ∈ [-4095, -1]` → `-errno`
    |
  }
}
mem.orig_rax_row -> annotations.syscall_nr_ann: "preserved across\nentry → exit" {
  style.stroke: "#aa44ff"
  style.stroke-width: 2
  style.stroke-dash: 3
  target-arrowhead.shape: arrow
}
mem.rax_row -> annotations.syscall_nr_ann: "overwritten with\nreturn value" {
  style.stroke: "#ff6644"
  style.stroke-width: 2
  style.stroke-dash: 3
  target-arrowhead.shape: arrow
}
mem.rcx_row -> annotations.r10_vs_rcx_ann: "DESTROYED by\nsyscall instr" {
  style.stroke: "#cc9900"
  style.stroke-width: 2
  style.animated: true
  target-arrowhead.shape: arrow
}
mem.r10_row -> annotations.r10_vs_rcx_ann: "use this for\narg4, NOT rcx" {
  style.stroke: "#44cc44"
  style.stroke-width: 2
  target-arrowhead.shape: arrow
}
mem.rdi_row -> annotations.stop_type_ann: "args 1–6 valid\nat entry stop only" {
  style.stroke: "#44cc44"
  style.stroke-width: 1
  style.stroke-dash: 5
  target-arrowhead.shape: arrow
}
mem.rax_row -> annotations.stop_type_ann: "retval valid\nat exit stop" {
  style.stroke: "#ff6644"
  style.stroke-width: 1
  style.stroke-dash: 5
  target-arrowhead.shape: arrow
}
