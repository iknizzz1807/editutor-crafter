  grid-gap: 8
  arg_reg: "Argument Registers" {
    style.fill: "#1a3a1a"
    style.stroke: "#44cc44"
    style.font-color: "#88ff88"
    style.border-radius: 4
  }
  ret_reg: "Return Value" {
    style.fill: "#3a1a1a"
    style.stroke: "#ff6644"
    style.font-color: "#ff9977"
    style.border-radius: 4
