vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## Three-Level View: One `read()` Syscall Stop
  **Hardware → Kernel → Application**
| {near: top-center}

hw: "Hardware (CPU + Memory)" {
  style.fill: "#1a1a2e"
  style.font-color: "#e0e0ff"
  style.stroke: "#4a4a8a"
  style.stroke-width: 2
  style.border-radius: 8
  cr3: "CR3 Register Switch" {
    style.fill: "#2d2d5e"
    style.font-color: "#aaaaff"
    style.stroke: "#6666cc"
    style.border-radius: 4
  }
  tlb: "TLB Flush / PCID" {
    style.fill: "#2d2d5e"
    style.font-color: "#aaaaff"
    style.stroke: "#6666cc"
    style.border-radius: 4
  }
  dram: "DRAM Access (cold lines)" {
    style.fill: "#2d2d5e"
    style.font-color: "#aaaaff"
    style.stroke: "#6666cc"
    style.border-radius: 4
  }
  cost1: |md
    **~1–10 μs / context switch**
    2 switches per syscall stop
    = 2–20 μs observer overhead
  | {
    style.fill: "#3a1a1a"
    style.font-color: "#ff9999"
    style.stroke: "#cc4444"
    style.border-radius: 4
  }
  cr3 -> tlb: "invalidates entries\n(unless PCID active)"
  tlb -> dram: "cold miss → DRAM\n~200 cycles"
}

kern: "Kernel (ring 0)" {
  style.fill: "#1a2e1a"
  style.font-color: "#e0ffe0"
  style.stroke: "#4a8a4a"
  style.stroke-width: 2
  style.border-radius: 8
  syscall_entry: "syscall instruction (tracee)" {
    style.fill: "#2d5e2d"
    style.font-color: "#aaffaa"
    style.stroke: "#66cc66"
    style.border-radius: 4
  }
  task_struct: "Save to task_struct\n(pt_regs, 168 bytes)" {
    style.fill: "#2d5e2d"
    style.font-color: "#aaffaa"
    style.stroke: "#66cc66"
    style.border-radius: 4
  }
  task_traced: "Set TASK_TRACED\non tracee" {
    style.fill: "#2d5e2d"
    style.font-color: "#aaffaa"
    style.stroke: "#66cc66"
    style.border-radius: 4
  }
  wake_q: "Wake tracer wait_queue\n(SIGCHLD-like notification)" {
    style.fill: "#2d5e2d"
    style.font-color: "#aaffaa"
    style.stroke: "#66cc66"
    style.border-radius: 4
  }
  exec_syscall: "Execute read() in kernel\n(VFS → block layer → wait)" {
    style.fill: "#1a3a1a"
    style.font-color: "#88ff88"
    style.stroke: "#44aa44"
    style.border-radius: 4
    style.stroke-dash: 4
  }
  exit_stop: "Syscall exit stop\nWrite retval → rax\nSet TASK_TRACED again" {
    style.fill: "#2d5e2d"
    style.font-color: "#aaffaa"
    style.stroke: "#66cc66"
    style.border-radius: 4
  }
  copy_to_user: "copy_to_user()\nPTRACE_GETREGS → 168 bytes" {
    style.fill: "#2d5e2d"
    style.font-color: "#aaffaa"
    style.stroke: "#66cc66"
    style.border-radius: 4
  }
  sysret: "SYSRET → ring 3\nresume tracee" {
    style.fill: "#2d5e2d"
    style.font-color: "#aaffaa"
    style.stroke: "#66cc66"
    style.border-radius: 4
  }
  syscall_entry -> task_struct: "ring 0 transition\nMSR_LSTAR jump"
  task_struct -> task_traced: "ptrace hook fires"
  task_traced -> wake_q: "enqueue tracer"
  wake_q -> exec_syscall: "tracer resumes;\nPTRACE_SYSCALL issued"
  exec_syscall -> exit_stop: "read() returns n bytes"
  exit_stop -> copy_to_user: "PTRACE_GETREGS\ncall from tracer"
  copy_to_user -> sysret: "tracee unblocked"
}

app: "Application (ring 3)" {
  style.fill: "#2e1a2e"
  style.font-color: "#ffe0ff"
  style.stroke: "#8a4a8a"
  style.stroke-width: 2
  style.border-radius: 8
  tracee_read: "Tracee: read(0, buf, 100)" {
    style.fill: "#5e2d5e"
    style.font-color: "#ffaaff"
    style.stroke: "#cc66cc"
    style.border-radius: 4
  }
  tracee_frozen: "Tracee: FROZEN\n(TASK_TRACED)" {
    style.fill: "#3a1a3a"
    style.font-color: "#dd88dd"
    style.stroke: "#884488"
    style.border-radius: 4
    style.stroke-dash: 5
  }
  ptrace_syscall_1: "Tracer: ptrace(PTRACE_SYSCALL,\n  child_pid, NULL, 0)" {
    style.fill: "#8a2be2"
    style.font-color: "#ffffff"
    style.stroke: "#cc00ff"
    style.border-radius: 4
  }
  waitpid_1: "Tracer: waitpid(child, &status, 0)\n→ BLOCKS" {
    style.fill: "#5e2d5e"
    style.font-color: "#ffaaff"
    style.stroke: "#cc66cc"
    style.border-radius: 4
  }
  entry_stop_handler: "Tracer: ENTRY STOP received\nWIFSTOPPED(status)\nsig == SIGTRAP|0x80" {
    style.fill: "#8a2be2"
    style.font-color: "#ffffff"
    style.stroke: "#cc00ff"
    style.border-radius: 4
  }
  getregs_1: "Tracer: ptrace(PTRACE_GETREGS)\n→ read orig_rax = 0 (read)\n→ save entry_time" {
    style.fill: "#5e2d5e"
    style.font-color: "#ffaaff"
    style.stroke: "#cc66cc"
    style.border-radius: 4
  }
  ptrace_syscall_2: "Tracer: ptrace(PTRACE_SYSCALL,\n  child_pid, NULL, 0)\n[resume tracee]" {
    style.fill: "#8a2be2"
    style.font-color: "#ffffff"
    style.stroke: "#cc00ff"
    style.border-radius: 4
  }
  waitpid_2: "Tracer: waitpid(child, &status, 0)\n→ BLOCKS again" {
    style.fill: "#5e2d5e"
    style.font-color: "#ffaaff"
    style.stroke: "#cc66cc"
    style.border-radius: 4
  }
  exit_stop_handler: "Tracer: EXIT STOP received" {
    style.fill: "#8a2be2"
    style.font-color: "#ffffff"
    style.stroke: "#cc00ff"
    style.border-radius: 4
  }
  getregs_2: "Tracer: ptrace(PTRACE_GETREGS)\n→ read rax = n (retval)\n→ record exit_time\n→ elapsed_ns = exit-entry" {
    style.fill: "#5e2d5e"
    style.font-color: "#ffaaff"
    style.stroke: "#cc66cc"
    style.border-radius: 4
  }
  output: "Tracer: fprintf(g_output,\n'read(0, ...buf..., 100) = %ld\\n')" {
    style.fill: "#5e2d5e"
    style.font-color: "#ffaaff"
    style.stroke: "#cc66cc"
    style.border-radius: 4
  }
  tracee_returns: "Tracee: read() returns n\n(sees nothing of above)" {
    style.fill: "#3a1a3a"
    style.font-color: "#dd88dd"
    style.stroke: "#884488"
    style.border-radius: 4
  }
  tracee_read -> tracee_frozen: "syscall instruction\n→ entry stop"
  tracee_frozen -> ptrace_syscall_1: "tracer wakes"
  ptrace_syscall_1 -> waitpid_1: "tracer blocks"
  waitpid_1 -> entry_stop_handler: "stop reported"
  entry_stop_handler -> getregs_1: "classify: ENTRY"
  getregs_1 -> ptrace_syscall_2: "resume tracee"
  ptrace_syscall_2 -> waitpid_2: "tracer blocks again"
  waitpid_2 -> exit_stop_handler: "exit stop reported"
  exit_stop_handler -> getregs_2: "classify: EXIT"
  getregs_2 -> output: "format line"
  output -> tracee_returns: "tracee resumes"
}

app.tracee_read -> kern.syscall_entry: "syscall instruction" {
  style.stroke: "#88cc88"
  style.stroke-width: 2
}
kern.task_traced -> hw.cr3: "scheduler selects tracer\n→ CR3 switch" {
  style.stroke: "#aaaaff"
  style.stroke-width: 2
}
hw.dram -> kern.copy_to_user: "168 bytes fetched\nfrom task_struct pages" {
  style.stroke: "#aaaaff"
  style.stroke-width: 2
}
kern.wake_q -> app.waitpid_1: "waitpid() returns\nWIFSTOPPED" {
  style.stroke: "#cc88cc"
  style.stroke-width: 2
}
kern.copy_to_user -> app.getregs_1: "168 bytes → tracer stack" {
  style.stroke: "#cc88cc"
  style.stroke-width: 2
}
kern.exit_stop -> kern.copy_to_user: "" {
  style.stroke: "#66cc66"
}
kern.copy_to_user -> app.getregs_2: "168 bytes → tracer stack\n(exit stop registers)" {
  style.stroke: "#cc88cc"
  style.stroke-width: 2
}
kern.sysret -> app.tracee_returns: "ring 3 resume" {
  style.stroke: "#88cc88"
  style.stroke-width: 2
}

observer: |md
  ### ⚠ Observer Effect
  **What elapsed_ns actually measures:**
  - T₁ = clock_gettime at entry stop (after PTRACE_GETREGS returns to tracer)
  - T₂ = clock_gettime at exit stop (after PTRACE_GETREGS returns to tracer)
  - **T₂ − T₁ includes 2× context-switch round-trips (~2–20 μs each)**
  - For `read()` blocking 500 ms on disk: T₂−T₁ ≈ 500 ms (I/O dominates ✓)
  - For `getpid()` taking 100 ns: T₂−T₁ ≈ 4–20 μs (overhead dominates ✗)
  **Ratio is meaningful. Absolute nanoseconds are not.**
| {
  near: bottom-center
  style.fill: "#2a1a00"
  style.font-color: "#ffcc66"
  style.stroke: "#cc8800"
  style.stroke-width: 2
  style.border-radius: 6
}