vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## PTRACE_PEEKDATA Word-by-Word String Reading
  **Unaligned address 0x7fff3a2b8003 → scan until null or max_len**
| {near: top-center}

# ── Step containers ──────────────────────────────────────────────────────────

step1: "STEP 1 — Compute Aligned Address" {
  style.fill: "#e8eaf6"
  style.stroke: "#5c6bc0"
  style.border-radius: 6
  formula: |md
    `aligned_addr = addr & ~7ULL`
    `byte_offset  = addr - aligned_addr`
  | {
    style.fill: transparent
    style.stroke-width: 0
  }
  calc: "" {
    style.fill: "#c5cae9"
    style.border-radius: 4
    grid-columns: 3
    grid-gap: 0
    a: "addr" {
      style.fill: "#7986cb"
      style.font-color: white
      style.bold: true
    }
    eq: "=" {style.fill: transparent; style.stroke-width: 0}
    av: "0x7fff3a2b**8003**" {
      style.fill: "#7986cb"
      style.font-color: white
      style.italic: true
    }
    b: "aligned_addr" {
      style.fill: "#3949ab"
      style.font-color: white
      style.bold: true
    }
    eq2: "=" {style.fill: transparent; style.stroke-width: 0}
    bv: "0x7fff3a2b**8000**" {
      style.fill: "#3949ab"
      style.font-color: white
      style.italic: true
    }
    c: "byte_offset" {
      style.fill: "#e53935"
      style.font-color: white
      style.bold: true
    }
    eq3: "=" {style.fill: transparent; style.stroke-width: 0}
    cv: "**3**  (skip bytes 0,1,2)" {
      style.fill: "#e53935"
      style.font-color: white
    }
  }
}

step2: "STEP 2 — PTRACE_PEEKDATA Reads 8 Bytes (Word 0)" {
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.border-radius: 6
  peekdata_call: |md
    `errno = 0;`
    `long word = ptrace(PTRACE_PEEKDATA, pid, (void*)0x7fff3a2b8000, NULL);`
    `if (word == -1L && errno != 0) → ERROR`
  | {
    style.fill: transparent
    style.stroke-width: 0
  }
  word_layout: "Little-endian word — byte[0] is at 0x7fff3a2b8000" {
    style.fill: "#c8e6c9"
    style.border-radius: 4
    grid-columns: 8
    grid-gap: 0
    b0: "byte[0]\n0x8000" {
      style.fill: "#ef9a9a"
      style.font-color: "#b71c1c"
      style.bold: true
      width: 80
    }
    b1: "byte[1]\n0x8001" {
      style.fill: "#ef9a9a"
      style.font-color: "#b71c1c"
      style.bold: true
      width: 80
    }
    b2: "byte[2]\n0x8002" {
      style.fill: "#ef9a9a"
      style.font-color: "#b71c1c"
      style.bold: true
      width: 80
    }
    b3: "byte[3]\n0x8003\n'o'" {
      style.fill: "#a5d6a7"
      style.font-color: "#1b5e20"
      style.bold: true
      width: 80
    }
    b4: "byte[4]\n0x8004\n'p'" {
      style.fill: "#a5d6a7"
      style.font-color: "#1b5e20"
      style.bold: true
      width: 80
    }
    b5: "byte[5]\n0x8005\n'e'" {
      style.fill: "#a5d6a7"
      style.font-color: "#1b5e20"
      style.bold: true
      width: 80
    }
    b6: "byte[6]\n0x8006\n'n'" {
      style.fill: "#a5d6a7"
      style.font-color: "#1b5e20"
      style.bold: true
      width: 80
    }
    b7: "byte[7]\n0x8007\n'/'" {
      style.fill: "#a5d6a7"
      style.font-color: "#1b5e20"
      style.bold: true
      width: 80
    }
  }
  legend: "" {
    style.fill: transparent
    style.stroke-width: 0
    grid-columns: 2
    grid-gap: 8
    skip_key: "  SKIP (byte_offset=3)" {
      style.fill: "#ef9a9a"
      style.font-color: "#b71c1c"
      style.border-radius: 3
    }
    data_key: "  COPY to output buffer" {
      style.fill: "#a5d6a7"
      style.font-color: "#1b5e20"
      style.border-radius: 3
    }
  }
}

step3: "STEP 3 — Scan Bytes byte_offset..7 for Null Terminator" {
  style.fill: "#fff8e1"
  style.stroke: "#f57f17"
  style.border-radius: 6
  scan_code: |md
    c
    unsigned char *bytes = (unsigned char *)&word;
    for (int i = byte_offset; i < 8; i++) {
        if (bytes_read >= max_len) break;         // length guard
        if (bytes[i] == '\0') { found_null=1; break; }
        out[bytes_read++] = (char)bytes[i];       // copy to output
    }
  | {
    style.fill: transparent
    style.stroke-width: 0
  }
  scan_states: "" {
    style.fill: "#fff3e0"
    style.border-radius: 4
    grid-columns: 3
    grid-gap: 12
    s_skip: "i = 0,1,2\ni < byte_offset\n→ **SKIP**" {
      style.fill: "#ef9a9a"
      style.font-color: "#b71c1c"
      style.border-radius: 4
    }
    s_copy: "i = 3..7\nbytes[i] != 0\n→ **COPY** to out[]" {
      style.fill: "#a5d6a7"
      style.font-color: "#1b5e20"
      style.border-radius: 4
    }
    s_null: "bytes[i] == 0\n→ **NULL FOUND**\nfound_null = 1; break" {
      style.fill: "#fff176"
      style.font-color: "#f57f17"
      style.bold: true
      style.border-radius: 4
    }
  }
  errno_note: |md
    ⚠️ **Critical**: `errno = 0` BEFORE `ptrace()` call.
    If `word == -1L && errno == 0` → **valid data** (0xFF×8), continue scanning.
    If `word == -1L && errno != 0` → **read error**, return -1.
  | {
    style.fill: "#ffecb3"
    style.stroke: "#f9a825"
    style.border-radius: 4
  }
}

step4: "STEP 4 — Advance to Next Word" {
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
  style.border-radius: 6
  advance: |md
    `aligned_addr += 8;    // → 0x7fff3a2b8008`
    `byte_offset   = 0;    // only skip prefix in FIRST word`
  | {
    style.fill: transparent
    style.stroke-width: 0
  }
  addr_progression: "" {
    style.fill: "#e1bee7"
    style.border-radius: 4
    grid-columns: 4
    grid-gap: 0
    w0h: "Word 0" {style.fill: "#8e24aa"; style.font-color: white; style.bold: true}
    w0a: "0x7fff3a2b**8000**" {style.fill: "#ce93d8"}
    w0off: "offset=3" {style.fill: "#ef9a9a"; style.font-color: "#b71c1c"}
    w0sk: "skip 3 bytes" {style.fill: "#ef9a9a"; style.font-color: "#b71c1c"}
    w1h: "Word 1" {style.fill: "#6a1b9a"; style.font-color: white; style.bold: true}
    w1a: "0x7fff3a2b**8008**" {style.fill: "#ce93d8"}
    w1off: "offset=0" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    w1sk: "scan all 8 bytes" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    w2h: "Word N" {style.fill: "#4a148c"; style.font-color: white; style.bold: true}
    w2a: "0x7fff3a2b8000\n+ N×8" {style.fill: "#ce93d8"}
    w2off: "offset=0" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    w2sk: "scan until null\nor max_len" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    wnh: "..." {style.fill: transparent; style.stroke-width: 0}
    wna: "" {style.fill: transparent; style.stroke-width: 0}
    wnoff: "" {style.fill: transparent; style.stroke-width: 0}
    wnsk: "" {style.fill: transparent; style.stroke-width: 0}
  }
}

step5: "STEP 5 — Loop Until Null Found OR max_len Reached" {
  style.fill: "#e0f2f1"
  style.stroke: "#00695c"
  style.border-radius: 6
  loop_code: |md
    c
    while (bytes_read < max_len && !found_null) {
        errno = 0;
        long word = ptrace(PTRACE_PEEKDATA, pid, aligned_addr, NULL);
        if (word == -1L && errno != 0) return -1;   // → ERROR path
        // ... scan bytes ...
        aligned_addr += 8;
        byte_offset = 0;
    }
    out[bytes_read] = '\0';    // always null-terminate output
    return bytes_read;         // 0..max_len  (-1 on error)
  | {
    style.fill: transparent
    style.stroke-width: 0
  }
  exit_conditions: "" {
    style.fill: "#b2dfdb"
    style.border-radius: 4
    grid-columns: 3
    grid-gap: 8
    ec_null: "**Null found**\nfound_null == 1\n→ return bytes_read\n(string complete)" {
      style.fill: "#80cbc4"
      style.font-color: "#004d40"
      style.border-radius: 4
    }
    ec_len: "**Length cap**\nbytes_read == max_len\n→ return max_len\n(truncated: show \"...\")" {
      style.fill: "#ffd54f"
      style.font-color: "#e65100"
      style.border-radius: 4
    }
    ec_err: "**PEEKDATA error**\nerrno != 0 on -1L\n→ return -1\n(print raw 0xADDR)" {
      style.fill: "#ef9a9a"
      style.font-color: "#b71c1c"
      style.border-radius: 4
    }
  }
}

# ── Full example trace ────────────────────────────────────────────────────────

example: "Worked Example: reading \"/open/path\\0\" from 0x7fff3a2b8003" {
  style.fill: "#fafafa"
  style.stroke: "#546e7a"
  style.border-radius: 6
  grid-columns: 1
  ex_table: "" {
    style.fill: "#eceff1"
    style.border-radius: 4
    grid-columns: 6
    grid-gap: 0
    h1: "Iteration" {style.fill: "#455a64"; style.font-color: white; style.bold: true}
    h2: "aligned_addr" {style.fill: "#455a64"; style.font-color: white; style.bold: true}
    h3: "byte_offset" {style.fill: "#455a64"; style.font-color: white; style.bold: true}
    h4: "Bytes scanned" {style.fill: "#455a64"; style.font-color: white; style.bold: true}
    h5: "Chars added to out[]" {style.fill: "#455a64"; style.font-color: white; style.bold: true}
    h6: "bytes_read after" {style.fill: "#455a64"; style.font-color: white; style.bold: true}
    r0i: "0 (initial)" {style.fill: "#cfd8dc"}
    r0a: "0x7fff3a2b8000" {style.fill: "#cfd8dc"}
    r0o: "**3**" {style.fill: "#ef9a9a"; style.font-color: "#b71c1c"}
    r0s: "bytes[3..7]" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    r0c: "'o','p','e','n','/'  (5 chars)" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    r0r: "5" {style.fill: "#cfd8dc"}
    r1i: "1" {style.fill: "#eceff1"}
    r1a: "0x7fff3a2b8008" {style.fill: "#eceff1"}
    r1o: "0" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    r1s: "bytes[0..7]" {style.fill: "#a5d6a7"; style.font-color: "#1b5e20"}
    r1c: "'p','a','t','h','\\0' → STOP" {style.fill: "#fff176"; style.font-color: "#f57f17"}
    r1r: "9  (null at byte[4])" {style.fill: "#eceff1"}
  }
  ex_result: |md
    **Result**: `out[] = "/open/path"`, `bytes_read = 9`, `out[9] = '\0'`
    → `print_string_arg` outputs: `"/open/path"`
  | {
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    style.border-radius: 4
  }
}

# ── Flow arrows between steps ─────────────────────────────────────────────────

step1 -> step2: "aligned_addr computed" {style.stroke: "#5c6bc0"; style.bold: true}
step2 -> step3: "word read via PTRACE_PEEKDATA" {style.stroke: "#388e3c"; style.bold: true}
step3 -> step4: "bytes copied; no null yet" {style.stroke: "#f57f17"; style.bold: true}
step4 -> step5: "advance + reset offset" {style.stroke: "#7b1fa2"; style.bold: true}
step5 -> step2: "next iteration\n(aligned_addr += 8)" {
  style.stroke: "#00695c"
  style.stroke-dash: 4
  style.bold: true
}
step5 -> example: "exit condition met" {style.stroke: "#546e7a"; style.bold: true}