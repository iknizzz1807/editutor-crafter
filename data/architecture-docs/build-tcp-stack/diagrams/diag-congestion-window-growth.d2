direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: TCP Congestion Window Growth Over Time (RFC 5681)
title.near: top-center
title.shape: text
title.style: {
  font-size: 28
  bold: true
  underline: true
}

# Axis definitions (Root level shapes)
time_axis: Time (RTTs)
time_axis.near: bottom-center
time_axis.shape: rectangle
time_axis.style: {
  fill: transparent
  stroke: "#666666"
  stroke-width: 2
}
time_axis.width: 900
time_axis.height: 50

cwnd_axis: "cwnd\n(MSS)"
cwnd_axis.near: center-left
cwnd_axis.shape: rectangle
cwnd_axis.style: {
  fill: transparent
  stroke: transparent
}
cwnd_axis.width: 50
cwnd_axis.height: 500

graph_area: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  slow_start_phase: {
    direction: down
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      stroke-dash: 5
    }
    width: 250
    height: 500

    phase_label: SLOW START
    phase_label.shape: text
    phase_label.style: {
      font-size: 16
      bold: true
      font-color: "#2E7D32"
    }

    growth_formula: "cwnd += 1 per ACK\n(Exponential: 2x per RTT)"
    growth_formula.shape: text
    growth_formula.style: {
      font-size: 12
      italic: true
      font-color: "#388E3C"
    }

    point_rtt0: 1
    point_rtt0.shape: circle
    point_rtt1: 2
    point_rtt1.shape: circle
    point_rtt2: 4
    point_rtt2.shape: circle
    point_rtt3: 8
    point_rtt3.shape: circle
    point_rtt4: 16
    point_rtt4.shape: circle

    point_rtt0 -> point_rtt1 -> point_rtt2 -> point_rtt3 -> point_rtt4: {
      style: {
        stroke: "#4CAF50"
        stroke-width: 3
        animated: true
      }
    }
  }

  threshold_line: {
    direction: down
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 60
    height: 500

    ssthresh_marker: "ssthresh\nthreshold"
    ssthresh_marker.shape: text
    ssthresh_marker.style: {
      font-size: 11
      font-color: "#FF6F00"
      bold: true
    }

    dashed_line: {
      shape: rectangle
      width: 2
      height: 400
      style: {
        fill: "#FF6F00"
        stroke: "#FF6F00"
        stroke-dash: 8
      }
    }
  }

  congestion_avoid_phase: {
    direction: down
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      stroke-dash: 5
    }
    width: 300
    height: 500

    phase_label_ca: "CONGESTION\nAVOIDANCE"
    phase_label_ca.shape: text
    phase_label_ca.style: {
      font-size: 16
      bold: true
      font-color: "#1565C0"
    }

    growth_formula_ca: "cwnd += MSS²/cwnd per ACK\n(Linear: +1 MSS per RTT)"
    growth_formula_ca.shape: text
    growth_formula_ca.style: {
      font-size: 12
      italic: true
      font-color: "#1976D2"
    }

    ca_point1: 17
    ca_point1.shape: circle
    ca_point2: 18
    ca_point2.shape: circle
    ca_point3: 19
    ca_point3.shape: circle
    ca_point4: 20
    ca_point4.shape: circle
    ca_point5: 21
    ca_point5.shape: circle

    ca_point1 -> ca_point2 -> ca_point3 -> ca_point4 -> ca_point5: {
      style: {
        stroke: "#1976D2"
        stroke-width: 3
      }
    }
  }

  loss_event: {
    direction: down
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
      stroke-width: 2
    }
    width: 100
    height: 500

    loss_marker: LOSS
    loss_marker.shape: diamond
    loss_marker.width: 40
    loss_marker.style.fill: "#D32F2F"

    drop_arrow: {
      shape: rectangle
      width: 3
      height: 200
      style: {
        fill: "#D32F2F"
        stroke: "#D32F2F"
        animated: true
      }
    }

    cwnd_reset: 1
    cwnd_reset.shape: circle
    cwnd_reset.width: 20
    cwnd_reset.style.fill: "#D32F2F"
  }

  recovery_phase: {
    direction: down
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
      stroke-dash: 5
    }
    width: 200
    height: 500

    phase_label_rec: "RECOVERY\n(Restart)"
    phase_label_rec.shape: text
    phase_label_rec.style: {
      font-size: 16
      bold: true
      font-color: "#E65100"
    }

    new_ssthresh_note: "New ssthresh =\nold_cwnd / 2 = 10"
    new_ssthresh_note.shape: text
    new_ssthresh_note.style: {
      font-size: 11
      italic: true
      font-color: "#F57C00"
    }

    rec_point1: 1
    rec_point1.shape: circle
    rec_point2: 2
    rec_point2.shape: circle
    rec_point3: 4
    rec_point3.shape: circle
    rec_point4: 8
    rec_point4.shape: circle
    rec_point5: 10
    rec_point5.shape: circle

    rec_point1 -> rec_point2 -> rec_point3 -> rec_point4 -> rec_point5: {
      style: {
        stroke: "#F57C00"
        stroke-width: 3
        animated: true
      }
    }
  }
}

legend: {
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  legend_title: LEGEND
  legend_title.shape: text
  legend_title.style.bold: true

  slow_start_key: Slow Start (exponential)
  slow_start_key.shape: circle
  slow_start_key.style.fill: "#4CAF50"

  ca_key: Congestion Avoidance (linear)
  ca_key.shape: circle
  ca_key.style.fill: "#1976D2"

  loss_key: Packet Loss Event
  loss_key.shape: diamond
  loss_key.style.fill: "#D32F2F"

  recovery_key: Recovery (restart from cwnd=1)
  recovery_key.shape: circle
  recovery_key.style.fill: "#F57C00"
}
legend.near: bottom-left

formulas: {
  direction: down
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    border-radius: 8
  }
  title_f: Key Formulas (RFC 5681)
  title_f.shape: text
  title_f.style: {
    bold: true
    font-size: 14
    underline: true
  }
  ss_detail: |md
    **Slow Start**:
    - cwnd < ssthresh
    - cwnd += MSS per ACK
    - Doubles every RTT
  |
  ca_detail: |md
    **Congestion Avoidance**:
    - cwnd >= ssthresh
    - cwnd += MSS²/cwnd per ACK
    - +1 MSS per RTT (linear)
  |
  loss_detail: |md
    **On Loss (timeout)**:
    - ssthresh = cwnd / 2
    - cwnd = 1 MSS
    - Restart slow start
  |
}
formulas.near: bottom-right

slow_start_phase -> congestion_avoid_phase: "cwnd >= ssthresh" {
  style: {
    stroke: "#FF6F00"
    stroke-width: 2
    stroke-dash: 5
  }
}
congestion_avoid_phase -> loss_event: packet loss {
  style: {
    stroke: "#D32F2F"
    stroke-width: 2
  }
}
loss_event -> recovery_phase: reset cwnd=1 {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
}