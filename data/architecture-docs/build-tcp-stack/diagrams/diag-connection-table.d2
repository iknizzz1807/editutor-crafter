direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Connection Table Structure
  Hash table keyed by 4-tuple for O(1) connection lookup
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  incoming: {
    direction: down
    label: "Incoming Segment"
    segment_buf: {
      shape: sql_table
      label: "TCP Segment Buffer"
      src_ip: "0x00 | uint32_t | src_ip"
      src_port: "0x04 | uint16_t | src_port"
      dst_ip: "0x06 | uint32_t | dst_ip"
      dst_port: "0x0A | uint16_t | dst_port"
      seq_num: "0x0C | uint32_t | seq_num"
      flags: "0x10 | uint8_t  | flags"
      total: "24 bytes (header only)"
    }
  }
  hash_fn: {
    label: "Hash Function"
    width: 280
    code: |'c
      uint32_t hash_4tuple(uint32_t src_ip, uint16_t src_port,
                           uint32_t dst_ip, uint16_t dst_port) {
        uint32_t h = src_ip ^ dst_ip;
        h ^= ((uint32_t)src_port << 16) | dst_port;
        h ^= (h >> 16);
        return h % TCP_CONN_HASH_SIZE;
      }
    '|
  }
  conn_table: {
    label: "Connection Table (struct tcp_conn_table)"
    hash_array: {
      label: "Hash Array [TCP_CONN_HASH_SIZE]"
      shape: rectangle
      width: 200
      height: 180
      bucket0: {label: "[0]"; width: 40; height: 20}
      bucket1: {label: "[1] → conn"; width: 40; height: 20}
      bucket2: {label: "[2]"; width: 40; height: 20}
      bucket3: {label: "[3] → conn"; width: 40; height: 20}
      bucketN: {label: "[N-1]"; width: 40; height: 20}
    }
    stats: {
      shape: sql_table
      label: "Table Statistics"
      count: "int | count"
      max: "#define | TCP_MAX_CONNECTIONS | 1024"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  conn_entry: {
    direction: down
    label: "Connection Entry (struct tcp_conn)"
    tuple: {
      shape: sql_table
      label: "Connection 4-Tuple (Key)"
      local_ip: "0x00 | uint32_t | local_ip"
      local_port: "0x04 | uint16_t | local_port"
      remote_ip: "0x06 | uint32_t | remote_ip"
      remote_port: "0x0A | uint16_t | remote_port"
      total: "14 bytes (unique identifier)"
    }
    state: {
      shape: sql_table
      label: "Connection State"
      state: "0x00 | enum tcp_state | state"
      flags: "0x04 | uint8_t | flags"
      error: "0x05 | int | error"
      in_use: "0x08 | int | in_use"
      total: "12 bytes"
    }
    seq_vars: {
      shape: sql_table
      label: "Sequence Variables (struct tcp_conn_vars)"
      snd_una: "0x00 | uint32_t | snd_una"
      snd_nxt: "0x04 | uint32_t | snd_nxt"
      snd_wnd: "0x08 | uint32_t | snd_wnd"
      snd_wl1: "0x0C | uint32_t | snd_wl1"
      snd_wl2: "0x10 | uint32_t | snd_wl2"
      iss: "0x14 | uint32_t | iss"
      rcv_nxt: "0x18 | uint32_t | rcv_nxt"
      rcv_wnd: "0x1C | uint32_t | rcv_wnd"
      irs: "0x20 | uint32_t | irs"
      snd_mss: "0x24 | uint16_t | snd_mss"
      rcv_mss: "0x26 | uint16_t | rcv_mss"
      total: "42 bytes"
    }
  }
  timers: {
    direction: down
    label: "Timers"
    timer_state: {
      shape: sql_table
      label: "Timer State"
      rto: "0x00 | uint32_t | retransmit_timer"
      tw: "0x04 | uint32_t | time_wait_expire"
      persist: "0x08 | uint32_t | persist_backoff"
      retry: "0x0C | uint32_t | retry_count"
      total: "16 bytes"
    }
    rto_state: {
      shape: sql_table
      label: "RTO State (RFC 6298)"
      srtt: "0x00 | int32_t | srtt"
      rttvar: "0x04 | int32_t | rttvar"
      rto_val: "0x08 | int32_t | rto"
      init: "0x0C | int | initialized"
      total: "16 bytes"
    }
  }
  buffers: {
    direction: down
    label: "Send/Recv Buffers"
    send_buf: {
      shape: sql_table
      label: "Send Buffer (256KB)"
      data: "0x0000 | uint8_t[256K] | data"
      head: "0x40000 | uint32_t | head"
      tail: "0x40004 | uint32_t | tail"
      snd_nxt_off: "0x40008 | uint32_t | snd_nxt"
      total: "262152 bytes"
    }
    recv_buf: {
      shape: sql_table
      label: "Recv Buffer (256KB)"
      data: "0x0000 | uint8_t[256K] | data"
      buf_start: "0x40000 | uint32_t | buf_start"
      buf_end: "0x40004 | uint32_t | buf_end"
      total: "262152 bytes"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lookup_flow: {
    label: "Connection Lookup Flow"
    width: 320
    code: |'c
      // On segment arrival:
      struct tcp_conn *tcp_conn_lookup(
          struct tcp_conn_table *table,
          uint32_t local_ip, uint16_t local_port,
          uint32_t remote_ip, uint16_t remote_port)
      {
        uint32_t hash = hash_4tuple(...);
        struct tcp_conn *conn = table->buckets[hash];
        while (conn) {
          if (conn->in_use &&
              conn->local_ip == local_ip &&
              conn->local_port == local_port &&
              conn->remote_ip == remote_ip &&
              conn->remote_port == remote_port) {
            return conn;  // Found!
          }
          conn = conn->hash_next;
        }
        return NULL;  // Not found → RST
      }
    '|
  }
  states: {
    label: "TCP State Enum"
    state_enum: {
      shape: class
      label: "enum tcp_state"
      TCP_STATE_CLOSED: "0"
      TCP_STATE_LISTEN: "1"
      TCP_STATE_SYN_SENT: "2"
      TCP_STATE_SYN_RECEIVED: "3"
      TCP_STATE_ESTABLISHED: "4"
      TCP_STATE_FIN_WAIT_1: "5"
      TCP_STATE_FIN_WAIT_2: "6"
      TCP_STATE_CLOSE_WAIT: "7"
      TCP_STATE_CLOSING: "8"
      TCP_STATE_LAST_ACK: "9"
      TCP_STATE_TIME_WAIT: "10"
    }
  }
}
incoming.segment_buf -> hash_fn: "extract 4-tuple"
hash_fn -> conn_table.hash_array: "hash % SIZE"
conn_table.hash_array -> conn_entry.tuple: "bucket → conn"
conn_entry.tuple -> conn_entry.state: ""
conn_entry.state -> conn_entry.seq_vars: ""
conn_entry.seq_vars -> timers.timer_state: ""
timers.timer_state -> timers.rto_state: ""
timers.rto_state -> buffers.send_buf: ""
buffers.send_buf -> buffers.recv_buf: ""
legend: {
  near: bottom-center
  note: {
    shape: rectangle
    label: |md
      **Connection Table Memory Layout**
      - Per-connection struct: ~524KB (mostly buffers)
      - 1024 connections max: ~537MB total
      - Hash collisions: chain via `hash_next` pointer
      - Lookup: O(1) average, O(n) worst case
    |
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
  }
}