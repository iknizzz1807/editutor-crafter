direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- Classes for styling ---
classes: {
  struct_node: {
    shape: sql_table
    style: {
      stroke: "#4a7be8"
      fill: "#f8faff"
    }
  }
  logic_step: {
    shape: step
    width: 400
  }
  annotation: {
    style: {
      fill: transparent
      stroke: transparent
      font: mono
    }
  }
}

# --- Section 1: End-to-End Topology ---
topology: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  client: "Test Client (Source)" {
    shape: person
    icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
  }

  network: "Virtual Tap Interface" {
    shape: cloud
    style.stroke-dash: 3
  }

  server: "Stack under Test" {
    shape: rectangle
    style.fill: "#e8f4ff"
    listener: "TCP Listener (Port 80)" {
      shape: circle
      style.fill: "#fff9c4"
    }
  }

  client -> network: "1MB Raw Data"
  network -> server.listener: "Ethernet II | IPv4 | TCP"
}

# --- Section 2: Core Data Structures ---
data_structures: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  tcp_conn: {
    shape: sql_table
    label: "struct tcp_conn (tcp_conn.h)"
    r0: "0x00 | enum tcp_state | state"
    r1: "0x04 | uint32_t | local_ip"
    r2: "0x08 | uint32_t | remote_ip"
    r3: "0x0C | uint16_t | local_port"
    r4: "0x0E | uint16_t | remote_port"
    r5: "0x10 | uint32_t | snd_nxt // Next sequence to send"
    r6: "0x14 | uint32_t | rcv_nxt // Expected sequence"
    r7: "0x18 | uint32_t | rcv_wnd // Advertised window"
    r8: "0x1C | struct tcp_ooo_buf* | ooo_buf"
    r9: "0x24 | struct tcp_congestion | cong"
    total: "Total: 128 bytes (aligned)"
  }

  ooo_buffer: {
    shape: sql_table
    label: "struct tcp_ooo_segment"
    s0: "0x00 | uint32_t | seq_start"
    s1: "0x04 | uint32_t | seq_end"
    s2: "0x08 | void* | data_ptr"
    s3: "0x10 | struct ooo_segment* | next"
    note: "Used for reassembly of out-of-order data"
  }
}

# --- Section 3: Implementation Logic ---
processing_logic: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  send_path: {
    label: "T1: Data Transmission Logic"
    code: |'c
      while (sent < total_size) {
        data_len = min(MSS, total_size - sent);
        if (tcp_can_send(conn, data_len)) {
          tcp_send_segment(conn, data, data_len);
          conn->snd_nxt += data_len;
          sent += data_len;
        }
      }
    '|
  }

  receive_path: {
    label: "T2: In-Order Reassembly"
    code: |'c
      if (seq == conn->rcv_nxt) {
        memcpy(conn->recv_buf + offset, data, len);
        conn->rcv_nxt += len;
        // Check if gap is filled in OOO buffer
        tcp_check_ooo_queue(conn);
      } else if (seq > conn->rcv_nxt) {
        tcp_ooo_store(&conn->ooo_buf, seq, data, len);
      }
    '|
  }
}

# --- Section 4: State Machine Evolution ---
state_machine: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  LISTEN: {shape: oval}
  SYN_RCVD: {shape: oval}
  ESTABLISHED: {shape: oval; style.stroke-width: 3}

  LISTEN -> SYN_RCVD: "SYN | Send SYN-ACK"
  SYN_RCVD -> ESTABLISHED: "ACK | conn_established()"
  ESTABLISHED -> ESTABLISHED: "Data Segment | update_rcv_nxt()"
}

# --- Section 5: Diagnostic & Timers ---
diagnostics: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  retransmit_logic: {
    label: "Retransmission Timer"
    rto_calc: "Initial RTO: 1s"
    backoff: "Exponential Backoff (max 64s)"
    style.fill: "#fff3e0"
  }

  metrics: {
    shape: sql_table
    label: "Test Metrics"
    m1: "Expected Hash | SHA-256"
    m2: "Throughput | 100 Mbps (Simulated)"
    m3: "MTU | 1500 Bytes"
    m4: "MSS | 1460 Bytes"
  }
}

# --- Connections between layers ---
topology.server -> data_structures.tcp_conn: "allocates"
data_structures.tcp_conn -> processing_logic: "ptr"
processing_logic.receive_path -> state_machine.ESTABLISHED: "updates seq"
processing_logic.send_path -> diagnostics.retransmit_logic: "starts timer"

legend: {
  shape: rectangle
  near: bottom-right
  label: "Manual Reference"
  item1: "Blue Nodes: Hot Path"
  item2: "Yellow Nodes: Control Path"
  item3: "Dashed: Virtual/Simulated"
}