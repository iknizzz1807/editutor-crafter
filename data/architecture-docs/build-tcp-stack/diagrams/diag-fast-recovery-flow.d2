direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # TCP Fast Recovery State Transitions
  Window inflation during recovery, deflation on exit
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  normal: {
    direction: down
    label: "Normal Operation"
    normal_state: {
      shape: circle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    normal_desc: {
      label: |md
        **State: Steady Transfer**
        - cwnd growing (slow start/avoidance)
        - ssthresh stable
        - dup_ack_count = 0
      |
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  trigger: {
    direction: down
    label: "Loss Detection"
    dup1: {
      label: "Dup ACK #1"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
    }
    dup2: {
      label: "Dup ACK #2"
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
    }
    dup3: {
      label: "Dup ACK #3\n(Trigger)"
      shape: rectangle
      style.fill: "#FFCC80"
      style.stroke: "#E65100"
      style.bold: true
    }
    dup1 -> dup2: "same ack_num"
    dup2 -> dup3: "same ack_num"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  entry: {
    direction: down
    label: "Fast Recovery Entry"
    entry_action: {
      label: |md
        **On 3rd Dup ACK:**
        
        ssthresh = cwnd / 2
        retransmit lost segment
        cwnd = ssthresh + 3*MSS
        recovery_mode = true
        recover_seq = snd_nxt
      |
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      width: 280
    }
    entry_note: {
      label: |md
        **Why +3 MSS?**
        Each dup ACK means 1 segment left the network.
        3 dup ACKs = 3 segments delivered, so inflate
        window to allow new transmission.
      |
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#F57C00"
      width: 280
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recovery: {
    direction: down
    label: "Fast Recovery (Inflation)"
    recovery_state: {
      shape: circle
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      width: 120
    }
    inflation: {
      label: |md
        **Per Additional Dup ACK:**
        
        cwnd += MSS
        // Transmit new segment if
        // window allows
        
        Window *inflates* as dup ACKs
        arrive, allowing new data
        transmission during recovery.
      |
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      width: 280
    }
    window_example: {
      label: |md
        **Example (MSS=1460):**
        
        Initial cwnd:     10 MSS (14600 bytes)
        ssthresh:         5 MSS  (7300 bytes)
        Entry cwnd:       8 MSS  (11680 bytes)
        After dup #4:     9 MSS
        After dup #5:     10 MSS
        After dup #6:     11 MSS
      |
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      width: 280
    }
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  exit: {
    direction: down
    label: "Fast Recovery Exit"
    exit_trigger: {
      label: |md
        **New ACK Arrives**
        (ack_num > recover_seq)
      |
      shape: diamond
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
    exit_action: {
      label: |md
        **On Exit:**
        
        cwnd = ssthresh
        recovery_mode = false
        dup_ack_count = 0
        
        Window *deflates* back to
        ssthresh, entering congestion
        avoidance.
      |
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      width: 280
    }
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  resume: {
    direction: down
    label: "Congestion Avoidance"
    avoid_state: {
      shape: circle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    avoid_desc: {
      label: |md
        **State: Congestion Avoidance**
        - cwnd = ssthresh
        - Linear growth: cwnd += MSS²/cwnd per RTT
        - dup_ack_count = 0
        - Ready for normal operation
      |
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
  }
}

# Transitions
row1.normal.normal_state -> row2.trigger.dup1: "Out-of-order\nsegment arrives" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
}
row2.trigger.dup3 -> row3.entry.entry_action: "3 dup ACKs\n(Fast Retransmit)" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
row3.entry.entry_action -> row4.recovery.recovery_state: "Enter Fast Recovery" {
  style.stroke: "#1565C0"
}
row4.recovery.recovery_state -> row4.recovery.recovery_state: "Dup ACK arrives\n(cwnd += MSS)" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
  style.animated: true
}
row4.recovery.recovery_state -> row5.exit.exit_trigger: "New ACK\n(ack > recover_seq)" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
row5.exit.exit_trigger -> row6.resume.avoid_state: "Exit Fast Recovery\n(cwnd = ssthresh)" {
  style.stroke: "#2E7D32"
}

# Window size annotation
legend: {
  label: |'md
    **Window Size During Fast Recovery:**
    | Event | cwnd Change | Direction |
    |-------|-------------|-----------|
    | 3 dup ACKs (entry) | cwnd = ssthresh + 3*MSS | Inflate |
    | Each additional dup ACK | cwnd += MSS | Inflate |
    | New ACK (exit) | cwnd = ssthresh | Deflate |
    
    **Key Insight:** Inflation allows new transmissions during recovery.
    Deflation prevents burst on exit.
  '|
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  width: 500
}
legend.near: bottom-center