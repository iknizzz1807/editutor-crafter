direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "Fast Retransmit on 3 Duplicate ACKs"
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

states: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  sender_init: {
    shape: class
    label: "Sender State (Initial)"
    -cwnd: "10 MSS"
    -ssthresh: "65535"
    -snd_una: "1"
    -snd_nxt: "7301 (seq 6)"
    -dup_acks: "0"
  }

  receiver_init: {
    shape: class
    label: "Receiver State (Initial)"
    -rcv_nxt: "1"
    -rcv_wnd: "65535"
    -ooo_buffer: "Empty"
  }
}

flow: {
  shape: sequence_diagram
  sender: Sender (TCP Stack)
  receiver: Receiver (TCP Stack)

  # Phase 1: Normal Transmission & Loss
  sender -> receiver: "SEG seq=1 [1460b]"
  sender -> receiver: "SEG seq=2 [1460b] | LOST" {
    style.stroke: red
    style.stroke-dash: 5
  }
  sender.tx_burst -> receiver.rx_burst: "SEG seq=3 [1460b]"
  sender.tx_burst -> receiver.rx_burst: "SEG seq=4 [1460b]"
  sender.tx_burst -> receiver.rx_burst: "SEG seq=5 [1460b]"

  # Phase 2: Duplicate ACKs generated by out-of-order segments
  receiver.rx_burst -> sender: "ACK ack=2"
  sender."dup_acks = 1"
  
  receiver.rx_burst -> sender: "ACK ack=2 (DUP #1)"
  sender."dup_acks = 2"
  
  receiver.rx_burst -> sender: "ACK ack=2 (DUP #2)"
  sender."dup_acks = 3"
  
  # Phase 3: Triggering Fast Retransmit
  sender.trigger: "TRIGGER: Fast Retransmit" {
    style.fill: "#FFE4B5"
  }
  
  sender.retransmit -> receiver: "SEG seq=2 [RETRANSMIT]" {
    style.stroke: green
    style.stroke-width: 4
    style.animated: true
  }
  
  sender."ssthresh = cwnd/2 (5)"
  sender."cwnd = ssthresh + 3 (8)"
  
  # Phase 4: Recovery
  receiver -> sender: "ACK ack=6 (Cumulative)" {
    style.stroke: green
    style.stroke-width: 2
  }
  sender."exit FAST RECOVERY"
  sender."cwnd = ssthresh (5)"
}

analysis_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  timing_note: {
    label: "Timeline & Efficiency"
    content: |'md
      | Event | Time (ms) | Action |
      |-------|-----------|--------|
      | Loss  | 1ms       | Seg 2 dropped |
      | Dup 1 | 51ms      | Rcvd Seg 3 |
      | Dup 2 | 52ms      | Rcvd Seg 4 |
      | Dup 3 | 53ms      | **Retransmit** |
      | Done  | 105ms     | Full recovery |

      **Advantage**: Recovered in 1 RTT instead of 
      waiting for RTO (Retransmission Timeout) 
      which is typically 200ms+.
    '|
    width: 400
  }

  state_logic: {
    shape: class
    label: "RFC 5681 Logic"
    +on_three_dups(): "void"
    +ssthresh: "max(FlightSize/2, 2*MSS)"
    +cwnd: "ssthresh + 3*MSS"
    +retransmit_lost_segment(): "void"
    +on_new_ack(): "cwnd = ssthresh"
  }
}

legend: {
  shape: package
  label: "Iconography"
  near: bottom-right
  
  l1: {
    label: "Lost Segment"
    style.stroke: red
    style.stroke-dash: 5
  }
  l2: {
    label: "Fast Retransmit"
    style.stroke: green
    style.stroke-width: 4
  }
  l1 -> l2: "Detected via"
}

# Styles for flow components
flow.sender.style.fill: "#C7F1FF"
flow.receiver.style.fill: "#E4DBFE"