direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # IP Checksum Calculation (RFC 1071)
  Ones' Complement Sum Algorithm
| {near: top-center}
step1: {
  label: "Step 1: Treat Header as 16-bit Words"
  width: 420
  header_bytes: {
    shape: sql_table
    label: "IP Header (20 bytes) - checksum field = 0x0000"
    w0: "0x00 | 0x45 | version=4, ihl=5, tos=0x00"
    w1: "0x02 | 0x00 | total_len=512 bytes"
    w2: "0x12 | 0x34 | identification=0x1234"
    w3: "0x40 | 0x00 | flags=DF, frag_offset=0"
    w4: "0x40 | 0x06 | ttl=64, proto=TCP(6)"
    w5: "0x00 | 0x00 | checksum=0 (for calc)"
    w6: "0xC0 | 0xA8 | src_ip[0:1]=192.168..."
    w7: "0x01 | 0x01 | src_ip[2:3]=...1.1"
    w8: "0x0A | 0x00 | dst_ip[0:1]=10.0..."
    w9: "0x00 | 0x05 | dst_ip[2:3]=...0.5"
  }
  note: |md
    20-byte header = **10 words** of 16 bits each
    Checksum field set to **0x0000** before calculation
  |
}
step2: {
  label: "Step 2: Ones' Complement Sum (Carry Wraps)"
  width: 480
  sum_sequence: {
    shape: sql_table
    label: "Accumulate 16-bit Words"
    s0: "sum = 0x0045"
    s1: "sum = 0x0045 + 0x0200 = 0x0245"
    s2: "sum = 0x0245 + 0x1234 = 0x1479"
    s3: "sum = 0x1479 + 0x4000 = 0x5479"
    s4: "sum = 0x5479 + 0x4006 = 0x947F"
    s5: "sum = 0x947F + 0x0000 = 0x947F"
    s6: "sum = 0x947F + 0xC0A8 = 0x15527"
    note1: "→ Carry! Fold: 0x5527 + 0x0001 = 0x5528"
    s7: "sum = 0x5528 + 0x0101 = 0x5629"
    s8: "sum = 0x5629 + 0x0A00 = 0x6029"
    s9: "sum = 0x6029 + 0x0005 = 0x602E"
    final: "Final sum (with carry folded) = **0x602E**"
  }
  carry_box: {
    label: "Carry Folding Rule"
    style.fill: "#FFF9C9"
    style.stroke: "#9D341E"
    width: 400
    code: |'c
      // Fold 32-bit sum to 16 bits
      while (sum >> 16) {
        sum = (sum & 0xFFFF) + (sum >> 16);
      }
      // 0x15527 → 0x5527 + 0x0001 = 0x5528
    '|
  }
}
step3: {
  label: "Step 3: Ones' Complement of Sum"
  width: 420
  result: {
    shape: sql_table
    label: "Final Checksum Value"
    sum: "Sum (16-bit)   = 0x602E"
    inv: "~0x602E        = 0x9FD1"
    result: "**Checksum = 0x9FD1**"
  }
  formula: {
    label: "Ones' Complement"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    width: 380
    code: |'c
      // Bitwise NOT (ones' complement)
      checksum = ~sum & 0xFFFF;
      // 0x602E → binary:
      // 0110 0000 0010 1110
      // NOT:
      // 1001 1111 1101 0001 = 0x9FD1
    '|
  }
}
verification: {
  label: "Verification: Receiver Adds All Words"
  width: 480
  verify: {
    shape: sql_table
    label: "Including Checksum Field"
    v0: "Sum all 10 words (checksum = 0x9FD1)"
    v1: "... intermediate sums ..."
    v2: "Final sum = 0x602E + 0x9FD1 = 0xFFFF"
    pass: "**Result = 0xFFFF → Checksum VALID**"
  }
  rule: {
    label: "Verification Property"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    width: 380
    code: |'c
      // On receiver: sum all words
      // If header intact, result = 0xFFFF
      int verify(void *hdr, size_t len) {
        uint32_t sum = 0;
        uint16_t *ptr = (uint16_t *)hdr;
        for (int i = 0; i < len/2; i++)
          sum += ptr[i];
        while (sum >> 16)
          sum = (sum & 0xFFFF) + (sum >> 16);
        return (sum == 0xFFFF);  // valid?
      }
    '|
  }
}
step1 -> step2: "words"
step2 -> step3: "sum"
step3 -> verification: "checksum"