direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "IP Fragmentation and Reassembly (RFC 791)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
before: "BEFORE: Original Datagram (4000 bytes)" {
  direction: down
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
    border-radius: 8
  }
  orig_desc: |md
    **Path MTU Discovery Fails**
    Sending host creates 4000-byte IP datagram
    First hop link has MTU = 1500 bytes
    DF (Don't Fragment) flag = 0
    Router must fragment to proceed
  |
  orig_pkt: {
    direction: right
    label: ""
    style: {
      stroke: transparent
      fill: transparent
    }
    ip_hdr: {
      label: "IP Header\n20 bytes"
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
        stroke-width: 2
      }
      width: 100
    }
    payload: {
      label: "Payload\n3980 bytes"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
        stroke-width: 2
      }
      width: 300
    }
  }
  orig_fields: {
    shape: sql_table
    label: "Original IP Header Fields"
    f0: "0x00 | version=4 | ihl=5"
    f1: "0x00 | tos=0"
    f2: "0x02 | total_len=4000"
    f3: "0x04 | id=0x1234"
    f4: "0x06 | flags=0 | frag_off=0"
    f5: "0x08 | ttl=64 | proto=6 (TCP)"
    f6: "0x0A | checksum=0xXXXX"
    f7: "0x0C | src_ip=10.0.0.1"
    f8: "0x10 | dst_ip=192.168.1.100"
    note: "Total: 4000 bytes (20 hdr + 3980 data)"
  }
  mtu_constraint: {
    label: "MTU 1500\nConstraint"
    shape: diamond
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 3
    }
  }
  ip_hdr -> payload
  payload -> mtu_constraint: "exceeds\nMTU!"
}
fragmentation: "FRAGMENTATION: Router splits datagram" {
  direction: down
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
    border-radius: 8
  }
  frag_rules: |md
    **Fragmentation Rules (RFC 791)**
    1. Each fragment gets its own IP header (20 bytes)
    2. Fragment offset in 8-byte units (divide byte offset by 8)
    3. All fragments share same Identification field
    4. MF (More Fragments) = 1 on all except last
    5. Data must be multiple of 8 (except last fragment)
  |
  frag_calc: {
    shape: sql_table
    label: "Fragment Size Calculation"
    step1: "Max payload per frag = MTU - IP_HDR = 1500 - 20 = 1480"
    step2: "1480 % 8 = 0 ✓ (8-byte aligned)"
    step3: "Frag 1: bytes 0-1479 → offset=0, len=1480"
    step4: "Frag 2: bytes 1480-2959 → offset=1480/8=185, len=1480"
    step5: "Frag 3: bytes 2960-3979 → offset=2960/8=370, len=1020"
    step6: "Total payload: 1480+1480+1020 = 3980 ✓"
  }
  frag_packets: "Fragments (sent sequentially)" {
    direction: down
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
      stroke-dash: 3
    }
    frag1: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      f1_hdr: {
        label: "IP Header\n20B"
        shape: rectangle
        style: {
          fill: "#BBDEFB"
          stroke: "#1976D2"
        }
        width: 60
      }
      f1_data: {
        label: "Data 0-1479\n1480B"
        shape: rectangle
        style: {
          fill: "#A5D6A7"
          stroke: "#388E3C"
        }
        width: 140
      }
      f1_info: {
        shape: sql_table
        label: "Fragment 1"
        t1: "id=0x1234"
        t2: "flags=MF=1"
        t3: "frag_off=0"
        t4: "total_len=1500"
      }
    }
    frag2: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      f2_hdr: {
        label: "IP Header\n20B"
        shape: rectangle
        style: {
          fill: "#BBDEFB"
          stroke: "#1976D2"
        }
        width: 60
      }
      f2_data: {
        label: "Data 1480-2959\n1480B"
        shape: rectangle
        style: {
          fill: "#81C784"
          stroke: "#388E3C"
        }
        width: 140
      }
      f2_info: {
        shape: sql_table
        label: "Fragment 2"
        t1: "id=0x1234"
        t2: "flags=MF=1"
        t3: "frag_off=185"
        t4: "total_len=1500"
      }
    }
    frag3: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      f3_hdr: {
        label: "IP Header\n20B"
        shape: rectangle
        style: {
          fill: "#BBDEFB"
          stroke: "#1976D2"
        }
        width: 60
      }
      f3_data: {
        label: "Data 2960-3979\n1020B"
        shape: rectangle
        style: {
          fill: "#66BB6A"
          stroke: "#388E3C"
        }
        width: 100
      }
      f3_info: {
        shape: sql_table
        label: "Fragment 3 (LAST)"
        t1: "id=0x1234"
        t2: "flags=MF=0"
        t3: "frag_off=370"
        t4: "total_len=1040"
      }
    }
  }
  frag1.f1_hdr -> frag1.f1_data
  frag2.f2_hdr -> frag2.f2_data
  frag3.f3_hdr -> frag3.f2_data
}
after: "AFTER: Reassembly at Destination" {
  direction: down
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
    border-radius: 8
  }
  reassembly_desc: |md
    **Reassembly Buffer State (out-of-order arrival)**
    Fragments may arrive in any order due to:
    - Different network paths
    - Variable queuing delays
    - Retransmissions
    Receiver buffers until all gaps filled
  |
  timeline: "Arrival Timeline" {
    direction: right
    style: {
      fill: transparent
      stroke: transparent
    }
    t1: {
      direction: down
      label: "T=0ms"
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        border-radius: 4
      }
      t1_buf: {
        shape: rectangle
        label: |md
          **Fragment 2 arrives first**
          (offset=185, len=1480)
          Buffer: [?????][DATA2][???????]
                  gap    recv   gap
        |
        style: {
          fill: "#E8F5E9"
          font: mono
        }
        width: 220
      }
    }
    t2: {
      direction: down
      label: "T=5ms"
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        border-radius: 4
      }
      t2_buf: {
        shape: rectangle
        label: |md
          **Fragment 1 arrives**
          (offset=0, len=1480)
          Buffer: [DATA1][DATA2][???????]
                  recv   recv   gap
        |
        style: {
          fill: "#E8F5E9"
          font: mono
        }
        width: 220
      }
    }
    t3: {
      direction: down
      label: "T=12ms"
      style: {
        fill: "#A5D6A7"
        stroke: "#2E7D32"
        border-radius: 4
        stroke-width: 3
      }
      t3_buf: {
        shape: rectangle
        label: |md
          **Fragment 3 arrives (LAST)**
          (offset=370, len=1020)
          Buffer: [DATA1][DATA2][DATA3]
                  recv   recv   recv
          **Complete! Deliver to upper layer**
        |
        style: {
          fill: "#C8E6C9"
          font: mono
          bold: true
        }
        width: 220
      }
    }
  }
  reassembly_state: {
    shape: class
    label: "Reassembly Context (per datagram)"
    -src_ip: "uint32_t"
    -dst_ip: "uint32_t"
    -id: "uint16_t"
    -proto: "uint8_t"
    -frags: "frag_node*"
    -total_len: "uint16_t"
    -have_last_frag: "int"
    -expires_at: "time_t"
    +frag_add(offset, data, len, is_last): "int"
    +frag_is_complete(): "int"
    +frag_reassemble(out_buf): "int"
  }
  key_fields: {
    shape: sql_table
    label: "Reassembly Key Fields"
    f1: "Identification | Groups fragments of same datagram"
    f2: "Source IP + Dest IP | Distinguish senders"
    f3: "Protocol | TCP vs UDP reassembly separate"
    f4: "MF flag + offset | Detect last fragment, fill gaps"
    f5: "TTL | 30 second reassembly timeout (RFC 791)"
  }
}
edge_cases: "Edge Cases and Security Concerns" {
  direction: right
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-dash: 3
    border-radius: 8
  }
  overlap: {
    label: "Overlapping Fragments"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
    }
    width: 180
  }
  tiny: {
    label: "Tiny Fragment Attack\n(8-byte fragments)"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
    }
    width: 180
  }
  timeout: {
    label: "Reassembly Timeout\n(DoS via incomplete frags)"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
    }
    width: 180
  }
  overflow: {
    label: "Buffer Overflow\n(len > 65535)"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
    }
    width: 180
  }
}
before -> fragmentation: "Router\nfragments" {
  style: {
    stroke: "#FF9800"
    stroke-width: 3
    animated: true
  }
}
fragmentation -> after: "Receiver\nreassembles" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    animated: true
  }
}
after -> edge_cases: "Must handle" {
  style: {
    stroke: "#F44336"
    stroke-dash: 5
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    border-radius: 4
  }
  hdr_box: {
    label: "IP Header"
    shape: rectangle
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
    width: 60
    height: 30
  }
  data_box: {
    label: "Payload"
    shape: rectangle
    style: {
      fill: "#A5D6A7"
      stroke: "#388E3C"
    }
    width: 60
    height: 30
  }
  mf1: "MF=1: More fragments follow"
  mf0: "MF=0: Last fragment"
  off: "Offset in 8-byte units"
}