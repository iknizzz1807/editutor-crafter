direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Initial Sequence Number (ISN) Generation
  ## RFC 6528 — Preventing Sequence Number Prediction Attacks
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  naive: {
    direction: down
    label: "NAIVE (INSECURE)"
    style.fill: "#FFE4E1"
    style.stroke: "#DC143C"
    naive_struct: {
      shape: sql_table
      label: "Naive ISN Generator"
      f0: "0x00 | uint32_t | isn"
      f1: "0x04 | uint32_t | counter = 0"
      sz: "Total: 8 bytes"
      style.fill: "#FFE4E1"
    }
    naive_code: {
      label: "Attack Vector (1990s)"
      width: 320
      code: |'c
        // VULNERABLE: Predictable ISN
        uint32_t generate_isn(void) {
            static uint32_t counter = 0;
            return counter++;  // 0, 1, 2, 3...
        }
        // Attacker can guess ISN:
        // 1. Connect to server, observe ISN
        // 2. Guess next ISN = observed + 1
        // 3. Forge packets with guessed ISN
        // 4. Connection hijacked!
      '|
    }
    attack_label: {
      label: "⚠️ IP Spoofing + ISN Prediction\n= Connection Hijacking"
      shape: diamond
      style.fill: "#FF6B6B"
      style.font-color: white
    }
  }
  rfc6528: {
    direction: down
    label: "RFC 6528 COMPLIANT"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    rfc_struct: {
      shape: sql_table
      label: "Secure ISN Generator (RFC 6528)"
      f0: "0x00 | uint32_t | clock_ms"
      f1: "0x04 | uint32_t | hash[4]"
      f2: "0x08 | uint32_t | local_ip"
      f3: "0x0C | uint16_t | local_port"
      f4: "0x0E | uint16_t | remote_port"
      f5: "0x10 | uint32_t | remote_ip"
      f6: "0x14 | uint8_t[16] | secret_key"
      sz: "Total: 36+ bytes"
      style.fill: "#E8F5E9"
    }
    rfc_formula: {
      label: "RFC 6528 Formula"
      width: 380
      code: |'c
        // ISN = M + F(local_ip, local_port, 
        //            remote_ip, remote_port, secret)
        //
        // Where:
        //   M = clock component (changes ~4µs)
        //   F = cryptographically secure hash
        //     (MD5, SHA-1, or equivalent)
        //
        uint32_t rfc6528_isn(conn_tuple *t) {
            uint32_t M = clock_ms();  // Time-based
            uint8_t buf[18];
            memcpy(buf, &t->local_ip, 4);
            memcpy(buf+4, &t->local_port, 2);
            memcpy(buf+6, &t->remote_ip, 4);
            memcpy(buf+10, &t->remote_port, 2);
            memcpy(buf+12, secret_key, 16);
            // F() = hash function
            uint32_t F = md5_truncated(buf, 18);
            return M + F;  // Unpredictable
        }
      '|
    }
    secure_label: {
      label: "✓ Unpredictable ISN\n= Attack Prevented"
      shape: diamond
      style.fill: "#4CAF50"
      style.font-color: white
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  attack_flow: {
    direction: down
    label: "Attack Scenario: ISN Prediction"
    attacker: {
      label: "Attacker\n(spoofed IP)"
      shape: person
      style.fill: "#FFCDD2"
    }
    victim: {
      label: "Victim Server"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    trusted: {
      label: "Trusted Host\n(spoofed source)"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    step1: {
      label: "Step 1: Probe"
      code: |'c
        // Attacker sends SYN
        // from their real IP to
        // observe ISN pattern
      '|
      width: 200
    }
    step2: {
      label: "Step 2: Predict"
      code: |'c
        // Attacker calculates:
        // next_isn = observed 
        //          + delta_per_sec
        //          * elapsed_time
      '|
      width: 200
    }
    step3: {
      label: "Step 3: Spoof"
      code: |'c
        // Attacker sends SYN-ACK
        // with guessed ISN from
        // spoofed trusted host IP
      '|
      width: 200
    }
    attacker -> step1: "probe"
    step1 -> victim: "SYN"
    victim -> step1: "SYN-ACK\n(ISN observed)"
    step1 -> step2: "analyze"
    step2 -> step3: "calculate"
    attacker -> step3: "forge"
    step3 -> victim: "SYN-ACK\n(guessed ISN)"
    victim -> trusted: "ACK\n(connection hijacked!)"
    step3.style.stroke: "#DC143C"
    step3.style.stroke-dash: 4
  }
  defense: {
    direction: down
    label: "Defense: RFC 6528 Components"
    components: {
      shape: sql_table
      label: "Security Layer Stack"
      layer1: "Layer 1 | Clock | Changes every ~4µs"
      layer2: "Layer 2 | Connection Tuple | Unique per flow"
      layer3: "Layer 3 | Secret Key | 128-bit random"
      layer4: "Layer 4 | Hash Function | MD5/SHA-1+"
      total: "Result: 2^32 space, ~65K guesses needed"
      style.fill: "#E8F5E9"
    }
    timing: {
      label: "Clock Component Timing"
      shape: class
      label: "Clock Parameters"
      -clock_rate: "4 µs increments"
      -wrap_period: "~4.66 hours (32-bit)"
      -guess_window: "~64K guesses/sec max"
      +is_clock_based: "bool"
      +uses_secret: "bool"
    }
    hash_func: {
      label: "Hash Function F()"
      shape: class
      +input: "conn_tuple + secret"
      +output: "uint32_t"
      +algorithm: "MD5 | SHA-1 | SipHash"
      +collision_resist: "computationally infeasible"
    }
    components -> timing
    timing -> hash_func
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  history: {
    direction: down
    label: "Historical Context"
    timeline: {
      shape: class
      label: "Timeline"
      year_1985: "1985 | Morris worm uses ISN prediction"
      year_1995: "1995 | RFC 1948 (clock-based ISN)"
      year_2001: "2001 | MIT attack on RFC 1948"
      year_2008: "2008 | Linux adds MD5 ISN hash"
      year_2012: "2012 | RFC 6528 (current standard)"
      year_2024: "Today | SipHash common (faster)"
    }
    impl_note: {
      label: "Linux Implementation"
      width: 340
      code: |'c
        // net/core/secure_seq.c
        u32 secure_tcp_seq(__be32 saddr, __be32 daddr,
                           __be16 sport, __be16 dport)
        {
            u32 hash[MD5_DIGEST_WORDS];
            // SipHash-2-4 (fast + secure)
            hash[0] = siphash_1u64(...);
            // Add clock component
            return hash[0] + tcp_clock_ms();
        }
      '|
    }
  }
  comparison: {
    direction: down
    label: "Security Comparison"
    compare_table: {
      shape: sql_table
      label: "ISN Generation Methods"
      row1: "Method | Predictability | Attack Cost"
      row2: "Sequential | Trivial | O(1)"
      row3: "Clock-only | Easy | O(100)"
      row4: "Clock+Hash | Hard | O(65000)"
      row5: "Clock+Cryptographic | Infeasible | O(2^32)"
    }
    verdict: {
      label: "Verdict"
      shape: diamond
      style.fill: "#4CAF50"
      style.font-color: white
      note: |md
        RFC 6528 requires:
        • Clock component (changes frequently)
        • Cryptographic hash of connection tuple
        • Secret key (random, periodically rotated)
        This makes ISN prediction computationally
        infeasible within the TCP handshake timeout.
      |
    }
  }
}
legend: {
  near: bottom-center
  red: "Red = Vulnerable to ISN prediction attacks" {shape: text}
  green: "Green = RFC 6528 compliant, secure" {shape: text}
}