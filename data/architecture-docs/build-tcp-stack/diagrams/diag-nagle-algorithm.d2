direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Nagle's Algorithm Decision Tree
  Self-clocking segment coalescing to reduce small packets
| {near: top-center}
nagle_root: {
  shape: diamond
  label: "Application\nwrites data"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
check_mss: {
  shape: diamond
  label: "data_len >= MSS\n(1460 bytes)?"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
}
send_full: {
  label: "SEND IMMEDIATELY\nFull-sized segment"
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  width: 180
}
check_unacked: {
  shape: diamond
  label: "Any unacked\ndata in flight?\n(snd_una < snd_nxt)"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
}
send_small: {
  label: "SEND IMMEDIATELY\nSmall segment allowed\n(no outstanding data)"
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  width: 180
}
buffer_data: {
  label: "BUFFER THE DATA\nWait for condition..."
  style.fill: "#FFF9C4"
  style.stroke: "#FFC107"
  style.stroke-width: 2
  width: 180
}
check_conditions: {
  shape: diamond
  label: "Wait until\nwhich condition?"
  style.fill: "#FFF9C4"
  style.stroke: "#FFC107"
}
cond_ack: {
  label: "ACK arrives\n(unacked → acked)\nThen SEND all buffered"
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
  width: 180
}
cond_mss: {
  label: "Buffer grows\nto ≥ MSS\nThen SEND as full segment"
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
  width: 180
}
nagle_root -> check_mss: "Yes"
check_mss -> send_full: "Yes\n(full MSS)"
check_mss -> check_unacked: "No\n(small segment)"
check_unacked -> send_small: "No\n(pipe empty)"
check_unacked -> buffer_data: "Yes\n(data in flight)"
buffer_data -> check_conditions: "Blocking..."
check_conditions -> cond_ack: "ACK received"
check_conditions -> cond_mss: "More writes\naccumulate"
problem_section: {
  label: "The Nagle + Delayed ACK Problem"
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-dash: 4
  width: 500
  problem_desc: |md
    **Pathological Interaction (200ms delay):**
    1. Client sends small request (fits in one segment)
    2. Server receives, but delays ACK (40ms typical)
    3. Client has response data, but Nagle blocks it
    4. Client waits for ACK that server is delaying
    5. Deadlock until delayed ACK timer fires
  |
}
problem_timeline: {
  shape: sequence_diagram
  Client
  Server
  interaction: {
    Client -> Server: "Small request (1 seg)"
    Server: "ACK delayed (40-200ms)"
    Server -> Server: "Processing..."
    Client: "Response ready but Nagle blocks"
    Client: "Waiting for ACK..."
    Server -> Client: "ACK (finally!)"
    Client -> Server: "Response (now sent)"
  }
}
solutions: {
  label: "Solutions"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  sol1: |md
    **1. TCP_NODELAY socket option**
    Disables Nagle entirely
    c
    int flag = 1;
    setsockopt(sock, IPPROTO_TCP, 
               TCP_NODELAY, &flag, sizeof(flag));
    
  |
  sol2: |md
    **2. Write in full MSS chunks**
    Application ensures writes ≥ MSS
    (Only first/last segments are small)
  |
  sol3: |md
    **3. Request/Response pattern**
    Send all data, then read
    (Don't interleave reads/writes)
  |
}
legend: {
  near: bottom-right
  style.fill: transparent
  style.stroke: "#666"
  green_box: {
    label: "Send immediately"
    style.fill: "#C8E6C9"
    width: 120
    height: 30
  }
  yellow_box: {
    label: "Wait/Buffer"
    style.fill: "#FFF9C4"
    width: 120
    height: 30
  }
  red_box: {
    label: "Problem area"
    style.fill: "#FFEBEE"
    width: 120
    height: 30
  }
}
send_full -> problem_section: "Optimal path" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
buffer_data -> problem_section: "Can trigger\nNagle+DelayedACK" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
code_example: {
  label: "Nagle Algorithm Implementation"
  width: 400
  code: |'c
    int tcp_nagle_can_send(struct tcp_conn *c, size_t len) {
        // Full-sized segment always sends
        if (len >= c->mss) return 1;
        // No unacked data? Send immediately
        if (c->snd_una == c->snd_nxt) return 1;
        // PUSH flag set? Application requested
        if (c->push_pending) return 1;
        // Nagle disabled? Always send
        if (c->nagle_disabled) return 1;
        // Otherwise: buffer and wait
        return 0;
    }
  '|
}
problem_section -> problem_timeline: "Timeline"
problem_section -> solutions: "Fixes"