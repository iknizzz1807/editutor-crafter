direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "TCP Receiver Out-of-Order Buffer (rcv_buf)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
legend: {
  near: top-right
  style.fill: white
  style.stroke: "#999"
  label: "Legend"
  received: "Received (buffered)" {
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  gap: "Gap (missing)" {
    shape: rectangle
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
    style.stroke-dash: 3
  }
  rcv_nxt: "RCV.NXT pointer" {
    shape: rectangle
    style.fill: "#FFD700"
    style.stroke: "#DAA520"
  }
}
buffer_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  buffer: "Receive Buffer (256KB)" {
    direction: down
    style.fill: "#F8F8F8"
    style.stroke: "#333"
    style.stroke-width: 2
    header: "Byte Range | State | Data" {
      shape: rectangle
      style.fill: "#E0E0E0"
      style.font: mono
      style.bold: true
    }
    seg1: "0x0000 - 0x0063 | RECEIVED | bytes 1-100" {
      shape: rectangle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.font: mono
      label: "1-100 (in-order)"
    }
    gap1: "0x0064 - 0x00C7 | GAP | bytes 101-200" {
      shape: rectangle
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
      style.stroke-dash: 3
      style.font: mono
      label: "101-200 (MISSING)"
    }
    seg2: "0x00C8 - 0x012B | OOO RECV | bytes 201-300" {
      shape: rectangle
      style.fill: "#87CEEB"
      style.stroke: "#4169E1"
      style.font: mono
      label: "201-300 (out-of-order)"
    }
    gap2: "0x012C - 0x018F | GAP | bytes 301-400" {
      shape: rectangle
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
      style.stroke-dash: 3
      style.font: mono
      label: "301-400 (MISSING)"
    }
    seg3: "0x0190 - 0x01F3 | OOO RECV | bytes 401-500" {
      shape: rectangle
      style.fill: "#87CEEB"
      style.stroke: "#4169E1"
      style.font: mono
      label: "401-500 (out-of-order)"
    }
  }
  ooo_tracker: "OOO Segment Tracker (ooo_buf)" {
    direction: down
    style.fill: "#FFFACD"
    style.stroke: "#B8860B"
    ooo_header: "start_seq | end_seq | ptr" {
      shape: rectangle
      style.fill: "#FFE4B5"
      style.font: mono
      style.bold: true
    }
    ooo_entry1: "201 | 300 | buf+0xC8" {
      shape: rectangle
      style.font: mono
      label: "seg[0]: 201-300"
    }
    ooo_entry2: "401 | 500 | buf+0x190" {
      shape: rectangle
      style.font: mono
      label: "seg[1]: 401-500"
    }
    ooo_entry3: "... | ... | ..." {
      shape: rectangle
      style.fill: "#D3D3D3"
      style.font: mono
      style.multiple: true
      label: "seg[n]: ..."
    }
  }
}
pointer_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rcv_nxt_box: "RCV.NXT = 101" {
    shape: rectangle
    style.fill: "#FFD700"
    style.stroke: "#DAA520"
    style.stroke-width: 3
    style.font: mono
    style.bold: true
    width: 180
  }
  explanation: {
    width: 400
    label: "RCV.NXT points to first missing byte"
    code: |'c
      // First gap starts at byte 101
      // RCV.NXT = 101 (waiting for this)
      // Bytes 1-100: deliverable to app
      // Bytes 201-300, 401-500: buffered in OOO
    '|
  }
}
rcv_nxt_box -> buffer.seg1: "ACKed up to here" {
  style.stroke: "#228B22"
  style.stroke-width: 2
  target-arrowhead.shape: arrow
}
rcv_nxt_box -> buffer.gap1: "waiting for" {
  style.stroke: "#DC143C"
  style.stroke-width: 2
  style.stroke-dash: 4
  target-arrowhead.shape: arrow
}
ack_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ack_packet: "ACK Segment Sent" {
    direction: down
    style.fill: "#E6E6FA"
    style.stroke: "#483D8B"
    ack_header: "TCP Header Fields" {
      shape: rectangle
      style.fill: "#DDA0DD"
      style.font: mono
      style.bold: true
    }
    ack_num: "ack_num: 101" {
      shape: rectangle
      style.fill: "#FFD700"
      style.font: mono
      style.bold: true
    }
    ack_win: "window: 65336" {
      shape: rectangle
      style.font: mono
    }
    ack_flags: "flags: ACK" {
      shape: rectangle
      style.font: mono
    }
  }
  ack_explain: {
    width: 420
    label: "Cumulative ACK semantics"
    code: |'c
      // ACK=101 means:
      // "I have received ALL bytes 0-100"
      // "I am waiting for byte 101+"
      // 
      // This is a CUMULATIVE acknowledgment.
      // Does NOT ACK the OOO segments 201-300
      // or 401-500 (those are buffered, not
      // delivered until gap is filled).
    '|
  }
}
rcv_nxt_box -> ack_packet.ack_num: "ACK value = RCV.NXT" {
  style.stroke: "#DAA520"
  style.stroke-width: 2
  style.stroke-dash: 2
}
ooo_tracker.ooo_entry1 -> buffer.seg2: "points to" {
  style.stroke: "#4169E1"
  style.stroke-dash: 2
}
ooo_tracker.ooo_entry2 -> buffer.seg3: "points to" {
  style.stroke: "#4169E1"
  style.stroke-dash: 2
}
gap_fill_scenario: {
  label: "When Gap Fills (seg 101-200 arrives)"
  direction: down
  style.fill: "#F0FFF0"
  style.stroke: "#2E8B57"
  step1: {
    label: "Step 1: Check seq_num against RCV.NXT"
    code: |'c
      if (seq == conn->vars.rcv_nxt) {
        // In-order! Fill the gap
        memcpy(buf + offset, data, len);
        conn->vars.rcv_nxt += len;
      }
    '|
    width: 400
  }
  step2: {
    label: "Step 2: Check OOO buffer for contiguous"
    code: |'c
      // Now RCV.NXT = 201
      // Check OOO buffer: seg 201-300 is next!
      uint32_t deliverable = 
        tcp_ooo_check_contiguous(conn, ooo);
      // Returns 100 (bytes 201-300)
    '|
    width: 400
  }
  step3: {
    label: "Step 3: Deliver contiguous to application"
    code: |'c
      // Gap filled! Now bytes 1-300 contiguous
      // RCV.NXT advances to 301
      // Deliver bytes 1-300 to application
      // Still waiting for 301-400...
    '|
    width: 400
  }
}
flow_arrow: buffer -> pointer_row -> ack_row -> gap_fill_scenario: "processing flow" {
  style.stroke: "#999"
  style.stroke-dash: 2
  style.opacity: 0.3
}