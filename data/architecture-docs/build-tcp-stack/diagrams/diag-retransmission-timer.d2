direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # TCP Retransmission Timer State Machine
  RFC 6298: Computing TCP's Retransmission Timer
'| {near: top-center}

classes: {
  stopped: {
    style.fill: "#F3F4F6"
    style.stroke: "#4B5563"
    style.stroke-width: 2
  }
  running: {
    style.fill: "#DCFCE7"
    style.stroke: "#166534"
    style.stroke-width: 3
  }
  expired: {
    style.fill: "#FEE2E2"
    style.stroke: "#991B1B"
    style.stroke-width: 3
  }
  backoff: {
    style.fill: "#FEF3C7"
    style.stroke: "#92400E"
    style.stroke-width: 2
    style.stroke-dash: 4
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  stopped: STOPPED {
    class: stopped
    shape: oval
    width: 180
    height: 100
    label: "STOPPED\n(Idle)"
    note: |'md
      **Condition:** No outstanding data
      SND.UNA == SND.NXT
      Timer is disarmed.
    '|
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  running: RUNNING {
    class: running
    shape: oval
    width: 200
    height: 120
    label: "RUNNING\n(Armed)"
    note: |'md
      **Logic:**
      RTO = SRTT + max(G, 4*RTTVAR)
      Armed for RTO seconds.
      Tracks oldest unacked segment.
    '|
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  expired: EXPIRED {
    class: expired
    shape: diamond
    width: 180
    height: 120
    label: "TIMEOUT\nEVENT"
    note: |'md
      **Action:**
      1. Retransmit SND.UNA
      2. RTO = RTO * 2 (Backoff)
      3. Restart Timer
    '|
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  backoff_box: Backoff State {
    class: backoff
    shape: rectangle
    width: 250
    height: 140
    label: "EXPONENTIAL BACKOFF"
    details: |'md
      **Implementation Detail:**
      c
      // Double RTO up to 60s cap
      tp->srtt = 0; // RFC: clear SRTT on timeout?
      tp->rto = min(tp->rto << 1, TCP_RTO_MAX);
      tcp_retransmit_skb(sk, seg);
      
    '|
  }
}

# Logic Flow Connections (Using Absolute Paths for ELK precision)
row1.stopped -> row2.running: "SND.NXT > SND.UNA | START" {
  style.stroke: "#166534"
  style.stroke-width: 2
  style.font-color: "#166534"
}

row2.running -> row3.expired: "Clock >= RTO | EXPIRE" {
  style.stroke: "#991B1B"
  style.stroke-width: 2
  style.font-color: "#991B1B"
}

row3.expired -> row4.backoff_box: "Retransmit | BACKOFF" {
  style.stroke: "#92400E"
  style.stroke-width: 2
  style.font-color: "#92400E"
}

row4.backoff_box -> row2.running: "Restart | RESET" {
  style.stroke: "#92400E"
  style.stroke-width: 2
  style.font-color: "#92400E"
}

row2.running -> row1.stopped: "All ACKed | STOP" {
  style.stroke: "#4B5563"
  style.stroke-width: 2
  style.font-color: "#4B5563"
  style.stroke-dash: 4
}

row2.running -> row2.running: "New Data ACKed | RESTART" {
  style.stroke: "#166534"
  style.stroke-width: 1
  style.stroke-dash: 3
}

# Annotations and Supporting Documentation
rto_limits: {
  label: "RFC 6298 Parameters"
  shape: package
  style.fill: "#F9FAFB"
  
  bounds: |'md
    - **Initial RTO:** 1.0 second
    - **Min RTO:** 1.0 second (Typical)
    - **Max RTO:** 60.0 seconds
    - **G:** Clock granularity
    - **K:** 4 (RTTVAR Multiplier)
  '|
}
rto_limits.near: top-right

backoff_table: {
  label: "Backoff Progression"
  shape: sql_table
  style.fill: "#FFFBEB"
  
  table: |'md
    | Attempt | RTO (sec) | Cumul. (sec) |
    | :--- | :--- | :--- |
    | 1 | 1.0 | 1.0 |
    | 2 | 2.0 | 3.0 |
    | 3 | 4.0 | 7.0 |
    | 4 | 8.0 | 15.0 |
    | 5 | 16.0 | 31.0 |
    | 6 | 32.0 | 63.0 |
    | 7+ | 60.0 (MAX) | 123.0+ |
  '|
}
backoff_table.near: bottom-left

karns_rule: {
  label: "Karn's Algorithm (Refinement)"
  shape: callout
  style.fill: "#EFF6FF"
  style.stroke: "#1E40AF"
  
  content: |'md
    **Constraint:** 
    RTT samples MUST NOT be 
    measured for retransmitted segments. 
    
    **Reason:** Acknowledgement Ambiguity. 
    We cannot distinguish if the ACK is for 
    the original or the retransmission.
  '|
}
karns_rule.near: bottom-center

legend: {
  label: "Diagram Legend"
  shape: package
  direction: down
  
  s1: "Success/Normal Path" {
    shape: rectangle
    style.fill: "#DCFCE7"
  }
  s2: "Error/Timeout Path" {
    shape: rectangle
    style.fill: "#FEE2E2"
  }
  s3: "Control/State Reset" {
    shape: rectangle
    style.stroke-dash: 4
  }
}
legend.near: bottom-right