direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # IP Routing Table: Trie Structure for Longest Prefix Match
  Lookup for 10.1.2.3 → matches 10.1.0.0/16 (not 10.0.0.0/8)
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  trie: {
    direction: down
    label: "Binary Trie (bits examined left-to-right from MSB)"
    root: {
      shape: circle
      label: "*"
      style.fill: "#E8E8E8"
      style.stroke: "#666"
    }
    level1: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      n0: {
        shape: circle
        label: "0"
        style.fill: "#E8E8E8"
      }
      n1: {
        shape: circle
        label: "1"
        style.fill: "#E8E8E8"
      }
    }
    level2: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      n00: {
        shape: circle
        label: "0"
        style.fill: "#E8E8E8"
      }
      n01: {
        shape: circle
        label: "1"
        style.fill: "#E8E8E8"
      }
      n10: {
        shape: circle
        label: "0"
        style.fill: "#FFE4B5"
        style.stroke: "#FF8C00"
        style.stroke-width: 3
      }
      n11: {
        shape: circle
        label: "1"
        style.fill: "#E8E8E8"
      }
    }
    level3: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      n000: {
        shape: diamond
        label: "DF"
        style.fill: "#90EE90"
        style.stroke: "#228B22"
      }
      n001: {
        shape: circle
        label: "..."
        style.fill: "#E8E8E8"
      }
      n010: {
        shape: circle
        label: "0"
        style.fill: "#E8E8E8"
      }
      n011: {
        shape: circle
        label: "1"
        style.fill: "#E8E8E8"
      }
      n100: {
        shape: diamond
        label: "/8"
        style.fill: "#FFD700"
        style.stroke: "#B8860B"
        style.stroke-width: 2
      }
      n101: {
        shape: circle
        label: "..."
        style.fill: "#E8E8E8"
      }
      n110: {
        shape: circle
        label: "..."
        style.fill: "#E8E8E8"
      }
      n111: {
        shape: circle
        label: "..."
        style.fill: "#E8E8E8"
      }
    }
    level4: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      n010_ext: {
        shape: circle
        label: "..."
        style.fill: "#E8E8E8"
      }
      n011_ext: {
        shape: diamond
        label: "/24"
        style.fill: "#87CEEB"
        style.stroke: "#4169E1"
      }
    }
    level16: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      route_16: {
        shape: diamond
        label: "/16"
        style.fill: "#32CD32"
        style.stroke: "#006400"
        style.stroke-width: 3
        style.bold: true
      }
    }
    root -> level1.n0: "0" {style.stroke: "#999"}
    root -> level1.n1: "1" {style.stroke: "#999"}
    level1.n0 -> level2.n00: "0" {style.stroke: "#999"}
    level1.n0 -> level2.n01: "1" {style.stroke: "#999"}
    level1.n1 -> level2.n10: "0" {style.stroke: "#FF8C00"; style.stroke-width: 3}
    level1.n1 -> level2.n11: "1" {style.stroke: "#999"}
    level2.n00 -> level3.n000: "0" {style.stroke: "#999"}
    level2.n00 -> level3.n001: "1" {style.stroke: "#999"}
    level2.n01 -> level3.n010: "0" {style.stroke: "#999"}
    level2.n01 -> level3.n011: "1" {style.stroke: "#999"}
    level2.n10 -> level3.n100: "0" {style.stroke: "#FF8C00"; style.stroke-width: 3}
    level2.n10 -> level3.n101: "1" {style.stroke: "#999"}
    level2.n11 -> level3.n110: "0" {style.stroke: "#999"}
    level2.n11 -> level3.n111: "1" {style.stroke: "#999"}
    level3.n010 -> level4.n010_ext: {style.stroke: "#999"}
    level3.n011 -> level4.n011_ext: {style.stroke: "#4169E1"}
    level3.n100 -> level16.route_16: "...bits 9-16" {style.stroke: "#006400"; style.stroke-width: 3; style.animated: true}
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  routes: {
    label: "Route Entries"
    direction: down
    route_default: {
      shape: sql_table
      label: "Default Route"
      prefix: "0.0.0.0/0"
      bits: "*(any)"
      gateway: "Gateway A"
      match: "Last resort"
    }
    route_8: {
      shape: sql_table
      label: "Network Route"
      prefix: "10.0.0.0/8"
      bits: "00001010..."
      gateway: "Gateway B"
      match: "8 bits"
    }
    route_16: {
      shape: sql_table
      label: "Network Route"
      prefix: "10.1.0.0/16"
      bits: "00001010 00000001"
      gateway: "Gateway C"
      match: "16 bits (BEST)"
      style.fill: "#E8FFE8"
    }
    route_24: {
      shape: sql_table
      label: "Network Route"
      prefix: "192.168.1.0/24"
      bits: "11000000 10101000 00000001"
      gateway: "Gateway D"
      match: "24 bits"
    }
  }
  lookup: {
    label: "Lookup Example"
    direction: down
    dst_ip: {
      shape: sql_table
      label: "Destination IP"
      addr: "10.1.2.3"
      binary: "00001010 00000001 00000010 00000011"
      style.fill: "#FFF8DC"
    }
    match_path: {
      label: "Match Path"
      width: 350
      code: |'c
        bit 1:   0 → go left
        bit 2:   0 → go left  
        bit 3:   0 → go left
        bit 4:   0 → go left
        bit 5:   1 → go right
        bit 6:   0 → go left
        bit 7:   1 → go right
        bit 8:   0 → go left  [/8 matches]
        bits 9-16: 00000001 [/16 matches!]
      '|
    }
    result: {
      shape: rectangle
      label: "Result: 10.1.0.0/16 via Gateway C"
      style.fill: "#32CD32"
      style.font-color: "white"
      style.bold: true
    }
    dst_ip -> match_path: "traverse"
    match_path -> result: "longest match"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  algorithm: {
    label: "Longest Prefix Match Algorithm"
    width: 380
    code: |'c
      // O(prefix_length) lookup, not O(routes)
      route_t *route_lookup(trie_t *root, uint32_t dst_ip) {
        route_t *best = NULL;
        trie_t *node = root;
        for (int bit = 31; bit >= 0 && node; bit--) {
          // Check if this node has a route
          if (node->has_route) {
            best = node->route;  // Remember best match
          }
          // Traverse: 0=left, 1=right
          int b = (dst_ip >> bit) & 1;
          node = node->child[b];
        }
        return best;  // Longest prefix matched
      }
    '|
  }
  legend: {
    direction: down
    label: "Legend"
    leg_node: {
      shape: circle
      label: "Internal Node"
      style.fill: "#E8E8E8"
    }
    leg_route: {
      shape: diamond
      label: "Route Entry"
      style.fill: "#FFD700"
    }
    leg_match: {
      shape: diamond
      label: "Best Match"
      style.fill: "#32CD32"
      style.stroke-width: 3
    }
    leg_path: {
      label: "Lookup Path"
      style.fill: "#FFE4B5"
      style.stroke: "#FF8C00"
    }
  }
}
row1 -> row2: "Structure"
row2 -> row3: "Algorithm"