direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: "TCP RST Segment Handling by State" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rst_arrival: {
    shape: diamond
    label: "RST\nArrives"
    width: 100
    height: 100
    style.fill: "#FFE4B5"
    style.stroke: "#FF8C00"
    style.stroke-width: 3
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lookup: {
    shape: diamond
    label: "Connection\nExists?"
    width: 110
    height: 110
    style.fill: "#E6E6FA"
    style.stroke: "#9370DB"
    style.stroke-width: 2
  }
}
rst_arrival -> lookup: "segment\narrives"
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  seq_check: {
    shape: diamond
    label: "SEQ in\nWindow?"
    width: 110
    height: 110
    style.fill: "#E6E6FA"
    style.stroke: "#9370DB"
    style.stroke-width: 2
  }
  send_rst: {
    label: "Generate RST\n(no connection)"
    shape: rectangle
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
    style.stroke-width: 2
    style.stroke-dash: 4
  }
}
lookup -> seq_check: "YES"
lookup -> send_rst: "NO" {
  style.stroke: "#DC143C"
  style.stroke-dash: 4
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_check: {
    shape: diamond
    label: "Current\nState?"
    width: 120
    height: 120
    style.fill: "#98FB98"
    style.stroke: "#228B22"
    style.stroke-width: 2
  }
  ignore_outside: {
    label: "IGNORE\n(out of window)"
    shape: rectangle
    style.fill: "#D3D3D3"
    style.stroke: "#696969"
    style.stroke-width: 2
  }
}
seq_check -> state_check: "YES\n(valid RST)"
seq_check -> ignore_outside: "NO" {
  style.stroke: "#696969"
  style.stroke-dash: 3
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  closed_listen: {
    label: "CLOSED\nor LISTEN"
    shape: oval
    style.fill: "#ADD8E6"
    style.stroke: "#4682B4"
    style.stroke-width: 2
  }
  syn_received: {
    label: "SYN_RECEIVED"
    shape: oval
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
    style.stroke-width: 2
  }
  established: {
    label: "ESTABLISHED\nFIN_WAIT_1\nFIN_WAIT_2"
    shape: oval
    style.fill: "#FFA07A"
    style.stroke: "#FF4500"
    style.stroke-width: 2
  }
  closing: {
    label: "CLOSE_WAIT\nCLOSING\nLAST_ACK"
    shape: oval
    style.fill: "#DDA0DD"
    style.stroke: "#8B008B"
    style.stroke-width: 2
  }
}
state_check -> closed_listen: "CLOSED/\nLISTEN"
state_check -> syn_received: "SYN_\nRECEIVED"
state_check -> established: "ESTAB/\nFIN*"
state_check -> closing: "CLOSE_\nWAIT*"
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  action_ignore: {
    label: "IGNORE\n(no action)"
    shape: rectangle
    style.fill: "#D3D3D3"
    style.stroke: "#696969"
    style.stroke-width: 2
  }
  action_listen: {
    label: "Return to\nLISTEN"
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    style.stroke-width: 2
  }
  action_abort_user: {
    label: "ABORT\nNotify User\nECONNRESET"
    shape: rectangle
    style.fill: "#FF6B6B"
    style.stroke: "#DC143C"
    style.stroke-width: 3
  }
  action_abort: {
    label: "ABORT\nClose Connection"
    shape: rectangle
    style.fill: "#FF6B6B"
    style.stroke: "#DC143C"
    style.stroke-width: 3
  }
}
closed_listen -> action_ignore
syn_received -> action_listen
established -> action_abort_user
closing -> action_abort
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  final_closed: {
    label: "CLOSED"
    shape: circle
    style.fill: "#2F4F4F"
    style.stroke: "#000000"
    style.stroke-width: 3
    style.font-color: "#FFFFFF"
    style.bold: true
  }
}
action_ignore -> final_closed: "done" {
  style.stroke-dash: 3
}
action_listen -> final_closed: "done" {
  style.stroke-dash: 3
}
action_abort_user -> final_closed: "done" {
  style.stroke-dash: 3
}
action_abort -> final_closed: "done" {
  style.stroke-dash: 3
}
send_rst -> final_closed: "done" {
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  label: "RST Handling Legend (RFC 793)"
  style.fill: "#F5F5F5"
  style.stroke: "#A9A9A9"
  style.stroke-width: 2
  l1: "Valid RST Requirements:" {
    shape: text
    style.font-size: 12
  }
  l2: "• SEQ must be within receive window" {
    shape: text
    style.font-size: 11
  }
  l3: "• RCV.NXT <= SEQ < RCV.NXT + RCV.WND" {
    shape: text
    style.font-size: 11
  }
  l4: "• Out-of-window RST: silently ignore" {
    shape: text
    style.font-size: 11
  }
  l5: "---" { shape: text }
  l6: "State Transitions:" {
    shape: text
    style.font-size: 12
    style.bold: true
  }
  l7: "• SYN_RECEIVED → LISTEN (half-open)" {
    shape: text
    style.font-size: 11
  }
  l8: "• ESTABLISHED → CLOSED (notify app)" {
    shape: text
    style.font-size: 11
  }
  l9: "• FIN_WAIT* → CLOSED (notify app)" {
    shape: text
    style.font-size: 11
  }
  l10: "• CLOSE_WAIT* → CLOSED (no notify)" {
    shape: text
    style.font-size: 11
  }
}
note_generation: {
  near: bottom-left
  label: "RST Generation Triggers"
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  g1: "Send RST when segment arrives for:" {
    shape: text
    style.font-size: 12
    style.bold: true
  }
  g2: "• Non-existent connection (no 4-tuple match)" {
    shape: text
    style.font-size: 11
  }
  g3: "• No listening socket on destination port" {
    shape: text
    style.font-size: 11
  }
  g4: "• Segment with invalid checksum" {
    shape: text
    style.font-size: 11
  }
  g5: "• ACK for non-existent connection" {
    shape: text
    style.font-size: 11
  }
  g6: "---" { shape: text }
  g7: "RST SEQ Rules:" {
    shape: text
    style.font-size: 12
    style.bold: true
  }
  g8: "• If ACK in segment: SEQ = ACK value" {
    shape: text
    style.font-size: 11
  }
  g9: "• If no ACK: SEQ = 0, ACK = SEG.SEQ+SEG.LEN" {
    shape: text
    style.font-size: 11
  }
}