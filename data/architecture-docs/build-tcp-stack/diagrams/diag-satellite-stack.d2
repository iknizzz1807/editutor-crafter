direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    app: "#E8E8E8"
    tcp: "#B5D8F0"
    ip: "#C5E0C5"
    eth: "#F5E6D3"
    arp: "#FFE4B5"
    wire: "#D0D0D0"
    send: "#28A745"
    recv: "#007BFF"
  }
}

# Satellite Navigation Layers
layers: {
  build-tcp-stack-m1: {
    label: "Milestone 1: Ethernet & ARP"
  }
  build-tcp-stack-m2: {
    label: "Milestone 2: IP Layer & ICMP"
  }
  build-tcp-stack-m3: {
    label: "Milestone 3: TCP Connection Mgmt"
  }
  build-tcp-stack-m4: {
    label: "Milestone 4: TCP Reliable Delivery"
  }
}

title: TCP/IP Stack Architecture: Satellite View {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# --- APPLICATION LAYER ---
row_app: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  app_layer: Application Layer {
    style: {
      fill: ${colors.app}
      stroke: "#666666"
      stroke-width: 2
    }
    app_api: {
      shape: class
      label: "Socket API (socket.h)"
      +send(buf, len): "ssize_t"
      +recv(buf, len): "ssize_t"
      +connect(addr): "int"
      +listen(port): "int"
      +close(fd): "int"
    }
    app_buffers: {
      label: "User Buffers\nRing Queues"
      style.fill: "#FFFFFF"
      style.stroke-dash: 2
    }
  }
}

# --- TRANSPORT LAYER ---
row_tcp: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  tcp_layer: TCP Layer (L4) {
    link: layers.build-tcp-stack-m4
    style: {
      fill: ${colors.tcp}
      stroke: "#4A90A4"
      stroke-width: 2
    }
    tcp_logic: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      m4_reliable: Reliable Delivery {
        style.fill: "#D0E8F8"
        label: |md
          **M4: Reliability**
          - Sliding Window
          - Congestion (reno)
          - RTO/Retransmit
          - Flow Control
        |
      }
      m3_mgmt: Connection Mgmt {
        style.fill: "#D0E8F8"
        label: |md
          **M3: Control**
          - 11-State Machine
          - 3-Way Handshake
          - 4-Way Close
          - TIME_WAIT
        |
      }
    }
    tcp_tcb: {
      shape: sql_table
      label: "struct tcp_conn (TCB)"
      f0: "0x00 | uint32_t | snd_una"
      f1: "0x04 | uint32_t | snd_nxt"
      f2: "0x08 | uint32_t | snd_wnd"
      f3: "0x0C | uint32_t | rcv_nxt"
      f4: "0x10 | uint32_t | rcv_wnd"
      f5: "0x14 | uint8_t  | state"
      f6: "0x15 | uint8_t  | flags"
      sz: "Total: 32 bytes (packed)"
    }
  }
}

# --- NETWORK LAYER ---
row_ip: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  ip_layer: IP Layer (L3) {
    link: layers.build-tcp-stack-m2
    style: {
      fill: ${colors.ip}
      stroke: "#5A8A5A"
      stroke-width: 2
    }
    ip_core: IP Routing Core {
      style.fill: "#E8F5E8"
      label: |md
        **M2: IP Subsystem**
        - Header Validation
        - Checksum Calc
        - TTL Management
        - Route Lookup
      |
    }
    icmp: ICMP Protocol {
      style.fill: "#E8F5E8"
      label: |md
        **ICMP Handlers**
        - Type 0/8: Echo
        - Type 3: Unreachable
        - Type 11: Exceeded
      |
    }
    ip_hdr: {
      shape: sql_table
      label: "struct ip_hdr (ipv4.h)"
      f0: "0x00 | uint8_t  | ver_ihl"
      f1: "0x01 | uint8_t  | tos"
      f2: "0x02 | uint16_t | len"
      f3: "0x04 | uint16_t | id"
      f4: "0x06 | uint16_t | frag_off"
      f5: "0x08 | uint8_t  | ttl"
      f6: "0x09 | uint8_t  | proto"
      f7: "0x0C | uint32_t | src"
      f8: "0x10 | uint32_t | dst"
      sz: "Size: 20 bytes"
    }
  }
}

# --- LINK LAYER ---
row_l2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  eth_layer: Ethernet Layer (L2) {
    link: layers.build-tcp-stack-m1
    style: {
      fill: ${colors.eth}
      stroke: "#B8926A"
      stroke-width: 2
    }
    eth_demux: EtherType Demux {
      style.fill: "#FDF5E6"
      label: |md
        **Demux Logic**
        - 0x0800 -> IPv4
        - 0x0806 -> ARP
        - 0x8100 -> VLAN
      |
    }
    arp_cache: ARP Table {
      style.fill: ${colors.arp}
      label: |md
        **Cache Mgmt**
        - IP -> MAC Map
        - Pending Queue
        - Entry Timeout
      |
    }
    eth_hdr: {
      shape: sql_table
      label: "struct eth_hdr (ether.h)"
      f0: "0x00 | uint8_t[6] | dst_mac"
      f1: "0x06 | uint8_t[6] | src_mac"
      f2: "0x0C | uint16_t  | type"
      sz: "Size: 14 bytes"
    }
  }
}

# --- HARDWARE LAYER ---
row_hw: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  hw_interface: Interface {
    style: {
      fill: ${colors.wire}
      stroke: "#888888"
      stroke-width: 2
      stroke-dash: 3
    }
    tap_dev: {
      label: "TAP Device\n(/dev/net/tun)"
      icon: https://icons.terrastruct.com/tech/022-server.svg
      style.fill: "#FFFFFF"
    }
    dma_ring: {
      shape: cylinder
      label: "DMA RX/TX Ring"
      style.fill: "#E0E0E0"
    }
    phy_nic: {
      label: "NIC Hardware\n(MII Interface)"
      icon: https://icons.terrastruct.com/aws%2FNetworking%20&%20Content%20Delivery%2FAmazon-Route-53_Hosted-Zone_light-bg.svg
      style.fill: "#FFFFFF"
    }
  }
}

# --- DATA FLOW CONNECTIONS ---

# SEND PATH (Green)
row_app.app_layer -> row_tcp.tcp_layer: "byte stream | write" {
  style: {
    stroke: ${colors.send}
    stroke-width: 4
    animated: true
  }
}
row_tcp.tcp_layer -> row_ip.ip_layer: "TCP segment | ip_send" {
  style: {
    stroke: ${colors.send}
    stroke-width: 4
    animated: true
  }
}
row_ip.ip_layer -> row_l2.eth_layer: "IP packet | eth_send" {
  style: {
    stroke: ${colors.send}
    stroke-width: 4
    animated: true
  }
}
row_l2.eth_layer -> row_hw.hw_interface: "Eth Frame | write" {
  style: {
    stroke: ${colors.send}
    stroke-width: 4
    animated: true
  }
}

# RECEIVE PATH (Blue)
row_hw.hw_interface -> row_l2.eth_layer: "Raw Frame | poll" {
  style: {
    stroke: ${colors.recv}
    stroke-width: 4
    stroke-dash: 4
    animated: true
  }
}
row_l2.eth_layer -> row_ip.ip_layer: "IP packet | demux" {
  style: {
    stroke: ${colors.recv}
    stroke-width: 4
    stroke-dash: 4
    animated: true
  }
}
row_ip.ip_layer -> row_tcp.tcp_layer: "TCP segment | dispatch" {
  style: {
    stroke: ${colors.recv}
    stroke-width: 4
    stroke-dash: 4
    animated: true
  }
}
row_tcp.tcp_layer -> row_app.app_layer: "byte stream | recv" {
  style: {
    stroke: ${colors.recv}
    stroke-width: 4
    stroke-dash: 4
    animated: true
  }
}

# Annotations (Near Legend/Root)
flow_notes: {
  near: bottom-left
  send_box: |md
    **SEND PATH (L7 → L1)**
    1. Socket write buffers data
    2. TCP adds SEQ and window checks
    3. IP encapsulates and checks routes
    4. L2 resolves ARP and frames
    5. PHY DMA to hardware
  | {
    style: {
      fill: "#F0FFF0"
      stroke: ${colors.send}
    }
  }
  recv_box: |md
    **RECV PATH (L1 → L7)**
    1. Interrupt triggers ring buffer read
    2. L2 filters MAC and demuxes type
    3. IP validates checksum and TTL
    4. TCP reorders OOO segments
    5. App wakes on data availability
  | {
    style: {
      fill: "#F0F8FF"
      stroke: ${colors.recv}
    }
  }
}

legend: {
  near: bottom-right
  style: {
    fill: "#FFFFFF"
    stroke: "#CCCCCC"
    border-radius: 4
  }
  l1: "Green Arrow | Send Flow (TX)" {
    style.font-color: ${colors.send}
  }
  l2: "Blue Dashed | Recv Flow (RX)" {
    style.font-color: ${colors.recv}
  }
  l3: "Milestone Links | Detailed View" {
    style.font-color: "#888888"
  }
}