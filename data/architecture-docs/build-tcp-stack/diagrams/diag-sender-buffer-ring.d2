direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## TCP Send Buffer Ring Structure
  Circular buffer managing sent/unacknowledged/unsent data
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  buffer_state: {
    direction: down
    label: "Buffer State Legend"
    acked: {
      label: "ACKed Data"
      shape: rectangle
      width: 120
      height: 40
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    in_flight: {
      label: "In-Flight (Unacked)"
      shape: rectangle
      width: 120
      height: 40
      style.fill: "#FFD700"
      style.stroke: "#DAA520"
    }
    usable: {
      label: "Usable Space"
      shape: rectangle
      width: 120
      height: 40
      style.fill: "#87CEEB"
      style.stroke: "#4682B4"
    }
    empty: {
      label: "Empty (Buffer Tail)"
      shape: rectangle
      width: 120
      height: 40
      style.fill: "#E8E8E8"
      style.stroke: "#A0A0A0"
      style.stroke-dash: 3
    }
  }
  ring_buffer: {
    direction: down
    label: "Circular Ring Buffer (256KB typical)"
    width: 500
    ring: {
      shape: rectangle
      width: 480
      height: 200
      style.fill: transparent
      style.stroke: "#333"
      style.stroke-width: 2
      style.border-radius: 8
      # Linear representation of ring
      seg1: {
        posx: 0
        posy: 0
        shape: rectangle
        width: 100
        height: 60
        label: "ACKed\nBytes 0-99"
        style.fill: "#90EE90"
        style.stroke: "#228B22"
      }
      seg2: {
        posx: 105
        posy: 0
        shape: rectangle
        width: 140
        height: 60
        label: "In-Flight\nBytes 100-239"
        style.fill: "#FFD700"
        style.stroke: "#DAA520"
      }
      seg3: {
        posx: 250
        posy: 0
        shape: rectangle
        width: 80
        height: 60
        label: "Usable\nSpace"
        style.fill: "#87CEEB"
        style.stroke: "#4682B4"
      }
      seg4: {
        posx: 335
        posy: 0
        shape: rectangle
        width: 130
        height: 60
        label: "Empty\n(Buffer Tail)"
        style.fill: "#E8E8E8"
        style.stroke: "#A0A0A0"
        style.stroke-dash: 3
      }
    }
    # Pointer markers below ring
    pointers: {
      direction: right
      width: 480
      height: 80
      ptr_una: {
        shape: rectangle
        width: 100
        label: "SND.UNA\n(seq 100)"
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.font-color: white
        style.bold: true
      }
      ptr_nxt: {
        shape: rectangle
        width: 140
        label: "SND.NXT\n(seq 240)"
        style.fill: "#4ECDC4"
        style.stroke: "#008080"
        style.font-color: white
        style.bold: true
      }
      ptr_tail: {
        shape: rectangle
        width: 80
        label: "TAIL\n(seq 320)"
        style.fill: "#9B59B6"
        style.stroke: "#6C3483"
        style.font-color: white
        style.bold: true
      }
    }
  }
}
# Arrow from pointers to ring
ring_buffer.ring.seg2 -> ring_buffer.pointers.ptr_una: {
  style.stroke: "#CC0000"
  style.stroke-width: 2
}
ring_buffer.ring.seg3 -> ring_buffer.pointers.ptr_nxt: {
  style.stroke: "#008080"
  style.stroke-width: 2
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  calculations: {
    direction: down
    label: "Key Calculations (tcp_send_buf.h)"
    width: 280
    calc_table: {
      shape: sql_table
      label: "Buffer Metrics"
      f1: "0x00 | uint32_t | in_flight = SND.NXT - SND.UNA"
      f2: "0x04 | uint32_t | unsent = TAIL - SND.NXT"
      f3: "0x08 | uint32_t | usable_window = min(cwnd, rwnd) - in_flight"
      f4: "0x0C | uint32_t | buffer_space = BUF_SIZE - (TAIL - HEAD)"
      sz: "Ring wraps at seq % BUF_SIZE"
    }
  }
  retransmit: {
    direction: down
    label: "Retransmission on Timeout"
    width: 320
    retrans_box: {
      shape: rectangle
      width: 300
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
      style.border-radius: 6
      step1: {
        label: "1. RTO expires for oldest segment"
        shape: rectangle
        width: 280
        style.fill: transparent
      }
      step2: {
        label: "2. Read from SND.UNA offset"
        shape: rectangle
        width: 280
        style.fill: transparent
      }
      step3: {
        label: "3. Resend segment (up to MSS bytes)"
        shape: rectangle
        width: 280
        style.fill: transparent
      }
      step4: {
        label: "4. Exponential backoff RTO *= 2"
        shape: rectangle
        width: 280
        style.fill: transparent
      }
      step5: {
        label: "5. cwnd = 1 (reset congestion)"
        shape: rectangle
        width: 280
        style.fill: transparent
      }
    }
    code: |'c
      // Retransmit oldest unacked segment
      uint32_t seq = conn->vars.snd_una;
      const uint8_t *data = tcp_send_buf_peek(
          &conn->send_buf, seq, &avail);
      tcp_send_data_segment(conn, tap_fd, 
          seq, data, min(avail, mss));
    '|
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  window_check: {
    direction: down
    label: "Window Availability Check"
    width: 260
    check_code: |'c
      // Can we send more?
      uint32_t in_flight = snd_nxt - snd_una;
      uint32_t cwnd_bytes = cwnd * mss;
      uint32_t window = min(cwnd_bytes, rwnd);
      if (in_flight >= window) {
          return 0;  // Window full
      }
      return window - in_flight;
    '|
  }
  sliding: {
    direction: down
    label: "Window Slide on ACK"
    width: 280
    slide_code: |'c
      // New ACK arrives for seq 180
      // Before: SND.UNA = 100, SND.NXT = 240
      // After:  SND.UNA = 180, SND.NXT = 240
      void tcp_send_buf_ack(
          struct tcp_send_buf *buf, 
          uint32_t ack_num) 
      {
          uint32_t acked = ack_num - buf->head;
          buf->head = ack_num;  // Slide forward
          // ACKed bytes freed from buffer
      }
    '|
  }
}
# Legend note
note: {
  near: bottom-center
  label: |md
    **Pointer Semantics:**
    - **SND.UNA**: Oldest unacknowledged byte (buffer head)
    - **SND.NXT**: Next byte to send (may equal SND.UNA if nothing sent)
    - **TAIL**: End of queued data (application write pointer)
    - **In-flight**: SND.NXT - SND.UNA (bytes awaiting ACK)
    - **Unsent**: TAIL - SND.NXT (bytes queued but not transmitted)
  |
  shape: rectangle
  style.fill: "#F0F8FF"
  style.stroke: "#4682B4"
  width: 600
}