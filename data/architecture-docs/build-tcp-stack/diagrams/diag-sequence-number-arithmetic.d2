direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Modulo 2^32 Sequence Number Comparison (RFC 793 / 1323)"
  shape: rectangle
  style: {
    font-size: 32
    bold: true
    fill: "#f8f9fa"
    stroke-width: 0
  }
}

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  problem_container: "PROBLEM: Naive Linear Comparison" {
    direction: down
    style.fill: "#fff5f5"
    
    prob_code: {
      label: "Comparison Failure Case"
      width: 400
      code: |'c
        // 32-bit unsigned integers
        uint32_t seq = 0xFFFFFF00; // Near max (4.29B)
        uint32_t ack = 0x00000100; // Near zero (256)

        // NAIVE ATTEMPT:
        if (seq < ack) { 
            // Result: FALSE (4294967040 < 256 is false)
            // BUG: In circular space, seq is BEFORE ack!
        }
      '|
    }

    linear_view: {
      shape: sql_table
      label: "Linear Number Line View"
      r1: "Value | Decimal | Position"
      r2: "0x00000100 | 256 | Start of line"
      r3: "0xFFFFFF00 | 4,294,967,040 | End of line"
      note: "Result: 0x100 is numerically smaller"
    }
  }

  arrow_sep: "Comparison" {
    shape: parallelogram
    style.fill: transparent
  }

  solution_container: "SOLUTION: Two's Complement Subtraction" {
    direction: down
    style.fill: "#f4fff4"

    sol_code: {
      label: "Correct Sequence Logic"
      width: 400
      code: |'c
        // Standard TCP Comparison Macros
        #define SEQ_LT(a,b) ((int32_t)((a)-(b)) < 0)
        #define SEQ_LE(a,b) ((int32_t)((a)-(b)) <= 0)
        #define SEQ_GT(a,b) ((int32_t)((a)-(b)) > 0)
        #define SEQ_GE(a,b) ((int32_t)((a)-(b)) >= 0)

        // EVALUATION:
        // (0xFFFFFF00 - 0x00000100) = 0xFFFFFE00
        // (int32_t)0xFFFFFE00 = -512
        // -512 < 0 is TRUE -> seq is BEFORE ack
      '|
    }

    circular_logic: {
      shape: sql_table
      label: "Modular Arithmetic Result"
      r1: "Operation | Hex Result | Signed (int32_t)"
      r2: "seq - ack | 0xFFFFFE00 | -512 (LT)"
      r3: "ack - seq | 0x00000200 | +512 (GT)"
      note: "Distance is correct regardless of wraparound"
    }
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  visual_theory: "Modular Sequence Space" {
    direction: down
    
    clock_face: {
      shape: circle
      label: "2^32 Range"
      width: 250
      height: 250
      
      top_marker: "0x0" {
        style.stroke: transparent
      }
      bottom_marker: "0x80000000" {
        style.stroke: transparent
      }
    }

    quadrants: {
      shape: sql_table
      label: "Distance Thresholds"
      q1: "Distance (a-b) | Interpretation"
      q2: "0 to (2^31 - 1) | a is AFTER b (Positive)"
      q3: "2^31 to (2^32 - 1) | a is BEFORE b (Negative)"
      note: "Comparison valid for distances < 2^31"
    }
  }

  truth_table: "Macro Implementation Reference" {
    shape: sql_table
    label: "SEQ_ Comparison Logic Table"
    h: "Test Case | Macro | Result | Signed Diff"
    c1: "0xFFFFFF00, 0x100 | SEQ_LT | TRUE | -512"
    c2: "0xFFFFFF00, 0x100 | SEQ_GT | FALSE | -512"
    c3: "0x100, 0xFFFFFF00 | SEQ_GT | TRUE | +512"
    c4: "0x200, 0x100 | SEQ_GE | TRUE | +256"
    c5: "0x100, 0x100 | SEQ_LE | TRUE | 0"
    footer: "Arithmetic performed as uint32_t before cast"
  }
}

row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  tcp_window_example: "Practical Application: Receive Window" {
    direction: down
    code_block: {
      label: "Window Bound Check"
      width: 450
      code: |'c
        uint32_t rcv_nxt = 0xFFFFFF00; // Next byte expected
        uint32_t rcv_wnd = 0x00002000; // 8KB Window
        uint32_t seg_seq = 0x00000100; // Incoming segment

        // Is segment in window? [rcv_nxt, rcv_nxt + rcv_wnd)
        bool in_window = SEQ_GE(seg_seq, rcv_nxt) && 
                         SEQ_LT(seg_seq, rcv_nxt + rcv_wnd);

        // Evaluation:
        // SEQ_GE(0x100, 0xFFFFFF00) -> (int32_t)512 >= 0 (TRUE)
        // SEQ_LT(0x100, 0x000010FF) -> (int32_t)-4095 < 0 (TRUE)
      '|
    }
  }

  pitfalls: "Implementation Checklist" {
    shape: sql_table
    label: "Engineering Requirements"
    p1: "Category | Rule"
    p2: "Casting | Must cast to SIGNED 32-bit (int32_t)"
    p3: "Subtraction | Subtraction MUST occur before the cast"
    p4: "Range | Only valid if |a-b| < 2^31"
    p5: "Standard | Matches RFC 1323 PAWS checks"
    size: "Total Logic Size: 4 Macros"
  }
}

legend_box: {
  label: "Visualization Legend"
  direction: right
  pos: "Positive Diff" {
    style.fill: "#d0f0fd"
    label: "(a-b) > 0: a follows b"
  }
  neg: "Negative Diff" {
    style.fill: "#ffdada"
    label: "(a-b) < 0: a precedes b"
  }
}

legend_box.near: bottom-right

problem_container -> solution_container: "Apply Signed Subtraction" {
  style.stroke-width: 4
}