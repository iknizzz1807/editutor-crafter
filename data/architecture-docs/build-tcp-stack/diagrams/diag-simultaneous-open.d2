direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
header: {
  title: |md
    # TCP Simultaneous Open
    **Rare corner case where both peers initiate connections simultaneously**
  |
}

# --- MAIN DIAGRAM BODY ---
row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  host_a: {
    direction: down
    label: "Host A (Client A)"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"

    state_a0: "CLOSED" {
      shape: circle
      style.fill: "#FFE4B5"
      style.stroke: "#CD853F"
    }
    state_a1: "SYN_SENT" {
      shape: circle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    state_a2: "SYN_RECEIVED" {
      shape: diamond
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
    }
    state_a3: "ESTABLISHED" {
      shape: circle
      style.fill: "#32CD32"
      style.stroke: "#006400"
      style.bold: true
    }

    state_a0 -> state_a1: "connect()"
    state_a1 -> state_a2: "recv SYN"
    state_a2 -> state_a3: "recv ACK"
  }

  packets: {
    direction: down
    label: "Packet Exchange"
    style.fill: "#F5F5F5"
    style.stroke: "#D3D3D3"
    width: 350

    note_intro: "Both hosts send SYN simultaneously" {
      shape: parallelogram
      style.fill: "#FFFFFF"
    }

    syn_a: "① SYN (Host A)" {
      shape: parallelogram
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
    }
    syn_a_data: "seq=ISN_A, flags=SYN"

    syn_b: "② SYN (Host B)" {
      shape: parallelogram
      style.fill: "#ADD8E6"
      style.stroke: "#4169E1"
    }
    syn_b_data: "seq=ISN_B, flags=SYN"

    synack_a: "③ SYN-ACK (Host A)" {
      shape: parallelogram
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
    }
    synack_a_data: |'md
      seq=ISN_A, ack=ISN_B+1
      flags=SYN|ACK
    '|

    synack_b: "④ SYN-ACK (Host B)" {
      shape: parallelogram
      style.fill: "#ADD8E6"
      style.stroke: "#4169E1"
    }
    synack_b_data: |'md
      seq=ISN_B, ack=ISN_A+1
      flags=SYN|ACK
    '|
  }

  host_b: {
    direction: down
    label: "Host B (Client B)"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"

    state_b0: "CLOSED" {
      shape: circle
      style.fill: "#FFE4B5"
      style.stroke: "#CD853F"
    }
    state_b1: "SYN_SENT" {
      shape: circle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    state_b2: "SYN_RECEIVED" {
      shape: diamond
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
    }
    state_b3: "ESTABLISHED" {
      shape: circle
      style.fill: "#32CD32"
      style.stroke: "#006400"
      style.bold: true
    }

    state_b0 -> state_b1: "connect()"
    state_b1 -> state_b2: "recv SYN"
    state_b2 -> state_b3: "recv ACK"
  }
}

# --- FLOW CONNECTIONS ---
row_timeline.host_a.state_a1 -> row_timeline.packets.syn_a: "send"
row_timeline.packets.syn_a -> row_timeline.host_b.state_b2: "recv"

row_timeline.host_b.state_b1 -> row_timeline.packets.syn_b: "send"
row_timeline.packets.syn_b -> row_timeline.host_a.state_a2: "recv"

row_timeline.host_a.state_a2 -> row_timeline.packets.synack_a: "send"
row_timeline.packets.synack_a -> row_timeline.host_b.state_b3: "recv"

row_timeline.host_b.state_b2 -> row_timeline.packets.synack_b: "send"
row_timeline.packets.synack_b -> row_timeline.host_a.state_a3: "recv"

# --- FOOTER & IMPLEMENTATION ---
row_bottom: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  code_impl: {
    label: "RFC 793 Simultaneous Open Logic"
    width: 450
    code: |'c
      // In SYN_SENT state, receiving a SYN segment
      // causes transition to SYN_RECEIVED state.
      if (tcp_state == TCP_SYN_SENT && (seg->flags & SYN)) {
          conn->irs = seg->seq;
          conn->rcv_nxt = seg->seq + 1;
          tcp_set_state(conn, TCP_SYN_RECEIVED);
          tcp_send_synack(conn); // Send SYN+ACK
      }
    '|
  }

  legend_box: "Protocol Legend" {
    l1: "Normal Sent" { shape: circle; style.fill: "#90EE90" }
    l2: "Collision Detected" { shape: diamond; style.fill: "#FFD700" }
    l3: "Final State" { shape: circle; style.fill: "#32CD32" }
  }
}

note_rare: {
  near: bottom-center
  shape: callout
  label: "Simultaneous open is rare but required for RFC compliance."
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
}