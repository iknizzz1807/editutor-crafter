direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Effective Window Calculation
  **Formula:** `EffectiveWindow = min(cwnd, rwnd) - (SND.NXT - SND.UNA)`
| {near: top-center}
row_constraints: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cwnd_box: {
    direction: down
    label: "Congestion Window (cwnd)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    cwnd_label: |md
      **Network-imposed limit**
      Based on estimated network capacity
    |
    cwnd_value: {
      label: "64 KB"
      shape: rectangle
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      style.bold: true
      style.font-size: 28
      width: 120
    }
    cwnd_desc: |md
      Grows via slow start and congestion avoidance.
      Reduces on packet loss (congestion signal).
    |
  }
  rwnd_box: {
    direction: down
    label: "Receiver Window (rwnd)"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    rwnd_label: |md
      **Receiver buffer limit**
      Advertised in every ACK segment
    |
    rwnd_value: {
      label: "32 KB"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      style.bold: true
      style.font-size: 28
      width: 120
    }
    rwnd_desc: |md
      Receiver's available buffer space.
      Prevents sender from overwhelming receiver.
    |
  }
}
row_min: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  min_func: {
    direction: down
    label: "min(cwnd, rwnd)"
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
    min_calc: {
      label: "min(64 KB, 32 KB)"
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
    }
    min_result: {
      label: "= 32 KB"
      shape: rectangle
      style.fill: "#FFCC80"
      style.stroke: "#F57C00"
      style.bold: true
      style.font-size: 24
    }
  }
  constraint_label: |md
    ### The Stricter Limit Wins
    Sender cannot exceed either constraint.
    Network congestion OR buffer overflow will result.
  | {width: 280}
}
row_inflight: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  inflight_box: {
    direction: down
    label: "Bytes In Flight"
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    inflight_formula: |md
      **SND.NXT - SND.UNA**
      *(Sent but not yet acknowledged)*
    |
    inflight_value: {
      label: "8 KB"
      shape: rectangle
      style.fill: "#F8BBD9"
      style.stroke: "#C2185B"
      style.bold: true
      style.font-size: 24
      width: 120
    }
    inflight_desc: |md
      These bytes are already on the wire,
      consuming window space.
    |
  }
}
row_calculation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  calc_box: {
    direction: down
    label: "Final Calculation"
    style.fill: "#EDE7F6"
    style.stroke: "#7B1FA2"
    step1: {
      label: "min(cwnd, rwnd) = 32 KB"
      shape: rectangle
      style.fill: "#D1C4E9"
    }
    minus: {
      label: "−"
      shape: text
      style.font-size: 32
    }
    step2: {
      label: "In Flight = 8 KB"
      shape: rectangle
      style.fill: "#F8BBD9"
      style.stroke: "#C2185B"
    }
    equals: {
      label: "="
      shape: text
      style.font-size: 32
    }
    result: {
      label: "24 KB Available"
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
      style.font-size: 28
      width: 200
    }
  }
}
sequence_space: {
  label: "Sequence Number Space View"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  explanation: |md
    **How the window slides through sequence space:**
    - **SND.UNA** = Oldest unacknowledged byte (window left edge)
    - **SND.NXT** = Next byte to send (in-flight right edge)  
    - **Window Limit** = SND.UNA + min(cwnd, rwnd)
    - **Usable Window** = Window Limit - SND.NXT
  | {width: 700}
  bar: {
    direction: right
    acked: {
      label: "ACKed\n(Done)"
      shape: rectangle
      width: 150
      style.fill: "#81C784"
      style.stroke: "#388E3C"
    }
    inflight_bar: {
      label: "In Flight\n(8 KB)"
      shape: rectangle
      width: 100
      style.fill: "#F8BBD9"
      style.stroke: "#C2185B"
    }
    usable_bar: {
      label: "Usable\n(24 KB)"
      shape: rectangle
      width: 250
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
    }
    blocked_bar: {
      label: "Window\nLimit"
      shape: rectangle
      width: 100
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.stroke-dash: 4
    }
  }
  pointers: {
    direction: right
    width: 600
    una_ptr: {
      label: "SND.UNA ↑"
      shape: text
      style.font-color: "#C2185B"
      style.bold: true
    }
    nxt_ptr: {
      label: "SND.NXT ↑"
      shape: text
      style.font-color: "#1976D2"
      style.bold: true
    }
    limit_ptr: {
      label: "Window Limit ↑"
      shape: text
      style.font-color: "#388E3C"
      style.bold: true
    }
  }
}
cwnd_box -> min_func: "cwnd"
rwnd_box -> min_func: "rwnd"
min_func -> calc_box: "min"
inflight_box -> calc_box: "in flight"
legend: {
  near: bottom-center
  direction: right
  leg1: {
    label: "cwnd"
    shape: rectangle
    width: 60
    style.fill: "#BBDEFB"
  }
  leg2: {
    label: "rwnd"
    shape: rectangle
    width: 60
    style.fill: "#C8E6C9"
  }
  leg3: {
    label: "In Flight"
    shape: rectangle
    width: 60
    style.fill: "#F8BBD9"
  }
  leg4: {
    label: "Usable"
    shape: rectangle
    width: 60
    style.fill: "#4CAF50"
    style.font-color: white
  }
}