direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Sliding Window Protocol
  Window slides right as ACKs arrive
| {near: top-center}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_state: {
    direction: down
    label: "Before: Window at position 0"
    stream_before: {
      direction: right
      label: ""
      acked_before: {
        label: "Sent & ACKed"
        width: 120
        height: 60
        style.fill: "#90EE90"
        style.stroke: "#228B22"
      }
      inflight_before: {
        label: "In Flight\n(Sent, not ACKed)"
        width: 160
        height: 60
        style.fill: "#FFD700"
        style.stroke: "#DAA520"
      }
      usable_before: {
        label: "Usable\nWindow"
        width: 120
        height: 60
        style.fill: "#87CEEB"
        style.stroke: "#4682B4"
      }
      blocked_before: {
        label: "Cannot Send Yet"
        width: 200
        height: 60
        style.fill: "#D3D3D3"
        style.stroke: "#A9A9A9"
      }
    }
    window_frame_before: {
      label: "Window = min(cwnd, rwnd)"
      width: 300
      height: 20
      style.fill: "#FF6B6B"
      style.stroke: "#CC0000"
      style.font-color: white
      style.bold: true
    }
    vars_before: {
      direction: right
      label: ""
      style.fill: transparent
      style.stroke: transparent
      var_una_before: {
        label: "SND.UNA = 0\n(oldest unacked)"
        shape: rectangle
        style.fill: "#FFFACD"
        style.stroke: "#DAA520"
      }
      var_nxt_before: {
        label: "SND.NXT = 2920\n(next to send)"
        shape: rectangle
        style.fill: "#E0FFFF"
        style.stroke: "#4682B4"
      }
      var_wnd_before: {
        label: "SND.WND = 4380\n(receiver window)"
        shape: rectangle
        style.fill: "#FFE4E1"
        style.stroke: "#DC143C"
      }
    }
  }
}
row_arrow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arrow_container: {
    width: 600
    height: 80
    label: ""
    style.fill: transparent
    style.stroke: transparent
    ack_arrow: {
      label: "ACK 1460 arrives\n(Window slides →)"
      shape: rectangle
      width: 200
      style.fill: "#98FB98"
      style.stroke: "#228B22"
      style.bold: true
    }
    flow_arrow: {
      label: ""
      width: 100
      style.fill: transparent
      style.stroke: transparent
    }
  }
}
ack_arrow -> flow_arrow: "ACK confirms\nbytes 0-1459" {
  style.stroke: "#228B22"
  style.stroke-width: 3
  style.animated: true
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after_state: {
    direction: down
    label: "After: Window slid right by 1460 bytes"
    stream_after: {
      direction: right
      label: ""
      acked_after: {
        label: "Sent & ACKed"
        width: 200
        height: 60
        style.fill: "#90EE90"
        style.stroke: "#228B22"
      }
      inflight_after: {
        label: "In Flight\n(Sent, not ACKed)"
        width: 160
        height: 60
        style.fill: "#FFD700"
        style.stroke: "#DAA520"
      }
      usable_after: {
        label: "Usable\nWindow"
        width: 120
        height: 60
        style.fill: "#87CEEB"
        style.stroke: "#4682B4"
      }
      blocked_after: {
        label: "Cannot Send Yet"
        width: 120
        height: 60
        style.fill: "#D3D3D3"
        style.stroke: "#A9A9A9"
      }
    }
    window_frame_after: {
      label: "Window = min(cwnd, rwnd)"
      width: 300
      height: 20
      style.fill: "#FF6B6B"
      style.stroke: "#CC0000"
      style.font-color: white
      style.bold: true
    }
    vars_after: {
      direction: right
      label: ""
      style.fill: transparent
      style.stroke: transparent
      var_una_after: {
        label: "SND.UNA = 1460\n(advanced!)"
        shape: rectangle
        style.fill: "#90EE90"
        style.stroke: "#228B22"
        style.bold: true
      }
      var_nxt_after: {
        label: "SND.NXT = 4380\n(can send more!)"
        shape: rectangle
        style.fill: "#E0FFFF"
        style.stroke: "#4682B4"
      }
      var_wnd_after: {
        label: "SND.WND = 4380\n(unchanged)"
        shape: rectangle
        style.fill: "#FFE4E1"
        style.stroke: "#DC143C"
      }
    }
  }
}
before_state -> after_state: " " {
  style.stroke: transparent
}
legend: {
  near: bottom-center
  direction: right
  label: ""
  style.fill: transparent
  style.stroke: transparent
  leg_acked: {
    label: "Sent & ACKed"
    width: 100
    height: 30
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  leg_inflight: {
    label: "In Flight"
    width: 100
    height: 30
    style.fill: "#FFD700"
    style.stroke: "#DAA520"
  }
  leg_usable: {
    label: "Usable"
    width: 100
    height: 30
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
  }
  leg_blocked: {
    label: "Blocked"
    width: 100
    height: 30
    style.fill: "#D3D3D3"
    style.stroke: "#A9A9A9"
  }
}
key_insight: {
  near: bottom-center
  label: |md
    **Key Insight:** Usable window = min(cwnd, rwnd) - (SND.NXT - SND.UNA)
    When ACK arrives:
    1. SND.UNA advances (bytes removed from "in flight")
    2. Window effectively slides right
    3. More data becomes "usable" for sending
  |
  shape: rectangle
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
  width: 500
}
byte_scale: {
  near: top-right
  label: "Byte Sequence Numbers (mod 2³²)"
  shape: rectangle
  width: 180
  scale: {
    shape: sql_table
    label: "Window Variables"
    row0: "0x000 | SND.UNA | oldest unacked"
    row1: "0x5B8 | SND.NXT | next to send"
    row2: "0x000 | SND.WND | recv window"
    row3: "0x5B8 | in_flight | NXT - UNA"
    row4: "0x000 | usable | WND - in_flight"
  }
}