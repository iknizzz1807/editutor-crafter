direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Slow Start vs Congestion Avoidance {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  slow_start: {
    direction: down
    label: "SLOW START PHASE\n(cwnd < ssthresh)"
    growth: {
      label: "Exponential Growth"
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      width: 400
      formula: {
        label: "cwnd += MSS per ACK received"
        shape: text
        style: {
          font-size: 16
          bold: true
          font-color: "#1B5E20"
        }
      }
      behavior: {
        label: "Each ACK → cwnd increases by 1 MSS"
        shape: text
        style.font-size: 14
      }
      behavior2: {
        label: "Result: cwnd DOUBLES every RTT"
        shape: text
        style: {
          font-size: 14
          bold: true
        }
      }
    }
    timeline: {
      label: "Growth Timeline (per RTT)"
      style.fill: "#C8E6C9"
      width: 400
      rtts: {
        shape: sql_table
        label: "cwnd Evolution"
        rt0: "RTT 0 | 1 MSS   | Initial"
        rt1: "RTT 1 | 2 MSS   | Doubled"
        rt2: "RTT 2 | 4 MSS   | Doubled"
        rt3: "RTT 3 | 8 MSS   | Doubled"
        rt4: "RTT 4 | 16 MSS  | Doubled"
        rt5: "RTT 5 | 32 MSS  | Approaching ssthresh"
      }
    }
    visual: {
      label: "Why 'Slow' Start is Actually FAST"
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
      width: 400
      explanation: {
        shape: text
        label: |md
          **Misleading Name!** "Slow" compared to:
          - Starting at full receiver window
          **Reality:** Exponential ramp:
          - 1 → 2 → 4 → 8 → 16 → 32 MSS
          - Reaches 32 MSS in just 5 RTTs
          - At 100ms RTT: 500ms to full speed
        |
      }
    }
  }
  cong_avoid: {
    direction: down
    label: "CONGESTION AVOIDANCE PHASE\n(cwnd >= ssthresh)"
    growth: {
      label: "Linear Growth"
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      width: 400
      formula: {
        label: "cwnd += MSS × MSS / cwnd per ACK"
        shape: text
        style: {
          font-size: 16
          bold: true
          font-color: "#BF360C"
        }
      }
      behavior: {
        label: "Each ACK → cwnd increases fractionally"
        shape: text
        style.font-size: 14
      }
      behavior2: {
        label: "Result: cwnd +~1 MSS per RTT (linear)"
        shape: text
        style: {
          font-size: 14
          bold: true
        }
      }
    }
    timeline: {
      label: "Growth Timeline (per RTT)"
      style.fill: "#FFE0B2"
      width: 400
      rtts: {
        shape: sql_table
        label: "cwnd Evolution (from ssthresh=32)"
        rt0: "RTT 0 | 32 MSS  | At ssthresh"
        rt1: "RTT 1 | 33 MSS  | +1 MSS"
        rt2: "RTT 2 | 34 MSS  | +1 MSS"
        rt3: "RTT 3 | 35 MSS  | +1 MSS"
        rt4: "RTT 4 | 36 MSS  | +1 MSS"
        rt5: "RTT 5 | 37 MSS  | +1 MSS"
      }
    }
    visual: {
      label: "Conservative Probing"
      style.fill: "#FFCC80"
      style.stroke: "#E65100"
      width: 400
      explanation: {
        shape: text
        label: |md
          **Caution Zone:** Network capacity unknown
          **Behavior:** Gentle probing:
          - Increase slowly to detect congestion
          - React quickly to packet loss
          - Prevents oscillation at capacity edge
          **Safety:** Small increases = small backs-off
        |
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  comparison: {
    direction: down
    label: "Side-by-Side Comparison"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    width: 820
    table: {
      shape: sql_table
      label: "Algorithm Comparison (RFC 5681)"
      aspect: "Aspect | Slow Start | Congestion Avoidance"
      condition: "Condition | cwnd < ssthresh | cwnd >= ssthresh"
      formula: "Per-ACK Formula | cwnd += MSS | cwnd += MSS²/cwnd"
      growth: "Growth Type | Exponential | Linear"
      rate: "Growth Rate | ~2× per RTT | ~+1 MSS per RTT"
      goal: "Goal | Fast ramp-up | Gentle probing"
      risk: "Risk | Overshoot capacity | Under-utilization"
      time_10: "Time 1→10 MSS | 4 RTTs | 9 RTTs"
      time_100: "Time 1→100 MSS | 7 RTTs | 99 RTTs"
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  state_machine: {
    direction: down
    label: "Phase Transition Logic"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 820
    code: {
      label: "Congestion Control State Machine (tcp_congestion.c)"
      width: 780
      logic: |'c
        void tcp_congestion_on_ack(struct tcp_conn *conn) {
            struct tcp_congestion *cc = &conn->congestion;
            if (cc->recovery_mode) return;  // Don't grow in recovery
            if (cc->cwnd < cc->ssthresh) {
                // SLOW START: Exponential growth
                cc->cwnd += 1;  // +1 MSS per ACK
            } else {
                // CONGESTION AVOIDANCE: Linear growth
                cc->cwnd += (MSS * MSS) / cc->cwnd;
            }
        }
        void tcp_congestion_on_loss(struct tcp_conn *conn) {
            // Packet loss detected
            cc->ssthresh = cc->cwnd / 2;  // Cut threshold
            cc->cwnd = 1;                 // Reset to slow start
        }
      '|
    }
    transition: {
      label: "Phase Transitions"
      t1: {
        label: "SLOW START → CONGESTION AVOIDANCE"
        shape: text
        style.font-size: 14
      }
      t1_trigger: {
        label: "Trigger: cwnd reaches ssthresh"
        shape: text
        style: {
          font-color: "#1565C0"
          italic: true
        }
      }
      t2: {
        label: "ANY → SLOW START (reset)"
        shape: text
        style.font-size: 14
      }
      t2_trigger: {
        label: "Trigger: Timeout (severe congestion)"
        shape: text
        style: {
          font-color: "#C62828"
          italic: true
        }
      }
      t3: {
        label: "ANY → FAST RECOVERY"
        shape: text
        style.font-size: 14
      }
      t3_trigger: {
        label: "Trigger: 3× duplicate ACKs (moderate loss)"
        shape: text
        style: {
          font-color: "#F57C00"
          italic: true
        }
      }
    }
  }
}
legend: {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    border-radius: 8
  }
  label: "Key Insight: 'Slow Start' is a historical misnomer. Compared to sending at full receiver window immediately, it's 'slow'. But exponential growth is actually very fast for safely discovering available bandwidth."
  legend_text: {
    shape: text
    label: |md
      **MSS** = Maximum Segment Size (typically 1460 bytes)
      **RTT** = Round-Trip Time
      **ssthresh** = Slow Start Threshold (dynamically adjusted)
      **cwnd** = Congestion Window (in MSS units)
    |
  }
}
slow_start -> cong_avoid: "cwnd >= ssthresh" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    animated: true
  }
}
cong_avoid -> slow_start: "Loss detected\n(timeout)" {
  style: {
    stroke: "#C62828"
    stroke-dash: 5
    stroke-width: 2
  }
}