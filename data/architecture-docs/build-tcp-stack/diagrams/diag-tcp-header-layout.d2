direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # TCP Segment Header Layout (RFC 793)
    **Minimum Header: 20 bytes | Maximum Header: 60 bytes**
  '|
}
title.near: top-center

row_top: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  header_layout: {
    shape: sql_table
    label: "struct tcp_hdr (tcp.h)"
    row0: "0x00-0x01 | uint16_t  | src_port"
    row1: "0x02-0x03 | uint16_t  | dst_port"
    row2: "0x04-0x07 | uint32_t  | seq_num"
    row3: "0x08-0x0B | uint32_t  | ack_num"
    row4: "0x0C      | uint4_t   | data_offset (header units)"
    row5: "0x0C      | uint6_t   | reserved (zero)"
    row6: "0x0D      | uint8_t   | flags (9 bits used)"
    row7: "0x0E-0x0F | uint16_t  | window (rcv_wnd)"
    row8: "0x10-0x11 | uint16_t  | checksum (pseudo-hdr)"
    row9: "0x12-0x13 | uint16_t  | urgent_ptr"
    row10: "0x14+     | uint8_t[] | options (if doff > 5)"
    total: "Total Size: 20-60 bytes"
  }

  byte_grid: {
    label: "Memory Map (20-byte min)"
    direction: right
    style.stroke-dash: 3
    
    col0: {
      direction: down
      style.stroke: transparent
      b0: "0" {shape: square; width: 40; style.fill: "#E8E8E8"}
      b1: "1" {shape: square; width: 40; style.fill: "#E8E8E8"}
      b2: "2" {shape: square; width: 40; style.fill: "#E8E8E8"}
      b3: "3" {shape: square; width: 40; style.fill: "#E8E8E8"}
      b4: "4" {shape: square; width: 40; style.fill: "#D4E6F1"}
      b5: "5" {shape: square; width: 40; style.fill: "#D4E6F1"}
      b6: "6" {shape: square; width: 40; style.fill: "#D4E6F1"}
      b7: "7" {shape: square; width: 40; style.fill: "#D4E6F1"}
      b8: "8" {shape: square; width: 40; style.fill: "#D5F5E3"}
      b9: "9" {shape: square; width: 40; style.fill: "#D5F5E3"}
      b10: "10" {shape: square; width: 40; style.fill: "#D5F5E3"}
      b11: "11" {shape: square; width: 40; style.fill: "#D5F5E3"}
      b12: "12" {shape: square; width: 40; style.fill: "#FCF3CF"}
      b13: "13" {shape: square; width: 40; style.fill: "#FCF3CF"}
      b14: "14" {shape: square; width: 40; style.fill: "#FADBD8"}
      b15: "15" {shape: square; width: 40; style.fill: "#FADBD8"}
      b16: "16" {shape: square; width: 40; style.fill: "#E8DAEF"}
      b17: "17" {shape: square; width: 40; style.fill: "#E8DAEF"}
      b18: "18" {shape: square; width: 40; style.fill: "#AED6F1"}
      b19: "19" {shape: square; width: 40; style.fill: "#AED6F1"}
      b20: "etc" {shape: square; width: 40; style.fill: "#F5B7B1"; style.stroke-dash: 3}
    }
    col1: {
      direction: down
      style.stroke: transparent
      f0: "Source Port" {width: 150; style.fill: "#E8E8E8"}
      f1: "Source Port (L)" {width: 150; style.fill: "#E8E8E8"}
      f2: "Dest Port" {width: 150; style.fill: "#E8E8E8"}
      f3: "Dest Port (L)" {width: 150; style.fill: "#E8E8E8"}
      f4: "Sequence No" {width: 150; style.fill: "#D4E6F1"}
      f5: "Sequence No" {width: 150; style.fill: "#D4E6F1"}
      f6: "Sequence No" {width: 150; style.fill: "#D4E6F1"}
      f7: "Sequence No" {width: 150; style.fill: "#D4E6F1"}
      f8: "Ack No" {width: 150; style.fill: "#D5F5E3"}
      f9: "Ack No" {width: 150; style.fill: "#D5F5E3"}
      f10: "Ack No" {width: 150; style.fill: "#D5F5E3"}
      f11: "Ack No" {width: 150; style.fill: "#D5F5E3"}
      f12: "Off|Res|NS" {width: 150; style.fill: "#FCF3CF"}
      f13: "Flags (C-F)" {width: 150; style.fill: "#FCF3CF"}
      f14: "Window Size" {width: 150; style.fill: "#FADBD8"}
      f15: "Window Size" {width: 150; style.fill: "#FADBD8"}
      f16: "Checksum" {width: 150; style.fill: "#E8DAEF"}
      f17: "Checksum" {width: 150; style.fill: "#E8DAEF"}
      f18: "Urgent Ptr" {width: 150; style.fill: "#AED6F1"}
      f19: "Urgent Ptr" {width: 150; style.fill: "#AED6F1"}
      f20: "Options" {width: 150; style.fill: "#F5B7B1"; style.stroke-dash: 3}
    }
  }
}

bit_detail: {
  label: "Byte 12-13 Bit Layout (16 bits)"
  bit_row1: {
    direction: right
    style.stroke: transparent
    doff: "Data Offset (4b)" {width: 100; style.fill: "#85C1E9"}
    res: "Reserved (3b)" {width: 80; style.fill: "#ABEBC6"}
    ns: "NS" {width: 40; style.fill: "#F9E79F"}
    cwr: "CWR" {width: 40; style.fill: "#F9E79F"}
    ece: "ECE" {width: 40; style.fill: "#F9E79F"}
    urg: "URG" {width: 40; style.fill: "#F9E79F"}
    ack: "ACK" {width: 40; style.fill: "#F1948A"}
    psh: "PSH" {width: 40; style.fill: "#F1948A"}
    rst: "RST" {width: 40; style.fill: "#F1948A"}
    syn: "SYN" {width: 40; style.fill: "#BB8FCE"}
    fin: "FIN" {width: 40; style.fill: "#BB8FCE"}
  }
}

row_bottom: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  flags_legend: {
    shape: sql_table
    label: "TCP Flags (RFC 3168, RFC 3540)"
    f_syn: "SYN (0x02) | Synchronize sequence numbers"
    f_ack: "ACK (0x10) | Acknowledgment field significant"
    f_fin: "FIN (0x01) | No more data from sender"
    f_rst: "RST (0x04) | Reset connection"
    f_psh: "PSH (0x08) | Push function (deliver now)"
    f_urg: "URG (0x20) | Urgent pointer significant"
    f_ece: "ECE (0x40) | ECN-Echo (congestion feedback)"
    f_cwr: "CWR (0x80) | Congestion Window Reduced"
    f_ns: "NS  (0x100) | ECN-nonce (concealment sum)"
  }

  options_section: {
    shape: sql_table
    label: "Common TCP Options (RFC 793, RFC 1323)"
    opt_eol: "0 | EOL     | End of option list"
    opt_nop: "1 | NOP     | No operation (padding)"
    opt_mss: "2 | MSS     | Maximum Segment Size (4 bytes)"
    opt_ws: "3 | WS      | Window Scale (3 bytes)"
    opt_sok: "4 | SACKOK  | SACK Permitted (2 bytes)"
    opt_ts: "8 | TS      | Timestamps (10 bytes)"
    note: "Options padded to 4-byte boundary"
  }
}

data_offset_calc: {
  label: "Implementation Logic: Header Length"
  code: |'c
    // data_offset defines header size in 32-bit units
    uint8_t doff = (tcp_hdr[12] >> 4) & 0x0F;
    size_t header_len = doff * 4;
    
    if (doff < 5) return ERR_INVALID_HDR; // Min 20B
    uint8_t *payload = (uint8_t*)tcp_hdr + header_len;
    size_t options_len = (doff - 5) * 4;
  '|
  width: 450
}

legend_box: {
  direction: right
  style.stroke: transparent
  l1: "Port" {shape: square; width: 60; style.fill: "#E8E8E8"}
  l2: "Seq" {shape: square; width: 60; style.fill: "#D4E6F1"}
  l3: "Ack" {shape: square; width: 60; style.fill: "#D5F5E3"}
  l4: "Flags" {shape: square; width: 60; style.fill: "#FCF3CF"}
  l5: "Window" {shape: square; width: 60; style.fill: "#FADBD8"}
  l6: "Csum" {shape: square; width: 60; style.fill: "#E8DAEF"}
  l7: "Urg" {shape: square; width: 60; style.fill: "#AED6F1"}
}
legend_box.near: bottom-right

header_layout -> byte_grid: "uint8_t[] | map"
byte_grid -> bit_detail: "byte[12-13] | zoom"
bit_detail -> row_bottom: "uint16_t | parse"
row_bottom -> data_offset_calc: "doff | calculate"