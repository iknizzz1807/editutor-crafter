direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "TCP Options Parsing Logic (RFC 793)" {
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_input: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  input_buffer: {
    label: "Input: TCP Options Buffer"
    width: 500
    code: |'c
      uint8_t *opts;      // Pointer to options start
      size_t opts_len;    // Total options length
      size_t i = 0;       // Current position
    '|
  }
}
row_loop: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  loop_start: {
    shape: diamond
    label: "i < opts_len?"
    width: 160
  }
  read_kind: {
    label: "Read Kind Byte"
    width: 280
    code: |'c
      uint8_t kind = opts[i];
      // Kind determines option type
    '|
  }
}
row_kind_dispatch: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  kind_check: {
    shape: diamond
    label: "Kind < 2?"
    width: 140
  }
  handle_special: {
    label: "Special Single-Byte Options"
    width: 320
    code: |'c
      if (kind == 0) {       // EOL
          break;  // End of options
      }
      if (kind == 1) {       // NOP
          i++;  // Skip padding byte
          continue;
      }
    '|
  }
}
row_length: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  read_length: {
    label: "Read Length Byte"
    width: 300
    code: |'c
      if (i + 1 >= opts_len) break;
      uint8_t opt_len = opts[i + 1];
      if (opt_len < 2) break;  // Malformed
    '|
  }
  extract_value: {
    label: "Extract Value Bytes"
    width: 300
    code: |'c
      // Value starts at opts[i+2]
      // Value length = opt_len - 2
      uint8_t *value = &opts[i+2];
      size_t value_len = opt_len - 2;
    '|
  }
}
row_advance: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  process_option: {
    shape: diamond
    label: "Process by Kind"
    width: 160
  }
  advance: {
    label: "Advance to Next Option"
    width: 280
    code: |'c
      i += opt_len;  // Skip entire option
      // Loop continues
    '|
  }
}
row_options_table: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  options_table: {
    shape: sql_table
    label: "Common TCP Options (options_table.h)"
    col1: "Kind | Length | Name | Value Format"
    eol: "0    | —      | End of Option List | None (single byte)"
    nop: "1    | —      | No Operation      | None (padding)"
    mss: "2    | 4      | Max Segment Size  | uint16_t (bytes)"
    ws: "3    | 3      | Window Scale      | uint8_t (shift count)"
    sackok: "4    | 2      | SACK Permitted    | None"
    sack: "5    | 8-40   | SACK              | N × (uint32_t, uint32_t)"
    ts: "8    | 10     | Timestamp         | uint32_t ts_val, uint32_t ts_ecr"
    note: "Length includes Kind + Length + Value bytes"
  }
  parsing_result: {
    shape: class
    label: "struct tcp_parse_result"
    +mss: "uint16_t"
    +window_scale: "uint8_t"
    +sack_ok: "int"
    +ts_val: "uint32_t"
    +ts_ecr: "uint32_t"
  }
}
row_examples: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  example_syn: {
    label: "Example: SYN Segment Options"
    width: 520
    code: |'c
      // Typical SYN options (12 bytes total, header padded to 32 bytes)
      uint8_t syn_opts[] = {
          0x02, 0x04, 0x05, 0xB4,  // MSS = 1460
          0x03, 0x03, 0x07,        // Window Scale = 7
          0x04, 0x02,              // SACK Permitted
          0x01, 0x01, 0x01, 0x01   // NOP padding to 4-byte boundary
      };
    '|
  }
}
row_validation: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  validation_checks: {
    shape: class
    label: "Validation Checks (tcp_parse_options)"
    -check_length_bounds: "void"
    -check_mss_range: "void"
    -check_ws_range: "void"
    -check_duplicate_opts: "void"
    +validate_opts(opts, len): "int"
  }
  validation_code: {
    label: "Validation Logic"
    width: 400
    code: |'c
      // 1. Length must not exceed remaining buffer
      if (i + opt_len > opts_len) return -1;
      // 2. MSS must be reasonable (536-65535)
      if (kind == 2 && value_len == 2) {
          uint16_t mss = (value[0] << 8) | value[1];
          if (mss < 536) mss = 536;  // RFC 879 min
      }
      // 3. Window Scale must be 0-14
      if (kind == 3 && value_len == 1) {
          if (value[0] > 14) return -1;
      }
    '|
  }
}
error_paths: {
  label: "Error Handling Paths"
  width: 480
  style: {
    stroke: "#FF6B6B"
    stroke-dash: 4
  }
  code: |'c
    // Malformed options handling
    if (opt_len < 2) {
        // Length byte too small, cannot continue parsing
        // Options may be corrupted, stop parsing
        return -1;
    }
    if (i + opt_len > opts_len) {
        // Option extends beyond buffer boundary
        // Truncated option, stop parsing
        return -1;
    }
    if (opt_len > opts_len - i) {
        // Not enough bytes remaining for this option
        // Malformed, abort
        return -1;
    }
  '|
}
loop_back: {
  shape: circle
  label: "Loop"
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
  }
}
exit_done: {
  shape: oval
  label: "Done\n(All options parsed)"
  style: {
    fill: "#C8E6C9"
    stroke: "#4CAF50"
  }
}
exit_error: {
  shape: oval
  label: "Error\n(Malformed options)"
  style: {
    fill: "#FFCDD2"
    stroke: "#F44336"
  }
}
exit_eol: {
  shape: oval
  label: "EOL\n(End of List)"
  style: {
    fill: "#FFF9C4"
    stroke: "#FFC107"
  }
}
row_input -> row_loop
loop_start -> read_kind: "yes"
read_kind -> kind_check
kind_check -> handle_special: "yes"
kind_check -> read_length: "no"
handle_special -> exit_eol: "kind == 0\n(EOL)"
handle_special -> loop_back: "kind == 1\n(NOP)"
read_length -> extract_value
extract_value -> process_option
process_option -> advance
advance -> loop_back
loop_back -> loop_start
loop_start -> exit_done: "no\n(buffer exhausted)"
error_paths -> exit_error: "opt_len < 2 ||\ni + opt_len > opts_len"
row_options_table -> parsing_result: "populate"
row_examples -> row_validation
validation_checks -> validation_code
options_table: {
  style: {
    fill: "#F5F5F5"
  }
}
parsing_result: {
  style: {
    fill: "#E3F2FD"
  }
}
legend: {
  near: bottom-center
  style.fill: transparent
  key1: "Kind=0 (EOL): Single byte, terminates parsing" {
    shape: rectangle
    style: {
      fill: "#FFF9C4"
      stroke: "#FFC107"
    }
  }
  key2: "Kind=1 (NOP): Single byte padding, skip and continue" {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  key3: "Kind≥2: Multi-byte (Kind, Length, Value)" {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
    }
  }
}