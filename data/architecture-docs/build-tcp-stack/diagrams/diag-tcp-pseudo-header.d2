direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Pseudo-Header for Checksum Calculation
  ### RFC 793 / RFC 1071 — Breaking Layer Boundaries
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pseudo_header: {
    direction: down
    label: "Pseudo-Header (12 bytes)"
    style.fill: "#E8D5F0"
    style.stroke: "#7B4B94"
    style.stroke-width: 2
    src_ip: {
      shape: sql_table
      label: "Source IP Address"
      f0: "0x00 | uint32_t | src_ip"
      f1: "0x04 | — | from IP header"
      sz: "4 bytes"
    }
    dst_ip: {
      shape: sql_table
      label: "Destination IP Address"
      f0: "0x00 | uint32_t | dst_ip"
      f1: "0x04 | — | from IP header"
      sz: "4 bytes"
    }
    zero_proto: {
      shape: sql_table
      label: "Zero + Protocol"
      f0: "0x00 | uint8_t  | zero"
      f1: "0x01 | uint8_t  | protocol"
      f2: "0x01 | —       | = 6 (TCP)"
      sz: "2 bytes"
    }
    tcp_len: {
      shape: sql_table
      label: "TCP Segment Length"
      f0: "0x00 | uint16_t | tcp_len"
      f1: "0x02 | —       | header + data"
      sz: "2 bytes"
    }
  }
  arrow1: {
    shape: text
    label: "→"
    style.font-size: 40
    style.fill: transparent
    style.stroke: transparent
  }
  plus: {
    shape: text
    label: "+"
    style.font-size: 50
    style.font-color: "#7B4B94"
    style.fill: transparent
    style.stroke: transparent
  }
  tcp_segment: {
    direction: down
    label: "TCP Segment (20+ bytes)"
    style.fill: "#D5E8D4"
    style.stroke: "#82B366"
    style.stroke-width: 2
    tcp_hdr: {
      shape: sql_table
      label: "TCP Header"
      f0: "0x00 | uint16_t | src_port"
      f1: "0x02 | uint16_t | dst_port"
      f2: "0x04 | uint32_t | seq_num"
      f3: "0x08 | uint32_t | ack_num"
      f4: "0x0C | uint16_t | flags + win"
      f5: "0x10 | uint16_t | checksum"
      sz: "20+ bytes"
    }
    tcp_data: {
      shape: sql_table
      label: "TCP Data (Payload)"
      f0: "0x00 | uint8_t[] | application data"
      sz: "0–65515 bytes"
    }
  }
}
arrow2: {
  shape: text
  label: "↓ ones' complement sum"
  style.font-size: 24
  style.fill: transparent
  style.stroke: transparent
}
checksum_result: {
  direction: right
  label: "Checksum Result"
  style.fill: "#FFF2CC"
  style.stroke: "#D6B656"
  style.stroke-width: 2
  checksum_field: {
    shape: sql_table
    label: "TCP Checksum Field"
    f0: "0x00 | uint16_t | checksum"
    f1: "Offset: 0x10 in TCP header"
    sz: "2 bytes"
  }
}
validation: {
  direction: down
  label: "Verification Property"
  style.fill: "#F8CECC"
  style.stroke: "#B85450"
  style.stroke-width: 2
  width: 400
  code: |'c
    // Sum pseudo-header + TCP segment
    // If checksum is correct:
    // sum == 0xFFFF (all 1s)
    int tcp_verify_checksum(uint32_t src_ip, 
                            uint32_t dst_ip,
                            const void *tcp_hdr,
                            uint16_t tcp_len) {
        // Sum pseudo-header
        sum += src_ip >> 16;
        sum += src_ip & 0xFFFF;
        sum += dst_ip >> 16;
        sum += dst_ip & 0xFFFF;
        sum += 0x0006;        // protocol
        sum += tcp_len;
        // Sum TCP segment...
        // Fold carries, check == 0xFFFF
    }
  '|
}
layer_break: {
  direction: down
  label: "⚠️ Layer Boundary Violation"
  style.fill: "#FFE6E6"
  style.stroke: "#CC0000"
  style.stroke-width: 3
  layer_table: {
    shape: sql_table
    label: "Why TCP Needs IP Addresses"
    r0: "Layer 4 (Transport) | TCP"
    r1: "Layer 3 (Network)   | IP"
    r2: "Layer 2 (Data Link) | Ethernet"
    note: "Pseudo-header binds L4 to L3"
  }
  explanation: {
    label: "Purpose"
    width: 350
    code: |'c
      // Without pseudo-header:
      // A TCP segment could be misdelivered
      // to wrong IP address due to routing
      // corruption or packet injection.
      // Pseudo-header ensures segment
      // was meant for THIS destination.
    '|
  }
}
legend: {
  near: bottom-right
  direction: right
  style.fill: transparent
  style.stroke: transparent
  l1: {
    shape: rectangle
    label: "Pseudo-Header"
    style.fill: "#E8D5F0"
    width: 120
  }
  l2: {
    shape: rectangle
    label: "TCP Segment"
    style.fill: "#D5E8D4"
    width: 120
  }
  l3: {
    shape: rectangle
    label: "Result"
    style.fill: "#FFF2CC"
    width: 120
  }
}
pseudo_header.src_ip -> pseudo_header.dst_ip
pseudo_header.dst_ip -> pseudo_header.zero_proto
pseudo_header.zero_proto -> pseudo_header.tcp_len
tcp_segment.tcp_hdr -> tcp_segment.tcp_data
row1.pseudo_header -> row1.tcp_segment: "concatenate"
row1.tcp_segment -> checksum_result.checksum_field: "compute"
checksum_result -> validation: "verify"
validation -> layer_break: "understand"