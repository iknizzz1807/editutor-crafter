direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # TCP State Machine (RFC 793 Figure 6)
    Complete 11-State Finite State Automaton
  |
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_closed: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  closed: {
    shape: circle
    label: CLOSED
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 3
      font: mono
      bold: true
    }
  }
}
row_listen: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  listen: {
    shape: circle
    label: LISTEN
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
}
row_syn: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  syn_sent: {
    shape: circle
    label: SYN_SENT
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  syn_received: {
    shape: circle
    label: SYN_RECEIVED
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
}
row_established: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  established: {
    shape: circle
    label: ESTABLISHED
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 3
      font: mono
      bold: true
    }
  }
}
row_close_passive: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  close_wait: {
    shape: circle
    label: CLOSE_WAIT
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  last_ack: {
    shape: circle
    label: LAST_ACK
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
}
row_close_active: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  fin_wait-1: {
    shape: circle
    label: FIN_WAIT_1
    style: {
      fill: "#F8BBD9"
      stroke: "#C2185B"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  fin-wait-2: {
    shape: circle
    label: FIN_WAIT_2
    style: {
      fill: "#F8BBD9"
      stroke: "#C2185B"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  closing: {
    shape: circle
    label: CLOSING
    style: {
      fill: "#F8BBD9"
      stroke: "#C2185B"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  time-wait: {
    shape: circle
    label: TIME_WAIT
    style: {
      fill: "#D1C4E9"
      stroke: "#7E57C2"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
}
closed -> listen: "passive OPEN\n(socket(), listen())" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
    font-size: 12
  }
}
closed -> syn_sent: "active OPEN\n(send SYN)" {
  style: {
    stroke: "#1976D2"
    stroke-width: 2
    font-size: 12
  }
}
listen -> syn_received: "rcv SYN\nsend SYN+ACK" {
  style: {
    stroke: "#1976D2"
    stroke-width: 2
    font-size: 12
  }
}
listen -> closed: "CLOSE\n(RST)" {
  style: {
    stroke: "#E53935"
    stroke-width: 2
    stroke-dash: 4
    font-size: 12
  }
}
syn_sent -> established: "rcv SYN+ACK\nsend ACK" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
    font-size: 12
  }
}
syn_sent -> syn_received: "rcv SYN\nsimultaneous open" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    stroke-dash: 3
    font-size: 11
  }
}
syn_sent -> closed: "CLOSE / timeout\n(RST)" {
  style: {
    stroke: "#E53935"
    stroke-width: 2
    stroke-dash: 4
    font-size: 12
  }
}
syn_received -> established: "rcv ACK\n(3-way complete)" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
    font-size: 12
  }
}
syn_received -> closed: "timeout / CLOSE\n(RST)" {
  style: {
    stroke: "#E53935"
    stroke-width: 2
    stroke-dash: 4
    font-size: 12
  }
}
established -> fin-wait-1: "CLOSE\n(active close, send FIN)" {
  style: {
    stroke: "#C2185B"
    stroke-width: 2
    font-size: 11
  }
}
established -> close_wait: "rcv FIN\n(passive close, send ACK)" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    font-size: 11
  }
}
established -> closed: "rcv RST\n(abort)" {
  style: {
    stroke: "#E53935"
    stroke-width: 2
    stroke-dash: 4
    font-size: 12
  }
}
fin-wait-1 -> fin-wait-2: "rcv ACK\n(for our FIN)" {
  style: {
    stroke: "#C2185B"
    stroke-width: 2
    font-size: 12
  }
}
fin-wait-1 -> closing: "rcv FIN\n(simultaneous close)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    stroke-dash: 3
    font-size: 11
  }
}
fin-wait-1 -> time-wait: "rcv FIN+ACK\n(fast close)" {
  style: {
    stroke: "#7E57C2"
    stroke-width: 2
    stroke-dash: 3
    font-size: 11
  }
}
fin-wait-2 -> time-wait: "rcv FIN\nsend ACK" {
  style: {
    stroke: "#7E57C2"
    stroke-width: 2
    font-size: 12
  }
}
closing -> time-wait: "rcv ACK\n(for our FIN)" {
  style: {
    stroke: "#7E57C2"
    stroke-width: 2
    font-size: 12
  }
}
time-wait -> closed: "2*MSL timeout\n(60s default)" {
  style: {
    stroke: "#7E57C2"
    stroke-width: 2
    font-size: 12
  }
}
close_wait -> last_ack: "CLOSE\n(send FIN)" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    font-size: 12
  }
}
last_ack -> closed: "rcv ACK\n(for our FIN)" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    font-size: 12
  }
}
legend: {
  near: bottom-center
  legend-box: {
    style: {
      fill: "#FAFAFA"
      stroke: "#BDBDBD"
      stroke-width: 1
      border-radius: 4
    }
    label: "Legend: Transition Types"
    leg-active: "━━  Normal transition"
    leg-active.style: {
      font: mono
      font-size: 11
    }
    leg-simul: "- - -  Simultaneous/Fast path"
    leg-simul.style: {
      font: mono
      font-size: 11
      stroke: "#7B1FA2"
    }
    leg-rst: "┅ ┅  RST/Abort/Timeout"
    leg-rst.style: {
      font: mono
      font-size: 11
      stroke: "#E53935"
    }
  }
}
server-path: {
  near: center-left
  style: {
    fill: transparent
    stroke: "#F57C00"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 8
  }
  label: "Passive Close Path\n(Server)"
}
client-path: {
  near: center-right
  style: {
    fill: transparent
    stroke: "#C2185B"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 8
  }
  label: "Active Close Path\n(Client)"
}