direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "TTL Handling & ICMP Time Exceeded — Traceroute Mechanics"
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#f8f9fa"
  }
}
header.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  normal_flow: {
    direction: down
    label: "Normal Forwarding (TTL > 1)"
    
    source1: {
      label: "Source Host"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    
    router1: {
      label: "Router: Decrement TTL"
      shape: diamond
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    
    dest1: {
      label: "Destination"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    
    source1 -> router1: "IP | TTL=64"
    router1 -> dest1: "IP | TTL=63"
    
    action: {
      label: "Status: Packet Forwarded"
      style.font-color: "#4CAF50"
      style.stroke: "#4CAF50"
      style.fill: "#E8F5E9"
    }
  }

  expired_flow: {
    direction: down
    label: "TTL Expiration (TTL = 1)"
    
    source2: {
      label: "Source Host"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
    }
    
    router2: {
      label: "Router: TTL Check"
      shape: diamond
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
    }
    
    dest2: {
      label: "Destination (Unreachable)"
      shape: rectangle
      style.fill: "#E0E0E0"
      style.stroke: "#9E9E9E"
      style.stroke-dash: 3
    }
    
    source2 -> router2: "IP | TTL=1"
    router2 -> dest2: "Action: DROP" {
      style.stroke-dash: 5
    }
    router2 -> source2: "ICMP | Type 11" {
      style.stroke: "#FF9800"
      style.stroke-dash: 4
    }
    
    action: {
      label: "Status: TTL Expired"
      style.font-color: "#F44336"
      style.stroke: "#F44336"
      style.fill: "#FFEBEE"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ttl_process: {
    direction: down
    label: "TTL Processing Logic (router.c)"
    
    step1: {
      label: "1: Parse Header"
      code: |'c
        struct ip_hdr *ip = (struct ip_hdr *)buffer;
        uint8_t ttl = ip->ttl;
      '|
      width: 350
    }
    step2: {
      label: "2: Condition Check"
      code: |'c
        if (ttl <= 1) {
          // Packet cannot be forwarded
          goto send_time_exceeded;
        }
        ip->ttl = ttl - 1;
      '|
      width: 350
    }
    step3: {
      label: "3: Update Integrity"
      code: |'c
        // Must update L3 checksum
        ip_set_checksum(ip);
      '|
      width: 350
    }
    step4: {
      label: "4: Dispatch"
      code: |'c
        forward_packet(ip, route);
        return;
      send_time_exceeded:
        icmp_error(ip, ICMP_T_TIME_EXCEED, 0);
      '|
      width: 350
    }
    step1 -> step2 -> step3 -> step4
  }

  traceroute_steps: {
    direction: down
    label: "Traceroute Probe Mechanism"
    
    probe1: {
      label: "Hop 1: Discovery"
      code: |'c
        // Set TTL to 1
        send_udp(dst, port=33434, ttl=1);
        // Expect: ICMP Time Exceeded from R1
      '|
      width: 380
      style.fill: "#FFF3E0"
    }
    probe2: {
      label: "Hop 2: Discovery"
      code: |'c
        // Set TTL to 2
        send_udp(dst, port=33435, ttl=2);
        // Expect: ICMP Time Exceeded from R2
      '|
      width: 380
      style.fill: "#E8F5E9"
    }
    probe_n: {
      label: "Hop N: Final Destination"
      code: |'c
        // Set TTL to N
        send_udp(dst, port=33436, ttl=N);
        // Expect: ICMP Port Unreachable
      '|
      width: 380
      style.fill: "#E3F2FD"
    }
    probe1 -> probe2 -> probe_n
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  icmp_spec: {
    direction: down
    label: "Protocol Specification"
    
    icmp_hdr: {
      shape: sql_table
      label: "struct icmp_error (icmp.h)"
      f0: "0x00 | uint8_t  | type // 11: Time Exceeded"
      f1: "0x01 | uint8_t  | code // 0: TTL, 1: Frag Reassembly"
      f2: "0x02 | uint16_t | checksum"
      f3: "0x04 | uint32_t | unused // Reserved: 0"
      f4: "0x08 | ip_hdr   | orig_ip_header // 20 bytes"
      f5: "0x1C | uint8_t[8] | orig_payload // 8 bytes"
      sz: "Total: 36 bytes (minimum)"
    }
    
    codes: {
      label: "ICMP Code 0: TTL exceeded in transit"
      shape: callout
      style.fill: "#f8f9fa"
    }
  }

  trace_trace: {
    direction: down
    label: "Example Discovery Trace"
    
    topo: {
      direction: right
      style.stroke: "#e0e0e0"
      client: "Client (192.168.1.10)" {
        shape: rectangle
      }
      r1: "R1 (10.0.0.1)" {
        shape: diamond
      }
      r2: "R2 (10.0.1.1)" {
        shape: diamond
      }
      server: "Server (203.0.113.5)" {
        shape: rectangle
      }
      client -> r1 -> r2 -> server
    }
    
    terminal: {
      label: "traceroute to 203.0.113.5"
      code: |'text
        1  10.0.0.1     1.2 ms
        2  10.0.1.1     2.8 ms
        3  203.0.113.5  4.1 ms
      '|
      width: 350
    }
  }
}

legend: {
  direction: right
  label: "Diagram Legend"
  
  l1: {
    label: "Forward"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  l2: {
    label: "Error/Drop"
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
  }
  l3: {
    label: "ICMP Path"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
legend.near: bottom-center

row1 -> row2: "Processing Loop"
row2 -> row3: "Wire Format"