vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 40
  }
}

title: |md
  # TCP/IP Stack Architecture: Satellite View
  **Implementation Specification for RFC 793 (TCP), RFC 791 (IPv4), RFC 826 (ARP)**
| {near: top-center}

direction: down

# -----------------------------------------------------------------------------------------
# STYLING & CLASSES
# -----------------------------------------------------------------------------------------
classes: {
  layer-container: {
    style: {
      stroke-dash: 4
      stroke: "#444"
      fill: "transparent"
      stroke-width: 1
    }
  }
  app-layer: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      font-color: "#2E7D32"
      shadow: true
    }
  }
  transport-layer: {
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
      font-color: "#1565C0"
      shadow: true
    }
  }
  network-layer: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      font-color: "#E65100"
      shadow: true
    }
  }
  link-layer: {
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      font-color: "#6A1B9A"
      shadow: true
    }
  }
  physical-layer: {
    style: {
      fill: "#ECEFF1"
      stroke: "#607D8B"
      stroke-width: 2
      font-color: "#37474F"
    }
  }
  data-flow: {
    style: {
      stroke: "#2196F3"
      animated: true
      stroke-width: 3
    }
  }
  control-flow: {
    style: {
      stroke: "#F44336"
      stroke-dash: 3
      stroke-width: 1
    }
  }
  note-box: {
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      stroke: "#CCC"
      font-size: 11
      border-radius: 4
    }
  }
}

# -----------------------------------------------------------------------------------------
# ARCHITECTURE LAYERS
# -----------------------------------------------------------------------------------------

"Application Layer": {
  class: layer-container
  label.near: top-left
  
  App: {
    label: "User Process\n(Socket API)"
    class: app-layer
    width: 220
    height: 100
  }
  
  App_Doc: |md
    **Context: User Space**
    - `sys_sendto` / `sys_recvfrom`
    - Circular Ring Buffers (Tx/Rx)
    - Zero-copy via `mmap` (optional)
  | {
    class: note-box
  }
}

"Transport Layer": {
  class: layer-container
  label.near: top-left

  TCP_Conn: {
    label: "M3: TCP Connection\nState Machine"
    class: transport-layer
    width: 220
    height: 120
  }
  
  TCP_Conn_Doc: |md
    **Control Plane**
    - RFC 793 (11 States)
    - Retransmission Timeout (RTO) logic
    - 4-tuple: {src_ip, src_port, dst_ip, dst_port}
  | {
    class: note-box
  }

  TCP_Data: {
    label: "M4: TCP Segmentation\n& Flow Control"
    class: transport-layer
    width: 220
    height: 120
  }
  
  TCP_Data_Doc: |md
    **Data Plane**
    - Sliding Window Protocol
    - Congestion: Reno/Cubic (Slow Start)
    - MTU Path Discovery
  | {
    class: note-box
  }

  TCP_Conn -> TCP_Data: "State: ESTABLISHED" {style.stroke: "#2196F3"}
}

"Network Layer": {
  class: layer-container
  label.near: top-left

  IP_Module: {
    label: "M2: IP Layer\n(Addressing & Routing)"
    class: network-layer
    width: 220
    height: 120
  }
  
  IP_Doc: |md
    **Network Protocol**
    - TTL Management & ICMP
    - Fragmentation / Reassembly
    - LPM (Longest Prefix Match)
  | {
    class: note-box
  }
}

"Link Layer": {
  class: layer-container
  label.near: top-left

  Ethernet_ARP: {
    label: "M1: Ethernet Frame\n& ARP Cache"
    class: link-layer
    width: 220
    height: 120
  }
  
  Link_Doc: |md
    **Hardware Abstraction**
    - TAP Device File I/O
    - ARP Request Broadcast (Who-has)
    - Checksum Calculation (FCS)
  | {
    class: note-box
  }
}

"Physical Layer": {
  class: layer-container
  label.near: top-left

  NIC: {
    label: "Network Interface\n(Hardware/NIC)"
    class: physical-layer
    width: 220
    height: 80
  }
}

# -----------------------------------------------------------------------------------------
# SYSTEM SEQUENCES (DATA & CONTROL PATHS)
# -----------------------------------------------------------------------------------------

# Downward Path (Egress)
"Application Layer".App -> "Transport Layer".TCP_Conn: "1. write()" {class: data-flow}
"Transport Layer".TCP_Conn -> "Transport Layer".TCP_Data: "2. segment" {class: data-flow}
"Transport Layer".TCP_Data -> "Network Layer".IP_Module: "3. ip_output" {class: data-flow}
"Network Layer".IP_Module -> "Link Layer".Ethernet_ARP: "4. eth_send" {class: data-flow}
"Link Layer".Ethernet_ARP -> "Physical Layer".NIC: "5. NIC DMA TX" {class: data-flow}

# Upward Path (Ingress)
"Physical Layer".NIC -> "Link Layer".Ethernet_ARP: "IRQ / RX Descriptor" {class: control-flow}
"Link Layer".Ethernet_ARP -> "Network Layer".IP_Module: "Type: 0x0800 (IP)" {class: control-flow}
"Network Layer".IP_Module -> "Transport Layer".TCP_Data: "Proto: 6 (TCP)" {class: control-flow}
"Transport Layer".TCP_Data -> "Transport Layer".TCP_Conn: "Validate SEQ/ACK" {class: control-flow}
"Transport Layer".TCP_Conn -> "Application Layer".App: "wake_up(wait_queue)" {class: control-flow}

# -----------------------------------------------------------------------------------------
# ANNOTATIONS & SPECIFICATIONS
# -----------------------------------------------------------------------------------------

Stack_Specs: {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#F1F1F1"
    stroke: "#AAA"
  }
  label: |md
    ### Memory Layout & Timing
    - **sizeof(struct tcp_pcb)**: 128 bytes (2x Cache Lines)
    - **sizeof(struct eth_hdr)**: 14 bytes (No VLAN)
    - **sizeof(struct ip_hdr)**: 20 bytes (No Options)
    - **sizeof(struct tcp_hdr)**: 20 bytes (No Options)
    
    **Latency Budget:**
    - L2 Switching: < 5μs
    - L3 Routing: < 20μs
    - TCP ACK Process: < 50μs
  |
}

Legend: {
  near: bottom-right
  M1: "M1: Link/ARP" {style.fill: "#F3E5F5"}
  M2: "M2: IP/ICMP" {style.fill: "#FFF3E0"}
  M3: "M3: TCP Control" {style.fill: "#E3F2FD"}
  M4: "M4: TCP Data" {style.fill: "#E3F2FD"}
  
  M1_label: {
    label: "Module Boundaries"
    shape: text
    style.bold: true
  }
}

Implementation_Notes: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
  }
  label: |md
    ### Critical Implementation Rules
    1. **Big Endian**: All network headers must use `htons()` / `htonl()`.
    2. **Alignment**: Ensure IP header starts at 2-byte offset to align 4-byte fields.
    3. **Checksums**: TCP checksum must include Pseudo-IP header.
    4. **RTO**: Use Karn's Algorithm; do not sample retransmitted segments.
  |
}