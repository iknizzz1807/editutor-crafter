vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # Ethernet Send/Receive Data Path
  **Userspace to Wire Architecture & Implementation Spec (v2.1.0)**
  *Focus: TAP Interface & Linux Kernel Network Subsystem*
|| {
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}

direction: right

# ============== APPLICATION LAYER ==============
application_layer: "Application Layer (Userspace)" {
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 4
  }

  app_send: "Application\nsend() syscall" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      bold: true
    }
    tooltip: "Writes data to socket file descriptor via VFS"
  }
  app_recv: "Application\nrecv() syscall" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      bold: true
    }
    tooltip: "Reads data from socket file descriptor via VFS"
  }
}

# ============== TCP STACK (USERSPACE) ==============
tcp_stack: "TCP/IP Stack (Userspace context)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 4
  }

  send_buffer: "Send Buffer\n(Ring: 64KB)" {
    shape: cylinder
    style: {
      fill: "#BBDEFB"
      stroke: "#1565C0"
    }
  }

  eth_frame_struct: "Eth Frame Memory Layout" {
    shape: sql_table
    style.fill: "#E1D5E7" # Header Purple
    "0x00": "6 Bytes" {constraint: "DMAC (Destination)"}
    "0x06": "6 Bytes" {constraint: "SMAC (Source)"}
    "0x0C": "2 Bytes" {constraint: "EtherType (0x0800)"}
    "0x0E": "46-1500B" {constraint: "Payload (Data)"}
    "0xCRC": "4 Bytes" {constraint: "FCS (CRC32)"}
  }

  tcp_processor: "TCP Segment\nBuilder/Parser" {
    shape: rectangle
    style.fill: "#DAE8FC"
  }
  
  ip_processor: "IP Packet\nBuilder/Parser" {
    shape: rectangle
    style.fill: "#DAE8FC"
  }

  recv_buffer: "Receive Buffer\n(+ OOO Queue)" {
    shape: cylinder
    style.fill: "#BBDEFB"
  }

  # Internal logic flow for segment generation
  send_buffer -> tcp_processor: "1. Enqueue payload"
  tcp_processor -> ip_processor: "2. Add TCP Header (20B)"
  ip_processor -> eth_frame_struct: "3. Encapsulate"
  eth_frame_struct -> recv_buffer: "Incoming Path"
}

# ============== TAP DEVICE INTERFACE ==============
tap_interface: "TAP Virtual Network Interface" {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 4
  }

  tap_fd: "TAP File Descriptor\n/dev/net/tun" {
    shape: rectangle
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
      double-border: true
    }
  }
  
  vnet_hdr: "Virtio Net Header" {
    shape: sql_table
    style.fill: "#E1D5E7"
    flags: "uint8_t" {constraint: "0x00"}
    gso_type: "uint8_t" {constraint: "0x01"}
    hdr_len: "uint16_t" {constraint: "0x02"}
    csum_start: "uint16_t" {constraint: "0x04"}
  }

  tap_buffer: "TAP Ring Queue\n(sk_buff list)" {
    shape: cylinder
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
    }
  }

  tap_fd -> vnet_hdr: "User -> Kernel Copy"
  vnet_hdr -> tap_buffer: "skb_alloc"
}

# ============== KERNEL SPACE ==============
kernel: "Linux Kernel Subsystem" {
  style: {
    fill: "#FCE4EC"
    stroke: "#E91E63"
    stroke-width: 4
  }

  sk_buff_layout: "struct sk_buff (Kernel)" {
    shape: sql_table
    style.fill: "#E1D5E7"
    next: "pointer" {constraint: "8 Bytes"}
    prev: "pointer" {constraint: "8 Bytes"}
    len: "uint32" {constraint: "4 Bytes"}
    data: "char*" {constraint: "8 Bytes"}
    head: "char*" {constraint: "8 Bytes"}
    tail: "char*" {constraint: "8 Bytes"}
    end: "char*" {constraint: "8 Bytes"}
  }

  tun_driver: "TUN/TAP Driver\n(drivers/net/tun.c)" {
    shape: rectangle
    style.fill: "#F8BBD9"
  }
  
  net_device: "NetDev Layer\n(struct net_device)" {
    shape: rectangle
    style.fill: "#F8BBD9"
  }

  tun_driver -> sk_buff_layout: "Manipulate Pointers"
  sk_buff_layout -> net_device: "dev_queue_xmit"
}

# ============== HARDWARE LAYER ==============
hardware: "Hardware (NIC)" {
  style: {
    fill: "#EDE7F6"
    stroke: "#673AB7"
    stroke-width: 4
  }

  dma_ring: "PCIe NIC DMA Ring" {
    shape: sql_table
    style.fill: "#E1D5E7"
    desc_0: "Buffer Addr | Status | Len"
    desc_1: "Buffer Addr | Status | Len"
    desc_n: "Buffer Addr | Status | Len"
  }

  nic: "NIC Controller\n(MAC / BIU)" {
    shape: rectangle
    style: {
      fill: "#D1C4E9"
      stroke: "#4527A0"
      bold: true
    }
  }

  phy: "PHY Transceiver\n(802.3 PCS/PMA)" {
    shape: rectangle
    style.fill: "#B39DDB"
  }

  nic -> dma_ring: "Fetch Descriptors"
  nic -> phy: "GMII interface"
}

# ============== PHYSICAL WIRE ==============
wire: "Physical Layer (Cable)" {
  style: {
    fill: "#ECEFF1"
    stroke: "#607D8B"
  }
  tx_pair: "TX+ / TX- Pair" {
    shape: parallelogram
    style.fill: "#CFD8DC"
  }
  rx_pair: "RX+ / RX- Pair" {
    shape: parallelogram
    style.fill: "#CFD8DC"
  }
}

# ============== MAIN DATA FLOW (SEND) ==============
application_layer.app_send -> tcp_stack.send_buffer: "1. Payload Data" {
  style.stroke: "#4CAF50"
  style.stroke-width: 5
  style.animated: true
}
tcp_stack.eth_frame_struct -> tap_interface.tap_fd: "2. Raw Frame Write" {
  style.stroke: "#4CAF50"
  style.stroke-width: 5
  style.animated: true
}
tap_interface.tap_buffer -> kernel.tun_driver: "3. skb creation" {
  style.stroke: "#4CAF50"
  style.stroke-width: 5
}
kernel.net_device -> hardware.dma_ring: "4. Descriptor Push" {
  style.stroke: "#4CAF50"
  style.stroke-width: 5
}
hardware.phy -> wire.tx_pair: "5. 1000Base-T TX" {
  style.stroke: "#4CAF50"
  style.stroke-width: 5
  style.animated: true
}

# ============== MAIN DATA FLOW (RECEIVE) ==============
wire.rx_pair -> hardware.phy: "R1. Signal" {
  style.stroke: "#2196F3"
  style.stroke-width: 5
  style.animated: true
}
hardware.nic -> kernel.sk_buff_layout: "R2. DMA Transfer" {
  style.stroke: "#2196F3"
  style.stroke-width: 5
  style.animated: true
}
kernel.tun_driver -> tap_interface.tap_fd: "R3. wake_up_interruptible" {
  style.stroke: "#2196F3"
  style.stroke-width: 5
}
tap_interface.tap_fd -> tcp_stack.recv_buffer: "R4. read() frame" {
  style.stroke: "#2196F3"
  style.stroke-width: 5
  style.animated: true
}
tcp_stack.recv_buffer -> application_layer.app_recv: "R5. Userspace payload" {
  style.stroke: "#2196F3"
  style.stroke-width: 5
  style.animated: true
}

# ============== ANNOTATIONS (ELK COMPLIANT) ==============

send_path_info: ||md
  ### SEND PATH (GREEN)
  1. **Userspace Buffer:** Data stored in `send_buffer`.
  2. **Encapsulation:** Ethernet header (14B) prepended in userspace.
  3. **Syscall:** `write(tap_fd)` copies frame to kernel memory.
  4. **Kernel skb:** `tun.c` allocates `sk_buff` and notifies stack.
  5. **DMA:** NIC fetches frame from `dma_ring` via PCIe Master.
|| {
  near: top-left
  style: { fill: "#E8F5E9"; stroke: "#4CAF50" }
}

recv_path_info: ||md
  ### RECEIVE PATH (BLUE)
  1. **PHY:** Clock recovery and 8b/10b decoding.
  2. **DMA:** NIC writes frame directly to kernel `skb->data`.
  3. **IRQ:** Hardware generates MSI-X interrupt.
  4. **TAP Queue:** Frame enqueued in `tun->read_wait`.
  5. **Parsing:** Userspace stack strips headers and verifies CRC.
|| {
  near: bottom-right
  style: { fill: "#E3F2FD"; stroke: "#1976D2" }
}

mem_stats: ||md
  ### Data Copy Overhead
  - **Copy 1:** App Buffer → Stack Buffer (memmove)
  - **Copy 2:** User Space → Kernel Space (copy_from_user)
  - **Copy 3 (DMA):** Kernel RAM → NIC SRAM (Zero CPU)
|| {
  near: top-right
  style: { fill: "#FCE4EC"; stroke: "#E91E63" }
}

latency_specs: ||md
  ### Latency Breakdown
  - **Syscall Overhead:** ~0.6 μs
  - **Context Switch:** ~1.2 μs
  - **DMA Transaction:** ~0.4 μs
  - **PHY Processing:** ~0.2 μs
  - **TOTAL E2E:** **~2.4 μs + Wire Time**
|| {
  near: bottom-left
  style: { fill: "#FFF9C4"; stroke: "#F9A825" }
}

legend: "Protocol Legend" {
  near: bottom-center
  tx: "Transmit (TX)" { style.stroke: "#4CAF50"; style.stroke-width: 4 }
  rx: "Receive (RX)" { style.stroke: "#2196F3"; style.stroke-width: 4 }
  tx -> rx: { style.opacity: 0 }
}