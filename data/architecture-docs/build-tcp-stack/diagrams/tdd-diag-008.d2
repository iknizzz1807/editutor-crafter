vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # ARP Packet Structure (28 bytes)
  RFC 826 - Address Resolution Protocol
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

direction: right

# Memory Layout Table Wrapper
arp_memory_view: {
  grid-columns: 3
  grid-gap: 0
  style.stroke-width: 0

  # Column 1: Byte Offsets
  offsets: {
    grid-rows: 9
    grid-columns: 1
    grid-gap: 0
    style.stroke-width: 0
    
    o00: "0x00" { height: 60; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o02: "0x02" { height: 60; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o04: "0x04" { height: 40; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o05: "0x05" { height: 40; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o06: "0x06" { height: 60; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o08: "0x08" { height: 80; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o0E: "0x0E" { height: 70; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o12: "0x12" { height: 80; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
    o18: "0x18" { height: 70; style: { fill: transparent; font: mono; font-color: "#666666"; stroke-width: 0 } }
  }

  # Column 2: The Packet Structure
  packet: {
    grid-rows: 9
    grid-columns: 2
    grid-gap: 0
    
    # Row 1: Hardware Type
    hw_type_l: "Hardware Type (HTYPE)" { height: 60; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    hw_type_v: "0x0001 (Ethernet)" { height: 60; style: { fill: "#B8D4E8"; stroke: "#4A90A4"; font: mono } }
    
    # Row 2: Protocol Type
    proto_type_l: "Protocol Type (PTYPE)" { height: 60; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    proto_type_v: "0x0800 (IPv4)" { height: 60; style: { fill: "#B8D4E8"; stroke: "#4A90A4"; font: mono } }
    
    # Row 3: Hardware Address Length
    hw_len_l: "Hardware Length (HLEN)" { height: 40; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    hw_len_v: "0x06 (6 bytes)" { height: 40; style: { fill: "#C8E6C9"; stroke: "#66BB6A"; font: mono } }
    
    # Row 4: Protocol Address Length
    proto_len_l: "Protocol Length (PLEN)" { height: 40; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    proto_len_v: "0x04 (4 bytes)" { height: 40; style: { fill: "#C8E6C9"; stroke: "#66BB6A"; font: mono } }
    
    # Row 5: Operation Code
    opcode_l: "Operation (OPER)" { height: 60; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    opcode_v: "1=REQ, 2=REPLY" { height: 60; style: { fill: "#FFE0B2"; stroke: "#FF9800"; font: mono } }
    
    # Row 6: Sender Hardware Address
    s_hw_l: "Sender HW Address (SHA)" { height: 80; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    s_hw_v: "Source MAC Address" { height: 80; style: { fill: "#E1BEE7"; stroke: "#9C27B0"; font: mono } }
    
    # Row 7: Sender Protocol Address
    s_pr_l: "Sender Proto Address (SPA)" { height: 70; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    s_pr_v: "Source IP Address" { height: 70; style: { fill: "#BBDEFB"; stroke: "#2196F3"; font: mono } }
    
    # Row 8: Target Hardware Address
    t_hw_l: "Target HW Address (THA)" { height: 80; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    t_hw_v: "Dest MAC (0 if Req)" { height: 80; style: { fill: "#E1BEE7"; stroke: "#9C27B0"; font: mono } }
    
    # Row 9: Target Protocol Address
    t_pr_l: "Target Proto Address (TPA)" { height: 70; style: { fill: "#E8E8E8"; stroke: "#666666"; font: mono; bold: true } }
    t_pr_v: "Dest IP Address" { height: 70; style: { fill: "#BBDEFB"; stroke: "#2196F3"; font: mono } }
  }

  # Column 3: Field Sizes
  sizes: {
    grid-rows: 9
    grid-columns: 1
    grid-gap: 0
    style.stroke-width: 0
    
    s0: "2 B" { height: 60; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s1: "2 B" { height: 60; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s2: "1 B" { height: 40; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s3: "1 B" { height: 40; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s4: "2 B" { height: 60; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s5: "6 B" { height: 80; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s6: "4 B" { height: 70; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s7: "6 B" { height: 80; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
    s8: "4 B" { height: 70; style: { fill: transparent; font: mono; font-color: "#888888"; stroke-width: 0 } }
  }
}

# Documentation and Legend
meta: {
  near: bottom-center
  
  legend: {
    grid-columns: 3
    style.stroke-dash: 3
    
    l1: "Header Setup" { style: { fill: "#B8D4E8"; stroke: "#4A90A4" } }
    l2: "Length Specs" { style: { fill: "#C8E6C9"; stroke: "#66BB6A" } }
    l3: "Opcode" { style: { fill: "#FFE0B2"; stroke: "#FF9800" } }
    l4: "MAC Address" { style: { fill: "#E1BEE7"; stroke: "#9C27B0" } }
    l5: "IP Address" { style: { fill: "#BBDEFB"; stroke: "#2196F3" } }
  }

  total_size: |md
    **Total Struct Size: 28 bytes**
    
    c
    struct arp_hdr {
      uint16_t hw_type;        // 0x00
      uint16_t proto_type;     // 0x02
      uint8_t  hw_addr_len;    // 0x04
      uint8_t  proto_addr_len; // 0x05
      uint16_t opcode;         // 0x06
      uint8_t  sender_hw[6];   // 0x08
      uint8_t  sender_proto[4];// 0x0E
      uint8_t  target_hw[6];   // 0x12
      uint8_t  target_proto[4];// 0x18
    } __attribute__((packed));
    
  | {
    style: {
      font-size: 14
    }
  }
}

# Layout constraints to force vertical alignment
arp_memory_view.offsets.o00 -> arp_memory_view.packet.hw_type_l: { style: { stroke-width: 0; opacity: 0 } }
arp_memory_view.packet.hw_type_v -> arp_memory_view.sizes.s0: { style: { stroke-width: 0; opacity: 0 } }