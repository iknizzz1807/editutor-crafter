vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Pending Queue Flow
  ARP Resolution and Packet Queuing Logic
| {near: top-center}

direction: right

# ============================================
# STAGE 1: OUTBOUND PACKET ARRIVAL
# ============================================
stage1: {
  label: "1. Outbound Packet"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  
  app: Application {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
  
  outbound: "Outbound IP Packet\ndst=192.168.1.5" {
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke: "#1565C0"
    style.bold: true
  }
  
  app -> outbound: send\ndata {
    style.stroke: "#1565C0"
    style.animated: true
  }
}

# ============================================
# STAGE 2: ARP LOOKUP - MISS
# ============================================
stage2: {
  label: "2. ARP Cache Lookup"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  
  lookup: ARP Cache\nLookup {
    shape: diamond
    style.fill: "#FFE0B2"
    style.stroke: "#E65100"
  }
  
  cache: ARP Cache {
    shape: cylinder
    style.fill: "#FFCC80"
    style.stroke: "#EF6C00"
    entry1: "192.168.1.1 → AA:BB:CC:DD:EE:01"
    entry2: "192.168.1.2 → AA:BB:CC:DD:EE:02"
    style.font-size: 14
  }
  
  miss: "MISS!\n192.168.1.5\nnot in cache" {
    shape: rectangle
    style.fill: "#FFAB91"
    style.stroke: "#D84315"
    style.bold: true
    style.font-color: "#D84315"
  }
  
  lookup -> cache: query\n192.168.1.5 {
    style.stroke: "#E65100"
  }
  
  cache -> lookup: not found {
    style.stroke: "#D84315"
    style.stroke-dash: 3
  }
  
  lookup -> miss: {
    style.stroke: "#D84315"
    style.bold: true
  }
}

# ============================================
# STAGE 3: QUEUE PACKET
# ============================================
stage3: {
  label: "3. Queue Packet"
  style.fill: "#F3E5F5"
  style.stroke: "#6A1B9A"
  
  queue_decision: Queue\nPacket? {
    shape: diamond
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
  }
  
  pending_queue: Pending Queue {
    shape: rectangle
    style.fill: "#CE93D8"
    style.stroke: "#6A1B9A"
    
    qhdr: "+-------------------+" {
      shape: text
      style.font: mono
      style.font-size: 12
    }
    qentry1: "| IP: 192.168.1.5   |" {
      shape: text
      style.font: mono
      style.font-size: 12
      style.bold: true
      style.font-color: "#4A148C"
    }
    qentry2: "| Packets: [pkt1]  |" {
      shape: text
      style.font: mono
      style.font-size: 12
    }
    qentry3: "| Retry: 0          |" {
      shape: text
      style.font: mono
      style.font-size: 12
    }
    qftr: "+-------------------+" {
      shape: text
      style.font: mono
      style.font-size: 12
    }
  }
  
  arp_req: ARP Request {
    shape: rectangle
    style.fill: "#BA68C8"
    style.stroke: "#4A148C"
    style.font-color: white
    style.bold: true
    
    arp_label: "Broadcast:" {
      shape: text
      style.font-size: 14
    }
    arp_content: "Who has 192.168.1.5?" {
      shape: text
      style.font-size: 14
    }
  }
  
  queue_decision -> pending_queue: yes {
    style.stroke: "#6A1B9A"
    style.bold: true
  }
  
  queue_decision -> arp_req: send\nrequest {
    style.stroke: "#4A148C"
    style.animated: true
  }
}

# ============================================
# STAGE 4: ARP RESOLUTION
# ============================================
stage4: {
  label: "4. ARP Resolution"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  
  network: Network {
    shape: cloud
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  
  target: "Target Host\n192.168.1.5" {
    shape: rectangle
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
    icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
  }
  
  arp_reply: ARP Reply {
    shape: rectangle
    style.fill: "#81C784"
    style.stroke: "#1B5E20"
    style.bold: true
    
    reply_label: "192.168.1.5 is at" {
      shape: text
      style.font-size: 14
    }
    reply_mac: "AA:BB:CC:DD:EE:05" {
      shape: text
      style.font-size: 14
      style.bold: true
      style.font-color: "#1B5E20"
    }
  }
  
  network -> target: ARP\nRequest {
    style.stroke: "#388E3C"
    style.animated: true
  }
  
  target -> arp_reply: ARP\nReply {
    style.stroke: "#1B5E20"
    style.animated: true
    style.stroke-dash: 3
  }
}

# ============================================
# STAGE 5: CACHE UPDATE & QUEUE FLUSH
# ============================================
stage5: {
  label: "5. Cache Update & Flush"
  style.fill: "#E1F5FE"
  style.stroke: "#0277BD"
  
  updated_cache: Updated ARP Cache {
    shape: cylinder
    style.fill: "#B3E5FC"
    style.stroke: "#01579B"
    style.bold: true
    
    uentry1: "192.168.1.1 → AA:BB:CC:DD:EE:01"
    uentry2: "192.168.1.2 → AA:BB:CC:DD:EE:02"
    uentry3: "192.168.1.5 → AA:BB:CC:DD:EE:05" {
      style.font-color: "#0D47A1"
      style.bold: true
    }
    style.font-size: 14
  }
  
  flush: Queue Flush {
    shape: rectangle
    style.fill: "#4FC3F7"
    style.stroke: "#0277BD"
    style.bold: true
    
    flush_label: "For each queued packet:" {
      shape: text
      style.font-size: 14
    }
    flush_step1: "1. Update dst_mac" {
      shape: text
      style.font-size: 14
    }
    flush_step2: "2. Send packet" {
      shape: text
      style.font-size: 14
    }
  }
  
  cleared_queue: "Cleared Queue\n(count=0)" {
    shape: rectangle
    style.fill: "#B2EBF2"
    style.stroke: "#006064"
    style.opacity: 0.7
  }
  
  updated_cache -> flush: MAC\nresolved {
    style.stroke: "#0277BD"
    style.bold: true
  }
  
  flush -> cleared_queue: clear {
    style.stroke: "#006064"
    style.stroke-dash: 3
  }
}

# ============================================
# STAGE 6: PACKET DELIVERED
# ============================================
stage6: {
  label: "6. Packet Delivered"
  style.fill: "#F1F8E9"
  style.stroke: "#33691E"
  
  delivered: "Packet Delivered\nto Destination" {
    shape: rectangle
    style.fill: "#C5E1A5"
    style.stroke: "#558B2F"
    style.bold: true
    style.double-border: true
  }
  
  dest_host: Destination\n192.168.1.5 {
    shape: rectangle
    style.fill: "#AED581"
    style.stroke: "#33691E"
    icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
  }
  
  delivered -> dest_host: success {
    style.stroke: "#33691E"
    style.animated: true
  }
}

# ============================================
# FLOW CONNECTIONS
# ============================================
stage1.outbound -> stage2.lookup: packet\nneeds MAC {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
stage2.miss -> stage3.queue_decision: {
  style.stroke: "#D84315"
  style.stroke-width: 2
  style.bold: true
}
stage3.arp_req -> stage4.network: broadcast {
  style.stroke: "#4A148C"
  style.stroke-width: 2
  style.animated: true
}
stage4.arp_reply -> stage5.updated_cache: process\nreply {
  style.stroke: "#1B5E20"
  style.stroke-width: 2
  style.animated: true
}
stage5.flush -> stage6.delivered: transmit {
  style.stroke: "#0277BD"
  style.stroke-width: 2
  style.animated: true
}

# ============================================
# DATA STRUCTURE DETAIL
# ============================================
data_structures: {
  label: "Data Structures"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  
  pending_queue_struct: Pending Queue Structure {
    shape: class
    ip: uint32_t
    packets: "pending_packet[16]"
    head: int
    count: int
    request_sent: time_t
    retry_count: int
    in_use: int
  }
  
  pending_packet_struct: Pending Packet {
    shape: class
    data: "uint8_t[1500]"
    len: size_t
    valid: int
  }
  
  pending_queues_struct: Pending Queues {
    shape: class
    queues: "pending_queue[32]"
    count: int
  }
}

# ============================================
# LEGEND (FIXED RESERVED KEYWORDS)
# ============================================
legend: {
  label: "Flow Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#757575"
  style.border-radius: 8
  
  flow_normal: Normal Flow {
    shape: rectangle
    style.fill: "#E0E0E0"
  }
  flow_animated: Animated (Active) {
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  flow_error: Miss/Error {
    shape: rectangle
    style.fill: "#FFCCBC"
  }
  flow_success: Success/Complete {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  
  flow_normal -> flow_animated -> flow_error -> flow_success
}

# ============================================
# TIMING ANNOTATIONS
# ============================================
timing: {
  label: "Timing Notes"
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
  shape: rectangle
  
  t1: "• ARP cache lookup: <1μs" {shape: text}
  t2: "• Queue operation: <1μs" {shape: text}
  t3: "• ARP request TX: ~10μs" {shape: text}
  t4: "• Network RTT: 1-10ms (LAN)" {shape: text}
  t5: "• Queue flush: O(n) packets" {shape: text}
  t6: "• Cache TTL: 60 seconds" {shape: text}
  
  style.font-size: 14
}