vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # IP Layer Receive Processing Path
  From Ethernet payload to upper-layer delivery
| {near: top-center}
direction: right
# Input stage
ethernet_payload: "Ethernet Payload\n(IP Packet)" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.font-color: "#333333"
}
# Parsing stage
parse: "Parse IP Header" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  extract: "Extract Fields:\n• Version (4 bits)\n• IHL (4 bits)\n• Total Length\n• ID, Flags, FragOff\n• TTL, Protocol\n• Checksum\n• Src/Dst IP"
}
# Validation stage
validate: "Validate Header" {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  checks: "Checks:\n• Version == 4\n• IHL >= 5\n• Len >= Header\n• Len <= Buffer"
}
# Checksum stage
checksum: "Verify Checksum\n(RFC 1071)" {
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  algo: |md
    Ones' complement sum
    of all 16-bit words
    Result must be 0xFFFF
  |
}
# Fragmentation decision
frag_check: "Is Fragment?\n(MF=1 OR Offset>0)" {
  shape: diamond
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
# Fragment handling
frag_no: "Not Fragmented" {
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
}
frag_yes: "Fragmented" {
  style.fill: "#FFECB3"
  style.stroke: "#FF8F00"
  reassemble: "Reassembly\n• Find context by\n  (src,dst,id,proto)\n• Store fragment\n• Check completeness\n• Timeout: 30s"
}
# Destination check
dest_check: "Destination\nis Local?" {
  shape: diamond
  style.fill: "#E1F5FE"
  style.stroke: "#0277BD"
}
# Local delivery
local_delivery: "Deliver to\nUpper Layer" {
  style.fill: "#B3E5FC"
  style.stroke: "#0277BD"
  protocols: |md
    Protocol Dispatch:
    • 1 → ICMP
    • 6 → TCP
    • 17 → UDP
  |
}
# Non-local handling
non_local: "Drop or\nForward" {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  note: |md
    Host mode: drop
    Router mode: 
    • Decrement TTL
    • Route lookup
    • Forward
  |
}
# Error paths
checksum_fail: "DROP\nChecksum Error" {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-color: "#B71C1C"
}
validate_fail: "DROP\nInvalid Header" {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-color: "#B71C1C"
}
# Connections
ethernet_payload -> parse: "raw bytes" {style.stroke: "#666666"}
parse -> validate: "parsed fields" {style.stroke: "#1565C0"}
validate -> checksum: "header OK" {style.stroke: "#2E7D32"}
validate -> validate_fail: "invalid" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
checksum -> frag_check: "valid" {style.stroke: "#2E7D32"}
checksum -> checksum_fail: "corrupted" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
frag_check -> frag_no: "No" {style.stroke: "#2E7D32"}
frag_check -> frag_yes: "Yes" {style.stroke: "#FF8F00"}
frag_no -> dest_check: "complete packet" {style.stroke: "#2E7D32"}
frag_yes -> dest_check: "reassembled" {style.stroke: "#2E7D32"}
dest_check -> local_delivery: "Yes" {style.stroke: "#0277BD"}
dest_check -> non_local: "No" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
# Legend
legend: |md
  **Flow Legend:**
  🟦 Blue: Parsing/Extraction
  🟧 Orange: Validation
  🟪 Pink: Checksum
  🟩 Green: Fragmentation
  🟦 Cyan: Routing/Delivery
  🟥 Red: Error/Drop
| {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
}