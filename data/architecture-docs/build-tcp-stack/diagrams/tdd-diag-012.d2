vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # IPv4 Header Byte Layout
  ### Standard 20-Byte Minimum (IHL=5)
| {near: top-center}

direction: right

# Offset labels column - Vertical alignment for byte addresses
offsets: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
    font-size: 14
  }
  label: |md
    **Byte Offset**
    0x00 (0)
    0x04 (4)
    0x08 (8)
    0x0C (12)
    0x10 (16)
    0x14 (20)
  |
}

# Container for the packet structure to ensure alignment
packet: {
  # Row 0: Version(4b) + IHL(4b) + TOS(8b) + Total Length(16b)
  row0: {
    grid-columns: 4
    v: {
      label: "Version\n(4 bits)"
      tooltip: "Typically 4 for IPv4"
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
      width: 60
    }
    ihl: {
      label: "IHL\n(4 bits)"
      tooltip: "Internet Header Length in 32-bit words"
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
      width: 60
    }
    tos: {
      label: "Type of Service / DSCP\n(8 bits)"
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
      width: 120
    }
    totlen: {
      label: "Total Length\n(16 bits)"
      tooltip: "Total length of packet (header + data) in bytes"
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
      width: 240
    }
  }

  # Row 1: Identification (16b) + Flags(3b) + Fragment Offset(13b)
  row1: {
    grid-columns: 3
    id: {
      label: "Identification\n(16 bits)"
      style: {
        fill: "#D4E6F1"
        stroke: "#2874A6"
        stroke-width: 2
      }
      width: 240
    }
    flags: {
      label: "Flags\n(3 bits)"
      style: {
        fill: "#D4E6F1"
        stroke: "#2874A6"
        stroke-width: 2
      }
      width: 60
    }
    fragoff: {
      label: "Fragment Offset\n(13 bits)"
      style: {
        fill: "#D4E6F1"
        stroke: "#2874A6"
        stroke-width: 2
      }
      width: 180
    }
  }

  # Row 2: TTL(8b) + Protocol(8b) + Checksum(16b)
  row2: {
    grid-columns: 3
    ttl: {
      label: "Time to Live\n(8 bits)"
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
      width: 120
    }
    proto: {
      label: "Protocol\n(8 bits)"
      tooltip: "Next level protocol (e.g., TCP=6, UDP=17)"
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
      width: 120
    }
    cksum: {
      label: "Header Checksum\n(16 bits)"
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
      width: 240
    }
  }

  # Row 3: Source IP Address (32b)
  row3: {
    srcip: {
      label: "Source IP Address\n(32 bits)"
      style: {
        fill: "#D5F5E3"
        stroke: "#27AE60"
        stroke-width: 2
        bold: true
      }
      width: 480
    }
  }

  # Row 4: Destination IP Address (32b)
  row4: {
    dstip: {
      label: "Destination IP Address\n(32 bits)"
      style: {
        fill: "#D5F5E3"
        stroke: "#27AE60"
        stroke-width: 2
        bold: true
      }
      width: 480
    }
  }

  # Row 5: Options (Optional, 0-40 bytes)
  row5: {
    options: {
      label: "Options / Padding\n(0 to 320 bits)"
      style: {
        fill: "#F2F3F4"
        stroke: "#7F8C8D"
        stroke-dash: 3
      }
      width: 480
    }
  }
}

# Layout constraints to keep offsets next to the packet
offsets -> packet: {style.stroke: transparent}

# Size and Implementation annotations
size_note: |md
  ### Header Metadata
  - **Minimum Size:** 20 Bytes (when IHL = 5)
  - **Maximum Size:** 60 Bytes (when IHL = 15)
  - **Word Size:** 32 bits (4 bytes)
  - **Total Length Limit:** 65,535 bytes
| {near: bottom-left}

# Detailed Legend
legend: {
  near: bottom-right
  label: |md
    ### Field Categories
    - <span style="color:#8B5A8B">■</span> **Control/Management**: Purple
    - <span style="color:#2874A6">■</span> **Fragmentation/ID**: Blue
    - <span style="color:#27AE60">■</span> **Addressing**: Green
    - <span style="color:#7F8C8D">■</span> **Optional/Padding**: Gray
  |
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#CCCCCC"
    border-radius: 4
  }
}