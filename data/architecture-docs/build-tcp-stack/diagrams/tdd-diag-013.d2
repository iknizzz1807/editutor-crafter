direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: {
  shape: text
  near: top-center
  label: |md
    # IP Checksum Algorithm (RFC 1071)
    ### Implementation-Grade Logic for IPv4/TCP/UDP Checksums
  |
  style: {
    font-size: 24
    bold: true
  }
}

# -----------------------------------------------------------------------------------------
# CLASSES & STYLING
# -----------------------------------------------------------------------------------------
classes: {
  step_box: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      font-color: "#0D47A1"
      border-radius: 4
      shadow: true
    }
  }
  data_structure: {
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
      border-radius: 4
    }
  }
  result_state: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 3
      bold: true
      border-radius: 6
    }
  }
  calculation_logic: {
    style: {
      font: mono
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      stroke-dash: 2
    }
  }
  highlight_red: {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------------------
# ALGORITHM FLOW
# -----------------------------------------------------------------------------------------
Algorithm: {
  Step1: {
    class: step_box
    label: |md
      ## 1. Initialization
      - **Field:** Checksum = `0x0000`
      - **Accumulator:** 32-bit `sum = 0`
      - **Pointer:** `p = header_start`
    |
  }

  Step2: {
    class: step_box
    label: |md
      ## 2. 16-bit Summation
      - Iteratively add 16-bit words to `sum`
      - `sum += (p[i] << 8) | p[i+1]`
      - **Odd Byte Handling:** Pad with `0x00`
    |
  }

  Step3: {
    class: step_box
    label: |md
      ## 3. Fold Carries
      - Add bits 16-31 to bits 0-15
      - `sum = (sum & 0xFFFF) + (sum >> 16)`
      - Repeat until no carries remain
    |
  }

  Step4: {
    class: step_box
    label: |md
      ## 4. Ones' Complement
      - Apply bitwise `NOT` to 16-bit result
      - `result = ~sum`
    |
  }

  Step5: {
    class: result_state
    label: |md
      ## 5. Result
      - Store in header at offset `0x0A`
    |
  }

  Step1 -> Step2: "Initialize Sum"
  Step2 -> Step3: "Aggregate Carry Bits"
  Step3 -> Step4: "Final 16-bit Fold"
  Step4 -> Step5: "Invert for Checksum"
}

# -----------------------------------------------------------------------------------------
# DATA VISUALIZATION
# -----------------------------------------------------------------------------------------
Header_Layout: {
  label: "IPv4 Header Byte Layout (RFC 791)"
  shape: sql_table
  class: data_structure
  
  "0x00": "0x4500 (Ver/IHL/TOS)"
  "0x02": "0x0014 (Total Length)"
  "0x04": "0x1234 (Identification)"
  "0x06": "0x0000 (Flags/Offset)"
  "0x08": "0x4006 (TTL/Protocol)"
  "0x0A": "0x0000 (Checksum Field)" {
    class: highlight_red
  }
  "0x0C": "0xC0A8 0x0101 (Source IP)"
  "0x10": "0xC0A8 0x0102 (Dest IP)"
}

Calculation_Detail: {
  Folding_Logic: {
    class: calculation_logic
    label: |md
      ### Fold Detail (End-Around Carry)
      **Input:** 32-bit Sum: `0x0002_BBCD`
      1. **Mask Low:** `sum & 0xFFFF` → `0xBBCD`
      2. **Shift High:** `sum >> 16` → `0x0002`
      3. **Accumulate:** `0xBBCD + 0x0002 = 0xBBCF`
    |
  }

  Verification: {
    class: result_state
    label: |md
      ### Receiver Verification
      1. Sum entire header (incl. checksum)
      2. Sum should be `0xFFFF`
      3. `~sum == 0x0000` (Packet Valid)
    |
  }
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS & ANNOTATIONS
# -----------------------------------------------------------------------------------------
Algorithm.Step2 -> Header_Layout: "Load 16-bit chunks" {
  style.stroke-dash: 5
}

Algorithm.Step3 -> Calculation_Detail.Folding_Logic: "Logical expansion"

Algorithm.Step5 -> Calculation_Detail.Verification: "Hand-off to Receiver"

# -----------------------------------------------------------------------------------------
# CODE IMPLEMENTATION
# -----------------------------------------------------------------------------------------
Implementation: {
  shape: rectangle
  near: bottom-center
  label: |go
    // RFC 1071 Compliant Checksum Implementation
    func CalculateChecksum(data []byte) uint16 {
        var sum uint32

        // Step 2: Sum 16-bit words
        for i := 0; i < len(data)-1; i += 2 {
            sum += uint32(data[i])<<8 | uint32(data[i+1])
        }

        // Handle odd-length data
        if len(data)%2 != 0 {
            sum += uint32(data[len(data)-1]) << 8
        }

        // Step 3: Fold 32-bit sum into 16 bits
        // Repeat addition of carry bits
        for (sum >> 16) > 0 {
            sum = (sum & 0xffff) + (sum >> 16)
        }

        // Step 4: Return ones' complement
        return ^uint16(sum)
    }
  |
  style: {
    fill: "#F5F5F5"
    stroke: "#212121"
    font-size: 12
  }
}

# Footer metadata
Footer: {
  shape: text
  near: bottom-right
  label: |md
    **Notes on Architecture:**
    - **One-Pass Sum:** Accumulate in 32-bit register.
    - **Endianness:** Algorithm is byte-order independent.
    - **Padding:** Odd-sized buffers padded with `0x00`.
  |
}