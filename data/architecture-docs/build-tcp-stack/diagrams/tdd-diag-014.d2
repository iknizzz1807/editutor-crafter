title: {
  label: |md
    # IP Fragmentation and Reassembly (RFC 791)
    **Implementation Spec:** Fragment Offset (13-bit) is measured in 8-byte units.
  |
  near: top-center
}

# 1. Original Datagram Construction
original: {
  label: "Original IP Datagram (MTU > 1500)"
  
  memory_layout: {
    grid-columns: 1
    grid-gap: 0
    
    h: "IP Header" {
      width: 400
      height: 60
      style.fill: "#B19CD9"
      tooltip: "ID=0x1234, Flags: DF=0, MF=0, Offset=0"
    }
    p: "Data Payload (2980 Bytes)" {
      width: 400
      height: 120
      style.fill: "#6CB4EE"
    }
    
    offsets: {
      o0: "0" {shape: text}
      o20: "20" {shape: text}
      o3000: "3000" {shape: text}
    }
  }
  
  meta_info: {
    label: |md
      **Header Fields:**
      - Identification: 0x1234
      - Total Length: 3000
      - Flags: [0][DF=0][MF=0]
      - Fragment Offset: 0
    |
    style.stroke-dash: 2
    style.border-radius: 5
  }
}

# 2. Fragmentation Event
router: "L3 Router\n(Egress MTU=1500)" {
  shape: diamond
  style.fill: "#FFF8DC"
  style.stroke-width: 3
}

original -> router: "Size (3000) > MTU (1500)" {
  style.stroke: red
  style.animated: true
}

# 3. Fragment Generation
fragments: {
  label: "Generated IP Fragments (Wire Format)"
  style.stroke-dash: 3

  f1: {
    label: "Fragment 1"
    h: "IP HDR (20B)" { style.fill: "#B19CD9" }
    d: "Data 0-1479" { style.fill: "#6CB4EE"; style.stroke: "#FF6B6B"; style.stroke-width: 3 }
    h -> d
    meta: "Len: 1500\nMF: 1\nOff: 0" {
      shape: text
    }
  }

  f2: {
    label: "Fragment 2"
    h: "IP HDR (20B)" { style.fill: "#B19CD9" }
    d: "Data 1480-2959" { style.fill: "#6CB4EE"; style.stroke: "#4ECDC4"; style.stroke-width: 3 }
    h -> d
    meta: "Len: 1500\nMF: 1\nOff: 185" {
      shape: text
    }
  }

  f3: {
    label: "Fragment 3"
    h: "IP HDR (20B)" { style.fill: "#B19CD9" }
    d: "Data 2960-2979" { style.fill: "#6CB4EE"; style.stroke: "#45B7D1"; style.stroke-width: 3 }
    h -> d
    meta: "Len: 40\nMF: 0\nOff: 370" {
      shape: text
    }
  }
}

router -> fragments: "Segmentation Logic"

# 4. Wire Specification
frag_details: {
  label: ||md
    ### IP Fragment Header Fields
    | Fragment | Total Len | ID | MF | Offset (8B units) | Data Range |
    | :--- | :--- | :--- | :--- | :--- | :--- |
    | **Frag 1** | 1500 | 0x1234 | **1** | 0 | 0 - 1479 |
    | **Frag 2** | 1500 | 0x1234 | **1** | 185 | 1480 - 2959 |
    | **Frag 3** | 40 | 0x1234 | **0** | 370 | 2960 - 2979 |
  ||
  style.stroke: "#333"
}

fragments -> frag_details

# 5. Reassembly Buffer
reassembly_engine: {
  label: "Host Reassembly Engine"
  
  buffer: "Buffer [ID: 0x1234]" {
    grid-columns: 3
    grid-gap: 2
    
    b0: "Chunk 1" { 
      style.fill: "#FF6B6B"
      style.opacity: 0.5
    }
    b1480: "Chunk 2" { 
      style.fill: "#4ECDC4"
      style.opacity: 0.5
    }
    b2960: "Chunk 3" { 
      style.fill: "#45B7D1"
      style.opacity: 0.5
    }
    
    b0 -> b1480 -> b2960: "Validate MF=0 Terminal"
  }
  
  logic: {
    label: ||md
      ### Reassembly Algorithm
      c
      u16 actual_offset = fragment.offset * 8;
      if (actual_offset == buffer.expected_ptr) {
          copy_to_buffer(buffer, fragment.data, fragment.len);
          buffer.expected_ptr += fragment.len;
          if (fragment.MF == 0) {
              dispatch_to_upper_layer(buffer);
          }
      } else {
          queue_out_of_order(fragment);
          check_for_gaps();
      }
      
    ||
  }
}

frag_details -> reassembly_engine: "Arrival (Possible Reordering)" {
  style.stroke-dash: 5
  style.stroke: orange
}

# 6. Final State
reassembled: {
  label: "Reassembled Datagram"
  style.stroke: green
  style.stroke-width: 4
  
  hdr: "IP Header" { style.fill: "#B19CD9" }
  payload: "Full Data (2980B)" { style.fill: "#6CB4EE" }
  hdr -> payload
}

reassembly_engine -> reassembled: "Linearized Buffer"

# 7. Error Handling
timeout_state: {
  label: ||md
    ### Reassembly Timeout
    - **Timer:** 60s (Default)
    - **Action:** Drop all segments
    - **ICMP:** Type 11, Code 1
  ||
  style.fill: "#FFE4E1"
  style.stroke: red
}

reassembly_engine -> timeout_state: "TTL Expired" {
  style.stroke: red
  style.stroke-dash: 2
}

# Footer Documentation
footer: {
  label: ||md
    ## Critical Constraints for Implementation
    1. **8-Byte Alignment:** Every fragment (except the last) MUST have a length that is a multiple of 8 bytes.
    2. **Overlapping:** If Fragment B overlaps Fragment A, the implementation must resolve (standard: favor later data or discard).
    3. **Total Size:** Reassembled size must not exceed 65,535 bytes (IP max).
  ||
  near: bottom-center
}

# Styling Globs
***.style.font-size: 14
fragments.**.style.font-size: 11
reassembly_engine.**.style.font-size: 11
reassembly_engine.logic.style.font: mono