vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # IP Fragment Reassembly Buffer Structure
  Per RFC 791 - Fragment Context & Linked List
| {near: top-center}

direction: right

# --- REASSEMBLY CONTEXT (64B) ---
# Aligned to cache line boundaries to prevent false sharing in multi-threaded stacks.
context: Fragment Reassembly Context {
  style: {
    fill: "#E8E4F0"
    stroke: "#7B68EE"
    stroke-width: 2
  }
  header: |md
    **Fragment Context** (per datagram)
    Key: (src_ip, dst_ip, id, protocol)
  | {
    style.fill: "#7B68EE"
    style.font-color: white
    style.bold: true
  }
  grid-rows: 9
  grid-gap: 0

  src_ip: "0x00 | src_ip: 0x0A000001 | 4B" {
    style.fill: "#C8A2C8"
    style.stroke: "#7B68EE"
  }
  dst_ip: "0x04 | dst_ip: 0x0A000002 | 4B" {
    style.fill: "#C8A2C8"
    style.stroke: "#7B68EE"
  }
  frag_id: "0x08 | identification: 0x1234 | 2B" {
    style.fill: "#C8A2C8"
    style.stroke: "#7B68EE"
  }
  proto: "0x0A | protocol: 6 (TCP) | 1B" {
    style.fill: "#C8A2C8"
    style.stroke: "#7B68EE"
  }
  pad0: "0x0B | [padding] | 5B" {
    style.fill: "#D3D3D3"
    style.stroke: "#7B68EE"
  }
  frags_ptr: "0x10 | *frags: → head node | 8B" {
    style.fill: "#FFA500" # Orange for Pointers
    style.stroke: "#7B68EE"
  }
  total_len: "0x18 | total_len: 2000 | 4B" {
    style.fill: "#98D8C8"
    style.stroke: "#7B68EE"
  }
  expires: "0x1C | expires_at: T+30s | 8B" {
    style.fill: "#FFB6C1"
    style.stroke: "#7B68EE"
  }
  in_use: "0x24 | in_use: 1 | 1B" {
    style.fill: "#98FB98"
    style.stroke: "#7B68EE"
  }
}

# --- FRAGMENT NODE STRUCTURE ---
# Representing a single hole or received fragment metadata
node_struct: Fragment Node Structure {
  style: {
    fill: "#E0F0FF"
    stroke: "#4169E1"
    stroke-width: 2
  }
  node_header: "**frag_node** (24 bytes each)" {
    style.fill: "#4169E1"
    style.font-color: white
    style.bold: true
  }
  grid-rows: 5
  grid-gap: 0
  offset: "0x00 | offset: 0 | 4B" {
    style.fill: "#B0C4DE"
    style.stroke: "#4169E1"
  }
  len: "0x04 | len: 500 | 4B" {
    style.fill: "#B0C4DE"
    style.stroke: "#4169E1"
  }
  data_ptr: "0x08 | *data: → payload | 8B" {
    style.fill: "#FFA500"
    style.stroke: "#4169E1"
  }
  is_last: "0x10 | is_last: 0 | 1B" {
    style.fill: "#98FB98"
    style.stroke: "#4169E1"
  }
  next_ptr: "0x11 | *next: → next node | 8B" {
    style.fill: "#FFA500"
    style.stroke: "#4169E1"
  }
}

# --- LINKED LIST VISUALIZATION ---
linked_list: Sorted Fragment List {
  style: {
    fill: "#F5F5DC"
    stroke: "#8B4513"
    stroke-width: 2
    border-radius: 8
  }
  list_header: |md
    **Linked List (sorted by offset)**
    Fragments received: [0-500], [500-1000], [1500-2000]
  | {
    style.fill: "#8B4513"
    style.font-color: white
    style.bold: true
  }
  direction: right
  node0: Fragment 1 {
    style.fill: "#98D8C8"
    style.stroke: "#2E8B57"
    n0_offset: "offset: 0"
    n0_len: "len: 500"
    n0_data: "data: [bytes 0-499]"
    n0_last: "is_last: 0"
  }
  node1: Fragment 2 {
    style.fill: "#98D8C8"
    style.stroke: "#2E8B57"
    n1_offset: "offset: 500"
    n1_len: "len: 500"
    n1_data: "data: [bytes 500-999]"
    n1_last: "is_last: 0"
  }
  gap: GAP {
    style.fill: "#FF6B6B"
    style.stroke: "#CC0000"
    style.bold: true
    style.stroke-dash: 4
  }
  node2: Fragment 3 {
    style.fill: "#98D8C8"
    style.stroke: "#2E8B57"
    n2_offset: "offset: 1500"
    n2_len: "len: 500"
    n2_data: "data: [bytes 1500-1999]"
    n2_last: "is_last: 1"
  }
  node0 -> node1: "*next"
  node1 -> gap: "*next"
  gap -> node2: "missing!"
}

# --- REASSEMBLED DATAGRAM ---
reassembled: Reassembled Datagram {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }
  reassembled_header: |md
    **Reassembled Output** (when complete)
    Original IP header + concatenated payloads
  | {
    style.fill: "#2E7D32"
    style.font-color: white
    style.bold: true
  }
  grid-rows: 2
  grid-gap: 0
  ip_hdr: "IP Header (restored)" {
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
  }
  payload: "Payload (2000 bytes)" {
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
}

# --- CACHE LINE ANALYSIS ---
memory: Memory Layout Analysis {
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    stroke-width: 2
  }
  mem_header: "**64-byte Cache Line** usage per context" {
    style.fill: "#FF8F00"
    style.font-color: white
    style.bold: true
  }
  grid-rows: 1
  grid-columns: 4
  grid-gap: 0
  cl0: "CL0: Context" {
    style.fill: "#FFE082"
    style.stroke: "#FF8F00"
    style.stroke-dash: 5
  }
  cl1: "CL1: Unused Space" {
    style.fill: "#E0E0E0"
    style.stroke: "#9E9E9E"
    style.stroke-dash: 5
  }
  cl2: "CL2: Unused Space" {
    style.fill: "#E0E0E0"
    style.stroke: "#9E9E9E"
    style.stroke-dash: 5
  }
  cl3: "CL3: Fragment Nodes" {
    style.fill: "#FFCC80"
    style.stroke: "#FF8F00"
    style.stroke-dash: 5
  }
}

# --- CONNECTIONS & POINTERS ---
context.frags_ptr -> linked_list.node0: "head_ptr" {
  style.stroke: "#FFA500"
  style.stroke-width: 2
}

# --- DOCUMENTATION & INVARIANTS ---
annotations: |md
  ## Invariants
  - List sorted by **offset** (ascending)
  - Gap detection: node[i].offset + node[i].len < node[i+1].offset
  - Complete when: have_last_frag AND no gaps
  - Timeout: 30 seconds (RFC 791)
  ## Key Fields
  - **src_ip/dst_ip**: 32-bit host byte order
  - **id**: IP identification field (16-bit)
  - **protocol**: IP protocol (TCP=6, UDP=17)
  - **expires_at**: system_ticks + FRAG_TIMEOUT
| {
  near: bottom-center
  style.fill: transparent
  style.font-size: 14
}

# --- GLOBAL REASSEMBLER MANAGER ---
reassembler: Global Reassembler {
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
  reasm_header: |md
    **frag_reassembler** (4KB total)
    FRAG_TABLE_SIZE = 64 contexts
  | {
    style.fill: "#9E9E9E"
    style.font-color: white
  }
  contexts_map: "contexts[64]" {
    style.fill: "#E0E0E0"
    style.stroke: "#9E9E9E"
    style.multiple: true
  }
  stats: Statistics {
    stats_timeouts: "timeouts: 0"
    stats_completed: "completed: 0"
    stats_dropped: "dropped: 0"
  }
}

reassembler.contexts_map -> context: "mapped indices"