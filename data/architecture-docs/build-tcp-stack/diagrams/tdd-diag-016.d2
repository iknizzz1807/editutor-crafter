vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Routing Table: Longest Prefix Match (LPM)
  ### Trie-Based PATRICIA Structure Implementation
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --- STYLING CLASSES ---
classes: {
  node: {
    shape: circle
    width: 80
    height: 80
    style: {
      fill: white
      stroke: "#2C3E50"
      stroke-width: 2
      font-size: 14
    }
  }
  route_entry: {
    shape: rectangle
    style: {
      fill: "#D5F5E3"
      stroke: "#27AE60"
      stroke-width: 2
      border-radius: 4
      font-size: 13
    }
  }
  highlight_winner: {
    shape: rectangle
    style: {
      fill: "#F1C40F"
      stroke: "#D4AC0D"
      stroke-width: 4
      bold: true
      border-radius: 8
      shadow: true
    }
  }
  bit_edge: {
    style: {
      stroke: "#34495E"
      stroke-width: 1.5
      font-size: 14
      font: mono
    }
  }
  traversal_path: {
    style: {
      stroke: "#E74C3C"
      stroke-width: 4
      animated: true
      bold: true
    }
  }
  annotation: {
    shape: text
    style: {
      font-color: "#7F8C8D"
      italic: true
      font-size: 14
    }
  }
}

# --- INPUT QUERY ---
lookup_context: {
  near: top-left
  
  query: "Target: 10.0.1.5" {
    shape: rectangle
    style: {
      fill: "#E74C3C"
      stroke: "#C0392B"
      stroke-width: 3
      font-color: white
      bold: true
      border-radius: 8
      font-size: 20
    }
  }

  binary_repr: |md
    **Search Key (32-bit Binary)**
    `00001010` . `00000000` . `00000001` . `00000101`
    [Byte 0] . [Byte 1] . [Byte 2] . [Byte 3]
  | {
    shape: rectangle
    style: {
      fill: "#FEF9E7"
      stroke: "#F1C40F"
      border-radius: 4
    }
  }
}

# --- THE TRIE STRUCTURE ---

# Level 0: Root
root: "Root\n(∅)" {
  class: node
  style.fill: "#EBEDEF"
}

# Level 1: /8 Prefix (Byte 0)
n_10: "Byte 0 Match\n[10.x.x.x]" {
  class: node
  tooltip: "Match bits 1-8: 00001010"
}
root -> n_10: "00001010" {class: traversal_path}

r8: "ENTRY: 10.0.0.0/8\nGW: 192.168.1.1\nMetric: 100" {
  class: route_entry
}
n_10 -> r8: "match /8" {style.stroke-dash: 3; style.stroke: "#27AE60"}

# Level 2: /16 Prefix (Byte 1)
n_10_0: "Byte 1 Match\n[10.0.x.x]" {
  class: node
  tooltip: "Match bits 9-16: 00000000"
}
n_10 -> n_10_0: "00000000" {class: traversal_path}

# Level 3: /24 Prefix (Byte 2)
n_10_0_1: "Byte 2 Match\n[10.0.1.x]" {
  class: node
  tooltip: "Match bits 17-24: 00000001"
}
n_10_0 -> n_10_0_1: "00000001" {class: traversal_path}

r24: "ENTRY: 10.0.1.0/24\nGW: 10.0.1.254\nMetric: 50" {
  class: route_entry
}
n_10_0_1 -> r24: "match /24" {style.stroke-dash: 3; style.stroke: "#27AE60"}

# Level 4: /30 Prefix (The Longest Match)
n_10_0_1_4: "Byte 3 Partial\n[10.0.1.4/30]" {
  class: node
  tooltip: "Match bits 25-30: 000001"
}
n_10_0_1 -> n_10_0_1_4: "000001" {class: traversal_path}

r30_winner: "WINNER: 10.0.1.4/30\nGW: 172.16.0.1\nMetric: 10\n(30 Bits Match)" {
  class: highlight_winner
}
n_10_0_1_4 -> r30_winner: "BEST MATCH" {
  style: {
    stroke: "#D4AC0D"
    stroke-width: 4
  }
}

# --- DOCUMENTATION & LEGEND ---

analysis_blocks: {
  near: bottom-right
  
  bits: {
    label: "Bit-Level Match Depth"
    grid-columns: 1
    style.fill: "#F4F6F7"
    
    b1: "Octet 1: 00001010 (Matches /8)" {style.font: mono; style.font-color: green}
    b2: "Octet 2: 00000000 (Matches /16)" {style.font: mono; style.font-color: green}
    b3: "Octet 3: 00000001 (Matches /24)" {style.font: mono; style.font-color: green}
    b4: "Octet 4: 000001 | 01 (Matches /30)" {style.font: mono; style.font-color: green}
  }

  algorithm_logic: |md
    ### LPM Resolution Rules
    1. **Iterate** bits of destination IP.
    2. **Traverse** Trie branches corresponding to bit values.
    3. **Record** every route entry encountered (Valid match).
    4. **Terminate** when no further child node matches or IP ends.
    5. **Select** the entry with the highest mask length (prefix).
  | {
    shape: rectangle
    style: {
      fill: "#EBF5FB"
      stroke: "#3498DB"
      border-radius: 8
    }
  }
}

legend: {
  near: top-right
  
  l1: "Node (Trie Level)" { class: node }
  l2: "Stored Route" { class: route_entry }
  l3: "Active Path" { 
    shape: rectangle
    style.stroke: "#E74C3C"
    style.stroke-width: 4
  }
}

result_summary: |md
  ## Routing Decision Result
  *   **Target IP:** 10.0.1.5
  *   **Candidates Found:**
      *   10.0.0.0/8 (Depth 1)
      *   10.0.1.0/24 (Depth 3)
      *   10.0.1.4/30 (Depth 4 - **Winner**)
  *   **Decision:** **10.0.1.4/30**
  *   **Next Hop:** Gateway 172.16.0.1
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FEF9E7"
    stroke: "#F1C40F"
    stroke-width: 2
    border-radius: 12
    shadow: true
  }
}

# --- PATH EXPLANATION ANNOTATIONS ---
lookup_context -> root: "Start Traversal" {style.stroke: "#7F8C8D"; style.stroke-dash: 5}

traversal_step1: "1. Match First Byte" { class: annotation; near: top-left }
traversal_step2: "2. Descend to Subnet" { class: annotation; near: center-left }
traversal_step3: "3. Identify Longest match" { class: annotation; near: bottom-left }