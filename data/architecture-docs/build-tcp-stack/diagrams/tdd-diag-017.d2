vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  # Technical parameters for the ICMP packet
  id: "7F3E"
  seq: "0001"
}

shape: sequence_diagram

# Participants with specific types and roles
sender: Network Client {
  label: "Sender\n(ICMP Source)"
  style.stroke: "#1976D2"
}

receiver: Network Target {
  label: "Receiver\n(ICMP Destination)"
  style.stroke: "#2E7D32"
}

# ICMP Message Format Reference (for engineers)
# [0-7 bits] Type | [8-15 bits] Code | [16-31 bits] Checksum
# [32-47 bits] Identifier | [48-63 bits] Sequence Number

# Sequence Start: Echo Request
sender -> receiver: "ICMP Echo Request (Type 8)" {
  label: "Type: 8, Code: 0\nIdentifier: 0x${id}\nSequence: ${seq}\nData: [Timestamp + Payload]"
  style: {
    stroke: "#1976D2"
    stroke-width: 4
  }
}

# Receiver In-stack Processing Sequence
receiver."1. Validate IP Header Checksum" {
  style.font-size: 14
}
receiver."2. Verify ICMP Checksum (CRC-16)" {
  style.font-size: 14
}
receiver."3. Filter ICMP Type 8 (Echo Request)" {
  style.font-size: 14
}
receiver."4. Prepare Mirror Buffer" {
  style.font-size: 14
  tooltip: "Preserve Identifier and Sequence for Reply"
}

# Sequence Response: Echo Reply
receiver -> sender: "ICMP Echo Reply (Type 0)" {
  label: "Type: 0, Code: 0\nIdentifier: 0x${id}\nSequence: ${seq}\nData: [Same Payload]"
  style: {
    stroke: "#2E7D32"
    stroke-width: 4
    stroke-dash: 0
  }
}

# Sender Completion & Timing
sender."5. Match Identifier 0x${id}" {
  style.font-size: 14
}
sender."6. Verify Sequence ${seq}" {
  style.font-size: 14
}
sender."7. Measure RTT (Round-Trip Time)" {
  style: {
    bold: true
    font-size: 16
    font-color: "#D32F2F"
  }
}

# Global Styling for Sequence Lifelines
***: {
  style: {
    font-size: 18
  }
}