layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# -----------------------------------------------------------------------------------
# GLOBAL STYLES & CLASSES
# -----------------------------------------------------------------------------------
classes: {
  router: {
    shape: hexagon
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
  packet: {
    shape: rectangle
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
  error_state: {
    shape: diamond
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
  icmp_fmt: {
    shape: rectangle
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  process_step: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 4
    }
  }
  # Memory Layout Classes (Intel Manual Style)
  mem_header: {
    shape: rectangle
    style: {
      font: mono
      font-size: 11
      stroke: "#424242"
      stroke-width: 1
    }
  }
  offset_label: {
    shape: text
    style: {
      font: mono
      font-size: 10
      font-color: "#757575"
    }
  }
}

# -----------------------------------------------------------------------------------
# DOCUMENT STRUCTURE
# -----------------------------------------------------------------------------------
title: |md
  # TTL Handling and Time Exceeded (ICMP Type 11)
  ### RFC 792 / RFC 1812: Per-hop decrement and error generation
| {near: top-center}

# Root container to handle vertical layout without using invalid 'near' object references
specification: {
  grid-columns: 1
  vertical-gap: 50

  # 1. NETWORK FLOW VISUALIZATION
  network_flow: Network Path Lifecycle {
    direction: right
    
    src: Source Host { 
      class: router
      style.fill: "#C8E6C9" 
    }
    r1: Router 1 { class: router }
    r2: Router 2 { class: router }
    r3: Router 3 (Drop Point) {
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#D32F2F"
        stroke-width: 3
        double-border: true
      }
    }
    dest: Destination { 
      class: router
      style.fill: "#E0E0E0" 
    }

    src -> r1: "IP [TTL=64]" { style.stroke: "#1976D2"; style.stroke-width: 3 }
    r1 -> r2: "Forward [TTL=63]" { style.stroke: "#1976D2" }
    r2 -> r3: "Ingress [TTL=1]" { style.stroke: "#1976D2"; style.stroke-dash: 4 }
    r3 -> dest: "❌ TTL=0 (DROP)" {
      style: {
        stroke: "#D32F2F"
        stroke-dash: 5
        stroke-width: 2
      }
    }
    r3 -> src: "ICMP Type 11 (Time Exceeded)" {
      class: icmp_fmt
      style: {
        stroke: "#7B1FA2"
        stroke-width: 2
        animated: true
      }
    }
  }

  # 2. ALGORITHM LOGIC
  algorithm: Router TTL Processing Logic {
    direction: down
    
    s1: "Step 1: Inbound Packet Parsing\nExtract IP Header Byte 8" { class: process_step }
    s2: "Step 2: Check TTL Value\nIs Inbound TTL > 1?" { 
      class: process_step
      shape: diamond 
    }
    
    s2_yes: "Step 3a: Forwarding Path\n1. TTL = TTL - 1\n2. Update Checksum (Incremental)\n3. Route to L2 Out Interface" {
      class: process_step
      style.fill: "#C8E6C9"
    }
    
    s2_no: "Step 3b: ICMP Path\n1. Discard Original Datagram\n2. Prepare ICMP Payload (Header+64bits)\n3. Send ICMP Type 11 Code 0 to Source" {
      class: error_state
    }
    
    s1 -> s2
    s2 -> s2_yes: "YES (TTL > 1)"
    s2 -> s2_no: "NO (TTL <= 1)"
  }

  # 3. IP HEADER MEMORY MAP
  ip_view: IP Header Layout (32-bit Words) {
    grid-columns: 1
    grid-gap: 0

    header_bits: "0..............7..............15..............23..............31" {
      shape: text
      style.font: mono
    }

    word0: {
      grid-columns: 4
      grid-gap: 0
      v: "Ver (4b)" { class: mem_header; style.fill: "#E1BEE7" }
      ihl: "IHL (4b)" { class: mem_header; style.fill: "#E1BEE7" }
      tos: "ToS (8b)" { class: mem_header; style.fill: "#E1BEE7" }
      len: "Total Length (16b)" { class: mem_header; style.fill: "#E1F5FE"; width: 200 }
    }
    
    word1: "Identification (16b) | Flags (3b) | Fragment Offset (13b)" {
      class: mem_header
      style.fill: "#E1F5FE"
    }
    
    word2: {
      grid-columns: 3
      grid-gap: 0
      ttl: "TTL (8b)\nByte 8" { 
        class: mem_header
        style: {
          fill: "#FFCDD2"
          stroke: "#D32F2F"
          bold: true
          stroke-width: 2
        }
      }
      proto: "Protocol (8b)" { class: mem_header; style.fill: "#E1BEE7" }
      csum: "Header Checksum (16b)" { class: mem_header; style.fill: "#FFF9C4"; width: 200 }
    }

    word3: "Source IP Address (32 bits)" { class: mem_header; style.fill: "#E1F5FE" }
    word4: "Destination IP Address (32 bits)" { class: mem_header; style.fill: "#E1F5FE" }

    footer: |md
      **Note:** Byte offset 8 (TTL) is the trigger for Type 11 generation.
      Checksum must be recalculated after TTL decrement.
    | {
      shape: rectangle
      style: {
        font-size: 11
        stroke-dash: 3
        fill: "#FAFAFA"
      }
    }
  }

  # 4. ICMP PACKET STRUCTURE
  icmp_layout: ICMP Type 11 Message Format {
    grid-columns: 1
    grid-gap: 0

    header_bits: "0..............7..............15..............23..............31" {
      shape: text
      style.font: mono
    }

    row1: {
      grid-columns: 3
      grid-gap: 0
      type: "Type: 11 (8b)" { 
          class: mem_header
          style.fill: "#CE93D8" 
          tooltip: "Time Exceeded"
      }
      code: "Code: 0 (8b)" { 
          class: mem_header
          style.fill: "#E1BEE7" 
          tooltip: "TTL exceeded in transit"
      }
      checksum: "Checksum (16b)" { class: mem_header; style.fill: "#FFF9C4"; width: 200 }
    }
    
    row2: "Unused / Reserved (32 bits) - Must be Zero" { 
      class: mem_header
      style.fill: "#F5F5F5"
      style.font-color: "#9E9E9E"
    }
    
    payload: Original IP Header + First 64 bits of Original Payload {
      class: mem_header
      style: {
        fill: "#E3F2FD"
        stroke-dash: 4
      }
    }
    
    footer: "RFC 792: Return header + 64 bits allows source to identify process/socket." {
      shape: text
      style.font-size: 10
    }
  }

  # 5. TRACEROUTE MECHANICS (Operational)
  stats: Traceroute Operational View {
    grid-columns: 1
    style: {
      stroke: "#7B1FA2"
      stroke-dash: 2
      fill: "#F3E5F5"
    }
    t1: "Probe Cycle 1: [TTL=1] -> Router 1 sends Type 11" { shape: text }
    t2: "Probe Cycle 2: [TTL=2] -> Router 2 sends Type 11" { shape: text }
    t3: "Probe Cycle 3: [TTL=3] -> Router 3 sends Type 11" { shape: text }
  }
}

# Legend for Diagram
legend: {
  near: bottom-right
  
  h: Header Field { style.fill: "#E1BEE7" }
  d: Data Field { style.fill: "#E1F5FE" }
  e: Error Field { style.fill: "#FFCDD2" }
}