vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header_main: "#8B478F"
    header_alt: "#9B5CA6"
    checksum: "#7B3D8C"
    data_blue: "#4682B4"
    data_light: "#5A9BC7"
    reserved_gray: "#808080"
    pointer_orange: "#FF8C00"
    bg: "#FFFFFF"
    border: "#1A1A1A"
    row_even: "#F8F9FA"
    offset_text: "#666666"
  }
}

title: |'md
  # ICMP Packet Memory Layout (RFC 792)
  **Alignment:** 32-bit (4-byte) boundaries
  **Total Header Size:** 8 Bytes Fixed
'| {near: top-center}

# Main Layout Container
Packet_Structure: {
  style: {
    fill: "${colors.bg}"
    stroke: "${colors.border}"
    stroke-width: 2
  }

  # Root grid to align Offsets with Data Fields
  grid-columns: 2
  grid-gap: 0

  # --- OFFSET COLUMN (Byte indices / Memory Addresses) ---
  Offsets: {
    style: {
      fill: "#F0F0F0"
      stroke: "#CCCCCC"
      font: mono
    }
    grid-columns: 1
    grid-gap: 0

    o0: "0x00" { height: 120; width: 100 }
    o4: "0x04" { height: 120; width: 100 }
    o8: "0x08" { height: 180; width: 100 }
    oN: "..." { height: 60; width: 100 }
  }

  # --- DATA FIELDS COLUMN ---
  Data_Fields: {
    # Using a single column grid to stack the rows
    grid-columns: 1
    grid-gap: 0
    style.stroke-width: 0

    # Row 1: Fixed ICMP Header [Bytes 0-3]
    # We avoid grid here to allow internal connections between fields
    fixed_header: {
      height: 120
      width: 600
      style.stroke-width: 1

      type: "TYPE (8-bit)\n[Byte 0]" {
        style: { fill: "${colors.header_main}"; font-color: white; bold: true }
        width: 150; height: 120
        top: 0; left: 0
      }
      code: "CODE (8-bit)\n[Byte 1]" {
        style: { fill: "${colors.header_alt}"; font-color: white; bold: true }
        width: 150; height: 120
        top: 0; left: 150
      }
      checksum: "CHECKSUM (16-bit)\n[Bytes 2-3]" {
        style: { fill: "${colors.checksum}"; font-color: white; bold: true }
        width: 300; height: 120
        top: 0; left: 300
      }
    }

    # Row 2: Type-Specific Data (The 'Rest of Header') [Bytes 4-7]
    header_variants: {
      height: 120
      width: 600
      style: {
        fill: "#FCFCFC"
        stroke: "${colors.border}"
        stroke-width: 1
      }
      
      label: "Rest of Header (32-bit) [Bytes 4-7]"

      # Variant context displayed as nested metadata
      echo_context: "Echo Msg: [Identifier (16b) | Sequence (16b)]" {
        style: { fill: "${colors.data_light}"; font-color: white; font-size: 11; bold: true }
        width: 580; height: 30
        top: 40; left: 10
      }
      addr_context: "Redirect: [Gateway IP Address (32b)]" {
        style: { fill: "${colors.pointer_orange}"; font-color: white; font-size: 11; bold: true }
        width: 580; height: 30
        top: 80; left: 10
      }
    }

    # Row 3: Variable Data [Byte 8+]
    payload: {
      height: 180
      width: 600
      style: {
        fill: "#E1F5FE"
        stroke: "${colors.border}"
        stroke-width: 2
        stroke-dash: 5
      }
      
      label: "Data / Payload (Variable Size) [Byte 8+]"
      
      content: "Error Messages: Original IP Header + 64 bits of Data\nEcho Messages: Arbitrary Data (Timestamp, etc.)" {
        style: { 
          fill: "${colors.data_blue}"
          font-color: white
          opacity: 0.9
          bold: true 
          stroke-width: 0
        }
        width: 560; height: 100
        top: 50; left: 20
      }
    }

    # Footer row for expansion
    footer_gap: {
      height: 60
      width: 600
      style.fill: transparent
      style.stroke-dash: 10
      label: "... Continued until MTU boundary ..."
    }
  }
}

# --- TECHNICAL SPECIFICATIONS ---
Specs: {
  near: Packet_Structure
  
  definitions: |'md
    ### ICMP Message Types (Standard)
    - **Type 0:** Echo Reply
    - **Type 3:** Destination Unreachable
    - **Type 5:** Redirect
    - **Type 8:** Echo Request
    - **Type 11:** Time Exceeded

    ### Memory Invariants
    1. **Network Byte Order:** All multi-byte integers (Checksum, Identifiers) are Big-Endian.
    2. **Checksum Calculation:** 16-bit one's complement of the ICMP header and data.
    3. **Alignment:** ICMP is encapsulated in IP; memory alignment follows IP payload offset.
  '|
}

# --- METRICS & ANNOTATIONS ---
size_info: |'md
  **sizeof(struct icmp_hdr)** = 8 Bytes
  **Total Size:** Header(8) + Payload(N)
'| {
  near: bottom-center
  style: {
    font-size: 16
    bold: true
    font-color: "#333333"
  }
}

# --- LOGICAL MAPPING & CONSTRAINTS ---

# Dependency link: The Type field determines the format of the header_variants
Packet_Structure.Data_Fields.fixed_header.type -> Packet_Structure.Data_Fields.header_variants: "Controls Format" {
  style: {
    stroke: red
    stroke-width: 2
    stroke-dash: 2
  }
}

# Relationship between Echo fields and the data section
Packet_Structure.Data_Fields.header_variants.echo_context -> Packet_Structure.Data_Fields.payload.content: "Echo Correlation" {
  style: {
    stroke: "${colors.pointer_orange}"
    stroke-width: 3
    stroke-dash: 4
    animated: true
  }
}

# Global invariants markers
Packet_Structure.Data_Fields.fixed_header.type.style.double-border: true
Packet_Structure.Data_Fields.fixed_header.code.style.double-border: true

# Page Boundary Annotation
boundary_note: "Typical MTU Limit: 1500 Bytes" {
  near: Packet_Structure.Data_Fields.footer_gap
  style.font-size: 10
  style.italic: true
}