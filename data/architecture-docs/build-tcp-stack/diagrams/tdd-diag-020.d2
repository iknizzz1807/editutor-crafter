vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # IP Forwarding Decision Tree
  Layer 3 Packet Processing Flow
| {near: top-center}
START: {
  shape: circle
  style.fill: "#4CAF50"
  style.stroke: "#2E7D32"
  style.font-color: white
}
is_dest_us: "Destination == Our IP?" {
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}
deliver_locally: "Deliver to\nUpper Layer\n(TCP/UDP/ICMP)" {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
}
check_route: "Route\nLookup" {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
route_found: "Route\nFound?" {
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}
send_icmp_unreach: "Send ICMP\nDestination\nUnreachable" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
decr_ttl: "Decrement TTL" {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
ttl_zero: "TTL == 0?" {
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}
send_icmp_time: "Send ICMP\nTime Exceeded" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
forward_packet: "Forward to\nNext Hop" {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
}
END_LOCAL: {
  label: ""
  shape: circle
  style.fill: "#9E9E9E"
  style.stroke: "#616161"
}
END_ERROR: {
  label: ""
  shape: circle
  style.fill: "#9E9E9E"
  style.stroke: "#616161"
}
END_FORWARD: {
  label: ""
  shape: circle
  style.fill: "#9E9E9E"
  style.stroke: "#616161"
}
START -> is_dest_us: "Packet\nArrives" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
is_dest_us -> deliver_locally: "YES" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
is_dest_us -> check_route: "NO" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}
deliver_locally -> END_LOCAL {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
check_route -> route_found {
  style.stroke: "#F9A825"
  style.stroke-width: 2
}
route_found -> send_icmp_unreach: "NO" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
route_found -> decr_ttl: "YES" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
send_icmp_unreach -> END_ERROR {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
decr_ttl -> ttl_zero {
  style.stroke: "#F9A825"
  style.stroke-width: 2
}
ttl_zero -> send_icmp_time: "YES" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
ttl_zero -> forward_packet: "NO" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
send_icmp_time -> END_ERROR {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
forward_packet -> END_FORWARD {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  legend_title: "Legend" {
    shape: text
    style.font-size: 16
    style.bold: true
  }
  success: "Success Path" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  decision: "Decision Point" {
    shape: diamond
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  error: "Error/ICMP" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  process: "Process Step" {
    shape: rectangle
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
}