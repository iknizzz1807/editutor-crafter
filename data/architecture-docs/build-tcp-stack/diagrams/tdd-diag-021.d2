vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # TCP State Machine
  RFC 793 Figure 6 - 11 States
| {near: top-center}
# State nodes with invariants
CLOSED: {
  shape: circle
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 3
}
LISTEN: {
  shape: circle
  style.fill: "#B8D4E8"
  style.stroke: "#4A90A4"
  style.stroke-width: 2
  tooltip: "Server waiting for SYN\nSND.UNA = ISS, RCV.NXT = 0"
}
SYN_SENT: {
  shape: circle
  style.fill: "#FFE4B5"
  style.stroke: "#D48806"
  style.stroke-width: 2
  tooltip: "Client sent SYN, waiting for SYN-ACK\nSND.NXT = ISS+1"
}
SYN_RECEIVED: {
  shape: circle
  style.fill: "#E6D5F2"
  style.stroke: "#7B4BA0"
  style.stroke-width: 2
  tooltip: "Server received SYN, sent SYN-ACK\nWaiting for ACK"
}
ESTABLISHED: {
  shape: circle
  style.fill: "#90EE90"
  style.stroke: "#228B22"
  style.stroke-width: 3
  style.shadow: true
  tooltip: "Connection open\nData transfer phase"
}
FIN_WAIT_1: {
  shape: circle
  style.fill: "#FFB6C1"
  style.stroke: "#DC143C"
  style.stroke-width: 2
  tooltip: "Active closer sent FIN\nWaiting for ACK"
}
FIN_WAIT_2: {
  shape: circle
  style.fill: "#FFA07A"
  style.stroke: "#CD5C5C"
  style.stroke-width: 2
  tooltip: "FIN ACKed\nWaiting for peer FIN"
}
CLOSE_WAIT: {
  shape: circle
  style.fill: "#87CEEB"
  style.stroke: "#4682B4"
  style.stroke-width: 2
  tooltip: "Received FIN from peer\nWaiting for app close"
}
CLOSING: {
  shape: circle
  style.fill: "#DDA0DD"
  style.stroke: "#9370DB"
  style.stroke-width: 2
  tooltip: "Simultaneous close\nSent FIN, got FIN before ACK"
}
LAST_ACK: {
  shape: circle
  style.fill: "#F0E68C"
  style.stroke: "#BDB76B"
  style.stroke-width: 2
  tooltip: "Passive closer sent FIN\nWaiting for final ACK"
}
TIME_WAIT: {
  shape: circle
  style.fill: "#E0FFFF"
  style.stroke: "#00CED1"
  style.stroke-width: 2
  tooltip: "Waiting 2*MSL (60s)\nAbsorbing delayed segments"
}
# Initial state marker
initial: {
  shape: circle
  style.fill: "#333333"
  width: 15
  height: 15
}
initial -> CLOSED
# Active OPEN (client path)
CLOSED -> SYN_SENT: {
  label: "ACTIVE OPEN\nsend SYN"
  style.stroke: "#D48806"
  style.stroke-width: 2
}
SYN_SENT -> ESTABLISHED: {
  label: "rcv SYN-ACK\nsend ACK"
  style.stroke: "#228B22"
  style.stroke-width: 2
}
# Passive OPEN (server path)
CLOSED -> LISTEN: {
  label: "PASSIVE OPEN\ncreate TCB"
  style.stroke: "#4A90A4"
  style.stroke-width: 2
}
LISTEN -> SYN_RECEIVED: {
  label: "rcv SYN\nsend SYN-ACK"
  style.stroke: "#7B4BA0"
  style.stroke-width: 2
}
SYN_RECEIVED -> ESTABLISHED: {
  label: "rcv ACK"
  style.stroke: "#228B22"
  style.stroke-width: 2
}
# RST from SYN_RECEIVED returns to LISTEN
SYN_RECEIVED -> LISTEN: {
  label: "rcv RST"
  style.stroke: "#DC143C"
  style.stroke-dash: 3
}
# Close paths from ESTABLISHED
ESTABLISHED -> FIN_WAIT_1: {
  label: "CLOSE\nsend FIN"
  style.stroke: "#DC143C"
  style.stroke-width: 2
}
ESTABLISHED -> CLOSE_WAIT: {
  label: "rcv FIN\nsend ACK"
  style.stroke: "#4682B4"
  style.stroke-width: 2
}
# Active close path
FIN_WAIT_1 -> FIN_WAIT_2: {
  label: "rcv ACK\nfor FIN"
  style.stroke: "#CD5C5C"
  style.stroke-width: 2
}
FIN_WAIT_2 -> TIME_WAIT: {
  label: "rcv FIN\nsend ACK"
  style.stroke: "#00CED1"
  style.stroke-width: 2
}
# Simultaneous close
FIN_WAIT_1 -> CLOSING: {
  label: "rcv FIN\n(send ACK)"
  style.stroke: "#9370DB"
  style.stroke-dash: 3
}
CLOSING -> TIME_WAIT: {
  label: "rcv ACK"
  style.stroke: "#00CED1"
  style.stroke-dash: 3
}
# Passive close path
CLOSE_WAIT -> LAST_ACK: {
  label: "CLOSE\nsend FIN"
  style.stroke: "#BDB76B"
  style.stroke-width: 2
}
LAST_ACK -> CLOSED: {
  label: "rcv ACK\nof FIN"
  style.stroke: "#666666"
  style.stroke-width: 2
}
# TIME_WAIT to CLOSED
TIME_WAIT: {
  grid-columns: 1
  grid-rows: 1
  timeout: "timeout=2MSL\ndelete TCB" {
    shape: text
    style.fill: transparent
  }
}
TIME_WAIT -> CLOSED: {
  label: "timeout\n2*MSL"
  style.stroke: "#666666"
  style.stroke-dash: 5
}
# Simultaneous open (both sides send SYN)
SYN_SENT -> SYN_RECEIVED: {
  label: "rcv SYN\n(simultaneous\nopen)"
  style.stroke: "#7B4BA0"
  style.stroke-dash: 3
}
# Legend
legend: {
  near: bottom-right
  legend_title: "Legend" {
    shape: text
    style.font-size: 14
    style.bold: true
  }
  active: "Active OPEN (client)" {
    shape: text
    style.font-color: "#D48806"
  }
  passive: "Passive OPEN (server)" {
    shape: text
    style.font-color: "#4A90A4"
  }
  data_phase: "Data transfer phase" {
    shape: text
    style.font-color: "#228B22"
  }
  close_phase: "Close handshake phase" {
    shape: text
    style.font-color: "#DC143C"
  }
  dashed: "Simultaneous/edge case" {
    shape: text
    style.font-color: "#9370DB"
  }
  style.fill: white
  style.stroke: "#CCCCCC"
  style.border-radius: 8
}
# State invariants box
invariants: {
  near: bottom-left
  inv_title: "State Invariants" {
    shape: text
    style.font-size: 14
    style.bold: true
  }
  inv1: "• SYN consumes 1 seq number" {
    shape: text
    style.font-size: 11
  }
  inv2: "• FIN consumes 1 seq number" {
    shape: text
    style.font-size: 11
  }
  inv3: "• TIME_WAIT = 2*MSL (60s)" {
    shape: text
    style.font-size: 11
  }
  inv4: "• MSL = Maximum Segment Lifetime" {
    shape: text
    style.font-size: 11
  }
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  style.border-radius: 8
}