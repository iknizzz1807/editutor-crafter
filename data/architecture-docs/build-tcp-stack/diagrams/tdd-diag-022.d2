vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # TCP Segment Header Layout
  **RFC 793 Specification** | *32-Bit Word Alignment*
||
title.near: top-center

# Structure container for the segment layout
segment_view: {
  direction: down
  style: {
    stroke-width: 0
    fill: transparent
  }

  # Visual Bit Ruler (0-31)
  bit_ruler: {
    direction: right
    style.stroke-width: 0
    style.fill: transparent
    
    b0: "0" { width: 125; style.font: mono; style.font-size: 10; style.text-transform: uppercase }
    b8: "8" { width: 125; style.font: mono; style.font-size: 10; style.text-transform: uppercase }
    b16: "16" { width: 125; style.font: mono; style.font-size: 10; style.text-transform: uppercase }
    b24: "24" { width: 125; style.font: mono; style.font-size: 10; style.text-transform: uppercase }
    b31: "31" { width: 20; style.font: mono; style.font-size: 10; style.text-transform: uppercase }
    
    b0 -> b8 -> b16 -> b24 -> b31: { style.opacity: 0 }
  }

  # Main Header Block
  tcp_header: {
    label: "TCP Header (20 - 60 Bytes)\nsizeof=variable"
    style: {
      fill: "#F8F9FA"
      stroke: "#333333"
      stroke-width: 2
      border-radius: 4
    }

    # Word 0: 0-31 bits (Source/Dest Ports)
    word_0: {
      direction: right
      style.stroke: "#CCCCCC"
      style.fill: "#E1BEE7" 
      
      src_port: "Source Port\n(16 bits)" {
        width: 250; height: 60
        style.fill: "#9575CD"
        style.font-color: white
      }
      dst_port: "Destination Port\n(16 bits)" {
        width: 250; height: 60
        style.fill: "#9575CD"
        style.font-color: white
      }
    }

    # Word 1: 32-63 bits (Sequence Number)
    word_1: {
      style.stroke: "#CCCCCC"
      seq_num: "Sequence Number (32 bits)" {
        width: 500; height: 60
        style.fill: "#7E57C2" 
        style.font-color: white
      }
    }

    # Word 2: 64-95 bits (Ack Number)
    word_2: {
      style.stroke: "#CCCCCC"
      ack_num: "Acknowledgment Number (32 bits)" {
        width: 500; height: 60
        style.fill: "#7E57C2" 
        style.font-color: white
      }
    }

    # Word 3: 96-127 bits (Offset, Reserved, Flags, Window)
    word_3: {
      direction: right
      style.stroke: "#CCCCCC"
      
      data_offset: "Offset\n(4b)" {
        width: 62; height: 60
        style.fill: "#D1C4E9"
        style.font-size: 10
      }
      reserved: "Res\n(6b)" {
        width: 62; height: 60
        style.fill: "#B0BEC5"
        style.font-size: 10
      }
      flags: "Flags\n(6b)" {
        width: 126; height: 60
        style.fill: "#EF5350"
        style.font-color: white
        style.font-size: 10
      }
      window: "Window Size\n(16b)" {
        width: 250; height: 60
        style.fill: "#81C784"
        style.font-color: white
      }
    }

    # Word 4: 128-159 bits (Checksum, Urgent Ptr)
    word_4: {
      direction: right
      style.stroke: "#CCCCCC"
      
      checksum: "Checksum\n(16b)" {
        width: 250; height: 60
        style.fill: "#BA68C8"
        style.font-color: white
      }
      urgent_ptr: "Urgent Ptr\n(16b)" {
        width: 250; height: 60
        style.fill: "#FFB74D"
        style.font-color: white
      }
    }

    # Word 5: Options (Variable)
    word_5: {
      options: "Options and Padding\n(0-40 bytes)" {
        width: 500; height: 60
        style.fill: "#CFD8DC"
        style.stroke-dash: 4
      }
    }

    # Sequential layout of words
    word_0 -> word_1 -> word_2 -> word_3 -> word_4 -> word_5: { style.opacity: 0 }
  }

  # Payload Data Section
  payload: "Segment Payload Data\n(Application Layer Stream)" {
    width: 500; height: 120
    style.fill: "#64B5F6"
    style.font-color: white
    style.stroke: "#1E88E5"
    style.stroke-width: 3
    style.double-border: true
  }

  bit_ruler -> tcp_header -> payload: { style.opacity: 0 }
}

# Left margin Byte Offsets
offsets: {
  near: center-left
  style.stroke-width: 0
  style.fill: transparent

  o0: "Byte 0 (0x00)" { style.font: mono; style.font-size: 12 }
  o4: "Byte 4 (0x04)" { style.font: mono; style.font-size: 12 }
  o8: "Byte 8 (0x08)" { style.font: mono; style.font-size: 12 }
  o12: "Byte 12 (0x0C)" { style.font: mono; style.font-size: 12 }
  o16: "Byte 16 (0x10)" { style.font: mono; style.font-size: 12 }
  o20: "Byte 20 (0x14)" { style.font: mono; style.font-size: 12 }

  o0 -> o4 -> o8 -> o12 -> o16 -> o20: { style.opacity: 0 }
}

# Detailed Control Flags Breakdown
flag_breakdown: "Detailed Bit Flags (Byte 13)" {
  near: center-right
  grid-columns: 6
  urg: "URG" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
  ack: "ACK" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
  psh: "PSH" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
  rst: "RST" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
  syn: "SYN" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
  fin: "FIN" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
}

# Mapping flag field to detailed breakdown
segment_view.tcp_header.word_3.flags -> flag_breakdown: "Mapped bits" {
  style.stroke-dash: 3
  style.stroke: "#EF5350"
}

# Technical Specs
notes: |md
  ### TCP Header Specifications
  1. **Data Offset**: 4 bits indicating the header length in 32-bit words (min=5).
  2. **Reserved**: 6 bits reserved for future use; must be zero.
  3. **Window**: Flow control mechanism specifying available receive buffer size.
  4. **Checksum**: Covers header, payload, and a conceptual IP pseudo-header.
  5. **Urgent Pointer**: Points to sequence number of last byte of urgent data.
|
notes.near: bottom-center

# Implementation Legend
legend: {
  label: "Field Classification"
  near: bottom-right
  
  addr: "Addressing" { style.fill: "#9575CD"; style.font-color: white }
  seq: "Sequencing" { style.fill: "#7E57C2"; style.font-color: white }
  ctrl: "Control" { style.fill: "#EF5350"; style.font-color: white }
  flow: "Flow Control" { style.fill: "#81C784"; style.font-color: white }
  meta: "Meta/Padding" { style.fill: "#CFD8DC" }
  data: "Payload" { style.fill: "#64B5F6"; style.font-color: white }
  
  addr -> seq -> ctrl -> flow -> meta -> data: { style.opacity: 0 }
}