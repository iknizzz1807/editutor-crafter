direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# TCP Pseudo-Header for Checksum
# Memory Layout Specification - Intel Manual Quality
# Standard: RFC 793, RFC 9293

title: |md
  # TCP Pseudo-Header for Checksum
  ### RFC 793 / RFC 9293 Standard Architecture
  *12-byte structure prepended to the TCP Segment for checksum calculation only.*
  *Ensures segments are not delivered to the wrong IP address or protocol.*
| {
  near: top-center
}

# Bit Scale Header (0 to 31)
bit_scale: {
  grid-columns: 4
  grid-gap: 0
  style.stroke: transparent
  
  b0: "0" { width: 40; style.font-size: 10; style.stroke: transparent }
  b8: "8" { width: 40; style.font-size: 10; style.stroke: transparent }
  b16: "16" { width: 80; style.font-size: 10; style.stroke: transparent }
  b31: "31" { width: 160; style.font-size: 10; style.stroke: transparent; label.near: center-right }
}

memory_layout: {
  grid-columns: 3
  grid-gap: 5
  vertical-gap: 2
  
  # --- ROW 0: Source IP ---
  off0: "0x00" { shape: text; style.font: mono; width: 60; label: "Offset 0" }
  src_ip: "Source IP Address (32 bits)" {
    style.fill: "#E8D4F8" # Purple (Header/Metadata)
    style.stroke: "#7C3AED"
    style.stroke-width: 2
    width: 320
    height: 45
  }
  size0: "4 Bytes" { shape: text; style.font: mono; width: 80 }

  # --- ROW 1: Destination IP ---
  off4: "0x04" { shape: text; style.font: mono; label: "Offset 4" }
  dst_ip: "Destination IP Address (32 bits)" {
    style.fill: "#E8D4F8"
    style.stroke: "#7C3AED"
    style.stroke-width: 2
    width: 320
    height: 45
  }
  size4: "4 Bytes" { shape: text; style.font: mono }

  # --- ROW 2: Zero | Protocol | TCP Length ---
  off8: "0x08" { shape: text; style.font: mono; label: "Offset 8" }
  mixed_row: {
    grid-columns: 3
    grid-gap: 0
    style.stroke-width: 2
    
    zero: "Zero" {
      tooltip: "8 bits of Padding"
      style.fill: "#D1D5DB" # Gray (Padding/Reserved)
      width: 80
      height: 45
    }
    proto: "PTCL (6)" {
      tooltip: "Protocol: TCP is 0x06"
      style.fill: "#FDE68A" # Special/Protocol
      width: 80
      height: 45
    }
    t_len: "TCP Length" {
      tooltip: "Total octets in TCP Header + TCP Data"
      style.fill: "#BFDBFE" # Blue (Data/Length)
      width: 160
      height: 45
    }
  }
  size8: "4 Bytes" { shape: text; style.font: mono }
}

# Visual separator representing the boundary between pseudo-header and actual segment
boundary: "------------------- WIRE BOUNDARY: PSEUDO-HEADER IS NOT TRANSMITTED -------------------" {
  shape: text
  style: {
    font-color: "#DC2626"
    italic: true
    bold: true
  }
}

tcp_segment: {
  label: "TCP Segment (Transmitted on Wire)"
  style.stroke-dash: 5
  style.stroke: "#3B82F6"
  
  grid-columns: 3
  grid-gap: 5
  
  off_tcp: "0x0C" { shape: text; style.font: mono; width: 60; label: "Offset 12" }
  segment_body: {
    grid-rows: 2
    grid-gap: 0
    
    header: "TCP Header (20-60 Bytes)" {
      style.fill: "#C4B5FD"
      style.stroke: "#7C3AED"
      style.stroke-width: 2
      width: 320
      height: 60
    }
    data: "TCP Payload / Data Segment" {
      style.fill: "#93C5FD"
      style.stroke: "#2563EB"
      style.stroke-width: 2
      width: 320
      height: 100
    }
  }
  size_tcp: "Variable" { shape: text; style.font: mono; width: 80 }
}

# Floating Notes Section
technical_specs: |md
  ### TCP Checksum Implementation Details
  - **Algorithm**: 16-bit one's complement sum of all 16-bit words in the Pseudo-Header + TCP Segment.
  - **Zero Padding**: If the total length is not a multiple of 2 bytes, a zero pad byte (0x00) is appended for calculation only.
  - **The Zero Field**: Must be all zeros (8 bits).
  - **Protocol Field**: For TCP, this value is always 6 (0x06).
  - **Checksum Field**: When calculating, the Checksum field in the TCP header is treated as zero.
| {
  near: bottom-right
  style.fill: "#F8FAFC"
  style.stroke: "#CBD5E1"
}

# Checksum scope annotation
checksum_range: {
  near: top-left
  label: |md
    **Calculation Scope**
    The 16-bit Checksum covers:
    1. **Pseudo-header** (12 bytes)
    2. **TCP Header** (20-60 bytes)
    3. **TCP Data** (N bytes)
  |
  style.stroke: "#DC2626"
  style.fill: "#FEF2F2"
  style.font-size: 11
}

# Hidden connections for layout flow
bit_scale -> memory_layout: { style.stroke: transparent }
memory_layout -> boundary: { style.stroke: transparent }
boundary -> tcp_segment: { style.stroke: transparent }

# Checksum coverage indicator arrows
(checksum_range -> memory_layout): {
  style.stroke: "#DC2626"
  style.stroke-dash: 4
  target-arrowhead: triangle
}
(checksum_range -> tcp_segment): {
  style.stroke: "#DC2626"
  style.stroke-dash: 4
  target-arrowhead: triangle
}

# Footer Legend for Field Types
legend: {
  near: bottom-left
  grid-columns: 2
  grid-gap: 10
  
  l1: "" { style.fill: "#E8D4F8"; width: 15; height: 15 }
  lt1: "IP-Layer Metadata" { shape: text; style.font-size: 10 }
  
  l2: "" { style.fill: "#D1D5DB"; width: 15; height: 15 }
  lt2: "Padding/Reserved" { shape: text; style.font-size: 10 }
  
  l3: "" { style.fill: "#BFDBFE"; width: 15; height: 15 }
  lt3: "TCP-Layer Length/Body" { shape: text; style.font-size: 10 }
}