vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
# Participants
Client
Server
# State annotations at top
Client."CLOSED"
Server."CLOSED"
# Step 1: SYN from Client
step1: {
  Client -> Server: SYN {
    label: "seq=ISN₁\nflags=SYN"
  }
  Client."SYN_SENT"
}
# Step 2: SYN-ACK from Server
step2: {
  Server -> Client: SYN-ACK {
    label: "seq=ISN₂\nack=ISN₁+1\nflags=SYN,ACK"
  }
  Server."SYN_RECEIVED"
}
# Step 3: ACK from Client
step3: {
  Client -> Server: ACK {
    label: "seq=ISN₁+1\nack=ISN₂+1\nflags=ACK"
  }
  Client."ESTABLISHED"
  Server."ESTABLISHED"
}
# Styling for clarity
step1.style.stroke: "#2563eb"
step2.style.stroke: "#16a34a"
step3.style.stroke: "#9333ea"
# Legend
legend: {
  near: bottom-center
  shape: rectangle
  label: "3-Way Handshake\n\nSYN consumes 1 sequence number\nACK confirms receipt of all bytes up to (but not including) ack_num"
  style: {
    fill: "#f8fafc"
    stroke: "#e2e8f0"
    font-size: 14
  }
}