layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Modulo 2³² Sequence Number Comparison (RFC 793 / RFC 1323)
  `SEQ_LT(a, b)` logic for TCP Window Management and Wraparound Handling
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --- CLASSES FOR STYLING ---
classes: {
  header_box: {
    style: {
      fill: "#2D3748"
      font-color: white
      stroke-width: 0
      bold: true
    }
  }
  math_block: {
    style: {
      fill: "#F7FAFC"
      stroke: "#CBD5E0"
      stroke-width: 1
      font: mono
    }
  }
  success_state: {
    style: {
      fill: "#F0FFF4"
      stroke: "#38A169"
      stroke-width: 2
    }
  }
  error_state: {
    style: {
      fill: "#FFF5F5"
      stroke: "#E53E3E"
      stroke-width: 2
    }
  }
  register_byte: {
    width: 60
    height: 40
    style: {
      font: mono
      text-transform: uppercase
    }
  }
}

# --- 1. THEORETICAL MODEL ---
clock_analogy: {
  label: "Visualization: Sequence Number Space as a Circle"
  
  circle_main: {
    shape: circle
    width: 400
    height: 400
    style: {
      fill: white
      stroke: "#4A5568"
      stroke-width: 4
      stroke-dash: 5
    }
    
    # Internal markers as labels on the circle itself
    label: "2³²-1 Total States"
    label.near: center-center

    # Logical points inside the circle container
    points: {
      grid-columns: 3
      grid-gap: 50
      style.opacity: 0

      p_start: "0" { style.bold: true }
      p_top: "" { style.opacity: 0 }
      p_max: "2³²-1" { style.font-color: red }
      
      p_left: "b" { style.font-color: "#38A169" }
      p_center: "•" { style.font-size: 30 }
      p_right: "a" { style.font-color: "#3182CE" }

      p_dummy: "" { style.opacity: 0 }
      p_mid: "2³¹" { style.italic: true }
      p_dummy2: "" { style.opacity: 0 }
    }
  }

  points.p_center -> points.p_right: "Pointer A" {
    style: {
      stroke: "#3182CE"
      stroke-width: 4
    }
  }
  
  points.p_center -> points.p_left: "Pointer B" {
    style: {
      stroke: "#38A169"
      stroke-width: 4
    }
  }

  note: |md
    ### Axiom of RFC 1323
    `a < b` is true if and only if:
    1. `a != b`
    2. `(i32)(a - b) < 0`
    
    This effectively defines "less than" as being in the 
    **preceding half** of the circular sequence space.
  | {
    shape: text
    style.font-size: 14
  }
}

# --- 2. IMPLEMENTATION MACROS ---
implementation: {
  label: "C Macro Definitions (Production Grade)"
  
  macros_table: {
    shape: sql_table
    style.fill: "#EDF2F7"
    
    SEQ_LT: "((int32_t)((a) - (b)) < 0)" {constraint: "a is before b"}
    SEQ_LE: "((int32_t)((a) - (b)) <= 0)" {constraint: "a is before or equal b"}
    SEQ_GT: "((int32_t)((a) - (b)) > 0)" {constraint: "a is after b"}
    SEQ_GE: "((int32_t)((a) - (b)) >= 0)" {constraint: "a is after or equal b"}
  }

  usage_warning: {
    label: "Warning: These macros fail if |a - b| ≥ 2³¹"
    shape: text
    style: {
      italic: true
      bold: true
      font-color: "#E53E3E"
    }
  }
}

# --- 3. EXECUTION STEPS (ALGORITHM STATE) ---
examples: {
  direction: right
  
  standard_case: {
    class: success_state
    label: "Case A: Standard Ordering"
    
    step1: "1. Input: a=10, b=100" {shape: text}
    step2: "2. Subtraction: 10 - 100 = -90" {shape: text; style.bold: true}
    step3: "3. Signed Cast: (int32_t)(-90)" {shape: text}
    step4: "4. Logic: -90 < 0 is TRUE" {shape: text; style.font-color: green}
    
    step1 -> step2 -> step3 -> step4
  }

  wrap_case: {
    class: success_state
    label: "Case B: Wraparound Handling"
    
    step1: "1. Input: a=0xFFFFFFF0, b=0x00000010" {shape: text}
    step2: "2. Unsigned Sub: 0xFFFFFFF0 - 0x10 = 0xFFFFFFE0" {shape: text; style.bold: true; style.font-color: red}
    step3: "3. Signed Cast: (int32_t)(0xFFFFFFE0) = -32" {shape: text}
    step4: "4. Logic: -32 < 0 is TRUE" {shape: text; style.font-color: green}
    
    step1 -> step2 -> step3 -> step4
  }

  fail_case: {
    class: error_state
    label: "Failure Analysis: Naive C-style Comparison"
    
    logic: |md
      **Naive Unsigned Check:**
      `0xFFFFFFF0 < 0x00000010`
      Result: **FALSE**
      
      **The Problem:**
      Naive comparison treats the space as linear. 
      TCP sees 0xFFFFFFF0 as being "just before" 0x10.
      The subtraction method correctly calculates the 
      **signed distance** across the wraparound boundary.
    |
  }
}

# --- 4. MEMORY & ARITHMETIC LAYOUT ---
memory_layout: {
  label: "Arithmetic Logic Unit (ALU) Perspective"
  
  registers: {
    reg_a: {
      label: "Register A (uint32_t)"
      grid-columns: 4
      grid-gap: 0
      b0: "0xFF" {class: register_byte}
      b1: "0xFF" {class: register_byte}
      b2: "0xFF" {class: register_byte}
      b3: "0xF0" {class: register_byte}
    }
    
    op: {
      shape: text
      label: "MINUS"
      style.bold: true
    }
    
    reg_b: {
      label: "Register B (uint32_t)"
      grid-columns: 4
      grid-gap: 0
      b0: "0x00" {class: register_byte}
      b1: "0x00" {class: register_byte}
      b2: "0x00" {class: register_byte}
      b3: "0x10" {class: register_byte}
    }
    
    res_sep: {
      shape: text
      label: "EQUALS (Interpreted as Signed)"
    }
    
    reg_res: {
      label: "Result Register (int32_t)"
      style.fill: "#FFF5F5"
      grid-columns: 4
      grid-gap: 0
      # Red highlight on MSB to show sign bit
      b0: "0xFF" {
        class: register_byte
        style.fill: "#FEB2B2"
        tooltip: "Sign bit is 1 (Negative)"
      }
      b1: "0xFF" {class: register_byte}
      b2: "0xFF" {class: register_byte}
      b3: "0xE0" {class: register_byte}
    }

    reg_a -> op -> reg_b -> res_sep -> reg_res
  }

  annotation_box: {
    label: "Two's Complement Interpretation"
    style.stroke: red
    style.stroke-dash: 3
    
    content: |md
      The result `0xFFFFFFE0` in a 32-bit 
      signed integer register is exactly `-32`.
      
      Since `-32 < 0`, the comparison `SEQ_LT` 
      succeeds, correctly handling the wrap.
    |
  }

  reg_res.b0 -> annotation_box: "MSB is 1" {
    style.stroke: red
  }
}

# --- FOOTER ---
documentation: {
  shape: rectangle
  style.fill: "#F7FAFC"
  label: |md
    ### Technical Implementation Summary
    1. **Integer Promotion**: C standards dictate that subtraction of unsigned types wraps modulo 2ⁿ.
    2. **Signed Conversion**: Casting the result to `int32_t` maps the upper half of the unsigned range `[2³¹, 2³²-1]` to negative values `[-2³¹, -1]`.
    3. **Window Constraints**: This logic is the mathematical foundation for PAWS (Protection Against Wrapped Sequence numbers). It requires that the sequence number cannot wrap more than once within the Maximum Segment Lifetime (MSL).
  |
}

# --- LAYOUT FLOW ---
# Use non-visual connections to help ELK order the sections
clock_analogy -> implementation
implementation -> examples
examples -> memory_layout
memory_layout -> documentation

# Global styling for headers
clock_analogy.label: "I. Mathematical Model"
implementation.label: "II. Implementation"
examples.label: "III. Algorithm States"
memory_layout.label: "IV. Register Level"