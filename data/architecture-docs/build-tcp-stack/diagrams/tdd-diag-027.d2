vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: TCP Options Parsing State Machine {
  near: top-center
  shape: text
  style.font-size: 32
  style.bold: true
}
# Initial state
Start: {
  shape: circle
  style.fill: "#4CAF50"
  style.stroke: "#2E7D32"
  style.font-color: white
  style.shadow: true
}
# Main parsing loop
ParseLoop: "Parse Loop" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
# Option kind dispatch
CheckKind: "Check\nOption Kind" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
}
# EOL handling (Kind=0)
EOL: "EOL\n(Kind=0)" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 2
}
# NOP handling (Kind=1)
NOP: "NOP\n(Kind=1)" {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
# Length check for other options
CheckLength: "Length\nValid?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
}
# MSS Option (Kind=2, Length=4)
MSS: "MSS Option\n(Kind=2, Len=4)" {
  shape: rectangle
  style.fill: "#B3E5FC"
  style.stroke: "#0277BD"
  style.stroke-width: 2
  process: |md
    **Parse MSS:**
    - Extract 2-byte value
    - result.mss = value
    - result.has_mss = true
  |
}
# Window Scale (Kind=3, Length=3)
WinScale: "Window Scale\n(Kind=3, Len=3)" {
  shape: rectangle
  style.fill: "#D1C4E9"
  style.stroke: "#512DA8"
  style.stroke-width: 2
  process: |md
    **Parse WS:**
    - Extract 1-byte scale
    - result.window_scale = scale
    - result.has_ws = true
  |
}
# SACK Permitted (Kind=4, Length=2)
SACKOK: "SACK Permitted\n(Kind=4, Len=2)" {
  shape: rectangle
  style.fill: "#FFCCBC"
  style.stroke: "#D84315"
  style.stroke-width: 2
  process: |md
    **Set Flag:**
    - result.sack_ok = 1
  |
}
# Unknown/Skipped option
UnknownOpt: "Unknown\nOption" {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#546E7A"
  style.stroke-width: 2
  process: |md
    **Skip Option:**
    - Advance by opt_len bytes
    - Continue parsing
  |
}
# Error states
Malformed: "Malformed\n(Error)" {
  shape: rectangle
  style.fill: "#FF5252"
  style.stroke: "#B71C1C"
  style.font-color: white
  style.stroke-width: 2
}
# Exit state
Done: {
  shape: circle
  style.fill: "#2196F3"
  style.stroke: "#0D47A1"
  style.font-color: white
  style.double-border: true
}
# Connections
Start -> ParseLoop: "Begin\ni = 0"
ParseLoop -> CheckKind: "i < opts_len?"
CheckKind -> EOL: "kind == 0\n(EOL)"
CheckKind -> NOP: "kind == 1\n(NOP)"
CheckKind -> CheckLength: "kind >= 2\n(has length)"
EOL -> Done: "Terminate\nparsing"
NOP -> ParseLoop: "i++\n(continue)"
CheckLength -> MSS: "kind==2\nlen==4"
CheckLength -> WinScale: "kind==3\nlen==3"
CheckLength -> SACKOK: "kind==4\nlen==2"
CheckLength -> UnknownOpt: "Other\nkind"
CheckLength -> Malformed: "len < 2\nor\ntruncated"
MSS -> ParseLoop: "i += 4"
WinScale -> ParseLoop: "i += 3"
SACKOK -> ParseLoop: "i += 2"
UnknownOpt -> ParseLoop: "i += opt_len"
ParseLoop -> Done: "i >= opts_len\n(complete)"
# Legend
Legend: {
  near: bottom-right
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  title: "TCP Option Kinds" {
    shape: text
    style.bold: true
  }
  opt0: "Kind=0: End of Option List (EOL)"
  opt1: "Kind=1: No-Operation (NOP)"
  opt2: "Kind=2: Maximum Segment Size (4 bytes)"
  opt3: "Kind=3: Window Scale (3 bytes)"
  opt4: "Kind=4: SACK Permitted (2 bytes)"
}
# State invariants
Invariants: {
  near: bottom-left
  shape: rectangle
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
  title: "Parsing Invariants" {
    shape: text
    style.bold: true
  }
  inv1: |md
    - EOL terminates parsing immediately
    - NOP advances by exactly 1 byte
    - Other options: validate length before parsing
    - Unknown options: skip (per RFC)
    - Malformed: terminate parsing
  |
}