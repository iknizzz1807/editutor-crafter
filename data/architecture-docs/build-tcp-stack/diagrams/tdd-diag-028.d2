vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |'md
  # TCP MSS Option Negotiation (RFC 793, RFC 1122)
  During the 3-way handshake, both peers advertise their Maximum Segment Size (MSS).
  The effective sending MSS is calculated as: `min(Local_MTU - 40, Peer_Advertised_MSS)`.
'| {
  near: top-center
  shape: text
}

direction: right

# Participant Definitions
Client: {
  shape: rectangle
  label: "Client Node\neth0 MTU: 1500"
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
    shadow: true
  }
  
  local_calc: |'md
    ### Local MSS Calculation
    - Interface MTU: 1500 bytes
    - IP Header (Min): 20 bytes
    - TCP Header (Min): 20 bytes
    - **Max Payload (MSS): 1460**
  '| {
    shape: text
    style: { font-size: 12 }
  }
}

Server: {
  shape: rectangle
  label: "Server Node\neth0 MTU: 9000 (Jumbo)"
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
    shadow: true
  }
  
  local_calc: |'md
    ### Local MSS Calculation
    - Interface MTU: 9000 bytes
    - IP Header (Min): 20 bytes
    - TCP Header (Min): 20 bytes
    - **Max Payload (MSS): 8960**
  '| {
    shape: text
    style: { font-size: 12 }
  }
}

# --- HANDSHAKE SEQUENCE ---

# 1. SYN from Client
Client -> Server: {
  label: |'md
    **STEP 1: TCP SYN**
    - Seq: 1000, CTL: SYN
    - TCP Option: **MSS (Kind=2, Len=4)**
    - Value: **1460** (0x05B4)
  '|
  style: {
    stroke: "#1976D2"
    stroke-width: 3
    fill: "#BBDEFB"
    animated: true
  }
}

# Server Side Logic
Server.logic: |'md
  **[SERVER INTERNALS]**
  1. Receive Peer MSS: 1460
  2. Local MTU Limit: 8960
  3. **Effective Send MSS**: `min(8960, 1460) = 1460`
  4. Store `peer_mss=1460` in TCB
'| {
  shape: text
  style: {
    fill: "#FFF8E1"
    stroke: "#FF9800"
    stroke-dash: 3
    font-size: 11
  }
}

# 2. SYN-ACK from Server
Server -> Client: {
  label: |'md
    **STEP 2: TCP SYN-ACK**
    - Seq: 5000, Ack: 1001, CTL: SYN/ACK
    - TCP Option: **MSS (Kind=2, Len=4)**
    - Value: **8960** (0x2300)
  '|
  style: {
    stroke: "#F57C00"
    stroke-width: 3
    fill: "#FFE0B2"
    animated: true
  }
}

# Client Side Logic
Client.logic: |'md
  **[CLIENT INTERNALS]**
  1. Receive Peer MSS: 8960
  2. Local MTU Limit: 1460
  3. **Effective Send MSS**: `min(1460, 8960) = 1460`
  4. Store `peer_mss=8960` in TCB
'| {
  shape: text
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-dash: 3
    font-size: 11
  }
}

# 3. ACK completing handshake
Client -> Server: {
  label: "**STEP 3: ACK**\nSeq: 1001, Ack: 5001"
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

# --- TECHNICAL SPECIFICATIONS ---

established: {
  label: |'md
    ## Connection State: ESTABLISHED
    
    | Parameter | Client Side | Server Side |
    | :--- | :--- | :--- |
    | Interface MTU | 1500 | 9000 |
    | Local MSS Cap | 1460 | 8960 |
    | Advertised MSS | 1460 | 8960 |
    | Peer MSS (Recv) | 8960 | 1460 |
    | **Resultant MSS** | **1460** | **1460** |
    
    *Result: Data segments will not exceed 1460 bytes to avoid path fragmentation.*
  '|
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

wire_format: {
  label: |'md
    ## MSS Option Wire Format
    Offset (Bits) | 0-7 | 8-15 | 16-31 |
    :--- | :--- | :--- | :--- |
    **Content** | Kind (2) | Length (4) | MSS Value |
    **Hex (1460)** | `0x02` | `0x04` | `0x05B4` |
    
    *The MSS option is only valid in segments with the SYN bit set.*
  '|
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font: mono
  }
}

algorithm: {
  label: |'md
    ## Decision Matrix
    c
    // RFC 1122 Logic
    if (packet.has_option(TCP_OPT_MSS)) {
        conn->eff_mss = min(
            conn->local_mtu - 40, 
            packet.get_mss_option()
        );
    } else {
        // Default if no option present
        conn->eff_mss = 536; 
    }
    
  '|
  shape: rectangle
  style: {
    fill: "#EDE7F6"
    stroke: "#7E57C2"
  }
}

# Layout constraints for technical organization
established -> wire_format: {style.stroke-width: 0}
wire_format -> algorithm: {style.stroke-width: 0}