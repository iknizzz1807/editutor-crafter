vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # TCP Connection Table Structure
  Array of 1024 connection entries, each ~200 bytes, keyed by 4-tuple hash
| {near: top-center}

direction: right

tcp_conn_table: TCP Connection Table {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2

  header: |md
    **struct tcp_conn_table**
    c
    {
      struct tcp_conn conns[1024];
      int count;
      uint32_t next_id;
    }
    
  | {
    shape: text
  }

  conn_table_mem: {
    grid-columns: 4
    grid-gap: 0
    idx_label: "Index" {
      style.fill: "#6B5B95"
      style.font-color: white
      style.stroke: "#5A4A84"
      style.bold: true
      width: 60
    }
    conn_label: "Connection Entry" {
      style.fill: "#6B5B95"
      style.font-color: white
      style.stroke: "#5A4A84"
      style.bold: true
      width: 280
    }
    hash_label: "Hash Key" {
      style.fill: "#6B5B95"
      style.font-color: white
      style.stroke: "#5A4A84"
      style.bold: true
      width: 120
    }
    status_label: "Status" {
      style.fill: "#6B5B95"
      style.font-color: white
      style.stroke: "#5A4A84"
      style.bold: true
      width: 80
    }
    idx_0: "0" {
      style.fill: "#F5F5F5"
      style.font: mono
      width: 60
    }
    conn_0: Connection 0 {
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      width: 280
      shape: rectangle
    }
    hash_0: "hash(tuple₀)" {
      style.fill: "#FFF3E0"
      style.font: mono
      style.stroke: "#F57C00"
      width: 120
    }
    status_0: "in_use" {
      style.fill: "#C8E6C9"
      style.font-color: "#2E7D32"
      width: 80
    }
    idx_1: "1" {
      style.fill: "#F5F5F5"
      style.font: mono
      width: 60
    }
    conn_1: Connection 1 {
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      width: 280
      shape: rectangle
    }
    hash_1: "hash(tuple₁)" {
      style.fill: "#FFF3E0"
      style.font: mono
      style.stroke: "#F57C00"
      width: 120
    }
    status_1: "in_use" {
      style.fill: "#C8E6C9"
      style.font-color: "#2E7D32"
      width: 80
    }
    idx_2: "2" {
      style.fill: "#F5F5F5"
      style.font: mono
      width: 60
    }
    conn_2: "(empty)" {
      style.fill: "#FAFAFA"
      style.stroke: "#BDBDBD"
      style.font-color: "#9E9E9E"
      width: 280
    }
    hash_2: "—" {
      style.fill: "#FAFAFA"
      style.stroke: "#BDBDBD"
      style.font-color: "#9E9E9E"
      width: 120
    }
    status_2: "free" {
      style.fill: "#FFEBEE"
      style.font-color: "#C62828"
      width: 80
    }
    idx_dots: "..." {
      style.fill: "#F5F5F5"
      style.font: mono
      width: 60
    }
    conn_dots: "..." {
      style.fill: "#F5F5F5"
      style.stroke: "#E0E0E0"
      width: 280
    }
    hash_dots: "..." {
      style.fill: "#F5F5F5"
      width: 120
    }
    status_dots: "..." {
      style.fill: "#F5F5F5"
      width: 80
    }
    idx_1023: "1023" {
      style.fill: "#F5F5F5"
      style.font: mono
      width: 60
    }
    conn_1023: Connection 1023 {
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      width: 280
    }
    hash_1023: "hash(tupleₙ)" {
      style.fill: "#FFF3E0"
      style.font: mono
      style.stroke: "#F57C00"
      width: 120
    }
    status_1023: "in_use" {
      style.fill: "#C8E6C9"
      style.font-color: "#2E7D32"
      width: 80
    }
  }

  stats: |md
    **Table Statistics**
    - Total entries: 1024
    - Entry size: ~200 bytes
    - Total memory: ~200 KB
    - Cache footprint: Fits in L2
  | {
    shape: text
  }
}

connection_detail: Connection Entry Detail {
  style.fill: "#F8F9FA"
  style.stroke: "#1976D2"
  style.stroke-width: 2

  title_detail: |md
    **struct tcp_conn** (~200 bytes)
  | { shape: text }

  direction: right

  conn_tuple: Connection Tuple (12 bytes) {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    tuple_layout: {
      grid-columns: 2
      grid-gap: 0
      l1: "local_ip" {
        style.fill: "#BBDEFB"
        style.bold: true
        width: 100
      }
      l2: "uint32_t" {
        style.fill: "#E3F2FD"
        style.font: mono
        width: 60
      }
      l3: "local_port" {
        style.fill: "#BBDEFB"
        style.bold: true
        width: 100
      }
      l4: "uint16_t" {
        style.fill: "#E3F2FD"
        style.font: mono
        width: 60
      }
      l5: "remote_ip" {
        style.fill: "#BBDEFB"
        style.bold: true
        width: 100
      }
      l6: "uint32_t" {
        style.fill: "#E3F2FD"
        style.font: mono
        width: 60
      }
      l7: "remote_port" {
        style.fill: "#BBDEFB"
        style.bold: true
        width: 100
      }
      l8: "uint16_t" {
        style.fill: "#E3F2FD"
        style.font: mono
        width: 60
      }
    }
    offset_note: |md
      Offset: 0x00
      Key for hash lookup
    | {
      shape: text
      style.font-size: 10
      style.font-color: "#666666"
    }
  }

  conn_state: State Variables (8 bytes) {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    state_layout: {
      grid-columns: 2
      grid-gap: 0
      s1: "state" {
        style.fill: "#E1BEE7"
        style.bold: true
        width: 100
      }
      s2: "enum" {
        style.fill: "#F3E5F5"
        style.font: mono
        width: 60
      }
      s3: "flags" {
        style.fill: "#E1BEE7"
        style.bold: true
        width: 100
      }
      s4: "uint8_t" {
        style.fill: "#F3E5F5"
        style.font: mono
        width: 60
      }
      s5: "error" {
        style.fill: "#E1BEE7"
        style.bold: true
        width: 100
      }
      s6: "int8_t" {
        style.fill: "#F3E5F5"
        style.font: mono
        width: 60
      }
      s7: "in_use" {
        style.fill: "#E1BEE7"
        style.bold: true
        width: 100
      }
      s8: "int" {
        style.fill: "#F3E5F5"
        style.font: mono
        width: 60
      }
    }
    state_note: |md
      Offset: 0x0C
      11 states per RFC 793
    | {
      shape: text
      style.font-size: 10
      style.font-color: "#666666"
    }
  }

  conn_vars: Sequence Variables (56 bytes) {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
    vars_title: "struct tcp_conn_vars" {
      style.fill: "#FFE0B2"
      style.bold: true
    }
    send_vars: Send Variables {
      direction: down
      style.fill: "#FFF8E1"
      s1: "snd_una: uint32_t"
      s2: "snd_nxt: uint32_t"
      s3: "snd_wnd: uint32_t"
      s4: "iss: uint32_t"
    }
    recv_vars: Receive Variables {
      direction: down
      style.fill: "#FFF8E1"
      r1: "rcv_nxt: uint32_t"
      r2: "rcv_wnd: uint32_t"
      r3: "irs: uint32_t"
    }
    mss_vars: MSS Variables {
      direction: down
      style.fill: "#FFF8E1"
      m1: "snd_mss: uint16_t"
      m2: "rcv_mss: uint16_t"
    }
    vars_note: |md
      Offset: 0x14
      Per RFC 793
    | {
      shape: text
      style.font-size: 10
      style.font-color: "#666666"
    }
  }

  conn_bufs: Buffers (128 KB) {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    buf_title: "Data Buffers" {
      style.fill: "#C8E6C9"
      style.bold: true
    }
    send_buf: Send Buffer {
      direction: down
      style.fill: "#E8F5E9"
      style.stroke-dash: 3
      sb1: "data[64KB]"
      sb2: "snd_una: seq"
      sb3: "snd_nxt: seq"
      sb4: "tail: seq"
    }
    recv_buf: Receive Buffer {
      direction: down
      style.fill: "#E8F5E9"
      style.stroke-dash: 3
      rb1: "data[64KB]"
      rb2: "rcv_nxt: seq"
      rb3: "ooo_list"
    }
    buf_note: |md
      Offset: 0x50+
      Ring buffers
    | {
      shape: text
      style.font-size: 10
      style.font-color: "#666666"
    }
  }
}

lookup_flow: Lookup Flow {
  style.fill: "#FAFAFA"
  style.stroke: "#666666"
  
  lookup_title: |md
    **4-Tuple Hash Lookup**
  | { shape: text }

  direction: down
  input: "Input: (local_ip, local_port, remote_ip, remote_port)" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  hash: "hash(tuple) % 1024 → index" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
  }
  probe: "Linear probe from index" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  compare: "Compare tuple with entry" {
    shape: diamond
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
  found: "Return conn*" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  notfound: "Return NULL" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
  input -> hash -> probe -> compare
  compare -> found: "match"
  compare -> notfound: "no match\nor collision"
}

cache_analysis: Cache Analysis {
  style.fill: "#F5F5F5"
  style.stroke: "#666666"

  cache_title: |md
    **Cache Line Analysis**
  | { shape: text }

  cache_layout: {
    grid-columns: 1
    grid-gap: 4
    line1: "Cache Line 0 (64 bytes)" {
      style.fill: "#E3F2FD"
      width: 300
    }
    line1_detail: "Connection tuple + state + flags" {
      style.fill: "#BBDEFB"
      width: 300
      style.font-size: 10
    }
    line2: "Cache Line 1 (64 bytes)" {
      style.fill: "#FFF8E1"
      width: 300
    }
    line2_detail: "Sequence variables (partial)" {
      style.fill: "#FFE0B2"
      width: 300
      style.font-size: 10
    }
    line3: "Cache Line 2 (64 bytes)" {
      style.fill: "#FFF8E1"
      width: 300
    }
    line3_detail: "Remaining vars + timers" {
      style.fill: "#FFE0B2"
      width: 300
      style.font-size: 10
    }
    line_dots: "..." {
      style.fill: "#F5F5F5"
      width: 300
    }
    line_buf: "Separate allocation" {
      style.fill: "#E8F5E9"
      width: 300
    }
    line_buf_detail: "128 KB buffers (not in hot path)" {
      style.fill: "#C8E6C9"
      width: 300
      style.font-size: 10
    }
  }

  cache_summary: |md
    **Summary**
    - Header: ~80 bytes (2 cache lines)
    - Lookup: 2-16 cache line touches
    - 1024 entries = ~80 KB header
    - Fits comfortably in L2 cache
  | {
    shape: text
  }
}

legend: Legend {
  style.fill: "#FAFAFA"
  style.stroke: "#666666"
  direction: right
  l1: "4-Tuple (Key)" {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  l2: "State" {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  l3: "Seq Vars" {
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
  }
  l4: "Buffers" {
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
  l5: "Free" {
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
}
legend.near: bottom-right