vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: "RST Segment Handling by State" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------
# Legend / Metadata
# -----------------------------------------------------------------------------
legend: {
  near: top-right
  shape: rectangle
  style: {
    fill: "#f5f5f5"
    stroke: "#666"
    stroke-width: 1
    border-radius: 4
  }
  normal_transition: {
    shape: text
    label: "• Normal Transition"
    style.font-color: "#2563eb"
  }
  abort_transition: {
    shape: text
    label: "• Abort/Close"
    style.font-color: "#dc2626"
  }
  ignore_rst: {
    shape: text
    label: "• Ignore RST"
    style.font-color: "#d97706"
  }
  illegal_transition: {
    shape: text
    label: "• Illegal/Invalid"
    style.font-color: "#9333ea"
  }
}

# -----------------------------------------------------------------------------
# States and Processing Logic
# -----------------------------------------------------------------------------

entry: "RST Segment Received" {
  shape: oval
  style: {
    fill: "#e0f2fe"
    stroke: "#0284c7"
    stroke-width: 3
  }
}

seq_check: {
  label: "Is seq_num within window?\n(RCV.NXT ≤ seq < RCV.NXT+RCV.WND)"
  shape: diamond
  style: {
    fill: "#fef3c7"
    stroke: "#d97706"
    stroke-width: 2
  }
}

out_of_window: {
  label: |md
    **RST Out-of-Window**
    Action: Silently Ignore
    No state change
    No response sent
  |
  shape: rectangle
  style: {
    fill: "#fef9c3"
    stroke: "#d97706"
    stroke-width: 2
  }
}

state_dispatch: {
  label: "Current TCP State?"
  shape: diamond
  style: {
    fill: "#e0e7ff"
    stroke: "#4f46e5"
    stroke-width: 2
  }
}

# State Definitions
syn_received: "SYN_RECEIVED" {
  shape: rectangle
  style: {
    fill: "#dbeafe"
    stroke: "#2563eb"
    stroke-width: 2
  }
}

syn_received_result: {
  label: |md
    **Return to LISTEN**
    Action:
    • Delete connection TCB
    • Release resources
    • Allow new SYN to be accepted
  |
  shape: rectangle
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    stroke-width: 2
  }
}

listen_state: "LISTEN" {
  shape: rectangle
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    stroke-width: 2
    bold: true
  }
}

established: "ESTABLISHED" {
  shape: rectangle
  style: {
    fill: "#dbeafe"
    stroke: "#2563eb"
    stroke-width: 2
  }
}

established_result: {
  label: |md
    **Abort Connection**
    Action:
    • Set error = ECONNRESET
    • Notify application
    • Release all resources
    • Delete TCB
  |
  shape: rectangle
  style: {
    fill: "#fee2e2"
    stroke: "#dc2626"
    stroke-width: 3
    font-color: "#991b1b"
    bold: true
  }
}

closed_state: "CLOSED" {
  shape: rectangle
  style: {
    fill: "#f3f4f6"
    stroke: "#6b7280"
    stroke-width: 2
    bold: true
  }
}

# Connection Release States
fin_wait_1: "FIN_WAIT_1"
fin_wait_2: "FIN_WAIT_2"
close_wait: "CLOSE_WAIT"
closing: "CLOSING"
last_ack: "LAST_ACK"
time_wait: "TIME_WAIT"

fin_wait_1; fin_wait_2; close_wait; closing; last_ack; time_wait: {
  shape: rectangle
  style: {
    fill: "#dbeafe"
    stroke: "#2563eb"
    stroke-width: 2
  }
}

abort_data_states: {
  label: |md
    **Abort Connection**
    States: FIN_WAIT_1, FIN_WAIT_2,
    CLOSE_WAIT, CLOSING, LAST_ACK
    Action: Release resources, CLOSED
  |
  shape: rectangle
  style: {
    fill: "#fee2e2"
    stroke: "#dc2626"
    stroke-width: 2
  }
}

time_wait_result: {
  label: |md
    **Absorb RST**
    Action:
    • Transition to CLOSED
    • Cancel TIME_WAIT timer
    • Release TCB
  |
  shape: rectangle
  style: {
    fill: "#fef3c7"
    stroke: "#d97706"
    stroke-width: 2
  }
}

listen_rst: {
  label: |md
    **LISTEN State Handling**
    Action: Silently drop
    No connection exists
    No response sent
  |
  shape: rectangle
  style: {
    fill: "#fef9c3"
    stroke: "#d97706"
    stroke-width: 2
  }
}

syn_sent: "SYN_SENT" {
  shape: rectangle
  style: {
    fill: "#dbeafe"
    stroke: "#2563eb"
    stroke-width: 2
  }
}

syn_sent_result: {
  label: |md
    **Connection Failed**
    Action:
    • Set error = ECONNREFUSED
    • Notify application
    • Transition to CLOSED
  |
  shape: rectangle
  style: {
    fill: "#fee2e2"
    stroke: "#dc2626"
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# Transitions
# -----------------------------------------------------------------------------

entry -> seq_check: "RST arrives" {
  style.stroke: "#0284c7"
  style.stroke-width: 2
}

seq_check -> out_of_window: "NO" {
  style.stroke: "#d97706"
  style.stroke-dash: 3
  label: "seq outside window"
}

seq_check -> state_dispatch: "YES" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
  label: "seq in window"
}

# State dispatch transitions
state_dispatch -> listen_rst: "LISTEN" { style.stroke: "#d97706" }
state_dispatch -> syn_sent: "SYN_SENT" { style.stroke: "#2563eb" }
state_dispatch -> syn_received: "SYN_RECEIVED" { style.stroke: "#2563eb" }
state_dispatch -> established: "ESTABLISHED" { style.stroke: "#2563eb" }
state_dispatch -> fin_wait_1: "FIN_WAIT_1" { style.stroke: "#2563eb" }
state_dispatch -> fin_wait_2: "FIN_WAIT_2" { style.stroke: "#2563eb" }
state_dispatch -> close_wait: "CLOSE_WAIT" { style.stroke: "#2563eb" }
state_dispatch -> closing: "CLOSING" { style.stroke: "#2563eb" }
state_dispatch -> last_ack: "LAST_ACK" { style.stroke: "#2563eb" }
state_dispatch -> time_wait: "TIME_WAIT" { style.stroke: "#2563eb" }

# Result paths
syn_received -> syn_received_result: "Process RST" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
}
syn_received_result -> listen_state: {
  style.stroke: "#16a34a"
  style.stroke-width: 2
  style.animated: true
}

syn_sent -> syn_sent_result { style.stroke: "#dc2626" }
syn_sent_result -> closed_state { style.stroke: "#dc2626" }

established -> established_result: "ABORT" {
  style.stroke: "#dc2626"
  style.stroke-width: 3
  style.animated: true
}
established_result -> closed_state { style.stroke: "#dc2626" }

fin_wait_1 -> abort_data_states { style.stroke: "#dc2626" }
fin_wait_2 -> abort_data_states { style.stroke: "#dc2626" }
close_wait -> abort_data_states { style.stroke: "#dc2626" }
closing -> abort_data_states { style.stroke: "#dc2626" }
last_ack -> abort_data_states { style.stroke: "#dc2626" }
abort_data_states -> closed_state { style.stroke: "#dc2626" }

time_wait -> time_wait_result { style.stroke: "#d97706" }
time_wait_result -> closed_state { style.stroke: "#6b7280" }

# -----------------------------------------------------------------------------
# Annotations (Fixed near constraints for ELK)
# -----------------------------------------------------------------------------

note_established: |md
  **CRITICAL PATH: ESTABLISHED**
  - Most common abort scenario
  - Application receives SIGPIPE/ECONNRESET
  - All buffered data is lost
  - Buffer cleanup required
| {
  near: bottom-left
  shape: text
  style: {
    font-color: "#991b1b"
    font-size: 12
    font: mono
  }
}

note_sequence: |md
  **Sequence Validation (RFC 793)**
  RST is acceptable ONLY if:
  RCV.NXT ≤ SEG.SEQ < RCV.NXT + RCV.WND
  Prevents spoofed blind resets.
| {
  near: top-left
  shape: text
  style: {
    font-color: "#92400e"
    font-size: 12
    font: mono
  }
}

note_syn_received: |md
  **Server Special Case**
  SYN_RECEIVED → LISTEN
  Allows server to continue listening.
  Accepts new SYN immediately.
| {
  near: center-left
  shape: text
  style: {
    font-color: "#166534"
    font-size: 12
    font: mono
  }
}

illegal_marker: "ILLEGAL: RST -> RST" {
  shape: text
  near: bottom-right
  style: {
    font-color: "#9333ea"
    bold: true
    stroke: "#9333ea"
    fill: "#f3e8ff"
  }
}

illegal_note: |md
  **Protocol Invariant:**
  Never send RST in response to RST!
  Prevents infinite RST recursion loops.
| {
  shape: text
  near: bottom-center
  style: {
    font-color: "#7c3aed"
    font-size: 11
    font: mono
  }
}