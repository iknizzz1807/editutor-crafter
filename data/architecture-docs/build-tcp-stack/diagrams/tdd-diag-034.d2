vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    ack: "#4CAF50"
    in_flight: "#2196F3"
    pending: "#FFC107"
    blocked: "#9E9E9E"
    border: "#333333"
    pointer: "#E91E63"
  }
}

# --- STYLING CLASSES ---
classes: {
  segment: {
    style: {
      stroke-width: 2
      border-radius: 2
      font-size: 14
      bold: true
    }
  }
  formula_box: {
    style: {
      fill: "#F8F9FA"
      stroke: "#D1D5DB"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  pointer_text: {
    shape: text
    style: {
      font-size: 16
      bold: true
      italic: true
    }
  }
}

title: |md
  # Sliding Window Protocol Concept
  ### Transmission Control Block (TCB) State & Segment Logic
| {near: top-center}

direction: right

# --- MAIN VISUALIZATION ---
Sequence_Space: {
  style: {
    fill: transparent
    stroke: transparent
  }

  # Visual representation of the byte buffer
  Byte_Stream: {
    label: "TCP Send Buffer (Octet Stream)"
    style: {
      fill: "#FFFFFF"
      stroke: ${colors.border}
      stroke-width: 3
    }

    Acknowledged: {
      label: "1. SENT & ACKED\n(Retired Data)"
      class: segment
      style: {
        fill: ${colors.ack}
        font-color: white
      }
      width: 200
      height: 120
    }

    InFlight: {
      label: "2. SENT / UNACKED\n(Outstanding)"
      class: segment
      style: {
        fill: ${colors.in_flight}
        font-color: white
      }
      width: 300
      height: 120
    }

    Pending: {
      label: "3. READY TO SEND\n(Usable Window)"
      class: segment
      style: {
        fill: ${colors.pending}
        font-color: black
      }
      width: 200
      height: 120
    }

    Blocked: {
      label: "4. NOT SENDABLE\n(Window Full)"
      class: segment
      style: {
        fill: ${colors.blocked}
        font-color: white
      }
      width: 250
      height: 120
    }

    Acknowledged -> InFlight -> Pending -> Blocked
  }

  # TCP State Variables (Logical Pointers)
  Markers: {
    label: ""
    style: {
      fill: transparent
      stroke: transparent
    }

    SND_UNA: "SND.UNA\n(Oldest Unacked)" {
      class: pointer_text
      style.font-color: ${colors.in_flight}
    }

    SND_NXT: "SND.NXT\n(Next To Send)" {
      class: pointer_text
      style.font-color: ${colors.pointer}
    }

    SND_WND_EDGE: "Window Boundary\n(UNA + WND)" {
      class: pointer_text
      style.font-color: ${colors.border}
    }
  }
}

# --- WINDOW OVERLAY ---
Window_Visual: {
  style: {
    stroke: ${colors.pointer}
    stroke-width: 4
    stroke-dash: 5
    fill: transparent
  }
  label: "Current Send Window (SND.WND)"
}

# --- DOCUMENTATION & CALCULATIONS ---
Calculations: {
  class: formula_box
  near: bottom-left
  
  Content: |md
    ### Window Invariants
    - **Advertised Window (rwnd):** Flow control from receiver.
    - **In-Flight (SND.NXT - SND.UNA):** Bytes currently on the wire.
    - **Usable Window:** `SND.WND - (SND.NXT - SND.UNA)`
    
    ### Variable Definitions
    1. **SND.UNA:** Pointer to oldest byte sent but not yet acknowledged.
    2. **SND.NXT:** Sequence number of the next byte to be transmitted.
    3. **SND.WND:** Sequence space authorized by the remote peer.
  |
}

Protocol_Dynamics: {
  class: formula_box
  near: bottom-right
  
  Content: |md
    ### State Transitions
    - **ACK Arrival:** `SND.UNA` increments, sliding window to the right.
    - **Data Transmission:** `SND.NXT` increments, consuming usable window.
    - **Timeout:** Retransmission begins at `SND.UNA`.
    - **Persist Timer:** Triggers probe segments if `rwnd == 0` to prevent deadlock.
  |
}

# --- LEGEND ---
Legend: {
  near: bottom-center
  grid-columns: 4
  grid-gap: 20
  style: {
    fill: "#F0F0F0"
    stroke: "#CCCCCC"
    stroke-width: 1
  }

  L_ACK: "Acknowledged" { style.fill: ${colors.ack} }
  L_FLT: "In-Flight" { style.fill: ${colors.in_flight} }
  L_RDY: "Queued/Usable" { style.fill: ${colors.pending} }
  L_BLK: "Blocked/Wait" { style.fill: ${colors.blocked} }
}

# --- ANNOTATIONS ---
Implementation_Notes: {
  near: center-right
  style.fill: "#FFFDF0"
  style.stroke: "#E6DB74"
  
  note: |md
    **RFC 793 / RFC 1323 Details:**
    - Segment sizes are restricted by **MSS** (Maximum Segment Size).
    - Window Scaling allows windows up to $2^{30}$ bytes.
    - **Silly Window Syndrome** prevention: Sender waits for `Min(MSS, 1/2 Window)` before sending small payloads.
  |
}

# --- LOGICAL MAPPING & POINTER ALIGNMENT ---
# Pointing from labels to buffer boundaries
Sequence_Space.Markers.SND_UNA -> Sequence_Space.Byte_Stream.InFlight: {
  style.stroke: ${colors.in_flight}
  source-arrowhead: none
}
Sequence_Space.Markers.SND_NXT -> Sequence_Space.Byte_Stream.Pending: {
  style.stroke: ${colors.pointer}
  source-arrowhead: none
}
Sequence_Space.Markers.SND_WND_EDGE -> Sequence_Space.Byte_Stream.Blocked: {
  style.stroke: ${colors.border}
  source-arrowhead: none
}

# Highlighting the Window span
Window_Visual -> Sequence_Space.Byte_Stream.InFlight
Window_Visual -> Sequence_Space.Byte_Stream.Pending

# Custom Styling for logical flow
(Sequence_Space.Byte_Stream.Acknowledged -> Sequence_Space.Byte_Stream.InFlight)[0].style.stroke-width: 0
(Sequence_Space.Byte_Stream.InFlight -> Sequence_Space.Byte_Stream.Pending)[0].style.stroke-width: 0
(Sequence_Space.Byte_Stream.Pending -> Sequence_Space.Byte_Stream.Blocked)[0].style.stroke-width: 0