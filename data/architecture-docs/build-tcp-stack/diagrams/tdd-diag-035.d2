vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # TCP Effective Window Calculation
  **Formula:** `usable_window = min(cwnd, rwnd) - in_flight`
  **Definitions:**
  - `in_flight = SND.NXT - SND.UNA`
  - `cwnd`: Congestion Window (Network capacity)
  - `rwnd`: Receive Window (Receiver buffer capacity)
| {near: top-center}

direction: right

classes: {
  constraint-box: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 8
    }
  }
  formula-box: {
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
  result-box: {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
      stroke-width: 3
      border-radius: 8
      bold: true
    }
  }
  variable: {
    shape: rectangle
    style: {
      fill: white
      stroke: "#666"
      border-radius: 4
      font: mono
    }
  }
  marker: {
    shape: circle
    width: 12
    height: 12
  }
}

# SECTION 1: Input Constraints
constraints: {
  label: "Sender State & Remote Constraints"
  
  congestion_window: {
    class: constraint-box
    label: "Congestion Window (cwnd)"
    val: {
      class: variable
      label: "14,600 Bytes\n(10 × MSS)"
    }
    desc: |md
      **Limit: Network Congestion**
      - Derived via AIMD/Slow Start
      - Prevents bufferbloat in routers
    | {shape: text}
  }

  receiver_window: {
    class: constraint-box
    label: "Receiver Window (rwnd)"
    val: {
      class: variable
      label: "65,535 Bytes"
    }
    desc: |md
      **Limit: Flow Control**
      - Advertised in TCP Header
      - Based on `free_buffer_space`
    | {shape: text}
  }

  in_flight: {
    class: constraint-box
    label: "Bytes In Flight"
    val: {
      class: variable
      label: "8,760 Bytes\n(6 × MSS)"
    }
    desc: |md
      **Limit: Unacknowledged**
      - `SND.NXT` (Next to send)
      - `SND.UNA` (Unacknowledged)
    | {shape: text}
  }
}

# SECTION 2: Calculation Process
calculation: {
  label: "Effective Window Logic"
  direction: down

  step1: {
    class: formula-box
    label: |md
      ### 1. Window Selection
      `allowed_win = min(cwnd, rwnd)`
      `allowed_win = min(14600, 65535)`
      **Result: 14,600**
    |
  }

  step2: {
    class: formula-box
    label: |md
      ### 2. Usage Calculation
      `usable = allowed_win - in_flight`
      `usable = 14600 - 8760`
      **Result: 5,840**
    |
  }

  step3: {
    class: formula-box
    label: |md
      ### 3. Segment Mapping
      `usable / MSS = 5840 / 1460`
      **Result: 4 Segments**
    |
  }
}

# SECTION 3: Visual Sequence Space View
sequence_space: {
  label: "TCP Sequence Number View"
  
  stream: {
    shape: rectangle
    width: 700
    height: 80
    style: {
      fill: "linear-gradient(to right, #90CAF9, #A5D6A7, #FFF59D)"
      stroke: "#333"
      stroke-width: 2
    }
    
    parts: {
      grid-columns: 3
      grid-gap: 0
      acked: "ACKED" { style: { fill: "#E0E0E0"; stroke: "#999" } }
      inflight: "IN-FLIGHT" { style: { fill: "#90CAF9"; stroke: "#1E88E5" } }
      usable: "USABLE" { style: { fill: "#A5D6A7"; stroke: "#2E7D32" } }
    }
  }

  markers: {
    una: "SND.UNA" {
      class: marker
      style.fill: "#D32F2F"
    }
    nxt: "SND.NXT" {
      class: marker
      style.fill: "#1976D2"
    }
    max: "SND.WND_EDGE" {
      class: marker
      style.fill: "#388E3C"
    }
  }

  legend: {
    shape: text
    label: |md
      - **Red (SND.UNA):** Oldest unacked byte
      - **Blue (SND.NXT):** Next byte to be sent
      - **Green (Edge):** Maximum allowed offset (`SND.UNA + allowed_win`)
    |
  }
}

# SECTION 4: Final Result
result: {
  final: {
    class: result-box
    label: |md
      # USABLE WINDOW: 5,840 Bytes
      The application can call `send()` for this amount
      of data immediately without being blocked
      by the TCP stack flow/congestion control.
    |
  }
  
  edge_cases: {
    label: "Boundary Invariants"
    shape: rectangle
    style.fill: "#FFECB3"
    case1: |md
      - **Zero Window:** If `rwnd == 0`, `usable = 0`. Start Persist Timer.
      - **Congestion:** If `cwnd` shrinks below `in_flight`, `usable = 0`.
      - **Nagle's Interaction:** If `usable < MSS`, may delay sending (SWS avoidance).
    | {shape: text}
  }
}

# Connections
constraints.congestion_window -> calculation.step1: "14,600"
constraints.receiver_window -> calculation.step1: "65,535"
constraints.in_flight -> calculation.step2: "8,760"

calculation.step1 -> calculation.step2: "Window Limit"
calculation.step2 -> calculation.step3: "Usable Bytes"
calculation.step3 -> result.final: "Execute Send"

# Positioning for root elements
annotations: {
  near: bottom-center
  shape: text
  label: |md
    ### RFC 9293 & Implementation Invariants
    1. `SND.UNA <= SND.NXT` (Strict Monotonicity)
    2. `SND.NXT <= SND.UNA + min(cwnd, rwnd)` (Window Constraint)
    3. All calculations use **unsigned 32-bit sequence arithmetic** (Modular 2^32)
    4. Effective window is throttled by the *strictest* of network or receiver limits.
  |
}