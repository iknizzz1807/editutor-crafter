direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: |md
    # TCP Receiver Out-of-Order Buffer
    Technical specification of memory layout, TCB state, and gap-filling logic.
  |
  near: top-center
}

# 1. PHYSICAL MEMORY LAYOUT
buffer_state: {
  label: "Physical Buffer Layout (Receive Window)"
  grid-columns: 1
  grid-gap: 20
  
  header: {
    label: "Circular Receive Buffer: 256 KB (Base: 0x70000000)"
    style: {
      fill: "#E1BEE7"
      stroke: "#4A148C"
      bold: true
      font-size: 18
    }
  }

  mem_map: {
    grid-columns: 8
    grid-gap: 0
    
    delivered: {
      label: "Delivered\nSeq: 1-1000\n0x0000"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      style.stroke-width: 2
      width: 140
      height: 80
    }
    in_order: {
      label: "In-Order (Ready)\nSeq: 1001-1500\n0x03E8"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      style.stroke-width: 2
      width: 140
      height: 80
    }
    gap_block: {
      label: "GAP / MISSING\nSeq: 1501-2000\n[TIMEOUT TRAP]"
      style.fill: "#EEEEEE"
      style.stroke: "#CC0000"
      style.stroke-width: 3
      style.stroke-dash: 4
      style.font-color: "#8B0000"
      style.bold: true
      width: 140
      height: 80
    }
    ooo1: {
      label: "OOO Segment #1\nSeq: 2001-2500\n0x07D1"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      style.stroke-width: 2
      width: 140
      height: 80
    }
    ooo2: {
      label: "OOO Segment #2\nSeq: 2501-3000\n0x09C5"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      style.stroke-width: 2
      width: 140
      height: 80
    }
    ooo3: {
      label: "OOO Segment #3\nSeq: 3001-3500\n0x0BB9"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      style.stroke-width: 2
      width: 140
      height: 80
    }
    ooo4: {
      label: "OOO Segment #4\nSeq: 3501-4000\n0x0DAD"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      style.stroke-width: 2
      width: 140
      height: 80
    }
    free_pool: {
      label: "Empty Space\n(RCV.WND Available)"
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.stroke-dash: 2
      style.font-color: "#2E7D32"
      width: 140
      height: 80
    }
  }
}

# 2. SEQUENCE POINTERS & TCB STATE
pointers: {
  label: "TCB Control Pointers"
  grid-columns: 5
  grid-gap: 10
  
  ptr1: "↓\nSND.UNA" {
    shape: text
    style.font-color: "#2E7D32"
    style.bold: true
  }
  ptr2: "↓\nRCV.NXT" {
    shape: text
    style.font-color: "#1976D2"
    style.bold: true
    style.font-size: 14
  }
  ptr3: "↓\nGAP_START" {
    shape: text
    style.font-color: "#CC0000"
    style.bold: true
  }
  ptr4: "↓\nOOO_HEAD" {
    shape: text
    style.font-color: "#F57C00"
    style.bold: true
  }
  ptr5: "↓\nRCV.WND_END" {
    shape: text
    style.font-color: "#666666"
    style.bold: true
  }
}

# 3. DATA STRUCTURES
data_structs: {
  label: "Implementation Memory Structures"
  grid-columns: 2
  grid-gap: 50
  
  recv_buf_struct: {
    shape: class
    label: "struct tcp_recv_buf"
    buffer_data: "uint8_t[262144] (Offs: 0)"
    rcv_nxt: "uint32_t (Offs: 262144)"
    rcv_wnd: "uint32_t (Offs: 262148)"
    ooo_list: "struct tcp_ooo_seg* (Offs: 262152)"
    ooo_count: "uint16_t (Offs: 262160)"
  }
  
  ooo_seg_node: {
    shape: class
    label: "struct tcp_ooo_seg"
    start_seq: "uint32_t (Offs: 0)"
    end_seq: "uint32_t (Offs: 4)"
    buf_ptr: "uint8_t* (Offs: 8)"
    next: "struct tcp_ooo_seg* (Offs: 16)"
    valid: "bool (Offs: 24)"
  }
}

# 4. ALGORITHM STEPS: GAP FILLING
algorithm_flow: {
  label: "Gap Fill & Cascade Delivery Logic"
  direction: down
  
  step1: "1. Retransmitted Segment Arrives\n(Seq: 1501, Len: 500)" {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  step2: "2. Verify Seq Range\n(1501 == RCV.NXT? YES)" {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  step3: "3. Copy Data to Buffer\n(Offset: 1501 % 256KB)" {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  step4: "4. Advance RCV.NXT\n(1501 -> 2001)" {
    style.fill: "#BBDEFB"
    style.bold: true
  }
  step5: "5. Check OOO List\n(Does Head.Start == 2001?)" {
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
  }
  step6: "6. Contiguous OOO Found\n(Merge OOO #1-#4 into In-Order)" {
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  step7: "7. Final RCV.NXT Update\n(RCV.NXT = 4001)" {
    style.fill: "#66BB6A"
    style.stroke: "#1B5E20"
    style.bold: true
  }

  step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> step7
}

# 5. BEFORE/AFTER COMPARISON
comparison: {
  label: "State Transition: Gap Resolution"
  grid-columns: 2
  grid-gap: 40

  before_state: {
    label: "State: STALLED"
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    
    vis: {
      grid-columns: 5
      grid-gap: 0
      b1: "In-Order" { style.fill: "#BBDEFB"; width: 80 }
      b2: "GAP" { style.fill: "#FFCDD2"; style.bold: true; width: 80 }
      b3: "OOO #1" { style.fill: "#FFE0B2"; width: 80 }
      b4: "OOO #2" { style.fill: "#FFE0B2"; width: 80 }
      b5: "OOO #3" { style.fill: "#FFE0B2"; width: 80 }
    }
    note: "RCV.NXT points to GAP (1501)" {
      shape: text
      style.font-color: "#CC0000"
    }
  }

  after_state: {
    label: "State: DELIVERING"
    style.fill: "#F0FFF0"
    style.stroke: "#228B22"
    
    vis: {
      grid-columns: 5
      grid-gap: 0
      a1: "Ready" { style.fill: "#C8E6C9"; width: 80 }
      a2: "Filled" { style.fill: "#C8E6C9"; width: 80 }
      a3: "Merged" { style.fill: "#C8E6C9"; width: 80 }
      a4: "Merged" { style.fill: "#C8E6C9"; width: 80 }
      a5: "Merged" { style.fill: "#C8E6C9"; width: 80 }
    }
    note: "RCV.NXT advanced to 4001" {
      shape: text
      style.font-color: "#2E7D32"
    }
  }
}

# 6. LEGEND
legend: {
  label: "Diagram Legend"
  grid-columns: 5
  grid-gap: 20
  
  l1: "Delivered / Ready" { style.fill: "#BBDEFB"; width: 120 }
  l2: "Gap / Missing" { style.fill: "#EEEEEE"; style.stroke: "#CC0000"; width: 120 }
  l3: "Buffered OOO" { style.fill: "#FFE0B2"; width: 120 }
  l4: "Free Space" { style.fill: "#C8E6C9"; width: 120 }
  l5: "Header / Control" { style.fill: "#E1BEE7"; width: 120 }
}

# CONNECTIONS
buffer_state.mem_map.gap_block -> comparison.before_state.vis.b2: "Target Gap"
algorithm_flow.step1 -> comparison.after_state: "Triggers transition" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.animated: true
}

algorithm_flow.step5 -> data_structs.ooo_seg_node: "Iterate List" {
  style.stroke-dash: 5
  style.stroke: "#F57C00"
}