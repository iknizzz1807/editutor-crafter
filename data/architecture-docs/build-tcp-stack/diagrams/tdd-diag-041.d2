vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # TCP Congestion Control: Transition Logic & State Comparison
  ### Technical Specification for cwnd Management
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# Variable Definitions for Implementation
Definitions: {
  shape: sql_table
  style.fill: "#F8F9FA"
  cwnd: "uint32" {constraint: "Congestion Window (bytes)"}
  ssthresh: "uint32" {constraint: "Slow Start Threshold"}
  MSS: "uint16" {constraint: "Maximum Segment Size (default 1460B)"}
  RTT: "duration" {constraint: "Round Trip Time"}
}

Slow_Start: "STATE: SLOW START\nInvariant: cwnd < ssthresh" {
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 4
    double-border: true
  }
  
  Logic: ||md
    ### Update Rule (RFC 5681)
    **On every ACK received:**
    `cwnd += 1 * MSS`
    
    ### Phase Characteristics
    - **Growth Profile:** Exponential ($2^n$)
    - **Update Frequency:** Per valid ACK
    - **Exit Condition:** `cwnd >= ssthresh` or Packet Loss
    
    ### Trace (Assume MSS=1)
    1. Initial: `cwnd = 1`
    2. ACK 1: `cwnd = 2` (Send 2)
    3. ACK 2,3: `cwnd = 4` (Send 4)
    4. ACK 4,5,6,7: `cwnd = 8`
  || {
    shape: text
    style.font-size: 14
  }
}

Congestion_Avoidance: "STATE: CONGESTION AVOIDANCE\nInvariant: cwnd >= ssthresh" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 4
    double-border: true
  }
  
  Logic: ||md
    ### Update Rule (RFC 5681)
    **On every ACK received:**
    `cwnd += MSS * (MSS / cwnd)`
    
    ### Phase Characteristics
    - **Growth Profile:** Linear ($\approx 1$ MSS per RTT)
    - **Update Frequency:** Incremental per ACK
    - **Exit Condition:** Packet Loss (Timeout/3-DupACK)
    
    ### Mathematical Approximation
    - For a window of size $W$:
    - Receiving $W$ ACKs results in:
    - $\sum_{i=1}^{W} \frac{1}{W} = 1$ MSS increase per RTT.
  || {
    shape: text
    style.font-size: 14
  }
}

# The block string fix: using double pipes to handle internal markdown table pipes
Comparison_Table: {
  label: ||md
    ## Algorithm Comparison Matrix
    
    | Functional Aspect | Slow Start Phase | Congestion Avoidance Phase |
    | :--- | :--- | :--- |
    | **Primary Trigger** | $cwnd < ssthresh$ | $cwnd \ge ssthresh$ |
    | **Growth Formula** | $cwnd = cwnd + MSS$ | $cwnd = cwnd + \frac{MSS^2}{cwnd}$ |
    | **Growth Vector** | Exponential | Linear |
    | **Discovery Mode** | High-speed searching | Conservative probing |
    | **ACK Handling** | Immediate doubling effect | Fractional window sliding |
    | **Risk Profile** | High (Overshoot likely) | Low (Steady state) |
  ||
  shape: rectangle
  style: {
    fill: "#FFFFFF"
    stroke: "#333333"
    stroke-width: 1
    font-size: 16
  }
}

# State Transition Arrow
Slow_Start -> Congestion_Avoidance: "STATE TRANSITION\nTriggered when cwnd reaches ssthresh" {
  style: {
    stroke: "#FF9800"
    stroke-width: 5
    stroke-dash: 5
    animated: true
  }
}

# Loss Event Logic
Loss_Handler: "EVENT: PACKET LOSS DETECTED" {
  shape: diamond
  style.fill: "#FFEBEE"
  style.stroke: "#D32F2F"
  
  Action: ||md
    1. `ssthresh = max(FlightSize / 2, 2 * MSS)`
    2. `cwnd = MSS` (if Timeout)
    3. Enter **Slow Start**
  ||
}

Congestion_Avoidance -> Loss_Handler: "Timeout / 3-DupACK" {style.stroke: red}
Loss_Handler -> Slow_Start: "Reset to Initial" {style.stroke: red; style.stroke-dash: 2}

footer_note: |md
  **Implementation Note:** In modern Linux kernels (CUBIC), $ssthresh$ is dynamically 
  calculated based on the window size at the time of congestion. The transitions 
  documented here reflect the standard NewReno behavior (RFC 5681).
| {
  near: bottom-center
  style: {
    font-size: 12
    italic: true
  }
}