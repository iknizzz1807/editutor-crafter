vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Zero Window Probing Sequence Diagram
# Receiver advertises 0 → sender starts persist timer → sends 1-byte probe → receiver ACKs with window → resume or backoff
shape: sequence_diagram
# Declare participants
Sender
Receiver
"Persist Timer"
# Initial data transfer
group: "Normal Operation" {
  Sender -> Receiver: Data Segment (seq=1000, len=100)
  Sender <- Receiver: ACK (ack=1100, win=500)
}
# Receiver buffer fills up
group: "Buffer Exhaustion" {
  Sender <- Receiver: ACK (ack=1100, win=50)
  Sender <- Receiver: ACK (ack=1100, win=0)
  Sender."Win=0 detected"
}
# Enter zero-window probing mode
group: "Zero-Window Mode" {
  Sender -> "Persist Timer": Start (delay=1s)
  Sender."Cancel retransmit timer\nEnter persist state"
}
# First probe attempt
group: "Probe #1 (backoff=1)" {
  "Persist Timer" -> Sender: Timeout
  Sender -> Receiver: 1-byte Probe (seq=1100)
  Sender <- Receiver: ACK (ack=1101, win=0)
  Sender -> "Persist Timer": Restart (delay=2s)
  Sender."Window still 0\nBackoff *= 2"
}
# Second probe attempt
group: "Probe #2 (backoff=2)" {
  "Persist Timer" -> Sender: Timeout
  Sender -> Receiver: 1-byte Probe (seq=1101)
  Sender <- Receiver: ACK (ack=1102, win=0)
  Sender -> "Persist Timer": Restart (delay=4s)
  Sender."Window still 0\nBackoff *= 2"
}
# Third probe - window opens
group: "Probe #3 - Window Opens" {
  "Persist Timer" -> Sender: Timeout
  Sender -> Receiver: 1-byte Probe (seq=1102)
  Sender <- Receiver: ACK (ack=1103, win=800)
  Sender."Window opened!"
  Sender -> "Persist Timer": Cancel
}
# Resume normal operation
group: "Resume Normal Transfer" {
  Sender."Exit zero-window mode\nRestart retransmit timer"
  Sender -> Receiver: Data Segment (seq=1103, len=500)
  Sender <- Receiver: ACK (ack=1603, win=300)
}