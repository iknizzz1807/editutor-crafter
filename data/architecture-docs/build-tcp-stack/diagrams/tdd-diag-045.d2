vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
# Title
title: Nagle's Algorithm Decision Tree {
  near: top-center
  shape: text
  style.font-size: 32
  style.bold: true
}
# Start node
start: {
  shape: circle
  style.fill: "#4A90D9"
  style.stroke: "#2E5A8B"
  style.font-color: white
  width: 60
}
# Decision nodes
decision: {
  shape: diamond
  style.fill: "#FFE4B5"
  style.stroke: "#D4A574"
  width: 200
}
full_segment_check: {
  shape: diamond
  label: "data_len >= MSS?"
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
}
no_unacked_check: {
  shape: diamond
  label: "snd_nxt == snd_una?\n(No unacked data)"
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
}
psh_check: {
  shape: diamond
  label: "PSH flag set?"
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
}
nagle_disabled_check: {
  shape: diamond
  label: "Nagle disabled?\n(TCP_NODELAY)"
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
}
# Action nodes
can_send: {
  shape: rectangle
  style.fill: "#90EE90"
  style.stroke: "#228B22"
  style.bold: true
  style.font-size: 18
  width: 140
}
wait: {
  shape: rectangle
  label: "WAIT\n(Buffer small segment\nuntil ACK arrives)"
  style.fill: "#FFB6C1"
  style.stroke: "#DC143C"
  style.font-size: 16
  width: 160
}
# Explanation boxes
nagle_explanation: |md
  **Nagle's Algorithm (RFC 896)**
  Purpose: Reduce small packet count by coalescing writes.
  Rule: At most **one small segment** in flight at a time.
| {
  near: bottom-left
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
}
mss_explanation: |md
  **MSS = Maximum Segment Size**
  Typically 1460 bytes for Ethernet (1500 MTU - 40 byte headers)
| {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
}
# Connections
start -> decision: "Small segment\nready to send"
decision -> full_segment_check
decision.label: "Check\nconditions"
full_segment_check -> can_send: "YES"
full_segment_check.label: "Full MSS segment\n→ Send immediately"
full_segment_check -> no_unacked_check: "NO"
no_unacked_check -> can_send: "YES"
no_unacked_check.label: "Nothing in flight\n→ Send immediately"
no_unacked_check -> psh_check: "NO"
psh_check -> can_send: "YES"
psh_check.label: "App requested\n→ Send immediately"
psh_check -> nagle_disabled_check: "NO"
nagle_disabled_check -> can_send: "YES"
nagle_disabled_check.label: "TCP_NODELAY\n→ Send immediately"
nagle_disabled_check -> wait: "NO"
nagle_disabled_check.label: "All conditions fail\n→ Buffer and wait"
# Arrow styling
(full_segment_check -> can_send).style.stroke: "#228B22"
(full_segment_check -> can_send).style.stroke-width: 3
(no_unacked_check -> can_send).style.stroke: "#228B22"
(no_unacked_check -> can_send).style.stroke-width: 3
(psh_check -> can_send).style.stroke: "#228B22"
(psh_check -> can_send).style.stroke-width: 3
(nagle_disabled_check -> can_send).style.stroke: "#228B22"
(nagle_disabled_check -> can_send).style.stroke-width: 3
(nagle_disabled_check -> wait).style.stroke: "#DC143C"
(nagle_disabled_check -> wait).style.stroke-width: 2
# Feedback loop for wait
wait_wait: {
  shape: circle
  label: ""
  width: 30
  style.fill: "#FFB6C1"
  style.stroke: "#DC143C"
}
wait -> wait_wait
wait_wait -> decision: "ACK arrives\n→ Check again" {
  style.stroke-dash: 5
  style.animated: true
  style.stroke: "#DC143C"
}
# Summary box
summary: |md
  **Summary: SEND if ANY condition is TRUE**
  ✓ Full-sized segment (≥ MSS)
  ✓ No unacknowledged data
  ✓ PSH flag requested
  ✓ Nagle disabled (TCP_NODELAY)
  ✗ Otherwise: Wait for ACK
| {
  near: top-right
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
  style.stroke-width: 2
}