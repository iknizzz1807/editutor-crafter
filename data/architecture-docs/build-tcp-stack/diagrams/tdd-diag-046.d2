vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Silly Window Syndrome Prevention
  Clark's Algorithm (Receiver) + Nagle's Algorithm (Sender)
| {near: top-center}

direction: right

receiver_side: {
  label: "RECEIVER SIDE\n(Clark's Algorithm)"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2

  recv_buf: {
    label: "Receive Buffer"
    shape: rectangle
    # Use grid to position elements side-by-side inside the buffer
    grid-columns: 2
    grid-gap: 0
    style.fill: white
    style.stroke: "#2E86AB"

    app_data: {
      label: "Application\nData\n(consumed)"
      shape: rectangle
      width: 140
      height: 120
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    free_space: {
      label: "Free Space\n\nAvailable:\n35 bytes"
      shape: rectangle
      width: 140
      height: 120
      style.fill: "#FFE4B5"
      style.stroke: "#FF8C00"
    }
  }
  
  # Threshold marker placed as a sibling to the buffer
  threshold_marker: {
    label: "SWS Threshold Boundary"
    shape: rectangle
    height: 10
    style.fill: "#FF4444"
    style.stroke: "#FF4444"
    style.stroke-dash: 3
  }

  decision: {
    label: "Advertise\nWindow?"
    shape: diamond
    width: 120
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
  }
  advert_small: {
    label: "Advertise 0\n(Don't reveal\nsmall window)"
    shape: rectangle
    style.fill: "#FF6B6B"
    style.stroke: "#CC0000"
    style.font-color: white
  }
  advert_full: {
    label: "Advertise\nfull amount"
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  clark_rule: |md
    **Clark's Rule:**
    Only advertise window if:
    - Available ≥ 35% of buffer, OR
    - Available ≥ 2 × MSS
  |
  
  recv_buf.free_space -> decision: "35 bytes\navailable"
  decision -> advert_small: "< threshold"
  decision -> advert_full: "≥ threshold"
}

sender_side: {
  label: "SENDER SIDE\n(Nagle's Algorithm)"
  style.fill: "#FFF4E6"
  style.stroke: "#E07C24"
  style.stroke-width: 2
  
  app_write: {
    label: "Application\nwrites 50 bytes"
    shape: person
    style.fill: "#E6E6FA"
    style.stroke: "#9370DB"
  }
  
  send_buf: {
    label: "Send Buffer"
    shape: rectangle
    grid-columns: 2
    grid-gap: 0
    style.fill: white
    style.stroke: "#E07C24"
    
    in_flight: {
      label: "In-Flight\n(sent, not ACKed)\n\nSND.UNA → SND.NXT\n1000 bytes"
      shape: rectangle
      width: 140
      height: 120
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
    }
    queued: {
      label: "Queued\n(waiting)\n\n50 bytes"
      shape: rectangle
      width: 140
      height: 120
      style.fill: "#87CEEB"
      style.stroke: "#4682B4"
    }
  }
  
  nagle_check: {
    label: "Nagle\nCheck"
    shape: diamond
    width: 120
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
  }
  send_now: {
    label: "SEND\nIMMEDIATELY"
    shape: rectangle
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  wait: {
    label: "WAIT\nfor ACK"
    shape: rectangle
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
  }
  
  app_write -> send_buf: "write"
  send_buf.queued -> nagle_check: "50 bytes\nready"
  nagle_check -> send_now: "Full MSS OR\nNo data in flight"
  nagle_check -> wait: "Small segment AND\nUnacked data exists"
  
  nagle_rule: |md
    **Nagle's Rule:**
    Send immediately if ANY:
    - Segment = full MSS
    - No unacknowledged data
    - PSH flag set
    - TCP_NODELAY enabled
  |
}

problem: {
  label: "THE PROBLEM"
  style.fill: "#FFE4E1"
  style.stroke: "#8B0000"
  style.stroke-width: 2
  desc: |md
    Without SWS Prevention:
    1. Receiver has 10 bytes free
    2. Receiver advertises win=10
    3. Sender sends 10-byte segment
    4. App reads 10 bytes
    5. Receiver advertises win=10 again
    6. **Loop: many tiny segments**
    **Result:** High overhead, poor throughput
    10 bytes data + 40 bytes headers = **25% efficiency**
  |
}

solution: {
  label: "THE SOLUTION"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  desc: |md
    With SWS Prevention:
    **Receiver (Clark):**
    - Don't advertise small increments
    - Wait until significant space opens
    **Sender (Nagle):**
    - Coalesce small writes
    - Send when ACK arrives or buffer full
    **Result:** Fewer, larger segments
    1460 bytes data + 40 bytes headers = **97% efficiency**
  |
}

flow_chart: {
  label: "DECISION FLOW"
  style.fill: "#F5F5F5"
  style.stroke: "#666666"
  start: {
    label: "App writes\ndata"
    shape: oval
    style.fill: "#E6E6FA"
  }
  check_size: {
    label: "Full MSS?"
    shape: diamond
    style.fill: "#FFFACD"
  }
  check_flight: {
    label: "Data\nin flight?"
    shape: diamond
    style.fill: "#FFFACD"
  }
  send: {
    label: "SEND"
    shape: oval
    style.fill: "#90EE90"
  }
  buffer: {
    label: "Buffer &\nWait for ACK"
    shape: oval
    style.fill: "#FFB6C1"
  }
  start -> check_size
  check_size -> send: "Yes"
  check_size -> check_flight: "No"
  check_flight -> send: "No"
  check_flight -> buffer: "Yes"
  buffer -> send: "ACK\narrives"
}

annotations: {
  # This near is valid because annotations is a root-level shape
  near: bottom-center
  note: |md
    **Key Parameters:**
    - MSS (Maximum Segment Size): Typically 1460 bytes on Ethernet
    - SWS threshold: min(35% buffer, 2×MSS)
    - Default: Don't advertise < 1024 bytes
  |
}