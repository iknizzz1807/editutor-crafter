vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --------------------------------------------------------------------------------------------
# SECTION 1: ETHERNET & TCP/IP PACKET MEMORY LAYOUT
# --------------------------------------------------------------------------------------------

packet_structure: "Complete Packet Memory Layout (One Segment)" {
  shape: rectangle
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
  }

  ethernet_header: "Ethernet Frame Header" {
    style.fill: "#e1d5e7" # Purple (Header)
    
    L2_DST: "Destination MAC | 6 Bytes" { tooltip: "Offset 0x00" }
    L2_SRC: "Source MAC | 6 Bytes" { tooltip: "Offset 0x06" }
    L2_TYPE: "EtherType (0x0800) | 2 Bytes" { tooltip: "Offset 0x0C" }
  }

  ipv4_header: "IPv4 Header (20 Bytes)" {
    style.fill: "#dae8fc" # Blue (Data/Protocol)
    
    IP_V_IHL: "Version/IHL | 1 Byte" { tooltip: "Offset 0x0E" }
    IP_TOS: "Type of Service | 1 Byte" { tooltip: "Offset 0x0F" }
    IP_LEN: "Total Length | 2 Bytes" { tooltip: "Offset 0x10" }
    IP_ID: "Identification | 2 Bytes" { tooltip: "Offset 0x12" }
    IP_FLAGS: "Flags/Frag Offset | 2 Bytes" { tooltip: "Offset 0x14" }
    IP_TTL_PROTO: "TTL/Protocol | 2 Bytes" { tooltip: "Offset 0x16" }
    IP_CSUM: "Header Checksum | 2 Bytes" { tooltip: "Offset 0x18" }
    IP_SRC: "Source IP | 4 Bytes" { tooltip: "Offset 0x1A" }
    IP_DST: "Destination IP | 4 Bytes" { tooltip: "Offset 0x1E" }
  }

  tcp_header: "TCP Header (20 Bytes)" {
    style.fill: "#fff2cc" # Orange (Pointers/Control)
    
    TCP_PORTS: "Src/Dst Ports | 4 Bytes" { tooltip: "Offset 0x22" }
    TCP_SEQ: "Sequence Number | 4 Bytes" { tooltip: "Offset 0x26" }
    TCP_ACK: "Acknowledgment Number | 4 Bytes" { tooltip: "Offset 0x2A" }
    TCP_OFF_FLAGS: "Data Offset/Flags | 2 Bytes" { tooltip: "Offset 0x2E" }
    TCP_WIN: "Window Size | 2 Bytes" { tooltip: "Offset 0x30" }
    TCP_CSUM: "TCP Checksum | 2 Bytes" { tooltip: "Offset 0x32" }
    TCP_URP: "Urgent Pointer | 2 Bytes" { tooltip: "Offset 0x34" }
  }

  payload: "TCP Payload / Data Segment" {
    style.fill: "#d5e8d4" # Green (Free/Data)
    data: "Variable Length Payload (MSS)" {
      shape: parallelogram
    }
  }

  padding: "FCS / Inter-frame Gap" {
    style.fill: "#f5f5f5" # Gray (Padding)
    fcs: "CRC-32 Checksum | 4 Bytes"
  }
}

# Layout Connections for the stack
packet_structure.ethernet_header -> packet_structure.ipv4_header -> packet_structure.tcp_header -> packet_structure.payload -> packet_structure.padding

# --------------------------------------------------------------------------------------------
# SECTION 2: IMPLEMENTATION SEQUENCE (PHASE 1-8)
# --------------------------------------------------------------------------------------------

implementation_workflow: "TCP Stack Implementation Phases" {
  
  phase_1: "Phase 1: Send Buffer" {
    shape: rectangle
    label: |md
      ### Buffer Logic
      - ISS Initialization
      - Wraparound Handling
      - SND.UNA Tracking
    |
  }

  phase_2: "Phase 2: Recv Buffer & OOO" {
    shape: rectangle
    label: |md
      ### Out-of-Order Logic
      - IRS Setup
      - Gap Detection
      - Sorted Insertion (Seq)
    |
  }

  phase_3: "Phase 3: RTO SM" {
    shape: rectangle
    label: |md
      ### Timing
      - Karn's Algorithm
      - SRTT/RTTVAR Calculation
      - Exponential Backoff
    |
  }

  phase_4_7: "Phases 4-7: Integration & CC" {
    shape: rectangle
    label: |md
      ### Congestion & Logic
      - Slow Start / Cong. Avoid
      - Fast Retransmit (3 Dup ACKs)
      - End-to-End File Transfer
    |
  }

  phase_1 -> phase_2: "Data structures ready"
  phase_2 -> phase_3: "Buffer flow stable"
  phase_3 -> phase_4_7: "Timing reliability"
}

# --------------------------------------------------------------------------------------------
# SECTION 3: RELIABLE DELIVERY STATE MACHINE
# --------------------------------------------------------------------------------------------

tcp_state_machine: "Reliable Delivery Logic" {
  shape: cylinder
  
  ESTABLISHED: "● ESTABLISHED" {
    style.fill: white
  }
  
  RETRANSMIT: "RETRANSMIT STATE" {
    style.fill: "#f8cecc"
    style.stroke: red
    label: |md
      - SND.UNA Constant
      - RTO = RTO * 2
      - CWND = 1
    |
  }
  
  FAST_RECOVERY: "FAST RECOVERY" {
    style.fill: "#dae8fc"
    label: |md
      - 3 Duplicate ACKs
      - SSTHRESH = CWND / 2
    |
  }

  ESTABLISHED -> RETRANSMIT: "Timer Expires" {
    style.stroke: red
    style.animated: true
  }
  
  ESTABLISHED -> FAST_RECOVERY: "3x Dup ACKs" {
    style.stroke: orange
  }
  
  RETRANSMIT -> ESTABLISHED: "New ACK (SND.UNA++)" {
    style.stroke: green
  }
  
  FAST_RECOVERY -> ESTABLISHED: "ACK > Recovery Point" {
    style.stroke: green
  }
  
  FAST_RECOVERY -> FAST_RECOVERY: "Duplicate ACK" {
    label: "CWND++ (Inflation)"
  }
}

# --------------------------------------------------------------------------------------------
# SECTION 4: CONCURRENCY MODEL (MAIN THREAD EVENT LOOP)
# --------------------------------------------------------------------------------------------

concurrency_model: "TCP Event Loop & Timer Heap" {
  direction: right
  
  poll_call: "poll(tap_fd, timeout)" { shape: diamond }
  
  process_logic: {
    recv: "process_data()"
    ack: "process_acks()"
    send: "send_more()"
  }
  
  timer_heap: "Timer Min-Heap" {
    shape: queue
    style.fill: "#fff2cc"
    root: "Next Expiry (SND.UNA RTO)"
  }

  poll_call -> process_logic.recv: "Packet In"
  process_logic.recv -> process_logic.ack: "Check Seq"
  process_logic.ack -> process_logic.send: "Window check"
  
  timer_heap -> poll_call: "Update poll() timeout"
  process_logic.ack -> timer_heap: "Cancel/Reset RTO"
}

# --------------------------------------------------------------------------------------------
# SECTION 5: CACHE LINE ANALYSIS (HARDWARE SOUL)
# --------------------------------------------------------------------------------------------

cache_analysis: "Hot Path Cache Efficiency (64B Boundary)" {
  grid-columns: 1
  
  line_1: "Cache Line 1 (0-63)" {
    style.stroke-dash: 5
    struct_tcp_conn: "Connection State (SND.UNA, SND.NXT, RCV.NXT, SND.WND)"
  }
  
  line_2: "Cache Line 2 (64-127)" {
    style.stroke-dash: 5
    cc_state: "Congestion Control (CWND, SSTHRESH, DUPACK_CNT)"
  }
}

# Legend and Annotations
legend: {
  near: bottom-right
  
  header_color: "Header Logic" {
    style.fill: "#e1d5e7"
  }
  data_color: "Data/Buffers" {
    style.fill: "#dae8fc"
  }
  timer_color: "Timers/Pointers" {
    style.fill: "#fff2cc"
  }
}

# Positioning instructions for layout engine
implementation_workflow.near: top-left
tcp_state_machine.near: center-right
concurrency_model.near: bottom-left
cache_analysis.near: bottom-right