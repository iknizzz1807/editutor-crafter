vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # End-to-End 1MB File Transfer Test
  **Complete data integrity verification through TCP reliable delivery**
| {
  near: top-center
}

direction: right

# Test phases container
"Test Execution": {
  # Phase 1: Data Generation
  "Phase 1: Setup": {
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    "Random Data\nGenerator": {
      shape: hexagon
      style.fill: "#BBDEFB"
      width: 140
    }
    "1MB Test\nBuffer": {
      shape: cylinder
      style.fill: "#90CAF9"
      width: 120
    }
    "SHA-256\n(expected)": {
      shape: stored_data
      style.fill: "#64B5F6"
      width: 130
    }

    "Random Data\nGenerator" -> "1MB Test\nBuffer": "generate"
    "1MB Test\nBuffer" -> "SHA-256\n(expected)": "hash"
  }

  # Phase 2: TCP Transmission
  "Phase 2: Transfer": {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2

    "Application\nSend Buffer": {
      shape: rectangle
      style.fill: "#FFE0B2"
      width: 130
    }
    "TCP Stack\n(Sender)": {
      shape: rectangle
      style.fill: "#FFCC80"
      width: 150
      tooltip: |md
        - Sliding window
        - Retransmission
        - Congestion control
        - Flow control
      |
    }
    "Network\n(Simulated Loss)": {
      shape: cloud
      style.fill: "#FFB74D"
      width: 140
      style.stroke-dash: 3
    }
    "TCP Stack\n(Receiver)": {
      shape: rectangle
      style.fill: "#FFCC80"
      width: 150
      tooltip: |md
        - OOO buffering
        - ACK generation
        - Window updates
      |
    }
    "Application\nRecv Buffer": {
      shape: rectangle
      style.fill: "#FFE0B2"
      width: 130
    }

    "Application\nSend Buffer" -> "TCP Stack\n(Sender)": "write\ndata"
    "TCP Stack\n(Sender)" -> "Network\n(Simulated Loss)": "segments\n(~700)"
    "Network\n(Simulated Loss)" -> "TCP Stack\n(Receiver)": "segments\n(may drop\n0.1%)"
    "TCP Stack\n(Receiver)" -> "Application\nRecv Buffer": "deliver\nin-order"
  }

  # Phase 3: Verification
  "Phase 3: Verify": {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    "Received\n1MB Data": {
      shape: cylinder
      style.fill: "#A5D6A7"
      width: 120
    }
    "SHA-256\n(computed)": {
      shape: stored_data
      style.fill: "#81C784"
      width: 130
    }
    "Hash\nComparison": {
      shape: diamond
      style.fill: "#66BB6A"
      width: 100
    }
    "PASS": {
      shape: circle
      style.fill: "#43A047"
      style.font-color: white
      style.bold: true
    }
    "FAIL": {
      shape: circle
      style.fill: "#E53935"
      style.font-color: white
      style.bold: true
    }

    "Received\n1MB Data" -> "SHA-256\n(computed)": "hash"
    "SHA-256\n(computed)" -> "Hash\nComparison"
    "Hash\nComparison" -> "PASS": "match"
    "Hash\nComparison" -> "FAIL": "mismatch"
  }
}

# Connect phases
"Test Execution"."Phase 1: Setup"."1MB Test\nBuffer" -> "Test Execution"."Phase 2: Transfer"."Application\nSend Buffer": "copy"
"Test Execution"."Phase 2: Transfer"."Application\nRecv Buffer" -> "Test Execution"."Phase 3: Verify"."Received\n1MB Data": "read"

# Feedback loop for ACKs
"Test Execution"."Phase 2: Transfer"."TCP Stack\n(Receiver)" -> "Test Execution"."Phase 2: Transfer"."TCP Stack\n(Sender)": "ACKs\n(ACK, Dup ACK)" {
  style.stroke: "#FF9800"
  style.stroke-dash: 4
  style.animated: true
}

# Statistics panel
"Transfer Statistics": {
  near: top-right
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  explanation: |md
    **Expected Results:**
    - Segments sent: ~700
    - Retransmits: 5-10 (0.1% loss)
    - Transfer time: <5s (local)
    - Final cwnd: 10-50 MSS
    - SHA-256: **MATCH**
  |
}