vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # ACK Processing State Machine
| {near: top-center}
# Initial state
Start: {
  shape: circle
  style.fill: "#4A5568"
  label: ""
}
# Main decision states
"ACK Arrives": {
  shape: rectangle
  style.fill: "#E2E8F0"
  style.stroke: "#64748B"
}
"New Data ACKed?": {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
"Duplicate ACK?": {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
# Action states
"Update Buffer": {
  shape: rectangle
  style.fill: "#D1FAE5"
  style.stroke: "#059669"
  label: |md
    **Advance SND.UNA**
    Remove acknowledged data
    from send buffer ring
  |
}
"Measure RTT": {
  shape: rectangle
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  label: |md
    **Jacobson's Algorithm**
    Update SRTT, RTTVAR
    Calculate new RTO
  |
}
"Grow cwnd": {
  shape: rectangle
  style.fill: "#F3E8FF"
  style.stroke: "#7C3AED"
  label: |md
    **Congestion Control**
    Slow Start: cwnd += MSS
    Cong. Avoid: cwnd += MSS²/cwnd
  |
}
"Check Recovery Exit": {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
"Exit Fast Recovery": {
  shape: rectangle
  style.fill: "#DCFCE7"
  style.stroke: "#16A343"
  label: |md
    **Recovery Complete**
    cwnd = ssthresh
    Re-arm retransmit timer
  |
}
"Stay in Recovery": {
  shape: rectangle
  style.fill: "#FEF2F2"
  style.stroke: "#DC2626"
  label: |md
    **Partial ACK**
    Retransmit first
    unacknowledged segment
  |
}
"Increment Dup Count": {
  shape: rectangle
  style.fill: "#FEF9C3"
  style.stroke: "#CA8A04"
  label: |md
    **dup_ack_count++**
    In recovery: cwnd += MSS
    (window inflation)
  |
}
"Check Fast Retransmit": {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}
"Trigger Fast Retransmit": {
  shape: rectangle
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.font-color: "#DC2626"
  style.bold: true
  label: |md
    **3 Duplicate ACKs**
    ssthresh = cwnd/2
    cwnd = ssthresh + 3
    Retransmit missing segment
    Enter FAST RECOVERY
  |
}
"Normal ACK Done": {
  shape: circle
  style.fill: "#10B981"
  label: ""
}
# Transitions
Start -> "ACK Arrives": "ACK segment\nreceived" {
  style.stroke: "#4A5568"
  style.stroke-width: 2
}
"ACK Arrives" -> "New Data ACKed?": "Compare\nack_num vs SND.UNA" {
  style.stroke: "#64748B"
}
"New Data ACKed?" -> "Duplicate ACK?": "NO\n(ack_num == SND.UNA)" {
  label: "NO"
  style.stroke: "#D97706"
}
"New Data ACKed?" -> "Update Buffer": "YES\n(ack_num > SND.UNA)" {
  label: "YES"
  style.stroke: "#059669"
  style.bold: true
}
"Duplicate ACK?" -> "Increment Dup Count": "YES" {
  label: "YES"
  style.stroke: "#CA8A04"
}
"Duplicate ACK?" -> "Normal ACK Done": "NO\n(old duplicate,\nignore)" {
  label: "NO"
  style.stroke: "#64748B"
}
"Update Buffer" -> "Measure RTT": {
  style.stroke: "#2563EB"
}
"Measure RTT" -> "Grow cwnd": {
  style.stroke: "#7C3AED"
}
"Grow cwnd" -> "Check Recovery Exit": {
  style.stroke: "#64748B"
}
"Check Recovery Exit" -> "Exit Fast Recovery": "ACK past\nrecover_seq?" {
  label: "YES"
  style.stroke: "#16A343"
  style.bold: true
}
"Check Recovery Exit" -> "Stay in Recovery": "NO\n(Partial ACK)" {
  label: "NO"
  style.stroke: "#DC2626"
}
"Exit Fast Recovery" -> "Normal ACK Done": {
  style.stroke: "#16A343"
}
"Stay in Recovery" -> "Normal ACK Done": {
  style.stroke: "#DC2626"
}
"Increment Dup Count" -> "Check Fast Retransmit": {
  style.stroke: "#CA8A04"
}
"Check Fast Retransmit" -> "Trigger Fast Retransmit": "dup_count >= 3?" {
  label: "YES\n(3 dup ACKs)"
  style.stroke: "#DC2626"
  style.bold: true
}
"Check Fast Retransmit" -> "Normal ACK Done": "NO\n(wait for more)" {
  label: "NO"
  style.stroke: "#64748B"
}
"Trigger Fast Retransmit" -> "Normal ACK Done": {
  style.stroke: "#DC2626"
}
# Legend
Legend: {
  near: bottom-right
  style.fill: "#F8FAFC"
  style.stroke: "#E2E8F0"
  style.border-radius: 8
  legend_title: |md
    **Legend**
  |
  decision: {
    shape: diamond
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    width: 40
    height: 40
  }
  action: {
    shape: rectangle
    style.fill: "#D1FAE5"
    style.stroke: "#059669"
    width: 60
    height: 30
  }
  terminal: {
    shape: circle
    style.fill: "#10B981"
    width: 30
    height: 30
  }
  legend_title -> decision: "Decision"
  decision -> action: "Action"
  action -> terminal: "Terminal"
}