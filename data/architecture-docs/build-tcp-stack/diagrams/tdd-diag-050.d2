direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: "TCP Stack: Timer Heap Structure (Min-Priority Queue)" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# --- Heap Logical Visualization ---
# Engineers use this to verify the heap invariant during sift-up/sift-down debugging.
heap: "Priority Queue Logical View (Binary Heap Invariant)" {
  style: {
    fill: "#F3F4F6"
    stroke: "#374151"
    stroke-width: 2
    border-radius: 10
  }

  root: "Timer[0]\n(Min Element)" {
    style: {
      fill: "#10B981"
      stroke: "#047857"
      font-color: white
      bold: true
    }
    label: ||md
      **expire_time: 1050ms**
      conn_id: 42
      type: RETRANSMIT
    ||
  }

  l1_left: "Timer[1]" {
    style: {
      fill: "#FCD34D"
      stroke: "#D97706"
      border-radius: 5
    }
    label: ||md
      **expire_time: 2100ms**
      conn_id: 17
      type: PERSIST
    ||
  }

  l1_right: "Timer[2]" {
    style: {
      fill: "#60A5FA"
      stroke: "#2563EB"
      font-color: white
    }
    label: ||md
      **expire_time: 3200ms**
      conn_id: 03
      type: TIME_WAIT
    ||
  }

  l2_ll: "Timer[3]" {
    style: {
      fill: "#A78BFA"
      stroke: "#7C3AED"
      font-color: white
    }
    label: ||md
      **expire_time: 4500ms**
      conn_id: 08
      type: DELAYED_ACK
    ||
  }

  l2_lr: "Timer[4]" {
    style: {
      fill: "#F87171"
      stroke: "#DC2626"
      font-color: white
    }
    label: ||md
      **expire_time: 5000ms**
      conn_id: 21
      type: RETRANSMIT
    ||
  }

  l2_rl: "Timer[5]" {
    style: {
      fill: "#D1D5DB"
      stroke: "#6B7280"
    }
    label: ||md
      **expire_time: 7200ms**
      conn_id: 12
      type: PERSIST
    ||
  }

  # Binary Tree Connections
  root -> l1_left: "expire[0] <= expire[1]" { style.stroke-width: 2 }
  root -> l1_right: "expire[0] <= expire[2]" { style.stroke-width: 2 }
  l1_left -> l2_ll: "expire[1] <= expire[3]"
  l1_left -> l2_lr: "expire[1] <= expire[4]"
  l1_right -> l2_rl: "expire[2] <= expire[5]"
}

# --- Memory Representation and Math ---
# Details exact byte layouts and offset calculations for implementation.
heap_meta: {
  near: center-left
  
  array_rep: "Physical Memory: Contiguous Timer Struct Array" {
    shape: sql_table
    style.fill: "#EFF6FF"
    # Row definitions: Byte Offset | Values
    "+0x00 (Index 0)": "expire: 1050ms | id: 42" {constraint: ROOT}
    "+0x18 (Index 1)": "expire: 2100ms | id: 17" {constraint: LEFT_CHILD}
    "+0x30 (Index 2)": "expire: 3200ms | id: 03" {constraint: RIGHT_CHILD}
    "+0x48 (Index 3)": "expire: 4500ms | id: 08" {constraint: L_L_CHILD}
    "+0x60 (Index 4)": "expire: 5000ms | id: 21" {constraint: L_R_CHILD}
    "+0x78 (Index 5)": "expire: 7200ms | id: 12" {constraint: R_L_CHILD}
  }

  math: ||md
    ### Index Relationships
    - **Parent(i)**: `floor((i - 1) / 2)`
    - **Left(i)**: `(2 * i) + 1`
    - **Right(i)**: `(2 * i) + 2`
    
    ### Memory Layout per Element
    `sizeof(Timer) = 24 bytes`
    | Offset | Field | Size |
    | :--- | :--- | :--- |
    | 0 | `expire_time` (uint64) | 8B |
    | 8 | `conn_id` (uint32) | 4B |
    | 12 | `type` (enum) | 4B |
    | 16 | `padding` | 8B |
  || {
    shape: text
    style.font-size: 14
  }
}

# --- Operational Logic ---
# State transition logic for Heap Maintenance.
ops: {
  near: top-right
  
  insert_op: "PUSH Operation" {
    style.fill: "#ECFDF5"
    style.stroke: "#10B981"
    
    step1: "1. Append to index N"
    step2: "2. Compare with Parent((N-1)/2)"
    step3: "3. If smaller: SWAP"
    step4: "4. Recurse (Bubble-Up)"
    
    complexity: "Time: O(log N)" {
      style: {
        italic: true
        font-color: "#047857"
      }
    }
  }

  remove_op: "POP_MIN Operation" {
    style.fill: "#FFFBEB"
    style.stroke: "#D97706"
    
    r_step1: "1. Move index N to root"
    r_step2: "2. Compare with min(Left, Right)"
    r_step3: "3. If larger: SWAP"
    r_step4: "4. Recurse (Sift-Down)"
    
    r_complexity: "Time: O(log N)" {
      style: {
        italic: true
        font-color: "#B45309"
      }
    }
  }
}

# --- Legend ---
legend: "Timer Classification" {
  near: bottom-right
  style.fill: white
  
  rtx: "RETRANSMIT (Critical)" {
    style.fill: "#10B981"
    shape: circle
  }
  pst: "PERSIST (Zero-Window)" {
    style.fill: "#FCD34D"
    shape: circle
  }
  tw: "TIME_WAIT (Cleanup)" {
    style.fill: "#60A5FA"
    shape: circle
  }
  ack: "DELAYED_ACK" {
    style.fill: "#A78BFA"
    shape: circle
  }
}

# Operational/Metadata connections
ops.insert_op -> heap: "Maintain invariant" { style.stroke-dash: 3 }
ops.remove_op -> heap: "Extract min expire" { style.stroke-dash: 3 }
heap_meta.array_rep -> heap: "Physical Mapping" { style.stroke-dash: 5 }