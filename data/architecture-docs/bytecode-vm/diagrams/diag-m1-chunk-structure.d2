direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  shape: rectangle
  label: |md
    # Bytecode Chunk Internal Structure
    `struct Chunk` — instruction bytes paired with constant pool
  |
  style.stroke: transparent
  style.fill: transparent
}
title_node.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  chunk: {
    direction: down
    label: "Chunk (chunk.h)"
    style.fill: "#E8F4F8"
    style.stroke: "#2B6CB0"
    
    bytecode: {
      shape: sql_table
      label: "BytecodeArray"
      f0: "0x00 | uint8_t* | code"
      f1: "0x08 | int      | count"
      f2: "0x0C | int      | capacity"
      sz: "Total: 16 bytes"
    }
    
    constants: {
      shape: sql_table
      label: "ConstantPool"
      f0: "0x00 | Value* | values"
      f1: "0x08 | int    | count"
      f2: "0x0C | int    | capacity"
      sz: "Total: 16 bytes"
    }
  }

  code_array: {
    direction: down
    label: "code[] — Instruction Bytes"
    style.fill: "#FFF5F5"
    style.stroke: "#C53030"
    
    code_table: {
      shape: sql_table
      label: "Byte Offset | Opcode | Data"
      r0: "0x00 | 0x10 | LOAD_CONST"
      r1: "0x01 | 0x00 | operand_hi"
      r2: "0x02 | 0x00 | operand_lo"
      r3: "0x03 | 0x10 | LOAD_CONST"
      r4: "0x04 | 0x00 | operand_hi"
      r5: "0x05 | 0x01 | operand_lo"
      r6: "0x06 | 0x20 | ADD"
      r7: "0x07 | 0x00 | HALT"
      note: "Size: 8 bytes total"
    }
  }

  const_array: {
    direction: down
    label: "constants[] — Value Pool"
    style.fill: "#F0FFF4"
    style.stroke: "#276749"
    
    const_table: {
      shape: sql_table
      label: "Pool Index | Type | Value"
      c0: "0 | double | 3.14"
      c1: "1 | double | 42.0"
      note: "Size: 16 bytes (8/val)"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  index_flow: {
    label: "Index Correspondence"
    style.fill: "#FAF5FF"
    style.stroke: "#6B46C1"
    
    flow: {
      direction: right
      a: "Op: LOAD_CONST 0" {
        shape: rectangle
        style.fill: "#FED7D7"
      }
      b: "Pool: constants[0]" {
        shape: rectangle
        style.fill: "#C6F6D5"
      }
      a -> b: "lookup"
    }
    
    flow2: {
      direction: right
      c: "Op: LOAD_CONST 1" {
        shape: rectangle
        style.fill: "#FED7D7"
      }
      d: "Pool: constants[1]" {
        shape: rectangle
        style.fill: "#C6F6D5"
      }
      c -> d: "lookup"
    }
  }

  encoding: {
    label: "Instruction Encoding"
    style.fill: "#FFFAF0"
    style.stroke: "#C05621"
    
    format: {
      shape: class
      label: "LOAD_CONST Format"
      opcode: "uint8_t (0x10)"
      operand: "uint16_t (big-endian)"
      +size(): "3 bytes"
    }
    
    note: {
      label: "Memory Layout Detail"
      content: |'md
        | Byte | Purpose | Value |
        | :--- | :--- | :--- |
        | 0 | Opcode | 0x10 |
        | 1 | Idx High | 0x00 |
        | 2 | Idx Low | 0x01 |
      '|
    }
  }
}

legend: {
  style.fill: "#F7FAFC"
  style.stroke: "#A0AEC0"
  label: "Manual Legend"
  l1: "Red = Instructions (Code)"
  l2: "Green = Constants (Pool)"
  l3: "Purple = Index Mapping"
  l1.style.fill: "#FED7D7"
  l2.style.fill: "#C6F6D5"
  l3.style.fill: "#E9D8FD"
}
legend.near: bottom-right

row1.chunk.bytecode -> row1.code_array: "uint8_t*"
row1.chunk.constants -> row1.const_array: "Value*"

row1.code_array.code_table.r1 -> row1.const_array.const_table.c0: "idx:0" {
  style.stroke: "#6B46C1"
  style.stroke-width: 2
}

row1.code_array.code_table.r4 -> row1.const_array.const_table.c1: "idx:1" {
  style.stroke: "#6B46C1"
  style.stroke-width: 2
}

row1 -> row2: "Execution Flow" {
  style.stroke-dash: 5
}