direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Constant Pool Deduplication
  **Memory optimization through string interning**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  source: {
    direction: down
    label: "Source Code (example.lox)"
    code: {
      width: 320
      label: "Source with repeated literals"
      code: |'c
        print "hello";
        print "hello";  // Same literal
        print "hello";  // Same literal
        var greeting = "hello";
      '|
    }
    note1: {
      label: "4 occurrences of \"hello\""
      shape: text
      style.font-color: "#E74C3C"
      style.bold: true
    }
  }
  arrow1: {
    label: "Compile"
    shape: text
    style.font-size: 20
  }
  detection: {
    direction: down
    label: "Deduplication Process"
    step1: {
      label: "1. Scan all literals"
      width: 280
      code: |'c
        // Compiler tracks seen literals
        seen = {}  // hash table
        for each literal L:
          hash = compute_hash(L)
          if hash in seen:
            reuse index from seen[hash]
          else:
            add to constant pool
            seen[hash] = new_index
      '|
    }
    step2: {
      label: "2. Hash comparison"
      width: 280
      code: |'c
        "hello" → hash=0x7CF2A1
        "hello" → hash=0x7CF2A1 ✓ match!
        "hello" → hash=0x7CF2A1 ✓ match!
        "hello" → hash=0x7CF2A1 ✓ match!
      '|
    }
    note2: {
      label: "All 4 references → same pool index"
      shape: text
      style.font-color: "#27AE60"
      style.bold: true
    }
  }
}
row1.source -> row1.detection: "Compile"
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: {
    direction: down
    label: "WITHOUT Deduplication"
    style.stroke: "#E74C3C"
    style.stroke-width: 3
    naive_pool: {
      shape: sql_table
      label: "Constant Pool (Naive)"
      style.fill: "#FADBD8"
      idx0: "0 | String | \"hello\" | 6 bytes"
      idx1: "1 | String | \"hello\" | 6 bytes"
      idx2: "2 | String | \"hello\" | 6 bytes"
      idx3: "3 | String | \"hello\" | 6 bytes"
      total: "Total: 4 × (ptr + len + chars) = 64+ bytes"
    }
    naive_bytecode: {
      label: "Bytecode References"
      code: |'c
        LOAD_CONST 0  // "hello"
        LOAD_CONST 1  // "hello" (duplicate!)
        LOAD_CONST 2  // "hello" (duplicate!)
        LOAD_CONST 3  // "hello" (duplicate!)
      '|
    }
    wasted: {
      label: "⚠ 3 duplicate allocations"
      shape: text
      style.font-color: "#E74C3C"
      style.bold: true
    }
  }
  vs: {
    label: "vs"
    shape: text
    style.font-size: 28
    style.bold: true
  }
  after: {
    direction: down
    label: "WITH Deduplication"
    style.stroke: "#27AE60"
    style.stroke-width: 3
    dedup_pool: {
      shape: sql_table
      label: "Constant Pool (Deduplicated)"
      style.fill: "#D5F5E3"
      idx0: "0 | String | \"hello\" | 6 bytes"
      total: "Total: 1 × (ptr + len + chars) = 16 bytes"
    }
    dedup_bytecode: {
      label: "Bytecode References"
      code: |'c
        LOAD_CONST 0  // "hello"
        LOAD_CONST 0  // "hello" (same index!)
        LOAD_CONST 0  // "hello" (same index!)
        LOAD_CONST 0  // "hello" (same index!)
      '|
    }
    saved: {
      label: "✓ 75% memory reduction"
      shape: text
      style.font-color: "#27AE60"
      style.bold: true
    }
  }
}
row2.before -> row2.after: "Deduplicate" {
  style.stroke: "#3498DB"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  impl: {
    direction: down
    label: "Implementation (chunk.c)"
    func: {
      width: 420
      label: "chunk_add_constant()"
      code: |'c
        int chunk_add_constant(Chunk* chunk, Value value) {
          // Check for existing identical constant
          for (int i = 0; i < chunk->constants.count; i++) {
            if (values_equal(chunk->constants.values[i], value)) {
              return i;  // Reuse existing index
            }
          }
          // Not found: add new constant
          push_value(&chunk->constants, value);
          return chunk->constants.count - 1;
        }
      '|
    }
    complexity: {
      shape: sql_table
      label: "Complexity Analysis"
      naive: "Naive scan | O(n) per add | O(n²) total"
      hash: "Hash table | O(1) avg | O(n) total"
      note: "n = number of unique constants"
    }
  }
  benefits: {
    direction: down
    label: "Benefits"
    ben1: {
      label: "Memory Efficiency"
      code: |'md
        * Single allocation per unique value
        * Reduces GC pressure
        * Better cache locality
      '|
    }
    ben2: {
      label: "Bytecode Compactness"
      code: |'md
        * Same index reused
        * Smaller constant pool
        * Faster loading
      '|
    }
    ben3: {
      label: "Comparison Speed"
      code: |'md
        * Pointer equality check
        * No string comparison
        * `if (a == b)` → O(1)
      '|
    }
  }
}
legend: {
  near: bottom-right
  label: "Key Insight"
  shape: callout
  content: |md
    **String interning** is the same technique
    used by Python (`sys.intern()`), Java
    (string pool), and JavaScript engines.
    Your constant pool IS an intern table!
  '|
}
row3.impl -> row3.benefits: "Enables"