direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Disassembler Output Format
  Bytecode → Human-Readable Assembly
| {
  near: top-center
  shape: text
  style.font-size: 32
  style.underline: true
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bytecode: {
    direction: down
    label: "Raw Bytecode (bytes)"
    bytes: {
      shape: sql_table
      label: "Bytecode Chunk (chunk.c)"
      row0: "0x00 | 10 | opcode: LOAD_CONST"
      row1: "0x01 | 00 | operand high byte"
      row2: "0x02 | 00 | operand low byte (index 0)"
      row3: "0x03 | 10 | opcode: LOAD_CONST"
      row4: "0x04 | 00 | operand high byte"
      row5: "0x05 | 01 | operand low byte (index 1)"
      row6: "0x06 | 20 | opcode: ADD"
      row7: "0x07 | 10 | opcode: LOAD_CONST"
      row8: "0x08 | 00 | operand high byte"
      row9: "0x09 | 02 | operand low byte (index 2)"
      row10: "0x0A | 44 | opcode: PRINT"
      row11: "0x0B | 00 | opcode: HALT"
    }
    constpool: {
      shape: sql_table
      label: "Constant Pool"
      idx0: "0 | 3.0"
      idx1: "1 | 5.0"
      idx2: "2 | 8.0 (result)"
    }
  }
  arrow: {
    shape: text
    label: "disassemble_chunk()"
    style.font: mono
    style.font-size: 20
    style.fill: transparent
    style.stroke: transparent
  }
  output: {
    direction: down
    label: "Disassembled Output"
    header: {
      shape: sql_table
      label: "Header"
      line1: "== expression =="
      line2: "Offset  Bytes     Instruction     Operands"
      line3: "------  --------  ---------------  --------"
    }
    instructions: {
      shape: sql_table
      label: "Disassembled Instructions"
      inst0: "000000  10 00 00  LOAD_CONST     constant[0] = 3"
      inst3: "000003  10 00 01  LOAD_CONST     constant[1] = 5"
      inst6: "000006  20       ADD"
      inst7: "000007  10 00 02  LOAD_CONST     constant[2] = 8.0"
      inst10: "000010  44       PRINT"
      inst11: "000011  00       HALT"
    }
    note: |md
      **Column Breakdown:**
      - **Offset**: Byte position in bytecode array
      - **Bytes**: Raw hex bytes of instruction
      - **Instruction**: Human-readable opcode name
      - **Operands**: Interpreted values with context
    |
  }
}
bytecode -> arrow -> output
legend: {
  near: bottom-center
  direction: right
  style.fill: "#f5f5f5"
  style.stroke: "#cccccc"
  style.border-radius: 8
  key: {
    label: "Key"
    shape: text
    style.bold: true
  }
  item1: "1-byte opcode (0x10 = LOAD_CONST)"
  item2: "2-byte operand (big-endian index)"
  item3: "1-byte opcode (0x20 = ADD, 0x00 = HALT)"
}