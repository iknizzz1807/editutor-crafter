direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  category: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      border-radius: 8
      font-color: "#1A5276"
      bold: true
    }
  }
  opcode: {
    style: {
      fill: "#FDFEFE"
      stroke: "#566573"
      stroke-width: 1
      border-radius: 4
      font: mono
    }
  }
  control: {
    style.fill: "#FADBD8"
    style.stroke: "#C0392B"
    style.font-color: "#922B21"
  }
  stack: {
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
    style.font-color: "#1E8449"
  }
  arith: {
    style.fill: "#FCF3CF"
    style.stroke: "#F39C12"
    style.font-color: "#9A7D0A"
  }
  comp: {
    style.fill: "#E8DAEF"
    style.stroke: "#8E44AD"
    style.font-color: "#6C3483"
  }
  func: {
    style.fill: "#D6EAF8"
    style.stroke: "#3498DB"
    style.font-color: "#21618C"
  }
}
title: |md
  # Opcode Taxonomy by Category
  **Bytecode VM Instruction Set — 20 Opcodes**
| {near: top-center}
root: OpCode {
  class: category
  style.fill: "#2C3E50"
  style.stroke: "#1A252F"
  style.font-color: "#ECF0F1"
  style.font-size: 20
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  control_flow: Control Flow {
    direction: down
    class: [category; control]
    op_halt: OP_HALT {
      class: [opcode; control]
      label: "0x00 | HALT"
    }
    op_jump: OP_JUMP {
      class: [opcode; control]
      label: "0x01 | JUMP"
    }
    op_jif: OP_JUMP_IF_FALSE {
      class: [opcode; control]
      label: "0x02 | JUMP_IF_FALSE"
    }
  }
  stack_ops: Stack Operations {
    direction: down
    class: [category; stack]
    op_load: OP_LOAD_CONST {
      class: [opcode; stack]
      label: "0x10 | LOAD_CONST"
    }
    op_pop: OP_POP {
      class: [opcode; stack]
      label: "0x11 | POP"
    }
    op_dup: OP_DUP {
      class: [opcode; stack]
      label: "0x12 | DUP"
    }
  }
  arithmetic: Arithmetic {
    direction: down
    class: [category; arith]
    op_add: OP_ADD {
      class: [opcode; arith]
      label: "0x20 | ADD"
    }
    op_sub: OP_SUB {
      class: [opcode; arith]
      label: "0x21 | SUB"
    }
    op_mul: OP_MUL {
      class: [opcode; arith]
      label: "0x22 | MUL"
    }
    op_div: OP_DIV {
      class: [opcode; arith]
      label: "0x23 | DIV"
    }
    op_neg: OP_NEG {
      class: [opcode; arith]
      label: "0x24 | NEG"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: Comparison {
    direction: down
    class: [category; comp]
    op_eq: OP_EQUAL {
      class: [opcode; comp]
      label: "0x30 | EQUAL"
    }
    op_ne: OP_NOT_EQUAL {
      class: [opcode; comp]
      label: "0x31 | NOT_EQUAL"
    }
    op_lt: OP_LESS {
      class: [opcode; comp]
      label: "0x32 | LESS"
    }
    op_gt: OP_GREATER {
      class: [opcode; comp]
      label: "0x33 | GREATER"
    }
    op_le: OP_LESS_EQ {
      class: [opcode; comp]
      label: "0x34 | LESS_EQ"
    }
    op_ge: OP_GREATER_EQ {
      class: [opcode; comp]
      label: "0x35 | GREATER_EQ"
    }
  }
  functions: Functions {
    direction: down
    class: [category; func]
    op_load_local: OP_LOAD_LOCAL {
      class: [opcode; func]
      label: "0x40 | LOAD_LOCAL"
    }
    op_store_local: OP_STORE_LOCAL {
      class: [opcode; func]
      label: "0x41 | STORE_LOCAL"
    }
    op_call: OP_CALL {
      class: [opcode; func]
      label: "0x42 | CALL"
    }
    op_return: OP_RETURN {
      class: [opcode; func]
      label: "0x43 | RETURN"
    }
  }
}
