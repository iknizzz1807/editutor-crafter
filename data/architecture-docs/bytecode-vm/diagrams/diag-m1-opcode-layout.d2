direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Bytecode Instruction Memory Layout
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_view: {
    direction: down
    label: "Instruction Memory (chunk->bytecode.code)"
    byte_grid: {
      grid-columns: 8
      grid-gap: 0
      cell_00: "0x10" {
        style.fill: "#E8F4FD"
        style.stroke: "#2E86AB"
        style.font: mono
        style.bold: true
      }
      cell_01: "0x00" {
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
        style.font: mono
      }
      cell_02: "0x05" {
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
        style.font: mono
      }
      cell_03: "0x20" {
        style.fill: "#E8F4FD"
        style.stroke: "#2E86AB"
        style.font: mono
        style.bold: true
      }
      cell_04: "0x10" {
        style.fill: "#E8F4FD"
        style.stroke: "#2E86AB"
        style.font: mono
        style.bold: true
      }
      cell_05: "0x00" {
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
        style.font: mono
      }
      cell_06: "0x0A" {
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
        style.font: mono
      }
      cell_07: "0x21" {
        style.fill: "#E8F4FD"
        style.stroke: "#2E86AB"
        style.font: mono
        style.bold: true
      }
    }
    offset_labels: {
      direction: right
      grid-columns: 8
      grid-gap: 0
      off0: "0" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
      off1: "1" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
      off2: "2" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
      off3: "3" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
      off4: "4" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
      off5: "5" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
      off6: "6" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
      off7: "7" {
        style.fill: transparent
        style.stroke: transparent
        style.font: mono
        style.font-size: 12
      }
    }
    offset_labels.style.fill: transparent
    offset_labels.style.stroke: transparent
  }
  instruction_decode: {
    direction: down
    label: "Instruction Decoding"
    instr1: {
      label: "LOAD_CONST 5"
      shape: rectangle
      width: 200
      code: |'c
        opcode: 0x10
        operand: 0x0005 (16-bit)
        size: 3 bytes
      '|
      style.fill: "#E3F2FD"
    }
    instr2: {
      label: "ADD"
      shape: rectangle
      width: 200
      code: |'c
        opcode: 0x20
        operand: none
        size: 1 byte
      '|
      style.fill: "#E8F5E9"
    }
    instr3: {
      label: "LOAD_CONST 10"
      shape: rectangle
      width: 200
      code: |'c
        opcode: 0x10
        operand: 0x000A (16-bit)
        size: 3 bytes
      '|
      style.fill: "#E3F2FD"
    }
    instr4: {
      label: "SUB"
      shape: rectangle
      width: 200
      code: |'c
        opcode: 0x21
        operand: none
        size: 1 byte
      '|
      style.fill: "#E8F5E9"
    }
    instr1 -> instr2 -> instr3 -> instr4: "next" {
      style.stroke-dash: 3
      style.stroke: "#666"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ip_movement: {
    direction: down
    label: "IP Advancement Pattern"
    trace: {
      shape: sequence_diagram
      width: 500
      ip_reg: "IP Register"
      memory: "Bytecode Array"
      decoder: "Decoder"
      step1: {
        ip_reg -> memory: "read byte[0]"
        memory -> decoder: "0x10 (LOAD_CONST)"
        decoder -> decoder: "operand_count = 2"
        ip_reg -> ip_reg: "IP += 3 (1+2)"
      }
      step2: {
        ip_reg -> memory: "read byte[3]"
        memory -> decoder: "0x20 (ADD)"
        decoder -> decoder: "operand_count = 0"
        ip_reg -> ip_reg: "IP += 1"
      }
      step3: {
        ip_reg -> memory: "read byte[4]"
        memory -> decoder: "0x10 (LOAD_CONST)"
        decoder -> decoder: "operand_count = 2"
        ip_reg -> ip_reg: "IP += 3 (1+2)"
      }
      step4: {
        ip_reg -> memory: "read byte[7]"
        memory -> decoder: "0x21 (SUB)"
        decoder -> decoder: "operand_count = 0"
        ip_reg -> ip_reg: "IP += 1"
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    direction: down
    label: "Legend"
    opcode_cell: {
      direction: right
      cell: "" {
        width: 30
        height: 30
        shape: square
        style.fill: "#E8F4FD"
        style.stroke: "#2E86AB"
      }
      desc: "Opcode byte (1 byte)"
    }
    operand_cell: {
      direction: right
      cell: "" {
        width: 30
        height: 30
        shape: square
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
      }
      desc: "Operand byte (part of 16-bit)"
    }
    operand_format: {
      label: "16-bit Operand Format (Big-Endian)"
      code: |'c
        byte[0] = (operand >> 8) & 0xFF  // High
        byte[1] = operand & 0xFF         // Low
      '|
      shape: rectangle
      width: 280
      style.fill: "#F5F5F5"
    }
  }
  size_table: {
    direction: down
    label: "Instruction Sizes (chunk.c)"
    table: {
      shape: sql_table
      label: "opcode_operand_count() Lookup"
      op_halt: "0x00 | HALT           | 0 bytes"
      op_jump: "0x01 | JUMP           | 2 bytes"
      op_jif:  "0x02 | JUMP_IF_FALSE  | 2 bytes"
      op_lc:   "0x10 | LOAD_CONST     | 2 bytes"
      op_pop:  "0x11 | POP            | 0 bytes"
      op_dup:  "0x12 | DUP            | 0 bytes"
      op_add:  "0x20 | ADD            | 0 bytes"
      op_sub:  "0x21 | SUB            | 0 bytes"
      op_ll:   "0x40 | LOAD_LOCAL     | 2 bytes"
      op_sl:   "0x41 | STORE_LOCAL    | 2 bytes"
      op_call: "0x42 | CALL           | 6 bytes (3 operands)"
      total:   "Total: 1 + operand_count bytes per instruction"
    }
  }
}
note_ip_convention: |md
  **IP Convention**: After fetching opcode, IP points to first operand byte.
  After processing all operands, IP points to next instruction's opcode.
| {
  near: bottom-center
  shape: rectangle
  width: 450
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
}