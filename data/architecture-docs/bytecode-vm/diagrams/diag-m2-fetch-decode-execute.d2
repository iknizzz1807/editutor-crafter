direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "VM Interpreter Loop: Fetch-Decode-Execute State Machine"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
states: {
  direction: down
  idle: {
    shape: circle
    label: "IDLE"
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 2
    }
  }
  fetch: {
    shape: rectangle
    label: "FETCH"
    style: {
      fill: "#B5D8F0"
      stroke: "#2E75B6"
      stroke-width: 2
    }
    width: 180
    fetch_code: {
      label: "Fetch Logic (vm.c)"
      width: 320
      code: |'c
        uint8_t opcode_byte = 
          vm->chunk->bytecode.code[vm->ip++];
        OpCode instruction = (OpCode)opcode_byte;
      '|
    }
  }
  decode: {
    shape: diamond
    label: "DECODE"
    style: {
      fill: "#F9E79F"
      stroke: "#B7950B"
      stroke-width: 2
    }
    width: 140
    height: 100
  }
  execute: {
    shape: rectangle
    label: "EXECUTE"
    style: {
      fill: "#ABEBC6"
      stroke: "#1E8449"
      stroke-width: 2
    }
    width: 180
    handlers: {
      label: "Opcode Handlers"
      shape: class
      OP_LOAD_CONST: "uint16_t index → push pool[index]"
      OP_ADD: "b = pop(); a = pop(); push(a+b)"
      OP_JUMP: "ip = read_operand(ip)"
      OP_JUMP_IF_FALSE: "if(pop()==0) ip = target"
      OP_CALL: "push frame; jump to entry"
      OP_RETURN: "pop frame; push retval"
    }
  }
  halt: {
    shape: circle
    label: "HALT"
    style: {
      fill: "#F5B7B1"
      stroke: "#C0392B"
      stroke-width: 3
      double-border: true
    }
  }
  error: {
    shape: circle
    label: "ERROR"
    style: {
      fill: "#FADBD8"
      stroke: "#922B21"
      stroke-width: 2
      stroke-dash: 4
    }
  }
}
idle -> states.fetch: "vm_interpret(vm, chunk)"
style: {
  stroke: "#2E75B6"
  stroke-width: 2
}
states.fetch -> states.decode: "opcode_byte ready"
states.fetch -> states.decode: "Type: uint8_t | 1 byte"
style: {
  stroke: "#2E75B6"
  stroke-width: 2
}
states.decode -> states.execute: "valid opcode\n(0x00-0x43)"
style: {
  stroke: "#1E8449"
  stroke-width: 2
}
states.decode -> states.error: "invalid opcode\n(> 0x43)"
style: {
  stroke: "#C0392B"
  stroke-width: 2
  stroke-dash: 4
}
states.execute -> states.fetch: "continue"
states.execute -> states.fetch: "Type: void | loop"
style: {
  stroke: "#1E8449"
  stroke-width: 2
}
states.execute -> states.halt: "OP_HALT (0x00)"
style: {
  stroke: "#C0392B"
  stroke-width: 3
}
states.execute -> states.error: "runtime error\n(div/0, stack overflow)"
style: {
  stroke: "#922B21"
  stroke-width: 2
  stroke-dash: 4
}
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#CCCCCC"
    stroke-width: 1
    border-radius: 4
  }
  title: "Legend"
  normal: {
    shape: rectangle
    label: "Normal Flow"
    style: {
      fill: "#1E8449"
      stroke: "#1E8449"
    }
    width: 60
    height: 20
  }
  error_path: {
    shape: rectangle
    label: "Error Path"
    style: {
      fill: "#922B21"
      stroke: "#922B21"
      stroke-dash: 4
    }
    width: 60
    height: 20
  }
  exit_path: {
    shape: rectangle
    label: "Exit Path"
    style: {
      fill: "#C0392B"
      stroke: "#C0392B"
      stroke-width: 3
    }
    width: 60
    height: 20
  }
}
cycle_annotation: {
  near: center-right
  label: |md
    **Cycle Timing**
    Each iteration:
    - FETCH: ~2-5 CPU cycles
    - DECODE: ~1-2 CPU cycles  
    - EXECUTE: ~5-50+ CPU cycles
    Total: ~10-60 cycles/instruction
  |
  shape: rectangle
  style: {
    fill: "#FEF9E7"
    stroke: "#F4D03F"
    border-radius: 4
    stroke-width: 1
  }
  width: 200
}
ip_annotation: {
  near: center-left
  label: |md
    **IP Register**
    Before FETCH:
    
    ip = N
    
    After FETCH:
    
    ip = N + 1
    
    Points to *next* instruction
  |
  shape: rectangle
  style: {
    fill: "#EBF5FB"
    stroke: "#5DADE2"
    border-radius: 4
    stroke-width: 1
  }
  width: 180
}