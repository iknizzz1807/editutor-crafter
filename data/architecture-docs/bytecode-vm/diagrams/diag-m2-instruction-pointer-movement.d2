direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Instruction Pointer Advancement Patterns
  Bytecode execution trace showing IP position at each step
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bytecode_layout: {
    direction: down
    label: "Bytecode Memory Layout"
    layout: {
      shape: sql_table
      label: "Bytecode Array (chunk->bytecode.code)"
      offset: "Offset"
      byte0: "0x00 | 0x10 | OP_LOAD_CONST"
      byte1: "0x01 | 0x00 | operand high byte"
      byte2: "0x02 | 0x00 | operand low byte"
      byte3: "0x03 | 0x20 | OP_ADD"
      byte4: "0x04 | 0x00 | OP_HALT"
      note: "Total: 5 bytes"
    }
    instruction_sizes: {
      label: "Instruction Sizes"
      shape: sql_table
      lc: "LOAD_CONST | 3 bytes (1 opcode + 2 operand)"
      add: "ADD        | 1 byte  (opcode only)"
      halt: "HALT       | 1 byte  (opcode only)"
    }
  }
  step_trace: {
    direction: down
    label: "Execution Trace"
    step0: {
      label: "Step 0: Initial State"
      width: 380
      code: |'c
        IP = 0  (points to opcode)
        Stack: []
      '|
      style.fill: "#E8F5E9"
    }
    step1: {
      label: "Step 1: Fetch OP_LOAD_CONST"
      width: 380
      code: |'c
        IP = 0 → read 0x10 (LOAD_CONST)
        IP++ → IP = 1
      '|
      style.fill: "#E3F2FD"
    }
    step2: {
      label: "Step 2: Read 16-bit Operand"
      width: 380
      code: |'c
        IP = 1 → read operand bytes 0x00, 0x00
        IP += 2 → IP = 3
        Push constants[0] onto stack
      '|
      style.fill: "#E3F2FD"
    }
    step3: {
      label: "Step 3: Fetch OP_ADD"
      width: 380
      code: |'c
        IP = 3 → read 0x20 (ADD)
        IP++ → IP = 4
        Pop 2 values, push result
      '|
      style.fill: "#FFF3E0"
    }
    step4: {
      label: "Step 4: Fetch OP_HALT"
      width: 380
      code: |'c
        IP = 4 → read 0x00 (HALT)
        Execution stops
        Final IP = 5 (past HALT)
      '|
      style.fill: "#FFEBEE"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ip_movement: {
    direction: down
    label: "IP Movement Visualization"
    memory_view: {
      direction: right
      label: ""
      cell0: {
        label: "0x10\nLOAD_CONST"
        shape: rectangle
        width: 90
        height: 60
        style.fill: "#E3F2FD"
      }
      cell1: {
        label: "0x00\nop[7:8]"
        shape: rectangle
        width: 70
        height: 60
        style.fill: "#E3F2FD"
        style.stroke-dash: 3
      }
      cell2: {
        label: "0x00\nop[0:7]"
        shape: rectangle
        width: 70
        height: 60
        style.fill: "#E3F2FD"
        style.stroke-dash: 3
      }
      cell3: {
        label: "0x20\nADD"
        shape: rectangle
        width: 70
        height: 60
        style.fill: "#FFF3E0"
      }
      cell4: {
        label: "0x00\nHALT"
        shape: rectangle
        width: 70
        height: 60
        style.fill: "#FFEBEE"
      }
    }
    ip_arrows: {
      direction: right
      label: ""
      arrow0: {
        label: "IP=0\nfetch"
        shape: text
      }
      arrow1: {
        label: "IP=1,2\noperand"
        shape: text
      }
      arrow2: {
        label: "IP=3\nfetch"
        shape: text
      }
      arrow3: {
        label: "IP=4\nhalt"
        shape: text
      }
      arrow4: {
        label: "IP=5\nstopped"
        shape: text
        style.fill: transparent
      }
    }
    memory_view.cell0 -> ip_arrows.arrow0: {
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
    memory_view.cell2 -> ip_arrows.arrow1: {
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
    memory_view.cell3 -> ip_arrows.arrow2: {
      style.stroke: "#F57C00"
      style.stroke-width: 2
    }
    memory_view.cell4 -> ip_arrows.arrow3: {
      style.stroke: "#D32F2F"
      style.stroke-width: 2
    }
  }
  advancement_rules: {
    direction: down
    label: "IP Advancement Rules"
    rules: {
      shape: sql_table
      label: "opcode_operand_count() Logic"
      r1: "OP_LOAD_CONST   | return 2"
      r2: "OP_ADD          | return 0"
      r3: "OP_HALT         | return 0"
      r4: "OP_JUMP         | return 2"
      r5: "OP_CALL         | return 6 (3 operands)"
    }
    formula: {
      label: "Formula"
      width: 320
      code: |'c
        // After fetching opcode:
        IP = IP + 1 + opcode_operand_count(opcode)
        // Example for LOAD_CONST:
        IP = 0 + 1 + 2 = 3
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  key_insight: {
    direction: down
    label: "Key Insight: IP Always Points Ahead"
    width: 400
    insight: |md
      **After reading an instruction, IP points to the NEXT
      instruction, not the current one.**
      This convention simplifies jump calculation:
      - `JUMP target` just sets `IP = target`
      - The next fetch naturally reads from the new location
      The IP advance happens in two phases:
      1. **Fetch**: `IP++` (past the opcode)
      2. **Operands**: `IP += operand_count`
    |
  }
  common_pattern: {
    direction: down
    label: "Common Fetch Pattern"
    width: 420
    pattern: {
      label: "vm.c — Interpreter Loop"
      width: 400
      code: |'c
        // FETCH: Read opcode, advance IP
        uint8_t opcode = chunk->code[vm->ip++];
        // DECODE & EXECUTE with operand read
        switch (opcode) {
          case OP_LOAD_CONST: {
            // Read operand at current IP
            uint16_t idx = read_operand(vm->ip);
            vm->ip += 2;  // Advance past operand
            push(vm, constants[idx]);
            break;
          }
          case OP_ADD: {
            // No operands to read
            Value b = pop(vm);
            Value a = pop(vm);
            push(vm, a + b);
            break;
          }
        }
      '|
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  style.border-radius: 8
  l1: {
    label: "Opcode Byte"
    shape: rectangle
    style.fill: "#E3F2FD"
    width: 80
  }
  l2: {
    label: "Operand Byte"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke-dash: 3
    width: 80
  }
  l3: {
    label: "ADD"
    shape: rectangle
    style.fill: "#FFF3E0"
    width: 60
  }
  l4: {
    label: "HALT"
    shape: rectangle
    style.fill: "#FFEBEE"
    width: 60
  }
}