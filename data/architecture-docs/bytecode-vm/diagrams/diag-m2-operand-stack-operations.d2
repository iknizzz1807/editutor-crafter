direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Operand Stack Before/After Operations
  Stack-based execution trace showing LIFO push/pop discipline
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  panel1: {
    direction: down
    label: "1. Initial State"
    stack1: {
      shape: sql_table
      label: "Operand Stack (empty)"
      note: "// stack_top = 0"
    }
    sp1: {
      label: "stack_top → 0"
      width: 120
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    sp1 -> stack1: {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      target-arrowhead.shape: arrow
    }
  }
  panel2: {
    direction: down
    label: "2. After LOAD_CONST 42"
    stack2: {
      shape: sql_table
      label: "Operand Stack"
      slot0: "0 | Value | 42.0"
    }
    sp2: {
      label: "stack_top → 1"
      width: 120
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    sp2 -> stack2.slot0: {
      style.stroke: "#2196F3"
      style.stroke-width: 2
      target-arrowhead.shape: arrow
    }
    instr2: {
      label: "Instruction"
      code: |'c
        LOAD_CONST 0  ; push 42
      '|
      width: 160
      style.fill: "#FFF3E0"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  panel3: {
    direction: down
    label: "3. After LOAD_CONST 10"
    stack3: {
      shape: sql_table
      label: "Operand Stack"
      slot0: "0 | Value | 42.0"
      slot1: "1 | Value | 10.0"
    }
    sp3: {
      label: "stack_top → 2"
      width: 120
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    sp3 -> stack3.slot1: {
      style.stroke: "#2196F3"
      style.stroke-width: 2
      target-arrowhead.shape: arrow
    }
    instr3: {
      label: "Instruction"
      code: |'c
        LOAD_CONST 1  ; push 10
      '|
      width: 160
      style.fill: "#FFF3E0"
    }
  }
  panel4: {
    direction: down
    label: "4. After ADD"
    stack4: {
      shape: sql_table
      label: "Operand Stack"
      slot0: "0 | Value | 52.0"
      note: "// Result of 42 + 10"
    }
    sp4: {
      label: "stack_top → 1"
      width: 120
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    sp4 -> stack4.slot0: {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      target-arrowhead.shape: arrow
    }
    instr4: {
      label: "Instruction"
      code: |'c
        ADD  ; pop 10, pop 42
             ; push 52
      '|
      width: 160
      style.fill: "#FFF3E0"
    }
  }
}
panel1 -> panel2: "PUSH" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.stroke-dash: 0
  style.animated: true
}
panel2 -> panel3: "PUSH" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.stroke-dash: 0
  style.animated: true
}
panel3 -> panel4: "POP 2, PUSH 1" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  style.stroke-dash: 0
  style.animated: true
}
legend: {
  near: bottom-center
  direction: right
  push_legend: {
    label: "PUSH"
    shape: rectangle
    width: 80
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  pop_legend: {
    label: "POP"
    shape: rectangle
    width: 80
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  note: |md
    **LIFO Discipline**: Last-In-First-Out  
    Right operand (10) popped first, then left (42)  
    Result: 42 + 10 = 52 pushed
  |
}
stack1.style.fill: "#FAFAFA"
stack2.style.fill: "#FAFAFA"
stack3.style.fill: "#FAFAFA"
stack4.style.fill: "#FAFAFA"