direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Stack Overflow/Underflow Detection
  Runtime bounds checking prevents memory corruption
| {near: top-center}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stack_container: {
    direction: down
    label: "Operand Stack (STACK_MAX = 256)"
    stack_limit: {
      label: "stack_limit (STACK_MAX)"
      shape: rectangle
      width: 200
      style: {
        fill: "#FFE4E1"
        stroke: "#DC143C"
        stroke-width: 3
        stroke-dash: 4
      }
    }
    stack_growth: {
      direction: down
      label: ""
      style.stroke: transparent
      slot_255: {
        label: "stack[255]"
        shape: rectangle
        width: 200
        style.fill: "#F5F5F5"
      }
      slot_254: {
        label: "stack[254]"
        shape: rectangle
        width: 200
        style.fill: "#F5F5F5"
      }
      ellipsis_high: {
        label: "..."
        shape: text
      }
      slot_3: {
        label: "stack[3]"
        shape: rectangle
        width: 200
        style.fill: "#E8F5E9"
      }
      slot_2: {
        label: "stack[2] ← stack_top = 3"
        shape: rectangle
        width: 200
        style: {
          fill: "#C8E6C9"
          stroke: "#4CAF50"
          stroke-width: 2
        }
      }
      slot_1: {
        label: "stack[1] = 5.0"
        shape: rectangle
        width: 200
        style.fill: "#E8F5E9"
      }
      slot_0: {
        label: "stack[0] = 3.0"
        shape: rectangle
        width: 200
        style.fill: "#E8F5E9"
      }
    }
    stack_base: {
      label: "stack_base (index 0)"
      shape: rectangle
      width: 200
      style: {
        fill: "#E3F2FD"
        stroke: "#2196F3"
        stroke-width: 3
        stroke-dash: 4
      }
    }
  }
  operations: {
    direction: down
    label: "Operations"
    push_op: {
      label: "PUSH Operation"
      shape: rectangle
      width: 280
      style.fill: "#E8F5E9"
      push_code: {
        label: |'c
void vm_push(VM* vm, Value value) {
  if (vm->stack_top >= STACK_MAX) {
    fprintf(stderr, 
      "Runtime error: Stack overflow\n");
    exit(1);
  }
  vm->stack[vm->stack_top++] = value;
}
        '|
        shape: rectangle
        width: 270
        style.fill: "#FAFAFA"
      }
    }
    pop_op: {
      label: "POP Operation"
      shape: rectangle
      width: 280
      style.fill: "#FFF3E0"
      pop_code: {
        label: |'c
Value vm_pop(VM* vm) {
  if (vm->stack_top <= 0) {
    fprintf(stderr, 
      "Runtime error: Stack underflow\n");
    exit(1);
  }
  return vm->stack[--vm->stack_top];
}
        '|
        shape: rectangle
        width: 270
        style.fill: "#FAFAFA"
      }
    }
  }
}
row_errors: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  overflow_error: {
    label: "OVERFLOW Detected"
    shape: diamond
    width: 180
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 3
    }
    overflow_desc: {
      label: |md
**Trigger:** `stack_top >= STACK_MAX`
**Cause:** Too many nested expressions or deep recursion without sufficient stack space
**Result:** `INTERPRET_RUNTIME_ERROR`
      |
      shape: rectangle
      width: 220
      style.fill: "#FFEBEE"
    }
  }
  underflow_error: {
    label: "UNDERFLOW Detected"
    shape: diamond
    width: 180
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 3
    }
    underflow_desc: {
      label: |md
**Trigger:** `stack_top <= 0`
**Cause:** POP with empty stack, or binary op without enough operands
**Result:** `INTERPRET_RUNTIME_ERROR`
      |
      shape: rectangle
      width: 220
      style.fill: "#FFEBEE"
    }
  }
}
stack_container.stack_limit -> overflow_error: "exceeds limit" {
  style: {
    stroke: "#D32F2F"
    stroke-width: 2
    stroke-dash: 4
  }
}
stack_container.stack_base -> underflow_error: "below base" {
  style: {
    stroke: "#D32F2F"
    stroke-width: 2
    stroke-dash: 4
  }
}
operations.push_op -> overflow_error: "check before push" {
  style: {
    stroke: "#4CAF50"
    stroke-dash: 3
  }
}
operations.pop_op -> underflow_error: "check before pop" {
  style: {
    stroke: "#FF9800"
    stroke-dash: 3
  }
}
legend: {
  near: bottom-center
  label: ""
  direction: right
  safe: {
    label: "Safe Zone"
    shape: rectangle
    width: 80
    style.fill: "#E8F5E9"
  }
  danger: {
    label: "Error Zone"
    shape: rectangle
    width: 80
    style.fill: "#FFCDD2"
  }
  current: {
    label: "stack_top"
    shape: rectangle
    width: 80
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
}