direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  label: "Subtraction Operand Order: 10 - 3"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    direction: down
    label: "Step 1: Source"
    source_box: {
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      expr: |'c
        10 - 3
      '|
      width: 120
    }
    note1: {
      label: "Expression evaluates\nleft to right"
      shape: text
      style.font-size: 11
      style.font-color: "#666666"
    }
  }
  step2: {
    direction: down
    label: "Step 2: Push 10"
    stack1: {
      shape: sql_table
      label: "Operand Stack"
      s1: "0 | Value | 10.0"
      empty: "1 | --- | ..."
      sz: "Top at index 1"
    }
    code1: {
      label: "LOAD_CONST 0"
      width: 140
      code: |'c
        // Push first operand
        vm_push(vm, 10.0);
      '|
    }
  }
  step3: {
    direction: down
    label: "Step 3: Push 3"
    stack2: {
      shape: sql_table
      label: "Operand Stack"
      s0: "0 | Value | 10.0"
      s1: "1 | Value | 3.0  ← TOP"
      sz: "Top at index 2"
    }
    code2: {
      label: "LOAD_CONST 1"
      width: 140
      code: |'c
        // Push second operand
        vm_push(vm, 3.0);
      '|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step4: {
    direction: down
    label: "Step 4: SUB Pops"
    pop_order: {
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.stroke-width: 2
      pop_label: "POP ORDER (LIFO)"
      pop_b: "1st pop → b = 3.0 (TOP)"
      pop_a: "2nd pop → a = 10.0"
      style.font: mono
    }
    stack3: {
      shape: sql_table
      label: "After Both Pops"
      empty: "0 | --- | (empty)"
      sz: "Top at index 0"
      style.fill: "#FFEBEE"
    }
    code3: {
      label: "SUB pops operands"
      width: 180
      code: |'c
        Value b = vm_pop(vm); // 3.0
        Value a = vm_pop(vm); // 10.0
      '|
    }
  }
  step5: {
    direction: down
    label: "Step 5: Compute"
    compute_box: {
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      formula: |'c
        a - b = 10.0 - 3.0 = 7.0
      '|
      width: 200
    }
    warning_box: {
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      style.stroke-width: 2
      warn: "⚠️ WRONG: b - a = 3 - 10 = -7"
      style.font: mono
      style.font-color: "#C62828"
    }
    note2: {
      label: "Left operand popped SECOND\nRight operand popped FIRST"
      shape: text
      style.font-size: 11
      style.font-color: "#1565C0"
    }
  }
  step6: {
    direction: down
    label: "Step 6: Push Result"
    stack4: {
      shape: sql_table
      label: "Operand Stack"
      result: "0 | Value | 7.0"
      sz: "Top at index 1"
      style.fill: "#E8F5E9"
    }
    code4: {
      label: "Push result"
      width: 160
      code: |'c
        vm_push(vm, a - b);
        // Stack: [7.0]
      '|
    }
    success: {
      label: "✓ Correct: 7.0"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
  }
}
step1 -> step2: "emit"
step2 -> step3: "emit"
step3 -> step4: "execute SUB"
step4 -> step5: "compute"
step5 -> step6: "push"
legend: {
  near: bottom-center
  direction: right
  key1: {
    label: "Stack grows upward\nTOP is highest index"
    shape: text
    style.font-size: 10
  }
  key2: {
    label: "LIFO: Last In = First Out\nRight operand on TOP"
    shape: text
    style.font-size: 10
  }
  key3: {
    label: "Binary ops: pop right first\nthen left, compute left op right"
    shape: text
    style.font-size: 10
  }
}
impl_box: {
  near: bottom-right
  label: "OP_SUB Implementation (vm.c)"
  impl: |'c
    case OP_SUB: {
      Value b = vm_pop(vm);  // Right (TOP)
      Value a = vm_pop(vm);  // Left (below)
      vm_push(vm, a - b);    // a - b, NOT b - a!
      break;
    }
  '|
  width: 320
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.font: mono
}