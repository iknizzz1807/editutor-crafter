direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # VM Struct Memory Layout
  `struct VM` — 64-bit system, total ~38KB
| {near: top-center}
vm_struct: {
  shape: sql_table
  label: "struct VM (vm.h)"
  f0: "0x00 | uint8_t*      | ip"
  f1: "0x08 | Value*        | stack_top"
  f2: "0x10 | int           | frame_count"
  f3: "0x18 | const char*   | error"
  f4: "0x20 | Value[256]    | stack"
  f5: "0x820 | CallFrame[64] | frames"
  sz: "Total: ~38,472 bytes (0x9618)"
}
memory_regions: {
  direction: right
  label: ""
  style.stroke: transparent
  style.fill: transparent
  stack_region: {
    direction: down
    label: "Operand Stack\nstack[256] @ 0x20"
    stack_mem: {
      shape: sql_table
      label: "Value stack[256] — 2048 bytes"
      s0: "0x20  | Value | stack[0]"
      s1: "0x28  | Value | stack[1]"
      s2: "0x30  | Value | stack[2]"
      s255: "...  | Value | ..."
      s256: "0x818 | Value | stack[255]"
    }
    stack_top_ptr: {
      label: "stack_top"
      width: 120
      code: |'c
        // Points to NEXT
        // free slot
        // stack_top == 0
        // means empty stack
      '|
    }
  }
  frames_region: {
    direction: down
    label: "Call Frames\nframes[64] @ 0x820"
    frame_struct: {
      shape: sql_table
      label: "struct CallFrame (frame.h) — 32 bytes each"
      cf0: "0x00 | uint8_t*    | ip"
      cf1: "0x08 | Value*      | stack_base"
      cf2: "0x10 | int         | locals_count"
      cf3: "0x18 | uint8_t*    | return_addr"
      cf4: "0x20 | -- padding --"
      sz: "Total: 32 bytes"
    }
    frames_array: {
      shape: sql_table
      label: "frames[64] — 2048 bytes total"
      fa0: "0x820  | CallFrame | frames[0] (main)"
      fa1: "0x840  | CallFrame | frames[1]"
      fa2: "0x860  | CallFrame | frames[2]"
      fa3: "...    | CallFrame | ..."
      fa63: "0xD20  | CallFrame | frames[63]"
    }
    frame_count_box: {
      label: "frame_count"
      width: 140
      code: |'c
        // Active frames
        // 0 = no frames
        // 1 = main only
        // 64 = overflow
      '|
    }
  }
  pointers_region: {
    direction: down
    label: "Pointer State"
    ip_box: {
      label: "ip (Instruction Pointer)"
      width: 180
      code: |'c
        // Points into
        // chunk->bytecode.code[]
        // Current opcode offset
      '|
    }
    error_box: {
      label: "error string"
      width: 180
      code: |'c
        // NULL if no error
        // Points to static
        // error message
      '|
    }
  }
}
bytecode_ref: {
  direction: down
  label: "Referenced Memory (not owned by VM)"
  chunk_box: {
    label: "Chunk (owned by caller)"
    width: 200
    code: |'c
      typedef struct {
        BytecodeArray bytecode;
        ConstantPool constants;
      } Chunk;
    '|
  }
  bytecode_mem: {
    shape: sql_table
    label: "bytecode.code[] — uint8_t[]"
    b0: "0x00 | uint8_t | opcode"
    b1: "0x01 | uint8_t | operand_hi"
    b2: "0x02 | uint8_t | operand_lo"
    b3: "...  | uint8_t | ..."
  }
}
annotations: {
  direction: right
  label: ""
  style.stroke: transparent
  style.fill: transparent
  legend: {
    direction: down
    label: "Memory Layout Notes"
    note1: {
      width: 220
      code: |'c
        // Value = double (8 bytes)
        // All pointers are 8 bytes
        // on 64-bit systems
      '|
    }
  }
  sizes: {
    direction: down
    label: "Size Breakdown"
    size_table: {
      shape: sql_table
      label: "Component Sizes"
      c1: "VM header     | 32 bytes"
      c2: "stack[256]    | 2,048 bytes"
      c3: "frames[64]    | 2,048 bytes"
      c4: "Total VM      | 4,128 bytes"
      c5: "+ alignment  | ~4,200 bytes"
    }
  }
}
arrows: {
  ip_arrow: vm_struct.f0 -> bytecode_ref.bytecode_mem.b0: {
    label: "ip points to\ncurrent opcode"
    style.stroke: blue
    style.stroke-dash: 3
  }
  stack_top_arrow: vm_struct.f1 -> memory_regions.stack_region.stack_mem.s2: {
    label: "stack_top → next\nfree slot"
    style.stroke: green
    style.stroke-dash: 3
  }
  frame_ip_arrow: memory_regions.frames_region.frame_struct.cf0 -> bytecode_ref.bytecode_mem.b3: {
    label: "frame.ip for\nreturn resume"
    style.stroke: purple
    style.stroke-dash: 3
  }
  frame_stack_arrow: memory_regions.frames_region.frame_struct.cf1 -> memory_regions.stack_region.stack_mem.s0: {
    label: "stack_base for\nframe locals"
    style.stroke: orange
    style.stroke-dash: 3
  }
}