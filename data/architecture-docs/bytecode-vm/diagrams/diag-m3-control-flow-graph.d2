direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Control Flow Graph from Bytecode
  How jumps create basic blocks and CFG edges
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bytecode: {
    direction: down
    label: "Bytecode Listing"
    style.fill: "#E8F4E8"
    style.stroke: "#2D5A2D"
    code: {
      label: "offset | instruction"
      width: 260
      code: |'text
        0000: LOAD_CONST 0      ; n
        0003: STORE_LOCAL 0
        0006: LOAD_LOCAL 0      ; ─┐
        0009: LOAD_CONST 1      ;  │ BB1
        0012: GREATER           ;  │ (condition)
        0013: JUMP_IF_FALSE 32  ; ─┘
        0016: LOAD_LOCAL 0      ; ─┐
        0019: LOAD_CONST 1      ;  │ BB2
        0022: SUB               ;  │ (then)
        0023: STORE_LOCAL 0     ;  │
        0026: JUMP 6            ; ─┘
        0029: LOAD_CONST 0      ; ─┐ BB3
        0032: STORE_LOCAL 1     ; ─┘ (else)
        0035: LOAD_LOCAL 1      ; ─┐ BB4
        0038: HALT              ; ─┘ (after)
      '|
    }
    legend: {
      label: "Key Insight"
      width: 240
      style.fill: "#FFF8DC"
      style.stroke: "#DAA520"
      note: |md
        Jumps **define** basic block boundaries.
        Each JUMP target starts a new block.
        Each JUMP instruction ends its block.
      |
    }
  }
  cfg: {
    direction: down
    label: "Control Flow Graph"
    style.fill: "#E8E8F4"
    style.stroke: "#2D2D5A"
    bb_entry: {
      label: "BB0: Entry"
      shape: rectangle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      width: 180
      stmts: {
        shape: text
        label: "n = init_value"
      }
    }
    bb1: {
      label: "BB1: Loop Condition"
      shape: diamond
      style.fill: "#FFFFE0"
      style.stroke: "#DAA520"
      width: 160
      height: 100
      stmts: {
        shape: text
        label: "n > 1 ?"
      }
    }
    bb2: {
      label: "BB2: Then (Loop Body)"
      shape: rectangle
      style.fill: "#ADD8E6"
      style.stroke: "#4169E1"
      width: 160
      stmts: {
        shape: text
        label: "n = n - 1"
      }
    }
    bb3: {
      label: "BB3: Else (Exit Path)"
      shape: rectangle
      style.fill: "#ADD8E6"
      style.stroke: "#4169E1"
      width: 160
      stmts: {
        shape: text
        label: "result = 0"
      }
    }
    bb4: {
      label: "BB4: Exit"
      shape: rectangle
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
      width: 180
      stmts: {
        shape: text
        label: "return result"
      }
    }
    bb_entry -> bb1: "fall-through" {
      style.stroke: "#333"
    }
    bb1 -> bb2: "true\n(JUMP_IF_FALSE\nnot taken)" {
      style.stroke: "#228B22"
      style.stroke-width: 2
    }
    bb1 -> bb3: "false\n(JUMP_IF_FALSE\nto offset 32)" {
      style.stroke: "#DC143C"
      style.stroke-dash: 4
    }
    bb2 -> bb1: "loop back\n(JUMP to 6)" {
      style.stroke: "#4169E1"
      style.stroke-width: 2
      style.animated: true
    }
    bb3 -> bb4: "fall-through" {
      style.stroke: "#333"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mapping: {
    direction: down
    label: "Bytecode → CFG Mapping"
    style.fill: "#F5F5F5"
    style.stroke: "#666"
    width: 300
    map_table: {
      shape: sql_table
      label: "Jump → Edge Transformation"
      r1: "JUMP target | creates edge to target block"
      r2: "JUMP_IF_FALSE | creates two edges (true/false)"
      r3: "fall-through | implicit edge to next block"
      r4: "backward JUMP | creates loop back-edge"
    }
  }
  block_rules: {
    direction: down
    label: "Basic Block Formation Rules"
    style.fill: "#FFF0F5"
    style.stroke: "#C71585"
    width: 300
    rules: {
      label: "Block Starts (leaders)"
      width: 280
      code: |'text
        1. First instruction is a leader
        2. Jump target is a leader
        3. Instruction after JUMP is a leader
      '|
    }
    rules2: {
      label: "Block Ends (terminators)"
      width: 280
      code: |'text
        1. JUMP/JUMP_IF_FALSE instruction
        2. RETURN/HALT instruction
        3. Instruction before a leader
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ir_relation: {
    direction: down
    label: "Relation to Compiler IR"
    style.fill: "#F0FFF0"
    style.stroke: "#2E8B57"
    width: 620
    pipeline: {
      label: "Compiler Pipeline"
      width: 600
      code: |'text
        Source Code → AST → Bytecode → CFG → Optimizations → Native Code
                            ↑
                      You are here
      '|
    }
    why_cfg: {
      label: "Why Convert to CFG?"
      width: 600
      style.fill: "#E0FFE0"
      note: |md
        **Data Flow Analysis**: Reaching definitions, live variables
        **Optimizations**: Dead code elimination, constant propagation
        **Loop Detection**: Identify loops via back-edges for unrolling
        **Register Allocation**: Compute liveness across blocks
      |
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  offset_map: {
    direction: down
    label: "Offset → Block Mapping"
    style.fill: "#F5F5DC"
    style.stroke: "#8B8B00"
    table: {
      shape: sql_table
      label: "Bytecode Offset to Basic Block"
      b0: "0x0000-0x0005 | BB0 (Entry)"
      b1: "0x0006-0x0015 | BB1 (Condition)"
      b2: "0x0016-0x0028 | BB2 (Then/Loop Body)"
      b3: "0x0029-0x0034 | BB3 (Else)"
      b4: "0x0035-0x0039 | BB4 (Exit)"
    }
    note: {
      label: ""
      width: 280
      style.fill: transparent
      note: |md
        Notice how JUMP targets (6, 32) 
        define block boundaries.
        The backward JUMP at 26 creates
        the loop back-edge BB2 → BB1.
      |
    }
  }
  loop_detection: {
    direction: down
    label: "Loop Detection via Back-Edges"
    style.fill: "#E6E6FA"
    style.stroke: "#4B0082"
    loop_info: {
      shape: class
      label: "Loop (detected)"
      header: "BB1"
      back_edge: "BB2 → BB1"
      body: "[BB2]"
      is_natural: "true"
    }
    algo: {
      label: "Detection Algorithm"
      width: 280
      code: |'text
        For each edge E: A → B:
          if B dominates A:
            # B is loop header
            # Edge is back-edge
            # Loop found!
      '|
    }
  }
}
insight: {
  near: bottom-center
  label: ""
  width: 700
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
  note: |md
    **The Revelation**: The VM executes linear bytecode. The CFG exists only in the compiler's analysis.
    When you see `while (n > 0)`, the compiler creates: condition block → body block → back-edge.
    The VM just sees jumps. Structure is imposed by the compiler, not the machine.
  |
}