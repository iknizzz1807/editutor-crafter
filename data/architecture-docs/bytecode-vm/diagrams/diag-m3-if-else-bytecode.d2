direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  source: {
    direction: down
    label: "Source Code"
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"
    code: {
      width: 320
      code: |'javascript
if (condition) {
    // then-branch
    result = 100;
} else {
    // else-branch  
    result = 200;
}
// after-both
'|
    }
  }
  bytecode: {
    direction: down
    label: "Bytecode (offsets)"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    instr: {
      shape: sql_table
      label: "Instruction Stream"
      f0: "0x00 | <condition code>"
      f1: "0x06 | JUMP_IF_FALSE 0x10"
      f2: "0x09 | <then-branch>"
      f3: "0x0D | LOAD_CONST 100"
      f4: "0x10 | JUMP 0x19"
      f5: "0x13 | <else-branch>"
      f6: "0x17 | LOAD_CONST 200"
      f7: "0x19 | <after-both>"
      sz: "Total: ~28 bytes"
    }
  }
}
arrows: {
  direction: down
  style.fill: transparent
  style.stroke: transparent
  cond_arrow: {
    label: "1. Evaluate"
    style.stroke: "#1565C0"
    style.stroke-width: 2
  }
  branch_arrow: {
    label: "2. Branch if FALSE"
    style.stroke: "#C62828"
    style.stroke-width: 2
    style.stroke-dash: 4
  }
  skip_arrow: {
    label: "3. Skip else"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  fall_arrow: {
    label: "4. Fall through"
    style.stroke: "#6A1B9A"
    style.stroke-width: 2
  }
}
flow: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  legend: {
    label: "Control Flow"
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
    l1: "JUMP_IF_FALSE: conditional skip"
    l2: "JUMP: unconditional skip"
    l3: "Arrows show jump targets"
  }
  graph: {
    direction: down
    label: "Jump Graph"
    cond: {
      shape: diamond
      label: "condition?"
      style.fill: "#BBDEFB"
    }
    then: {
      shape: rectangle
      label: "then-branch\n(result=100)"
      style.fill: "#C8E6C9"
    }
    else: {
      shape: rectangle
      label: "else-branch\n(result=200)"
      style.fill: "#FFCCBC"
    }
    after: {
      shape: rectangle
      label: "after-both"
      style.fill: "#E1BEE7"
    }
    cond -> then: "TRUE" {
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
    cond -> else: "FALSE (0x10)" {
      style.stroke: "#C62828"
      style.stroke-width: 2
      style.stroke-dash: 4
    }
    then -> after: "JUMP 0x19" {
      style.stroke: "#1565C0"
      style.stroke-width: 2
    }
    else -> after: "fall through" {
      style.stroke: "#6A1B9A"
      style.stroke-width: 2
    }
  }
}
source -> bytecode: "compiles to" {
  style.stroke: "#424242"
  style.stroke-width: 3
  style.stroke-dash: 3
}
source.code -> flow.graph.cond: {
  style.stroke: transparent
}
bytecode.instr -> flow.graph: {
  style.stroke: transparent
}
flow.legend -> flow.graph: {
  style.stroke: transparent
}