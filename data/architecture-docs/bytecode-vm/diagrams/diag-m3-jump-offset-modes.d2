direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Jump Offset Modes: Absolute vs. Relative {
  shape: callout
  near: top-center
  style.font-size: 24
  style.bold: true
}

row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  absolute: {
    direction: down
    label: "Absolute Offsets (Fixed Address)"
    
    abs_desc: {
      label: "Logic: Direct Assignment"
      width: 280
      code: |'c
        // JUMP 0x14 (20)
        // Instruction Pointer set directly
        IP = target_operand; 
      '|
    }

    abs_program: {
      direction: down
      label: "Memory Layout (Program.bin)"
      
      abs_block_1: {
        shape: sql_table
        label: "Main Execution Block"
        i0: "0x00 | LOAD_CONST 0"
        i1: "0x03 | LOAD_CONST 1"
        i2: "0x06 | ADD"
        i3: "0x07 | JUMP 0x14    // target = 20"
        i4: "0x0A | LOAD_CONST 2  [SKIPPED]"
        i5: "0x0D | POP           [SKIPPED]"
        sz: "Size: 16 bytes"
      }

      abs_gap: {
        label: "Skipped Instructions (Address 0x0A - 0x13)"
        style.fill: "#ffcccc"
        style.stroke-dash: 3
      }

      abs_block_2: {
        shape: sql_table
        label: "Jump Target Block"
        t0: "0x14 | LOAD_CONST 3"
        t1: "0x17 | HALT"
        sz: "Total Program Size: 24 bytes"
      }
    }

    abs_note: {
      label: "Constraint: Requires fixed load address"
      width: 280
      style.fill: "#e8f4e8"
      style.stroke: "#4a9"
    }
  }

  relative: {
    direction: down
    label: "Relative Offsets (Position Independent)"
    
    rel_desc: {
      label: "Logic: Current IP + Offset"
      width: 280
      code: |'c
        // JUMP +0x0A (10)
        // Offset added to current IP
        IP = IP + offset_operand;
      '|
    }

    rel_program: {
      direction: down
      label: "Memory Layout (Program.bin)"
      
      rel_block_1: {
        shape: sql_table
        label: "Main Execution Block"
        i0: "0x00 | LOAD_CONST 0"
        i1: "0x03 | LOAD_CONST 1"
        i2: "0x06 | ADD"
        i3: "0x07 | JUMP +0x0A   // relative +10"
        i4: "0x0A | LOAD_CONST 2  [SKIPPED]"
        i5: "0x0D | POP           [SKIPPED]"
        sz: "Size: 16 bytes"
      }

      rel_gap: {
        label: "Skipped Instructions (Distance: 10 bytes)"
        style.fill: "#e1f5fe"
        style.stroke-dash: 3
      }

      rel_block_2: {
        shape: sql_table
        label: "Jump Target Block"
        t0: "0x11 | LOAD_CONST 3"
        t1: "0x14 | HALT"
        sz: "Dynamic load address capable"
      }
    }

    rel_note: {
      label: "Math: IP(0x07) + Op(0x0A) = 0x11"
      width: 280
      style.fill: "#e8f0ff"
      style.stroke: "#48c"
    }
  }
}

footer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  comparison: {
    shape: sql_table
    label: "Architectural Comparison"
    c0: "Feature  | Absolute Mode | Relative Mode"
    c1: "Encoding | Direct Pointer | Byte Distance"
    c2: "Portability | Needs Relocation | Position Independent"
    c3: "Debugging | Easier Disassembly | Harder Mental Math"
    c4: "Examples | CPython, MIPS | x86, WebAssembly, JVM"
  }
}

abs_program.abs_gap -> rel_program.rel_gap: "Logic Parity" {
  style.stroke-dash: 5
  style.stroke: "#888"
}

absolute.abs_program.abs_block_2 -> relative.rel_program.rel_block_2: "Address Shift" {
  style.stroke: "#d32f2f"
  style.stroke-dash: 4
}