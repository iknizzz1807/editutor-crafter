direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Jump Target Validation"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_main: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  bytecode_zone: {
    direction: down
    label: "Valid Jump Zone"
    bytecode_array: {
      shape: sql_table
      label: "Bytecode Array (chunk.c)"
      f0: "0x00 | uint8_t | opcode"
      f1: "0x01 | uint8_t | operand_hi"
      f2: "0x02 | uint8_t | operand_lo"
      f3: "0x03 | uint8_t | opcode"
      f4: "0x04 | uint8_t | operand_hi"
      f5: "0x05 | uint8_t | operand_lo"
      f6: "0x06 | uint8_t | opcode"
      f7: "0x07 | uint8_t | opcode"
      f8: "0x08 | uint8_t | opcode"
      ell: "..."
      cnt: "count-1 | uint8_t | last_byte"
      total: "Valid: [0, count-1]"
    }
    bytecode_array.style.fill: "#E8F5E9"
    valid_label: {
      label: "✓ Any offset 0 to count-1\n  passes validation"
      shape: text
      style.font-color: "#2E7D32"
    }
  }
  error_zone: {
    direction: down
    label: "Invalid Targets"
    invalid_negative: {
      shape: rectangle
      label: "target < 0"
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
    }
    invalid_positive: {
      shape: rectangle
      label: "target >= count"
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
    }
    invalid_mid: {
      shape: rectangle
      label: "Mid-instruction\n(e.g., operand byte)"
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
        stroke-width: 2
        stroke-dash: 4
      }
    }
    error_label: {
      label: "✗ Returns\nINTERPRET_RUNTIME_ERROR"
      shape: text
      style.font-color: "#C62828"
    }
  }
}
row_validator: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  verifier: {
    direction: down
    label: "Runtime Validator (vm.c)"
    validate_func: {
      shape: class
      label: "validate_jump_target(vm, target, name)"
      returns: "bool"
      check1: "- target < 0"
      check2: "- target >= bytecode.count"
      result: "→ false on error"
    }
    validate_func.style.fill: "#E3F2FD"
  }
  check_flow: {
    direction: down
    label: "Validation Flow"
    step1: {
      label: "1. Read JUMP operand"
      code: |'c
        uint16_t target = chunk_read_operand(
          vm->chunk, vm->ip);
      '|
      width: 320
    }
    step2: {
      label: "2. Bounds check"
      code: |'c
        if (target >= vm->chunk->bytecode.count) {
          runtime_error(vm, 
            "Jump target %d out of bounds", 
            target);
          return INTERPRET_RUNTIME_ERROR;
        }
      '|
      width: 320
    }
    step3: {
      label: "3. Execute or reject"
      code: |'c
        // Valid: transfer control
        vm->ip = target;
        // Invalid: already returned error
      '|
      width: 320
    }
  }
  check_flow.style.fill: "#F3E5F5"
}
row_annotation: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  legend: {
    direction: right
    label: "Legend"
    green_box: {
      label: "Valid zone"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
      }
    }
    red_box: {
      label: "Invalid (rejected)"
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
      }
    }
    orange_box: {
      label: "Mid-instruction\n(not runtime-checked)"
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
        stroke-dash: 4
      }
    }
  }
}
bytecode_zone -> error_zone: "JUMP target\nvalidation" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
verifier -> bytecode_zone: "checks bounds" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
verifier -> error_zone: "detects" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
note: {
  label: |md
    **Production VMs** (JVM, WASM) use load-time verification:
    - Scan bytecode once at load
    - Record all instruction start offsets
    - Verify every JUMP target lands on boundary
    - Zero runtime overhead after verification
  |
  near: bottom-center
  style: {
    fill: "#FFFDE7"
    stroke: "#F9A825"
    stroke-dash: 2
  }
}