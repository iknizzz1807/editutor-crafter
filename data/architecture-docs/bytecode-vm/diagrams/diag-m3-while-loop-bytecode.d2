direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # While Loop Bytecode Pattern
  Backward jumps create repetition
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  source: {
    direction: down
    label: "Source Code"
    code_block: {
      label: "while (n > 0)"
      width: 200
      code: |'c
        while (n > 0) {
          n = n - 1;
        }
        // Initial: n = 3
      '|
    }
  }
  arrow1: {
    shape: text
    label: "→ Compiler"
    style.font-size: 20
    style.fill: transparent
    style.stroke: transparent
  }
  bytecode: {
    direction: down
    label: "Generated Bytecode"
    chunk: {
      shape: sql_table
      label: "Chunk (bytecode + constants)"
      row0: "0x00 | STORE_LOCAL 0 | slot 0 // n = 3"
      row1: "0x03 | LOAD_LOCAL 0  | slot 0"
      row2: "0x06 | LOAD_CONST 1  | const[1] = 0"
      row3: "0x09 | GREATER       | —"
      row4: "0x0A | JUMP_IF_FALSE | → 0x1D"
      row5: "0x0D | LOAD_LOCAL 0  | slot 0"
      row6: "0x10 | LOAD_CONST 2  | const[2] = 1"
      row7: "0x13 | SUB           | —"
      row8: "0x14 | STORE_LOCAL 0 | slot 0"
      row9: "0x17 | JUMP          | → 0x03"
      row10: "0x1A | HALT          | —"
      note: "Loop: 0x03 ↔ 0x17"
    }
    constants: {
      shape: sql_table
      label: "Constant Pool"
      c0: "0 | 3.0 | (initial n)"
      c1: "1 | 0.0 | (compare)"
      c2: "2 | 1.0 | (decrement)"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  flow: {
    direction: down
    label: "Control Flow Graph"
    start: {
      shape: oval
      label: "n = 3"
    }
    cond: {
      shape: diamond
      label: "n > 0?"
      style.fill: "#FFF9C9"
    }
    body: {
      shape: rectangle
      label: "n = n - 1"
      style.fill: "#E8F5E9"
    }
    exit: {
      shape: oval
      label: "HALT"
      style.fill: "#FFCDD2"
    }
    start -> cond: "offset 0x00"
    cond -> body: "true\n(offset 0x0D)"
    cond -> exit: "false\n(JUMP_IF_FALSE → 0x1D)"
    body -> cond: "loop back\n(JUMP → 0x03)" {
      style.stroke: "#E53935"
      style.stroke-width: 3
      style.animated: true
    }
  }
  trace: {
    direction: down
    label: "Execution Trace"
    iter1: {
      direction: right
      label: "Iteration 1"
      state1: {
        shape: sql_table
        label: "IP | n | Stack | Action"
        s0: "0x03 | 3 | [] | LOAD_LOCAL"
        s1: "0x06 | 3 | [3] | LOAD_CONST 0"
        s2: "0x09 | 3 | [3,0] | GREATER"
        s3: "0x0A | 3 | [1.0] | JUMP_IF_FALSE?"
        s4: "0x0D | 3 | [] | (don't jump)"
        s5: "0x14 | 2 | [2] | STORE_LOCAL"
        s6: "0x17 | 2 | [] | JUMP → 0x03"
      }
      result1: {
        shape: text
        label: "n: 3 → 2 ✓"
        style.fill: "#C8E6C9"
        style.stroke: "#43A047"
        style.stroke-width: 2
      }
    }
    iter2: {
      direction: right
      label: "Iteration 2"
      state2: {
        shape: sql_table
        label: "IP | n | Stack | Action"
        s0: "0x03 | 2 | [] | LOAD_LOCAL"
        s1: "0x09 | 2 | [2,0] | GREATER"
        s2: "0x0A | 2 | [1.0] | JUMP_IF_FALSE?"
        s3: "0x14 | 1 | [1] | n = n - 1"
        s4: "0x17 | 1 | [] | JUMP → 0x03"
      }
      result2: {
        shape: text
        label: "n: 2 → 1 ✓"
        style.fill: "#C8E6C9"
        style.stroke: "#43A047"
        style.stroke-width: 2
      }
    }
    iter3: {
      direction: right
      label: "Iteration 3"
      state3: {
        shape: sql_table
        label: "IP | n | Stack | Action"
        s0: "0x03 | 1 | [] | LOAD_LOCAL"
        s1: "0x09 | 1 | [1,0] | GREATER"
        s2: "0x0A | 1 | [1.0] | JUMP_IF_FALSE?"
        s3: "0x14 | 0 | [0] | n = n - 1"
        s4: "0x17 | 0 | [] | JUMP → 0x03"
      }
      result3: {
        shape: text
        label: "n: 1 → 0 ✓"
        style.fill: "#C8E6C9"
        style.stroke: "#43A047"
        style.stroke-width: 2
      }
    }
    exit_iter: {
      direction: right
      label: "Exit"
      state_exit: {
        shape: sql_table
        label: "IP | n | Stack | Action"
        s0: "0x03 | 0 | [] | LOAD_LOCAL"
        s1: "0x09 | 0 | [0,0] | GREATER"
        s2: "0x0A | 0 | [0.0] | JUMP_IF_FALSE"
        s3: "0x1A | 0 | [] | (JUMP TAKEN!)"
        s4: "— | 0 | [] | HALT"
      }
      result_exit: {
        shape: text
        label: "n = 0 → EXIT"
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
        style.stroke-width: 2
      }
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  back_jump: {
    label: "Backward Jump"
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  cond_check: {
    label: "Condition Check"
    style.fill: "#FFF9C9"
    style.stroke: "#F9A825"
  }
  body_exec: {
    label: "Loop Body"
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
  }
}
back_jump.style.stroke-width: 2
cond_check.style.stroke-width: 2
body_exec.style.stroke-width: 2
row1.bytecode.chunk -> row2.flow.cond: "condition\nat 0x03-0x09" {
  style.stroke-dash: 3
  style.stroke: "#1565C0"
}
row2.flow.body -> row1.bytecode.chunk: "backward\nJUMP at 0x17" {
  style.stroke: "#E53935"
  style.stroke-width: 2
  style.animated: true
}