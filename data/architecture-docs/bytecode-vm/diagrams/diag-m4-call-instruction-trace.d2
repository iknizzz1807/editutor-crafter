direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # CALL Instruction Execution Trace
  Six-panel trace showing frame creation, argument passing, and control transfer
|
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  panel1: {
    direction: down
    label: "Step 1: Before CALL"
    caller_stack: {
      shape: sql_table
      label: "Operand Stack"
      r0: "stack_top-2 | Value | arg0 (3.0)"
      r1: "stack_top-1 | Value | arg1 (5.0)"
      r2: "stack_top   | int   | → next free"
    }
    frame_state1: {
      shape: sql_table
      label: "Frame Stack"
      r0: "0 | CallFrame | main()"
      note1: "count: 1"
    }
    ip_state1: {
      label: "IP: 6 (CALL instruction)"
      shape: rectangle
      style.fill: "#FFF9C4"
    }
  }

  panel2: {
    direction: down
    label: "Step 2: Pop Args"
    args_array: {
      shape: sql_table
      label: "Temp Args[]"
      r0: "0 | Value | 3.0 ← popped 2nd"
      r1: "1 | Value | 5.0 ← popped 1st"
    }
    stack_empty: {
      label: "Operand Stack (empty)"
      shape: rectangle
      style.fill: "#FFECB3"
    }
    note2: {
      label: |md
        Pop in **reverse order**:
        1. Pop 5.0 → args[1]
        2. Pop 3.0 → args[0]
      |
      shape: rectangle
      style.fill: transparent
    }
  }

  panel3: {
    direction: down
    label: "Step 3: Push Frame"
    new_frame: {
      shape: sql_table
      label: "Frame Stack (after push)"
      r0: "0 | CallFrame | main()"
      r1: "1 | CallFrame | add() ← NEW"
      note3: "count: 2"
    }
    frame_detail: {
      shape: sql_table
      label: "New Frame Contents"
      r0: "return_address | int | 12"
      r1: "locals_base    | int | 0"
      r2: "locals_count   | int | 2"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  panel4: {
    direction: down
    label: "Step 4: Init Locals"
    locals_array: {
      shape: sql_table
      label: "VM.locals[] Array"
      r0: "0 | Value | 3.0 (arg0 → local_0)"
      r1: "1 | Value | 5.0 (arg1 → local_1)"
      note4: "locals_top: 2"
    }
    mapping_note: {
      label: |md
        **Left-to-right mapping:**
        - local_0 = args[0] = 3.0
        - local_1 = args[1] = 5.0
      |
      shape: rectangle
      style.fill: "#E8F5E9"
    }
  }

  panel5: {
    direction: down
    label: "Step 5: Jump to Entry"
    ip_state5: {
      label: "IP: 20 (add function)"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    func_bytecode: {
      shape: sql_table
      label: "Function add() Bytecode"
      r0: "20 | LOAD_LOCAL 0 | push 3.0"
      r1: "23 | LOAD_LOCAL 1 | push 5.0"
      r2: "26 | ADD          | push 8.0"
      r3: "27 | RETURN       | → caller"
    }
    exec_stack: {
      shape: sql_table
      label: "Operand Stack (Running)"
      r0: "0 | Value | 3.0"
      r1: "1 | Value | 5.0"
      r2: "2 | Value | 8.0 ← result"
    }
  }

  panel6: {
    direction: down
    label: "Step 6: After RETURN"
    final_stack: {
      shape: sql_table
      label: "Operand Stack"
      r0: "0 | Value | 8.0 ← return value"
    }
    final_frames: {
      shape: sql_table
      label: "Frame Stack"
      r0: "0 | CallFrame | main()"
      note5: "count: 1 (frame popped)"
    }
    ip_state6: {
      label: "IP: 12 (after CALL)"
      shape: rectangle
      style.fill: "#B3E5FC"
    }
  }
}

panel1 -> panel2: "Pop args" {style.stroke: "#1976D2"}
panel2 -> panel3: "Push frame" {style.stroke: "#388E3C"}
panel3 -> panel4: "Copy to locals" {style.stroke: "#388E3C"}
panel4 -> panel5: "Set IP=20" {style.stroke: "#F57C00"}
panel5 -> panel6: "RETURN" {style.stroke: "#7B1FA2"}

legend: {
  direction: right
  arg_color: "Args/Params" {
    shape: rectangle
    style.fill: "#FFECB3"
  }
  frame_color: "Frame Data" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  ip_color: "IP Register" {
    shape: rectangle
    style.fill: "#B3E5FC"
  }
}
legend.near: bottom-center

legend_note: {
  label: |md
    **Key Insight**: Arguments are popped in reverse order (LIFO) so they map to local slots in left-to-right (source) order.
    The return address (12) points *after* the CALL instruction, so execution resumes correctly.
  |
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
legend_note.near: bottom-center