direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STYLES & CLASSES ---
classes: {
  frame_box: {
    style: {
      fill: "#E8F5F5"
      stroke: "#7C5B5D"
      stroke-width: 2
    }
  }
  local_box: {
    style: {
      fill: "#FFF3CD"
      stroke: "#7C5B5D"
    }
  }
  stack_box: {
    style: {
      fill: "#FDEBD7"
      stroke: "#DAA065"
    }
  }
  danger_zone: {
    style: {
      fill: "#FFCCCC"
      stroke: "#CC0000"
      stroke-width: 3
      stroke-dash: 5
    }
  }
}

# --- DIAGRAM ELEMENTS ---

title: "Deep Recursion & Stack Overflow (Virtual Machine)" {
  shape: text
  near: top-center
  style.font-size: 24
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  vm_memory: {
    label: "Process Memory Map (Stack Segment)"
    
    operand_stack: {
      shape: sql_table
      label: "Operand Stack (Evaluation)"
      row1: "0x7FFF00 | [ 42 ]   | result_tmp"
      row2: "0x7FFF08 | [  3 ]   | multiplier"
      row3: "0x7FFF10 | [  2 ]   | accumulator"
      sp_meta: "Stack Pointer (SP) -> 0x7FFF10"
    }

    frame_stack: {
      shape: sql_table
      label: "Call Stack (Activation Records)"
      f0: "0x0000 | Frame 0: main() | RA: 0x0 | LP: 0x100"
      f1: "0x0040 | Frame 1: factorial(3) | RA: 0x42 | LP: 0x140"
      f2: "0x0080 | Frame 2: factorial(2) | RA: 0x42 | LP: 0x180"
      f3: "0x00C0 | Frame 3: factorial(1) | RA: 0x42 | LP: 0x1C0"
      skipped: " ... recursive expansion (96 deeper) ... "
      f_max: "0xF000 | Frame 100: factorial(-96) | RA: 0x42 | LP: 0x200" {
        class: danger_zone
      }
      overflow: "CRITICAL: STACK_OVERFLOW_ERROR (Limit: 64KB)" {
        style.font-color: red
        style.bold: true
      }
    }
  }

  execution_logic: {
    label: "Execution Engine"
    
    code_block: {
      label: "factorial(n) Bytecode"
      width: 400
      code: |'c
        0x40: ILOAD n       // Push n to stack
        0x41: ICONST_1      // Push 1
        0x42: IF_ICMPGT 0x48 // if n > 1 goto recurse
        0x45: ICONST_1      // Base case return
        0x46: IRETURN
        0x48: ILOAD n       // Recurse: load n
        0x4C: INVOKEVIRTUAL // Call factorial(n-1)
      '|
    }

    registers: {
      shape: sql_table
      label: "CPU Registers"
      pc: "PC | 0x4C | INVOKEVIRTUAL"
      fp: "FP | 0xF000 | Current Frame"
      sp: "SP | 0x7FFF10 | Stack Top"
    }
  }
}

# --- ANNOTATIONS & FLOWS ---

legend_container: {
  label: "Memory Map Legend"
  item1: "Green Arrow | Frame Allocation" { style.font-color: green }
  item2: "Red Arrow | Overflow Trigger" { style.font-color: red }
}
legend_container.near: bottom-right

# Define relationships using explicit node paths
execution_logic.code_block -> vm_memory.frame_stack.f_max: "CALL | push frame" {
  style.stroke: red
  style.stroke-width: 2
  style.animated: true
}

vm_memory.operand_stack -> execution_logic.registers.sp: "points to" {
  style.stroke-dash: 3
}

execution_logic.registers.pc -> execution_logic.code_block: "fetches" {
  style.stroke: blue
}

note_node: {
  label: "Root Cause: Missing base case or too many nested calls exhausting the 64KB stack limit."
  shape: callout
  style.fill: "#FFF3CD"
}
note_node.near: bottom-left