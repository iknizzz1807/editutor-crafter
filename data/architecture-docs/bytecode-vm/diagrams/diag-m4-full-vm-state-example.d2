direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Complete VM State Snapshot
  **Debugger Breakpoint View: `factorial(5)` at IP=27 (recursive case)**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bytecode_panel: {
    direction: down
    label: "Bytecode Chunk"
    style.fill: "#E8F4F8"
    style.stroke: "#2E86AB"
    style.stroke-width: 2
    chunk_header: {
      shape: sql_table
      label: "struct Chunk"
      f0: "0x00 | uint8_t*    | code"
      f1: "0x08 | int        | count = 42"
      f2: "0x0C | int        | capacity = 64"
      f3: "0x10 | Value*     | constants"
      sz: "Total: 24 bytes"
    }
    bytecode_array: {
      label: "code[] (42 bytes)"
      style.fill: white
      offset_0: {
        direction: right
        style.fill: "#F0F0F0"
        style.stroke: "#CCC"
        label: "Main Entry"
        b0: |md
          `00: LOAD_CONST 0`
          `03: CALL 1, 10, 1`
          `09: HALT`
        |
      }
      offset_10: {
        direction: right
        style.fill: "#FFF9E6"
        style.stroke: "#E6B800"
        label: "factorial() at 10"
        b10: |md
          `10: LOAD_LOCAL 0`
          `13: LOAD_CONST 1`
          `16: LESS_EQ`
          `17: JUMP_IF_FALSE 25`
          `20: LOAD_CONST 1`
          `23: RETURN`
          `25: LOAD_LOCAL 0`
          `28: LOAD_LOCAL 0`
        |
      }
      offset_31: {
        direction: right
        style.fill: "#FFF9E6"
        style.stroke: "#E6B800"
        b31: |md
          `31: LOAD_CONST 1`
          `34: SUB`
          `35: CALL 1, 10, 1`
          `41: MUL`
          `42: RETURN`
        |
      }
    }
    constants: {
      shape: sql_table
      label: "Constant Pool"
      c0: "0 | double | 5.0"
      c1: "1 | double | 1.0"
    }
  }
  vm_registers: {
    direction: down
    label: "VM Registers"
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    style.stroke-width: 2
    ip_register: {
      shape: sql_table
      label: "Instruction Pointer"
      ip_val: "ip = 27 | → LOAD_LOCAL 0"
      note: "Inside factorial(), recursive case"
      style.fill: "#FFE6E6"
    }
    ip_register.style.fill: "#FFCCCC"
    stack_top_reg: {
      shape: sql_table
      label: "Stack Pointer"
      sp_val: "stack_top = 0"
      note: "Operand stack empty at CALL"
      style.fill: "#FFE6E6"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  operand_stack: {
    direction: down
    label: "Operand Stack"
    style.fill: "#E6F3E6"
    style.stroke: "#228B22"
    style.stroke-width: 2
    stack_header: {
      label: "Value stack[256]"
      shape: rectangle
      style.fill: "#D4EDDA"
      style.stroke: "#228B22"
    }
    stack_empty: {
      label: |md
        
        [0]  (empty)
        [1]  (empty)
        ...
        [255] (empty)
        
      |
      shape: rectangle
      style.fill: white
      style.stroke: "#AAA"
      style.stroke-dash: 3
    }
    stack_note: {
      label: "stack_top = 0\n(Empty at this breakpoint)"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
    }
  }
  locals_array: {
    direction: down
    label: "Locals Array (All Frames)"
    style.fill: "#F0E6F6"
    style.stroke: "#6B3FA0"
    style.stroke-width: 2
    locals_header: {
      label: "Value locals[65536]"
      shape: rectangle
      style.fill: "#E6D5F2"
      style.stroke: "#6B3FA0"
    }
    locals_content: {
      direction: right
      style.fill: white
      frame0_locals: {
        direction: down
        label: "Frame 0 (main)"
        style.fill: "#F5F5F5"
        style.stroke: "#999"
        l0: "[0] = 5.0 (n arg)"
        l1: "[1] = unused"
      }
      frame1_locals: {
        direction: down
        label: "Frame 1 (fact n=5)"
        style.fill: "#E8F4E8"
        style.stroke: "#228B22"
        l2: "[2] = 5.0 (n)"
        l3: "[3] = unused"
      }
      frame2_locals: {
        direction: down
        label: "Frame 2 (fact n=4)"
        style.fill: "#E8F4E8"
        style.stroke: "#228B22"
        l4: "[4] = 4.0 (n)"
        l5: "[5] = unused"
      }
      frame3_current: {
        direction: down
        label: "Frame 3 (fact n=3)"
        style.fill: "#FFE6CC"
        style.stroke: "#FF8C00"
        style.stroke-width: 3
        style.bold: true
        l6: "[6] = 3.0 (n) ← CURRENT"
        l7: "[7] = unused"
      }
    }
    locals_top: {
      label: "locals_top = 8"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  frame_stack: {
    direction: down
    label: "Call Frame Stack"
    style.fill: "#FFF8E6"
    style.stroke: "#B8860B"
    style.stroke-width: 2
    frame_stack_header: {
      label: "FrameStack frames[256]"
      shape: rectangle
      style.fill: "#FFF0C4"
      style.stroke: "#B8860B"
    }
    frame0: {
      direction: right
      label: "Frame 0: main"
      style.fill: "#F5F5F5"
      style.stroke: "#999"
      frame0_data: {
        shape: sql_table
        label: "CallFrame"
        r0: "chunk      | ptr"
        r1: "return_ip  | N/A"
        r2: "locals_base| 0"
        r3: "locals_cnt | 2"
      }
    }
    frame1: {
      direction: right
      label: "Frame 1: factorial(5)"
      style.fill: "#E8F4E8"
      style.stroke: "#228B22"
      frame1_data: {
        shape: sql_table
        label: "CallFrame"
        r0: "chunk      | ptr"
        r1: "return_ip  | 12"
        r2: "locals_base| 2"
        r3: "locals_cnt | 2"
      }
    }
    frame2: {
      direction: right
      label: "Frame 2: factorial(4)"
      style.fill: "#E8F4E8"
      style.stroke: "#228B22"
      frame2_data: {
        shape: sql_table
        label: "CallFrame"
        r0: "chunk      | ptr"
        r1: "return_ip  | 41"
        r2: "locals_base| 4"
        r3: "locals_cnt | 2"
      }
    }
    frame3: {
      direction: right
      label: "Frame 3: factorial(3) ← CURRENT"
      style.fill: "#FFE6CC"
      style.stroke: "#FF8C00"
      style.stroke-width: 3
      style.bold: true
      frame3_data: {
        shape: sql_table
        label: "CallFrame"
        r0: "chunk      | ptr"
        r1: "return_ip  | 41"
        r2: "locals_base| 6"
        r3: "locals_cnt | 2"
      }
    }
    frame_count: {
      label: "frames.count = 4"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
    }
  }
  current_frame_detail: {
    direction: down
    label: "Current Frame Detail"
    style.fill: "#FFE6CC"
    style.stroke: "#FF8C00"
    style.stroke-width: 3
    detail_header: {
      label: "frame_stack_top() → Frame 3"
      shape: rectangle
      style.fill: "#FFD699"
      style.stroke: "#FF8C00"
      style.bold: true
    }
    access_example: {
      label: |'c
        // LOAD_LOCAL 0 at IP=27
        slot = 0;
        frame = frame_stack_top(&vm->frames);
        // frame->locals_base = 6
        // frame->locals_count = 2
        // Bounds check: 0 < 2 ✓
        value = vm->locals[6 + 0];
        // value = 3.0
        vm_push(vm, value);
        // stack[0] = 3.0
        // stack_top = 1
      '|
      shape: rectangle
      style.fill: white
      style.stroke: "#666"
      width: 320
    }
    state_after: {
      label: "After LOAD_LOCAL 0:\n  stack = [3.0]\n  stack_top = 1\n  IP = 28"
      shape: rectangle
      style.fill: "#E6FFE6"
      style.stroke: "#228B22"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  execution_context: {
    direction: down
    label: "Execution Context"
    style.fill: "#E6E6FF"
    style.stroke: "#4B0082"
    context_data: {
      shape: sql_table
      label: "struct VM State"
      f0: "Chunk*     | chunk"
      f1: "int        | ip = 27"
      f2: "Value[256] | stack"
      f3: "int        | stack_top = 0"
      f4: "FrameStack | frames"
      f5: "Value[65536] | locals"
      f6: "int        | locals_top = 8"
    }
    call_depth: {
      label: "Call Depth: 4 frames\n(3 recursive calls pending)"
      shape: rectangle
      style.fill: "#D4D4FF"
      style.stroke: "#4B0082"
    }
  }
  memory_layout: {
    direction: down
    label: "Memory Layout"
    style.fill: "#F5F5F5"
    style.stroke: "#666"
    layout_visual: {
      label: |md
        
        ┌─────────────────────────────────┐
        │ VM Struct (heap)                │
        ├─────────────────────────────────┤
        │ chunk ──────────────┐           │
        │ ip = 27             │           │
        │ stack[256]          │           │
        │ stack_top = 0       │           │
        │ frames ──────┐      │           │
        │ locals[65536]│      │           │
        │ locals_top=8 │      │           │
        └──────────────│──────│───────────┘
                       │      │
        ┌──────────────┘      └──────────┐
        │                               │
        ▼                               ▼
        ┌─────────────┐     ┌─────────────────┐
        │ FrameStack  │     │ Chunk (static)  │
        │ frames[256] │     │ code[42]        │
        │ count = 4   │     │ constants[2]    │
        └─────────────┘     └─────────────────┘
        
      |
      shape: rectangle
      style.fill: white
      style.stroke: "#999"
      width: 350
    }
  }
}
legend: {
  near: bottom-right
  direction: down
  label: "Legend"
  style.fill: "#F8F8F8"
  style.stroke: "#CCC"
  legend_items: {
    direction: right
    item1: {
      label: "Current IP"
      style.fill: "#FFCCCC"
      style.stroke: "#CC0000"
    }
    item2: {
      label: "Current Frame"
      style.fill: "#FFE6CC"
      style.stroke: "#FF8C00"
    }
    item3: {
      label: "Active Frames"
      style.fill: "#E8F4E8"
      style.stroke: "#228B22"
    }
    item4: {
      label: "Inactive"
      style.fill: "#F5F5F5"
      style.stroke: "#999"
    }
  }
}