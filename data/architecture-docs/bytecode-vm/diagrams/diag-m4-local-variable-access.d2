direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Local Variable Indexing Within Frame
  Frame-relative addressing with base pointer arithmetic
|
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  frame_structure: {
    direction: down
    label: "CallFrame Structure (frame.h)"
    frame_layout: {
      shape: sql_table
      label: "struct CallFrame"
      f0: "0x00 | Chunk*      | chunk"
      f1: "0x04 | int         | return_address"
      f2: "0x08 | int         | locals_base"
      f3: "0x0C | int         | locals_count"
      sz: "Total: 16 bytes"
    }
  }
  locals_array: {
    direction: down
    label: "VM Locals Array (vm->locals[])"
    locals_table: {
      shape: sql_table
      label: "Value locals[LOCALS_MAX]"
      row0: "base + 0 | Value | local_0 (arg0)"
      row1: "base + 1 | Value | local_1 (arg1)"
      row2: "base + 2 | Value | local_2"
      row3: "base + 3 | Value | local_3"
      row4: "...      | ...   | ..."
      note: "Index = frame->locals_base + slot"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  load_local: {
    direction: down
    label: "LOAD_LOCAL 2 Execution"
    width: 380
    load_code: |'c
      case OP_LOAD_LOCAL: {
        uint16_t slot = read_operand(ip);
        ip += 2;
        CallFrame* frame = frame_stack_top(&frames);
        // Index calculation:
        int index = frame->locals_base + slot;
        Value value = vm->locals[index];
        vm_push(vm, value);
      }
    '|
    load_diagram: {
      direction: right
      label: "Memory Access Pattern"
      load_op: "LOAD_LOCAL 2" {
        style.fill: "#E8F5E9"
        style.stroke: "#2E7D32"
      }
      load_calc: "index = base + 2" {
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
      }
      load_target: "local_2" {
        style.fill: "#BBDEFB"
        style.stroke: "#1565C0"
      }
      load_op -> load_calc: "slot=2"
      load_calc -> load_target: "locals[2]"
    }
  }
  store_local: {
    direction: down
    label: "STORE_LOCAL 0 Execution"
    width: 380
    store_code: |'c
      case OP_STORE_LOCAL: {
        uint16_t slot = read_operand(ip);
        ip += 2;
        CallFrame* frame = frame_stack_top(&frames);
        // Index calculation:
        int index = frame->locals_base + slot;
        Value value = vm_pop(vm);
        vm->locals[index] = value;
      }
    '|
    store_diagram: {
      direction: right
      label: "Memory Access Pattern"
      store_op: "STORE_LOCAL 0" {
        style.fill: "#FFEBEE"
        style.stroke: "#C62828"
      }
      store_calc: "index = base + 0" {
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
      }
      store_target: "local_0" {
        style.fill: "#BBDEFB"
        style.stroke: "#1565C0"
      }
      store_op -> store_calc: "slot=0"
      store_calc -> store_target: "locals[0]"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  frame_example: {
    direction: down
    label: "Concrete Example: base=100"
    example_table: {
      shape: sql_table
      label: "Frame with 4 locals"
      e0: "100 + 0 | 3.0 | local_0"
      e1: "100 + 1 | 5.0 | local_1"
      e2: "100 + 2 | 0.0 | local_2"
      e3: "100 + 3 | 0.0 | local_3"
      base: "frame->locals_base = 100"
    }
    access_examples: {
      label: "Access Examples"
      code: |'c
        LOAD 1  -> locals[101] = 5.0
        STORE 0 -> locals[100] = <pop>
        LOAD 2  -> locals[102] = 0.0
      '|
    }
  }
  validation: {
    direction: down
    label: "Bounds Validation"
    valid_code: |'c
      if (slot >= frame->locals_count) {
        runtime_error(vm, "Local out of bounds");
        return INTERPRET_RUNTIME_ERROR;
      }
    '|
    valid_diagram: {
      direction: right
      valid_slot: "slot=2 < 4 ✓" {
        shape: diamond
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
      invalid_slot: "slot=5 >= 4 ✗" {
        shape: diamond
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
      }
    }
  }
}

legend: {
  label: "Key Insight"
  insight: |md
    **Base Pointer Arithmetic:**
    Each frame's locals start at `locals_base` offset.
    `local_slot_N` = `vm->locals[frame->locals_base + N]`
    This enables O(1) access and automatic isolation
    between function calls without per-frame allocation.
  |
}
legend.near: bottom-right

row1.frame_structure.frame_layout -> row1.locals_array.locals_table: "locals_base indexes into" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}