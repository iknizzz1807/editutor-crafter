direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## RETURN Instruction Execution Trace
  Four-phase transformation from callee to caller
| {near: top-center}
# Phase 1: Before RETURN (Callee state)
phase1_container: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase1: {
    direction: down
    label: "Phase 1: Before RETURN"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    stack_before: {
      shape: sql_table
      label: "Operand Stack"
      s0: "0x00 | Value  | 8.0 (return value)"
      s1: "0x08 | Value  | [unused]"
      note: "Return value on top"
    }
    frame_before: {
      shape: sql_table
      label: "CallFrame (add)"
      f0: "0x00 | Chunk*   | bytecode"
      f1: "0x08 | int      | return_address = 12"
      f2: "0x0C | int      | locals_base = 2"
      f3: "0x10 | int      | locals_count = 2"
    }
    frames_state: {
      label: "frames.count = 2"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    locals_before: {
      shape: sql_table
      label: "Locals Array"
      l0: "0  | 0x00 | 3.0 (main local)"
      l1: "1  | 0x08 | 5.0 (main local)"
      l2: "2  | 0x10 | 3.0 (a = add local)"
      l3: "3  | 0x18 | 5.0 (b = add local)"
      note: "locals_top = 4"
    }
  }
}
# Arrow between phases
arrow1: {
  shape: rectangle
  label: "1. Capture return value"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
# Phase 2: Frame Popped
phase2_container: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase2: {
    direction: down
    label: "Phase 2: Frame Popped"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.stroke-width: 2
    return_val: {
      shape: rectangle
      label: "return_value = 8.0\n(captured before pop)"
      style.fill: "#FFECB3"
    }
    frame_popped: {
      shape: sql_table
      label: "CallFrame (main)"
      f0: "0x00 | Chunk*   | bytecode"
      f1: "0x08 | int      | return_address = 0"
      f2: "0x0C | int      | locals_base = 0"
      f3: "0x10 | int      | locals_count = 0"
    }
    frames_after: {
      label: "frames.count = 1"
      shape: rectangle
      style.fill: "#FFE082"
    }
    locals_restored: {
      shape: sql_table
      label: "Locals Array"
      l0: "0  | 0x00 | 3.0"
      l1: "1  | 0x08 | 5.0"
      l2: "2  | 0x10 | (freed)"
      l3: "3  | 0x18 | (freed)"
      note: "locals_top = 2 (restored)"
    }
  }
}
# Arrow between phases
arrow2: {
  shape: rectangle
  label: "2. Restore IP from return_address"
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
}
# Phase 3: IP Restored
phase3_container: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase3: {
    direction: down
    label: "Phase 3: IP Restored"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    ip_state: {
      shape: rectangle
      label: "vm->ip = 12\n(return_address from frame)"
      style.fill: "#BBDEFB"
    }
    bytecode_at_ip: {
      shape: sql_table
      label: "Bytecode at offset 12"
      b0: "0x0C | OP_HALT    | 0x00"
      note: "Next instruction to execute"
    }
    caller_context: {
      shape: rectangle
      label: "Execution resumed in main\nFrame: main, Locals: slots 0-1"
      style.fill: "#90CAF9"
    }
  }
}
# Arrow between phases
arrow3: {
  shape: rectangle
  label: "3. Push return value to caller's stack"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
}
# Phase 4: Return Value on Caller Stack
phase4_container: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase4: {
    direction: down
    label: "Phase 4: Return Value Preserved"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    stack_after: {
      shape: sql_table
      label: "Operand Stack (Caller's)"
      s0: "0x00 | Value  | 8.0 (return value)"
      s1: "0x08 | Value  | [unused]"
      note: "stack_top = 1"
    }
    final_state: {
      shape: rectangle
      label: "RETURN complete:\n• Frame popped\n• Locals freed\n• IP restored to 12\n• Return value (8.0) on caller stack"
      style.fill: "#E1BEE7"
    }
    execution_flow: {
      shape: rectangle
      label: "Next: Execute OP_HALT\nResult: INTERPRET_OK"
      style.fill: "#CE93D8"
    }
  }
}
# Connect phases
phase1_container.phase1 -> arrow1: "vm_pop()"
arrow1 -> phase2_container.phase2: "frame = top()"
phase2_container.phase2 -> arrow2: "vm->ip = frame->return_address"
arrow2 -> phase3_container.phase3: "ip = 12"
phase3_container.phase3 -> arrow3: "vm_push(return_value)"
arrow3 -> phase4_container.phase4: "stack[0] = 8.0"
# Legend
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  title: "Key Operations"
  op1: "1. Pop return_value from operand stack"
  op2: "2. locals_top = frame->locals_base (free callee's locals)"
  op3: "3. frame_stack_pop() (remove callee frame)"
  op4: "4. vm->ip = frame->return_address (resume caller)"
  op5: "5. vm_push(return_value) (pass value to caller)"
}