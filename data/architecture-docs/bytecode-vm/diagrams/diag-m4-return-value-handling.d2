direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Return Value Crossing Frame Boundary
  ## The Critical Transfer During RETURN
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_return: {
    direction: down
    label: "BEFORE RETURN (in callee)"
    operand_stack_before: {
      shape: rectangle
      label: "Operand Stack"
      width: 200
      stack_content: {
        shape: sql_table
        label: "Stack (callee owns)"
        row_top: "... | 8.0 | ← return value"
        row_below: "... | ... | (other temps)"
      }
    }
    frames_before: {
      shape: rectangle
      label: "Call Frames"
      width: 200
      frame_table_before: {
        shape: sql_table
        label: "Frame Stack"
        row_main: "0 | main | ret=12 | base=0"
        row_callee: "1 | add | ret=?? | base=2 | ← current"
      }
    }
    note_before: {
      label: "Return value 8.0 sits on operand stack\nwhile callee frame is still active"
      shape: rectangle
      width: 200
      style.fill: "#FFF9C9"
      style.stroke: "#9D341E"
    }
  }
  arrow_down: {
    label: "RETURN executes"
    shape: rectangle
    width: 80
    style.fill: transparent
    style.stroke: transparent
  }
  steps_box: {
    direction: down
    label: "RETURN Instruction Steps"
    width: 280
    step1: {
      label: "Step 1: Pop return value"
      code: |'c
        Value ret = vm_pop(vm);
        // ret = 8.0
      '|
      width: 260
      style.fill: "#E8F5E9"
    }
    step2: {
      label: "Step 2: Restore locals_top"
      code: |'c
        vm->locals_top = 
          frame->locals_base;
      '|
      width: 260
      style.fill: "#E3F2FD"
    }
    step3: {
      label: "Step 3: Pop frame"
      code: |'c
        frame_stack_pop(&vm->frames);
        // Now in caller's context!
      '|
      width: 260
      style.fill: "#FCE4EC"
    }
    step4: {
      label: "Step 4: Push return value"
      code: |'c
        vm_push(vm, ret);
        // 8.0 now on caller's stack!
      '|
      width: 260
      style.fill: "#E8F5E9"
    }
    critical: {
      label: "⚠️ CRITICAL: Value was captured\nBEFORE frame pop, pushed AFTER"
      shape: rectangle
      width: 260
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.stroke-width: 2
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after_return: {
    direction: down
    label: "AFTER RETURN (in caller)"
    operand_stack_after: {
      shape: rectangle
      label: "Operand Stack"
      width: 200
      stack_content_after: {
        shape: sql_table
        label: "Stack (caller owns)"
        row_ret: "... | 8.0 | ← return value NOW HERE"
      }
    }
    frames_after: {
      shape: rectangle
      label: "Call Frames"
      width: 200
      frame_table_after: {
        shape: sql_table
        label: "Frame Stack"
        row_main_only: "0 | main | ret=12 | base=0 | ← current"
      }
    }
    note_after: {
      label: "Return value successfully crossed\nthe frame boundary into caller's context"
      shape: rectangle
      width: 200
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
  }
  spacer: {
    label: ""
    width: 80
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
  }
  bug_box: {
    direction: down
    label: "Common Bug Pattern"
    width: 280
    bug_title: {
      label: "❌ BUGGY: Per-Frame Stack"
      shape: rectangle
      width: 260
      style.fill: "#FFCDD2"
    }
    bug_code: {
      label: ""
      code: |'c
        // WRONG: per-frame stacks
        Value ret = vm_pop(callee_stack);
        frame_stack_pop(&vm->frames);
        // BUG: Pushes to which stack?!
        vm_push(caller_stack, ret);
        // Must track which stack is active!
      '|
      width: 260
    }
    bug_explain: {
      label: "If each frame has its own operand stack,\nyou must explicitly switch stacks during return.\nOur design uses ONE shared stack, avoiding this."
      shape: rectangle
      width: 260
      style.fill: "#FFF3E0"
    }
  }
}
before_return -> steps_box: "executes" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
steps_box -> after_return: "results in" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  direction: right
  callee_color: {
    label: "Callee context"
    shape: rectangle
    style.fill: "#FFF9C9"
    width: 100
  }
  caller_color: {
    label: "Caller context"
    shape: rectangle
    style.fill: "#C8E6C9"
    width: 100
  }
  critical_color: {
    label: "Critical step"
    shape: rectangle
    style.fill: "#FFCDD2"
    width: 100
  }
}