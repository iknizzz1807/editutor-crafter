direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_shared: {
    direction: down
    label: "SHARED TYPES & UTILITIES"
    value: {
      shape: sql_table
      label: "struct Value (value.h)  [M1]"
      type: "double | 64-bit IEEE 754"
      size: "Total: 8 bytes"
    }
    opcode: {
      shape: sql_table
      label: "enum OpCode (opcode.h)  [M1]"
      control_flow: "0x00-0x0F | HALT, JUMP, JUMP_IF_FALSE"
      stack_ops: "0x10-0x1F | LOAD_CONST, POP, DUP"
      arithmetic: "0x20-0x2F | ADD, SUB, MUL, DIV, NEG"
      comparison: "0x30-0x3F | EQUAL, LESS, GREATER, etc."
      functions: "0x40-0x4F | LOAD_LOCAL, STORE_LOCAL, CALL, RETURN"
      count: "OP_COUNT = 21 opcodes"
    }
    chunk: {
      shape: sql_table
      label: "struct Chunk (chunk.h)  [M1]"
      bytecode: "BytecodeArray | {code*, count, capacity}"
      constants: "ConstantPool | {values*, count, capacity}"
      size: "Total: ~48 bytes + dynamic arrays"
    }
  }
  layer_infra: {
    direction: down
    label: "INFRASTRUCTURE"
    bytecode_array: {
      shape: sql_table
      label: "BytecodeArray (chunk.h)  [M1]"
      code: "uint8_t* | pointer to instruction bytes"
      count: "int | number of bytes used"
      capacity: "int | allocated size"
      growth: "Strategy: double on overflow, min 8"
    }
    constant_pool: {
      shape: sql_table
      label: "ConstantPool (chunk.h)  [M1]"
      values: "Value* | pointer to constants"
      count: "int | number of constants"
      capacity: "int | allocated size"
      dedup: "Deduplication via values_equal()"
    }
    frame: {
      shape: sql_table
      label: "struct CallFrame (frame.h)  [M4]"
      chunk: "Chunk* | bytecode being executed"
      return_address: "int | IP offset to resume"
      locals_base: "int | index into VM.locals"
      locals_count: "int | number of local slots"
      size: "Total: 24 bytes (aligned)"
    }
    frame_stack: {
      shape: sql_table
      label: "struct FrameStack (frame.h)  [M4]"
      frames: "CallFrame* | dynamic array"
      count: "int | current depth"
      capacity: "int | allocated size"
      max: "FRAMES_MAX = 256"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_vm: {
    direction: down
    label: "VIRTUAL MACHINE (vm.c)  [M1-M4]"
    vm: {
      shape: sql_table
      label: "struct VM (vm.h)  [M2]"
      chunk: "Chunk* | current bytecode"
      ip: "int | instruction pointer (offset)"
      stack: "Value[256] | operand stack (2KB)"
      stack_top: "int | next free slot index"
      frames: "FrameStack | call frame stack"
      locals: "Value[65536] | all local variables (512KB)"
      locals_top: "int | next free local slot"
      size: "Total: ~532 KB"
    }
    interpret_result: {
      shape: sql_table
      label: "enum InterpretResult (vm.h)  [M2]"
      ok: "INTERPRET_OK | reached HALT"
      compile_error: "INTERPRET_COMPILE_ERROR | reserved"
      runtime_error: "INTERPRET_RUNTIME_ERROR | error occurred"
    }
    vm_class: {
      shape: class
      label: "VM  vm.c  [M1-M4]"
      -chunk: "Chunk*"
      -ip: "int"
      -stack: "Value[STACK_MAX]"
      -stack_top: "int"
      -frames: "FrameStack"
      -locals: "Value[LOCALS_MAX]"
      -locals_top: "int"
      +vm_init(vm): "void"
      +vm_free(vm): "void"
      +vm_interpret(vm, chunk): "InterpretResult"
      +vm_push(vm, value): "void"
      +vm_pop(vm): "Value"
      +vm_peek(vm, distance): "Value"
    }
    frame_class: {
      shape: class
      label: "FrameStack  frame.c  [M4]"
      -frames: "CallFrame*"
      -count: "int"
      -capacity: "int"
      +frame_stack_init(stack): "void"
      +frame_stack_free(stack): "void"
      +frame_stack_push(stack): "CallFrame*"
      +frame_stack_pop(stack): "void"
      +frame_stack_top(stack): "CallFrame*"
    }
  }
  layer_chunks: {
    direction: down
    label: "CHUNK OPERATIONS (chunk.c)  [M1]"
    chunk_class: {
      shape: class
      label: "Chunk  chunk.c  [M1]"
      -bytecode: "BytecodeArray"
      -constants: "ConstantPool"
      +chunk_init(chunk): "void"
      +chunk_free(chunk): "void"
      +chunk_write_opcode(chunk, op): "void"
      +chunk_write_opcode_operand(chunk, op, operand): "void"
      +chunk_add_constant(chunk, value): "int"
      +chunk_read_operand(chunk, offset): "uint16_t"
    }
    opcode_class: {
      shape: class
      label: "OpCode  opcode.c  [M1]"
      +opcode_name(code): "const char*"
      +opcode_operand_count(code): "int"
    }
    disasm_class: {
      shape: class
      label: "Disassembler  disassemble.c  [M1]"
      +disassemble_chunk(chunk, name): "void"
      +disassemble_instruction(chunk, offset): "int"
    }
    value_class: {
      shape: class
      label: "Value  value.c  [M1]"
      +values_equal(a, b): "bool"
      +value_print(value): "void"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_exec: {
    direction: down
    label: "EXECUTION ENGINE  [M2-M3]"
    fetch_decode: {
      shape: class
      label: "Fetch-Decode-Execute Loop  vm.c  [M2]"
      +fetch(): "uint8_t opcode | IP++"
      +decode(opcode): "OpCode | operand count"
      +execute(instruction): "InterpretResult"
      note: "Loop until HALT or error"
    }
    stack_ops: {
      shape: class
      label: "Stack Operations  vm.c  [M2]"
      +OP_LOAD_CONST: "push constants[index]"
      +OP_POP: "discard top"
      +OP_DUP: "push peek(0)"
      note: "stack_top points to NEXT free slot"
    }
    arith_ops: {
      shape: class
      label: "Arithmetic Operations  vm.c  [M2]"
      +OP_ADD: "pop b, pop a, push a+b"
      +OP_SUB: "pop b, pop a, push a-b"
      +OP_MUL: "pop b, pop a, push a*b"
      +OP_DIV: "pop b, pop a, check b!=0, push a/b"
      +OP_NEG: "pop a, push -a"
      note: "Right operand popped FIRST"
    }
    comp_ops: {
      shape: class
      label: "Comparison Operations  vm.c  [M2]"
      +OP_EQUAL: "push 1.0 if equal, else 0.0"
      +OP_LESS: "push 1.0 if a < b"
      +OP_GREATER: "push 1.0 if a > b"
      +OP_LESS_EQ: "push 1.0 if a <= b"
      +OP_GREATER_EQ: "push 1.0 if a >= b"
      note: "Booleans as 1.0 / 0.0"
    }
    control_ops: {
      shape: class
      label: "Control Flow  vm.c  [M3]"
      +OP_JUMP: "read target, validate, IP = target"
      +OP_JUMP_IF_FALSE: "pop cond, jump if 0.0"
      note: "Absolute offsets, bounds checked"
    }
  }
  layer_funcs: {
    direction: down
    label: "FUNCTIONS  [M4]"
    local_ops: {
      shape: class
      label: "Local Variables  vm.c  [M4]"
      +OP_LOAD_LOCAL: "read slot, push locals[base+slot]"
      +OP_STORE_LOCAL: "pop, store locals[base+slot]"
      validation: "slot < frame->locals_count"
    }
    call_op: {
      shape: class
      label: "OP_CALL  vm.c  [M4]"
      operands: "arg_count, entry_point, locals_count (6 bytes)"
      validations: "frame depth, locals capacity, arg count"
      actions: "pop args reverse, push frame, init locals"
      transfer: "IP = entry_point"
      note: "7 bytes total instruction size"
    }
    return_op: {
      shape: class
      label: "OP_RETURN  vm.c  [M4]"
      capture: "pop return value from stack"
      teardown: "restore locals_top, pop frame"
      restore: "set chunk and IP from caller"
      propagate: "push return value to caller stack"
      main_return: "frames.count <= 1 returns INTERPRET_OK"
    }
    arg_passing: {
      shape: sql_table
      label: "Argument Passing Convention  [M4]"
      order: "Left-to-right into locals"
      mapping: "args[0] -> local_0, args[1] -> local_1"
      pop_order: "Pop in REVERSE from stack"
      defaults: "Remaining locals init to 0.0"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_encoding: {
    direction: down
    label: "INSTRUCTION ENCODING  [M1]"
    instr_layout: {
      shape: sql_table
      label: "Instruction Format"
      opcode: "1 byte | 0x00-0xFF"
      operand: "0 or 2 bytes | 16-bit big-endian"
      call_special: "OP_CALL has 6 operand bytes"
      example: "LOAD_CONST 5 = [0x10, 0x00, 0x05]"
    }
    memory_layout: {
      shape: sql_table
      label: "Bytecode Memory Layout"
      offset_0: "Opcode byte"
      offset_1: "Operand high byte"
      offset_2: "Operand low byte"
      note: "Big-endian: high byte first"
    }
  }
  layer_runtime: {
    direction: down
    label: "RUNTIME STRUCTURES  [M2-M4]"
    stack_layout: {
      shape: sql_table
      label: "Operand Stack (256 values, 2KB)"
      empty: "stack_top = 0"
      push: "stack[stack_top++] = value"
      pop: "return stack[--stack_top]"
      peek: "stack[stack_top - 1 - distance]"
    }
    locals_layout: {
      shape: sql_table
      label: "Local Variables Array (65536 values, 512KB)"
      frame_access: "locals[frame->locals_base + slot]"
      growth: "locals_top += locals_count on CALL"
      shrink: "locals_top = frame->locals_base on RETURN"
    }
    frame_layout: {
      shape: sql_table
      label: "Frame Stack (256 frames max)"
      main_frame: "frames[0] = main, always present"
      push: "New frame at frames[count++]"
      pop: "Decrement count, restore caller state"
    }
  }
  layer_constants: {
    direction: down
    label: "CONSTANTS  [M1]"
    constants_info: {
      shape: sql_table
      label: "System Constants"
      stack_max: "STACK_MAX = 256"
      frames_max: "FRAMES_MAX = 256"
      locals_per_frame: "LOCALS_PER_FRAME_MAX = 256"
      locals_max: "LOCALS_MAX = 65536"
      initial_cap: "Initial capacity = 8"
    }
  }
}
layer_shared -> layer_vm: "types used by"
layer_infra -> layer_vm: "structures in"
layer_vm -> layer_exec: "dispatches to"
layer_vm -> layer_funcs: "executes"
layer_chunks -> layer_vm: "loaded into"
layer_exec.stack_ops -> layer_vm.vm: "modifies stack"
layer_exec.arith_ops -> layer_vm.vm: "modifies stack"
layer_exec.control_ops -> layer_vm.vm: "modifies IP"
layer_funcs.local_ops -> layer_vm.vm: "accesses locals"
layer_funcs.call_op -> layer_infra.frame_stack: "pushes frame"
layer_funcs.return_op -> layer_infra.frame_stack: "pops frame"
layer_runtime.stack_layout -> layer_vm.vm: "2KB operand stack"
layer_runtime.locals_layout -> layer_vm.vm: "512KB locals array"
layer_runtime.frame_layout -> layer_infra.frame_stack: "256 frames"
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | bytecode-vm-m1 | Instruction Set Design: opcodes, chunks, disassembler"
  m2: "M2 | bytecode-vm-m2 | Stack-Based Execution: fetch-decode-execute, arithmetic, comparisons"
  m3: "M3 | bytecode-vm-m3 | Control Flow: OP_JUMP, OP_JUMP_IF_FALSE, loops, conditionals"
  m4: "M4 | bytecode-vm-m4 | Variables and Functions: call frames, locals, CALL, RETURN"
}