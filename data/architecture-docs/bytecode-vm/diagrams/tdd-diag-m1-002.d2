vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Instruction Encoding Memory Layout
Variable-length format: 1 byte (no operand) or 3 bytes (with 16-bit operand).
Byte-aligned, Big-Endian.
'| {
  near: top-center
}

direction: down

classes: {
  opcode: {
    style: {
      fill: "#D2B4DE"
      stroke: "#7D3C98"
      stroke-width: 2
      font: mono
      font-size: 18
      bold: true
    }
  }
  operand: {
    style: {
      fill: "#AED6F1"
      stroke: "#2E86C1"
      stroke-width: 2
      font: mono
      font-size: 18
      bold: true
    }
  }
  offset: {
    style: {
      fill: "#EBEDEF"
      stroke: "#85929E"
      stroke-width: 1
      font: mono
      font-size: 14
      font-color: "#2C3E50"
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 16
    }
  }
}

# -----------------------------------------------------------------------------
# 1. FORMAT SPECIFICATION
# -----------------------------------------------------------------------------
section_general: "General Format Specification" {
  format: {
    grid-rows: 2
    grid-columns: 3
    grid-gap: 0
    
    # Row 1: Memory Offsets
    off0: "Offset N" {class: offset}
    off1: "Offset N+1" {class: offset}
    off2: "Offset N+2" {class: offset}
    
    # Row 2: Fields
    op: "Opcode\n(Byte 0)" {class: opcode}
    hi: "Operand High\n(Byte 1)" {class: operand}
    lo: "Operand Low\n(Byte 2)" {class: operand}
  }
  
  note1: {
    shape: text
    label: |'md
**Big-Endian Encoding**: High byte first (Most Significant Byte).
`value = (high << 8) | low`
Total size: 3 bytes if operand present.
'|
  }
}

# -----------------------------------------------------------------------------
# 2. EXAMPLES
# -----------------------------------------------------------------------------
section_halt: "Example 1: OP_HALT (No Operand)" {
  halt_layout: {
    grid-rows: 2
    grid-columns: 1
    grid-gap: 0
    h_off: "+0" {class: offset}
    h_op: "0x00\nHALT" {class: opcode}
  }
  halt_info: {
    shape: text
    label: |'md
**Total: 1 byte**
Stops VM execution gracefully.
'|
  }
}

section_load: "Example 2: OP_LOAD_CONST (With Operand)" {
  load_layout: {
    grid-rows: 2
    grid-columns: 3
    grid-gap: 0
    l_off0: "+0" {class: offset}
    l_off1: "+1" {class: offset}
    l_off2: "+2" {class: offset}
    l_op: "0x10\nLOAD" {class: opcode}
    l_hi: "0x00\nHI" {class: operand}
    l_lo: "0x05\nLO" {class: operand}
  }
  load_info: {
    shape: text
    label: |'md
**Total: 3 bytes**
Loads `constants[5]` onto stack.
Index: `(0x00 << 8) | 0x05 = 5`
'|
  }
}

# -----------------------------------------------------------------------------
# 3. BYTECODE STREAM TRACE
# -----------------------------------------------------------------------------
section_trace: "Bytecode Stream Memory Trace" {
  trace_header: {
    shape: text
    label: "Segment: LOAD_CONST 0; LOAD_CONST 1; ADD; HALT"
  }
  
  trace_stream: {
    grid-columns: 8
    grid-gap: 0
    
    # Offsets
    t0_off: "00" {class: offset}
    t1_off: "01" {class: offset}
    t2_off: "02" {class: offset}
    t3_off: "03" {class: offset}
    t4_off: "04" {class: offset}
    t5_off: "05" {class: offset}
    t6_off: "06" {class: offset}
    t7_off: "07" {class: offset}
    
    # Values
    t0_val: "0x10" {class: opcode}
    t1_val: "0x00" {class: operand}
    t2_val: "0x00" {class: operand}
    t3_val: "0x10" {class: opcode}
    t4_val: "0x00" {class: operand}
    t5_val: "0x01" {class: operand}
    t6_val: "0x20" {class: opcode}
    t7_val: "0x00" {class: opcode}
  }
  
  trace_legend: {
    shape: text
    label: |'md
- **00-02**: `LOAD_CONST 0`
- **03-05**: `LOAD_CONST 1`
- **06**: `ADD`
- **07**: `HALT`
'|
  }
}

# -----------------------------------------------------------------------------
# 4. ENCODING LOGIC
# -----------------------------------------------------------------------------
section_encoding: "Binary Encoding Logic" {
  serialization: {
    grid-columns: 2
    write_logic: {
      label: |'go
// Encoding (Writer)
func WriteInstr(op byte, arg uint16) {
    bytecode.push(op)
    bytecode.push(byte(arg >> 8))
    bytecode.push(byte(arg & 0xFF))
}
'|
      style: {
        fill: "#2D2D2D"
        font-color: "#E0E0E0"
        font: mono
      }
    }
    
    read_logic: {
      label: |'go
// Decoding (VM Dispatch)
func ReadArg(pc int) uint16 {
    hi := uint16(bytecode[pc+1])
    lo := uint16(bytecode[pc+2])
    return (hi << 8) | lo
}
'|
      style: {
        fill: "#2D2D2D"
        font-color: "#E0E0E0"
        font: mono
      }
    }
  }
}

# -----------------------------------------------------------------------------
# 5. SUMMARY TABLE
# -----------------------------------------------------------------------------
section_summary: "Instruction Set Reference" {
  summary_table: {
    shape: text
    label: |'md
| Mnemonic | Opcode | Args | Size | Description |
| :--- | :--- | :--- | :--- | :--- |
| **HALT** | 0x00 | 0 | 1B | Terminate execution |
| **JUMP** | 0x01 | 1 | 3B | Set PC to operand |
| **LOAD_CONST**| 0x10 | 1 | 3B | Load constant index |
| **ADD** | 0x20 | 0 | 1B | Pop 2, Push Sum |
| **SUB** | 0x21 | 0 | 1B | Pop 2, Push Diff |
| **CALL** | 0x42 | 3 | 7B | Multi-arg Call |
'|
  }
}