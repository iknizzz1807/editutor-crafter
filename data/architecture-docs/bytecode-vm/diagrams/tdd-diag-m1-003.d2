vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: BytecodeChunk Internal Structure {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
direction: right
Chunk: {
  style: {
    fill: "#E8F4FD"
    stroke: "#2563EB"
    stroke-width: 3
    border-radius: 8
    shadow: true
  }
  header: |md
    ## Chunk
    `sizeof=24 bytes` (pointers + ints)
  | {
    shape: text
    style.fill: "#DBEAFE"
  }
  bytecode: {
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
      border-radius: 6
    }
    bc_header: |md
      **BytecodeArray**
      `sizeof=16 bytes`
    | {
      shape: text
      style.fill: "#FDE68A"
    }
    code_ptr: {
      label: "code\nuint8_t*"
      shape: rectangle
      style: {
        fill: "#FBBF24"
        font: mono
        font-size: 11
      }
    }
    count_field: {
      label: "count\nint"
      shape: rectangle
      style: {
        fill: "#FBBF24"
        font: mono
        font-size: 11
      }
    }
    capacity_field: {
      label: "capacity\nint"
      shape: rectangle
      style: {
        fill: "#FBBF24"
        font: mono
        font-size: 11
      }
    }
  }
  constants: {
    style: {
      fill: "#D1FAE5"
      stroke: "#059669"
      stroke-width: 2
      border-radius: 6
    }
    const_header: |md
      **ConstantPool**
      `sizeof=16 bytes`
    | {
      shape: text
      style.fill: "#A7F3D0"
    }
    values_ptr: {
      label: "values\nValue*"
      shape: rectangle
      style: {
        fill: "#34D399"
        font: mono
        font-size: 11
      }
    }
    const_count: {
      label: "count\nint"
      shape: rectangle
      style: {
        fill: "#34D399"
        font: mono
        font-size: 11
      }
    }
    const_capacity: {
      label: "capacity\nint"
      shape: rectangle
      style: {
        fill: "#34D399"
        font: mono
        font-size: 11
      }
    }
  }
}
BytecodeBuffer: {
  style: {
    fill: "#FFF7ED"
    stroke: "#EA580C"
    stroke-width: 2
    border-radius: 6
    stroke-dash: 4
  }
  bb_title: |md
    **Heap-allocated Byte Buffer**
    `uint8_t[]`
  | {
    shape: text
    style.fill: "#FFEDD5"
  }
  byte_0: { label: "0x10"; shape: square; style: { fill: "#FED7AA"; font: mono; font-size: 10 } }
  byte_1: { label: "0x00"; shape: square; style: { fill: "#FED7AA"; font: mono; font-size: 10 } }
  byte_2: { label: "0x05"; shape: square; style: { fill: "#FED7AA"; font: mono; font-size: 10 } }
  byte_3: { label: "0x20"; shape: square; style: { fill: "#FED7AA"; font: mono; font-size: 10 } }
  byte_4: { label: "0x00"; shape: square; style: { fill: "#FED7AA"; font: mono; font-size: 10 } }
  byte_ellipsis: { label: "..."; shape: square; style: { fill: "#FED7AA"; font-size: 10 } }
  byte_0 -- byte_1 -- byte_2 -- byte_3 -- byte_4 -- byte_ellipsis {
    style: { stroke: "#EA580C"; stroke-width: 1 }
  }
  valid_region: |md
    `count` bytes valid
    `[0, count)` range
  | {
    shape: text
    style: { font-size: 10 }
  }
  total_region: |md
    `capacity` bytes allocated
    `[0, capacity)` range
  | {
    shape: text
    style: { font-size: 10; italic: true }
  }
}
ConstantsArray: {
  style: {
    fill: "#ECFDF5"
    stroke: "#059669"
    stroke-width: 2
    border-radius: 6
    stroke-dash: 4
  }
  ca_title: |md
    **Heap-allocated Values**
    `Value[]` (double[])
  | {
    shape: text
    style.fill: "#D1FAE5"
  }
  val_0: { label: "3.0"; shape: rectangle; style: { fill: "#A7F3D0"; font: mono; font-size: 10 } }
  val_1: { label: "5.0"; shape: rectangle; style: { fill: "#A7F3D0"; font: mono; font-size: 10 } }
  val_2: { label: "0.0"; shape: rectangle; style: { fill: "#A7F3D0"; font: mono; font-size: 10 } }
  val_ellipsis: { label: "..."; shape: rectangle; style: { fill: "#A7F3D0"; font-size: 10 } }
  val_0 -- val_1 -- val_2 -- val_ellipsis {
    style: { stroke: "#059669"; stroke-width: 1 }
  }
  dedup_note: |md
    **Deduplication:**
    Same literal → Same index
    `values_equal()` check
  | {
    shape: text
    style: { font-size: 9; italic: true }
  }
}
Chunk.bytecode.code_ptr -> BytecodeBuffer: "owns" {
  style: {
    stroke: "#D97706"
    stroke-width: 2
    bold: true
  }
}
Chunk.constants.values_ptr -> ConstantsArray: "owns" {
  style: {
    stroke: "#059669"
    stroke-width: 2
    bold: true
  }
}
ownership_legend: {
  near: bottom-center
  legend_title: |md
    **Ownership Semantics**
  | { shape: text; style: { bold: true } }
  solid_line: "Solid arrow = owns (malloc/free responsibility)" {
    shape: text
    style: { font-size: 11 }
  }
  dashed_box: "Dashed box = heap-allocated memory" {
    shape: text
    style: { font-size: 11 }
  }
}
invariants: {
  near: bottom-right
  inv_title: |md
    **Invariants**
  | { shape: text; style: { bold: true; fill: "#F3F4F6" } }
  inv1: "`count <= capacity` always" { shape: text; style: { font-size: 10 } }
  inv2: "`code != NULL` when `capacity > 0`" { shape: text; style: { font-size: 10 } }
  inv3: "`values != NULL` when `capacity > 0`" { shape: text; style: { font-size: 10 } }
  inv4: "Growth: double capacity, min 8" { shape: text; style: { font-size: 10 } }
  inv_title -- inv1 -- inv2 -- inv3 -- inv4 {
    style: { stroke: transparent }
  }
}
growth_policy: {
  near: top-right
  style: {
    fill: "#FDF2F8"
    stroke: "#DB2777"
    stroke-width: 1
    border-radius: 4
  }
  growth_title: |md
    **Dynamic Array Growth**
  | { shape: text; style: { bold: true } }
  growth_steps: |md
    
    Initial: capacity = 0
    First write: capacity → 8
    At 8 full: capacity → 16
    At 16 full: capacity → 32
    ...
    Amortized O(1) append
    
  | {
    shape: text
    style: { font: mono; font-size: 9 }
  }
}