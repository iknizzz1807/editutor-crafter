layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header_purple: "#6a0dad"
    data_blue: "#2E86AB"
    padding_gray: "#D3D3D3"
    sign_red: "#FFB4A2"
    exp_brown: "#B5838D"
    mant_dark: "#6D6875"
  }
}

title: |md
  # VALUE TYPE MEMORY LAYOUT
  **Specification**: IEEE 754 Double-Precision (64-bit)
  **Architecture**: Little-Endian (Standard x86_64)
| {near: top-center}

# --- 1. PHYSICAL MEMORY LAYOUT ---

Memory_Frame: {
  label: "Memory Map: Value (8 Bytes)"
  style.stroke: "#000000"
  style.stroke-width: 2
  style.fill: "#FFFFFF"

  # Bit offsets visualization
  Offsets: {
    style.stroke-width: 0
    style.fill: transparent
    grid-columns: 3
    grid-gap: 0
    
    b63: "Bit 63" { width: 60; style.font-size: 10 }
    b62_52: "Bits 62-52" { width: 200; style.font-size: 10 }
    b51_0: "Bits 51-0" { width: 450; style.font-size: 10 }
  }

  Binary_Layout: {
    grid-columns: 3
    grid-gap: 0
    
    sign: "S" {
      width: 60; height: 100
      tooltip: "Sign Bit (1 bit)"
      style.fill: ${colors.sign_red}
      style.stroke: "#000000"
      style.bold: true
    }
    
    exponent: "EXPONENT" {
      width: 200; height: 100
      tooltip: "Biased Exponent (11 bits)"
      style.fill: ${colors.exp_brown}
      style.stroke: "#000000"
      style.font-color: white
      style.bold: true
    }
    
    mantissa: "MANTISSA / FRACTION" {
      width: 450; height: 100
      tooltip: "Significand (52 bits)"
      style.fill: ${colors.mant_dark}
      style.stroke: "#000000"
      style.font-color: white
      style.bold: true
    }
  }

  Byte_Boundaries: {
    shape: rectangle
    style.stroke-width: 0
    style.fill: transparent
    label: "| Byte 7 | Byte 6 | Byte 5 | Byte 4 | Byte 3 | Byte 2 | Byte 1 | Byte 0 |"
  }
}

# --- 2. ARCHITECTURAL SPECIFICATION ---

IEEE754_Spec: {
  style.fill: "#F8F9FA"
  
  Header: "IEEE 754 Components" {
    style.fill: ${colors.header_purple}
    style.font-color: white
    style.bold: true
  }
  
  Sign_Logic: {
    label: |md
      ### Sign (1 bit)
      **Offset**: +63
      **Value**: $(-1)^S$
      - `0`: Positive (+)
      - `1`: Negative (-)
    |
    style.fill: ${colors.sign_red}
  }
  
  Exp_Logic: {
    label: |md
      ### Exponent (11 bits)
      **Offset**: +52
      **Bias**: 1023 (0x3FF)
      **Range**: $2^{-1022}$ to $2^{1023}$
      - All 0s: Subnormal / Zero
      - All 1s: Inf / NaN
    |
    style.fill: ${colors.exp_brown}
    style.font-color: white
  }
  
  Mant_Logic: {
    label: |md
      ### Mantissa (52 bits)
      **Offset**: +0
      **Precision**: ~15.9 decimal digits
      **Implicit Bit**: $1.f$ (Normalized)
    |
    style.fill: ${colors.mant_dark}
    style.font-color: white
  }
}

# --- 3. STATE TRANSITIONS & SPECIAL CASES ---

State_Invariants: {
  Header: "Encoded Value Invariants" {
    style.fill: ${colors.header_purple}
    style.font-color: white
  }

  Zero: {
    label: "ZERO: Exp=0, Mant=0"
    style.fill: "#E8F5E9"
  }
  
  Infinity: {
    label: "INF: Exp=0x7FF, Mant=0"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
  
  NaN: {
    label: "NaN: Exp=0x7FF, Mant!=0"
    style.fill: "#FFF3E0"
    style.stroke: "#EF6C00"
    style.double-border: true
  }
}

# --- 4. IMPLEMENTATION OVERRIDE ---

Equality_Contract: {
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  
  Header: "Bitwise Equality Exception" {
    style.fill: "#FBC02D"
    style.bold: true
  }
  
  Logic: |md
    **Rule**: In a VM, NaN constants must be deduplicated.
    c
    bool valuesEqual(Value a, Value b) {
      // Bitwise check for NaNs to treat them as identical keys
      if (isnan(a) && isnan(b)) return true;
      return a == b;
    }
    
  |
}

# --- 5. DATA STRUCTURE (C-SPEC) ---

Value_Object_Model: {
  style.fill: transparent
  style.stroke-dash: 3

  Value_Typedef: "typedef double Value" {
    shape: rectangle
    style.fill: "#E1F5FE"
    style.font: mono
  }
  
  ValueArray: {
    shape: class
    style.fill: "#E1F5FE"
    
    capacity: "int"
    count: "int"
    values: "Value*"
    
    "initValueArray()": "void"
    "writeValueArray(Value)": "void"
    "freeValueArray()": "void"
  }
}

# --- CONNECTIONS & ANNOTATIONS ---

Memory_Frame.Binary_Layout -> IEEE754_Spec: "Bit Interpretation"
IEEE754_Spec -> State_Invariants: "Field Values"
State_Invariants.NaN -> Equality_Contract: "Override required"
Equality_Contract -> Value_Object_Model.ValueArray: "Implemented in"

Footprint: {
  near: bottom-right
  label: |md
    ### Physical Specification
    - **Total Size**: 8 Bytes (64-bit)
    - **Alignment**: 8-byte aligned (Required for atomic ops)
    - **Endianness**: x86_64 Little-Endian
    - **Type**: `typedef double Value`
  |
  style.fill: "#FFFFFF"
  style.stroke: "#333333"
  style.stroke-dash: 3
}

# --- POSITIONING FIX ---
Memory_Frame.Offsets -> Memory_Frame.Binary_Layout: {
  style.stroke-width: 0
  source-arrowhead: none
  target-arrowhead: none
}