vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    control: "#E8D5E3"
    stack: "#D5E8E3"
    arithmetic: "#E3E8D5"
    comparison: "#D5D8E8"
    functions: "#E8E3D5"
    header: "#2D3436"
    fixed: "#74B9FF"
    variable: "#E17055"
    border: "#636E72"
  }
}
title: ||md
  # Instruction Size Lookup Table
  Total size = 1 byte (opcode) + operand bytes
| {near: top-center}
legend: {
  near: top-right
  legend_box: {
    grid-columns: 2
    grid-gap: 8
    style.fill: white
    style.stroke: "${colors.border}"
    style.border-radius: 4
    fixed_label: "Fixed Size" {
      style.fill: "${colors.fixed}"
      style.stroke: "none"
      style.font-size: 12
    }
    fixed_desc: "1 or 3 bytes" {
      style.fill: transparent
      style.font-size: 11
    }
    variable_label: "Variable Size" {
      style.fill: "${colors.variable}"
      style.stroke: "none"
      style.font-size: 12
    }
    variable_desc: "7 bytes (3 operands)" {
      style.fill: transparent
      style.font-size: 11
    }
  }
}
instruction_table: {
  grid-columns: 4
  grid-gap: 0
  style.stroke: "${colors.border}"
  style.border-radius: 8
  style.fill: white
  header_category: Category {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
    style.font-size: 14
  }
  header_opcode: Opcode (Hex) {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
    style.font-size: 14
  }
  header_operands: Operands {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
    style.font-size: 14
  }
  header_total: Total Size {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
    style.font-size: 14
  }
  ctrl_divider: "" {style.fill: "${colors.control}"}
  ctrl_divider2: "" {style.fill: "${colors.control}"}
  ctrl_divider3: "" {style.fill: "${colors.control}"}
  ctrl_divider4: "" {style.fill: "${colors.control}"}
  ctrl_label: "CONTROL FLOW\n(0x00-0x0F)" {
    style.fill: "${colors.control}"
    style.bold: true
    style.font-size: 12
    style.vertical-align: center
  }
  ctrl_opcodes: |md
  OP_HALT ........... 0x00
  OP_JUMP ........... 0x01
  OP_JUMP_IF_FALSE .. 0x02
| {
    style.fill: "${colors.control}"
    style.font-size: 11
    style.font: mono
  }
  ctrl_operands: |md
  none
  target (16-bit)
  target (16-bit)
| {
    style.fill: "${colors.control}"
    style.font-size: 11
  }
  ctrl_sizes: |md
  **1 byte**
  **3 bytes**
  **3 bytes**
| {
    style.fill: "${colors.control}"
    style.font-size: 11
    style.bold: true
  }
  stack_divider: "" {style.fill: "${colors.stack}"}
  stack_divider2: "" {style.fill: "${colors.stack}"}
  stack_divider3: "" {style.fill: "${colors.stack}"}
  stack_divider4: "" {style.fill: "${colors.stack}"}
  stack_label: "STACK OPS\n(0x10-0x1F)" {
    style.fill: "${colors.stack}"
    style.bold: true
    style.font-size: 12
    style.vertical-align: center
  }
  stack_opcodes: |md
  OP_LOAD_CONST .... 0x10
  OP_POP ........... 0x11
  OP_DUP ........... 0x12
| {
    style.fill: "${colors.stack}"
    style.font-size: 11
    style.font: mono
  }
  stack_operands: |md
  index (16-bit)
  none
  none
| {
    style.fill: "${colors.stack}"
    style.font-size: 11
  }
  stack_sizes: |md
  **3 bytes**
  **1 byte**
  **1 byte**
| {
    style.fill: "${colors.stack}"
    style.font-size: 11
    style.bold: true
  }
  arith_divider: "" {style.fill: "${colors.arithmetic}"}
  arith_divider2: "" {style.fill: "${colors.arithmetic}"}
  arith_divider3: "" {style.fill: "${colors.arithmetic}"}
  arith_divider4: "" {style.fill: "${colors.arithmetic}"}
  arith_label: "ARITHMETIC\n(0x20-0x2F)" {
    style.fill: "${colors.arithmetic}"
    style.bold: true
    style.font-size: 12
    style.vertical-align: center
  }
  arith_opcodes: |md
  OP_ADD ........... 0x20
  OP_SUB ........... 0x21
  OP_MUL ........... 0x22
  OP_DIV ........... 0x23
  OP_NEG ........... 0x24
| {
    style.fill: "${colors.arithmetic}"
    style.font-size: 11
    style.font: mono
  }
  arith_operands: |md
  none
  none
  none
  none
  none
| {
    style.fill: "${colors.arithmetic}"
    style.font-size: 11
  }
  arith_sizes: |md
  **1 byte**
  **1 byte**
  **1 byte**
  **1 byte**
  **1 byte**
| {
    style.fill: "${colors.arithmetic}"
    style.font-size: 11
    style.bold: true
  }
  comp_divider: "" {style.fill: "${colors.comparison}"}
  comp_divider2: "" {style.fill: "${colors.comparison}"}
  comp_divider3: "" {style.fill: "${colors.comparison}"}
  comp_divider4: "" {style.fill: "${colors.comparison}"}
  comp_label: "COMPARISON\n(0x30-0x3F)" {
    style.fill: "${colors.comparison}"
    style.bold: true
    style.font-size: 12
    style.vertical-align: center
  }
  comp_opcodes: |md
  OP_EQUAL ......... 0x30
  OP_NOT_EQUAL ..... 0x31
  OP_LESS .......... 0x32
  OP_GREATER ....... 0x33
  OP_LESS_EQ ....... 0x34
  OP_GREATER_EQ .... 0x35
| {
    style.fill: "${colors.comparison}"
    style.font-size: 11
    style.font: mono
  }
  comp_operands: |md
  none
  none
  none
  none
  none
  none
| {
    style.fill: "${colors.comparison}"
    style.font-size: 11
  }
  comp_sizes: |md
  **1 byte**
  **1 byte**
  **1 byte**
  **1 byte**
  **1 byte**
  **1 byte**
| {
    style.fill: "${colors.comparison}"
    style.font-size: 11
    style.bold: true
  }
  func_divider: "" {style.fill: "${colors.functions}"}
  func_divider2: "" {style.fill: "${colors.functions}"}
  func_divider3: "" {style.fill: "${colors.functions}"}
  func_divider4: "" {style.fill: "${colors.functions}"}
  func_label: "FUNCTIONS\n(0x40-0x4F)" {
    style.fill: "${colors.functions}"
    style.bold: true
    style.font-size: 12
    style.vertical-align: center
  }
  func_opcodes: |md
  OP_LOAD_LOCAL .... 0x40
  OP_STORE_LOCAL ... 0x41
  OP_CALL .......... 0x42
  OP_RETURN ........ 0x43
| {
    style.fill: "${colors.functions}"
    style.font-size: 11
    style.font: mono
  }
  func_operands: |md
  slot (16-bit)
  slot (16-bit)
  arg_cnt + entry + locals
  none
| {
    style.fill: "${colors.functions}"
    style.font-size: 11
  }
  func_sizes: |md
  **3 bytes**
  **3 bytes**
  **7 bytes** ⚠
  **1 byte**
| {
    style.fill: "${colors.functions}"
    style.font-size: 11
    style.bold: true
  }
}
summary_box: {
  near: bottom-center
  style.fill: "#F8F9FA"
  style.stroke: "${colors.border}"
  style.border-radius: 6
  summary_content: |md
  ### Size Patterns Summary
  | Pattern | Opcode Range | Size | Examples |
  |---------|--------------|------|----------|
  | **Zero Operand** | 0x00, 0x11-0x12, 0x20-0x35, 0x43 | **1 byte** | HALT, ADD, RETURN |
  | **Single Operand** | 0x01-0x02, 0x10, 0x40-0x41 | **3 bytes** | JUMP, LOAD_CONST |
  | **Triple Operand** | 0x42 only | **7 bytes** | CALL (3 × 16-bit) |
  **Formula**: `sizeof(instruction) = 1 + (operand_count × 2)`
| {shape: text}
}
encoding_detail: {
  near: bottom-right
  style.fill: white
  style.stroke: "${colors.border}"
  style.border-radius: 6
  encoding_title: "Byte Layout" {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
    style.font-size: 12
  }
  layout_fixed: |md
  **Fixed (1 byte):**
  ┌────────────┐
  │   Opcode   │
  │  (0x00)    │
  └────────────┘
| {
    style.fill: "${colors.fixed}"
    style.font-size: 10
    style.font: mono
  }
  layout_operand: |md
  **Single Operand (3 bytes):**
  ┌────────┬─────────┬─────────┐
  │ Opcode │  High   │   Low   │
  │(0x10)  │  Byte   │  Byte   │
  └────────┴─────────┴─────────┘
| {
    style.fill: "${colors.fixed}"
    style.font-size: 10
    style.font: mono
  }
  layout_call: |md
  **CALL Instruction (7 bytes):**
  ┌────────┬─────────┬─────────┬─────────┬─────────┬─────────┬─────────┐
  │ 0x42   │ArgCount │ArgCount │ EntryPt │ EntryPt │ Locals  │ Locals  │
  │        │  High   │   Low   │  High   │   Low   │  High   │   Low   │
  └────────┴─────────┴─────────┴─────────┴─────────┴─────────┴─────────┘
| {
    style.fill: "${colors.variable}"
    style.font-size: 10
    style.font: mono
  }
}
||