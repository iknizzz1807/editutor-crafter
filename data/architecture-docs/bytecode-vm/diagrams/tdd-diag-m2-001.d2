vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    pointer: "#F97316"
    data: "#3B82F6"
    counter: "#10B981"
    padding: "#9CA3AF"
    cache: "#EF4444"
  }
}
title: |md
  # VM Struct Memory Layout
  `sizeof(VM) ≈ 2,112 bytes` (64-bit system)
| {near: top-center}
VM_Struct: {
  shape: rectangle
  style.fill: white
  style.stroke: "#1F2937"
  style.stroke-width: 2
  # Byte 0x00: chunk pointer
  chunk_ptr: {
    shape: rectangle
    label: "Chunk* chunk\n8 bytes (pointer)"
    style.fill: "${colors.pointer}"
    style.font-color: white
    style.bold: true
    width: 300
    height: 40
  }
  # Bytes 0x08-0x0B: instruction pointer
  ip_field: {
    shape: rectangle
    label: "int ip\n4 bytes"
    style.fill: "${colors.counter}"
    style.font-color: white
    style.bold: true
    width: 300
    height: 40
  }
  # Bytes 0x0C-0x0F: padding
  padding1: {
    shape: rectangle
    label: "padding\n4 bytes"
    style.fill: "${colors.padding}"
    style.font-color: white
    style.fill-pattern: lines
    width: 300
    height: 40
  }
  # Bytes 0x10-0x80F: operand stack (256 * 8 = 2048 bytes)
  stack_array: {
    shape: rectangle
    label: "Value stack[256]\n2,048 bytes (256 × sizeof(double))"
    style.fill: "${colors.data}"
    style.font-color: white
    style.bold: true
    width: 300
    height: 200
  }
  # Bytes 0x810-0x813: stack_top
  stack_top_field: {
    shape: rectangle
    label: "int stack_top\n4 bytes"
    style.fill: "${colors.counter}"
    style.font-color: white
    style.bold: true
    width: 300
    height: 40
  }
  # Bytes 0x814-0x817: padding
  padding2: {
    shape: rectangle
    label: "padding\n4 bytes"
    style.fill: "${colors.padding}"
    style.font-color: white
    style.fill-pattern: lines
    width: 300
    height: 40
  }
  # Vertical layout
  chunk_ptr -> ip_field -> padding1 -> stack_array -> stack_top_field -> padding2: {style.opacity: 0}
}
# Offset annotations on the left
offsets: {
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
  off0: {
    shape: text
    label: "0x0000"
    style.font: mono
    style.font-size: 14
    style.font-color: "#6B7280"
  }
  off8: {
    shape: text
    label: "0x0008"
    style.font: mono
    style.font-size: 14
    style.font-color: "#6B7280"
  }
  offC: {
    shape: text
    label: "0x000C"
    style.font: mono
    style.font-size: 14
    style.font-color: "#6B7280"
  }
  off10: {
    shape: text
    label: "0x0010"
    style.font: mono
    style.font-size: 14
    style.font-color: "#6B7280"
  }
  off810: {
    shape: text
    label: "0x0810"
    style.font: mono
    style.font-size: 14
    style.font-color: "#6B7280"
  }
  off814: {
    shape: text
    label: "0x0814"
    style.font: mono
    style.font-size: 14
    style.font-color: "#6B7280"
  }
  off0 -> off8 -> offC -> off10 -> off810 -> off814: {style.opacity: 0}
}
offsets.off0 -> VM_Struct.chunk_ptr: {style.stroke: "${colors.cache}"; style.stroke-dash: 3}
offsets.off8 -> VM_Struct.ip_field: {style.stroke: "${colors.cache}"; style.stroke-dash: 3}
offsets.off10 -> VM_Struct.stack_array: {style.stroke: "${colors.cache}"; style.stroke-dash: 3}
offsets.off810 -> VM_Struct.stack_top_field: {style.stroke: "${colors.cache}"; style.stroke-dash: 3}
# Size annotations on the right
sizes: {
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
  size8_1: {
    shape: text
    label: "← 8 bytes"
    style.font: mono
    style.font-size: 12
    style.font-color: "#6B7280"
  }
  size4_1: {
    shape: text
    label: "← 4 bytes"
    style.font: mono
    style.font-size: 12
    style.font-color: "#6B7280"
  }
  size4_2: {
    shape: text
    label: "← 4 bytes"
    style.font: mono
    style.font-size: 12
    style.font-color: "#6B7280"
  }
  size2048: {
    shape: text
    label: "← 2,048 bytes"
    style.font: mono
    style.font-size: 12
    style.font-color: "#6B7280"
  }
  size4_3: {
    shape: text
    label: "← 4 bytes"
    style.font: mono
    style.font-size: 12
    style.font-color: "#6B7280"
  }
  size4_4: {
    shape: text
    label: "← 4 bytes"
    style.font: mono
    style.font-size: 12
    style.font-color: "#6B7280"
  }
  size8_1 -> size4_1 -> size4_2 -> size2048 -> size4_3 -> size4_4: {style.opacity: 0}
}
VM_Struct.chunk_ptr -> sizes.size8_1: {style.stroke: "#E5E7EB"; style.stroke-dash: 2}
VM_Struct.ip_field -> sizes.size4_1: {style.stroke: "#E5E7EB"; style.stroke-dash: 2}
VM_Struct.padding1 -> sizes.size4_2: {style.stroke: "#E5E7EB"; style.stroke-dash: 2}
VM_Struct.stack_array -> sizes.size2048: {style.stroke: "#E5E7EB"; style.stroke-dash: 2}
VM_Struct.stack_top_field -> sizes.size4_3: {style.stroke: "#E5E7EB"; style.stroke-dash: 2}
VM_Struct.padding2 -> sizes.size4_4: {style.stroke: "#E5E7EB"; style.stroke-dash: 2}
# Cache line legend
legend: {
  shape: rectangle
  style.fill: "#F9FAFB"
  style.stroke: "#E5E7EB"
  style.border-radius: 4
  label: ""
  cache_line_note: |md
    **Cache Line: 64 bytes**
    - `chunk` + `ip` + padding = 16 bytes (¼ cache line)
    - `stack[0..7]` = 64 bytes (1 cache line)
    - `stack` spans 32 cache lines
  |
}
legend.near: bottom-right
# Stack detail expansion
stack_detail: {
  shape: rectangle
  style.fill: white
  style.stroke: "${colors.data}"
  style.stroke-width: 2
  label: ""
  stack_title: {
    shape: text
    label: "stack[256] Detail"
    style.bold: true
    style.font-size: 16
  }
  stack_0: {
    shape: rectangle
    label: "stack[0]\n8 bytes"
    style.fill: "${colors.data}"
    style.font-color: white
    width: 80
    height: 40
  }
  stack_1: {
    shape: rectangle
    label: "stack[1]\n8 bytes"
    style.fill: "${colors.data}"
    style.font-color: white
    width: 80
    height: 40
  }
  stack_dots: {
    shape: text
    label: "⋮"
    style.font-size: 20
  }
  stack_top: {
    shape: rectangle
    label: "stack[255]\n8 bytes"
    style.fill: "${colors.data}"
    style.font-color: white
    width: 80
    height: 40
  }
  stack_top_ptr: {
    shape: rectangle
    label: "stack_top"
    style.fill: "${colors.counter}"
    style.font-color: white
    width: 80
    height: 40
  }
  stack_0 -> stack_1 -> stack_dots -> stack_top: {style.opacity: 0}
  stack_top -> stack_top_ptr: {
    label: "points to\nnext free slot"
    style.stroke: "${colors.counter}"
    style.stroke-width: 2
  }
}
# Total size summary
summary: {
  shape: rectangle
  style.fill: "#FEF3C7"
  style.stroke: "#F59E0B"
  style.border-radius: 4
  total: |md
    **Total Size Calculation:**
    
    sizeof(Chunk*)     = 8 bytes
    sizeof(int ip)     = 4 bytes
    padding            = 4 bytes
    sizeof(stack[256]) = 2,048 bytes
    sizeof(stack_top)  = 4 bytes
    padding            = 4 bytes
    ─────────────────────────────
    TOTAL              = 2,072 bytes
    
  |
}
summary.near: bottom-center
# Note about alignment
alignment_note: {
  shape: text
  label: |md
    **Alignment Notes:**
    • Struct aligned to 8-byte boundary (largest member)
    • `int` fields padded to maintain alignment
    • Cache line size: 64 bytes (typical x86-64)
  |
  style.fill: white
  style.stroke: "#E5E7EB"
  style.border-radius: 4
}
alignment_note.near: top-right