vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # Fetch-Decode-Execute Cycle
  ### State Machine: Bytecode Virtual Machine Interpreter Loop
  *TDD Specification Module: M2-VM-CORE*
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --- State Definitions ---

FETCH: {
  shape: circle
  label: |md
    ### 01: FETCH
    **Action: Load OpCode**
    - `opcode_t IR = vm->code[vm->ip]`
    - `vm->ip += 1` (Post-increment)
    - **Invariant**: `ip < code_size`
  |
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 4
    font-color: "#1565C0"
  }
}

DECODE: {
  shape: diamond
  label: |md
    ### 02: DECODE
    **Logic: Pattern Match**
    - `instr = lookup_table[IR]`
    - **Guard**: `IR <= MAX_OPCODE`
    - **Guard**: `instr.handler != NULL`
  |
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 4
    font-color: "#E65100"
  }
}

EXECUTE: {
  shape: hexagon
  label: |md
    ### 03: EXECUTE
    **Action: Dispatch & Mutate**
    - `stack_ptr` manipulation
    - `switch(IR) { ... }`
    - **OP_ADD**: `push(pop() + pop())`
    - **OP_JMP**: `ip = read_u16(ip)`
  |
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 4
    font-color: "#2E7D32"
  }
}

HALT: {
  shape: circle
  label: |md
    ### TERMINAL: HALT
    **Status: INTERPRET_OK**
    - Clear Stack
    - `vm->status = 0x00`
    - Exit Loop
  |
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-width: 4
    font-color: "#C62828"
    double-border: true
  }
}

ERROR: {
  shape: circle
  label: |md
    ### ERROR: PANIC
    **Status: INTERPRET_RUNTIME_ERR**
    - **Reason**: `0x01` (Illegal Op)
    - Dump Registers
    - `stderr` trace
  |
  style: {
    fill: "#FCE4EC"
    stroke: "#E91E63"
    stroke-width: 3
    font-color: "#AD1457"
  }
}

START: "" {
  shape: circle
  width: 25
  height: 25
  style.fill: "#424242"
}

# --- Transitions ---

START -> FETCH: "INIT_VM\n{IP: 0, SP: 0}" {
  style.stroke: "#616161"
  style.stroke-width: 2
}

FETCH -> DECODE: "1. Read byte\n2. IP++" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.font-color: "#1565C0"
}

DECODE -> EXECUTE: "VALID_OP" {
  style.stroke: "#FF9800"
  style.stroke-width: 3
  style.font-color: "#E65100"
}

EXECUTE -> FETCH: "NEXT_INSTR\n(Loopback)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    font-color: "#2E7D32"
    animated: true
  }
}

EXECUTE -> HALT: "OP_HALT\n(0xFF)" {
  style.stroke: "#F44336"
  style.stroke-width: 4
  style.font-color: "#C62828"
}

DECODE -> ERROR: "INVALID_OP\n[ILLEGAL]" {
  style: {
    stroke: "#E91E63"
    stroke-width: 3
    stroke-dash: 5
    font-color: "#AD1457"
  }
}

# --- Sidecar Documentation & Annotations ---

IP_STATE_ANNOTATION: {
  shape: rectangle
  label: |md
    ## IP Register Behavior Spec
    - **FETCH**: `ip` strictly increments by `sizeof(uint8_t)`.
    - **DECODE**: `ip` is read-only (Peeking not allowed).
    - **EXECUTE (JMP)**: `ip` overwritten by immediate 16-bit address.
    - **EXECUTE (OTHERS)**: `ip` moves forward by `N` operands.
  |
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    stroke-dash: 3
    border-radius: 8
  }
}

LEGEND_BOX: {
  shape: rectangle
  label: |md
    ### State Machine Semantics
    - **Circle**: Atomic Phase
    - **Diamond**: Branching/Validation
    - **Hexagon**: Complex Logic/Dispatch
    - **Double Border**: Terminal Node
    - **Dashed Red**: Fault Condition
  |
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-width: 1
    font-size: 12
  }
}

# --- Layout Positioning (Fixed) ---

FETCH.near: top-left
DECODE.near: top-center
EXECUTE.near: bottom-center
HALT.near: center-right
ERROR.near: bottom-right
IP_STATE_ANNOTATION.near: bottom-left
LEGEND_BOX.near: bottom-right