direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Stack Overflow/Underflow Detection
  Stack bounds checking in `vm_push` and `vm_pop`
| {near: top-center}
classes: {
  decision: {
    shape: diamond
    width: 140
    height: 80
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
  success: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  error: {
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 2
    }
  }
  state_box: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-dash: 3
      font: mono
      font-size: 12
    }
  }
  action: {
    style: {
      fill: "#FFFFFF"
      stroke: "#616161"
    }
  }
}
container: vm_push {
  label: "vm_push(vm, value)"
  style.stroke: "#1976D2"
  push_start: "Push Request" {
    shape: oval
    style.fill: "#E3F2FD"
  }
  push_check: "stack_top < STACK_MAX?" {
    class: decision
  }
  push_overflow: "OVERFLOW ERROR" {
    class: error
    style.bold: true
  }
  push_action: "stack[stack_top++] = value" {
    class: action
    shape: rectangle
  }
  push_success: "Success" {
    class: success
    shape: oval
  }
  push_state_before: |md
    Before:
    
    stack_top = N
    stack[N-1] = top
    stack[N] = ???
    
  | {class: state_box}
  push_state_after: |md
    After:
    
    stack_top = N+1
    stack[N] = value
    
  | {class: state_box}
  push_error_msg: |md
    Error:
    
    "Stack overflow"
    exit(1)
    
  | {
    class: state_box
    style.fill: "#FFEBEE"
  }
  push_start -> push_check
  push_check -> push_overflow: "NO\n(top >= MAX)" {
    style.stroke: "#C62828"
    style.stroke-width: 3
    style.bold: true
  }
  push_check -> push_action: "YES\n(top < MAX)" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  push_action -> push_success
  push_overflow -> push_error_msg
  push_state_before -> push_check -> push_state_after
}
container: vm_pop {
  label: "vm_pop(vm)"
  style.stroke: "#1976D2"
  pop_start: "Pop Request" {
    shape: oval
    style.fill: "#E3F2FD"
  }
  pop_check: "stack_top > 0?" {
    class: decision
  }
  pop_underflow: "UNDERFLOW ERROR" {
    class: error
    style.bold: true
  }
  pop_action: "return stack[--stack_top]" {
    class: action
    shape: rectangle
  }
  pop_success: "Success\n(return value)" {
    class: success
    shape: oval
  }
  pop_state_before: |md
    Before:
    
    stack_top = N
    stack[N-1] = value
    
  | {class: state_box}
  pop_state_after: |md
    After:
    
    stack_top = N-1
    return value
    
  | {class: state_box}
  pop_error_msg: |md
    Error:
    
    "Stack underflow"
    exit(1)
    
  | {
    class: state_box
    style.fill: "#FFEBEE"
  }
  pop_start -> pop_check
  pop_check -> pop_underflow: "NO\n(top <= 0)" {
    style.stroke: "#C62828"
    style.stroke-width: 3
    style.bold: true
  }
  pop_check -> pop_action: "YES\n(top > 0)" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  pop_action -> pop_success
  pop_underflow -> pop_error_msg
  pop_state_before -> pop_check -> pop_state_after
}
legend: {
  near: bottom-center
  grid-columns: 3
  grid-gap: 20
  l1: "Decision" {
    shape: diamond
    class: decision
    width: 60
    height: 40
  }
  l2: "Success Path" {
    class: success
  }
  l3: "Error Path" {
    class: error
  }
}
constants: {
  near: center-left
  style.fill: "#F3E5F5"
  |md
  ### Constants
  - `STACK_MAX = 256`
  - Valid range: `0 ≤ stack_top ≤ STACK_MAX`
  - Empty: `stack_top == 0`
  - Full: `stack_top == STACK_MAX`
  |
}