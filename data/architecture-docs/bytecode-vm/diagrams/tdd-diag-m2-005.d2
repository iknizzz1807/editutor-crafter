vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Subtraction Operand Order Trace
  `10 - 3` → `7` (not `-7`)
| {near: top-center}
Step_1: {
  label: "Step 1: LOAD_CONST 0"
  instruction_1: {
    shape: rectangle
    style.fill: "#E8F4E8"
    style.stroke: "#4A7C4A"
    style.stroke-width: 2
    label: |md
      **Bytecode:** `LOAD_CONST 0`
      **Constant Pool:** `constants[0] = 10.0`
    |
  }
  arrow_1: instruction_1 -> stack_1: "push 10" {
    style.stroke: "#4A7C4A"
    style.stroke-width: 2
  }
  stack_1: {
    label: "Operand Stack"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    slot_0: "stack[0] = 10" {
      shape: rectangle
      style.fill: "#BBDEFB"
      style.font: mono
      style.bold: true
    }
    stack_top_1: "stack_top = 1" {
      style.fill: "#FFF9C4"
      style.font: mono
    }
  }
}
Step_2: {
  label: "Step 2: LOAD_CONST 1"
  instruction_2: {
    shape: rectangle
    style.fill: "#E8F4E8"
    style.stroke: "#4A7C4A"
    style.stroke-width: 2
    label: |md
      **Bytecode:** `LOAD_CONST 1`
      **Constant Pool:** `constants[1] = 3.0`
    |
  }
  arrow_2: instruction_2 -> stack_2: "push 3" {
    style.stroke: "#4A7C4A"
    style.stroke-width: 2
  }
  stack_2: {
    label: "Operand Stack"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    slot_0_b: "stack[0] = 10" {
      shape: rectangle
      style.fill: "#BBDEFB"
      style.font: mono
    }
    slot_1: "stack[1] = 3 ← TOP" {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.font: mono
      style.bold: true
    }
    stack_top_2: "stack_top = 2" {
      style.fill: "#FFF9C4"
      style.font: mono
    }
  }
}
Step_3: {
  label: "Step 3: SUB"
  instruction_3: {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 3
    style.bold: true
    label: |md
      **Bytecode:** `SUB`
      ---
      `b = vm_pop(vm)` → **b = 3** (TOP)
      `a = vm_pop(vm)` → **a = 10**
      `push(a - b)` → `push(10 - 3)` → **push(7)**
    |
  }
  note_critical: {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.stroke-width: 3
    label: |md
      ⚠️ **CRITICAL ORDER**
      Pop **RIGHT** operand FIRST (b = 3)
      Then pop **LEFT** operand (a = 10)
      Compute: `a - b` = `10 - 3` = **7**
      ❌ WRONG: `b - a` = `3 - 10` = **-7**
    |
  }
  instruction_3 -> note_critical {
    style.stroke: "#C62828"
    style.stroke-dash: 3
  }
}
Step_4: {
  label: "Step 4: Result"
  stack_4: {
    label: "Final Operand Stack"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    result: "stack[0] = 7" {
      shape: rectangle
      style.fill: "#C8E6C9"
      style.font: mono
      style.bold: true
      style.font-size: 18
    }
    stack_top_4: "stack_top = 1" {
      style.fill: "#FFF9C4"
      style.font: mono
    }
  }
  success: {
    shape: diamond
    style.fill: "#4CAF50"
    style.font-color: white
    label: "✓ Correct!\n10 - 3 = 7"
  }
}
Step_1 -> Step_2 -> Step_3 -> Step_4 {
  style.stroke: "#666"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#999"
  label: |md
    **Legend:**
    - Stack grows upward (top = highest index)
    - TOP is the **last pushed** value (right operand)
    - Binary ops: pop **right first**, then **left**
    - Result: `left - right` (NOT `right - left`)
  |
}
memory_layout: {
  near: bottom-right
  label: "Memory View"
  layout: {
    shape: rectangle
    style.fill: "#F5F5F5"
    label: |md
      
      Stack Memory:
      ┌─────────────┬─────────────┐
      │ Index 0: 10 │ Index 1: 3  │
      │ (left op)   │ (right op)  │
      │ pushed 1st  │ pushed 2nd  │
      └─────────────┴─────────────┘
                    ↑
                stack_top
      
    |
  }
}