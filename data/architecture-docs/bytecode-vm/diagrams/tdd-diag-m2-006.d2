layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Division Operand Order Trace
  `20 / 4` execution with operand order verification
| {near: top-center}

classes: {
  step: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      font: mono
    }
  }
  changed: {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
      stroke-width: 3
      bold: true
    }
  }
  error: {
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
      stroke-width: 3
    }
  }
  stack_cell: {
    width: 100
    height: 40
    style: {
      fill: "#FFF9C4"
      stroke: "#FFA000"
      stroke-width: 2
      font: mono
    }
  }
  empty: {
    width: 100
    height: 40
    style: {
      fill: "#FAFAFA"
      stroke: "#BDBDBD"
      stroke-dash: 3
      font: mono
    }
  }
  note: {
    shape: text
    style: {
      font: mono
      font-size: 14
      italic: true
      font-color: "#424242"
    }
  }
}

direction: right

# --- EXECUTION STEPS ---

step0: {
  label: "Step 0: Initial"
  class: step
  grid-columns: 1
  stack0: {
    grid-columns: 1
    grid-gap: 2
    s0_empty: "EMPTY STACK" {class: empty}
  }
  note0: "Stack: [] | IP: 0" {class: note}
}

step1: {
  label: "Step 1: LOAD_CONST 0"
  class: step
  grid-columns: 1
  stack1: {
    grid-columns: 1
    grid-gap: 2
    s1_20: "20.0" {class: stack_cell}
  }
  note1: "PUSH const[0]\nIP: 0 -> 3" {class: note}
}

step2: {
  label: "Step 2: LOAD_CONST 1"
  class: changed
  grid-columns: 1
  stack2: {
    grid-columns: 1
    grid-gap: 2
    s2_20: "20.0" {class: stack_cell}
    s2_4: "4.0" {class: changed}
  }
  note2: "PUSH const[1]\nIP: 3 -> 6" {class: note}
}

step3: {
  label: "Step 3: OP_DIV Fetch"
  class: step
  grid-columns: 1
  stack3: {
    grid-columns: 1
    grid-gap: 2
    s3_20: "20.0" {class: stack_cell}
    s3_4: "4.0" {class: stack_cell}
  }
  note3: "Fetch OP_DIV (0x23)\nIP: 6 -> 7" {class: note}
}

step4: {
  label: "Step 4: Pop Right"
  class: changed
  grid-columns: 1
  stack4: {
    grid-columns: 1
    grid-gap: 2
    s4_20: "20.0" {class: stack_cell}
    s4_empty: "POPPED: 4.0" {class: empty; style.font-color: red}
  }
  note4: "b = pop() = 4.0\n(Top is Right)" {class: note}
}

step5: {
  label: "Step 5: Pop Left"
  class: changed
  grid-columns: 1
  stack5: {
    grid-columns: 1
    grid-gap: 2
    s5_empty: "POPPED: 20.0" {class: empty; style.font-color: red}
  }
  note5: "a = pop() = 20.0\n(Next is Left)" {class: note}
}

step6: {
  label: "Step 6: Validation"
  class: step
  grid-columns: 1
  check6: {
    shape: diamond
    label: "divisor != 0?"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  note6: "b=4.0; 4.0 != 0\nPass Validation" {class: note}
}

step7: {
  label: "Step 7: Push Result"
  class: changed
  grid-columns: 1
  stack7: {
    grid-columns: 1
    grid-gap: 2
    s7_5: "5.0" {class: changed}
  }
  note7: "push(20.0 / 4.0)\nResult: 5.0" {class: note}
}

# --- FLOW ---

step0 -> step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> step7

step4 -> step5: "pop left" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
step5 -> step6: "validate" {
  style.stroke: "#FF9800"
}
step6 -> step7: "compute" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

# --- ANNOTATIONS AND REFERENCE ---

error_path: {
  label: "Exception Handling Path"
  class: error
  near: bottom-center
  
  error_trigger: {
    label: "TRAP: DivByZero"
    class: error
    style.stroke-dash: 0
  }
  
  error_msg: |md
    ## Runtime Error
    - Msg: "Division by zero"
    - Status: INTERPRET_RUNTIME_ERROR
    - Stack: [20.0] (partial)
  | {shape: text}
}

step6 -> error_path.error_trigger: "if b == 0" {
  style.stroke: "#F44336"
  style.stroke-dash: 5
}

bytecode_ref: {
  label: "Virtual Machine Context"
  near: top-right
  
  code_table: {
    shape: sql_table
    style.fill: "#F5F5F5"
    "Offset": "uint16"
    "Opcode": "uint8"
    "Instruction": "string"
    
    0: "0x0000 | 0x10 | LOAD_CONST 0"
    3: "0x0003 | 0x10 | LOAD_CONST 1"
    6: "0x0006 | 0x23 | OP_DIV"
    7: "0x0007 | 0x00 | OP_HALT"
  }
  
  pool: {
    label: "Constant Pool (Static Data)"
    shape: sql_table
    "Index": "uint8"
    "Value": "double"
    
    p0: "0 | 20.0"
    p1: "1 | 4.0"
  }
}

logic_box: {
  label: "C Implementation Logic"
  near: bottom-right
  style.fill: "#FDFDFD"
  
  source_snippet: |c
    // Correct order for non-commutative ops
    double b = AS_NUMBER(pop()); // Top element
    double a = AS_NUMBER(pop()); // Next element
    
    if (b == 0) {
        runtimeError("Division by zero.");
        return INTERPRET_RUNTIME_ERROR;
    }
    
    push(NUMBER_VAL(a / b));
  | {shape: text; style.font: mono}
}

legend: {
  near: bottom-left
  grid-columns: 1
  l1: "Changed State" {class: changed}
  l2: "Active Stack Cell" {class: stack_cell}
  l3: "Exception State" {class: error}
}