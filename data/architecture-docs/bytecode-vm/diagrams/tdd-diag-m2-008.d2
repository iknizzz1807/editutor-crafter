vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Instruction Pointer (IP) Advancement Patterns
    **Virtual Machine TDD Specification**
    *Rule: IP always points to the next byte to be fetched by the dispatcher.*
  |
  near: top-center
}

direction: down

classes: {
  byte_cell: {
    shape: rectangle
    width: 90
    height: 70
    style: {
      stroke: "#495057"
      stroke-width: 2
      font: mono
      font-size: 14
      bold: true
    }
  }
  opcode: {
    class: byte_cell
    style.fill: "#B197FC"
  }
  operand: {
    class: byte_cell
    style.fill: "#74C0FC"
  }
  padding: {
    class: byte_cell
    style.fill: "#E9ECEF"
    style.stroke-dash: 3
  }
  marker: {
    shape: text
    style: {
      font-size: 12
      bold: true
      font: mono
    }
  }
}

# --- 1. MEMORY LAYOUT STRIP ---
BytecodeBuffer: {
  label: "Bytecode Array (Physical Memory Layout) | sizeof=10 Bytes"
  grid-columns: 10
  grid-gap: 0
  
  b0: "0x00\nHALT" {class: opcode}
  b1: "0x00" {class: padding}
  b2: "0x00" {class: padding}
  b3: "0x10\nLDC" {class: opcode}
  b4: "0x00\nidx_h" {class: operand}
  b5: "0x01\nidx_l" {class: operand}
  b6: "0x20\nADD" {class: opcode}
  b7: "0x01\nJMP" {class: opcode}
  b8: "0x00\ntgt_h" {class: operand}
  b9: "0x06\ntgt_l" {class: operand}
}

# Offset Annotations placed relative to BytecodeBuffer
BytecodeBuffer.b0.o: "ptr: 0" {class: marker; near: outside-top-center}
BytecodeBuffer.b3.o: "ptr: 3" {class: marker; near: outside-top-center}
BytecodeBuffer.b6.o: "ptr: 6" {class: marker; near: outside-top-center}
BytecodeBuffer.b7.o: "ptr: 7" {class: marker; near: outside-top-center}

# --- 2. EXECUTION STATE TRANSITIONS ---
Patterns: {
  grid-columns: 1
  grid-gap: 80

  Pattern1: {
    label: "Pattern A: Single Byte Advancement (e.g., HALT, ADD)"
    grid-columns: 2
    
    Before: {
      label: "State: T₀ (Fetch)"
      direction: right
      ip: "IP=0" {class: marker; style.font-color: "#FF922B"}
      cell: "0x00 (HALT)" {class: opcode}
      ip -> cell: "points to"
    }
    
    After: {
      label: "State: T₁ (Post-Increment)"
      direction: right
      cell: "0x00 (HALT)" {class: opcode; style.stroke: "#51CF66"; style.stroke-width: 4}
      ip: "IP=1" {class: marker; style.font-color: "#51CF66"}
      cell -> ip: "Dispatcher moves IP"
    }
    
    Note: {
      label: |md
        **Advancement Rule:** `IP += 1`
        The dispatcher consumes the opcode and immediately increments the pointer before execution.
      |
      near: bottom-center
    }
  }

  Pattern2: {
    label: "Pattern B: Multi-Byte Operand Fetch (e.g., LDC <u16>)"
    
    Layout: {
      direction: right
      op: "0x10 (LDC)" {class: opcode}
      arg1: "0x00 (High)" {class: operand}
      arg2: "0x01 (Low)" {class: operand}
      
      ip_start: "Start IP=3" {class: marker; style.font-color: "#FF922B"}
      ip_end: "End IP=6" {class: marker; style.font-color: "#51CF66"}
      
      ip_start -> op: "1. Fetch Op"
      op -> arg1: "2. Consume Arg"
      arg1 -> arg2: "3. Consume Arg"
      arg2 -> ip_end: "4. Final IP Pos"
    }
    
    Note: {
      label: |md
        **Advancement Rule:** `IP += 3`
        Total stride = 1 (Opcode) + 2 (Immediate Operand). IP points to the opcode of the *next* instruction.
      |
      near: bottom-center
    }
  }

  Pattern3: {
    label: "Pattern C: Control Flow Jump (e.g., JMP <u16>)"
    
    JumpFlow: {
      direction: right
      jmp_op: "0x01 (JMP)" {class: opcode}
      t1: "0x00" {class: operand}
      t2: "0x06" {class: operand}
      
      ip_init: "Initial IP=7" {class: marker; style.font-color: "#FF922B"}
      ip_seq: "Sequential IP=10" {class: marker; style.font-color: "#868e96"; style.stroke-dash: 2}
      ip_taken: "Jump Target IP=6" {class: marker; style.font-color: "#339AF0"}
      
      ip_init -> jmp_op: "Fetch"
      t2 -> ip_seq: "If No Jump" {style.stroke: "#dee2e6"}
      t2 -> ip_taken: "IP = Target" {
        style: {
          stroke: "#339AF0"
          stroke-width: 4
          animated: true
        }
      }
    }
    
    Note: {
      label: |md
        **Absolute Jump:** The IP is overwritten with the value decoded from the operands.
        New IP = `(Operand[0] << 8) | Operand[1]`
      |
      near: bottom-center
    }
  }
}

# --- 3. IMPLEMENTATION PSEUDOCODE ---
ImplementationDetail: {
  label: |md
    ### Bytecode Dispatcher Loop (C99)
    c
    void execute(VM* vm) {
        while (vm->running) {
            // 1. Fetch opcode and post-increment IP
            uint8_t op = vm->bytecode[vm->ip++]; 
            
            switch (op) {
                case OP_LDC: {
                    // 2. Helper read16() handles IP advancement (+2)
                    uint16_t idx = read16(vm); 
                    push(vm->stack, vm->constants[idx]);
                    break;
                }
                case OP_JMP: {
                    // 3. Absolute write to IP
                    vm->ip = read16(vm); 
                    break;
                }
                case OP_HALT:
                    vm->running = false;
                    break;
            }
        }
    }
    
  |
  shape: rectangle
  near: bottom-center
  style: {
    fill: "#f8f9fa"
    stroke: "#495057"
    stroke-width: 1
  }
}

# --- 4. LEGEND ---
Legend: {
  near: bottom-right
  grid-columns: 1
  style.stroke: "#333"
  style.fill: "#ffffff"
  
  op: "Opcode (1 Byte)" {class: opcode}
  arg: "Operand (N Bytes)" {class: operand}
  ptr: "▲ Active Instruction Pointer" {
    shape: text
    style.font-color: "#FF922B"
    style.bold: true
  }
}

# Connection showing logical link
BytecodeBuffer -> Patterns: "Decoding Sequence" {
  style: {
    stroke-dash: 5
    opacity: 0.4
    stroke: "#adb5bd"
  }
}

# Global Overrides for Intel Quality
***.style.font: mono
(*** -> ***)[*].style.stroke: "#333"
(*** -> ***)[*].style.stroke-width: 1.5