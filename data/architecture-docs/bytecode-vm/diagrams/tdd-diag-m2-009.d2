vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Comparison Instruction Result Mapping {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: |md
  Stack-based comparison semantics: pop two values, push boolean result (1.0/0.0)
| {
  near: top-center
  shape: text
  style.font-size: 14
}
# Legend box
legend: {
  near: top-right
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
  style.stroke-dash: 3
  style.border-radius: 6
  legend_title: "Stack Convention" {
    style.bold: true
    style.fill: transparent
  }
  legend_content: |md
    **Stack before comparison:**
    `[a, b]` where `b` is on top
    **Pop order:** `b` first, then `a`
    **Result pushed:** 1.0 (true) or 0.0 (false)
  |
}
# Main comparison instructions table
comparison_table: {
  grid-columns: 5
  grid-gap: 0
  # Header row
  header_opcode: "Opcode" {
    style: {
      fill: "#4A5568"
      font-color: white
      bold: true
      border-radius: 0
    }
  }
  header_stack: "Stack Before\n(top → right)" {
    style: {
      fill: "#4A5568"
      font-color: white
      bold: true
      border-radius: 0
    }
  }
  header_condition: "Condition Tested" {
    style: {
      fill: "#4A5568"
      font-color: white
      bold: true
      border-radius: 0
    }
  }
  header_result: "Result\nPushed" {
    style: {
      fill: "#4A5568"
      font-color: white
      bold: true
      border-radius: 0
    }
  }
  header_example: "Example" {
    style: {
      fill: "#4A5568"
      font-color: white
      bold: true
      border-radius: 0
    }
  }
  # OP_EQUAL row
  equal_opcode: "OP_EQUAL\n0x30" {
    style: {
      fill: "#E6FFFA"
      bold: true
      font: mono
    }
  }
  equal_stack: "[a, b]" {
    style.fill: "#E6FFFA"
  }
  equal_condition: "values_equal(a, b)\n(uses special\nNaN handling)" {
    style.fill: "#E6FFFA"
    style.font-size: 11
  }
  equal_result: "1.0 if true\n0.0 if false" {
    style.fill: "#E6FFFA"
    style.bold: true
  }
  equal_example: "5.0, 5.0 → 1.0\n3.0, 7.0 → 0.0\nNaN, NaN → 1.0" {
    style.fill: "#E6FFFA"
    style.font: mono
    style.font-size: 10
  }
  # OP_NOT_EQUAL row
  nequal_opcode: "OP_NOT_EQUAL\n0x31" {
    style: {
      fill: "#F0FFF4"
      bold: true
      font: mono
    }
  }
  nequal_stack: "[a, b]" {
    style.fill: "#F0FFF4"
  }
  nequal_condition: "!values_equal(a, b)\n(inverted result)" {
    style.fill: "#F0FFF4"
    style.font-size: 11
  }
  nequal_result: "0.0 if true\n1.0 if false" {
    style.fill: "#F0FFF4"
    style.bold: true
  }
  nequal_example: "5.0, 5.0 → 0.0\n3.0, 7.0 → 1.0\nNaN, NaN → 0.0" {
    style.fill: "#F0FFF4"
    style.font: mono
    style.font-size: 10
  }
  # OP_LESS row
  less_opcode: "OP_LESS\n0x32" {
    style: {
      fill: "#FFF5F5"
      bold: true
      font: mono
    }
  }
  less_stack: "[a, b]" {
    style.fill: "#FFF5F5"
  }
  less_condition: "a < b\n(IEEE 754)" {
    style.fill: "#FFF5F5"
    style.font-size: 11
  }
  less_result: "1.0 if true\n0.0 if false" {
    style.fill: "#FFF5F5"
    style.bold: true
  }
  less_example: "3.0, 5.0 → 1.0\n5.0, 3.0 → 0.0\nNaN, 1.0 → 0.0" {
    style.fill: "#FFF5F5"
    style.font: mono
    style.font-size: 10
  }
  # OP_GREATER row
  greater_opcode: "OP_GREATER\n0x33" {
    style: {
      fill: "#FFFAF0"
      bold: true
      font: mono
    }
  }
  greater_stack: "[a, b]" {
    style.fill: "#FFFAF0"
  }
  greater_condition: "a > b\n(IEEE 754)" {
    style.fill: "#FFFAF0"
    style.font-size: 11
  }
  greater_result: "1.0 if true\n0.0 if false" {
    style.fill: "#FFFAF0"
    style.bold: true
  }
  greater_example: "5.0, 3.0 → 1.0\n3.0, 5.0 → 0.0\nNaN, 1.0 → 0.0" {
    style.fill: "#FFFAF0"
    style.font: mono
    style.font-size: 10
  }
  # OP_LESS_EQ row
  lesseq_opcode: "OP_LESS_EQ\n0x34" {
    style: {
      fill: "#F0F0FF"
      bold: true
      font: mono
    }
  }
  lesseq_stack: "[a, b]" {
    style.fill: "#F0F0FF"
  }
  lesseq_condition: "a <= b\n(IEEE 754)" {
    style.fill: "#F0F0FF"
    style.font-size: 11
  }
  lesseq_result: "1.0 if true\n0.0 if false" {
    style.fill: "#F0F0FF"
    style.bold: true
  }
  lesseq_example: "3.0, 5.0 → 1.0\n5.0, 5.0 → 1.0\nNaN, 1.0 → 0.0" {
    style.fill: "#F0F0FF"
    style.font: mono
    style.font-size: 10
  }
  # OP_GREATER_EQ row
  greatereq_opcode: "OP_GREATER_EQ\n0x35" {
    style: {
      fill: "#FFF0F5"
      bold: true
      font: mono
    }
  }
  greatereq_stack: "[a, b]" {
    style.fill: "#FFF0F5"
  }
  greatereq_condition: "a >= b\n(IEEE 754)" {
    style.fill: "#FFF0F5"
    style.font-size: 11
  }
  greatereq_result: "1.0 if true\n0.0 if false" {
    style.fill: "#FFF0F5"
    style.bold: true
  }
  greatereq_example: "5.0, 3.0 → 1.0\n5.0, 5.0 → 1.0\nNaN, 1.0 → 0.0" {
    style.fill: "#FFF0F5"
    style.font: mono
    style.font-size: 10
  }
}
# NaN handling detail box
nan_handling: {
  style: {
    fill: "#FEF3C7"
    stroke: "#D97706"
    stroke-width: 2
    border-radius: 8
  }
  nan_title: "⚠ NaN Handling for EQUAL/NOT_EQUAL" {
    style.bold: true
    style.fill: transparent
  }
  nan_code: |c
    // Standard IEEE 754: NaN != NaN
    // Our values_equal() handles this specially:
    bool values_equal(Value a, Value b) {
        // Two NaNs are considered equal
        if (isnan(a) && isnan(b)) return true;
        // Standard comparison for everything else
        return a == b;
    }
    // This ensures constant pool deduplication
    // works correctly with NaN values.
  |
}
# Execution flow diagram
execution_flow: {
  style.stroke: "#718096"
  style.stroke-dash: 2
  flow_title: "Comparison Execution Flow" {
    style.bold: true
    style.fill: white
  }
  step1: "1. FETCH opcode" {
    shape: rectangle
    style.fill: "#EDF2F7"
  }
  step2: "2. POP b (top)" {
    shape: rectangle
    style.fill: "#E2E8F0"
  }
  step3: "3. POP a (second)" {
    shape: rectangle
    style.fill: "#E2E8F0"
  }
  step4: "4. EVALUATE condition" {
    shape: diamond
    style.fill: "#FED7D7"
  }
  step5a: "5a. true: PUSH 1.0" {
    shape: rectangle
    style.fill: "#C6F6D5"
  }
  step5b: "5b. false: PUSH 0.0" {
    shape: rectangle
    style.fill: "#FED7AA"
  }
  step1 -> step2 -> step3 -> step4
  step4 -> step5a: "condition\nmet" {
    style.stroke: "#38A169"
    style.stroke-width: 2
  }
  step4 -> step5b: "condition\nnot met" {
    style.stroke: "#DD6B20"
    style.stroke-width: 2
  }
}
# Truthiness note for control flow
truthiness: {
  near: bottom-center
  style: {
    fill: "#EBF8FF"
    stroke: "#3182CE"
    border-radius: 6
  }
  truth_title: "Control Flow Integration" {
    style.bold: true
    style.fill: transparent
  }
  truth_content: |md
    **For JUMP_IF_FALSE:**
    - `0.0` and `-0.0` are **falsy** → jump taken
    - All other values (including `1.0`, `NaN`, `INFINITY`) are **truthy** → jump not taken
    **Truthy check:** `condition == 0.0` determines falsy
  |
}
# Connect sections
comparison_table -> nan_handling
execution_flow -> truthiness