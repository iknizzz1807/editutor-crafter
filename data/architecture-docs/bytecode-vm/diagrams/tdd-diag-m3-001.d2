layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    block-bg: "#E8F4FD"
    block-stroke: "#2E86AB"
    jump-edge: "#E63946"
    fallthrough: "#457B9D"
    loop-edge: "#8B5CF6"
    highlight: "#FFD60A"
    text-dark: "#1D3557"
    header-purple: "#6B21A8"
    memory-header: "#F8F9FA"
    memory-stroke: "#64748B"
  }
}

# --- GLOBAL STYLING ---
classes: {
  basic_block: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      border-radius: 4
    }
  }
  header_block: {
    style: {
      fill: "#FFD60A"
      stroke: "#8B5CF6"
      stroke-width: 3
      double-border: true
    }
  }
  terminal_block: {
    style: {
      fill: "#FFE5E5"
      stroke: "#E63946"
      stroke-width: 2
    }
  }
  annotation_box: {
    style: {
      fill: "#FEF3C7"
      stroke: "#F59E0B"
      stroke-dash: 3
      font-size: 12
    }
  }
}

title: {
  shape: text
  near: top-center
  label: |md
    # Control Flow Graph from Bytecode
    **Technical Specification: Jumps, Basic Blocks, and Edge Transitions**
    *Version: 1.0.4 | ISA: Custom Stack VM*
  |
}

# --- BYTECODE MEMORY LAYOUT ---
# Exact byte offsets left, instructions center, metadata right
bytecode_listing: {
  label: "ISA SEGMENT: .text (PC Relative)"
  shape: sql_table
  style: {
    fill: ${vars.colors.memory-header}
    stroke: ${vars.colors.memory-stroke}
  }
  
  "Offset (HEX)": "Instruction (Mnemonic + Op)" {constraint: "Field Size"}
  "0000": "LOAD_CONST 0" {constraint: "2 Bytes"}
  "0002": "STORE_LOCAL 0" {constraint: "2 Bytes"}
  "0004": "--- [PAGE BOUNDARY] ---" {style.stroke-width: 4}
  "0006": "LOAD_LOCAL 0" {constraint: "2 Bytes"}
  "0008": "LOAD_CONST 1" {constraint: "2 Bytes"}
  "0010": "GREATER" {constraint: "1 Byte"}
  "0011": "JUMP_IF_FALSE 29" {constraint: "3 Bytes"}
  "0014": "LOAD_LOCAL 0" {constraint: "2 Bytes"}
  "0016": "LOAD_CONST 1" {constraint: "2 Bytes"}
  "0018": "SUB" {constraint: "1 Byte"}
  "0019": "STORE_LOCAL 0" {constraint: "2 Bytes"}
  "0021": "JUMP 6" {constraint: "3 Bytes"}
  "0024": "--- [UNREACHABLE PADDING] ---" {style.fill: gray}
  "0029": "HALT" {constraint: "1 Byte"}
}

# --- CONTROL FLOW GRAPH RECONSTRUCTION ---
cfg: {
  label: "Control Flow Analysis (Graph Representation)"

  # B0: Initialization Sequence
  B0: {
    class: basic_block
    label: |md
      ### B0: Entry Block
      **Range: [0x0000 - 0x0003]**
      - `0000: LOAD_CONST 0`
      - `0002: STORE_LOCAL 0`
      ---
      *Properties:*
      - Predecessors: [None]
      - Successors: [B1]
      - Size: 4 Bytes
    |
  }

  # B1: Loop Header (Dominator)
  B1: {
    class: header_block
    label: |md
      ### B1: Loop Header
      **Range: [0x0006 - 0x0013]**
      - `0006: LOAD_LOCAL 0`
      - `0010: GREATER`
      - `0011: JUMP_IF_FALSE 29`
      ---
      *Analysis:*
      - Branch target: B3
      - Loop Type: Natural Loop Header
      - Size: 8 Bytes
    |
  }

  # B2: Loop Body (Back-edge tail)
  B2: {
    class: basic_block
    label: |md
      ### B2: Loop Body
      **Range: [0x0014 - 0x0023]**
      - `0014: LOAD_LOCAL 0`
      - `0018: SUB`
      - `0019: STORE_LOCAL 0`
      - `0021: JUMP 6`
      ---
      *Properties:*
      - Terminator: Unconditional Jump
      - Target: B1 (Header)
      - Size: 10 Bytes
    |
  }

  # B3: Terminal Block (Exit)
  B3: {
    class: terminal_block
    label: |md
      ### B3: Program Exit
      **Range: [0x0029 - 0x0029]**
      - `0029: HALT`
      ---
      *Analysis:*
      - Terminal instruction reached
      - Control Flow Terminated
      - Size: 1 Byte
    |
  }

  # --- CFG EDGES WITH TYPE ANNOTATION ---
  B0 -> B1: "Linear Fallthrough" {
    style: {
      stroke: ${vars.colors.fallthrough}
      stroke-width: 2
    }
  }

  B1 -> B2: "Path: Condition True" {
    style: {
      stroke: ${vars.colors.fallthrough}
      stroke-width: 2
    }
  }

  B1 -> B3: "Path: Condition False\nBranch to 0x0029" {
    style: {
      stroke: ${vars.colors.jump-edge}
      stroke-width: 2
      stroke-dash: 5
    }
  }

  B2 -> B1: "CRITICAL BACK-EDGE\nJump to 0x0006" {
    style: {
      stroke: ${vars.colors.loop-edge}
      stroke-width: 3
      animated: true
    }
  }
}

# --- DOCUMENTATION & LEGEND ---
metadata: {
  near: bottom-right
  
  legend: {
    shape: rectangle
    label: "Graph Legend"
    style.fill: white
    
    BBlock: {
      label: "Basic Block"
      class: basic_block
    }
    HBlock: {
      label: "Loop Header"
      class: header_block
    }
    TBlock: {
      label: "Terminal"
      class: terminal_block
    }
  }

  insight: {
    class: annotation_box
    label: |md
      ### Static Analysis Invariants
      1. **Basic Block (BB)**: Maximal sequence 
         of instructions with one entry/exit.
      2. **Dominance**: B1 dominates B2 because 
         every path from Entry to B2 must pass 
         through B1.
      3. **Natural Loop**: Formed by the {B2->B1} 
         back-edge.
      
      *Total Program Segment: 30 Bytes*
    |
  }
}

# --- ARCHITECTURAL CONTEXT ---
revelation_box: {
  near: bottom-center
  style: {
    fill: "#EDE9FE"
    stroke: "#8B5CF6"
    stroke-width: 2
    shadow: true
  }
  label: |md
    ## Control Flow Discontinuity Analysis
    In Bytecode-based VMs, high-level control structures (`while`, `for`, `if`) are erased. 
    The reconstruction relies on identifying:
    
    1. **Entry Points**: Targets of any jump instruction.
    2. **Exit Points**: Instructions immediately preceding a jump or a jump itself.
    
    This diagram maps the raw linear memory of `.text` to the non-linear execution graph 
    utilized by the JIT compiler and Optimizer.
  |
}

# --- CROSS-SECTIONAL CONNECTIONS ---
bytecode_listing -> cfg.B0: "Disassemble & Partition" {
  style: {
    stroke-dash: 3
    opacity: 0.5
    stroke: orange
  }
}