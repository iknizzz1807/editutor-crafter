vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Jump Target Validation Zones
| {near: top-center}
direction: right
classes: {
  valid-zone: {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      stroke-width: 2
    }
  }
  invalid-zone: {
    style: {
      fill: "#FFB6C1"
      stroke: "#DC143C"
      stroke-width: 2
      stroke-dash: 5
    }
  }
  instruction-marker: {
    shape: diamond
    style: {
      fill: "#4169E1"
      stroke: "#00008B"
      stroke-width: 2
    }
  }
  byte: {
    width: 60
    height: 40
    style: {
      font: mono
      font-size: 14
    }
  }
  header-byte: {
    style: {
      fill: "#DDA0DD"
      font-color: "#4B0082"
    }
  }
  operand-byte: {
    style: {
      fill: "#87CEEB"
      font-color: "#00008B"
    }
  }
}
bytecode_array: "Bytecode Array" {
  style: {
    fill: "#F5F5F5"
    stroke: "#333"
    stroke-width: 2
  }
  grid-columns: 8
  grid-gap: 2
  b0: "0x10\nLOAD_CONST" {class: [byte; header-byte]}
  b1: "0x00" {class: [byte; operand-byte]}
  b2: "0x05" {class: [byte; operand-byte]}
  b3: "0x20\nADD" {class: [byte; header-byte]}
  b4: "0x01\nJUMP" {class: [byte; header-byte]}
  b5: "0x00" {class: [byte; operand-byte]}
  b6: "0x03" {class: [byte; operand-byte]}
  b7: "0x00\nHALT" {class: [byte; header-byte]}
}
bytecode_array.b0 -> bytecode_array.b1
bytecode_array.b1 -> bytecode_array.b2
bytecode_array.b2 -> bytecode_array.b3
bytecode_array.b3 -> bytecode_array.b4
bytecode_array.b4 -> bytecode_array.b5
bytecode_array.b5 -> bytecode_array.b6
bytecode_array.b6 -> bytecode_array.b7
valid_targets: "Valid Jump Targets (instruction starts)" {
  style.fill: "#E8F5E9"
  valid_0: "✓ 0" {
    class: valid-zone
    tooltip: "LOAD_CONST instruction start"
  }
  valid_3: "✓ 3" {
    class: valid-zone
    tooltip: "ADD instruction start"
  }
  valid_4: "✓ 4" {
    class: valid-zone
    tooltip: "JUMP instruction start"
  }
  valid_7: "✓ 7" {
    class: valid-zone
    tooltip: "HALT instruction start"
  }
}
invalid_targets: "Invalid Jump Targets" {
  style.fill: "#FFF0F0"
  inv_neg: "✗ -1" {
    class: invalid-zone
    tooltip: "Negative: impossible with uint16_t"
  }
  inv_1: "✗ 1" {
    class: invalid-zone
    tooltip: "Operand byte of LOAD_CONST"
  }
  inv_2: "✗ 2" {
    class: invalid-zone
    tooltip: "Operand byte of LOAD_CONST"
  }
  inv_5: "✗ 5" {
    class: invalid-zone
    tooltip: "Operand byte of JUMP"
  }
  inv_6: "✗ 6" {
    class: invalid-zone
    tooltip: "Operand byte of JUMP"
  }
  inv_8: "✗ 8" {
    class: invalid-zone
    tooltip: "Past end of bytecode"
  }
  inv_999: "✗ 999" {
    class: invalid-zone
    tooltip: "Way past end of bytecode"
  }
}
bytecode_array -> valid_targets
valid_targets -> invalid_targets
legend: |md
  **Instruction Boundary Validation**
  - Green zones: Valid targets (instruction opcodes)
  - Red zones: Invalid targets (operand bytes, past end, negative)
  `validate_jump_target()` checks:
  - `target >= 0` (implicit with uint16_t)
  - `target < bytecode.count`
  Note: Full verification also checks instruction
  boundaries (not mid-operand). This requires
  bytecode verification pass or precomputed
  valid-offsets bitmap.
| {near: bottom-center}