vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |md
  # Absolute vs Relative Jump Offsets
  Addressing modes for bytecode branch targets and Instruction Pointer (IP) control.
| {near: top-center}

comparison: {
  grid-columns: 2
  grid-gap: 40

  absolute: {
    label: "Absolute Jump Mode (Direct Addressing)"
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }

    info: |md
      **Mechanism**
      The operand is the exact memory address.
      `JUMP 42` → Set IP to 42.
    |

    states: {
      direction: right
      before: "Before: IP = 5" {
        style.fill: white
        width: 150
      }
      instruction: "JUMP 42" {
        shape: hexagon
        style.fill: "#BBDEFB"
        style.stroke: "#1976D2"
        style.stroke-width: 2
        width: 120
      }
      after: "After: IP = 42" {
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        style.stroke-width: 2
        width: 150
      }
      before -> instruction: "exec"
      instruction -> after: "branch"
    }

    formula: "ip ← target" {
      shape: text
      style.font: mono
      style.font-size: 18
      style.bold: true
    }
  }

  relative: {
    label: "Relative Jump Mode (Offset Addressing)"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }

    info: |md
      **Mechanism**
      The operand is a signed displacement.
      `JUMP +10` → Set IP to (Current + 10).
    |

    states_rel: {
      direction: right
      before_rel: "Before: IP = 5" {
        style.fill: white
        width: 150
      }
      instruction_rel: "JUMP +10" {
        shape: hexagon
        style.fill: "#FFE0B2"
        style.stroke: "#F57C00"
        style.stroke-width: 2
        width: 120
      }
      after_rel: "After: IP = 15" {
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        style.stroke-width: 2
        width: 150
      }
      before_rel -> instruction_rel: "exec"
      instruction_rel -> after_rel: "branch"
    }

    formula_rel: "ip ← ip + offset" {
      shape: text
      style.font: mono
      style.font-size: 18
      style.bold: true
    }
  }
}

memory_view: {
  label: "Memory Layout and Instruction Encoding"
  style.fill: "#F0F0F0"
  style.stroke: "#B0B0B0"
  style.stroke-dash: 2
  
  abs_mem_container: {
    label: "Absolute Encoding (3 Bytes: Op, High, Low)"
    direction: right
    bytecode: {
      grid-rows: 1
      grid-gap: 0
      b0: "0x01\n(JMP)" {style.fill: "#D1C4E9"; width: 60}
      b1: "0x00\n(H)" {style.fill: "#BBDEFB"; width: 60}
      b2: "0x2A\n(42)" {style.fill: "#BBDEFB"; width: 60}
      b_gap: "..." {style.fill: white; style.stroke-dash: 5; width: 40}
      b42: "Target\nAddr 42" {style.fill: "#C8E6C9"; width: 100}
    }
    bytecode.b0 -> bytecode.b42: "Jump to 42" {
      style.stroke: "#2196F3"
      style.animated: true
    }
  }

  rel_mem_container: {
    label: "Relative Encoding (3 Bytes: Op, High, Low)"
    direction: right
    bytecode_rel: {
      grid-rows: 1
      grid-gap: 0
      br0: "0x01\n(JMPR)" {style.fill: "#D1C4E9"; width: 60}
      br1: "0x00\n(H)" {style.fill: "#FFE0B2"; width: 60}
      br2: "0x0A\n(10)" {style.fill: "#FFE0B2"; width: 60}
      br_gap: "..." {style.fill: white; style.stroke-dash: 5; width: 40}
      br15: "Target\nAddr 15" {style.fill: "#C8E6C9"; width: 100}
    }
    bytecode_rel.br0 -> bytecode_rel.br15: "Offset +10" {
      style.stroke: "#FF9800"
      style.animated: true
    }
  }
}

advantages_table: {
  direction: right
  grid-columns: 3
  grid-gap: 1
  style.fill: "#FFFFFF"

  # Headers
  h_aspect: "**Design Aspect**" { style.fill: "#37474F"; style.font-color: white }
  h_abs: "**Absolute Offsets**" { style.fill: "#1976D2"; style.font-color: white }
  h_rel: "**Relative Offsets**" { style.fill: "#F57C00"; style.font-color: white }

  # Row 1
  r1_a: "Debugging" { style.fill: "#F5F7F9" }
  r1_abs: "High readability: Disassembler shows actual destination address."
  r1_rel: "Requires mental math: `IP + offset` to find destination."

  # Row 2
  r2_a: "Code Relocation" { style.fill: "#F5F7F9" }
  r2_abs: "Brittle: Code must be patched if moved in memory."
  r2_rel: "Position-Independent Code (PIC): Jumps valid regardless of load address."

  # Row 3
  r3_a: "Control Flow" { style.fill: "#F5F7F9" }
  r3_abs: "Standard 16-bit range: 0 to 65535."
  r3_rel: "Signed logic: Allows backward jumps (loops) via negative offsets."

  # Row 4
  r4_a: "VM Simplicity" { style.fill: "#F5F7F9" }
  r4_abs: "Simpler Implementation: No signed arithmetic in IP update."
  r4_rel: "Moderate complexity: Handle Two's Complement sign extension."
}

summary: {
  style.fill: "#E1F5FE"
  style.stroke: "#01579B"
  style.stroke-dash: 4
  content: |md
    ### Implementation Choice: Absolute Offsets
    **Rationale for Bytecode VM:**
    1. **Visibility**: Easier to trace execution in custom debuggers.
    2. **Sign Simplicity**: Bytecode operands are treated as unsigned integers.
    3. **Alignment**: CPython (our reference) utilizes absolute offsets in `JUMP_ABSOLUTE` instructions.
    
    *Note: For production Shared Objects (.so / .dll), relative offsets are mandatory for PIC support.*
  |
}