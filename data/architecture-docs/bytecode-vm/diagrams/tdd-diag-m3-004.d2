direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # If-Else Compilation to Jumps
  **Technical Specification: Control Flow Lowering**
  `if (condition) { then } else { else }`
| {near: top-center}

# Source code representation
source: {
  shape: code
  label: |cpp
    // High-level Source
    if (condition) {
      // then-branch [Block A]
      do_then_work();
    } else {
      // else-branch [Block B]
      do_else_work();
    }
    // continue...
  |
  style: {
    fill: "#f0f4f8"
    stroke: "#627d98"
    font: mono
    font-size: 14
    stroke-width: 2
  }
}

# Bytecode layout (Main Memory Representation)
# Using a 3-column grid: [Offset | Instruction/Data | Logic Annotation]
bytecode_layout: {
  grid-columns: 3
  grid-gap: 0
  vertical-gap: 0
  style.stroke: "#4a5568"
  style.stroke-width: 1
  
  # Headers
  h_off: "Offset" { style: { bold: true; fill: "#e2e8f0"; font-size: 16 } }
  h_ins: "Instruction / Label" { style: { bold: true; fill: "#e2e8f0"; font-size: 16 } }
  h_log: "Logic Annotation" { style: { bold: true; fill: "#e2e8f0"; font-size: 16 } }

  # --- Condition block ---
  off_00: "0x00" { style.font: mono }
  cond_header: "Condition Test" {
    style: { fill: "#e8f4f8"; stroke: "#3182ce"; bold: true }
  }
  log_00: "Evaluate boolean expression" { style.font-color: "#718096" }

  off_01: "0x01" { style.font: mono }
  cond_code: "<condition code>" {
    style: { fill: "#bee3f8"; font: mono }
  }
  log_01: "Pushes result to stack (1 byte)" { style.font-color: "#718096" }

  # --- Conditional jump ---
  off_02: "0x02" { style.font: mono }
  jump_if_false: "JUMP_IF_FALSE [0x08]" {
    style: { fill: "#fed7d7"; stroke: "#c53030"; bold: true; font: mono }
  }
  log_02: "Pop stack; If FALSE, PC = 0x08" { 
    style: { font-color: "#c53030"; bold: true } 
  }

  # --- Then branch ---
  off_03: "0x03" { style.font: mono }
  then_header: "Then Branch (Block A)" {
    style: { fill: "#c6f6d5"; stroke: "#276749"; bold: true }
  }
  log_03: "Reached if Condition == TRUE" { style.font-color: "#276749" }

  off_04: "0x04" { style.font: mono }
  then_code: "<then-branch code>" {
    style: { fill: "#9ae6b4"; font: mono }
  }
  log_04: "Inlined for fast-path execution"

  # --- Jump past else ---
  off_07: "0x07" { style.font: mono }
  jump_past_else: "JUMP [0x0B]" {
    style: { fill: "#feebc8"; stroke: "#c05621"; bold: true; font: mono }
  }
  log_07: "Unconditional: Skip Else Block" {
    style: { font-color: "#c05621"; bold: true }
  }

  # --- Else branch ---
  off_08: "0x08" { style.font: mono }
  else_label: "else_start:" {
    style: { fill: "#d6bcfa"; font: mono; bold: true; stroke: "#6b46c1" }
  }
  log_08: "Target of Conditional Jump (0x02)"

  off_09: "0x09" { style.font: mono }
  else_code: "<else-branch code>" {
    style: { fill: "#d6bcfa"; font: mono }
  }
  log_09: "Reached if Condition == FALSE"

  # --- After both ---
  off_0B: "0x0B" { style.font: mono }
  after_label: "after_both:" {
    style: { fill: "#cbd5e0"; font: mono; bold: true; stroke: "#4a5568" }
  }
  log_0B: "Target of Unconditional Jump (0x07)"

  off_0C: "0x0C" { style.font: mono }
  continue_code: "<continue...>" {
    style: { fill: "#e2e8f0"; font: mono }
  }
  log_0C: "Resume linear control flow"
}

# Control flow connections
bytecode_layout.cond_header -> bytecode_layout.jump_if_false: "execute"

# Success path (Linear / Not-Taken)
bytecode_layout.jump_if_false -> bytecode_layout.then_header: "NOT TAKEN (True)" {
  style: { stroke: "#276749"; stroke-width: 4; font-color: "#276749"; bold: true }
}

# Jump path (Non-linear / Taken)
bytecode_layout.jump_if_false -> bytecode_layout.else_label: "TAKEN (False)" {
  style: {
    stroke: "#c53030"
    stroke-width: 4
    stroke-dash: 5
    font-color: "#c53030"
    bold: true
  }
}

bytecode_layout.then_code -> bytecode_layout.jump_past_else

# Skip Else path
bytecode_layout.jump_past_else -> bytecode_layout.after_label: "JUMP" {
  style: {
    stroke: "#c05621"
    stroke-width: 4
    stroke-dash: 2
    font-color: "#c05621"
    bold: true
  }
}

bytecode_layout.else_code -> bytecode_layout.after_label: "fall through" {
  style: { stroke: "#6b46c1"; stroke-width: 2 }
}

# Source to bytecode mapping
source -> bytecode_layout.cond_header: "compilation / lowering" {
  style: { stroke: "#627d98"; stroke-dash: 3 }
}

# Legend for implementation detail
legend: {
  near: bottom-center
  label: "Jump Sandwich Pattern Legend"
  style: { stroke: "#4a5568"; fill: "#f7fafc"; border-radius: 8 }

  grid-columns: 2
  grid-gap: 15
  
  l1: "" { shape: circle; width: 15; style.fill: "#fed7d7"; style.stroke: "#c53030" }
  t1: "Conditional Jump: Skips next block if stack-top is False."
  
  l2: "" { shape: circle; width: 15; style.fill: "#feebc8"; style.stroke: "#c05621" }
  t2: "Unconditional Jump: Prevents executing else-block after then-block completes."
  
  l3: "" { shape: circle; width: 15; style.fill: "#c6f6d5"; style.stroke: "#276749" }
  t3: "Branch A (Then): Placed immediately after jump to benefit from fall-through prediction."
  
  l4: "" { shape: circle; width: 15; style.fill: "#e9d8fd"; style.stroke: "#6b46c1" }
  t4: "Branch B (Else): Out-of-line block reached only via explicit redirection."
}

# Final structural metadata - Fixed 'near' placement to avoid grid-descendant error
implementation_notes: |md
  ### Bytecode Implementation Details
  - **Opcode Size:** 1 Byte (`0xE2` for JUMP_IF_FALSE).
  - **Operand Size:** 2 Bytes (Absolute 16-bit address or 8-bit signed offset).
  - **Branch Prediction:** The 'then' branch is the linear path; modern CPUs favor this via static prediction if no dynamic data exists.
  - **Stack Effect:** `JUMP_IF_FALSE` consumes the top-of-stack element.
  - **Memory Alignment:** Labels are logical; actual offsets depend on variable-length opcode encoding.
| { 
  near: top-right
  style: {
    stroke: "#4a5568"
    fill: "#edf2f7"
    font-size: 12
  }
}