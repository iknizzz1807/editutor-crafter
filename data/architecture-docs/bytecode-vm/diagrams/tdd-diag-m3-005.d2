vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # WHILE LOOP BYTECODE PATTERN
  ## Architectural Specification: Instruction Stream & Control Flow
  ---
  **Target VM:** Stack-based Virtual Machine (v1.0)
  **Pattern:** `WHILE (condition) { body }`
  **Mechanism:** Relative Offset Backward Branching
  **Instruction Width:** 32-bit (Fixed Length)
| {
  near: top-center
  shape: text
  style: {
    font-size: 18
    font-color: "#1A202C"
  }
}

# -----------------------------------------------------------------------------
# 1. Bytecode Memory Layout (Byte-Addressed, 4-Byte Alignment)
# -----------------------------------------------------------------------------
bytecode_layout: {
  label: "MEMORY LAYOUT: 32-BIT INSTRUCTION STREAM (sizeof=32 bytes)"
  style: {
    fill: "#F7FAFC"
    stroke: "#2D3748"
    stroke-width: 2
  }

  # --- Condition Evaluation Block ---
  # Bytes 0x00 to 0x0B
  cond_eval: {
    label: "Block: Condition Evaluation [0x00 - 0x0B]"
    style: {
      fill: "#F0FFF4"
      stroke: "#38A169"
      stroke-width: 2
    }
    
    0x00: "0x00: LOAD_LOCAL [0x00]" {
      tooltip: "Fetch 'n' from local slot 0; TOS++"
      style.fill: "#EBF8FF"
      # Field metadata for engineering detail
      info: "OPCODE: 0x15 | OPERAND: 0x00"
    }
    0x04: "0x04: LOAD_CONST [0x01]" {
      tooltip: "Fetch 0 from constant pool; TOS++"
      style.fill: "#EBF8FF"
      info: "OPCODE: 0x12 | OPERAND: 0x01"
    }
    0x08: "0x08: OP_GREATER_THAN" {
      tooltip: "Compare TOS[-1] > TOS[0]; push result"
      style.fill: "#BEE3F8"
      style.bold: true
      info: "OPCODE: 0x34"
    }
    
    0x00 -> 0x04 -> 0x08
  }

  # --- Branch Instruction ---
  # Bytes 0x0C to 0x0F
  cond_jump: "0x0C: JUMP_IF_FALSE [0x1D]" {
    shape: rectangle
    style: {
      fill: "#FFF5F5"
      stroke: "#E53E3E"
      stroke-width: 3
      double-border: true
    }
    tooltip: "Branching Logic: if TOS == 0, PC = 0x1D"
    info: "OPCODE: 0x99 | OPERAND: 0x1D"
  }

  # --- Loop Body Block ---
  # Bytes 0x10 to 0x19 (padded for alignment)
  body_block: {
    label: "Block: Loop Body [0x10 - 0x19]"
    style: {
      fill: "#E6FFFA"
      stroke: "#319795"
      stroke-width: 2
    }

    0x10: "0x10: LOAD_LOCAL [0x00]" { style.fill: "#EBF8FF" }
    0x14: "0x14: LOAD_CONST [0x02]" { style.fill: "#EBF8FF" } # val: 1
    0x18: "0x18: OP_SUBTRACT" { style.fill: "#BEE3F8" }
    0x19: "0x1C: STORE_LOCAL [0x00]" { 
      style.fill: "#E2E8F0"
      label: "0x1C: STORE_LOCAL [0x00]"
    }
    
    0x10 -> 0x14 -> 0x18 -> 0x19
  }

  # --- Jump Back to Start ---
  loop_back: "0x20: JUMP_ABSOLUTE [0x00]" {
    shape: rectangle
    style: {
      fill: "#FEFCBF"
      stroke: "#D69E2E"
      stroke-width: 4
      shadow: true
    }
    info: "OPCODE: 0xA7 | OPERAND: 0x00"
  }

  # --- Termination ---
  exit_halt: "0x24: OP_HALT" {
    style: {
      fill: "#FAF5FF"
      stroke: "#805AD5"
      stroke-width: 2
    }
    info: "OPCODE: 0xFF"
  }

  # Instruction Sequencing
  cond_eval -> cond_jump
  cond_jump -> body_block: "TOS == 1 (True)" {
    style: {
      stroke: "#2F855A"
      stroke-width: 2
    }
  }
  body_block -> loop_back
  loop_back -> cond_eval: "BACK-EDGE" {
    style: {
      stroke: "#D69E2E"
      stroke-width: 4
      animated: true
    }
  }
  cond_jump -> exit_halt: "TOS == 0 (False)" {
    style: {
      stroke: "#C53030"
      stroke-dash: 5
    }
  }
}

# -----------------------------------------------------------------------------
# 2. Control Flow Graph (CFG)
# -----------------------------------------------------------------------------
cfg: {
  label: "LOGICAL CONTROL FLOW GRAPH (CFG)"
  style.fill: "#EDF2F7"

  entry: ● {
    label: "Entry"
    style.fill: "#2D3748"
  }

  decision: "WHILE\nn > 0" {
    shape: diamond
    style: {
      fill: "#FED7D7"
      stroke: "#C53030"
      stroke-width: 2
    }
  }

  loop_body: "n = n - 1" {
    shape: rectangle
    style: {
      fill: "#BEE3F8"
      stroke: "#2B6CB0"
      stroke-width: 2
      border-radius: 4
    }
  }

  end: "HALT" {
    shape: circle
    style: {
      fill: "#E9D8FD"
      stroke: "#6B46C1"
      double-border: true
    }
  }

  entry -> decision
  decision -> loop_body: "True" {
    style: {
      stroke: "#38A169"
      stroke-width: 3
    }
  }
  decision -> end: "False" {
    style: {
      stroke: "#E53E3E"
      stroke-dash: 5
    }
  }
  loop_body -> decision: "Loop" {
    style: {
      stroke: "#B7791F"
      stroke-width: 4
      animated: true
    }
  }
}

# -----------------------------------------------------------------------------
# 3. Technical Implementation Notes
# -----------------------------------------------------------------------------
notes: |md
  ### VM Execution Mechanics
  
  **1. Condition Pipeline:**
  The `cond_eval` block performs a destructive stack comparison. `OP_GREATER_THAN` consumes two stack elements and pushes a boolean integer (0 or 1).
  
  **2. Conditional Branching:**
  `JUMP_IF_FALSE` (0x0C) is a relative forward jump. If the condition is not met, the Instruction Pointer (IP) is incremented by the operand value to skip the loop body.
  
  **3. Reification of the Loop:**
  The `JUMP_ABSOLUTE` (0x20) instruction at the end of the body creates the cycle by explicitly setting the IP back to the header address (`0x00`).
| {
  near: bottom-left
  style: {
    fill: "#FFFBEB"
    stroke: "#D69E2E"
    font-size: 12
  }
}

# -----------------------------------------------------------------------------
# 4. Logical Mapping
# -----------------------------------------------------------------------------
bytecode_layout.cond_jump -> cfg.decision: "Logical Mapping" {
  style: {
    stroke: "#718096"
    stroke-dash: 10
    opacity: 0.4
  }
}

bytecode_layout.loop_back -> cfg.loop_body: "Back-edge Control" {
  style: {
    stroke: "#718096"
    stroke-dash: 10
    opacity: 0.4
  }
}

# -----------------------------------------------------------------------------
# 5. Legend
# -----------------------------------------------------------------------------
legend: {
  near: bottom-right
  
  stack_op: "Data/Stack Op" {
    style.fill: "#EBF8FF"
  }
  alu_op: "ALU / Logic" {
    style.fill: "#BEE3F8"
  }
  control_op: "Control Flow" {
    style.fill: "#FFF5F5"
    style.double-border: true
  }
  jump_op: "Backward Jump" {
    style.fill: "#FEFCBF"
  }
}