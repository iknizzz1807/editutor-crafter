layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "TECHNICAL SPECIFICATION: JUMP VALIDATION STATE MACHINE (VM-M3-007)" {
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

direction: right

# -----------------------------------------------------------------------------
# DEFINITIONS: States and Invariants
# -----------------------------------------------------------------------------
states: {
  READ_OPERAND: {
    shape: circle
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 4
    }
    label: "STEP 1: FETCH_OPERAND\n\n[Invariant]\nIP points to OP_JUMP + 1\nOperand: uint16_t (Big Endian)"
  }

  VALIDATE_BOUNDS: {
    shape: diamond
    style: {
      fill: "#FFF3CD"
      stroke: "#856404"
      stroke-width: 4
    }
    label: "STEP 2: BOUNDS_CHECK\n\n[Guard]\ntarget < bytecode.count\n(Prevent Segment Fault)"
  }

  SET_IP: {
    shape: circle
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
      stroke-width: 4
    }
    label: "STEP 3: COMMIT_IP\n\n[Action]\nvm->ip = target\n[Insn Ptr updated]"
  }

  ERROR: {
    shape: circle
    style: {
      fill: "#F8D7DA"
      stroke: "#721C24"
      stroke-width: 4
      font-color: "#721C24"
    }
    label: "HALT: RUNTIME_ERROR\n\n[State]\nVM_INTERPRET_RUNTIME_ERROR\nReport OOB Jump"
  }

  CONTINUE: {
    shape: circle
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
      stroke-width: 2
    }
    label: "FETCH_NEXT_OPCODE"
  }
}

initial: "" {
  shape: circle
  style: {
    fill: "#333333"
    stroke: "#333333"
    stroke-width: 2
  }
  width: 20
  height: 20
}

terminal: "" {
  shape: circle
  style: {
    fill: "#333333"
    stroke: "#333333"
    stroke-width: 2
    double-border: true
  }
  width: 20
  height: 20
}

# -----------------------------------------------------------------------------
# TRANSITIONS: Trigger + Guard + Action
# -----------------------------------------------------------------------------
initial -> states.READ_OPERAND: "DISPATCH_JUMP" {
  style: {
    stroke-width: 2
    stroke: "#333333"
  }
}

states.READ_OPERAND -> states.VALIDATE_BOUNDS: "Read HI/LO bytes" {
  style: {
    stroke-width: 2
    stroke: "#2E86AB"
  }
}

states.VALIDATE_BOUNDS -> states.SET_IP: "target < count" {
  style: {
    stroke-width: 4
    stroke: "#155724"
    animated: true
  }
}

states.VALIDATE_BOUNDS -> states.ERROR: "target >= count" {
  style: {
    stroke-width: 4
    stroke: "#721C24"
    stroke-dash: 4
  }
}

states.SET_IP -> states.CONTINUE: "JMP_SUCCESS" {
  style: {
    stroke-width: 2
    stroke: "#155724"
  }
}

states.CONTINUE -> terminal: "NEXT_CYCLE" {
  style: {
    stroke-width: 2
    stroke: "#333333"
  }
}

states.ERROR -> terminal: "VM_HALT" {
  style: {
    stroke-width: 2
    stroke: "#721C24"
  }
}

# -----------------------------------------------------------------------------
# TECHNICAL SPECIFICATIONS (Sidecars)
# -----------------------------------------------------------------------------

operand_format: |'md
### Instruction Layout
| Offset | Field | Description | Size |
| :--- | :--- | :--- | :--- |
| **0x00** | `OP_JUMP` | Opcode (8-bit) | 1B |
| **0x01** | `TARGET_HI` | High bits (8-bit) | 1B |
| **0x02** | `TARGET_LO` | Low bits (8-bit) | 1B |

**Bitwise Reconstruction:**
c
uint16_t target = (HI << 8) | LO;

'|

operand_format.near: center-right
operand_format.style: {
  fill: "#E8F4FD"
  stroke: "#2E86AB"
  border-radius: 8
  font: mono
  font-size: 11
}

validation_logic: |'md
### Safety Invariants
1. **Range Check**: Ensure `0 <= target < size`.
2. **Alignment**: Target must be start of opcode.
3. **VM Context**: Error must log current IP.

c
if (target >= chunk->count) {
    runtimeError("Jump OOB: %d", target);
    return INTERPRET_RUNTIME_ERROR;
}

'|

validation_logic.near: center-left
validation_logic.style: {
  fill: "#FFF3CD"
  stroke: "#856404"
  border-radius: 8
  font: mono
  font-size: 11
}

error_reporting: |'md
### Error State
**Diagnostic Output:**
`[line 12] Runtime Error: Jump target 0x%04X exceeds bytecode capacity 0x%04X.`

**Memory State:**
- IP is discarded.
- Stack is preserved for debugger trace.
'|

error_reporting.near: bottom-right
error_reporting.style: {
  fill: "#F8D7DA"
  stroke: "#721C24"
  border-radius: 8
  font: mono
  font-size: 11
}

# -----------------------------------------------------------------------------
# ARCHITECTURAL LEGEND
# -----------------------------------------------------------------------------
legend: |'md
### Engineering Legend
- **Blue Node**: Memory I/O Phase (Bus access)
- **Yellow Diamond**: ALU / Logic Decision
- **Green Node**: State Commitment (Registers updated)
- **Red Node**: Terminal Fault State (Immediate exit)
- **Bold Arrow**: Critical Path (Successful jump)
- **Dashed Arrow**: Illegal/Error Transition
'|

legend.near: bottom-center
legend.style: {
  fill: "#F8F9FA"
  stroke: "#DEE2E6"
  border-radius: 8
  stroke-width: 2
}

# ILLEGAL TRANSITION ANNOTATION
illegal_transition: (states.ERROR -> states.SET_IP) {
  label: "ILLEGAL"
  style: {
    stroke: red
    stroke-dash: 2
    opacity: 0.5
  }
}