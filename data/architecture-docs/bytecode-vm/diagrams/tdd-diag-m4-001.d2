direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# --- STYLES & CLASSES ---
classes: {
  memory_header: {
    style: {
      fill: "#E4DBFE" # Purple
      stroke: "#6A5ACD"
      stroke-width: 2
      bold: true
    }
  }
  memory_data: {
    style: {
      fill: "#C7F1FF" # Blue
      stroke: "#4682B4"
      stroke-width: 1
    }
  }
  memory_pointer: {
    style: {
      fill: "#FFE4B5" # Orange
      stroke: "#D2691E"
      stroke-width: 2
    }
  }
  memory_padding: {
    style: {
      fill: "#D3D3D3" # Gray
      stroke-dash: 3
    }
  }
}

# --- DIAGRAM TITLE ---
title: {
  shape: text
  near: top-center
  label: ||md
    # Virtual Machine: Call Frame & Memory Layout
    **Ref:** Technical Design Specification v4.1
    *Engineer Notes: Layout optimized for 64-bit alignment.*
  ||
}

# --- MEMORY LAYOUT: CALL FRAME ---
call_frame_layout: {
  label: "CallFrame Memory Layout (sizeof=64B)"
  
  grid-rows: 9
  grid-columns: 3
  grid-gap: 0

  # Header Row
  h1: "Offset" { shape: text; style.bold: true; style.underline: true }
  h2: "Field Descriptor" { shape: text; style.bold: true; style.underline: true }
  h3: "Size" { shape: text; style.bold: true; style.underline: true }

  # Byte Offsets (Left) | Actual Data Fields (Center) | Field Sizes (Right)
  
  o00: "0x00" { shape: text }
  ip: "Instruction Pointer (uint8_t* ip)" { class: memory_pointer }
  s1: "8 Bytes" { shape: text }

  o08: "0x08" { shape: text }
  stack_base: "Stack Base (Value* slots)" { class: memory_pointer }
  s2: "8 Bytes" { shape: text }

  o16: "0x10" { shape: text }
  closure: "ObjClosure* closure" { class: memory_pointer }
  s3: "8 Bytes" { shape: text }

  o24: "0x18" { shape: text }
  return_addr: "Return Address (uint64_t)" { class: memory_data }
  s4: "8 Bytes" { shape: text }

  o32: "0x20" { shape: text }
  locals_cnt: "Locals Count (uint32_t)" { class: memory_data }
  s5: "4 Bytes" { shape: text }

  o36: "0x24" { shape: text }
  padding: "Padding/Reserved" { class: memory_padding }
  s6: "4 Bytes" { shape: text }

  o40: "0x28" { shape: text }
  extra1: "Frame Metadata" { class: memory_data }
  s7: "8 Bytes" { shape: text }

  o48: "0x30" { shape: text }
  extra2: "End of Frame Marker" { class: memory_header }
  s8: "8 Bytes" { shape: text }
}

# Boundary indicator placed manually since grid-span is not supported
cache_line_boundary: {
  label: "--- CACHE LINE BOUNDARY (64B / 0x40) ---"
  shape: text
  style: {
    font-color: red
    bold: true
    stroke-dash: 5
  }
}

# --- OPERAND STACK ---
operand_stack: {
  label: "Operand Stack (LIFO)"
  
  stack_top: "Stack Top (vm.stackTop)" {
    shape: circle
    style.fill: "#ACE1AF" # Green for Free/Pointer
  }
  
  slots: {
    grid-columns: 1
    grid-gap: 2
    
    slot_n: "Slot [n]: Result of OP_ADD" {
      style: {
        fill: "#FFB6C1" # Red-highlight for change
        bold: true
        stroke: red
        stroke-width: 3
      }
    }
    slot_2: "Slot [2]: Local Var B" { class: memory_data }
    slot_1: "Slot [1]: Local Var A" { class: memory_data }
    slot_0: "Slot [0]: Initial Constant" { class: memory_data }
  }
  
  stack_top -> slots.slot_n: "Push / Pop" { style.animated: true }
}

# --- INSTRUCTION SET REFERENCE ---
instruction_ref: {
  shape: rectangle
  style.fill: "#F5F5F5"
  label: ||md
    ### Instruction Format Reference
    | Opcode | Mnemonic | Operands | Description |
    | :--- | :--- | :--- | :--- |
    | `0x00` | **HALT** | None | Terminate execution |
    | `0x10` | **LOAD_CONST** | `uint16 idx` | Push constant pool[idx] to stack |
    | `0x20` | **ADD** | None | Pop A, Pop B, Push A+B |
    | `0x30` | **JUMP** | `int16 off` | Add offset to IP |
    | `0x40` | **CALL** | `uint8 args` | Setup new CallFrame |
    | `0x41` | **RETURN** | None | Tear down frame, push result |
  ||
}

# --- COMPONENT RELATIONSHIPS ---
vm_core: {
  label: "VM Runtime State"
  style.stroke-dash: 5
  
  chunk: "Bytecode Chunk" {
    shape: cylinder
    style.fill: "#E4DBFE"
  }
  
  interpreter: "Interpreter Loop" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
}

# Logical Flow Connections
vm_core.interpreter -> call_frame_layout: "Reads Frame State"
call_frame_layout.ip -> vm_core.chunk: "Points to offset" {
  style.stroke: orange
  style.stroke-width: 2
}
vm_core.interpreter -> operand_stack: "Manipulates values"
operand_stack.slots -> instruction_ref: "Applied by Opcodes"

# Footer Note
footer: {
  shape: text
  near: bottom-right
  label: ||md
    *Alignment Warning:*
    Frame metadata at `0x28` must remain 8-byte aligned to prevent 
    bus errors on strict ARM/RISC targets. Padding inserted at `0x24`.
  ||
}