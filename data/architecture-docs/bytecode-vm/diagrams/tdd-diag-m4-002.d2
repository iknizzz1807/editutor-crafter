layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

classes: {
  header: {
    style: {
      fill: "#6e40aa"
      stroke: "#4a2b70"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  bytecode_op: {
    style: {
      fill: "#b5aff6"
      stroke: "#6e40aa"
      stroke-width: 1
    }
  }
  stack_data: {
    style: {
      fill: "#c7f1ff"
      stroke: "#88dcf7"
      stroke-width: 1
    }
  }
  pointer_ref: {
    style: {
      fill: "#ffcc33"
      stroke: "#e4a000"
      stroke-width: 3
      bold: true
    }
  }
  free_space: {
    style: {
      fill: "#ace1af"
      stroke: "#76b07a"
      stroke-dash: 3
    }
  }
  padding_cell: {
    style: {
      fill: "#dee1eb"
      stroke: "#adb5bd"
    }
  }
  changed: {
    style: {
      stroke: "#ef4444"
      stroke-width: 4
      bold: true
    }
  }
}

title: |md
  # Bytecode VM: Frame Stack Growth Pattern
  **Engineering Specification: Memory Layout, Call Semantics, and Operand Stack Mechanics**
| {
  near: top-center
  shape: text
}

# --- 1. DETAILED MEMORY LAYOUT ---
# Intel Manual Style: Byte offsets on left, sizes on right
vm_memory: "System Memory Map (Address Space 0x0000 - 0xFFFF)" {
  direction: right
  
  # Address Rulers
  offsets: {
    shape: text
    label: |md
      **Offset**
      0x0000
      0x0400
      0x0800
      0x2000
      0x4000
      0x8000
      0xFFFF
    |
  }

  layout: {
    global_header: "VM Global Header" {
      class: header
      tooltip: "u32 version, u32 entry, u32 flags"
      style.double-border: true
    }
    
    code_segment: "Instruction Segment (RX)" {
      class: bytecode_op
      grid-columns: 1
      op0: "0x0400: OP_LOAD_CONST [16-bit]"
      op1: "0x0403: OP_CALL [8-bit argc]"
      op2: "0x0405: OP_RETURN"
    }

    const_pool: "Constant Pool (RO)" {
      class: stack_data
      style.fill-pattern: dots
      c0: "0x0800: Float64 (3.1415)"
      c1: "0x0808: String ('main')"
    }

    operand_stack: "Operand Stack (RW)" {
      class: stack_data
      v0: "0x2000: Value[0]"
      v1: "0x2008: Value[1]"
      pad: "..." { class: padding_cell }
    }

    call_stack: "Call Frame Stack" {
      class: header
      frame_main: "0x4000: Frame(main)"
      frame_calc: "0x4020: Frame(calc)"
      style.fill-pattern: lines
    }

    heap: "Heap / Unallocated" {
      class: free_space
      label: "Dynamic Allocation Area"
    }
  }

  offsets -> layout.global_header: {
    style: {
      stroke-dash: 5
      stroke-width: 1
    }
  }
}

# --- 2. ARCHITECTURE / TYPE DEFINITIONS ---
# sizeof annotations for engineer implementation
vm_structs: "Core Engine Structures" {
  CallFrame: {
    shape: class
    class: header
    label: "struct CallFrame (sizeof=32B)"
    "ip: *uint8_t": "Instruction Pointer (Return Address)"
    "slots: *Value": "Base of locals in Operand Stack"
    "closure: *ObjClosure": "Function metadata/upvalues"
  }

  VirtualMachine: {
    shape: class
    label: "struct VM (sizeof=4096B)"
    "frames: CallFrame[64]": "Fixed depth call stack"
    "frameCount: int32_t": "Current frame depth"
    "stack: Value[256]": "Operand stack (Value = 8-byte union)"
    "stackTop: *Value": "Next free slot pointer"
    
    "push(Value val)": "void"
    "pop()": "Value"
    "callValue(Closure*, int argc)": "bool"
  }
  
  VirtualMachine -> CallFrame: "owns fixed stack" {source-arrowhead: 1; target-arrowhead: 64}
}

# --- 3. ALGORITHM STATE: OP_CALL TRANSITION ---
# Illustrates the movement of pointers during a call dispatch
call_logic: "Algorithm State: Function Call Dispatch" {
  direction: right

  before: "STEP N: Pre-Call State" {
    stack_view: {
      grid-rows: 5
      arg1: "Arg 1 (Idx 0)" { class: stack_data }
      arg2: "Arg 2 (Idx 1)" { class: stack_data }
      sp_ptr: "SP ->" { class: pointer_ref }
      free1: "[Empty]" { class: free_space }
      free2: "[Empty]" { class: free_space }
    }
    frame_view: {
      grid-rows: 2
      parent: "Frame: Parent" { class: header }
      fp_ptr: "FP ->" { class: pointer_ref }
    }
    bytecode: "IP -> [OP_CALL 2]" { class: bytecode_op }
  }

  after: "STEP N+1: Post-Call State" {
    stack_view: {
      grid-rows: 5
      arg1: "Arg 1 (Local 0)" { class: [stack_data; changed] }
      arg2: "Arg 2 (Local 1)" { class: [stack_data; changed] }
      locals: "Local 2 (Uninit)" { class: [free_space; changed] }
      sp_ptr: "SP ->" { class: pointer_ref }
      free: "[Empty]" { class: free_space }
    }
    frame_view: {
      grid-rows: 3
      parent: "Frame: Parent" { class: header }
      child: "Frame: Child" { class: [header; changed] }
      fp_ptr: "FP ->" { class: pointer_ref }
    }
    bytecode: "IP -> [Fn Entry]" { class: [bytecode_op; changed] }
  }

  before -> after: "dispatch(OP_CALL)" {
    style: {
      stroke-width: 5
      animated: true
      stroke: "#6e40aa"
    }
  }
}

# --- 4. SEQUENCE DIAGRAM: CALL/RETURN LIFECYCLE ---
runtime_flow: "Execution Pipeline" {
  shape: sequence_diagram
  
  engine: "VM_Engine\n(Interpret Loop)"
  stack: "Operand_Stack\n(Value[])"
  frames: "Frame_Stack\n(CallFrame[])"

  engine -> stack: push(arg1)
  engine -> stack: push(arg2)
  engine -> engine: fetch(OP_CALL)
  
  engine -> frames: push_frame(closure, argc)
  frames."IP saved to Frame\nSlots = stackTop - argc"
  
  engine -> engine: set_ip(closure.entry)
  
  engine -> engine: execute_function()
  
  engine -> stack: push(result)
  engine -> engine: fetch(OP_RETURN)
  
  engine -> frames: pop_frame()
  frames."Restore previous IP"
  
  engine -> stack: "reset_slots()\npush(result)"
}

# --- 5. TECHNICAL LEGEND ---
legend: {
  near: bottom-right
  
  l1: "Call Frames / Stack Headers" {
    class: header
  }
  l2: "Operands / Values (u64)" {
    class: stack_data
  }
  l3: "Active Pointers (IP/SP/FP)" {
    class: pointer_ref
  }
  l4: "Unallocated / Padding" {
    class: padding_cell
  }
  l5: "State Change (Red Border)" {
    class: changed
  }
  
  notes: {
    shape: text
    label: |md
      ### Implementation Notes
      - **Operand Stack** grows upwards (to higher addresses).
      - **Call Stack** is a fixed-size array of pointers into the operand stack.
      - **Page Boundaries**: Bold lines every 4096 bytes.
      - **Cache Alignment**: Structs are padded to 64 bytes.
    |
  }
}

# Global structural connections
vm_structs.VirtualMachine -> vm_memory.layout.operand_stack: "manages" { style.stroke-dash: 5 }
vm_memory.layout.call_stack -> runtime_flow: "visualized in" { style.stroke-dash: 5 }