vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    frame0: "#E8D5B7"
    frame1: "#B7D5E8"
    frame2: "#D5E8B7"
    highlight: "#FF6B6B"
    text: "#2C3E50"
    grid: "#BDC3C7"
    index: "#7F8C8D"
  }
}
title: |md
  # Local Variable Indexing Within Frame
  Frame-relative slot access via `locals_base` offset
| {near: top-center}
direction: right
locals_array: {
  label: "VM.locals[LOCALS_MAX]"
  style.fill: white
  style.stroke: ${colors.grid}
  style.stroke-width: 2
  grid-columns: 1
  grid-rows: 8
  grid-gap: 0
  slot0: {
    label: "0"
    style.fill: ${colors.frame0}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
  slot1: {
    label: "1"
    style.fill: ${colors.frame0}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
  slot2: {
    label: "2"
    style.fill: ${colors.frame0}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
  slot3: {
    label: "3"
    style.fill: ${colors.frame1}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
  slot4: {
    label: "4"
    style.fill: ${colors.frame1}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
  slot5: {
    label: "5"
    style.fill: ${colors.frame1}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
  slot6: {
    label: "6"
    style.fill: ${colors.frame2}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
  slot7: {
    label: "7"
    style.fill: ${colors.frame2}
    style.stroke: ${colors.grid}
    width: 80
    height: 40
  }
}
frame_annotations: {
  grid-columns: 1
  grid-rows: 8
  grid-gap: 0
  width: 1
  f0a: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
  f0b: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
  f0c: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
  f1a: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
  f1b: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
  f1c: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
  f2a: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
  f2b: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    width: 1
    height: 40
  }
}
frame0_brace: {
  shape: text
  label: "Frame 0\nlocals_base=0\nlocals_count=3"
  style.fill: ${colors.frame0}
  style.stroke: ${colors.text}
  style.font-color: ${colors.text}
  width: 120
}
frame1_brace: {
  shape: text
  label: "Frame 1\nlocals_base=3\nlocals_count=3"
  style.fill: ${colors.frame1}
  style.stroke: ${colors.text}
  style.font-color: ${colors.text}
  width: 120
}
frame2_brace: {
  shape: text
  label: "Frame 2\nlocals_base=6\nlocals_count=2"
  style.fill: ${colors.frame2}
  style.stroke: ${colors.text}
  style.font-color: ${colors.text}
  width: 120
}
frame0_brace -- locals_array.slot0: {style.stroke: transparent}
frame1_brace -- locals_array.slot3: {style.stroke: transparent}
frame2_brace -- locals_array.slot6: {style.stroke: transparent}
access_formula: {
  label: |md
    ## Address Formula
    
    vm->locals[frame->locals_base + slot]
    
    **Example: Frame 1, slot 1**
    `locals[3 + 1] = locals[4]`
  |
  style.fill: "#F8F9FA"
  style.stroke: ${colors.grid}
  style.font: mono
  width: 250
}
legend: {
  grid-columns: 3
  grid-gap: 10
  leg0: {
    label: "Frame 0"
    style.fill: ${colors.frame0}
    style.stroke: ${colors.grid}
    width: 80
    height: 30
  }
  leg1: {
    label: "Frame 1"
    style.fill: ${colors.frame1}
    style.stroke: ${colors.grid}
    width: 80
    height: 30
  }
  leg2: {
    label: "Frame 2"
    style.fill: ${colors.frame2}
    style.stroke: ${colors.grid}
    width: 80
    height: 30
  }
}
locals_array -- access_formula
legend -- locals_array