vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: |'md
    # CALL Instruction Execution Trace
    Step-by-step state machine for function invocation
  '|
  near: top-center
}

direction: right

classes: {
  step: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      font: mono
    }
  }
  state: {
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
  arrow: {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
      animated: true
    }
  }
}

Step_0: "STEP 0: Initial State" {
  class: step
  before_call: {
    label: |'md
      **Before CALL executes:**
      
      IP = 6 (pointing at CALL opcode)
      Stack: [3.0, 5.0, 7.0]
                       ↑ stack_top = 3
      Frames: [main]
      locals_top = 0
    '|
    class: state
  }
}

Step_0 -> Step_1: "Fetch CALL\nopcode" {class: arrow}

Step_1: "STEP 1: Read Operands" {
  class: step
  after_fetch: {
    label: |'md
      **After reading 3 operands (6 bytes):**
      
      IP = 13 (past CALL instruction)
      Operands read:
        arg_count    = 3
        entry_point  = 50
        locals_count = 5
      Stack: [3.0, 5.0, 7.0] (unchanged)
    '|
    class: state
  }
  operand_encoding: {
    label: |'md
      | Offset | Field | Value |
      |--------|-------|-------|
      | 6-8    | arg_count | 0x0003 |
      | 9-11   | entry_point | 0x0032 |
      | 12-14  | locals_count | 0x0005 |
    '|
  }
}

Step_1 -> Step_2: "Validate\nbounds" {class: arrow}

Step_2: "STEP 2: Validation Phase" {
  class: step
  validation: {
    label: |'md
      **Four validation checks:**
      
      ✓ frames.count (1) < FRAMES_MAX (256)
      ✓ locals_top (0) + 5 <= LOCALS_MAX (65536)
      ✓ arg_count (3) <= locals_count (5)
      ✓ entry_point (50) < bytecode.count
      
      All pass → continue
      Any fail → INTERPRET_RUNTIME_ERROR
    '|
    class: state
  }
}

Step_2 -> Step_3: "Save return\naddress" {class: arrow}

Step_3: "STEP 3: Save Return Address" {
  class: step
  save_ip: {
    label: |'md
      **Capture where to resume:**
      
      return_address = IP = 13
      (Points to instruction AFTER CALL)
    '|
    class: state
  }
}

Step_3 -> Step_4: "Pop args\nin reverse" {class: arrow}

Step_4: "STEP 4: Pop Arguments (Reverse Order)" {
  class: step
  pop_args: {
    label: |'md
      **CRITICAL: Pop right-to-left:**
      
      args[2] = vm_pop() → 7.0
      args[1] = vm_pop() → 5.0
      args[0] = vm_pop() → 3.0
      Stack: [] (empty)
      args = [3.0, 5.0, 7.0]
      
      Result: args array has left-to-right order!
    '|
    class: state
  }
  stack_diagram: {
    before: "Before pop:" {
      shape: rectangle
      label: |'md
        Stack: [3, 5, 7]
                       ↑ top
      '|
    }
    after: "After pop:" {
      shape: rectangle
      label: |'md
        Stack: []
        args[0]=3, args[1]=5, args[2]=7
      '|
    }
    before -> after: "pop ×3 (reverse)"
  }
}

Step_4 -> Step_5: "Push new\nframe" {class: arrow}

Step_5: "STEP 5: Push Call Frame" {
  class: step
  push_frame: {
    label: |'md
      **Create frame at top of stack:**
      
      frame = frame_stack_push()
      frame->chunk = vm->chunk
      frame->return_address = 13
      frame->locals_base = 0
      frame->locals_count = 5
      frames.count = 2 (main + new)
    '|
    class: state
  }
}

Step_5 -> Step_6: "Initialize\nlocals" {class: arrow}

Step_6: "STEP 6: Initialize Local Variables" {
  class: step
  init_locals: {
    label: |'md
      **Copy args + zero-fill rest:**
      
      for i = 0 to 4:
        if i < 3:  // i < arg_count
          locals[0+i] = args[i]
        else:
          locals[0+i] = 0.0
      Result:
        locals[0] = 3.0  (arg0)
        locals[1] = 5.0  (arg1)
        locals[2] = 7.0  (arg2)
        locals[3] = 0.0  (default)
        locals[4] = 0.0  (default)
      locals_top = 5
    '|
    class: state
  }
}

Step_6 -> Step_7: "Jump to\nentry" {class: arrow}

Step_7: "STEP 7: Transfer Control" {
  class: step
  final_state: {
    label: |'md
      **Final state after CALL:**
      
      IP = 50 (entry_point)
      Stack: []
      Frames: [main, foo]
      locals: [3.0, 5.0, 7.0, 0.0, 0.0]
      locals_top = 5
      Ready to execute function body!
    '|
    class: state
  }
}

memory_layout: "Memory Layout After CALL" {
  style.fill: "#F5F5F5"
  frames_array: {
    label: |'md
      **FrameStack (frames):**
      
      ┌─────────────────────────────────────────┐
      │ [0] main                                 │
      │     return_address = 0                   │
      │     locals_base = 0                      │
      │     locals_count = 0                     │
      ├─────────────────────────────────────────┤
      │ [1] foo ← TOP                            │
      │     return_address = 13                  │
      │     locals_base = 0                      │
      │     locals_count = 5                     │
      └─────────────────────────────────────────┘
      count = 2
    '|
  }
  locals_array: {
    label: |'md
      **Locals Array:**
      
      ┌────┬────┬────┬────┬────┐
      │ 3.0│ 5.0│ 7.0│ 0.0│ 0.0│
      └────┴────┴────┴────┴────┘
        [0]  [1]  [2]  [3]  [4]
        ↑                  ↑
        locals_base    locals_top
      
      foo.local_0 = locals[0] = 3.0
      foo.local_1 = locals[1] = 5.0
      foo.local_2 = locals[2] = 7.0
      foo.local_3 = locals[3] = 0.0
      foo.local_4 = locals[4] = 0.0
    '|
  }
}

legend: {
  shape: text
  label: |'md
    ### Key Invariants
    1. **Return address** saved BEFORE popping args
    2. **Args popped reverse** → map left-to-right to locals
    3. **Locals initialized**: args first, then 0.0 defaults
    4. **locals_top updated** after initialization
    5. **IP set last** to entry_point
  '|
  near: bottom-center
}