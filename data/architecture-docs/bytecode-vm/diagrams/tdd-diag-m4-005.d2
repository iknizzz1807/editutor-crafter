vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5B7"
    data: "#B8D4E8"
    pointer: "#A8D8B7"
    changed: "#FF6B6B"
    text: "#2C3E50"
    border: "#7F8C8D"
  }
}
classes: {
  frame_box: {
    style: {
      fill: "${colors.data}"
      stroke: "${colors.border}"
      stroke-width: 2
      border-radius: 6
    }
  }
  value_slot: {
    style: {
      fill: "${colors.header}"
      stroke: "${colors.border}"
      stroke-width: 1
    }
  }
  changed_slot: {
    style: {
      fill: "${colors.changed}"
      stroke: "${colors.border}"
      stroke-width: 2
      font-color: white
    }
  }
  pointer_arrow: {
    style: {
      stroke: "${colors.pointer}"
      stroke-width: 2
      fill: "${colors.pointer}"
    }
  }
  step_label: {
    style: {
      font-size: 14
      bold: true
      fill: "${colors.text}"
    }
  }
}
title: |md
  # RETURN Instruction Execution Trace
| {near: top-center}
direction: right
steps: {
  step1: {
    label: |md
      ## Step 1: Pop Return Value
    |
    stack_before: {
      shape: rectangle
      class: frame_box
      label: |md
        **Operand Stack**
        ┌─────────────┐
        │ 42.0 (top)  │ ← return_value
        │ 99.0        │
        └─────────────┘
      |
    }
    action: {
      shape: text
      label: |md
        c
        Value return_value = vm_pop(vm);
        // return_value = 42.0
        // stack_top: 2 → 1
        
      |
    }
    result: {
      shape: rectangle
      class: frame_box
      label: |md
        **After Pop**
        ┌─────────────┐
        │ 99.0 (top)  │
        └─────────────┘
        return_value = **42.0**
      |
    }
  }
  step2: {
    label: |md
      ## Step 2: Save locals_base
    |
    frames_before: {
      shape: rectangle
      class: frame_box
      label: |md
        **Frame Stack**
        ┌────────────────────────────┐
        │ Frame 1 (caller)           │
        │   return_address: 15       │
        │   locals_base: 0           │
        │   locals_count: 3          │
        ├────────────────────────────┤
        │ Frame 2 (callee) ← TOP     │
        │   return_address: 42       │
        │   locals_base: 3           │
        │   locals_count: 2          │
        └────────────────────────────┘
      |
    }
    action2: {
      shape: text
      label: |md
        c
        CallFrame* frame = frame_stack_top(&vm->frames);
        // frame->locals_base = 3
        
      |
    }
    saved: {
      shape: rectangle
      class: frame_box
      label: |md
        **Saved Value**
        saved_base = **3**
      |
    }
  }
  step3: {
    label: |md
      ## Step 3: Pop Frame
    |
    frames_before3: {
      shape: rectangle
      class: frame_box
      label: |md
        **Before Pop**
        frames.count = 2
        ┌────────────────────────────┐
        │ Frame 1 (caller)           │
        │   locals_base: 0           │
        ├────────────────────────────┤
        │ Frame 2 (callee)           │
        │   locals_base: 3 ← REMOVE  │
        └────────────────────────────┘
      |
    }
    action3: {
      shape: text
      label: |md
        c
        // First: restore locals_top
        vm->locals_top = frame->locals_base;
        // locals_top: 5 → 3
        // Then: pop frame
        frame_stack_pop(&vm->frames);
        // frames.count: 2 → 1
        
      |
    }
    frames_after3: {
      shape: rectangle
      class: frame_box
      label: |md
        **After Pop**
        frames.count = 1
        ┌────────────────────────────┐
        │ Frame 1 (caller) ← TOP     │
        │   return_address: 15       │
        │   locals_base: 0           │
        │   locals_count: 3          │
        └────────────────────────────┘
      |
    }
  }
  step4: {
    label: |md
      ## Step 4: Restore IP
    |
    ip_before: {
      shape: rectangle
      class: frame_box
      label: |md
        **Before**
        IP = 58 (inside callee)
        Frame 2 (popped):
          return_address: 42
      |
    }
    action4: {
      shape: text
      label: |md
        c
        CallFrame* caller = frame_stack_top(&vm->frames);
        vm->chunk = caller->chunk;
        vm->ip = frame->return_address;
        // IP: 58 → 42 (back to caller)
        
      |
    }
    ip_after: {
      shape: rectangle
      class: frame_box
      label: |md
        **After**
        IP = 42 (caller code)
        ┌─────────────────────────┐
        │ Caller Bytecode         │
        │ ...                     │
        │ 42: ← IP points here    │
        │     (after CALL)        │
        └─────────────────────────┘
      |
    }
  }
  step5: {
    label: |md
      ## Step 5: Push Return Value
    |
    locals_array: {
      shape: rectangle
      class: frame_box
      label: |md
        **Locals Array**
        ┌─────────────────────────────────────┐
        │ [0] [1] [2] │ [3] [4] │ [5] [6] ... │
        │  Caller's   │ Callee's│   FREE      │
        │  Locals     │ Locals  │             │
        └─────────────────────────────────────┘
                      ▲
                      │
                locals_top = 3 (restored)
      |
    }
    action5: {
      shape: text
      label: |md
        c
        // Push return value to CALLER's stack
        vm_push(vm, return_value);
        // Stack now has 42.0 (return value)
        
      |
    }
    stack_final: {
      shape: rectangle
      class: frame_box
      label: |md
        **Final Operand Stack**
        ┌─────────────┐
        │ 42.0 (top)  │ ← Return value
        │ 99.0        │   (crossed frame boundary!)
        └─────────────┘
        **Execution resumes in caller**
      |
    }
  }
}
crossing_boundary: {
  label: |md
    ## Critical: Value Crosses Frame Boundary
  |
  boundary_diagram: {
    shape: rectangle
    style.fill: "${colors.header}"
    style.stroke: "${colors.border}"
    style.stroke-width: 2
    label: |md
      **Before RETURN (in callee frame)**
      Callee Frame:
        locals_base: 3
        locals_count: 2
        locals: [3, 4]
      Operand Stack: [99.0, 42.0]
                                  ↓
      return_value = vm_pop() → 42.0
                                  ↓
      frame_stack_pop() removes callee frame
                                  ↓
      **After RETURN (in caller frame)**
      Caller Frame:
        locals_base: 0
        locals_count: 3
        locals: [0, 1, 2]
      Operand Stack: [99.0, **42.0**]
                               ↑
      Return value successfully
      transferred to caller's context!
    |
  }
}
step1 -> step2 -> step3 -> step4 -> step5
step5 -> crossing_boundary
legend: {
  near: bottom-center
  label: |md
    ### Key Invariants
    1. **Return value popped first** - before frame manipulation
    2. **locals_top restored** - to frame->locals_base before pop
    3. **Frame popped** - after locals_top is saved
    4. **IP restored** - from saved return_address
    5. **Return value pushed last** - onto caller's operand stack
  |
}