vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Argument Passing Conventions
  **Left-to-Right vs Right-to-Left**
| {
  near: top-center
  style.font-size: 24
}

# Container for the comparison
comparison: {
  grid-columns: 2
  grid-gap: 60

  # LEFT SIDE: Left-to-Right Convention
  ltr: {
    label: "Left-to-Right Convention\n(arg0 → local_0)"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 3
      border-radius: 10
    }

    ltr_intro: |md
      **Function Call:** `foo(3, 5, 7)`
      Arguments pushed in source order:
      1. **PUSH 3** (arg0) - Offset 0
      2. **PUSH 5** (arg1) - Offset 8
      3. **PUSH 7** (arg2) - Offset 16
    | {
      shape: text
      style.font-size: 14
    }

    ltr_stack_before: {
      label: "Stack State Before CALL\n(Stack Growth: Up)"
      style.fill: "#C8E6C9"
      
      ltr_s2: "slot[2]: 7.0 (arg2)\n[TOP]" {
        style: {
          fill: "#43A047"
          font-color: white
          bold: true
          stroke-width: 2
        }
      }
      ltr_s1: "slot[1]: 5.0 (arg1)" {
        style.fill: "#81C784"
      }
      ltr_s0: "slot[0]: 3.0 (arg0)\n[BASE]" {
        style.fill: "#A5D6A7"
      }
      
      ltr_s2 -> ltr_s1 -> ltr_s0: {style.stroke-dash: 3}
    }

    ltr_pop_order: {
      label: "Execution Pop Sequence"
      style.fill: "#FFF9C4"
      style.stroke: "#F57F17"

      ltr_pop_desc: |md
        **REVERSE POP LOGIC**
        c
        for (i = param_count - 1; i >= 0; i--) {
            locals[i] = pop();
        }
        
      | {shape: text}

      ltr_pop_1: "STEP 1: pop() -> 7.0" { style.fill: "#FFECB3" }
      ltr_pop_2: "STEP 2: pop() -> 5.0" { style.fill: "#FFE082" }
      ltr_pop_3: "STEP 3: pop() -> 3.0" { style.fill: "#FFD54F" }

      ltr_pop_1 -> ltr_pop_2: "Next"
      ltr_pop_2 -> ltr_pop_3: "Next"
    }

    ltr_result: {
      label: "VM Local Frame Mapping"
      style.fill: "#B3E5FC"
      style.stroke: "#0277BD"

      ltr_l0: "local_0 [Value: 3.0]\nMapped from arg0" {
        style: {
          fill: "#81D4FA"
          bold: true
          stroke: "#01579B"
        }
      }
      ltr_l1: "local_1 [Value: 5.0]\nMapped from arg1" {
        style.fill: "#4FC3F7"
      }
      ltr_l2: "local_2 [Value: 7.0]\nMapped from arg2" {
        style.fill: "#29B6F6"
      }
    }

    ltr_verdict: |md
      ### Analysis
      ✅ **Natural Mapping**
      The 0-th argument in source code maps directly to the 0-th local variable slot in the VM frame.
      
      **Implementations:** 
      - Pascal p-Code
      - Our Custom VM Spec
    | {shape: text}
  }

  # RIGHT SIDE: Right-to-Left Convention
  rtl: {
    label: "Right-to-Left Convention\n(argN → local_0)"
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 3
      border-radius: 10
    }

    rtl_intro: |md
      **Function Call:** `foo(3, 5, 7)`
      Arguments pushed in source order:
      1. **PUSH 3** (arg0)
      2. **PUSH 5** (arg1)
      3. **PUSH 7** (arg2)
    | {
      shape: text
      style.font-size: 14
    }

    rtl_stack_before: {
      label: "Stack State Before CALL\n(Stack Growth: Up)"
      style.fill: "#FFCDD2"

      rtl_s2: "slot[2]: 7.0 (arg2)\n[TOP]" {
        style: {
          fill: "#D32F2F"
          font-color: white
          bold: true
          stroke-width: 2
        }
      }
      rtl_s1: "slot[1]: 5.0 (arg1)" {
        style.fill: "#EF9A9A"
      }
      rtl_s0: "slot[0]: 3.0 (arg0)\n[BASE]" {
        style.fill: "#FFAB91"
      }

      rtl_s2 -> rtl_s1 -> rtl_s0: {style.stroke-dash: 3}
    }

    rtl_pop_order: {
      label: "Execution Pop Sequence"
      style.fill: "#FFF9C4"
      style.stroke: "#F57F17"

      rtl_pop_desc: |md
        **FORWARD POP LOGIC**
        c
        for (i = 0; i < param_count; i++) {
            locals[i] = pop();
        }
        
      | {shape: text}

      rtl_pop_1: "STEP 1: pop() -> 7.0" { style.fill: "#FFECB3" }
      rtl_pop_2: "STEP 2: pop() -> 5.0" { style.fill: "#FFE082" }
      rtl_pop_3: "STEP 3: pop() -> 3.0" { style.fill: "#FFD54F" }

      rtl_pop_1 -> rtl_pop_2
      rtl_pop_2 -> rtl_pop_3
    }

    rtl_result: {
      label: "VM Local Frame Mapping"
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"

      rtl_l0: "local_0 [Value: 7.0]\nLast arg -> First local" {
        style: {
          fill: "#CE93D8"
          bold: true
          stroke: "#4A148C"
        }
      }
      rtl_l1: "local_1 [Value: 5.0]" {
        style.fill: "#BA68C8"
      }
      rtl_l2: "local_2 [Value: 3.0]" {
        style.fill: "#AB47BC"
      }
    }

    rtl_verdict: |md
      ### Analysis
      ⚠️ **Inverted Mapping**
      The rightmost argument (last pushed) becomes the first local variable. 
      
      **Advantages:**
      - Variadic functions (e.g., `printf`) can find the first argument at a fixed offset from the base.
      
      **Implementations:**
      - C (cdecl)
      - x86 Calling Conventions
    | {shape: text}
  }
}

# Summary comparison at bottom using block string to handle Markdown pipes safely
summary: {
  near: bottom-center
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    stroke-width: 2
    border-radius: 8
  }
  
  summary_title: {
    label: "Architecture Comparison Matrix"
    style: {
      fill: "#37474F"
      font-color: white
      bold: true
    }
  }
  
  summary_content: ||md
| Feature | Left-to-Right (LTR) | Right-to-Left (RTL) |
| :--- | :--- | :--- |
| **Pop Order** | Reverse Index (N-1 down to 0) | Forward Index (0 up to N-1) |
| **local_0 Result** | Receives First Argument (arg0) | Receives Last Argument (argN) |
| **Variadic Support** | Complex (Requires pre-scan) | Natural (First arg is always Top) |
| **Cognitive Load** | Low (Matches source) | High (Requires mapping mental model) |
| **VM Choice** | **Selected for Clarity** | Rejected |
|| {
    shape: text
    style.font-size: 14
  }
}

# Explicit connections to show data flow logic
comparison.ltr.ltr_stack_before.ltr_s2 -> comparison.ltr.ltr_pop_order.ltr_pop_1: "Pop" {style.stroke: orange}
comparison.rtl.rtl_stack_before.rtl_s2 -> comparison.rtl.rtl_pop_order.rtl_pop_1: "Pop" {style.stroke: orange}

comparison.ltr.ltr_pop_order.ltr_pop_3 -> comparison.ltr.ltr_result.ltr_l0: "Store" {style.stroke: blue}
comparison.rtl.rtl_pop_order.rtl_pop_1 -> comparison.rtl.rtl_result.rtl_l0: "Store" {style.stroke: blue}