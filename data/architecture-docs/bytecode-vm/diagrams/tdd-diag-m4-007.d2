vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Return Value Crossing Frame Boundary
  **The operand stack is GLOBAL (shared across all frames)**
|
direction: right
before_return: Before RETURN {
  style.fill: "#E8F4FD"
  style.stroke: "#2563EB"
  callee_frame: Callee Frame {
    style.fill: "#DBEAFE"
    return_instruction: "RETURN instruction"
    locals_label: "locals[8-11]:"
    local_0: "local_0 = 3"
    local_1: "local_1 = 5"
    local_2: "local_2 = 8"
    local_3: "local_3 = 0.0"
  }
  stack_state_before: Operand Stack {
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    stack_label: "stack[0-1]:"
    stack_0: "stack[0] = 8.0  ← RETURN VALUE"
    stack_0.style.fill: "#FDE68A"
    stack_0.style.bold: true
    stack_top_before: "stack_top = 1"
  }
  vm_state_before: VM State {
    style.fill: "#F3E8FF"
    frames_count_before: "frames.count = 3"
    frames_before: "frames: [main][foo][bar]"
    locals_top_before: "locals_top = 12"
  }
}
arrow_1: -> : "1. Pop return value\n   value = 8.0" {
  style.stroke: "#DC2626"
  style.stroke-width: 3
  style.bold: true
}
temp_storage: Temporary {
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  return_value: "return_value = 8.0\n(popped from stack)"
  return_value.style.fill: "#FECACA"
  return_value.style.bold: true
  note_1: |md
    **CRITICAL:**
    Value is held in C local variable,
    NOT on any stack during transition
  |
}
arrow_2: -> : "2. Pop frame\n   Restore state" {
  style.stroke: "#059669"
  style.stroke-width: 3
}
after_pop: After Frame Pop {
  style.fill: "#ECFDF5"
  style.stroke: "#059669"
  caller_frame: Caller Frame (foo) {
    style.fill: "#D1FAE5"
    resumed: "Execution resumes here"
    locals_label_2: "locals[4-7]:"
    local_0_2: "local_0 = 10"
    local_1_2: "local_1 = 20"
    local_2_2: "local_2 = 30"
    local_3_2: "local_3 = 40"
  }
  stack_state_mid: Operand Stack {
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    stack_label_2: "stack[0]:"
    stack_0_2: "(empty slot)"
    stack_0_2.style.fill: "#F5F5F5"
    stack_top_mid: "stack_top = 0"
  }
  vm_state_mid: VM State {
    style.fill: "#F3E8FF"
    frames_count_mid: "frames.count = 2"
    frames_mid: "frames: [main][foo]"
    locals_top_mid: "locals_top = 8"
    restored: "IP = return_address"
  }
}
arrow_3: -> : "3. Push return value\n   to caller's stack" {
  style.stroke: "#2563EB"
  style.stroke-width: 3
  style.bold: true
}
after_return: After RETURN {
  style.fill: "#E8F4FD"
  style.stroke: "#2563EB"
  caller_frame_2: Caller Frame (foo) {
    style.fill: "#DBEAFE"
    next_instruction: "Next instruction\nuses stack[0]"
    locals_label_3: "locals[4-7]:"
    local_0_3: "local_0 = 10"
    local_1_3: "local_1 = 20"
    local_2_3: "local_2 = 30"
    local_3_3: "local_3 = 40"
  }
  stack_state_after: Operand Stack {
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    stack_label_3: "stack[0]:"
    stack_0_3: "stack[0] = 8.0  ← RETURN VALUE"
    stack_0_3.style.fill: "#FDE68A"
    stack_0_3.style.bold: true
    stack_top_after: "stack_top = 1"
  }
  vm_state_after: VM State {
    style.fill: "#F3E8FF"
    frames_count_after: "frames.count = 2"
    frames_after: "frames: [main][foo]"
    locals_top_after: "locals_top = 8"
  }
}
key_insight: |md
  ## Key Insight: Global Operand Stack
  The operand stack is **NOT per-frame**. It's a single global array
  shared by all function invocations.
  
  VM {
    stack[256]     ← ONE array for ALL frames
    stack_top      ← Single index
    frames[]       ← Multiple frames
    locals[]       ← Multiple frame locals
  }
  
  This simplifies return value handling:
  - No need to copy between "callee stack" and "caller stack"
  - Just pop, pop frame, push back to same array
  - The "caller's stack" is the same memory as "callee's stack"
| {
  near: bottom-center
  style.fill: "#F0FDF4"
  style.stroke: "#16A34A"
}
memory_layout: Memory Layout {
  style.fill: "#FAFAFA"
  style.stroke: "#525252"
  locals_array: "locals[] array:" {
    style.fill: "#E5E5E5"
    main_locals: "[0-3] main's locals"
    foo_locals: "[4-7] foo's locals"
    foo_locals.style.fill: "#D1FAE5"
    bar_locals: "[8-11] bar's locals (freed)"
    bar_locals.style.fill: "#FEE2E2"
    bar_locals.style.stroke-dash: 3
    free_space: "[12+] free"
  }
  stack_array: "stack[] array:" {
    style.fill: "#FEF3C7"
    used_slot: "[0] 8.0 (return value)"
    used_slot.style.fill: "#FDE68A"
    free_slots: "[1-255] free"
  }
}