vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Deep Recursion: Frame Stack Growth and Overflow
| {near: top-center}

classes: {
  frame: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
  frame_active: {
    shape: rectangle
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      stroke-width: 3
      font-color: white
      bold: true
    }
  }
  frame_overflow: {
    shape: rectangle
    style: {
      fill: "#F44336"
      stroke: "#B71C1C"
      stroke-width: 3
      font-color: white
      bold: true
    }
  }
  error_state: {
    shape: diamond
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 3
    }
  }
  success_state: {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
}

Frame_Stack: {
  label: "Frame Stack | depth index (0..255)"
  frame_0: "frame[0]: main()" {class: frame}
  frame_1: "frame[1]: foo()" {class: frame}
  frame_2: "frame[2]: foo()" {class: frame}
  frame_3: "..." {class: frame}
  frame_n: "frame[254]: foo()\nDepth Limit Reached" {class: frame_active}
  frame_overflow: "PUSH [255]\nSTACK_OVERFLOW" {class: frame_overflow; style.opacity: 0.8}
  
  frame_0 -> frame_1 -> frame_2 -> frame_3 -> frame_n -> frame_overflow: "call depth increment"
}

Memory_State: {
  label: "Memory State (VM Locals Array)"
  locals_array: ||md
    **VM.locals[] Allocation**
    
    ┌────────────────────────────────────┐ 0x0000
    │ main() locals (Slot 0..N)          │
    ├────────────────────────────────────┤
    │ foo[1] locals                      │
    ├────────────────────────────────────┤
    │ foo[2] locals                      │
    ├────────────────────────────────────┤
    │ ...                                │
    ├────────────────────────────────────┤ 0xFE00
    │ foo[254] locals                    │
    ├────────────────────────────────────┤ 0xFFFF
    │ ◀── locals_top (Pointer)           │
    │ [EXHAUSTED - NO SLOTS LEFT]        │
    └────────────────────────────────────┘
  ||
  
  exhaustion_point: |md
    **Invariants Check:**
    c
    if (vm.frameCount >= FRAMES_MAX) {
        runtimeError("Stack overflow.");
        return INTERPRET_RUNTIME_ERROR;
    }
    
  |
  exhaustion_point.style.fill: "#FFF3E0"
  exhaustion_point.style.stroke: "#E65100"
}

Call_Flow: {
  label: "OP_CALL Validation Logic"
  normal_call: "OP_CALL\n1. Resolve Function\n2. Calculate Locals" {
    shape: rectangle
    style.fill: "#E3F2FD"
  }
  validate_depth: "frames.count < 256?" {class: error_state}
  validate_locals: "locals_top + N < 65536?" {class: error_state}
  push_frame: "Push New CallFrame\nSet return IP\nSet slots base" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  jump_entry: "IP = func.chunk.code\nNext Instruction" {
    shape: rectangle
    style.fill: "#E8F5E9"
  }
  error_depth: "RUNTIME_ERROR\n'Stack overflow'" {
    class: error_state
  }
  error_locals: "RUNTIME_ERROR\n'Locals limit exceeded'" {
    class: error_state
  }

  normal_call -> validate_depth
  validate_depth -> validate_locals: "Yes"
  validate_depth -> error_depth: "No"
  validate_locals -> push_frame: "Yes"
  validate_locals -> error_locals: "No"
  push_frame -> jump_entry
}

State_Transitions: {
  label: "Execution States"
  init: "VM_READY" {class: success_state}
  executing: "STEADY_RECURSION\nframes++" {shape: rectangle; style.fill: "#E3F2FD"}
  at_limit: "CRITICAL_DEPTH\ncount == 255" {shape: rectangle; style.fill: "#FFF9C4"}
  overflow: "HALT_OVERFLOW" {class: frame_overflow}
  terminated: "RUNTIME_ERROR" {class: error_state}

  init -> executing: "main()"
  executing -> executing: "call (depth < 255)"
  executing -> at_limit: "call (depth == 255)"
  at_limit -> overflow: "call (depth == 256)"
  overflow -> terminated: "error handling"
}

Bounds_Annotation: {
  label: "Virtual Machine Constraints"
  bounds_table: ||md
    | Constant | Value | Purpose |
    | :--- | :--- | :--- |
    | `FRAMES_MAX` | 256 | Maximum call depth (CallFrame array size) |
    | `STACK_MAX` | 256 | Working operand stack depth |
    | `LOCALS_MAX` | 65536 | Total global slot limit for all frames |
    
    **Trigger Conditions:**
    1. `vm.frameCount == FRAMES_MAX` (Frame stack overflow)
    2. `vm.stackTop + locals > vm.stack + STACK_MAX` (Locals overlap)
  ||
  bounds_table.style.fill: "#F5F5F5"
  bounds_table.style.stroke: "#9E9E9E"
}

Error_Recovery: {
  label: "Post-Overflow VM State"
  vm_state: ||md
    **VM Inspection (Internal)**
    - `ip`: Call instruction + 1
    - `frameCount`: 255 (Pinned at max)
    - `stackTop`: Reset to start of current frame
    - `status`: `INTERPRET_RUNTIME_ERROR`
  ||
  vm_state.style.fill: "#FFEBEE"
  vm_state.style.stroke: "#C62828"
}

Frame_Stack -> Memory_State: "Reference layout" {style.stroke-dash: 3}
Call_Flow -> State_Transitions: "Drives" {style.stroke-dash: 3}
State_Transitions -> Bounds_Annotation: "Constraint Check" {style.stroke-dash: 3}
State_Transitions -> Error_Recovery: "On Error" {style.stroke: "#C62828"; style.stroke-width: 2}

legend: ||md
  ┌─────────────────────────────────────────────┐
  │ RECURSION LOG:                              │
  ├─────────────────────────────────────────────┤
  │ Depth 0:   [Main] count=1                   │
  │ Depth 1:   [foo]  count=2                   │
  │ ...                                         │
  │ Depth 254: [foo]  count=255                 │
  │ Depth 255: [foo]  VALIDATION FAILS          │
  │                                             │
  │ Error: "Stack overflow" emitted.            │
  └─────────────────────────────────────────────┘
|| {near: bottom-center}