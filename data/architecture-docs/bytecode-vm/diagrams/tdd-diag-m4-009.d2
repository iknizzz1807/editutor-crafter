layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: |md
  # Complete VM State Snapshot
  Runtime memory layout with 3 active call frames (main → foo → bar)
| {near: top-center}

classes: {
  header: {
    style: {
      fill: "#E8D5E0"
      font-color: "#4A3542"
      bold: true
    }
  }
  header_blue: {
    style: {
      fill: "#D4E5F7"
      font-color: "#2B4F7A"
      bold: true
    }
  }
  header_orange: {
    style: {
      fill: "#FDE5C8"
      font-color: "#8B5A2B"
      bold: true
    }
  }
  header_green: {
    style: {
      fill: "#D5E8D4"
      font-color: "#3D6B33"
      bold: true
    }
  }
  header_purple: {
    style: {
      fill: "#E1D5E7"
      font-color: "#5B3D6B"
      bold: true
    }
  }
  ptr: {
    shape: diamond
    width: 40
    height: 40
    style: {
      fill: "#FFD700"
      stroke: "#B8860B"
      font-size: 10
    }
  }
  slot: {
    width: 60
    height: 30
    style: {
      fill: "#F5F5F5"
      stroke: "#CCCCCC"
      font: mono
      font-size: 11
    }
  }
  active_slot: {
    width: 60
    height: 30
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      font: mono
      font-size: 11
      bold: true
    }
  }
  label_box: {
    width: 120
    style: {
      fill: transparent
      font: mono
      font-size: 11
      font-color: "#666666"
    }
  }
  frame_box: {
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
}

direction: right

vm_container: {
  "VM struct": {
    class: header
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 3
    fields: {
      grid-columns: 2
      grid-gap: 0
      chunk_ptr_label: "chunk *" {class: label_box; width: 80}
      chunk_ptr: "→" {
        class: ptr
        width: 40; height: 30
        style.fill: "#FFD700"
      }
      ip_label: "ip" {class: label_box; width: 80}
      ip_val: "42" {
        class: slot
        style.fill: "#FFCDD2"
        style.stroke: "#E53935"
        style.bold: true
      }
      stack_top_label: "stack_top" {class: label_box; width: 80}
      stack_top_val: "2" {
        class: slot
        style.fill: "#C8E6C9"
        style.stroke: "#43A047"
        style.bold: true
      }
      frames_label: "frames" {class: label_box; width: 80}
      frames_ptr: "→" {
        class: ptr
        width: 40; height: 30
        style.fill: "#FFD700"
      }
      locals_top_label: "locals_top" {class: label_box; width: 80}
      locals_top_val: "10" {
        class: slot
        style.fill: "#C8E6C9"
        style.stroke: "#43A047"
        style.bold: true
      }
    }
  }
}

operand_stack: {
  class: header_blue
  "Operand Stack": {
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    stack_array: {
      grid-columns: 4
      grid-gap: 2
      s0_label: "[0]" {class: label_box; width: 30}
      s0_val: "8.0" {class: active_slot; style.fill: "#BBDEFB"}
      s1_label: "[1]" {class: label_box; width: 30}
      s1_val: "result" {class: active_slot; style.fill: "#BBDEFB"}
      s2_label: "[2]" {class: label_box; width: 30}
      s2_val: "—" {class: slot}
      s3_label: "[3]" {class: label_box; width: 30}
      s3_val: "—" {class: slot}
    }
    stack_note: |md
      **Stack State**
      stack_top = 2
      (next free slot at index 2)
    | {
      style: {
        fill: transparent
        font-size: 10
        font-color: "#666666"
      }
    }
  }
}

frame_stack: {
  class: header_orange
  "Frame Stack": {
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    style.stroke-width: 2
    frames_array: {
      grid-columns: 1
      grid-gap: 8
      main_frame: {
        class: frame_box
        "Frame[0]: main": {
          style: {
            fill: "#FFFDE7"
            stroke: "#FBC02D"
          }
          grid-columns: 2
          grid-gap: 0
          m_chunk_label: "chunk" {class: label_box; width: 60}
          m_chunk_val: "→ main" {class: slot; width: 60; style.fill: "#E1F5FE"}
          m_ret_label: "return_ip" {class: label_box; width: 60}
          m_ret_val: "0" {class: slot; width: 60}
          m_base_label: "locals_base" {class: label_box; width: 60}
          m_base_val: "0" {class: slot; width: 60; style.fill: "#E8F5E9"}
          m_cnt_label: "locals_count" {class: label_box; width: 60}
          m_cnt_val: "5" {class: slot; width: 60}
        }
      }
      foo_frame: {
        class: frame_box
        "Frame[1]: foo": {
          style: {
            fill: "#FFFDE7"
            stroke: "#FBC02D"
          }
          grid-columns: 2
          grid-gap: 0
          f_chunk_label: "chunk" {class: label_box; width: 60}
          f_chunk_val: "→ main" {class: slot; width: 60; style.fill: "#E1F5FE"}
          f_ret_label: "return_ip" {class: label_box; width: 60}
          f_ret_val: "25" {class: slot; width: 60; style.fill: "#FFCDD2"; style.bold: true}
          f_base_label: "locals_base" {class: label_box; width: 60}
          f_base_val: "5" {class: slot; width: 60; style.fill: "#E8F5E9"}
          f_cnt_label: "locals_count" {class: label_box; width: 60}
          f_cnt_val: "3" {class: slot; width: 60}
        }
      }
      bar_frame: {
        class: frame_box
        "Frame[2]: bar ← TOP": {
          style: {
            fill: "#FFF9C4"
            stroke: "#FF6F00"
            stroke-width: 3
            bold: true
          }
          grid-columns: 2
          grid-gap: 0
          b_chunk_label: "chunk" {class: label_box; width: 60}
          b_chunk_val: "→ main" {class: slot; width: 60; style.fill: "#E1F5FE"}
          b_ret_label: "return_ip" {class: label_box; width: 60}
          b_ret_val: "42" {class: slot; width: 60; style.fill: "#FFCDD2"; style.bold: true}
          b_base_label: "locals_base" {class: label_box; width: 60}
          b_base_val: "8" {class: slot; width: 60; style.fill: "#C8E6C9"; style.bold: true}
          b_cnt_label: "locals_count" {class: label_box; width: 60}
          b_cnt_val: "2" {class: slot; width: 60}
        }
      }
    }
    frames_note: |md
      **Call Chain**
      frames.count = 3
      (main → foo → bar)
    | {
      style: {
        fill: transparent
        font-size: 10
        font-color: "#666666"
      }
    }
  }
}

locals_array: {
  class: header_green
  "Locals Array [0..15]": {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    locals_grid: {
      grid-columns: 4
      grid-gap: 2
      l0_label: "[0]" {class: label_box; width: 30}
      l0_val: "x=3.0" {class: active_slot; style.fill: "#DCEDC8"}
      l1_label: "[1]" {class: label_box; width: 30}
      l1_val: "y=5.0" {class: active_slot; style.fill: "#DCEDC8"}
      l2_label: "[2]" {class: label_box; width: 30}
      l2_val: "sum" {class: active_slot; style.fill: "#DCEDC8"}
      l3_label: "[3]" {class: label_box; width: 30}
      l3_val: "tmp" {class: active_slot; style.fill: "#DCEDC8"}
      l4_label: "[4]" {class: label_box; width: 30}
      l4_val: "flag" {class: active_slot; style.fill: "#DCEDC8"}
      l5_label: "[5]" {class: label_box; width: 30}
      l5_val: "a=10" {class: active_slot; style.fill: "#B3E5FC"}
      l6_label: "[6]" {class: label_box; width: 30}
      l6_val: "b=20" {class: active_slot; style.fill: "#B3E5FC"}
      l7_label: "[7]" {class: label_box; width: 30}
      l7_val: "c" {class: active_slot; style.fill: "#B3E5FC"}
      l8_label: "[8]" {class: label_box; width: 30}
      l8_val: "n=5" {class: active_slot; style.fill: "#FFCCBC"; style.bold: true}
      l9_label: "[9]" {class: label_box; width: 30}
      l9_val: "acc=120" {class: active_slot; style.fill: "#FFCCBC"; style.bold: true}
      l10_label: "[10]" {class: label_box; width: 30}
      l10_val: "—" {class: slot; style.fill: "#FAFAFA"}
      l11_label: "[11]" {class: label_box; width: 30}
      l11_val: "—" {class: slot; style.fill: "#FAFAFA"}
      l12_label: "[12]" {class: label_box; width: 30}
      l12_val: "—" {class: slot; style.fill: "#FAFAFA"}
    }
    locals_note: |md
      **Locals Allocation**
      locals_top = 10
      (slots 10+ are free)
    | {
      style: {
        fill: transparent
        font-size: 10
        font-color: "#666666"
      }
    }
  }
}

chunk_struct: {
  class: header_purple
  "Chunk (main)": {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
    chunk_fields: {
      grid-columns: 1
      grid-gap: 4
      bytecode_label: "bytecode:" {
        style: {
          fill: transparent
          font: mono
          font-size: 11
        }
      }
      bytecode_preview: {
        grid-columns: 8
        grid-gap: 1
        style.fill: "#EDE7F6"
        b0: "0x10" {class: slot; width: 35; style.fill: "#E1BEE7"}
        b1: "0x00" {class: slot; width: 35}
        b2: "0x00" {class: slot; width: 35}
        b3: "0x20" {class: slot; width: 35; style.fill: "#E1BEE7"}
        b4: "0x42" {class: slot; width: 35; style.fill: "#FFCDD2"; style.bold: true}
        b5: "..." {class: slot; width: 35}
        b6: "0x43" {class: slot; width: 35}
        b7: "0x00" {class: slot; width: 35}
      }
      constants_label: "constants:" {
        style: {
          fill: transparent
          font: mono
          font-size: 11
        }
      }
      constants_preview: {
        grid-columns: 3
        grid-gap: 2
        c0: "[0]=3.0" {class: slot; width: 50; style.fill: "#C5CAE9"}
        c1: "[1]=5.0" {class: slot; width: 50; style.fill: "#C5CAE9"}
        c2: "[2]=1.0" {class: slot; width: 50; style.fill: "#C5CAE9"}
      }
    }
  }
}

legend: {
  "Legend": {
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
    legend_grid: {
      grid-columns: 4
      grid-gap: 8
      leg1: "🟢 Main's locals" {
        style: {fill: transparent; font-size: 10}
      }
      leg2: "🔵 foo's locals" {
        style: {fill: transparent; font-size: 10}
      }
      leg3: "🟠 bar's locals (current)" {
        style: {fill: transparent; font-size: 10}
      }
      leg4: "⬜ Free slots" {
        style: {fill: transparent; font-size: 10}
      }
    }
  }
}
legend.near: bottom-center

# Fixed Connection Paths
vm_container."VM struct".fields.chunk_ptr -> chunk_struct: "chunk" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}

vm_container."VM struct".fields.stack_top_val -> operand_stack."Operand Stack".stack_array.s2_val: "points to free slot" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}

vm_container."VM struct".fields.frames_ptr -> frame_stack."Frame Stack".frames_array: "frames" {
  style.stroke: "#FF8F00"
  style.stroke-dash: 3
}

vm_container."VM struct".fields.locals_top_val -> locals_array."Locals Array [0..15]".locals_grid.l10_val: "locals_top=10" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}

frame_stack."Frame Stack".frames_array.bar_frame."Frame[2]: bar ← TOP".b_base_val -> locals_array."Locals Array [0..15]".locals_grid.l8_val: "base=8" {
  style.stroke: "#FF6F00"
  style.stroke-width: 2
  style.stroke-dash: 5
}

offset_annotations: ||md
  ## Frame → Locals Mapping
  | Frame | base | count | Slots |
  |-------|------|-------|-------|
  | main  | 0    | 5     | 0-4   |
  | foo   | 5    | 3     | 5-7   |
  | bar   | 8    | 2     | 8-9   |
  
  **Runtime Check:**
  `locals_top = 10`
  (sum of bases + counts)
|| {
  near: center-right
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    font-size: 11
  }
}