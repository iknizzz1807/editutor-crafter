direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# Metadata and ID Tracking
# Diagram ID: tdd-diag-m4-010
# Based on: diag-m4-deep-recursion-stack (tdd-diag-m4-009)
# Trace of: diag-m4-call-instruction-trace (tdd-diag-m4-004), diag-m4-return-instruction-trace (tdd-diag-m4-005)

classes: {
  frame_base: {
    style: {
      fill: "white"
      stroke: "#2c3e50"
      stroke-width: 2
      border-radius: 4
    }
  }
  active_op: {
    style: {
      stroke: "#e74c3c"
      stroke-width: 4
      font-color: "#e74c3c"
      bold: true
    }
  }
  return_path: {
    style: {
      stroke: "#e74c3c"
      stroke-dash: 3
      animated: true
    }
  }
  main_box: {
    style: {
      fill: "#ecf0f1"
      stroke: "#2c3e50"
      double-border: true
    }
  }
}

Title: |md
  ### Recursive Factorial Execution Trace: `factorial(5)`
  **ALGORITHM TRACE DIAGRAM (m4: Variables & Functions)**
  *Demonstrating Stack Frame Growth and Return Value Propagation*
| {
  near: top-center
  shape: text
}

"Main Scope": {
  class: main_box
  "Local Variables": {
    shape: sql_table
    "Result": "120 (Final)"
  }
}

"Call Stack": {
  "Frame 5": {
    class: frame_base
    "locals": {
      shape: sql_table
      "n": "5"
      "ret_val": "5 * 24 = 120" {
        class: active_op
      }
    }
  }

  "Frame 4": {
    class: frame_base
    "locals": {
      shape: sql_table
      "n": "4"
      "ret_val": "4 * 6 = 24" {
        class: active_op
      }
    }
  }

  "Frame 3": {
    class: frame_base
    "locals": {
      shape: sql_table
      "n": "3"
      "ret_val": "3 * 2 = 6" {
        class: active_op
      }
    }
  }

  "Frame 2": {
    class: frame_base
    "locals": {
      shape: sql_table
      "n": "2"
      "ret_val": "2 * 1 = 2" {
        class: active_op
      }
    }
  }

  "Frame 1": {
    class: frame_base
    "style.fill": "#f9ebea"
    "locals": {
      shape: sql_table
      "n": "1"
      "Base Case": "1" {
        class: active_op
      }
    }
  }
}

# Execution Flow - Calls (1 to 5)
"Main Scope" -> "Call Stack"."Frame 5": "1. CALL factorial(5)" {
  source-arrowhead: circle
}
"Call Stack"."Frame 5" -> "Call Stack"."Frame 4": "2. CALL factorial(4)"
"Call Stack"."Frame 4" -> "Call Stack"."Frame 3": "3. CALL factorial(3)"
"Call Stack"."Frame 3" -> "Call Stack"."Frame 2": "4. CALL factorial(2)"
"Call Stack"."Frame 2" -> "Call Stack"."Frame 1": "5. CALL factorial(1)"

# Execution Flow - Returns and Multiplications (6 to 10)
"Call Stack"."Frame 1" -> "Call Stack"."Frame 2": "6. RETURN 1" {
  class: return_path
}
"Call Stack"."Frame 2" -> "Call Stack"."Frame 3": "7. RETURN (2 * 1) = 2" {
  class: return_path
}
"Call Stack"."Frame 3" -> "Call Stack"."Frame 4": "8. RETURN (3 * 2) = 6" {
  class: return_path
}
"Call Stack"."Frame 4" -> "Call Stack"."Frame 5": "9. RETURN (4 * 6) = 24" {
  class: return_path
}
"Call Stack"."Frame 5" -> "Main Scope": "10. RETURN (5 * 24) = 120" {
  class: return_path
}

# Annotations for Engineer Implementation
Legend: {
  near: bottom-right
  Call: "Instruction: CALL (OpCode 0x10)" {
    style.stroke: "#2c3e50"
  }
  Return: "Instruction: RETURN (OpCode 0x11)" {
    class: return_path
  }
  Active: "Active Computation (ALU)" {
    class: active_op
  }
}

# Stack Pointer Visualization
"Stack Pointers": {
  near: center-left
  "SP_start": "SP at main"
  "SP_deep": "SP at n=1 (Deepest)"
  "SP_start" -> "Main Scope": "Initial"
  "SP_deep" -> "Call Stack"."Frame 1": "Maximum Depth"
}