direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Array of Structs (AoS) Memory Layout
  ## Particle System: 7 fields per struct, cache-line waste on partial access
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    label: "Legend"
    style.fill: "#f8f9fa"
    used: {
      shape: rectangle
      label: "Used (x,y,z)"
      style.fill: "#d4edda"
      style.stroke: "#28a745"
    }
    wasted: {
      shape: rectangle
      label: "Wasted (vx,vy,vz,mass)"
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
    }
    cachelinedesc: {
      label: "─── Cache Line Boundary (64 bytes)"
      shape: text
    }
  }
  access_pattern: {
    label: "Access Pattern Analysis"
    width: 380
    code: |'c
      // Position-only update loop
      void apply_gravity(Particle* p, int n) {
        for (int i = 0; i < n; i++) {
          p[i].x += gx * dt;  // +0  bytes
          p[i].y += gy * dt;  // +4  bytes
          p[i].z += gz * dt;  // +8  bytes
          // vx,vy,vz,mass NOT accessed!
        }
      }
    '|
  }
}
particle_struct: {
  shape: sql_table
  label: "struct Particle (particle.h)"
  f0: "0x00 | float | x"
  f1: "0x04 | float | y"
  f2: "0x08 | float | z"
  f3: "0x0C | float | vx"
  f4: "0x10 | float | vy"
  f5: "0x14 | float | vz"
  f6: "0x18 | float | mass"
  sz: "Total: 28 bytes (padded to 32)"
}
memory_layout: {
  label: "Memory Layout: particles[0..2]"
  cacheline0: {
    label: "Cache Line 0 (0x00-0x3F)"
    style.fill: "#e9ecef"
    style.stroke: "#495057"
    style.stroke-width: 3
    cl0_content: "" {
      direction: right
      p0_xyz: {
        label: "p[0]\nx y z"
        style.fill: "#d4edda"
        style.stroke: "#28a745"
        width: 80
      }
      p0_vxyz: {
        label: "p[0]\nvx vy vz"
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
        width: 80
      }
      p0_m: {
        label: "p[0]\nm"
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
        width: 40
      }
      p1_xyz: {
        label: "p[1]\nx y z"
        style.fill: "#d4edda"
        style.stroke: "#28a745"
        width: 80
      }
      p1_vx: {
        label: "p[1]\nvx"
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
        width: 40
      }
    }
  }
  cacheline1: {
    label: "Cache Line 1 (0x40-0x7F)"
    style.fill: "#e9ecef"
    style.stroke: "#495057"
    style.stroke-width: 3
    cl1_content: "" {
      direction: right
      p1_vy: {
        label: "p[1]\nvy vz"
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
        width: 60
      }
      p1_m: {
        label: "p[1]\nm"
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
        width: 40
      }
      p2_xyz: {
        label: "p[2]\nx y z"
        style.fill: "#d4edda"
        style.stroke: "#28a745"
        width: 80
      }
      p2_vxyz: {
        label: "p[2]\nvx vy vz"
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
        width: 80
      }
      p2_m: {
        label: "p[2]\nm"
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
        width: 40
      }
    }
  }
}
byte_offsets: {
  label: "Byte Offsets Within particles[] Array"
  style.fill: "#f8f9fa"
  offset_table: {
    shape: sql_table
    label: "Offset Mapping"
    r0: "Particle | Base Offset | x | y | z | vx | vy | vz | mass"
    r1: "p[0]     | 0x00        | +0 | +4 | +8 | +12 | +16 | +20 | +24"
    r2: "p[1]     | 0x20        | +0 | +4 | +8 | +12 | +16 | +20 | +24"
    r3: "p[2]     | 0x40        | +0 | +4 | +8 | +12 | +16 | +20 | +24"
  }
}
efficiency: {
  label: "Cache Line Utilization"
  style.fill: "#fff3cd"
  eff_table: {
    shape: sql_table
    label: "Position-Only Access Analysis"
    r0: "Data Loaded per Cache Line | 64 bytes"
    r1: "Actually Used (x,y,z)       | 12 bytes"
    r2: "Wasted (vx,vy,vz,mass)      | 16 bytes"
    r3: "Cache Line Utilization      | 18.75%"
    r4: "Bandwidth Waste             | 81.25%"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  problem: {
    label: "The Problem"
    width: 350
    code: |'c
      // Iteration i=0:
      // Load cache line 0 (64 bytes)
      // Use: x,y,z of p[0] (12 bytes)
      // Waste: vx,vy,vz,mass of p[0] (16 bytes)
      //        + partial p[1] data
      // Iteration i=1:
      // p[1] starts at 0x20 (in cache line 0)
      // Already cached! But still waste 16 bytes
      // Net: 12 useful bytes per 28-byte struct
      //      = 43% struct utilization
    '|
  }
  solution: {
    label: "The Solution: SoA"
    width: 350
    code: |'c
      // Struct of Arrays (SoA):
      struct Particles {
        float* x;  // [p0.x, p1.x, p2.x, ...]
        float* y;  // [p0.y, p1.y, p2.y, ...]
        float* z;  // [p0.z, p1.z, p2.z, ...]
      };
      // Cache line: 16 consecutive x values
      // Utilization: 100% (all x's used)
      // 2.67x fewer cache lines needed!
    '|
  }
}
hardware_trace: {
  label: "Hardware Trace: Accessing p[0].x, p[0].y, p[0].z"
  trace_code: {
    width: 450
    code: |'c
      // CPU loads entire cache line on first access
      Address 0x00 requested (p[0].x)
      │
      ├─► Cache Line 0 loaded (0x00-0x3F)
      │   Contains: p[0].x,y,z,vx,vy,vz,m + p[1].x,y,z,vx
      │   Cost: ~200 cycles (L1 miss) or ~4 cycles (L1 hit)
      │
      Access p[0].y at 0x04 → CACHE HIT (same line)
      Access p[0].z at 0x08 → CACHE HIT (same line)
      // But we also loaded:
      // - p[0].vx,vy,vz,mass (16 bytes of WASTE)
      // - p[1].x,y,z,vx (partial neighbor)
      // Bandwidth: 64 bytes fetched, 12 bytes used
    '|
  }
}
particle_struct -> memory_layout: "28 bytes per\nstruct"
memory_layout -> efficiency: "analyze"
legend -> access_pattern: "position-only\naccess"