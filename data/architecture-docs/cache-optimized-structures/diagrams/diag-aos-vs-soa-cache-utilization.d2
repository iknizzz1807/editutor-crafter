direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: |'md
    # AoS vs SoA: Cache Line Utilization
    ## Position-Only Access Pattern (x, y, z fields)
  '|
  style: {
    stroke-width: 0
    fill: transparent
  }
}

row_comparison: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  aos_section: {
    direction: down
    label: "Array of Structs (AoS) - Traditional OOP"

    aos_struct: {
      shape: sql_table
      label: "struct Particle (28 bytes)"
      f0: "0x00 | float | x // Position"
      f1: "0x04 | float | y"
      f2: "0x08 | float | z"
      f3: "0x0C | float | vx // Velocity"
      f4: "0x10 | float | vy"
      f5: "0x14 | float | vz"
      f6: "0x18 | float | mass"
      total: "Total: 28 bytes per element"
    }

    aos_cache_line: {
      direction: down
      label: "Single Cache Line View"
      
      cl_header: {
        shape: rectangle
        width: 480
        height: 20
        label: "64-Byte Hardware Cache Line"
        style.fill: "#333333"
        style.font-color: white
      }

      aos_content: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        
        p0_used: {
          shape: rectangle
          width: 90
          height: 50
          style.fill: "#90EE90"
          style.stroke: "#228B22"
          label: "P[0].{x,y,z}\n(12B Used)"
        }
        p0_waste: {
          shape: rectangle
          width: 120
          height: 50
          style.fill: "#FFB6C1"
          style.stroke: "#DC143C"
          label: "P[0].{v,m}\n(16B Wasted)"
        }
        p1_used: {
          shape: rectangle
          width: 90
          height: 50
          style.fill: "#90EE90"
          style.stroke: "#228B22"
          label: "P[1].{x,y,z}\n(12B Used)"
        }
        p1_waste: {
          shape: rectangle
          width: 120
          height: 50
          style.fill: "#FFB6C1"
          style.stroke: "#DC143C"
          label: "P[1].{v,m}\n(16B Wasted)"
        }
        p2_partial: {
          shape: rectangle
          width: 60
          height: 50
          style.fill: "#FFE4B5"
          style.stroke: "#FF8C00"
          label: "P[2]..."
        }
      }
    }

    aos_stats: {
      shape: rectangle
      width: 480
      style.fill: "#FFF0F0"
      style.stroke: "#DC143C"
      label: |'md
        **Memory Efficiency Analysis:**
        • Useful bytes: 12 (x,y,z) / 28 (total)
        • **Utilization: 42.8%**
        • Bandwidth Waste: 57.2% (Cold data fetched)
        • Particles per line: 2.28
      '|
    }
  }

  soa_section: {
    direction: down
    label: "Struct of Arrays (SoA) - Data Oriented"

    soa_struct: {
      shape: class
      label: "ParticleSystem (Parallel Arrays)"
      +x: "float[N]"
      +y: "float[N]"
      +z: "float[N]"
      +vx: "float[N]"
      +vy: "float[N]"
      +vz: "float[N]"
      +mass: "float[N]"
    }

    soa_cache_line: {
      direction: down
      label: "X-Array Cache Line View"

      cl_header: {
        shape: rectangle
        width: 480
        height: 20
        label: "64-Byte Hardware Cache Line"
        style.fill: "#333333"
        style.font-color: white
      }

      soa_content: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        
        x_values: {
          shape: rectangle
          width: 480
          height: 50
          style.fill: "#90EE90"
          style.stroke: "#228B22"
          label: "x[0...15] (16 floats × 4 bytes = 64 bytes)"
        }
      }
      
      note: {
        shape: rectangle
        width: 480
        label: "100% UTILIZATION: Every byte is used by the CPU"
        style.fill: "#E6FFE6"
        style.stroke: "#228B22"
        style.font-color: "#006400"
      }
    }

    soa_stats: {
      shape: rectangle
      width: 480
      style.fill: "#F0FFF0"
      style.stroke: "#228B22"
      label: |'md
        **Memory Efficiency Analysis:**
        • Useful bytes: 64 / 64 (full line)
        • **Utilization: 100%**
        • Bandwidth Waste: 0.0%
        • Particles per line: 16 (7x increase)
      '|
    }
  }
}

comparison_results: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  summary_box: {
    shape: rectangle
    width: 750
    style.fill: "#F9F9F9"
    style.stroke: "#333333"
    style.stroke-width: 2
    label: |'md
      ### Execution Impact (Position-Only Update Loop)
      | Metric | AoS (Traditional) | SoA (Optimized) | Delta |
      |--------|------------------|-----------------|-------|
      | **X-Values / Cache Line** | 2.28 | 16 | **+601%** |
      | **Bandwidth Efficiency** | 42.8% | 100% | **2.33x** |
      | **Cache Misses (1M elements)** | ~438,596 | ~62,500 | **7x Reduction** |
      | **SIMD Vectorization** | Poor (Requires Gather) | Excellent (Linear) | **Speedup ++** |
    '|
  }
}

legend_node: {
  near: bottom-right
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  l1: "Used (x,y,z)" {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  l2: "Wasted (vx,vy,vz,mass)" {
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
  }
  l3: "Cold/Partial" {
    style.fill: "#FFE4B5"
    style.stroke: "#FF8C00"
  }
}

row_comparison.aos_section -> row_comparison.soa_section: "Transform to SoA" {
  style.stroke-width: 4
  style.stroke: "#228B22"
}