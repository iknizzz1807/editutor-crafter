direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Block Size Auto-Tuner: Empirical Search
  Execution Time vs Block Size — Finding the Sweet Spot
| {near: top-center}
row_analysis: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_panel: {
    direction: down
    graph_area: {
      label: "Execution Time vs Block Size"
      width: 500
      height: 380
      y_axis_label: {
        label: "Execution Time\n(milliseconds)"
        shape: text
        style.font-size: 14
        style.bold: true
      }
      x_axis_label: {
        label: "Block Size (B)"
        shape: text
        style.font-size: 14
        style.bold: true
      }
      y_axis: {
        shape: rectangle
        width: 4
        height: 300
        style.fill: "#666666"
        label: ""
      }
      x_axis: {
        shape: rectangle
        width: 400
        height: 4
        style.fill: "#666666"
        label: ""
      }
      curve: {
        shape: rectangle
        width: 380
        height: 260
        style.fill: transparent
        style.stroke: transparent
        data_points: |md
          
                 ▲
                ╱ ╲
               ╱   ╲
              ╱     ╲
             ╱       ╲
            ╱         ╲___________________
           ╱
          ╱
         ●
          
        |
      }
    }
  }
  right_panel: {
    direction: down
    width: 380
    curve_label: "U-Shaped Performance Curve" {
      shape: rectangle
      style.fill: "#E8F4F8"
      style.stroke: "#4A90A4"
      style.border-radius: 8
      explanation: |md
        **Why U-shaped?**
        • **Too Small (B=8-16)**: High loop  
          overhead, few operations per block
        • **Optimal (B=32-64)**: Block fits L1,  
          good reuse, low overhead
        • **Too Large (B=128+)**: Block spills  
          to L2/L3, cache pollution
      |
    }
    tuner_process: "Auto-Tuner Algorithm" {
      shape: rectangle
      style.fill: "#FFF9E6"
      style.stroke: "#F5A623"
      style.border-radius: 8
      process: |md
        
        for B in [16, 32, 64, 128, 256]:
            time[B] = benchmark(A, B, n=1024)
        optimal = argmin(time)
        
        **Output:** `Optimal B=32 (12.4ms)`
      |
    }
  }
}
row_results: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  results_table: {
    label: "Auto-Tune Results (n=1024, float)"
    shape: sql_table
    width: 450
    b16: "16  | 45.2 ms  | High overhead, 8×8 blocks"
    b32: "32  | 12.4 ms | ✓ OPTIMAL — fits L1 perfectly"
    b64: "64  | 14.8 ms | Borderline L1 spill"
    b128: "128 | 28.6 ms | Exceeds L1, L2 pressure"
    b256: "256 | 52.1 ms | Cache thrashing"
  }
  insight_box: {
    shape: rectangle
    style.fill: "#E6F3E6"
    style.stroke: "#27AE60"
    style.border-radius: 8
    width: 350
    insight: |md
      **Key Insight:**
      The optimal block size is **architecture-dependent**:
      • L1 size determines maximum block
      • Element type affects fit (float vs double)
      • Prefetcher behavior influences overhead
      **Auto-tuning finds the empirical optimum
      without knowing cache parameters.**
    |
  }
}
legend_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  small_block: {
    label: "B < 32"
    shape: rectangle
    width: 80
    style.fill: "#FF6B6B"
    style.font-color: white
  }
  small_label: {
    label: "Loop overhead dominates"
    shape: text
  }
  optimal_block: {
    label: "B = 32-48"
    shape: rectangle
    width: 80
    style.fill: "#27AE60"
    style.font-color: white
  }
  optimal_label: {
    label: "Cache optimal"
    shape: text
  }
  large_block: {
    label: "B > 64"
    shape: rectangle
    width: 80
    style.fill: "#F39C12"
    style.font-color: white
  }
  large_label: {
    label: "Cache overflow"
    shape: text
  }
}
graph_area -> results_table: "empirical data"
tuner_process -> results_table: "benchmark"