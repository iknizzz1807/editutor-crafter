direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Blocked Matrix Multiplication: Access Pattern (Intel Optimization Guide)
| {near: top-center}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  matrix_a: {
    direction: down
    label: "Matrix A (M × K)"
    a_grid: {
      grid-columns: 4
      grid-rows: 4
      grid-gap: 0
      a00: "A₀₀" {style.fill: "#E8F4FD"}
      a01: "A₀₁" {style.fill: "#E8F4FD"}
      a02: "A₀₂" {style.fill: "#E8F4FD"}
      a03: "..." {style.fill: transparent; style.stroke: transparent}
      a10: "A₁₀" {style.fill: "#E8F4FD"}
      a11: "A₁₁" {style.fill: "#E8F4FD"}
      a12: "A₁₂" {style.fill: "#E8F4FD"}
      a13: "..." {style.fill: transparent; style.stroke: transparent}
      a20: "A₂₀" {style.fill: "#E8F4FD"}
      a21: "A₂₁" {style.fill: "#E8F4FD"}
      a22: "A₂₂" {style.fill: "#E8F4FD"}
      a23: "..." {style.fill: transparent; style.stroke: transparent}
      a30: "..." {style.fill: transparent; style.stroke: transparent}
      a31: "..." {style.fill: transparent; style.stroke: transparent}
      a32: "..." {style.fill: transparent; style.stroke: transparent}
      a33: "" {style.fill: transparent; style.stroke: transparent}
    }
    block_label_a: {
      label: "Block A[I][K]"
      info: |'md
        **Size**: B × B elements
        **Access**: row-wise
        **Stride**: 4 bytes
      '|
      style.fill: "#E8F4FD"
    }
  }

  mult_symbol: {
    label: "×"
    shape: text
    style.font-size: 40
  }

  matrix_b: {
    direction: down
    label: "Matrix B (K × N)"
    b_grid: {
      grid-columns: 4
      grid-rows: 4
      grid-gap: 0
      b00: "B₀₀" {style.fill: "#FFF3E0"}
      b01: "B₀₁" {style.fill: "#FFF3E0"}
      b02: "B₀₂" {style.fill: "#FFF3E0"}
      b03: "..." {style.fill: transparent; style.stroke: transparent}
      b10: "B₁₀" {style.fill: "#FFF3E0"}
      b11: "B₁₁" {style.fill: "#FFF3E0"}
      b12: "B₁₂" {style.fill: "#FFF3E0"}
      b13: "..." {style.fill: transparent; style.stroke: transparent}
      b20: "B₂₀" {style.fill: "#FFF3E0"}
      b21: "B₂₁" {style.fill: "#FFF3E0"}
      b22: "B₂₂" {style.fill: "#FFF3E0"}
      b23: "..." {style.fill: transparent; style.stroke: transparent}
      b30: "..." {style.fill: transparent; style.stroke: transparent}
      b31: "..." {style.fill: transparent; style.stroke: transparent}
      b32: "..." {style.fill: transparent; style.stroke: transparent}
      b33: "" {style.fill: transparent; style.stroke: transparent}
    }
    block_label_b: {
      label: "Block B[K][J]"
      info: |'md
        **Size**: B × B elements
        **Access**: row-wise (Optimized)
        **Stride**: 4 bytes
      '|
      style.fill: "#FFF3E0"
    }
  }

  eq_symbol: {
    label: "="
    shape: text
    style.font-size: 40
  }

  matrix_c: {
    direction: down
    label: "Matrix C (M × N)"
    c_grid: {
      grid-columns: 4
      grid-rows: 4
      grid-gap: 0
      c00: "C₀₀" {style.fill: "#E8F5E9"}
      c01: "C₀₁" {style.fill: "#E8F5E9"}
      c02: "C₀₂" {style.fill: "#E8F5E9"}
      c03: "..." {style.fill: transparent; style.stroke: transparent}
      c10: "C₁₀" {style.fill: "#E8F5E9"}
      c11: "C₁₁" {style.fill: "#E8F5E9"}
      c12: "C₁₂" {style.fill: "#E8F5E9"}
      c13: "..." {style.fill: transparent; style.stroke: transparent}
      c20: "C₂₀" {style.fill: "#E8F5E9"}
      c21: "C₂₁" {style.fill: "#E8F5E9"}
      c22: "C₂₂" {style.fill: "#E8F5E9"}
      c23: "..." {style.fill: transparent; style.stroke: transparent}
      c30: "..." {style.fill: transparent; style.stroke: transparent}
      c31: "..." {style.fill: transparent; style.stroke: transparent}
      c32: "..." {style.fill: transparent; style.stroke: transparent}
      c33: "" {style.fill: transparent; style.stroke: transparent}
    }
    block_label_c: {
      label: "Block C[I][J]"
      info: "Σ A[I][K] × B[K][J]"
      style.fill: "#E8F5E9"
    }
  }
}

matrix_a.block_label_a -> matrix_b.block_label_b: "Multiply"
matrix_b.block_label_b -> matrix_c.block_label_c: "Accumulate"

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  cache_block: {
    label: "L1 Cache Memory Layout (32 KB Limit)"
    width: 500
    details: |'md
      **Working Set (B=32):**
      - Block A: 32 × 32 × 4 bytes = **4 KB**
      - Block B: 32 × 32 × 4 bytes = **4 KB**
      - Block C: 32 × 32 × 4 bytes = **4 KB**
      - **Total Footprint: 12 KB** (< 32 KB L1)
      
      *Status: No evictions during block inner-loop.*
    '|
    style.fill: "#F5F5F5"
    style.stroke: "#999"
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  reuse_analysis: {
    label: "Temporal Data Reuse Analysis"
    width: 600
    table: |'md
      | Component | Elements Loaded | Operations | Reuses per Element |
      |-----------|-----------------|------------|--------------------|
      | Block A   | B²              | B³         | **B times**        |
      | Block B   | B²              | B³         | **B times**        |
      | Block C   | B² (Accumulate) | B³         | **B times**        |
      
      *Improvement: Cache misses reduced from O(N³) to O(N³/B)*
    '|
    style.fill: "#FFF8E1"
  }
}

row4: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  access_pattern_viz: {
    direction: right
    label: "Implementation Strategy: Naive vs Blocked"
    
    naive: {
      label: "Naive (O(N³))"
      width: 250
      style.fill: "#FFEBEE"
      desc: |'md
        **B-Matrix Access**: Column-wise
        **Stride**: N × 4 bytes
        **Cache Lines**: 1 element per line
        **Outcome**: 100% Cache Thrashing
      '|
    }
    
    spacer: {
      shape: text
      label: "→"
      style.font-size: 30
    }
    
    blocked: {
      label: "Blocked (O(N³/B))"
      width: 250
      style.fill: "#E8F5E9"
      desc: |'md
        **B-Matrix Access**: Sequential
        **Stride**: 4 bytes (Contiguous)
        **Cache Lines**: 16 elements per line
        **Outcome**: Optimal Prefetching
      '|
    }
  }
}

legend_block: {
  label: "Performance Parameters"
  width: 320
  notes: |'md
    **Optimal B (Block Size):**
    - Float32: B=32 to 64
    - Float64: B=16 to 32
    
    **Hardware Considerations:**
    - Must fit 3 blocks in L1
    - Aligned to 64-byte boundaries
    - Minimizes TLB misses
  '|
  style.fill: "#FAFAFA"
}
legend_block.near: bottom-right