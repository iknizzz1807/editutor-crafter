direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Title Container
header: {
  style.stroke: transparent
  style.fill: transparent
  title: "CPU CACHE HIERARCHY (Side View)" {
    shape: rectangle
    style: {
      font-size: 24
      bold: true
      stroke-width: 0
      fill: transparent
    }
  }
}

# Main Vertical Layout
system_stack: {
  style.stroke: transparent
  style.fill: transparent

  # 1. CPU CORE LAYER
  cpu_layer: {
    style.stroke: transparent
    style.fill: transparent
    cpu_core: "CPU Core (x86_64/ARM)" {
      width: 400
      style: {
        fill: "#E74C3C"
        stroke: "#C0392B"
        stroke-width: 3
        font-color: white
        shadow: true
      }
      execution: "Execution Units (ALU/FPU)"
      registers: "Register File (RAX, RBX...)"
    }
  }

  # 2. L1 CACHE LAYER
  l1_layer: {
    style.stroke: transparent
    style.fill: transparent
    l1_cache: {
      shape: sql_table
      label: "L1 DATA CACHE (L1D)"
      size: "0x00 | 32 KB | Size"
      latency: "0x04 | 4 cycles | Load-to-Use"
      assoc: "0x08 | 8-way | Associativity"
      line: "0x0C | 64 Bytes | Cache Line Size"
      bw: "Total | ~1 TB/s | Agg. Bandwidth"
      style.fill: "#F39C12"
      style.stroke: "#D68910"
    }
  }

  # 3. L2 CACHE LAYER
  l2_layer: {
    style.stroke: transparent
    style.fill: transparent
    l2_cache: {
      shape: sql_table
      label: "L2 UNIFIED CACHE"
      size: "0x00 | 256 KB - 1 MB | Size"
      latency: "0x04 | 12 cycles | Latency"
      assoc: "0x08 | 8-way / 16-way | Associativity"
      line: "0x0C | 64 Bytes | Cache Line Size"
      bw: "Total | ~500 GB/s | Agg. Bandwidth"
      style.fill: "#27AE60"
      style.stroke: "#1E8449"
    }
  }

  # 4. L3 CACHE LAYER
  l3_layer: {
    style.stroke: transparent
    style.fill: transparent
    l3_cache: {
      shape: sql_table
      label: "L3 LAST-LEVEL CACHE (Shared)"
      size: "0x00 | 8 MB - 64 MB | Shared Size"
      latency: "0x04 | 40 cycles | Inclusive/Exclusive"
      assoc: "0x08 | 16-way | Associativity"
      line: "0x0C | 64 Bytes | Cache Line Size"
      bw: "Total | ~200 GB/s | Ring/Mesh Bus"
      style.fill: "#3498DB"
      style.stroke: "#2980B9"
    }
  }

  # 5. RAM LAYER
  ram_layer: {
    style.stroke: transparent
    style.fill: transparent
    main_memory: {
      shape: sql_table
      label: "MAIN MEMORY (DDR5 DRAM)"
      size: "0x00 | 16 GB - 128 GB | Capacity"
      latency: "0x04 | 200+ cycles | CAS Latency"
      page: "0x08 | 4 KB | Virtual Page Size"
      unit: "0x0C | 64 Bytes | Burst Length"
      bw: "Total | ~50-100 GB/s | Memory Channel"
      style.fill: "#9B59B6"
      style.stroke: "#7D3C98"
    }
  }
}

# Data Flow Connections
system_stack.cpu_layer.cpu_core -> system_stack.l1_layer.l1_cache: "64B | hit" {
  style.stroke: "#E74C3C"
  style.stroke-width: 4
}
system_stack.l1_layer.l1_cache -> system_stack.l2_layer.l2_cache: "64B | miss" {
  style.stroke: "#F39C12"
  style.stroke-dash: 4
  style.stroke-width: 3
}
system_stack.l2_layer.l2_cache -> system_stack.l3_layer.l3_cache: "64B | miss" {
  style.stroke: "#27AE60"
  style.stroke-dash: 4
  style.stroke-width: 3
}
system_stack.l3_layer.l3_cache -> system_stack.ram_layer.main_memory: "64B | fill" {
  style.stroke: "#3498DB"
  style.stroke-dash: 4
  style.stroke-width: 3
}

# Side Annotations
latency_benchmarks: {
  label: "Latency Analysis"
  comparison: |'md
    | Hierarchy Level | Cycles | Rel. Latency |
    |-----------------|--------|--------------|
    | L1 Cache        | 4      | 1x           |
    | L2 Cache        | 12     | 3x           |
    | L3 Cache        | 40     | 10x          |
    | Main RAM        | 200+   | 50x+         |
  '|
  style: {
    stroke: "#7F8C8D"
    fill: "#FDFEFE"
  }
}
latency_benchmarks.near: top-right

tradeoff_note: {
  label: "System Constraints"
  desc: |'md
    **Funnel Effect:**
    - Speed decreases as Capacity increases.
    - Transfer unit is the **Cache Line**.
    - Software must optimize for **Temporal**
      and **Spatial** locality.
  '|
  style: {
    stroke: "#7F8C8D"
    fill: "#FDFEFE"
  }
}
tradeoff_note.near: bottom-left