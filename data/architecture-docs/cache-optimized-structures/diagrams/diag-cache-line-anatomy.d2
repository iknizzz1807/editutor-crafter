direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Anatomy of a Cache Line (64 bytes)
  The fundamental unit of data transfer between CPU and memory
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cache_line: {
    label: "Cache Line Entry (cache_entry.h)"
    shape: sql_table
    tag: "0x00 | uint64_t  | tag         // Address bits [63:6]"
    flags: "0x08 | uint8_t   | valid       // 1 = valid data"
    flags2: "0x09 | uint8_t   | dirty       // 1 = modified"
    pad: "0x0A | uint8_t[6] | padding"
    data: "0x10 | uint8_t[64]| data        // 64 bytes payload"
    sz: "Total: 80 bytes (metadata + data)"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  breakdown: {
    label: "64-Byte Data Block Layout"
    direction: right
    metadata: {
      label: "Metadata (16 bytes)"
      shape: rectangle
      width: 120
      style.fill: "#E4DBFE"
      style.stroke: "#B5AFF6"
      tag_box: {
        label: "Tag Bits\n(8 bytes)"
        shape: rectangle
        width: 100
        style.fill: "#E4DBFE"
      }
      flags_box: {
        label: "V | D\n(2 bytes)"
        shape: rectangle
        width: 100
        style.fill: "#E4DBFE"
      }
      tag_box -> flags_box
    }
    data_block: {
      label: "Data Block (64 bytes)"
      shape: rectangle
      style.fill: "#C7F1FF"
      style.stroke: "#88DCF7"
      bytes_0_15: {
        label: "Bytes 0-15"
        shape: rectangle
        width: 160
        style.fill: "#ACE1AF"
        style.stroke: "#3D9069"
      }
      bytes_16_31: {
        label: "Bytes 16-31"
        shape: rectangle
        width: 160
        style.fill: "#C7F1FF"
        style.stroke: "#88DCF7"
      }
      bytes_32_47: {
        label: "Bytes 32-47"
        shape: rectangle
        width: 160
        style.fill: "#C7F1FF"
        style.stroke: "#88DCF7"
      }
      bytes_48_63: {
        label: "Bytes 48-63"
        shape: rectangle
        width: 160
        style.fill: "#C7F1FF"
        style.stroke: "#88DCF7"
      }
      bytes_0_15 -> bytes_16_31 -> bytes_32_47 -> bytes_48_63
    }
    metadata -> data_block: "points to"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  int_access: {
    label: "Single int Access Loads 64 Bytes"
    width: 400
    before: {
      label: "CPU Request"
      shape: rectangle
      width: 120
      style.fill: "#F6C889"
      request: |md
        read int at addr 0x1000
        (4 bytes needed)
      |
    }
    arrow1: {
      shape: text
      label: "→"
      width: 40
    }
    memory: {
      label: "Memory Controller"
      shape: rectangle
      width: 140
      style.fill: "#FCE7C6"
      action: |md
        Fetches entire cache line
        addr 0x1000 → 0x103F
      |
    }
    arrow2: {
      shape: text
      label: "→"
      width: 40
    }
    cache: {
      label: "L1 Cache"
      shape: rectangle
      width: 160
      style.fill: "#ACE1AF"
      result: |md
        All 64 bytes now cached
        int returned in 4 cycles
      |
    }
    before -> arrow1 -> memory -> arrow2 -> cache
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  spatial: {
    label: "Spatial Locality: Subsequent Accesses Hit Same Line"
    width: 600
    direction: right
    access_pattern: {
      label: "Access Pattern"
      shape: rectangle
      width: 180
      style.fill: transparent
      style.stroke: "#CBD6E0"
      a1: "arr[0] → bytes 0-3" {style.fill: "#ACE1AF"}
      a2: "arr[1] → bytes 4-7" {style.fill: "#ACE1AF"}
      a3: "arr[2] → bytes 8-11" {style.fill: "#ACE1AF"}
      a4: "arr[15] → bytes 60-63" {style.fill: "#ACE1AF"}
      a1 -> a2 -> a3 -> a4: "HIT!" {style.stroke: "#3D9069"; style.stroke-width: 3}
    }
    cost: {
      label: "Access Cost Comparison"
      shape: sql_table
      first: "arr[0] | ~200 cycles | Cache MISS (loads line)"
      rest: "arr[1..15] | ~4 cycles | Cache HIT (same line)"
      ratio: "16 reads for price of 1 | 16x amortized benefit"
    }
    access_pattern -> cost: "Result"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  formula: {
    label: "Cache Line Math"
    shape: rectangle
    width: 500
    style.fill: "#F6F9FC"
    style.stroke: "#CBD6E0"
    calc: |md
      **Address Decomposition:**
      - Tag bits: Identify which memory block
      - Set index: Which cache set (for set-associative caches)
      - Block offset: Which byte within the 64-byte line (6 bits: log₂(64))
      **Example: Accessing address 0x1004**
      - Block address: 0x1004 >> 6 = 0x40 (which 64-byte block)
      - Block offset: 0x1004 & 0x3F = 4 (byte 4 within the line)
      - Cache line loaded: bytes 0x1000 through 0x103F
      - The int at 0x1004 is at offset 4 in that line
    |
  }
}
row1 -> row2 -> row3 -> row4 -> row5
legend: {
  near: bottom-right
  label: "Color Key"
  shape: rectangle
  style.fill: "#F6F9FC"
  style.stroke: "#CBD6E0"
  l1: "Metadata" {style.fill: "#E4DBFE"}
  l2: "Accessed bytes" {style.fill: "#ACE1AF"}
  l3: "Cached data" {style.fill: "#C7F1FF"}
  l4: "CPU/Memory" {style.fill: "#FCE7C6"}
  l1 -> l2 -> l3 -> l4: {style.stroke: transparent}
}