direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cache Miss Comparison: Naive vs Blocked Matrix Multiplication
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    label: Legend
    naive: "Naive (O(n³) misses)"
    naive.style.fill: "#E74C3C"
    blocked: "Blocked (O(n³/B) misses)"
    blocked.style.fill: "#27AE60"
  }
  insight: {
    label: Key Insight
    width: 380
    code: |'c
      // Naive: Column-wise B access
      // Each element = new cache line
      // Misses: O(n³)
      // Blocked: B×B tile fits in L1
      // Data reused BLOCK_SIZE times
      // Misses: O(n³/B)
    '|
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mat256: {
    label: "Matrix 256×256"
    label.near: outside-top-center
    l1_256: {
      label: "L1 Misses"
      shape: sql_table
      naive: "Naive   | ~12M"
      blocked: "Blocked | ~8M"
      ratio: "Ratio: 1.5x"
    }
    l2_256: {
      label: "L2 Misses"
      shape: sql_table
      naive: "Naive   | ~3M"
      blocked: "Blocked | ~1.8M"
      ratio: "Ratio: 1.7x"
    }
    l3_256: {
      label: "L3 Misses"
      shape: sql_table
      naive: "Naive   | ~0.4M"
      blocked: "Blocked | ~0.2M"
      ratio: "Ratio: 2.0x"
    }
    note: "Fits in L3 cache\nBoth approaches similar"
    note.shape: rectangle
    note.style.fill: "#F8F9FA"
    note.style.stroke-dash: 3
  }
  mat512: {
    label: "Matrix 512×512"
    label.near: outside-top-center
    l1_512: {
      label: "L1 Misses"
      shape: sql_table
      naive: "Naive   | ~95M"
      blocked: "Blocked | ~45M"
      ratio: "Ratio: 2.1x"
    }
    l2_512: {
      label: "L2 Misses"
      shape: sql_table
      naive: "Naive   | ~25M"
      blocked: "Blocked | ~8M"
      ratio: "Ratio: 3.1x"
    }
    l3_512: {
      label: "L3 Misses"
      shape: sql_table
      naive: "Naive   | ~4M"
      blocked: "Blocked | ~1M"
      ratio: "Ratio: 4.0x"
    }
    note: "Exceeds L2\nBlocked advantage emerges"
    note.shape: rectangle
    note.style.fill: "#F8F9FA"
    note.style.stroke-dash: 3
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mat1024: {
    label: "Matrix 1024×1024"
    label.near: outside-top-center
    l1_1024: {
      label: "L1 Misses"
      shape: sql_table
      naive: "Naive   | ~760M"
      blocked: "Blocked | ~280M"
      ratio: "Ratio: 2.7x"
    }
    l2_1024: {
      label: "L2 Misses"
      shape: sql_table
      naive: "Naive   | ~200M"
      blocked: "Blocked | ~35M"
      ratio: "Ratio: 5.7x"
    }
    l3_1024: {
      label: "L3 Misses"
      shape: sql_table
      naive: "Naive   | ~50M"
      blocked: "Blocked | ~8M"
      ratio: "Ratio: 6.3x"
    }
    note: "Exceeds L3\nMajor blocked advantage"
    note.shape: rectangle
    note.style.fill: "#E8F6F3"
    note.style.stroke: "#27AE60"
  }
  mat2048: {
    label: "Matrix 2048×2048"
    label.near: outside-top-center
    l1_2048: {
      label: "L1 Misses"
      shape: sql_table
      naive: "Naive   | ~6.1B"
      blocked: "Blocked | ~1.8B"
      ratio: "Ratio: 3.4x"
    }
    l2_2048: {
      label: "L2 Misses"
      shape: sql_table
      naive: "Naive   | ~1.6B"
      blocked: "Blocked | ~180M"
      ratio: "Ratio: 8.9x"
    }
    l3_2048: {
      label: "L3 Misses"
      shape: sql_table
      naive: "Naive   | ~420M"
      blocked: "Blocked | ~45M"
      ratio: "Ratio: 9.3x"
    }
    note: "Far exceeds cache\nBlocked critical for perf"
    note.shape: rectangle
    note.style.fill: "#E8F6F3"
    note.style.stroke: "#27AE60"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  analysis: {
    label: "Cache Miss Analysis"
    naive_pattern: {
      label: "Naive Access Pattern"
      width: 320
      code: |'c
        // Column-wise access of B matrix
        for (k = 0; k < n; k++) {
          // B[k][j] is n*4 bytes from B[k+1][j]
          // Each access: NEW cache line!
          sum += A[i][k] * B[k][j];
        }
        // L2/L3 miss rate: ~80-95%
        // Working set: 12n² bytes (all 3 matrices)
      '|
    }
    blocked_pattern: {
      label: "Blocked Access Pattern"
      width: 320
      code: |'c
        // Process B×B blocks (e.g., 32×32)
        // Block working set: 3 * 32² * 4 = 12KB
        // Fits entirely in L1 cache!
        for (kk = k0; kk < k0+BLOCK; kk++) {
          // Sequential within block
          // L1 hit rate: ~90%+
          C[ii][jj] += A[ii][kk] * B[kk][jj];
        }
      '|
    }
  }
  perf_summary: {
    label: "Performance Summary"
    shape: sql_table
    size256: "256×256   | Naive: 45ms  | Blocked: 28ms  | 1.6x"
    size512: "512×512   | Naive: 380ms | Blocked: 140ms | 2.7x"
    size1024: "1024×1024 | Naive: 3.2s  | Blocked: 0.9s  | 3.6x"
    size2048: "2048×2048 | Naive: 26s   | Blocked: 6.2s  | 4.2x"
    note: "Block size: 32×32 (auto-tuned)"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  perf_cmd: {
    label: "Measuring Cache Misses"
    width: 400
    code: |'bash
      # Profile with perf
      perf stat -e L1-dcache-loads,L1-dcache-load-misses,\
        LLC-loads,LLC-load-misses ./matmul_benchmark
      # Expected output for 2048×2048:
      # Naive:   6,147,283,456  L1-dcache-load-misses
      # Blocked: 1,823,451,234  L1-dcache-load-misses
      # Ratio: ~3.4x reduction
    '|
  }
  formula: {
    label: "Cache Complexity"
    shape: class
    naive: "-Naive: O(n³) misses"
    blocked: "-Blocked: O(n³/B) misses"
    improvement: "-Improvement: B× factor"
    block_note: "-B = block size (typically 32)"
    line_note: "-L = elements per cache line"
  }
}