direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Block Fits in Cache: Working Set Analysis" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  scenario_32: {
    direction: down
    label: "B = 32 (Fits in L1)"
    block_diagram_32: {
      direction: right
      label: "3 Blocks × 4KB = 12KB"
      block_a_32: {
        label: "Block A\n32×32 floats"
        width: 120
        style: {
          fill: "#E8F5E9"
          stroke: "#4CAF50"
          stroke-width: 2
        }
        note: "4,096 bytes\n(1 cache line = 64B\n= 64 lines/block)"
      }
      block_b_32: {
        label: "Block B\n32×32 floats"
        width: 120
        style: {
          fill: "#E3F2FD"
          stroke: "#2196F3"
          stroke-width: 2
        }
      }
      block_c_32: {
        label: "Block C\n32×32 floats"
        width: 120
        style: {
          fill: "#FFF3E0"
          stroke: "#FF9800"
          stroke-width: 2
        }
      }
    }
    cache_fit_32: {
      label: "✓ Total: 12 KB\n✓ Fits comfortably in L1 (32 KB)"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
        bold: true
        font-color: "#1B5E20"
      }
    }
    block_diagram_32 -> cache_fit_32
  }
  scenario_128: {
    direction: down
    label: "B = 128 (Exceeds L1)"
    block_diagram_128: {
      direction: right
      label: "3 Blocks × 64KB = 192KB"
      block_a_128: {
        label: "Block A\n128×128 floats"
        width: 120
        style: {
          fill: "#FFEBEE"
          stroke: "#F44336"
          stroke-width: 2
          stroke-dash: 4
        }
        note: "65,536 bytes\n(1,024 cache lines)"
      }
      block_b_128: {
        label: "Block B\n128×128 floats"
        width: 120
        style: {
          fill: "#FFEBEE"
          stroke: "#F44336"
          stroke-width: 2
          stroke-dash: 4
        }
      }
      block_c_128: {
        label: "Block C\n128×128 floats"
        width: 120
        style: {
          fill: "#FFEBEE"
          stroke: "#F44336"
          stroke-width: 2
          stroke-dash: 4
        }
      }
    }
    cache_overflow_128: {
      label: "✗ Total: 192 KB\n✗ Exceeds L1 (32 KB)\n→ Spills to L2 (256 KB)"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#D32F2F"
        bold: true
        font-color: "#B71C1C"
      }
    }
    block_diagram_128 -> cache_overflow_128
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  l1_cache: {
    label: "L1 Data Cache"
    width: 300
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 3
    }
    capacity: "Capacity: 32 KB (512 cache lines)"
    latency: "Latency: ~4 cycles"
    usage_bar: {
      direction: right
      label: ""
      used_32: {
        label: "B=32\n12 KB\n37%"
        width: 80
        style: {
          fill: "#81C784"
          stroke: "#388E3C"
        }
      }
      overflow_128: {
        label: "B=128 needs 192 KB\n→ 6x L1 capacity!"
        width: 200
        style: {
          fill: "#FFCDD2"
          stroke: "#D32F2F"
          stroke-dash: 4
        }
      }
    }
  }
  crossover_calc: {
    label: "Crossover Calculation"
    width: 380
    formula: |'c
      // Working set per block operation:
      //   3 × B² × sizeof(float) bytes
      //
      // For L1 fit (32 KB):
      //   3 × B² × 4 < 32,768
      //   B² < 2,730
      //   B < 52.2
      //
      // Safe choice: B = 32 or 48
      // B = 64 → 49 KB (spills to L2)
      // B = 128 → 192 KB (L2 only)
    '|
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      font: mono
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  memory_hierarchy: {
    label: "Memory Hierarchy Impact"
    l1_box: {
      label: "L1 Cache\n32 KB | 4 cycles"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
        bold: true
      }
    }
    l2_box: {
      label: "L2 Cache\n256 KB | 12 cycles"
      shape: rectangle
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
      }
    }
    l3_box: {
      label: "L3 Cache\n8 MB | 40 cycles"
      shape: rectangle
      style: {
        fill: "#FFE0B2"
        stroke: "#EF6C00"
      }
    }
    ram_box: {
      label: "RAM\n64 GB | 200+ cycles"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#D32F2F"
      }
    }
    l1_box -> l2_box: "B > 52\nspills"
    l2_box -> l3_box: "B > 260\nspills"
    l3_box -> ram_box: "working set\n> 8 MB"
  }
  perf_table: {
    label: "Performance Impact"
    table: {
      shape: sql_table
      label: "Block Size vs Cache Behavior"
      col1: "Block Size | Working Set | Cache Level | Access Latency"
      row1: "B = 32     | 12 KB       | L1 resident | ~4 cycles"
      row2: "B = 48     | 27 KB       | L1 resident | ~4 cycles"
      row3: "B = 64     | 49 KB       | L1→L2 spill | ~12 cycles"
      row4: "B = 128    | 192 KB      | L2 resident | ~12 cycles"
      row5: "B = 256    | 768 KB      | L2→L3 spill | ~40 cycles"
    }
  }
}
legend: {
  near: bottom-right
  label: "Key Insight"
  shape: callout
  insight: |md
    **Optimal block size depends on cache size**
    For L1-only: B ≤ 52 (use 32 or 48)
    For L2 fit: B ≤ 260 (use 64-128)
    Smaller blocks = more loop overhead
    Larger blocks = cache misses
    **Auto-tuning finds the sweet spot!**
  |
}
scenario_32 -> l1_cache: "Fits ✓"
scenario_128 -> l2_box: "Spills to L2" {
  style: {
    stroke: "#D32F2F"
    stroke-dash: 4
  }
}