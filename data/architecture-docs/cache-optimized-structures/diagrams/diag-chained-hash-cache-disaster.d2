direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Chained Hash Table: Cache Disaster
  **Every pointer chase = potential cache miss**
| {
  near: top-center
  shape: text
  style.font-size: 24
}
bucket_array: Bucket Array (contiguous, cache-friendly) {
  shape: rectangle
  width: 600
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  buckets: {
    grid-columns: 8
    grid-gap: 0
    b0: "[0]" {style.fill: "#C8E6C9"}
    b1: "[1]" {style.fill: "#C8E6C9"}
    b2: "[2]" {style.fill: "#C8E6C9"}
    b3: "[3]" {style.fill: "#C8E6C9"}
    b4: "[4]" {style.fill: "#C8E6C9"}
    b5: "[5]" {style.fill: "#C8E6C9"}
    b6: "[6]" {style.fill: "#C8E6C9"}
    b7: "[7]" {style.fill: "#C8E6C9"}
  }
}
heap: Heap Memory (scattered allocations) {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-dash: 4
  width: 700
  chain_label: "Each node allocated separately at unpredictable addresses" {
    shape: text
    style.font-color: "#C62828"
    style.italic: true
  }
  chain: {
    direction: right
    node1: Node α {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
      width: 100
      addr1: "addr: 0x7F20" {
        shape: text
        style.font-size: 10
        style.font-color: "#666"
      }
      data1: "key: 42\nval: data" {
        shape: text
        style.font-size: 11
      }
      next1: "next ──→" {
        shape: text
        style.bold: true
        style.font-color: "#1565C0"
      }
    }
    miss1: "CACHE\nMISS!" {
      shape: diamond
      style.fill: "#FF5252"
      style.font-color: white
      style.bold: true
    }
    node2: Node β {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
      width: 100
      addr2: "addr: 0x3A10" {
        shape: text
        style.font-size: 10
        style.font-color: "#666"
      }
      data2: "key: 17\nval: data" {
        shape: text
        style.font-size: 11
      }
      next2: "next ──→" {
        shape: text
        style.bold: true
        style.font-color: "#1565C0"
      }
    }
    miss2: "CACHE\nMISS!" {
      shape: diamond
      style.fill: "#FF5252"
      style.font-color: white
      style.bold: true
    }
    node3: Node γ {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
      width: 100
      addr3: "addr: 0xB480" {
        shape: text
        style.font-size: 10
        style.font-color: "#666"
      }
      data3: "key: 93\nval: data" {
        shape: text
        style.font-size: 11
      }
      next3: "next ──→" {
        shape: text
        style.bold: true
        style.font-color: "#1565C0"
      }
    }
    miss3: "CACHE\nMISS!" {
      shape: diamond
      style.fill: "#FF5252"
      style.font-color: white
      style.bold: true
    }
    node4: Node δ {
      shape: rectangle
      style.fill: "#A5D6A7"
      style.stroke: "#43A047"
      width: 100
      addr4: "addr: 0x1F00" {
        shape: text
        style.font-size: 10
        style.font-color: "#666"
      }
      data4: "key: 88 ✓\nval: FOUND" {
        shape: text
        style.font-size: 11
        style.bold: true
      }
      next4: "next = NULL" {
        shape: text
        style.font-color: "#999"
      }
    }
  }
}
bucket_array.buckets.b3 -> heap.chain.node1: "ptr" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
heap.chain.node1 -> heap.chain.miss1 -> heap.chain.node2: {
  style.stroke: "#E53935"
  style.stroke-width: 2
  style.stroke-dash: 3
}
heap.chain.node2 -> heap.chain.miss2 -> heap.chain.node3: {
  style.stroke: "#E53935"
  style.stroke-width: 2
  style.stroke-dash: 3
}
heap.chain.node3 -> heap.chain.miss3 -> heap.chain.node4: {
  style.stroke: "#E53935"
  style.stroke-width: 2
  style.stroke-dash: 3
}
cost_analysis: Cache Miss Cost Analysis {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  breakdown: {
    shape: sql_table
    label: "Lookup Cost Breakdown"
    row1: "Bucket array access | L1/L2 hit | ~4-12 cycles"
    row2: "Node α pointer chase | CACHE MISS | ~200-300 cycles"
    row3: "Node β pointer chase | CACHE MISS | ~200-300 cycles"
    row4: "Node γ pointer chase | CACHE MISS | ~200-300 cycles"
    row5: "Node δ pointer chase | CACHE MISS | ~200-300 cycles"
    total: "TOTAL | 4 cache misses | ~800-1200 cycles"
  }
}
problem: The Fundamental Problem {
  near: bottom-center
  shape: rectangle
  width: 650
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  content: |md
    **Why this is catastrophic:**
    • Each `malloc()` places nodes at unpredictable heap addresses
    • No spatial locality → hardware prefetcher cannot help
    • Every `node->next` dereference is a potential cache miss
    • Same O(1) algorithm, but 50-100x slower due to memory latency
    **Compare to open addressing:** Sequential probe through contiguous array = 1 cache miss for entire search
  |
}
bucket_array -> heap: "Pointer chase\ntraversal" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5
}
heap.chain.miss1 -> cost_analysis: "accumulates" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}