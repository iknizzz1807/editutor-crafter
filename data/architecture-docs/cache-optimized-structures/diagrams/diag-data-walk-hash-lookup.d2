direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Data Walk: Hash Table Lookup (Robin Hood Open-Addressing)"
  style.font-size: 24
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: {
    direction: down
    label: "Step 1: Hash & Index (wyhash_mix)"
    input_box: {
      shape: sql_table
      label: "Input Key (buffer)"
      key: "0x00 | user_id_12345"
      len: "0x0E | 14 bytes"
      style.fill: "#E8F5E9"
    }
    hash_func: {
      label: "wyhash_mix(key)"
      code: |'c
        uint64_t hash = wyhash_mix(key);
        // hash = 0x7A3F2B1E8C4D6F90
      '|
      style.fill: "#FFF3E0"
    }
    index_calc: {
      label: "slot = hash % capacity"
      code: |'c
        size_t slot = hash % 1024;
        // slot = 42
      '|
      style.fill: "#E3F2FD"
    }
    input_box -> hash_func -> index_calc
  }

  step2: {
    direction: down
    label: "Step 2: Linear Probe (Index 42)"
    keys_array_1: {
      shape: sql_table
      label: "keys[] Array (CL 0: 0x1000)"
      idx40: "idx 40 | 0x0000... (empty)"
      idx41: "idx 41 | 0x0000... (empty)"
      idx42: "idx 42 | 0x8A7B... (profile_id)"
      style.fill: "#FAFAFA"
    }
    check_result: {
      label: "MISMATCH: keys[42] != 0x7A3F..."
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.bold: true
    }
    probe_dist_check: {
      shape: sql_table
      label: "probe_dist[] check"
      dist42: "pd[42] = 0 (Ideal Slot)"
      meta: "Logic: pd[42] < current_dist(0) is false"
      style.fill: "#FFF8E1"
    }
    keys_array_1 -> check_result -> probe_dist_check
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step3: {
    direction: down
    label: "Step 3: Linear Probe (Index 43)"
    keys_array_2: {
      shape: sql_table
      label: "keys[] Array (CL 0: 0x1000)"
      idx42: "idx 42 | 0x8A7B... (profile_id)"
      idx43: "idx 43 | 0x7A3F... (MATCH!)"
      style.fill: "#E8F5E9"
    }
    check_hit: {
      label: "SUCCESS: keys[43] == target_hash"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      style.bold: true
    }
    robin_hood_logic: {
      label: "Robin Hood Rules"
      code: |'c
        pd[43] = 1 (1 slot from ideal)
        my_probe = 1
        // my_probe >= pd[43] (Continue)
        // keys[43] == target (Found)
      '|
      style.fill: "#E3F2FD"
    }
    keys_array_2 -> check_hit -> robin_hood_logic
  }

  step4: {
    direction: down
    label: "Step 4: Value Fetch"
    values_array: {
      shape: sql_table
      label: "values[] Array (CL 5: 0x1500)"
      val42: "val[42] | 0xDEADC0DE"
      val43: "val[43] | 0xCAFEBABE"
      style.fill: "#F3E5F5"
    }
    return_result: {
      label: "Result Pointer"
      code: |'c
        void* ptr = &values[43];
        return *(uint64_t*)ptr;
        // returns 0xCAFEBABE
      '|
      style.fill: "#C8E6C9"
      style.bold: true
    }
    values_array -> return_result
  }
}

row3: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent

  cache_summary: {
    label: "Cache Performance Analysis"
    content: |'md
      **Total L1 Accesses: 2 Cache Lines**
      
      | Target | Memory Address | L1 State | Overhead |
      |--------|----------------|----------|----------|
      | keys[42] | 0x1000 (CL 0) | Cold Miss | 100ns (DRAM) |
      | pd[42]   | 0x1100 (CL 1) | Cold Miss | 100ns (DRAM) |
      | keys[43] | 0x1008 (CL 0) | **L1 Hit** | **~0.5ns** |
      | values[43]| 0x1518 (CL 5) | Cold Miss | 100ns (DRAM) |

      **Implementation Insight**: 
      Linear probing maximizes spatial locality. Probing index 43 after 42 
      is "free" as it resides in the same 64-byte cache line.
    '|
    style.fill: "#ECEFF1"
  }
}

# Connections between steps
row1.step1.index_calc -> row1.step2.keys_array_1: "slot=42"
row1.step2.probe_dist_check -> row2.step3.keys_array_2: "next_slot=43"
row2.step3.robin_hood_logic -> row2.step4.values_array: "found_at=43"

memory_layout: {
  label: "Memory Segment Layout (Flat Addressing)"
  direction: right
  keys: {
    label: "Keys (Hash Codes)"
    shape: cylinder
    style.fill: "#FFEBEE"
  }
  metadata: {
    label: "Metadata (Probe Dist)"
    shape: cylinder
    style.fill: "#FFF8E1"
  }
  values: {
    label: "Values (Pointers/Data)"
    shape: cylinder
    style.fill: "#F3E5F5"
  }
  keys -> metadata: "contiguous"
  metadata -> values: "contiguous"
}

legend: {
  shape: sql_table
  label: "Color Semantics"
  green: "Data Found / Success Path"
  red: "Miss / Collison"
  blue: "Computation / Logic"
  purple: "Memory Access"
}
legend.near: bottom-right