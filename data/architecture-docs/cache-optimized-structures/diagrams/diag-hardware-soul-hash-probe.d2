direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "Hardware Soul: Hash Table Probe Sequence"
  subtitle: "Linear probing loop analysis at the microarchitecture level"
}

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  loop_logic: {
    label: "Probe Loop (hash_table.c)"
    width: 450
    code: |'c
      size_t slot = hash % capacity;
      uint8_t probe_so_far = 0;
      while (true) {
        __builtin_prefetch(&keys[slot + 8], 0, 3);
        if (metadata[slot] == EMPTY) return NULL;
        if (keys[slot] == target) return &values[slot];
        slot++;
        probe_so_far++;
      }
    '|
  }

  cache_hierarchy: {
    label: "Memory Hierarchy Impact"
    direction: down
    
    cl0: {
      label: "Cache Line 0 (0-63B)"
      shape: rectangle
      style.fill: "#E8F5E9"
      content: |'md
        - `keys[0-7]`
        - `meta[0-7]`
      '|
    }
    cl1: {
      label: "Cache Line 1 (64-127B)"
      shape: rectangle
      style.fill: "#E3F2FD"
      content: |'md
        - `keys[8-15]`
        - `meta[8-15]`
      '|
    }
    
    analysis: {
      label: "Access Pattern"
      shape: rectangle
      style.fill: "#F5F5F5"
      body: |'md
        **Contiguous Stride**
        - Sequential progression
        - 8 keys per 64B line
        - 1 miss per 8 probes
      '|
    }
    cl0 -> cl1: "Stride +1"
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  branch_prediction: {
    label: "Branch Prediction Analysis"
    direction: down
    
    bp_loop: "Loop Continue?" {
      shape: diamond
      style.fill: "#C8E6C9"
    }
    bp_match: "Key Match?" {
      shape: diamond
      style.fill: "#FFECB3"
    }
    
    report: {
      label: "Predictability Report"
      shape: rectangle
      content: |'md
        - **Loop Exit**: Predictable (learned stride)
        - **Key Match**: Unpredictable (random hash)
        - **Mispredict Cost**: ~15-20 CPU cycles
      '|
    }
    bp_loop -> bp_match: "True"
  }

  tlb_stats: {
    label: "TLB Impact & Paging"
    direction: down
    
    tlb_small: {
      label: "Small Table (4KB Page)"
      shape: rectangle
      style.fill: "#E8F5E9"
      body: "1024 slots fit in 1 entry. Zero pressure."
    }
    
    tlb_huge: {
      label: "Large Table (2MB Page)"
      shape: rectangle
      style.fill: "#FFF3E0"
      body: "mmap(MAP_HUGETLB) reduces TLB misses by 512x."
    }
    
    tlb_small -> tlb_huge: "Scalability Path"
  }

  prefetch_dist: {
    label: "Software Prefetching"
    direction: down
    
    pf_config: {
      label: "Distance Tuning"
      code: |'c
        // Dist 8 = 8 probes ahead
        // Hides ~200cyc latency
        __builtin_prefetch(
          &keys[slot + 8], 
          0, 3
        );
      '|
    }
    
    pf_chart: {
      label: "Timing Diagram"
      shape: rectangle
      body: |'md
        Cycle: 0...50...100...200
        Probe: [N]  [N+1]  [N+2]
        Fetch: └────────────> [N+8] Ready
      '|
    }
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  metrics_table: {
    shape: sql_table
    label: "Micro-op Cost Latency (CPU Cycles)"
    r1: "Operation | Latency | Hardware Component"
    r2: "L1 Hit | 4 | Level 1 Data Cache"
    r3: "L2 Hit | 12 | Level 2 Unified Cache"
    r4: "L3 Hit | 40 | Level 3 Shared Cache"
    r5: "RAM Miss | 200+ | Main Memory (DDR4/5)"
    r6: "Branch Mis | 15 | Branch Predictor Unit"
    r7: "TLB Miss | 10-100 | Page Table Walker"
    footer: "Amortized Probe: ~5-10 cycles (with L1 hit)"
  }

  arch_comparison: {
    label: "Memory Access Comparison"
    direction: right
    
    chained: {
      label: "Chained Hashing"
      style.fill: "#FFEBEE"
      content: |'md
        - Pointer chasing
        - Multiple random misses
        - ~1000+ cycles
      '|
    }
    
    open_addr: {
      label: "Open Addressing"
      style.fill: "#E8F5E9"
      content: |'md
        - Contiguous cache lines
        - 1 initial miss
        - ~250 cycles (4x gain)
      '|
    }
    
    chained -> open_addr: "Hardware Affinity"
  }
}

legend: {
  near: bottom-right
  shape: rectangle
  label: "Manual Legend"
  body: |'md
    - 🟢 Low Latency (Cache/Predictable)
    - 🟠 High Latency (RAM/Unpredictable)
    - 🔵 Tuning Opportunity
  '|
}

row1 -> row2: "Data Dependency"
row2 -> row3: "Performance Result"