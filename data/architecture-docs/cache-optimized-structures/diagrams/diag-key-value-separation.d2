direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Key-Value Separation for Cache Efficiency"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  combined: {
    direction: down
    label: "Combined Layout (Traditional)"
    style.fill: "#FFF0F0"
    combined_desc: {
      shape: text
      label: "Key and value stored together in each slot"
    }
    combined_table: {
      shape: sql_table
      label: "Entry slots"
      f0: "0x00 | uint64_t | key"
      f1: "0x08 | uint64_t | value"
      f2: "0x10 | uint8_t  | metadata"
      f3: "0x11 | uint8_t  | probe_dist"
      sz: "24 bytes per entry"
    }
    combined_cache: {
      label: "Cache Line Utilization"
      cache_line: {
        shape: rectangle
        label: |md
          64 bytes = 2.6 entries
          Probe 5 slots = 2 cache lines
        |
      }
    }
    combined_problem: {
      label: "Problem"
      shape: diamond
      style.fill: "#FFCCCC"
    }
    combined_table -> combined_cache: "probes"
    combined_cache -> combined_problem: "loads value\non every probe"
  }
  arrow: {
    shape: text
    label: "→"
    style: {
      font-size: 48
      bold: true
    }
  }
  separated: {
    direction: down
    label: "Separated Layout (Optimized)"
    style.fill: "#F0FFF0"
    separated_desc: {
      shape: text
      label: "Keys and values in separate arrays"
    }
    keys_array: {
      shape: sql_table
      label: "keys[] (hot path)"
      k0: "0x00 | uint64_t | key[0]"
      k1: "0x08 | uint64_t | key[1]"
      k2: "0x10 | uint64_t | key[2]"
      k3: "0x18 | uint64_t | key[3]"
      k4: "0x20 | uint64_t | key[4]"
      k5: "0x28 | uint64_t | key[5]"
      k6: "0x30 | uint64_t | key[6]"
      k7: "0x38 | uint64_t | key[7]"
      ks: "8 keys per cache line"
      style.fill: "#E8F5E9"
    }
    values_array: {
      shape: sql_table
      label: "values[] (cold path)"
      v0: "index 0 | uint64_t | value[0]"
      v1: "index 1 | uint64_t | value[1]"
      v2: "index 2 | uint64_t | value[2]"
      v3: "index 3 | uint64_t | value[3]"
      v4: "index 4 | uint64_t | value[4]"
      v5: "index 5 | uint64_t | value[5]"
      v6: "index 6 | uint64_t | value[6]"
      v7: "index 7 | uint64_t | value[7]"
      vs: "Accessed ONLY on match"
      style.fill: "#E3F2FD"
    }
    separated_cache: {
      label: "Cache Line Utilization"
      cache_line: {
        shape: rectangle
        label: |md
          64 bytes = 8 keys
          Probe 5 slots = 1 cache line
        |
      }
    }
    separated_benefit: {
      label: "Benefit"
      shape: diamond
      style.fill: "#CCFFCC"
    }
    keys_array -> separated_cache: "probes"
    separated_cache -> separated_benefit: "values NOT loaded\nduring probe"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  lookup_flow: {
    label: "Lookup Flow"
    style.fill: "#F5F5F5"
    step1: {
      label: "1. Hash Key"
      code: |'c
        hash = hash_func(key)
        slot = hash % capacity
      '|
      width: 320
    }
    step2: {
      label: "2. Probe keys[] Only"
      code: |'c
        while (keys[slot] != target) {
          slot = (slot + 1) % capacity;
          // Only keys[] touched!
          // values[] NOT in cache
        }
      '|
      width: 320
    }
    step3: {
      label: "3. Access Value Once"
      code: |'c
        // Found at slot 5
        return &values[slot]; // ONE cache miss
      '|
      width: 320
    }
    step1 -> step2: "slot index"
    step2 -> step3: "found at\nslot N"
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  comparison: {
    label: "Cache Line Comparison"
    metric: {
      shape: sql_table
      label: "Metrics"
      m1: "Keys per cache line"
      m2: "Probe 5 slots (cache lines)"
      m3: "Values loaded during probe"
      m4: "Total cache lines for lookup"
    }
    combined_metrics: {
      shape: sql_table
      label: "Combined"
      c1: "2.6 keys"
      c2: "~2 cache lines"
      c3: "5 values (wasted!)"
      c4: "2-3 cache lines"
      style.fill: "#FFE0E0"
    }
    separated_metrics: {
      shape: sql_table
      label: "Separated"
      s1: "8 keys"
      s2: "1 cache line"
      s3: "0 values"
      s4: "2 cache lines (1 for keys, 1 for value on hit)"
      style.fill: "#E0FFE0"
    }
    metric -> combined_metrics
    metric -> separated_metrics
  }
  savings: {
    label: "Memory Bandwidth Savings"
    bandwidth_calc: |md
      **For 5-slot probe with hit:**
      Combined: Load 5 × 24 bytes = 120 bytes
      Separated: Load 5 × 8 bytes + 1 × 8 bytes = 48 bytes
      **Savings: 2.5× less memory traffic**
      For value types larger than uint64_t,
      the savings are even greater.
    |
  }
}
legend: {
  near: bottom-right
  hot: {
    label: "Hot Path (keys[])"
    shape: rectangle
    style.fill: "#E8F5E9"
  }
  cold: {
    label: "Cold Path (values[])"
    shape: rectangle
    style.fill: "#E3F2FD"
  }
  hot -> cold: {
    style: {
      stroke-dash: 3
    }
  }
}