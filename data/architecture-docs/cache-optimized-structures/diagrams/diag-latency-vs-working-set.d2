direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Cache Hierarchy: Latency vs Working Set Size
  The visual signature of cache boundaries
|
title.near: top-center

row_main: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  graph_area: {
    direction: down
    width: 700
    y_axis_label: "Access Latency (cycles, log scale)"
    y_axis_label.style.font-size: 14
    y_axis_label.style.font-color: "#666"
    y_axis_label.style.italic: true
  }
}

row_legend: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  legend_box: {
    width: 600
    style.fill: "#f8f9fa"
    style.stroke: "#dee2e6"
    style.border-radius: 8
    leg_title: "Cache Level Boundaries"
    leg_title.style.bold: true
    leg_title.style.font-size: 14
    legs: {
      direction: right
      leg1: {
        l1_box: {
          width: 16
          height: 16
          style.fill: "#2ecc71"
          style.stroke: "#27ae60"
        }
        l1_label: "L1 Cache (4 cycles)"
      }
      leg2: {
        l2_box: {
          width: 16
          height: 16
          style.fill: "#3498db"
          style.stroke: "#2980b9"
        }
        l2_label: "L2 Cache (12 cycles)"
      }
      leg3: {
        l3_box: {
          width: 16
          height: 16
          style.fill: "#f39c12"
          style.stroke: "#e67e22"
        }
        l3_label: "L3 Cache (40 cycles)"
      }
      leg4: {
        ram_box: {
          width: 16
          height: 16
          style.fill: "#e74c3c"
          style.stroke: "#c0392b"
        }
        ram_label: "RAM (200+ cycles)"
      }
    }
  }
}

row_data: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  data_box: {
    width: 680
    style.fill: "#fafbfc"
    style.stroke: "#e1e4e8"
    style.border-radius: 4
    graph_title: "Pointer-Chasing Latency Measurement"
    graph_title.style.bold: true
    graph_title.style.font-size: 16
    
    plot_data: {
      width: 640
      data_title: "Benchmark Results"
      data_title.style.bold: true
      row1: {
        direction: right
        col1: {
          label: "Working Set"
          label.style.bold: true
          label.style.fill: "#f1f3f5"
        }
        col2: {
          label: "Latency"
          label.style.bold: true
          label.style.fill: "#f1f3f5"
        }
        col3: {
          label: "Cache Level"
          label.style.bold: true
          label.style.fill: "#f1f3f5"
        }
        col4: {
          label: "Status"
          label.style.bold: true
          label.style.fill: "#f1f3f5"
        }
      }
      r0: {
        direction: right
        ws: "4 KB"
        lat: "4.2 cycles"
        lvl: "L1"
        stat: "HIT"
        stat.style.fill: "#2ecc71"
        stat.style.font-color: white
      }
      r1: {
        direction: right
        ws: "16 KB"
        lat: "4.1 cycles"
        lvl: "L1"
        stat: "HIT"
        stat.style.fill: "#2ecc71"
        stat.style.font-color: white
      }
      r2: {
        direction: right
        ws: "32 KB"
        lat: "4.3 cycles"
        lvl: "L1"
        stat: "HIT"
        stat.style.fill: "#2ecc71"
        stat.style.font-color: white
      }
      r3: {
        direction: right
        ws: "64 KB"
        lat: "11.8 cycles"
        lvl: "L2"
        stat: "STEP"
        stat.style.fill: "#f39c12"
        stat.style.font-color: white
      }
      r4: {
        direction: right
        ws: "256 KB"
        lat: "12.2 cycles"
        lvl: "L2"
        stat: "HIT"
        stat.style.fill: "#3498db"
        stat.style.font-color: white
      }
      r5: {
        direction: right
        ws: "512 KB"
        lat: "38.5 cycles"
        lvl: "L3"
        stat: "STEP"
        stat.style.fill: "#f39c12"
        stat.style.font-color: white
      }
      r6: {
        direction: right
        ws: "4 MB"
        lat: "42.1 cycles"
        lvl: "L3"
        stat: "HIT"
        stat.style.fill: "#f39c12"
        stat.style.font-color: white
      }
      r7: {
        direction: right
        ws: "16 MB"
        lat: "185 cycles"
        lvl: "RAM"
        stat: "STEP"
        stat.style.fill: "#e74c3c"
        stat.style.font-color: white
      }
      r8: {
        direction: right
        ws: "64 MB"
        lat: "210 cycles"
        lvl: "RAM"
        stat: "MISS"
        stat.style.fill: "#e74c3c"
        stat.style.font-color: white
      }
    }
    axis_x_label: "Working Set Size (bytes, log scale)"
    axis_x_label.style.font-size: 12
    axis_x_label.style.font-color: "#666"
  }
}

row_insight: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  insight_box: {
    width: 680
    style.fill: "#e8f4f8"
    style.stroke: "#17a2b8"
    style.border-radius: 8
    insight_title: "Key Insight"
    insight_title.style.bold: true
    insight_title.style.font-size: 16
    insight_title.style.font-color: "#17a2b8"
    insight_text: |md
      The "step function" pattern reveals cache boundaries:
      - **L1→L2**: Latency jumps ~3x at 32KB (typical L1 size)
      - **L2→L3**: Latency jumps ~3x at 256KB-1MB (typical L2 size)  
      - **L3→RAM**: Latency jumps ~5x at 8-64MB (typical L3 size)
      This is how `detect_cache_sizes()` discovers hardware parameters by measuring latency inflection points.
    |
  }
}

row_code: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  code_box: {
    width: 680
    label: "Core Measurement Loop (cache_profiler.c)"
    label.style.bold: true
    label.style.fill: "#2d3748"
    label.style.font-color: white
    code: |'c
      // Pointer-chasing defeats hardware prefetchers
      void* current = &buffer[perm[0]];
      uint64_t start = rdtsc();
      for (int i = 0; i < iterations; i++) {
          current = *(void**)current;  // Dependency chain
          current = *(void**)current;
          current = *(void**)current;
          current = *(void**)current;  // 4 unrolled iterations
      }
      uint64_t end = rdtsc();
      double cycles_per_access = (end - start) / (iterations * 4.0);
    '|
    code.style.fill: "#1e1e1e"
    code.style.font: mono
    code.style.font-size: 11
    code.style.font-color: "#d4d4d4"
    code.width: 660
  }
}

row_arch: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  arch_box: {
    width: 680
    label: "Memory Hierarchy Architecture"
    label.style.bold: true
    levels: {
      direction: down
      cpu: "CPU Core" {
        style.fill: "#2d3748"
        style.font-color: white
        width: 120
      }
      l1: "L1 Cache (32 KB)" {
        style.fill: "#2ecc71"
        style.font-color: white
        width: 120
      }
      l2: "L2 Cache (256 KB - 1 MB)" {
        style.fill: "#3498db"
        style.font-color: white
        width: 180
      }
      l3: "L3 Cache (8 - 64 MB)" {
        style.fill: "#f39c12"
        style.font-color: white
        width: 260
      }
      ram: {
        shape: cylinder
        label: "RAM (8 - 128 GB)"
        style.fill: "#e74c3c"
        style.font-color: white
        width: 300
      }

      cpu -> l1: "4 cycles"
      l1 -> l2: "12 cycles"
      l2 -> l3: "40 cycles"
      l3 -> ram: "200+ cycles"
    }
  }
}

row_summary: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  summary_box: {
    width: 680
    style.fill: "#fff3cd"
    style.stroke: "#856404"
    style.border-radius: 8
    summary_title: "M1 Success Criteria"
    summary_title.style.bold: true
    summary_title.style.font-size: 14
    summary_text: |md
      ✓ Latency graph shows clear inflection points at cache boundaries
      ✓ Pointer-chasing technique defeats prefetchers (dependency chain)
      ✓ L1→L2 step at ~32KB, L2→L3 step at ~256KB-1MB
      ✓ RAM latency 50-100x higher than L1
      ✓ Warmup iterations eliminate page fault noise
    |
  }
}

row_main.graph_area -> row_legend.legend_box
row_legend.legend_box -> row_data.data_box
row_data.data_box -> row_insight.insight_box
row_insight.insight_box -> row_code.code_box
row_code.code_box -> row_arch.arch_box
row_arch.arch_box -> row_summary.summary_box