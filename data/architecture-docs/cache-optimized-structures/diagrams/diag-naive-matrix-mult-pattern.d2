direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_block: {
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#343a40"
  style.stroke-width: 2
  content: |md
    # Naive Matrix Multiplication Access Pattern
    Logic: `C[i][j] = Σ(A[i][k] × B[k][j])` for `k=0` to `K-1`
  |
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  matrix_a: {
    label: "Matrix A (M×K)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    
    row_access: {
      label: "Row i (Stride: 1)"
      grid-columns: 6
      style.fill: "#C8E6C9"
      a0: "A[i][0]"
      a1: "A[i][1]"
      a2: "A[i][2]"
      a3: "A[i][3]"
      a4: "..."
      ak: "A[i][K-1]"
    }
    
    other_rows: "Padding / Other Rows" {
      style.stroke-dash: 3
      style.fill: "#f1f1f1"
      style.opacity: 0.5
    }
  }

  operator_mul: {
    shape: rectangle
    label: "×"
    style.font-size: 40
    style.stroke: transparent
    style.fill: transparent
  }

  matrix_b: {
    label: "Matrix B (K×N)"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    
    col_access: {
      label: "Column j (Stride: K)"
      grid-rows: 6
      style.fill: "#FFCDD2"
      b0: "B[0][j]"
      b1: "B[1][j]"
      b2: "B[2][j]"
      b3: "B[3][j]"
      b4: "..."
      bk: "B[K-1][j]"
    }

    other_cols: "Padding / Other Columns" {
      style.stroke-dash: 3
      style.fill: "#f1f1f1"
      style.opacity: 0.5
    }
  }

  operator_eq: {
    shape: rectangle
    label: "="
    style.font-size: 40
    style.stroke: transparent
    style.fill: transparent
  }

  matrix_c: {
    label: "Matrix C (M×N)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    
    result_cell: {
      shape: circle
      label: "C[i][j]"
      style.fill: "#BBDEFB"
      style.bold: true
    }
    
    context: "Dot Product Result" {
      style.stroke-dash: 3
      style.fill: "#f1f1f1"
      style.opacity: 0.5
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  analysis_a: {
    label: "Matrix A: Sequential Access"
    width: 350
    style.fill: "#E8F5E9"
    code: |'c
      // Row-major: A[i][k] and A[i][k+1] 
      // are adjacent in memory.
      ptr = &A[i][0];
      for (k=0; k<K; k++) {
        sum += ptr[k] * B[k][j];
      }
      // Result: High spatial locality.
      // One 64B fetch = 16 floats.
    '|
  }

  analysis_b: {
    label: "Matrix B: Strided Access"
    width: 350
    style.fill: "#FFEBEE"
    code: |'c
      // Column-access: B[k][j] and B[k+1][j]
      // are separated by K elements.
      for (k=0; k<K; k++) {
        val = B[k * N + j]; 
        // Stride = N * sizeof(float)
        // If N=1024, Stride = 4KB
      }
      // Result: Zero spatial locality.
    '|
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  memory_viz: {
    label: "L1 Cache Line Utilization"
    width: 720
    content: |'md
      ### Matrix A (Sequential)
      | Cache Line Offset | 0 | 4 | 8 | 12 | ... | 60 |
      | :--- | :--- | :--- | :--- | :--- | :--- | :--- |
      | **Line 0** | A[i][0] | A[i][1] | A[i][2] | A[i][3] | ... | A[i][15] |
      | **Status** | **HIT** | **HIT** | **HIT** | **HIT** | ... | **HIT** |
      *Utilization: 100%. 1 Miss per 16 elements.*

      ### Matrix B (Strided)
      | Cache Line Offset | 0 | 4 | 8 | 12 | ... | 60 |
      | :--- | :--- | :--- | :--- | :--- | :--- | :--- |
      | **Line X** | B[0][j] | (wasted) | (wasted) | (wasted) | ... | (wasted) |
      | **Line Y** | B[1][j] | (wasted) | (wasted) | (wasted) | ... | (wasted) |
      *Utilization: 6.25%. 1 Miss per 1 element.*
    '|
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  perf_stats: {
    label: "Performance Impact (Cycle Penalty)"
    width: 720
    style.fill: "#fff3e0"
    table: |'md
      | Metric | Matrix A (Row) | Matrix B (Col) | Impact |
      | :--- | :--- | :--- | :--- |
      | **Access Pattern** | Sequential | Strided (Stride > 64B) | - |
      | **Effective Bandwidth** | ~100% of Max | < 10% of Max | **Severe BottleNeck** |
      | **Prefetcher** | Success | Confused / Thrashed | **High Latency** |
      | **Misses (N=1024)** | 64,000 | 1,048,576 | **16x more misses** |
    '|
  }
}

matrix_a.row_access -> matrix_c.result_cell: "Read | Seq" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

matrix_b.col_access -> matrix_c.result_cell: "Read | Stride" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.stroke-dash: 4
}

legend: {
  near: bottom-right
  direction: right
  style.fill: "#f8f9fa"
  
  good: "Cache Friendly" {
    style.fill: "#C8E6C9"
    shape: rectangle
  }
  bad: "Cache Hostile" {
    style.fill: "#FFCDD2"
    shape: rectangle
  }
}