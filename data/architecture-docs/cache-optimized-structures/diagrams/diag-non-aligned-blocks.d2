row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  code_block: {
    direction: down
    label: "Edge Handling Code (matmul_blocked.c)"
    width: 420
    code: |'c
      // Calculate actual block size with boundary check
      int i_max = (i0 + block_size < M) 
                  ? i0 + block_size 
                  : M;  // Clamp to matrix dimension
      int j_max = (j0 + block_size < N) 
                  ? j0 + block_size 
                  : N;
      int k_max = (k0 + block_size < K) 
                  ? k0 + block_size 
                  : K;
      // Process block with actual dimensions
      for (int i = i0; i < i_max; i++) {
        for (int j = j0; j < j_max; j++) {
          for (int k = k0; k < k_max; k++) {
            C[i*n + j] += A[i*n + k] * B[k*n + j];
          }
        }
      }
    '|
  }
  math_block: {
    direction: down
    label: "Block Grid Calculation"
    width: 320
    calc: |md
      Matrix: 1000×1000, block_size = 32
      **Full blocks:** floor(1000/32) = 31
      **Remainder:** 1000 - (31 × 32) = 8
      **Block grid:** 32 × 32 blocks total
      - Interior: 31 × 31 = 961 full blocks
      - Right edge: 31 × 1 = 31 vertical edge (8×32)
      - Bottom edge: 1 × 31 = 31 horizontal edge (32×8)
      - Corner: 1 × 1 = 1 corner block (8×8)
      **Total:** 1024 blocks
    |
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  perf_note: {
    direction: down
    label: "Performance Impact"
    width: 380
    content: |md
      Edge blocks have **lower efficiency**:
      • Smaller working set → less cache reuse
      • Same loop overhead → higher overhead ratio
      • 8×8 corner: only 512 ops vs 32,768 for full block
      **Impact is minimal** for large matrices:
      • 961 full blocks vs 63 edge blocks
      • Edge blocks: ~6% of total computation
    |
  }
  correctness_note: {
    direction: down
    label: "Correctness Guarantee"
    width: 380
    content: |md
      The `min()` boundary calculation ensures:
      ✓ No out-of-bounds array access
      ✓ All matrix elements processed exactly once
      ✓ Result matches naive implementation
      **Key insight:** The ternary operator handles
      both aligned and non-aligned cases uniformly.
    |
  }
}
matrix_viz -> code_block: "boundary logic" {
  style.stroke-dash: 3
  style.stroke: "#666666"
}