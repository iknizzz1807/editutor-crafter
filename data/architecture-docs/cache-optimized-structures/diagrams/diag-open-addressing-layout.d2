direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Open Addressing: Contiguous Memory Layout
  Single array storage with linear probing — hardware prefetcher friendly
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hash_section: {
    direction: down
    label: "Hash Function"
    hash_func: {
      shape: class
      label: "hash(key) → slot"
      +hash_key(key): "size_t"
    }
    hash_result: {
      label: "hash(42) = 3"
      width: 140
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
  }
  hash_func -> hash_result: "compute"
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  array_section: {
    direction: down
    label: "Entry Array (Contiguous Memory)"
    entries: {
      shape: sql_table
      label: "HashEntry entries[N] — Single Allocation"
      slot0: "0 | EMPTY    | —    | —"
      slot1: "1 | OCCUPIED | 17   | val_17"
      slot2: "2 | OCCUPIED | 31   | val_31"
      slot3: "3 | OCCUPIED | 42   | val_42"
      slot4: "4 | OCCUPIED | 58   | val_58"
      slot5: "5 | OCCUPIED | 42   | val_42b"
      slot6: "6 | EMPTY    | —    | —"
      slot7: "7 | OCCUPIED | 91   | val_91"
      note: "Cache line: 64 bytes = ~4 entries"
    }
    entries.style.fill: "#E3F2FD"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  probe_section: {
    direction: down
    label: "Linear Probe Sequence"
    width: 450
    step1: {
      label: "Step 1: Check slot 3"
      code: |'c
        slot = hash(42) % 8 = 3
        entries[3].key == 42? YES → FOUND!
      '|
      width: 420
      style.fill: "#C8E6C9"
    }
    step2: {
      label: "Step 2: If collision, probe forward"
      code: |'c
        // entries[3] occupied by different key
        slot = (slot + 1) % 8  // → 4
        entries[4].key == 42? NO
        slot = (slot + 1) % 8  // → 5
        entries[5].key == 42? YES → FOUND!
      '|
      width: 420
      style.fill: "#FFF9C4"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cache_section: {
    direction: down
    label: "Cache Behavior"
    width: 450
    cache_line: {
      shape: sql_table
      label: "L1 Cache Line (64 bytes)"
      cl0: "entries[0-3] | 64 bytes | Loaded on first access"
      cl1: "entries[4-7] | 64 bytes | Prefetched automatically"
    }
    cache_line.style.fill: "#F3E5F5"
  }
  prefetcher: {
    direction: down
    label: "Hardware Prefetcher"
    width: 280
    pf_active: {
      label: "✓ Sequential pattern detected"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    pf_action: {
      label: "→ Fetches cache line 4-7\n   before CPU requests it"
      style.fill: "#E8F5E9"
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  benefits: {
    direction: down
    label: "Why This Is Cache-Friendly"
    b1: {
      label: "1. Single Allocation"
      width: 200
      style.fill: "#E8F5E9"
    }
    b2: {
      label: "2. Sequential Probing"
      width: 200
      style.fill: "#E8F5E9"
    }
    b3: {
      label: "3. Prefetcher Engaged"
      width: 200
      style.fill: "#E8F5E9"
    }
    b4: {
      label: "4. No Pointer Chasing"
      width: 200
      style.fill: "#E8F5E9"
    }
  }
  comparison: {
    direction: down
    label: "vs Chained Hash"
    c1: {
      label: "❌ Multiple allocations"
      width: 200
      style.fill: "#FFEBEE"
    }
    c2: {
      label: "❌ Random pointer jumps"
      width: 200
      style.fill: "#FFEBEE"
    }
    c3: {
      label: "❌ Prefetcher confused"
      width: 200
      style.fill: "#FFEBEE"
    }
    c4: {
      label: "❌ ~5x more cache misses"
      width: 200
      style.fill: "#FFEBEE"
    }
  }
}
hash_section.hash_result -> array_section.entries.slot3: "initial probe" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
array_section.entries.slot3 -> array_section.entries.slot4: "probe+1" {
  style.stroke: "#2196F3"
  style.stroke-dash: 4
}
array_section.entries.slot4 -> array_section.entries.slot5: "probe+1" {
  style.stroke: "#2196F3"
  style.stroke-dash: 4
}
array_section.entries -> cache_section.cache_line: "cache line load" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
cache_section.cache_line -> prefetcher.pf_active: "triggers" {
  style.stroke: "#9C27B0"
}