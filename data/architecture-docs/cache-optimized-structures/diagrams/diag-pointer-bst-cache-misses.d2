direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Pointer-Based BST: One Cache Miss Per Level
  Each pointer hop → new heap allocation → new cache line fetch
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  tree_col: {
    direction: down
    label: "BST Structure (heap allocations)"
    level0: {
      label: "Level 0"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 3
      width: 140
      root: {
        shape: class
        label: "Node (root)"
        -key: "int"
        -left: "Node*"
        -right: "Node*"
      }
    }
    level1: {
      direction: right
      label: "Level 1"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.stroke-width: 3
      width: 300
      l1_left: {
        shape: class
        label: "Node"
        -key: "int"
        -left: "Node*"
        -right: "Node*"
      }
      l1_right: {
        shape: class
        label: "Node"
        -key: "int"
        -left: "Node*"
        -right: "Node*"
      }
    }
    level2: {
      direction: right
      label: "Level 2"
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      style.stroke-width: 3
      width: 300
      l2_left: {
        shape: class
        label: "Node"
        -key: "int"
        -left: "Node*"
        -right: "Node*"
      }
      l2_right: {
        shape: class
        label: "Node"
        -key: "int"
        -left: "Node*"
        -right: "Node*"
      }
    }
    root -> l1_left: "left\nptr" {
      style.stroke: "#4CAF50"
      style.stroke-width: 3
      style.animated: true
    }
    root -> l1_right: "right\nptr" {
      style.stroke: "#9E9E9E"
      style.stroke-dash: 3
    }
    l1_left -> l2_left: "ptr" {
      style.stroke: "#FF9800"
      style.stroke-width: 3
      style.animated: true
    }
    l1_left -> l2_right: "ptr" {
      style.stroke: "#9E9E9E"
      style.stroke-dash: 3
    }
  }
  spacer: {
    width: 60
    style.fill: transparent
    style.stroke: transparent
  }
  cache_col: {
    direction: down
    label: "Cache Line Fetches"
    style.fill: transparent
    style.stroke: "#1565C0"
    style.stroke-dash: 4
    cl0: {
      label: "Cache Line 0"
      shape: sql_table
      row0: "0x00-0x03 | int   | key"
      row1: "0x04-0x07 | ptr   | left"
      row2: "0x08-0x0B | ptr   | right"
      waste0: "0x0C-0x3F | —     | UNUSED (52 bytes)"
      total0: "64 bytes loaded, 12 used"
      style.fill: "#E8F5E9"
    }
    cl1: {
      label: "Cache Line 1"
      shape: sql_table
      row0: "0x00-0x03 | int   | key"
      row1: "0x04-0x07 | ptr   | left"
      row2: "0x08-0x0B | ptr   | right"
      waste1: "0x0C-0x3F | —     | UNUSED (52 bytes)"
      total1: "64 bytes loaded, 12 used"
      style.fill: "#FFF3E0"
    }
    cl2: {
      label: "Cache Line 2"
      shape: sql_table
      row0: "0x00-0x03 | int   | key"
      row1: "0x04-0x07 | ptr   | left"
      row2: "0x08-0x0B | ptr   | right"
      waste2: "0x0C-0x3F | —     | UNUSED (52 bytes)"
      total2: "64 bytes loaded, 12 used"
      style.fill: "#FFEBEE"
    }
  }
}
waste_analysis: {
  label: "Bandwidth Waste Analysis"
  width: 500
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  analysis: |md
    **Per Level:**
    - Cache line fetched: **64 bytes**
    - Node size: **12-16 bytes** (key + 2 pointers)
    - Useful data: **18.75-25%**
    - **Wasted: 48-52 bytes (75-81%)**
    **For 20-level tree (1M nodes):**
    - Cache misses: **20** (one per level)
    - Total bandwidth: **1280 bytes**
    - Useful data: **240-320 bytes**
    - **Wasted: 960-1040 bytes**
  |
}
cost_table: {
  label: "Cache Miss Cost Per Level"
  shape: sql_table
  l0: "Level 0 (root)  | L2/L3 hit  | ~12-40 cycles"
  l1: "Level 1         | L3/RAM     | ~40-200 cycles"
  l2: "Level 2         | RAM miss   | ~200+ cycles"
  ln: "Level n         | RAM miss   | ~200+ cycles each"
  total: "Total (20 levels) | ~3000-4000 cycles"
  note: "Each pointer chase = potential cache miss"
}
heap_layout: {
  label: "Heap Memory Layout (Scattered)"
  width: 480
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  heap: |md
    
    Heap Address Space (fragmented):
    0x7F1000: [Node A] ←── root
    0x7F2A40: [Node B] ←── A.left (158 KB away!)
    0x7F1840: [Node C] ←── B.right (47 KB away)
    0x7F3100: [Node D] ←── C.left (62 KB away)
    ...
    Problem: No spatial locality!
    - Parent and child rarely in same cache line
    - Prefetcher cannot predict pointer targets
    - Every hop = cache miss gamble
    
  |
}
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: transparent
  legend_content: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    hit: {
      label: "→ Search path (animated)"
      style.fill: "#E8F5E9"
    }
    miss: {
      label: "⇢ Not traversed"
      style.fill: "#F5F5F5"
    }
  }
}