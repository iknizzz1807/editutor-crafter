direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Robin Hood Hashing: Probe Distance Invariant
  **"Steal from the rich (low PSL), give to the poor (high PSL)"**
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  naive: {
    direction: down
    label: "Naive Linear Probing"
    naive_before: {
      label: "Before Insertions"
      width: 400
      slots_nb: {
        shape: sql_table
        label: "Hash Table Slots"
        s0: "0 | Key:A | PSL:0"
        s1: "1 | Key:B | PSL:0"
        s2: "2 | Key:C | PSL:1"
        s3: "3 | Key:D | PSL:2"
        s4: "4 | Key:E | PSL:3"
        s5: "5 | Key:F | PSL:4"
        s6: "6 | empty | --"
        s7: "7 | empty | --"
      }
    }
    naive_insert: {
      label: "Insert Key:G (hash=2)"
      width: 400
      code: |'c
        // G wants slot 2, must probe
        // Slots 2,3,4,5,6 all occupied
        // G lands at slot 7 with PSL=5!
      '|
    }
    naive_after: {
      label: "After Insertion"
      width: 400
      slots_na: {
        shape: sql_table
        label: "Unbounded PSL Growth"
        s0: "0 | Key:A | PSL:0"
        s1: "1 | Key:B | PSL:0"
        s2: "2 | Key:C | PSL:1"
        s3: "3 | Key:D | PSL:2"
        s4: "4 | Key:E | PSL:3"
        s5: "5 | Key:F | PSL:4"
        s6: "6 | Key:G | PSL:5"
        s7: "7 | Key:H | PSL:6"
        warn: "Max PSL: 6 (grows unbounded!)"
        s6.style.fill: "#ffcccc"
        s7.style.fill: "#ffcccc"
        warn.style.fill: "#ff6666"
      }
    }
    naive_prob: {
      label: "Problem: Clustering"
      width: 400
      desc: |md
        **Cache lines wasted:**
        - Long probe chains form clusters
        - New inserts extend clusters
        - Max PSL grows to O(n) worst case
        - At 90% load: max PSL can exceed 50!
      |
    }
  }
  robin: {
    direction: down
    label: "Robin Hood Hashing"
    rh_before: {
      label: "Before Insertions"
      width: 400
      slots_rb: {
        shape: sql_table
        label: "Hash Table Slots"
        s0: "0 | Key:A | PSL:0"
        s1: "1 | Key:B | PSL:0"
        s2: "2 | Key:C | PSL:1"
        s3: "3 | Key:D | PSL:2"
        s4: "4 | Key:E | PSL:3"
        s5: "5 | Key:F | PSL:1"
        s6: "6 | empty | --"
        s7: "7 | empty | --"
        s5.style.fill: "#ffffcc"
      }
    }
    rh_step1: {
      label: "Step 1: Insert Key:G (hash=2, PSL=0)"
      width: 400
      code: |'c
        // G wants slot 2, current PSL=0
        // Slot 2 has C with PSL=1
        // G's PSL(0) < C's PSL(1)? NO
        // Move to slot 3, G's PSL becomes 1
      '|
    }
    rh_step2: {
      label: "Step 2: Displacement Chain"
      width: 400
      code: |'c
        // G at slot 3: PSL=1, D has PSL=2
        // G's PSL(1) < D's PSL(2)? NO
        // Move to slot 4, G's PSL becomes 2
        // G's PSL(2) < E's PSL(3)? NO
        // Move to slot 5, G's PSL becomes 3
        // G's PSL(3) > F's PSL(1)? YES!
        // SWAP: G takes slot 5, F displaced
      '|
    }
    rh_after: {
      label: "After Robin Hood Insertion"
      width: 400
      slots_ra: {
        shape: sql_table
        label: "Bounded PSL Distribution"
        s0: "0 | Key:A | PSL:0"
        s1: "1 | Key:B | PSL:0"
        s2: "2 | Key:C | PSL:1"
        s3: "3 | Key:D | PSL:2"
        s4: "4 | Key:E | PSL:3"
        s5: "5 | Key:G | PSL:3"
        s6: "6 | Key:F | PSL:2"
        s7: "7 | empty | --"
        note: "Max PSL: 3 (bounded by ln(n))"
        s5.style.fill: "#ccffcc"
        s6.style.fill: "#ccffcc"
        note.style.fill: "#66ff66"
      }
    }
    rh_benefit: {
      label: "Benefit: Variance Reduction"
      width: 400
      desc: |md
        **PSL variance decreases:**
        - Rich entries (low PSL) share with poor
        - Maximum PSL bounded to O(log n)
        - At 90% load: max PSL typically < 15
        - Predictable worst-case lookup time
      |
    }
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  algorithm: {
    direction: down
    label: "Robin Hood Insert Algorithm"
    width: 450
    insert_code: {
      label: "Core Displacement Logic"
      code: |'c
        void robin_hood_insert(HashTable* t, 
                               uint64_t key, 
                               uint64_t value) {
          size_t slot = hash(key) % t->capacity;
          uint8_t my_psl = 0;
          while (true) {
            Entry* e = &t->entries[slot];
            if (e->metadata == EMPTY) {
              // Found empty slot - place here
              e->key = key;
              e->value = value;
              e->psl = my_psl;
              return;
            }
            // Robin Hood: steal if I'm poorer
            if (my_psl > e->psl) {
              // SWAP with current occupant
              swap(key, e->key);
              swap(value, e->value);
              swap(my_psl, e->psl);
              // Continue inserting displaced entry
            }
            slot = (slot + 1) % t->capacity;
            my_psl++;
          }
        }
      '|
    }
  }
  lookup_opt: {
    direction: down
    label: "Lookup Early Termination"
    width: 450
    lookup_code: {
      label: "O(log n) Worst-Case Lookup"
      code: |'c
        Value* robin_hood_lookup(HashTable* t, 
                                 uint64_t key) {
          size_t slot = hash(key) % t->capacity;
          uint8_t probe_dist = 0;
          while (true) {
            Entry* e = &t->entries[slot];
            if (e->metadata == EMPTY) {
              return NULL; // Key not found
            }
            // EARLY TERMINATION:
            // If we've probed farther than this
            // entry's PSL, key cannot exist
            if (e->psl < probe_dist) {
              return NULL; // Impossible to find
            }
            if (e->key == key) {
              return &e->value; // Found!
            }
            slot = (slot + 1) % t->capacity;
            probe_dist++;
          }
        }
      '|
    }
  }
}
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  comparison: {
    direction: down
    label: "PSL Distribution Comparison (1M entries, 90% load)"
    dist_table: {
      shape: sql_table
      label: "Probe Sequence Length Statistics"
      metric: "Metric | Naive | Robin Hood"
      avg: "Average PSL | 5.5 | 5.5"
      max: "Maximum PSL | 50+ | 12"
      p99: "99th Percentile | 25 | 8"
      variance: "Variance | High | Low"
      max.style.fill: "#ccffcc"
      p99.style.fill: "#ccffcc"
      variance.style.fill: "#ccffcc"
    }
    cache_impact: {
      label: "Cache Impact"
      desc: |md
        **Robin Hood Advantage:**
        1. **Bounded probes** = bounded cache misses
           - Worst case: ~12 cache lines vs ~50+
           - Predictable latency for real-time systems
        2. **Early termination** saves probes
           - Lookup stops when `probe_dist > entry.psl`
           - Misses fail fast instead of scanning entire chain
        3. **Better cache line utilization**
           - Similar PSL entries cluster together
           - Prefetcher can anticipate access pattern
      |
    }
  }
  invariant: {
    direction: down
    label: "The Robin Hood Invariant"
    inv_box: {
      shape: rectangle
      width: 400
      inv_text: |md
        **Invariant:** For any slot `i`:
        
        PSL(entry at slot i) >= PSL(any entry
          that hashed to same bucket and probed
          past slot i)
        
        **Intuition:** Entries that traveled far
        get priority seats. "Poor" entries (high
        PSL) displace "rich" entries (low PSL).
        **Result:** PSL variance → 0 as n → ∞
        Maximum PSL ≈ ln(n) with high probability
      |
    }
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  green: "Green = Robin Hood benefit" {style.fill: "#ccffcc"}
  red: "Red = Naive problem" {style.fill: "#ffcccc"}
  yellow: "Yellow = Displacement target" {style.fill: "#ffffcc"}
}
naive.naive_after.slots_na -> robin.rh_after.slots_ra: "Robin Hood bounds\nmax PSL" {
  style.stroke: "#00aa00"
  style.stroke-width: 3
  style.stroke-dash: 5
}