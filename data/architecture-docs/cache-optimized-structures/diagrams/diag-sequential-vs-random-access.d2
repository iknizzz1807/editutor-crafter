direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------------------
# TITLE SECTION
# -----------------------------------------------------------------------------------------
header: {
  style: {
    stroke: transparent
    fill: transparent
  }
  title: "Sequential vs Random Access Memory Pattern" {
    shape: rectangle
    style: {
      font-size: 32
      bold: true
      underline: true
      stroke: transparent
      fill: transparent
    }
  }
}

# -----------------------------------------------------------------------------------------
# MAIN COMPARISON ROW
# -----------------------------------------------------------------------------------------
row_comparison: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  # --- SEQUENTIAL ACCESS PANEL ---
  sequential: "SEQUENTIAL ACCESS" {
    direction: down
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 8
    }

    annotation_box: {
      label: "Hardware prefetcher detects pattern"
      style: {
        font-color: "#2E7D32"
        italic: true
        fill: transparent
        stroke-dash: 2
      }
    }

    seq_array: "Array in Memory (64-byte cache line = 16 floats)" {
      direction: right
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
        border-radius: 4
      }
      cell0: "[0]" { style.fill: "#4CAF50"; style.font-color: white; style.bold: true }
      cell1: "[1]" { style.fill: "#4CAF50"; style.font-color: white; style.bold: true }
      cell2: "[2]" { style.fill: "#4CAF50"; style.font-color: white; style.bold: true }
      cell3: "[3]" { style.fill: "#81C784"; style.font-color: white }
      cell4: "[4]" { style.fill: "#81C784"; style.font-color: white }
      cell5: "[5]" { style.fill: "#81C784"; style.font-color: white }
      ellipsis: "..." { style.fill: transparent; style.font-color: "#388E3C"; style.stroke: transparent }
      cell15: "[15]" { style.fill: "#81C784"; style.font-color: white }
    }

    seq_access: "Access Pattern" {
      direction: right
      style: {
        fill: "#A5D6A7"
        stroke: "#2E7D32"
        border-radius: 4
      }
      a0: "read[0]" { shape: step; style.fill: "#4CAF50"; style.font-color: white }
      a1: "read[1]" { shape: step; style.fill: "#4CAF50"; style.font-color: white }
      a2: "read[2]" { shape: step; style.fill: "#4CAF50"; style.font-color: white }
      a3: "read[3]" { shape: step; style.fill: "#66BB6A"; style.font-color: white }
      a4: "read[4]" { shape: step; style.fill: "#66BB6A"; style.font-color: white }
    }

    prefetch_action: {
      label: "Prefetcher Status: ACTIVE"
      prefetch_logic: {
        label: "Prefetcher anticipates [8..15]\nand fetches next cache line"
        shape: callout
        style: {
          fill: "#C8E6C9"
          stroke: "#2E7D32"
        }
      }
    }

    seq_stats: {
      shape: class
      label: "Cache Efficiency"
      +elements_per_line: "16 (100%)"
      +cycles_per_access: "~4-8 cycles"
      +prefetch_status: "PREDICTIVE_LOAD"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
      }
    }

    cell0 -> a0
    cell1 -> a1
    cell2 -> a2
    cell3 -> a3
    cell4 -> a4
    seq_access -> prefetch_action.prefetch_logic: "predicts"
  }

  # --- RANDOM ACCESS PANEL ---
  random: "RANDOM ACCESS" {
    direction: down
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      border-radius: 8
    }

    rand_annotation: {
      label: "Prefetcher cannot detect pattern"
      style: {
        font-color: "#C62828"
        italic: true
        fill: transparent
        stroke-dash: 2
      }
    }

    rand_array: "Array in Memory (scattered access)" {
      direction: right
      style: {
        fill: "#FFCDD2"
        stroke: "#E53935"
        border-radius: 4
      }
      r0: "[0]" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
      r1: "[1]" { style.fill: "#FFCDD2"; style.font-color: "#B71C1C" }
      r2: "[2]" { style.fill: "#FFCDD2"; style.font-color: "#B71C1C" }
      r3: "[3]" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
      dots1: "..." { style.fill: transparent; style.font-color: "#E53935"; style.stroke: transparent }
      r999: "[999]" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
      dots2: "..." { style.fill: transparent; style.font-color: "#E53935"; style.stroke: transparent }
      r847: "[847]" { style.fill: "#EF5350"; style.font-color: white; style.bold: true }
    }

    rand_access: "Access Pattern (Pointer Chasing)" {
      direction: right
      style: {
        fill: "#FFCDD2"
        stroke: "#E53935"
        border-radius: 4
      }
      ra0: "read[0]" { shape: step; style.fill: "#EF5350"; style.font-color: white }
      ra999: "read[999]" { shape: step; style.fill: "#EF5350"; style.font-color: white }
      ra3: "read[3]" { shape: step; style.fill: "#EF5350"; style.font-color: white }
      ra847: "read[847]" { shape: step; style.fill: "#EF5350"; style.font-color: white }
    }

    rand_status: {
      label: "Prefetcher Status: IDLE/STALLED"
      confused_box: {
        label: "Prefetcher: ???\nNo pattern detected\nEach access = cache miss"
        shape: callout
        style: {
          fill: "#FFCDD2"
          stroke: "#E53935"
        }
      }
    }

    rand_stats: {
      shape: class
      label: "Cache Efficiency"
      +elements_per_line: "1-2 (6-12%)"
      +cycles_per_access: "~100-300 cycles"
      +prefetch_status: "PATTERN_UNKNOWN"
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
      }
    }

    r0 -> ra0
    r999 -> ra999
    r3 -> ra3
    r847 -> ra847
    rand_access -> rand_status.confused_box: "confuses"
  }
}

# -----------------------------------------------------------------------------------------
# SUMMARY DATA ROW
# -----------------------------------------------------------------------------------------
summary: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  cache_line_detail: {
    label: "Cache Line Utilization"
    direction: down
    width: 400
    seq_detail: {
      label: |'md
        **Sequential**: Load cache line → use ALL 16 elements
        - 1 cache miss per 16 accesses
        - 15 "free" accesses from same line
      '|
      shape: rectangle
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
      }
    }
    rand_detail: {
      label: |'md
        **Random**: Load cache line → use 1 element (waste 15)
        - Each access may be a cache miss
        - No reuse, no spatial locality benefit
      '|
      shape: rectangle
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
      }
    }
  }

  perf_impact: {
    label: "Performance Impact"
    width: 400
    impact_text: {
      label: |'md
        **Same O(n) algorithm, different performance:**

        | Pattern | Time for 1M accesses |
        | :--- | :--- |
        | Sequential | ~8 ms |
        | Random | ~300 ms |

        **~40x difference from access pattern alone!**
      '|
      shape: rectangle
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
        border-radius: 4
      }
    }
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  key1: "Accessed" { style.fill: "#4CAF50"; style.font-color: white }
  key2: "Prefetched" { style.fill: "#81C784"; style.font-color: white }
  key3: "Random Hit" { style.fill: "#EF5350"; style.font-color: white }
  key4: "Unused" { style.fill: "#FFCDD2"; style.font-color: "#B71C1C" }
}
legend.near: bottom-center