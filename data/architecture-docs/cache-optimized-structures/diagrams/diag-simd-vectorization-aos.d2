direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SIMD Vectorization: Why AoS Fails
  Loading 8 floats into a 256-bit AVX register
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  aos: {
    direction: down
    label: "Array of Structs (AoS)"
    aos_explanation: {
      label: "Memory Layout"
      width: 320
      code: |'c
        Particle particles[N];
        // Each particle: 28 bytes
        // [x][y][z][vx][vy][vz][mass]
        //
        // particles[0]: x0 y0 z0 vx0 vy0 vz0 m0
        // particles[1]: x1 y1 z1 vx1 vy1 vz1 m1
        // particles[2]: x2 y2 z2 vx2 vy2 vz2 m2
        // ...
        //
        // x values are STRIDED by 28 bytes!
        // x0 at offset 0,  x1 at offset 28,  x2 at offset 56
      '|
    }
    aos_problem: {
      label: "SIMD Load Attempt"
      width: 380
      register_aos: {
        shape: rectangle
        label: "256-bit YMM Register\n(8 × float = 32 bytes)"
        style.fill: "#E8F4FD"
        style.stroke: "#2196F3"
        style.stroke-width: 2
      }
      gather_label: {
        label: "Requires VGATHERDPS\n(scattered memory access)"
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
        style.font-color: "#C62828"
      }
      slot0: {label: "slot 0"; shape: rectangle; style.fill: "#BBDEFB"}
      slot1: {label: "slot 1"; shape: rectangle; style.fill: "#BBDEFB"}
      slot2: {label: "slot 2"; shape: rectangle; style.fill: "#BBDEFB"}
      slot3: {label: "slot 3"; shape: rectangle; style.fill: "#BBDEFB"}
      slot4: {label: "slot 4"; shape: rectangle; style.fill: "#BBDEFB"}
      slot5: {label: "slot 5"; shape: rectangle; style.fill: "#BBDEFB"}
      slot6: {label: "slot 6"; shape: rectangle; style.fill: "#BBDEFB"}
      slot7: {label: "slot 7"; shape: rectangle; style.fill: "#BBDEFB"}
      register_aos -> gather_label
      gather_label -> slot0
      gather_label -> slot1
      gather_label -> slot2
      gather_label -> slot3
      gather_label -> slot4
      gather_label -> slot5
      gather_label -> slot6
      gather_label -> slot7
    }
    aos_mem: {
      label: "Memory (Non-contiguous x values)"
      p0: {
        shape: rectangle
        label: "[x0][y0][z0][vx0][vy0][vz0][m0]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p1: {
        shape: rectangle
        label: "[x1][y1][z1][vx1][vy1][vz1][m1]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p2: {
        shape: rectangle
        label: "[x2][y2][z2][vx2][vy2][vz2][m2]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p3: {
        shape: rectangle
        label: "[x3][y3][z3][vx3][vy3][vz3][m3]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p4: {
        shape: rectangle
        label: "[x4][y4][z4][vx4][vy4][vz4][m4]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p5: {
        shape: rectangle
        label: "[x5][y5][z5][vx5][vy5][vz5][m5]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p6: {
        shape: rectangle
        label: "[x6][y6][z6][vx6][vy6][vz6][m6]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p7: {
        shape: rectangle
        label: "[x7][y7][z7][vx7][vy7][vz7][m7]"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
      p0 -> p1 -> p2 -> p3 -> p4 -> p5 -> p6 -> p7
    }
    aos_mem.slot0 -> aos_problem.p0: "x0" {style.stroke: "#C62828"; style.stroke-dash: 3}
    aos_mem.slot1 -> aos_problem.p1: "x1" {style.stroke: "#C62828"; style.stroke-dash: 3}
    aos_mem.slot2 -> aos_problem.p2: "x2" {style.stroke: "#C62828"; style.stroke-dash: 3}
    aos_mem.slot3 -> aos_problem.p3: "x3" {style.stroke: "#C62828"; style.stroke-dash: 3}
    aos_mem.slot4 -> aos_problem.p4: "x4" {style.stroke: "#C62828"; style.stroke-dash: 3}
    aos_mem.slot5 -> aos_problem.p5: "x5" {style.stroke: "#C62828"; style.stroke-dash: 3}
    aos_mem.slot6 -> aos_problem.p6: "x6" {style.stroke: "#C62828"; style.stroke-dash: 3}
    aos_mem.slot7 -> aos_problem.p7: "x7" {style.stroke: "#C62828"; style.stroke-dash: 3}
  }
  soa: {
    direction: down
    label: "Struct of Arrays (SoA)"
    soa_explanation: {
      label: "Memory Layout"
      width: 320
      code: |'c
        struct { float *x, *y, *z;
                 float *vx, *vy, *vz;
                 float *mass; } particles;
        // Separate contiguous arrays:
        // x[]:  x0  x1  x2  x3  x4  x5  x6  x7
        // y[]:  y0  y1  y2  y3  y4  y5  y6  y7
        // ...
        //
        // x values are CONTIGUOUS!
        // Load 8 values with ONE instruction
      '|
    }
    soa_solution: {
      label: "SIMD Load"
      width: 380
      load_label: {
        label: "Single VMOVAPS Instruction\n(aligned packed load)"
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
        style.font-color: "#2E7D32"
      }
      register_soa: {
        shape: rectangle
        label: "256-bit YMM Register\n(8 × float = 32 bytes)"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        style.stroke-width: 2
      }
      lane0: {label: "x0"; shape: rectangle; style.fill: "#A5D6A7"}
      lane1: {label: "x1"; shape: rectangle; style.fill: "#A5D6A7"}
      lane2: {label: "x2"; shape: rectangle; style.fill: "#A5D6A7"}
      lane3: {label: "x3"; shape: rectangle; style.fill: "#A5D6A7"}
      lane4: {label: "x4"; shape: rectangle; style.fill: "#A5D6A7"}
      lane5: {label: "x5"; shape: rectangle; style.fill: "#A5D6A7"}
      lane6: {label: "x6"; shape: rectangle; style.fill: "#A5D6A7"}
      lane7: {label: "x7"; shape: rectangle; style.fill: "#A5D6A7"}
      load_label -> register_soa
      register_soa -> lane0
      register_soa -> lane1
      register_soa -> lane2
      register_soa -> lane3
      register_soa -> lane4
      register_soa -> lane5
      register_soa -> lane6
      register_soa -> lane7
    }
    soa_mem: {
      label: "Memory (Contiguous x[] array)"
      x_array: {
        shape: rectangle
        label: "[x0][x1][x2][x3][x4][x5][x6][x7][x8]..."
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
        style.stroke-width: 2
      }
      y_array: {
        shape: rectangle
        label: "[y0][y1][y2][y3][y4][y5][y6][y7][y8]..."
        style.fill: "#E0E0E0"
        style.stroke: "#9E9E9E"
      }
      z_array: {
        shape: rectangle
        label: "[z0][z1][z2][z3][z4][z5][z6][z7][z8]..."
        style.fill: "#E0E0E0"
        style.stroke: "#9E9E9E"
      }
      x_array -> y_array -> z_array
    }
    soa_mem.x_array -> soa_solution.load_label: "32 bytes\none load" {style.stroke: "#2E7D32"; style.stroke-width: 2}
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  comparison: {
    label: "Performance Comparison"
    width: 700
    comp_table: {
      shape: sql_table
      label: "Instruction Analysis"
      col1: "Aspect | AoS (Gather) | SoA (Direct Load)"
      row1: "Instruction | vgatherdps | vmovaps"
      row2: "Latency | ~15-30 cycles | ~3-5 cycles"
      row3: "Throughput | 1 per ~10 cyc | 2 per cycle"
      row4: "Cache lines | 8 (scattered) | 1 (contiguous)"
      row5: "Typical speedup | 1x (scalar fallback) | 8x (full vector)"
    }
  }
}
summary: {
  label: "Key Insight"
  width: 650
  code: |'c
    // AoS: Compiler CANNOT vectorize efficiently
    for (int i = 0; i < n; i++) {
        particles[i].x += dt;  // stride = 28 bytes → gather or scalar
    }
    // SoA: Compiler AUTO-VECTORIZES to AVX
    for (int i = 0; i < n; i++) {
        xs[i] += dt;  // stride = 4 bytes → vmovaps + vaddps
    }
    // Transforms to:
    //   vmovaps ymm0, [xs + i*4]    ; load 8 floats
    //   vaddps  ymm0, ymm0, ymm1    ; add 8 floats in parallel
    //   vmovaps [xs + i*4], ymm0    ; store 8 results
  '|
}
row1 -> row2
row2 -> summary
legend: {
  near: bottom-right
  label: "Legend"
  bad: {
    label: "Red = Cache-unfriendly"
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  good: {
    label: "Green = Cache-friendly"
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  bad -> good
}