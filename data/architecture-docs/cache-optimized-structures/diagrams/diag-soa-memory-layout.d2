direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_block: {
  label: "Struct of Arrays (SoA) Memory Layout"
  style: {
    font-size: 32
    bold: true
    stroke: transparent
    fill: transparent
  }
}

arrays_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  pos_arrays: {
    direction: down
    label: "Position Arrays (High Locality)"
    x_arr: {
      label: "float x[]"
      width: 280
      height: 50
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 2
    }
    y_arr: {
      label: "float y[]"
      width: 280
      height: 50
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 2
    }
    z_arr: {
      label: "float z[]"
      width: 280
      height: 50
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 2
    }
  }
  
  vel_arrays: {
    direction: down
    label: "Velocity Arrays (Cold Path)"
    vx_arr: {
      label: "float vx[]"
      width: 280
      height: 50
      style.fill: "#E0E0E0"
      style.stroke: "#888888"
      style.stroke-width: 2
      style.opacity: 0.5
    }
    vy_arr: {
      label: "float vy[]"
      width: 280
      height: 50
      style.fill: "#E0E0E0"
      style.stroke: "#888888"
      style.stroke-width: 2
      style.opacity: 0.5
    }
    vz_arr: {
      label: "float vz[]"
      width: 280
      height: 50
      style.fill: "#E0E0E0"
      style.stroke: "#888888"
      style.stroke-width: 2
      style.opacity: 0.5
    }
  }
  
  mass_arr: {
    direction: down
    label: "Property Array"
    mass: {
      label: "float mass[]"
      width: 280
      height: 50
      style.fill: "#E0E0E0"
      style.stroke: "#888888"
      style.stroke-width: 2
      style.opacity: 0.5
    }
  }
}

cache_line_detail: {
  label: "x[] Array Detail: Cache Line & SIMD Packing"
  direction: down
  
  cache_line_0: {
    label: "Cache Line 0 (64 bytes = 16 floats)"
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    
    floats_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      f0: { label: "x[0]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f1: { label: "x[1]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f2: { label: "x[2]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f3: { label: "x[3]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f4: { label: "x[4]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f5: { label: "x[5]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f6: { label: "x[6]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f7: { label: "x[7]"; width: 35; height: 40; style.fill: "#4CAF50"; style.font-color: white }
      f8: { label: "x[8]"; width: 35; height: 40; style.fill: "#81C784" }
      f9: { label: "x[9]"; width: 35; height: 40; style.fill: "#81C784" }
      f10: { label: "etc"; width: 35; height: 40; style.fill: "#81C784" }
      f11: { label: "x[15]"; width: 35; height: 40; style.fill: "#81C784" }
    }
  }
  
  simd_row: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    simd_overlay: {
      label: "AVX-256 (ymm0): 32B / 8 floats"
      style.fill: "transparent"
      style.stroke: "#FF6B00"
      style.stroke-width: 3
      style.stroke-dash: 4
      width: 290
      height: 40
    }
    simd_overlay2: {
      label: "AVX-256 (ymm1)"
      style.fill: "transparent"
      style.stroke: "#FF6B00"
      style.stroke-width: 3
      style.stroke-dash: 4
      width: 290
      height: 40
    }
  }
}

analysis_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  simd_note: {
    label: "Vectorization Implementation"
    code: |'c
      // Load 8 contiguous floats into YMM
      __m256 vx = _mm256_load_ps(&x[i]);
      __m256 vy = _mm256_load_ps(&y[i]);
      // Parallel addition/multiplication
      _mm256_add_ps(vx, vy);
    '|
    width: 350
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
    style.stroke-width: 2
  }

  efficiency_box: {
    label: "Efficiency Analysis"
    table: |'md
      | Metric | Efficiency Value |
      |---|---|
      | Cache Line | 64 Bytes |
      | SIMD Width | 8 Floats (AVX-256) |
      | Utilization | 100% (No Padding) |
      | Locality | Contiguous Access |
    '|
    width: 380
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
  }

  comparison_note: {
    label: "vs Array of Structs (AoS)"
    note: |'md
      **AoS Interleaving:**
      `[x][y][z][vx][vy][vz][m]...`
      
      When only updating Position:
      - Cache loads 28 bytes per particle
      - Only 12 bytes are used (43% efficiency)
      - SoA avoids loading Vel/Mass entirely
    '|
    width: 350
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2
  }
}

arrays_row.pos_arrays.x_arr -> cache_line_detail: "Contiguous floats" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
cache_line_detail -> analysis_row: "Process in SIMD chunks"