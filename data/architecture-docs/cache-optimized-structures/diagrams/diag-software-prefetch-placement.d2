direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Software Prefetch: Hiding Memory Latency"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  timeline: {
    direction: down
    label: "Timeline: Cache Line Arrives During Probe"
    t0: {
      label: "T0: Prefetch Issued"
      width: 380
      code: |'c
        // At slot i, prefetch i+8
        __builtin_prefetch(&keys[slot + 8], 0, 3);
        // Request goes to memory subsystem
      '|
      style.fill: "#E8F4E8"
    }
    t1: {
      label: "T1-T7: Probe Continues"
      width: 380
      code: |'c
        // Compare keys at slots i through i+7
        // These are likely cache hits (L1/L2)
        // Memory controller fetching cache line
        //   for slot i+8 in parallel...
      '|
      style.fill: "#FFF9E6"
    }
    t2: {
      label: "T8: Data Arrives"
      width: 380
      code: |'c
        // Cache line for slot i+8 now in L1!
        // No stall - data ready when we arrive
        // Latency completely hidden
      '|
      style.fill: "#E6F3FF"
    }
  }
  timeline -> timing_detail: "200+ cycles\nhidden"
}
timing_detail: {
  label: "Latency Breakdown (Typical)"
  direction: down
  breakdown: {
    shape: sql_table
    label: "Memory Access Timing"
    row1: "Prefetch issue    | ~5 cycles  | CPU instruction"
    row2: "Memory fetch      | ~200 cycles| DRAM to L1"
    row3: "Probe slots i..i+7| ~40 cycles | 8 key compares"
    row4: "Slot i+8 access   | ~4 cycles  | L1 HIT (prefetched!)"
    row5: "Total visible latency | ~0 cycles | HIDDEN"
  }
  note: {
    label: "Key Insight: Memory fetch happens in parallel with useful work"
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#666666"
    }
  }
}
prefetch_config: {
  label: "Prefetch Configuration"
  direction: right
  builtin: {
    shape: class
    label: "__builtin_prefetch"
    addr: "const void* addr"
    rw: "int rw (0=read, 1=write)"
    locality: "int locality (0-3)"
    desc: "0=temporal, 3=keep in cache"
  }
  tuning: {
    shape: sql_table
    label: "Tuning Parameters"
    p1: "PREFETCH_DISTANCE | 8 | entries ahead"
    p2: "Memory latency    | 200 | cycles (typical)"
    p3: "Loop iteration    | 5-10 | cycles each"
    p4: "Optimal distance  | latency/iteration | ~20-40"
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  green: "Prefetch issued" {
    shape: rectangle
    style.fill: "#E8F4E8"
  }
  yellow: "Parallel work" {
    shape: rectangle
    style.fill: "#FFF9E6"
  }
  blue: "Cache hit" {
    shape: rectangle
    style.fill: "#E6F3FF"
  }
}