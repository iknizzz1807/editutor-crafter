direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Robin Hood Insert Sequence
  PSL (Probe Sequence Length) stays bounded as entries redistribute
|

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  
  step0: {
    direction: down
    label: "Step 0: Initial State"
    table0: {
      shape: sql_table
      label: "Hash Table (cap=8)"
      s0: "0x00 | EMPTY    | - | -"
      s1: "0x01 | EMPTY    | - | -"
      s2: "0x02 | EMPTY    | - | -"
      s3: "0x03 | EMPTY    | - | -"
      s4: "0x04 | EMPTY    | - | -"
      s5: "0x05 | EMPTY    | - | -"
      s6: "0x06 | EMPTY    | - | -"
      s7: "0x07 | EMPTY    | - | -"
    }
    note0: |md
      Empty table
      Max PSL: 0
    |
  }

  step1: {
    direction: down
    label: "Step 1: Insert K=10"
    table1: {
      shape: sql_table
      label: "Hash Table (K=10)"
      s0: "0x00 | EMPTY    | -   | -"
      s1: "0x01 | EMPTY    | -   | -"
      s2: "0x02 | OCCUPIED | 0   | K=10, v=100"
      s3: "0x03 | EMPTY    | -   | -"
      s4: "0x04 | EMPTY    | -   | -"
      s5: "0x05 | EMPTY    | -   | -"
      s6: "0x06 | EMPTY    | -   | -"
      s7: "0x07 | EMPTY    | -   | -"
    }
    note1: |md
      hash(10) % 8 = 2
      Slot 2 empty -> place here
      **Max PSL: 0**
    |
  }

  step2: {
    direction: down
    label: "Step 2: Insert K=18"
    table2: {
      shape: sql_table
      label: "Hash Table (K=18)"
      s0: "0x00 | EMPTY    | -   | -"
      s1: "0x01 | EMPTY    | -   | -"
      s2: "0x02 | OCCUPIED | 0   | K=10, v=100"
      s3: "0x03 | OCCUPIED | 1   | K=18, v=200"
      s4: "0x04 | EMPTY    | -   | -"
      s5: "0x05 | EMPTY    | -   | -"
      s6: "0x06 | EMPTY    | -   | -"
      s7: "0x07 | EMPTY    | -   | -"
    }
    note2: |md
      hash(18) % 8 = 2
      Slot 2 occupied, probe to 3
      **Max PSL: 1**
    |
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  step3: {
    direction: down
    label: "Step 3: Insert K=26"
    table3: {
      shape: sql_table
      label: "Hash Table (K=26)"
      s0: "0x00 | EMPTY    | -   | -"
      s1: "0x01 | EMPTY    | -   | -"
      s2: "0x02 | OCCUPIED | 0   | K=10, v=100"
      s3: "0x03 | OCCUPIED | 1   | K=18, v=200"
      s4: "0x04 | OCCUPIED | 2   | K=26, v=300"
      s5: "0x05 | EMPTY    | -   | -"
      s6: "0x06 | EMPTY    | -   | -"
      s7: "0x07 | EMPTY    | -   | -"
    }
    note3: |md
      hash(26) % 8 = 2
      Slots 2,3 occupied
      Probe to slot 4
      **Max PSL: 2**
    |
  }

  step4: {
    direction: down
    label: "Step 4: Insert K=34"
    table4: {
      shape: sql_table
      label: "Hash Table (K=34)"
      s0: "0x00 | EMPTY    | -   | -"
      s1: "0x01 | EMPTY    | -   | -"
      s2: "0x02 | OCCUPIED | 0   | K=10, v=100"
      s3: "0x03 | OCCUPIED | 1   | K=18, v=200"
      s4: "0x04 | OCCUPIED | 2   | K=26, v=300"
      s5: "0x05 | OCCUPIED | 3   | K=34, v=400"
      s6: "0x06 | EMPTY    | -   | -"
      s7: "0x07 | EMPTY    | -   | -"
    }
    note4: |md
      hash(34) % 8 = 2
      Sequential linear probing
      Eventually slot 5
      **Max PSL: 3**
    |
  }

  step5: {
    direction: down
    label: "Step 5: Insert K=2"
    table5: {
      shape: sql_table
      label: "Hash Table (K=2)"
      s0: "0x00 | EMPTY    | -   | -"
      s1: "0x01 | EMPTY    | -   | -"
      s2: "0x02 | OCCUPIED | 0   | K=2, v=500"
      s3: "0x03 | OCCUPIED | 1   | K=10, v=100"
      s4: "0x04 | OCCUPIED | 2   | K=18, v=200"
      s5: "0x05 | OCCUPIED | 3   | K=26, v=300"
      s6: "0x06 | OCCUPIED | 4   | K=34, v=400"
      s7: "0x07 | EMPTY    | -   | -"
    }
    note5: |md
      **Robin Hood Displacement!**
      K=2 @ slot 2 (PSL=0)
      displaces K=10 because it's
      closer than previous tenants.
      **Max PSL: 4**
    |
  }
}

row1.step0 -> row1.step1: "insert(10)"
row1.step1 -> row1.step2: "insert(18)"
row1.step2 -> row2.step3: "insert(26)"
row2.step3 -> row2.step4: "insert(34)"
row2.step4 -> row2.step5: "insert(2)"

legend: {
  label: "PSL Distribution Analysis"
  dist: {
    shape: sql_table
    label: "Final PSL Histogram"
    p0: "PSL 0 | 1 entry (K=2)"
    p1: "PSL 1 | 1 entry (K=10)"
    p2: "PSL 2 | 1 entry (K=18)"
    p3: "PSL 3 | 1 entry (K=26)"
    p4: "PSL 4 | 1 entry (K=34)"
    avg: "Avg PSL: 2.0 | Max: 4"
  }
  insight: |md
    **Key Insight**: Robin Hood equalizes probe distances.
    Without Robin Hood, naive linear probing could have
    one entry with high PSL while others have 0.
    With Robin Hood, PSL variance is minimized.
  |
}
legend.near: bottom-right