direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Struct Padding and Alignment
| {near: top-center}
row_naive: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  naive_struct: {
    direction: down
    label: "Naive Layout (expected)"
    naive_memory: {
      direction: right
      grid-gap: 0
      n_byte0: "0" {
        label: "char a\n1 byte"
        style.fill: "#B5AFF6"
        style.stroke: "#7B68EE"
        width: 80
        height: 60
      }
      n_byte1: "1-4" {
        label: "int b\n4 bytes"
        style.fill: "#88DCF7"
        style.stroke: "#00CED1"
        width: 80
        height: 60
      }
      n_byte5: "5" {
        label: "char c\n1 byte"
        style.fill: "#B5AFF6"
        style.stroke: "#7B68EE"
        width: 80
        height: 60
      }
    }
    naive_info: {
      label: "Expected: 6 bytes"
      shape: text
      style.font-color: "#666"
    }
  }
}
row_actual: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  actual_struct: {
    direction: down
    label: "Actual Layout (with padding)"
    actual_memory: {
      direction: right
      grid-gap: 0
      a_byte0: "0" {
        label: "char a\n1 byte"
        style.fill: "#B5AFF6"
        style.stroke: "#7B68EE"
        width: 80
        height: 60
      }
      pad1: "1-3" {
        label: "padding\n3 bytes"
        style.fill: "#FFE4E1"
        style.stroke: "#FF6B6B"
        style.stroke-dash: 3
        width: 80
        height: 60
      }
      b_bytes: "4-7" {
        label: "int b\n4 bytes"
        style.fill: "#88DCF7"
        style.stroke: "#00CED1"
        width: 80
        height: 60
      }
      c_byte: "8" {
        label: "char c\n1 byte"
        style.fill: "#B5AFF6"
        style.stroke: "#7B68EE"
        width: 80
        height: 60
      }
      pad2: "9-11" {
        label: "padding\n3 bytes"
        style.fill: "#FFE4E1"
        style.stroke: "#FF6B6B"
        style.stroke-dash: 3
        width: 80
        height: 60
      }
    }
    actual_info: {
      label: "Actual: 12 bytes (2x larger!)"
      shape: text
      style.font-color: "#FF6B6B"
      style.bold: true
    }
  }
}
row_rules: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  alignment_rules: {
    label: "Alignment Rules"
    width: 400
    rule1: |md
      **1. Natural Alignment**
      Each type prefers addresses divisible by its size:
      - `char` (1 byte): any address
      - `int` (4 bytes): address % 4 == 0
      - `double` (8 bytes): address % 8 == 0
    |
    rule2: |md
      **2. Struct Alignment**
      Struct alignment = max alignment of any member.
      Total size is padded to be a multiple of alignment.
    |
    rule3: |md
      **3. Array Implication**
      In `struct S arr[100]`, each element must start
      at correct alignment → trailing padding required.
    |
  }
}
row_solutions: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  solution_reorder: {
    label: "Solution 1: Reorder Fields"
    width: 420
    reorder_code: |c
      // BEFORE: 12 bytes
      struct Bad {
          char a;     // 1 + 3 padding
          int  b;     // 4
          char c;     // 1 + 3 padding
      };
      // AFTER: 8 bytes
      struct Good {
          int  b;     // 4 (no padding before)
          char a;     // 1
          char c;     // 1
          // 2 bytes padding at end
      };
    |
    reorder_note: {
      label: "Rule: Order members largest → smallest"
      shape: text
      style.font-color: "#228B22"
      style.italic: true
    }
  }
  solution_packed: {
    label: "Solution 2: __attribute__((packed))"
    width: 380
    packed_code: |c
      struct __attribute__((packed)) Packed {
          char a;  // 1 byte at offset 0
          int  b;  // 4 bytes at offset 1
          char c;  // 1 byte at offset 5
      };  // Total: 6 bytes
      // WARNING: Unaligned access!
      // - May crash on ARM (some modes)
      // - Slow on x86 (penalty cycles)
      // - Use only for serialization
    |
    packed_note: {
      label: "Use only for network/disk serialization"
      shape: text
      style.font-color: "#FF8C00"
      style.italic: true
    }
  }
}
row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison_table: {
    shape: sql_table
    label: "Layout Comparison"
    field_layout: "Layout | sizeof | Use Case"
    field_naive: "Naive (reorder) | 8 bytes | General code"
    field_packed: "packed attribute | 6 bytes | Serialization only"
    field_warning: "Unoptimized | 12 bytes | AVOID (wastes memory)"
  }
}
row_naive -> row_actual: "Compiler inserts padding" {
  style.stroke: "#7B68EE"
  style.stroke-width: 2
}
row_actual -> row_rules: "Why?" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
row_rules -> row_solutions: "How to fix" {
  style.stroke: "#228B22"
  style.stroke-width: 2
}
row_solutions -> row_comparison: "Summary" {
  style.stroke: "#666"
}
legend: {
  near: bottom-right
  direction: right
  legend_data: {
    label: "char"
    style.fill: "#B5AFF6"
    style.stroke: "#7B68EE"
    width: 60
    height: 30
  }
  legend_int: {
    label: "int"
    style.fill: "#88DCF7"
    style.stroke: "#00CED1"
    width: 60
    height: 30
  }
  legend_pad: {
    label: "padding"
    style.fill: "#FFE4E1"
    style.stroke: "#FF6B6B"
    style.stroke-dash: 3
    width: 60
    height: 30
  }
}