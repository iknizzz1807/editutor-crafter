direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Van Emde Boas Layout: Logical → Physical Index Mapping
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  logical: {
    direction: down
    label: "Logical Tree (BFS Order)"
    root: {
      label: "Root"
      shape: circle
      style.fill: "#E4DBFE"
    }
    l1: {
      direction: right
      label: ""
      l1a: {
        label: "1"
        shape: circle
        style.fill: "#B5AFF6"
      }
      l1b: {
        label: "2"
        shape: circle
        style.fill: "#B5AFF6"
      }
    }
    l2: {
      direction: right
      label: ""
      l2a: {
        label: "3"
        shape: circle
        style.fill: "#88DCF7"
      }
      l2b: {
        label: "4"
        shape: circle
        style.fill: "#88DCF7"
      }
      l2c: {
        label: "5"
        shape: circle
        style.fill: "#88DCF7"
      }
      l2d: {
        label: "6"
        shape: circle
        style.fill: "#88DCF7"
      }
    }
    root -> l1.l1a
    root -> l1.l1b
    l1.l1a -> l2.l2a
    l1.l1a -> l2.l2b
    l1.l1b -> l2.l2c
    l1.l1b -> l2.l2d
  }
  arrow1: {
    label: "vEB Transform"
    shape: text
    style.fill: transparent
    style.stroke: transparent
    style.font-color: "#6772E5"
    style.bold: true
  }
  physical: {
    direction: down
    label: "Physical Array (vEB Order)"
    mem: {
      shape: class
      label: "Memory Layout"
      idx0: "0: R"
      idx1: "1: 1"
      idx2: "2: 2"
      idx3: "3: 3"
      idx4: "4: 7"
      idx5: "5: 8"
      idx6: "6: 4"
      idx7: "7: 9"
      idx8: "8: 10"
      idx9: "9: 5"
      idx10: "10: 11"
      idx11: "11: 12"
      idx12: "12: 6"
      idx13: "13: 13"
      idx14: "14: 14"
    }
    note: {
      label: "Cache lines group\nsubtree nodes together"
      shape: text
      style.fill: "#E4DBFE"
      style.stroke: "#B5AFF6"
      style.border-radius: 4
      style.font-size: 14
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  formula: {
    direction: down
    label: "Index Mapping Formula"
    bfs_to_veb: {
      label: "BFS → vEB Conversion"
      width: 400
      code: |'c
size_t bfs_to_veb(size_t bfs, size_t h) {
  if (h <= 1) return 0;
  size_t top_h    = h / 2;
  size_t bot_h    = h - top_h;
  size_t top_sz   = (1 << top_h) - 1;
  size_t bot_sz   = (1 << bot_h) - 1;
  if (bfs < top_sz) {
    // Node in top subtree
    return bfs_to_veb(bfs, top_h);
  }
  // Node in bottom subtree
  size_t offset   = bfs - top_sz;
  size_t bot_idx  = offset / bot_sz;
  size_t pos      = offset % bot_sz;
  return top_sz + bot_idx * bot_sz 
         + bfs_to_veb(pos, bot_h);
}
      '|
    }
  }
  mapping_table: {
    direction: down
    label: "Mapping Table (h=4)"
    table: {
      shape: sql_table
      label: "BFS Index → vEB Index"
      r0: "BFS[0] (R)  | vEB[0]"
      r1: "BFS[1] (1)  | vEB[1]"
      r2: "BFS[2] (2)  | vEB[2]"
      r3: "BFS[3] (3)  | vEB[3]"
      r4: "BFS[4] (4)  | vEB[6]"
      r5: "BFS[5] (5)  | vEB[9]"
      r6: "BFS[6] (6)  | vEB[12]"
      r7: "BFS[7] (7)  | vEB[4]"
      note: "... (height 4 tree)"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  traversal: {
    direction: down
    label: "Search Traversal: Contiguous Access"
    path: {
      label: "Path for key=9 (BFS indices)"
      shape: class
      step1: "Step 1: BFS[0]=R  → vEB[0]"
      step2: "Step 2: BFS[2]=2  → vEB[2]"
      step3: "Step 3: BFS[5]=5  → vEB[9]"
      step4: "Step 4: BFS[11]=11 → vEB[7]"
    }
    cache_analysis: {
      shape: class
      label: "Cache Line Analysis"
      cl1: "vEB[0-2]: Top subtree (1 cache line)"
      cl2: "vEB[3-6]: Bottom subtree 0 (1 line)"
      cl3: "vEB[7-10]: Bottom subtree 1 (1 line)"
      result: "4 steps → 2-3 cache misses"
    }
  }
  comparison: {
    direction: down
    label: "Comparison"
    naive: {
      shape: class
      label: "BFS Array Layout"
      miss1: "BFS[0] at index 0"
      miss2: "BFS[2] at index 2"
      miss3: "BFS[5] at index 5"
      miss4: "BFS[11] at index 11"
      result: "4 steps → 4 cache misses"
      style.fill: "#FFE0F5"
    }
    veb: {
      shape: class
      label: "vEB Layout"
      hit1: "vEB[0]: Top subtree root"
      hit2: "vEB[2]: Same top subtree!"
      hit3: "vEB[9]: Jump to bottom"
      hit4: "vEB[7]: Same bottom subtree!"
      result: "4 steps → 2 cache misses"
      style.fill: "#ACE1AF"
    }
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  legend_root: {
    label: "Root level"
    shape: circle
    style.fill: "#E4DBFE"
  }
  legend_l1: {
    label: "Level 1 (top subtree)"
    shape: circle
    style.fill: "#B5AFF6"
  }
  legend_l2: {
    label: "Level 2+ (bottom subtrees)"
    shape: circle
    style.fill: "#88DCF7"
  }
}
logical.arrow1 -> physical.mem: "maps to" {
  style.stroke-dash: 3
  style.stroke: "#6772E5"
}