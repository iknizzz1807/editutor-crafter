direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "Van Emde Boas (vEB) Layout Construction"
  style: {
    font-size: 24
    bold: true
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: {
    direction: down
    label: "Step 1: Original Tree (H=4)"
    
    orig_tree: {
      style.fill: "#E8F4FD"
      orig_root: "R" {
        shape: circle
        style.fill: "#4A90D9"
        style.font-color: white
      }
      
      l1: "" {
        direction: right
        style.stroke: transparent
        n1: "1" { shape: circle }
        n2: "2" { shape: circle }
      }
      
      l2: "" {
        direction: right
        style.stroke: transparent
        n3: "3" { shape: circle }
        n4: "4" { shape: circle }
        n5: "5" { shape: circle }
        n6: "6" { shape: circle }
      }
      
      l3: "" {
        direction: right
        style.stroke: transparent
        n7: "7" { shape: circle; style.fill: "#FFE4B5" }
        n8: "8" { shape: circle; style.fill: "#FFE4B5" }
        n9: "9" { shape: circle; style.fill: "#E8B4B4" }
        nA: "A" { shape: circle; style.fill: "#E8B4B4" }
        nB: "B" { shape: circle; style.fill: "#B8D4B8" }
        nC: "C" { shape: circle; style.fill: "#B8D4B8" }
        nD: "D" { shape: circle; style.fill: "#D4B8D4" }
        nE: "E" { shape: circle; style.fill: "#D4B8D4" }
      }

      orig_root -> l1.n1
      orig_root -> l1.n2
      l1.n1 -> l2.n3
      l1.n1 -> l2.n4
      l1.n2 -> l2.n5
      l1.n2 -> l2.n6
      l2.n3 -> l3.n7
      l2.n3 -> l3.n8
      l2.n4 -> l3.n9
      l2.n4 -> l3.nA
      l2.n5 -> l3.nB
      l2.n5 -> l3.nC
      l2.n6 -> l3.nD
      l2.n6 -> l3.nE
    }

    cut: "Split Line (H/2)" {
      shape: callout
      style.stroke: red
      style.font-color: red
      style.stroke-dash: 3
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step2: {
    direction: down
    label: "Step 2: Partitioned Subtrees"

    top_subtree: "Top Subtree (Upper H/2 Levels)" {
      style.fill: "#E8F4FD"
      t_root: "R" { shape: circle; style.fill: "#4A90D9"; style.font-color: white }
      t_l1: "" {
        direction: right
        style.stroke: transparent
        t1: "1" { shape: circle }
        t2: "2" { shape: circle }
      }
      t_root -> t_l1.t1
      t_root -> t_l1.t2
    }

    bottom_container: "Bottom Subtrees (Lower H/2 Levels)" {
      direction: right
      style.fill: "#FFF8E7"
      
      t1_sub: "T1" {
        n3: "3" { shape: circle; style.fill: "#FFE4B5" }
        n7: "7" { shape: circle }
        n8: "8" { shape: circle }
        n3 -> n7
        n3 -> n8
      }
      t2_sub: "T2" {
        n4: "4" { shape: circle; style.fill: "#E8B4B4" }
        n9: "9" { shape: circle }
        nA: "A" { shape: circle }
        n4 -> n9
        n4 -> nA
      }
      t3_sub: "T3" {
        n5: "5" { shape: circle; style.fill: "#B8D4B8" }
        nB: "B" { shape: circle }
        nC: "C" { shape: circle }
        n5 -> nB
        n5 -> nC
      }
      t4_sub: "T4" {
        n6: "6" { shape: circle; style.fill: "#D4B8D4" }
        nD: "D" { shape: circle }
        nE: "E" { shape: circle }
        n6 -> nD
        n6 -> nE
      }
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step3: {
    direction: down
    label: "Step 3: Recursive Memory Layout"

    veb_layout: {
      shape: sql_table
      label: "Contiguous Memory (vEB Mapping)"
      header: "Offset | Node | Subtree"
      r0: "0x00 | R | Δ (Top)"
      r1: "0x04 | 1 | Δ (Top)"
      r2: "0x08 | 2 | Δ (Top)"
      r3: "0x0C | 3 | T1 (Bottom)"
      r4: "0x10 | 7 | T1 (Bottom)"
      r5: "0x14 | 8 | T1 (Bottom)"
      r6: "0x18 | 4 | T2 (Bottom)"
      r7: "0x1C | 9 | T2 (Bottom)"
      r8: "0x20 | A | T2 (Bottom)"
      r9: "0x24 | 5 | T3 (Bottom)"
      r10: "0x28 | B | T3 (Bottom)"
      r11: "0x2C | C | T3 (Bottom)"
      r12: "0x30 | 6 | T4 (Bottom)"
      r13: "0x34 | D | T4 (Bottom)"
      r14: "0x38 | E | T4 (Bottom)"
    }

    cache_viz: {
      direction: right
      style.stroke: transparent
      cl1: "Cache Line 1 (Δ)" {
        style.fill: "#4A90D9"
        style.font-color: white
      }
      cl2: "Cache Line 2 (T1)" {
        style.fill: "#FFE4B5"
      }
      cl3: "Cache Line 3 (T2)" {
        style.fill: "#E8B4B4"
      }
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  analysis: {
    label: "Cache-Optimal Property Analysis"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
    content: |'md
      **Key Result:** Search takes O(log_B N) cache misses.
      - **Parameter-Free:** The layout does not depend on cache line size B.
      - **Subtree Locality:** Any subtree of height h is stored in a contiguous block.
      - **Static Efficiency:** Optimal performance across L1, L2, L3, and RAM.
    '|
  }
}

legend_node: {
  near: bottom-right
  label: "Legend"
  style.fill: "#FAFAFA"
  
  items: {
    direction: down
    l_top: "Top Subtree (Δ)" {
      shape: circle
      style.fill: "#4A90D9"
      style.font-color: white
    }
    l_bot: "Bottom Subtrees (Ti)" {
      shape: circle
      style.fill: "#FFE4B5"
    }
  }
}

header -> row1: "Initiate"
row1 -> row2: "Recursively split height H/2"
row2 -> row3: "Map to contiguous array"
row3 -> row4: "Final Analysis"