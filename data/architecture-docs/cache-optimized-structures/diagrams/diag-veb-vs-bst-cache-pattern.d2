direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Cache Access Pattern Comparison {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: "Search for key 750 in tree of 1000 elements" {
  near: top-center
  shape: text
  style.font-size: 18
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  veb_section: {
    direction: down
    label: "Van Emde Boas Layout"
    veb_memory: {
      direction: right
      label: "Memory Layout"
      veb_cl0: {
        label: "CL 0"
        shape: rectangle
        width: 140
        style.fill: "#90EE90"
        style.stroke: "#228B22"
        veb_cl0_note: "Top subtree\n(root + 2 levels)\n7 nodes" {
          shape: text
          style.font-size: 10
        }
      }
      veb_cl1: {
        label: "CL 1-2"
        shape: rectangle
        width: 140
        style.fill: "#98FB98"
        style.stroke: "#228B22"
        veb_cl1_note: "Bottom subtree 1\n31 nodes" {
          shape: text
          style.font-size: 10
        }
      }
      veb_cl2: {
        label: "CL 3-4"
        shape: rectangle
        width: 140
        style.fill: "#98FB98"
        style.stroke: "#228B22"
        veb_cl2_note: "Target subtree\ncontiguous" {
          shape: text
          style.font-size: 10
        }
      }
    }
    veb_timeline: {
      direction: down
      label: "Access Timeline"
      width: 450
      veb_t0: {
        label: "T0: Load CL 0"
        width: 420
        code: |'c
          root = keys[0]      // Cache MISS (200 cycles)
          child = keys[1]     // Cache HIT (4 cycles)  
          grandchild = keys[3] // Cache HIT (4 cycles)
        '|
        style.fill: "#E8F5E9"
      }
      veb_t1: {
        label: "T1: Load CL 1-2 (bottom subtree)"
        width: 420
        code: |'c
          descend to target subtree
          // Cache MISS (200 cycles) - entire subtree loads
          search within subtree
          // All subsequent accesses: HIT (4 cycles each)
        '|
        style.fill: "#C8E6C9"
      }
      veb_result: {
        label: "Result: 2 cache misses for 10-level search"
        shape: rectangle
        width: 420
        style: {
          fill: "#4CAF50"
          font-color: white
          bold: true
        }
      }
    }
  }
  bst_section: {
    direction: down
    label: "Pointer-Based BST"
    bst_memory: {
      direction: right
      label: "Memory Layout (Scattered)"
      bst_cl0: {
        label: "CL ?"
        shape: rectangle
        width: 90
        style.fill: "#FFB6C1"
        style.stroke: "#B22222"
        bst_cl0_note: "root node\n(heap addr 0x1A40)" {
          shape: text
          style.font-size: 9
        }
      }
      bst_cl1: {
        label: "CL ???"
        shape: rectangle
        width: 90
        style.fill: "#FFB6C1"
        style.stroke: "#B22222"
        bst_cl1_note: "left child\n(addr 0x7F20)" {
          shape: text
          style.font-size: 9
        }
      }
      bst_cl2: {
        label: "CL ????"
        shape: rectangle
        width: 90
        style.fill: "#FFB6C1"
        style.stroke: "#B22222"
        bst_cl2_note: "node\n(addr 0x3B10)" {
          shape: text
          style.font-size: 9
        }
      }
      bst_dots: "..." {
        shape: text
        style.font-size: 16
      }
      bst_cl9: {
        label: "CL ????"
        shape: rectangle
        width: 90
        style.fill: "#FFB6C1"
        style.stroke: "#B22222"
        bst_cl9_note: "target node\n(addr 0xC8F0)" {
          shape: text
          style.font-size: 9
        }
      }
    }
    bst_timeline: {
      direction: down
      label: "Access Timeline"
      width: 450
      bst_t0: {
        label: "T0: Load root"
        width: 420
        code: |'c
          root = *node_ptr     // Cache MISS (200 cycles)
          // Each node is a separate allocation!
        '|
        style.fill: "#FFEBEE"
      }
      bst_t1: {
        label: "T1-T9: Follow pointers"
        width: 420
        code: |'c
          node = root->left    // Cache MISS (200 cycles)
          node = node->right   // Cache MISS (200 cycles)
          node = node->left    // Cache MISS (200 cycles)
          // ... each hop = new cache line
          // 10 levels = 10 cache misses!
        '|
        style.fill: "#FFCDD2"
      }
      bst_result: {
        label: "Result: 10 cache misses for 10-level search"
        shape: rectangle
        width: 420
        style: {
          fill: "#E53935"
          font-color: white
          bold: true
        }
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  comparison: {
    direction: down
    label: "Cache Efficiency Comparison"
    metrics: {
      shape: sql_table
      label: "Performance Metrics (1000 elements)"
      m0: "Metric | vEB Layout | Pointer BST"
      m1: "Cache misses | 2-3 | 10"
      m2: "Cycles (est) | ~500 | ~2000"
      m3: "Speedup | 4-5x | baseline"
      m4: "Memory locality | Contiguous | Scattered"
    }
    style.fill: "#F5F5F5"
  }
  why_box: {
    direction: down
    label: "Why vEB Wins"
    width: 380
    insight: {
      width: 360
      code: |'c
// vEB layout groups tree levels into
// contiguous memory blocks:
// - Top subtree fits in 1-2 cache lines
// - Each bottom subtree is contiguous
// - Search path stays within loaded blocks
// Pointer BST scatters nodes:
// - malloc() places nodes randomly
// - Each pointer chase = new cache line
// - No spatial locality exploited
      '|
    }
    style.fill: "#E3F2FD"
  }
}
legend: {
  near: bottom-center
  direction: right
  l1: "CL = Cache Line (64 bytes)" {
    shape: text
    style.font-size: 12
  }
  l2: " | " {
    shape: text
  }
  l3: "Green = Cache HIT (4 cycles)" {
    shape: text
    style: {
      font-size: 12
      font-color: "#228B22"
    }
  }
  l4: " | " {
    shape: text
  }
  l5: "Red = Cache MISS (200 cycles)" {
    shape: text
    style: {
      font-size: 12
      font-color: "#B22222"
    }
  }
}
veb_section.veb_memory.veb_cl0 -> veb_section.veb_timeline.veb_t0: "search starts"
veb_section.veb_timeline.veb_t0 -> veb_section.veb_timeline.veb_t1: "descend"
bst_section.bst_memory.bst_cl0 -> bst_section.bst_timeline.bst_t0: "search starts"
bst_section.bst_timeline.bst_t0 -> bst_section.bst_timeline.bst_t1: "10 pointer hops" {
  style.stroke-dash: 3
}