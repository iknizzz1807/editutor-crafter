vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cache Line Anatomy (64 Bytes)
  Fundamental unit of data transfer between memory hierarchy levels
| {near: top-center}
# Main cache line container
cache_line: {
  label: "Cache Line (64 bytes)"
