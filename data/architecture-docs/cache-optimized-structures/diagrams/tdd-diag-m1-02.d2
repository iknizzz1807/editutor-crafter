}
# Data type mappings
mappings: {
  label: "Data Type Mappings"
  float_array: {
    label: "float array (4 bytes each)"
    style.fill: "#E8F4FC"
    f0: "float[0]" {style.fill: "#4A90D9"; style.font-color: white}
    f1: "float[1]" {style.fill: "#4A90D9"; style.font-color: white}
    f2: "float[2]" {style.fill: "#4A90D9"; style.font-color: white}
    f3: "float[3]" {style.fill: "#4A90D9"; style.font-color: white}
    f4: "float[4]" {style.fill: "#5BA3E0"; style.font-color: white}
    f5: "float[5]" {style.fill: "#5BA3E0"; style.font-color: white}
    f6: "float[6]" {style.fill: "#5BA3E0"; style.font-color: white}
    f7: "float[7]" {style.fill: "#5BA3E0"; style.font-color: white}
    f8: "float[8]" {style.fill: "#6DB5E7"; style.font-color: white}
    f9: "float[9]" {style.fill: "#6DB5E7"; style.font-color: white}
    f10: "float[10]" {style.fill: "#6DB5E7"; style.font-color: white}
    f11: "float[11]" {style.fill: "#6DB5E7"; style.font-color: white}
    f12: "float[12]" {style.fill: "#7FC8EE"; style.font-color: "#1A3A5C"}
    f13: "float[13]" {style.fill: "#7FC8EE"; style.font-color: "#1A3A5C"}
    f14: "float[14]" {style.fill: "#7FC8EE"; style.font-color: "#1A3A5C"}
    f15: "float[15]" {style.fill: "#7FC8EE"; style.font-color: "#1A3A5C"}
  }
  float_array.grid-columns: 4
  float_array.grid-gap: 2
  int_array: {
    label: "int32_t array (4 bytes each)"
    style.fill: "#FFF4E8"
    i0: "int[0]" {style.fill: "#E8944A"; style.font-color: white}
    i1: "int[1]" {style.fill: "#E8944A"; style.font-color: white}
    i2: "int[2]" {style.fill: "#E8944A"; style.font-color: white}
    i3: "int[3]" {style.fill: "#E8944A"; style.font-color: white}
    i4: "int[4]" {style.fill: "#E8A45B"; style.font-color: white}
    i5: "int[5]" {style.fill: "#E8A45B"; style.font-color: white}
    i6: "int[6]" {style.fill: "#E8A45B"; style.font-color: white}
    i7: "int[7]" {style.fill: "#E8A45B"; style.font-color: white}
    i8: "int[8]" {style.fill: "#E8B46C"; style.font-color: white}
    i9: "int[9]" {style.fill: "#E8B46C"; style.font-color: white}
    i10: "int[10]" {style.fill: "#E8B46C"; style.font-color: white}
    i11: "int[11]" {style.fill: "#E8B46C"; style.font-color: white}
    i12: "int[12]" {style.fill: "#E8C47D"; style.font-color: "#5C3A1A"}
    i13: "int[13]" {style.fill: "#E8C47D"; style.font-color: "#5C3A1A"}
    i14: "int[14]" {style.fill: "#E8C47D"; style.font-color: "#5C3A1A"}
    i15: "int[15]" {style.fill: "#E8C47D"; style.font-color: "#5C3A1A"}
  }
  int_array.grid-columns: 4
  int_array.grid-gap: 2
  struct_example: {
    label: "struct ParticleAoS (32 bytes each)"
    style.fill: "#F0E8FC"
    p1: "Particle 0" {
      style.fill: "#9B7ED9"
      style.font-color: white
      label: |md
        **Particle 0**
        x,y,z,vx,vy,vz,mass
        (28 bytes + 4 padding)
      |
    }
    p2: "Particle 1" {
      style.fill: "#A98EE0"
      style.font-color: white
      label: |md
        **Particle 1**
        x,y,z,vx,vy,vz,mass
        (28 bytes + 4 padding)
      |
    }
  }
  struct_example.grid-columns: 2
  struct_example.grid-gap: 0
}
# Cache line metadata
metadata: {
  label: "Cache Line Metadata (Hardware)"
  style.fill: "#F5F5F5"
  tag: {
    label: |md
      **Tag Bits**
      Identifies which memory block
      this cache line represents
    |
    style.fill: "#90EE90"
  }
  valid: {
    label: |md
      **Valid Bit**
      1 = contains valid data
      0 = line is invalid/empty
    |
    style.fill: "#98FB98"
  }
  dirty: {
    label: |md
      **Dirty Bit**
      1 = modified, needs write-back
      0 = clean, matches memory
    |
    style.fill: "#7CFC00"
  }
  mesi: {
    label: |md
      **MESI State**
      Modified/Exclusive/Shared/Invalid
      Coherence protocol state
    |
    style.fill: "#00FA9A"
  }
  lru: {
    label: |md
      **LRU Bits**
      For replacement policy
      Tracks access recency
    |
    style.fill: "#00FF7F"
  }
}
metadata.grid-columns: 3
metadata.grid-gap: 8
# Key statistics
stats: {
  label: "Key Statistics"
  style.fill: "#FFFACD"
  stat1: |md
    **Capacity per cache line:**
    - 16 × float (4 bytes each)
    - 16 × int32_t (4 bytes each)
    - 8 × double (8 bytes each)
    - 8 × int64_t/pointer (8 bytes each)
    - 2 × ParticleAoS (32 bytes each)
  |
  stat2: |md
    **Transfer efficiency:**
    - CPU fetches ENTIRE line
    - Even if you read 1 byte
    - Spatial locality is FREE
    - Sequential access = max benefit
  |
  stat3: |md
    **Alignment matters:**
    - Address % 64 = offset in line
    - Misaligned data spans lines
    - 2 cache misses for 1 access
  |
}
stats.grid-columns: 1
stats.grid-gap: 4
# Performance implications
implications: {
  label: "Performance Implications"
  style.fill: "#FFE4E1"
  good: {
    label: "✓ Cache-Friendly Patterns"
    style.fill: "#90EE90"
    content: |md
      - Sequential array access
      - Array of same-type data
      - Struct of Arrays (SoA)
      - Aligned allocations
    |
  }
  bad: {
    label: "✗ Cache-Hostile Patterns"
    style.fill: "#FFB6C1"
    content: |md
      - Random/strided access
      - Linked list traversal
      - Column-wise matrix access
      - Pointer chasing chains
    |
  }
}
implications.grid-columns: 2
implications.grid-gap: 16
# Connections
cache_line.content.row1.b0_3 -- mappings.float_array.f0
cache_line.content.row1.b0_3 -- mappings.int_array.i0
cache_line.content.row1.b0_3 -- mappings.struct_example.p1
# Legend
legend: {
  label: "Color Legend"
  style.fill: "#FFFFFF"
  blue: "Blue gradient = Byte positions" {style.fill: "#4A90D9"; style.font-color: white}
  orange: "Orange = int32_t mapping" {style.fill: "#E8944A"; style.font-color: white}
  purple: "Purple = struct mapping" {style.fill: "#9B7ED9"; style.font-color: white}
  green: "Green = Hardware metadata" {style.fill: "#90EE90"}
}
legend.grid-columns: 2
legend.grid-gap: 8