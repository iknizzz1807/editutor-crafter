    o56: "56"
    o57: "57"
    o58: "58"
    o59: "59"
    o60: "60"
    o61: "61"
    o62: "62"
    o63: "63"
  }
  offsets.style.fill: transparent
  offsets.style.stroke: transparent
  # Data content blocks
  content: {
    label: ""
    # Row 1: bytes 0-15 (4 floats or 4 ints)
    row1: {
      label: ""
      grid-columns: 4
      grid-gap: 0
      b0_3: {
        label: "Bytes\n0-3"
        style.fill: "#4A90D9"
        style.font-color: white
        style.stroke: "#2E5A8C"
      }
      b4_7: {
        label: "Bytes\n4-7"
        style.fill: "#4A90D9"
        style.font-color: white
        style.stroke: "#2E5A8C"
      }
      b8_11: {
        label: "Bytes\n8-11"
        style.fill: "#4A90D9"
        style.font-color: white
        style.stroke: "#2E5A8C"
      }
      b12_15: {
        label: "Bytes\n12-15"
        style.fill: "#4A90D9"
        style.font-color: white
        style.stroke: "#2E5A8C"
      }
    }
    # Row 2: bytes 16-31
    row2: {
      label: ""
      grid-columns: 4
      grid-gap: 0
      b16_19: {
        label: "Bytes\n16-19"
        style.fill: "#5BA3E0"
        style.font-color: white
        style.stroke: "#2E5A8C"
      }
      b20_23: {
        label: "Bytes\n20-23"
