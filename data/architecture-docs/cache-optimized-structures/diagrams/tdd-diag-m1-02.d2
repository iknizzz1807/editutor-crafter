      b28_31: {
        label: "Bytes\n28-31"
        style.fill: "#5BA3E0"
        style.font-color: white
        style.stroke: "#2E5A8C"
      }
    }
    # Row 3: bytes 32-47
    row3: {
      label: ""
      grid-columns: 4
      grid-gap: 0
      b32_35: {
        label: "Bytes\n32-35"
        style.fill: "#6DB5E7"
