vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
}

# ---------------------------------------------------------------------------------
# CLASS DEFINITIONS: Intel Technical Manual Specification Quality
# ---------------------------------------------------------------------------------
classes: {
  axis: {
    style: {
      stroke: "#1A1A1B"
      stroke-width: 5
    }
  }
  cache_region: {
    style: {
      stroke-width: 3
      border-radius: 4
      opacity: 0.95
      shadow: true
    }
  }
  label_text: {
    shape: text
    style: {
      font-size: 16
      bold: true
      font: mono
    }
  }
  boundary_line: {
    width: 2
    height: 450
    style: {
      stroke-dash: 8
      stroke-width: 2
    }
  }
  inflection_point: {
    shape: circle
    width: 20
    height: 20
    style: {
      stroke: white
      stroke-width: 3
    }
  }
  callout: {
    style: {
      stroke: "#FFAB00"
      stroke-width: 2
      fill: "#FFF8E1"
      font: mono
    }
  }
}

# ---------------------------------------------------------------------------------
# MAIN DIAGRAM STRUCTURE
# ---------------------------------------------------------------------------------
MemoryHierarchyGraph: "Figure 1-1: Microarchitecture Latency vs. Working Set Size (Intel x86-64)" {
  style: {
    stroke: "#222222"
    fill: "#FDFDFD"
    stroke-width: 2
    border-radius: 0
  }

  # Axis Labels - Placed with precision
  y_title: "Access Latency (Clock Cycles - Log Scale)" {
    class: label_text
  }
  
  x_title: "Working Set Size (Bytes - Log Scale)" {
    class: label_text
  }

  # -------------------------------------------------------------------------------
  # PLOT AREA: Step-Function Logic
  # -------------------------------------------------------------------------------
  PlotArea: {
    direction: right
    style.fill: transparent
    style.stroke: transparent

    # Vertical Latency Axis (Y) Visual Representation
    y_axis_marker: {
      class: axis
      height: 450
      width: 2
    }

    # Region 1: L1 Data Cache (Fastest Path)
    L1_Step: "L1 Data Cache\n(4 Cycles)" {
      class: cache_region
      width: 140
      height: 60
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      
      tooltip: |md
        ### L1 Data Cache (L1D)
        - **Latency:** 4 cycles (Fixed Load-to-Use)
        - **Throughput:** Two 32-byte loads per cycle
        - **Associativity:** 8-way set associative
        - **Line Size:** 64 Bytes
      |
    }

    # Region 2: L2 Unified Cache
    L2_Step: "L2 Unified Cache\n(12 Cycles)" {
      class: cache_region
      width: 180
      height: 120
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      
      tooltip: |md
        ### L2 Unified Cache (MLC)
        - **Latency:** ~12 cycles (Non-inclusive)
        - **Bandwidth:** 32-64 bytes per cycle to L1
        - **Associativity:** 4-way to 16-way
        - **Inclusive:** Depends on architecture (e.g., Skylake vs Sunny Cove)
      |
    }

    # Region 3: Last Level Cache (Shared)
    L3_Step: "L3 Shared LLC\n(40+ Cycles)" {
      class: cache_region
      width: 220
      height: 220
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      
      tooltip: |md
        ### Last Level Cache (LLC)
        - **Latency:** 38-44 cycles (Architecture dependent)
        - **Structure:** Slice-based, ring/mesh interconnect
        - **Policy:** Inclusive (traditional Intel) or Non-inclusive (Server)
      |
    }

    # Region 4: System DRAM
    RAM_Step: "System DRAM\n(200-300+ Cycles)" {
      class: cache_region
      width: 280
      height: 400
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      
      tooltip: |md
        ### Main Memory (DRAM)
        - **Latency:** ~200-350 cycles
        - **Components:** Memory Controller (iMC) + DIMM + Row Buffers
        - **Floor:** CAS Latency + Command Overhead
        - **NUMA:** Latency doubles for remote sockets
      |
    }

    # -----------------------------------------------------------------------------
    # BOUNDARY MARKERS: Critical Thresholds
    # -----------------------------------------------------------------------------
    Boundaries: {
      style.stroke: transparent
      
      B1_32KB: "32KB\nLimit" {
        class: boundary_line
        style.stroke: "#2E7D32"
      }
      B2_256KB: "256KB\nLimit" {
        class: boundary_line
        style.stroke: "#1565C0"
      }
      B3_8MB: "8MB\nLimit" {
        class: boundary_line
        style.stroke: "#EF6C00"
      }
    }

    # INFLECTION MARKERS: Miss Point Visualization
    InflectionPoints: {
      style.stroke: transparent
      p1: { class: [inflection_point]; style.fill: "#2E7D32" }
      p2: { class: [inflection_point]; style.fill: "#1565C0" }
      p3: { class: [inflection_point]; style.fill: "#EF6C00" }
    }
  }
}

# ---------------------------------------------------------------------------------
# GRAPH LOGIC & INTER-COMPONENT ROUTING
# ---------------------------------------------------------------------------------

# Primary Latency Progression Path (The 'Staircase')
MemoryHierarchyGraph.PlotArea.L1_Step -> MemoryHierarchyGraph.PlotArea.L2_Step: "L1 Miss" {
  style.stroke-width: 4
  style.stroke: "#444444"
}
MemoryHierarchyGraph.PlotArea.L2_Step -> MemoryHierarchyGraph.PlotArea.L3_Step: "L2 Miss" {
  style.stroke-width: 4
  style.stroke: "#444444"
}
MemoryHierarchyGraph.PlotArea.L3_Step -> MemoryHierarchyGraph.PlotArea.RAM_Step: "L3 Miss" {
  style.stroke-width: 4
  style.stroke: "#444444"
}

# Structural Alignment: Linking Plot Elements to Physical Boundaries
MemoryHierarchyGraph.PlotArea.L1_Step -- MemoryHierarchyGraph.PlotArea.Boundaries.B1_32KB
MemoryHierarchyGraph.PlotArea.Boundaries.B1_32KB -- MemoryHierarchyGraph.PlotArea.L2_Step

MemoryHierarchyGraph.PlotArea.L2_Step -- MemoryHierarchyGraph.PlotArea.Boundaries.B2_256KB
MemoryHierarchyGraph.PlotArea.Boundaries.B2_256KB -- MemoryHierarchyGraph.PlotArea.L3_Step

MemoryHierarchyGraph.PlotArea.L3_Step -- MemoryHierarchyGraph.PlotArea.Boundaries.B3_8MB
MemoryHierarchyGraph.PlotArea.Boundaries.B3_8MB -- MemoryHierarchyGraph.PlotArea.RAM_Step

# Visual Anchors for Inflection Points
MemoryHierarchyGraph.PlotArea.InflectionPoints.p1 -- MemoryHierarchyGraph.PlotArea.Boundaries.B1_32KB: { style.stroke-width: 0 }
MemoryHierarchyGraph.PlotArea.InflectionPoints.p2 -- MemoryHierarchyGraph.PlotArea.Boundaries.B2_256KB: { style.stroke-width: 0 }
MemoryHierarchyGraph.PlotArea.InflectionPoints.p3 -- MemoryHierarchyGraph.PlotArea.Boundaries.B3_8MB: { style.stroke-width: 0 }

# ---------------------------------------------------------------------------------
# TECHNICAL LEGEND & DOCUMENTATION BLOCKS
# ---------------------------------------------------------------------------------
TechnicalDetails: {
  label: "Microarchitecture Latency Specification Table"
  description: ||md
    | Level | Access Time | Typical Size | Associativity |
    | :--- | :--- | :--- | :--- |
    | **L1** | 4 cycles | 32-64 KB | 8-way |
    | **L2** | 12 cycles | 256-512 KB | 4-16 way |
    | **L3** | 40 cycles | 2-32 MB | 16-way |
    | **RAM** | 200+ cycles | 8 GB+ | N/A |
  ||
}

SummaryNotes: {
  shape: rectangle
  label: |md
    ### PERFORMANCE IMPACT NOTE
    Working sets exceeding L3 capacity (LLC)
    induce 'Pointer Chasing' stalls. 
    Memory wall effects trigger ~10x 
    performance degradation as the CPU 
    waits on DRAM row-buffer activation 
    and CAS latency cycles.
  |
}

# ---------------------------------------------------------------------------------
# GLOBAL STYLING & FORMATTING
# ---------------------------------------------------------------------------------
***.style.font: mono
(*** -> ***)[*]: {
  style.stroke: "#333333"
  style.stroke-width: 2
}

# Specific formatting for the Markdown containers to ensure Intel quality
TechnicalDetails.style.fill: "#F0F0F0"
TechnicalDetails.style.stroke: "#888888"
TechnicalDetails.style.stroke-width: 1

SummaryNotes.style.fill: "#FFF9C4"
SummaryNotes.style.stroke: "#FBC02D"