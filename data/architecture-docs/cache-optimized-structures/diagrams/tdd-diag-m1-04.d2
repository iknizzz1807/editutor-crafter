vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Sequential vs Random Access: Prefetcher Effectiveness
| {near: top-center}
sequential_container: {
  label: "Sequential Access Pattern"
  sequential_array: {
    grid-rows: 1
    grid-gap: 0
    elem0: "[0]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
    elem1: "[1]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
    elem2: "[2]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
    elem3: "[3]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
    elem4: "[4]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
    elem5: "[5]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
    elem6: "[6]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
    elem7: "[7]" {
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
    }
  }
  access_order_seq: {
    shape: text
    label: "Access: 0 → 1 → 2 → 3 → 4 → 5 → 6 → 7"
  }
  cache_line_seq: {
    label: "Cache Line (64 bytes)"
    shape: rectangle
    style.fill: "transparent"
    style.stroke: "#2196F3"
    style.stroke-width: 3
    style.stroke-dash: 4
  }
  prefetcher_seq: {
    shape: diamond
    label: "Prefetcher\nACTIVE ✓"
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.font-color: "#1B5E20"
  }
  latency_seq: {
    shape: text
    label: |md
      **Latency: ~4-8 cycles/access**
      * After first miss, subsequent
      * accesses hit in same cache line
      * Prefetcher anticipates next line
    |
  }
}
sequential_container.cache_line_seq -- sequential_container.sequential_array: {style.stroke: transparent}
random_container: {
  label: "Random Access Pattern"
  perm_array: {
    label: "Permutation Array"
    grid-rows: 1
    grid-gap: 0
    p0: "5" {
      style.fill: "#FF9800"
      style.stroke: "#E65100"
      style.font-color: white
      width: 40
    }
    p1: "2" {
      style.fill: "#FF9800"
      style.stroke: "#E65100"
      style.font-color: white
      width: 40
    }
    p2: "7" {
      style.fill: "#FF9800"
      style.stroke: "#E65100"
      style.font-color: white
      width: 40
    }
    p3: "0" {
      style.fill: "#FF9800"
      style.stroke: "#E65100"
      style.font-color: white
      width: 40
    }
    p4: "3" {
      style.fill: "#FF9800"
      style.stroke: "#E65100"
      style.font-color: white
      width: 40
    }
  }
  data_array: {
    grid-rows: 1
    grid-gap: 0
    d0: "[0]" {
      style.fill: "#F44336"
      style.stroke: "#B71C1C"
      style.font-color: white
    }
    d1: "[1]" {
      style.fill: "#9E9E9E"
      style.stroke: "#616161"
      style.font-color: white
    }
    d2: "[2]" {
      style.fill: "#F44336"
      style.stroke: "#B71C1C"
      style.font-color: white
    }
    d3: "[3]" {
      style.fill: "#F44336"
      style.stroke: "#B71C1C"
      style.font-color: white
    }
    d4: "[4]" {
      style.fill: "#9E9E9E"
      style.stroke: "#616161"
      style.font-color: white
    }
    d5: "[5]" {
      style.fill: "#F44336"
      style.stroke: "#B71C1C"
      style.font-color: white
    }
    d6: "[6]" {
      style.fill: "#9E9E9E"
      style.stroke: "#616161"
      style.font-color: white
    }
    d7: "[7]" {
      style.fill: "#F44336"
      style.stroke: "#B71C1C"
      style.font-color: white
    }
  }
  access_order_rand: {
    shape: text
    label: "Access: 5 → 2 → 7 → 0 → 3 (scattered!)"
  }
  prefetcher_rand: {
    shape: diamond
    label: "Prefetcher\nDEFEATED ✗"
    style.fill: "#FFCDD2"
    style.stroke: "#B71C1C"
    style.font-color: "#B71C1C"
  }
  latency_rand: {
    shape: text
    label: |md
      **Latency: ~40-200 cycles/access**
      * Each access likely cache miss
      * No pattern for prefetcher
      * Same cache line may be loaded
      * multiple times (thrashing)
    |
  }
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  legend_title: {
    shape: text
    label: "**Legend**"
  }
  legend_content: {
    grid-columns: 4
    grid-gap: 16
    seq_hit: "Sequential Hit" {
      style.fill: "#4CAF50"
      style.font-color: white
    }
    rand_miss: "Random Miss" {
      style.fill: "#F44336"
      style.font-color: white
    }
    rand_skip: "Not Accessed" {
      style.fill: "#9E9E9E"
      style.font-color: white
    }
    perm: "Permutation" {
      style.fill: "#FF9800"
      style.font-color: white
    }
  }
}
summary: {
  near: bottom-center
  shape: text
  label: |md
    **Key Insight:** Sequential access exploits spatial locality — each 64-byte cache line brings 16 floats.
    Random access defeats prefetcher, causing ~50x slower per-access latency.
    For arrays exceeding L1 cache, random can be **10-50x slower** overall.
  |
}
sequential_container -> random_container: " vs " {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 4
  style.font-size: 20
}