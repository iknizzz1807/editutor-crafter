direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Technical Metadata for Engineering Spec
title: |md
  # Cache Line Stride Benchmark: Memory Layout Analysis
  **Hardware Context:** L1d=32KB, LineSize=64B, Prefetcher=Enabled
  **Alignment:** 8-byte aligned pointers
| {near: top-center}

# Global Memory Component Classes (Intel Manual Standard)
classes: {
  header: { style: { fill: "#9C27B0"; font-color: white; bold: true } }
  data_field: { style: { fill: "#2196F3"; font-color: white; bold: true } }
  free_space: { style: { fill: "#4CAF50"; font-color: white } }
  padding: { style: { fill: "#CFD8DC"; font-color: "#546E7A"; italic: true } }
  pointer: { style: { fill: "#FF9800"; font-color: black; bold: true } }
  cache_line_boundary: { style: { stroke-dash: 5; stroke-width: 2; border-radius: 2 } }
  metric_box: { style: { stroke-width: 1; border-radius: 4 } }
}

# 1. PHYSICAL BUFFER LAYOUT [0..63] (Detailed Byte Mapping)
buffer_view: {
  label: "Physical Layer: Single 64B Cache Line Structure"
  class: cache_line_boundary
  
  # Offsets and Field Sizes per Intel Spec
  layout: {
    grid-columns: 3
    grid-gap: 0
    
    # Header Row
    h1: "Offset (Hex)" { class: header }
    h2: "Field Identification" { class: header }
    h3: "Size" { class: header }

    # Row 1: Head Pointer
    off_0: "0x00" { style.font: mono }
    head: "Next_Ptr*" { class: pointer }
    sz_0: "8B" { style.font: mono }

    # Row 2: Metadata
    off_8: "0x08" { style.font: mono }
    meta: "Sequence_ID" { class: data_field }
    sz_8: "4B" { style.font: mono }

    # Row 3: Data payload
    off_c: "0x0C" { style.font: mono }
    data: "Payload_Segment" { class: data_field }
    sz_c: "20B" { style.font: mono }

    # Row 4: Padding to align to 64B line
    off_20: "0x20" { style.font: mono }
    pad: "Alignment Padding (Internal Wasted Space)" { class: padding }
    sz_20: "32B" { style.font: mono }
  }
  
  footer: "Total Size: 64 Bytes (sizeof=64)" {
    shape: text
    style.font-size: 12
  }
}

# 2. STRIDE-8 PATTERN (High Spatial Locality)
# Engineer Note: Fits 8 pointer-sized elements in one burst
stride_8_container: {
  label: "Stride-8 Analysis"
  
  stride_8: {
    label: "Stride-8 Access Pattern (Spatial Locality Optimization)"
    class: cache_line_boundary
    style.fill: "#E3F2FD"
    
    l1_cache_line_0: {
      label: "L1 Cache Line [0x00...0x3F]"
      grid-columns: 8
      
      # Accessed elements colored as Data
      e0: "[0]" { class: data_field }
      e8: "[8]" { class: data_field }
      e16: "[16]" { class: data_field }
      e24: "[24]" { class: data_field }
      e32: "[32]" { class: data_field }
      e40: "[40]" { class: data_field }
      e48: "[48]" { class: data_field }
      e56: "[56]" { class: data_field }
    }
  }

  stride_8_metrics: |md
    ### Performance Profile: Stride-8
    - **L1 Miss Rate:** 12.5% (1 per 8 accesses)
    - **Bandwidth Util:** 100% (All bytes in line utilized)
    - **Hardware Prefetch:** High Confidence (Linear)
    - **Cycles/Access:** ~4-5 (L1 Hit)
  | {
    class: metric_box
    style.stroke: "#4CAF50"
    style.fill: "#F1F8E9"
  }
}

# 3. STRIDE-64 PATTERN (Cache Hostile / Thrashing)
# Engineer Note: Each access evicts previous or forces new fetch
stride_64_container: {
  label: "Stride-64 Analysis"

  stride_64: {
    label: "Stride-64 Access Pattern (Cache Line Thrashing)"
    
    cl_0: "Cache Line N" {
      class: [cache_line_boundary; padding]
      acc_0: "ptr[0]" { class: data_field }
    }
    
    gap_1: "Gap: 63 Bytes ignored" { shape: text; style.font-size: 10 }

    cl_1: "Cache Line N+1" {
      class: [cache_line_boundary; padding]
      acc_64: "ptr[64]" { class: data_field }
    }

    gap_2: "Gap: 63 Bytes ignored" { shape: text; style.font-size: 10 }

    cl_2: "Cache Line N+2" {
      class: [cache_line_boundary; padding]
      acc_128: "ptr[128]" { class: data_field }
    }
  }

  stride_64_metrics: |md
    ### Performance Profile: Stride-64
    - **L1 Miss Rate:** 100% (Every access misses)
    - **Bandwidth Util:** 1.56% (Only 1/64 bytes used)
    - **Stall cycles:** ~150-300 (DRAM Fetch)
    - **Warning:** Effectively bypasses L1/L2 benefits
  | {
    class: metric_box
    style.stroke: "#D32F2F"
    style.fill: "#FFEBEE"
  }
}

# Logical Sequence & Flow
buffer_view -> stride_8_container.stride_8: "Optimized fit" {
  style.stroke: "#2E7D32"
  style.stroke-width: 4
}

stride_8_container.stride_8 -> stride_64_container.stride_64: "Scaling Stride > LineSize" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
  style.animated: true
}

# Implementation Legend
legend: {
  near: bottom-right
  class_hit: "L1 Cache Hit" { class: data_field }
  class_miss: "L1 Cache Miss / DRAM" { 
    style: {
      fill: "#FFEBEE"
      stroke: red 
    }
  }
  class_ptr: "Memory Pointer" { class: pointer }
  class_pad: "Wasted Memory" { class: padding }
}