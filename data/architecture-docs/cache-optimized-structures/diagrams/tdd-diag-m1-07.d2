vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}
title: Hardware Performance Counter Collection {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
direction: right
Application: Application Layer {
  style.fill: "#E8E8E8"
  Benchmark_Loop: Benchmark Loop {
    style.fill: "#D4E6F1"
    warmup: Warmup Iterations {
      style.fill: "#B8D4E8"
    }
    measurement: Measurement Iterations {
      style.fill: "#B8D4E8"
    }
    stats: Statistics Collection {
      style.fill: "#B8D4E8"
    }
  }
  counter_init: perf_counters_init {
    style.fill: "#C8E6C9"
    shape: hexagon
  }
  counter_start: perf_counters_start {
    style.fill: "#C8E6C9"
    shape: hexagon
  }
  counter_stop: perf_counters_stop {
    style.fill: "#C8E6C9"
    shape: hexagon
  }
  counter_read: perf_counters_read {
    style.fill: "#C8E6C9"
    shape: hexagon
  }
}
OS_Kernel: OS/Kernel Layer {
  style.fill: "#FFF2CC"
  syscall: syscall(__NR_perf_event_open) {
    style.fill: "#FFE699"
    shape: diamond
  }
  fd_allocation: File Descriptor Allocation {
    style.fill: "#FFE699"
  }
  pmu_config: PMU Configuration {
    style.fill: "#FFE699"
  }
}
Hardware: Hardware Layer {
  style.fill: "#F4CCCC"
  PMU: Performance Monitoring Unit {
    style.fill: "#EA9999"
    counter_regs: Hardware Counter Registers {
      style.fill: "#E06666"
      style.font-color: white
    }
    event_select: Event Selection {
      style.fill: "#E06666"
      style.font-color: white
    }
  }
  CPU_Events: CPU Events {
    style.fill: "#EA9999"
    L1_accesses: L1-dcache-loads
    L1_misses: L1-dcache-load-misses
    LLC_loads: LLC-loads
    LLC_misses: LLC-load-misses
  }
}
counter_init -> syscall: "perf_event_open attr"
syscall -> fd_allocation: "returns fd"
fd_allocation -> pmu_config: "configures counters"
pmu_config -> counter_regs: "enable events"
counter_start -> PMU: "ioctl(PERF_EVENT_IOC_ENABLE)"
counter_stop -> PMU: "ioctl(PERF_EVENT_IOC_DISABLE)"
CPU_Events -> counter_regs: "increments on event"
counter_read -> counter_regs: "read(fd, &value)"
counter_read -> stats: "results"
Benchmark_Loop.warmup -> counter_start: "before measurement"
Benchmark_Loop.measurement -> counter_stop: "after measurement"
annotation: |md
  ## Flow Summary
  1. **Init**: `perf_event_open()` configures hardware counters
  2. **Start**: `ioctl(fd, PERF_EVENT_IOC_ENABLE)` begins counting
  3. **Measure**: Benchmark code runs, PMU counts events
  4. **Stop**: `ioctl(fd, PERF_EVENT_IOC_DISABLE)` stops counting
  5. **Read**: `read(fd, &value)` retrieves counter values
| {
  near: bottom-center
  style.fill: white
  style.stroke: gray
}