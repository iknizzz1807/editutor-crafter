layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 40
  }
}

direction: right

title: {
  shape: text
  label: |'md
    # ParticleAoS Memory Layout (Technical Spec)
    ### Array-of-Structures: 32-Byte Aligned
    *Reference: Intel® 64 and IA-32 Architectures Optimization Reference Manual*
  '|
  near: top-center
}

# Left margin: Virtual Address / Byte Offsets
address_margin: {
  style.stroke-width: 0
  style.fill: transparent
  
  grid-columns: 1
  grid-gap: 0

  "0x00": "0x00 [P0 Base]" { shape: text; height: 32; style.font: mono }
  "0x04": "0x04" { shape: text; height: 32; style.font: mono }
  "0x08": "0x08" { shape: text; height: 32; style.font: mono }
  "0x0C": "0x0C" { shape: text; height: 32; style.font: mono }
  "0x10": "0x10" { shape: text; height: 32; style.font: mono }
  "0x14": "0x14" { shape: text; height: 32; style.font: mono }
  "0x18": "0x18" { shape: text; height: 32; style.font: mono }
  "0x1C": "0x1C" { shape: text; height: 32; style.font: mono }
  "0x20": "0x20 [P1 Base]" { shape: text; height: 32; style.font: mono }
  "0x24": "0x24" { shape: text; height: 32; style.font: mono }
  "0x28": "0x28" { shape: text; height: 32; style.font: mono }
  "0x2C": "0x2C" { shape: text; height: 32; style.font: mono }
  "0x30": "0x30" { shape: text; height: 32; style.font: mono }
  "0x34": "0x34" { shape: text; height: 32; style.font: mono }
  "0x38": "0x38" { shape: text; height: 32; style.font: mono }
  "0x3C": "0x3C" { shape: text; height: 32; style.font: mono }
  "0x40": "0x40 [P2 Base]" { 
    shape: text
    height: 32
    style: {
      font: mono
      bold: true
      font-color: "#D97706"
    }
  }
}

# Physical Memory Stack
container: {
  label: "Physical Memory Stack"
  style.fill: white
  style.stroke: "#333"
  style.stroke-width: 2

  Particle_0: "struct Particle [0] (32 Bytes)" {
    style.fill: "#F3E8FF"
    style.stroke: "#8B5CF6"
    style.bold: true

    grid-columns: 1
    grid-gap: 0

    x: "f32 x (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    y: "f32 y (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    z: "f32 z (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    vx: "f32 vx (4B)" { style.fill: "#E0F2FE"; width: 400; height: 32 }
    vy: "f32 vy (4B)" { style.fill: "#E0F2FE"; width: 400; height: 32 }
    vz: "f32 vz (4B)" { style.fill: "#E0F2FE"; width: 400; height: 32 }
    mass: "f32 mass (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    padding: "padding (4B)" { style.fill: "#F3F4F6"; width: 400; height: 32 }
  }

  Particle_1: "struct Particle [1] (32 Bytes)" {
    style.fill: "#F3E8FF"
    style.stroke: "#8B5CF6"
    style.bold: true

    grid-columns: 1
    grid-gap: 0

    x: "f32 x (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    y: "f32 y (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    z: "f32 z (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    vx: "f32 vx (4B)" { style.fill: "#E0F2FE"; width: 400; height: 32 }
    vy: "f32 vy (4B)" { style.fill: "#E0F2FE"; width: 400; height: 32 }
    vz: "f32 vz (4B)" { style.fill: "#E0F2FE"; width: 400; height: 32 }
    mass: "f32 mass (4B)" { style.fill: "#DBEAFE"; width: 400; height: 32 }
    padding: "padding (4B)" { style.fill: "#F3F4F6"; width: 400; height: 32 }
  }
}

# Relationship between addresses and blocks
address_margin -> container: { style.stroke-width: 0; target-arrowhead: none }

# Boundary Indicators
cache_indicators: {
  style.stroke-width: 0
  style.fill: transparent

  line_0: "L1 Cache Line Boundary (64B)" {
    shape: text
    style.font-color: "#D97706"
    style.bold: true
  }
}

# Placement of cache lines relative to memory
(container.Particle_1.padding) -> cache_indicators.line_0: {
  style.stroke: "#D97706"
  style.stroke-dash: 4
  style.stroke-width: 3
  label: "64B Edge"
}

# Metadata and Structure Legend
legend: {
  near: center-right
  style.fill: "#FFFFFF"
  style.stroke: "#666"
  style.shadow: true

  pos_label: "Position Fields" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#8B5CF6"
    width: 180
  }
  vel_label: "Velocity Fields" {
    shape: rectangle
    style.fill: "#E0F2FE"
    style.stroke: "#8B5CF6"
    width: 180
  }
  pad_label: "Alignment Padding" {
    shape: rectangle
    style.fill: "#F3F4F6"
    style.stroke: "#9CA3AF"
    width: 180
  }

  struct_info: {
    shape: text
    label: |'md
      **sizeof(Particle) = 32B**
      - Total Payload: 28 Bytes
      - Internal Padding: 4 Bytes
      - SIMD Suitability: Moderate
      - Cache Utilization: High (linear)
    '|
  }
}

# Analytical Summary for Implementation
summary: {
  shape: text
  near: bottom-left
  label: |'md
    ### Cache Efficiency & Performance Analysis
    | Component Access | Bytes/Iteration | Cache Utilization |
    |------------------|-----------------|-------------------|
    | Full Struct (All) | 32B / 32B       | 100.0%            |
    | Position (XYZ)    | 12B / 32B       | 37.5%             |
    | Velocity (Vxyz)   | 12B / 32B       | 37.5%             |
    
    **Implementation Impact:** 
    AoS layout provides excellent locality when *all* fields of an object are processed 
    simultaneously. However, if a kernel only requires 'Position' (e.g., collision detection), 
    62.5% of the cache-line traffic consists of unused bytes (Velocity, Mass, Padding).
  '|
}

# Connectivity Flow
container.Particle_0 -> container.Particle_1: "Next Memory Block" {
  style.stroke: "#8B5CF6"
  style.stroke-width: 2
  style.animated: true
}