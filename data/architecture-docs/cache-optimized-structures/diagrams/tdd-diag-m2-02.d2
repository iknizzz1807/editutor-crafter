direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

classes: {
  header_style: {
    style: {
      fill: "#D2B4DE"
      bold: true
      font-size: 14
      stroke: "#76448A"
    }
  }
  data_field: {
    style: {
      fill: "#AED6F1"
      stroke: "#2E86C1"
    }
  }
  padding_field: {
    style: {
      fill: "#D5DBDB"
      stroke: "#7F8C8D"
      stroke-dash: 3
    }
  }
  logic_block: {
    style: {
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
}

# =============================================================================
# MODULE 1: CACHE FUNDAMENTALS & BENCHMARKING
# =============================================================================

M1_Cache_Fundamentals: {
  title: |md
    # Cache Profiler Architecture
    `Module: cache-optimized-structures-m1`
  |

  timing: {
    class: logic_block
    style.fill: "#E8D5B7"
    header: "**Timing Utilities** (`src/timing.h`)" { class: header_style }
    rdtsc: "rdtsc()\l→ uint64_t cycles"
    rdtsc_ser: "rdtsc_serialized()\l→ uint64_t (with cpuid)"
    get_time_ns: "get_time_ns()\l→ uint64_t nanoseconds"
    
    rdtsc -> rdtsc_ser: "serialize"
    rdtsc_ser -> get_time_ns: "convert"
  }

  barriers: {
    class: logic_block
    style.fill: "#D5E8D4"
    header: "**Compiler Barriers** (`src/compiler_barriers.h`)" { class: header_style }
    force_read: "force_read(p)\lPrevents optimization"
    compiler_barrier: "compiler_barrier()\lMemory clobber"
    do_not_optimize: "DO_NOT_OPTIMIZE(x)\lMark as used"
  }

  latency: {
    class: logic_block
    style.fill: "#DAE8FC"
    header: "**Latency Measurement** (`src/latency_measurement.c`)" { class: header_style }
    config: "LatencyConfig\lworking_set_bytes\lwarmup_iterations\lmeasurement_iterations\lsamples_per_config"
    result: "LatencyResult\lmean, stddev\lmin, max, median\lsample_count\loutlier_count"
    config -> result: "measure_chase_latency()"
  }

  chase: {
    class: logic_block
    style.fill: "#FFE6CC"
    header: "**Pointer Chase Buffer** (`src/pointer_chase.c`)" { class: header_style }
    buffer: "void** buffer\lnum_elements\lbuffer_size_bytes\lvoid* start"
    perm: "LCG Permutation\lstate = (state * 1664525 + 1013904223) % num_elements"
    buffer -> perm: "build_pointer_chase()"
  }

  detection: {
    class: logic_block
    style.fill: "#F8CECC"
    header: "**Cache Size Detection** (`src/cache_detection.c`)" { class: header_style }
    sizes: "Test Sizes (17)\l4KB → 256MB (doubling)"
    inflection: "Inflection Detection\l>20% latency increase → boundary"
    cache_info: "CacheInfo\ll1_data_size, l2_size, l3_size\ll1/l2/l3_latency, ram_latency"
    sizes -> inflection: "sweep"
    inflection -> cache_info: "detect_cache_sizes()"
  }

  perf: {
    class: logic_block
    style.fill: "#E1D5E7"
    header: "**Hardware Counters** (`src/perf_counters.c`)" { class: header_style }
    group: "PerfCounterGroup\lleader_fd, l1_misses_fd, llc_misses_fd"
    results: "PerfCounterResults\laccesses/misses\linstructions/cycles"
    group -> results: "perf_counters_read()"
  }

  # Connections
  timing -> barriers
  barriers -> latency.config
  chase.buffer -> latency.config: "working set"
  latency -> detection.sizes
  detection -> perf.group: "correlate"

  M1_Memory_Layout: {
    shape: sql_table
    style.stroke: "#333"
    style.shadow: true
    label: "LatencyResult Memory Layout (sizeof=64 bytes)"
    
    0x00: "mean: double" {constraint: "8B"; class: data_field}
    0x08: "stddev: double" {constraint: "8B"; class: data_field}
    0x10: "min: double" {constraint: "8B"; class: data_field}
    0x18: "max: double" {constraint: "8B"; class: data_field}
    0x20: "median: double" {constraint: "8B"; class: data_field}
    0x28: "sample_count: size_t" {constraint: "8B"; class: data_field}
    0x30: "outlier_count: size_t" {constraint: "8B"; class: data_field}
    0x38: "padding: char[8]" {constraint: "8B"; class: padding_field}
  }
}

# =============================================================================
# MODULE 2: ARRAY OF STRUCTS VS STRUCT OF ARRAYS
# =============================================================================

M2_AoS_vs_SoA: {
  title: |md
    # AoS vs SoA Particle System Architecture
    `Module: cache-optimized-structures-m2`
  |

  aos: {
    class: logic_block
    style.fill: "#F5DEB3"
    header: "**Array of Structs (AoS)**" { class: header_style }
    particle: {
      x: "x: float @ 0x00"
      y: "y: float @ 0x04"
      z: "z: float @ 0x08"
      vx: "vx: float @ 0x0C"
      vy: "vy: float @ 0x10"
      vz: "vz: float @ 0x14"
      mass: "mass: float @ 0x18"
      p_pad: "padding @ 0x1C" { class: padding_field }
      x -> y -> z -> vx -> vy -> vz -> mass
    }
    system: "ParticleSystemAoS\lParticleAoS* particles\lint count, capacity"
    particle -> system: "array of"
  }

  soa: {
    class: logic_block
    style.fill: "#E0FFFF"
    header: "**Struct of Arrays (SoA)**" { class: header_style }
    arrays: {
      x_arr: "float* x"
      y_arr: "float* y"
      z_arr: "float* z"
      vx_arr: "float* vx"
      vy_arr: "float* vy"
      vz_arr: "float* vz"
      mass_arr: "float* mass"
    }
    system: "ParticleSystemSoA\l7 separate arrays (32-byte aligned)"
    arrays -> system: "contains"
  }

  operations: {
    class: logic_block
    style.fill: "#F0FFF0"
    pos_update: "update_positions\lpos += vel * dt"
    gravity: "apply_gravity\lpos += g * dt"
    full_update: "full_update\lvel += g/m*dt; pos+=vel*dt"
    pos_update -> gravity -> full_update
  }

  benchmark: {
    class: logic_block
    style.fill: "#FFF0F5"
    config: "BenchmarkConfig\lcount: 1M\ldt: 0.0166"
    result: "BenchmarkResult\lmean_ns, cycles/particle"
    config -> result: "benchmark()"
  }

  aos -> operations: "AoS ops"
  soa -> operations: "SoA ops"
  operations -> benchmark: "measure"

  M2_Cache_Line_Visual: {
    grid-columns: 1
    aos_line: {
      grid-columns: 8
      label: "AoS Cache Line (64B) - 2 Particles"
      p1x: "P1.x" {class: data_field}
      p1y: "P1.y" {class: data_field}
      p1z: "P1.z" {class: data_field}
      p1v: "P1.v" {class: data_field}
      p1m: "P1.m" {class: data_field}
      p1p: "pad" {class: padding_field}
      p2x: "P2.x" {class: data_field}
      p2y: "P2.y" {class: data_field}
    }
    soa_line: {
      grid-columns: 8
      label: "SoA Cache Line (64B) - 16 Floats"
      f0: "x[0]"; f1: "x[1]"; f2: "x[2]"; f3: "x[3]"; f4: "x[4]"; f5: "x[5]"; f6: "x[6]"; f7: "x[7]"
      style.fill: "#E0FFFF"
    }
  }
}

# =============================================================================
# MODULE 3: CACHE-FRIENDLY HASH TABLE
# =============================================================================

M3_Robin_Hood_Hash: {
  title: |md
    # Robin Hood Hash Table Architecture
    `Module: cache-optimized-structures-m3`
  |

  hashtable: {
    class: logic_block
    style.fill: "#E6E6FA"
    header: "**Hash Table Structure**" { class: header_style }
    arrays: {
      keys: "uint64_t* keys (Hot Path)"
      values: "uint64_t* values (Cold Path)"
      metadata: "uint8_t* metadata (State)"
      probe: "uint8_t* probe_dist (RH Dist)"
    }
    state: "Table State\lcapacity, count, tombstones"
    arrays -> state: "manages"
  }

  insert: {
    class: logic_block
    style.fill: "#98FB98"
    header: "**Insertion Logic**" { class: header_style }
    check_resize: "1. Load Factor Check (>0.85)"
    hash: "2. Hash & Initial Slot"
    probe_step: "3. Linear Probe"
    displace: "4. Robin Hood Swap (if dist > stored)"
    place: "5. Commit to Slot"
    check_resize -> hash -> probe_step -> displace -> place
  }

  lookup: {
    class: logic_block
    style.fill: "#87CEEB"
    init: "Hash → Slot"
    prefetch: "__builtin_prefetch(&keys[slot + 8])"
    check: "Early Term (if dist < current)"
    match: "Key Comparison"
    init -> prefetch -> check -> match
  }

  hashtable -> insert
  insert -> lookup

  M3_Entry_Layout: {
    shape: sql_table
    label: "Hash Table Entry View (Logical Layout)"
    0x00: "Key (uint64_t)" {constraint: "8B"; class: data_field}
    0x08: "Value (uint64_t)" {constraint: "8B"; class: data_field}
    0x10: "Metadata (uint8_t)" {constraint: "1B"; class: data_field}
    0x11: "Probe Dist (uint8_t)" {constraint: "1B"; class: data_field}
    0x12: "Alignment Pad" {constraint: "6B"; class: padding_field}
  }
}

# =============================================================================
# MODULE 4: CACHE-OBLIVIOUS B-TREE
# =============================================================================

M4_Van_Emde_Boas: {
  title: |md
    # Van Emde Boas Tree Architecture
    `Module: cache-optimized-structures-m4`
  |

  veb: {
    class: logic_block
    style.fill: "#E0FFE0"
    header: "**vEB Tree Structure**" { class: header_style }
    arrays: {
      keys: "int32_t* keys (vEB Sorted)"
      mapping: "size_t* bfs_to_veb"
    }
    state: "Tree State\lsize, capacity, height"
    arrays -> state
  }

  search: {
    class: logic_block
    style.fill: "#E6E6FA"
    init: "Set BFS index = 0"
    convert: "veb = mapping[bfs]"
    compare: "key = keys[veb]"
    traverse: "bfs = (target < key) ? 2*bfs+1 : 2*bfs+2"
    
    init -> convert -> compare -> traverse
    traverse -> convert: "Recurse"
  }

  M4_vEB_Order: {
    label: "vEB Recursive Layout (H=4)"
    root_subtree: "Subtree Root (H/2)" {style.fill: "#ABEBC6"}
    leaf_subtrees: "√N Subtrees" {style.fill: "#AED6F1"; style.multiple: true}
    root_subtree -> leaf_subtrees: "Stored contiguously"
  }

  veb -> search: "defines lookup"
}

# =============================================================================
# MODULE 5: BLOCKED MATRIX OPERATIONS
# =============================================================================

M5_Matrix_Optimization: {
  title: |md
    # Blocked Matrix Multiplication Architecture
    `Module: cache-optimized-structures-m5`
  |

  matrix: {
    class: logic_block
    style.fill: "#E6E6FA"
    header: "**Matrix Structure**" { class: header_style }
    struct: "Matrix\lfloat* data (64B aligned)\lrow_stride"
  }

  blocked: {
    class: logic_block
    style.fill: "#98FB98"
    header: "**Blocked Multiplication**" { class: header_style }
    loops: "for i0, j0, k0 step B:\l  for i, k, j:\l    C[i,j] += A[i,k]*B[k,j]"
    cache_info: "Working set (B=32) = 12KB\lFits in 32KB L1 Data Cache"
  }

  optimized: {
    class: logic_block
    style.fill: "#87CEEB"
    microkernel: "4x4 Micro-kernel\lRegister accumulation"
    simd: "AVX2/AVX-512 vectorization"
    microkernel -> simd: "implement"
  }

  autotune: {
    class: logic_block
    style.fill: "#DDA0DD"
    sizes: "8, 16, 24, 32, 48, 64..."
    measure: "Sweep block sizes\lSelect min(latency)"
    sizes -> measure: "profile"
  }

  matrix -> blocked: "Input"
  blocked -> optimized: "Micro-optimization"
  blocked -> autotune: "Configure"

  M5_Cache_L1_View: {
    grid-columns: 2
    l1_cache: "L1 Cache (32KB)" { style.fill: "#FAD7A0" }
    block_a: "Block A (4KB)" { class: data_field }
    block_b: "Block B (4KB)" { class: data_field }
    block_c: "Block C (4KB)" { class: data_field }
    
    block_a -> l1_cache
    block_b -> l1_cache
    block_c -> l1_cache: "Working Set fits"
  }
}

# =============================================================================
# GLOBAL CONNECTIONS
# =============================================================================
M1_Cache_Fundamentals -> M2_AoS_vs_SoA: "Baseline performance"
M2_AoS_vs_SoA -> M3_Robin_Hood_Hash: "AoS/SoA trade-offs"
M3_Robin_Hood_Hash -> M4_Van_Emde_Boas: "Pointer-less traversal"
M4_Van_Emde_Boas -> M5_Matrix_Optimization: "Memory layout principles"