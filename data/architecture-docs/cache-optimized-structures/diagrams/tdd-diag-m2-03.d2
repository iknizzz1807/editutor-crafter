layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
  }
}

title: |'md
  # AoS vs SoA: Cache Line Utilization
  **Scenario:** Accessing only `x, y, z` coordinates for 16 particles (Position-only update).
'| {near: top-center}

direction: right

classes: {
  header_box: {
    style: {
      fill: "#6B46C1"
      font-color: white
      bold: true
    }
  }
  data_field: {
    style: {
      fill: "#4299E1"
      font-color: white
    }
  }
  unused_field: {
    style: {
      fill: "#A0AEC0"
      font-color: white
      stroke-dash: 2
    }
  }
  cache_line_boundary: {
    style: {
      stroke: "#2D3748"
      stroke-width: 4
      stroke-dash: 5
    }
  }
}

# ============================================================
# Array of Structs (AoS) Analysis
# ============================================================
AoS_Section: {
  label: "Array of Structs (AoS) - Memory Layout"
  
  Particle_Struct: {
    shape: sql_table
    style.fill: "#FFF5F5"
    
    00: "x (float32)" {constraint: "4 Bytes (USED)"}
    04: "y (float32)" {constraint: "4 Bytes (USED)"}
    08: "z (float32)" {constraint: "4 Bytes (USED)"}
    12: "vx (float32)" {constraint: "4 Bytes (WASTED)"}
    16: "vy (float32)" {constraint: "4 Bytes (WASTED)"}
    20: "vz (float32)" {constraint: "4 Bytes (WASTED)"}
    24: "mass (float32)" {constraint: "4 Bytes (WASTED)"}
    28: "padding" {constraint: "4 Bytes (WASTED)"}
  }

  AoS_Cache_Visual: {
    label: "Physical Cache Line Utilization (64B)"
    
    Line_0: {
      grid-columns: 16
      grid-gap: 0
      style.stroke: red
      
      p0_x.label: "x0"; p0_y.label: "y0"; p0_z.label: "z0"
      p0_u1.label: "-"; p0_u2.label: "-"; p0_u3.label: "-"; p0_u4.label: "-"; p0_u5.label: "-"
      
      p1_x.label: "x1"; p1_y.label: "y1"; p1_z.label: "z1"
      p1_u1.label: "-"; p1_u2.label: "-"; p1_u3.label: "-"; p1_u4.label: "-"; p1_u5.label: "-"
      
      p0_x.class: data_field; p0_y.class: data_field; p0_z.class: data_field
      p0_u1.class: unused_field; p0_u2.class: unused_field; p0_u3.class: unused_field; p0_u4.class: unused_field; p0_u5.class: unused_field

      p1_x.class: data_field; p1_y.class: data_field; p1_z.class: data_field
      p1_u1.class: unused_field; p1_u2.class: unused_field; p1_u3.class: unused_field; p1_u4.class: unused_field; p1_u5.class: unused_field
    }
    
    annotation: |'md
      **AoS Efficiency:**
      - Loaded: 64 bytes
      - Useful: 24 bytes (x0,y0,z0,x1,y1,z1)
      - **Wasted: 40 bytes** (62.5%)
    '|
  }

  Particle_Struct -> AoS_Cache_Visual: "CPU requests x0"
}

# ============================================================
# Struct of Arrays (SoA) Analysis
# ============================================================
SoA_Section: {
  label: "Struct of Arrays (SoA) - Memory Layout"
  
  X_Array: {
    label: "float32 X[16]"
    shape: rectangle
    grid-columns: 16
    grid-gap: 0
    
    x0: "x0"; x1: "x1"; x2: "x2"; x3: "x3"; x4: "x4"; x5: "x5"; x6: "x6"; x7: "x7"
    x8: "x8"; x9: "x9"; x10: "xA"; x11: "xB"; x12: "xC"; x13: "xD"; x14: "xE"; x15: "xF"
    
    *.class: data_field
  }
  
  Y_Array: {
    label: "float32 Y[16]"
    shape: rectangle
    grid-columns: 16
    grid-gap: 0
    *.class: data_field
    y0: "y0"; y1: "y1"; y2: "y2"; y3: "y3"; y4: "y4"; y5: "y5"; y6: "y6"; y7: "y7"
    y8: "y8"; y9: "y9"; y10: "yA"; y11: "yB"; y12: "yC"; y13: "yD"; y14: "yE"; y15: "yF"
  }

  SoA_Cache_Visual: {
    label: "Physical Cache Line Utilization (64B)"
    
    Line_Full: {
      grid-columns: 16
      grid-gap: 0
      style.stroke: green
      f0: "x0"; f1: "x1"; f2: "x2"; f3: "x3"; f4: "x4"; f5: "x5"; f6: "x6"; f7: "x7"
      f8: "x8"; f9: "x9"; fa: "x10"; fb: "x11"; fc: "x12"; fd: "x13"; fe: "x14"; ff: "x15"
      *.class: data_field
    }

    annotation: |'md
      **SoA Efficiency:**
      - Loaded: 64 bytes
      - Useful: 64 bytes (x0...x15)
      - **Wasted: 0 bytes** (0%)
    '|
  }

  X_Array -> SoA_Cache_Visual: "CPU requests x0"
}

# ============================================================
# Quantitative Comparison Summary
# ============================================================
Comparison_Table: {
  label: ||md
    ### Architectural Metrics for 16 Particles (XYZ Access Only)
    
    | Metric | Array of Structs (AoS) | Struct of Arrays (SoA) | Benefit |
    | :--- | :--- | :--- | :--- |
    | **Total Memory Loaded** | 512 Bytes (8 lines) | 192 Bytes (3 lines) | **2.66x Lower BW** |
    | **Effective Throughput** | 37.5% Utilized | 100% Utilized | **Maximum Saturation** |
    | **Unused Data Loaded** | 320 Bytes (Velocity/Mass) | 0 Bytes | **No Cache Pollution** |
    | **Pre-fetching** | Staggered | Perfectly Linear | **Hardware Friendly** |
  ||
  style.fill: "#EBF8FF"
  style.stroke: "#3182CE"
  style.stroke-width: 2
}

# ============================================================
# Relationships
# ============================================================
AoS_Section -> SoA_Section: "Data-Oriented Refactor" {
  style.stroke: orange
  style.stroke-width: 4
  style.animated: true
}

SoA_Section -> Comparison_Table: "Metrics Collection"

# Legends / Metadata
Legend: {
  near: bottom-left
  Data: "Used Field (X,Y,Z)" { class: data_field }
  Waste: "Unused Field (V,M)" { class: unused_field }
}

Footer: "Intel Optimization Manual Style - Technical Reference for Particle Systems" {
  shape: text
  near: bottom-right
  style.font-size: 14
}