vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # SIMD Vectorization: Why AoS Fails
  **AoS (Array of Structs)**: Non-contiguous access (stride-7) defeats cache prefetchers and SIMD lane loading.
  **SoA (Struct of Arrays)**: Contiguous memory access enables AVX-256 (8 x 32-bit floats per instruction).
| {near: top-center}

direction: right

# ============================================
# Array of Structs (AoS) - Vectorization Bottleneck
# ============================================
AoS: {
  label: "Memory Layout: Array of Structs (AoS)\nsizeof(Particle) = 28 bytes"
  style: {
    fill: "#FFE4E1"
    stroke: "#DC143C"
    stroke-width: 2
  }

  memory: {
    grid-columns: 1
    grid-gap: 10

    p0: {
      label: "Particle 0 [Offset 0x00]"
      grid-columns: 7
      grid-gap: 0
      x0: "x₀" {style.fill: "#4169E1"; style.font-color: white; tooltip: "Offset: 0"}
      y0: "y₀" {style.fill: "#B0C4DE"}
      z0: "z₀" {style.fill: "#B0C4DE"}
      vx0: "vx₀" {style.fill: "#D3D3D3"}
      vy0: "vy₀" {style.fill: "#D3D3D3"}
      vz0: "vz₀" {style.fill: "#D3D3D3"}
      m0: "m₀" {style.fill: "#D3D3D3"}
    }
    
    p1: {
      label: "Particle 1 [Offset 0x1C]"
      grid-columns: 7
      grid-gap: 0
      x1: "x₁" {style.fill: "#4169E1"; style.font-color: white; tooltip: "Offset: 28"}
      y1: "y₁" {style.fill: "#B0C4DE"}
      z1: "z₁" {style.fill: "#B0C4DE"}
      vx1: "vx₁" {style.fill: "#D3D3D3"}
      vy1: "vy₁" {style.fill: "#D3D3D3"}
      vz1: "vz₁" {style.fill: "#D3D3D3"}
      m1: "m₁" {style.fill: "#D3D3D3"}
    }

    p2: {
      label: "Particle 2 [Offset 0x38]"
      grid-columns: 7
      grid-gap: 0
      x2: "x₂" {style.fill: "#4169E1"; style.font-color: white; tooltip: "Offset: 56"}
      y2: "y₂" {style.fill: "#B0C4DE"}
      z2: "z₂" {style.fill: "#B0C4DE"}
      vx2: "vx₂" {style.fill: "#D3D3D3"}
      vy2: "vy₂" {style.fill: "#D3D3D3"}
      vz2: "vz₂" {style.fill: "#D3D3D3"}
      m2: "m₂" {style.fill: "#D3D3D3"}
    }
  }

  stride_info: |md
    ### Stride Analysis
    - **Element Stride**: 28 bytes
    - **Access Pattern**: `[base + i * 28]`
    - **SIMD Problem**: Elements span across multiple 64B cache lines.
    - **Hardware**: Prefetcher cannot predict stride-7 effectively.
  |
}

# ============================================
# Struct of Arrays (SoA) - SIMD Optimized
# ============================================
SoA: {
  label: "Memory Layout: Struct of Arrays (SoA)\nContiguous Components"
  style: {
    fill: "#E6FFE6"
    stroke: "#228B22"
    stroke-width: 2
  }

  x_block: {
    label: "x[] Array (Contiguous)"
    grid-columns: 8
    grid-gap: 0
    x0: "x₀" {style.fill: "#4169E1"; style.font-color: white}
    x1: "x₁" {style.fill: "#4169E1"; style.font-color: white}
    x2: "x₂" {style.fill: "#4169E1"; style.font-color: white}
    x3: "x₃" {style.fill: "#4169E1"; style.font-color: white}
    x4: "x₄" {style.fill: "#4169E1"; style.font-color: white}
    x5: "x₅" {style.fill: "#4169E1"; style.font-color: white}
    x6: "x₆" {style.fill: "#4169E1"; style.font-color: white}
    x7: "x₇" {style.fill: "#4169E1"; style.font-color: white}
  }

  vx_block: {
    label: "vx[] Array (Contiguous)"
    grid-columns: 8
    grid-gap: 0
    vx0: "vx₀" {style.fill: "#D3D3D3"}
    vx1: "vx₁" {style.fill: "#D3D3D3"}
    vx2: "vx₂" {style.fill: "#D3D3D3"}
    vx3: "vx₃" {style.fill: "#D3D3D3"}
    vx4: "vx₄" {style.fill: "#D3D3D3"}
    vx5: "vx₅" {style.fill: "#D3D3D3"}
    vx6: "vx₆" {style.fill: "#D3D3D3"}
    vx7: "vx₇" {style.fill: "#D3D3D3"}
  }

  simd_info: |md
    ### Vector Analysis
    - **Element Stride**: 4 bytes (packed)
    - **Access Pattern**: `[base + i * 4]`
    - **SIMD Benefit**: 32 bytes (8 floats) can be loaded in **one** burst.
    - **Hardware**: Trigger L1/L2 linear prefetchers.
  |
}

# ============================================
# AVX Register Execution
# ============================================
Execution_Logic: {
  label: "Hardware Register Loading (AVX-256)"
  
  AoS_Status: {
    label: "❌ AoS: Scalar/Gather Loading"
    style.fill: "#FFC0CB"
    ymm_aos: {
      label: "YMM0 (Blocked)"
      grid-columns: 8
      grid-gap: 2
      l0: "x₀" {style.fill: "#8B0000"; style.font-color: white}
      l1: "Wait" {style.fill: gray}
      l2: "Wait" {style.fill: gray}
      l3: "Wait" {style.fill: gray}
      l4: "Wait" {style.fill: gray}
      l5: "Wait" {style.fill: gray}
      l6: "Wait" {style.fill: gray}
      l7: "Wait" {style.fill: gray}
    }
    desc: "Requires 8 separate cache line requests or slow Gather instruction."
  }

  SoA_Status: {
    label: "✅ SoA: Linear Vector Loading"
    style.fill: "#90EE90"
    ymm_soa: {
      label: "YMM0 (Filled)"
      grid-columns: 8
      grid-gap: 2
      l0: "x₀" {style.fill: "#4169E1"; style.font-color: white}
      l1: "x₁" {style.fill: "#4169E1"; style.font-color: white}
      l2: "x₂" {style.fill: "#4169E1"; style.font-color: white}
      l3: "x₃" {style.fill: "#4169E1"; style.font-color: white}
      l4: "x₄" {style.fill: "#4169E1"; style.font-color: white}
      l5: "x₅" {style.fill: "#4169E1"; style.font-color: white}
      l6: "x₆" {style.fill: "#4169E1"; style.font-color: white}
      l7: "x₇" {style.fill: "#4169E1"; style.font-color: white}
    }
    desc: "Single `VMOVAPS` loads all 8 lanes at peak throughput."
  }
}

# ============================================
# Assembly Level View
# ============================================
Assembly_Comparison: {
  label: "Compiler Output: Assembly Comparison"
  
  Scalar_ASM: {
    label: "AoS (Scalar Code)"
    code: |asm
    .L_loop:
      movss xmm0, [rdi + rax*4]      ; Load 1 float
      mulss xmm0, xmm1               ; Scalar Mul
      addss xmm0, [rsi + rax*4]      ; Scalar Add
      movss [rdi + rax*4], xmm0      ; Store 1 float
      add rax, 1                     ; Increment by 1
      cmp rax, rdx
      jne .L_loop
    |
    style.fill: "#FFF5F5"
  }

  Vector_ASM: {
    label: "SoA (SIMD Code)"
    code: |asm
    .V_loop:
      vmovaps ymm0, [rdi + rax*4]    ; Load 8 floats
      vfmadd213ps ymm0, ymm1, ymm2   ; 8 x FMA (Add+Mul)
      vmovaps [rdi + rax*4], ymm0    ; Store 8 floats
      add rax, 8                     ; Increment by 8
      cmp rax, rdx
      jne .V_loop
    |
    style.fill: "#F5FFF5"
  }
}

# ============================================
# Performance Summary
# ============================================
Metrics: {
  label: "Performance Benchmarks"
  grid-columns: 3
  grid-gap: 20
  
  AoS_Metric: {
    label: "AoS Layout"
    throughput: "1.2 GFLOPS"
    status: "Memory Bound"
    style.fill: "#FFB6C1"
  }
  
  SoA_Metric: {
    label: "SoA Layout"
    throughput: "9.6 GFLOPS"
    status: "Compute Bound"
    style.fill: "#98FB98"
  }
  
  Delta: {
    label: "Optimization Gain"
    val: "8.0x Speedup"
    note: "Linear vs Strided"
    style.fill: "#FFD700"
    style.bold: true
  }
}

# Connections defining logic flow
AoS.memory -> Execution_Logic.AoS_Status: "Stride-7 prevents packing"
SoA.x_block -> Execution_Logic.SoA_Status: "Contiguous load 32B"
Execution_Logic -> Assembly_Comparison
Assembly_Comparison -> Metrics

# Styling for connections
(AoS.memory -> Execution_Logic.AoS_Status)[0].style.stroke: red
(SoA.x_block -> Execution_Logic.SoA_Status)[0].style.stroke: green