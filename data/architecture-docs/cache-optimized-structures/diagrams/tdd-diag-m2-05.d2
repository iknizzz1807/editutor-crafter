layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 40
  }
}

direction: right

# -----------------------------------------------------------------------------
# TITLE SECTION
# -----------------------------------------------------------------------------
title: {
  shape: text
  label: |md
    # Compiler Output: AoS vs SoA Assembly Analysis
    ## Implementation Guide: Vectorization & Cache Locality Optimization
  |
}
title.near: top-center

# -----------------------------------------------------------------------------
# 1. MEMORY LAYOUT COMPARISON
# -----------------------------------------------------------------------------
Memory_Layouts: {
  grid-columns: 2
  grid-gap: 50

  AoS_Memory: "Array of Structs (AoS) Layout" {
    tooltip: "Stride-32 byte access patterns cause cache fragmentation"
    grid-columns: 1
    grid-gap: 0
    style.stroke: "#805ad5"

    Header: "Struct Particle { float x, y, z, _p, vx, vy, vz, _p2; } // 32 Bytes"
    Header.style: {
      fill: "#805ad5"
      font-color: white
      bold: true
    }

    # Element 0
    P0_Offsets: {
      grid-columns: 8
      grid-gap: 0
      o0: "00"; o4: "04"; o8: "08"; o12: "12"; o16: "16"; o20: "20"; o24: "24"; o28: "28"
      o0.style.font-size: 10
      o4.style.font-size: 10
      o8.style.font-size: 10
      o12.style.font-size: 10
      o16.style.font-size: 10
      o20.style.font-size: 10
      o24.style.font-size: 10
      o28.style.font-size: 10
      
      o0.style.stroke-width: 0
      o4.style.stroke-width: 0
      o8.style.stroke-width: 0
      o12.style.stroke-width: 0
      o16.style.stroke-width: 0
      o20.style.stroke-width: 0
      o24.style.stroke-width: 0
      o28.style.stroke-width: 0

      o0.style.font-color: "#718096"
      o4.style.font-color: "#718096"
      o8.style.font-color: "#718096"
      o12.style.font-color: "#718096"
      o16.style.font-color: "#718096"
      o20.style.font-color: "#718096"
      o24.style.font-color: "#718096"
      o28.style.font-color: "#718096"
    }

    P0: {
      grid-columns: 8
      grid-gap: 0
      x: "X0" { style.fill: "#3182ce"; tooltip: "4 Bytes" }
      y: "Y0" { style.fill: "#cbd5e0" }
      z: "Z0" { style.fill: "#cbd5e0" }
      p: "pad" { style.fill: "#a0aec0" }
      vx: "VX0" { style.fill: "#ed8936"; style.bold: true; tooltip: "Target Field" }
      vy: "VY0" { style.fill: "#cbd5e0" }
      vz: "VZ0" { style.fill: "#cbd5e0" }
      p2: "pad" { style.fill: "#a0aec0" }
    }

    Stride_Gap: {
      label: "---- 32 Byte Stride Boundary ----"
      style.stroke-dash: 5
      style.font-color: "#a0aec0"
    }

    # Element 1
    P1_Offsets: {
      grid-columns: 8
      grid-gap: 0
      o32: "32"; o36: "36"; o40: "40"; o44: "44"; o48: "48"; o52: "52"; o56: "56"; o60: "60"
      o32.style.font-size: 10
      o36.style.font-size: 10
      o40.style.font-size: 10
      o44.style.font-size: 10
      o48.style.font-size: 10
      o52.style.font-size: 10
      o56.style.font-size: 10
      o60.style.font-size: 10
      
      o32.style.stroke-width: 0
      o36.style.stroke-width: 0
      o40.style.stroke-width: 0
      o44.style.stroke-width: 0
      o48.style.stroke-width: 0
      o52.style.stroke-width: 0
      o56.style.stroke-width: 0
      o60.style.stroke-width: 0

      o32.style.font-color: "#718096"
      o36.style.font-color: "#718096"
      o40.style.font-color: "#718096"
      o44.style.font-color: "#718096"
      o48.style.font-color: "#718096"
      o52.style.font-color: "#718096"
      o56.style.font-color: "#718096"
      o60.style.font-color: "#718096"
    }

    P1: {
      grid-columns: 8
      grid-gap: 0
      x: "X1" { style.fill: "#3182ce" }
      y: "Y1" { style.fill: "#cbd5e0" }
      z: "Z1" { style.fill: "#cbd5e0" }
      p: "pad" { style.fill: "#a0aec0" }
      vx: "VX1" { style.fill: "#ed8936"; style.bold: true }
      vy: "VY1" { style.fill: "#cbd5e0" }
      vz: "VZ1" { style.fill: "#cbd5e0" }
      p2: "pad" { style.fill: "#a0aec0" }
    }
    
    Footer: "Memory: Stride=32B, Effective Use=12.5%" { 
      shape: text 
      style.italic: true
    }
  }

  SoA_Memory: "Struct of Arrays (SoA) Layout" {
    tooltip: "Contiguous streams allow 256-bit SIMD loads"
    grid-columns: 1
    grid-gap: 15
    style.stroke: "#2b6cb0"

    Header: "Struct Particles { float x[N], vx[N], ... } // Contiguous"
    Header.style: {
      fill: "#2b6cb0"
      font-color: white
      bold: true
    }

    X_Stream: {
      label: "X Coordinates Block (Unit Stride)"
      grid-columns: 8
      grid-gap: 0
      x0: "X0"; x1: "X1"; x2: "X2"; x3: "X3"; x4: "X4"; x5: "X5"; x6: "X6"; x7: "X7"
      style.fill: "#3182ce"
      style.font-color: white
    }

    VX_Stream: {
      label: "VX Velocity Block (Unit Stride)"
      grid-columns: 8
      grid-gap: 0
      vx0: "VX0"; vx1: "VX1"; vx2: "VX2"; vx3: "VX3"; vx4: "VX4"; vx5: "VX5"; vx6: "VX6"; vx7: "VX7"
      style.fill: "#ed8936"
      style.font-color: white
      style.bold: true
    }

    CacheLine: {
      label: "------------------ 64B L1 Cache Line Boundary ------------------"
      style.stroke-dash: 8
      style.stroke: "#48bb78"
    }
    
    Footer: "Memory: Stride=4B, Effective Use=100%" { 
      shape: text 
      style.italic: true
    }
  }
}

# -----------------------------------------------------------------------------
# 2. ASSEMBLY STREAMS (INNER LOOPS)
# -----------------------------------------------------------------------------
AoS_Assembly: {
  label: "AoS: Scalar Assembly (-O1)"
  style: {
    fill: "#2d3748"
    stroke: "#4a5568"
    font-color: "#e2e8f0"
    stroke-width: 2
  }

  Code: {
    style.fill: "#1a202c"
    L3: ".L3 (Loop Entry):"
    L3.style.font-color: "#f6ad55"
    i1: "movss xmm0, [rdi+rax*4]      ; Load X (Offset 0)" 
    i2: "movss xmm1, [rdi+rax*4+16]   ; Load VX (Offset 16)"
    i3: "mulss xmm1, xmm2            ; vx * dt"
    i4: "addss xmm0, xmm1            ; x + (vx * dt)"
    i5: "movss [rdi+rax*4], xmm0      ; Store result"
    i6: "add rax, 8                   ; Increment pointer by 32B"
    i7: "cmp rax, rcx; jl .L3"

    L3 -> i1 -> i2 -> i3 -> i4 -> i5 -> i6 -> i7
    i7 -> L3: "Back-edge" {
      style.stroke-dash: 3
    }
  }
}

SoA_Assembly: {
  label: "SoA: Vector Assembly (-O3 -march=native)"
  style: {
    fill: "#1a365d"
    stroke: "#2b6cb0"
    font-color: "#e2e8f0"
    stroke-width: 2
  }

  Code: {
    style.fill: "#1e3a8a"
    L5: ".L5 (Vector Loop):"
    L5.style.font-color: "#f6ad55"
    v1: "vmovups ymm0, [rsi+rax*4]    ; Load 8 X values"
    v1.style.font-color: "#93c5fd"
    v2: "vmovups ymm1, [rcx+rax*4]    ; Load 8 VX values"
    v2.style.font-color: "#93c5fd"
    v3: "vfmadd213ps ymm0, ymm1, ymm2 ; Parallel FMA"
    v3.style.font-color: "#f87171"
    v3.style.bold: true
    v4: "vmovups [rsi+rax*4], ymm0    ; Store 8 results"
    v4.style.font-color: "#93c5fd"
    v5: "add rax, 8                   ; Increment index"
    v6: "cmp rax, rdx; jl .L5"

    L5 -> v1 -> v2 -> v3 -> v4 -> v5 -> v6
    v6 -> L5: "Back-edge" {
      style.stroke-dash: 3
    }
  }
}

# -----------------------------------------------------------------------------
# 3. ANALYSIS & PERFORMANCE
# -----------------------------------------------------------------------------
Analysis: {
  label: "Compiled Metrics (Per 8 Particles processed)"
  style.fill: "#f8fafc"
  
  ComparisonTable: ||md
    | Metric | AoS (Scalar) | SoA (SIMD) | Efficiency |
    | :--- | :---: | :---: | :---: |
    | **Instruction Count** | 56 | 6 | **9.3x** |
    | **Memory Loads** | 16 | 2 | **8.0x** |
    | **Arithmetic Ops** | 16 | 1 | **16.0x** |
    | **L1 Utilization**| 6.25% | 100% | **16.0x** |
  ||

  Summary: |md
    ### Architect's Summary:
    The **AoS** approach forces the CPU to perform 16 separate memory requests, 
    pulling 16 full cache lines (1024 bytes) into L1 just to extract 64 bytes of 
    relevant data. The **SoA** approach utilizes the full width of the 
    **AVX-256** registers, loading only 2 cache lines to process 8 
    particles in parallel using a single **FMA (Fused Multiply-Add)** operation.
  |
}

# -----------------------------------------------------------------------------
# GLOBAL CONNECTIONS
# -----------------------------------------------------------------------------
Memory_Layouts.AoS_Memory -> AoS_Assembly: "High Cache Miss Ratio"
Memory_Layouts.SoA_Memory -> SoA_Assembly: "Optimal Cache Pre-fetching"

AoS_Assembly -> Analysis: "Scalar Bottleneck"
SoA_Assembly -> Analysis: "SIMD Throughput"

Legend: {
  style: {
    stroke: "#cbd5e0"
    fill: "#edf2f7"
  }
  Content: |md
    ### Register & ISA Guide
    - `xmm0-15`: 128-bit (4 floats)
    - `ymm0-15`: 256-bit (8 floats)
    - `rax`: Induction Variable (Index)
    - `vfmadd213ps`: Fused Multiply-Add
    - `vmovups`: Vector Move Unaligned
  |
}
Legend.near: bottom-right

# -----------------------------------------------------------------------------
# UNIVERSAL STYLING
# -----------------------------------------------------------------------------
***.style.font: mono
AoS_Assembly.Code.**.style.font: mono
SoA_Assembly.Code.**.style.font: mono
Memory_Layouts.AoS_Memory.**.style.font: mono
Memory_Layouts.SoA_Memory.**.style.font: mono