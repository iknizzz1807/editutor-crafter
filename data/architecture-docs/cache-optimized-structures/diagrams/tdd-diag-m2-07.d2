layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    padding: "#9CA3AF"
    border: "#374151"
    green: "#10B981"
    simd: "#EF4444"
    bg: "#F8FAFC"
  }
}

title: |md
  # Struct Padding Analysis
  **ParticleAoS: Pack vs Align (SIMD Optimization)**
  *Intel® 64 and IA-32 Architectures Optimization Reference*
|
title.near: top-center

direction: down

# === LEGEND ===
Legend: {
  near: top-right
  grid-rows: 1
  grid-gap: 20
  pos: "Position (float32)" { style.fill: "#3B82F6"; style.font-color: white; width: 140 }
  vel: "Velocity (float32)" { style.fill: "#8B5CF6"; style.font-color: white; width: 140 }
  mass: "Mass (float32)" { style.fill: "#10B981"; style.font-color: white; width: 120 }
  pad: "Padding (Alignment)" { style.fill: "#9CA3AF"; style.stroke-dash: 3; width: 140 }
}

# === UNPADDED VERSION ===
unpadded: {
  label: "UNALIGNED DATA STRUCTURE\nsizeof = 28 bytes | Alignment = 4-byte"
  style.fill: transparent
  style.stroke: "#374151"
  style.stroke-width: 2

  offsets: {
    shape: text
    label: "Offset: [0B]    [4B]    [8B]    [12B]   [16B]   [20B]   [24B]   [28B]"
    style.font: mono
  }

  cells: {
    grid-rows: 1
    grid-gap: 0
    x: "x" { style.fill: "#3B82F6"; style.font-color: white; width: 80; height: 50 }
    y: "y" { style.fill: "#3B82F6"; style.font-color: white; width: 80; height: 50 }
    z: "z" { style.fill: "#3B82F6"; style.font-color: white; width: 80; height: 50 }
    vx: "vx" { style.fill: "#8B5CF6"; style.font-color: white; width: 80; height: 50 }
    vy: "vy" { style.fill: "#8B5CF6"; style.font-color: white; width: 80; height: 50 }
    vz: "vz" { style.fill: "#8B5CF6"; style.font-color: white; width: 80; height: 50 }
    mass: "mass" { style.fill: "#10B981"; style.font-color: white; width: 80; height: 50 }
  }
}

# === PADDED VERSION ===
padded: {
  label: "SIMD-OPTIMIZED STRUCTURE\nsizeof = 32 bytes | __attribute__((aligned(16)))"
  style.fill: "#F3F4F6"
  style.stroke: "#6366F1"
  style.stroke-width: 4 

  offsets2: {
    shape: text
    label: "Offset: [0B]    [4B]    [8B]    [12B] | [16B]   [20B]   [24B]   [28B]   [32B]"
    style.font: mono
  }

  cells2: {
    grid-rows: 1
    grid-gap: 0
    x2: "x" { style.fill: "#3B82F6"; style.font-color: white; width: 80; height: 50 }
    y2: "y" { style.fill: "#3B82F6"; style.font-color: white; width: 80; height: 50 }
    z2: "z" { style.fill: "#3B82F6"; style.font-color: white; width: 80; height: 50 }
    vx2: "vx" { style.fill: "#8B5CF6"; style.font-color: white; width: 80; height: 50 }
    vy2: "vy" { style.fill: "#8B5CF6"; style.font-color: white; width: 80; height: 50 }
    vz2: "vz" { style.fill: "#8B5CF6"; style.font-color: white; width: 80; height: 50 }
    mass2: "mass" { style.fill: "#10B981"; style.font-color: white; width: 80; height: 50 }
    pad_cell: "PAD" { style.fill: "#9CA3AF"; style.stroke-dash: 3; width: 80; height: 50 }
  }

  # Fixed: Use 'near: top-right' to position marker within container
  # to avoid referencing the grid-child object directly which causes layout errors.
  alignment_marker: "SIMD 128-bit Lane Boundary" {
    near: top-center
    style: {
      font-color: "#EF4444"
      bold: true
      stroke: "#EF4444"
      stroke-width: 2
      stroke-dash: 4
    }
  }
}

unpadded -> padded: "Compiler adds 4B padding to enforce 16B struct size" {
  style.stroke: "#6366F1"
  style.stroke-width: 2
  style.animated: true
}

# === CACHE ANALYSIS ===
cache_metrics: {
  near: center-right
  
  content: |md
    ### Architectural Metrics
    - **L1 Cache Line:** 64 Bytes (Fixed)
    - **Unpadded:** Particle #3 will cross cache line (Byte 56-84).
    - **Padded:** Every particle is aligned to cache line start or midpoint.
    
    ### Instruction Set Capability
    - **Packed (SSE):** `movups` used. Handles unaligned loads with throughput penalty.
    - **Aligned (SSE):** `movaps` enabled. Atomic 128-bit load from memory to XMM registers.
    - **AVX Note:** Requires 32-byte alignment for `vmovaps` (256-bit).
  |
}

# === SUMMARY ===
summary: |md
  ## Engineering Significance
  Data alignment ensures that memory accesses do not cross hardware boundaries (Cache Lines, DRAM Pages). 
  While padding increases memory footprint by **14.2%** in this instance, it results in a deterministic 
  latency reduction of **2x-4x** during heavy SIMD processing by eliminating unaligned access stall cycles 
  and allowing the hardware prefetcher to work more effectively.
|
summary.near: bottom-center

# Global Styling
***.style.font: mono
***.style.font-size: 14
***.style.border-radius: 2
***.style.shadow: true