vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ### DIAGRAM M3-01: CHAINED HASH TABLE CACHE INEFFICIENCY
  **Focus:** Pointer Chasing Latency & Fragmented Heap Access
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# --- MEMORY LAYOUT DEFINITIONS ---
# Intel Manual Style: Byte Offsets and Cache Lines

memory_layout: "Memory Address Space" {
  style: {
    fill: "#f8f9fa"
    stroke: "#343a40"
    stroke-width: 2
  }

  cache_line_0: "Cache Line A (64 Bytes)" {
    style: {
      stroke: "#dee2e6"
      stroke-dash: 5
      fill: transparent
    }
    
    bucket_array: "Bucket Array [Contiguous RAM]" {
      shape: sql_table
      style.fill: "#E1BEE7" # Purple Header
      
      0x1000: "bucket[0]" {constraint: "void* (8B)"}
      0x1008: "bucket[1]" {constraint: "void* (8B)"}
      0x1010: "bucket[i]" {
        constraint: "0x7A00 (8B)"
        style.fill: "#FFB347" # Orange Pointer
      }
      0x1018: "bucket[3]" {constraint: "void* (8B)"}
      0x1020: "bucket[4]" {constraint: "void* (8B)"}
      0x1028: "bucket[5]" {constraint: "void* (8B)"}
      0x1030: "bucket[6]" {constraint: "void* (8B)"}
      0x1038: "bucket[7]" {constraint: "void* (8B)"}
    }
  }

  heap_fragmentation: "Heap Region [Non-Contiguous]" {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-dash: 3
    }

    # NODE 1 - Initial Miss
    node1: "Node Struct @ 0x7A00" {
      shape: sql_table
      style.fill: "#BBDEFB" # Blue Data
      
      +0x00: "Key: 42" {constraint: "int64 (8B)"}
      +0x08: "Next: 0x9B10" {
        constraint: "ptr (8B)"
        style.fill: "#FFB347"
      }
      latency: "MISS #1: ~200ns" {
        style: {
          fill: "#FF6B6B"
          font-color: white
          bold: true
        }
      }
    }

    # FRAGMENT GAP
    gap1: "Padding / Malloc Overhead (128B)" {
      style.fill: "#eeeeee"
      style.opacity: 0.5
    }

    # NODE 2 - Page Walk Miss
    node2: "Node Struct @ 0x9B10" {
      shape: sql_table
      style.fill: "#BBDEFB"
      
      +0x00: "Key: 17" {constraint: "int64 (8B)"}
      +0x08: "Next: 0xC420" {
        constraint: "ptr (8B)"
        style.fill: "#FFB347"
      }
      latency: "MISS #2: ~200ns" {
        style: {
          fill: "#FF6B6B"
          font-color: white
          bold: true
        }
      }
    }

    # NODE 3 - TLB Miss
    node3: "Node Struct @ 0xC420" {
      shape: sql_table
      style.fill: "#BBDEFB"
      
      +0x00: "Key: 89" {constraint: "int64 (8B)"}
      +0x08: "Next: 0x21F0" {
        constraint: "ptr (8B)"
        style.fill: "#FFB347"
      }
      latency: "MISS #3: ~200ns" {
        style: {
          fill: "#FF6B6B"
          font-color: white
          bold: true
        }
      }
    }

    # NODE 4 - Target Match
    node4: "Node Struct @ 0x21F0" {
      shape: sql_table
      style.fill: "#C8E6C9" # Green Found
      
      +0x00: "Key: 56 [MATCH]" {
        constraint: "int64 (8B)"
        style.bold: true
      }
      +0x08: "Next: NULL" {constraint: "ptr (8B)"}
      latency: "MISS #4: ~200ns" {
        style: {
          fill: "#4CAF50"
          font-color: white
          bold: true
        }
      }
    }
  }
}

# --- CONTROL FLOW / POINTER CHASE ---
memory_layout.cache_line_0.bucket_array.0x1010 -> memory_layout.heap_fragmentation.node1: "Deref Head" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 4
    animated: true
  }
}

memory_layout.heap_fragmentation.node1.+0x08 -> memory_layout.heap_fragmentation.node2: "Next Pointer" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 3
    stroke-dash: 2
    animated: true
  }
}

memory_layout.heap_fragmentation.node2.+0x08 -> memory_layout.heap_fragmentation.node3: "Next Pointer" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 3
    stroke-dash: 2
    animated: true
  }
}

memory_layout.heap_fragmentation.node3.+0x08 -> memory_layout.heap_fragmentation.node4: "Next Pointer" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 3
    stroke-dash: 2
    animated: true
  }
}

# --- LEGEND & PERFORMANCE ANALYSIS ---

legend: "Hardware Latency Key" {
  near: top-right
  l1: "L1 Cache Hit: 1-2ns" { style.fill: "#90EE90" }
  dram: "DRAM Access (Pointer Chase): 100-200ns" { style.fill: "#FF6B6B" }
}

summary: ||md
  ### Hardware Implementation Analysis
  **Data Structure:** `std::list<Entry> buckets[N]` (Chained Hash Table)
  
  **Total Traversal Time:** $\approx 800ns$ for 4 nodes.
  
  | Resource | Metric | Cost |
  | :--- | :--- | :--- |
  | **CPU Cycles** | 3.2GHz Base | ~2,560 cycles stalled |
  | **Bandwidth** | 64B Cache Lines | 320B fetched for 32B actual data |
  | **Prefetcher** | Pattern Recognition | **FAILED** (Indirection prevents stride detection) |

  **Root Cause:** "Pointer Chasing" prevents Instruction Level Parallelism (ILP). The CPU cannot issue the load for `Node[n+1]` until `Node[n]` has returned from DRAM.
  
  **Recommended fix:** Use Open Addressing (Linear Probing) to utilize Hardware Prefetching.
|| {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#333333"
    border-radius: 10
    font-size: 16
  }
}

# Global Styling
***.style.font: mono
(*** -> ***)[*].target-arrowhead: triangle {
  style.filled: true
}