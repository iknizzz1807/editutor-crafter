vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Open-Addressed Hash Table: Contiguous Memory Layout
  **Technical Specification: Cache-Aligned SIMD-Friendly Array-of-Structs vs Struct-of-Arrays**
| {near: top-center}

direction: right

header: {
  style: {
    fill: "#E8D5E8"
    stroke: "#8B668B"
    font-color: "#4B0082"
    bold: true
  }
  label: "MEMORY ARCHITECTURE: Flat Linear Addressing (0x0000 - 0xFFFF)"
}

arrays_container: {
  label: "Contiguous Virtual Memory Blocks (Struct-of-Arrays)"
  style.fill: "#F5F5F5"
  style.stroke: "#666666"

  keys_array: {
    label: "keys[]: Primary Probe Target (Hot Memory)"
    style.fill: "#E1BEE7" # Purple Header per Rule 1
    style.stroke: "#8E24AA"
    
    k0: "0x00 | uint64_t [KEY_0] | 8B" {style.fill: "#BBDEFB"; tooltip: "Data: Blue per Rule 1"}
    k1: "0x08 | uint64_t [KEY_1] | 8B" {style.fill: "#BBDEFB"}
    k2: "0x10 | uint64_t [KEY_2] | 8B" {style.fill: "#BBDEFB"}
    k3: "0x18 | uint64_t [KEY_3] | 8B" {style.fill: "#BBDEFB"}
    k4: "0x20 | uint64_t [KEY_4] | 8B" {style.fill: "#BBDEFB"}
    k5: "0x28 | uint64_t [KEY_5] | 8B" {style.fill: "#BBDEFB"}
    k6: "0x30 | uint64_t [KEY_6] | 8B" {style.fill: "#BBDEFB"}
    k7: "0x38 | uint64_t [KEY_7] | 8B" {style.fill: "#BBDEFB"}
    
    padding: "0x3C | Alignment Padding | 4B" {style.fill: "#E0E0E0"; style.stroke-dash: 2} # Padding: Gray per Rule 1
    
    k0 -> k1 -> k2 -> k3 -> k4 -> k5 -> k6 -> k7 -> padding {style.stroke: "#4A90A4"; style.stroke-dash: 2}
  }

  values_array: {
    label: "values[]: Payload (Cold Memory)"
    style.fill: "#E1BEE7" # Purple Header
    style.stroke: "#8E24AA"
    
    v0: "0x00 | uint64_t [VAL_0] | 8B" {style.fill: "#C8E6C9"} # Data: Green/Blue (Values/Free mapping)
    v1: "0x08 | uint64_t [VAL_1] | 8B" {style.fill: "#C8E6C9"}
    v2: "0x10 | uint64_t [VAL_2] | 8B" {style.fill: "#C8E6C9"}
    v3: "0x18 | uint64_t [VAL_3] | 8B" {style.fill: "#C8E6C9"}
    
    v0 -> v1 -> v2 -> v3 {style.stroke: "#4A7C4A"; style.stroke-dash: 2}
  }

  metadata_array: {
    label: "metadata[]: Slot State (1B tags)"
    style.fill: "#E1BEE7"
    style.stroke: "#8E24AA"
    
    m0: "0x00 | 0xFF (EMPTY) | 1B" {style.fill: "#E0E0E0"} # Gray: Empty/Padding
    m1: "0x01 | 0x01 (OCCUPIED) | 1B" {style.fill: "#BBDEFB"} # Blue: Data
    m2: "0x02 | 0x01 (OCCUPIED) | 1B" {style.fill: "#BBDEFB"}
    m3: "0x03 | 0xFE (TOMBSTONE) | 1B" {style.fill: "#FFCDD2"; style.stroke: red}
    
    m0 -> m1 -> m2 -> m3 {style.stroke: "#B8860B"; style.stroke-dash: 2}
  }

  # Fixed the compilation error by removing index access on non-existent edges 
  # and declaring them directly with properties.
  keys_array -> values_array: { style.stroke: transparent }
  values_array -> metadata_array: { style.stroke: transparent }
}

cache_lines: {
  label: "Cache Line Alignment (L1d: 64B Boundaries)"
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"

  cl1: {
    label: "Cache Line Block 0"
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    style.stroke-dash: 5
    cl1_note: |md
      **Burst Segment 0**
      *   Alignment: 64-byte aligned
      *   Capacity: 8x 64-bit keys
      *   SIMD: Loadable into YMM (256b) or ZMM (512b)
    | {shape: text}
  }

  cl2: {
    label: "Cache Line Block 1"
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    style.stroke-dash: 5
    cl2_note: |md
      **Hardware Prefetcher Target**
      Prefetcher identifies strided access patterns 
      (i+1) and populates L2/L1 speculatively.
    | {shape: text}
  }

  cl1 -> cl2: "Prefetch Stream" {style.stroke: "#FBC02D"; style.stroke-dash: 3; style.animated: true}
}

probe_sequence: {
  label: "Algorithm: Linear Probe Execution State"
  style.fill: "#F1F8E9"
  style.stroke: "#558B2F"

  probe_diagram: {
    shape: sequence_diagram
    cpu: "CPU Core"
    l1: "L1 Cache (64B Line)"
    dram: "Main Memory"

    cpu -> l1: "Request Index H(k)"
    l1 -> dram: "L1 Miss (0.5%)" {style.stroke: red}
    dram -> l1: "Fill Line (0x00-0x3F)" {style.stroke: orange}
    l1 -> cpu: "Load keys[0..7] into Register"
    cpu -> cpu: "SIMD CMP: key == 42"
    cpu -> cpu: "Movemask -> Result Index"
  }

  cache_stats: |md
    **Micro-op Latencies:**
    1. Initial Probe (DRAM): **~240 cycles**
    2. Linear Scan (L1 Hit): **~4 cycles**
    3. SIMD Compare (AVX): **1 cycle**
    *Effective throughput: 8 keys / 5 cycles*
  | {shape: text; style.fill: "#DCEDC8"}
}

comparison: {
  label: "Performance Analysis: Memory Locality"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"

  chained: {
    label: "Chained (Linked List)"
    style.fill: "#FFCDD2"
    ch_note: |md
      **Pointer Chasing (Stall)**
      - Nodes at: 0x4A21, 0x89F2, 0x110C
      - Each `->next` is a cold cache miss.
      - **Result: T = O(N * DRAM_LATENCY)**
    | {shape: text}
  }

  open: {
    label: "Open Addressing (Contiguous)"
    style.fill: "#C8E6C9"
    op_note: |md
      **Spatial Locality (Throughput)**
      - Nodes at: 0x1000, 0x1008, 0x1010
      - Single fetch fills L1 for 8+ lookups.
      - **Result: T = O(1*DRAM + N*L1_LATENCY)**
    | {shape: text}
  }
  
  chained -> open: "85% Speedup" {style.stroke: "#2E7D32"; style.bold: true}
}

arrays_container -> cache_lines: "Hardware Mapping" {style.stroke: "#757575"}
cache_lines -> probe_sequence: "Access Pattern" {style.stroke: "#757575"}
probe_sequence -> comparison: "Performance Validation" {style.stroke: "#757575"}

# Global Legend
legend: {
  near: bottom-left
  style.fill: "#FFFFFF"
  style.stroke: "#BDBDBD"
  style.double-border: true
  
  title: "Memory Legend" {shape: text; style.bold: true}
  l1: "Key Space (Hot Data)" {style.fill: "#BBDEFB"}
  l2: "Value Space (Cold Data)" {style.fill: "#C8E6C9"}
  l3: "Metadata/State" {style.fill: "#FFD54F"}
  l4: "Alignment/Padding" {style.fill: "#E0E0E0"}
  
  l1 -> l2 -> l3 -> l4 {style.stroke: transparent}
}

# Metrics Table
stats: |||md
  ### Contiguous Layout Stats (N=10^6)
  
  | Segment | Alignment | Size (MB) | Strategy |
  | :--- | :--- | :--- | :--- |
  | `keys[]` | 64B | 8.0 | SIMD/Hot |
  | `values[]` | 8B | 8.0 | Deferred |
  | `metadata[]` | 1B | 1.0 | Bit-maskable |
  | **Total** | | **17.0** | **Compact** |

  **Design Goals:**
  - Zero pointer overhead.
  - Page-walk minimization (TLB efficiency).
  - Compatible with software prefetching (`_mm_prefetch`).
||| {near: bottom-right; shape: text}