vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Robin Hood Hash Insert: Step-by-Step Flow
  **Key K insertion with displacement**
| {near: top-center}
direction: right
step1: {
  label: "Step 1\nCompute Hash"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  compute: |md
    `hash = hash_key(K)`
    `slot = hash % capacity`
    `my_distance = 0`
  |
}
step2: {
  label: "Step 2\nProbe Slot"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  probe: |md
    Check `metadata[slot]`:
    - EMPTY? → Place here ✓
    - TOMBSTONE? → Place here ✓
    - Same key? → Update value ✓
    - Occupied? → Compare distances
  |
}
step3: {
  label: "Step 3\nCompare Distances"
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  compare: |md
    **Robin Hood Check:**
    `if my_distance > probe_dist[slot]:`
    → This entry traveled less
    → **STEAL THE SLOT**
  |
}
step4: {
  label: "Step 4\nSwap & Displace"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  swap: |md
    **Swap with current occupant:**
    
    displaced = slot's (key, value, dist)
    slot ← (K, value, my_distance)
    K ← displaced.key
    my_distance ← displaced.dist
    
  |
}
step5: {
  label: "Step 5\nContinue Probing"
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  continue: |md
    **Advance and repeat:**
    
    slot = (slot + 1) % capacity
    my_distance++
    goto Step 2
    
  |
}
step1 -> step2: "hash computed"
step2 -> step3: "slot occupied\ncheck distance" {
  style.stroke: "#C2185B"
  style.stroke-dash: 3
}
step3 -> step4: "my_distance > stored\nDISPLACE!" {
  style.stroke: "#2E7D32"
  style.bold: true
}
step4 -> step5: "swapped"
step5 -> step2: "continue with\ndisplaced entry" {
  style.stroke: "#7B1FA2"
  style.animated: true
  style.stroke-dash: 5
}
step2_terminate: {
  label: "TERMINATE\nPlace Entry"
  style.fill: "#C8E6C9"
  style.stroke: "#1B5E20"
  style.bold: true
  place: |md
    Found EMPTY or TOMBSTONE:
    
    keys[slot] = K
    values[slot] = value
    probe_dist[slot] = my_distance
    metadata[slot] = OCCUPIED
    count++
    
  |
}
step2 -> step2_terminate: "EMPTY or\nTOMBSTONE found" {
  style.stroke: "#1B5E20"
  style.bold: true
}
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  title: |md
    **Robin Hood Invariant**
  |
  inv: |md
    Entries with longer probe distances "steal" from 
    entries with shorter distances, ensuring:
    - **Bounded max probe**: O(log n) even at 90% load
    - **Fair distribution**: "Rich don't get richer"
    - **Predictable lookups**: Early termination possible
  |
}