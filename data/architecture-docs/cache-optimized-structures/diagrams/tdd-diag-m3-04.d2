vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Robin Hood Hashing: Probe Distance Invariant
  **Bounded Maximum Probe Through Displacement**
| {near: top-center}
direction: right
naive_histogram: "Naive Linear Probing\n(90% load factor, 1M entries)" {
  style.fill: "#FFE4E1"
  style.stroke: "#CD5C5C"
  style.stroke-width: 2
  na_label: "Probe Distance Distribution" {shape: text}
  na_0: "0: ████ 15%" {shape: text}
  na_1: "1: ███ 12%" {shape: text}
  na_2: "2: ██ 9%" {shape: text}
  na_3: "3: ██ 7%" {shape: text}
  na_4: "4: █ 5%" {shape: text}
  na_5: "5: █ 4%" {shape: text}
  na_10: "10: ░ 1%" {shape: text}
  na_20: "20: ░ 0.3%" {shape: text}
  na_30: "30: ░ 0.1%" {shape: text}
  na_40: "40: ░ 0.05%" {shape: text}
  na_50: "50+: ░ 0.01%" {shape: text}
  na_tail: |md
    **Long tail extends to 50+**
    - No upper bound
    - Clustering causes cascade
    - Worst-case unpredictable
  | {shape: text}
}
robin_hood_histogram: "Robin Hood Hashing\n(90% load factor, 1M entries)" {
  style.fill: "#E6FFE6"
  style.stroke: "#228B22"
  style.stroke-width: 2
  rh_label: "Probe Distance Distribution" {shape: text}
  rh_0: "0: ██ 8%" {shape: text}
  rh_1: "1: ████ 18%" {shape: text}
  rh_2: "2: █████ 22%" {shape: text}
  rh_3: "3: ████ 20%" {shape: text}
  rh_4: "4: ███ 15%" {shape: text}
  rh_5: "5: ██ 10%" {shape: text}
  rh_6: "6: █ 4%" {shape: text}
  rh_7: "7: ░ 2%" {shape: text}
  rh_8: "8: ░ 0.8%" {shape: text}
  rh_9: "9: ░ 0.15%" {shape: text}
  rh_10: "10: ░ 0.02%" {shape: text}
  rh_bound: |md
    **Bounded to ~ln(N) ≈ 14**
    - Variance reduced
    - Predictable worst-case
    - No long tail
  | {shape: text}
}
invariant_box: "Robin Hood Invariant" {
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  style.stroke-width: 2
  inv_title: |md
    **Key Principle**
  | {shape: text}
  inv_rule: |md
    **Entries with longer probe distance
    "steal" slots from entries with
    shorter probe distance**
  | {shape: text}
  inv_before: "Before Insert (distance=5 arrives):" {shape: text}
  before_state: {
    shape: sequence_diagram
    slot_a: "Slot A\nprobe=1\n(was 5 away)"
    slot_b: "Slot B\nprobe=2\n(was 6 away)"
    slot_c: "Slot C\nprobe=7\n(new entry)"
    slot_a -> slot_b: "chain"
    slot_b -> slot_c: "chain"
  }
  inv_after: "After Displacement:" {shape: text}
  after_state: {
    shape: sequence_diagram
    new_a: "Slot A\nprobe=5\n(displaced to here)"
    new_b: "Slot B\nprobe=1\n(moved closer!)"
    new_c: "Slot C\nprobe=2\n(moved closer!)"
    new_a -> new_b: "chain"
    new_b -> new_c: "chain"
  }
  inv_result: |md
    **Result:** "Rich" entries (short probe)
    give slots to "poor" entries (long probe)
    → Variance in probe distances decreases
    → Maximum probe bounded by O(ln n)
  | {shape: text}
}
comparison: "Statistical Comparison" {
  style.fill: "#F0F8FF"
  style.stroke: "#4682B4"
  style.stroke-width: 2
  comp_title: "At 90% Load Factor, 1M Entries" {shape: text}
  metric_avg: "Average Probe Distance" {shape: text}
  naive_avg: "  Naive:        ~5.5" {shape: text}
  rh_avg: "  Robin Hood:  ~5.5 (same!)" {shape: text}
  metric_max: "Maximum Probe Distance" {shape: text}
  naive_max: "  Naive:        50+ (unbounded)" {shape: text; style.font-color: "#CD5C5C"; style.bold: true}
  rh_max: "  Robin Hood:  ~10-14 (bounded)" {shape: text; style.font-color: "#228B22"; style.bold: true}
  metric_var: "Probe Distance Variance" {shape: text}
  naive_var: "  Naive:        HIGH" {shape: text}
  rh_var: "  Robin Hood:  LOW" {shape: text; style.font-color: "#228B22"}
}
naive_histogram -> robin_hood_histogram: "Displacement\nTransform" {
  style.stroke: "#4169E1"
  style.stroke-width: 3
  style.stroke-dash: 4
}
robin_hood_histogram -> invariant_box: "Achieved By" {
  style.stroke: "#228B22"
  style.stroke-width: 2
}
naive_histogram -> comparison: "Metrics" {style.stroke-dash: 3}
robin_hood_histogram -> comparison: "Metrics" {style.stroke-dash: 3}
legend: |md
  **Legend**
  - ████ = High concentration of entries
  - ░ = Few entries (long tail)
  - Red = Problematic clustering
  - Green = Controlled distribution
| {near: bottom-center; shape: text}