direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: ||md
  # Cache Misses: Chained vs Open Addressing
  **Performance Analysis of Hash Table Memory Access Patterns**
  *Open addressing shows 2.5x to 4.0x reduction across all cache hierarchy levels.*
|| {
  near: top-center
  shape: rectangle
  style: {
    stroke-width: 0
    fill: transparent
    font-size: 18
  }
}

# -----------------------------------------------------------------------------
# Metric Legend and Context
# -----------------------------------------------------------------------------
legend: {
  near: top-right
  shape: rectangle
  style: {
    fill: "#f8f9fa"
    stroke: "#adb5bd"
    stroke-width: 1
    double-border: true
  }
  
  key_chained: "Chained Hash Table" {
    shape: rectangle
    width: 25
    height: 15
    style.fill: "#e74c3c"
  }
  key_open: "Open Addressed (Linear)" {
    shape: rectangle
    width: 25
    height: 15
    style.fill: "#27ae60"
  }
  
  description: ||md
    **Metric:** Millions of cache misses
    **Workload:** 10M lookups / 1M entries
    **Hardware:** x86_64, 64B Cache Line
  || {shape: text}
}

# -----------------------------------------------------------------------------
# Comparison Sections (The Bars)
# -----------------------------------------------------------------------------
metrics_container: {
  y_axis: {
    shape: rectangle
    width: 15
    height: 400
    style: {
      fill: "linear-gradient(#f8f9fa, #dee2e6)"
      stroke: "#495057"
    }
  }

  label_100: "100M" { shape: text; style.font-size: 12 }
  label_50: "50M" { shape: text; style.font-size: 12 }
  label_0: "0" { shape: text; style.font-size: 12 }

  l1_section: {
    label: "L1-dcache Load Misses"
    
    l1_chained: "85M" {
      shape: rectangle
      width: 80
      height: 300
      style: {
        fill: "#e74c3c"
        stroke: "#c0392b"
        stroke-width: 3
      }
      tooltip: "Chained: High pointer chasing overhead. Each bucket is a linked list."
    }
    
    l1_open: "28M" {
      shape: rectangle
      width: 80
      height: 100
      style: {
        fill: "#27ae60"
        stroke: "#1e8449"
        stroke-width: 3
      }
      tooltip: "Open: Sequential array access fits cache lines perfectly."
    }
    
    improvement: "3.0x Spatial Locality" {
      shape: text
      style.font-color: "#27ae60"
      style.bold: true
    }
  }

  l2_section: {
    label: "L2 Cache Load Misses"
    
    l2_chained: "52M" {
      shape: rectangle
      width: 80
      height: 185
      style: {
        fill: "#e74c3c"
        stroke: "#c0392b"
        stroke-width: 3
      }
      tooltip: "Scattered heap allocations for nodes bypass L2 prefetchers."
    }
    
    l2_open: "15M" {
      shape: rectangle
      width: 80
      height: 55
      style: {
        fill: "#27ae60"
        stroke: "#1e8449"
        stroke-width: 3
      }
      tooltip: "Contiguous layout allows L2 hardware prefetch to predict next probes."
    }
    
    improvement: "3.5x Prefetcher Win" {
      shape: text
      style.font-color: "#27ae60"
      style.bold: true
    }
  }

  l3_section: {
    label: "LLC (L3) Load Misses"
    
    l3_chained: "32M" {
      shape: rectangle
      width: 80
      height: 115
      style: {
        fill: "#e74c3c"
        stroke: "#c0392b"
        stroke-width: 3
      }
      tooltip: "Large working set + pointers = LLC eviction pressure."
    }
    
    l3_open: "8M" {
      shape: rectangle
      width: 80
      height: 30
      style: {
        fill: "#27ae60"
        stroke: "#1e8449"
        stroke-width: 3
      }
      tooltip: "Dense bit-packed entries keep working set within LLC."
    }
    
    improvement: "4.0x LLC Occupancy" {
      shape: text
      style.font-color: "#27ae60"
      style.bold: true
    }
  }

  # Layout sequence for Elk within container
  y_axis -> l1_section -> l2_section -> l3_section
}

# -----------------------------------------------------------------------------
# Memory Layout Visualization (Intel Quality)
# -----------------------------------------------------------------------------
memory_layout_comparison: {
  near: bottom-center
  
  chained_layout: {
    label: "Chained Node: 32 Bytes (Heap Scattered)"
    
    mem_grid: {
      grid-columns: 2
      grid-gap: 0
      
      "0x00": "Header/Meta" { style.fill: "#9b59b6"; width: 60 }
      "8B": "" { style.fill: "#9b59b6"; width: 200 }
      
      "0x08": "Key Pointer" { style.fill: "#f39c12"; width: 60 }
      "8B": "" { style.fill: "#f39c12"; width: 200 }
      
      "0x10": "Value Data" { style.fill: "#3498db"; width: 60 }
      "8B": "" { style.fill: "#3498db"; width: 200 }
      
      "0x18": "Next Node *" { style.fill: "#e67e22"; width: 60 }
      "8B": "" { style.fill: "#e67e22"; width: 200 }
    }
    
    ptr_jump: "Pointer Jump"
    mem_grid."0x18" -> ptr_jump: "Cache Miss" { 
      style.stroke: "#e67e22"
      style.animated: true 
    }
    ptr_jump: "Scattered Memory Block" { 
      shape: rectangle
      style.stroke-dash: 5 
    }
  }

  open_layout: {
    label: "Open Addressing: Array Slots (Contiguous)"
    
    slots: {
      grid-columns: 2
      grid-gap: 0
      
      "0x00": "Entry A (K, V)" { style.fill: "#3498db"; width: 80 }
      "16B": "" { style.fill: "#3498db"; width: 200 }
      
      "0x10": "Entry B (K, V)" { style.fill: "#3498db"; width: 80 }
      "16B": "" { style.fill: "#3498db"; width: 200 }
      
      "0x20": "Entry C (K, V)" { style.fill: "#3498db"; width: 80 }
      "16B": "" { style.fill: "#3498db"; width: 200 }
      
      "0x30": "Entry D (K, V)" { style.fill: "#3498db"; width: 80 }
      "16B": "" { style.fill: "#3498db"; width: 200 }
    }
    
    cache_line: "L1 Cache Line Boundary (64B)" {
      shape: rectangle
      style: {
        fill: transparent
        stroke: "#34495e"
        stroke-dash: 5
        stroke-width: 2
      }
    }
    
    slots -> cache_line: "Full Line Fetch" { style.stroke: "#27ae60" }
  }
}

# -----------------------------------------------------------------------------
# Impact Table & Analysis
# -----------------------------------------------------------------------------
analysis_group: {
  near: bottom-right
  
  detailed_analysis: {
    label: "Micro-Architectural Analysis"
    style: {
      fill: "#e8f5e9"
      stroke: "#27ae60"
      border-radius: 10
    }
    
    content: |||md
      ## Performance Fundamentals
      
      ### The Cost of Indirection
      - **Chained:** `buckets[h]` -> `node*` -> `next*`.
      - Each pointer dereference is a **dependent load**. The CPU stalls waiting for RAM.
      
      ### The Power of Locality
      - **Open Addressing:** Modern CPUs fetch 64 bytes at a time.
      - A single DRAM access brings **4 entries** into L1 simultaneously.
      - **Hardware Prefetchers** proactively fetch subsequent lines.
    |||
  }

  performance_impact: {
    label: "System Impact Summary"
    style: {
      fill: "#fff3e0"
      stroke: "#f39c12"
      border-radius: 10
    }
    
    content: |||md
      | Level | Chained | Open | Speedup |
      | :--- | :--- | :--- | :--- |
      | **L1 Misses** | 85M | 28M | 3.03x |
      | **L2 Misses** | 52M | 15M | 3.46x |
      | **LLC Misses** | 32M | 8M  | 4.00x |
      | **Cycles** | 12.2B | 3.1B | **3.9x** |
      
      > Result: Dramatically reduced CPU Pipeline Stalls.
    |||
  }
}

# -----------------------------------------------------------------------------
# Structural Connections & Baseline
# -----------------------------------------------------------------------------
baseline: {
  shape: rectangle
  width: 800
  height: 4
  style.fill: "#343a40"
}

metrics_container -- baseline
memory_layout_comparison -- baseline: "Implementation Strategy"

metrics_container.l3_section -> analysis_group.detailed_analysis: {
  label: "Logic Flow"
  style.stroke-dash: 5
}

analysis_group.detailed_analysis -> analysis_group.performance_impact: {
  style.stroke-dash: 5
}