vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Pointer-Based BST: Memory Locality & Cache Miss Analysis
  **Architecture Specification: Standard Heap-Allocated Node (O(h) Cache Misses)**
  *Note: Each level transition triggers a random memory access, bypassing spatial locality.*
'| {near: top-center}

direction: right

# Global Styles & Classes
classes: {
  memory_node: {
    shape: sql_table
    style: {
      stroke-width: 2
      shadow: true
    }
  }
  cache_miss: {
    style: {
      fill: "#FFDADA"
      stroke: "#CC0000"
      bold: true
    }
  }
  pointer: {
    style: {
      stroke: orange
      stroke-width: 2
      font-color: orange
    }
  }
  header_purple: {
    style: {
      fill: "#DDA0DD" # Purple Header
    }
  }
}

# 1. Physical Memory Layout (Heap Fragmented)
heap: "Heap Memory Space (Fragmented Allocation)" {
  style: {
    fill: "#F8F8F8"
    stroke: "#666666"
    stroke-dash: 3
  }

  node_a: "Node A (Root) @0x7F30" {
    class: [memory_node; header_purple]
    tooltip: "sizeof=24 bytes | Cache Line: 0x7F00"
    
    "Offset" : "Field Name | Size | Value"
    "0x00" : "vtable_ptr | 8B | 0xDEADBEEF" {style.fill: "#E8E8E8"}
    "0x08" : "value | 8B | 50 (int64)" {style.fill: "#B6D0F6"} # Data Blue
    "0x10" : "\"left\" | 8B | *ptr: 0x3A20" {style.fill: "#FFE5B4"} # Pointer Orange
    "0x18" : "\"right\" | 8B | *ptr: 0xB180" {style.fill: "#FFE5B4"}
    
    padding: "Padding | 40B | [Empty / Unrelated]" {style.fill: "#D3D3D3"} # Padding Gray
  }

  node_b: "Node B (Left Child) @0x3A20" {
    class: [memory_node; header_purple]
    tooltip: "sizeof=24 bytes | Cache Line: 0x3A00"

    "Offset" : "Field Name | Size | Value"
    "0x00" : "vtable_ptr | 8B | 0xDEADBEEF" {style.fill: "#E8E8E8"}
    "0x08" : "value | 8B | 25 (int64)" {style.fill: "#B6D0F6"}
    "0x10" : "\"left\" | 8B | *ptr: 0x1F40" {style.fill: "#FFE5B4"}
    "0x18" : "\"right\" | 8B | *ptr: 0x8C10" {style.fill: "#FFE5B4"}

    padding: "Padding | 40B | [Empty / Unrelated]" {style.fill: "#D3D3D3"}
  }

  node_c: "Node C (Right Child) @0xB180" {
    class: [memory_node; header_purple]
    tooltip: "sizeof=24 bytes | Cache Line: 0xB180"

    "Offset" : "Field Name | Size | Value"
    "0x00" : "vtable_ptr | 8B | 0xDEADBEEF" {style.fill: "#E8E8E8"}
    "0x08" : "value | 8B | 75 (int64)" {style.fill: "#B6D0F6"}
    "0x10" : "\"left\" | 8B | *ptr: 0x4D90" {style.fill: "#FFE5B4"}
    "0x18" : "\"right\" | 8B | *ptr: 0xE200" {style.fill: "#FFE5B4"}
  }

  gap_1: "Stride: ~17.6 KB" {shape: text}
  gap_2: "Stride: ~30.5 KB" {shape: text}

  node_a -> gap_1 -> node_b
  node_b -> gap_2 -> node_c
}

# 2. Logical BST Structure
tree: "Logical BST Structure" {
  style: {
    fill: "#FFFFFF"
    stroke: "#333333"
  }
  
  root: "50\n(0x7F30)" {
    shape: circle
    style: {
      fill: "#FFB6C1"
      stroke: "#CC0000"
      stroke-width: 3
    }
  }
  
  left_child: "25\n(0x3A20)" {
    shape: circle
    style: {
      fill: "#90EE90"
      stroke: "#006600"
      stroke-width: 3
    }
  }
  
  right_child: "75\n(0xB180)" {
    shape: circle
    style: {
      fill: "#ADD8E6"
      stroke: "#0000CC"
    }
  }

  root -> left_child: "ptr chase" {
    class: pointer
  }
  root -> right_child: "ptr chase" {
    class: pointer
  }
}

# 3. Execution Trace: Search(25)
trace: "Execution Trace: Search(25)" {
  direction: down
  
  step_1: "Step 1: Access Root (0x7F30)" {
    class: cache_miss
    label: |'md
      - Fetching Cache Line: **0x7F00**
      - **Latency: 100ns (Main Memory)**
      - compare(50, 25) -> Go Left (0x3A20)
    '|
  }
  
  step_2: "Step 2: Access Child (0x3A20)" {
    class: cache_miss
    label: |'md
      - Fetching Cache Line: **0x3A00**
      - **Latency: 100ns (Main Memory)**
      - **STATUS: FOUND**
    '|
  }
  
  step_1 -> step_2: "Follow Pointer" {
    style: {
      stroke: red
      stroke-width: 4
      animated: true
    }
  }
}

# 4. Cache Utilization Analysis
cache_analysis: "L1 Cache Line Analysis (64B Blocks)" {
  cl_root: "Line 0x7F00" {
    shape: rectangle
    style: {
      fill: "linear-gradient(to right, #B6D0F6 37%, #D3D3D3 37%)"
    }
    label: "Node A (24B) | Padding/Noise (40B)"
  }
  
  cl_left: "Line 0x3A00" {
    shape: rectangle
    style: {
      fill: "linear-gradient(to right, #B6D0F6 37%, #D3D3D3 37%)"
    }
    label: "Node B (24B) | Padding/Noise (40B)"
  }
  
  annot: "Utilization: 37.5%\nSpatial Locality: ZERO" {
    shape: text
    style: {
      font-color: red
      bold: true
    }
  }
}

# 5. Performance Summary
summary: "Performance Impact Summary" {
  label: |'md
    ### Cost Analysis (Pointer-Based)
    
    | Metric | Pointer-Based | Cache-Optimized (Goal) |
    | :--- | :--- | :--- |
    | **Cache Misses** | **1 per Level** | ~1 per 4-8 Levels |
    | **Instruction Stalls** | ~250 cycles/node | < 20 cycles/node |
    | **Spatial Locality** | None (Heap Dispersed) | High (Packed Array) |
    | **Prefetching** | Failed (Random Trace) | Linear/Predictable |

    **Root Cause:** The CPU hardware prefetcher is unable to anticipate the next pointer-chase address because nodes are allocated non-contiguously in the heap.
  '|
}

# Structural Cross-References
tree.root -> heap.node_a: "phys_mapping" {style.stroke-dash: 5; style.stroke: grey}
tree.left_child -> heap.node_b: "phys_mapping" {style.stroke-dash: 5; style.stroke: grey}

trace -> cache_analysis: "Cold Access"
cache_analysis -> summary: "Efficiency Loss"
heap -> summary: "Fragmentation"