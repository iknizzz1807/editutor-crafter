layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Van Emde Boas (vEB) Layout: Recursive Construction
  **Height-4 Tree (15 nodes) split at middle height (H/2 = 2)**
  *Cache-oblivious data structure for optimal search performance.*
| {
  near: top-center
}

direction: right

# === ORIGINAL TREE (BFS order) ===
original_tree: {
  label: "Logical View: Original Tree (BFS Order)"
  style: {
    fill: "#F5F5F5"
    stroke: "#666666"
    stroke-width: 2
  }

  # Level 0 - Root
  n0: "[0]" {
    shape: circle
    style: { fill: "#E8D5E8"; stroke: "#9B59B6"; stroke-width: 2 }
  }

  # Level 1
  n1: "[1]" {
    shape: circle
    style: { fill: "#E8D5E8"; stroke: "#9B59B6"; stroke-width: 2 }
  }
  n2: "[2]" {
    shape: circle
    style: { fill: "#E8D5E8"; stroke: "#9B59B6"; stroke-width: 2 }
  }

  # SPLIT LINE 
  split_indicator: {
    shape: text
    label: "--- Recursive Split Point (H/2) ---"
    style: { font-color: "#E74C3C"; bold: true }
  }

  # Level 2 - Bottom Subtree Roots
  n3: "[3]" {
    shape: circle
    style: { fill: "#AED6F1"; stroke: "#3498DB"; stroke-width: 2 }
  }
  n4: "[4]" {
    shape: circle
    style: { fill: "#AED6F1"; stroke: "#3498DB"; stroke-width: 2 }
  }
  n5: "[5]" {
    shape: circle
    style: { fill: "#AED6F1"; stroke: "#3498DB"; stroke-width: 2 }
  }
  n6: "[6]" {
    shape: circle
    style: { fill: "#AED6F1"; stroke: "#3498DB"; stroke-width: 2 }
  }

  # Level 3 - Bottom Subtree Leaves
  n7: "[7]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }
  n8: "[8]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }
  n9: "[9]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }
  n10: "[10]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }
  n11: "[11]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }
  n12: "[12]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }
  n13: "[13]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }
  n14: "[14]" {
    shape: circle
    style: { fill: "#A9DFBF"; stroke: "#27AE60" }
  }

  # Edges
  n0 -> n1
  n0 -> n2
  n1 -> n3
  n1 -> n4
  n2 -> n5
  n2 -> n6
  n3 -> n7
  n3 -> n8
  n4 -> n9
  n4 -> n10
  n5 -> n11
  n5 -> n12
  n6 -> n13
  n6 -> n14
}

# === VEB MEMORY CLUSTERS ===
veb_clusters: {
  label: "vEB Clustered View (Recursive Grouping)"
  style: { fill: "#FAFAFA"; stroke: "#333333"; stroke-dash: 5 }

  top_cluster: "Top Subtree\n(Indices 0, 1, 2)" {
    style: { fill: "#E8D5E8"; stroke: "#9B59B6"; stroke-width: 3 }
  }

  bottom_row: {
    grid-columns: 4
    b0: "Bottom Cluster 0\n(3, 7, 8)" { style: { fill: "#AED6F1"; stroke: "#3498DB" } }
    b1: "Bottom Cluster 1\n(4, 9, 10)" { style: { fill: "#AED6F1"; stroke: "#3498DB" } }
    b2: "Bottom Cluster 2\n(5, 11, 12)" { style: { fill: "#AED6F1"; stroke: "#3498DB" } }
    b3: "Bottom Cluster 3\n(6, 13, 14)" { style: { fill: "#AED6F1"; stroke: "#3498DB" } }
  }

  top_cluster -> bottom_row.b0: "Contiguous Pointer"
  bottom_row.b0 -> bottom_row.b1
  bottom_row.b1 -> bottom_row.b2
  bottom_row.b2 -> bottom_row.b3
}

# === MEMORY ARRAY VIEW ===
memory_layout: {
  label: "Physical Memory Array (Linear Addresses)"
  grid-columns: 15
  grid-gap: 2

  idx0: "0" { style: { fill: "#E8D5E8"; stroke: "#9B59B6"; font: mono } }
  idx1: "1" { style: { fill: "#E8D5E8"; stroke: "#9B59B6"; font: mono } }
  idx2: "2" { style: { fill: "#E8D5E8"; stroke: "#9B59B6"; font: mono } }
  idx3: "3" { style: { fill: "#AED6F1"; stroke: "#3498DB"; font: mono } }
  idx4: "7" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
  idx5: "8" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
  idx6: "4" { style: { fill: "#AED6F1"; stroke: "#3498DB"; font: mono } }
  idx7: "9" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
  idx8: "10" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
  idx9: "5" { style: { fill: "#AED6F1"; stroke: "#3498DB"; font: mono } }
  idx10: "11" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
  idx11: "12" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
  idx12: "6" { style: { fill: "#AED6F1"; stroke: "#3498DB"; font: mono } }
  idx13: "13" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
  idx14: "14" { style: { fill: "#A9DFBF"; stroke: "#27AE60"; font: mono } }
}

# === ALGORITHM STEPS ===
algo_steps: {
  label: "Construction Algorithm"
  style: { fill: "#FFF9E6"; stroke: "#F39C12" }

  s1: "Step 1: Recursive Split" {
    shape: text
    label: |md
      **1. Recursive Split**
      Split tree of height $H$ at $H/2$.
      This creates one 'Top' subtree and $\sqrt{N}$ 'Bottom' subtrees.
    |
  }

  s2: "Step 2: Top First" {
    shape: text
    label: |md
      **2. Store Top Cluster**
      Recursively lay out the Top subtree.
      These nodes occupy the first memory slots.
    |
  }

  s3: "Step 3: Bottom Clusters" {
    shape: text
    label: |md
      **3. Store Bottom Clusters**
      Lay out each Bottom subtree recursively.
      Store them left-to-right in the array.
    |
  }

  s1 -> s2 -> s3
}

# === KEY INSIGHT ===
performance_note: |md
  ### Cache-Oblivious Search Benefit
  - Any search path from root to leaf crosses $O(\log N)$ nodes.
  - vEB ensures that any sub-tree of size $B$ (cache block size) is stored contiguously.
  - **Memory Transfers:** $O(\log_B N)$, matching the optimal B-Tree without knowing $B$.
  - Reduces cache misses by up to 75% compared to standard BFS/DFS layouts.
| {
  near: bottom-center
  style: { fill: "#E8F8F5"; stroke: "#1ABC9C"; border-radius: 10 }
}

# Legend
legend: {
  label: "Legend"
  near: bottom-right
  
  p: " " { style: { fill: "#E8D5E8"; stroke: "#9B59B6" } }
  p_label: "Top Subtree (H=2)" { shape: text }
  
  b: " " { style: { fill: "#AED6F1"; stroke: "#3498DB" } }
  b_label: "Subtree Roots" { shape: text }
  
  g: " " { style: { fill: "#A9DFBF"; stroke: "#27AE60" } }
  g_label: "Subtree Leaves" { shape: text }

  p -- p_label
  b -- b_label
  g -- g_label
}