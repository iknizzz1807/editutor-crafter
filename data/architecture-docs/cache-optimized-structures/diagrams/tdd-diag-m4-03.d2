vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # vEB Layout: Logical to Physical Index Mapping
| {near: top-center}
direction: right
# BFS Index Column
bfs_indices: {
  label: BFS Index\n(Logical Position)
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.font: mono
  bfs_0: "0 (root)" {style.fill: "#B8D4E8"}
  bfs_1: "1" {style.fill: "#C5DDF0"}
  bfs_2: "2" {style.fill: "#C5DDF0"}
  bfs_3: "3" {style.fill: "#D2E6F7"}
  bfs_4: "4" {style.fill: "#D2E6F7"}
  bfs_5: "5" {style.fill: "#D2E6F7"}
  bfs_6: "6" {style.fill: "#D2E6F7"}
  bfs_7: "7" {style.fill: "#DFEFFC"}
  bfs_8: "8" {style.fill: "#DFEFFC"}
  bfs_9: "9" {style.fill: "#DFEFFC"}
  bfs_10: "10" {style.fill: "#DFEFFC"}
  bfs_11: "11" {style.fill: "#DFEFFC"}
  bfs_12: "12" {style.fill: "#DFEFFC"}
  bfs_13: "13" {style.fill: "#DFEFFC"}
  bfs_14: "14" {style.fill: "#DFEFFC"}
  bfs_0 -> bfs_1 -> bfs_2 -> bfs_3 -> bfs_4 -> bfs_5 -> bfs_6 -> bfs_7 -> bfs_8 -> bfs_9 -> bfs_10 -> bfs_11 -> bfs_12 -> bfs_13 -> bfs_14: {style.opacity: 0}
}
# Mapping Arrows
mapping_arrows: {
  arrow_0: "→" {shape: text; style.font-size: 20; style.font-color: "#2E86AB"}
  arrow_1: "→" {shape: text; style.font-size: 20; style.font-color: "#2E86AB"}
  arrow_2: "→" {shape: text; style.font-size: 20; style.font-color: "#2E86AB"}
  arrow_3: "→" {shape: text; style.font-size: 20; style.font-color: "#2E86AB"}
  arrow_4: "→" {shape: text; style.font-size: 20; style.font-color: "#E67E22"}
  arrow_5: "→" {shape: text; style.font-size: 20; style.font-color: "#E67E22"}
  arrow_6: "→" {shape: text; style.font-size: 20; style.font-color: "#E67E22"}
  arrow_7: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
  arrow_8: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
  arrow_9: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
  arrow_10: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
  arrow_11: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
  arrow_12: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
  arrow_13: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
  arrow_14: "→" {shape: text; style.font-size: 20; style.font-color: "#27AE60"}
}
# vEB Index Column
veb_indices: {
  label: vEB Index\n(Memory Position)
  style.fill: "#F5E6D3"
  style.stroke: "#D35400"
  style.font: mono
  veb_0: "0" {style.fill: "#B8D4E8"}
  veb_1: "1" {style.fill: "#C5DDF0"}
  veb_2: "2" {style.fill: "#C5DDF0"}
  veb_3: "3" {style.fill: "#D2E6F7"}
  veb_4: "7" {style.fill: "#FAD7A0"; style.font-color: "#E67E22"; style.bold: true}
  veb_5: "8" {style.fill: "#FAD7A0"; style.font-color: "#E67E22"; style.bold: true}
  veb_6: "9" {style.fill: "#FAD7A0"; style.font-color: "#E67E22"; style.bold: true}
  veb_7: "4" {style.fill: "#ABEBC6"; style.font-color: "#27AE60"; style.bold: true}
  veb_8: "5" {style.fill: "#ABEBC6"; style.font-color: "#27AE60"; style.bold: true}
  veb_9: "6" {style.fill: "#ABEBC6"; style.font-color: "#27AE60"; style.bold: true}
  veb_10: "10" {style.fill: "#DFEFFC"}
  veb_11: "11" {style.fill: "#DFEFFC"}
  veb_12: "12" {style.fill: "#DFEFFC"}
  veb_13: "13" {style.fill: "#DFEFFC"}
  veb_14: "14" {style.fill: "#DFEFFC"}
  veb_0 -> veb_1 -> veb_2 -> veb_3 -> veb_4 -> veb_5 -> veb_6 -> veb_7 -> veb_8 -> veb_9 -> veb_10 -> veb_11 -> veb_12 -> veb_13 -> veb_14: {style.opacity: 0}
}
# Connect BFS to vEB
bfs_indices.bfs_0 -> mapping_arrows.arrow_0 -> veb_indices.veb_0: {style.stroke: "#2E86AB"; style.stroke-width: 2}
bfs_indices.bfs_1 -> mapping_arrows.arrow_1 -> veb_indices.veb_1: {style.stroke: "#2E86AB"; style.stroke-width: 2}
bfs_indices.bfs_2 -> mapping_arrows.arrow_2 -> veb_indices.veb_2: {style.stroke: "#2E86AB"; style.stroke-width: 2}
bfs_indices.bfs_3 -> mapping_arrows.arrow_3 -> veb_indices.veb_3: {style.stroke: "#2E86AB"; style.stroke-width: 2}
bfs_indices.bfs_4 -> mapping_arrows.arrow_4 -> veb_indices.veb_4: {style.stroke: "#E67E22"; style.stroke-width: 2; style.stroke-dash: 4}
bfs_indices.bfs_5 -> mapping_arrows.arrow_5 -> veb_indices.veb_5: {style.stroke: "#E67E22"; style.stroke-width: 2; style.stroke-dash: 4}
bfs_indices.bfs_6 -> mapping_arrows.arrow_6 -> veb_indices.veb_6: {style.stroke: "#E67E22"; style.stroke-width: 2; style.stroke-dash: 4}
bfs_indices.bfs_7 -> mapping_arrows.arrow_7 -> veb_indices.veb_7: {style.stroke: "#27AE60"; style.stroke-width: 2}
bfs_indices.bfs_8 -> mapping_arrows.arrow_8 -> veb_indices.veb_8: {style.stroke: "#27AE60"; style.stroke-width: 2}
bfs_indices.bfs_9 -> mapping_arrows.arrow_9 -> veb_indices.veb_9: {style.stroke: "#27AE60"; style.stroke-width: 2}
bfs_indices.bfs_10 -> mapping_arrows.arrow_10 -> veb_indices.veb_10: {style.stroke: "#7F8C8D"; style.stroke-width: 1}
bfs_indices.bfs_11 -> mapping_arrows.arrow_11 -> veb_indices.veb_11: {style.stroke: "#7F8C8D"; style.stroke-width: 1}
bfs_indices.bfs_12 -> mapping_arrows.arrow_12 -> veb_indices.veb_12: {style.stroke: "#7F8C8D"; style.stroke-width: 1}
bfs_indices.bfs_13 -> mapping_arrows.arrow_13 -> veb_indices.veb_13: {style.stroke: "#7F8C8D"; style.stroke-width: 1}
bfs_indices.bfs_14 -> mapping_arrows.arrow_14 -> veb_indices.veb_14: {style.stroke: "#7F8C8D"; style.stroke-width: 1}
# Tree Structure Visual
tree_visual: {
  label: Tree Structure (Height 4)
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  # Level 0 - Root (top subtree)
  root: "0" {shape: circle; style.fill: "#B8D4E8"; width: 40; height: 40}
  # Level 1 - Top subtree children
  l1_left: "1" {shape: circle; style.fill: "#C5DDF0"; width: 36; height: 36}
  l1_right: "2" {shape: circle; style.fill: "#C5DDF0"; width: 36; height: 36}
  # Level 2 - Split point (bottom subtrees begin)
  l2_0: "3" {shape: circle; style.fill: "#FAD7A0"; width: 32; height: 32}
  l2_1: "4" {shape: circle; style.fill: "#FAD7A0"; width: 32; height: 32}
  l2_2: "5" {shape: circle; style.fill: "#ABEBC6"; width: 32; height: 32}
  l2_3: "6" {shape: circle; style.fill: "#ABEBC6"; width: 32; height: 32}
  # Level 3 - Leaves
  l3_0: "7" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  l3_1: "8" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  l3_2: "9" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  l3_3: "10" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  l3_4: "11" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  l3_5: "12" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  l3_6: "13" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  l3_7: "14" {shape: circle; style.fill: "#DFEFFC"; width: 28; height: 28}
  # Tree edges
  root -> l1_left
  root -> l1_right
  l1_left -> l2_0
  l1_left -> l2_1
  l1_right -> l2_2
  l1_right -> l2_3
  l2_0 -> l3_0
  l2_0 -> l3_1
  l2_1 -> l3_2
  l2_1 -> l3_3
  l2_2 -> l3_4
  l2_2 -> l3_5
  l2_3 -> l3_6
  l2_3 -> l3_7
}
# Explanation Panel
explanation: {
  label: vEB Layout Explanation
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  split: |md
    ## Split at Height H/2 = 2
    **Top Subtree** (height 2, 3 nodes):
    - BFS indices 0, 1, 2
    - vEB indices 0, 1, 2 (stored first)
  |
  bottom: |md
    **Bottom Subtrees** (4 trees, each 3 nodes):
    Subtree 0 (rooted at BFS 3):
    - BFS 3, 7, 8 → vEB 3, 7, 8
    Subtree 1 (rooted at BFS 4):
    - BFS 4, 9, 10 → vEB 4, 9, 10
    Subtree 2 (rooted at BFS 5):
    - BFS 5, 11, 12 → vEB 5, 11, 12
    Subtree 3 (rooted at BFS 6):
    - BFS 6, 13, 14 → vEB 6, 13, 14
  |
  gap: |md
    ## The Gap Explained
    After vEB index 3, the next indices are **7, 8, 9** (not 4, 5, 6).
    This gap occurs because:
    1. Top subtree uses vEB 0-2
    2. First bottom subtree root (BFS 3) uses vEB 3
    3. First bottom subtree children (BFS 7, 8) use vEB 7, 8
    **vEB 4, 5, 6 are reserved for other bottom subtree roots** (BFS 4, 5, 6).
    This ensures each subtree's nodes are **contiguous in memory**.
  |
  split -> bottom -> gap
}
# Memory Layout Visualization
memory_layout: {
  label: Memory Layout (vEB Order)
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  slot_0: "0" {style.fill: "#B8D4E8"; width: 50}
  slot_1: "1" {style.fill: "#C5DDF0"; width: 50}
  slot_2: "2" {style.fill: "#C5DDF0"; width: 50}
  slot_3: "3" {style.fill: "#FAD7A0"; width: 50}
  slot_4: "4" {style.fill: "#ABEBC6"; width: 50}
  slot_5: "5" {style.fill: "#ABEBC6"; width: 50}
  slot_6: "6" {style.fill: "#ABEBC6"; width: 50}
  slot_7: "7" {style.fill: "#DFEFFC"; width: 50}
  slot_8: "8" {style.fill: "#DFEFFC"; width: 50}
  slot_9: "9" {style.fill: "#DFEFFC"; width: 50}
  ellipsis: "..." {shape: text; style.font-size: 16}
  slot_0 -> slot_1 -> slot_2 -> slot_3 -> slot_4 -> slot_5 -> slot_6 -> slot_7 -> slot_8 -> slot_9 -> ellipsis: {style.stroke: "#CCCCCC"}
  top_brace: "Top Subtree" {shape: text; style.font-size: 12; style.font-color: "#2E86AB"}
  bottom_brace: "Bottom Roots" {shape: text; style.font-size: 12; style.font-color: "#27AE60"}
  top_brace -> slot_0: {style.stroke: "transparent"}
  bottom_brace -> slot_4: {style.stroke: "transparent"}
}
# Legend
legend: {
  label: Legend
  style.fill: "#FFFFFF"
  style.stroke: "#CCCCCC"
  top_node: {shape: circle; width: 20; height: 20; style.fill: "#B8D4E8"}
  top_label: "Top subtree nodes" {shape: text}
  top_node -> top_label: {style.stroke: "transparent"}
  bottom_root: {shape: circle; width: 20; height: 20; style.fill: "#FAD7A0"}
  bottom_root_label: "Bottom subtree roots" {shape: text}
  bottom_root -> bottom_root_label: {style.stroke: "transparent"}
  contig: {shape: circle; width: 20; height: 20; style.fill: "#ABEBC6"}
  contig_label: "Nodes stored contiguously" {shape: text}
  contig -> contig_label: {style.stroke: "transparent"}
  top_node -> bottom_root -> contig: {style.opacity: 0}
}
# Connections between sections
tree_visual -> explanation: {style.stroke: "transparent"}
explanation -> memory_layout: {style.stroke: "transparent"}
memory_layout -> legend: {style.stroke: "transparent"}