direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Cache Access Pattern: vEB vs Pointer BST
  Side-by-side comparison of cache lines touched during search operations.
  *Intel Optimization Reference Manual Style*
| {near: top-center; shape: text}

veb_side: "Van Emde Boas Layout (Cache-Oblivious)" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    double-border: true
  }

  veb_label: |md
    ### vEB Search Efficiency
    **3-4 Cache Lines (CL) per Search**
    Recursive subtrees fit contiguously:
    - `H = log N` levels
    - `√N` subtrees stored as contiguous units
    - **High spatial locality**: Prefetcher (L2/L3) identifies stride.
  | {shape: text}

  veb_memory: "Physical Memory Layout (Contiguous)" {
    grid-columns: 1
    grid-gap: 0

    header: "Offset | Data Segment | Cache Line Boundary" {
      style.font: mono
      style.bold: true
      style.stroke-width: 0
    }

    cl0: "0x00 | [Root] [L1] [L2] [L3] [L4] [L5] [L6] | CL_0" {
      style: {
        fill: "#81C784"
        font: mono
        stroke-dash: 5
      }
    }
    cl1: "0x40 | [L7] [L8] [L9] [L10] [L11] [L12] [L13] | CL_1" {
      style: {
        fill: "#81C784"
        font: mono
        stroke-dash: 5
      }
    }
    cl2: "0x80 | [R_Sub_A] [1] [2] [3] [4] [5] [6] | CL_2" {
      style: {
        fill: "#A5D6A7"
        font: mono
        stroke-dash: 5
      }
    }
    cl3: "0xC0 | [R_Sub_B] [1] [2] [3] [4] [5] [6] | CL_3" {
      style: {
        fill: "#A5D6A7"
        font: mono
        stroke-dash: 5
      }
    }
  }

  veb_trace: "L1/L2 Cache Line Search Trace" {
    style.fill: "#C8E6C9"
    cl_hit1: "1. Load CL_0: Root Found" {
      style.fill: "#2E7D32"
      style.font-color: white
    }
    cl_hit2: "2. Stride CL_1: Child Found" {
      style.fill: "#2E7D32"
      style.font-color: white
    }
    cl_hit3: "3. Branch to CL_2: Leaf Found" {
      style.fill: "#43A047"
      style.font-color: white
    }
    
    cl_hit1 -> cl_hit2: "Sequential Stride"
    cl_hit2 -> cl_hit3: "Spatial Locality Hit"
  }
}

pointer_side: "Pointer-Based BST (Standard Heap)" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    double-border: true
  }

  ptr_label: |md
    ### Pointer BST Inefficiency
    **~20 Cache Lines (CL) per Search**
    Nodes scattered across DRAM pages:
    - 1 Cache Miss per Tree Level
    - **Pointer Chasing**: CPU Pipeline Stalls (300+ cycles)
    - **TLB Pressure**: Random virtual memory translations.
  | {shape: text}

  ptr_memory: "Physical Memory Layout (Fragmented)" {
    style.fill: "#FFCDD2"
    
    node_a: "Node Root @0x1A40 (CL_X)" {
      shape: rectangle
      style.fill: "#EF5350"
      style.font: mono
    }
    node_b: "Node Child @0x8B80 (CL_Y)" {
      shape: rectangle
      style.fill: "#EF5350"
      style.font: mono
    }
    node_c: "Node Leaf @0x4DC0 (CL_Z)" {
      shape: rectangle
      style.fill: "#EF5350"
      style.font: mono
    }

    node_a -> node_b: "Pointer Deref (MISS)" {style.stroke: "#B71C1C"; style.stroke-dash: 5}
    node_b -> node_c: "Pointer Deref (MISS)" {style.stroke: "#B71C1C"; style.stroke-dash: 5}
  }

  ptr_access: "Heap Cache Miss Trace" {
    grid-columns: 5
    grid-gap: 5
    
    pcl1: "CL_1" {style.fill: "#E53935"; style.font-color: white}
    pcl2: "CL_2" {style.fill: "#E53935"; style.font-color: white}
    pcl3: "CL_3" {style.fill: "#E53935"; style.font-color: white}
    pcl4: "CL_4" {style.fill: "#E53935"; style.font-color: white}
    pcl5: "CL_5" {style.fill: "#E53935"; style.font-color: white}
    pcl6: "CL_6" {style.fill: "#F44336"; style.font-color: white}
    pcl7: "CL_7" {style.fill: "#F44336"; style.font-color: white}
    pcl8: "CL_8" {style.fill: "#F44336"; style.font-color: white}
    pcl9: "CL_9" {style.fill: "#F44336"; style.font-color: white}
    pcl10: "CL_10" {style.fill: "#F44336"; style.font-color: white}
    
    pcl11: "..." {shape: text}
    pcl12: "CL_20" {
      style.fill: "#FFCDD2"
      style.font-color: "#B71C1C"
      style.bold: true
    }
    
    # Corrected filler labels to avoid empty text error
    pcl13: "Stall_1" {style.opacity: 0.3}
    pcl14: "Stall_2" {style.opacity: 0.3}
    pcl15: "Stall_3" {style.opacity: 0.3}
  }
}

# Metrics comparison
veb_side <-> pointer_side: |md
  **Latency Comparison (1M Nodes)**
  vEB Search: ~120ns (Cache Optimized)
  BST Search: ~840ns (Pointer Chasing)
  **Result: 7x Speedup**
| {
  style.stroke: "#1565C0"
  style.stroke-width: 4
  style.font-color: "#0D47A1"
  style.bold: true
}

summary: {
  shape: text
  label: |md
    ### System Architect's Key Insight
    **vEB (Van Emde Boas)** layouts eliminate the "pointer chasing" bottleneck by aligning the data structure topology with hardware cache line boundaries (typically 64B). 
    - **vEB Advantage**: L1/L2 Prefetchers successfully predict subsequent node accesses because they are spatially adjacent in memory.
    - **Pointer Penalty**: In standard BSTs, every pointer dereference effectively stalls the CPU pipeline for ~200-300 cycles as it waits for a main memory (DRAM) fetch, bypassing the L1/L2/L3 hierarchy.
  |
  near: bottom-center
}