direction: right
layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9C27B0"
    data: "#2196F3"
    hit: "#4CAF50"
    miss: "#FF9800"
    padding: "#9E9E9E"
    pointer: "#FF5722"
    cl_hit: "#C8E6C9"
    cl_miss: "#FFF9C4"
    mem_bg: "#ECEFF1"
  }
}

title: |'md
# Trace Example: vEB Tree Search
**Target: key 750,000 in 1M node tree (height 20)**
*Demonstrating O(log_B N) memory efficiency via Cache-Oblivious Layout*
'|
title.shape: text
title.near: top-center

# -----------------------------------------------------------------------------------------
# 1. Tree Structure Overview
# -----------------------------------------------------------------------------------------
tree_structure: {
  label: "Logical Structure: Van Emde Boas Layout"
  style: {
    stroke-width: 2
    border-radius: 10
  }
  
  level_info: {
    shape: text
    label: |'md
### BFS to vEB Mapping
| Level | Nodes | BFS Index Range | vEB Cluster |
|-------|-------|-----------------|-------------|
| 0     | 1     | 0               | Top [0]     |
| 1-9   | 511   | 1-511           | Top [1..1022] |
| 10-19 | 524,288 | 512-524,799   | Bottom [0..1023] |
'|
  }

  top_subtree: "Top Subtree Cluster (H=10)\nSize: 1,023 nodes (4,092 bytes)\n~64 Cache Lines" {
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      double-border: true
    }
  }
  
  bottom_subtrees: "1,024 Bottom Subtrees (H=10 each)\nSize: 1,023 nodes each\nTotal: 1,047,552 nodes" {
    style: {
      fill: "#F3E5F5"
      stroke: "#4A148C"
      multiple: true
    }
  }
  
  top_subtree -> bottom_subtrees: "Recursively applied layout" {
    style: {
      stroke-dash: 5
      stroke: "#4A148C"
    }
  }
}

# -----------------------------------------------------------------------------------------
# 2. Search Path Trace (Algorithm State)
# -----------------------------------------------------------------------------------------
search_trace: {
  label: "Search Path Execution (Key 750,000)"
  style.border-radius: 10
  
  step_1: {
    label: "S1: Level 0 (Root)"
    tooltip: "Cold start - DRAM Latency ~100ns"
    content: |'md
**BFS Index**: 0
**vEB Offset**: 0
**Compare**: 750,000 > 524,287
**Action**: **RIGHT**
'|
    content.shape: text
    style: {
      fill: ${colors.cl_miss}
      stroke: "#FBC02D"
      stroke-width: 3
    }
  }

  step_2: {
    label: "S2: Level 1"
    tooltip: "Cache Hit - Latency ~1ns"
    content: |'md
**BFS Index**: 2
**vEB Offset**: 2
**Compare**: 750,000 < 786,431
**Action**: **LEFT**
'|
    content.shape: text
    style: {
      fill: ${colors.cl_hit}
      stroke: "#2E7D32"
    }
  }

  step_3: {
    label: "S3: Level 2"
    content: |'md
**BFS Index**: 5
**vEB Offset**: 5
**Compare**: 750,000 > 655,359
**Action**: **RIGHT**
'|
    content.shape: text
    style: {
      fill: ${colors.cl_hit}
      stroke: "#2E7D32"
    }
  }

  step_4: {
    label: "S4-S10: Top Cluster Completion"
    content: |'md
- Levels 3 to 9
- All indices in range [0..1022]
- **Contiguous in memory**
- **0 New Cache Misses**
'|
    content.shape: text
    style: {
      fill: "#A5D6A7"
      stroke: "#1B5E20"
    }
  }

  step_5: {
    label: "S11: Jump to Subtree"
    tooltip: "Mandatory DRAM Access"
    content: |'md
**Subtree ID**: 750
**vEB Base**: 1,023 + (750 * 1,023)
**Pointer**: `&keys[768273]`
**Action**: **Reload Cache Line**
'|
    content.shape: text
    style: {
      fill: ${colors.cl_miss}
      stroke: "#FBC02D"
      stroke-width: 3
    }
  }

  step_6: {
    label: "S12-S20: Final Search"
    content: |'md
- Search within Subtree 750
- Contiguous Block in Memory
- **Result**: Found 750,000
'|
    content.shape: text
    style: {
      fill: "#81C784"
      bold: true
      stroke: "#2E7D32"
    }
  }

  step_1 -> step_2: "BFS Index 0 -> 2"
  step_2 -> step_3: "BFS Index 2 -> 5"
  step_3 -> step_4: "Spatial Locality Hit"
  step_4 -> step_5: "Cluster Exit (Offset 1022 -> 768273)" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 4
      animated: true
    }
  }
  step_5 -> step_6: "Final Ascent"
}

# -----------------------------------------------------------------------------------------
# 3. Memory Layout & Cache Lines
# -----------------------------------------------------------------------------------------
memory_layout: {
  label: "Memory Layout Analysis (4-byte keys)"
  style.border-radius: 10
  
  # Byte Offsets visualization using SQL table for alignment
  address_space: {
    shape: sql_table
    "0x0000": "Root Node (vEB Offset 0)" {constraint: "CL 0 Start"}
    "0x0040": "Nodes [16..31]" {constraint: "CL 1 Start"}
    "0x03C0": "Nodes [960..975]" {constraint: "CL 60 Start"}
    "0x0FFC": "End of Top Cluster" {constraint: "4B Padding"}
    "0x1000": "Subtree 0, Root" {constraint: "Page/CL 64"}
    "0x1FFC": "Subtree 1, Root" {constraint: "Offset 2046"}
    style.fill: ${colors.mem_bg}
  }

  cl_viz: {
    label: "Cache Line Residency"
    
    top_cluster_cl: "Top Subtree Block (L1 Resident After S1)" {
      cl_0: "Cache Line 0\nNodes [0..15]" { style.fill: "#FFECB3" }
      cl_1: "Cache Line 1\nNodes [16..31]" { style.fill: "#C8E6C9" }
      cl_dots: "..." { shape: text }
      cl_63: "Cache Line 63\nNodes [1008..1022]" { style.fill: "#C8E6C9" }
      
      cl_0 -> cl_1 -> cl_dots -> cl_63
    }

    bottom_cluster_n: "Bottom Subtree Cluster 750" {
      bcl_0: "CL 48064\nSubtree Root" { style.fill: "#FFECB3" }
      bcl_1: "CL 48065\nChildren" { style.fill: "#C8E6C9" }
      bcl_dots: "..." { shape: text }
      
      bcl_0 -> bcl_1 -> bcl_dots
    }

    top_cluster_cl -> bottom_cluster_n: "DRAM Transaction Required" {
      style: {
        stroke: "#FF5722"
        stroke-width: 4
        animated: true
      }
    }
  }
}

# -----------------------------------------------------------------------------------------
# 4. Comparative Analysis
# -----------------------------------------------------------------------------------------
cache_analysis: {
  label: "Performance Metrics: vEB vs. Pointer BST"
  grid-columns: 2

  veb_stats: {
    label: "vEB Layout (Cache-Oblivious)"
    info: |'md
### Efficiency
- **Search Depth**: 20 levels
- **Worst-Case Misses**: $\approx 4 \times \log_B N$
- **Actual Trace**: 2 Cache Misses
- **Spatial Locality**: 100% within clusters
'|
    info.shape: text
    style: {
      fill: "#E3F2FD"
      stroke: "#1E88E5"
      border-radius: 8
    }
  }

  pointer_stats: {
    label: "Standard Pointer BST (Heap)"
    info: |'md
### Efficiency
- **Search Depth**: 20 levels
- **Worst-Case Misses**: 20 (1 per level)
- **Actual Trace**: 18-20 Cache Misses
- **Spatial Locality**: 0% (Random Heap)
'|
    info.shape: text
    style: {
      fill: "#FFEBEE"
      stroke: "#E53935"
      border-radius: 8
    }
  }
}

# -----------------------------------------------------------------------------------------
# 5. Key Insight
# -----------------------------------------------------------------------------------------
insight: {
  label: "Final Technical Summary"
  content: |'md
## The vEB Implementation Advantage
By grouping nodes into subtrees that fit exactly into cache lines or memory pages:
- **Reduced DRAM Latency**: By packing $\sqrt{N}$ subtrees contiguously, we reduce the number of times the CPU waits for data from main memory.
- **Cache Line Utilization**: Standard BSTs waste ~60 bytes of a 64-byte fetch. vEB uses nearly 100% of the fetched cache line for path traversal.
- **Complexity**: Total Memory Transfers $W \approx \log_B N$, significantly outperforming $O(\log_2 N)$.
'|
  content.shape: text
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    fill: "#F1F8E9"
    border-radius: 12
  }
}

insight.near: bottom-center