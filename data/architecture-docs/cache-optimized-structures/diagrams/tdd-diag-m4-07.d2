vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "B-Tree Node: Cache Line Packing (64 bytes)" {
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Main cache line visualization
cache_line: {
  label: "B-Tree Node (64-byte cache line)"
  style: {
    fill: "#E8F4FD"
    stroke: "#2563EB"
    stroke-width: 3
    border-radius: 8
  }
  # Keys section (14 keys × 4 bytes = 56 bytes)
  keys_section: {
    label: "Keys (14 × 4 bytes = 56 bytes)"
    style.fill: "#DBEAFE"
    grid-columns: 7
    grid-gap: 2
    k0: "k₀" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k1: "k₁" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k2: "k₂" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k3: "k₃" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k4: "k₄" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k5: "k₅" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k6: "k₆" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k7: "k₇" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k8: "k₈" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k9: "k₉" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k10: "k₁₀" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k11: "k₁₁" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k12: "k₁₂" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k13: "k₁₃" { style: { fill: "#93C5FD"; stroke: "#1D4ED8"; font: mono; font-size: 14 } }
    k_unused: "..." { style: { fill: "#E5E7EB"; stroke: "#9CA3AF"; font: mono; font-size: 14 } }
  }
  # Pointer section (simplified - shown as compact row)
  pointers_section: {
    label: "Child Pointers (15 × 4 bytes = 60 bytes, stored separately)"
    style.fill: "#FEF3C7"
    grid-columns: 5
    grid-gap: 2
    p0: "p₀" { style: { fill: "#FCD34D"; stroke: "#D97706"; font: mono; font-size: 14 } }
    p1: "p₁" { style: { fill: "#FCD34D"; stroke: "#D97706"; font: mono; font-size: 14 } }
    p2: "p₂" { style: { fill: "#FCD34D"; stroke: "#D97706"; font: mono; font-size: 14 } }
    p3: "p₃" { style: { fill: "#FCD34D"; stroke: "#D97706"; font: mono; font-size: 14 } }
    p4: "..." { style: { fill: "#E5E7EB"; stroke: "#9CA3AF"; font: mono; font-size: 14 } }
    p5: "p₁₄" { style: { fill: "#FCD34D"; stroke: "#D97706"; font: mono; font-size: 14 } }
  }
}
# Byte offset annotation
byte_offsets: {
  near: top-right
  label: |md
    **Byte Layout:**
    
    Offset  Size    Field
    ─────────────────────
    0x00    4       k₀
    0x04    4       k₁
    0x08    4       k₂
    ...
    0x34    4       k₁₃
    ─────────────────────
    Total: 56 bytes
    (keys only)
    
  |
  style: {
    fill: "#F9FAFB"
    stroke: "#9CA3AF"
    font: mono
    font-size: 12
  }
}
# Comparison with binary tree
comparison: {
  near: bottom-center
  label: "Cache Efficiency Comparison"
  binary_tree: {
    label: "Binary Tree Node"
    style.fill: "#FEE2E2"
    bt_layout: |md
      
      ┌─────────────────┐
      │ key  (4 bytes)  │
      ├─────────────────┤
      │ pad  (4 bytes)  │
      ├─────────────────┤
      │ left (8 bytes)  │
      ├─────────────────┤
      │ right(8 bytes)  │
      └─────────────────┘
      24 bytes/node
      1 cache miss = 1 comparison
      
    |
  }
  btree_node: {
    label: "B-Tree Node (B=16)"
    style.fill: "#DCFCE7"
    bt_layout: |md
      
      ┌─────────────────┐
      │ k₀│k₁│...│k₁₃  │
      │  56 bytes       │
      └─────────────────┘
      1 cache miss = 14 comparisons!
      
    |
  }
  binary_tree -> btree_node: "14× more efficient" {
    style: {
      stroke: "#16A34A"
      stroke-width: 3
      animated: true
    }
  }
}
# Key insight box
insight: {
  near: bottom-right
  label: |md
    **Key Insight**
    One cache miss loads 64 bytes.
    - Binary tree: 1 key loaded
    - B-tree: 14 keys loaded
    **14 comparisons per cache miss**
    vs **1 comparison per cache miss**
    B-tree height reduced from log₂(n)
    to log₁₆(n) = log₂(n) / 4
  |
  style: {
    fill: "#ECFDF5"
    stroke: "#059669"
    stroke-width: 2
    border-radius: 8
    font-size: 14
  }
}