vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- GLOBAL STYLES & CLASSES ---
classes: {
  node_valid: {
    style: {
      fill: "#007bff"
      stroke: "#0056b3"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  node_padding: {
    style: {
      fill: "#adb5bd"
      stroke: "#6c757d"
      stroke-dash: 4
      opacity: 0.6
    }
  }
  header_purple: {
    style: {
      fill: "#6f42c1"
      font-color: white
      bold: true
    }
  }
  container_box: {
    style: {
      stroke-width: 2
      border-radius: 8
      fill: "#ffffff"
      shadow: true
    }
  }
  address_label: {
    shape: text
    style: {
      font: mono
      font-size: 11
      font-color: "#495057"
    }
  }
}

title: {
  label: ||md
    # Non-Power-of-Two Tree Handling in vEB Layout
    **Technical Specification for Memory Alignment and Cache Optimization**
    *Version: 1.0.4 | Intel-Manual Standard*
  ||
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}

# --- ARCHITECTURE SPECIFICATION ---
NodeStruct: {
  shape: sql_table
  class: header_purple
  label: "struct veb_node_t"
  
  id: "uint32_t" {constraint: "4 bytes"}
  data_ptr: "void*" {constraint: "8 bytes"}
  metadata: "uint32_t" {constraint: "4 bytes"}
  
  footer: "sizeof = 16 bytes (Aligned to 16B boundary)"
}

# --- 1. ORIGINAL PROBLEM DEFINITION ---
original: {
  label: "INPUT STATE: N=10 Sparse Nodes"
  class: container_box
  style.fill: "#f8f9fa"

  tree_viz: {
    grid-columns: 5
    grid-gap: 15
    
    n0: "Node 0" { class: node_valid }
    n1: "Node 1" { class: node_valid }
    n2: "Node 2" { class: node_valid }
    n3: "Node 3" { class: node_valid }
    n4: "Node 4" { class: node_valid }
    n5: "Node 5" { class: node_valid }
    n6: "Node 6" { class: node_valid }
    n7: "Node 7" { class: node_valid }
    n8: "Node 8" { class: node_valid }
    n9: "Node 9" { class: node_valid }
  }

  specs: {
    label: |md
      ### Tree Topology Constraints
      - **Target Height (H):** 4
      - **Full Capacity (2^H - 1):** 15 slots required
      - **Utilization:** 10 / 15 nodes (~66.6%)
      "- **Missing Indices": "** [10, 11, 12, 13, 14]"
    |
    shape: text
  }
}

# --- 2. OPTION A: FULL RECURSIVE PADDING (RELIABLE) ---
padding_layout: {
  label: "Option A: Power-of-Two Recursive Padding"
  class: container_box
  style.fill: "#e3f2fd"

  mem_array: {
    label: "vEB Memory Array [0...14] - 240B Total"
    grid-columns: 15
    grid-gap: 0
    
    p0: "0" { class: node_valid; width: 45 }
    p1: "1" { class: node_valid; width: 45 }
    p2: "2" { class: node_valid; width: 45 }
    p3: "3" { class: node_valid; width: 45 }
    p4: "4" { class: node_valid; width: 45 }
    p5: "5" { class: node_valid; width: 45 }
    p6: "6" { class: node_valid; width: 45 }
    p7: "7" { class: node_valid; width: 45 }
    p8: "8" { class: node_valid; width: 45 }
    p9: "9" { class: node_valid; width: 45 }
    p10: "NULL" { class: node_padding; width: 45 }
    p11: "NULL" { class: node_padding; width: 45 }
    p12: "NULL" { class: node_padding; width: 45 }
    p13: "NULL" { class: node_padding; width: 45 }
    p14: "NULL" { class: node_padding; width: 45 }
  }

  byte_offsets: {
    o0: "0x000" { class: address_label }
    o1: "0x040" { class: address_label }
    o2: "0x090" { class: address_label }
    o3: "0x0E0" { class: address_label }
    
    o0 -> mem_array.p0
    o1 -> mem_array.p4
    o2 -> mem_array.p9
    o3 -> mem_array.p14
  }

  analysis: {
    label: |md
      ### Implementation Details
      - **Allocation:** `malloc(sizeof(Node) * 15)`
      - **Logic:** Static index math: 'O(1)' address generation
      - **Pros:** No bounds checks in inner loops
      - **Cache:** Perfect alignment for subtrees
    |
    shape: text
  }
}

# --- 3. OPTION B: STRICT BOUNDARY MAPPING ---
incomplete: {
  label: "Option B: Strict Boundary Mapping"
  class: container_box
  style.fill: "#fff3e0"

  mem_layout: {
    label: "Compact Memory Array [0...9] - 160B Total"
    grid-columns: 10
    grid-gap: 0
    i0: "0" { class: node_valid; width: 45 }
    i1: "1" { class: node_valid; width: 45 }
    i2: "2" { class: node_valid; width: 45 }
    i3: "3" { class: node_valid; width: 45 }
    i4: "4" { class: node_valid; width: 45 }
    i5: "5" { class: node_valid; width: 45 }
    i6: "6" { class: node_valid; width: 45 }
    i7: "7" { class: node_valid; width: 45 }
    i8: "8" { class: node_valid; width: 45 }
    i9: "9" { class: node_valid; width: 45 }
  }

  analysis: {
    label: |md
      ### Implementation Details
      - **Allocation:** `malloc(sizeof(Node) * 10)`
      - **Logic:** Requires logical-to-physical mapping LUT
      - **Cons:** Performance penalties on traversal
      - **Waste:** 0 Bytes, but high CPU overhead
    |
    shape: text
  }
}

# --- 4. COMPARISON MATRIX ---
comparison_table: {
  grid-columns: 4
  grid-gap: 0
  style.stroke: "#333333"

  # Row 0: Headers
  c00: "Metric" { class: header_purple }
  c01: "Full Padding" { class: header_purple }
  c02: "Incomplete" { class: header_purple }
  c03: "Hybrid vEB" { class: header_purple }

  # Row 1: Size
  c10: "Mem Footprint"
  c11: "240 Bytes"
  c12: "160 Bytes"
  c13: "160 Bytes"

  # Row 2: Logic
  c20: "Traversal Math"
  c21: "Bitwise Shift"
  c22: "Bounds Check"
  c23: "LUT + Shift"

  # Row 3: Cache
  c30: "Cache Locality"
  c31: "Deterministic"
  c32: "Non-Linear"
  c33: "Optimal (L1)"
}

# --- 5. IMPLEMENTATION LOGIC ---
implementation_logic: {
  label: |cpp
    /**
     * Intel-Optimized vEB Pointer Calculation
     * Handling Non-Power-of-Two subtrees via Virtual Padding
     */
    inline void* veb_get_child(veb_node_t* base, uint32_t idx) {
        // Fast log2 calculation using compiler intrinsics
        // '31 - __builtin_clz(idx + 1)'
        uint32_t h = 31 - __builtin_clz(idx + 1); 
        
        // Calculate byte offset: index * 16-byte stride
        uint64_t offset = (uint64_t)idx << 4;
        return (void*)((char*)base + offset);
    }
  |
  shape: code
}

# --- 6. ARCHITECTURAL RECOMMENDATION ---
recommendation: {
  style: {
    fill: "#e8f5e9"
    double-border: true
  }
  
  text_content: {
    label: |md
      ### Final Recommendation
      1. **Small Trees (N < 1024):** Use **Full Padding**. Memory waste is trivial and performance is ~2.4x higher.
      2. **Massive Trees (N > 1M):** Use **Incomplete subtrees** at top levels to save GBs, but switch to **Full Padding** for leaf subtrees to ensure L1 Cache line alignment.
    |
    shape: text
  }
}

# --- CONNECTIONS ---
original -> padding_layout: "Allocation Path A"
original -> incomplete: "Allocation Path B"

padding_layout -> comparison_table
incomplete -> comparison_table

comparison_table -> recommendation
recommendation -> implementation_logic

# --- LEGEND ---
legend: {
  near: bottom-right
  class: container_box
  
  l1: "Valid Node" { class: node_valid }
  l2: "Padding Slot" { 
    label: "NULL / PAD"
    class: node_padding 
  }
  l3: "Memory Offset" {
    shape: text
    style.font: mono
  }
}