direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT LEVEL ANNOTATIONS ---

title: |'md
  # Cache Miss Count: Tree Size Scaling
  Log-log plot showing cache misses vs tree size (N)
'|
title.near: top-center

# Legend positioned at top-right
legend: {
  near: top-right
  style.fill: "#FFFFFF"
  style.stroke: "#D1D5DB"
  style.border-radius: 4
  
  veb_legend: "vEB Layout: O(log_B N) ≈ log₁₆(N)" {
    shape: text
    style.font-color: "#2E86AB"
    style.bold: true
  }
  bfs_legend: "BFS Array: O(log N)" {
    shape: text
    style.font-color: "#A23B72"
    style.bold: true
  }
  ptr_legend: "Pointer BST: O(log N)" {
    shape: text
    style.font-color: "#F18F01"
    style.bold: true
  }
  note: |'md
    **B = 16 keys per cache line**
    vEB achieves cache-optimal scaling
  '|
  note.style.font-size: 12
  note.style.font-color: "#6B7280"
}

# Formula box positioned at bottom-left
formula: {
  near: bottom-left
  style.fill: "#F9FAFB"
  style.stroke: "#9CA3AF"
  style.border-radius: 4
  
  content: |'md
    **Cache Complexity Formulas:**
    - vEB: `O(log_B N)` where B = keys/cache-line
    - BFS/Pointer: `O(log N)`
    
    **Numerical Example (B=16, N=10⁶):**
    - vEB: log₁₆(10⁶) ≈ **5 misses**
    - BFS: log₂(10⁶) ≈ **20 misses**
  '|
  content.shape: text
  content.style.font-size: 11
  content.style.font: mono
}

# --- MAIN VISUALIZATION AREA ---

chart: {
  style.fill: "#FAFAFA"
  style.stroke: "#1F2937"
  style.stroke-width: 2
  
  # Axis Labels (Internal to chart container - No 'near' allowed)
  y_axis: {
    shape: text
    style.font-size: 12
    style.bold: true
    label: "Cache Misses (Log Scale)"
  }
  
  y_scale: |'md
    10²
    |
    10³
    |
    10⁴
    |
    10⁵
    |
    10⁶
  '|
  y_scale.shape: text
  y_scale.style.font: mono
  y_scale.style.font-size: 10

  x_axis: {
    shape: text
    style.font-size: 12
    style.bold: true
    label: "Tree Size N (Log Scale)"
  }
  
  x_scale: |'md
    10³    10⁴    10⁵    10⁶    10⁷
  '|
  x_scale.shape: text
  x_scale.style.font: mono
  x_scale.style.font-size: 10

  # Curves defined by coordinate points
  # p = vEB, b = BFS, t = Pointer
  
  veb_curve: {
    style.stroke: "#2E86AB"
    style.stroke-width: 4
    style.fill: transparent
    p1: {shape: circle; width: 10; style.fill: "#2E86AB"}
    p2: {shape: circle; width: 10; style.fill: "#2E86AB"}
    p3: {shape: circle; width: 10; style.fill: "#2E86AB"}
    p4: {shape: circle; width: 10; style.fill: "#2E86AB"}
    p5: {shape: circle; width: 10; style.fill: "#2E86AB"}
    
    p1 -> p2 -> p3 -> p4 -> p5: {style.stroke: "#2E86AB"; style.stroke-width: 4}
  }
  
  bfs_curve: {
    style.stroke: "#A23B72"
    style.stroke-width: 4
    style.fill: transparent
    b1: {shape: circle; width: 10; style.fill: "#A23B72"}
    b2: {shape: circle; width: 10; style.fill: "#A23B72"}
    b3: {shape: circle; width: 10; style.fill: "#A23B72"}
    b4: {shape: circle; width: 10; style.fill: "#A23B72"}
    b5: {shape: circle; width: 10; style.fill: "#A23B72"}
    
    b1 -> b2 -> b3 -> b4 -> b5: {style.stroke: "#A23B72"; style.stroke-width: 4}
  }
  
  ptr_curve: {
    style.stroke: "#F18F01"
    style.stroke-width: 4
    style.fill: transparent
    t1: {shape: circle; width: 10; style.fill: "#F18F01"}
    t2: {shape: circle; width: 10; style.fill: "#F18F01"}
    t3: {shape: circle; width: 10; style.fill: "#F18F01"}
    t4: {shape: circle; width: 10; style.fill: "#F18F01"}
    t5: {shape: circle; width: 10; style.fill: "#F18F01"}
    
    t1 -> t2 -> t3 -> t4 -> t5: {style.stroke: "#F18F01"; style.stroke-width: 4}
  }
}

# --- SUPPORTING DATA & INSIGHTS ---

# Data table positioned at bottom-right
data_table: {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#D1D5DB"
  style.border-radius: 4
  
  header: |'md
    | N | vEB | BFS | Pointer |
    |---|-----|-----|---------|
  '|
  header.shape: text
  header.style.font: mono
  header.style.font-size: 11

  rows: |'md
    | 10³ | 3 | 10 | 20 |
    | 10⁴ | 4 | 14 | 28 |
    | 10⁵ | 5 | 17 | 34 |
    | 10⁶ | 5 | 20 | 40 |
    | 10⁷ | 6 | 23 | 46 |
  '|
  rows.shape: text
  rows.style.font: mono
  rows.style.font-size: 11

  caption: |'md
    **Observed Cache Misses (N=1M):**
    - vEB: **5** (Optimal log₁₆ N)
    - BFS: **20** (Standard log₂ N)
    - Pointer: **40** (Pointers ruin locality)
  '|
  caption.shape: text
  caption.style.font-size: 11
  caption.style.font-color: "#374151"
}

# High-level insight box
insight: {
  near: top-left
  style.fill: "#EFF6FF"
  style.stroke: "#2563EB"
  style.border-radius: 8
  
  title: "**Architectural Advantage**" {
    shape: text
    style.font-size: 13
    style.bold: true
    style.font-color: "#1E40AF"
  }
  
  content: |'md
    vEB layout achieves **O(log_B N)** 
    cache complexity *cache-obliviously*.
    - Optimal across L1/L2/L3/TLB simultaneously
    - No hardware parameters required in code
    - **4x - 8x performance boost** over pointers
  '|
  content.shape: text
  content.style.font-size: 11
}

# Mathematical slope indicators
slope_annotation: {
  near: center-right
  
  veb_slope: |'md
    **Slope = 1/log₂(B) = 0.25**
    (Ideal scaling)
  '|
  veb_slope.shape: text
  veb_slope.style.font-size: 10
  veb_slope.style.font-color: "#2E86AB"

  other_slope: |'md
    **Slope = 1.0**
    (Logarithmic scaling)
  '|
  other_slope.shape: text
  other_slope.style.font-size: 10
  other_slope.style.font-color: "#A23B72"
}