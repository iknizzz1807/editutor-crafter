vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Naive Matrix Multiplication: Access Pattern Analysis
  **A[i,k] (Row-Major) × B[k,j] (Column-Major)**
  *Demonstrating Spatial Locality vs. Cache Striding*
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# Matrix A: Sequential Access (Spatial Locality)
# -----------------------------------------------------------------------------------------
matrix_a: {
  label: "Matrix A (M×K): Row-Major Storage"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 4

  row_label: |md
    ### Sequential Access (Stride = 1)
    - Loop Order: `for k in 0..K-1`
    - Address: `&A[i][k]`
    - Next Address: `&A[i][k] + sizeof(float)`
    - **Prefetcher Behavior:** Next cache line requested before needed.
  | {shape: text}

  row_i: "Active Row i" {
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    
    # Visualizing 16 floats (64 bytes)
    cells: {
      grid-columns: 16
      grid-gap: 2
      
      c0: "A[i,0]" {style.fill: "#90CAF9"; style.bold: true}
      c1: "A[i,1]" {style.fill: "#90CAF9"}
      c2: "A[i,2]" {style.fill: "#90CAF9"}
      c3: "A[i,3]" {style.fill: "#90CAF9"}
      c4: "..." {shape: text}
      c5: "..." {shape: text}
      c6: "..." {shape: text}
      c7: "..." {shape: text}
      c8: "..." {shape: text}
      c9: "..." {shape: text}
      c10: "..." {shape: text}
      c11: "..." {shape: text}
      c12: "..." {shape: text}
      c13: "..." {shape: text}
      c14: "..." {shape: text}
      c15: "A[i,15]" {style.fill: "#90CAF9"}
    }
    
    cells.c0 -> cells.c1 -> cells.c2 -> cells.c3: {style.stroke: "#0D47A1"; style.animated: true; style.stroke-width: 3}
  }

  cache_line_a: |md
    **Cache Status:**
    - 64B Cache Line fits 16 floats.
    - 1st access (A[i,0]): **Miss** (Loads 64B).
    - Next 15 accesses: **Hits**.
    - **Total: 1 Miss per 16 elements.**
  | {shape: text}
}

# -----------------------------------------------------------------------------------------
# Matrix B: Strided Access (Cache Hostile)
# -----------------------------------------------------------------------------------------
matrix_b: {
  label: "Matrix B (K×N): Column-Major Access"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 4

  col_label: |md
    ### Strided Access (Stride = N)
    - Loop Order: `for k in 0..K-1`
    - Address: `&B[k][j]`
    - Next Address: `&B[k][j] + (N * sizeof(float))`
    - **Stride:** 4096B (if N=1024)
    - **Prefetcher Behavior:** Triggers many page-boundary requests.
  | {shape: text}

  col_j: "Active Column j" {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    direction: down
    
    b0: "B[0,j]" {style.fill: "#EF9A9A"; style.bold: true}
    b1: "B[1,j]" {style.fill: "#EF9A9A"}
    b2: "B[2,j]" {style.fill: "#EF9A9A"}
    gap: "⋮ Stride Gap (N elements)" {shape: text; style.font-color: "#757575"}
    b15: "B[15,j]" {style.fill: "#EF9A9A"}
    
    b0 -> b1 -> b2 -> gap -> b15: {style.stroke: "#B71C1C"; style.animated: true; style.stroke-width: 3}
  }

  cache_lines_b: |md
    **Cache Status:**
    - Each access jumps far past the current Cache Line.
    - Every element (k=0, 1, 2...) is a **NEW Cache Miss**.
    - **Total: 16 Misses per 16 elements.**
  | {shape: text}
}

# -----------------------------------------------------------------------------------------
# Matrix C: Result Calculation
# -----------------------------------------------------------------------------------------
matrix_c: {
  label: "Matrix C (M×N): Output"
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  
  output_cell: {
    label: "C[i,j]"
    shape: square
    style.fill: "#A5D6A7"
    style.stroke: "#388E3C"
    style.bold: true
    width: 120
    height: 120
  }
  
  formula: |md
    ### Dot Product Formula
    `C[i,j] += A[i,k] * B[k,j]`
    *Requires K loads from A and K loads from B.*
  | {shape: text}
}

# Data Flow Connections
matrix_a.row_i.cells.c0 -> matrix_c.output_cell: "Fast (L1 Hit)" {style.stroke: "#1976D2"; style.stroke-width: 3}
matrix_b.col_j.b0 -> matrix_c.output_cell: "Slow (Memory/L3 Miss)" {style.stroke: "#C62828"; style.stroke-width: 3; style.stroke-dash: 5}

# -----------------------------------------------------------------------------------------
# Physical Cache Layout Visualization (Engineer Level Detail)
# -----------------------------------------------------------------------------------------
physical_memory: {
  label: "Physical DRAM to SRAM (Cache) Mapping"
  
  cl_good: {
    label: "Efficient Utilization (Matrix A)"
    cl_box: {
      grid-columns: 16
      grid-gap: 0
      # 64B Cache Line
      a0: "0B" {style.fill: "#BBDEFB"}
      a1: "4B" {style.fill: "#BBDEFB"}
      a2: "8B" {style.fill: "#BBDEFB"}
      a3: "12B" {style.fill: "#BBDEFB"}
      a4: "16B" {style.fill: "#BBDEFB"}
      a5: "20B" {style.fill: "#BBDEFB"}
      a6: "24B" {style.fill: "#BBDEFB"}
      a7: "28B" {style.fill: "#BBDEFB"}
      a8: "32B" {style.fill: "#BBDEFB"}
      a9: "36B" {style.fill: "#BBDEFB"}
      a10: "40B" {style.fill: "#BBDEFB"}
      a11: "44B" {style.fill: "#BBDEFB"}
      a12: "48B" {style.fill: "#BBDEFB"}
      a13: "52B" {style.fill: "#BBDEFB"}
      a14: "56B" {style.fill: "#BBDEFB"}
      a15: "60B" {style.fill: "#BBDEFB"}
    }
    desc: "1 Load = 16 floats. Utilization: 100% (All data used)" {shape: text}
  }

  cl_bad: {
    label: "Cache Pollution / Waste (Matrix B)"
    cl_box: {
      grid-columns: 16
      grid-gap: 0
      b0: "B[0,j]" {style.fill: "#EF9A9A"; style.bold: true}
      w1: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w2: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w3: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w4: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w5: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w6: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w7: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w8: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w9: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w10: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w11: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w12: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w13: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w14: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
      w15: "X" {style.fill: "#EEEEEE"; style.stroke-dash: 2}
    }
    desc: "1 Load = 1 float. Utilization: 6.25% (Remaining 60B evicted before use)" {shape: text}
  }
}

# -----------------------------------------------------------------------------------------
# Global Summary (Root Level Shape)
# -----------------------------------------------------------------------------------------
cache_comparison: {
  near: bottom-center
  label: ||md
    ## Cache Line Analysis Summary (K=1024)
    | Feature | Matrix A (Row-wise) | Matrix B (Column-wise) |
    | :--- | :--- | :--- |
    | **Spatial Locality** | High (1.0) | Zero (Stride N) |
    | **Cache Misses** | ~64 per dot product | ~1024 per dot product |
    | **DRAM Bandwidth** | Efficient (Burst Loads) | Inefficient (Random Access) |
    | **IPC Potential** | High (Vectorizable) | Low (Stalled on Memory) |
  ||
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    stroke-width: 4
    border-radius: 10
  }
}