layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
  }
}

# -----------------------------------------------------------------------------
# GLOBAL ANNOTATIONS & TITLE
# -----------------------------------------------------------------------------

title: {
  shape: text
  label: |md
    # Blocked Matrix Multiplication: Access Pattern
    **Block (I,J) of C computed from blocks A[I,K] and B[K,J]**
    *Optimization: Maximizing Temporal and Spatial Locality*
    *Hardware Target: L1D Cache (32KB, 8-way set associative)*
  |
  near: top-center
}

# -----------------------------------------------------------------------------
# RESOURCE SPECIFICATION (TABLE)
# -----------------------------------------------------------------------------

block_spec: {
  near: top-right
  shape: rectangle
  style: {
    fill: "#F1F8E9"
    stroke: "#388E3C"
    stroke-dash: 2
  }
  label: ||md
    ### Block Hierarchy (32×32)
    | Matrix | Elements | Precision | Total Size |
    | :--- | :--- | :--- | :--- |
    | **A[I,K]** | 1,024 | FP32 (4B) | **4,096 B** |
    | **B[K,J]** | 1,024 | FP32 (4B) | **4,096 B** |
    | **C[I,J]** | 1,024 | FP32 (4B) | **4,096 B** |
    | **Total** | 3,072 | | **12,288 B** |
    ---
    **L1D Capacity: 32,768 B**
    **Headroom: 20,480 B**
  ||
}

# -----------------------------------------------------------------------------
# SOURCE MATRICES
# -----------------------------------------------------------------------------

matrix_a: "Matrix A (M×K)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    double-border: true
  }
  
  grid-columns: 4
  grid-rows: 4
  grid-gap: 5
  
  a00: "a[0,0]" { style.fill: "#BBDEFB" }
  a01: "" { style.fill: "#BBDEFB" }
  a02: "" { style.fill: "#BBDEFB" }
  a03: "a[0,K-1]" { style.fill: "#BBDEFB" }
  
  a10: "" { style.fill: "#BBDEFB" }
  a_block: "A[I,K]\n(32x32 Block)" {
    style: {
      fill: "#1565C0"
      font-color: white
      bold: true
      shadow: true
    }
  }
  a12: "" { style.fill: "#BBDEFB" }
  a13: "" { style.fill: "#BBDEFB" }
  
  a20: "a[I,0]" { style.fill: "#BBDEFB" }
  a21: "" { style.fill: "#BBDEFB" }
  a22: "" { style.fill: "#BBDEFB" }
  a23: "" { style.fill: "#BBDEFB" }
  
  a30: "a[M-1,0]" { style.fill: "#BBDEFB" }
  a31: "" { style.fill: "#BBDEFB" }
  a32: "" { style.fill: "#BBDEFB" }
  a33: "a[M-1,K-1]" { style.fill: "#BBDEFB" }
}

math_ops: {
  style.stroke-width: 0
  direction: right
  mult: "⊗" {
    shape: text
    style.font-size: 60
  }
}

matrix_b: "Matrix B (K×N)" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    double-border: true
  }
  
  grid-columns: 4
  grid-rows: 4
  grid-gap: 5
  
  b00: "b[0,0]" { style.fill: "#C8E6C9" }
  b01: "" { style.fill: "#C8E6C9" }
  b02: "" { style.fill: "#C8E6C9" }
  b03: "b[0,N-1]" { style.fill: "#C8E6C9" }
  
  b10: "" { style.fill: "#C8E6C9" }
  b11: "" { style.fill: "#C8E6C9" }
  b_block: "B[K,J]\n(32x32 Block)" {
    style: {
      fill: "#2E7D32"
      font-color: white
      bold: true
      shadow: true
    }
  }
  b13: "" { style.fill: "#C8E6C9" }
  
  b20: "" { style.fill: "#C8E6C9" }
  b21: "" { style.fill: "#C8E6C9" }
  b22: "" { style.fill: "#C8E6C9" }
  b23: "" { style.fill: "#C8E6C9" }
  
  b30: "b[K-1,0]" { style.fill: "#C8E6C9" }
  b31: "" { style.fill: "#C8E6C9" }
  b32: "" { style.fill: "#C8E6C9" }
  b33: "b[K-1,N-1]" { style.fill: "#C8E6C9" }
}

math_ops_2: {
  style.stroke-width: 0
  eq: "=" {
    shape: text
    style.font-size: 60
  }
}

matrix_c: "Matrix C (M×N)" {
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    double-border: true
  }
  
  grid-columns: 4
  grid-rows: 4
  grid-gap: 5
  
  c00: "c[0,0]" { style.fill: "#FFE0B2" }
  c01: "" { style.fill: "#FFE0B2" }
  c02: "" { style.fill: "#FFE0B2" }
  c03: "c[0,N-1]" { style.fill: "#FFE0B2" }
  
  c10: "" { style.fill: "#FFE0B2" }
  c11: "" { style.fill: "#FFE0B2" }
  c_block: "C[I,J]\n(Accumulator)" {
    style: {
      fill: "#E65100"
      font-color: white
      bold: true
      shadow: true
    }
  }
  c13: "" { style.fill: "#FFE0B2" }
  
  c20: "" { style.fill: "#FFE0B2" }
  c21: "" { style.fill: "#FFE0B2" }
  c22: "" { style.fill: "#FFE0B2" }
  c23: "" { style.fill: "#FFE0B2" }
  
  c30: "c[M-1,0]" { style.fill: "#FFE0B2" }
  c31: "" { style.fill: "#FFE0B2" }
  c32: "" { style.fill: "#FFE0B2" }
  c33: "c[M-1,N-1]" { style.fill: "#FFE0B2" }
}

# -----------------------------------------------------------------------------
# CACHE HIERARCHY
# -----------------------------------------------------------------------------

l1_subsystem: {
  label: "Hardware L1 Data Cache Logic"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-dash: 4
    stroke-width: 2
  }
  
  resident_blocks: {
    grid-columns: 3
    grid-gap: 20
    
    a_cache: "Cached A[I,K]\n4096B" {
      style.fill: "#1565C0"
      style.font-color: white
    }
    b_cache: "Cached B[K,J]\n4096B" {
      style.fill: "#2E7D32"
      style.font-color: white
    }
    c_cache: "Cached C[I,J]\n4096B" {
      style.fill: "#E65100"
      style.font-color: white
    }
  }
  
  mechanics: |md
    **Execution Strategy:**
    1. Load A-block into Cache Lines.
    2. Load B-block into Cache Lines.
    3. FMA (Fused Multiply-Add) logic pulls directly from SRAM cells.
    4. C-block remains "Dirty" in L1 until the K-loop completes.
  |
}

# -----------------------------------------------------------------------------
# DATA PATHS
# -----------------------------------------------------------------------------

matrix_a.a_block -> l1_subsystem.resident_blocks.a_cache: "Burst Load\n(64B Lines)" {
  style.stroke: "#1565C0"
  style.animated: true
}

matrix_b.b_block -> l1_subsystem.resident_blocks.b_cache: "Burst Load\n(64B Lines)" {
  style.stroke: "#2E7D32"
  style.animated: true
}

l1_subsystem.resident_blocks.a_cache -> l1_subsystem.resident_blocks.c_cache: "Matrix Mul-Add" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}

l1_subsystem.resident_blocks.b_cache -> l1_subsystem.resident_blocks.c_cache: "Matrix Mul-Add" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}

l1_subsystem.resident_blocks.c_cache -> matrix_c.c_block: "Evict/Write-Back" {
  style.stroke: "#E65100"
  style.stroke-width: 2
}

# -----------------------------------------------------------------------------
# PERFORMANCE ANALYSIS
# -----------------------------------------------------------------------------

analysis: {
  near: bottom-center
  label: |md
    ### Locality Analysis
    - **Temporal Locality:** Every element in `a_cache` is accessed **32 times** for the dot product of 32 rows/columns.
    - **Spatial Locality:** Row-major access in `A` and `C` ensures 16 sequential FP32 values populate a single cache line.
    - **Arithmetic Intensity:** ${Intensity} = \frac{2 \cdot B^3}{3 \cdot 4 \cdot B^2} = \frac{B}{6}$ FLOPS/Byte.
    - **Result:** Blocking changes the algorithm from **Memory-Bound** to **Compute-Bound**.
  |
  style: {
    fill: "#FAFAFA"
    stroke: "#455A64"
    border-radius: 8
  }
}