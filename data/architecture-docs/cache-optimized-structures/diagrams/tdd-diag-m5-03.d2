vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Block Fits in Cache: Working Set Analysis
| {near: top-center}
direction: right
# L1 Cache Container
L1_Cache: {
  label: "L1 Data Cache (32 KB)\n512 cache lines"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    border-radius: 8
  }
  # Block working set fits inside
  Block_Working_Set: {
    label: "Blocked Working Set\n(12 KB total)"
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 6
    }
    A_block: {
      label: "A Block\n32×32 floats\n= 4 KB\n64 cache lines"
      style: {
        fill: "#81C784"
        stroke: "#2E7D32"
      }
    }
    B_block: {
      label: "B Block\n32×32 floats\n= 4 KB\n64 cache lines"
      style: {
        fill: "#81C784"
        stroke: "#2E7D32"
      }
    }
    C_block: {
      label: "C Block\n32×32 floats\n= 4 KB\n64 cache lines"
      style: {
        fill: "#81C784"
        stroke: "#2E7D32"
      }
    }
    A_block -- B_block -- C_block
  }
  Free_Space: {
    label: "Free L1 Space\n20 KB remaining"
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      stroke-dash: 3
    }
  }
}
# Naive Working Set - Exceeds Cache
Naive_Working_Set: {
  label: "Naive Working Set\n(Exceeds ALL Cache Levels)"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    border-radius: 8
  }
  Matrix_A_Full: {
    label: "Matrix A\n1024×1024\n= 4 MB"
    style: {
      fill: "#FFCDD2"
      stroke: "#E53935"
    }
  }
  Matrix_B_Full: {
    label: "Matrix B\n1024×1024\n= 4 MB"
    style: {
      fill: "#FFCDD2"
      stroke: "#E53935"
    }
  }
  Matrix_C_Full: {
    label: "Matrix C\n1024×1024\n= 4 MB"
    style: {
      fill: "#FFCDD2"
      stroke: "#E53935"
    }
  }
  Matrix_A_Full -- Matrix_B_Full -- Matrix_C_Full
}
# Comparison Arrow
comparison: {
  label: "Cache Behavior\nComparison"
  style.fill: transparent
}
comparison -> L1_Cache: "BLOCKED:\nFits in L1 ✓" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    animated: true
  }
}
comparison -> Naive_Working_Set: "NAIVE:\nExceeds all caches ✗" {
  style: {
    stroke: "#C62828"
    stroke-width: 3
    stroke-dash: 5
  }
}
# Legend
legend: {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  fits: {
    label: "■ Fits in Cache (Reuse)"
    style.fill: "#81C784"
  }
  exceeds: {
    label: "■ Exceeds Cache (Thrashing)"
    style.fill: "#FFCDD2"
  }
  fits -- exceeds
}
# Key insight annotation
insight: |md
  **Key Insight:**
  **Blocked:** 3 × 32² × 4 = 12,288 bytes
  Fits in L1 cache → data reused while hot
  **Naive:** 3 × 1024² × 4 = 12,582,912 bytes
  Exceeds L3 → every access may miss cache
| {near: bottom-right}