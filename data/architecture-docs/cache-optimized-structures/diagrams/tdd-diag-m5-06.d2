d2
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#5B9BD5"
    free: "#98FB98"
    padding: "#D3D3D3"
    pointer: "#FFA500"
  }
}
title: |md
  # CPU Cache Hierarchy: Side View
| { near: top-center }
L1_Cache: "L1 Cache\n32KB, 4 cycles" {
  style.fill: "${colors.data}"
  style.font-size: 14
  width: 180
  L1_Core: "CPU Core" {
    style.fill: "${colors.header}"
  }
}
L2_Cache: "L2 Cache\n256KB-1MB, 12 cycles" {
  style.fill: "${colors.data}"
  style.font-size: 14
  width: 200
}
L3_Cache: "L3 Cache\n8-64MB, 40 cycles" {
  style.fill: "${colors.data}"
  style.font-size: 14
  width: 220
}
RAM: "Main Memory (RAM)\n8-128GB, 200+ cycles" {
  style.fill: "${colors.free}"
  style.font-size: 14
  width: 240
}
L1_Cache.L1_Core -> L1_Cache: "owns"
L1_Cache -> L2_Cache: "←→" {
  style.stroke: "${colors.pointer}"
  style.stroke-width: 2
}
L2_Cache -> L3_Cache: "←→" {
  style.stroke: "${colors.pointer}"
  style.stroke-width: 2
}
L3_Cache -> RAM: "←→" {
  style.stroke: "${colors.pointer}"
  style.stroke-width: 2
}
CPU: "CPU" {
  style.fill: "${colors.header}"
  style.font-size: 16
  style.bold: true
}
CPU -> L1_Cache.L1_Core: "fetch/store"
latency_annotation: |md
  **Latency increases ~50x at each level**
| {
  near: bottom-center
  style.fill: transparent
  style.font-size: 12
}