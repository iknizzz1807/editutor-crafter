vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cache Miss Comparison: Naive vs Blocked Matrix Multiplication
  **n = 2048 × 2048 matrices**
| {near: top-center}
# Legend
legend: {
  near: top-right
  style.fill: "#f5f5f5"
  style.stroke: "#cccccc"
  style.border-radius: 4
  naive_label: "Naive O(n³)"
  naive_label.style.fill: "#e74c3c"
  naive_label.style.font-color: white
  blocked_label: "Blocked O(n³/B)"
  blocked_label.style.fill: "#27ae60"
  blocked_label.style.font-color: white
}
# L1 Cache Misses
l1_section: {
  label: "L1 Data Cache Misses"
  l1_naive: |md
    **Naive: 847M**
    ████████████████████
    ████████████████████
    ████████████████████
  | {
    style.fill: "#e74c3c"
    style.font-color: white
    style.stroke: "#c0392b"
    width: 400
  }
  l1_blocked: |md
    **Blocked: 28M**
    ██
  | {
    style.fill: "#27ae60"
    style.font-color: white
    style.stroke: "#1e8449"
    width: 60
  }
  l1_naive -> l1_blocked: "30× reduction" {
    style.stroke: "#2980b9"
    style.stroke-width: 2
    style.stroke-dash: 4
    style.font-color: "#2980b9"
    style.bold: true
  }
}
# L2 Cache Misses
l2_section: {
  label: "L2 Cache Misses"
  l2_naive: |md
    **Naive: 312M**
    ████████████████████
    ████████████████████
  | {
    style.fill: "#e74c3c"
    style.font-color: white
    style.stroke: "#c0392b"
    width: 350
  }
  l2_blocked: |md
    **Blocked: 8.4M**
    █
  | {
    style.fill: "#27ae60"
    style.font-color: white
    style.stroke: "#1e8449"
    width: 45
  }
  l2_naive -> l2_blocked: "37× reduction" {
    style.stroke: "#2980b9"
    style.stroke-width: 2
    style.stroke-dash: 4
    style.font-color: "#2980b9"
    style.bold: true
  }
}
# L3 Cache Misses
l3_section: {
  label: "L3 (LLC) Cache Misses"
  l3_naive: |md
    **Naive: 156M**
    ████████████████████
  | {
    style.fill: "#e74c3c"
    style.font-color: white
    style.stroke: "#c0392b"
    width: 300
  }
  l3_blocked: |md
    **Blocked: 3.2M**
    █
  | {
    style.fill: "#27ae60"
    style.font-color: white
    style.stroke: "#1e8449"
    width: 35
  }
  l3_naive -> l3_blocked: "49× reduction" {
    style.stroke: "#2980b9"
    style.stroke-width: 2
    style.stroke-dash: 4
    style.font-color: "#2980b9"
    style.bold: true
  }
}
# Analysis Box
analysis: {
  near: bottom-center
  style.fill: "#ecf0f1"
  style.stroke: "#bdc3c7"
  style.border-radius: 8
  content: |md
    ## Why Blocked Wins
    **Naive**: B accessed column-wise
    - Stride = 2048 × 4 = 8192 bytes
    - Each element on different cache line
    - 1 miss per B element accessed
    **Blocked**: B accessed row-wise within blocks
    - 32×32 block fits in L1 (12KB)
    - Sequential access enables prefetching
    - Cache lines fully utilized (16 floats/line)
  |
}
# Command reference
command: {
  near: bottom-right
  style.fill: "#2c3e50"
  style.font-color: white
  style.font: mono
  style.border-radius: 4
  cmd: |md
    bash
    perf stat -e L1-dcache-load-misses,\
      LLC-load-misses \
      ./matmul_benchmark --size 2048
    
  |
}
l1_section -> l2_section -> l3_section