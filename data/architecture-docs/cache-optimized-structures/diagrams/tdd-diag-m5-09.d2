layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 40
  }
}

# --- REGISTER BLOCKING MICRO-KERNEL DESIGN SPEC ---
# Intel Manual Level Implementation Details
# Target: AVX-512 / Skylake-X+ Register File

classes: {
  header_style: {
    style: {
      fill: "#673AB7"
      font-color: white
      bold: true
      stroke: "#311B92"
      stroke-width: 2
    }
  }
  memory_block: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 1
    }
  }
  register_active: {
    style: {
      fill: "#FFB74D"
      stroke: "#E65100"
      stroke-width: 2
      font: mono
      border-radius: 3
    }
  }
  register_load: {
    style: {
      fill: "#A5D6A7"
      stroke: "#2E7D32"
      stroke-width: 2
      font: mono
    }
  }
  cache_boundary: {
    style: {
      stroke: "#212121"
      stroke-width: 5
      fill: transparent
    }
  }
  pipeline_step: {
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      border-radius: 8
    }
  }
  data_edge: {
    style: {
      stroke: "#FF6F00"
      stroke-width: 3
      animated: true
    }
  }
}

title: |md
  # REGISTER BLOCKING: MICRO-KERNEL ARCHITECTURE
  ## Hardware-Level Optimization Spec (v4.2)
  ### SIMD ISA: AVX-512 (ZMM Register Set)
  ---
  **Constraint:** $M_r \times N_r$ Register Tile must fit in Register File (32 x 512-bit)
| {
  near: top-center
  shape: text
}

# --- PHYSICAL MEMORY LAYOUT ---
memory_map: {
  label: "Physical Address Space & Data Alignment"
  
  ram: "Main Memory (DDR4/5)" {
    class: header_style
    
    matrix_a: "Matrix A (Row-Major)" {
      shape: sql_table
      style.fill: "#E1F5FE"
      "0x0000": "Row 0: [a0,0...a0,K]" {constraint: "64B Aligned"}
      "0x0040": "Row 1: [a1,0...a1,K]" {constraint: "Stride_A"}
      "0x0080": "Row 2: [a2,0...a2,K]" {constraint: "Stride_A"}
      "0x00C0": "... (Padding)" {constraint: "Alignment"}
      "0xNNNN": "Row M: [aM,0...aM,K]" {constraint: "End_A"}
    }
    
    matrix_b: "Matrix B (Packed-Col)" {
      shape: sql_table
      style.fill: "#FFF9C4"
      "0x0000": "Col 0: [b0,0...bK,0]" {constraint: "Packed Nr=16"}
      "0x0200": "Col 1: [b0,1...bK,1]" {constraint: "Next Micro-Panel"}
    }
  }

  cache_hierarchy: {
    label: "On-Chip Cache Buffers"
    
    l2_cache: "L2 Cache (Private 1MB)" {
      class: cache_boundary
      a_panel: "A-Panel (Mc x Kc)" {
        style.fill: "#BBDEFB"
        label: "Software Managed Stack\nSize: 256KB (Mc=256)"
      }
    }

    l1_cache: "L1 Cache (32KB)" {
      style.stroke-dash: 5
      b_panel: "B-Panel (Kc x Nr)" {
        style.fill: "#FFF176"
        label: "Streaming Micro-Panel\nNr=16 (AVX-512)"
      }
    }
  }
}

# --- EXECUTION UNIT: SIMD REGISTER FILE ---
register_file: "CPU Execution Core (Register File)" {
  class: header_style
  
  accumulators: "Accumulator Tile (Mr x Nr)" {
    grid-columns: 2
    grid-rows: 4
    grid-gap: 15
    style.fill: "#F3E5F5"
    
    zmm0: "ZMM0 (Row 0)" { class: register_active }
    zmm1: "ZMM1 (Row 1)" { class: register_active }
    zmm2: "ZMM2 (Row 2)" { class: register_active }
    zmm3: "ZMM3 (Row 3)" { class: register_active }
    zmm4: "ZMM4 (Row 4)" { class: register_active }
    zmm5: "ZMM5 (Row 5)" { class: register_active }
    zmm6: "ZMM6 (Row 6)" { class: register_active }
    zmm7: "ZMM7 (Row 7)" { class: register_active }
  }

  io_registers: "Operand Buffers" {
    grid-columns: 1
    grid-gap: 20
    zmm8: "ZMM8 (Broadcast A)" { class: register_load }
    zmm9: "ZMM9 (Vector Load B)" { class: register_load }
  }
}

# --- ALGORITHM PIPELINE ---
pipeline: "Micro-Kernel Execution Flow" {
  direction: right
  
  init: "1. PROLOGUE" {
    label: "Zero-init Registers\nVXORPS ZMM0..7"
    class: pipeline_step
  }
  
  k_loop: "2. K-LOOP (Kc iterations)" {
    class: pipeline_step
    style.double-border: true
    
    sub_1: "VBROADCASTSS" {
      label: "Load A[i,k] into ZMM8"
      style.fill: "#C8E6C9"
    }
    sub_2: "VMOVAPS" {
      label: "Load B[k, j:j+15] into ZMM9"
      style.fill: "#FFF9C4"
    }
    sub_3: "VFMADD231PS" {
      label: "FMA: ACC += A * B"
      style.bold: true
      style.fill: "#FFEB3B"
    }
    
    sub_1 -> sub_2 -> sub_3
  }
  
  writeback: "3. EPILOGUE" {
    label: "Store Accums to Matrix C\nVMOVUPS -> [Base_C]"
    class: pipeline_step
  }
  
  init -> k_loop -> writeback
}

# --- DATA STEERING (Arrows) ---
(memory_map.ram.matrix_a -> memory_map.cache_hierarchy.l2_cache.a_panel)[0]: "Load to L2" { class: data_edge }
(memory_map.cache_hierarchy.l2_cache.a_panel -> register_file.io_registers.zmm8)[0]: "Broadcast" { class: data_edge }
(memory_map.ram.matrix_b -> memory_map.cache_hierarchy.l1_cache.b_panel)[0]: "Prefetch L1" { class: data_edge }
(memory_map.cache_hierarchy.l1_cache.b_panel -> register_file.io_registers.zmm9)[0]: "SIMD Load" { class: data_edge }

# --- ARCHITECTURAL ANNOTATION ---
spec_notes: |md
  ### Micro-Kernel Constants
  - **Arith. Intensity:** $AI \approx 16$ FLOPs per 4-byte float.
  - **Alignment:** 64-byte aligned (ZMM Boundary).
  - **Latency:** FMA = 4 cycles, Throughput = 0.5 cycles.
  - **Loop Unrolling:** K-loop unrolled 4x to hide FMA latency.
| {
  near: bottom-left
  shape: text
}

# --- LEGEND ---
legend: {
  near: bottom-right
  class: header_style
  r1: "SIMD Accumulator" { class: register_active }
  r2: "Instruction Path" { style.stroke: black; style.stroke-dash: 2 }
  r3: "Data Flow (RFO/WB)" { class: data_edge }
}