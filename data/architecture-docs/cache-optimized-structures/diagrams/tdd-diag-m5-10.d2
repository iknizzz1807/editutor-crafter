vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
}

# Header Section: Intel-Manual Style Title
title: {
  label: ||md
# Performance Scaling: Matrix Multiplication
### Log-Log Analysis — Execution Time vs Matrix Dimension (n)
||
  near: top-center
  style: {
    stroke-width: 0
    font-size: 18
    font-color: "#2c3e50"
    bold: true
  }
}

# Axis Labels positioned at root to provide coordinate context
y_axis_label: {
  label: ||md
**Execution Time (ms)**
*(Logarithmic Scale)*
||
  shape: text
  style: {
    font-size: 14
    font-color: "#34495e"
  }
  near: center-left
}

x_axis_label: {
  label: ||md
**Matrix Dimension (n x n)**
*(Logarithmic Scale)*
||
  shape: text
  style: {
    font-size: 14
    font-color: "#34495e"
  }
  near: bottom-center
}

# Main Plotting Framework
performance_plot: {
  graph_frame: {
    shape: rectangle
    width: 850
    height: 600
    style: {
      fill: white
      stroke: "#2c3e50"
      stroke-width: 3
      shadow: true
      border-radius: 2
    }
  }

  # Data Series 1: Naive O(n^3) - Traditional Triple Loop
  naive_series: {
    n64:   "64"  { shape: circle; width: 16; style: { fill: "#e74c3c"; stroke: "#c0392b"; stroke-width: 2 } }
    n128:  "128" { shape: circle; width: 16; style: { fill: "#e74c3c"; stroke: "#c0392b"; stroke-width: 2 } }
    n256:  "256" { shape: circle; width: 16; style: { fill: "#e74c3c"; stroke: "#c0392b"; stroke-width: 2 } }
    n512:  "512" { shape: circle; width: 16; style: { fill: "#e74c3c"; stroke: "#c0392b"; stroke-width: 2 } }
    n1024: "1k"  { shape: circle; width: 16; style: { fill: "#e74c3c"; stroke: "#c0392b"; stroke-width: 2 } }
    n2048: "2k"  { shape: circle; width: 16; style: { fill: "#e74c3c"; stroke: "#c0392b"; stroke-width: 2 } }

    n64 -> n128 -> n256 -> n512 -> n1024 -> n2048: {
      style: {
        stroke: "#e74c3c"
        stroke-width: 4
      }
    }
  }

  # Data Series 2: Cache-Blocked O(n^3) - Sub-matrix Tiling
  blocked_series: {
    b64:   "64"  { shape: square; width: 16; style: { fill: "#3498db"; stroke: "#2980b9"; stroke-width: 2 } }
    b128:  "128" { shape: square; width: 16; style: { fill: "#3498db"; stroke: "#2980b9"; stroke-width: 2 } }
    b256:  "256" { shape: square; width: 16; style: { fill: "#3498db"; stroke: "#2980b9"; stroke-width: 2 } }
    b512:  "512" { shape: square; width: 16; style: { fill: "#3498db"; stroke: "#2980b9"; stroke-width: 2 } }
    b1024: "1k"  { shape: square; width: 16; style: { fill: "#3498db"; stroke: "#2980b9"; stroke-width: 2 } }
    b2048: "2k"  { shape: square; width: 16; style: { fill: "#3498db"; stroke: "#2980b9"; stroke-width: 2 } }

    b64 -> b128 -> b256 -> b512 -> b1024 -> b2048: {
      style: {
        stroke: "#3498db"
        stroke-width: 4
      }
    }
  }

  # Analytical Overlays: Explaining the crossover point
  crossover_zone: {
    area: {
      shape: rectangle
      width: 150
      height: 460
      style: {
        fill: "#f1c40f"
        fill-pattern: lines
        opacity: 0.15
        stroke: "#f39c12"
        stroke-width: 1
        stroke-dash: 5
      }
    }
    annotation: {
      label: ||md
**CACHE THRASHING THRESHOLD**
*n* ≈ 256
L2 Data Cache footprint exceeded.
Blocked variant begins O(1) cache miss 
scaling while Naive scales O(n).
||
      shape: text
      style: {
        font-size: 11
        font-color: "#d35400"
        bold: true
      }
    }
  }
}

# Metadata and Legend Pane
analysis_sidebar: {
  legend_box: {
    label: "Metric Reference"
    grid-columns: 2
    grid-gap: 20
    
    naive_marker: {
      shape: circle
      width: 18
      style.fill: "#e74c3c"
      style.stroke: "#c0392b"
    }
    naive_text: "Naive (Column-Major Strided) O(n³)" { shape: text }
    
    blocked_marker: {
      shape: square
      width: 18
      style.fill: "#3498db"
      style.stroke: "#2980b9"
    }
    blocked_text: "Tiled (L1-Cache Resident) O(n³)" { shape: text }

    style: {
      stroke: "#bdc3c7"
      fill: "#f8f9fa"
      border-radius: 6
      shadow: true
    }
  }

  raw_data_table: {
    label: ||md
| Matrix n | Naive (ms) | Blocked (ms) | Efficiency |
| :--- | :--- | :--- | :--- |
| 64 | 0.5 | 0.6 | 83% |
| 128 | 4.0 | 3.5 | 114% |
| 256 | 32.0 | 18.0 | 177% |
| 512 | 260.0 | 85.0 | 305% |
| 1024 | 2,100 | 450.0 | 466% |
| 2048 | 17,200 | 3,200 | 537% |
||
    shape: text
    style: {
      font: mono
      font-size: 12
    }
  }

  key_insight: {
    label: ||md
### Micro-Architectural Impact
At **n=2048**, spatial and temporal
locality optimizations yield **5.4x** throughput.

**Hardware Counters:**
- L1-D Cache Miss: -82%
- LLC Miss: -64%
- Instructions Per Cycle (IPC): +120%
||
    style: {
      fill: "#e8f6f3"
      stroke: "#1abc9c"
      stroke-width: 2
      border-radius: 10
      shadow: true
    }
  }
}

# Positioning logic using relative IDs to avoid constant near errors
analysis_sidebar.near: center-right