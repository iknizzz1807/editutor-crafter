direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Container Runtime Architecture: Satellite View {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
legend: {
  near: top-right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  ns: "Namespace (Visibility Isolation)"
  cg: "Cgroup (Resource Enforcement)"
  kernel: "Kernel Primitive"
  ns.style.fill: "#e3f2fd"
  cg.style.fill: "#fff3e0"
  kernel.style.fill: "#f3e5f5"
}
host_layer: "" {
  direction: down
  style.fill: transparent
  style.stroke: transparent
  hardware: Hardware {
    shape: rectangle
    style: {
      fill: "#fafafa"
      stroke: "#9e9e9e"
      stroke-width: 2
    }
    cpu: "CPU Cores"
    memory: "RAM"
    disk: "Storage"
    network_hw: "NIC"
  }
  kernel_space: Linux Kernel {
    shape: rectangle
    style: {
      fill: "#f3e5f5"
      stroke: "#7b1fa2"
      stroke-width: 3
    }
    scheduler: Scheduler {
      style.fill: "#e1bee7"
    }
    mm: Memory Manager {
      style.fill: "#e1bee7"
    }
    vfs: VFS Layer {
      style.fill: "#e1bee7"
    }
    net_stack: Network Stack {
      style.fill: "#e1bee7"
    }
    ns_core: Namespace Core {
      style.fill: "#ce93d8"
    }
    cgroup_core: Cgroup Core {
      style.fill: "#ce93d8"
    }
  }
}
isolation_layer: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  pid_ns_box: PID Namespace {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
    }
    link: "#container-basic-m1"
    pid_desc: "Process ID isolation"
    pid_view: "View transformation"
    pid_p1: "Container sees PID 1"
    pid_table: "struct pid_namespace"
  }
  uts_ns_box: UTS Namespace {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
    }
    link: "#container-basic-m1"
    uts_desc: "Hostname isolation"
    uts_struct: "struct uts_namespace"
    uts_fields: "nodename[65]"
    uts_domain: "domainname[65]"
  }
  mount_ns_box: Mount Namespace {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
    }
    link: "#container-basic-m2"
    mount_desc: "Filesystem isolation"
    mount_key: "pivot_root()"
    mount_prop: "MS_PRIVATE"
    mount_struct: "struct mnt_namespace"
  }
  net_ns_box: Network Namespace {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
    }
    link: "#container-basic-m3"
    net_desc: "Network stack isolation"
    net_veth: "veth pairs"
    net_bridge: "Linux bridge"
    net_nat: "NAT/masquerade"
    net_struct: "struct net"
  }
  user_ns_box: User Namespace {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
    }
    link: "#container-basic-m5"
    user_desc: "UID/GID mapping"
    user_map: "uid_map / gid_map"
    user_cap: "Scoped capabilities"
    user_rootless: "Enables rootless"
    user_struct: "struct user_namespace"
  }
  cgroup_box: Cgroups v2 {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-width: 2
    }
    link: "#container-basic-m4"
    cg_desc: "Resource enforcement"
    cg_mem: "memory.max (OOM)"
    cg_cpu: "cpu.max (throttle)"
    cg_pids: "pids.max (fork bomb)"
    cg_path: "/sys/fs/cgroup/"
  }
}
container_layer: "" {
  direction: down
  style.fill: transparent
  style.stroke: transparent
  namespace_boundary: Isolation Boundary {
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      stroke-width: 3
      stroke-dash: 5
    }
    container_rootfs: Container Rootfs {
      style.fill: "#c8e6c9"
      bin: "/bin/"
      etc: "/etc/"
      proc: "/proc/ (mounted)"
      var: "/var/"
    }
    init_process: Init Process (PID 1) {
      shape: hexagon
      style: {
        fill: "#81c784"
        stroke: "#2e7d32"
        stroke-width: 2
      }
      init_desc: "Zombie reaping"
      init_sig: "Signal handling"
      init_exec: "Exec payload"
    }
    worker_processes: Worker Processes {
      style.multiple: true
      style.fill: "#a5d6a7"
      w1: "PID 2"
      w2: "PID 3"
      wn: "PID n"
    }
    init_process -> worker_processes: spawns
    container_rootfs -> init_process: provides
  }
}
host_layer.kernel_space -> isolation_layer: provides primitives {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
}
isolation_layer -> container_layer.namespace_boundary: enforces isolation {
  style.stroke: "#1976d2"
  style.stroke-width: 2
  style.stroke-dash: 3
}
isolation_layer.cgroup_box -> container_layer.namespace_boundary: enforces limits {
  style.stroke: "#f57c00"
  style.stroke-width: 2
}
data_flow: Data Flow {
  near: bottom-center
  style.fill: "#fafafa"
  style.stroke: "#bdbdbd"
  flow_title: Translation Flow {
    shape: text
    style.bold: true
  }
  syscall: "Syscall (e.g., getpid())"
  ns_check: "Namespace lookup"
  translate: "ID translation"
  result: "Namespaced result"
  syscall -> ns_check -> translate -> result
}
syscall_layer: "" {
  direction: right
  near: bottom-center
  style.fill: transparent
  style.stroke: transparent
  clone_box: clone() {
    style.fill: "#fce4ec"
    flags: "CLONE_NEWPID | CLONE_NEWUTS | CLONE_NEWNS | CLONE_NEWNET | CLONE_NEWUSER"
  }
  pivot_box: pivot_root() {
    style.fill: "#fce4ec"
    args: "new_root, put_old"
  }
  mount_box: mount() {
    style.fill: "#fce4ec"
    args: "source, target, type, flags"
  }
  write_box: write() {
    style.fill: "#fce4ec"
    desc: "cgroup files"
  }
}
milestone_anchors: Milestone Anchors {
  near: bottom-right
  style.fill: "#f5f5f5"
  style.stroke: "#9e9e9e"
  m1: "M1: PID + UTS Namespaces" {
    link: "#container-basic-m1"
  }
  m2: "M2: Mount + pivot_root" {
    link: "#container-basic-m2"
  }
  m3: "M3: Network + veth" {
    link: "#container-basic-m3"
  }
  m4: "M4: Cgroups Resource Limits" {
    link: "#container-basic-m4"
  }
  m5: "M5: User Namespace + Rootless" {
    link: "#container-basic-m5"
  }
}
isolation_layer.pid_ns_box -> milestone_anchors.m1: implements {
  style.stroke-dash: 3
  style.stroke: "#bdbdbd"
}
isolation_layer.uts_ns_box -> milestone_anchors.m1: implements {
  style.stroke-dash: 3
  style.stroke: "#bdbdbd"
}
isolation_layer.mount_ns_box -> milestone_anchors.m2: implements {
  style.stroke-dash: 3
  style.stroke: "#bdbdbd"
}
isolation_layer.net_ns_box -> milestone_anchors.m3: implements {
  style.stroke-dash: 3
  style.stroke: "#bdbdbd"
}
isolation_layer.cgroup_box -> milestone_anchors.m4: implements {
  style.stroke-dash: 3
  style.stroke: "#bdbdbd"
}
isolation_layer.user_ns_box -> milestone_anchors.m5: implements {
  style.stroke-dash: 3
  style.stroke: "#bdbdbd"
}