direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "clone() Stack Layout for PID Namespace"
}
title.near: top-center

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  mem_layout: {
    direction: down
    label: "Child Stack Memory Layout (x86-64)"
    
    stack_region: {
      width: 400
      height: 400
      style.fill: "#E8F4E8"
      style.stroke: "#2D5A2D"
      
      high_addr: {
        label: "0x7FFF FFFF F000 (stack_top)"
        style.fill: "#90EE90"
        style.stroke: "#2D5A2D"
      }
      
      growth_arrow: {
        label: "Stack Grows DOWNWARD ⬇"
        info: |'md
          PUSH decrements RSP
          POP increments RSP
        '|
        style.fill: "#FFFACD"
        style.stroke: "#B8860B"
      }
      
      alignment_pad: {
        label: "0x7FFF FFFF FFF0 (16-byte aligned)"
        style.fill: "#87CEEB"
        style.stroke: "#4682B4"
      }
      
      pass_to_clone: {
        label: "TARGET ADDRESS"
        info: |'md
          Pass stack_top to clone()
          clone(fn, stack_top, ...)
        '|
        style.fill: "#FFB6C1"
        style.stroke: "#DC143C"
        style.stroke-width: 3
      }
      
      low_addr: {
        label: "0x7FFF FFEF F000 (stack_base)"
        style.fill: "#D3D3D3"
        style.stroke: "#696969"
      }
    }
  }

  alloc_code: {
    direction: down
    label: "Stack Allocation Code (C)"
    width: 420
    
    implementation: {
      shape: code
      language: c
      code: |'c
        void *stack = malloc(1024 * 1024); 
        // Stack grows DOWNWARD on x86-64
        void *stack_top = stack + (1024 * 1024);
        // ABI: 16-byte alignment (clear bottom 4 bits)
        stack_top = (void *)((uintptr_t)stack_top & ~0xF);
        int fl = CLONE_NEWPID | CLONE_NEWUTS | SIGCHLD;
        pid_t pid = clone(child_fn, stack_top, fl, NULL);
      '|
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  flags_table: {
    direction: down
    label: "Namespace Flags"
    flags: {
      shape: sql_table
      label: "clone() Flags (container.c)"
      f1: "0x20000000 | CLONE_NEWPID  | New PID namespace"
      f2: "0x04000000 | CLONE_NEWUTS  | New UTS namespace"
      f3: "0x00000011 | SIGCHLD       | Signal parent on exit"
      total: "Combined: 0x24000011"
    }
  }
  
  common_errors: {
    direction: down
    label: "Common Errors"
    errors: {
      shape: sql_table
      label: "Error Diagnosis"
      e1: "EINVAL    | Stack not aligned / invalid flags"
      e2: "EPERM     | No CAP_SYS_ADMIN for namespace"
      e3: "ENOMEM    | Insufficient memory for stack"
      e4: "SIGSEGV   | Passed stack_bottom instead of top"
    }
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  abi_req: {
    direction: down
    label: "ABI Alignment Requirement"
    width: 380
    align_box: {
      style.fill: "#E6E6FA"
      style.stroke: "#483D8B"
      content: |'md
        **System V AMD64 ABI**
        - RSP must be 16-byte aligned
        - Required for SSE/AVX instructions
        - stack_top & ~0xF ensures compliance
      '|
    }
  }
  
  why_matters: {
    direction: down
    label: "Why Stack Direction Matters"
    width: 420
    matter_box: {
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      content: |'md
        **CRITICAL: Overflow Risk**
        Passing the BOTTOM (stack) instead of TOP:
        1. First push writes outside allocation
        2. Corrupts adjacent heap memory
        3. Leads to immediate crash or CVE
      '|
    }
  }
}

legend_box: {
  label: "Memory Map Legend"
  direction: right
  style.fill: "#F8F8F8"
  
  high: "High Addr" {
    style.fill: "#90EE90"
  }
  target: "clone() Target" {
    style.fill: "#FFB6C1"
  }
  low: "Low Addr" {
    style.fill: "#D3D3D3"
  }
}
legend_box.near: bottom-right