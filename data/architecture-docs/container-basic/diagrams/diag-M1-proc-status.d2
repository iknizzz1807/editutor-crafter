direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "/proc/self/status NSpid Field Analysis"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  outside_ns: {
    direction: down
    label: "OUTSIDE NAMESPACE (Host View)"
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 8
    }
    host_process: {
      shape: class
      label: "Host Process (PID 12344)"
      +getpid(): "int → 12344"
      +getppid(): "int → 12343"
    }
    host_proc: {
      label: "Reading /proc/self/status"
      shape: rectangle
      style.fill: white
      width: 280
      content: |'text
        Pid:    12344
        PPid:   12343
        NSpid:  12344
      '|
    }
    host_proc.style.font: mono
    host_proc.style.font-size: 14
    host_process -> host_proc: "fopen()\nfgets()"
  }
  arrow_container: {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    width: 100
    arrow: {
      shape: text
      label: "↔"
      style: {
        font-size: 48
        font-color: "#666666"
      }
    }
    comparison: {
      shape: text
      label: "Same Process\nDifferent Views"
      style: {
        font-size: 14
        italic: true
        font-color: "#666666"
      }
    }
  }
  inside_ns: {
    direction: down
    label: "INSIDE NAMESPACE (Container View)"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      border-radius: 8
    }
    container_process: {
      shape: class
      label: "Container Init (PID 1)"
      +getpid(): "int → 1"
      +getppid(): "int → 0"
    }
    container_proc: {
      label: "Reading /proc/self/status"
      shape: rectangle
      style.fill: white
      width: 280
      content: |'text
        Pid:    1
        PPid:   0
        NSpid:  1      12345
      '|
    }
    container_proc.style.font: mono
    container_proc.style.font-size: 14
    container_process -> container_proc: "fopen()\nfgets()"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  nspid_explanation: {
    direction: down
    label: "NSpid Field Format"
    style: {
      fill: "#FFF8E1"
      stroke: "#FFC107"
      stroke-width: 2
      border-radius: 8
    }
    width: 700
    format_header: {
      label: "NSpid:  <innermost>  <outermost>"
      shape: rectangle
      style: {
        fill: "#FFF3E0"
        font: mono
        font-size: 16
        bold: true
      }
    }
    format_detail: {
      direction: right
      level1: {
        label: "Level 1\n(Container NS)"
        shape: rectangle
        style.fill: "#C8E6C9"
        width: 150
      }
      level2: {
        label: "Level 2\n(Host NS)"
        shape: rectangle
        style.fill: "#BBDEFB"
        width: 150
      }
      separator: {
        label: "Whitespace Separated"
        shape: text
        style.italic: true
      }
    }
    example: {
      label: |'text
        Example: NSpid:  1      12345
                         ↑      ↑
                         │      └─ Host PID (visible to host)
                         └──────── Container PID (visible inside)
      '|
      shape: rectangle
      style: {
        fill: white
        font: mono
        font-size: 13
      }
      width: 650
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_struct: {
    label: "Kernel Translation Layer"
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      border-radius: 8
    }
    width: 700
    struct_layout: {
      shape: sql_table
      label: "struct pid (kernel/pid.c)"
      f0: "0x00 | int               | level"
      f1: "0x04 | struct hlist_head | tasks[PIDTYPE_MAX]"
      f2: "0x10 | struct rcu_head   | rcu"
      f3: "0x18 | struct upid      | numbers[0]  // NS-specific"
      f4: "0x28 | struct upid      | numbers[1]  // Host"
      sz: "Per-namespace virtual PID in numbers[].nr"
    }
    struct_layout.width: 350
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  code_example: {
    label: "Verification Code (C)"
    width: 700
    style: {
      fill: "#263238"
      stroke: "#455A64"
      border-radius: 8
    }
    code: |'c
      static void print_nspid_info(const char *label) {
          printf("=== %s ===\n", label);
          printf("  PID: %d\n", getpid());
          FILE *f = fopen("/proc/self/status", "r");
          if (!f) return;
          char line[256];
          while (fgets(line, sizeof(line), f)) {
              if (strncmp(line, "NSpid:", 6) == 0) {
                  printf("  %s", line);  // Shows all namespace PIDs
              }
          }
          fclose(f);
      }
      // Output inside namespace:
      //   PID: 1
      //   NSpid:   1       12345
      //            ^       ^
      //            |       └─ Host view
      //            └───────── Container view
    '|
    code.style: {
      fill: "#1E1E1E"
      font: mono
      font-color: "#D4D4D4"
      font-size: 12
    }
  }
}
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  legend_title: {
    label: "Key Insight"
    shape: text
    style: {
      bold: true
      underline: true
    }
  }
  insight: {
    label: "NSpid shows PID in EVERY nested namespace level,\nfrom innermost (container) to outermost (host).\nSame process, multiple valid identities."
    shape: text
    style.italic: true
    style.font-size: 13
  }
}