direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: "UTS Namespace Struct Layout"
  style: {
    font-size: 28
    bold: true
    underline: true
    stroke: transparent
    fill: transparent
  }
}

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  host_uts: {
    direction: down
    label: "Host UTS Namespace (init_user_ns)"
    
    host_struct: {
      shape: sql_table
      label: "struct uts_namespace (utsname.h)"
      f0: "0x00 | struct kref     | kref"
      f1: "0x08 | struct new_utsname | name"
      f2: "0x00 | char[65]         | sysname = \"Linux\""
      f3: "0x41 | char[65]         | nodename = \"host-prod-01\""
      f4: "0x82 | char[65]         | release = \"6.1.0-generic\""
      f5: "0xC3 | char[65]         | version = \"#1 SMP...\""
      f6: "0x104| char[65]         | machine = \"x86_64\""
      f7: "0x145| char[65]         | domainname = \"localdomain\""
      sz: "Total: 398 bytes"
    }
    
    host_proc: {
      label: "/proc/sys/kernel/hostname"
      code: |'sh
        $ hostname
        host-prod-01
      '|
      width: 220
    }
  }

  container_uts: {
    direction: down
    label: "Container UTS Namespace (new)"
    style: {
      stroke: "#3d9069"
      fill: "#e8f5e9"
    }
    
    container_struct: {
      shape: sql_table
      label: "struct uts_namespace (utsname.h)"
      style: {
        stroke: "#3d9069"
        fill: "#e8f5e9"
      }
      f0: "0x00 | struct kref     | kref"
      f1: "0x08 | struct new_utsname | name"
      f2: "0x00 | char[65]         | sysname = \"Linux\""
      f3: "0x41 | char[65]         | nodename = \"my-container\""
      f4: "0x82 | char[65]         | release = \"6.1.0-generic\""
      f5: "0xC3 | char[65]         | version = \"#1 SMP...\""
      f6: "0x104| char[65]         | machine = \"x86_64\""
      f7: "0x145| char[65]         | domainname = \"container\""
      sz: "Total: 398 bytes"
    }
    
    container_proc: {
      label: "/proc/sys/kernel/hostname"
      code: |'sh
        $ hostname
        my-container
      '|
      width: 220
      style: {
        stroke: "#3d9069"
        fill: "#e8f5e9"
      }
    }
  }
}

sethostname_flow: {
  direction: down
  label: "sethostname() Call Path"
  
  sethostname_box: {
    label: "sethostname(2) Execution"
    width: 600
    code: |'c
      // 1. Validate length < 65
      // 2. ns = current->nsproxy->uts_ns;
      // 3. down_write(&uts_sem);
      // 4. memcpy(ns->name.nodename, name, len);
      // 5. memset(ns->name.nodename + len, 0, 65 - len);
      // 6. up_write(&uts_sem);
    '|
  }

  validation_note: {
    label: "Kernel validates CAP_SYS_ADMIN in the CURRENT user namespace only"
    shape: rectangle
    style: {
      fill: "#fff3e0"
      stroke: "#ff9800"
      stroke-dash: 3
    }
  }

  flow_logic: "" {
    direction: right
    style: {
      stroke: transparent
      fill: transparent
    }
    
    task: {
      label: "task_struct (sched.h)"
      shape: class
      +nsproxy: "struct nsproxy *"
    }
    
    nsproxy_box: {
      label: "struct nsproxy (nsproxy.h)"
      shape: class
      +uts_ns: "struct uts_namespace *"
      +mnt_ns: "struct mnt_namespace *"
    }
    
    uts_ptr: {
      label: "struct uts_namespace"
      shape: class
      +name: "struct new_utsname"
    }
    
    task -> nsproxy_box: "nsproxy | read"
    nsproxy_box -> uts_ptr: "uts_ns | ptr"
  }
}

# Connections
row1.container_uts.container_struct.f3 -> sethostname_flow.uts_ptr: "nodename | modify" {
  style: {
    stroke: "#3d9069"
    stroke-dash: 3
  }
}

# Legend and Notes
legend_container: {
  direction: down
  near: bottom-center
  style: {
    fill: "#f5f5f5"
    stroke: "#ccc"
    border-radius: 4
  }
  
  note1: {
    shape: rectangle
    label: "Key Insight: Each UTS namespace has its own copy of new_utsname"
    style.stroke: transparent
  }
  note2: {
    shape: rectangle
    label: "sethostname() modifies ONLY current->nsproxy->uts_ns->name.nodename"
    style.stroke: transparent
  }
  note3: {
    shape: rectangle
    label: "Host and container see completely different hostname values"
    style.stroke: transparent
  }
}