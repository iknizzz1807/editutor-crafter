direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Why chroot() is NOT Container Isolation
  The Classic Escape via Directory Traversal
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  chroot_section: {
    direction: down
    label: "chroot: Process Pointer Only"
    chroot_step1: {
      label: "Step 1: Initial State"
      width: 340
      code: |'c
        // Process in chroot("/jail")
        // Root pointer: /jail
        // Current dir: /jail
      '|
      style.fill: "#e8f5e9"
    }
    chroot_step2: {
      label: "Step 2: Create Escape Dir"
      width: 340
      code: |'c
        mkdir("/jail/escape", 0755);
        // Directory entry ".." still
        // points to parent on disk!
      '|
      style.fill: "#fff3e0"
    }
    chroot_step3: {
      label: "Step 3: Nested chroot"
      width: 340
      code: |'c
        chroot("/jail/escape");
        // Root pointer: /jail/escape
        // But /jail/escape/.. = /jail
        // on the ACTUAL filesystem
      '|
      style.fill: "#fff3e0"
    }
    chroot_step4: {
      label: "Step 4: Escape via .."
      width: 340
      code: |'c
        chdir("../../../../../..");
        // Walks up ACTUAL directory
        // entries, ignoring chroot!
        // Now at REAL root /
      '|
      style.fill: "#ffebee"
    }
    chroot_step5: {
      label: "Step 5: Final chroot"
      width: 340
      code: |'c
        chroot(".");
        // Root pointer: / (REAL!)
        execl("/bin/sh", "sh", NULL);
        // ESCAPED! Full host access
      '|
      style.fill: "#ffcdd2"
    }
    chroot_step1 -> chroot_step2 -> chroot_step3 -> chroot_step4 -> chroot_step5
  }
  pivot_section: {
    direction: down
    label: "pivot_root: Kernel Mount Table"
    pivot_step1: {
      label: "Step 1: Initial State"
      width: 340
      code: |'c
        // Root mount: /
        // Process root: /
        // Mount table has / as root
      '|
      style.fill: "#e8f5e9"
    }
    pivot_step2: {
      label: "Step 2: Bind Mount Rootfs"
      width: 340
      code: |'c
        mount(newroot, newroot, NULL,
              MS_BIND | MS_REC, NULL);
        // Creates MOUNT POINT
        // Required for pivot_root!
      '|
      style.fill: "#e3f2fd"
    }
    pivot_step3: {
      label: "Step 3: pivot_root()"
      width: 340
      code: |'c
        pivot_root(newroot, oldroot);
        // ATOMIC kernel operation:
        // 1. Detach / from mount tree
        // 2. Attach to oldroot
        // 3. Attach newroot as /
      '|
      style.fill: "#e3f2fd"
    }
    pivot_step4: {
      label: "Step 4: Unmount Old"
      width: 340
      code: |'c
        umount2("/oldroot", MNT_DETACH);
        // Removes host filesystem
        // from mount table ENTIRELY
        // No path to host exists!
      '|
      style.fill: "#c8e6c9"
    }
    pivot_step5: {
      label: "Step 5: Isolated!"
      width: 340
      code: |'c
        rmdir("/oldroot");
        // Host filesystem GONE
        // chdir("..") stays in /newroot
        // No escape possible!
      '|
      style.fill: "#a5d6a7"
    }
    pivot_step1 -> pivot_step2 -> pivot_step3 -> pivot_step4 -> pivot_step5
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: {
    direction: down
    label: "Key Difference: What Actually Changes"
    chroot_mechanism: {
      shape: class
      label: "chroot(path) Mechanism"
      -changes: "struct path fs->root"
      -scope: "Per-process pointer only"
      -kernel_state: "Mount table UNCHANGED"
      -security: "Directory entries on disk unchanged"
      -escape_path: ".. traversal reaches real root"
    }
    pivot_mechanism: {
      shape: class
      label: "pivot_root(new, old) Mechanism"
      -changes: "Kernel mount tree structure"
      -scope: "Entire mount namespace"
      -kernel_state: "Mount table REWRITTEN"
      -security: "Old root detached from tree"
      -escape_path: "No path to host after umount"
    }
  }
  attack_flow: {
    direction: down
    label: "Attack Flow Visualization"
    attack_diagram: {
      label: ""
      jail: {
        label: "/jail\n(chroot boundary)"
        shape: rectangle
        style.fill: "#ffcdd2"
        style.stroke: "#c62828"
      }
      escape_dir: {
        label: "/jail/escape"
        shape: rectangle
        style.fill: "#fff9c4"
      }
      real_root: {
        label: "/\n(REAL ROOT)"
        shape: rectangle
        style.fill: "#c8e6c9"
        style.stroke: "#2e7d32"
      }
      host_etc: {
        label: "/etc/shadow\n(TARGET)"
        shape: rectangle
        style.fill: "#ef9a9a"
        style.stroke: "#b71c1c"
      }
      jail -> escape_dir: "mkdir" {
        style.stroke: "#ff9800"
        style.stroke-dash: 3
      }
      escape_dir -> jail: "chdir(..)\nESCAPE!" {
        label: "chdir(..)\nESCAPE!"
        style.stroke: "#f44336"
        style.stroke-width: 3
        style.animated: true
      }
      jail -> real_root: "chdir(..)" {
        style.stroke: "#f44336"
        style.stroke-dash: 3
      }
      real_root -> host_etc: "ACCESS\nGRANTED" {
        style.stroke: "#c62828"
        style.stroke-width: 3
        style.animated: true
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  summary_box: {
    label: "Summary: Why pivot_root is Required"
    width: 700
    point1: {
      label: |md
        **1. chroot = Pointer Change Only**
        - Modifies `current->fs->root` (one pointer in task_struct)
        - Directory entries on disk still point to real parent
        - `..` from `/jail/escape` still resolves to `/jail` on disk
      |
    }
    point2: {
      label: |md
        **2. pivot_root = Mount Table Surgery**
        - Modifies kernel's `struct mount` tree
        - Detaches old root from mount hierarchy
        - After `umount()`, no kernel data structure links to host
      |
    }
    point3: {
      label: |md
        **3. The Escape Vector**
        
        chdir("..") from /jail/escape
          ↓ (follows disk directory entry)
        Reaches /jail (outside chroot!)
          ↓
        chdir("..") repeatedly → reaches /
          ↓
        chroot(".") → full host root
        
      |
    }
    point4: {
      label: |md
        **4. Why Containers Use pivot_root**
        - Atomic operation (all-or-nothing)
        - No directory traversal escape
        - Old root can be completely unmounted
        - Combined with mount namespace = true isolation
      |
    }
  }
}
chroot_section -> comparison: "Comparison"
pivot_section -> attack_flow: "Attack\nPath"
legend: {
  near: bottom-right
  label: "Color Legend"
  safe: {
    label: "Safe / Isolated"
    style.fill: "#c8e6c9"
  }
  warning: {
    label: "Warning / Transition"
    style.fill: "#fff3e0"
  }
  danger: {
    label: "Danger / Escape"
    style.fill: "#ffcdd2"
  }
  info: {
    label: "Kernel Operation"
    style.fill: "#e3f2fd"
  }
}