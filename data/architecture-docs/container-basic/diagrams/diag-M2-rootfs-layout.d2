direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    mount: "#4A90D9"
    dir: "#7CB342"
    device: "#FF7043"
    required: "#FFA726"
    optional: "#9E9E9E"
  }
}

title_node: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
  content: |md
    # Minimal Container rootfs Directory Structure
    **Filesystem tree for container isolation (container_rootfs/)**
  |
}

# --- PRIMARY STRUCTURE ROW ---
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  rootfs: {
    label: "/ (rootfs container_root)"
    style: {
      fill: "#E3F2FD"
      stroke: "#4A90D9"
      stroke-width: 3
    }
    proc_entry: "proc/" {
      style.fill: "#BBDEFB"
      style.stroke: "#4A90D9"
    }
    sys_entry: "sys/" {
      style.fill: "#BBDEFB"
      style.stroke: "#4A90D9"
    }
    dev_entry: "dev/" {
      style.fill: "#BBDEFB"
      style.stroke: "#4A90D9"
    }
    bin_entry: "bin/" {
      style.fill: "#DCEDC8"
      style.stroke: "#7CB342"
    }
    lib_entry: "lib/" {
      style.fill: "#DCEDC8"
      style.stroke: "#7CB342"
    }
    lib64_entry: "lib64/" {
      style.fill: "#DCEDC8"
      style.stroke: "#7CB342"
    }
    etc_entry: "etc/" {
      style.fill: "#DCEDC8"
      style.stroke: "#7CB342"
    }
    tmp_entry: "tmp/" {
      style: {
        fill: "#F5F5F5"
        stroke: "#9E9E9E"
        stroke-dash: 3
      }
    }
    var_entry: "var/" {
      style: {
        fill: "#F5F5F5"
        stroke: "#9E9E9E"
        stroke-dash: 3
      }
    }
    root_entry: "root/" {
      style: {
        fill: "#F5F5F5"
        stroke: "#9E9E9E"
        stroke-dash: 3
      }
    }
  }
}

# --- DETAIL LEVEL ROW ---
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  dev_detail: {
    label: "/dev/ Node Detail"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF7043"
      stroke-width: 2
    }
    null_dev: "null" {
      shape: parallelogram
      style.fill: "#FFCCBC"
    }
    zero_dev: "zero" {
      shape: parallelogram
      style.fill: "#FFCCBC"
    }
    urandom_dev: "urandom" {
      shape: parallelogram
      style.fill: "#FFCCBC"
    }
    random_dev: "random" {
      shape: parallelogram
      style: {
        fill: "#FFE0B2"
        stroke: "#9E9E9E"
        stroke-dash: 2
      }
    }
    tty_dev: "tty" {
      shape: parallelogram
      style: {
        fill: "#FFE0B2"
        stroke: "#9E9E9E"
        stroke-dash: 2
      }
    }
    pts_dir: "pts/" {
      style.fill: "#E1F5FE"
      style.stroke: "#4A90D9"
    }
    shm_dir: "shm/" {
      style.fill: "#E1F5FE"
      style.stroke: "#4A90D9"
    }
  }

  etc_detail: {
    label: "/etc/ Config Detail"
    style: {
      fill: "#F1F8E9"
      stroke: "#7CB342"
      stroke-width: 2
    }
    hostname_file: "hostname" {
      shape: document
      style.fill: "#C8E6C9"
    }
    hosts_file: "hosts" {
      shape: document
      style.fill: "#C8E6C9"
    }
    resolv_file: "resolv.conf" {
      shape: document
      style.fill: "#C8E6C9"
    }
    passwd_file: "passwd" {
      shape: document
      style.fill: "#F5F5F5"
      style.stroke-dash: 2
    }
    group_file: "group" {
      shape: document
      style.fill: "#F5F5F5"
      style.stroke-dash: 2
    }
  }
}

# --- DOCUMENTATION ROW ---
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  mount_table: {
    content: |'md
      ## Mount Points
      | Path | Type | Flags | Purpose |
      |------|------|-------|---------|
      | `/proc` | proc | NOSUID,NOEXEC,NODEV | Process info |
      | `/sys` | sysfs | NOSUID,NOEXEC,NODEV,RDONLY | Device info |
      | `/dev` | devtmpfs | NOSUID,NOEXEC | Device nodes |
      | `/dev/pts` | devpts | NOSUID,NOEXEC | PTY devices |
      | `/dev/shm` | tmpfs | NOSUID,NODEV | Shared memory |
    '|
    style: {
      fill: "#E8EAF6"
      stroke: "#3F51B5"
    }
  }

  device_table: {
    content: |'md
      ## Minimal /dev Nodes
      | Device | Type | Major:Minor | Mode |
      |--------|------|-------------|------|
      | null | char | 1:3 | 0666 |
      | zero | char | 1:5 | 0666 |
      | urandom | char | 1:9 | 0666 |
      | random | char | 1:8 | 0666 |
      | tty | char | 5:0 | 0666 |
    '|
    style: {
      fill: "#FBE9E7"
      stroke: "#E64A19"
    }
  }
}

# --- LEGEND ---
legend_box: {
  label: "FS Component Legend"
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
  }
  mount_legend: "Mount Point" {
    style: {
      fill: "#BBDEFB"
      stroke: "#4A90D9"
    }
  }
  dir_legend: "Static Directory" {
    style: {
      fill: "#DCEDC8"
      stroke: "#7CB342"
    }
  }
  device_legend: "Device Node" {
    shape: parallelogram
    style: {
      fill: "#FFCCBC"
      stroke: "#FF7043"
    }
  }
  optional_legend: "Optional/Dashed" {
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      stroke-dash: 3
    }
  }
}

# --- CONNECTIONS ---
row1.rootfs.dev_entry -> row2.dev_detail: "mount | devtmpfs"
row1.rootfs.etc_entry -> row2.etc_detail: "bind | config"
row2.dev_detail -> row3.device_table: "mknod | static"
row1.rootfs -> row3.mount_table: "fstab | runtime"

legend_box.near: bottom-right