direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Container Network Bridge Topology
  veth pairs connect containers to bridge; NAT enables internet access
| {near: top-center}
external: {
  label: External Network
  style.fill: "#E8F4EA"
  style.stroke: "#34A853"
  style.stroke-width: 2
  internet: {
    label: Internet
    shape: cloud
    style.fill: white
    style.stroke: "#34A853"
  }
  dns: {
    label: "8.8.8.8\n(Google DNS)"
    shape: circle
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
}
host: {
  label: "Host Machine (Linux)"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  direction: down
  host_stack: {
    label: "Host Network Stack"
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
    eth0: {
      label: "eth0\n192.168.1.100"
      shape: rectangle
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
      width: 140
    }
    bridge: {
      label: "Bridge: ctr0\n172.17.0.1/16"
      shape: rectangle
      style.fill: "#64B5F6"
      style.stroke: "#1565C0"
      style.bold: true
      width: 160
    }
    iptables: {
      label: "iptables\nNAT + Forward"
      shape: rectangle
      style.fill: "#FFCC80"
      style.stroke: "#E65100"
      width: 140
    }
  }
  containers: {
    label: "Containers (Network Namespaces)"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-dash: 3
    direction: right
    container1: {
      label: "Container 1\nnetns: c1"
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
      c1_eth0: {
        label: "eth0\n172.17.0.2/16"
        shape: rectangle
        style.fill: "#CE93D8"
        style.stroke: "#7B1FA2"
        width: 120
      }
      c1_route: {
        label: "default via 172.17.0.1"
        shape: rectangle
        style.fill: white
        style.stroke: "#7B1FA2"
        style.stroke-dash: 2
        width: 160
      }
      c1_eth0 -> c1_route
    }
    container2: {
      label: "Container 2\nnetns: c2"
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
      c2_eth0: {
        label: "eth0\n172.17.0.3/16"
        shape: rectangle
        style.fill: "#CE93D8"
        style.stroke: "#7B1FA2"
        width: 120
      }
      c2_route: {
        label: "default via 172.17.0.1"
        shape: rectangle
        style.fill: white
        style.stroke: "#7B1FA2"
        style.stroke-dash: 2
        width: 160
      }
      c2_eth0 -> c2_route
    }
  }
}
veth_pairs: {
  label: "veth Pairs (Virtual Cables)"
  style.fill: transparent
  style.stroke: transparent
  veth1: {
    label: "veth_c1 ↔ eth0@c1"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    width: 130
  }
  veth2: {
    label: "veth_c2 ↔ eth0@c2"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    width: 130
  }
}
# veth connections to bridge
veth_pairs.veth1 -> host.host_stack.bridge: "plugged\ninto bridge" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
veth_pairs.veth2 -> host.host_stack.bridge: "plugged\ninto bridge" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
# veth to containers
host.containers.container1.c1_eth0 -> veth_pairs.veth1: "peer" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 3
}
host.containers.container2.c2_eth0 -> veth_pairs.veth2: "peer" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 3
}
# Bridge to iptables
host.host_stack.bridge -> host.host_stack.iptables: "forward" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
# iptables to eth0
host.host_stack.iptables -> host.host_stack.eth0: "NAT\nMASQUERADE" {
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.animated: true
}
# eth0 to external
host.host_stack.eth0 -> external.internet: "outbound" {
  style.stroke: "#34A853"
  style.stroke-width: 2
}
external.internet -> host.host_stack.eth0: "inbound" {
  style.stroke: "#34A853"
  style.stroke-width: 2
  style.stroke-dash: 3
}
# DNS connection
external.dns -> host.host_stack.eth0: "DNS" {
  style.stroke: "#F9A825"
  style.stroke-dash: 2
}
# Container-to-container via bridge
host.containers.container1.c1_eth0 -> host.containers.container2.c2_eth0: "direct via\nbridge" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  style.stroke-dash: 4
}
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  label: |md
    **Packet Flow:**
    1. **Container-to-Container**: c1 → bridge → c2 (layer 2 switching)
    2. **Container-to-Internet**: c1 → bridge → iptables (SNAT) → eth0 → internet
    3. **Response**: internet → eth0 → iptables (DNAT) → bridge → c1
    **Key Components:**
    - **Bridge (ctr0)**: Virtual switch, learns MACs, forwards frames
    - **veth pairs**: Virtual cables connecting namespaces
    - **iptables NAT**: Rewrites src/dst IPs for external traffic
  |
}
flow_table: {
  near: bottom-right
  label: "Traffic Flow Summary"
  style.fill: "#FFF3E0"
  style.stroke: "#FF6F00"
  c2c: {
    label: "c1 → c2 (172.17.0.2 → .3)"
    shape: rectangle
    style.fill: "#FFE0B2"
  }
  c2i: {
    label: "c1 → internet (SNAT)"
    shape: rectangle
    style.fill: "#FFCC80"
  }
  i2c: {
    label: "internet → c1 (DNAT)"
    shape: rectangle
    style.fill: "#FFB74D"
  }
  c2c.style.stroke: "#9C27B0"
  c2i.style.stroke: "#E65100"
  i2c.style.stroke: "#34A853"
}