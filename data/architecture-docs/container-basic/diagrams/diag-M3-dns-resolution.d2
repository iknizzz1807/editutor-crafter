direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Container DNS Resolution Path
| {near: top-center}
row_application: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  app_layer: {
    direction: down
    label: "APPLICATION LAYER"
    style.fill: "#E8F4FD"
    container_app: {
      label: "Container Application"
      style.fill: "#B6DDF6"
      app_code: {
        label: |'c
// glibc resolver call
struct addrinfo hints = {0};
hints.ai_family = AF_INET;
hints.ai_socktype = SOCK_STREAM;
int rc = getaddrinfo("api.example.com", 
                     "443", &hints, &res);
        '|
        width: 380
      }
    }
    getaddrinfo_call: {
      shape: oval
      label: "getaddrinfo()\n→ glibc resolver"
      style.fill: "#FFE4B5"
    }
  }
}
row_resolv: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  resolv_layer: {
    direction: down
    label: "DNS CONFIGURATION"
    style.fill: "#F0FFF0"
    resolv_approaches: {
      direction: right
      approach_bind: {
        label: "Option A: Bind-Mount"
        style.fill: "#90EE90"
        style.stroke-dash: 3
        host_resolv: {
          shape: document
          label: "/etc/resolv.conf\n(host)"
          width: 140
        }
        container_resolv_bind: {
          shape: document
          label: "/etc/resolv.conf\n(container)"
          width: 140
          style.fill: "#98FB98"
        }
        host_resolv -> container_resolv_bind: "MS_BIND\nmount" {
          style.stroke: "#228B22"
          style.stroke-width: 2
        }
      }
      approach_gen: {
        label: "Option B: Generated"
        style.fill: "#87CEEB"
        runtime_gen: {
          shape: parallelogram
          label: "Container Runtime\ngenerates file"
          width: 160
        }
        container_resolv_gen: {
          shape: document
          label: "/etc/resolv.conf\n(container)"
          width: 140
          style.fill: "#ADD8E6"
        }
        runtime_gen -> container_resolv_gen: "write()" {
          style.stroke: "#4169E1"
        }
      }
    }
    resolv_content: {
      label: "resolv.conf Contents"
      style.fill: "#FFFACD"
      width: 300
      content: |'plaintext
# /etc/resolv.conf (inside container)
nameserver 10.200.0.1    # Bridge IP (DNS proxy)
# OR
nameserver 8.8.8.8       # External DNS
nameserver 8.8.4.4
search cluster.local
      '|
    }
  }
}
row_network: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  network_layer: {
    direction: down
    label: "NETWORK TRANSPORT"
    style.fill: "#FFE4E1"
    dns_query: {
      label: "DNS Query Construction"
      style.fill: "#FFA07A"
      query_detail: {
        shape: class
        label: "DNS Query (UDP/53)"
        src_ip: "10.200.0.2"
        dst_ip: "10.200.0.1"
        dst_port: "53"
        query: "api.example.com A?"
      }
    }
    bridge_layer: {
      direction: right
      bridge: {
        shape: hexagon
        label: "ctr0 Bridge\n10.200.0.1"
        style.fill: "#DDA0DD"
      }
      dns_proxy: {
        label: "DNS Proxy Options"
        style.fill: "#E6E6FA"
        proxy_options: |md
**dnsmasq** (common)
- Caches queries
- Forwards to upstream
**systemd-resolved**
- Per-namespace DNS
- Split DNS support
**Direct forward**
- No proxy layer
- Container → external
        |
      }
    }
    bridge -> dns_proxy: "intercept\nor forward" {
      style.stroke-dash: 4
    }
  }
}
row_external: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  external_layer: {
    direction: down
    label: "EXTERNAL RESOLUTION"
    style.fill: "#F5F5DC"
    nat_layer: {
      label: "NAT/Masquerade"
      style.fill: "#DEB887"
      nat_detail: {
        shape: class
        label: "iptables NAT"
        prerouting: "10.200.0.2:random"
        postrouting: "192.168.1.100:random"
        target: "8.8.8.8:53"
      }
    }
    external_dns: {
      direction: right
      google_dns: {
        shape: cylinder
        label: "Google DNS\n8.8.8.8"
        style.fill: "#4285F4"
        style.font-color: white
      }
      cloudflare_dns: {
        shape: cylinder
        label: "Cloudflare\n1.1.1.1"
        style.fill: "#F38020"
        style.font-color: white
      }
    }
  }
}
row_response: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  response_layer: {
    direction: down
    label: "DNS RESPONSE"
    style.fill: "#98FB98"
    response_packet: {
      label: "DNS Response"
      style.fill: "#3CB371"
      style.font-color: white
      response_detail: |'plaintext
Query: api.example.com IN A
Answer: api.example.com 300 IN A 93.184.216.34
      '|
    }
    result_cache: {
      label: "glibc Resolver Cache"
      style.fill: "#2E8B57"
      style.font-color: white
      cache_note: |md
- TTL-based caching
- /etc/gai.conf config
- nscd may interfere
      |
    }
  }
}
// Vertical flow connections
row_application.app_layer.container_app -> row_application.app_layer.getaddrinfo_call: "1. call" {
  style.stroke: "#333"
}
row_application.app_layer.getaddrinfo_call -> row_resolv.resolv_layer.resolv_approaches.approach_bind.container_resolv_bind: "2. read config" {
  style.stroke: "#333"
  style.stroke-dash: 3
}
row_application.app_layer.getaddrinfo_call -> row_resolv.resolv_layer.resolv_approaches.approach_gen.container_resolv_gen: "2. read config" {
  style.stroke: "#333"
  style.stroke-dash: 3
}
row_resolv.resolv_layer.resolv_content -> row_network.network_layer.dns_query: "3. nameserver IP" {
  style.stroke: "#006400"
}
row_network.network_layer.dns_query -> row_network.network_layer.bridge_layer.bridge: "4. UDP to 10.200.0.1:53" {
  style.stroke: "#8B0000"
  style.animated: true
}
row_network.network_layer.bridge_layer.bridge -> row_external.external_layer.nat_layer: "5. NAT + forward" {
  style.stroke: "#8B0000"
  style.animated: true
}
row_external.external_layer.nat_layer -> row_external.external_layer.external_dns.google_dns: "6. query" {
  style.stroke: "#8B0000"
  style.animated: true
}
row_external.external_layer.external_dns.google_dns -> row_response.response_layer.response_packet: "7. response" {
  style.stroke: "#006400"
  style.animated: true
  style.stroke-dash: 4
}
row_response.response_layer.response_packet -> row_application.app_layer.container_app: "8. return IP" {
  style.stroke: "#006400"
  style.stroke-dash: 4
}
// Legend
legend: {
  near: bottom-right
  style.fill: "#F9F9F9"
  style.stroke: "#CCC"
  legend_title: "DNS Resolution Approaches"
  legend_bind: "Bind-mount: Host DNS config shared with container"
  legend_gen: "Generated: Runtime creates container-specific config"
  legend_bind.style.fill: "#90EE90"
  legend_gen.style.fill: "#87CEEB"
  note: |md
**Key Considerations:**
- Bind-mount: Inherits host DNS changes dynamically
- Generated: Isolated, but must handle updates
- Bridge IP proxy: Enables DNS caching/interception
- Direct external: Simpler, no caching layer
  |
}