direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # NAT MASQUERADE: Container to Internet
  Packet flow from container (172.17.0.2) → internet (8.8.8.8)
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  container: {
    label: "Container\nNamespace"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    app: {
      shape: rectangle
      label: "Application\n(curl google.com)"
      style.fill: "#C8E6C9"
    }
    eth0: {
      shape: rectangle
      label: "eth0\n172.17.0.2"
      style.fill: "#A5D6A7"
    }
    app -> eth0: "SYN → 8.8.8.8:80\nsrc: 172.17.0.2:45678"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  veth_pair: {
    label: "veth Pair\n(Virtual Cable)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    veth_c: {
      shape: rectangle
      label: "vethxxx\n(in container ns)"
      style.fill: "#FFE0B2"
    }
    veth_h: {
      shape: rectangle
      label: "vethyyy\n(on host)"
      style.fill: "#FFE0B2"
    }
    veth_c <-> veth_h: "tunnel" {
      style.stroke-dash: 3
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  host: {
    label: "Host Network Stack"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    bridge: {
      shape: rectangle
      label: "docker0/ctr0\n172.17.0.1"
      style.fill: "#BBDEFB"
    }
    iptables: {
      shape: rectangle
      label: "iptables\nNAT Table"
      style.fill: "#90CAF9"
    }
    eth0_host: {
      shape: rectangle
      label: "eth0\n192.168.1.100"
      style.fill: "#64B5F6"
    }
    bridge -> iptables: "FORWARD chain"
    iptables -> eth0_host: "POSTROUTING chain"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  internet: {
    label: "Internet"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    google_dns: {
      shape: rectangle
      label: "8.8.8.8\n(Google DNS)"
      style.fill: "#E1BEE7"
    }
    web_server: {
      shape: rectangle
      label: "Web Server\n(google.com)"
      style.fill: "#CE93D8"
    }
  }
}
# Vertical connections
container.eth0 -> veth_pair.veth_c: "egress" {style.stroke: "#4CAF50"}
veth_pair.veth_h -> host.bridge: "ingress" {style.stroke: "#FF9800"}
host.eth0_host -> internet.web_server: "→ 8.8.8.8:80\nsrc: 192.168.1.100:45678\n(AFTER NAT)" {
  style.stroke: "#2196F3"
  style.bold: true
}
# Return path
internet.web_server -> host.eth0_host: "← response\ndst: 192.168.1.100:45678" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
# Packet transformation detail
packet_detail: {
  label: "Packet Transformation"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  before: {
    label: "BEFORE NAT (inside container)"
    shape: rectangle
    style.fill: "#FFEBEE"
    src_before: "src: 172.17.0.2:45678"
    dst_before: "dst: 8.8.8.8:80"
  }
  after: {
    label: "AFTER MASQUERADE (on wire)"
    shape: rectangle
    style.fill: "#E8F5E9"
    src_after: "src: 192.168.1.100:45678"
    dst_after: "dst: 8.8.8.8:80"
  }
  before -> after: "POSTROUTING\nMASQUERADE" {
    style.stroke: "#F44336"
    style.bold: true
  }
}
# iptables chain flow
iptables_flow: {
  label: "iptables NAT Chain Traversal"
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  prerouting: {
    shape: diamond
    label: "PREROUTING\n(DNAT)"
    style.fill: "#FFF9C4"
  }
  routing: {
    shape: oval
    label: "Routing\nDecision"
    style.fill: "#FFF59D"
  }
  forward: {
    shape: rectangle
    label: "FORWARD\n(filter)"
    style.fill: "#FFF176"
  }
  postrouting: {
    shape: hexagon
    label: "POSTROUTING\n(MASQUERADE)"
    style.fill: "#FFEE58"
    style.stroke: "#F44336"
    style.bold: true
  }
  prerouting -> routing
  routing -> forward
  forward -> postrouting
}
# MASQUERADE rule
masq_rule: {
  label: "MASQUERADE Rule"
  shape: code
  code: |'bash
    # iptables NAT rule
    iptables -t nat -A POSTROUTING \
      -s 172.17.0.0/16 \
      ! -o docker0 \
      -j MASQUERADE
    # Rewrites source IP to
    # outbound interface IP
  '|
  style.fill: "#ECEFF1"
}
# Connection tracking
conntrack: {
  label: "Connection Tracking (conntrack)"
  style.fill: "#E0F7FA"
  style.stroke: "#00BCD4"
  table: {
    shape: sql_table
    label: "conntrack entry"
    orig_src: "orig_src | 172.17.0.2:45678"
    orig_dst: "orig_dst | 8.8.8.8:80"
    reply_src: "reply_src | 8.8.8.8:80"
    reply_dst: "reply_dst | 192.168.1.100:45678"
    state: "state | ESTABLISHED"
  }
  note: "Kernel tracks connection\nfor reverse NAT on response"
}
# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  dir: "Direction"
  dir_out: "Outbound (request)" {style.fill: "#4CAF50"}
  dir_in: "Inbound (response)" {style.fill: "#9C27B0"}
  transform: "IP Transformation"
  t_before: "Private IP (container)" {style.fill: "#FFEBEE"}
  t_after: "Public IP (host)" {style.fill: "#E8F5E9"}
}