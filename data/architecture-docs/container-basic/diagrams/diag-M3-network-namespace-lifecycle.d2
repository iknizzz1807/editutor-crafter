direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Network Namespace Lifecycle" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  step1: {
    label: "1. Create Namespace"
    width: 280
    code: |'c
      unshare(CLONE_NEWNET);
      // OR
      clone(..., CLONE_NEWNET, ...);
    '|
    style.fill: "#E8F5E9"
  }
  step2: {
    label: "2. Initial State"
    width: 280
    code: |'c
      // Only lo exists (DOWN)
      // No routes, no connectivity
      $ ip link show
      1: lo: <LOOPBACK> mtu ...
        link/loopback 00:00:00...
    '|
    style.fill: "#FFF3E0"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  step3: {
    label: "3. Create veth Pair"
    width: 280
    code: |'c
      // In host namespace
      ip link add veth0 
        type veth 
        peer name veth1
      // Creates virtual cable
      // veth0 <-> veth1
    '|
    style.fill: "#E3F2FD"
  }
  step4: {
    label: "4. Move to Namespace"
    width: 280
    code: |'c
      // Move veth1 to container
      ip link set veth1 
        netns <container_pid>
      // Rename inside namespace
      ip link set veth1 
        name eth0
    '|
    style.fill: "#E3F2FD"
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  step5: {
    label: "5. Configure Network"
    width: 280
    code: |'c
      // Inside container namespace:
      ip link set lo up
      ip link set eth0 up
      ip addr add 10.0.0.2/24 
        dev eth0
      ip route add default 
        via 10.0.0.1
    '|
    style.fill: "#F3E5F5"
  }
  step6: {
    label: "6. Bridge Attachment"
    width: 280
    code: |'c
      // Host side:
      ip link set veth0 
        master br0
      ip link set veth0 up
      // Bridge becomes gateway
      // br0: 10.0.0.1
    '|
    style.fill: "#F3E5F5"
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  step7: {
    label: "7. Container Exec"
    width: 280
    code: |'c
      // Process runs with full
      // network isolation
      execvp(argv[0], argv);
      // Container has:
      // - Own IP (10.0.0.2)
      // - Own routes
      // - Own iptables
    '|
    style.fill: "#C8E6C9"
  }
  step8: {
    label: "8. Cleanup"
    width: 280
    code: |'c
      // Kill container process
      kill(pid, SIGTERM);
      // Delete veth pair
      ip link del veth0
      // Namespace auto-destroyed
      // when last process exits
    '|
    style.fill: "#FFCDD2"
  }
}
step1 -> step2: "namespace\ncreated"
step2 -> step3: "parent\nsetup"
step3 -> step4: "veth pair\nexists"
step4 -> step5: "veth in\ntarget ns"
step5 -> step6: "configured\ninside"
step6 -> step7: "bridge\nattached"
step7 -> step8: "container\nexits"
legend: {
  near: bottom-center
  label: "Lifecycle Phases"
  phase1: "1-2: Creation" {
    style.fill: "#E8F5E9"
  }
  phase2: "3-4: veth Setup" {
    style.fill: "#E3F2FD"
  }
  phase3: "5-6: Configuration" {
    style.fill: "#F3E5F5"
  }
  phase4: "7: Runtime" {
    style.fill: "#C8E6C9"
  }
  phase5: "8: Cleanup" {
    style.fill: "#FFCDD2"
  }
}