direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # cgroup Cleanup Order: Why rmdir Fails
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  success_path: {
    direction: down
    label: "SUCCESS PATH"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    s1: {
      shape: circle
      label: "Container\nRunning"
      style.fill: "#BBDEFB"
    }
    s2: {
      shape: rectangle
      label: "1. Send SIGTERM\nto container init"
      width: 180
    }
    s3: {
      shape: diamond
      label: "All processes\nexited?"
    }
    s4: {
      shape: rectangle
      label: "2. Verify\ncgroup.procs empty"
      width: 180
    }
    s5: {
      shape: rectangle
      label: "3. rmdir(cgroup_path)\n→ returns 0"
      width: 180
      style.fill: "#C8E6C9"
    }
    s6: {
      shape: circle
      label: "Cleanup\nComplete"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    s1 -> s2: "terminate"
    s2 -> s3: "wait"
    s3 -> s4: "Yes" {
      style.stroke: "#4CAF50"
    }
    s4 -> s5: "empty"
    s5 -> s6: "success"
  }
  failure_path: {
    direction: down
    label: "FAILURE CASE"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    f1: {
      shape: circle
      label: "Container\nRunning"
      style.fill: "#BBDEFB"
    }
    f2: {
      shape: rectangle
      label: "rmdir(cgroup_path)\nPREMATURE"
      width: 180
      style.fill: "#FFCDD2"
    }
    f3: {
      shape: rectangle
      label: "Returns: -1\nerrno = EBUSY"
      width: 180
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.bold: true
    }
    f4: {
      shape: rectangle
      label: "Kernel: cgroup\nstill has tasks"
      width: 180
    }
    f1 -> f2: "skip wait" {
      style.stroke-dash: 4
      style.stroke: "#F44336"
    }
    f2 -> f3: "fails" {
      style.stroke: "#F44336"
    }
    f3 -> f4: "reason"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  crash_recovery: {
    direction: down
    label: "CRASH RECOVERY"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    c1: {
      shape: circle
      label: "Container\nCrashed"
      style.fill: "#FFE0B2"
    }
    c2: {
      shape: rectangle
      label: "Check cgroup.procs\nfor zombies"
      width: 180
    }
    c3: {
      shape: diamond
      label: "Zombies\nexist?"
    }
    c4: {
      shape: rectangle
      label: "kill -9 all PIDs\nfrom cgroup.procs"
      width: 180
      style.fill: "#FFCC80"
    }
    c5: {
      shape: rectangle
      label: "Wait 1-2s\nfor kernel cleanup"
      width: 180
    }
    c6: {
      shape: rectangle
      label: "rmdir(cgroup_path)\n→ success"
      width: 180
      style.fill: "#C8E6C9"
    }
    c1 -> c2: "detect"
    c2 -> c3: "scan"
    c3 -> c4: "Yes" {
      style.stroke: "#FF9800"
    }
    c4 -> c5: "forced"
    c5 -> c6: "then"
    c3 -> c6: "No" {
      style.stroke: "#4CAF50"
    }
  }
  code_ref: {
    direction: down
    label: "Cleanup Code Pattern (cgroup.c)"
    style.fill: "#E3F2FD"
    check_empty: {
      label: "Check if cgroup empty"
      width: 350
      code: |'c
        int cgroup_is_empty(const char *path) {
            char procs_path[512];
            snprintf(procs_path, sizeof(procs_path),
                     "%s/cgroup.procs", path);
            FILE *f = fopen(procs_path, "r");
            if (!f) return 1;
            int pid;
            int empty = (fscanf(f, "%d", &pid) != 1);
            fclose(f);
            return empty;
        }
      '|
    }
    cleanup_func: {
      label: "Safe cleanup sequence"
      width: 350
      code: |'c
        int remove_cgroup(const char *path) {
            // Wait for processes to exit
            int retries = 10;
            while (!cgroup_is_empty(path) && retries > 0) {
                sleep(1);
                retries--;
            }
            // Force kill if still not empty
            if (!cgroup_is_empty(path)) {
                kill_all_in_cgroup(path);
                sleep(1);
            }
            return rmdir(path);  // Now safe
        }
      '|
    }
    check_empty -> cleanup_func: "called by"
  }
}
row1.success_path.s3 -> row1.failure_path.f2: "No\n(premature)" {
  style.stroke-dash: 4
  style.stroke: "#F44336"
}
legend: {
  near: bottom-center
  style.fill: transparent
  label: ""
  legend_content: {
    direction: right
    green_box: {
      label: "Success"
      style.fill: "#C8E6C9"
      width: 80
    }
    red_box: {
      label: "Error (EBUSY)"
      style.fill: "#FFCDD2"
      width: 100
    }
    orange_box: {
      label: "Recovery"
      style.fill: "#FFCC80"
      width: 80
    }
  }
}
error_codes: {
  near: bottom-right
  label: "Common Errors"
  ebusy: {
    shape: sql_table
    label: "rmdir() Error Codes"
    e1: "EBUSY | cgroup has processes or child cgroups"
    e2: "ENOENT | cgroup path does not exist"
    e3: "EPERM | permission denied (not owner)"
    e4: "ENOTEMPTY | contains child cgroups"
  }
}