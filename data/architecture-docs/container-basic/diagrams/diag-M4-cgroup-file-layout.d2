direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # cgroup v2 File Layout for Container
  Directory structure under `/sys/fs/cgroup/` with read/write semantics
| {near: top-center}
sys_fs_cgroup: {
  label: "/sys/fs/cgroup/"
  style.fill: "#E8F4E8"
  style.stroke: "#4A7C59"
  container_runtime: {
    label: "container-runtime/"
    style.fill: "#D4E8D4"
    style.stroke: "#4A7C59"
    container_id: {
      label: "container-id/"
      style.fill: "#B8D4B8"
      style.stroke: "#4A7C59"
      style.stroke-width: 2
      # Core cgroup files
      cgroup_procs: {
        shape: sql_table
        label: "cgroup.procs"
        desc: "Process IDs in this cgroup"
        f1: "Read | List of PIDs"
        f2: "Write | Add PID to cgroup"
        rw: "RW: Process membership"
      }
      cgroup_subtree: {
        shape: sql_table
        label: "cgroup.subtree_control"
        desc: "Controllers enabled for children"
        f1: "Read | Enabled controllers"
        f2: "Write | +cpu +memory +pids"
        rw: "RW: Controller delegation"
      }
      # Memory controller files
      memory_max: {
        shape: sql_table
        label: "memory.max"
        desc: "Hard memory limit (bytes)"
        f1: "Read | Current limit value"
        f2: "Write | Set limit (e.g., 100M)"
        rw: "RW: OOM trigger threshold"
      }
      memory_max.style.fill: "#FFE4E1"
      memory_current: {
        shape: sql_table
        label: "memory.current"
        desc: "Current memory usage"
        f1: "Read | Bytes in use"
        f2: "Write | N/A"
        rw: "RO: Usage monitoring"
      }
      memory_current.style.fill: "#E6E6FA"
      # CPU controller files
      cpu_max: {
        shape: sql_table
        label: "cpu.max"
        desc: "CPU bandwidth limit"
        f1: "Read | quota period (μs)"
        f2: "Write | 50000 100000"
        rw: "RW: Throttle threshold"
      }
      cpu_max.style.fill: "#FFE4E1"
      cpu_stat: {
        shape: sql_table
        label: "cpu.stat"
        desc: "CPU usage statistics"
        f1: "Read | usage_usec, throttled"
        f2: "Write | N/A"
        rw: "RO: Performance metrics"
      }
      cpu_stat.style.fill: "#E6E6FA"
      # PIDs controller files
      pids_max: {
        shape: sql_table
        label: "pids.max"
        desc: "Maximum process count"
        f1: "Read | Current limit"
        f2: "Write | Set limit (e.g., 100)"
        rw: "RW: Fork bomb prevention"
      }
      pids_max.style.fill: "#FFE4E1"
    }
  }
}
# Legend
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: "#666666"
  style.stroke-dash: 3
  rw_label: "Legend:" {shape: text}
  rw_files: {
    label: "Read/Write Files"
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
  }
  ro_files: {
    label: "Read-Only Files"
    style.fill: "#E6E6FA"
    style.stroke: "#6A5ACD"
  }
  note: |md
    **RW (Red)**: Configure limits — writes enforce kernel constraints  
    **RO (Purple)**: Monitor usage — read current state and statistics
  |
}
# Semantic annotations
annotation_write: {
  label: |md
    ### Write Semantics
    - `echo $PID > cgroup.procs` — Move process into cgroup
    - `echo 100M > memory.max` — Set 100MB hard limit
    - `echo "50000 100000" > cpu.max` — 50% CPU (50ms/100ms)
    - `echo 100 > pids.max` — Max 100 processes
  |
  near: top-right
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
}
annotation_read: {
  label: |md
    ### Read Semantics
    - `cat memory.current` — Current bytes allocated
    - `cat cpu.stat` — Usage, throttle count, throttle time
    - `cat cgroup.procs` — List of PIDs in cgroup
  |
  near: bottom-right
  style.fill: "#F0F8FF"
  style.stroke: "#4682B4"
}