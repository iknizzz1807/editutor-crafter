direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  label: "cgroups v1 vs v2 Hierarchy Comparison"
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
comparison: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  v1_container: "cgroups v1 (Legacy)" {
    direction: down
    style: {
      fill: "#FFF0F0"
      stroke: "#CC6666"
      stroke-width: 2
    }
    v1_desc: |md
      **Multiple Independent Hierarchies**
      Each controller has its own mount point.
      Process can be in different cgroups per controller.
    | {
      style.fill: transparent
      style.stroke: transparent
    }
    sys_fs_v1: "/sys/fs/cgroup" {
      direction: down
      style: {
        fill: "#F5F5F5"
        stroke: "#999999"
      }
      memory_dir: "memory/" {
        direction: down
        style: {
          fill: "#FFE4E1"
          stroke: "#CD5C5C"
        }
        mem_label: "memory controller" {
          shape: text
          style.italic: true
          style.font-size: 11
        }
        mem_limit: "memory.limit_in_bytes"
        mem_usage: "memory.usage_in_bytes"
        mem_procs: "cgroup.procs"
        mem_tasks: "tasks"
        container1_mem: "container_a/" {
          style.fill: "#FFFFFF"
        }
      }
      cpu_dir: "cpu/" {
        direction: down
        style: {
          fill: "#E6E6FA"
          stroke: "#9370DB"
        }
        cpu_label: "cpu controller" {
          shape: text
          style.italic: true
          style.font-size: 11
        }
        cpu_quota: "cpu.cfs_quota_us"
        cpu_period: "cpu.cfs_period_us"
        cpu_procs: "cgroup.procs"
        cpu_tasks: "tasks"
        container1_cpu: "container_a/" {
          style.fill: "#FFFFFF"
        }
      }
      cpuacct_dir: "cpuacct/" {
        direction: down
        style: {
          fill: "#E0FFFF"
          stroke: "#20B2AA"
        }
        cpuacct_label: "cpu accounting" {
          shape: text
          style.italic: true
          style.font-size: 11
        }
        cpuacct_usage: "cpuacct.usage"
        cpuacct_procs: "cgroup.procs"
      }
      blkio_dir: "blkio/" {
        direction: down
        style: {
          fill: "#F0FFF0"
          stroke: "#3CB371"
        }
        blkio_label: "block I/O" {
          shape: text
          style.italic: true
          style.font-size: 11
        }
        blkio_weight: "blkio.weight"
        blkio_procs: "cgroup.procs"
      }
      pids_dir: "pids/" {
        direction: down
        style: {
          fill: "#FFFACD"
          stroke: "#DAA520"
        }
        pids_label: "pids controller" {
          shape: text
          style.italic: true
          style.font-size: 11
        }
        pids_max: "pids.max"
        pids_current: "pids.current"
      }
    }
    v1_problem: |md
      **Problem:** Process 1234 must be added to
      SEPARATE cgroups for each controller:
      - /sys/fs/cgroup/memory/container_a/cgroup.procs
      - /sys/fs/cgroup/cpu/container_a/cgroup.procs
      - /sys/fs/cgroup/blkio/container_a/cgroup.procs
    | {
      style: {
        fill: "#FFEEEE"
        stroke: "#CC6666"
        stroke-dash: 3
      }
    }
  }
  spacer: "" {
    width: 60
    style: {
      fill: transparent
      stroke: transparent
    }
  }
  v2_container: "cgroups v2 (Unified)" {
    direction: down
    style: {
      fill: "#F0FFF0"
      stroke: "#228B22"
      stroke-width: 2
    }
    v2_desc: |md
      **Single Unified Hierarchy**
      All controllers share one tree.
      Process in exactly ONE cgroup.
    | {
      style.fill: transparent
      style.stroke: transparent
    }
    sys_fs_v2: "/sys/fs/cgroup" {
      direction: down
      style: {
        fill: "#F5F5F5"
        stroke: "#228B22"
      }
      root_files: "Root Interface Files" {
        direction: down
        style.fill: "#E8F5E9"
        cgroup_controllers: "cgroup.controllers: cpuset cpu io memory pids"
        cgroup_procs: "cgroup.procs: (host processes)"
      }
      subtree_control: |md
        **subtree_control**
        Enables controllers for children:
        `echo "+memory +cpu +pids" > subtree_control`
      | {
        style: {
          fill: "#C8E6C9"
          stroke: "#4CAF50"
          stroke-width: 2
        }
      }
      container_root: "container_a/" {
        direction: down
        style: {
          fill: "#E8F5E9"
          stroke: "#4CAF50"
        }
        cgroup_procs_v2: "cgroup.procs: 1234"
        mem_max: "memory.max: 100M"
        mem_high: "memory.high: 80M"
        mem_current: "memory.current: (usage)"
        cpu_max: "cpu.max: 50000 100000"
        cpu_stat: "cpu.stat: (throttling info)"
        pids_max_v2: "pids.max: 100"
        pids_current_v2: "pids.current: 5"
        nested: "nested_child/" {
          direction: down
          style.fill: "#F1F8E9"
          nested_procs: "cgroup.procs"
          nested_mem: "memory.max"
        }
      }
      container_b: "container_b/" {
        direction: down
        style: {
          fill: "#E8F5E9"
          stroke: "#4CAF50"
        }
        cb_procs: "cgroup.procs: 5678"
        cb_mem: "memory.max: 200M"
        cb_cpu: "cpu.max: 100000 100000"
      }
    }
    v2_benefit: |md
      **Benefit:** Process 1234 added ONCE:
      `/sys/fs/cgroup/container_a/cgroup.procs`
      All controllers apply automatically!
    | {
      style: {
        fill: "#E8F5E9"
        stroke: "#228B22"
      }
    }
  }
}
flow_section: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  v1_flow: "v1 Controller Enablement" {
    direction: down
    style: {
      fill: "#FFF0F0"
      stroke: "#CC6666"
    }
    v1_mount: "mount -t cgroup -o memory none /sys/fs/cgroup/memory"
    v1_mount2: "mount -t cgroup -o cpu none /sys/fs/cgroup/cpu"
    v1_mount3: "mount -t cgroup -o blkio none /sys/fs/cgroup/blkio"
    v1_note: |md
      Each controller requires separate mount.
      No delegation possible.
    | {
      style.fill: transparent
      style.stroke: transparent
    }
  }
  flow_spacer: "" {
    width: 60
    style: {
      fill: transparent
      stroke: transparent
    }
  }
  v2_flow: "v2 Controller Enablement Flow" {
    direction: down
    style: {
      fill: "#F0FFF0"
      stroke: "#228B22"
    }
    v2_step1: "1. Check available controllers" {
      code: |'bash
cat /sys/fs/cgroup/cgroup.controllers
# Output: cpuset cpu io memory pids
      '|
    }
    v2_step2: "2. Enable for children (in parent)" {
      code: |'bash
echo "+memory +cpu +pids" > \
  /sys/fs/cgroup/cgroup.subtree_control
      '|
    }
    v2_step3: "3. Create child cgroup" {
      code: |'bash
mkdir /sys/fs/cgroup/container_a
# Interface files auto-created by kernel
      '|
    }
    v2_step4: "4. Set limits and add process" {
      code: |'bash
echo 100M > container_a/memory.max
echo 50 100 > container_a/cpu.max
echo 1234 > container_a/cgroup.procs
      '|
    }
    v2_delegate: "5. Delegation (rootless)" {
      code: |'bash
# Enable delegation for unprivileged user
chown -R 1000:1000 container_a/
# User can now manage their own cgroup
      '|
    }
  }
}
legend: "" {
  near: bottom-center
  direction: right
  style: {
    fill: "#F9F9F9"
    stroke: "#CCCCCC"
    stroke-dash: 3
  }
  legend_title: "Key Differences:" {
    shape: text
    style.bold: true
  }
  v1_bad: "v1: Process in N cgroups (one per controller)" {
    style: {
      fill: "#FFEEEE"
      stroke: "#CC6666"
    }
  }
  v2_good: "v2: Process in 1 cgroup (all controllers unified)" {
    style: {
      fill: "#E8F5E9"
      stroke: "#228B22"
    }
  }
  thread_support: "v2: Thread mode (cgroup.threads) for fine-grained control" {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
    }
  }
}
v1_flow -> v2_flow: "Modern Standard | migrate" {
  style: {
    stroke: "#228B22"
    stroke-width: 3
    animated: true
  }
}