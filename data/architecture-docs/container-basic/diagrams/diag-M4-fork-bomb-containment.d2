direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # pids.max: Fork Bomb Containment
| {near: top-center}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: "WITHOUT pids.max" {
    direction: down
    style.fill: "#2d1b1b"
    style.stroke: "#8b0000"
    style.stroke-width: 3
    fork_bomb_unlimited: {
      label: "Fork Bomb Process"
      shape: code
      code: |'c
        while(1) {
          fork();  // Exponential growth
        }
      '|
      style.fill: "#8b0000"
      style.font-color: white
    }
    host_procs_unlimited: {
      label: "Host Process Table"
      shape: sql_table
      f0: "PID 1 | systemd"
      f1: "PID 2 | kthreadd"
      f2: "PID 100 | fork_child"
      f3: "PID 101 | fork_child"
      f4: "PID 102 | fork_child"
      f5: "..."
      f6: "PID 32767 | fork_child"
      exhausted: "EXHAUSTED: No PIDs left!"
      style.fill: "#1a0a0a"
      style.font-color: "#ff6b6b"
    }
    result_bad: {
      label: "Result: HOST UNRESPONSIVE"
      style.fill: "#8b0000"
      style.font-color: white
      style.bold: true
    }
    fork_bomb_unlimited -> host_procs_unlimited: "Unlimited forks"
    host_procs_unlimited -> result_bad: "pid_max reached"
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after: "WITH pids.max=100" {
    direction: down
    style.fill: "#1b2d1b"
    style.stroke: "#228b22"
    style.stroke-width: 3
    cgroup_box: {
      label: "Container cgroup\npids.max=100"
      style.fill: "#2d4a2d"
      style.stroke: "#228b22"
      style.stroke-dash: 4
      fork_bomb_limited: {
        label: "Fork Bomb Process"
        shape: code
        code: |'c
          while(1) {
            if (fork() == -1) {
              // EAGAIN: Resource limit
              break;
            }
          }
        '|
        style.fill: "#4a7c4a"
        style.font-color: white
      }
      contained_procs: {
        label: "cgroup Process Table"
        shape: sql_table
        f0: "PID 1 | init"
        f1: "PID 2 | fork_child"
        f2: "PID 3 | fork_child"
        f3: "..."
        f4: "PID 100 | fork_child"
        limit: "pids.current: 100/100"
        style.fill: "#1a2d1a"
        style.font-color: "#90ee90"
      }
    }
    host_safe: {
      label: "Host Process Table"
      shape: sql_table
      h0: "PID 1 | systemd"
      h1: "PID 2 | kthreadd"
      h2: "PID 12345 | container"
      h3: "PID 12346-12445 | cgroup procs"
      h4: "... | other host processes"
      status: "HEALTHY: Plenty of PIDs"
      style.fill: "#1a2d1a"
      style.font-color: "#90ee90"
    }
    result_good: {
      label: "Result: HOST STABLE"
      style.fill: "#228b22"
      style.font-color: white
      style.bold: true
    }
    fork_bomb_limited -> contained_procs: "Forks until limit"
    contained_procs -> host_safe: "Contained to 100 PIDs"
    host_safe -> result_good: "Host unaffected"
  }
}
arrow_between: |md
  ## 
| {
  near: center-left
}
row_before -> row_after: "Add cgroup pids.max" {
  style.stroke: "#4a90d9"
  style.stroke-width: 3
  style.animated: true
}
syscall_box: {
  direction: right
  label: "Kernel Enforcement"
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  fork_call: {
    label: "fork() Syscall Path"
    direction: down
    shape: rectangle
    step1: "1. Process calls fork()"
    step2: "2. kernel checks pids.current"
    step3: "3. pids.current >= pids.max?"
    step4: "4. Return -1, errno=EAGAIN"
    step1 -> step2 -> step3 -> step4
  }
  code_result: {
    label: "Application Code"
    shape: code
    code: |'c
      pid_t pid = fork();
      if (pid == -1) {
        if (errno == EAGAIN) {
          // Resource limit exceeded
          fprintf(stderr, 
            "Process limit reached\n");
          exit(1);
        }
      }
    '|
    style.fill: "#2d2d4a"
  }
  fork_call -> code_result: "EAGAIN"
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  red_box: {
    label: "Without Limit"
    style.fill: "#8b0000"
    style.font-color: white
    width: 120
  }
  green_box: {
    label: "With pids.max"
    style.fill: "#228b22"
    style.font-color: white
    width: 120
  }
  red_box -> green_box: "Protection"
}