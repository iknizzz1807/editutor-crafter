direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  label: "Capability Scoping in User Namespaces"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  userns: {
    direction: down
    label: "User Namespace"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    container_root: {
      label: "Container Root (UID 0)"
      shape: circle
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
    }
    caps_inside: {
      label: "Capabilities VALID Inside Namespace"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      width: 280
      cap1: "CAP_SYS_ADMIN"
      cap2: "CAP_NET_ADMIN"
      cap3: "CAP_MKNOD"
      cap4: "CAP_SYS_CHROOT"
      cap5: "CAP_SETUID/CAP_SETGID"
    }
    container_root -> caps_inside: "has"
  }
  host_space: {
    direction: down
    label: "Host System"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 3
    host_root: {
      label: "Host Root (UID 0)"
      shape: circle
      style.fill: "#EF9A9A"
      style.stroke: "#C62828"
    }
    host_caps: {
      label: "Global Capabilities"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      width: 280
      hcap1: "CAP_SYS_MODULE"
      hcap2: "CAP_SYS_TIME"
      hcap3: "CAP_SYS_RAWIO"
      hcap4: "CAP_SYS_BOOT"
      hcap5: "All kernel capabilities"
    }
    host_root -> host_caps: "has"
  }
}
ns_boundary: {
  label: "Namespace Boundary\n(Capability Translation)"
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
  width: 200
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  translation: {
    direction: down
    label: "UID Translation Table"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    uid_map: {
      shape: sql_table
      label: "/proc/<pid>/uid_map"
      col1: "nsid | hostid | count"
      row1: "0    | 1000   | 1"
      total: "Container 0 → Host 1000"
    }
  }
  setuid_drop: {
    direction: down
    label: "Capability Drop on execve()"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-dash: 4
    width: 320
    code: |'c
      // setuid binaries LOSE namespace caps
      // Kernel clears ambient capabilities
      if (file_has_setuid_bit) {
          clear_namespace_capabilities();
          // Container "root" cannot escalate
          // via setuid binaries
      }
    '|
  }
}
result_box: {
  label: "Security Result"
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  width: 700
  item1: "✓ Mount operations scoped to mount namespace"
  item2: "✓ Network config scoped to network namespace"
  item3: "✗ Cannot load kernel modules (global operation)"
  item4: "✗ Cannot modify system clock (global operation)"
  item5: "✗ Cannot access host files owned by UID 0"
}
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style.fill: white
  style.stroke: gray
  green: "Scoped Capabilities" {
    shape: rectangle
    style.fill: "#C8E6C9"
    width: 120
  }
  red: "Global Only" {
    shape: rectangle
    style.fill: "#FFCDD2"
    width: 120
  }
  yellow: "Translation Layer" {
    shape: diamond
    style.fill: "#FFF9C4"
    width: 120
  }
}
userns.caps_inside -> ns_boundary: "scoped ops"
host_space.host_caps -> ns_boundary: "blocked" {
  style.stroke-dash: 4
  style.stroke: "#F44336"
}
ns_boundary -> result_box: "enforces"
translation -> setuid_drop: "protects against"
setuid_drop -> result_box: "prevents escalation"