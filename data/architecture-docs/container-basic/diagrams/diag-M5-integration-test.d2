direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Full Stack Integration: All Namespaces Combined
  Container Runtime Architecture
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  host: {
    direction: down
    label: "Host System (Linux Kernel)"
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
    kernel: {
      shape: rectangle
      label: "Linux Kernel"
      style.fill: "#e8e8e8"
      style.stroke: "#666666"
      width: 200
      sched: "Scheduler"
      mm: "Memory Manager"
      net: "Network Stack"
      vfs: "VFS Layer"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cgroup: {
    direction: down
    label: "cgroup v2 Resource Limits"
    style.fill: "#fff3e0"
    style.stroke: "#ff9800"
    style.stroke-width: 3
    style.border-radius: 8
    width: 850
    cgroup_files: {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent
      mem_limit: {
        label: "memory.max"
        shape: rectangle
        style.fill: "#ffe0b2"
        style.stroke: "#ff9800"
        width: 120
      }
      cpu_limit: {
        label: "cpu.max"
        shape: rectangle
        style.fill: "#ffe0b2"
        style.stroke: "#ff9800"
        width: 120
      }
      pids_limit: {
        label: "pids.max"
        shape: rectangle
        style.fill: "#ffe0b2"
        style.stroke: "#ff9800"
        width: 120
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  userns: {
    direction: down
    label: "User Namespace (CLONE_NEWUSER)"
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    style.stroke-width: 2
    style.border-radius: 8
    width: 850
    uid_map: {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent
      uid_map_box: {
        label: "UID/GID Mapping"
        shape: rectangle
        style.fill: "#bbdefb"
        style.stroke: "#1976d2"
        width: 200
        uid_table: {
          shape: sql_table
          label: "Translation Table"
          ns0: "0 | container root"
          host1000: "1000 | host user"
          count1: "1 | count"
        }
      }
      cap_box: {
        label: "Scoped Capabilities"
        shape: class
        +CAP_SYS_ADMIN: "mount, pivot_root"
        +CAP_NET_ADMIN: "ifconfig, routes"
        +CAP_SYS_CHROOT: "chroot"
        +CAP_MKNOD: "device nodes"
        -CAP_SYS_MODULE: "NO kernel modules"
        -CAP_SYS_BOOT: "NO reboot"
      }
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ns_row: {
    direction: right
    label: ""
    style.stroke: transparent
    style.fill: transparent
    width: 850
    pid_ns: {
      direction: down
      label: "PID Namespace\n(CLONE_NEWPID)"
      style.fill: "#e8f5e9"
      style.stroke: "#4caf50"
      style.stroke-width: 2
      style.border-radius: 6
      width: 200
      init_proc: {
        shape: rectangle
        label: "Init Process\nPID 1 (container)"
        style.fill: "#c8e6c9"
        style.stroke: "#4caf50"
      }
      child_procs: {
        shape: rectangle
        label: "Child Processes\nPID 2, 3, ..."
        style.fill: "#c8e6c9"
        style.stroke: "#4caf50"
        style.multiple: true
      }
      zombie_reaper: {
        shape: diamond
        label: "Zombie\nReaper"
        style.fill: "#a5d6a7"
        style.stroke: "#4caf50"
      }
    }
    uts_ns: {
      direction: down
      label: "UTS Namespace\n(CLONE_NEWUTS)"
      style.fill: "#fce4ec"
      style.stroke: "#e91e63"
      style.stroke-width: 2
      style.border-radius: 6
      width: 160
      hostname: {
        shape: rectangle
        label: "Hostname\nmy-container"
        style.fill: "#f8bbd9"
        style.stroke: "#e91e63"
      }
      domain: {
        shape: rectangle
        label: "Domain\nlocal"
        style.fill: "#f8bbd9"
        style.stroke: "#e91e63"
      }
    }
    mount_ns: {
      direction: down
      label: "Mount Namespace\n(CLONE_NEWNS)"
      style.fill: "#f3e5f5"
      style.stroke: "#9c27b0"
      style.stroke-width: 2
      style.border-radius: 6
      width: 200
      pivot_root: {
        shape: rectangle
        label: "pivot_root()"
        style.fill: "#e1bee7"
        style.stroke: "#9c27b0"
      }
      rootfs: {
        shape: cylinder
        label: "rootfs/\n├── bin/\n├── etc/\n├── proc/\n└── dev/"
        style.fill: "#e1bee7"
        style.stroke: "#9c27b0"
      }
      oldroot: {
        shape: rectangle
        label: "oldroot/\n(umounted)"
        style.fill: "#d1c4e9"
        style.stroke: "#9c27b0"
        style.stroke-dash: 3
      }
    }
    net_ns: {
      direction: down
      label: "Network Namespace\n(CLONE_NEWNET)"
      style.fill: "#e0f7fa"
      style.stroke: "#00bcd4"
      style.stroke-width: 2
      style.border-radius: 6
      width: 180
      lo: {
        shape: rectangle
        label: "lo\n127.0.0.1"
        style.fill: "#b2ebf2"
        style.stroke: "#00bcd4"
      }
      eth0: {
        shape: rectangle
        label: "eth0\n10.200.0.2/16"
        style.fill: "#b2ebf2"
        style.stroke: "#00bcd4"
      }
      routes: {
        shape: rectangle
        label: "Routes\ndefault → gw"
        style.fill: "#b2ebf2"
        style.stroke: "#00bcd4"
      }
      iptables: {
        shape: rectangle
        label: "iptables\n(isolate)"
        style.fill: "#80deea"
        style.stroke: "#00bcd4"
      }
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  container_proc: {
    direction: right
    label: "Container Process"
    style.fill: "#fff8e1"
    style.stroke: "#ffc107"
    style.stroke-width: 3
    style.border-radius: 8
    width: 850
    proc_view: {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent
      inside: {
        label: "Inside Container View"
        shape: class
        label_inside: "Process sees:"
        uid: "UID: 0 (root)"
        pid: "PID: 1 (init)"
        host: "Hostname: my-container"
        root: "Root: / (isolated)"
        ip: "IP: 10.200.0.2"
        caps: "Caps: Full set"
      }
      outside: {
        label: "Host View"
        shape: class
        label_outside: "Host sees:"
        uid_host: "UID: 1000 (user)"
        pid_host: "PID: 12345 (child)"
        host_host: "Hostname: host-machine"
        root_host: "Root: /var/containers/..."
        ip_host: "IP: veth_c12345"
        caps_host: "Caps: None"
      }
    }
  }
}
connections: {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  cgroup_to_userns: {
    shape: rectangle
    label: ""
    style.stroke: transparent
    style.fill: transparent
  }
}
host -> cgroup: "clone() with\nall flags" {
  style.stroke: "#333333"
  style.stroke-width: 2
}
cgroup -> userns: "Enforce limits\n(OOM, throttle)" {
  style.stroke: "#ff9800"
  style.stroke-width: 2
  style.stroke-dash: 3
}
userns -> ns_row.pid_ns: "UID 0 →\nroot ops" {
  style.stroke: "#1976d2"
}
userns -> ns_row.uts_ns: "sethostname()" {
  style.stroke: "#1976d2"
}
userns -> ns_row.mount_ns: "mount()\npivot_root()" {
  style.stroke: "#1976d2"
}
userns -> ns_row.net_ns: "ifconfig\nroutes" {
  style.stroke: "#1976d2"
}
ns_row.pid_ns -> container_proc: "exec()" {
  style.stroke: "#4caf50"
  style.stroke-width: 2
}
ns_row.mount_ns.pivot_root -> ns_row.mount_ns.rootfs: "swap" {
  style.stroke: "#9c27b0"
  style.stroke-dash: 3
}
ns_row.mount_ns.rootfs -> ns_row.mount_ns.oldroot: "move old" {
  style.stroke: "#9c27b0"
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  style.fill: "#fafafa"
  style.stroke: "#cccccc"
  style.border-radius: 4
  label: "Legend"
  l1: "Green = PID namespace (process isolation)"
  l2: "Pink = UTS namespace (hostname)"
  l3: "Purple = Mount namespace (filesystem)"
  l4: "Cyan = Network namespace (network stack)"
  l5: "Blue = User namespace (UID mapping)"
  l6: "Orange = cgroups (resource limits)"
}
legend.l1.style.font-color: "#4caf50"
legend.l2.style.font-color: "#e91e63"
legend.l3.style.font-color: "#9c27b0"
legend.l4.style.font-color: "#00bcd4"
legend.l5.style.font-color: "#1976d2"
legend.l6.style.font-color: "#ff9800"