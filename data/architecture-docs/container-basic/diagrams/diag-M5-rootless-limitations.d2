direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Rootless Container Limitations
  What works in user namespace vs what requires host privilege or workarounds
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  works: {
    direction: down
    label: "Works in User Namespace"
    mount_ns: {
      label: "Mount Namespace"
      shape: rectangle
      style.fill: "#ACE1AF"
      style.stroke: "#2E7D32"
      width: 200
      desc1: |md
        **mount() syscall**
        Full filesystem isolation
        pivot_root() works
        tmpfs, proc, bind mounts
      |
    }
    pid_ns: {
      label: "PID Namespace"
      shape: rectangle
      style.fill: "#ACE1AF"
      style.stroke: "#2E7D32"
      width: 200
      desc2: |md
        **Process isolation**
        PID 1 inside container
        Zombie reaping
        /proc isolation
      |
    }
    uts_ns: {
      label: "UTS Namespace"
      shape: rectangle
      style.fill: "#ACE1AF"
      style.stroke: "#2E7D32"
      width: 200
      desc3: |md
        **Hostname isolation**
        sethostname() works
        uname() returns container
        domain name isolation
      |
    }
  }
  partial: {
    direction: down
    label: "Partial / Requires Workarounds"
    filesystem: {
      label: "Filesystem Mounts"
      shape: rectangle
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
      width: 200
      desc4: |md
        **Some mounts fail**
        overlay: limited support
        sysfs: not allowed
        devtmpfs: devices non-functional
      |
    }
    devices: {
      label: "Device Nodes"
      shape: rectangle
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
      width: 200
      desc5: |md
        **mknod() succeeds**
        But devices don't work
        Need bind-mount from host
        devtmpfs handles permissions
      |
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  needs_root: {
    direction: down
    label: "Requires Host Root or Workaround"
    network: {
      direction: right
      label: "Network Namespace"
      veth_fail: {
        label: "veth + Bridge"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
        style.stroke-dash: 4
        width: 140
        veth_desc: |md
          **REQUIRES ROOT**
          ip link add veth fails
          CAP_NET_ADMIN on host
          Bridge attach needs root
        |
      }
      arrow1: {
        shape: text
        label: "→"
        style.font-size: 24
      }
      slirp: {
        label: "slirp4netns"
        shape: rectangle
        style.fill: "#B3E5FC"
        style.stroke: "#0277BD"
        width: 140
        slirp_desc: |md
          **USERSPACE WORKAROUND**
          TAP device in container
          TCP/IP in userspace
          No host privilege needed
        |
      }
    }
    cgroup: {
      direction: right
      label: "Cgroups Resource Limits"
      cgroup_fail: {
        label: "Direct cgroup Creation"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
        style.stroke-dash: 4
        width: 140
        cgroup_desc: |md
          **REQUIRES ROOT**
          mkdir /sys/fs/cgroup/ctr
          Permission denied
          No write access to cgroupfs
        |
      }
      arrow2: {
        shape: text
        label: "→"
        style.font-size: 24
      }
      systemd: {
        label: "systemd Delegation"
        shape: rectangle
        style.fill: "#B3E5FC"
        style.stroke: "#0277BD"
        width: 140
        systemd_desc: |md
          **DELEGATION WORKAROUND**
          Delegate=cpu memory pids
          User slice ownership
          systemctl --user set limits
        |
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  summary: {
    direction: down
    label: "Summary Matrix"
    matrix: {
      shape: sql_table
      label: "Rootless Capability Matrix (user_ns.go)"
      row1: "Feature | User NS | Workaround"
      row2: "mount/pivot_root | YES | —"
      row3: "PID namespace | YES | —"
      row4: "UTS namespace | YES | —"
      row5: "Network (veth) | NO | slirp4netns / pasta"
      row6: "Cgroups | NO | systemd delegation"
      row7: "OverlayFS | LIMITED | fuse-overlayfs"
      row8: "Device nodes | PARTIAL | bind-mount from host"
    }
  }
  key: {
    direction: down
    label: "Color Key"
    green: {
      shape: rectangle
      style.fill: "#ACE1AF"
      style.stroke: "#2E7D32"
      width: 120
      label: "Works"
    }
    yellow: {
      shape: rectangle
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
      width: 120
      label: "Partial"
    }
    red: {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      width: 120
      label: "Needs Root"
    }
    blue: {
      shape: rectangle
      style.fill: "#B3E5FC"
      style.stroke: "#0277BD"
      width: 120
      label: "Workaround"
    }
  }
}
row1 -> row2: "Privilege escalation boundary"
row2 -> row3: "Mitigation strategies"