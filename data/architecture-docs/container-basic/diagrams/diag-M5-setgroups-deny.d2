direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "setgroups='deny' Security Requirement (CVE-2014-8989)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vuln_side: {
    direction: down
    label: "BEFORE Linux 3.19 (VULNERABLE)"
    style: {
      stroke: "#C0392B"
      stroke-width: 3
      fill: "#FADBD8"
    }
    vuln_step1: {
      label: "Step 1: Unprivileged User"
      width: 200
      code: |'c
        // Regular user on host
        UID: 1000
        GID: 1000
        Groups: [1000]
        // No special privileges
      '|
      style.fill: "#F5B7B1"
    }
    vuln_step2: {
      label: "Step 2: Create User Namespace"
      width: 200
      code: |'c
        unshare(CLONE_NEWUSER);
        // Now "root" inside namespace
        UID: 0 (namespace view)
        GID: 0 (namespace view)
      '|
      style.fill: "#F5B7B1"
    }
    vuln_step3: {
      label: "Step 3: setgroups() Attack"
      width: 200
      code: |'c
        // CRITICAL VULNERABILITY
        gid_t groups[] = {0, 100, 1000};
        setgroups(3, groups);
        // SUCCEEDS! Can join ANY group
      '|
      style: {
        fill: "#E74C3C"
        stroke: "#922B21"
        stroke-width: 3
      }
    }
    vuln_step4: {
      label: "Step 4: Privilege Escalation"
      width: 200
      code: |'c
        // Access protected files
        open("/etc/shadow", O_RDONLY);
        // Owned by root:shadow (GID 42)
        // We're in GID 42 now -> SUCCESS!
      '|
      style: {
        fill: "#922B21"
        font-color: white
      }
    }
    vuln_step1 -> vuln_step2 -> vuln_step3 -> vuln_step4: {
      style: {
        stroke: "#C0392B"
        stroke-width: 2
        animated: true
      }
    }
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fixed_side: {
    direction: down
    label: "AFTER Linux 3.19 (FIXED)"
    style: {
      stroke: "#27AE60"
      stroke-width: 3
      fill: "#D5F5E3"
    }
    fix_step1: {
      label: "Step 1: Unprivileged User"
      width: 200
      code: |'c
        // Regular user on host
        UID: 1000
        GID: 1000
        Groups: [1000]
        // No special privileges
      '|
      style.fill: "#ABEBC6"
    }
    fix_step2: {
      label: "Step 2: Create User Namespace"
      width: 200
      code: |'c
        unshare(CLONE_NEWUSER);
        // Now "root" inside namespace
        UID: 0 (namespace view)
        GID: 0 (namespace view)
      '|
      style.fill: "#ABEBC6"
    }
    fix_step3: {
      label: "Step 3: DENY setgroups"
      width: 200
      code: |'c
        // REQUIRED before gid_map
        write("/proc/self/setgroups",
              "deny");
        // Now setgroups() -> EPERM
      '|
      style: {
        fill: "#27AE60"
        stroke: "#1E8449"
        stroke-width: 3
        font-color: white
      }
    }
    fix_step4: {
      label: "Step 4: Write gid_map"
      width: 200
      code: |'c
        // Now allowed (setgroups denied)
        write("/proc/self/gid_map",
              "0 1000 1");
        // Can only map OWN GID
      '|
      style.fill: "#ABEBC6"
    }
    fix_step5: {
      label: "Step 5: Attack BLOCKED"
      width: 200
      code: |'c
        gid_t groups[] = {0, 100, 42};
        setgroups(3, groups);
        // Returns: -1, errno=EPERM
        // Cannot join arbitrary groups!
      '|
      style: {
        fill: "#1E8449"
        font-color: white
      }
    }
    fix_step1 -> fix_step2 -> fix_step3 -> fix_step4 -> fix_step5: {
      style: {
        stroke: "#27AE60"
        stroke-width: 2
      }
    }
  }
}
row_before -> row_after: "Linux 3.19 Fix" {
  style: {
    stroke: "#7D3C98"
    stroke-width: 3
    stroke-dash: 5
  }
}
kernel_box: {
  label: "Kernel Enforcement"
  width: 600
  style.fill: "#EBF5FB"
  kernel_check: {
    shape: diamond
    label: "setgroups()\ncalled?"
  }
  check_setgroups: {
    shape: diamond
    label: "setgroups\ndenied?"
  }
  result_eperm: {
    label: "Return EPERM"
    style: {
      fill: "#27AE60"
      font-color: white
    }
  }
  result_allow: {
    label: "Proceed\n(Vulnerable!)"
    style: {
      fill: "#E74C3C"
      font-color: white
    }
  }
  kernel_check -> check_setgroups
  check_setgroups -> result_eperm: "Yes" {style.stroke: "#27AE60"}
  check_setgroups -> result_allow: "No" {style.stroke: "#E74C3C"}
}
flow_legend: {
  label: "Sequence Legend"
  near: bottom-right
  style.fill: transparent
  vuln_arrow: "Vulnerable Path" {
    shape: text
    style.font-color: "#C0392B"
  }
  safe_arrow: "Fixed Path" {
    shape: text
    style.font-color: "#27AE60"
  }
  vuln_arrow -> safe_arrow: {
    style: {
      stroke: transparent
    }
  }
}