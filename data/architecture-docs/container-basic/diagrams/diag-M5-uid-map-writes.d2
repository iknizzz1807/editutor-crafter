direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # uid_map/gid_map Write Sequence
  Parent process establishes UID/GID mapping before child execs
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parent_box: {
    direction: down
    label: "Parent Process (host UID 1000)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    p_start: {
      label: "fork()"
      shape: oval
      style.fill: "#C8E6C9"
    }
    p_clone: {
      label: "clone(CLONE_NEWUSER)"
      shape: rectangle
      width: 200
    }
    p_deny: {
      label: "write 'deny' to\n/proc/child/setgroups"
      shape: rectangle
      width: 200
      style.fill: "#FFCDD2"
    }
    p_uidmap: {
      label: "write '0 1000 1' to\n/proc/child/uid_map"
      shape: rectangle
      width: 200
      style.fill: "#BBDEFB"
    }
    p_gidmap: {
      label: "write '0 1000 1' to\n/proc/child/gid_map"
      shape: rectangle
      width: 200
      style.fill: "#C5CAE9"
    }
    p_signal: {
      label: "signal child\n(mapping done)"
      shape: rectangle
      width: 200
    }
    p_wait: {
      label: "waitpid(child)"
      shape: oval
      style.fill: "#FFF9C4"
    }
    p_start -> p_clone -> p_deny -> p_uidmap -> p_gidmap -> p_signal -> p_wait
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  child_box: {
    direction: down
    label: "Child Process (in new user_ns)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    c_start: {
      label: "created with\nempty mapping"
      shape: rectangle
      width: 180
      style.fill: "#FFECB3"
    }
    c_block: {
      label: "blocked on pipe\n(waiting for signal)"
      shape: rectangle
      width: 180
      style.fill: "#FFECB3"
    }
    c_verify: {
      label: "getuid() returns 0\n(I am root!)"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
    }
    c_exec: {
      label: "exec container\npayload"
      shape: oval
      style.fill: "#B2DFDB"
    }
    c_start -> c_block -> c_verify -> c_exec
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_box: {
    direction: down
    label: "Kernel Enforcement"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    k_ns: {
      label: "alloc user_namespace\nempty uid/gid maps"
      shape: rectangle
      width: 180
    }
    k_setgroups: {
      label: "setgroups = 'deny'\n(required for\nunprivileged gid_map)"
      shape: rectangle
      width: 180
      style.fill: "#FFCDD2"
    }
    k_uidmap: {
      label: "validate: parent UID\nmatches map target\nWRITE-ONCE: locked"
      shape: rectangle
      width: 180
      style.fill: "#BBDEFB"
    }
    k_gidmap: {
      label: "validate: setgroups=deny\nparent GID matches\nWRITE-ONCE: locked"
      shape: rectangle
      width: 180
      style.fill: "#C5CAE9"
    }
    k_active: {
      label: "UID translation active:\nns_uid 0 <-> host_uid 1000"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
    }
    k_ns -> k_setgroups -> k_uidmap -> k_gidmap -> k_active
  }
}
parent_box.p_clone -> kernel_box.k_ns: "creates" {style.stroke: "#1565C0"}
parent_box.p_deny -> kernel_box.k_setgroups: "enforces" {style.stroke: "#C62828"}
parent_box.p_uidmap -> kernel_box.k_uidmap: "validates" {style.stroke: "#1976D2"}
parent_box.p_gidmap -> kernel_box.k_gidmap: "validates" {style.stroke: "#303F9F"}
kernel_box.k_active -> child_box.c_verify: "enables" {style.stroke: "#2E7D32"; style.stroke-dash: 3}
parent_box.p_signal -> child_box.c_block: "releases" {style.stroke: "#388E3C"}
error_note: {
  label: |md
    ### Write-Once Enforcement
    - Second write to `uid_map` returns **EPERM**
    - Second write to `gid_map` returns **EPERM**
    - Mapping locked for process lifetime
  |
  style.fill: "#FFEBEE"
  style.stroke: "#B71C1C"
}
error_note.near: bottom-right
ordering_note: {
  label: |md
    ### Critical Ordering
    1. `setgroups='deny'` BEFORE `gid_map`
    2. Parent writes BEFORE child execs
    3. Use pipe/signal for synchronization
  |
  style.fill: "#E8F5E9"
  style.stroke: "#1B5E20"
}
ordering_note.near: bottom-left