direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # UID Translation: Inside vs Outside Namespace
  User namespace UID/GID mapping creates a bidirectional translation layer
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  container_view: {
    direction: down
    label: "Container Process View"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    app: {
      label: "Application"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
    }
    syscall_layer: {
      label: "Syscall Return"
      width: 180
      code: |'c
        struct stat st;
        stat("/file", &st);
        // st.st_uid = 0
        // Process sees: UID 0 (root)
      '|
    }
    app -> syscall_layer: "stat() returns\nst_uid = 0"
  }
  kernel_core: {
    direction: down
    label: "Kernel UID Translation"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 320
    uid_map: {
      shape: sql_table
      label: "/proc/pid/uid_map"
      r1: "nsid_start | hostid_start | count"
      r2: "0          | 1000         | 1"
      r3: "0          | →            | 1000"
    }
    translate_fn: {
      label: "Translation Function"
      width: 280
      code: |'c
        // kernel/user_namespace.c
        uid_t from_kuid(struct user_namespace *targ,
                        kuid_t kuid) {
          // Map: nsid 0 → host 1000
          // Reverse: host 1000 → nsid 0
          return map_id_down(targ->uid_map,
                             kuid);
        }
      '|
    }
    uid_map -> translate_fn: "lookup"
  }
  container_view.syscall_layer -> kernel_core.translate_fn: "kernel translates\nUID on syscall return"
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  host_view: {
    direction: down
    label: "Host Filesystem View"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    width: 280
    file_inode: {
      label: "File inode on disk"
      shape: sql_table
      label: "struct inode (ext4)"
      f1: "i_uid: 1000"
      f2: "i_gid: 1000"
      f3: "i_mode: 0644"
      f4: "i_ino: 131074"
    }
    host_ps: {
      label: "Host Process List"
      code: |md
        `$ ps -o pid,uid,cmd -p 12345`
        
        PID   UID  CMD
        12345 1000 ./container
        
      |
    }
  }
  bidirectional: {
    direction: down
    label: "Bidirectional Translation"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    width: 340
    outbound: {
      label: "Outbound (container → host)"
      width: 300
      code: |'c
        // Container creates file:
        //   write() as UID 0 (container)
        // Kernel translates:
        //   0 → 1000 (host)
        // File created: owner=1000
      '|
    }
    inbound: {
      label: "Inbound (host → container)"
      width: 300
      code: |'c
        // Container reads file:
        //   File owner = 1000 (host)
        // Kernel translates:
        //   1000 → 0 (container)
        // Container sees: owner=0
      '|
    }
    outbound -> inbound: "same mapping\nboth directions"
  }
  host_view -> bidirectional: "files owned by\nhost UID 1000"
}
kernel_core.translate_fn -> host_view.file_inode: "write creates file\nwith host UID 1000"
legend: {
  near: bottom-center
  label: "Translation Summary"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  grid-columns: 3
  grid-gap: 20
  c1: "Container sees UID 0" {
    style.fill: "#C8E6C9"
  }
  c2: "Host sees UID 1000" {
    style.fill: "#BBDEFB"
  }
  c3: "Same process, two identities" {
    style.fill: "#E1BEE7"
  }
}