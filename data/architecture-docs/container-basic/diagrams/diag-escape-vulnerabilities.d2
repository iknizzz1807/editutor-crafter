direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    escape-red: "#DC2626"
    escape-orange: "#EA580C"
    escape-yellow: "#CA8A04"
    safe-green: "#16A34A"
    safe-blue: "#2563EB"
    safe-purple: "#7C3AED"
    container-bg: "#F8FAFC"
  }
}
title: {
  label: "Container Escape Vulnerability Taxonomy\nMapping Attack Vectors to Mitigations"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  container: Container Boundary {
    style.fill: ${colors.container-bg}
    style.stroke: ${colors.safe-blue}
    style.stroke-width: 3
    namespaces: Namespaces {
      style.fill: "#DBEAFE"
      direction: down
      pid_ns: PID Namespace
      uts_ns: UTS Namespace
      mnt_ns: Mount Namespace
      net_ns: Network Namespace
      user_ns: User Namespace
    }
    cgroups: Cgroups {
      style.fill: "#FEF3C7"
      direction: down
      mem_limit: memory.max
      cpu_limit: cpu.max
      pids_limit: pids.max
    }
    capabilities: Capabilities {
      style.fill: "#F3E8FF"
      direction: down
      cap_sys_admin: CAP_SYS_ADMIN
      cap_net_admin: CAP_NET_ADMIN
      cap_sys_ptrace: CAP_SYS_PTRACE
      cap_mknod: CAP_MKNOD
    }
    security: Security Modules {
      style.fill: "#DCFCE7"
      direction: down
      seccomp: seccomp filter
      apparmor: AppArmor profile
      selinux: SELinux policy
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  escape_vectors: Escape Vectors {
    style.fill: "#FEF2F2"
    style.stroke: ${colors.escape-red}
    style.stroke-width: 2
    direction: down
    kernel_exploits: {
      label: "Kernel Exploits\n(User Namespace)"
      style.fill: "#FEE2E2"
      style.stroke: ${colors.escape-red}
      style.stroke-width: 2
      dirty_pipe: {
        label: "Dirty Pipe\nCVE-2022-0847"
        style.fill: ${colors.escape-red}
        style.font-color: white
        tooltip: "Overwrite arbitrary files via pipe buffer corruption"
      }
      cve_2022_0185: {
        label: "Filesystem Context Overflow\nCVE-2022-0185"
        style.fill: ${colors.escape-red}
        style.font-color: white
        tooltip: "Buffer overflow in fs_context parsing"
      }
      cve_2022_25636: {
        label: "Netfilter Use-After-Free\nCVE-2022-25636"
        style.fill: ${colors.escape-red}
        style.font-color: white
        tooltip: "UAF in netfilter nftables"
      }
    }
    capability_leaks: {
      label: "Misconfigured Capabilities"
      style.fill: "#FFEDD5"
      style.stroke: ${colors.escape-orange}
      style.stroke-width: 2
      cap_sys_module: {
        label: "CAP_SYS_MODULE\nLoad kernel modules"
        style.fill: ${colors.escape-orange}
        style.font-color: white
      }
      cap_sys_rawio: {
        label: "CAP_SYS_RAWIO\nI/O port access"
        style.fill: ${colors.escape-orange}
        style.font-color: white
      }
      cap_sys_admin_full: {
        label: "Full CAP_SYS_ADMIN\nUnrestricted mount"
        style.fill: ${colors.escape-orange}
        style.font-color: white
      }
    }
    proc_leaks: {
      label: "/proc Information Leaks"
      style.fill: "#FEF9C3"
      style.stroke: ${colors.escape-yellow}
      style.stroke-width: 2
      proc_root: {
        label: "/proc/1/root\nHost filesystem access"
        style.fill: ${colors.escape-yellow}
      }
      proc_fds: {
        label: "/proc/*/fd\nOpen file descriptors"
        style.fill: ${colors.escape-yellow}
      }
      proc_maps: {
        label: "/proc/*/maps\nMemory layout leak"
        style.fill: ${colors.escape-yellow}
      }
    }
    symlink_attacks: {
      label: "Symlink/Path Attacks"
      style.fill: "#FEF9C3"
      style.stroke: ${colors.escape-yellow}
      style.stroke-width: 2
      toctou: {
        label: "TOCTOU Race\nTime-of-check to time-of-use"
        style.fill: ${colors.escape-yellow}
      }
      escape_symlink: {
        label: "Escape Symlink\n../../../etc/passwd"
        style.fill: ${colors.escape-yellow}
      }
      bind_mount_escape: {
        label: "Bind Mount Escape\nMount host paths"
        style.fill: ${colors.escape-yellow}
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mitigations: Mitigations {
    style.fill: "#F0FDF4"
    style.stroke: ${colors.safe-green}
    style.stroke-width: 2
    direction: down
    kernel_mitigations: {
      label: "Kernel Hardening"
      style.fill: "#DCFCE7"
      style.stroke: ${colors.safe-green}
      direction: down
      unprivileged_userns: {
        label: "Disable Unprivileged Userns\nkernel.unprivileged_userns_clone=0"
        style.fill: ${colors.safe-green}
        style.font-color: white
      }
      kernel_update: {
        label: "Kernel Updates\nPatch known CVEs"
        style.fill: ${colors.safe-green}
        style.font-color: white
      }
    }
    capability_mitigations: {
      label: "Capability Dropping"
      style.fill: "#DCFCE7"
      style.stroke: ${colors.safe-green}
      direction: down
      drop_all: {
        label: "Drop All Capabilities\nThen add only required"
        style.fill: ${colors.safe-green}
        style.font-color: white
      }
      no_new_privs: {
        label: "no_new_privs\nPrevent privilege escalation"
        style.fill: ${colors.safe-green}
        style.font-color: white
      }
    }
    proc_mitigations: {
      label: "/proc Hardening"
      style.fill: "#DBEAFE"
      style.stroke: ${colors.safe-blue}
      direction: down
      hidepid: {
        label: "hidepid=2\nHide other user processes"
        style.fill: ${colors.safe-blue}
        style.font-color: white
      }
      proc_mask: {
        label: "Mask /proc mounts\nContainer-specific /proc"
        style.fill: ${colors.safe-blue}
        style.font-color: white
      }
    }
    fs_mitigations: {
      label: "Filesystem Isolation"
      style.fill: "#EDE9FE"
      style.stroke: ${colors.safe-purple}
      direction: down
      pivot_root: {
        label: "pivot_root()\nComplete root swap"
        style.fill: ${colors.safe-purple}
        style.font-color: white
      }
      readonly_root: {
        label: "Read-Only Rootfs\nMS_RDONLY on /"
        style.fill: ${colors.safe-purple}
        style.font-color: white
      }
      nosuid_noexec: {
        label: "nosuid,noexec,nodev\nMount hardening flags"
        style.fill: ${colors.safe-purple}
        style.font-color: white
      }
    }
  }
}
# Attack to mitigation mappings
escape_vectors.kernel_exploits.dirty_pipe -> mitigations.kernel_mitigations.unprivileged_userns: "Prevented by" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 4
}
escape_vectors.kernel_exploits.dirty_pipe -> mitigations.kernel_mitigations.kernel_update: "Patched in\n5.16.11, 5.15.25, 5.10.102" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 4
}
escape_vectors.kernel_exploits.cve_2022_0185 -> mitigations.kernel_mitigations.kernel_update: "Patched in\n5.16.2" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 4
}
escape_vectors.capability_leaks.cap_sys_module -> mitigations.capability_mitigations.drop_all: "Removed by\ndefault drop" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 4
}
escape_vectors.capability_leaks.cap_sys_rawio -> mitigations.capability_mitigations.drop_all: "Removed by\ndefault drop" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 4
}
escape_vectors.capability_leaks.cap_sys_admin_full -> mitigations.capability_mitigations.no_new_privs: "Limited by\nno_new_privs" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 4
}
escape_vectors.proc_leaks.proc_root -> mitigations.proc_mitigations.proc_mask: "Isolated by\nmount namespace" {
  style.stroke: ${colors.safe-blue}
  style.stroke-dash: 4
}
escape_vectors.proc_leaks.proc_fds -> mitigations.proc_mitigations.hidepid: "Hidden by\nhidepid=2" {
  style.stroke: ${colors.safe-blue}
  style.stroke-dash: 4
}
escape_vectors.proc_leaks.proc_maps -> mitigations.proc_mitigations.hidepid: "Hidden by\nhidepid=2" {
  style.stroke: ${colors.safe-blue}
  style.stroke-dash: 4
}
escape_vectors.symlink_attacks.toctou -> mitigations.fs_mitigations.readonly_root: "Prevented by\nread-only root" {
  style.stroke: ${colors.safe-purple}
  style.stroke-dash: 4
}
escape_vectors.symlink_attacks.escape_symlink -> mitigations.fs_mitigations.pivot_root: "Contained by\npivot_root" {
  style.stroke: ${colors.safe-purple}
  style.stroke-dash: 4
}
escape_vectors.symlink_attacks.bind_mount_escape -> mitigations.fs_mitigations.nosuid_noexec: "Limited by\nmount flags" {
  style.stroke: ${colors.safe-purple}
  style.stroke-dash: 4
}
# Container internal relationships
container.namespaces.user_ns -> escape_vectors.kernel_exploits: "Enables access to\nkernel code paths" {
  style.stroke: ${colors.escape-red}
  style.stroke-dash: 3
  style.animated: true
}
container.capabilities -> escape_vectors.capability_leaks: "Excessive caps\nenable escape" {
  style.stroke: ${colors.escape-orange}
  style.stroke-dash: 3
}
# Security module protections
container.security.seccomp -> mitigations: "Syscall filtering" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 2
}
container.security.apparmor -> mitigations: "Profile enforcement" {
  style.stroke: ${colors.safe-green}
  style.stroke-dash: 2
}
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#94A3B8"
  l1: "Critical Escape (CVE)" {
    style.fill: ${colors.escape-red}
    style.font-color: white
  }
  l2: "High Risk (Capabilities)" {
    style.fill: ${colors.escape-orange}
    style.font-color: white
  }
  l3: "Medium Risk (Info Leak)" {
    style.fill: ${colors.escape-yellow}
  }
  l4: "Mitigation Available" {
    style.fill: ${colors.safe-green}
    style.font-color: white
  }
}