direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_types: {
    direction: down
    label: "CORE DATA STRUCTURES"

    container_config: {
      shape: sql_table
      label: "struct container_config_t (01_types.h) [M1-M5]"
      00_08: "const char* hostname | UTS ID"
      08_16: "const char* rootfs   | MNT path"
      16_24: "int argc             | param count"
      24_32: "char** argv          | exec vector"
      32_40: "void* userns_ctx     | M5 ref"
      sz: "Total: ~128 bytes"
    }

    clone_stack: {
      shape: sql_table
      label: "struct clone_stack_t (02_stack.c) [M1]"
      00_08: "void* base           | malloc ptr"
      08_16: "void* top            | base + size (aligned)"
      16_24: "size_t size          | 1MB default"
      sz: "Total: 24 bytes"
    }
  }

  layer_infra: {
    direction: down
    label: "COMMON UTILITIES"

    stack_mgr: {
      shape: class
      label: "StackManager (02_stack.c) [M1]"
      +allocate_stack(size): "clone_stack_t"
      +free_stack(stack): "void"
      -align_top(ptr): "void*"
    }

    sync_pipe: {
      shape: class
      label: "SyncPipe (04_sync_pipe.c) [M5]"
      -fds: "int[2]"
      +create(): "int"
      +wait_child(): "void"
      +signal_done(): "void"
      +close_all(): "void"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_ns_core: {
    direction: down
    label: "NAMESPACE ISOLATION"

    user_ns: {
      shape: class
      label: "UserNamespace (03_uid_gid_map.c) [M5]"
      +setup_mapping(pid, uid, gid): "int"
      -write_id_map(path, map): "int"
      -deny_setgroups(pid): "int"
      note: "Required for rootless M5"
    }

    mount_ns: {
      shape: class
      label: "MountNamespace (06_fs_isolation.c) [M2]"
      +isolate_fs(rootfs): "int"
      -bind_mount_self(path): "int"
      -pivot_root_wrapper(new, old): "int"
      -mount_pseudo_fs(): "int"
    }

    pid_uts_ns: {
      shape: class
      label: "PidUtsNamespace (04_pid_ns.c) [M1]"
      +set_hostname(name): "int"
      +get_ns_pid(): "pid_t"
      +verify_isolation(): "bool"
    }
  }

  layer_ns_data: {
    direction: down
    label: "NS DATA MODELS"

    mount_ctx: {
      shape: sql_table
      label: "struct mount_context_t (01_types.h) [M2]"
      00_4096: "char rootfs_path[4096]"
      4096_4352: "char old_root[256]"
      4352_4356: "int propagation | MS_PRIVATE"
      sz: "Total: ~4.4 KB"
    }

    id_map: {
      shape: sql_table
      label: "struct id_map_t (01_types.h) [M5]"
      00_04: "uint32_t ns_start"
      04_08: "uint32_t host_start"
      08_12: "uint32_t count"
      sz: "Single Extent: 12 bytes"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_resources: {
    direction: down
    label: "RESOURCE & NETWORK"

    cgroup_mgr: {
      shape: class
      label: "CgroupManager (07_cgroup_mgr.c) [M4]"
      +setup(pid, cfg): "int"
      +apply_limits(cfg): "int"
      +cleanup(): "int"
      -detect_version(): "int"
      -enable_controllers(): "int"
    }

    net_mgr: {
      shape: class
      label: "NetworkManager (07_network_main.c) [M3]"
      +setup_veth(pid): "int"
      +setup_bridge(): "int"
      +configure_nat(): "int"
      -move_to_ns(if, pid): "int"
    }
  }

  layer_res_data: {
    direction: down
    label: "RESOURCE MODELS"

    cgroup_cfg: {
      shape: sql_table
      label: "struct cgroup_config_t (01_types.h) [M4]"
      mem_max: "uint64_t | bytes"
      cpu_pct: "int      | 1-100"
      pids_max: "int     | count"
      path: "char[512]   | sysfs path"
    }

    net_cfg: {
      shape: sql_table
      label: "struct net_config_t (01_types.h) [M3]"
      ip: "char[46]    | CIDR"
      gw: "char[46]    | Bridge IP"
      br: "char[16]    | Name"
      veth: "char[16]  | Host End"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_orchestration: {
    direction: down
    label: "ORCHESTRATION"

    launcher: {
      shape: class
      label: "ContainerLauncher (07_namespace_main.c) [M1-M5]"
      +main(argc, argv): "int"
      -parse_args(cfg): "void"
      -run_container(cfg): "int"
    }

    init_proc: {
      shape: class
      label: "InitProcess (06_init_process.c) [M1]"
      +init_entry(arg): "int"
      -setup_signals(): "int"
      -reap_zombies(): "void"
      -exec_workload(): "void"
    }
  }
}

# Global Relationships
row4.layer_orchestration.launcher -> row1.layer_infra.stack_mgr: "allocates child stack"
row4.layer_orchestration.launcher -> row2.layer_ns_core.user_ns: "M5 | maps UID/GID"
row4.layer_orchestration.launcher -> row4.layer_orchestration.init_proc: "clone() | creates child"
row4.layer_orchestration.init_proc -> row2.layer_ns_core.mount_ns: "M2 | pivot_root()"
row4.layer_orchestration.init_proc -> row2.layer_ns_core.pid_uts_ns: "M1 | set hostname"
row4.layer_orchestration.launcher -> row3.layer_resources.cgroup_mgr: "M4 | sets limits"
row4.layer_orchestration.launcher -> row3.layer_resources.net_mgr: "M3 | setup connectivity"

# Internal handshakes
row1.layer_infra.sync_pipe -> row4.layer_orchestration.init_proc: "blocks until mapped"
row2.layer_ns_core.user_ns -> row1.layer_infra.sync_pipe: "signals ready"

milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | container-basic-m1 | PID/UTS Isolation & Reaping"
  m2: "M2 | container-basic-m2 | Mount Namespace & pivot_root"
  m3: "M3 | container-basic-m3 | Network Namespace & veth/Bridge"
  m4: "M4 | container-basic-m4 | Cgroups Resource Limits (v1/v2)"
  m5: "M5 | container-basic-m5 | User Namespace & Rootless Mapping"
}

legend: {
  near: bottom-right
  note: "Scale: 1MB Child Stack | 4KB Sysfs Buffer"
  style.stroke: "#333333"
}