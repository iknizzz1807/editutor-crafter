direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# PID Namespace View Translation Architecture
# Intel Manual Style Specification

title: |md
  # PID Namespace Translation Hierarchy
  ### Level 0 (Host) ↔ Level N (Container)
| {
  near: top-center
}

classes: {
  kernel_struct: {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      font-size: 14
    }
  }
  user_ns: {
    style: {
      stroke-width: 3
      border-radius: 10
    }
  }
  process_node: {
    shape: rectangle
    style: {
      stroke-width: 2
      font-size: 12
    }
  }
  offset_label: {
    shape: text
    style: {
      font-size: 10
      font-color: "#757575"
      font: mono
    }
  }
}

# --- PROCESS ENTITY (TASK_STRUCT) ---
task_struct: {
  label: "struct task_struct"
  shape: sql_table
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
  }
  0x00: "..."
  0x4A0: "struct pid *thread_pid" {constraint: "Pointer [Orange]"}
  0x4A8: "struct pid *pids[PIDTYPE_MAX]"
  0xFFFF: "..."
}

# --- KERNEL PID MAPPING ---
kernel_space: {
  label: "Kernel Memory space (slab: pid_cache)"
  style.fill: "#FAFAFA"
  style.stroke: "#E65100"
  style.stroke-dash: 4

  struct_pid: {
    label: "struct pid (Global Kernel Object)"
    shape: sql_table
    style.fill: "#FFFFFF"
    style.stroke: "#1565C0"
    
    count: "atomic_t count" {constraint: "Refcnt"}
    level: "unsigned int level = 2" {style.font-color: red; style.bold: true}
    numbers: "struct upid numbers[level]" {constraint: "VLA"}
    
    upid_0: "numbers[0]: { .nr=12345, .ns=&init_ns }" {style.fill: "#BBDEFB"}
    upid_1: "numbers[1]: { .nr=1, .ns=&child_ns }" {style.fill: "#90CAF9"}
  }

  ns_hierarchy: {
    label: "PID Namespace Hierarchy"
    init_ns: "init_pid_ns (Level 0)" {
      style.fill: "#BBDEFB"
    }
    child_ns: "child_pid_ns (Level 1)" {
      style.fill: "#90CAF9"
    }
    
    child_ns -> init_ns: "parent" {
      style.stroke: "#1565C0"
      target-arrowhead.shape: triangle
    }
  }
}

# --- HOST VIEW (init_ns) ---
host_view: {
  label: "Host View (Namespace: 0)"
  class: user_ns
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"

  host_proc: "/proc/ (Host FS)" {
    pid_1: "PID 1 (systemd)"
    target: "PID 12345 (container init)" {
      style: {
        fill: "#E53935"
        font-color: white
        bold: true
        stroke-width: 4
      }
    }
    other: "PID 12400 (child proc)"
  }
}

# --- CONTAINER VIEW (child_ns) ---
container_view: {
  label: "Container View (Namespace: 1)"
  class: user_ns
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"

  container_proc: "/proc/ (Container FS)" {
    pid_1: "PID 1 (container init)" {
      style: {
        fill: "#4CAF50"
        font-color: white
        bold: true
        stroke-width: 4
      }
    }
    pid_7: "PID 7 (child proc)" {
      style.fill: "#A5D6A7"
    }
  }
}

# --- TRANSLATION LOGIC ---

# Pointer from task to kernel struct
task_struct.0x4A0 -> kernel_space.struct_pid: "Dereference" {
  style.stroke: orange
  style.stroke-width: 3
}

# Mapping to Host PID
kernel_space.struct_pid.upid_0 -> host_view.host_proc.target: "View Translation" {
  label: "numbers[0].nr"
  style: {
    stroke: "#C62828"
    stroke-width: 3
    animated: true
  }
}

# Mapping to Container PID
kernel_space.struct_pid.upid_1 -> container_view.container_proc.pid_1: "View Translation" {
  label: "numbers[1].nr"
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    animated: true
  }
}

# Relationship between namespaces
host_view -> container_view: "clone(CLONE_NEWPID)" {
  style.stroke-dash: 5
  style.stroke: grey
}

# --- VERIFICATION & LEGEND ---

legend: {
  label: "Technical Implementation Notes"
  near: bottom-right
  note: |md
    - **Isolation**: Procs in child NS cannot see Host PIDs.
    - **Visibility**: Host NS sees all children as high-numbered PIDs.
    - **Translation**: Done via `pid_vnr()` and `pid_nr_ns()` in kernel.
  |
}

# Fixed: Using |' ... '| to handle the internal pipe '|' in the bash command
verify_cmd: |'bash
  # Inside Container:
  $ cat /proc/self/status | grep NSpid
  NSpid:	12345	1
  # (Host PID) (NS PID)
'| {
  near: bottom-left
  style.font: mono
  style.fill: "#ECEFF1"
}

# Ensure the struct_pid links to the NS pointers
kernel_space.struct_pid.upid_0 -> kernel_space.ns_hierarchy.init_ns: ".ns" {style.stroke-dash: 2}
kernel_space.struct_pid.upid_1 -> kernel_space.ns_hierarchy.child_ns: ".ns" {style.stroke-dash: 2}