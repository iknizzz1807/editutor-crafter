page_marker: {
  label: "────────── Page Boundary (4KB) ──────────"
  shape: text
  style: {
    font-size: 11
    font-color: "#7C3AED"
    bold: true
  }
}
# Positioning connections (invisible)
addr_high -> stack_region.stack_top_aligned: {
  style: {
    stroke: "transparent"
  }
}
