layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# -----------------------------------------------------------------------------------------
# CLASSES & STYLING
# -----------------------------------------------------------------------------------------
classes: {
  memory_data: {
    shape: rectangle
    style: {
      fill: "#e0e7ff"
      stroke: "#4338ca"
      stroke-width: 2
      font-size: 14
      bold: true
    }
  }
  offset_label: {
    shape: text
    style: {
      font: mono
      font-size: 12
      font-color: "#475569"
      bold: true
    }
  }
  size_label: {
    shape: text
    style: {
      italic: true
      font-size: 12
      font-color: "#64748b"
    }
  }
  cache_boundary: {
    shape: text
    style: {
      font-color: "#f59e0b"
      font-size: 11
      bold: true
    }
  }
  hex_val: {
    shape: text
    style: {
      font: mono
      font-size: 11
      font-color: "#94a3b8"
    }
  }
}

# -----------------------------------------------------------------------------------------
# HEADER SECTION
# -----------------------------------------------------------------------------------------
header: {
  title: "UTS Namespace struct new_utsname Memory Layout" {
    shape: text
    style: {
      font-size: 28
      bold: true
      underline: true
    }
  }
  subtitle: "Linux Kernel include/uapi/linux/utsname.h | Total Size: 390 Bytes" {
    shape: text
    style: {
      font-size: 16
      italic: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# PRIMARY MEMORY LAYOUT CONTAINER
# -----------------------------------------------------------------------------------------
struct_layout: {
  style: {
    fill: "#f8fafc"
    stroke: "#1e293b"
    stroke-width: 2
    border-radius: 4
  }

  # Left Margin: Byte Offsets (Hex and Decimal)
  offsets: {
    style.stroke-width: 0
    o0: "0x000 (0)" { class: offset_label }
    o65: "0x041 (65)" { class: offset_label }
    o130: "0x082 (130)" { class: offset_label }
    o195: "0x0C3 (195)" { class: offset_label }
    o260: "0x104 (260)" { class: offset_label }
    o325: "0x145 (325)" { class: offset_label }
    o390: "0x186 (390)" { class: offset_label }
    
    o0 -> o65 -> o130 -> o195 -> o260 -> o325 -> o390: { style.stroke-width: 0 }
  }

  # Center: Data Fields (Blue = Data)
  fields: {
    style.stroke-width: 0
    sysname: "sysname[65]\nOS Name (e.g., 'Linux')" { 
      class: memory_data
      width: 400
      height: 60 
    }
    nodename: "nodename[65]\nHostname (e.g., 'debian')" { 
      class: memory_data
      width: 400
      height: 60 
    }
    release: "release[65]\nKernel Release (e.g., '6.1.0-18')" { 
      class: memory_data
      width: 400
      height: 60 
    }
    version: "version[65]\nKernel Version Info" { 
      class: memory_data
      width: 400
      height: 60 
    }
    machine: "machine[65]\nArchitecture (e.g., 'x86_64')" { 
      class: memory_data
      width: 400
      height: 60 
    }
    domainname: "domainname[65]\nNIS Domain Name" { 
      class: memory_data
      width: 400
      height: 60 
    }
    
    sysname -> nodename -> release -> version -> machine -> domainname: { style.stroke-width: 0 }
  }

  # Right Margin: Field Sizes
  sizes: {
    style.stroke-width: 0
    s1: "65 B" { class: size_label }
    s2: "65 B" { class: size_label }
    s3: "65 B" { class: size_label }
    s4: "65 B" { class: size_label }
    s5: "65 B" { class: size_label }
    s6: "65 B" { class: size_label }
    
    s1 -> s2 -> s3 -> s4 -> s5 -> s6: { style.stroke-width: 0 }
  }

  # Alignment Mapping (Fixed Elk logic: uses connections to force parallel columns)
  offsets.o0 -> fields.sysname -> sizes.s1
  offsets.o65 -> fields.nodename -> sizes.s2
  offsets.o130 -> fields.release -> sizes.s3
  offsets.o195 -> fields.version -> sizes.s4
  offsets.o260 -> fields.machine -> sizes.s5
  offsets.o325 -> fields.domainname -> sizes.s6
}

# -----------------------------------------------------------------------------------------
# CACHE LINE OVERLAY (64-BYTE ALIGNMENT)
# FIXED: Using constant 'near' for ELK compliance
# -----------------------------------------------------------------------------------------
cache_analysis: {
  near: bottom-left
  label: "Microarchitecture Analysis: Cache Alignment"
  style: {
    stroke-dash: 4
    stroke: "#f59e0b"
    fill: "#fffbeb"
    stroke-width: 2
  }
  
  info: |md
    ### Cache Portability Note
    The Linux constant `__NEW_UTS_LEN` is 64. Including the `\0` terminator, each field is **65 bytes**.
    This misaligns with the standard **64-byte L1 Cache Line**, ensuring that every string access 
    likely results in a cache line split (spanning two lines).
  | {
    style.font-size: 12
  }
  
  grid: {
    grid-columns: 2
    grid-gap: 10
    l1: "Line 1 Boundary" { class: cache_boundary }
    d1: "Offset 0x40 (64)" { class: hex_val }
    l2: "Line 2 Boundary" { class: cache_boundary }
    d2: "Offset 0x80 (128)" { class: hex_val }
    l3: "Line 3 Boundary" { class: cache_boundary }
    d3: "Offset 0xC0 (192)" { class: hex_val }
    l4: "Line 4 Boundary" { class: cache_boundary }
    d4: "Offset 0x100 (256)" { class: hex_val }
    l5: "Line 5 Boundary" { class: cache_boundary }
    d5: "Offset 0x140 (320)" { class: hex_val }
    l6: "Line 6 Boundary" { class: cache_boundary }
    d6: "Offset 0x180 (384)" { class: hex_val }
  }
}

# -----------------------------------------------------------------------------------------
# REFERENCE DOCUMENTATION
# FIXED: Using constant 'near' for ELK compliance
# -----------------------------------------------------------------------------------------
implementation_spec: |md
  ### C Structure Definition
  c
  /* From include/uapi/linux/utsname.h */
  #define __NEW_UTS_LEN 64

  struct new_utsname {
      char sysname[__NEW_UTS_LEN + 1];    /* OS name */
      char nodename[__NEW_UTS_LEN + 1];   /* Hostname */
      char release[__NEW_UTS_LEN + 1];    /* Kernel release */
      char version[__NEW_UTS_LEN + 1];    /* Kernel version */
      char machine[__NEW_UTS_LEN + 1];    /* Arch */
      char domainname[__NEW_UTS_LEN + 1]; /* NIS domain */
  };
  
  
  **Implementation Details:**
  - **Memory Growth:** Continuous array of chars.
  - **Padding:** None (1-byte char alignment).
  - **Total Size:** $65 \times 6 = 390$ Bytes.
  - **Data Type:** All fields are `char[]` arrays.
| {
  near: bottom-right
}

# -----------------------------------------------------------------------------------------
# FOOTER / TOTAL SIZE
# -----------------------------------------------------------------------------------------
total_summary: {
  label: "sizeof(struct new_utsname) = 390 Bytes (0x186)"
  shape: rectangle
  style: {
    fill: "#1e293b"
    font-color: white
    bold: true
    font-size: 20
    double-border: true
    shadow: true
    border-radius: 8
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  near: top-right
  title: "MAP LEGEND" { shape: text; style.bold: true }
  
  items: {
    grid-columns: 1
    data: "Data Field (char[])" {
      style.fill: "#e0e7ff"
      style.stroke: "#4338ca"
      style.stroke-width: 2
    }
    cache: "64B Cache Line Overlap" {
      style.stroke: "#f59e0b"
      style.stroke-dash: 4
      style.stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------------------
# LOGIC FLOW FOR PLACEMENT (ELK)
# -----------------------------------------------------------------------------------------
header -> struct_layout
struct_layout -> total_summary
total_summary -> cache_analysis
total_summary -> implementation_spec