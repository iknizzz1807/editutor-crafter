vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

# -----------------------------------------------------------------------------------------
# TITLE & HEADER
# -----------------------------------------------------------------------------------------
header: {
  title: "Mount Propagation Types Comparison" {
    shape: text
    style: {
      font-size: 32
      bold: true
      underline: true
    }
  }
  subtitle: "Linux VFS Layer Mount Namespace Event Flow (Implementation Detail)" {
    shape: text

    style.font-size: 18
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND & METADATA
# -----------------------------------------------------------------------------------------
legend: {
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    stroke: "#6c7086"
    stroke-width: 2
    border-radius: 10
  }
  near: bottom-right

  legend_title: "Propagation State Legend" {
    shape: text
    style.bold: true
    style.font-color: white
  }

  bidir: "⟷ Bidirectional" {
    style.fill: "#a6e3a1"
    style.font-color: black
  }
  isolated: "⊘ No Propagation" {
    style.fill: "#f38ba8"
    style.font-color: black
  }
  oneway: "← One-way Receive" {
    style.fill: "#fab387"
    style.font-color: black
  }
  blocked: "⃠ Bind-blocked" {
    style.fill: "#cba6f7"
    style.font-color: black
  }
}

# -----------------------------------------------------------------------------------------
# KERNEL DATA STRUCTURES (Memory Layout)
# -----------------------------------------------------------------------------------------
# Exact byte offsets and field sizes for structural engineering reference
kernel_mem: "struct mount (fs/mount.h)" {
  shape: sql_table
  style: {
    fill: "#f5e0dc"
    stroke: "#cba6f7"
    stroke-width: 2
  }
  
  header: "Field Name | Data Type" {
    style: {
      bold: true
      fill: "#cba6f7"
    }
  }

  mnt_parent: "struct mount*" {
    constraint: "Offset: 0x00 (8B)"
  }
  mnt_mountpoint: "struct dentry*" {
    constraint: "Offset: 0x08 (8B)"
  }
  mnt_group_id: "int (Peer Group ID)" {
    constraint: "Offset: 0x10 (4B)"
  }
  mnt_master: "struct mount* (Master)" {
    constraint: "Offset: 0x18 (8B)"
  }
  mnt_propagation: "unsigned long (Flags)" {
    constraint: "Offset: 0x20 (8B)"
  }
  mnt_peer_list: "struct list_head" {
    constraint: "Offset: 0x28 (16B)"
  }
}

# -----------------------------------------------------------------------------------------
# HOST NAMESPACE (Source)
# -----------------------------------------------------------------------------------------
host_ns: "Host Mount Namespace\n[NS_ID: 4026531840]" {
  shape: rectangle
  style: {
    fill: "#313244"
    stroke: "#89b4fa"
    stroke-width: 4
  }

  host_mount: "/mnt/source" {
    shape: cylinder
    style.fill: "#45475a"
  }

  host_event: "Mount Event\n(vfs_mount)" {
    shape: diamond
    style: {
      fill: "#89b4fa"
      bold: true
    }
  }

  host_mount -> host_event: "do_mount() call" {
    style.stroke-dash: 3
  }
}

# -----------------------------------------------------------------------------------------
# SHARED PROPAGATION
# -----------------------------------------------------------------------------------------
shared_ns: "MS_SHARED\n(Peer Group Member)" {
  shape: rectangle
  style: {
    fill: "#1e3a2f"
    stroke: "#a6e3a1"
    stroke-width: 3
  }

  info: |md
    **Bidirectional Propagation**
    - `mnt_group_id != 0`
    - Trigger: `mount --make-shared`
    - Internal: Logic handles `next_peer` traversal.
  |

  shared_mount: "/mnt/shared" {
    shape: cylinder
    style.fill: "#2d4a3e"
  }

  shared_in: "← IN" {
    shape: circle
    style.fill: "#a6e3a1"
  }

  shared_out: "OUT →" {
    shape: circle
    style.fill: "#a6e3a1"
  }

  shared_mount -> shared_in: {style.stroke: transparent}
  shared_mount -> shared_out: {style.stroke: transparent}
}

# -----------------------------------------------------------------------------------------
# PRIVATE PROPAGATION
# -----------------------------------------------------------------------------------------
private_ns: "MS_PRIVATE\n(Fully Isolated)" {
  shape: rectangle
  style: {
    fill: "#3a1e2f"
    stroke: "#f38ba8"
    stroke-width: 3
  }

  info: |md
    **Isolated Propagation**
    - `mnt_group_id == 0`
    - Trigger: `mount --make-private`
    - Cloned mounts are strictly independent.
  |

  private_mount: "/mnt/private" {
    shape: cylinder
    style.fill: "#4a2d3e"
  }

  private_block_in: "⊘" {
    shape: circle
    style.fill: "#f38ba8"
  }

  private_block_out: "⊘" {
    shape: circle
    style.fill: "#f38ba8"
  }

  private_mount -> private_block_in: {style.stroke: transparent}
  private_mount -> private_block_out: {style.stroke: transparent}
}

# -----------------------------------------------------------------------------------------
# SLAVE PROPAGATION
# -----------------------------------------------------------------------------------------
slave_ns: "MS_SLAVE\n(Unidirectional)" {
  shape: rectangle
  style: {
    fill: "#3a2f1e"
    stroke: "#fab387"
    stroke-width: 3
  }

  info: |md
    **Unidirectional Propagation**
    - `mnt_master != NULL`
    - Trigger: `mount --make-slave`
    - Downstream of a Master Peer Group.
  |

  slave_mount: "/mnt/slave" {
    shape: cylinder
    style.fill: "#4a3e2d"
  }

  slave_in: "← IN" {
    shape: circle
    style.fill: "#fab387"
  }

  slave_block_out: "⊘" {
    shape: circle
    style.fill: "#fab387"
  }

  slave_mount -> slave_in: {style.stroke: transparent}
  slave_mount -> slave_block_out: {style.stroke: transparent}
}

# -----------------------------------------------------------------------------------------
# UNBINDABLE PROPAGATION
# -----------------------------------------------------------------------------------------
unbindable_ns: "MS_UNBINDABLE\n(Bind-Blocked)" {
  shape: rectangle
  style: {
    fill: "#2f1e3a"
    stroke: "#cba6f7"
    stroke-width: 3
  }

  info: |md
    **Bind-Blocked Propagation**
    - `mnt_flags & MNT_UNBINDABLE`
    - Prevents cyclic mount dependencies.
    - Useful for bulk mount mirroring.
  |

  unbindable_mount: "/mnt/unbindable" {
    shape: cylinder
    style.fill: "#3e2d4a"
  }

  unbindable_block: "⃠ BIND" {
    shape: circle
    style.fill: "#cba6f7"
  }

  unbindable_mount -> unbindable_block: {style.stroke: transparent}
}

# -----------------------------------------------------------------------------------------
# EVENT FLOW CONNECTIONS
# -----------------------------------------------------------------------------------------
# SHARED: Bi-directional flow
host_ns.host_event -> shared_ns.shared_in: "propagate_mnt()" {
  style: {
    stroke: "#a6e3a1"
    stroke-width: 3
  }
}
shared_ns.shared_out -> host_ns.host_mount: "peer_propagation" {
  style: {
    stroke: "#a6e3a1"
    stroke-width: 2
    stroke-dash: 5
  }
}

# PRIVATE: Blocked flow
host_ns.host_event -> private_ns.private_block_in: "DROP_EVENT" {
  style: {
    stroke: "#f38ba8"
    stroke-width: 2
    stroke-dash: 3
  }
}
private_ns.private_block_out -> host_ns.host_mount: "ISOLATED" {
  style: {
    stroke: "#f38ba8"
    stroke-width: 2
    stroke-dash: 3
  }
}

# SLAVE: One-way flow
host_ns.host_event -> slave_ns.slave_in: "MASTER → SLAVE" {
  style: {
    stroke: "#fab387"
    stroke-width: 3
  }
}
slave_ns.slave_block_out -> host_ns.host_mount: "BLOCK_UP" {
  style: {
    stroke: "#fab387"
    stroke-width: 2
    stroke-dash: 3
  }
}

# UNBINDABLE: Structural block
host_ns.host_event -> unbindable_ns.unbindable_block: "NO_PROP" {
  style: {
    stroke: "#cba6f7"
    stroke-width: 2
    stroke-dash: 3
  }
}

# -----------------------------------------------------------------------------------------
# PEER GROUP INDICATOR
# -----------------------------------------------------------------------------------------
peer_group: "Internal Kernel Peer Group [PG_ID: 12]" {
  shape: rectangle
  style: {
    fill: "#1e3a2f"
    stroke: "#a6e3a1"
    stroke-dash: 5
  }
  near: top-left

  peer_host: "host_member" {
    shape: circle
    style.fill: "#a6e3a1"
  }
  peer_shared: "shared_member" {
    shape: circle
    style.fill: "#a6e3a1"
  }
  peer_host <-> peer_shared: "mnt_peer_list traversal" {
    style: {
      stroke: "#a6e3a1"
      stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------------------
# TABLE OF USE CASES
# -----------------------------------------------------------------------------------------
container_context: "Container Runtime Use Cases" {
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    stroke: "#6c7086"
    border-radius: 5
  }
  
  table: ||md
  | Propagation Type | Engineering Use Case |
  | :--- | :--- |
  | **SHARED** | Bi-directional volume sharing (sidecars, shared logs) |
  | **PRIVATE** | Default container isolation (standard pivot_root) |
  | **SLAVE** | Host-to-container updates (Read-only dynamic configs) |
  | **UNBINDABLE** | Preventing 'mount explosion' in complex nested envs |
  ||
}