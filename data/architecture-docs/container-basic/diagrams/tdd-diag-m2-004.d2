direction: right
layout-engine: elk
title: {
  label: pivot_root Error Cases
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# Initial state
Start: {
  shape: circle
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
  }
}
# Validation checks
Check_New_Root: {
  label: "Check new_root\nis mount point?"
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
Check_Put_Old: {
  label: "Check put_old\nunder new_root?"
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
Check_Busy: {
  label: "Check new_root\nhas other mounts?"
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
# Success state
Success: {
  label: "pivot_root\nSUCCESS"
  shape: circle
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
    font-color: "#2E7D32"
    bold: true
  }
}
# Error states
EINVAL_NotMount: {
  label: "EINVAL\nnew_root is not\na mount point"
  shape: square
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 2
    font-color: "#C62828"
  }
}
EINVAL_NotUnder: {
  label: "EINVAL\nput_old is not\nunder new_root"
  shape: square
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 2
    font-color: "#C62828"
  }
}
EBUSY_Mounts: {
  label: "EBUSY\nnew_root has\nother mounts attached"
  shape: square
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
    stroke-width: 2
    font-color: "#AD1457"
  }
}
# Legend
legend: {
  label: Legend
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
  }
  legend_start: {
    label: "Start/End"
    shape: circle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
    }
  }
  legend_decision: {
    label: "Decision"
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
    }
  }
  legend_error: {
    label: "Error State"
    shape: square
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
    }
  }
  legend_success: {
    label: "Success"
    shape: circle
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
    }
  }
}
# Connections (state machine flow)
Start -> Check_New_Root: {
  label: "pivot_root(new_root, put_old)"
  style: {
    stroke: "#1976D2"
  }
}
Check_New_Root -> Check_Put_Old: {
  label: "YES"
  style: {
    stroke: "#388E3C"
  }
}
Check_New_Root -> EINVAL_NotMount: {
  label: "NO"
  style: {
    stroke: "#D32F2F"
    stroke-dash: 3
  }
}
Check_Put_Old -> Check_Busy: {
  label: "YES"
  style: {
    stroke: "#388E3C"
  }
}
Check_Put_Old -> EINVAL_NotUnder: {
  label: "NO"
  style: {
    stroke: "#D32F2F"
    stroke-dash: 3
  }
}
Check_Busy -> Success: {
  label: "NO"
  style: {
    stroke: "#388E3C"
    bold: true
  }
}
Check_Busy -> EBUSY_Mounts: {
  label: "YES"
  style: {
    stroke: "#C2185B"
    stroke-dash: 3
  }
}
# Error annotations
EINVAL_NotMount_annotation: {
  label: "errno = 22\nInvalid argument"
  shape: text
  style: {
    font-color: "#C62828"
    font-size: 11
    italic: true
  }
}
EINVAL_NotMount -> EINVAL_NotMount_annotation: {
  style: {
    stroke: "transparent"
  }
}
EINVAL_NotUnder_annotation: {
  label: "errno = 22\nInvalid argument"
  shape: text
  style: {
    font-color: "#C62828"
    font-size: 11
    italic: true
  }
}
EINVAL_NotUnder -> EINVAL_NotUnder_annotation: {
  style: {
    stroke: "transparent"
  }
}
EBUSY_Mounts_annotation: {
  label: "errno = 16\nDevice or resource busy"
  shape: text
  style: {
    font-color: "#AD1457"
    font-size: 11
    italic: true
  }
}
EBUSY_Mounts -> EBUSY_Mounts_annotation: {
  style: {
    stroke: "transparent"
  }
}