direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 40
  }
}

classes: {
  directory: {
    style: {
      fill: "#6b5b95"
      stroke: "#483d8b"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  binary_static: {
    style: {
      fill: "#4682b4"
      stroke: "#b22222"
      stroke-width: 3
      font-color: white
    }
  }
  binary_shared: {
    style: {
      fill: "#4682b4"
      stroke: "#191970"
      stroke-width: 1
      font-color: white
    }
  }
  symlink: {
    style: {
      fill: "#f0f8ff"
      stroke: "#4682b4"
      stroke-dash: 3
    }
  }
  config_file: {
    style: {
      fill: "#ffffff"
      stroke: "#708090"
      stroke-width: 1
    }
  }
  pseudo_fs: {
    style: {
      fill: "#e0ffe0"
      stroke: "#006400"
      font-color: "#006400"
    }
  }
  device_node: {
    style: {
      fill: "#fff0f0"
      stroke: "#8b0000"
      font-color: "#8b0000"
    }
  }
}

rootfs: "/ (rootfs)" {
  class: directory
  tooltip: "Standard OCI-compliant root filesystem layout"

  bin: "/bin" {
    class: directory
    busybox: "busybox (ELF64)" {
      class: binary_static
      label: "busybox\nMode: 0755\nSize: ~1.2MB"
    }
    sh: "sh -> busybox" {
      class: symlink
    }
    ls: "ls -> busybox" {
      class: symlink
    }
    cp: "cp -> busybox" {
      class: symlink
    }
  }

  lib: "/lib" {
    class: directory
    libc_so: "libc.so.6" {
      class: binary_shared
      label: "libc.so.6\nMode: 0644\nSize: 2.1MB"
    }
    ld_linux: "ld-linux-x86-64.so.2" {
      class: binary_shared
      label: "ld-linux.so\nMode: 0755\nSize: 190KB"
    }
    libm: "libm.so.6" {
      class: binary_shared
      label: "libm.so.6\nMode: 0644\nSize: 1.3MB"
    }
  }

  etc: "/etc" {
    class: directory
    hostname: "hostname" { class: config_file }
    hosts: "hosts" { class: config_file }
    resolv_conf: "resolv.conf" { class: config_file }
    passwd: "passwd" {
      class: config_file
      label: "passwd\nMode: 0644\nOwner: 0:0"
    }
  }

  proc: "/proc" {
    class: pseudo_fs
    tooltip: "Virtual kernel process information"
    self: "self/"
    uptime: "uptime"
    meminfo: "meminfo"
  }

  sys: "/sys" {
    class: pseudo_fs
    tooltip: "Kernel object and device attributes"
    class_dir: "class/"
    kernel: "kernel/"
    fs: "fs/"
  }

  dev: "/dev" {
    class: directory
    null: "null" {
      class: device_node
      label: "null\nType: c\nMajor: 1, Minor: 3"
    }
    zero: "zero" {
      class: device_node
      label: "zero\nType: c\nMajor: 1, Minor: 5"
    }
    console: "console" {
      class: device_node
      label: "console\nType: c\nMajor: 5, Minor: 1"
    }
    urandom: "urandom" {
      class: device_node
      label: "urandom\nType: c\nMajor: 1, Minor: 9"
    }
    shm: "shm/" { class: directory }
    pts: "pts/" { class: directory }
  }

  tmp: "/tmp" {
    class: directory
    style.stroke-dash: 5
    label: "/tmp\nMode: 1777 (Sticky)"
  }

  run: "/run" {
    class: directory
    label: "/run\nMode: 0755"
  }
}

# --- Internal Logical Connections ---

rootfs.bin.sh -> rootfs.bin.busybox: "multicall" {
  style.stroke: "#b22222"
}
rootfs.bin.ls -> rootfs.bin.busybox: "multicall" {
  style.stroke: "#b22222"
}
rootfs.bin.cp -> rootfs.bin.busybox: "multicall" {
  style.stroke: "#b22222"
}

rootfs.bin.busybox -> rootfs.lib.libc_so: "dynamic link" {
  style.stroke: "#4682b4"
  source-arrowhead: * { shape: diamond }
}

# --- Implementation Requirements Table ---

implementation_spec: |'md
### rootfs Implementation Requirements (OCI/Docker)

| Component | Target Type | Min. Size | Permission | Purpose |
| :--- | :--- | :--- | :--- | :--- |
| **Busybox** | Static ELF | 1.2 MB | 0755 | Core system utilities |
| **Glibc** | Dynamic Lib | 2.1 MB | 0644 | System API provider |
| **etc/passwd** | Text File | 128 B | 0644 | User/Group metadata |
| **dev/null** | Char Dev | 0 B | 0666 | Bit-bucket device |
| **proc** | VFS Mount | N/A | 0555 | Kernel state exposure |

**Bootstrapping Sequence (Strict):**
1. `mkdir -p bin dev etc lib proc sys tmp run`
2. `cp -a /usr/bin/busybox ./bin/`
3. `cd ./bin && for i in $(./busybox --list); do ln -s busybox $i; done`
4. `printf "root:x:0:0:root:/root:/bin/sh\n" > ./etc/passwd`
5. `mknod -m 666 ./dev/null c 1 3`
'| {
  near: top-right
  shape: text
  style.font-size: 13
}

# --- Structural Skeleton ---

rootfs -> rootfs.bin
rootfs -> rootfs.lib
rootfs -> rootfs.etc
rootfs -> rootfs.proc
rootfs -> rootfs.sys
rootfs -> rootfs.dev
rootfs -> rootfs.tmp
rootfs -> rootfs.run

rootfs.dev -> rootfs.dev.null
rootfs.dev -> rootfs.dev.zero
rootfs.dev -> rootfs.dev.console
rootfs.dev -> rootfs.dev.urandom
rootfs.dev -> rootfs.dev.shm
rootfs.dev -> rootfs.dev.pts

rootfs.bin -> rootfs.bin.busybox
rootfs.bin -> rootfs.bin.sh
rootfs.bin -> rootfs.bin.ls
rootfs.bin -> rootfs.bin.cp

rootfs.lib -> rootfs.lib.libc_so
rootfs.lib -> rootfs.lib.ld_linux
rootfs.lib -> rootfs.lib.libm

rootfs.etc -> rootfs.etc.hostname
rootfs.etc -> rootfs.etc.hosts
rootfs.etc -> rootfs.etc.resolv_conf
rootfs.etc -> rootfs.etc.passwd

legend: "Filesystem Typology" {
  near: bottom-right
  dir: "Directory (Purple)" { class: directory }
  bin: "Static Binary (Steel Blue)" { class: binary_static }
  lib: "Shared Object (Blue/Thin)" { class: binary_shared }
  node: "Device Node (Red)" { class: device_node }
  vfs: "Pseudo-FS (Green)" { class: pseudo_fs }
}