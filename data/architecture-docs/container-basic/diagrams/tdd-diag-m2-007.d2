vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

direction: right

title: {
  label: "Mount Propagation: Shared vs Private Demo\nWhy MS_PRIVATE is Mandatory for Container Isolation"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# Shared Propagation Branch (BAD)
shared_branch: {
  label: "MS_SHARED Propagation\n(UNSAFE - Mount Leakage)"
  style: {
    fill: "#fee2e2"
    stroke: "#dc2626"
    stroke-width: 3
  }
  
  host_ns_shared: {
    label: "Host Mount Namespace\n(Peer Group ID: 1)"
    shape: rectangle
    style: {
      fill: "#fef2f2"
      stroke: "#b91c1c"
    }
  }
  
  container_ns_shared: {
    label: "Container Mount Namespace\n(Cloned with MS_SHARED)"
    shape: rectangle
    style: {
      fill: "#fef2f2"
      stroke: "#b91c1c"
    }
  }
  
  step1_shared: {
    label: "1. clone(CLONE_NEWNS)\nMount propagation: SHARED"
    shape: rectangle
    style: {
      fill: "#fecaca"
      border-radius: 5
    }
  }
  
  step2_shared: {
    label: "2. Container mounts /dev/shm\ntmpfs at /dev/shm"
    shape: rectangle
    style: {
      fill: "#fecaca"
      border-radius: 5
    }
  }
  
  step3_shared: {
    label: "3. Mount event propagates\nvia shared peer group"
    shape: rectangle
    style: {
      fill: "#fca5a5"
      border-radius: 5
    }
  }
  
  leak_shared: {
    label: "⚠️ MOUNT LEAKAGE\nHost sees container's /dev/shm\nSecurity boundary VIOLATED"
    shape: diamond
    style: {
      fill: "#ef4444"
      font-color: white
      bold: true
      stroke: "#991b1b"
    }
  }
  
  host_ns_shared -> step1_shared: "fork/clone"
  step1_shared -> container_ns_shared: "inherits flags"
  container_ns_shared -> step2_shared: "mount operation"
  step2_shared -> step3_shared: "kernel event"
  step3_shared -> leak_shared: "side effect"
  
  step3_shared -> host_ns_shared: "Propagation\n(leaks back)" {
    style: {
      stroke-dash: 4
      stroke: "#dc2626"
      bold: true
    }
  }
}

# Private Propagation Branch (GOOD)
private_branch: {
  label: "MS_PRIVATE Propagation\n(SAFE - Full Isolation)"
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    stroke-width: 3
  }
  
  host_ns_private: {
    label: Host Mount Namespace
    shape: rectangle
    style: {
      fill: "#f0fdf4"
      stroke: "#15803d"
    }
  }
  
  container_ns_private: {
    label: "Container Mount Namespace\n(MS_PRIVATE applied)"
    shape: rectangle
    style: {
      fill: "#f0fdf4"
      stroke: "#15803d"
    }
  }
  
  step1_private: {
    label: "1. clone(CLONE_NEWNS)"
    shape: rectangle
    style: {
      fill: "#bbf7d0"
      border-radius: 5
    }
  }
  
  step2_private: {
    label: "2. mount(\"\", \"/\", MS_REC | MS_PRIVATE)\nRecursively mark PRIVATE"
    shape: rectangle
    style: {
      fill: "#bbf7d0"
      border-radius: 5
    }
  }
  
  step3_private: {
    label: "3. Container mounts /dev/shm\ntmpfs at /dev/shm"
    shape: rectangle
    style: {
      fill: "#bbf7d0"
      border-radius: 5
    }
  }
  
  isolated_private: {
    label: "✓ ISOLATION COMPLETE\nMount event does NOT propagate\nHost namespace unaffected"
    shape: diamond
    style: {
      fill: "#22c55e"
      font-color: white
      bold: true
      stroke: "#15803d"
    }
  }
  
  host_ns_private -> step1_private
  step1_private -> container_ns_private
  container_ns_private -> step2_private
  step2_private -> step3_private
  step3_private -> isolated_private
  
  step3_private -> host_ns_private: "No propagation\n(isolated)" {
    style: {
      stroke-dash: 4
      stroke: "#16a34a"
      opacity: 0
    }
  }
}

# Comparison
shared_branch <-> private_branch: "Key Difference:\nShared = Bidirectional Propagation\nPrivate = No Propagation" {
  style: {
    stroke: "#6366f1"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Technical explanation box
explanation: {
  label: |md
    ## Mount Propagation Types

    **MS_SHARED**: Mount events propagate bidirectionally
    • Container mount → visible to host
    • Host mount → visible to container
    • **SECURITY RISK**: Information leakage

    **MS_PRIVATE**: No propagation at all
    • Complete isolation of mount tree
    • Required for container security
    • Used with MS_REC for recursive application

    **Why Mandatory?**
    • Prevents mount namespace leaks
    • Stops container mounts appearing on host
    • Blocks host mount changes in container
    • Essential for `pivot_root()` safety
  |
  shape: rectangle
  style: {
    fill: "#f8fafc"
    stroke: "#475569"
    border-radius: 8
  }
  near: bottom-center
}

# Legend
legend: {
  label: "Legend / Comparison Key"
  near: bottom-right
  style: {
    fill: "#f1f5f9"
    stroke: "#64748b"
  }
  
  red_box: "Mount Leakage Path" {
    shape: rectangle
    style: {
      fill: "#ef4444"
      font-color: white
    }
  }
  
  green_box: "Isolated Boundary" {
    shape: rectangle
    style: {
      fill: "#22c55e"
      font-color: white
    }
  }
  
  red_box -> green_box: "Security Hardening" {
    style.stroke-width: 2
  }
}

# Invisible anchors for layout
shared_branch -> explanation: {
  style.opacity: 0
}
private_branch -> explanation: {
  style.opacity: 0
}