layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  near: top-center
  label: |md
    # Algorithm: Device Node Creation for Minimal /dev
    **Standard Mode:** `S_IFCHR | 0666` (Character Device, World Read/Write)
    **Context:** Populating container rootfs `/dev` mount point via `mknod`
  |
}

# -----------------------------------------------------------------------------------------
# STEP 1: NULL DEVICE
# -----------------------------------------------------------------------------------------
Step_1: {
  label: "1. Create Null Device"
  direction: right
  
  before: {
    label: "Before: Initial state"
    directory: {
      shape: folder
      label: "/dev/"
      empty: "EMPTY" {
        style: {
          stroke-dash: 3
          opacity: 0.5
        }
      }
    }
  }
  
  after: {
    label: "After: mknod(null)"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)" {
        style: {
          stroke: "#ff0000"
          stroke-width: 4
          font-color: "#ff0000"
          bold: true
        }
      }
    }
  }
  
  (before -> after)[0]: {
    label: |md
      **Syscall:** `mknod("null", S_IFCHR|0666, makedev(1, 3))`
      **Function:** Data sink; discards all input.
    |
  }
}

# -----------------------------------------------------------------------------------------
# STEP 2: ZERO DEVICE
# -----------------------------------------------------------------------------------------
Step_2: {
  label: "2. Create Zero Device"
  direction: right
  
  before: {
    label: "Before: Step 1 Result"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
    }
  }
  
  after: {
    label: "After: mknod(zero)"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
      zero_dev: "zero (1, 5)" {
        style: {
          stroke: "#ff0000"
          stroke-width: 4
          font-color: "#ff0000"
          bold: true
        }
      }
    }
  }
  
  (before -> after)[0]: {
    label: |md
      **Syscall:** `mknod("zero", S_IFCHR|0666, makedev(1, 5))`
      **Function:** Infinite stream of NULL bytes (\0).
    |
  }
}

# -----------------------------------------------------------------------------------------
# STEP 3: URANDOM DEVICE
# -----------------------------------------------------------------------------------------
Step_3: {
  label: "3. Create Urandom Device"
  direction: right
  
  before: {
    label: "Before: Step 2 Result"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
      zero_dev: "zero (1, 5)"
    }
  }
  
  after: {
    label: "After: mknod(urandom)"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
      zero_dev: "zero (1, 5)"
      urandom_dev: "urandom (1, 9)" {
        style: {
          stroke: "#ff0000"
          stroke-width: 4
          font-color: "#ff0000"
          bold: true
        }
      }
    }
  }
  
  (before -> after)[0]: {
    label: |md
      **Syscall:** `mknod("urandom", S_IFCHR|0666, makedev(1, 9))`
      **Function:** Non-blocking entropy source.
    |
  }
}

# -----------------------------------------------------------------------------------------
# STEP 4: RANDOM DEVICE
# -----------------------------------------------------------------------------------------
Step_4: {
  label: "4. Create Random Device"
  direction: right
  
  before: {
    label: "Before: Step 3 Result"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
      zero_dev: "zero (1, 5)"
      urandom_dev: "urandom (1, 9)"
    }
  }
  
  after: {
    label: "After: mknod(random)"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
      zero_dev: "zero (1, 5)"
      urandom_dev: "urandom (1, 9)"
      random_dev: "random (1, 8)" {
        style: {
          stroke: "#ff0000"
          stroke-width: 4
          font-color: "#ff0000"
          bold: true
        }
      }
    }
  }
  
  (before -> after)[0]: {
    label: |md
      **Syscall:** `mknod("random", S_IFCHR|0666, makedev(1, 8))`
      **Function:** High-quality blocking entropy source.
    |
  }
}

# -----------------------------------------------------------------------------------------
# STEP 5: TTY DEVICE
# -----------------------------------------------------------------------------------------
Step_5: {
  label: "5. Create TTY Device"
  direction: right
  
  before: {
    label: "Before: Step 4 Result"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
      zero_dev: "zero (1, 5)"
      urandom_dev: "urandom (1, 9)"
      random_dev: "random (1, 8)"
    }
  }
  
  after: {
    label: "After: mknod(tty)"
    directory: {
      shape: folder
      label: "/dev/"
      null_dev: "null (1, 3)"
      zero_dev: "zero (1, 5)"
      urandom_dev: "urandom (1, 9)"
      random_dev: "random (1, 8)"
      tty_dev: "tty (5, 0)" {
        style: {
          stroke: "#ff0000"
          stroke-width: 4
          font-color: "#ff0000"
          bold: true
        }
      }
    }
  }
  
  (before -> after)[0]: {
    label: |md
      **Syscall:** `mknod("tty", S_IFCHR|0666, makedev(5, 0))`
      **Function:** Alias for current process's terminal.
    |
  }
}

# -----------------------------------------------------------------------------------------
# SUMMARY
# -----------------------------------------------------------------------------------------
Summary: {
  shape: text
  near: bottom-center
  label: |md
    ### Implementation Summary Table
    | Device | Major | Minor | Syscall Mode | Device Type |
    | :--- | :--- | :--- | :--- | :--- |
    | **null** | 1 | 3 | `S_IFCHR \| 0666` | Character |
    | **zero** | 1 | 5 | `S_IFCHR \| 0666` | Character |
    | **urandom** | 1 | 9 | `S_IFCHR \| 0666` | Character |
    | **random** | 1 | 8 | `S_IFCHR \| 0666` | Character |
    | **tty** | 5 | 0 | `S_IFCHR \| 0666` | Character |
  |
}

Step_1 -> Step_2
Step_2 -> Step_3
Step_3 -> Step_4
Step_4 -> Step_5
Step_5 -> Summary