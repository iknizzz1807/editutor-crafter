direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- Network Topology: Bridge-Based Container Isolation ---

internet: "External Network (Internet)" {
  shape: cloud
  tooltip: "Public WAN - Default Route 0.0.0.0/0 via ISP Gateway"
  style: {
    stroke-width: 4
    fill: "#f3f4f6"
    stroke: "#64748b"
    shadow: true
  }
}

# --- Host Network Namespace (Root Context) ---
# Intel Manual Reference: ARCH-NET-001
host_ns: "Host Network Namespace (Root NetNS)" {
  tooltip: "The primary networking stack where physical device drivers and system-wide bridges reside."
  style: {
    fill: "#f8fafc"
    stroke: "#1e293b"
    stroke-width: 4
    double-border: true
  }

  physical_nic: "Physical NIC: eth0" {
    shape: rectangle
    label: |'md
      ### Interface: eth0
      - **Driver**: `virtio_net` / `ixgbe`
      - **L3 Address**: `192.168.1.100/24`
      - **L2 Address**: `52:54:00:12:34:56`
      - **State**: `IFF_UP`, `LOWER_UP`
      - **MTU**: 1500 | **TX Queues**: 8
    '|
    style: {
      fill: "#dbeafe"
      stroke: "#2563eb"
      stroke-width: 2
    }
  }

  iptables_nat: "Kernel Packet Engine: Netfilter/NAT" {
    shape: parallelogram
    label: |'md
      ### L3 Forwarding Logic
      - **Table**: `nat` | **Chain**: `POSTROUTING`
      - **Action**: `MASQUERADE` (Source NAT)
      - **Kernel Parameter**: `net.ipv4.ip_forward=1`
      - **Tracking**: `nf_conntrack` enabled
    '|
    style: {
      fill: "#ffedd5"
      stroke: "#f97316"
      stroke-width: 2
    }
  }

  bridge_ctr0: "Virtual Switch: ctr0 (Linux Bridge)" {
    label: |'md
      ### Bridge: ctr0 (Software L2)
      - **Gateway IP**: `10.200.0.1/16`
      - **MAC Address**: `02:42:ac:11:00:01`
      - **Protocol**: `802.1d` Ethernet Bridge
      - **Aging Time**: 300s | **STP**: Disabled
    '|
    style: {
      fill: "#f3e8ff"
      stroke: "#7e22ce"
      stroke-width: 3
    }

    ports: "FDB Port Map (Forwarding Database)" {
      grid-columns: 3
      grid-gap: 20
      
      veth_host0: "port: veth_h0" {
        label: "veth_h0\nifindex: 10\nState: UP\nMaster: ctr0"
        style.fill: "#3b82f6"
        style.font-color: white
        style.border-radius: 4
        style.bold: true
      }
      veth_host1: "port: veth_h1" {
        label: "veth_h1\nifindex: 12\nState: UP\nMaster: ctr0"
        style.fill: "#3b82f6"
        style.font-color: white
        style.border-radius: 4
        style.bold: true
      }
      veth_host_n: "port: veth_hN" {
        label: "veth_hN\nFree Pool\n(Available)"
        style.fill: "#94a3b8"
        style.stroke-dash: 4
        style.opacity: 0.6
      }
    }
  }

  # Kernel internal paths
  physical_nic <-> iptables_nat: "sk_buff ingress/egress" {
    style.stroke-width: 2
  }
  iptables_nat <-> bridge_ctr0: "L3 Local Routing" {
    style.stroke-width: 2
  }
}

# --- Container Isolation Domains ---

container_1: "Container 1 Namespace (PID: 1234)" {
  tooltip: "Isolated Network via CLONE_NEWNET"
  style: {
    fill: "#eff6ff"
    stroke: "#3b82f6"
    stroke-dash: 6
    stroke-width: 3
  }

  eth0: "eth0 (Container End)" {
    label: |'md
      **Interface: eth0**
      - **L3**: `10.200.0.2/16`
      - **L2**: `02:42:0a:c8:00:02`
      - **Peer ID**: 10 (veth_h0)
    '|
    style.fill: "#3b82f6"
    style.font-color: white
    style.bold: true
  }

  routing: "L3 Local Routing Table" {
    shape: rectangle
    label: |'md
      | Target | Gateway | Interface |
      | :--- | :--- | :--- |
      | 0.0.0.0/0 | 10.200.0.1 | eth0 |
      | 10.200.0.0/16 | 0.0.0.0 | eth0 |
    '|
    style.font: mono
    style.fill: "#ffffff"
    style.stroke: "#94a3b8"
  }

  lo: "lo (Localhost)" {
    label: "lo\n127.0.0.1/8\nMTU: 65536"
    style.fill: "#86efac"
    style.stroke: "#16a34a"
    style.border-radius: 20
  }
}

container_2: "Container 2 Namespace (PID: 5678)" {
  style: {
    fill: "#eff6ff"
    stroke: "#3b82f6"
    stroke-dash: 6
    stroke-width: 3
  }

  eth0: "eth0 (Container End)" {
    label: |'md
      **Interface: eth0**
      - **L3**: `10.200.0.3/16`
      - **L2**: `02:42:0a:c8:00:03`
      - **Peer ID**: 12 (veth_h1)
    '|
    style.fill: "#3b82f6"
    style.font-color: white
    style.bold: true
  }

  routing: "Default Gateway" {
    shape: rectangle
    label: "Target: 0.0.0.0/0\nvia 10.200.0.1"
    style.font: mono
    style.fill: "#ffffff"
    style.stroke: "#94a3b8"
  }
}

# --- Inter-Namespace Links (Veth Pairs) ---

host_ns.bridge_ctr0.ports.veth_host0 <-> container_1.eth0: "veth tunnel [h:10 <-> c:11]\nL2 Virtual Pipe" {
  style: {
    stroke-width: 6
    stroke: "#3b82f6"
    animated: true
  }
}

host_ns.bridge_ctr0.ports.veth_host1 <-> container_2.eth0: "veth tunnel [h:12 <-> c:13]\nL2 Virtual Pipe" {
  style: {
    stroke-width: 6
    stroke: "#3b82f6"
  }
}

host_ns.physical_nic -> internet: "WAN Egress (802.3)" {
  style: {
    stroke-width: 4
    stroke: "#1e293b"
  }
}

# --- Engineering Annotations ---

specs: |'md
  ### Data Plane Invariants
  1. **Veth Drivers**: Defined in `drivers/net/veth.c`. Implements `ndo_start_xmit` to switch context between namespaces.
  2. **Namespace Traversal**: Packet ingress on Container `eth0` is redirected to Host `veth_h*` via `netif_rx()` in the sibling context.
  3. **Bridge Forwarding**: `ctr0` populates its Forwarding Database (FDB) by learning source MACs from the `veth_h*` ports.
  4. **NAT Masquerade**: Packet headers are modified at the Host `eth0` egress to replace Container IP with Host IP (192.168.1.100).
  5. **MTU Consistency**: All internal virtual interfaces should match physical MTU (1500) to prevent kernel-level fragmentation.
'| {
  near: bottom-left
  style.font-size: 14
}

# --- Legend ---

legend: "Infrastructure Color Map" {
  near: bottom-right
  veth: "Virtual Ethernet Interface" {
    style.fill: "#3b82f6"
    style.font-color: white
    style.bold: true
  }
  bridge: "Linux Bridge (L2 Switch)" {
    style.fill: "#f3e8ff"
    style.stroke: "#7e22ce"
  }
  netfilter: "IP Stack / NAT Logic" {
    style.fill: "#ffedd5"
    style.stroke: "#f97316"
  }
  container: "Namespace Isolation Boundary" {
    style.stroke: "#3b82f6"
    style.stroke-dash: 6
    style.fill: "#eff6ff"
  }
  phys: "Physical Hardware NIC" {
    style.fill: "#dbeafe"
    style.stroke: "#2563eb"
  }
}