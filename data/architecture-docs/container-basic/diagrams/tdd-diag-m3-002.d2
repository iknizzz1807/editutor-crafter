direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# =============================================================================
# VETH PAIR VIRTUAL CABLE MECHANICS - KERNEL MEMORY FLOW
# =============================================================================

title: ||md
  # Linux Kernel veth Driver: Packet Cross-Namespace Traversal
  **Mechanism**: Pure Software Queueing (No Hardware/DMA)
  **Driver Path**: `drivers/net/veth.c` | `net/core/dev.c`
  **Complexity**: O(1) Memory Copy (Pointer Swap)
|| {
  near: top-center
  shape: rectangle
  style: {
    stroke-width: 0
    fill: transparent
  }
}

# -----------------------------------------------------------------------------
# STYLING CLASSES (Intel Manual Quality Palette)
# -----------------------------------------------------------------------------
classes: {
  struct_header: {
    style: {
      fill: "#9b59b6" # Header: Purple
      font-color: white
      bold: true
      stroke: "#4a235a"
    }
  }
  memory_data: {
    style: {
      fill: "#3498db" # Data: Blue
      font-color: white
      stroke: "#1a5276"
    }
  }
  pointer_field: {
    style: {
      fill: "#e67e22" # Pointers: Orange
      font-color: white
      stroke: "#873600"
    }
  }
  padding_gray: {
    style: {
      fill: "#95a5a6" # Padding: Gray
      stroke: "#717d7e"
    }
  }
  namespace_container: {
    style: {
      stroke-dash: 5
      stroke-width: 2
      fill: "#f4f6f7"
    }
  }
}

# -----------------------------------------------------------------------------
# MEMORY LAYOUT REPRESENTATION
# -----------------------------------------------------------------------------
kernel_memory: Kernel Slab Memory {
  style: {
    fill: "#fdfefe"
    stroke: "#2c3e50"
    stroke-width: 3
  }

  host_namespace: Host Network Namespace (init_net) {
    class: namespace_container
    
    veth0: {
      shape: sql_table
      label: "struct net_device (veth0) @0xFFFF8880..."
      "0x00": "char name[16] ('veth_host')" {constraint: "16B"}
      "0x10": "--- cache line padding ---" {constraint: "48B"}
      "0x40": "const struct net_device_ops *netdev_ops" {constraint: "8B"}
      "0x48": "const struct ethtool_ops *ethtool_ops" {constraint: "8B"}
      "0xC0": "void *priv (Pointer to veth_priv)" {constraint: "8B"}
      "0x180": "rx_handler_func_t *rx_handler (NULL)" {constraint: "8B"}
      "0x200": "unsigned int mtu (1500)" {constraint: "4B"}
      footer: "sizeof=2304 bytes (approx 36 cache lines)"
    }

    veth0_priv: {
      shape: sql_table
      label: "struct veth_priv (Private Data)"
      "0x00": "struct net_device *peer (Points to veth1)" {constraint: "8B"}
      "0x08": "struct net_device *dev (Back-pointer)" {constraint: "8B"}
      "0x10": "struct veth_rq rq[NUM_QUEUES]" {constraint: "Var"}
      "0x40": "u64_stats_t dropped" {constraint: "8B"}
    }
  }

  container_namespace: Container Network Namespace (net_ns_1) {
    class: namespace_container

    veth1: {
      shape: sql_table
      label: "struct net_device (eth0) @0xFFFF8880..."
      "0x00": "char name[16] ('eth0')" {constraint: "16B"}
      "0x40": "const struct net_device_ops *netdev_ops" {constraint: "8B"}
      "0x120": "rx_handler_func_t *rx_handler (ip_rcv)" {constraint: "8B"}
      "0x180": "struct softnet_data *backlog_queue" {constraint: "8B"}
      "0x1C0": "struct netdev_queue *_tx" {constraint: "8B"}
      footer: "sizeof=2304 bytes"
    }

    veth1_priv: {
      shape: sql_table
      label: "struct veth_priv"
      "0x00": "struct net_device *peer (Points to veth0)" {constraint: "8B"}
      "0x08": "struct net_device *dev (Back-pointer)" {constraint: "8B"}
    }
  }

  packet_buffer: {
    shape: sql_table
    label: "struct sk_buff (The 'Socket Buffer')"
    "0x00": "unsigned char *head (Buffer start)" {constraint: "8B"}
    "0x08": "unsigned char *data (Payload start)" {constraint: "8B"}
    "0x10": "unsigned char *tail (Payload end)" {constraint: "8B"}
    "0x18": "struct net_device *dev (Logical Owner)" {constraint: "8B"}
    "0x20": "__be16 protocol (ETH_P_IP)" {constraint: "2B"}
    "0x22": "--- alignment padding ---" {constraint: "6B"}
    "0x28": "ktime_t tstamp" {constraint: "8B"}
    footer: "sizeof=256 bytes (Pre-allocated Slab)"
  }
}

# -----------------------------------------------------------------------------
# APPLY CLASSES
# -----------------------------------------------------------------------------
# Apply to veth0
kernel_memory.host_namespace.veth0.class: struct_header
kernel_memory.host_namespace.veth0."0x00".class: memory_data
kernel_memory.host_namespace.veth0."0x10".class: padding_gray
kernel_memory.host_namespace.veth0."0x40".class: pointer_field
kernel_memory.host_namespace.veth0."0x48".class: pointer_field
kernel_memory.host_namespace.veth0."0xC0".class: pointer_field
kernel_memory.host_namespace.veth0."0x180".class: pointer_field
kernel_memory.host_namespace.veth0."0x200".class: memory_data

# Apply to veth0_priv
kernel_memory.host_namespace.veth0_priv.class: struct_header
kernel_memory.host_namespace.veth0_priv."0x00".class: pointer_field
kernel_memory.host_namespace.veth0_priv."0x08".class: pointer_field
kernel_memory.host_namespace.veth0_priv."0x10".class: memory_data
kernel_memory.host_namespace.veth0_priv."0x40".class: memory_data

# Apply to veth1
kernel_memory.container_namespace.veth1.class: struct_header
kernel_memory.container_namespace.veth1."0x00".class: memory_data
kernel_memory.container_namespace.veth1."0x40".class: pointer_field
kernel_memory.container_namespace.veth1."0x120".class: pointer_field
kernel_memory.container_namespace.veth1."0x180".class: pointer_field
kernel_memory.container_namespace.veth1."0x1C0".class: pointer_field

# Apply to veth1_priv
kernel_memory.container_namespace.veth1_priv.class: struct_header
kernel_memory.container_namespace.veth1_priv."0x00".class: pointer_field
kernel_memory.container_namespace.veth1_priv."0x08".class: pointer_field

# Apply to sk_buff
kernel_memory.packet_buffer.class: struct_header
kernel_memory.packet_buffer."0x00".class: pointer_field
kernel_memory.packet_buffer."0x08".class: pointer_field
kernel_memory.packet_buffer."0x10".class: pointer_field
kernel_memory.packet_buffer."0x18".class: pointer_field
kernel_memory.packet_buffer."0x20".class: memory_data
kernel_memory.packet_buffer."0x22".class: padding_gray
kernel_memory.packet_buffer."0x28".class: memory_data

# -----------------------------------------------------------------------------
# LOGICAL DATA FLOW & ACTIONS
# -----------------------------------------------------------------------------
app: User Application Socket {
  shape: person
  style.fill: "#D5F5E3"
}

app -> kernel_memory.host_namespace.veth0: "1. ndo_start_xmit(skb)" {
  style: {
    stroke: "#27ae60"
    stroke-width: 3
    bold: true
  }
}

# TRANSITION: Pointer handover logic
handover: |md
  **VETH DRIVER HANDOVER**
  `veth_xmit()` -> `dev_forward_skb()`
| {
  near: bottom-left
}

# THE VIRTUAL LINK (Memory dereference)
kernel_memory.host_namespace.veth0_priv."0x00" -> kernel_memory.container_namespace.veth1: "2. Lookup Peer Device" {
  style: {
    stroke: "#e67e22"
    stroke-width: 3
    animated: true
  }
}

# PACKET RE-ASSIGNMENT (Ownership update in SKB field)
kernel_memory.packet_buffer."0x18" -> kernel_memory.container_namespace.veth1: "3. skb->dev = peer_dev" {
  style: {
    stroke: "#3498db"
    stroke-width: 4
    bold: true
  }
}

kernel_memory.container_namespace.veth1 -> stack: "4. netif_rx(skb) Enqueue" {
  style.stroke: "#8e44ad"
}
stack: Container IP Stack (Ingress) {
  shape: parallelogram
  style.fill: "#E8F8F5"
}

# -----------------------------------------------------------------------------
# ANNOTATIONS
# -----------------------------------------------------------------------------
infra_notes: |md
  ### KERNEL PERFORMANCE CHARACTERISTICS
  - **Memory Locality**: Data remains in the same RAM bank. No DMA is performed.
  - **Namespace Isolation**: Separation is logical (L3/L2 stack state), not physical.
  - **Backlog Mechanism**: If peer ingress queue is full, `NET_RX_DROP` is returned.
  - **Driver Logic**: `veth_xmit` simply calls `netif_rx` on the peer device.
| {
  shape: rectangle
  near: bottom-center
  style: {
    fill: "#fff9c4"
    stroke: "#f1c40f"
    stroke-width: 2
    double-border: true
  }
}

# -----------------------------------------------------------------------------
# POINTER RELATIONSHIPS (Internal Struct Linkages)
# -----------------------------------------------------------------------------
kernel_memory.host_namespace.veth0."0xC0" -> kernel_memory.host_namespace.veth0_priv: "INTERNAL_NETDEV_PRIV" {
  style.stroke-dash: 3
}

kernel_memory.container_namespace.veth1."0x40" -> kernel_memory.container_namespace.veth1_priv: "INTERNAL_NETDEV_PRIV" {
  style.stroke-dash: 3
}

# THE "VIRTUAL CABLE" PAIRING
kernel_memory.host_namespace.veth0_priv."0x00" <-> kernel_memory.container_namespace.veth1_priv."0x00": "Virtual Pair Coupling" {
  style: {
    stroke: "#e67e22"
    stroke-width: 5
    stroke-dash: 0
  }
}