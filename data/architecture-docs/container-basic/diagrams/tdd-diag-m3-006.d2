direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# =========================================================================
# VETH NETLINK MESSAGE MEMORY LAYOUT (RTM_NEWLINK)
# Target: Intel Manual Quality Engineering Spec
# Alignment: 4-byte boundary (RTA_ALIGN)
# Total size: 100 bytes (0x64)
# =========================================================================

veth_netlink_msg: {
  shape: sql_table
  label: "veth Netlink Message Structure | sizeof=100 bytes"
  style: {
    stroke: "#000000"
    stroke-width: 2
    font-size: 18
    bold: true
  }

  # Offset | Field Identifier                             | Size (Bytes)
  # -----------------------------------------------------------------------
  
  # nlmsghdr: Primary Netlink Header
  "0x00": "nlmsghdr.nlmsg_len" {constraint: "4B"}
  "0x04": "nlmsghdr.nlmsg_type (RTM_NEWLINK)" {constraint: "2B"}
  "0x06": "nlmsghdr.nlmsg_flags (NLM_F_REQUEST | NLM_F_ACK)" {constraint: "2B"}
  "0x08": "nlmsghdr.nlmsg_seq" {constraint: "4B"}
  "0x0C": "nlmsghdr.nlmsg_pid" {constraint: "4B"}

  # ifinfomsg: Interface Information Structure
  "0x10": "ifinfomsg.ifi_family (AF_UNSPEC)" {constraint: "1B"}
  "0x11": "ifinfomsg.__ifi_pad" {constraint: "1B"}
  "0x12": "ifinfomsg.ifi_type" {constraint: "2B"}
  "0x14": "ifinfomsg.ifi_index" {constraint: "4B"}
  "0x18": "ifinfomsg.ifi_flags" {constraint: "4B"}
  "0x1C": "ifinfomsg.ifi_change" {constraint: "4B"}

  # Attribute: IFLA_IFNAME (Host side)
  "0x20": "rtattr.rta_len (IFLA_IFNAME)" {constraint: "2B"}
  "0x22": "rtattr.rta_type (IFLA_IFNAME)" {constraint: "2B"}
  "0x24": "Payload: 'veth_host\\0'" {constraint: "10B"}
  "0x2E": "Padding (RTA_ALIGN)" {constraint: "2B"}

  # Attribute: IFLA_LINKINFO (Nested)
  "0x30": "rtattr.rta_len (IFLA_LINKINFO)" {constraint: "2B"}
  "0x32": "rtattr.rta_type (IFLA_LINKINFO)" {constraint: "2B"}

  # Nested: IFLA_INFO_KIND
  "0x34": "  rtattr.rta_len (IFLA_INFO_KIND)" {constraint: "2B"}
  "0x36": "  rtattr.rta_type (IFLA_INFO_KIND)" {constraint: "2B"}
  "0x38": "  Payload: 'veth\\0'" {constraint: "5B"}
  "0x3D": "  Padding (RTA_ALIGN)" {constraint: "3B"}

  # Nested: IFLA_INFO_DATA (Driver specific data)
  "0x40": "  rtattr.rta_len (IFLA_INFO_DATA)" {constraint: "2B"}
  "0x42": "  rtattr.rta_type (IFLA_INFO_DATA)" {constraint: "2B"}

  # Attribute: VETH_INFO_PEER (Nested in Data)
  "0x44": "    rtattr.rta_len (VETH_INFO_PEER)" {constraint: "2B"}
  "0x46": "    rtattr.rta_type (VETH_INFO_PEER)" {constraint: "2B"}

  # Nested Body: peer_ifinfomsg (16B header for the peer)
  "0x48": "    peer_ifinfomsg (Embedded Body)" {constraint: "16B"}

  # Attribute: IFLA_IFNAME (Container side)
  "0x58": "    rtattr.rta_len (IFLA_IFNAME)" {constraint: "2B"}
  "0x5A": "    rtattr.rta_type (IFLA_IFNAME)" {constraint: "2B"}
  "0x5C": "    Payload: 'eth0\\0'" {constraint: "5B"}
  "0x61": "    Padding (RTA_ALIGN)" {constraint: "3B"}
}

# -------------------------------------------------------------------------
# COLOR CODING (Intel Manual Standards)
# Purple=Headers, Blue=Data, Orange=Nested, Gray=Padding
# -------------------------------------------------------------------------

veth_netlink_msg."0x00".style.fill: "#E1BEE7"
veth_netlink_msg."0x04".style.fill: "#E1BEE7"
veth_netlink_msg."0x06".style.fill: "#E1BEE7"
veth_netlink_msg."0x08".style.fill: "#E1BEE7"
veth_netlink_msg."0x0C".style.fill: "#E1BEE7"
veth_netlink_msg."0x10".style.fill: "#E1BEE7"
veth_netlink_msg."0x11".style.fill: "#E1BEE7"
veth_netlink_msg."0x12".style.fill: "#E1BEE7"
veth_netlink_msg."0x14".style.fill: "#E1BEE7"
veth_netlink_msg."0x18".style.fill: "#E1BEE7"
veth_netlink_msg."0x1C".style.fill: "#E1BEE7"

veth_netlink_msg."0x20".style.fill: "#BBDEFB"
veth_netlink_msg."0x22".style.fill: "#BBDEFB"
veth_netlink_msg."0x24".style.fill: "#BBDEFB"
veth_netlink_msg."0x2E".style.fill: "#EEEEEE"

veth_netlink_msg."0x30".style.fill: "#FFE0B2"
veth_netlink_msg."0x32".style.fill: "#FFE0B2"
veth_netlink_msg."0x34".style.fill: "#BBDEFB"
veth_netlink_msg."0x36".style.fill: "#BBDEFB"
veth_netlink_msg."0x38".style.fill: "#BBDEFB"
veth_netlink_msg."0x3D".style.fill: "#EEEEEE"

veth_netlink_msg."0x40".style.fill: "#FFE0B2"
veth_netlink_msg."0x42".style.fill: "#FFE0B2"
veth_netlink_msg."0x44".style.fill: "#FFE0B2"
veth_netlink_msg."0x46".style.fill: "#FFE0B2"

veth_netlink_msg."0x48".style.fill: "#E1BEE7"
veth_netlink_msg."0x58".style.fill: "#BBDEFB"
veth_netlink_msg."0x5A".style.fill: "#BBDEFB"
veth_netlink_msg."0x5C".style.fill: "#BBDEFB"
veth_netlink_msg."0x61".style.fill: "#EEEEEE"

# -------------------------------------------------------------------------
# BOUNDARIES & ANNOTATIONS
# Fix: Using 'top-right' constant for layout stability in ELK
# -------------------------------------------------------------------------

cache_line_boundary: "--- ⚠️ CACHE LINE BOUNDARY (64B / 0x40) ---" {
  near: top-right
  style: {
    font-color: "#D32F2F"
    font-size: 14
    bold: true
    italic: true
  }
}

legend: {
  near: bottom-left
  label: "Memory Map Legend"
  style: {
    stroke: "#000000"
    stroke-width: 1
    fill: "#FFFFFF"
  }
  
  h: Header (nlmsghdr / ifinfomsg) { style.fill: "#E1BEE7" }
  d: Attribute Payload / Data { style.fill: "#BBDEFB" }
  n: Nested Root Attribute { style.fill: "#FFE0B2" }
  p: Alignment Padding { style.fill: "#EEEEEE" }
}

explanation: |md
  ### veth Netlink Implementation Design
  - **Memory Alignment**: All `rtattr` structures are `RTA_ALIGN`'d to 4B.
  - **Nesting Hierarchy**: 
    1. `IFLA_LINKINFO` (Nested container)
    2. `IFLA_INFO_KIND` -> Driver identifier string ("veth")
    3. `IFLA_INFO_DATA` -> Driver-specific attributes
    4. `VETH_INFO_PEER` -> Encapsulated interface config for the peer.
  - **Cache Line Impact**: The `IFLA_INFO_DATA` start marks the 64-byte boundary.
| {
  near: bottom-center
}