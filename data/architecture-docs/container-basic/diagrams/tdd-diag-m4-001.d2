direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- GLOBAL STYLES & CLASSES ---
classes: {
  cache_line: {
    style: {
      stroke-dash: 5
    }
  }
  page_boundary: {
    style: {
      stroke-width: 4
    }
  }
}

cgroups_comparison: {
  label: "Linux Control Groups: Hierarchy Comparison (Implementation Spec)"
  
  # --- V1 LEGACY ARCHITECTURE ---
  v1_legacy: {
    label: "cgroups v1: Multiple Hierarchies (Legacy Model)"
    style: {
      fill: "#f8f9fa"
      stroke: "#7d3c98"
      stroke-width: 4
    }

    memory_hierarchy: {
      shape: sql_table
      label: "Hierarchy: /sys/fs/cgroup/memory/"
      style.fill: "#7d3c98"
      style.font-color: white
      
      "0x00": "uint64* | tasks (PIDs) [64B Cache Line]" {style.font-color: "orange"; class: cache_line}
      "0x40": "uint64 | memory.limit_in_bytes [8B]" {style.font-color: "#2e86c1"}
      "0x48": "uint64 | memory.usage_in_bytes [8B]" {style.font-color: "#2e86c1"}
      "0x50": "byte[16] | alignment padding [16B]" {style.font-color: "gray"}
      
      tooltip: "sizeof=4096B (Aligned Page)"
    }

    cpu_hierarchy: {
      shape: sql_table
      label: "Hierarchy: /sys/fs/cgroup/cpu/"
      style.fill: "#7d3c98"
      style.font-color: white
      
      "0x00": "uint64* | tasks (PIDs) [64B Cache Line]" {style.font-color: "orange"; class: cache_line}
      "0x40": "int64 | cpu.cfs_quota_us [8B]"
      "0x48": "uint64 | cpu.cfs_period_us [8B]"
    }

    pids_hierarchy: {
      shape: sql_table
      label: "Hierarchy: /sys/fs/cgroup/pids/"
      style.fill: "#7d3c98"
      style.font-color: white
      
      "0x00": "uint64* | tasks (PIDs) [64B Cache Line]" {style.font-color: "orange"; class: cache_line}
      "0x40": "int64 | pids.max [8B]"
      "0x48": "int32 | pids.current [4B]"
    }

    process_node: "Kernel Task Struct\n(PID 12345)" {
      shape: circle
      style.fill: "#fff3e0"
      style.stroke: "orange"
      style.stroke-width: 3
    }

    # Internal Pointers (Kernel-space references)
    process_node -> memory_hierarchy."0x00": "mm_struct ptr" {style.stroke: "orange"; style.stroke-dash: 5}
    process_node -> cpu_hierarchy."0x00": "sched_entity ptr" {style.stroke: "orange"; style.stroke-dash: 5}
    process_node -> pids_hierarchy."0x00": "pids ptr" {style.stroke: "orange"; style.stroke-dash: 5}

    v1_notes: |md
      ### v1 Design Characteristics
      1. **Siloed Controllers**: Each resource (CPU, Mem) manages its own independent tree.
      2. **N:M Complexity**: A process may reside in `/memory/groupA` and `/cpu/groupB` simultaneously.
      3. **Inconsistent States**: Coordination overhead between OOM kills and PID limits.
    |
  }

  # --- V2 UNIFIED ARCHITECTURE ---
  v2_unified: {
    label: "cgroups v2: Unified Hierarchy (Modern Model)"
    style: {
      fill: "#f0f7ff"
      stroke: "#2e86c1"
      stroke-width: 4
    }

    root_node: {
      shape: sql_table
      label: "/sys/fs/cgroup/ (VFS Root)"
      style.fill: "#2e86c1"
      style.font-color: white
      
      "0x00": "bitmask | cgroup.controllers [8B]"
      "0x08": "bitmask | cgroup.subtree_control [8B]"
      "0x10": "file_handle | cgroup.procs [32B]" {style.font-color: "orange"}
    }

    container_a: {
      shape: sql_table
      label: "cgroup: /container_a/"
      style.fill: "#d6eaf8"
      
      "0x00": "file_handle | cgroup.procs (PID 12345)" {style.font-color: "orange"}
      "0x20": "uint64 | memory.max [8B]"
      "0x28": "int64 | cpu.max [8B]"
      "0x30": "int64 | pids.max [8B]"
      
      tooltip: "sizeof=8192B (Multi-controller Slab)"
    }

    root_node -> container_a: "vfs_mkdir (inheritance)" {style.stroke-width: 3}

    process_node_v2: "Kernel Task Struct\n(PID 12345)" {
      shape: circle
      style.fill: "#fff3e0"
      style.stroke: "orange"
      style.stroke-width: 3
    }

    # Unified Reference (css_set)
    process_node_v2 -> container_a."0x00": "css_set reference" {
      style.stroke: "orange"
      style.stroke-dash: 5
    }

    v2_notes: |md
      ### v2 Design Characteristics
      1. **Unified Hierarchy**: One directory structure for all resource controllers.
      2. **No-Internal-Process Rule**: Processes only reside in leaf nodes.
      3. **Subtree Control**: Enabled via `+controller` bitmask.
      4. **Atomic Transitions**: Simplified process migration across nodes.
    |
  }
}

# --- ROOT LEVEL ANNOTATIONS ---
legend: {
  near: bottom-right
  style: {
    fill: "#ffffff"
    stroke: "#333333"
    stroke-width: 1
    border-radius: 8
  }

  l1: "Purple Header = v1 Controller Root" { style.font-color: "#7d3c98" }
  l2: "Blue Header = v2 Unified Root" { style.font-color: "#2e86c1" }
  l3: "Orange Rows/Lines = Task/PID Pointers" { style.font-color: "orange" }
  l4: "Dashed Line = Pointer/Reference Relationship"
  l5: "Solid Line = VFS Hierarchy (Parent-Child)"
}

global_metadata: |md
  **Implementation Details**
  - All memory offsets are relative to the controller struct base.
  - Page size assumed 4096B.
  - V2 uses `cgroup.procs` instead of `tasks` for thread-group atomic management.
| {
  near: bottom-left
}