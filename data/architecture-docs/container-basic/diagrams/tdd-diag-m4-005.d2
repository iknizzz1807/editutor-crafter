direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT LEVEL CONTAINERS ---

memory_layout: {
  label: "cgroup v2 Container Directory Layout (Virtual Memory View)"
  style: {
    stroke-width: 4
    fill: "#f3e5f5"
    font-size: 20
  }

  # --- MEMORY BLOCKS ---
  
  # Offset: 0x0000
  controllers: "0x0000 | cgroup.controllers | 64B" {
    width: 600
    style: {
      fill: "#6a1b9a"
      font-color: white
      bold: true
    }
  }

  cache_line_1: "----------------------- CACHE LINE BOUNDARY (64B) -----------------------" {
    style: {
      stroke-dash: 5
      stroke: gray
      font-size: 10
    }
  }

  # Offset: 0x0040
  subtree: "0x0040 | cgroup.subtree_control | 64B" {
    width: 600
    style: {
      fill: "#6a1b9a"
      font-color: white
      bold: true
    }
  }

  cache_line_2: "----------------------- CACHE LINE BOUNDARY (128B) -----------------------" {
    style: {
      stroke-dash: 5
      stroke: gray
      font-size: 10
    }
  }

  # Offset: 0x0080
  procs: "0x0080 | cgroup.procs | 64B" {
    width: 600
    style: {
      fill: "#ef6c00"
      font-color: white
      bold: true
    }
  }

  # Offset: 0x00C0
  mem_max: "0x00C0 | memory.max | 8B" {
    width: 600
    style: {
      fill: "#1565c0"
      font-color: white
    }
  }

  # Offset: 0x00C8
  mem_curr: "0x00C8 | memory.current | 8B" {
    width: 600
    style: {
      fill: "#1565c0"
      font-color: white
    }
  }

  # Offset: 0x00D0
  padding_1: "0x00D0 | Padding / Reserved | 3888B" {
    width: 600
    style: {
      fill: "#9e9e9e"
      opacity: 0.4
    }
  }

  page_boundary_1: "==================== PAGE BOUNDARY (4096B) ====================" {
    width: 650
    style: {
      stroke-width: 6
      stroke: black
      font-color: black
      bold: true
    }
  }

  # Offset: 0x1000
  mem_stat: "0x1000 | memory.stat | 4096B" {
    width: 600
    style: {
      fill: "#1565c0"
      font-color: white
    }
  }

  page_boundary_2: "==================== PAGE BOUNDARY (8192B) ====================" {
    width: 650
    style: {
      stroke-width: 6
      stroke: black
      font-color: black
      bold: true
    }
  }

  # Offset: 0x2000
  cpu_max: "0x2000 | cpu.max | 16B" {
    width: 600
    style: {
      fill: "#1565c0"
      font-color: white
    }
  }

  # Offset: 0x2010
  cpu_stat: "0x2010 | cpu.stat | 4096B" {
    width: 600
    style: {
      fill: "#1565c0"
      font-color: white
    }
  }

  # Offset: 0x3010
  pids_max: "0x3010 | pids.max | 8B" {
    width: 600
    style: {
      fill: "#1565c0"
      font-color: white
    }
  }

  # Offset: 0x3018
  pids_curr: "0x3018 | pids.current | 8B" {
    width: 600
    style: {
      fill: "#1565c0"
      font-color: white
    }
  }

  # Offset: 0x3020
  free_space: "0x3020 | Free / Extension Space | Variable" {
    width: 600
    style: {
      fill: "#2e7d32"
      font-color: white
      stroke-dash: 2
    }
  }

  # --- Sequence Flow ---
  controllers -> cache_line_1
  cache_line_1 -> subtree
  subtree -> cache_line_2
  cache_line_2 -> procs
  procs -> mem_max
  mem_max -> mem_curr
  mem_curr -> padding_1
  padding_1 -> page_boundary_1
  page_boundary_1 -> mem_stat
  mem_stat -> page_boundary_2
  page_boundary_2 -> cpu_max
  cpu_max -> cpu_stat
  cpu_stat -> pids_max
  pids_max -> pids_curr
  pids_curr -> free_space
}

# --- ROOT LEVEL LEGEND AND ANNOTATIONS ---

legend: {
  near: top-right
  h: Header (Cgroup Meta) {
    style.fill: "#6a1b9a"
    style.font-color: white
  }
  d: Data (Cgroup Metrics) {
    style.fill: "#1565c0"
    style.font-color: white
  }
  p: Process/Pointers {
    style.fill: "#ef6c00"
    style.font-color: white
  }
  pad: Padding / Reserved {
    style.fill: "#9e9e9e"
    style.font-color: black
  }
  f: Free / Growth Area {
    style.fill: "#2e7d32"
    style.font-color: white
  }
}

annotation: |md
  ### Memory Invariants & Technical Specs
  - **Addressing**: Offsets follow `Base + Offset` convention. Total mapped range shown: 16KB.
  - **Cache Line Alignment**: Configuration files `controllers` and `subtree_control` are 64B-aligned to prevent false sharing during directory traversal.
  - **Page Isolation**: Heavy metric files like `memory.stat` and `cpu.stat` are allocated on dedicated 4KB pages to optimize TLB caching for high-frequency reads.
  - **Growth Logic**: Metadata is fixed at page start; dynamic extensions or child group descriptors utilize the Green (0x3020+) region.
| {
  near: bottom-left
}