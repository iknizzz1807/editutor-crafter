direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- DOCUMENTATION AND CONTEXT ---
title: |md
  ### Controller Enablement Chain (cgroup v2)
  **Engineer Manual:** Determine file availability based on subtree control bitmasks.
  **Mechanism:** `cgroup_apply_control()` -> `css_populate_dir()`
| {
  near: top-center
}

# --- GLOBAL CLASSES ---
classes: {
  header: {
    style: {
      fill: "#e1d5e7"
      stroke: "#9673a6"
      font-color: "#7e5a9b"
      bold: true
      border-radius: 4
    }
  }
  kernel_struct: {
    style: {
      fill: "#dae8fc"
      stroke: "#6c8ebf"
      stroke-width: 2
    }
  }
  active_write: {
    style: {
      stroke: "#b85450"
      stroke-width: 4
      animated: true
    }
  }
  new_file: {
    style: {
      fill: "#d5e8d4"
      stroke: "#82b366"
      bold: true
      font-size: 11
    }
  }
}

# --- ROOT CGROUP LAYER ---
root_cgroup: "/sys/fs/cgroup (Root Hierarchy)" {
  class: kernel_struct
  tooltip: "The root cgroup node (cgrp_dfl_root)"
  
  controllers: "cgroup.controllers (RO)" {
    class: header
    data: "cpuset cpu io memory pids" {
      style.font: mono
    }
  }

  subtree: "cgroup.subtree_control (RW)" {
    class: header
    initial_state: " [ ] (empty bitmask) " {
      style.stroke-dash: 3
    }
  }
}

# --- THE TRANSITION ACTION ---
activation: "VFS_WRITE: cgroup_subtree_control_write" {
  shape: package
  near: center-right
  command: |md
    `# Enable memory, cpu, and pids for children`
    `echo "+memory +cpu +pids" > /sys/fs/cgroup/cgroup.subtree_control`
  | {
    style.font: mono
    style.fill: "#f8f9fa"
  }
}

# Signal path for write operation
root_cgroup.subtree -> activation: "Trigger Mask Change" { class: active_write }

# --- CHILD CGROUP LAYER ---
child_cgroup: "/sys/fs/cgroup/container_12345 (Child Node)" {
  class: kernel_struct
  tooltip: "Child nodes inherit capability but require explicit enablement via parent"
  
  parent_ref: "Inherited Capability Mask" {
    shape: rectangle
    style.fill: "#fff2cc"
    style.stroke: "#d6b656"
    style.stroke-dash: 2
  }

  visibility: "cgroup.controllers (Visible Pool)" {
    class: header
    data: "memory cpu pids" {
      style.font: mono
    }
  }

  control_files: "Auto-Generated Interface Files" {
    grid-columns: 1
    mem: "memory.max (0x0C8)" { class: new_file }
    cpu: "cpu.max    (0x1A2)" { class: new_file }
    pid: "pids.max   (0x2F4)" { class: new_file }
  }
}

# --- CONNECTIONS AND LOGIC ---
# Propagation of enablement to the visible pool
activation -> child_cgroup.visibility: "Kernel Populates Inodes" {
  style.stroke: "#82b366"
  style.stroke-width: 2
}

# Root constraints filtering the child pool
root_cgroup.controllers -> child_cgroup.visibility: "Kernel Constraint Check" {
  style.stroke-dash: 5
}

# Mapping: Enabled controller -> File realization
# FIX: Declared as a primary edge instead of attempting to label an undeclared index.
child_cgroup.visibility -> child_cgroup.control_files: "css_populate_dir()" {
  style.stroke: "#6c8ebf"
  style.stroke-width: 2
}

# --- TECHNICAL FOOTNOTES ---
explanation: |md
  #### Implementation Logic (cgroup.c)
  1. **Validation:** `cgroup_control_audit()` ensures enabled bits in `subtree_control` are present in `cgroup.controllers`.
  2. **Propagation:** The bitmask is merged into the child's `cgrp->subtree_ss_mask`.
  3. **Realization:** For every child, `cgroup_apply_control_enable()` iterates through all enabled subsystems.
  4. **Inode Creation:** `css_populate_dir()` is called for each enabled subsystem, creating the `.max` and `.stat` files shown above.
| {
  near: bottom-center
}

# Styling global connection rules for clarity
(child_cgroup.visibility -> child_cgroup.control_files)[*]: {
  style.stroke: "#6c8ebf"
}