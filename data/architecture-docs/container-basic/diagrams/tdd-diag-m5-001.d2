direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# -----------------------------------------------------------------------------------------
# 1. LOGICAL FLOW: UID NAMESPACE TRANSLATION (VUID -> KUID)
# -----------------------------------------------------------------------------------------
translation_logic: "UID Translation Logic (Kernel-Side Implementation)" {
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#f8f9fa"
  }

  container_view: "User Namespace (unshare -U)" {
    process: "Process (Task)" {
      shape: person
      label: "Process\nCreds: VUID 0"
      tooltip: "Process believes it is root within the namespace"
      style.fill: "#B6DDF6"
    }
  }

  kernel_mapping: "Kernel Mapping Engine" {
    style.stroke-dash: 5
    
    map_lookup: "id_map Lookup Table" {
      shape: sql_table
      label: "struct uid_gid_map (extent list)"
      
      # Data fields representing the mapping logic
      field1: "ns_start: 0 (VUID)" {constraint: "Source Offset"}
      field2: "host_start: 1000 (KUID)" {constraint: "Target Base"}
      field3: "count: 1" {constraint: "Range Size"}
      
      style.fill: "#E4DBFE"
    }

    translator: "make_kuid()" {
      shape: diamond
      label: "Map Logic:\nKUID = host_start + (VUID - ns_start)"
      style.fill: "#FFF9C9"
    }
  }

  host_view: "Host/Initial Namespace View" {
    effective_id: "Effective Identity (kuid_t)" {
      shape: person
      label: "Process\nKUID: 1000 (user)"
      tooltip: "The ID the kernel uses for permission checks"
      style.fill: "#ACE1AF"
    }
  }

  # Call sequence definitions
  container_view.process -> kernel_mapping.map_lookup: "1. Syscall: open(\"/data/log\")" {
    style: {
      stroke: orange
      stroke-width: 2
      font-size: 11
    }
  }
  kernel_mapping.map_lookup -> kernel_mapping.translator: "2. Extent Match" {
    style.stroke: orange
  }
  kernel_mapping.translator -> host_view.effective_id: "3. Resolved KUID" {
    style: {
      stroke: orange
      animated: true
      stroke-width: 3
    }
  }
}

# -----------------------------------------------------------------------------------------
# 2. RESOURCE OWNERSHIP TRANSFORMATION (VFS SHIFTING)
# -----------------------------------------------------------------------------------------
resource_example: "VFS Inode Ownership Mapping" {
  near: bottom-center
  direction: right
  style.fill: "#ffffff"

  container_fs: "Container View (NS)" {
    file_inner: "/app/data.txt" {
      label: "Inode i_uid: 0\n(Displayed via from_kuid())"
      style.fill: "#B6DDF6"
    }
  }

  vfs_layer: "VFS Layer" {
    shape: parallelogram
    label: "VFS Shift Logic\n(i_uid_read / i_uid_write)"
    style: {
      fill: "#E4DBFE"
      stroke-dash: 3
    }
  }

  host_fs: "Physical Disk (Host)" {
    file_outer: "/var/lib/container/rootfs/app/data.txt" {
      label: "Inode i_uid: 1000\n(On-Disk Storage)"
      style.fill: "#ACE1AF"
    }
  }

  container_fs.file_inner -> vfs_layer: "Write Attr"
  vfs_layer -> host_fs.file_outer: "Commit to Disk"
}

# -----------------------------------------------------------------------------------------
# 3. MEMORY LAYOUT: STRUCT UID_GID_EXTENT
# -----------------------------------------------------------------------------------------
mapping_memory: "Memory Layout: struct uid_gid_extent" {
  shape: sql_table
  style.fill: white
  
  header: "Byte Offset | Member Variable | Size | Type" {
    style: {
      fill: "#E4DBFE"
      bold: true
    }
  }
  
  # Offsets and sizes for C-structure implementation
  row1: "0x00 | first (ns_start) | 4B | u32" {
    style.fill: "#B6DDF6"
  }
  row2: "0x04 | lower_first (host_start) | 4B | u32" {
    style.fill: "#B6DDF6"
  }
  row3: "0x08 | count | 4B | u32" {
    style.fill: "#B6DDF6"
  }
  row4: "0x0C | (struct alignment padding) | 4B | padding" {
    style.fill: "#D3D3D3"
  }

  sizeof_struct: "sizeof(struct uid_gid_extent) = 16 bytes (Cache Aligned)" {
    near: bottom-right
    shape: text
    style: {
      font-size: 11
      italic: true
      font-color: "#666666"
    }
  }
}

# -----------------------------------------------------------------------------------------
# 4. DOCUMENTATION AND INVARIANTS
# -----------------------------------------------------------------------------------------
annotation: |md
  ### UID Mapping Invariants (Linux Kernel)
  1. **Two-Way Translation**: 
     - **Inbound**: Syscalls from process use `id_map` to check permissions against kernel `kuid_t`.
     - **Outbound**: Userland tools (e.g., `ls`) map `kuid_t` back to VUIDs via `from_kuid()`.
  2. **Capability Scoping**: Administrative actions (`CAP_SYS_ADMIN`) held by UID 0 inside a namespace are restricted to that namespace and its children.
  3. **Isolation Guarantee**:
     - Real Root (Host UID 0) is never mapped to a standard container user.
     - Result: If a process escapes, it retains UID 1000 on the host, preventing host-level root compromise.
| {
  near: top-right
}

# -----------------------------------------------------------------------------------------
# 5. LEGEND
# -----------------------------------------------------------------------------------------
legend: "Diagram Key" {
  near: bottom-left
  
  vuid: "Virtual UID (Container-Local)" {
    style.fill: "#B6DDF6"
  }
  kuid: "Kernel UID (KUID / Host ID)" {
    style.fill: "#ACE1AF"
  }
  kdata: "Kernel Internal Metadata" {
    style.fill: "#E4DBFE"
  }
  logic: "Translation/Decision Logic" {
    style.fill: "#FFF9C9"
  }
}