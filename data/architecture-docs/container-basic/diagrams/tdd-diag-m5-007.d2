layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
  colors: {
    header_purple: "#D1C4E9"
    data_blue: "#BBDEFB"
    green_field: "#C8E6C9"
    padding_gray: "#F5F5F5"
    pointer_orange: "#FFE0B2"
    border_gray: "#BDBDBD"
  }
}

# ---------------------------------------------------------------------------------
# 1. MEMORY LAYOUT DEFINITION: struct id_map_extent_t
# ---------------------------------------------------------------------------------
uid_extent_struct: {
  label: "struct id_map_extent_t (sizeof=12 bytes)"
  
  header: {
    shape: sql_table
    style.fill: "#D1C4E9"
    
    # Offsets | Field Name | Size
    "0x00": "ns_start" {constraint: "u32 (4B)"}
    "0x04": "host_start" {constraint: "u32 (4B)"}
    "0x08": "count" {constraint: "u32 (4B)"}
  }

  body: "Instance Data: (0 1000 1)" {
    shape: sql_table
    style.fill: "#BBDEFB"
    "Value": "0 | 1000 | 1"
  }
}

# ---------------------------------------------------------------------------------
# 2. MAIN ARRAY CONTAINER: struct id_map_t
# ---------------------------------------------------------------------------------
id_map_container: {
  label: "struct id_map_t (Memory Allocation View)"
  
  layout: {
    shape: sql_table
    style.stroke: "#BDBDBD"
    
    # Byte Offset | Member | Size/Alignment
    "0x00": "extents[0]" {constraint: "12B"}
    "0x0C": "extents[1]" {constraint: "12B"}
    "0x18": "extents[2]" {constraint: "12B"}
    "0x24": "extents[3]" {constraint: "12B"}
    "0x30": "extents[4]" {constraint: "12B"}
    
    # Explicit Cache Line Alignment Annotation
    "0x3C": "extent_count" {constraint: "u32 (4B)"}
    
    # 64-byte alignment visual marker
    "64B": "--- L1 CACHE LINE BOUNDARY (64B) ---" {
      style: {
        stroke-dash: 5
        font-color: "#757575"
        bold: true
      }
    }
    
    "0x40": "map_string[256]" {constraint: "char[256]"}
  }
  
  style.fill: "#F5F5F5"
}

# ---------------------------------------------------------------------------------
# 3. LOGICAL FORMATTING & EXPLANATION
# ---------------------------------------------------------------------------------
# Using triple pipes to prevent markdown table pipes from interfering with D2 parser
string_format: ||md
### ProcFS Interface Format
**Path:** `/proc/<pid>/uid_map`

**Raw Data Representation:**
`"0 1000 1\n"`

| Logic Field | ProcFS Value | Binary mapping |
| :--- | :--- | :--- |
| **nsid_first** | 0 | `extents[0].ns_start` |
| **hostid_first** | 1000 | `extents[0].host_start` |
| **count** | 1 | `extents[0].count` |
||

# ---------------------------------------------------------------------------------
# 4. CONNECTIONS & MAPPING
# ---------------------------------------------------------------------------------
id_map_container.layout."0x00" -> uid_extent_struct.header : "Binary Structure Reference" {
  style: {
    stroke: "#EF6C00"
    stroke-width: 2
    animated: true
  }
}

# ---------------------------------------------------------------------------------
# 5. ANNOTATIONS & NOTES
# ---------------------------------------------------------------------------------
annotations: {
  near: bottom-center
  
  notes: ||md
### Implementation Specifications
- **Header (Purple)**: Structure metadata and control fields.
- **Data (Blue)**: Active UID/GID translation extents.
- **Green Segment**: ProcFS raw string buffer for kernel-to-user reporting.
- **Alignment**: Note that `id_map_extent_t` is 12 bytes; array indexing assumes no padding between elements in `id_map_t`.
- **Cache Optimization**: `extent_count` is positioned at 0x3C to remain within the first 64B cache line alongside the most active extents.
||
}

# ---------------------------------------------------------------------------------
# 6. DETAILED STYLING
# ---------------------------------------------------------------------------------
# Apply systematic colors based on role
uid_extent_struct.header."0x00".style.fill: "#BBDEFB"
uid_extent_struct.header."0x04".style.fill: "#BBDEFB"
uid_extent_struct.header."0x08".style.fill: "#BBDEFB"

id_map_container.layout."0x00".style.fill: "#BBDEFB"
id_map_container.layout."0x0C".style.fill: "#BBDEFB"
id_map_container.layout."0x18".style.fill: "#BBDEFB"
id_map_container.layout."0x24".style.fill: "#BBDEFB"
id_map_container.layout."0x30".style.fill: "#BBDEFB"
id_map_container.layout."0x3C".style.fill: "#D1C4E9"
id_map_container.layout."0x40".style.fill: "#C8E6C9"

# Global attributes
uid_extent_struct.style.shadow: true
id_map_container.style.shadow: true