direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    go_primary: "#00ADD8"
    go_secondary: "#5DC9E2"
    tokio_primary: "#FF6F00"
    tokio_secondary: "#FFB74D"
    your_primary: "#7C4DFF"
    your_secondary: "#B388FF"
    shared: "#4CAF50"
    diff: "#F44336"
  }
}
title: {
  label: "Architecture Comparison: Coroutine Runtimes"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  go_runtime: {
    direction: down
    label: "Go Runtime"
    style: {
      fill: "${colors.go_secondary}"
      stroke: "${colors.go_primary}"
      stroke-width: 3
      border-radius: 8
    }
    go_stacks: {
      label: "Stack Management"
      shape: rectangle
      style.fill: white
      f1: "Initial: 2 KB (tiny)"
      f2: "Growth: Segmented → Contiguous"
      f3: "Copy-on-grow with pointer updates"
      f4: "Max: ~1 GB per goroutine"
    }
    go_scheduler: {
      label: "Scheduler"
      shape: rectangle
      style.fill: white
      s1: "M:N work-stealing (G/P/M model)"
      s2: "Per-P local run queue (LIFO)"
      s3: "Global run queue (FIFO)"
      s4: "runnext slot for spawned child"
    }
    go_preempt: {
      label: "Preemption"
      shape: rectangle
      style.fill: white
      p1: "Compiler-assisted (async safe points)"
      p2: "Signal-based (SIGURG) since 1.14"
      p3: "Stack check on function entry"
      p4: "~10ms time slices"
    }
    go_io: {
      label: "I/O Integration"
      shape: rectangle
      style.fill: white
      i1: "Netpoller (epoll/kqueue/IOCP)"
      i2: "Integrated with scheduler"
      i3: "Non-blocking by default"
      i4: "File I/O: blocking in sysmon"
    }
    go_stacks -> go_scheduler
    go_scheduler -> go_preempt
    go_preempt -> go_io
  }
  tokio_runtime: {
    direction: down
    label: "Tokio Runtime (Rust)"
    style: {
      fill: "${colors.tokio_secondary}"
      stroke: "${colors.tokio_primary}"
      stroke-width: 3
      border-radius: 8
    }
    tokio_stacks: {
      label: "Stack Management"
      shape: rectangle
      style.fill: white
      f1: "Stackless coroutines (Future trait)"
      f2: "State machine compiled from async fn"
      f3: "Size: ~100 bytes per task (varies)"
      f4: "No recursion across await points"
    }
    tokio_scheduler: {
      label: "Scheduler"
      shape: rectangle
      style.fill: white
      s1: "M:N work-stealing"
      s2: "LIFO slot + inject queue"
      s3: "Per-worker local queue"
      s4: "Budget-based fairness"
    }
    tokio_preempt: {
      label: "Preemption"
      shape: rectangle
      style.fill: white
      p1: "Cooperative only (at .await)"
      p2: "Budget: 128 ops per yield"
      p3: "No forced preemption"
      p4: "Relies on well-behaved tasks"
    }
    tokio_io: {
      label: "I/O Integration"
      shape: rectangle
      style.fill: white
      i1: "mio-based reactor (epoll/kqueue)"
      i2: "Per-task waker registration"
      i3: "File I/O: blocking thread pool"
      i4: "Timer wheel integration"
    }
    tokio_stacks -> tokio_scheduler
    tokio_scheduler -> tokio_preempt
    tokio_preempt -> tokio_io
  }
  your_runtime: {
    direction: down
    label: "Your Runtime"
    style: {
      fill: "${colors.your_secondary}"
      stroke: "${colors.your_primary}"
      stroke-width: 3
      border-radius: 8
    }
    your_stacks: {
      label: "Stack Management"
      shape: rectangle
      style.fill: white
      f1: "Stackful coroutines"
      f2: "Fixed 64 KB per coroutine"
      f3: "Guard page for overflow"
      f4: "Yield from anywhere (incl. FFI)"
    }
    your_scheduler: {
      label: "Scheduler"
      shape: rectangle
      style.fill: white
      s1: "M:N work-stealing"
      s2: "Chase-Lev local queues (LIFO)"
      s3: "Global queue for overflow"
      s4: "Random victim selection"
    }
    your_preempt: {
      label: "Preemption"
      shape: rectangle
      style.fill: white
      p1: "Timer + flag (hybrid)"
      p2: "Signal sets preempt flag"
      p3: "Coroutine checks at safe points"
      p4: "10ms time slices (configurable)"
    }
    your_io: {
      label: "I/O Integration"
      shape: rectangle
      style.fill: white
      i1: "epoll reactor (Linux)"
      i2: "Level-triggered events"
      i3: "File I/O: thread pool"
      i4: "Timer wheel for sleep()"
    }
    your_stacks -> your_scheduler
    your_scheduler -> your_preempt
    your_preempt -> your_io
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  convergence: {
    direction: down
    label: "Convergent Design Choices"
    style: {
      fill: "#C8E6C9"
      stroke: "${colors.shared}"
      stroke-width: 2
      border-radius: 8
    }
    c1: {
      label: "M:N Scheduling"
      shape: rectangle
      style.fill: white
      desc: "Multiplex many tasks onto few threads"
    }
    c2: {
      label: "Work-Stealing"
      shape: rectangle
      style.fill: white
      desc: "Idle threads steal from busy ones"
    }
    c3: {
      label: "Local + Global Queues"
      shape: rectangle
      style.fill: white
      desc: "Fast local ops, global for balance"
    }
    c4: {
      label: "Reactor Pattern"
      shape: rectangle
      style.fill: white
      desc: "epoll/kqueue for readiness notification"
    }
    c5: {
      label: "Per-Task Wakers"
      shape: rectangle
      style.fill: white
      desc: "Wake specific tasks on completion"
    }
    c1 -> c2 -> c3 -> c4 -> c5
  }
  divergence: {
    direction: down
    label: "Key Divergences"
    style: {
      fill: "#FFCDD2"
      stroke: "${colors.diff}"
      stroke-width: 2
      border-radius: 8
    }
    d1: {
      label: "Stack Strategy"
      shape: rectangle
      style.fill: white
      code: |`text
        Go:    2KB → grows (copy)
        Tokio: ~100B state machine
        You:   64KB fixed + guard
      `|
    }
    d2: {
      label: "Preemption Model"
      shape: rectangle
      style.fill: white
      code: |`text
        Go:    Async (signal-based)
        Tokio: Cooperative (.await only)
        You:   Hybrid (flag + safe points)
      `|
    }
    d3: {
      label: "FFI Safety"
      shape: rectangle
      style.fill: white
      code: |`text
        Go:    Cannot yield in cgo
        Tokio: Cannot yield across FFI
        You:   Safe to yield anywhere
      `|
    }
    d4: {
      label: "Memory per Task"
      shape: rectangle
      style.fill: white
      code: |`text
        Go:    2-8 KB (dynamic)
        Tokio: ~100 bytes
        You:   64 KB (fixed)
      `|
    }
    d1 -> d2 -> d3 -> d4
  }
}
row1.go_runtime -> row2.convergence: "shared patterns" {
  style.stroke: "${colors.shared}"
  style.stroke-dash: 3
}
row1.tokio_runtime -> row2.convergence: "shared patterns" {
  style.stroke: "${colors.shared}"
  style.stroke-dash: 3
}
row1.your_runtime -> row2.convergence: "shared patterns" {
  style.stroke: "${colors.shared}"
  style.stroke-dash: 3
}
row1.go_runtime -> row2.divergence: "tradeoffs" {
  style.stroke: "${colors.diff}"
  style.stroke-dash: 3
}
row1.tokio_runtime -> row2.divergence: "tradeoffs" {
  style.stroke: "${colors.diff}"
  style.stroke-dash: 3
}
row1.your_runtime -> row2.divergence: "tradeoffs" {
  style.stroke: "${colors.diff}"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  label: "Legend"
  style: {
    fill: white
    stroke: gray
    border-radius: 4
  }
  l1: "Green = Shared architectural patterns"
  l2: "Red = Design tradeoffs and differences"
}