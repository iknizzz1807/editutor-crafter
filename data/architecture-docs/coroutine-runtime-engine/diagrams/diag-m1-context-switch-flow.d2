direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
header: {
  title: {
    label: |'md
      # Context Switch State Machine
      Trace of a 64-bit yield operation between coroutines
    '|
    style: {
      stroke-width: 0
      fill: transparent
      font-size: 24
      bold: true
    }
  }
}

# --- ROW 1: EXECUTION FLOW ---
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  coro_a: {
    direction: down
    label: "Coroutine A (Yielding) (coro.c)"
    style.fill: "#E8F5E9"
    state_running: {
      label: "Running"
      shape: circle
      style.fill: "#4CAF50"
      style.font-color: white
    }
    state_saving: {
      label: "Saving Context"
      shape: rectangle
      style.fill: "#FFF9C4"
    }
    state_suspended: {
      label: "Suspended"
      shape: circle
      style.fill: "#FFCDD2"
    }
    state_running -> state_saving: "yield_now()"
    state_saving -> state_suspended: "saved"
  }

  spacer1: {
    label: ""
    width: 60
    style.stroke: transparent
    style.fill: transparent
  }

  context_switch: {
    direction: down
    label: "context_switch.S (x86-64)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 2

    step1: {
      label: "1. Save Callee-Saved"
      code: |'asm
        mov [rdi + 0],  rbx
        mov [rdi + 8],  rbp
        mov [rdi + 16], r12
        mov [rdi + 24], r13
        mov [rdi + 32], r14
        mov [rdi + 40], r15
      '|
      width: 280
      style.fill: "#BBDEFB"
    }
    step2: {
      label: "2. Save Stack Ptr"
      code: |'asm
        mov [rdi + 48], rsp
        mov rax, [rsp]       ; ret addr
        mov [rdi + 56], rax  ; rip
      '|
      width: 280
      style.fill: "#90CAF9"
    }
    step3: {
      label: "3. Load Target Regs"
      code: |'asm
        mov rbx, [rsi + 0]
        mov rbp, [rsi + 8]
        mov r12, [rsi + 16]
        mov r13, [rsi + 24]
        mov r14, [rsi + 32]
        mov r15, [rsi + 40]
      '|
      width: 280
      style.fill: "#64B5F6"
    }
    step4: {
      label: "4. Load Stack & JMP"
      code: |'asm
        mov rsp, [rsi + 48]
        mov rax, [rsi + 56]
        jmp rax              ; to B
      '|
      width: 280
      style.fill: "#1976D2"
      style.font-color: white
    }
    step1 -> step2
    step2 -> step3
    step3 -> step4
  }

  spacer2: {
    label: ""
    width: 60
    style.stroke: transparent
    style.fill: transparent
  }

  coro_b: {
    direction: down
    label: "Coroutine B (Resuming) (coro.c)"
    style.fill: "#E8F5E9"
    state_b_suspended: {
      label: "Suspended"
      shape: circle
      style.fill: "#FFCDD2"
    }
    state_b_loading: {
      label: "Loading Context"
      shape: rectangle
      style.fill: "#FFF9C4"
    }
    state_b_running: {
      label: "Running"
      shape: circle
      style.fill: "#4CAF50"
      style.font-color: white
    }
    state_b_suspended -> state_b_loading: "dispatch"
    state_b_loading -> state_b_running: "loaded"
  }
}

# --- ROW 2: DATA STRUCTURES & MEMORY ---
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  context_struct: {
    direction: down
    label: "Memory Definitions"
    ctx_table: {
      shape: sql_table
      label: "struct Context (context.h)"
      f0: "0x00 | uint64_t | rbx"
      f1: "0x08 | uint64_t | rbp"
      f2: "0x10 | uint64_t | r12"
      f3: "0x18 | uint64_t | r13"
      f4: "0x20 | uint64_t | r14"
      f5: "0x28 | uint64_t | r15"
      f6: "0x30 | void*    | rsp"
      f7: "0x38 | void*    | rip"
      sz: "Total: 64 bytes (1 cache line)"
    }
  }

  spacer3: {
    label: ""
    width: 60
    style.stroke: transparent
    style.fill: transparent
  }

  memory_trace: {
    direction: down
    label: "Execution Trace"
    style.fill: "#FFF8E1"
    
    m1: {
      label: "Phase: Save A"
      content: |'md
        **Stack A**
        0x7FFF000: [RET ADDR]
        0x7FFEFF8: [SAVED RBP]
      '|
      style.fill: "#C8E6C9"
    }
    m2: {
      label: "Phase: Contexts"
      content: |'md
        **Ctx A (Heap)**
        rbx=0x100, rsp=0x7FFF000
        **Ctx B (Heap)**
        rbx=0x200, rsp=0x7FFE000
      '|
      style.fill: "#FFF9C4"
    }
    m3: {
      label: "Phase: Resume B"
      content: |'md
        **Stack B**
        0x7FFE000: [RET ADDR]
        0x7FFDFF8: [B LOCALS]
      '|
      style.fill: "#BBDEFB"
    }
    m1 -> m2: "save"
    m2 -> m3: "restore"
  }

  spacer4: {
    label: ""
    width: 60
    style.stroke: transparent
    style.fill: transparent
  }

  analysis: {
    direction: down
    label: "Timing Analysis"
    timing_table: {
      shape: sql_table
      label: "Cycles (x86-64)"
      op1: "mov r/m, r | 4 | L1 Save"
      op2: "mov r, r/m | 4 | L1 Load"
      op3: "6 GPR Save | 24 | Callee"
      op4: "6 GPR Load | 24 | Callee"
      op5: "Indirect JMP| 2 | Branch"
      total: "Total | 54-80 | ~20-40ns"
    }
    note: {
      label: |'md
        **Insight:** 30x faster than
        OS thread context switch.
      '|
      shape: callout
      style.fill: "#FFCDD2"
    }
  }
}

# --- CONNECTIONS ---
row1.coro_a.state_saving -> row1.context_switch.step1: "RDI: &CtxA" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
row1.context_switch.step4 -> row1.coro_b.state_b_loading: "RSI: &CtxB" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
row1 -> row2: "ABI Compliance"

# --- LEGEND ---
legend: {
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  l1: "Running" {
    shape: circle
    style.fill: "#4CAF50"
  }
  l2: "Saving/Loading" {
    shape: rectangle
    style.fill: "#FFF9C4"
  }
  l3: "Suspended" {
    shape: circle
    style.fill: "#FFCDD2"
  }
  l4: "Assembly Code" {
    shape: rectangle
    style.fill: "#64B5F6"
  }
}

legend.near: bottom-right