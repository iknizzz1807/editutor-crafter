direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Coroutine Control Block (CCB)
    Memory Layout — 136 bytes total
  |
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  ccb: {
    label: "struct Coroutine (coroutine.rs)"
    shape: sql_table
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
    }
    f0: "0x00 | u64            | id"
    f1: "0x08 | CoroutineState | state"
    f2: "0x10 | Context        | context"
    f3: "0x10 | [usize; 6]     | context.regs"
    f4: "0x40 | *mut u8        | context.rsp"
    f5: "0x48 | *const u8      | context.rip"
    f6: "0x50 | Stack          | stack"
    f7: "0x50 | *mut u8        | stack.ptr"
    f8: "0x58 | usize          | stack.size"
    f9: "0x60 | Layout         | stack.layout"
    f10: "0x70 | Option(Box(dyn Fn)) | entry"
    sz_total: "Total: 136 bytes (stack excl.)"
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  context_detail: {
    label: "Context (coroutine.rs:22)"
    shape: sql_table
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
    reg0: "0x00 | usize | regs[0] = rbx"
    reg1: "0x08 | usize | regs[1] = rbp"
    reg2: "0x10 | usize | regs[2] = r12"
    reg3: "0x18 | usize | regs[3] = r13"
    reg4: "0x20 | usize | regs[4] = r14"
    reg5: "0x28 | usize | regs[5] = r15"
    sp: "0x30 | *mut u8 | rsp (stack ptr)"
    ip: "0x38 | *const u8 | rip (resume addr)"
    ctx_total: "Total: 64 bytes (1 cache line)"
  }
  state_enum: {
    label: "CoroutineState (coroutine.rs:14)"
    shape: sql_table
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
    s0: "0x00 | Runnable  | Ready to run"
    s1: "0x01 | Running   | Currently executing"
    s2: "0x02 | Finished  | Entry returned"
    s3: "0x03 | Panicked  | Unwind caught"
    enum_total: "Size: 1 byte (discriminant)"
  }
}

row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  stack_detail: {
    label: "Stack (coroutine.rs:46)"
    shape: sql_table
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
    }
    f_ptr: "0x00 | *mut u8  | ptr (base addr)"
    f_sz: "0x08 | usize    | size (64KB default)"
    f_lay: "0x10 | Layout   | layout (align=4096)"
    stk_total: "Total: 32 bytes"
  }
  memory_view: {
    label: "Stack Memory View"
    shape: sql_table
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
    }
    f_guard: "0x0000 | [GUARD PAGE] | PROT_NONE"
    f_base: "0x1000 | stack.ptr    | stack base"
    f_grow: "...    | (grows down) | "
    # FIXED: 'top' is a reserved layout keyword; using 'f_top' instead
    f_top: "0xFFFF | stack.top()  | rsp init here"
    mem_note: "64KB + 4KB guard = 68KB total"
  }
}

row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  rust_def: {
    label: "Rust Definition (coroutine.rs)"
    width: 420
    code: |'rust
pub struct Coroutine {
    pub id: u64,                      // 0x00
    pub state: CoroutineState,        // 0x08
    context: Context,                 // 0x10
    stack: Stack,                     // 0x50
    entry: Option<Box<dyn FnOnce(&mut Coroutine) + Send>>,
}                                     // 0x70+
#[repr(C)]
pub struct Context {
    regs: [usize; 6],  // rbx,rbp,r12-r15
    rsp: *mut u8,      // stack pointer
    rip: *const u8,    // instruction pointer
}
    '|
  }
}

row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  cache_analysis: {
    label: "Cache Line Analysis"
    shape: rectangle
    width: 380
    style: {
      fill: "#FFFDE7"
      stroke: "#FFC107"
    }
    analysis: |md
      **Hot Path (every switch):**
      - `id` (8B), `state` (1B), `context` (64B)
      - Fits in **1 cache line** (73 bytes)
      
      **Cold Path (setup/teardown):**
      - `stack` (24B), `entry` (16B)
      - Accessed once per coroutine lifetime
      
      **Alignment:** `#[repr(C)]` ensures
      predictable layout for assembly
    |
  }
  abi_note: {
    label: "ABI Compliance Note"
    shape: rectangle
    width: 380
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
    }
    note: |md
      **x86-64 System V ABI:**
      Callee-saved registers (must preserve):
      `rbx`, `rbp`, `r12`, `r13`, `r14`, `r15`
      Context switch saves these to `regs[0..6]`
      before switching to scheduler.
      
      Caller-saved (`rax`,`rcx`,`rdx`,`rsi`,`rdi`,
      `r8`-`r11`) are assumed garbage across yield.
    |
  }
}

legend: {
  near: bottom-right
  label: "Field Colors"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
  }
  ccb_color: "CCB header — blue"
  ctx_color: "Context — orange"
  state_color: "State enum — green"
  stack_color: "Stack — purple"
  mem_color: "Memory — red"
}