direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Stack Growth Strategies
    Three approaches to coroutine stack management
  |
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  fixed: {
    direction: down
    label: "Strategy 1: Fixed-Size"
    fixed_initial: {
      label: "Initial Stack"
      width: 200
      height: 120
      header: {
        shape: rectangle
        label: "Stack Memory"
        style: {
          fill: "#E8F5E9"
          stroke: "#4CAF50"
          stroke-width: 2
        }
      }
      spacer: {
        label: ""
        height: 10
      }
      usage: {
        shape: rectangle
        label: "64 KB allocated"
        style: {
          fill: "#C8E6C9"
          stroke: "#4CAF50"
        }
      }
      spacer2: {
        label: ""
        height: 10
      }
      guard: {
        shape: rectangle
        label: "Guard Page\n(PROT_NONE)"
        style: {
          fill: "#FFCDD2"
          stroke: "#F44336"
          stroke-dash: 3
        }
      }
    }
    fixed_arrow: {
      label: "Recursion exceeds 64KB"
      shape: text
    }
    fixed_overflow: {
      label: "Stack Overflow!"
      width: 200
      height: 120
      overflow_header: {
        shape: rectangle
        label: "Stack Memory"
        style: {
          fill: "#E8F5E9"
          stroke: "#4CAF50"
          stroke-width: 2
        }
      }
      spacer3: {
        label: ""
        height: 10
      }
      overflow_usage: {
        shape: rectangle
        label: "64 KB allocated\n(full)"
        style: {
          fill: "#C8E6C9"
          stroke: "#4CAF50"
        }
      }
      spacer4: {
        label: ""
        height: 10
      }
      overflow_guard: {
        shape: rectangle
        label: "WRITE → SIGSEGV!"
        style: {
          fill: "#F44336"
          stroke: "#B71C1C"
          font-color: white
          bold: true
        }
      }
    }
  }
  spacer_col: {
    width: 80
    label: ""
  }
  segmented: {
    direction: down
    label: "Strategy 2: Segmented"
    seg_initial: {
      label: "Initial (Chunk 1)"
      width: 200
      height: 100
      seg1_header: {
        shape: rectangle
        label: "Chunk 1 (4 KB)"
        style: {
          fill: "#E3F2FD"
          stroke: "#2196F3"
          stroke-width: 2
        }
      }
      spacer5: {
        label: ""
        height: 8
      }
      seg1_content: {
        shape: rectangle
        label: "frame data\nlocal vars"
        style: {
          fill: "#BBDEFB"
          stroke: "#2196F3"
        }
      }
    }
    seg_arrow: {
      label: "Need more space?"
      shape: text
    }
    seg_grown: {
      label: "Grown (3 Chunks)"
      width: 200
      height: 160
      seg2_header: {
        shape: rectangle
        label: "Chunk 3 (new)"
        style: {
          fill: "#E3F2FD"
          stroke: "#2196F3"
          stroke-width: 2
        }
      }
      spacer6: {
        label: ""
        height: 5
      }
      seg2_ptr: {
        shape: rectangle
        label: "prev → Chunk 2"
        style: {
          fill: "#BBDEFB"
          stroke: "#2196F3"
        }
      }
      spacer7: {
        label: ""
        height: 5
      }
      seg2_content: {
        shape: rectangle
        label: "more frames"
        style: {
          fill: "#BBDEFB"
          stroke: "#2196F3"
        }
      }
    }
    seg_note: {
      label: |md
        **Linked list of chunks**
        - Complex pointer chasing
        - Fragmentation overhead
        - Cache-unfriendly
        - Go 1.3 used this
      |
      shape: text
      style: {
        font-color: "#1565C0"
      }
    }
  }
  spacer_col2: {
    width: 80
    label: ""
  }
  contiguous: {
    direction: down
    label: "Strategy 3: Contiguous (Go 1.4+)"
    cont_initial: {
      label: "Initial (2 KB)"
      width: 200
      height: 100
      cont1_header: {
        shape: rectangle
        label: "Stack Memory"
        style: {
          fill: "#FFF3E0"
          stroke: "#FF9800"
          stroke-width: 2
        }
      }
      spacer8: {
        label: ""
        height: 8
      }
      cont1_content: {
        shape: rectangle
        label: "2 KB allocated\n8 KB reserved"
        style: {
          fill: "#FFE0B2"
          stroke: "#FF9800"
        }
      }
    }
    cont_arrow: {
      label: "mremap grows in-place"
      shape: text
    }
    cont_grown: {
      label: "Grown (8 KB → 32 KB)"
      width: 200
      height: 140
      cont2_header: {
        shape: rectangle
        label: "Stack Memory"
        style: {
          fill: "#FFF3E0"
          stroke: "#FF9800"
          stroke-width: 2
        }
      }
      spacer9: {
        label: ""
        height: 5
      }
      cont2_content: {
        shape: rectangle
        label: "8 KB used"
        style: {
          fill: "#FFE0B2"
          stroke: "#FF9800"
        }
      }
      spacer10: {
        label: ""
        height: 5
      }
      cont2_extra: {
        shape: rectangle
        label: "24 KB available"
        style: {
          fill: "#FFF8E1"
          stroke: "#FF9800"
          stroke-dash: 2
        }
      }
    }
    cont_note: {
      label: |md
        **Single contiguous block**
        - mremap() to grow
        - Copy stack on growth
        - Adjust pointers in frames
        - Go 1.4+ approach
      |
      shape: text
      style: {
        font-color: "#E65100"
      }
    }
  }
}
comparison: {
  label: "Trade-off Summary"
  comparison_table: {
    shape: sql_table
    label: "Stack Strategy Comparison"
    strategy: "Strategy"
    memory: "Memory Efficiency"
    complexity: "Implementation"
    cache: "Cache Behavior"
    risk: "Key Risk"
    fixed_val: "Fixed-Size | Wasteful (64KB each) | Simple | Good | Overflow crashes"
    seg_val: "Segmented | Efficient | Complex | Poor (pointer chase) | Fragmentation"
    cont_val: "Contiguous | Efficient | Moderate | Excellent | Relocation cost"
  }
}
verdict: {
  label: |md
    ### Why Go Switched (1.3 → 1.4)
    **Segmented stacks** caused "hot split" problem: frequently-called functions
    that barely exceeded chunk size caused constant allocation/deallocation.
    **Contiguous stacks** with `mremap` grow once, shrink later, and maintain
    cache locality. The cost of copying during growth is amortized.
    **Your choice**: Fixed-size (64 KB) is simplest for learning.
    Contiguous is production-ready but requires OS support.
  |
  shape: text
  style: {
    fill: "#F5F5F5"
    border-radius: 8
  }
}
legend: {
  near: bottom-right
  leg1: "Used Space" {
    shape: rectangle
    style: {
      fill: "#BBDEFB"
      stroke: "#2196F3"
    }
  }
  leg2: "Available/Reserved" {
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF9800"
      stroke-dash: 2
    }
  }
  leg3: "Guard/Error" {
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
  }
}
# Connections
fixed_initial -> fixed_overflow: "overflow!" {
  style: {
    stroke: "#F44336"
    stroke-dash: 4
    bold: true
  }
}
seg_initial -> seg_grown: "allocate chunk" {
  style: {
    stroke: "#2196F3"
  }
}
cont_initial -> cont_grown: "mremap()" {
  style: {
    stroke: "#FF9800"
  }
}
comparison -> verdict: "conclusion" {
  style: {
    stroke-dash: 3
  }
}