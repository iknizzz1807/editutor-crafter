direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Coroutine Yield/Resume Sequence
    Tracing control flow and return values through the yield/resume cycle
  |
  near: top-center
  shape: text
  style: {
    font-size: 28
    underline: true
  }
}
# Define the actors in the sequence
actors: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  main_actor: {
    shape: rectangle
    label: "main\n(Caller)"
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      font: mono
    }
  }
  coroutine_actor: {
    shape: rectangle
    label: "Coroutine\n(Worker)"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      font: mono
    }
  }
  scheduler_actor: {
    shape: rectangle
    label: "Scheduler\nContext"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      font: mono
    }
  }
}
# Step 1: Coroutine Creation
step1_create: {
  label: "Step 1: Spawn Coroutine"
  style.fill: "#E8F5E9"
  create_code: {
    label: "main.rs"
    width: 380
    code: |'rust
      let coroutine = Coroutine::spawn(|| {
          let x = compute();
          yield_now();        // <- Will yield here
          let y = x + 1;
          y                   // Return value
      });
    '|
  }
  create_note: {
    label: |md
      - Allocates 64KB stack
      - Initializes Context with entry point
      - State = Runnable (not yet running)
    |
    style.fill: "#C8E6C9"
  }
}
# Step 2: First Resume
step2_resume1: {
  label: "Step 2: First Resume"
  style.fill: "#E3F2FD"
  resume1_code: {
    label: "Scheduler"
    width: 380
    code: |'rust
      // Scheduler selects coroutine
      scheduler_context.switch_to(&mut coroutine.context);
      // ^ Returns when coroutine yields
    '|
  }
  flow1: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    main_side1: {
      label: "Main Thread"
      style.fill: "#BBDEFB"
      state1: "Running scheduler"
      switch1: "context_switch() called"
      wait1: "CPU jumps to coroutine"
    }
    arrow1: {
      label: "RIP/RSP change"
      style: {
        stroke: "#1976D2"
        stroke-width: 3
        animated: true
      }
    }
    coro_side1: {
      label: "Coroutine"
      style.fill: "#FFE0B2"
      entry1: "Entry point begins"
      compute1: "x = compute()"
      yield1: "yield_now() called"
    }
  }
}
# Step 3: First Yield
step3_yield1: {
  label: "Step 3: Coroutine Yields"
  style.fill: "#FFF8E1"
  yield1_code: {
    label: "Inside Coroutine"
    width: 380
    code: |'rust
      // yield_now() implementation
      let scheduler_ctx = get_scheduler_context();
      current_coroutine.state = Runnable;
      current_coroutine.context.switch_to(scheduler_ctx);
      // ^ Control returns to scheduler
    '|
  }
  state_box1: {
    shape: sql_table
    label: "Coroutine State After Yield"
    f1: "state     | Runnable"
    f2: "context   | Saved RIP at resume point"
    f3: "stack     | Preserved (x still valid)"
  }
}
# Step 4: Control Returns to Scheduler
step4_return1: {
  label: "Step 4: Scheduler Resumes Control"
  style.fill: "#E8F5E9"
  return1_code: {
    label: "Scheduler Loop"
    width: 380
    code: |'rust
      // context_switch "returns" here
      // (actually coroutine yielded back)
      match coroutine.state {
          Runnable => local_queue.push(coroutine),
          Finished => handle_result(),
          // ...
      }
      // Pick next coroutine to run...
    '|
  }
  timeline1: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    t1: "t=0ms" {shape: circle; style.fill: "#4CAF50"}
    t2: "t=5ms" {shape: circle; style.fill: "#4CAF50"}
    t3: "t=10ms" {shape: circle; style.fill: "#FF9800"}
    t1_note: "Resume" {shape: text; style.font-size: 12}
    t2_note: "Yield" {shape: text; style.font-size: 12}
    t3_note: "Re-resume" {shape: text; style.font-size: 12}
    t1 -> t2: "compute()" {style.stroke: "#666"}
    t2 -> t3: "other work" {style.stroke-dash: 3}
  }
}
# Step 5: Second Resume
step5_resume2: {
  label: "Step 5: Second Resume (Resume After Yield)"
  style.fill: "#E3F2FD"
  resume2_code: {
    label: "Scheduler"
    width: 380
    code: |'rust
      // Later: coroutine is picked from queue
      scheduler_context.switch_to(&mut coroutine.context);
      // ^ Returns when coroutine finishes
    '|
  }
  flow2: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    restore_box: {
      label: "Context Restoration"
      style.fill: "#C8E6C9"
      restore_code: |'asm
        ; Assembly in context_switch
        mov rbx, [rsi + 0]    ; Restore rbx
        mov rbp, [rsi + 8]    ; Restore rbp
        mov rsp, [rsi + 48]   ; Restore stack ptr
        mov rax, [rsi + 56]   ; Get resume RIP
        jmp rax               ; Jump to yield point
      '|
    }
    arrow2: {
      label: "Registers restored"
      style: {
        stroke: "#388E3C"
        stroke-width: 3
      }
    }
    continue_box: {
      label: "Coroutine Continues"
      style.fill: "#FFE0B2"
      cont_code: |'rust
        // Execution resumes HERE
        // x is still in register or on stack
        let y = x + 1;
        y   // Return this value
      '|
    }
  }
}
# Step 6: Coroutine Completes
step6_complete: {
  label: "Step 6: Coroutine Finishes"
  style.fill: "#FCE4EC"
  complete_code: {
    label: "Coroutine Exit"
    width: 380
    code: |'rust
      // Entry function returns
      // coroutine_exit trampoline runs:
      extern "C" fn coroutine_exit(coroutine: *mut Coroutine) {
          (*coroutine).state = Finished;
          // Yield to scheduler (never returns)
          yield_to_scheduler();
      }
    '|
  }
  final_state: {
    shape: sql_table
    label: "Final Coroutine State"
    s1: "state     | Finished"
    s2: "result    | Some(y) stored"
    s3: "stack     | Will be freed on Drop"
  }
}
# Step 7: Return Value Extraction
step7_result: {
  label: "Step 7: Result Retrieved"
  style.fill: "#E8F5E9"
  result_code: {
    label: "main.rs"
    width: 380
    code: |'rust
      // Scheduler detects Finished state
      if coroutine.state == Finished {
          let result = coroutine.take_result();
          // result = Some(value_returned)
      }
    '|
  }
}
# Arrows connecting steps
step1_create -> step2_resume1: "spawn() returns\nCoroutine handle" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
step2_resume1 -> step3_yield1: "executes" {
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}
step3_yield1 -> step4_return1: "yield_now()" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    stroke-dash: 4
  }
}
step4_return1 -> step5_resume2: "scheduler picks\nfrom queue" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    stroke-dash: 3
  }
}
step5_resume2 -> step6_complete: "resumes at\nyield point" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
step6_complete -> step7_result: "state=Finished" {
  style: {
    stroke: "#C2185B"
    stroke-width: 2
  }
}
# Legend
legend: {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  title: "Legend" {
    shape: text
    style: {
      bold: true
      underline: true
    }
  }
  l1: "Runnable → Running → Runnable → Finished" {
    shape: text
    style.font: mono
  }
  l2: "Yield preserves: registers, stack, locals" {
    shape: text
    style.font: mono
  }
  l3: "Context switch: ~20-50ns" {
    shape: text
    style.font: mono
  }
  solid_arrow: "Control flow" {shape: text}
  dashed_arrow: "Async/yield boundary" {shape: text; style.stroke-dash: 3}
}