direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL HEADER ---
title: {
  label: "Global Queue Bottleneck Analysis: Thread Serialization vs. Work Stealing"
  near: top-center
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#F0F8FF"
    stroke: "#4169E1"
    stroke-width: 2
  }
}

# --- COMPARISON ROW ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  naive: {
    direction: down
    label: "Naive Architecture: Centralized Global Queue"
    style: {
      stroke: "#DC143C"
      stroke-dash: 2
      fill: "#FFF5F5"
    }

    global_queue: {
      shape: queue
      label: "Global Shared Queue\n(Mutex<VecDeque>)"
      width: 220
      style.fill: "#FFE4E1"
      style.stroke: "#DC143C"
      style.stroke-width: 3
    }

    lock_indicator: {
      label: "🔒 SERIALIZATION POINT"
      shape: diamond
      style.fill: "#FF6B6B"
      style.stroke: "#DC143C"
      style.font-color: white
    }

    workers_naive: {
      direction: right
      label: "Worker Threads (OS-Managed)"
      style.fill: transparent
      style.stroke: transparent
      w1: "T1" { shape: circle; style.fill: "#87CEEB" }
      w2: "T2" { shape: circle; style.fill: "#87CEEB" }
      w3: "T3" { shape: circle; style.fill: "#87CEEB" }
      w4: "T4" { shape: circle; style.fill: "#87CEEB" }
    }

    lock_indicator -> global_queue: "serialized\naccess" {
      style.stroke: "#DC143C"
      style.stroke-width: 3
      style.stroke-dash: 4
    }

    workers_naive.w1 -> lock_indicator: "contend"
    workers_naive.w2 -> lock_indicator: "contend"
    workers_naive.w3 -> lock_indicator: "contend"
    workers_naive.w4 -> lock_indicator: "contend"
  }

  transition: {
    label: "RE-ARCHITECT\nFOR SCALE"
    shape: parallelogram
    style: {
      fill: "#E8F5E9"
      stroke: "#228B22"
      bold: true
    }
  }

  optimized: {
    direction: down
    label: "Optimized Architecture: Distributed Work-Stealing"
    style: {
      stroke: "#228B22"
      stroke-dash: 2
      fill: "#F1F8F1"
    }

    local_queues: {
      direction: right
      label: "Per-Thread Local Queues (Lock-Free)"
      style.fill: transparent
      style.stroke: transparent
      lq1: "LQ1" { shape: queue; style.fill: "#90EE90"; style.stroke: "#228B22" }
      lq2: "LQ2" { shape: queue; style.fill: "#90EE90"; style.stroke: "#228B22" }
      lq3: "LQ3" { shape: queue; style.fill: "#90EE90"; style.stroke: "#228B22" }
      lq4: "LQ4" { shape: queue; style.fill: "#90EE90"; style.stroke: "#228B22" }
    }

    workers_opt: {
      direction: right
      label: "Worker Threads"
      style.fill: transparent
      style.stroke: transparent
      wo1: "T1" { shape: circle; style.fill: "#90EE90" }
      wo2: "T2" { shape: circle; style.fill: "#90EE90" }
      wo3: "T3" { shape: circle; style.fill: "#90EE90" }
      wo4: "T4" { shape: circle; style.fill: "#90EE90" }
    }

    global_opt: {
      label: "Global Overflow\n(Shared Shared)"
      shape: queue
      width: 120
      style.fill: "#FFFACD"
      style.stroke: "#DAA520"
      style.stroke-dash: 3
    }

    wo1 -> lq1: "local pop" { style.stroke: "#228B22" }
    wo2 -> lq2: "local pop" { style.stroke: "#228B22" }
    wo3 -> lq3: "local pop" { style.stroke: "#228B22" }
    wo4 -> lq4: "local pop" { style.stroke: "#228B22" }

    lq1 <-> lq2: "STEAL" { style.stroke: "#4169E1"; style.stroke-dash: 3; style.animated: true }
    lq3 <-> lq4: "STEAL" { style.stroke: "#4169E1"; style.stroke-dash: 3; style.animated: true }
  }
}

# --- TIMELINE ROW ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  contention_timeline: {
    direction: down
    label: "OS Scheduler & Mutex Contention Timeline"
    
    t_naive: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      p1: {
        label: "Step 1"
        shape: rectangle
        width: 100; height: 140
        style.fill: "#FF6B6B"; style.stroke: "#DC143C"
        note: |md
          **T1 Accessing**
          T2: Blocked
          T3: Blocked
          T4: Blocked
        |
      }
      p2: {
        label: "Step 2"
        shape: rectangle
        width: 100; height: 140
        style.fill: "#FF6B6B"; style.stroke: "#DC143C"
        note: |md
          **T2 Accessing**
          T1: Context Switch
          T3: Blocked
          T4: Blocked
        |
      }
    }
    
    warning: {
      label: "CPU UTILIZATION: 25%"
      shape: callout
      style.fill: "#FFBABA"; style.font-color: "#D8000C"
    }
  }

  parallel_timeline: {
    direction: down
    label: "Lock-Free Parallelism Timeline"
    
    t_opt: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      p1: {
        label: "Step 1"
        shape: rectangle
        width: 100; height: 140
        style.fill: "#90EE90"; style.stroke: "#228B22"
        note: |md
          **T1: Pop LQ1**
          **T2: Pop LQ2**
          **T3: Pop LQ3**
          **T4: Pop LQ4**
        |
      }
      p2: {
        label: "Step 2"
        shape: rectangle
        width: 100; height: 140
        style.fill: "#90EE90"; style.stroke: "#228B22"
        note: |md
          **T1: Pop LQ1**
          **T2: Steal LQ1**
          **T3: Pop LQ3**
          **T4: Pop LQ4**
        |
      }
    }
    
    success: {
      label: "CPU UTILIZATION: 98%"
      shape: callout
      style.fill: "#DFF2BF"; style.font-color: "#4F8A10"
    }
  }
}

# --- METRICS & CACHE ROW ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  metrics_analysis: {
    direction: down
    label: "Benchmark: 8 Cores | 100K Tasks"
    
    stats: {
      shape: sql_table
      label: "Latency & Throughput Profile"
      c1: "Metric | Naive (Global) | Optimized (Stealing)"
      r1: "Avg Mutex Wait | 1250ns | < 1ns (Lock-Free)"
      r2: "Cache Line Bounces | High (L3 Shared) | Low (L1 Local)"
      r3: "Max Throughput | 4.2M ops/sec | 38.5M ops/sec"
      r4: "Context Switches | 15,200/sec | 420/sec"
      total: "Speedup: ~9.2x performance gain"
    }
  }

  cache_theory: {
    direction: down
    label: "CPU Cache Invalidation Analysis"
    
    theory: {
      label: "MESI Protocol Overhead"
      width: 400
      code: |'c
        // GLOBAL QUEUE: CACHE SLOSHING
        // Thread 1 pops -> Invalidates Cache Line on Threads 2-8
        // Result: Stall on every memory access.

        // LOCAL QUEUE: L1 AFFINITY
        // Thread 1 reads LQ1 -> L1 Cache Hit (Fast)
        // Thread 2 steals from LQ1 -> Atomic CAS (Rare)
        // Result: Execution at hardware memory speed.
      '|
    }
  }
}

# --- FOOTER INSIGHT ---
key_insight: {
  label: |md
    ### CORE ARCHITECTURAL PRINCIPLE
    Centralized resources create a bottleneck that scales **O(N)** with thread count.
    Distributed local resources with **Work Stealing** provide **O(1)** scalability.
    In the Coroutine Engine, this is the difference between linear performance scaling and thread starvation.
  |
  shape: rectangle
  width: 900
  style: {
    fill: "#FFFFE0"
    stroke: "#DAA520"
    stroke-width: 2
  }
}

key_insight.near: bottom-center

# --- CONNECTIONS ---
row1.naive -> row1.optimized: "remove serialization"
row2.contention_timeline -> row2.parallel_timeline: "enable concurrency"