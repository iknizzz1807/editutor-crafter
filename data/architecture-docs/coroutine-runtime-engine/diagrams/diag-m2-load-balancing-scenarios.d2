direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Work-Stealing: Load Balancing Under Skewed Workloads"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

classes: {
  thread_box: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 8
    }
  }
  hot_thread: {
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 3
      border-radius: 8
    }
  }
  idle_thread: {
    style: {
      fill: "#F3F4F6"
      stroke: "#9CA3AF"
      stroke-width: 2
      stroke-dash: 4
      border-radius: 8
    }
  }
  coroutine: {
    shape: circle
    width: 28
    height: 28
    style: {
      fill: "#3B82F6"
      stroke: "#1E40AF"
      font-color: white
      font-size: 11
    }
  }
  steal_arrow: {
    style: {
      stroke: "#F59E0B"
      stroke-width: 3
      animated: true
    }
  }
  work_arrow: {
    style: {
      stroke: "#10B981"
      stroke-width: 2
    }
  }
}

row1: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  scenario1: {
    direction: down
    label: "Scenario 1: Hot Spot"
    
    s1_before: {
      label: "Initial State"
      direction: right
      s1_t1_hot: {
        class: hot_thread
        label: "Thread 0"
        direction: down
        s1_c1: { class: coroutine; label: "T1" }
        s1_c2: { class: coroutine; label: "T2" }
        s1_c3: { class: coroutine; label: "T3" }
        s1_c4: { class: coroutine; label: "T4" }
        s1_c5: { class: coroutine; label: "T5" }
        s1_c6: { class: coroutine; label: "T6" }
      }
      s1_t2_idle: {
        class: idle_thread
        label: "Thread 1"
        s1_empty1: {
          label: "(empty)"
          shape: text
          style: { font-color: "#9CA3AF"; italic: true }
        }
      }
      s1_t3_idle: {
        class: idle_thread
        label: "Thread 2"
        s1_empty2: {
          label: "(empty)"
          shape: text
          style: { font-color: "#9CA3AF"; italic: true }
        }
      }
    }
    
    s1_steal: {
      label: "Stealing Phase"
      direction: right
      s1_t1_mid: {
        class: hot_thread
        label: "Thread 0"
        direction: down
        s1_c1m: { class: coroutine; label: "T1" }
        s1_c2m: { class: coroutine; label: "T2" }
      }
      s1_t2_mid: {
        class: thread_box
        label: "Thread 1"
        direction: down
        s1_c3m: { class: coroutine; label: "T3" }
        s1_c4m: { class: coroutine; label: "T4" }
      }
      s1_t3_mid: {
        class: thread_box
        label: "Thread 2"
        direction: down
        s1_c5m: { class: coroutine; label: "T5" }
        s1_c6m: { class: coroutine; label: "T6" }
      }
    }
    
    s1_t1_mid -> s1_t2_mid: "steal 2" { class: steal_arrow }
    s1_t1_mid -> s1_t3_mid: "steal 2" { class: steal_arrow }
    
    s1_result: {
      label: "Result"
      shape: rectangle
      style: {
        fill: "#ECFDF5"
        stroke: "#10B981"
        font-color: "#065F46"
      }
      result_text: |md
        ✓ Load balanced in O(log P) steal rounds
        ✓ Idle threads self-activate
        ✓ No central coordinator needed
      |
    }
  }
}

row2: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  scenario2: {
    direction: down
    label: "Scenario 2: Fork-Join Pattern"
    
    s2_fork: {
      label: "Fork: Work Spreads"
      direction: right
      s2_root: {
        class: hot_thread
        label: "Thread 0 (main)"
        s2_root_task: {
          label: "Root Task"
          shape: hexagon
          style: { fill: "#8B5CF6"; font-color: white }
        }
      }
      s2_fork_arrow: {
        label: "fork"
        shape: text
      }
      s2_spread: {
        direction: right
        s2_t1_fork: {
          class: thread_box
          label: "T0"
          s2_f1: { class: coroutine; label: "F1" }
          s2_f2: { class: coroutine; label: "F2" }
        }
        s2_t2_fork: {
          class: thread_box
          label: "T1"
          s2_f3: { class: coroutine; label: "F3" }
          s2_f4: { class: coroutine; label: "F4" }
        }
        s2_t3_fork: {
          class: thread_box
          label: "T2"
          s2_f5: { class: coroutine; label: "F5" }
          s2_f6: { class: coroutine; label: "F6" }
        }
        s2_t4_fork: {
          class: thread_box
          label: "T3"
          s2_f7: { class: coroutine; label: "F7" }
          s2_f8: { class: coroutine; label: "F8" }
        }
      }
    }
    
    s2_root -> s2_fork_arrow: "spawns" { class: work_arrow }
    s2_fork_arrow -> s2_spread: "distributes" { class: work_arrow }
    
    s2_join: {
      label: "Join: Work Converges"
      direction: right
      s2_j1: {
        class: thread_box
        label: "T0"
        direction: down
        s2_jc1: { class: coroutine; label: "✓" }
        s2_jc2: { class: coroutine; label: "✓" }
        s2_waiting: {
          label: "waiting..."
          shape: text
          style: { font-color: "#F59E0B" }
        }
      }
      s2_j2: {
        class: thread_box
        label: "T1"
        direction: down
        s2_jc3: { class: coroutine; label: "✓" }
        s2_jc4: { class: coroutine; label: "..." }
      }
      s2_j3: {
        class: idle_thread
        label: "T2"
        s2_jempty: { label: "done"; shape: text }
      }
      s2_j4: {
        class: idle_thread
        label: "T3"
        s2_jempty2: { label: "done"; shape: text }
      }
    }
    
    s2_j3 -> s2_j2: "steal" { class: steal_arrow }
    s2_j4 -> s2_j2: "steal" { class: steal_arrow }
    
    s2_result: {
      label: "Result"
      shape: rectangle
      style: {
        fill: "#ECFDF5"
        stroke: "#10B981"
        font-color: "#065F46"
      }
      s2_res: |md
        ✓ Theoretical bound: O(T₁/P + T∞)
        ✓ Critical path (T∞) limits parallelism
        ✓ Idle threads help finish stragglers
      |
    }
  }
}

row3: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  scenario3: {
    direction: down
    label: "Scenario 3: Producer-Consumer"
    
    s3_flow: {
      label: "Unidirectional Flow"
      direction: right
      s3_producers: {
        label: "Producer Threads"
        direction: down
        style: { fill: "#DBEAFE"; stroke: "#3B82F6"; border-radius: 8 }
        s3_p1: {
          label: "Producer 0"
          direction: right
          s3_p1_c1: { class: coroutine; label: "P1" }
          s3_p1_c2: { class: coroutine; label: "P2" }
        }
        s3_p2: {
          label: "Producer 1"
          direction: right
          s3_p2_c1: { class: coroutine; label: "P3" }
          s3_p2_c2: { class: coroutine; label: "P4" }
        }
      }
      s3_channel: {
        label: "Channel"
        shape: queue
        style: { fill: "#FEF3C7"; stroke: "#F59E0B"; stroke-width: 2 }
        width: 120
      }
      s3_consumers: {
        label: "Consumer Threads"
        direction: down
        style: { fill: "#D1FAE5"; stroke: "#10B981"; border-radius: 8 }
        s3_c1: {
          label: "Consumer 0"
          s3_c1_empty: {
            label: "(waiting)"
            shape: text
            style: { font-color: "#9CA3AF"; italic: true }
          }
        }
        s3_c2: {
          label: "Consumer 1"
          s3_c2_empty: {
            label: "(waiting)"
            shape: text
            style: { font-color: "#9CA3AF"; italic: true }
          }
        }
      }
    }
    
    s3_producers -> s3_channel: "send" { class: work_arrow }
    s3_channel -> s3_consumers: "recv" { class: work_arrow }
    
    s3_balanced: {
      label: "After Stealing"
      direction: right
      s3_bp: {
        label: "Producers"
        direction: down
        style: { fill: "#DBEAFE"; stroke: "#3B82F6"; border-radius: 8 }
        s3_bp1: {
          label: "P0"
          s3_bp1e: { label: "done"; shape: text; style: { font-color: "#10B981" } }
        }
        s3_bp2: {
          label: "P1"
          s3_bp2e: { label: "done"; shape: text; style: { font-color: "#10B981" } }
        }
      }
      s3_bc: {
        label: "Consumers (now busy)"
        direction: down
        style: { fill: "#D1FAE5"; stroke: "#10B981"; border-radius: 8 }
        s3_bc1: {
          label: "C0"
          direction: right
          s3_bc1_t1: { class: coroutine; label: "P1" }
          s3_bc1_t2: { class: coroutine; label: "P2" }
        }
        s3_bc2: {
          label: "C1"
          direction: right
          s3_bc2_t1: { class: coroutine; label: "P3" }
          s3_bc2_t2: { class: coroutine; label: "P4" }
        }
      }
    }
    
    s3_bp -> s3_bc: "work flows via channel" { class: work_arrow }
    
    s3_result: {
      label: "Result"
      shape: rectangle
      style: {
        fill: "#FEF3C7"
        stroke: "#F59E0B"
        font-color: "#92400E"
      }
      s3_res: |md
        ⚠ Work-stealing helps within each role
        ⚠ Cross-role balance requires channel capacity tuning
        ✓ Backpressure prevents producer overflow
      |
    }
  }
}

legend: {
  near: bottom-center
  direction: right
  style: { fill: "#F9FAFB"; stroke: "#E5E7EB"; border-radius: 8 }
  leg_title: {
    label: "Legend"
    shape: text
    style: { bold: true }
  }
  leg_hot: {
    label: "Hot Thread"
    style: { fill: "#FEE2E2"; stroke: "#DC2626" }
  }
  leg_normal: {
    label: "Active Thread"
    style: { fill: "#E8F4FD"; stroke: "#2563EB" }
  }
  leg_idle: {
    label: "Idle Thread"
    style: { fill: "#F3F4F6"; stroke: "#9CA3AF"; stroke-dash: 4 }
  }
  leg_task: {
    label: "Task"
    shape: circle
    style: { fill: "#3B82F6"; font-color: white }
  }
  leg_steal: {
    label: "Steal"
    style: { stroke: "#F59E0B"; stroke-width: 3 }
  }
}