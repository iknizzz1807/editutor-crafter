direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Scaling Efficiency vs Thread Count
  Work-Stealing Scheduler Performance Analysis
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  graph_container: {
    direction: down
    label: "Throughput Scaling Analysis"
    y_axis: {
      label: "Efficiency (%)"
      shape: text
      style.font-size: 14
    }
    grid_high: {
      label: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 100%"
      shape: text
      style.font: mono
      style.font-color: "#888888"
    }
    grid_80: {
      label: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━  80%"
      shape: text
      style.font: mono
      style.font-color: "#888888"
    }
    grid_70: {
      label: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━  70% ← Target"
      shape: text
      style.font: mono
      style.font-color: "#4CAF50"
    }
    grid_60: {
      label: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━  60%"
      shape: text
      style.font: mono
      style.font-color: "#888888"
    }
    grid_40: {
      label: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━  40%"
      shape: text
      style.font: mono
      style.font-color: "#888888"
    }
    grid_20: {
      label: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━  20%"
      shape: text
      style.font: mono
      style.font-color: "#888888"
    }
    x_axis: {
      label: "Thread Count:  1      2      4      8     16     32     64    128"
      shape: text
      style.font: mono
      style.font-size: 12
    }
    ideal_line: {
      label: "═══════════════════════════════════════════════ Ideal (100%)"
      shape: text
      style.font: mono
      style.font-color: "#2196F3"
    }
    actual_line: {
      label: "████████████████████████████▓▓▓▓▒▒▒▒░░░░ Actual Work-Stealing"
      shape: text
      style.font: mono
      style.font-color: "#4CAF50"
    }
    contention_zone: {
      label: "                              ▲ Contention Kicks In (~2× cores)"
      shape: text
      style.font: mono
      style.font-color: "#FF9800"
    }
    numa_zone: {
      label: "                                        ▲ NUMA Effects"
      shape: text
      style.font: mono
      style.font-color: "#F44336"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  col_left: {
    direction: down
    label: "Scaling Phases"
    phase1: {
      label: "Phase 1: Linear Scaling (1-8 threads)"
      shape: rectangle
      width: 280
      code: |'text
  Efficiency: 95-100%
  Behavior: Near-ideal scaling
  Why: Minimal contention, local
        queues mostly independent
        Cache effects minimal
      '|
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    phase2: {
      label: "Phase 2: Graceful Degradation (8-32)"
      shape: rectangle
      width: 280
      code: |'text
  Efficiency: 70-95%
  Behavior: Contention emerges
  Why: Global queue contention
        Cross-thread cache effects
        Steal attempts collide
      '|
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    phase3: {
      label: "Phase 3: NUMA Territory (32-128)"
      shape: rectangle
      width: 280
      code: |'text
  Efficiency: 40-70%
  Behavior: Cross-socket penalty
  Why: Remote memory access 2× slower
        Cache coherence overhead
        Work-stealing across nodes
      '|
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
    }
  }
  col_right: {
    direction: down
    label: "Stealing Strategy Impact"
    stealing_table: {
      shape: sql_table
      label: "Steal Success Rate by Strategy"
      r1: "Threads | Random | Directed | NUMA-Aware"
      r2: "8       | 78%    | 82%      | 82%"
      r3: "16      | 65%    | 74%      | 75%"
      r4: "32      | 48%    | 61%      | 68%"
      r5: "64      | 31%    | 45%      | 58%"
      r6: "128     | 18%    | 32%      | 47%"
    }
    strategy_note: {
      label: "Key Insight"
      shape: callout
      width: 260
      code: |'text
Random stealing spreads contention
but scales poorly past core count.
Directed stealing (prefer loaded
victims) improves success rate.
NUMA-aware stealing prefers same
socket, avoiding remote memory.
      '|
      style.fill: "#E3F2FD"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  overhead_breakdown: {
    direction: down
    label: "Overhead Sources"
    overhead_table: {
      shape: sql_table
      label: "Cost Breakdown per Steal Attempt"
      f1: "0x00 | Context switch     | 20-50 ns"
      f2: "0x08 | Queue lock (local) | 5-15 ns"
      f3: "0x10 | Cache miss (victim)| 40-100 ns"
      f4: "0x18 | Atomic CAS fail    | 10-20 ns"
      f5: "0x20 | TLB miss           | 20-50 ns"
      f6: "0x28 | NUMA remote access | +50-100 ns"
      total: "Total steal cost: 100-350 ns"
    }
    cache_effect: {
      label: "Cache Effect on Stolen Work"
      shape: rectangle
      width: 300
      code: |'text
When stealing a coroutine:
  Victim's L1: Coroutine's stack HOT
  Stealer's L1: Coroutine's stack COLD
  First 100 accesses: ~40 cycles each
  (L3/DRAM instead of L1 ~4 cycles)
  Warmup penalty: 100-500 cache misses
  Estimated cost: 4,000-20,000 cycles
This is why LIFO local pops are
preferred over stealing.
      '|
      style.fill: "#F3E5F5"
      style.stroke: "#9C27B0"
    }
  }
  contention_analysis: {
    direction: down
    label: "Contention Analysis"
    contention_graph: {
      shape: rectangle
      label: "Global Queue Contention"
      width: 320
      code: |'text
Threads waiting on global_queue lock:
  4 threads:  ████████░░░░░░░░░░░░  12% wait
  8 threads:  ██████████████░░░░░░  28% wait  
  16 threads: ████████████████████  52% wait
  32 threads: ████████████████████  78% wait
Mitigation: Local queues are primary
             Global queue is fallback
             Batch transfers reduce lock
             acquisitions by 10-32×
      '|
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  benchmark_results: {
    direction: down
    label: "Benchmark: CPU-Bound Workload"
    results_table: {
      shape: sql_table
      label: "Fibonacci(35) × 1000 coroutines"
      h1: "Threads | Time (ms) | Speedup | Efficiency"
      r1: "1       | 12400     | 1.00×   | 100%"
      r2: "2       | 6300      | 1.97×   | 98%"
      r3: "4       | 3300      | 3.76×   | 94%"
      r4: "8       | 1850      | 6.70×   | 84%"
      r5: "16      | 1200      | 10.33×  | 65%"
      r6: "32      | 980       | 12.65×  | 40%"
      r7: "64      | 1100      | 11.27×  | 18%"
    }
    analysis: {
      label: "Analysis"
      shape: rectangle
      width: 280
      code: |'text
Peak efficiency at core count (8).
Past 2× cores, contention dominates:
  - Lock acquisition collisions
  - Cache line bouncing
  - Memory bandwidth saturation
64 threads SLOWER than 32 due to:
  - NUMA cross-socket traffic
  - Hyperthreading (no real cores)
  - Oversubscription overhead
      '|
      style.fill: "#ECEFF1"
    }
  }
  recommendations: {
    direction: down
    label: "Optimization Strategies"
    strategy1: {
      label: "Thread Count Selection"
      shape: rectangle
      width: 300
      code: |'text
Rule of thumb:
  threads = min(physical_cores, 
                coroutine_count / 100)
For 8-core machine:
  - 8 threads: Best throughput
  - 4 threads: Lower latency
  - 16 threads: Diminishing returns
  - 32+ threads: Counterproductive
      '|
      style.fill: "#E8F5E9"
    }
    strategy2: {
      label: "Work Distribution"
      shape: rectangle
      width: 300
      code: |'text
Keep work local when possible:
  1. Spawn on current thread's queue
  2. Prefer LIFO from local queue
  3. Steal only when truly idle
  4. Batch steals (grab 8-16 items)
This maximizes cache warmth and
minimizes contention.
      '|
      style.fill: "#E3F2FD"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  label: ""
  style.stroke: transparent
  style.fill: transparent
  l1: {
    label: "═══ Ideal Linear"
    shape: text
    style.font: mono
    style.font-color: "#2196F3"
  }
  l2: {
    label: "  ███ Actual (Work-Stealing)"
    shape: text
    style.font: mono
    style.font-color: "#4CAF50"
  }
  l3: {
    label: "  ▓▓▓ Contention Zone"
    shape: text
    style.font: mono
    style.font-color: "#FF9800"
  }
  l4: {
    label: "  ░░░ NUMA Penalty"
    shape: text
    style.font: mono
    style.font-color: "#F44336"
  }
}
phase1 -> phase2: "Contention\nEmerges" {
  style.stroke-dash: 3
  style.stroke: "#FF9800"
}
phase2 -> phase3: "NUMA\nEffects" {
  style.stroke-dash: 3
  style.stroke: "#F44336"
}