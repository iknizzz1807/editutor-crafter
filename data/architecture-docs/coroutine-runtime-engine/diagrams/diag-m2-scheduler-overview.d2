direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  style.stroke: transparent
  style.fill: transparent
  title: "M:N Scheduler Architecture" {
    shape: rectangle
    style.font-size: 28
    style.bold: true
    style.fill: "#FAFAFA"
  }
  subtitle: "M Coroutines multiplexed onto N Kernel Threads (M >> N)" {
    shape: rectangle
    style.italic: true
    style.fill: "#FAFAFA"
  }
}

row_coroutines: "" {
  style.stroke: transparent
  style.fill: transparent
  coroutines: {
    label: "Coroutines (M = thousands)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    direction: right

    coro1: "Coroutine 1 | 64 KB" {
      style.fill: "#C8E6C9"
    }
    coro2: "Coroutine 2 | 64 KB" {
      style.fill: "#C8E6C9"
    }
    coro3: "Coroutine 3 | 64 KB" {
      style.fill: "#C8E6C9"
    }
    coro_m: "Coroutine M | ..." {
      style.fill: "#C8E6C9"
      style.stroke-dash: 3
    }
  }
}

row_scheduler: "" {
  style.stroke: transparent
  style.fill: transparent
  scheduler: {
    label: "Scheduler (User-Space)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    
    global_queue: {
      shape: sql_table
      label: "Global Run Queue (FIFO)"
      row1: "Task A"
      row2: "Task B"
      row3: "Task C"
      style.fill: "#BBDEFB"
    }

    local_queues: {
      label: "Per-Thread Local Queues"
      style.stroke: transparent
      direction: right
      
      lq0: {
        label: "Local Queue 0 (LIFO)"
        shape: queue
        style.fill: "#90CAF9"
      }
      lq1: {
        label: "Local Queue 1 (LIFO)"
        shape: queue
        style.fill: "#90CAF9"
      }
      lq2: {
        label: "Local Queue N (LIFO)"
        shape: queue
        style.fill: "#90CAF9"
      }
    }
  }
}

row_threads: "" {
  style.stroke: transparent
  style.fill: transparent
  threads: {
    label: "Kernel Threads (N = CPU cores)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    direction: right

    t0: "Thread 0 (Core 0)" {
      style.fill: "#FFE0B2"
    }
    t1: "Thread 1 (Core 1)" {
      style.fill: "#FFE0B2"
    }
    tn: "Thread N (Core N)" {
      style.fill: "#FFE0B2"
    }
  }
}

row_hardware: "" {
  style.stroke: transparent
  style.fill: transparent
  hardware: {
    label: "Hardware (CPU Cores)"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    style.stroke-width: 2
    direction: right

    c0: "Core 0" {
      shape: hexagon
      style.fill: "#F8BBD9"
    }
    c1: "Core 1" {
      shape: hexagon
      style.fill: "#F8BBD9"
    }
    cn: "Core N" {
      shape: hexagon
      style.fill: "#F8BBD9"
    }
  }
}

# Connections
row_coroutines.coroutines -> row_scheduler.scheduler.global_queue: "spawn | 64KB stack" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

row_scheduler.scheduler.global_queue -> row_scheduler.scheduler.local_queues: "distribute"

row_scheduler.scheduler.local_queues.lq0 -> row_threads.threads.t0: "pop | LIFO" {
  style.stroke: "#2196F3"
}
row_scheduler.scheduler.local_queues.lq1 -> row_threads.threads.t1: "pop | LIFO" {
  style.stroke: "#2196F3"
}
row_scheduler.scheduler.local_queues.lq2 -> row_threads.threads.tn: "pop | LIFO" {
  style.stroke: "#2196F3"
}

row_threads.threads.t0 -> row_hardware.hardware.c0: "execute" {
  style.stroke: "#FF9800"
}
row_threads.threads.t1 -> row_hardware.hardware.c1: "execute" {
  style.stroke: "#FF9800"
}
row_threads.threads.tn -> row_hardware.hardware.cn: "execute" {
  style.stroke: "#FF9800"
}

# Work-stealing
row_scheduler.scheduler.local_queues.lq1 -> row_scheduler.scheduler.local_queues.lq0: "steal half" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 4
  style.animated: true
}
row_scheduler.scheduler.local_queues.lq2 -> row_scheduler.scheduler.local_queues.lq1: "steal half" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 4
  style.animated: true
}

# Footer Info
benefits: {
  label: "Performance Metrics Comparison"
  content: |'md
    | Metric | OS Threads | Coroutines |
    |--------|-----------|------------|
    | Stack size | 8 MB | 64 KB |
    | Context switch | 1-2 μs | 20-50 ns |
    | 10K concurrent | 80 GB RAM | 640 MB RAM |
    | Kernel calls | Every switch | Rare |
  '|
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}
benefits.near: bottom-right

legend: {
  label: "Component Legend"
  leg_coro: "Green = Coroutines (User-space)" {
    style.font-color: "#4CAF50"
  }
  leg_sched: "Blue = Scheduler (User-space)" {
    style.font-color: "#2196F3"
  }
  leg_thread: "Orange = Threads (Kernel)" {
    style.font-color: "#FF9800"
  }
  leg_hw: "Pink = Hardware Cores" {
    style.font-color: "#E91E63"
  }
  leg_steal: "Purple dashed = Work stealing" {
    style.font-color: "#9C27B0"
  }
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
}
legend.near: bottom-left