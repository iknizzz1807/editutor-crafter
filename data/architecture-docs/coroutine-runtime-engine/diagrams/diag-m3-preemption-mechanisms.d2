direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Preemption Mechanisms Compared
  Trade-offs: Safety vs Precision vs Implementation Complexity
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  approach1: {
    direction: down
    label: "Approach 1: Signal-Based"
    signal_timer: {
      label: "Timer Signal (SIGUSR1)"
      width: 280
      style.fill: "#FFE4E1"
      style.stroke: "#DC143C"
      mechanism: |'c
        // Kernel delivers signal at time slice
        setitimer(ITIMER_REAL, &timer, NULL);
        // Signal handler runs on current stack
        void handler(int sig) {
            // DANGER: Very few functions are safe here!
            preempt_flag = 1;  // Only async-signal-safe ops
        }
      '|
    }
    signal_flow: {
      label: "Execution Flow"
      width: 280
      step1: "Timer fires → SIGUSR1"
      step2: "Handler saves context"
      step3: "Force yield to scheduler"
      step4: "Resume elsewhere"
      step1 -> step2 -> step3 -> step4
    }
    signal_pros: {
      label: "Pros ✓"
      shape: rectangle
      width: 280
      style.fill: "#E8F5E9"
      pros_list: |md
        • Preempts at **any instruction**
        • No compiler cooperation needed
        • Precise time slicing (10ms guaranteed)
        • Works with unmodified binaries
      |
    }
    signal_cons: {
      label: "Cons ✗"
      shape: rectangle
      width: 280
      style.fill: "#FFEBEE"
      cons_list: |md
        • **Async-signal-safe only** (no malloc, printf)
        • Can interrupt mid-operation
        • Stack handling is tricky
        • Complex interaction with syscalls
        • **Risk: corruption, deadlock**
      |
    }
    signal_rating: {
      label: "Complexity & Risk"
      width: 280
      style.fill: "#FFF3E0"
      risk_bar: {
        label: "HIGH"
        shape: rectangle
        width: 200
        style.fill: "#F44336"
        style.font-color: white
        style.bold: true
      }
    }
    signal_timer -> signal_flow -> signal_pros -> signal_cons -> signal_rating
  }
  approach2: {
    direction: down
    label: "Approach 2: Compiler Yield Points"
    compiler_points: {
      label: "Compiler-Inserted Checks"
      width: 280
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      mechanism: |'c
        // Compiler inserts at safe points:
        void coroutine_func() {
            yield_check();  // Function entry
            for (int i = 0; i < N; i++) {
                yield_check();  // Loop backedge
                do_work(i);
            }
            yield_check();  // Before blocking ops
        }
        // Generated check:
        void yield_check() {
            if (preempt_flag) {
                preempt_flag = 0;
                yield_to_scheduler();
            }
        }
      '|
    }
    compiler_flow: {
      label: "Execution Flow"
      width: 280
      cstep1: "Coroutine executes normally"
      cstep2: "Reaches yield point"
      cstep3: "Check flag → yield if set"
      cstep4: "Scheduler picks next"
      cstep1 -> cstep2 -> cstep3 -> cstep4
    }
    compiler_pros: {
      label: "Pros ✓"
      shape: rectangle
      width: 280
      style.fill: "#E8F5E9"
      pros_list: |md
        • Only preempts at **safe points**
        • No signal handling complexity
        • Predictable overhead (constant-time)
        • No risk of mid-operation interrupt
      |
    }
    compiler_cons: {
      label: "Cons ✗"
      shape: rectangle
      width: 280
      style.fill: "#FFEBEE"
      cons_list: |md
        • **Requires compiler support**
        • Doesn't work with FFI/libraries
        • Long loops without calls can starve
        • Latency depends on check frequency
      |
    }
    compiler_rating: {
      label: "Complexity & Risk"
      width: 280
      style.fill: "#FFF3E0"
      c_risk_bar: {
        label: "LOW"
        shape: rectangle
        width: 200
        style.fill: "#4CAF50"
        style.font-color: white
        style.bold: true
      }
    }
    compiler_points -> compiler_flow -> compiler_pros -> compiler_cons -> compiler_rating
  }
  approach3: {
    direction: down
    label: "Approach 3: Hybrid (Recommended)"
    hybrid_mech: {
      label: "Timer + Safe Points"
      width: 280
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      mechanism: |'c
        // Timer sets flag (signal-safe)
        void timer_handler(int sig) {
            preempt_requested = 1;  // Just atomic store
        }
        // Coroutines check at safe points
        void cooperative_yield() {
            if (preempt_requested) {
                preempt_requested = 0;
                yield_now();  // Safe to yield here
            }
        }
        // Called in loops, before I/O, etc.
        for (i in 0..N) {
            cooperative_yield();
            do_work(i);
        }
      '|
    }
    hybrid_flow: {
      label: "Execution Flow"
      width: 280
      hstep1: "Timer fires, sets flag"
      hstep2: "Coroutine continues"
      hstep3: "Reaches safe point"
      hstep4: "Check flag → yield if set"
      hstep5: "Scheduler picks next"
      hstep1 -> hstep2 -> hstep3 -> hstep4 -> hstep5
    }
    hybrid_pros: {
      label: "Pros ✓"
      shape: rectangle
      width: 280
      style.fill: "#E8F5E9"
      pros_list: |md
        • Timer precision for fairness
        • Only yields at **safe points**
        • No signal handler complexity
        • Works without full compiler support
        • **Best of both worlds**
      |
    }
    hybrid_cons: {
      label: "Cons ✗"
      shape: rectangle
      width: 280
      style.fill: "#FFEBEE"
      cons_list: |md
        • Still requires some cooperation
        • Latency bounded by safe-point freq
        • Manual insertion without compiler
        • Bad code can still starve
      |
    }
    hybrid_rating: {
      label: "Complexity & Risk"
      width: 280
      style.fill: "#FFF3E0"
      h_risk_bar: {
        label: "MEDIUM"
        shape: rectangle
        width: 200
        style.fill: "#FF9800"
        style.font-color: white
        style.bold: true
      }
    }
    hybrid_mech -> hybrid_flow -> hybrid_pros -> hybrid_cons -> hybrid_rating
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison_table: {
    label: "Feature Comparison"
    width: 880
    features: {
      shape: sql_table
      label: "Preemption Approaches"
      f_feature: "Feature"
      f_signal: "Signal-Based"
      f_compiler: "Compiler Points"
      f_hybrid: "Hybrid"
      r1: "Preemption precision | Any instruction | Safe points only | Safe points only"
      r2: "Time-slice guarantee | ✓ Exact | ✗ Depends on checks | ✓ Approximate"
      r3: "Compiler support | ✗ None needed | ✓ Required | ⚠ Optional"
      r4: "FFI compatibility | ✓ Works | ✗ Cannot yield in FFI | ⚠ Limited"
      r5: "Implementation risk | High (corruption) | Low | Medium"
      r6: "Signal safety | Critical | N/A | Minimal (just set flag)"
      r7: "Latency bound | ~0 | Check frequency | Check frequency"
      r8: "Used by | Early Go (abandoned) | Modern Go, Tokio | This runtime"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recommendation: {
    label: "Recommendation: Hybrid Approach"
    width: 880
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.border-radius: 8
    content: |md
      **Why Hybrid?**
      The hybrid approach balances safety and fairness:
      1. **Timer provides fairness guarantee** — no coroutine runs >10ms unchecked
      2. **Safe-point checks prevent corruption** — never interrupt mid-operation
      3. **Signal handler is trivial** — just set a flag (async-signal-safe)
      4. **Graceful degradation** — uncooperative code still makes progress (slower)
      **Implementation Tips:**
      - Insert `cooperative_yield()` at loop boundaries, before I/O, after function calls
      - Use 10ms time slices (balance fairness vs overhead)
      - In debug builds, warn if coroutine runs >50ms without yielding
    |
  }
}
row1 -> row2 -> row3