direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Preemption Overhead Breakdown
  ## Where does the <1% cost come from?
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  overhead_box: {
    label: "Preemption Cost Sources"
    width: 400
    signal: {
      label: "Signal Delivery"
      code: |'c
        Timer fires → SIGUSR1
        Handler sets PREEMPTION_FLAG
        Atomic store (~5 cycles)
      '|
      width: 380
    }
    signal.style.fill: "#FFE4B5"
    signal.style.stroke: "#FF8C00"
    check: {
      label: "Flag Check (per safe point)"
      code: |'c
        if PREEMPTION_FLAG.load(Relaxed) {
          // Branch predicted "not taken"
          // ~1-2 cycles per check
        }
      '|
      width: 380
    }
    check.style.fill: "#E6FFE6"
    check.style.stroke: "#32CD32"
    ctxswitch: {
      label: "Context Switch (when preempted)"
      code: |'c
        yield_now() → scheduler
        Save callee-saved regs
        Switch to scheduler context
      '|
      width: 380
    }
    ctxswitch.style.fill: "#E6E6FF"
    ctxswitch.style.stroke: "#4169E1"
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  timing_box: {
    label: "Timing Analysis"
    width: 500
    timing_table: {
      shape: sql_table
      label: "Cost Breakdown (per 10ms time slice)"
      r1: "Signal delivery | 1× | ~100 ns | One timer fire"
      r2: "Flag check | 10,000× | ~1 ns each | ~10 μs total"
      r3: "Context switch | 1× | ~50 ns | If preempted"
      r4: "Total overhead | — | ~10.15 μs | Per time slice"
      total: "Overhead ratio | 10.15 μs / 10 ms | ~0.1% | Negligible"
    }
  }
}
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  scale_box: {
    label: "Time Scale Perspective"
    width: 500
    timeline: {
      shape: class
      label: "10ms Time Slice (10,000,000 ns)"
      useful: "Useful work: ~9,989,850 ns (99.9%)"
      signal: "Signal: ~100 ns"
      checks: "Checks: ~10,000 ns"
      switch: "Switch: ~50 ns"
    }
  }
}
row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  insight_box: {
    label: "Why It's So Low"
    width: 400
    insight: |md
      **Key Insight**: The flag check is a *single atomic load* 
      that's almost always in L1 cache and branch-predicted 
      as "not taken." The CPU speculatively continues executing 
      useful work.
      The actual preemption (context switch) happens only 
      **once per time slice**, so the 50ns cost is amortized 
      over 10ms of work.
      **Compare to OS preemption**: ~1-2 μs per switch, 
      100× more expensive than our coroutine switch.
    |
  }
}
row1 -> row2: "Costs → Timing"
row2 -> row3: "Timing → Scale"
row3 -> row4: "Scale → Insight"
legend: {
  near: bottom-right
  label: "Color Key"
  signal_legend: "Signal Delivery" {style.fill: "#FFE4B5"}
  check_legend: "Flag Check" {style.fill: "#E6FFE6"}
  switch_legend: "Context Switch" {style.fill: "#E6E6FF"}
}