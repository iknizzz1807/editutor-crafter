direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Safe Points for Preemption {
  near: top-center
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#f0f0f0"
    stroke-width: 0
  }
}

row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  safe_points: "SAFE POINTS ✓" {
    direction: down
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 3
      border-radius: 12
    }

    func_entry: "Function Entry" {
      style.fill: "#C8E6C9"
      code: |'rust
      fn process() {
          // SAFE: prologue complete
          // stack frame established
          // no partial state
      }
      '|
      note: "Note: Frame ready, no registers in flux"
    }

    loop_back: "Loop Back-Edge" {
      style.fill: "#C8E6C9"
      code: |'rust
      for i in 0..n {
          compute(i);
          // SAFE: iteration done
          // invariants hold
      }
      '|
      note: "Note: Check before next iteration"
    }

    alloc_point: "Allocation Points" {
      style.fill: "#C8E6C9"
      code: |'rust
      let v = Vec::new();
      // SAFE: heap consistent
      // GC-safe point
      v.push(item);
      '|
      note: "Note: Heap/GC state is valid here"
    }

    yield_point: "Explicit Yield" {
      style.fill: "#C8E6C9"
      code: |'rust
      yield_now();
      // SAFE: by definition
      // state explicitly saved
      '|
      note: "Note: Cooperative context switch"
    }

    func_entry -> loop_back -> alloc_point -> yield_point
  }

  unsafe_points: "UNSAFE POINTS ✗" {
    direction: down
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 3
      border-radius: 12
    }

    inside_lock: "Inside Lock Hold" {
      style.fill: "#FFCDD2"
      code: |'rust
      let guard = mutex.lock();
      // UNSAFE: lock held
      // preemption = deadlock
      // others blocked
      '|
      note: "Note: Deadlock or priority inversion risk"
    }

    mid_struct: "Mid-Struct Update" {
      style.fill: "#FFCDD2"
      code: |'rust
      state.phase = Writing;
      state.offset = 0;
      // UNSAFE: partial update
      // invariants broken
      '|
      note: "Note: Data inconsistency risk"
    }

    ffi_boundary: "FFI Boundary" {
      style.fill: "#FFCDD2"
      code: |'rust
      unsafe {
          // UNSAFE: in FFI call
          // C code on stack
          libc::write(fd, buf, len)
      };
      '|
      note: "Note: Opaque stack / No unwind support"
    }

    mid_expression: "Mid-Expression" {
      style.fill: "#FFCDD2"
      code: |'rust
      let x = a + b * c;
      // UNSAFE: mid-compute
      // partial in register
      '|
      note: "Note: Scratch register corruption"
    }

    inside_lock -> mid_struct -> ffi_boundary -> mid_expression
  }
}

row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  why_matters: "Why Safe Points Matter" {
    direction: down
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      border-radius: 12
    }
    
    stack_consistency: {
      label: "Stack Consistency"
      width: 280
      style.fill: "#FFE0B2"
      desc: |'md
      Frame is fully established.
      Locals have defined locations.
      Return addresses are valid.
      '|
    }
    
    invariant_preservation: {
      label: "Invariant Preservation"
      width: 280
      style.fill: "#FFE0B2"
      desc: |'md
      Data invariants hold:
      - Linked lists are consistent
      - Ref-counts are correct
      '|
    }
    
    recoverability: {
      label: "Recoverability"
      width: 280
      style.fill: "#FFE0B2"
      desc: |'md
      Resumption is clean.
      No dangling pointers.
      No half-written states.
      '|
    }
    
    stack_consistency -> invariant_preservation -> recoverability
  }

  check_frequency: "Check Frequency" {
    direction: down
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 12
    }
    
    freq_table: {
      shape: sql_table
      label: "Check Strategy | Latency | Overhead"
      r1: "Every instruction | < 1us  | 5-10%"
      r2: "Loop/Func Entry  | < 10us | 1-2%"
      r3: "Explicit Yield   | Unbound| 0%"
    }
    
    recommendation: {
      label: "Hybrid Approach (e.g. Go Runtime)"
      width: 280
      style.fill: "#BBDEFB"
      code: |'rust
      fn heavy_task() {
          for i in 0..1000 {
              compute(i);
              // Check preemption flag
              if runtime.should_yield() {
                  yield_now();
              }
          }
      }
      '|
    }
    
    freq_table -> recommendation
  }
}

row1.safe_points -> row2.why_matters: "Guarantees Safety" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 4
}

row1.unsafe_points -> row2.why_matters: "State Corruption" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}

legend: {
  near: bottom-right
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  safe: "✓ Safe Point" {
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  unsafe: "✗ Unsafe Point" {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
    }
  }
}