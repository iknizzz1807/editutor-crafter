direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Time Slice Scheduling: Fairness Through Preemption" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

scheduler_state: {
  shape: sql_table
  label: "struct SchedContext (kernel/sched.h)"
  f0: "0x00 | uint64_t | tick_count"
  f1: "0x08 | task_t*  | current_task"
  f2: "0x10 | list_head | run_queue"
  f3: "0x18 | uint32_t | slice_remaining_ms"
  f4: "0x1C | uint32_t | preempt_threshold"
  sz: "Total: 32 bytes"
}
scheduler_state.near: top-right

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  scenario_cooperative: {
    direction: down
    label: "Cooperative Scheduling (No Preemption)"
    style.fill: "#fff5f5"
    
    timeline_coop: {
      direction: right
      style.stroke: transparent
      t0: "0ms"; t10: "10ms"; t20: "20ms"; t30: "30ms"; t40: "40ms"; t50: "50ms+"
      *.shape: text
      *.style.font-size: 14
    }

    coro_a_group: {
      direction: down
      style.stroke: transparent
      bar: "Coroutine A (CPU-bound loop)" {
        width: 500
        height: 40
        style: {
          fill: "#ff6b6b"
          stroke: "#c92a2a"
          stroke-width: 2
        }
      }
      note: "Hogs thread: t=0 to completion" {
        shape: text
        style.font-color: "#c92a2a"
        style.italic: true
        style.font-size: 12
      }
    }

    coro_b_group: {
      direction: down
      style.stroke: transparent
      bar: "Coroutine B (Ready)" {
        width: 500
        height: 40
        style: {
          fill: "#f1f3f5"
          stroke: "#fab005"
          stroke-dash: 5
        }
      }
      note: "Starved: never reaches CPU" {
        shape: text
        style.font-color: "#e67700"
        style.italic: true
        style.font-size: 12
      }
    }

    verdict_coop: {
      label: "Result: 0% fairness, unbounded latency"
      shape: callout
      style: {
        fill: "#fff5f5"
        stroke: "#c92a2a"
        font-color: "#c92a2a"
        bold: true
      }
    }
  }

  scenario_preemptive: {
    direction: down
    label: "Preemptive Scheduling (10ms Time Slices)"
    style.fill: "#ebfbee"
    
    timeline_pre: {
      direction: right
      style.stroke: transparent
      t0: "0ms"; t10: "10ms"; t20: "20ms"; t30: "30ms"; t40: "40ms"; t50: "50ms"
      *.shape: text
      *.style.font-size: 14
    }

    coro_a_pre: {
      direction: right
      style.stroke: transparent
      a1: "A" { width: 80; height: 40; style.fill: "#ff6b6b" }
      gap1: "Wait" { width: 160; style.fill: "#f8f9fa"; style.stroke-dash: 3 }
      a2: "A" { width: 80; height: 40; style.fill: "#ff6b6b" }
      gap2: "Wait" { width: 160; style.fill: "#f8f9fa"; style.stroke-dash: 3 }
      a3: "A" { width: 80; height: 40; style.fill: "#ff6b6b" }
    }

    coro_b_pre: {
      direction: right
      style.stroke: transparent
      gap1: "Wait" { width: 80; style.fill: "#f8f9fa"; style.stroke-dash: 3 }
      b1: "B" { width: 80; height: 40; style.fill: "#ffe066" }
      gap2: "Wait" { width: 160; style.fill: "#f8f9fa"; style.stroke-dash: 3 }
      b2: "B" { width: 80; height: 40; style.fill: "#ffe066" }
      gap3: "Wait" { width: 80; style.fill: "#f8f9fa"; style.stroke-dash: 3 }
      b3: "B" { width: 80; height: 40; style.fill: "#ffe066" }
    }

    coro_c_pre: {
      direction: right
      style.stroke: transparent
      gap1: "Wait" { width: 160; style.fill: "#f8f9fa"; style.stroke-dash: 3 }
      c1: "C" { width: 80; height: 40; style.fill: "#69db7c" }
      gap2: "Wait" { width: 160; style.fill: "#f8f9fa"; style.stroke-dash: 3 }
      c2: "C" { width: 80; height: 40; style.fill: "#69db7c" }
    }

    verdict_pre: {
      label: "Result: 100% fairness, max latency: 20ms"
      shape: callout
      style: {
        fill: "#ebfbee"
        stroke: "#2b8a3e"
        font-color: "#2b8a3e"
        bold: true
      }
    }
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  timeslice_analysis: {
    direction: down
    label: "Efficiency vs Latency Trade-offs"
    
    short: {
      direction: right
      bar: { width: 40; height: 20; style.fill: "#ff8787" }
      text: "1ms (Low Latency)"
      data: |'md
        - **Latency:** 2ms (Excellent)
        - **Overhead:** ~12% (High)
        - **Use:** Real-time audio/HFT
      '|
    }
    
    medium: {
      direction: right
      bar: { width: 100; height: 20; style.fill: "#69db7c" }
      text: "10ms (Balanced)"
      data: |'md
        - **Latency:** 20ms (Good)
        - **Overhead:** <1% (Low)
        - **Use:** General Purpose OS
      '|
    }
    
    long: {
      direction: right
      bar: { width: 200; height: 20; style.fill: "#74c0fc" }
      text: "100ms (Throughput)"
      data: |'md
        - **Latency:** 200ms (Poor)
        - **Overhead:** Negligible
        - **Use:** Batch processing/HPC
      '|
    }
  }

  overhead_chart: {
    direction: down
    label: "Context Switch Overhead"
    
    viz: {
      direction: right
      y_axis: {
        direction: down
        "10%": { shape: text }
        "5%": { shape: text }
        "1%": { shape: text }
        "0%": { shape: text }
      }
      bars: {
        direction: right
        b1: { direction: down; rect: { height: 100; width: 30; style.fill: "#ff8787" }; label: "1ms" }
        b2: { direction: down; rect: { height: 20; width: 30; style.fill: "#69db7c" }; label: "10ms" }
        b3: { direction: down; rect: { height: 5; width: 30; style.fill: "#74c0fc" }; label: "50ms" }
      }
    }
    
    insight: {
      label: |'md
        **Hardware Context Switch:** ~50-100ns
        **Cache Warm-up Cost:** ~5-50µs
        
        Frequent switching destroys instruction cache locality.
      '|
      style.fill: "#e7f5ff"
      style.stroke: "#339af0"
    }
  }
}

legend: {
  direction: right
  running: { style.fill: "#74c0fc"; label: "Running" }
  waiting: { style.fill: "#f1f3f5"; style.stroke-dash: 3; label: "Wait/Ready" }
  preempt: { shape: hexagon; style.fill: "#ff922b"; label: "Interrupt/Yield" }
}
legend.near: bottom-right

formula_box: {
  label: |'md
    **Latency Formula:**
    `T_latency = T_slice * (N_tasks - 1)`
    
    *Assumes tasks are CPU-bound and slice-exhausting.*
  '|
  style: {
    fill: "#f8f9fa"
    stroke: "#495057"
    font: mono
  }
}
formula_box.near: bottom-left