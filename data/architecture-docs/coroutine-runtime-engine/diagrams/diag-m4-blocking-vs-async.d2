direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Blocking I/O vs Async I/O Timeline
| {near: top-center}
row_before: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  before: "Blocking I/O (1 Thread = 1 Connection)" {
    direction: down
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    b_timeline: {
      direction: right
      label: "Thread T1"
      b_t0: "t=0" {shape: text}
      b_t1: "t=1" {shape: text}
      b_t2: "t=2" {shape: text}
      b_t3: "t=3" {shape: text}
      b_t4: "t=4" {shape: text}
      b_t5: "t=5" {shape: text}
    }
    b_blocks: {
      direction: right
      label: ""
      b_work1: "CPU Work\n50ms" {
        style.fill: "#90EE90"
        shape: rectangle
        width: 80
      }
      b_wait1: "I/O Wait\n150ms" {
        style.fill: "#FFB6C1"
        shape: rectangle
        width: 180
      }
      b_work2: "CPU\n50ms" {
        style.fill: "#90EE90"
        shape: rectangle
        width: 80
      }
      b_wait2: "I/O Wait\n150ms" {
        style.fill: "#FFB6C1"
        shape: rectangle
        width: 180
      }
      b_work3: "CPU\n50ms" {
        style.fill: "#90EE90"
        shape: rectangle
        width: 80
      }
    }
    b_labels: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      b_l1: "Green = Useful Work" {
        shape: text
        style.fill: "#90EE90"
      }
      b_l2: "Pink = Thread Blocked (Idle)" {
        shape: text
        style.fill: "#FFB6C1"
      }
    }
  }
}
row_after: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  after: "Async I/O (1 Thread = N Coroutines)" {
    direction: down
    style.fill: "#F0FFF0"
    style.stroke: "#00AA00"
    a_timeline: {
      direction: right
      label: "Thread T1"
      a_t0: "t=0" {shape: text}
      a_t1: "t=1" {shape: text}
      a_t2: "t=2" {shape: text}
      a_t3: "t=3" {shape: text}
      a_t4: "t=4" {shape: text}
      a_t5: "t=5" {shape: text}
    }
    a_coro1: {
      direction: right
      label: "Coroutine A"
      c1_work1: "CPU" {
        style.fill: "#90EE90"
        width: 60
      }
      c1_wait: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c1_work2: "CPU" {
        style.fill: "#90EE90"
        width: 60
      }
      c1_wait2: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c1_work3: "CPU" {
        style.fill: "#90EE90"
        width: 60
      }
    }
    a_coro2: {
      direction: right
      label: "Coroutine B"
      c2_work1: "CPU" {
        style.fill: "#98FB98"
        width: 60
      }
      c2_wait: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c2_work2: "CPU" {
        style.fill: "#98FB98"
        width: 60
      }
      c2_wait2: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c2_work3: "CPU" {
        style.fill: "#98FB98"
        width: 60
      }
    }
    a_coro3: {
      direction: right
      label: "Coroutine C"
      c3_work1: "CPU" {
        style.fill: "#7CFC00"
        width: 60
      }
      c3_wait: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c3_work2: "CPU" {
        style.fill: "#7CFC00"
        width: 60
      }
      c3_wait2: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c3_work3: "CPU" {
        style.fill: "#7CFC00"
        width: 60
      }
    }
    a_coro4: {
      direction: right
      label: "Coroutine D"
      c4_work1: "CPU" {
        style.fill: "#32CD32"
        width: 60
      }
      c4_wait: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c4_work2: "CPU" {
        style.fill: "#32CD32"
        width: 60
      }
      c4_wait2: "yield" {
        style.fill: "#ADD8E6"
        style.stroke-dash: 3
        width: 40
      }
      c4_work3: "CPU" {
        style.fill: "#32CD32"
        width: 60
      }
    }
    a_labels: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      a_l1: "Green shades = Different coroutines doing work" {
        shape: text
      }
      a_l2: "Blue = Yielded (scheduler runs other coroutines)" {
        shape: text
        style.fill: "#ADD8E6"
      }
    }
  }
}
row_metrics: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  metrics: "Throughput Comparison" {
    direction: right
    style.fill: "#F5F5F5"
    style.stroke: "#666666"
    blocking_stats: {
      direction: down
      label: "Blocking I/O"
      style.fill: "#FFF0F0"
      bs_cpu: "CPU Utilization: ~25%" {
        shape: rectangle
        style.fill: "#FFCCCC"
      }
      bs_idle: "Thread Idle: ~75%" {
        shape: rectangle
        style.fill: "#FF9999"
      }
      bs_conn: "Connections per thread: 1" {
        shape: rectangle
        style.fill: "#FFE0E0"
      }
    }
    async_stats: {
      direction: down
      label: "Async I/O"
      style.fill: "#F0FFF0"
      as_cpu: "CPU Utilization: ~95%" {
        shape: rectangle
        style.fill: "#CCFFCC"
      }
      as_idle: "Thread Idle: ~5%" {
        shape: rectangle
        style.fill: "#99FF99"
      }
      as_conn: "Connections per thread: 100+" {
        shape: rectangle
        style.fill: "#E0FFE0"
      }
    }
  }
}
arrow_label: "Same Hardware\nDifferent Abstraction" {
  shape: text
  near: center-left
  style.font-size: 20
  style.italic: true
}
before_blocks -> after: "Transform" {
  style.stroke: "#666666"
  style.stroke-width: 3
  style.stroke-dash: 5
}
blocking_stats -> async_stats: "4x-10x improvement" {
  style.stroke: "#00AA00"
  style.stroke-width: 2
}