direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  shape: rectangle
  label: |md
    # Scaling to 10K+ Connections
    **Thread-per-Connection vs. Coroutine-per-Connection**
  |
  style: {
    stroke-width: 0
    fill: transparent
    font-size: 14
  }
}

# ========== THREAD-PER-CONNECTION (BLOCKING I/O) ==========
thread_approach: "❌ Thread-per-Connection Model" {
  style: {
    stroke: "#c0392b"
    stroke-width: 3
    fill: "#fadbd8"
    border-radius: 8
  }
  
  direction: right
  
  thread_diagram: {
    direction: down
    style.fill: transparent
    
    t_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      t1: "Thread 1" {
        shape: rectangle
        style.fill: "#e74c3c"
        style.font-color: white
        width: 80
      }
      t2: "Thread 2" {
        shape: rectangle
        style.fill: "#e74c3c"
        style.font-color: white
        width: 80
      }
      t3: "Thread 3" {
        shape: rectangle
        style.fill: "#e74c3c"
        style.font-color: white
        width: 80
      }
      tdots: "..." {
        shape: text
        style.font-size: 24
      }
      t10k: "Thread 10k" {
        shape: rectangle
        style.fill: "#e74c3c"
        style.font-color: white
        width: 100
      }
    }
    
    c_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      c1: "Conn 1" { shape: circle; style.fill: "#f5b7b1" }
      c2: "Conn 2" { shape: circle; style.fill: "#f5b7b1" }
      c3: "Conn 3" { shape: circle; style.fill: "#f5b7b1" }
      cdots: "..." { shape: text; style.font-size: 24 }
      c10k: "Conn 10k" { shape: circle; style.fill: "#f5b7b1" }
    }
    
    t_row.t1 -> c_row.c1: "1:1"
    t_row.t2 -> c_row.c2
    t_row.t3 -> c_row.c3
    t_row.t10k -> c_row.c10k
  }

  thread_stack_detail: "Per-Thread Overhead (OS Level)" {
    direction: down
    stack_struct: {
      shape: class
      label: "OS Thread (pthread)"
      +stack_size: "8 MB (Default)"
      +kernel_obj: "task_struct"
      +overhead: "Kernel Context"
      +switching: "Preemptive (1.5us)"
    }
    
    visual: {
      direction: down
      guard: "Guard Page (4KB)" {
        style.fill: "#922b21"; style.font-color: white; height: 20
      }
      space: "Stack Space (8MB)" {
        style.fill: "#f1948a"; height: 100
      }
      guard -> space
    }
  }
}

# ========== COROUTINE-PER-CONNECTION (ASYNC I/O) ==========
coro_approach: "✅ Coroutine-per-Connection Model" {
  style: {
    stroke: "#27ae60"
    stroke-width: 3
    fill: "#d5f5e3"
    border-radius: 8
  }
  
  direction: right

  runtime: {
    direction: down
    style.fill: transparent
    
    threads: "OS Thread Pool (N=Cores)" {
      direction: right
      style.fill: "#82e0aa"
      w1: "Worker 1"; w2: "Worker 2"; w3: "Worker 3"
      w1.style.fill: "#27ae60"; w1.style.font-color: white
      w2.style.fill: "#27ae60"; w2.style.font-color: white
      w3.style.fill: "#27ae60"; w3.style.font-color: white
    }
    
    scheduler: "User-Space Scheduler (M:N)" {
      shape: hexagon
      style.fill: "#1abc9c"; style.font-color: white
    }
    
    coros: "10,000+ Coroutines" {
      direction: right
      style.fill: "#abebc6"
      co1: "Co 1"; co2: "Co 2"; co3: "Co 3"; co_n: "Co 10k"
      co1.shape: circle; co2.shape: circle; co3.shape: circle; co_n.shape: circle
      co1.style.fill: "#58d68d"
    }

    threads -> scheduler: "M tasks"
    scheduler -> coros: "Schedule"
  }

  coro_stack_detail: "Per-Coroutine (User Level)" {
    direction: down
    coro_struct: {
      shape: class
      label: "User-Space Stack"
      +min_size: "2 KB (Go) / 4 KB"
      +growth: "Segmented/Dynamic"
      +switching: "Cooperative (50ns)"
      +managed: "By Runtime"
    }
    
    visual: {
      direction: down
      c_space: "Coro Stack (4KB)" {
        style.fill: "#82e0aa"; height: 40
      }
    }
  }
}

# ========== RESOURCE COMPARISON TABLE ==========
comparison_table: "📊 10,000 Connection Resource Comparison" {
  style: {
    fill: "#fef9e7"
    stroke: "#f39c12"
    stroke-width: 2
  }
  
  direction: down
  
  header: "" {
    direction: right
    style.fill: transparent; style.stroke: transparent
    h1: "Metric" { width: 150; style.fill: "#f39c12"; style.font-color: white; style.bold: true }
    h2: "Threads" { width: 150; style.fill: "#e74c3c"; style.font-color: white; style.bold: true }
    h3: "Coroutines" { width: 150; style.fill: "#27ae60"; style.font-color: white; style.bold: true }
  }
  
  row1: "" {
    direction: right
    style.fill: transparent; style.stroke: transparent
    r1: "Stack RAM" { width: 150; style.fill: "#fdebd0" }
    r2: "80 GB" { width: 150; style.fill: "#fadbd8"; style.bold: true; style.font-color: "#c0392b" }
    r3: "40 MB" { width: 150; style.fill: "#d5f5e3"; style.bold: true; style.font-color: "#1e8449" }
  }
  
  row2: "" {
    direction: right
    style.fill: transparent; style.stroke: transparent
    r1: "Context Switch" { width: 150; style.fill: "#fdebd0" }
    r2: "1500 ns" { width: 150; style.fill: "#fadbd8" }
    r3: "50 ns" { width: 150; style.fill: "#d5f5e3" }
  }

  row3: "" {
    direction: right
    style.fill: transparent; style.stroke: transparent
    r1: "Switch Mode" { width: 150; style.fill: "#fdebd0" }
    r2: "Kernel Trap" { width: 150; style.fill: "#fadbd8" }
    r3: "User Jump" { width: 150; style.fill: "#d5f5e3" }
  }
}

# ========== KEY INSIGHTS (FIXED BLOCK STRING) ==========
key_insight: "🔑 Key Scalability Insight" {
  shape: rectangle
  label: |'md
    ## Coroutines decouple Concurrency from Parallelism
    
    10,000 coroutines can run on just **4-8 OS threads**, keeping the CPU cache "hot" and preventing kernel scheduler thrashing.

    | Runtime Platform | Coroutine Implementation |
    |------------------|--------------------------|
    | Go               | Goroutines (M:N)         |
    | Rust             | Tokio/Async Tasks        |
    | Python           | Asyncio / Greenlets      |
    | Erlang           | BEAM Processes           |
    | Java (Loom)      | Virtual Threads          |
  '|
  style: {
    fill: "#eaf2f8"
    stroke: "#2980b9"
    stroke-width: 2
    border-radius: 8
  }
}

# Connections for Layout Flow
thread_approach -> comparison_table: "Compare"
coro_approach -> comparison_table: "Compare"
comparison_table -> key_insight: "Conclusion"

# Ensure vertical layout for the root containers
title_node -> thread_approach: {style.stroke: transparent}
thread_approach -> coro_approach: {style.stroke: transparent}
coro_approach -> comparison_table: {style.stroke: transparent}
comparison_table -> key_insight: {style.stroke: transparent}