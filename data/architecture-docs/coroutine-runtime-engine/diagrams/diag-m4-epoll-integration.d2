direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # epoll State Machine: Async Socket Read Lifecycle
| {near: top-center}
states: {
  direction: down
  init: {
    shape: circle
    label: "INIT"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
  }
  calling: {
    shape: rectangle
    label: "CALLING\nasync_read()"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    width: 140
  }
  checking: {
    shape: diamond
    label: "Data\nReady?"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    width: 120
    height: 80
  }
  reading_fast: {
    shape: rectangle
    label: "READING\n(recv syscall)\nFast Path"
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 140
  }
  registering: {
    shape: rectangle
    label: "REGISTERING\nepoll_ctl(EPOLL_CTL_ADD)\nfd + EPOLLIN"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    width: 180
  }
  yielding: {
    shape: rectangle
    label: "YIELDED\nCoroutine suspended\nState: BLOCKED"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    width: 160
  }
  waiting: {
    shape: rectangle
    label: "KERNEL WAIT\nThread runs other\ncoroutines"
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    style.stroke-width: 2
    width: 160
    style.stroke-dash: 4
  }
  event_fired: {
    shape: rectangle
    label: "EVENT FIRED\nNIC → DMA → TCP\nepoll_wait returns"
    style.fill: "#E1F5FE"
    style.stroke: "#03A9F4"
    style.stroke-width: 2
    width: 180
  }
  waking: {
    shape: rectangle
    label: "WAKING\nReactor finds waker\nMarks coroutine RUNNABLE"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.stroke-width: 2
    width: 180
  }
  resuming: {
    shape: rectangle
    label: "RESUMING\nScheduler picks\ncoroutine"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 160
  }
  reading_slow: {
    shape: rectangle
    label: "READING\n(recv syscall)\nData Available"
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 140
  }
  deregistering: {
    shape: rectangle
    label: "CLEANUP\nepoll_ctl(EPOLL_CTL_DEL)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    width: 180
  }
  returning: {
    shape: rectangle
    label: "RETURNING\nio::Result<usize>\nto caller"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    width: 140
  }
  complete: {
    shape: circle
    label: "DONE"
    style.fill: "#4CAF50"
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    style.font-color: white
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: white
  style.stroke: "#CCCCCC"
  style.stroke-width: 1
  fast: {
    label: "Fast Path"
    style.fill: "#C8E6C9"
    width: 80
    height: 30
  }
  slow: {
    label: "Slow Path (Yield)"
    style.fill: "#FFEBEE"
    width: 80
    height: 30
  }
  kernel: {
    label: "Kernel/Async"
    style.fill: "#E1F5FE"
    width: 80
    height: 30
  }
}
init -> calling: "coroutine calls\nstream.read(&buf)"
calling -> checking: "check socket"
checking -> reading_fast: "Yes\nEAGAIN not set" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
reading_fast -> returning: "bytes read"
checking -> registering: "No\nEAGAIN returned" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 4
}
registering -> yielding: "waker stored\nin reactor map"
yielding -> waiting: "context switch\nto scheduler"
waiting -> event_fired: "packet arrives\n~10-1000μs later" {
  style.stroke: "#03A9F4"
  style.stroke-width: 2
  style.animated: true
}
event_fired -> waking: "epoll_wait returns\ntoken → waker lookup"
waking -> resuming: "wake() called\ncoroutine → run queue"
resuming -> reading_slow: "retry recv()"
reading_slow -> deregistering: "data received"
deregistering -> returning: "fd removed\nfrom epoll"
returning -> complete: "Result<usize>"
legend.fast -> legend.slow
legend.slow -> legend.kernel