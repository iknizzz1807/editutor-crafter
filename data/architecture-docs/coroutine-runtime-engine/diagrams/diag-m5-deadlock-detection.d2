direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "Deadlock Detection via Wait-For Graph"
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
title.near: top-center

row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  scenario: {
    direction: down
    label: "Deadlock Scenario"
    coro_a: {
      label: "Coroutine A (0x100)"
      shape: rectangle
      style.fill: "#FFE4E1"
      width: 160
      holds_a: {
        label: "holds Mutex M1"
        shape: rectangle
        style.fill: "#98FB98"
        width: 140
      }
      waits_b: {
        label: "waits for M2"
        shape: rectangle
        style.fill: "#FFB6C1"
        width: 140
      }
    }
    coro_b: {
      label: "Coroutine B (0x200)"
      shape: rectangle
      style.fill: "#E6E6FA"
      width: 160
      holds_b: {
        label: "holds Mutex M2"
        shape: rectangle
        style.fill: "#98FB98"
        width: 140
      }
      waits_a: {
        label: "waits for M1"
        shape: rectangle
        style.fill: "#FFB6C1"
        width: 140
      }
    }
  }
  wait_for_graph: {
    direction: down
    label: "Wait-For Graph"
    node_a: {
      label: "A"
      shape: circle
      style.fill: "#FFE4E1"
      width: 60
    }
    node_b: {
      label: "B"
      shape: circle
      style.fill: "#E6E6FA"
      width: 60
    }
    node_m1: {
      label: "M1"
      shape: diamond
      style.fill: "#98FB98"
      width: 50
    }
    node_m2: {
      label: "M2"
      shape: diamond
      style.fill: "#98FB98"
      width: 50
    }
    node_a -> node_m2: "waits" {
      style.stroke: "#FF6B6B"
      style.stroke-width: 2
    }
    node_m2 -> node_b: "held by" {
      style.stroke: "#4ECDC4"
      style.stroke-dash: 3
    }
    node_b -> node_m1: "waits" {
      style.stroke: "#FF6B6B"
      style.stroke-width: 2
    }
    node_m1 -> node_a: "held by" {
      style.stroke: "#4ECDC4"
      style.stroke-dash: 3
    }
    cycle_label: {
      shape: callout
      label: "⚠ CYCLE DETECTED"
      style: {
        font-color: "#FF0000"
        bold: true
        font-size: 16
        stroke: "#FF0000"
      }
    }
  }
}

row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  data_structures: {
    direction: down
    label: "Data Structures"
    waiting_for: {
      shape: sql_table
      label: "HashMap<CoroID, WaitTarget>"
      row0: "Key: CoroID | Value: MutexID"
      row1: "0x100 (A)   | 0x002 (M2)"
      row2: "0x200 (B)   | 0x001 (M1)"
      style.fill: "#F0F8FF"
    }
    held_by: {
      shape: sql_table
      label: "HashMap<MutexID, CoroID>"
      row0: "Key: MutexID | Value: CoroID"
      row1: "0x001 (M1)   | 0x100 (A)"
      row2: "0x002 (M2)   | 0x200 (B)"
      style.fill: "#F0FFF0"
    }
  }
  algorithm: {
    direction: down
    label: "Cycle Detection Algorithm"
    step1: {
      label: "Step 1: Record Wait"
      width: 340
      style.fill: "#FFF8DC"
      code: |'rust
  fn record_wait(&self, coro: ID, mutex: ID) {
    waiting_for.insert(coro, Mutex(mutex));
    if self.check_deadlock(coro) {
      panic!("Deadlock detected!");
    }
  }
      '|
    }
    step2: {
      label: "Step 2: Traverse Graph"
      width: 340
      style.fill: "#E6FFE6"
      code: |'rust
  fn check_deadlock(&self, start: ID) -> bool {
    let mut visited = HashSet::new();
    let mut current = start;
    loop {
      if visited.contains(current) { return true; }
      visited.insert(current);
      current = self.follow_edge(current)?;
    }
  }
      '|
    }
    step3: {
      label: "Step 3: Recovery"
      width: 340
      style.fill: "#FFE4E1"
      code: |'rust
  fn recover(&self, chain: Vec<ID>) {
    let victim = chain.choose_random();
    victim.abort();
    warn!("Aborted {} to resolve deadlock", victim);
  }
      '|
    }
  }
}

row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  integration: {
    direction: down
    label: "Integration with AsyncMutex"
    lock_flow: {
      label: "lock_with_detection() Flow"
      shape: rectangle
      width: 380
      style.fill: "#F5F5F5"
      code: |'rust
  pub async fn lock_with_detection(
    &self, det: &DeadlockDetector,
  ) -> Result<Guard, DeadlockError> {
    let cid = current_coroutine_id();
    if det.record_wait(cid, self.id) {
      return Err(DeadlockError { chain: det.get_chain(cid) });
    }
    let guard = self.lock().await;
    det.record_acquire(cid, self.id);
    Ok(guard)
  }
      '|
    }
  }
  recovery: {
    direction: down
    label: "Recovery Strategies"
    strat1: {
      label: "Strategy 1: Timeout + Retry"
      shape: rectangle
      width: 320
      style.fill: "#E0FFFF"
      code: |'rust
  match timeout(DUR, m.lock()).await {
    Ok(g) => { /* use g */ },
    Err(_) => {
      warn!("Timeout, backing off");
      release_all_held();
    }
  }
      '|
    }
    strat2: {
      label: "Strategy 2: Lock Ordering"
      shape: rectangle
      width: 320
      style.fill: "#FFE0FF"
      code: |'rust
  // Global ordering (Hierarchy):
  // M1 < M2 < M3
  async fn safe_op(m1: &M, m2: &M) {
    let g1 = m1.lock().await;
    let g2 = m2.lock().await;
  }
      '|
    }
  }
}

