direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Fix: Closed the title map and placed near at root level
title: Graceful Shutdown Sequence {
  style.font-size: 28
  style.bold: true
}
title.near: top-center

# States and Implementation Details
# Using direction: right inside containers to lay out internal steps horizontally (Rule F)
Running: {
  label: "STATE: RUNNING (runtime.c)"
  direction: right
  style.fill: "#E8F5E9"
  
  logic: {
    shape: sql_table
    label: "Execution Policy"
    00: "Accept New | ENABLED"
    01: "Spawn Coro | ENABLED"
    02: "IO Polling | ACTIVE"
  }
  
  code: |'c
    if (atomic_load(&shutdown_flag)) {
      transition(STATE_DRAINING);
    }
  '|
}

Draining: {
  label: "STATE: DRAINING"
  direction: right
  style.fill: "#FFF3CD"
  
  logic: {
    shape: sql_table
    label: "Drain Sequence"
    00: "Accept New | DISABLED"
    01: "Run Queues | FLUSHING"
    02: "Wakers | NOTIFY_EXIT"
  }
  
  code: |'c
    while (!queue_empty(q)) {
      task = queue_pop(q);
      execute(task);
    }
  '|
}

CancelingIO: {
  label: "STATE: CANCEL_IO"
  direction: right
  style.fill: "#E6E6FA"
  
  logic: {
    shape: sql_table
    label: "Resource Cleanup"
    00: "epoll_ctl | DEL_ALL"
    01: "timerfd | DISARM"
    02: "fds | CLOSE_PENDING"
  }
  
  code: |'c
    for (int i=0; i < nfds; i++) {
      epoll_ctl(efd, EPOLL_CTL_DEL, fds[i], NULL);
    }
  '|
}

Joining: {
  label: "STATE: JOIN_THREADS"
  direction: right
  style.fill: "#E0E0E0"
  
  logic: {
    shape: sql_table
    label: "Thread Sync"
    00: "Worker Array | JOIN_ALL"
    01: "Cleanup | FREE_HEAP"
    02: "Finalize | LOG_DONE"
  }
}

Done: {
  shape: circle
  label: "SHUTDOWN_COMPLETE"
  style.fill: "#F5F5F5"
  style.stroke-width: 3
}

# Main Evolution Paths
Running -> Draining: "shutdown() | invoke" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
Draining -> CancelingIO: "empty | signal" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
CancelingIO -> Joining: "io_clean | flag" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
Joining -> Done: "joined | exit" {
  style.stroke: "#424242"
  style.stroke-width: 2
}

# Error & Recovery Paths
Running -> Draining: "SIGINT | catch" {
  style.stroke-dash: 3
}
Draining -> Done: "TIMEOUT | force" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
  tooltip: "Hard exit if drain takes > 30s"
}
CancelingIO -> Joining: "IO_ERR | notify" {
  style.stroke-dash: 3
}
Joining -> Done: "FORCED_EXIT | kill" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}

# Metadata Legend
legend: {
  shape: sql_table
  label: "Operational Legend"
  near: bottom-right
  r1: "Solid Line | Nominal Sequence"
  r2: "Dashed Line | Error/Override Path"
  r3: "Code Blocks | Critical Path Logic"
}