direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Runtime Statistics Dashboard
  Real-time observability for coroutine runtime performance
| {near: top-center}
# Row 1: Core Metrics Overview
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  coroutines_panel: {
    direction: down
    label: "Coroutine States"
    state_chart: {
      shape: sql_table
      label: "Coroutine Counts (scheduler.rs)"
      runnable: "runnable: u64 | Ready to execute"
      running: "running: u64 | Currently on CPU"
      blocked: "blocked: u64 | Waiting on I/O/sync"
      finished: "finished: u64 | Completed"
      panicked: "panicked: u64 | Aborted with error"
    }
    health_indicator: {
      label: "Health Assessment"
      code: |'rust
        // Good: runnable ≈ num_workers * queue_depth
        // Warning: runnable > 10000 (scheduler pressure)
        // Critical: blocked >> runnable (I/O bottleneck)
        // Critical: panicked > 0 (investigate immediately)
      '|
      width: 320
    }
  }
  queues_panel: {
    direction: down
    label: "Queue Depths"
    queue_metrics: {
      shape: sql_table
      label: "Per-Thread Local Queues"
      t0: "worker-0 | depth: 47 | steals_in: 12"
      t1: "worker-1 | depth: 52 | steals_in: 8"
      t2: "worker-2 | depth: 23 | steals_in: 31"
      t3: "worker-3 | depth: 61 | steals_in: 5"
      global: "global_queue | depth: 0 | overflow target"
    }
    queue_code: {
      label: "Imbalance Detection"
      code: |'rust
        // Calculate Gini coefficient for load balance
        let variance = depths.iter()
          .map(|&d| (d - avg_depth).powi(2))
          .sum::<f64>() / n as f64;
        // variance > 100 → work-stealing not keeping up
        // max_depth - min_depth > 50 → investigate victim selection
      '|
      width: 340
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scheduler_panel: {
    direction: down
    label: "Scheduler Metrics"
    scheduler_stats: {
      shape: sql_table
      label: "Scheduling Statistics (RuntimeStats)"
      ctx_sw: "context_switches: u64 | Total yields"
      steals_ok: "steals_success: u64 | Work found"
      steals_fail: "steals_failed: u64 | Empty victim"
      preempt: "preemptions: u64 | Timer-forced yields"
      steal_rate: "steal_rate: f64 | success / (success + failed)"
    }
    scheduler_analysis: {
      label: "Performance Signals"
      code: |'rust
        // Steal rate < 30%: workload too uniform (good)
        // Steal rate > 70%: high contention, add workers
        // Preemptions / sec > 1000: CPU-bound coroutines
        // Preemptions / sec < 10: cooperative yielding OK
      '|
      width: 340
    }
  }
  io_panel: {
    direction: down
    label: "I/O & Blocking"
    io_stats: {
      shape: sql_table
      label: "I/O Metrics (reactor.rs)"
      epoll_calls: "epoll_wait_calls: u64 | Event polls"
      events_ready: "events_ready: u64 | FDs ready"
      io_wait_ns: "io_wait_ns: u64 | Time blocked on I/O"
      bytes_read: "bytes_read: u64 | Total inbound"
      bytes_written: "bytes_written: u64 | Total outbound"
    }
    io_analysis: {
      label: "I/O Health"
      code: |'rust
        // events_ready / epoll_wait_calls < 1.0: over-polling
        // io_wait_ns / uptime > 0.5: I/O bound workload
        // bytes_read >> bytes_written: download heavy
        // bytes_written >> bytes_read: upload heavy
      '|
      width: 340
    }
  }
}
# Row 3: Visualization - Time Series
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeseries: {
    direction: down
    label: "Time-Series Metrics (sampled every 100ms)"
    width: 600
    sample_data: {
      shape: sql_table
      label: "Recent Samples (circular buffer)"
      s0: "t=0.0s | runnable: 847 | blocked: 1203 | steal_ok: 45"
      s1: "t=0.1s | runnable: 892 | blocked: 1198 | steal_ok: 52"
      s2: "t=0.2s | runnable: 756 | blocked: 1289 | steal_ok: 38"
      s3: "t=0.3s | runnable: 901 | blocked: 1176 | steal_ok: 61"
      s4: "t=0.4s | runnable: 823 | blocked: 1245 | steal_ok: 47"
      s5: "t=0.5s | runnable: 867 | blocked: 1212 | steal_ok: 55"
    }
    trend_code: {
      label: "Trend Detection"
      code: |'rust
        // Spike: |current - avg| > 2 * stddev
        // Ramp: slope(runnable[-10..]) > threshold
        // Plateau: variance(last_100) < threshold
        // Correlate: runnable ∦ blocked suggests I/O bottleneck
      '|
      width: 560
    }
  }
  alerts: {
    direction: down
    label: "Alert Conditions"
    alert_table: {
      shape: sql_table
      label: "Predefined Alerts"
      a1: "queue_overflow | local depth > 1000"
      a2: "steal_starvation | steal_rate < 10% for 5s"
      a3: "preempt_storm | >5000 preempts/sec"
      a4: "io_lag | io_wait_ns > 90% of time"
      a5: "deadlock_suspected | blocked unchanging for 10s"
      a6: "memory_pressure | stacks > 80% of limit"
    }
    severity: {
      label: "Severity Levels"
      code: |'rust
        // INFO: transient, self-correcting
        // WARN: sustained anomaly, may need tuning
        // ERROR: functional impact, investigate now
        // CRITICAL: system degradation, immediate action
      '|
      width: 340
    }
  }
}
# Row 4: Diagnostic Tools
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  deadlock_panel: {
    direction: down
    label: "Deadlock Detection"
    wait_graph: {
      shape: sql_table
      label: "Wait-For Graph (DeadlockDetector)"
      waiting_for: "waiting_for: HashMap<CoroID, WaitTarget>"
      held_by: "held_by: HashMap<ResourceID, CoroID>"
      cycle_check: "cycle_check(): bool | DFS for cycles"
      chain: "get_chain(): Vec<CoroID> | Deadlocked coroutines"
    }
    deadlock_code: {
      label: "Detection Algorithm"
      code: |'rust
        // On each wait, check for cycle:
        // 1. Start from waiter, follow wait_for -> held_by
        // 2. If we return to start, cycle detected
        // 3. Report chain for debugging
        // Recovery: abort youngest coroutine in chain
      '|
      width: 340
    }
  }
  trace_panel: {
    direction: down
    label: "Execution Tracing"
    trace_config: {
      shape: sql_table
      label: "Trace Configuration"
      enabled: "trace_enabled: bool | Master switch"
      sample_rate: "sample_rate: f64 | 0.0-1.0"
      buffer_size: "buffer_size: usize | Events to retain"
      events: "events: Vec<TraceEvent> | Ring buffer"
    }
    trace_events: {
      label: "Event Types"
      code: |'rust
        enum TraceEvent {
          Spawn { coro_id, parent_id },
          Yield { coro_id, reason },
          Resume { coro_id, worker_id },
          Steal { from_worker, to_worker },
          Block { coro_id, resource },
          Wake { coro_id, resource },
          Preempt { coro_id, timeslice_ns },
        }
      '|
      width: 340
    }
  }
}
# Row 5: Export & Integration
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  export_panel: {
    direction: down
    label: "Export Formats"
    export_formats: {
      shape: sql_table
      label: "Output Options"
      prometheus: "prometheus | /metrics endpoint"
      json: "json | REST API snapshot"
      opentelemetry: "opentelemetry | Distributed traces"
      log: "structured_log | JSON lines to file"
    }
  }
  integration_panel: {
    direction: down
    label: "Production Integration"
    integration_code: {
      label: "Usage Pattern"
      code: |'rust
        // Initialize stats at runtime start
        let stats = Arc::new(RuntimeStats::new());
        // Expose via HTTP (async handler)
        scheduler.spawn(move |_| {
            let snapshot = stats.snapshot();
            serde_json::to_string(&snapshot).unwrap()
        });
        // Or push to Prometheus push gateway
        prometheus::register(Box::new(
            Gauge::new("coro_runnable", snapshot.runnable)
        ));
      '|
      width: 500
    }
  }
}
# Legend
legend: {
  near: bottom-right
  label: "Color Legend"
  good: {
    shape: rectangle
    style.fill: "#90EE90"
    label: "Healthy range"
  }
  warn: {
    shape: rectangle
    style.fill: "#FFD700"
    label: "Needs attention"
  }
  critical: {
    shape: rectangle
    style.fill: "#FF6B6B"
    label: "Immediate action"
  }
}
# Arrows showing data flow
row1.coroutines_panel -> row3.timeseries: "state counts"
row1.queues_panel -> row3.alerts: "depth alerts"
row2.scheduler_panel -> row3.alerts: "steal/preempt alerts"
row2.io_panel -> row3.alerts: "I/O lag alerts"
row3.alerts -> row4.deadlock_panel: "deadlock suspected"
row3.timeseries -> row5.export_panel: "snapshot"
row4.trace_panel -> row5.export_panel: "events"