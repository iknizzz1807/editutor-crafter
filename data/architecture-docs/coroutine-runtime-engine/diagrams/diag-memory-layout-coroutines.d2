direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT TITLE ---
header: {
  label: "Memory Layout: 10,000 Coroutines (coroutine-runtime)"
  sub_label: "Total Memory Usage: ~649.1 MB | Cache Line Optimization Analysis"
  style.font-size: 24
  style.bold: true
  style.stroke: transparent
  style.fill: transparent
}

# --- ROW 1: EXECUTIVE SUMMARY ---
row_summary: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  mem_stats: {
    shape: sql_table
    label: "Memory Utilization Summary"
    row1: "Stacks (mmap) | 640.0 MB | 98.60%"
    row2: "Coroutine Structs | 6.4 MB | 1.00%"
    row3: "Scheduler Queues | 1.6 MB | 0.25%"
    row4: "Metadata / Alignment | 1.1 MB | 0.15%"
    total_mem: "TOTAL | ~649.1 MB | 100.0%"
    style.fill: "#E8F5E9"
  }

  cache_efficiency: {
    shape: sql_table
    label: "Cache Hierarchy Impact"
    l1_data: "HOT: Saved Context (64B) | 1 Cache Line"
    l2_data: "WARM: Run Queue Head (64B) | 1 Cache Line"
    l3_data: "COLD: Stack Data (64KB) | Page Fault Risk"
    tlb_stat: "TLB Pressure: 160k Pages | High"
    style.fill: "#FFF3E0"
  }
}

# --- ROW 2: HEAP REGION (COROUTINES) ---
row_heap: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  heap_details: {
    direction: down
    label: "Heap Region: Coroutine Registry"
    style.fill: "#E3F2FD"

    coro_struct: {
      shape: sql_table
      label: "struct Coroutine (coroutine.rs)"
      f0: "0x00 | u64          | id // Unique identifier"
      f1: "0x08 | CoroState    | state // 1 byte + 7 padding"
      f2: "0x10 | Context       | regs[6] // 48B saved registers"
      f3: "0x40 | *mut u8       | rsp // Stack pointer"
      f4: "0x48 | *const u8     | rip // Instruction pointer"
      f5: "0x50 | *mut u8       | stack_ptr // Mapped base"
      f6: "0x58 | usize         | stack_size // Usually 64KB"
      f7: "0x60 | Box<dyn Fn>   | entry // Fat pointer (16B)"
      total_sz: "Total Size: 112 Bytes (Occupies 2 Cache Lines)"
      style.fill: "#BBDEFB"
    }

    heap_visual: {
      direction: right
      label: "Registry Array (Sequential Allocation)"
      c1: "Coroutine 0" {
        style.fill: "#90CAF9"
      }
      c2: "Coroutine 1" {
        style.fill: "#90CAF9"
      }
      dots_node: "..." {
        shape: rectangle
        style.stroke: transparent
      }
      cn: "Coroutine 9999" {
        style.fill: "#90CAF9"
      }
    }
  }
}

# --- ROW 3: STACK REGIONS ---
row_stacks: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  stacks_region: {
    direction: down
    label: "Virtual Memory: Stack Segments"
    style.fill: "#FCE4EC"

    stack_layout: {
      shape: sql_table
      label: "mmap Segment (68 KB per task)"
      guard_page: "0x0000 | 4 KB | GUARD PAGE (PROT_NONE)"
      unused_mem: "0x1000 | 56 KB | Reserved / Unused"
      active_data: "0xF000 | 8 KB | Active Frames (HOT)"
      addr_limit: "0x11000| 0 B | Initial RSP (grows down)"
      total_vmem: "Total Virtual Memory: 680 MB for 10k tasks"
      style.fill: "#F8BBD9"
    }

    stack_visual: {
      direction: right
      label: "TLB View: Segmented Addressing"
      s0: {
        direction: down
        g: "GUARD" { style.fill: "#EF5350"; style.font-color: white }
        d: "STACK 0" { style.fill: "#F8BBD9" }
      }
      s1: {
        direction: down
        g: "GUARD" { style.fill: "#EF5350"; style.font-color: white }
        d: "STACK 1" { style.fill: "#F8BBD9" }
      }
      dots_visual: "..." { shape: rectangle; style.stroke: transparent }
      sn: {
        direction: down
        g: "GUARD" { style.fill: "#EF5350"; style.font-color: white }
        d: "STACK 9999" { style.fill: "#F8BBD9" }
      }
    }
  }
}

# --- ROW 4: SCHEDULER QUEUES ---
row_scheduler: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  queues_region: {
    direction: down
    label: "Scheduler Memory: Work Stealing Queues"
    style.fill: "#F3E5F5"

    global_q: {
      shape: sql_table
      label: "Global Queue (Locked VecDeque)"
      f0: "0x00 | MutexState   | lock // 40B"
      f1: "0x28 | usize        | cap // 8B"
      f2: "0x30 | *mut Coro    | ptr // 8B"
      f3: "0x38 | usize        | len // 8B"
      header_sz: "Total Header: 64 Bytes (Fits 1 Cache Line)"
      style.fill: "#E1BEE7"
    }

    locals: {
      direction: right
      label: "Local Worker Queues (Cache-Aligned)"
      
      q0: {
        shape: sql_table
        label: "Worker 0 Queue"
        q_bot: "0x00 | AtomicIsize | bottom // 8B"
        pad1: "0x08 | [u8; 56]     | _pad1 // 56B"
        q_top: "0x40 | AtomicIsize | top // 8B"
        pad2: "0x48 | [u8; 56]     | _pad2 // 56B"
        buf: "0x80 | AtomicPtr   | buffer // 8B"
        total_align: "Total: 136B (Aligned to 3 CL)"
        style.fill: "#D1C4E9"
      }

      q_dots: "Worker 1..N" {
        shape: rectangle
        style.stroke: transparent
      }

      q7: {
        shape: sql_table
        label: "Worker 7 Queue"
        q_bot_7: "0x00 | AtomicIsize | bottom"
        pad_7: "..."
        sz_7: "136 Bytes"
        style.fill: "#D1C4E9"
      }
    }
  }
}

# --- ROW 5: ANALYSIS & SCALING ---
row_analysis: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  path_analysis: {
    direction: down
    label: "Runtime Critical Path Analysis"
    style.fill: "#FFFDE7"

    hot_path: {
      shape: class
      label: "Context Switch (HOT)"
      -registers: "48 Bytes"
      -state_check: "1 Byte"
      -cache_lines: "1 touched"
      +resume(): "void"
    }

    cold_path: {
      shape: class
      label: "Stack Access (COLD)"
      -page_walk: "Required"
      -l3_miss: "Likely"
      -tlb_miss: "Frequent"
      +run_task_logic(): "void"
    }
  }

  scaling_logic: {
    direction: down
    label: "Scaling Scenarios"
    style.fill: "#E0F2F1"

    scale_table: {
      shape: sql_table
      label: "Density Matrix"
      k10: "10k Tasks | 649 MB | L3 Friendly"
      k100: "100k Tasks | 6.5 GB | Server RAM"
      m1: "1M Tasks | 65.0 GB | NUMA Required"
      scaling_note: "Optimization: Use 16KB Stacks to 4x density"
    }
    
    tlb_analysis: {
      label: "TLB Pressure Note"
      content: |md
        - 10k Stacks = 160k virtual pages
        - Modern CPU TLB (L2): ~1500 entries
        - Suggestion: Use **2MB Huge Pages** to reduce page table depth
      |
    }
  }
}

# --- LEGEND ---
legend: {
  label: "Performance Legend"
  direction: right
  hot: "HOT: L1/L2 Cache" { style.fill: "#C8E6C9" }
  warm: "WARM: L3 Cache" { style.fill: "#FFF9C4" }
  cold: "COLD: DRAM/MMU" { style.fill: "#FFCDD2" }
}
legend.near: bottom-right