layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    pad: 20
  }
}

title: {
  shape: text
  label: ||md
    # Coroutine Control Block (CCB) Memory Layout
    ### Total Size: 120 Bytes | 2x Cache Lines (64B)
    *Technical Specification: v1.0.4*
  ||
  near: top-center
}

# -----------------------------------------------------------------------------------------
# PHYSICAL MEMORY MAP (Byte-aligned Grid)
# -----------------------------------------------------------------------------------------
memory_map: {
  grid-columns: 1
  grid-gap: 0
  
  header: {
    grid-columns: 4
    grid-gap: 0
    style: {
      bold: true
      fill: "#E1BEE7" # Purple (Header)
      font-size: 16
    }
    o: "Offset (Hex)"
    f: "Field Name"
    s: "Size (Bytes)"
    d: "Description"
  }

  cl0_separator: "--- PHYSICAL BOUNDARY: CACHE LINE 0 (0x00) ---" {
    style: {
      stroke: "#2196F3"
      stroke-width: 4
      stroke-dash: 0
      font-color: "#1976D2"
      bold: true
    }
  }

  row_0: {
    grid-columns: 4
    grid-gap: 0
    off: "0x00"
    name: "coro_id"
    size: "8B"
    desc: "Unique U64 ID"
    style.fill: "#BBDEFB" # Blue (Data)
  }

  row_1: {
    grid-columns: 4
    grid-gap: 0
    off: "0x08"
    name: "state"
    size: "1B"
    desc: "Atomic State Enum"
    style.fill: "#C8E6C9" # Green (Free/State)
  }

  row_2: {
    grid-columns: 4
    grid-gap: 0
    off: "0x09"
    name: "padding"
    size: "7B"
    desc: "Alignment Padding (Cold)"
    style.fill: "#E0E0E0" # Gray (Padding)
  }

  row_3: {
    grid-columns: 4
    grid-gap: 0
    off: "0x10"
    name: "context.regs[0-5]"
    size: "48B"
    desc: "Saved GPRs (rbx, rbp, r12-r15)"
    style: {
      fill: "#FFCDD2" # Red (Hot Data)
      stroke-width: 2
      bold: true
    }
  }

  cl1_separator: "--- PHYSICAL BOUNDARY: CACHE LINE 1 (0x40 / 64B) ---" {
    style: {
      stroke: "#FF9800"
      stroke-width: 4
      stroke-dash: 5
      font-color: "#E65100"
      bold: true
    }
  }

  row_4: {
    grid-columns: 4
    grid-gap: 0
    off: "0x40"
    name: "context.rsp/rip"
    size: "16B"
    desc: "Stack & Instruction Pointers"
    style: {
      fill: "#FFCDD2" # Red (Hot Data)
      bold: true
    }
  }

  row_5: {
    grid-columns: 4
    grid-gap: 0
    off: "0x50"
    name: "stack_ptr"
    size: "8B"
    desc: "*mut u8 (Memory Base)"
    style.fill: "#FFE0B2" # Orange (Pointer)
  }

  row_6: {
    grid-columns: 4
    grid-gap: 0
    off: "0x58"
    name: "stack_size"
    size: "8B"
    desc: "usize (Stack Depth)"
    style.fill: "#BBDEFB" # Blue (Data)
  }

  row_7: {
    grid-columns: 4
    grid-gap: 0
    off: "0x60"
    name: "layout"
    size: "8B"
    desc: "alloc::Layout Metadata"
    style.fill: "#BBDEFB" # Blue (Data)
  }

  row_8: {
    grid-columns: 4
    grid-gap: 0
    off: "0x68"
    name: "entry_fn"
    size: "16B"
    desc: "Boxed FnOnce Closure"
    style.fill: "#E1BEE7" # Purple (Header/Object)
  }

  footer_separator: "--- END OF STRUCTURE (0x78 / 120B) ---" {
    style: {
      stroke: "#9E9E9E"
      stroke-width: 2
      stroke-dash: 2
      font-color: "#616161"
    }
  }
}

# -----------------------------------------------------------------------------------------
# TECHNICAL SPECIFICATIONS
# -----------------------------------------------------------------------------------------
specs: {
  near: center-right
  
  hot_path_analysis: {
    label: ||md
      ### 🔥 Hot Path (Context Switch)
      | Field | Action | Cost (Cycles) |
      | :--- | :--- | :--- |
      | `context.regs` | Load/Store | 12-18 |
      | `context.rsp` | Write | 2 |
      | `context.rip` | Jump | 1-3 |
      | `state` | Atomic CAS | 5-10 |
    ||
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      border-radius: 4
    }
  }

  cache_line_notes: {
    label: ||md
      ### ⚠️ Cache Optimization Note
      **Line Split Detected:** The `context` structure spans 
      across `CL0` and `CL1`.
      - `0x10 - 0x3F`: 48 bytes in CL0
      - `0x40 - 0x4F`: 16 bytes in CL1
      *Impact:* A full context switch requires 2 cache line fetches.
      *Recommendation:* Re-order `coro_id` and `stack_size` to cold-storage or 
      ensure 64B alignment of the CCB start address.
    ||
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      border-radius: 4
    }
  }
}

# -----------------------------------------------------------------------------------------
# ALIGNMENT VERIFICATION
# -----------------------------------------------------------------------------------------
verif: {
  near: bottom-center
  label: ||md
    ### Alignment Validation Table
    | Field | Type | Offset | Alignment | Status |
    | :--- | :--- | :--- | :--- | :--- |
    | `coro_id` | `u64` | 0x00 | 8B | ✅ |
    | `state` | `AtomicU8` | 0x08 | 1B | ✅ |
    | `padding` | `[u8;7]` | 0x09 | 1B | ✅ |
    | `context` | `struct` | 0x10 | 16B | ✅ |
    | `entry_fn` | `Box<T>` | 0x68 | 8B | ✅ |
  ||
  style: {
    fill: "#F1F8E9"
    stroke: "#33691E"
    border-radius: 4
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-left
  grid-columns: 2
  grid-gap: 5
  
  data: "Data (u64/usize)" { style.fill: "#BBDEFB" }
  state: "State/Control" { style.fill: "#C8E6C9" }
  hot: "Hot Path (Regs)" { style.fill: "#FFCDD2" }
  ptr: "Pointers (*mut)" { style.fill: "#FFE0B2" }
  pad: "Padding" { style.fill: "#E0E0E0" }
  obj: "Header/Heap Objects" { style.fill: "#E1BEE7" }
}

# -----------------------------------------------------------------------------------------
# RELATIONSHIPS
# -----------------------------------------------------------------------------------------
memory_map -> specs.hot_path_analysis: "Access Pattern" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    animated: true
  }
}
memory_map -> verif: "Validates" {
  style.stroke-dash: 3
}
specs.cache_line_notes -> memory_map.cl1_separator: "Critical Split Path" {
  style: {
    stroke: "#EF6C00"
    stroke-width: 2
  }
}