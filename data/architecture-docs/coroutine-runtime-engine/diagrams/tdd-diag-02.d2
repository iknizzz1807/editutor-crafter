Field_Names: {
  grid-rows: 8
  grid-gap: 0
  Field_rbx: {
    label: "regs[0]"
    shape: rectangle
    style: {
      fill: "${colors.register}"
      stroke: "#1D4ED8"
      font-color: white
      bold: true
    }
    width: 100
  }
  Field_rbp: {
    label: "regs[1]"
    shape: rectangle
