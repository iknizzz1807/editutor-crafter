direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    register: "#3B82F6"
    pointer: "#F59E0B"
    offset: "#6B7280"
    cache-line: "#10B981"
  }
}

title: |md
  # Context Struct Register Mapping
  x86-64 System V ABI — 64 bytes (1 cache line)
| {near: top-center}

Context_Struct: {
  label: "Context {\l  regs: [usize; 6],\l  rsp: *mut u8,\l  rip: *const u8,\l}"
  shape: rectangle
  style: {
    fill: "${colors.header}"
    stroke: "#7C3AED"
    font-color: white
    bold: true
  }
}

Memory_Layout: {
  grid-rows: 8
  grid-gap: 0
  Offset_0x00: {
    label: |md
      **Offset 0x00**
      8 bytes
    |
    shape: rectangle
    style: {
      fill: "${colors.offset}"
      stroke: "#4B5563"
      font-color: white
    }
    width: 120
  }
