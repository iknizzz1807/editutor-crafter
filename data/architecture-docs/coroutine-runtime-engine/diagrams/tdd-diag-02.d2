Memory_Layout -> Field_Names: {style.stroke: transparent}
Field_Names -> x86_64_Registers: {style.stroke: transparent}
x86_64_Registers -> Assembly_Constants: {style.stroke: transparent}

Alignment_Verification: {
  label: ||md
    ## Alignment Verification
    | Property | Value | Status |
    |----------|-------|--------|
    | Struct Size | 64 bytes | ✅ 1 cache line |
    | Struct Align | 8 bytes | ✅ usize aligned |
    | Field Size | 8 bytes each | ✅ usize on 64-bit |
    | Total Fields | 8 fields | ✅ 6 regs + rsp + rip |
  ||
  shape: rectangle
  style: {
    fill: "#ECFDF5"
    stroke: "${colors.cache-line}"
    stroke-width: 3
  }
}

Cache_Line_Boundary: {
  label: |md
    **Cache Line: 64 bytes**
    Single L1 fetch saves/restores entire context
  |
  shape: rectangle
  style: {
    fill: "${colors.cache-line}"
    font-color: white
    bold: true
  }
  width: 600
}

Caller_Saved_Note: {
  label: ||md
    ### Caller-Saved Registers (NOT saved)
    These are assumed garbage across context switch:
    `rax`, `rcx`, `rdx`, `rsi`, `rdi`, `r8`-`r11`
    Per x86-64 ABI: caller must preserve if needed
  ||
  shape: rectangle
  style: {
    fill: "#FEF3C7"
    stroke: "#F59E0B"
  }
}

Memory_Layout -> Alignment_Verification: {style.stroke-dash: 3}
Alignment_Verification -> Cache_Line_Boundary: {style.stroke: "${colors.cache-line}"}
Cache_Line_Boundary -> Caller_Saved_Note: {style.stroke-dash: 3}