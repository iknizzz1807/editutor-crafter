vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Coroutine Stack Memory Layout
  ### 64KB Stack with Guard Page Protection
| {near: top-center}
# Memory region container
stack_memory: {
  style.fill: white
  style.stroke: "#333"
  style.stroke-width: 2
  # Usable stack area (60KB)
  usable: {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 1
    # Stack frames visualization
    frame_high: {
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      height: 60
      width: 280
      label: "Initial Stack Frame\n─────────────────────\nReturn Addr (8B)\nCoroutine Ptr (8B)"
    }
    frame_growth: {
      shape: text
      label: |md
        ↓ Stack grows downward ↓
        ┌─────────────────────┐
        │  Stack Frame N      │
        ├─────────────────────┤
        │  Stack Frame N-1    │
        ├─────────────────────┤
        │  ...                │
        ├─────────────────────┤
        │  Stack Frame 1      │
        └─────────────────────┘
      |
      style.font-size: 11
      style.font: mono
    }
    # Free space indicator
    free_space: {
      style.fill: "#E8F5E9"
      style.stroke-dash: 3
      style.stroke: "#4CAF50"
      height: 120
      width: 280
      label: "Free Stack Space\n(~60KB available)\n\nMax depth before overflow:\n~60 function frames\n(1KB per frame avg)"
    }
  }
  # Guard page (4KB)
  guard: {
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 2
    height: 80
    width: 280
    label: |md
      **GUARD PAGE (4KB)**
      `PROT_NONE` — No access allowed
      Any read/write → **SIGSEGV**
      Stack overflow detected!
    |
  }
}
# Address annotations on left
addresses: {
  style.fill: transparent
  style.stroke: transparent
  addr_top: {
    shape: text
    label: |md
      
      0x7FFF_FFFF_FFFF
      (stack_top)
      
    |
    style.font: mono
    style.font-size: 10
  }
  addr_initial_rsp: {
    shape: text
    label: |md
      
      0x7FFF_FFFF_FFEF
      (initial rsp)
      rsp % 16 == 8 ✓
      
    |
    style.font: mono
    style.font-size: 10
  }
  addr_guard_top: {
    shape: text
    label: |md
      
      0x7FFF_FFFF_F000
      (guard page start)
      
    |
    style.font: mono
    style.font-size: 10
  }
  addr_base: {
    shape: text
    label: |md
      
      0x7FFF_FFFF_E000
      (stack.ptr)
      
    |
    style.font: mono
    style.font-size: 10
  }
}
# Size annotations on right
sizes: {
  style.fill: transparent
  style.stroke: transparent
  size_top: {
    shape: text
    label: |md
      **offset: +0x10000**
      (64KB from base)
    |
    style.font-size: 10
  }
  size_usable: {
    shape: text
    label: |md
      **60KB Usable**
      Stack frames grow
      downward from top
    |
    style.font-size: 10
  }
  size_guard: {
    shape: text
    label: |md
      **4KB Guard**
      `mprotect(PROT_NONE)`
      First page of allocation
    |
    style.font-size: 10
    style.font-color: "#C62828"
  }
  size_base: {
    shape: text
    label: |md
      **offset: +0x0000**
      (allocation base)
    |
    style.font-size: 10
  }
}
# Layout arrows
addresses.addr_top -> stack_memory.usable.frame_high: {style.stroke: transparent}
addresses.addr_initial_rsp -> stack_memory.usable.free_space: {style.stroke: transparent}
addresses.addr_guard_top -> stack_memory.guard: {style.stroke: transparent}
addresses.addr_base -> stack_memory.guard: {style.stroke: transparent}
sizes.size_top -> stack_memory.usable.frame_growth: {style.stroke: transparent}
sizes.size_usable -> stack_memory.usable.free_space: {style.stroke: transparent}
sizes.size_guard -> stack_memory.guard: {style.stroke: transparent}
sizes.size_base -> stack_memory.guard: {style.stroke: transparent}
# Code implementation panel
impl: {
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  style.stroke-width: 1
  code: |go
    // Stack allocation with guard page
    fn new(usable_size: usize) -> Self {
        let page_size = 4096;
        let total = usable_size + page_size;
        let layout = Layout::from_size_align(
            total, page_size
        ).unwrap();
        let ptr = alloc(layout);
        // Protect guard page (first page)
        mprotect(ptr, page_size, PROT_NONE);
        Stack { ptr, size: total, layout }
    }
    fn top(&self) -> *mut u8 {
        unsafe { self.ptr.add(self.size) }
    }
  |
}
# Key invariants panel
invariants: {
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
  inv_title: "Key Invariants" {
    style.bold: true
    style.underline: true
  }
  inv1: |md
    • `stack.ptr` points to **lowest** address
    • `stack.top()` = `ptr + size` (highest)
    • Stack grows **downward** (toward guard)
    • Initial `rsp = top - 16` (ABI aligned)
  |
  inv2: |md
    • Guard page at `ptr[0..4096)`
    • SIGSEGV handler checks fault address
    • If in guard range → stack overflow
    • Otherwise → re-raise SIGSEGV
  |
}
# Connections
stack_memory -> impl: "Implementation" {style.stroke-dash: 2}
stack_memory -> invariants: "Guarantees" {style.stroke-dash: 2}