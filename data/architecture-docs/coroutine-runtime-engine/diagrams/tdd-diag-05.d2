direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 50
  }
}

# --- HEADER SECTION ---
title: {
  label: ||md
    # Coroutine State Machine
    ## Technical Specification: Lifecycle & Transitions
    `Version: 1.0.4` | `Engine: ELK` | `Scope: Runtime Execution`
  ||
  near: top-center
  shape: text
  style: {
    stroke-width: 0
    font-size: 18
  }
}

# --- STATE DEFINITIONS ---
# states container for logical grouping
states: {
  Runnable: {
    shape: circle
    tooltip: "Task is in the global/local run queue, awaiting scheduler dispatch."
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 4
      font-color: "#1B5E20"
      bold: true
      shadow: true
    }
  }

  Running: {
    shape: circle
    tooltip: "Task is currently assigned to a CPU core/Worker thread."
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 4
      font-color: "#0D47A1"
      bold: true
      shadow: true
    }
  }

  Blocked: {
    shape: circle
    tooltip: "Task is suspended awaiting an external event or synchronization primitive."
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 4
      font-color: "#E65100"
      bold: true
      shadow: true
    }
  }

  Finished: {
    shape: circle
    tooltip: "Terminal state: Normal return. Resources scheduled for drop."
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 4
      font-color: "#4A148C"
      bold: true
      double-border: true
    }
  }

  Panicked: {
    shape: circle
    tooltip: "Terminal state: Uncaught exception. Unwinding stack."
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 4
      font-color: "#B71C1C"
      bold: true
      double-border: true
    }
  }
}

# --- INITIAL ENTRY ---
initial: {
  shape: circle
  style: {
    fill: "#000000"
    stroke: "#333333"
  }
  width: 25
  height: 25
}

initial -> states.Runnable: "Coroutine::spawn()" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    bold: true
    animated: true
  }
}

# --- VALID TRANSITIONS ---

states.Runnable -> states.Running: "Scheduler::resume()" {
  label: "Context Switch\n(Load Stack)"
  style: {
    stroke: "#1565C0"
    stroke-width: 4
    animated: true
  }
}

states.Running -> states.Runnable: "yield_now()" {
  label: "Preemption /\nVoluntary Yield"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    stroke-dash: 3
  }
}

states.Running -> states.Blocked: "poll() == Pending" {
  label: "Async Await\n(Register Waker)"
  style: {
    stroke: "#EF6C00"
    stroke-width: 2
    stroke-dash: 5
  }
}

states.Blocked -> states.Runnable: "Waker::wake()" {
  label: "Event Notified\n(Enqueue Task)"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

states.Running -> states.Finished: "return Result<T>" {
  label: "Normal exit"
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}

states.Running -> states.Panicked: "panic!()" {
  label: "Abort Process"
  style: {
    stroke: "#C62828"
    stroke-width: 4
  }
}

# --- DOCUMENTATION OVERLAYS ---

legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
    border-radius: 10
  }
  title: "Transition Manifest" {
    style.bold: true
  }
  t1: "1. resume() - Context switch to coroutine stack"
  t2: "2. yield_now() - Return control to scheduler"
  t3: "3. await I/O - Suspended, waker stored in reactor"
  t4: "4. I/O ready - Reactor wakes task into Runnable queue"
  t5: "5. return - Final cleanup and dropping futures"
  t6: "6. panic! - Propagation of uncaught unwinding"
}

illegal_flows: {
  near: bottom-left
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-dash: 5
    border-radius: 10
  }
  header: "FATAL / ILLEGAL FLOWS" {
    style: {
      bold: true
      font-color: "#B71C1C"
      font-size: 14
    }
  }
  i1: "Runnable → Finished (ILLEGAL: Must execute at least 1 poll)"
  i2: "Runnable → Panicked (ILLEGAL: Panic occurs during execution)"
  i3: "Finished → * (ILLEGAL: Terminal state is immutable)"
  i4: "Panicked → * (ILLEGAL: Dropped task cannot resume)"
  i5: "Blocked → Running (ILLEGAL: Must be re-queued in Runnable first)"
}

state_invariants: {
  near: top-right
  style: {
    fill: "#F1F8E9"
    stroke: "#2E7D32"
    border-radius: 10
  }
  header: "State Invariants" {
    style.bold: true
  }
  inv1: "Runnable: Task is present in LIFO/FIFO run-queue"
  inv2: "Running: Associated with exactly one OS Thread/Worker"
  inv3: "Blocked: Pointer registered in Reactor/Epoll instance"
  inv4: "Finished: Memory deallocated or moved to join-handle"
  inv5: "Panicked: Stack unwound, lock poisoning active"
}

function_ownership: {
  near: bottom-center
  style: {
    fill: "#E1F5FE"
    stroke: "#0288D1"
    border-radius: 10
  }
  header: "Function Reference" {
    style.bold: true
  }
  f1: "tokio::spawn() -> Runnable"
  f2: "Runtime::enter() -> Running"
  f3: "Future::poll() -> Blocked | Finished"
  f4: "std::panic::catch_unwind() -> Panicked"
}

terminal_logic: {
  label: ||md
    ### Resource Management
    **Terminal States (Finished/Panicked):**
    - All local variables are dropped in reverse order.
    - If a `JoinHandle` exists, result is propagated.
    - Memory is reclaimed by the slab allocator.
  ||
  near: bottom-right
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font-size: 11
  }
}

# Terminal status styling override
states.Finished.style.stroke-dash: 0
states.Panicked.style.stroke-dash: 0