vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
User Code
Coroutine
Stack
Context
Memory
User Code."1. Call Coroutine::spawn(|f|)"
User Code.t1 -> Coroutine.t1: "spawn<F>(f: FnOnce)"
Coroutine.t1 -> Memory.t1: "Allocate Coroutine struct (~112 bytes)"
Memory.t1 -> Coroutine.t1: "coroutine_ptr"
Coroutine.t1 -> Stack.t1: "Stack::new_with_guard(64KB)"
Stack.t1 -> Memory.t1: "alloc(68KB page-aligned)"
Memory.t1 -> Stack.t1: "ptr, size"
Stack.t1 -> Stack.t1: "mprotect(guard_page, PROT_NONE)"
Stack.t1 -> Coroutine.t1: "stack { ptr, size }"
Coroutine.t1 -> Coroutine.t1: "Generate ID via AtomicU64::fetch_add"
Coroutine.t1 -> Context.t1: "Context::new(stack.top(), coroutine_entry, coroutine_ptr)"
Context.t1 -> Stack.t2: "Set up initial stack frame"
Stack.t2: |md
  
  stack_top - 24: [alignment padding]
  stack_top - 16: [coroutine_ptr]  ← arg for trampoline
  stack_top - 8:  [coroutine_exit] ← fake return addr
  rsp = stack_top - 8
  rsp % 16 == 8 ✓ (ABI compliant)
  
|
Stack.t2 -> Context.t2: "Initialize registers"
Context.t2: |md
  
  regs[0..5] = [0; 6]  # rbx, rbp, r12-r15
  regs[2] = coroutine_ptr  # r12 = arg
  rsp = stack_top - 8
  rip = coroutine_entry_shim
  
|
Context.t2 -> Coroutine.t2: "context ready"
Coroutine.t2 -> Coroutine.t2: "state = Runnable"
Coroutine.t2 -> Coroutine.t2: "entry = Some(Box::new(f))"
Coroutine.t2 -> User Code.t2: "Box<Coroutine> { id, state=Runnable, context, stack, entry }"
User Code."Coroutine ready for scheduling"