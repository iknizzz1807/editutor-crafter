vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # M:N Work-Stealing Scheduler Architecture
| {near: top-center}
direction: right
classes: {
  worker: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  queue: {
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
    }
  }
  global_queue: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  coroutine: {
    shape: circle
    width: 40
    height: 40
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  steal_arrow: {
    style: {
      stroke: "#E53935"
      stroke-dash: 3
      animated: true
    }
  }
}
scheduler: Scheduler {
  style: {
    fill: "#FAFAFA"
    stroke: "#424242"
    stroke-width: 3
    double-border: true
  }
  global_queue: Global Queue {
    class: global_queue
    shape: queue
    width: 120
    height: 200
    g1: {class: coroutine}
    g2: {class: coroutine}
    g3: {class: coroutine}
  }
  workers: Worker Pool {
    direction: right
    style.fill: transparent
    worker0: Worker 0 {
      class: worker
      direction: right
      local0: Local Queue {
        class: queue
        shape: queue
        width: 80
        height: 140
        l0_1: {class: coroutine}
        l0_2: {class: coroutine}
        l0_3: {class: coroutine}
        l0_4: {class: coroutine}
      }
      thread0: Thread 0 {
        shape: hexagon
        style.fill: "#BBDEFB"
      }
    }
    worker1: Worker 1 {
      class: worker
      direction: right
      local1: Local Queue {
        class: queue
        shape: queue
        width: 80
        height: 140
        l1_1: {class: coroutine}
        l1_2: {class: coroutine}
      }
      thread1: Thread 1 {
        shape: hexagon
        style.fill: "#BBDEFB"
      }
    }
    worker2: Worker 2 {
      class: worker
      direction: right
      local2: Local Queue {
        class: queue
        shape: queue
        width: 80
        height: 140
        l2_1: {class: coroutine}
        l2_2: {class: coroutine}
        l2_3: {class: coroutine}
      }
      thread2: Thread 2 {
        shape: hexagon
        style.fill: "#BBDEFB"
      }
    }
    worker3: Worker 3 {
      class: worker
      direction: right
      local3: Local Queue {
        class: queue
        shape: queue
        width: 80
        height: 140
        l3_1: {class: coroutine}
      }
      thread3: Thread 3 {
        shape: hexagon
        style.fill: "#BBDEFB"
      }
    }
  }
}
scheduler.global_queue -> scheduler.workers.worker0.local0: batch\ngrab
scheduler.global_queue -> scheduler.workers.worker1.local0: batch\ngrab
scheduler.global_queue -> scheduler.workers.worker2.local0: batch\ngrab
scheduler.global_queue -> scheduler.workers.worker3.local0: batch\ngrab
scheduler.workers.worker0.thread0 -> scheduler.workers.worker0.local0: pop\n(LIFO)
scheduler.workers.worker1.thread1 -> scheduler.workers.worker1.local0: pop\n(LIFO)
scheduler.workers.worker2.thread2 -> scheduler.workers.worker2.local0: pop\n(LIFO)
scheduler.workers.worker3.thread3 -> scheduler.workers.worker3.local0: pop\n(LIFO)
scheduler.workers.worker0.local0 -> scheduler.workers.worker1.local1: steal\n(FIFO) {
  class: steal_arrow
}
scheduler.workers.worker1.local1 -> scheduler.workers.worker2.local2: steal\n(FIFO) {
  class: steal_arrow
}
scheduler.workers.worker2.local2 -> scheduler.workers.worker3.local3: steal\n(FIFO) {
  class: steal_arrow
}
scheduler.workers.worker3.local3 -> scheduler.workers.worker0.local0: steal\n(FIFO) {
  class: steal_arrow
}
legend: |md
  ## Scheduling Algorithm
  **Priority Order:**
  1. Pop from local queue (LIFO - cache hot)
  2. Batch fetch from global queue
  3. Steal from random victim (FIFO - fair)
  **Key Invariants:**
  - Each coroutine in exactly one queue
  - Local pop: LIFO (most recent = cache hot)
  - Remote steal: FIFO (oldest = fair)
  - Steal half on success
| {
  near: bottom-left
  style: {
    fill: "#ECEFF1"
    stroke: "#90A4AE"
  }
}
stats: |md
  ## Chase-Lev Queue
  - Lock-free SPSC for owner
  - Lock-free SPMC for stealers
  - `bottom` and `top` on separate
    cache lines (56B padding)
  **Time Complexity:**
  - Push: O(1)
  - Pop: O(1)
  - Steal: O(1)
| {
  near: bottom-right
  style: {
    fill: "#ECEFF1"
    stroke: "#90A4AE"
  }
}