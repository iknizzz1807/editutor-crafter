direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Chase-Lev Queue: Steal Operation Algorithm
  ## Implementation-Grade Work-Stealing Logic (FIFO from top)
  **State: Thief thread attempting to steal from Victim (Owner) thread**
| {near: top-center}

# -----------------------------------------------------------------------------
# STEP 1: ATOMIC SNAPSHOT
# -----------------------------------------------------------------------------
step1: {
  label: "STEP 1: INITIAL SNAPSHOT\nAtomic Load of 'top'"
  
  victim_queue: "Victim Circular Buffer (Size=2^n)" {
    style.fill: "#F8F9FA"
    style.stroke: "#BDC3C7"
    
    # Memory Layout with byte offsets and sizes
    buffer_layout: {
      grid-columns: 6
      grid-gap: 0
      
      off0: "0x00" { style.font-size: 10; style.fill: transparent; style.stroke-width: 0 }
      off1: "0x08" { style.font-size: 10; style.fill: transparent; style.stroke-width: 0 }
      off2: "0x10" { style.font-size: 10; style.fill: transparent; style.stroke-width: 0 }
      off3: "0x18" { style.font-size: 10; style.fill: transparent; style.stroke-width: 0 }
      off4: "0x20" { style.font-size: 10; style.fill: transparent; style.stroke-width: 0 }
      off5: "0x28" { style.font-size: 10; style.fill: transparent; style.stroke-width: 0 }

      slot0: "Task A" { style.fill: "#B5AFF6"; style.stroke: "#333"; tooltip: "Size: 8B" }
      slot1: "Task B" { style.fill: "#B5AFF6"; style.stroke: "#333"; tooltip: "Size: 8B" }
      slot2: "Task C" { style.fill: "#B5AFF6"; style.stroke: "#333"; tooltip: "Size: 8B" }
      slot3: "Task D" { style.fill: "#B5AFF6"; style.stroke: "#333"; tooltip: "Size: 8B" }
      slot4: "---" { style.fill: "#ECEFF1"; style.stroke: "#CFD8DC"; tooltip: "Empty" }
      slot5: "---" { style.fill: "#ECEFF1"; style.stroke: "#CFD8DC"; tooltip: "Empty" }
      
      sz0: "8B" { style.font-size: 8; style.stroke-width: 0 }
      sz1: "8B" { style.font-size: 8; style.stroke-width: 0 }
      sz2: "8B" { style.font-size: 8; style.stroke-width: 0 }
      sz3: "8B" { style.font-size: 8; style.stroke-width: 0 }
      sz4: "8B" { style.font-size: 8; style.stroke-width: 0 }
      sz5: "8B" { style.font-size: 8; style.stroke-width: 0 }
    }

    ptr_state: {
      t_ptr: "top = 0" {
        shape: person
        style.fill: "#D32F2F"
        style.font-color: white
      }
      b_ptr: "bottom = 4" {
        shape: person
        style.fill: "#388E3C"
        style.font-color: white
      }
      t_ptr -> buffer_layout.slot0: "Thief Target" { 
        style.stroke: "#D32F2F"
        style.stroke-width: 2 
      }
      b_ptr -> buffer_layout.slot4: "Owner Next" { 
        style.stroke: "#388E3C"
        style.stroke-dash: 3 
      }
    }
  }

  impl_code: |go
    // Thread: Thief
    // Operation: Steal()
    t := top.Load(Acquire) // Atomic load t = 0
  | {
    style.font: mono
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}

# -----------------------------------------------------------------------------
# STEP 2: MEMORY ORDERING
# -----------------------------------------------------------------------------
step2: {
  label: "STEP 2: SEQUENTIAL CONSISTENCY\nMemory Fence (LoadLoad | LoadStore)"
  
  fence: "MemoryBarrier(SeqCst)" {
    shape: diamond
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 4
    
    annotation: |md
      **CRITICAL INVARIANT**
      Prevents the thief from seeing 
      a 'bottom' value that is newer
      than the 'top' value it just read.
      Ensures: **t = Load(top)** happens BEFORE **b = Load(bottom)**.
    |
  }

  sync_flow: {
    shape: sequence_diagram
    thief: Thief Actor
    owner: Owner Actor
    
    thief -> thief: "Load(top) // t=0"
    thief -> thief: "[FENCE]"
    owner -> owner: "Push(Task E)"
    owner -> owner: "Store(bottom) // b=5"
    thief -> thief: "Load(bottom) // b=4 or 5"
  }
}

# -----------------------------------------------------------------------------
# STEP 3: LOGIC CHECK
# -----------------------------------------------------------------------------
step3: {
  label: "STEP 3: BOUNDS CHECK\nDetermine Queue Occupancy"
  
  logic_gate: "Is Queue Empty?" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    
    cmp_grid: {
      grid-columns: 3
      grid-gap: 10
      
      val_t: "t = 0" { style.fill: "#FFCDD2"; style.bold: true }
      op: " < " { shape: text }
      val_b: "b = 4" { style.fill: "#C8E6C9"; style.bold: true }
    }

    result: "Occupancy = b - t = 4\n**OK: Proceed to Read**" {
      style.font-color: "#2E7D32"
      style.bold: true
    }
  }

  impl_code: |go
    b := bottom.Load(Acquire)
    if t >= b {
        return Empty // Queue is empty or shrinking
    }
  | {
    style.font: mono
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
  }
}

# -----------------------------------------------------------------------------
# STEP 4: STAGING
# -----------------------------------------------------------------------------
step4: {
  label: "STEP 4: BUFFER ACCESS\nRead Task from Descriptor"
  
  read_target: "buffer[t % size]" {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    
    visual: {
      grid-columns: 2
      cell_ptr: "Index 0" { style.bold: true }
      cell_val: "**Task A**" { 
        style.fill: "#FF5722"
        style.font-color: white 
        style.double-border: true
      }
    }
  }

  warning_box: "CONCURRENCY ADVISORY" {
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    label: "Task A is copied to local register.\nIt remains in buffer until CAS succeeds."
  }
}

# -----------------------------------------------------------------------------
# STEP 5: ATOMIC COMMIT
# -----------------------------------------------------------------------------
step5: {
  label: "STEP 5: COMMIT CLAIM\nAtomic Compare-And-Swap"
  
  cas_engine: "Atomic CAS(top, 0, 1)" {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    
    states: {
      grid-columns: 3
      grid-gap: 30
      
      pre: "Expected: 0" { style.fill: "#FFCDD2" }
      arrow: "→" { shape: text }
      post: "New: 1" { 
        style.fill: "#C8E6C9"
        style.bold: true
      }
    }
    
    instruction: "LOCK CMPXCHG [top_ptr], reg_new" {
      style.font: mono
      style.font-size: 14
    }
  }

  outcomes: {
    grid-columns: 2
    success: "CAS == True" {
      label: "CLAIM SUCCESS\n**Task A Stolen**"
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      style.bold: true
    }
    failure: "CAS == False" {
      label: "RACE LOST\n**Return Empty**"
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
    }
  }
}

# Global Routing
step1 -> step2: "1. Top Snapshot"
step2 -> step3: "2. Load Fence"
step3 -> step4: "3. Bounds OK"
step4 -> step5: "4. Stage Data"

# Infrastructure Legend
legend: {
  near: bottom-left
  grid-columns: 1
  style.fill: "#FDFEFE"
  style.stroke: "#CCD1D1"
  
  l1: "🔴 Red: Volatile 'top' pointer (Atomic Load/CAS target)"
  l2: "🟢 Green: 'bottom' pointer (Owner-exclusive write)"
  l3: "🔵 Blue: Logic gates and occupancy validation"
  l4: "🟣 Purple: Memory buffer and task payload"
}

# Implementation Details
details: |md
  ### Implementation Notes
  - **Memory Layout**: Buffer size must be a power of two to allow `t & (size - 1)` masking.
  - **Memory Ordering**: Uses `Acquire` for loads and `Release` for stores. CAS is `SeqCst`.
  - **Owner Ops**: Owner performs `Push` (at `bottom`) and `Pop` (at `bottom-1`). 
  - **Thief Ops**: Thieves perform `Steal` (at `top`).
| {
  near: bottom-right
  style.fill: "#F4F6F6"
  style.font-size: 12
}