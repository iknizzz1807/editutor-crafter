direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Pop vs Steal Race Condition
  ## Work-Stealing Queue: 1 Item Corner Case
  ### Hardware-Level Memory & Synchronization Spec
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --- 1. MEMORY LAYOUT ---
# Intel Manual Quality: Byte offsets and alignment visualization
memory_view: "Physical Memory Layout (Deque Struct)" {
  style.stroke-dash: 3
  style.fill: "#F8F9FA"
  
  header_boundary: "Cache Line Boundary (64B Alignment)" {
    style.stroke: "#673AB7" # Purple Header
    style.stroke-dash: 5
    style.fill: transparent
  }

  layout: {
    shape: sql_table
    style.fill: white
    style.stroke: "#673AB7"
    
    # Offsets left, sizes right. Colors: Header=Purple, Data=Blue, Free=Green, Padding=Gray, Pointers=Orange
    "0x00": "buffer_ptr (64-bit)" {constraint: "Size: 8B"; style.fill: "#D1E9FF"}
    "0x08": "capacity (32-bit)" {constraint: "Size: 4B"; style.fill: "#D1E9FF"}
    "0x0C": "padding (32-bit)" {constraint: "Size: 4B"; style.fill: "#EEEEEE"}
    "0x10": "top (Atomic i64)" {constraint: "Size: 8B"; style.fill: "#FFE0B2"} # Pointer/Index: Orange
    "0x18": "bottom (Atomic i64)" {constraint: "Size: 8B"; style.fill: "#FFE0B2"} # Pointer/Index: Orange
    "0x20": "data_payload[0]" {constraint: "Size: 8B"; style.fill: "#C8E6C9"}
    "0x28": "data_payload[1...]" {constraint: "Size: 24B"; style.fill: "#E8F5E9"}
  }
  
  footer_annotation: |md
    **sizeof = 64 bytes (Single Cache Line)**
    **Initial State (1 Item):**
    - `top` = 0
    - `bottom` = 1
    - `count` = `bottom - top` = 1
  | {
    near: bottom-center
    shape: text
    style.font-size: 12
  }
}

# --- 2. ALGORITHM STATE DIAGRAMS ---
# Shows the changed elements in RED + BOLD as per TDD spec
logic_flow: "Concurrent Execution Logic" {
  
  owner_logic: "Owner Thread: pop()" {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    implementation_steps: |md
      1. `b = bottom.load(Relaxed)` // b=1
      2. **`bottom.store(b - 1, Relaxed)`** // **bottom=0**
      3. `atomic::fence(SeqCst)` 
      4. `t = top.load(Relaxed)` // t=0
      5. `if (t == b)` // Last item detection
      6. **Race: CAS top (0 -> 1)**
    |
  }

  thief_logic: "Thief Thread: steal()" {
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    implementation_steps: |md
      1. `t = top.load(Acquire)` // t=0
      2. `atomic::fence(SeqCst)`
      3. **`b = bottom.load(Acquire)`** // **b=0** (read after owner store)
      4. `if (t < b)` // No items left?
      5. **Race: CAS top (0 -> 1)**
    |
  }
}

# --- 3. SEQUENCE DIAGRAM ---
# Participants with exact types. Timing annotations included.
execution_timeline: {
  label: "Interleaved Race Sequence Diagram"
  shape: sequence_diagram
  
  owner: "Owner Thread (pop)" {
    shape: person
    style.stroke: "#1976D2"
  }
  thief: "Thief Thread (steal)" {
    shape: person
    style.stroke: "#C2185B"
  }
  
  atomic_top: "Atomic top" {
    style.fill: "#FFE0B2"
    style.double-border: true
  }
  atomic_bottom: "Atomic bottom" {
    style.fill: "#FFE0B2"
    style.double-border: true
  }

  owner.t1 -> atomic_bottom: "1. Load bottom (b=1)"
  owner.t2 -> atomic_bottom: "2. Store bottom=0 (tentative)" {
    style.stroke: red
    style.bold: true
    style.animated: true
  }
  
  # Timing: Fence ensuring SeqCst
  note over owner: "FENCE (SeqCst) ▼" {style.fill: "#FFF59D"}
  
  thief.t3 -> atomic_top: "3. Load top (t=0)"
  
  note over thief: "FENCE (SeqCst) ▲" {style.fill: "#FFF59D"}
  
  thief.t4 -> atomic_bottom: "4. Load bottom (b=0)"
  
  owner.t5 -> atomic_top: "5. Load top (t=0)"
  
  note over owner, thief: "CRITICAL SECTION: Race for Single Item" {
    style.stroke: red
    style.bold: true
  }
  
  owner.t6 -> atomic_top: "6. CAS(0 -> 1)?" {
    source-arrowhead: triangle
    style.stroke: orange
    style.stroke-width: 4
  }
  
  thief.t7 -> atomic_top: "7. CAS(0 -> 1)?" {
    source-arrowhead: triangle
    style.stroke: orange
    style.stroke-width: 4
  }
  
  note right of atomic_top: "HARDWARE BUS LOCK\nARBITRATION POINT" {
    style.fill: "#FFCDD2"
    style.font-color: "#B71C1C"
    style.bold: true
  }
}

# --- 4. RESOLUTION STATE ---
outcomes: "Conflict Resolution" {
  style.fill: "#F5F5F5"
  
  cas_winner: "CAS SUCCESS" {
    style.fill: "#C8E6C9"
    label: "**Winner gets ITEM_A**\nQueue state: **EMPTY**\ntop=1, bottom=0"
  }
  
  cas_loser: "CAS FAILURE" {
    style.fill: "#FFCDD2"
    label: "**Loser returns NULL**\nConflict detected\nAtomic state preserved"
  }
  
  cas_winner -> cas_loser: "Atomic Mutex" {
    style.stroke: red
    style.bold: true
    style.stroke-width: 3
    style.animated: true
  }
}

# --- 5. GLOBAL INVARIANTS ---
footer_notes: |md
  ### Safety Invariant
  Exactly one thread obtains the item. The combination of:
  1. **Owner's tentative decrement** of `bottom` (visible to thieves).
  2. **SeqCst Fences** preventing reordering of index loads relative to the tentative store.
  3. **Atomic CAS** on `top` providing the final linearizability point.
  
  If the Thief loads `bottom=0` before its CAS, it fails immediately. If the Owner wins the CAS, the Thief's CAS fails because the expected value `0` is now `1`.
| {
  near: bottom-center
  shape: text
  style.font-size: 14
}

# Structural Connections
memory_view -> logic_flow: "Process Specs" {style.stroke-width: 2}
logic_flow -> execution_timeline: "Race Vectors" {style.stroke-width: 2}
execution_timeline -> outcomes: "Finality" {style.stroke-width: 2}

# Global Styling
***.style.font: mono
(execution_timeline.owner -> execution_timeline.atomic_bottom)[*].style.stroke: "#1976D2"
(execution_timeline.thief -> execution_timeline.atomic_top)[*].style.stroke: "#C2185B"
(execution_timeline.owner -> execution_timeline.atomic_top)[*].style.stroke: "#1976D2"
(execution_timeline.thief -> execution_timeline.atomic_bottom)[*].style.stroke: "#C2185B"