vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Scheduler State Machine
| {near: top-center}
# States
Idle: "No work available\nThreads parked"
Running: "At least one\ncoroutine running"
ShuttingDown: "Shutdown requested\nDraining work"
# Transitions
Idle -> Running: "spawn() or\ncoroutine yields"
Running -> Idle: "All coroutines\ncomplete or block"
Running -> ShuttingDown: "shutdown()\ncalled"
ShuttingDown -> Idle: "All work\ndrained"
# Worker thread states
WorkerIdle: "Waiting for work"
Searching: "Checking queues\n(local → global → steal)"
Executing: "Running coroutine"
Yielding: "Coroutine yielded\nRe-queuing"
Sleeping: "No work found\nCondvar wait"
WorkerIdle -> Searching: "Work available\nor timeout"
Searching -> Executing: "Found coroutine"
Searching -> Sleeping: "No work after\nspin/yield"
Executing -> Yielding: "Coroutine\nyielded"
Yielding -> Searching: "Re-queued"
Sleeping -> Searching: "Woken or\ntimeout"
# Style
WorkerIdle.style.fill: "#E8F5E9"
WorkerIdle.style.stroke: "#2E7D32"
Running.style.fill: "#E3F2FD"
Running.style.stroke: "#1976D2"
Executing.style.fill: "#FFF3E0"
Executing.style.stroke: "#F57C00"
ShuttingDown.style.fill: "#FFEBEE"
ShuttingDown.style.stroke: "#C62828"
Sleeping.style.fill: "#F3E5F5"
Sleeping.style.stroke: "#7B1FA2"