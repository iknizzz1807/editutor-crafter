vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # Random Victim Selection Flow
  Work-stealing victim selection algorithm with PRNG
| {near: top-center}
direction: down
start: {
  shape: circle
  style.fill: "#4CAF50"
  style.stroke: "#2E7D32"
  style.font-color: white
}
step1_prng: {
  label: "1. Generate Random Victim"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  prng_state: |md
    **PRNG Update (LCG)**
    rust
    state = state * 6364136223846793005
             + 1442695040888963407
    victim = (state as usize) % num_workers
    
  |
}
step2_check_self: {
  label: "2. Check: victim == self?"
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
step2a_adjust: {
  label: "Adjust victim"
  |md
    `victim = (victim + 1) % num_workers`
  |
  style.fill: "#FFECB3"
  style.stroke: "#FF9800"
}
step3_attempt: {
  label: "3. Attempt Steal"
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
}
steal_operation: {
  label: "Steal Operation"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  steal_detail: |md
    rust
    if let Some(task) = 
      local_queues[victim].steal() 
    {
      stats.steals_success += 1;
      return Some(task);
    }
    
  |
}
step4_next_victim: {
  label: "4. Try Next Victim"
  shape: diamond
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
}
advance_victim: {
  label: "Advance Victim Index"
  |md
    `victim = (victim + 1) % num_workers`
    `attempts++`
  |
  style.fill: "#E1BEE7"
  style.stroke: "#9C27B0"
}
step5_all_tried: {
  label: "5. All Victims Tried?"
  shape: diamond
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
}
record_failure: {
  label: "Record Failed Steals"
  |md
    rust
    stats.steals_failed += 1;
    return None;
    
  |
  style.fill: "#FFCDD2"
  style.stroke: "#F44336"
}
success: {
  shape: circle
  label: "Success\nReturn Task"
  style.fill: "#4CAF50"
  style.stroke: "#2E7D32"
  style.font-color: white
}
failure: {
  shape: circle
  label: "Failure\nReturn None"
  style.fill: "#F44336"
  style.stroke: "#C62828"
  style.font-color: white
}
# Connections
start -> step1_prng
step1_prng -> step2_check_self
step2_check_self -> step3_attempt: "No"
step2_check_self -> step2a_adjust: "Yes\n(self-selected)"
step2a_adjust -> step3_attempt
step3_attempt -> steal_operation: "Attempt"
steal_operation -> success: "CAS Success"
steal_operation -> step4_next_victim: "CAS Failed\nor Empty"
step4_next_victim -> advance_victim: "Try Another"
advance_victim -> step5_all_tried
step5_all_tried -> step3_attempt: "No\n(more victims)"
step5_all_tried -> record_failure: "Yes\n(all tried)"
record_failure -> failure
# Annotations
annotation: |md
  **Key Properties:**
  - Random distribution via LCG prevents synchronized contention
  - Self-exclusion prevents stealing from own queue
  - Round-robin fallback ensures all queues eventually tried
  - Statistics track success rate for monitoring
| {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
}