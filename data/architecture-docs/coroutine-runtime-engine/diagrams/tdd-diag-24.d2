vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: down

title: ||md
  # Scaling Efficiency & Memory Layout Analysis
  ## M:N Work-Stealing Scheduler Performance Technical Manual
|| {
  near: top-center
  style: {
    font-size: 32
    bold: true
    stroke-width: 0
    fill: transparent
  }
}

# ==========================================
# SECTION 1: MEMORY LAYOUT (BYTE-LEVEL SPEC)
# ==========================================
# Intel Manual Quality: Byte-level precision for CCB structure.
# Colors: Header=Purple (Context), Data=Blue (Stats), Free=Green, Padding=Gray, Pointers=Orange.

ccb_spec: Coroutine Control Block (CCB) Memory Layout {
  shape: sql_table
  label: "sizeof(CCB) = 128 bytes (2 Cache Lines)"
  
  "0x00 - 0x07": "stack_ptr" {type: "pointer (8B)"; constraint: "RSP / Top of Stack"; style.fill: orange}
  "0x08 - 0x0F": "stack_base" {type: "pointer (8B)"; constraint: "Allocation Base"; style.fill: orange}
  "0x10 - 0x17": "stack_size" {type: "uint64 (8B)"; constraint: "Page Aligned"; style.fill: blue}
  "0x18 - 0x1F": "coro_id" {type: "uint64 (8B)"; constraint: "Unique GID"; style.fill: blue}
  
  # Cache Line Boundary - 64B
  line_1: "------------------------------------------------" {type: "L1 CACHE LINE BOUNDARY (64B)"; style.stroke-dash: 5; style.font-color: gray}
  
  "0x20 - 0x3F": "context_regs" {type: "struct (32B)"; constraint: "rax, rbx, rcx, rdx, rsi, rdi, rbp"; style.fill: purple}
  "0x40 - 0x43": "state_flags" {type: "uint32 (4B)"; constraint: "Atomic Bitmask"; style.fill: purple}
  "0x44 - 0x47": "priority" {type: "int32 (4B)"; constraint: "Sched Class"; style.fill: purple}
  "0x48 - 0x4F": "wait_obj_ptr" {type: "pointer (8B)"; constraint: "Futex / Channel Obj"; style.fill: orange}
  
  # Padding to align to next cache line
  "0x50 - 0x7F": "padding" {type: "padding (48B)"; constraint: "Alignment Gap"; style.fill: gray}
  
  line_2: "================================================" {type: "PAGE/L2 ALIGNMENT BOUNDARY (128B)"; style.stroke-width: 4}
}

# ==========================================
# SECTION 2: PERFORMANCE METRICS DASHBOARD
# ==========================================
perf_metrics: Performance Analysis Dashboard {
  grid-columns: 2
  grid-gap: 50

  speedup_chart: {
    label: "Speedup vs Thread Count (1000 Coroutines)"
    chart_area: {
      shape: rectangle
      width: 600
      height: 400
      style.fill: "#f8f9fa"
      
      y_axis: "Speedup (x)" {
        shape: text
        label.near: center-left
        style.font-size: 14
      }
      x_axis: "Threads (P)" {
        shape: text
        label.near: bottom-center
        style.font-size: 14
      }

      ideal: {
        shape: rectangle
        width: 500; height: 350
        style.stroke: "#28a745"; style.stroke-width: 3; style.stroke-dash: 5; style.fill: transparent
        label: "Ideal Linear (1.0 Efficiency)"
        label.near: top-right
      }
      
      actual: {
        shape: rectangle
        width: 420; height: 280
        style.stroke: "#007bff"; style.stroke-width: 5; style.fill: transparent
        label: "Measured Work-Stealing"
        label.near: center
      }
      
      threshold: {
        shape: rectangle
        width: 500; height: 245
        style.stroke: "#dc3545"; style.stroke-width: 2; style.stroke-dash: 2; style.fill: transparent
        label: "70% Efficiency Limit"
        label.near: bottom-right
      }
    }
  }

  data_results: {
    label: "Raw Execution Data (Scaling Metrics)"
    results: |md
      | Threads (P) | Speedup (S) | Efficiency (E) | Steals/sec |
      |-------------|-------------|----------------|------------|
      | 1           | 1.00x       | 100%           | 0          |
      | 4           | 3.04x       | 76%            | 1.2k       |
      | 8           | 5.70x       | 71%            | 4.8k       |
      | 16          | 9.92x       | 62%            | 22k        |
    |
  }
}

# ==========================================
# SECTION 3: OVERHEAD & CACHE ANALYSIS
# ==========================================
analysis_block: Analysis of Scaling Bottlenecks {
  grid-columns: 3
  grid-gap: 30

  ctx_switch: {
    label: "Context Switching"
    style.fill: "#e3f2fd"
    content: |md
      **Cost:** 45ns - 80ns
      - Reg Save: 20ns
      - Stack Swap: 10ns
      - Cache Warm: 30ns
    |
  }

  work_stealing: {
    label: "Work Stealing"
    style.fill: "#fff3e0"
    content: |md
      **Cost:** 30ns - 60ns
      - Atomic CAS: 15ns
      - Remote Miss: 25ns
      - Lock-Free Deque: 10ns
    |
  }

  numa_effects: {
    label: "NUMA Latency"
    style.fill: "#fce4ec"
    content: |md
      **Cross-Socket Penalty**
      - Local: ~50ns
      - Remote: ~110ns
      - Impact: 2x slowdown
    |
  }
}

# ==========================================
# SECTION 4: STATE TRANSITION (STEAL ALGORITHM)
# ==========================================
steal_algo: Algorithm State Transitions {
  grid-columns: 2
  grid-gap: 100

  before: {
    label: "T0: Processor A Idle (Victim)"
    style.stroke: "#333"
    P_A: {
      label: "Proc A (Victim)"
      L_Queue: "[ C1 | C2 | C3 ]" {
        style: {
          stroke: "#28a745"
          bold: true
          stroke-width: 2
        }
      }
    }
    P_B: {
      label: "Proc B (Thief)"
      L_Queue: "[ EMPTY ]" {
        style: {
          stroke: "#dc3545"
          stroke-dash: 3
        }
      }
    }
  }

  after: {
    label: "T1: Proc B Steals Tail (C3)"
    style.stroke: "#333"
    P_A: {
      label: "Proc A"
      L_Queue: "[ C1 | C2 ]"
    }
    P_B: {
      label: "Proc B"
      L_Queue: "[ **C3** ]" {
        style: {
          stroke: "#dc3545"
          bold: true
          stroke-width: 4
          font-color: "#dc3545"
        }
      }
    }
  }

  before -> after: "Atomic CAS(Tail, Tail-1)" {
    style: {
      animated: true
      stroke: "#007bff"
      stroke-width: 2
    }
  }
}

# ==========================================
# SECTION 5: THEORETICAL BOUNDS
# ==========================================
theory: Mathematical Foundation {
  grid-columns: 2
  
  complexity: {
    label: "Expected Time Bound"
    formula: |md
      $$T(P) = O(\frac{T_1}{P} + T_\infty)$$
      *Where:*
      - $T_1$: Total Work (Sequential Time)
      - $P$: Number of Processors
      - $T_\infty$: Critical Path Length (Span)
    |
  }

  amdahl: {
    label: "Amdahl's Law (S=5% Sequential)"
    table: |md
      | Cores (P) | Max Speedup (S) | Efficiency (E) |
      |-----------|-----------------|----------------|
      | 1         | 1.0x            | 100%           |
      | 8         | 5.4x            | 67.5%          |
      | 64        | 13.5x           | 21.1%          |
    |
  }
}

# ==========================================
# ANNOTATIONS & CONNECTIONS
# ==========================================

ccb_spec -> perf_metrics: "128B size affects\ncache line utilization" {
  style.stroke: orange
}
perf_metrics -> analysis_block: "Profiling data identifies\nspecific overheads" {
  style.stroke: blue
}
analysis_block -> theory: "Empirical vs\nTheoretical match" {
  style.stroke-dash: 5
}

footer: ||md
  ## Implementation Constraints for Scaling
  To maintain >70% efficiency at high core counts (P > 16), the runtime MUST:
  1. **Locality:** Use **LIFO** for local pushes/pops to maximize L1/L2 hits.
  2. **Granularity:** Use **FIFO** for stealing from victims to grab larger chunks of recursion trees.
  3. **Topology:** Implement **NUMA-Aware** victim selection (steal from siblings before cross-socket).
  4. **Contention:** Use Exponential Backoff on failed CAS to prevent bus-locking.
|| 

footer.near: bottom-center
footer.style.fill: "#fff9c4"
footer.style.stroke: "#fbc02d"