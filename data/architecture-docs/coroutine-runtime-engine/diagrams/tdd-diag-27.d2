layout-engine: elk
theme-id: 4

title: |md
  # Preemption Mechanisms Comparison
  Three approaches to coroutine preemption with trade-offs
| {near: top-center}

vars: {
  colors: {
    signal-bg: "#FFE4E1"
    compiler-bg: "#E0F7FA"
    hybrid-bg: "#F0FFF0"
    header: "#2C3E50"
    pro: "#27AE60"
    con: "#E74C3C"
    arrow: "#3498DB"
  }
}

classes: {
  approach-container: {
    style: {
      stroke: "#BDC3C7"
      stroke-width: 2
      border-radius: 8
    }
  }
  header-box: {
    style: {
      fill: "${colors.header}"
      font-color: white
      bold: true
      font-size: 20
      border-radius: 4
    }
  }
  pro-item: {
    shape: rectangle
    style: {
      fill: "${colors.pro}"
      font-color: white
      border-radius: 4
      font-size: 14
    }
  }
  con-item: {
    shape: rectangle
    style: {
      fill: "${colors.con}"
      font-color: white
      border-radius: 4
      font-size: 14
    }
  }
  mechanism-box: {
    style: {
      fill: white
      stroke: "#95A5A6"
      border-radius: 4
      font-size: 13
    }
  }
  center-label: {
    shape: text
    style: {
      font-size: 16
      bold: true
      fill: "#7F8C8D"
    }
  }
}

# ==================== SIGNAL-BASED PREEMPTION ====================
signal: "1. Signal-Based Preemption" {
  class: approach-container
  style.fill: "${colors.signal-bg}"
  width: 380
  
  signal_header: "🔴 Signal-Based (Timer → SIGALRM)" {
    class: header-box
    width: 360
  }
  
  signal_mechanism: |md
    **Mechanism:**
    - Hardware timer fires (setitimer/timer_create)
    - Kernel delivers signal (SIGALRM/SIGUSR1)
    - Signal handler runs on current stack
    - Handler sets preemption flag or forces yield
  | {
    class: mechanism-box
    width: 350
  }
  
  signal_pro_header: "✓ PROS:" {
    class: center-label
    style.fill: transparent
  }
  signal_pro1: "Works with any code (including unmodified binaries)" {class: pro-item}
  signal_pro2: "No compiler cooperation needed" {class: pro-item}
  signal_pro3: "Precise time slicing (guaranteed 10ms slices)" {class: pro-item}
  
  signal_con_header: "✗ CONS:" {
    class: center-label
    style.fill: transparent
  }
  signal_con1: "Signal safety restrictive (few async-signal-safe functions)" {class: con-item}
  signal_con2: "Can interrupt at arbitrary points (mid-malloc, mid-lock)" {class: con-item}
  signal_con3: "Stack handling complex (signal runs on current stack)" {class: con-item}
  signal_con4: "Interaction with syscalls/other signals complex" {class: con-item}
  
  signal_libraries: |md
    **Used by:** Early Go (pre-1.14), 
    some research runtimes
  | {
    style.fill: "#FDF2E9"
    style.border-radius: 4
    style.font-size: 12
  }
}

# ==================== COMPILER-ASSISTED PREEMPTION ====================
compiler: "2. Compiler-Assisted Preemption" {
  class: approach-container
  style.fill: "${colors.compiler-bg}"
  width: 380
  
  compiler_header: "🔵 Compiler-Assisted (Yield Points)" {
    class: header-box
    width: 360
  }
  
  compiler_mechanism: |md
    **Mechanism:**
    - Compiler inserts checks at safe points
    - Function entry, loop backedges, call sites
    - Each check tests "should yield?" flag
    - If set: coroutine yields cooperatively
  | {
    class: mechanism-box
    width: 350
  }
  
  compiler_pro_header: "✓ PROS:" {
    class: center-label
    style.fill: transparent
  }
  compiler_pro1: "Only preempts at safe points (function boundaries)" {class: pro-item}
  compiler_pro2: "No signal handling complexity" {class: pro-item}
  compiler_pro3: "Predictable overhead (constant-time check)" {class: pro-item}
  compiler_pro4: "No truly arbitrary interruption" {class: pro-item}
  
  compiler_con_header: "✗ CONS:" {
    class: center-label
    style.fill: transparent
  }
  compiler_con1: "Requires compiler support or source transformation" {class: con-item}
  compiler_con2: "Doesn't work with external libraries/FFI code" {class: con-item}
  compiler_con3: "Long loops without calls can still starve" {class: con-item}
  compiler_con4: "Overhead at every safe point check" {class: con-item}
  
  compiler_libraries: |md
    **Used by:** Go (current), 
    C# async/await
  | {
    style.fill: "#E8F8F5"
    style.border-radius: 4
    style.font-size: 12
  }
}

# ==================== HYBRID APPROACH ====================
hybrid: "3. Hybrid Approach (Timer + Safe Points)" {
  class: approach-container
  style.fill: "${colors.hybrid-bg}"
  width: 380
  
  hybrid_header: "🟢 Hybrid (Timer + Cooperative Checks)" {
    class: header-box
    width: 360
  }
  
  hybrid_mechanism: |md
    **Mechanism:**
    - Timer sets "preempt requested" flag
    - Coroutine checks flag at safe points
    - If set: yield cooperatively
    - Combines timer precision with safe-point safety
  | {
    class: mechanism-box
    width: 350
  }
  
  hybrid_pro_header: "✓ PROS:" {
    class: center-label
    style.fill: transparent
  }
  hybrid_pro1: "Timer precision + safe-point safety combined" {class: pro-item}
  hybrid_pro2: "No truly arbitrary interruption" {class: pro-item}
  hybrid_pro3: "Reasonable latency bounds" {class: pro-item}
  hybrid_pro4: "Simpler than full signal-based preemption" {class: pro-item}
  
  hybrid_con_header: "✗ CONS:" {
    class: center-label
    style.fill: transparent
  }
  hybrid_con1: "Still requires some cooperation (flag checks)" {class: con-item}
  hybrid_con2: "Latency depends on safe-point frequency" {class: con-item}
  hybrid_con3: "More complex implementation than pure cooperative" {class: con-item}
  
  hybrid_libraries: |md
    **Used by:** This Runtime (your choice),
    Tokio (cooperative with hints)
  | {
    style.fill: "#EAFAF1"
    style.border-radius: 4
    style.font-size: 12
  }
}

# ==================== FLOW DIAGRAMS ====================
flow_section: "Preemption Flow Comparison" {
  style.fill: white
  style.stroke: "#BDC3C7"
  style.border-radius: 8
  
  # Signal flow
  signal_flow: "Signal-Based Flow" {
    style.fill: "${colors.signal-bg}"
    style.border-radius: 6
    sf1: "Timer Fires" {shape: circle; style.fill: "#E74C3C"; style.font-color: white}
    sf2: "Signal Handler" {shape: diamond; style.fill: "#F39C12"}
    sf3: "Set Flag / Force Yield" {shape: rectangle}
    sf4: "Coroutine Yielded\n(at any instruction!)" {shape: rectangle; style.fill: "#FADBD8"}
    
    sf1 -> sf2: kernel delivers
    sf2 -> sf3: handler runs
    sf3 -> sf4: immediate
  }
  
  # Compiler flow
  compiler_flow: "Compiler-Assisted Flow" {
    style.fill: "${colors.compiler-bg}"
    style.border-radius: 6
    cf1: "Coroutine Executing" {shape: circle; style.fill: "#3498DB"; style.font-color: white}
    cf2: "Safe Point Reached" {shape: diamond; style.fill: "#F39C12"}
    cf3: "Check Flag" {shape: rectangle}
    cf4: "Yield if Set" {shape: rectangle; style.fill: "#D5F5E3"}
    
    cf1 -> cf2: reaches check
    cf2 -> cf3: test
    cf3 -> cf4: if true
  }
  
  # Hybrid flow
  hybrid_flow: "Hybrid Flow" {
    style.fill: "${colors.hybrid-bg}"
    style.border-radius: 6
    hf1: "Timer Fires" {shape: circle; style.fill: "#27AE60"; style.font-color: white}
    hf2: "Set Preempt Flag" {shape: rectangle}
    hf3: "Coroutine at Safe Point" {shape: diamond; style.fill: "#F39C12"}
    hf4: "Check & Yield" {shape: rectangle; style.fill: "#D5F5E3"}
    
    hf1 -> hf2: async
    hf2 -> hf3: later
    hf3 -> hf4: check
  }
}

# ==================== COMPARISON MATRIX ====================
matrix: "Quick Comparison Matrix" {
  style.fill: white
  style.stroke: "#BDC3C7"
  style.border-radius: 8
  grid-columns: 4
  grid-gap: 0
  
  # Header row
  h_aspect: "Aspect" {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
  }
  h_signal: "Signal" {
    style.fill: "${colors.signal-bg}"
    style.bold: true
  }
  h_compiler: "Compiler" {
    style.fill: "${colors.compiler-bg}"
    style.bold: true
  }
  h_hybrid: "Hybrid" {
    style.fill: "${colors.hybrid-bg}"
    style.bold: true
  }
  
  # Data rows
  r1_aspect: "Arbitrary Interruption"
  r1_signal: "⚠️ Yes" {style.fill: "#FADBD8"}
  r1_compiler: "✅ No" {style.fill: "#D5F5E3"}
  r1_hybrid: "✅ No" {style.fill: "#D5F5E3"}
  
  r2_aspect: "FFI Compatible"
  r2_signal: "✅ Yes" {style.fill: "#D5F5E3"}
  r2_compiler: "⚠️ Limited" {style.fill: "#FCF3CF"}
  r2_hybrid: "⚠️ Limited" {style.fill: "#FCF3CF"}
  
  r3_aspect: "Latency Guarantee"
  r3_signal: "✅ Precise" {style.fill: "#D5F5E3"}
  r3_compiler: "⚠️ Depends" {style.fill: "#FCF3CF"}
  r3_hybrid: "✅ Bounded" {style.fill: "#D5F5E3"}
  
  r4_aspect: "Implementation"
  r4_signal: "⚠️ Complex" {style.fill: "#FADBD8"}
  r4_compiler: "❌ Needs Compiler" {style.fill: "#FADBD8"}
  r4_hybrid: "✅ Moderate" {style.fill: "#D5F5E3"}
  
  r5_aspect: "Overhead"
  r5_signal: "✅ Low" {style.fill: "#D5F5E3"}
  r5_compiler: "⚠️ Per-check" {style.fill: "#FCF3CF"}
  r5_hybrid: "⚠️ Per-check" {style.fill: "#FCF3CF"}
}

# ==================== DECISION FLOWCHART ====================
decision: "Which Approach to Choose?" {
  style.fill: white
  style.stroke: "#2C3E50"
  style.stroke-width: 2
  style.border-radius: 8
  
  start: "Start" {shape: circle; style.fill: "#27AE60"; style.font-color: white}
  q1: "Need FFI/pre-compiled code?" {shape: diamond; style.fill: "#F39C12"}
  q2_yes: "Need precise timing?" {shape: diamond; style.fill: "#F39C12"}
  
  signal_choice: "Signal-Based" {
    shape: rectangle
    style.fill: "${colors.signal-bg}"
    style.border-radius: 4
  }
  hybrid_choice: "Hybrid" {
    shape: rectangle
    style.fill: "${colors.hybrid-bg}"
    style.border-radius: 4
  }
  
  q3_no: "Have compiler support?" {shape: diamond; style.fill: "#F39C12"}
  compiler_choice: "Compiler-Assisted" {
    shape: rectangle
    style.fill: "${colors.compiler-bg}"
    style.border-radius: 4
  }
  cooperative_choice: "Pure Cooperative\n(with manual yields)" {
    shape: rectangle
    style.fill: "#E8DAEF"
    style.border-radius: 4
  }
  
  start -> q1
  q1 -> q2_yes: Yes
  q1 -> q3_no: No
  q2_yes -> signal_choice: Yes
  q2_yes -> hybrid_choice: No
  q3_no -> compiler_choice: Yes
  q3_no -> cooperative_choice: No
}

# ==================== KEY INSIGHT ====================
insight: |md
  ## 🎯 Key Insight
  **The hybrid approach is the pragmatic choice for most runtimes:**
  - Timer provides bounded latency (fairness guarantee)
  - Safe-point checks avoid corruption (correctness guarantee)
  - Moderate complexity (implementation cost)
  Your runtime uses: **Timer (10ms) → sets flag → coroutine checks at safe points → yields**
  This achieves **<1% overhead** with **bounded 10ms latency** for any runnable coroutine.
| {
  near: bottom-center
  style: {
    fill: "#EBF5FB"
    stroke: "#3498DB"
    stroke-width: 2
    border-radius: 8
    font-size: 14
  }
  width: 700
}

# Layout connections for visual grouping
signal -- compiler -- hybrid {style.opacity: 0}