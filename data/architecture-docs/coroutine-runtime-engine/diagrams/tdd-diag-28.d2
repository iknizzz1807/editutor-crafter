vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
kernel: Kernel (Timer Subsystem)
cpu: CPU Core
thread: Worker Thread
handler: Signal Handler
flag: PreemptionFlag
kernel."timer_create( CLOCK_MONOTONIC, SIGEV_THREAD_ID, SIGUSR1 )"
kernel.t1 -> thread.t1: "Setup: sev.sigev_notify_thread_id = tid"
thread.t2 -> kernel.t2: "timer_settime( 10ms interval )"
kernel.t3 -> kernel.t3: "Timer Armed\nit_value = 10ms\nit_interval = 10ms"
thread.t4: "Coroutine executing...\n( no preemption checks yet )"
kernel.t5: "10ms elapsed"
kernel.t6 -> cpu.t6: "Hardware Timer Interrupt"
cpu.t7 -> cpu.t7: "APIC delivers IRQ\nVector to timer ISR"
cpu.t8 -> kernel.t8: "ISR: check_timer()\nIdentify expired timer"
kernel.t9 -> cpu.t9: "Signal pending\nfor thread with tid"
cpu.t10 -> thread.t10: "Interrupt user-mode execution\nSave context to kernel stack"
kernel.t11 -> thread.t11: "Setup signal frame on\nthread's user stack"
cpu.t12 -> thread.t12: "Load handler address\ninto RIP"
thread.t13 -> handler.t13: "preemption_signal_handler()"
handler.t14 -> flag.t14: "flag.set()\nAtomicBool.store(true, Relaxed)"
handler.t15 -> thread.t15: "Return from handler"
thread.t16 -> cpu.t16: "sigreturn syscall\nRestore context"
thread.t17: "Coroutine resumes...\nflag now set"
thread.t18 -> flag.t18: "check_preemption()\nflag.is_set() == true"
thread.t19 -> thread.t19: "clear_preemption()\nyield_now()"
thread.t20: "Scheduler runs\nother coroutines"
handler.note1: "Async-signal-safe:\n‚Ä¢ Only atomic ops\n‚Ä¢ No malloc/locks\n‚Ä¢ No stdio"
thread.note1: "Stack at signal delivery:\n‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê\n‚îÇ Signal Frame        ‚îÇ\n‚îÇ  ‚Ä¢ siginfo_t        ‚îÇ\n‚îÇ  ‚Ä¢ ucontext_t       ‚îÇ\n‚îÇ  ‚Ä¢ original regs    ‚îÇ\n‚îú‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î§\n‚îÇ Coroutine Stack     ‚îÇ\n‚îÇ  ‚Ä¢ local vars       ‚îÇ\n‚îÇ  ‚Ä¢ return addrs     ‚îÇ\n‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò"
kernel.note2: "Timer Configuration:\n‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê\n‚îÇ struct sigevent sev         ‚îÇ\n‚îÇ   sigev_notify: THREAD_ID   ‚îÇ\n‚îÇ   sigev_signo: SIGUSR1      ‚îÇ\n‚îÇ   sigev_notify_thread_id: N ‚îÇ\n‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò"