direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: {
  shape: text
  label: ||md
    # Safe Points for Preemption
    Code locations where coroutine suspension is safe
  ||
  near: top-center
}

# ============================================
# LEGEND
# ============================================
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#999999"
  label: ||md
    ### **Legend**
    - 🟢 **Safe Point** — Preemption allowed
    - 🔴 **Unsafe Point** — Preemption forbidden
    - ⚠️ **Conditional** — Depends on lock state
  ||
}

# ============================================
# SAFE POINTS (Left side)
# ============================================
safe_points: "Safe Points (Preemption Allowed)" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2

  func_entry: {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    label: ||md
      **1. Function Entry**
      rust
      fn process_data() {
          yield_if_preempted(); // ✅ SAFE
          // Prologue complete
      }
      
    ||
  }

  loop_backedge: {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    label: ||md
      **2. Loop Backedge**
      rust
      for i in 0..1_000_000 {
          compute_step(i);
          yield_if_preempted(); // ✅ SAFE
      }
      
    ||
  }

  after_yield: {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    label: ||md
      **3. After yield_now()**
      rust
      yield_now();
      yield_if_preempted(); // ✅ SAFE
      
    ||
  }

  io_complete: {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    label: ||md
      **4. I/O Completion**
      rust
      let n = socket.read(&mut buf).await;
      yield_if_preempted(); // ✅ SAFE
      
    ||
  }

  func_exit: {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    label: ||md
      **5. Function Exit**
      rust
      fn compute() -> Result {
          yield_if_preempted(); // ✅ SAFE
          return Ok(result);
      }
      
    ||
  }

  func_entry -> loop_backedge: "common pattern"
  loop_backedge -> after_yield: "explicit yield"
  after_yield -> io_complete: "async I/O"
  io_complete -> func_exit: "cleanup"

  safe_note: {
    shape: text
    label: ||md
      **Why Safe?**
      - No partial register state
      - Stack is consistent
      - No locks held
    ||
    style.font-color: "#388E3C"
  }
}

# ============================================
# UNSAFE POINTS (Right side)
# ============================================
unsafe_points: "Unsafe Points (Preemption Forbidden)" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 2

  mid_expr: {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    label: ||md
      **1. Mid-Expression**
      rust
      // ❌ UNSAFE
      let result = a + compute() * b;
      // Partial results in registers
      
    ||
  }

  malloc_region: {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    label: ||md
      **2. Inside malloc/free**
      rust
      // ❌ UNSAFE
      let ptr = allocate(size);
      // Heap invariants in flux
      
    ||
  }

  lock_region: {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    label: ||md
      **3. Lock Operations**
      rust
      // ❌ UNSAFE
      mutex.lock();
      critical_section();
      mutex.unlock();
      
    ||
  }

  ffi_region: {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    label: ||md
      **4. FFI Boundary**
      rust
      // ❌ UNSAFE
      unsafe {
          let result = c_library_call();
      }
      
    ||
  }

  signal_region: {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    label: ||md
      **5. Signal Handler**
      rust
      // ❌ UNSAFE
      extern "C" fn handler(sig: c_int) {
          // Reentrancy issues
      }
      
    ||
  }

  mid_expr -> malloc_region: "memory ops"
  malloc_region -> lock_region: "synchronization"
  lock_region -> ffi_region: "external code"
  ffi_region -> signal_region: "interrupts"

  unsafe_note: {
    shape: text
    label: ||md
      **Why Unsafe?**
      - Partial results undefined
      - Heap/lock state corrupted
      - May cause deadlock
    ||
    style.font-color: "#D32F2F"
  }
}

# ============================================
# LOCK DEFERRAL MECHANISM
# ============================================
lock_deferral: "Lock Deferral Mechanism" {
  near: bottom-left
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2

  defer_guard: {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
    label: ||md
      **DeferPreemptionGuard (RAII)**
      rust
      {
          let _guard = defer_preemption();
          acquire_lock();
          modify_shared_state();
          release_lock();
      }
      
    ||
  }

  locks_held: {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
    label: ||md
      **Lock Tracking**
      rust
      fn should_defer_preemption() -> bool {
          LOCKS_HELD.with(|c| c.get() > 0)
      }
      
    ||
  }
  defer_guard -> locks_held: "uses"
}

# ============================================
# PREEMPTION CHECK FLOW
# ============================================
state_flow: "Preemption Check Flow" {
  near: top-right
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"

  check_flag: {
    shape: diamond
    label: "Preemption\nFlag Set?"
    style.fill: "#BBDEFB"
  }
  check_locks: {
    shape: diamond
    label: "Locks\nHeld?"
    style.fill: "#BBDEFB"
  }
  continue_exec: {
    shape: rectangle
    label: "Continue\nExecution"
    style.fill: "#C8E6C9"
  }
  yield_scheduler: {
    shape: rectangle
    label: "yield_now()"
    style.fill: "#FFF9C4"
  }
  defer_exec: {
    shape: rectangle
    label: "Defer\n(Flag stays set)"
    style.fill: "#FFCDD2"
  }

  check_flag -> continue_exec: "No" {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  check_flag -> check_locks: "Yes" {
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  check_locks -> yield_scheduler: "No" {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  check_locks -> defer_exec: "Yes" {
    style.stroke: "#F44336"
    style.stroke-width: 2
  }
  yield_scheduler -> continue_exec: "resumed" {
    style.stroke: "#9E9E9E"
    style.stroke-dash: 3
  }
}

# ============================================
# SAFE POINT PATTERNS
# ============================================
patterns: "Safe Point Patterns" {
  near: bottom-center
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"

  pattern_cpu: {
    shape: rectangle
    style.fill: "#E1BEE7"
    label: ||md
      **CPU-Bound Loop**
      rust
      for chunk in data.chunks_mut(1024) {
          process_chunk(chunk);
          yield_if_preempted();
      }
      
    ||
  }

  pattern_producer: {
    shape: rectangle
    style.fill: "#E1BEE7"
    label: ||md
      **Producer-Consumer**
      rust
      async fn producer(queue: &Queue) {
          loop {
              let item = generate_item();
              queue.send(item).await;
              yield_if_preempted();
          }
      }
      
    ||
  }

  pattern_recursive: {
    shape: rectangle
    style.fill: "#E1BEE7"
    label: ||md
      **Recursive Processing**
      rust
      fn traverse(node: &Node, depth: u32) {
          if depth % 100 == 0 { yield_if_preempted(); }
          for child in &node.children {
              traverse(child, depth + 1);
          }
      }
      
    ||
  }
  pattern_cpu -> pattern_producer: "work pattern"
  pattern_producer -> pattern_recursive: "depth control"
}

# ============================================
# CROSS-SECTION CONNECTIONS
# ============================================
safe_points -> state_flow: "check at\nthese points" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 5
}
unsafe_points -> state_flow: "NEVER check\nat these points" {
  style.stroke: "#F44336"
  style.stroke-dash: 5
}
lock_deferral -> state_flow: "modifies\ndeferral check" {
  style.stroke: "#FF9800"
  style.stroke-dash: 5
}