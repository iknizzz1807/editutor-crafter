vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## cooperative_yield() Algorithm
  Step-by-step execution flow
| {near: top-center}
# Entry point
start: {
  shape: circle
  style.fill: "#4CAF50"
  style.stroke: "#2E7D32"
  style.font-color: white
  width: 60
}
# Step 1: Check preemption enabled
step1: {
  label: "Step 1\nCheck PREEMPTION_ENABLED"
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  width: 180
}
# Step 2: Return immediately (not enabled)
step1_no: {
  label: "Preemption disabled\nReturn immediately\n(~1 cycle)"
  shape: rectangle
  style.fill: "#FFECB3"
  style.stroke: "#FF8F00"
}
# Step 3: Load flag
step2: {
  label: "Step 2\nLoad PREEMPTION_FLAG\n(Relaxed atomic load)"
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
}
# Step 4: Check flag value
step3: {
  label: "Step 3\nflag == true?"
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  width: 160
}
# Step 5a: Flag not set - return
step3_no: {
  label: "Flag not set\nReturn immediately\n(~3 cycles total)"
  shape: rectangle
  style.fill: "#FFECB3"
  style.stroke: "#FF8F00"
}
# Step 5b: Clear flag
step4: {
  label: "Step 4\nClear PREEMPTION_FLAG\n(Relaxed store: false)"
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-color: "#B71C1C"
  style.bold: true
}
# Step 6: Yield
step5: {
  label: "Step 5\nCall yield_now()\n(Context switch to scheduler)"
  shape: rectangle
  style.fill: "#CE93D8"
  style.stroke: "#6A1B9A"
  style.font-color: "#4A148C"
  style.bold: true
}
# Step 7: Resumed
step6: {
  label: "Step 6\nResumed by scheduler\nContinue execution"
  shape: rectangle
  style.fill: "#B2DFDB"
  style.stroke: "#00695C"
}
# Exit point
exit: {
  label: "Return to\ncaller"
  shape: circle
  style.fill: "#F44336"
  style.stroke: "#C62828"
  style.font-color: white
  width: 60
}
# Performance annotation
perf_note: |md
  **Performance:**
  - Flag not set: ~3 cycles
  - Flag set: ~3 cycles + yield overhead (~50ns)
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
}
# Connections
start -> step1
step1 -> step1_no: "false\n(disabled)"
step1 -> step2: "true\n(enabled)"
step1_no -> exit
step2 -> step3
step3 -> step3_no: "false\n(not set)"
step3 -> step4: "true\n(set)"
step3_no -> exit
step4 -> step5: "clear flag"
step5 -> step6: "yield"
step6 -> exit
# Edge labels with timing
step1 -> step1_no: {
  label: "disabled"
  style.stroke: "#FF8F00"
}
step1 -> step2: {
  label: "enabled"
  style.stroke: "#388E3C"
}
step3 -> step4: {
  label: "PREEMPT!"
  style.stroke: "#C62828"
  style.bold: true
  style.animated: true
}