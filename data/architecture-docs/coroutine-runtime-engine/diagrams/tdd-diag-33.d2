direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    running: "#4CAF50"
    preempted: "#FF5722"
    waiting: "#FFEB3B"
    blocked: "#9C27B0"
    timeline: "#E8E8E8"
    cpu_bg: "#E3F2FD"
    header_purple: "#7B1FA2"
  }
}

title: ||md
  # Coroutine Runtime: Time Slice Fairness (10ms Quantum)
  **Intel Manual Reference: Preemptive Scheduling Visualization**
  *This diagram demonstrates the 10ms preemption mechanism ensuring fair CPU distribution among N coroutines.*
|| {near: top-center}

# Timeline axis at the top for reference
timeline_axis: {
  shape: rectangle
  width: 1200
  height: 50
  style: {
    fill: ${colors.timeline}
    stroke: "#666666"
    stroke-width: 1
  }
  
  direction: right
  t0: "0ms" { width: 300; style.font-size: 14; style.bold: true; style.stroke-width: 0 }
  t10: "10ms" { width: 300; style.font-size: 14; style.bold: true; style.stroke-width: 0 }
  t20: "20ms" { width: 300; style.font-size: 14; style.bold: true; style.stroke-width: 0 }
  t30: "30ms" { width: 300; style.font-size: 14; style.bold: true; style.stroke-width: 0 }
}

# CPU Core (single thread view)
cpu_core: "Execution Context: P0 (Processor 0)" {
  style: {
    fill: ${colors.cpu_bg}
    stroke: "#1976D2"
    stroke-width: 4
  }

  # Coroutine A timeline - CPU Intensive
  coro_a: "G[A]: CPU-bound Task" {
    style.fill: transparent
    direction: right
    
    a_run1: "RUNNING (10ms)" {
      width: 300; height: 60
      style.fill: ${colors.running}
      style.font-color: white; style.bold: true
      tooltip: "G[A] Stack: [0x7000...0x7800]"
    }
    a_p: "⏸️ PREEMPT" {
      width: 80; height: 60
      style.fill: ${colors.preempted}
      style.font-color: white; style.bold: true
      tooltip: "Timer Interrupt -> runtime.preemptOne"
    }
    a_w: "WAITING (Runnable)" {
      width: 520; height: 60
      style.fill: ${colors.waiting}
    }
    a_run2: "RESUMED (10ms)" {
      width: 300; height: 60
      style.fill: ${colors.running}
      style.font-color: white; style.bold: true
    }
    a_run1 -> a_p -> a_w -> a_run2
  }

  # Coroutine B timeline - Mixed I/O
  coro_b: "G[B]: I/O + Compute" {
    style.fill: transparent
    direction: right
    
    b_w1: "WAITING" {
      width: 380; height: 60
      style.fill: ${colors.waiting}
    }
    b_run1: "RUNNING (10ms)" {
      width: 300; height: 60
      style.fill: "#2196F3"
      style.font-color: white; style.bold: true
    }
    b_p: "⏸️ PREEMPT" {
      width: 80; height: 60
      style.fill: ${colors.preempted}
      style.font-color: white; style.bold: true
    }
    b_io: "I/O BLOCKED" {
      width: 440; height: 60
      style.fill: ${colors.blocked}
      style.font-color: white
    }
    b_w1 -> b_run1 -> b_p -> b_io
  }

  # Coroutine C timeline - Quick Network Handler
  coro_c: "G[C]: Network IO" {
    style.fill: transparent
    direction: right
    
    c_w1: "WAITING" {
      width: 760; height: 60
      style.fill: ${colors.waiting}
    }
    c_run1: "RUNNING (6ms)" {
      width: 200; height: 60
      style.fill: "#FF9800"
      style.font-color: white; style.bold: true
    }
    c_io: "NETWORK WAIT" {
      width: 240; height: 60
      style.fill: ${colors.blocked}
      style.font-color: white
    }
    c_w1 -> c_run1 -> c_io
  }

  # Coroutine D timeline - High Frequency Processor
  coro_d: "G[D]: Event Processor" {
    style.fill: transparent
    direction: right
    
    d_w1: "WAITING" {
      width: 760; height: 60
      style.fill: ${colors.waiting}
    }
    d_run1: "RUNNING (10ms)" {
      width: 300; height: 60
      style.fill: "#00BCD4"
      style.font-color: white; style.bold: true
    }
    d_p: "⏸️ PREEMPT" {
      width: 80; height: 60
      style.fill: ${colors.preempted}
      style.font-color: white; style.bold: true
    }
    d_w2: "WAIT" {
      width: 60; height: 60
      style.fill: ${colors.waiting}
    }
    d_w1 -> d_run1 -> d_p -> d_w2
  }
}

# Documentation / Details
fairness_stats: {
  near: bottom-left
  style.fill: "#F3E5F5"; style.stroke: ${colors.header_purple}
  width: 320
  label: ||md
    ### Scheduling Statistics (0-40ms)
    | G (ID) | CPU Time | Slices | State |
    | :--- | :--- | :--- | :--- |
    | G[A] | 20ms | 2 | Runnable |
    | G[B] | 10ms | 1 | Blocked |
    | G[C] | 6ms | 1 | Blocked |
    | G[D] | 10ms | 1 | Runnable |

    **Fairness Efficiency:** 100%
  ||
}

fairness_guarantee: {
  near: bottom-right
  style.fill: "#E8F5E9"; style.stroke: "#2E7D32"
  width: 380
  label: ||md
    ### System Invariants
    1. **Quantum Limit:** No G exceeds 10ms execution.
    2. **Bounded Wait:** $Wait_{max} = Quantum \times (N_{runnable} - 1)$
    3. **Preemption Cost:** ~10-50μs context switch.
    4. **Safety:** Stack integrity preserved during yield.
  ||
}

preemption_detail: {
  near: top-right
  style.fill: "#FFF3E0"; style.stroke: "#E65100"
  width: 320
  label: "### HW Timer Mechanism"
  flow: {
    direction: down
    s1: "Timer Interrupt (10ms)" { shape: circle }
    s2: "Kernel Sets `preempt` flag" { shape: rectangle }
    s3: "G checks `flag` at loop" { shape: parallelogram }
    s4: "G calls `mcall(runtime.gosched)`" { shape: rectangle; style.bold: true }
    s1 -> s2 -> s3 -> s4
  }
}

# Visual Legend
legend: {
  near: bottom-center
  style.stroke: grey; style.fill: "#FAFAFA"
  grid-columns: 4
  l_run: "Active" { style.fill: ${colors.running}; shape: square }
  l_pre: "Preempted" { style.fill: ${colors.preempted}; shape: square }
  l_wait: "Runnable" { style.fill: ${colors.waiting}; shape: square }
  l_io: "I/O Block" { style.fill: ${colors.blocked}; shape: square }
}

# Cross-linking preemption points
cpu_core.coro_a.a_p -> preemption_detail.flow: "Trigger Signal" {
  style: { 
    stroke: red
    stroke-dash: 5
    opacity: 0.5 
  }
}