vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 25
  }
}

direction: right

title: {
  label: |md
    # Signal Handler Restrictions
    ## Async-Signal-Safe vs Unsafe Operations
  |
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
    bold: true
  }
}

signal_handler: Signal Handler Context {
  style: {
    fill: "#FFF9C9"
    stroke: "#9E2146"
    stroke-width: 2
    border-radius: 8
  }
  
  entry: Entry Point {
    shape: diamond
    style.fill: "#FFE7CB"
    style.stroke: "#9E2146"
  }
  
  check: Check Signal Source {
    shape: rectangle
  }
  
  entry -> check: "SIGUSR1 received"
}

async_safe: Async-Signal-Safe Operations {
  style: {
    fill: "#ACE1AF"
    stroke: "#228B22"
    stroke-width: 2
    border-radius: 8
  }
  
  header: |md
    ### ✅ SAFE
    **Permitted in signal context**
  | {
    near: top-center
    style.stroke-width: 0
  }

  atomic_store: "AtomicBool::store" {
    style: {
      fill: white
      stroke: "#228B22"
    }
    tooltip: |md
      **Usage:** `flag.store(true, Ordering::Relaxed)`
      - Single CPU instruction
      - No heap allocation
      - No locks
      - Execution time: ~5-10 cycles
    |
  }

  atomic_load: "AtomicBool::load" {
    style: {
      fill: white
      stroke: "#228B22"
    }
    tooltip: |md
      **Usage:** `flag.load(Ordering::Relaxed)`
      - Read-only operation
      - Cache-coherent access
      - Safe for concurrent reading
    |
  }

  tls: "Thread-Local Access" {
    style: {
      fill: white
      stroke: "#228B22"
    }
    tooltip: |md
      **Usage:** `PREEMPTION_FLAG.with(|f| f.set())`
      - Per-thread storage
      - No global synchronization needed
    |
  }

  arithmetic: "Simple Arithmetic" {
    style: {
      fill: white
      stroke: "#228B22"
    }
    tooltip: |md
      - Integer increment/decrement
      - Bitwise operations
      - Operations that do not trigger traps
    |
  }

  write_sys: "write() syscall" {
    style: {
      fill: white
      stroke: "#228B22"
    }
    tooltip: |md
      - Low-level raw file descriptor writing
      - To stderr/stdout (raw fd)
      - Non-blocking, unbuffered
    |
  }

  exit_call: "_exit(status)" {
    style: {
      fill: white
      stroke: "#228B22"
    }
    tooltip: |md
      - Immediate process termination
      - Bypasses standard library cleanup
      - Guaranteed safe exit path
    |
  }
}

unsafe_ops: Forbidden Operations {
  style: {
    fill: "#FE7070"
    stroke: "#C41E3A"
    stroke-width: 2
    border-radius: 8
  }
  
  header: |md
    ### ❌ UNSAFE
    **Deadlock or Corruption Risk**
  | {
    near: top-center
    style.stroke-width: 0
  }

  malloc_free: "malloc / free" {
    style: {
      fill: white
      stroke: "#C41E3A"
    }
    tooltip: |md
      - Takes internal allocator locks
      - Corrupts heap if signal hits during allocation
      - **CRITICAL DEADLOCK RISK**
    |
  }

  stdio_printf: "printf / stdio" {
    style: {
      fill: white
      stroke: "#C41E3A"
    }
    tooltip: |md
      - Uses global FILE stream locks
      - Internal buffering is not atomic
      - May perform hidden heap allocations
    |
  }

  mutex_ops: "Mutex Lock/Unlock" {
    style: {
      fill: white
      stroke: "#C41E3A"
    }
    tooltip: |md
      - If main thread holds lock and is interrupted by signal:
      - Signal handler waits for lock -> Deadlock.
    |
  }

  pthread_calls: "pthread_* functions" {
    style: {
      fill: white
      stroke: "#C41E3A"
    }
    tooltip: |md
      - Most pthread functions use internal locks
      - Thread creation/joining is not signal-safe
    |
  }

  panic_risk: "Rust panic!" {
    style: {
      fill: white
      stroke: "#C41E3A"
    }
    tooltip: |md
      - Stack unwinding allocates memory
      - Calling Drop handlers triggers complex code
      - IO access in panic formatting is unsafe
    |
  }

  alloc: "Heap Allocation" {
    style: {
      fill: white
      stroke: "#C41E3A"
    }
    tooltip: |md
      - Box::new(), Vec::push(), String
      - Re-entering the allocator from a signal
      - Always leads to UB or Deadlock
    |
  }
}

consequence: Consequences of Violations {
  style: {
    fill: "#FCE7C6"
    stroke: "#ED800C"
    stroke-width: 2
    border-radius: 8
  }
  
  deadlock: |md
    ### 💀 DEADLOCK
    Thread holds lock L -> Signal interrupts -> Handler calls `lock(L)` -> **Hangs Forever**.
  | {
    style.fill: white
  }
  
  corruption: |md
    ### 💀 HEAP CORRUPTION
    Signal during pointer swap in `free()` -> Handler calls `malloc()` -> **Pointers Invalidated**.
  | {
    style.fill: white
  }
  
  ub: |md
    ### 💀 UNDEFINED BEHAVIOR
    Stack corruption, silent data loss, or random SIGSEGV later in program life.
  | {
    style.fill: white
  }
}

correct_pattern: Safe Implementation Pattern {
  style: {
    fill: "#E4DBFE"
    stroke: "#6A5ACD"
    stroke-width: 2
    border-radius: 8
  }
  
  snippet: |md
    rust
    static SIGNAL_FLAG: AtomicBool = AtomicBool::new(false);

    pub unsafe extern "C" fn handler(_sig: i32) {
        // 1. Set atomic flag ONLY
        SIGNAL_FLAG.store(true, Ordering::Relaxed);
        // 2. Return immediately
    }
    
  | {
    style.fill: white
  }
  
  rule: |md
    **Key Principle:** Do the absolute minimum.
    Postpone complex logic to the main event loop.
  | {
    style.stroke-width: 0
  }
}

signal_handler.check -> async_safe: "Proceed"
signal_handler.check -> unsafe_ops: "FORBIDDEN" {
  style: {
    stroke: "#C41E3A"
    stroke-dash: 5
    stroke-width: 2
  }
}

unsafe_ops -> consequence: "Violation Results" {
  style: {
    stroke: "#C41E3A"
    stroke-width: 2
  }
}

correct_pattern -> async_safe: "Compliance" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
  }
}

legend: Legend {
  near: bottom-right
  safe: "✅ Safe" {
    shape: text
    style.font-color: "#228B22"
    style.bold: true
  }
  unsafe: "❌ Unsafe" {
    shape: text
    style.font-color: "#C41E3A"
    style.bold: true
  }
  warning: "⚠️ Violation" {
    shape: text
    style.font-color: "#ED800C"
    style.bold: true
  }
}