direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  coroutine: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  reactor: {
    shape: hexagon
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 3
      shadow: true
    }
  }
  kernel: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-dash: 4
    }
  }
  waker: {
    shape: diamond
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
  }
  scheduler: {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
    }
  }
  data-struct: {
    shape: cylinder
    style: {
      fill: "#ECEFF1"
      stroke: "#546E7A"
    }
  }
  event: {
    shape: circle
    style: {
      fill: "#FFF8E1"
      stroke: "#F57C00"
    }
  }
}
title: |md
  # Reactor Pattern Architecture
  I/O Event Dispatch for Coroutine Runtime
| {near: top-center}
# Left side: Coroutines registering interest
coro_group: "Blocked Coroutines" {
  style.fill: transparent
  style.stroke: "#90CAF9"
  style.stroke-dash: 3
  coro1: "Coroutine A\n(blocked on read)" {class: coroutine}
  coro2: "Coroutine B\n(blocked on write)" {class: coroutine}
  coro3: "Coroutine C\n(blocked on accept)" {class: coroutine}
}
# Center: Reactor
reactor: "Reactor" {
  class: reactor
  width: 200
  token_gen: "Token\nGenerator" {class: data-struct}
  waker_map: "Waker\nRegistry" {class: data-struct}
  epoll_fd: "epoll_fd\n(kernel handle)" {shape: circle}
  token_gen -> waker_map: "token → waker"
  waker_map -> epoll_fd
}
# Registration flow
reg_flow: {
  style.fill: transparent
  style.stroke: transparent
  coro1 -> reactor: "1. register(fd, Interest, waker)" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
      animated: true
    }
  }
  coro2 -> reactor: "1. register(fd, Interest, waker)" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
      animated: true
    }
  }
  coro3 -> reactor: "1. register(fd, Interest, waker)" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
      animated: true
    }
  }
}
# Bottom: Kernel epoll_wait
kernel_layer: "Kernel Space" {
  class: kernel
  style.stroke-width: 3
  epoll_wait: "epoll_wait(timeout)" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      bold: true
    }
  }
  event_queue: "Event Queue\n(ready fds)" {class: event}
  epoll_wait -> event_queue: "2. returns events"
}
reactor.epoll_fd -> kernel_layer.epoll_wait: "blocks until\nI/O ready" {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
    stroke-dash: 5
  }
}
# Right side: Waker dispatch
dispatch: "Event Dispatch" {
  style.fill: transparent
  style.stroke: "#CE93D8"
  style.stroke-dash: 3
  waker1: "Waker A" {class: waker}
  waker2: "Waker B" {class: waker}
  waker3: "Waker C" {class: waker}
}
kernel_layer.event_queue -> dispatch: "3. lookup token" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
}
# Scheduler receiving woken coroutines
scheduler: "Scheduler\n(Run Queue)" {
  class: scheduler
  width: 180
  run_queue: "Runnable\nCoroutines" {class: data-struct}
}
dispatch.waker1 -> scheduler: "4. wake()\n(schedule coroutine)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    animated: true
  }
}
dispatch.waker2 -> scheduler: "4. wake()" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
dispatch.waker3 -> scheduler: "4. wake()" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
# Flow back to coroutines (they become runnable)
scheduler -> coro_group: "5. resume()\n(coroutine continues)" {
  style: {
    stroke: "#C62828"
    stroke-dash: 4
    stroke-width: 2
  }
}
# Annotations
legend: |md
  ## Flow
  1. **Register**: Coroutine yields, registers fd + waker
  2. **Wait**: epoll_wait blocks until I/O ready
  3. **Dispatch**: Lookup waker by token, call wake()
  4. **Schedule**: Waker marks coroutine Runnable
  5. **Resume**: Scheduler resumes coroutine
| {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
  }
}