vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
AsyncTcpStream State Machine: {
  style.font-size: 28
  style.bold: true
}
# Initial state marker
initial: ● {
  style.fill: "#2E7D32"
  style.stroke: "#1B5E20"
}
# States
Connecting: {
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.font-size: 20
  style.bold: true
  label: "Connecting\n\n|'md Socket created, connect() called\nReturns EINPROGRESS '|"
}
Connected: {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.font-size: 20
  style.bold: true
  label: "Connected\n\n|'md Connection established\nReady for I/O operations '|"
}
Reading: {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.font-size: 20
  style.bold: true
  label: "Reading\n\n|'md Registered for EPOLLIN\nWaiting for data '|"
}
Writing: {
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  style.font-size: 20
  style.bold: true
  label: "Writing\n\n|'md Registered for EPOLLOUT\nWaiting for buffer space '|"
}
Closed: {
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.font-size: 20
  style.bold: true
  label: "Closed\n\n|'md Socket closed or error\nTerminal state '|"
}
# Terminal state marker
terminal: ● {
  style.fill: "#C62828"
  style.stroke: "#8E0000"
}
# Transitions
initial -> Connecting: "connect() called"
Connecting -> Connected: "EPOLLOUT ready\nSO_ERROR == 0" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.bold: true
}
Connecting -> Closed: "EPOLLOUT ready\nSO_ERROR != 0" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.bold: true
}
Connected -> Reading: "read() called\nEAGAIN returned" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
Connected -> Writing: "write() called\nEAGAIN returned" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
Connected -> Closed: "close() or error" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
Reading -> Connected: "EPOLLIN ready\ndata received" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.bold: true
}
Reading -> Closed: "read() returns 0\nEOF or error" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
Writing -> Connected: "EPOLLOUT ready\nbuffer available" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  style.bold: true
}
Writing -> Closed: "write() error\nEPIPE, etc." {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
Closed -> terminal
# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.stroke-width: 1
  title: "Legend" {
    style.font-size: 18
    style.bold: true
  }
  success: "Successful transition" {
    style.stroke: "#2E7D32"
  }
  data_op: "I/O operation" {
    style.stroke: "#1565C0"
  }
  error: "Error/Close" {
    style.stroke: "#C62828"
  }
}