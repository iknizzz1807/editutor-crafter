vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Timer Wheel Structure
### O(1) Insertion, Amortized O(1) Tick Processing
'| {near: top-center}

TimerWheel: {
  style.fill: white
  style.stroke: "#6B7280"
  style.stroke-width: 2

  wheel_container: {
    style.fill: "#F3F4F6"
    style.stroke: "#9CA3AF"
    style.border-radius: 8

    slot_00: "Slot [0]" {
      shape: rectangle
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      width: 220

      entry_00: |'md
      **TimerEntry**
      ────────────
      deadline: t+10ms
      waker: `Arc<dyn Wake>`
      '| {style.fill: "#E0E7FF"}
    }

    slot_01: "Slot [1]" {
      shape: rectangle
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      width: 220

      entry_01a: |'md
      **TimerEntry**
      ────────────
      deadline: t+11ms
      waker: `Arc<dyn Wake>`
      '| {style.fill: "#E0E7FF"}

      entry_01b: |'md
      **TimerEntry**
      ────────────
      deadline: t+11ms
      waker: `Arc<dyn Wake>`
      '| {style.fill: "#E0E7FF"}
    }

    slot_02: "Slot [2] ← current_slot" {
      shape: rectangle
      style.fill: "#FBBF24"
      style.stroke: "#D97706"
      style.stroke-width: 3
      style.bold: true
      width: 220

      current_marker: |'md
      ⬆️ **CURRENT SLOT**
      Processing now...
      '| {style.fill: "#FEF3C7"}
    }

    slot_03: "Slot [3]" {
      shape: rectangle
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      width: 220

      entry_03: |'md
      **TimerEntry**
      ────────────
      deadline: t+19ms
      waker: `Arc<dyn Wake>`
      '| {style.fill: "#E0E7FF"}
    }

    slot_dotdot: "..." {
      shape: text
      style.font-size: 24
    }

    slot_63: "Slot [63]" {
      shape: rectangle
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      width: 220
    }

    slot_00 -> slot_01: "next" {style.stroke-dash: 2; style.stroke: "#9CA3AF"}
    slot_01 -> slot_02: "next" {style.stroke-dash: 2; style.stroke: "#9CA3AF"}
    slot_02 -> slot_03: "next" {style.stroke-dash: 2; style.stroke: "#9CA3AF"}
    slot_03 -> slot_dotdot: {style.stroke-dash: 2; style.stroke: "#9CA3AF"}
    slot_dotdot -> slot_63: {style.stroke-dash: 2; style.stroke: "#9CA3AF"}
    slot_63 -> slot_00: "wrap" {style.stroke: "#3B82F6"; style.stroke-width: 2; style.animated: true}
  }
}

tick_process: "tick() Algorithm" {
  style.fill: "#ECFDF5"
  style.stroke: "#059669"
  style.border-radius: 8

  step1: |'md
  **1. Calculate elapsed slots**
  ──────────────────────────
  `elapsed = now - base_time`
  `slots_elapsed = elapsed / tick_rate`
  '| {style.fill: "#D1FAE5"}

  step2: |'md
  **2. Process each elapsed slot**
  ──────────────────────────
  For each slot in `[last..current]`:
    - Drain Entry `VecDeque`
    - If deadline expired: Add to wakers
    - Else: Re-file to correct wheel slot
  '| {style.fill: "#D1FAE5"}

  step3: |'md
  **3. Wake expired timers**
  ──────────────────────────
  For `waker` in `expired_list`:
    `waker.wake()`
  '| {style.fill: "#D1FAE5"}

  step4: |'md
  **4. Return next timeout**
  ──────────────────────────
  Calculate `min(deadline - now)`
  for scheduling hardware interrupt.
  '| {style.fill: "#D1FAE5"}

  step1 -> step2 -> step3 -> step4 {style.stroke: "#059669"; style.stroke-width: 2}
}

TimerWheel.wheel_container.slot_02 -> tick_process.step1: "Timer Interrupt" {
  style.stroke: "#D97706"
  style.stroke-width: 2
  style.animated: true
}

add_timer: "add_timer(duration, waker)" {
  style.fill: "#FEF3C7"
  style.stroke: "#F59E0B"
  style.border-radius: 8

  calc: |'md
  **Calculate target slot**
  ──────────────────────────
  `offset = duration / slot_duration`
  `target = (current + offset) % 64`
  '|

  insert: |'md
  **Insert into VecDeque**
  ──────────────────────────
  `slots[target].push_back(`
    `TimerEntry { deadline, waker }`
  `)`
  '|

  calc -> insert {style.stroke: "#F59E0B"}
}

TimerWheel.wheel_container.slot_01 <- add_timer.insert: "O(1) push_back" {
  style.stroke: "#10B981"
  style.stroke-dash: 3
}

memory_layout: "Memory Layout (72 Bytes)" {
  style.fill: "#F3E8FF"
  style.stroke: "#7C3AED"
  style.border-radius: 8

  fields: |'md
  | Offset | Field | Size | Type / Purpose |
  |:-------|:------|:-----|:---------------|
  | 0x00   | slots | 24B | `Vec<VecDeque<Entry>>` |
  | 0x18   | num_slots | 8B | Power-of-2 Cap (64) |
  | 0x20   | tick_dur | 16B | Slot granularity |
  | 0x30   | base | 16B | Epoch Instant |
  | 0x40   | current | 8B | Current index |
  '| {style.fill: "#EDE9FE"}
}

invariants: "System Invariants" {
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.border-radius: 8
  
  inv: |'md
  • **Power of 2**: `num_slots` mask-based wrapping for speed.
  • **Range Overflow**: Timers > wheel range refiled to last slot.
  • **Concurrency**: Single-producer/Single-consumer or Mutex-protected.
  • **Tick Drift**: `tick()` must account for missed intervals.
  '|
}

legend: {
  near: bottom-center
  
  l1: "Current Slot" {
    shape: rectangle
    style.fill: "#FBBF24"
    style.stroke: "#D97706"
    style.stroke-width: 3
  }
  
  l2: "Normal Slot" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
  }
  
  l3: "TimerEntry" {
    shape: rectangle
    style.fill: "#E0E7FF"
    style.stroke: "#6366F1"
  }
  
  l1 -> l2 -> l3: {style.opacity: 0}
}