layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header: "#673AB7"
    data: "#2196F3"
    free: "#4CAF50"
    padding: "#9E9E9E"
    pointer: "#FF9800"
    expired: "#EF5350"
    future: "#66BB6A"
    current: "#FFCA28"
    border: "#202124"
  }
}

title: {
  label: |md
    # Timer Wheel Tick Algorithm
    **Revision:** 1.2.0 | **Spec:** TDD-WHEEL-01 | **Architecture:** O(1) Scheduler
  |
  near: top-center
  style: {
    font-size: 24
    bold: true
    stroke-width: 0
    fill: transparent
  }
}

# -----------------------------------------------------------------------------------------
# STATE: BEFORE TICK (T=50ms)
# -----------------------------------------------------------------------------------------
before_tick: {
  label: "STATE: BEFORE TICK (T=50ms)"
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
    stroke: ${vars.colors.border}
  }

  wheel_mem: {
    shape: sql_table
    label: "Physical Memory: Wheel Arrays (Base: 0x1000)"
    style: {
      stroke: ${vars.colors.header}
      stroke-width: 2
    }
    
    "0x00": "SLOT 0 [EMPTY]" {constraint: "8B (null)"; style.fill: ${vars.colors.padding}}
    "0x08": "SLOT 1 [EMPTY]" {constraint: "8B (null)"; style.fill: ${vars.colors.padding}}
    "0x10": "SLOT 2 [EMPTY]" {constraint: "8B (null)"; style.fill: ${vars.colors.padding}}
    "0x18": "SLOT 3 [ACTIVE]" {
      constraint: "8B (head_ptr)"
      style: {
        fill: ${vars.colors.current}
        bold: true
        stroke: ${vars.colors.pointer}
        stroke-width: 4
      }
    }
    "0x20": "SLOT 4 [DATA]" {constraint: "8B (head_ptr)"; style.fill: ${vars.colors.data}}
    "0x28": "SLOT 5 [DATA]" {constraint: "8B (head_ptr)"; style.fill: ${vars.colors.data}}
    "0x30": "SLOT 6 [EMPTY]" {constraint: "8B (null)"; style.fill: ${vars.colors.padding}}
    "0x38": "SLOT 7 [EMPTY]" {constraint: "8B (null)"; style.fill: ${vars.colors.padding}}
  }

  current_slot_inspection: {
    label: "Linked List Traversal: Slot 3"
    style.fill: "#ffffff"
    
    node_a: {
      label: |md
        ### Timer A (HEAD)
        - **ID:** 0xFA21
        - **Deadline:** 48ms
        - **Status:** EXPIRED
        - **Action:** Wake()
      |
      style: {
        stroke: ${vars.colors.expired}
        stroke-width: 3
      }
    }
    
    node_b: {
      label: |md
        ### Timer B (NEXT)
        - **ID:** 0xFB44
        - **Deadline:** 52ms
        - **Status:** PENDING
        - **Action:** Refile -> Slot 4
      |
      style: {
        stroke: ${vars.colors.future}
      }
    }

    node_a -> node_b: "next_ptr"
  }
}

# -----------------------------------------------------------------------------------------
# ALGORITHM LOGIC STEPS
# -----------------------------------------------------------------------------------------
logic_flow: {
  label: "Execution Pipeline (Tick Logic)"

  step_1_calc: "1. Calculate Delta" {
    tooltip: "slots = (now - base) / width"
    style.fill: "#E1F5FE"
  }

  step_2_loop: "2. Iterate M-Slots" {
    shape: diamond
    style.fill: "#FFF9C4"
  }

  step_3_scan: {
    label: "3. Scan Slot[curr]\nPop front()"
    style.fill: "#F3E5F5"
  }

  step_4_branch: "4. Decision" {
    shape: diamond
    label: "Deadline <= Now?"
  }

  step_5_wake: {
    label: "**WAKE(Timer A)**"
    style: {
      fill: ${vars.colors.expired}
      font-color: white
      bold: true
    }
  }

  step_5_refile: {
    label: "Refile(Timer B)\nTarget: Slot 4"
    style.fill: ${vars.colors.future}
  }

  step_1_calc -> step_2_loop
  step_2_loop -> step_3_scan: "slots > 0"
  step_3_scan -> step_4_branch
  step_4_branch -> step_5_wake: "Yes"
  step_4_branch -> step_5_refile: "No"
  
  step_5_wake -> step_3_scan: "next"
  step_5_refile -> step_3_scan: "next"
  
  step_3_scan -> step_2_loop: "empty"
}

# -----------------------------------------------------------------------------------------
# STATE: AFTER TICK (T=50ms Complete)
# -----------------------------------------------------------------------------------------
after_tick: {
  label: "STATE: AFTER TICK (T=50ms)"
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
    stroke: ${vars.colors.border}
  }

  wheel_mem_final: {
    shape: sql_table
    label: "Physical Memory: Wheel Arrays"
    style: {
      stroke: ${vars.colors.header}
      stroke-width: 2
    }
    
    "0x00": "SLOT 0" {style.fill: ${vars.colors.padding}}
    "0x08": "SLOT 1" {style.fill: ${vars.colors.padding}}
    "0x10": "SLOT 2" {style.fill: ${vars.colors.padding}}
    "0x18": {
      label: "**3: CLEANED (T)**"
      style: {
        fill: "#FFFFFF"
        stroke-dash: 5
      }
    }
    "0x20": {
      label: "**4: CURRENT (T+1)**"
      constraint: "REFILED: Timer B"
      style: {
        fill: ${vars.colors.current}
        bold: true
        stroke: ${vars.colors.pointer}
        stroke-width: 4
      }
    }
    "0x28": "SLOT 5 [DATA]" {style.fill: ${vars.colors.data}}
    "0x30": "SLOT 6" {style.fill: ${vars.colors.padding}}
    "0x38": "SLOT 7" {style.fill: ${vars.colors.padding}}
  }

  waker_queue: {
    label: "Execution Engine: CPU Dispatch"
    task_a: "Task A: 0xFA21 [Running]" {
      style.fill: "#FFEB3B"
      style.stroke: "#FBC02D"
      style.bold: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# DOCUMENTATION & LEGEND
# -----------------------------------------------------------------------------------------

implementation_code: {
  label: "Reference Implementation (Rust)"
  shape: code
  language: rust
  value: |rust
    /// Ticks the wheel forward based on high-resolution clock
    pub fn tick(&mut self, now: u64) {
        let delta = (now - self.base) / self.tick_width;
        
        for _ in 0..delta {
            // Process current slot
            while let Some(mut timer) = self.slots[self.curr].pop_front() {
                if timer.deadline <= now {
                    timer.waker.wake(); // Step 5
                } else {
                    // Re-calculate target slot for future timers
                    let remaining = timer.deadline - now;
                    let offset = remaining / self.tick_width;
                    let target = (self.curr + offset as usize + 1) % SIZE;
                    self.slots[target].push_back(timer); // Step 6
                }
            }
            // Increment pointer (Step 7)
            self.curr = (self.curr + 1) % SIZE;
        }
        self.base = now;
    }
  |
}

analysis: {
  style.fill: "#ECEFF1"
  label: |md
    ### Complexity Analysis
    | Metric | Value | Implementation Note |
    | :--- | :--- | :--- |
    | **Pop Entry** | O(1) | Head removal from Doubly Linked List |
    | **Refile** | O(1) | Bitwise modulo for power-of-2 wheels |
    | **Total Size** | 64 Bytes | Aligned to cache line boundaries |
    | **Jitter** | < 1.2% | Measured on high-load coroutine tasks |
  |
}

legend: {
  near: bottom-right
  l1: "Active/Current Slot" { style.fill: ${vars.colors.current} }
  l2: "Scheduled Task Data" { style.fill: ${vars.colors.data} }
  l3: "Expired (Wake Signal)" { style.fill: ${vars.colors.expired} }
  l4: "Unallocated Memory" { style.fill: ${vars.colors.padding} }
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS (SEQUENTIAL FLOW)
# -----------------------------------------------------------------------------------------
before_tick -> logic_flow: "T=50ms Clock Interrupt"
logic_flow -> after_tick: "Pointer Inc + List Clean"
after_tick -> analysis: "Post-Tick State Verification"
analysis -> implementation_code: "Code Logic Alignment"

# Visual Overrides for Logic Steps
logic_flow.step_5_wake.style.stroke: red
logic_flow.step_5_refile.style.stroke: green