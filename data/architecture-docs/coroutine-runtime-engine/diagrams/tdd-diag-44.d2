vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Level-Triggered (LT) vs Edge-Triggered (ET) Semantics
  *Engineers' Reference for `epoll(7)` and `kqueue(2)`*
| {near: top-center}

direction: right

# ============================================
# CLASSES & STYLING
# ============================================
classes: {
  process_logic: {
    style: {
      fill: "#F8F9FA"
      stroke: "#343A40"
      stroke-width: 1
      border-radius: 4
    }
  }
  notification_active: {
    style: {
      fill: "#D4EDDA"
      stroke: "#28A745"
      bold: true
    }
  }
  notification_idle: {
    style: {
      fill: "#E2E3E5"
      stroke: "#6C757D"
      stroke-dash: 3
    }
  }
  buffer_field: {
    shape: sql_table
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
    }
  }
}

# ============================================
# LEVEL-TRIGGERED SIDE
# ============================================
Level_Triggered: {
  label: "Level-Triggered (Default: EPOLLIN)"
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 3
    double-border: true
  }

  explanation: |md
    ### **Semantics: "State-Based"**
    The kernel notifies the process **as long as** the condition is true (e.g., data is present in the RX buffer).
  | {style.font-size: 14}

  Timeline: {
    grid-columns: 1
    grid-gap: 10

    t0: "T=0ms | Buffer Empty" {
      class: process_logic
      label: "Buffer: [ ] (0 bytes) | Result: epoll_wait blocks ⏸️"
    }
    
    t1: "T=10ms | Data Arrival" {
      style.fill: "#BBDEFB"
      label: "Buffer: [XXXX] (100 bytes) | Result: epoll_wait returns ✅"
    }

    t2: "T=20ms | Partial Read (Process reads 20B)" {
      style.fill: "#90CAF9"
      label: "Buffer: [XXX ] (80 bytes remains) | Result: epoll_wait returns ✅ IMMEDIATELY"
    }

    t3: "T=30ms | Loop (Process busy)" {
      style.fill: "#64B5F6"
      label: "Condition still met. epoll_wait will keep firing until 0 bytes."
    }
    
    t4: "T=40ms | Drain (Process reads 80B)" {
      style.fill: "#42A5F5"
      label: "Buffer: [ ] (0 bytes) | Result: epoll_wait blocks ⏸️"
    }
  }
}

# ============================================
# EDGE-TRIGGERED SIDE
# ============================================
Edge_Triggered: {
  label: "Edge-Triggered (EPOLLET)"
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
    stroke-width: 3
    double-border: true
  }

  explanation: |md
    ### **Semantics: "Change-Based"**
    The kernel notifies the process **only when** the state changes (e.g., from Empty to Not-Empty).
  | {style.font-size: 14}

  Timeline: {
    grid-columns: 1
    grid-gap: 10

    t0: "T=0ms | Buffer Empty" {
      class: process_logic
      label: "Buffer: [ ] (0 bytes) | Result: epoll_wait blocks ⏸️"
    }

    t1: "T=10ms | Data Arrival (State: 0 -> 1)" {
      style.fill: "#FFE0B2"
      label: "Buffer: [XXXX] (100 bytes) | Result: epoll_wait returns ✅"
    }

    t2: "T=20ms | Partial Read (Process reads 20B)" {
      style.fill: "#FFCC80"
      label: "Buffer: [XXX ] (80 bytes remains) | Result: epoll_wait blocks ⏸️"
    }

    danger: "⚠️ STALL HAZARD" {
      shape: hexagon
      style: {
        fill: "#FF8A65"
        stroke: "#D84315"
        font-color: white
      }
      label: "Process must loop read() until EAGAIN\nor it will never be notified again for these 80B!"
    }

    t3: "T=50ms | New Data Arrival (State: 1 -> 1)" {
      style.fill: "#FFB74D"
      label: "Buffer: [XXXXXX] (180 bytes) | Result: epoll_wait returns ✅ (New Edge)"
    }
  }
}

# ============================================
# KERNEL DATA STRUCTURES
# ============================================
Kernel_Internal: {
  label: "Kernel State Representation"
  near: bottom-center

  Socket_Buffer: {
    shape: sql_table
    style.fill: "#F3E5F5"
    header: "RX_BUFFER_MEM (Size: 4096B)"
    row_0: "0x00 | Page Header | 16B" {style.fill: "#CE93D8"}
    row_1: "0x10 | Data Payload | 100B" {style.fill: "#BA68C8"}
    row_2: "0x74 | Padding/Free | 3980B" {style.fill: "#E1BEE7"}
  }

  Wait_Queue: {
    shape: class
    label: "WaitQueueNode"
    + flags: uint32
    + private: void*
    + func: wait_queue_func_t
    + task_list: list_head
  }
}

# ============================================
# CONNECTIONS & FLOW
# ============================================
Level_Triggered.Timeline.t1 -> Kernel_Internal.Socket_Buffer: "Fills" {style.stroke: blue}
Edge_Triggered.Timeline.t1 -> Kernel_Internal.Socket_Buffer: "Fills" {style.stroke: orange}

Level_Triggered.Timeline.t2 -> Level_Triggered.Timeline.t3: "Notification Loop" {
  style: {
    animated: true
    stroke: blue
  }
}

Edge_Triggered.Timeline.t2 -> Edge_Triggered.Timeline.danger: "Logical Block" {
  style: {
    stroke: red
    stroke-width: 2
  }
}

legend: {
  near: bottom-right
  LT: "Level Triggered" {
    style.fill: "#E3F2FD"
  }
  ET: "Edge Triggered" {
    style.fill: "#FFF3E0"
  }
  warning: "Critical Implementation Note" {
    style.fill: "#FF8A65"
  }
}

# Documentation Overlay
notes: |md
  ## Implementation Requirements
  - **LT:** Can use blocking or non-blocking FDs. Simple programming model.
  - **ET:** **MUST** use non-blocking FDs (`O_NONBLOCK`).
  - **ET:** **MUST** read/write until `EAGAIN` or `EWOULDBLOCK`.
| {near: bottom-left}