vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  stack_color: "#9C27B0"
  data_color: "#2196F3"
  padding_color: "#BDBDBD"
  pointer_color: "#FF9800"
  boundary_color: "#212121"
  cache_line_color: "#616161"
}

title: |md
  # 10K Active Connection Resource & Memory Analysis
  **Technical Specification: Per-Stream Allocation & Scalability Matrix**
| {
  near: top-center
  style.font-size: 24
}

# 1. PHYSICAL MEMORY LAYOUT (SINGLE STREAM)
mem_spec: Single TCP Stream Memory Layout {
  tooltip: "Physical alignment for a single coroutine-managed TCP connection"
  style.stroke-width: 0.5
  style.fill: "#f8f9fa"

  # Offset Annotations (Left Margin)
  offsets: {
    shape: text
    label: |md
      **OFFSETS**
      0x0000
      0x10000
      0x30000
      0x50000
      0x51000
    |
    style.font: mono
    style.font-size: 12
    near: center-left
  }

  # Field Size Annotations (Right Margin)
  sizes: {
    shape: text
    label: |md
      **SIZE**
      64 KB
      128 KB
      128 KB
      4 KB
      200 B
    |
    style.font: mono
    style.font-size: 12
    near: center-right
  }

  # Layout Blocks
  stack: "Coroutine User Stack (L1 Cache Context)" {
    style: {
      fill: "${stack_color}"
      font-color: white
      stroke: "${cache_line_color}"
      stroke-dash: 3
    }
  }

  recv_buf: "Kernel Socket Receive Buffer (rmem)" {
    style: {
      fill: "${data_color}"
      font-color: white
    }
  }

  send_buf: "Kernel Socket Send Buffer (wmem)" {
    style: {
      fill: "${data_color}"
      font-color: white
    }
  }

  padding_align: "Memory Alignment Padding (4K Boundary)" {
    style: {
      fill: "${padding_color}"
      stroke: "${boundary_color}"
      stroke-width: 4
    }
  }

  epoll_ptr: "epoll_event Structure (Pointer)" {
    style: {
      fill: "${pointer_color}"
      font-color: black
    }
  }

  stack -> recv_buf -> send_buf -> padding_align -> epoll_ptr: {
    style.stroke-width: 1
    style.stroke: "#CCCCCC"
  }
  
  legend: |md
    **Legend:**
    - `---` Dash: Cache Line (64B)
    - **Bold**: Page Boundary (4096B)
    - Purple: User Stack
    - Blue: Kernel Data
  | {
    near: bottom-center
  }
}

# 2. SCALABILITY ARCHITECTURE (10,000 STREAMS)
scalability_matrix: 10K Connections Aggregation {
  grid-columns: 2
  style.fill: "#263238"
  style.font-color: white

  comp_stacks: {
    label: "User-space Stacks\nType: Coroutine\nSize: 640.0 MB"
    style.fill: "${stack_color}"
    style.multiple: true
    tooltip: "10,000 × 64KB"
  }

  comp_buffers: {
    label: "Socket Buffers\nType: Kernel TCP\nSize: 2.56 GB"
    style.fill: "${data_color}"
    style.multiple: true
    tooltip: "10,000 × (128KB+128KB)"
  }

  comp_epoll: {
    label: "Event Notifiers\nType: epoll_event\nSize: 2.0 MB"
    style.fill: "${pointer_color}"
    style.font-color: black
    tooltip: "10,000 × 200B"
  }

  total_vitals: {
    label: "TOTAL RSS\nType: Resident Memory\nSize: ~3.202 GB"
    style: {
      stroke: "#E91E63"
      stroke-width: 3
      double-border: true
      bold: true
    }
  }

  comp_stacks -> total_vitals
  comp_buffers -> total_vitals
  comp_epoll -> total_vitals
}

# 3. KERNEL & SYSTEM CONSTRAINTS
system_tuning: Tuning Profiles {
  direction: right

  default_state: Default Linux Kernel {
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    content: |md
      | Parameter | Default Value |
      | :--- | :--- |
      | `ulimit -n` | 1024 (Insufficient) |
      | `tcp_rmem` | 4096 131072 6291456 |
      | `tcp_wmem` | 4096 16384 4194304 |
      | **Result** | **ERR: Too many open files** |
    |
    
    status: CRITICAL_FAILURE {
      style.fill: "#D32F2F"
      style.font-color: white
      style.bold: true
    }
  }

  optimized_state: Optimized High-Concurrency {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    content: |md
      | Parameter | Target Value |
      | :--- | :--- |
      | `fs.file-max` | 200,000+ |
      | `tcp_rmem` | 4096 65536 131072 |
      | `tcp_wmem` | 4096 65536 131072 |
      | **Result** | **PASS: 10K Active Stable** |
    |
    
    status: SYSTEM_OK {
      style.fill: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
  }

  default_state -> optimized_state: "Kernel Sysctl Tuning Applied" {
    style.animated: true
    style.stroke: "#2E7D32"
    style.bold: true
  }
}

# 4. IMPLEMENTATION NOTES
implementation_guide: |md
  ### Engineering Implementation Checklist
  1. **File Descriptors:** Increment `no-file` limit in `/etc/security/limits.conf`.
  2. **Buffer Sizing:** If throughput is low, reduce `SO_RCVBUF` to 32KB to scale to 50K connections.
  3. **CPU Pinning:** Bind coroutine workers to NUMA nodes to minimize L1 cache misses on stacks.
  4. **Epoll Mode:** Use Edge-Triggered (EPOLLET) for maximum throughput with large FD sets.
| {
  near: bottom-center
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
}

# GLOBAL CONNECTORS
mem_spec -> scalability_matrix: "Vector Scaled (x10,000)"
scalability_matrix -> system_tuning: "Validation against OS Limits"
system_tuning -> implementation_guide: "Final Production Spec"

# Styling recursive globs
***.style.font: mono

scalability_matrix.** {
  style.border-radius: 8
}

mem_spec.** {
  style.font-size: 14
}