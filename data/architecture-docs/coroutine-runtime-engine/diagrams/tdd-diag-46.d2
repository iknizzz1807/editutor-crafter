vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

direction: right

title: |md
  # Reactor-Scheduler Integration
  ### Core Runtime Implementation Spec (v1.2)
  *Target: High-Performance Asynchronous Worker Loop*
| {
  near: top-center
  shape: text
}

# -----------------------------------------------------------------------------
# Worker Thread Definition
# -----------------------------------------------------------------------------
Worker: {
  label: "Worker Thread Context (Sizeof: 256 bytes)"
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
  }
  
  Running: {
    label: "STATE: RUNNING\nPC: Task Entry"
    shape: circle
    style: {
      fill: "#4CAF50"
      stroke: "#1B5E20"
      stroke-width: 4
      font-color: white
      bold: true
    }
  }
  
  Idle: {
    label: "STATE: IDLE\nSpin: counter++"
    shape: circle
    style: {
      fill: "#FFC107"
      stroke: "#FFA000"
    }
  }
  
  Polling: {
    label: "STATE: POLLING\nMode: Blocked"
    shape: circle
    style: {
      fill: "#9C27B0"
      stroke: "#7B1FA2"
      font-color: white
    }
  }
  
  Sleeping: {
    label: "STATE: PARKED\nFutex: wait"
    shape: circle
    style: {
      fill: "#607D8B"
      stroke: "#455A64"
      font-color: white
    }
  }
}

# -----------------------------------------------------------------------------
# Work Management System
# -----------------------------------------------------------------------------
Scheduler: {
  label: "M:N Work-Stealing Scheduler"
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-dash: 2
  }
  
  LocalQueue: {
    label: "Local Task Queue\n[Offset 0x00, 128B]\nCircular Chase-Lev"
    shape: cylinder
    style.fill: "#BBDEFB"
  }
  
  GlobalQueue: {
    label: "Global Injector\n[Offset 0x80, 64B]\nLock-free MPSC"
    shape: cylinder
    style.fill: "#BBDEFB"
  }
  
  FindWork: {
    label: "find_work() Implementation\n1. pop_local()\n2. batch_global(32)\n3. steal_from_peer()"
    shape: rectangle
    style: {
      fill: "#90CAF9"
      border-radius: 8
    }
  }
  
  ExecuteTask: {
    label: "execute_task()\n- Setup Stack\n- Swap Context\n- Run Coroutine"
    shape: rectangle
    style: {
      fill: "#64B5F6"
      border-radius: 8
    }
  }
}

# -----------------------------------------------------------------------------
# I/O Subsystem (The Reactor)
# -----------------------------------------------------------------------------
Reactor: {
  label: "Kernel Event Loop (Reactor)"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
  
  Epoll: {
    label: "epoll_wait()\nFlags: EPOLLET\nEvents: MAX=1024"
    shape: diamond
    style.fill: "#E1BEE7"
  }
  
  TimerWheel: {
    label: "Timer Wheel\nTick: 1ms\nSlots: 512"
    shape: hexagon
    style.fill: "#CE93D8"
  }
  
  Wakers: {
    label: "Waker Map\nType: AtomicHashmap\nKey: u64 FD_TOKEN"
    shape: class
    style: {
      fill: "#BA68C8"
      font-color: white
    }
  }
  
  Events: {
    label: "Event Dispatcher\nIterate ready_list\nInvoke wake()"
    shape: rectangle
    style: {
      fill: "#AB47BC"
      font-color: white
      border-radius: 8
    }
  }
}

# -----------------------------------------------------------------------------
# Coroutine Lifecycle State Machine
# -----------------------------------------------------------------------------
CoroutineStates: {
  label: "Coroutine Lifecycle"
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
  }
  
  Runnable: {
    label: "RUNNABLE\nIn Queue"
    shape: circle
    style.fill: "#A5D6A7"
  }
  
  RunningState: {
    label: "RUNNING\nActive CPU"
    shape: circle
    style: {
      fill: "#66BB6A"
      font-color: white
      bold: true
    }
  }
  
  Blocked: {
    label: "BLOCKED\nPending I/O"
    shape: circle
    style: {
      fill: "#EF5350"
      font-color: white
    }
  }
}

# -----------------------------------------------------------------------------
# Logical Connections & Control Flow
# -----------------------------------------------------------------------------

# Reactor Timer logic
Reactor.TimerWheel -> Reactor.Epoll: "timeout_ns = \nget_next_timer()"

# Main Scheduler loop transitions
Worker.Running -> Scheduler.FindWork: "Yield / Tick" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}

Scheduler.FindWork -> Scheduler.LocalQueue: "1. Atomic Load"
Scheduler.LocalQueue -> Scheduler.FindWork: "Task_t | NULL"
Scheduler.FindWork -> Scheduler.GlobalQueue: "2. Mutex Acquire"
Scheduler.GlobalQueue -> Scheduler.FindWork: "Batch[32]"

# Polling Path
Scheduler.FindWork -> Worker.Polling: "Queue Empty" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
Worker.Polling -> Reactor.Epoll: "syscall: epoll_wait"
Reactor.Epoll -> Reactor.Wakers: "u64 token"
Reactor.Wakers -> Reactor.Events: "lookup(token)"
Reactor.Events -> Worker.Running: "atomic_store(RUNNABLE)" {
  style: {
    stroke: "#E91E63"
    stroke-width: 3
    animated: true
  }
}

# Execution Path
Scheduler.FindWork -> Scheduler.ExecuteTask: "task found"
Scheduler.ExecuteTask -> Worker.Running: "longjmp / context_switch" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

# Worker Idle/Sleep logic
Worker.Running -> Worker.Idle: "no work (spin)"
Worker.Idle -> Worker.Running: "steal() success"
Worker.Idle -> Worker.Sleeping: "spin > threshold"
Worker.Sleeping -> Scheduler.GlobalQueue: "cond_wait"
Scheduler.GlobalQueue -> Worker.Running: "unpark(notify_one)"

# Coroutine Transitions
CoroutineStates.Runnable -> CoroutineStates.RunningState: "Scheduler.ExecuteTask"
CoroutineStates.RunningState -> CoroutineStates.Runnable: "Yield(Preemption)"
CoroutineStates.RunningState -> CoroutineStates.Blocked: "Await(I/O)"
CoroutineStates.Blocked -> CoroutineStates.Runnable: "Reactor.Events (Wake)"

# -----------------------------------------------------------------------------
# Implementation Detail Annotations
# -----------------------------------------------------------------------------
# FIXED: Changed 'near: <object>' to 'near: <constant>' for ELK compatibility.
Annotation1: ||md
  ### Worker Loop Algorithm (Low Level)
  c
  while (atomic_load(&worker->active)) {
      task_t *t = scheduler_find_work(worker);
      if (t) {
          execute_task(t);
          worker->spin_count = 0;
      } else if (worker->spin_count++ < 1000) {
          cpu_relax();
      } else {
          reactor_poll(worker);
      }
  }
  
|| {
  near: top-left
  shape: text
}

# FIXED: Changed 'near: <object>' to 'near: <constant>' for ELK compatibility.
Annotation2: ||md
  ### Reactor Block Mechanics
  * epoll_wait(timeout) uses the TimerWheel to calculate precise sleep duration.
  * Tokens are raw pointers to Waker structs to avoid O(log n) lookups where safe.
  * Edge-triggered (EPOLLET) requires reading until EAGAIN.
|| {
  near: bottom-left
  shape: text
}

# -----------------------------------------------------------------------------
# Legend
# -----------------------------------------------------------------------------
Legend: {
