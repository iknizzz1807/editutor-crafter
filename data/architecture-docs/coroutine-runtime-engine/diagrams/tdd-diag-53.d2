vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
"Coroutine A"
AsyncCondvar
AsyncMutex
"Coroutine B"
"Scheduler"
"Coroutine A"."holds guard"
"Coroutine A" -> AsyncCondvar: wait(guard).await
AsyncCondvar -> AsyncCondvar: create CoroutineWaker
AsyncCondvar -> AsyncCondvar: add to waiters queue
AsyncCondvar -> AsyncMutex: release via guard.drop()
note: |md
  Guard marks consumed=true
  Then: locked.store(false, Release)
|
AsyncMutex -> "Coroutine B": wake next waiter (if any)
AsyncCondvar -> "Scheduler": yield_now()
"Coroutine A"."Blocked on condvar"
"Coroutine B" -> AsyncCondvar: notify_one()
AsyncCondvar -> "Scheduler": waker.wake() → mark Runnable
"Scheduler" -> "Coroutine A": resume
"Coroutine A" -> AsyncMutex: lock().await (re-acquire)
AsyncMutex -> "Coroutine A": guard returned
"Coroutine A"."condition check loop"