direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Producer-Consumer with AsyncQueue
  ## Technical Implementation Specification
  This diagram details the coroutine-aware bounded queue using `AsyncMutex` and `AsyncCondvar`.
  *Spec v1.4.2 - Thread-safe, non-blocking asynchronous implementation.*
| {
  near: top-center
  style: {
    font-size: 20
    stroke-width: 0
    fill: transparent
  }
}

classes: {
  producer: {
    shape: person
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      shadow: true
    }
  }
  consumer: {
    shape: person
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      shadow: true
    }
  }
  queue-container: {
    style: {
      fill: "#FFF8E1"
      stroke: "#F57C00"
      stroke-width: 3
      border-radius: 12
      double-border: true
    }
  }
  mutex: {
    shape: diamond
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
    }
  }
  condvar: {
    shape: oval
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  data-item: {
    shape: square
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      bold: true
      border-radius: 4
    }
    width: 60
    height: 60
  }
  empty-slot: {
    shape: square
    style: {
      fill: "#FAFAFA"
      stroke: "#BDBDBD"
      stroke-dash: 4
      opacity: 0.6
    }
    width: 60
    height: 60
  }
  blocked: {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 4
      stroke-dash: 0
    }
  }
  action: {
    shape: text
    style: {
      font: mono
      font-size: 14
      bold: true
    }
  }
}

# === PRODUCER SIDE ===
producer_group: {
  label: "Producers (Async Coroutines)"
  style: {
    stroke: "#2E7D32"
    stroke-dash: 5
    fill: "#F1F8E9"
  }
  
  p1: {
    class: producer
    label: "Producer 1\n(Active)"
  }
  p2: {
    class: [producer; blocked]
    label: "Producer 2\n(Blocked)"
  }
  p3: {
    class: producer
    label: "Producer N"
    style.multiple: true
  }
  
  p1_action: "`push(item)`" {
    class: action
    near: producer_group.p1
  }
  p2_action: |md
    `push(item)`
    **BLOCKS** (Queue Full)
  | {
    class: action
    style.font-color: "#D32F2F"
    near: producer_group.p2
  }
}

# === QUEUE STRUCTURE ===
queue: {
  label: "AsyncQueue<T> | Capacity: 8"
  class: queue-container
  
  # Logic Layer
  internals: {
    label: "Synchronization primitives"
    style: {
      stroke: "#F57C00"
      stroke-dash: 2
    }
    queue_mutex: {
      label: "data_mutex:\nAsyncMutex<VecDeque<T>>"
      class: mutex
    }
    not_empty_cv: {
      label: "not_empty_cv:\nAsyncCondvar"
      class: condvar
    }
    not_full_cv: {
      label: "not_full_cv:\nAsyncCondvar"
      class: condvar
    }
  }
  
  # Data Layer - Implementation of the circular buffer
  slots: {
    label: "Internal Ring Buffer / VecDeque"
    grid-columns: 4
    grid-gap: 15
    style: {
      fill: "#FFFFFF"
      stroke: "#BDBDBD"
      border-radius: 8
    }
    
    slot0: "A" { class: data-item }
    slot1: "B" { class: data-item }
    slot2: "C" { class: data-item }
    slot3: "D" { class: data-item }
    slot4: ""  { class: empty-slot }
    slot5: ""  { class: empty-slot }
    slot6: ""  { class: empty-slot }
    slot7: ""  { class: empty-slot }
  }

  # Navigation Metadata - Internal indicators
  metadata: {
    style.stroke-width: 0
    style.fill: transparent
    head_ptr: "**HEAD** (Pop Location)" {
      shape: text
      style.font-color: "#1565C0"
    }
    tail_ptr: "**TAIL** (Push Location)" {
      shape: text
      style.font-color: "#2E7D32"
    }
  }
  
  internals.queue_mutex -> slots: "Guards Access" {
    style.stroke: "#C2185B"
  }
  internals.not_empty_cv -- slots: "Wait on 0" { style.stroke-dash: 3; style.stroke: "#7B1FA2" }
  internals.not_full_cv -- slots: "Wait on 8" { style.stroke-dash: 3; style.stroke: "#7B1FA2" }
}

# === CONSUMER SIDE ===
consumer_group: {
  label: "Consumers (Async Coroutines)"
  style: {
    stroke: "#1565C0"
    stroke-dash: 5
    fill: "#E3F2FD"
  }
  
  c1: {
    class: consumer
    label: "Consumer 1\n(Active)"
  }
  c2: {
    class: [consumer; blocked]
    label: "Consumer 2\n(Blocked)"
  }
  c3: {
    class: consumer
    label: "Consumer M"
    style.multiple: true
  }

  c1_action: "`pop() -> T`" {
    class: action
    near: consumer_group.c1
  }
  c2_action: |md
    `pop()`
    **BLOCKS** (Queue Empty)
  | {
    class: action
    style.font-color: "#D32F2F"
    near: consumer_group.c2
  }
}

# === FLOW INTERCONNECTIONS ===
producer_group.p1 -> queue.internals.queue_mutex: "1. lock().await" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    animated: true
  }
}

producer_group.p2 -> queue.internals.not_full_cv: "Full: wait(guard).await" {
  style: {
    stroke: "#D32F2F"
    stroke-dash: 5
  }
}

# Direct cell interaction
queue.slots.slot0 -> consumer_group.c1: "4. Return Data" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}

consumer_group.c2 -> queue.internals.not_empty_cv: "Empty: wait(guard).await" {
  style: {
    stroke: "#D32F2F"
    stroke-dash: 5
  }
}

# === DOCUMENTATION & ALGORITHMS ===
push_algo: |md
  ### `fn push(&self, item: T)`
  rust
  let mut guard = self.data.lock().await;
  while guard.len() >= self.capacity {
      guard = self.not_full.wait(guard).await;
  }
  guard.push_back(item);
  self.not_empty.notify_one();
  
  1. **Acquire Mutex**: Non-blocking async lock.
  2. **Check Capacity**: If full, `yield` control.
  3. **Modify**: Safe access via `MutexGuard`.
  4. **Notify**: Signal waiting consumers.
| {
  near: producer_group
  style: {
    stroke: "#2E7D32"
    fill: "#F1F8E9"
    border-radius: 8
  }
}

pop_algo: |md
  ### `fn pop(&self) -> T`
  rust
  let mut guard = self.data.lock().await;
  while guard.is_empty() {
      guard = self.not_empty.wait(guard).await;
  }
  let item = guard.pop_front().unwrap();
  self.not_full.notify_one();
  item
  
  1. **Acquire Mutex**: Ensures memory safety.
  2. **Check Content**: If empty, `yield` control.
  3. **Modify**: Extract first element.
  4. **Notify**: Signal waiting producers.
| {
  near: consumer_group
  style: {
    stroke: "#1565C0"
    fill: "#E3F2FD"
    border-radius: 8
  }
}

# === STATE MACHINE ===
state_box: {
  label: "Queue Lifecycle States"
  states: {
    shape: sequence_diagram
    empty: "Empty (0)"
    partial: "Partial (1..7)"
    full: "Full (8)"
    
    empty -> partial: "push() [Notify Empty]"
    partial -> partial: "push() / pop()"
    partial -> full: "push() [Full]"
    full -> partial: "pop() [Notify Full]"
    partial -> empty: "pop() [Empty]"
  }
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-width: 2
  }
}

# === INVARIANTS & COMPLIANCE ===
invariants: |md
  ## System Invariants
  - **I1**: `len <= capacity` always.
  - **I2**: `not_empty_cv` signaled if `len > 0`.
  - **I3**: `not_full_cv` signaled if `len < capacity`.
  - **I4**: `MutexGuard` required for pointer movement.
  - **I5**: Tokio/Loom compatible async yielding.
| {
  near: state_box
  style: {
    fill: "#EEEEEE"
    stroke: "#424242"
    stroke-width: 1
    font-size: 13
  }
}