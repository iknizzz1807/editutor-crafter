vars: {
  d2-config: {
    layout-engine: elk
  }
  colors: {
    sender: "#4A90D9"
    receiver: "#50C878"
    queue: "#F5DEB3"
    waiter: "#FFB6C1"
    data: "#E8E8E8"
  }
}
title: |md
  # MPSC Channel Architecture
  Multiple Producers, Single Consumer with Bounded Queue
| {near: top-center}
# Senders (Multiple Producers)
sender_group: {
  style.fill: transparent
  sender1: {
    shape: circle
    style.fill: ${colors.sender}
    style.stroke: "#2E5A8C"
    style.font-color: white
    label: "S1\ncoroutine"
  }
  sender2: {
    shape: circle
    style.fill: ${colors.sender}
    style.stroke: "#2E5A8C"
    style.font-color: white
    label: "S2\ncoroutine"
  }
  senderN: {
    shape: circle
    style.fill: ${colors.sender}
    style.stroke: "#2E5A8C"
    style.font-color: white
    label: "Sn\ncoroutine"
    style.multiple: true
  }
  sender_label: {
    shape: text
    label: "Senders (cloned)\nsender_count: AtomicUsize"
    style.font-size: 12
    style.italic: true
  }
}
# Channel Core
channel: {
  style.fill: ${colors.queue}
  style.stroke: "#8B7355"
  style.stroke-width: 3
  style.border-radius: 8
  label: "ChannelInner<T>"
  # Bounded Queue
  queue: {
    style.fill: ${colors.data}
    style.stroke: "#666"
    style.border-radius: 4
    label: "queue: Mutex<VecDeque<T>>"
    slot0: {shape: square; style.fill: "#98D8C8"; label: "msg"; width: 40; height: 40}
    slot1: {shape: square; style.fill: "#98D8C8"; label: "msg"; width: 40; height: 40}
    slot2: {shape: square; style.fill: "#98D8C8"; label: "msg"; width: 40; height: 40}
    slot3: {shape: square; style.fill: "#D3D3D3"; label: ""; width: 40; height: 40}
    slot4: {shape: square; style.fill: "#D3D3D3"; label: ""; width: 40; height: 40}
    slot0 -> slot1 -> slot2 -> slot3 -> slot4
  }
  # Capacity indicator
  capacity: {
    shape: text
    label: "capacity: N (bounded)"
    style.font-size: 11
    style.italic: true
  }
  # Send Waiters (blocked on full)
  send_waiters: {
    style.fill: ${colors.waiter}
    style.stroke: "#DB7093"
    style.border-radius: 6
    label: "send_waiters\n(blocked on full)"
    sw1: {shape: circle; style.fill: ${colors.sender}; style.font-size: 10; label: "S"}
    sw2: {shape: circle; style.fill: ${colors.sender}; style.font-size: 10; label: "S"}
    sw3: {shape: circle; style.fill: ${colors.sender}; style.font-size: 10; label: "S"; style.multiple: true}
    sw1 -> sw2 -> sw3
  }
  # Receive Waiters (blocked on empty)
  recv_waiters: {
    style.fill: ${colors.waiter}
    style.stroke: "#DB7093"
    style.border-radius: 6
    label: "recv_waiters\n(blocked on empty)"
    rw1: {shape: circle; style.fill: ${colors.receiver}; style.font-size: 10; label: "R"}
    rw2: {shape: circle; style.fill: ${colors.receiver}; style.font-size: 10; label: "R"; style.multiple: true}
    rw1 -> rw2
  }
  # Atomic flags
  atomics: {
    shape: rectangle
    style.fill: "#FFFACD"
    style.stroke: "#DAA520"
    style.border-radius: 4
    atomics_label: {
      shape: text
      label: |md
        **Atomic State:**
        `sender_count: AtomicUsize`
        `receiver_dropped: AtomicBool`
      |
      style.font-size: 10
    }
  }
  queue -> send_waiters: "queue.len >= capacity\n→ block sender" {
    style.stroke: "#DB7093"
    style.stroke-dash: 4
    style.animated: true
  }
  queue -> recv_waiters: "queue.len == 0\n→ block receiver" {
    style.stroke: "#DB7093"
    style.stroke-dash: 4
    style.animated: true
  }
}
# Receiver (Single Consumer)
receiver: {
  receiver1: {
    shape: circle
    style.fill: ${colors.receiver}
    style.stroke: "#2E8B57"
    style.font-color: white
    style.stroke-width: 3
    label: "Receiver\n(single)"
  }
  receiver_label: {
    shape: text
    label: "Only one receiver\nper channel"
    style.font-size: 12
    style.italic: true
  }
}
# Send operations
sender_group.sender1 -> channel.queue: "send().await" {
  label: "try send"
  style.stroke: ${colors.sender}
  style.stroke-width: 2
}
sender_group.sender2 -> channel.queue: "send().await" {
  style.stroke: ${colors.sender}
  style.stroke-width: 2
}
sender_group.senderN -> channel.queue: "send().await" {
  style.stroke: ${colors.sender}
  style.stroke-width: 2
  style.stroke-dash: 3
}
# Blocked senders go to waiters
sender_group.senderN -> channel.send_waiters: "queue full\nyield + wait" {
  style.stroke: "#DB7093"
  style.stroke-dash: 5
  style.animated: true
  label: ""
}
# Receive operation
channel.queue -> receiver.receiver1: "recv().await" {
  label: "pop front"
  style.stroke: ${colors.receiver}
  style.stroke-width: 2
}
# Wake on send (notifies receivers)
channel.send_waiters -> receiver.receiver1: "notify recv_waiters\non send()" {
  style.stroke: "#32CD32"
  style.stroke-dash: 3
  label: ""
}
# Wake on recv (notifies senders)
channel.recv_waiters -> channel.send_waiters: "notify send_waiters\non recv()" {
  style.stroke: "#32CD32"
  style.stroke-dash: 3
  style.animated: true
}
# Error handling legend
legend: {
  near: bottom-right
  style.fill: "#F9F9F9"
  style.stroke: "#CCC"
  style.border-radius: 6
  legend_title: {
    shape: text
    label: "**Return Values**"
    style.font-size: 12
  }
  send_ok: {
    shape: rectangle
    label: "send() → Ok(())"
    style.fill: "#90EE90"
    style.font-size: 10
  }
  send_err: {
    shape: rectangle
    label: "send() → Err(SendError)\n(receiver dropped)"
    style.fill: "#FFB6C1"
    style.font-size: 10
  }
  recv_ok: {
    shape: rectangle
    label: "recv() → Ok(T)"
    style.fill: "#90EE90"
    style.font-size: 10
  }
  recv_err: {
    shape: rectangle
    label: "recv() → Err(RecvError)\n(all senders dropped)"
    style.fill: "#FFB6C1"
    style.font-size: 10
  }
  send_ok -> send_err -> recv_ok -> recv_err
}
# Drop behavior annotation
drop_note: |md
  **Drop Behavior:**
  - `Sender` drop: decrements `sender_count`, wakes `recv_waiters` if last
  - `Receiver` drop: sets `receiver_dropped`, wakes all `send_waiters`
| {
  near: bottom-left
  shape: text
  style.font-size: 11
}