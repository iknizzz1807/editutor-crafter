vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Channel Receive (Async) Algorithm Spec
  **Component:** Coroutine Runtime / Synchronization Primitive
  **Memory Model:** SeqCst (Atomic Operations)
| {near: top-center}

direction: down

classes: {
  algorithm_step: {
    shape: rectangle
    style: {
      stroke-width: 2
      border-radius: 4
      shadow: true
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FEF3C7"
      stroke: "#F59E0B"
    }
  }
  state_node: {
    style: {
      stroke-dash: 3
      font-size: 12
    }
  }
  terminal_error: {
    shape: rectangle
    style: {
      fill: "#FEE2E2"
      stroke: "#EF4444"
      font-color: "#991B1B"
      bold: true
    }
  }
  success_terminal: {
    shape: rectangle
    style: {
      fill: "#DCFCE7"
      stroke: "#166534"
      font-color: "#14532D"
      bold: true
    }
  }
}

# --- Steps ---

Step_1: "1. Lock Queue Mutex" {
  class: algorithm_step
  style.fill: "#E8F4F8"
  style.stroke: "#2563EB"
  tooltip: "Acquire spinlock or mutex on the internal ring buffer"
}

Step_2: "2. Is Queue Empty?" {
  class: decision
}

Step_3a: "3a. Load sender_count" {
  class: algorithm_step
  style.fill: "#DBEAFE"
  style.stroke: "#3B82F6"
  tooltip: "Check atomic counter for active senders"
}

Step_3b: "3b. sender_count == 0?" {
  class: decision
}

Step_4a: "4a. Return Err(Disconnected)" {
  class: terminal_error
}

Step_5: "5. Register Waker" {
  class: algorithm_step
  style.fill: "#DCFCE7"
  style.stroke: "#22C55E"
  tooltip: "Capture current Coroutine context and Waker"
}

Step_6: "6. Push to recv_waiters" {
  class: algorithm_step
  style.fill: "#DCFCE7"
  style.stroke: "#22C55E"
  tooltip: "Append waker to the wait-list queue"
}

Step_7: "7. yield_now() / Suspend" {
  class: algorithm_step
  style.fill: "#FAE8FF"
  style.stroke: "#A855F7"
  style.font-color: "#6B21A8"
}

Step_8: "8. Success: Pop & Return" {
  class: success_terminal
}

# --- State Containers ---

Empty: "State: Queue Empty" {
  class: state_node
  shape: oval
  style.fill: "#FEF9C3"
}

NotEmpty: "State: Data Ready" {
  class: state_node
  shape: oval
  style.fill: "#DCFCE7"
}

Waiters: "recv_waiters Stack" {
  shape: cylinder
  style.fill: "#F3E8FF"
  style.stroke: "#8B5CF6"
}

YieldBlock: "Coroutine: SUSPENDED" {
  shape: square
  style.fill: "#FEE2E2"
  style.stroke: "#EF4444"
  style.font-color: "#991B1B"
}

Resume: "Coroutine: RUNNABLE" {
  shape: square
  style.fill: "#DCFCE7"
  style.stroke: "#22C55E"
}

# --- Connections ---

Step_1 -> Step_2
Step_2 -> NotEmpty: "False"
Step_2 -> Empty: "True"

NotEmpty -> Step_8: "Release Lock"

Empty -> Step_3a
Step_3a -> Step_3b

Step_3b -> Step_4a: "Yes" {
  label: "All Senders Dropped"
  style.stroke: red
}

Step_3b -> Step_5: "No" {
  label: "Senders Active"
}

Step_5 -> Step_6
Step_6 -> Waiters: "Atomic Push"
Waiters -> Step_7: "Release Lock"
Step_7 -> YieldBlock

# External trigger event
WakerEvent: "Sender::send() Event" {
  shape: cloud
  style.fill: "#FFF7ED"
}

WakerEvent -> YieldBlock: "Pop Waker & .wake()" {
  style.stroke: orange
  style.animated: true
}

YieldBlock -> Resume
Resume -> Step_1: "Loop: Re-acquire Lock"

# --- Footer Annotations ---

annotation: |md
  ### Implementation Notes
  - **Lock Ordering:** Mutex must be released *before* the coroutine suspends in `Step_7` to prevent deadlock.
  - **Spurious Wakeups:** The algorithm loops back to `Step_1` after resumption because another consumer might have stolen the data during the transition from `RUNNABLE` to `RUNNING`.
  - **sender_count:** Uses `Relaxed` ordering for the check, but `Acquire` when determining channel closure.
| {near: bottom-center}