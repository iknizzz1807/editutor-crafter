direction: right
title: {
  label: Channel Drop Detection Flow
  near: top-center
  shape: text
  style.font-size: 36
  style.bold: true
}
# Actors
sender1: Sender 1 {
  shape: person
  style.fill: "#E8F5E9"
}
sender2: Sender 2 {
  shape: person
  style.fill: "#E8F5E9"
}
receiver: Receiver {
  shape: person
  style.fill: "#BBDEFB"
}
channel: MPSC Channel {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1E88E5"
  style.stroke-width: 3
}
# Channel internal state
channel.sender_count: sender_count: AtomicUsize = 2 {
  style.fill: "#C8E6C9"
  shape: hexagon
}
channel.receiver_dropped: receiver_dropped: AtomicBool = false {
  style.fill: "#C8E6C9"
  shape: hexagon
}
channel.recv_waiters: recv_waiters {
  style.fill: "#FFCDD2"
  shape: queue
}
channel.send_waiters: send_waiters {
  style.fill: "#FFE0B2"
  shape: queue
}
# Phase 1: Initial State
phase1: |md
  ## Phase 1: Initial State
  - 2 senders active
  - sender_count = 2
  - receiver active
| {
  near: top-left
}
# Phase 2: Sender 1 Drops
phase2: |md
  ## Phase 2: Sender 1 Drops
  - Drop decrements count
  - sender_count: 2 → 1
  - NOT last sender, no wake
| {
  near: center-left
}
sender1.drop: Drop {
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.font-color: "#B71C1C"
  style.bold: true
}
sender1.drop.decrement: fetch_sub(1) {
  style.fill: "#FFF9C4"
}
# Phase 3: Sender 2 Drops (Last Sender)
phase3: |md
  ## Phase 3: Last Sender Drops
  - sender_count: 1 → 0
  - **LAST SENDER** → wake all receivers
| {
  near: bottom-left
}
sender2.drop: Drop {
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.font-color: "#B71C1C"
  style.bold: true
}
sender2.drop.decrement: fetch_sub(1) {
  style.fill: "#FFF9C4"
}
sender2.drop.check: count == 0? {
  shape: diamond
  style.fill: "#FFF9C4"
}
sender2.drop.wake: wake_all(recv_waiters) {
  style.fill: "#C8E6C9"
  style.bold: true
}
# Phase 4: Receiver Drop
phase4: |md
  ## Phase 4: Receiver Drops
  - Sets receiver_dropped = true
  - Wakes all send_waiters
  - Senders get SendError
| {
  near: bottom-right
}
receiver.drop: Drop {
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.font-color: "#B71C1C"
  style.bold: true
}
receiver.drop.set_flag: store(true) {
  style.fill: "#FFF9C4"
}
receiver.drop.wake: wake_all(send_waiters) {
  style.fill: "#C8E6C9"
  style.bold: true
}
# Error responses
error_send: SendError(value) {
  style.fill: "#FFCDD2"
  shape: oval
  style.bold: true
}
error_recv: RecvError {
  style.fill: "#FFCDD2"
  shape: oval
  style.bold: true
}
# Flow arrows
sender1.drop -> channel.sender_count: decrement
sender2.drop -> channel.sender_count: decrement
sender2.drop.decrement -> sender2.drop.check
sender2.drop.check -> sender2.drop.wake: yes
sender2.drop.wake -> channel.recv_waiters: wake
receiver.drop -> channel.receiver_dropped: set flag
receiver.drop -> channel.send_waiters: wake
channel.send_waiters -> error_send: blocked senders\nget error
channel.recv_waiters -> error_recv: blocked receivers\nget error
# Styling
sender1 -> sender1.drop: goes out of scope
sender2 -> sender2.drop: goes out of scope
receiver -> receiver.drop: goes out of scope