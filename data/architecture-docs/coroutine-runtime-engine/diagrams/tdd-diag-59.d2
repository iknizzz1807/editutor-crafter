vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Wait-For Graph Deadlock Detection
| { near: top-center }
direction: right
// Legend
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: transparent
  style.stroke: gray
  style.font-size: 12
  waiting: { shape: circle; style.fill: "#FFB3B3"; style.stroke: "#CC0000" }
  held: { shape: circle; style.fill: "#B3FFB3"; style.stroke: "#00CC00" }
  deadlock_cycle: { shape: rectangle; style.stroke: "#FF0000"; style.stroke-width: 3; style.stroke-dash: 4 }
}
// Coroutines (as circles)
coroutine_A: Coroutine A {
  shape: circle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
coroutine_B: Coroutine B {
  shape: circle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
coroutine_C: Coroutine C {
  shape: circle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
// Resources (as rectangles with mutex icon style)
mutex_M1: Mutex M1 {
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#FF8C00"
}
mutex_M2: Mutex M2 {
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#FF8C00"
}
mutex_M3: Mutex M3 {
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#FF8C00"
}
// Waiting edges (coroutine -> resource it wants)
coroutine_A -> mutex_M2: waiting for {
  style.stroke: "#FFB3B3"
  style.stroke-width: 2
  style.stroke-dash: 5
  label: "wants"
  source-arrowhead: 1
  target-arrowhead: triangle {
    shape: diamond
    style.fill: "#FFB3B3"
  }
}
coroutine_B -> mutex_M3: waiting for {
  style.stroke: "#FFB3B3"
  style.stroke-width: 2
  style.stroke-dash: 5
  label: "wants"
  source-arrowhead: 1
  target-arrowhead: triangle {
    shape: diamond
    style.fill: "#FFB3B3"
  }
}
coroutine_C -> mutex_M1: waiting for {
  style.stroke: "#FFB3B3"
  style.stroke-width: 2
  style.stroke-dash: 5
  label: "wants"
  source-arrowhead: 1
  target-arrowhead: triangle {
    shape: diamond
    style.fill: "#FFB3B3"
  }
}
// Held edges (resource -> coroutine that holds it)
mutex_M1 -> coroutine_A: held by {
  style.stroke: "#B3FFB3"
  style.stroke-width: 3
  label: "holds"
  source-arrowhead: circle {
    style.fill: "#B3FFB3"
  }
}
mutex_M2 -> coroutine_B: held by {
  style.stroke: "#B3FFB3"
  style.stroke-width: 3
  label: "holds"
  source-arrowhead: circle {
    style.fill: "#B3FFB3"
  }
}
mutex_M3 -> coroutine_C: held by {
  style.stroke: "#B3FFB3"
  style.stroke-width: 3
  label: "holds"
  source-arrowhead: circle {
    style.fill: "#B3FFB3"
  }
}
// Deadlock cycle indicator (red dashed box around the cycle)
deadlock_indicator: "⚠ DEADLOCK CYCLE DETECTED" {
  shape: rectangle
  style.stroke: "#FF0000"
  style.stroke-width: 3
  style.stroke-dash: 4
  style.fill: transparent
  style.font-color: "#FF0000"
  style.bold: true
}
// Position the deadlock indicator to encompass the cycle
deadlock_indicator -> coroutine_A: { style.opacity: 0 }
deadlock_indicator -> coroutine_B: { style.opacity: 0 }
deadlock_indicator -> coroutine_C: { style.opacity: 0 }
deadlock_indicator -> mutex_M1: { style.opacity: 0 }
deadlock_indicator -> mutex_M2: { style.opacity: 0 }
deadlock_indicator -> mutex_M3: { style.opacity: 0 }