direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    node-fill: "#E8F5E8"
    visited-fill: "#FFC7C7"
    cycle-fill: "#FF6B6B"
    edge-color: "#666666"
    highlight: "#FF0000"
  }
}
title: |md
  # Deadlock Detection via Wait-For Graph DFS
| {near: top-center}
classes: {
  graph_node: {
    shape: circle
    width: 50
    height: 50
    style: {
      fill: ${colors.node-fill}
      stroke: "#333333"
      stroke-width: 2
      font-size: 12
      font-color: "#333333"
    }
  }
  visited_node: {
    shape: circle
    width: 50
    height: 50
    style: {
      fill: ${colors.visited-fill}
      stroke: "#333333"
      stroke-width: 2
      font-size: 12
      font-color: "#333333"
    }
  }
  cycle_node: {
    shape: circle
    width: 50
    height: 50
    style: {
      fill: ${colors.cycle-fill}
      stroke: "#FF0000"
      stroke-width: 3
      font-size: 12
      font-color: "#FFFFFF"
    }
  }
  wait_edge: {
    style: {
      stroke: ${colors.edge-color}
      stroke-width: 2
      animated: true
    }
  }
  hold_edge: {
    style: {
      stroke: ${colors.edge-color}
      stroke-width: 2
      stroke-dash: 3
    }
  }
}
// === Step 0: Initial State ===
step_0: {
  label: |md
    **Step 0: Initial Wait-For Graph**
    Starting state before any wait operations.
  | {near: top-center}
  nodes: {
    grid-columns: 4
    grid-gap: 40
    c1: "C1" {class: graph_node}
    c2: "C2" {class: graph_node}
    c3: "C3" {class: graph_node}
    c4: "C4" {class: graph_node}
    m1: "M1" {class: graph_node}
    m2: "M2" {class: graph_node}
  }
}
// === Step 1: C1 acquires M1 ===
step_1: {
  label: |md
    **Step 1: Coroutine C1 Acquires Mutex M1**
    1. `record_acquire(C1, M1)`
    2. `held_by[M1] = C1`
  | {near: top-center}
  nodes: {
    grid-columns: 4
    grid-gap: 40
    c1: "C1" {class: graph_node}
    c2: "C2" {class: graph_node}
    c3: "C3" {class: graph_node}
    c4: "C4" {class: graph_node}
    m1: "M1" {class: visited_node}
    m2: "M2" {class: graph_node}
  }
  edges: {
    c1 -> m1: "holds" {class: hold_edge}
  }
}
// === Step 2: C2 acquires M2 ===
step_2: {
  label: |md
    **Step 2: Coroutine C2 Acquires Mutex M2**
    1. `record_acquire(C2, M2)`
    2. `held_by[M2] = C2`
  | {near: top-center}
  nodes: {
    grid-columns: 4
    grid-gap: 40
    c1: "C1" {class: graph_node}
    c2: "C2" {class: graph_node}
    c3: "C3" {class: graph_node}
    c4: "C4" {class: graph_node}
    m1: "M1" {class: visited_node}
    m2: "M2" {class: visited_node}
  }
  edges: {
    c1 -> m1: "holds" {class: hold_edge}
    c2 -> m2: "holds" {class: hold_edge}
  }
}
// === Step 3: C1 waits for M2 ===
step_3: {
  label: |md
    **Step 3: Coroutine C1 Waits for Mutex M2**
    1. `check_and_record(C1, M2)`
    2. `waiting_for[C1] = WaitTarget::Mutex(M2)`
    3. Look up who holds M2 → C2
    4. DFS: C1 → M2 → C2
    5. No cycle yet, continue
  | {near: top-center}
  nodes: {
    grid-columns: 4
    grid-gap: 40
    c1: "C1" {class: visited_node}
    c2: "C2" {class: graph_node}
    c3: "C3" {class: graph_node}
    c4: "C4" {class: graph_node}
    m1: "M1" {class: visited_node}
    m2: "M2" {class: visited_node}
  }
  edges: {
    c1 -> m1: "holds" {class: hold_edge}
    c2 -> m2: "holds" {class: hold_edge}
    c1 -> m2: "waits" {class: wait_edge}
  }
}
// === Step 4: C2 waits for M1 (CYCLE!) ===
step_4: {
  label: |md
    **Step 4: Coroutine C2 Waits for Mutex M1 — CYCLE DETECTED!**
    1. `check_and_record(C2, M1)` — **BEFORE adding to graph**
    2. `waiting_for[C2] = WaitTarget::Mutex(M1)` (tentative)
    3. Look up who holds M1 → C1
    4. **DFS begins**: C2 → M1 → C1
    5. Look up what C1 is waiting for → M2
    6. Continue DFS: C2 → M1 → C1 → M2
    7. Look up who holds M2 → C2
    8. **CYCLE FOUND!** C2 is already in visited set
    9. Return `Err(DeadlockError)` with chain: `[C2, M1, C1, M2, C2]`
    10. **Do NOT record the wait** — coroutine blocked from waiting
  | {near: top-center}
  nodes: {
    grid-columns: 4
    grid-gap: 40
    c1: "C1" {class: visited_node}
    c2: "C2" {class: cycle_node}
    c3: "C3" {class: graph_node}
    c4: "C4" {class: graph_node}
    m1: "M1" {class: cycle_node}
    m2: "M2" {class: cycle_node}
  }
  edges: {
    c1 -> m1: "holds" {class: hold_edge}
    c2 -> m2: "holds" {class: hold_edge}
    c1 -> m2: "waits" {class: wait_edge}
    c2 -> m1: "BLOCKED!" {class: wait_edge; style.stroke: "#FF0000"; style.stroke-width: 3}
  }
  cycle_highlight: {
    c2 -> m1 -> c1 -> m2 -> c2
  }
}
// === Legend ===
legend: {
  near: bottom-center
  node_legend: |md
    **Node Types:**
    - ○ White: Unvisited coroutine/mutex
    - ○ Yellow: Visited during DFS
    - ○ Red: Part of deadlock cycle
  |
  edge_legend: |md
    **Edge Types:**
    - Solid → : Holds (coroutine owns mutex)
    - Dashed - -> : Waits (coroutine waiting for mutex)
    - Red dashed: Would create deadlock
  |
}