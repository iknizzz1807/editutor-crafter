vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
}

graceful_shutdown_sequence: {
  shape: sequence_diagram
  label: "Graceful Yield/Resume Sequence: Coroutine Runtime Engine (x86_64 ABI)"

  user: User Code {
    shape: person
    style: {
      fill: "#DEE1EB"
      stroke: "#2c3e50"
      stroke-width: 2
    }
  }
  
  scheduler: Scheduler Context {
    style: {
      fill: "#C7F1FF"
      stroke: "#5CB8FF"
      stroke-width: 2
      bold: true
    }
  }
  
  coroutine: Coroutine Stack {
    style: {
      fill: "#E4DBFE"
      stroke: "#B5AFF6"
      stroke-width: 2
      bold: true
    }
  }

  # --- INITIAL RESUMPTION ---
  user -> scheduler: 1. resume(target_coroutine_t *tcb)
  user."Entry point: Transition from Ring 3 app logic to runtime scheduler" {
    style.font-size: 12
  }
  
  scheduler.logic -> scheduler.logic: 2. find_next_runnable(queue_mask=0xFF)
  
  scheduler.switch -> coroutine.exec: 3. context_switch(rip, rsp, rbp) {
    style: {
      stroke: "#2ecc71"
      stroke-width: 4
      bold: true
    }
  }
  
  coroutine."CPU State: [RIP: 0x4010A0, RSP: 0x7000, STATE: RUNNABLE]" {
    style: {
      font-color: "#27ae60"
      bold: true
      stroke: "#27ae60"
    }
  }

  # --- EXECUTION & YIELD TRIGGER ---
  Execution_Phase: "Execution Phase [Pre-emption Window]" {
    coroutine.exec -> coroutine.exec: 4. process_business_logic(ticks=200ms)
    
    scheduler.interrupt -> coroutine.yield: 5. SIG_YIELD_IRQ(vector=0x20) {
      style: {
        stroke: "#e67e22"
        stroke-dash: 3
        stroke-width: 2
      }
    }
  }

  # --- CONTEXT SAVING & YIELDING ---
  Context_Preservation: "Context Preservation [Atomic Section]" {
    coroutine.yield -> coroutine.yield: 6. yield_to(scheduler_ctx_t *sched)
    coroutine.yield -> coroutine.yield: 7. save_registers(rip, rsp, rbp, rbx)
    
    coroutine."TCB Serialization:\n[0x00]: RIP\n[0x08]: RSP\n[0x10]: RBP\n[0x18]: RBX" {
      style: {
        font-size: 11
        stroke: "#8e44ad"
      }
    }
    
    coroutine.yield -> scheduler.resume: 8. return_control(YIELD_SIGNAL_OK) {
      style: {
        stroke: "#e67e22"
        stroke-width: 3
        animated: true
      }
    }
  }

  # --- FINAL RESUMPTION ---
  scheduler.resume -> coroutine.exec: 9. resume(coroutine_ctx) {
    style: {
      stroke: "#2ecc71"
      stroke-width: 3
    }
  }

  coroutine."Context Restored: Execution resumes at next PC instruction" {
    style: {
      italic: true
      font-color: "#2980b9"
    }
  }

  # Global connection styling for technical clarity
  (coroutine -> scheduler)[*].style.stroke-width: 2
  (scheduler -> coroutine)[*].style.stroke-width: 2
}

# Implementation-Grade Specification Data
spec_details: {
  near: graceful_shutdown_sequence
  
  tcb_layout: ||md
### TCB Memory Layout (64-bit)
| Offset | Field | Size | Description |
| :--- | :--- | :--- | :--- |
| 0x00 | `uint64_t rip` | 8B | Instruction Pointer |
| 0x08 | `uint64_t rsp` | 8B | Stack Pointer |
| 0x10 | `uint64_t rbp` | 8B | Base Pointer |
| 0x18 | `uint64_t rbx` | 8B | Callee-saved Reg |
| 0x20 | `uint32_t stat`| 4B | Task State Flags |
||

  metadata: ||md
### Sequence Specification v1.2
- **Architecture**: x86_64 Cooperative Runtime
- **Mechanism**: Stackful Coroutine Yield
- **Memory Guard**: Redzone (128B) preserved below RSP
- **Invariants**: 
  - RAII guards must be preserved across `yield_now()`.
  - Scheduler stack must be isolated from Coroutine stack via TLS.
||
}

# Styling for the documentation containers
spec_details.tcb_layout: {
  style.fill: "#f8f9fa"
}
spec_details.metadata: {
  style.fill: "#fcf3cf"
}