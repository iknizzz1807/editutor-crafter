vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}
title: |md
  # Performance Benchmark Results Template
  **Coroutine Runtime vs Go/Tokio Baselines**
| {near: top-center}
direction: right
# Legend
legend: {
  label: Legend
  shape: rectangle
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  pass_indicator: "✓ PASS" {
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
    style.font-color: "#155724"
  }
  fail_indicator: "✗ FAIL" {
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
    style.font-color: "#721C24"
  }
  within_2x: "Within 2x of target" {
    style.fill: "#FFF3CD"
    style.stroke: "#FFC107"
    style.font-color: "#856404"
  }
  pass_indicator -> fail_indicator: "Status Indicators" {style.opacity: 0}
}
# Benchmark Categories
spawn_section: {
  label: "Spawn Throughput"
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  your_runtime_spawn: "Your Runtime\n_____ coroutines/sec" {
    shape: rectangle
    style.fill: white
    style.stroke: "#1976D2"
    style.stroke-dash: 3
  }
  go_spawn: "Go Runtime\n2-5M coroutines/sec" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  tokio_spawn: "Tokio Runtime\n1-3M coroutines/sec" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  target_spawn: "Target: >500K/sec" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.bold: true
  }
  spawn_status: "Status: _____" {
    shape: rectangle
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
  }
  your_runtime_spawn -> go_spawn: "Compare" {style.stroke-dash: 3; style.stroke: "#90CAF9"}
  your_runtime_spawn -> tokio_spawn: "Compare" {style.stroke-dash: 3; style.stroke: "#90CAF9"}
  your_runtime_spawn -> target_spawn: "Validate" {style.stroke: "#FFA726"; style.bold: true}
  target_spawn -> spawn_status: "Result" {style.stroke: "#66BB6A"}
}
channel_section: {
  label: "Channel Throughput"
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  your_runtime_channel: "Your Runtime\n_____ messages/sec" {
    shape: rectangle
    style.fill: white
    style.stroke: "#7B1FA2"
    style.stroke-dash: 3
  }
  go_channel: "Go Runtime\n5-20M messages/sec" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  tokio_channel: "Tokio Runtime\n5-15M messages/sec" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  target_channel: "Target: >2M/sec" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.bold: true
  }
  channel_status: "Status: _____" {
    shape: rectangle
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
  }
  your_runtime_channel -> go_channel: "Compare" {style.stroke-dash: 3; style.stroke: "#CE93D8"}
  your_runtime_channel -> tokio_channel: "Compare" {style.stroke-dash: 3; style.stroke: "#CE93D8"}
  your_runtime_channel -> target_channel: "Validate" {style.stroke: "#FFA726"; style.bold: true}
  target_channel -> channel_status: "Result" {style.stroke: "#66BB6A"}
}
mutex_section: {
  label: "Mutex Throughput"
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  your_runtime_mutex: "Your Runtime\n_____ operations/sec" {
    shape: rectangle
    style.fill: white
    style.stroke: "#388E3C"
    style.stroke-dash: 3
  }
  go_mutex: "Go Runtime\n1-5M operations/sec" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  tokio_mutex: "Tokio Runtime\n1-3M operations/sec" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  target_mutex: "Target: >500K/sec" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.bold: true
  }
  mutex_status: "Status: _____" {
    shape: rectangle
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
  }
  your_runtime_mutex -> go_mutex: "Compare" {style.stroke-dash: 3; style.stroke: "#81C784"}
  your_runtime_mutex -> tokio_mutex: "Compare" {style.stroke-dash: 3; style.stroke: "#81C784"}
  your_runtime_mutex -> target_mutex: "Validate" {style.stroke: "#FFA726"; style.bold: true}
  target_mutex -> mutex_status: "Result" {style.stroke: "#66BB6A"}
}
ctx_switch_section: {
  label: "Context Switch Overhead"
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  your_runtime_switch: "Your Runtime\n_____ ns/switch" {
    shape: rectangle
    style.fill: white
    style.stroke: "#E65100"
    style.stroke-dash: 3
  }
  go_switch: "Go Runtime\n20-100 ns/switch" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  tokio_switch: "Tokio Runtime\n50-150 ns/switch" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  target_switch: "Target: <200 ns" {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.bold: true
  }
  switch_status: "Status: _____" {
    shape: rectangle
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
  }
  your_runtime_switch -> go_switch: "Compare" {style.stroke-dash: 3; style.stroke: "#FFB74D"}
  your_runtime_switch -> tokio_switch: "Compare" {style.stroke-dash: 3; style.stroke: "#FFB74D"}
  your_runtime_switch -> target_switch: "Validate" {style.stroke: "#FFA726"; style.bold: true}
  target_switch -> switch_status: "Result" {style.stroke: "#66BB6A"}
}
# Section connections (visual grouping)
spawn_section -> channel_section: "" {style.opacity: 0}
channel_section -> mutex_section: "" {style.opacity: 0}
mutex_section -> ctx_switch_section: "" {style.opacity: 0}
# Summary
summary: {
  label: |md
    ## Summary
    **Pass/Fail Criteria:**
    - All benchmarks must meet minimum targets
    - Performance should be within 2× of Go/Tokio
    **Fill in your results:**
    1. Run `cargo bench`
    2. Record actual values
    3. Mark PASS/FAIL for each
  |
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  style.stroke-width: 2
  overall_status: "Overall: _____ / 4 PASS" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.bold: true
    style.font-size: 20
  }
}
ctx_switch_section -> summary: "Aggregate" {style.stroke: "#1565C0"; style.stroke-width: 2}
legend -> spawn_section: "Reference" {style.opacity: 0}