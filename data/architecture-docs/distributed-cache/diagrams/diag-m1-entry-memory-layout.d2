direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Cache Entry Memory Layout {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
entry_struct: {
  shape: sql_table
  label: "struct Entry (cache.go:23)"
  f0: "0x00 | *byte      | Key        // slice header 16B"
  f1: "0x10 | *byte      | Value      // slice header 24B"
  f2: "0x28 | time.Time  | CreatedAt  // 24 bytes"
  f3: "0x40 | time.Time  | ExpiresAt  // 24 bytes"
  f4: "0x58 | *Entry     | Prev       // LRU backward"
  f5: "0x60 | *Entry     | Next       // LRU forward"
  f6: "0x68 | uint64     | Frequency  // LFU counter"
  f7: "0x70 | time.Time  | Recency    // LFU tie-break"
  f8: "0x88 | int64      | Size       // Total bytes"
  total: "Total: 144 bytes (struct only)"
  style.stroke: "#4A90D9"
}
heap_region: {
  label: "Heap Memory (separate allocations)"
  direction: right
  style: {
    fill: "#F5F5F5"
    stroke: "#CCCCCC"
    stroke-dash: 3
  }
  key_data: {
    label: "Key Data"
    shape: rectangle
    width: 120
    style: {
      fill: "#FFE4B5"
      stroke: "#DAA520"
    }
    code: |'go
      []byte("user:12345")
      len=11, cap=16
    '|
  }
  value_data: {
    label: "Value Data"
    shape: rectangle
    width: 180
    style: {
      fill: "#E6E6FA"
      stroke: "#9370DB"
    }
    code: |'go
      []byte(json_payload)
      len=2048, cap=2048
    '|
  }
}
overhead_breakdown: {
  label: "Memory Overhead Analysis"
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  struct_box: {
    label: "Struct Fields"
    shape: rectangle
    width: 160
    style: {
      fill: "#E8F4FD"
      stroke: "#4A90D9"
    }
    code: |'text
      Metadata: 144 bytes
      Pointers:     56 bytes
      Timestamps:   72 bytes
      Counters:     16 bytes
    '|
  }
  data_box: {
    label: "Actual Data"
    shape: rectangle
    width: 160
    style: {
      fill: "#FFF8DC"
      stroke: "#DAA520"
    }
    code: |'text
      Key:   11 bytes + 16 header
      Value: 2048 bytes + 24 header
      Total: 2099 bytes
    '|
  }
  ratio_box: {
    label: "Overhead Ratio"
    shape: rectangle
    width: 160
    style: {
      fill: "#FFE4E1"
      stroke: "#CD5C5C"
    }
    code: |'text
      Entry:   144 bytes
      Data:    2099 bytes
      Total:   2243 bytes
      Overhead: 6.4%
    '|
  }
}
pointer_diagram: {
  label: "Pointer Relationships"
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  entry_node: {
    label: "Entry Struct"
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#4A90D9"
      stroke-width: 2
    }
    width: 100
  }
  key_node: {
    label: "Key\n\"user:12345\""
    shape: rectangle
    style: {
      fill: "#FFE4B5"
      stroke: "#DAA520"
    }
    width: 90
  }
  value_node: {
    label: "Value\n{json...}"
    shape: rectangle
    style: {
      fill: "#E6E6FA"
      stroke: "#9370DB"
    }
    width: 90
  }
  prev_node: {
    label: "Prev Entry"
    shape: rectangle
    style: {
      fill: "#98FB98"
      stroke: "#228B22"
    }
    width: 80
  }
  next_node: {
    label: "Next Entry"
    shape: rectangle
    style: {
      fill: "#98FB98"
      stroke: "#228B22"
    }
    width: 80
  }
  entry_node.Key -> key_node: "*byte"
  entry_node.Value -> value_node: "*byte"
  entry_node.Prev -> prev_node: "*Entry"
  entry_node.Next -> next_node: "*Entry"
}
lru_list_context: {
  label: "LRU List Context"
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  lru_tail: {
    label: "LRU (tail)"
    shape: rectangle
    style: {
      fill: "#FFB6C1"
      stroke: "#DC143C"
    }
    width: 70
  }
  middle_entry: {
    label: "This Entry"
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#4A90D9"
      stroke-width: 3
    }
    width: 80
  }
  lru_head: {
    label: "MRU (head)"
    shape: rectangle
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
    }
    width: 70
  }
  lru_tail -> middle_entry: "Next"
  middle_entry -> lru_head: "Next"
  lru_head -> middle_entry: "Prev"
  middle_entry -> lru_tail: "Prev"
}
lfu_context: {
  label: "LFU Tracking"
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  freq_1: {
    label: "Freq=1\n(Bucket)"
    shape: rectangle
    style: {
      fill: "#DDA0DD"
      stroke: "#8B008B"
    }
    width: 80
  }
  entry_in_bucket: {
    label: "Entry\n(Freq=1)"
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#4A90D9"
    }
    width: 70
  }
  freq_counter: {
    label: "uint64\nFrequency"
    shape: rectangle
    style: {
      fill: "#87CEEB"
      stroke: "#4682B4"
    }
    width: 80
  }
  freq_1 -> entry_in_bucket: "contains"
  entry_in_bucket -> freq_counter: "tracks"
}
entry_struct -> heap_region: "pointers to heap"
heap_region -> overhead_breakdown
overhead_breakdown -> pointer_diagram
pointer_diagram -> lru_list_context
lru_list_context -> lfu_context
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#999999"
  }
  code: |'text
    Colors indicate field purpose:
    □ Blue   - Core struct fields
    □ Gold   - Key data (user-provided)
    □ Purple - Value data (user-provided)
    □ Green  - LRU list pointers
    □ Pink   - LFU tracking fields
  '|
}