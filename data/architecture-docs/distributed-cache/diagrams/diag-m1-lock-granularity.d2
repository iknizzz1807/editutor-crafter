direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Lock Granularity: Single vs Sharded Locks
| {
  near: top-center
  shape: rectangle
  style.stroke: transparent
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  single_lock: {
    direction: down
    label: "Single Global Lock (Mutex Chokepoint)"
    
    global_lock: {
      label: "Global Lock (sync.RWMutex)"
      shape: rectangle
      width: 280
      style: {
        fill: "#ffcccc"
        stroke: "#cc0000"
        stroke-width: 2
      }
    }

    goroutines_single: {
      direction: right
      label: "Waiting Goroutines"
      style.stroke-dash: 3
      g1: "G1\nGET" { shape: circle; style.fill: "#ffe6e6" }
      g2: "G2\nSET" { shape: circle; style.fill: "#ffe6e6" }
      g3: "G3\nGET" { shape: circle; style.fill: "#ffe6e6" }
      g4: "G4\nDEL" { shape: circle; style.fill: "#ffe6e6" }
      g5: "G5\nSET" { shape: circle; style.fill: "#ffe6e6" }
    }

    contention_single: {
      label: "Serialization Queue"
      shape: queue
      width: 260
      style: {
        fill: "#ffdddd"
        stroke: "#cc0000"
        stroke-dash: 3
      }
    }

    goroutines_single.g1 -> global_lock: "wait" { style.stroke: red; style.stroke-dash: 3 }
    goroutines_single.g2 -> global_lock: "wait" { style.stroke: red; style.stroke-dash: 3 }
    goroutines_single.g3 -> global_lock: "blocked" { style.stroke: red; style.stroke-dash: 3 }
    global_lock -> contention_single: "Head-of-Line Blocking"
  }

  sharded_locks: {
    direction: down
    label: "Sharded Locks (Parallel Execution)"
    
    shard_container: {
      direction: right
      label: ""
      style.stroke: transparent
      
      shard0: "Shard 0\n(0-25%)" { shape: rectangle; width: 100; style: { fill: "#ccffcc"; stroke: "#006600"; stroke-width: 2 } }
      shard1: "Shard 1\n(25-50%)" { shape: rectangle; width: 100; style: { fill: "#ccffcc"; stroke: "#006600"; stroke-width: 2 } }
      shard2: "Shard 2\n(50-75%)" { shape: rectangle; width: 100; style: { fill: "#ccffcc"; stroke: "#006600"; stroke-width: 2 } }
      shard3: "Shard 3\n(75-100%)" { shape: rectangle; width: 100; style: { fill: "#ccffcc"; stroke: "#006600"; stroke-width: 2 } }
    }

    goroutines_sharded: {
      direction: right
      label: "Parallel Goroutines"
      style.stroke-dash: 3
      sg1: "G1\nGET(a)" { shape: circle; style.fill: "#e6ffe6" }
      sg2: "G2\nSET(m)" { shape: circle; style.fill: "#e6ffe6" }
      sg3: "G3\nGET(x)" { shape: circle; style.fill: "#e6ffe6" }
      sg4: "G4\nDEL(p)" { shape: circle; style.fill: "#e6ffe6" }
      sg5: "G5\nSET(b)" { shape: circle; style.fill: "#e6ffe6" }
    }

    goroutines_sharded.sg1 -> shard_container.shard0: "OK" { style.stroke: green }
    goroutines_sharded.sg2 -> shard_container.shard1: "OK" { style.stroke: green }
    goroutines_sharded.sg3 -> shard_container.shard3: "OK" { style.stroke: green }
    goroutines_sharded.sg4 -> shard_container.shard2: "OK" { style.stroke: green }
    goroutines_sharded.sg5 -> shard_container.shard0: "wait\n(collision)" { style.stroke: orange; style.stroke-dash: 3 }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  comparison: {
    label: "Implementation Strategy (cache.go)"
    shape: rectangle
    width: 600
    style.fill: "#f5f5f5"
    code: |'go
      // Single Global Lock
      type Cache struct {
          mu      sync.RWMutex    // ONE lock for entire cache
          entries map[string]*Entry
      }

      // Sharded Locks (Striping)
      type ShardedCache struct {
          shards [16]*CacheShard  // N locks, one per shard
      }

      type CacheShard struct {
          mu      sync.RWMutex    // Lock per shard
          entries map[string]*Entry
      }

      func (c *ShardedCache) getShard(key string) *CacheShard {
          hash := fnv64(key)
          return c.shards[hash % 16]
      }
    '|
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  metrics: {
    label: "Benchmark: Throughput Impact (1000 cores)"
    shape: rectangle
    width: 600
    style.fill: "#fafafa"
    # CRITICAL: Use |' to allow pipes inside the markdown table
    table: |'md
      | Metric              | Global Lock    | 16 Shards      | 256 Shards     |
      |---------------------|----------------|----------------|----------------|
      | Lock Contention     | CRITICAL       | LOW            | NEGLIGIBLE     |
      | Throughput (ops/s)  | ~50K           | ~400K          | ~1.2M          |
      | P99 Latency         | 15.0ms         | 2.1ms          | 0.8ms          |
      | Memory Efficiency   | 100%           | 98%            | 92%            |
      | Code Complexity     | O(1)           | O(N)           | O(N)           |
    '|
  }
}

legend: {
  near: bottom-right
  direction: down
  label: "Visual Key"
  high_contention: "High Contention Path" {
    shape: rectangle
    style.fill: "#ffcccc"
    style.stroke: "#cc0000"
  }
  low_contention: "Low Contention Path" {
    shape: rectangle
    style.fill: "#ccffcc"
    style.stroke: "#006600"
  }
  wait_state: "Waiting/Blocked" {
    shape: rectangle
    style.fill: "#ffeecc"
    style.stroke: "#cc6600"
    style.stroke-dash: 3
  }
}

# Cross-container transition annotation
row1.single_lock -> row1.sharded_locks: "Optimize via\nPartitioning" {
  style.stroke: "#666"
  style.stroke-width: 2
  style.stroke-dash: 5
}