    hm_desc: |md
      **O(1) Lookup**
      Direct pointer to node
      No traversal needed
    | {
      shape: text
      style: {
        font-size: 12
        font-color: "#1565C0"
      }
    }
    hm_entry1: {
      shape: rectangle
      label: "\"user:123\""
      style: {
        fill: "#BBDEFB"
        stroke: "#1565C0"
        font: mono
        font-size: 11
      }
    }
    hm_entry2: {
      shape: rectangle
      label: "\"product:456\""
      style: {
        fill: "#BBDEFB"
        stroke: "#1565C0"
        font: mono
        font-size: 11
      }
    }
    hm_entry3: {
      shape: rectangle
      label: "\"session:789\""
