title: LRU Cache Architecture {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: "O(1) Operations via Hashmap + Doubly Linked List" {
  near: top-center
  shape: text
  style: {
    font-size: 16
    italic: true
    font-color: "#666666"
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
