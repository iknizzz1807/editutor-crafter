        width: 200
        style: {
          fill: transparent
          stroke: transparent
        }
      }
      tail_ptr: {
        label: "TAIL → Node D"
        style: {
          fill: "#EF9A9A"
          stroke: "#C62828"
          font: mono
          font-size: 10
        }
      }
    }
  }
}
hm_entry1 -> node1: "ptr" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    stroke-dash: 3
  }
}
hm_entry2 -> node2: "ptr" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    stroke-dash: 3
  }
}
hm_entry3 -> node3: "ptr" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    stroke-dash: 3
  }
}
hm_entry4 -> node4: "ptr" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    stroke-dash: 3
  }
}
operations: {
  direction: down
  label: "OPERATION COMPLEXITY"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
    border-radius: 8
  }
  op_row: "" {
    direction: right
    op_get: {
      direction: down
      label: "GET(key)"
      style: {
        fill: "#FFE0B2"
        stroke: "#E65100"
        border-radius: 4
      }
      get_steps: |md
        1. Hashmap lookup → O(1)
        2. Check TTL → O(1)
        3. Move to front → O(1)
        4. Return value
        **Total: O(1)**
      | {
        shape: text
        style: {
          font-size: 10
          font: mono
        }
      }
    }
    op_set: {
      direction: down
      label: "SET(key, value)"
      style: {
        fill: "#FFE0B2"
        stroke: "#E65100"
        border-radius: 4
      }
      set_steps: |md
        1. Hashmap lookup → O(1)
        2. If exists: update + move front
        3. If new: check capacity
        4. Evict tail if needed → O(1)
        5. Insert at front → O(1)
        **Total: O(1)**
      | {
        shape: text
        style: {
          font-size: 10
          font: mono
        }
      }
    }
    op_evict: {
      direction: down
      label: "evictLRU()"
      style: {
        fill: "#FFCDD2"
        stroke: "#C62828"
        border-radius: 4
      }
      evict_steps: |md
        1. Get tail pointer → O(1)
        2. Update tail.Prev.Next = null
        3. Update tail = tail.Prev
        4. Delete from hashmap → O(1)
        **Total: O(1)**
      | {
        shape: text
        style: {
          font-size: 10
          font: mono
        }
      }
    }
  }
}
key_insight: {
  label: |md
    ### 🔑 Key Insight: Why Doubly Linked?
    **Singly linked**: Removal requires finding predecessor → O(n) traversal
    **Doubly linked**: Each node has `Prev` pointer → O(1) removal from any position
    This is the critical optimization that makes LRU cache operations constant time.
  |
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
    border-radius: 8
  }
}
memory_layout: {
  direction: down
  label: "Entry Struct (cache.go)"
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    stroke-width: 2
    border-radius: 8
  }
  struct_def: |'go
    type Entry struct {
        Key       []byte      // The lookup key
        Value     []byte      // The cached data
        CreatedAt time.Time   // When entry was created
        ExpiresAt time.Time   // TTL expiration (zero = no expiry)
        // LRU tracking - O(1) reordering
        Prev      *Entry      // Previous node in list
        Next      *Entry      // Next node in list
        // LFU tracking (alternative policy)
        Frequency uint64      // Access count
        Recency   time.Time   // Last access time
        Size      int64       // Total bytes used
    }
  '|
}