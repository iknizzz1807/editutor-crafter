          label: |md
            **Prev:** null
            **Next:** → Node B
            **Value:** "alice"
          |
          shape: text
          style: {
            font-size: 9
            font: mono
          }
        }
      }
      arrow1: {
        shape: text
        label: "⟷"
        style: {
          font-size: 20
          font-color: "#2E7D32"
        }
      }
      node2: {
        direction: down
        label: "Node B\nproduct:456"
        style: {
          fill: "#C8E6C9"
          stroke: "#2E7D32"
          stroke-width: 2
          border-radius: 4
        }
        node2_data: {
          label: |md
            **Prev:** ← Node A
            **Next:** → Node C
            **Value:** "widget"
          |
          shape: text
          style: {
            font-size: 9
            font: mono
          }
        }
      }
      arrow2: {
        shape: text
        label: "⟷"
        style: {
          font-size: 20
          font-color: "#2E7D32"
        }
      }
      node3: {
        direction: down
        label: "Node C\nsession:789"
        style: {
          fill: "#C8E6C9"
          stroke: "#2E7D32"
          stroke-width: 2
          border-radius: 4
        }
        node3_data: {
          label: |md
            **Prev:** ← Node B
            **Next:** → Node D
            **Value:** "sess_xyz"
          |
          shape: text
