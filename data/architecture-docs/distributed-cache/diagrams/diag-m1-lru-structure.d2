      node4: {
        direction: down
        label: "Node D\nconfig:abc"
        style: {
          fill: "#FFCDD2"
          stroke: "#C62828"
          stroke-width: 2
          border-radius: 4
        }
        node4_data: {
          label: |md
            **Prev:** ← Node C
            **Next:** null
            **Value:** "{...}"
          |
