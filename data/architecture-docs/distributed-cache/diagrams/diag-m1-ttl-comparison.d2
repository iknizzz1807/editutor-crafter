direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TTL Expiration Strategies Comparison
  Lazy vs Active vs Hybrid Cleanup
| {near: top-center}
row_strategies: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lazy: {
    direction: down
    label: "LAZY EVICTION\n(Check on Access)"
    style.stroke: "#DC2626"
    style.fill: "#FEF2F2"
    lazy_timeline: {
      direction: down
      label: "Timeline"
      width: 280
      t0: {
        label: "T=0ms"
        style.fill: "#D1FAE5"
        style.stroke: "#059669"
        entry_a: "user:1 → 'alice'\nExpiresAt: T+100ms"
      }
      t50: {
        label: "T=50ms"
        style.fill: "#FEF3C7"
        style.stroke: "#D97706"
        expired_entries: "Entries expired but\nNOT removed!"
        code: |'go
// Get() checks TTL
if now.After(entry.ExpiresAt) {
    removeEntry(entry)  // Lazy removal
    return nil, false
}
'|
      }
      t100: {
        label: "T=100ms+"
        style.fill: "#FEE2E2"
        style.stroke: "#DC2626"
        memory_leak: "EXPIRED ENTRIES\nLINGER IN MEMORY\n(Leak Risk!)"
      }
      t0 -> t50 -> t100
    }
    lazy_pros_cons: {
      direction: down
      label: "Trade-offs"
      width: 280
      pros: {
        label: "PROS"
        style.fill: "#D1FAE5"
        p1: "✓ No background goroutines"
        p2: "✓ Eviction only when needed"
        p3: "✓ Zero CPU when idle"
      }
      cons: {
        label: "CONS"
        style.fill: "#FEE2E2"
        c1: "✗ Memory leak if never accessed"
        c2: "✗ Expired entries waste capacity"
        c3: "✗ Unpredictable cleanup timing"
      }
    }
  }
  active: {
    direction: down
    label: "ACTIVE CLEANUP\n(Background Scanner)"
    style.stroke: "#F59E0B"
    style.fill: "#FFFBEB"
    active_timeline: {
      direction: down
      label: "Timeline"
      width: 280
      a_t0: {
        label: "Background Goroutine"
        style.fill: "#DBEAFE"
        style.stroke: "#2563EB"
        code: |'go
go func() {
  ticker := time.NewTicker(interval)
  for range ticker.C {
    c.cleanupExpired()
  }
}()
'|
      }
      a_scan: {
        label: "Cleanup Cycle"
        style.fill: "#FEF3C7"
        style.stroke: "#D97706"
        scan: "Iterate ALL entries\nCheck ExpiresAt\nRemove if expired"
      }
      a_spike: {
        label: "CPU Spike!"
        style.fill: "#FEE2E2"
        style.stroke: "#DC2626"
        spike: "With 100K entries:\n• Full scan = O(n)\n• Lock held during scan\n• Blocks Get/Set ops"
      }
      a_t0 -> a_scan -> a_spike
    }
    active_pros_cons: {
      direction: down
      label: "Trade-offs"
      width: 280
      a_pros: {
        label: "PROS"
        style.fill: "#D1FAE5"
        ap1: "✓ Bounded memory usage"
        ap2: "✓ Predictable cleanup"
        ap3: "✓ No stale data returned"
      }
      a_cons: {
        label: "CONS"
        style.fill: "#FEE2E2"
        ac1: "✗ CPU spikes on large caches"
        ac2: "✗ Lock contention during scan"
        ac3: "✗ Background goroutine overhead"
      }
    }
  }
  hybrid: {
    direction: down
    label: "HYBRID APPROACH\n(Production-Grade)"
    style.stroke: "#059669"
    style.fill: "#ECFDF5"
    hybrid_flow: {
      direction: down
      label: "Combined Strategy"
      width: 320
      h_lazy: {
        label: "1. Lazy Eviction (Always)"
        style.fill: "#DBEAFE"
        style.stroke: "#2563EB"
        code: |'go
func (c *Cache) Get(key string) ([]byte, bool) {
    // Check TTL on every access
    if expired(entry) {
        c.removeEntry(entry)
        c.maybeScheduleCleanup()
        return nil, false
    }
    return entry.Value, true
}
'|
      }
      h_trigger: {
        label: "2. Trigger Conditions"
        style.fill: "#FEF3C7"
        style.stroke: "#D97706"
        trigger: |md
**Schedule cleanup if:**
- `expiredRatio > threshold` (e.g., 10%)
- `timeSinceCleanup > interval`
- `memoryPressure > 90%`
|
      }
      h_active: {
        label: "3. Background Cleanup (On-Demand)"
        style.fill: "#D1FAE5"
        style.stroke: "#059669"
        code: |'go
func (c *Cache) cleanupExpired() {
    c.mu.Lock()
    defer c.mu.Unlock()
    now := time.Now()
    for key, entry := range c.entries {
        if !entry.ExpiresAt.IsZero() && 
           now.After(entry.ExpiresAt) {
            c.removeEntry(entry)
        }
    }
}
'|
      }
      h_lazy -> h_trigger -> h_active
    }
    hybrid_config: {
      direction: down
      label: "Configuration"
      width: 320
      config: {
        shape: sql_table
        label: "CleanupConfig (cache.go)"
        f0: "CleanupInterval | time.Duration | 5m (max wait)"
        f1: "CleanupThreshold | float64 | 0.10 (10% expired)"
        f2: "MemoryThreshold | float64 | 0.90 (90% full)"
        sz: "Recommended: interval=5m, threshold=10%"
      }
    }
  }
}
row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: {
    direction: down
    label: "Strategy Comparison Matrix"
    width: 900
    matrix: {
      shape: sql_table
      label: "TTL Cleanup Strategies"
      h1: "Metric | Lazy | Active | Hybrid"
      r1: "Memory Bounded | ✗ No | ✓ Yes | ✓ Yes"
      r2: "CPU Efficient | ✓ Yes | ✗ Spikes | ✓ Yes"
      r3: "Lock Contention | ✓ Low | ✗ High | ✓ Low"
      r4: "Implementation | Simple | Simple | Moderate"
      r5: "Production Ready | ✗ Risky | △ OK | ✓ Best"
      r6: "Used By | - | Redis | Memcached, Redis"
    }
  }
}
row_visual: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  visual: {
    direction: down
    label: "Memory Usage Over Time"
    width: 900
    lazy_graph: {
      label: "Lazy: Memory grows until expired keys accessed"
      direction: right
      baseline: "0%"
      peak: "100%\n(Leak!)"
      style.fill: "#FEE2E2"
      baseline -> peak: "Expired entries accumulate"
    }
    active_graph: {
      label: "Active: Sawtooth pattern from periodic scans"
      direction: right
      a_base: "10%"
      a_peak: "30%"
      a_drop: "10%"
      style.fill: "#FEF3C7"
      a_base -> a_peak: "Expired accumulate"
      a_peak -> a_drop: "Cleanup scan\n(CPU spike)"
    }
    hybrid_graph: {
      label: "Hybrid: Bounded with adaptive cleanup"
      direction: right
      h_base: "10%"
      h_warn: "15%"
      h_trigger: "12%"
      style.fill: "#D1FAE5"
      h_base -> h_warn: "Expired accumulate"
      h_warn -> h_trigger: "Threshold triggers\ncleanup (async)"
    }
  }
}
legend: {
  near: bottom-right
  l1: "🔴 Red = Risk/Problem"
  l2: "🟡 Yellow = Caution/Trade-off"
  l3: "🟢 Green = Good/Recommended"
  l4: "🔵 Blue = Implementation Code"
  style.fill: "#F3F4F6"
  style.stroke: "#9CA3AF"
}