direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    hot: "#E53935"
    warm: "#FB8C00"
    cool: "#43A047"
    cold: "#1E88E5"
    header: "#37474F"
  }
}

title: {
  label: "# Key Distribution: Virtual Nodes Effect on Load Balance"
  style.stroke: transparent
  style.fill: transparent
  style.font-size: 24
}

comparison_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  without_vnodes: {
    direction: down
    label: "WITHOUT VIRTUAL NODES"
    
    label_problem: {
      label: "❌ HIGH VARIANCE — Hotspots"
      style: {
        fill: ${colors.hot}
        font-color: white
        stroke: transparent
        bold: true
      }
    }

    ring_naive: {
      label: "Hash Ring (Single Position per Node)"
      ring_viz: {
        direction: down
        style: {
          fill: "#ECEFF1"
          stroke: "#90A4AE"
        }
        arc_a: {
          label: "Node A (8% of keys)"
          width: 180
          style: {
            fill: ${colors.cold}
            font-color: white
          }
        }
        arc_b: {
          label: "Node B (54% of keys)"
          width: 60
          style: {
            fill: ${colors.hot}
            font-color: white
          }
        }
        arc_c: {
          label: "Node C (38% of keys)"
          width: 200
          style: {
            fill: ${colors.warm}
            font-color: white
          }
        }
      }
    }

    heatmap_naive: {
      label: "Load Heatmap"
      direction: right
      style: {
        fill: transparent
        stroke: "#B0BEC5"
      }
      h1: { width: 40; height: 40; style.fill: ${colors.cold} }
      h2: { width: 40; height: 40; style.fill: ${colors.hot} }
      h3: { width: 40; height: 40; style.fill: ${colors.hot} }
      h4: { width: 40; height: 40; style.fill: ${colors.warm} }
      h5: { width: 40; height: 40; style.fill: ${colors.cold} }
      h6: { width: 40; height: 40; style.fill: ${colors.hot} }
      h7: { width: 40; height: 40; style.fill: ${colors.warm} }
      h8: { width: 40; height: 40; style.fill: ${colors.cold} }
    }

    stats_naive: {
      content: |'md
        **Variance: 40%**
        Max: 54% | Min: 8%
        Hotspot: Node B (6.75x overloaded)
      '|
      style: {
        fill: "#FFEBEE"
        stroke: ${colors.hot}
      }
    }
  }

  spacer: {
    width: 50
    style.stroke: transparent
    style.fill: transparent
  }

  with_vnodes: {
    direction: down
    label: "WITH VIRTUAL NODES"
    
    label_success: {
      label: "✓ LOW VARIANCE — Balanced"
      style: {
        fill: ${colors.cool}
        font-color: white
        stroke: transparent
        bold: true
      }
    }

    ring_vnodes: {
      label: "Hash Ring (150 VNodes per Node)"
      ring_viz_v: {
        direction: down
        style: {
          fill: "#ECEFF1"
          stroke: "#90A4AE"
        }
        arc_a2: {
          label: "Node A (150 positions) | 33%"
          width: 130
          style: {
            fill: ${colors.cool}
            font-color: white
          }
        }
        arc_b2: {
          label: "Node B (150 positions) | 34%"
          width: 130
          style: {
            fill: ${colors.cool}
            font-color: white
          }
        }
        arc_c2: {
          label: "Node C (150 positions) | 33%"
          width: 130
          style: {
            fill: ${colors.cool}
            font-color: white
          }
        }
      }
    }

    heatmap_vnodes: {
      label: "Load Heatmap"
      direction: right
      style: {
        fill: transparent
        stroke: "#B0BEC5"
      }
      v1: { width: 40; height: 40; style.fill: ${colors.cool} }
      v2: { width: 40; height: 40; style.fill: ${colors.cool} }
      v3: { width: 40; height: 40; style.fill: ${colors.cool} }
      v4: { width: 40; height: 40; style.fill: ${colors.cool} }
      v5: { width: 40; height: 40; style.fill: ${colors.cool} }
      v6: { width: 40; height: 40; style.fill: ${colors.cool} }
      v7: { width: 40; height: 40; style.fill: ${colors.cool} }
      v8: { width: 40; height: 40; style.fill: ${colors.cool} }
    }

    stats_vnodes: {
      content: |'md
        **Variance: 5%**
        Max: 34% | Min: 33%
        Balanced: All nodes within 1%
      '|
      style: {
        fill: "#E8F5E9"
        stroke: ${colors.cool}
      }
    }
  }
}

footer_section: "" {
  direction: down
  style.fill: transparent
  style.stroke: transparent

  legend_row: "" {
    direction: right
    label: "Heatmap Legend"
    style: {
      fill: transparent
      stroke: "#90A4AE"
    }
    l1: {
      label: "Cold (<20%)"
      width: 120
      height: 30
      style: { fill: ${colors.cold}; font-color: white }
    }
    l2: {
      label: "Cool (20-35%)"
      width: 120
      height: 30
      style: { fill: ${colors.cool}; font-color: white }
    }
    l3: {
      label: "Warm (35-50%)"
      width: 120
      height: 30
      style: { fill: ${colors.warm}; font-color: white }
    }
    l4: {
      label: "Hot (>50%)"
      width: 120
      height: 30
      style: { fill: ${colors.hot}; font-color: white }
    }
  }

  explanation_box: {
    label: "Why Virtual Nodes Work"
    body: |'md
      Hash functions aren't perfectly uniform. With 1 position per node, random placement causes severe imbalance. 
      With 150 positions, the Law of Large Numbers ensures each node's total arc length converges to 1/N of the ring.
    '|
    style: {
      fill: "#FFF8E1"
      stroke: "#FFB300"
    }
    width: 800
  }
}

comparison_row -> footer_section: "Analysis Results" {
  style.stroke: "#B0BEC5"
}