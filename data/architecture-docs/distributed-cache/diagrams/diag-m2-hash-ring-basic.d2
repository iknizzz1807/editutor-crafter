direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Consistent Hash Ring with Virtual Nodes
  Ring space: 0 to 2³²-1 (uint32)
| {near: top-center}
