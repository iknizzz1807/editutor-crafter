  label: "Hash Ring (0 → 2³²-1)"
  ring_segment_top: {
    shape: rectangle
    label: ""
    width: 600
    height: 200
    style.fill: transparent
    style.stroke: "#4A90D9"
    style.stroke-width: 3
    vnode_a1: {
      label: "A₀"
      shape: circle
      style.fill: "#E74C3C"
      style.stroke: "#C0392B"
      style.font-color: white
      width: 40
    }
    vnode_a2: {
      label: "A₁"
      shape: circle
      style.fill: "#E74C3C"
      style.stroke: "#C0392B"
      style.font-color: white
      width: 40
    }
    vnode_a3: {
      label: "A₂"
      shape: circle
      style.fill: "#E74C3C"
      style.stroke: "#C0392B"
      style.font-color: white
      width: 40
    }
    vnode_b1: {
      label: "B₀"
      shape: circle
      style.fill: "#27AE60"
      style.stroke: "#1E8449"
      style.font-color: white
      width: 40
    }
    vnode_b2: {
      label: "B₁"
      shape: circle
      style.fill: "#27AE60"
      style.stroke: "#1E8449"
      style.font-color: white
      width: 40
    }
    vnode_b3: {
      label: "B₂"
      shape: circle
      style.fill: "#27AE60"
      style.stroke: "#1E8449"
      style.font-color: white
      width: 40
    }
    vnode_c1: {
      label: "C₀"
      shape: circle
      style.fill: "#9B59B6"
      style.stroke: "#7D3C98"
      style.font-color: white
      width: 40
    }
    vnode_c2: {
      label: "C₁"
      shape: circle
      style.fill: "#9B59B6"
      style.stroke: "#7D3C98"
      style.font-color: white
      width: 40
    }
    vnode_c3: {
      label: "C₂"
      shape: circle
      style.fill: "#9B59B6"
      style.stroke: "#7D3C98"
      style.font-color: white
      width: 40
    }
    key_position: {
      label: "user:123\nhash()"
      shape: diamond
      style.fill: "#F39C12"
      style.stroke: "#D68910"
      style.font-color: white
      width: 60
    }
    zero_marker: {
      label: "0"
      shape: text
      style.font-color: "#666"
    }
    max_marker: {
      label: "2³²-1"
      shape: text
      style.font-color: "#666"
    }
  }
}
legend_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  server_a: {
    label: "Server A\n3 vnodes"
    shape: rectangle
    style.fill: "#E74C3C"
    style.stroke: "#C0392B"
    style.font-color: white
  }
  server_b: {
    label: "Server B\n3 vnodes"
    shape: rectangle
    style.fill: "#27AE60"
    style.stroke: "#1E8449"
    style.font-color: white
  }
  server_c: {
    label: "Server C\n3 vnodes"
    shape: rectangle
    style.fill: "#9B59B6"
    style.stroke: "#7D3C98"
    style.font-color: white
  }
  key_legend: {
    label: "Key Lookup"
    shape: diamond
    style.fill: "#F39C12"
    style.stroke: "#D68910"
    style.font-color: white
    width: 60
  }
}
lookup_flow: {
  label: "Key Lookup Flow"
  width: 700
  step1: {
    label: "1. Hash Key"
    code: |'go
      key = "user:123"
      hash = fnv1a(key)  // → 1,847,293,451
    '|
    width: 320
  }
  step2: {
    label: "2. Binary Search Ring"
    code: |'go
      // Find first vnode >= hash
      idx = bisect_left(vnodes, hash)
      if idx >= len(vnodes):
          idx = 0  // Wrap around
    '|
    width: 320
  }
  step3: {
    label: "3. Return Physical Node"
    code: |'go
      vnode := ring.vnodes[idx]
      return ring.nodes[vnode.nodeID]
      // → Server A (via vnode A₂)
    '|
    width: 320
  }
  step1 -> step2 -> step3
}
arrow_annotation: {
  label: |md
    **Clockwise Walk**: Key hashes to position, 
    walks clockwise to first vnode → Server A
  |
  shape: rectangle
  style.fill: "#FEF9E7"
  style.stroke: "#F1C40F"
  width: 300
}
 vnode_b3 -> vnode_a2: "← user:123 routes here (clockwise)" {
  style.stroke: "#F39C12"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.animated: true
}
key_position -> vnode_a2: "routes to" {
  style.stroke: "#F39C12"
  style.stroke-width: 2
  style.stroke-dash: 3
}
distribution_table: {
  label: "Distribution with Virtual Nodes"
  shape: sql_table
  server_a_dist: "Server A | 3 vnodes | ~33%"
  server_b_dist: "Server B | 3 vnodes | ~33%"
  server_c_dist: "Server C | 3 vnodes | ~33%"
  note: "Variance: <5% with 150+ vnodes/server"
}
benefits: {
  label: "Why Virtual Nodes?"
  width: 600
  benefit1: {
    label: "Load Balancing"
    code: |'go
      // Without vnodes: 2-3x imbalance
      // With 150 vnodes: <5% variance
      vnodeCount = 150 * weight
    '|
    width: 280
  }
  benefit2: {
    label: "Weighted Distribution"
    code: |'go
      // Server with 4x capacity
      node.Weight = 4  // 600 vnodes
      // Gets 4x more keys
    '|
    width: 280
  }
  benefit1 -> benefit2
}