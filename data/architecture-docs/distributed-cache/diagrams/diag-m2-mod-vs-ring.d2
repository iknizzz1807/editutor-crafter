direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  near: top-center
  label: |'md
    # Key Remapping: Mod Hashing vs Consistent Hashing
    **Adding one node to a 4-node cluster**
  '|
  style.stroke: transparent
  style.fill: transparent
}

row_compare: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  mod_col: {
    direction: down
    label: "MOD HASHING (hash % N)"
    
    mod_before: {
      label: "BEFORE: 4 Nodes"
      style.fill: "#E8F5E9"
      mod_ring_before: {
        label: ""
        shape: circle
        width: 200
        height: 200
        style.fill: "#F5F5F5"
        style.stroke: "#BDBDBD"
        
        mod_n1b: "N1 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        mod_n2b: "N2 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        mod_n3b: "N3 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        mod_n4b: "N4 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
      }
      mod_stats_before: {
        shape: rectangle
        style.fill: transparent
        label: |'md
          **Keys per node:** 25,000
          **Total keys:** 100,000
        '|
      }
    }

    mod_arrow: "↓" {
      shape: text
      style.font-size: 40
      style.bold: true
      style.font-color: "#F44336"
    }

    mod_after: {
      label: "AFTER: 5 Nodes"
      style.fill: "#FFEBEE"
      mod_ring_after: {
        label: ""
        shape: circle
        width: 200
        height: 200
        style.fill: "#F5F5F5"
        style.stroke: "#BDBDBD"

        mod_n1a: "N1 (20%)" {
          shape: circle
          style.fill: "#EF5350"
          style.stroke: "#C62828"
          style.font-color: white
        }
        mod_n2a: "N2 (20%)" {
          shape: circle
          style.fill: "#EF5350"
          style.stroke: "#C62828"
          style.font-color: white
        }
        mod_n3a: "N3 (20%)" {
          shape: circle
          style.fill: "#EF5350"
          style.stroke: "#C62828"
          style.font-color: white
        }
        mod_n4a: "N4 (20%)" {
          shape: circle
          style.fill: "#EF5350"
          style.stroke: "#C62828"
          style.font-color: white
        }
        mod_n5a: "N5 (20%)" {
          shape: circle
          style.fill: "#EF5350"
          style.stroke: "#C62828"
          style.font-color: white
        }
      }
      mod_stats_after: {
        shape: rectangle
        style.fill: transparent
        label: |'md
          **Keys remapped:** 80,000
          **Remap rate:** **80%** ❌
        '|
      }
    }

    mod_result: "CATASTROPHIC REMAPPING" {
      shape: diamond
      style.fill: "#F44336"
      style.stroke: "#B71C1C"
      style.font-color: white
      style.bold: true
    }
  }

  consistent_col: {
    direction: down
    label: "CONSISTENT HASHING (hash ring)"
    
    cons_before: {
      label: "BEFORE: 4 Nodes"
      style.fill: "#E8F5E9"
      cons_ring_before: {
        label: ""
        shape: circle
        width: 200
        height: 200
        style.fill: "#F5F5F5"
        style.stroke: "#BDBDBD"

        cons_n1b: "N1 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        cons_n2b: "N2 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        cons_n3b: "N3 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        cons_n4b: "N4 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
      }
      cons_stats_before: {
        shape: rectangle
        style.fill: transparent
        label: |'md
          **Keys per node:** 25,000
          **Total keys:** 100,000
        '|
      }
    }

    cons_arrow: "↓" {
      shape: text
      style.font-size: 40
      style.bold: true
      style.font-color: "#4CAF50"
    }

    cons_after: {
      label: "AFTER: 5 Nodes"
      style.fill: "#E8F5E9"
      cons_ring_after: {
        label: ""
        shape: circle
        width: 200
        height: 200
        style.fill: "#F5F5F5"
        style.stroke: "#BDBDBD"

        cons_n1b_stay: "N1 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        cons_n2b_stay: "N2 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        cons_n3b_stay: "N3 (25%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        cons_n4b_stay: "N4 (20%)" {
          shape: circle
          style.fill: "#81C784"
          style.stroke: "#388E3C"
          style.font-color: white
        }
        cons_n5_new: "N5 (5%)" {
          shape: circle
          style.fill: "#4CAF50"
          style.stroke: "#2E7D32"
          style.font-color: white
        }
      }
      cons_stats_after: {
        shape: rectangle
        style.fill: transparent
        label: |'md
          **Keys remapped:** 20,000
          **Remap rate:** **20%** ✓
        '|
      }
    }

    cons_result: "MINIMAL DISRUPTION" {
      shape: diamond
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
  }
}

row_formula: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  mod_formula: {
    label: "Mod Hashing Formula"
    style.fill: "#FFCDD2"
    content: {
      shape: rectangle
      style.fill: transparent
      label: |'md
        `node = hash(key) % N`
        Adding 5th node:
        `hash % 4 != hash % 5`
        **4/5 of keys change node!**
      '|
    }
  }
  
  cons_formula: {
    label: "Consistent Hashing Formula"
    style.fill: "#C8E6C9"
    content: {
      shape: rectangle
      style.fill: transparent
      label: |'md
        `node = first_node_clockwise(hash(key))`
        Adding 5th node:
        Only keys in N5 arc move
        **Only 1/N of keys change!**
      '|
    }
  }
}

impact_box: {
  label: "Production Impact"
  style.fill: "#FFF3E0"
  impact_content: {
    shape: rectangle
    style.fill: transparent
    label: |'md
      ## What happens when 80% of your cache invalidates?
      | Metric | Before | After (Mod) | After (Consistent) |
      |--------|--------|-------------|-------------------|
      | Cache hit rate | 95% | **5%** | 80% |
      | DB queries/sec | 500 | **9,500** | 1,000 |
      | Latency p99 | 10ms | **500ms** | 50ms |
      **Mod hashing causes a thundering herd that can crash your database.**
    '|
  }
}

row_compare.mod_col.mod_result -> impact_box: "CRASH!" {
  style.stroke: "#F44336"
  style.stroke-width: 3
  style.stroke-dash: 4
}

row_compare.consistent_col.cons_result -> impact_box: "Graceful" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}