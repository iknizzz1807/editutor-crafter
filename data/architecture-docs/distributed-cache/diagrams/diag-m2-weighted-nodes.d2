direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Weighted Node Position Calculation"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  high_cap_node: {
    label: "High-Capacity Node\n(Weight: 4)"
    width: 320
    spec: {
      shape: sql_table
      label: "PhysicalNode (ring.go)"
      f0: "ID | string | cache-large-1"
      f1: "Address | string | 10.0.1.10:6379"
      f2: "Weight | int | 4"
      f3: "Capacity | int64 | 256 GB"
    }
    formula: {
      label: "Virtual Node Calculation"
      code: |'go
        vnodesPerWeight = 40
        totalVNodes = weight * vnodesPerWeight
                      = 4 * 40 = 160 positions
      '|
      width: 280
      style.fill: "#E8F5E9"
    }
  }
  low_cap_node: {
    label: "Low-Capacity Node\n(Weight: 1)"
    width: 320
    spec2: {
      shape: sql_table
      label: "PhysicalNode (ring.go)"
      f0: "ID | string | cache-small-1"
      f1: "Address | string | 10.0.2.10:6379"
      f2: "Weight | int | 1"
      f3: "Capacity | int64 | 64 GB"
    }
    formula2: {
      label: "Virtual Node Calculation"
      code: |'go
        vnodesPerWeight = 40
        totalVNodes = weight * vnodesPerWeight
                      = 1 * 40 = 40 positions
      '|
      width: 280
      style.fill: "#FFF3E0"
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  high_cap_vnodes: {
    label: "Virtual Node Generation\n(160 positions for weight=4)"
    width: 400
    style.fill: "#E8F5E9"
    positions: {
      label: "Ring Positions (sample)"
      code: |'go
        hash("cache-large-1#0")   = 0x1A3F...  (pos 1)
        hash("cache-large-1#1")   = 0x8B2C...  (pos 2)
        hash("cache-large-1#2")   = 0x3D7E...  (pos 3)
        ...
        hash("cache-large-1#159") = 0xF4A1...  (pos 160)
      '|
      width: 360
    }
  }
  low_cap_vnodes: {
    label: "Virtual Node Generation\n(40 positions for weight=1)"
    width: 400
    style.fill: "#FFF3E0"
    positions2: {
      label: "Ring Positions (sample)"
      code: |'go
        hash("cache-small-1#0")  = 0x5C9D...  (pos 1)
        hash("cache-small-1#1")  = 0x2E1F...  (pos 2)
        hash("cache-small-1#2")  = 0xA7B3...  (pos 3)
        ...
        hash("cache-small-1#39") = 0x6D42...  (pos 40)
      '|
      width: 360
    }
  }
}
distribution_formula: {
  label: "Key Distribution Formula"
  code: |'go
    // Fraction of keys going to node i
    keys_i = (weight_i / Σweight_j) × total_keys
    // Example with 2 nodes:
    //   large: (4 / 5) × 1,000,000 = 800,000 keys (80%)
    //   small: (1 / 5) × 1,000,000 = 200,000 keys (20%)
  '|
  width: 500
  style.fill: "#E3F2FD"
}
ring_visual: {
  label: "Hash Ring Distribution"
  width: 700
  style.fill: "#FAFAFA"
  ring: {
    label: ""
    shape: circle
    width: 300
    style: {
      fill: transparent
      stroke: "#90A4AE"
      stroke-width: 3
    }
  }
  legend: {
    label: ""
    width: 280
    style.fill: transparent
    high: {
      label: "● cache-large-1 (160 vnodes)"
      shape: text
      style.font-color: "#2E7D32"
    }
    low: {
      label: "● cache-small-1 (40 vnodes)"
      shape: text
      style.font-color: "#E65100"
    }
    ratio: {
      label: "Ratio: 4:1 (matches weight)"
      shape: text
      style.font-color: "#1565C0"
    }
  }
}
result: {
  label: "Result: 4x Weight → 4x Virtual Nodes → 4x Keys"
  shape: diamond
  width: 350
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    stroke-width: 2
  }
}
high_cap_node -> high_cap_vnodes: "generate"
low_cap_node -> low_cap_vnodes: "generate"
high_cap_vnodes -> distribution_formula: "positions"
low_cap_vnodes -> distribution_formula: "positions"
distribution_formula -> ring_visual: "distribute"
ring_visual -> result: "achieves"