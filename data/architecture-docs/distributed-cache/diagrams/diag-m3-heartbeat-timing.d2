direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Heartbeat Failure Detection Timing {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_timeline: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  timeline_col: {
    direction: down
    label: ""
    timeline: {
      label: "Failure Detection Timeline"
      width: 900
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
      t0: {
        label: "T=0ms"
        code: |'c
          Heartbeat sent
          LastHeartbeat = now()
        '|
        width: 280
        style.fill: "#d4edda"
        style.stroke: "#28a745"
      }
      t100: {
        label: "T=100ms (Interval)"
        code: |'c
          Next heartbeat due
          (sent if healthy)
        '|
        width: 280
        style.fill: "#d4edda"
        style.stroke: "#28a745"
      }
      t200: {
        label: "T=200ms"
        code: |'c
          2nd heartbeat due
          1 missed if no response
        '|
        width: 280
        style.fill: "#fff3cd"
        style.stroke: "#ffc107"
      }
      t300: {
        label: "T=300ms (Suspect)"
        code: |'c
          status = SUSPECT
          ConsecutiveFails = 2
        '|
        width: 280
        style.fill: "#fff3cd"
        style.stroke: "#ffc107"
      }
      t500: {
        label: "T=500ms (Failure)"
        code: |'c
          status = DEAD
          // 5 intervals = failure
          trigger_failover()
        '|
        width: 280
        style.fill: "#f8d7da"
        style.stroke: "#dc3545"
      }
    }
    timeline.t0 -> timeline.t100: "100ms"
    timeline.t100 -> timeline.t200: "100ms"
    timeline.t200 -> timeline.t300: "100ms"
    timeline.t300 -> timeline.t500: "200ms"
  }
  config_col: {
    direction: down
    label: ""
    config: {
      label: "Detector Configuration"
      shape: class
      heartbeat_interval: "100ms"
      suspect_timeout: "300ms"
      failure_timeout: "500ms"
      min_heartbeats: "3"
    }
    states: {
      label: "Node Status Transitions"
      shape: class
      healthy: "LastHB < 300ms"
      suspect: "300ms < LastHB < 500ms"
      dead: "LastHB > 500ms"
    }
    config -> states: "triggers"
  }
}
row_risk: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  risk_analysis: {
    direction: down
    label: "False Positive Risk Analysis"
    risk_timeline: {
      label: "Transient Delay Scenarios"
      width: 420
      normal: {
        label: "Normal Operation"
        code: |'c
          HB arrives at T=105ms
          (within 100ms ± 20ms)
          ✓ No false positive
        '|
        width: 380
        style.fill: "#d4edda"
      }
      gc_pause: {
        label: "GC Pause (50ms)"
        code: |'c
          HB sent at T=0ms
          GC pauses node at T=80ms
          HB arrives at T=155ms
          ⚠ Marked SUSPECT briefly
        '|
        width: 380
        style.fill: "#fff3cd"
      }
      network_spike: {
        label: "Network Latency Spike"
        code: |'c
          Normal RTT: 5ms
          Spike RTT: 200ms
          HB arrives at T=305ms
          ⚠ False SUSPECT state
        '|
        width: 380
        style.fill: "#fff3cd"
      }
      partition: {
        label: "Network Partition"
        code: |'c
          Partition at T=50ms
          No HB for 500ms+
          ✓ Correctly marked DEAD
          (true positive)
        '|
        width: 380
        style.fill: "#f8d7da"
      }
    }
    normal -> gc_pause: "delay"
    gc_pause -> network_spike: "worse"
    network_spike -> partition: "failure"
  }
  phi_col: {
    direction: down
    label: ""
    phi_detector: {
      label: "Phi Accrual Detection"
      shape: class
      +record_heartbeat(node_id): "void"
      +phi(node_id): "float64"
      +is_alive(node_id): "bool"
      -intervals: "[]time.Duration"
      -mean: "time.Duration"
      -variance: "time.Duration"
    }
    phi_formula: {
      label: "Phi Calculation"
      code: |'c
        phi = -log10(1 - F(t))
        // F = normal CDF
        // t = time_since_last_hb
        phi > 8.0 → declare DEAD
        phi > 2.0 → mark SUSPECT
      '|
      width: 350
      style.fill: "#e7f1ff"
      style.stroke: "#0d6efd"
    }
    phi_detector -> phi_formula: "uses"
  }
}
row_comparison: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  simple: {
    label: "Simple Timeout"
    shape: class
    approach: "Fixed threshold"
    pros: "Simple, predictable"
    cons: "High false positive rate"
    use_case: "Low-traffic systems"
    style.fill: "#f8d7da"
  }
  phi: {
    label: "Phi Accrual"
    shape: class
    approach: "Statistical threshold"
    pros: "Adaptive, low false positives"
    cons: "Complex, needs training data"
    use_case: "High-availability systems"
    style.fill: "#d4edda"
  }
  hybrid: {
    label: "Hybrid (Recommended)"
    shape: class
    approach: "Suspect → Dead progression"
    pros: "Balanced responsiveness/safety"
    cons: "More state to manage"
    use_case: "Production caches"
    style.fill: "#d4edda"
  }
  simple -> phi: "evolves to"
  phi -> hybrid: "practical"
}
legend: {
  near: bottom-center
  label: ""
  green: "Healthy / Low Risk" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
  }
  yellow: "Suspect / Medium Risk" {
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
  }
  red: "Dead / High Risk" {
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
  }
}
row_timeline -> row_risk: "Analysis"
row_risk -> row_comparison: "Solutions"