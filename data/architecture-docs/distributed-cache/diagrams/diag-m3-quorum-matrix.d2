      }
    }
    nodes7_row2: {
      direction: right
      node7_e: {
        shape: circle
        label: "E"
        style.fill: "#FFB6C1"
        width: 40
      }
      node7_f: {
        shape: circle
        label: "F"
        style.fill: "#FFB6C1"
        width: 40
      }
      node7_g: {
        shape: circle
        label: "G"
        style.fill: "#FFB6C1"
        width: 40
      }
    }
    result7: {
      label: "✓ Quorum: 4/7 nodes"
      shape: rectangle
      style.fill: "#E8F5E9"
