direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Quorum Decision Matrix
    ## Minimum nodes required for consensus: ⌈N/2⌉ + 1
  |
  near: top-center
  shape: text
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scenario_3nodes: {
    direction: down
    label: "3-Node Cluster (Quorum: 2)"
    nodes3: {
      direction: right
      node3_a: {
        shape: circle
        label: "A"
        style.fill: "#90EE90"
      }
      node3_b: {
        shape: circle
        label: "B"
        style.fill: "#90EE90"
      }
      node3_c: {
        shape: circle
        label: "C"
        style.fill: "#FFB6C1"
      }
    }
    result3: {
      label: "✓ Quorum: 2/3 nodes"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
  }
  scenario_5nodes: {
