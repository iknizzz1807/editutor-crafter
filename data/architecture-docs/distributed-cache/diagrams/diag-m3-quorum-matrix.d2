        style.fill: "#FFB6C1"
      }
      node5_e: {
        shape: circle
        label: "E"
        style.fill: "#FFB6C1"
      }
    }
    result5: {
      label: "✓ Quorum: 3/5 nodes"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
  }
  scenario_7nodes: {
    direction: down
    label: "7-Node Cluster (Quorum: 4)"
    nodes7_row1: {
      direction: right
      node7_a: {
        shape: circle
        label: "A"
        style.fill: "#90EE90"
        width: 40
      }
      node7_b: {
        shape: circle
        label: "B"
        style.fill: "#90EE90"
        width: 40
      }
      node7_c: {
        shape: circle
        label: "C"
        style.fill: "#90EE90"
        width: 40
      }
