direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Primary-Secondary Replication Flow
  Write path, async replication, and eventual consistency windows
| {near: top-center}
row_client: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  client_write: {
    label: "Client (Write)"
    shape: person
    style.fill: "#E8F5E9"
  }
  client_read: {
    label: "Client (Read)"
    shape: person
    style.fill: "#E3F2FD"
  }
}
row_nodes: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  primary: {
    label: "PRIMARY\nNode A"
    shape: hexagon
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    storage: {
      label: "Storage"
      shape: cylinder
      style.fill: "#A5D6A7"
      entry: {
        shape: sql_table
        label: "Key: user:123"
        val: "0x00 | []byte | \"alice\""
        ver: "0x10 | uint64  | v=5"
        ts: "0x18 | int64   | T=0ms"
      }
    }
  }
  secondary1: {
    label: "SECONDARY\nNode B"
    shape: hexagon
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    storage_b: {
      label: "Storage"
      shape: cylinder
      style.fill: "#FFF59D"
      entry_b: {
        shape: sql_table
        label: "Key: user:123"
        val_b: "0x00 | []byte | \"bob\" (stale)"
        ver_b: "0x10 | uint64  | v=4"
        ts_b: "0x18 | int64   | T=-50ms"
        note_b: "Replica Lag: 50ms"
      }
    }
  }
  secondary2: {
    label: "SECONDARY\nNode C"
    shape: hexagon
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    storage_c: {
      label: "Storage"
      shape: cylinder
      style.fill: "#FFF59D"
      entry_c: {
        shape: sql_table
        label: "Key: user:123"
        val_c: "0x00 | []byte | \"bob\" (stale)"
        ver_c: "0x10 | uint64  | v=4"
        ts_c: "0x18 | int64   | T=-50ms"
        note_c: "Replica Lag: 50ms"
      }
    }
  }
}
row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    label: "Timeline (milliseconds)"
    shape: rectangle
    width: 700
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
    t0: {
      label: "T=0"
      shape: circle
      style.fill: "#4CAF50"
      style.font-color: white
    }
    t5: {
      label: "T=5"
      shape: circle
      style.fill: "#FF9800"
      style.font-color: white
    }
    t10: {
      label: "T=10"
      shape: circle
      style.fill: "#FF9800"
      style.font-color: white
    }
    t50: {
      label: "T=50"
      shape: circle
      style.fill: "#2196F3"
      style.font-color: white
    }
  }
}
lag_window: {
  label: "═════════ REPLICA LAG WINDOW ═════════\nStale reads possible (eventual consistency)\nDuration: ~50ms typical, up to 500ms under load"
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#E53935"
  style.stroke-dash: 4
  style.font-color: "#C62828"
  width: 600
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#F5F5F5"
  label: |md
    **Replication Factor: 3** (1 Primary + 2 Secondaries)
    • **Write**: Synchronous to PRIMARY only → ACK at T=0ms
    • **Replication**: Async fire-and-forget to secondaries
    • **Read**: Any replica can serve (may return stale data)
    • **Consistency**: Eventual (secondaries converge within lag window)
  |
}
connections: {
  write_flow: {
    client_write -> primary: "SET user:123 = \"alice\"" {
      label: "1. WRITE\n(T=0ms)"
      style.stroke: "#2E7D32"
      style.stroke-width: 3
      style.animated: true
    }
  }
  replicate_flow: {
    primary -> secondary1.storage_b: "Replicate\nv=5, T=0ms" {
      label: "2a. ASYNC\n(T=5ms)"
      style.stroke: "#FF9800"
      style.stroke-width: 2
      style.stroke-dash: 4
      style.animated: true
    }
    primary -> secondary2.storage_c: "Replicate\nv=5, T=0ms" {
      label: "2b. ASYNC\n(T=10ms)"
      style.stroke: "#FF9800"
      style.stroke-width: 2
      style.stroke-dash: 4
      style.animated: true
    }
  }
  read_flow: {
    client_read -> secondary1.storage_b: "GET user:123" {
      label: "3. READ\n(T=25ms)"
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
    secondary1.storage_b -> client_read: "\"bob\" (STALE!)" {
      label: "Returns old\nvalue v=4"
      style.stroke: "#E53935"
      style.stroke-dash: 3
      style.font-color: "#C62828"
    }
  }
  ack_flow: {
    primary -> client_write: "ACK +OK" {
      label: "Write\nconfirmed"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
  }
  timeline_arrows: {
    timeline.t0 -> timeline.t5: {
      style.stroke: "#BDBDBD"
      style.stroke-dash: 2
    }
    timeline.t5 -> timeline.t10: {
      style.stroke: "#BDBDBD"
      style.stroke-dash: 2
    }
    timeline.t10 -> timeline.t50: {
      style.stroke: "#BDBDBD"
      style.stroke-dash: 2
    }
  }
}
primary -> lag_window: {
  style.stroke: transparent
}
lag_window -> secondary1: {
  style.stroke: transparent
}