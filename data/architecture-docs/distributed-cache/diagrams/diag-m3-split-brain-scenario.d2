direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Split-Brain During Network Partition {
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_state: {
    label: "BEFORE: Normal Operation"
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    cluster_before: {
      label: "Cluster (Replication Factor: 3)"
      direction: right
      node_a_before: {
        label: "Node A\nPRIMARY"
        shape: hexagon
        style.fill: "#4caf50"
        style.font-color: white
        style.stroke: "#2e7d32"
      }
      node_b_before: {
        label: "Node B\nSECONDARY"
        shape: hexagon
        style.fill: "#81c784"
        style.stroke: "#2e7d32"
      }
      node_c_before: {
        label: "Node C\nSECONDARY"
        shape: hexagon
        style.fill: "#81c784"
        style.stroke: "#2e7d32"
      }
    }
    data_before: {
      label: "Data State"
      shape: sql_table
      key: "user:123"
      value: "\"alice\""
      version: "v1"
    }
    cluster_before -> data_before: "replicated" {
      style.stroke: "#2e7d32"
      style.stroke-dash: 3
    }
  }
}
row_partition: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  partition_state: {
    label: "DURING: Network Partition"
    direction: down
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
    side_minority: {
      label: "Partition Side A\n(Minority: 1/3 nodes)"
      direction: down
      style.fill: "#ffebee"
      style.stroke: "#c62828"
      node_a_partition: {
        label: "Node A\n(Old Primary)"
        shape: hexagon
        style.fill: "#ef5350"
        style.font-color: white
        style.stroke: "#b71c1c"
      }
      client1: {
        label: "Client X"
        shape: person
        style.fill: "#bbdefb"
      }
      client1 -> node_a_partition: "SET user:123\n= \"bob\"" {
        style.stroke: "#1976d2"
        style.stroke-width: 2
      }
      data_a: {
        label: "Node A Data"
        shape: sql_table
        key: "user:123"
        value: "\"bob\""
        version: "v2 (local)"
        style.fill: "#ffcdd2"
      }
      node_a_partition -> data_a: "writes"
    }
    partition_wall: {
      label: "║║║\nNETWORK\nPARTITION\n║║║"
      shape: rectangle
      style.fill: "#ff5722"
      style.font-color: white
      style.stroke: "#bf360c"
      style.bold: true
      width: 80
    }
    side_majority: {
      label: "Partition Side B\n(Majority: 2/3 nodes)"
      direction: down
      style.fill: "#e3f2fd"
      style.stroke: "#1565c0"
      nodes_bc: {
        direction: right
        node_b_partition: {
          label: "Node B\nNEW PRIMARY"
          shape: hexagon
          style.fill: "#2196f3"
          style.font-color: white
          style.stroke: "#0d47a1"
        }
        node_c_partition: {
          label: "Node C\nSECONDARY"
          shape: hexagon
          style.fill: "#64b5f6"
          style.stroke: "#0d47a1"
        }
      }
      client2: {
        label: "Client Y"
        shape: person
        style.fill: "#c8e6c9"
      }
      client2 -> node_b_partition: "SET user:123\n= \"charlie\"" {
        style.stroke: "#388e3c"
        style.stroke-width: 2
      }
      data_bc: {
        label: "Nodes B+C Data"
        shape: sql_table
        key: "user:123"
        value: "\"charlie\""
        version: "v2 (elected)"
        style.fill: "#bbdefb"
      }
      node_b_partition -> data_bc: "writes"
      node_b_partition <-> node_c_partition: "replicate" {
        style.stroke: "#0d47a1"
        style.stroke-dash: 3
        style.animated: true
      }
    }
    side_minority -> partition_wall: "✗ cannot reach" {
      style.stroke: "#c62828"
      style.stroke-dash: 5
    }
    partition_wall -> side_majority: "✗ cannot reach" {
      style.stroke: "#c62828"
      style.stroke-dash: 5
    }
  }
}
row_conflict: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  conflict_state: {
    label: "THE PROBLEM: Two Primaries, Conflicting Data"
    direction: down
    style.fill: "#ffebee"
    style.stroke: "#c62828"
    conflict_row: {
      direction: right
      conflict_a: {
        label: "Node A Thinks"
        shape: rectangle
        style.fill: "#ef5350"
        style.font-color: white
        conflict_a_data: {
          label: "user:123 = \"bob\""
          shape: rectangle
          style.fill: white
          style.font-color: "#c62828"
          style.stroke: "#c62828"
        }
      }
      vs: {
        label: "VS"
        shape: circle
        style.fill: "#c62828"
        style.font-color: white
        style.bold: true
      }
      conflict_b: {
        label: "Nodes B+C Think"
        shape: rectangle
        style.fill: "#2196f3"
        style.font-color: white
        conflict_b_data: {
          label: "user:123 = \"charlie\""
          shape: rectangle
          style.fill: white
          style.font-color: "#0d47a1"
          style.stroke: "#0d47a1"
        }
      }
    }
    conflict_a -> conflict_a_data
    conflict_b -> conflict_b_data
  }
}
row_recovery: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recovery_state: {
    label: "AFTER: Partition Heals - MERGE CONFLICT!"
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#880e4f"
    recovery_cluster: {
      label: "Cluster Reunited"
      direction: right
      node_a_recovery: {
        label: "Node A\n???"
        shape: hexagon
        style.fill: "#9e9e9e"
        style.font-color: white
        style.stroke: "#424242"
      }
      node_b_recovery: {
        label: "Node B\nPRIMARY?"
        shape: hexagon
        style.fill: "#9e9e9e"
        style.font-color: white
        style.stroke: "#424242"
      }
      node_c_recovery: {
        label: "Node C\nSECONDARY"
        shape: hexagon
        style.fill: "#9e9e9e"
        style.stroke: "#424242"
      }
    }
    merge_question: {
      label: "WHICH VALUE WINS?"
      shape: diamond
      style.fill: "#ff5722"
      style.font-color: white
      style.stroke: "#bf360c"
    }
    options: {
      direction: right
      option1: {
        label: "Option 1:\nLast-Write-Wins\n(based on timestamp)"
        shape: rectangle
        style.fill: "#e1bee7"
        style.stroke: "#7b1fa2"
      }
      option2: {
        label: "Option 2:\nVector Clock\n(conflict detection)"
        shape: rectangle
        style.fill: "#b2dfdb"
        style.stroke: "#00695c"
      }
      option3: {
        label: "Option 3:\nApplication-level\nresolution required"
        shape: rectangle
        style.fill: "#ffe0b2"
        style.stroke: "#e65100"
      }
    }
    recovery_cluster -> merge_question: "conflict!"
    merge_question -> options: "how to resolve?"
  }
}
row_solution: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  solution_state: {
    label: "THE FIX: Quorum-Based Failover"
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#1b5e20"
    quorum_rule: {
      label: "Quorum Rule"
      shape: rectangle
      style.fill: "#4caf50"
      style.font-color: white
      style.stroke: "#1b5e20"
      quorum_text: {
        label: |md
          **Require majority to elect leader:**
          - 3 nodes → need 2 (quorum = 2)
          - 5 nodes → need 3 (quorum = 3)
          Only the majority side can elect.
          Minority side CANNOT elect → no split-brain!
        |
        shape: text
      }
    }
    correct_behavior: {
      label: "Correct Behavior with Quorum"
      direction: right
      side_a_correct: {
        label: "Side A (1 node)\nMINORITY"
        direction: down
        style.fill: "#ffcdd2"
        style.stroke: "#c62828"
        node_a_correct: {
          label: "Node A\nCANNOT ELECT\n(no quorum)"
          shape: hexagon
          style.fill: "#ef5350"
          style.font-color: white
        }
        result_a: {
          label: "→ Writes REJECTED\n→ Returns error to client\n→ Data stays consistent"
          shape: rectangle
          style.fill: white
          style.stroke: "#c62828"
          style.font-color: "#c62828"
        }
        node_a_correct -> result_a
      }
      side_b_correct: {
        label: "Side B (2 nodes)\nMAJORITY"
        direction: down
        style.fill: "#c8e6c9"
        style.stroke: "#2e7d32"
        nodes_b_correct: {
          direction: right
          node_b_correct: {
            label: "Node B\nELECTED PRIMARY\n(has quorum)"
            shape: hexagon
            style.fill: "#4caf50"
            style.font-color: white
          }
          node_c_correct: {
            label: "Node C"
            shape: hexagon
            style.fill: "#81c784"
          }
        }
        result_b: {
          label: "→ Writes ACCEPTED\n→ Single source of truth\n→ No conflict possible"
          shape: rectangle
          style.fill: white
          style.stroke: "#2e7d32"
          style.font-color: "#2e7d32"
        }
        nodes_b_correct -> result_b
      }
    }
    quorum_rule -> correct_behavior: "prevents split-brain"
  }
}
row_before -> row_partition
row_partition -> row_conflict
row_conflict -> row_recovery
row_recovery -> row_solution
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: "#f5f5f5"
  style.stroke: "#9e9e9e"
  leg_primary: {
    label: "PRIMARY"
    shape: hexagon
    style.fill: "#4caf50"
    style.font-color: white
  }
  leg_secondary: {
    label: "SECONDARY"
    shape: hexagon
    style.fill: "#81c784"
  }
  leg_conflict: {
    label: "CONFLICT"
    shape: hexagon
    style.fill: "#ef5350"
    style.font-color: white
  }
}