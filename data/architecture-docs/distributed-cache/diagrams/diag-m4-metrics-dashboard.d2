direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_container: {
  style.stroke: transparent
  style.fill: transparent
  title: |md
    # Cache Metrics Dashboard
    ### Production Monitoring View (0x7F22)
  |
}

# Row 1: Primary KPIs
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  hitrate_gauge: {
    label: "Metric: Hit Rate"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    gauge: {
      shape: circle
      label: "94.2%"
      style.fill: "#4CAF50"
      style.font-color: white
      style.font-size: 32
      style.bold: true
      width: 120
    }
    target: "Target: > 90%"
    trend: "↑ +2.1% (24h Δ)"
    trend.style.font-color: "#4CAF50"
  }
  
  latency_p50: {
    label: "Metric: Latency P50"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    value: {
      shape: rectangle
      label: "0.8ms"
      style.fill: "#2196F3"
      style.font-color: white
      style.font-size: 28
      style.bold: true
      width: 100
    }
    bar_group: {
      style.stroke: transparent
      direction: right
      bar_fill: {
        shape: rectangle
        width: 120
        height: 20
        style.fill: "#2196F3"
      }
      bar_empty: {
        shape: rectangle
        width: 30
        height: 20
        style.fill: "#BBDEFB"
      }
    }
    range: "Range: 0.1ms - 5ms"
  }
  
  latency_p99: {
    label: "Metric: Latency P99"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    value: {
      shape: rectangle
      label: "12.3ms"
      style.fill: "#FF9800"
      style.font-color: white
      style.font-size: 28
      style.bold: true
      width: 100
    }
    bar_group: {
      style.stroke: transparent
      direction: right
      bar_fill: {
        shape: rectangle
        width: 90
        height: 20
        style.fill: "#FF9800"
      }
      bar_empty: {
        shape: rectangle
        width: 60
        height: 20
        style.fill: "#FFE0B2"
      }
    }
    range: "Range: 1ms - 50ms"
    alert: "⚠️ Status: Elevated"
    alert.style.font-color: "#FF9800"
  }
  
  throughput: {
    label: "Metric: Throughput"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    value: {
      shape: rectangle
      label: "47.2K"
      style.fill: "#9C27B0"
      style.font-color: white
      style.font-size: 28
      style.bold: true
      width: 100
    }
    unit: "ops/sec"
    peak: "Peak: 89.1K"
    avg: "Avg: 42.8K"
  }
}

# Row 2: Charts
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  latency_histogram: {
    label: "Latency Distribution (μs)"
    width: 500
    style.fill: white
    style.stroke: "#90A4AE"
    style.stroke-width: 2
    
    chart_area: {
      direction: right
      style.stroke: transparent
      b1: { shape: rectangle; height: 100; width: 40; style.fill: "#4CAF50" }
      b2: { shape: rectangle; height: 150; width: 40; style.fill: "#4CAF50" }
      b3: { shape: rectangle; height: 280; width: 40; style.fill: "#8BC34A" }
      b4: { shape: rectangle; height: 180; width: 40; style.fill: "#CDDC39" }
      b5: { shape: rectangle; height: 90; width: 40; style.fill: "#FFC107" }
      b6: { shape: rectangle; height: 40; width: 40; style.fill: "#FF9800" }
      b7: { shape: rectangle; height: 15; width: 40; style.fill: "#F44336" }
    }
    x_axis_labels: {
      label: "10μs  50μs  100μs  500μs   1ms    5ms   50ms+"
      style.font-size: 12
    }
    legend_info: {
      label: "■ Fast (<100μs)  ■ Normal (100μs-1ms)  ■ Slow (>1ms)"
      style.font-size: 12
    }
  }
  
  memory_timeline: {
    label: "Memory Usage Over Time"
    width: 450
    style.fill: white
    style.stroke: "#90A4AE"
    style.stroke-width: 2
    
    vis: {
      label: "Memory [GB] | Utilization %"
      code: |'text
        8GB ┤                      ! Alert 80%
        6GB ┤    ╭──────────╮      ╭─╮
        4GB ┤╭───╯          ╰──────╯ ╰───
        2GB ┤│
          0 └────────────────────────────► Time
             -6h  -4h  -2h  -1h   Now
      '|
    }
    stats: "Current: 6.2GB (77.5% capacity)"
    threshold: "CRITICAL LIMIT: 8.0GB"
    threshold.style.font-color: "#F44336"
  }
}

# Row 3: Eviction & Errors
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  eviction_panel: {
    label: "Eviction Analysis"
    style.fill: "#FFEBEE"
    style.stroke: "#E53935"
    style.stroke-width: 2
    width: 320
    shape: sql_table
    rate: "Rate | 127/sec | ↑ +15% spike"
    policy: "Policy | LRU | Active"
    p1: "Pattern 1 | session:* | 42%"
    p2: "Pattern 2 | cache:user:* | 28%"
    total: "Total 24h | 1.2M Keys | CRITICAL"
  }
  
  error_panel: {
    label: "Errors & System Alerts"
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
    style.stroke-width: 2
    width: 320
    shape: sql_table
    timeouts: "Timeouts | 23 (0.05%) | OK"
    conn_err: "Conn Err | 7 (0.02%) | OK"
    alert1: "ALRT | High Mem Node-03 | 87%"
    alert2: "ALRT | P99 Latency | >10ms"
  }
  
  node_health: {
    label: "Cluster Topology"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 350
    nodes: {
      shape: class
      label: "Node Status (Active: 5)"
      -cache_01: "Healthy | 78% | 12K rps"
      -cache_02: "Healthy | 72% | 11K rps"
      -cache_03: "Warning | 87% | 14K rps"
      -cache_04: "Healthy | 65% | 10K rps"
      -cache_05: "Healthy | 71% | 11K rps"
    }
    summary: {
      total_mem: "Cluster Mem: 6.2/8.0GB"
      total_conn: "Active Conns: 847"
    }
  }
}

# Row 4: Operations Panel
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  coalescing_stats: {
    label: "Protection: Thundering Herd"
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    style.stroke-width: 2
    width: 320
    coalesced: "Total Requests Coalesced: 8,234"
    saved: "Backend Queries Prevented: 8,234"
    hotkey: "Hot-Key Mitigations: 47 events"
  }
  
  buffer_stats: {
    label: "Persistence: Write-Behind"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    style.stroke-width: 2
    width: 320
    buffer: "Size: 234 / 10,000"
    flush: "Flush Rate: 1.2K ops/s"
    lag: "Replication Lag: 12ms"
    loss: "Data Loss (24h): 0 (Safe)"
  }
  
  quick_actions: {
    label: "Operations Console"
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    style.stroke-width: 2
    width: 320
    actions: {
      label: "Control Plane Commands"
      content: "[Flush All]  [Warm]  [Rebalance]  [Scale]"
    }
    history: "Last: Warm Cache | 15m ago | admin"
  }
}

legend_panel: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.stroke-width: 1
  indicators: {
    shape: rectangle
    label: |'md
      **Status Indicators:**
      ● Healthy (Green) | ● Warning (Orange) | ● Critical (Red)
      **Threshold Configs:**
      Hit Rate < 85% | P99 > 20ms | Memory > 85% | Eviction > 200/s
    '|
  }
}