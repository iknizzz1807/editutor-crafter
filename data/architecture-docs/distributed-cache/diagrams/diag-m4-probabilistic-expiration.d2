direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: "PROBABILISTIC EARLY EXPIRATION DISTRIBUTION (X-FETCH)"
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#34495e"
    font-color: white
  }
}

row_compare: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  without_strategy: "SCENARIO A: Standard TTL (Thundering Herd)" {
    direction: down
    style.stroke: "#e74c3c"
    style.fill: "#fdf2f2"
    style.stroke-width: 2

    wo_header: {
      label: "All requests synchronized at expiration"
      shape: rectangle
      style: {
        font-color: "#c0392b"
        bold: true
        fill: transparent
        stroke-width: 0
      }
    }

    wo_timeline: "" {
      direction: right
      style.stroke: transparent
      t1: "TTL - δ" { style.fill: "#ecf0f1"; width: 80 }
      t2: "TTL - δ/2" { style.fill: "#ecf0f1"; width: 80 }
      t3: "TTL" { style.fill: "#ecf0f1"; width: 80 }
      t4: "EXPIRED" { 
        style.fill: "#e74c3c"
        style.font-color: white
        width: 100 
      }
    }

    wo_requests: "1000 Concurrent Requests" {
      shape: rectangle
      style: {
        fill: "#e74c3c"
        stroke: "#c0392b"
        font-color: white
        bold: true
        multiple: true
      }
    }

    wo_db: "Database Server" {
      shape: cylinder
      label: "Database\n[CRITICAL OVERLOAD]"
      style: {
        fill: "#e74c3c"
        stroke: "#c0392b"
        font-color: white
        bold: true
      }
    }

    wo_timeline.t4 -> wo_requests: "HTTP 404/Miss | fetch"
    wo_requests -> wo_db: "SQL | 1000 ops/s" {
      style.stroke: "#e74c3c"
      style.stroke-width: 4
      style.animated: true
    }
  }

  with_strategy: "SCENARIO B: Probabilistic Expiration" {
    direction: down
    style.stroke: "#27ae60"
    style.fill: "#f0fff4"
    style.stroke-width: 2

    w_header: {
      label: "Requests spread across early-refresh window"
      shape: rectangle
      style: {
        font-color: "#1b5e20"
        bold: true
        fill: transparent
        stroke-width: 0
      }
    }

    w_timeline: "" {
      direction: right
      style.stroke: transparent
      wt1: "TTL - δ" { style.fill: "#27ae60"; style.font-color: white; width: 80 }
      wt2: "TTL - δ/2" { style.fill: "#2ecc71"; style.font-color: white; width: 80 }
      wt3: "TTL" { style.fill: "#82e0aa"; width: 80 }
      wt4: "EXPIRED" { style.fill: "#ecf0f1"; width: 100 }
    }

    w_batch: "" {
      direction: right
      style.stroke: transparent
      w_r1: "~200" { style.fill: "#27ae60"; style.font-color: white }
      w_r2: "~350" { style.fill: "#2ecc71"; style.font-color: white }
      w_r3: "~300" { style.fill: "#82e0aa" }
      w_r4: "~150" { style.fill: "#d5f5e3" }
    }

    w_db: "Database Server" {
      shape: cylinder
      label: "Database\n[HEALTHY LOAD]"
      style: {
        fill: "#27ae60"
        stroke: "#1e8449"
        font-color: white
        bold: true
      }
    }

    w_timeline.wt1 -> w_batch.w_r1: "t=90s | early"
    w_timeline.wt2 -> w_batch.w_r2: "t=95s | mid"
    w_timeline.wt3 -> w_batch.w_r3: "t=99s | late"
    
    w_batch.w_r1 -> w_db: "SQL | 200 ops"
    w_batch.w_r2 -> w_db: "SQL | 350 ops"
    w_batch.w_r3 -> w_db: "SQL | 300 ops"
    w_batch.w_r4 -> w_db: "SQL | 150 ops"
  }
}

implementation_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  cache_struct: {
    shape: sql_table
    label: "struct CacheEntry (cache.go)"
    f0: "0x00 | string   | key"
    f1: "0x10 | []byte   | value"
    f2: "0x28 | int64    | ttl_seconds"
    f3: "0x30 | float64  | beta // skew factor"
    sz: "Total: 56 bytes"
  }

  logic_gate: {
    label: "Expiration Logic"
    code: |'go
    // X-Fetch Algorithm (Probabilistic)
    // t: time, T: expiration time, b: beta (skew)
    // rand() returns (0, 1]
    
    func shouldRefresh(entry Entry) bool {
        skew := entry.beta * entry.delta * math.Log(rand.Float64())
        return (time.Now() - skew) >= entry.expiryTime
    }
    '|
  }
}

distribution_viz: "Traffic Distribution (Gaussian-like spread)" {
  direction: down
  style.fill: "#f8f9fa"
  
  graph_container: "" {
    direction: right
    style.stroke: transparent
    
    y_axis: "Freq" { shape: rectangle; height: 150; width: 10; style.fill: "#34495e" }
    
    b1: { height: 20; width: 40; style.fill: "#d5f5e3" }
    b2: { height: 45; width: 40; style.fill: "#abebc6" }
    b3: { height: 80; width: 40; style.fill: "#58d68d" }
    b4: { height: 130; width: 40; style.fill: "#2ecc71" }
    b5: { height: 100; width: 40; style.fill: "#27ae60" }
    b6: { height: 60; width: 40; style.fill: "#1e8449" }
    b7: { height: 30; width: 40; style.fill: "#145a32" }
  }
  
  x_axis: "Early Window (δ) -------------------------------- Expiration (TTL)" {
    shape: rectangle
    style.stroke-width: 0
    style.fill: transparent
    style.italic: true
  }
}

legend_row: "" {
  direction: right
  style.stroke: transparent
  leg1: "Early Strategy" { style.fill: "#27ae60"; style.font-color: white }
  leg2: "Standard Expiry" { style.fill: "#ecf0f1" }
  leg3: "Critical Load" { style.fill: "#e74c3c"; style.font-color: white }
}

summary: {
  shape: callout
  label: "By injecting randomness proportional to remaining TTL, thundering herds are flattened into a manageable baseline."
  style: {
    fill: "#e8f6f3"
    stroke: "#27ae60"
    stroke-width: 2
  }
}

row_compare -> implementation_row: "Implementation Detail"
implementation_row -> distribution_viz: "Telemetry"
distribution_viz -> legend_row: "Context"
legend_row -> summary: "Conclusion"