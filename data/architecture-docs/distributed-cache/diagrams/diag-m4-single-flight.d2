  direction: right
  style.stroke: transparent
  style.fill: transparent
  timing_box: {
    direction: down
    label: "Timeline"
    width: 400
    t0: {
      label: "T=0ms"
      width: 80
      style.fill: "#E8F4FD"
    }
    t1: {
      label: "T=1ms"
      width: 80
      style.fill: "#E8F4FD"
    }
    t2: {
      label: "T=50ms"
      width: 80
      style.fill: "#E8F4FD"
    }
    t3: {
      label: "T=51ms"
      width: 80
      style.fill: "#D4EDDA"
    }
  }
}
row_requests: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  clients: {
    direction: down
    label: "Concurrent Clients"
    width: 200
    req1: {
      label: "Request #1"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
    }
    req2: {
      label: "Request #2"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
    }
    req3: {
      label: "Request #3"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
    }
    reqN: {
      label: "Request #N"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
      style.stroke-dash: 5
    }
  }
}
row_singleflight: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sf: {
    direction: down
    label: "SingleFlight"
    width: 280
    sf_map: {
      shape: sql_table
      label: "calls map[string]*call"
      key1: "key | *call"
      row_note: "(one entry per key)"
    }
    sf_call: {
      shape: class
      label: "call struct"
      wg: "sync.WaitGroup"
      val: "interface{}"
      err: "error"
    }
    sf_logic: {
      label: |md
        **Logic:**
        1. Lock map
        2. Check if call exists
        3. If yes: wait on WaitGroup
        4. If no: create call, execute fn
        5. Broadcast result to waiters
      |
      shape: rectangle
      style.fill: "#F8D7DA"
      width: 250
    }
  }
}
row_db: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  db_section: {
    direction: down
    label: "Backend"
    width: 180
    db_query: {
      label: "Database\nQuery"
      shape: cylinder
      style.fill: "#CCE5FF"
      style.stroke: "#004085"
    }
    db_latency: {
      label: "~50ms latency"
      shape: text
      style.font-color: "#6C757D"
    }
  }
}
row_response: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  response_section: {
    direction: down
    label: "Response Broadcast"
    width: 200
    resp1: {
      label: "→ Request #1"
      style.fill: "#D4EDDA"
      style.stroke: "#155724"
    }
    resp2: {
      label: "→ Request #2"
      style.fill: "#D4EDDA"
      style.stroke: "#155724"
    }
    resp3: {
      label: "→ Request #3"
      style.fill: "#D4EDDA"
      style.stroke: "#155724"
    }
    respN: {
      label: "→ Request #N"
      style.fill: "#D4EDDA"
      style.stroke: "#155724"
      style.stroke-dash: 5
    }
  }
}
row_requests.clients.req1 -> row_singleflight.sf.sf_map: "GET key" {
  label: "1"
  style.stroke: "#856404"
}
row_requests.clients.req2 -> row_singleflight.sf.sf_map: "GET key" {
  label: "2"
  style.stroke: "#856404"
}
row_requests.clients.req3 -> row_singleflight.sf.sf_map: "GET key" {
  label: "3"
  style.stroke: "#856404"
}
