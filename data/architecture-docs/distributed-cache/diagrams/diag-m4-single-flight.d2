  style.stroke: "#28A745"
  style.stroke-dash: 5
}
legend: {
  near: bottom-center
  direction: right
  label: ""
  style.stroke: transparent
  style.fill: transparent
  l1: {
    label: "Without: N queries"
    style.fill: "#F8D7DA"
  }
  l2: {
    label: "With: 1 query"
    style.fill: "#D4EDDA"
  }
  l3: {
    label: "Wait on WaitGroup"
    style.fill: "#FFF3CD"
  }
}
code_example: {
  label: "SingleFlight.Do() Implementation"
  width: 450
  code: |'go
    func (sf *SingleFlight) Do(key string, fn func() (interface{}, error)) (interface{}, error) {
        sf.mu.Lock()
        if c, ok := sf.calls[key]; ok {
            sf.mu.Unlock()
            c.wg.Wait()  // Wait for in-flight request
            return c.val, c.err
        }
        c := &call{}
        c.wg.Add(1)
        sf.calls[key] = c
        sf.mu.Unlock()
        c.val, c.err = fn()  // Execute ONLY ONCE
        c.wg.Done()          // Wake all waiters
        sf.mu.Lock()
        delete(sf.calls, key)
        sf.mu.Unlock()
        return c.val, c.err
    }
  '|
}