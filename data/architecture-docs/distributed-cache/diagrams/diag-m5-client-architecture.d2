direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "CLIENT LIBRARY ARCHITECTURE: DISTRIBUTED CACHE SYSTEM"
  style: {
    font-size: 28
    bold: true
    underline: true
    stroke: transparent
    fill: transparent
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  app_layer: {
    direction: down
    label: "LAYER 1: APPLICATION (main.go)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    
    app: {
      label: "Application Logic"
      code: |'go
        val, err := cache.Get(ctx, "user:101")
        if err == ErrNotFound {
            cache.Set(ctx, "user:101", data, 3600)
        }
      '|
      width: 350
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  api_layer: {
    direction: down
    label: "LAYER 2: CLIENT API"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"

    inner_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent

      client_api: {
        shape: class
        label: "Client (client.go)"
        +Get(ctx, key): "([]byte, error)"
        +Set(ctx, key, val, ttl): "error"
        +Delete(ctx, key): "error"
        +Incr(ctx, key): "(int64, error)"
        +Pipeline(ctx): "(*Pipeline, error)"
        +Close(): "error"
      }

      retrier_group: "" {
        direction: down
        style.stroke: transparent
        style.fill: transparent
        
        retrier: {
          shape: class
          label: "Retrier (retry.go)"
          -config: "RetryConfig"
          +Do(ctx, fn): "error"
          -backoff(n): "time.Duration"
        }

        retrier_note: {
          shape: callout
          label: "Retry Policy: Exp Backoff, Jitter 20%, MaxRetries 3"
          style.stroke-dash: 2
        }
      }
    }

    pipeline_obj: {
      shape: class
      label: "Pipeline (pipeline.go)"
      -cmds: "[]Command"
      +Add(cmd): "void"
      +Exec(ctx): "([]Result, error)"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  pool_layer: {
    direction: down
    label: "LAYER 3: CONNECTION POOL"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"

    pool_manager: {
      shape: class
      label: "Pool (pool.go)"
      -idle: "[]*Conn"
      -active: "int"
      +Get(ctx): "(*Conn, error)"
      +Put(c): "void"
      -create(): "(*Conn, error)"
    }

    pool_note: {
      shape: callout
      label: "Mgmt: Health Check 30s, Max Lifetime 1hr"
      style.stroke-dash: 2
    }

    conn_wrapper: {
      shape: class
      label: "Conn (conn.go)"
      -raw: "net.Conn"
      +Write(b): "(int, error)"
      +Read(b): "(int, error)"
    }

    pool_config: {
      shape: sql_table
      label: "struct PoolConfig"
      f1: "0x00 | int | MaxIdle"
      f2: "0x08 | int | MaxActive"
      f3: "0x10 | Duration | IdleTimeout"
      sz: "Total: 24 bytes"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ring_layer: {
    direction: down
    label: "LAYER 4: CONSISTENT HASHING"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"

    hashring: {
      shape: class
      label: "HashRing (hashring.go)"
      -vnodes: "[]VNode"
      -nodes: "map[string]Node"
      +GetNode(key): "(*Node, error)"
      +AddNode(node): "void"
    }

    ring_note: {
      shape: callout
      label: "Strategy: FNV-1a Hasher, 160 vNodes per Node"
      style.stroke-dash: 2
    }

    physical_node: {
      shape: sql_table
      label: "struct PhysicalNode"
      f1: "0x00 | string | ID"
      f2: "0x10 | string | Address"
      f3: "0x20 | int | Weight"
      sz: "Total: 40 bytes"
    }
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  network_layer: {
    direction: down
    label: "LAYER 5: WIRE PROTOCOL (DCP)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"

    protocol_parser: {
      shape: class
      label: "Parser (parser.go)"
      +ParseResponse(): "(*Response, error)"
      -readBulk(): "([]byte, error)"
    }

    protocol_note: {
      shape: callout
      label: "DCP: Type [1], Len [4], Payload [N]"
      style.stroke-dash: 2
    }

    command_struct: {
      shape: sql_table
      label: "struct Command"
      f1: "0x00 | string | Name"
      f2: "0x10 | []string | Args"
      f3: "0x28 | bool | IsWrite"
      sz: "Total: 41 bytes"
    }
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  server_nodes: {
    direction: right
    label: "LAYER 6: CACHE SERVERS"
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    
    node_a: {
      label: "Node A\n10.0.0.1:7379"
      shape: cylinder
    }
    node_b: {
      label: "Node B\n10.0.0.2:7379"
      shape: cylinder
    }
    node_c: {
      label: "Node C\n10.0.0.3:7379"
      shape: cylinder
    }
  }
}

# Connections
app_layer -> api_layer: "CacheRequest | invoke"
api_layer -> ring_layer: "Key | lookup"
api_layer -> pool_layer: "Pool.Get | acquire"
pool_layer -> network_layer: "TCP.Write | binary"
network_layer -> server_nodes: "DCP Frame | transport" {
  style.stroke-dash: 3
}