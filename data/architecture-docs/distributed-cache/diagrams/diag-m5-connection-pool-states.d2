direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Connection Pool State Machine {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# --- Functional Layers ---
main_flow: {
  style.stroke: transparent
  style.fill: transparent
  
  # Row 1: External Inputs / Actions
  row1: {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    actions: {
      label: "Control Plane Triggers"
      direction: right
      create_conn: "Create New Connection" {
        shape: step
        style: {
          fill: "#98FB98"
          stroke: "#32CD32"
        }
      }
      health_check: "Health Check" {
        shape: step
        style: {
          fill: "#FAFAD2"
          stroke: "#DAA520"
        }
      }
      maintenance: "" {
        direction: down
        style.stroke: transparent
        style.fill: transparent
        timeout: "Idle Timeout" {
          shape: step
          style: {
            fill: "#FFB6C1"
            stroke: "#DB7093"
          }
        }
        max_lifetime: "Max Lifetime" {
          shape: step
          style: {
            fill: "#FFB6C1"
            stroke: "#DB7093"
          }
        }
      }
    }
  }

  # Row 2: Core State Machine
  row2: {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    states: {
      label: "Connection State Lifecycle"
      direction: down
      
      idle: "IDLE" {
        shape: circle
        style: {
          fill: "#90EE90"
          stroke: "#228B22"
          stroke-width: 3
          font-color: "#006400"
          bold: true
        }
      }
      in_use: "IN_USE" {
        shape: circle
        style: {
          fill: "#87CEEB"
          stroke: "#4169E1"
          stroke-width: 3
          font-color: "#00008B"
          bold: true
        }
      }
      validating: "VALIDATING" {
        shape: diamond
        style: {
          fill: "#FFD700"
          stroke: "#DAA520"
          stroke-width: 2
          font-color: "#8B4513"
        }
      }
      failed: "FAILED" {
        shape: circle
        style: {
          fill: "#FF6B6B"
          stroke: "#DC143C"
          stroke-width: 3
          font-color: "#8B0000"
          bold: true
        }
      }
      closed: "CLOSED" {
        shape: circle
        style: {
          fill: "#D3D3D3"
          stroke: "#696969"
          stroke-width: 2
          font-color: "#2F4F4F"
        }
      }
    }

    pool_mgmt: {
      label: "Pool Resource Management"
      direction: down
      exhausted: "POOL\nEXHAUSTED" {
        shape: hexagon
        style: {
          fill: "#FFA500"
          stroke: "#FF8C00"
          stroke-width: 3
          font-color: "#8B4513"
          bold: true
        }
      }
      wait_queue: "WAIT QUEUE" {
        shape: queue
        style: {
          fill: "#E6E6FA"
          stroke: "#9370DB"
          stroke-width: 2
          font-color: "#4B0082"
        }
      }
    }
  }
}

# --- Legend (Using Grid to avoid 'near' relative paths) ---
legend: {
  near: bottom-right
  label: "State Key"
  grid-columns: 2
  grid-gap: 10
  style: {
    fill: "#F5F5F5"
    stroke: "#A9A9A9"
    stroke-dash: 3
  }
  
  l1: "" {
    shape: circle
    style.fill: "#90EE90"
    width: 15
    height: 15
  }
  t1: "Healthy" { shape: rectangle; style.stroke: transparent; style.fill: transparent }
  
  l2: "" {
    shape: diamond
    style.fill: "#FFD700"
    width: 15
    height: 15
  }
  t2: "Validation" { shape: rectangle; style.stroke: transparent; style.fill: transparent }
  
  l3: "" {
    shape: circle
    style.fill: "#FF6B6B"
    width: 15
    height: 15
  }
  t3: "Error" { shape: rectangle; style.stroke: transparent; style.fill: transparent }
  
  l4: "" {
    shape: circle
    style.fill: "#D3D3D3"
    width: 15
    height: 15
  }
  t4: "Terminal" { shape: rectangle; style.stroke: transparent; style.fill: transparent }
}

# --- State Transitions ---

# 1. Activation
main_flow.row1.actions.create_conn -> main_flow.row2.states.idle: "pool.NewConn()" {
  style: {
    stroke: "#32CD32"
    stroke-width: 2
    animated: true
  }
}

# 2. Lifecycle
main_flow.row2.states.idle -> main_flow.row2.states.in_use: "pool.Get(ctx) | checkout" {
  style: { stroke: "#4169E1"; stroke-width: 2 }
}

main_flow.row2.states.in_use -> main_flow.row2.states.validating: "pool.Put(conn) | return" {
  style: { stroke: "#DAA520"; stroke-width: 2 }
}

main_flow.row2.states.validating -> main_flow.row2.states.idle: "OK | valid" {
  style: { stroke: "#32CD32"; stroke-width: 2 }
}

main_flow.row2.states.validating -> main_flow.row2.states.failed: "FAIL | invalid" {
  style: { stroke: "#DC143C"; stroke-width: 2; stroke-dash: 4 }
}

main_flow.row2.states.failed -> main_flow.row2.states.closed: "close()" {
  style: { stroke: "#696969"; stroke-width: 2 }
}

# 3. Background Maintenance
main_flow.row1.actions.health_check -> main_flow.row2.states.validating: "Keep-Alive" {
  style: { stroke: "#DAA520"; stroke-dash: 4 }
}

main_flow.row1.actions.maintenance.timeout -> main_flow.row2.states.closed: "Prune" {
  style: { stroke: "#DB7093"; stroke-dash: 4 }
}

main_flow.row1.actions.maintenance.max_lifetime -> main_flow.row2.states.closed: "Cycle" {
  style: { stroke: "#DB7093"; stroke-dash: 4 }
}

# 4. Congestion Management
main_flow.row2.states.in_use -> main_flow.row2.pool_mgmt.exhausted: "active >= max" {
  style: { stroke: "#FF8C00"; stroke-width: 2 }
}

main_flow.row2.pool_mgmt.exhausted -> main_flow.row2.pool_mgmt.wait_queue: "enqueue" {
  style: { stroke: "#9370DB"; animated: true }
}

main_flow.row2.pool_mgmt.wait_queue -> main_flow.row2.states.in_use: "signal" {
  style: { stroke: "#32CD32"; stroke-width: 2 }
}

main_flow.row2.pool_mgmt.exhausted -> main_flow.row2.states.failed: "reject" {
  style: { stroke: "#DC143C"; stroke-dash: 4 }
}