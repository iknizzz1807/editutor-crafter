direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # DCP Wire Protocol Packet Format
  Binary layout for cache operations
| {near: top-center}
packet_header: {
  label: "Packet Header (18 bytes fixed)"
  shape: sql_table
  opcode: "0x00-0x01 | uint16   | opcode      // GET=0x01, SET=0x02, DEL=0x03, INCR=0x04"
  key_len: "0x02-0x05 | uint32   | key_len     // Length of key in bytes"
  val_len: "0x06-0x09 | uint32   | val_len     // Length of value (0 for GET/DEL)"
  ttl_ms: "0x0A-0x11 | uint64   | ttl_ms      // TTL in milliseconds (0 = no expiry)"
  total: "Total: 18 bytes"
}
key_payload: {
  label: "Key Payload (variable)"
  shape: sql_table
  key_bytes: "0x12-N   | bytes    | key         // UTF-8 encoded key string"
  note: "Length = key_len bytes"
}
value_payload: {
  label: "Value Payload (variable, SET only)"
  shape: sql_table
  val_bytes: "N+1-M    | bytes    | value       // Raw value bytes"
  note: "Length = val_len bytes"
}
request_layout: {
  label: "Request Packet Layout"
  width: 600
  layout: |md
    
    ┌─────────────────────────────────────────────────────────────────────┐
    │  HEADER (18 bytes, fixed)                                           │
    ├──────────┬──────────┬──────────┬────────────────────────────────────┤
    │ opcode   │ key_len  │ val_len  │ ttl_ms                             │
    │ 2 bytes  │ 4 bytes  │ 4 bytes  │ 8 bytes                            │
    ├──────────┴──────────┴──────────┴────────────────────────────────────┤
    │  KEY (variable, key_len bytes)                                      │
    ├──────────────────────────────────────────────────────────────────────┤
    │  VALUE (variable, val_len bytes) — only for SET                     │
    └──────────────────────────────────────────────────────────────────────┘
    
  |
}
opcode_table: {
  label: "Opcode Definitions"
  shape: sql_table
  get: "0x0001 | GET    | Retrieve value by key"
  set: "0x0002 | SET    | Store key-value with optional TTL"
  del: "0x0003 | DELETE | Remove key from cache"
  incr: "0x0004 | INCR   | Increment counter by amount"
  decr: "0x0005 | DECR   | Decrement counter by amount"
  ping: "0x0006 | PING   | Health check (no key/value)"
  info: "0x0007 | INFO   | Server statistics (no key)"
}
response_layout: {
  label: "Response Packet Layout"
  width: 600
  layout: |md
    
    ┌─────────────────────────────────────────────────────────────────────┐
    │  HEADER (7 bytes, fixed)                                            │
    ├──────────┬──────────┬───────────────────────────────────────────────┤
    │ status   │ val_len  │ (padding)                                    │
    │ 1 byte   │ 4 bytes  │ 2 bytes (reserved)                           │
    ├──────────┴──────────┴───────────────────────────────────────────────┤
    │  VALUE (variable, val_len bytes)                                    │
    │  — val_len = 0xFFFFFFFF (-1) means NULL/not found                   │
    └──────────────────────────────────────────────────────────────────────┘
    
  |
}
status_codes: {
  label: "Status Codes"
  shape: sql_table
  ok: "0x00 | OK       | Success, value follows"
  notfound: "0x01 | NOTFOUND | Key does not exist"
  error: "0x02 | ERROR    | Error, message in value"
  type_err: "0x03 | TYPE_ERR | Type mismatch (INCR on non-int)"
}
byte_order: {
  label: "Byte Order (Endianness)"
  width: 400
  note: |md
    **All multi-byte integers: Network byte order (Big-Endian)**
    
    Example: key_len = 0x0000000F (15 bytes)
    Wire format:
    [0x00][0x00][0x00][0x0F]
      ↑ most significant byte transmitted first
    
  |
}
example_get: {
  label: "Example: GET \"user:123\""
  width: 550
  code: |'c
    // Request packet (24 bytes total)
    // Header (18 bytes)
    0x00 0x01              // opcode = GET
    0x00 0x00 0x00 0x08    // key_len = 8
    0x00 0x00 0x00 0x00    // val_len = 0 (no value)
    0x00 0x00 0x00 0x00    // ttl_ms = 0 (ignored for GET)
    0x00 0x00 0x00 0x00
    // Key payload (8 bytes)
    0x75 0x73 0x65 0x72    // "user"
    0x3A 0x31 0x32 0x33    // ":123"
  '|
}
example_set: {
  label: "Example: SET \"user:123\" = \"alice\" TTL=3600s"
  width: 550
  code: |'c
    // Request packet (29 bytes total)
    // Header (18 bytes)
    0x00 0x02              // opcode = SET
    0x00 0x00 0x00 0x08    // key_len = 8
    0x00 0x00 0x00 0x05    // val_len = 5 ("alice")
    0x00 0x00 0x0E 0x10    // ttl_ms = 3600000 (0x000E1000)
    0x00 0x00 0x00 0x00
    // Key payload (8 bytes)
    0x75 0x73 0x65 0x72    // "user"
    0x3A 0x31 0x32 0x33    // ":123"
    // Value payload (5 bytes)
    0x61 0x6C 0x69 0x63    // "alic"
    0x65                   // "e"
  '|
}
example_response: {
  label: "Example: Response for GET \"user:123\" → \"alice\""
  width: 500
  code: |'c
    // Response packet (12 bytes total)
    // Header (7 bytes)
    0x00                   // status = OK
    0x00 0x00 0x00 0x05    // val_len = 5
    0x00 0x00              // padding
    // Value payload (5 bytes)
    0x61 0x6C 0x69 0x63    // "alic"
    0x65                   // "e"
  '|
}
parser_logic: {
  label: "Parser State Machine"
  shape: class
  label: "ProtocolParser (protocol.go)"
  -buf: "[]byte"
  -pos: "int"
  -state: "ParseState"
  +ParseHeader(): "*Header, error"
  +ParseKey(h): "[]byte, error"
  +ParseValue(h): "[]byte, error"
  +ReadUint16(): "uint16"
  +ReadUint32(): "uint32"
  +ReadUint64(): "uint64"
}
memory_alignment: {
  label: "Memory Alignment Notes"
  width: 450
  note: |md
    **Alignment for efficient parsing:**
    - Header is 18 bytes (not 8-byte aligned)
    - Consider padding to 24 bytes for SIMD operations
    - Key/value pointers can reference original buffer (zero-copy)
    **Optimization tip:** Use `encoding/binary.BigEndian` 
    for portable parsing, or unsafe casts on little-endian 
    systems with byte swapping.
  |
}
packet_header -> key_payload: "key_len bytes"
packet_header -> value_payload: "val_len bytes (SET)"
request_layout -> opcode_table: "opcodes"
response_layout -> status_codes: "status"
byte_order -> example_get: "applied to"
example_get -> example_response: "triggers"
example_set -> example_response: "triggers"
parser_logic -> packet_header: "reads"
parser_logic -> response_layout: "writes"
memory_alignment -> parser_logic: "optimizes"