direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Exponential Backoff with Jitter Timeline
  **Retry Strategy: Preventing Synchronized Thundering Herd**
| {near: top-center}
row_timeline: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  t0: {
    label: "T=0ms"
    style: {
      fill: "#FFE7CB"
      stroke: "#E67E22"
      font-color: "#9E2146"
    }
    request: "Request\nSent" {
      shape: rectangle
      style: {
        fill: "#B6DDF6"
        stroke: "#3498DB"
        font-color: "#1A5276"
      }
    }
  }
  t1: {
    label: "T=100ms\n±25% jitter"
    style: {
      fill: "#FCE7C6"
      stroke: "#E67E22"
      font-color: "#9E2146"
    }
    retry1: "Retry #1\n(75-125ms)" {
      shape: rectangle
      style: {
        fill: "#F9D8A7"
        stroke: "#D68910"
        font-color: "#7D6608"
      }
    }
  }
  t2: {
    label: "T=200ms\n±25% jitter"
    style: {
      fill: "#FCE7C6"
      stroke: "#E67E22"
      font-color: "#9E2146"
    }
    retry2: "Retry #2\n(150-250ms)" {
      shape: rectangle
      style: {
        fill: "#F6C889"
        stroke: "#D68910"
        font-color: "#7D6608"
      }
    }
  }
  t3: {
    label: "T=400ms\n±25% jitter"
    style: {
      fill: "#FCE7C6"
      stroke: "#E67E22"
      font-color: "#9E2146"
    }
    retry3: "Retry #3\n(300-500ms)" {
      shape: rectangle
      style: {
        fill: "#F4B76C"
        stroke: "#D68910"
        font-color: "#7D6608"
      }
    }
  }
}
row_arrows: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  t0 -> t1: "Backoff\n×2" {
    style: {
      stroke: "#E67E22"
      stroke-width: 2
      animated: true
    }
  }
  t1 -> t2: "Backoff\n×2" {
    style: {
      stroke: "#E67E22"
      stroke-width: 2
      animated: true
    }
  }
  t2 -> t3: "Backoff\n×2" {
    style: {
      stroke: "#E67E22"
      stroke-width: 2
      animated: true
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  jitter_box: "Jitter Range" {
    shape: rectangle
    width: 200
    style: {
      fill: "#FCE7C6"
      stroke: "#D68910"
    }
    desc: |md
      **Jitter spreads retry attempts**
      Client A: 100ms → 200ms → 400ms
      Client B: 87ms → 178ms → 356ms
      Client C: 112ms → 223ms → 489ms
      Randomness prevents synchronized
      retry storms during recovery.
    |
  }
}
formula: {
  near: bottom-right
  label: "Backoff Formula"
  code: |'go
    // Calculate backoff with jitter
    func calculateBackoff(base, jitterFactor) {
      jitter = base * jitterFactor * 2 * random()
      return base + jitter - (base * jitterFactor)
    }
    // Example: base=100ms, jitterFactor=0.25
    // Range: [75ms, 125ms]
  '|
}