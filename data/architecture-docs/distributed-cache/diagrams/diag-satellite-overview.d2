direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Distributed Cache System Architecture
  **Satellite View: Implementation Blueprint**
|
title.near: top-center

row_m1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m1_container: "M1: Single Node Cache" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    cache_node: {
      shape: class
      label: "SingleNodeCache (cache.go)"
      -entries: "map[string]*Entry"
      -head: "*Entry"
      -tail: "*Entry"
      -size: "int64"
      -maxSize: "int64"
      -policy: "EvictionPolicy"
      +Get(key): "([]byte, bool)"
      +Set(key, value, ttl): "error"
      +Delete(key): "bool"
    }

    entry_struct: {
      shape: sql_table
      label: "struct Entry (cache.go)"
      f0: "0x00 | []byte     | Key"
      f1: "0x10 | []byte     | Value"
      f2: "0x20 | time.Time  | CreatedAt"
      f3: "0x28 | time.Time  | ExpiresAt"
      f4: "0x30 | *Entry     | Prev (LRU)"
      f5: "0x38 | *Entry     | Next (LRU)"
      f6: "0x40 | uint64     | Frequency (LFU)"
      f7: "0x48 | int64      | Size"
      sz: "Total: ~120 bytes + data"
    }

    eviction_box: "Eviction Policies" {
      direction: right
      lru: "LRU\nO(1) recency" {
        shape: hexagon
        style.fill: "#81C784"
      }
      lfu: "LFU\nO(1) frequency" {
        shape: hexagon
        style.fill: "#81C784"
      }
      ttl: "TTL\nLazy + Active" {
        shape: hexagon
        style.fill: "#A5D6A7"
      }
    }
  }
}

row_m2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  m2_container: "M2: Consistent Hashing" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    hash_ring: {
      shape: class
      label: "HashRing (hashring.go)"
      -vnodes: "[]VirtualNode"
      -nodes: "map[string]*PhysicalNode"
      -vnodeCount: "int"
      +GetNode(key): "(*PhysicalNode, error)"
      +GetNodes(key, n): "([]*PhysicalNode, error)"
      +AddNode(node): "error"
      +RemoveNode(id): "error"
    }

    ring_visual: "Hash Ring (2³² positions)" {
      shape: circle
      style.fill: "#BBDEFB"
      node_a: "Node A (150 vnodes)"
      node_b: "Node B (150 vnodes)"
      node_c: "Node C (150 vnodes)"
    }

    distribution_note: {
      label: |md
        **Virtual Nodes: 150/server**
        - Distribution variance: <8%
        - Remap on add: ~1/N keys
        - Weighted capacity support
      |
    }
  }
}

m1_container.cache_node -> m2_container.hash_ring: "Key | Hash Route" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}

row_m3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  m3_container: "M3: Replication & Failover" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2

    replication_group: {
      shape: class
      label: "ReplicationGroup (replication.go)"
      -primary: "*NodeInfo"
      -secondaries: "[]*NodeInfo"
      -quorumSize: "int"
      +CanFailover(): "bool"
      +Failover(deadID): "(*NodeInfo, error)"
    }

    replica_topology: "Topology (RF=3)" {
      direction: right
      primary: "PRIMARY\n(Writes)" {
        shape: rectangle
        style.fill: "#FFB74D"
        style.stroke: "#E65100"
        style.stroke-width: 3
      }
      sec1: "SECONDARY\n(Reads)" {
        shape: rectangle
        style.fill: "#FFCC80"
      }
      sec2: "SECONDARY\n(Reads)" {
        shape: rectangle
        style.fill: "#FFCC80"
      }
      primary -> sec1: "replicate"
      primary -> sec2: "replicate"
    }

    failure_detector: {
      shape: class
      label: "PhiAccrualDetector (health.go)"
      -intervals: "[]time.Duration"
      -mean: "time.Duration"
      -variance: "time.Duration"
      +RecordHeartbeat(nodeID): "void"
      +Phi(nodeID): "float64"
      +CheckAllNodes(): "[]string"
    }

    cap_note: {
      label: |md
        **CAP Tradeoff: AP (Eventual Consistency)**
        - Quorum: (N/2) + 1 for failover
        - Lease-based leadership
        - Replica lag: async window
      |
    }
  }
}

m2_container.hash_ring -> m3_container.replication_group: "NodeSet | RF Discovery" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}

row_m4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  m4_container: "M4: Cache Patterns" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2

    patterns: {
      direction: right
      aside: "Cache-Aside" {
        style.fill: "#CE93D8"
        note: |md
          1. Check cache
          2. Miss → Load DB
          3. Populate cache
        |
      }
      through: "Write-Through" {
        style.fill: "#BA68C8"
        note: |md
          1. Write cache
          2. Sync write DB
          3. ACK client
        |
      }
    }

    stampede: "Protection Logic" {
      direction: right
      singleflight: "SingleFlight" {
        shape: diamond
        style.fill: "#E1BEE7"
        note: "Request Coalescing"
      }
      prob_expire: "Probabilistic" {
        shape: diamond
        style.fill: "#E1BEE7"
        note: "Early Expiration"
      }
    }
    
    pattern_note: {
      label: |md
        **Pattern Selection:**
        - Profiles: Cache-Aside
        - Counters: Write-Behind
      |
    }
  }
}

m3_container.replica_topology -> m4_container.patterns: "Access | Pattern Logic" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}

row_m5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  m5_container: "M5: Network & Protocol" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2

    protocol: {
      shape: class
      label: "DCP Protocol (Text)"
      +GET(key): "value | null"
      +SET(key, val): "OK"
      +DEL(key): ":1 | :0"
      +INCR(key): ":n"
      +PING(): "+PONG"
    }

    client_lib: {
      shape: class
      label: "Client (client.go)"
      -ring: "*HashRing"
      -pools: "map[string]*Pool"
      -retrier: "*Retrier"
      +Get(ctx, key): "[]byte, error)"
      +Set(ctx, key, val, ttl): "error"
      +Pipeline(ctx): "(*Pipe, error)"
    }

    connection_pool: {
      shape: class
      label: "Pool (pool.go)"
      -idle: "[]*Conn"
      -active: "int"
      -maxActive: "int"
      +Get(ctx): "(*Conn, error)"
      +Put(conn): "void"
    }

    pipeline_box: {
      style.fill: "#FFCDD2"
      label: |md
        **Pipelining (Batch Commands)**
        - Reduce RTT overhead
        - Max 1000 CMDs / batch
      |
    }
  }
}

m4_container.patterns -> m5_container.client_lib: "APIs | Client Interface" {
  style.stroke: "#F44336"
  style.stroke-width: 2
}

legend: {
  label: "Milestone Navigation"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  m1: "M1: Single Node Cache (LRU/LFU)"
  m2: "M2: Consistent Hashing (VNodes)"
  m3: "M3: Replication (Quorum)"
  m4: "M4: Patterns (Write-Through)"
  m5: "M5: Network (DCP Protocol)"
}
legend.near: bottom-right

data_flow: {
  label: |md
    **Request Execution Path:**
    1. Serialization → Hash Selection
    2. Connection Pool Reuse
    3. Cache Node Lookup (LRU/LFU)
    4. Async Replication (if write)
    5. SingleFlight Coalescing (if miss)
  |
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
}
data_flow.near: bottom-left