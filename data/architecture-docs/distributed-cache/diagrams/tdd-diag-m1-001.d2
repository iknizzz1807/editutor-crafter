vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Cache Entry Memory Layout
  `sizeof(Entry) ≈ 120 bytes + key/value data`
| {near: top-center}

direction: right

# Memory layout showing byte offsets in a tabular struct format
layout: {
  grid-columns: 3
  grid-gap: 0

  # Column headers
  offset_header: "Offset" {
    style: {
      fill: "#E8E8E8"
      bold: true
      underline: true
    }
  }
  field_header: "Field" {
    style: {
      fill: "#E8E8E8"
      bold: true
      underline: true
    }
  }
  size_header: "Size" {
    style: {
      fill: "#E8E8E8"
      bold: true
      underline: true
    }
  }

  # Core Data Section
  core_label: "─── CORE DATA ───" {
    style: {
      fill: "#B8D4E8"
      bold: true
    }
  }
  core_label2: "" {style.fill: "#B8D4E8"}
  core_label3: "" {style.fill: "#B8D4E8"}

  offset_00: "0x00" {style.font: mono}
  key_field: "Key []byte" {
    style: {
      fill: "#B8D4E8"
      font: mono
    }
    tooltip: "Slice header: ptr(8) + len(8) + cap(8)"
  }
  key_size: "24 bytes" {
    style: {
      fill: "#B8D4E8"
      font: mono
    }
  }

  offset_18: "0x18" {style.font: mono}
  value_field: "Value []byte" {
    style: {
      fill: "#B8D4E8"
      font: mono
    }
    tooltip: "Slice header: ptr(8) + len(8) + cap(8)"
  }
  value_size: "24 bytes" {
    style: {
      fill: "#B8D4E8"
      font: mono
    }
  }

  # Timestamps Section
  ts_label: "─── TIMESTAMPS ───" {
    style: {
      fill: "#D4B8E8"
      bold: true
    }
  }
  ts_label2: "" {style.fill: "#D4B8E8"}
  ts_label3: "" {style.fill: "#D4B8E8"}

  offset_30: "0x30" {style.font: mono}
  created_field: "CreatedAt time.Time" {
    style: {
      fill: "#D4B8E8"
      font: mono
    }
    tooltip: "Entry creation time (wall + ext + loc)"
  }
  created_size: "24 bytes" {
    style: {
      fill: "#D4B8E8"
      font: mono
    }
  }

  offset_48: "0x48" {style.font: mono}
  expires_field: "ExpiresAt time.Time" {
    style: {
      fill: "#D4B8E8"
      font: mono
    }
    tooltip: "TTL expiration (zero = no expiry)"
  }
  expires_size: "24 bytes" {
    style: {
      fill: "#D4B8E8"
      font: mono
    }
  }

  offset_60: "0x60" {style.font: mono}
  recency_field: "Recency time.Time" {
    style: {
      fill: "#D4B8E8"
      font: mono
    }
    tooltip: "LFU tie-breaking timestamp or last access"
  }
  recency_size: "24 bytes" {
    style: {
      fill: "#D4B8E8"
      font: mono
    }
  }

  # Memory Tracking
  mem_label: "─── MEMORY ───" {
    style: {
      fill: "#E8D4B8"
      bold: true
    }
  }
  mem_label2: "" {style.fill: "#E8D4B8"}
  mem_label3: "" {style.fill: "#E8D4B8"}

  offset_78: "0x78" {style.font: mono}
  size_field: "Size int64" {
    style: {
      fill: "#E8D4B8"
      font: mono
    }
    tooltip: "Total bytes: key + value + overhead"
  }
  size_size: "8 bytes" {
    style: {
      fill: "#E8D4B8"
      font: mono
    }
  }

  # LRU Pointers Section
  lru_label: "─── LRU LINKS ───" {
    style: {
      fill: "#B8E8D4"
      bold: true
    }
  }
  lru_label2: "" {style.fill: "#B8E8D4"}
  lru_label3: "" {style.fill: "#B8E8D4"}

  offset_80: "0x80" {style.font: mono}
  prev_field: "Prev *Entry" {
    style: {
      fill: "#B8E8D4"
      font: mono
    }
    tooltip: "Previous element in LRU doubly-linked list"
  }
  prev_size: "8 bytes" {
    style: {
      fill: "#B8E8D4"
      font: mono
    }
  }

  offset_88: "0x88" {style.font: mono}
  next_field: "Next *Entry" {
    style: {
      fill: "#B8E8D4"
      font: mono
    }
    tooltip: "Next element in LRU doubly-linked list"
  }
  next_size: "8 bytes" {
    style: {
      fill: "#B8E8D4"
      font: mono
    }
  }

  # LFU Tracking Section
  lfu_label: "─── LFU TRACKING ───" {
    style: {
      fill: "#E8B8D4"
      bold: true
    }
  }
  lfu_label2: "" {style.fill: "#E8B8D4"}
  lfu_label3: "" {style.fill: "#E8B8D4"}

  offset_90: "0x90" {style.font: mono}
  freq_field: "Frequency uint64" {
    style: {
      fill: "#E8B8D4"
      font: mono
    }
    tooltip: "Access count for LFU eviction logic"
  }
  freq_size: "8 bytes" {
    style: {
      fill: "#E8B8D4"
      font: mono
    }
  }

  # Padding
  pad_label: "─── ALIGNMENT ───" {
    style: {
      fill: "#C0C0C0"
      bold: true
    }
  }
  pad_label2: "" {style.fill: "#C0C0C0"}
  pad_label3: "" {style.fill: "#C0C0C0"}

  offset_98: "0x98" {style.font: mono}
  padding_field: "padding" {
    style: {
      fill: "#C0C0C0"
      font: mono
      stroke-dash: 3
    }
    tooltip: "Compiler struct alignment padding to 64-bit boundaries"
  }
  padding_size: "~24 bytes" {
    style: {
      fill: "#C0C0C0"
      font: mono
    }
  }

  # Total
  total_label: "═════════════════" {
    style: {
      fill: "#333"
      bold: true
      font-color: white
    }
  }
  total_field: "TOTAL STRUCT" {
    style: {
      fill: "#333"
      bold: true
      font-color: white
    }
  }
  total_size: "≈120 bytes" {
    style: {
      fill: "#333"
      bold: true
      font-color: white
    }
  }
}

# Legend explaining colors and sections
legend: {
  near: bottom-left
  core: "Core Data" {
    width: 120
    style: {
      fill: "#B8D4E8"
    }
  }
  timestamps: "Timestamps" {
    width: 120
    style: {
      fill: "#D4B8E8"
    }
  }
  memory: "Memory" {
    width: 120
    style: {
      fill: "#E8D4B8"
    }
  }
  lru: "LRU Links" {
    width: 120
    style: {
      fill: "#B8E8D4"
    }
  }
  lfu: "LFU Tracking" {
    width: 120
    style: {
      fill: "#E8B8D4"
    }
  }
  pad: "Padding" {
    width: 120
    style: {
      fill: "#C0C0C0"
    }
  }
}

# Memory growth visualization
growth: {
  near: bottom-right
  direction: right
  base: "Base: ~120B" {
    shape: text
    style.font: mono
  }
  arrow1: -> : "+ len(Key)" {
    style: {
      stroke: "#B8D4E8"
      animated: true
    }
  }
  arrow2: -> : "+ len(Value)" {
    style: {
      stroke: "#B8D4E8"
      animated: true
    }
  }
  total_entry: "= Final Entry Size" {
    shape: text
    style: {
      bold: true
      font: mono
    }
  }
}

# Concrete example calculation
example: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#333"
    border-radius: 4
  }
  label: |md
    **Example: Entry with key="user:123", value="alice"**
    
    Base struct:     120 bytes
    Key data:        8 bytes ("user:123")
    Value data:      5 bytes ("alice")
    ────────────────────────────
    Total Memory:    133 bytes
  |
}