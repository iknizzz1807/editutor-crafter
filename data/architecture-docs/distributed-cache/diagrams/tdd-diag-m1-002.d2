vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 20
  }
}

direction: right

# =============================================================================
# HEADER SECTION
# =============================================================================

title: |`md
  # LRU Cache Technical Architecture
  **Components:** Hashmap for O(1) Lookup + Doubly Linked List for O(1) Eviction
  **Constraints:** Fixed Capacity, Thread-Safe (Mutex protected in implementation)
`| {
  near: top-center
  shape: text
  style.font-size: 18
}

# =============================================================================
# DATA STRUCTURE DEFINITIONS
# =============================================================================

hashmap_container: Hashmap Index {
  tooltip: "Maps key strings to memory pointers of Entry nodes in the DLL"
  style: {
    fill: "#F3E8FF"
    stroke: "#7C3AED"
    stroke-width: 2
    border-radius: 8
  }

  table: {
    shape: sql_table
    style.fill: "#EDE9FE"
    
    "user:101": "0x7FF01" {constraint: "Entry*"}
    "user:102": "0x7FF08" {constraint: "Entry*"}
    "user:103": "0x7FF12" {constraint: "Entry*"}
    "user:104": "0x7FF25" {constraint: "Entry*"}
  }

  footer: "sizeof = capacity * (sizeof(string) + sizeof(void*))" {
    shape: text
    style.font-size: 10
    style.italic: true
  }
}

linkedlist_container: Doubly Linked List (DLL) {
  tooltip: "Maintains recency order. Head is Most Recently Used (MRU), Tail is Least Recently Used (LRU)."
  style: {
    fill: "#EFF6FF"
    stroke: "#2563EB"
    stroke-width: 2
    border-radius: 8
  }

  # MRU Head marker
  head_marker: "HEAD (MRU)" {
    shape: circle
    style.fill: "#D1FAE5"
    style.stroke: "#059669"
    style.bold: true
  }

  # DLL Entry Nodes
  entry_101: {
    label: |`md
      **Entry 0x7FF01**
      Key: "user:101"
      Val: {name: "Alice"}
      `|
    shape: rectangle
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    style.border-radius: 4
  }

  entry_102: {
    label: |`md
      **Entry 0x7FF08**
      Key: "user:102"
      Val: {name: "Bob"}
      `|
    shape: rectangle
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    style.border-radius: 4
  }

  entry_103: {
    label: |`md
      **Entry 0x7FF12**
      Key: "user:103"
      Val: {name: "Charlie"}
      `|
    shape: rectangle
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    style.border-radius: 4
  }

  # LRU Tail marker
  tail_marker: "TAIL (LRU)" {
    shape: circle
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    style.bold: true
  }

  # List Connections
  head_marker -> entry_101: "head_ptr" { style.stroke: "#059669"; style.stroke-width: 2 }
  
  entry_101 <-> entry_102: "next / prev" { style.stroke: "#2563EB"; style.stroke-width: 2 }
  entry_102 <-> entry_103: "next / prev" { style.stroke: "#2563EB"; style.stroke-width: 2 }
  
  entry_103 -> tail_marker: "tail_ptr" { style.stroke: "#DC2626"; style.stroke-width: 2 }
}

# =============================================================================
# CROSS-STRUCTURE POINTERS
# =============================================================================

hashmap_container.table."user:101" -> linkedlist_container.entry_101: "O(1) Access" {
  style: {
    stroke: "#7C3AED"
    stroke-width: 2
    stroke-dash: 2
    animated: true
  }
}

hashmap_container.table."user:102" -> linkedlist_container.entry_102: "O(1) Access" {
  style: {
    stroke: "#7C3AED"
    stroke-width: 2
    stroke-dash: 2
    animated: true
  }
}

hashmap_container.table."user:103" -> linkedlist_container.entry_103: "O(1) Access" {
  style: {
    stroke: "#7C3AED"
    stroke-width: 2
    stroke-dash: 2
    animated: true
  }
}

# =============================================================================
# ALGORITHMIC LOGIC & COMPLEXITY
# =============================================================================

operations: Cache Operations {
  style.fill: "#F9FAFB"
  
  get: |`md
    ### GET(key)
    1. **Lookup**: node = map[key]
    2. **Check**: if !node return null
    3. **Promote**: DLL.moveToFront(node)
    4. **Return**: node.value
  `|
  
  put: |`md
    ### PUT(key, value)
    1. **Lookup**: node = map[key]
    2. **Update**: if exists, node.val = val, promote
    3. **Insert**: if new, create node, DLL.pushFront(node), map[key]=node
    4. **Evict**: if size > cap, DLL.popTail(), delete from map
  `|
  
  get.shape: rectangle
  put.shape: rectangle
  get.style.fill: "#ECFDF5"
  put.style.fill: "#FFF7ED"
}

# FIX: Using backticks inside the pipe for the Markdown Table to prevent parser confusion
complexity: Technical Specification {
  label: |`md
    ### Complexity Analysis
    | Operation | Time | Space |
    | :--- | :--- | :--- |
    | **Lookup (GET)** | O(1) | O(1) |
    | **Insertion (PUT)** | O(1) | O(1) |
    | **Eviction** | O(1) | O(1) |
    | **Total Store** | - | O(N) |

    ### Node Layout (Entry)
    - **key**: string (ptr)
    - **value**: interface{} (ptr)
    - **prev**: *Entry
    - **next**: *Entry
    - **sizeof**: ~32-64 bytes
  `|
  style: {
    fill: "#FAFAFA"
    stroke: "#D1D5DB"
    border-radius: 8
  }
}

# =============================================================================
# LAYOUT CONSTRAINTS
# =============================================================================

hashmap_container -> linkedlist_container: "Points To" { style.opacity: 0 }
linkedlist_container -> operations: "Modified By" { style.opacity: 0 }
operations -> complexity: "Spec" { style.opacity: 0 }

# Legend
legend: {
  near: bottom-right
  h: Hashmap { style.fill: "#F3E8FF" }
  d: DLL Node { style.fill: "#FEF3C7" }
  p: "Pointers (Orange)" { shape: text; style.font-color: "#D97706" }
}