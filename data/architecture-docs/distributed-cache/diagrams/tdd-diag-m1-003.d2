vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # LFU Frequency Bucket Structure
  Hierarchical buckets with linked lists of entries at each frequency
| {near: top-center}
# Frequency bucket container
buckets_container: {
  label: "Frequency Buckets (Sorted by Access Count)"
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
  style.stroke-width: 2
  # Bucket 1 (Minimum - eviction candidates)
  bucket_1: {
    label: "Freq = 1\n(Minimum)"
    style.fill: "#FFE4E1"
    style.stroke: "#DC143C"
    style.stroke-width: 3
    entry_1a: "Entry A\nkey: 'old_data'"
    entry_1b: "Entry B\nkey: 'stale'"
    entry_1c: "Entry C\nkey: 'rare'"
    entry_1a -> entry_1b -> entry_1c: "Prev ↔ Next" {
      style.stroke: "#888"
      style.stroke-dash: 2
    }
  }
  # Bucket 2
  bucket_2: {
    label: "Freq = 2"
    style.fill: "#FFF8DC"
    style.stroke: "#DAA520"
    entry_2a: "Entry D\nkey: 'moderate'"
    entry_2b: "Entry E\nkey: 'periodic'"
    entry_2a -> entry_2b: {
      style.stroke: "#888"
      style.stroke-dash: 2
    }
  }
  # Bucket 5
  bucket_5: {
    label: "Freq = 5"
    style.fill: "#E0FFE0"
    style.stroke: "#228B22"
    entry_5a: "Entry F\nkey: 'frequent'"
  }
  # Bucket 100 (Hot)
  bucket_100: {
    label: "Freq = 100\n(HOT)"
    style.fill: "#E6E6FA"
    style.stroke: "#8A2BE2"
    style.stroke-width: 2
    entry_100a: "Entry G\nkey: 'celebrity'"
  }
  # Bucket connections (sorted order)
  bucket_1 -> bucket_2: "next" {
    style.stroke: "#4A90D9"
    style.stroke-width: 2
    target-arrowhead: {
      shape: triangle
      style.filled: true
    }
  }
  bucket_2 -> bucket_5: "next" {
    style.stroke: "#4A90D9"
    style.stroke-width: 2
    target-arrowhead: {
      shape: triangle
      style.filled: true
    }
  }
  bucket_5 -> bucket_100: "next" {
    style.stroke: "#4A90D9"
    style.stroke-width: 2
    target-arrowhead: {
      shape: triangle
      style.filled: true
    }
  }
  # Reverse links
  bucket_2 -> bucket_1: "prev" {
    style.stroke: "#999"
    style.stroke-dash: 3
    source-arrowhead: {
      shape: triangle
      style.filled: true
    }
  }
  bucket_5 -> bucket_2: "prev" {
    style.stroke: "#999"
    style.stroke-dash: 3
    source-arrowhead: {
      shape: triangle
      style.filled: true
    }
  }
  bucket_100 -> bucket_5: "prev" {
    style.stroke: "#999"
    style.stroke-dash: 3
    source-arrowhead: {
      shape: triangle
      style.filled: true
    }
  }
}
# minBucket pointer
min_pointer: {
  shape: text
  label: "minBucket\n(Eviction Target)"
  style.font-color: "#DC143C"
  style.bold: true
}
min_pointer -> buckets_container.bucket_1: {
  style.stroke: "#DC143C"
  style.stroke-width: 3
  style.stroke-dash: 5
  target-arrowhead: {
    shape: triangle
    style.filled: true
  }
}
# Legend
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#CCC"
  legend_title: "Legend" {
    style.bold: true
  }
  eviction: "← Evict from tail of min bucket" {
    style.fill: "#FFE4E1"
    style.font-color: "#DC143C"
  }
  hot_data: "Hot data (rarely evicted)" {
    style.fill: "#E6E6FA"
    style.font-color: "#8A2BE2"
  }
  bucket_link: "Buckets doubly-linked (sorted)" {
    style.fill: "#E8F4FD"
  }
}
# Operations annotation
operations: |md
  ## Key Operations
  **Increment Frequency:**
  1. Remove entry from current bucket
  2. Increment `entry.Frequency++`
  3. Insert into new bucket (create if needed)
  4. Update `minBucket` if lowest becomes empty
  **Evict LFU:**
  1. Find tail of `minBucket` entries list
  2. Remove entry (oldest at same frequency)
  3. LRU tie-breaker within same frequency
| {near: bottom-left}
# Complexity box
complexity: {
  near: top-right
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
  title: "Time Complexity" {
    style.bold: true
  }
  get_freq: "Get frequency bucket: O(1)"
  remove_entry: "Remove entry: O(1)"
  insert_entry: "Insert entry: O(1)"
  find_min: "Find minimum: O(1)"
  evict: "Evict LFU: O(n) in bucket"
}