vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
direction: right
title: |md
  # Cache State Machine
| {near: top-center}
states: {
  Empty: {
    shape: circle
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    style.stroke-width: 2
    label: Empty
  }
  Populating: {
    shape: rectangle
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    style.stroke-width: 2
    style.bold: true
    label: Populating
  }
  Active: {
    shape: rectangle
    style.fill: "#D4EDDA"
    style.stroke: "#155724"
    style.stroke-width: 2
    style.bold: true
    label: Active
  }
  Evicting: {
    shape: diamond
    style.fill: "#F8D7DA"
    style.stroke: "#721C24"
    style.stroke-width: 2
    style.bold: true
    label: Evicting
  }
  Cleanup: {
    shape: hexagon
    style.fill: "#D1ECF1"
    style.stroke: "#0C5460"
    style.stroke-width: 2
    style.bold: true
    label: Cleanup
  }
}
Empty -> Populating: {
  label: |md
    **SET** (first entry)
  |
  style.stroke: "#155724"
  style.stroke-width: 2
}
Populating -> Active: {
  label: |md
    **entry stored**
  |
  style.stroke: "#155724"
  style.stroke-width: 2
}
Active -> Evicting: {
  label: |md
    **memory limit exceeded**
    on SET
  |
  style.stroke: "#721C24"
  style.stroke-width: 2
  style.stroke-dash: 3
}
Evicting -> Active: {
  label: |md
    **LRU/LFU victim removed**
    space available
  |
  style.stroke: "#155724"
  style.stroke-width: 2
}
Active -> Cleanup: {
  label: |md
    **TTL expired**
    (lazy or active)
  |
  style.stroke: "#0C5460"
  style.stroke-width: 2
  style.stroke-dash: 3
}
Cleanup -> Active: {
  label: |md
    **expired entry removed**
    other entries remain
  |
  style.stroke: "#155724"
  style.stroke-width: 2
}
Cleanup -> Empty: {
  label: |md
    **last entry expired**
    cache now empty
  |
  style.stroke: "#666666"
  style.stroke-width: 2
}
Active -> Active: {
  label: |md
    **GET** (hit) → update LRU/LFU
    **SET** (update) → refresh TTL
  |
  style.stroke: "#155724"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.stroke-width: 1
  entry_events: |md
    ## Trigger Events
    - **SET**: Store or update entry
    - **GET**: Retrieve entry
    - **TTL expired**: Entry lifetime ended
    - **memory limit**: Capacity reached
  |
  state_invariants: |md
    ## State Invariants
    - **Empty**: entries = 0, size = 0
    - **Populating**: write in progress
    - **Active**: entries > 0, size ≤ maxSize
    - **Evicting**: size > maxSize (temporary)
    - **Cleanup**: scanning for expired
  |
}
initial: {
  shape: circle
  style.fill: "#333333"
  width: 20
  height: 20
}
initial -> Empty: {
  label: "init"
  style.stroke: "#333333"
  style.stroke-width: 2
}