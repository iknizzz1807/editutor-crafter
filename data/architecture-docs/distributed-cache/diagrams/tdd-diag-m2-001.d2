layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- DOCUMENT METADATA ---
title: |'md
# Consistent Hash Ring Topology
**Technical Specification: Intel-Manual Quality v1.0.4**
*Byte-exact mapping of keys to physical server nodes via virtual partitions.*
'| {
  near: top-center
}

# --- GLOBAL STYLING (Architecture Standards) ---
classes: {
  physical_host: {
    shape: rectangle
    style: {
      stroke: "#a855f7" # Purple (Owner)
      stroke-width: 4
      fill: "#f3e8ff"
      shadow: true
    }
  }
  virtual_partition: {
    shape: circle
    width: 700
    height: 700
    style: {
      stroke: "#3b82f6" # Blue (Data/VNode)
      fill: "#dbeafe"
      font-size: 14
      bold: true
    }
  }
  request_key: {
    shape: diamond
    style: {
      stroke: "#f59e0b" # Orange (Pointers)
      fill: "#fffbeb"
      font-size: 12
    }
  }
  spec_panel: {
    style: {
      fill: "#f8fafc"
      stroke: "#475569"
      stroke-width: 2
      border-radius: 8
    }
  }
  memory_box: {
    shape: sql_table
    style: {
      stroke: "#475569"
      fill: "#f1f5f9"
    }
  }
}

# --- HASH RING VISUALIZATION ---
# Root-level markers to fix 'near' scoping errors
marker_origin: "Offset: 0x00000000" {
  shape: text
  near: top-center
}
marker_midpoint: "Offset: 0x80000000" {
  shape: text
  near: bottom-center
}
traversal_indicator: "Clockwise Traversal ↻" {
  shape: text
  near: center-right
  style: {
    font-color: "#3b82f6"
    bold: true
    italic: true
  }
}

ring_system: {
  label: "HASH SPACE [0, 2³²-1]"
  ring_core: {
    shape: circle
    width: 750
    height: 750
    style: {
      fill: transparent
      stroke: "#94a3b8"
      stroke-width: 8
      stroke-dash: 5
    }
  }
}

# --- PHYSICAL INFRASTRUCTURE ---
infrastructure: {
  server_a: "SERVER_A\nIP: 10.0.0.1\nWeight: 1.0" {
    class: physical_host
  }
  server_b: "SERVER_B\nIP: 10.0.0.2\nWeight: 2.0" {
    class: physical_host
    style.stroke: "#22c55e" 
  }
  server_c: "SERVER_C\nIP: 10.0.0.3\nWeight: 1.0" {
    class: physical_host
  }
}

# --- VIRTUAL NODE DISTRIBUTION ---
partitions: {
  # Node A Partitions
  vnode_a1: "A.1\n0x05F5E100" { class: virtual_partition; width: 60; height: 60 }
  vnode_a2: "A.2\n0x59682F00" { class: virtual_partition; width: 60; height: 60 }
  vnode_a3: "A.3\n0xA6E49D00" { class: virtual_partition; width: 60; height: 60 }

  # Node B Partitions (Higher Weight)
  vnode_b1: "B.1\n0x1DCD6500" { 
    class: virtual_partition; width: 60; height: 60
    style.stroke: "#22c55e"
  }
  vnode_b2: "B.2\n0x2CB41780" { 
    class: virtual_partition; width: 60; height: 60
    style.stroke: "#22c55e"
  }
  vnode_b3: "B.3\n0x89544000" { 
    class: virtual_partition; width: 60; height: 60
    style.stroke: "#22c55e"
  }
  vnode_b4: "B.4\n0xB2D05E00" { 
    class: virtual_partition; width: 60; height: 60
    style.stroke: "#22c55e"
  }

  # Node C Partitions
  vnode_c1: "C.1\n0x02FAF080" { class: virtual_partition; width: 60; height: 60; style.stroke: "#f59e0b" }
  vnode_c2: "C.2\n0x47868C00" { class: virtual_partition; width: 60; height: 60; style.stroke: "#f59e0b" }
  vnode_c3: "C.3\n0xD0974300" { class: virtual_partition; width: 60; height: 60; style.stroke: "#f59e0b" }
}

# Ownership Mappings
infrastructure.server_a -> partitions.vnode_a1
infrastructure.server_a -> partitions.vnode_a2
infrastructure.server_a -> partitions.vnode_a3

infrastructure.server_b -> partitions.vnode_b1
infrastructure.server_b -> partitions.vnode_b2
infrastructure.server_b -> partitions.vnode_b3
infrastructure.server_b -> partitions.vnode_b4

infrastructure.server_c -> partitions.vnode_c1
infrastructure.server_c -> partitions.vnode_c2
infrastructure.server_c -> partitions.vnode_c3

# --- DATA OBJECTS (Incoming Keys) ---
incoming_requests: {
  key_user_123: "KEY: user:123\nHash: 0x47868BFF" { class: request_key }
  key_prod_456: "KEY: prod:456\nHash: 0xA6E49CFF" { class: request_key }
  key_sess_789: "KEY: sess:789\nHash: 0x0BEBC200" { class: request_key }
}

# Routing Logic (The "Clockwise Lookup")
incoming_requests.key_user_123 -> partitions.vnode_c2: "Match: next_higher(hash)" {
  style: { stroke: "#3b82f6"; stroke-dash: 3; animated: true }
}
incoming_requests.key_prod_456 -> partitions.vnode_a3: "Match: next_higher(hash)" {
  style: { stroke: "#3b82f6"; stroke-dash: 3; animated: true }
}
incoming_requests.key_sess_789 -> partitions.vnode_b1: "Match: next_higher(hash)" {
  style: { stroke: "#3b82f6"; stroke-dash: 3; animated: true }
}

# --- IMPLEMENTATION DETAILS (Memory & Byte Layout) ---
vnode_struct: {
  shape: sql_table
  label: "VNode Entry Struct (In-Memory)"
  near: top-right
  style.fill: "#fdf4ff"
  
  0x00: "uint32_t hash_token" { constraint: "Token Index (Key)" }
  0x04: "uint16_t physical_id" { constraint: "Server Index" }
  0x06: "uint16_t status_flags" { constraint: "Bitmask [Active|Pending]" }
  0x08: "char[16] ipv4_addr" { constraint: "Direct Pointer" }
  0x18: "void* next_ptr" { constraint: "Successor Pointer" }
}

# --- FULL TECHNICAL SPECIFICATION ---
technical_spec: {
  class: spec_panel
  near: bottom-right
  
  details: |'md
  ### Algorithm Implementation: `O(log N)`
  
  python
  def get_node(key_hash, ring):
      # Binary search (bisect_right) on sorted vnode hash list
      idx = bisect.bisect_right(ring.sorted_hashes, key_hash)
      if idx == len(ring.sorted_hashes):
          return ring.nodes[ring.sorted_hashes[0]] # Wrap around
      return ring.nodes[ring.sorted_hashes[idx]]
  

  | Parameter | Value |
  | :--- | :--- |
  | **Hash Function** | Murmur3 (32-bit output) |
  | **VNode Ratio** | 256 per Physical Core |
  | **Replication** | N=3 (Standard) |
  | **Quorum** | W=2, R=2 (Strict) |
  | **Balance Var** | < 3.2% with 1000 VNodes |
  | **Remap Ratio** | 1/N on Node Join/Leave |
  | **Gossip Interval** | 500ms |
  | **Consistency** | AP (Available/Partition-Tolerant) |
  | **Topology** | Decentralized Peer-to-Peer |
  '|
}

# --- COMPARISON PANEL ---
benchmark_panel: {
  class: spec_panel
  near: bottom-left
  label: "Scaling Efficiency Analysis"

  naive: {
    label: "Naive Hashing\n(hash % n)"
    style.fill: "#fee2e2"
    style.stroke: "#ef4444"
  }
  
  consistent: {
    label: "Consistent Hashing\n(Ring Topology)"
    style.fill: "#dcfce7"
    style.stroke: "#22c55e"
  }

  naive -> consistent: "Movement: 1-1/n -> 1/n" {
    style.stroke: "#475569"
    style.bold: true
  }
  
  stats: |md
  **Node Addition Benchmark:**
  - Cluster Size: 10 -> 11 Nodes
  - Naive Data Movement: **~91%**
  - Consistent Data Movement: **~9%**
  |
}

# Footnote for Engineers
footnote: |md
  **Intel Manual Spec Notes:**
  1. Virtual nodes (vnodes) are hashed using `host_id + counter`.
  2. Data keys are hashed using the same function.
  3. Ownership is defined as the first vnode encountered clockwise.
| {
  near: bottom-center
  style.font-size: 10
}