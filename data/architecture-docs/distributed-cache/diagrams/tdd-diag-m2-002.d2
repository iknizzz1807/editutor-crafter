vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# --- GLOBAL CLASSES ---
classes: {
  vnode: {
    shape: circle
    width: 14
    height: 14
    style: {
      stroke-width: 1
    }
  }
  server_box: {
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
  metric_box: {
    shape: rectangle
    height: 60
    style: {
      font-color: white
      bold: true
      stroke-width: 0
      shadow: true
    }
  }
  # Color-coded classes for virtual nodes
  vnode_a: { style.fill: "#EF4444"; style.stroke: "#B91C1C" }
  vnode_b: { style.fill: "#3B82F6"; style.stroke: "#1D4ED8" }
  vnode_c: { style.fill: "#10B981"; style.stroke: "#047857" }
  vnode_d: { style.fill: "#F59E0B"; style.stroke: "#B45309" }
}

# --- DIAGRAM TITLE ---
title: |md
  # Virtual Node Distribution
  ### Consistent Hash Ring with Statistical Balance (v1.2.0)
| {
  near: top-center
  shape: text
}

direction: right

# --- HASH RING VISUALIZATION ---
ring_container: {
  label: "Hash Ring Topology (uint32: 0 → 2³²-1)"
  style: {
    fill: "#F8F9FA"
    stroke: "#CBD6E0"
    stroke-width: 2
    border-radius: 8
  }

  ring_visual: {
    shape: circle
    width: 500
    height: 500
    style: {
      fill: transparent
      stroke: "#6B7280"
      stroke-width: 5
      stroke-dash: 0
    }
    
    # Internal ring labels for range
    zero: "0x00000000 (Start)" {
      shape: text
      style.font-size: 12
      label.near: top-center
    }
    max: "0xFFFFFFFF (End)" {
      shape: text
      style.font-size: 12
      label.near: bottom-center
    }
  }

  # Cluster Node A (Red)
  node_a: "Physical Server A" {
    class: server_box
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    
    v1: { class: vnode }
    v2: { class: vnode }
    v3: { class: vnode }
    v4: { class: vnode }
    label_a: "150 vnodes total" { shape: text; style.font-size: 10 }
  }

  # Cluster Node B (Blue)
  node_b: "Physical Server B" {
    class: server_box
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    
    v1: { class: vnode }
    v2: { class: vnode }
    v3: { class: vnode }
    v4: { class: vnode }
    label_b: "150 vnodes total" { shape: text; style.font-size: 10 }
  }

  # Cluster Node C (Green)
  node_c: "Physical Server C" {
    class: server_box
    style.fill: "#DCFCE7"
    style.stroke: "#10B981"
    
    v1: { class: vnode }
    v2: { class: vnode }
    v3: { class: vnode }
    v4: { class: vnode }
    label_c: "150 vnodes total" { shape: text; style.font-size: 10 }
  }

  # Cluster Node D (Orange)
  node_d: "Physical Server D" {
    class: server_box
    style.fill: "#FFEDD5"
    style.stroke: "#F59E0B"
    
    v1: { class: vnode }
    v2: { class: vnode }
    v3: { class: vnode }
    v4: { class: vnode }
    label_d: "150 vnodes total" { shape: text; style.font-size: 10 }
  }

  ring_visual -> node_a: "Mapped Points" { style.stroke-dash: 2 }
  ring_visual -> node_b: "Mapped Points" { style.stroke-dash: 2 }
  ring_visual -> node_c: "Mapped Points" { style.stroke-dash: 2 }
  ring_visual -> node_d: "Mapped Points" { style.stroke-dash: 2 }
}

# --- COMPARISON SECTION ---
distribution_comparison: {
  label: "Load Balancing Efficiency Analysis"
  style: {
    fill: "#FAFBFC"
    stroke: "#E1E4E8"
    stroke-width: 2
    border-radius: 8
  }

  without_vnodes: {
    label: "Naive Hashing (1 position/node)"
    bad_arc_a: "Server A\n54%" { class: metric_box; width: 220; style.fill: "#EF4444" }
    bad_arc_b: "B\n4%" { class: metric_box; width: 40; style.fill: "#3B82F6" }
    bad_arc_c: "Server C\n21%" { class: metric_box; width: 100; style.fill: "#10B981" }
    bad_arc_d: "Server D\n21%" { class: metric_box; width: 100; style.fill: "#F59E0B" }
    
    bad_label: "Variance: 40% (POOR)" { 
      shape: text
      style: {
        bold: true
        font-color: "#DC2626"
        font-size: 16
      }
    }
    
    bad_arc_a -> bad_arc_b -> bad_arc_c -> bad_arc_d: {style.opacity: 0}
  }

  vnode_delta: "UPGRADE: Add 150 Virtual\nNodes per Server" {
    shape: text
    style.font-size: 16
    style.bold: true
    style.font-color: "#2563EB"
  }

  with_vnodes: {
    label: "Consistent Hashing w/ Vnodes"
    good_arc_a: "A\n25.2%" { class: metric_box; width: 110; style.fill: "#EF4444" }
    good_arc_b: "B\n24.9%" { class: metric_box; width: 110; style.fill: "#3B82F6" }
    good_arc_c: "C\n25.1%" { class: metric_box; width: 110; style.fill: "#10B981" }
    good_arc_d: "D\n24.8%" { class: metric_box; width: 110; style.fill: "#F59E0B" }
    
    good_label: "Variance: 3% (OPTIMAL)" { 
      shape: text
      style: {
        bold: true
        font-color: "#059669"
        font-size: 16
      }
    }
    
    good_arc_a -> good_arc_b -> good_arc_c -> good_arc_d: {style.opacity: 0}
  }
}

# --- LEGEND AND CALCULATIONS ---
logic_details: {
  label: "Hash Generation Logic"
  style: {
    fill: "#F3F4F6"
    stroke: "#D1D5DB"
    border-radius: 4
  }
  
  code_snippet: |'python
    # Virtual Node Mapping Function
    def generate_vnodes(server_id, count):
        for i in range(count):
            # Deterministic token generation
            token = murmur3_32(f"{server_id}-{i}")
            # Insert into sorted list (Hash Ring)
            hash_ring.add_node(token, server_id)
    
    # Mapping Server A:
    # "srv-a-0" -> 0x4A2...
    # "srv-a-1" -> 0xBD9...
  '|

  formula_box: {
    label: "P(Key ∩ Node_i) ≈ 1/N ± ε"
    tooltip: "Where ε decreases as vnodes increase"
    shape: rectangle
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
}

# --- STATISTICAL DATA TABLE ---
stats_table: {
  label: "Statistical Distribution Metrics (N=100K keys, 4 nodes)"
  style: {
    fill: white
    stroke: "#9CA3AF"
  }
  
  table: |'md
| VNodes/Node | Standard Deviation | Max Load Bias | Key Range Variance |
| :--- | :--- | :--- | :--- |
| 1 (Naive) | 40.2% | 1.8x | 4,000 - 54,000 |
| 10 | 18.1% | 1.3x | 20,500 - 29,500 |
| 50 | 8.4% | 1.12x | 23,000 - 27,000 |
| **150** | **3.1%** | **1.04x** | **24,800 - 25,200** |
| 500 | 1.4% | 1.02x | 24,850 - 25,150 |
  '|
}

# --- GLOBAL CONNECTIONS AND FLOW ---
ring_container -> distribution_comparison: "Request Routing\nO(log V) search" {
  style: {
    stroke: "#6B7280"
    stroke-dash: 4
    stroke-width: 2
    font-size: 14
  }
}

distribution_comparison -> logic_details
logic_details -> stats_table

# Specific Vnode Styles (Applied via Classes)
ring_container.node_a.v1.class: [vnode; vnode_a]
ring_container.node_a.v2.class: [vnode; vnode_a]
ring_container.node_a.v3.class: [vnode; vnode_a]
ring_container.node_a.v4.class: [vnode; vnode_a]

ring_container.node_b.v1.class: [vnode; vnode_b]
ring_container.node_b.v2.class: [vnode; vnode_b]
ring_container.node_b.v3.class: [vnode; vnode_b]
ring_container.node_b.v4.class: [vnode; vnode_b]

ring_container.node_c.v1.class: [vnode; vnode_c]
ring_container.node_c.v2.class: [vnode; vnode_c]
ring_container.node_c.v3.class: [vnode; vnode_c]
ring_container.node_c.v4.class: [vnode; vnode_c]

ring_container.node_d.v1.class: [vnode; vnode_d]
ring_container.node_d.v2.class: [vnode; vnode_d]
ring_container.node_d.v3.class: [vnode; vnode_d]
ring_container.node_d.v4.class: [vnode; vnode_d]