vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Binary Search Key Lookup Algorithm
  O(log V) lookup on sorted vnode ring
'| {near: top-center}

# Step 1: Hash the Key
step1: {
  label: "Step 1: Hash the Key"
  input: {
    shape: rectangle
    label: |'md
      **Input**
      
      key = "user:12345"
      
    '|
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
  }
  hasher: {
    shape: rectangle
    label: |'md
      **FNV-1a Hash**
      
      hash = fnv64(key)
      
    '|
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
  output1: {
    shape: rectangle
    label: |'md
      **Key Hash**
      
      h = 2,847,293,461
      (0xA9B3C5D5)
      
    '|
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
  input -> hasher: "compute" {style.stroke: "#666"}
  hasher -> output1: "result" {style.stroke: "#666"}
}

# Step 2: Binary Search Setup
step2: {
  label: "Step 2: Binary Search on Sorted VNodes"
  vnode_array: {
    shape: rectangle
    label: |'md
      **Sorted vnodes[] Array**
      | idx | hash (uint32) | nodeID |
      |-----|---------------|--------|
      | 0   | 500,000,000   | C      |
      | 1   | 1,200,000,000 | A      |
      | 2   | 1,800,000,000 | B      |
      | 3   | 2,300,000,000 | D      |
      | 4   | 3,100,000,000 | E      |
      | 5   | 3,800,000,000 | F      |
      **Target**: find first vnode where `vnode.hash >= h`
    '|
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  binary_search: {
    shape: rectangle
    label: |'md
      **sort.Search(len(vnodes), predicate)**
      go
      idx := sort.Search(6, func(i int) bool {
          return vnodes[i].hash >= 2847293461
      })
      
    '|
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
  }
  vnode_array -> binary_search: "search" {style.stroke: "#666"; style.stroke-dash: 3}
}

# Step 3: Search Iterations
step3: {
  label: "Step 3: Binary Search Iterations"
  iter1: {
    shape: rectangle
    label: |'md
      **Iteration 1**
      
      lo=0, hi=6, **mid=3**
      vnodes[3].hash = 2,300,000,000
      2,300,000,000 < 2,847,293,461? YES
      → Search right half
      **lo = 4**
    '|
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
  iter2: {
    shape: rectangle
    label: |'md
      **Iteration 2**
      
      lo=4, hi=6, **mid=5**
      vnodes[5].hash = 3,800,000,000
      3,800,000,000 >= 2,847,293,461? YES
      → Search left half
      **hi = 5**
    '|
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
  iter3: {
    shape: rectangle
    label: |'md
      **Iteration 3**
      
      lo=4, hi=5, **mid=4**
      vnodes[4].hash = 3,100,000,000
      3,100,000,000 >= 2,847,293,461? YES
      → Search left half
      **hi = 4**
    '|
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
  iter4: {
    shape: rectangle
    label: |'md
      **Termination**
      
      lo=4, hi=4, lo >= hi
      → **Return idx = 4**
    '|
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  iter1 -> iter2: "continue" {style.stroke: "#666"; style.stroke-dash: 2}
  iter2 -> iter3: "continue" {style.stroke: "#666"; style.stroke-dash: 2}
  iter3 -> iter4: "done" {style.stroke: "#666"}
}

# Step 4: Wraparound Check
step4: {
  label: "Step 4: Wraparound Handling"
  wraparound_logic: {
    shape: diamond
    label: |'md
      **idx >= len(vnodes)?**
    '|
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
  no_wrap: {
    shape: rectangle
    label: |'md
      **NO - Use found index**
      
      idx = 4
      → vnodes[4].nodeID = "E"
    '|
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
  yes_wrap: {
    shape: rectangle
    label: |'md
      **YES - Wrap to beginning**
      go
      if idx >= len(vnodes) {
          idx = 0  // Ring wraparound
      }
      
      *Example: key hash = 4,000,000,000*
      *Binary search returns idx = 6*
      *Wrap to idx = 0 → Node C*
    '|
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
  wraparound_logic -> no_wrap: "No" {style.stroke: "#2E7D32"}
  wraparound_logic -> yes_wrap: "Yes" {style.stroke: "#C62828"}
}

# Step 5: Return Result
step5: {
  label: "Step 5: Return Physical Node"
  vnode_ref: {
    shape: rectangle
    label: |'md
      **VirtualNode at idx=4**
      go
      vnode := vnodes[4]
      // {
      //   hash:   3,100,000,000
      //   nodeID: "E"
      // }
      
    '|
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  physical_lookup: {
    shape: rectangle
    label: |'md
      **Lookup Physical Node**
      go
      node := nodes[vnode.nodeID]
      // PhysicalNode{
      //   ID:      "cache-server-e"
      //   Address: "10.0.5.10:6379"
      // }
      
    '|
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
  }
  return_val: {
    shape: rectangle
    label: |'md
      **Return**
      go
      return node, nil
      
      Key `"user:12345"` is owned by **Node E**
    '|
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.font: mono
  }
  vnode_ref -> physical_lookup: "nodeID lookup" {style.stroke: "#666"}
  physical_lookup -> return_val: "return" {style.stroke: "#2E7D32"}
}

# Visual Ring Representation
# Corrected: Removed invalid 'near' keys from nested shapes.
ring_visual: {
  label: "Visual: Hash Ring"
  ring: {
    shape: circle
    label: ""
    style.fill: transparent
    style.stroke: "#9E9E9E"
    style.stroke-width: 2
    width: 400
    height: 400
  }
  node_c: {
    shape: circle
    label: "C\n500M"
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    width: 60
  }
  node_a: {
    shape: circle
    label: "A\n1.2B"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    width: 60
  }
  node_b: {
    shape: circle
    label: "B\n1.8B"
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
    width: 60
  }
  node_d: {
    shape: circle
    label: "D\n2.3B"
    style.fill: "#F8BBD9"
    style.stroke: "#C2185B"
    width: 60
  }
  node_e: {
    shape: circle
    label: "E\n3.1B"
    style.fill: "#D1C4E9"
    style.stroke: "#7B1FA2"
    width: 60
  }
  node_f: {
    shape: circle
    label: "F\n3.8B"
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
    width: 60
  }
  key_marker: {
    shape: diamond
    label: "Key\n2.85B"
    style.fill: "#EF5350"
    style.stroke: "#B71C1C"
    style.font-color: white
    width: 50
  }
  
  # Structural connections to help layout without 'near'
  node_c -> node_a -> node_b -> node_d -> node_e -> node_f -> node_c: {
    style.stroke: transparent
  }
  
  ownership_arrow: "← Clockwise to E" {
    style.font-color: "#7B1FA2"
    style.font-size: 14
  }
}

# Connect steps
step1 -> step2: "" {style.stroke: "#666"; style.stroke-dash: 3}
step2 -> step3: "" {style.stroke: "#666"; style.stroke-dash: 3}
step3 -> step4: "" {style.stroke: "#666"; style.stroke-dash: 3}
step4 -> step5: "" {style.stroke: "#666"; style.stroke-dash: 3}

# Complexity annotation
complexity: |'md
  ## Complexity Analysis
  | Metric | Value |
  |--------|-------|
  | Time | O(log V) |
  | Space | O(1) |
  | Comparisons | ⌈log₂ V⌉ |
  
  For V = 1,000 vnodes: ~10 comparisons
  For V = 10,000 vnodes: ~14 comparisons
'| {near: bottom-center}

# Error handling
errors: {
  label: "Error Cases"
  empty_ring: {
    shape: rectangle
    label: |'md
      **Empty Ring**
      go
      if len(vnodes) == 0 {
          return nil, ErrNoNodes
      }
      
    '|
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
}