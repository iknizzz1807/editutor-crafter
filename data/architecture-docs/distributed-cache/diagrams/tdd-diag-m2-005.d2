vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Node Addition Flow
  Consistent Hashing: AddNode Sequence
| {near: top-center}
direction: right
# Step 1: AddNode Call
step1: {
  label: "Step 1: AddNode Call"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  caller: "Client Code" {
    shape: rectangle
    style.fill: white
  }
  call: "AddNode(node)" {
    shape: hexagon
    style.fill: "#2E86AB"
    style.font-color: white
    style.bold: true
  }
  caller -> call: "invokes"
}
# Step 2: Validation
step2: {
  label: "Step 2: Validation"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  check: "Check Existing" {
    shape: diamond
    style.fill: "#FFE0B2"
  }
  exists: "Node Exists?" {
    shape: text
    style.font-color: "#E65100"
    style.bold: true
  }
  error: "ErrNodeExists" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  check -> exists
  check -> error: "YES (return error)"
}
# Step 3: VNode Generation
step3: {
  label: "Step 3: VNode Generation"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  calc: "Calculate Count" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  formula: |md
    `totalVNodes = vnodeCount × max(1, weight)`
  | {
    shape: rectangle
    style.fill: white
    style.stroke: "#2E7D32"
    style.stroke-dash: 2
  }
  genloop: "Generate Loop" {
    shape: rectangle
    style.fill: "#A5D6A7"
    vnode_i: |md
      For i = 0 to totalVNodes-1:
      
      vnodeKey = "nodeID#i"
      hash = hasher.Hash(vnodeKey)
      vnode = {hash, nodeID, weight}
      
    | {
      shape: text
      style.font: mono
      style.font-size: 12
    }
  }
  vnode_list: "New VNodes[]" {
    shape: cylinder
    style.fill: "#81C784"
    style.multiple: true
  }
  calc -> formula
  formula -> genloop
  genloop -> vnode_list: "append"
}
# Step 4: Sorted Merge
step4: {
  label: "Step 4: Sorted Merge"
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  existing: "Existing vnodes[]" {
    shape: rectangle
    style.fill: "#E1BEE7"
    style.multiple: true
  }
  new: "New vnodes[]" {
    shape: rectangle
    style.fill: "#CE93D8"
    style.multiple: true
  }
  append_op: "Append" {
    shape: circle
    style.fill: "#7B1FA2"
    style.font-color: white
    style.bold: true
  }
  sort_op: "Sort by Hash" {
    shape: rectangle
    style.fill: "#BA68C8"
    style.font-color: white
    style.bold: true
  }
  merged: "Merged vnodes[]" {
    shape: rectangle
    style.fill: "#AB47BC"
    style.font-color: white
    style.multiple: true
  }
  existing -> append_op
  new -> append_op
  append_op -> sort_op: "O(V log V)"
  sort_op -> merged
}
# Step 5: Index Update
step5: {
  label: "Step 5: Index Update"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  scan: "Scan vnodes[]" {
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  index_map: "vnodesByNode Map" {
    shape: rectangle
    style.fill: "#90CAF9"
    entry: |md
      
      vnodesByNode[nodeID] = []
      for i, vnode in vnodes:
        if vnode.nodeID == nodeID:
          vnodesByNode[nodeID].append(i)
      
    | {
      shape: text
      style.font: mono
      style.font-size: 11
    }
  }
  scan -> index_map: "rebuild indices"
}
# Step 6: Final Ring State
step6: {
  label: "Step 6: Final Ring State"
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"
  style.stroke-width: 3
  ring: "HashRing" {
    shape: circle
    style.fill: "#CFD8DC"
    style.stroke: "#37474F"
    style.stroke-width: 2
    vnodes: |md
      **vnodes[]**: sorted by hash
      - [0] vnode{hash:100, nodeID:"a"}
      - [1] vnode{hash:250, nodeID:"b"}
      - [2] vnode{hash:300, nodeID:"a"}
      - [3] vnode{hash:500, nodeID:"c"}
      - ...
    | {
      shape: text
      style.font-size: 11
    }
  }
  maps: "Lookup Maps" {
    shape: rectangle
    style.fill: "#B0BEC5"
    nodes_map: |md
      **nodes**: ID → PhysicalNode
      **vnodesByNode**: ID → [indices]
    | {
      shape: text
      style.font: mono
      style.font-size: 11
    }
  }
  ring <-> maps
}
# Flow connections
step1.call -> step2.check: "validate"
step2.check -> step3.calc: "NO (proceed)"
step3.vnode_list -> step4.new
step4.merged -> step5.scan
step5.index_map -> step6.ring
# Time complexity annotations
tc: |md
  ### Time Complexity
  - VNode Generation: **O(V)** where V = vnodeCount × weight
  - Sorted Merge: **O(N log N)** where N = total vnodes
  - Index Rebuild: **O(N)**
  - **Total: O(N log N)**
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  style.stroke-width: 2
}
# Legend
legend: {
  near: bottom-left
  style.fill: white
  style.stroke: "#9E9E9E"
  title: "Legend" {
    shape: text
    style.bold: true
  }
  process: "Process Step" {
    shape: rectangle
    style.fill: "#E8F4FD"
  }
  data: "Data Structure" {
    shape: cylinder
    style.fill: "#E8F5E9"
  }
  decision: "Decision" {
    shape: diamond
    style.fill: "#FFF3E0"
  }
}