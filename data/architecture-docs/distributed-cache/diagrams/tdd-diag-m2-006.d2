vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    weight1: "#7CB9E8"
    weight4: "#FF7F50"
    key: "#90EE90"
    ring: "#E8E8E8"
    border_a: "#4A90D9"
    border_b: "#CC5533"
    text_main: "#2D3436"
  }
}

title: |'md
  # Weighted Node Virtual Node Allocation
  ### Consistent Hashing: Capacity-Proportional Distribution
'| {near: top-center}

direction: down

section_top: {
  label: "INPUT: NODE TOPOLOGY & WEIGHTING"
  style: {
    stroke-width: 2
    stroke-dash: 3
    fill: "#F0F4F8"
  }
  
  weight_comparison: {
    node_weight1: {
      label: "Node A\n(Standard Capacity)\n───────────\nWeight: 1.0\nvNodes: 40"
      shape: rectangle
      style: {
        fill: ${colors.weight1}
        stroke: ${colors.border_a}
        stroke-width: 2
        shadow: true
      }
      width: 220
      height: 120
    }
    node_weight4: {
      label: "Node B\n(High Capacity)\n───────────\nWeight: 4.0\nvNodes: 160"
      shape: rectangle
      style: {
        fill: ${colors.weight4}
        stroke: ${colors.border_b}
        stroke-width: 2
        shadow: true
      }
      width: 220
      height: 120
    }
    
    formula: |'md
      **Virtual Node Calculation (vNode)**
      
      `vNode_count = Base_vNodes × Weight`
      
      - **Node A (Base):** 40 × 1.0 = **40 vNodes**
      - **Node B (Scale):** 40 × 4.0 = **160 vNodes**
      - **Total System:** 200 Tokens on Ring
    '| {
      shape: rectangle
      style: {
        fill: "#F5F5F5"
        stroke: "#CCCCCC"
        border-radius: 4
        font-size: 14
      }
      width: 320
    }
    
    node_weight1 -- node_weight4: {style.stroke-width: 0}
  }
}

section_middle: {
  label: "PROCESS: HASH RING MAPPING"
  style: {
    stroke-width: 2
    stroke-dash: 3
    fill: "#FFFFFF"
  }

  ring_visual: {
    label: "Consistent Hash Ring Mapping (CRC32 Range)"
    
    ring: {
      shape: circle
      width: 500
      height: 500
      style: {
        fill: transparent
        stroke: ${colors.ring}
        stroke-width: 8
      }
      
      # Fixed the error: Removed 'near: top-center' as it is invalid on nested shapes
      internal_stats: |'md
        **Distribution Objectives**
        ---
        - **Range:** [0, 2³²-1]
        - **Target A:** 20.0% coverage
        - **Target B:** 80.0% coverage
        - **Alg:** MurmurHash3
      '| {
        shape: text
        style.font-size: 16
        style.bold: true
      }
    }

    # Node A vNode Subset (Represented)
    vnode_pool_a: {
      vnode_a1: { label: "A₀"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight1}; style.stroke: ${colors.border_a} }
      vnode_a2: { label: "A₁"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight1}; style.stroke: ${colors.border_a} }
      vnode_a3: { label: "A₂"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight1}; style.stroke: ${colors.border_a} }
    }
    
    # Node B vNode Subset (Represented)
    vnode_pool_b: {
      vnode_b1: { label: "B₀"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight4}; style.stroke: ${colors.border_b} }
      vnode_b2: { label: "B₁"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight4}; style.stroke: ${colors.border_b} }
      vnode_b3: { label: "B₂"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight4}; style.stroke: ${colors.border_b} }
      vnode_b4: { label: "B₃"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight4}; style.stroke: ${colors.border_b} }
      vnode_b5: { label: "B₄"; shape: circle; width: 22; height: 22; style.fill: ${colors.weight4}; style.stroke: ${colors.border_b} }
    }

    # Metadata for Engineering Specs
    meta_a: "vNode Registry A\nIdx: node_a#i" {
      shape: text
      style.font-size: 12
      style.font-color: ${colors.border_a}
    }
    meta_b: "vNode Registry B\nIdx: node_b#i" {
      shape: text
      style.font-size: 12
      style.font-color: ${colors.border_b}
    }

    # Request Key Samples
    key1: "User:101\nHash: 0x7A2B" {
      shape: diamond
      width: 60; height: 60
      style.fill: ${colors.key}
      style.stroke: "#228B22"
      style.stroke-width: 2
    }
    key2: "User:204\nHash: 0x1F4D" {
      shape: diamond
      width: 60; height: 60
      style.fill: ${colors.key}
      style.stroke: "#228B22"
      style.stroke-width: 2
    }
  }
}

section_bottom: {
  label: "OUTPUT: DISTRIBUTION ANALYSIS"
  style: {
    stroke-width: 2
    stroke-dash: 3
    fill: "#F9FAFB"
  }

  distribution: {
    chart: {
      label: "vNode Capacity Allocation Histogram"
      bar_a: {
        label: "Node A (40 vNodes)"
        width: 150
        height: 50
        style.fill: ${colors.weight1}
        style.stroke: ${colors.border_a}
      }
      bar_b: {
        label: "Node B (160 vNodes)"
        width: 600
        height: 50
        style.fill: ${colors.weight4}
        style.stroke: ${colors.border_b}
      }
      bar_a -> bar_b: {style.stroke-width: 0}
    }

    stats_table: |'md
      ### Capacity & Distribution Specification
      | Parameter             | Node A (L-Cap) | Node B (H-Cap) | System Total |
      | :-------------------- | :------------- | :------------- | :----------- |
      | **Config Weight**     | 1.0            | 4.0            | 5.0 (Aggregate) |
      | **Virtual Nodes**     | 40             | 160            | 200 Tokens   |
      | **Arc Coverage**      | 20.00%         | 80.00%         | 100.0%       |
      | **Standard Deviation**| σ = 0.04       | σ = 0.02       | -            |
      | **Max Key Overhead**  | 1,024 Bytes    | 4,096 Bytes    | 5,120 Bytes  |
    '| {
      shape: rectangle
      style: {
        fill: "#FAFAFA"
        stroke: "#DDDDDD"
        font-size: 13
      }
    }
  }
}

legend: {
  label: "DIAGRAM LEGEND"
  near: bottom-right
  content: |'md
    ### Architectural Reference
    - ● **Blue Circle**: vNodes for **Node A** (Base)
    - ● **Orange Circle**: vNodes for **Node B** (Scale)
    - ◆ **Green Diamond**: Incoming Request Hashed Key
    - ── **Heavy Arc**: 32-bit Hash Space Continuous Loop
    - ➟ **Dashed Line**: Allocation/Dependency Link
  '|
  style: {
    fill: "#F9F9F9"
    stroke: "#CCCCCC"
    border-radius: 8
    font-size: 12
  }
}

insight: |'md
  **Implementation Note:** By scaling virtual nodes directly proportional to physical capacity (weight), 
  we ensure that "High Capacity" nodes manage a larger share of the hash space. 
  Request keys traverse clockwise until they hit the first available vNode.
'| {
  near: bottom-center
  style: {
    font-size: 14
    italic: true
    fill: "#FFFEE0"
    stroke: "#E6DB74"
  }
}

# Cross-Section Relationships
section_top.weight_comparison.node_weight1 -> section_middle.ring_visual.vnode_pool_a.vnode_a1: "GENERATE 40" {
  style: {
    stroke-dash: 5
    opacity: 0.5
    stroke: ${colors.border_a}
  }
}

section_top.weight_comparison.node_weight4 -> section_middle.ring_visual.vnode_pool_b.vnode_b1: "GENERATE 160" {
  style: {
    stroke-dash: 5
    opacity: 0.5
    stroke: ${colors.border_b}
  }
}

# Routing Simulation
section_middle.ring_visual.key1 -> section_middle.ring_visual.vnode_pool_b.vnode_b3: "WALK_CLOCKWISE" {
  style: {
    stroke: "#228B22"
    stroke-width: 3
    animated: true
  }
}

section_middle.ring_visual.key2 -> section_middle.ring_visual.vnode_pool_a.vnode_a2: "WALK_CLOCKWISE" {
  style: {
    stroke: "#228B22"
    stroke-width: 3
    animated: true
  }
}