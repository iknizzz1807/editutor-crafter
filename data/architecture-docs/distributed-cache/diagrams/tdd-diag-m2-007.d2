vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    hot: "#DC2626"
    warm: "#F59E0B"
    neutral: "#10B981"
    cool: "#3B82F6"
    cold: "#6366F1"
  }
}

title: ||md
  # Key Distribution Heatmap
  ### Consistent Hash Ring Analysis
||
title.near: top-center

direction: right

legend: {
  near: top-right
  label: ""
  scale_title: Distribution Scale {style.bold: true}
  hot_label: "> 30% deviation" {style.fill: ${colors.hot}; style.font-color: white}
  warm_label: "15-30% deviation" {style.fill: ${colors.warm}; style.font-color: white}
  neutral_label: "±5% of expected" {style.fill: ${colors.neutral}; style.font-color: white}
  cool_label: "5-15% below" {style.fill: ${colors.cool}; style.font-color: white}
  cold_label: "> 15% below" {style.fill: ${colors.cold}; style.font-color: white}
}

ring_visualization: Hash Ring (uint32: 0 → 2³²-1) {
  style.fill: "#F8FAFC"
  style.stroke: "#94A3B8"
  style.stroke-width: 2
  
  position_0: "0x00000000" {
    shape: diamond
    width: 20
    style.fill: "#E2E8F0"
    style.stroke: "#64748B"
  }
  position_25: "0x40000000 (25%)" {
    shape: diamond
    width: 20
    style.fill: "#E2E8F0"
    style.stroke: "#64748B"
  }
  position_50: "0x80000000 (50%)" {
    shape: diamond
    width: 20
    style.fill: "#E2E8F0"
    style.stroke: "#64748B"
  }
  position_75: "0xC0000000 (75%)" {
    shape: diamond
    width: 20
    style.fill: "#E2E8F0"
    style.stroke: "#64748B"
  }
}

heatmap_grid: Node Distribution Analysis {
  style.fill: "#FFFFFF"
  style.stroke: "#CBD6E1"
  grid-columns: 5
  grid-gap: 0
  
  header_node: "Node" {class: header}
  header_vnodes: "VNodes" {class: header}
  header_keys: "Key Count" {class: header}
  header_pct: "% Share" {class: header}
  header_dev: "Deviation" {class: header}
  
  node_a_name: "cache-server-a" {class: row_label}
  node_a_vnodes: "150" {class: data}
  node_a_keys: "25,234" {class: data}
  node_a_pct: "25.2%" {class: data_neutral}
  node_a_dev: "+0.2%" {class: neutral}
  
  node_b_name: "cache-server-b" {class: row_label}
  node_b_vnodes: "150" {class: data}
  node_b_keys: "24,891" {class: data}
  node_b_pct: "24.9%" {class: data_cool}
  node_b_dev: "-0.1%" {class: cool}
  
  node_c_name: "cache-server-c" {class: row_label}
  node_c_vnodes: "150" {class: data}
  node_c_keys: "25,156" {class: data}
  node_c_pct: "25.2%" {class: data_neutral}
  node_c_dev: "+0.2%" {class: neutral}
  
  node_d_name: "cache-server-d" {class: row_label}
  node_d_vnodes: "150" {class: data}
  node_d_keys: "24,719" {class: data}
  node_d_pct: "24.7%" {class: data_cool}
  node_d_dev: "-0.3%" {class: cool}
}

distribution_visual: Key Density Across Ring Positions {
  style.fill: "#F1F5F9"
  segment_0_25: Segment 0-25% {
    style.fill: ${colors.neutral}
    keys: "24,892 keys"
    density: "Normal"
  }
  segment_25_50: Segment 25-50% {
    style.fill: ${colors.warm}
    keys: "25,534 keys"
    density: "Slightly High"
  }
  segment_50_75: Segment 50-75% {
    style.fill: ${colors.cool}
    keys: "24,312 keys"
    density: "Slightly Low"
  }
  segment_75_100: Segment 75-100% {
    style.fill: ${colors.neutral}
    keys: "25,262 keys"
    density: "Normal"
  }
  segment_0_25 -> segment_25_50 -> segment_50_75 -> segment_75_100
}

statistics: Statistical Analysis {
  style.fill: "#EFF6FF"
  style.stroke: "#3B82F6"
  
  total_keys: ||md
    **Total Keys:** 100,000
  ||
  
  expected_per_node: ||md
    **Expected per Node:** 25,000 (25.0%)
  ||
  
  std_dev_title: Standard Deviation Calculation {style.bold: true}
  std_dev_formula: ||latex
    \sigma = \sqrt{\frac{\sum(x_i - \mu)^2}{N}} \\
    \text{where: } x_i = \text{key count, } \mu = 25000, N = 4 \\
    \sigma = \sqrt{\frac{234^2 + 891^2 + 156^2 + 281^2}{4}} \\
    \sigma \approx 239 \text{ keys (0.24\%)}
  ||
  
  std_dev_result: ||md
    **σ = 239 keys (0.24% variance)**
    ✅ Within acceptable range (< 5%)
  ||
  std_dev_result.style: {
    fill: "#DCFCE7"
    stroke: "#16A34A"
  }
  
  chi_square: ||md
    **Chi-Square Test:**
    χ² = Σ(Observed - Expected)² / Expected
    χ² ≈ 0.038 (p > 0.99)
    Distribution is statistically uniform
  ||
}

vnode_distribution: Virtual Node Spread {
  style.fill: "#FDF4FF"
  explanation: ||md
    ### Why 150 VNodes?
    With 150 virtual nodes per physical node:
    - Each vnode covers ~1/150 of the ring
    - Statistical variance reduced to ~5-8%
    - Memory overhead: ~40 bytes × 150 = 6KB per node
  ||
  spread_analysis: {
    style.fill: "#FFFFFF"
    min_arc: "Min arc length: 1.5% of ring" {class: spread_data}
    max_arc: "Max arc length: 2.1% of ring" {class: spread_data}
    avg_arc: "Avg arc length: 1.67% of ring" {class: spread_data}
  }
}

comparison: Without VNodes vs With VNodes {
  style.fill: "#FEF3C7"
  without_vnodes: Without Virtual Nodes {
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    node_a_hot: "Node A: 54% (!)" {style.fill: ${colors.hot}; style.font-color: white}
    node_b_cold: "Node B: 12%" {style.fill: ${colors.cold}; style.font-color: white}
    node_c_ok: "Node C: 22%" {style.fill: ${colors.neutral}}
    node_d_low: "Node D: 12%" {style.fill: ${colors.cold}; style.font-color: white}
    variance_bad: "σ = 18.5% ❌" {style.fill: ${colors.hot}; style.font-color: white; style.bold: true}
  }
  with_vnodes: With 150 VNodes {
    style.fill: "#DCFCE7"
    style.stroke: "#16A34A"
    node_a_ok: "Node A: 25.2%" {style.fill: ${colors.neutral}}
    node_b_ok: "Node B: 24.9%" {style.fill: ${colors.neutral}}
    node_c_ok2: "Node C: 25.2%" {style.fill: ${colors.neutral}}
    node_d_ok: "Node D: 24.7%" {style.fill: ${colors.neutral}}
    variance_good: "σ = 0.24% ✅" {style.fill: ${colors.neutral}; style.bold: true}
  }
  without_vnodes -> with_vnodes: Adding VNodes\nimproves balance {
    style.stroke: "#16A34A"
    style.stroke-width: 3
    style.animated: true
  }
}

conclusion: ||md
  ## Analysis Summary
  | Metric | Value | Status |
  | :--- | :--- | :--- |
  | Max Deviation | 0.3% | ✅ Excellent |
  | Standard Deviation | 0.24% | ✅ Excellent |
  | Chi-Square p-value | > 0.99 | ✅ Uniform |

  **Recommendation:** Current configuration (150 vnodes) provides excellent
  distribution. No tuning required.
||
conclusion.near: bottom-center
conclusion.style: {
  fill: "#F0FDF4"
  stroke: "#16A34A"
}

