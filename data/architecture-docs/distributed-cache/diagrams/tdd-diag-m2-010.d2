vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Hash Ring State Machine
  Consistent Hashing with Virtual Nodes
| {near: top-center}

direction: right

# States
Empty: {
  shape: circle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: "#1B5E20"
  }
  invariants: |md
    **Invariants:**
    - `len(vnodes) == 0`
    - `len(nodes) == 0`
    - `len(vnodesByNode) == 0`
  |
}

Populating: {
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
    stroke-width: 2
    font-color: "#E65100"
  }
  invariants: |md
    **Invariants:**
    - `len(vnodes) > 0`
    - `len(nodes) >= 1`
    - vnodes slice sorted by hash
    - vnodesByNode indices valid
  |
}

Active: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 3
    font-color: "#0D47A1"
  }
  invariants: |md
    **Invariants:**
    - `len(nodes) >= 1`
    - vnodes sorted by hash
    - All vnodes point to valid nodes
    - GetNode always returns valid node
    - Binary search O(log V)
  |
}

Rebalancing: {
  shape: diamond
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
    stroke-width: 2
    font-color: "#880E4F"
  }
  invariants: |md
    **Invariants:**
    - Transition in progress
    - Lock held (write)
    - Indices being rebuilt
    - No reads allowed
  |
}

Error: {
  shape: circle
  style: {
    fill: "#FFEBEE"
    stroke: "#B71C1C"
    stroke-width: 2
    font-color: "#B71C1C"
  }
  label: "Error\nState"
}

# Initial state indicator
Initial: {
  shape: circle
  style: {
    fill: "#2E7D32"
    stroke: "#1B5E20"
    stroke-width: 2
  }
  width: 20
  height: 20
}

Initial -> Empty: "● start"

# Transitions from Empty
Empty -> Populating: "AddNode(node)\n✓ node.ID unique\n✓ weight >= 0" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    animated: true
  }
}

Empty -> Error: "AddNode(node)\n✗ node.ID exists\n→ ErrNodeExists" {
  style: {
    stroke: "#B71C1C"
    stroke-dash: 3
  }
}

# Transitions from Populating
Populating -> Active: "population\ncomplete\n✓ vnodes sorted" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

Populating -> Rebalancing: "AddNode(node)\n✓ node.ID unique" {
  style: {
    stroke: "#EF6C00"
    stroke-width: 2
  }
}

# Transitions from Active
Active -> Rebalancing: "AddNode(node)\n✓ node.ID unique" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

Active -> Rebalancing: "RemoveNode(nodeID)\n✓ nodeID exists" {
  style: {
    stroke: "#C2185B"
    stroke-width: 2
  }
}

Active -> Error: "RemoveNode(nodeID)\n✗ nodeID not found\n→ ErrNodeNotFound" {
  style: {
    stroke: "#B71C1C"
    stroke-dash: 3
  }
}

Active -> Error: "AddNode(node)\n✗ node.ID exists\n→ ErrNodeExists" {
  style: {
    stroke: "#B71C1C"
    stroke-dash: 3
  }
}

# Transitions from Rebalancing
Rebalancing -> Active: "rebalance\ncomplete\n✓ indices rebuilt\n✓ vnodes sorted" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

Rebalancing -> Empty: "RemoveNode(last)\n✓ len(nodes)==1\n→ ring empty" {
  style: {
    stroke: "#C2185B"
    stroke-width: 2
  }
}

# Self-transitions (valid operations in state)
Active -> Active: "GetNode(key)\n✓ ring non-empty\n→ returns *PhysicalNode" {
  style: {
    stroke: "#1565C0"
    stroke-dash: 5
  }
}

Active -> Active: "GetNodes(key, n)\n✓ n <= len(nodes)\n→ returns []*PhysicalNode" {
  style: {
    stroke: "#1565C0"
    stroke-dash: 5
  }
}

# Legend
Legend: {
  label: State Transition Legend
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
  valid: Valid transition {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  invalid: Invalid/Error transition {
    style: {
      stroke: "#B71C1C"
      stroke-dash: 3
    }
  }
  self: Self-loop (read op) {
    style: {
      stroke: "#1565C0"
      stroke-dash: 5
    }
  }
}

# Invariant summary box
Invariants_Summary: {
  label: ||md
    ## Global Invariants
    1. **vnode slice always sorted** by hash ascending
    2. **Each node ID appears at most once** in nodes map
    3. **vnodesByNode indices** remain consistent with vnode slice
    4. **Binary search with wraparound** always returns valid node
    5. **Lock ordering**: Write lock for Add/Remove, Read lock for Get
  ||
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    border-radius: 8
  }
  near: bottom-right
}

# Time complexity annotations
Complexity: {
  label: ||md
    ## Time Complexity
    | Operation | Complexity |
    |-----------|------------|
    | GetNode | O(log V) |
    | AddNode | O(V log V) |
    | RemoveNode | O(V) |
    | GetNodes(n) | O(n × log V) |
    
    *V = total virtual nodes*
  ||
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    border-radius: 8
  }
  near: bottom-left
}