vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Primary-Secondary Replication Topology
  **System Invariant**: All writes must serialize through Node A. 
  **Consistency Model**: Eventual Consistency for Read-Only Replicas.
  **Replication Mode**: Asynchronous Binlog Streaming.
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
  }
}

direction: right

classes: {
  client: {
    shape: person
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  primary: {
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.stroke-width: 4
    style.bold: true
    style.double-border: true
  }
  secondary: {
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    style.stroke-width: 2
  }
  write_arrow: {
    style.stroke: "#2E7D32"
    style.stroke-width: 4
    style.animated: true
  }
  replicate_arrow: {
    style.stroke: "#EF6C00"
    style.stroke-dash: 4
    style.animated: true
    target-arrowhead: triangle
  }
  read_arrow: {
    style.stroke: "#1976D2"
    style.stroke-width: 2
    style.stroke-dash: 2
  }
  state_box: {
    style.font-size: 10
    style.border-radius: 4
  }
}

# Replication Group Definition
replication_group: "Replication Group (Cluster ID: CLSTR-092)" {
  style: {
    fill: "#F8F9FA"
    stroke: "#757575"
    stroke-dash: 5
  }

  primary_node: "PRIMARY NODE [A]\nADDR: 10.0.0.1:5432\nROLE: LEADER\nLSN: 0x4F2A1" {
    class: primary
    internal_state: "Memory & Buffer State" {
      style.fill: "#F1F8E9"
      write_lock: "MUTEX: LOCKED" {
        class: state_box
        style.fill: "#FFCDD2"
      }
      binlog_buffer: "BUFFER: 0x45...0x8E" {
        class: state_box
        style.fill: "#BBDEFB"
      }
      heartbeat: "STATUS: HEALTHY" {
        class: state_box
        style.fill: "#C8E6C9"
      }
    }
  }

  secondary_b: "SECONDARY NODE [B]\nADDR: 10.0.0.2:5432\nROLE: FOLLOWER\nLSN: 0x4F29E (Lag: 3ms)" {
    class: secondary
    internal_state: "Follower State" {
      style.fill: "#FFFDE7"
      relay_log: "RELAY: SYNC_0x42" {
        class: state_box
        style.fill: "#BBDEFB"
      }
      read_only: "MODE: READ_ONLY" {
        class: state_box
        style.fill: "#E1F5FE"
      }
    }
  }

  secondary_c: "SECONDARY NODE [C]\nADDR: 10.0.0.3:5432\nROLE: FOLLOWER\nLSN: 0x4F290 (Lag: 12ms)" {
    class: secondary
    internal_state: "Follower State" {
      style.fill: "#FFFDE7"
      relay_log: "RELAY: SYNC_0x38" {
        class: state_box
        style.fill: "#BBDEFB"
      }
      read_only: "MODE: READ_ONLY" {
        class: state_box
        style.fill: "#E1F5FE"
      }
    }
  }

  # Internal cluster communication
  primary_node -> secondary_b: "Binlog Dump\n(Streaming)" {
    class: replicate_arrow
    source-arrowhead.label: "Master Thread"
    target-arrowhead.label: "I/O Thread"
  }
  
  primary_node -> secondary_c: "Binlog Dump\n(Streaming)" {
    class: replicate_arrow
    source-arrowhead.label: "Master Thread"
    target-arrowhead.label: "I/O Thread"
  }
}

# Client Layer Definition
clients: "Client Access Layer" {
  style.fill: transparent
  style.stroke-width: 0

  writer: "Writer Client\n(Service: Orders)" {
    class: client
  }
  
  reader_pool: "Reader Pool" {
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
    reader1: "Analytics Svc" {class: client}
    reader2: "User Profile Svc" {class: client}
    reader3: "Legacy Reporting" {class: client}
  }
}

# Global Flow Connections
clients.writer -> replication_group.primary_node: "POST /write_request\n(Protocol: Protobuf/gRPC)" {
  class: write_arrow
}

clients.reader_pool.reader1 -> replication_group.primary_node: "GET /latest\n(Strong Consistency)" {
  class: read_arrow
}

clients.reader_pool.reader2 -> replication_group.secondary_b: "GET /profile\n(Eventual Consistency)" {
  class: read_arrow
}

clients.reader_pool.reader3 -> replication_group.secondary_c: "GET /report_raw\n(High Latency Tolerated)" {
  class: read_arrow
}

# Documentation and Legend
legend: ||md
  ### Operational Legend
  - **Primary (Node A)**: The only node allowing `INSERT/UPDATE/DELETE`.
  - **Secondary (B/C)**: Replicas that pull changes via binary log offsets.
  - **Async Replication**: Primary does not wait for replicas to ACK before returning to client.
  - **LSN (Log Sequence Number)**: Unique identifier for the position in the transaction stream.
|| {
  near: bottom-left
  style: {
    fill: "#ECEFF1"
    stroke: "#607D8B"
    font-size: 14
  }
}

timing_note: ||md
  ### Timing & SLA Profile
  | Interaction Path | Expected Latency | Consistency Mode |
  | :--- | :--- | :--- |
  | **Client → Primary** | 2ms - 8ms | **ACID Compliant** |
  | **Replication Lag** | 10ms - 500ms | **Asynchronous** |
  | **Read (Primary)** | < 1ms | **Linearizable** |
  | **Read (Secondary)** | < 2ms | **Eventual** |

  *Note: High replication lag (> 1s) triggers automatic alerts to SRE on-call.*
|| {
  near: bottom-right
  style: {
    fill: "#FFF8E1"
    stroke: "#FFB300"
    font-size: 14
  }
}

# Structural Annotation
replication_group.primary_node.internal_state.write_lock.style.font-color: red
replication_group.primary_node.internal_state.write_lock.style.bold: true