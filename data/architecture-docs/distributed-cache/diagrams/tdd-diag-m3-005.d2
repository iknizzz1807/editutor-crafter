vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Quorum Decision Matrix
### Primary-Secondary Replication Failover Analysis
'| {near: top-center}

direction: right

three_node: "3-Node Cluster (RF=3)" {
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
    double-border: true
  }
  
  header_3: |'md
  ### CONFIGURATION: RF=3
  **Quorum Size: 2** (majority = ⌈3/2⌉)
  **Fault Tolerance**: 1 Node
  '| 

  scenario_3a: "Scenario A: Single Node Failure" {
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    nodes_3a: {
      style.fill: transparent
      n1_3a: "N1\n✓ Alive" {
        shape: circle
        style.fill: "#4CAF50"
        style.font-color: white
      }
      n2_3a: "N2\n✓ Alive" {
        shape: circle
        style.fill: "#4CAF50"
        style.font-color: white
      }
      n3_3a: "N3\n✗ Dead" {
        shape: circle
        style.fill: "#F44336"
        style.font-color: white
      }
    }
    result_3a: |'md
    **Status: 2/3 Up**
    **Quorum: ✓ MET** (2 ≥ 2)
    → **Failover PROCEEDS**
    '| 
  }

  scenario_3b: "Scenario B: Network Partition (1 vs 2)" {
    style.fill: "#FFECB3"
    style.stroke: "#FF9800"
    partition_3b: {
      style.fill: transparent
      side_a_3b: "Minority Side" {
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        style.stroke-dash: 3
        n1_side_a: "N1\n(Isolated)" {
          shape: circle
          style.fill: "#9E9E9E"
          style.font-color: white
        }
        label_a: |'md
        **Quorum: ✗ NO** (1 < 2)
        → **Failover BLOCKED**
        '|
      }
      divider_3b: "║\nNET\nSEP\n║" {
        shape: text
        style.font-color: "#F44336"
        style.bold: true
      }
      side_b_3b: "Majority Side" {
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        n2_side_b: "N2\n✓" {
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        n3_side_b: "N3\n✓" {
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        label_b: |'md
        **Quorum: ✓ YES** (2 ≥ 2)
        → **Failover PROCEEDS**
        '|
      }
    }
  }

  scenario_3c: "Scenario C: Two Node Failure" {
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    nodes_3c: {
      style.fill: transparent
      n1_3c: "N1\n✓ Alive" {
        shape: circle
        style.fill: "#4CAF50"
        style.font-color: white
      }
      n2_3c: "N2\n✗ Dead" {
        shape: circle
        style.fill: "#F44336"
        style.font-color: white
      }
      n3_3c: "N3\n✗ Dead" {
        shape: circle
        style.fill: "#F44336"
        style.font-color: white
      }
    }
    result_3c: |'md
    **Status: 1/3 Up**
    **Quorum: ✗ LOST** (1 < 2)
    → **Cluster HALTS**
    '| 
  }
}

five_node: "5-Node Cluster (RF=5)" {
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
    double-border: true
  }
  
  header_5: |'md
  ### CONFIGURATION: RF=5
  **Quorum Size: 3** (majority = ⌈5/2⌉)
  **Fault Tolerance**: 2 Nodes
  '| 

  scenario_5a: "Scenario A: Single Node Failure" {
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    nodes_5a: {
      style.fill: transparent
      n1_5a: "N1\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n2_5a: "N2\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n3_5a: "N3\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n4_5a: "N4\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n5_5a: "N5\n✗" { shape: circle; style.fill: "#F44336"; style.font-color: white }
    }
    result_5a: |'md
    **Alive: 4/5**
    **Quorum: ✓ YES** (4 ≥ 3)
    → **Failover PROCEEDS**
    '| 
  }

  scenario_5b: "Scenario B: 2 vs 3 Partition" {
    style.fill: "#FFECB3"
    style.stroke: "#FF9800"
    partition_5b: {
      style.fill: transparent
      side_a_5b: "Minority (2)" {
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        style.stroke-dash: 3
        n1_5b: "N1" { shape: circle; style.fill: "#9E9E9E"; style.font-color: white }
        n2_5b: "N2" { shape: circle; style.fill: "#9E9E9E"; style.font-color: white }
        label_5a: |'md
        **Quorum: ✗ NO** (2 < 3)
        → **Read-Only**
        '|
      }
      divider_5b: "║\nNET\nSEP\n║" {
        shape: text
        style.font-color: "#F44336"
        style.bold: true
      }
      side_b_5b: "Majority (3)" {
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        n3_5b: "N3\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
        n4_5b: "N4\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
        n5_5b: "N5\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
        label_5b: |'md
        **Quorum: ✓ YES** (3 ≥ 3)
        → **Primary Elected**
        '|
      }
    }
  }

  scenario_5c: "Scenario C: Two Node Failure" {
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    nodes_5c: {
      style.fill: transparent
      n1_5c: "N1\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n2_5c: "N2\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n3_5c: "N3\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n4_5c: "N4\n✗" { shape: circle; style.fill: "#F44336"; style.font-color: white }
      n5_5c: "N5\n✗" { shape: circle; style.fill: "#F44336"; style.font-color: white }
    }
    result_5c: |'md
    **Alive: 3/5**
    **Quorum: ✓ YES** (3 ≥ 3)
    → **Tolerates 2 Failures**
    '| 
  }

  scenario_5d: "Scenario D: Three Node Failure" {
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    nodes_5d: {
      style.fill: transparent
      n1_5d: "N1\n✓" { shape: circle; style.fill: "#4CAF50"; style.font-color: white }
      n2_5d: "N2\n✗" { shape: circle; style.fill: "#F44336"; style.font-color: white }
      n3_5d: "N3\n✗" { shape: circle; style.fill: "#F44336"; style.font-color: white }
      n4_5d: "N4\n✗" { shape: circle; style.fill: "#F44336"; style.font-color: white }
      n5_5d: "N5\n✗" { shape: circle; style.fill: "#F44336"; style.font-color: white }
    }
    result_5d: |'md
    **Alive: 1/5**
    **Quorum: ✗ LOST** (1 < 3)
    → **Unavailable**
    '| 
  }
}

legend: "Decision Matrix Summary" {
  near: bottom-left
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  matrix: |'md
  | Cluster Size | Quorum Req | Max Failures | Min Majority Side |
  | :--- | :--- | :--- | :--- |
  | 3 nodes | 2 | 1 node | 2 nodes |
  | 5 nodes | 3 | 2 nodes | 3 nodes |
  | 7 nodes | 4 | 3 nodes | 4 nodes |

  **Split-Brain Prevention**: Only the side with ≥ quorum can elect a new primary. 
  The minority side must remain in read-only mode or shut down.
  '|
}

invariant: "CAP Theorem Implementation" {
  near: bottom-right
  style.fill: "#E1F5FE"
  style.stroke: "#03A9F4"
  cap_note: |'md
  **During Network Partition:**
  - **Majority side**: Chooses **Availability** (A) 
    Continues accepting writes.
  - **Minority side**: Chooses **Consistency** (C) 
    Blocks writes to prevent data divergence.
  **Key Insight**: Quorum ensures exactly ONE active primary per cluster.
  '|
}