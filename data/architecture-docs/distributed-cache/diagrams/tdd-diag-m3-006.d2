vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    primary: "#4A90D9"
    secondary: "#7FB069"
    danger: "#D45555"
    warning: "#E8A838"
    muted: "#8B8B8B"
    bg: "#F5F7FA"
    border: "#CBD6E0"
    hex_data: "#44C7B1"
  }
}

title: |md
  # Split-Brain Prevention with Leader Leases
  **Implementation Spec: Distributed Consensus Safety (v2.4)**
| {near: top-center}

# ============================================
# PROTOCOL DEFINITION: LEASE OBJECT LAYOUT
# ============================================
# Memory-grade byte layout for engineering implementation
lease_memory_layout: {
  shape: sql_table
  label: "Lease Packet Binary Structure (32 Bytes)"
  style.fill: "${colors.bg}"
  
  00_07: "Term ID (uint64)" {constraint: "Monotonic Counter"}
  08_15: "Expiry Timestamp (uint64)" {constraint: "Nanoseconds Since Epoch"}
  16_23: "Holder ID (uint64)" {constraint: "Unique Node Identifier"}
  24_31: "Quorum Signature (bytes8)" {constraint: "CRC-64 Checksum"}
  
  00_07.style.fill: "${colors.hex_data}"
  08_15.style.fill: "${colors.hex_data}"
  16_23.style.fill: "${colors.hex_data}"
  24_31.style.fill: "${colors.hex_data}"
}

# ============================================
# NORMAL STATE: Primary with Valid Lease
# ============================================
normal_state: "Normal State: Primary Holds Valid Lease" {
  style: {
    fill: "${colors.bg}"
    stroke: "${colors.border}"
    border-radius: 8
  }
  
  primary_node: "Node A (Primary)" {
    style: {
      fill: "${colors.primary}"
      font-color: white
      bold: true
    }
    width: 180
    height: 120
    
    lease_box: "LEASE STATUS\nID: 0x41 (Node A)\nEXP: T+10s\nSTATE: ACTIVE" {
      style: {
        fill: "${colors.secondary}"
        font-color: white
        stroke-width: 2
      }
      shape: rectangle
    }
  }

  secondary_b: "Node B (Secondary)" {
    style.fill: "${colors.muted}"
    style.font-color: white
    width: 140
    height: 100
  }

  secondary_c: "Node C (Secondary)" {
    style.fill: "${colors.muted}"
    style.font-color: white
    width: 140
    height: 100
  }

  primary_node -> secondary_b: "Replication (OpID: 1042)" {
    style: {
      stroke: "${colors.primary}"
      animated: true
      stroke-width: 2
    }
  }
  primary_node -> secondary_c: "Replication (OpID: 1042)" {
    style: {
      stroke: "${colors.primary}"
      animated: true
      stroke-width: 2
    }
  }

  client: "External Client" {
    shape: person
    style.fill: "${colors.warning}"
  }
  client -> primary_node: "Write Request\n(Commit Log 1043)" {
    style: {
      stroke: "${colors.secondary}"
      bold: true
    }
  }
}

# ============================================
# PARTITION STATE: Split Network
# ============================================
partition_state: "Partition State: Network Split & Lease Expiry" {
  style: {
    fill: "${colors.bg}"
    stroke: "${colors.danger}"
    stroke-width: 2
    border-radius: 8
  }

  minority: "MINORITY (Isolated)" {
    style: {
      fill: "#FFF0F0"
      stroke: "${colors.danger}"
      stroke-dash: 4
    }
    
    isolated_primary: "Node A (Stale Primary)" {
      style.fill: "${colors.muted}"
      style.font-color: white
      
      expired_lease: "LEASE EXPIRED\nT+11s > T+10s\nSTATE: REJECT_ALL" {
        style: {
          fill: "${colors.danger}"
          font-color: white
          bold: true
        }
      }
    }
    
    m_client: "Client A" { shape: person; style.fill: "#DDD" }
    m_client -> isolated_primary: "Write Request"
    (m_client -> isolated_primary)[0].label: "503: SERVICE_UNAVAILABLE\n(LEASE_EXPIRED)" {
      style.font-color: "${colors.danger}"
    }
  }

  barrier: "== NETWORK PARTITION ==" {
    shape: text
    style: {
      font-color: "${colors.danger}"
      bold: true
      font-size: 20
    }
  }

  majority: "MAJORITY (Active Quorum)" {
    style: {
      fill: "#F0FFF0"
      stroke: "${colors.secondary}"
    }
    
    new_primary: "Node B (Elected Primary)" {
      style: {
        fill: "${colors.primary}"
        font-color: white
        bold: true
      }
      
      active_lease: "NEW LEASE\nID: 0x42 (Node B)\nEXP: T+25s\nSTATE: ACTIVE" {
        style: {
          fill: "${colors.secondary}"
          font-color: white
        }
      }
    }
    
    node_c: "Node C (Secondary)" { style.fill: "${colors.muted}"; style.font-color: white }
    
    election_logic: "Consensus Quorum\n2/3 Nodes Reached" {
      shape: diamond
      style: {
        fill: "${colors.secondary}"
        font-color: white
      }
    }

    maj_client: "Client B" { shape: person; style.fill: "${colors.warning}" }
    maj_client -> new_primary: "Write Request → 200 OK" {
      style.stroke: "${colors.secondary}"
    }
    new_primary -> node_c: "Replicate Log 1043+"
    election_logic -> new_primary: "PROMOTED"
  }
}

# ============================================
# LEASE LIFECYCLE STATE MACHINE
# ============================================
lifecycle: "Lease Lifecycle Logic" {
  style.fill: "${colors.bg}"
  
  S1: LEASE_HELD {
    shape: circle
    style.fill: "${colors.secondary}"
    style.font-color: white
  }
  
  S2: LEASE_EXPIRED {
    shape: circle
    style.fill: "${colors.danger}"
    style.font-color: white
  }

  S1 -> S2: "Wall Clock > Expiry\nAction: Clear Write Buffer" {
    style.stroke: "${colors.danger}"
  }
  
  S2 -> S1: "Consensus Aquired\nAction: Enable Write Log" {
    style.stroke: "${colors.secondary}"
    style.stroke-dash: 3
  }
}

# ============================================
# TIMELINE: SEQUENCE OF SAFETY
# ============================================
timeline: "Consensus Timing Diagram (Safety Window)" {
  direction: right
  style.fill: "${colors.bg}"

  t0: "T=0s\nPartition\nCreated" { shape: circle; style.fill: "${colors.muted}" }
  t1: "T=5s\nQuorum Heartbeat\nTimeouts" { shape: circle; style.fill: "${colors.warning}" }
  t2: "T=10s\nOld Lease\nHard-Expiry" { shape: circle; style.fill: "${colors.danger}" }
  t3: "T=11s\nSafety Buffer\nMargin" { shape: circle; style.fill: "${colors.muted}" }
  t4: "T=12s\nMajority Promotes\nNode B" { shape: circle; style.fill: "${colors.primary}" }
  
  t0 -> t1 -> t2 -> t3 -> t4
}

# ============================================
# KEY INSIGHT (FIXED COMPILATION)
# ============================================
# Using container with explicit label to fix 'near' field compilation error
key_insight: {
  shape: rectangle
  near: bottom-center
  style: {
    fill: "#E8F4FD"
    stroke: "${colors.primary}"
    stroke-width: 2
    border-radius: 8
  }
  label: |md
    ### Implementation Note: Safety Guarantees
    1. **Clock Drift**: Protocol assumes a bounded clock drift $\Delta$. The safety margin $M$ (T=11s) must be $> \Delta$.
    2. **Fencing**: New Primary (Node B) increments the `Term ID` (0x0C). Even if Node A resumes, storage will reject its lower term IDs.
    3. **Quorum**: A partition cannot have two majorities. Only one side can reach the threshold of $(N/2)+1$.
    4. **Invariance**: At timestamp $T$, if Node B has a valid lease, Node A's lease MUST be expired in all possible observers.
  |
}

# Connection between states for flow
normal_state -> partition_state: "Fault Injected" {
  style: {
    stroke: "${colors.danger}"
    stroke-width: 4
  }
}