vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # Failover State Machine
  Primary-Secondary Replication Group Lifecycle
| {near: top-center}
direction: right
# State definitions
Healthy: {
  shape: circle
  style: {
    fill: "#90EE90"
    stroke: "#228B22"
    stroke-width: 3
    font-color: "#006400"
    bold: true
  }
  tooltip: "Normal operation: Primary active, all replicas in sync"
}
PrimarySuspect: {
  shape: circle
  style: {
    fill: "#FFD700"
    stroke: "#DAA520"
    stroke-width: 3
    font-color: "#8B4513"
    bold: true
  }
  tooltip: "Primary missed heartbeat(s), under observation"
}
PrimaryDead: {
  shape: circle
  style: {
    fill: "#FF6B6B"
    stroke: "#DC143C"
    stroke-width: 3
    font-color: "#8B0000"
    bold: true
  }
  tooltip: "Primary declared dead by failure detector (phi > threshold)"
}
FailoverInProgress: {
  shape: circle
  style: {
    fill: "#DDA0DD"
    stroke: "#9370DB"
    stroke-width: 3
    font-color: "#4B0082"
    bold: true
  }
  tooltip: "Quorum check in progress, secondary promotion attempt"
}
NewPrimaryElected: {
  shape: circle
  style: {
    fill: "#87CEEB"
    stroke: "#4169E1"
    stroke-width: 3
    font-color: "#00008B"
    bold: true
  }
  tooltip: "New primary successfully promoted, cluster recovering"
}
# Initial state marker
Initial: {
  shape: circle
  width: 20
  height: 20
  style: {
    fill: "#000000"
    stroke: "#000000"
  }
}
# Transitions
Initial -> Healthy: "START" {
  style: {
    stroke-width: 2
    stroke: "#228B22"
    font-size: 14
  }
}
Healthy -> PrimarySuspect: "heartbeat_missed\n[timeout < threshold]" {
  style: {
    stroke-width: 2
    stroke: "#DAA520"
    font-size: 12
  }
}
PrimarySuspect -> Healthy: "heartbeat_received\n[phi < threshold]" {
  style: {
    stroke-width: 2
    stroke: "#228B22"
    font-size: 12
  }
}
PrimarySuspect -> PrimaryDead: "phi > threshold\n[declare dead]" {
  style: {
    stroke-width: 2
    stroke: "#DC143C"
    font-size: 12
  }
}
PrimaryDead -> FailoverInProgress: "initiate_failover()\n[quorum check]" {
  style: {
    stroke-width: 2
    stroke: "#9370DB"
    font-size: 12
  }
}
FailoverInProgress -> NewPrimaryElected: "promote_secondary()\n[LastSync check]" {
  style: {
    stroke-width: 2
    stroke: "#4169E1"
    font-size: 12
  }
}
FailoverInProgress -> PrimaryDead: "rollback\n[no quorum / no healthy secondary]" {
  style: {
    stroke-width: 2
    stroke: "#DC143C"
    stroke-dash: 4
    font-size: 12
  }
}
NewPrimaryElected -> Healthy: "recovery_complete\n[broadcast complete]" {
  style: {
    stroke-width: 2
    stroke: "#228B22"
    font-size: 12
  }
}
# Self-loop for continuous monitoring
Healthy -> Healthy: "heartbeat_ok\n[lease renewed]" {
  style: {
    stroke-width: 2
    stroke: "#90EE90"
    font-size: 11
  }
}
# State invariants box
Invariants: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#808080"
    stroke-dash: 2
    border-radius: 8
  }
  inv1: |md
    **Invariants:**
    - At most ONE primary per group
    - Failover requires QUORUM (majority)
    - Lease must be valid for writes
    - Promotion selects most recent sync
  |
}
# Rollback scenarios box
RollbackScenarios: {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FFF0F0"
    stroke: "#DC143C"
    stroke-dash: 2
    border-radius: 8
  }
  rb: |md
    **Rollback Triggers:**
    - `ErrNoQuorum`: < majority alive
    - `ErrNoHealthySecondary`: no sync'd replica
    - `ErrLeaseExpired`: old primary still active
    - Network partition: minority isolated
  |
}
# Legend
Legend: {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#FFFFFF"
    stroke: "#808080"
    border-radius: 8
  }
  leg_title: "Legend" {
    style: { bold: true }
  }
  normal: "───── Normal transition" {
    style: { font-size: 11 }
  }
  rollback_line: "- - - Rollback path" {
    style: { font-size: 11 }
  }
  green_state: "● Healthy state" {
    style: { font-size: 11; font-color: "#228B22" }
  }
  yellow_state: "● Warning state" {
    style: { font-size: 11; font-color: "#DAA520" }
  }
  red_state: "● Error state" {
    style: { font-size: 11; font-color: "#DC143C" }
  }
}