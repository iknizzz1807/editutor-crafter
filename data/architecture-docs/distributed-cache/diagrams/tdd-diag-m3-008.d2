vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

# -----------------------------------------------------------------------------------------
# TITLE & HEADER
# -----------------------------------------------------------------------------------------
title: |'md
# REPLICA LAG & EVENTUAL CONSISTENCY TIMELINE
**Technical Specification: Write-to-Read Consistency Window**
*Intel Manual Style Ref: DS-772-REPL | Offset: 0x00 - 0xFF*
'|
title.shape: text
title.near: top-center
title.style: {
  font-size: 24
  bold: true
}

# -----------------------------------------------------------------------------------------
# MAIN TIMELINE CONTAINER
# -----------------------------------------------------------------------------------------
timeline: {
  grid-columns: 1
  grid-gap: 30
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#FFFFFF"
    border-radius: 4
  }

  # Synchronization Ticks (Timeline Axis)
  time_markers: {
    grid-columns: 5
    grid-gap: 0
    t0: "T+0ms [START]" { style: { fill: transparent; font: mono; font-size: 14; font-color: "#777777"; stroke-width: 0 } }
    t5: "T+5ms [COMMIT]" { style: { fill: transparent; font: mono; font-size: 14; font-color: "#777777"; stroke-width: 0 } }
    t10: "T+10ms [LATENCY]" { style: { fill: transparent; font: mono; font-size: 14; font-color: "#777777"; stroke-width: 0 } }
    t15: "T+15ms [APPLY]" { style: { fill: transparent; font: mono; font-size: 14; font-color: "#777777"; stroke-width: 0 } }
    t20: "T+20ms [SYNC]" { style: { fill: transparent; font: mono; font-size: 14; font-color: "#777777"; stroke-width: 0 } }
  }

  # Primary Storage Node Layer
  primary_row: {
    grid-columns: 2
    grid-gap: 10
    
    label_box: "PRIMARY\n(Node A)" {
      shape: rectangle
      style: {
        fill: "#D1C4E9" # Purple: Header
        stroke: "#673AB7"
        stroke-width: 2
        font: mono
        bold: true
      }
    }
    
    events: {
      grid-columns: 4
      grid-gap: 10
      write: "WRITE [0x01]\nkey:123\nval:\"alice\"" {
        style: {
          fill: "#BBDEFB" # Blue: Data
          stroke: "#1976D2"
          stroke-width: 2
          bold: true
        }
      }
      ack: "ACK\n(Commit)" {
        style: {
          fill: "#C8E6C9" # Green: Free/Success
          stroke: "#388E3C"
          stroke-width: 1
        }
      }
      repl: "LOG SHIP\nLSN: 42" {
        style: {
          fill: "#FFE0B2" # Orange: Log/Pointer
          stroke: "#F57C00"
          stroke-width: 2
        }
      }
      idle: "READY" {
        style: {
          fill: "#F5F5F5" # Gray: Padding
          stroke: "#BDBDBD"
        }
      }
    }
  }

  # Network Latency Layer
  network_row: {
    grid-columns: 2
    grid-gap: 10
    label_box: "TRANSPORT\nLAYER" {
      style: {
        fill: transparent
        font: mono
        font-size: 12
        stroke-width: 0
      }
    }
    events: {
      grid-columns: 4
      grid-gap: 10
      spacer_1: "" { style.opacity: 0 }
      spacer_2: "" { style.opacity: 0 }
      transit: "LOG TRANSIT\nLatency: 12ms" {
        style: {
          fill: "#FFF9C4"
          stroke: "#FBC02D"
          stroke-width: 2
          stroke-dash: 5
        }
      }
      spacer_3: "" { style.opacity: 0 }
    }
  }

  # Secondary Storage Node Layer
  secondary_row: {
    grid-columns: 2
    grid-gap: 10
    label_box: "SECONDARY\n(Node B)" {
      shape: rectangle
      style: {
        fill: "#D1C4E9" # Purple: Header
        stroke: "#673AB7"
        stroke-width: 2
        font: mono
        bold: true
      }
    }
    events: {
      grid-columns: 4
      grid-gap: 10
      stale: "OLD STATE\nkey:123\nval:\"bob\"" {
        style: {
          fill: "#FFCDD2" # Red: Error/Stale
          stroke: "#D32F2F"
          stroke-width: 2
        }
      }
      fail_read: "STALE READ\nReturning 'bob'" {
        style: {
          fill: "#FFCDD2" # Red: Error/Stale
          stroke: "#D32F2F"
          stroke-width: 2
          stroke-dash: 2
        }
      }
      apply: "RX & APPLY\nLSN: 42" {
        style: {
          fill: "#FFE0B2" # Orange: Pointers
          stroke: "#F57C00"
          stroke-width: 2
        }
      }
      sync: "CONSISTENT\nval:\"alice\"" {
        style: {
          fill: "#BBDEFB" # Blue: Data
          stroke: "#1976D2"
          stroke-width: 2
        }
      }
    }
  }
}

# -----------------------------------------------------------------------------------------
# ANNOTATION
# -----------------------------------------------------------------------------------------
stale_window: |'md
### STALE READ WINDOW (LAG)
**Inconsistency Interval:** ~12ms

1. **T=5ms:** Master commits new data.
2. **T=8ms:** Client reads from Replica.
3. **RESULT:** Stale data returned ("bob").

*Remediation:*
Implement **Version Vectors** or **Read-After-Write**
routing to Primary for specific keys.
'|
stale_window.shape: rectangle
stale_window.near: top-right
stale_window.style: {
  fill: "#FFFDE7"
  stroke: "#FBC02D"
  stroke-width: 2
  stroke-dash: 4
  shadow: true
}

# -----------------------------------------------------------------------------------------
# LEGEND & FLOW
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-center
  grid-columns: 4
  grid-gap: 20
  l1: "Fresh State (Blue)" { style: { fill: "#BBDEFB"; stroke: "#1976D2" } }
  l2: "Stale/Error (Red)" { style: { fill: "#FFCDD2"; stroke: "#D32F2F" } }
  l3: "Log Shipping (Orange)" { style: { fill: "#FFE0B2"; stroke: "#F57C00" } }
  l4: "Async Delay (Yellow)" { style: { fill: "#FFF9C4"; stroke: "#FBC02D"; stroke-dash: 3 } }
}

# Logic Flow Connections
timeline.primary_row.events.write -> timeline.primary_row.events.repl: "Write-Ahead Log"
timeline.primary_row.events.repl -> timeline.network_row.events.transit: "Ingress"
timeline.network_row.events.transit -> timeline.secondary_row.events.apply: "Egress" {
  style: {
    stroke: "#F57C00"
    stroke-width: 3
    stroke-dash: 5
    animated: true
  }
}

# Causal Fault
timeline.secondary_row.events.stale -> timeline.secondary_row.events.fail_read: "Read Triggered"
timeline.secondary_row.events.apply -> timeline.secondary_row.events.sync: "State Convergence" {
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}