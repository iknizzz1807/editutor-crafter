vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Replica Manager Architecture
  **Module:** M3 Replication & Consistency
  **Spec:** IEEE-2988 Distributed Consensus
| {near: top-center}

direction: right

# Core ReplicaManager container
ReplicaManager: {
  style: {
    fill: "#E8E8E8"
    stroke: "#666666"
    stroke-width: 2
    border-radius: 8
  }

  # HashRing - Consistent Hashing Implementation
  HashRing: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
    label: |md
      **HashRing**
      *sizeof=128KB (base)*
      ─────────────────────
      - vnodes: []VirtualNode
      - nodes: map[string]*PhysicalNode
      - hashFn: func(uint32) uint32
      ─────────────────────
      + GetNode(key) → *PhysicalNode
      + GetNodes(key, n) → []*PhysicalNode
    |
  }

  # Failure Detection
  FailureDetector: {
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
    label: |md
      **FailureDetector**
      *Heartbeat Monitor*
      ─────────────────────
      - config: DetectorConfig
      - nodes: map[string]*NodeHealth
      ─────────────────────
      + RecordHeartbeat(nodeID)
      + CheckAllNodes() []string
      + GetNodeStatus(nodeID) NodeStatus
    |
  }

  PhiAccrualDetector: {
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FFA000"
      stroke-width: 2
    }
    label: |md
      **PhiAccrualDetector**
      *Adaptive Probabilistic*
      ─────────────────────
      - nodeStats: map[string]*IntervalStats
      - threshold: float64 (default 8.0)
      ─────────────────────
      + Phi(nodeID) float64
      + IsAvailable(nodeID) bool
    |
  }

  # Replication Groups
  ReplicationGroups: {
    shape: cylinder
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
    }
    label: |md
      **ReplicationGroups**
      *Consistency Management*
      ─────────────────────
      - groups: map[string]*Group
      ─────────────────────
      ReplicationGroup struct {
        - Primary: *NodeInfo
        - Secondaries: []*NodeInfo
        - QuorumSize: int
        - Failover(deadNodeID)
      }
    |
  }

  # Connection Pools
  ConnectionPools: {
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    label: |md
      **ConnectionPools**
      *TCP Stream Multiplexer*
      ─────────────────────
      - pools: map[string]*Pool
      ─────────────────────
      Pool struct {
        - idle: []*Conn
        - active: int
        - Get(ctx) → *Conn
        - Put(conn)
      }
    |
  }

  # Leader Leases
  LeaderLeases: {
    shape: rectangle
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
    }
    label: |md
      **LeaderLeases**
      *Split-Brain Guard*
      ─────────────────────
      - map[string]*LeaderLease
      ─────────────────────
      LeaderLease struct {
        - NodeID: string
        - ExpiresAt: time.Time
        + Acquire() bool
        + Renew() bool
        + IsValid() bool
      }
    |
  }

  # Configuration
  Config: {
    shape: rectangle
    style: {
      fill: "#ECEFF1"
      stroke: "#546E7A"
      stroke-width: 2
    }
    label: |md
      **Config (Global)**
      ─────────────────────
      - ReplicationFactor: 3
      - HeartbeatInterval: 500ms
      - FailureTimeout: 5s
      - PhiThreshold: 8.0
      - LeaseDuration: 10s
    |
  }

  # Internal connections within ReplicaManager
  HashRing -> ReplicationGroups: "GetNodes(key, RF)\n→ group assignment" {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  FailureDetector -> ReplicationGroups: "Promote Secondary\non Primary fail" {
    style: {
      stroke: "#F57C00"
      stroke-width: 2
      stroke-dash: 3
    }
  }
  PhiAccrualDetector -> FailureDetector: "Suspicion Level\n(Phi value)" {
    style: {
      stroke: "#FFA000"
      stroke-width: 2
    }
  }
  ReplicationGroups -> ConnectionPools: "Target Node RPC" {
    style: {
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
  ReplicationGroups -> LeaderLeases: "Assert Authority" {
    style: {
      stroke: "#C2185B"
      stroke-width: 2
    }
  }
  
  # Invisible layout constraints
  Config -> HashRing: {style.opacity: 0}
  Config -> FailureDetector: {style.opacity: 0}
  Config -> ReplicationGroups: {style.opacity: 0}
}

# External components
Client: {
  shape: person
  style: {
    fill: "#BBDEFB"
    stroke: "#1976D2"
  }
}

CacheNodes: {
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 2
    stroke-dash: 5
  }
  NodeA: {
    shape: circle
    style.fill: "#81C784"
    label: "Node A\n(Primary)"
  }
  NodeB: {
    shape: circle
    style.fill: "#A5D6A7"
    label: "Node B\n(Secondary)"
  }
  NodeC: {
    shape: circle
    style.fill: "#A5D6A7"
    label: "Node C\n(Secondary)"
  }
  
  NodeA -> NodeB: "Sync Replicate" {style.stroke-dash: 3}
  NodeA -> NodeC: "Async Replicate" {style.stroke-dash: 3}
}

# External connections
Client -> ReplicaManager: "Write(key, val)\n[WAIT QUORUM]" {
  style: {
    stroke: "#1976D2"
    stroke-width: 3
  }
}
Client -> ReplicaManager: "Read(key)\n[CONSISTENT]" {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
  }
}

ReplicaManager.ConnectionPools -> CacheNodes: "TCP Keep-alive" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}

CacheNodes -> ReplicaManager.FailureDetector: "UDP Heartbeat\n(SeqNum, Timestamp)" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    animated: true
  }
}

# Legend
Legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  label: |md
    **Legend**
    ──▶ Synchronous Call
    - - -▶ Asynchronous/Periodic
    ═══▶ Network Request
    (●) State Node
  |
}

# Annotations (FIXED: Set to constant value for ELK compliance)
Annotation1: |md
  ### Operational Logic:
  1. **Write Path:**
     - Client calls `WriteToPrimary`.
     - `HashRing` resolves primary node.
     - `LeaderLease` verified (must be held by primary).
     - Data replicated to secondaries via `ConnectionPool`.
     - ACK returned once `QuorumSize` is reached.

  2. **Failure & Recovery:**
     - `PhiAccrualDetector` tracks inter-arrival times of heartbeats.
     - If `Phi > 8.0`, `FailureDetector` marks node as `SUSPECT`.
     - `ReplicationGroups` initiates promotion of secondary with highest `LastSyncIndex`.
     - `LeaderLease` on dead node expires, allowing new primary to `Acquire()`.

  3. **Performance:**
     - `ConnectionPool` reduces handshake overhead for high-frequency internal RPCs.
| {
  near: bottom-left
  shape: text
  style: {
    font-size: 13
    font-color: "#333333"
  }
}