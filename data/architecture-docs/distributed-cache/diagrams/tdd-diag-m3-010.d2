vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Network Partition Recovery Flow
title: |md
  # Network Partition Recovery Sequence
  Detection → Minority Unavailable → Majority Failover → Healing & Sync
| {near: top-center}
shape: sequence_diagram
# Define participants
NodeA: "Node A\n(Primary)"
NodeB: "Node B\n(Secondary)"
NodeC: "Node C\n(Secondary)"
NodeD: "Node D\n(Secondary)"
NodeE: "Node E\n(Secondary)"
# ===================
# PHASE 1: Normal Operation
# ===================
phase1_normal: {
  NodeA -> NodeB: "heartbeat"
  NodeA -> NodeC: "heartbeat"
  NodeA -> NodeD: "heartbeat"
  NodeA -> NodeE: "heartbeat"
  NodeB -> NodeA: "heartbeat ack"
  NodeC -> NodeA: "heartbeat ack"
  NodeD -> NodeA: "heartbeat ack"
  NodeE -> NodeA: "heartbeat ack"
}
# ===================
# PHASE 2: Partition Occurs
# ===================
phase2_partition: {
  NodeA -> NodeD: "heartbeat ✗" {
    style.stroke: red
    style.stroke-dash: 3
  }
  NodeA -> NodeE: "heartbeat ✗" {
    style.stroke: red
    style.stroke-dash: 3
  }
  NodeD -> NodeA: "heartbeat ✗" {
    style.stroke: red
    style.stroke-dash: 3
  }
  NodeE -> NodeA: "heartbeat ✗" {
    style.stroke: red
    style.stroke-dash: 3
  }
  # Minority side still communicates
  NodeD -> NodeE: "heartbeat" {
    style.stroke: orange
  }
  NodeE -> NodeD: "heartbeat" {
    style.stroke: orange
  }
}
# ===================
# PHASE 3: Detection & Phi Accrual
# ===================
phase3_detection: {
  NodeD: "Φ = 8.5\n(threshold exceeded)" {
    style.fill: "#ffcccc"
    style.stroke: red
  }
  NodeE: "Φ = 9.2\n(threshold exceeded)" {
    style.fill: "#ffcccc"
    style.stroke: red
  }
  NodeD: "Status: SUSPECT → DEAD"
  NodeE: "Status: SUSPECT → DEAD"
  NodeD: "Count alive: 2/5"
  NodeE: "Quorum required: 3"
  NodeD."❌ CANNOT FAILOVER\nNo quorum (2 < 3)" {
    style.fill: "#ffdddd"
    style.font-color: darkred
  }
}
# ===================
# PHASE 4: Majority Side Behavior
# ===================
phase4_majority: {
  NodeA: "Count alive: 3/5"
  NodeA: "Quorum: 3 ✓"
  NodeA: "Primary alive\nContinue serving"
  NodeA -> NodeB: "replication"
  NodeA -> NodeC: "replication"
  NodeB -> NodeA: "ack"
  NodeC -> NodeA: "ack"
  NodeA: "Writes succeed\nCluster operational"
}
# ===================
# PHASE 5: Partition Healing
# ===================
phase5_healing: {
  NodeD -> NodeA: "heartbeat ✓" {
    style.stroke: green
    style.animated: true
  }
  NodeE -> NodeA: "heartbeat ✓" {
    style.stroke: green
    style.animated: true
  }
  NodeA -> NodeD: "heartbeat ✓" {
    style.stroke: green
  }
  NodeA -> NodeE: "heartbeat ✓" {
    style.stroke: green
  }
}
# ===================
# PHASE 6: Sync & Recovery
# ===================
phase6_sync: {
  NodeA -> NodeD: "SYNC: write_log\n(entries 100-150)"
  NodeA -> NodeE: "SYNC: write_log\n(entries 100-150)"
  NodeD -> NodeA: "SYNC: ack\n(caught up)"
  NodeE -> NodeA: "SYNC: ack\n(caught up)"
  NodeD: "Status: HEALTHY\nLastSync: now()" {
    style.fill: "#ccffcc"
    style.stroke: green
  }
  NodeE: "Status: HEALTHY\nLastSync: now()" {
    style.fill: "#ccffcc"
    style.stroke: green
  }
  NodeA: "Cluster: 5/5 healthy\nFull replication restored" {
    style.fill: "#ccffcc"
  }
}
# Styling
NodeA.style.fill: "#E8D4F8"
NodeB.style.fill: "#D4E8F8"
NodeC.style.fill: "#D4E8F8"
NodeD.style.fill: "#F8E8D4"
NodeE.style.fill: "#F8E8D4"