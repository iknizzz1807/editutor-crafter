vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Cache Pattern Comparison Matrix
| {near: top-center}

direction: right

# Define classes for consistent styling
classes: {
  pattern_box: {
    style: {
      stroke: "#333333"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  header_cell: {
    style: {
      fill: "#4A5568"
      font-color: "#ffffff"
      bold: true
      border-radius: 4
    }
  }
  data_cell: {
    style: {
      fill: "#F7FAFC"
      border-radius: 4
    }
  }
  low_latency: {
    style: {
      fill: "#C6F6D5"
      stroke: "#2F855A"
    }
  }
  medium_latency: {
    style: {
      fill: "#FEFCBF"
      stroke: "#B7791F"
    }
  }
  high_latency: {
    style: {
      fill: "#FED7D7"
      stroke: "#C53030"
    }
  }
  strong_consistency: {
    style: {
      fill: "#C6F6D5"
      stroke: "#2F855A"
    }
  }
  eventual_consistency: {
    style: {
      fill: "#FEFCBF"
      stroke: "#B7791F"
    }
  }
  no_loss: {
    style: {
      fill: "#C6F6D5"
      stroke: "#2F855A"
    }
  }
  possible_loss: {
    style: {
      fill: "#FED7D7"
      stroke: "#C53030"
    }
  }
}

# Main comparison matrix
matrix: {
  grid-columns: 4
  grid-gap: 0
  
  # Row 0: Headers
  header_metric: {
    class: header_cell
    label: "Metric"
  }
  cache_aside_header: {
    class: header_cell
    label: "Cache-Aside\n(Lazy Loading)"
  }
  write_through_header: {
    class: header_cell
    label: "Write-Through\n(Sync)"
  }
  write_behind_header: {
    class: header_cell
    label: "Write-Behind\n(Async)"
  }

  # Row 1: Write Latency
  latency_label: {
    class: data_cell
    label: "Write Latency"
  }
  aside_latency: {
    class: low_latency
    label: "LOW\n~0.1-1ms\n(cache only)"
  }
  through_latency: {
    class: high_latency
    label: "HIGH\n~50-100ms\n(cache + DB)"
  }
  behind_latency: {
    class: low_latency
    label: "LOW\n~0.1-1ms\n(cache only)"
  }

  # Row 2: Read Latency
  read_label: {
    class: data_cell
    label: "Read Latency"
  }
  aside_read: {
    class: low_latency
    label: "HIT: ~0.1ms\nMISS: ~50ms"
  }
  through_read: {
    class: low_latency
    label: "HIT: ~0.1ms\nMISS: ~50ms"
  }
  behind_read: {
    class: low_latency
    label: "HIT: ~0.1ms\nMISS: ~50ms"
  }

  # Row 3: Consistency
  consistency_label: {
    class: data_cell
    label: "Consistency"
  }
  aside_consistency: {
    class: eventual_consistency
    label: "EVENTUAL\nStale until\nTTL expires"
  }
  through_consistency: {
    class: strong_consistency
    label: "STRONG\nCache = DB\nalways"
  }
  behind_consistency: {
    class: eventual_consistency
    label: "EVENTUAL\nBuffer delay\nbefore DB"
  }

  # Row 4: Data Loss
  loss_label: {
    class: data_cell
    label: "Data Loss Risk"
  }
  aside_loss: {
    class: no_loss
    label: "NONE\nDB is source\nof truth"
  }
  through_loss: {
    class: no_loss
    label: "NONE\nAtomic write\nwith rollback"
  }
  behind_loss: {
    class: possible_loss
    label: "YES\nBuffer loss on\nserver crash"
  }

  # Row 5: Complexity
  complex_label: {
    class: data_cell
    label: "Complexity"
  }
  aside_complex: {
    class: low_latency
    label: "LOW\nApp manages\ncache explicitly"
  }
  through_complex: {
    class: medium_latency
    label: "MEDIUM\nRollback logic\nrequired"
  }
  behind_complex: {
    class: high_latency
    label: "HIGH\nBuffer mgmt,\nflush, retry"
  }

  # Row 6: Best For
  best_label: {
    class: data_cell
    label: "Best For"
  }
  aside_best: {
    class: data_cell
    label: "- Read-heavy\n- User profiles\n- Product catalog"
  }
  through_best: {
    class: data_cell
    label: "- Financial data\n- Configuration\n- Critical writes"
  }
  behind_best: {
    class: data_cell
    label: "- Analytics\n- High write vol\n- IoT data"
  }
}

# Pattern flow diagrams
flows: {
  label: "Data Flow Visualizations"
  
  # Cache-Aside flow
  aside_flow: {
    label: "Cache-Aside (Read Hit/Miss)"
    style.fill: "#EDF2F7"
    app1: "App"
    cache1: "Cache"
    db1: "Database"
    app1 -> cache1: "1. GET key"
    cache1 -> app1: "2. MISS"
    app1 -> db1: "3. Query DB"
    db1 -> app1: "4. Data"
    app1 -> cache1: "5. SET (async)"
    
    app1.shape: rectangle
    cache1.shape: cylinder
    db1.shape: cylinder
  }

  # Write-Through flow
  through_flow: {
    label: "Write-Through (Synchronous)"
    style.fill: "#EDF2F7"
    app2: "App"
    cache2: "Cache"
    db2: "Database"
    app2 -> cache2: "1. SET key=val"
    cache2 -> db2: "2. Write DB"
    db2 -> cache2: "3. ACK"
    cache2 -> app2: "4. Success"
    
    app2.shape: rectangle
    cache2.shape: cylinder
    db2.shape: cylinder
  }

  # Write-Behind flow
  behind_flow: {
    label: "Write-Behind (Asynchronous)"
    style.fill: "#EDF2F7"
    app3: "App"
    cache3: "Cache\n+ Buffer"
    db3: "Database"
    app3 -> cache3: "1. SET key=val"
    cache3 -> app3: "2. ACK (immediate)"
    cache3 -> db3: "3. Flush (async)"
    db3 -> cache3: "4. ACK (later)"
    
    app3.shape: rectangle
    cache3.shape: cylinder
    db3.shape: cylinder
  }

  aside_flow -- through_flow: {style.stroke: transparent}
  through_flow -- behind_flow: {style.stroke: transparent}
}

# Legend
legend: {
  near: bottom-center
  legend_title: "Performance / Risk Legend"
  
  good: "Good / Low Risk" {
    class: low_latency
  }
  medium: "Medium / Warning" {
    class: medium_latency
  }
  poor: "Poor / High Risk" {
    class: high_latency
  }
  
  good -- medium -- poor: {style.stroke: transparent}
}

# Summary recommendation
summary: {
  near: bottom-center
  style: {
    fill: "#EDF2F7"
    border-radius: 8
    stroke: "#4A5568"
    stroke-width: 2
  }
  content: ||md
    ## Quick Selection Guide
    | Use Case | Recommended Pattern | Why |
    |----------|---------------------|-----|
    | User sessions | Cache-Aside | Stale OK, simple to implement |
    | Financial transactions | Write-Through | Atomicity is critical; no data loss |
    | Analytics counters | Write-Behind | Extreme high write volume throughput |
    | Configuration data | Write-Through | Consistency across nodes is critical |
    | Social media feeds | Cache-Aside | Read-heavy load; eventual consistency OK |
    | IoT sensor data | Write-Behind | High-frequency sampling; loss acceptable |
  ||
}