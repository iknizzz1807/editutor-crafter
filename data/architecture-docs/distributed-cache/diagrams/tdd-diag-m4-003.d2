direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Thundering Herd: Timeline Comparison
  **Implementation Spec: Request Coalescing vs. Naive Fetching**
  *Engineers: Reference this for Single-Flight implementation logic.*
| {near: top-center}

# ============================================
# WITHOUT SINGLE-FLIGHT (LEFT SIDE)
# ============================================
without_coalescing: {
  label: "Scenario A: Naive Cache-Aside (Thundering Herd)"
  style: {
    stroke: "#E53935"
    stroke-width: 4
    fill: "#FFEBEE"
    shadow: true
  }

  # Timeline axis - definition order matters in ELK for top-to-bottom
  time_axis: {
    shape: text
    label: |md
      ### Timeline (ms)
      **T=0** : TTL Expires
      **T=1** : N Arrivals
      **T=50**: I/O Completes
    |
  }

  # Phase markers
  phase_labels: {
    style.fill: transparent
    style.stroke: transparent
    p1: "1. TTL 0" {style.font-size: 11; style.bold: true; style.font-color: "#D32F2F"}
    p2: "2. N Misses" {style.font-size: 11; style.bold: true; style.font-color: "#D32F2F"}
    p3: "3. N I/O Ops" {style.font-size: 11; style.bold: true; style.font-color: "#D32F2F"}
  }

  cache_layer: {
    label: "Cache (Redis/Memcached)"
    style.fill: "#FFFFFF"
    style.stroke: "#4CAF50"
    
    cache_expire: {
      label: "KEY_EXPIRED"
      shape: diamond
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
        bold: true
      }
    }
    
    miss_group: {
      style.stroke: transparent
      miss1: "Miss #1" {shape: circle; style.fill: "#FFCDD2"}
      miss2: "Miss #2" {shape: circle; style.fill: "#FFCDD2"}
      missN: "Miss #N" {shape: circle; style.fill: "#FFCDD2"}
    }

    set_group: {
      style.stroke: transparent
      set1: "Set #1" {shape: circle; style.fill: "#C8E6C9"}
      set2: "Set #2" {shape: circle; style.fill: "#C8E6C9"}
      setN: "Set #N" {shape: circle; style.fill: "#C8E6C9"}
    }
  }

  db_layer: {
    label: "Relational Database / Upstream"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.double-border: true

    queries: {
      label: "Concurrent SQL Execution"
      style.stroke-dash: 2
      q1: "SELECT... (1)" {style.fill: "#BBDEFB"; style.animated: true}
      q2: "SELECT... (2)" {style.fill: "#BBDEFB"; style.animated: true}
      qN: "SELECT... (N)" {style.fill: "#BBDEFB"; style.animated: true}
    }
  }

  # Flow logic
  cache_layer.cache_expire -> cache_layer.miss_group: "T=0: Expiration" {style.stroke: "#F44336"}
  cache_layer.miss_group.miss1 -> db_layer.queries.q1: "IO Wait" {style.stroke: "#2196F3"}
  cache_layer.miss_group.miss2 -> db_layer.queries.q2: "IO Wait" {style.stroke: "#2196F3"}
  cache_layer.miss_group.missN -> db_layer.queries.qN: "IO Wait" {style.stroke: "#2196F3"}
  
  db_layer.queries.q1 -> cache_layer.set_group.set1: "T+50ms" {style.stroke: "#4CAF50"}
  db_layer.queries.q2 -> cache_layer.set_group.set2: "T+50ms" {style.stroke: "#4CAF50"}
  db_layer.queries.qN -> cache_layer.set_group.setN: "T+50ms" {style.stroke: "#4CAF50"}
}

# ============================================
# WITH SINGLE-FLIGHT (RIGHT SIDE)
# ============================================
with_coalescing: {
  label: "Scenario B: Request Coalescing (Single-Flight)"
  style: {
    stroke: "#43A047"
    stroke-width: 4
    fill: "#E8F5E9"
    shadow: true
  }

  time_axis_coal: {
    shape: text
    label: |md
      ### Timeline (ms)
      **T=0** : TTL Expires
      **T=1** : N Arrivals (Shared)
      **T=50**: Single I/O Completes
    |
  }

  sf_layer: {
    label: "Application: Single-Flight Mutex"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    
    sf_coordinator: {
      label: "SingleFlight\nGroup.Do(key)"
      shape: hexagon
      style: {
        fill: "#E1BEE7"
        stroke: "#9C27B0"
        bold: true
      }
    }
  }

  cache_layer_coal: {
    label: "Cache"
    style.fill: "#FFFFFF"
    style.stroke: "#4CAF50"
    
    cache_expire_coal: "KEY_EXPIRED" {
      shape: diamond
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
    }
    
    shared_miss: "Atomic Check" {
      shape: circle
      style.fill: "#FFF9C4"
    }
    
    cache_set_coal: "SET ONCE" {
      shape: circle
      style.fill: "#C8E6C9"
      style.bold: true
    }
  }

  db_layer_coal: {
    label: "Database"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    
    single_query: "SELECT... (1 ONLY)" {
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        stroke: "#2196F3"
        bold: true
        animated: true
      }
    }
  }

  clients: {
    label: "Waiting Callers"
    c1: "Caller 1" {shape: person}
    c2: "Caller 2" {shape: person}
    cN: "Caller N" {shape: person}
  }

  # Logic Flow
  cache_layer_coal.cache_expire_coal -> cache_layer_coal.shared_miss: "Miss Detection"
  cache_layer_coal.shared_miss -> sf_layer.sf_coordinator: "Acquire Flight Lock"
  sf_layer.sf_coordinator -> db_layer_coal.single_query: "First execution\nstarts I/O"
  db_layer_coal.single_query -> cache_layer_coal.cache_set_coal: "Populate"
  
  sf_layer.sf_coordinator -> clients.c1: "Return shared val" {style.stroke: "#4CAF50"; style.animated: true}
  sf_layer.sf_coordinator -> clients.c2: "Return shared val" {style.stroke: "#4CAF50"; style.animated: true}
  sf_layer.sf_coordinator -> clients.cN: "Return shared val" {style.stroke: "#4CAF50"; style.animated: true}
}

# ============================================
# ANALYSIS & METRICS
# ============================================
metrics: {
  grid-columns: 2
  
  bad_stats: {
    label: "Performance: Naive"
    style.fill: "#FFEBEE"
    stats: |md
      - **DB Load:** O(N)
      - **Network:** O(N)
      - **Risk:** Database Socket Exhaustion
    |
  }
  
  good_stats: {
    label: "Performance: Coalesced"
    style.fill: "#E8F5E9"
    stats: |md
      - **DB Load:** O(1)
      - **Network:** O(1)
      - **Risk:** Minimal
    |
  }
}

insight_box: {
  label: "Implementation Guidance"
  style: {
    stroke: "#1976D2"
    fill: "#E3F2FD"
    stroke-width: 2
  }
  content: |md
    ### Single-Flight Logic
    1.  **Map Check:** Use a `map[string]*call` to track active keys.
    2.  **Wait:** Subsequent requests for the same key block on a `sync.WaitGroup` or channel inside the `call` struct.
    3.  **Broadcast:** Once the first request finishes, it updates the `call` result and signals the WaitGroup.
    4.  **Cleanup:** Remove the key from the map before returning to allow future updates.
  |
}

# Structural placement hints
without_coalescing -> with_coalescing: "Transition to\nOptimal Pattern" {
  style.stroke-width: 4
  style.stroke: "#BDBDBD"
}

legend: {
  label: "Legend & Color Codes"
  style.fill: "#FAFAFA"
  
  l1: "Active I/O" {style.fill: "#BBDEFB"; style.stroke: "#2196F3"}
  l2: "Cache Miss" {style.fill: "#FFCDD2"; style.stroke: "#F44336"}
  l3: "Coalescing Logic" {style.fill: "#F3E5F5"; style.stroke: "#9C27B0"}
  l4: "Success/Set" {style.fill: "#C8E6C9"; style.stroke: "#4CAF50"}
}