direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# ---------------------------------------------------------------------------------------
# TITLE & HEADER
# ---------------------------------------------------------------------------------------
title: {
  shape: text
  label: |'md
    # Probabilistic Early Expiration Distribution
    ### Technical Specification: Thundering Herd Mitigation Strategy
  '|
  near: top-center
}

# ---------------------------------------------------------------------------------------
# MEMORY LAYOUT: CACHE ENTRY STRUCTURE (Intel Manual Style)
# ---------------------------------------------------------------------------------------
cache_entry_layout: {
  label: "Memory Layout: CacheMetadataEntry (Packed)"
  style: {
    stroke: "#333"
    fill: "#F5F5F5"
    stroke-width: 2
  }
  
  header: {
    grid-columns: 5
    grid-gap: 0
    
    # Byte Offsets (Purple)
    o0: "0x00" { style.fill: "#673AB7"; style.font-color: white; style.font: mono }
    o8: "0x08" { style.fill: "#673AB7"; style.font-color: white; style.font: mono }
    o16: "0x10" { style.fill: "#673AB7"; style.font-color: white; style.font: mono }
    o24: "0x18" { style.fill: "#673AB7"; style.font-color: white; style.font: mono }
    o32: "0x20" { style.fill: "#673AB7"; style.font-color: white; style.font: mono }

    # Data Fields
    f1: "Value Pointer (8B)" { 
      tooltip: "uintptr to actual cached payload"
      style.fill: "#FF9800" 
    }
    f2: "Created At (8B)" { 
      tooltip: "int64 UnixNano timestamp"
      style.fill: "#2196F3" 
    }
    f3: "Expires At (8B)" { 
      tooltip: "int64 Absolute expiration timestamp"
      style.fill: "#F44336" 
    }
    f4: "TTL Duration (8B)" { 
      tooltip: "int64 Total duration for window calc"
      style.fill: "#4CAF50" 
    }
    f5: "Padding (8B)" { 
      tooltip: "Alignment padding to 64B cache line"
      style.fill: "#9E9E9E" 
    }
  }

  footer: |'md
    **Total Size:** 40 Bytes + 24 Bytes Internal Padding
    **Alignment:** 8-byte (64-bit word)
    **Cache Line Impact:** Fits in single 64B L1 Cache Line
  '|
}

# ---------------------------------------------------------------------------------------
# ALGORITHM VISUALIZATION: PROBABILITY CURVE
# ---------------------------------------------------------------------------------------
graph_container: {
  label: "Probability Curve: P(refresh) = 1.0 - (remaining / (TTL * earlyFactor))"
  style: {
    fill: white
    stroke: "#333"
    stroke-width: 2
  }

  y_axis: {
    shape: text
    label: |'md
      **P(refresh)**
      1.0 ─┐ (Hard Expiry)
          │
      0.8 ─┤
          │
      0.6 ─┤
          │
      0.4 ─┤
          │
      0.2 ─┤
          │ (Window Start)
      0.0 ─┴───────────────► t
    '|
  }

  curve_representation: {
    shape: rectangle
    label: "Refresh Probability Gradient (Early Window)"
    style: {
      fill: "linear-gradient(90deg, #E3F2FD 0%, #1976D2 100%)"
      opacity: 0.5
      stroke-dash: 2
      3d: true
    }
    width: 450
    height: 120
  }

  points: {
    p0: {
      shape: circle; width: 15; style.fill: "#4CAF50"
      label: "t = 0.9 TTL"
      tooltip: "P(refresh) = 0.0"
    }
    p50: {
      shape: circle; width: 15; style.fill: "#FFC107"
      label: "t = 0.95 TTL"
      tooltip: "P(refresh) = 0.5"
    }
    p100: {
      shape: circle; width: 15; style.fill: "#F44336"
      label: "t = 1.0 TTL"
      tooltip: "P(refresh) = 1.0"
    }
    
    p0 -> p50 -> p100: "Linear Probability Growth" { 
      style.stroke-dash: 3 
      style.stroke: "#333"
    }
  }

  x_labels: {
    shape: text
    label: |'md
      **Timeline Distribution (Relative to Expiry)**
      ─────────────────────────────────────────────────────────────
      |  Safe Zone (No Early Refresh)   |   Early Refresh Window    |
      |◄───────────────────────────────►|◄─────────────────────────►|
      Creation (t=0)                   90% TTL                   100% TTL
    '|
  }
}

# ---------------------------------------------------------------------------------------
# DISTRIBUTION TIMELINE: REQUEST SAMPLING
# ---------------------------------------------------------------------------------------
distribution: {
  label: "Refresh Event Distribution (Real-world Sample)"
  style.fill: "#FAFAFA"
  style.stroke: "#DDD"

  timeline_base: {
    shape: rectangle
    width: 600
    height: 4
    style.fill: "#333"
  }

  events: {
    req_a: "Req A" { 
      shape: diamond; style.fill: "#4CAF50"
      tooltip: "Calculated P=0.05 vs Rand=0.88 -> Skip Refresh" 
    }
    req_b: "Req B" { 
      shape: diamond; style.fill: "#4CAF50"
      tooltip: "Calculated P=0.15 vs Rand=0.42 -> Skip Refresh" 
    }
    req_c: "Req C (TRIGGER)" { 
      shape: diamond; style.fill: "#FF9800"
      tooltip: "Calculated P=0.45 vs Rand=0.12 -> TRIGGER REFRESH" 
      style.stroke-width: 3
    }
    req_d: "Req D" { 
      shape: diamond; style.fill: "#9E9E9E"
      tooltip: "Already Refreshing -> Suppression Active" 
    }
  }

  legend: {
    shape: text
    label: |'md
      **Event Key**
      ◆ GREEN: Cache Hit (Stale data acceptable)
      ◆ ORANGE: Probabilistic Win (Early fetch started)
      ◆ GREY: Request Coalesced (Single-flight in progress)
    '|
  }
}

# ---------------------------------------------------------------------------------------
# COMPARATIVE ANALYSIS: THUNDERING HERD IMPACT
# ---------------------------------------------------------------------------------------
mitigation_analysis: {
  label: "Performance Impact: Standard vs Probabilistic"
  
  standard_ttl: {
    label: "Standard TTL (Blocking)"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    spike: {
      shape: text
      label: |'md
        **Backend Load Spike (T=100%)**
        Critical Contention: N requests hit simultaneously
        █ █ █ █ █ █ █ █ █ █ █ █ █ 
        █ █ █ █ █ █ █ █ █ █ █ █ █ 
        ───────────────────────
      '|
    }
  }

  prob_ttl: {
    label: "Probabilistic TTL (Non-Blocking)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    spread: {
      shape: text
      label: |'md
        **Distributed Load (T=90-100%)**
        Load Flattening: Single request triggers early
        ░  ░  ░  █  ░  ░  ░  ░
        ░  ░  ░  █  ░  ░  ░  ░
        ───────────────────────
      '|
    }
  }

  standard_ttl -> prob_ttl: "Load Flattening Vector" {
    style.stroke: "#2E7D32"
    style.stroke-width: 4
    style.animated: true
  }
}

# ---------------------------------------------------------------------------------------
# FORMULA & CONFIGURATION
# ---------------------------------------------------------------------------------------
logic_container: {
  grid-columns: 2
  grid-gap: 20
  
  formula_box: {
    label: "Implementation Algorithm (Golang)"
    style.fill: "#E8EAF6"
    style.font: mono
    content: |'md
      go
      func shouldRefresh(expiry, now time.Time, ttl time.Duration) bool {
          // Define the early window (e.g., last 10% of life)
          earlyFactor := 0.1
          earlyWindow := float64(ttl) * earlyFactor
          remaining := float64(expiry.Sub(now))
          
          if remaining <= 0 { return true } // Hard expiry
          if remaining > earlyWindow { return false } // Safe zone
          
          // Calculate Probability: 0.0 at window start -> 1.0 at expiry
          pRefresh := 1.0 - (remaining / earlyWindow)
          
          // Weighted random decision
          return rand.Float64() < pRefresh
      }
      
    '|
  }

  config_box: {
    label: "Operational Parameters"
    style.fill: "#FFFDE7"
    params: |'md
      | Const | Value | Description |
      | :--- | :--- | :--- |
      | `WINDOW_FACTOR` | 0.1 | Defines 10% overlap period |
      | `JITTER_SEED` | crypto | Prevents seed collisions |
      | `S_FLIGHT` | Enabled | Coalesces parallel refreshes |
      | `MAX_STALE` | 500ms | Max safety overhead |
    '|
  }
}

# ---------------------------------------------------------------------------------------
# GLOBAL ANNOTATIONS & CONNECTIONS
# ---------------------------------------------------------------------------------------
insight: {
  shape: rectangle # FIX: Explicitly set rectangle to support double-border
  label: |'md
    **Final Implementation Requirement:**
    This algorithm **must** be coupled with a **Single-Flight (Coalescing)** mechanism. 
    Probabilistic logic distributes the *decision* to refresh, but Single-Flight 
    ensures that exactly **one** upstream fetch occurs, even if multiple 
    clients concurrently decide to refresh during the early window.
  '|
  style: {
    fill: "#E0F7FA"
    stroke: "#00838F"
    stroke-width: 2
    border-radius: 8
    double-border: true
    font-size: 14
  }
}

# Connective Tissue for Data Flow
graph_container -> distribution: "Determines Probability Threshold"
distribution -> mitigation_analysis: "Traffic Distribution Result"
logic_container -> cache_entry_layout: "Implementation Specs"

# Absolute Placement
insight.near: bottom-center
cache_entry_layout.near: top-right

# Style Overrides for Technical Polish
***.style.font: mono
***.style.stroke-width: 1
mitigation_analysis.standard_ttl.style.bold: true
mitigation_analysis.prob_ttl.style.bold: true