vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Metrics Dashboard Data Flow
  ## Distributed Cache System v1.0.4
  **Engineer Reference: Atomic Byte Counters & Histogram Updates**
| {near: top-center}

# ============================================
# SECTION 1: Cache Operations (Source)
# ============================================
operations_group: Cache Operations {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  
  get_op: GET Operation {
    style.fill: white
    style.stroke: "#4CAF50"
    tooltip: "Entry point for data retrieval. Triggers Hit or Miss counters."
  }
  set_op: SET Operation {
    style.fill: white
    style.stroke: "#2196F3"
    tooltip: "Entry point for data insertion. Triggers byte count and write flush metrics."
  }
  evict_op: Eviction {
    style.fill: white
    style.stroke: "#FF9800"
    tooltip: "Triggered by LRU/LFU policy when capacity reached."
  }
  coalesce_op: Request Coalesced {
    style.fill: white
    style.stroke: "#9C27B0"
    tooltip: "Singleflight deduplication of concurrent requests for same key."
  }
  refresh_op: Early Refresh {
    style.fill: white
    style.stroke: "#00BCD4"
    tooltip: "Soft-TTL expiration triggering background update while serving stale data."
  }
}

# ============================================
# SECTION 2: Metrics Recording
# ============================================
recording_group: Metric Recording {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  
  # Moved annotation inside the group to fix ELK 'near' error
  annotation_1: |md
    ### Atomic Operations
    - Hot path metrics use `sync/atomic` for zero lock contention.
    - Counters are 64-bit aligned for ARM compatibility.
  | {
    shape: text
    style.font-size: 14
  }

  hit_counter: Hit Counter {
    shape: hexagon
    style.fill: "#C8E6C9"
    tooltip: |md
      go
      atomic.AddInt64(&hits, 1)
      
    |
  }
  miss_counter: Miss Counter {
    shape: hexagon
    style.fill: "#FFCDD2"
    tooltip: |md
      go
      atomic.AddInt64(&misses, 1)
      
    |
  }
  latency_accum: Latency Accumulator {
    shape: cylinder
    style.fill: "#BBDEFB"
    tooltip: |md
      go
      atomic.AddInt64(&latencySum, μs)
      atomic.AddInt64(&latencyCount, 1)
      
    |
  }
  coalesce_counter: Coalesced Counter {
    shape: hexagon
    style.fill: "#E1BEE7"
    tooltip: |md
      go
      atomic.AddInt64(&coalesced, 1)
      
    |
  }
}

# ============================================
# SECTION 3: Histogram Updates
# ============================================
histogram_group: Latency Histogram {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  
  # Moved annotation inside to fix ELK 'near' error
  annotation_2: |md
    ### Histogram Config
    - Precision: Microseconds (μs)
    - Buckets: [10, 50, 100, 500, 1000, 5000, 50000, +Inf]
  | {
    shape: text
    style.font-size: 14
  }

  histogram: Histogram Buckets {
    style.fill: white
    bucket_10: "0-10μs" {style.fill: "#E8F5E9"}
    bucket_50: "10-50μs" {style.fill: "#C8E6C9"}
    bucket_100: "50-100μs" {style.fill: "#A5D6A7"}
    bucket_500: "100-500μs" {style.fill: "#81C784"}
    bucket_1k: "500μs-1ms" {style.fill: "#66BB6A"}
    bucket_5k: "1-5ms" {style.fill: "#4CAF50"}
    bucket_50k: "5-50ms" {style.fill: "#43A047"}
    bucket_inf: ">50ms" {style.fill: "#2E7D32"}
    
    bucket_10 -> bucket_50 -> bucket_100 -> bucket_500 -> bucket_1k -> bucket_5k -> bucket_50k -> bucket_inf
  }
  
  update_logic: Update Logic {
    style.fill: "#FCE4EC"
    tooltip: |md
      go
      func (h *Histogram) Record(latency int64) {
        for i, bound := range h.bounds {
          if latency <= bound {
            atomic.AddInt64(&h.buckets[i], 1)
            return
          }
        }
      }
      
    |
  }
}

# ============================================
# SECTION 4: Snapshot Creation (Memory Layout)
# ============================================
snapshot_group: Snapshot Creation {
  style.fill: "#E0F7FA"
  style.stroke: "#00BCD4"
  style.stroke-width: 2
  
  snapshot_struct: Snapshot Data Layout {
    shape: sql_table
    style.fill: "#673AB7"
    style.stroke: "#512DA8"
    
    0x00: "Hits (uint64)" {constraint: "8 bytes"}
    0x08: "Misses (uint64)" {constraint: "8 bytes"}
    0x10: "Sets (uint64)" {constraint: "8 bytes"}
    0x18: "Evictions (uint64)" {constraint: "8 bytes"}
    0x20: "SumLatency (int64)" {constraint: "8 bytes"}
    0x28: "HistogramPtr (*[]uint64)" {constraint: "8 bytes"}
    0x30: "Uptime (int64)" {constraint: "8 bytes"}
    0x38: "Padding" {style.fill: "#E0E0E0"; constraint: "8 bytes"}
  }
  
  calculation: Calculations {
    style.fill: "#FFF8E1"
    tooltip: |md
      **Metrics Processing Engine:**
      - hitRate = hits / (hits + misses)
      - avgLatency = latencySum / latencyCount
      - p99 = Calculated via Histogram linear interpolation
    |
  }
  
  snapshot_struct -> calculation: compute
}

# ============================================
# SECTION 5: Prometheus Export
# ============================================
prometheus_group: Prometheus Export {
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  style.stroke-width: 2
  
  prom_metrics: PrometheusMetrics {
    style.fill: white
    style.stroke: "#607D8B"
    tooltip: |md
      text
      # HELP cache_hits_total Total number of hits.
      # TYPE cache_hits_total counter
      cache_hits_total 1234
      
      # HELP cache_latency_bucket Latency histogram buckets.
      # TYPE cache_latency_bucket histogram
      cache_latency_bucket{le="10"} 100
      cache_latency_bucket{le="50"} 450
      cache_latency_bucket{le="+Inf"} 1290
      
    |
  }
  
  http_handler: HTTP /metrics Handler {
    shape: hexagon
    style.fill: "#CFD8DC"
    tooltip: |md
      **Endpoint Details:**
      - URI: `/metrics`
      - Port: 9090
      - Scrape Interval: 15s
    |
  }
}

# ============================================
# SECTION 6: Dashboard Visualization
# ============================================
dashboard_group: Grafana Dashboard {
  style.fill: "#263238"
  style.stroke: "#455A64"
  style.stroke-width: 2
  
  hit_rate_gauge: Hit Rate {
    shape: diamond
    style.fill: "#4CAF50"
    style.font-color: white
    label: "95.6%"
  }
  latency_graph: Latency P99 {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: white
    label: "420μs"
  }
  buffer_graph: Buffer Usage {
    shape: rectangle
    style.fill: "#FF9800"
    style.font-color: white
    label: "42MB / 1GB"
  }
}

# ============================================
# DATA FLOW CONNECTIONS
# ============================================
operations_group.get_op -> recording_group.hit_counter: "INCR hits" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.animated: true
}

operations_group.get_op -> recording_group.latency_accum: "timer_start()" {
  style.stroke: "#2196F3"
  style.stroke-dash: 3
}

operations_group.set_op -> recording_group.miss_counter: "INCR miss" {
  style.stroke: "#F44336"
  style.stroke-width: 2
}

recording_group.latency_accum -> histogram_group.update_logic: "Record(μs)" {
  style.stroke: "#3F51B5"
  style.stroke-width: 2
}

histogram_group.update_logic -> histogram_group.histogram: "bucket[i]++" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}

recording_group.hit_counter -> snapshot_group.snapshot_struct: "LOAD atomic"
recording_group.miss_counter -> snapshot_group.snapshot_struct: "LOAD atomic"
histogram_group.histogram -> snapshot_group.snapshot_struct: "mem_copy buckets"

snapshot_group.snapshot_struct -> prometheus_group.prom_metrics: "text/plain" {
  style.stroke: "#607D8B"
  style.stroke-width: 2
}

prometheus_group.prom_metrics -> prometheus_group.http_handler: "serve"

prometheus_group.http_handler -> dashboard_group.hit_rate_gauge: "scrape" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 5
  style.animated: true
}

prometheus_group.http_handler -> dashboard_group.latency_graph: "scrape" {
  style.stroke: "#2196F3"
  style.stroke-dash: 5
  style.animated: true
}

# ============================================
# LEGEND
# ============================================
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  label: "Architecture Symbols"
  
  atomic_node: Atomic Op {
    shape: hexagon
    style.fill: "#E8F5E9"
  }
  data_node: Mem Snapshot {
    shape: sql_table
    style.fill: "#BBDEFB"
  }
  live_flow: Live Scrape {
    shape: rectangle
    style.fill: white
    style.animated: true
  }
}