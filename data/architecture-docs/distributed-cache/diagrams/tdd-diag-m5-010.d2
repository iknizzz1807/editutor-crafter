direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# --- STYLES AND CLASSES ---
classes: {
  header: {
    style: {
      fill: "#6c5ce7"
      font-color: white
      bold: true
    }
  }
  data_field: {
    style: {
      fill: "#74b9ff"
      font-color: black
    }
  }
  padding_field: {
    style: {
      fill: "#dfe6e9"
      font-color: "#636e72"
      stroke-dash: 3
    }
  }
  pointer_field: {
    style: {
      fill: "#fab1a0"
      bold: true
    }
  }
  node_primary: {
    style: {
      fill: "#55efc4"
      stroke-width: 2
    }
  }
  node_secondary: {
    style: {
      fill: "#81ecec"
      stroke-dash: 5
    }
  }
}

# --- 1. MEMORY LAYOUT: CACHE ENTRY ---
CacheEntryMemory: {
  label: "Memory Layout: Cache Entry Structure (sizeof=128 bytes)"
  
  grid-columns: 2
  grid-gap: 0

  "Offset 0x00"
  Header: {
    class: header
    label: "Header (Metadata)"
    width: 300
    "Flags (1B) | Type (1B) | Version (2B) | Reserved (4B)"
  }

  "Offset 0x08"
  KeyPointer: {
    class: pointer_field
    label: "Key Pointer (8B)"
    "uintptr -> Heap Address"
  }

  "Offset 0x10"
  ValuePointer: {
    class: pointer_field
    label: "Value Pointer (8B)"
    "uintptr -> Heap Address"
  }

  "Offset 0x18"
  Timestamps: {
    class: data_field
    label: "Created (8B) | ExpiresAt (8B)"
    "int64 (UnixNano)"
  }

  "Offset 0x28"
  EvictionStats: {
    class: data_field
    label: "Frequency (8B) | Recency (8B)"
    "uint64 (LFU) | int64 (LRU)"
  }

  "Offset 0x38"
  AlignmentPadding: {
    class: padding_field
    label: "Padding (72B)"
    "Cache Line Alignment (64B + 8B)"
  }
}

# --- 2. ARCHITECTURE: DISTRIBUTED PIPELINE ---
DistributedSystem: {
  label: "Multi-Node Pipeline Execution Architecture"

  Client: {
    HashRing: {
      shape: circle
      label: "Consistent Hashing Ring\n(Virtual Nodes: 256)"
    }
    
    PipelineManager: {
      shape: rectangle
      label: "Command Pipeline Buffer"
      tooltip: "Groups commands by Target Node before dispatch"
    }
  }

  NetworkLayer: {
    label: "Parallel Dispatch Layer"
    style.stroke-dash: 5
  }

  ShardCluster: {
    Shard_A: {
      class: node_primary
      label: "Node A (Primary)"
      Memory: "LRU + LFU Shard"
    }
    Shard_B: {
      class: node_primary
      label: "Node B (Primary)"
      Memory: "LRU + LFU Shard"
    }
    Shard_A_Replica: {
      class: node_secondary
      label: "Node A (Replica)"
    }
  }

  # Connections
  Client.HashRing -> Client.PipelineManager: "1. Map Key to NodeID"
  Client.PipelineManager -> NetworkLayer: "2. Flush Buffered Commands"
  NetworkLayer -> ShardCluster.Shard_A: "Parallel TCP Stream A"
  NetworkLayer -> ShardCluster.Shard_B: "Parallel TCP Stream B"
  ShardCluster.Shard_A -> ShardCluster.Shard_A_Replica: "Async Replication"
}

# --- 3. ALGORITHM STATE: PROBABILISTIC EARLY REFRESH ---
EarlyRefreshAlgo: {
  label: "Probabilistic Early Refresh Algorithm State"

  Before: {
    label: "Step N: Access within Refresh Window"
    Entry: {
      style.fill: white
      "TTL: 10s Remaining"
      "Prob: P(refresh) = 0.2"
    }
    RandomSeed: "0.15 (Threshold Met)"
  }

  After: {
    label: "Step N+1: Async Refresh Triggered"
    Entry: {
      style.fill: "#ffeaa7"
      "TTL: 300s (Reset)"
      label: "**Refreshed**"
    }
    BackgroundRefresher: {
      shape: parallelogram
      label: "Goroutine: Fetch from DB"
      style.stroke: red
    }
  }

  Before -> After: "Random < Prob -> Spawn Refresh"
}

# --- 4. SEQUENCE: MULTI-NODE PIPELINE EXECUTION ---
PipelineSequence: {
  shape: sequence_diagram
  
  User: "API Client"
  Ring: "Hash Ring"
  Buf: "Command Buffer"
  NodeA: "Shard Node A"
  NodeB: "Shard Node B"

  User -> Ring: "Get(Key1), Get(Key2)"
  Ring -> User: "Target: NodeA, NodeB"
  
  User -> Buf: "Enqueue(NodeA, Cmd1)"
  User -> Buf: "Enqueue(NodeB, Cmd2)"
  
  User -> Buf: "ExecutePipeline()"
  
  lock: "Acquire Shard Locks" {
    Buf -> NodeA: "Parallel POST /pipeline (Cmd1)"
    Buf -> NodeB: "Parallel POST /pipeline (Cmd2)"
    
    NodeA -> Buf: "Result1"
    NodeB -> Buf: "Result2"
  }
  
  Buf -> User: "[]Results{Res1, Res2}"
}

# --- CROSS-COMPONENT ANNOTATIONS ---
DistributedSystem.ShardCluster.Shard_A -> CacheEntryMemory: "Internal Memory Structure" {
  style.stroke: orange
  style.stroke-dash: 2
}

DistributedSystem.Client.PipelineManager -> PipelineSequence: "Implementation Logic" {
  style.stroke: blue
  style.opacity: 0.5
}