direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "3D Parallelism Process Grid (64 GPUs)"
  sub: "Configuration: DP=4 × TP=8 × PP=2"
  style.stroke: transparent
  style.fill: transparent
  style.font-size: 24
  style.bold: true
}

top_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  legend: {
    label: "Process Group Legend"
    width: 300
    dp_legend: {
      label: "Data Parallel (DP)"
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      style.stroke-width: 3
    }
    tp_legend: {
      label: "Tensor Parallel (TP)"
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      style.stroke-width: 3
    }
    pp_legend: {
      label: "Pipeline Parallel (PP)"
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      style.stroke-width: 3
    }
    logic: {
      label: "Invariants"
      content: |md
        - **DP group**: Same (tp_rank, pp_rank)
        - **TP group**: Same (dp_rank, pp_rank)
        - **PP group**: Same (dp_rank, tp_rank)
      |
    }
  }
}

grid_container: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent

  pp0: "Pipeline Stage 0 (PP=0)" {
    style.fill: "#FAFAFA"
    style.stroke: "#EF6C00"
    style.stroke-width: 2
    direction: down

    dp_row0: "DP=0" {
      direction: right
      style.stroke: transparent
      tp_g00: "TP Group (DP=0, PP=0)" {
        style.fill: "#E8F5E9"
        direction: right
        g000: "0,0,0"; g010: "0,1,0"; g020: "0,2,0"; g030: "0,3,0"
        g040: "0,4,0"; g050: "0,5,0"; g060: "0,6,0"; g070: "0,7,0"
      }
    }
    dp_row1: "DP=1" {
      direction: right
      style.stroke: transparent
      tp_g10: "TP Group (DP=1, PP=0)" {
        style.fill: "#E8F5E9"
        direction: right
        g100: "1,0,0"; g110: "1,1,0"; g120: "1,2,0"; g130: "1,3,0"
        g140: "1,4,0"; g150: "1,5,0"; g160: "1,6,0"; g170: "1,7,0"
      }
    }
    dp_row2: "DP=2" {
      direction: right
      style.stroke: transparent
      tp_g20: "TP Group (DP=2, PP=0)" {
        style.fill: "#E8F5E9"
        direction: right
        g200: "2,0,0"; g210: "2,1,0"; g220: "2,2,0"; g230: "2,3,0"
        g240: "2,4,0"; g250: "2,5,0"; g260: "2,6,0"; g270: "2,7,0"
      }
    }
    dp_row3: "DP=3" {
      direction: right
      style.stroke: transparent
      tp_g30: "TP Group (DP=3, PP=0)" {
        style.fill: "#E8F5E9"
        direction: right
        g300: "3,0,0"; g310: "3,1,0"; g320: "3,2,0"; g330: "3,3,0"
        g340: "3,4,0"; g350: "3,5,0"; g360: "3,6,0"; g370: "3,7,0"
      }
    }
  }

  pp_spacer: {
    shape: parallelogram
    label: "Activation/Gradient Flow"
    style.fill: "#EF6C00"
    style.font-color: white
    height: 30
  }

  pp1: "Pipeline Stage 1 (PP=1)" {
    style.fill: "#FAFAFA"
    style.stroke: "#EF6C00"
    style.stroke-width: 2
    direction: down

    dp_row0_p1: "DP=0" {
      direction: right
      style.stroke: transparent
      tp_g01: "TP Group (DP=0, PP=1)" {
        style.fill: "#E8F5E9"
        direction: right
        g001: "0,0,1"; g011: "0,1,1"; g021: "0,2,1"; g031: "0,3,1"
        g041: "0,4,1"; g051: "0,5,1"; g061: "0,6,1"; g071: "0,7,1"
      }
    }
    dp_row1_p1: "DP=1" {
      direction: right
      style.stroke: transparent
      tp_g11: "TP Group (DP=1, PP=1)" {
        style.fill: "#E8F5E9"
        direction: right
        g101: "1,0,1"; g111: "1,1,1"; g121: "1,2,1"; g131: "1,3,1"
        g141: "1,4,1"; g151: "1,5,1"; g161: "1,6,1"; g171: "1,7,1"
      }
    }
    dp_row2_p1: "DP=2" {
      direction: right
      style.stroke: transparent
      tp_g21: "TP Group (DP=2, PP=1)" {
        style.fill: "#E8F5E9"
        direction: right
        g201: "2,0,1"; g211: "2,1,1"; g221: "2,2,1"; g231: "2,3,1"
        g241: "2,4,1"; g251: "2,5,1"; g261: "2,6,1"; g271: "2,7,1"
      }
    }
    dp_row3_p1: "DP=3" {
      direction: right
      style.stroke: transparent
      tp_g31: "TP Group (DP=3, PP=1)" {
        style.fill: "#E8F5E9"
        direction: right
        g301: "3,0,1"; g311: "3,1,1"; g321: "3,2,1"; g331: "3,3,1"
        g341: "3,4,1"; g351: "3,5,1"; g361: "3,6,1"; g371: "3,7,1"
      }
    }
  }
}

comm_analysis: "Communication Patterns" {
  direction: down
  dp_box: {
    label: "DP (All-Reduce)"
    style.fill: "#E3F2FD"
    content: "Global Gradient Sync: Amortized over backward pass. Model Size payload."
  }
  tp_box: {
    label: "TP (All-Reduce)"
    style.fill: "#E8F5E9"
    content: "Activation Sync: 2x per Transformer block. Intra-node NVLink mandatory."
  }
  pp_box: {
    label: "PP (P2P)"
    style.fill: "#FFF3E0"
    content: "Micro-batch passing: Inter-stage. Cross-node InfiniBand efficient."
  }
}

rank_details: "Implementation Details" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  formula: {
    label: "Global Rank Coordinate Mapping"
    code: |'python
      def get_rank(dp, tp, pp, tp_sz=8, pp_sz=2):
          # TP is contiguous for intra-node affinity
          return (dp * pp_sz + pp) * tp_sz + tp

      # Example (2, 5, 1) -> (2*2 + 1)*8 + 5 = 45
    '|
  }

  mapping_table: {
    label: "Example GPU Mapping"
    content: |'md
      | GPU (dp,tp,pp) | Global Rank | TP Group |
      |----------------|-------------|----------|
      | (0,0,0)        | 0           | 0..7     |
      | (1,0,0)        | 8           | 8..15    |
      | (3,7,1)        | 63          | 56..63   |
    '|
  }
}

grid_container.pp0 -> grid_container.pp1: "Forward Activations" {
  style.stroke: "#EF6C00"
  style.stroke-width: 3
}

grid_container.pp1 -> grid_container.pp0: "Backward Gradients" {
  style.stroke: "#EF6C00"
  style.stroke-width: 3
  style.stroke-dash: 5
}