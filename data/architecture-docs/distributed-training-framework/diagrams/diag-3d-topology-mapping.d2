    direction: right
    style.fill: transparent
    label: ""
    node0: {
      label: "Node 0\nPP Stage 0\nDP Ranks 0-3"
      style.fill: "#DBEAFE"
      style.stroke: ${colors.tp-blue}
      style.stroke-width: 2
