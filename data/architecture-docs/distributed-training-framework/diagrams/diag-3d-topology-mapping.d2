  # PP connections
  node0 -> node4: "PP Send/Recv\nActivations" {
    style.stroke: ${colors.pp-green}
    style.stroke-width: 3
  }
  node1 -> node5: "PP Send/Recv\nActivations" {
    style.stroke: ${colors.pp-green}
    style.stroke-width: 3
  }
}
# Communication Patterns Summary
communication_summary: {
  label: "Communication Patterns by Dimension"
  style.fill: "#F8FAFC"
  style.stroke: "#CBD6E1"
  direction: down
  tp_row: {
    direction: right
    style.fill: transparent
    tp_comm: {
      label: "Tensor Parallel (TP=8)"
      style.fill: ${colors.tp-blue}
      style.font-color: white
      width: 150
    }
    tp_details: |md
      **Pattern:** All-Reduce (every layer)
      **Volume:** batch × seq × hidden_dim
      **Bandwidth:** NVLink ~300 GB/s
      **Constraint:** MUST be within node
    | {shape: rectangle}
  }
  pp_row: {
    direction: right
    style.fill: transparent
    pp_comm: {
      label: "Pipeline Parallel (PP=2)"
      style.fill: ${colors.pp-green}
      style.font-color: white
      width: 150
    }
    pp_details: |md
      **Pattern:** Point-to-Point Send/Recv
      **Volume:** batch × seq × hidden_dim
      **Bandwidth:** InfiniBand ~25 GB/s
      **Constraint:** Tolerates inter-node latency
    | {shape: rectangle}
  }
  dp_row: {
    direction: right
    style.fill: transparent
    dp_comm: {
      label: "Data Parallel (DP=4)"
      style.fill: ${colors.dp-orange}
      style.font-color: white
      width: 150
    }
    dp_details: |md
      **Pattern:** All-Reduce (once per step)
      **Volume:** model_parameters
      **Bandwidth:** InfiniBand ~25 GB/s
      **Constraint:** Amortized over step time
    | {shape: rectangle}
  }
}
# Key Configuration Rules
rules: {
  label: "Configuration Discipline"
  style.fill: "#FEF3C7"
  style.stroke: "#F59E0B"
  rule1: "1. TP ≤ GPUs per node (requires NVLink bandwidth)" {shape: rectangle}
  rule2: "2. PP can span nodes (point-to-point tolerates latency)" {shape: rectangle}
  rule3: "3. DP fills remaining dimension (all-reduce amortized)" {shape: rectangle}
  rule4: "4. TP × PP × DP = Total GPUs" {shape: rectangle}
  example: |md
    **Example Config (64 GPUs):**
    - TP = 8 (fills one node, uses NVLink)
    - PP = 2 (across 2 nodes, tolerates IB)
    - DP = 4 (across remaining nodes)
    **Memory per GPU:** Model params / (TP × PP)
    **Communication:** TP every layer, PP every stage, DP every step
  | {shape: rectangle}
}
logical_grid -> cluster: "Maps to" {style.stroke-dash: 3}