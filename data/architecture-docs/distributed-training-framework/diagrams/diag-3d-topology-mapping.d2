direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    tp-blue: "#4A90D9"
    pp-green: "#5B9A6F"
    dp-orange: "#D97706"
    nvlink: "#22C55E"
    infiniband: "#F59E0B"
    node-bg: "#F8FAFC"
  }
}
title: |md
  # 3D Parallelism → Cluster Topology Mapping
  **Logical Grid: TP=8 × PP=2 × DP=4 = 64 GPUs**
| {near: top-center}
# Legend
legend: {
  near: top-right
  style.fill: transparent
  style.stroke: "#E2E8F0"
  tp_legend: "TP Group (Tensor Parallel)" {
    shape: rectangle
    style.fill: ${colors.tp-blue}
    style.font-color: white
  }
  pp_legend: "PP Group (Pipeline Parallel)" {
    shape: rectangle
    style.fill: ${colors.pp-green}
    style.font-color: white
  }
  dp_legend: "DP Group (Data Parallel)" {
    shape: rectangle
    style.fill: ${colors.dp-orange}
    style.font-color: white
  }
  nvlink_legend: "NVLink (300 GB/s)" {
    shape: rectangle
    style.fill: ${colors.nvlink}
    style.font-color: white
    width: 120
  }
  ib_legend: "InfiniBand (25 GB/s)" {
    shape: rectangle
    style.fill: ${colors.infiniband}
    style.font-color: white
    width: 120
  }
}
# Logical 3D Grid
logical_grid: {
  label: "Logical 3D Process Grid"
  style.fill: "#F1F5F9"
  style.stroke: "#CBD6E1"
  style.stroke-width: 2
  grid_visual: {
    direction: right
    style.fill: transparent
    dp_dim: {
      label: "DP Dimension\n(DP=4)"
      direction: down
      style.fill: transparent
      dp0: {
        label: "DP Rank 0"
        style.fill: ${colors.dp-orange}
        style.font-color: white
        style.stroke: ${colors.dp-orange}
      }
      dp1: {
        label: "DP Rank 1"
        style.fill: ${colors.dp-orange}
        style.font-color: white
        style.stroke: ${colors.dp-orange}
      }
      dp2: {
        label: "DP Rank 2"
        style.fill: ${colors.dp-orange}
        style.font-color: white
        style.stroke: ${colors.dp-orange}
      }
      dp3: {
        label: "DP Rank 3"
        style.fill: ${colors.dp-orange}
        style.font-color: white
        style.stroke: ${colors.dp-orange}
      }
    }
    pp_dim: {
      label: "PP Dimension\n(PP=2)"
      direction: down
      style.fill: transparent
      pp0: {
        label: "PP Stage 0"
        style.fill: ${colors.pp-green}
        style.font-color: white
        style.stroke: ${colors.pp-green}
      }
      pp1: {
        label: "PP Stage 1"
        style.fill: ${colors.pp-green}
        style.font-color: white
        style.stroke: ${colors.pp-green}
      }
    }
    tp_dim: {
      label: "TP Dimension\n(TP=8)"
      direction: down
      style.fill: transparent
      tp_info: {
        label: "TP Group:\n8 GPUs\nwithin node"
        style.fill: ${colors.tp-blue}
        style.font-color: white
        width: 80
      }
    }
  }
  formula: |md
    **Total GPUs = TP × PP × DP = 8 × 2 × 4 = 64**
    Each GPU has coordinates: `(tp_rank, pp_rank, dp_rank)`
  | {shape: rectangle}
}
# Physical Cluster Topology
cluster: {
  label: "Physical Cluster Topology (8 Nodes × 8 GPUs)"
  style.fill: ${colors.node-bg}
  style.stroke: "#94A3B8"
