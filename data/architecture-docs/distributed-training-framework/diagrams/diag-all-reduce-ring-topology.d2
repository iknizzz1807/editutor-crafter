direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Ring All-Reduce Mechanism
  Step-by-step trace across 4 GPUs
| {near: top-center}
phase1: {
  label: "Phase 1: Scatter-Reduce (n-1 steps)"
  direction: down
  p1_initial: {
    label: "Initial State: Each GPU holds full data array, split into n chunks"
    direction: right
    style.stroke: transparent
    style.fill: transparent
    gpu0_init: {
      label: "GPU 0"
      shape: rectangle
      width: 120
      style.fill: "#E3F2FD"
      chunks0: {
        shape: sql_table
        label: "Local Data"
        c0: "A₀ | gpu0"
        c1: "B₀ | gpu0"
        c2: "C₀ | gpu0"
        c3: "D₀ | gpu0"
      }
    }
    gpu1_init: {
      label: "GPU 1"
      shape: rectangle
      width: 120
      style.fill: "#FFF3E0"
      chunks1: {
        shape: sql_table
        label: "Local Data"
        c0: "A₁ | gpu1"
        c1: "B₁ | gpu1"
        c2: "C₁ | gpu1"
        c3: "D₁ | gpu1"
      }
    }
    gpu2_init: {
      label: "GPU 2"
      shape: rectangle
      width: 120
      style.fill: "#E8F5E9"
      chunks2: {
        shape: sql_table
        label: "Local Data"
        c0: "A₂ | gpu2"
        c1: "B₂ | gpu2"
        c2: "C₂ | gpu2"
        c3: "D₂ | gpu2"
      }
    }
    gpu3_init: {
      label: "GPU 3"
      shape: rectangle
      width: 120
      style.fill: "#FCE4EC"
      chunks3: {
        shape: sql_table
        label: "Local Data"
        c0: "A₃ | gpu3"
        c1: "B₃ | gpu3"
        c2: "C₃ | gpu3"
        c3: "D₃ | gpu3"
      }
    }
  }
  p1_legend: {
    label: "Chunk Assignment: GPU i owns chunk (i+1) mod n for reduction"
    direction: right
    style.stroke: transparent
    style.fill: transparent
    l0: "A = chunk 0" {style.fill: "#BBDEFB"}
    l1: "B = chunk 1" {style.fill: "#FFE0B2"}
    l2: "C = chunk 2" {style.fill: "#C8E6C9"}
    l3: "D = chunk 3" {style.fill: "#F8BBD9"}
  }
  p1_step1: {
    label: "Step 1: Send chunk (rank-1) to neighbor, accumulate received chunk"
    direction: down
    style.stroke: "#1976D2"
    style.stroke-width: 2
    ring1: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      g0_s1: {
        label: "GPU 0"
        shape: rectangle
        style.fill: "#E3F2FD"
        data: {
          shape: sql_table
          c0: "A₀"
          c1: "B₀" {constraint: "[sending]"}
          c2: "C₀"
          c3: "D₀"
        }
      }
      g1_s1: {
        label: "GPU 1"
        shape: rectangle
        style.fill: "#FFF3E0"
        data: {
          shape: sql_table
          c0: "A₁"
          c1: "B₁+B₀" {constraint: "[accum]"}
          c2: "C₁"
          c3: "D₁"
        }
      }
      g2_s1: {
        label: "GPU 2"
        shape: rectangle
        style.fill: "#E8F5E9"
        data: {
          shape: sql_table
          c0: "A₂"
          c1: "C₁" {constraint: "[sending]"}
          c2: "C₂"
          c3: "D₂"
        }
      }
      g3_s1: {
        label: "GPU 3"
        shape: rectangle
        style.fill: "#FCE4EC"
        data: {
          shape: sql_table
          c0: "A₃"
          c1: "C₃+C₂" {constraint: "[accum]"}
          c2: "D₁"
          c3: "D₃"
        }
      }
    }
    flow1: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      f01: "0→1: B₀" {style.fill: "#BBDEFB"}
      f12: "1→2: A₁" {style.fill: "#FFE0B2"}
      f23: "2→3: C₁+C₂" {style.fill: "#C8E6C9"}
      f30: "3→0: D₁+D₃" {style.fill: "#F8BBD9"}
    }
  }
  p1_step2: {
    label: "Step 2: Continue around ring (n-1=3 total steps for n=4 GPUs)"
    direction: down
    style.stroke: "#388E3C"
    style.stroke-width: 2
    ring2: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      g0_s2: {
        label: "GPU 0"
        shape: rectangle
        style.fill: "#E3F2FD"
        data: {
          shape: sql_table
          c0: "A₀+A₃" {constraint: "[accum]"}
          c1: "B₀"
          c2: "C₀"
          c3: "D₀"
        }
      }
      g1_s2: {
        label: "GPU 1"
        shape: rectangle
        style.fill: "#FFF3E0"
        data: {
          shape: sql_table
          c0: "A₁"
          c1: "B₁+B₀+B₃" {constraint: "[accum]"}
          c2: "C₁"
          c3: "D₁"
        }
      }
      g2_s2: {
        label: "GPU 2"
        shape: rectangle
        style.fill: "#E8F5E9"
        data: {
          shape: sql_table
          c0: "A₂"
          c1: "B₂"
          c2: "C₂+C₁+C₀" {constraint: "[accum]"}
          c3: "D₂"
        }
      }
      g3_s2: {
        label: "GPU 3"
        shape: rectangle
        style.fill: "#FCE4EC"
        data: {
          shape: sql_table
          c0: "A₃"
          c1: "B₃"
          c2: "C₃"
          c3: "D₃+D₂+D₁" {constraint: "[accum]"}
        }
      }
    }
  }
  p1_result: {
    label: "Scatter-Reduce Result: Each GPU has fully reduced ONE chunk"
    direction: right
    style.stroke: transparent
    style.fill: transparent
    r0: {
      label: "GPU 0"
      shape: rectangle
      style.fill: "#E3F2FD"
      data: {
        shape: sql_table
        c0: "ΣA" {constraint: "complete"}
        c1: "partial"
        c2: "partial"
        c3: "partial"
      }
    }
    r1: {
      label: "GPU 1"
      shape: rectangle
      style.fill: "#FFF3E0"
      data: {
        shape: sql_table
        c0: "partial"
        c1: "ΣB" {constraint: "complete"}
        c2: "partial"
        c3: "partial"
      }
    }
    r2: {
      label: "GPU 2"
      shape: rectangle
      style.fill: "#E8F5E9"
      data: {
        shape: sql_table
        c0: "partial"
        c1: "partial"
        c2: "ΣC" {constraint: "complete"}
        c3: "partial"
      }
    }
    r3: {
      label: "GPU 3"
      shape: rectangle
      style.fill: "#FCE4EC"
      data: {
        shape: sql_table
        c0: "partial"
        c1: "partial"
        c2: "partial"
        c3: "ΣD" {constraint: "complete"}
      }
    }
  }
}
phase2: {
  label: "Phase 2: All-Gather (n-1 steps)"
  direction: down
  p2_step1: {
    label: "Step 1: Send fully reduced chunk to neighbor"
    direction: down
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
    gather1: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      g0_g1: {
        label: "GPU 0"
        shape: rectangle
        style.fill: "#E3F2FD"
        data: {
          shape: sql_table
          c0: "ΣA" {constraint: "[sending]"}
          c1: "ΣB" {constraint: "received"}
          c2: "partial"
          c3: "partial"
        }
      }
      g1_g1: {
        label: "GPU 1"
        shape: rectangle
        style.fill: "#FFF3E0"
        data: {
          shape: sql_table
          c0: "partial"
          c1: "ΣB" {constraint: "[sending]"}
          c2: "ΣC" {constraint: "received"}
          c3: "partial"
        }
      }
      g2_g1: {
        label: "GPU 2"
        shape: rectangle
        style.fill: "#E8F5E9"
        data: {
          shape: sql_table
          c0: "partial"
          c1: "partial"
          c2: "ΣC" {constraint: "[sending]"}
          c3: "ΣD" {constraint: "received"}
        }
      }
      g3_g1: {
        label: "GPU 3"
        shape: rectangle
        style.fill: "#FCE4EC"
        data: {
          shape: sql_table
          c0: "ΣA" {constraint: "received"}
          c1: "partial"
          c2: "partial"
          c3: "ΣD" {constraint: "[sending]"}
        }
      }
    }
  }
  p2_final: {
    label: "Final State: All GPUs have complete reduced data"
    direction: right
    style.stroke: transparent
    style.fill: transparent
    f0: {
      label: "GPU 0"
      shape: rectangle
      style.fill: "#C8E6C9"
      data: {
        shape: sql_table
        label: "Complete"
        c0: "ΣA"
        c1: "ΣB"
        c2: "ΣC"
        c3: "ΣD"
      }
    }
    f1: {
      label: "GPU 1"
      shape: rectangle
      style.fill: "#C8E6C9"
      data: {
        shape: sql_table
        label: "Complete"
        c0: "ΣA"
        c1: "ΣB"
        c2: "ΣC"
        c3: "ΣD"
      }
    }
    f2: {
      label: "GPU 2"
      shape: rectangle
      style.fill: "#C8E6C9"
      data: {
        shape: sql_table
        label: "Complete"
        c0: "ΣA"
        c1: "ΣB"
        c2: "ΣC"
        c3: "ΣD"
      }
    }
    f3: {
      label: "GPU 3"
      shape: rectangle
      style.fill: "#C8E6C9"
      data: {
        shape: sql_table
        label: "Complete"
        c0: "ΣA"
        c1: "ΣB"
        c2: "ΣC"
        c3: "ΣD"
      }
    }
  }
}
bandwidth_analysis: {
  label: "Bandwidth Cost Analysis"
  direction: down
  formula_box: {
    shape: rectangle
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
    style.stroke-width: 2
    width: 500
    formula: |md
      **Total data transferred per GPU:**
      `2(n-1)/n × data_size`
      **Phase 1 (Scatter-Reduce):** (n-1) × (data_size/n)
      **Phase 2 (All-Gather):** (n-1) × (data_size/n)
      **Total:** 2(n-1)/n × data_size
      **As n → ∞:** approaches `2 × data_size` (constant!)
    |
  }
  comparison: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    naive: {
      label: "Naive All-Reduce"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 200
      cost: {
        shape: sql_table
        label: "O(n²) sends"
        c0: "n × data_size"
        c1: "Per GPU cost"
        c2: "Scales with n"
      }
    }
    ring: {
      label: "Ring All-Reduce"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 200
      cost: {
        shape: sql_table
        label: "O(n) steps"
        c0: "2 × data_size"
        c1: "Per GPU cost"
        c2: "Constant for n"
      }
    }
  }
  example: {
    label: "Example: 7B Model Gradients"
    direction: right
    style.fill: transparent
    style.stroke: transparent
    config: {
      shape: sql_table
      label: "Configuration"
      p0: "Parameters: 7B"
      p1: "fp16: 14 GB"
      p2: "n = 4 GPUs"
    }
    result: {
      shape: sql_table
      label: "Ring All-Reduce"
      p0: "Per GPU: 2(3/4) × 14GB"
      p1: "= 21 GB transferred"
      p2: "Same for n=8, n=16..."
    }
    network: {
      shape: sql_table
      label: "Network Time"
      n0: "NVLink (300GB/s): ~70ms"
      n1: "InfiniBand (12GB/s): ~1.75s"
      n2: "Bandwidth = bottleneck"
    }
  }
}
phase1.p1_initial -> phase1.p1_step1: "Ring topology\nGPU i → GPU (i+1) mod n"
phase1.p1_step1 -> phase1.p1_step2: "Continue\nn-1 steps"
phase1.p1_step2 -> phase1.p1_result: "Complete\nscatter-reduce"
phase1.p1_result -> phase2.p2_step1: "Begin\nall-gather"
phase2.p2_step1 -> phase2.p2_final: "Complete\nall-gather"
phase2.p2_final -> bandwidth_analysis: "Analyze\ncost"
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  label: |md
    **Legend**
    - ΣX = sum of all X chunks across GPUs
    - [sending] = chunk being transmitted
    - [accum] = accumulating received data
    - complete = fully reduced chunk
  |
}