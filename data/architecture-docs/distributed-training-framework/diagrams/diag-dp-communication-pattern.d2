direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_block: {
  label: "Data Parallel Communication Pattern"
  note: "PyTorch DDP Timeline with Gradient Bucketization"
  style.fill: "#F4F6F7"
  style.stroke: "#34495E"
  style.stroke-width: 2
}

# === LEGEND ===
legend: {
  label: "Legend"
  compute: "Forward/Backward Compute" {
    style.fill: "#4A90D9"
    style.stroke: "#2E5A8C"
    style.font-color: white
  }
  comm: "All-Reduce (Ring)" {
    style.fill: "#E74C3C"
    style.stroke: "#A93226"
    style.font-color: white
  }
  optim: "Optimizer Step" {
    style.fill: "#27AE60"
    style.stroke: "#1E8449"
    style.font-color: white
  }
  idle: "Idle / Wait" {
    style.fill: "#BDC3C7"
    style.stroke: "#7F8C8D"
    style.font-color: "#2C3E50"
  }
  overlap: "Overlapped (Bucketized)" {
    style.fill: "#9B59B6"
    style.stroke: "#6C3483"
    style.font-color: white
  }
}
legend.near: bottom-right

# === GPU TIMELINES HEADER ===
timeline_header: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  gpu_label: "GPU 0-7" {
    width: 80
    style.fill: "#34495E"
    style.font-color: white
    style.stroke: transparent
  }
  t_markers: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    t1: "T1" {width: 60; style.fill: transparent; style.stroke: transparent}
    t2: "T2" {width: 60; style.fill: transparent; style.stroke: transparent}
    t3: "T3" {width: 60; style.fill: transparent; style.stroke: transparent}
    t4: "T4" {width: 60; style.fill: transparent; style.stroke: transparent}
    t5: "T5" {width: 60; style.fill: transparent; style.stroke: transparent}
    t6: "T6" {width: 60; style.fill: transparent; style.stroke: transparent}
  }
}

# === NAIVE SCHEDULE (No Overlap) ===
naive_section: {
  label: "Naive Schedule: No Overlap"
  direction: down
  naive_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    naive_label: "All GPUs" {
      width: 80
      style.fill: "#34495E"
      style.font-color: white
    }
    naive_timeline: {
      direction: right
      width: 500
      n_forward: "Forward\n(50ms)" {
        width: 100
        style.fill: "#4A90D9"
        style.stroke: "#2E5A8C"
        style.font-color: white
      }
      n_backward: "Backward\n(80ms)" {
        width: 140
        style.fill: "#4A90D9"
        style.stroke: "#2E5A8C"
        style.font-color: white
      }
      n_allreduce: "All-Reduce\n(60ms)" {
        width: 100
        style.fill: "#E74C3C"
        style.stroke: "#A93226"
        style.font-color: white
      }
      n_optim: "Optim\n(10ms)" {
        width: 60
        style.fill: "#27AE60"
        style.stroke: "#1E8449"
        style.font-color: white
      }
    }
  }
  naive_total: "Total: 200ms per step" {
    style.fill: transparent
    style.font-color: "#E74C3C"
    style.bold: true
    style.stroke: transparent
  }
}

# === BUCKETIZED SCHEDULE (With Overlap) ===
bucketized_section: {
  label: "Bucketized Schedule: Overlapped Communication"
  direction: down
  bucket_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    bucket_label: "All GPUs" {
      width: 80
      style.fill: "#34495E"
      style.font-color: white
    }
    bucket_timeline: {
      direction: right
      width: 500
      b_forward: "Forward\n(50ms)" {
        width: 100
        style.fill: "#4A90D9"
        style.stroke: "#2E5A8C"
        style.font-color: white
      }
      b_backward: "Backward" {
        width: 140
        style.fill: "#4A90D9"
        style.stroke: "#2E5A8C"
        style.font-color: white
      }
      b_overlap: "Overlapped" {
        width: 100
        style.fill: "#9B59B6"
        style.stroke: "#6C3483"
        style.font-color: white
      }
      b_optim: "Optim\n(10ms)" {
        width: 60
        style.fill: "#27AE60"
        style.stroke: "#1E8449"
        style.font-color: white
      }
    }
  }
  bucket_total: "Total: 140ms per step (30% faster)" {
    style.fill: transparent
    style.font-color: "#27AE60"
    style.bold: true
    style.stroke: transparent
  }
}

# === RING ALL-REDUCE TOPOLOGY ===
ring_section: {
  label: "Ring All-Reduce Topology"
  direction: down
  ring_container: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    ring_diagram: {
      direction: right
      width: 600
      gpu0: "GPU 0" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      gpu1: "GPU 1" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      gpu2: "GPU 2" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      gpu3: "GPU 3" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      gpu4: "GPU 4" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      gpu5: "GPU 5" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      gpu6: "GPU 6" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      gpu7: "GPU 7" { shape: circle; style.fill: "#3498DB"; style.font-color: white }
      
      gpu0 -> gpu1: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2}
      gpu1 -> gpu2: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2}
      gpu2 -> gpu3: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2}
      gpu3 -> gpu4: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2}
      gpu4 -> gpu5: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2}
      gpu5 -> gpu6: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2}
      gpu6 -> gpu7: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2}
      gpu7 -> gpu0: "chunk" {style.stroke: "#E74C3C"; style.stroke-width: 2; style.stroke-dash: 3}
    }
    ring_info: {
      direction: down
      width: 180
      phase1: "Phase 1:\nReduce-Scatter" {
        style.fill: "#FADBD8"
        style.stroke: "#E74C3C"
      }
      phase2: "Phase 2:\nAll-Gather" {
        style.fill: "#D5F5E3"
        style.stroke: "#27AE60"
      }
      bandwidth_note: |md
        **Bandwidth Cost:**
        `2 × model_size`
        (constant per GPU)
      | {
        style.fill: "#FEF9E7"
        style.stroke: "#F1C40F"
      }
    }
  }
}

# === GRADIENT BUCKETIZATION DETAIL ===
bucket_detail: {
  label: "Gradient Bucketization Mechanism"
  direction: down
  bucket_flow: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    bucket_diagram: {
      direction: down
      nn_layers: {
        direction: right
        layer_n: "Layer N" { style.fill: "#5DADE2"; style.font-color: white }
        layer_n1: "Layer N-1" { style.fill: "#5DADE2"; style.font-color: white }
        layer_n2: "Layer N-2" { style.fill: "#5DADE2"; style.font-color: white }
        dots_l: "..." { style.fill: transparent; style.stroke: transparent }
        layer_0: "Layer 0" { style.fill: "#5DADE2"; style.font-color: white }
      }
      buckets: {
        direction: right
        bucket_0: "Bucket 0\n(25MB)" { style.fill: "#9B59B6"; style.font-color: white }
        bucket_1: "Bucket 1\n(25MB)" { style.fill: "#9B59B6"; style.font-color: white }
        bucket_2: "Bucket 2\n(25MB)" { style.fill: "#9B59B6"; style.font-color: white }
        dots_b: "..." { style.fill: transparent; style.stroke: transparent }
        bucket_k: "Bucket K\n(25MB)" { style.fill: "#9B59B6"; style.font-color: white }
      }
      allreduce_pipeline: {
        direction: right
        ar0: "All-Reduce\nBucket 0" { style.fill: "#E74C3C"; style.font-color: white }
        ar1: "All-Reduce\nBucket 1" { style.fill: "#E74C3C"; style.font-color: white }
        ar2: "All-Reduce\nBucket 2" { style.fill: "#E74C3C"; style.font-color: white }
        dots_a: "..." { style.fill: transparent; style.stroke: transparent }
        ark: "All-Reduce\nBucket K" { style.fill: "#E74C3C"; style.font-color: white }
      }
      
      nn_layers.layer_n -> buckets.bucket_0: "grad" {style.stroke: "#7F8C8D"; style.stroke-dash: 2}
      nn_layers.layer_n1 -> buckets.bucket_0: "grad" {style.stroke: "#7F8C8D"; style.stroke-dash: 2}
      nn_layers.layer_n2 -> buckets.bucket_1: "grad" {style.stroke: "#7F8C8D"; style.stroke-dash: 2}
      nn_layers.layer_0 -> buckets.bucket_k: "grad" {style.stroke: "#7F8C8D"; style.stroke-dash: 2}
      buckets.bucket_0 -> allreduce_pipeline.ar0 {style.stroke: "#E74C3C"}
      buckets.bucket_1 -> allreduce_pipeline.ar1 {style.stroke: "#E74C3C"}
      buckets.bucket_2 -> allreduce_pipeline.ar2 {style.stroke: "#E74C3C"}
      buckets.bucket_k -> allreduce_pipeline.ark {style.stroke: "#E74C3C"}
    }
    bucket_explanation: {
      direction: down
      width: 150
      hook: "Backward Hook\nTriggers" { style.fill: "#FADBD8"; style.stroke: "#E74C3C" }
      ready: "Bucket Ready\n-> Start AR" { style.fill: "#D5F5E3"; style.stroke: "#27AE60" }
      overlap_note: "Computation\n|| Comm" { style.fill: "#E8DAEF"; style.stroke: "#9B59B6" }
    }
  }
}

# === COMMUNICATION VOLUME ANALYSIS ===
volume_section: {
  label: "Communication Volume Analysis"
  direction: down
  volume_table: {
    shape: sql_table
    label: "Per-Step Communication (7B Model, fp16)"
    row1: "Parameter | Size | Notes"
    row2: "Model params | 14 GB | 7B x 2 bytes"
    row3: "Gradients | 14 GB | Same as params"
    row4: "Per-GPU send | 28 GB | 2 x model_size"
    row5: "Per-GPU recv | 28 GB | 2 x model_size"
    row6: "Total per step | 56 GB/GPU | Ring All-Reduce"
  }
  bandwidth_row: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    nvlink: "NVLink (300 GB/s)" {
      style.fill: "#27AE60"; style.font-color: white; width: 180
      label: "Time: ~93ms"
    }
    infiniband: "InfiniBand (12 GB/s)" {
      style.fill: "#E74C3C"; style.font-color: white; width: 180
      label: "Time: ~2.3s"
    }
  }
  volume_table -> bandwidth_row: "Analysis" {style.stroke-width: 2}
}

# === KEY EQUATIONS ===
equations: {
  label: "Key Equations"
  direction: right
  style.fill: transparent
  style.stroke: transparent
  eq1: {
    width: 280
    label: "Ring All-Reduce"
    code: |'python
# Per-GPU data transfer
send_vol = 2 * model_size
# For 7B fp16 model
t_nvlink = 28GB / 300GB/s
         = 93ms
t_ib = 28GB / 12GB/s
     = 2.3s
    '|
  }
  eq2: {
    width: 280
    label: "Scaling Efficiency"
    code: |'python
# Efficiency formula
eff = T_1 / (N * T_N)
# Overlap improvement
eff_ov = T_1 / (N * T_N_ov)
# Target: 85-95%
    '|
  }
  eq3: {
    width: 280
    label: "Bucket Trade-off"
    code: |'python
# Default: 25MB
bucket_cap = 25
# Smaller = more overlap
# Larger = throughput
# Optimal: balance
    '|
  }
}

# === GLOBAL CONNECTIONS ===
naive_section -> bucketized_section: "Optimization" {
  style.stroke: "#27AE60"
  style.stroke-width: 3
  style.stroke-dash: 5
}
bucketized_section -> ring_section: "Implementation" {
  style.stroke: "#3498DB"
  style.stroke-dash: 3
}
ring_section -> bucket_detail: "Mechanism" {
  style.stroke: "#9B59B6"
  style.stroke-dash: 3
}
bucket_detail -> volume_section: "Cost Analysis" {
  style.stroke: "#E74C3C"
  style.stroke-dash: 3
}