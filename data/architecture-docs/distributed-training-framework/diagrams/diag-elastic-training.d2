direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Elastic Training: Dynamic Worker Management
  Handling joins and leaves in distributed training
| {near: top-center}
classes: {
  worker: {
    shape: rectangle
    width: 140
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 4
    }
  }
  worker_new: {
    shape: rectangle
    width: 140
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 4
    }
  }
  worker_dead: {
    shape: rectangle
    width: 140
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 2
      stroke-dash: 4
      border-radius: 4
      opacity: 0.5
    }
  }
  controller: {
    shape: hexagon
    width: 160
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
  }
  storage: {
    shape: cylinder
    width: 140
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  step: {
    shape: step
    width: 180
    style: {
      fill: "#FAFAFA"
      stroke: "#757575"
      stroke-width: 1
    }
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  join_section: {
    direction: down
    label: "WORKER JOIN SCENARIO"
    join_before: {
      label: "Before: 3 Workers"
      direction: right
      join_ctrl_before: {
        class: controller
        label: "Controller\n(ElasticManager)"
      }
      join_w1: {
        class: worker
        label: "Worker 0\nDP rank 0\nbatch=4"
      }
      join_w2: {
        class: worker
        label: "Worker 1\nDP rank 1\nbatch=4"
      }
      join_w3: {
        class: worker
        label: "Worker 2\nDP rank 2\nbatch=4"
      }
      join_ctrl_before -> join_w1: "state"
      join_ctrl_before -> join_w2: "state"
      join_ctrl_before -> join_w3: "state"
    }
    join_step1: {
      class: step
      label: "Step 1: New Worker Joins"
    }
    join_detect: {
      label: "Step 1: Detect New Worker"
      direction: right
      join_ctrl_detect: {
        class: controller
        label: "Controller\nnew_size=4"
      }
      join_w1_d: {
        class: worker
        label: "Worker 0\nDP rank 0"
      }
      join_w2_d: {
        class: worker
        label: "Worker 1\nDP rank 1"
      }
      join_w3_d: {
        class: worker
        label: "Worker 2\nDP rank 2"
      }
      join_w4_d: {
        class: worker_new
        label: "Worker 3\nNEW!\nDP rank 3"
      }
      join_ctrl_detect -> join_w4_d: "1. Broadcast\ncurrent step\nmodel params" {
        style: {
          stroke: "#388E3C"
          stroke-width: 3
          animated: true
        }
      }
    }
    join_step2: {
      class: step
      label: "Step 2: Redistribute Data Shards"
    }
    join_redist: {
      label: "Step 2: Redistribute Data"
      direction: right
      join_ds_ctrl: {
        class: controller
        label: "Sampler\nreindex"
      }
      join_ds_w1: {
        class: worker
        label: "Worker 0\nshard: [0,4,8...]"
      }
      join_ds_w2: {
        class: worker
        label: "Worker 1\nshard: [1,5,9...]"
      }
      join_ds_w3: {
        class: worker
        label: "Worker 2\nshard: [2,6,10...]"
      }
      join_ds_w4: {
        class: worker_new
        label: "Worker 3\nshard: [3,7,11...]"
      }
      join_ds_ctrl -> join_ds_w1: "mod 4"
      join_ds_ctrl -> join_ds_w2: "mod 4"
      join_ds_ctrl -> join_ds_w3: "mod 4"
      join_ds_ctrl -> join_ds_w4: "mod 4"
    }
    join_step3: {
      class: step
      label: "Step 3: Adjust Batch & LR"
    }
    join_adjust: {
      label: "Step 3: Adjust Hyperparams"
      join_adjust_box: {
        style: {
          fill: "#E8F5E9"
          stroke: "#2E7D32"
          border-radius: 8
        }
        join_formula: |md
          **Batch Size Scaling:**
          
          old_batch = 4 (per worker)
          new_batch = global_batch / new_size
                    = 12 / 4 = 3
          
          **Learning Rate Scaling:**
          
          # Linear scaling rule
          old_lr = 1e-4
          scale = new_size / old_size = 4/3
          new_lr = old_lr * scale = 1.33e-4
          
          **Gradient Accumulation:**
          
          # Keep global batch constant
          accum = global_batch / (local_batch * size)
                = 12 / (3 * 4) = 1
          
        | {shape: rectangle}
      }
    }
    join_final: {
      label: "Result: 4 Workers Active"
      direction: right
      join_f_ctrl: {
        class: controller
        label: "Controller\nworld_size=4"
      }
      join_f_w1: {
        class: worker
        label: "Worker 0\nbatch=3\nlr=1.33e-4"
      }
      join_f_w2: {
        class: worker
        label: "Worker 1\nbatch=3\nlr=1.33e-4"
      }
      join_f_w3: {
        class: worker
        label: "Worker 2\nbatch=3\nlr=1.33e-4"
      }
      join_f_w4: {
        class: worker_new
        label: "Worker 3\nbatch=3\nlr=1.33e-4"
      }
      join_f_ctrl -> join_f_w1
      join_f_ctrl -> join_f_w2
      join_f_ctrl -> join_f_w3
      join_f_ctrl -> join_f_w4
    }
  }
  leave_section: {
    direction: down
    label: "WORKER LEAVE SCENARIO"
    leave_before: {
      label: "Before: 4 Workers"
      direction: right
      leave_ctrl_before: {
        class: controller
        label: "Controller\nworld_size=4"
      }
      leave_w1: {
        class: worker
        label: "Worker 0\nDP rank 0"
      }
      leave_w2: {
        class: worker
        label: "Worker 1\nDP rank 1"
      }
      leave_w3: {
        class: worker
        label: "Worker 2\nDP rank 2"
      }
      leave_w4: {
        class: worker
        label: "Worker 3\nDP rank 3"
      }
      leave_ctrl_before -> leave_w1
      leave_ctrl_before -> leave_w2
      leave_ctrl_before -> leave_w3
      leave_ctrl_before -> leave_w4
    }
    leave_step1: {
      class: step
      label: "Step 1: Worker Failure Detected"
    }
    leave_detect: {
      label: "Step 1: Detect Failure"
      direction: right
      leave_ctrl_detect: {
        class: controller
        label: "Controller\nheartbeat timeout!"
      }
      leave_w1_d: {
        class: worker
        label: "Worker 0\nalive"
      }
      leave_w2_d: {
        class: worker
        label: "Worker 1\nalive"
      }
      leave_w3_d: {
        class: worker
        label: "Worker 2\nDEAD"
        class: worker_dead
      }
      leave_w4_d: {
        class: worker
        label: "Worker 3\nalive"
      }
      leave_ctrl_detect -> leave_w3_d: "no response\nafter 30s" {
        style: {
          stroke: "#D32F2F"
          stroke-dash: 4
        }
      }
    }
    leave_step2: {
      class: step
      label: "Step 2: Checkpoint Surviving Workers"
    }
    leave_ckpt: {
      label: "Step 2: Emergency Checkpoint"
      direction: right
      leave_ckpt_ctrl: {
        class: controller
        label: "Controller\ninitiate ckpt"
      }
      leave_ckpt_store: {
        class: storage
        label: "Distributed\nStorage\n(S3/GCS)"
      }
      leave_ckpt_w1: {
        class: worker
        label: "Worker 0\nsave state"
      }
      leave_ckpt_w2: {
        class: worker
        label: "Worker 1\nsave state"
      }
      leave_ckpt_w3: {
        class: worker_dead
        label: "Worker 2\n(skipped)"
      }
      leave_ckpt_w4: {
        class: worker
        label: "Worker 3\nsave state"
      }
      leave_ckpt_w1 -> leave_ckpt_store: "async upload"
      leave_ckpt_w2 -> leave_ckpt_store: "async upload"
      leave_ckpt_w4 -> leave_ckpt_store: "async upload"
      leave_ckpt_ctrl -> leave_ckpt_store: "mark valid"
    }
    leave_step3: {
      class: step
      label: "Step 3: Restart with Fewer Workers"
    }
    leave_restart: {
      label: "Step 3: Restart Pipeline"
      leave_restart_box: {
        style: {
          fill: "#FFF8E1"
          stroke: "#F57C00"
          border-radius: 8
        }
        leave_restart_flow: |md
          **Restart Sequence:**
          
          1. Destroy old process groups
          2. Reinitialize with world_size=3
          3. Reassign DP ranks:
             - Worker 0 → rank 0
             - Worker 1 → rank 1  
             - Worker 3 → rank 2 (was rank 3)
          4. Load checkpoint from storage
          5. Recreate DistributedSampler with new size
          
          **Rendezvous Protocol:**
          
          # All workers meet at rendezvous point
          # Wait for min_workers (e.g., 2)
          # If timeout → scale down further
          
        | {shape: rectangle}
      }
    }
    leave_step4: {
      class: step
      label: "Step 4: Scale Learning Rate Down"
    }
    leave_lr: {
      label: "Step 4: Adjust Hyperparams"
      leave_lr_box: {
        style: {
          fill: "#FFEBEE"
          stroke: "#C62828"
          border-radius: 8
        }
        leave_formula: |md
          **Learning Rate Scaling (Down):**
          
          # Scale down with fewer workers
          old_size = 4
          new_size = 3
          old_lr = 1.33e-4
          scale = new_size / old_size = 3/4
          new_lr = old_lr * scale = 1.0e-4
          
          **Batch Size Adjustment:**
          
          # Keep global batch constant
          global_batch = 12
          new_local_batch = 12 / 3 = 4
          
          **Warmup Restart:**
          
          # Optional: short warmup after scale-down
          # to stabilize training
          warmup_steps = 100
          lr_schedule = warmup_decay(new_lr, step)
          
        | {shape: rectangle}
      }
    }
    leave_final: {
      label: "Result: 3 Workers Active"
      direction: right
      leave_f_ctrl: {
        class: controller
        label: "Controller\nworld_size=3"
      }
      leave_f_w1: {
        class: worker
        label: "Worker 0\nbatch=4\nlr=1.0e-4\nrank=0"
      }
      leave_f_w2: {
        class: worker
        label: "Worker 1\nbatch=4\nlr=1.0e-4\nrank=1"
      }
      leave_f_w3: {
        class: worker_dead
        label: "Worker 2\n(REMOVED)"
      }
      leave_f_w4: {
        class: worker
        label: "Worker 3\nbatch=4\nlr=1.0e-4\nrank=2"
      }
      leave_f_ctrl -> leave_f_w1
      leave_f_ctrl -> leave_f_w2
      leave_f_ctrl -> leave_f_w4
    }
  }
}
join_section -> leave_section: "Time / Failure Event" {
  style: {
    stroke: "#757575"
    stroke-dash: 4
  }
}
legend: {
  near: bottom-center
  direction: right
  leg1: {
    class: worker
    label: "Active Worker"
    width: 100
  }
  leg2: {
    class: worker_new
    label: "New Worker"
    width: 100
  }
  leg3: {
    class: worker_dead
    label: "Failed Worker"
    width: 100
  }
  leg4: {
    class: controller
    label: "Controller"
    width: 100
  }
}
join_before -> join_detect -> join_redist -> join_adjust -> join_final
leave_before -> leave_detect -> leave_ckpt -> leave_restart -> leave_lr -> leave_final