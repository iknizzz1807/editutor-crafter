direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Gradient Accumulation Timeline
  **4 micro-batches accumulate gradients before single optimizer step**
| {near: top-center}
classes: {
  forward_phase: {
    style: {
      fill: "#4A90D9"
      font-color: white
      bold: true
    }
  }
  backward_phase: {
    style: {
      fill: "#7B68EE"
      font-color: white
      bold: true
    }
  }
  optimizer_phase: {
    style: {
      fill: "#2ECC71"
      font-color: white
      bold: true
    }
  }
  accumulate: {
    style: {
      fill: "#FFF3CD"
      stroke: "#856404"
      stroke-dash: 3
    }
  }
  memory_high: {
    style: {
      fill: "#F8D7DA"
      stroke: "#721C24"
    }
  }
  memory_low: {
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
    }
  }
}
timeline: {
  direction: down
  label: "Training Step Timeline"
  mb0: {
    direction: right
    label: "Micro-batch 0"
    fwd0: "Forward" {class: forward_phase}
    bwd0: "Backward\n(accumulate)" {class: backward_phase}
    fwd0 -> bwd0
  }
  mb1: {
    direction: right
    label: "Micro-batch 1"
    fwd1: "Forward" {class: forward_phase}
    bwd1: "Backward\n(accumulate)" {class: backward_phase}
    fwd1 -> bwd1
  }
  mb2: {
    direction: right
    label: "Micro-batch 2"
    fwd2: "Forward" {class: forward_phase}
    bwd2: "Backward\n(accumulate)" {class: backward_phase}
    fwd2 -> bwd2
  }
  mb3: {
    direction: right
    label: "Micro-batch 3"
    fwd3: "Forward" {class: forward_phase}
    bwd3: "Backward\n(accumulate)" {class: backward_phase}
    fwd3 -> bwd3
  }
  opt: {
    direction: right
    label: "After 4 steps"
    sync: "All-Reduce\nGradients" {class: accumulate}
    step: "Optimizer\nStep" {class: optimizer_phase}
    zero: "Zero\nGrads" {class: memory_low}
    sync -> step -> zero
  }
}
mb0 -> mb1: "activations\nreleased"
mb1 -> mb2: "activations\nreleased"
mb2 -> mb3: "activations\nreleased"
mb3 -> opt: "4× grads\naccumulated"
gradient_state: {
  direction: down
  label: "Gradient Buffer State"
  state0: {
    direction: right
    label: "After MB0"
    g0: "grad₀"
    note0: "1/4 accumulated" {class: accumulate}
  }
  state1: {
    direction: right
    label: "After MB1"
    g1: "grad₀ + grad₁"
    note1: "2/4 accumulated" {class: accumulate}
  }
  state2: {
    direction: right
    label: "After MB2"
    g2: "grad₀ + grad₁ + grad₂"
    note2: "3/4 accumulated" {class: accumulate}
  }
  state3: {
    direction: right
    label: "After MB3"
    g3: "Σ gradᵢ"
    note3: "Ready for\noptimizer" {class: optimizer_phase}
  }
  state0 -> state1 -> state2 -> state3
}
memory_comparison: {
  direction: right
  label: "Memory Usage Comparison"
  with_accum: {
    direction: down
    label: "With Accumulation\n(effective_batch = 4×)"
    mem_peak1: "Peak Memory\nactivations per micro-batch" {class: memory_low}
    grad_buf1: "Gradient Buffer\ncontinuously accumulating"
    mem_peak1 -> grad_buf1: "same peak\nas single batch"
  }
  without_accum: {
    direction: down
    label: "Without Accumulation\n(single batch = 4× size)"
    mem_peak2: "Peak Memory\n4× activations" {class: memory_high}
    grad_buf2: "Gradient Buffer\nsingle update"
    mem_peak2 -> grad_buf2: "4× memory\nfor activations"
  }
}
key_insight: {
  label: "Key Trade-off"
  code: |'python
# Loss must be scaled for correct averaging
scaled_loss = loss / accumulation_steps
scaled_loss.backward()
# Equivalent to:
# grad_avg = (grad_0 + grad_1 + ... + grad_n) / n
# optimizer uses averaged gradients
'|
  width: 380
}
legend: {
  near: bottom-center
  direction: right
  f: "Forward" {class: forward_phase}
  b: "Backward" {class: backward_phase}
  o: "Optimizer" {class: optimizer_phase}
  a: "Accumulate" {class: accumulate}
}