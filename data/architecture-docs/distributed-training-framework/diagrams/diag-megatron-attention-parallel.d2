direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Megatron-LM Tensor-Parallel Attention"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  input: {
    label: "Input X"
    shape: rectangle
    width: 120
    height: 60
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
    shape_info: {
      label: "(batch, seq, hidden)"
      shape: text
      style.font-size: 11
    }
    status: {
      label: "REPLICATED"
      shape: text
      style: {
        font-color: "#2E7D32"
        font-size: 10
        bold: true
      }
    }
  }
  input_note: {
    label: "Same input on all GPUs"
    shape: text
    style.font-size: 11
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  qkv_label: {
    label: "Column-Parallel\nQKV Projection"
    shape: rectangle
    width: 160
    height: 50
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  qkv_desc: {
    label: |md
      **Each GPU:**
      - QKV weight: (hidden, 3×hidden/tp)
      - Output: (batch, seq, 3×hidden/tp)
      - **NO COMMUNICATION**
    |
    shape: text
    style.font-size: 10
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  gpu0: {
    label: "GPU 0"
    shape: rectangle
    width: 200
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
    }
    qkv0: {
      shape: sql_table
      label: "QKV Projection (local)"
      w: "0x00 | float16 | W_qkv₀"
      shape_row: "     | (hidden, 3×h/tp)"
      out: "0x00 | float16 | QKV₀"
      shape_out: "     | (b, s, 3×h/tp)"
    }
    heads0: {
      label: "Heads 0-7"
      shape: rectangle
      style.fill: "#FFCDD2"
    }
  }
  gpu1: {
    label: "GPU 1"
    shape: rectangle
    width: 200
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    qkv1: {
      shape: sql_table
      label: "QKV Projection (local)"
      w: "0x00 | float16 | W_qkv₁"
      shape_row: "     | (hidden, 3×h/tp)"
      out: "0x00 | float16 | QKV₁"
      shape_out: "     | (b, s, 3×h/tp)"
    }
    heads1: {
      label: "Heads 8-15"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
  }
  gpu2: {
    label: "GPU 2"
    shape: rectangle
    width: 200
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
    qkv2: {
      shape: sql_table
      label: "QKV Projection (local)"
      w: "0x00 | float16 | W_qkv₂"
      shape_row: "     | (hidden, 3×h/tp)"
      out: "0x00 | float16 | QKV₂"
      shape_out: "     | (b, s, 3×h/tp)"
    }
    heads2: {
      label: "Heads 16-23"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
  }
  gpu3: {
    label: "GPU 3"
    shape: rectangle
    width: 200
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    qkv3: {
      shape: sql_table
      label: "QKV Projection (local)"
      w: "0x00 | float16 | W_qkv₃"
      shape_row: "     | (hidden, 3×h/tp)"
      out: "0x00 | float16 | QKV₃"
      shape_out: "     | (b, s, 3×h/tp)"
    }
    heads3: {
      label: "Heads 24-31"
      shape: rectangle
      style.fill: "#E1BEE7"
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  attn_label: {
    label: "Independent\nAttention per Head"
    shape: rectangle
    width: 160
    height: 50
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  attn_desc: {
    label: |md
      **Per GPU:**
      - Split QKV → Q, K, V
      - Compute attention scores
      - Apply to values
      - **NO COMMUNICATION**
    |
    shape: text
    style.font-size: 10
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  attn0: {
    label: "Attention\n(Heads 0-7)"
    shape: rectangle
    width: 180
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
    code0: |'c
      Q₀, K₀, V₀ = split(QKV₀)
      scores = Q₀ @ K₀ᵀ / √d
      attn = softmax(scores)
      out₀ = attn @ V₀
    '|
  }
  attn1: {
    label: "Attention\n(Heads 8-15)"
    shape: rectangle
    width: 180
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
    code1: |'c
      Q₁, K₁, V₁ = split(QKV₁)
      scores = Q₁ @ K₁ᵀ / √d
      attn = softmax(scores)
      out₁ = attn @ V₁
    '|
  }
  attn2: {
    label: "Attention\n(Heads 16-23)"
    shape: rectangle
    width: 180
    style: {
      fill: "#BBDEFB"
      stroke: "#1565C0"
    }
    code2: |'c
      Q₂, K₂, V₂ = split(QKV₂)
      scores = Q₂ @ K₂ᵀ / √d
      attn = softmax(scores)
      out₂ = attn @ V₂
    '|
  }
  attn3: {
    label: "Attention\n(Heads 24-31)"
    shape: rectangle
    width: 180
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
    }
    code3: |'c
      Q₃, K₃, V₃ = split(QKV₃)
      scores = Q₃ @ K₃ᵀ / √d
      attn = softmax(scores)
      out₃ = attn @ V₃
    '|
  }
}
row6: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  outproj_label: {
    label: "Row-Parallel\nOutput Projection"
    shape: rectangle
    width: 160
    height: 50
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  outproj_desc: {
    label: |md
      **Each GPU:**
      - W_out: (hidden/tp, hidden)
      - Compute partial output
      - **ALL-REDUCE** to sum
    |
    shape: text
    style.font-size: 10
  }
}
row7: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  proj0: {
    shape: sql_table
    label: "Output Proj (GPU 0)"
    w: "0x00 | float16 | W_out₀"
    shape_w: "     | (h/tp, hidden)"
    partial: "0x00 | float16 | Y₀ (partial)"
    shape_y: "     | (b, s, hidden)"
  }
  proj1: {
    shape: sql_table
    label: "Output Proj (GPU 1)"
    w: "0x00 | float16 | W_out₁"
    shape_w: "     | (h/tp, hidden)"
    partial: "0x00 | float16 | Y₁ (partial)"
    shape_y: "     | (b, s, hidden)"
  }
  proj2: {
    shape: sql_table
    label: "Output Proj (GPU 2)"
    w: "0x00 | float16 | W_out₂"
    shape_w: "     | (h/tp, hidden)"
    partial: "0x00 | float16 | Y₂ (partial)"
    shape_y: "     | (b, s, hidden)"
  }
  proj3: {
    shape: sql_table
    label: "Output Proj (GPU 3)"
    w: "0x00 | float16 | W_out₃"
    shape_w: "     | (h/tp, hidden)"
    partial: "0x00 | float16 | Y₃ (partial)"
    shape_y: "     | (b, s, hidden)"
  }
}
row8: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  allreduce: {
    label: "ALL-REDUCE (SUM)"
    shape: diamond
    width: 140
    height: 60
    style: {
      fill: "#FF5722"
      stroke: "#BF360C"
      stroke-width: 3
      font-color: white
      bold: true
    }
  }
  allreduce_desc: {
    label: |md
      **Y = Y₀ + Y₁ + Y₂ + Y₃**
      Volume: batch × seq × hidden
      Bandwidth: NVLink (~300 GB/s)
    |
    shape: text
    style.font-size: 10
  }
}
row9: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  output: {
    label: "Output Y"
    shape: rectangle
    width: 120
    height: 60
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    shape_info: {
      label: "(batch, seq, hidden)"
      shape: text
      style.font-size: 11
    }
    status: {
      label: "REPLICATED"
      shape: text
      style: {
        font-color: "#2E7D32"
        font-size: 10
        bold: true
      }
    }
  }
  output_note: {
    label: "Same output on all GPUs"
    shape: text
    style.font-size: 11
  }
}
legend: {
  near: bottom-right
  label: "Communication Pattern"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
  }
  no_comm: {
    label: "NO COMMUNICATION"
    shape: text
    style: {
      font-color: "#2E7D32"
      bold: true
    }
  }
  allreduce: {
    label: "ALL-REDUCE (1× per block)"
    shape: text
    style: {
      font-color: "#BF360C"
      bold: true
    }
  }
}
input -> qkv_label: "X (replicated)"
qkv_label -> gpu0
qkv_label -> gpu1
qkv_label -> gpu2
qkv_label -> gpu3
gpu0 -> attn0: "QKV₀"
gpu1 -> attn1: "QKV₁"
gpu2 -> attn2: "QKV₂"
gpu3 -> attn3: "QKV₃"
attn0 -> outproj_label: "out₀"
attn1 -> outproj_label: "out₁"
attn2 -> outproj_label: "out₂"
attn3 -> outproj_label: "out₃"
outproj_label -> proj0
outproj_label -> proj1
outproj_label -> proj2
outproj_label -> proj3
proj0 -> allreduce: "Y₀"
proj1 -> allreduce: "Y₁"
proj2 -> allreduce: "Y₂"
proj3 -> allreduce: "Y₃"
allreduce -> output: "Y = ΣYᵢ"