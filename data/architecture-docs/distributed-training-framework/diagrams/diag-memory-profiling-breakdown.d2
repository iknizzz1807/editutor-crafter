direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    params: "#4A90D9"
    optimizer: "#7B68EE"
    activations: "#50C878"
    gradients: "#FF6B6B"
    buffers: "#FFB347"
    warning: "#FF4757"
    bg: "#1a1a2e"
  }
}
title: |md
  # Memory Profiling Breakdown
  ### Training Step Memory Allocation Analysis
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_stack: {
    direction: down
    label: "Memory Stack Over Time"
    step_axis: {
      label: "Training Step Timeline"
      style.fill: transparent
      style.stroke: "${colors.params}"
      style.stroke-width: 2
      step_markers: |md
        `Forward` → `Backward` → `Optimizer`
      |
    }
    phase_forward: {
      label: "Phase 1: Forward Pass"
      style.fill: "#E8F4FD"
      style.stroke: "${colors.params}"
      forward_desc: |md
        **Memory Growth:**
        - Parameters: **loaded** (constant)
        - Activations: **growing** per layer
        - Gradients: **not yet allocated**
      |
    }
    phase_backward: {
      label: "Phase 2: Backward Pass (PEAK)"
      style.fill: "#FFE4E1"
      style.stroke: "${colors.warning}"
      style.stroke-width: 3
      backward_desc: |md
        **Memory Peak:**
        - Activations: **fully stored**
        - Gradients: **allocated per layer**
        - Temporary: **gradient computation buffers**
        - ⚠️ **Peak memory usage here**
      |
    }
    phase_optimizer: {
      label: "Phase 3: Optimizer Step"
      style.fill: "#E8F8E8"
      style.stroke: "${colors.activations}"
      optimizer_desc: |md
        **Memory Release:**
        - Activations: **freed**
        - Gradients: **consumed, then freed**
        - Optimizer states: **updated**
      |
    }
    phase_forward -> phase_backward: "activations stored"
    phase_backward -> phase_optimizer: "gradients consumed"
  }
  memory_breakdown: {
    direction: down
    label: "Memory Category Breakdown"
    categories: {
      shape: sql_table
      label: "Memory Categories (per GPU)"
      cat1: "Parameters     | ~17.5 GB | 25% | ${colors.params}"
      cat2: "Optimizer      | ~35.0 GB | 50% | ${colors.optimizer}"
      cat3: "Activations    | ~10.5 GB | 15% | ${colors.activations}"
      cat4: "Gradients      | ~3.5 GB  | 5%  | ${colors.gradients}"
      cat5: "Temp Buffers   | ~3.5 GB  | 5%  | ${colors.buffers}"
      total: "PEAK TOTAL     | ~70.0 GB | 100% | A100 limit: 80GB"
    }
    peak_analysis: {
      label: "Peak Memory Analysis"
      style.fill: "#FFF3E0"
      style.stroke: "${colors.buffers}"
      peak_content: |md
        **Peak Memory Timing:**
        - Occurs during **late backward pass**
        - All activations stored + gradients computing
        - **Safety margin:** ~10 GB from OOM
        **Critical Threshold:**
        - 70GB peak / 80GB capacity = **87.5% utilization**
        - Single large batch could trigger OOM
      |
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fragmentation: {
    direction: down
    label: "Fragmentation Analysis"
    frag_visual: {
      direction: down
      label: "Memory Fragmentation Pattern"
      allocated: {
        label: "Allocated Blocks"
        style.fill: "${colors.params}"
        style.stroke: "${colors.params}"
        block1: {style.fill: "${colors.params}"; label: "Params"}
        block2: {style.fill: "${colors.activations}"; label: "Act"}
        block3: {style.fill: "${colors.params}"; label: "Params"}
        gap1: {label: "gap"; style.fill: "transparent"; style.stroke-dash: 3}
        block4: {style.fill: "${colors.gradients}"; label: "Grad"}
        gap2: {label: "gap"; style.fill: "transparent"; style.stroke-dash: 3}
        block5: {style.fill: "${colors.optimizer}"; label: "Opt"}
      }
      fragmentation_metrics: {
        shape: sql_table
        label: "Fragmentation Metrics"
        m1: "Total Allocated     | 70.0 GB"
        m2: "Total Reserved      | 78.5 GB"
        m3: "Fragmentation Ratio | 12.2%"
        m4: "Largest Free Block  | 4.2 GB"
        m5: "Free Block Count    | 127 fragments"
      }
    }
    frag_impact: {
      label: "Fragmentation Impact"
      style.fill: "#FFEBEE"
      style.stroke: "${colors.warning}"
      impact_content: |md
        **Problems:**
        - Cannot allocate 8GB activation block
        - Sum of free = 8.5GB but fragmented
        - Would fail despite "available" memory
        **Solutions:**
        - `torch.cuda.empty_cache()` after optimizer
        - Pre-allocate activation buffers
        - Use gradient checkpointing
      |
    }
  }
  timeline_profile: {
    direction: down
    label: "Memory Timeline Profile"
    time_series: {
      direction: right
      label: "Memory Over Training Step"
      t0: {
        label: "T0\nStart"
        style.fill: "${colors.params}"
        m0: |md
          **Memory:** 52.5 GB
          - Params: 17.5 GB
          - Optimizer: 35.0 GB
        |
      }
      t1: {
        label: "T1\nForward"
        style.fill: "${colors.activations}"
        m1: |md
          **Memory:** 63.0 GB
          - +Activations: 10.5 GB
          - Growing per layer
        |
      }
      t2: {
        label: "T2\nBackward"
        style.fill: "${colors.warning}"
        style.stroke-width: 3
        m2: |md
          **Memory:** 70.0 GB ⚠️
          - +Gradients: 3.5 GB
          - +Temp buffers: 3.5 GB
          - **PEAK**
        |
      }
      t3: {
        label: "T3\nPost-Opt"
        style.fill: "${colors.params}"
        m3: |md
          **Memory:** 52.5 GB
          - Activations freed
          - Gradients freed
          - Back to baseline
        |
      }
      t0 -> t1: "+10.5 GB"
      t1 -> t2: "+7.0 GB"
      t2 -> t3: "-17.5 GB"
    }
    leak_detection: {
      label: "Memory Leak Detection"
      style.fill: "#E8F5E9"
      style.stroke: "${colors.activations}"
      leak_content: |md
        **Leak Indicators:**
        - Step 0 → 100: 52.5 GB → 52.5 GB ✓
        - No accumulated growth
        - Stable baseline = **no leak**
        **Leak Signs to Watch:**
        - Baseline growing 0.1 GB/step
        - Saved tensors not freed
        - Growing lists in training loop
      |
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  optimization: {
    direction: down
    label: "Memory Optimization Strategies"
    strategies: {
      shape: sql_table
      label: "Optimization Actions (Priority Order)"
      s1: "1. Gradient Checkpointing | -40% activations | Compute tradeoff"
      s2: "2. ZeRO-1 Sharding       | -50% optimizer   | No comm overhead"
      s3: "3. ZeRO-3 Sharding       | -75% all state   | +comm overhead"
      s4: "4. Reduce Batch Size     | -linear scaling  | Longer training"
      s5: "5. empty_cache() calls   | -fragmentation   | Small overhead"
      s6: "6. Activation Offload    | -100% act on GPU | PCIe bandwidth"
    }
    recommendation: {
      label: "Recommended Actions"
      style.fill: "#E3F2FD"
      style.stroke: "${colors.params}"
      rec_content: |md
        **For 70GB peak on 80GB GPU:**
        1. **Immediate:** Add `empty_cache()` after optimizer
        2. **If OOM occurs:** Enable gradient checkpointing
        3. **For larger models:** Implement ZeRO-1 sharding
        **Expected result:**
        - Peak reduced to ~55 GB (31% margin)
        - Fragmentation reduced to <5%
      |
    }
  }
  profiler_code: {
    direction: down
    label: "Memory Profiler Implementation"
    code_example: {
      label: "MemoryProfiler (memory_profiler.py)"
      width: 450
      code: |'python
        class MemoryProfiler:
            def take_snapshot(self) -> MemorySnapshot:
                allocated = torch.cuda.memory_allocated()
                reserved = torch.cuda.memory_reserved()
                # Breakdown by category
                params = sum(p.numel() * p.element_size() 
                            for p in model.parameters())
                grads = sum(p.grad.numel() * p.grad.element_size()
                           for p in model.parameters() if p.grad)
                # Fragmentation
                frag = 1.0 - (allocated / reserved)
                return MemorySnapshot(
                    allocated_bytes=allocated,
                    fragmentation_ratio=frag,
                    ...
                )
      '|
    }
    usage: {
      label: "Usage in Training Loop"
      usage_code: |'python
        profiler = MemoryProfiler(model, optimizer, pg)
        for step, batch in enumerate(dataloader):
            # Profile automatically
            loss = train_step(batch)
            profiler.step()  # Snapshot every N steps
            if step % 100 == 0:
                print(profiler.generate_report())
      '|
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  l1: {label: "Parameters"; style.fill: "${colors.params}"}
  l2: {label: "Optimizer"; style.fill: "${colors.optimizer}"}
  l3: {label: "Activations"; style.fill: "${colors.activations}"}
  l4: {label: "Gradients"; style.fill: "${colors.gradients}"}
  l5: {label: "Temp Buffers"; style.fill: "${colors.buffers}"}
  l6: {label: "Peak Warning"; style.fill: "${colors.warning}"}
}
memory_stack.phase_forward -> memory_breakdown.categories: "breakdown"
timeline_profile.time_series.t2 -> fragmentation.frag_visual: "peak state"
optimization.strategies -> memory_breakdown.peak_analysis: "reduces peak"