direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    fp32-blue: "#3B82F6"
    fp16-green: "#10B981"
    danger-red: "#EF4444"
    warning-yellow: "#F59E0B"
    success-purple: "#8B5CF6"
    gray: "#6B7280"
  }
}

# --- HEADER SECTION ---
header: {
  label: "Mixed Precision Training Flow (fp16/bf16)"
  note: "Loss scaling prevents gradient underflow in fp16 narrow range"
}

# --- LEGEND ---
legend: {
  shape: package
  direction: right
  fp32_box: "FP32 (32-bit)" {
    style.fill: "#3B82F6"
    style.font-color: white
  }
  fp16_box: "FP16 (16-bit)" {
    style.fill: "#10B981"
    style.font-color: white
  }
  danger_box: "Overflow/Underflow Risk" {
    style.fill: "#EF4444"
    style.font-color: white
  }
}
legend.near: bottom-right

# --- MAIN FLOW ---
# ROW 1: Weight Preparation
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  master_weights: {
    shape: sql_table
    label: "FP32 Master Weights (optimizer.h)"
    f0: "0x00 | float32 | param[0]"
    f1: "0x04 | float32 | param[1]"
    f2: "0x08 | float32 | ..."
    fn: "0xN | float32 | param[N]"
    sz: "Total: 4N bytes"
    style.fill: "#3B82F6"
    style.font-color: white
  }
  
  cast_fp16: {
    label: "Cast to FP16"
    shape: diamond
    style.fill: "#F59E0B"
  }
  
  compute_weights: {
    shape: sql_table
    label: "FP16 Compute Weights (model.h)"
    f0: "0x00 | float16 | param[0]"
    f1: "0x02 | float16 | param[1]"
    f2: "0x04 | float16 | ..."
    fn: "0xN | float16 | param[N]"
    sz: "Total: 2N bytes (50% savings)"
    style.fill: "#10B981"
    style.font-color: white
  }
}

# ROW 2: Forward Pass
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  forward_block: {
    direction: down
    forward_label: "Forward Pass" {
      style.fill: "#10B981"
      style.font-color: white
      style.bold: true
    }
    forward_ops: {
      label: "FP16 Computation"
      forward_matmul: "matmul(X, W) -> fp16"
      forward_act: "GELU/ReLU/SiLU -> fp16"
      forward_attn: "Attention(Q,K,V) -> fp16"
      forward_out: "Output logits -> fp16"
    }
  }

  overflow_risk: {
    label: "⚠️ OVERFLOW RISK"
    shape: callout
    style.fill: "#EF4444"
    style.font-color: white
    code: |'c
      // FP16 max: 65504
      // Large activations can overflow!
      float x = 70000.0f;  // -> inf in fp16
    '|
  }
}

# ROW 3: Loss & Scaling
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  loss_box: {
    shape: rectangle
    label: "Compute Loss (CrossEntropy)"
    style.fill: "#10B981"
    style.font-color: white
  }

  loss_value: "Loss approx 2.5 (fp16 range OK)" {
    shape: rectangle
  }

  scale_innovation: {
    direction: down
    scale_label: "LOSS SCALING" {
      style.fill: "#8B5CF6"
      style.font-color: white
      style.bold: true
    }
    scale_op: "scaled_loss = loss * scale" {
      style.fill: "#8B5CF6"
      style.font-color: white
    }
    scale_value: "scale = 65536 (2^16, dynamic)" {
      style.fill: "#EDE9FE"
    }
  }
}

# ROW 4: Backward Pass
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  backward_block: {
    direction: down
    backward_label: "Backward Pass" {
      style.fill: "#10B981"
      style.font-color: white
      style.bold: true
    }
    backward_ops: {
      label: "FP16 Gradient Computation"
      backward_grad: "dL/doutput -> fp16"
      backward_chain: "Chain rule -> fp16"
      backward_param: "dL/dW -> fp16 (scaled!)"
    }
  }

  underflow_prevented: {
    label: "✓ Underflow Prevented"
    shape: callout
    style.fill: "#10B981"
    style.font-color: white
    code: |'c
      // Before scaling (DANGER):
      // grad = 0.00001 -> 0 in fp16
      // After scaling (SAFE):
      // scaled_grad = 0.656 -> preserved
    '|
  }
}

# ROW 5: Unscaling & Gradients
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  unscale_proc: {
    direction: down
    unscale_label: "GRADIENT UNSCALING" {
      style.fill: "#F59E0B"
      style.font-color: white
      style.bold: true
    }
    unscale_op: "grad = grad / scale" {
      style.fill: "#F59E0B"
      style.font-color: white
    }
    cast_fp32_grad: {
      label: "Cast to FP32"
      shape: diamond
      style.fill: "#F59E0B"
    }
  }

  fp32_grad: {
    shape: sql_table
    label: "FP32 Gradients (for optimizer)"
    f0: "0x00 | float32 | dL/dW[0]"
    f1: "0x04 | float32 | dL/dW[1]"
    f2: "0x08 | float32 | ..."
    sz: "Full precision for Adam"
    style.fill: "#3B82F6"
    style.font-color: white
  }
}

# ROW 6: Optimization
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  optim_block: {
    direction: down
    optimizer_label: "Optimizer Step (Adam/AdamW)" {
      style.fill: "#3B82F6"
      style.font-color: white
      style.bold: true
    }
    adam_ops: {
      shape: sql_table
      label: "Adam State (FP32)"
      f0: "m_t = beta1 * m + (1-beta1) * grad"
      f1: "v_t = beta2 * v + (1-beta2) * grad^2"
      f2: "m_hat = m / (1-beta1^t)"
      f3: "v_hat = v / (1-beta2^t)"
      f4: "W = W - lr * m_hat/(sqrt(v_hat) + eps)"
      style.fill: "#3B82F6"
      style.font-color: white
    }
  }

  scale_logic: {
    label: "Dynamic Scale Tracker"
    shape: rectangle
    style.fill: "#EDE9FE"
    code: |'c
      if (overflow_detected) {
        scale /= 2;  // Reduce range
        skip_step();
      } else if (all_finite) {
        scale *= 2;  // Expand range
      }
    '|
  }
}

# --- CONNECTIONS ---
row1.master_weights -> row1.cast_fp16: "0x01 | Cast"
row1.cast_fp16 -> row1.compute_weights: "0x02 | FP16 Weights"
row1.compute_weights -> row2.forward_block: "0x03 | W_fp16"
row2.forward_block -> row3.loss_box: "0x04 | logits"
row3.loss_box -> row3.scale_innovation: "0x05 | loss"
row3.scale_innovation -> row4.backward_block: "0x06 | scaled_loss"
row4.backward_block -> row5.unscale_proc: "0x07 | scaled_grad"
row5.unscale_proc -> row5.fp32_grad: "0x08 | grad_fp32"
row5.fp32_grad -> row6.optim_block: "0x09 | gradients"
row6.optim_block -> row1.master_weights: "0x10 | Weight Update" {
  style.stroke-dash: 3
  style.stroke: "#3B82F6"
}

# Functional hints
row2.overflow_risk -> row2.forward_block: "Check" {
  style.stroke: "#EF4444"
  style.stroke-dash: 3
}
row6.scale_logic -> row3.scale_innovation: "Update Scale" {
  style.stroke: "#8B5CF6"
  style.stroke-dash: 3
}