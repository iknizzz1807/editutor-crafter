direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # 1F1B Pipeline Schedule (4 Stages, 8 Micro-batches)
| {near: top-center}
legend: {
  near: top-right
  label: "Legend"
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  forward: {
    label: "Forward"
    shape: rectangle
    style.fill: "#4dabf7"
    style.stroke: "#228be6"
  }
  backward: {
    label: "Backward"
    shape: rectangle
    style.fill: "#69db7c"
    style.stroke: "#37b24d"
  }
  bubble: {
    label: "Bubble (idle)"
    shape: rectangle
    style.fill: "#ffe066"
    style.stroke: "#fab005"
    style.stroke-dash: 3
  }
  mem_note: {
    label: "Peak memory: activations for\nP=4 micro-batches (not M=8)"
    shape: text
    style.font-size: 11
    style.font-color: "#495057"
  }
  forward -> backward -> bubble -> mem_note: {style.opacity: 0}
}
