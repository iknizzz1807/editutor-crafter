analysis: {
  direction: right
  phases: {
    label: "Schedule Phases"
    shape: rectangle
    style.fill: "#f1f3f5"
    style.stroke: "#adb5bd"
    phase1: {
      label: "1. Warmup\n(P-1=3 forwards)\nFill pipeline"
      shape: rectangle
      style.fill: "#d0ebff"
      style.stroke: "#339af0"
    }
    phase2: {
      label: "2. Steady State\n(1F1B alternation)\nBounded memory"
      shape: rectangle
      style.fill: "#c3fae8"
      style.stroke: "#20c997"
    }
    phase3: {
      label: "3. Cooldown\n(P-1=3 backwards)\nDrain pipeline"
      shape: rectangle
      style.fill: "#fff3bf"
      style.stroke: "#fab005"
    }
    phase1 -> phase2 -> phase3
  }
  comparison: {
    label: "Memory Comparison"
    shape: rectangle
    style.fill: "#f1f3f5"
    style.stroke: "#adb5bd"
    gpipe: {
      label: "GPipe (baseline)"
      shape: rectangle
      style.fill: "#ffc9c9"
      style.stroke: "#f03e3e"
      gpipe_desc: {
        label: |md
          Stores ALL M=8 micro-batch
          activations simultaneously
          Peak memory: O(M)
        |
        shape: text
        style.font-size: 11
      }
    }
    f1b1: {
      label: "1F1B (this schedule)"
      shape: rectangle
      style.fill: "#b2f2bb"
      style.stroke: "#2f9e44"
      f1b1_desc: {
        label: |md
          Stores only P=4 micro-batch
          activations at any time
          Peak memory: O(P)
          **50% memory reduction!**
        |
        shape: text
        style.font-size: 11
        style.font-color: "#2f9e44"
      }
    }
    gpipe -> f1b1: "Improvement"
  }
  formula: {
    label: "Efficiency Analysis"
    shape: rectangle
    style.fill: "#f1f3f5"
    style.stroke: "#adb5bd"
    formula_text: {
      label: |md
        **Bubble Fraction:**
        
        (P-1) / (M + P - 1)
        = 3 / (8 + 3)
        = 27.3%
        
        **vs GPipe:**
        
        2(P-1) / (M + 2(P-1))
        = 6 / (8 + 6)
        = 42.9%
        
        **1F1B reduces bubble by 36%**
      |
      shape: text
      style.font-size: 11
    }
  }
  phases -> comparison -> formula
}