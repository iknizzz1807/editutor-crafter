row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    label: "Legend"
    width: 300
    leg_f: {label: "F = Forward Pass"; shape: rectangle; style.fill: "#4A90E2"}
    leg_b: {label: "B = Backward Pass"; shape: rectangle; style.fill: "#E74C3C"}
    leg_fb: {label: "F/B = Interleaved"; shape: rectangle; style.fill: "#9B59B6"}
    leg_idle: {label: "Idle (Bubble)"; style.fill: "#E0E0E0"}
  }
  metrics: {
    label: "Bubble Fraction"
    width: 350
    m_naive: "Naive (M=1): 75%"
    m_gpipe: "GPipe (M=4): 37.5%"
    m_f1b1: "1F1B (M=4): 37.5%"
    note: |md
      **Formula:** Bubble = 2(P-1) / (M + 2(P-1))
      P = pipeline stages, M = micro-batches
      More micro-batches → smaller bubble
    |
  }
}
naive -> gpipe: "Add micro-batches"
gpipe -> f1b1: "Interleave F/B"