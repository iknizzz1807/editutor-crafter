direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    gpu0: "#4A90D9"
    gpu1: "#7B68EE"
    gpu2: "#50C878"
    gpu3: "#FF6B6B"
    forward: "#E8F4FD"
    backward: "#FFE4E1"
    comm: "#FFF3CD"
  }
}

# --- ROOT TITLE ---
header: {
  label: "Interleaved 1F1B Schedule: Pipeline Parallelism (PP) & Virtual Stages (VP)"
  style: {
    font-size: 28
    bold: true
    stroke: transparent
    fill: transparent
  }
}

# --- SECTION 1: LAYER DISTRIBUTION ---
layer_distribution: {
  label: "Layer Distribution Strategy (Virtual Stages)"
  style.fill: transparent
  style.stroke: "#CBD6E0"
  style.stroke-width: 2
  
  explanation: |'md
    **Key Insight**: Each physical GPU holds non-contiguous "virtual stages" to reduce the pipeline bubble.
    - **GPU 0**: Virtual Stages 0, 4, 8, 12 (Layers [0-3], [16-19]...)
    - **GPU 1**: Virtual Stages 1, 5, 9, 13
    - **GPU 2**: Virtual Stages 2, 6, 10, 14
    - **GPU 3**: Virtual Stages 3, 7, 11, 15
    **Benefit**: 4× more pipeline stages (V=4) results in smaller execution bubbles.
  '|
}

# --- SECTION 2: COMPARISON ---
comparison: {
  label: "Standard vs Interleaved Partitioning"
  style.stroke: transparent
  
  standard: {
    label: "Standard Pipeline (PP=4, V=1)"
    style.fill: "#F8F9FA"
    std_gpu0: "GPU 0: L[0-3]" { style.fill: ${colors.gpu0} }
    std_gpu1: "GPU 1: L[4-7]" { style.fill: ${colors.gpu1} }
    std_gpu2: "GPU 2: L[8-11]" { style.fill: ${colors.gpu2} }
    std_gpu3: "GPU 3: L[12-15]" { style.fill: ${colors.gpu3} }
    std_gpu0 -> std_gpu1: "Activation | seq"
    std_gpu1 -> std_gpu2: "Activation | seq"
    std_gpu2 -> std_gpu3: "Activation | seq"
  }

  interleaved: {
    label: "Interleaved Pipeline (PP=4, V=4 Total stages=16)"
    style.fill: "#F8F9FA"
    il_rows: "" {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      il_col0: {
        direction: down
        label: "GPU 0"
        style.fill: ${colors.gpu0}
        v0: "VS₀" { shape: circle; style.fill: white }
        v4: "VS₄" { shape: circle; style.fill: white }
        v8: "VS₈" { shape: circle; style.fill: white }
        v12: "VS₁₂" { shape: circle; style.fill: white }
      }
      il_col1: {
        direction: down
        label: "GPU 1"
        style.fill: ${colors.gpu1}
        v1: "VS₁" { shape: circle; style.fill: white }
        v5: "VS₅" { shape: circle; style.fill: white }
        v9: "VS₉" { shape: circle; style.fill: white }
        v13: "VS₁₃" { shape: circle; style.fill: white }
      }
      il_col2: {
        direction: down
        label: "GPU 2"
        style.fill: ${colors.gpu2}
        v2: "VS₂" { shape: circle; style.fill: white }
        v6: "VS₆" { shape: circle; style.fill: white }
        v10: "VS₁₀" { shape: circle; style.fill: white }
        v14: "VS₁₄" { shape: circle; style.fill: white }
      }
      il_col3: {
        direction: down
        label: "GPU 3"
        style.fill: ${colors.gpu3}
        v3: "VS₃" { shape: circle; style.fill: white }
        v7: "VS₇" { shape: circle; style.fill: white }
        v11: "VS₁₁" { shape: circle; style.fill: white }
        v15: "VS₁₅" { shape: circle; style.fill: white }
      }
    }
  }
}

# --- SECTION 3: TIMELINE SCHEDULE ---
schedule: {
  label: "Interleaved 1F1B Execution Timeline"
  style.fill: transparent
  style.stroke: "#CBD6E0"
  style.stroke-width: 2
  
  timeline_header: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    time_label: "Time Execution →" {
      style.fill: transparent
      style.bold: true
    }
    t1: "t1" { style.fill: transparent }
    t2: "t2" { style.fill: transparent }
    t3: "t3" { style.fill: transparent }
    t4: "t4" { style.fill: transparent }
  }

  gpu0_timeline: {
    label: "GPU 0"
    style.fill: ${colors.gpu0}
    gpu0_row: "" {
      direction: right
      style.fill: transparent
      g0_f0: "F₀" { style.fill: ${colors.forward}; shape: rectangle }
      g0_f4: "F₄" { style.fill: ${colors.forward}; shape: rectangle }
      g0_f8: "F₈" { style.fill: ${colors.forward}; shape: rectangle }
      g0_f12: "F₁₂" { style.fill: ${colors.forward}; shape: rectangle }
      g0_b12: "B₁₂" { style.fill: ${colors.backward}; shape: rectangle }
      g0_b8: "B₈" { style.fill: ${colors.backward}; shape: rectangle }
      g0_b4: "B₄" { style.fill: ${colors.backward}; shape: rectangle }
      g0_b0: "B₀" { style.fill: ${colors.backward}; shape: rectangle }
    }
  }

  gpu1_timeline: {
    label: "GPU 1"
    style.fill: ${colors.gpu1}
    gpu1_row: "" {
      direction: right
      style.fill: transparent
      g1_recv: "RX" { style.fill: ${colors.comm}; shape: rectangle }
      g1_f1: "F₁" { style.fill: ${colors.forward}; shape: rectangle }
      g1_f5: "F₅" { style.fill: ${colors.forward}; shape: rectangle }
      g1_f9: "F₉" { style.fill: ${colors.forward}; shape: rectangle }
      g1_f13: "F₁₃" { style.fill: ${colors.forward}; shape: rectangle }
      g1_b13: "B₁₃" { style.fill: ${colors.backward}; shape: rectangle }
      g1_b9: "B₉" { style.fill: ${colors.backward}; shape: rectangle }
      g1_b5: "B₅" { style.fill: ${colors.backward}; shape: rectangle }
      g1_b1: "B₁" { style.fill: ${colors.backward}; shape: rectangle }
    }
  }

  gpu2_timeline: {
    label: "GPU 2"
    style.fill: ${colors.gpu2}
    gpu2_row: "" {
      direction: right
      style.fill: transparent
      g2_wait: "..." { style.fill: ${colors.comm}; shape: rectangle }
      g2_f2: "F₂" { style.fill: ${colors.forward}; shape: rectangle }
      g2_f6: "F₆" { style.fill: ${colors.forward}; shape: rectangle }
      g2_f10: "F₁₀" { style.fill: ${colors.forward}; shape: rectangle }
      g2_f14: "F₁₄" { style.fill: ${colors.forward}; shape: rectangle }
      g2_b14: "B₁₄" { style.fill: ${colors.backward}; shape: rectangle }
      g2_b10: "B₁₀" { style.fill: ${colors.backward}; shape: rectangle }
      g2_b6: "B₆" { style.fill: ${colors.backward}; shape: rectangle }
      g2_b2: "B₂" { style.fill: ${colors.backward}; shape: rectangle }
    }
  }

  gpu3_timeline: {
    label: "GPU 3"
    style.fill: ${colors.gpu3}
    gpu3_row: "" {
      direction: right
      style.fill: transparent
      g3_wait: "..." { style.fill: ${colors.comm}; shape: rectangle }
      g3_f3: "F₃" { style.fill: ${colors.forward}; shape: rectangle }
      g3_f7: "F₇" { style.fill: ${colors.forward}; shape: rectangle }
      g3_f11: "F₁₁" { style.fill: ${colors.forward}; shape: rectangle }
      g3_f15: "F₁₅" { style.fill: ${colors.forward}; shape: rectangle }
      g3_b15: "B₁₅" { style.fill: ${colors.backward}; shape: rectangle }
      g3_b11: "B₁₁" { style.fill: ${colors.backward}; shape: rectangle }
      g3_b7: "B₇" { style.fill: ${colors.backward}; shape: rectangle }
      g3_b3: "B₃" { style.fill: ${colors.backward}; shape: rectangle }
    }
  }
}

# --- SECTION 4: COMMUNICATION PATTERN ---
comm_pattern: {
  label: "Communication Pattern Complexity"
  style.fill: transparent
  style.stroke: "#CBD6E0"
  
  comm_explanation: |'md
    **Overhead Trade-off:**
    Standard PP: (P-1) communication events per micro-batch.
    Interleaved: (V × P) - 1 communication events.
    **For Physical P=4, Virtual V=4:**
    - Standard: 3 P2P Transfers
    - Interleaved: 15 P2P Transfers
    **Verdict**: Increased bandwidth requirements, but significantly reduced bubble latency.
  '|

  comm_diagram: {
    label: "Activation Data Flow (Forward Pass)"
    flow: "" {
      direction: right
      style.fill: transparent
      vs0: "VS₀ (GPU0)" { shape: circle; style.fill: ${colors.gpu0} }
      vs1: "VS₁ (GPU1)" { shape: circle; style.fill: ${colors.gpu1} }
      vs2: "VS₂ (GPU2)" { shape: circle; style.fill: ${colors.gpu2} }
      vs3: "VS₃ (GPU3)" { shape: circle; style.fill: ${colors.gpu3} }
      vs4: "VS₄ (GPU0)" { shape: circle; style.fill: ${colors.gpu0} }
      vs5: "VS₅ (GPU1)" { shape: circle; style.fill: ${colors.gpu1} }
      vs0 -> vs1 -> vs2 -> vs3 -> vs4 -> vs5: "Cross-GPU P2P" {
        style.stroke-dash: 2
        style.animated: true
      }
    }
  }
}

# --- SECTION 5: BUBBLE ANALYSIS ---
bubble_analysis: {
  label: "Quantifying the Bubble Reduction"
  style.fill: transparent
  
  analysis_content: |'md
    **Bubble Fraction Analysis (P=4, M=8 Micro-batches):**

    | Schedule Type | Bubble Fraction Formula | Calculation | Efficiency Result |
    | :--- | :--- | :--- | :--- |
    | Standard 1F1B | (P-1) / (M + P - 1) | 3 / 11 | ~27.2% Idle |
    | Interleaved (V=4) | (P-1) / (M*V + P - 1) | 3 / 34 | ~8.8% Idle |

    **Conclusion**: Virtual stages increase effective pipeline depth, scaling bubble size by 1/V.
    **Memory Constraint**: Each GPU stores V× more activation checkpoints, though each stage compute is 1/V the size.
  '|
}

# --- LEGEND & CONNECTIONS ---
legend: {
  label: "Legend"
  style.fill: "#F8F9FA"
  style.stroke: "#CBD6E0"
  
  legend_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    leg_f: "Forward (F)" { style.fill: ${colors.forward} }
    leg_b: "Backward (B)" { style.fill: ${colors.backward} }
    leg_c: "Comm/Sync" { style.fill: ${colors.comm} }
  }
}
legend.near: bottom-right

# Vertical flow arrows
layer_distribution -> comparison
comparison -> schedule
schedule -> comm_pattern
comm_pattern -> bubble_analysis