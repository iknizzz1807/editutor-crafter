# Data flow arrows showing topological dependencies
timeline.s0_t1 -> timeline.s1_t2: "forward" {
  style: {
    stroke: "#1971c2"
    stroke-width: 2
    stroke-dash: 3
  }
}
timeline.s1_t2 -> timeline.s2_t3: "forward" {
  style: {
    stroke: "#1971c2"
    stroke-width: 2
    stroke-dash: 3
  }
}
timeline.s2_t3 -> timeline.s3_t4: "forward" {
  style: {
    stroke: "#1971c2"
    stroke-width: 2
    stroke-dash: 3
  }
}
timeline.s3_t4 -> timeline.s2_t4: "backward" {
  style: {
    stroke: "#c92a2a"
    stroke-width: 2
    stroke-dash: 3
  }
}
timeline.s2_t4 -> timeline.s1_t4: "backward" {
  style: {
    stroke: "#c92a2a"
    stroke-width: 2
    stroke-dash: 3
  }
}
timeline.s1_t4 -> timeline.s0_t4: "backward" {
  style: {
    stroke: "#c92a2a"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Flow Diagram Container
flow_section: {
  label: "Logical Data Flow"
  style: {
    fill: transparent
    stroke: transparent
  }
  direction: right
  flow_diagram: {
    direction: right
    input: {
      label: "Input\nBatch"
      shape: document
      style.fill: "#d0ebff"
      style.stroke: "#1971c2"
    }
    s0_box: {
      label: "Stage 0"
      shape: rectangle
      style.fill: "#4dabf7"
      style.stroke: "#1971c2"
    }
    s1_box: {
      label: "Stage 1"
      shape: rectangle
      style.fill: "#4dabf7"
      style.stroke: "#1971c2"
    }
    s2_box: {
      label: "Stage 2"
      shape: rectangle
      style.fill: "#4dabf7"
      style.stroke: "#1971c2"
    }
    s3_box: {
      label: "Stage 3"
      shape: rectangle
      style.fill: "#4dabf7"
      style.stroke: "#1971c2"
    }
    output: {
      label: "Loss"
      shape: circle
      style.fill: "#ff8787"
      style.stroke: "#c92a2a"
    }
    input -> s0_box: "send" {
      style.stroke: "#fab005"
      style.stroke-width: 2
    }
    s0_box -> s1_box: "activations" {
      style.stroke: "#fab005"
      style.stroke-width: 2
    }
    s1_box -> s2_box: "activations" {
      style.stroke: "#fab005"
      style.stroke-width: 2
    }
    s2_box -> s3_box: "activations" {
      style.stroke: "#fab005"
      style.stroke-width: 2
    }
    s3_box -> output: "loss" {
      style.stroke: "#c92a2a"
      style.stroke-width: 2
    }
  }
}

# Bubble Analysis Container
analysis: {
  label: "Pipeline Bubble Analysis"
  style: {
    fill: "#fff9db"
    stroke: "#fab005"
    stroke-width: 2
    border-radius: 8
  }
  formula_box: {
    label: "Bubble Fraction Formula"
    style: {
      fill: "#fff3bf"
      stroke: "#fab005"
      border-radius: 4
    }
    formula: |md
      **For P stages and M micro-batches:**
      
      Bubble Fraction = 2 × (P - 1) / (M + 2 × (P - 1))
      
      With **P = 4** stages and **M = 1** micro-batch:
      
      Bubble = 2 × (4 - 1) / (1 + 2 × (4 - 1))
             = 6 / 7
             = 85.7%
    |
  }
  utilization_box: {
    label: "GPU Utilization"
    style: {
      fill: "#ffe3e3"
      stroke: "#c92a2a"
      border-radius: 4
    }
    utilization: |md
      **Per-Stage Active Time:**
      - Forward: 1 unit, Backward: 1 unit
      - **Total active: 2 units**
      **Total Timeline: 4 units**
      **Utilization = 2 / 4 = 50%**
      ⚠️ **3/4 GPUs are idle at any time.**
    |
  }
  problem_box: {
    label: "The Problem"
    style: {
      fill: "#ffe3e3"
      stroke: "#c92a2a"
      border-radius: 4
    }
    problem: |md
      **Why This Is Suboptimal:**
      1. **Sequential dependency**: Stages wait for the predecessor.
      2. **No parallelism**: Only one stage computes at a time.
      3. **Waste**: Paying for 4 GPUs, getting 1 GPU worth of throughput.
      **Solution**: Micro-batching.
    |
  }
  formula_box -> utilization_box -> problem_box
}

# Implementation Details
memory_note: {
  label: "Memory Consideration"
  style: {
    fill: "#d3f9d8"
    stroke: "#2f9e44"
    border-radius: 8
  }
  note: |md
    Even with naive scheduling, each stage must store **activations** 
    for the backward pass.
    For a 70B model with batch=8, seq=4096:
    - Activations per stage: ~4 GB
    - Must persist until backward pass completes.
  |
}