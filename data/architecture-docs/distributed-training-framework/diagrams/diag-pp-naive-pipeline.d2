direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Naive Pipeline Execution (4 Stages, 1 Micro-batch)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Legend
legend: {
  near: top-right
  style: {
    fill: "#f8f9fa"
    stroke: "#dee2e6"
    stroke-width: 1
    border-radius: 8
  }
  forward: {
    label: "Forward Pass"
    style.fill: "#4dabf7"
    style.stroke: "#1971c2"
  }
  backward: {
    label: "Backward Pass"
    style.fill: "#ff8787"
    style.stroke: "#c92a2a"
  }
  idle: {
    label: "Idle (Bubble)"
    style.fill: "#e9ecef"
    style.stroke: "#adb5bd"
    style.stroke-dash: 3
  }
  comm: {
    label: "Communication"
    style.fill: "#ffd43b"
    style.stroke: "#fab005"
  }
}

