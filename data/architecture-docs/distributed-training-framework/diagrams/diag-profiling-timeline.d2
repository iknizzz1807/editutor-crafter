direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    compute: "#4CAF50"
    communication: "#2196F3"
    idle: "#FFC107"
    straggler: "#F44336"
    overlap: "#9C27B0"
  }
}

title: |md
  # Distributed Profiling Timeline
  ## Identifying Bottlenecks Across 8 GPUs
|
title.near: top-center

# Legend - Positioned at Root
legend: {
  label: "Legend"
  compute_legend: "Compute Time" {style.fill: "#4CAF50"}
  comm_legend: "Communication" {style.fill: "#2196F3"}
  idle_legend: "Idle (waiting)" {style.fill: "#FFC107"}
  straggler_legend: "Straggler Delay" {style.fill: "#F44336"}
  overlap_legend: "Overlap (optimal)" {style.fill: "#9C27B0"}
}
legend.near: top-right

# Timeline Section
timelines: {
  label: "Step Timeline (100ms total)"
  
  gpu0: {
    label: "GPU 0 (Normal)"
    direction: right
    style.stroke: "#333"
    fwd: { width: 120; height: 30; style.fill: "#4CAF50"; label: "Fwd" }
    bwd: { width: 180; height: 30; style.fill: "#4CAF50"; label: "Bwd" }
    comm: { width: 150; height: 30; style.fill: "#2196F3"; label: "AllReduce" }
    idle: { width: 30; height: 30; style.fill: "#FFC107"; label: "Wait" }
  }
  
  gpu1: {
    label: "GPU 1 (Normal)"
    direction: right
    style.stroke: "#333"
    fwd: { width: 120; height: 30; style.fill: "#4CAF50"; label: "Fwd" }
    bwd: { width: 180; height: 30; style.fill: "#4CAF50"; label: "Bwd" }
    comm: { width: 150; height: 30; style.fill: "#2196F3"; label: "AllReduce" }
    idle: { width: 30; height: 30; style.fill: "#FFC107"; label: "Wait" }
  }

  gpu3: {
    label: "GPU 3 (STRAGGLER)"
    direction: right
    style.stroke: "#F44336"
    style.stroke-width: 4
    fwd: { width: 120; height: 30; style.fill: "#4CAF50"; label: "Fwd" }
    bwd: { width: 280; height: 30; style.fill: "#F44336"; label: "Slow Bwd" }
    comm: { width: 150; height: 30; style.fill: "#2196F3"; label: "AllReduce" }
  }

  gpu_others: {
    label: "GPU 4-7 (Waiting for GPU 3)"
    direction: right
    style.stroke: "#333"
    fwd: { width: 120; height: 30; style.fill: "#4CAF50"; label: "Fwd" }
    bwd: { width: 180; height: 30; style.fill: "#4CAF50"; label: "Bwd" }
    idle: { width: 100; height: 30; style.fill: "#FFC107"; label: "Straggler Idle" }
    comm: { width: 150; height: 30; style.fill: "#2196F3"; label: "AllReduce" }
  }
}

# Time axis
time_axis: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t0: "0ms" { shape: oval }
  t25: "25ms" { shape: oval }
  t50: "50ms" { shape: oval }
  t75: "75ms" { shape: oval }
  t100: "100ms" { shape: oval }
  t0 -> t25 -> t50 -> t75 -> t100
}

# Analysis Section
analysis: {
  label: "Bottleneck Analysis"
  direction: right
  style.stroke: transparent
  style.fill: transparent

  timing_breakdown: {
    shape: sql_table
    label: "Per-GPU Timing Breakdown (ms)"
    col1: "GPU | Forward | Backward | All-Reduce | Idle | Total"
    row0: "GPU 0 | 20 | 30 | 25 | 5 | 80"
    row1: "GPU 1 | 20 | 30 | 25 | 5 | 80"
    row2: "GPU 2 | 20 | 30 | 25 | 5 | 80"
    row3: "GPU 3 | 20 | 45 | 25 | 20 | 110"
    row4: "GPU 4-7 | 20 | 30 | 25 | 25 | 100"
    total: "Avg Efficiency: 72.7%"
  }

  bottleneck_metrics: {
    shape: class
    label: "Bottleneck Metrics"
    +compute_time: "33ms (33%)"
    +comm_time: "25ms (25%)"
    +idle_time: "25ms (25%)"
    +straggler_overhead: "17ms (17%)"
    -efficiency: "75% (Target: >90%)"
    -root_cause: "GPU 3 Thermal Throttling"
  }
}

# Detection Flow
detection_flow: {
  label: "Automated Detection Process"
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: {
    label: "1. Collect Timings"
    code: |'python
      # Record kernel execution durations
      fwd_t = measure(model.forward)
      bwd_t = measure(model.backward)
      comm_t = measure(dist.all_reduce)
    '|
    width: 350
  }
  step2: {
    label: "2. All-Gather Metrics"
    code: |'python
      # Synchronize stats across cluster
      stats = [None] * world_size
      dist.all_gather_object(stats, local_t)
      median = np.median(stats)
    '|
    width: 350
  }
  step3: {
    label: "3. Detect Anomalies"
    code: |'python
      # Outlier detection (IQR or Z-Score)
      is_straggler = local_t > 1.5 * median
      if is_straggler:
          log_anomaly(rank, local_t)
    '|
    width: 350
  }
  step4: {
    label: "4. Classification"
    code: |'python
      if comm > compute:
          return "COMM_BOUND"
      if idle > 0.2 * total:
          return "STRAGGLER_WAIT"
      return "HEALTHY"
    '|
    width: 350
  }
  step1 -> step2 -> step3 -> step4
}

# Remediation Section
remediation: {
  label: "Remediation & Mitigation"
  direction: right
  style.stroke: transparent
  style.fill: transparent

  strategies: {
    shape: sql_table
    label: "Strategy Matrix"
    header: "Bottleneck | Symptom | Remedy"
    comm: "Communication | High Comm/Comp | TP Reduction / Quantization"
    straggler: "Straggler | Timing Outliers | Elastic Rank Exclusion"
    memory: "Memory | OOM / Spill | ZeRO-3 / Activation Checkpoint"
    load: "Load | Imbalance | Micro-batch Re-partitioning"
  }

  straggler_actions: {
    shape: class
    label: "Straggler Mitigation API"
    +detect_outlier(threshold): "bool"
    +compress_grads(method): "void"
    +exclude_rank(rank_id): "ElasticStatus"
    +rebalance_load(): "Plan"
  }
}

# Heatmap Visualization
heatmap: {
  label: "GPU Timing Heatmap (8 GPUs × 10 Steps)"
  
  heatmap_grid: {
    label: "Execution Steps (Left to Right)"
    grid-columns: 10
    grid-gap: 4
    
    # GPU 0 (Consistent Green)
    c00: "" {style.fill: "#4CAF50"}
    c01: "" {style.fill: "#4CAF50"}
    c02: "" {style.fill: "#4CAF50"}
    c03: "" {style.fill: "#4CAF50"}
    c04: "" {style.fill: "#4CAF50"}
    c05: "" {style.fill: "#4CAF50"}
    c06: "" {style.fill: "#4CAF50"}
    c07: "" {style.fill: "#4CAF50"}
    c08: "" {style.fill: "#4CAF50"}
    c09: "" {style.fill: "#4CAF50"}

    # GPU 3 (Straggler - Red Hotspots)
    c30: "" {style.fill: "#F44336"}
    c31: "" {style.fill: "#4CAF50"}
    c32: "" {style.fill: "#F44336"}
    c33: "" {style.fill: "#F44336"}
    c34: "" {style.fill: "#4CAF50"}
    c35: "" {style.fill: "#F44336"}
    c36: "" {style.fill: "#4CAF50"}
    c37: "" {style.fill: "#F44336"}
    c38: "" {style.fill: "#F44336"}
    c39: "" {style.fill: "#F44336"}
    
    # GPU 7 (Normal)
    c70: "" {style.fill: "#4CAF50"}
    c71: "" {style.fill: "#4CAF50"}
    c72: "" {style.fill: "#4CAF50"}
    c73: "" {style.fill: "#4CAF50"}
    c74: "" {style.fill: "#4CAF50"}
    c75: "" {style.fill: "#4CAF50"}
    c76: "" {style.fill: "#4CAF50"}
    c77: "" {style.fill: "#4CAF50"}
    c78: "" {style.fill: "#4CAF50"}
    c79: "" {style.fill: "#4CAF50"}
  }
}

# Note moved to Root to satisfy Rule G
heatmap_note: |md
  **Anomaly Heatmap Interpretation**:
  - **Green Cells**: Target throughput reached (80ms/step).
  - **Red Cells**: GPU 3 exhibits sporadic "Heat Spikes" (>110ms).
  - **Inference**: Root cause is hardware-level (likely thermal throttling on Rank 3).
|
heatmap_note.near: bottom-center

# Higher Level Flow Connections
timelines -> analysis: "Metric Aggregation"
analysis -> detection_flow: "Anomaly Engine"
detection_flow -> remediation: "Policy Dispatch"
remediation -> heatmap: "State Update"