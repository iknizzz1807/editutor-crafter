direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    node-bg: "#F8FAFC"
    node-stroke: "#CBD5E1"
    tp-fill: "#DBEAFE"
    tp-stroke: "#3B82F6"
    pp-fill: "#FEF3C7"
    pp-stroke: "#F59E0B"
    dp-fill: "#D1FAE5"
    dp-stroke: "#10B981"
    gpu-fill: "#F1F5F9"
    gpu-stroke: "#64748B"
    comm-tp: "#2563EB"
    comm-pp: "#D97706"
    comm-dp: "#059669"
  }
}

title: |md
  # 3D Parallelism: DP × TP × PP Architecture
  Process Grid Mapping to Cluster Topology
| {near: top-center}

legend: {
  near: bottom-right
  grid-columns: 1
  style.fill: white
  style.stroke: "#E2E8F0"
  style.stroke-width: 2
  header: "Communication Patterns" {
    style.fill: "${colors.node-bg}"
    style.bold: true
  }
  tp-legend: "TP: All-Reduce (NVLink)" {
    style.fill: "${colors.tp-fill}"
    style.stroke: "${colors.comm-tp}"
    style.stroke-width: 3
  }
  pp-legend: "PP: Send/Recv (InfiniBand)" {
    style.fill: "${colors.pp-fill}"
    style.stroke: "${colors.comm-pp}"
    style.stroke-width: 3
    style.stroke-dash: 4
  }
  dp-legend: "DP: All-Reduce (InfiniBand)" {
    style.fill: "${colors.dp-fill}"
    style.stroke: "${colors.comm-dp}"
    style.stroke-width: 3
  }
}

dimensions: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  dim-label: "3D Process Grid Dimensions" {
    style.fill: "${colors.node-bg}"
    style.stroke: "${colors.node-stroke}"
    style.bold: true
    width: 350
  }
  dp-dim: "DP (Data Parallel): Batch replication" {
    width: 350
  }
  tp-dim: "TP (Tensor Parallel): Layer sharding (NVLink)" {
    width: 350
  }
  pp-dim: "PP (Pipeline Parallel): Stage partitioning" {
    width: 350
  }
}

cluster: "GPU Cluster: 4 Nodes × 8 GPUs = 32 GPUs" {
  style.fill: "${colors.node-bg}"
  style.stroke: "${colors.node-stroke}"
  style.stroke-width: 2
  direction: down
  
  row1: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    
    node0: "Node 0 (NVLink Domain)" {
      direction: down
      style.fill: white
      style.stroke: "${colors.node-stroke}"
      style.stroke-width: 2
      node0-header: "TP Group 0" {
        style.fill: "${colors.tp-fill}"
        style.stroke: "${colors.tp-stroke}"
        style.bold: true
      }
      node0-gpus: "" {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        gpu0: "GPU 0\nDP=0\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu1: "GPU 1\nDP=0\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu2: "GPU 2\nDP=0\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu3: "GPU 3\nDP=0\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
      }
      gpu0 -- gpu1 -- gpu2 -- gpu3: {
        style.stroke: "${colors.comm-tp}"
        style.stroke-width: 3
        label: "All-Reduce"
      }
    }
    
    node1: "Node 1 (NVLink Domain)" {
      direction: down
      style.fill: white
      style.stroke: "${colors.node-stroke}"
      style.stroke-width: 2
      node1-header: "TP Group 1" {
        style.fill: "${colors.tp-fill}"
        style.stroke: "${colors.tp-stroke}"
        style.bold: true
      }
      node1-gpus: "" {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        gpu4: "GPU 4\nDP=0\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu5: "GPU 5\nDP=0\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu6: "GPU 6\nDP=0\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu7: "GPU 7\nDP=0\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
      }
      gpu4 -- gpu5 -- gpu6 -- gpu7: {
        style.stroke: "${colors.comm-tp}"
        style.stroke-width: 3
        label: "All-Reduce"
      }
    }
  }

  pp-arrow-0-1: node0.node0-gpus.gpu2 -> node1.node1-gpus.gpu6: {
    label: "PP Stage 0→1"
    style.stroke: "${colors.comm-pp}"
    style.stroke-width: 3
    style.stroke-dash: 4
  }

  row2: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    
    node2: "Node 2 (NVLink Domain)" {
      direction: down
      style.fill: white
      style.stroke: "${colors.node-stroke}"
      style.stroke-width: 2
      node2-header: "TP Group 2" {
        style.fill: "${colors.tp-fill}"
        style.stroke: "${colors.tp-stroke}"
        style.bold: true
      }
      node2-gpus: "" {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        gpu8: "GPU 8\nDP=1\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu9: "GPU 9\nDP=1\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu10: "GPU 10\nDP=1\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu11: "GPU 11\nDP=1\nPP=0" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
      }
      gpu8 -- gpu9 -- gpu10 -- gpu11: {
        style.stroke: "${colors.comm-tp}"
        style.stroke-width: 3
        label: "All-Reduce"
      }
    }
    
    node3: "Node 3 (NVLink Domain)" {
      direction: down
      style.fill: white
      style.stroke: "${colors.node-stroke}"
      style.stroke-width: 2
      node3-header: "TP Group 3" {
        style.fill: "${colors.tp-fill}"
        style.stroke: "${colors.tp-stroke}"
        style.bold: true
      }
      node3-gpus: "" {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        gpu12: "GPU 12\nDP=1\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu13: "GPU 13\nDP=1\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu14: "GPU 14\nDP=1\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
        gpu15: "GPU 15\nDP=1\nPP=1" {
          shape: rectangle
          style.fill: "${colors.gpu-fill}"
          style.stroke: "${colors.gpu-stroke}"
          width: 70
        }
      }
      gpu12 -- gpu13 -- gpu14 -- gpu15: {
        style.stroke: "${colors.comm-tp}"
        style.stroke-width: 3
        label: "All-Reduce"
      }
    }
  }

  pp-arrow-2-3: node2.node2-gpus.gpu10 -> node3.node3-gpus.gpu14: {
    label: "PP Stage 0→1"
    style.stroke: "${colors.comm-pp}"
    style.stroke-width: 3
    style.stroke-dash: 4
  }

  dp-vertical: node0.node0-gpus.gpu1 -> node2.node2-gpus.gpu9: {
    label: "DP Group Sync"
    style.stroke: "${colors.comm-dp}"
    style.stroke-width: 3
  }
  dp-vertical2: node1.node1-gpus.gpu5 -> node3.node3-gpus.gpu13: {
    style.stroke: "${colors.comm-dp}"
    style.stroke-width: 3
  }
}

process-grid: "3D Process Grid: rank = dp × (PP × TP) + pp × TP + tp" {
  direction: down
  style.fill: white
  style.stroke: "${colors.node-stroke}"
  style.stroke-width: 2
  grid-title: "Process Group Assignment (DP=2, PP=2, TP=4)" {
    style.fill: "${colors.node-bg}"
    style.bold: true
  }
  grid-visual: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    dp0-slice: "DP=0 Slice" {
      direction: down
      style.fill: "${colors.dp-fill}"
      style.stroke: "${colors.dp-stroke}"
      dp0-pp0: "PP=0, TP=[0-3]" {
        style.fill: "${colors.pp-fill}"
        style.stroke: "${colors.pp-stroke}"
      }
      dp0-pp1: "PP=1, TP=[0-3]" {
        style.fill: "${colors.pp-fill}"
        style.stroke: "${colors.pp-stroke}"
      }
      dp0-pp0 -> dp0-pp1: "PP flow" {
        style.stroke: "${colors.comm-pp}"
        style.stroke-dash: 4
      }
    }
    dp1-slice: "DP=1 Slice" {
      direction: down
      style.fill: "${colors.dp-fill}"
      style.stroke: "${colors.dp-stroke}"
      dp1-pp0: "PP=0, TP=[0-3]" {
        style.fill: "${colors.pp-fill}"
        style.stroke: "${colors.pp-stroke}"
      }
      dp1-pp1: "PP=1, TP=[0-3]" {
        style.fill: "${colors.pp-fill}"
        style.stroke: "${colors.pp-stroke}"
      }
      dp1-pp0 -> dp1-pp1: "PP flow" {
        style.stroke: "${colors.comm-pp}"
        style.stroke-dash: 4
      }
    }
    dp0-slice -> dp1-slice: "DP gradient sync" {
      style.stroke: "${colors.comm-dp}"
    }
  }
}

bandwidth-table: {
  shape: sql_table
  label: "Communication Bandwidth Requirements (distributed.h)"
  row1: "TP All-Reduce | Every layer | batch x seq x hidden | NVLink (~300 GB/s)"
  row2: "PP Send/Recv | Every micro-batch | batch x seq x hidden | IB (~12 GB/s)"
  row3: "DP All-Reduce | Every step | model params | IB (~12 GB/s)"
  note: "Key: TP requires NVLink within node, PP/DP tolerate inter-node"
}