direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Scaling Efficiency vs GPU Count {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
title.near: top-center

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  
  graph_7b: {
    label: "7B Model (14GB gradients)"
    style.stroke-width: 2
    
    chart_area: {
      style.fill: transparent
      style.stroke: "#E0E0E0"
      
      ideal_line: "Ideal (100%)" {
        width: 350
        height: 240
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        style.stroke-width: 3
        style.stroke-dash: 5
      }
      
      actual_line: "Actual Efficiency" {
        width: 320
        height: 180
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        style.stroke-width: 3
      }
      
      target90: "90% Target" {
        width: 280
        height: 40
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
        style.font-color: "#1565C0"
      }
    }
    
    x_axis: "GPU Count: 1  2  4  8  16  32  64" {
      shape: text
      style.font: mono
    }
  }

  graph_70b: {
    label: "70B Model (140GB gradients)"
    style.stroke-width: 2
    
    chart_area: {
      style.fill: transparent
      style.stroke: "#E0E0E0"
      
      ideal_line: "Ideal (100%)" {
        width: 350
        height: 240
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        style.stroke-width: 3
        style.stroke-dash: 5
      }
      
      actual_line: "Actual Efficiency" {
        width: 280
        height: 140
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        style.stroke-width: 3
      }
      
      target90: "90% Target" {
        width: 280
        height: 40
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
        style.font-color: "#1565C0"
      }
    }
    
    x_axis: "GPU Count: 1  2  4  8  16  32  64" {
      shape: text
      style.font: mono
    }
  }

  graph_175b: {
    label: "175B Model (350GB gradients)"
    style.stroke-width: 2
    
    chart_area: {
      style.fill: transparent
      style.stroke: "#E0E0E0"
      
      ideal_line: "Ideal (100%)" {
        width: 350
        height: 240
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        style.stroke-width: 3
        style.stroke-dash: 5
      }
      
      actual_line: "Actual Efficiency" {
        width: 200
        height: 100
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        style.stroke-width: 3
      }
      
      target90: "90% Target" {
        width: 280
        height: 40
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
        style.font-color: "#1565C0"
      }
    }
    
    x_axis: "GPU Count: 1  2  4  8  16  32  64" {
