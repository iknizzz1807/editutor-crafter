direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    gpu0: "#E8F5E9"
    gpu1: "#E3F2FD"
    gpu2: "#FFF3E0"
    gpu3: "#FCE4EC"
    attention: "#FF6B6B"
    communication: "#4ECDC4"
    sequence: "#45B7D1"
  }
}

title: |md
  # Sequence Parallelism for Long Sequences
  **Ring Attention: Sharding Along Sequence Dimension**
|
title.near: top-center

row_memory_problem: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  memory_problem: {
    label: "Memory Problem: Activations Don't Fit"
    width: 380
    problem_desc: |'md
      For 128K+ token contexts:
      - Full sequence activations: **64GB+**
      - Attention scores alone: seq² × heads × 2 bytes
      - 128K × 128K × 32 × 2 = **1 TB** per layer!
      **Solution**: Shard sequence across GPUs
    '|
    style.fill: "#FFEBEE"
    style.stroke: "#EF5350"
  }

  sequence_view: {
    label: "Full Sequence (128K tokens)"
    width: 400
    seq_full: {
      shape: rectangle
      label: "Seq[0:128K] | Full sequence on 1 GPU = OOM"
      width: 360
      height: 30
      style.fill: ${colors.sequence}
      style.stroke: "#1976D2"
    }
  }
}

row_sharding: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  sharding_title: {
    label: "Sequence Sharding Strategy"
    width: 380
    shard_desc: |'md
      **Each GPU holds seq_len/P tokens:**
      - GPU 0: tokens [0:32K]
      - GPU 1: tokens [32K:64K]  
      - GPU 2: tokens [64K:96K]
      - GPU 3: tokens [96K:128K]
      Memory per GPU: **1/P of total**
    '|
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }

  sharded_sequence: {
    label: "Sharded Sequence (4 GPUs)"
    direction: right
    width: 420
    shard0: {
      label: "GPU 0\n[0:32K]"
      width: 90
      height: 60
      style.fill: ${colors.gpu0}
      style.stroke: "#2E7D32"
    }
    shard1: {
      label: "GPU 1\n[32K:64K]"
      width: 90
      height: 60
      style.fill: ${colors.gpu1}
      style.stroke: "#1565C0"
    }
    shard2: {
      label: "GPU 2\n[64K:96K]"
      width: 90
      height: 60
      style.fill: ${colors.gpu2}
      style.stroke: "#E65100"
    }
    shard3: {
      label: "GPU 3\n[96K:128K]"
      width: 90
      height: 60
      style.fill: ${colors.gpu3}
      style.stroke: "#C2185B"
    }
  }
}

row_ring: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ring_title: {
    label: "Ring Attention Communication"
    width: 380
    ring_desc: |'md
      **Challenge**: Each GPU needs to compute
      attention for ALL K,V pairs, but only
      has 1/P of the sequence.
      **Ring Pattern**:
      1. Each GPU computes local Q × local K
      2. Rotate K,V blocks around the ring
      3. After P steps, all pairs computed
      4. Communication: **O(seq/P)** per step
    '|
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }

  ring_diagram: {
    label: "Ring Topology"
    width: 420
    height: 300
    gpu_ring_0: {
      label: "GPU 0\nQ₀, K₀, V₀"
      shape: circle
      width: 80
      style.fill: ${colors.gpu0}
      style.stroke: "#2E7D32"
      style.stroke-width: 3
    }
    gpu_ring_1: {
      label: "GPU 1\nQ₁, K₁, V₁"
      shape: circle
      width: 80
      style.fill: ${colors.gpu1}
      style.stroke: "#1565C0"
      style.stroke-width: 3
    }
    gpu_ring_2: {
      label: "GPU 2\nQ₂, K₂, V₂"
      shape: circle
      width: 80
      style.fill: ${colors.gpu2}
      style.stroke: "#E65100"
      style.stroke-width: 3
    }
    gpu_ring_3: {
      label: "GPU 3\nQ₃, K₃, V₃"
      shape: circle
      width: 80
      style.fill: ${colors.gpu3}
      style.stroke: "#C2185B"
      style.stroke-width: 3
    }
    gpu_ring_0 -> gpu_ring_1: "K,V rotate" {
      style.stroke: ${colors.communication}
      style.stroke-width: 2
      style.animated: true
    }
    gpu_ring_1 -> gpu_ring_2: "K,V rotate" {
      style.stroke: ${colors.communication}
      style.stroke-width: 2
      style.animated: true
    }
    gpu_ring_2 -> gpu_ring_3: "K,V rotate" {
      style.stroke: ${colors.communication}
      style.stroke-width: 2
      style.animated: true
    }
    gpu_ring_3 -> gpu_ring_0: "K,V rotate" {
      style.stroke: ${colors.communication}
      style.stroke-width: 2
      style.animated: true
    }
  }
}

row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  timeline_title: {
    label: "Ring Attention Timeline"
    width: 380
    timeline_desc: |'md
      **Step-by-step execution (P=4):**
      | Step | GPU 0 computes | K,V from |
      |------|----------------|----------|
      | 0    | Q₀ × K₀        | local    |
      | 1    | Q₀ × K₃        | GPU 3    |
      | 2    | Q₀ × K₂        | GPU 2    |
      | 3    | Q₀ × K₁        | GPU 1    |
      After P steps: **Complete attention**
      Total communication: P × (seq/P × hidden)
    '|
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
  }

  timeline_vis: {
    label: "Execution Timeline"
    width: 420
    step0: {
      label: "Step 0: Local Attention"
      direction: right
      style.stroke: transparent
      gpu0_s0: { label: "Q₀K₀ᵀ"; width: 85; style.fill: ${colors.gpu0} }
      gpu1_s0: { label: "Q₁K₁ᵀ"; width: 85; style.fill: ${colors.gpu1} }
      gpu2_s0: { label: "Q₂K₂ᵀ"; width: 85; style.fill: ${colors.gpu2} }
      gpu3_s0: { label: "Q₃K₃ᵀ"; width: 85; style.fill: ${colors.gpu3} }
    }
    step1: {
      label: "Step 1: 1st Rotation"
      direction: right
      style.stroke: transparent
      gpu0_s1: { label: "Q₀K₃ᵀ"; width: 85; style.fill: ${colors.gpu0} }
      gpu1_s1: { label: "Q₁K₀ᵀ"; width: 85; style.fill: ${colors.gpu1} }
      gpu2_s1: { label: "Q₂K₁ᵀ"; width: 85; style.fill: ${colors.gpu2} }
      gpu3_s1: { label: "Q₃K₂ᵀ"; width: 85; style.fill: ${colors.gpu3} }
    }
    step2: {
      label: "Step 2: 2nd Rotation"
      direction: right
      style.stroke: transparent
      gpu0_s2: { label: "Q₀K₂ᵀ"; width: 85; style.fill: ${colors.gpu0} }
      gpu1_s2: { label: "Q₁K₃ᵀ"; width: 85; style.fill: ${colors.gpu1} }
      gpu2_s2: { label: "Q₂K₀ᵀ"; width: 85; style.fill: ${colors.gpu2} }
      gpu3_s2: { label: "Q₃K₁ᵀ"; width: 85; style.fill: ${colors.gpu3} }
    }
    step3: {
      label: "Step 3: Complete!"
      direction: right
      style.stroke: transparent
      gpu0_s3: { label: "Q₀K₁ᵀ ✓"; width: 85; style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
      gpu1_s3: { label: "Q₁K₂ᵀ ✓"; width: 85; style.fill: "#BBDEFB"; style.stroke: "#1565C0" }
      gpu2_s3: { label: "Q₂K₃ᵀ ✓"; width: 85; style.fill: "#FFE0B2"; style.stroke: "#E65100" }
      gpu3_s3: { label: "Q₃K₀ᵀ ✓"; width: 85; style.fill: "#F8BBD9"; style.stroke: "#C2185B" }
    }
    step0 -> step1 -> step2 -> step3: "rotate" {
      style.stroke: ${colors.communication}
      style.stroke-dash: 3
    }
  }
}

row_math: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  complexity: {
    label: "Complexity Analysis"
    width: 380
    math_desc: |'md
      **Memory per GPU:**
      - Activations: O(seq × hidden / P)
      - Attention scores: O(seq² / P)
      **Communication per step:**
      - K,V transfer: O(seq/P × hidden)
      - Total: P × O(seq/P × hidden) = O(seq × hidden)
      **Key insight**: Total communication is
      **independent of P** (same as full sequence)
    '|
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }

  benefits: {
    label: "Benefits of Sequence Parallelism"
    width: 420
    benefit_list: |'md
      **✓ Enables 128K+ context training**
      - Full sequence would OOM on any GPU
      **✓ Linear memory scaling with P**
      - Double GPUs → half memory per GPU
      **✓ Combines with Tensor Parallelism**
      - Orthogonal dimensions sharded
      **✓ Overlaps compute/communication**
      - While computing Q×Kᵢ, receiving Kᵢ₊₁
    '|
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}

row_integration: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  integration: {
    label: "Integration with 3D Parallelism"
    width: 380
    int_desc: |'md
      **Where Sequence Parallelism (SP) fits:**
      
      - Data Parallel (DP): Batch sharding
      - Tensor Parallel (TP): Hidden sharding
      - Pipeline Parallel (PP): Layer sharding
      - Sequence Parallel (SP): Sequence sharding
      
      **128K context configuration:**
      TP=8, SP=8, PP=4, DP=4
    '|
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
  }

  code_example: {
    label: "Ring Attention Forward"
    width: 420
    code: |'python
    def ring_attention(Q, K, V, ring_rank, ring_size):
        output = torch.zeros_like(Q)
        scale = 1.0 / math.sqrt(Q.size(-1))
        for step in range(ring_size):
            # Compute partial attention
            scores = torch.matmul(Q, K.transpose(-2, -1)) * scale
            attn = F.softmax(scores, dim=-1)
            output += torch.matmul(attn, V)
            # Send K,V to next GPU
            if step < ring_size - 1:
                K = rotate_tensor(K)
                V = rotate_tensor(V)
        return output
    '|
    style.fill: "#263238"
    style.font-color: "#ECEFF1"
  }
}

row_memory_summary: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  memory_table: {
    shape: sql_table
    label: "Attention Memory Comparison (128K context)"
    header: "Metric | Standard | TP=8 | SP=8 | TP8+SP8"
    activations: "Activations | 64 GB | 8 GB | 8 GB | 1 GB"
    scores: "Scores | 2048 GB | 256 GB | 32 GB | 4 GB"
    total: "Total | 2112 GB | 264 GB | 40 GB | 5 GB"
  }

  key_insight: {
    label: "Scaling Analysis"
    width: 420
    insight: |'md
      **Attention scores scale O(seq²)**
      For 128K sequence:
      - 128K × 128K = 16B elements per head
      - With SP=8: (128K/8) × 128K = 2B elements
      - **8× reduction in local score memory**
      SP is more effective than TP for long-context
      memory management.
    '|
    style.fill: "#FFF8E1"
    style.stroke: "#F9A825"
    style.stroke-width: 2
  }
}

row_memory_problem -> row_sharding: "Problem → Solution"
row_sharding -> row_ring: "Comm Pattern"
row_ring -> row_timeline: "Execution"
row_timeline -> row_math: "Analysis"
row_math -> row_integration: "Architecture"
row_integration -> row_memory_summary: "Impact"