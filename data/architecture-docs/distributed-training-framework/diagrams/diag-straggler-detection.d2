        r7_8: "" { class: cell_light_green }
        r7_9: "" { class: cell_green }
        r7_10: "" { class: cell_green }
      }
    }
    
    straggler_callout: {
      label: "⚠️ STRAGGLER: Rank 4\nHigh Heat / Thermal Trip"
      shape: callout
      style.fill: "#fef3c7"
      style.stroke: "#f59e0b"
      style.font-color: "#92400e"
    }
    straggler_callout -> heatmap_container.grid.r4_5: "critical stall"
  }

  legend_section: {
    direction: down
    label: "Latency (ms)"
    legend_bar: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      l1: "50" { class: cell_green }
      l2: "75" { class: cell_light_green }
      l3: "100" { class: cell_yellow }
      l4: "125" { class: cell_orange }
      l5: "150" { class: cell_red }
      l6: "175" { class: cell_dark_red }
    }
    note: "Normalized against cluster median"
  }
}

row_impact: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  impact_diag: {
    direction: down
    label: "Global Synchronous Barrier Impact"
    
    timeline: {
      direction: right
      
      normal_step: {
        label: "Normal Iteration\n(Aligned Ranks)"
        width: 180
        compute_bar: {
          direction: right
          c1: "Comp" { width: 60; style.fill: "#60a5fa" }
          c2: "Sync" { width: 30; style.fill: "#a78bfa" }
          c3: "Upd" { width: 20; style.fill: "#34d399" }
        }
        total: "110ms" { style.font-color: "#22c55e"; style.bold: true }
      }
      
      straggler_step: {
        label: "Straggler Iteration\n(Rank 4 Delayed)"
        width: 240
        slow_bar: {
          direction: right
          s1: "Comp" { width: 60; style.fill: "#60a5fa" }
          s2: "WAIT" { width: 40; style.fill: "#fbbf24"; style.stroke-dash: 3 }
          s3: "Sync" { width: 60; style.fill: "#a78bfa" }
          s4: "Upd" { width: 20; style.fill: "#34d399" }
        }
        total: "180ms (+63%)" { style.font-color: "#ef4444"; style.bold: true }
      }
      
      normal_step -> straggler_step: "Barrier Drift" {
        style.stroke: "#ef4444"
        style.stroke-dash: 4
      }
    }
  }
}

row_metrics: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  stats_box: {
    shape: rectangle
    label: "Detector Configuration"
    style.fill: "#1e293b"
    style.font-color: "#f8fafc"
    content: |md
      **Trigger:** Mean > 1.5× Median
      **Observation Window:** 10 Steps
      **R4 Diagnostic Data:**
      - p50 Latency: 52ms
      - R4 Mean: 145ms
      - Deviance: 2.79 sig
      - State: **DETECTED**
    |
  }
  
  mitigation_box: {
    shape: rectangle
    label: "Automated Mitigations"
    style.fill: "#1e293b"
    style.font-color: "#f8fafc"
    content: |md
      1. **Int8 Quantization:**
         Enable for Rank 4 traffic.
      2. **Load Balancing:**
         Reduce Micro-batch size on R4.
      3. **Thermal Management:**
         Increase fan duty cycle on Node 4.
      4. **Exclusion:**
         Decommission rank if heat > 95C.
    |
  }
}

row_code: "" {
  direction: down
  label: "Detection Logic (detector.py)"
  
  logic_code: {
    shape: code
    language: python
    code: |'python
    def find_stragglers(self, current_step: int) -> list:
        # Aggregate across sliding window
        window_data = self.history.get_last(self.window_size)
        cluster_median = np.median([d.ms for d in window_data])
        
        slow_ranks = []
        for rank in self.active_ranks:
            rank_mean = np.mean([d.ms for d in window_data if d.rank == rank])
            if rank_mean > (cluster_median * self.threshold_factor):
                slow_ranks.append(rank)
        return slow_ranks
    '|
  }
}

row_visuals.heatmap_section.straggler_callout -> row_impact.impact_diag.timeline.straggler_step: "triggers stall" {
  style.stroke: "#f59e0b"
  style.stroke-dash: 4
}