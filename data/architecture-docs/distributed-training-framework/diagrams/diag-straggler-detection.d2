        r1_7: "" { class: cell_light_green }
        r1_8: "" { class: cell_green }
        r1_9: "" { class: cell_green }
        r1_10: "" { class: cell_light_green }

        # Row 4: Rank 2
        r2_l: "2" { class: rank_label }
        r2_1: "" { class: cell_green }
        r2_2: "" { class: cell_green }
