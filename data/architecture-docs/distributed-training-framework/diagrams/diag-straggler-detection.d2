direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  rank_label: {
    width: 28
    style: {
      fill: transparent
      stroke: transparent
      font-color: "#aaa"
      font-size: 10
      bold: true
    }
  }
  step_label: {
    width: 28
    style: {
      fill: transparent
      stroke: transparent
      font-color: "#888"
      font-size: 10
    }
  }
  cell_green: {
    width: 28
    height: 22
    style: {
      stroke: "#2d5a3d"
      stroke-width: 1
      fill: "#4ade80"
    }
  }
  cell_light_green: {
    width: 28
    height: 22
    style: {
      stroke: "#2d5a3d"
      stroke-width: 1
      fill: "#86efac"
    }
  }
  cell_yellow: {
    width: 28
    height: 22
    style: {
      stroke: "#8b6914"
      stroke-width: 1
      fill: "#fbbf24"
    }
  }
  cell_orange: {
    width: 28
    height: 22
    style: {
      stroke: "#8b4513"
      stroke-width: 1
      fill: "#f97316"
    }
  }
  cell_red: {
    width: 28
    height: 22
    style: {
      stroke: "#8b1a1a"
      stroke-width: 1
      fill: "#ef4444"
    }
  }
  cell_dark_red: {
    width: 28
    height: 22
    style: {
      stroke: "#6b1a1a"
      stroke-width: 1
      fill: "#dc2626"
    }
  }
}

title_node: {
  shape: rectangle
  label: |md
    # Straggler Detection Heatmap
    GPU timing visualization across distributed training clusters
  |
  style: {
    stroke-width: 0
    fill: transparent
  }
}

row_visuals: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  heatmap_section: {
    direction: down
    label: "All-Reduce Latency Heatmap (Rank vs Step)"
    
    heatmap_container: {
      style.fill: "#1a1a2e"
      style.stroke: "#4a4a6a"
      style.stroke-width: 2
      
      grid: {
        grid-rows: 9
        grid-columns: 11
        grid-gap: 0
        
        # Row 1: Headers
        corner: "R \ S" { class: step_label }
        s1: "1" { class: step_label }
        s2: "2" { class: step_label }
        s3: "3" { class: step_label }
        s4: "4" { class: step_label }
        s5: "5" { class: step_label }
        s6: "6" { class: step_label }
        s7: "7" { class: step_label }
        s8: "8" { class: step_label }
        s9: "9" { class: step_label }
        s10: "10" { class: step_label }

        # Row 2: Rank 0
        r0_l: "0" { class: rank_label }
        r0_1: "" { class: cell_green }
        r0_2: "" { class: cell_green }
        r0_3: "" { class: cell_light_green }
        r0_4: "" { class: cell_green }
        r0_5: "" { class: cell_green }
        r0_6: "" { class: cell_light_green }
        r0_7: "" { class: cell_green }
