direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: SyncBatchNorm vs Local BatchNorm {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_before: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  local_bn_section: {
    direction: down
    label: "Local BatchNorm (PROBLEM)"
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
    style.stroke-width: 2
    local_gpu_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      gpu0_local: {
        label: "GPU 0\nBatch: 32 samples"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        stats0: {
          shape: sql_table
          label: "Local Statistics"
          f0: "mean₀ = 0.42"
          f1: "var₀  = 0.12"
        }
      }
      gpu1_local: {
        label: "GPU 1\nBatch: 32 samples"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        stats1: {
          shape: sql_table
          label: "Local Statistics"
          f0: "mean₁ = 0.67"
          f1: "var₁  = 0.31"
        }
      }
      gpu2_local: {
        label: "GPU 2\nBatch: 32 samples"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        stats2: {
          shape: sql_table
          label: "Local Statistics"
          f0: "mean₂ = 0.23"
          f1: "var₂  = 0.08"
        }
      }
      gpu3_local: {
        label: "GPU 3\nBatch: 32 samples"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        stats3: {
          shape: sql_table
          label: "Local Statistics"
          f0: "mean₃ = 0.89"
          f1: "var₃  = 0.45"
        }
      }
    }
    divergent_warning: {
      label: "⚠️ DIVERGENT STATISTICS"
      shape: callout
      style.fill: "#FF6B6B"
      style.font-color: white
      style.bold: true
    }
    problem_arrow: gpu0_local -> divergent_warning {
      style.stroke: "#CD5C5C"
      style.stroke-dash: 3
    }
    problem_arrow2: gpu1_local -> divergent_warning {
      style.stroke: "#CD5C5C"
      style.stroke-dash: 3
    }
    problem_arrow3: gpu2_local -> divergent_warning {
      style.stroke: "#CD5C5C"
      style.stroke-dash: 3
    }
    problem_arrow4: gpu3_local -> divergent_warning {
      style.stroke: "#CD5C5C"
      style.stroke-dash: 3
    }
  }
}
consequence_section: {
  direction: right
  label: "Training Consequences"
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  train_issue: {
    label: "Training Phase"
    style.fill: white
    issue1: "• Each GPU normalizes differently"
    issue2: "• Running_mean/var diverge per GPU"
    issue3: "• Gradient conflicts during sync"
  }
  test_issue: {
    label: "Inference Phase"
    style.fill: white
    issue4: "• Which statistics to use?"
    issue5: "• Model performs inconsistently"
    issue6: "• Validation loss >> training loss"
  }
  train_issue -> test_issue: "Leads to"
}
row_after: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  sync_bn_section: {
    direction: down
    label: "SyncBatchNorm (SOLUTION)"
    style.fill: "#E0FFE0"
    style.stroke: "#228B22"
    style.stroke-width: 2
    sync_gpu_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      gpu0_sync: {
        label: "GPU 0"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        local0: {
          shape: sql_table
          label: "Local Partial"
          f0: "sum₀   = 13.44"
          f1: "sum₂₀  = 8.21"
          f2: "count  = 32"
        }
      }
      gpu1_sync: {
        label: "GPU 1"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        local1: {
          shape: sql_table
          label: "Local Partial"
          f0: "sum₁   = 21.44"
          f1: "sum²₁  = 18.92"
          f2: "count  = 32"
        }
      }
      gpu2_sync: {
        label: "GPU 2"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        local2: {
          shape: sql_table
          label: "Local Partial"
          f0: "sum₂   = 7.36"
          f1: "sum²₂  = 3.12"
          f2: "count  = 32"
        }
      }
      gpu3_sync: {
        label: "GPU 3"
        shape: rectangle
        style.fill: "#E6E6FA"
        style.stroke: "#4169E1"
        local3: {
          shape: sql_table
          label: "Local Partial"
          f0: "sum₃   = 28.48"
          f1: "sum²₃  = 42.88"
          f2: "count  = 32"
        }
      }
    }
    allreduce_op: {
      label: "ALL-REDUCE (SUM)"
      shape: diamond
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
      style.bold: true
    }
    gpu0_sync -> allreduce_op: "partial sums"
    gpu1_sync -> allreduce_op: "partial sums"
    gpu2_sync -> allreduce_op: "partial sums"
    gpu3_sync -> allreduce_op: "partial sums"
    global_stats: {
      label: "Global Statistics (ALL GPUs)"
      shape: rectangle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      global_table: {
        shape: sql_table
        label: "Computed Globally"
        f0: "total_sum  = 70.72"
        f1: "total_sum² = 73.13"
        f2: "total_cnt  = 128"
        f3: "─────────────────"
        f4: "global_mean = 0.55"
        f5: "global_var  = 0.27"
      }
    }
    allreduce_op -> global_stats: "broadcast"
    result_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      result0: {
        label: "GPU 0 ✓"
        shape: rectangle
        style.fill: "#98FB98"
        r0: "mean = 0.55"
        r1: "var  = 0.27"
      }
      result1: {
        label: "GPU 1 ✓"
        shape: rectangle
        style.fill: "#98FB98"
        r2: "mean = 0.55"
        r3: "var  = 0.27"
      }
      result2: {
        label: "GPU 2 ✓"
        shape: rectangle
        style.fill: "#98FB98"
        r4: "mean = 0.55"
        r5: "var  = 0.27"
      }
      result3: {
        label: "GPU 3 ✓"
        shape: rectangle
        style.fill: "#98FB98"
        r6: "mean = 0.55"
        r7: "var  = 0.27"
      }
    }
    global_stats -> result0: "identical"
    global_stats -> result1: "identical"
    global_stats -> result2: "identical"
    global_stats -> result3: "identical"
    success_msg: {
      label: "✓ CONSISTENT STATISTICS"
      shape: callout
      style.fill: "#32CD32"
      style.font-color: white
      style.bold: true
    }
    result0 -> success_msg
  }
}
row_before -> consequence_section: "Causes"
consequence_section -> row_after: "Solution"
legend: {
  near: bottom-center
  direction: right
  style.fill: "#F5F5F5"
  style.stroke: "#808080"
  legend_title: "Legend" {
    shape: text
    style.bold: true
  }
  comm_vol: {
    label: "Communication: 2 × C floats per BN layer"
    shape: text
  }
  overhead: {
    label: "Overhead: ~0.5-1ms per layer (NVLink)"
    shape: text
  }
  when_use: {
    label: "Use for: Vision models with BatchNorm"
    shape: text
  }
  skip: {
    label: "Skip for: Transformers (use LayerNorm)"
    shape: text
    style.font-color: "#228B22"
  }
}
code_example: {
  label: "Implementation (PyTorch)"
  width: 400
  code: |'python
    import torch.nn as nn
    # Convert all BatchNorm to SyncBatchNorm
    model = nn.SyncBatchNorm.convert_sync_batchnorm(model)
    # Or use in model definition
    self.bn = nn.SyncBatchNorm(num_features)
  '|
}