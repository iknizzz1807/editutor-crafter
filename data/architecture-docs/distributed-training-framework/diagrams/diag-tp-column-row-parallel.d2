direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # Column vs Row Parallelism
    Side-by-side comparison of sharding strategies for `Y = XW`
  '|
  near: top-center
}

comparison_row: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  column_parallel: {
    direction: down
    label: "Column Parallelism (TP-Col)"
    
    cp_desc: {
      label: |'md
        **Weight W sharded column-wise**
        - Input X: **Replicated** on all GPUs
        - Weight W: `[W1 | W2 | W3]` (column slices)
        - Output Y: **Sharded** `[Y1 | Y2 | Y3]`
        - **Comm**: No communication in forward pass
      '|
    }

    cp_diagram: {
      direction: down
      cp_input: {
        label: "Input X (Replicated)"
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        width: 300
      }

      cp_math_row: {
        direction: right
        style.stroke: transparent
        
        x_block: "X" {
          style.fill: "#E8F5E9"
          width: 50
          height: 80
        }

        times: "×" {
          shape: rectangle
          style.stroke: transparent
          style.fill: transparent
          style.font-size: 24
        }

        w_shards: {
          direction: right
          label: "W (shards)"
          w1: "W1" {
            style.fill: "#BBDEFB"
            width: 30
            height: 80
          }
          w2: "W2" {
            style.fill: "#90CAF9"
            width: 30
            height: 80
          }
          w3: "W3" {
            style.fill: "#64B5F6"
            width: 30
            height: 80
          }
        }

        equals: "=" {
          shape: rectangle
          style.stroke: transparent
          style.fill: transparent
          style.font-size: 24
        }

        y_shards: {
          direction: right
          label: "Y (shards)"
          y1: "Y1" {
            style.fill: "#FFECB3"
            width: 40
            height: 60
          }
          y2: "Y2" {
            style.fill: "#FFE082"
            width: 40
            height: 60
          }
          y3: "Y3" {
            style.fill: "#FFD54F"
            width: 40
            height: 60
          }
        }
      }

      cp_input -> cp_math_row: "Broadcast"
      cp_math_row -> cp_output: "Local Compute"

      cp_output: {
        label: "Output Y = [Y1 | Y2 | Y3] (Sharded)"
        shape: rectangle
        style.fill: "#FFF8E1"
        style.stroke: "#FFA000"
        width: 300
      }
    }

    cp_status: "✓ Computationally Efficient" {
      style.fill: "#C8E6C9"
    }
  }

  spacer: {
    label: ""
    style.stroke: transparent
    style.fill: transparent
    width: 50
  }

  row_parallel: {
    direction: down
    label: "Row Parallelism (TP-Row)"

    rp_desc: {
      label: |'md
        **Weight W sharded row-wise**
        - Input X: **Sharded** `[X1 | X2 | X3]` (column slices of X)
        - Weight W: `[W1; W2; W3]` (row slices)
        - Output Y: **Requires All-Reduce** to sum partial results
        - Comm: Partial sums must be aggregated
      '|
    }

    rp_diagram: {
      direction: down
      
      rp_math_row: {
        direction: right
        style.stroke: transparent

        x_shards: {
          direction: right
          label: "X (shards)"
          x1: "X1" {
            style.fill: "#E8F5E9"
            width: 40
            height: 30
          }
          x2: "X2" {
            style.fill: "#C8E6C9"
            width: 40
            height: 30
          }
          x3: "X3" {
            style.fill: "#A5D6A7"
            width: 40
            height: 30
          }
        }

        times: "×" {
          shape: rectangle
          style.stroke: transparent
          style.fill: transparent
          style.font-size: 24
        }

        w_rows: {
          direction: down
          label: "W (rows)"
          wr1: "W1" {
            style.fill: "#BBDEFB"
            width: 60
            height: 25
          }
          wr2: "W2" {
            style.fill: "#90CAF9"
            width: 60
            height: 25
          }
          wr3: "W3" {
            style.fill: "#64B5F6"
            width: 60
            height: 25
          }
        }

        equals: "=" {
          shape: rectangle
          style.stroke: transparent
          style.fill: transparent
          style.font-size: 24
        }

        y_partials: {
          direction: down
          label: "Y' (partials)"
          p1: "Y1'" {
            style.fill: "#FFECB3"
            style.stroke-dash: 3
            width: 50
            height: 25
          }
          p2: "Y2'" {
            style.fill: "#FFE082"
            style.stroke-dash: 3
            width: 50
            height: 25
          }
          p3: "Y3'" {
            style.fill: "#FFD54F"
            style.stroke-dash: 3
            width: 50
            height: 25
          }
        }
      }

      rp_reduce: "All-Reduce (SUM)" {
        shape: diamond
        style.fill: "#FFCDD2"
        style.stroke: "#E53935"
      }

      rp_math_row -> rp_reduce: "Partial Sums"
      rp_reduce -> rp_output: "Summation"

      rp_output: {
        label: "Output Y (Replicated)"
        shape: rectangle
        style.fill: "#FFF8E1"
        style.stroke: "#FFA000"
        width: 300
      }
    }

    rp_status: "⚠ All-Reduce Latency" {
      style.fill: "#FFCDD2"
    }
  }
}

key_insight: {
  label: |'md
    **Technical Insight**: Sequence of [TP-Col] -> [TP-Row] is optimal.
    The output of Column Parallelism is already sharded exactly as Row Parallelism requires for its input,
    meaning zero communication is needed between these two layers in a transformer block.
  '|
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
  near: bottom-center
}

legend: {
  direction: right
  near: bottom-right
  l1: "Replicated" { style.fill: "#E8F5E9" }
  l2: "W Shard" { style.fill: "#BBDEFB" }
  l3: "Y Shard" { style.fill: "#FFECB3" }
  l4: "Comm" { shape: diamond; style.fill: "#FFCDD2" }
}