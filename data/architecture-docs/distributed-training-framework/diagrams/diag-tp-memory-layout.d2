direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    gpu0: "#E8F5E9"
    gpu1: "#E3F2FD"
    gpu2: "#FFF3E0"
    gpu3: "#F3E5F5"
    weight: "#BBDEFB"
    activation: "#C8E6C9"
    header: "#1565C0"
  }
}

# --- HEADER SECTION ---
header: {
  label: |'md
    # Tensor Parallel (TP) Memory & Logic Layout
    **Config: 4 GPUs | TP-Degree: 4 | Model: 7B Parameters**
  '|
  style.stroke: transparent
}

# --- STATS & LEGEND ROW ---
row_stats: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  legend: {
    shape: sql_table
    label: "Memory Legend"
    l1: "Type | Color | Strategy"
    l2: "Weights | Blue | Sharded (1/TP per GPU)"
    l3: "Activations | Green | Replicated or Sharded"
    l4: "Static | Yellow | Replicated (Full)"
    
    legend_note: "Total Shard Factor: 0.25x"
  }

  memory_summary: {
    shape: sql_table
    label: "Memory Comparison (FP16/BF16)"
    h: "Metric | Single GPU | TP=4 (Per GPU)"
    p: "Parameters | 14.0 GB | 3.5 GB"
    a: "Activations | 4.0 GB | 4.0 GB"
    o: "Optimizer | 56.0 GB | 14.0 GB"
    t: "Peak Memory | 74.0 GB | 21.5 GB"
    note: "Status: Fits in 24GB/40GB/80GB VRAM"
  }
}

# --- PARALLELISM LOGIC ROW ---
row_logic: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  column_parallel: {
    label: "Column-Parallel (Linear 1)"
    style.fill: white
    style.stroke: "#1976D2"
    
    desc: {
      label: |'md
        **Forward Pass:**
        1. Input $X$ is replicated.
        2. Each GPU holds $W_i$ (shard of weight).
        3. $Y_i = X \cdot W_i$ (shard of output).
      '|
    }
    
    struct: {
      shape: sql_table
      label: "Weight Matrix Shards"
      g0: "GPU 0 | [H, H/4] | 8 MB"
      g1: "GPU 1 | [H, H/4] | 8 MB"
      g2: "GPU 2 | [H, H/4] | 8 MB"
      g3: "GPU 3 | [H, H/4] | 8 MB"
    }
  }

  row_parallel: {
    label: "Row-Parallel (Linear 2)"
    style.fill: white
    style.stroke: "#388E3C"
    
    desc: {
      label: |'md
        **Forward Pass:**
        1. Input $Y_i$ is sharded.
        2. Each GPU holds $W'_i$ (shard of weight).
        3. $Z = \sum(Y_i \cdot W'_i)$ via **All-Reduce**.
      '|
    }

    struct: {
      shape: sql_table
      label: "Weight Matrix Shards"
      g0: "GPU 0 | [H/4, H] | 8 MB"
      g1: "GPU 1 | [H/4, H] | 8 MB"
      g2: "GPU 2 | [H/4, H] | 8 MB"
      g3: "GPU 3 | [H/4, H] | 8 MB"
    }
  }
}

# --- GPU HARDWARE PERSPECTIVE ---
row_gpu: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  gpu0: {
    style.fill: ${colors.gpu0}
    label: "GPU 0 (Master)"
    mem: {
      shape: sql_table
      label: "VRAM Layout"
      r1: "0x00 | Param Shard | 3.5 GB"
      r2: "0x0E | Activations | 4.0 GB"
      r3: "0x12 | Buffers | 0.5 GB"
      total: "Total Util: 8.0 GB"
    }
  }

  gpu1: {
    style.fill: ${colors.gpu1}
    label: "GPU 1"
    mem: {
      shape: sql_table
      label: "VRAM Layout"
      r1: "0x00 | Param Shard | 3.5 GB"
      r2: "0x0E | Activations | 4.0 GB"
      r3: "0x12 | Buffers | 0.5 GB"
      total: "Total Util: 8.0 GB"
    }
  }

  gpu2: {
    style.fill: ${colors.gpu2}
    label: "GPU 2"
    mem: {
      shape: sql_table
      label: "VRAM Layout"
      r1: "0x00 | Param Shard | 3.5 GB"
      r2: "0x0E | Activations | 4.0 GB"
      r3: "0x12 | Buffers | 0.5 GB"
      total: "Total Util: 8.0 GB"
    }
  }

  gpu3: {
    style.fill: ${colors.gpu3}
    label: "GPU 3"
    mem: {
      shape: sql_table
      label: "VRAM Layout"
      r1: "0x00 | Param Shard | 3.5 GB"
      r2: "0x0E | Activations | 4.0 GB"
      r3: "0x12 | Buffers | 0.5 GB"
      total: "Total Util: 8.0 GB"
    }
  }
}

# --- IMPLEMENTATION FLOW ROW ---
row_flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  megatron_impl: {
    label: "Megatron-LM Block Execution"
    direction: down
    
    step1: {
      label: "Pre-LayerNorm"
      code: |'py
        # Replicated input
        x = layernorm(input)
      '|
    }
    
    step2: {
      label: "Column Linear"
      code: |'py
        # Each GPU: (B, S, H) @ (H, H/4)
        out_shard = x @ weight_shard
      '|
    }
    
    step3: {
      label: "Row Linear + All-Reduce"
      code: |'py
        # Result is partial sum
        partial = out_shard @ weight_shard_2
        # Barrier: All-Reduce to sync
        output = all_reduce(partial)
      '|
    }

    step1 -> step2: "Full X"
    step2 -> step3: "Sharded Y"
  }

  comm_spec: {
    label: "Communication Specification"
    style.fill: "#FFF9C4"
    
    table: {
      shape: sql_table
      label: "Sync Overhead"
      op: "Operation | Frequency | Size"
      ar1: "All-Reduce (Attn) | 1 / Layer | 2*B*S*H"
      ar2: "All-Reduce (MLP) | 1 / Layer | 2*B*S*H"
      lat: "Total Latency | ~1.8ms | NVLink"
    }
    
    note: {
      label: |'md
        **Optimization:** TP degree should 
        not exceed the number of GPUs
        connected via high-speed NVLink
        to avoid PCIe/IB bottlenecks.
      '|
    }
  }
}

# --- TOP LEVEL CONNECTIONS ---
row_stats -> row_logic: "Architecture Definition"
row_logic -> row_gpu: "Memory Mapping"
row_gpu -> row_flow: "Implementation"