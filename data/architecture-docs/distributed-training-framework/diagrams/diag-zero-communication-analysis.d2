direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: ZeRO Communication Volume Analysis {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  baseline_ddp: {
    label: "Baseline DDP"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
    forward: {
      label: "Forward Pass"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    backward: {
      label: "Backward Pass"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    allreduce_grads: {
      label: "All-Reduce\nGradients"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#E53935"
        stroke-width: 2
      }
    }
    forward -> backward
    backward -> allreduce_grads
    comm_label: "Comm: 1× Model Size"
    comm_label.shape: text
    comm_label.style: {
      font-color: "#C62828"
      bold: true
    }
  }
  zero1: {
    label: "ZeRO Stage 1"
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
    forward1: {
      label: "Forward Pass"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    backward1: {
      label: "Backward Pass"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    allreduce1: {
      label: "All-Reduce\nGradients"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#E53935"
        stroke-width: 2
      }
    }
    forward1 -> backward1
    backward1 -> allreduce1
    comm1: "Comm: 1× Model Size"
    comm1.shape: text
    comm1.style: {
      font-color: "#1565C0"
      bold: true
    }
    savings1: "✓ Optimizer states sharded\n  (no comm overhead)"
    savings1.shape: text
    savings1.style: {
      font-color: "#2E7D32"
      font-size: 12
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  zero2: {
    label: "ZeRO Stage 2"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
    forward2: {
      label: "Forward Pass"
      shape: rectangle
      style.fill: "#FFE0B2"
    }
    backward2: {
      label: "Backward Pass"
      shape: rectangle
      style.fill: "#FFE0B2"
    }
    reduce_scatter: {
      label: "Reduce-Scatter\nGradients"
      shape: rectangle
      style: {
        fill: "#FFCC80"
        stroke: "#EF6C00"
        stroke-width: 2
      }
    }
    allgather_params2: {
      label: "All-Gather\nUpdated Params"
      shape: rectangle
      style: {
        fill: "#FFCC80"
        stroke: "#EF6C00"
        stroke-width: 2
      }
    }
    forward2 -> backward2
    backward2 -> reduce_scatter
    reduce_scatter -> allgather_params2
    comm2: "Comm: 1.5× Model Size"
    comm2.shape: text
    comm2.style: {
      font-color: "#E65100"
      bold: true
    }
    savings2: "✓ Gradients + Optimizer sharded\n  (reduce-scatter vs all-reduce)"
    savings2.shape: text
    savings2.style: {
      font-color: "#2E7D32"
      font-size: 12
    }
  }
  zero3: {
    label: "ZeRO Stage 3"
    style: {
      fill: "#FCE4EC"
      stroke: "#E91E63"
      stroke-width: 2
    }
    allgather_before: {
      label: "All-Gather\nParams (per layer)"
      shape: rectangle
      style: {
        fill: "#F8BBD9"
        stroke: "#C2185B"
        stroke-width: 2
      }
    }
    forward3: {
      label: "Forward Pass"
      shape: rectangle
      style.fill: "#F8BBD9"
    }
    backward3: {
      label: "Backward Pass"
      shape: rectangle
      style.fill: "#F8BBD9"
    }
    reduce_scatter3: {
      label: "Reduce-Scatter\nGradients"
      shape: rectangle
      style: {
        fill: "#F48FB1"
        stroke: "#AD1457"
        stroke-width: 2
      }
    }
    allgather_after: {
      label: "All-Gather\nUpdated Params"
      shape: rectangle
      style: {
        fill: "#F48FB1"
        stroke: "#AD1457"
        stroke-width: 2
      }
    }
    allgather_before -> forward3
    forward3 -> backward3
    backward3 -> reduce_scatter3
    reduce_scatter3 -> allgather_after
    comm3: "Comm: 3× Model Size"
    comm3.shape: text
    comm3.style: {
      font-color: "#880E4F"
      bold: true
    }
    note3: "⚠ 50% more comm than DDP\n  but enables larger models"
    note3.shape: text
    note3.style: {
      font-color: "#B71C1C"
      font-size: 12
    }
  }
}
comparison: {
  label: "Communication Volume Comparison"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-width: 2
  }
  width: 700
  header: "Stage | Comm Volume | Memory Savings"
  header.shape: text
  header.style: {
    bold: true
    underline: true
    font: mono
  }
  row_ddp: "DDP         | 1.0× (baseline)    | 0%"
  row_ddp.shape: text
  row_ddp.style.font: mono
  row_z1: "ZeRO-1      | 1.0× (same as DDP) | ~33%"
  row_z1.shape: text
  row_z1.style: {
    font: mono
    font-color: "#1565C0"
  }
  row_z2: "ZeRO-2      | 1.5×               | ~50%"
  row_z2.shape: text
  row_z2.style: {
    font: mono
    font-color: "#E65100"
  }
  row_z3: "ZeRO-3      | 3.0×               | ~75%+"
  row_z3.shape: text
  row_z3.style: {
    font: mono
    font-color: "#880E4F"
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
  }
  compute_op: "Compute Operation"
  compute_op.shape: rectangle
  compute_op.style.fill: "#C8E6C9"
  comm_op: "Communication Operation"
  comm_op.shape: rectangle
  comm_op.style.fill: "#FFCDD2"
  comm_high: "High Communication"
  comm_high.shape: rectangle
  comm_high.style.fill: "#F48FB1"
}
row1 -> row2: ""
row2 -> comparison: ""