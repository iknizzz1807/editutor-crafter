direction: right
layout: elk
# Milestone Index Panel
MilestoneIndex: {
  shape: sql_table
  style: {
    fill: "#E8F4FD"
    stroke: "#1976D2"
  }
  M1: M1: Data Parallelism
  M2: M2: Tensor Parallelism
  M3: M3: Pipeline Parallelism
  M4: M4: 3D Parallelism & ZeRO
  M5: M5: Fault Tolerance & Profiling
}
# ============================================================
# ROW 1: M1 - DATA PARALLELISM FUNDAMENTALS
# ============================================================
M1_DataParallel: {
  label: "M1: Data Parallelism Fundamentals"
  Trainer: {
    shape: class
    style: {
      fill: "#E3F2FD"
    }
    # File: data_parallel/trainer.py
    DataParallelTrainer: {
      shape: class
      - model: nn.Module
      - optimizer: Optimizer
      - world_size: int
      - rank: int
      - bucket_size_mb: float
      + __init__(model, optimizer, world_size, rank)
      + train_batch(batch: Tensor) -> Dict[str, Any]
      + forward_backward(batch) -> Tuple[Tensor, Tensor]
      + sync_gradients() -> None
      + step_optimizer() -> None
    }
    # File: data_parallel/gradient_accumulation.py
    GradientAccumulator: {
      shape: class
      - accumulation_steps: int
      - current_step: int
      - accumulated_grads: Dict[str, Tensor]
      + accumulate(grads: Dict) -> bool
      + reset() -> None
      + should_step() -> bool
    }
  }
  Communication: {
    shape: class
    style: {
      fill: "#E8F5E9"
    }
    # File: data_parallel/communication.py
    AllReduce: {
      shape: class
      - process_group: ProcessGroup
      - backend: str
      + bucketize(tensor: Tensor, bucket_size: int) -> List[Tensor]
      + all_reduce_coalesced(tensors: List[Tensor], op: ReduceOp) -> None
      + wait() -> None
    }
    # File: data_parallel/communication.py
    ReduceScatter: {
      shape: class
      + reduce_scatter(output: Tensor, input_list: List[Tensor]) -> None
    }
    # File: data_parallel/communication.py
    AllGather: {
      shape: class
      + all_gather(tensor_list: List[Tensor], tensor: Tensor) -> None
    }
  }
  Normalization: {
    shape: class
    style: {
      fill: "#FFF3E0"
    }
    # File: data_parallel/sync_batchnorm.py
    SyncBatchNorm: {
      shape: class
      - num_features: int
      - eps: float
      - momentum: float
      - affine: bool
      - running_mean: Tensor
      - running_var: Tensor
      - sync_stats: bool
      + forward(input: Tensor) -> Tensor
      + sync_statistics(mean: Tensor, var: Tensor) -> Tuple[Tensor, Tensor]
    }
  }
  MixedPrecision: {
    shape: class
    style: {
      fill: "#F3E5F5"
    }
    # File: data_parallel/mixed_precision.py
    AMPManager: {
      shape: class
      - enabled: bool
      - dtype: torch.dtype
      - scale: float
      - growth_factor: float
      - backoff_factor: float
      - growth_interval: int
      + forward_with_amp(func: Callable) -> Tensor
      + scale_loss(loss: Tensor) -> Tensor
      + unscale_grads() -> None
      + update_scale() -> None
    }
  }
}
# ============================================================
# ROW 2: M2 - TENSOR PARALLELISM
# ============================================================
M2_TensorParallel: {
  label: "M2: Tensor Parallelism"
  LinearLayers: {
    shape: class
    style: {
      fill: "#FFEBEE"
    }
    # File: tensor_parallel/linear.py
    ColumnParallelLinear: {
      shape: class
      - in_features: int
      - out_features: int
      - world_size: int
      - rank: int
      - gather_output: bool
      - weight: Tensor
      - bias: Optional[Tensor]
      + forward(input: Tensor) -> Tensor
      + get_output_parallel() -> Tensor
      + gather_output_tensor() -> Tensor
    }
    # File: tensor_parallel/linear.py
    RowParallelLinear: {
      shape: class
      - in_features: int
      - out_features: int
      - world_size: int
      - rank: int
      - input_is_parallel: bool
      - reduce_output: bool
      + forward(input: Tensor) -> Tensor
      + reduce_from_parallel(input: Tensor) -> Tensor
    }
  }
  Attention: {
    shape: class
    style: {
      fill: "#E0F7FA"
    }
    # File: tensor_parallel/attention.py
    TensorParallelAttention: {
      shape: class
      - hidden_size: int
      - num_attention_heads: int
      - attention_dropout: float
      - num_heads_per_partition: int
      - hidden_size_per_partition: int
      - query: ColumnParallelLinear
      - key: ColumnParallelLinear
      - value: ColumnParallelLinear
      - dense: RowParallelLinear
      + forward(hidden_states: Tensor) -> Tensor
      + split_heads(tensor: Tensor) -> Tensor
      + merge_heads(tensor: Tensor) -> Tensor
      + attention_scores(Q: Tensor, K: Tensor) -> Tensor
    }
  }
  Embedding: {
    shape: class
    style: {
      fill: "#F1F8E9"
    }
    # File: tensor_parallel/embedding.py
    TensorParallelEmbedding: {
      shape: class
      - num_embeddings: int
      - embedding_dim: int
      - world_size: int
      - rank: int
      - vocab_per_partition: int
      - weight: Tensor
      + forward(input: Tensor) -> Tensor
      + get_partition_indices() -> Tuple[int, int]
      + all_gather_embeddings() -> Tensor
    }
  }
  MLP: {
    shape: class
    style: {
      fill: "#FFF8E1"
    }
    # File: tensor_parallel/mlp.py
    TensorParallelMLP: {
      shape: class
      - hidden_size: int
      - ffn_hidden_size: int
      - world_size: int
      - dense_h_to_4h: ColumnParallelLinear
      - dense_4h_to_h: RowParallelLinear
      - activation: Callable
      + forward(hidden_states: Tensor) -> Tensor
    }
  }
}
# ============================================================
# ROW 3: M3 - PIPELINE PARALLELISM
# ============================================================
M3_PipelineParallel: {
  label: "M3: Pipeline Parallelism"
  PipelineStage: {
    shape: class
    style: {
      fill: "#E1F5FE"
    }
    # File: pipeline_parallel/stage.py
    PipelineStage: {
      shape: class
      - stage_id: int
      - num_stages: int
      - layers: nn.ModuleList
      - num_microbatches: int
      - input_tensor: Optional[Tensor]
      - output_tensor: Optional[Tensor]
      - input_shape: Tuple[int, ...]
      - output_shape: Tuple[int, ...]
      + forward(input: Tensor) -> Tensor
      + backward(grad_output: Tensor) -> Tensor
      + get_layer_balance_cost() -> float
      + get_memory_footprint() -> Dict[str, int]
    }
  }
  Schedules: {
    shape: class
    style: {
      fill: "#FCE4EC"
    }
    # File: pipeline_parallel/schedules/gpipe.py
    GPipeSchedule: {
      shape: class
      - num_microbatches: int
      - num_stages: int
      - forward_schedule: List[Tuple[int, int]]
      - backward_schedule: List[Tuple[int, int]]
      + get_forward_step(microbatch: int, stage: int) -> int
      + get_backward_step(microbatch: int, stage: int) -> int
      + get_pipeline_bubble_time() -> float
      + generate_schedule() -> Tuple[List, List]
    }
    # File: pipeline_parallel/schedules/f1b1.py
    F1B1Schedule: {
      shape: class
      - num_microbatches: int
      - num_stages: int
      - warmup_microbatches: int
      - cooldown_microbatches: int
      - steady_state_microbatches: int
      + compute_warmup_steps() -> int
      + compute_cooldown_steps() -> int
      + generate_interleaved_schedule() -> List[Tuple[str, int, int]]
      + get_bubble_fraction() -> float
    }
  }
  Communicator: {
    shape: class
    style: {
      fill: "#F3E5F5"
    }
    # File: pipeline_parallel/communicator.py
    PipelineCommunicator: {
      shape: class
      - stage_id: int
      - num_stages: int
      - recv_prev_queue: Queue
      - send_next_queue: Queue
      + send_forward(tensor: Tensor, dst: int) -> None
      + recv_forward(src: int) -> Tensor
      + send_backward(tensor: Tensor, dst: int) -> None
      + recv_backward(src: int) -> Tensor
      + is_first_stage() -> bool
      + is_last_stage() -> bool
    }
  }
  Microbatch: {
    shape: sql_table
    style: {
      fill: "#E8EAF6"
    }
    MicrobatchConfig: {
      shape: sql_table
      batch_size: int
      num_microbatches: int
      microbatch_size: int
      gradient_accumulation_steps: int
    }
  }
}
# ============================================================
# ROW 4: M4 - 3D PARALLELISM & ZeRO
# ============================================================
M4_3DParallelism: {
  label: "M4: 3D Parallelism & ZeRO"
  ProcessGroups: {
    shape: class
    style: {
      fill: "#E0F2F1"
    }
    # File: parallelism_3d/process_groups.py
    ProcessGroups3D: {
      shape: class
      - world_size: int
      - dp_size: int
      - tp_size: int
      - pp_size: int
      - dp_group: ProcessGroup
      - tp_group: ProcessGroup
      - pp_group: ProcessGroup
      - rank: int
      - dp_rank: int
      - tp_rank: int
      - pp_rank: int
      + initialize(world_size, dp, tp, pp) -> None
      + get_dp_group() -> ProcessGroup
      + get_tp_group() -> ProcessGroup
      + get_pp_group() -> ProcessGroup
      + get_ranks() -> Tuple[int, int, int]
      + validate_configuration() -> bool
    }
  }
  ZeRO: {
    shape: class
    style: {
      fill: "#FFF3E0"
    }
    # File: zero/stage1.py
    ZeROStage1: {
      shape: class
      - optimizer_state_shard: Dict
      - world_size: int
      - rank: int
      + partition_optimizer_states(optimizer: Optimizer) -> None
      + gather_optimizer_states() -> Dict
      + step() -> None
    }
    # File: zero/stage2.py
    ZeROStage2: {
      shape: class
      - gradient_shard: Dict[str, Tensor]
      - optimizer_state_shard: Dict
      - reduce_scatter_threshold: int
      + partition_gradients() -> None
      + reduce_scatter_gradients() -> None
      + gather_full_gradients() -> Dict
    }
    # File: zero/stage3.py
    ZeROStage3: {
      shape: class
      - param_shard: Dict[str, Tensor]
      - gradient_shard: Dict[str, Tensor]
      - optimizer_state_shard: Dict
      - prefetch_bucket_size: int
      - registered_params: Set[str]
      + partition_parameters(model: nn.Module) -> None
      + gather_parameter(name: str) -> Tensor
      + release_parameter(name: str) -> None
      + prefetch_parameters(names: List[str]) -> None
      + get_memory_savings() -> Dict[str, int]
    }
  }
  Checkpoint: {
    shape: class
    style: {
      fill: "#FBE9E7"
    }
    # File: checkpoint/distributed.py
    DistributedCheckpoint: {
      shape: class
      - checkpoint_dir: str
      - world_size: int
      - rank: int
      - consensus_protocol: str
      - checkpoint_version: int
      + save(state_dict: Dict, step: int) -> None
      + load(step: int) -> Dict
      + coordinate_consensus() -> bool
      + cleanup_old_checkpoints(keep_n: int) -> None
      + validate_checkpoint_integrity(path: str) -> bool
    }
  }
}
# ============================================================
# ROW 5: M5 - FAULT TOLERANCE & PROFILING
# ============================================================
M5_FaultTolerance: {
  label: "M5: Fault Tolerance & Profiling"
  Checkpointing: {
    shape: class
    style: {
      fill: "#E8F5E9"
    }
    # File: fault_tolerance/checkpoint/async_manager.py
    AsyncCheckpointManager: {
      shape: class
      - checkpoint_thread: Thread
      - checkpoint_queue: Queue
      - storage_backend: str
      - compression: bool
      - checkpoint_interval: int
      - in_progress: bool
      + start_async_checkpoint() -> None
      + wait_for_checkpoint() -> bool
      + save_to_cloud(state: Dict, path: str) -> None
      + load_from_cloud(path: str) -> Dict
      + get_mttr_metrics() -> Dict[str, float]
    }
  }
  Recovery: {
    shape: class
    style: {
      fill: "#FFEBEE"
    }
    # File: fault_tolerance/recovery/failure_handler.py
    FailureHandler: {
      shape: class
      - failed_ranks: Set[int]
      - recovery_strategy: str
      - max_retries: int
      - backoff_factor: float
      + detect_failure() -> Optional[int]
      + isolate_failed_rank(rank: int) -> None
      + initiate_recovery() -> None
      + rebuild_process_groups() -> ProcessGroup
      + restore_from_checkpoint(checkpoint_path: str) -> None
    }
  }
  ElasticTraining: {
    shape: class
    style: {
      fill: "#E3F2FD"
    }
    # File: fault_tolerance/elastic/controller.py
    ElasticController: {
      shape: class
      - min_workers: int
      - max_workers: int
      - current_workers: int
      - scaling_policy: str
      - rendezvous_backend: str
      + scale_up(n: int) -> None
      + scale_down(ranks: List[int]) -> None
      + reinitialize_workers() -> None
      + sync_rendezvous() -> bool
      + get_worker_health() -> Dict[int, str]
    }
  }
  StragglerDetection: {
    shape: class
    style: {
      fill: "#FFF8E1"
    }
    # File: fault_tolerance/straggler/detector.py
    StragglerDetector: {
      shape: class
      - iteration_times: Dict[int, List[float]]
      - threshold_sigma: float
      - window_size: int
      - detected_stragglers: Set[int]
      + record_iteration(rank: int, time: float) -> None
      + detect_outliers() -> List[int]
      + get_statistics() -> Dict[str, float]
      + reset_statistics() -> None
    }
  }
  Profiling: {
    shape: class
    style: {
      fill: "#F3E5F5"
    }
    # File: fault_tolerance/profiling/distributed_profiler.py
    DistributedProfiler: {
      shape: class
      - enabled: bool
      - profile_dir: str
      - trace_events: List[Dict]
      - memory_snapshots: List[Dict]
      - communication_metrics: Dict[str, float]
      + start_profiling() -> None
      + stop_profiling() -> None
      + record_event(name: str, duration: float) -> None
      + aggregate_traces() -> Dict
      + export_chrome_trace(path: str) -> None
      + get_memory_timeline() -> List[Dict]
      + get_communication_breakdown() -> Dict[str, float]
    }
  }
}
# ============================================================
# DATA FLOW CONNECTIONS
# ============================================================
# M1 Internal connections
M1_DataParallel.Trainer.DataParallelTrainer -> M1_DataParallel.Communication.AllReduce: "sync gradients\n(all-reduce)" {
  style.stroke: "#1976D2"
}
M1_DataParallel.Trainer.DataParallelTrainer -> M1_DataParallel.Normalization.SyncBatchNorm: "normalize\n(sync stats)" {
  style.stroke: "#1976D2"
}
M1_DataParallel.Trainer.DataParallelTrainer -> M1_DataParallel.MixedPrecision.AMPManager: "scale loss\n(AMP)" {
  style.stroke: "#1976D2"
}
M1_DataParallel.Trainer.DataParallelTrainer -> M1_DataParallel.Trainer.GradientAccumulator: "accumulate\ngradients" {
  style.stroke: "#1976D2"
}
# M1 -> M2 connections
M1_DataParallel.Communication.AllReduce -> M2_TensorParallel.LinearLayers.ColumnParallelLinear: "weight\nsharding" {
  style.stroke: "#388E3C"
  style.stroke-dash: 3
}
# M2 Internal connections
M2_TensorParallel.LinearLayers.ColumnParallelLinear -> M2_TensorParallel.Attention.TensorParallelAttention: "Q,K,V\nprojections" {
  style.stroke: "#D32F2F"
}
M2_TensorParallel.Attention.TensorParallelAttention -> M2_TensorParallel.LinearLayers.RowParallelLinear: "output\nprojection" {
  style.stroke: "#D32F2F"
}
M2_TensorParallel.Embedding.TensorParallelEmbedding -> M2_TensorParallel.LinearLayers.ColumnParallelLinear: "vocab\npartition" {
  style.stroke: "#D32F2F"
}
M2_TensorParallel.LinearLayers.ColumnParallelLinear -> M2_TensorParallel.MLP.TensorParallelMLP: "hidden\nexpansion" {
  style.stroke: "#D32F2F"
}
M2_TensorParallel.MLP.TensorParallelMLP -> M2_TensorParallel.LinearLayers.RowParallelLinear: "hidden\ncontraction" {
  style.stroke: "#D32F2F"
}
# M3 Internal connections
M3_PipelineParallel.PipelineStage.PipelineStage -> M3_PipelineParallel.Schedules.GPipeSchedule: "schedule\nexecution" {
  style.stroke: "#7B1FA2"
}
M3_PipelineParallel.Schedules.GPipeSchedule -> M3_PipelineParallel.Schedules.F1B1Schedule: "optimized\nscheduling" {
  style.stroke: "#7B1FA2"
}
M3_PipelineParallel.PipelineStage.PipelineStage -> M3_PipelineParallel.Communicator.PipelineCommunicator: "send/recv\ntensors" {
  style.stroke: "#7B1FA2"
}
M3_PipelineParallel.Microbatch.MicrobatchConfig -> M3_PipelineParallel.Schedules.F1B1Schedule: "microbatch\ncount" {
  style.stroke: "#7B1FA2"
}
# M3 -> M4 connections
M3_PipelineParallel.PipelineStage.PipelineStage -> M4_3DParallelism.ProcessGroups.ProcessGroups3D: "stage\nassignment" {
  style.stroke: "#00796B"
  style.stroke-dash: 3
}
# M4 Internal connections
M4_3DParallelism.ProcessGroups.ProcessGroups3D -> M4_3DParallelism.ZeRO.ZeROStage1: "DP\ngroup" {
  style.stroke: "#F57C00"
}
M4_3DParallelism.ZeRO.ZeROStage1 -> M4_3DParallelism.ZeRO.ZeROStage2: "add grad\nsharding" {
  style.stroke: "#F57C00"
}
M4_3DParallelism.ZeRO.ZeROStage2 -> M4_3DParallelism.ZeRO.ZeROStage3: "add param\nsharding" {
  style.stroke: "#F57C00"
}
M4_3DParallelism.ZeRO.ZeROStage3 -> M4_3DParallelism.Checkpoint.DistributedCheckpoint: "sharded\nstate" {
  style.stroke: "#F57C00"
}
# M4 -> M5 connections
M4_3DParallelism.Checkpoint.DistributedCheckpoint -> M5_FaultTolerance.Checkpointing.AsyncCheckpointManager: "async\ncheckpoint" {
  style.stroke: "#5D4037"
  style.stroke-dash: 3
}
# M5 Internal connections
M5_FaultTolerance.Checkpointing.AsyncCheckpointManager -> M5_FaultTolerance.Recovery.FailureHandler: "restore\nstate" {
  style.stroke: "#388E3C"
}
M5_FaultTolerance.Recovery.FailureHandler -> M5_FaultTolerance.ElasticTraining.ElasticController: "scale\nworkers" {
  style.stroke: "#388E3C"
}
M5_FaultTolerance.StragglerDetection.StragglerDetector -> M5_FaultTolerance.ElasticTraining.ElasticController: "straggler\nremoval" {
  style.stroke: "#388E3C"
}
M5_FaultTolerance.Profiling.DistributedProfiler -> M5_FaultTolerance.StragglerDetection.StragglerDetector: "timing\ndata" {
  style.stroke: "#388E3C"
}
# Cross-milestone major flows
M2_TensorParallel.Attention.TensorParallelAttention -> M3_PipelineParallel.PipelineStage.PipelineStage: "layer\nstaging" {
  style.stroke: "#1565C0"
  style.stroke-dash: 5
}
M4_3DParallelism.ProcessGroups.ProcessGroups3D -> M1_DataParallel.Trainer.DataParallelTrainer: "process\ngroups" {
  style.stroke: "#C62828"
  style.stroke-dash: 5
}
# Legend
Legend: {
  shape: sql_table
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
  }
  Legend_Entries: {
    shape: sql_table
    "───>": Data Flow
    "- - ->": Cross-Milestone
    "Class Box": Implementation Module
    "SQL Table": Data Structure
  }
}
# Position milestone index
MilestoneIndex -> M1_DataParallel: {
  style.opacity: 0
}