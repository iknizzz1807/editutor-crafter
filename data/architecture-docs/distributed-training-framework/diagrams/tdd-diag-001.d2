direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
  # Base Colors
  gpu_color: "#2563eb"
  model_color: "#7c3aed"
  data_color: "#059669"
  gradient_color: "#dc2626"
  sync_color: "#d97706"
  nccl_color: "#0891b2"
  # Background/Light Colors (Calculated for white background)
  gpu_bg: "#e9effd"
  model_bg: "#f2ebfd"
  data_bg: "#e6f5ef"
  gradient_bg: "#fdeeee"
  sync_bg: "#fff7ed"
  nccl_bg: "#ecfeff"
  model_sub: "#d8cbf9"
}

classes: {
  gpu_container: {
    style: {
      fill: ${gpu_bg}
      stroke: ${gpu_color}
      stroke-width: 2
      border-radius: 8
    }
  }
  model_replica: {
    shape: rectangle
    style: {
      fill: ${model_bg}
      stroke: ${model_color}
      stroke-width: 2
      border-radius: 4
      font-color: ${model_color}
      bold: true
    }
  }
  data_batch: {
    shape: cylinder
    style: {
      fill: ${data_bg}
      stroke: ${data_color}
      stroke-width: 2
      font-color: ${data_color}
    }
  }
  gradient_tensor: {
    shape: hexagon
    style: {
      fill: ${gradient_bg}
      stroke: ${gradient_color}
      stroke-width: 2
      font-color: ${gradient_color}
    }
  }
  sync_node: {
    shape: diamond
    style: {
      fill: ${sync_bg}
      stroke: ${sync_color}
      stroke-width: 3
      font-color: ${sync_color}
      bold: true
    }
  }
  nccl_channel: {
    style: {
      stroke: ${nccl_color}
      stroke-width: 3
      stroke-dash: 5
      animated: true
    }
  }
  control_flow: {
    style: {
      stroke: "#64748b"
      stroke-width: 2
    }
  }
  data_flow: {
    style: {
      stroke: ${data_color}
      stroke-width: 2
    }
  }
  gradient_flow: {
    style: {
      stroke: ${gradient_color}
      stroke-width: 2
      animated: true
    }
  }
}

# Title
title: {
  label: "DATA PARALLEL ARCHITECTURE\nDistributed Training with Synchronized Gradient Descent"
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
    font-color: "#1e293b"
  }
}

# Dataset / Distributed Sampler
# FIX: Changed shape from cylinder to rectangle because cylinders do not support double-border
dataset: {
  label: "GLOBAL DATASET\nDistributedSampler"
  shape: rectangle
  style: {
    fill: ${data_bg}
    stroke: ${data_color}
    stroke-width: 3
    font-color: ${data_color}
    bold: true
    double-border: true
    border-radius: 4
  }
}

# Batch Splitter
batch_splitter: {
  label: "Batch Splitter\nper_gpu_batch_size × world_size"
  shape: rectangle
  style: {
    fill: ${data_bg}
    stroke: ${data_color}
    stroke-width: 2
    border-radius: 4
  }
}

dataset -> batch_splitter: {
  label: "len(dataset) / world_size\neach rank gets unique shard"
  class: data_flow
}

# GPU Workers Container
gpu_workers: {
  label: "GPU WORKERS (World Size = 4)"
  
  # GPU 0
  gpu_0: {
    label: "GPU 0 (Rank 0)"
    class: gpu_container
    model_0: {
      label: "MODEL REPLICA\n(Same Parameters)"
      class: model_replica
      layers_0: {
        label: |md
          Layers:
          ├── Embedding
          ├── Transformer Blocks
          │   ├── Attention
          │   └── FFN
          └── Output Head
        |
        shape: rectangle
        style: {
          fill: transparent
          stroke: ${model_sub}
          font-size: 11
        }
      }
    }
    batch_0: {
      label: "BATCH 0\nindices[0:N/4]"
      class: data_batch
    }
    forward_0: {
      label: "Forward Pass"
      shape: rectangle
      style: {
        fill: "#e0f2fe"
        stroke: "#0284c7"
        border-radius: 4
      }
    }
    loss_0: {
      label: "Loss\nComputation"
      shape: oval
      style: {
        fill: "#fef3c7"
        stroke: "#d97706"
        bold: true
      }
    }
    backward_0: {
      label: "Backward Pass\n∂L/∂W"
      shape: rectangle
      style: {
        fill: "#fee2e2"
        stroke: "#dc2626"
        border-radius: 4
      }
    }
    grad_0: {
      label: "Local\nGradients"
      class: gradient_tensor
    }
    batch_0 -> forward_0
    model_0 -> forward_0
    forward_0 -> loss_0
    loss_0 -> backward_0
    backward_0 -> grad_0: {
      label: "grad accumulation"
      class: gradient_flow
    }
  }

  # GPU 1
  gpu_1: {
    label: "GPU 1 (Rank 1)"
    class: gpu_container
    model_1: {
      label: "MODEL REPLICA\n(Same Parameters)"
      class: model_replica
    }
    batch_1: {
      label: "BATCH 1\nindices[N/4:N/2]"
      class: data_batch
    }
    forward_1: {
      label: "Forward Pass"
      shape: rectangle
      style: {
        fill: "#e0f2fe"
        stroke: "#0284c7"
        border-radius: 4
      }
    }
    loss_1: {
      label: "Loss\nComputation"
      shape: oval
      style: {
        fill: "#fef3c7"
        stroke: "#d97706"
        bold: true
      }
    }
    backward_1: {
      label: "Backward Pass\n∂L/∂W"
      shape: rectangle
      style: {
        fill: "#fee2e2"
        stroke: "#dc2626"
        border-radius: 4
      }
    }
    grad_1: {
      label: "Local\nGradients"
      class: gradient_tensor
    }
    batch_1 -> forward_1
    model_1 -> forward_1
    forward_1 -> loss_1
    loss_1 -> backward_1
    backward_1 -> grad_1: {
      label: "grad accumulation"
      class: gradient_flow
    }
  }

  # GPU 2
  gpu_2: {
    label: "GPU 2 (Rank 2)"
    class: gpu_container
    model_2: {
      label: "MODEL REPLICA\n(Same Parameters)"
      class: model_replica
    }
    batch_2: {
      label: "BATCH 2\nindices[N/2:3N/4]"
      class: data_batch
    }
    forward_2: {
      label: "Forward Pass"
      shape: rectangle
      style: {
        fill: "#e0f2fe"
        stroke: "#0284c7"
        border-radius: 4
      }
    }
    loss_2: {
      label: "Loss\nComputation"
      shape: oval
      style: {
        fill: "#fef3c7"
        stroke: "#d97706"
        bold: true
      }
    }
    backward_2: {
      label: "Backward Pass\n∂L/∂W"
      shape: rectangle
      style: {
        fill: "#fee2e2"
        stroke: "#dc2626"
        border-radius: 4
      }
    }
    grad_2: {
      label: "Local\nGradients"
      class: gradient_tensor
    }
    batch_2 -> forward_2
    model_2 -> forward_2
    forward_2 -> loss_2
    loss_2 -> backward_2
    backward_2 -> grad_2: {
      label: "grad accumulation"
      class: gradient_flow
    }
  }

  # GPU 3
  gpu_3: {
    label: "GPU 3 (Rank 3)"
    class: gpu_container
    model_3: {
      label: "MODEL REPLICA\n(Same Parameters)"
      class: model_replica
    }
    batch_3: {
      label: "BATCH 3\nindices[3N/4:N]"
      class: data_batch
    }
    forward_3: {
      label: "Forward Pass"
      shape: rectangle
      style: {
        fill: "#e0f2fe"
        stroke: "#0284c7"
        border-radius: 4
      }
    }
    loss_3: {
      label: "Loss\nComputation"
      shape: oval
      style: {
        fill: "#fef3c7"
        stroke: "#d97706"
        bold: true
      }
    }
    backward_3: {
      label: "Backward Pass\n∂L/∂W"
      shape: rectangle
      style: {
        fill: "#fee2e2"
        stroke: "#dc2626"
        border-radius: 4
      }
    }
    grad_3: {
      label: "Local\nGradients"
      class: gradient_tensor
    }
    batch_3 -> forward_3
    model_3 -> forward_3
    forward_3 -> loss_3
    loss_3 -> backward_3
    backward_3 -> grad_3: {
      label: "grad accumulation"
      class: gradient_flow
    }
  }
}

# Batch distribution from splitter
batch_splitter -> gpu_workers.gpu_0.batch_0: {
  label: "scatter"
  class: data_flow
}
batch_splitter -> gpu_workers.gpu_1.batch_1: {
  label: "scatter"
  class: data_flow
}
batch_splitter -> gpu_workers.gpu_2.batch_2: {
  label: "scatter"
  class: data_flow
}
batch_splitter -> gpu_workers.gpu_3.batch_3: {
  label: "scatter"
  class: data_flow
}

# NCCL All-Reduce Ring
all_reduce_ring: {
  label: "NCCL RING ALL-REDUCE"
  ring_top: {
    label: false
    shape: rectangle
    style.opacity: 0
    gpu_0_send: {
      label: "GPU 0"
      shape: circle
      style: {
        fill: ${nccl_bg}
        stroke: ${nccl_color}
        stroke-width: 2
      }
    }
    gpu_1_send: {
      label: "GPU 1"
      shape: circle
      style: {
        fill: ${nccl_bg}
        stroke: ${nccl_color}
        stroke-width: 2
      }
    }
    gpu_2_send: {
      label: "GPU 2"
      shape: circle
      style: {
        fill: ${nccl_bg}
        stroke: ${nccl_color}
        stroke-width: 2
      }
    }
    gpu_3_send: {
      label: "GPU 3"
      shape: circle
      style: {
        fill: ${nccl_bg}
        stroke: ${nccl_color}
        stroke-width: 2
      }
    }
    gpu_0_send -> gpu_1_send: {
      label: "Send chunk"
      class: nccl_channel
    }
    gpu_1_send -> gpu_2_send: {
      label: "Send chunk"
      class: nccl_channel
    }
    gpu_2_send -> gpu_3_send: {
      label: "Send chunk"
      class: nccl_channel
    }
    gpu_3_send -> gpu_0_send: {
      label: "Send chunk\n(complete ring)"
      class: nccl_channel
    }
  }
  ring_info: {
    label: |md
      COMMUNICATION COMPLEXITY:
      • Each GPU sends: 2 × model_size
      • Independent of world_size
      • Bandwidth-optimal scaling
      BUCKETIZATION:
      • Gradients bucketed by size
      • Pipelined with backward pass
      • Reduces communication latency
    |
    shape: rectangle
    style: {
      fill: ${nccl_bg}
      stroke: ${nccl_color}
      border-radius: 8
      font-size: 11
    }
  }
}

# Gradient flow to all-reduce
gpu_workers.gpu_0.grad_0 -> all_reduce_ring.ring_top.gpu_0_send: {
  label: "all_reduce\n(bucketized)"
  class: gradient_flow
}
gpu_workers.gpu_1.grad_1 -> all_reduce_ring.ring_top.gpu_1_send: {
  label: "all_reduce\n(bucketized)"
  class: gradient_flow
}
gpu_workers.gpu_2.grad_2 -> all_reduce_ring.ring_top.gpu_2_send: {
  label: "all_reduce\n(bucketized)"
  class: gradient_flow
}
gpu_workers.gpu_3.grad_3 -> all_reduce_ring.ring_top.gpu_3_send: {
  label: "all_reduce\n(bucketized)"
  class: gradient_flow
}

# Synchronization Point
sync_point: {
  label: "GRADIENT SYNCHRONIZATION\nBarrier: All-Reduce Complete"
  class: sync_node
}

all_reduce_ring -> sync_point: {
  label: "Averaged Gradients\nΣ grad_i / world_size"
  style: {
    stroke: ${sync_color}
    stroke-width: 3
    bold: true
  }
}

# Optimizer Step
optimizer: {
  label: "OPTIMIZER STEP\n(Synchronized Across All GPUs)"
  optimizer_step: {
    label: |md
      For each parameter:
        1. Apply gradient clipping
        2. Update momentum/Adam state
        3. Compute parameter update
        4. Apply update: W = W - lr × ∇W_avg
    |
    shape: rectangle
    style: {
      fill: "#f0fdf4"
      stroke: "#16a34a"
      stroke-width: 2
      border-radius: 8
      font-size: 11
    }
  }
  optimizer_info: {
    label: |md
      SYNCHRONIZATION GUARANTEE:
      • All GPUs receive identical gradients
      • Identical optimizer state
      → Parameters remain synchronized
      SUPPORTED OPTIMIZERS:
      • SGD (momentum, nesterov)
      • Adam, AdamW
      • LAMB (layer-wise scaling)
    |
    shape: rectangle
    style: {
      fill: "#f0fdf4"
      stroke: "#16a34a"
      border-radius: 8
      font-size: 11
    }
  }
  optimizer_step -> optimizer_info
}

sync_point -> optimizer: {
  label: "broadcast\naveraged gradients"
  style: {
    stroke: "#16a34a"
    stroke-width: 3
  }
}

# Parameter Update Back to Models
optimizer -> gpu_workers.gpu_0.model_0: {
  label: "update params"
  style: {
    stroke: "#16a34a"
    stroke-width: 2
    stroke-dash: 3
  }
}
optimizer -> gpu_workers.gpu_1.model_1: {
  label: "update params"
  style: {
    stroke: "#16a34a"
    stroke-width: 2
    stroke-dash: 3
  }
}
optimizer -> gpu_workers.gpu_2.model_2: {
  label: "update params"
  style: {
    stroke: "#16a34a"
    stroke-width: 2
    stroke-dash: 3
  }
}
optimizer -> gpu_workers.gpu_3.model_3: {
  label: "update params"
  style: {
    stroke: "#16a34a"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Mixed Precision Training Detail
mixed_precision: {
  label: "MIXED PRECISION (AMP)"
  amp_flow: {
    label: |md
      AUTOMATIC MIXED PRECISION:
      Forward Pass:
        • Weights stored in fp32 (master)
        • Computed in fp16/bf16
        • Activations in fp16/bf16
      Loss Scaling:
        • Scale loss: L_scaled = L × scale
        • Backward pass with scaled gradients
        • Unscale before clipping: grad / scale
        • Check for inf/nan values
      Benefits:
        • 2× memory reduction (activations)
        • 2-3× speedup on Tensor Cores
        • Maintains fp32 numerical stability
    |
    shape: rectangle
    style: {
      fill: "#fdf4ff"
      stroke: "#a855f7"
      stroke-width: 2
      border-radius: 8
      font-size: 10
    }
  }
}

# Gradient Accumulation Detail
grad_accumulation: {
  label: "GRADIENT ACCUMULATION"
  accum_flow: {
    label: |md
      EFFECTIVE BATCH SIZE SCALING:
      accumulation_steps = effective_batch / (per_gpu_batch × world_size)
      For each micro-batch i:
        1. Forward + Backward
        2. Accumulate: grads += ∂L_i/∂W
        3. if (step + 1) % accumulation_steps == 0:
             - All-reduce averaged gradients
             - Optimizer step
             - Zero gradients
      Memory: Same as single batch
      Time: Linear with accumulation steps
    |
    shape: rectangle
    style: {
      fill: ${sync_bg}
      stroke: "#ea580c"
      stroke-width: 2
      border-radius: 8
      font-size: 10
    }
  }
}

# SyncBatchNorm Detail
sync_batchnorm: {
  label: "SYNCBATCHNORM"
  sbn_flow: {
    label: |md
      DISTRIBUTED BATCH NORMALIZATION:
      Standard BatchNorm:
        μ, σ computed per-GPU batch
      SyncBatchNorm:
        1. All-reduce sum(x) → global μ
        2. All-reduce sum(x²) → global σ
        3. Normalize with global statistics
      When to use:
        • Small per-GPU batch sizes
        • Vision models (ResNet, ViT)
        • When batch statistics matter
      Cost: Extra all-reduce per BN layer
    |
    shape: rectangle
    style: {
      fill: "#ecfeff"
      stroke: "#0891b2"
      stroke-width: 2
      border-radius: 8
      font-size: 10
    }
  }
}

# Training Loop State Machine
training_loop: {
  label: "TRAINING LOOP STATE MACHINE"
  states: {
    direction: right
    init: {
      label: "Initialize\nDistributed"
      shape: oval
      style: {
        fill: "#dbeafe"
        stroke: ${gpu_color}
      }
    }
    load_data: {
      label: "Load\nMini-Batch"
      shape: rectangle
      style: {
        fill: ${data_bg}
        stroke: ${data_color}
        border-radius: 4
      }
    }
    forward_pass: {
      label: "Forward\nPass"
      shape: rectangle
      style: {
        fill: "#e0f2fe"
        stroke: "#0284c7"
        border-radius: 4
      }
    }
    loss_calc: {
      label: "Compute\nLoss"
      shape: diamond
      style: {
        fill: "#fef3c7"
        stroke: "#d97706"
      }
    }
    backward_pass: {
      label: "Backward\nPass"
      shape: rectangle
      style: {
        fill: "#fee2e2"
        stroke: "#dc2626"
        border-radius: 4
      }
    }
    accum_check: {
      label: "Accum\nDone?"
      shape: diamond
      style: {
        fill: "#fef3c7"
        stroke: "#d97706"
      }
    }
    allreduce: {
      label: "All-Reduce\nGradients"
      shape: rectangle
      style: {
        fill: ${nccl_bg}
        stroke: ${nccl_color}
        border-radius: 4
      }
    }
    opt_step: {
      label: "Optimizer\nStep"
      shape: rectangle
      style: {
        fill: "#f0fdf4"
        stroke: "#16a34a"
        border-radius: 4
      }
    }
    zero_grad: {
      label: "Zero\nGradients"
      shape: rectangle
      style: {
        fill: "#f5f5f5"
        stroke: "#525252"
        border-radius: 4
      }
    }
    complete: {
      label: "Training\nComplete"
      shape: oval
      style: {
        fill: "#dbeafe"
        stroke: ${gpu_color}
        double-border: true
      }
    }
    init -> load_data
    load_data -> forward_pass
    forward_pass -> loss_calc
    loss_calc -> backward_pass
    backward_pass -> accum_check
    accum_check -> load_data: {
      label: "No"
      style.stroke-dash: 3
    }
    accum_check -> allreduce: {
      label: "Yes"
    }
    allreduce -> opt_step
    opt_step -> zero_grad
    zero_grad -> load_data
    load_data -> complete: {
      label: "epoch done"
      style.stroke-dash: 3
    }
  }
}

# Performance Metrics
performance: {
  label: "PERFORMANCE CHARACTERISTICS"
  metrics: {
    label: |md
      THROUGHPUT SCALING:
      Ideal: Speedup = world_size
      Actual: Speedup = world_size × efficiency
      EFFICIENCY FACTORS:
      • Communication overhead: O(model_size)
      • Computation/communication ratio
      • Network bandwidth (InfiniBand vs Ethernet)
      • Gradient bucketization efficiency
      MEMORY PER GPU:
      • Model parameters: param_size
      • Model gradients: param_size
      • Optimizer state: 2× param_size (Adam)
      • Activations: activation_size
      • Total: ~4× param_size + activations
      TYPICAL EFFICIENCY:
      • 4 GPUs: ~95%
      • 8 GPUs: ~90%
      • 16 GPUs: ~85%
      • 32+ GPUs: Requires gradient compression
    |
    shape: rectangle
    style: {
      fill: "#fafafa"
      stroke: "#525252"
      border-radius: 8
      font-size: 10
    }
  }
}