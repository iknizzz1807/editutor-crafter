direction: right
layout-engine: elk
theme-id: 200
title: {
  label: "Gradient Synchronization Data Flow\n(Distributed Data Parallel Training)"
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# GPU Replicas Container
gpu_replicas: {
  label: "GPU Replicas (World Size = 4)"
  style.fill: "#E3F2FD"
  gpu_0: {
    label: "GPU 0\nRank 0"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  gpu_1: {
    label: "GPU 1\nRank 1"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  gpu_2: {
    label: "GPU 2\nRank 2"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  gpu_3: {
    label: "GPU 3\nRank 3"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
}
# Backward Pass Phase
backward_phase: {
  label: "Phase 1: Backward Pass"
  style.fill: "#FFF3E0"
  loss_computation: {
    label: "Loss Computation"
    shape: rectangle
    style.fill: "#FFE0B2"
  }
  gradient_generation: {
    label: "Gradient Generation\n∂L/∂W per layer"
    shape: rectangle
    style.fill: "#FFE0B2"
  }
  backward_hooks: {
    label: "Backward Hooks\n(DDP Hook Registration)"
    shape: rectangle
    style.fill: "#FFCC80"
  }
  loss_computation -> gradient_generation: {
    label: "Chain Rule"
    style.stroke: "#E65100"
  }
  gradient_generation -> backward_hooks: {
    label: "Register grads"
    style.stroke: "#E65100"
  }
}
# Bucketization Phase
bucketization: {
  label: "Phase 2: Gradient Bucketization"
  style.fill: "#E8F5E9"
  grad_bucket_0: {
    label: "Bucket 0\n(25MB)\nLayers: 0-15"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  grad_bucket_1: {
    label: "Bucket 1\n(25MB)\nLayers: 16-30"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  grad_bucket_2: {
    label: "Bucket 2\n(15MB)\nLayers: 31-40"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  bucket_ready_trigger: {
    label: "Bucket Ready\nTrigger"
    shape: diamond
    style.fill: "#A5D6A7"
  }
  grad_bucket_0 -> bucket_ready_trigger: {
    label: "Full"
    style.stroke-dash: 3
  }
  grad_bucket_1 -> bucket_ready_trigger: {
    label: "Full"
    style.stroke-dash: 3
  }
  grad_bucket_2 -> bucket_ready_trigger: {
    label: "Final"
    style.stroke-dash: 3
  }
}
# All-Reduce Phase
all_reduce: {
  label: "Phase 3: Ring All-Reduce (NCCL Backend)"
  style.fill: "#F3E5F5"
  scatter_reduce: {
    label: "Scatter-Reduce\nPhase"
    shape: rectangle
    style.fill: "#E1BEE7"
  }
  ring_topology: {
    label: "Ring Topology"
    shape: rectangle
    style.fill: "#CE93D8"
    node_0: {label: "N0"; shape: circle; style.fill: "#BA68C8"}
    node_1: {label: "N1"; shape: circle; style.fill: "#BA68C8"}
    node_2: {label: "N2"; shape: circle; style.fill: "#BA68C8"}
    node_3: {label: "N3"; shape: circle; style.fill: "#BA68C8"}
    node_0 -> node_1: {label: "send"; style.stroke: "#7B1FA2"}
    node_1 -> node_2: {label: "send"; style.stroke: "#7B1FA2"}
    node_2 -> node_3: {label: "send"; style.stroke: "#7B1FA2"}
    node_3 -> node_0: {label: "send"; style.stroke: "#7B1FA2"}
  }
  all_gather: {
    label: "All-Gather\nPhase"
    shape: rectangle
    style.fill: "#E1BEE7"
  }
  scatter_reduce -> ring_topology: {style.stroke: "#7B1FA2"}
  ring_topology -> all_gather: {style.stroke: "#7B1FA2"}
}
# Gradient Averaging Phase
averaging: {
  label: "Phase 4: Gradient Averaging"
  style.fill: "#E0F7FA"
  sum_gradients: {
    label: "Sum Gradients\nAcross Ranks"
    shape: rectangle
    style.fill: "#B2EBF2"
  }
  divide_world_size: {
    label: "Divide by\nWorld Size (4)"
    shape: rectangle
    style.fill: "#80DEEA"
  }
  sync_grads: {
    label: "Synchronized\nGradients"
    shape: rectangle
    style.fill: "#4DD0E1"
    style.font-color: "#006064"
  }
  sum_gradients -> divide_world_size: {
    label: "Σ gradients"
    style.stroke: "#00838F"
  }
  divide_world_size -> sync_grads: {
    label: "÷ world_size"
    style.stroke: "#00838F"
  }
}
# Optimizer Update
optimizer: {
  label: "Phase 5: Optimizer Update"
  style.fill: "#FFEBEE"
  optimizer_step: {
    label: "Optimizer Step\n(SGD/Adam/etc.)"
    shape: rectangle
    style.fill: "#FFCDD2"
  }
  weight_update: {
    label: "Weight Update\nW = W - lr × grad_avg"
    shape: rectangle
    style.fill: "#EF9A9A"
    style.font-color: "#B71C1C"
  }
  optimizer_step -> weight_update: {
    style.stroke: "#C62828"
  }
}
# Main Flow Connections
gpu_replicas -> backward_phase: {
  label: "Forward pass complete"
  style.stroke: "#1565C0"
  style.stroke-width: 3
}
backward_phase -> bucketization: {
  label: "Gradients generated"
  style.stroke: "#E65100"
  style.stroke-width: 3
}
bucketization -> all_reduce: {
  label: "Bucket ready → AllReduce"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}
all_reduce -> averaging: {
  label: "Reduced tensors"
  style.stroke: "#7B1FA2"
  style.stroke-width: 3
}
averaging -> optimizer: {
  label: "Averaged gradients"
  style.stroke: "#00838F"
  style.stroke-width: 3
}
# Communication-Computation Overlap Annotation
overlap_note: {
  label: "Note: Communication-Computation Overlap\nBackward pass continues while earlier buckets are being all-reduced"
  shape: text
  style: {
    font-size: 12
    italic: true
    fill: "#FFFDE7"
  }
}
# Legend
legend: {
  label: "Legend"
  style.fill: "#FAFAFA"
  data_flow: {
    label: "→ Data Flow"
    shape: text
  }
  trigger: {
    label: "⇢ Trigger/Sync"
    shape: text
  }
  nccl: {
    label: "NCCL: GPU Communication Library"
    shape: text
  }
  bucket_size: {
    label: "Default Bucket Size: 25MB"
    shape: text
  }
}
# Performance Metrics Box
metrics: {
  label: "Performance Characteristics"
  style.fill: "#ECEFF1"
  bandwidth: {
    label: "Bandwidth Utilization: ~90%\nLatency: O(N) for ring all-reduce\nMemory Overhead: 1 copy per bucket"
    shape: text
    style.font-size: 11
  }
}
backward_phase -> overlap_note: {
  style.stroke-dash: 5
  style.stroke: "#9E9E9E"
}