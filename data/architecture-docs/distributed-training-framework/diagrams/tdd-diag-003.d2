direction: right
layout-engine: elk
theme-id: 300
title: {
  label: Ring All-Reduce Algorithm\nReduce-Scatter + All-Gather Phases
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
vars: {
  rank0_color: "#1E88E5"
  rank1_color: "#43A047"
  rank2_color: "#FB8C00"
  rank3_color: "#E53935"
  chunk0_color: "#BBDEFB"
  chunk1_color: "#C8E6C9"
  chunk2_color: "#FFE0B2"
  chunk3_color: "#FFCDD2"
  reduced_color: "#CE93D8"
  arrow_color: "#546E7A"
}
# Legend
legend: {
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    double-border: true
  }
  title: Legend
  title.style: {
    bold: true
    font-size: 14
  }
  rank_legend: {
    shape: sequence_diagram
    r0: R0 (Rank 0)
    r1: R1 (Rank 1)
    r2: R2 (Rank 2)
    r3: R3 (Rank 3)
  }
  chunk_legend: {
    shape: rectangle
    c0: {
      label: "C0: Chunk 0"
      shape: rectangle
      style.fill: "${chunk0_color}"
    }
    c1: {
      label: "C1: Chunk 1"
      shape: rectangle
      style.fill: "${chunk1_color}"
    }
    c2: {
      label: "C2: Chunk 2"
      shape: rectangle
      style.fill: "${chunk2_color}"
    }
    c3: {
      label: "C3: Chunk 3"
      shape: rectangle
      style.fill: "${chunk3_color}"
    }
    reduced: {
      label: "ОЈ: Reduced"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
  }
  chunk_legend.c0 -> chunk_legend.c1 -> chunk_legend.c2 -> chunk_legend.c3 -> chunk_legend.reduced: {style.opacity: 0}
}
# Initial State - All ranks have their local data
initial_state: {
  label: "INITIAL STATE\nEach rank holds local gradient chunks"
  shape: rectangle
  style: {
    fill: "#ECEFF1"
    stroke: "#37474F"
    double-border: true
  }
  init_title: {
    label: "Data Distribution (N=4 ranks, 4 chunks per rank)"
    shape: text
    style: {
      font-size: 14
      bold: true
    }
  }
  rank0_init: {
    label: "Rank 0\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ AвӮҖвӮҖ в”Ӯ AвӮҖвӮҒ в”Ӯ AвӮҖвӮӮ в”Ӯ AвӮҖвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank0_color}"
      font-color: white
      stroke: "#0D47A1"
    }
  }
  rank1_init: {
    label: "Rank 1\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ AвӮҒвӮҖ в”Ӯ AвӮҒвӮҒ в”Ӯ AвӮҒвӮӮ в”Ӯ AвӮҒвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank1_color}"
      font-color: white
      stroke: "#1B5E20"
    }
  }
  rank2_init: {
    label: "Rank 2\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ AвӮӮвӮҖ в”Ӯ AвӮӮвӮҒ в”Ӯ AвӮӮвӮӮ в”Ӯ AвӮӮвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank2_color}"
      font-color: white
      stroke: "#E65100"
    }
  }
  rank3_init: {
    label: "Rank 3\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ AвӮғвӮҖ в”Ӯ AвӮғвӮҒ в”Ӯ AвӮғвӮӮ в”Ӯ AвӮғвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank3_color}"
      font-color: white
      stroke: "#B71C1C"
    }
  }
  rank0_init -> rank1_init -> rank2_init -> rank3_init: {style.opacity: 0}
}
# Ring Topology Visualization
ring_topology: {
  label: "RING TOPOLOGY\nUnidirectional communication pattern"
  shape: rectangle
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    double-border: true
  }
  ring_center: {
    label: "вҶ» Clockwise\nSend вҶ’ Rank+1\nRecv вҶҗ Rank-1"
    shape: circle
    style: {
      fill: "#C5CAE9"
      font-size: 11
    }
  }
  node0: {
    label: "R0"
    shape: circle
    style: {
      fill: "${rank0_color}"
      font-color: white
    }
  }
  node1: {
    label: "R1"
    shape: circle
    style: {
      fill: "${rank1_color}"
      font-color: white
    }
  }
  node2: {
    label: "R2"
    shape: circle
    style: {
      fill: "${rank2_color}"
      font-color: white
    }
  }
  node3: {
    label: "R3"
    shape: circle
    style: {
      fill: "${rank3_color}"
      font-color: white
    }
  }
  node0 -> node1: "send" {
    style: {
      stroke: "${arrow_color}"
      stroke-width: 3
    }
  }
  node1 -> node2: "send" {
    style: {
      stroke: "${arrow_color}"
      stroke-width: 3
    }
  }
  node2 -> node3: "send" {
    style: {
      stroke: "${arrow_color}"
      stroke-width: 3
    }
  }
  node3 -> node0: "send" {
    style: {
      stroke: "${arrow_color}"
      stroke-width: 3
    }
  }
}
# Phase 1: Reduce-Scatter
phase1: {
  label: "PHASE 1: REDUCE-SCATTER\nN-1 steps to reduce and scatter partial results"
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    double-border: true
  }
  phase1_desc: {
    label: "Each step: Send chunk (rank-step) mod N to right neighbor\nReceive from left neighbor and REDUCE into chunk (rank-step-1) mod N"
    shape: text
    style: {
      font-size: 11
      italic: true
    }
  }
  # Step 0
  step0: {
    label: "STEP 0"
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#FF9800"
    }
    step0_desc: {
      label: "Send: chunk[(rank-0) mod 4] = chunk[rank]\nRecv: chunk[(rank-1) mod 4]\n"
      shape: text
      style.font-size: 10
    }
    s0_r0: {
      label: "R0 sends C0(AвӮҖвӮҖ)\nreceives C3(AвӮғвӮғ)\nreduces into C3"
      shape: rectangle
      style.fill: "${chunk0_color}"
    }
    s0_r1: {
      label: "R1 sends C1(AвӮҒвӮҒ)\nreceives C0(AвӮҖвӮҖ)\nreduces into C0"
      shape: rectangle
      style.fill: "${chunk1_color}"
    }
    s0_r2: {
      label: "R2 sends C2(AвӮӮвӮӮ)\nreceives C1(AвӮҒвӮҒ)\nreduces into C1"
      shape: rectangle
      style.fill: "${chunk2_color}"
    }
    s0_r3: {
      label: "R3 sends C3(AвӮғвӮғ)\nreceives C2(AвӮӮвӮӮ)\nreduces into C2"
      shape: rectangle
      style.fill: "${chunk3_color}"
    }
    s0_r0 -> s0_r1 -> s0_r2 -> s0_r3: {style.opacity: 0}
    step0_flow: {
      label: "Data Flow:\nR0в”Җв”ҖC0в”Җв”Җв–¶R1в”Җв”ҖC1в”Җв”Җв–¶R2в”Җв”ҖC2в”Җв”Җв–¶R3в”Җв”ҖC3в”Җв”Җв–¶R0"
      shape: text
      style: {
        font-size: 10
        fill: "#F5F5F5"
      }
    }
  }
  # Step 1
  step1: {
    label: "STEP 1"
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#FF9800"
    }
    step1_desc: {
      label: "Send: chunk[(rank-1) mod 4]\nRecv: chunk[(rank-2) mod 4]\n"
      shape: text
      style.font-size: 10
    }
    s1_r0: {
      label: "R0 sends C3(AвӮҖвӮғ+AвӮғвӮғ)\nreceives C2(AвӮҒвӮӮ+AвӮӮвӮӮ)\nreduces into C2"
      shape: rectangle
      style.fill: "${chunk3_color}"
    }
    s1_r1: {
      label: "R1 sends C0(AвӮҖвӮҖ+AвӮҒвӮҖ)\nreceives C3(AвӮҖвӮғ+AвӮғвӮғ)\nreduces into C3"
      shape: rectangle
      style.fill: "${chunk0_color}"
    }
    s1_r2: {
      label: "R2 sends C1(AвӮҒвӮҒ+AвӮӮвӮҒ)\nreceives C0(AвӮҖвӮҖ+AвӮҒвӮҖ)\nreduces into C0"
      shape: rectangle
      style.fill: "${chunk1_color}"
    }
    s1_r3: {
      label: "R3 sends C2(AвӮӮвӮӮ+AвӮғвӮӮ)\nreceives C1(AвӮҒвӮҒ+AвӮӮвӮҒ)\nreduces into C1"
      shape: rectangle
      style.fill: "${chunk2_color}"
    }
    s1_r0 -> s1_r1 -> s1_r2 -> s1_r3: {style.opacity: 0}
    step1_flow: {
      label: "Partial sums propagate:\nОЈвӮҖвӮҒ, ОЈвӮҒвӮҒ, ОЈвӮӮвӮҒ, ОЈвӮғвӮҒ"
      shape: text
      style.font-size: 10
    }
  }
  # Step 2
  step2: {
    label: "STEP 2 (Final)"
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      double-border: true
    }
    step2_desc: {
      label: "Send: chunk[(rank-2) mod 4]\nRecv: chunk[(rank-3) mod 4]\n"
      shape: text
      style.font-size: 10
    }
    s2_r0: {
      label: "R0 sends C2\nreceives C1\nC1 = AвӮҖвӮҒ+AвӮҒвӮҒ+AвӮӮвӮҒ+AвӮғвӮҒ вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    s2_r1: {
      label: "R1 sends C3\nreceives C2\nC2 = AвӮҖвӮӮ+AвӮҒвӮӮ+AвӮӮвӮӮ+AвӮғвӮӮ вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    s2_r2: {
      label: "R2 sends C0\nreceives C3\nC3 = AвӮҖвӮғ+AвӮҒвӮғ+AвӮӮвӮғ+AвӮғвӮғ вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    s2_r3: {
      label: "R3 sends C1\nreceives C0\nC0 = AвӮҖвӮҖ+AвӮҒвӮҖ+AвӮӮвӮҖ+AвӮғвӮҖ вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    s2_r0 -> s2_r1 -> s2_r2 -> s2_r3: {style.opacity: 0}
  }
  step0 -> step1 -> step2: "progress" {
    style: {
      stroke: "#FF9800"
      stroke-width: 2
      animated: true
    }
  }
}
# Reduce-Scatter Result
rs_result: {
  label: "REDUCE-SCATTER RESULT\nEach rank holds ONE fully reduced chunk"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    double-border: true
  }
  result_desc: {
    label: "After N-1=3 steps:\nвҖў Each rank has exactly ONE complete reduction\nвҖў Chunks are SCATTERED across ranks\nвҖў Total data per rank: 1/N of original"
    shape: text
    style.font-size: 11
  }
  rs_r0: {
    label: "R0 holds: ОЈC1\nв”” AвӮҖвӮҒ+AвӮҒвӮҒ+AвӮӮвӮҒ+AвӮғвӮҒ"
    shape: rectangle
    style: {
      fill: "${rank0_color}"
      font-color: white
    }
  }
  rs_r1: {
    label: "R1 holds: ОЈC2\nв”” AвӮҖвӮӮ+AвӮҒвӮӮ+AвӮӮвӮӮ+AвӮғвӮӮ"
    shape: rectangle
    style: {
      fill: "${rank1_color}"
      font-color: white
    }
  }
  rs_r2: {
    label: "R2 holds: ОЈC3\nв”” AвӮҖвӮғ+AвӮҒвӮғ+AвӮӮвӮғ+AвӮғвӮғ"
    shape: rectangle
    style: {
      fill: "${rank2_color}"
      font-color: white
    }
  }
  rs_r3: {
    label: "R3 holds: ОЈC0\nв”” AвӮҖвӮҖ+AвӮҒвӮҖ+AвӮӮвӮҖ+AвӮғвӮҖ"
    shape: rectangle
    style: {
      fill: "${rank3_color}"
      font-color: white
    }
  }
  rs_r0 -> rs_r1 -> rs_r2 -> rs_r3: {style.opacity: 0}
}
# Phase 2: All-Gather
phase2: {
  label: "PHASE 2: ALL-GATHER\nN-1 steps to broadcast reduced chunks to all ranks"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    double-border: true
  }
  phase2_desc: {
    label: "Each step: Send chunk (rank-step+1) mod N\nReceive chunk (rank-step) mod N (no reduction, just copy)"
    shape: text
    style: {
      font-size: 11
      italic: true
    }
  }
  # AG Step 0
  ag_step0: {
    label: "STEP 0"
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#2196F3"
    }
    ag0_desc: {
      label: "Send: chunk[(rank+1) mod 4]\nRecv: chunk[rank]"
      shape: text
      style.font-size: 10
    }
    ag0_r0: {
      label: "R0 sends C2\nreceives C1\nnow has: C1, C2"
      shape: rectangle
      style.fill: "${rank0_color}"
    }
    ag0_r1: {
      label: "R1 sends C3\nreceives C2\nnow has: C2, C3"
      shape: rectangle
      style.fill: "${rank1_color}"
    }
    ag0_r2: {
      label: "R2 sends C0\nreceives C3\nnow has: C3, C0"
      shape: rectangle
      style.fill: "${rank2_color}"
    }
    ag0_r3: {
      label: "R3 sends C1\nreceives C0\nnow has: C0, C1"
      shape: rectangle
      style.fill: "${rank3_color}"
    }
    ag0_r0 -> ag0_r1 -> ag0_r2 -> ag0_r3: {style.opacity: 0}
  }
  # AG Step 1
  ag_step1: {
    label: "STEP 1"
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#2196F3"
    }
    ag1_desc: {
      label: "Send: chunk[rank mod 4]\nRecv: chunk[(rank-1) mod 4]"
      shape: text
      style.font-size: 10
    }
    ag1_r0: {
      label: "R0 sends C1\nreceives C0\nnow has: C0, C1, C2"
      shape: rectangle
      style.fill: "${rank0_color}"
    }
    ag1_r1: {
      label: "R1 sends C2\nreceives C1\nnow has: C1, C2, C3"
      shape: rectangle
      style.fill: "${rank1_color}"
    }
    ag1_r2: {
      label: "R2 sends C3\nreceives C2\nnow has: C2, C3, C0"
      shape: rectangle
      style.fill: "${rank2_color}"
    }
    ag1_r3: {
      label: "R3 sends C0\nreceives C3\nnow has: C3, C0, C1"
      shape: rectangle
      style.fill: "${rank3_color}"
    }
    ag1_r0 -> ag1_r1 -> ag1_r2 -> ag1_r3: {style.opacity: 0}
  }
  # AG Step 2
  ag_step2: {
    label: "STEP 2 (Final)"
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      double-border: true
    }
    ag2_desc: {
      label: "Send: chunk[(rank-1) mod 4]\nRecv: chunk[(rank-2) mod 4]"
      shape: text
      style.font-size: 10
    }
    ag2_r0: {
      label: "R0 sends C0\nreceives C3\nnow has: C0вң“, C1вң“, C2вң“, C3вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    ag2_r1: {
      label: "R1 sends C1\nreceives C0\nnow has: C0вң“, C1вң“, C2вң“, C3вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    ag2_r2: {
      label: "R2 sends C2\nreceives C1\nnow has: C0вң“, C1вң“, C2вң“, C3вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    ag2_r3: {
      label: "R3 sends C3\nreceives C2\nnow has: C0вң“, C1вң“, C2вң“, C3вң“"
      shape: rectangle
      style.fill: "${reduced_color}"
    }
    ag2_r0 -> ag2_r1 -> ag2_r2 -> ag2_r3: {style.opacity: 0}
  }
  ag_step0 -> ag_step1 -> ag_step2: "progress" {
    style: {
      stroke: "#2196F3"
      stroke-width: 2
      animated: true
    }
  }
}
# Final State
final_state: {
  label: "FINAL STATE\nAll ranks hold complete reduced gradient"
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#1B5E20"
    double-border: true
  }
  final_desc: {
    label: "All-Gather Complete:\nвҖў Every rank has ALL reduced chunks\nвҖў Synchronized gradient ready for optimizer step"
    shape: text
    style: {
      font-size: 11
      bold: true
    }
  }
  final_r0: {
    label: "Rank 0\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ ОЈCвӮҖ в”Ӯ ОЈCвӮҒ в”Ӯ ОЈCвӮӮ в”Ӯ ОЈCвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank0_color}"
      font-color: white
      stroke: "#0D47A1"
    }
  }
  final_r1: {
    label: "Rank 1\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ ОЈCвӮҖ в”Ӯ ОЈCвӮҒ в”Ӯ ОЈCвӮӮ в”Ӯ ОЈCвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank1_color}"
      font-color: white
      stroke: "#1B5E20"
    }
  }
  final_r2: {
    label: "Rank 2\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ ОЈCвӮҖ в”Ӯ ОЈCвӮҒ в”Ӯ ОЈCвӮӮ в”Ӯ ОЈCвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank2_color}"
      font-color: white
      stroke: "#E65100"
    }
  }
  final_r3: {
    label: "Rank 3\nв”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ ОЈCвӮҖ в”Ӯ ОЈCвӮҒ в”Ӯ ОЈCвӮӮ в”Ӯ ОЈCвӮғ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ"
    shape: rectangle
    style: {
      fill: "${rank3_color}"
      font-color: white
      stroke: "#B71C1C"
    }
  }
  final_r0 -> final_r1 -> final_r2 -> final_r3: {style.opacity: 0}
  checkmark: {
    label: "вң“ ALL SYNCHRONIZED"
    shape: text
    style: {
      font-size: 14
      bold: true
      fill: "#2E7D32"
    }
  }
}
# Complexity Analysis
complexity: {
  label: "COMPLEXITY ANALYSIS"
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    double-border: true
  }
  bandwidth: {
    label: "Bandwidth Cost"
    shape: rectangle
    style.fill: "#E1BEE7"
    bw_formula: {
      label: "Total data transferred per rank:\n\nReduce-Scatter: (N-1) Г— (M/N) bytes\nAll-Gather: (N-1) Г— (M/N) bytes\n\nTotal: 2(N-1)(M/N) = 2M(N-1)/N\n\nAs NвҶ’вҲһ: вүҲ 2M bytes"
      shape: text
      style.font-size: 11
    }
  }
  latency: {
    label: "Latency Cost"
    shape: rectangle
    style.fill: "#E1BEE7"
    lat_formula: {
      label: "Number of synchronization steps:\n\nReduce-Scatter: N-1 steps\nAll-Gather: N-1 steps\n\nTotal: 2(N-1) steps\n\nEach step: Оұ + ОІ(M/N)\nwhere Оұ=latency, ОІ=inv_bw"
      shape: text
      style.font-size: 11
    }
  }
  comparison: {
    label: "vs Naive All-Reduce"
    shape: rectangle
    style.fill: "#CE93D8"
    comp_text: {
      label: "Naive (centralized):\nвҖў Send all to root: M bytes\nвҖў Root reduces: O(M)\nвҖў Broadcast back: M bytes\nвҖў Total: 2M bytes\n\nRing All-Reduce:\nвҖў Same bandwidth: ~2M\nвҖў Better pipeline utilization\nвҖў No hotspot at root\nвҖў Scales linearly"
      shape: text
      style.font-size: 10
    }
  }
  bandwidth -> latency -> comparison: {style.opacity: 0}
}
# Data Flow Summary
data_flow: {
  label: "DATA FLOW SUMMARY"
  shape: rectangle
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    double-border: true
  }
  flow_diagram: {
    shape: sequence_diagram
    span: 1
    init: Initial
    rs0: RS-Step0
    rs1: RS-Step1
    rs2: RS-Step2
    ag0: AG-Step0
    ag1: AG-Step1
    ag2: AG-Step2
    final: Final
    init.r0: "R0: [AвӮҖвӮҖ AвӮҖвӮҒ AвӮҖвӮӮ AвӮҖвӮғ]"
    init.r1: "R1: [AвӮҒвӮҖ AвӮҒвӮҒ AвӮҒвӮӮ AвӮҒвӮғ]"
    init.r2: "R2: [AвӮӮвӮҖ AвӮӮвӮҒ AвӮӮвӮӮ AвӮӮвӮғ]"
    init.r3: "R3: [AвӮғвӮҖ AвӮғвӮҒ AвӮғвӮӮ AвӮғвӮғ]"
    rs0.r0: "send C0, recv C3"
    rs0.r1: "send C1, recv C0"
    rs0.r2: "send C2, recv C1"
    rs0.r3: "send C3, recv C2"
    rs2.r0: "R0: [?  ОЈCвӮҒ ОЈCвӮӮ  ?]"
    rs2.r1: "R1: [?   ?  ОЈCвӮӮ ОЈCвӮғ]"
    rs2.r2: "R2: [ОЈCвӮҖ ?   ?  ОЈCвӮғ]"
    rs2.r3: "R3: [ОЈCвӮҖ ОЈCвӮҒ  ?  ?]"
    ag2.r0: "R0: [ОЈCвӮҖ ОЈCвӮҒ ОЈCвӮӮ ОЈCвӮғ]"
    ag2.r1: "R1: [ОЈCвӮҖ ОЈCвӮҒ ОЈCвӮӮ ОЈCвӮғ]"
    ag2.r2: "R2: [ОЈCвӮҖ ОЈCвӮҒ ОЈCвӮӮ ОЈCвӮғ]"
    ag2.r3: "R3: [ОЈCвӮҖ ОЈCвӮҒ ОЈCвӮӮ ОЈCвӮғ]"
  }
}
# Connections between phases
initial_state -> ring_topology -> phase1 -> rs_result -> phase2 -> final_state: {
  style: {
    stroke: "#37474F"
    stroke-width: 3
    stroke-dash: 5
  }
}
legend -> initial_state: {style.opacity: 0}
complexity -> data_flow: {style.opacity: 0}
final_state -> complexity: {
  label: "Analysis"
  style: {
    stroke: "#7B1FA2"
    stroke-dash: 3
  }
}