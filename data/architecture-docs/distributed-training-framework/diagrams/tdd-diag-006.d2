direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    nvlink: "#007bff"
    ib: "#dc3545"
    optimal: "#28a745"
    bg: "#f8f9fa"
    axis: "#343a40"
    header: "#6f42c1"
    padding: "#e9ecef"
  }
}

# --- STYLING CLASSES ---
classes: {
  axis_line: {
    style: {
      stroke: ${colors.axis}
      stroke-width: 3
    }
  }
  marker_label: {
    style: {
      font-size: 12
      font-color: ${colors.axis}
      bold: false
    }
  }
  stats_box: {
    style: {
      fill: white
      stroke: "#dee2e6"
      stroke-width: 1
      border-radius: 4
      shadow: true
    }
  }
  data_node_nv: {
    shape: circle
    width: 12
    height: 12
    style: {
      fill: ${colors.nvlink}
      stroke: white
      stroke-width: 2
    }
  }
  data_node_ib: {
    shape: diamond
    width: 14
    height: 14
    style: {
      fill: ${colors.ib}
      stroke: white
      stroke-width: 2
    }
  }
}

# --- HEADER SECTION ---
title: {
  label: |'md
    # SCALING EFFICIENCY ANALYSIS
    ## Interconnect Comparison: NVLink 3.0 vs. InfiniBand HDR
  '|
  shape: rectangle
  near: top-center
  style: {
    stroke-width: 0
    fill: transparent
  }
}

# --- LEGEND & SPECIFICATIONS ---
sidebar: {
  legend: {
    label: "SYSTEM LEGEND"
    style: {
      fill: ${colors.bg}
      stroke: "#dee2e6"
      stroke-dash: 0
      bold: true
      font-size: 14
    }
    
    optimal: {
      label: "Theoretical Optimal (100%)"
      
      style: { stroke: ${colors.optimal}; font-color: ${colors.optimal}; bold: true }
    }
    nvlink: {
      label: "NVLink Measured Path"
      style: { stroke: ${colors.nvlink}; font-color: ${colors.nvlink}; bold: true }
    }
    ib: {
      label: "InfiniBand Measured Path"
      style: { stroke: ${colors.ib}; font-color: ${colors.ib}; bold: true }
    }
  }

  specs: {
    label: "INTERCONNECT SPECIFICATIONS"
    style: { fill: "#d1ecf1"; stroke: "#0c5460"; border-radius: 4 }
    
    nv_details: |'md
      **NVLink 3.0 (Internal)**
      - **Topology**: Non-blocking Mesh
      - **Bandwidth**: 600 GB/s (Agg)
      - **Latency**: < 1.0μs
    '|
    ib_details: |'md
      **InfiniBand HDR (External)**
      - **Topology**: Fat-Tree (Clos)
      - **Bandwidth**: 200 Gb/s (Link)
      - **Latency**: ~ 1.5μs
    '|
  }
  
  legend -> specs: "Comparison context"
}

# --- GRAPH VISUALIZATION ENGINE ---
scaling_graph: {
  style: {
    fill: white
    stroke: ${colors.axis}
    stroke-width: 2
  }

  y_axis: {
    class: axis_line
    label.near: outside-left-center
    label: "Efficiency (%)"
    height: 400
    width: 2
  }

  x_axis: {
    class: axis_line
    label.near: outside-bottom-center
    label: "Total GPU Count (N)"
    width: 600
    height: 2
  }

  grid_area: {
    style: { fill: "#fafafa"; stroke-width: 1; stroke: "#eeeeee" }
    
    # Representative Data Nodes placed in conceptual space
    ideal: "100% Linear Scaling Target" {
      style: { font-color: ${colors.optimal}; stroke: ${colors.optimal}; stroke-dash: 5 }
    }
    
    nodes_nv: {
      nv_8: "8-GPU: 93.8%" { class: data_node_nv }
      nv_32: "32-GPU: 85.4%" { class: data_node_nv }
      nv_64: "64-GPU: 79.2%" { class: data_node_nv }
    }

    nodes_ib: {
      ib_8: "8-GPU: 72.3%" { class: data_node_ib }
      ib_32: "32-GPU: 55.1%" { class: data_node_ib }
      ib_64: "64-GPU: 47.8%" { class: data_node_ib }
    }

    # Trend Indicators
    nv_trend: {
      style: { stroke: ${colors.nvlink}; stroke-width: 4; animated: true }
    }
    ib_trend: {
      style: { stroke: ${colors.ib}; stroke-width: 4; stroke-dash: 4 }
    }

    nodes_nv.nv_8 -> nodes_nv.nv_32 -> nodes_nv.nv_64: { class: nv_trend }
    nodes_ib.ib_8 -> nodes_ib.ib_32 -> nodes_ib.ib_64: { class: ib_trend }
  }

  y_axis -> grid_area
  grid_area -> x_axis
}

# --- DATA TABLE & INSIGHTS ---
analytics: {
  performance_table: {
    label: |'md
      ### SCALING METRICS TABLE
      | GPU Count (N) | NVLink Efficiency | InfiniBand Efficiency | Performance Delta |
      | :--- | :--- | :--- | :--- |
      | 2 | 98.5% | 91.2% | +7.3% |
      | 4 | 96.2% | 82.5% | +13.7% |
      | 8 | 93.8% | 72.3% | +21.5% |
      | 16 | 90.1% | 63.7% | +26.4% |
      | 32 | 85.4% | 55.1% | +30.3% |
      | 64 | 79.2% | 47.8% | +31.4% |
    '|
    style: {
      fill: "#f8f9fa"
      border-radius: 8
      stroke: "#ced4da"
    }
  }

  insights: {
    label: "KEY ARCHITECTURAL INSIGHTS"
    class: stats_box
    style.fill: "#fff3cd"
    content: |'md
      - **Saturation Point**: NVLink maintains sub-microsecond synchronization overhead up to 16 nodes.
      - **Bottleneck Analysis**: IB efficiency degradation is primarily attributed to MPI_AllReduce latency in hierarchical topologies.
      - **Critical Threshold**: At 64 GPUs, NVLink provides **1.65x** the effective compute throughput of standard IB HDR.
    '|
  }
}

# --- MATHEMATICAL FOUNDATION ---
math: {
  formula: {
    label: |latex
      \text{Efficiency}(N) = \frac{T_{single\_gpu}}{N \times T_{n\_gpu}} \times 100\%
      \\
      \Delta_{\text{overhead}} = \int_{1}^{N} \frac{\partial \text{Latency}}{\partial \text{Nodes}} dN
    |
    style: {
      font-size: 14
      fill: "#f1f3f5"
      stroke: "#adb5bd"
    }
  }
}

# --- LAYOUT WIRING ---
sidebar -> scaling_graph: "Config"
scaling_graph -> analytics: "Data Stream"
analytics.performance_table -> math.formula: "Validation"
analytics.insights -> annotation: "System Recommendation"

annotation: {
  label: "RECOMMENDATION: Use NVLink for intra-chassis Peer-to-Peer (P2P)\nand InfiniBand for inter-chassis scale-out."
  shape: text
  style: {
    font-size: 12
    font-color: "#495057"
    italic: true
    bold: true
  }
}

# Global Style Overrides
***.style.font: mono
(*** -> ***)[*]: {
  style: {
    stroke-width: 2
  }
}