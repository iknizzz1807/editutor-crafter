direction: right
layout-engine: elk
theme-id: 300
title: {
  label: Tensor Parallel Attention Architecture
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Legend
legend: {
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#F8F9FA"
  }
  legend_title: {
    label: Legend
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
  col_parallel: {
    shape: rectangle
    label: Column-Parallel\nLinear
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
    }
  }
  row_parallel: {
    shape: rectangle
    label: Row-Parallel\nLinear
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
    }
  }
  attn_block: {
    shape: rectangle
    label: Attention\nComputation
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
    }
  }
  comm_op: {
    shape: diamond
    label: All-Reduce
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
    }
  }
  shard: {
    shape: rectangle
    label: GPU Shard\n(tp_rank)
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
  }
}
legend -> col_parallel: {style: {opacity: 0}}
legend -> row_parallel: {style: {opacity: 0}}
legend -> attn_block: {style: {opacity: 0}}
legend -> comm_op: {style: {opacity: 0}}
legend -> shard: {style: {opacity: 0}}
# Input Stage
input: {
  shape: rectangle
  label: "Input Tensor\n[batch, seq_len, hidden_dim]"
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    font-size: 12
  }
}
# GPU Shards Container
gpu_shards: {
  label: ""
  shape: rectangle
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
  # GPU 0
  gpu_0: {
    shape: rectangle
    label: "GPU 0 (tp_rank=0)"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    gpu0_qkv: {
      shape: rectangle
      label: "ColumnParallelLinear\nQKV Projection\n\nOutput: [batch, seq, (num_heads/tp_size)*head_dim*3]"
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
        stroke-width: 2
        font-size: 11
      }
    }
    gpu0_split: {
      shape: diamond
      label: "Split\nQ,K,V"
      style: {
        fill: "#FFF8E1"
        stroke: "#FF8F00"
        font-size: 10
      }
    }
    gpu0_heads: {
      shape: rectangle
      label: "Heads 0..h/tp-1"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
      gpu0_q_proj: {
        label: "Q: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
      gpu0_k_proj: {
        label: "K: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
      gpu0_v_proj: {
        label: "V: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
    }
    gpu0_attn: {
      shape: rectangle
      label: "Scaled Dot-Product\nAttention\n\nscores = QK^T / √d\nattn = softmax(scores)V\n\nout: [batch, seq, h/tp, d_head]"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
        font-size: 10
      }
    }
    gpu0_reshape: {
      shape: rectangle
      label: "Reshape\n[batch, seq, (h/tp)*d_head]"
      style: {
        fill: "#FFFDE7"
        stroke: "#F9A825"
        font-size: 10
      }
    }
    gpu0_out: {
      shape: rectangle
      label: "RowParallelLinear\nOutput Projection\n\nWeight: [(h/tp)*d_head, hidden]\nBias: [hidden] (summed)"
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
        stroke-width: 2
        font-size: 11
      }
    }
    gpu0_partial: {
      shape: rectangle
      label: "Partial Output\n[batch, seq, hidden_dim]"
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-dash: 3
        font-size: 10
      }
    }
    gpu0_qkv -> gpu0_split
    gpu0_split -> gpu0_heads
    gpu0_heads -> gpu0_attn
    gpu0_attn -> gpu0_reshape
    gpu0_reshape -> gpu0_out
    gpu0_out -> gpu0_partial
  }
  # GPU 1
  gpu_1: {
    shape: rectangle
    label: "GPU 1 (tp_rank=1)"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    gpu1_qkv: {
      shape: rectangle
      label: "ColumnParallelLinear\nQKV Projection\n\nOutput: [batch, seq, (num_heads/tp_size)*head_dim*3]"
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
        stroke-width: 2
        font-size: 11
      }
    }
    gpu1_split: {
      shape: diamond
      label: "Split\nQ,K,V"
      style: {
        fill: "#FFF8E1"
        stroke: "#FF8F00"
        font-size: 10
      }
    }
    gpu1_heads: {
      shape: rectangle
      label: "Heads h/tp..2h/tp-1"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
      gpu1_q_proj: {
        label: "Q: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
      gpu1_k_proj: {
        label: "K: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
      gpu1_v_proj: {
        label: "V: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
    }
    gpu1_attn: {
      shape: rectangle
      label: "Scaled Dot-Product\nAttention\n\nscores = QK^T / √d\nattn = softmax(scores)V\n\nout: [batch, seq, h/tp, d_head]"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
        font-size: 10
      }
    }
    gpu1_reshape: {
      shape: rectangle
      label: "Reshape\n[batch, seq, (h/tp)*d_head]"
      style: {
        fill: "#FFFDE7"
        stroke: "#F9A825"
        font-size: 10
      }
    }
    gpu1_out: {
      shape: rectangle
      label: "RowParallelLinear\nOutput Projection\n\nWeight: [(h/tp)*d_head, hidden]\nBias: [hidden] (summed)"
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
        stroke-width: 2
        font-size: 11
      }
    }
    gpu1_partial: {
      shape: rectangle
      label: "Partial Output\n[batch, seq, hidden_dim]"
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-dash: 3
        font-size: 10
      }
    }
    gpu1_qkv -> gpu1_split
    gpu1_split -> gpu1_heads
    gpu1_heads -> gpu1_attn
    gpu1_attn -> gpu1_reshape
    gpu1_reshape -> gpu1_out
    gpu1_out -> gpu1_partial
  }
  # GPU N
  gpu_n: {
    shape: rectangle
    label: "GPU N-1 (tp_rank=tp_size-1)"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    gpuN_qkv: {
      shape: rectangle
      label: "ColumnParallelLinear\nQKV Projection\n\nOutput: [batch, seq, (num_heads/tp_size)*head_dim*3]"
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
        stroke-width: 2
        font-size: 11
      }
    }
    gpuN_split: {
      shape: diamond
      label: "Split\nQ,K,V"
      style: {
        fill: "#FFF8E1"
        stroke: "#FF8F00"
        font-size: 10
      }
    }
    gpuN_heads: {
      shape: rectangle
      label: "Heads (tp-1)*h/tp..h-1"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
      gpuN_q_proj: {
        label: "Q: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
      gpuN_k_proj: {
        label: "K: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
      gpuN_v_proj: {
        label: "V: [batch, seq, h/tp, d_head]"
        shape: rectangle
        style: {font-size: 10}
      }
    }
    gpuN_attn: {
      shape: rectangle
      label: "Scaled Dot-Product\nAttention\n\nscores = QK^T / √d\nattn = softmax(scores)V\n\nout: [batch, seq, h/tp, d_head]"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
        font-size: 10
      }
    }
    gpuN_reshape: {
      shape: rectangle
      label: "Reshape\n[batch, seq, (h/tp)*d_head]"
      style: {
        fill: "#FFFDE7"
        stroke: "#F9A825"
        font-size: 10
      }
    }
    gpuN_out: {
      shape: rectangle
      label: "RowParallelLinear\nOutput Projection\n\nWeight: [(h/tp)*d_head, hidden]\nBias: [hidden] (summed)"
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
        stroke-width: 2
        font-size: 11
      }
    }
    gpuN_partial: {
      shape: rectangle
      label: "Partial Output\n[batch, seq, hidden_dim]"
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-dash: 3
        font-size: 10
      }
    }
    gpuN_qkv -> gpuN_split
    gpuN_split -> gpuN_heads
    gpuN_heads -> gpuN_attn
    gpuN_attn -> gpuN_reshape
    gpuN_reshape -> gpuN_out
    gpuN_out -> gpuN_partial
  }
  ellipsis: {
    shape: text
    label: "···"
    style: {
      font-size: 24
      bold: true
    }
  }
}
# All-Reduce Communication
all_reduce: {
  shape: diamond
  label: "All-Reduce\n(Sum)\n\nNVLink Ring\nor Tree"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    font-size: 11
  }
}
# Output Stage
output: {
  shape: rectangle
  label: "Output Tensor\n[batch, seq_len, hidden_dim]\n\nComplete attention output\n(replicated across all GPUs)"
  style: {
    fill: "#E8F5E9"
    stroke: "#1B5E20"
    stroke-width: 2
    font-size: 12
  }
}
# Weight Distribution Box
weight_info: {
  shape: rectangle
  label: "Weight Distribution\n──────────────────\nQKV Weight: [hidden_dim, 3*hidden_dim]\n  → Sharded along dim 1 (column)\n  → Each GPU: [hidden, (h/tp)*d_head*3]\n\nOutput Weight: [hidden_dim, hidden_dim]\n  → Sharded along dim 0 (row)\n  → Each GPU: [(h/tp)*d_head, hidden]"
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    font-size: 10
  }
}
# Communication Info Box
comm_info: {
  shape: rectangle
  label: "Communication Pattern\n─────────────────────\nForward Pass:\n  1. Broadcast input (replicated)\n  2. Local QKV projection (no comm)\n  3. Local attention (no comm)\n  4. All-Reduce partial outputs\n\nBackward Pass:\n  1. All-Reduce gradient (for input)\n  2. Local gradients (no comm)\n  3. All-Reduce QKV gradients\n\nNVLink Bandwidth: 900 GB/s bidirectional\nRecommended TP Size: ≤8 GPUs per node"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    font-size: 10
  }
}
# Connections
input -> gpu_shards.gpu_0.gpu0_qkv: {
  label: "replicated\n[batch, seq, hidden]"
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}
input -> gpu_shards.gpu_1.gpu1_qkv: {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}
input -> gpu_shards.gpu_n.gpuN_qkv: {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}
gpu_shards.gpu_0.gpu0_partial -> all_reduce: {
  label: "partial_0"
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}
gpu_shards.gpu_1.gpu1_partial -> all_reduce: {
  label: "partial_1"
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}
gpu_shards.gpu_n.gpuN_partial -> all_reduce: {
  label: "partial_N"
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}
all_reduce -> output: {
  label: "∑ partial_i"
  style: {
    stroke: "#1B5E20"
    stroke-width: 3
    animated: true
  }
}
# NVLink connections between GPUs (horizontal communication)
gpu_shards.gpu_0.gpu0_partial <-> gpu_shards.gpu_1.gpu1_partial: {
  label: "NVLink"
  style: {
    stroke: "#9C27B0"
    stroke-dash: 3
    stroke-width: 1
  }
}
gpu_shards.gpu_1.gpu1_partial <-> gpu_shards.gpu_n.gpuN_partial: {
  label: "NVLink"
  style: {
    stroke: "#9C27B0"
    stroke-dash: 3
    stroke-width: 1
  }
}
# Annotations
tp_annotation: {
  shape: text
  label: "Tensor Parallelism: Each GPU computes attention for num_heads/tp_size heads\nColumn-Parallel: Output dimension sharded, no forward communication\nRow-Parallel: Input dimension sharded, requires all-reduce for output"
  style: {
    font-size: 11
    italic: true
  }
}