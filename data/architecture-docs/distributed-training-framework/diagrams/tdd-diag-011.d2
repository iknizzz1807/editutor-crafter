direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 101
  }
}

title: {
  label: "Gradient Flow Through TP Layers\n(Backward Pass)"
  shape: text
  near: top-center
  style.font-size: 24
  style.bold: true
}

# Legend
legend: {
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  legend_title: {
    label: "Legend"
    shape: text
    style.bold: true
  }
  no_comm: {
    label: "← No Communication"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  all_reduce: {
    label: "← All-Reduce Required"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
  }
  gradient: {
    label: "∇ Gradient Flow"
    shape: text
    style.italic: true
  }
  legend_title -> no_comm -> all_reduce -> gradient: {style.opacity: 0}
}

# Backward pass starts from loss
loss_gradient: {
  label: "Loss Gradient\n∇L"
  shape: circle
  style.fill: "#E1BEE7"
  style.stroke: "#9C27B0"
}

# Upcoming gradient flows into row-parallel backward
row_parallel_backward: {
  label: "Row-Parallel Linear\n(Backward Pass)"
  shape: rectangle
  style.fill: "#BBDEFB"
  style.stroke: "#2196F3"
  weight_grad_row: {
    label: "∂L/∂W_row\n(local computation)"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#64B5F6"
  }
  input_grad_row: {
    label: "∂L/∂X_row\n(sharded across GPUs)"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
}

no_comm_annotation: {
  label: "NO COMMUNICATION\n\nRow-parallel backward produces\nnaturally sharded gradient:\n∂L/∂X = ∂L/∂Y @ W\n\nEach GPU computes its shard\nof the input gradient"
  shape: text
  style.bold: true
  style.fill: "#C8E6C9"
}

# Column-parallel backward section
column_parallel_backward: {
  label: "Column-Parallel Linear\n(Backward Pass)"
  shape: rectangle
  style.fill: "#BBDEFB"
  style.stroke: "#2196F3"
  weight_grad_col: {
    label: "∂L/∂W_col\n(local computation)"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#64B5F6"
  }
  input_grad_col: {
    label: "∂L/∂X_partial\n(partial sum on each GPU)"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
  }
}

all_reduce_op: {
  label: "ALL-REDUCE\n(Sum)"
  shape: diamond
  style.fill: "#FFCDD2"
  style.stroke: "#F44336"
  style.bold: true
}

all_reduce_annotation: {
  label: "ALL-REDUCE REQUIRED\n\nColumn-parallel backward produces\npartial input gradients:\n∂L/∂X_partial = ∂L/∂Y_i @ W_i\n\nMust sum across GPUs to get\ncomplete ∂L/∂X"
  shape: text
  style.bold: true
  style.fill: "#FFCDD2"
}

# Final gradient output
final_grad: {
  label: "Complete\nInput Gradient\n∂L/∂X"
  shape: circle
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
}

# GPU representation
gpu_0: {
  label: "GPU 0"
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  style.stroke-dash: 3
}
gpu_1: {
  label: "GPU 1"
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  style.stroke-dash: 3
}

# Connections - Gradient flow (backward sequence)
loss_gradient -> row_parallel_backward: {
  label: "∇L (replicated)"
  style.stroke: "#9C27B0"
  style.stroke-width: 3
}

row_parallel_backward.input_grad_row -> column_parallel_backward.input_grad_col: {
  label: "∂L/∂X_i (sharded)"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

column_parallel_backward.input_grad_col -> all_reduce_op: {
  label: "partial ∂L/∂X"
  style.stroke: "#F44336"
  style.stroke-width: 2
}

all_reduce_op -> final_grad: {
  label: "complete ∂L/∂X"
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}

# Annotations positioned near relevant components
row_parallel_backward -> no_comm_annotation: {
  style.stroke-dash: 5
  style.stroke: "#4CAF50"
}

column_parallel_backward -> all_reduce_annotation: {
  style.stroke-dash: 5
  style.stroke: "#F44336"
}

# Key insight box
key_insight: {
  label: "KEY INSIGHT: Backward Communication ≠ Forward Communication\n\nForward:  Column-parallel (no comm) → Row-parallel (all-reduce)\nBackward: Row-parallel (no comm) → Column-parallel (all-reduce)\n\nMegatron-LM exploits this symmetry for efficient TP"
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.bold: true
}

# Position key insight via opacity hack for spacing
final_grad -> key_insight: {
  style.opacity: 0
}

# Communication pattern comparison
forward_vs_backward: {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  fwd_title: {
    label: "Forward Pass"
    shape: text
    style.bold: true
  }
  fwd_col: {
    label: "Column-Parallel: NO comm"
    shape: text
    style.fill: "#C8E6C9"
  }
  fwd_row: {
    label: "Row-Parallel: ALL-REDUCE"
    shape: text
    style.fill: "#FFCDD2"
  }
  bwd_title: {
    label: "Backward Pass"
    shape: text
    style.bold: true
  }
  bwd_row: {
    label: "Row-Parallel: NO comm"
    shape: text
    style.fill: "#C8E6C9"
  }
  bwd_col: {
    label: "Column-Parallel: ALL-REDUCE"
    shape: text
    style.fill: "#FFCDD2"
  }
  fwd_title -> fwd_col -> fwd_row -> bwd_title -> bwd_row -> bwd_col: {
    style.opacity: 0
  }
}