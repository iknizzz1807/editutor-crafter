vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: "Tensor Parallel Memory Layout\nMemory Breakdown per GPU with TP Degree Scaling"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Legend explaining memory components
legend: {
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#f8f9fa"
  }
  title: Memory Components (70B Model) {
    shape: text
    style: {
      font-size: 14
      bold: true
    }
  }
  params_legend: {
    shape: rectangle
    style.fill: "#3498db"
    label: "Parameters (fp16): 140GB"
  }
  grads_legend: {
    shape: rectangle
    style.fill: "#e74c3c"
    label: "Gradients (fp16): 140GB"
  }
  optim_legend: {
    shape: rectangle
    style.fill: "#2ecc71"
    label: "Optimizer States (Adam fp32×2): 560GB"
  }
  total_legend: {
    shape: rectangle
    style.fill: "#9b59b6"
    label: "Total: 840GB per GPU @ TP=1"
  }
}

# Mathematical Reference
formula: {
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#fff3cd"
  }
  label: "Memory Formula:\nPer GPU Memory = Total Memory ÷ TP Degree\n\n8 bytes (params + grads) + 8 bytes (optimizer)\n= ~16 bytes per param × 70B = ~1.12TB total\n\nWith Adam: fp16(2B) + fp16(2B) + fp32(4B)×2 = 12 bytes/param"
}

# TP=1 Column (Baseline)
tp1_container: {
  label: "TP = 1 (Single GPU)"
  style: {
    fill: "#fce4ec"
    stroke: "#c62828"
    stroke-width: 3
  }
  tp1_title: {
    shape: text
    label: "840 GB Total\n(No Reduction)"
    style: {
      font-size: 16
      bold: true
    }
  }
  tp1_params: {
    label: "Parameters\n140 GB"
    shape: rectangle
    width: 200
    height: 80
    style: {
      fill: "#3498db"
    }
  }
  tp1_grads: {
    label: "Gradients\n140 GB"
    shape: rectangle
    width: 200
    height: 80
    style: {
      fill: "#e74c3c"
    }
  }
  tp1_optim: {
    label: "Optimizer States\n560 GB"
    shape: rectangle
    width: 200
    height: 160
    style: {
      fill: "#2ecc71"
    }
  }
  tp1_gpu: {
    label: "GPU 0\n840 GB"
    shape: hexagon
    width: 200
    style: {
      fill: "#9b59b6"
    }
  }
  tp1_params -> tp1_grads -> tp1_optim -> tp1_gpu: {style.opacity: 0}
}

# TP=2 Column
tp2_container: {
  label: "TP = 2 (2 GPUs)"
  style: {
    fill: "#e3f2fd"
    stroke: "#1565c0"
    stroke-width: 3
  }
  tp2_title: {
    shape: text
    label: "420 GB per GPU\n(2× Reduction)"
    style: {
      font-size: 16
      bold: true
    }
  }
  tp2_params: {
    label: "Parameters\n70 GB"
    shape: rectangle
    width: 160
    height: 60
    style: {
      fill: "#3498db"
    }
  }
  tp2_grads: {
    label: "Gradients\n70 GB"
    shape: rectangle
    width: 160
    height: 60
    style: {
      fill: "#e74c3c"
    }
  }
  tp2_optim: {
    label: "Optimizer States\n280 GB"
    shape: rectangle
    width: 160
    height: 120
    style: {
      fill: "#2ecc71"
    }
  }
  tp2_gpus: {
    label: "GPU 0 & GPU 1\n420 GB each"
    shape: hexagon
    width: 160
    style: {
      fill: "#9b59b6"
    }
  }
  tp2_params -> tp2_grads -> tp2_optim -> tp2_gpus: {style.opacity: 0}
}

# TP=4 Column
tp4_container: {
  label: "TP = 4 (4 GPUs)"
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
    stroke-width: 3
  }
  tp4_title: {
    shape: text
    label: "210 GB per GPU\n(4× Reduction)"
    style: {
      font-size: 16
      bold: true
    }
  }
  tp4_params: {
    label: "Parameters\n35 GB"
    shape: rectangle
    width: 120
    height: 45
    style: {
      fill: "#3498db"
    }
  }
  tp4_grads: {
    label: "Gradients\n35 GB"
    shape: rectangle
    width: 120
    height: 45
    style: {
      fill: "#e74c3c"
    }
  }
  tp4_optim: {
    label: "Optimizer\n140 GB"
    shape: rectangle
    width: 120
    height: 90
    style: {
      fill: "#2ecc71"
    }
  }
  tp4_gpus: {
    label: "GPU 0-3\n210 GB each"
    shape: hexagon
    width: 120
    style: {
      fill: "#9b59b6"
    }
  }
  tp4_params -> tp4_grads -> tp4_optim -> tp4_gpus: {style.opacity: 0}
}

# TP=8 Column (Optimized Production State)
tp8_container: {
  label: "TP = 8 (8 GPUs) ✓ Target"
  style: {
    fill: "#e8eaf6"
    stroke: "#283593"
    stroke-width: 4
  }
  tp8_title: {
    shape: text
    label: "105 GB per GPU\n(8× Reduction)"
    style: {
      font-size: 16
      bold: true
      underline: true
    }
  }
  tp8_params: {
    label: "Parameters\n17.5 GB"
    shape: rectangle
    width: 100
    height: 35
    style: {
      fill: "#3498db"
    }
  }
  tp8_grads: {
    label: "Gradients\n17.5 GB"
    shape: rectangle
    width: 100
    height: 35
    style: {
      fill: "#e74c3c"
    }
  }
  tp8_optim: {
    label: "Optimizer\n70 GB"
    shape: rectangle
    width: 100
    height: 70
    style: {
      fill: "#2ecc71"
    }
  }
  tp8_gpus: {
    label: "GPU 0-7\n105 GB each"
    shape: hexagon
    width: 100
    style: {
      fill: "#9b59b6"
    }
  }
  tp8_params -> tp8_grads -> tp8_optim -> tp8_gpus: {style.opacity: 0}
}

# Scaling flow
tp1_container -> tp2_container: "Shard\nAcross\n2 GPUs" {
  style: {
    stroke: "#666"
    stroke-width: 2
    animated: true
  }
}
tp2_container -> tp4_container: "Shard\nAcross\n4 GPUs" {
  style: {
    stroke: "#666"
    stroke-width: 2
    animated: true
  }
}
tp4_container -> tp8_container: "Shard\nAcross\n8 GPUs" {
  style: {
    stroke: "#666"
    stroke-width: 2
    animated: true
  }
}

# Internal Layer detail
layer_breakdown: {
  label: "Per-Layer Memory Breakdown (TP=8)"
  style: {
    fill: "#fafafa"
    stroke: "#666"
    stroke-dash: 4
  }
  layer_title: {
    shape: text
    label: "Transformer Layer Components\n(Memory Reduction with TP=8)"
    style: {
      font-size: 14
      bold: true
    }
  }
  qkv_layer: {
    label: "QKV Projection\n96 MB → 12 MB"
    shape: rectangle
    width: 140
    style: {
      fill: "#bbdefb"
    }
  }
  out_layer: {
    label: "Output Projection\n32 MB → 4 MB"
    shape: rectangle
    width: 140
    style: {
      fill: "#c8e6c9"
    }
  }
  ffn_up_layer: {
    label: "FFN Up Projection\n128 MB → 16 MB"
    shape: rectangle
    width: 140
    style: {
      fill: "#ffe0b2"
    }
  }
  ffn_down_layer: {
    label: "FFN Down Projection\n128 MB → 16 MB"
    shape: rectangle
    width: 140
    style: {
      fill: "#f8bbd9"
    }
  }
  qkv_layer -> out_layer -> ffn_up_layer -> ffn_down_layer: {
    style: {
      stroke-dash: 3
    }
  }
}

# Interconnect Hardware Requirements
comm_box: {
  label: "NVLink Communication Requirements"
  style: {
    fill: "#e0f7fa"
    stroke: "#006064"
  }
  comm_title: {
    shape: text
    label: "TP requires high-bandwidth interconnect"
    style: {
      font-size: 12
      bold: true
    }
  }
  nvlink: {
    label: "NVLink\n300 GB/s\n✓ Required"
    shape: diamond
    style: {
      fill: "#4caf50"
    }
  }
  infiniband: {
    label: "InfiniBand\n12 GB/s\n✗ Too Slow"
    shape: diamond
    style: {
      fill: "#f44336"
    }
  }
  nvlink -> infiniband: {
    label: "25× faster"
    style: {
      stroke-width: 2
    }
  }
}

# Analytical Summary
summary: {
  shape: rectangle
  style: {
    fill: "#fff8e1"
    stroke: "#ff8f00"
    stroke-width: 2
  }
  label: "Summary: 70B Model Memory Reduction\n\n┌─────────────┬──────────┬─────────────┬──────────────┐\n│ TP Degree   │ Params   │ Gradients   │ Optimizer    │\n├─────────────┼──────────┼─────────────┼──────────────┤\n│ TP=1        │ 140 GB   │ 140 GB      │ 560 GB       │\n│ TP=2        │ 70 GB    │ 70 GB       │ 280 GB       │\n│ TP=4        │ 35 GB    │ 35 GB       │ 140 GB       │\n│ TP=8        │ 17.5 GB  │ 17.5 GB     │ 70 GB        │\n└─────────────┴──────────┴─────────────┴──────────────┘\nTotal: 840 GB → 420 GB → 210 GB → 105 GB per GPU"
}

# Structural organization connections (invisible)
legend -> formula -> tp1_container -> tp2_container -> tp4_container -> tp8_container: {
  style.opacity: 0
}
layer_breakdown -> comm_box -> summary: {
  style.opacity: 0
}