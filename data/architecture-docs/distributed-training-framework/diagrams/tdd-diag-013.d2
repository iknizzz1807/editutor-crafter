layout-engine: elk
theme-id: 4
direction: right
title: {
  label: "Pipeline Stage Partitioning\nDistributed Training Framework"
  shape: text
  near: top-center
}
# Global styles
classes: {
  stage_container: {
    style: {
      fill: "#1a1f36"
      stroke: "#4a5568"
      stroke-width: 2
      font-color: "#e2e8f0"
      border-radius: 8
    }
  }
  layer_block: {
    style: {
      fill: "#2d3748"
      stroke: "#4299e1"
      stroke-width: 1
      font-color: "#e2e8f0"
      border-radius: 4
    }
  }
  special_block: {
    style: {
      fill: "#2c5282"
      stroke: "#63b3ed"
      stroke-width: 2
      font-color: "#ffffff"
      border-radius: 4
    }
  }
  output_block: {
    style: {
      fill: "#553c9a"
      stroke: "#9f7aea"
      stroke-width: 2
      font-color: "#ffffff"
      border-radius: 4
    }
  }
  connection_style: {
    style: {
      stroke: "#48bb78"
      stroke-width: 3
      animated: true
    }
  }
}
# Pipeline stages
Stage0: {
  class: stage_container
  label: "Stage 0 (GPU 0)"
  Embedding: {
    class: special_block
    label: "Embedding Layer\n(Vocab → Hidden)"
  }
  Layers0: {
    class: layer_block
    label: "Transformer Layers\n0 - 19"
  }
  Embedding -> Layers0: {
    style: {
      stroke: "#4299e1"
      stroke-width: 2
    }
  }
}
Stage1: {
  class: stage_container
  label: "Stage 1 (GPU 1)"
  Layers1: {
    class: layer_block
    label: "Transformer Layers\n20 - 39"
  }
}
Stage2: {
  class: stage_container
  label: "Stage 2 (GPU 2)"
  Layers2: {
    class: layer_block
    label: "Transformer Layers\n40 - 59"
  }
}
Stage3: {
  class: stage_container
  label: "Stage 3 (GPU 3)"
  Layers3: {
    class: layer_block
    label: "Transformer Layers\n60 - 79"
  }
  OutputHead: {
    class: output_block
    label: "Output Head\n(LM Head / Classifier)"
  }
  Layers3 -> OutputHead: {
    style: {
      stroke: "#9f7aea"
      stroke-width: 2
    }
  }
}
# Inter-stage communication (forward pass)
Stage0.Layers0 -> Stage1.Layers1: {
  class: connection_style
  label: "Send/Recv\nActivations"
}
Stage1.Layers1 -> Stage2.Layers2: {
  class: connection_style
  label: "Send/Recv\nActivations"
}
Stage2.Layers2 -> Stage3.Layers3: {
  class: connection_style
  label: "Send/Recv\nActivations"
}
# Legend
Legend: {
  direction: right
  shape: rectangle
  style: {
    fill: "#1a1f36"
    stroke: "#4a5568"
    border-radius: 8
    font-color: "#e2e8f0"
  }
  label: "Legend"
  ForwardPass: {
    shape: rectangle
    label: "→ Forward Pass (Activations)"
    style: {
      fill: "#2d3748"
      stroke: "#48bb78"
      font-color: "#e2e8f0"
    }
  }
  BackwardPass: {
    shape: rectangle
    label: "← Backward Pass (Gradients)"
    style: {
      fill: "#2d3748"
      stroke: "#f56565"
      font-color: "#e2e8f0"
    }
  }
  PipelineStage: {
    shape: rectangle
    label: "Pipeline Stage Container"
    style: {
      fill: "#1a1f36"
      stroke: "#4a5568"
      font-color: "#e2e8f0"
    }
  }
}
# Annotations
Info: {
  shape: text
  near: bottom-center
  label: |md
    ### Pipeline Stage Partitioning
    - **Total Layers**: 80 Transformer layers distributed across 4 stages
    - **Layers per Stage**: 20 layers (balanced partitioning)
    - **Stage 0**: Embedding + Layers 0-19
    - **Stage 3**: Layers 60-79 + Output Head
    - **Communication**: Point-to-point send/recv between adjacent stages
    - **Memory**: Each stage holds activations for in-flight micro-batches
  |
}
# Connection arrows positioning
Stage0 -> Stage1 -> Stage2 -> Stage3: {
  style: {
    opacity: 0
  }
}