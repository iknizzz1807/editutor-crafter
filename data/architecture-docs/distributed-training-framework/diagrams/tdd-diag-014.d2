direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
  }
}

title: "GPipe Schedule Timeline" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Legend for the Pipeline Visualization
legend: {
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: "#FAFAFA"
  }
  legend_title: "Legend" {
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
  forward_cell: {
    shape: rectangle
    label: "Fm"
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      font-color: white
    }
  }
  backward_cell: {
    shape: rectangle
    label: "Bm"
    style: {
      fill: "#2196F3"
      stroke: "#1565C0"
      font-color: white
    }
  }
  bubble_cell: {
    shape: rectangle
    label: "Bubble"
    style: {
      fill: "#FFEB3B"
      stroke: "#F57F17"
      font-color: "#333"
      stroke-dash: 4
    }
  }
  note: {
    shape: text
    label: "F=Forward, B=Backward\nm=micro-batch index"
    style: {
      font-size: 12
    }
  }
  
  legend_title -> forward_cell -> backward_cell -> bubble_cell -> note: {
    style.stroke: transparent
  }
}

legend -> timeline_grid: {
  style.stroke: transparent
}

# Timeline Grid Container - Pipeline Parallelism Execution Map
timeline_grid: {
  label: ""
  shape: rectangle
  style: {
    fill: white
    stroke: "#E0E0E0"
  }
  
  # Time axis header
  time_header: {
    shape: rectangle
    style: {
      fill: "#ECEFF1"
      stroke: "#B0BEC5"
    }
    t0: "T0" { shape: text; style: { font-size: 12; bold: true } }
    t1: "T1" { shape: text; style: { font-size: 12; bold: true } }
    t2: "T2" { shape: text; style: { font-size: 12; bold: true } }
    t3: "T3" { shape: text; style: { font-size: 12; bold: true } }
    t4: "T4" { shape: text; style: { font-size: 12; bold: true } }
    t5: "T5" { shape: text; style: { font-size: 12; bold: true } }
    t6: "T6" { shape: text; style: { font-size: 12; bold: true } }
    t7: "T7" { shape: text; style: { font-size: 12; bold: true } }
    t8: "T8" { shape: text; style: { font-size: 12; bold: true } }
    t9: "T9" { shape: text; style: { font-size: 12; bold: true } }
    t10: "T10" { shape: text; style: { font-size: 12; bold: true } }
    t11: "T11" { shape: text; style: { font-size: 12; bold: true } }
    
    t0 -> t1 -> t2 -> t3 -> t4 -> t5 -> t6 -> t7 -> t8 -> t9 -> t10 -> t11: {
      style.stroke: transparent
    }
  }

  # Stage 0 Row (First GPU in Pipeline)
  stage0: {
    label: "Stage 0\n(P0)"
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
    }
    # Initial Bubbles
    s0_bub1: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    
    # Forward passes (F0 to F3)
    s0_f0: "F0" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s0_f1: "F1" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s0_f2: "F2" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s0_f3: "F3" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    
    # Flush Gap
    s0_gap1: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    s0_gap2: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    
    # Backward passes
    s0_b3: "B3" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s0_b2: "B2" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s0_b1: "B1" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s0_b0: "B0" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    
    s0_bub1 -> s0_f0 -> s0_f1 -> s0_f2 -> s0_f3 -> s0_gap1 -> s0_gap2 -> s0_b3 -> s0_b2 -> s0_b1 -> s0_b0: {
      style.stroke: transparent
    }
  }

  # Stage 1 Row
  stage1: {
    label: "Stage 1\n(P1)"
    shape: rectangle
    style: { fill: "#E3F2FD"; stroke: "#1976D2" }
    
    s1_bub1: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    s1_bub2: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    
    s1_f0: "F0" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s1_f1: "F1" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s1_f2: "F2" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s1_f3: "F3" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    
    s1_gap1: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    
    s1_b3: "B3" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s1_b2: "B2" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s1_b1: "B1" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s1_b0: "B0" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    
    s1_bub1 -> s1_bub2 -> s1_f0 -> s1_f1 -> s1_f2 -> s1_f3 -> s1_gap1 -> s1_b3 -> s1_b2 -> s1_b1 -> s1_b0: {
      style.stroke: transparent
    }
  }

  # Stage 2 Row
  stage2: {
    label: "Stage 2\n(P2)"
    shape: rectangle
    style: { fill: "#E3F2FD"; stroke: "#1976D2" }
    
    s2_bub1: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    s2_bub2: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    s2_bub3: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    
    s2_f0: "F0" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s2_f1: "F1" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s2_f2: "F2" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s2_f3: "F3" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    
    s2_b3: "B3" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s2_b2: "B2" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s2_b1: "B1" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s2_b0: "B0" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    
    s2_bub1 -> s2_bub2 -> s2_bub3 -> s2_f0 -> s2_f1 -> s2_f2 -> s2_f3 -> s2_b3 -> s2_b2 -> s2_b1 -> s2_b0: {
      style.stroke: transparent
    }
  }

  # Stage 3 Row (Final Output GPU)
  stage3: {
    label: "Stage 3\n(P3)"
    shape: rectangle
    style: { fill: "#E3F2FD"; stroke: "#1976D2" }
    
    s3_bub1: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    s3_bub2: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    s3_bub3: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    s3_bub4: "—" { style: { fill: "#FFEB3B"; stroke: "#F57F17"; stroke-dash: 4 } }
    
    s3_f0: "F0" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s3_f1: "F1" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s3_f2: "F2" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    s3_f3: "F3" { style: { fill: "#4CAF50"; stroke: "#2E7D32"; font-color: white; bold: true } }
    
    s3_b3: "B3" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s3_b2: "B2" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s3_b1: "B1" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    s3_b0: "B0" { style: { fill: "#2196F3"; stroke: "#1565C0"; font-color: white; bold: true } }
    
    s3_bub1 -> s3_bub2 -> s3_bub3 -> s3_bub4 -> s3_f0 -> s3_f1 -> s3_f2 -> s3_f3 -> s3_b3 -> s3_b2 -> s3_b1 -> s3_b0: {
      style.stroke: transparent
    }
  }

  time_header -> stage0 -> stage1 -> stage2 -> stage3: {
    style.stroke: transparent
  }
}

# Phase annotations for Pipeline Mechanics
phases: {
  fill_phase: {
    shape: rectangle
    label: "FILL\nPHASE"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-dash: 3
      font-color: "#E65100"
    }
  }
  steady_phase: {
    shape: rectangle
    label: "STEADY STATE"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      font-color: "#2E7D32"
    }
  }
  drain_phase: {
    shape: rectangle
    label: "DRAIN\nPHASE"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-dash: 3
      font-color: "#E65100"
    }
  }
  fill_phase -> steady_phase -> drain_phase: {
    style: {
      stroke: "#9E9E9E"
      stroke-width: 2
    }
  }
}

phases -> timeline_grid: {
  style.stroke: transparent
}

# Formula box for GPipe Theory
formula_box: {
  label: ""
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }
  formula_title: "Bubble Fraction Analysis" {
    shape: text
    style: {
      bold: true
      font-size: 16
      font-color: "#4A148C"
    }
  }
  formula: "β_bubble = 2(P-1) / (M + 2(P-1))" {
    shape: text
    style: {
      font-size: 14
      font-color: "#6A1B9A"
    }
  }
  params: "P = 4 stages, M = 4 micro-batches\nβ_bubble = 2(3) / (4 + 6) = 6/10 = 60%" {
    shape: text
    style: {
      font-size: 12
      font-color: "#7B1FA2"
    }
  }
  memory: "Activation Memory: O(M × activation_size)" {
    shape: text
    style: {
      font-size: 12
      font-color: "#1565C0"
      bold: true
    }
  }
  formula_title -> formula -> params -> memory: {
    style.stroke: transparent
  }
}

formula_box -> phases: {
  style.stroke: transparent
}

# Data flow arrows (Dependencies)
timeline_grid.stage0.s0_f0 -> timeline_grid.stage1.s1_f0: {
  style: { stroke: "#4CAF50"; stroke-width: 2 }
}
timeline_grid.stage1.s1_f0 -> timeline_grid.stage2.s2_f0: {
  style: { stroke: "#4CAF50"; stroke-width: 2 }
}
timeline_grid.stage2.s2_f0 -> timeline_grid.stage3.s3_f0: {
  style: { stroke: "#4CAF50"; stroke-width: 2 }
}

# Backward Dependency flow
timeline_grid.stage3.s3_b0 -> timeline_grid.stage2.s2_b0: {
  style: { stroke: "#2196F3"; stroke-width: 2; stroke-dash: 3 }
}
timeline_grid.stage2.s2_b0 -> timeline_grid.stage1.s1_b0: {
  style: { stroke: "#2196F3"; stroke-width: 2; stroke-dash: 3 }
}
timeline_grid.stage1.s1_b0 -> timeline_grid.stage0.s0_b0: {
  style: { stroke: "#2196F3"; stroke-width: 2; stroke-dash: 3 }
}

# Execution Axis labels
time_axis_label: "→ Time (T)" {
  shape: text
  style: { bold: true; font-size: 14; font-color: "#424242" }
}
space_axis_label: "↓ Pipeline Stages (P)" {
  shape: text
  style: { bold: true; font-size: 14; font-color: "#424242" }
}

time_axis_label -> timeline_grid: { style.stroke: transparent }
space_axis_label -> time_axis_label: { style.stroke: transparent }