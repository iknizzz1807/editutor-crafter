direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: "Pipeline Bubble Analysis" {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: "Bubble Fraction vs Micro-Batch Count for Pipeline Parallelism (PP) Degrees" {
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}

# Legend for graph and table interpretation
legend: {
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: "#f8f9fa"
  }
  title: "Legend" {
    shape: text
    style: { bold: true }
  }
  gpipe_label: "GPipe Schedule (Synchronous)" {
    shape: text
    style: { font-size: 12 }
  }
  gpipe_line: " " {
    shape: rectangle
    width: 30
    height: 3
    style: { fill: "#e74c3c" }
  }
  gpipe_line -> gpipe_label: { style: { opacity: 0 } }
  
  oneF1b_label: "1F1B Schedule (Asynchronous)" {
    shape: text
    style: { font-size: 12 }
  }
  oneF1b_line: " " {
    shape: rectangle
    width: 30
    height: 3
    style: { fill: "#3498db" }
  }
  oneF1b_line -> oneF1b_label: { style: { opacity: 0 } }
  
  pp_markers: {
    grid-columns: 2
    pp2_marker: " " { shape: circle; width: 10; style.fill: "#2ecc71" }
    pp2_label: "PP=2"
    pp4_marker: " " { shape: diamond; width: 12; style.fill: "#9b59b6" }
    pp4_label: "PP=4"
    pp8_marker: " " { shape: square; width: 10; style.fill: "#e67e22" }
    pp8_label: "PP=8"
  }
}

# Mathematical Definitions
formulas: {
  shape: rectangle
  style: {
    stroke: "#34495e"
    stroke-width: 2
    fill: "#ecf0f1"
  }
  title: "Bubble Complexity Formulas" {
    shape: text
    style: { bold: true; underline: true; font-size: 14 }
  }
  gpipe_formula: |md
    **GPipe Bubble Fraction**
    $f_{bubble} = \frac{2(P-1)}{M + 2(P-1)}$
    *P=Stages, M=Micro-batches*
  | { shape: text }
  
  oneF1b_formula: |md
    **1F1B Bubble Fraction**
    $f_{bubble} = \frac{P-1}{M + P - 1}$
    *Reduces bubble by ~50% vs GPipe*
  | { shape: text }
}

# GPipe Schedule Analysis Table (Fixed: Converted to Grid for multi-column data display)
gpipe_analysis: {
  grid-columns: 4
  grid-gap: 0
  style: { fill: "#fdf2f2"; stroke: "#e74c3c" }
  
  # Header Row
  h1: "**PP Degree**" { style.fill: "#f8d7da" }
  h2: "**Micro-batches**" { style.fill: "#f8d7da" }
  h3: "**Fraction**" { style.fill: "#f8d7da" }
  h4: "**Percent**" { style.fill: "#f8d7da" }
  
  # Data Rows
  "2"; "4"; "0.333"; "33.3%"
  "2"; "8"; "0.200"; "20.0%"
  "4"; "8"; "0.467"; "46.7%"
  "8"; "16"; "0.467"; "46.7%"
  
  label: "GPipe Schedule Data"
  label.near: top-center
}

# 1F1B Schedule Analysis Table (Fixed: Converted to Grid for multi-column data display)
oneF1b_analysis: {
  grid-columns: 4
  grid-gap: 0
  style: { fill: "#ebf5fb"; stroke: "#3498db" }
  
  # Header Row
  h1: "**PP Degree**" { style.fill: "#d6eaf8" }
  h2: "**Micro-batches**" { style.fill: "#d6eaf8" }
  h3: "**Fraction**" { style.fill: "#d6eaf8" }
  h4: "**Percent**" { style.fill: "#d6eaf8" }
  
  # Data Rows
  "2"; "4"; "0.200"; "20.0%"
  "2"; "8"; "0.111"; "11.1%"
  "4"; "8"; "0.273"; "27.3%"
  "8"; "16"; "0.304"; "30.4%"
  
  label: "1F1B Schedule Data"
  label.near: top-center
}

# Visual Graph Representation
bubble_graph: {
  style: {
    stroke: "#2c3e50"
    stroke-width: 3
    fill: "#ffffff"
  }
  title: "Bubble Fraction Efficiency Graph" {
    shape: text
    style: { bold: true; font-size: 16 }
  }

  y_axis: " " {
    shape: rectangle
    width: 3
    height: 200
    style: { fill: "#2c3e50" }
  }
  
  y_labels: {
    y_50: "50%" { shape: text }
    y_25: "25%" { shape: text }
    y_0: "0%" { shape: text }
  }

  data_points: {
    grid-rows: 2
    grid-columns: 3
    
    p2_g: "GPipe P=2" { shape: circle; style.fill: "#2ecc71" }
    p4_g: "GPipe P=4" { shape: diamond; style.fill: "#9b59b6" }
    p8_g: "GPipe P=8" { shape: square; style.fill: "#e67e22" }
    
    p2_1: "1F1B P=2" { shape: circle; style.stroke-dash: 2; style.fill: "#2ecc71" }
    p4_1: "1F1B P=4" { shape: diamond; style.stroke-dash: 2; style.fill: "#9b59b6" }
    p8_1: "1F1B P=8" { shape: square; style.stroke-dash: 2; style.fill: "#e67e22" }
  }

  x_axis: " " {
    shape: rectangle
    width: 300
    height: 3
    style: { fill: "#2c3e50" }
  }
  x_label: "Micro-batch Count (M) →" { shape: text }
}

# Key Insights Block
insights: {
  style: {
    stroke: "#16a085"
    stroke-width: 2
    fill: "#e8f8f5"
  }
  title: "Key Performance Insights" {
    shape: text
    style: { bold: true; underline: true; font-size: 14 }
  }
  content: |md
    - **1F1B Advantage**: Consistently achieves ~50% lower bubble than GPipe due to interleaved forward/backward passes.
    - **Scaling Law**: Higher PP degrees require linearly more micro-batches (M) to maintain the same efficiency.
    - **Efficiency Threshold**: For <10% bubble with 1F1B, target $M \ge 9 \times (P-1)$.
    - **Memory Tradeoff**: Increasing M reduces bubble but increases activation memory footprint.
  | { shape: text }
}

# Configuration Recommendations (Fixed: Converted to Grid)
recommendations: {
  grid-columns: 1
  style: {
    stroke: "#2980b9"
    stroke-width: 2
    fill: "#ebf5fb"
  }
  title: "Configuration Recommendations" {
    shape: text
    style: { bold: true; underline: true; font-size: 14 }
  }
  rec_table: {
    grid-columns: 3
    grid-gap: 0
    style.fill: white
    # Header
    "**PP Degree (P)**"; "**Min Microbatches (M)**"; "**Optimal Schedule**"
    # Data
    "2"; "8"; "1F1B"
    "4"; "24"; "1F1B"
    "8"; "48"; "1F1B"
  }
}

# Layout constraints
title -> subtitle
subtitle -> legend
legend -> formulas
formulas -> gpipe_analysis
gpipe_analysis -> oneF1b_analysis
oneF1b_analysis -> bubble_graph
bubble_graph -> insights
insights -> recommendations