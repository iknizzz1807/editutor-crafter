direction: right
layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

title: {
  label: "GPipe vs 1F1B Pipeline Parallelism Memory Comparison"
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# Memory Scale Legend
legend: {
  near: top-right
  label: "Visualization Key"
  gpipe_color: GPipe Peak Memory {
    style.fill: "#ff6b6b"
  }
  onef_color: 1F1B Peak Memory {
    style.fill: "#4ecdc4"
  }
  bubble_color: Pipeline Bubble (Idle) {
    style.fill: "#ffe066"
  }
}

# GPipe Section
gpipe_container: {
  label: "GPipe Scheduling Strategy (Synchronous)"
  style: {
    fill: "#fff5f5"
    stroke: "#ff6b6b"
    stroke-width: 4
  }

  time_axis_gpipe: "Timeline (T) →" {
    shape: text
    style.italic: true
  }

  gpipe_memory_viz: {
    label: "Activation Memory Usage over Time"
    style.fill: "#ffffff"
    style.stroke: "#dee2e6"
    width: 650
    height: 400

    mem_axis: "Memory (Bytes) ↑" {
      shape: text
    }

    # Graph plotting area
    graph: {
      shape: rectangle
      style.fill: transparent
      style.stroke: "#e9ecef"
      
      forward_phase: {
        label: "Forward Phase: Memory O(M)"
        tooltip: "Linear growth as M micro-batches accumulate activations"
        shape: parallelogram
        style: {
          fill: "#ff6b6b"
          opacity: 0.6
        }
        width: 300
        height: 250
      }

      peak_marker: {
        label: "PEAK: 10.72 GB\n(M=32 activations)"
        shape: circle
        style: {
          fill: "#c92a2a"
          font-color: white
          bold: true
        }
      }

      backward_drain: {
        label: "Backward Phase: Memory release"
        shape: parallelogram
        style: {
          fill: "#ffa8a8"
          opacity: 0.4
        }
        width: 300
        height: 250
      }

      forward_phase -> peak_marker: "M micro-batches filled"
      peak_marker -> backward_drain: "Releasing activations"
    }

    bubble: "Pipeline Bubble (Stage Idle Time)" {
      style.fill: "#ffe066"
      style.opacity: 0.5
    }
  }

  gpipe_info: {
    label: |md
### GPipe Characteristics
- **Execution**: All M forward passes must complete before backward passes start.
- **Peak Memory**: $O(M)$ activations stored.
- **Bottleneck**: Last stage must wait for all micro-batches to arrive.
- **Stash Scale**: For M=32, device holds 32 sets of activations.
    |
    style.fill: "#fff0f0"
    style.stroke: "#ff6b6b"
  }
}

# 1F1B Section
onefoneb_container: {
  label: "1F1B Strategy (One-Forward-One-Backward)"
  style: {
    fill: "#f0fffc"
    stroke: "#4ecdc4"
    stroke-width: 4
  }

  time_axis_1f1b: "Timeline (T) →" {
    shape: text
    style.italic: true
  }

  onefoneb_memory_viz: {
    label: "Activation Memory Usage over Time"
    style.fill: "#ffffff"
    style.stroke: "#dee2e6"
    width: 650
    height: 400

    mem_axis: "Memory (Bytes) ↑" {
      shape: text
    }

    graph: {
      shape: rectangle
      style.fill: transparent
      
      warmup: "Warmup: Fill Pipeline" {
        style.fill: "#4ecdc4"
        style.opacity: 0.3
        width: 150
        height: 120
      }

      steady_state: "Steady State: 1F1B Interleaving" {
        tooltip: "Memory is constant as 1 FWD is matched by 1 BWD"
        style.fill: "#20c997"
        style.opacity: 0.6
        width: 300
        height: 120
      }

      cooldown: "Cooldown: Drain Pipeline" {
        style.fill: "#4ecdc4"
        style.opacity: 0.3
        width: 150
        height: 120
      }

      peak_marker: {
        label: "PEAK: 5.36 GB\n(P=4 activations)"
        shape: circle
        style: {
          fill: "#087f5b"
          font-color: white
          bold: true
        }
      }

      # Visualization of the bounded memory
      mem_limit: "Memory Bound O(P)" {
        shape: rectangle
        style: {
          stroke: "#087f5b"
          stroke-dash: 5
          stroke-width: 2
          fill: transparent
        }
        width: 600
        height: 130
      }

      warmup -> steady_state -> cooldown
    }
  }

  onefoneb_info: {
    label: |md
### 1F1B Characteristics
- **Execution**: Once pipeline is full (P steps), each forward is followed by a backward.
- **Peak Memory**: $O(P)$ activations stored.
- **Efficiency**: Activations are consumed almost immediately after generation.
- **Stash Scale**: For P=4, device holds only 4 sets of activations regardless of M.
    |
    style.fill: "#e6fcf5"
    style.stroke: "#4ecdc4"
  }
}

# Comparison Summary Section
comparison_summary: {
  label: "Analysis & Metrics Comparison"
  style.fill: "#f8f9fa"
  
  metrics: ||md
| Metric | GPipe (Baseline) | 1F1B (Optimized) | Impact |
| :--- | :--- | :--- | :--- |
| **Peak Activation Mem** | $O(M)$ | $O(P)$ | **Significant Reduction** |
| **Example (M=32, P=4)** | 32 units | 4 units | 8x Memory Efficiency |
| **70B Parameter Model** | ~10.72 GB | ~5.36 GB | 50% Activation Savings |
| **Throughput** | High | High | Equivalent |
| **Bubble Size** | (P-1)/M | (P-1)/M | Equivalent |
  ||

  conclusion: {
    label: ||md
**Key Engineering Insight**:
The 1F1B scheduler decouples activation memory from the number of micro-batches (M). 
This allows engineers to increase M to amortize optimizer overhead without hitting OOM limits, 
effectively bypassing the memory wall of traditional pipeline parallelism.
    ||
    style: {
      fill: "#fff3bf"
      stroke: "#fab005"
      bold: true
    }
  }
}

# Layout connections
gpipe_container -> onefoneb_container: "Reduce Activation Stash" {
  style.stroke: "#868e96"
  style.stroke-dash: 5
}

onefoneb_container -> comparison_summary: "Validation" {
  style.stroke: transparent
}