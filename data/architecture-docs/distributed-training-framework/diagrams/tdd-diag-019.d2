direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  dp_size: 2
  tp_size: 2
  pp_size: 2
  total_gpus: 8
}

# Diagram Title as a Header Shape
header: {
  label: "3D Parallelism Process Grid | DP × TP × PP Architecture"
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# Legend for process group colors and communication types
legend: {
  shape: rectangle
  style.stroke-dash: 4
  style.fill: "#1a1a2e"
  
  legend_title: {
    label: "Process Group & Interconnect Legend"
    shape: text
    style.font-size: 16
    style.bold: true
  }

  tp_group: {
    label: "Tensor Parallel (TP)\nNVLink All-Reduce"
    shape: rectangle
    style.fill: "#4a90d9"
    style.font-color: white
  }
  
  pp_group: {
    label: "Pipeline Parallel (PP)\nIB P2P Send/Recv"
    shape: rectangle
    style.fill: "#50c878"
    style.font-color: white
  }
  
  dp_group: {
    label: "Data Parallel (DP)\nIB/RoCE All-Reduce"
    shape: rectangle
    style.fill: "#ff6b6b"
    style.font-color: white
  }

  legend_title -> tp_group -> pp_group -> dp_group: {style.stroke: transparent}
}

# Coordinate System Definition and Calculation Logic
coordinate_system: {
  label: Rank Coordinate System
  shape: rectangle
  style.fill: "#0d1117"
  style.font-color: white
  
  coord_title: {
    label: "GPU Rank Mapping: (tp_rank, pp_rank, dp_rank)"
    shape: text
    style.font-size: 18
    style.bold: true
    style.underline: true
    style.font-color: "#50c878"
  }
  
  formula: |'md
    ### Global Rank Calculation
    The global rank is determined using a nested stride approach based on the parallelism dimensions:
    
    `global_rank = (dp_rank × pp_size + pp_rank) × tp_size + tp_rank`
    
    **Rank Grid (PP=2, TP=2, DP=2):**
    - **GPU 0:** (0, 0, 0) → (0×2+0)×2+0 = **0**
    - **GPU 1:** (1, 0, 0) → (0×2+0)×2+1 = **1**
    - **GPU 2:** (0, 1, 0) → (0×2+1)×2+0 = **2**
    - **GPU 3:** (1, 1, 0) → (0×2+1)×2+1 = **3**
    - **GPU 4:** (0, 0, 1) → (1×2+0)×2+0 = **4**
    - **GPU 5:** (1, 0, 1) → (1×2+0)×2+1 = **5**
    - **GPU 6:** (0, 1, 1) → (1×2+1)×2+0 = **6**
    - **GPU 7:** (1, 1, 1) → (1×2+1)×2+1 = **7**
  '|
}

# 3D Grid Visualization
process_grid: {
  label: "Distributed Process Grid (8 GPU Topology)"
  style.fill: "#0d1117"
  style.stroke: "#30363d"
  style.font-color: white

  # DP=0 slice
  dp0_slice: {
    label: "Data Parallel Rank = 0"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#ff6b6b"
    style.stroke-width: 4
    
    # PP Stage 0
    pp0_dp0: {
      label: "PP Stage 0"
      shape: rectangle
      style.fill: "#1c2128"
      style.stroke: "#50c878"
      style.stroke-width: 2
      
      tp0_pp0_dp0: {
        label: "GPU 0\n(0,0,0)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp1_pp0_dp0: {
        label: "GPU 1\n(1,0,0)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp0_pp0_dp0 <-> tp1_pp0_dp0: "TP All-Reduce" {
        style.stroke: "#4a90d9"
        style.stroke-width: 3
        style.animated: true
      }
    }
    
    # PP Stage 1
    pp1_dp0: {
      label: "PP Stage 1"
      shape: rectangle
      style.fill: "#1c2128"
      style.stroke: "#50c878"
      style.stroke-width: 2
      
      tp0_pp1_dp0: {
        label: "GPU 2\n(0,1,0)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp1_pp1_dp0: {
        label: "GPU 3\n(1,1,0)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp0_pp1_dp0 <-> tp1_pp1_dp0: "TP All-Reduce" {
        style.stroke: "#4a90d9"
        style.stroke-width: 3
        style.animated: true
      }
    }
    
    pp0_dp0 -> pp1_dp0: "Activations" {
      style.stroke: "#50c878"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
    pp1_dp0 -> pp0_dp0: "Gradients" {
      style.stroke: "#50c878"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
  }

  # DP=1 slice
  dp1_slice: {
    label: "Data Parallel Rank = 1"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#ff6b6b"
    style.stroke-width: 4
    
    # PP Stage 0
    pp0_dp1: {
      label: "PP Stage 0"
      shape: rectangle
      style.fill: "#1c2128"
      style.stroke: "#50c878"
      style.stroke-width: 2
      
      tp0_pp0_dp1: {
        label: "GPU 4\n(0,0,1)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp1_pp0_dp1: {
        label: "GPU 5\n(1,0,1)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp0_pp0_dp1 <-> tp1_pp0_dp1: "TP All-Reduce" {
        style.stroke: "#4a90d9"
        style.stroke-width: 3
      }
    }
    
    # PP Stage 1
    pp1_dp1: {
      label: "PP Stage 1"
      shape: rectangle
      style.fill: "#1c2128"
      style.stroke: "#50c878"
      style.stroke-width: 2
      
      tp0_pp1_dp1: {
        label: "GPU 6\n(0,1,1)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp1_pp1_dp1: {
        label: "GPU 7\n(1,1,1)"
        shape: hexagon
        style.fill: "#4a90d9"
      }
      tp0_pp1_dp1 <-> tp1_pp1_dp1: "TP All-Reduce" {
        style.stroke: "#4a90d9"
        style.stroke-width: 3
      }
    }
    
    pp0_dp1 <-> pp1_dp1: "Pipeline Comm" {
      style.stroke: "#50c878"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
  }

  # Connection between DP Slices
  dp0_slice <-> dp1_slice: "DP All-Reduce (Gradient Sync)" {
    style.stroke: "#ff6b6b"
    style.stroke-width: 5
    style.stroke-dash: 8
  }
}

# Process Groups Detail
process_groups: {
  label: "Logical Process Group Membership"
  style.fill: "#0d1117"
  style.font-color: white

  # TP Groups
  tp_groups: {
    label: "Tensor Parallel Groups (intra-node)"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#4a90d9"
    style.stroke-width: 2
    
    tp_group_0: "TP_GROUP[0]: {GPU0, GPU1}" { style.fill: "#4a90d9" }
    tp_group_1: "TP_GROUP[1]: {GPU2, GPU3}" { style.fill: "#4a90d9" }
    tp_group_2: "TP_GROUP[2]: {GPU4, GPU5}" { style.fill: "#4a90d9" }
    tp_group_3: "TP_GROUP[3]: {GPU6, GPU7}" { style.fill: "#4a90d9" }
    
    tp_note: |'md
      **Formation:** Same pp_rank, same dp_rank.
      **Scope:** Usually within a single node over NVLink.
    '| {
      shape: text
      style.font-size: 11
    }
  }

  # PP Groups
  pp_groups: {
    label: "Pipeline Parallel Groups"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#50c878"
    style.stroke-width: 2
    
    pp_group_0: "PP_GROUP[0]: {GPU0, GPU2}" { style.fill: "#50c878" }
    pp_group_1: "PP_GROUP[1]: {GPU1, GPU3}" { style.fill: "#50c878" }
    pp_group_2: "PP_GROUP[2]: {GPU4, GPU6}" { style.fill: "#50c878" }
    pp_group_3: "PP_GROUP[3]: {GPU5, GPU7}" { style.fill: "#50c878" }
    
    pp_note: |'md
      **Formation:** Same tp_rank, same dp_rank.
      **Scope:** Inter-stage communication.
    '| {
      shape: text
      style.font-size: 11
    }
  }

  # DP Groups
  dp_groups: {
    label: "Data Parallel Groups"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    
    dp_group_0: "DP_GROUP[0]: {GPU0, GPU4}" { style.fill: "#ff6b6b" }
    dp_group_1: "DP_GROUP[1]: {GPU1, GPU5}" { style.fill: "#ff6b6b" }
    dp_group_2: "DP_GROUP[2]: {GPU2, GPU6}" { style.fill: "#ff6b6b" }
    dp_group_3: "DP_GROUP[3]: {GPU3, GPU7}" { style.fill: "#ff6b6b" }
    
    dp_note: |'md
      **Formation:** Same tp_rank, same pp_rank.
      **Scope:** Cross-node gradient synchronization.
    '| {
      shape: text
      style.font-size: 11
    }
  }
}

# Summary Relationships
orthogonal_summary: {
  label: "Orthogonal Process Group Relationships"
  shape: rectangle
  style.fill: "#0d1117"
  style.font-color: white

  ortho_title: {
    label: "Each GPU belongs to exactly 3 process groups (one per dimension)"
    shape: text
    style.font-size: 16
    style.bold: true
    style.font-color: "#4a90d9"
  }
  
  gpu0_example: |'md
    **Example Analysis: GPU 0 (0, 0, 0)**
    | Dimension | Group Identifier | Members | Purpose |
    | :--- | :--- | :--- | :--- |
    | **Tensor (TP)** | tp_rank=0 | {GPU0, GPU1} | Multi-head/Linear sharding |
    | **Pipeline (PP)** | pp_rank=0 | {GPU0, GPU2} | Sequential layer partition |
    | **Data (DP)** | dp_rank=0 | {GPU0, GPU4} | Parameter/Gradient sync |
  '| {
    shape: text
    style.font-size: 12
  }
  
  ortho_matrix: |'md
    **Intersection Logic (Total Size = TP × PP × DP)**
    | Metric | TP Dimension | PP Dimension | DP Dimension |
    | :--- | :--- | :--- | :--- |
    | **Group Count** | 4 | 4 | 4 |
    | **Group Size** | 2 | 2 | 2 |
    | **Communication** | All-Reduce | P2P Send/Recv | All-Reduce |
  '| {
    shape: text
    style.font-size: 12
  }
}

# Layout constraints for vertical flow
header -> legend: {style.stroke: transparent}
legend -> coordinate_system: {style.stroke: transparent}
coordinate_system -> process_grid: {style.stroke: transparent}
process_grid -> process_groups: {style.stroke: transparent}
process_groups -> orthogonal_summary: {style.stroke: transparent}