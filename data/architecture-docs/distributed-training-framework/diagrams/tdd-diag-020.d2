direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "3D Topology Mapping\nLogical Process Grid → Physical Cluster Topology" {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  style: {
    stroke: "#666666"
    stroke-dash: 4
    fill: "#fafafa"
  }
  
  legend_title: "LEGEND" {
    shape: text
    style: { bold: true; font-size: 14 }
  }
  
  nvlink_legend: "NVLink Domain\n(300-600 GB/s)" {
    shape: rectangle
    style: { fill: "#e8f5e9"; stroke: "#4caf50" }
  }
  
  ib_legend: "InfiniBand\n(12-25 GB/s)" {
    shape: rectangle
    style: { fill: "#e3f2fd"; stroke: "#2196f3" }
  }
  
  tp_group: "TP Group\n(Intra-Node)" {
    shape: rectangle
    style: { fill: "#fff3e0"; stroke: "#ff9800" }
  }
  
  pp_group: "PP Group\n(Inter-Node P2P)" {
    shape: rectangle
    style: { fill: "#fce4ec"; stroke: "#e91e63" }
  }
  
  dp_group: "DP Group\n(Inter-Node AllReduce)" {
    shape: rectangle
    style: { fill: "#f3e5f5"; stroke: "#9c27b0" }
  }
  
  nvlink_legend -> ib_legend -> tp_group -> pp_group -> dp_group: {
    style: { opacity: 0 }
  }
}

# -----------------------------------------------------------------------------------------
# LOGICAL PROCESS GRID
# -----------------------------------------------------------------------------------------
formula_box: "Process Grid Formula:\nglobal_rank = (dp_rank × pp_size + pp_rank) × tp_size + tp_rank\n\nGrid: DP=2 × TP=4 × PP=2 = 16 GPUs across 4 Nodes" {
  shape: rectangle
  style: {
    fill: "#fff8e1"
    stroke: "#ffc107"
    stroke-width: 2
    font-size: 11
  }
}

logical_grid: "Logical Process Grid\n(DP × TP × PP)" {
  style: {
    fill: "#fafafa"
    stroke: "#333333"
    stroke-width: 2
  }

  dp0: "DP Rank 0" {
    style: { fill: "#e8eaf6"; stroke: "#3f51b5" }
    
    dp0_pp0: "PP=0" {
      style: { fill: "#fce4ec"; stroke: "#e91e63" }
      dp0_pp0_tp0: "R0\nTP=0" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp0_tp1: "R1\nTP=1" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp0_tp2: "R2\nTP=2" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp0_tp3: "R3\nTP=3" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp0_tp0 -> dp0_pp0_tp1 -> dp0_pp0_tp2 -> dp0_pp0_tp3: {
        style: { stroke: "#ff9800"; stroke-width: 2 }
      }
    }
    
    dp0_pp1: "PP=1" {
      style: { fill: "#fce4ec"; stroke: "#e91e63" }
      dp0_pp1_tp0: "R8\nTP=0" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp1_tp1: "R9\nTP=1" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp1_tp2: "R10\nTP=2" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp1_tp3: "R11\nTP=3" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp0_pp1_tp0 -> dp0_pp1_tp1 -> dp0_pp1_tp2 -> dp0_pp1_tp3: {
        style: { stroke: "#ff9800"; stroke-width: 2 }
      }
    }
  }

  dp1: "DP Rank 1" {
    style: { fill: "#e8eaf6"; stroke: "#3f51b5" }
    
    dp1_pp0: "PP=0" {
      style: { fill: "#fce4ec"; stroke: "#e91e63" }
      dp1_pp0_tp0: "R4\nTP=0" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp0_tp1: "R5\nTP=1" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp0_tp2: "R6\nTP=2" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp0_tp3: "R7\nTP=3" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp0_tp0 -> dp1_pp0_tp1 -> dp1_pp0_tp2 -> dp1_pp0_tp3: {
        style: { stroke: "#ff9800"; stroke-width: 2 }
      }
    }
    
    dp1_pp1: "PP=1" {
      style: { fill: "#fce4ec"; stroke: "#e91e63" }
      dp1_pp1_tp0: "R12\nTP=0" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp1_tp1: "R13\nTP=1" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp1_tp2: "R14\nTP=2" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp1_tp3: "R15\nTP=3" { style: { fill: "#fff3e0"; stroke: "#ff9800" } }
      dp1_pp1_tp0 -> dp1_pp1_tp1 -> dp1_pp1_tp2 -> dp1_pp1_tp3: {
        style: { stroke: "#ff9800"; stroke-width: 2 }
      }
    }
  }
}

mapping_arrow: "MAPPING\n→" {
  shape: text
  style: { font-size: 20; bold: true }
}

# -----------------------------------------------------------------------------------------
# PHYSICAL CLUSTER TOPOLOGY
# -----------------------------------------------------------------------------------------
physical_cluster: "Physical Cluster Topology" {
  style: {
    fill: "#f5f5f5"
    stroke: "#333333"
    stroke-width: 2
  }

  node0: "Node 0\n(PP=0, DP=0)" {
    style: { fill: "#e8f5e9"; stroke: "#4caf50"; stroke-width: 3 }
    node0_nvlink: "NVLink Domain\n600 GB/s Full Mesh" {
      style: { fill: "#c8e6c9"; stroke: "#4caf50"; stroke-dash: 3 }
      gpu0: "GPU 0\nR0" { shape: hexagon; style: { fill: "#81c784" } }
      gpu1: "GPU 1\nR1" { shape: hexagon; style: { fill: "#81c784" } }
      gpu2: "GPU 2\nR2" { shape: hexagon; style: { fill: "#81c784" } }
      gpu3: "GPU 3\nR3" { shape: hexagon; style: { fill: "#81c784" } }
      gpu0 -- gpu1: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu0 -- gpu2: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu0 -- gpu3: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu1 -- gpu2: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu1 -- gpu3: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu2 -- gpu3: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
    }
  }

  node1: "Node 1\n(PP=0, DP=1)" {
    style: { fill: "#e8f5e9"; stroke: "#4caf50"; stroke-width: 3 }
    node1_nvlink: "NVLink Domain\n600 GB/s Full Mesh" {
      style: { fill: "#c8e6c9"; stroke: "#4caf50"; stroke-dash: 3 }
      gpu4: "GPU 4\nR4" { shape: hexagon; style: { fill: "#81c784" } }
      gpu5: "GPU 5\nR5" { shape: hexagon; style: { fill: "#81c784" } }
      gpu6: "GPU 6\nR6" { shape: hexagon; style: { fill: "#81c784" } }
      gpu7: "GPU 7\nR7" { shape: hexagon; style: { fill: "#81c784" } }
      gpu4 -- gpu5: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu4 -- gpu6: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu4 -- gpu7: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu5 -- gpu6: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu5 -- gpu7: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu6 -- gpu7: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
    }
  }

  node2: "Node 2\n(PP=1, DP=0)" {
    style: { fill: "#e8f5e9"; stroke: "#4caf50"; stroke-width: 3 }
    node2_nvlink: "NVLink Domain\n600 GB/s Full Mesh" {
      style: { fill: "#c8e6c9"; stroke: "#4caf50"; stroke-dash: 3 }
      gpu8: "GPU 8\nR8" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu9: "GPU 9\nR9" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu10: "GPU 10\nR10" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu11: "GPU 11\nR11" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu8 -- gpu9: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu8 -- gpu10: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu8 -- gpu11: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu9 -- gpu10: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu9 -- gpu11: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu10 -- gpu11: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
    }
  }

  node3: "Node 3\n(PP=1, DP=1)" {
    style: { fill: "#e8f5e9"; stroke: "#4caf50"; stroke-width: 3 }
    node3_nvlink: "NVLink Domain\n600 GB/s Full Mesh" {
      style: { fill: "#c8e6c9"; stroke: "#4caf50"; stroke-dash: 3 }
      gpu12: "GPU 12\nR12" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu13: "GPU 13\nR13" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu14: "GPU 14\nR14" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu15: "GPU 15\nR15" { shape: hexagon; style: { fill: "#a5d6a7" } }
      gpu12 -- gpu13: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu12 -- gpu14: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu12 -- gpu15: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu13 -- gpu14: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu13 -- gpu15: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
      gpu14 -- gpu15: "NVLink" { style: { stroke: "#4caf50"; stroke-width: 3 } }
    }
  }
}

# -----------------------------------------------------------------------------------------
# FABRIC AND COMMUNICATION
# -----------------------------------------------------------------------------------------
ib_fabric: "InfiniBand Fabric\nHDR 200 Gb/s (25 GB/s per link)" {
  shape: rectangle
  style: {
    fill: "#e3f2fd"
    stroke: "#2196f3"
    stroke-width: 3
  }
}

physical_cluster.node0 -> ib_fabric: "IB\nP2P Send" {
  style: { stroke: "#2196f3"; stroke-width: 4; animated: true }
}
physical_cluster.node1 -> ib_fabric: "IB\nP2P Send" {
  style: { stroke: "#2196f3"; stroke-width: 4; animated: true }
}
ib_fabric -> physical_cluster.node2: "IB\nP2P Recv" {
  style: { stroke: "#2196f3"; stroke-width: 4; animated: true }
}
ib_fabric -> physical_cluster.node3: "IB\nP2P Recv" {
  style: { stroke: "#2196f3"; stroke-width: 4; animated: true }
}

physical_cluster.node0 <-> physical_cluster.node1: "DP AllReduce\n(IB)" {
  style: { stroke: "#9c27b0"; stroke-width: 3; stroke-dash: 5 }
}
physical_cluster.node2 <-> physical_cluster.node3: "DP AllReduce\n(IB)" {
  style: { stroke: "#9c27b0"; stroke-width: 3; stroke-dash: 5 }
}

pp_flow: "PP Pipeline Flow\nStage 0 → Stage 1" {
  shape: rectangle
  style: {
    fill: "#fce4ec"
    stroke: "#e91e63"
    stroke-width: 2
  }
}

physical_cluster.node0 -> pp_flow: { style: { stroke: "#e91e63"; stroke-width: 2 } }
pp_flow -> physical_cluster.node2: { style: { stroke: "#e91e63"; stroke-width: 2 } }

comm_patterns: "Communication Patterns" {
  style: {
    fill: "#fafafa"
    stroke: "#333"
    stroke-width: 2
  }
  tp_pattern: "Tensor Parallelism (TP)\n• All-Reduce every layer\n• Requires NVLink bandwidth\n• Latency: ~5μs" {
    style: { fill: "#fff3e0"; stroke: "#ff9800" }
  }
  pp_pattern: "Pipeline Parallelism (PP)\n• Point-to-point Send/Recv\n• Tolerates IB latency\n• Bubble overhead: ~10-15%" {
    style: { fill: "#fce4ec"; stroke: "#e91e63" }
  }
  dp_pattern: "Data Parallelism (DP)\n• All-Reduce once per step\n• Gradient sync via IB\n• Overlap with compute" {
    style: { fill: "#f3e5f5"; stroke: "#9c27b0" }
  }
  tp_pattern -> pp_pattern -> dp_pattern: { style: { opacity: 0 } }
}

# -----------------------------------------------------------------------------------------
# MAPPING VISUALIZATION
# -----------------------------------------------------------------------------------------
logical_grid.dp0.dp0_pp0.dp0_pp0_tp0 -> physical_cluster.node0.node0_nvlink.gpu0: {
  style: { stroke: "#666"; stroke-dash: 3; opacity: 0.5 }
}
logical_grid.dp0.dp0_pp1.dp0_pp1_tp0 -> physical_cluster.node2.node2_nvlink.gpu8: {
  style: { stroke: "#666"; stroke-dash: 3; opacity: 0.5 }
}
logical_grid.dp1.dp1_pp0.dp1_pp0_tp0 -> physical_cluster.node1.node1_nvlink.gpu4: {
  style: { stroke: "#666"; stroke-dash: 3; opacity: 0.5 }
}
logical_grid.dp1.dp1_pp1.dp1_pp1_tp0 -> physical_cluster.node3.node3_nvlink.gpu12: {
  style: { stroke: "#666"; stroke-dash: 3; opacity: 0.5 }
}

# SPATIAL ALIGNMENT HINTS
formula_box -- logical_grid: { style: { opacity: 0 } }
logical_grid -- mapping_arrow: { style: { opacity: 0 } }
mapping_arrow -- physical_cluster: { style: { opacity: 0 } }
physical_cluster -- comm_patterns: { style: { opacity: 0 } }
legend -- formula_box: { style: { opacity: 0 } }