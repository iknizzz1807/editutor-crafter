direction: right
layout-engine: elk
title: ZeRO Stages Memory Comparison {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: Memory Breakdown for 70B Model (per GPU with DP=8) {
  shape: text
  style: {
    font-size: 14
    italic: true
  }
}
legend: {
  shape: rectangle
  style.fill: "#f8f9fa"
  params_legend: "Parameters" {
    shape: rectangle
    style.fill: "#4285f4"
    style.stroke: "#1a73e8"
  }
  grads_legend: "Gradients" {
    shape: rectangle
    style.fill: "#34a853"
    style.stroke: "#1e8e3e"
  }
  optim_legend: "Optimizer States" {
    shape: rectangle
    style.fill: "#ea4335"
    style.stroke: "#d33426"
  }
  params_legend -- grads_legend -- optim_legend
}
# No ZeRO - 840GB total (140GB params, 140GB grads, 560GB optimizer)
no_zero: {
  label: "No ZeRO"
  shape: rectangle
  style.fill: "#ffffff"
  style.stroke: "#dadce0"
  bar_container: {
    shape: rectangle
    style.fill: "#ffffff"
    style.stroke: "transparent"
    width: 120
    height: 300
    # Optimizer states (560GB - scaled to 200px height)
    optim_bar: {
      shape: rectangle
      style.fill: "#ea4335"
      style.stroke: "#d33426"
      width: 100
      height: 200
      label: "560 GB"
      style.font-size: 10
    }
    # Gradients (140GB - scaled to 50px height)
    grads_bar: {
      shape: rectangle
      style.fill: "#34a853"
      style.stroke: "#1e8e3e"
      width: 100
      height: 50
      label: "140 GB"
      style.font-size: 10
    }
    # Parameters (140GB - scaled to 50px height)
    params_bar: {
      shape: rectangle
      style.fill: "#4285f4"
      style.stroke: "#1a73e8"
      width: 100
      height: 50
      label: "140 GB"
      style.font-size: 10
    }
  }
  total_label: "Total: 840 GB" {
    shape: text
    style.bold: true
    style.font-size: 14
  }
}
# ZeRO-1 - 280GB total (140GB params, 140GB grads, 70GB optimizer sharded)
zero1: {
  label: "ZeRO-1"
  shape: rectangle
  style.fill: "#ffffff"
  style.stroke: "#dadce0"
  bar_container: {
    shape: rectangle
    style.fill: "#ffffff"
    style.stroke: "transparent"
    width: 120
    height: 300
    # Optimizer states (70GB - scaled to 25px height)
    optim_bar: {
      shape: rectangle
      style.fill: "#ea4335"
      style.stroke: "#d33426"
      width: 100
      height: 25
      label: "70 GB"
      style.font-size: 9
    }
    # Gradients (140GB - scaled to 50px height)
    grads_bar: {
      shape: rectangle
      style.fill: "#34a853"
      style.stroke: "#1e8e3e"
      width: 100
      height: 50
      label: "140 GB"
      style.font-size: 10
    }
    # Parameters (140GB - scaled to 50px height)
    params_bar: {
      shape: rectangle
      style.fill: "#4285f4"
      style.stroke: "#1a73e8"
      width: 100
      height: 50
      label: "140 GB"
      style.font-size: 10
    }
  }
  total_label: "Total: 350 GB" {
    shape: text
    style.bold: true
    style.font-size: 14
  }
  savings_label: "58% savings" {
    shape: text
    style.font-size: 11
    style.italic: true
    style.fill: "#1e8e3e"
  }
}
# ZeRO-2 - 175GB total (140GB params, 17.5GB grads, 17.5GB optimizer)
zero2: {
  label: "ZeRO-2"
  shape: rectangle
  style.fill: "#ffffff"
  style.stroke: "#dadce0"
  bar_container: {
    shape: rectangle
    style.fill: "#ffffff"
    style.stroke: "transparent"
    width: 120
    height: 300
    # Optimizer states (70GB/8 = 8.75GB - scaled to ~3px)
    optim_bar: {
      shape: rectangle
      style.fill: "#ea4335"
      style.stroke: "#d33426"
      width: 100
      height: 12
      label: "8.75 GB"
      style.font-size: 8
    }
    # Gradients (140GB/8 = 17.5GB - scaled to ~6px)
    grads_bar: {
      shape: rectangle
      style.fill: "#34a853"
      style.stroke: "#1e8e3e"
      width: 100
      height: 25
      label: "17.5 GB"
      style.font-size: 9
    }
    # Parameters (140GB - scaled to 50px height)
    params_bar: {
      shape: rectangle
      style.fill: "#4285f4"
      style.stroke: "#1a73e8"
      width: 100
      height: 50
      label: "140 GB"
      style.font-size: 10
    }
  }
  total_label: "Total: 166 GB" {
    shape: text
    style.bold: true
    style.font-size: 14
  }
  savings_label: "80% savings" {
    shape: text
    style.font-size: 11
    style.italic: true
    style.fill: "#1e8e3e"
  }
}
# ZeRO-3 - 26.25GB total (17.5GB params, 17.5GB grads, 8.75GB optimizer with TP=8)
zero3: {
  label: "ZeRO-3 + TP"
  shape: rectangle
  style.fill: "#ffffff"
  style.stroke: "#dadce0"
  bar_container: {
    shape: rectangle
    style.fill: "#ffffff"
    style.stroke: "transparent"
    width: 120
    height: 300
    # Optimizer states (8.75GB)
    optim_bar: {
      shape: rectangle
      style.fill: "#ea4335"
      style.stroke: "#d33426"
      width: 100
      height: 12
      label: "8.75 GB"
      style.font-size: 8
    }
    # Gradients (17.5GB/8 = 2.2GB with TP)
    grads_bar: {
      shape: rectangle
      style.fill: "#34a853"
      style.stroke: "#1e8e3e"
      width: 100
      height: 12
      label: "2.2 GB"
      style.font-size: 8
    }
    # Parameters (140GB/8 = 17.5GB with TP)
    params_bar: {
      shape: rectangle
      style.fill: "#4285f4"
      style.stroke: "#1a73e8"
      width: 100
      height: 12
      label: "17.5 GB"
      style.font-size: 8
    }
  }
  total_label: "Total: ~28 GB" {
    shape: text
    style.bold: true
    style.font-size: 14
  }
  savings_label: "97% savings" {
    shape: text
    style.font-size: 11
    style.italic: true
    style.fill: "#1e8e3e"
  }
}
# Connections to show progression
no_zero -> zero1 -> zero2 -> zero3 {
  style.stroke-dash: 3
  style.stroke: "#9aa0a6"
  label: "Memory Reduction"
}
# Annotations
annotation_no_zero: "All states replicated\non every GPU" {
  shape: text
  style.font-size: 10
  style.fill: "#5f6368"
  style.italic: true
}
annotation_zero1: "Optimizer states\nsharded across GPUs" {
  shape: text
  style.font-size: 10
  style.fill: "#5f6368"
  style.italic: true
}
annotation_zero2: "Optimizer + Gradients\nsharded across GPUs" {
  shape: text
  style.font-size: 10
  style.fill: "#5f6368"
  style.italic: true
}
annotation_zero3: "All states sharded\n+ Tensor Parallelism" {
  shape: text
  style.font-size: 10
  style.fill: "#5f6368"
  style.italic: true
}
no_zero -- annotation_no_zero
zero1 -- annotation_zero1
zero2 -- annotation_zero2
zero3 -- annotation_zero3