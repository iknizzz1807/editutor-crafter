direction: right
layout: elk
theme: 101
title: ZeRO-3 Forward Pass with Parameter Gathering {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
subtitle: On-Demand Parameter Fetching Across DP Ranks {
  near: top-center
  shape: text
  style: {
    font-size: 14
    italic: true
  }
}
# Legend box
legend: {
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: "#F8F9FA"
  }
  legend_title: {
    label: Legend
    shape: text
    style: {
      bold: true
      font-size: 12
    }
  }
  async_line: {
    shape: text
    label: "--> Async\n(message)"
  }
  sync_line: {
    shape: text
    label: "-> Sync\n(blocking)"
  }
  response_line: {
    shape: text
    label: "<-- Response"
  }
  note_box: {
    shape: text
    label: "[Note/State]"
  }
}
# Sequence diagram participants
DP_Rank_0: {
  shape: rectangle
  label: "DP Rank 0\n(owns W₀ shard)"
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
  }
}
DP_Rank_1: {
  shape: rectangle
  label: "DP Rank 1\n(owns W₁ shard)"
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
  }
}
DP_Rank_2: {
  shape: rectangle
  label: "DP Rank 2\n(owns W₂ shard)"
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
DP_Rank_3: {
  shape: rectangle
  label: "DP Rank 3\n(owns W₃ shard)"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
}
# Sequence connections
edge: {
  source: DP_Rank_0
  target: DP_Rank_1
  label: ""
}
# Phase 1: Parameter Fetch Request
phase1_box: {
  shape: rectangle
  label: "Phase 1: All-Gather Parameter Shards"
  style: {
    stroke-dash: 5
    fill: "#E3F2FD"
    stroke: "#1976D2"
    border-radius: 8
  }
}
# Memory state indicators
memory_initial: {
  shape: rectangle
  label: "Memory State:\n• Each rank holds 1/N of params\n• W = [W₀, W₁, W₂, W₃] sharded"
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
  }
}
DP_Rank_0 -> DP_Rank_1: {
  label: "AllGather(W₀)\n[broadcast local shard]"
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}
DP_Rank_0 -> DP_Rank_2: {
  label: "AllGather(W₀)"
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}
DP_Rank_0 -> DP_Rank_3: {
  label: "AllGather(W₀)"
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}
DP_Rank_1 -> DP_Rank_0: {
  label: "AllGather(W₁)"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
DP_Rank_1 -> DP_Rank_2: {
  label: "AllGather(W₁)"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
DP_Rank_1 -> DP_Rank_3: {
  label: "AllGather(W₁)"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
DP_Rank_2 -> DP_Rank_0: {
  label: "AllGather(W₂)"
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
}
DP_Rank_2 -> DP_Rank_1: {
  label: "AllGather(W₂)"
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
}
DP_Rank_2 -> DP_Rank_3: {
  label: "AllGather(W₂)"
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
}
DP_Rank_3 -> DP_Rank_0: {
  label: "AllGather(W₃)"
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
DP_Rank_3 -> DP_Rank_1: {
  label: "AllGather(W₃)"
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
DP_Rank_3 -> DP_Rank_2: {
  label: "AllGather(W₃)"
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
# Memory state after gather
memory_after_gather: {
  shape: rectangle
  label: "Memory State (Temporary):\n• Each rank now holds FULL W\n• W = concat(W₀, W₁, W₂, W₃)\n• ⚠️ Peak memory usage"
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
  }
}
# Phase 2: Local Computation
phase2_box: {
  shape: rectangle
  label: "Phase 2: Local Forward Computation"
  style: {
    stroke-dash: 5
    fill: "#E8F5E9"
    stroke: "#388E3C"
    border-radius: 8
  }
}
compute_0: {
  shape: rectangle
  label: "y₀ = Layer(x₀; W)"
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
  }
}
compute_1: {
  shape: rectangle
  label: "y₁ = Layer(x₁; W)"
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
  }
}
compute_2: {
  shape: rectangle
  label: "y₂ = Layer(x₂; W)"
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
  }
}
compute_3: {
  shape: rectangle
  label: "y₃ = Layer(x₃; W)"
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
  }
}
# Connect computes to ranks
DP_Rank_0 -> compute_0: {
  label: "forward"
  style: {
    stroke: "#388E3C"
    stroke-dash: 3
  }
}
DP_Rank_1 -> compute_1: {
  label: "forward"
  style: {
    stroke: "#388E3C"
    stroke-dash: 3
  }
}
DP_Rank_2 -> compute_2: {
  label: "forward"
  style: {
    stroke: "#388E3C"
    stroke-dash: 3
  }
}
DP_Rank_3 -> compute_3: {
  label: "forward"
  style: {
    stroke: "#388E3C"
    stroke-dash: 3
  }
}
# Phase 3: Parameter Release
phase3_box: {
  shape: rectangle
  label: "Phase 3: Release Gathered Parameters"
  style: {
    stroke-dash: 5
    fill: "#FFF3E0"
    stroke: "#F57C00"
    border-radius: 8
  }
}
release_0: {
  shape: rectangle
  label: "release(W)\nkeep only W₀"
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
release_1: {
  shape: rectangle
  label: "release(W)\nkeep only W₁"
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
release_2: {
  shape: rectangle
  label: "release(W)\nkeep only W₂"
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
release_3: {
  shape: rectangle
  label: "release(W)\nkeep only W₃"
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
  }
}
compute_0 -> release_0: {
  label: "after compute"
  style: {
    stroke: "#F57C00"
    stroke-dash: 3
  }
}
compute_1 -> release_1: {
  label: "after compute"
  style: {
    stroke: "#F57C00"
    stroke-dash: 3
  }
}
compute_2 -> release_2: {
  label: "after compute"
  style: {
    stroke: "#F57C00"
    stroke-dash: 3
  }
}
compute_3 -> release_3: {
  label: "after compute"
  style: {
    stroke: "#F57C00"
    stroke-dash: 3
  }
}
# Final memory state
memory_final: {
  shape: rectangle
  label: "Memory State (Released):\n• Back to sharded state\n• Only local shard retained\n• ✅ Memory minimized"
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
  }
}
release_0 -> memory_final: {
  label: ""
  style: {
    stroke: "transparent"
  }
}
release_1 -> memory_final: {
  label: ""
  style: {
    stroke: "transparent"
  }
}
release_2 -> memory_final: {
  label: ""
  style: {
    stroke: "transparent"
  }
}
release_3 -> memory_final: {
  label: ""
  style: {
    stroke: "transparent"
  }
}
# Next layer indicator
next_layer: {
  shape: rectangle
  label: "→ Repeat for next layer\n   (Gather → Compute → Release)"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    border-radius: 8
  }
}
memory_final -> next_layer: {
  label: ""
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
# Algorithm pseudocode box
algorithm: {
  shape: rectangle
  label: "ZeRO-3 Forward Algorithm\n────────────────────────────\nfor layer in model.layers:\n  # All-gather across DP group\n  W_full = all_gather(W_shard)\n  \n  # Local forward with full params\n  output = layer(x, W_full)\n  \n  # Release non-local shards\n  release(W_full)\n  keep(W_local_shard)\n"
  style: {
    fill: "#263238"
    font-color: "#ECEFF1"
    stroke: "#37474F"
    font: mono
  }
}
# Key metrics box
metrics: {
  shape: rectangle
  label: "Memory Efficiency\n───────────────────\nStandard DP:  1× params/rank\nZeRO-3:        1/N params/rank\n───────────────────\nN=4 shown\n(64× reduction with TP=8)"
  style: {
    fill: "#FAFAFA"
    stroke: "#607D8B"
  }
}