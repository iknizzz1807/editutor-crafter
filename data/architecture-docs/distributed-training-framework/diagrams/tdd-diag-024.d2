direction: right
layout-engine: elk
theme-id: 300
vars: {
    color-primary: "#0066CC"
    color-secondary: "#FF6B35"
    color-success: "#28A745"
    color-warning: "#FFC107"
    color-info: "#17A2B8"
    color-dark: "#343A40"
    color-light: "#F8F9FA"
}
classes: {
    rank-shard: {
        shape: rectangle
        style.fill: "${color-primary}"
        style.font-color: white
        style.stroke: "#004499"
        style.stroke-width: 2
        label: "Rank Shard"
    }
    metadata: {
        shape: document
        style.fill: "${color-info}"
        style.font-color: white
        style.stroke: "#117A8B"
    }
    valid-marker: {
        shape: diamond
        style.fill: "${color-success}"
        style.font-color: white
        style.stroke: "#1E7E34"
    }
    storage: {
        shape: cylinder
        style.fill: "${color-secondary}"
        style.font-color: white
        style.stroke: "#C9302C"
    }
    coordinator: {
        shape: hexagon
        style.fill: "${color-warning}"
        style.font-color: "${color-dark}"
        style.stroke: "#D39E00"
    }
}
title: {
    label: "Distributed Checkpoint Structure\nFault Tolerance Module (M5)"
    shape: text
    style.font-size: 24
    style.bold: true
    style.underline: true
}
checkpoint_coordinator: {
    class: coordinator
    label: "Checkpoint\nCoordinator"
}
process_groups: {
    label: "3D Parallelism Process Groups"
    tp_group: {
        label: "Tensor Parallel\nGroup (TP=4)"
        style.fill: "#E3F2FD"
        style.stroke: "${color-primary}"
        tp_rank_0: {
            class: rank-shard
            label: "TP Rank 0\nshard_tp0.pt"
        }
        tp_rank_1: {
            class: rank-shard
            label: "TP Rank 1\nshard_tp1.pt"
        }
        tp_rank_2: {
            class: rank-shard
            label: "TP Rank 2\nshard_tp2.pt"
        }
        tp_rank_3: {
            class: rank-shard
            label: "TP Rank 3\nshard_tp3.pt"
        }
    }
    pp_group: {
        label: "Pipeline Parallel\nGroup (PP=2)"
        style.fill: "#FFF3E0"
        style.stroke: "${color-secondary}"
        pp_stage_0: {
            class: rank-shard
            label: "PP Stage 0\nshard_pp0.pt"
        }
        pp_stage_1: {
            class: rank-shard
            label: "PP Stage 1\nshard_pp1.pt"
        }
    }
    dp_group: {
        label: "Data Parallel\nGroup (DP=8)"
        style.fill: "#E8F5E9"
        style.stroke: "${color-success}"
        dp_rank_0: {
            class: rank-shard
            label: "DP Rank 0\nshard_dp0.pt"
        }
        dp_rank_1: {
            class: rank-shard
            label: "DP Rank 1\nshard_dp1.pt"
        }
        dp_rank_n: {
            class: rank-shard
            label: "DP Rank N\nshard_dpN.pt"
        }
    }
}
sharded_state: {
    label: "Sharded Checkpoint State"
    style.fill: "#F5F5F5"
    style.stroke: "${color-dark}"
    style.stroke-dash: 3
    rank_0: {
        class: rank-shard
        label: "Global Rank 0\nrank_0.pt\n\n• Model Shards\n• Optimizer State\n• RNG State"
    }
    rank_1: {
        class: rank-shard
        label: "Global Rank 1\nrank_1.pt\n\n• Model Shards\n• Optimizer State\n• RNG State"
    }
    rank_k: {
        class: rank-shard
        label: "Global Rank K\nrank_K.pt\n\n• Model Shards\n• Optimizer State\n• RNG State"
    }
    rank_n: {
        class: rank-shard
        label: "Global Rank N-1\nrank_N-1.pt\n\n• Model Shards\n• Optimizer State\n• RNG State"
    }
}
metadata_file: {
    class: metadata
    label: "metadata.json\n\n{\n  \"step\": 12500,\n  \"timestamp\": \"2024-01-15T10:30:00Z\",\n  \"tp_size\": 4,\n  \"pp_size\": 2,\n  \"dp_size\": 8,\n  \"zero_stage\": 3,\n  \"num_shards\": 64,\n  \"checksum\": \"sha256:abc123\",\n  \"shard_files\": [\n    \"rank_0.pt\",\n    \"rank_1.pt\",\n    ...\n  ]\n}"
}
valid_marker: {
    label: "Checkpoint Validation"
    style.fill: "#FAFAFA"
    style.stroke: "${color-dark}"
    success_marker: {
        class: valid-marker
        label: "VALID\n.SUCCESS"
    }
    pending_marker: {
        shape: diamond
        style.fill: "${color-warning}"
        style.font-color: "${color-dark}"
        label: "PENDING"
    }
    failed_marker: {
        shape: diamond
        style.fill: "#DC3545"
        style.font-color: white
        label: "FAILED"
    }
}
consensus_protocol: {
    label: "Consensus Protocol"
    style.fill: "#F0F4F8"
    style.stroke: "${color-info}"
    barrier: {
        shape: circle
        style.fill: "${color-info}"
        style.font-color: white
        label: "Barrier\nSync"
    }
    all_reduce: {
        shape: circle
        style.fill: "${color-info}"
        style.font-color: white
        label: "AllReduce\nValidation"
    }
    broadcast: {
        shape: circle
        style.fill: "${color-info}"
        style.font-color: white
        label: "Broadcast\nMarker"
    }
}
storage_tier: {
    label: "Tiered Storage"
    local_ssd: {
        class: storage
        label: "Local SSD\n(/mnt/checkpoint)\n\nHigh Speed\nTemporary"
    }
    distributed_storage: {
        class: storage
        label: "Distributed Storage\n(S3/GCS/HDFS)\n\nDurable\nPermanent"
    }
}
async_saver: {
    label: "Async Checkpoint\nWriter Thread"
    shape: rectangle
    style.fill: "${color-dark}"
    style.font-color: white
    style.stroke: "#1A1A1A"
}
recovery_handler: {
    label: "Recovery Handler"
    shape: rectangle
    style.fill: "#6F42C1"
    style.font-color: white
    style.stroke: "#5A32A3"
}
checkpoint_coordinator -> process_groups.tp_group: "1. Initiate checkpoint" {
    style.stroke: "${color-primary}"
    style.stroke-width: 2
}
checkpoint_coordinator -> process_groups.pp_group: "1. Initiate checkpoint" {
    style.stroke: "${color-secondary}"
    style.stroke-width: 2
}
checkpoint_coordinator -> process_groups.dp_group: "1. Initiate checkpoint" {
    style.stroke: "${color-success}"
    style.stroke-width: 2
}
process_groups -> sharded_state: "2. Collect sharded states" {
    style.stroke-dash: 4
}
sharded_state -> metadata_file: "3. Generate metadata" {
    style.stroke: "${color-info}"
}
sharded_state -> async_saver: "4. Queue for async save" {
    style.stroke: "${color-dark}"
}
async_saver -> local_ssd: "5a. Fast local write" {
    style.stroke: "${color-success}"
    style.stroke-width: 2
}
async_saver -> distributed_storage: "5b. Async persistent write" {
    style.stroke: "${color-secondary}"
    style.stroke-dash: 3
}
metadata_file -> consensus_protocol.barrier: "6. Coordinate ranks" {
    style.stroke: "${color-info}"
}
consensus_protocol.barrier -> consensus_protocol.all_reduce: "7. Validate all shards" {
    style.stroke: "${color-info}"
}
consensus_protocol.all_reduce -> consensus_protocol.broadcast: "8. Consensus result" {
    style.stroke: "${color-info}"
}
consensus_protocol.broadcast -> valid_marker.success_marker: "All valid" {
    style.stroke: "${color-success}"
}
consensus_protocol.broadcast -> valid_marker.failed_marker: "Any failed" {
    style.stroke: "#DC3545"
}
valid_marker.success_marker -> local_ssd: "9. Commit marker" {
    style.stroke: "${color-success}"
    style.stroke-width: 2
}
valid_marker.success_marker -> distributed_storage: "10. Persist marker" {
    style.stroke: "${color-success}"
    style.stroke-width: 2
}
recovery_handler -> valid_marker.success_marker: "Check on restart" {
    style.stroke: "#6F42C1"
    style.stroke-dash: 4
}
recovery_handler -> metadata_file: "Load topology info" {
    style.stroke: "#6F42C1"
    style.stroke-dash: 4
}
recovery_handler -> sharded_state: "Restore state" {
    style.stroke: "#6F42C1"
    style.stroke-dash: 4
}
legend: {
    label: "Legend"
    style.fill: "#FAFAFA"
    style.stroke: "${color-dark}"
    legend_shard: { class: rank-shard; label: "Rank Shard" }
    legend_meta: { class: metadata; label: "Metadata" }
    legend_valid: { class: valid-marker; label: "Valid Marker" }
    legend_storage: { class: storage; label: "Storage" }
    sync_flow: { label: "Sync Flow"; shape: text }
    async_flow: { label: "Async Flow"; shape: text }
    recovery_flow: { label: "Recovery Flow"; shape: text }
}