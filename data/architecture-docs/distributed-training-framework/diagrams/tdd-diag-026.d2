layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

Checkpoint_Architecture: {
  direction: right

  # 1. Main Sequence Visualization: Cross-Hardware Overlap
  Strategy_Sequence: {
    shape: sequence_diagram
    label: "Async Checkpoint Strategy: GPU-to-CPU Overlap"

    # Participants (Actors)
    training: Training Process {
      shape: person
    }
    gpu: GPU Memory (HBM3) {
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
    }
    cpu: CPU Memory (DDR5) {
      style.fill: "#F1F8E9"
      style.stroke: "#2E7D32"
    }
    ssd: Local NVMe SSD {
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
    }
    cloud: Distributed Storage (S3) {
      style.fill: "#E8EAF6"
      style.stroke: "#283593"
    }

    # Phase 0: Compute Phase
    training -> training: "Compute Kernels: Forward/Backward Pass"
    gpu -> training: "Trigger: Global Step % 1000 == 0" {
      style.stroke-dash: 3
    }

    # Phase 1: GPU to CPU Copy (Synchronous/Blocking)
    training -> gpu: "BLOCK_COMPUTE()" {
      tooltip: "Stop all kernels to ensure state consistency"
    }
    
    gpu -> cpu: "DMA_COPY: Weights + Opt States (~1.75TB)" {
      style: {
        stroke: "#E53935"
        stroke-width: 5
      }
    }
    
    gpu -> training: "RESUME_COMPUTE()" {
      style.stroke-dash: 3
    }
    
    training -> training: "Compute Kernels: Iteration N+1 (Resume)"

    # Phase 2: CPU to SSD Write (Background - Local Persistence)
    cpu -> ssd: "ASYNC_FLUSH: PageCache Writeback" {
      style: {
        stroke: "#43A047"
        stroke-dash: 5
        stroke-width: 3
      }
    }
    ssd -> cpu: "IO_COMPLETE_ACK" {
      style: {
        stroke: "#43A047"
        stroke-dash: 3
      }
    }

    # Phase 3: Local to Cloud Upload (Background - Distributed Durability)
    ssd -> cloud: "PARALLEL_UPLOAD: S3 Multipart Put" {
      style: {
        stroke: "#1E88E5"
        stroke-dash: 5
        stroke-width: 3
      }
    }
    cloud -> ssd: "COMMIT_ACK (Durability Guaranteed)" {
      style: {
        stroke: "#1E88E5"
        stroke-dash: 3
      }
    }
  }

  # 2. Technical Specification Annotation
  Timing_Summary: {
    shape: rectangle
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
    style.border-radius: 4
    
    label: ||md
      ### Execution Profile (1.75TB State)
      | Stage | Latency | Visibility | Path |
      | :--- | :--- | :--- | :--- |
      | **Buffer Copy** | ~30s | **Blocking** | HBM3 -> DDR5 (PCIe Gen5) |
      | **Local SSD** | ~20s | Background | DDR5 -> NVMe (io_uring) |
      | **Remote S3** | 2-5m | Background | NVMe -> S3 (100GbE) |

      **Key Metric (Recovery):**
      - Local Recovery: **~30s** (Fetch from local NVMe)
      - Cold Recovery: **~5m** (Fetch from Distributed)
    ||
  }

  # 3. Memory Layout Field (Size Context)
  Memory_Usage: {
    shape: sql_table
    label: "Checkpoint Buffer Composition (1.75 TB)"
    
    model_params: "Weights (FP32)" {
      constraint: "350 GB"
      style.fill: "#D1C4E9"
    }
    opt_momentum: "Momentum (FP32)" {
      constraint: "700 GB"
      style.fill: "#C5CAE9"
    }
    opt_variance: "Variance (FP32)" {
      constraint: "700 GB"
      style.fill: "#C5CAE9"
    }
  }

  # 4. Color Legend
  Legend: {
    label: "Path Legend"
    blocking_path: "CRITICAL: Blocking (Stop Compute)" {
      style: {
        fill: "#FFCDD2"
        stroke: "#E53935"
        stroke-width: 2
      }
    }
    local_path: "ASYNC: Local Persistence" {
      style: {
        fill: "#C8E6C9"
        stroke: "#43A047"
        stroke-dash: 5
      }
    }
    remote_path: "ASYNC: Distributed Durability" {
      style: {
        fill: "#BBDEFB"
        stroke: "#1E88E5"
        stroke-dash: 5
      }
    }
  }
}

# Layout constraints using hidden connections
Checkpoint_Architecture.Strategy_Sequence -> Checkpoint_Architecture.Timing_Summary: {style.opacity: 0}
Checkpoint_Architecture.Timing_Summary -> Checkpoint_Architecture.Memory_Usage: {style.opacity: 0}
Checkpoint_Architecture.Memory_Usage -> Checkpoint_Architecture.Legend: {style.opacity: 0}