vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Async Checkpoint Timeline
  Training continues immediately after CPU copy (~30s), while SSD write and remote upload proceed in background
|
shape: sequence_diagram
Training_Thread
Checkpoint_Thread
Local_SSD
Remote_Storage
Init: {
  Training_Thread -> Checkpoint_Thread: save_async(step=1000)
}
CPU_Copy_Phase: {
  Training_Thread.t1 -> Training_Thread.t1: Continue training
  Checkpoint_Thread.t1 -> Checkpoint_Thread.t1: Copy model state to CPU {
    style.stroke: orange
    style.bold: true
  }
  Training_Thread.t1 -> Training_Thread.t1: Step 1001, 1002...
}
SSD_Write_Phase: {
  Checkpoint_Thread.t2 -> Local_SSD.t1: Write checkpoint shard (~20s)
  Training_Thread.t2 -> Training_Thread.t2: Training continues unblocked
  Local_SSD.t1 -> Local_SSD.t1: NVMe write in progress {
    style.stroke: blue
    style.bold: true
  }
  Training_Thread.t2 -> Training_Thread.t2: Step 1003, 1004, 1005...
}
Remote_Upload_Phase: {
  Local_SSD.t2 -> Checkpoint_Thread.t3: Write complete
  Checkpoint_Thread.t3 -> Remote_Storage.t1: Upload to S3/GCS (~2-5 min)
  Training_Thread.t3 -> Training_Thread.t3: Training continues
  Remote_Storage.t1 -> Remote_Storage.t1: Network upload in background {
    style.stroke: purple
    style.bold: true
  }
  Training_Thread.t3 -> Training_Thread.t3: Steps 1006...1020...
}
Complete: {
  Remote_Storage.t2 -> Checkpoint_Thread.t4: Upload complete
  Checkpoint_Thread.t4 -> Training_Thread.t4: Checkpoint ready {
    style.stroke: green
  }
  Training_Thread."Checkpoint saved\n(Training never blocked\nafter step 1000)"
}
Timeline_Annotation: |md
  **Synchronous blocking:** ~30s (CPU copy only)
  **Background:** SSD write + remote upload
  **Total overhead:** < 2% of training time
|
Training_Thread.style.stroke: "#2E7D32"
Checkpoint_Thread.style.stroke: "#F57C00"
Local_SSD.style.stroke: "#1976D2"
Remote_Storage.style.stroke: "#7B1FA2"