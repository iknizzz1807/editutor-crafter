direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

style: {
  font: mono
  fill: "#0d1117"
  stroke: "#30363d"
  stroke-width: 1
}

title: {
  label: "Failure Recovery Flow (distributed-m5: Fault Tolerance)"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    fill: "#e6edf3"
  }
}

# -----------------------------------------------------------------------------
# States
# -----------------------------------------------------------------------------

Initial: {
  shape: circle
  label: "●"
  style: {
    fill: "#238636"
    stroke: "#2ea043"
    stroke-width: 3
    font-size: 20
  }
}

NormalTraining: {
  label: "Normal Training\n━━━━━━━━━━━━━━━━\nInvariant:\n• All ranks active\n• Step counter ++\n• Loss decreasing"
  shape: class
  style: {
    fill: "#161b22"
    stroke: "#58a6ff"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

FailureDetected: {
  label: "Failure Detected\n━━━━━━━━━━━━━━━━\nInvariant:\n• Exception caught\n• Rank identified\n• Timestamp logged"
  shape: class
  style: {
    fill: "#161b22"
    stroke: "#f0883e"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

ClassifyingFailure: {
  label: "Classifying Failure\n━━━━━━━━━━━━━━━━\nInvariant:\n• Error type determined\n• Severity assessed\n• Recovery strategy selected"
  shape: class
  style: {
    fill: "#161b22"
    stroke: "#a371f7"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

FailureTypes: {
  label: "Failure Registry"
  shape: rectangle
  style: {
    fill: "#21262d"
    stroke: "#30363d"
    stroke-dash: 3
    font-color: "#8b949e"
  }

  GPU_OOM: {
    label: "GPU_OOM"
    shape: diamond
    style: {
      fill: "#da3633"
      stroke: "#f85149"
      font-color: "#ffffff"
    }
  }
  GPU_ERROR: {
    label: "GPU_ERROR"
    shape: diamond
    style: {
      fill: "#da3633"
      stroke: "#f85149"
      font-color: "#ffffff"
    }
  }
  NETWORK_ERROR: {
    label: "NETWORK_ERROR"
    shape: diamond
    style: {
      fill: "#8957e5"
      stroke: "#a371f7"
      font-color: "#ffffff"
    }
  }
  CHECKPOINT_ERROR: {
    label: "CHECKPOINT_ERROR"
    shape: diamond
    style: {
      fill: "#8957e5"
      stroke: "#a371f7"
      font-color: "#ffffff"
    }
  }
  STRAGGLER_TIMEOUT: {
    label: "STRAGGLER_TIMEOUT"
    shape: diamond
    style: {
      fill: "#d29922"
      stroke: "#e3b341"
      font-color: "#ffffff"
    }
  }
  UNKNOWN: {
    label: "UNKNOWN"
    shape: diamond
    style: {
      fill: "#6e7681"
      stroke: "#8b949e"
      font-color: "#ffffff"
    }
  }
}

RecoveryAttempt: {
  label: "Recovery Attempt\n━━━━━━━━━━━━━━━━\nInvariant:\n• retry_count ≤ max_retries\n• Exponential backoff active\n• checkpoint_path valid"
  shape: class
  style: {
    fill: "#161b22"
    stroke: "#3fb950"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

RecoveryActions: {
  label: "Recovery Actions"
  shape: rectangle
  style: {
    fill: "#21262d"
    stroke: "#30363d"
    stroke-dash: 3
    font-color: "#8b949e"
  }
  ClearCache: {
    label: "clear_cuda_cache()\nreduce_batch_size()"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
      font-color: "#79c0ff"
      font: mono
    }
  }
  ResetGPU: {
    label: "reset_gpu_state()\nreinit_context()"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
      font-color: "#79c0ff"
      font: mono
    }
  }
  Reconnect: {
    label: "reinit_process_group()\nverify_connectivity()"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
      font-color: "#79c0ff"
      font: mono
    }
  }
  LoadBackup: {
    label: "load_backup_checkpoint()\nverify_integrity()"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
      font-color: "#79c0ff"
      font: mono
    }
  }
  Reschedule: {
    label: "reschedule_work()\nredistribute_batches()"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
      font-color: "#79c0ff"
      font: mono
    }
  }
  LogAnalyze: {
    label: "log_diagnostics()\nalert_admins()"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
      font-color: "#79c0ff"
      font: mono
    }
  }
}

CheckpointLoaded: {
  label: "Checkpoint Loaded\n━━━━━━━━━━━━━━━━\nInvariant:\n• State restored\n• Optimizer synced\n• Step counter recovered"
  shape: class
  style: {
    fill: "#161b22"
    stroke: "#3fb950"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

TrainingResumed: {
  label: "Training Resumed\n━━━━━━━━━━━━━━━━\nInvariant:\n• All ranks synchronized\n• Training loop active\n• Metrics logging resumed"
  shape: class
  style: {
    fill: "#161b22"
    stroke: "#238636"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

EmergencySave: {
  label: "Emergency Save\n━━━━━━━━━━━━━━━━\nInvariant:\n• Partial state saved\n• Artifacts preserved\n• Logs dumped"
  shape: class
  style: {
    fill: "#161b22"
    stroke: "#d29922"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

UnrecoverableFailure: {
  label: "Unrecoverable\nFailure\n━━━━━━━━━━━━━━━━\nInvariant:\n• All retries exhausted\n• Training halted\n• Alert sent"
  shape: class
  style: {
    fill: "#da3633"
    stroke: "#f85149"
    stroke-width: 3
    font-color: "#ffffff"
  }
}

Final: {
  shape: circle
  label: "◎"
  style: {
    fill: "#f85149"
    stroke: "#da3633"
    stroke-width: 3
    double-border: true
    font-size: 20
  }
}

# -----------------------------------------------------------------------------
# Transitions
# -----------------------------------------------------------------------------

Initial -> NormalTraining: "start" {
  style: {
    stroke: "#3fb950"
    stroke-width: 2
  }
}

NormalTraining -> FailureDetected: "trigger: exception_raised\naction: capture_stack_trace()" {
  style: {
    stroke: "#f0883e"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

FailureDetected -> ClassifyingFailure: "trigger: error_logged\naction: analyze_error_type()" {
  style: {
    stroke: "#a371f7"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

ClassifyingFailure -> FailureTypes: "reference" {
  style: {
    stroke: "#30363d"
    stroke-dash: 3
  }
}

FailureTypes.GPU_OOM -> RecoveryActions.ClearCache: {
  style: {
    stroke: "#30363d"
    stroke-dash: 2
  }
}
FailureTypes.GPU_ERROR -> RecoveryActions.ResetGPU: {
  style: {
    stroke: "#30363d"
    stroke-dash: 2
  }
}
FailureTypes.NETWORK_ERROR -> RecoveryActions.Reconnect: {
  style: {
    stroke: "#30363d"
    stroke-dash: 2
  }
}
FailureTypes.CHECKPOINT_ERROR -> RecoveryActions.LoadBackup: {
  style: {
    stroke: "#30363d"
    stroke-dash: 2
  }
}
FailureTypes.STRAGGLER_TIMEOUT -> RecoveryActions.Reschedule: {
  style: {
    stroke: "#30363d"
    stroke-dash: 2
  }
}
FailureTypes.UNKNOWN -> RecoveryActions.LogAnalyze: {
  style: {
    stroke: "#30363d"
    stroke-dash: 2
  }
}

ClassifyingFailure -> RecoveryAttempt: "trigger: type_classified\naction: select_recovery_fn()" {
  style: {
    stroke: "#3fb950"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

RecoveryAttempt -> CheckpointLoaded: "trigger: recovery_success\nguard: checkpoint_valid == true\naction: load_checkpoint()" {
  style: {
    stroke: "#3fb950"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

RecoveryAttempt -> RecoveryAttempt: "trigger: recovery_failed\nguard: retry_count < max_retries\naction: backoff_wait()" {
  style: {
    stroke: "#d29922"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

RecoveryAttempt -> EmergencySave: "trigger: all_retries_failed\nguard: retry_count >= max_retries\naction: save_partial_state()" {
  style: {
    stroke: "#f85149"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

CheckpointLoaded -> TrainingResumed: "trigger: state_restored\naction: sync_all_ranks()" {
  style: {
    stroke: "#3fb950"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

TrainingResumed -> NormalTraining: "trigger: resume_complete\naction: log_mttr()" {
  style: {
    stroke: "#3fb950"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

EmergencySave -> UnrecoverableFailure: "trigger: save_complete\naction: notify_admins()" {
  style: {
    stroke: "#f85149"
    stroke-width: 2
    font-color: "#e6edf3"
  }
}

UnrecoverableFailure -> Final: "trigger: cleanup_done\naction: exit_training()" {
  style: {
    stroke: "#f85149"
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# Metadata / Legend
# -----------------------------------------------------------------------------

Legend: {
  label: "Operational Reference"
  shape: rectangle
  near: bottom-right
  style: {
    fill: "#21262d"
    stroke: "#30363d"
    font-color: "#8b949e"
  }
  
  InitS: "● Initial State" { shape: text; style.font-color: "#3fb950" }
  NormS: "□ Operational State" { shape: text; style.font-color: "#58a6ff" }
  ErrS: "■ Fault/Terminal State" { shape: text; style.font-color: "#f85149" }
  RetryL: "↻ Exponential Retry" { shape: text; style.font-color: "#d29922" }
  Logic: "trigger / guard / action" { shape: text; style.font-color: "#8b949e" }
}

# MTTR annotation
MTTR: "MTTR = t_resume - t_failure\nTarget SLA: < 30s" {
  shape: text
  near: bottom-center
  style: {
    font-color: "#8b949e"
    italic: true
    font-size: 14
  }
}