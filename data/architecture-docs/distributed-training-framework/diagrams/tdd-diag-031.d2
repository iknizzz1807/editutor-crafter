layout-engine: elk
direction: right

vars: {
  d2-config: {
    theme-id: 200
    layout-engine: elk
  }
}

title: {
  label: "3D Parallelism Architecture - Complete Stack Overview\nDistributed Training Framework Reference"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

global_style: {
  style: {
    font-size: 14
    stroke: "#333333"
  }
}

# =============================================================================
# SECTION 1: 3D Process Grid Architecture
# =============================================================================
section_3d_grid: {
  label: "3D Process Grid Architecture"
  shape: rectangle
  style: {
    fill: "#f5f5f5"
    stroke: "#8B5CF6"
    stroke-width: 3
  }
  header_3d: {
    label: "Process Grid: DP Г— TP Г— PP = Total GPUs"
    shape: text
    style: {
      font-size: 18
      bold: true
      underline: true
    }
  }
  
  process_grid: {
    label: ""
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#666666"
      stroke-dash: 3
    }
    
    dp_axis: {
      label: "Data Parallel (DP)\nWorld Size: 2"
      shape: text
      style: {
        font-size: 12
        fill: "#3B82F6"
      }
    }
    
    tp_axis: {
      label: "Tensor Parallel (TP)\nWorld Size: 2"
      shape: text
      style: {
        font-size: 12
        fill: "#F97316"
      }
    }
    
    pp_axis: {
      label: "Pipeline Parallel (PP)\nWorld Size: 2"
      shape: text
      style: {
        font-size: 12
        fill: "#10B981"
      }
    }
    
    layer_0: {
      label: "PP Stage 0"
      shape: rectangle
      style: {
        fill: "#E8F5E9"
        stroke: "#10B981"
      }
      gpu_0: {
        label: "GPU 0\nDP=0, TP=0, PP=0"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_1: {
        label: "GPU 1\nDP=0, TP=1, PP=0"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_2: {
        label: "GPU 2\nDP=1, TP=0, PP=0"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_3: {
        label: "GPU 3\nDP=1, TP=1, PP=0"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_0 -> gpu_1: "TP" {
        style.stroke: "#F97316"
        style.stroke-width: 2
      }
      gpu_2 -> gpu_3: "TP" {
        style.stroke: "#F97316"
        style.stroke-width: 2
      }
      gpu_0 -> gpu_2: "DP" {
        style.stroke: "#3B82F6"
        style.stroke-width: 2
      }
      gpu_1 -> gpu_3: "DP" {
        style.stroke: "#3B82F6"
        style.stroke-width: 2
      }
    }
    
    layer_1: {
      label: "PP Stage 1"
      shape: rectangle
      style: {
        fill: "#F3E5F5"
        stroke: "#10B981"
      }
      gpu_4: {
        label: "GPU 4\nDP=0, TP=0, PP=1"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_5: {
        label: "GPU 5\nDP=0, TP=1, PP=1"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_6: {
        label: "GPU 6\nDP=1, TP=0, PP=1"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_7: {
        label: "GPU 7\nDP=1, TP=1, PP=1"
        shape: rectangle
        style: {
          fill: "#DBEAFE"
          stroke: "#3B82F6"
        }
      }
      gpu_4 -> gpu_5: "TP" {
        style.stroke: "#F97316"
        style.stroke-width: 2
      }
      gpu_6 -> gpu_7: "TP" {
        style.stroke: "#F97316"
        style.stroke-width: 2
      }
      gpu_4 -> gpu_6: "DP" {
        style.stroke: "#3B82F6"
        style.stroke-width: 2
      }
      gpu_5 -> gpu_7: "DP" {
        style.stroke: "#3B82F6"
        style.stroke-width: 2
      }
    }
    
    layer_0.gpu_0 -> layer_1.gpu_4: "PP" {
      style.stroke: "#10B981"
      style.stroke-width: 3
      style.stroke-dash: 5
    }
    layer_0.gpu_1 -> layer_1.gpu_5: {
      style.stroke: "#10B981"
      style.stroke-width: 3
      style.stroke-dash: 5
    }
    layer_0.gpu_2 -> layer_1.gpu_6: {
      style.stroke: "#10B981"
      style.stroke-width: 3
      style.stroke-dash: 5
    }
    layer_0.gpu_3 -> layer_1.gpu_7: {
      style.stroke: "#10B981"
      style.stroke-width: 3
      style.stroke-dash: 5
    }
  }
  
  total_gpus: {
    label: "Total GPUs: 2 (DP) Г— 2 (TP) Г— 2 (PP) = 8 GPUs"
    shape: text
    style: {
      font-size: 16
      bold: true
      fill: "#7C3AED"
    }
  }
  
  legend_3d: {
    label: ||md
    **Legend:**
    - **DP (Blue)**: Data Parallel - Gradient AllReduce
    - **TP (Orange)**: Tensor Parallel - Activation AllReduce  
    - **PP (Green)**: Pipeline Parallel - Point-to-Point Send/Recv
    ||
    shape: text
    style.font-size: 11
  }
}

# =============================================================================
# SECTION 2: Data Parallel Communication Pattern
# =============================================================================
section_dp_comm: {
  label: "DP Process Group Communication Pattern"
  shape: rectangle
  style: {
    fill: "#f0f9ff"
    stroke: "#3B82F6"
    stroke-width: 3
  }
  dp_header: {
    label: "Data Parallel: Gradient Synchronization via AllReduce"
    shape: text
    style: {
      font-size: 18
      bold: true
      underline: true
    }
  }
  
  dp_group: {
    label: "DP Group (World Size = 4)"
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#3B82F6"
      stroke-dash: 4
    }
    dp_rank_0: {
      label: ||md
      **DP Rank 0**
      Model Replica (Full)
      - Parameters: 7B
      - Gradients: 7B
      - Optimizer: 84M
      ||
      shape: rectangle
      style: {
        fill: "#DBEAFE"
        stroke: "#3B82F6"
      }
    }
    dp_rank_1: {
      label: ||md
      **DP Rank 1**
      Model Replica (Full)
      - Parameters: 7B
      - Gradients: 7B
      - Optimizer: 84M
      ||
      shape: rectangle
      style: {
        fill: "#DBEAFE"
        stroke: "#3B82F6"
      }
    }
    dp_rank_2: {
      label: ||md
      **DP Rank 2**
      Model Replica (Full)
      - Parameters: 7B
      - Gradients: 7B
      - Optimizer: 84M
      ||
      shape: rectangle
      style: {
        fill: "#DBEAFE"
        stroke: "#3B82F6"
      }
    }
    dp_rank_3: {
      label: ||md
      **DP Rank 3**
      Model Replica (Full)
      - Parameters: 7B
      - Gradients: 7B
      - Optimizer: 84M
      ||
      shape: rectangle
      style: {
        fill: "#DBEAFE"
        stroke: "#3B82F6"
      }
    }
    
    dp_rank_0 -> dp_rank_1: "вҲӮL/вҲӮW" {
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      style.animated: true
    }
    dp_rank_1 -> dp_rank_2: "вҲӮL/вҲӮW" {
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      style.animated: true
    }
    dp_rank_2 -> dp_rank_3: "вҲӮL/вҲӮW" {
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      style.animated: true
    }
    dp_rank_3 -> dp_rank_0: "вҲӮL/вҲӮW" {
      style.stroke: "#3B82F6"
      style.stroke-width: 2
      style.animated: true
    }
  }
  
  dp_allreduce_detail: {
    label: ||md
    **AllReduce Operation (Ring)**
    1. **Scatter-Reduce Phase**
       - Each rank sends 1/N of gradients to next
       - N-1 steps, partial sums accumulated
    2. **All-Gather Phase**  
       - Final sums distributed to all ranks
       - N-1 steps, all ranks receive full result
    **Bandwidth**: 2(N-1)/N Г— GradientSize
    **Latency**: 2(N-1) Г— Оұ (network latency)
    ||
    shape: rectangle
    style: {
      fill: "#EFF6FF"
      stroke: "#93C5FD"
    }
  }
  
  dp_bandwidth: {
    label: ||md
    **Network Requirements**
    | Interconnect | Bandwidth | Latency |
    |--------------|-----------|---------|
    | NVLink       | 300 GB/s  | 1-2 Ојs  |
    | InfiniBand   | 200 Gb/s  | 1-2 Ојs  |
    | Ethernet     | 100 Gb/s  | 10+ Ојs  |
    ||
    shape: rectangle
    style: {
      fill: "#FEF3C7"
      stroke: "#FCD34D"
    }
  }
}

# =============================================================================
# SECTION 3: Tensor Parallel Communication Pattern
# =============================================================================
section_tp_comm: {
  label: "TP Process Group Communication Pattern"
  shape: rectangle
  style: {
    fill: "#fff7ed"
    stroke: "#F97316"
    stroke-width: 3
  }
  tp_header: {
    label: "Tensor Parallel: Model Sharding with Activation AllReduce"
    shape: text
    style: {
      font-size: 18
      bold: true
      underline: true
    }
  }
  
  tp_group: {
    label: "TP Group (World Size = 4)"
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#F97316"
      stroke-dash: 4
    }
    tp_rank_0: {
      label: ||md
      **TP Rank 0**
      Sharded Weight: WвӮҖ
      (Columns 0-25%)
      Local Activation: AвӮҖ
      ||
      shape: rectangle
      style: {
        fill: "#FED7AA"
        stroke: "#F97316"
      }
    }
    tp_rank_1: {
      label: ||md
      **TP Rank 1**
      Sharded Weight: WвӮҒ
      (Columns 25-50%)
      Local Activation: AвӮҒ
      ||
      shape: rectangle
      style: {
        fill: "#FED7AA"
        stroke: "#F97316"
      }
    }
    tp_rank_2: {
      label: ||md
      **TP Rank 2**
      Sharded Weight: WвӮӮ
      (Columns 50-75%)
      Local Activation: AвӮӮ
      ||
      shape: rectangle
      style: {
        fill: "#FED7AA"
        stroke: "#F97316"
      }
    }
    tp_rank_3: {
      label: ||md
      **TP Rank 3**
      Sharded Weight: WвӮғ
      (Columns 75-100%)
      Local Activation: AвӮғ
      ||
      shape: rectangle
      style: {
        fill: "#FED7AA"
        stroke: "#F97316"
      }
    }
    
    tp_rank_0 -> tp_rank_1: "AllReduce" {
      style.stroke: "#F97316"
      style.stroke-width: 2
      style.animated: true
    }
    tp_rank_1 -> tp_rank_2: {
      style.stroke: "#F97316"
      style.stroke-width: 2
      style.animated: true
    }
    tp_rank_2 -> tp_rank_3: {
      style.stroke: "#F97316"
      style.stroke-width: 2
      style.animated: true
    }
    tp_rank_3 -> tp_rank_0: {
      style.stroke: "#F97316"
      style.stroke-width: 2
      style.animated: true
    }
  }
  
  tp_mlp_detail: {
    label: ||md
    **MLP Layer Tensor Parallelism**
    
    Input X: [batch, seq, hidden]
    First Linear (Column Parallel):
    YвӮҒ = X @ WвӮҒ  (on TP rank 0)
    YвӮӮ = X @ WвӮӮ  (on TP rank 1)
    ...
    AllReduce: Y = ОЈ(Yбөў)
    Second Linear (Row Parallel):
    ZвӮҒ = Y[0:25%] @ VвӮҒ
    ZвӮӮ = Y[25:50%] @ VвӮӮ
    ...
    Output: Z = ОЈ(Zбөў) via AllReduce
    ||
    shape: rectangle
    style: {
      fill: "#FFF7ED"
      stroke: "#FDBA74"
    }
  }
  
  tp_attention_detail: {
    label: ||md
    **Attention Tensor Parallelism**
    
    Multi-Head Attention:
    - Heads sharded across TP ranks
    - TP=4, 32 heads вҶ’ 8 heads per rank
    Q = X @ Wq  (sharded by heads)
    K = X @ Wk  (sharded by heads)
    V = X @ Wv  (sharded by heads)
    Attention = softmax(QKбөҖ/вҲҡd) @ V
    Output Projection:
    Out = Concat(heads) @ Wo
    AllReduce across TP ranks
    ||
    shape: rectangle
    style: {
      fill: "#FFF7ED"
      stroke: "#FDBA74"
    }
  }
}

# =============================================================================
# SECTION 4: Pipeline Parallel Communication Pattern
# =============================================================================
section_pp_comm: {
  label: "PP Process Group Communication Pattern"
  shape: rectangle
  style: {
    fill: "#f0fdf4"
    stroke: "#10B981"
    stroke-width: 3
  }
  pp_header: {
    label: "Pipeline Parallel: Stage-wise Model Partitioning"
    shape: text
    style: {
      font-size: 18
      bold: true
      underline: true
    }
  }
  pp_stages: {
    label: ""
    shape: rectangle
    style: {
      fill: "#ffffff"
      stroke: "#10B981"
      stroke-dash: 4
    }
    stage_0: {
      label: ||md
      **Stage 0** (PP Rank 0)
      Layers: 0-11
      Embedding: вң“
      Input: token_ids
      Output: hidden_states
      ||
      shape: rectangle
      style: {
        fill: "#D1FAE5"
        stroke: "#10B981"
      }
    }
    stage_1: {
      label: ||md
      **Stage 1** (PP Rank 1)
      Layers: 12-23
      Input: hidden_states
      Output: hidden_states
      ||
      shape: rectangle
      style: {
        fill: "#D1FAE5"
        stroke: "#10B981"
      }
    }
    stage_2: {
      label: ||md
      **Stage 2** (PP Rank 2)
      Layers: 24-35
      Input: hidden_states
      Output: hidden_states
      ||
      shape: rectangle
      style: {
        fill: "#D1FAE5"
        stroke: "#10B981"
      }
    }
    stage_3: {
      label: ||md
      **Stage 3** (PP Rank 3)
      Layers: 36-47
      LM Head: вң“
      Input: hidden_states
      Output: logits
      ||
      shape: rectangle
      style: {
        fill: "#D1FAE5"
        stroke: "#10B981"
      }
    }
    
    stage_0 -> stage_1: "Forward\nsend()" {
      style.stroke: "#10B981"
      style.stroke-width: 3
    }
    stage_1 -> stage_2: "Forward\nsend()" {
      style.stroke: "#10B981"
      style.stroke-width: 3
    }
    stage_2 -> stage_3: "Forward\nsend()" {
      style.stroke: "#10B981"
      style.stroke-width: 3
    }
    
    stage_3 -> stage_2: "Backward\nsend()" {
      style.stroke: "#EF4444"
      style.stroke-width: 3
      style.stroke-dash: 5
    }
    stage_2 -> stage_1: {
      style.stroke: "#EF4444"
      style.stroke-width: 3
      style.stroke-dash: 5
    }
    stage_1 -> stage_0: {
      style.stroke: "#EF4444"
      style.stroke-width: 3
      style.stroke-dash: 5
    }
  }
  
  pp_schedule: {
    label: ||md
    **1F1B Schedule (One Forward One Backward)**
    
    Warmup Phase:
    Stage 0: F0 F1 F2 F3
    Stage 1:    F0 F1 F2 F3
    Stage 2:       F0 F1 F2 F3
    Stage 3:          F0 F1 F2 F3
    Steady State (1F1B):
    Stage 0: B0 F4 B1 F5 B2 F6 B3 F7
    Stage 1:    B0 F4 B1 F5 B2 F6 B3 F7
    Stage 2:       B0 F4 B1 F5 B2 F6 B3 F7
    Stage 3:          B0 F4 B1 F5 B2 F6 B3 F7
    Cooldown Phase:
    Stage 0:          B4 B5 B6 B7
    Stage 1:             B4 B5 B6 B7
    Stage 2:                B4 B5 B6 B7
    Stage 3:                   B4 B5 B6 B7
    
    F = Forward, B = Backward, Number = Micro-batch ID
    ||
    shape: rectangle
    style: {
      fill: "#ECFDF5"
      stroke: "#6EE7B7"
    }
  }
  
  pp_memory: {
    label: ||md
    **Activation Memory per Stage**
    | Stage | Layers | Activation Memory |
    |-------|--------|-------------------|
    | 0     | 12     | ~2 GB             |
    | 1     | 12     | ~2 GB             |
    | 2     | 12     | ~2 GB             |
    | 3     | 12     | ~2 GB             |
    **Pipeline Bubble**: (PP-1) / (2Г—PP) вүҲ 37.5% for PP=4
    ||
    shape: rectangle
    style: {
      fill: "#FEF3C7"
      stroke: "#FCD34D"
    }
  }
}

# =============================================================================
# SECTION 5: ZeRO Memory Optimization Stages
# =============================================================================
section_zero: {
  label: "ZeRO Memory Optimization Stages"
  shape: rectangle
  style: {
    fill: "#faf5ff"
    stroke: "#7C3AED"
    stroke-width: 3
  }
  zero_header: {
    label: "ZeRO: Zero Redundancy Optimizer (70B Model Example)"
    shape: text
    style: {
      font-size: 18
      bold: true
      underline: true
    }
  }
  
  baseline_memory: {
    label: ||md
    **Baseline (No ZeRO) - 70B Model**
    | Component    | Size      | Per GPU (DP=8) |
    |--------------|-----------|---------------|
    | Parameters   | 140 GB    | 140 GB        |
    | Gradients    | 140 GB    | 140 GB        |
    | Optimizer    | 840 GB    | 840 GB        |
    | **Total**    | **1120 GB** | **1120 GB** |
    вқҢ Requires 8Г—A100 80GB with model parallelism
    ||
    shape: rectangle
    style: {
      fill: "#FEE2E2"
      stroke: "#EF4444"
    }
  }
  
  zero_stages: {
    label: ""
    shape: rectangle
    style: {
      fill: "#ffffff"
    }
    zero_1: {
      label: ||md
      **ZeRO-1: Optimizer State Sharding**
      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
      в”Ӯ  GPU 0  в”Ӯ  GPU 1  в”Ӯ  GPU 2  в”Ӯ  GPU 3  в”Ӯ
      в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
      в”Ӯ Optim   в”Ӯ Optim   в”Ӯ Optim   в”Ӯ Optim   в”Ӯ
      в”Ӯ State 0 в”Ӯ State 1 в”Ӯ State 2 в”Ӯ State 3 в”Ӯ
      в”Ӯ (1/4)   в”Ӯ (1/4)   в”Ӯ (1/4)   в”Ӯ (1/4)   в”Ӯ
      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
      **Memory per GPU (DP=4):**
      - Parameters: 140 GB (replicated)
      - Gradients: 140 GB (replicated)
      - Optimizer: 210 GB (sharded 1/4)
      - **Total: 490 GB** вҶ“ 56%
      ||
      shape: rectangle
      style: {
        fill: "#DCFCE7"
        stroke: "#22C55E"
      }
    }
    zero_2: {
      label: ||md
      **ZeRO-2: + Gradient Sharding**
      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
      в”Ӯ  GPU 0  в”Ӯ  GPU 1  в”Ӯ  GPU 2  в”Ӯ  GPU 3  в”Ӯ
      в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
      в”Ӯ Optim   в”Ӯ Optim   в”Ӯ Optim   в”Ӯ Optim   в”Ӯ
      в”Ӯ State 0 в”Ӯ State 1 в”Ӯ State 2 в”Ӯ State 3 в”Ӯ
      в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
      в”Ӯ Grad 0  в”Ӯ Grad 1  в”Ӯ Grad 2  в”Ӯ Grad 3  в”Ӯ
      в”Ӯ (1/4)   в”Ӯ (1/4)   в”Ӯ (1/4)   в”Ӯ (1/4)   в”Ӯ
      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
      **Memory per GPU (DP=4):**
      - Parameters: 140 GB (replicated)
      - Gradients: 35 GB (sharded 1/4)
      - Optimizer: 210 GB (sharded 1/4)
      - **Total: 385 GB** вҶ“ 66%
      ||
      shape: rectangle
      style: {
