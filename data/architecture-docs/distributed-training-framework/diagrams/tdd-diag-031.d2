      underline: true
    }
  }
  zero3_timeline: {
    label: ""
    shape: rectangle
    style: {
      fill: "#ffffff"
    }
    timeline_axis: "Time вҶ’" { shape: text }
    
    phase_1: {
      label: ||md
      **Phase 1: All-Gather**
      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
      в”Ӯ GPU 0: Has WвӮҖ       в”Ӯв”Җв”Җв”җ
      в”Ӯ GPU 1: Has WвӮҒ       в”Ӯв”Җв”Җв”Ө
      в”Ӯ GPU 2: Has WвӮӮ       в”Ӯв”Җв”Җв”Ө All-Gather
      в”Ӯ GPU 3: Has WвӮғ       в”Ӯв”Җв”Җв”ҳ
      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
            в”Ӯ
            в–ј
      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
      в”Ӯ All GPUs have       в”Ӯ
      в”Ӯ full WвӮҖWвӮҒWвӮӮWвӮғ       в”Ӯ
      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
      ||
      shape: rectangle
      style: {
        fill: "#FEF3C7"
        stroke: "#FCD34D"
      }
    }
    phase_2: {
      label: ||md
      **Phase 2: Compute**
      
      Forward Pass:
      h = LayerNorm(x)
      h = h @ W  (full weight)
      h = GeLU(h)
      Compute Time: ~2ms
      (overlapped with next
       all-gather)
      ||
      shape: rectangle
      style: {
        fill: "#DBEAFE"
        stroke: "#3B82F6"
      }
    }
    phase_3: {
      label: ||md
      **Phase 3: Release**
      
      After compute:
      - Free full weight
      - Keep only local shard
      - Prefetch next layer
      Memory peak: during compute
      Memory steady: shard only
      ||
      shape: rectangle
      style: {
        fill: "#D1FAE5"
        stroke: "#10B981"
      }
    }
    phase_1 -> phase_2 -> phase_3
  }
  
  zero3_overlap: {
    label: ||md
    **Communication-Compute Overlap**
    
    Timeline (per layer):
    Layer N:    [AllGather][Compute][Release]
    Layer N+1:            [Prefetch ][AllGather][Compute]
    Layer N+2:                      [Prefetch ][AllGather]
    Effective bandwidth increase:
    - NVLink: ~600 GB/s (bidirectional)
    - Computation hidden by prefetch
    
    **Bandwidth Formula:**
    CommTime = ParamSize / Bandwidth
    ComputeTime = FLOPs / TFLOPS
    If ComputeTime > CommTime:
        No slowdown!
    ||
    shape: rectangle
    style: {
      fill: "#ECFDF5"
      stroke: "#6EE7B7"
    }
  }
  
  zero3_gather_code: {
    label: ||md
    **All-Gather Implementation**
    python
    def gather_parameter(param, dp_group):
        # Get full parameter via all-gather
        world_size = dist.get_world_size(dp_group)
        # Allocate buffer for full parameter
        full_param = torch.empty(
            param.shape[0] * world_size,
            device=param.device,
            dtype=param.dtype
        )
        # All-gather operation
        dist.all_gather_into_tensor(full_param, param, group=dp_group)
        return full_param
    
    ||
    shape: rectangle
    style: {
      fill: "#F1F5F9"
      stroke: "#94A3B8"
    }
  }
}

