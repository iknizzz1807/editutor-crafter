direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

# -----------------------------------------------------------------------------------------
# CLASSES & STYLES
# -----------------------------------------------------------------------------------------
classes: {
  cell_normal: {
    style: {
      fill: "#2ecc71"
      stroke: "#27ae60"
      font-color: white
      border-radius: 2
    }
  }
  cell_warning: {
    style: {
      fill: "#f39c12"
      stroke: "#e67e22"
      font-color: white
      border-radius: 2
    }
  }
  cell_critical: {
    style: {
      fill: "#e74c3c"
      stroke: "#c0392b"
      font-color: white
      border-radius: 2
    }
  }
  header_box: {
    style: {
      fill: "#2c3e50"
      stroke: "#34495e"
      font-color: white
      bold: true
    }
  }
  pipeline_step: {
    style: {
      fill: "#3498db"
      stroke: "#2980b9"
      font-color: white
      bold: true
      shadow: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# HEADER & LEGEND
# -----------------------------------------------------------------------------------------
header: {
  shape: rectangle
  style.fill: "#1a1a2e"
  style.stroke: "#16213e"
  style.stroke-width: 4
  
  title: "Straggler Detection Heatmap" {
    style.font-size: 32
    style.font-color: white
  }
  subtitle: "Per-Rank Timing Analysis Across Training Steps" {
    style.font-color: "#bdc3c7"
  }

  legend: {
    grid-columns: 3
    style.fill: "#0f0f23"
    style.stroke: "#34495e"
    
    normal: "Normal (< 1.5x)" { class: cell_normal }
    warning: "Warning (1.5-2.0x)" { class: cell_warning }
    critical: "Critical (> 2.0x)" { class: cell_critical }
  }
}

# -----------------------------------------------------------------------------------------
# DETECTION PIPELINE
# -----------------------------------------------------------------------------------------
pipeline: {
  label: "Detection Pipeline"
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  style.stroke-dash: 5

  step1: "1. Gather Timings" { class: pipeline_step }
  step2: "2. Compute Median" { class: pipeline_step }
  step3: "3. Identify Stragglers" { class: pipeline_step }
  step4: "4. Check Consistency" { class: pipeline_step }

  step1 -> step2 -> step3 -> step4: { style.stroke: "#34495e"; style.stroke-width: 2 }
}

# -----------------------------------------------------------------------------------------
# HEATMAP GRID
# -----------------------------------------------------------------------------------------
heatmap: {
  label: "Timing Heatmap (ms) - Step vs Rank"
  style.fill: "#1a1a2e"
  style.stroke: "#16213e"

  # Column Headers (Ranks)
  rank_header: {
    grid-columns: 8
    style.fill: transparent
    r0: "Rank 0"; r1: "Rank 1"; r2: "Rank 2"; r3: "Rank 3"
    r4: "Rank 4"; r5: "Rank 5"; r6: "Rank 6"; r7: "Rank 7"
    *.class: header_box
  }

  # Data Rows
  step1: {
    grid-columns: 8
    s1r0: "142" { class: cell_normal }; s1r1: "145" { class: cell_normal }; s1r2: "148" { class: cell_normal }; s1r3: "143" { class: cell_normal }
    s1r4: "147" { class: cell_normal }; s1r5: "198" { class: cell_critical }; s1r6: "144" { class: cell_normal }; s1r7: "146" { class: cell_normal }
  }
  step2: {
    grid-columns: 8
    s2r0: "138" { class: cell_normal }; s2r1: "141" { class: cell_normal }; s2r2: "139" { class: cell_normal }; s2r3: "140" { class: cell_normal }
    s2r4: "137" { class: cell_normal }; s2r5: "185" { class: cell_critical }; s2r6: "142" { class: cell_normal }; s2r7: "140" { class: cell_normal }
  }
  step3: {
    grid-columns: 8
    s3r0: "145" { class: cell_normal }; s3r1: "147" { class: cell_normal }; s3r2: "144" { class: cell_normal }; s3r3: "146" { class: cell_normal }
    s3r4: "143" { class: cell_normal }; s3r5: "192" { class: cell_critical }; s3r6: "148" { class: cell_normal }; s3r7: "144" { class: cell_normal }
  }
  step4: {
    grid-columns: 8
    s4r0: "150" { class: cell_normal }; s4r1: "152" { class: cell_normal }; s4r2: "149" { class: cell_normal }; s4r3: "151" { class: cell_normal }
    s4r4: "148" { class: cell_normal }; s4r5: "201" { class: cell_critical }; s4r6: "153" { class: cell_normal }; s4r7: "149" { class: cell_normal }
  }
  step5: {
    grid-columns: 8
    s5r0: "143" { class: cell_normal }; s5r1: "146" { class: cell_normal }; s5r2: "144" { class: cell_normal }; s5r3: "145" { class: cell_normal }
    s5r4: "142" { class: cell_normal }; s5r5: "188" { class: cell_critical }; s5r6: "147" { class: cell_normal }; s5r7: "144" { class: cell_normal }
  }
  step6: {
    grid-columns: 8
    s6r0: "139" { class: cell_normal }; s6r1: "141" { class: cell_normal }; s6r2: "138" { class: cell_normal }; s6r3: "140" { class: cell_normal }
    s6r4: "137" { class: cell_normal }; s6r5: "176" { class: cell_warning }; s6r6: "142" { class: cell_normal }; s6r7: "139" { class: cell_normal }
  }
  step7: {
    grid-columns: 8
    s7r0: "147" { class: cell_normal }; s7r1: "149" { class: cell_normal }; s7r2: "146" { class: cell_normal }; s7r3: "148" { class: cell_normal }
    s7r4: "145" { class: cell_normal }; s7r5: "195" { class: cell_critical }; s7r6: "150" { class: cell_normal }; s7r7: "146" { class: cell_normal }
  }
  step8: {
    grid-columns: 8
    s8r0: "144" { class: cell_normal }; s8r1: "146" { class: cell_normal }; s8r2: "143" { class: cell_normal }; s8r3: "145" { class: cell_normal }
    s8r4: "141" { class: cell_normal }; s8r5: "189" { class: cell_critical }; s8r6: "147" { class: cell_normal }; s8r7: "143" { class: cell_normal }
  }
  step9: {
    grid-columns: 8
    s9r0: "141" { class: cell_normal }; s9r1: "143" { class: cell_normal }; s9r2: "140" { class: cell_normal }; s9r3: "142" { class: cell_normal }
    s9r4: "139" { class: cell_normal }; s9r5: "183" { class: cell_critical }; s9r6: "144" { class: cell_normal }; s9r7: "140" { class: cell_normal }
  }
  step10: {
    grid-columns: 8
    s10r0: "146" { class: cell_normal }; s10r1: "148" { class: cell_normal }; s10r2: "145" { class: cell_normal }; s10r3: "147" { class: cell_normal }
    s10r4: "144" { class: cell_normal }; s10r5: "197" { class: cell_critical }; s10r6: "149" { class: cell_normal }; s10r7: "145" { class: cell_normal }
  }
}

# -----------------------------------------------------------------------------------------
# STATISTICS PANEL
# -----------------------------------------------------------------------------------------
stats: {
  label: "Detection Statistics"
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"

  median_box: {
    label: "Median Timing: 144 ms"
    style.fill: "#3498db"
    style.font-color: white
  }
  threshold_box: {
    label: "Straggler Threshold: 216 ms (1.5x)"
    style.fill: "#e74c3c"
    style.font-color: white
  }
  detected_box: {
    label: "Detected Straggler: Rank 5"
    style.fill: "#c0392b"
    style.font-color: white
    style.multiple: true
    tooltip: "Consistent delay (+32% avg)"
  }
  consistency_box: {
    label: "Consistency: 10/10 steps ✓"
    style.fill: "#27ae60"
    style.font-color: white
  }
}

# -----------------------------------------------------------------------------------------
# MITIGATION ACTIONS
# -----------------------------------------------------------------------------------------
mitigation: {
  label: "Mitigation Actions"
  style.fill: "#fff3cd"
  style.stroke: "#ffc107"
  
  grid-columns: 2
  action1: "Redistribute Work" { style.fill: "#17a2b8"; style.font-color: white }
  action2: "Reduce Batch Size" { style.fill: "#fd7e14"; style.font-color: white }
  action3: "Isolate & Diagnose" { style.fill: "#dc3545"; style.font-color: white }
  action4: "Exclude from Ring" { style.fill: "#6c757d"; style.font-color: white }
}

# -----------------------------------------------------------------------------------------
# FLOW CONNECTIONS
# -----------------------------------------------------------------------------------------
pipeline.step4 -> stats: "analysis" { style.stroke-width: 2 }
stats.detected_box -> mitigation: "trigger" { style.stroke: red; style.animated: true }
stats -> heatmap: "colorize" { style.stroke-dash: 3 }

# -----------------------------------------------------------------------------------------
# DETECTION ALGORITHM
# -----------------------------------------------------------------------------------------
algorithm: {
  label: "Detection Algorithm"
  style.fill: "#e8f4f8"
  style.stroke: "#17a2b8"
  
  pseudo: |python
    def detect_stragglers(timings, threshold=1.5, window=10, min_occurrences=5):
        # Calculate moving median per rank
        median = np.median(timings, axis=1)
        
        # Binary mask for straggling ranks
        slow_mask = timings > (median * threshold)
        
        # Check temporal consistency
        occurrence_count = slow_mask.sum(axis=0)
        stragglers = np.where(occurrence_count >= min_occurrences)[0]
        
        return stragglers, occurrence_count
  |
}

# -----------------------------------------------------------------------------------------
# DATA SOURCE
# -----------------------------------------------------------------------------------------
timing_source: {
  label: "Rank Timings\n(distributed-all-reduce)"
  shape: hexagon
  style.fill: "#9b59b6"
  style.font-color: white
}
timing_source -> pipeline.step1: "gather" { style.stroke-width: 2 }