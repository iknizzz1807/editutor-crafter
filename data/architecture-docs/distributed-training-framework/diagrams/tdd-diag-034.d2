direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title_container: {
  near: top-center
  style: {
    stroke-width: 0
    fill: transparent
  }
  title: "Memory Profiling Breakdown | 70B Parameter Model" {
    shape: text
    style: {
      font-size: 32
      bold: true
      underline: true
    }
  }
  subtitle: "Total Memory Footprint: ~1,000 GB (1.0 TB) @ FP16/BF16 Mixed Precision" {
    shape: text
    style: {
      font-size: 20
      italic: true
      font-color: "#475569"
    }
  }
}

# --- Section 1: Memory Layout (Address Space Simulation) ---
# Visualizing the 1000GB stack across multiple H100 units
memory_layout: "Physical GPU Memory Layout (H100/A100 Stack)" {
  shape: rectangle
  style: {
    fill: "#f8fafc"
    stroke: "#334155"
    stroke-width: 2
  }

  header: "Byte Offsets (GB) | Relative Addressing" {
    shape: text
    style: {
      bold: true
      font-size: 16
    }
  }

  layout: {
    grid-columns: 1
    grid-gap: 0

    params: "Model Parameters (Weights) | 0.0 - 140.0 GB" {
      tooltip: "70B parameters * 2 bytes (BF16)"
      style: {
        fill: "#7C3AED"
        font-color: white
        bold: true
        stroke: white
        stroke-width: 2
      }
    }
    grads: "Gradients | 140.0 - 280.0 GB" {
      tooltip: "70B grads * 2 bytes (BF16)"
      style: {
        fill: "#2563EB"
        font-color: white
        bold: true
        stroke: white
        stroke-width: 2
      }
    }
    opt_states: "Optimizer States (Adam: m, v) | 280.0 - 840.0 GB" {
      tooltip: "70B * 8 bytes (m, v as FP32)"
      style: {
        fill: "#DC2626"
        font-color: white
        bold: true
        stroke: white
        stroke-width: 2
      }
    }
    activations: "Activations & Temporary Buffers | 840.0 - 1000.0 GB" {
      tooltip: "Batch Size * Seq Len dependent"
      style: {
        fill: "#059669"
        font-color: white
        bold: true
        stroke: white
        stroke-width: 2
      }
    }
  }
}

# --- Section 2: Legend & Categories ---
legend: "Memory Category Definitions" {
  near: bottom-left
  grid-columns: 2
  grid-gap: 15
  style: {
    stroke: "#333333"
    fill: "#f1f5f9"
    stroke-dash: 3
  }

  p_box: "" { style: { fill: "#7C3AED" }; width: 20; height: 20 }
  p_txt: "Parameters: 2 bytes/param (FP16/BF16)" { shape: text }
  
  g_box: "" { style: { fill: "#2563EB" }; width: 20; height: 20 }
  g_txt: "Gradients: 2 bytes/param (FP16/BF16)" { shape: text }
  
  o_box: "" { style: { fill: "#DC2626" }; width: 20; height: 20 }
  o_txt: "Optimizer: 8 bytes/param (Adam FP32)" { shape: text }
  
  a_box: "" { style: { fill: "#059669" }; width: 20; height: 20 }
  a_txt: "Activations: Variable (Checkpointing On)" { shape: text }
}

# --- Section 3: The Detailed Table ---
# FIX: Using unique block string delimiter |# ... #| to prevent Markdown table pipes from closing the block prematurely
memory_details: {
  shape: rectangle
  style: {
    fill: "#FFFFFF"
    stroke: "#334155"
    stroke-width: 1
    shadow: true
  }
  label: |#md
### Tensor Memory Requirements
| Category | Size (GB) | % Total | DType | Implementation Details |
| :--- | :--- | :--- | :--- | :--- |
| **Parameters** | 140 | 14% | BF16 | `70B * 2 bytes` |
| **Gradients** | 140 | 14% | BF16 | Same size as parameters |
| **Optimizer States** | 560 | 56% | FP32 | `70B * (4 + 4) bytes` (Adam) |
| **Activations** | 160 | 16% | BF16 | Checkpointing dependent |
| **TOTAL** | **1,000** | **100%** | - | **Required: 13x H100 (80GB)** |
#|
}

# --- Section 4: Optimization Logic ---
optimization_strategies: "DeepSpeed / ZeRO Optimization Logic" {
  zero_stages: "ZeRO Reductions" {
    style.fill: "#fff7ed"
    style.stroke: "#fb923c"
    
    s1: "Stage 1: Partition Optimizer States" {
      tooltip: "Reduces 560GB memory requirement by 1/N_gpus"
      style.fill: "#ffedd5"
    }
    s2: "Stage 2: Partition Gradients" {
      tooltip: "Further reduces 140GB by 1/N_gpus"
      style.fill: "#fed7aa"
    }
    s3: "Stage 3: Partition Parameters" {
      tooltip: "The 'Infinite' model mode"
      style.fill: "#fdba74"
    }
    s1 -> s2 -> s3: "Increase Distributed Savings"
  }

  checkpointing: "Activation Checkpointing" {
    style.fill: "#eff6ff"
    style.stroke: "#60a5fa"
    method: "Recompute forward pass during backward"
    result: "160GB -> 20GB (8x Compression)" {
      style.font-color: "#1d4ed8"
      style.bold: true
      style.italic: true
    }
  }
}

# --- Section 5: Profiler API (UML) ---
profiler_api: {
  shape: class
  label: "MemoryProfiler"
  style: {
    fill: "#f0fdf4"
    stroke: "#166534"
    stroke-width: 2
  }
  
  + peak_reserved_bytes: uint64
  + current_allocated_bytes: uint64
  + shard_id: int
  
  + start_trace(): void
  + stop_trace(): MemorySnapshot
  + get_summary(): Dict<string, float>
  + export_chrome_trace(path: string): bool
}

# --- Connections and Flow ---
memory_layout.layout.opt_states -> optimization_strategies.zero_stages: "Apply Sharding" {
  style: {
    stroke: "#DC2626"
    stroke-width: 4
    animated: true
  }
}

memory_layout.layout.activations -> optimization_strategies.checkpointing: "Recompute Logic" {
  style: {
    stroke: "#059669"
    stroke-width: 4
    animated: true
  }
}

optimization_strategies -> memory_details: "Updated Totals (Post-Sharding)" {
  style.stroke: "#334155"
  style.stroke-dash: 5
}

memory_details -> profiler_api: "Runtime Validation" {
  style.stroke: "#166534"
}

# --- Footer ---
footer: {
  near: bottom-center
  shape: text
  label: "Note: Analysis assumes Adam optimizer. BF16 training requires master weights in FP32 (4 bytes/param) contained in Optimizer States for numerical stability."
  style: {
    font-size: 14
    italic: true
    font-color: "#64748b"
  }
}