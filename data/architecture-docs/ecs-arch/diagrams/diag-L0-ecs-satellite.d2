      L1: {
        label: "Entity ID | Gen-counted"
        style.fill: "#FFF3E0"
      }
      L2: {
        label: "Storage | Sparse Sets"
        style.fill: "#E8F5E9"
      }
      L3: {
        label: "Logic | Systems"
        style.fill: "#F3E5F5"
      }
      L4: {
        label: "Memory | Archetypes"
        style.fill: "#E3F2FD"
      }
    }
  }
}

