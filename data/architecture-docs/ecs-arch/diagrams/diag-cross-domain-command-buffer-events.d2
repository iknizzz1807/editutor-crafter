direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# ---------------------------------------------------------------------------------
# Header Section
# ---------------------------------------------------------------------------------
title: {
  label: |'md
    # Cross-Domain: Command Buffers as Event Sourcing
    *The architecture pattern powering deferred execution, distributed systems, and version control.*
  '|
}

# ---------------------------------------------------------------------------------
# Row 1: The Core Systems (ECS vs Event Sourcing)
# ---------------------------------------------------------------------------------
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  # --- ECS Abstraction ---
  ecs: {
    direction: down
    label: "ECS Domain: Command Buffer (game_loop.rs)"
    style.stroke-width: 2
    
    frame_n: {
      label: "Frame Execution Boundary (T = 16.6ms)"
      style.fill: "#E8F5E9"
      
      systems: {
        label: "Parallel System Execution"
        style.fill: "#C8E6C9"
        sys1: "MovementSystem(Query<Pos, Vel>)"
        sys2: "AISystem(Query<Behavior>)"
        sys3: "CombatSystem(Query<Health, Attack>)"
        sys1 -> sys2 -> sys3: "dependency"
      }
      
      cmd_buf: {
        label: "Deferred Command Queue (vec<Command>)"
        shape: queue
        style.fill: "#81C784"
        c1: "Spawn{id: 42, type: 'Orc'}"
        c2: "AddComp{e: 42, Pos(0,0)}"
        c3: "Destroy{e: 15}"
        c4: "AddComp{e: 7, Buff(Fire)}"
      }
      systems -> cmd_buf: "push_command()"
    }
    
    flush: {
      label: "Sync Point: flush(world)"
      style.fill: "#FFECB3"
      style.stroke: "#FFA000"
      
      flush_code: {
        shape: code
        label: "World State Mutation"
        code: |'rust
          for cmd in buffer.drain(..) {
            match cmd {
              Spawn{id, ..} => world.spawn(id),
              Destroy{e} => world.despawn(e),
              AddComp{e, c} => world.insert(e, c),
            }
          }
        '|
        width: 320
      }
    }
    frame_n -> flush: "end of frame"
  }

  # --- Conceptual Bridge ---
  bridge: {
    shape: parallelogram
    label: "PATTERN EQUIVALENCE"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.bold: true
  }

  # --- Event Sourcing Abstraction ---
  event_src: {
    direction: down
    label: "Distributed Domain: Event Sourcing (ledger.go)"
    style.stroke-width: 2
    
    event_log: {
      label: "Append-Only Event Store"
      shape: cylinder
      style.fill: "#E3F2FD"
      
      events: {
        label: "Persistence Log"
        shape: queue
        style.fill: "#90CAF9"
        e1: "OrderCreated{uid: 101}"
        e2: "ItemAdded{sku: 'AX-1'}"
        e3: "PaymentValidated{tx: 99}"
        e4: "OrderShipped{pkg: 882}"
      }
    }
    
    projector: {
      label: "Materialized View Projector"
      style.fill: "#FFECB3"
      style.stroke: "#FFA000"
      
      proj_code: {
        shape: code
        label: "State Reduction"
        code: |'rust
          fn apply(state: &mut OrderState, ev: Event) {
            match ev {
              OrderCreated{..} => state.status = Pending,
              ItemAdded{sku}   => state.items.push(sku),
              OrderShipped{..} => state.status = Shipped,
            }
          }
        '|
        width: 320
      }
    }
    event_log -> projector: "replay / stream"
  }
}

# ---------------------------------------------------------------------------------
# Row 2: Equivalence Mapping & Use Cases
# ---------------------------------------------------------------------------------
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  mapping: {
    label: "Structural Mapping"
    eq_table: {
      shape: rectangle
      label: |'md
        | Component | ECS Definition | Event Sourcing Definition |
        | :--- | :--- | :--- |
        | **The Log** | `CommandBuffer` | Event Store / Kafka Topic |
        | **The Atom** | `Command` enum | `Event` payload |
        | **Process** | `world.flush()` | Projection / Aggregation |
        | **State** | `World` (Entities/Comps) | Materialized View / Read Model |
        | **Trigger** | Frame Completion | Transaction / User Action |
      '|
    }
    style.fill: "#F5F5F5"
  }

  apps: {
    label: "Downstream Implementation Strategies"
    direction: right
    style.fill: "#FFF3E0"
    
    networking: {
      label: "Network Replication"
      icon: https://icons.terrastruct.com/infra/019-network.svg
      desc: |'md
        **Delta Sync**
        Serialize the Buffer instead
        of the whole World state.
      '|
      style.fill: "#FFCC80"
    }
    
    replay: {
      label: "Deterministic Replay"
      desc: |'md
        **Bug Reproduction**
        Record user commands + seeds.
        Re-run for bit-perfect failure.
      '|
      style.fill: "#FFCC80"
    }

    undo: {
      label: "Undo / Redo Stack"
      desc: |'md
        **Command Inversion**
        Store 'inverse' commands.
        e.g., `Add` becomes `Remove`.
      '|
      style.fill: "#FFCC80"
    }
  }
}

# ---------------------------------------------------------------------------------
# Row 3: Higher-Level Philosophy
# ---------------------------------------------------------------------------------
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  philosophy: {
    label: "Architectural Shift: Intent-Based vs State-Based"
    direction: right
    width: 1000
    
    state_side: {
      label: "State-Based (Direct Mutation)"
      style.fill: "#FFCDD2"
      content: |'md
        **"What is the value now?"**
        - `health -= 20`
        - Destructive: Loses "How" and "Why"
        - Hard to sync (Requires snapshots)
        - Conflict-prone
      '|
    }
    
    transition: {
      shape: text
      label: "==== transforms to ====>"
    }
    
    intent_side: {
      label: "Intent-Based (Event Log)"
      style.fill: "#C8E6C9"
      content: |'md
        **"What happened to get here?"**
        - `DamageCommand{amt: 20}`
        - Preserves History: Audit trail
        - Easy to sync (Stream of deltas)
        - Conflict-free (Interleave logs)
      '|
    }
  }
}

# ---------------------------------------------------------------------------------
# Metadata and Connections
# ---------------------------------------------------------------------------------
legend: {
  label: "Implementation Summary"
  near: bottom-right
  style.fill: "#E1F5FE"
  content: |'md
    **Engineers:** By implementing an ECS Command Buffer, 
    you have already built an Event Sourcing engine. 
    Exploit this for Networking, Save-Games, and Tools.
  '|
}

# Cross-container references to show relationship
row1.ecs.frame_n.systems -> row1.ecs.flush: "deferred"
row1.event_src.event_log -> row1.event_src.projector: "derivation"

# Global Styles
***.style.font-size: 14
(*** -> ***)[*].style.stroke: "#546E7A"
(*** -> ***)[*].style.stroke-width: 1