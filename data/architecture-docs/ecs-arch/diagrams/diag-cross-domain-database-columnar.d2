direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
header: {
  label: "Cross-Domain: Archetypes as Columnar Database Tables"
  near: top-center
  style.stroke: transparent
  style.fill: transparent
  style.font-size: 24
}

# --- ROW 1: CORE DATA STRUCTURES ---
data_layer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  entity_handle: {
    shape: sql_table
    label: "struct Entity (types.rs)"
    f0: "0x00 | u32 | index // Offset into sparse array"
    f1: "0x04 | u32 | generation // Stale handle detection"
    sz: "Total: 8 bytes (fits in Register)"
  }

  sparse_set_storage: {
    shape: sql_table
    label: "Sparse Set Storage"
    f0: "index_map: Vec<u32> // Sparse indices"
    f1: "dense_entities: Vec<Entity> // Contiguous"
    f2: "dense_data: Vec<T> // Aligned with entities"
    perf: "Best for: High-frequency Add/Remove"
  }

  archetype_chunk: {
    shape: sql_table
    label: "Archetype Table (Columnar)"
    f0: "entities: Vec<Entity>"
    f1: "columns: Vec<Box<[u8]>> // Type-erased stores"
    f2: "capacity: usize"
    f3: "len: usize"
    note: "Memory Layout: SoA (Structure of Arrays)"
  }
}

# --- ROW 2: LIFECYCLE LOGIC ---
logic_layer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  entity_manager: {
    shape: class
    label: "EntityManager (world.rs)"
    -generations: "Vec<u32>"
    -free_list: "Vec<u32>"
    -entity_locations: "Vec<Location>"
    +create(): "Entity"
    +destroy(e: Entity): "void"
    +is_alive(e: Entity): "bool"
    +get_location(e: Entity): "Location"
  }

  recycling_logic: {
    label: "Recycling & Generations"
    code: |'rust
    fn destroy(&mut self, e: Entity) {
      let current_gen = self.generations[e.index];
      // Increment gen to invalidate stale handles
      self.generations[e.index] = current_gen.wrapping_add(1);
      self.free_list.push(e.index);
      self.len -= 1;
    }
    '|
  }

  migration_logic: {
    label: "Entity Migration (Archetype Move)"
    code: |'rust
    fn move_entity(e: Entity, old_arch: ID, new_arch: ID) {
      // 1. Copy shared components to new columns
      // 2. swap_remove from old table (O(1))
      // 3. Update entity_locations[swapped_entity]
      // 4. Update entity_locations[e]
    }
    '|
  }
}

# --- ROW 3: QUERY EXECUTION ---
query_layer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  archetype_registry: {
    shape: class
    label: "ArchetypeRegistry"
    -archetypes: "HashMap<Signature, Archetype>"
    -graph_edges: "HashMap<(ID, TypeID), ID>"
    +get_target(src: ID, add: TypeID): "ID"
    +find_matching(query: Signature): "Vec<ID>"
  }

  query_execution: {
    label: "Query Execution Flow"
    code: |'rust
    for arch in registry.filter(query.signature) {
      let pos_col = arch.column::<Position>();
      let vel_col = arch.column::<Velocity>();
      for i in 0..arch.len {
        pos_col[i] += vel_col[i] * dt;
      }
    }
    '|
  }
}

# --- ANNOTATIONS & FLOWS ---

entity_handle -> entity_manager: "8 bytes | handle"
entity_manager -> recycling_logic: "index | release"
recycling_logic -> entity_handle: "generation++"

archetype_registry -> archetype_chunk: "Signature | map"
archetype_chunk -> query_execution: "Column Ptrs | iterate"

migration_logic -> archetype_chunk: "Move Data"
migration_logic -> entity_manager: "Update Location"

# --- LEGEND ---
legend: {
  near: bottom-right
  direction: down
  
  sparse_set: "Sparse Set: Fast Composition" {
    style.fill: "#E1F5FE"
  }
  archetype: "Archetype: Fast Iteration" {
    style.fill: "#FFF9C4"
  }
}

data_layer.sparse_set_storage.style.fill: "#E1F5FE"
data_layer.archetype_chunk.style.fill: "#FFF9C4"
query_layer.query_execution.style.fill: "#FFF9C4"