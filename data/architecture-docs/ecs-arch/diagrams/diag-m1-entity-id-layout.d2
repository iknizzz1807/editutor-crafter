direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Entity ID Bit Packing {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bit_layout: {
    direction: down
    label: "32-bit Entity ID Structure"
    bits_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      gen_bits: {
        direction: down
        label: "Generation\n(12 bits)"
        style.fill: "#E8D5E0"
        style.stroke: "#9B6B8A"
        style.font-color: "#5D3A6E"
        gen_range: "Bits 20-31"
        gen_max: "Max: 4,096"
        gen_purpose: "Recycle count"
      }
      idx_bits: {
        direction: down
        label: "Index\n(20 bits)"
        style.fill: "#D5E8D4"
        style.stroke: "#6B9B6B"
        style.font-color: "#3A5D3A"
        idx_range: "Bits 0-19"
        idx_max: "Max: 1,048,576"
        idx_purpose: "Slot number"
      }
    }
    packing_formula: {
      label: "Packing Formula"
      width: 350
      code: |'rust
        // Pack index and generation into 32-bit ID
        id = (index << 12) | (generation & 0xFFF)
        // Unpack
        index = id >> 12
        generation = id & 0xFFF
      '|
    }
    masks: {
      label: "Bit Masks (entity.rs)"
      width: 320
      code: |'rust
        const INDEX_BITS: u32 = 20;
        const GENERATION_BITS: u32 = 12;
        const INDEX_MASK: u32 = 0x000FFFFF;
        const GENERATION_MASK: u32 = 0x00000FFF;
      '|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  examples: {
    direction: down
    label: "Entity #42 Through Three Lifetimes"
    lifetime1: {
      direction: right
      label: "Lifetime 1: New Entity"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      l1_box: {
        direction: down
        label: "Entity ID"
        l1_bits: {
          shape: sql_table
          label: "Binary Representation"
          row1: "31-20 | 000000000000 | generation=0"
          row2: "19-0  | 0000000000101010 | index=42"
          total: "Value: 0x00002A = 42"
        }
      }
      l1_desc: {
        label: "State"
        width: 200
        code: |'rust
          // First spawn at frame 100
          let e1 = world.create_entity();
          // e1.id = 42, generation = 0
        '|
      }
    }
    lifetime2: {
      direction: right
      label: "Lifetime 2: After First Recycle"
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
      l2_box: {
        direction: down
        label: "Entity ID"
        l2_bits: {
          shape: sql_table
          label: "Binary Representation"
          row1: "31-20 | 000000000001 | generation=1"
          row2: "19-0  | 0000000000101010 | index=42"
          total: "Value: 0x0010002A = 1,048,618"
        }
      }
      l2_desc: {
        label: "State"
        width: 240
        code: |'rust
          // Frame 150: entity destroyed
          // Frame 200: slot recycled
          let e2 = world.create_entity();
          // e2.id = 42, generation = 1
          // Old handle (42, gen=0) invalid!
        '|
      }
    }
    lifetime3: {
      direction: right
      label: "Lifetime 3: After Second Recycle"
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      l3_box: {
        direction: down
        label: "Entity ID"
        l3_bits: {
          shape: sql_table
          label: "Binary Representation"
          row1: "31-20 | 000000000010 | generation=2"
          row2: "19-0  | 0000000000101010 | index=42"
          total: "Value: 0x0020002A = 2,097,194"
        }
      }
      l3_desc: {
        label: "State"
        width: 240
        code: |'rust
          // Frame 250: entity destroyed
          // Frame 300: slot recycled again
          let e3 = world.create_entity();
          // e3.id = 42, generation = 2
          // Both old handles now invalid
        '|
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  validation: {
    direction: down
    label: "Stale Handle Detection"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    val_scenario: {
      label: "Use-After-Free Prevention"
      width: 380
      code: |'rust
        // Frame 100: Create bullet targeting enemy
        let enemy = world.create_entity();  // (42, gen=0)
        bullet.target = enemy;
        // Frame 150: Enemy destroyed
        world.destroy_entity(enemy);  // gen -> 1
        // Frame 200: Health pickup gets slot 42
        let pickup = world.create_entity();  // (42, gen=1)
        // Frame 201: Bullet hits!
        // VALIDATION CHECK:
        if world.is_alive(bullet.target) {
          // FALSE! (42, gen=0) != current (42, gen=1)
          // Prevents damage to wrong entity
        }
      '|
    }
  }
  comparison: {
    direction: down
    label: "Index vs Generation Bit Trade-off"
    comp_table: {
      shape: sql_table
      label: "Configuration Options"
      opt1: "20 index | 1M entities | 12 gen | 4K recycles"
      opt2: "22 index | 4M entities | 10 gen | 1K recycles"
      opt3: "24 index | 16M entities | 8 gen | 256 recycles"
      chosen: "Chosen: 20/12 (balanced for most games)"
    }
  }
}
row1 -> row2: "same index,\ndifferent lifetimes"
row2 -> row3: "generation mismatch\ndetects stale refs"