direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "Entity Lifecycle State Machine (entity.rs)"
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#f8f9fa"
    stroke-width: 2
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  states: {
    direction: down
    label: "Entity Slot States"
    
    alive: {
      shape: circle
      label: "ALIVE"
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        stroke-width: 3
        font-color: "#1B5E20"
        bold: true
      }
    }
    dead: {
      shape: diamond
      label: "DEAD\n(stale)"
      style: {
        fill: "#FFCDD2"
        stroke: "#C62828"
        stroke-width: 2
        font-color: "#B71C1C"
      }
    }
    free: {
      shape: circle
      label: "FREE\n(stack)"
      style: {
        fill: "#B3E5FC"
        stroke: "#0277BD"
        stroke-width: 2
        font-color: "#01579B"
      }
    }
    unallocated: {
      shape: circle
      label: "UNALLOCATED"
      style: {
        fill: "#F5F5F5"
        stroke: "#616161"
        stroke-width: 2
        font-color: "#212121"
      }
    }
  }

  free_list_container: {
    direction: down
    label: "Memory Management"
    stack_visual: {
      shape: class
      label: "free_list: Vec<usize>"
      -head: "usize | index 5"
      -slot_1: "usize | index 12"
      -slot_2: "usize | index 8"
      -tail: "usize | index 1"
    }
    operations: {
      label: "Stack Logic"
      push_op: "push(idx)" {
        shape: hexagon
        style.fill: "#FFF9C4"
      }
      pop_op: "pop() -> idx" {
        shape: hexagon
        style.fill: "#E1BEE7"
      }
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  logic_units: {
    direction: down
    label: "Lifecycle Implementation"
    
    trans_create_new: {
      label: "create_entity() | NEW"
      code: |'rust
        idx = capacity++;
        generations[idx] = 0;
        Entity::new(idx, 0)
      '|
      width: 300
      style.fill: "#E8F5E9"
    }
    trans_create_recycle: {
      label: "create_entity() | RECYCLE"
      code: |'rust
        idx = free_list.pop();
        gen = generations[idx];
        Entity::new(idx, gen)
      '|
      width: 300
      style.fill: "#E3F2FD"
    }
    trans_destroy: {
      label: "destroy_entity(entity)"
      code: |'rust
        generations[idx] += 1;
        free_list.push(idx);
        len -= 1;
      '|
      width: 300
      style.fill: "#FFEBEE"
    }
  }

  validation: {
    direction: down
    label: "Safety Validation"
    is_alive_check: {
      label: "is_alive(entity)"
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#FBC02D"
      }
    }
    gen_match: "Gen Match" {
      style.fill: "#C8E6C9"
    }
    gen_mismatch: "Gen Stale" {
      style.fill: "#FFCDD2"
    }
    result_true: "RETURN TRUE" {
      shape: parallelogram
      style.fill: "#A5D6A7"
    }
    result_false: "RETURN FALSE" {
      shape: parallelogram
      style.fill: "#EF9A9A"
    }
    
    is_alive_check -> gen_match: "E.gen == G[idx]"
    is_alive_check -> gen_mismatch: "E.gen != G[idx]"
    gen_match -> result_true
    gen_mismatch -> result_false
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  mem_layout: {
    direction: down
    label: "Storage Backend"
    gen_table: {
      shape: sql_table
      label: "generations: Vec<u16>"
      f0: "0x00 | u16 | gen[0] = 3"
      f1: "0x02 | u16 | gen[1] = 1"
      f2: "0x04 | u16 | gen[2] = 0"
      f3: "0x06 | u16 | gen[3] = 5"
      sz: "Total: capacity * 2 bytes"
    }
  }

  packing: {
    direction: down
    label: "ID Specification"
    entity_bits: {
      shape: class
      label: "EntityID (32-bit)"
      -index: "bits [31:12] (20 bits)"
      -generation: "bits [11:0] (12 bits)"
    }
    visual_bits: {
      label: "Bit Layout"
      code: |'text
        [31 ......... 12] [11 ....... 0]
        |     INDEX     | | GENERATION |
        |  (1,048,576)  | |   (4,096)  |
      '|
      width: 350
      style: {
        fill: "#263238"
        font-color: "#FFFFFF"
      }
    }
  }
}

# Root-level connections
row2.logic_units.trans_create_new -> row1.states.unallocated: "alloc"
row2.logic_units.trans_create_recycle -> row1.free_list_container.operations.pop_op: "pop"
row1.free_list_container.operations.pop_op -> row1.states.alive: "recycle"
row1.states.alive -> row2.logic_units.trans_destroy: "destroy"
row2.logic_units.trans_destroy -> row1.free_list_container.operations.push_op: "push"
row1.free_list_container.operations.push_op -> row1.states.free: "index returned"

row1.states.alive -> row1.states.dead: "invalidate"
row1.states.dead -> row1.states.free: "re-stack"

row2.validation.is_alive_check -> row1.states.alive: "verify gen"

example_box: {
  label: "Sequence: Stale Handle Resolution"
  seq: {
    shape: sequence_diagram
    User; World; Registry
    User -> World: "create_entity()"
    World -> Registry: "pop index 5, gen 2"
    Registry -> User: "handle(idx:5, gen:2)"
    User -> World: "destroy(handle(5,2))"
    World -> Registry: "gen[5] += 1, push 5"
    User -> World: "is_alive(handle(5,2))"
    World -> Registry: "check gen(2) == current(3)"
    Registry -> User: "false (stale)"
  }
}

footer_note: {
  label: "Safety Guarantee: Generational indices prevent the 'ABA problem' where a slot is reused but an old handle incorrectly points to new data."
  shape: callout
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
  }
}

header -> row1: {style.stroke: transparent}
row1 -> row2: {style.stroke: transparent}
row2 -> row3: {style.stroke: transparent}
row3 -> example_box: {style.stroke: transparent}

footer_note.near: bottom-center