direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Generation Counter Overflow: 12-Bit Wraparound Scenario"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_timeline: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  t1: "Frame 1" {
    direction: down
    slot5_t1: {
      label: "Entity Slot #5"
      shape: sql_table
      f0: "0x00 | u16 | generation"
      f1: "0x02 | bool | alive"
      val: "gen=0, alive=true"
    }
    bullet_t1: {
      label: "Bullet Reference"
      shape: rectangle
      code: |'rust
        target: Entity {
          index: 5,
          generation: 0
        }
      '|
      width: 180
      style.fill: "#FFE4B5"
    }
    bullet_t1 -> slot5_t1: "holds ref"
  }
  arrow1: {
    label: "Destroy\nx4096"
    shape: text
    style: {
      font-size: 14
      italic: true
    }
  }
  t2: "Frame 100" {
    direction: down
    slot5_t2: {
      label: "Entity Slot #5"
      shape: sql_table
      f0: "0x00 | u16 | generation"
      f1: "0x02 | bool | alive"
      val: "gen=4095, alive=false"
    }
    note_destroy: {
      label: "After 4095 recycles"
      shape: text
      style: {
        font-size: 11
        italic: true
        font-color: "#666666"
      }
    }
  }
  arrow2: {
    label: "Create\n+1"
    shape: text
    style: {
      font-size: 14
      italic: true
    }
  }
  t3: "Frame 101" {
    direction: down
    slot5_t3: {
      label: "Entity Slot #5"
      shape: sql_table
      f0: "0x00 | u16 | generation"
      f1: "0x02 | bool | alive"
      val: "gen=0, alive=true"
      style.fill: "#FFB6C1"
    }
    pickup_t3: {
      label: "Health Pickup\n(now at slot #5)"
      shape: rectangle
      style.fill: "#90EE90"
    }
    pickup_t3 -> slot5_t3: "occupies"
  }
}
row_problem: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  bullet_stale: {
    label: "Stale Bullet Reference\n(from Frame 1)"
    shape: rectangle
    code: |'rust
      target: Entity {
        index: 5,
        generation: 0  // Still 0!
      }
    '|
    width: 180
    style: {
      fill: "#FF6B6B"
      stroke: "#8B0000"
      stroke-width: 2
    }
  }
  validation_check: {
    label: "Validation Check"
    shape: diamond
    code: |'rust
      entity.generation()
        == generations[5]
      // 0 == 0 -> TRUE!
    '|
    width: 200
    style: {
      fill: "#FFD700"
      stroke: "#B8860B"
      stroke-width: 2
    }
  }
  health_pickup: {
    label: "Health Pickup"
    shape: rectangle
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
    }
  }
  bug_result: {
    label: "BUG!\nBullet damages\nhealth pickup"
    shape: callout
    style: {
      fill: "#FF4444"
      font-color: white
      bold: true
    }
  }
  bullet_stale -> validation_check: "is_alive()"
  validation_check -> health_pickup: "valid!\napply damage"
  health_pickup -> bug_result
}
row_bit_layout: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  entity_id_layout: {
    label: "32-Bit Entity ID Layout"
    shape: rectangle
    direction: right
    width: 400
    index_bits: {
      label: "Index\n(20 bits)"
      shape: rectangle
      style: {
        fill: "#87CEEB"
        stroke: "#4169E1"
      }
    }
    gen_bits: {
      label: "Generation\n(12 bits)"
      shape: rectangle
      style: {
        fill: "#DDA0DD"
        stroke: "#8B008B"
      }
    }
  }
  gen_overflow: {
    label: "Generation Overflow Math"
    shape: rectangle
    width: 300
    code: |'rust
      const GEN_BITS: u32 = 12;
      const MAX_GEN: u16 = 4095;
      // At gen=4095:
      gen.wrapping_add(1) // = 0
      // 4096 recycles brings
      // generation back to 0
    '|
  }
}
row_mitigation: "Mitigation Strategies" {
  direction: right
  style: {
    fill: "#F0F8FF"
    stroke: "#4682B4"
    stroke-width: 2
  }
  strategy1: {
    label: "1. More Generation Bits"
    shape: rectangle
    width: 200
    code: |'rust
      // 16-bit generation
      // = 65,536 recycles
      struct Entity {
        id: u64  // 32 idx + 32 gen
      }
    '|
    style.fill: "#E6F3FF"
  }
  strategy2: {
    label: "2. 64-Bit Entity IDs"
    shape: rectangle
    width: 200
    code: |'rust
      // Split 64 bits:
      // 32 index + 32 gen
      // = 4B entities
      // = 4B recycles
    '|
    style.fill: "#E6F3FF"
  }
  strategy3: {
    label: "3. Accept Rare Failure"
    shape: rectangle
    width: 200
    code: |'rust
      // 12 bits = 4096 recycles
      // Stale ref must survive
      // 4096 entity lifetimes
      // at same index
      // 
      // Practically impossible
    '|
    style.fill: "#FFF8DC"
  }
  strategy4: {
    label: "4. Debug Panic on Wrap"
    shape: rectangle
    width: 200
    code: |'rust
      #[cfg(debug_assertions)]
      {
        if gen == MAX_GEN {
          panic!(
            "Gen overflow!"
          );
        }
      }
    '|
    style.fill: "#E6F3FF"
  }
}
row_comparison: "Generation Bit Trade-offs" {
  direction: right
  shape: sql_table
  label: "Entity ID Configuration Options"
  r1: "20 index / 12 gen | 1,048,576 entities | 4,096 recycles | Most common"
  r2: "22 index / 10 gen | 4,194,304 entities | 1,024 recycles | Large worlds"
  r3: "24 index / 8 gen | 16,777,216 entities | 256 recycles | MMO scale"
  r4: "32 index / 32 gen | 4,294,967,296 entities | 4B+ recycles | 64-bit ID"
}
row_timeline -> row_problem: "Same entity reference"
row_problem -> row_bit_layout
row_bit_layout -> row_mitigation
row_mitigation -> row_comparison
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#CCCCCC"
  }
  danger: {
    label: ""
    shape: rectangle
    style.fill: "#FF6B6B"
  }
  danger_label: "Stale/Invalid Reference"
  warn: {
    label: ""
    shape: rectangle
    style.fill: "#FFD700"
  }
  warn_label: "Validation Point"
  safe: {
    label: ""
    shape: rectangle
    style.fill: "#90EE90"
  }
  safe_label: "New Valid Entity"
  overflow: {
    label: ""
    shape: rectangle
    style.fill: "#FFB6C1"
  }
  overflow_label: "Wrapped Generation"
}