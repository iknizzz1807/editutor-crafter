direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "World Container Structure\nSingle owner pattern for clear memory management"
  near: top-center
  style.font-size: 18
  style.bold: true
}

world: {
  label: "World (world.rs)"
  style.fill: "#E8F4F8"
  style.stroke: "#2B6CB0"
  style.stroke-width: 3

  entities: {
    label: "EntityManager"
    shape: class
    style.fill: "#F0FFF4"
    style.stroke: "#38A169"
    "-generations": "Vec<u16>"
    "-free_list": "Vec<usize>"
    "-len": "usize"
    "-capacity": "usize"
    "+create()": "Entity"
    "+destroy(e: Entity)": "bool"
    "+is_alive(e: Entity)": "bool"
  }

  row_components: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    components: {
      label: "ComponentStorage"
      shape: class
      style.fill: "#FFF5F5"
      style.stroke: "#C53030"
      style.stroke-dash: 4
      note: "Metadata: (M2)"
      "+add_component<T>()": "void"
      "+get_component<T>()": "Option<&T>"
      "+remove_entity()": "void"
    }

    systems: {
      label: "SystemScheduler"
      shape: class
      style.fill: "#FAF5FF"
      style.stroke: "#805AD5"
      style.stroke-dash: 4
      note: "Metadata: (M3)"
      "+add_system()": "void"
      "+run()": "void"
    }
  }

  commands: {
    label: "CommandBuffer"
    shape: class
    style.fill: "#FFFAF0"
    style.stroke: "#DD6B20"
    style.stroke-dash: 4
    note: "Metadata: (M3)"
    "+spawn()": "Entity"
    "+destroy()": "void"
    "+insert<T>()": "void"
  }

  world_api: {
    label: "World Public API"
    shape: class
    style.fill: "#EBF8FF"
    style.stroke: "#3182CE"
    "+create_entity()": "Entity"
    "+destroy_entity(e: Entity)": "bool"
    "+is_alive(e: Entity)": "bool"
    "+entity_count()": "usize"
    "+tick(dt: f32)": "void"
  }
}

# Ownership and Flow
world.world_api -> world.entities: "manages"
world.world_api -> world.commands: "records"
world.commands -> world.entities: "deferred mutation"
world.row_components.systems -> world.row_components.components: "queries"

legend: {
  near: bottom-right
  style.fill: "#F7FAFC"
  style.stroke: "#CBD5E0"
  
  m1: {
    label: "Implemented (M1)"
    shape: rectangle
    style.fill: "#F0FFF4"
    style.stroke: "#38A169"
    style.stroke-width: 2
  }
  m23: {
    label: "Placeholder (M2/M3)"
    shape: rectangle
    style.fill: "#FFF5F5"
    style.stroke: "#C53030"
    style.stroke-dash: 4
  }
}

ownership_note: {
  label: "Ownership Model"
  near: bottom-left
  content: |md
    - **World** owns all data (single owner)
    - No shared ownership (Rc/Arc)
    - Clear lifetime boundaries
    - Cache-friendly storage
  |
}