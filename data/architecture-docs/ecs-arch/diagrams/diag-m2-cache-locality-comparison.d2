direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Cache Locality Comparison: HashMap vs Sparse Set {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_compare: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hashmap_side: {
    direction: down
    label: "HashMap<Entity, Position>"
    width: 420
    hm_overview: {
      label: "Iteration Access Pattern"
      width: 400
      style.fill: "#FFE4E4"
      style.stroke: "#CC0000"
      code: |'c
        // Each iteration = multiple cache misses
        for (entity, pos) in hashmap.iter() {
          // Cache miss: load bucket
          // Cache miss: load heap node
          // Cache miss: load Position data
          process(pos);
        }
      '|
    }
    hm_memory: {
      label: "Memory Layout (Heap)"
      width: 400
      style.fill: "#FFF0F0"
      style.stroke: "#AA0000"
      bucket_array: {
        label: "Bucket Array (sparse)"
        width: 380
        style.fill: "#FFCCCC"
        b0: "bucket[0]\n→ ptr"
        b1: "bucket[1]\n→ NULL"
        b2: "bucket[2]\n→ ptr"
        b3: "bucket[3]\n→ ptr"
        b0.style.fill: "#FFDDDD"
        b2.style.fill: "#FFDDDD"
        b3.style.fill: "#FFDDDD"
        b1.style.fill: "#EEEEEE"
      }
      heap_nodes: {
        label: "Heap Nodes (scattered)"
        width: 380
        style.fill: "#FFCCCC"
        node_a: {
          label: |md
            Node @ 0x1A40
            - key: Entity(5)
            - value: Position
            - next: 0x2F00
          |
          style.fill: "#FFBBBB"
          style.stroke: "#880000"
        }
        node_b: {
          label: |md
            Node @ 0x2F00
            - key: Entity(42)
            - value: Position
            - next: NULL
          |
          style.fill: "#FFBBBB"
          style.stroke: "#880000"
        }
        node_c: {
          label: |md
            Node @ 0x7B20
            - key: Entity(9)
            - value: Position
            - next: NULL
          |
          style.fill: "#FFBBBB"
          style.stroke: "#880000"
        }
      }
      position_data: {
        label: "Position Data (scattered)"
        width: 380
        style.fill: "#FFE4E4"
        pos_a: "Position @ 0x1A48\nx=10, y=20"
        pos_b: "Position @ 0x2F08\nx=50, y=60"
        pos_c: "Position @ 0x7B28\nx=90, y=100"
        pos_a.style.fill: "#FF9999"
        pos_b.style.fill: "#FF9999"
        pos_c.style.fill: "#FF9999"
      }
    }
    bucket_array -> heap_nodes.node_a: "ptr" {
      style.stroke-dash: 3
      style.stroke: "#AA0000"
    }
    bucket_array -> heap_nodes.node_c: "ptr" {
      style.stroke-dash: 3
      style.stroke: "#AA0000"
    }
    heap_nodes.node_a -> heap_nodes.node_b: "next" {
      style.stroke-dash: 2
      style.stroke: "#880000"
      style.animated: true
    }
    heap_nodes.node_a -> position_data.pos_a: "value" {
      style.stroke: "#CC0000"
    }
    heap_nodes.node_b -> position_data.pos_b: "value" {
      style.stroke: "#CC0000"
    }
    heap_nodes.node_c -> position_data.pos_c: "value" {
      style.stroke: "#CC0000"
    }
    hm_cache_analysis: {
      label: "Cache Analysis"
      width: 400
      style.fill: "#FFEEEE"
      style.stroke: "#CC0000"
      cache_line1: {
        label: "Cache Line 0 (64 bytes)"
        width: 380
        style.fill: "#FFCCCC"
        style.stroke-dash: 2
        cl1_note: "Only 1 useful Position per cache line fetch"
        cl1_note.shape: text
        cl1_note.style.font-color: "#880000"
      }
      miss_count: {
        label: |md
          **Per-entity access cost:**
          - Bucket lookup: 1 cache miss
          - Node load: 1 cache miss  
          - Position load: 1 cache miss
          - **Total: 3 cache misses/entity**
          **100K entities × 3 = 300K cache misses**
          @ ~100 cycles/miss = **30M cycles**
        |
        style.fill: "#FFDDDD"
      }
    }
  }
  divider: {
    shape: text
    label: |md
      # VS
    |
    width: 60
    style.fill: transparent
  }
  sparse_side: {
    direction: down
    label: "SparseSet<Position>"
    width: 420
    ss_overview: {
      label: "Iteration Access Pattern"
      width: 400
      style.fill: "#E4FFE4"
      style.stroke: "#00AA00"
      code: |'c
        // Dense array = sequential access
        for pos in sparse_set.dense.iter() {
          // ONE cache line brings in
          // 8-16 Position components!
          process(pos);
        }
      '|
    }
    ss_memory: {
      label: "Memory Layout (Dense)"
      width: 400
      style.fill: "#F0FFF0"
      style.stroke: "#008800"
      sparse_array: {
        label: "Sparse Array (index lookup only)"
        width: 380
        style.fill: "#CCFFCC"
        sp_label: |md
          sparse[entity.index] → dense_index
          (Not touched during iteration!)
        |
        sp_label.shape: text
        sp_label.style.fill: "#DDFFDD"
      }
      dense_array: {
        label: "Dense Array (iteration target)"
        width: 380
        style.fill: "#AAFFAA"
        dense_row: {
          grid-columns: 8
          grid-gap: 0
          style.fill: transparent
          d0: "P0\n10,20"
          d1: "P1\n30,40"
          d2: "P2\n50,60"
          d3: "P3\n70,80"
          d4: "P4\n90,100"
          d5: "P5\n110,120"
          d6: "P6\n130,140"
          d7: "P7\n150,160"
          d0.style.fill: "#88FF88"
          d1.style.fill: "#88FF88"
          d2.style.fill: "#88FF88"
          d3.style.fill: "#88FF88"
          d4.style.fill: "#88FF88"
          d5.style.fill: "#88FF88"
          d6.style.fill: "#88FF88"
          d7.style.fill: "#88FF88"
        }
        cache_boundary1: {
          label: "← 64 bytes (1 cache line) →"
          width: 380
          shape: text
          style.font-color: "#006600"
        }
      }
      entities_array: {
        label: "Entities Array (parallel to dense)"
        width: 380
        style.fill: "#CCFFCC"
        ent_row: {
          grid-columns: 8
          grid-gap: 0
          style.fill: transparent
          e0: "E5"
          e1: "E42"
          e2: "E9"
          e3: "E17"
          e4: "E3"
          e5: "E88"
          e6: "E21"
          e7: "E55"
          e0.style.fill: "#AAFFAA"
          e1.style.fill: "#AAFFAA"
          e2.style.fill: "#AAFFAA"
          e3.style.fill: "#AAFFAA"
          e4.style.fill: "#AAFFAA"
          e5.style.fill: "#AAFFAA"
          e6.style.fill: "#AAFFAA"
          e7.style.fill: "#AAFFAA"
        }
      }
    }
    dense_array.dense_row -> entities_array.ent_row: "parallel\nindex" {
      style.stroke: "#00AA00"
      style.stroke-dash: 2
    }
    ss_cache_analysis: {
      label: "Cache Analysis"
      width: 400
      style.fill: "#EEFFEE"
      style.stroke: "#00AA00"
      cache_benefits: {
        label: |md
          **Per-entity access cost:**
          - Dense array access: sequential
          - CPU prefetcher loads ahead
          - **1 cache line = 8 Positions**
          **100K entities ÷ 8 = 12.5K cache lines**
          @ ~40 cycles/line = **500K cycles**
        |
        style.fill: "#DDFFDD"
      }
      prefetch: {
        label: "Prefetcher Bonus"
        width: 380
        style.fill: "#CCFFCC"
        pf_note: |md
          CPU detects sequential pattern:
          - Loads cache lines ahead automatically
          - L1/L2 hit rate approaches 100%
          - Effective cost: ~4 cycles/entity
        |
        pf_note.shape: text
      }
    }
  }
}
summary: {
  near: bottom-center
  label: "Performance Summary"
  width: 900
  style.fill: "#F5F5F5"
  style.stroke: "#666666"
  style.border-radius: 8
  comparison: {
    grid-columns: 3
    grid-gap: 20
    style.fill: transparent
    metric: {
      label: "Metric"
      style.fill: "#DDDDDD"
      style.bold: true
    }
    hashmap_val: {
      label: "HashMap"
      style.fill: "#FFCCCC"
      style.bold: true
    }
    sparse_val: {
      label: "Sparse Set"
      style.fill: "#CCFFCC"
      style.bold: true
    }
    row1_m: "Cache misses (100K entities)"
    row1_h: "~300,000"
    row1_s: "~12,500"
    row1_h.style.fill: "#FFDDDD"
    row1_s.style.fill: "#DDFFDD"
    row2_m: "Cycles per entity"
    row2_h: "~300"
    row2_s: "~5"
    row2_h.style.fill: "#FFDDDD"
    row2_s.style.fill: "#DDFFDD"
    row3_m: "Total time (100K)"
    row3_h: "~10ms"
    row3_s: "~0.5ms"
    row3_h.style.fill: "#FFDDDD"
    row3_s.style.fill: "#DDFFDD"
    row4_m: "Speedup"
    row4_h: "1x (baseline)"
    row4_s: "**20x faster**"
    row4_h.style.fill: "#EEEEEE"
    row4_s.style.fill: "#AAFFAA"
    row4_s.style.bold: true
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#999999"
  cache_line: {
    shape: rectangle
    label: "64 bytes = 1 cache line"
    style.fill: "#E0E0E0"
    style.stroke: "#666666"
    style.stroke-dash: 2
  }
  cache_miss: {
    shape: rectangle
    label: "Cache miss (~100 cycles)"
    style.fill: "#FFCCCC"
  }
  cache_hit: {
    shape: rectangle  
    label: "Cache hit (~4 cycles)"
    style.fill: "#CCFFCC"
  }
}