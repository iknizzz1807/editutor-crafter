direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: |md
    # Per-Type Component Storage Registry
    Type Erasure Boundary Architecture
  |
}
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  registry: {
    direction: down
    label: "ComponentRegistry (component_registry.rs)"
    style.fill: "#E8F4F8"
    style.stroke: "#2C5282"

    fields: {
      shape: class
      label: "Fields"
      "-storages": "HashMap<TypeId, Box<dyn ComponentStorage>>"
    }
    methods: {
      shape: class
      label: "Methods"
      "+get_or_create<T>()": "&mut SparseSet<T>"
      "+get<T>()": "Option<&SparseSet<T>>"
      "+get_mut<T>()": "Option<&mut SparseSet<T>>"
      "+remove_entity(entity)": "void"
    }
  }

  type_erasure_boundary: {
    label: "Type Erasure Boundary"
    width: 320
    style.fill: "#FFF5E6"
    style.stroke: "#D69E2E"
    style.stroke-dash: 4
    boundary_code: {
      shape: code
      code: |'rust
        // Trait object erases concrete type
        Box<dyn ComponentStorage>

        // Recovery via downcast:
        storage.as_any_mut()
          .downcast_mut::<SparseSet<T>>()
      '|
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  trait_box: {
    direction: down
    label: "ComponentStorage Trait"
    style.fill: "#F0FFF4"
    style.stroke: "#276749"
    
    trait_def: {
      shape: class
      label: "dyn ComponentStorage"
      "+as_any(&self)": "&dyn Any"
      "+as_any_mut(&mut self)": "&mut dyn Any"
      "+remove_entity(&mut self, entity)": "void"
      "+len(&self)": "usize"
    }
    impl_note: {
      label: "Implemented by SparseSet<T>"
      width: 220
      style.fill: transparent
      style.stroke-dash: 3
    }
  }

  arrow_container: {
    width: 80
    style.fill: transparent
    style.stroke: transparent
    msg: {
      shape: text
      label: "maps to"
    }
  }

  sparse_sets: {
    direction: down
    label: "Per-Type SparseSet<T> Instances"
    style.fill: "#FAF5FF"
    style.stroke: "#6B46C1"
    
    position_storage: {
      shape: class
      label: "SparseSet<Position>"
      "-sparse": "Vec<usize>"
      "-dense": "Vec<Position>"
      "-entities": "Vec<Entity>"
      "+insert(entity, Position)": "void"
      "+get(entity)": "Option<&Position>"
      "+remove(entity)": "Option<Position>"
    }
    velocity_storage: {
      shape: class
      label: "SparseSet<Velocity>"
      "-sparse": "Vec<usize>"
      "-dense": "Vec<Velocity>"
      "-entities": "Vec<Entity>"
      "+insert(entity, Velocity)": "void"
      "+get(entity)": "Option<&Velocity>"
      "+remove(entity)": "Option<Velocity>"
    }
    health_storage: {
      shape: class
      label: "SparseSet<Health>"
      "-sparse": "Vec<usize>"
      "-dense": "Vec<Health>"
      "-entities": "Vec<Entity>"
      "+insert(entity, Health)": "void"
      "+get(entity)": "Option<&Health>"
      "+remove(entity)": "Option<Health>"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  type_id_map: {
    direction: down
    label: "TypeId → Storage Lookup"
    style.fill: "#FFF5F5"
    style.stroke: "#C53030"
    
    lookup_table: {
      shape: sql_table
      label: "HashMap Key-Value Pairs"
      row1: "TypeId::of::<Position>() | Box<SparseSet<Position>>"
      row2: "TypeId::of::<Velocity>() | Box<SparseSet<Velocity>>"
      row3: "TypeId::of::<Health>()   | Box<SparseSet<Health>>"
      total: "Generic storage erased to Trait Object"
    }
    lookup_note: {
      label: "TypeId is computed at compile time"
      width: 260
      style.fill: transparent
      style.stroke-dash: 3
    }
  }
}

type_flow: {
  direction: down
  label: "Type Flow: Compile-Time to Runtime"
  style.fill: "#F7FAFC"
  style.stroke: "#4A5568"
  
  step1: {
    label: "1. User calls world.add_component::<Position>(entity, pos)"
    width: 650
  }
  step2: {
    label: "2. Compiler generates TypeId::of::<Position>() at compile time"
    width: 650
  }
  step3: {
    label: "3. Registry.looks up HashMap<TypeId, Box<dyn ComponentStorage>>"
    width: 650
  }
  step4: {
    label: "4. downcast_mut::<SparseSet<Position>>() recovers concrete type"
    width: 650
  }
  step5: {
    label: "5. sparse_set.insert(entity, pos) — type-safe operation"
    width: 650
  }
  step1 -> step2 -> step3 -> step4 -> step5: "→"
}

row1.registry -> row1.type_erasure_boundary: "stores"
row1.type_erasure_boundary -> row2.trait_box: "trait object"
row2.trait_box -> row2.arrow_container
row2.arrow_container -> row2.sparse_sets: "concrete impls"
row1.registry -> row3.type_id_map: "internal map"

row1 -> row2: "Downcast | Recover Type"
row2 -> row3: "Lookup | Map Access"
row3 -> type_flow: "Process Flow"

legend: {
  label: "Legend & Architecture Notes"
  style.fill: "#EDF2F7"
  style.stroke: "#A0AEC0"
  
  note1: "Yellow zone = Type erasure boundary (Trait Objects)"
  note2: "TypeId computed at compile time (Zero Overhead)"
  note3: "downcast at runtime recovers type safety (Any trait)"
}
legend.near: bottom-right