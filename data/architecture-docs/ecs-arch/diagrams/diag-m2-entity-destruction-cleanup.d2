direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Entity Destruction: Cascading Component Cleanup
  Tracing `world.destroy_entity(Entity{index: 5, gen: 2})`
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    direction: down
    label: "Step 1: Mark Dead"
    entity_mgr: {
      label: "EntityManager"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      generations: {
        shape: sql_table
        label: "generations: Vec<u16>"
        r0: "0 | 3"
        r1: "1 | 1"
        r2: "2 | 0"
        r3: "3 | 2"
        r4: "4 | 1"
        r5: "5 | 3 → 4"
        r6: "6 | 0"
        note: "gen[5]++: 3 → 4"
      }
      generations.style.fill: "#C8E6C9"
      free_list: {
        shape: sql_table
        label: "free_list: Vec<usize>"
        f0: "push(5)"
        note: "Index 5 recycled"
      }
      free_list.style.fill: "#FFF9C4"
    }
    entity_handle: {
      shape: rectangle
      label: "Entity{index:5, gen:2}"
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
      style.stroke-dash: 4
    }
    entity_handle.style.opacity: 0.6
    note1: {
      label: |md
        **Generation mismatch!**
        - Handle carries gen=2
        - generations[5] now = 4
        - Future lookups fail ✓
      |
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step2: {
    direction: down
    label: "Step 2: Iterate ComponentStorages"
    registry: {
      shape: class
      label: "ComponentRegistry"
      -storages: "HashMap<TypeId, Box<dyn ComponentStorage>>"
      +remove_entity(entity): "void"
    }
    registry.style.fill: "#E3F2FD"
    registry.style.stroke: "#1976D2"
    iterate_code: {
      label: "ComponentRegistry::remove_entity()"
      width: 380
      code: |'rust
        fn remove_entity(&mut self, entity: Entity) {
            for storage in self.storages.values_mut() {
                storage.remove_entity(entity);  // trait call
            }
        }
      '|
    }
    iterate_code.style.fill: "#F3E5F5"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step3: {
    direction: down
    label: "Step 3: Each Storage Removes Component"
    position_storage: {
      direction: down
      label: "SparseSet<Position>"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      pos_sparse: {
        shape: sql_table
        label: "sparse"
        s0: "0 | 0"
        s1: "1 | EMPTY"
        s2: "2 | 1"
        s3: "3 | EMPTY"
        s4: "4 | 2"
        s5: "5 | 3 → EMPTY"
        s6: "6 | EMPTY"
      }
      pos_sparse.style.fill: "#FFE0B2"
      pos_dense: {
        shape: sql_table
        label: "dense (after swap-remove)"
        d0: "0 | (10,20)"
        d1: "1 | (30,40)"
        d2: "2 | (50,60)"
        note: "Entity 5 removed"
      }
      pos_dense.style.fill: "#FFCC80"
      pos_result: {
        label: "✓ Position removed"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
    }
    velocity_storage: {
      direction: down
      label: "SparseSet<Velocity>"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      vel_sparse: {
        shape: sql_table
        label: "sparse"
        s0: "0 | 0"
        s1: "1 | EMPTY"
        s2: "2 | 1"
        s3: "3 | 2"
        s4: "4 | EMPTY"
        s5: "5 | EMPTY"
        s6: "6 | EMPTY"
        note: "Already EMPTY"
      }
      vel_sparse.style.fill: "#C8E6C9"
      vel_result: {
        label: "✗ No Velocity (skip)"
        shape: rectangle
        style.fill: "#FFECB3"
        style.stroke: "#FFA000"
      }
    }
    health_storage: {
      direction: down
      label: "SparseSet<Health>"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#E53935"
      health_sparse: {
        shape: sql_table
        label: "sparse"
        s0: "0 | EMPTY"
        s1: "1 | 0"
        s2: "2 | EMPTY"
        s3: "3 | 1"
        s4: "4 | EMPTY"
        s5: "5 | 2 → EMPTY"
        s6: "6 | EMPTY"
      }
      health_sparse.style.fill: "#FFCDD2"
      health_dense: {
        shape: sql_table
        label: "dense (after swap-remove)"
        d0: "0 | 80"
        d1: "1 | 100"
        note: "Entity 5 removed"
      }
      health_dense.style.fill: "#EF9A9A"
      health_result: {
        label: "✓ Health removed"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 8
  key1: {
    label: "→ before/after"
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
  }
  check1: {
    label: "✓ Component removed"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  check2: {
    label: "✗ No component (skip)"
    shape: rectangle
    style.fill: "#FFECB3"
    style.stroke: "#FFA000"
  }
  check3: {
    label: "Stale handle"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke-dash: 4
    style.opacity: 0.6
  }
}
row1 -> row2: "destroy_entity(5)\nreturns true"
row2 -> row3: "for each storage:\nstorage.remove_entity(Entity{5,2})"
position_storage.pos_result -> velocity_storage.vel_result: "next storage"
velocity_storage.vel_result -> health_storage.health_result: "next storage"