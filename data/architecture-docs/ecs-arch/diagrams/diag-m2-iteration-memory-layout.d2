direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Dense Array Iteration: Cache Line Utilization
| {near: top-center}

row_main: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  dense_array: {
    direction: down
    label: "Dense Array: Vec<Position> (800 KB for 100K entities)"
    
    cache_line_0: {
      direction: right
      label: "Cache Line 0 (64 bytes)"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      
      pos0: { label: "Pos[0]\nx: 1.0, y: 2.0\n8 bytes"; style.fill: "#C8E6C9" }
      pos1: { label: "Pos[1]\nx: 3.0, y: 4.0\n8 bytes"; style.fill: "#C8E6C9" }
      pos2: { label: "Pos[2]\nx: 5.0, y: 6.0\n8 bytes"; style.fill: "#C8E6C9" }
      pos3: { label: "Pos[3]\nx: 7.0, y: 8.0\n8 bytes"; style.fill: "#C8E6C9" }
      pos4: { label: "Pos[4]\nx: 9.0, y: 10.0\n8 bytes"; style.fill: "#C8E6C9" }
      pos5: { label: "Pos[5]\nx: 11.0, y: 12.0\n8 bytes"; style.fill: "#C8E6C9" }
      pos6: { label: "Pos[6]\nx: 13.0, y: 14.0\n8 bytes"; style.fill: "#C8E6C9" }
      pos7: { label: "Pos[7]\nx: 15.0, y: 16.0\n8 bytes"; style.fill: "#C8E6C9" }
    }
    
    ellipsis: {
      label: "..."
      shape: text
    }
    
    cache_line_N: {
      direction: right
      label: "Cache Line N (64 bytes)"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      style.stroke-dash: 3
      pn0: { label: "Pos[99992]"; style.fill: "#BBDEFB" }
      pn1: { label: "Pos[99993]"; style.fill: "#BBDEFB" }
      pn2: { label: "Pos[99994]"; style.fill: "#BBDEFB" }
      pn3: { label: "Pos[99995]"; style.fill: "#BBDEFB" }
      pn4: { label: "Pos[99996]"; style.fill: "#BBDEFB" }
      pn5: { label: "Pos[99997]"; style.fill: "#BBDEFB" }
      pn6: { label: "Pos[99998]"; style.fill: "#BBDEFB" }
      pn7: { label: "Pos[99999]"; style.fill: "#BBDEFB" }
    }
  }

  cpu_access: {
    direction: down
    label: "CPU Access Pattern"
    
    cpu: {
      label: "CPU Core (L1 Cache: 32KB)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    
    prefetcher: {
      label: "Hardware Prefetcher | loads cache lines ahead"
      shape: rectangle
      style.fill: "#FCE4EC"
      style.stroke: "#E91E63"
    }
    
    access_seq: {
      label: "Access Sequence"
      code: |'c
        // Sequential access - prefetcher wins
        for (int i = 0; i < 100000; i++) {
          pos[i].x += vel[i].dx * dt;
          pos[i].y += vel[i].dy * dt;
        }
      '|
      width: 320
    }
  }
}

row_perf: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  perf_table: {
    label: "Performance Comparison"
    shape: sql_table
    metric: "Metric | Dense Array | Random Access"
    entities_per_line: "Entities/Cache Line | 8 entities | 1 entity"
    cache_efficiency: "Cache Efficiency | 100% | 12.5%"
    cycles_per_entity: "Cycles/Entity | ~4 cycles (L1 hit) | ~100 cycles (L3 miss)"
    time_per_entity: "Time/Entity | ~1 ns | ~30 ns"
    total_100k: "Total (100K entities) | ~0.1 ms | ~3 ms"
    speedup: "Speedup | 30x faster | baseline"
  }
  
  timeline: {
    direction: down
    label: "Iteration Timeline (100K entities)"
    
    t0: {
      direction: right
      label: "Dense Array (~0.1ms)"
      d_frame: {
        width: 50
        label: ""
        style.fill: "#4CAF50"
      }
      d_label: {
        label: "Frame Budget: 16.67ms"
        shape: text
      }
    }
    
    t1: {
      direction: right
      label: "Random Access (~3ms)"
      r_frame: {
        width: 150
        label: ""
        style.fill: "#F44336"
      }
      r_label: {
        label: "Same Frame Budget"
        shape: text
      }
    }
    
    scale: {
      label: "Scale: 150px = 3ms"
      shape: text
    }
  }
}

row_breakdown: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  breakdown: {
    direction: down
    label: "Memory Layouts"
    
    struct_layout: {
      shape: sql_table
      label: "struct Position (8 bytes)"
      f0: "0x00 | f32 | x"
      f1: "0x04 | f32 | y"
      sz: "Total: 8 bytes"
    }
    
    line_util: {
      shape: sql_table
      label: "Cache Line Util (64 bytes)"
      e0: "Bytes 0-7   | Position[0] | 8 bytes"
      e1: "Bytes 8-15  | Position[1] | 8 bytes"
      e2: "Bytes 16-23 | Position[2] | 8 bytes"
      e3: "Bytes 24-31 | Position[3] | 8 bytes"
      e4: "Bytes 32-39 | Position[4] | 8 bytes"
      e5: "Bytes 40-47 | Position[5] | 8 bytes"
      e6: "Bytes 48-55 | Position[6] | 8 bytes"
      e7: "Bytes 56-63 | Position[7] | 8 bytes"
      total: "8 entities per cache line fetch"
    }
  }
  
  memory_hierarchy: {
    direction: down
    label: "Memory Hierarchy Latency"
    
    l1: {
      label: "L1 Cache | 32 KB | 4 cycles"
      style.fill: "#C8E6C9"
    }
    l2: {
      label: "L2 Cache | 256 KB | 12 cycles"
      style.fill: "#DCEDC8"
    }
    l3: {
      label: "L3 Cache | 8 MB | 40 cycles"
      style.fill: "#FFF9C4"
    }
    ram: {
      label: "RAM | 16+ GB | 100+ cycles"
      style.fill: "#FFCCBC"
    }
    
    l1 -> l2: "miss"
    l2 -> l3: "miss"
    l3 -> ram: "miss"
  }
}

row_formula: {
  direction: down
  label: "Computational Efficiency"
  
  formula_dense: {
    label: |'md
      **Dense Array Iteration:**
      - 100,000 entities × 8 bytes = 800 KB (fits in L3 cache)
      - Cache lines needed: 800 KB ÷ 64 bytes = 12,500 lines
      - After warmup: all data hits L1/L3
      - Per entity: 1 L1 cache hit (~4 cycles)
      - **Total: 100k × 4c = 400k cycles ≈ 0.13ms @ 3GHz**
    '|
    width: 500
  }
  
  formula_random: {
    label: |'md
      **Random Access (Pointer Chasing):**
      - Each entity access: random memory location
      - Per entity: 1 L3 cache miss (~100 cycles) + memory overhead
      - **Total: 100k × 100c = 10M cycles ≈ 3.3ms @ 3GHz**
      - **Result: ~25x-30x slower performance**
    '|
    width: 500
  }
}

legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style.fill: white
  style.stroke: gray
  
  green: {
    label: "Cache Hit (fast)"
    shape: rectangle
    style.fill: "#4CAF50"
  }
  red: {
    label: "Cache Miss (slow)"
    shape: rectangle
    style.fill: "#F44336"
  }
  blue: {
    label: "Prefetch Target"
    shape: rectangle
    style.fill: "#2196F3"
    style.stroke-dash: 3
  }
}

row_main.dense_array.cache_line_0 -> row_main.cpu_access.cpu: "L1 hit" { style.stroke: "#4CAF50" }
row_main.cpu_access.prefetcher -> row_main.dense_array.cache_line_N: "Prefetch" { style.stroke: "#2196F3"; style.stroke-dash: 3 }