direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  invalid: {
    style: {
      fill: "#2d2d2d"
      font-color: "#888888"
      stroke: "#555555"
      stroke-dash: 3
    }
  }
  valid-sparse: {
    style: {
      fill: "#1a4a3a"
      font-color: "#4ade80"
      stroke: "#22c55e"
    }
  }
  dense-slot: {
    style: {
      fill: "#1a3a5a"
      font-color: "#60a5fa"
      stroke: "#3b82f6"
    }
  }
  entity-slot: {
    style: {
      fill: "#4a1a4a"
      font-color: "#c084fc"
      stroke: "#a855f7"
    }
  }
  header: {
    style: {
      bold: true
      font-size: 14
      fill: "#333333"
      font-color: "#ffffff"
    }
  }
  container-box: {
    style: {
      stroke: "#666666"
      stroke-width: 2
      fill: "#1e1e1e"
      border-radius: 8
    }
  }
}
title: |md
  # Sparse Set: Anatomy of the Data Structure
| {near: top-center}
subtitle: |md
  O(1) add/remove/lookup with cache-friendly dense iteration
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sparse_container: Sparse Array (indexed by entity.index()) {
    direction: down
    class: container-box
    width: 280
    sparse_header: {
      class: header
      label: "sparse: Vec<usize>"
    }
    sparse_grid: {
      grid-columns: 2
      grid-gap: 4
      idx0: "0"
      val0: "EMPTY" {class: invalid}
      idx1: "1"
      val1: "0" {class: valid-sparse}
      idx2: "2"
      val2: "EMPTY" {class: invalid}
      idx3: "3"
      val3: "1" {class: valid-sparse}
      idx4: "4"
      val4: "2" {class: valid-sparse}
      idx5: "5"
      val5: "EMPTY" {class: invalid}
      idx6: "6"
      val6: "3" {class: valid-sparse}
      idx7: "7"
      val7: "EMPTY" {class: invalid}
    }
    sparse_note: |md
      Size = max entity index + 1
      EMPTY = usize::MAX sentinel
    |
  }
  arrow_container: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    width: 60
    lookup_label: {
      label: "O(1)\nlookup"
      style.font-size: 12
      style.font-color: "#888888"
    }
  }
  dense_container: Dense Array (contiguous components) {
    direction: down
    class: container-box
    width: 320
    dense_header: {
      class: header
      label: "dense: Vec<Position>"
    }
    dense_grid: {
      grid-columns: 4
      grid-gap: 4
      d_idx0: "[0]"
      d_x0: "x: 5"
      d_y0: "y: 10"
      d_owner0: "e:1" {class: entity-slot}
      d_idx1: "[1]"
      d_x1: "x: 10"
      d_y1: "y: 20"
      d_owner1: "e:3" {class: entity-slot}
      d_idx2: "[2]"
      d_x2: "x: 15"
      d_y2: "y: 25"
      d_owner2: "e:4" {class: entity-slot}
      d_idx3: "[3]"
      d_x3: "x: 30"
      d_y3: "y: 40"
      d_owner3: "e:6" {class: entity-slot}
    }
    dense_note: |md
      Contiguous memory for
      cache-friendly iteration
    |
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  entities_container: Entities Array (dense index → entity) {
    direction: down
    class: container-box
    width: 320
    entities_header: {
      class: header
      label: "entities: Vec<Entity>"
    }
    entities_grid: {
      grid-columns: 4
      grid-gap: 4
      e_idx0: "[0]"
      e_val0: "Entity(1)" {class: entity-slot}
      e_arrow0: "→"
      e_dense0: "dense[0]"
      e_idx1: "[1]"
      e_val1: "Entity(3)" {class: entity-slot}
      e_arrow1: "→"
      e_dense1: "dense[1]"
      e_idx2: "[2]"
      e_val2: "Entity(4)" {class: entity-slot}
      e_arrow2: "→"
      e_dense2: "dense[2]"
      e_idx3: "[3]"
      e_val3: "Entity(6)" {class: entity-slot}
      e_arrow3: "→"
      e_dense3: "dense[3]"
    }
    entities_note: |md
      Reverse mapping for swap-and-pop
    |
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  trace_container: Lookup Trace: Entity(3) → Position {
    direction: down
    class: container-box
    width: 600
    step1: {
      label: "Step 1: Extract Index"
      code: |'rust
        let index = entity.index();  // index = 3
      '|
    }
    step2: {
      label: "Step 2: Sparse Lookup"
      code: |'rust
        let dense_idx = sparse[3];   // dense_idx = 1
        if dense_idx == EMPTY { return None; }
      '|
    }
    step3: {
      label: "Step 3: Dense Access"
      code: |'rust
        let pos = &dense[1];         // Position { x: 10, y: 20 }
      '|
    }
    trace_result: {
      label: "Result: Position(10, 20)"
      style.fill: "#1a4a3a"
      style.font-color: "#4ade80"
      style.border-radius: 4
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ops_container: Operations Summary {
    direction: right
    class: container-box
    width: 600
    op_add: {
      label: "insert(entity, component)"
      code: |'rust
        sparse[entity.index] = dense.len();
        dense.push(component);
        entities.push(entity);
      '|
      style.fill: "#1a3a4a"
    }
    op_get: {
      label: "get(entity)"
      code: |'rust
        let i = sparse[entity.index];
        if i == EMPTY { None }
        else { Some(&dense[i]) }
      '|
      style.fill: "#1a3a4a"
    }
    op_remove: {
      label: "remove(entity)"
      code: |'rust
        let i = sparse[entity.index];
        dense.swap_remove(i);
        entities.swap_remove(i);
        // Update swapped entity's sparse entry
      '|
      style.fill: "#1a3a4a"
    }
  }
}
legend: |md
  **Legend:** 
  - Gray slots = EMPTY (usize::MAX) — no component
  - Green slots = Valid sparse index → dense array
  - Blue slots = Position component data
  - Purple = Entity ID for reverse lookup
| {near: bottom-center}