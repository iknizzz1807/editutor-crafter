direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Sparse Set Operations {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  panel_add: Add Component {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    step1: "1. sparse[entity] = dense.len()" {
      shape: step
      style.fill: "#C8E6C9"
    }
    step2: "2. push component to dense[]" {
      shape: step
      style.fill: "#C8E6C9"
    }
    step3: "3. push entity to entities[]" {
      shape: step
      style.fill: "#C8E6C9"
    }
    step1 -> step2
    step2 -> step3
    complexity_add: "Time: O(1) amortized" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#2E7D32"
      style.bold: true
    }
  }
  panel_remove: Remove (Swap-and-Pop) {
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    rstep1: "1. sparse[entity] = EMPTY" {
      shape: step
      style.fill: "#FFCDD2"
    }
    rstep2: "2. swap removed with last" {
      shape: step
      style.fill: "#FFCDD2"
    }
    rstep3: "3. update swapped sparse[]" {
      shape: step
      style.fill: "#FFCDD2"
    }
    rstep4: "4. pop from dense/entities" {
      shape: step
      style.fill: "#FFCDD2"
    }
    rstep1 -> rstep2
    rstep2 -> rstep3
    rstep3 -> rstep4
    complexity_rm: "Time: O(1)" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#C62828"
      style.bold: true
    }
  }
  panel_lookup: Lookup Component {
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    lstep1: "1. index = sparse[entity]" {
      shape: step
      style.fill: "#BBDEFB"
    }
    lstep2: "2. if index != EMPTY" {
      shape: diamond
      style.fill: "#BBDEFB"
    }
    lstep3: "3. return dense[index]" {
      shape: step
      style.fill: "#BBDEFB"
    }
    lstep4: "return None" {
      shape: step
      style.fill: "#FFECB3"
    }
    lstep1 -> lstep2
    lstep2 -> lstep3: "yes"
    lstep2 -> lstep4: "no"
    complexity_lk: "Time: O(1)" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#1565C0"
      style.bold: true
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_add: Memory Layout After Add {
    direction: right
    style.fill: "#FAFAFA"
    sparse_add: {
      label: "sparse[]"
      shape: sql_table
      e0: "0 | 0"
      e1: "1 | EMPTY"
      e2: "2 | 1"
      e3: "3 | EMPTY"
      note: "Index → dense pos"
    }
    dense_add: {
      label: "dense[]"
      shape: sql_table
      d0: "0 | Pos{1,2}"
      d1: "1 | Pos{5,6}"
      note: "Packed data"
    }
    entities_add: {
      label: "entities[]"
      shape: sql_table
      en0: "0 | Entity(0)"
      en1: "1 | Entity(2)"
      note: "Reverse lookup"
    }
    sparse_add -> dense_add: "0 → dense[0]"
    dense_add -> entities_add: "parallel"
  }
  memory_remove: Memory Layout After Remove {
    direction: right
    style.fill: "#FAFAFA"
    sparse_rm: {
      label: "sparse[]"
      shape: sql_table
      e0: "0 | EMPTY"
      e1: "1 | EMPTY"
      e2: "2 | 0"
      e3: "3 | EMPTY"
      note: "Entity 0 removed"
    }
    dense_rm: {
      label: "dense[]"
      shape: sql_table
      d0: "0 | Pos{5,6}"
      note: "Swapped from last"
    }
    entities_rm: {
      label: "entities[]"
      shape: sql_table
      en0: "0 | Entity(2)"
      note: "Entity 2 now at 0"
    }
    sparse_rm -> dense_rm
    dense_rm -> entities_rm
  }
  memory_lookup: Lookup Path Trace {
    direction: down
    style.fill: "#FAFAFA"
    code: {
      width: 280
      code: |'rust
        fn get(&self, entity: Entity) -> Option<&T> {
            let index = entity.index();
            if index >= self.sparse.len() {
                return None;
            }
            let dense_idx = self.sparse[index];
            if dense_idx == EMPTY {
                return None;
            }
            Some(&self.dense[dense_idx])
        }
      '|
    }
    path_note: "Two array accesses → component" {
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
  }
}
legend: {
  near: bottom-center
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
 EMPTY: "EMPTY = usize::MAX (sentinel for absent)" {
    shape: text
    style.font: mono
  }
  dense_desc: "dense[]: Contiguous packed components (cache-friendly iteration)" {
    shape: text
  }
  sparse_desc: "sparse[]: Direct-indexed lookup table (grows to max entity index)" {
    shape: text
  }
  entities_desc: "entities[]: Parallel to dense, maps row → Entity for reverse lookup" {
    shape: text
  }
}