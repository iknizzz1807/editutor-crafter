direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "API Safety: Preventing Mutation During Iteration" {
  shape: rectangle
  near: top-center
  style.stroke: transparent
  style.fill: transparent
  style.font-size: 24
  style.bold: true
}

row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  unsafe_approach: {
    direction: down
    label: "UNSAFE API (Direct Mutation)"
    style.fill: "#2d1b1b"
    style.stroke: "#8b3a3a"
    style.font-color: "#ff6b6b"

    world_unsafe: {
      label: "World (world.rs)"
      shape: class
      style.fill: "#3d2020"
      style.font-color: "#ff8888"
      "+add_component<T>(entity, component)": "void"
      "+remove_component<T>(entity)": "Option<T>"
      "+destroy_entity(entity)": "bool"
      "+create_entity()": "Entity"
      "+storage_mut<T>()": "Option<&mut SparseSet<T>>"
    }

    system_code_unsafe: {
      label: "System Function"
      width: 320
      code: |'rust
        fn collision_system(world: &mut World) {
          // world is &mut, allowing structural changes
          for (e, pos) in world.storage_mut::<Pos>() {
            if collides(pos) {
              // BUG: Modifies storage during iteration!
              world.destroy_entity(e);
              // swap-and-pop moves data under iterator
            }
          }
        }
      '|
      style.fill: "#3d2020"
      style.stroke: "#8b3a3a"
      style.font-color: "#ffaaaa"
    }

    bug_result: {
      label: "Iterator Invalidation"
      shape: diamond
      style.fill: "#5a1a1a"
      style.stroke: "#ff4444"
      style.font-color: "#ff6666"
    }

    world_unsafe -> system_code_unsafe: "&mut World" {
      style.stroke: "#ff4444"
      style.stroke-dash: 3
    }
    system_code_unsafe -> bug_result: "UB / Panic" {
      style.stroke: "#ff4444"
      style.animated: true
    }
  }

  safe_approach: {
    direction: down
    label: "SAFE API (Deferred Commands)"
    style.fill: "#1b2d1b"
    style.stroke: "#3a8b3a"
    style.font-color: "#6bff6b"

    commands_trait: {
      label: "Commands (commands.rs)"
      shape: class
      style.fill: "#203d20"
      style.font-color: "#88ff88"
      "+spawn()": "Entity"
      "+destroy(entity)": "void"
      "+insert<T>(entity, component)": "void"
      "+remove<T>(entity)": "void"
    }

    world_safe: {
      label: "World (Safe Impl)"
      shape: class
      style.fill: "#203d20"
      style.font-color: "#88ff88"
      "+storage<T>()": "Option<&SparseSet<T>>"
      "+destroy_entity(entity)": "bool"
      "-flush_commands()": "void"
    }

    system_code_safe: {
      label: "System Function"
      width: 340
      code: |'rust
        fn collision_system(
          world: &World,           // immutable!
          commands: &mut Commands, // structural changes
        ) {
          for (e, pos) in world.storage::<Pos>() {
            if collides(pos) {
              // SAFE: Queued, not executed immediately
              commands.destroy(e);
              // Iterator stays valid
            }
          }
        }
      '|
      style.fill: "#203d20"
      style.stroke: "#3a8b3a"
      style.font-color: "#aaffaa"
    }

    success_result: {
      label: "Deferred Execution"
      shape: diamond
      style.fill: "#1a5a1a"
      style.stroke: "#44ff44"
      style.font-color: "#66ff66"
    }

    commands_trait -> system_code_safe: "&mut Commands" {
      style.stroke: "#44ff44"
    }
    world_safe -> system_code_safe: "&World" {
      style.stroke: "#44ff44"
      style.stroke-dash: 3
    }
    system_code_safe -> success_result: "Safe Queue" {
      style.stroke: "#44ff44"
    }
  }
}

row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  timeline_container: {
    direction: right
    label: "Execution Flow: Command Pattern"
    
    phase_1: {
      label: "Phase 1: Run Systems"
      shape: rectangle
      width: 250
      style.fill: "#2a4a2a"
      style.stroke: "#44aa44"
      note: "World is Read-Only. Commands are Write-Only queues." {
        style.font-size: 11
        style.font-color: "#88ff88"
      }
    }

    phase_2: {
      label: "Phase 2: Flush Buffer"
      shape: rectangle
      width: 250
      style.fill: "#4a4a2a"
      style.stroke: "#aaaa44"
      note: "Exclusive World access. Commands applied sequentially." {
        style.font-size: 11
        style.font-color: "#ffff88"
      }
    }

    phase_3: {
      label: "Phase 3: Cleanup"
      shape: rectangle
      width: 250
      style.fill: "#2a2a4a"
      style.stroke: "#4444aa"
      note: "Command buffers cleared. Ready for next frame." {
        style.font-size: 11
        style.font-color: "#8888ff"
      }
    }

    phase_1 -> phase_2: "Sync Point"
    phase_2 -> phase_3: "Complete"
  }
}

row_enforcement: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  enforcement: {
    direction: right
    label: "Enforcement Mechanisms"

    compile_time: {
      label: "Rust Borrow Checker"
      width: 320
      code: |'rust
        // The type signature prevents error
        fn run(world: &World, cmd: &mut Commands);

        // Cannot get &mut World while
        // we have &World (read-only)
        // reference for iteration.
      '|
      style.fill: "#1a3a5a"
      style.stroke: "#4488cc"
      style.font-color: "#88ccff"
    }

    runtime_guard: {
      label: "Runtime State Guard"
      width: 320
      code: |'rust
        impl World {
          fn destroy(&mut self, e: Entity) {
            if self.is_iterating {
              panic!("Structural mutation during loop!");
            }
            self.raw_destroy(e);
          }
        }
      '|
      style.fill: "#5a3a1a"
      style.stroke: "#cc8844"
      style.font-color: "#ffcc88"
    }
  }
}

legend: {
  near: bottom-right
  direction: right
  style.stroke: "#888888"
  style.fill: "#f8f8f8"
  
  danger_box: {
    width: 20; height: 20
    style.fill: "#5a1a1a"
    style.stroke: "#ff4444"
  }
  danger_label: "Unsafe / Direct" {
    shape: text
    style.font-size: 12
  }

  safe_box: {
    width: 20; height: 20
    style.fill: "#1a5a1a"
    style.stroke: "#44ff44"
  }
  safe_label: "Safe / Deferred" {
    shape: text
    style.font-size: 12
  }
}