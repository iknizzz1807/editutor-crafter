direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Command Buffer: Deferred Operation Queue {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  systems: Systems {
    direction: down
    label: "System Execution Phase"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    movement_sys: MovementSystem {
      width: 200
      code: |'rust
for (e, pos) in positions.iter_mut() {
  if let Some(vel) = velocities.get(e) {
    pos.x += vel.dx * dt;
  }
}
'|
    }
    collision_sys: CollisionSystem {
      width: 200
      code: |'rust
if bullet_hits_enemy(b, e) {
  commands.destroy(b);
  commands.destroy(e);
  commands.spawn()  // explosion
}
'|
    }
    ai_sys: AISystem {
      width: 200
      code: |'rust
if should_spawn_enemy() {
  let e = commands.spawn();
  commands.insert(e, Enemy{...});
}
'|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arrow_push: "" {
    shape: text
    label: "push"
    style.font-color: "#2196F3"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  command_buffer: EntityCommandBuffer {
    direction: down
    label: "EntityCommandBuffer (ecs_commands.h)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    width: 600
    buffer_struct: {
      shape: sql_table
      label: "struct EntityCommandBuffer"
      f0: "0x00 | Vec<Command> | commands"
      f1: "0x18 | usize        | write_pos"
      f2: "0x20 | bool        | in_flush"
      sz: "Total: 40 bytes"
    }
    command_enum: {
      shape: sql_table
      label: "enum Command (24 bytes each)"
      v0: "SpawnEntity { entity: Entity }"
      v1: "DestroyEntity { entity: Entity }"
      v2: "AddComponent { entity: Entity, component: Box<dyn Any>, type_id: TypeId }"
      v3: "RemoveComponent { entity: Entity, type_id: TypeId }"
    }
    vec_visual: {
      direction: right
      label: "commands: Vec<Command>"
      c0: "[0]" {
        label: "Spawn\nEntity"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        width: 70
      }
      c1: "[1]" {
        label: "Destroy\nEntity(5)"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        width: 80
      }
      c2: "[2]" {
        label: "Destroy\nEntity(12)"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        width: 80
      }
      c3: "[3]" {
        label: "AddComp\n(5, Vel)"
        shape: rectangle
        style.fill: "#BBDEFB"
        style.stroke: "#2196F3"
        width: 80
      }
      c4: "[4]" {
        label: "Spawn\nEntity"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        width: 70
      }
      c5: "[5]" {
        label: "..."
        shape: rectangle
        style.fill: "#F5F5F5"
        style.stroke: "#BDBDBD"
        style.stroke-dash: 3
        width: 50
      }
    }
    state_label: {
      shape: text
      label: "State: Write-Only (no reads allowed)"
      style.font-color: "#2196F3"
      style.bold: true
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  flush_phase: "" {
    direction: down
    label: "Flush Phase"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    flush_header: {
      label: "After All Systems Complete"
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke: "#FF9800"
      width: 250
    }
    flush_code: {
      label: "CommandBuffer::flush()"
      width: 320
      code: |'rust
let commands = mem::take(&mut self.commands);
for cmd in commands {
  match cmd {
    SpawnEntity{e} => world.mark_alive(e),
    DestroyEntity{e} => world.destroy(e),
    AddComponent{e,c,t} => world.insert(e,c),
    RemoveComponent{e,t} => world.remove(e,t),
  }
}
'|
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  world_result: World After Flush {
    direction: right
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    entities_box: Entities {
      label: "World State\n(Mutated)"
      style.fill: "#E1BEE7"
      e_alive: "Entity 3: ALIVE"
      e_dead: "Entity 5: DEAD (destroyed)"
      e_new: "Entity 100: NEW (spawned)"
    }
  }
}
timeline_note: {
  near: bottom-center
  label: |md
**Timeline:**
1. **System Execution** → Commands pushed to buffer (no structural changes)
2. **Flush Phase** → Commands executed sequentially (world mutated)
3. **Next Frame** → Systems see consistent world state
|
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  width: 500
}
systems.movement_sys -> command_buffer: "write-only\n(no reads)" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 5
  style.animated: true
}
systems.collision_sys -> command_buffer: "write-only" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 5
  style.animated: true
}
systems.ai_sys -> command_buffer: "write-only" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 5
  style.animated: true
}
command_buffer -> flush_phase: "flush()" {
  style.stroke: "#FF9800"
  style.bold: true
  label: "drain &\nexecute"
}
flush_phase -> world_result: "apply" {
  style.stroke: "#9C27B0"
  style.bold: true
}