direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Iterator Invalidation Problem
  **Swap-and-pop during iteration corrupts traversal**
| {near: top-center}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: {
    direction: down
    label: "BEFORE Iteration"
    iter_state_before: {
      label: "Iterator State"
      width: 280
      code: |'rust
        // MovementSystem iterating...
        current_index: 2
        dense_array: [E0, E1, E2, E3, E4]
                       ✓    ✓   ←HERE  ?    ?
      '|
    }
    sparse_before: {
      direction: down
      label: "SparseSet<Position>"
      dense_before: {
        shape: sql_table
        label: "dense: Vec<Position>"
        r0: "0 | E0 | (10, 20)"
        r1: "1 | E1 | (30, 40)"
        r2: "2 | E2 | (50, 60)"
        r3: "3 | E3 | (70, 80)"
        r4: "4 | E4 | (90, 100)"
      }
      iter_arrow_before: {
        shape: text
        label: "← iterator here"
        style.font-color: red
        style.bold: true
      }
    }
    sparse_before.dense_before -> sparse_before.iter_arrow_before: {
      style.stroke: red
      style.stroke-width: 2
    }
  }
}
row_action: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  action_box: {
    label: "DURING Iteration at index 2"
    width: 400
    style.fill: "#fff3cd"
    style.stroke: "#856404"
    trigger: {
      width: 380
      code: |'rust
        // Collision detected: bullet hit enemy E3
        // Code calls: world.destroy_entity(E3)
        //
        // SparseSet::remove(E3) triggers swap-and-pop:
        // 1. dense.swap(3, 4)  // swap with last
        // 2. dense.pop()       // remove E3's slot
        // 3. sparse[E4] = 3    // update E4's index
      '|
    }
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after: {
    direction: down
    label: "AFTER destroy_entity(E3)"
    iter_state_after: {
      label: "Iterator State (CORRUPTED)"
      width: 280
      style.fill: "#f8d7da"
      style.stroke: "#721c24"
      code: |'rust
        // Iterator still holds:
        current_index: 3  // will visit next
        dense_array: [E0, E1, E2, E4]
                       ✓    ✓    ✓   ←NEXT
        // PROBLEM: E4's data was at index 4
        // Now E4's data is at index 3
        // Iterator already processed E4 at old position!
      '|
    }
    sparse_after: {
      direction: down
      label: "SparseSet<Position> (Mutated)"
      style.fill: "#f8d7da"
      dense_after: {
        shape: sql_table
        label: "dense: Vec<Position>"
        r0: "0 | E0 | (10, 20)"
        r1: "1 | E1 | (30, 40)"
        r2: "2 | E2 | (50, 60)"
        r3: "3 | E4 | (90, 100)  ← SWAPPED!"
        sz: "len: 4 (was 5)"
      }
      iter_arrow_after: {
        shape: text
        label: "← iterator moves to 3"
        style.font-color: "#721c24"
        style.bold: true
      }
    }
    sparse_after.dense_after -> sparse_after.iter_arrow_after: {
      style.stroke: "#721c24"
      style.stroke-width: 2
    }
  }
}
row_bug: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bug_analysis: {
    direction: down
    label: "THE BUG: Three Disasters"
    width: 700
    style.fill: "#f8d7da"
    style.stroke: "#721c24"
    disaster1: {
      label: "Disaster 1: E4 Processed Twice"
      width: 680
      code: |'rust
        // Frame timeline:
        // [i=0] Process E0 at dense[0] ✓
        // [i=1] Process E1 at dense[1] ✓
        // [i=2] Process E2 at dense[2] ✓
        // [i=2] destroy_entity(E3) called
        //        → E4 moves from dense[4] to dense[3]
        // [i=3] Process E4 at dense[3] ← E4 PROCESSED AGAIN!
      '|
    }
    disaster2: {
      label: "Disaster 2: E3 Skipped Entirely"
      width: 680
      code: |'rust
        // E3 was at dense[3]
        // Swap moved E4 into dense[3]
        // Pop removed what was E3's data (now at dense[4])
        // Iterator never visits E3 — logic skipped!
      '|
    }
    disaster3: {
      label: "Disaster 3: Stale References"
      width: 680
      code: |'rust
        // If iterator held &mut Position for E4 at old index...
        // That memory location may now contain garbage or E3's data
        // Use-after-free or data corruption!
      '|
    }
  }
}
row_solution: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  solution: {
    direction: down
    label: "SOLUTION: Command Buffer"
    width: 700
    style.fill: "#d4edda"
    style.stroke: "#155724"
    solution_code: {
      width: 680
      code: |'rust
        // Instead of immediate destruction:
        world.destroy_entity(E3);  // ❌ MUTATES DURING ITERATION
        // Queue destruction via command buffer:
        commands.destroy(E3);      // ✓ DEFERRED UNTIL SAFE
        // After ALL systems complete:
        world.flush_commands();    // Apply all queued mutations
      '|
    }
    timeline: {
      direction: right
      label: "Temporal Boundary"
      phase1: {
        label: "Phase 1\nSystem Execution"
        style.fill: "#cce5ff"
        shape: hexagon
      }
      phase2: {
        label: "Phase 2\nFlush Commands"
        style.fill: "#d4edda"
        shape: hexagon
      }
      phase3: {
        label: "Phase 3\nNext Frame"
        style.fill: "#fff3cd"
        shape: hexagon
      }
      phase1 -> phase2: "queue" {
        style.stroke: "#004085"
        style.stroke-width: 2
      }
      phase2 -> phase3: "apply" {
        style.stroke: "#155724"
        style.stroke-width: 2
      }
    }
    invariant: {
      label: "Invariant"
      width: 680
      style.fill: "#cce5ff"
      code: |'rust
        // During system execution:
        // - Component STORAGE is mutable (pos.x += vel.dx)
        // - Component STRUCTURE is immutable (no add/remove/destroy)
        // - All structural changes go through CommandBuffer
      '|
    }
  }
}
row_before.before.iter_state_before -> row_action.action_box: "collision" {
  style.stroke: orange
  style.stroke-dash: 4
}
row_action.action_box -> row_after.after.iter_state_after: "swap-and-pop" {
  style.stroke: "#721c24"
  style.stroke-width: 2
}
row_after.after.iter_state_after -> row_bug.bug_analysis: "analysis" {
  style.stroke: "#721c24"
  style.stroke-dash: 4
}
row_bug.bug_analysis -> row_solution.solution: "solution" {
  style.stroke: "#155724"
  style.stroke-width: 2
}