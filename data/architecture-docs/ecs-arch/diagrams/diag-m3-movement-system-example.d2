direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: MovementSystem Integration Example {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  left_panel: {
    direction: down
    system_def: System Definition {
      width: 380
      style.fill: "#E8F4E8"
      style.stroke: "#2E7D32"
      code: |'rust
  fn movement_system(world: &mut World, dt: f32) {
      let positions = world.storage_mut::<Position>();
      let velocities = world.storage::<Velocity>();
      for (entity, pos) in positions.iter_mut_with_entity() {
          if let Some(vel) = velocities.get(entity) {
              pos.x += vel.dx * dt;
              pos.y += vel.dy * dt;
          }
      }
  }
  '|
    }
    query_spec: Query Specification {
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      width: 380
      sig: Query Signature {
        shape: class
        label: "Query Filter"
        +requires: "Position"
        +requires: "Velocity"
        +yields: "(Entity, &mut Position, &Velocity)"
      }
    }
    dt_box: Delta Time {
      width: 380
      style.fill: "#FFF3E0"
      style.stroke: "#EF6C00"
      code: |'rust
  let dt: f32 = 0.016;  // 60 FPS frame
  '|
    }
  }
  right_panel: {
    direction: down
    storage_before: BEFORE: Component Storage {
      style.fill: "#FCE4EC"
      style.stroke: "#C62828"
      pos_sparse: Position SparseSet {
        shape: sql_table
        label: "SparseSet<Position>"
        s0: "sparse[0] | 0"
        s1: "sparse[1] | 1"
        s2: "sparse[2] | EMPTY"
        s3: "sparse[3] | 2"
        d0: "dense[0] | Position{1.0, 0.0}"
        d1: "dense[1] | Position{5.0, 3.0}"
        d2: "dense[2] | Position{10.0, 2.0}"
      }
      vel_sparse: Velocity SparseSet {
        shape: sql_table
        label: "SparseSet<Velocity>"
        v0: "sparse[0] | 0"
        v1: "sparse[1] | EMPTY"
        v2: "sparse[2] | EMPTY"
        v3: "sparse[3] | 1"
        d0: "dense[0] | Velocity{10.0, 5.0}"
        d1: "dense[1] | Velocity{20.0, 0.0}"
      }
    }
    entities_box: Entity Summary {
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      width: 380
      e0: Entity 0 {
        shape: class
        label: "Entity(0, gen=1)"
        +Position: "{x: 1.0, y: 0.0}"
        +Velocity: "{dx: 10.0, dy: 5.0}"
        +status: "WILL MOVE"
      }
      e1: Entity 1 {
        shape: class
        label: "Entity(1, gen=1)"
        +Position: "{x: 5.0, y: 3.0}"
        +Velocity: "None"
        +status: "SKIPPED"
      }
      e2: Entity 2 {
        shape: class
        label: "Entity(2, gen=1)"
        +Position: "None"
        +Velocity: "None"
        +status: "SKIPPED"
      }
      e3: Entity 3 {
        shape: class
        label: "Entity(3, gen=1)"
        +Position: "{x: 10.0, y: 2.0}"
        +Velocity: "{dx: 20.0, dy: 0.0}"
        +status: "WILL MOVE"
      }
    }
  }
}
arrow_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  execution_flow: Execution Flow {
    direction: down
    width: 400
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
    step1: "1. Iterate Position dense array" {
      shape: step
    }
    step2: "2. For each, check Velocity.sparse[entity]" {
      shape: step
    }
    step3: "3. If found, update: pos += vel * dt" {
      shape: step
    }
    step4: "4. If not found, skip entity" {
      shape: step
    }
    step1 -> step2
    step2 -> step3: "has Velocity"
    step2 -> step4: "no Velocity"
  }
  calculation: Movement Calculation {
    direction: down
    width: 350
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    calc_title: "dt = 0.016" {
      style.bold: true
    }
    e0_calc: Entity 0 {
      shape: class
      label: "Entity 0 Calculation"
      +before: "pos = (1.0, 0.0)"
      +velocity: "vel = (10.0, 5.0)"
      +delta: "vel * dt = (0.16, 0.08)"
      +after: "pos = (1.16, 0.08)"
    }
    e3_calc: Entity 3 {
      shape: class
      label: "Entity 3 Calculation"
      +before: "pos = (10.0, 2.0)"
      +velocity: "vel = (20.0, 0.0)"
      +delta: "vel * dt = (0.32, 0.0)"
      +after: "pos = (10.32, 2.0)"
    }
    e1_skip: Entity 1 {
      shape: class
      label: "Entity 1 (SKIPPED)"
      +reason: "No Velocity component"
      +result: "pos unchanged = (5.0, 3.0)"
    }
  }
}
result_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  storage_after: AFTER: Component Storage {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    pos_after: Position SparseSet {
      shape: sql_table
      label: "SparseSet<Position> (Updated)"
      s0: "sparse[0] | 0"
      s1: "sparse[1] | 1"
      s2: "sparse[2] | EMPTY"
      s3: "sparse[3] | 2"
      d0: "dense[0] | Position{1.16, 0.08}"
      d1: "dense[1] | Position{5.0, 3.0}"
      d2: "dense[2] | Position{10.32, 2.0}"
      note: "Only E0, E3 changed"
    }
    vel_after: Velocity SparseSet {
      shape: sql_table
      label: "SparseSet<Velocity> (Unchanged)"
      v0: "sparse[0] | 0"
      v1: "sparse[1] | EMPTY"
      v2: "sparse[2] | EMPTY"
      v3: "sparse[3] | 1"
      d0: "dense[0] | Velocity{10.0, 5.0}"
      d1: "dense[1] | Velocity{20.0, 0.0}"
      note: "Velocity is read-only"
    }
  }
  summary: Result Summary {
    direction: down
    width: 380
    style.fill: "#F1F8E9"
    style.stroke: "#558B2F"
    s_title: Movement Results {
      style.bold: true
    }
    s0: Entity 0 {
      shape: class
      label: "Entity 0"
      +moved: "YES"
      +from: "(1.0, 0.0)"
      +to: "(1.16, 0.08)"
    }
    s1: Entity 1 {
      shape: class
      label: "Entity 1"
      +moved: "NO"
      +reason: "Missing Velocity"
      +final: "(5.0, 3.0)"
    }
    s2: Entity 2 {
      shape: class
      label: "Entity 2"
      +moved: "NO"
      +reason: "Missing Position"
      +final: "N/A"
    }
    s3: Entity 3 {
      shape: class
      label: "Entity 3"
      +moved: "YES"
      +from: "(10.0, 2.0)"
      +to: "(10.32, 2.0)"
    }
  }
}
storage_before -> execution_flow: "iterates"
execution_flow -> storage_after: "updates"
calculation -> summary: "produces"
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: "WILL MOVE = has both Position AND Velocity"
  l2: "SKIPPED = missing required component(s)"
  l3: "Sparse lookup = O(1) via sparse array"
}