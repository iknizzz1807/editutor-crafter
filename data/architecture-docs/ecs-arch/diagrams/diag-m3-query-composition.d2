direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "Query Execution: Filtering Entities by Component Presence"
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  step1_box: "Step 1: Identify Position Entities" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"

    position_storage: {
      label: "SparseSet<Position>"
      shape: class
      -sparse: "Vec<usize>"
      -dense: "Vec<Position>"
      -entities: "Vec<Entity>"
    }

    position_lookup: {
      label: "Lookup Process (query_iter.rs)"
      code: |'rust
        // Iterate dense array of primary component
        for (entity, pos) in positions.iter_with_entity() {
          self.check_velocity(entity, pos);
        }
      '|
      width: 320
    }

    position_result: {
      shape: sql_table
      label: "Result: Entities with [Position]"
      row0: "Entity 0 | (0,0)"
      row1: "Entity 1 | (10,5)"
      row2: "Entity 2 | (20,10)"
      row3: "Entity 5 | (15,8)"
      row4: "Entity 8 | (5,3)"
    }
  }

  step2_box: "Step 2: Filter by Velocity Presence" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"

    velocity_storage: {
      label: "SparseSet<Velocity>"
      shape: class
      -sparse: "Vec<usize>"
      -dense: "Vec<Velocity>"
      -entities: "Vec<Entity>"
    }

    velocity_check: {
      label: "O(1) Filter Check"
      code: |'rust
        // sparse[id] maps to index in dense array
        // if value is tombstone (MAX_USIZE), entity lacks component
        if velocities.sparse[entity.id()] != EMPTY {
          yield (entity, pos, &velocities[entity]);
        }
      '|
      width: 320
    }

    velocity_result: {
      shape: sql_table
      label: "Sparse Array Lookups"
      va0: "sparse[0] -> 0  | VALID"
      va1: "sparse[1] -> N/A| EMPTY"
      va2: "sparse[2] -> 1  | VALID"
      va3: "sparse[5] -> N/A| EMPTY"
      va4: "sparse[8] -> 2  | VALID"
    }
  }
}

row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  intersection_box: "Step 3: Set Intersection Result" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 380

    venn: {
      direction: right
      style.stroke: transparent
      set_p: {
        label: "Position Only"
        shape: circle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
        width: 140
        height: 140
        e1: "E1"
        e5: "E5"
      }
      set_overlap: {
        label: "P ∩ V"
        shape: oval
        style.fill: "#FFE0B2"
        style.stroke: "#F57C00"
        width: 100
        height: 100
        e0: "E0"
        e2: "E2"
        e8: "E8"
      }
      set_v: {
        label: "Velocity Only"
        shape: circle
        style.fill: "#BBDEFB"
        style.stroke: "#2196F3"
        width: 140
        height: 140
        e3: "E3"
      }
    }

    intersection_details: {
      shape: sql_table
      label: "Moving Entities (Yielded)"
      m0: "Entity 0: Pos(0,0), Vel(1,0)"
      m2: "Entity 2: Pos(20,10), Vel(-1,2)"
      m8: "Entity 8: Pos(5,3), Vel(0,1)"
    }

    excluded: {
      label: "Filtered Out"
      style.fill: "#FFECB3"
      ex1: "E1: Static (No Velocity)"
      ex5: "E5: Static (No Velocity)"
      ex3: "E3: Ghost (No Position)"
    }
  }

  output_box: "Step 4: Iterator Yields Tuples" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    width: 350

    iterator_type: {
      label: "QueryIterator<'w, (P, V)>"
      shape: class
      +next(): "Option<(Entity, &P, &V)>"
    }

    yield_example: {
      label: "System Dispatch"
      code: |'rust
        fn update_motion(mut query: Query<(&mut Position, &Velocity)>) {
          // System logic operates only on intersection
          for (mut pos, vel) in query.iter_mut() {
            pos.apply_velocity(vel);
          }
        }
      '|
      width: 320
    }
    
    perf_note: {
      shape: callout
      label: "Linear cache access for Position storage"
    }
  }
}

flow_annotation: {
  near: bottom-center
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  width: 750
  
  complexity: {
    shape: sql_table
    label: "Algorithm Analysis"
    c1: "Step 1 | Linear Scan | O(N_pos)"
    c2: "Step 2 | Random Access (Sparse) | O(1)"
    c3: "Total  | Query Runtime | O(N_primary_set)"
    c4: "Note: Always scans the smallest set to minimize cache misses"
  }
}

row1.step1_box.position_result -> row1.step2_box.velocity_result: "Entity ID" {
  style.stroke-dash: 3
  style.animated: true
}

row1.step2_box.velocity_result -> row2.intersection_box: "Check passed" {
  style.stroke-dash: 3
}

row2.intersection_box -> row2.output_box: "Yield to System" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}