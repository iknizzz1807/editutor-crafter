direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # System Registration & Execution Order
| {near: top-center}
row_world: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  world: World {
    direction: down
    label: "World (scheduler.rs)"
    style.fill: "#E8F4E8"
    style.stroke: "#2D5A2D"
    systems: systems: Vec<Box<dyn System>> {
      shape: class
      label: "Vec<Box<dyn System>>"
      -systems: "Vec<Box<dyn System>>"
      -command_buffer: "CommandBuffer"
      +add_system(s): "&mut Self"
      +tick(dt): "void"
    }
  }
}
row_systems: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sys1: InputSystem {
    shape: class
    label: "InputSystem (input.rs)"
    +name: "&'static str"
    +components: "ComponentMask"
    +run(world, dt): "void"
    style.fill: "#FFF4E6"
    style.stroke: "#CC8800"
  }
  sys2: MovementSystem {
    shape: class
    label: "MovementSystem (movement.rs)"
    +name: "&'static str"
    +components: "ComponentMask"
    +run(world, dt): "void"
    style.fill: "#E6F3FF"
    style.stroke: "#0066CC"
  }
  sys3: CollisionSystem {
    shape: class
    label: "CollisionSystem (collision.rs)"
    +name: "&'static str"
    +components: "ComponentMask"
    +run(world, dt): "void"
    style.fill: "#FFE6E6"
    style.stroke: "#CC0000"
  }
  sys4: RenderSystem {
    shape: class
    label: "RenderSystem (render.rs)"
    +name: "&'static str"
    +components: "ComponentMask"
    +run(world, dt): "void"
    style.fill: "#F0E6FF"
    style.stroke: "#6600CC"
  }
}
row_exec: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  exec: ExecutionLoop {
    direction: down
    label: "Execution Loop (tick)"
    style.fill: "#F5F5F5"
    style.stroke: "#666666"
    width: 600
    step1: "1. InputSystem.run(world, dt)" {
      style.fill: "#FFF4E6"
      style.stroke: "#CC8800"
    }
    step2: "2. MovementSystem.run(world, dt)" {
      style.fill: "#E6F3FF"
      style.stroke: "#0066CC"
    }
    step3: "3. CollisionSystem.run(world, dt)" {
      style.fill: "#FFE6E6"
      style.stroke: "#CC0000"
    }
    step4: "4. RenderSystem.run(world, dt)" {
      style.fill: "#F0E6FF"
      style.stroke: "#6600CC"
    }
    step5: "5. flush_commands()" {
      style.fill: "#E0E0E0"
      style.stroke: "#666666"
      style.stroke-dash: 3
    }
  }
}
world.systems -> sys1: "Box::new()" {
  style.stroke: "#2D5A2D"
  style.stroke-width: 2
}
world.systems -> sys2: "Box::new()" {
  style.stroke: "#2D5A2D"
  style.stroke-width: 2
}
world.systems -> sys3: "Box::new()" {
  style.stroke: "#2D5A2D"
  style.stroke-width: 2
}
world.systems -> sys4: "Box::new()" {
  style.stroke: "#2D5A2D"
  style.stroke-width: 2
}
sys1 -> exec.step1: "executes" {
  style.stroke-dash: 3
  style.stroke: "#888888"
}
sys2 -> exec.step2: "executes" {
  style.stroke-dash: 3
  style.stroke: "#888888"
}
sys3 -> exec.step3: "executes" {
  style.stroke-dash: 3
  style.stroke: "#888888"
}
sys4 -> exec.step4: "executes" {
  style.stroke-dash: 3
  style.stroke: "#888888"
}
exec.step1 -> exec.step2: "next" {
  style.stroke: "#333333"
  style.stroke-width: 2
}
exec.step2 -> exec.step3: "next" {
  style.stroke: "#333333"
  style.stroke-width: 2
}
exec.step3 -> exec.step4: "next" {
  style.stroke: "#333333"
  style.stroke-width: 2
}
exec.step4 -> exec.step5: "deferred" {
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 4
}
legend: "" {
  near: bottom-right
  direction: down
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  width: 280
  title: "System Trait (system.rs)" {
    style.bold: true
    style.underline: true
  }
  trait_def: {
    shape: class
    label: "trait System"
    +name(): "&str"
    +run(world, dt): "void"
  }
  note: |md
    **Registration order = execution order**
    Systems are stored in Vec and
    executed sequentially each tick().
    Structural changes are queued
    and flushed after all systems.
  |
}