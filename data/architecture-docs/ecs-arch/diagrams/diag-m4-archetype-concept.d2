direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Archetype Concept: Grouping by Component Signature
  Entities with identical component sets are stored together in contiguous tables
| {near: top-center}
row_entities: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  entities_label: "Individual Entities\n(Scattered Components)" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 20
    style.bold: true
  }
  entity_container: {
    direction: right
    style.fill: "#F5F5F5"
    style.stroke: "#CCCCCC"
    style.stroke-dash: 3
    e0: {
      label: "E0"
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      width: 80
      comps: |md
        Position
        Velocity
      |
    }
    e1: {
      label: "E1"
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      width: 80
      comps: |md
        Position
        Velocity
        Health
      |
    }
    e2: {
      label: "E2"
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      width: 80
      comps: |md
        Position
        Velocity
      |
    }
    e3: {
      label: "E3"
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      width: 80
      comps: |md
        Position
        Velocity
        Health
      |
    }
    e4: {
      label: "E4"
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
      width: 80
      comps: |md
        Position
      |
    }
    e5: {
      label: "E5"
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      width: 80
      comps: |md
        Position
        Velocity
      |
    }
    e6: {
      label: "E6"
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
      width: 80
      comps: |md
        Position
      |
    }
    e7: {
      label: "E7"
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
      width: 80
      comps: |md
        Position
      |
    }
  }
}
arrow_group: "Sort by Signature →" {
  style.fill: transparent
  style.stroke: transparent
  style.font-size: 18
  style.italic: true
}
row_archetypes: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  arch_label: "Archetype Tables\n(Contiguous Storage)" {
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 20
    style.bold: true
  }
  archetypes_container: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    arch_pos_vel: {
      label: "Archetype [Position, Velocity]"
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      style.stroke-width: 2
      table: {
        shape: sql_table
        label: "Row | Position | Velocity"
        r0: "0   | (1, 2)   | (3, 4)"
        r1: "1   | (5, 6)   | (7, 8)"
        r2: "2   | (9, 10)  | (11, 12)"
      }
      entities_tag: "Entities: {E0, E2, E5}" {
        style.fill: transparent
        style.stroke: "#1976D2"
        style.stroke-dash: 2
        style.font-color: "#1976D2"
      }
      table -> entities_tag
    }
    arch_pos_vel_health: {
      label: "Archetype [Position, Velocity, Health]"
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
      style.stroke-width: 2
      table: {
        shape: sql_table
        label: "Row | Position | Velocity | Health"
        r0: "0   | (1, 2)   | (3, 4)   | 100"
        r1: "1   | (5, 6)   | (7, 8)   | 50"
      }
      entities_tag: "Entities: {E1, E3}" {
        style.fill: transparent
        style.stroke: "#388E3C"
        style.stroke-dash: 2
        style.font-color: "#388E3C"
      }
      table -> entities_tag
    }
    arch_pos: {
      label: "Archetype [Position]"
      style.fill: "#FFF3E0"
      style.stroke: "#F57C00"
      style.stroke-width: 2
      table: {
        shape: sql_table
        label: "Row | Position"
        r0: "0   | (20, 21)"
        r1: "1   | (22, 23)"
        r2: "2   | (24, 25)"
      }
      entities_tag: "Entities: {E4, E6, E7}" {
        style.fill: transparent
        style.stroke: "#F57C00"
        style.stroke-dash: 2
        style.font-color: "#F57C00"
      }
      table -> entities_tag
    }
  }
}
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  title: "Key Insight" {
    style.bold: true
    style.font-size: 16
  }
  insight: |md
    - Each archetype is a **table** with fixed columns (component types)
    - All entities in an archetype have the **exact same component signature**
    - Components stored in **parallel arrays** for cache-friendly iteration
    - Query matches at **archetype level**, not per-entity
  |
}
row_entities -> arrow_group: ""
arrow_group -> row_archetypes: ""