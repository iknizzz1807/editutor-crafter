direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Archetype Explosion: The Fragmentation Problem
  **When component combinations multiply beyond control**
| {near: top-center}
row_problem: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  problem_space: {
    direction: down
    label: "The Problem: Exponential Archetype Growth"
    component_types: {
      label: "10 Independent Component Types"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      width: 200
      comp_list: |md
        - Position
        - Velocity  
        - Health
        - AIState
        - RenderData
        - Collider
        - Inventory
        - Dialogue
        - QuestMarker
        - DebugTag
      |
    }
    combination_math: {
      label: "Combination Math"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      width: 200
      math_content: |md
        **Possible combinations:**
        2¹⁰ = **1,024 archetypes**
        With 10,000 entities:
        ~10 entities per archetype
        **Result:** Cache thrashing
      |
    }
    component_types -> combination_math: "random\ncombinations"
  }
  archetype_landscape: {
    direction: down
    label: "Archetype Landscape (Fragmented)"
    archetype_grid: {
      grid-columns: 8
      grid-gap: 4
      style.fill: transparent
      a01: A01 { style.fill: "#C8E6C9"; label: "2 ent" }
      a02: A02 { style.fill: "#FFCDD2"; label: "1 ent" }
      a03: A03 { style.fill: "#C8E6C9"; label: "3 ent" }
      a04: A04 { style.fill: "#FFCDD2"; label: "1 ent" }
      a05: A05 { style.fill: "#FFF9C4"; label: "0 ent" }
      a06: A06 { style.fill: "#FFCDD2"; label: "1 ent" }
      a07: A07 { style.fill: "#FFF9C4"; label: "0 ent" }
      a08: A08 { style.fill: "#C8E6C9"; label: "4 ent" }
      a09: A09 { style.fill: "#FFCDD2"; label: "1 ent" }
      a10: A10 { style.fill: "#FFF9C4"; label: "0 ent" }
      a11: A11 { style.fill: "#FFCDD2"; label: "1 ent" }
      a12: A12 { style.fill: "#FFCDD2"; label: "1 ent" }
      a13: A13 { style.fill: "#C8E6C9"; label: "2 ent" }
      a14: A14 { style.fill: "#FFF9C4"; label: "0 ent" }
      a15: A15 { style.fill: "#FFCDD2"; label: "1 ent" }
      a16: A16 { style.fill: "#FFF9C4"; label: "0 ent" }
      a17: "..." { style.fill: transparent; style.stroke: transparent }
      a18: "..." { style.fill: transparent; style.stroke: transparent }
      a19: "..." { style.fill: transparent; style.stroke: transparent }
      a20: "..." { style.fill: transparent; style.stroke: transparent }
      a21: "..." { style.fill: transparent; style.stroke: transparent }
      a22: "..." { style.fill: transparent; style.stroke: transparent }
      a23: "..." { style.fill: transparent; style.stroke: transparent }
      a24: "..." { style.fill: transparent; style.stroke: transparent }
      a25: A512 { style.fill: "#FFCDD2"; label: "1 ent" }
      a26: A513 { style.fill: "#FFF9C4"; label: "0 ent" }
      a27: A514 { style.fill: "#FFCDD2"; label: "1 ent" }
      a28: A1023 { style.fill: "#FFCDD2"; label: "1 ent" }
      a29: "..." { style.fill: transparent; style.stroke: transparent }
      a30: "..." { style.fill: transparent; style.stroke: transparent }
      a31: "..." { style.fill: transparent; style.stroke: transparent }
      a32: "..." { style.fill: transparent; style.stroke: transparent }
    }
    legend_box: {
      direction: right
      style.stroke: transparent
      leg1: "■ Viable (2+ entities)" { style.fill: "#C8E6C9"; width: 120 }
      leg2: "■ Sparse (1 entity)" { style.fill: "#FFCDD2"; width: 120 }
      leg3: "■ Empty" { style.fill: "#FFF9C4"; width: 100 }
    }
  }
}
problem_space -> archetype_landscape: "creates"
row_impact: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  impact_analysis: {
    direction: down
    label: "Performance Impact"
    cache_behavior: {
      label: "Cache Behavior"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      width: 280
      cache_content: |md
        **Query for (Position, Velocity):**
        1. Visit archetype A01 (2 entities)
           → Cache miss: load 64 bytes
           → Process 2, waste 90% of cache line
        2. Visit archetype A03 (3 entities)  
           → Cache miss: load 64 bytes
           → Process 3, waste 85%
        3. ... repeat for 50+ archetypes
        **Result:** 50 cache misses for 100 entities
        vs. 2 cache misses with dense archetype
      |
    }
    overhead_costs: {
      label: "Management Overhead"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      width: 280
      overhead_content: |md
        **Per-Archetype Costs:**
        - HashMap lookup: ~20 cycles
        - Signature check: O(n) components
        - Iterator setup: ~10 cycles
        **With 50 matching archetypes:**
        50 × 30 cycles = 1,500 cycles overhead
        before processing any data
        **vs. Dense archetype:**
        1 × 30 cycles = 30 cycles overhead
      |
    }
  }
  root_causes: {
    direction: down
    label: "Root Causes"
    cause1: {
      label: "1. Independent Components"
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
      width: 260
      cause1_content: |md
        Components added/removed
        without consideration of
        resulting archetype count
        **Example:** Adding `DebugTag` to
        random entities creates new
        archetypes for each combination
      |
    }
    cause2: {
      label: "2. Marker Component Proliferation"
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
      width: 260
      cause2_content: |md
        Each boolean flag as separate
        component doubles potential
        archetypes
        `IsPlayer`, `IsEnemy`, `IsNPC`,
        `CanBeDamaged`, `IsVisible`...
        → 2⁵ = 32 variants
      |
    }
    cause3: {
      label: "3. Rare Component Addition"
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
      width: 260
      cause3_content: |md
        Adding `Dialogue` component to
        5 NPCs out of 1000 entities
        creates 5 singleton archetypes
        if each has different base
        component set
      |
    }
  }
}
row_mitigation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mitigation_strategies: {
    direction: down
    label: "Mitigation Strategies"
    strategy1: {
      direction: right
      label: "1. Component Grouping"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      before: {
        label: "Before"
        shape: rectangle
        style.fill: "#FFCDD2"
        width: 160
        before_content: |md
          `Health`
          `MaxHealth`
          `Armor`
          `Resistance`
          → 2⁴ = 16 archetypes
          for combat stats alone
        |
      }
      arrow1: "->" {
        label: "combine"
        style.stroke: "#4CAF50"
        style.stroke-width: 3
      }
      after: {
        label: "After"
        shape: rectangle
        style.fill: "#C8E6C9"
        width: 160
        after_content: |md
          `CombatStats`
          {
            health: f32,
            max_health: f32,
            armor: f32,
            resistance: f32
          }
          → 1 archetype
        |
      }
    }
    strategy2: {
      direction: right
      label: "2. Use Bitflags for Markers"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 420
      strategy2_content: |md
        **Instead of:** Separate marker components
        rust
        struct EntityFlags: u32 {
            const IS_PLAYER = 1 << 0;
            const IS_ENEMY = 1 << 1;
            const CAN_BE_DAMAGED = 1 << 2;
            const IS_VISIBLE = 1 << 3;
        }
        
        **Result:** Single `EntityFlags` component
        replaces 4+ marker components
      |
    }
    strategy3: {
      direction: right
      label: "3. Sparse Sets for Rare Components"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 420
      strategy3_content: |md
        **Hybrid Storage:**
        - **Archetypes:** Common components (Position, Velocity, RenderData)
        - **Sparse Sets:** Rare components (Dialogue, QuestMarker, DebugTag)
        Rare components don't fragment archetypes;
        they exist in parallel sparse set storage
      |
    }
    strategy4: {
      direction: right
      label: "4. Monitor Archetype Health"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 420
      strategy4_content: |md
        **Diagnostic Metrics:**
        rust
        fn archetype_health_check(world: &World) {
            let count = world.archetype_count();
            let entities = world.entity_count();
            let ratio = entities as f32 / count as f32;
            if ratio < 10.0 {
                warn!("Archetype fragmentation! Avg {} entities/archetype", ratio);
            }
        }
        
      |
    }
  }
  best_practices: {
    direction: down
    label: "Design Guidelines"
    guideline1: {
      label: "Rule of Thumb"
      shape: diamond
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      width: 200
      guideline1_content: |md
        **Target ratio:**
        entities / archetypes > 50
        If below 20, investigate fragmentation
      |
    }
    guideline2: {
      label: "Component Design Checklist"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      width: 280
      checklist_content: |md
        □ Do these components always appear together?
          → Combine into struct
        □ Is this a boolean flag?
          → Use bitflags in existing component
        □ Is this component rare (<5% of entities)?
          → Use sparse set instead
        □ Does adding this create <10 new archetypes?
          → Acceptable, monitor
        □ Does this vary per entity or per archetype?
          → Per-archetype: consider as resource
      |
    }
    guideline3: {
      label: "Warning Signs"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      width: 280
      warning_content: |md
        🚨 Archetype count grows during gameplay
        🚨 Many archetypes with 1-3 entities
        🚨 Query iteration visits 20+ archetypes
        🚨 Adding a component takes >1ms
        🚨 Memory usage grows unexpectedly
      |
    }
  }
}
mitigation_strategies -> best_practices: "informs"
row_summary: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  summary_box: {
    label: "Key Takeaway"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    width: 600
    summary_content: |md
      **Archetype explosion is a design problem, not an algorithm problem.**
      The solution isn't better archetype management—it's better component design.
      Group related data, use bitflags for markers, and reserve sparse sets for rare components.
      **Healthy ECS:** 10-50 archetypes, 100+ entities per archetype
      **Fragmented ECS:** 500+ archetypes, <10 entities per archetype
    |
  }
}
legend_global: {
  near: bottom-right
  direction: down
  label: "Storage Choice"
  arch: "Archetype: Frequent iteration, stable composition" {
    shape: rectangle
    style.fill: "#C8E6C9"
    width: 200
  }
  sparse: "Sparse Set: Rare component, dynamic add/remove" {
    shape: rectangle
    style.fill: "#BBDEFB"
    width: 200
  }
  hybrid: "Hybrid: Mix both based on access patterns" {
    shape: rectangle
    style.fill: "#E1BEE7"
    width: 200
  }
}