direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Archetype Graph: O(1) Transition Lookup
  Edges cache add/remove operations for instant archetype resolution
| {near: top-center}
legend: {
  near: bottom-right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  add_edge: "Add Component → Green"
  remove_edge: "Remove Component → Red"
  cache_note: |md
    `transitions: HashMap<(ArchetypeId, TypeId), ArchetypeId>`
    Lookup: `O(1)` after first computation
  |
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  archetype_empty: {
    label: "Archetype\n∅ (empty)"
    shape: rectangle
    style.fill: "#e9ecef"
    style.stroke: "#6c757d"
    width: 140
    signature: |md
      **Signature:** `[]`
    |
    entities: "Entities: 0"
    id_label: "ArchetypeId(0)"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  archetype_pos: {
    label: "Archetype\n[Position]"
    shape: rectangle
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    width: 160
    signature: |md
      **Signature:** `[Position]`
    |
    entities: "Entities: 5,000"
    id_label: "ArchetypeId(1)"
    column_layout: {
      label: "Storage Layout"
      pos_col: "Position[] (40 KB)"
    }
  }
  archetype_vel: {
    label: "Archetype\n[Velocity]"
    shape: rectangle
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    width: 160
    signature: |md
      **Signature:** `[Velocity]`
    |
    entities: "Entities: 500"
    id_label: "ArchetypeId(2)"
  }
  archetype_health: {
    label: "Archetype\n[Health]"
    shape: rectangle
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    width: 160
    signature: |md
      **Signature:** `[Health]`
    |
    entities: "Entities: 200"
    id_label: "ArchetypeId(3)"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  archetype_pos_vel: {
    label: "Archetype\n[Position, Velocity]"
    shape: rectangle
    style.fill: "#cfe2ff"
    style.stroke: "#0d6efd"
    width: 180
    signature: |md
      **Signature:** `[Position, Velocity]`
    |
    entities: "Entities: 50,000"
    id_label: "ArchetypeId(4)"
    column_layout: {
      label: "Storage Layout"
      pos_col: "Position[] (400 KB)"
      vel_col: "Velocity[] (400 KB)"
    }
  }
  archetype_pos_health: {
    label: "Archetype\n[Position, Health]"
    shape: rectangle
    style.fill: "#cfe2ff"
    style.stroke: "#0d6efd"
    width: 180
    signature: |md
      **Signature:** `[Position, Health]`
    |
    entities: "Entities: 10,000"
    id_label: "ArchetypeId(5)"
  }
  archetype_vel_health: {
    label: "Archetype\n[Velocity, Health]"
    shape: rectangle
    style.fill: "#cfe2ff"
    style.stroke: "#0d6efd"
    width: 180
    signature: |md
      **Signature:** `[Velocity, Health]`
    |
    entities: "Entities: 300"
    id_label: "ArchetypeId(6)"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  archetype_full: {
    label: "Archetype\n[Position, Velocity, Health]"
    shape: rectangle
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    width: 220
    signature: |md
      **Signature:** `[Health, Position, Velocity]`
    |
    entities: "Entities: 25,000"
    id_label: "ArchetypeId(7)"
    column_layout: {
      label: "Storage Layout (Contiguous)"
      health_col: "Health[] (100 KB)"
      pos_col: "Position[] (200 KB)"
      vel_col: "Velocity[] (200 KB)"
    }
  }
}
cache_structure: {
  label: "Transition Cache (ArchetypeRegistry)"
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#495057"
  style.stroke-dash: 3
  width: 400
  cache_code: |'rust
    // Add-component transitions
    transitions: HashMap<(ArchetypeId, TypeId), ArchetypeId>
    // Example entries:
    // (ArchetypeId(1), TypeId::of::<Velocity>()) → ArchetypeId(4)
    // (ArchetypeId(1), TypeId::of::<Health>())   → ArchetypeId(5)
    // (ArchetypeId(4), TypeId::of::<Health>())   → ArchetypeId(7)
    // Remove-component transitions
    removal_transitions: HashMap<(ArchetypeId, TypeId), ArchetypeId>
    // Example entries:
    // (ArchetypeId(4), TypeId::of::<Velocity>()) → ArchetypeId(1)
    // (ArchetypeId(7), TypeId::of::<Health>())   → ArchetypeId(4)
  '|
}
empty_to_pos: archetype_empty -> archetype_pos: "+Position" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
pos_to_vel: archetype_pos -> archetype_vel: "+Velocity\n-Position" {
  style.stroke: "#28a745"
  style.stroke-width: 2
  style.stroke-dash: 4
}
pos_to_health: archetype_pos -> archetype_health: "+Health\n-Position" {
  style.stroke: "#28a745"
  style.stroke-width: 2
  style.stroke-dash: 4
}
pos_to_pos_vel: archetype_pos -> archetype_pos_vel: "+Velocity" {
  style.stroke: "#28a745"
  style.stroke-width: 3
}
pos_to_pos_health: archetype_pos -> archetype_pos_health: "+Health" {
  style.stroke: "#28a745"
  style.stroke-width: 3
}
vel_to_pos_vel: archetype_vel -> archetype_pos_vel: "+Position" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
health_to_pos_health: archetype_health -> archetype_pos_health: "+Position" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
vel_to_vel_health: archetype_vel -> archetype_vel_health: "+Health" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
health_to_vel_health: archetype_health -> archetype_vel_health: "+Velocity" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
pos_vel_to_full: archetype_pos_vel -> archetype_full: "+Health" {
  style.stroke: "#28a745"
  style.stroke-width: 3
}
pos_health_to_full: archetype_pos_health -> archetype_full: "+Velocity" {
  style.stroke: "#28a745"
  style.stroke-width: 3
}
vel_health_to_full: archetype_vel_health -> archetype_full: "+Position" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
pos_vel_remove_vel: archetype_pos_vel -> archetype_pos: "-Velocity" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
  style.stroke-dash: 4
}
full_remove_health: archetype_full -> archetype_pos_vel: "-Health" {
  style.stroke: "#dc3545"
  style.stroke-width: 3
}
full_remove_vel: archetype_full -> archetype_pos_health: "-Velocity" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
  style.stroke-dash: 4
}
full_remove_pos: archetype_full -> archetype_vel_health: "-Position" {
  style.stroke: "#dc3545"
  style.stroke-width: 2
  style.stroke-dash: 4
}