direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header_node: {
  shape: rectangle
  label: |md
    # Archetype Table: Parallel Contiguous Arrays
    `Archetype(Position, Velocity)`
  |
  style.stroke: transparent
  style.fill: transparent
}

row_layout: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  archetype: {
    direction: down
    label: "Archetype Table (archetype.rs)"
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"

    table_meta: {
      shape: rectangle
      label: |md
        **Signature:** `{Position, Velocity}`
        **Entity Count:** 3
        **Row Size:** 16 bytes (8 + 8)
      |
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      width: 280
    }

    cols: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent

      entities_col: {
        direction: down
        label: "entities: Vec<Entity>"
        style.fill: "#E3F2FD"
        style.stroke: "#1565C0"
        width: 180
        e_header: "row | Entity (u32)" {
          style.fill: "#BBDEFB"
          style.stroke: "#1565C0"
          style.font: mono
          style.bold: true
        }
        e0: "0 | Entity(0x00003)" {
          style.fill: "#E3F2FD"
          style.stroke: "#1565C0"
          style.font: mono
          tooltip: "(idx:0, gen:3)"
        }
        e1: "1 | Entity(0x10005)" {
          style.fill: "#E3F2FD"
          style.stroke: "#1565C0"
          style.font: mono
          tooltip: "(idx:1, gen:5)"
        }
        e2: "2 | Entity(0x20002)" {
          style.fill: "#E3F2FD"
          style.stroke: "#1565C0"
          style.font: mono
          tooltip: "(idx:2, gen:2)"
        }
      }

      positions_col: {
        direction: down
        label: "positions: Vec<Position>"
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
        width: 200
        p_header: "row | Position {x, y}" {
          style.fill: "#FFE0B2"
          style.stroke: "#E65100"
          style.font: mono
          style.bold: true
        }
        p0: "0 | {x: 10.0, y: 20.0}" {
          style.fill: "#FFF3E0"
          style.stroke: "#E65100"
          style.font: mono
          tooltip: "8 bytes (2 x f32)"
        }
        p1: "1 | {x: 50.0, y: 75.0}" {
          style.fill: "#FFF3E0"
          style.stroke: "#E65100"
          style.font: mono
          tooltip: "8 bytes (2 x f32)"
        }
        p2: "2 | {x: 100.0, y: 0.0}" {
          style.fill: "#FFF3E0"
          style.stroke: "#E65100"
          style.font: mono
          tooltip: "8 bytes (2 x f32)"
        }
      }

      velocities_col: {
        direction: down
        label: "velocities: Vec<Velocity>"
        style.fill: "#F3E5F5"
        style.stroke: "#7B1FA2"
        width: 200
        v_header: "row | Velocity {dx, dy}" {
          style.fill: "#E1BEE7"
          style.stroke: "#7B1FA2"
          style.font: mono
          style.bold: true
        }
        v0: "0 | {dx: 1.5, dy: 0.0}" {
          style.fill: "#F3E5F5"
          style.stroke: "#7B1FA2"
          style.font: mono
          tooltip: "8 bytes (2 x f32)"
        }
        v1: "1 | {dx: -2.0, dy: 1.0}" {
          style.fill: "#F3E5F5"
          style.stroke: "#7B1FA2"
          style.font: mono
          tooltip: "8 bytes (2 x f32)"
        }
        v2: "2 | {dx: 0.0, dy: 5.0}" {
          style.fill: "#F3E5F5"
          style.stroke: "#7B1FA2"
          style.font: mono
          tooltip: "8 bytes (2 x f32)"
        }
      }
    }
  }

  memory_view: {
    direction: down
    label: "Memory Layout (Contiguous)"
    style.fill: "#FAFAFA"
    style.stroke: "#424242"
    width: 320
    mem_desc: {
      label: |md
        **Cache Line: 64 bytes**
        Each column stored as contiguous
        `Vec<T>` — sequential memory access
        Row i components at:
        • `positions[i]`
        • `velocities[i]`
        No indirection, no sparse lookup
      |
      shape: rectangle
      style.fill: "#FAFAFA"
      style.stroke: "#424242"
    }
    mem_layout: {
      shape: rectangle
      label: |md
        Memory Address    Content
        ─────────────────────────────
        0x1000..0x100B   Entity[0..3]
        0x100C..0x1017   (padding)
        0x2000..0x2017   Position[0..2]
                         (24 bytes total)
        0x3000..0x3017   Velocity[0..2]
                         (24 bytes total)
      |
      style.fill: "#F5F5F5"
      style.stroke: "#424242"
      style.font: mono
      width: 300
    }
  }
}

iteration_example: {
  direction: down
  label: "Query Iteration: Zero Indirection"
  style.fill: "#FFF8E1"
  style.stroke: "#F57C00"
  width: 600
  iter_code: {
    label: "Movement System (movement.rs)"
    code: |'rust
      // Query: (Position, Velocity)
      for archetype in world.query::<(Position, Velocity)>() {
          let pos = archetype.column::<Position>();
          let vel = archetype.column::<Velocity>();
          for i in 0..archetype.len() {
              // CPU Prefetcher efficiency: 100%
              pos[i].x += vel[i].dx * dt;
              pos[i].y += vel[i].dy * dt;
          }
      }
    '|
    width: 580
    style.fill: "#FFFDE7"
    style.stroke: "#F57C00"
  }
  access_pattern: {
    direction: right
    label: "Memory Access Pattern"
    step1: "1. Load positions[0..N]" {
      style.fill: "#C8E6C9"
    }
    step2: "2. Load velocities[0..N]" {
      style.fill: "#E1BEE7"
    }
    step3: "3. Store positions[0..N]" {
      style.fill: "#FFE0B2"
    }
    step1 -> step2: "sequential"
    step2 -> step3: "sequential"
  }
}

row_correlation: {
  direction: down
  label: "Index Correlation: Same Row = Same Entity"
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  width: 600
  corr_desc: {
    label: |md
      **Key Property:** For any row `i`:
      - `entities[i]` = Entity ID at row i
      - `positions[i]` = Position component
      - `velocities[i]` = Velocity component
      **Iteration:** Just loop `0..len()`, access all arrays at same index.
    |
    shape: rectangle
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
  }
  corr_visual: {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    idx: {
      label: "Index"
      i0: "0"
      i1: "1"
      i2: "2"
      style.fill: "#B2EBF2"
    }
    arr_e: "entities[]" {
      style.fill: "#E3F2FD"
    }
    arr_p: "positions[]" {
      style.fill: "#FFF3E0"
    }
    arr_v: "velocities[]" {
      style.fill: "#F3E5F5"
    }
    idx -> arr_e: "i"
    arr_e -> arr_p: "[i]"
    arr_p -> arr_v: "[i]"
  }
}

performance: {
  direction: down
  label: "Performance Characteristics"
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  width: 600
  perf_table: {
    shape: sql_table
    label: "Operation Complexity (archetype.rs)"
    op_get: "get_comp(ent) | O(1) | offset lookup"
    op_query: "iteration | O(N) | sequential access"
    op_add: "add_comp(ent) | O(M) | migrate entity"
    op_rem: "rem_comp(ent) | O(M) | migrate entity"
    op_spawn: "spawn() | O(1) | array push"
    op_dest: "destroy() | O(1) | swap-remove"
    footer: "N=entities, M=components/entity"
  }
  cache_note: {
    label: |md
      **Cache Efficiency:**
      - 64-byte cache line holds 8 `f32` values
      - `Position` = 8 bytes → 8 entities per cache line
      - **SIMD Potential:** Layout allows easy vectorization
    |
    shape: rectangle
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
  }
}

legend: {
  near: bottom-right
  direction: right
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  ent: "Entity ID" {style.fill: "#E3F2FD"}
  pos: "Position" {style.fill: "#FFF3E0"}
  vel: "Velocity" {style.fill: "#F3E5F5"}
}