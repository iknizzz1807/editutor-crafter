direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "ECS Architecture: High-Performance Blueprint"
  style.font-size: 32
  style.bold: true
}

# ROW 1: CORE ARCHITECTURE COMPONENTS
architecture_row: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  entity_manager: {
    shape: sql_table
    label: "EntityManager (m1.rs)"
    f0: "0x00 | Vec<u16> | generations"
    f1: "0x18 | Vec<usize> | free_list"
    f2: "0x30 | usize     | len"
    sz: "Total: 56 bytes (on stack)"
  }

  component_storage: {
    shape: class
    label: "ComponentRegistry (m2.rs)"
    -storages: "HashMap<TypeId, Box<dyn Storage>>"
    -bitsets: "HashMap<TypeId, BitSet>"
    +get_storage(id): "Option<&Storage>"
    +register_component(T): "void"
  }

  archetype_storage: {
    shape: class
    label: "ArchetypeGraph (m4.rs)"
    -nodes: "HashMap<ArchetypeId, Archetype>"
    -edges: "HashMap<TypeId, ArchetypeEdge>"
    +get_next(current, type): "ArchetypeId"
    +migrate(entity, from, to): "void"
  }
}

# ROW 2: BENCHMARK & IMPLEMENTATION
implementation_row: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  benchmark_comparison: {
    label: "Performance Benchmark: Sparse Set vs Archetype"
    content: |'md
      | Metric | Sparse Set | Archetype |
      | :--- | :--- | :--- |
      | **Memory Layout** | Indirection (Sparse -> Dense) | Sequential (Dense Columns) |
      | **CPU Prefetch** | Moderate (L1/L2 misses possible) | Maximum (Sequential Access) |
      | **Component Add** | O(1) (Direct index) | O(N) (Table migration) |
      | **Iteration** | ~40-60 cycles per entity | ~4-8 cycles per entity |
      | **Fragmentation** | Low | High (Signature explosion) |
    '|
  }

  spawn_process: {
    label: "Entity Spawn Flow (systems.rs)"
    code: |'rust
      fn spawn_bullet(world: &mut World) {
          let mut commands = world.commands();
          commands.spawn()
              .insert(Position { x: 0.0, y: 0.0 })
              .insert(Velocity { dx: 10.0, dy: 0.0 })
              .insert(Bullet);
          world.flush(); // Triggers Archetype Migration
      }
    '|
  }
}

# ROW 3: MEMORY DATA WALK (QUERY OPTIMIZATION)
data_walk_row: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  archetype_table: {
    shape: sql_table
    label: "Archetype Table (Pos + Vel)"
    r0: "Entity ID | [0] | [1] | [2] | [3]"
    r1: "Position  | x0  | x1  | x2  | x3"
    r2: "Velocity  | dx0 | dx1 | dx2 | dx3"
    note: "Perfect Cache Locality: 1 fetch = 4-8 entities"
  }

  sparse_set_layout: {
    shape: sql_table
    label: "Sparse Set Layout"
    s1: "Sparse: [ 0 | - | 1 | - | 2 ]"
    s2: "Dense:  [ E0 | E2 | E4 ]"
    s3: "Data:   [ D0 | D2 | D4 ]"
    note: "Indirection jump: Sparse[ID] -> Dense Index"
  }
}

# SYSTEM CONNECTIONS
architecture_row.entity_manager -> architecture_row.component_storage: "EntityID | Lookup"
architecture_row.component_storage -> architecture_row.archetype_storage: "Signature | Migrate"
implementation_row.spawn_process -> architecture_row.archetype_storage: "World::flush() | Graph Traversal"
data_walk_row.archetype_table -> implementation_row.benchmark_comparison: "400% speedup"

# LEGEND & STYLING
legend: {
  shape: sql_table
  near: bottom-right
  l1: "Blue: Data Flow"
  l2: "Purple: Metadata"
  l3: "Dashed: Transition"
}

architecture_row.entity_manager.style.fill: "#E4DBFE"
architecture_row.archetype_storage.style.fill: "#C7F1FF"
implementation_row.spawn_process.style.stroke: "#B5AFF6"
implementation_row.spawn_process.style.stroke-width: 3
data_walk_row.archetype_table.style.fill: "#D5E8D4"
data_walk_row.sparse_set_layout.style.fill: "#FFF2CC"