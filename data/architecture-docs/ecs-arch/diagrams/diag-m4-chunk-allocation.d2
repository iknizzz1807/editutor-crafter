        v0: "(3,4)" {
          style.fill: ${colors.vel-data}
          width: 90
        }
        h0: "100" {
          style.fill: ${colors.hlth-data}
          width: 70
        }
      }
      row_1: {
        direction: right
        style.stroke: transparent
        e1: "e1" {
          style.fill: ${colors.entity-data}
          width: 70
        }
        p1: "(5,6)" {
          style.fill: ${colors.pos-data}
          width: 90
        }
        v1: "(7,8)" {
          style.fill: ${colors.vel-data}
          width: 90
        }
        h1: "50" {
          style.fill: ${colors.hlth-data}
          width: 70
        }
      }
      ellipsis_row: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        dots: "..." {
          style.fill: transparent
          width: 320
        }
      }
      row_n: {
        direction: right
        style.stroke: transparent
        en: "eN" {
          style.fill: ${colors.entity-data}
          width: 70
        }
        pn: "(x,y)" {
          style.fill: ${colors.pos-data}
          width: 90
        }
        vn: "(dx,dy)" {
          style.fill: ${colors.vel-data}
          width: 90
        }
        hn: "HP" {
          style.fill: ${colors.hlth-data}
          width: 70
        }
      }
    }
    problem: {
      label: |md
        **Problems:**
        - Reallocation on growth copies ALL data
        - Single large block = cache misses
        - Memory fragmentation
      |
      style.fill: ${colors.benefit-bg}
      style.stroke: ${colors.pointer}
      style.stroke-dash: 4
    }
  }
  chunk_view: {
    direction: down
    label: "Chunk-Based Allocation"
    chunk_0: {
      label: "Chunk 0 (16KB)"
      style: {
        fill: ${colors.chunk-fill}
        stroke: ${colors.chunk-border}
        stroke-width: 2
      }
      c0_header: {
        direction: right
        style.stroke: transparent
        style.fill: ${colors.chunk-meta}
        c0_meta: "next → Chunk 1 | len: 3 | cap: 3" {
          style.fill: ${colors.chunk-meta}
          style.font-color: white
        }
      }
      c0_row0: {
        direction: right
        style.stroke: transparent
        c0_e0: "e0" {
          style.fill: ${colors.entity-data}
          width: 60
        }
        c0_p0: "(1,2)" {
          style.fill: ${colors.pos-data}
          width: 80
        }
        c0_v0: "(3,4)" {
          style.fill: ${colors.vel-data}
          width: 80
        }
        c0_h0: "100" {
          style.fill: ${colors.hlth-data}
          width: 50
        }
      }
      c0_row1: {
        direction: right
        style.stroke: transparent
        c0_e1: "e1" {
          style.fill: ${colors.entity-data}
          width: 60
        }
        c0_p1: "(5,6)" {
          style.fill: ${colors.pos-data}
          width: 80
        }
        c0_v1: "(7,8)" {
          style.fill: ${colors.vel-data}
          width: 80
        }
        c0_h1: "50" {
          style.fill: ${colors.hlth-data}
          width: 50
        }
      }
      c0_row2: {
        direction: right
        style.stroke: transparent
        c0_e2: "e2" {
          style.fill: ${colors.entity-data}
          width: 60
        }
        c0_p2: "(9,10)" {
          style.fill: ${colors.pos-data}
          width: 80
        }
        c0_v2: "(11,12)" {
          style.fill: ${colors.vel-data}
          width: 80
        }
        c0_h2: "75" {
          style.fill: ${colors.hlth-data}
          width: 50
        }
      }
    }
    chunk_1: {
      label: "Chunk 1 (16KB)"
      style: {
        fill: ${colors.chunk-fill}
        stroke: ${colors.chunk-border}
