direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#2D3748"
    chunk-border: "#4A5568"
    chunk-fill: "#EDF2F7"
    entity-data: "#48BB78"
    pos-data: "#4299E1"
    vel-data: "#ED8936"
    hlth-data: "#9F7AEA"
    chunk-meta: "#718096"
    free-slot: "#CBD5E0"
    pointer: "#E53E3E"
    benefit-bg: "#F7FAFC"
  }
}
title: |md
  # Chunk-Based Allocation Within Archetypes
  ## Archetype: (Position, Velocity, Health)
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arch_view: {
    direction: down
    label: "Traditional View (Conceptual)"
    concept_table: {
      label: "Single Allocation"
