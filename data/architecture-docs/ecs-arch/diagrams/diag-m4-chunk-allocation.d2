}
chunk_0 -> chunk_1: "next" {
  style.stroke: ${colors.pointer}
  style.stroke-width: 2
}
chunk_1 -> chunk_2: "next" {
  style.stroke: ${colors.pointer}
  style.stroke-width: 2
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  benefits: {
    label: "Benefits of Chunk-Based Allocation"
    style: {
      fill: ${colors.benefit-bg}
      stroke: ${colors.chunk-border}
      border-radius: 8
    }
    b1: {
      label: |md
        ### No Reallocation on Growth
        - Adding entities: just allocate new chunk
        - Existing data never moves
        - No expensive memcpy of thousands of entities
      |
    }
    b2: {
      label: |md
        ### Cache-Optimized Size
        - 16KB chunk fits in L1 cache (32KB typical)
        - Sequential iteration = predictable prefetch
        - Compaction happens naturally per chunk
      |
    }
    b3: {
      label: |md
        ### Memory Pool Integration
        - Chunks allocated from fixed-size pool
        - No heap fragmentation
        - Easy memory budgeting (N chunks max)
      |
    }
    b4: {
      label: |md
        ### Parallel Processing Unit
        - Thread N processes Chunk M
        - Natural work-stealing granularity
        - SIMD operates on chunk-sized blocks
      |
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  struct_layout: {
    label: "ArchetypeChunk Structure (chunk.h)"
    style: {
      fill: ${colors.chunk-fill}
      stroke: ${colors.chunk-border}
    }
    struct_def: {
      shape: class
      label: "struct ArchetypeChunk"
      +entities: "Entity[MAX_PER_CHUNK]"
      +component_data: "u8[CHUNK_SIZE]"
      +len: "u16"
      +capacity: "u16"
      +next: "ArchetypeChunk*"
      +archetype_id: "ArchetypeId"
    }
  }
  constants: {
    label: "Chunk Constants"
    style: {
      fill: ${colors.benefit-bg}
      stroke: ${colors.chunk-border}
    }
    const_block: {
      label: |'c
        // Cache-line aware sizing
        #define CHUNK_SIZE      (16 * 1024)  // 16KB
        #define CACHE_LINE_SIZE 64
        // Calculate capacity per chunk
        // Example: (Position + Velocity + Health) = 28 bytes/entity
        // MAX_PER_CHUNK = 16384 / 28 = 585 entities per chunk
        static inline size_t chunk_capacity(size_t entity_size) {
            return CHUNK_SIZE / entity_size;
        }
      '|
      width: 380
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  iteration_flow: {
    label: "Iteration Flow: Chunk-by-Chunk"
    style: {
      fill: ${colors.benefit-bg}
      stroke: ${colors.chunk-border}
    }
    iter_code: {
      label: |'c
        // Movement system iterating archetype chunks
        void movement_system(Archetype* arch, float dt) {
            for (Chunk* chunk = arch->first; chunk; chunk = chunk->next) {
                Position* pos = column_ptr(chunk, 0);
                Velocity* vel = column_ptr(chunk, 1);
                // SIMD-friendly inner loop over chunk
                for (u16 i = 0; i < chunk->len; i++) {
                    pos[i].x += vel[i].dx * dt;
                    pos[i].y += vel[i].dy * dt;
                }
                // Next chunk loads fresh into L1 cache
            }
        }
      '|
      width: 380
    }
  }
  memory_layout: {
    label: "Memory Layout Within Chunk"
    style: {
      fill: ${colors.chunk-fill}
      stroke: ${colors.chunk-border}
    }
    layout_visual: {
      direction: right
      style.stroke: transparent
      entities_block: {
        label: "Entity[]\n585 × 4B\n= 2.3KB"
        style.fill: ${colors.entity-data}
        width: 80
        height: 200
      }
      pos_block: {
        label: "Position[]\n585 × 8B\n= 4.7KB"
        style.fill: ${colors.pos-data}
        width: 80
        height: 200
      }
      vel_block: {
        label: "Velocity[]\n585 × 8B\n= 4.7KB"
        style.fill: ${colors.vel-data}
        width: 80
        height: 200
      }
      hlth_block: {
        label: "Health[]\n585 × 4B\n= 2.3KB"
        style.fill: ${colors.hlth-data}
        width: 80
        height: 200
      }
      meta_block: {
        label: "Chunk\nMeta\n8B"
        style.fill: ${colors.chunk-meta}
        width: 60
        height: 200
      }
    }
    total_note: {
      label: "Total: ~14KB per chunk (fits L1 with room for code)"
      style.fill: transparent
      style.italic: true
    }
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: white
  style.stroke: ${colors.chunk-border}
  leg_entity: "Entity IDs" {
    style.fill: ${colors.entity-data}
  }
  leg_pos: "Position (x,y)" {
    style.fill: ${colors.pos-data}
  }
  leg_vel: "Velocity (dx,dy)" {
    style.fill: ${colors.vel-data}
  }
  leg_hlth: "Health (HP)" {
    style.fill: ${colors.hlth-data}
  }
  leg_free: "Free slot" {
    style.fill: ${colors.free-slot}
  }
  leg_ptr: "Chunk pointer" {
    style.stroke: ${colors.pointer}
  }
}