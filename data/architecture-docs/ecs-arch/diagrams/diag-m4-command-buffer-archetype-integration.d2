direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Command Buffer: Archetype-Aware Structural Changes
    Deferred operations that trigger entity migration between archetype tables
  |
  near: top-center
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
  style.font-size: 20
}
row_systems: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  system_a: {
    label: "MovementSystem"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    width: 140
  }
  system_b: {
    label: "CombatSystem"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    width: 140
  }
  system_c: {
    label: "AISystem"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 140
  }
}
row_commands: {
  direction: down
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 4
  label: "Command Buffer (Deferred Queue)"
  cmd_spawn: {
    shape: rectangle
    label: |md
      **SpawnEntity**
      `entity: Entity`
    |
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    width: 200
  }
  cmd_add: {
    shape: rectangle
    label: |md
      **AddComponent**
      `entity: Entity`
      `type_id: TypeId`
      `component: Box<dyn Any>`
    |
    style.fill: "#BBDEFB"
    style.stroke: "#2196F3"
    width: 200
  }
  cmd_remove: {
    shape: rectangle
    label: |md
      **RemoveComponent**
      `entity: Entity`
      `type_id: TypeId`
    |
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
    width: 200
  }
  cmd_destroy: {
    shape: rectangle
    label: |md
      **DestroyEntity**
      `entity: Entity`
    |
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    width: 200
  }
}
row_archetypes: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arch_source: {
    direction: down
    label: "Archetype (Position, Velocity)"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    src_header: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      src_e: {
        label: "Entity"
        shape: rectangle
        style.fill: "#A5D6A7"
        width: 60
      }
      src_pos: {
        label: "Position"
        shape: rectangle
        style.fill: "#A5D6A7"
        width: 80
      }
      src_vel: {
        label: "Velocity"
        shape: rectangle
        style.fill: "#A5D6A7"
        width: 80
      }
    }
    src_row0: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      src_e0: { label: "e5"; shape: rectangle; style.fill: "#C8E6C9"; width: 60 }
      src_p0: { label: "(10,20)"; shape: rectangle; style.fill: "#C8E6C9"; width: 80 }
      src_v0: { label: "(1,0)"; shape: rectangle; style.fill: "#C8E6C9"; width: 80 }
    }
    src_row1: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      src_e1: { label: "e12"; shape: rectangle; style.fill: "#FFECB3"; width: 60; style.stroke: "#FF9800"; style.stroke-width: 3 }
      src_p1: { label: "(50,30)"; shape: rectangle; style.fill: "#FFECB3"; width: 80; style.stroke: "#FF9800"; style.stroke-width: 3 }
      src_v1: { label: "(0,2)"; shape: rectangle; style.fill: "#FFECB3"; width: 80; style.stroke: "#FF9800"; style.stroke-width: 3 }
    }
    src_row2: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      src_e2: { label: "e27"; shape: rectangle; style.fill: "#C8E6C9"; width: 60 }
      src_p2: { label: "(5,15)"; shape: rectangle; style.fill: "#C8E6C9"; width: 80 }
      src_v2: { label: "(3,1)"; shape: rectangle; style.fill: "#C8E6C9"; width: 80 }
    }
  }
  migration_zone: {
    direction: down
    label: "Migration"
    style.fill: "#FFF8E1"
    style.stroke: "#FFA000"
    style.stroke-dash: 4
    width: 180
    mig_step1: {
      label: "1. Lookup EntityLocation"
      shape: rectangle
      style.fill: "#FFE082"
      width: 150
    }
    mig_step2: {
      label: "2. Find target archetype"
      shape: rectangle
      style.fill: "#FFE082"
      width: 150
    }
    mig_step3: {
      label: "3. Copy components"
      shape: rectangle
      style.fill: "#FFE082"
      width: 150
    }
    mig_step4: {
      label: "4. Swap-remove source"
      shape: rectangle
      style.fill: "#FFE082"
      width: 150
    }
    mig_step5: {
      label: "5. Update location"
      shape: rectangle
      style.fill: "#FFE082"
      width: 150
    }
  }
  arch_target: {
    direction: down
    label: "Archetype (Position, Velocity, Health)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    tgt_header: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      tgt_e: { label: "Entity"; shape: rectangle; style.fill: "#90CAF9"; width: 50 }
      tgt_pos: { label: "Position"; shape: rectangle; style.fill: "#90CAF9"; width: 70 }
      tgt_vel: { label: "Velocity"; shape: rectangle; style.fill: "#90CAF9"; width: 60 }
      tgt_hp: { label: "Health"; shape: rectangle; style.fill: "#90CAF9"; width: 50 }
    }
    tgt_row0: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      tgt_e0: { label: "e3"; shape: rectangle; style.fill: "#BBDEFB"; width: 50 }
      tgt_p0: { label: "(0,0)"; shape: rectangle; style.fill: "#BBDEFB"; width: 70 }
      tgt_v0: { label: "(2,0)"; shape: rectangle; style.fill: "#BBDEFB"; width: 60 }
      tgt_h0: { label: "100"; shape: rectangle; style.fill: "#BBDEFB"; width: 50 }
    }
    tgt_row1: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      tgt_e1: { label: "e8"; shape: rectangle; style.fill: "#BBDEFB"; width: 50 }
      tgt_p1: { label: "(20,5)"; shape: rectangle; style.fill: "#BBDEFB"; width: 70 }
      tgt_v1: { label: "(1,1)"; shape: rectangle; style.fill: "#BBDEFB"; width: 60 }
      tgt_h1: { label: "50"; shape: rectangle; style.fill: "#BBDEFB"; width: 50 }
    }
    tgt_row_new: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      tgt_e_new: { label: "e12"; shape: rectangle; style.fill: "#FFECB3"; width: 50; style.stroke: "#FF9800"; style.stroke-width: 3 }
      tgt_p_new: { label: "(50,30)"; shape: rectangle; style.fill: "#FFECB3"; width: 70; style.stroke: "#FF9800"; style.stroke-width: 3 }
      tgt_v_new: { label: "(0,2)"; shape: rectangle; style.fill: "#FFECB3"; width: 60; style.stroke: "#FF9800"; style.stroke-width: 3 }
      tgt_h_new: { label: "75"; shape: rectangle; style.fill: "#FFECB3"; width: 50; style.stroke: "#FF9800"; style.stroke-width: 3 }
    }
  }
}
row_registry: {
  direction: right
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  label: "Archetype Registry & Graph"
  graph: {
    direction: right
    label: "Transition Cache"
    edge1: {
      label: "(A1, Health) → A2"
      shape: rectangle
      style.fill: "#E1BEE7"
      width: 140
    }
    edge2: {
      label: "(A2, Health) → A1"
      shape: rectangle
      style.fill: "#E1BEE7"
      width: 140
    }
  }
  locations: {
    label: "EntityLocations"
    shape: class
    -locations: "Vec<Option<EntityLocation>>"
    +get(entity): "Option<EntityLocation>"
    +set(entity, loc): "void"
    +clear(entity): "void"
  }
}
row_timeline: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase1: {
    label: "Phase 1: System Execution"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    width: 180
    note1: {
      label: |md
        • World is **structurally immutable**
        • Systems read/write component data
        • Commands queue to buffer
        • No archetype mutations
      |
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#A5D6A7"
      width: 160
    }
  }
  arrow1: {
    shape: rectangle
    label: "→"
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 24
    width: 40
  }
  phase2: {
    label: "Phase 2: Command Flush"
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#2196F3"
    width: 180
    note2: {
      label: |md
        • Drain command buffer
        • Execute each command
        • Trigger migrations
        • Update entity locations
      |
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#90CAF9"
      width: 160
    }
  }
  arrow2: {
    shape: rectangle
    label: "→"
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 24
    width: 40
  }
  phase3: {
    label: "Phase 3: Next Frame"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
    width: 180
    note3: {
      label: |md
        • World is stable again
        • New archetypes ready
        • Queries see updated state
        • Repeat
      |
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FFCC80"
      width: 160
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  leg1: { label: "Entity migrating"; shape: rectangle; style.fill: "#FFECB3"; style.stroke: "#FF9800"; style.stroke-width: 3; width: 100 }
  leg2: { label: "Normal data"; shape: rectangle; style.fill: "#C8E6C9"; style.stroke: "#4CAF50"; width: 80 }
  leg3: { label: "New row"; shape: rectangle; style.fill: "#BBDEFB"; style.stroke: "#2196F3"; width: 70 }
}
row_systems -> row_commands: "commands.spawn()\ncommands.insert()\ncommands.destroy()" {
  style.stroke: "#616161"
  style.stroke-dash: 3
}
row_commands -> row_archetypes.migration_zone: "flush_commands()" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.animated: true
}
arch_source.src_row1 -> migration_zone: "e12 migration" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
migration_zone -> arch_target.tgt_row_new: "insert row" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.animated: true
}
row_archetypes -> row_registry: "lookup transitions\nupdate locations" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}