direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    sparse_bg: "#FFF3E0"
    archetype_bg: "#E8F5E9"
    cache_miss: "#EF5350"
    cache_hit: "#4CAF50"
    entity_color: "#42A5F5"
    sparse_color: "#FFA726"
    dense_color: "#7E57C2"
    arrow_data: "#1565C0"
  }
}

# -----------------------------------------------------------------------------------------
# ROOT LEVEL ELEMENTS
# -----------------------------------------------------------------------------------------

title: {
  label: |'md
    # Iteration: Sparse Set vs Archetype Memory Access
    ## Why Archetypes Are 2x+ Faster for Queries
  '|
}
title.near: top-center

row_comparison: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  # 1. SPARSE SET SECTION
  sparse_set: {
    label: "STORAGE TYPE: SPARSE SETS (e.g., EnTT)"
    style.fill: ${colors.sparse_bg}
    style.stroke: ${colors.sparse_color}
    style.stroke-width: 2

    sparse_desc: {
      label: "Mechanism: Double-Indirection"
      width: 380
      code: |'cpp
        // Query: entities with (Position, Velocity)
        for (auto entity : position_view) {
          size_t p_idx = sparse_pos[entity]; // 1. Random
          auto& pos = dense_pos[p_idx];      // 2. Sequential
          
          if (sparse_vel.contains(entity)) { // 3. Random
            size_t v_idx = sparse_vel[entity]; // 4. Random
            auto& vel = dense_vel[v_idx];      // 5. Random
          }
        }
      '|
    }

    sparse_visual: {
      label: "Memory Access Trace"
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      entities_col: {
        label: "Entity ID"
        e0: "0x00" { style.fill: ${colors.entity_color} }
        e1: "0x01" { style.fill: ${colors.entity_color} }
        e2: "0x02" { style.fill: ${colors.entity_color} }
      }

      sparse_col: {
        label: "Sparse (Map)"
        s0: "ptr: 2" { style.fill: ${colors.sparse_color} }
        s1: "ptr: 0" { style.fill: ${colors.sparse_color} }
        s2: "ptr: 1" { style.fill: ${colors.sparse_color} }
      }

      dense_col: {
        label: "Dense (Data)"
        d0: "Pos[1]" { style.fill: ${colors.dense_color} }
        d1: "Pos[2]" { style.fill: ${colors.dense_color} }
        d2: "Pos[0]" { style.fill: ${colors.dense_color} }
      }

      entities_col.e0 -> sparse_col.s0: "Lookup"
      sparse_col.s0 -> dense_col.d2: "Indirection"
    }

    sparse_cost: {
      label: "Cost: ~800μs per 100K entities"
      width: 380
      style.fill: "#FFEBEE"
      content: |'md
        - **Random Access**: High cache miss rate on sparse lookups.
        - **Indirection**: Pointer chasing prevents CPU prefetching.
        - **L3 Pressure**: Sparse arrays often exceed L1/L2 cache size.
      '|
    }
  }

  # 2. ARCHETYPE SECTION
  archetype: {
    label: "STORAGE TYPE: ARCHETYPES (e.g., Flecs, Bevy)"
    style.fill: ${colors.archetype_bg}
    style.stroke: ${colors.cache_hit}
    style.stroke-width: 2

    arch_desc: {
      label: "Mechanism: Linear Memory Scan"
      width: 380
      code: |'cpp
        // Query: entities with (Position, Velocity)
        auto table = find_archetype(Position | Velocity);
        
        // Linear data arrays in the same table
        Position* pos_arr = table.columns[0];
        Velocity* vel_arr = table.columns[1];
        
        for (int i = 0; i < table.count; i++) {
          process(pos_arr[i], vel_arr[i]); // 1 & 2: Sequential
        }
      '|
    }

    arch_visual: {
      shape: sql_table
      label: "Archetype Table: [Entity|Pos|Vel]"
      r0: "Ent 0 | {1,2} | {10,5}"
      r1: "Ent 1 | {5,6} | {3,1}"
      r2: "Ent 2 | {3,4} | {7,2}"
      r3: "Ent 4 | {9,1} | {2,8}"
      note: "All data is contiguous in memory"
    }

    arch_cost: {
      label: "Cost: ~150μs per 100K entities"
      width: 380
      style.fill: "#E8F5E9"
      content: |'md
        - **Sequential Access**: 100% Cache Friendly.
        - **Hardware Prefetch**: CPU loads next cache line automatically.
        - **SIMD**: Memory is perfectly aligned for vectorization.
      '|
    }
  }
}

# -----------------------------------------------------------------------------------------
# COMPARISON SUMMARY
# -----------------------------------------------------------------------------------------

comparison_bar: {
  direction: down
  style.fill: "#F5F5F5"
  
  metrics: {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    sparse_m: {
      label: "Sparse Set\nIndirection Heavy"
      style.fill: ${colors.sparse_bg}
      width: 200
    }
    vs: "VS" {
      style.stroke: transparent
      style.fill: transparent
      style.bold: true
      style.font-size: 24
    }
    arch_m: {
      label: "Archetype\nLinear Scan"
      style.fill: ${colors.archetype_bg}
      width: 200
    }
  }

  result: "Archetypes are ~5.3x faster for heavy iteration" {
    style.fill: ${colors.cache_hit}
    style.font-color: white
    style.bold: true
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND & INSIGHTS
# -----------------------------------------------------------------------------------------

key_insight: {
  label: "Key Insight for Implementation"
  width: 800
  content: |'md
    ### Strategy: Optimize for the Hot Path
    - **Sparse Sets**: Best for high-frequency structural changes (adding/removing components) as it avoids data migration. Performance degrades during iteration due to random access.
    - **Archetypes**: Best for high-frequency iteration (Systems/Physics). Structural changes are expensive (requires `memcpy` to new table), but query execution reaches hardware limits.
  '|
}
key_insight.near: bottom-center

legend: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  l1: "Random / Cache Miss" {
    style.fill: ${colors.cache_miss}
    style.font-color: white
  }
  l2: "Sequential / Cache Hit" {
    style.fill: ${colors.cache_hit}
    style.font-color: white
  }
  l3: "SIMD Vectorizable" {
    style.fill: "#7B1FA2"
    style.font-color: white
  }
}
legend.near: bottom-right