direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Query Matching Against Archetypes
  `Query<Position, Velocity>` finds all archetypes containing both components
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  query: {
    label: "Query Spec"
    width: 200
    mask: {
      shape: sql_table
      label: "Component Mask"
      c1: "Position | ✓ required"
      c2: "Velocity  | ✓ required"
      c3: "Health    | ✗ not required"
    }
    note: "Query requires:\nALL of: {Position, Velocity}"
  }
  logic: {
    label: "Matching Logic"
    width: 280
    code: |'rust
      // For each archetype in registry:
      for archetype in archetypes.iter() {
        if archetype.signature()
            .contains_all(&query.required) 
        {
          // ✓ MATCH: archetype has all
          //    required components
          yield archetype;
        }
      }
    '|
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arch_pos_vel: {
    label: "Archetype A"
    style.fill: "#ACE1AF"
    sig: {
      shape: sql_table
      label: "Signature: {Position, Velocity}"
      s1: "Position"
      s2: "Velocity"
    }
    table: {
      shape: sql_table
      label: "Entity Table"
      h1: "row | Entity   | Position | Velocity"
      r0: "0   | e1       | (1, 2)   | (3, 4)"
      r1: "1   | e2       | (5, 6)   | (7, 8)"
      r2: "2   | e3       | (9, 10)  | (11, 12)"
    }
    match_status: {
      label: "✓ MATCHES"
      shape: oval
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
  }
  arch_pos_vel_hp: {
    label: "Archetype B"
    style.fill: "#ACE1AF"
    sig2: {
      shape: sql_table
      label: "Signature: {Position, Velocity, Health}"
      s1: "Position"
      s2: "Velocity"
      s3: "Health"
    }
    table2: {
      shape: sql_table
      label: "Entity Table"
      h1: "row | Entity | Position | Velocity | Health"
      r0: "0   | e4     | (2, 3)   | (1, 0)   | 100"
      r1: "1   | e5     | (8, 9)   | (2, 1)   | 75"
    }
    match_status2: {
      label: "✓ MATCHES"
      shape: oval
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    note2: "Superset OK!\nHas Position + Velocity\n(plus extra Health)"
  }
  arch_pos_only: {
    label: "Archetype C"
    style.fill: "#FFCDD2"
    sig3: {
      shape: sql_table
      label: "Signature: {Position}"
      s1: "Position"
      s2: "(no Velocity)"
    }
    table3: {
      shape: sql_table
      label: "Entity Table"
      h1: "row | Entity | Position"
      r0: "0   | e6     | (0, 0)"
      r1: "1   | e7     | (4, 4)"
    }
    match_status3: {
      label: "✗ NO MATCH"
      shape: oval
      style.fill: "#F44336"
      style.font-color: white
      style.bold: true
    }
    note3: "Missing Velocity!\nCannot satisfy query"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  iterator: {
    label: "Query Iterator: Yields from ALL matching archetypes"
    width: 900
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    flow: {
      direction: right
      step1: {
        label: "Archetype A"
        rows: "rows 0, 1, 2"
        style.fill: "#C8E6C9"
      }
      arrow1: "->" {
        label: "yield"
        style.stroke: "#4CAF50"
        style.bold: true
      }
      step2: {
        label: "Archetype B"
        rows: "rows 0, 1"
        style.fill: "#C8E6C9"
      }
      arrow2: "->" {
        label: "yield"
        style.stroke: "#4CAF50"
        style.bold: true
      }
      step3: {
        label: "Archetype C"
        rows: "SKIPPED"
        style.fill: "#FFCDD2"
        style.stroke-dash: 3
      }
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  result: {
    label: "Iteration Result: Sequential Memory Access"
    width: 900
    style.fill: "#FFF9C4"
    columns: {
      direction: right
      col_a: {
        label: "From Archetype A"
        shape: cylinder
        style.fill: "#C8E6C9"
        data_a: {
          shape: sql_table
          label: "Column Access"
          h1: "Entity | &Position | &Velocity"
          r1: "e1     | &(1, 2)   | &(3, 4)"
          r2: "e2     | &(5, 6)   | &(7, 8)"
          r3: "e3     | &(9, 10)  | &(11, 12)"
        }
      }
      arrow: "->" {
        label: "then"
      }
      col_b: {
        label: "From Archetype B"
        shape: cylinder
        style.fill: "#C8E6C9"
        data_b: {
          shape: sql_table
          label: "Column Access"
          h1: "Entity | &Position | &Velocity"
          r1: "e4     | &(2, 3)   | &(1, 0)"
          r2: "e5     | &(8, 9)   | &(2, 1)"
        }
      }
    }
    perf_note: |md
      **Performance Note:**
      - Each archetype: pure sequential array access
      - No sparse array indirection
      - CPU prefetcher fully utilized
      - SIMD auto-vectorization possible
    |
  }
}
query.logic -> arch_pos_vel: "check signature" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
query.logic -> arch_pos_vel_hp: "check signature" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
query.logic -> arch_pos_only: "check signature" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
arch_pos_vel -> iterator.flow.step1: "include" {
  style.stroke: "#4CAF50"
  style.animated: true
}
arch_pos_vel_hp -> iterator.flow.step2: "include" {
  style.stroke: "#4CAF50"
  style.animated: true
}
arch_pos_only -> iterator.flow.step3: "skip" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
iterator -> result: "yield (Entity, &Position, &Velocity)" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  key: {
    label: "Legend"
    green: {
      label: "Green fill/border"
      desc: "Matches query"
    }
    red: {
      label: "Red fill/border"
      desc: "Does not match"
    }
  }
}