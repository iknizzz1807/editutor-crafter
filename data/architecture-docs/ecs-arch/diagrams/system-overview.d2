direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
title: |md
  # ECS Architecture: Complete System Blueprint
  **Entity-Component-System Framework in Rust**
| {
  near: top-center
  shape: text
}
# ============================================================================
# ROW 1: FOUNDATION LAYER - Entity & Identity
# ============================================================================
row_foundation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_entity: {
    direction: down
    label: "MILESTONE 1: ENTITY MANAGER & WORLD"
    entity_struct: {
      shape: sql_table
      label: "struct Entity (entity.rs)  [M1]"
      id: "u32 | packed ID"
      index_bits: "20 bits | 0..1,048,575"
      gen_bits: "12 bits | 0..4095 recycles"
      null: "u32::MAX | sentinel"
      sz: "Total: 4 bytes"
    }
    entity_impl: {
      shape: class
      label: "impl Entity"
      +new(index: u32, gen: u32): "Self"
      +index(self): "usize"
      +generation(self): "u32"
      +is_null(self): "bool"
    }
    entity_manager: {
      shape: sql_table
      label: "struct EntityManager (entity_manager.rs)  [M1]"
      generations: "Vec<u16> | 2 bytes/slot"
      free_list: "Vec<usize> | stack LIFO"
      len: "usize | alive count"
      capacity: "usize | high-water mark"
      sz: "Total: ~48 bytes + heap"
    }
    em_impl: {
      shape: class
      label: "impl EntityManager"
      +new(): "Self"
      "+create(&mut self)": "Entity"
      "+destroy(&mut self, e: Entity)": "bool"
      "+is_alive(&self, e: Entity)": "bool"
      "+len(&self)": "usize"
      "+reserve(&mut self, n: usize)": "()"
    }
  }
  layer_world_core: {
    direction: down
    label: "WORLD CONTAINER"
    world_struct: {
      shape: sql_table
      label: "struct World (world.rs)"
      entities: "EntityManager"
      archetypes: "ArchetypeRegistry"
      archetype_graph: "ArchetypeGraph"
      entity_locations: "EntityLocations"
      component_types: "HashMap<TypeId, TypeInfo>"
      command_buffer: "CommandBuffer"
      scheduler: "SystemScheduler"
      in_system_exec: "bool | safety guard"
      sz: "Runtime: varies by entity count"
    }
    world_impl: {
      shape: class
      label: "impl World"
      +new(): "Self"
      "+create_entity(&mut self)": "Entity"
      "+destroy_entity(&mut self, e: Entity)": "bool"
      "+is_alive(&self, e: Entity)": "bool"
      "+entity_count(&self)": "usize"
      "+tick(&mut self, dt: f32)": "()"
      "+flush_commands(&mut self)": "()"
    }
  }
}
# ============================================================================
# ROW 2: COMPONENT STORAGE - Sparse Sets
# ============================================================================
row_sparse: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_sparse: {
    direction: down
    label: "MILESTONE 2: SPARSE-SET STORAGE"
    sparse_set: {
      shape: sql_table
      label: "struct SparseSet<T> (sparse_set.rs)  [M2]"
      sparse: "Vec<usize> | entity_idx -> dense_idx"
      dense: "Vec<T> | packed components"
      entities: "Vec<Entity> | dense_idx -> entity"
      empty: "usize::MAX | sentinel"
      sz: "Varies: sparse O(max_id), dense O(count)"
    }
    sparse_impl: {
      shape: class
      label: "impl SparseSet<T>"
      +new(): "Self"
      "+insert(&mut self, e: Entity, c: T)": "()"
      "+get(&self, e: Entity)": "Option<&T>"
      "+get_mut(&mut self, e: Entity)": "Option<&mut T>"
      "+contains(&self, e: Entity)": "bool"
      "+remove(&mut self, e: Entity)": "Option<T>"
      "+iter(&self)": "impl Iterator<Item=&T>"
      "+iter_mut(&mut self)": "impl Iterator<Item=&mut T>"
      "+iter_with_entity(&self)": "impl Iterator<Item=(Entity, &T)>"
    }
    column_ops: {
      shape: class
      label: "trait ColumnOps"
      "+as_any(&self)": "&dyn Any"
      "+as_any_mut(&mut self)": "&mut dyn Any"
      "+len(&self)": "usize"
      "+swap_remove(&mut self, idx: usize)": "Option<usize>"
      "+push_raw(&mut self, c: Box<dyn Any>)": "()"
    }
  }
  layer_registry: {
    direction: down
    label: "TYPE-ERASED REGISTRY"
    comp_storage: {
      shape: class
      label: "trait ComponentStorage"
      "+as_any(&self)": "&dyn Any"
      "+as_any_mut(&mut self)": "&mut dyn Any"
      "+remove_entity(&mut self, e: Entity)": "()"
      "+len(&self)": "usize"
      "+clear(&mut self)": "()"
    }
    comp_registry: {
      shape: sql_table
      label: "struct ComponentRegistry (component_registry.rs)"
      storages: "HashMap<TypeId, Box<dyn Storage>>"
      sz: "Varies by registered types"
    }
    registry_impl: {
      shape: class
      label: "impl ComponentRegistry"
      +new(): "Self"
      "+get_or_create<T: 'static>(&mut self)": "&mut SparseSet<T>"
      "+get<T: 'static>(&self)": "Option<&SparseSet<T>>"
      "+get_mut<T: 'static>(&mut self)": "Option<&mut SparseSet<T>>"
      "+remove_entity(&mut self, e: Entity)": "()"
    }
  }
}
# ============================================================================
# ROW 3: SYSTEMS & COMMANDS
# ============================================================================
row_systems: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_commands: {
    direction: down
    label: "MILESTONE 3: COMMAND BUFFERS"
    command_enum: {
      shape: sql_table
      label: "enum Command (command.rs)  [M3]"
      spawned: "{entity: Entity}"
      destroy: "{entity: Entity}"
      insert: "{entity, component: Box<dyn Any>, type_id}"
      remove: "{entity, type_id: TypeId}"
      sz: "~24-32 bytes per variant"
    }
    command_buffer: {
      shape: sql_table
      label: "struct CommandBuffer"
      commands: "Vec<Command>"
      sz: "24 bytes + heap"
    }
    commands_wrapper: {
      shape: class
      label: "struct Commands<'a> (commands.rs)"
      -buffer: "&'a mut CommandBuffer"
      -entity_manager: "&'a mut EntityManager"
      "+spawn(&mut self)": "Entity"
      "+destroy(&mut self, e: Entity)": "()"
      "+insert<T: 'static>(&mut self, e: Entity, c: T)": "()"
      "+remove<T: 'static>(&mut self, e: Entity)": "()"
    }
  }
  layer_scheduler: {
    direction: down
    label: "SYSTEM SCHEDULER"
    system_trait: {
      shape: class
      label: "trait System (system.rs)"
      "+name(&self)": "&str"
      "+run(&mut self, world: &mut World, dt: f32)": "()"
    }
    system_desc: {
      shape: sql_table
      label: "struct SystemDescriptor"
      name: "String"
      system: "Box<dyn System>"
    }
    scheduler: {
      shape: class
      label: "struct SystemScheduler (scheduler.rs)"
      -systems: "Vec<SystemDescriptor>"
      +new(): "Self"
      +add_system<S: System>(&mut self, s: S): "&mut Self"
      "+add_function<F>(&mut self, name: &'static str, f: F)": "&mut Self"
      "+run(&mut self, world: &mut World, dt: f32)": "()"
      "+len(&self)": "usize"
    }
  }
  layer_query: {
    direction: down
    label: "QUERY FILTERING"
    query_spec: {
      shape: sql_table
      label: "struct QuerySpec (query.rs)"
      included: "Vec<TypeId> | must have"
      excluded: "Vec<TypeId> | must not have"
    }
    query_impl: {
      shape: class
      label: "impl QuerySpec"
      +new(): "Self"
      "+with<T: 'static>(self)": "Self"
      "+without<T: 'static>(self)": "Self"
      "+matches(&self, arch: &Archetype)": "bool"
    }
    query_iter: {
      shape: class
      label: "struct Query<'a, Components>"
      -world: "&'a World"
      "+iter(&self)": "impl Iterator<Item=(Entity, &A, &B)>"
    }
  }
}
# ============================================================================
# ROW 4: ARCHETYPE STORAGE
# ============================================================================
row_archetype: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_sig: {
    direction: down
    label: "MILESTONE 4: ARCHETYPE SIGNATURES"
    archetype_sig: {
      shape: sql_table
      label: "struct ArchetypeSignature (archetype_signature.rs)  [M4]"
      type_ids: "Vec<TypeId> | sorted, deduped"
      sz: "24 bytes + 8 bytes per type"
    }
    sig_impl: {
      shape: class
      label: "impl ArchetypeSignature"
      +new(): "Self"
      +from_types(types: Vec<TypeId>): "Self"
      "+contains(&self, tid: TypeId)": "bool"
      "+contains_all(&self, types: &[TypeId])": "bool"
      "+contains_none(&self, types: &[TypeId])": "bool"
      "+with_added(&self, tid: TypeId)": "Option<Self>"
      "+with_removed(&self, tid: TypeId)": "Option<Self>"
      "+iter(&self)": "impl Iterator<Item=TypeId>"
    }
  }
  layer_arch: {
    direction: down
    label: "ARCHETYPE TABLE"
    archetype: {
      shape: sql_table
      label: "struct Archetype (archetype.rs)  [M4]"
      signature: "ArchetypeSignature"
      columns: "HashMap<TypeId, ComponentColumn>"
      entities: "Vec<Entity> | row -> entity"
      id: "ArchetypeId(usize)"
      entity_data_size: "usize | for alloc hints"
      sz: "Varies: entities + columns"
    }
    arch_impl: {
      shape: class
      label: "impl Archetype"
      +new(id: ArchetypeId, sig: ArchetypeSignature): "Self"
      "+ensure_column<T: 'static>(&mut self)": "()"
      "+push_entity(&mut self, e: Entity)": "usize"
      "+push_component<T>(&mut self, c: T)": "()"
      "+get<T: 'static>(&self, row: usize)": "Option<&T>"
      "+get_mut<T>(&mut self, row: usize)": "Option<&mut T>"
      "+swap_remove(&mut self, row: usize)": "Option<(Entity, usize)>"
      "+column<T: 'static>(&self)": "Option<&Vec<T>>"
      "+column_mut<T>(&mut self)": "Option<&mut Vec<T>>"
      "+len(&self)": "usize"
    }
  }
  layer_loc: {
    direction: down
    label: "ENTITY LOCATIONS"
    entity_loc: {
      shape: sql_table
      label: "struct EntityLocation (entity_location.rs)"
      archetype_id: "ArchetypeId"
      row: "usize"
      sz: "16 bytes"
    }
    entity_locations: {
      shape: sql_table
      label: "struct EntityLocations"
      locations: "Vec<Option<EntityLocation>>"
      sz: "17 bytes per entity slot"
    }
    loc_impl: {
      shape: class
      label: "impl EntityLocations"
      +new(): "Self"
      "+get(&self, e: Entity)": "Option<EntityLocation>"
      "+set(&mut self, e: Entity, loc: EntityLocation)": "()"
      "+clear(&mut self, e: Entity)": "()"
      "+update_row(&mut self, e: Entity, row: usize)": "()"
    }
  }
  layer_graph: {
    direction: down
    label: "ARCHETYPE GRAPH"
    arch_graph: {
      shape: sql_table
      label: "struct ArchetypeGraph (archetype_graph.rs)"
      edges: "HashMap<(ArchetypeId, TypeId, bool), ArchetypeId>"
      sz: "~60 bytes per cached edge"
    }
    graph_impl: {
      shape: class
      label: "impl ArchetypeGraph"
      +new(): "Self"
      "+get_add(&self, from: ArchetypeId, tid: TypeId)": "Option<ArchetypeId>"
      "+get_remove(&self, from: ArchetypeId, tid: TypeId)": "Option<ArchetypeId>"
      "+find_or_create_for_add(&mut self, reg, from, tid)": "ArchetypeId"
      "+find_or_create_for_remove(&mut self, reg, from, tid)": "Option<ArchetypeId>"
    }
    arch_registry: {
      shape: class
      label: "struct ArchetypeRegistry"
      -archetypes: "Vec<Archetype>"
      -signature_to_id: "HashMap<ArchetypeSignature, ArchetypeId>"
      "+get_or_create(&mut self, sig: ArchetypeSignature)": "ArchetypeId"
      "+get(&self, id: ArchetypeId)": "Option<&Archetype>"
      "+get_mut(&mut self, id: ArchetypeId)": "Option<&mut Archetype>"
      "+iter(&self)": "impl Iterator<Item=&Archetype>"
      "+stats(&self)": "ArchetypeStats"
    }
  }
}
# ============================================================================
# ROW 5: COMPONENT TYPE INFO
# ============================================================================
row_typeinfo: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_typeinfo: {
    direction: down
    label: "COMPONENT TYPE METADATA"
    type_info: {
      shape: sql_table
      label: "struct ComponentTypeInfo (component_type_info.rs)"
      type_id: "TypeId"
      type_name: "&'static str"
      size: "usize | bytes"
      clone_fn: "fn(&dyn Any) -> Box<dyn Any>"
      sz: "48 bytes"
    }
    type_info_impl: {
      shape: class
      label: "impl ComponentTypeInfo"
      "+new<T: 'static + Clone>()": "Self"
    }
    comp_column: {
      shape: sql_table
      label: "struct ComponentColumn (component_column.rs)"
      type_id: "TypeId"
      storage: "Box<dyn ColumnOps>"
      component_size: "usize"
      type_name: "&'static str"
      sz: "~56 bytes + heap"
    }
    comp_column_impl: {
      shape: class
      label: "impl ComponentColumn"
      "+new<T: 'static>()": "Self"
      "+push<T: 'static>(&mut self, c: T)": "()"
      "+get<T: 'static>(&self, idx: usize)": "Option<&T>"
      "+get_mut<T>(&mut self, idx: usize)": "Option<&mut T>"
      "+swap_remove(&mut self, idx: usize)": "Option<usize>"
      "+as_vec<T: 'static>(&self)": "Option<&Vec<T>>"
      "+as_vec_mut<T>(&mut self)": "Option<&mut Vec<T>>"
    }
  }
}
# ============================================================================
# CONNECTIONS: Entity Manager to World
# ============================================================================
row_foundation.layer_entity.entity_struct -> row_foundation.layer_entity.entity_impl: "uses"
row_foundation.layer_entity.entity_manager -> row_foundation.layer_entity.em_impl: "uses"
row_foundation.layer_entity.entity_impl -> row_foundation.layer_world_core.world_struct: "Entity handles"
row_foundation.layer_entity.entity_manager -> row_foundation.layer_world_core.world_struct: "owned by"
# ============================================================================
# CONNECTIONS: Sparse Sets
# ============================================================================
row_sparse.layer_sparse.sparse_set -> row_sparse.layer_sparse.sparse_impl: "methods"
row_sparse.layer_registry.comp_storage -> row_sparse.layer_sparse.column_ops: "impl by SparseSet"
row_sparse.layer_sparse.sparse_set -> row_sparse.layer_registry.comp_storage: "impl"
row_sparse.layer_registry.comp_registry -> row_sparse.layer_registry.registry_impl: "methods"
row_sparse.layer_registry.registry_impl -> row_sparse.layer_sparse.sparse_set: "stores"
# ============================================================================
# CONNECTIONS: Commands and Systems
# ============================================================================
row_systems.layer_commands.command_enum -> row_systems.layer_commands.command_buffer: "stored in"
row_systems.layer_commands.command_buffer -> row_systems.layer_commands.commands_wrapper: "wrapped by"
row_systems.layer_scheduler.system_trait -> row_systems.layer_scheduler.system_desc: "boxed as"
row_systems.layer_scheduler.system_desc -> row_systems.layer_scheduler.scheduler: "stored in"
row_systems.layer_query.query_spec -> row_systems.layer_query.query_impl: "methods"
row_systems.layer_query.query_spec -> row_systems.layer_query.query_iter: "filters for"
# ============================================================================
# CONNECTIONS: Archetype Storage
# ============================================================================
row_archetype.layer_sig.archetype_sig -> row_archetype.layer_sig.sig_impl: "methods"
row_archetype.layer_sig.archetype_sig -> row_archetype.layer_arch.archetype: "identifies"
row_archetype.layer_arch.archetype -> row_archetype.layer_arch.arch_impl: "methods"
row_archetype.layer_loc.entity_loc -> row_archetype.layer_loc.entity_locations: "stored in"
row_archetype.layer_loc.entity_locations -> row_archetype.layer_loc.loc_impl: "methods"
row_archetype.layer_graph.arch_graph -> row_archetype.layer_graph.graph_impl: "methods"
row_archetype.layer_graph.graph_impl -> row_archetype.layer_graph.arch_registry: "creates in"
# ============================================================================
# CROSS-LAYER CONNECTIONS
# ============================================================================
# World owns everything
row_foundation.layer_world_core.world_struct -> row_sparse.layer_registry.comp_registry: "components field"
row_foundation.layer_world_core.world_struct -> row_archetype.layer_graph.arch_registry: "archetypes field"
row_foundation.layer_world_core.world_struct -> row_archetype.layer_loc.entity_locations: "entity_locations field"
row_foundation.layer_world_core.world_struct -> row_systems.layer_commands.command_buffer: "command_buffer field"
row_foundation.layer_world_core.world_struct -> row_systems.layer_scheduler.scheduler: "scheduler field"
# Commands create entities
row_systems.layer_commands.commands_wrapper -> row_foundation.layer_entity.entity_manager: "borrows for spawn"
# Migration uses type info
row_archetype.layer_arch.arch_impl -> row_typeinfo.layer_typeinfo.type_info: "uses clone_fn"
# Query matches archetypes
row_systems.layer_query.query_spec -> row_archetype.layer_sig.archetype_sig: "matches against"
# Entity locations point to archetypes
row_archetype.layer_loc.entity_loc -> row_archetype.layer_arch.archetype: "archetype_id -> Archetype"
# ============================================================================
# KEY ALGORITHMS BOX
# ============================================================================
algorithms: {
  shape: rectangle
  label: "KEY ALGORITHMS"
  algo_list: |md
    **Entity Creation (M1):**
    1. Pop from free_list OR allocate new slot
    2. Return Entity(index, current_generation)
    3. O(1) amortized
    **Entity Destruction (M1):**
    1. Validate generation matches
    2. Increment generation (wrapping)
    3. Push index to free_list
    4. O(1)
    **Swap-and-Pop Remove (M2):**
    1. sparse[index] = EMPTY
    2. dense.swap(dense_idx, last)
    3. entities.swap(dense_idx, last)
    4. Update swapped entity's sparse entry
    5. O(1), maintains contiguity
    **Entity Migration (M4):**
    1. Get source archetype, row
    2. Find/create target archetype via graph
    3. Copy all shared components (clone_fn)
    4. Add new component if provided
    5. Swap-remove from source
    6. Update EntityLocation
    7. O(components in entity)
    **Command Buffer Flush (M3):**
    1. Phase 1: Process Insert commands
    2. Phase 2: Process Remove commands
    3. Phase 3: Process Destroy commands
    4. Buffer empty when complete
  |
}
# ============================================================================
# MEMORY LAYOUT BOX
# ============================================================================
memory_layout: {
  shape: rectangle
  label: "MEMORY LAYOUT (1M entities example)"
  mem_list: |md
    **EntityManager:**
    - generations: 1M × 2 bytes = 2 MB
    - free_list: 1M × 8 bytes = 8 MB (worst case)
    - Total: ~10 MB
    **SparseSet`<Position>` (100K components):**
    - sparse: 1M × 8 bytes = 8 MB
    - dense: 100K × 8 bytes = 800 KB
    - entities: 100K × 4 bytes = 400 KB
    - Total: ~9.2 MB
    **Archetype(Position, Velocity) 100K entities:**
    - entities: 100K × 4 bytes = 400 KB
    - Position column: 100K × 8 bytes = 800 KB
    - Velocity column: 100K × 8 bytes = 800 KB
    - Total: ~2 MB
    **Cache Line: 64 bytes**
    - 8 Position components per cache line
    - Sequential access = optimal prefetching
  |
}
# ============================================================================
# PERFORMANCE TARGETS BOX
# ============================================================================
perf_targets: {
  shape: rectangle
  label: "PERFORMANCE TARGETS"
  perf_list: |'md
    | Operation | Target | Notes |
    |-----------|--------|-------|
    | create_entity | &lt;100ns | O(1) amortized |
    | destroy_entity | &lt;100ns | O(1) |
    | is_alive | &lt;50ns | O(1) |
    | SparseSet get/insert/remove | O(1) | - |
    | SparseSet iteration (100K) | &lt;1ms | Sequential |
    | Archetype iteration (100K) | &lt;500us | 2x sparse set |
    | Entity migration | O(components) | Copy all shared |
    | Create+destroy 1M entities | &lt;100ms | Benchmark |
  '|
}
# ============================================================================
# MILESTONE INDEX
# ============================================================================
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | ecs-arch-m1 | Entity Manager & World Container"
  m2: "M2 | ecs-arch-m2 | Sparse-Set Component Storage"
  m3: "M3 | ecs-arch-m3 | Systems, Queries & Command Buffers"
  m4: "M4 | ecs-arch-m4 | Archetype-Based Storage"
}
# Position the reference boxes
algorithms.near: bottom-left
memory_layout.near: bottom-center
perf_targets.near: bottom-right
milestone_index.near: bottom-center