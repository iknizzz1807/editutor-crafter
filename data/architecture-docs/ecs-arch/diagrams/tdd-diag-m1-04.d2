vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B4C9A"
    data: "#3B82F6"
    free: "#22C55E"
    scalar: "#F59E0B"
    pointer: "#F97316"
    cache: "#94A3B8"
    padding: "#E2E8F0"
    border: "#1E293B"
  }
}

title: |'md
# EntityManager Memory Layout
**Intel-Grade Technical Specification**
*Total footprint for 1M entities: ~9.54 MiB*
'| {near: top-center}

direction: right

# --- Main Struct Memory Alignment ---
EntityManager: {
  label: "EntityManager Struct (sizeof=64 bytes - 1 cache line)"
  style: {
    fill: "${colors.header}"
    font-color: white
    stroke: "${colors.border}"
    stroke-width: 2
  }

  grid-columns: 3
  grid-gap: 20

  # Column 1: Byte Offsets (Left Margin)
  offsets: {
    grid-columns: 1
    style.stroke-width: 0
    o00: "0x00" { style.font-size: 11; style.font: mono }
    o18: "0x18" { style.font-size: 11; style.font: mono }
    o30: "0x30" { style.font-size: 11; style.font: mono }
    o38: "0x38" { style.font-size: 11; style.font: mono }
  }

  # Column 2: Field Definitions
  fields: {
    grid-columns: 1
    generations_vec: "generations: Vec<u16>" {
      tooltip: "Internal Struct: { data_ptr: 8B, capacity: 8B, len: 8B }"
      style.fill: "${colors.data}"
      style.font-color: white
      style.bold: true
      # Breaking down the Vec internal layout
      internal: {
        grid-columns: 3
        grid-gap: 0
        p: "ptr" { style.font-size: 10; style.fill: "${colors.pointer}" }
        c: "cap" { style.font-size: 10 }
        l: "len" { style.font-size: 10 }
      }
    }
    freelist_vec: "free_list: Vec<usize>" {
      tooltip: "Internal Struct: { data_ptr: 8B, capacity: 8B, len: 8B }"
      style.fill: "${colors.free}"
      style.font-color: white
      style.bold: true
      internal: {
        grid-columns: 3
        grid-gap: 0
        p: "ptr" { style.font-size: 10; style.fill: "${colors.pointer}" }
        c: "cap" { style.font-size: 10 }
        l: "len" { style.font-size: 10 }
      }
    }
    len: "active_count: usize" {
      style.fill: "${colors.scalar}"
      style.bold: true
    }
    capacity: "total_capacity: usize" {
      style.fill: "${colors.scalar}"
      style.bold: true
    }
  }

  # Column 3: Field Sizes (Right Margin)
  sizes: {
    grid-columns: 1
    style.stroke-width: 0
    s24a: "24 bytes" { style.font-size: 11; style.font: mono }
    s24b: "24 bytes" { style.font-size: 11; style.font: mono }
    s08a: "8 bytes" { style.font-size: 11; style.font: mono }
    s08b: "8 bytes" { style.font-size: 11; style.font: mono }
  }
}

# --- Pointers to Heap Allocations ---
EntityManager.fields.generations_vec.internal.p -> GenerationsHeap: "heap pointer (8B)" {
  style: {
    stroke: "${colors.pointer}"
    stroke-width: 3
    animated: true
  }
}

EntityManager.fields.freelist_vec.internal.p -> FreeListHeap: "heap pointer (8B)" {
  style: {
    stroke: "${colors.pointer}"
    stroke-width: 3
    animated: true
  }
}

# --- Heap Layout: Generations Array ---
GenerationsHeap: "Generations Heap [u16; 1,000,000]" {
  style.stroke: "#1D4ED8"
  style.stroke-width: 3
  style.fill: white

  CacheLine0: {
    label: "Cache Line 0 (Offset 0x00 - 0x3F)"
    style.stroke: "${colors.cache}"
    style.stroke-dash: 4
    
    grid-columns: 5
    g0: "gen[0]" { style.fill: "${colors.data}"; style.font-color: white }
    g1: "gen[1]" { style.fill: "${colors.data}"; style.font-color: white }
    g2: "gen[2]" { style.fill: "${colors.data}"; style.font-color: white }
    sep: "..." { shape: text }
    g31: "gen[31]" { style.fill: "${colors.data}"; style.font-color: white }
  }

  CacheLine1: {
    label: "Cache Line 1 (Offset 0x40 - 0x7F)"
    style.stroke: "${colors.cache}"
    style.stroke-dash: 4
    grid-columns: 2
    g32: "gen[32]" { style.fill: "${colors.data}"; style.font-color: white }
    sep2: "..." { shape: text }
  }

  Metadata: |md
  - **Storage:** Contiguous `u16` array
  - **Access:** $O(1)$ indexing via `EntityID`
  - **Cache:** 32 entries per L1 cache line (64B)
  |
}

# --- Heap Layout: Free List Stack ---
FreeListHeap: "Free List Heap [usize; capacity]" {
  style.stroke: "#15803D"
  style.stroke-width: 3
  style.fill: white

  Visual: {
    label: "LIFO Stack Structure"
    style.stroke-width: 0
    
    ptr: "**SP**" {
      shape: text
      style.font-color: red
      style.bold: true
    }
    i0: "idx[0]" { style.fill: "${colors.free}"; style.font-color: white }
    i1: "idx[1]" { style.fill: "${colors.free}"; style.font-color: white }
    gap: "..." { shape: text }
    iN: "idx[N]" { style.fill: "${colors.free}"; style.font-color: white }
  }

  Specs: |md
  - **Size:** 8-bytes per index (`usize`)
  - **Behavior:** Stores IDs of destroyed entities
  - **Performance:** $O(1)$ push/pop
  |
}

# --- Legends & Documentation ---
Legend: {
  near: bottom-right
  hdr: "Struct Header (Cache Line 1)" { style.fill: "${colors.header}"; style.font-color: white }
  dat: "Generation u16 Array" { style.fill: "${colors.data}"; style.font-color: white }
  fre: "Free Index Stack" { style.fill: "${colors.free}"; style.font-color: white }
  ptr: "Pointers (Heap References)" { 
    style: {
        stroke: "${colors.pointer}"
        stroke-width: 3
    }
  }
  cch: "--- 64B Cache Line Boundary" { style.stroke: "${colors.cache}"; style.stroke-dash: 4 }
}

MemorySummary: |md
## Total Memory Analysis (1,000,000 Entities)
| Memory Segment | Type | Element Size | Total Bytes | Capacity |
| :--- | :--- | :--- | :--- | :--- |
| `generations` | `u16` | 2 Bytes | **2,000,000** | Fixed |
| `free_list` | `usize` | 8 Bytes | **8,000,000** | Dynamic (Max) |
| `Scalars` | `usize` | 8 Bytes | **16** | Metadata |
| **Total Peak** | | | **~9.54 MiB** | |

### Hardware Alignment
- `EntityManager` struct is **exactly 64 bytes**, preventing false sharing and ensuring it fits in a single L1 cache line.
- `generations` array alignment ensures no element straddles a cache line boundary.
| { near: bottom-center }