direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    world-bg: "#E8F4F8"
    world-border: "#2E86AB"
    entity-mgr-bg: "#FDF6E3"
    entity-mgr-border: "#B58900"
    future-bg: "#F5F5F5"
    future-border: "#9E9E9E"
    future-fill: "transparent"
    header-color: "#1565C0"
    pointer-color: "#E65100"
    padding-gray: "#EEEEEE"
  }
}

# --- TOP LEVEL HEADER ---
title: {
  shape: text
  label: ||md
    # World Container Ownership
    ## Entity-Component-System Architecture (M1 Implementation Spec)
  ||
  near: top-center
}

# --- MAIN ARCHITECTURE ---
World: {
  style: {
    fill: "${colors.world-bg}"
    stroke: "${colors.world-border}"
    stroke-width: 4
    border-radius: 8
    shadow: true
  }
  
  label: ||md
    ### 📦 World (Root Container)
    `sizeof = 128 bytes` (Header + Managed Pointers)

    rust
    pub struct World {
        entities: EntityManager,
        component_storages: Map<TypeId, Box<dyn Storage>>,
        systems: SystemScheduler,
    }
    
  ||

  # --- CURRENT IMPLEMENTATION ---
  EntityManager: {
    style: {
      fill: "${colors.entity-mgr-bg}"
      stroke: "${colors.entity-mgr-border}"
      stroke-width: 2
      border-radius: 6
    }
    label: ||md
      ### 🧩 EntityManager
      **Memory Layout / Offsets:**
      | Offset | Field | Type | Size |
      | :--- | :--- | :--- | :--- |
      | `+0x00` | `generations` | `Vec<u16>` | 24B |
      | `+0x18` | `free_list` | `Vec<usize>` | 24B |
      | `+0x30` | `len` | `usize` | 8B |
      | `+0x38` | `capacity` | `usize` | 8B |
      
      **VTable / Methods:**
      - `fn create(&mut self) -> Entity`
      - `fn destroy(&mut self, e: Entity) -> bool`
      - `fn is_alive(&self, e: Entity) -> bool`
    ||
  }

  # Visual helper for connection anchor
  Anchor: {
    shape: circle
    width: 0
    height: 0
    style.opacity: 0
  }
}

# --- FUTURE MODULES (MILESTONES 2 & 3) ---
Future_Modules: {
  style: {
    stroke: "${colors.future-border}"
    stroke-dash: 5
    fill: transparent
  }
  label: "Milestone 2 & 3 Roadmap"

  ComponentStorage: {
    style: {
      fill: "${colors.future-fill}"
      stroke: "${colors.future-border}"
      stroke-dash: 4
      stroke-width: 2
      border-radius: 6
    }
    label: ||md
      ### 🗄️ ComponentStorage (M2)
      **Internal Data (Sparse Set):**
      - `sparse: Vec<u32>` (Index to Dense)
      - `dense: Vec<T>` (Packed Components)
      - `entities: Vec<Entity>` (Back-references)
    ||
  }

  SystemScheduler: {
    style: {
      fill: "${colors.future-fill}"
      stroke: "${colors.future-border}"
      stroke-dash: 4
      stroke-width: 2
      border-radius: 6
    }
    label: ||md
      ### ⚙️ SystemScheduler (M3)
      **Execution Logic:**
      - Dependency Graph Solver
      - Parallel System Dispatcher
      - `run(&mut World, dt: f32)`
    ||
  }

  CommandBuffer: {
    style: {
      fill: "${colors.future-fill}"
      stroke: "${colors.future-border}"
      stroke-dash: 4
      stroke-width: 2
      border-radius: 6
    }
    label: ||md
      ### 📬 CommandBuffer (M3)
      **Deferred Actions Queue:**
      - `Spawn(Bundle)`
      - `Despawn(Entity)`
      - `AddComponent(Entity, T)`
    ||
  }
}

# --- RELATIONSHIPS ---

# M1 Ownership
World.Anchor -> World.EntityManager: "owns (composition)" {
  style: {
    stroke: "${colors.world-border}"
    stroke-width: 4
  }
  target-arrowhead: {
    shape: diamond
    style.filled: true
  }
}

# Future Connections (M2/M3)
World -> Future_Modules.ComponentStorage: "owns (M2)" {
  style: {
    stroke: "${colors.future-border}"
    stroke-dash: 5
    stroke-width: 2
  }
}

World -> Future_Modules.SystemScheduler: "owns (M3)" {
  style: {
    stroke: "${colors.future-border}"
    stroke-dash: 5
    stroke-width: 2
  }
}

World -> Future_Modules.CommandBuffer: "owns (M3)" {
  style: {
    stroke: "${colors.future-border}"
    stroke-dash: 5
    stroke-width: 2
  }
}

# --- LEGEND & DOCUMENTATION ---
legend: {
  near: bottom-right
  style: {
    fill: "#FFFFFF"
    stroke: "#CCCCCC"
    stroke-width: 1
  }
  
  content: {
    shape: text
    label: ||md
      ### Diagram Legend
      | Element | Meaning |
      | :--- | :--- |
      | **Solid Bold** | Current Production Architecture (M1) |
      | **Dashed Light** | Planned Future Modules (M2+) |
      | **Diamond Arrow** | Composition (Exclusive Ownership) |
      | **Hex Table** | Memory Offset Specification |
    ||
  }

  current_proxy: {
    label: "Current M1"
    height: 20
    style: {
      fill: "${colors.world-border}"
      stroke: "${colors.world-border}"
    }
  }

  future_proxy: {
    label: "Future M2/3"
    height: 20
    style: {
      stroke: "${colors.future-border}"
      stroke-dash: 4
      fill: transparent
    }
  }
}

# Notes for Engineering
annotation: {
  shape: text
  near: bottom-left
  label: ||md
    **Implementation Notes:**
    1. `EntityManager` is the only source of truth for Entity IDs.
    2. Generations are used to prevent ABA problems in reused IDs.
    3. Milestone 2 will migrate storage out of `World` into `ComponentStorage` maps.
  ||
}