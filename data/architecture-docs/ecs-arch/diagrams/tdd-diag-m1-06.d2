layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

# -----------------------------------------------------------------------------------------
# GLOBAL STYLES & CLASSES
# -----------------------------------------------------------------------------------------
classes: {
  header: {
    style: {
      fill: "#E8E8E8"
      bold: true
      font-size: 14
      border-radius: 4
    }
  }
  alive: {
    style: {
      fill: "#ACE1AF"
      stroke: "#228B22"
      stroke-width: 2
    }
  }
  valid: {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      bold: true
    }
  }
  stale: {
    style: {
      fill: "#FFB6C1"
      stroke: "#DC143C"
      stroke-width: 2
    }
  }
  recycling: {
    style: {
      fill: "#FFFACD"
      stroke: "#DAA520"
      stroke-dash: 3
    }
  }
  danger: {
    style: {
      fill: "#FF6B6B"
      stroke: "#8B0000"
      bold: true
      font-color: "#FFFFFF"
      double-border: true
    }
  }
  bit_box: {
    width: 35
    height: 40
    style: {
      font-size: 11
      text-transform: uppercase
      font: mono
    }
  }
}

# -----------------------------------------------------------------------------------------
# TITLE & HEADER
# -----------------------------------------------------------------------------------------
title: {
  label: |md
    # Generation Wraparound Scenario
    ### Slot recycled 4096 times: Generation wraps 4095 → 0
    *Memory Safety Analysis: Spatial vs Temporal Aliasing*
  |
  near: top-center
  shape: text
}

# -----------------------------------------------------------------------------------------
# BIT LAYOUT VISUALIZATION
# -----------------------------------------------------------------------------------------
bits_section: {
  near: top-right
  style.stroke: "#333333"
  style.fill: "#FDFDFD"
  style.shadow: true
  style.stroke-width: 1
  
  bits_title: {
    label: |md
      ### 32-bit Handle Layout (4 Bytes)
    |
    shape: text
  }
  
  register_view: {
    grid-columns: 32
    grid-gap: 0
    
    # Bits 31-12: Index (20 bits)
    i31: { label: "31"; class: bit_box; style.fill: "#E1F5FE" }
    i30: { label: "I"; class: bit_box; style.fill: "#E1F5FE" }
    i29: { label: "N"; class: bit_box; style.fill: "#E1F5FE" }
    i28: { label: "D"; class: bit_box; style.fill: "#E1F5FE" }
    i27: { label: "E"; class: bit_box; style.fill: "#E1F5FE" }
    i26: { label: "X"; class: bit_box; style.fill: "#E1F5FE" }
    i25: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i24: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i23: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i22: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i21: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i20: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i19: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i18: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i17: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i16: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i15: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i14: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i13: { label: "."; class: bit_box; style.fill: "#E1F5FE" }
    i12: { label: "12"; class: bit_box; style.fill: "#E1F5FE" }
    
    # Bits 11-0: Generation (12 bits)
    g11: { label: "11"; class: bit_box; style.fill: "#FFF9C4" }
    g10: { label: "G"; class: bit_box; style.fill: "#FFF9C4" }
    g09: { label: "E"; class: bit_box; style.fill: "#FFF9C4" }
    g08: { label: "N"; class: bit_box; style.fill: "#FFF9C4" }
    g07: { label: "."; class: bit_box; style.fill: "#FFF9C4" }
    g06: { label: "."; class: bit_box; style.fill: "#FFF9C4" }
    g05: { label: "."; class: bit_box; style.fill: "#FFF9C4" }
    g04: { label: "."; class: bit_box; style.fill: "#FFF9C4" }
    g03: { label: "."; class: bit_box; style.fill: "#FFF9C4" }
    g02: { label: "."; class: bit_box; style.fill: "#FFF9C4" }
    g01: { label: "."; class: bit_box; style.fill: "#FFF9C4" }
    g00: { label: "0"; class: bit_box; style.fill: "#FFF9C4" }
  }
  
  legend_row: {
    grid-columns: 2
    idx_leg: "Index Bits [31:12]" { style.font-size: 11; style.bold: true; style.font-color: "#0277BD" }
    gen_leg: "Generation Bits [11:0]" { style.font-size: 11; style.bold: true; style.font-color: "#FBC02D" }
  }

  wrap_details: {
    label: |md
      **Boundary Transition:**
      - Max Generation: `4095` (`0xFFF`)
      - Increment: `4095 + 1 = 0` (Truncated to 12 bits)
    |
    shape: text
  }
}

# -----------------------------------------------------------------------------------------
# TIMELINE GRID
# -----------------------------------------------------------------------------------------
timeline: {
  grid-rows: 5
  grid-columns: 6
  grid-gap: 20
  
  # --- Row 0: Headers ---
  h1: { label: |md **Epoch** |; class: header }
  h2: { label: |md **Generation** |; class: header }
  h3: { label: |md **Slot State** |; class: header }
  h4: { label: |md **Reference in Hand** |; class: header }
  h5: { label: |md **Validator Result** |; class: header }
  h6: { label: |md **System Behavior** |; class: header }

  # --- Row 1: Epoch 0 ---
  e0_epoch: "0 (Start)"
  e0_gen: "0"
  e0_state: {
    label: |md
      **Entity(5, 0)**
      State: ALIVE
    |
    class: alive
  }
  e0_ref: {
    label: |md
      `ref_A = (5, 0)`
    |
    class: valid
  }
  e0_val: "✅ (0 == 0)"
  e0_note: "Initial allocation.\nHandle ref_A is valid."

  # --- Row 2: Epoch 1-4094 ---
  eMid_epoch: "1 - 4094"
  eMid_gen: "1 - 4094"
  eMid_state: {
    label: |md
      **Slot Recycled**
      N times
    |
    class: recycling
  }
  eMid_ref: {
    label: |md
      `ref_A = (5, 0)`
    |
    class: stale
  }
  eMid_val: "❌ (0 != gen)"
  eMid_note: "Stale handle ref_A\ndetected correctly."

  # --- Row 3: Epoch 4095 ---
  e4095_epoch: "4095"
  e4095_gen: "4095"
  e4095_state: {
    label: |md
      **Entity(5, 4095)**
      Max Gen Reached
    |
    class: alive
  }
  e4095_ref: {
    label: |md
      `ref_A = (5, 0)`
    |
    class: stale
  }
  e4095_val: "❌ (0 != 4095)"
  e4095_note: "One cycle before\nwraparound hazard."

  # --- Row 4: Epoch 4096 (THE HAZARD) ---
  e4096_epoch: "4096 (Wrap)"
  e4096_gen: "0"
  e4096_state: {
    label: |md
      **New Entity(5, 0)**
      *Recycled Index*
    |
    class: danger
  }
  e4096_ref: {
    label: |md
      `ref_A = (5, 0)`
    |
    class: danger
  }
  e4096_val: {
    label: |md
      **💥 FALSE POSITIVE**
      (0 == 0)
    |
    style.bold: true
    style.font-color: red
  }
  e4096_note: {
    label: |md
      **TEMPORAL ALIASING**
      Stale ref_A can now
      corrupt New Entity!
    |
    style.bold: true
  }
}

# -----------------------------------------------------------------------------------------
# IMPLEMENTATION DETAILS
# -----------------------------------------------------------------------------------------
code_section: {
  near: bottom-right
  
  code_title: {
    label: |md
      ### Hazardous Logic (Overflow)
    |
    shape: text
  }
  
  rust_code: {
    label: |go
      // Memory structure in SlotMap
      struct Slot {
          gen: u12, // Custom bitfield
          data: EntityData,
      }

      // UNSAFE RECYCLING
      fn recycle(index: usize) {
          // Silent 12-bit wraparound
          generations[index] = 
              (generations[index] + 1) & 0xFFF;
      }
    |
    shape: text
    style.font-size: 13
  }
}

# -----------------------------------------------------------------------------------------
# MITIGATION FOOTER
# -----------------------------------------------------------------------------------------
mitigation: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#E1F5FE"
    stroke: "#01579B"
    stroke-width: 2
    border-radius: 8
  }
  
  content: {
    label: |md
      ## 🛡️ Engineering Mitigations
      1. **Wide Generations:** Use 32-bit generations (`u32`). Wraparound takes years of uptime.
      2. **Generation Skip:** On `MAX_GEN`, mark slot as "Dead/Tombstone" and never reuse.
      3. **Panic on Overflow:** In debug builds, assert `gen < MAX_GEN`.
      4. **Handle Scrubbing:** Invalidate all handles on major state transitions.
    |
    shape: text
  }
}

# Connections for flow visualization
timeline.e0_state -> timeline.eMid_state: "Free & Realloc"
timeline.eMid_state -> timeline.e4095_state: "N cycles"
timeline.e4095_state -> timeline.e4096_state: "4096th Realloc" {
  style.stroke: red
  style.stroke-width: 3
  style.animated: true
}
bits_section.wrap_details -> timeline.e4096_gen: "Wrapped to zero" {
  style.stroke: red
  style.stroke-dash: 5
}