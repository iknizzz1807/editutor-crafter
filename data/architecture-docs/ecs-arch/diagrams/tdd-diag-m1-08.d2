vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Destroy Entity Flow
  `World::destroy_entity(entity)` → EntityManager::destroy()
| {near: top-center}

direction: right

classes: {
  step: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 8
      font-color: "#1E3A5F"
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
    }
  }
  error: {
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 2
      border-radius: 8
    }
  }
  success: {
    style: {
      fill: "#D1FAE5"
      stroke: "#059669"
      stroke-width: 2
      border-radius: 8
      bold: true
    }
  }
  data_read: {
    shape: parallelogram
    style: {
      fill: "#F3E8FF"
      stroke: "#7C3AED"
      stroke-width: 2
    }
  }
  data_write: {
    shape: parallelogram
    style: {
      fill: "#FCE7F3"
      stroke: "#DB2777"
      stroke-width: 2
    }
  }
  group_container: {
    style: {
      stroke-dash: 3
      stroke: "#CBD5E1"
      fill: "#F8FAFC"
      border-radius: 12
    }
  }
}

# --- Initialization ---
start_point: {
  start: ● {shape: circle; style.fill: "#10B981"}
  entity_param: "entity: Entity" {
    class: data_read
  }
}

# --- Process Steps (Encapsulated to maintain proximity in ELK) ---

step1_group: {
  class: group_container
  step1: "1. Extract Index" {
    class: step
  }
  step1_detail: |md
    `index ← entity.index()`
    `generation ← entity.generation()`
  | {shape: text}
}

check1: "index >= capacity?" {class: decision}

step2_group: {
  class: group_container
  step2: "2. Read Current Generation" {
    class: step
  }
  step2_detail: |md
    `current_gen ← generations[index]`
  | {shape: text}
}

check2: "generation == current_gen?" {class: decision}

step3_group: {
  class: group_container
  step3: "3. Increment Generation (Wrapping)" {
    class: step
  }
  step3_detail: |md
    `generations[index] ← current_gen.wrapping_add(1)`
    *4095 + 1 → 0 (wraps)*
  | {shape: text}
}

step4_group: {
  class: group_container
  step4: "4. Push to Free List" {
    class: step
  }
  step4_detail: |md
    `free_list.push(index)`
  | {shape: text}
}

step5_group: {
  class: group_container
  step5: "5. Decrement Length" {
    class: step
  }
  step5_detail: |md
    `len ← len - 1`
  | {shape: text}
}

# --- Exit States ---
return_false_1: {
  class: error
  label: "return false\n(Invalid Index)"
}
return_false_2: {
  class: error
  label: "return false\n(Stale Handle)"
}
return_true: {
  class: success
  label: "return true\n(Entity Destroyed)"
}

# --- Control Flow Connections ---
start_point.start -> step1_group.step1: "destroy_entity(entity)"
step1_group.step1 -> check1

check1 -> return_false_1: "Yes"
check1 -> step2_group.step2: "No"

step2_group.step2 -> check2

check2 -> return_false_2: "No\n(mismatch)"
check2 -> step3_group.step3: "Yes\n(match)"

step3_group.step3 -> step4_group.step4
step4_group.step4 -> step5_group.step5
step5_group.step5 -> return_true

# --- Documentation Annotations ---
memory_state: |md
  ### Memory State After Destroy
  **Before:**
  - `generations[5]` = 3
  - `free_list` = []
  - `len` = 100
  
  **After (entity at index 5 destroyed):**
  - `generations[5]` = 4  (incremented)
  - `free_list` = [5]     (recycled)
  - `len` = 99            (decremented)
  
  **Stale Handle Detection:**
  - Old handle: `Entity(index=5, gen=3)`
  - Current Slot: `gen(4)`
  - `gen(3) != current_gen(4)` → **Stale/Invalid**
| {
  near: bottom-center
  style: {
    fill: "#F8FAFC"
    stroke: "#94A3B8"
    stroke-dash: 2
    border-radius: 8
  }
}

invariants: |md
  ### Invariants Maintained
  1. `len == capacity - free_list.len()`
  2. `generations[index]` always current (alive or dead)
  3. Index in free_list ⟹ slot is dead
  4. Stale handles detected via generation mismatch
| {
  near: bottom-right
  style: {
    fill: "#ECFDF5"
    stroke: "#10B981"
    border-radius: 8
  }
}

# Legend for Byte-Level Mapping
legend: {
  near: top-right
  class: group_container
  label: "Field Key"
  r: "Data Read" { class: data_read }
  w: "Data Write" { class: data_write }
  s: "Logical Step" { class: step }
  d: "Branch Logic" { class: decision }
}

# Direct parameter reference
start_point.entity_param -> start_point.start: "input context" {
  style.stroke-dash: 3
  style.stroke: orange
}