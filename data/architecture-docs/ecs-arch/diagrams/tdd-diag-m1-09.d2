vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

# --- HEADER: Intel-Quality Specification ---
title: |md
  # Stale Handle Detection Algorithm
  ## `is_alive(handle)` — O(1) Validation Implementation
  ---
  **Constraint:** Slot-reused bitmasking and generation validation.
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 20
  }
}

# --- CLASSES ---
classes: {
  logic_step: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      border-radius: 4
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
  success: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 3
      double-border: true
    }
  }
  failure: {
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 3
      double-border: true
    }
  }
  bit_field: {
    style: {
      font: mono
      font-size: 14
      text-transform: uppercase
      fill: "#BBDEFB"
    }
  }
  header: {
    style: {
      fill: "#D1C4E9"
      bold: true
    }
  }
  data_cell: {
    style: {
      fill: "#E3F2FD"
    }
  }
}

# --- 1. DATA STRUCTURE LAYOUT (INTEL MANUAL STYLE) ---
entity_id_spec: "Data Structure: 32-bit Entity Handle" {
  style: {
    fill: "#F5F5F5"
    stroke: "#757575"
    stroke-dash: 3
  }
  
  bit_layout: {
    grid-columns: 32
    grid-gap: 0
    
    # Index Bits (31-12) - 20 bits
    i31: "I"; i30: "I"; i29: "I"; i28: "I"; i27: "I"; i26: "I"; i25: "I"; i24: "I"; i23: "I"; i22: "I"
    i21: "I"; i20: "I"; i19: "I"; i18: "I"; i17: "I"; i16: "I"; i15: "I"; i14: "I"; i13: "I"; i12: "I"
    
    # Generation Bits (11-0) - 12 bits
    g11: "G"; g10: "G"; g9: "G"; g8: "G"; g7: "G"; g6: "G"; g5: "G"; g4: "G"; g3: "G"; g2: "G"; g1: "G"; g0: "G"
    
    # Apply classes to bit ranges
    g*: { class: bit_field; style.fill: "#D1C4E9" } # Purple for Gen
    i*: { class: bit_field; style.fill: "#B3E5FC" } # Blue for Index
  }

  legend: |md
    **Layout Mapping:**
    - **[31..12] Index (20 bits):** Max Capacity = 1,048,576 slots.
    - **[11..00] Generation (12 bits):** Max Recycles = 4,095 iterations.
  | {
    shape: text
    style.font-size: 12
  }
}

# --- 2. ALGORITHM LOGIC FLOW ---
algorithm_flow: "Process: is_alive(entity)" {
  
  step1: "01. EXTRACT INDEX" {
    class: logic_step
    tooltip: "Shift right by 12 bits"
    description: |md
    rust
    let index = (handle >> 12) as usize;
    
    |
  }

  step2: "02. BOUNDS CHECK" {
    class: decision
    label: "index >= len?"
  }

  step3: "03. EXTRACT GENERATION" {
    class: logic_step
    tooltip: "Mask lowest 12 bits"
    description: |md
    rust
    let gen = (handle & 0x0FFF) as u16;
    
    |
  }

  step4: "04. LOOKUP CURRENT" {
    class: logic_step
    tooltip: "Random access to generation table"
    description: |md
    rust
    let current = gen_table[index];
    
    |
  }

  step5: "05. COMPARISON" {
    class: decision
    label: "gen == current?"
  }

  # Transitions
  step1 -> step2
  step2 -> result_oob: "YES" { style.stroke: red; style.bold: true }
  step2 -> step3: "NO" { style.stroke: green; style.bold: true }
  step3 -> step4
  step4 -> step5
  step5 -> result_valid: "MATCH" { style.stroke: green; style.bold: true }
  step5 -> result_stale: "MISMATCH" { style.stroke: red; style.bold: true }

  result_valid: "VALID" { class: success }
  result_stale: "STALE" { class: failure }
  result_oob: "OOB" { class: failure }
}

# --- 3. MEMORY LAYOUT DIAGRAM ---
memory_table_spec: "Memory: generation_table (Vec<u16>)" {
  style: {
    fill: "#F5F5F5"
    stroke: "#757575"
    stroke-dash: 3
  }
  
  table_grid: {
    grid-columns: 4
    grid-gap: 0
    
    # Row 0: Headers
    h1: "Offset" { class: header }
    h2: "Index" { class: header }
    h3: "Value (u16)" { class: header }
    h4: "Metadata" { class: header }
    
    # Row 1
    r1_off: "+0x00" { style.fill: "#EEEEEE" }
    r1_idx: "[0]" { class: data_cell }
    r1_val: "0x000A" { class: data_cell; style.font-color: blue }
    r1_meta: "Active Slot" { class: data_cell }
    
    # Row 2
    r2_off: "+0x02" { style.fill: "#EEEEEE" }
    r2_idx: "[1]" { class: data_cell }
    r2_val: "0x0001" { class: data_cell; style.font-color: blue }
    r2_meta: "Reused" { class: data_cell }
    
    # Row 3 (Dashed Cache Line)
    cache_sep: "--- Cache Line Boundary (64B) ---" {
      grid-columns: 4
      style.stroke-dash: 5
      style.font-size: 10
    }
    
    # Row 4
    r3_off: "+0x04" { style.fill: "#EEEEEE" }
    r3_idx: "[2]" { class: data_cell }
    r3_val: "0xFFFF" { class: data_cell; style.fill: "#BDBDBD" }
    r3_meta: "Tombstone" { class: data_cell }

    # Row 5 (Bold Page Boundary)
    page_sep: "=== Page Boundary (4096B) ===" {
      grid-columns: 4
      style.stroke-width: 4
      style.font-size: 10
    }
  }

  footer: |md
    - **Sizeof(u16):** 2 bytes.
    - **Growth:** Linear allocation in heap.
    - **Colors:** **Header=Purple**, **Data=Blue**, **Padding=Gray**
  | {
    shape: text
    style.font-size: 12
  }
}

# --- POSITIONING AND COMPLEXITY ---
entity_id_spec.near: top-left
memory_table_spec.near: bottom-left

complexity_analysis: |md
### Performance Characteristics
- **Time Complexity:** $O(1)$ constant time lookup.
- **Operations:** 1x Right Shift, 1x Bitwise AND, 1x Array Index.
- **Security:** Prevents "Use-after-free" by ensuring IDs from previous lives of a slot fail the equality check.
- **Spatial Locality:** Sequential `u16` table ensures high cache hit rate during batch processing.
| {
  near: bottom-right
  style: {
    font-size: 14
    fill: "#FAFAFA"
    stroke: "#CCCCCC"
  }
}

# Triple globs for consistent styling
***.style.font: mono
(*** -> ***)[*]: {
  style: {
    font-size: 12
    stroke-width: 2
  }
}