vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: {
  shape: text
  label: |md
    # 1M Entity Benchmark Timeline
    **Hardware:** Intel® Core™ i9-12900K | **Memory:** DDR5-4800 (Dual Channel)
    **Instruction Set:** AVX-512 enabled for batch ops
    *Target: 1,000,000 Entity Operations within 100ms Frame Budget*
  |
  near: top-center
  style: {
    stroke-width: 0
    font-size: 18
  }
}

direction: right

# --- GLOBAL TIME AXIS ---
time_axis: {
  grid-columns: 5
  grid-gap: 50
  
  t0: {
    label: "0ms\n[T0: INIT]"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 4
      bold: true
    }
  }
  t25: {
    label: "25ms\n[Q1: WARMUP]"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
  }
  t50: {
    label: "50ms\n[T50: CREATION DONE]"
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 4
      bold: true
    }
  }
  t75: {
    label: "75ms\n[Q3: GC/RECLAIM]"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
  }
  t100: {
    label: "100ms\n[T100: LIMIT]"
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 4
      bold: true
    }
  }
}

# --- PHASE 1: CREATION ---
phase_create: {
  label: "PHASE 1: CREATE 1M ENTITIES (0ms -> 50ms)"
  direction: down
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 2
  }

  create_ops: {
    label: |rust
      // O(N) Entity Creation
      // 1. Check free_list (Empty)
      // 2. Expand generations Vec
      // 3. Return Entity { id, gen }
      for _ in 0..1_000_000 {
          world.create_entity();
      }
    |
    style: {
      fill: "#FDFDFD"
      stroke: "#388E3C"
    }
  }

  generations_growth: {
    label: "Generations Store [u16; 1M] Layout"
    direction: right
    style.fill: "#E1BEE7"
    
    m0: "0x0000 | Gen [0..1k] | 2 KB" { 
      style.fill: "#F3E5F5" 
    }
    m1: "0x0800 | Gen [1k..16k] | 30 KB" { 
      style.fill: "#E1BEE7" 
    }
    m2: "0x8000 | Gen [16k..262k] | 480 KB" { 
      style.fill: "#CE93D8" 
    }
    m3: "0x80000 | Gen [262k..1M] | 1.5 MB" { 
      style: {
        fill: "#7B1FA2"
        font-color: white
        bold: true
      }
    }
    m0 -> m1 -> m2 -> m3: "Geometric Realloc (x2)" {
      style.stroke-dash: 3
      style.stroke: "#7B1FA2"
    }
  }

  free_list_state: {
    label: "free_list: Vec<usize>\nLen: 0 | Cap: 0\n[NO REUSE PHASE]"
    style.fill: "#B2DFDB"
    style.stroke: "#00897B"
  }
}

# --- PHASE 2: DESTRUCTION ---
phase_destroy: {
  label: "PHASE 2: DESTROY 1M ENTITIES (50ms -> 100ms)"
  direction: down
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
    stroke-width: 2
  }

  destroy_ops: {
    label: |rust
      // O(N) Entity Destruction
      // 1. Fetch Generation pointer
      // 2. wrapping_add(1) to Generation
      // 3. push ID to LIFO free_list
      for entity in entities {
          world.destroy_entity(entity);
      }
    |
    style: {
      fill: "#FDFDFD"
      stroke: "#C62828"
    }
  }

  generations_incr: {
    label: "Generation Word Update (Atomic)"
    direction: right
    style.fill: "#E1BEE7"
    
    gen_before: "0x0: [0x0001] (Gen 1)" { 
      style.fill: "#F3E5F5" 
    }
    gen_after: "0x0: [0x0002] (Gen 2)\n[DIRTY CACHE LINE]" {
      style: {
        fill: "#CE93D8"
        bold: true
      }
    }
    gen_before -> gen_after: "CPU WRITE (STORE)" {
      style.stroke: "#7B1FA2"
      style.stroke-width: 3
    }
  }

  free_list_fill: {
    label: "free_list [8MB Stack Footprint]"
    direction: right
    style.fill: "#B2DFDB"
    
    f0: "0x0 | Head (ID 999,999)" { 
      style.fill: "#E0F2F1" 
    }
    f1: "0x200k | Chunk A" { 
      style.fill: "#B2DFDB" 
    }
    f2: "0x400k | Chunk B" { 
      style.fill: "#80CBC4" 
    }
    f3: "0x7A1k | LIFO BASE [FULL]" {
      style: {
        fill: "#00897B"
        font-color: white
        bold: true
      }
    }
    f0 -> f1 -> f2 -> f3: "Sequential Push" {
      style.stroke: "#00695C"
      style.stroke-width: 2
    }
  }
}

# --- ANNOTATIONS ---

create_stats: {
  label: |md
    ### Create Performance
    - **Observed:** 12.4ms
    - **Instruction Density:** ~12 cycles/op
    - **Cache Misses:** L1: 0.2%, L3: 0.01%
    - **Page Faults:** 256 (Soft)
  |
  near: phase_create
  style: {
    fill: white
    stroke: "#388E3C"
    border-radius: 4
  }
}

destroy_stats: {
  label: |md
    ### Destroy Performance
    - **Observed:** 14.8ms
    - **Instruction Density:** ~18 cycles/op
    - **Write Stall:** 4.2% (Bus Lock)
    - **Memory BW:** 3.4 GB/s
  |
  near: phase_destroy
  style: {
    fill: white
    stroke: "#C62828"
    border-radius: 4
  }
}

# --- TIMELINE SEQUENCING ---
time_axis.t0 -> phase_create: "Start Creation"
phase_create -> time_axis.t50: "Allocation Complete"
time_axis.t50 -> phase_destroy: "Begin Reclamation"
phase_destroy -> time_axis.t100: "Deadline"

# --- SUMMARY & PERFORMANCE REPORTING ---
memory_summary: {
  label: "Final Memory State"
  grid-columns: 3
  grid-gap: 20
  near: bottom-center
  
  generations_final: "Generations Store\n[2.0 MB]\nu16 * 1,000,000" {
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
  }
  freelist_final: "Free List Stack\n[8.0 MB]\nusize * 1,000,000" {
    style.fill: "#B2DFDB"
    style.stroke: "#00897B"
  }
  total_mem: "TOTAL FOOTPRINT\n10.48 MB" {
    style: {
      fill: "#FFF9C4"
      bold: true
      double-border: true
      stroke: "#FBC02D"
    }
  }
}

performance_gate: {
  label: |md
    ### ✓ BENCHMARK PASS
    **Frame Budget: 100ms**
    **Total Usage: 27.2ms**

    | Task      | Duration | Throughput  |
    |-----------|----------|-------------|
    | Create    | 12.4ms   | 80.6M op/s  |
    | Destroy   | 14.8ms   | 67.5M op/s  |
    | Overhead  | 0.0ms    | N/A         |
  |
  near: bottom-right
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
    border-radius: 8
    shadow: true
  }
}

warning_zone: {
  label: |md
    ### ⚠️ SYSTEM MARGINS
    **75ms - 100ms**
    - High Context Swapping
    - Large Page Fault Overhead
  |
  near: bottom-left
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    border-radius: 8
  }
}

fail_zone: {
  label: |md
    ### ✗ FAILURE STATE
    **Time > 100ms**
    - Frame Spike Detected
    - Swap space thrashing
  |
  near: center-right
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    border-radius: 8
    bold: true
  }
}