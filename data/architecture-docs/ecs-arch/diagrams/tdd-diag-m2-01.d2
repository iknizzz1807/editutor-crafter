vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SparseSet Three-Array Structure
  Entity index → Sparse array → Dense index → Component
| {near: top-center}
direction: right
# === ENTITY INDEX COLUMN ===
entity_indices: {
  label: "Entity Indices"
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  idx0: "0" {style.fill: "#FFE4B5"}
  idx1: "1" {style.fill: "#FFE4B5"}
  idx2: "2" {style.fill: "#FFE4B5"}
  idx3: "3" {style.fill: "#FFE4B5"}
  idx4: "4" {style.fill: "#FFE4B5"}
  idx5: "5" {style.fill: "#FFE4B5"}
  idx6: "..." {shape: text; style.fill: transparent}
}
# === SPARSE ARRAY ===
sparse_array: {
  label: "sparse: Vec<usize>"
  style.fill: "#B5AFF6"
  style.stroke: "#6B5B95"
  sp0: "0" {
    style.fill: "#C7F1FF"
    tooltip: "Entity 0 → dense[0]"
  }
  sp1: "EMPTY" {
    style.fill: "#FFE4E4"
    style.stroke-dash: 3
    tooltip: "Entity 1 has no component"
  }
  sp2: "1" {
    style.fill: "#C7F1FF"
    tooltip: "Entity 2 → dense[1]"
  }
  sp3: "EMPTY" {
    style.fill: "#FFE4E4"
    style.stroke-dash: 3
  }
  sp4: "EMPTY" {
    style.fill: "#FFE4E4"
    style.stroke-dash: 3
  }
  sp5: "2" {
    style.fill: "#C7F1FF"
    tooltip: "Entity 5 → dense[2]"
  }
  sp6: "..." {shape: text; style.fill: transparent}
}
# === DENSE INDEX COLUMN ===
dense_indices: {
  label: "Dense Indices"
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  di0: "0" {style.fill: "#ACE1AF"}
  di1: "1" {style.fill: "#ACE1AF"}
  di2: "2" {style.fill: "#ACE1AF"}
}
# === DENSE COMPONENT ARRAY ===
dense_array: {
  label: "dense: Vec<T>"
  style.fill: "#88DCF7"
  style.stroke: "#2E8B8B"
  comp0: |md
    Position
    x: 1.0
    y: 2.0
  | {style.fill: "#E0FFFF"}
  comp1: |md
    Position
    x: 5.0
    y: 6.0
  | {style.fill: "#E0FFFF"}
  comp2: |md
    Position
    x: 9.0
    y: 10.0
  | {style.fill: "#E0FFFF"}
}
# === ENTITIES ARRAY (PARALLEL TO DENSE) ===
entities_array: {
  label: "entities: Vec<Entity>"
  style.fill: "#F0E68C"
  style.stroke: "#B8860B"
  ent0: "Entity(0, gen=1)" {tooltip: "Same row as dense[0]"}
  ent1: "Entity(2, gen=0)" {tooltip: "Same row as dense[1]"}
  ent2: "Entity(5, gen=0)" {tooltip: "Same row as dense[2]"}
}
# === CONNECTIONS: Entity Index → Sparse ===
entity_indices.idx0 -> sparse_array.sp0: "lookup" {
  style.stroke: "#6B5B95"
  style.stroke-width: 2
}
entity_indices.idx2 -> sparse_array.sp2 {
  style.stroke: "#6B5B95"
  style.stroke-width: 2
}
entity_indices.idx5 -> sparse_array.sp5 {
  style.stroke: "#6B5B95"
  style.stroke-width: 2
}
# === CONNECTIONS: Sparse → Dense Index ===
sparse_array.sp0 -> dense_indices.di0: "dense_idx" {
  style.stroke: "#2E8B8B"
  style.stroke-width: 2
  style.animated: true
}
sparse_array.sp2 -> dense_indices.di1: "dense_idx" {
  style.stroke: "#2E8B8B"
  style.stroke-width: 2
  style.animated: true
}
sparse_array.sp5 -> dense_indices.di2: "dense_idx" {
  style.stroke: "#2E8B8B"
  style.stroke-width: 2
  style.animated: true
}
# === CONNECTIONS: Dense Index → Component ===
dense_indices.di0 -> dense_array.comp0 {
  style.stroke: "#228B22"
  style.stroke-width: 2
}
dense_indices.di1 -> dense_array.comp1 {
  style.stroke: "#228B22"
  style.stroke-width: 2
}
dense_indices.di2 -> dense_array.comp2 {
  style.stroke: "#228B22"
  style.stroke-width: 2
}
# === PARALLEL ARRAYS CONNECTION ===
dense_array.comp0 -> entities_array.ent0: "parallel" {
  style.stroke: "#B8860B"
  style.stroke-dash: 5
  style.stroke-width: 1
}
dense_array.comp1 -> entities_array.ent1: "parallel" {
  style.stroke: "#B8860B"
  style.stroke-dash: 5
  style.stroke-width: 1
}
dense_array.comp2 -> entities_array.ent2: "parallel" {
  style.stroke: "#B8860B"
  style.stroke-dash: 5
  style.stroke-width: 1
}
# === LEGEND ===
legend: {
  label: "Legend"
  near: bottom-center
  style.fill: "#F5F5F5"
  style.stroke: "#999999"
  style.border-radius: 8
  active: "Active mapping" {
    style.fill: "#C7F1FF"
  }
  empty: "EMPTY (no component)" {
    style.fill: "#FFE4E4"
    style.stroke-dash: 3
  }
  component: "Component data" {
    style.fill: "#E0FFFF"
  }
}
# === INVARIANT NOTES ===
invariants: |md
  **Invariants:**
  - `sparse[i] == EMPTY` ⟺ Entity i has no component
  - `sparse[i] != EMPTY` ⟹ `dense[sparse[i]]` is Entity i's component
  - `dense.len() == entities.len()` (always)
  - `entities[j]` and `dense[j]` belong to the same entity
| {
  near: bottom-right
  shape: text
  style.font-size: 14
}