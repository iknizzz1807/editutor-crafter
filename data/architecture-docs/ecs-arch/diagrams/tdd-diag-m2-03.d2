vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |'md
  # SparseSet Insert Operation Algorithm
  ## Intel-Grade Technical Specification: O(1) Amortized Component Insertion
'| {
  near: top-center
}

# -----------------------------------------------------------------------------
# Legend & Metadata
# -----------------------------------------------------------------------------
legend: {
  near: top-right
  shape: package
  check: decision {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#F57C00"
  }
  action: operation {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
  data_store: memory {
    shape: cylinder
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  legend_text: |'md
    ### Legend
    - **Decision**: Logic branch
    - **Operation**: Mutation/Action
    - **Memory**: Data structure state
  '|
}

# -----------------------------------------------------------------------------
# Input Parameters
# -----------------------------------------------------------------------------
input: {
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  label: |'md
    **INPUT ARGUMENTS**
    `fn insert(entity: Entity, component: T)`
    - `entity`: `{ index: u32, generation: u32 }`
    - `component`: `T` (Size: `sizeof(T)`)
  '|
}

# -----------------------------------------------------------------------------
# Algorithm Flow Steps
# -----------------------------------------------------------------------------
flow: {
  step1: {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    label: |'md
      **[01] Extract Index**
      `let idx = entity.index() as usize;`
      *Complexity: O(1)*
    '|
  }

  step2: {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    label: |'md
      **[02] Bounds Check / Resize**
      `if idx >= sparse.len() {`
      `  sparse.resize(idx + 1, EMPTY);`
      `}`
      *Amortized: O(1) (Resize: O(N))*
    '|
  }

  decision1: {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#F57C00"
    label: |'md
      **Is `sparse[idx]` 
      equal to `EMPTY`?**
    '|
  }

  branch_new: {
    label: "NEW COMPONENT PATH (Insert)"
    style.stroke: "#1565C0"
    style.stroke-dash: 0

    step3a: {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#1565C0"
      label: |'md
        **[03a] Allocation**
        `let d_idx = dense.len();`
        Next available dense slot.
      '|
    }

    step4a: {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#1565C0"
      label: |'md
        **[04a] Link Sparse**
        `sparse[idx] = d_idx;`
        Map entity to dense storage.
      '|
    }

    step5a: {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#1565C0"
      label: |'md
        **[05a] Push Data**
        `dense.push(component);`
        `entities.push(entity);`
      '|
    }
  }

  branch_replace: {
    label: "REPLACE PATH (Update)"
    style.stroke: "#C62828"

    step3b: {
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      label: |'md
        **[03b] Lookup**
        `let d_idx = sparse[idx];`
        Retrieve existing index.
      '|
    }

    step4b: {
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      label: |'md
        **[04b] Overwrite**
        `dense[d_idx] = component;`
        In-place update.
      '|
    }
  }
}

# -----------------------------------------------------------------------------
# Memory Layout Visualization
# -----------------------------------------------------------------------------
memory_viz: {
  label: "Memory State Post-Condition (Intel Manual Layout)"
  
  sparse_mem: {
    label: "Sparse Array (Entity Registry)"
    grid-columns: 8
    grid-gap: 0
    
    h0: "Idx" {style.fill: "#CFD8DC"}
    h1: "0" {style.fill: "#CFD8DC"}
    h2: "1" {style.fill: "#CFD8DC"}
    h3: "2" {style.fill: "#CFD8DC"}
    h4: "3" {style.fill: "#CFD8DC"}
    h5: "4" {style.fill: "#CFD8DC"}
    h6: "5" {style.fill: "#CFD8DC"}
    h7: "..." {style.fill: "#CFD8DC"}

    v0: "Val" {style.fill: "#ECEFF1"}
    v1: "0" {style.fill: "#E3F2FD"}
    v2: "N/A" {style.fill: "#FFCDD2"}
    v3: "1" {style.fill: "#E3F2FD"}
    v4: "N/A" {style.fill: "#FFCDD2"}
    v5: "N/A" {style.fill: "#FFCDD2"}
    v6: "2" {style.fill: "#C8E6C9"; style.bold: true; style.stroke-width: 3}
    v7: "..." {style.fill: "#ECEFF1"}
  }

  dense_mem: {
    label: "Dense Storage (Packed Data)"
    grid-columns: 4
    grid-gap: 0
    
    dh0: "Dense Idx" {style.fill: "#CFD8DC"}
    dh1: "0" {style.fill: "#CFD8DC"}
    dh2: "1" {style.fill: "#CFD8DC"}
    dh3: "2 (New)" {style.fill: "#C8E6C9"}

    dv0: "Comp<T>" {style.fill: "#ECEFF1"}
    dv1: "Data₀" {style.fill: "#E3F2FD"}
    dv2: "Data₁" {style.fill: "#E3F2FD"}
    dv3: "Data₂" {style.fill: "#C8E6C9"; style.bold: true}

    de0: "Entity" {style.fill: "#ECEFF1"}
    de1: "E(0)" {style.fill: "#E3F2FD"}
    de2: "E(2)" {style.fill: "#E3F2FD"}
    de3: "E(5)" {style.fill: "#C8E6C9"; style.bold: true}
  }

  annotation: |'md
    **Visualization Details:**
    1. Entity(5) index used to probe `sparse[5]`.
    2. Value `2` at `sparse[5]` points to `dense[2]`.
    3. `entities[2]` mirrors back to `E(5)` for validation.
  '|
}

# -----------------------------------------------------------------------------
# Analysis Tables (FIXED BLOCK STRINGS)
# -----------------------------------------------------------------------------
complexity: {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  label: |'md
    ### COMPLEXITY ANALYSIS
    | Operation | Time Complexity | Space Complexity |
    | :--- | :--- | :--- |
    | Sparse Access | O(1) | O(1) |
    | Sparse Resize | O(N) Amortized | O(max_id) |
    | Dense Push | O(1) Amortized | O(1) |
    | **Total Insert** | **O(1) Amortized** | **O(1)** |
  '|
}

invariants: {
  shape: rectangle
  style.fill: "#FCE4EC"
  style.stroke: "#AD1457"
  label: |'md
    ### SYSTEM INVARIANTS
    1. `dense.len() == entities.len()`
    2. `idx < sparse.len() && sparse[idx] != EMPTY`
    3. `entities[sparse[idx]].index() == idx`
  '|
}

# -----------------------------------------------------------------------------
# Edge Connections
# -----------------------------------------------------------------------------
input -> flow.step1
flow.step1 -> flow.step2
flow.step2 -> flow.decision1

flow.decision1 -> flow.branch_new.step3a: "YES: EMPTY (Insert New)" {
  style.stroke: "#1565C0"
  style.stroke-width: 3
}

flow.decision1 -> flow.branch_replace.step3b: "NO: (Overwrite)" {
  style.stroke: "#C62828"
  style.stroke-dash: 5
}

# New path internal
flow.branch_new.step3a -> flow.branch_new.step4a
flow.branch_new.step4a -> flow.branch_new.step5a
flow.branch_new.step5a -> memory_viz: "Updates Memory"

# Replace path internal
flow.branch_replace.step3b -> flow.branch_replace.step4b
flow.branch_replace.step4b -> memory_viz: "Updates Value"

# Post-conditions
memory_viz -> complexity
memory_viz -> invariants