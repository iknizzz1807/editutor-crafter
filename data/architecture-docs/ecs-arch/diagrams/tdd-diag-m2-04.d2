vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

direction: right

title: |md
  # Swap-and-Pop Remove Algorithm
  ### Removing element **B** from dense array while maintaining contiguity
  ---
  **Requirement**: $O(1)$ removal from an Unordered Component Pool (ECS).
| {
  near: top-center
}

# === CLASSES ===
classes: {
  mem_header: { 
    style: {
      fill: "#8e44ad"
      font-color: white
      bold: true
    }
  }
  data_field: { 
    style: {
      fill: "#3498db"
      font-color: white
    }
  }
  target_field: { 
    style: {
      fill: "#e74c3c"
      bold: true
      font-color: white
    }
  }
  relocated_field: { 
    style: {
      fill: "#e67e22"
      bold: true
      font-color: white
    }
  }
  pointer_line: { 
    style: {
      stroke: "#e67e22"
      stroke-width: 2
      animated: true
    }
  }
  step_box: { 
    style: {
      stroke-width: 4
      border-radius: 10
    }
  }
}

# === STEP 1: BEFORE ===
before: {
  class: step_box
  label: "STEP 1: Identify Target (Len=4)"
  style.fill: "#fdfefe"
  style.stroke: "#8e44ad"

  sparse: {
    label: "Sparse Array (EntityID -> Index)"
    class: mem_header
    s0: "sparse[0] = 0" { class: data_field }
    s1: "sparse[1] = 1 (TARGET)" { class: target_field }
    s2: "sparse[2] = 2" { class: data_field }
    s3: "sparse[3] = 3 (TAIL)" { class: data_field }
  }

  dense: {
    label: "Dense Array (Component Data)"
    class: mem_header
    # Offset | Value | Size
    d0: "0x00 | Comp A | 8B" { class: data_field }
    d1: "0x08 | Comp B | 8B" { class: target_field }
    d2: "0x10 | Comp C | 8B" { class: data_field }
    d3: "0x18 | Comp D | 8B" { class: data_field }
  }

  entities: {
    label: "Entities (Back-refs)"
    class: mem_header
    e0: "0x00 | Ent A | 4B" { class: data_field }
    e1: "0x04 | Ent B | 4B" { class: target_field }
    e2: "0x08 | Ent C | 4B" { class: data_field }
    e3: "0x0C | Ent D | 4B" { class: data_field }
  }

  note: |md
    **Current State**:
    - `sparse[1]` maps to dense index **1**.
    - Target: **Comp B** at index 1.
    - Tail: **Comp D** at index 3.
  | { 
    shape: rectangle
    style.fill: "#fff9c4" 
  }
}

# === STEP 2: SWAP ===
swap: {
  class: step_box
  label: "STEP 2: Swap Target with Tail"
  style.fill: "#fef9e7"
  style.stroke: "#f39c12"

  dense: {
    label: "Dense Array (Swapped)"
    class: mem_header
    d0: "0x00 | Comp A | 8B" { class: data_field }
    d1: "0x08 | **Comp D** | 8B" { class: relocated_field }
    d2: "0x10 | Comp C | 8B" { class: data_field }
    d3: "0x18 | **Comp B** | 8B" { class: target_field; style.stroke-dash: 3 }
  }

  entities: {
    label: "Entities (Swapped)"
    class: mem_header
    e0: "0x00 | Ent A | 4B" { class: data_field }
    e1: "0x04 | **Ent D** | 4B" { class: relocated_field }
    e2: "0x08 | Ent C | 4B" { class: data_field }
    e3: "0x0C | **Ent B** | 4B" { class: target_field; style.stroke-dash: 3 }
  }

  note: |md
    **Mechanics**:
    - `dense.swap(1, 3)`
    - `entities.swap(1, 3)`
    - B is now vulnerable at tail.
    - D is safe in active range.
  | { 
    shape: rectangle
    style.fill: "#fff9c4" 
  }
}

# === STEP 3: REPAIR ===
repair: {
  class: step_box
  label: "STEP 3: Repair Sparse Pointer"
  style.fill: "#eaf2f8"
  style.stroke: "#2980b9"

  sparse: {
    label: "Sparse Array (Repaired)"
    class: mem_header
    s0: "sparse[0] = 0" { class: data_field }
    s1: "sparse[1] = EMPTY" { class: target_field }
    s2: "sparse[2] = 2" { class: data_field }
    s3: "**sparse[3] = 1**" { class: relocated_field; style.double-border: true }
  }

  note: |md
    **Pointer Safety**:
    - `sparse[Ent B]` set to null.
    - `sparse[Ent D]` set to **1** (its new index).
    - This maintains O(1) lookups.
  | { 
    shape: rectangle
    style.fill: "#fff9c4" 
  }
}

# === STEP 4: FINAL ===
final: {
  class: step_box
  label: "STEP 4: Pop and Cleanup (Len=3)"
  style.fill: "#e9f7ef"
  style.stroke: "#27ae60"

  dense: {
    label: "Dense Array (Final)"
    class: mem_header
    d0: "0x00 | Comp A | 8B" { class: data_field }
    d1: "0x08 | Comp D | 8B" { class: data_field }
    d2: "0x10 | Comp C | 8B" { class: data_field }
    # Popped slot
    d3: "0x18 | [FREE] | 8B" { 
      style: {
        fill: "#ecf0f1"
        font-color: "#bdc3c7"
      }
    }
  }

  entities: {
    label: "Entities (Final)"
    class: mem_header
    e0: "0x00 | Ent A | 4B" { class: data_field }
    e1: "0x04 | Ent D | 4B" { class: data_field }
    e2: "0x08 | Ent C | 4B" { class: data_field }
    e3: "0x0C | [FREE] | 4B" { 
      style: {
        fill: "#ecf0f1"
        font-color: "#bdc3c7"
      }
    }
  }
}

# === CONNECTIONS & FLOW ===

before.dense.d3 -> swap.dense.d1: "1. Relocate Tail" { class: pointer_line }
before.dense.d1 -> swap.dense.d3: "2. Park Target" { class: pointer_line; style.stroke: "#e74c3c" }

before -> swap: "SWAP PHASE" { style.stroke-width: 8; style.stroke: "#f39c12" }
swap -> repair: "RE-INDEXING" { style.stroke-width: 8; style.stroke: "#2980b9" }
repair -> final: "ARRAY SHRINK" { style.stroke-width: 8; style.stroke: "#27ae60" }

# === CODE BLOCK ===
algorithm_block: |md
  ## Rust Reference Implementation
  rust
  fn remove(&mut self, entity: Entity) -> Option&lt;T&gt; {
      let dense_idx = self.sparse[entity.id()];
      if dense_idx == EMPTY { return None; }
      
      // 1. Invalidate sparse target
      self.sparse[entity.id()] = EMPTY;
      let last_idx = self.dense.len() - 1;
      
      if dense_idx != last_idx {
          // 2. Move last element to hole
          self.dense.swap(dense_idx, last_idx);
          self.entities.swap(dense_idx, last_idx);
          
          // 3. Fix back-pointer for moved element
          let moved_entity = self.entities[dense_idx];
          self.sparse[moved_entity.id()] = dense_idx;
      }
      
      // 4. Shrink arrays
      self.entities.pop();
      self.dense.pop() // Returns Option&lt;T&gt;
  }
  
| {
  near: top-left
  shape: rectangle
  style: {
    fill: "#fdfefe"
    stroke: "#34495e"
  }
}

# === LEGEND ===
legend: {
  near: bottom-right
  class: mem_header
  label: "Memory Map Legend"
  
  l1: "Target (Removal)" { class: target_field }
  l2: "Relocated (Tail)" { class: relocated_field }
  l3: "Standard Record" { class: data_field }
  l4: "Deallocated Memory" { 
    style: {
      fill: "#ecf0f1"
      stroke: "#bdc3c7"
    }
  }
}