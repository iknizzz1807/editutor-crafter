direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- STYLING CLASSES ---
classes: {
  memory_header: {
    style: {
      fill: "#6b46c1"
      font-color: white
      bold: true
      stroke-width: 2
    }
  }
  data_node: {
    style: {
      fill: "#3182ce"
      font-color: white
      border-radius: 4
      stroke: "#2a4365"
    }
  }
  empty_node: {
    style: {
      fill: "#e2e8f0"
      font-color: "#718096"
      stroke-dash: 3
    }
  }
  highlight_node: {
    style: {
      fill: "#38a169"
      font-color: white
      bold: true
      stroke: "#22543d"
      stroke-width: 4
      shadow: true
    }
  }
  pointer_edge: {
    style: {
      stroke: "#ed8936"
      stroke-width: 3
      animated: true
    }
  }
}

# --- DIAGRAM TITLE ---
title: {
  shape: text
  label: ||md
    # Sparse Array Growth: Entity Index 999,999
    ### Before: sparse.len = 100 | After: sparse.len = 1,000,000
    **Memory Cost: ~8.0 MB (usize = 64-bit)**
  ||
  style.stroke-width: 0
  style.fill: transparent
}

# --- STEP 1: INITIAL STATE ---
step1: {
  label: "STEP 1: INITIAL STATE (OOB CHECK)"

  before_meta: {
    shape: rectangle
    label: |md
      ### Memory Invariants
      - **Base Address**: `0x7000`
      - **Current Length**: 100 elements
      "- **Target Access**": `sparse[999_999]`
      - **Condition**: `index >= len` (Reallocation Required)
    |
  }

  sparse_container: {
    label: "Sparse Array Heap Block (Size: 800B)"
    class: memory_header

    s0: "Offset +0x00: [0]" { class: data_node }
    s1: "Offset +0x08: [1]" { class: data_node }
    s_dots: "..." { shape: text }
    s99: "Offset +0x318: [99]" { class: data_node }

    s0 -> s1 -> s_dots -> s99
  }

  check_logic: {
    shape: diamond
    label: "999,999 >= 100?"
    style: {
      fill: "#fff5f5"
      stroke: "#c53030"
      font-color: "#c53030"
      bold: true
    }
  }

  sparse_container -> check_logic: " Bounds Check"
}

# --- STEP 2: ALLOCATION OPERATION ---
step2: {
  label: "STEP 2: HEAP REALLOCATION"

  op_code: {
    shape: code
    label: |rust
      // Growth Logic Triggered in ECS Manager
      let target_idx = 999_999;
      
      if target_idx >= sparse.len() {
          // Growth Strategy: Exact Resize
          // New Memory = (999,999 + 1) * sizeof(usize)
          sparse.resize(target_idx + 1, usize::MAX);
      }
    |
    style: {
      fill: "#fefcbf"
      stroke: "#b7791f"
      font-size: 14
    }
  }

  allocation_stats: {
    label: ||md
      ### Allocation Delta
      | Metric | Initial | Post-Growth |
      | :--- | :--- | :--- |
      | **Elements** | 100 | 1,000,000 |
      | **Capacity** | 128 | 1,048,576 (Next Pow2) |
      | **Memory** | 0.8 KB | **8,388,608 Bytes** |
      | **Init Val** | N/A | `0xFFFFFFFFFFFFFFFF` |
    ||
    style.fill: "#edf2f7"
  }
}

# --- STEP 3: FINAL STATE ---
step3: {
  label: "STEP 3: POST-GROWTH INSERTION"

  after_meta: {
    shape: rectangle
    label: |md
      ### Resulting Layout
      - **Sparse[999,999]** set to **0** (Dense Index)
      - **Component Data** allocated in Dense Array
      - **Entity ID** stable reference established
    |
  }

  sparse_after: {
    label: "Expanded Sparse Array (8MB Block)"
    class: memory_header

    sa0: "0x00: [0]" { class: data_node }
    sa_dots: "..." { shape: text }
    sa99: "0x318: [99]" { class: data_node }
    sa_empty: "--- Gap: 999,899 Null Slots ---" { class: empty_node }
    sa_target: "0x7A1200: [999,999] = 0" { class: highlight_node }

    sa0 -> sa_dots -> sa99 -> sa_empty -> sa_target
  }

  dense_array: {
    label: "Dense Array (Packed)"
    class: memory_header
    d0: "Dense[0]: PositionComponent { x: 10, y: 20 }" {
      style: {
        fill: "#bee3f8"
        font-color: "#2b6cb0"
        stroke: "#2b6cb0"
      }
    }
  }

  entities_metadata: {
    label: "Entity Registry"
    class: memory_header
    e0: "Entity(ID=999999, Gen=1)" {
      style: {
        fill: "#e9d8fd"
        font-color: "#553c9a"
        stroke: "#553c9a"
      }
    }
  }

  # Connections for mapping
  sparse_after.sa_target -> dense_array.d0: "maps to" {
    class: pointer_edge
    source-arrowhead: circle
  }
  
  entities_metadata.e0 -> sparse_after.sa_target: "O(1) Access" {
    style: {
      stroke-dash: 5
      stroke: "#805ad5"
    }
    target-arrowhead: {
      shape: arrow
    }
  }
}

# --- SEQUENCE FLOW ---
step1 -> step2: "1. Index Out of Bounds" {
  style: {
    stroke: "#3182ce"
    stroke-width: 4
    animated: true
  }
}

step2 -> step3: "2. Memory Commit" {
  style: {
    stroke: "#3182ce"
    stroke-width: 4
    animated: true
  }
}

# --- SUMMARY & FOOTER ---
summary_box: {
  label: |md
    ## Implementation Architecture Note
    This Sparse Set implementation prioritizes **Temporal Performance (O(1))** over **Spatial Efficiency**. 
    - **Cache Boundary**: Offset `0x00` represents a 64-byte cache line start.
    - **Optimization**: To reduce the 8MB overhead, consider a `PageSparseSet` (Chunked Sparse Array).
  |
  style: {
    fill: "#f0fff4"
    stroke: "#38a169"
    stroke-width: 2
  }
}

legend: {
  
  l1: "Existing Data Node" { class: data_node }
  l2: "Unallocated/Null Space" { class: empty_node }
  l3: "Active Target Node" { class: highlight_node }
}

# --- CACHE LINE DETAIL ---
step3.sparse_after.sa0.tooltip: "Physical Memory Address: 0x7FFF0000"
step3.sparse_after.sa0.style.double-border: true