vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    registry-bg: "#E8E8E8"
    storage-bg: "#F5F5DC"
    position-bg: "#E6F3FF"
    velocity-bg: "#FFF0E6"
    health-bg: "#E6FFE6"
    generic-bg: "#F0F0F0"
    arrow-color: "#666666"
  }
}
title: |md
  # Component Registry Architecture
  ## Type-Erased Storage with Per-Type Sparse Sets
| {near: top-center}
direction: right
ComponentRegistry: {
  label: "ComponentRegistry\n\nHashMap<TypeId,\nBox<dyn ComponentStorage>>"
  style: {
    fill: ${colors.registry-bg}
    stroke: "#333333"
    stroke-width: 2
    font: mono
    font-size: 14
  }
}
storages: {
  label: ""
  PositionStorage: {
    label: "SparseSet<Position>\n\nsparse: Vec<usize>\ndense: Vec<Position>\nentities: Vec<Entity>"
    style: {
      fill: ${colors.position-bg}
      stroke: "#4A90D9"
      stroke-width: 2
    }
  }
  VelocityStorage: {
    label: "SparseSet<Velocity>\n\nsparse: Vec<usize>\ndense: Vec<Velocity>\nentities: Vec<Entity>"
    style: {
      fill: ${colors.velocity-bg}
      stroke: "#D98A4A"
      stroke-width: 2
    }
  }
  HealthStorage: {
    label: "SparseSet<Health>\n\nsparse: Vec<usize>\ndense: Vec<Health>\nentities: Vec<Entity>"
    style: {
      fill: ${colors.health-bg}
      stroke: "#4AD94A"
      stroke-width: 2
    }
  }
  GenericStorage: {
    label: "SparseSet<T>\n\n...more component\nstorage types..."
    style: {
      fill: ${colors.generic-bg}
      stroke: "#999999"
      stroke-dash: 3
    }
  }
}
ComponentRegistry -> storages.PositionStorage: "TypeId(Position)" {
  label: "TypeId::of::<Position>()\n→ SparseSet<Position>"
  style: {
    stroke: "#4A90D9"
    stroke-width: 2
  }
}
ComponentRegistry -> storages.VelocityStorage: "TypeId(Velocity)" {
  label: "TypeId::of::<Velocity>()\n→ SparseSet<Velocity>"
  style: {
    stroke: "#D98A4A"
    stroke-width: 2
  }
}
ComponentRegistry -> storages.HealthStorage: "TypeId(Health)" {
  label: "TypeId::of::<Health>()\n→ SparseSet<Health>"
  style: {
    stroke: "#4AD94A"
    stroke-width: 2
  }
}
ComponentRegistry -> storages.GenericStorage: "TypeId(T)" {
  label: "TypeId::of::<T>()\n→ SparseSet<T>"
  style: {
    stroke: "#999999"
    stroke-dash: 3
  }
}
legend: {
  near: bottom-center
  label: |md
    **Key Operations:**
    - `get_or_create::<T>()` → Returns `&mut SparseSet<T>` (creates if needed)
    - `get::<T>()` → Returns `Option<&SparseSet<T>>`
    - `remove_entity(entity)` → Removes entity from ALL storages
    **Type Erasure:**
    - `Box<dyn ComponentStorage>` hides concrete `SparseSet<T>` type
    - `TypeId` (64-bit hash) provides O(1) type lookup
    - Downcast via `as_any().downcast_ref::<SparseSet<T>>()`
  |
  style: {
    fill: "#FAFAFA"
    stroke: "#CCCCCC"
    font: mono
    font-size: 11
  }
}
ComponentStorageTrait: {
  near: top-right
  label: |md
    rust
    trait ComponentStorage: Any {
        fn as_any(&self) -> &dyn Any;
        fn as_any_mut(&mut self) -> &mut dyn Any;
        fn remove_entity(&mut self, entity: Entity);
        fn len(&self) -> usize;
        fn clear(&mut self);
    }
    
  |
  style: {
    fill: "#FFF8E7"
    stroke: "#B8860B"
    font: mono
    font-size: 10
  }
}
ComponentStorageTrait -> storages.PositionStorage: "impl for SparseSet<T>" {
  style: {
    stroke: "#B8860B"
    stroke-dash: 5
    stroke-width: 1
  }
}