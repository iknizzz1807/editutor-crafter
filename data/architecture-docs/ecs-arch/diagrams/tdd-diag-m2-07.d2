layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    trait-bg: "#F3E5F5"
    trait-border: "#7B1FA2"
    impl-bg: "#E3F2FD"
    impl-border: "#1976D2"
    registry-bg: "#FFF3E0"
    registry-border: "#F57C00"
    type-erasure: "#D84315"
    type-recovery: "#2E7D32"
    padding: "#ECEFF1"
    header-purple: "#6A1B9A"
    pointer-orange: "#EF6C00"
  }
}

title: |md
  # ComponentStorage Trait Boundary
  ### Type erasure at registry boundary with downcast recovery
| {near: top-center}

direction: right

classes: {
  trait-box: {
    style: {
      fill: ${colors.trait-bg}
      stroke: ${colors.trait-border}
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
  impl-box: {
    style: {
      fill: ${colors.impl-bg}
      stroke: ${colors.impl-border}
      stroke-width: 2
      border-radius: 4
    }
  }
  registry-box: {
    style: {
      fill: ${colors.registry-bg}
      stroke: ${colors.registry-border}
      stroke-width: 2
      border-radius: 8
    }
  }
  type-erasure-arrow: {
    style: {
      stroke: ${colors.type-erasure}
      stroke-width: 3
      stroke-dash: 5
      animated: true
    }
  }
  type-recovery-arrow: {
    style: {
      stroke: ${colors.type-recovery}
      stroke-width: 3
    }
  }
}

ComponentStorage: {
  class: trait-box
  label: "ComponentStorage\n(trait object)"
  
  memory_layout: {
    shape: sql_table
    label: "Fat Pointer Layout (16 bytes)"
    00: "data_ptr: *mut ()" {constraint: "8 bytes"; style.stroke: ${colors.pointer-orange}}
    08: "vtable_ptr: *const ()" {constraint: "8 bytes"; style.stroke: ${colors.pointer-orange}}
  }

  methods: {
    shape: class
    label: "Trait Interface"
    style.fill: ${colors.header-purple}
    style.font-color: white
    "+as_any()": "&dyn Any"
    "+as_any_mut()": "&mut dyn Any"
    "+remove_entity(e: Entity)": "void"
    "+len()": "usize"
  }
}

SparseSet_Position: {
  class: impl-box
  label: "SparseSet<Position>"
  
  layout: {
    shape: sql_table
    label: "Storage Internals"
    00: "sparse: Vec<usize>" {constraint: "24 bytes"}
    24: "dense: Vec<Position>" {constraint: "24 bytes"}
    48: "entities: Vec<Entity>" {constraint: "24 bytes"}
    72: "padding (cache alignment)" {style.fill: "${colors.padding}"; constraint: "8 bytes"}
    # 64B cache line boundary marker
    "-------------------------------------------------": "64B Cache Line Boundary" {style.stroke-dash: 5}
  }
}

SparseSet_Velocity: {
  class: impl-box
  label: "SparseSet<Velocity>"
  
  layout: {
    shape: sql_table
    label: "Storage Internals"
    00: "sparse: Vec<usize>" {constraint: "24 bytes"}
    24: "dense: Vec<Velocity>" {constraint: "24 bytes"}
    48: "entities: Vec<Entity>" {constraint: "24 bytes"}
  }
}

SparseSet_Health: {
  class: impl-box
  label: "SparseSet<Health>"
  
  layout: {
    shape: sql_table
    label: "Storage Internals"
    00: "sparse: Vec<usize>" {constraint: "24 bytes"}
    24: "dense: Vec<Health>" {constraint: "24 bytes"}
    48: "entities: Vec<Entity>" {constraint: "24 bytes"}
  }
}

ComponentRegistry: {
  class: registry-box
  label: "ComponentRegistry"
  
  storage_map: {
    shape: class
    label: "Storage Map"
    style.fill: ${colors.registry-border}
    style.font-color: white
    storages: "HashMap<TypeId, Box<dyn ComponentStorage>>"
  }
  
  type_id_map: {
    shape: rectangle
    label: |md
      **TypeId Mapping Table**
      ---
      `TypeId::of::<Position>()` -> `StorageID_0`
      `TypeId::of::<Velocity>()` -> `StorageID_1`
      `TypeId::of::<Health>()`   -> `StorageID_2`
    |
  }
}

erasure_boundary: {
  label: "Type Erasure Boundary"
  shape: rectangle
  style: {
    fill: transparent
    stroke: ${colors.type-erasure}
    stroke-width: 4
    stroke-dash: 10
  }
}

SparseSet_Position -> ComponentStorage: "impl trait" {
  class: type-erasure-arrow
}
SparseSet_Velocity -> ComponentStorage: "impl trait" {
  class: type-erasure-arrow
}
SparseSet_Health -> ComponentStorage: "impl trait" {
  class: type-erasure-arrow
}

ComponentStorage -> ComponentRegistry: "stored as trait object" {
  style: {
    stroke: ${colors.registry-border}
    stroke-width: 2
  }
  target-arrowhead: diamond
}

type_recovery_flow: {
  label: "Type Recovery Sequence (Downcasting Flow)"
  shape: sequence_diagram
  
  caller: User Code {style.fill: "#E8F5E9"}
  registry: ComponentRegistry {style.fill: ${colors.registry-bg}}
  storage: dyn ComponentStorage {style.fill: ${colors.trait-bg}}
  concrete: "SparseSet<Position>" {style.fill: ${colors.impl-bg}}

  caller -> registry: "get_storage::<Position>()"
  registry -> storage: "lookup TypeId::of::<Position>()"
  registry <- storage: "&dyn ComponentStorage"
  
  lock: {
    registry -> storage: "as_any_mut()"
    storage -> storage: "vtable lookup (offset 8)"
    registry <- storage: "&mut dyn Any"
  }
  
  registry -> concrete: "downcast_mut::<SparseSet<Position>>()"
  registry <- concrete: "Some(&mut SparseSet<Position>)"
  caller <- registry: "Result<InternalStorageHandle>"
}

legend: {
  near: bottom-right
  shape: rectangle
  style: {
    fill: white
    stroke: "#666"
    border-radius: 4
  }
  label: |md
    ### Memory & Type Safety
    - **Type Erasure**: Concrete `SparseSet<T>` is coerced to `dyn ComponentStorage`.
    - **TypeId Security**: Map keys (TypeIDs) act as a compile-time proof of content.
    - **Safe Recovery**: Uses the `Any` trait's vtable to verify memory layout before downcasting.
    - **Alignment**: Trait objects consume 16 bytes (2 x 64-bit words) in the HashMap values.
  |
}

boundary_annotation: |rust
  // 1. Type erasure occurs here:
  // We box a concrete implementation into a trait object.
  let storage: Box<dyn ComponentStorage> = 
      Box::new(SparseSet::<Position>::new());

  // 2. Type recovery occurs here:
  // We use the 'Any' trait to perform a checked downcast via the vtable.
  let typed = storage.as_any_mut()
      .downcast_mut::<SparseSet<Position>>()
      .expect("Logic error: TypeId mismatch");
| {near: bottom-center}