layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: "ENTITY DESTRUCTION CASCADE - COMPONENT CLEANUP SEQUENCE" {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# --- PRIMARY LOGIC CONTAINER ---
DestructionLogic: {
  
  # --- THE SEQUENCE DIAGRAM ENGINE ---
  Sequence: {
    shape: sequence_diagram

    # Participant Definitions
    world: "World (Client Context)" {
      shape: person
      style.fill: "#E1F5FE"
    }

    entity_mgr: "EntityManager: ecs_core" {
      style.fill: "#E8F5E9"
    }

    registry: "ComponentRegistry: registry" {
      style.fill: "#FFF3E0"
    }

    storage_pos: "SparseSet<Position>: storage" {
      style.fill: "#E0F2F1"
    }

    storage_vel: "SparseSet<Velocity>: storage" {
      style.fill: "#E0F2F1"
    }

    storage_health: "SparseSet<Health>: storage" {
      style.fill: "#E0F2F1"
    }

    # --- PHASE 1: VALIDATION ---
    world -> entity_mgr: "▼ destroy_entity(entity_id: u64): bool"
    entity_mgr -> entity_mgr: "index = (entity_id >> 32) & 0xFFFFFFFF"
    entity_mgr -> entity_mgr: "current_gen = generations[index]"
    entity_mgr -> entity_mgr: "is_alive(entity_id)?"
    
    entity_mgr."ID VALIDATION: gen == current_gen ✓": {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        bold: true
      }
    }

    # --- PHASE 2: REGISTRY INVALIDATION ---
    entity_mgr -> entity_mgr: "generations[index] += 1"
    entity_mgr -> entity_mgr: "free_list.push(index)"
    entity_mgr -> entity_mgr: "total_entities -= 1"
    entity_mgr -> world: "▲ return true"

    # --- PHASE 3: CLEANUP CASCADE ---
    world -> registry: "▼ remove_all_components(entity_id: u64): void"
    
    registry."ITERATE: Registered Storage Sets": {
      style.fill: "#FFE0B2"
    }

    # Position Set Cleanup
    registry -> storage_pos: "▼ remove_entity(entity_id: u64): void"
    storage_pos -> storage_pos: "sparse[id] = 0xFFFFFFFF"
    storage_pos -> storage_pos: "swap_and_pop(): Position"
    storage_pos -> registry: "▲ ACK"
    storage_pos."POS_STORAGE: MEM_RELEASED": {
      style.fill: "#C8E6C9"
    }

    # Velocity Set Cleanup
    registry -> storage_vel: "▼ remove_entity(entity_id: u64): void"
    storage_vel -> storage_vel: "sparse[id] = 0xFFFFFFFF"
    storage_vel -> storage_vel: "swap_and_pop(): Velocity"
    storage_vel -> registry: "▲ ACK"
    storage_vel."VEL_STORAGE: MEM_RELEASED": {
      style.fill: "#C8E6C9"
    }

    # Health Set Cleanup
    registry -> storage_health: "▼ remove_entity(entity_id: u64): void"
    storage_health -> storage_health: "sparse[id] = 0xFFFFFFFF"
    storage_health -> storage_health: "swap_and_pop(): Health"
    storage_health -> registry: "▲ ACK"
    storage_health."HEALTH_STORAGE: MEM_RELEASED": {
      style.fill: "#C8E6C9"
    }

    registry -> world: "▲ cleanup_complete()"

    # --- PHASE 4: FINALIZATION ---
    world -> world: "reclaim_id(index)"
    
    world."CASCADE COMPLETE\n- Generation Incremented\n- All Sparse Indices Cleared\n- Dense Arrays Re-aligned": {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        stroke-width: 2
        double-border: true
      }
    }
  }

  # --- TECHNICAL ANNOTATIONS ---
  # Corrected syntax using block string delimiters that allow internal pipes
  technical_spec: ||md
### SWAP-AND-POP ALGORITHM (O(1))
Maintaining contiguous memory in Sparse Sets is critical for cache-friendly iteration (SIMD).

**Binary Layout & Operation:**
| Offset | Field | Size | Details |
| :--- | :--- | :--- | :--- |
| 0x00 | `dense_idx` | 4B | Index of the component in the data array |
| 0x04 | `generation| 4B | ABA protection against stale handles |

**Destruction Logic:**
1. **Swap**: Copy the *last* element in the dense array into the position of the deleted element.
2. **Remap**: Update the `sparse` index of the moved element to point to its new `dense` location.
3. **Pop**: Decrement the dense array length by 1.
4. **Result**: Array remains contiguous; no fragmentation (0% padding).
  || {
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    border-radius: 5
    font-size: 14
  }
}

  memory_integrity_note: ||md
### GENERATION RECLAMATION
Entity IDs are 64-bit:
- `32 bits`: Index (Pointer to generations array)
- `32 bits`: Generation (ABA counter)

*Invariant*: Handle is valid only if `handle.gen == generations[handle.index]`.
  || {
  style: {
    fill: "#E1F5FE"
    stroke: "#01579B"
    font-size: 12
  }
}

  # Metadata Legend
  legend: {
    green_box: "Success / Completion" {
      style.fill: "#C8E6C9"
    }
    orange_box: "Iterative Logic" {
      style.fill: "#FFE0B2"
    }
    blue_box: "External Context" {
      style.fill: "#E1F5FE"
    }
    
    grid-columns: 1
    grid-gap: 5
  }
}

# Global Style Overrides
***.style.font: mono
(*** -> ***)[*]: {
  style.stroke-width: 2
}