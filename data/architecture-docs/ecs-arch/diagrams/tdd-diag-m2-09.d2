vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    dense-fill: "#E8F4FD"
    dense-stroke: "#2E86AB"
    cache-fill: "#D4EDDA"
    cache-stroke: "#28A745"
    hashmap-fill: "#FFF3CD"
    hashmap-stroke: "#FFC107"
    pointer-fill: "#F8D7DA"
    pointer-stroke: "#DC3545"
    header-fill: "#E2D5F0"
    header-stroke: "#7B4BA8"
  }
}
title: |md
  # Iteration Memory Access Pattern
  ### Archetype Dense Array vs HashMap: Cache Efficiency Comparison
| {near: top-center}
direction: right
comparison: {
  grid-columns: 2
  grid-gap: 30
  dense_array: {
    label: "ARCHETYPE DENSE ARRAY\nSequential Access Pattern"
    style.fill: "${colors.dense-fill}"
    style.stroke: "${colors.dense-stroke}"
    style.stroke-width: 3
    header: |md
      **Cache-Friendly Traversal**
    | {
      style.fill: "${colors.header-fill}"
      style.stroke: "${colors.header-stroke}"
    }
    memory_layout: {
      label: "Memory Layout: Vec<Position>"
      style.fill: white
      style.stroke: "${colors.dense-stroke}"
      style.stroke-dash: 2
      cache_line_0: {
        label: "Cache Line 0 (64 bytes)"
        style.fill: "${colors.cache-fill}"
        style.stroke: "${colors.cache-stroke}"
        style.stroke-width: 2
        components_0: |md
          
          [0] Pos(1,2)  [1] Pos(3,4)  [2] Pos(5,6)  [3] Pos(7,8)
          ──────────────────────────────────────────────────────
          8 bytes      8 bytes       8 bytes       8 bytes
          ✓ USED       ✓ USED        ✓ USED        ✓ USED
          
        |
        components_0.shape: text
      }
      cache_line_1: {
        label: "Cache Line 1 (64 bytes)"
        style.fill: "${colors.cache-fill}"
        style.stroke: "${colors.cache-stroke}"
        style.stroke-width: 2
        components_1: |md
          
          [4] Pos(9,10) [5] Pos(11,12) [6] Pos(13,14) [7] Pos(15,16)
          ─────────────────────────────────────────────────────────
          8 bytes       8 bytes        8 bytes        8 bytes
          ✓ USED        ✓ USED         ✓ USED         ✓ USED
          
        |
        components_1.shape: text
      }
      arrow_indicator: {
        label: "Sequential Access →"
        shape: text
        style.fill: transparent
        style.font-color: "${colors.cache-stroke}"
        style.bold: true
      }
      cache_line_0 -> cache_line_1: {
        style.stroke: "${colors.cache-stroke}"
        style.stroke-width: 2
        style.animated: true
      }
    }
    prefetcher: {
      label: "CPU Prefetcher"
      style.fill: "${colors.cache-fill}"
      style.stroke: "${colors.cache-stroke}"
      status: |md
        **ACTIVE** ✓
        - Detects sequential pattern
        - Pre-loads next cache line
        - ~4 cycle latency per element
      |
      status.shape: text
    }
    stats: |md
      **Performance Metrics:**
      - Cache line utilization: **100%**
      - Components per cache line: **8**
      - Memory bandwidth: ~50 GB/s
      - 100K entities: **~400μs**
    |
      style.fill: "${colors.cache-fill}"
      style.stroke: "${colors.cache-stroke}"
      style.stroke-width: 2
  }
  hashmap: {
    label: "HASHMAP ITERATION\nRandom Access Pattern"
    style.fill: "${colors.hashmap-fill}"
    style.stroke: "${colors.hashmap-stroke}"
    style.stroke-width: 3
    header_hm: |md
      **Cache-Hostile Traversal**
    | {
      style.fill: "${colors.header-fill}"
      style.stroke: "${colors.header-stroke}"
    }
    bucket_array: {
      label: "Bucket Array (Sparse)"
      style.fill: white
      style.stroke: "${colors.hashmap-stroke}"
      style.stroke-dash: 2
      bucket_0: {
        label: "Bucket[0]"
        style.fill: "${colors.hashmap-fill}"
        style.stroke: "${colors.hashmap-stroke}"
        entry: |md
          
          ptr ──────────────────→ Heap Node
          │                        │
          │                        ├─ key: Entity
          │                        └─ value: Position
          │
          ~100 cycles to fetch
          
        |
        entry.shape: text
      }
      bucket_1: {
        label: "Bucket[1]"
        style.fill: "${colors.hashmap-fill}"
        style.stroke: "${colors.hashmap-stroke}"
        style.opacity: 0.5
        empty_entry: |md
          
          (empty bucket)
          Cache line partially wasted
          
        |
        empty_entry.shape: text
        empty_entry.style.opacity: 0.6
      }
      bucket_2: {
        label: "Bucket[hash]"
        style.fill: "${colors.hashmap-fill}"
        style.stroke: "${colors.hashmap-stroke}"
        collision: |md
          
          ptr → Node → Node → Node (collision chain)
          Each hop: potential cache miss
          
        |
        collision.shape: text
      }
      random_arrow: {
        label: "Random Access ↯"
        shape: text
        style.fill: transparent
        style.font-color: "${colors.pointer-stroke}"
        style.bold: true
      }
      bucket_0 -> bucket_1: {
        style.stroke: "${colors.hashmap-stroke}"
        style.stroke-dash: 5
        style.stroke-width: 1
      }
      bucket_1 -> bucket_2: {
        style.stroke: "${colors.hashmap-stroke}"
        style.stroke-dash: 5
        style.stroke-width: 1
      }
    }
    pointer_chasing: {
      label: "Pointer Chasing"
      style.fill: "${colors.pointer-fill}"
      style.stroke: "${colors.pointer-stroke}"
      chase_diagram: |md
        **EACH LOOKUP:**
        1. Hash → Bucket (~40 cycles)
        2. Bucket → Node (~100 cycles)
        3. Node → Value (~100 cycles)
        **~240 cycles per component**
        vs **~4 cycles** for dense array
      |
      chase_diagram.shape: text
    }
    stats_hm: |md
      **Performance Metrics:**
      - Cache line utilization: **~25%**
      - Components per cache line: **~1-2**
      - Memory bandwidth: Wasted
      - 100K entities: **~10ms**
    |
      style.fill: "${colors.pointer-fill}"
      style.stroke: "${colors.pointer-stroke}"
      style.stroke-width: 2
  }
}
legend: {
  label: "Key Insight"
  style.fill: white
  style.stroke: "#666"
  style.stroke-width: 2
  insight: |md
    ### Why Archetype Iteration is 25x Faster
    **Dense Array:**
    - Sequential access triggers CPU prefetcher
    - 1 cache miss per 8 components (64-byte line ÷ 8 bytes)
    - Prefetcher hides memory latency
    **HashMap:**
    - Random access defeats prefetcher
    - 1 cache miss per 1-2 components
    - Pointer chasing through scattered heap nodes
    **The Math:**
    - 100K entities × 8 bytes = 800 KB
    - Dense: 800 KB / 64 = 12,500 cache lines loaded
    - HashMap: ~50,000+ cache lines (scattered)
    - Ratio: **4:1** cache efficiency
    - Combined with prefetcher: **25:1** real-world speedup
  |
  insight.shape: text
}
comparison.dense_array -> legend: {
  style.stroke: transparent
}
comparison.hashmap -> legend: {
  style.stroke: transparent
}