vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right

title: |md
  # Cache Locality: HashMap vs Sparse Set
  ### Memory Layout & Iteration Access Patterns
| {
  near: top-center
  style.font-size: 24
}

# ============================================
# LEFT SIDE: HashMap (Cache-Hostile)
# ============================================
hashmap_container: "HashMap<Entity, Position>" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
  }
  
  explanation: |md
    **Random Access Pattern**
    Buckets contain pointers to disjoint heap allocations.
    Iteration requires dereferencing scattered addresses.
  | {
    style.font-size: 14
  }
  
  # Bucket array visualization
  bucket_array: "Bucket Array (Contiguous)" {
    style.fill: "#FFCDD2"
    b0: "[0]" { style.fill: "#FFCDD2" }
    b1: "[1]" { style.fill: "#FFCDD2" }
    b2: "[2]" { style.fill: "#FFCDD2" }
    b3: "[3]" { style.fill: "#FFCDD2" }
    b4: "[4]" { style.fill: "#FFCDD2" }
    b5: "[5]" { style.fill: "#FFCDD2" }
  }
  
  heap_section: "Heap Allocations (Scattered)" {
    style.stroke-dash: 5
    pos_a: "Pos(1,2)\n@0x1A00" { style.fill: "#EF9A9A" }
    pos_b: "Pos(5,6)\n@0x7F00" { style.fill: "#EF9A9A" }
    pos_c: "Pos(9,10)\n@0x3B00" { style.fill: "#EF9A9A" }
    pos_d: "Pos(3,4)\n@0xA200" { style.fill: "#EF9A9A" }
  }
}

# HashMap pointers (Random Memory Access)
hashmap_container.bucket_array.b0 -> hashmap_container.heap_section.pos_a: "0x1A00" {
  style: { stroke: "#C62828"; stroke-dash: 3 }
}
hashmap_container.bucket_array.b2 -> hashmap_container.heap_section.pos_b: "0x7F00" {
  style: { stroke: "#C62828"; stroke-dash: 3 }
}
hashmap_container.bucket_array.b3 -> hashmap_container.heap_section.pos_c: "0x3B00" {
  style: { stroke: "#C62828"; stroke-dash: 3 }
}
hashmap_container.bucket_array.b5 -> hashmap_container.heap_section.pos_d: "0xA200" {
  style: { stroke: "#C62828"; stroke-dash: 3 }
}

# ============================================
# RIGHT SIDE: Sparse Set (Cache-Friendly)
# ============================================
sparse_container: "SparseSet<Position>" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  
  explanation: |md
    **Sequential Access Pattern**
    Dense array holds actual data contiguously.
    Iteration is a simple linear scan over packed memory.
  | {
    style.font-size: 14
  }
  
  sparse_array: "Sparse Array (Indices)" {
    style.fill: "#C8E6C9"
    s0: "0" { style.fill: "#C8E6C9" }
    s1: "∅" { style.fill: "#E8F5E9" }
    s2: "1" { style.fill: "#C8E6C9" }
    s3: "3" { style.fill: "#C8E6C9" }
    s4: "∅" { style.fill: "#E8F5E9" }
    s5: "2" { style.fill: "#C8E6C9" }
  }
  
  dense_array: "Dense Array (Packed Data)" {
    style.fill: "#A5D6A7"
    d0: "Pos(1,2)" { style.fill: "#81C784" }
    d1: "Pos(5,6)" { style.fill: "#81C784" }
    d2: "Pos(9,10)" { style.fill: "#81C784" }
    d3: "Pos(3,4)" { style.fill: "#81C784" }
  }
  
  entities_array: "Entity Metadata" {
    style.fill: "#C8E6C9"
    e0: "E(0)"
    e1: "E(2)"
    e2: "E(5)"
    e3: "E(3)"
  }
}

# Sparse Index to Dense Data mappings
sparse_container.sparse_array.s0 -> sparse_container.dense_array.d0
sparse_container.sparse_array.s2 -> sparse_container.dense_array.d1
sparse_container.sparse_array.s5 -> sparse_container.dense_array.d2
sparse_container.sparse_array.s3 -> sparse_container.dense_array.d3

# ============================================
# PERFORMANCE COMPARISON
# ============================================
comparison: "Performance Metrics" {
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    stroke-width: 2
  }
  
  title: |md
    ## Critical Execution Path
  | 
  
  hashmap_stats: "HashMap Logic" {
    style.fill: "#FFCDD2"
    content: |md
      **Dereference Heavy:**
      1. Hash Key -> Bucket Index
      2. Bucket -> Pointer (Memory Jump)
      3. Pointer -> Data (Memory Jump)
      **~3 Cache Misses per Entity**
    |
  }
  
  sparse_stats: "SparseSet Logic" {
    style.fill: "#C8E6C9"
    content: |md
      **Sequential Scan:**
      1. Dense[i] -> Dense[i+1]
      2. CPU prefetcher detects pattern
      3. Data loaded into L1 before use
      **~1 Cache Miss per 8 Entities**
    |
  }
  
  hashmap_stats -> sparse_stats: "10x - 50x Faster\nIteration" {
    style: {
      stroke: "#C62828"
      stroke-width: 4
      font-color: "#C62828"
      bold: true
    }
  }
}

# ============================================
# CACHE LINE VISUALIZATION
# ============================================
cache_viz: "Hardware Level" {
  style.fill: "#FAFAFA"
  
  title: |md
    ### Cache Line (64B) Utilization
  |
  
  bad_cache: "Cache Line: HashMap" {
    style.fill: "#FFEBEE"
    cl1: "L1 Cache Block [64 Bytes]" {
      style.fill: "#FFCDD2"
    }
    waste: "87.5% Wasted Bandwidth\n(Only 1 Position/8B Used)" {
      style.font-color: "#C62828"
      style.bold: true
    }
    cl1 -> waste
  }
  
  good_cache: "Cache Line: SparseSet" {
    style.fill: "#E8F5E9"
    cl2: "L1 Cache Block [64 Bytes]" {
      style.fill: "#A5D6A7"
    }
    efficient: "100% Data Density\n(8 Positions Packed/64B)" {
      style.font-color: "#2E7D32"
      style.bold: true
    }
    cl2 -> efficient
  }
  
  bad_cache <-> good_cache: "Prefetch Friendly" {
    style.stroke: "#2E7D32"
    style.stroke-width: 3
  }
}

# ============================================
# MEMORY OFFSET DETAIL
# ============================================
memory_detail: "Address Space View" {
  style.fill: "#F5F5F5"
  
  title: |md
    ### Low-Level Memory Layout
  |
  
  hash_table: {
    shape: sql_table
    style.fill: "#FFEBEE"
    0x00: "Bucket 0 | Ptr -> 0x1A00"
    0x08: "Bucket 1 | Ptr -> 0x0000"
    0x10: "Bucket 2 | Ptr -> 0x7F00"
    "..." : "Scattered Allocations"
    0x1A00: "Pos(1,2).x | 1.0f"
    0x1A04: "Pos(1,2).y | 2.0f"
  }
  
  sparse_table: {
    shape: sql_table
    style.fill: "#E8F5E9"
    0x2000: "Dense[0].x | 1.0f"
    0x2004: "Dense[0].y | 2.0f"
    0x2008: "Dense[1].x | 5.0f"
    0x200C: "Dense[1].y | 6.0f"
    0x2010: "Dense[2].x | 9.0f"
    0x2014: "Dense[2].y | 10.0f"
  }
}

# ============================================
# BENCHMARK NUMBERS
# ============================================
benchmark: "Benchmark Result" {
  style: { fill: "#E3F2FD"; stroke: "#1565C0" }
  
  title: |md
    ### Throughput (100K Entities)
  |
  
  results: {
    grid-columns: 2
    grid-gap: 20
    
    hash_res: "HashMap Iter" {
      style.fill: "#FFCDD2"
      time: "12.4 ms" {
        style.font-size: 20
        style.bold: true
      }
    }
    
    sparse_res: "SparseSet Iter" {
      style.fill: "#C8E6C9"
      time: "0.4 ms" {
        style.font-size: 20
        style.bold: true
      }
    }
  }
  
  footer: |md
    **Conclusion:** Contiguous memory allows the CPU to load 8 elements at a time, 
    effectively eliminating memory latency during iteration.
  |
}

# Root-level relationship
hashmap_container <-> sparse_container: "Implementation Choice" {
  style: { stroke: "#666"; stroke-width: 2; font-size: 20; bold: true }
}