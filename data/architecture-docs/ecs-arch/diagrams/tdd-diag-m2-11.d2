layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# TECHNICAL SPECIFICATION: TYPE-SAFE COMPONENT ACCESS
# -----------------------------------------------------------------------------
title: {
  shape: text
  label: ||md
    # TECHNICAL SPECIFICATION: TYPE-SAFE COMPONENT ACCESS
    ### Path: `World::get_component::<T>(Entity)`
    **Complexity: O(1) | Memory Safety: Guaranteed via TypeID Registry**
  ||
  near: top-center
}

# -----------------------------------------------------------------------------
# Style Classes (Technical Manual Specification)
# -----------------------------------------------------------------------------
classes: {
  api_layer: {
    style: {
      fill: "#E1BEE7"
      stroke: "#4A148C"
      stroke-width: 2
      font-color: "#4A148C"
      double-border: true
    }
  }
  storage_layer: {
    style: {
      fill: "#BBDEFB"
      stroke: "#0D47A1"
      stroke-width: 2
    }
  }
  memory_segment: {
    style: {
      font: mono
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      stroke-dash: 2
    }
  }
  flow_logic: {
    style: {
      stroke: "#2E7D32"
      stroke-width: 3
      animated: true
    }
  }
  pointer_ref: {
    style: {
      stroke: "#EF6C00"
      stroke-width: 2
      stroke-dash: 4
    }
  }
}

# -----------------------------------------------------------------------------
# World / API Entry Point
# -----------------------------------------------------------------------------
World: {
  class: api_layer
  label: "pub struct World"
  
  Logic: |md
    ### Method Signature
    rust
    pub fn get_component<T: 'static>(
      &self, 
      entity: Entity
    ) -> Option<&T>
    
    1. Resolve `TypeId::of::<T>()`
    2. Lookup Storage in Registry
  |
  
  MemoryLayout: "Entity Handle Structure" {
    class: memory_segment
    tooltip: "8-byte packed identifier"
    
    grid-columns: 2
    grid-gap: 0
    
    H1: "Offset" { style.bold: true; style.fill: "#EEEEEE" }
    H2: "Field [31:0]" { style.bold: true; style.fill: "#EEEEEE" }
    
    O1: "0x00"
    F1: "Index (u32)" { style.fill: "#E3F2FD" }
    
    O2: "0x04"
    F2: "Generation (u32)" { style.fill: "#E8F5E9" }
  }
}

# -----------------------------------------------------------------------------
# Component Registry (Metadata Layer)
# -----------------------------------------------------------------------------
Registry: {
  class: storage_layer
  label: "Component Registry"
  
  StorageMap: "HashMap<TypeId, Box<dyn Storage>>" {
    shape: cylinder
    style.fill: "#FFF9C4"
  }
  
  ResolutionPath: |md
    ### Downcast Recovery
    rust
    // O(1) Internal Logic
    let storage = self.storages.get(&id)?;
    storage.as_any().downcast_ref::<SparseSet<T>>()
    
  |
}

# -----------------------------------------------------------------------------
# Data Storage Layer (Sparse Set)
# -----------------------------------------------------------------------------
SparseSet: {
  class: storage_layer
  label: "SparseSet<T>"
  
  SparseArray: "Sparse Index Map" {
    style.fill: "#FFE0B2"
    shape: rectangle
    label: ||md
      | Entity Index | Dense Index |
      | :--- | :--- |
      | ... | ... |
      | **42** | **-> 5** |
      | ... | ... |
    ||
  }
  
  DenseArray: "Packed Component Storage" {
    style.fill: "#C8E6C9"
    shape: rectangle
    label: ||md
      | Dense Index | Component T |
      | :--- | :--- |
      | ... | ... |
      | **5** | **{ val: 1.0 }** |
      | ... | ... |
    ||
  }
}

Result: {
  shape: circle
  label: "Return\n&T"
  style: {
    fill: "#4CAF50"
    font-color: white
    bold: true
  }
}

# -----------------------------------------------------------------------------
# Execution Flow & Call Sequence
# -----------------------------------------------------------------------------
World -> Registry: "1. Query TypeId" {
  class: flow_logic
}

Registry.StorageMap -> Registry.ResolutionPath: "2. Fetch Handle" {
  class: pointer_ref
}

Registry.ResolutionPath -> SparseSet: "3. Cast to SparseSet<T>" {
  class: flow_logic
}

SparseSet.SparseArray -> SparseSet.DenseArray: "4. Indirection" {
  class: pointer_ref
  label: "sparse[42] = 5"
}

SparseSet.DenseArray -> Result: "5. Access dense[5]" {
  class: flow_logic
}

# -----------------------------------------------------------------------------
# Technical Annotations
# -----------------------------------------------------------------------------
Documentation: {
  shape: text
  near: bottom-left
  label: |md
    ## Performance Implementation Details
    
    ### [1] Type-Safety
    Static dispatch via Rust generics guarantees `T` is known at compile time. 
    `TypeId` provides a unique 64-bit fingerprint for runtime 
    validation of the type-erased `Box<dyn Any>`.
    
    ### [2] Cache Locality
    Components are stored in the **Dense Array** as a contiguous 
    block of memory. Iteration is `O(N)` with optimal pre-fetching.
    
    ### [3] Access Complexity
    - **Step 1 (Map):** `O(1)` amortized hash lookup.
    - **Step 2 (Indirection):** `O(1)` array access.
  |
}

# -----------------------------------------------------------------------------
# Legend (Architectural Components)
# -----------------------------------------------------------------------------
Legend: {
  near: bottom-right
  
  L1: "API Interface" { style.fill: "#E1BEE7" }
  L2: "Metadata Registry" { style.fill: "#BBDEFB" }
  L3: "Linear Memory" { style.fill: "#C8E6C9" }
  
  LogicFlow: "Flow: Logic" {
    style: { stroke: "#2E7D32"; stroke-width: 2; animated: true }
  }
  PointerFlow: "Flow: Pointer" {
    style: { stroke: "#EF6C00"; stroke-width: 2; stroke-dash: 4 }
  }
}