vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B46C1"
    cache_hit: "#10B981"
    cache_load: "#3B82F6"
    iteration: "#8B5CF6"
    target: "#EF4444"
    milestone: "#F59E0B"
    background: "#1F2937"
    panel: "#374151"
    text: "#F3F4F6"
    dim: "#9CA3AF"
  }
}

title: |md
  # 100K Iteration Benchmark Timeline
  ### Dense Array Cache Load → Sequential Iteration → Sub-Millisecond Target
| {near: top-center}

direction: right

# Timeline axis
timeline_axis: {
  shape: rectangle
  width: 1400
  height: 60
  style.fill: "${colors.panel}"
  style.stroke: "${colors.dim}"
  style.border-radius: 4
  
  start_label: |md
    **T = 0μs**
    Benchmark Start
  |
  load_label: |md
    **~16μs**
    Cache Load
  |
  iter_label: |md
    **~200-400μs**
    Iteration
  |
  end_label: |md
    **<500μs**
    Complete ✓
  |
  target_label: |md
    **1000μs (1ms)**
    Target Limit
  |
}

# Memory Layout Panel
memory_panel: {
  label: |md
    ## Memory Layout
  |
  style.fill: "${colors.panel}"
  style.stroke: "${colors.dim}"
  style.border-radius: 8
  width: 320
  height: 400
  
  dense_array: {
    label: |md
      ### Dense Array
      **100,000 × Position**
      
      ┌─────────────────────┐
      │ x: f32 │ y: f32    │ × 100,000
      ├─────────────────────┤
      │ x: f32 │ y: f32    │
      ├─────────────────────┤
      │ x: f32 │ y: f32    │
      ├─────────────────────┤
      │       ...           │
      └─────────────────────┘
      
      **Size: 800 KB**
      (8 bytes per Position)
    |
    shape: rectangle
    style.fill: "${colors.cache_load}"
    style.fill-pattern: lines
    style.stroke: "${colors.header}"
    style.border-radius: 4
    width: 280
  }
  
  cache_line: {
    label: |md
      ### Cache Line (64 bytes)
      **8 entities per line**
      
      ┌────────┬────────┬────────┬────────┐
      │ Pos[0] │ Pos[1] │ Pos[2] │ Pos[3] │
      │ 8B     │ 8B     │ 8B     │ 8B     │
      ├────────┼────────┼────────┼────────┤
      │ Pos[4] │ Pos[5] │ Pos[6] │ Pos[7] │
      │ 8B     │ 8B     │ 8B     │ 8B     │
      └────────┴────────┴────────┴────────┘
      
      1 cache miss = 8 entities loaded
    |
    shape: rectangle
    style.fill: "${colors.iteration}"
    style.stroke: "${colors.header}"
    style.border-radius: 4
    width: 280
  }
  
  dense_array -> cache_line: "fetched in"
}

# Phase 1: Cache Load
phase1: {
  label: |md
    ## Phase 1: Cache Load
    **~16 microseconds**
  |
  style.fill: "${colors.panel}"
  style.stroke: "${colors.cache_load}"
  style.stroke-width: 3
  style.border-radius: 8
  width: 320
  
  load_detail: {
    label: |md
      Dense Array: 800 KB
      L3 Cache:    8-32 MB (typical)
      Transfer:    Sequential read
      Bandwidth:   ~50 GB/s (DDR4)
      Time = 800KB / 50GB/s
            = 16 μs
    |
    shape: rectangle
    style.fill: "${colors.background}"
    style.stroke: "${colors.cache_load}"
    style.border-radius: 4
    width: 280
  }
  
  l3_cache: {
    label: |md
      ### L3 Cache After Load
      
      ┌─────────────────────────────┐
      │ Position[0..99999]          │
      │ ████████████████████ 800KB  │
      └─────────────────────────────┘
      ✓ Entire array fits in L3
      ✓ Prefetcher activated
      ✓ Sequential access pattern
    |
    shape: rectangle
    style.fill: "${colors.cache_hit}"
    style.fill-pattern: dots
    style.stroke: "${colors.cache_hit}"
    style.border-radius: 4
    width: 280
  }
  
  load_detail -> l3_cache: "load into"
}

# Phase 2: Sequential Iteration
phase2: {
  label: |md
    ## Phase 2: Iteration
    **200-400 microseconds**
  |
  style.fill: "${colors.panel}"
  style.stroke: "${colors.iteration}"
  style.stroke-width: 3
  style.border-radius: 8
  width: 360
  
  iter_code: {
    label: |md
      ### Iteration Code
      rust
      // Pure sequential access
      for i in 0..100_000 {
          pos[i].x += vel[i].dx * dt;
          pos[i].y += vel[i].dy * dt;
      }
      
      **No indirection** — direct array access
      **No sparse lookup** — contiguous memory
    |
    shape: rectangle
    style.fill: "${colors.background}"
    style.stroke: "${colors.iteration}"
    style.border-radius: 4
    width: 320
  }
  
  prefetch_diagram: {
    label: |md
      ### CPU Prefetcher Active
      
      Time →
      Access:  [0][1][2][3][4][5][6][7]...
                ↓  ↓  ↓  ↓  ↓  ↓  ↓  ↓
      Cache:   ████████████████████████
                ↑_______Prefetch_______↑
      Each access triggers next-line
      prefetch. Cache lines arrive
      BEFORE they're needed.
    |
    shape: rectangle
    style.fill: "${colors.cache_hit}"
    style.fill-pattern: dots
    style.stroke: "${colors.cache_hit}"
    style.border-radius: 4
    width: 320
  }
  
  iter_math: {
    label: |md
      ### Iteration Math
      
      Operations:  100,000 × 4 (2 mul, 2 add)
                   = 400,000 FLOPs
      At 3 GHz:    ~133 μs compute
      With overhead:
      L1 hits:     ~4 cycles each
      Loop:        ~10 cycles per iter
      Total:       ~200-400 μs
    |
    shape: rectangle
    style.fill: "${colors.background}"
    style.stroke: "${colors.iteration}"
    style.border-radius: 4
    width: 320
  }
  
  iter_code -> prefetch_diagram
  prefetch_diagram -> iter_math
}

# Phase 3: Result
phase3: {
  label: |md
    ## Phase 3: Complete
    **< 500 microseconds**
  |
  style.fill: "${colors.panel}"
  style.stroke: "${colors.cache_hit}"
  style.stroke-width: 3
  style.border-radius: 8
  width: 280
  
  result: {
    label: |md
      ### Benchmark Result
      
      ┌────────────────────────┐
      │ ✓ 100,000 entities     │
      │ ✓ 2 components each    │
      │ ✓ All positions updated│
      │                        │
      │ Time: 200-400 μs       │
      │ Target: < 1000 μs      │
      │                        │
      │ MARGIN: 2-5x faster    │
      └────────────────────────┘
    |
    shape: rectangle
    style.fill: "${colors.cache_hit}"
    style.stroke: "${colors.header}"
    style.border-radius: 4
    width: 240
  }
  
  comparison: {
    label: |md
      ### vs Sparse Set
      
      Sparse Set:  ~1-2 ms
      Archetype:   ~0.3 ms
      Speedup:     3-6x faster
      Why?
      • No sparse array lookup
      • Pure sequential access
      • SIMD auto-vectorization
    |
    shape: rectangle
    style.fill: "${colors.background}"
    style.stroke: "${colors.milestone}"
    style.border-radius: 4
    width: 240
  }
  
  result -> comparison
}

# Target Line
target_section: {
  label: |md
    ## Target: 1ms (1000μs)
  |
  style.fill: "${colors.panel}"
  style.stroke: "${colors.target}"
  style.stroke-width: 3
  style.border-radius: 8
  width: 200
  
  target_bar: {
    label: |md
      0μs        500μs       1000μs
      │..........│...........│
                 ↑           ↑
            Actual      Target
            ~300μs      1000μs
      ✓ PASS with 3x margin
    |
    shape: rectangle
    style.fill: "${colors.background}"
    style.stroke: "${colors.target}"
    style.border-radius: 4
    width: 160
  }
}

# Flow connections
memory_panel -> phase1: "1. Load" {
  style.stroke: "${colors.cache_load}"
  style.stroke-width: 3
  style.animated: true
}
phase1 -> phase2: "2. Iterate" {
  style.stroke: "${colors.iteration}"
  style.stroke-width: 3
  style.animated: true
}
phase2 -> phase3: "3. Done" {
  style.stroke: "${colors.cache_hit}"
  style.stroke-width: 3
  style.animated: true
}

# Annotation: SIMD benefit
# FIXED: Elk layout engine does not support relative 'near' values.
# Changed from 'near: phase2' to constant position 'bottom-right'.
simd_note: |md
  ### SIMD Bonus
  With archetype layout, compiler can
  auto-vectorize to process 4-8 entities
  per instruction (AVX2/AVX-512).
  Potential additional 2-4x speedup.
| {
  near: bottom-right
  shape: rectangle
  style.fill: "${colors.panel}"
  style.stroke: "${colors.milestone}"
  style.border-radius: 4
}

# Cache hierarchy reference
cache_hierarchy: {
  label: |md
    ## Cache Hierarchy Reference
  |
  style.fill: "${colors.panel}"
  style.stroke: "${colors.dim}"
  style.border-radius: 8
  width: 280
  
  l1: {
    label: |md
      **L1 Cache**: 32 KB
      Latency: ~4 cycles
      Position fits: 4,096 entities
    |
    style.fill: "${colors.cache_hit}"
    style.border-radius: 4
  }
  
  l2: {
    label: |md
      **L2 Cache**: 256 KB - 1 MB
      Latency: ~12 cycles
      Position fits: 32K-128K entities
    |
    style.fill: "${colors.cache_hit}"
    style.border-radius: 4
  }
  
  l3: {
    label: |md
      **L3 Cache**: 8 - 32 MB
      Latency: ~40 cycles
      Position fits: 1M-4M entities ✓
    |
    style.fill: "${colors.cache_load}"
    style.border-radius: 4
  }
  
  ram: {
    label: |md
      **RAM**: 16+ GB
      Latency: ~100+ cycles
      800KB sequential: ~16μs
    |
    style.fill: "${colors.target}"
    style.border-radius: 4
  }
  
  l1 -> l2
  l2 -> l3
  l3 -> ram
}