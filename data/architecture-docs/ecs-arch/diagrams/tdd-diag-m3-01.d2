vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Iterator Invalidation Problem
  ### Swap-and-Pop During Iteration Causes Data Loss
  **Technical Specification: Memory Management 0xAF-12**
| {
  style: {
    font-size: 28
    bold: true
  }
}

direction: down

classes: {
  index_box: {
    shape: rectangle
    width: 140
    height: 100
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 2
      font: mono
    }
  }
  iter_indicator: {
    label: "▶ CURSOR"
    shape: rectangle
    style: {
      fill: "#FF6B6B"
      stroke: "#CC0000"
      font-color: white
      font-size: 12
      bold: true
      border-radius: 2
    }
  }
  removed: {
    style: {
      fill: "#FFB4B4"
      stroke: "#CC0000"
      stroke-dash: 3
    }
  }
  swapped: {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      stroke-width: 3
      bold: true
    }
  }
  skipped: {
    style: {
      fill: "#FFD700"
      stroke: "#FF8C00"
      stroke-width: 4
      bold: true
    }
  }
  label_box: {
    width: 400
    height: 80
    style: {
      fill: "#F0F0F0"
      stroke: "#CCCCCC"
      border-radius: 4
      font-size: 16
      font-color: "#333333"
      bold: true
    }
  }
}

# === STAGE 1: Before Removal ===
stage_1: {
  style.fill: transparent
  style.stroke-width: 0

  step1_label: "Pointer Analysis: Iterator points to Index 5 (Entity A)" {
    class: label_box
  }

  step1: {
    label: "STEP 1: Steady State (Iteration i=5)"
    
    step1_array: {
      grid-columns: 8
      grid-gap: 15
      
      idx4: "0x10 | Offset +16B\nEntity X" {class: index_box}
      idx5: "0x14 | Offset +20B\nEntity A" {
        class: [index_box; removed]
        cur: { 
          class: iter_indicator
          label.near: top-center 
        }
      }
      idx6: "0x18 | Offset +24B\nEntity Y" {class: index_box}
      dots1: "..." {style.stroke: transparent; style.fill: transparent}
      idx99: "0x18C | Offset +396B" {class: index_box}
      idx100: "0x190 | Offset +400B\nEntity B" {class: [index_box; swapped]}
      idx101: "0x194 | Offset +404B" {class: index_box}
      dots2: "..." {style.stroke: transparent; style.fill: transparent}
    }
  }

  step1_note: |md
    ### State: Memory View 0x01
    - **Memory Layout**: Contiguous Block (sizeof=408 bytes)
    - **Active Cursor**: `uint32_t i = 5`
    - **Interrupt**: `EntityA.Destroy()` is called.
    - **Swap Logic**: Array tail (Entity B) is target for fill.
  | {
    style.fill: "#F8F9FA"
  }
}

# === STAGE 2: Swap-and-Pop ===
stage_2: {
  style.fill: transparent
  style.stroke-width: 0

  step2_label: "Mutation Phase: Tail Entity B overwrites Hole at Index 5" {
    class: label_box
  }

  step2: {
    label: "STEP 2: Mutation (Memory Swap-and-Pop)"
    
    step2_array: {
      grid-columns: 8
      grid-gap: 15
      
      s2_idx4: "0x10 | Offset +16B\nEntity X" {class: index_box}
      s2_idx5: "0x14 | Offset +20B\n**Entity B**" {
        class: [index_box; swapped]
        cur: { 
          class: iter_indicator
          label.near: top-center 
        }
      }
      s2_idx6: "0x18 | Offset +24B\nEntity Y" {class: index_box}
      s2_dots1: "..." {style.stroke: transparent; style.fill: transparent}
      s2_idx99: "0x18C | Offset +396B" {class: index_box}
      s2_idx100: "0x190 | POPPED\n(Invalidated)" {class: [index_box; removed]}
      s2_idx101: "0x194 | Offset +404B" {class: index_box}
      s2_dots2: "..." {style.stroke: transparent; style.fill: transparent}

      s2_idx100 -> s2_idx5: "memcpy(&arr[5], &arr[100])" {
        style: {
          stroke: "#228B22"
          stroke-width: 4
          animated: true
        }
      }
    }
  }

  step2_note: |md
    ### Atomic Operation: 0x02
    1. `data[i] = data[size - 1]` 
    2. `size = size - 1` (Truncation)
    3. **Critical State**: Index 5 now holds new data, but iterator `i` is still 5.
  | {
    style.fill: "#F8F9FA"
  }
}

# === STAGE 3: Iterator Advances ===
stage_3: {
  style.fill: transparent
  style.stroke-width: 0

  step3_label: "DATA LOSS DETECTED: Entity B Update() call skipped for current frame" {
    class: label_box
    style: {
      font-color: "#CC0000"
      stroke: "#CC0000"
      stroke-width: 3
    }
  }

  step3: {
    label: "STEP 3: Resulting Logic Error"
    
    step3_array: {
      grid-columns: 8
      grid-gap: 15
      
      s3_idx4: "0x10 | Offset +16B\nEntity X" {class: index_box}
      s3_idx5: "0x14 | Offset +20B\n**Entity B**" {
        class: [index_box; skipped]
      }
      s3_idx6: "0x18 | Offset +24B\nEntity Y" {
        class: index_box
        cur: { 
          class: iter_indicator
          label.near: top-center 
        }
      }
      s3_dots1: "..." {style.stroke: transparent; style.fill: transparent}
      s3_idx99: "0x18C | Offset +396B" {class: index_box}
      s3_idx100: "FREE_POINTER" {style.fill: "#CCCCCC"; style.stroke-dash: 3}
      s3_idx101: "0x194 | Offset +404B" {class: index_box}
      s3_dots2: "..." {style.stroke: transparent; style.fill: transparent}
      
      s3_idx5 -- s3_idx6: "i++ JUMPS OVER B" {
        style: {
          stroke: "#FF8C00"
          stroke-width: 6
          stroke-dash: 3
        }
      }
    }
  }

  step3_note: |md
    ### Result Analysis: 0x03
    - **The i++ Increment**: Execution moves to Index 6.
    - **Side Effect**: Entity B (at Index 5) is effectively invisible to this loop.
    - **Verdict**: Naive forward iteration causes non-deterministic system updates.
  | {
    style.fill: "#FFF5F5"
  }
}

# High-Level Sequence Flow
stage_1 -> stage_2: "Remove(5)" {
  style: {
    stroke: "#CC0000"
    stroke-width: 5
  }
}
stage_2 -> stage_3: "Loop Increment (i++)" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 5
    stroke-dash: 4
  }
}

# Legend for Engineering Reference
legend: {
  style: {
    fill: "#FFFFFF"
    stroke: "#000000"
    stroke-width: 1
    shadow: true
  }
  
  leg_title: "Memory State Reference" {
    style: { bold: true; underline: true }
  }
  
  r1: "Marked for Disposal" { class: [index_box; removed]; width: 140; height: 40 }
  r2: "Tail-to-Hole Data" { class: [index_box; swapped]; width: 140; height: 40 }
  r3: "Logical Gap / Skipped" { class: [index_box; skipped]; width: 140; height: 40 }
  r4: "Current Pointer Location" { class: iter_indicator; width: 140; height: 40 }
}

# Implementation Guide for Software Engineers
root_explanation: |md
  ## Recommended Implementation Patterns
  
  ### Pattern A: Reverse Iteration (O(1) removal safety)
  cpp
  // Start from end to ensure swaps only affect previously processed memory
  for (int i = list.size() - 1; i >= 0; --i) {
      if (list[i].marked_for_deletion()) {
          swap_and_pop(list, i);
      }
  }
  
  
  ### Pattern B: Manual Increment Control
  cpp
  for (int i = 0; i < list.size(); ) {
      if (list[i].marked_for_deletion()) {
          swap_and_pop(list, i);
          // Index i now holds the new element from the tail; do NOT increment.
      } else {
          i++; // Only move forward if no mutation occurred
      }
  }
  
| {
  style: {
    fill: "#F0FFF4"
    stroke: "#28a745"
    stroke-width: 3
  }
}