direction: right

title: ||md
  # Command Buffer Structure & Structural Pipeline
  ### Internal Architecture for Deferred ECS Mutations
  *Specification: Intel Manual Quality - Byte Layout & Dispatch Sequence*
||
title.shape: text
title.near: top-center
title.style.font-size: 18

# -----------------------------------------------------------------------------
# 1. Host Container Definition
# -----------------------------------------------------------------------------

CommandBuffer: {
  label: "CommandBuffer (Host Container)\nsizeof=24 bytes"
  style: {
    fill: "#E8F4FD"
    stroke: "#2E86AB"
    stroke-width: 3
    border-radius: 8
  }

  vector: {
    label: "commands: Vec<Command>"
    shape: cylinder
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
}

AllocationStrategy: ||md
  ### Allocation Strategy
  - **Storage**: Contiguous Heap (Linear Buffer)
  - **Iteration**: Cache-friendly sequential access
  - **Alignment**: 8-byte aligned variants
  - **Growth**: Exponential (Factor 1.5x)
||
AllocationStrategy.shape: text
AllocationStrategy.near: top-right
AllocationStrategy.style.font-size: 11

# -----------------------------------------------------------------------------
# 2. Variant Definitions (Memory Layout)
# -----------------------------------------------------------------------------

Command: {
  label: "enum Command (Layout: Tagged Union)\nsizeof=48B (Aligned to max variant)"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
    border-radius: 8
  }

  Spawned: {
    label: "Variant: Spawned (0x01)"
    style.fill: "#C8E6C9"
    fields: ||md
      | Offset | Field | Type | Size |
      | :--- | :--- | :--- | :--- |
      | 0 | **tag** | u8 | 1B |
      | 1..7 | **pad** | byte[7] | 7B |
      | 8 | **entity** | EntityId | 8B |
      | 16..47| **unused** | byte[32] | 32B |
    ||
    fields.shape: text
    fields.style.font: mono
    fields.style.font-size: 10
  }

  Destroy: {
    label: "Variant: Destroy (0x02)"
    style.fill: "#FFCDD2"
    fields: ||md
      | Offset | Field | Type | Size |
      | :--- | :--- | :--- | :--- |
      | 0 | **tag** | u8 | 1B |
      | 1..7 | **pad** | byte[7] | 7B |
      | 8 | **entity** | EntityId | 8B |
      | 16..47| **unused** | byte[32] | 32B |
    ||
    fields.shape: text
    fields.style.font: mono
    fields.style.font-size: 10
  }

  Insert: {
    label: "Variant: Insert (0x03)"
    style.fill: "#BBDEFB"
    fields: ||md
      | Offset | Field | Type | Size |
      | :--- | :--- | :--- | :--- |
      | 0 | **tag** | u8 | 1B |
      | 1..7 | **pad** | byte[7] | 7B |
      | 8 | **entity** | EntityId | 8B |
      | 16 | **ptr** | Box&lt;dyn Any&gt; | 16B |
      | 32 | **type** | TypeId | 8B |
      | 40..47| **pad** | byte[8] | 8B |
    ||
    fields.shape: text
    fields.style.font: mono
    fields.style.font-size: 10
  }

  Remove: {
    label: "Variant: Remove (0x04)"
    style.fill: "#FFF9C4"
    fields: ||md
      | Offset | Field | Type | Size |
      | :--- | :--- | :--- | :--- |
      | 0 | **tag** | u8 | 1B |
      | 1..7 | **pad** | byte[7] | 7B |
      | 8 | **entity** | EntityId | 8B |
      | 16 | **type** | TypeId | 8B |
      | 24..47| **unused** | byte[24] | 24B |
    ||
    fields.shape: text
    fields.style.font: mono
    fields.style.font-size: 10
  }
}

# -----------------------------------------------------------------------------
# 3. Connection & Execution Logic
# -----------------------------------------------------------------------------

CommandBuffer.vector -> Command: "owns contiguous storage" {
  style: {
    stroke-width: 2
    stroke: "#E65100"
  }
  source-arrowhead: * {
    shape: diamond
    style.filled: true
  }
  target-arrowhead: * {
    shape: triangle
  }
}

ApplicationPipeline: ||md
  ## Application Pipeline (Atomic Sync Point)
  1. **Lock World**: Acquire Exclusive Write Lock.
  2. **Phase 1: IDs**: Map pre-allocated `Entity` IDs to live World index.
  3. **Phase 2: Structural**: Batch process `Insert` and `Remove`.
     - *Note: Triggers Archetype graph transitions.*
  4. **Phase 3: Cleanup**: Execute `Destroy`. Free component storage.
  5. **Clear Buffer**: Reset `Vec` length to 0 (Retain capacity).
||
ApplicationPipeline.shape: text
ApplicationPipeline.near: bottom-center
ApplicationPipeline.style: {
  font-size: 12
  font-color: "#333"
  stroke: "#777"
  fill: "#FAFAFA"
  border-radius: 4
  shadow: true
}

LegendBox: {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#CCCCCC"
  content: ||md
    ### Execution Context
    - 🟢 **Spawned**: Immediate ID, Deferred World insert
    - 🔴 **Destroy**: Mark removal, Batch drop
    - 🔵 **Insert**: Archetype migration (MOV/REALLOC)
    - 🟡 **Remove**: Data drop (Component level)
  ||
  content.shape: text
  content.style.font-size: 11
}

# -----------------------------------------------------------------------------
# 4. Global Styling & Layout Hints
# -----------------------------------------------------------------------------

***.style.font: mono

Command.Spawned.fields.style.font-color: "#2E7D32"
Command.Destroy.fields.style.font-color: "#C62828"
Command.Insert.fields.style.font-color: "#1565C0"
Command.Remove.fields.style.font-color: "#F57F17"

# Visual Grouping for Intel Quality
Command.style.fill: "#F8F9FA"
Command.style.stroke-dash: 0