vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # ECS Command Buffer Timeline & Structural Invariants
  ## Technical Specification for Deferred Command Execution
| {near: top-center}

# Frame N: Active Execution and Deferred Buffering
Frame_N: {
  label: "FRAME EXECUTION PIPELINE (N)"
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 4
  }

  # Phases of the World
  System_Execution: {
    label: "PHASE 1: SYSTEM EXECUTION (IMMUTABLE WORLD)"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-dash: 3
    }
    
    Movement_System: {
      shape: class
      label: "MovementSystem"
      "Update(dt: f32)"
      "Process(entities: Query<Pos, Vel>)"
      style.fill: "#C8E6C9"
    }

    Collision_System: {
      shape: class
      label: "CollisionSystem"
      "Update(dt: f32)"
      "OnContact(a: Entity, b: Entity)"
      style.fill: "#C8E6C9"
    }

    Movement_System -> Collision_System: "sequential_exec"
  }

  # The Command Buffer Memory Layout
  Command_Buffer_Populated: {
    label: "PHASE 2: COMMAND BUFFER (RECORDING)"
    shape: sql_table
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
    
    # Representing byte-level alignment for implementation
    header: "HEADER: Buffer Metadata [0x00]" {constraint: "16 bytes"}
    cmd_0: "[0x10] OP_SPAWN | ENTITY_ID: 0xAF12" {constraint: "24 bytes"}
    cmd_1: "[0x28] OP_DESPAWN | ENTITY_ID: 0xBC44" {constraint: "12 bytes"}
    cmd_2: "[0x34] OP_ADD_COMP | TID: 0x05 | DATA..." {constraint: "Varies"}
    padding: "PADDING / ALIGNMENT" {style.fill: gray}
  }

  # Explicit Transition
  (System_Execution -> Command_Buffer_Populated): "queues_structural_change()" {
    style: {
      stroke: "#F44336"
      stroke-width: 2
      stroke-dash: 3
    }
  }

  # The Flush/Sync Point
  Flush_Phase: {
    label: "PHASE 3: SYNC POINT (WORLD FLUSH)"
    style: {
      fill: "#E1BEE7"
      stroke: "#9C27B0"
    }

    Apply_Inserts: "1. Allocation & Archetype Move" {
      shape: rectangle
      style.fill: "#F3E5F5"
    }
    Apply_Removes: "2. Component Cleanup" {
      shape: rectangle
      style.fill: "#F3E5F5"
    }
    Apply_Destroys: "3. Entity ID Reclamation" {
      shape: rectangle
      style.fill: "#F3E5F5"
    }

    Apply_Inserts -> Apply_Removes -> Apply_Destroys
  }

  (Command_Buffer_Populated -> Flush_Phase): "World::flush_commands()" {
    style.stroke: "#9C27B0"
    style.stroke-width: 2
  }

  # Resultant State
  Command_Buffer_Empty: {
    label: "BUFFER RESET"
    shape: cylinder
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    "Available: 4096 bytes"
  }

  Flush_Phase -> Command_Buffer_Empty: "clear_buffer()"
}

# Frame N+1: Observation of Result
Frame_N1: {
  label: "FRAME PIPELINE (N+1)"
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 4
  }

  Consistent_World: {
    label: "Consistent World State"
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
      bold: true
    }
    "Entity Generation Validated"
    "Archetype Tables Reindexed"
  }

  Observation: "Systems read new Component Arrays" {
    shape: text
    style.font-size: 14
  }

  Consistent_World -> Observation
}

# Top level Transition
Frame_N -> Frame_N1: "TICK COMPLETE" {
  style: {
    stroke: "#2196F3"
    stroke-width: 4
    bold: true
  }
}

# Technical Annotations & Implementation Guards
Safety_Manual: {
  label: |md
    ## Safety & Threading Constraints
    - **In-System Invariant**: `World.is_locked = true`.
    - **Buffer Sizing**: Static allocation of `1MB` per thread.
    - **Memory Safety**: Commands must be POD or have trivial destructors.
    - **Direct Manipulation**: Any write to `EntityIndex` during Phase 1 causes immediate abort.
  |
  shape: text
  near: top-right
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    stroke-width: 2
  }
}

Memory_Map_Legend: {
  label: |md
    ### Buffer Entry Alignment
    - `u8`  : OpCode
    - `u32` : Target Entity Index
    - `u16` : Component Type ID
    - `ptr` : Data Payload (Aligned 8-byte)
  |
  shape: text
  near: bottom-right
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
  }
}