layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header: "#E8D5F2"
    system: "#D4E8F7"
    scheduler: "#F5E6D3"
    world: "#E2F0D9"
    arrow: "#444444"
    text: "#222222"
    mem_header: "#7030A0"
    data: "#2E75B6"
    padding: "#F0F0F0"
    orange_ptr: "#C55A11"
  }
}

title: |md
  # System Scheduler Architecture
  ### Linear Execution Model & Trait-Object Registration
| {
  near: top-center
  style.font-size: 24
}

direction: down

# -----------------------------------------------------------------------------
# CLASSES & STYLING
# -----------------------------------------------------------------------------
classes: {
  system-box: {
    style: {
      fill: "${colors.system}"
      stroke: "#2E75B6"
      stroke-width: 2
      font-color: "${colors.text}"
      border-radius: 4
    }
  }
  scheduler-box: {
    style: {
      fill: "${colors.scheduler}"
      stroke: "#C55A11"
      stroke-width: 2
      font-color: "${colors.text}"
      border-radius: 4
    }
  }
  trait-box: {
    style: {
      fill: "${colors.header}"
      stroke: "#7030A0"
      stroke-width: 2
      font-color: "${colors.text}"
      border-radius: 4
    }
  }
  world-box: {
    style: {
      fill: "${colors.world}"
      stroke: "#538135"
      stroke-width: 2
      font-color: "${colors.text}"
      border-radius: 4
    }
  }
}

# -----------------------------------------------------------------------------
# 1. TRAIT SPECIFICATION (UML CLASS)
# -----------------------------------------------------------------------------
SystemTrait: {
  shape: class
  label: "trait System"
  class: trait-box
  
  "+ name(&self)": "&str"
  "+ run(&mut self, world: &mut World, dt: f32)": "void"
  
  tooltip: "The core interface for all executable logic units"
}

# -----------------------------------------------------------------------------
# 2. IMPLEMENTATION LAYER
# -----------------------------------------------------------------------------
Implementation: {
  grid-columns: 2
  grid-gap: 40
  style.stroke-width: 0

  MovementSystem: {
    class: system-box
    shape: class
    label: "MovementSystem"
    " - velocity": "f32"
    "+ run(...)": "impl System"
  }

  CollisionSystem: {
    class: system-box
    shape: class
    label: "CollisionSystem"
    " - layers": "u32"
    "+ run(...)": "impl System"
  }

  AISystem: {
    class: system-box
    shape: class
    label: "AISystem"
    " - state": "BehaviorTree"
    "+ run(...)": "impl System"
  }

  FunctionSystem: {
    class: system-box
    shape: class
    label: "FnSystem<F>"
    " - closure": "F: FnMut"
    "+ run(...)": "impl System"
  }
}

# Implementation Connections (Realization)
# Hollow triangle + dashed line = Implements
Implementation.MovementSystem -> SystemTrait: "implements" { 
  style.stroke-dash: 3 
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}
Implementation.CollisionSystem -> SystemTrait: "implements" { 
  style.stroke-dash: 3 
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}
Implementation.AISystem -> SystemTrait: "implements" { 
  style.stroke-dash: 3 
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}
Implementation.FunctionSystem -> SystemTrait: "implements" { 
  style.stroke-dash: 3 
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

# -----------------------------------------------------------------------------
# 3. STORAGE & SCHEDULING (MEMORY ORIENTED)
# -----------------------------------------------------------------------------
SystemScheduler: {
  class: scheduler-box
  label: "SystemScheduler"
  
  storage: "Vec<Box<dyn System>>" {
    style.bold: true
    style.fill: "#FBE5D6"
  }
  
  slots: {
    grid-columns: 1
    grid-gap: 0
    s0: "[0]: Box<MovementSystem>" { style.fill: white }
    s1: "[1]: Box<CollisionSystem>" { style.fill: white }
    s2: "[2]: Box<AISystem>" { style.fill: white }
    s3: "[...]: Unallocated" { style.fill: "${colors.padding}"; style.stroke-dash: 2 }
  }
}

# Registration Flow
Registration: {
  label: "Registration Flow"
  direction: right
  r1: "add_system(M)"
  r2: "add_system(C)"
  r3: "add_system(A)"
  r1 -> r2 -> r3
}

Registration -> SystemScheduler.slots: "push_back()" {
  style.stroke: "#C55A11"
  style.stroke-width: 2
  style.animated: true
}

# -----------------------------------------------------------------------------
# 4. RUNTIME CONTROL
# -----------------------------------------------------------------------------
World: {
  class: world-box
  label: "World Context"
  
  state: {
    "scheduler": "SystemScheduler"
    "in_exec": "AtomicBool"
  }
  
  tick: "pub fn tick(&mut self, dt: f32)" {
    style.fill: "#C5E0B4"
    style.bold: true
  }
}

World.tick -> SystemScheduler: "1. Dispatch .run()" {
  style.stroke: "#538135"
  style.stroke-width: 3
}

# -----------------------------------------------------------------------------
# 5. EXECUTION TRACE (ALGORITHM STATE)
# -----------------------------------------------------------------------------
ExecutionTrace: {
  label: "Main Loop Sequence (per Frame)"
  step1: "1. set world.in_exec = true" { style.fill: "#FFF2CC" }
  step2: "2. foreach sys in scheduler.vec { sys.run(world, dt) }" { 
    style.fill: "#DEEBF7"
    style.bold: true
  }
  step3: "3. set world.in_exec = false" { style.fill: "#FFF2CC" }
  step4: "4. world.command_buffer.flush()" { style.fill: "#E2F0D9" }
  
  step1 -> step2 -> step3 -> step4: "Next Step"
}

SystemScheduler -> ExecutionTrace.step2: "Linear Iterator" {
  style.stroke-dash: 3
  style.stroke: "#C55A11"
}

# -----------------------------------------------------------------------------
# 6. MEMORY LAYOUT (BYTE LEVEL)
# -----------------------------------------------------------------------------
# FIXED: "near" set to constant "top-right" instead of object "SystemScheduler"
BoxedTraitObject: {
  label: "Box<dyn System> Memory Layout"
  near: top-right
  
  grid-columns: 3
  grid-gap: 0
  
  # Row 1: Header (Purple)
  h_off: "OFFSET" { style.stroke-width: 0; style.font-size: 10 }
  h_main: "Trait Object Fat Pointer" { 
    style.fill: "${colors.mem_header}"
    style.font-color: white
    style.bold: true
  }
  h_size: "SIZE" { style.stroke-width: 0; style.font-size: 10 }

  # Row 2: Data Pointer (Blue)
  p1_off: "0x00" { style.stroke-width: 0; style.font-size: 11; style.font: mono }
  p1_main: "Data Pointer (*mut ())" {
    style.fill: "${colors.data}"
    style.font-color: white
    tooltip: "Points to actual instance on Heap"
  }
  p1_size: "8 Bytes" { style.stroke-width: 0; style.font-size: 11; style.font: mono }

  # Row 3: Vtable Pointer (Orange)
  p2_off: "0x08" { style.stroke-width: 0; style.font-size: 11; style.font: mono }
  p2_main: "VTable Pointer (*const ())" {
    style.fill: "${colors.orange_ptr}"
    style.font-color: white
    tooltip: "Points to trait methods implementation (vtable)"
  }
  p2_size: "8 Bytes" { style.stroke-width: 0; style.font-size: 11; style.font: mono }

  footer: "sizeof=16 bytes (Double Word Alignment)" {
    style.stroke-width: 0
    style.font-size: 12
    style.italic: true
  }
}

# -----------------------------------------------------------------------------
# 7. CONSTRAINTS & ANNOTATIONS
# -----------------------------------------------------------------------------
SafetyNotice: |md
  ### Linear Execution Guarantees
  1. **Exclusivity**: `World` is mutably borrowed for the entire duration of `tick`.
  2. **Deferred Ops**: Systems cannot mutate World structure (spawn/despawn) 
     directly because the iterator over `systems` holds a reference.
  3. **Ordering**: Systems execute in the exact order of registration.
| {
  near: top-right
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
}

# -----------------------------------------------------------------------------
# 8. LEGEND
# -----------------------------------------------------------------------------
Legend: {
  near: bottom-right
  t: "Interface/Trait" { class: trait-box }
  s: "Concrete System" { class: system-box }
  c: "Controller/Manager" { class: scheduler-box }
}