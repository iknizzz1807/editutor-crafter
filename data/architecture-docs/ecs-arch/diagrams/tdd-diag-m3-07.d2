layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Smallest-Set Query Heuristic (ECS Optimization)
  **Target Query**: `Query<(&Position, &Velocity)>`
  **Rule**: Iterate the component set with minimum cardinality; perform random access lookups on the larger set.
|
title.shape: text
title.near: top-center

classes: {
  storage_box: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      border-radius: 8
    }
  }
  array_header: {
    style: {
      fill: "#2E86AB"
      font-color: white
      bold: true
      border-radius: 4
    }
  }
  dense_cell: {
    style: {
      fill: "#A8DADC"
      stroke: "#457B9D"
      border-radius: 2
    }
  }
  sparse_cell: {
    style: {
      fill: "#F1FAEE"
      stroke: "#A8DADC"
      stroke-dash: 2
      border-radius: 2
    }
  }
  empty_cell: {
    style: {
      fill: "#F0F0F0"
      stroke: "#CCCCCC"
      stroke-dash: 3
      font-color: "#999999"
    }
  }
  iteration_arrow: {
    style: {
      stroke: "#E63946"
      stroke-width: 3
      animated: true
    }
  }
  lookup_arrow: {
    style: {
      stroke: "#F4A261"
      stroke-width: 2
      stroke-dash: 5
    }
  }
  result_box: {
    style: {
      fill: "#E9C46A"
      stroke: "#F4A261"
      border-radius: 8
      shadow: true
    }
  }
  comparison_block: {
    style: {
      fill: "#264653"
      font-color: white
      border-radius: 6
    }
  }
}

# === POSITION STORAGE (Large Component Set) ===
position_storage: "Position Storage (Large Set)" {
  class: storage_box
  
  info: {
    shape: rectangle
    label: |md
      ### SparseSet<Position>
      - **Count**: 50,000 Entities
      - **Access**: Random O(1)
      - **Memory**: ~600KB Dense + Sparse Table
    |
    style: {
      fill: "#2E86AB"
      font-color: white
    }
  }

  sparse_array: "Sparse Array (Indirection Table)" {
    grid-columns: 5
    grid-gap: 4
    
    idx0: "Ent 0\n0x00\nVal: 0" {class: dense_cell; tooltip: "Points to Dense[0]"}
    idx1: "Ent 1\n0x04\nVal: 1" {class: dense_cell}
    idx2: "Ent 2\n0x08\nVal: 2" {class: dense_cell}
    idx3: "Ent 3\n0x0C\nVal: NULL" {class: empty_cell}
    idx_n: "Ent 49k\n0x...\nVal: 499" {class: dense_cell}
  }
  
  dense_array: "Dense Array (Packed Data)" {
    grid-columns: 5
    grid-gap: 10
    
    pos0: "Pos(0)\n{1.0, 1.0}\n12B" {class: dense_cell; style.fill: "#457B9D"; style.font-color: white}
    pos1: "Pos(1)\n{2.0, 2.0}\n12B" {class: dense_cell; style.fill: "#457B9D"; style.font-color: white}
    pos2: "Pos(2)\n{3.0, 3.0}\n12B" {class: dense_cell; style.fill: "#457B9D"; style.font-color: white}
    gap: "..." {shape: text}
    pos_n: "Pos(49k)\n{x, y}\n12B" {class: dense_cell; style.fill: "#457B9D"; style.font-color: white}
  }

  sparse_array.idx0 -> dense_array.pos0: "0x00 Offset" {
    style.stroke: orange
    style.stroke-width: 2
  }
}

# === VELOCITY STORAGE (Small Component Set) ===
velocity_storage: "Velocity Storage (Small Set)" {
  class: storage_box
  
  info: {
    shape: rectangle
    label: |md
      ### SparseSet<Velocity>
      - **Count**: 200 Entities
      - **Status**: SMALLEST (Source)
      - **Cache**: Fits in L1 Cache
    |
    style: {
      fill: "#E63946"
      font-color: white
    }
  }

  dense_vel: "Dense Velocity Data" {
    grid-columns: 5
    grid-gap: 10
    
    v0: "Vel(5)\n0x00" {class: dense_cell; style.fill: "#E63946"; style.font-color: white}
    v1: "Vel(42)\n0x0C" {class: dense_cell; style.fill: "#E63946"; style.font-color: white}
    v2: "Vel(100)\n0x18" {class: dense_cell; style.fill: "#E63946"; style.font-color: white}
    gap: "..." {shape: text}
    v_n: "Vel(48k)\n0x..." {class: dense_cell; style.fill: "#E63946"; style.font-color: white}
  }
  
  entities_list: "Entity ID Mapping" {
    grid-columns: 5
    e0: "ID: 5" {style.font-size: 10; style.bold: true}
    e1: "ID: 42" {style.font-size: 10; style.bold: true}
    e2: "ID: 100" {style.font-size: 10; style.bold: true}
    gap: "..." {shape: text}
    e_n: "ID: 48000" {style.font-size: 10; style.bold: true}
  }
}

# === QUERY ALGORITHM LOGIC ===
query_executor: "Query Executor Engine" {
  class: comparison_block
  
  logic: {
    shape: rectangle
    label: |md
      ### 1. Heuristic Calculation
      rust
      // Compare lengths to minimize iterations
      let (small, large) = if pos.len() < vel.len() { 
          (pos, vel) 
      } else { 
          (vel, pos) 
      };
      
      **Decision**: Velocity (200) < Position (50,000)

      ### 2. Contiguous Scan
      Iterate `&Velocity` linearly. High spatial locality.
      
      ### 3. Sparse Random Access
      For each `EntityID` from Velocity:
      1. `idx = pos_sparse[id]`
      2. `if idx != NULL: pos_dense[idx]`
    |
  }
}

# === COMPLEXITY & PERFORMANCE DATA ===
perf_metrics: "Performance Analysis" {
  class: result_box
  
  comparison: {
    shape: rectangle
    label: ||md
      | Strategy | Iters | Random Lookups | Latency |
      | :--- | :--- | :--- | :--- |
      | **Naive** | 50,000 | 50,000 | ~5.20ms |
      | **Heuristic** | 200 | 200 | **~0.02ms** |
      
      ### System Impact
      - **L1 Cache Hit**: >98% for Source.
      - **CPU Cycles**: Minimal branch misses.
      - **Gain**: ~250x throughput.
    ||
  }
}

# === CONNECTIONS ===

velocity_storage.dense_vel -> query_executor.logic: "Contiguous Stream" {
  style: {
    stroke: "#E63946"
    stroke-width: 3
    animated: true
  }
}

query_executor.logic -> position_storage.sparse_array: "Entity ID Lookup" {
  style: {
    stroke: "#F4A261"
    stroke-width: 2
    stroke-dash: 5
  }
}

query_executor -> perf_metrics: "Validation"

# === FINAL ANNOTATION ===
footer_note: |md
  **TDD Implementation Manual Ref (ECS-07):**
  - **Memory Alignment**: All indices are `u32` (4-byte alignment).
  - **Sizing**: Sparse arrays pre-allocated to `MAX_ENTITIES`.
  - **Dynamic State**: Re-evaluate heuristic if cardinality ratios cross 10% threshold.
|
footer_note.shape: text
footer_note.near: bottom-center
footer_note.style: {
  font-size: 11
  italic: true
  fill: "#F8F9FA"
  stroke: "#DEE2E6"
  border-radius: 8
}