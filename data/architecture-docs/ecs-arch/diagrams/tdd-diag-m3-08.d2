layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    mutable: "#E74C3C"
    immutable: "#3498DB"
    borrow-checker: "#2ECC71"
    position: "#9B59B6"
    velocity: "#E67E22"
    world-bg: "#F8F9FA"
    header-purple: "#8E44AD"
    data-blue: "#2980B9"
    padding-gray: "#BDC3C7"
  }
}

title: |md
  # Split Borrowing Pattern
  Simultaneous mutable and immutable storage access via type differentiation
| {near: top-center}

direction: right

World: {
  style.fill: ${colors.world-bg}
  style.stroke: "#BDC3C7"
  style.stroke-width: 2
  label: "World { components: ComponentRegistry }"
  
  ComponentRegistry: {
    label: "ComponentRegistry"
    style.fill: white
    style.stroke: "#95A5A6"
    
    storages: {
      label: "storages: HashMap<TypeId, Box<dyn ComponentStorage>>"
      shape: text
      style.font: mono
      style.font-size: 12
    }
  }
}

BorrowCheck: {
  style.fill: "#E8F8F5"
  style.stroke: ${colors.borrow-checker}
  style.stroke-width: 3
  style.border-radius: 8
  
  header: |md
    ### Borrow Checker Validation
  |
  
  rule1: |md
    ✓ `storage_mut::<Position>()`
    → `&mut SparseSet<Position>`
    → Mutable borrow of **different type**
  | {shape: text}
  
  rule2: |md
    ✓ `storage::<Velocity>()`  
    → `&SparseSet<Velocity>`
    → Immutable borrow of **different type**
  | {shape: text}
  
  rule3: |md
    ✓ **ALLOWED**: Different `TypeId` keys
    → No aliasing possible
    → Safe simultaneous access
  | {shape: text}
  
  rule1.style.font-color: ${colors.position}
  rule2.style.font-color: ${colors.velocity}
  rule3.style.font-color: ${colors.borrow-checker}
  rule3.style.bold: true
}

StorageAccess: {
  style.fill: white
  style.stroke: "#BDC3C7"
  
  PositionStorage: {
    label: "SparseSet<Position>"
    style.fill: "#F5EEF8"
    style.stroke: ${colors.position}
    style.stroke-width: 2
    
    layout: {
      shape: sql_table
      00: "sparse: Vec<usize>" {constraint: "Indices"}
      08: "dense: Vec<Position>" {constraint: "Data"}
      16: "entities: Vec<Entity>" {constraint: "Backlinks"}
    }
    
    mutable_indicator: "&mut" {
      shape: text
      style.font-color: ${colors.mutable}
      style.bold: true
      style.font-size: 16
      label.near: top-right
    }
  }
  
  VelocityStorage: {
    label: "SparseSet<Velocity>"
    style.fill: "#FEF5E7"
    style.stroke: ${colors.velocity}
    style.stroke-width: 2
    
    layout: {
      shape: sql_table
      00: "sparse: Vec<usize>" {constraint: "Indices"}
      08: "dense: Vec<Velocity>" {constraint: "Data"}
      16: "entities: Vec<Entity>" {constraint: "Backlinks"}
    }
    
    immutable_indicator: "&" {
      shape: text
      style.font-color: ${colors.immutable}
      style.bold: true
      style.font-size: 16
      label.near: top-right
    }
  }
}

CodeExample: {
  style.fill: "#2C3E50"
  style.border-radius: 8
  
  code: |rust
    fn movement_system(world: &mut World, dt: f32) {
        // Split borrowing: different types = safe
        let positions = world.storage_mut::<Position>().unwrap();
        let velocities = world.storage::<Velocity>().unwrap();
        
        // Simultaneous access allowed
        for (entity, pos) in positions.iter_mut_with_entity() {
            if let Some(vel) = velocities.get(entity) {
                pos.x += vel.dx * dt;  // Write to Position
                pos.y += vel.dy * dt;  // Read from Velocity
            }
        }
    }
  |
  code.style.font-color: "#ECF0F1"
}

KeyInsight: {
  style.fill: "#EBF5FB"
  style.stroke: ${colors.borrow-checker}
  style.stroke-width: 2
  style.border-radius: 8
  near: bottom-center
  
  insight: |md
    ## Why This Works
    **Rust's Borrow Rules:**
    - Cannot have `&mut T` and `&T` to the **same** `T` simultaneously
    - But `SparseSet<Position>` ≠ `SparseSet<Velocity>` (different types)
    
    **Type-Level Safety:**
    - `TypeId::of::<Position>()` ≠ `TypeId::of::<Velocity>()`
    - HashMap lookups return references to **different heap allocations**
    - No aliasing = borrow checker satisfied
  | {shape: text}
}

World -> BorrowCheck: "storage_mut::<Position>()\nstorage::<Velocity>()" {
  style.stroke-dash: 3
  style.stroke-width: 2
}

BorrowCheck -> StorageAccess.PositionStorage: "&mut SparseSet<Position>" {
  style.stroke: ${colors.position}
  style.stroke-width: 3
  target-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: ${colors.mutable}
  }
}

BorrowCheck -> StorageAccess.VelocityStorage: "&SparseSet<Velocity>" {
  style.stroke: ${colors.velocity}
  style.stroke-width: 3
  target-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: ${colors.immutable}
  }
}

StorageAccess.PositionStorage <-> StorageAccess.VelocityStorage: "Same loop iteration:\npos.x += vel.dx * dt" {
  style.stroke: ${colors.borrow-checker}
  style.stroke-width: 2
  style.stroke-dash: 5
  style.animated: true
  source-arrowhead: {
    label: "WRITE"
    shape: box
    style.fill: ${colors.mutable}
    style.font-color: white
  }
  target-arrowhead: {
    label: "READ"
    shape: box
    style.fill: ${colors.immutable}
    style.font-color: white
  }
}

legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#BDC3C7"
  
  mutable_legend: "&mut (Mutable)" {
    shape: text
    style.font-color: ${colors.mutable}
    style.bold: true
  }
  immutable_legend: "& (Immutable)" {
    shape: text
    style.font-color: ${colors.immutable}
    style.bold: true
  }
  safe_legend: "✓ Safe Access" {
    shape: text
    style.font-color: ${colors.borrow-checker}
    style.bold: true
  }
}