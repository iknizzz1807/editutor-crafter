vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # MovementSystem Integration Example
  Complete sequence: storage access → iteration → conditional update
|
# System entry point
movement_system: MovementSystem {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
# World container
world: World {
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  # Storage references obtained at system start
  storages: "Storage References" {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    pos_storage: "storage_mut::<Position>()\n&mut SparseSet<Position>"
    vel_storage: "storage::<Velocity>()\n&SparseSet<Velocity>"
    static_storage: "storage::<Static>()\nOption<&SparseSet<Static>>"
  }
  # The entities being processed
  entity_data: "Component Data" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    positions: "Position Dense Array\n[0]: (0.0, 0.0) e1\n[1]: (100.0, 100.0) e2\n[2]: (50.0, 50.0) e3"
    velocities: "Velocity Dense Array\n[0]: (10.0, 5.0) e1\n(no entry for e2)\n[1]: (10.0, 5.0) e3"
    statics: "Static Dense Array\n[0]: Static e3"
  }
}
# Sequence flow
movement_system -> world.storages.pos_storage: "1. Get mutable Position storage"
movement_system -> world.storages.vel_storage: "2. Get immutable Velocity storage"
movement_system -> world.storages.static_storage: "3. Get optional Static storage"
# Iteration phase
iteration: "Iteration Loop" {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  iter_start: "iter_mut_with_entity()\nover Position storage"
  step_e1: "Process Entity 1" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    check1: "statics.contains(e1)?\n→ false (skip check)"
    check1_vel: "velocities.get(e1)?\n→ Some((10.0, 5.0))"
    update1: "pos.x += vel.dx * dt\npos.y += vel.dy * dt\n→ (1.0, 0.5)"
  }
  step_e2: "Process Entity 2" {
    style.fill: "#FFECB3"
    style.stroke: "#FFA000"
    check2: "statics.contains(e2)?\n→ false (skip check)"
    check2_vel: "velocities.get(e2)?\n→ None"
    skip2: "SKIP: No Velocity component\nPosition unchanged: (100.0, 100.0)"
  }
  step_e3: "Process Entity 3" {
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    check3: "statics.contains(e3)?\n→ true"
    skip3: "SKIP: Has Static marker\nPosition unchanged: (50.0, 50.0)"
  }
  iter_end: "Loop complete"
}
world.storages.pos_storage -> iteration.iter_start: "4. Begin iteration"
iteration.iter_start -> iteration.step_e1.check1
iteration.step_e1.check1 -> iteration.step_e1.check1_vel
iteration.step_e1.check1_vel -> iteration.step_e1.update1
iteration.step_e1.update1 -> iteration.step_e2.check2
iteration.step_e2.check2 -> iteration.step_e2.check2_vel
iteration.step_e2.check2_vel -> iteration.step_e2.skip2
iteration.step_e2.skip2 -> iteration.step_e3.check3
iteration.step_e3.check3 -> iteration.step_e3.skip3
iteration.step_e3.skip3 -> iteration.iter_end
# Results summary
results: "Final Results" {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  result_e1: "e1: Position(1.0, 0.5)\n✓ Updated"
  result_e2: "e2: Position(100.0, 100.0)\n○ Unchanged (no Velocity)"
  result_e3: "e3: Position(50.0, 50.0)\n○ Unchanged (Static marker)"
}
iteration.iter_end -> results
# Legend
legend: |md
  ## Decision Flow
  **For each entity with Position:**
  1. Check Static marker → skip if present
  2. Check Velocity component → skip if absent
  3. Update: `pos += vel * dt`
  **Cache efficiency:**
  - Position iteration: sequential
  - Velocity lookup: O(1) sparse array
  - Static check: O(1) sparse array
| {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
}
# Performance note
perf_note: |md
  **dt = 0.1 seconds**
  Update formula:
  
  pos.x += vel.dx * 0.1
  pos.y += vel.dy * 0.1
  
| {
  near: top-right
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  style.stroke-dash: 3
}