direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B46C1"
    entity: "#3182CE"
    entity_bg: "#E1EFFE"
    position: "#38A169"
    position_bg: "#DEF7EC"
    velocity: "#DD6B20"
    velocity_bg: "#FEF3C7"
    cache-line: "#718096"
    cache_bg: "#F3F4F6"
    invariant_bg: "#F5F3FF"
    label: "#2D3748"
    bg: "#F7FAFC"
  }
}

title: ||md
  # Archetype Table Memory Layout
  **Architecture**: Parallel Columnar Storage (SoA - Structure of Arrays)
  **Archetype**: `(EntityID, Position, Velocity)`
|| {near: top-center}

container: "Archetype Table: [Position; Velocity]" {
  style: {
    fill: "${colors.bg}"
    stroke: "${colors.header}"
    stroke-width: 4
    border-radius: 8
  }
  direction: right

  entities: "Column 0: Entity IDs (4B per element)" {
    style: {
      fill: "${colors.entity_bg}"
      stroke: "${colors.entity}"
      stroke-width: 2
      border-radius: 4
    }
    header_entities: ||md
      ### entities
      `Vec<u32>`
    || {
      style: {
        fill: "${colors.entity}"
        font-color: white
        bold: true
        border-radius: 4
      }
    }
    e0: "0x00 | E1 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    e1: "0x04 | E2 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    e2: "0x08 | E3 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    e3: "0x0C | E4 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    e4: "0x10 | E5 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    e5: "0x14 | E6 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    e6: "0x18 | E7 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    e7: "0x1C | E8 (4B)" {
      style.fill: "${colors.entity}"
      style.font-color: white
      style.bold: true
    }
    header_entities -> e0 -> e1 -> e2 -> e3 -> e4 -> e5 -> e6 -> e7: {style.opacity: 0}
  }

  positions: "Column 1: Positions (8B per element)" {
    style: {
      fill: "${colors.position_bg}"
      stroke: "${colors.position}"
      stroke-width: 2
      border-radius: 4
      stroke-dash: 5
    }
    header_pos: ||md
      ### positions
      `Vec<f32; 2>`
    || {
      style: {
        fill: "${colors.position}"
        font-color: white
        bold: true
        border-radius: 4
      }
    }
    p0: "0x00 | [1.0, 2.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    p1: "0x08 | [3.0, 4.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    p2: "0x10 | [5.0, 6.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    p3: "0x18 | [7.0, 8.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    p4: "0x20 | [9.0, 10.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    p5: "0x28 | [11.0, 12.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    p6: "0x30 | [13.0, 14.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    p7: "0x38 | [15.0, 16.0] (8B)" {
      style.fill: "${colors.position}"
      style.font-color: white
      style.bold: true
    }
    header_pos -> p0 -> p1 -> p2 -> p3 -> p4 -> p5 -> p6 -> p7: {style.opacity: 0}
  }

  velocities: "Column 2: Velocities (8B per element)" {
    style: {
      fill: "${colors.velocity_bg}"
      stroke: "${colors.velocity}"
      stroke-width: 2
      border-radius: 4
      stroke-dash: 5
    }
    header_vel: ||md
      ### velocities
      `Vec<f32; 2>`
    || {
      style: {
        fill: "${colors.velocity}"
        font-color: white
        bold: true
        border-radius: 4
      }
    }
    v0: "0x00 | [10, 5] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    v1: "0x08 | [20, 10] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    v2: "0x10 | [30, 15] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    v3: "0x18 | [40, 20] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    v4: "0x20 | [50, 25] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    v5: "0x28 | [60, 30] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    v6: "0x30 | [70, 35] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    v7: "0x38 | [80, 40] (8B)" {
      style.fill: "${colors.velocity}"
      style.font-color: white
      style.bold: true
    }
    header_vel -> v0 -> v1 -> v2 -> v3 -> v4 -> v5 -> v6 -> v7: {style.opacity: 0}
  }

  entities.e0 -> positions.p0 -> velocities.v0: {style.opacity: 0}
}

cache_line_0: ||md
  ## Hardware Cache Line Efficiency
  - **Entity ID**: 32 bytes utilized (0x00-0x1F) for 8 entities per batch.
  - **Position Data**: 64 bytes total (0x00-0x3F). Perfect cache line alignment.
  - **Velocity Data**: 64 bytes total (0x00-0x3F). Perfect cache line alignment.
  - **Prefetcher**: High predictability. CPU prefetcher loads subsequent columns efficiently.
  - **SIMD**: 8x f32 elements (4 positions) fit into a single 256-bit AVX register.
|| {
  near: top-right
  style: {
    fill: "${colors.cache_bg}"
    stroke: "${colors.cache-line}"
    stroke-dash: 3
    border-radius: 4
  }
}

invariant: ||md
  ### Data Consistency Invariant
  For any row index **i**:
  - `entities[i]` provides the Unique ID.
  - `positions[i]` provides spatial coordinates.
  - `velocities[i]` provides movement vector.
  
  Indices across all vectors are kept perfectly in sync via internal table management.
|| {
  near: bottom-right
  style: {
    fill: "${colors.invariant_bg}"
    stroke: "${colors.header}"
    border-radius: 4
  }
}

stats: ||md
  ### Memory Footprint (N=100,000)
  | Component | Bytes/Entity | Total Column Size |
  | :--- | :--- | :--- |
  | Entity ID | 4 B | 400.0 KB |
  | Position (x,y) | 8 B | 800.0 KB |
  | Velocity (dx,dy) | 8 B | 800.0 KB |
  | **Table Total** | **20 B** | **2.0 MB** |

  *Alignment: All columns aligned to 64-byte boundaries.*
|| {
  near: center-right
  style: {
    fill: "#FFFFFF"
    stroke: "${colors.cache-line}"
    border-radius: 4
  }
}

growth: ||md
  **Memory Growth Direction**
  Low Address [Index 0] ➔ High Address [Index N]
  (Vectors reside in contiguous heap-allocated segments)
|| {
  near: bottom-center
  style: {
    fill: "transparent"
    font-color: "${colors.cache-line}"
    italic: true
  }
}