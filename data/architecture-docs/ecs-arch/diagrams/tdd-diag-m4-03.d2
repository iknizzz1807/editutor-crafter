vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Iteration Memory Access: Sparse Set vs Archetype
  ### Cache Locality Comparison for 100K Entity Query
| {near: top-center}
direction: right
# ============================================
# SPARSE SET APPROACH (LEFT SIDE)
# ============================================
sparse_set: {
  label: "Sparse Set Storage\n(Per-Type Sparse Sets)"
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
  entity_loop: {
    label: "For each entity in query"
    shape: rectangle
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 2
  }
  step1: {
    label: "1. Sparse Lookup A"
    shape: rectangle
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
    sparse_a: {
      label: |md
        **sparse_a[entity.index]**
        
        Array Access (random)
        Address: base + index × 8
        
      |
      shape: rectangle
      style.fill: "#FFAB91"
    }
    cycle1: {
      label: |md
        **~40-100 cycles**
        (L3 cache or miss)
      |
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.bold: true
    }
  }
  step2: {
    label: "2. Dense Access A"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    dense_a: {
      label: |md
        **dense_a[sparse_idx]**
        
        Array Access (random)
        Position data at offset
        
      |
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    cycle2: {
      label: |md
        **~4-10 cycles**
        (L1/L2 hit likely)
      |
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.bold: true
    }
  }
  step3: {
    label: "3. Sparse Lookup B"
    shape: rectangle
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
    sparse_b: {
      label: |md
        **sparse_b[entity.index]**
        
        Array Access (random)
        Different array entirely
        
      |
      shape: rectangle
      style.fill: "#FFAB91"
    }
    cycle3: {
      label: |md
        **~40-100 cycles**
        (likely cache miss)
      |
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.bold: true
    }
  }
  step4: {
    label: "4. Dense Access B"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    dense_b: {
      label: |md
        **dense_b[sparse_idx]**
        
        Array Access (random)
        Velocity data at offset
        
      |
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    cycle4: {
      label: |md
        **~4-10 cycles**
        (L1/L2 hit likely)
      |
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.bold: true
    }
  }
  entity_loop -> step1
  step1 -> step2
  step2 -> step3
  step3 -> step4
}
# ============================================
# ARCHETYPE APPROACH (RIGHT SIDE)
# ============================================
archetype: {
  label: "Archetype Storage\n(Entity Grouping by Signature)"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  archetype_loop: {
    label: "For each row in archetype"
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    style.stroke-width: 2
  }
  arch_step1: {
    label: "1. Column A Access"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    column_a: {
      label: |md
        **positions[row]**
        
        Sequential Array Access
        positions + row × sizeof(Position)
        
      |
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    arch_cycle1: {
      label: |md
        **~4 cycles**
        (L1 hit, prefetcher active)
      |
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.bold: true
    }
  }
  arch_step2: {
    label: "2. Column B Access"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    column_b: {
      label: |md
        **velocities[row]**
        
        Sequential Array Access
        velocities + row × sizeof(Velocity)
        
      |
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    arch_cycle2: {
      label: |md
        **~4 cycles**
        (L1 hit, prefetcher active)
      |
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.bold: true
    }
  }
  prefetch_note: {
    label: |md
      **CPU Prefetcher Benefits:**
      - Detects sequential pattern after 2-3 accesses
      - Pre-loads cache lines ahead of access
      - 64-byte cache line = 8 × Position components
      - Processes 8 entities per cache line load
    |
    shape: rectangle
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
    style.stroke-dash: 3
  }
  archetype_loop -> arch_step1
  arch_step1 -> arch_step2
  arch_step2 -> prefetch_note
}
# ============================================
# COMPARISON SUMMARY
# ============================================
comparison: {
  label: "Performance Comparison (100K entities)"
  style.fill: "#F5F5F5"
  style.stroke: "#424242"
  style.stroke-width: 2
  sparse_total: {
    label: |md
      ### Sparse Set Total
      **Per entity: ~88-220 cycles**
      - 2 sparse lookups: 80-200 cycles
      - 2 dense accesses: 8-20 cycles
      **100K entities: ~8.8-22M cycles**
      (~3-7ms at 3GHz)
    |
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.bold: true
  }
  arch_total: {
    label: |md
      ### Archetype Total
      **Per entity: ~8 cycles**
      - 2 column accesses: 8 cycles
      - Zero indirection overhead
      **100K entities: ~0.8M cycles**
      (~0.27ms at 3GHz)
    |
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.bold: true
  }
  speedup: {
    label: |md
      ### Archetype Speedup
      **10-27x faster** for iteration
      (Sparse set wins on add/remove)
    |
    shape: rectangle
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 3
    style.bold: true
  }
  sparse_total -> speedup
  arch_total -> speedup
}
# ============================================
# MEMORY LAYOUT VISUALIZATION
# ============================================
memory_layout: {
  label: "Memory Access Patterns"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  sparse_mem: {
    label: "Sparse Set Memory Layout"
    style.fill: "#FFEBEE"
    sparse_array: {
      label: |md
        **sparse[0..N]** (8MB for 1M entities)
        `[EMPTY][0][EMPTY][1][EMPTY][2]...`
        Random access pattern ❌
      |
      style.fill: "#FFCDD2"
    }
    dense_array: {
      label: |md
        **dense[0..M]** (contiguous)
        `[Pos₀][Pos₁][Pos₂]...`
        Sequential access ✓ (but via indirection)
      |
      style.fill: "#C8E6C9"
    }
    sparse_array -> dense_array: "indirect\nlookup" {
      style.stroke: "#E53935"
      style.stroke-dash: 3
      style.bold: true
    }
  }
  arch_mem: {
    label: "Archetype Memory Layout"
    style.fill: "#E3F2FD"
    position_col: {
      label: |md
        **positions[0..N]** (contiguous)
        `[P₀][P₁][P₂][P₃][P₄][P₅][P₆][P₇]...`
        Sequential access ✓ (8 per cache line)
      |
      style.fill: "#BBDEFB"
    }
    velocity_col: {
      label: |md
        **velocities[0..N]** (contiguous)
        `[V₀][V₁][V₂][V₃][V₄][V₅][V₆][V₇]...`
        Sequential access ✓ (8 per cache line)
      |
      style.fill: "#BBDEFB"
    }
    position_col -> velocity_col: "same row\nsame entity" {
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
  }
}
# ============================================
# CONNECT ELEMENTS
# ============================================
sparse_set -> comparison.sparse_total
archetype -> comparison.arch_total
comparison -> memory_layout
legend: {
  label: |md
    **Legend:**
    🟢 Green = Cache-friendly (sequential)
    🔴 Red = Cache-hostile (random/indirection)
    🟡 Yellow = Control flow / Mixed
  |
  near: bottom-center
  shape: rectangle
  style.fill: "#FFFFFF"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 2
}