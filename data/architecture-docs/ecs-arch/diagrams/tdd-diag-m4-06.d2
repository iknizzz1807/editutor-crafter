layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: ||md
  # Archetype Storage & Entity Migration Logic
  ### Data-Oriented Design: Component Signature Grouping & Memory Layout
| {
  near: top-center
  style.font-size: 24
}

# --- COMPONENT DEFINITIONS (MEMORY ALIGNMENT) ---
# Precise byte layouts for engineering implementation
components: "Component Memory Definitions" {
  style.fill: "#F8F9FA"
  
  pos: "struct Position" {
    shape: sql_table
    style.fill: "#BBDEFB"
    offset_0: "x: float32" {constraint: "4 bytes"}
    offset_4: "y: float32" {constraint: "4 bytes"}
    size: "sizeof = 8 bytes"
  }
  
  vel: "struct Velocity" {
    shape: sql_table
    style.fill: "#C8E6C9"
    offset_0: "dx: float32" {constraint: "4 bytes"}
    offset_4: "dy: float32" {constraint: "4 bytes"}
    size: "sizeof = 8 bytes"
  }
  
  health: "struct Health" {
    shape: sql_table
    style.fill: "#FFCDD2"
    offset_0: "hp: uint16" {constraint: "2 bytes"}
    offset_2: "padding: uint16" {constraint: "2 bytes (aligned)"}
    size: "sizeof = 4 bytes"
  }

  ai: "struct AIState" {
    shape: sql_table
    style.fill: "#E1BEE7"
    offset_0: "state: enum8" {constraint: "1 byte"}
    offset_1: "padding: uint8[3]" {constraint: "3 bytes (aligned)"}
    size: "sizeof = 4 bytes"
  }
}

# --- ENTITIES REGISTRY ---
entities_registry: "Entities Registry (Sparse Set)" {
  style.fill: "#F5F5F5"
  
  Entity_0: { 
    shape: hexagon
    label: "EID: 0"
    style.fill: "#B8D4E8" 
  }
  Entity_4: { 
    shape: hexagon
    label: "EID: 4"
    style.fill: "#E1DBFE" 
  }
  Entity_6: { 
    shape: hexagon
    label: "EID: 6"
    style.fill: "#F4DBFE" 
  }
  
  note: "Maps EntityID -> (ArchetypeID, RowIndex)" {
    shape: text
    style.italic: true
  }
}

# --- ARCHETYPE GRAPH (THE STORAGE TABLES) ---

archetypes: "Archetype Graph & Storage Tables" {
  
  empty: "Archetype [Ø]\n(Null Signature)" {
    shape: rectangle
    style.fill: "#EEEEEE"
    style.stroke-dash: 3
  }

  pos_only: "Archetype [Pos]\n(ID: 0x1)" {
    style.fill: "#E8F4E8"
    header: "Columnar Store: Position"
    table: |md
      | Row | Entity ID | x (f32) | y (f32) |
      | :-- | :--- | :--- | :--- |
      | 0 | 0 | 12.5 | 44.0 |
      | 1 | 1 | 0.0 | -1.2 |
    ||
# REMOVED (extra closing brace):   }

  pos_vel: "Archetype [Pos, Vel]\n(ID: 0x3)" {
    style.fill: "#B8D4E8"
    
    pos_col: "Column: Position" {
      shape: sql_table
      r0: "1.0, 1.0"
      r1: "8.0, 4.0"
    }
    
    vel_col: "Column: Velocity" {
      shape: sql_table
      r0: "1.0, 0.0"
      r1: "0.5, 0.5"
    }
    
    footer: "Dense packing: No gaps between Row 0 and 1" {shape: text}
  }

  full_entity: "Archetype [Pos, Vel, Health]\n(ID: 0x7)" {
    style.fill: "#C8F4E8"
    
    pos_col: "Column: Position" {
      shape: sql_table
      r0: "3.0, 6.0"
    }
    
    health_col: "Column: Health" {
      shape: sql_table
      r0: "100 HP"
    }
  }

  ai_entity: "Archetype [Pos, Vel, AI]\n(ID: 0xB)" {
    style.fill: "#F4DBFE"
    
    ai_col: "Column: AIState" {
      shape: sql_table
      r0: "IDLE"
      r1: "CHASE"
    }
  }

  # Transitions
  empty -> pos_only: "Add(Position)" {
    style.stroke: "#2E7D32"
    style.stroke-width: 3
  }

  pos_only -> pos_vel: "Add(Velocity)" {
    style.stroke: "#2E7D32"
    style.stroke-width: 3
  }

  pos_vel -> full_entity: "Add(Health)" {
    style.stroke: "#1565C0"
    style.stroke-width: 3
  }

  pos_vel -> ai_entity: "Add(AIState)" {
    style.stroke: "#6A1B9A"
    style.stroke-width: 3
  }

  full_entity -> pos_vel: "Remove(Health)" {
    style.stroke: "#1565C0"
    style.stroke-dash: 5
  }

  ai_entity -> pos_vel: "Remove(AIState)" {
    style.stroke: "#6A1B9A"
    style.stroke-dash: 5
  }
# REMOVED (extra closing brace): }

# --- ALGORITHM SPECIFICATION ---
migration_logic: "Internal Procedure: Migration(Entity E, Archetype Target)" {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  style.double-border: true
  
  content: |md
    ### Step-by-Step Logic for Engineers
    1. **Lock** Archetype Source and Target mutexes.
    2. **Locate** Row $i$ in Source via `EntityRegistry`.
    3. **Allocate** Row $j$ in Target (expand `vector<T>` if needed).
    4. **Memcpy** intersection of component data:
       - `Target[j].Pos = Source[i].Pos`
       - `Target[j].Vel = Source[i].Vel`
    "5. **Initialize** New Component": "`Target[j].NewComp = Default`."
    6. **Defragment Source**:
       - `LastEntity = ArchetypeSource.Entities.back()`
       - `ArchetypeSource.Table[i] = ArchetypeSource.Table.back()`
       - `EntityRegistry[LastEntity].RowIndex = i`
       - `ArchetypeSource.Table.pop_back()`
    "7. **Update Registry**": "`EntityRegistry[E] = {Target, j}`."
  |
}

# --- CROSS-CONTAINER REFERENCES ---
entities_registry.Entity_0 -> archetypes.pos_only: "ptr: ArchetypeID=1, Row=0" { 
  style.stroke: orange 
  style.stroke-width: 2
}
entities_registry.Entity_4 -> archetypes.pos_vel: "ptr: ArchetypeID=3, Row=1" { 
  style.stroke: orange 
  style.stroke-width: 2
}
entities_registry.Entity_6 -> archetypes.full_entity: "ptr: ArchetypeID=7, Row=0" { 
  style.stroke: orange 
  style.stroke-width: 2
}

# --- LEGEND ---
legend: "Legend & Status" {
  near: bottom-right
  
  arch: "Archetype (Signature-Matched Table)" {
    style.fill: "#E8F4E8"
  }
  add: "Structural Addition (New Table Migration)" {
    shape: text
    style.font-color: "#2E7D32"
    style.bold: true
  }
  rem: "Structural Removal (Table Migration)" {
    shape: text
    style.font-color: "#1565C0"
    style.stroke-dash: 3
  }
  ptr: "Entity Lookup Pointer" {
    shape: text
    style.font-color: orange
  }
}