vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Entity Migration Flow
    ### Archetype-Based Storage: Component Addition
  |
  near: top-center
}

direction: right

# Global Classes for reuse across containers
classes: {
  header_cell: {
    style: {
      fill: "#2E86AB"
      font-color: white
      bold: true
    }
  }
  data_cell: {
    style: {
      fill: "#F8F9FA"
    }
  }
  data_cell_highlight: {
    style: {
      fill: "#FF6B6B"
      font-color: white
      bold: true
    }
  }
  target_header_class: {
    style: {
      fill: "#28A745"
      font-color: white
      bold: true
    }
  }
  target_allocated: {
    style: {
      fill: "#28A745"
      font-color: white
      bold: true
    }
  }
  target_pending: {
    style: {
      fill: "#FFF3CD"
      font-color: "#856404"
      italic: true
    }
  }
  swap_remove: {
    style: {
      fill: "#721C24"
      font-color: white
      bold: true
    }
  }
  swap_moved: {
    style: {
      fill: "#FFC107"
      bold: true
    }
  }
}

# ============================================
# STEP 1: Get Current Location
# ============================================
step1_container: {
  label: "STEP 1: Get Current Location"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2

  step1_title: "1" {
    shape: circle
    style.fill: "#2E86AB"
    style.font-color: white
    style.stroke: "#1a5276"
  }

  step1_desc: {
    shape: rectangle
    label: |md
      **Entity Migration Begins**
      `location ← entity_locations.get(entity)`
      - Extract current `(archetype_id, row)`
      - Validate entity exists
      - Prepare for transition
    |
    style.stroke-width: 0
    style.fill: transparent
  }

  before_container: {
    label: "BEFORE: Entity in Source Archetype"
    style.fill: white
    style.stroke: "#666"
    style.stroke-dash: 2

    source_arch_label: "Source Archetype A" {
      shape: text
      style.bold: true
      style.font-color: "#2E86AB"
    }

    source_table: {
      label: ""
      shape: rectangle
      source_header: {
        grid-columns: 4
        grid-gap: 0
        h1: "Row" {class: header_cell}
        h2: "Entity" {class: header_cell}
        h3: "Pos" {class: header_cell}
        h4: "Vel" {class: header_cell}
      }
      source_row0: {
        grid-columns: 4
        grid-gap: 0
        r0_0: "0" {class: data_cell}
        r0_1: "E1" {class: data_cell}
        r0_2: "(1,2)" {class: data_cell}
        r0_3: "(1,0)" {class: data_cell}
      }
      source_row1: {
        grid-columns: 4
        grid-gap: 0
        r1_0: "1" {class: data_cell_highlight}
        r1_1: "E2" {class: data_cell_highlight}
        r1_2: "(3,4)" {class: data_cell_highlight}
        r1_3: "(2,0)" {class: data_cell_highlight}
      }
      source_row2: {
        grid-columns: 4
        grid-gap: 0
        r2_0: "2" {class: data_cell}
        r2_1: "E3" {class: data_cell}
        r2_2: "(5,6)" {class: data_cell}
        r2_3: "(3,0)" {class: data_cell}
      }
    }
    location_box: "EntityLocation[E2] = (Archetype A, row=1)" {
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
      style.bold: true
    }
  }
}

# ============================================
# STEP 2: Find Target Archetype
# ============================================
step2_container: {
  label: "STEP 2: Find Target Archetype"
  style.fill: "#D4EDDA"
  style.stroke: "#28A745"
  style.stroke-width: 2

  step2_title: "2" {
    shape: circle
    style.fill: "#28A745"
    style.font-color: white
    style.stroke: "#1e7e34"
  }

  step2_desc: {
    shape: rectangle
    label: |md
      **Graph Edge Lookup**
      `target_id ← graph.get_add(source_id, type_id)`
      - O(1) cached edge lookup
      - If miss: compute signature + create
      - Returns: Archetype B = (Pos, Vel, Health)
    |
    style.stroke-width: 0
    style.fill: transparent
  }

  graph_container: {
    label: "Archetype Graph (Cached Edges)"
    style.fill: white
    style.stroke: "#666"
    
    node_empty: "()" {
      shape: circle
      style.fill: "#E9ECEF"
    }
    node_pos: "(Pos)" {
      shape: circle
      style.fill: "#E9ECEF"
    }
    node_pos_vel: "(Pos,Vel)\nSource A" {
      shape: circle
      style.fill: "#FF6B6B"
      style.font-color: white
      style.bold: true
    }
    node_pos_vel_hp: "(Pos,Vel,Hp)\nTarget B" {
      shape: circle
      style.fill: "#28A745"
      style.font-color: white
      style.bold: true
    }
    node_empty -> node_pos: "+Pos" {
      style.stroke: "#999"
      style.stroke-dash: 2
    }
    node_pos -> node_pos_vel: "+Vel" {
      style.stroke: "#999"
      style.stroke-dash: 2
    }
    node_pos_vel -> node_pos_vel_hp: "+Health\n[CACHE HIT]" {
      style.stroke: "#28A745"
      style.stroke-width: 3
      style.bold: true
      style.animated: true
    }
  }

  edge_detail: {
    label: |md
      **Edge Key:** `(A, Health, add)`
      **Edge Value:** `Archetype B`
      First lookup: O(n) signature compute
      Subsequent: O(1) HashMap get
    |
    shape: rectangle
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
  }
}

# ============================================
# STEP 3: Allocate Row in Target
# ============================================
step3_container: {
  label: "STEP 3: Allocate Row in Target"
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  style.stroke-width: 2

  step3_title: "3" {
    shape: circle
    style.fill: "#856404"
    style.font-color: white
    style.stroke: "#533f03"
  }

  step3_desc: {
    shape: rectangle
    label: |md
      **Push Entity to Target**
      `target_row ← target.push_entity(entity)`
      - Append to entities array
      - Reserve space in all columns
      - Returns: new row index
    |
    style.stroke-width: 0
    style.fill: transparent
  }

  target_container: {
    label: "Target Archetype B: (Pos, Vel, Health)"
    style.fill: white
    style.stroke: "#666"
    style.stroke-dash: 2

    target_table: {
      label: ""
      shape: rectangle
      target_header: {
        grid-columns: 5
        grid-gap: 0
        th0: "Row" {class: target_header_class}
        th1: "Entity" {class: target_header_class}
        th2: "Pos" {class: target_header_class}
        th3: "Vel" {class: target_header_class}
        th4: "Hp" {class: target_header_class}
      }
      target_row0: {
        grid-columns: 5
        grid-gap: 0
        tr0_0: "0" {style.fill: "#F8F9FA"}
        tr0_1: "E5" {style.fill: "#F8F9FA"}
        tr0_2: "(7,8)" {style.fill: "#F8F9FA"}
        tr0_3: "(5,0)" {style.fill: "#F8F9FA"}
        tr0_4: "100" {style.fill: "#F8F9FA"}
      }
      target_row1: {
        grid-columns: 5
        grid-gap: 0
        tr1_0: "1" {class: target_allocated}
        tr1_1: "E2\n← ALLOCATED" {class: target_allocated}
        tr1_2: "???" {class: target_pending}
        tr1_3: "???" {class: target_pending}
        tr1_4: "???" {class: target_pending}
      }
    }
  }
}

# ============================================
# STEP 4: Copy Shared Components
# ============================================
step4_container: {
  label: "STEP 4: Copy Shared Components"
  style.fill: "#E2E3E5"
  style.stroke: "#383D41"
  style.stroke-width: 2

  step4_title: "4" {
    shape: circle
    style.fill: "#6C757D"
    style.font-color: white
    style.stroke: "#495057"
  }

  step4_desc: {
    shape: rectangle
    label: |md
      **Clone Components to Target**
      for type_id in source.signature():
        if target.signature().contains(type_id):
          component ← source.get(type_id, row)
          target.push_raw(cloned)
    |
    style.stroke-width: 0
    style.fill: transparent
  }

  copy_flow: {
    label: ""
    shape: rectangle
    source_mini: "Source[A]\nRow 1" {
      style.fill: "#FF6B6B"
      style.font-color: white
    }
    arrow_copy: "clone_fn" {
      shape: text
      style.bold: true
    }
    target_mini: "Target[B]\nRow 1" {
      style.fill: "#28A745"
      style.font-color: white
    }
    source_mini -> arrow_copy -> target_mini: {
      style.stroke: "#6C757D"
      style.stroke-width: 2
      style.animated: true
    }
  }
}

# ============================================
# STEP 5: Insert Added Component
# ============================================
step5_container: {
  label: "STEP 5: Insert Added Component"
  style.fill: "#CCE5FF"
  style.stroke: "#004085"
  style.stroke-width: 2

  step5_title: "5" {
    shape: circle
    style.fill: "#004085"
    style.font-color: white
    style.stroke: "#002752"
  }

  final_target: {
    label: "Target Archetype B: Complete"
    style.fill: white
    style.stroke: "#28A745"
    style.stroke-width: 3
    final_table: {
      label: ""
      shape: rectangle
      final_header: {
        grid-columns: 5
        grid-gap: 0
        fh0: "Row" {style.fill: "#004085"; style.font-color: white; style.bold: true}
        fh1: "Entity" {style.fill: "#004085"; style.font-color: white; style.bold: true}
        fh2: "Pos" {style.fill: "#004085"; style.font-color: white; style.bold: true}
        fh3: "Vel" {style.fill: "#004085"; style.font-color: white; style.bold: true}
        fh4: "Hp" {style.fill: "#004085"; style.font-color: white; style.bold: true}
      }
      final_row1: {
        grid-columns: 5
        grid-gap: 0
        fr1_0: "1" {style.fill: "#28A745"; style.font-color: white}
        fr1_1: "E2" {style.fill: "#28A745"; style.font-color: white}
        fr1_2: "(3,4)" {style.fill: "#28A745"; style.font-color: white}
        fr1_3: "(2,0)" {style.fill: "#28A745"; style.font-color: white}
        fr1_4: "75\nNEW!" {style.fill: "#004085"; style.font-color: white; style.bold: true}
      }
    }
  }
}

# ============================================
# STEP 6: Swap-Remove from Source
# ============================================
step6_container: {
  label: "STEP 6: Swap-Remove from Source"
  style.fill: "#F8D7DA"
  style.stroke: "#721C24"
  style.stroke-width: 2

  step6_title: "6" {
    shape: circle
    style.fill: "#721C24"
    style.font-color: white
    style.stroke: "#4a1018"
  }

  swap_flow: {
    label: ""
    before_swap: {
      label: "BEFORE Swap"
      style.fill: "#F8D7DA"
      bs_table: {
        grid-columns: 1
        bs1: "Row 1: E2 ← REMOVE" {class: swap_remove}
        bs2: "Row 2: E3" {style.fill: "#F8F9FA"}
      }
    }
    after_swap: {
      label: "AFTER Swap"
      style.fill: "#D4EDDA"
      as_table: {
        grid-columns: 1
        as1: "Row 1: E3 ← MOVED" {class: swap_moved}
        as2: "Row 2: E2 (popped)" {style.fill: "#E9ECEF"; style.font-color: "#999"}
      }
    }
    before_swap -> after_swap: "swap-pop"
  }
}

# ============================================
# STEP 7: Update Locations
# ============================================
step7_container: {
  label: "STEP 7: Update EntityLocations"
  style.fill: "#D4EDDA"
  style.stroke: "#155724"
  style.stroke-width: 3

  step7_title: "7" {
    shape: circle
    style.fill: "#155724"
    style.font-color: white
    style.stroke: "#0d3618"
  }

  location_updates: {
    grid-columns: 2
    grid-gap: 30
    update_swapped: "Update E3 (swapped)" {
      label: "E3: (A, 2) → (A, 1)"
      style.fill: "#FFF3CD"
    }
    update_migrated: "Update E2 (migrated)" {
      label: "E2: (A, 1) → (B, 1)"
      style.fill: "#D4EDDA"
    }
  }

  final_summary: {
    label: |md
      ## ✓ Migration Complete
      Entity E2 moved to Archetype B.
      Archetype A maintained via Swap-and-Pop.
    |
    shape: rectangle
    style.fill: "#D4EDDA"
  }
}

# ============================================
# Flow Arrows Between Steps
# ============================================
step1_container -> step2_container: {style.stroke-width: 2}
step2_container -> step3_container: {style.stroke-width: 2}
step3_container -> step4_container: {style.stroke-width: 2}
step4_container -> step5_container: {style.stroke-width: 2}
step5_container -> step6_container: {style.stroke-width: 2}
step6_container -> step7_container: {style.stroke-width: 2}

# ============================================
# Complexity Summary
# ============================================
complexity_box: {
  label: |md
    ## Migration Complexity
    - Find Target: O(1)
    - Allocation: O(1)
    - Component Copy: **O(N)**
    - Cleanup: O(1)
  |
  near: bottom-center
  shape: rectangle
  style.fill: "#E9ECEF"
  style.stroke-width: 2
}