vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B4C8A"
    data: "#4A90A4"
    free: "#8BC34A"
    padding: "#9E9E9E"
    pointer: "#FF9800"
    changed: "#E53935"
    text-light: "#FFFFFF"
    text-dark: "#1A1A1A"
  }
}
title: |md
  # Entity Migration: Before and After
| {near: top-center}
# Step 1: Before Migration
step1: {
  label: "BEFORE\n\nEntity E at Archetype A\nRow 5"
  arch_a_before: {
    label: "Archetype A\n(Position, Velocity)"
    style.fill: "${colors.header}"
    style.stroke: "${colors.text-dark}"
    row5_before: {
      label: "Row 5\nEntity E"
      style.fill: "${colors.changed}"
      style.bold: true
    }
    row6_before: {
      label: "Row 6\nEntity F"
      style.fill: "${colors.data}"
    }
    row7_before: {
      label: "Row 7\nEntity G"
      style.fill: "${colors.data}"
    }
  }
}
# Step 2: Allocate Row in Target
step2: {
  label: "STEP 1\n\nAllocate new row\nin Archetype B"
  arch_b_step2: {
    label: "Archetype B\n(Position, Velocity, Health)"
    style.fill: "${colors.data}"
    style.stroke: "${colors.text-dark}"
    row0_new: {
      label: "Row 0\nEntity E\n(NEW)"
      style.fill: "${colors.changed}"
      style.bold: true
    }
  }
}
step1 -> step2: "1. Find target\n   archetype via graph" {
  style.stroke: "${colors.pointer}"
  style.stroke-width: 3
}
# Step 3: Copy Shared Components
step3: {
  label: "STEP 2\n\nCopy Position, Velocity\nfrom A[5] to B[0]"
  arch_a_copy: {
    label: "Archetype A"
    style.fill: "${colors.header}"
    row5_copy: {
      label: "Row 5\nEntity E"
      style.fill: "${colors.changed}"
      style.bold: true
    }
  }
  arch_b_copy: {
    label: "Archetype B"
    style.fill: "${colors.data}"
    row0_copy: {
      label: "Row 0\nEntity E\n+ Position, Velocity"
      style.fill: "${colors.changed}"
      style.bold: true
    }
  }
  copy_arrow: {
    shape: text
    label: "COPY"
    style.fill: "transparent"
    style.stroke: "transparent"
    style.font-color: "${colors.pointer}"
    style.bold: true
  }
}
step2 -> step3: "2. Copy shared\n   components" {
  style.stroke: "${colors.pointer}"
}
# Step 4: Add New Component
step4: {
  label: "STEP 3\n\nAdd Health component\nto B[0]"
  arch_b_add: {
    label: "Archetype B\n(Position, Velocity, Health)"
    style.fill: "${colors.data}"
    row0_add: {
      label: "Row 0\nEntity E\n+ Health=100"
      style.fill: "${colors.changed}"
      style.bold: true
    }
  }
}
step3 -> step4: "3. Add new\n   component" {
  style.stroke: "${colors.pointer}"
}
# Step 5: Swap-Remove from Source
step5: {
  label: "STEP 4\n\nSwap-remove E from A\nRow 5 ↔ Row 7"
  arch_a_swap: {
    label: "Archetype A\n(Position, Velocity)"
    style.fill: "${colors.header}"
    row5_swap: {
      label: "Row 5\nEntity G\n(SWAPPED)"
      style.fill: "${colors.free}"
      style.bold: true
    }
    row6_swap: {
      label: "Row 6\nEntity F"
      style.fill: "${colors.data}"
    }
    row7_removed: {
      label: "Row 7\n(REMOVED)"
      style.fill: "${colors.padding}"
      style.stroke-dash: 3
    }
  }
}
step4 -> step5: "4. Swap-remove\n   from source" {
  style.stroke: "${colors.pointer}"
}
# Step 6: Update Location
step6: {
  label: "AFTER\n\nEntity E → Archetype B[0]\nEntity G → Archetype A[5]"
  entity_locations: {
    label: "EntityLocations"
    style.fill: "${colors.padding}"
    loc_e: {
      label: "Entity E → (B, 0)"
      style.fill: "${colors.changed}"
      style.bold: true
    }
    loc_g: {
      label: "Entity G → (A, 5)"
      style.fill: "${colors.free}"
      style.bold: true
    }
  }
  arch_b_final: {
    label: "Archetype B"
    style.fill: "${colors.data}"
    row0_final: {
      label: "Row 0: Entity E"
      style.fill: "${colors.changed}"
    }
  }
  arch_a_final: {
    label: "Archetype A"
    style.fill: "${colors.header}"
    row5_final: {
      label: "Row 5: Entity G"
      style.fill: "${colors.free}"
    }
  }
}
step5 -> step6: "5. Update\n   EntityLocations" {
  style.stroke: "${colors.pointer}"
}
# Migration flow annotation
migration_note: |md
  **Migration Cost**: O(components in entity)
  Each component cloned via `ComponentTypeInfo.clone_fn`
| {near: bottom-center}