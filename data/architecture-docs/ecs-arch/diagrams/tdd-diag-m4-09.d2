vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    c2: "#C7F1FF" # Archetypes (Header/Data)
    c4: "#DEE1EB" # Manager (Neutral/Control)
    c5: "#88DCF7" # Locations (Lookup)
    c6: "#E4DBFE" # Registry (System Meta)
  }
}

title: |md
  # EntityLocation Mapping & ECS Memory Layout
  *Technical Specification: O(1) Component Access via Archetypal Storage*
| {near: top-center}

direction: right

EntityManager: {
  label: "EntityManager\n(generations: Vec<u16>)"
  style.fill: "${colors.c4}"
  style.stroke-width: 2
  
  generations: {
    label: "[u16; capacity]\nOffset: 0x00 | Size: N * 2B"
    shape: code
  }
  free_list: {
    label: "Vec<usize>\n(Recycled indices)"
    shape: code
  }
}

EntityLocations: {
  label: "EntityLocations\n(Vec<Option<EntityLocation>>)"
  style.fill: "${colors.c5}"
  style.stroke-width: 2
  
  locations: {
    label: "[Option<EntityLocation>; max_index]\n8 Bytes per Entry"
    shape: code
  }
}

ArchetypeRegistry: {
  label: "ArchetypeRegistry\n(Meta-Registry)"
  style.fill: "${colors.c6}"
  style.stroke-width: 2
  
  archetypes: {
    label: "Vec<Archetype>\nPointers to Column Blocks"
    shape: code
  }
  signature_to_id: {
    label: "HashMap<Signature, ArchetypeId>\nBitmask Lookup"
    shape: code
  }
}

Archetype_0: {
  label: "Archetype 0\nSignature: (Empty)"
  style.fill: "${colors.c2}"
  style.double-border: true
  
  entities: {
    label: "[Entity; N]\nIdentity Column"
    shape: code
  }
}

Archetype_1: {
  label: "Archetype 1\nSignature: (Position)"
  style.fill: "${colors.c2}"
  style.double-border: true
  
  entities: {
    label: "[Entity; N]\nOffset: 0x00"
    shape: code
  }
  columns: {
    label: "PositionColumn: [f32; 3 * N]\nOffset: 0x40 (Aligned)"
    shape: code
  }
}

Archetype_2: {
  label: "Archetype 2\nSignature: (Pos, Vel)"
  style.fill: "${colors.c2}"
  style.double-border: true
  
  entities: {
    label: "[Entity; N]\nIdentity"
    shape: code
  }
  columns: {
    label: "PosColumn | VelColumn\nParallel Arrays"
    shape: code
  }
}

# Documentation and Legend
legend: |md
  ### Implementation Notes
  - **Generation Check**: Compare `generations[i]` with Entity ID to prevent stale access.
  - **Archetypal Storage**: Components stored in dense parallel arrays (SoA) for cache efficiency.
  - **Indirection**: `EntityLocations` provides $O(1)$ mapping from ID to specific Archetype + Row index.
  
  **Color Key:**
  - <span style="color:#DEE1EB">■</span> **Gray**: Logic/Management
  - <span style="color:#88DCF7">■</span> **Blue**: Lookup Table
  - <span style="color:#C7F1FF">■</span> **Cyan**: Data Storage (Archetypes)
| {near: bottom-center}

# Connections
EntityManager -> EntityLocations: "1. Indexing" {
  style.stroke: orange
  style.stroke-width: 2
}

EntityLocations -> Archetype_0: "Null Query" {
  style.stroke-dash: 3
}

EntityLocations -> Archetype_1: "Row Lookup" {
  style.stroke: orange
  target-arrowhead: triangle
}

EntityLocations -> Archetype_2: "Row Lookup" {
  style.stroke: orange
  target-arrowhead: triangle
}

ArchetypeRegistry -> Archetype_0: "manages"
ArchetypeRegistry -> Archetype_1: "manages"
ArchetypeRegistry -> Archetype_2: "manages"