vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Query Matching Against Archetypes
  `QuerySpec { included: [Position, Velocity], excluded: [Static] }`
| {near: top-center}
direction: right
QuerySpec: {
  label: "QuerySpec"
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  included: {
    label: "included: [Position, Velocity]"
    shape: text
    style.font: mono
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
  }
  excluded: {
    label: "excluded: [Static]"
    shape: text
    style.font: mono
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
  }
}
ArchetypeRegistry: {
  label: "ArchetypeRegistry"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  arch0: {
    label: "Archetype 0\n()\n0 entities"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  arch1: {
    label: "Archetype 1\n(Position)\n50 entities"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  arch2: {
    label: "Archetype 2\n(Velocity)\n30 entities"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  arch3: {
    label: "Archetype 3\n(Position, Velocity)\n100 entities"
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.bold: true
  }
  arch4: {
    label: "Archetype 4\n(Position, Velocity, Static)\n25 entities"
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
  }
  arch5: {
    label: "Archetype 5\n(Position, Health)\n75 entities"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
MatchingResult: {
  label: "Matching Archetypes"
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
  style.bold: true
  result: {
    label: "[Archetype 3]"
    shape: text
    style.font: mono
    style.font-size: 18
  }
}
check0: {
  label: "✗ Missing Position\n  Missing Velocity"
  shape: text
  style.fill: transparent
  style.font-color: "#DC3545"
}
check1: {
  label: "✗ Missing Velocity"
  shape: text
  style.fill: transparent
  style.font-color: "#DC3545"
}
check2: {
  label: "✗ Missing Position"
  shape: text
  style.fill: transparent
  style.font-color: "#DC3545"
}
check3: {
  label: "✓ Has Position\n✓ Has Velocity\n✓ No Static"
  shape: text
  style.fill: transparent
  style.font-color: "#28A745"
  style.bold: true
}
check4: {
  label: "✗ Has Static (excluded)"
  shape: text
  style.fill: transparent
  style.font-color: "#DC3545"
}
check5: {
  label: "✗ Missing Velocity"
  shape: text
  style.fill: transparent
  style.font-color: "#DC3545"
}
QuerySpec -> ArchetypeRegistry.arch0: "iterate" {style.stroke-dash: 3}
QuerySpec -> ArchetypeRegistry.arch1: "iterate" {style.stroke-dash: 3}
QuerySpec -> ArchetypeRegistry.arch2: "iterate" {style.stroke-dash: 3}
QuerySpec -> ArchetypeRegistry.arch3: "iterate" {style.stroke-dash: 3}
QuerySpec -> ArchetypeRegistry.arch4: "iterate" {style.stroke-dash: 3}
QuerySpec -> ArchetypeRegistry.arch5: "iterate" {style.stroke-dash: 3}
ArchetypeRegistry.arch0 -> check0
ArchetypeRegistry.arch1 -> check1
ArchetypeRegistry.arch2 -> check2
ArchetypeRegistry.arch3 -> check3
ArchetypeRegistry.arch4 -> check4
ArchetypeRegistry.arch5 -> check5
check3 -> MatchingResult: "MATCH" {style.stroke: "#4CAF50"; style.bold: true; style.stroke-width: 3}
legend: {
  near: bottom-center
  label: |md
    **Matching Logic:**
    - `contains_all(included)` → must have ALL required types
    - `contains_none(excluded)` → must have NO excluded types
    - Both conditions must pass
  |
  shape: text
  style.fill: "#F5F5F5"
  style.stroke: "#BDBDBD"
}