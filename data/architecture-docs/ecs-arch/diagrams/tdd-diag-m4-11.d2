vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#4A5568"
    active: "#2D3748"
    inactive: "#A0AEC0"
    success: "#48BB78"
    text: "#2D3748"
    flow: "#4299E1"
    decision: "#ED8936"
    error: "#F56565"
  }
}

title: |md
  # Archetype Query Iterator State Machine
  **Algorithm Steps for Entity Iteration**
| {near: top-center}

direction: right

states: {
  init: {
    label: "INITIALIZE"
    shape: circle
    style.fill: "${colors.success}"
    style.stroke: "${colors.active}"
    style.font-color: white
  }
  
  state_box: {
    label: "Iterator State"
    shape: rectangle
    style.fill: "${colors.header}"
    style.stroke: "${colors.active}"
    style.font-color: white
    
    current_archetype: "current_archetype: usize = 0"
    current_row: "current_row: usize = 0"
    matching: "matching: Vec<ArchetypeId>"
  }
  
  check_row: {
    label: "row < archetype.len()?"
    shape: diamond
    style.fill: "${colors.decision}"
    style.stroke: "${colors.active}"
    style.font-color: white
  }
  
  return_entity: {
    label: "RETURN\n(entity, row)"
    shape: rectangle
    style.fill: "${colors.success}"
    style.stroke: "${colors.active}"
    style.font-color: white
  }
  
  increment_row: {
    label: "row++"
    shape: rectangle
    style.fill: "${colors.flow}"
    style.stroke: "${colors.active}"
    style.font-color: white
  }
  
  next_archetype: {
    label: "archetype++\nrow = 0"
    shape: rectangle
    style.fill: "${colors.flow}"
    style.stroke: "${colors.active}"
    style.font-color: white
  }
  
  check_done: {
    label: "archetype >=\nmatching.len()?"
    shape: diamond
    style.fill: "${colors.decision}"
    style.stroke: "${colors.active}"
    style.font-color: white
  }
  
  done: {
    label: "RETURN None"
    shape: circle
    style: {
      double-border: true
      fill: "${colors.error}"
      stroke: "${colors.active}"
      font-color: white
    }
  }
}

# Flow connections
states.init -> states.state_box

states.state_box -> states.check_row

states.check_row -> states.return_entity: "YES" {
  style: {
    stroke: "${colors.success}"
    stroke-width: 3
    bold: true
  }
}

states.return_entity -> states.increment_row: "next call"

states.increment_row -> states.check_row

states.check_row -> states.next_archetype: "NO" {
  style.stroke: "${colors.inactive}"
}

states.next_archetype -> states.check_done

states.check_done -> states.state_box: "NO\n(continue)" {
  style: {
    stroke: "${colors.flow}"
    stroke-dash: 3
  }
}

states.check_done -> states.done: "YES\n(exhausted)" {
  style: {
    stroke: "${colors.error}"
    stroke-width: 3
    bold: true
  }
}

# Legend
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "${colors.header}"
  
  legend_title: "State Transitions" {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
  }
  
  success_legend: "Return entity (success path)" {
    style.fill: "${colors.success}"
    style.font-color: white
  }
  
  flow_legend: "State mutation" {
    style.fill: "${colors.flow}"
    style.font-color: white
  }
  
  decision_legend: "Conditional branch" {
    style.fill: "${colors.decision}"
    style.font-color: white
  }
  
  terminal_legend: "Iteration complete" {
    style.fill: "${colors.error}"
    style.font-color: white
  }
}

legend.legend_title -> legend.success_legend -> legend.flow_legend -> legend.decision_legend -> legend.terminal_legend: {
  style.opacity: 0
}

# Complexity annotation
complexity: |md
  **Complexity Analysis:**
  - **Per entity**: O(1) — single array access
  - **Total iteration**: O(matching entities)
  - **Memory access**: Sequential per archetype
| {near: bottom-center}