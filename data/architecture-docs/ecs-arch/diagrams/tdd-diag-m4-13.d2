vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Benchmark Results: Sparse Set vs Archetype Storage
| {near: top-center}

classes: {
  container: {
    style: {
      fill: white
      stroke: "#E5E7EB"
      stroke-width: 2
      border-radius: 8
    }
  }
  header: {
    style: {
      fill: "#4F46E5"
      font-color: white
      bold: true
      border-radius: 8
    }
  }
  bar_sparse: {
    style: {
      fill: "#F59E0B"
      stroke: "#D97706"
      stroke-width: 2
    }
  }
  bar_archetype: {
    style: {
      fill: "#10B981"
      stroke: "#059669"
      stroke-width: 2
    }
  }
  bar_migration: {
    style: {
      fill: "#EF4444"
      stroke: "#DC2626"
      stroke-width: 2
    }
  }
  metric: {
    style: {
      fill: "#F3F4F6"
      border-radius: 4
      font: mono
    }
  }
}

direction: right

section_iteration: "Iteration Performance\n(100K entities, 2 components)" {
  class: container
  # Using grid-columns: 1 forces children to stack vertically, 
  # achieving the intended header-top/box-bottom layout without illegal 'near' usage.
  grid-columns: 1
  grid-gap: 20

  header_iter: "Lower is Better" {
    class: header
    width: 200
  }

  chart_iter: {
    grid-rows: 1
    grid-columns: 2
    grid-gap: 60
    sparse_bar: "Sparse Set\n~1000μs" {
      class: bar_sparse
      width: 300
      height: 60
    }
    archetype_bar: "Archetype\n~300μs" {
      class: bar_archetype
      width: 300
      height: 60
    }
  }

  speedup_box: |md
    **3.3x Speedup**
    Archetype storage eliminates
    sparse array indirection for
    pure sequential memory access.
  | {
    class: metric
  }
}

section_migration: "Migration Cost\n(Add + Remove 10K components)" {
  class: container
  grid-columns: 1
  grid-gap: 20

  header_mig: "Archetype Trade-off" {
    class: header
    width: 200
  }

  chart_mig: {
    grid-rows: 1
    grid-columns: 2
    grid-gap: 60
    sparse_mig: "Sparse Set\n~1ms" {
      class: bar_sparse
      width: 300
      height: 40
    }
    arch_mig: "Archetype\n~5ms" {
      class: bar_migration
      width: 300
      height: 100
    }
  }

  tradeoff_box: |md
    **5x Slower**
    Migration requires copying ALL
    entity components between
    archetype tables.
  | {
    class: metric
  }
}

legend: {
  near: bottom-center
  grid-columns: 4
  grid-gap: 30
  leg1: "Sparse Set" {
    class: bar_sparse
    width: 80
    height: 20
  }
  leg2: "Archetype\n(Fast)" {
    class: bar_archetype
    width: 80
    height: 20
  }
  leg3: "Archetype\n(Slow)" {
    class: bar_migration
    width: 80
    height: 20
  }
}

insight: |md
  ## Key Insight
  **Archetype storage optimizes for iteration frequency over structural change speed.**
  In typical games:
  - Iteration: 60x/second (every frame)
  - Structural changes: ~1x/second (spawning/despawning)
  The 3.3x iteration speedup compounds across hundreds of systems
  running every frame, while the 5x migration penalty is amortized
  across infrequent structural changes.
| {near: center-right}