vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Archetype Explosion Scenario
  **10 component types × independent add/remove = 2¹⁰ = 1,024 potential archetypes**
| {near: top-center}
# Warning Banner
warning: |md
  ⚠️ **FRAGMENTATION WARNING**
  100,000 entities ÷ 1,024 archetypes = **~97 entities per archetype**
  Small tables → cache misses jumping between archetypes
| {
  near: top-center
  style: {
    fill: "#FFE4E1"
    stroke: "#DC143C"
    stroke-width: 3
    border-radius: 8
    font-color: "#8B0000"
  }
}
# Component Types Pool (Left side)
component_pool: "Component Types (10)" {
  style: {
    fill: "#E8E8E8"
    stroke: "#666"
    border-radius: 4
  }
  c0: "A" {style.fill: "#FF6B6B"}
  c1: "B" {style.fill: "#4ECDC4"}
  c2: "C" {style.fill: "#45B7D1"}
  c3: "D" {style.fill: "#96CEB4"}
  c4: "E" {style.fill: "#FFEAA7"}
  c5: "F" {style.fill: "#DDA0DD"}
  c6: "G" {style.fill: "#98D8C8"}
  c7: "H" {style.fill: "#F7DC6F"}
  c8: "I" {style.fill: "#BB8FCE"}
  c9: "J" {style.fill: "#85C1E9"}
  note: |md
    Each component can be
    independently added/removed
  | {style.fill: transparent; style.font-color: "#666"}
}
# Calculation Box
calculation: |md
  ## The Math
  
  Components: 10
  Combinations: 2^10 = 1,024
  Entities: 100,000
  Per archetype: ~97
  
  **Why this happens:**
  - Each entity has unique subset
  - No common patterns emerge
  - Every subset = separate table
| {
  style: {
    fill: "#FFF8DC"
    stroke: "#DAA520"
    border-radius: 8
  }
}
# Archetype Grid (showing explosion)
archetype_explosion: "Archetype Tables (1,024 potential)" {
  style: {
    fill: "#F5F5F5"
    stroke: "#999"
    border-radius: 4
  }
  # First row - single components
  row1: {
    grid-columns: 5
    style.fill: transparent
    a0: "(A)\n97 entities" {
      style: {
        fill: "#FF6B6B"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    a1: "(B)\n97 entities" {
      style: {
        fill: "#4ECDC4"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    a2: "(C)\n97 entities" {
      style: {
        fill: "#45B7D1"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    a3: "(D)\n97 entities" {
      style: {
        fill: "#96CEB4"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    a4: "(E)\n97 entities" {
      style: {
        fill: "#FFEAA7"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
  }
  # Second row - pairs
  row2: {
    grid-columns: 5
    style.fill: transparent
    b0: "(A,B)\n97 entities" {
      style: {
        fill: "#E8A0A0"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    b1: "(A,C)\n97 entities" {
      style: {
        fill: "#E8A0A0"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    b2: "(B,C)\n97 entities" {
      style: {
        fill: "#7ABFBF"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    b3: "(C,D)\n97 entities" {
      style: {
        fill: "#6DB6C2"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    b4: "(D,E)\n97 entities" {
      style: {
        fill: "#C0D9A7"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
  }
  # Third row - triples
  row3: {
    grid-columns: 5
    style.fill: transparent
    c0: "(A,B,C)\n97 entities" {
      style: {
        fill: "#D4A0A0"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    c1: "(B,C,D)\n97 entities" {
      style: {
        fill: "#7FBFBF"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    c2: "(C,D,E)\n97 entities" {
      style: {
        fill: "#72B3C4"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    c3: "(D,E,F)\n97 entities" {
      style: {
        fill: "#B0CCA0"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
    c4: "(E,F,G)\n97 entities" {
      style: {
        fill: "#E8D9A0"
        stroke: "#333"
        border-radius: 4
        font-size: 14
      }
    }
  }
  # Ellipsis
  ellipsis: |md
    ⋮
    **... 1,016 more archetypes ...**
    ⋮
  | {style.fill: transparent; style.font-color: "#666"; style.font-size: 18}
  # Last row - full set
  row_last: {
    grid-columns: 1
    style.fill: transparent
    full: "(A,B,C,D,E,F,G,H,I,J)\n97 entities" {
      style: {
        fill: "#D0D0D0"
        stroke: "#333"
        stroke-width: 2
        border-radius: 4
        font-size: 12
      }
    }
  }
}
# Performance Impact
performance: "Performance Impact" {
  style: {
    fill: "#FFE4E1"
    stroke: "#DC143C"
    stroke-width: 2
    border-radius: 8
  }
  cache_misses: |md
    ## Cache Misses Per Query
    **With 1,024 archetypes:**
    - Query must check ~1,024 signatures
    - Iterate over many small tables
    - Jump between memory locations
    - **~50-100 cache misses per query**
  | {style.fill: transparent}
  good_case: |md
    ## Good Case (10 archetypes)
    - Query checks 10 signatures
    - Iterate over large tables
    - Sequential memory access
    - **~5-10 cache misses per query**
  | {
    style: {
      fill: "#90EE90"
      border-radius: 4
    }
  }
}
# Mitigation Strategies
mitigation: "Mitigation Strategies" {
  style: {
    fill: "#E0FFE0"
    stroke: "#228B22"
    stroke-width: 2
    border-radius: 8
  }
  strategy1: "1. Group Components" {
    style.fill: "#98FB98"
    style.border-radius: 4
    desc: |md
      Combine components that
      always appear together
      `Health + MaxHealth` → `HealthStats`
    | {style.fill: transparent}
  }
  strategy2: "2. Rare Components → Sparse Sets" {
    style.fill: "#98FB98"
    style.border-radius: 4
    desc: |md
      Use sparse sets for
      rarely-used components
      `PlayerControlled` (0.1% entities)
    | {style.fill: transparent}
  }
  strategy3: "3. Monitor Archetype Count" {
    style.fill: "#98FB98"
    style.border-radius: 4
    desc: |md
      Log archetype count each frame
      
      if archetypes.len() > 100 {
        warn("Fragmentation!")
      }
      
    | {style.fill: transparent}
  }
}
# Connections
component_pool -> archetype_explosion: "Creates" {
  style: {
    stroke: "#666"
    stroke-dash: 3
    animated: true
  }
}
archetype_explosion -> performance: "Causes" {
  style: {
    stroke: "#DC143C"
    stroke-width: 2
  }
}
mitigation -> archetype_explosion: "Prevents" {
  style: {
    stroke: "#228B22"
    stroke-width: 2
    stroke-dash: 5
  }
}
# Entity Distribution Visualization
distribution: "Entity Distribution (per archetype)" {
  style: {
    fill: "#F8F8FF"
    stroke: "#4682B4"
    border-radius: 8
  }
  bar_chart: {
    grid-columns: 5
    grid-gap: 4
    style.fill: transparent
    bar1: "97\n▬▬▬" {style.fill: "#4682B4"; style.font-size: 12}
    bar2: "97\n▬▬▬" {style.fill: "#4682B4"; style.font-size: 12}
    bar3: "97\n▬▬▬" {style.fill: "#4682B4"; style.font-size: 12}
    bar4: "97\n▬▬▬" {style.fill: "#4682B4"; style.font-size: 12}
    bar5: "97\n▬▬▬" {style.fill: "#4682B4"; style.font-size: 12}
  }
  note: |md
    All archetypes have similar size (~97 entities)
    → No "hot" archetypes to optimize
    → Uniform fragmentation
  | {style.fill: transparent; style.font-color: "#666"}
}
calculation -> distribution