direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Chunk-Based Allocation Concept
  ### Archetype Table: { EntityID(4B), Position(8B), Velocity(8B) }
  **16KB Chunk Memory Layout & Cache Alignment Detail**
| {near: top-center}

# Global classes for consistency and engineering detail
classes: {
  header: { 
    style: { fill: "#E1BEE7"; stroke: "#9C27B0"; stroke-width: 2; bold: true } 
  }
  data: { 
    style: { fill: "#BBDEFB"; stroke: "#1976D2"; stroke-width: 1 } 
  }
  free: { 
    style: { fill: "#C8E6C9"; stroke: "#388E3C"; stroke-dash: 3 } 
  }
  padding: { 
    style: { fill: "#F5F5F5"; stroke: "#9E9E9E"; stroke-dash: 2 } 
  }
  pointer: { 
    style: { stroke: "#FF9800"; stroke-width: 3; animated: true } 
  }
}

legend: {
  near: top-right
  label: "Memory Map Legend"
  h: "Header (Purple)" { class: header }
  d: "Data (Blue)" { class: data }
  p: "Padding (Gray)" { class: padding }
  c: "Cache Line Boundary (Green Dash)" { 
    style: { stroke: "#4CAF50"; stroke-width: 2; stroke-dash: 5; fill: transparent } 
  }
}

component_specification: {
  label: "Component Layout Specification"
  style.fill: "#FAFAFA"
  
  pos: "Position { x: f32, y: f32 }" { style.fill: "#FFF3E0" }
  vel: "Velocity { dx: f32, dy: f32 }" { style.fill: "#FFF3E0" }
  entity: "EntityID { id: u32 }" { style.fill: "#E3F2FD" }
  
  sizes: |'md
| Component | Size | Alignment |
|-----------|------|-----------|
| Entity    | 4B   | 4B        |
| Position  | 8B   | 4B        |
| Velocity  | 8B   | 4B        |
| **Total** | 20B  | 4B        |
  '|
}

chunk_physical_layout: "Chunk 0 Structure (16,384 Bytes / 0x4000)" {
  style: { fill: "#FFFFFF"; stroke: "#2196F3"; stroke-width: 4 }
  
  # Offset labels on left, sizes on right
  header: "0x0000 | Chunk Header | 16B" {
    class: header
    grid-columns: 2
    f1: "archetype_id: u32"
    f2: "chunk_index: u32"
    f3: "entity_count: u16"
    f4: "capacity: u16"
  }
  
  entity_block: "0x0010 | Entity ID Column | 3,272B" {
    class: data
    label: "entities: [u32; 818]\nContiguous IDs for SoA access"
  }
  
  pos_block: "0x0CD8 | Position Column | 6,544B" {
    style.fill: "#FFF3E0"
    label: "position: [f32; 818 * 2]\nSoA Layout: [x,x,x...][y,y,y...]"
  }
  
  vel_block: "0x2668 | Velocity Column | 6,544B" {
    style.fill: "#FFF3E0"
    label: "velocity: [f32; 818 * 2]\nStored contiguously for SIMD"
  }
  
  pad_block: "0x3FF8 | Padding / EOF | 8B" {
    class: padding
    label: "Alignment Padding to 16KB Boundary"
  }
}

cache_alignment: "L1 Cache Line Detail (64B Window)" {
  label.near: top-center
  style.fill: "#F9F9F9"
  style.stroke: "#4CAF50"
  style.stroke-dash: 5

  line_0: "Offset 0x0000: Header + Entities" {
    grid-columns: 8
    h: "Header (16B)" { class: header; grid-span: 2 }
    e0: "E[0]" { class: data }
    e1: "E[1]" { class: data }
    e2: "E[2]" { class: data }
    e3: "E[3]" { class: data }
    e4: "E[4]" { class: data }
    e5: "E[5]" { class: data }
    e6: "E[6]" { class: data }
    e7: "E[7]" { class: data }
    e8: "E[8]" { class: data }
    e9: "E[9]" { class: data }
    e10: "E[10]" { class: data }
    e11: "E[11]" { class: data }
    
    label: "Cache Line 0 (64 Bytes Total) - Prefetcher Boundary"
  }
  
  line_n: "Offset 0x0CD8: Position Alignment" {
    grid-columns: 8
    p0x: "P[0].x" { style.fill: "#FFF3E0" }
    p0y: "P[0].y" { style.fill: "#FFF3E0" }
    p1x: "P[1].x" { style.fill: "#FFF3E0" }
    p1y: "P[1].y" { style.fill: "#FFF3E0" }
    p2x: "P[2].x" { style.fill: "#FFF3E0" }
    p2y: "P[2].y" { style.fill: "#FFF3E0" }
    p3x: "P[3].x" { style.fill: "#FFF3E0" }
    p3y: "P[3].y" { style.fill: "#FFF3E0" }
    
    label: "Cache Line 51 (Start of Component SoA Segment)"
  }
}

archetype_chunks: "Archetype Container: {Pos, Vel}" {
  style.fill: "#FAFAFA"
  style.stroke: "#673AB7"
  
  chunk_list: {
    grid-columns: 3
    grid-gap: 20
    c0: "Chunk 0" {
      style.fill: "#E3F2FD"; style.stroke: "#2196F3"
      label: "818 entities\nFull (Status: ReadOnly)"
    }
    c1: "Chunk 1" {
      style.fill: "#E3F2FD"; style.stroke: "#2196F3"
      label: "818 entities\nFull (Status: ReadOnly)"
    }
    c2: "Chunk 2" {
      style.fill: "#FFECB3"; style.stroke: "#FFC107"
      label: "412 entities\nActive (Status: Mut)"
    }
  }
  
  allocator: "Slab Allocator / Global Pool" {
    class: free
    grid-columns: 4
    p0: "P0" { style.fill: "#BBDEFB" }
    p1: "P1" { style.fill: "#BBDEFB" }
    p2: "P2" { style.fill: "#BBDEFB" }
    p3: "P3" { style.fill: "#C8E6C9" }
    label: "Chunk Allocation Bitmask (1110...)"
  }
}

offsets_table: {
  near: center-left
  shape: text
  label: |'md
### Chunk Physical Memory Map
**Total size: 16,384 Bytes (0x4000)**

| Offset (Hex) | Field Name         | Byte Size |
|--------------|--------------------|-----------|
| 0x0000       | **Header**         | 16B       |
| 0x0010       | **Entity IDs**     | 3,272B    |
| 0x0CD8       | **Position Data**  | 6,544B    |
| 0x2668       | **Velocity Data**  | 6,544B    |
| 0x3FF8       | **Padding**        | 8B        |
| 0x4000       | **EOF**            | -         |
  '|
}

# Technical Connectors (Pointers)
component_specification -> chunk_physical_layout: "Implementation Rule" { class: pointer }
chunk_physical_layout -> cache_alignment: "64B Window Analysis" { class: pointer }
cache_alignment -> archetype_chunks.chunk_list.c0: "Instance Mapping" { class: pointer }
archetype_chunks.allocator -> archetype_chunks.chunk_list: "Backing Memory" { class: pointer }

benefits: {
  near: bottom-center
  label: "Architectural Advantages"
  style.fill: "#E8F5E9"
  
  grid-columns: 2
  b1: "✓ L1-D Locality: Contiguous Component Scans"
  b2: "✓ Zero Frag: Fixed-size Chunk Recycling"
  b3: "✓ SIMD Ready: 32-byte Alignment Guaranteed"
  b4: "✓ Lock-free: Chunk-level Granularity"
}