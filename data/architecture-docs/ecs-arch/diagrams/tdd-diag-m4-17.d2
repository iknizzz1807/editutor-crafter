vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F97316"
    changed: "#EF4444"
    free: "#22C55E"
    gray: "#6B7280"
    bg: "#1F2937"
  }
}
title: |md
  # Swap-Remove Location Update
  ### Archetype Table: Before and After Removal at Row 5
|
direction: right
before: {
  label: "BEFORE: swap_remove(row=5)"
  style.fill: "${colors.bg}"
  style.stroke: "${colors.gray}"
  style.font-color: white
  entities_before: {
    label: "entities: Vec<Entity>"
    style.fill: "#111827"
    style.stroke: "${colors.data}"
    style.font-color: white
    grid-columns: 1
    grid-gap: 0
    e0: "row 0: Entity(A)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    e1: "row 1: Entity(B)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    e2: "row 2: Entity(C)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    e3: "row 3: Entity(D)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    e4: "row 4: Entity(E)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    e5: "row 5: Entity(F) ← REMOVE TARGET" { 
      style.fill: "${colors.changed}"; 
      style.font-color: white; 
      style.font-size: 14;
      style.bold: true
    }
    e6: "row 6: Entity(G)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    e7: "row 7: Entity(H) ← LAST" { 
      style.fill: "${colors.pointer}"; 
      style.font-color: white; 
      style.font-size: 14;
      style.bold: true
    }
  }
  location_before: {
    label: "EntityLocations (before)"
    style.fill: "#111827"
    style.stroke: "${colors.header}"
    style.font-color: white
    grid-columns: 2
    grid-gap: 2
    lh: "Entity Index" { class: header }
    lh2: "Location" { class: header }
    la: "H.index" { style.fill: "${colors.pointer}"; style.font-color: white }
    la2: "(arch_id, 7)" { style.fill: "${colors.pointer}"; style.font-color: white }
    lb: "F.index" { style.fill: "${colors.changed}"; style.font-color: white }
    lb2: "(arch_id, 5)" { style.fill: "${colors.changed}"; style.font-color: white }
  }
}
arrow: {
  label: "swap_remove(5)\n→ Some((H, 5))"
  style.stroke: "${colors.changed}"
  style.stroke-width: 3
  style.font-color: white
  style.bold: true
}
after: {
  label: "AFTER: swap_remove returns (Entity(H), 5)"
  style.fill: "${colors.bg}"
  style.stroke: "${colors.gray}"
  style.font-color: white
  entities_after: {
    label: "entities: Vec<Entity>"
    style.fill: "#111827"
    style.stroke: "${colors.data}"
    style.font-color: white
    grid-columns: 1
    grid-gap: 0
    a0: "row 0: Entity(A)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    a1: "row 1: Entity(B)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    a2: "row 2: Entity(C)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    a3: "row 3: Entity(D)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    a4: "row 4: Entity(E)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    a5: "row 5: Entity(H) ← SWAPPED HERE" { 
      style.fill: "${colors.changed}"; 
      style.font-color: white; 
      style.font-size: 14;
      style.bold: true
    }
    a6: "row 6: Entity(G)" { style.fill: "${colors.data}"; style.font-color: white; style.font-size: 14 }
    note: "(len = 7, was 8)" { 
      shape: text
      style.font-color: "${colors.gray}"
      style.font-size: 12
    }
  }
  location_after: {
    label: "EntityLocations (after update)"
    style.fill: "#111827"
    style.stroke: "${colors.header}"
    style.font-color: white
    grid-columns: 2
    grid-gap: 2
    ah: "Entity Index" { class: header }
    ah2: "Location" { class: header }
    aa: "H.index" { style.fill: "${colors.changed}"; style.font-color: white; style.bold: true }
    aa2: "(arch_id, 5) ← UPDATED!" { 
      style.fill: "${colors.changed}"; 
      style.font-color: white;
      style.bold: true
    }
    ab: "F.index" { style.fill: "${colors.gray}"; style.font-color: white }
    ab2: "(arch_id, 5) stale" { 
      style.fill: "${colors.gray}"; 
      style.font-color: white;
      style.italic: true
    }
  }
}
classes: {
  header: {
    style.fill: "${colors.header}"
    style.font-color: white
    style.bold: true
    style.font-size: 12
  }
}
swap_flow: {
  label: "Swap-Remove Algorithm Steps"
  style.fill: "#111827"
  style.stroke: "${colors.header}"
  style.font-color: white
  near: bottom-center
  grid-columns: 1
  grid-gap: 4
  s1: "1. entities.swap_remove(5) → F removed, H moves from row 7 to row 5" {
    style.fill: "#1F2937"
    style.font-color: white
    style.font-size: 13
  }
  s2: "2. columns[Position].swap_remove(5) → H's Position now at row 5" {
    style.fill: "#1F2937"
    style.font-color: white
    style.font-size: 13
  }
  s3: "3. columns[Velocity].swap_remove(5) → H's Velocity now at row 5" {
    style.fill: "#1F2937"
    style.font-color: white
    style.font-size: 13
  }
  s4: "4. Return: Some((Entity(H), 5))" {
    style.fill: "#1F2937"
    style.font-color: "${colors.changed}"
    style.bold: true
    style.font-size: 13
  }
  s5: "5. Caller: entity_locations.update_row(H, 5)" {
    style.fill: "#1F2937"
    style.font-color: "${colors.free}"
    style.bold: true
    style.font-size: 13
  }
}
before.entities_before.e5 -> after.entities_after.a5: "Entity(H) swapped\ninto row 5" {
  style.stroke: "${colors.changed}"
  style.stroke-dash: 4
  style.animated: true
  style.font-color: "${colors.changed}"
}
code: |md
  rust
  // In Archetype::swap_remove(row: usize) -> Option<(Entity, usize)>
  fn swap_remove(&mut self, row: usize) -> Option<(Entity, usize)> {
      if row >= self.entities.len() { return None; }
      // Remove from all columns
      for column in self.columns.values_mut() {
          column.swap_remove(row);
      }
      // Remove from entity list
      let last_idx = self.entities.len() - 1;
      self.entities.swap_remove(row);
      // Return swapped entity info for location update
      if row < self.entities.len() {
          Some((self.entities[row], row))  // (H, 5)
      } else {
          None  // Was last element, no swap
      }
  }
  // Caller in World::migrate_entity()
  if let Some((swapped_entity, new_row)) = source.swap_remove(source_row) {
      self.entity_locations.update_row(swapped_entity, new_row);
  }
  
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#0D1117"
  style.stroke: "${colors.gray}"
  style.font-color: white
}