vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # ECS Architecture: Complete World
  **Archetype-Based Storage (M4)**
  *Technical Specification - Memory Layout & Ownership*
| {near: top-center}

direction: right

classes: {
  container: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 4
      border-radius: 8
      font-color: "#1E3A8A"
      bold: true
    }
  }
  core: {
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
      stroke-width: 2
      border-radius: 4
      font-color: "#1E40AF"
    }
  }
  storage: {
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
      border-radius: 4
      font-color: "#92400E"
    }
  }
  cache: {
    style: {
      fill: "#FCE7F3"
      stroke: "#DB2777"
      stroke-width: 2
      border-radius: 4
      font-color: "#9D174D"
    }
  }
  buffer: {
    style: {
      fill: "#DCFCE7"
      stroke: "#16A34A"
      stroke-width: 2
      border-radius: 4
      font-color: "#166534"
    }
  }
}

World: {
  class: container
  label: "World (sizeof=256 bytes)"
  
  entity_manager: EntityManager {
    class: core
    label: "Entity Manager\n(ID Tracking)"
    generations: "Vec<u16> | offset: 0x00"
    free_list: "Vec<usize> | offset: 0x18"
    len: "usize | offset: 0x30"
    capacity: "usize | offset: 0x38"
  }

  archetype_registry: ArchetypeRegistry {
    class: storage
    label: "Archetype Registry\n(Structural Storage)"
    archetypes: "Vec<Archetype> | offset: 0x40"
    signature_to_id: "HashMap<Signature, Id> | offset: 0x58"
  }

  locations: EntityLocations {
    class: cache
    label: "Entity Locations\n(Fast Lookup)"
    locations: "Vec<Option<EntityLocation>> | offset: 0x88"
  }

  component_types: ComponentTypes {
    class: core
    label: "Component Metadata"
    registry: "HashMap<TypeId, ComponentTypeInfo> | offset: 0xA0"
  }

  command_buffer: CommandBuffer {
    class: buffer
    label: "Command Buffer\n(Deferred Op Queue)"
    commands: "Vec<Command> | offset: 0xD0"
  }
}

# Detailed Archetype Storage Breakdown
ArchetypeDefinition: {
  class: storage
  label: "Archetype Storage (Chunked Columnar)"
  
  header: {
    signature: "ArchetypeSignature (BitSet)"
    entity_count: "usize"
  }
  
  columns: {
    col_a: "ComponentColumn<A> (Dense)"
    col_b: "ComponentColumn<B> (Dense)"
    col_entities: "Vec<EntityID> (Reverse Map)"
  }
  
  columns.col_a -> World.component_types: "uses layout info"
}

# Relationships & Flow
World.entity_manager -> World.locations: "invalidates on delete"
World.command_buffer -> World: "flushes structural changes" {
  style.stroke-dash: 5
}

World.archetype_registry -> ArchetypeDefinition: "manages N instances"
World.locations -- "maps Entity → (Archetype, row)" --> ArchetypeDefinition

# Ownership Arrows (Hollow Triangle for implementation/owning link)
World -> World.entity_manager: "owns"
World -> World.archetype_registry: "owns"
World -> World.locations: "owns"
World -> World.component_types: "owns"
World -> World.command_buffer: "owns"

# Engineering Legend
legend: {
  shape: rectangle
  near: bottom-right
  label: |md
    ### Engineering Specs
    - **Memory Layout**: Standard C-style struct alignment (8-byte).
    - **Collections**: All `Vec<T>` are (ptr, len, cap) triplets.
    - **Complexity**: 
      - Entity creation: $O(1)$ amortized
      - Component Access: $O(1)$ via Location Cache
      - Structural Change: $O(N)$ (Migration cost)
  |
  style.fill: "#FFF9C9"
  style.stroke: "#FACC15"
}

# Styling Globs for high visibility
***: {
  style.font: mono
}

# Connector Labels
(World.entity_manager -> World.locations)[0].label: "update cache"
(World.command_buffer -> World)[0].label: "Deferred Execute"