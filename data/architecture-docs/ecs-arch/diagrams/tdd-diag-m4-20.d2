vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Hybrid Storage Strategy Decision Tree" {
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# STARTING POINT
decision_start: "Entity + Component Type" {
  shape: diamond
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
}

# DECISION NODES
freq_check: "Frequent add/remove\n(>10% frame ops)?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
}

rare_check: "Rare component\n(<5% entities)?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
}

iteration_check: "Massive iteration\n(100K+ entities)?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
}

stable_check: "Stable composition\n(rarely changes)?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
}

# STORAGE LEAVES
sparse_set: "SPARSE SET" {
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: "#1B5E20"
    bold: true
  }
  sparse_set_desc: |'md
    **Best for:**
    • Dynamic composition
    • Frequent structural changes
    • Rare components
    • Avoid archetype fragmentation

    **Operations:**
    • Add/Remove: O(1) amortized
    • Lookup: O(1)
    • Iteration: O(n) with indirection
  '|
}

archetype: "ARCHETYPE" {
  shape: rectangle
  style: {
    fill: "#BBDEFB"
    stroke: "#1565C0"
    stroke-width: 3
    font-color: "#0D47A1"
    bold: true
  }
  archetype_desc: |'md
    **Best for:**
    • Stable composition
    • Massive iteration workloads
    • SIMD-friendly data layout
    • Cache-optimal access

    **Operations:**
    • Add/Remove: O(components) migration
    • Lookup: O(1)
    • Iteration: O(n) sequential
  '|
}

hybrid: "HYBRID APPROACH" {
  shape: rectangle
  style: {
    fill: "#E1BEE7"
    stroke: "#7B1FA2"
    stroke-width: 3
    font-color: "#4A148C"
    bold: true
  }
  hybrid_desc: |'md
    **Strategy:**
    • Common components → Archetype
    • Rare/dynamic → Sparse Set
    • Track via component mask

    **Trade-off:**
    • Complexity vs optimal performance
  '|
}

# FLOW LOGIC
decision_start -> freq_check: "Analyze\naccess pattern"

freq_check -> sparse_set: "YES\n(Dynamic)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    bold: true
  }
}

freq_check -> rare_check: "NO\n(Stable)" {
  style: {
    stroke: "#666666"
    stroke-width: 2
  }
}

rare_check -> sparse_set: "YES\n(Avoid fragmentation)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    bold: true
  }
}

rare_check -> iteration_check: "NO\n(Common)" {
  style: {
    stroke: "#666666"
    stroke-width: 2
  }
}

iteration_check -> archetype: "YES\n(Cache critical)" {
  style: {
    stroke: "#2196F3"
    stroke-width: 3
    bold: true
  }
}

iteration_check -> stable_check: "NO\n(Moderate)" {
  style: {
    stroke: "#666666"
    stroke-width: 2
  }
}

stable_check -> archetype: "YES\n(Optimal layout)" {
  style: {
    stroke: "#2196F3"
    stroke-width: 3
    bold: true
  }
}

stable_check -> hybrid: "NO\n(Mixed pattern)" {
  style: {
    stroke: "#9C27B0"
    stroke-width: 3
    bold: true
  }
}

# AUXILIARY INFORMATION
perf_compare: "Performance Comparison (100K entities, 2 components)" {
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
  }
  # Using safe delimiter to prevent pipe-clash with Markdown table
  perf_data: |'md
    | Operation | Sparse Set | Archetype |
    | :--- | :--- | :--- |
    | Iteration | ~800μs | ~400μs |
    | Add comp | ~1μs | ~50μs |
    | Remove | ~1μs | ~50μs |
    | Lookup | ~50ns | ~50ns |
  '|
}

legend: "Decision Criteria" {
  style: {
    fill: "transparent"
    stroke: "#EEEEEE"
  }
  crit1: "• Frequent: >10% of frame budget on structural changes"
  crit2: "• Rare: Component on <5% of entities"
  crit3: "• Massive: Iterating >100K entities per frame"
  crit4: "• Stable: Component composition changes <1% per frame"
}

examples: "Example Use Cases" {
  style: {
    fill: "transparent"
    stroke: "#EEEEEE"
  }
  ex_sparse: |'md
    **Sparse Set:**
    • Status effects (buffs/debuffs)
    • Inventory items
    • Temporary flags
  '|
  ex_arch: |'md
    **Archetype:**
    • Position + Velocity (physics)
    • Transform + RenderData
    • AI + Pathfinding
  '|
}

# Cross-references
sparse_set -> perf_compare
archetype -> perf_compare