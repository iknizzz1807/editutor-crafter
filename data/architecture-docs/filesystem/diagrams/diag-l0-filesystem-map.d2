direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Filesystem Component Atlas
  Implementation-Ready Architecture Overview
| {near: top-center}
# Legend
legend: {
  near: bottom-right
  label: "Legend"
  foundation: "Foundation Layer"
  foundation.style.fill: "#E8F5E9"
  foundation.style.stroke: "#2E7D32"
  core: "Core Operations"
  core.style.fill: "#E3F2FD"
  core.style.stroke: "#1565C0"
  interface: "OS Integration"
  interface.style.fill: "#FFF3E0"
  interface.style.stroke: "#EF6C00"
  safety: "Crash Safety"
  safety.style.fill: "#FFEBEE"
  safety.style.stroke: "#C62828"
}
# Row 1: Foundation Layer
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  block_layer: {
    direction: down
    label: "M1: Block Layer & mkfs"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    block_dev: {
      shape: class
      label: "BlockDevice (block.c)"
      -fd: "int"
      -size: "uint64_t"
      -num_blocks: "uint64_t"
      +read_block(dev, block_num, buf): "int"
      +write_block(dev, block_num, data): "int"
    }
    superblock: {
      shape: sql_table
      label: "Superblock (superblock.h)"
      f0: "0x00 | uint32_t | magic"
      f1: "0x04 | uint32_t | version"
      f2: "0x08 | uint64_t | total_blocks"
      f3: "0x10 | uint64_t | total_inodes"
      f4: "0x18 | uint32_t | block_size"
      f5: "0x1C | uint32_t | inode_size"
      f6: "0x20 | uint64_t | block_bitmap_start"
      f7: "0x28 | uint64_t | inode_bitmap_start"
      f8: "0x30 | uint64_t | inode_table_start"
      f9: "0x38 | uint64_t | journal_start"
      f10: "0x40 | uint64_t | data_start"
      f11: "0x48 | uint64_t | free_blocks"
      f12: "0x50 | uint64_t | free_inodes"
      sz: "Total: 4096 bytes"
    }
    bitmap_ops: {
      shape: class
      label: "Bitmap Operations (bitmap.c)"
      +alloc_block(fs): "uint64_t"
      +free_block(fs, block_num): "int"
      +alloc_inode(fs): "uint64_t"
      +free_inode(fs, inode_num): "int"
    }
  }
}
# Row 2: Core Data Structures
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  inode_mgmt: {
    direction: down
    label: "M2: Inode Management"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    inode_struct: {
      shape: sql_table
      label: "struct Inode (inode.h)"
      f0: "0x00 | uint16_t | mode"
      f1: "0x02 | uint16_t | uid"
      f2: "0x04 | uint16_t | gid"
      f3: "0x06 | uint16_t | link_count"
      f4: "0x08 | uint64_t | size"
      f5: "0x10 | uint64_t | blocks"
      f6: "0x18 | uint64_t | atime"
      f7: "0x20 | uint64_t | mtime"
      f8: "0x28 | uint64_t | ctime"
      f9: "0x30 | uint64_t[12] | direct"
      f10: "0x90 | uint64_t | indirect"
      f11: "0x98 | uint64_t | double_ind"
      f12: "0xA0 | uint8_t[3960] | reserved"
      sz: "Total: 4096 bytes"
    }
    inode_ops: {
      shape: class
      label: "Inode Operations (inode.c)"
      +read_inode(fs, inode_num, inode): "int"
      +write_inode(fs, inode_num, inode): "int"
      +get_file_block(fs, inode, block_idx): "uint64_t"
      +get_or_alloc_block(fs, inode_num, inode, idx): "uint64_t"
      +inode_deallocate(fs, inode_num): "int"
    }
    ptr_scheme: {
      label: "Block Pointer Scheme"
      width: 300
      code: |'c
        // Direct: blocks 0-11 (0-48KB)
        // Single-indirect: blocks 12-523 (48KB-2MB)
        //   512 ptrs per indirect block
        // Double-indirect: blocks 524-262659 (2MB-1GB)
        //   512 indirect blocks, each with 512 ptrs
        #define DIRECT_BLOCKS 12
        #define PTRS_PER_INDIRECT 512
      '|
    }
  }
  dir_ops: {
    direction: down
    label: "M3: Directory Operations"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    direntry_struct: {
      shape: sql_table
      label: "struct DirEntry (dir.h)"
      f0: "0x00 | uint64_t | inode"
      f1: "0x08 | uint16_t | rec_len"
      f2: "0x0A | uint8_t | name_len"
      f3: "0x0B | uint8_t | file_type"
      f4: "0x0C | char[256] | name"
      f5: "0x10C | uint8_t[12] | padding"
      sz: "Total: 280 bytes"
    }
    dir_funcs: {
      shape: class
      label: "Directory Functions (dir.c)"
      +dir_lookup(fs, dir_inode, name): "uint64_t"
      +dir_add_entry(fs, dir_inode, name, target, type): "int"
      +dir_remove_entry(fs, dir_inode, name): "int"
      +path_resolve(fs, path): "uint64_t"
      +fs_mkdir(fs, path): "uint64_t"
      +fs_rmdir(fs, path): "int"
    }
    path_resolution: {
      label: "Path Resolution Flow"
      width: 300
      code: |'c
        // /home/user/file.txt resolution:
        // 1. Root (inode 1) -> lookup "home"
        // 2. Inode 100    -> lookup "user"  
        // 3. Inode 200    -> lookup "file.txt"
        // 4. Return inode 300
        // Each step: read dir blocks, scan entries
      '|
    }
  }
}
# Row 3: File Operations + FUSE
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  file_io: {
    direction: down
    label: "M4: File Read/Write"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    file_ops: {
      shape: class
      label: "File I/O Functions (file.c)"
      +fs_create(fs, path, mode): "uint64_t"
      +fs_read(fs, inode_num, offset, buf, len): "ssize_t"
      +fs_write(fs, inode_num, offset, data, len): "ssize_t"
      +fs_truncate(fs, inode_num, new_size): "int"
      +fs_append(fs, inode_num, data, len): "ssize_t"
    }
    sparse_file: {
      label: "Sparse File Handling"
      width: 320
      code: |'c
        // Hole detection in fs_read():
        uint64_t phys_block = get_file_block(fs, &inode, block_idx);
        if (phys_block == 0) {
          // Hole: synthesize zeros without disk I/O
          memset(buf + bytes_read, 0, to_read);
        } else {
          read_block(fs->dev, phys_block, block_buf);
          memcpy(buf + bytes_read, block_buf + offset, to_read);
        }
      '|
    }
  }
  fuse_layer: {
    direction: down
    label: "M5: FUSE Integration"
    style.fill: "#FFF3E0"
    style.stroke: "#EF6C00"
    style.stroke-width: 2
    fuse_callbacks: {
      shape: class
      label: "FUSE Callbacks (fuse_ops.c)"
      +fs_getattr(path, stbuf): "int"
      +fs_readdir(path, buf, filler, off, fi): "int"
      +fs_open(path, fi): "int"
      +fs_read(path, buf, size, off, fi): "int"
      +fs_write(path, buf, size, off, fi): "int"
      +fs_create(path, mode, fi): "int"
      +fs_mkdir(path, mode): "int"
      +fs_unlink(path): "int"
      +fs_rename(oldpath, newpath): "int"
      +fs_truncate(path, size): "int"
    }
    fuse_arch: {
      label: "Kernel-Userspace Bridge"
      width: 340
      code: |'c
        // FUSE splits filesystem in two:
        // Kernel: fuse.ko module handles VFS calls
        // Userspace: our daemon implements callbacks
        // 
        // Path: VFS -> /dev/fuse -> daemon -> response
        // Cost: ~1000 cycles per context switch
        // Benefit: crash-safe debugging, any language
      '|
    }
  }
}
# Row 4: Journaling (wraps all metadata ops)
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  journal: {
    direction: down
    label: "M6: Write-Ahead Journaling"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2
    journal_structs: {
      shape: sql_table
      label: "Journal Header (journal.h)"
      f0: "0x00 | uint32_t | magic"
      f1: "0x04 | uint32_t | version"
      f2: "0x08 | uint64_t | sequence"
      f3: "0x10 | uint64_t | head"
      f4: "0x18 | uint64_t | tail"
      f5: "0x20 | uint64_t | checksum"
      f6: "0x28 | uint8_t[4064] | padding"
      sz: "Total: 4096 bytes"
    }
    journal_entry: {
      shape: sql_table
      label: "Journal Entry"
      f0: "0x00 | uint16_t | type"
      f1: "0x02 | uint16_t | flags"
      f2: "0x04 | uint32_t | length"
      f3: "0x08 | uint64_t | sequence"
      f4: "0x10 | uint32_t | checksum"
      f5: "0x14 | uint8_t[] | data"
      sz: "Variable size"
    }
    journal_ops: {
      shape: class
      label: "Journal Operations (journal.c)"
      +journal_begin(j): "Transaction*"
      +journal_log(j, type, data, len): "int"
      +journal_commit(j): "int"
      +journal_apply(j, fs): "int"
      +journal_recover(j, fs): "int"
      +journal_checkpoint(j): "int"
    }
    txn_lifecycle: {
      label: "Transaction Lifecycle"
      width: 340
      code: |'c
        // Every metadata modification:
        // 1. BEGIN: Start transaction
        // 2. LOG: Record all changes
        // 3. COMMIT: Write to journal + fsync
        // 4. APPLY: Modify actual filesystem
        // 5. END: Free transaction
        //
        // Crash before commit: discard txn
        // Crash after commit: replay on mount
      '|
    }
  }
}
# Connections: Data flow between layers
# Block layer to inode management
row1.block_layer -> row2.inode_mgmt: "block reads/writes | support"
# Block layer to directory ops
row1.block_layer -> row2.dir_ops: "dir blocks | storage"
# Inode management to file I/O
row2.inode_mgmt -> row3.file_io: "inode pointers | data location"
# Directory ops to file I/O
row2.dir_ops -> row3.file_io: "path resolution | inode lookup"
# File I/O to FUSE
row3.file_io -> row3.fuse_layer: "file operations | API"
# Journaling wraps all metadata operations
row4.journal -> row2.inode_mgmt: "logs inode updates | protect" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
}
row4.journal -> row2.dir_ops: "logs dir changes | protect" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
}
row4.journal -> row1.block_layer: "logs bitmap updates | protect" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
}
# Journal recovery on mount
row3.fuse_layer -> row4.journal: "mount trigger | recover"
# Storage layout diagram
storage_layout: {
  label: "On-Disk Layout (per mkfs)"
  width: 600
  layout: {
    grid-columns: 6
    grid-gap: 0
    b0: "Block 0\nSuperblock" {
      style.fill: "#E8F5E9"
    }
    b1: "Blocks 1-N\nBlock\nBitmap" {
      style.fill: "#C8E6C9"
    }
    b2: "Blocks N+1-M\nInode\nBitmap" {
      style.fill: "#C8E6C9"
    }
    b3: "Blocks M+1-K\nInode\nTable" {
      style.fill: "#E3F2FD"
    }
    b4: "Blocks K+1-L\nJournal" {
      style.fill: "#FFCDD2"
    }
    b5: "Remaining\nData Blocks" {
      style.fill: "#FFF9C4"
    }
  }
}