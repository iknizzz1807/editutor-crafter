direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: package
  label: "Satellite View: The 4KB Grid (Milestone 1)"
  info: "Physical Layout of bitfs.img"
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  superblock: {
    shape: sql_table
    label: "struct superblock_t (fs.h)"
    f0: "0x00 | uint32_t | magic // 0x42495442"
    f1: "0x04 | uint32_t | version"
    f2: "0x08 | uint32_t | total_blocks"
    f3: "0x0C | uint32_t | block_size // 4096 bytes"
    f4: "0x10 | uint32_t | free_blocks"
    f5: "0x14 | uint32_t | free_inodes"
    f6: "0x18 | uint32_t | block_bitmap_start"
    f7: "0x1C | uint32_t | inode_bitmap_start"
    f8: "0x20 | uint32_t | inode_table_start"
    f9: "0x24 | uint32_t | journal_start"
    f10: "0x28 | uint32_t | data_block_start"
    f11: "0x2C | uint32_t | num_inodes"
    sz: "Total: 48 bytes (Occupies 1 Full Block)"
  }

  geometry_logic: {
    label: "Filesystem Geometry (mkfs.c)"
    code: |'c
      // 1 inode per 32KB rule
      num_inodes = total_bytes / (32 * 1024);
      
      // Bitmap size math
      block_bitmap_blocks = (total_blocks + 32767) / 32768;
      inode_bitmap_blocks = (num_inodes + 32767) / 32768;
      
      // 128B Inodes => 32 per block
      inode_table_blocks = num_inodes / 32;
    '|
    width: 400
  }
}

disk_layout: {
  label: "Global Partition Map (bitfs.img)"
  direction: right
  
  block_0: "Block 0\nSuperblock" {
    style.fill: "#C7F1FF"
    style.stroke-width: 2
  }
  
  bitmaps: "Blocks 1 to X\nBitmaps" {
    style.fill: "#B5AFF6"
    sub: "Free/Used tracking"
  }
  
  inode_table: "Blocks Y to Z\nInode Table" {
    style.fill: "#DEE1EB"
    sub: "Fixed Array of 128B structs"
  }
  
  journal: "Blocks J1 to J2\nJournal" {
    style.fill: "#88DCF7"
    sub: "Write-Ahead Log (WAL)"
  }
  
  data_blocks: "Blocks M to End\nData Blocks" {
    style.fill: "#E4DBFE"
    sub: "Raw File Contents"
  }
}

bitmap_zoom: {
  label: "Deep Dive: Allocation Bitmap (4KB Unit)"
  shape: rectangle
  
  bit_grid: {
    grid-columns: 8
    grid-gap: 5
    b0: "1" { style.fill: red }
    b1: "1" { style.fill: red }
    b2: "0" { style.fill: green }
    b3: "1" { style.fill: red }
    b4: "0" { style.fill: green }
    b5: "0" { style.fill: green }
    b6: "0" { style.fill: green }
    b7: "0" { style.fill: green }
  }
  
  caption: |'md
    **1 Block (4096 Bytes)**
    - Contains 32,768 bits
    - Each bit maps to 1 Data Block (4KB)
    - 1 Bitmap block tracks 128MB of disk
  '|
}

# Connections defining logic flow
row1.superblock -> disk_layout.block_0: "Describes"
disk_layout.bitmaps -> bitmap_zoom: "Internal Format"
disk_layout.data_blocks -> bitmap_zoom: "1 bit : 1 block"

legend: {
  shape: sql_table
  label: "Color Semantics"
  red: "Used / Allocated"
  green: "Free / Available"
  blue: "Control Metadata"
  gray: "Static Header"
}
legend.near: bottom-right