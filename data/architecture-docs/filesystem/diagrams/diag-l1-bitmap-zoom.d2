direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: callout
  label: "Microscopic: The Allocator Bit-Flip (Milestone 1)"
  style.stroke: "#2a9d8f"
  style.fill: "#e9c46a"
}

row_logic: {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  bitmap_byte: {
    shape: sql_table
    label: "Block Bitmap: Byte 0 (uint8_t)"
    bit7: "Bit 7 | 0 | Free"
    bit6: "Bit 6 | 0 | Free"
    bit5: "Bit 5 | 0 | Free"
    bit4: "Bit 4 | 0 | Free"
    target_bit: "Bit 3 | 0 -> 1 | TARGET"
    bit2: "Bit 2 | 1 | Used"
    bit1: "Bit 1 | 1 | Used"
    bit0: "Bit 0 | 1 | Used"
    
    target_bit.style.fill: "#f4a261"
    target_bit.style.bold: true
  }

  translation: {
    shape: code
    label: "Physical Address Calculation"
    code: |'c
      // Offset from start of data region
      uint32_t block_idx = (byte_idx * 8) + bit_idx;
      
      // Absolute LBA (Logical Block Address)
      uint32_t lba = sb->data_block_start + block_idx;
      
      // Byte offset in disk image
      uint64_t disk_pos = (uint64_t)lba * 4096;
    '|
    width: 400
  }
}

row_physical: {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  data_region: {
    shape: sql_table
    label: "Physical Storage Grid (Data Region)"
    b0: "Block 0 | [4096 Bytes] | Used"
    b1: "Block 1 | [4096 Bytes] | Used"
    b2: "Block 2 | [4096 Bytes] | Used"
    target_block: "Block 3 | [4096 Bytes] | ALLOCATED"
    b4: "Block 4 | [4096 Bytes] | Free"
    b5: "Block 5 | [4096 Bytes] | Free"
    
    target_block.style.fill: "#2a9d8f"
    target_block.style.font-color: white
    target_block.style.bold: true
  }
}

# Implementation Link
row_logic.bitmap_byte.target_bit -> row_physical.data_region.target_block: "1-to-1 Mapping" {
  style: {
    stroke: "#e76f51"
    stroke-width: 4
    animated: true
  }
}

legend: {
  shape: sql_table
  label: "Scale Indicators"
  s1: "1 Bit  | Tracks 4KB Block"
  s2: "1 Byte | Tracks 32KB Storage"
  s3: "1 Page | Tracks 128MB Storage"
}
legend.near: bottom-right