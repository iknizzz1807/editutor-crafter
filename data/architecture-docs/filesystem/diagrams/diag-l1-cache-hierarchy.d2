direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Header Section
title_container: {
  style.stroke: transparent
  style.fill: transparent
  near: top-center
  title: "Cache Levels and Miss Penalties" {
    style.font-size: 24
    style.bold: true
  }
  subtitle: "Hardware Soul View: Latency Cascade" {
    style.font-size: 14
    style.italic: true
  }
}

# Processor Cache Row
row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  l1: {
    label: "L1 Cache\n4 cycles (~1ns)"
    width: 160
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 8
    }
    desc: "64B cache lines | 32KB per core"
  }
  l2: {
    label: "L2 Cache\n12 cycles (~4ns)"
    width: 160
    style: {
      fill: "#DCEDC8"
      stroke: "#689F38"
      stroke-width: 2
      border-radius: 8
    }
    desc: "256KB-512KB per core"
  }
  l3: {
    label: "L3 Cache\n40 cycles (~15ns)"
    width: 160
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      stroke-width: 2
      border-radius: 8
    }
    desc: "8-64MB shared LL cache"
  }
}

# Memory and Storage Row
row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ram: {
    label: "Main Memory (RAM)\n~100ns (400x L1)"
    width: 200
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
      stroke-width: 2
      border-radius: 8
    }
    desc: "Page Cache / Block Buffer"
  }
  ssd: {
    label: "NVMe SSD\n~25-100us (1000x RAM)"
    width: 200
    style: {
      fill: "#FFCCBC"
      stroke: "#E64A19"
      stroke-width: 2
      border-radius: 8
    }
    desc: "4KB Block reads | 3GB/s Seq"
  }
  hdd: {
    label: "HDD\n~10ms (100,000x RAM)"
    width: 200
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 2
      border-radius: 8
    }
    desc: "Seek + Rotation Latency"
  }
}

# Logic Flow
row1.l1 -> row1.l2: "miss" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
row1.l2 -> row1.l3: "miss" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
row1.l3 -> row2.ram: "miss | cold" {
  style.stroke: "#F57C00"
  style.stroke-width: 2
}
row2.ram -> row2.ssd: "page fault" {
  style.stroke: "#E64A19"
  style.stroke-width: 2
  style.animated: true
}
row2.ssd -> row2.hdd: "tier swap" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 3
}

# Operations Mapping
fs_ops: {
  label: "Filesystem Operation Target Zones"
  near: bottom-center
  width: 450
  content: |md
    - **Bitmap ops**: Fit in L2/L3 (64-512KB)
    - **Inode cache**: L3 to RAM residency
    - **Block I/O**: RAM (page cache) or SSD (Direct IO)
    - **Journal writes**: Sequential SSD (optimal path)
  |
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
    border-radius: 8
  }
}

# Latency Visualization (FIXED: Using |' delimiters for content containing pipe chars)
latency_scale: {
  near: bottom-right
  style.fill: transparent
  style.stroke: transparent
  scale: |'md
    Latency Scale (logarithmic):
    L1    L2    L3    RAM   SSD      HDD
    1ns   4ns   15ns  100ns 100μs    10ms
    |-----|-----|------|-----|--------|
         4×    3×     7×    1000×    100×
  '|
}

# Metadata Legend
legend: {
  near: bottom-left
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  l1_indicator: "L1: Hottest data" { style.fill: "#C8E6C9" }
  ram_indicator: "RAM: Cache target" { style.fill: "#FFE0B2" }
  ssd_indicator: "Disk: Persistence" { style.fill: "#FFCCBC" }
}