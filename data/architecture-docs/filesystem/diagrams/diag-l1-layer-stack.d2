direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Filesystem Layer Stack
  Call flow from application to disk
| {
  near: top-center
  shape: text
  style.font-size: 32
  style.bold: true
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  apps: Applications {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    ls: {
      label: "ls"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    cat: {
      label: "cat"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    vim: {
      label: "vim"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    cp: {
      label: "cp"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    more: {
      label: "..."
      shape: text
      style.font-color: "#666666"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fuse: FUSE Layer {
    direction: down
    width: 500
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    kernel_mod: {
      label: "fuse.ko\n(kernel module)"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 200
    }
    dev_fuse: {
      label: "/dev/fuse\n(char device)"
      shape: parallelogram
      style.fill: "#90CAF9"
      width: 200
    }
    daemon: {
      label: "fs_fuse daemon\n(userspace)"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 200
    }
    kernel_mod -> dev_fuse: "request"
    dev_fuse -> daemon: "callback"
    daemon -> dev_fuse: "response"
    dev_fuse -> kernel_mod: "return"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vfs: VFS Operations {
    direction: down
    width: 500
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    ops_label: {
      label: "Virtual Filesystem Interface"
      shape: text
      style.font-size: 14
      style.bold: true
    }
    ops_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      op1: {
        label: "getattr()"
        shape: oval
        style.fill: "#FFE0B2"
      }
      op2: {
        label: "create()"
        shape: oval
        style.fill: "#FFE0B2"
      }
      op3: {
        label: "read()"
        shape: oval
        style.fill: "#FFE0B2"
      }
      op4: {
        label: "write()"
        shape: oval
        style.fill: "#FFE0B2"
      }
      op5: {
        label: "mkdir()"
        shape: oval
        style.fill: "#FFE0B2"
      }
      op6: {
        label: "readdir()"
        shape: oval
        style.fill: "#FFE0B2"
      }
    }
    op7: {
      label: "unlink()  •  rename()  •  truncate()  •  chmod()"
      shape: oval
      style.fill: "#FFE0B2"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  journal: Journaling Layer {
    direction: down
    width: 500
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    style.stroke-width: 2
    jlabel: {
      label: "Write-Ahead Log (WAL)"
      shape: text
      style.font-size: 14
      style.bold: true
    }
    jrow: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      txn: {
        label: "Transaction\nManager"
        shape: rectangle
        style.fill: "#F8BBD9"
        width: 140
      }
      commit: {
        label: "Commit\nRecord"
        shape: diamond
        style.fill: "#F8BBD9"
      }
      replay: {
        label: "Recovery\nReplay"
        shape: rectangle
        style.fill: "#F8BBD9"
        width: 140
      }
    }
    jflow: {
      label: "BEGIN → LOG → COMMIT → APPLY → END"
      shape: text
      style.font: mono
      style.font-size: 12
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  inode_dir: Inode + Directory Layer {
    direction: right
    width: 500
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    inode: {
      label: "Inode Table"
      shape: class
      mode: "uint16_t"
      uid: "uint16_t"
      gid: "uint16_t"
      size: "uint64_t"
      direct: "uint64_t[12]"
      indirect: "uint64_t"
      double_ind: "uint64_t"
    }
    dir: {
      label: "Directory Entries"
      shape: sql_table
      inode: "uint64_t"
      name: "char[256]"
      file_type: "uint8_t"
    }
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  alloc: Block Allocator {
    direction: right
    width: 500
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    style.stroke-width: 2
    block_bmp: {
      label: "Block Bitmap"
      shape: class
      alloc_block: "uint64_t"
      free_block: "int"
      BITS_PER_BLOCK: "32768"
    }
    inode_bmp: {
      label: "Inode Bitmap"
      shape: class
      alloc_inode: "uint64_t"
      free_inode: "int"
    }
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  block_dev: Block Device {
    direction: down
    width: 500
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    style.stroke-width: 2
    dev_struct: {
      label: "BlockDevice"
      shape: class
      fd: "int"
      size: "uint64_t"
      num_blocks: "uint64_t"
      read_block: "int"
      write_block: "int"
    }
    disk_img: {
      label: "disk.img\n(4KB blocks)"
      shape: cylinder
      style.fill: "#CFD8DC"
      style.multiple: true
    }
    dev_struct -> disk_img
  }
}
apps -> fuse: "syscalls\n(open, read, write)"
fuse -> vfs: "FUSE callbacks\n(getattr, create, read...)"
vfs -> journal: "wrap in\ntransaction"
journal -> inode_dir: "log metadata\nchanges"
inode_dir -> alloc: "allocate/free\nblocks + inodes"
alloc -> block_dev: "read_block()\nwrite_block()"
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  l1: {
    label: "Layer boundaries"
    shape: text
    style.font-size: 11
  }
  l2: {
    label: "→ Call direction"
    shape: text
    style.font-size: 11
  }
  l3: {
    label: "Each layer: single responsibility"
    shape: text
    style.font-size: 11
  }
  l4: {
    label: "Journal: crash safety"
    shape: text
    style.font-size: 11
  }
  l5: {
    label: "Bitmaps: O(1) allocation"
    shape: text
    style.font-size: 11
  }
}