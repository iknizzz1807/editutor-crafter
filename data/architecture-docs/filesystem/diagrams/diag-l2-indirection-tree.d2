direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "Microscopic: The Indirect Pointer Walk (Logical Block 2000)"
  style.font-size: 24
  style.bold: true
}

# --- STAGE 1: THE INODE ---
row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  inode: {
    shape: sql_table
    label: "struct bitfs_inode_t (inode.h)"
    f0: "0x00 | uint16_t | mode"
    f1: "0x04 | uint32_t | size"
    f2: "0x08 | uint32_t | direct[12]"
    f3: "0x38 | uint32_t | indirect"
    f4: "0x3C | uint32_t | db_indirect // Target"
    f5: "0x40 | uint8_t  | reserved[64]"
    sz: "Total: 128 bytes"
  }

  calc: {
    label: "Logic: Seek(2000)"
    code: |'c
      // 2000 is > (12 + 1024)
      uint32_t rel = 2000 - 1036;
      uint32_t i1 = rel / 1024; // 0
      uint32_t i2 = rel % 1024; // 964
    '|
    width: 300
  }
}

# --- STAGE 2: DOUBLE INDIRECT BLOCK ---
row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  db_block: {
    shape: sql_table
    label: "Double Indirect Block (Physical #500)"
    p0: "0x0000 | uint32_t | ptr[0] // Selected (i1=0)"
    p1: "0x0004 | uint32_t | ptr[1]"
    p2: "0x.... | uint32_t | ..."
    p3: "0x0FFC | uint32_t | ptr[1023]"
    sz: "Total: 4096 bytes"
  }
}

# --- STAGE 3: SINGLE INDIRECT BLOCK ---
row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  si_block: {
    shape: sql_table
    label: "Single Indirect Block (Physical #822)"
    p0: "0x0000 | uint32_t | ptr[0]"
    p1: "0x.... | uint32_t | ..."
    p2: "0x0F10 | uint32_t | ptr[964] // Selected (i2=964)"
    p3: "0x0FFC | uint32_t | ptr[1023]"
    sz: "Total: 4096 bytes"
  }
}

# --- STAGE 4: TARGET DATA ---
row4: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  data_block: {
    shape: rectangle
    label: "Data Block (Physical #9155)"
    style: {
      fill: "#C7F1FF"
      stroke-width: 2
    }
    content: "File data at offset 8,192,000"
  }
}

# --- CONNECTIONS ---
row1.inode.f4 -> row2.db_block.p0: "addr: 500"
row2.db_block.p0 -> row3.si_block.p2: "addr: 822"
row3.si_block.p2 -> row4.data_block: "addr: 9155"

# --- LEGEND ---
legend: {
  near: bottom-right
  direction: down
  note: "Address Mapping" {
    shape: text
  }
  m1: "Direct: 0-11"
  m2: "Indirect: 12-1035"
  m3: "DB Indirect: 1036+"
}