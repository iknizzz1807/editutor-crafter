direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_fuse: {
    label: "OS INTERFACE LAYER (FUSE) [M5]"
    direction: down

    fuse_main: {
      shape: class
      label: "fuse_main.c"
      +main(argc, argv): "int"
      +fs_init(conn): "void*"
      +fs_destroy(data): "void"
      note: "Entry point & session lifecycle"
    }

    fuse_callbacks: {
      shape: class
      label: "fuse_callbacks.c"
      +getattr(path, stbuf): "int"
      +readdir(path, buf, filler, off): "int"
      +open(path, fi): "int"
      +read(path, buf, sz, off, fi): "int"
      +write(path, buf, sz, off, fi): "int"
      +mkdir(path, mode): "int"
      +unlink(path): "int"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_logic: {
    label: "FILESYSTEM LOGIC [M3-M4]"
    direction: down

    path_resolver: {
      shape: class
      label: "path.c"
      +path_parse(path, out): "int"
      +path_resolve(fs, path): "uint64_t"
      +path_resolve_parent(fs, path, name): "uint64_t"
      note: "Component-by-component traversal"
    }

    directory_ops: {
      shape: class
      label: "direntry.c"
      +dir_lookup(fs, ino, name): "uint64_t"
      +dir_add_entry(fs, p_ino, name, t_ino, type): "int"
      +dir_remove_entry(fs, p_ino, name): "int"
      +dir_is_empty(fs, ino): "int"
    }

    file_io: {
      shape: class
      label: "file_read.c / file_write.c"
      +fs_read(fs, ino, off, buf, len): "ssize_t"
      +fs_write(fs, ino, off, buf, len): "ssize_t"
      +fs_truncate(fs, ino, new_sz): "int"
      +fs_create(fs, path, mode): "uint64_t"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_core: {
    label: "METADATA & ALLOCATION [M1-M2]"
    direction: down

    inode_manager: {
      shape: class
      label: "inode.c / block_ptr.c"
      +read_inode(dev, sb, ino, out): "int"
      +write_inode(dev, sb, ino, in): "int"
      +get_file_block(dev, inode, logical_blk): "uint64_t"
      +get_or_alloc_block(fs, ino, inode, logical_blk): "uint64_t"
      +inode_free_all_blocks(fs, inode): "int"
    }

    allocator: {
      shape: class
      label: "bitmap.c"
      +block_bitmap_alloc(dev, sb, buf): "uint64_t"
      +block_bitmap_free(dev, sb, bnum, buf): "int"
      +inode_bitmap_alloc(dev, sb, buf): "uint64_t"
      +inode_bitmap_free(dev, sb, inum, buf): "int"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  layer_storage: {
    label: "STORAGE & DURABILITY [M1, M6]"
    direction: down

    journal_sys: {
      shape: class
      label: "journal_txn.c / journal_recover.c"
      +journal_begin(j): "Transaction*"
      +journal_log(j, type, data, len): "int"
      +journal_commit(j): "int"
      +journal_apply(j, fs): "int"
      +journal_recover(j, fs): "int"
      +journal_checkpoint(j): "int"
    }

    block_layer: {
      shape: class
      label: "block.c"
      +block_device_create(path, n_blks): "BlockDevice*"
      +read_block(dev, bnum, buf): "int"
      +write_block(dev, bnum, buf): "int"
      +block_device_close(dev): "void"
      scale: "4KB Block Alignment"
    }
  }
}

# STRUCT DEFINITIONS

structs: {
  shape: package
  label: "ON-DISK STRUCTURES (packed)"

  Superblock: {
    shape: sql_table
    label: "struct Superblock (superblock.h) [M1]"
    0x00_magic: "uint32_t | 0x46534D4B"
    0x04_version: "uint32_t | v1"
    0x08_total_blocks: "uint64_t"
    0x10_total_inodes: "uint64_t"
    0x20_blk_bitmap_start: "uint64_t"
    0x30_ino_bitmap_start: "uint64_t"
    0x40_ino_table_start: "uint64_t"
    0x50_journal_start: "uint64_t"
    0x60_data_start: "uint64_t"
    0x68_free_blocks: "uint64_t"
    0xFF8_checksum: "uint64_t | CRC64"
    sz: "Total: 4096 bytes"
  }

  Inode: {
    shape: sql_table
    label: "struct Inode (inode.h) [M2]"
    0x00_mode: "uint16_t | type + perms"
    0x02_uid: "uint16_t"
    0x06_link_count: "uint16_t"
    0x0A_size: "uint64_t | bytes"
    0x12_blocks: "uint64_t | 512B units"
    0x1A_atime: "uint64_t | ts"
    0x22_mtime: "uint64_t | ts"
    0x32_direct: "uint64_t[12] | blk ptrs"
    0x92_indirect: "uint64_t | single"
    0x9A_double_ind: "uint64_t | double"
    sz: "Total: 4096 bytes"
  }

  DirEntry: {
    shape: sql_table
    label: "struct DirEntry (direntry.h) [M3]"
    0x00_inode: "uint64_t | 0=unused"
    0x08_rec_len: "uint16_t | 280 bytes"
    0x0A_name_len: "uint8_t"
    0x0B_file_type: "uint8_t | DT_*"
    0x0C_name: "char[256]"
    sz: "Total: 280 bytes (14/block)"
  }

  JournalHeader: {
    shape: sql_table
    label: "struct JournalHeader (journal.h) [M6]"
    0x00_magic: "uint32_t | 0x4A524E4C"
    0x08_sequence: "uint64_t | txn counter"
    0x10_head: "uint64_t | byte offset"
    0x18_tail: "uint64_t | byte offset"
    0x30_checksum: "uint64_t | CRC64"
    sz: "Total: 4096 bytes"
  }
}

# CONNECTIONS

row1.layer_fuse.fuse_callbacks -> row2.layer_logic.path_resolver: "path | resolve"
row1.layer_fuse.fuse_callbacks -> row2.layer_logic.file_io: "ino_num | IO"
row2.layer_logic.path_resolver -> row2.layer_logic.directory_ops: "name | lookup"
row2.layer_logic.file_io -> row3.layer_core.inode_manager: "logical_blk | mapping"
row2.layer_logic.file_io -> row3.layer_core.allocator: "ENOSPC | allocate"
row3.layer_core.inode_manager -> row4.layer_storage.block_layer: "phys_blk | read/write"
row3.layer_core.inode_manager -> row4.layer_storage.journal_sys: "metadata | log" {
  style.stroke-dash: 4
}
row4.layer_storage.journal_sys -> row4.layer_storage.block_layer: "JournalEntry | sequential"

row2.layer_logic.directory_ops -> structs.DirEntry: "maps"
row3.layer_core.inode_manager -> structs.Inode: "manages"
row4.layer_storage.block_layer -> structs.Superblock: "block 0"

# INDEX

milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | filesystem-m1 | Block Layer & mkfs"
  m2: "M2 | filesystem-m2 | Inode Management"
  m3: "M3 | filesystem-m3 | Directory Operations"
  m4: "M4 | filesystem-m4 | File Read/Write"
  m5: "M5 | filesystem-m5 | FUSE Integration"
  m6: "M6 | filesystem-m6 | Journaling & Crash Safety"
}

milestone_index.near: bottom-right