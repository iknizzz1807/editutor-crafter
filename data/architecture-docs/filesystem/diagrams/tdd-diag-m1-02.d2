direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 50
  }
}

# CONFIGURATION AND STYLES
# Technical Specifications Color Palette (Intel Manual Compliance):
# Header = Purple (#6f42c1)
# Metadata = Gray/Blue (#e1e4e8)
# Data = Blue (#0366d6) 
# Free/Journal = Green (#28a745)
# Padding/Reserved = Gray (#6a737d)
# Pointers = Orange (#f66a0a)

classes: {
  header_region: {
    style: {
      fill: "#6f42c1"
      font-color: white
      stroke-width: 4
      bold: true
    }
  }
  metadata_region: {
    style: {
      fill: "#e1e4e8"
      font-color: black
      stroke-width: 2
      stroke-dash: 2
    }
  }
  data_region: {
    style: {
      fill: "#0366d6"
      font-color: white
      stroke-width: 2
      shadow: true
    }
  }
  journal_region: {
    style: {
      fill: "#28a745"
      font-color: white
      stroke-width: 2
      double-border: true
    }
  }
  pointer_edge: {
    style: {
      stroke: "#f66a0a"
      stroke-dash: 3
      stroke-width: 3
      animated: true
    }
  }
  calc_box: {
    style: {
      fill: "#fffbdd"
      stroke: "#d1d5da"
      border-radius: 5
      font: mono
    }
  }
}

# MAIN ON-DISK LAYOUT MAP
Filesystem_Layout: {
  label: "FS-V1 PHYSICAL DISK LAYOUT MAP (4KB BLOCK ALIGNMENT)"
  
  Layout_Table: {
    shape: sql_table
    style.stroke-width: 2
    
    "0x0000": "Superblock (SB_0)" {
      constraint: "LBA 0 | size=4096B"
    }
    "0x1000": "Block Bitmap (B_BMP)" {
      constraint: "LBA 1..N | size=N*4KB"
    }
    "0x1000_N": "Inode Bitmap (I_BMP)" {
      constraint: "LBA N+1..M | size=M*4KB"
    }
    "0x1000_NM": "Inode Table (I_TAB)" {
      constraint: "LBA M+1..K | size=K*4KB"
    }
    "0x1000_NMK": "Journal (J_WAL)" {
      constraint: "LBA K+1..J | size=J*4KB"
    }
    "0x1000_NMKJ": "Data Blocks (D_BLK)" {
      constraint: "LBA J+1..END | size=VAR"
    }
  }

  # Apply colors to rows via globs
  Layout_Table."0x0000".class: header_region
  Layout_Table."0x1000".class: metadata_region
  Layout_Table."0x1000_N".class: metadata_region
  Layout_Table."0x1000_NM".class: metadata_region
  Layout_Table."0x1000_NMK".class: journal_region
  Layout_Table."0x1000_NMKJ".class: data_region

  # LAYOUT CALCULATIONS LOGIC
  Logic: {
    class: calc_box
    label: ||md
      ### FS GEOMETRY INVARIANTS
      | Parameter | Calculation Formula |
      | :--- | :--- |
      | **Block Size** | 4096 Bytes (Fixed) |
      | **N (B_BMP)** | `ceil(Total_Blocks / 32768)` |
      | **M (I_BMP)** | `ceil(Total_Inodes / 32768)` |
      | **K (I_TAB)** | `(Total_Inodes * 256) / 4096` |
      | **J (WAL)** | `1024 Blocks (Fixed)` |

      **Data Start LBA**: `1 + N + M + K + J`
    ||
  }
}

# COMPONENT POINTERS (Superblock Internal Structure)
Superblock_Structure: {
  label: "SB_T MEMORY MAPPED VIEW"
  SB: {
    shape: sql_table
    class: header_region
    
    fs_magic: "uint32_t" {constraint: "0xEF53"}
    block_bitmap_ptr: "uint64_t" {constraint: "LBA Offset"}
    inode_bitmap_ptr: "uint64_t" {constraint: "LBA Offset"}
    inode_table_ptr: "uint64_t" {constraint: "LBA Offset"}
    journal_ptr: "uint64_t" {constraint: "LBA Offset"}
    data_ptr: "uint64_t" {constraint: "LBA Offset"}
    reserved_pad: "uint8_t[4048]" {constraint: "Padding"}
  }

  # Mapping Pointers to Physical Disk Regions
  SB.block_bitmap_ptr -> Filesystem_Layout.Layout_Table."0x1000": "REL_LBA" {class: pointer_edge}
  SB.inode_bitmap_ptr -> Filesystem_Layout.Layout_Table."0x1000_N": "REL_LBA" {class: pointer_edge}
  SB.inode_table_ptr -> Filesystem_Layout.Layout_Table."0x1000_NM": "REL_LBA" {class: pointer_edge}
  SB.journal_ptr -> Filesystem_Layout.Layout_Table."0x1000_NMK": "REL_LBA" {class: pointer_edge}
  SB.data_ptr -> Filesystem_Layout.Layout_Table."0x1000_NMKJ": "REL_LBA" {class: pointer_edge}
}

# DETAILED INODE STRUCTURE (Representative Data Segment)
Inode_Table_Detail: {
  label: "INODE_T DEFINITION (256B)"
  Inode: {
    shape: sql_table
    style.fill: "#f1f8ff"
    
    "0x00": "mode" {constraint: "uint16"}
    "0x02": "uid" {constraint: "uint16"}
    "0x04": "size_lo" {constraint: "uint32"}
    "0x08": "atime" {constraint: "uint32"}
    "0x0C": "ctime" {constraint: "uint32"}
    "0x10": "mtime" {constraint: "uint32"}
    "0x28": "block_ptrs" {constraint: "uint32[12]"}
    "0x58": "ext_ptr" {constraint: "uint32"}
    "0xFC": "padding" {constraint: "uint32"; class: metadata_region}
  }
}

# FOOTER ANNOTATIONS
Annotation: |md
  ### IMPLEMENTATION SPECIFICATION (V1.0)
  - **I/O Alignment**: All disk transactions MUST be 4KB aligned.
  - **Endianness**: Little-Endian (Intel Standard) for all multi-byte fields.
  - **Journaling**: WAL uses Physical LBA Circular Buffer.
  - **Checksums**: Metadata blocks (Superblock/Inodes) use CRC32C at trailing 4-bytes.
  - **Concurrency**: O_DIRECT recommended for raw block access to prevent double-buffering.
|
Annotation.near: bottom-center

# Global Style Overrides
Filesystem_Layout.Layout_Table.style.stroke: black
Filesystem_Layout.Layout_Table.style.stroke-width: 2