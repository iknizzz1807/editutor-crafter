direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 20
  }
}

classes: {
  mem_field: {
    width: 500
    height: 40
    style: {
      font: mono
      font-size: 14
      stroke-width: 1
    }
  }
}

superblock_layout: "Superblock Memory Layout (sizeof = 4096 bytes)" {
  style: {
    stroke-width: 4
    fill: white
    border-radius: 4
  }

  header_region: {
    label: "Header & Geometry (Cache Line 0)"
    grid-columns: 1
    style: {
      stroke-dash: 5
      fill: "#e1d5e7"
    }

    f0: "0x000: magic (4B)" { class: mem_field }
    f1: "0x004: version (4B)" { class: mem_field }
    f2: "0x008: total_blocks (8B)" { class: mem_field }
    f3: "0x010: total_inodes (8B)" { class: mem_field }
    f4: "0x018: block_size (4B)" { class: mem_field }
    f5: "0x01C: inode_size (4B)" { class: mem_field }
    f6: "0x020: block_bitmap_start (8B)" { class: mem_field }
    f7: "0x028: block_bitmap_blocks (8B)" { class: mem_field }
    f8: "0x030: inode_bitmap_start (8B)" { class: mem_field }
    f9: "0x038: inode_bitmap_blocks (8B)" { class: mem_field }
  }

  cl_boundary_0: "--- Cache Line Boundary (64 Bytes) ---" {
    shape: text
    style: {
      font-size: 12
      italic: true
      font-color: "#666666"
    }
  }

  pointer_region: {
    label: "Region Pointers & Dynamic Counts (Cache Line 1)"
    grid-columns: 1
    style: {
      stroke-dash: 5
      fill: "#dae8fc"
    }

    f10: "0x040: inode_table_start (8B)" { class: mem_field }
    f11: "0x048: inode_table_blocks (8B)" { class: mem_field }
    f12: "0x050: journal_start (8B)" { class: mem_field }
    f13: "0x058: journal_blocks (8B)" { class: mem_field }
    f14: "0x060: data_start (8B)" { class: mem_field }
    f15: "0x068: free_blocks (8B)" { class: mem_field }
    f16: "0x070: free_inodes (8B)" { class: mem_field }
    f17: "0x078: mount_time (8B)" { class: mem_field }
  }

  cl_boundary_1: "--- Cache Line Boundary (128 Bytes) ---" {
    shape: text
    style: {
      font-size: 12
      italic: true
      font-color: "#666666"
    }
  }

  final_region: {
    label: "Padding & Integrity"
    grid-columns: 1
    style: {
      fill: "#f5f5f5"
    }

    f18: "0x080: write_time (8B)" { 
      class: mem_field
      style.fill: "#ffe6cc" 
    }
    f19: "0x088: reserved_padding (3944B)" { 
      class: mem_field
      style.fill: "#f5f5f5"
      style.stroke-dash: 2
    }
    f20: "0xFF8: crc64_checksum (8B)" { 
      class: mem_field
      style.fill: "#dae8fc"
    }
  }

  page_boundary: "=== Page Boundary / Block End (4096B) ===" {
    shape: text
    style: {
      bold: true
      font-color: "#cc0000"
      font-size: 14
    }
  }

  # Layout sequence
  header_region -> cl_boundary_0 -> pointer_region -> cl_boundary_1 -> final_region -> page_boundary
}

legend: {
  near: bottom-right
  title: "LEGEND" { shape: text; style.bold: true }
  
  h: "Header / Geometry" {
    style.fill: "#e1d5e7"
  }
  d: "Data / Region Pointers" {
    style.fill: "#dae8fc"
  }
  s: "Status / Dynamic Metadata" {
    style.fill: "#ffe6cc"
  }
  p: "Padding / Reserved Space" {
    style.fill: "#f5f5f5"
  }
}