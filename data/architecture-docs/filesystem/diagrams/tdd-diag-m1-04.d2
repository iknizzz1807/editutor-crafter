direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# BITMAP BLOCK STRUCTURE
# Total Size: 4096 Bytes (1 Memory Page)
# Capacity: 32,768 tracking bits (1 bit per 4KB block = 128MB tracked)

bitmap_block: {
  shape: sql_table
  label: "Bitmap Page Layout (4096B)"
  style: {
    stroke: "#000000"
    stroke-width: 4 # Bold lines for Page Boundary
    fill: "#d1c4e9" # Header=Purple
  }

  "0x000": "Word 0 (uint64_t)" {
    constraint: "8 Bytes | Bits 0-63"
    style.fill: "#dae8fc" # Data=Blue
  }
  "0x008": "Word 1 (uint64_t)" {
    constraint: "8 Bytes | Bits 64-127"
    style.fill: "#dae8fc"
  }
  "0x010": "Word 2 (uint64_t)" {
    constraint: "8 Bytes | Bits 128-191"
    style.fill: "#dae8fc"
  }
  "0x018": "Word 3 (uint64_t)" {
    constraint: "8 Bytes | Bits 192-255"
    style.fill: "#dae8fc"
  }
  "0x020": "Word 4 (uint64_t)" {
    constraint: "8 Bytes | Bits 256-319"
    style.fill: "#dae8fc"
  }
  "0x028": "Word 5 (uint64_t)" {
    constraint: "8 Bytes | Bits 320-383"
    style.fill: "#dae8fc"
  }
  "0x030": "Word 6 (uint64_t)" {
    constraint: "8 Bytes | Bits 384-447"
    style.fill: "#dae8fc"
  }
  "0x038": "Word 7 (uint64_t)" {
    constraint: "8 Bytes | Bits 448-511"
    style.fill: "#dae8fc"
  }

  # Visual Boundary row for Cache Line (64 Bytes)
  "0x040": "CACHE LINE BOUNDARY (64B)" {
    constraint: "---"
    style: {
      stroke-dash: 5 # Dashed lines for Cache Line
      fill: "#eeeeee"
    }
  }

  "0x048": "... (Words 8 to 510) ..." {
    constraint: "4024 Bytes Remaining"
    style.fill: "#f5f5f5" # Padding/Gray
  }

  "0xFF8": "Word 511 (uint64_t)" {
    constraint: "8 Bytes | Bits 32704-32767"
    style.fill: "#dae8fc"
  }
}

word_detail: {
  label: "Bit-Level View (uint64_t Word)"
  style.fill: "#f8f9fa"
  
  bits: {
    grid-columns: 8
    grid-gap: 0
    
    b63: "63" { style.fill: "#cfe2f3" }
    b62: "..." { style.fill: "#cfe2f3" }
    b_mid: "i" { 
      style: {
        fill: "#f8cecc"
        bold: true
      }
    }
    b_dots: "..." { style.fill: "#cfe2f3" }
    b2: "2" { style.fill: "#cfe2f3" }
    b1: "1" { style.fill: "#cfe2f3" }
    b0: "0" { style.fill: "#cfe2f3" }
    val: "Value" { style.fill: "#d5e8d4" }
  }
}

formula: |md
  ### Bit-to-Block Translation Logic
  To determine the physical block index `phys_block` from bit coordinates:
  
  **Given Parameters:**
  - `block_idx`: Index of bitmap block in the meta-region
  - `word_idx`: Index of the 64-bit word (0-511)
  - `bit_pos`: Position within the word (0-63)
  - `data_start`: Base address/block of the data region

  **Resultant Equation:**
  `phys_block = data_start + (block_idx * 32768) + (word_idx * 64) + bit_pos`
  
  **Example:**
  `Word 0, Bit 0` of `Bitmap Block 0` maps directly to `data_start`.
| {
  near: top-right # Fixed: ELK requires constant 'near' values
  style.fill: "#fff2cc"
}

# Connect row index to detail view
bitmap_block."0x000" -> word_detail: "Detailed bit layout" {
  style: {
    stroke: "#ff9800" # Orange for Pointers
    stroke-dash: 3
  }
}

legend: {
  near: bottom-center
  page_bound: "Page Boundary (4096B)" {
    style: {
      stroke-width: 4
      stroke: "#000000"
      fill: transparent
    }
  }
  cache_bound: "Cache Line Boundary (64B)" {
    style: {
      stroke-dash: 5
      stroke: "#000000"
      fill: transparent
    }
  }
  data_word: "Data Word (uint64_t)" {
    style.fill: "#dae8fc"
  }
  padding: "Padding/Remaining" {
    style.fill: "#f5f5f5"
  }
}