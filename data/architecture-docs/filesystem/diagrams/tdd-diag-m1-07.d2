direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Root Directory Entry Block Layout
# Located at 'data_start' physical offset. 
# Repesents the byte-perfect layout of Inode 1's content.

root_block: {
  label: "Root Directory Data Block (Physical Block ID: data_start)\nTotal Size: 4096 Bytes"
  style: {
    stroke-width: 4
    fill: "#f8f9fa"
    double-border: true
  }

  layout_grid: {
    grid-columns: 3
    grid-gap: 0
    vertical-gap: 5
    
    # --- Row Header ---
    off_h: "OFFSET" { style.bold: true; shape: text }
    field_h: "FIELD DEFINITION (Memory Map)" { style.bold: true; shape: text }
    size_h: "SIZE" { style.bold: true; shape: text }

    # --- Entry 0 ('.') ---
    off0: "0x000" { shape: text }
    entry0: "DirEntry[0]: '.'" {
      grid-columns: 1
      grid-gap: 0
      inode: "inode_ptr: 1 (Root Inode)" {
        tooltip: "Points to the self-inode"
        style: { fill: "#ff9900"; font-color: white; bold: true }
      }
      meta: {
        grid-columns: 3
        grid-gap: 0
        rec_len: "rec_len: 280" { style.fill: "#9900ff"; style.font-color: white }
        name_len: "name_len: 1" { style.fill: "#9900ff"; style.font-color: white }
        type: "type: 2 (DT_DIR)" { style.fill: "#9900ff"; style.font-color: white }
      }
      name: "data: '.' (0x2E + 255 NULLs)" {
        style: { fill: "#007bff"; font-color: white }
      }
      padding: "padding: 12 bytes (Reserved)" {
        style: { fill: "#6c757d"; font-color: white }
      }
    }
    size0: "280 bytes" { shape: text }

    # --- Entry 1 ('..') ---
    off1: "0x118" { shape: text }
    entry1: "DirEntry[1]: '..'" {
      grid-columns: 1
      grid-gap: 0
      inode: "inode_ptr: 1 (Parent)" {
        tooltip: "Root is its own parent"
        style: { fill: "#ff9900"; font-color: white; bold: true }
      }
      meta: {
        grid-columns: 3
        grid-gap: 0
        rec_len: "rec_len: 280" { style.fill: "#9900ff"; style.font-color: white }
        name_len: "name_len: 2" { style.fill: "#9900ff"; style.font-color: white }
        type: "type: 2 (DT_DIR)" { style.fill: "#9900ff"; style.font-color: white }
      }
      name: "data: '..' (0x2E 0x2E + 254 NULLs)" {
        style: { fill: "#007bff"; font-color: white }
      }
      padding: "padding: 12 bytes (Reserved)" {
        style: { fill: "#6c757d"; font-color: white }
      }
    }
    size1: "280 bytes" { shape: text }

    # --- Remainder of Block ---
    off_rem: "0x230" { shape: text }
    unused: "Unallocated Directory Slots [2-13]\nFree List Head: DirEntry[2]" {
      style: {
        fill: "#28a745"
        fill-pattern: dots
        font-color: white
        stroke-dash: 2
      }
    }
    size_rem: "3360 bytes" { shape: text }

    # --- Physical Tail ---
    off_final: "0xF50" { shape: text }
    block_pad: "Internal Fragmentation / Tail Alignment" {
      style: { fill: "#6c757d"; font-color: white }
    }
    size_final: "176 bytes" { shape: text }
  }
}

legend: {
  near: bottom-right
  shape: package
  label: "Field Specification Key"
  
  header: "Metadata / Header" { style.fill: "#9900ff"; style.font-color: white }
  data: "Entry Payload (Data)" { style.fill: "#007bff"; style.font-color: white }
  ptr: "Inode Reference (Orange)" { style.fill: "#ff9900"; style.font-color: white }
  padding: "Padding (Gray)" { style.fill: "#6c757d"; style.font-color: white }
  free: "Available Memory (Green)" { style.fill: "#28a745"; style.font-color: white }
}

annotation: |md
  ### Technical Implementation Spec
  1.  **Block Alignment**: Total size is exactly 4096 bytes. All entries are 8-byte aligned.
  2.  **Invariants**:
      *   `DirEntry[0]` (offset 0): Must be `.` (current directory).
      *   `DirEntry[1]` (offset 280): Must be `..` (parent directory).
  3.  **Search Logic**: Kernel iterates by adding `rec_len` to current offset until `inode == 0` (end of list) or block boundary is reached.
  4.  **Byte Layout**:
      *   `inode`: 4B
      *   `rec_len`: 2B
      *   `name_len`: 1B
      *   `file_type`: 1B
      *   `name`: 256B (Fixed width)
      *   `padding`: 12B
| {
  near: bottom-left
}

# Physical Architecture Markers
boundary_markers: {
  cache_line_64: "64B CACHE LINE" {
    style: { stroke-dash: 5; stroke: gray; opacity: 0.6 }
  }
  page_limit_4k: "4096B PAGE BOUNDARY" {
    style: { stroke-width: 4; stroke: black }
  }
}

# Mapping relationships
root_block.layout_grid.entry0 -> boundary_markers.cache_line_64: "Crosses line"
root_block.layout_grid.block_pad -> boundary_markers.page_limit_4k: "Aligns to"