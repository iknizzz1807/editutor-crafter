direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 40
  }
}

# -------------------------------------------------------------------------
# CLASSES: Standardized Technical Design Palette
# -------------------------------------------------------------------------
classes: {
  metadata_purple: {
    style: {
      fill: "#e9d5ff"
      stroke: "#7e22ce"
      stroke-width: 1
    }
  }
  data_blue: {
    style: {
      fill: "#bfdbfe"
      stroke: "#1d4ed8"
      stroke-width: 1
    }
  }
  pointer_orange: {
    style: {
      fill: "#fed7aa"
      stroke: "#c2410c"
      stroke-width: 1
    }
  }
  padding_gray: {
    style: {
      fill: "#f3f4f6"
      stroke: "#9ca3af"
      stroke-width: 1
    }
  }
  boundary_dashed: {
    style: {
      stroke-dash: 5
      font-size: 14
      italic: true
      font-color: "#4b5563"
      fill: transparent
    }
  }
  header_cell: {
    style: {
      bold: true
      fill: "#1f2937"
      font-color: "#ffffff"
    }
  }
}

# -------------------------------------------------------------------------
# MEMORY LAYOUT: Inode Structure
# -------------------------------------------------------------------------
inode_memory_layout: {
  shape: sql_table
  label: "Inode Structure Memory Layout (sizeof=4096 bytes)"

  # Table Header
  "Offset": "Field (C Name)" {
    constraint: "Size (Bytes)"
    class: header_cell
  }

  # METADATA SECTION (Purple)
  "0x000": "i_mode (File type & Permissions)" { constraint: "2B"; class: metadata_purple }
  "0x002": "i_uid (Owner User ID)" { constraint: "2B"; class: metadata_purple }
  "0x004": "i_gid (Owner Group ID)" { constraint: "2B"; class: metadata_purple }
  "0x006": "i_links_count (Hard link count)" { constraint: "2B"; class: metadata_purple }
  "0x008": "i_size (Logical file size in bytes)" { constraint: "8B"; class: metadata_purple }
  "0x010": "i_blocks (512B-unit Block Count)" { constraint: "8B"; class: metadata_purple }
  "0x018": "i_flags (Ext4/FS flags)" { constraint: "4B"; class: metadata_purple }

  # TIMESTAMPS SECTION (Blue)
  "0x01C": "i_atime (Access Time)" { constraint: "8B"; class: data_blue }
  "0x024": "i_mtime (Modification Time)" { constraint: "8B"; class: data_blue }
  "0x02C": "i_ctime (Attribute Change Time)" { constraint: "8B"; class: data_blue }
  "0x034": "i_crtime (Creation Time)" { constraint: "8B"; class: data_blue }

  # CACHE BOUNDARY 1
  "0x03C": "--- L1 Cache Line Boundary (64B) ---" { constraint: "LINE"; class: boundary_dashed }

  # POINTERS SECTION (Orange)
  "0x040": "i_block[0..11] (12 Direct Pointers)" { constraint: "96B"; class: pointer_orange }
  "0x0A0": "i_block[12] (Single Indirect Pointer)" { constraint: "8B"; class: pointer_orange }
  
  # CACHE BOUNDARY 2
  "0x0A8_": "--- L1 Cache Line Boundary (128B) ---" { constraint: "LINE"; class: boundary_dashed }

  "0x0A8": "i_block[13] (Double Indirect Pointer)" { constraint: "8B"; class: pointer_orange }
  "0x0B0": "i_block[14] (Triple Indirect Pointer)" { constraint: "8B"; class: pointer_orange }
  "0x0B8": "i_generation (File version)" { constraint: "4B"; class: metadata_purple }

  # PADDING SECTION (Gray)
  "0x0BC": "i_pad / Reserved for expansion" { constraint: "3908B"; class: padding_gray }

  # PAGE BOUNDARY
  "0x1000": "--- Page Boundary (4096B) ---" {
    constraint: "END"
    style: {
      stroke-width: 6
      bold: true
      fill: "#000000"
      font-color: "#ffffff"
    }
  }
}

# -------------------------------------------------------------------------
# ANNOTATIONS: Technical Implementation Specs
# -------------------------------------------------------------------------
implementation_notes: |md
  ### FS Implementation Specification
  - **Memory Alignment**: `__attribute__((aligned(64)))` is applied to ensure the start of the inode aligns with the L1 cache line hardware prefetcher.
  - **Cold Path Optimization**: Direct pointers and frequently accessed metadata (UID/Size) are packed within the first 64 bytes to minimize cache misses during recursive directory traversals.
  - **Capacity Metrics**:
    - **Direct Zone**: 48 KiB
    - **Single Indirect**: 2 MiB (assuming 4KiB blocks, 512 64-bit pointers)
    - **Double Indirect**: 1 GiB
    - **Triple Indirect**: 512 GiB
  - **Padding**: The 3908 bytes of padding ensure the struct perfectly fills a standard x86_64 4KB page, preventing internal fragmentation in the slab allocator.
| {
  near: bottom-center
  style: {
    stroke-width: 0
    font-size: 12
  }
}

# Fixed Growth Indicator
growth_direction: "Memory Growth Address" {
  shape: text
  style: {
    font-size: 14
    bold: true
    italic: true
  }
}

# Connection showing direction
growth_direction -> inode_memory_layout: {
  style: {
    stroke-width: 2
    stroke-dash: 3
  }
}