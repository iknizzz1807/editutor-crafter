vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# BLOCK POINTER ZONE ATLAS
# Implementation-grade layout for inode-based pointer resolution
# sizeof=4096 bytes (one memory page)

inode_structure: {
  shape: sql_table
  style: {
    fill: "#f3e5f5" # Header: Purple
    stroke: "#7b1fa2"
    stroke-width: 2
  }
  
  label: "INODE STRUCTURE (4096 Bytes)"
  
  mode: "0x00: uint16_t mode" {
    constraint: "2B"
    style.fill: "#e3f2fd" # Data: Blue
  }
  uid_gid: "0x02: uint32_t uid/gid" {
    constraint: "4B"
    style.fill: "#e3f2fd" # Data: Blue
  }
  size: "0x0A: uint64_t size" {
    constraint: "8B"
    style.fill: "#e3f2fd" # Data: Blue
  }
  blocks: "0x12: uint64_t blocks" {
    constraint: "8B"
    style.fill: "#e3f2fd" # Data: Blue
  }
  
  direct_ptrs: "0x32: uint64_t direct[12]" {
    constraint: "96B"
    style.fill: "#e3f2fd" # Data: Blue
    style.stroke: "#1976d2"
  }
  
  indirect_ptr: "0x92: uint64_t indirect" {
    constraint: "8B"
    style.fill: "#fff3e0" # Pointers: Orange
    style.stroke: "#f57c00"
  }
  
  double_ptr: "0x9A: uint64_t double_ind" {
    constraint: "8B"
    style.fill: "#fff3e0" # Pointers: Orange
    style.stroke: "#f57c00"
  }
  
  padding: "0xA2: uint8_t reserved[3934]" {
    constraint: "3934B"
    style.fill: "#f5f5f5" # Padding: Gray
  }
}

zones: {
  # ZONE 1: DIRECT
  zone_direct: "ZONE 1: DIRECT ACCESS" {
    style.fill: "#e8f5e9" # Free/Data Zone: Green
    capacity: "48 KB"
    range: "Blocks 0 - 11"
    
    d_blocks: "12x Data Blocks" {
      shape: cylinder
      style: {
        multiple: true
        fill: "#e3f2fd"
      }
    }
  }

  # ZONE 2: SINGLE-INDIRECT
  zone_single: "ZONE 2: SINGLE-INDIRECT" {
    style.fill: "#fffde7"
    capacity: "2 MB"
    range: "Blocks 12 - 523"
    
    ind_block: "Indirect Block (4KB)" {
      shape: sql_table
      style.fill: "#fff3e0"
      ptr_0: "ptr[0] -> block 12"
      ptr_n: "ptr[511] -> block 523"
      sizeof: "512 x 8B pointers"
    }
    
    s_data: "512x Data Blocks" {
      shape: cylinder
      style: {
        multiple: true
        fill: "#e3f2fd"
      }
    }
  }

  # ZONE 3: DOUBLE-INDIRECT
  zone_double: "ZONE 3: DOUBLE-INDIRECT" {
    style.fill: "#fce4ec"
    capacity: "1 GB"
    range: "Blocks 524 - 262667"
    
    dbl_ind_block: "Double-Indirect (4KB)" {
      shape: sql_table
      style.fill: "#fff3e0"
      ptr_0: "ptr[0] -> IndBlock 0"
      ptr_n: "ptr[511] -> IndBlock 511"
    }
    
    ind_layer: "512x Indirect Blocks" {
      shape: sql_table
      style: {
        multiple: true
        fill: "#fffde7"
      }
      ptrs: "512 pointers each"
    }
    
    d_data: "262,144x Data Blocks" {
      shape: cylinder
      style: {
        multiple: true
        fill: "#e3f2fd"
      }
    }
  }
}

# Ownership and References
# Solid = Owns, Dashed = References
inode_structure.direct_ptrs -> zones.zone_direct.d_blocks: "owns (0-48KB)" {
  style: {
    stroke-width: 2
    stroke: "#1976d2"
  }
}

inode_structure.indirect_ptr -> zones.zone_single.ind_block: "references (48KB-2MB)" {
  style: {
    stroke-dash: 3
    stroke: "#f57c00"
  }
}

zones.zone_single.ind_block -> zones.zone_single.s_data: "maps to data"

inode_structure.double_ptr -> zones.zone_double.dbl_ind_block: "references (2MB-1GB)" {
  style: {
    stroke-dash: 3
    stroke: "#f57c00"
  }
}

zones.zone_double.dbl_ind_block -> zones.zone_double.ind_layer: "maps to internal nodes"
zones.zone_double.ind_layer -> zones.zone_double.d_data: "maps to leaves"

# Annotations
calculations: |md
  ### Pointer Fan-out Math
  - **Block Size**: 4096 Bytes
  - **Ptr Size**: 8 Bytes (uint64_t)
  - **Pointers per Block**: 4096 / 8 = **512**
  
  ### Capacity Atlas
  1. **Direct**: 12 * 4KB = **48 KB**
  2. **Single**: 512 * 4KB = **2,048 KB (2MB)**
  3. **Double**: 512 * 512 * 4KB = **1,048,576 KB (1GB)**
  
  **Max File Size**: 48KB + 2MB + 1GB ≈ **1.002 GB**
| {
  near: bottom-right
}

legend: {
  shape: rectangle
  near: top-right
  style: {
    stroke-dash: 2
    fill: "#ffffff"
    shadow: true
  }
  
  header: "### Access Cost Performance"
  direct: "- **Direct**: 1 I/O (Data)"
  single: "- **Single**: 2 I/O (Ptr + Data)"
  double: "- **Double**: 3 I/O (Ptr + Ptr + Data)"
}