vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- PAGE BOUNDARY MARKERS (4096B) ---
page_start: "=== PAGE START (OFFSET 0x000) ===" {
  shape: text
  style: {
    font-size: 18
    bold: true
    font-color: "#212121"
    stroke: black
    stroke-width: 4
  }
  near: top-center
}

# --- MEMORY LAYOUT DEFINITION ---
indirect_block: {
  shape: sql_table
  label: "Indirect Block Structure (Size: 4096B)"
  tooltip: "sizeof=4096 bytes (Standard x86_64 Page)"
  style: {
    stroke: black
    stroke-width: 3
    fill: "#673AB7" # Header=Purple
    font-color: white
  }

  # Offset (Left) : Field Name { constraint: Size (Right) }
  0x000: "ptrs[0] (uint64_t)" {
    constraint: "8B"
  }
  0x008: "ptrs[1] (uint64_t)" {
    constraint: "8B"
  }
  0x010: "ptrs[2] (uint64_t)" {
    constraint: "8B"
  }
  0x018: "ptrs[3] (uint64_t)" {
    constraint: "8B"
  }
  0x020: "ptrs[4] (uint64_t)" {
    constraint: "8B"
  }
  0x028: "ptrs[5] (uint64_t)" {
    constraint: "8B"
  }
  0x030: "ptrs[6] (uint64_t)" {
    constraint: "8B"
  }
  0x038: "ptrs[7] (uint64_t)" {
    constraint: "8B"
  }

  # --- 64B CACHE LINE BOUNDARY ---
  cache_boundary: "--- 64B CACHE LINE (L1) ---" {
    constraint: "Boundary"
    style: {
      stroke-dash: 5
      fill: "#FAFAFA"
      bold: true
      italic: true
    }
  }

  0x040: "ptrs[8] (uint64_t)" {
    constraint: "8B"
  }
  0x048: "ptrs[9] (uint64_t)" {
    constraint: "8B"
  }
  
  indices_ellipsis: "[... Indices 10 to 510 ...]" {
    constraint: "4008B"
    style: {
      fill: "#E0E0E0" # Padding=Gray
      stroke-dash: 3
    }
  }

  0xFF8: "ptrs[511] (uint64_t)" {
    constraint: "8B"
  }
}

# --- STYLING DATA ELEMENTS ---
# Pointers = Orange
indirect_block."0x000".style.fill: "#FF9800"
indirect_block."0x008".style.fill: "#FF9800"
indirect_block."0x010".style.fill: "#FF9800"
indirect_block."0x018".style.fill: "#FF9800"
indirect_block."0x020".style.fill: "#FF9800"
indirect_block."0x028".style.fill: "#FF9800"
indirect_block."0x030".style.fill: "#FF9800"
indirect_block."0x038".style.fill: "#FF9800"
indirect_block."0x040".style.fill: "#FF9800"
indirect_block."0x048".style.fill: "#FF9800"
indirect_block."0xFF8".style.fill: "#FF9800"

# --- ANNOTATIONS & IMPLEMENTATION LOGIC ---
logic_spec: |md
  ### Indirect Block Implementation
  - **Encoding**: Little-Endian `uint64_t`
  - **Index Calculation**: `index = offset >> 3`
  - **Dereference**: `*uint64_t(block_ptr + (index << 3))`
  - **Cache Locality**: Each 64B line holds 8 pointers.
  - **Alignment**: Must be page-aligned (4KB).
| {
  near: top-right
  shape: text
  style.font-size: 14
}

# --- PAGE END BOUNDARY ---
page_end: "=== PAGE END (OFFSET 0xFFF) ===" {
  shape: text
  style: {
    font-size: 18
    bold: true
    font-color: "#212121"
    stroke: black
    stroke-width: 4
  }
  near: bottom-center
}

# --- LEGEND ---
legend: {
  near: bottom-right
  shape: package
  label: "Technical Specification Legend"

  pointer_def: "64-bit Pointer (Orange)" {
    style.fill: "#FF9800"
  }
  cache_def: "64B Cache Line (Dashed Line)" {
    style.stroke-dash: 5
  }
  terminal_def: "Terminal Data Block (Blue)" {
    style.fill: "#BBDEFB"
  }
  padding_def: "Padding / Ellipsis (Gray)" {
    style.fill: "#E0E0E0"
  }
}

# --- EXTERNAL TARGETS (DATA BLOCKS) ---
data_block_0: "Logical Data Block (N)" {
  tooltip: "Terminal storage block reached via ptrs[0]"
  style.fill: "#BBDEFB" # Data=Blue
  width: 250
}

data_block_511: "Logical Data Block (N+511)" {
  tooltip: "Terminal storage block reached via ptrs[511]"
  style.fill: "#BBDEFB" # Data=Blue
  width: 250
}

# --- CONNECTIONS (POINTER DEREFERENCE) ---
indirect_block."0x000" -> data_block_0: "deref (0x000)" {
  style: {
    stroke: "#FF9800" # Pointer=Orange
    stroke-width: 2
    animated: true
  }
}

indirect_block."0xFF8" -> data_block_511: "deref (0xFF8)" {
  style: {
    stroke: "#FF9800"
    stroke-width: 2
    animated: true
  }
}

# --- GLOBAL STYLING ---
direction: right
style.fill: "#FFFFFF"