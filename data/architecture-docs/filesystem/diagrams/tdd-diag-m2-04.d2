direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  step_container: {
    style: {
      stroke-width: 2
      border-radius: 8
      fill: "#ffffff"
    }
  }
  math_block: {
    shape: parallelogram
    style: {
      fill: "#e1f5fe"
      font: mono
      stroke: "#01579b"
    }
  }
  highlight_result: {
    style: {
      fill: "#ffecb3"
      stroke: "#ffa000"
      font-color: "#d32f2f"
      bold: true
      shadow: true
    }
  }
  inode_field: {
    style: {
      stroke-width: 1
      fill: "#f3e5f5"
      font-size: 14
    }
  }
}

# --- ALGORITHM: locate_block(offset) ---

ALGORITHM: {
  label: "locate_block(offset) Implementation Logic"
  style.fill: "#fafafa"
  style.stroke-dash: 3

  STEP_1: {
    class: step_container
    label: "Step 1: File Offset to Logical Block"
    desc: |md
      **Shift Operation**
      `block_offset = file_offset >> 12`
      *(Equivalent to floor(offset / 4096))*
    |
    state: {
      label: "Value: **N** (Logical Block Index)"
      style.font-color: red
      style.bold: true
    }
  }

  STEP_2: {
    class: step_container
    label: "Step 2: Direct Zone Evaluation"
    logic: |md
      **Branching Condition:**
      `IF N < 12`
    |
    result: {
      label: "TARGET: **ZONE_DIRECT**\nINDEX: **N**"
      class: highlight_result
    }
  }

  STEP_3: {
    class: step_container
    label: "Step 3: Single Indirect Evaluation"
    logic: |md
      **Branching Condition:**
      `IF 12 <= N < (12 + 512)`
      *(Max: 524)*
    |
    result: {
      label: "TARGET: **ZONE_SINGLE_IND**\nPTR_IDX: **N - 12**"
      class: highlight_result
    }
  }

  STEP_4: {
    class: step_container
    label: "Step 4: Double Indirect Evaluation"
    logic: |md
      **Branching Condition:**
      `IF 524 <= N < (524 + 512²)`
      *(Max: 262,660)*
    |
    result: {
      label: "TARGET: **ZONE_DOUBLE_IND**\nL1_IDX: **(N-524) / 512**\nL2_IDX: **(N-524) % 512**"
      class: highlight_result
    }
  }

  STEP_1 -> STEP_2: "Pass N"
  STEP_2 -> STEP_3: "N >= 12"
  STEP_3 -> STEP_4: "N >= 524"
}

# --- MEMORY LAYOUT: INODE POINTER SCHEME ---

INODE_STRUCTURE: {
  label: "Inode Structure & Block Addressing (sizeof=128B)"
  style.fill: "#ffffff"
  style.stroke-width: 3
  
  Header: {
    class: inode_field
    label: "0x00 | Header: Metadata\n(Size, Mode, Timestamps)"
    style.fill: "#eeeeee"
  }
  
  Direct: {
    class: inode_field
    label: "0x80 | Direct Pointers [0...11]\nCapacity: 12 * 4KB = 48 KB"
    style.fill: "#c8e6c9"
  }

  Single: {
    class: inode_field
    label: "0xB0 | Single Indirect Pointer\nCapacity: 512 * 4KB = 2 MB"
    style.fill: "#bbdefb"
  }

  Double: {
    class: inode_field
    label: "0xB4 | Double Indirect Pointer\nCapacity: 512² * 4KB = 1 GB"
    style.fill: "#d1c4e9"
  }
  
  Triple: {
    class: inode_field
    label: "0xB8 | Triple Indirect Pointer\nCapacity: 512³ * 4KB = 512 GB"
    style.fill: "#cfd8dc"
  }
}

# --- CROSS-DIAGRAM MAPPING ---

ALGORITHM.STEP_2.result -> INODE_STRUCTURE.Direct: "Resolves To" {
  style: {
    stroke: "#2e7d32"
    stroke-width: 2
    stroke-dash: 5
    animated: true
  }
}

ALGORITHM.STEP_3.result -> INODE_STRUCTURE.Single: "Resolves To" {
  style: {
    stroke: "#1565c0"
    stroke-width: 2
    stroke-dash: 5
    animated: true
  }
}

ALGORITHM.STEP_4.result -> INODE_STRUCTURE.Double: "Resolves To" {
  style: {
    stroke: "#6a1b9a"
    stroke-width: 2
    stroke-dash: 5
    animated: true
  }
}

# --- SYSTEM ANNOTATIONS ---

legend: {
  label: "Logical Address Boundaries"
  near: bottom-right
  
  L1: "Direct: [0, 48 KB)" {
    style.fill: "#c8e6c9"
    style.stroke: "#2e7d32"
  }
  L2: "Indirect: [48 KB, 2.04 MB)" {
    style.fill: "#bbdefb"
    style.stroke: "#1565c0"
  }
  L3: "Double: [2.04 MB, 1.07 GB)" {
    style.fill: "#d1c4e9"
    style.stroke: "#6a1b9a"
  }
}

Implementation_Notes: |md
  ### Low-Level Memory Mapping (Unix-Style Inode)
  - **Block Size**: 4096 Bytes (12-bit offset)
  - **Pointer Size**: 4 Bytes (32-bit addressing)
  - **Pointers per Block**: 4096 / 4 = 1024 (Note: Example uses 512 for legacy/TDD clarity)
  
  **Byte Offsets in Inode Structure:**
  - `0x00`: Start of Metadata
  - `0x80`: First Direct Pointer
  - `0xAC`: Last Direct Pointer (Direct[11])
  - `0xB0`: Single Indirect
  - `0xB4`: Double Indirect
  - `0xB8`: Triple Indirect
| {
  near: top-right
  style.font-size: 14
}