direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ALGORITHM: DOUBLE-INDIRECT TRAVERSAL (FS_GET_BLOCK) ---
# TDD Spec: Numbered steps matching filesystem block resolution logic.
# Layout: Side-by-side progression of memory and disk states.

traversal_process: {
  grid-columns: 2
  grid-gap: 50
  
  # STEP 1: RESOLVE INODE FIELD
  step_1: "01: Resolve Inode Entry" {
    style: {
      stroke: "#6C6AF2"
      stroke-width: 4
    }
    
    inode_mem: "Inode Structure (In Memory)" {
      shape: sql_table
      style.fill: "#E1D5E7" # Header Purple
      
      0x00: "mode: uint16" {label: "0x00: mode | 2B"; style.fill: "#F5F5F5"}
      0x02: "uid: uint32" {label: "0x02: uid | 4B"; style.fill: "#F5F5F5"}
      0x06: "gid: uint32" {label: "0x06: gid | 4B"; style.fill: "#F5F5F5"}
      0x0A: "size: uint64" {label: "0x0A: size | 8B"; style.fill: "#DAE8FC"}
      0x12: "atime: uint64" {label: "0x12: atime | 8B"; style.fill: "#DAE8FC"}
      0x32: "direct[12]: uint64[12]" {label: "0x32: direct[12] | 96B"; style.fill: "#DAE8FC"}
      0x92: "indirect: uint64" {label: "0x92: indirect | 8B"; style.fill: "#DAE8FC"}
      0x9A: "**double_ind: uint64**" {
        label: "0x9A: double_ind | 8B"
        style: {
          fill: "#FF8C00" # Pointer Orange
          font-color: white
          bold: true
          stroke: red
          stroke-width: 3
        }
      }
      0xA2: "triple_ind: uint64" {label: "0xA2: triple_ind | 8B"; style.fill: "#DAE8FC"}
      0xAA: "reserved[3958]" {label: "0xAA: padding | 3958B"; style.fill: "#F5F5F5"}
    }
    
    logic_1: |md
      ### Logical Calculation
      - **Target Logical Block**: 10,000
      - **Check Direct**: `10,000 < 12`? **NO**
      - **Check Single Indirect**: `10,000 < (12 + 512)`? **NO**
      - **Base for Double**: `10,000 - 524 = 9,476`
      - **Indices Calculation**:
        - `double_idx`: `9,476 / 512 = 18`
        - `indirect_idx`: `9,476 % 512 = 260`
      - **Action**: Fetch pointer at `Inode + 0x9A`
    |
    
    inode_mem.0x9A -> double_block_phys: "Fetch Phys Addr"
    double_block_phys: "Double-Indirect Block" {
      shape: circle
      style.stroke-dash: 3
    }
  }

  # STEP 2: L1 INDIRECT RESOLUTION
  step_2: "02: Access Level-1 Block" {
    style: {
      stroke: "#6C6AF2"
      stroke-width: 4
    }
    
    double_ind_block: "Double-Indirect Block (4KB)" {
      shape: sql_table
      style.fill: "#DAE8FC" # Data/Block Blue
      
      0x000: "ptrs[0...17]: uint64" {label: "0x000: ptrs[0...17] | 144B"; style.fill: "#F5F5F5"}
      0x090: "**ptrs[18]: uint64**" {
        label: "0x090: ptrs[18] | 8B"
        style: {
          fill: "#FF8C00" # Pointer Orange
          font-color: white
          bold: true
          stroke: red
          stroke-width: 3
        }
      }
      0x098: "ptrs[19...511]: uint64" {label: "0x098: ptrs[19...511] | 3944B"; style.fill: "#F5F5F5"}
      0xFF8: "End of Block" {label: "0xFF8: sentinel | 8B"; style.fill: "#E1D5E7"}
    }
    
    logic_2: |md
      ### Intermediate Fetch
      - Access index **18** via offset **0x090**
      - `18 * 8 bytes = 144 (0x90)`
      - Result: Physical block pointer to 
        **L2 Indirect Block**
    |
    
    double_ind_block.0x090 -> l2_block_phys: "Fetch L2 Addr"
    l2_block_phys: "Indirect Block" {
      shape: circle
      style.stroke-dash: 3
    }
  }

  # STEP 3: L2 INDIRECT RESOLUTION
  step_3: "03: Access Level-2 Block" {
    style: {
      stroke: "#6C6AF2"
      stroke-width: 4
    }
    
    indirect_block: "Indirect Block (4KB)" {
      shape: sql_table
      style.fill: "#DAE8FC"
      
      0x000: "ptrs[0...259]: uint64" {label: "0x000: ptrs[0...259] | 2080B"; style.fill: "#F5F5F5"}
      0x820: "**ptrs[260]: uint64**" {
        label: "0x820: ptrs[260] | 8B"
        style: {
          fill: "#FF8C00" # Pointer Orange
          font-color: white
          bold: true
          stroke: red
          stroke-width: 3
        }
      }
      0x828: "ptrs[261...511]: uint64" {label: "0x828: ptrs[261...511] | 2008B"; style.fill: "#F5F5F5"}
      0xFF8: "End of Block" {label: "0xFF8: sentinel | 8B"; style.fill: "#E1D5E7"}
    }
    
    logic_3: |md
      ### Final Leaf Resolution
      - Access index **260** via offset **0x820**
      - `260 * 8 bytes = 2080 (0x820)`
      - Result: Physical block pointer for 
        **Raw User Data**
    |
    
    indirect_block.0x820 -> data_phys: "Resolve User Data"
    data_phys: "Data Block" {
      shape: cylinder
      style.fill: "#DAE8FC"
    }
  }

  # STEP 4: DATA COMPLETION
  step_4: "04: Execution / DMA" {
    style: {
      stroke: "#6C6AF2"
      stroke-width: 4
    }
    
    data_content: "Data Block (Physical Storage)" {
      style.fill: "#DAE8FC"
      label: "4096 Bytes Content Payload\n[Phys Block # Resolved from Step 3]"
    }
    
    completion: |md
      ### OS Execution Result
      1. **vfs_read**: Returns target block index.
      2. **Block Layer**: Issue `bio_submit()` to disk.
      3. **Hardware**: DMA transfer from disk to kernel page cache.
      4. **User-space**: Data available in `read()` buffer.
    |
  }
}

# --- EXPLICIT STATE TRANSITIONS ---
# Logical flow connecting the steps within the grid
traversal_process.step_1 -> traversal_process.step_2: "Pointer L1" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 4
    animated: true
  }
}
traversal_process.step_2 -> traversal_process.step_3: "Pointer L2" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 4
    animated: true
  }
}
traversal_process.step_3 -> traversal_process.step_4: "I/O Request" {
  style: {
    stroke: "#28A745"
    stroke-width: 4
    animated: true
  }
}

# --- LEGEND & METADATA ---
legend: {
  near: bottom-right
  
  header_key: "Struct Header" {
    style.fill: "#E1D5E7"
  }
  data_key: "Disk Data/Pointers" {
    style.fill: "#DAE8FC"
  }
  active_key: "Active Pointer" {
    style: {
      fill: "#FF8C00"
      font-color: white
      stroke: red
    }
  }
  padding_key: "Reserved/Padding" {
    style.fill: "#F5F5F5"
  }
}

title: |md
  # Double-Indirect Traversal (Intel Manual Grade Spec)
  **Logical Target**: 10,000 blocks | **Arch**: Ext4-style Indirect Blocks | **Block**: 4KB
  **Algorithm**: Multi-level Page Table Walk equivalent for FS
| {
  near: top-center
}