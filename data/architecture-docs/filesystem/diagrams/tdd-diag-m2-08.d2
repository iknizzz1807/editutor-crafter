direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Algorithm: Inode Deallocation Tree
  **Logic:** `inode_free_all_blocks(fs, inode, bitmap_buf)`
| {near: top-center}

# --- STYLES ---
classes: {
  state_container: {
    style: {
      stroke-width: 2
      border-radius: 8
    }
  }
  inode_struct: {
    shape: sql_table
    style: {
      fill: "#F5F5F5"
      stroke: "#333333"
    }
  }
  highlight_red: {
    style: {
      fill: "#FFCCCC"
      font-color: "#FF0000"
      bold: true
    }
  }
  pointer_orange: {
    style: {
      fill: "#FFE6CC"
      stroke: "#D79B00"
    }
  }
  block_blue: {
    style: {
      fill: "#DAE8FC"
      stroke: "#6C8EBF"
    }
  }
}

# --- STEP 1: DIRECT POINTERS ---
step_1: "1. Free Direct Pointers" {
  class: state_container
  
  before: "Before: Initial State" {
    inode: "Inode (Target)" {
      class: inode_struct
      direct_0: "0x1234" {class: pointer_orange}
      direct_1: "0x1235" {class: pointer_orange}
      direct_n: "..."
      indirect: "0x5000" {class: pointer_orange}
      double_ind: "0x9000" {class: pointer_orange}
    }
    
    blocks: "Physical Storage" {
      b1234: "Block 0x1234" {class: block_blue}
      b1235: "Block 0x1235" {class: block_blue}
    }
    
    inode.direct_0 -> blocks.b1234
    inode.direct_1 -> blocks.b1235
  }

  after: "After: Directs Freed" {
    inode: "Inode (Modified)" {
      class: inode_struct
      direct_0: "**0**" {class: highlight_red}
      direct_1: "**0**" {class: highlight_red}
      direct_n: "..."
      indirect: "0x5000"
      double_ind: "0x9000"
    }
    
    bitmap: "Block Bitmap" {
      class: block_blue
      update: "Bits [0x1234, 0x1235] -> **0 (Free)**" {class: highlight_red}
    }
  }
  
  before -> after: "Iterate i=0..11"
}

# --- STEP 2: SINGLE INDIRECT ---
step_2: "2. Free Single Indirect" {
  class: state_container
  
  before: "Before: Indirect Active" {
    inode: "Inode" {
      class: inode_struct
      indirect: "0x5000" {class: pointer_orange}
    }
    
    ind_block: "Indir Block 0x5000" {
      class: inode_struct
      p0: "0x6001" {class: pointer_orange}
      p1: "0x6002" {class: pointer_orange}
    }
    
    data: "Data Blocks" {
      d1: "0x6001" {class: block_blue}
      d2: "0x6002" {class: block_blue}
    }
    
    inode.indirect -> ind_block
    ind_block.p0 -> data.d1
    ind_block.p1 -> data.d2
  }

  after: "After: Zone Cleared" {
    inode: "Inode" {
      class: inode_struct
      indirect: "**0**" {class: highlight_red}
    }
    
    status: |md
      - Free Data 0x6001
      - Free Data 0x6002
      - **Free Indirect 0x5000**
    | {class: highlight_red}
  }
  
  before -> after: "Traverse Pointers"
}

# --- STEP 3: DOUBLE INDIRECT ---
step_3: "3. Recursive Double Indirect" {
  class: state_container
  
  before: "Tree Structure" {
    inode: "Inode" {
      class: inode_struct
      double_ind: "0x9000" {class: pointer_orange}
    }
    
    dbl_block: "Dbl Block 0x9000" {
      class: inode_struct
      ip0: "0xA001" {class: pointer_orange}
      ip1: "0xA002" {class: pointer_orange}
    }
    
    ind_lvl: "Indirect Blocks" {
      i1: "Block 0xA001" {class: pointer_orange}
      i2: "Block 0xA002" {class: pointer_orange}
    }
    
    inode.double_ind -> dbl_block
    dbl_block.ip0 -> ind_lvl.i1
    dbl_block.ip1 -> ind_lvl.i2
  }

  after: "Final Deallocation" {
    inode: "Inode (Clean)" {
      class: inode_struct
      mode: "0644"
      size: "**0**" {class: highlight_red}
      blocks: "**0**" {class: highlight_red}
      direct: "All 0"
      indirect: "0"
      double_ind: "**0**" {class: highlight_red}
    }
    
    note: "All 262,144 potential data blocks\nand 513 metadata blocks freed" {
      style.italic: true
    }
  }
  
  before -> after: "Recursive free_ind()"
}

# --- FLOW ---
step_1 -> step_2 -> step_3

legend: {
  near: bottom-center
  label: "Implementation Details"
  m: |md
    - **Complexity:** O(N) where N is number of allocated blocks.
    - **I/O:** 1 read for each indirect block present.
    - **Invariants:** Bitmaps must be synced *after* pointers cleared to avoid partial-state leaks.
  |
}