direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Technical Design: Directory Lookup Linear Scan
# Algorithm: O(n) scan of directory entries within 4KB data blocks

classes: {
  step_container: {
    style: {
      stroke-width: 2
      border-radius: 8
    }
  }
  active_ptr: {
    style: {
      stroke: "#d32f2f"
      stroke-width: 4
      font-color: "#d32f2f"
      bold: true
    }
  }
  mem_block: {
    shape: sql_table
    style: {
      fill: "#e1f5fe"
      stroke: "#01579b"
    }
  }
  logic_gate: {
    shape: diamond
    style: {
      fill: "#fff9c4"
      stroke: "#fbc02d"
    }
  }
}

# --- ALGORITHM STATE: STEP 1 (BLOCK RESOLUTION) ---
Step1: "STEP 1: Logical to Physical Mapping" {
  class: step_container
  
  Inode_42: "Inode (Directory)" {
    shape: sql_table
    mode: "0x41ED (drwxr-xr-x)"
    size: "8192 (2 Blocks)"
    direct_0: "5000" {constraint: "Phys Block"}
    direct_1: "5001"
    indirect: "0"
  }

  Logic: "get_file_block(idx=0)" {
    class: logic_gate
  }

  Inode_42.direct_0 -> Logic: "Resolve Offset 0"
  Logic -> Phys_Block_5000: "Target Block"
}

# --- ALGORITHM STATE: STEP 2 (BLOCK LOAD) ---
Step2: "STEP 2: Buffer Loading" {
  class: step_container

  Disk: {
    Phys_5000: "Block 5000 (RAW)" {
      style.fill: "#cfd8dc"
    }
  }

  RAM_Buffer: "4KB Page Cache / Buffer" {
    class: mem_block
    # page boundary bold
    style.stroke-width: 4
    
    offset_000: "Entry 0 (DirEntry)" {constraint: "280B"}
    offset_280: "Entry 1 (DirEntry)" {constraint: "280B"}
    offset_560: "Entry 2 (DirEntry)" {constraint: "280B"}
    offset_others: "... 11 more entries ..."
  }

  Disk.Phys_5000 -> RAM_Buffer: "read_block(dev, 5000, buf)" {
    style.animated: true
  }
}

# --- ALGORITHM STATE: STEP 3 (ITERATIVE SCAN) ---
Step3: "STEP 3: Entry Inspection" {
  class: step_container

  Scanner: {
    target_name: "config.sys"
    
    Comparator: "strcmp(name, target)" {
      class: logic_gate
    }

    State: {
      current_entry_idx: "**1**"
      found: "**FALSE**"
      class: active_ptr
    }
  }

  Current_Buffer: {
    class: mem_block
    E0: "Entry 0: 'bin' | Inode: 50"
    E1: "Entry 1: 'config.sys' | Inode: 88" {
      style.stroke: "#d32f2f"
      style.stroke-width: 4
    }
    E2: "Entry 2: 'unused' | Inode: 0"
  }

  Scanner.Comparator -> Current_Buffer.E1: "Match?"
  Current_Buffer.E1 -> Scanner.State: "YES (Inode 88)" {
    class: active_ptr
  }
}

# --- ALGORITHM STATE: STEP 4 (TERMINATION) ---
Step4: "STEP 4: Return Result" {
  class: step_container

  Result: {
    shape: circle
    label: "Return 88"
    style.fill: "#c8e6c9"
    style.bold: true
  }

  Cleanup: "free(block_buffer)\nupdate_atime(inode)" {
    shape: parallelogram
  }

  Result -> Cleanup
}

# --- DATA STRUCTURE SPECIFICATION ---
Structure_Spec: "DirEntry Layout (280 Bytes)" {
  near: bottom-right
  
  Layout: {
    shape: sql_table
    "00_07": "inode (uint64)" {constraint: "8B"}
    "08_09": "rec_len (uint16)" {constraint: "2B"}
    "10_10": "name_len (uint8)" {constraint: "1B"}
    "11_11": "file_type (uint8)" {constraint: "1B"}
    "12_267": "name (char[256])" {constraint: "256B"}
    "268_279": "padding (uint8[12])" {constraint: "12B"}
  }
  
  Layout."00_07".style.fill: "#d1c4e9" # Header (Purple)
  Layout."12_267".style.fill: "#bbdefb" # Data (Blue)
  Layout."268_279".style.fill: "#f5f5f5" # Padding (Gray)
}

# --- COMPONENT CONNECTIONS ---
Step1 -> Step2: "Read Phys"
Step2 -> Step3: "Buffer Ready"
Step3 -> Step4: "Found"

Legend: {
  near: top-right
  note: |md
    **Search Invariants**
    - Linear Scan: O(n)
    - Block alignment: 4KB
    - Max Entries/Block: 14
    - Inode 0: End of entries/Deleted
  |
}

# Implementation Metadata
Annotation: |md
  ### Code Implementation Guide
  c
  for (uint64_t i = 0; i < num_blocks; i++) {
      phys_block = get_file_block(fs, dir_inode, i);
      read_block(fs->dev, phys_block, buffer);
      for (int j = 0; j < 14; j++) {
          if (entries[j].inode == 0) continue;
          if (strcmp(entries[j].name, target) == 0) 
              return entries[j].inode;
      }
  }
  
| {
  near: bottom-left
}