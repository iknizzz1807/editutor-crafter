direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 20
  }
}

directory_block: {
  label: "FS_BLOCK_LAYOUT: ROOT DIRECTORY (Inode 1)\nTotal Size: 4096 Bytes | Page Boundary: 4KB"
  style: {
    stroke-width: 4
    fill: "#ffffff"
    stroke: "#333333"
  }

  # --- ENTRY 0 ---
  entry_0: {
    label: "DirEntry[0]: '.' (Current)"
    style: {
      fill: "#ffffff"
      stroke: "#6200ee"
      stroke-width: 2
    }

    fields: {
      grid-columns: 3
      grid-gap: 0
      style.stroke-width: 0

      # Row 1: Pointer to Self
      off_0: "0x000" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      inode_0: "INODE_PTR = 1" {
        tooltip: "Pointer to current directory inode"
        style.fill: "#ffe0b2" # Pointers=Orange
        style.bold: true
      }
      sz_8: "8B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }

      # Row 2: Metadata
      off_8: "0x008" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      metadata_0: "rec_len=280 | name_len=1 | type=DT_DIR" {
        style.fill: "#d1c4e9" # Header=Purple
      }
      sz_4: "4B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }

      # Row 3: Name
      off_12: "0x00C" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      name_0: "name = '.' \\0" {
        style.fill: "#bbdefb" # Data=Blue
      }
      sz_256: "256B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }

      # Row 4: Alignment Padding
      off_268: "0x10C" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      pad_0: "_alignment_padding" {
        style.fill: "#eeeeee" # Padding=Gray
      }
      sz_12: "12B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
    }
  }

  cache_line_boundary: "---------------- 64B CACHE LINE BOUNDARY ----------------" {
    shape: text
    style: {
      stroke-dash: 5
      font-color: "#d32f2f"
      bold: true
    }
  }

  # --- ENTRY 1 ---
  entry_1: {
    label: "DirEntry[1]: '..' (Parent - ROOT_LOOPBACK)"
    style: {
      fill: "#ffffff"
      stroke: "#d32f2f"
      stroke-width: 2
    }

    fields: {
      grid-columns: 3
      grid-gap: 0
      style.stroke-width: 0

      # Row 1: Parent Pointer (Points to self in Root)
      off_280: "0x118" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      inode_1: "INODE_PTR = 1" {
        tooltip: "Loopback: Root's parent is Root"
        style.fill: "#ffe0b2" # Pointers=Orange
        style.bold: true
        style.stroke: "#e65100"
      }
      sz_8_1: "8B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }

      # Row 2: Metadata
      off_288: "0x120" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      metadata_1: "rec_len=280 | name_len=2 | type=DT_DIR" {
        style.fill: "#d1c4e9" # Header=Purple
      }
      sz_4_1: "4B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }

      # Row 3: Name
      off_292: "0x124" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      name_1: "name = '..' \\0" {
        style.fill: "#bbdefb" # Data=Blue
      }
      sz_256_1: "256B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }

      # Row 4: Alignment Padding
      off_548: "0x224" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      pad_1: "_alignment_padding" {
        style.fill: "#eeeeee" # Padding=Gray
      }
      sz_12_1: "12B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
    }
  }

  # --- UNUSED SPACE ---
  unused: {
    label: "Available Storage (Free Slots 2-13)"
    style: {
      fill: "#ffffff"
      stroke-dash: 5
      stroke: "#4caf50"
    }
    
    fields: {
      grid-columns: 3
      grid-gap: 0
      style.stroke-width: 0
      
      off_560: "0x230" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
      null_slots: "UNUSED_BUFFER (Zeroed)" {
        style.fill: "#c8e6c9" # Free=Green
        style.italic: true
      }
      sz_remaining: "3536B" { style.font: mono; style.stroke: "#cccccc"; style.fill: "#f8f9fa" }
    }
  }

  footer: "0x1000 | 4096B PAGE BOUNDARY | END OF BLOCK" {
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
}

# Documentation and Annotations
legend: {
  near: top-right
  pointer: "Inode Pointer" { style.fill: "#ffe0b2" }
  header: "Metadata Header" { style.fill: "#d1c4e9" }
  data: "Entry Name Data" { style.fill: "#bbdefb" }
  padding: "Padding/Alignment" { style.fill: "#eeeeee" }
  free: "Unallocated Space" { style.fill: "#c8e6c9" }
}

root_logic: |md
  ### Root Directory Implementation Details
  - **Inode 1**: Reserved for the filesystem root.
  - **Loopback Invariant**: In the root block, the parent entry `..` points back to Inode 1 to prevent upward traversal escape.
  - **Alignment**: Every directory entry is aligned to 4-byte boundaries, though internal `rec_len` padding extends to 280B for fixed-size predictability.
| {
  near: bottom-center
}

# Layout constraints to maintain vertical stack
directory_block.entry_0 -> directory_block.cache_line_boundary
directory_block.cache_line_boundary -> directory_block.entry_1
directory_block.entry_1 -> directory_block.unused
directory_block.unused -> directory_block.footer