direction: right
layout-engine: elk
theme-id: 6

# Technical Design Artist - Link Count State Transitions
# Milestone: M2/M3 - Inode and Directory Management

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

states: {
  INIT: "" {
    shape: circle
    style: {
      fill: black
      stroke-width: 0
    }
  }

  FREE: Unallocated Inode {
    style: {
      fill: "#eeeeee"
      stroke-dash: 3
    }
  }

  FILE_SINGLE: "Regular File\n(link_count = 1)" {
    tooltip: "Invariant: Exactly one directory entry points to this inode."
    style: {
      fill: "#e1f5fe"
      stroke: "#01579b"
    }
  }

  FILE_MULTI: "Regular File\n(link_count = N > 1)" {
    tooltip: "Invariant: Multiple directory entries (hard links) point to this inode."
    style: {
      fill: "#b3e5fc"
      stroke: "#01579b"
      multiple: true
    }
  }

  DIR_NEW: "Directory\n(link_count = 2)" {
    tooltip: "Invariant: Contains '.' (self) and '..' (parent) plus parent's entry."
    style: {
      fill: "#f3e5f5"
      stroke: "#4a148c"
    }
  }

  DIR_WITH_SUB: "Directory\n(link_count = N > 2)" {
    tooltip: "Invariant: link_count = 2 + number of subdirectories."
    style: {
      fill: "#e1bee7"
      stroke: "#4a148c"
      multiple: true
    }
  }
}

# --- Transitions: Regular Files ---

states.INIT -> states.FILE_SINGLE: "fs_create()\n[mode=S_IFREG]" {
  style: {
    stroke: "#01579b"
    font-color: "#01579b"
  }
}

states.FILE_SINGLE -> states.FILE_MULTI: "fs_link()\n[Action: link_count++]" {
  style: {
    stroke: "#01579b"
  }
}

states.FILE_MULTI -> states.FILE_MULTI: "fs_link()\n[Action: N++]"

states.FILE_MULTI -> states.FILE_SINGLE: "fs_unlink()\n[Guard: N == 2]" {
  style: {
    stroke: "#ef5350"
  }
}

states.FILE_SINGLE -> states.FREE: "fs_unlink()\n[Action: inode_deallocate()]" {
  style: {
    stroke: "#ef5350"
    stroke-dash: 5
  }
}

# --- Transitions: Directories ---

states.INIT -> states.DIR_NEW: "fs_mkdir()\n[mode=S_IFDIR]" {
  style: {
    stroke: "#4a148c"
    font-color: "#4a148c"
  }
}

states.DIR_NEW -> states.DIR_WITH_SUB: "fs_mkdir(child)\n[Action: link_count++]" {
  style: {
    stroke: "#4a148c"
  }
}

states.DIR_WITH_SUB -> states.DIR_WITH_SUB: "fs_mkdir(nested)\n[Action: N++]"

states.DIR_WITH_SUB -> states.DIR_NEW: "fs_rmdir(child)\n[Guard: N == 3]" {
  style: {
    stroke: "#ef5350"
  }
}

states.DIR_NEW -> states.FREE: "fs_rmdir()\n[Guard: dir_is_empty()]\n[Action: deallocate()]" {
  style: {
    stroke: "#ef5350"
    stroke-dash: 5
  }
}

# --- Illegal Transitions ---

states.DIR_NEW -> states.FILE_MULTI: "fs_link(dir)" {
  style: {
    stroke: red
    stroke-dash: 3
  }
  label: "ILLEGAL: EPERM"
}

states.DIR_WITH_SUB -> states.FREE: "fs_rmdir()" {
  style: {
    stroke: red
    stroke-dash: 3
  }
  label: "ILLEGAL: ENOTEMPTY"
}

# Annotations
legend: {
  near: bottom-right
  dir_rule: |md
    ### Directory Rule
    `link_count = 2 + subdirs`
    - 1 for entry in parent
    - 1 for `.` in self
    - 1 for each child's `..`
  |
  file_rule: |md
    ### File Rule
    `link_count = N`
    - N = total directory entries
    - Deallocated when `N == 0`
  |
}