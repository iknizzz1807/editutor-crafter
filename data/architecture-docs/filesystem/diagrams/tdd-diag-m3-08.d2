direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#d4bfff"
    data: "#b2d8ff"
    pointer: "#ffcc80"
    highlight: "#ff5252"
  }
}

"dir_is_empty Algorithm State": {
  "Step 1: Initialization": {
    "Local Variables": {
      shape: sql_table
      "entry_count": "uint32_t | 0"
      "current_block": "uint64_t | 0"
      "is_empty": "bool | true"
    }
    "Memory: Directory Inode": {
      shape: sql_table
      style.fill: "${colors.header}"
      "0x00: mode": "S_IFDIR | 0755"
      "0x0A: size": "4096 bytes"
      "0x32: direct[0]": "Block 5123"
    }
    "Active Buffer: Block 5123": {
      shape: sql_table
      style.fill: "${colors.data}"
      "Slot 0": "inode: 1, name: '.'"
      "Slot 1": "inode: 1, name: '..'"
      "Slot 2": "inode: 42, name: 'file.txt'"
      "Slot 3-13": "inode: 0 (Free)"
    }
    "Scanner": "Pointer → Slot 0" {
      style: {
        stroke: "${colors.pointer}"
        stroke-width: 4
        animated: true
      }
    }
  }

  "Step 2: Process Special Entries": {
    "Local Variables": {
      shape: sql_table
      "entry_count": "uint32_t | 0"
      "current_block": "uint64_t | 0"
      "is_empty": "bool | true"
    }
    "Status": |md
      - Found '.' (Self)
      - Found '..' (Parent)
      - **Action: Skip special entries**
    |
    "Active Buffer: Block 5123": {
      shape: sql_table
      style.fill: "${colors.data}"
      "Slot 0": "inode: 1, name: '.'" {style.stroke: gray}
      "Slot 1": "inode: 1, name: '..'" {style.stroke: gray}
      "Slot 2": "inode: 42, name: 'file.txt'"
      "Slot 3-13": "inode: 0 (Free)"
    }
    "Scanner": "Pointer → Slot 2" {
      style: {
        stroke: "${colors.pointer}"
        stroke-width: 4
      }
    }
  }

  "Step 3: Found User Entry": {
    "Local Variables": {
      shape: sql_table
      "entry_count": "**uint32_t | 1**" {
        style: {
          font-color: "${colors.highlight}"
          bold: true
        }
      }
      "current_block": "uint64_t | 0"
      "is_empty": "**bool | false**" {
        style: {
          font-color: "${colors.highlight}"
          bold: true
        }
      }
    }
    "Status": |md
      - Detected entry: **'file.txt'**
      - Name != '.' AND Name != '..'
      - **Action: Increment counter**
    |
    "Active Buffer: Block 5123": {
      shape: sql_table
      style.fill: "${colors.data}"
      "Slot 0": "inode: 1, name: '.'"
      "Slot 1": "inode: 1, name: '..'"
      "Slot 2": "**inode: 42, name: 'file.txt'**" {
        style: {
          stroke: "${colors.highlight}"
          stroke-width: 4
          fill: "#ffebee"
        }
      }
      "Slot 3-13": "inode: 0 (Free)"
    }
    "Scanner": "Match!" {
      style: {
        stroke: "${colors.highlight}"
        stroke-width: 4
      }
    }
  }

  "Step 4: Return False": {
    "Local Variables": {
      shape: sql_table
      "entry_count": "1"
      "is_empty": "false"
    }
    "Return Value": "**FALSE**" {
      shape: hexagon
      style: {
        fill: "${colors.highlight}"
        font-color: white
        bold: true
      }
    }
    "Conclusion": |md
      - Counter > 0
      - Directory is **NOT** empty
      - rmdir will fail with `ENOTEMPTY`
    |
  }
}

"Step 1: Initialization" -> "Step 2: Process Special Entries": "Next Slot"
"Step 2: Process Special Entries" -> "Step 3: Found User Entry": "Identify file.txt"
"Step 3: Found User Entry" -> "Step 4: Return False": "Halt scan"

"dir_is_empty Algorithm State".style.stroke-dash: 5