vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# HARD LINK MECHANISM
# -----------------------------------------------------------------------------
hard_link: "Hard Link: Multiple Names, Single Identity" {
  dir_block: "Directory Data Block" {
    shape: sql_table
    style: {
      fill: "#f3f4f6"
      stroke: "#9333ea"
      stroke-width: 2
    }
    
    # Offsets and directory entry types
    "file.txt": "DT_REG (Entry A)" {constraint: "inode: 100"}
    "link.txt": "DT_REG (Entry B)" {constraint: "inode: 100"}
    "unused": "0x00" {constraint: "padding"}
  }

  inode_table: "Inode Table Region" {
    inode_100: "Inode #100 (64B/4096B aligned)" {
      shape: sql_table
      style: {
        fill: "#dae8fc"
        stroke: "#2563eb"
        stroke-width: 2
      }
      
      # Field Layout for Engineer Reference
      "i_mode": "S_IFREG | 0644" {constraint: "2 bytes"}
      "i_links": "2 (Count Increment)" {constraint: "2 bytes"}
      "i_size": "1024 bytes" {constraint: "4 bytes"}
      "i_atime": "1715856000" {constraint: "8 bytes"}
      "i_block[0]": "Ptr -> Phys#5000" {constraint: "8 bytes"}
    }
  }

  data_region: "Data Blocks" {
    block_5000: "Data Block #5000" {
      style.fill: "#d5e8d4"
      style.stroke: "#16a34a"
      style.stroke-dash: 2
      label: "Actual File Content\n'Binary Data / Text Stream'"
    }
  }

  # Connections - Direct inode mapping
  # Hard links point to the same metadata structure directly
  dir_block."file.txt" -> inode_table.inode_100: "direct pointer" {
    style: {
      stroke: orange
      stroke-width: 3
    }
  }
  dir_block."link.txt" -> inode_table.inode_100: "direct pointer" {
    style: {
      stroke: orange
      stroke-width: 3
    }
  }
  inode_table.inode_100."i_block[0]" -> data_region.block_5000: "LBA Map" {
    style: {
      stroke: "#2563eb"
      stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------
# SYMBOLIC LINK MECHANISM
# -----------------------------------------------------------------------------
sym_link: "Symbolic Link: Pointer to a Path" {
  dir_block: "Directory Data Block" {
    shape: sql_table
    style: {
      fill: "#f3f4f6"
      stroke: "#9333ea"
      stroke-width: 2
    }
    
    "sym.txt": "DT_LNK (Entry C)" {constraint: "inode: 200"}
    "target.txt": "DT_REG (Entry D)" {constraint: "inode: 300"}
  }

  inode_table: "Inode Table Region" {
    inode_200: "Symlink Inode #200" {
      shape: sql_table
      style: {
        fill: "#dae8fc"
        stroke: "#2563eb"
        stroke-width: 2
      }
      
      "i_mode": "S_IFLNK | 0777" {constraint: "2 bytes"}
      "i_links": "1" {constraint: "2 bytes"}
      "i_size": "18 bytes" {constraint: "Path length"}
      "i_data": "'/home/user/target.txt'" {constraint: "Fast Symlink Data"}
    }
    
    inode_300: "Target Inode #300" {
      shape: sql_table
      style: {
        fill: "#f8cecc"
        stroke: "#dc2626"
        stroke-width: 2
      }
      
      "i_mode": "S_IFREG | 0644" {constraint: "2 bytes"}
      "i_links": "1" {constraint: "2 bytes"}
      "i_size": "500 bytes" {constraint: "4 bytes"}
      "i_block[0]": "Ptr -> Phys#9000" {constraint: "8 bytes"}
    }
  }

  # VFS Logic Layer - Corrected from unknown 'pill' to high border-radius rectangle
  vfs_resolver: "VFS Path Resolution Engine" {
    shape: rectangle
    style: {
      stroke-dash: 5
      fill: white
      border-radius: 999
      font-size: 14
      bold: true
    }
  }

  # Connections showing indirection
  dir_block."sym.txt" -> inode_table.inode_200: "map to metadata" {
    style: {
      stroke: orange
      stroke-width: 2
    }
  }
  
  # The symlink resolution process
  inode_table.inode_200."i_data" -> vfs_resolver: "parse string" {
    style: {
      stroke: "#4b5563"
      stroke-dash: 3
    }
  }
  
  vfs_resolver -> dir_block."target.txt": "recursive lookup" {
    style: {
      stroke: "#dc2626"
      stroke-dash: 5
      animated: true
    }
  }
  
  dir_block."target.txt" -> inode_table.inode_300: "resolved target" {
    style: {
      stroke: orange
      stroke-dash: 2
    }
  }
}

# Annotations and Key
legend: "Filesystem Legend & Implementation Notes" {
  near: bottom-right
  note: |md
    ### Implementation Grade Specs
    - **Hard Link**: Direct inode reference. Deleting one name does not delete the data if `i_links > 0`.
    - **Symlink**: Indirect lookup. Inode `i_data` stores the target path. If the target file is moved/deleted, the symlink breaks (Dangling Link).
    - **Performance**: Hard links provide O(1) metadata access. Symlinks require O(N) path resolution cycles through the VFS directory tree.
  |
  
  colors: {
    dir: "Directory Structure" { style.fill: "#f3f4f6" }
    inode: "Metadata (Inode)" { style.fill: "#dae8fc" }
    data: "Physical Storage" { style.fill: "#d5e8d4" }
  }
}

# Explicit separation link for layout clarity
hard_link -- sym_link: {
  style: {
    stroke-width: 0
  }
}