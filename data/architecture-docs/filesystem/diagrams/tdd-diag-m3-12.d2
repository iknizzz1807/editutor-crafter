direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    pointer: "#FF9900"
    active: "#FF0000"
    data: "#E1F5FE"
    header: "#D1C4E9"
    null_term: "#BDBDBD"
    padding: "#EEEEEE"
  }
}

# ALGORITHM: split_path("/home/user/file.txt")
# TDD REFERENCE: 29_path.c
# DATA STRUCTURE: ParsedPath { char* components[MAX]; int count; }

info_block: |md
  ### Algorithm: Path Splitter (Tokenization)
  - **Function**: `int split_path(char* input, ParsedPath* out)`
  - **Memory Model**: In-place scanning with buffer copies.
  - **Complexity**: $O(N)$ time, $O(N)$ space for results.
| {
  near: top-left
}

steps: {
  grid-columns: 1
  vertical-gap: 80
  
  s1: "Step 1: Initialization" {
    style.stroke: "#D1C4E9"
    style.stroke-width: 2
    
    input_str: "Input Buffer (char* addr: 0x7ffd)" {
      grid-columns: 20
      grid-gap: 0
      
      0: "/" {style.fill: ${colors.active}; style.bold: true; tooltip: "Offset: +0"}
      1: "h"; 2: "o"; 3: "m"; 4: "e"; 5: "/"; 6: "u"; 7: "s"; 8: "e"; 9: "r"; 10: "/"; 11: "f"; 12: "i"; 13: "l"; 14: "e"; 15: "."; 16: "t"; 17: "x"; 18: "t"
      19: "\\0" {style.fill: ${colors.null_term}; tooltip: "Null Terminator"}
    }
    
    p_ptr: "p_ptr" {
      shape: circle
      style.fill: ${colors.pointer}
    }
    
    p_ptr -> input_str.0: "base_addr" {
      style.stroke: ${colors.pointer}
      style.stroke-width: 4
    }
    
    result_array: "out->components[]" {
      grid-columns: 3
      0: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
      1: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
      2: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
    }
  }

  s2: "Step 2: Skip Leading Slashes" {
    style.stroke: "#D1C4E9"

    input_str: "Input Buffer" {
      grid-columns: 20
      grid-gap: 0
      0: "/" {style.opacity: 0.3}
      1: "h" {style.fill: ${colors.active}; style.bold: true; style.stroke: ${colors.pointer}; style.stroke-width: 3}
      2: "o"; 3: "m"; 4: "e"; 5: "/"; 6: "u"; 7: "s"; 8: "e"; 9: "r"; 10: "/"; 11: "f"; 12: "i"; 13: "l"; 14: "e"; 15: "."; 16: "t"; 17: "x"; 18: "t"
      19: "\\0" {style.fill: ${colors.null_term}}
    }
    
    p_ptr: "p++" {
      shape: circle
      style.fill: ${colors.pointer}
    }
    
    p_ptr -> input_str.1: "WHILE (*p == '/') p++" {
      style.stroke: ${colors.pointer}
      style.stroke-width: 4
    }
    
    result_array: "out->components[]" {
      grid-columns: 3
      0: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
      1: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
      2: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
    }
  }

  s3: "Step 3: Extract 'home' (Token 0)" {
    style.stroke: "#D1C4E9"

    input_str: "Input Buffer" {
      grid-columns: 20
      grid-gap: 0
      0: "/"; 1: "h"; 2: "o"; 3: "m"; 4: "e"
      5: "/" {style.fill: ${colors.active}; style.bold: true}
      6: "u"; 7: "s"; 8: "e"; 9: "r"; 10: "/"; 11: "f"; 12: "i"; 13: "l"; 14: "e"; 15: "."; 16: "t"; 17: "x"; 18: "t"; 19: "\\0"
      
      # Highlight extracted range
      1.style.fill: ${colors.data}; 1.style.bold: true
      2.style.fill: ${colors.data}; 2.style.bold: true
      3.style.fill: ${colors.data}; 3.style.bold: true
      4.style.fill: ${colors.data}; 4.style.bold: true
    }
    
    p_ptr: "p (delim)" {
      shape: circle
      style.fill: ${colors.pointer}
    }
    
    p_ptr -> input_str.5: "found '/'" {
      style.stroke: ${colors.pointer}
      style.stroke-width: 4
    }
    
    result_array: "out->components[]" {
      grid-columns: 3
      0: "**home**" {style.fill: ${colors.data}; style.bold: true; style.stroke: ${colors.active}}
      1: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
      2: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
    }
    
    input_str.1 -> result_array.0: "strndup(start, len=4)" {
      style.stroke: ${colors.active}
      style.animated: true
    }
  }

  s4: "Step 4: Extract 'user' (Token 1)" {
    style.stroke: "#D1C4E9"

    input_str: "Input Buffer" {
      grid-columns: 20
      grid-gap: 0
      0: "/"; 1: "h"; 2: "o"; 3: "m"; 4: "e"; 5: "/"
      6: "u"; 7: "s"; 8: "e"; 9: "r"
      10: "/" {style.fill: ${colors.active}; style.bold: true}
      11: "f"; 12: "i"; 13: "l"; 14: "e"; 15: "."; 16: "t"; 17: "x"; 18: "t"; 19: "\\0"
      
      # Highlight previous and current
      1.style.fill: ${colors.data}; 2.style.fill: ${colors.data}; 3.style.fill: ${colors.data}; 4.style.fill: ${colors.data}
      6.style.fill: ${colors.data}; 6.style.bold: true
      7.style.fill: ${colors.data}; 7.style.bold: true
      8.style.fill: ${colors.data}; 8.style.bold: true
      9.style.fill: ${colors.data}; 9.style.bold: true
    }
    
    p_ptr: "p (delim)" {
      shape: circle
      style.fill: ${colors.pointer}
    }
    
    p_ptr -> input_str.10: "found '/'" {
      style.stroke: ${colors.pointer}
      style.stroke-width: 4
    }
    
    result_array: "out->components[]" {
      grid-columns: 3
      0: "home" {style.fill: ${colors.data}}
      1: "**user**" {style.fill: ${colors.data}; style.bold: true; style.stroke: ${colors.active}}
      2: "NULL" {style.stroke-dash: 3; style.opacity: 0.5}
    }
    
    input_str.6 -> result_array.1: "strndup(start, len=4)" {
      style.stroke: ${colors.active}
      style.animated: true
    }
  }

  s5: "Step 5: Final Result (Token 2 + Cleanup)" {
    style.stroke: "#D1C4E9"

    input_str: "Input Buffer" {
      grid-columns: 20
      grid-gap: 0
      0: "/"; 1: "h"; 2: "o"; 3: "m"; 4: "e"; 5: "/"; 6: "u"; 7: "s"; 8: "e"; 9: "r"; 10: "/"
      11: "f"; 12: "i"; 13: "l"; 14: "e"; 15: "."; 16: "t"; 17: "x"; 18: "t"
      19: "\\0" {style.fill: ${colors.active}; style.bold: true}
      
      # All extracted
      1.style.fill: ${colors.data}; 2.style.fill: ${colors.data}; 3.style.fill: ${colors.data}; 4.style.fill: ${colors.data}
      6.style.fill: ${colors.data}; 7.style.fill: ${colors.data}; 8.style.fill: ${colors.data}; 9.style.fill: ${colors.data}
      11.style.fill: ${colors.data}; 12.style.fill: ${colors.data}; 13.style.fill: ${colors.data}; 14.style.fill: ${colors.data}; 15.style.fill: ${colors.data}; 16.style.fill: ${colors.data}; 17.style.fill: ${colors.data}; 18.style.fill: ${colors.data}
      11.style.bold: true; 18.style.bold: true
    }
    
    p_ptr: "p (EOF)" {
      shape: circle
      style.fill: ${colors.pointer}
    }
    
    p_ptr -> input_str.19: "Terminator" {
      style.stroke: ${colors.pointer}
      style.stroke-width: 4
    }
    
    result_array: "Final ParsedPath Struct" {
      grid-columns: 4
      0: "home" {style.fill: ${colors.data}}
      1: "user" {style.fill: ${colors.data}}
      2: "file.txt" {style.fill: ${colors.data}; style.bold: true; style.stroke: ${colors.active}}
      count: "3" {style.fill: ${colors.header}; style.bold: true}
    }
    
    input_str.11 -> result_array.2: "Final Token" {
      style.stroke: ${colors.active}
      style.animated: true
    }
  }
}

legend: {
  near: bottom-right
  
  ptr: "Pointer Position (p)" {
    shape: circle
    style.fill: ${colors.pointer}
  }
  
  active_cell: "Active Delimiter / Scanned" {
    style.fill: ${colors.active}
    style.bold: true
  }
  
  data_cell: "Extracted Data (Copied)" {
    style.fill: ${colors.data}
  }
  
  null_char: "Null Terminator (\\0)" {
    style.fill: ${colors.null_term}
  }
}