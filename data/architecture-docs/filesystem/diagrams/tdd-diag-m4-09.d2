direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# 1. Metadata Update Matrix: POSIX Timestamp Semantics
metadata_matrix: {
  label: "POSIX Metadata Update Logic"
  grid-columns: 4
  grid-gap: 0
  
  # Header Row (Purple per instructions)
  h_op: "Filesystem Operation" {
    style: {
      fill: "#6a0dad"
      font-color: white
      bold: true
    }
  }
  h_atime: "atime\n(Access)" {
    style: {
      fill: "#6a0dad"
      font-color: white
      bold: true
    }
  }
  h_mtime: "mtime\n(Modify)" {
    style: {
      fill: "#6a0dad"
      font-color: white
      bold: true
    }
  }
  h_ctime: "ctime\n(Change)" {
    style: {
      fill: "#6a0dad"
      font-color: white
      bold: true
    }
  }

  # Row: fs_read
  r_op: "fs_read(fd, buf, len)" { style.fill: "#e6e6fa" }
  r_atime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }
  r_mtime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }
  r_ctime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }

  # Row: fs_write
  w_op: "fs_write(fd, buf, len)" { style.fill: "#e6e6fa" }
  w_atime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }
  w_mtime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }
  w_ctime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }

  # Row: fs_truncate
  t_op: "fs_truncate(path, size)" { style.fill: "#e6e6fa" }
  t_atime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }
  t_mtime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }
  t_ctime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }

  # Row: fs_chmod
  c_op: "fs_chmod(path, mode)" { style.fill: "#e6e6fa" }
  c_atime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }
  c_mtime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }
  c_ctime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }

  # Row: fs_chown
  o_op: "fs_chown(path, uid, gid)" { style.fill: "#e6e6fa" }
  o_atime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }
  o_mtime: "-" { style.fill: "#f0f0f0"; style.font-color: "#808080" }
  o_ctime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }

  # Row: fs_utimens
  u_op: "fs_utimens(path, times)" { style.fill: "#e6e6fa" }
  u_atime: "EXPLICIT" { style.fill: "#add8e6"; style.bold: true }
  u_mtime: "EXPLICIT" { style.fill: "#add8e6"; style.bold: true }
  u_ctime: "UPDATE" { style.fill: "#90ee90"; style.bold: true }
}

# 2. Inode Memory Layout (Technical Specs)
# Exact byte offsets left margin, field sizes right margin.
inode_memory: {
  label: "Inode Timestamp Memory Map (sizeof=128 bytes)"
  grid-columns: 3
  grid-gap: 0

  # Headers
  h1: "Offset" { style.bold: true; style.underline: true }
  h2: "Field Structure" { style.bold: true; style.underline: true }
  h3: "Size" { style.bold: true; style.underline: true }

  # atime field
  off1: "0x1A" { style.font: mono }
  atime: "atime (Last Access)" { 
    style.fill: "#add8e6" 
    tooltip: "Updated on read() operations"
  }
  sz1: "8 bytes" { style.font: mono }

  # mtime field
  off2: "0x22" { style.font: mono }
  mtime: "mtime (Modification)" { 
    style.fill: "#add8e6" 
    tooltip: "Updated on write()/truncate()"
  }
  sz2: "8 bytes" { style.font: mono }

  # ctime field
  off3: "0x2A" { style.font: mono }
  ctime: "ctime (Status Change)" { 
    style.fill: "#add8e6" 
    tooltip: "Updated on any metadata change"
  }
  sz3: "8 bytes" { style.font: mono }

  # Padding Example
  off4: "0x32" { style.font: mono }
  padding: "Reserved / Padding" { 
    style.fill: "#f0f0f0" 
    style.font-color: "#808080"
  }
  sz4: "16 bytes" { style.font: mono }
}

# 3. Engineering Notes
logic_notes: |md
  ### Update Logic Invariants
  - **atime**: Last access (read, exec, readdir). Often disabled via `noatime` mount flag for performance.
  - **mtime**: Last content modification (write, truncate).
  - **ctime**: Last metadata change (chmod, chown, link count, mtime update).
  - **Sequence**: Any update to **mtime** triggers an implicit update to **ctime**.
| {
  near: top-center
}

# Relationships
metadata_matrix -> inode_memory: "Triggers In-Memory Update" {
  style.stroke: orange
  style.stroke-dash: 5
}

# Formatting for overall layout
metadata_matrix.style.stroke-width: 2
inode_memory.style.stroke-width: 2