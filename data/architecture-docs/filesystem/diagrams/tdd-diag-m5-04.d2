vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6a1b9a"
    data: "#1565c0"
    logic: "#2e7d32"
    error: "#c62828"
    highlight: "#ff8f00"
    padding: "#eeeeee"
  }
}

title: |md
  ### fs_readdir Algorithm: Filler Callback Mechanics
  **Objective**: Transform on-disk `DirEntry` records into Kernel-compatible Dirents via the `filler()` callback.
  *Implementation: FUSE-M5 / Linux VFS Interop*
| {
  near: top-center
}

# --- CONTROL FLOW ---

"Step 1: Inode Resolution" -> "Step 2: Block Traversal" -> "Step 3: Entry Validation" -> "Step 4: Prepare Stat" -> "Step 5: Invoke Filler" -> "Step 6: Termination Check"

# --- STEP DETAILS ---

"Step 1: Inode Resolution": {
  Inode_Mapping: {
    shape: sql_table
    "Path": "/home/user"
    "Inode_ID": "42"
    "dir_inode.mode": "S_IFDIR | 0755"
    "dir_inode.size": "4096 bytes"
  }
  annotation: "Daemon locks g_fuse and calls path_resolve()"
}

"Step 2: Block Traversal": {
  Block_Lookup: {
    shape: sql_table
    "Logical Block 0": "phys_block = 1024"
    "Cursor Offset": "0x0000"
    "Action": "read_block(1024, buffer)"
  }
  annotation: "Iterates through all blocks defined in inode pointers"
}

"Step 3: Entry Validation": {
  Directory_Block_Buffer: {
    shape: sql_table
    style.fill: ${colors.data}
    "0x000: inode": "101 (Used)"
    "0x008: rec_len": "28"
    "0x00C: name": "'config.yaml'"
    "0x118: inode_pad": "0 (Unused/Deleted)"
  }
  annotation: "Skips entries where inode == 0. Offset incremented by rec_len."
}

"Step 4: Prepare Stat": {
  Prepare_Stat: {
    shape: sql_table
    "struct stat.st_ino": "101"
    "struct stat.st_mode": "S_IFREG"
    "struct stat.st_size": "0 (Default for readdir)"
  }
  annotation: "Daemon constructs minimal stat structure for filler"
}

"Step 5: Invoke Filler": {
  Callback_Signature: ||md
  ### Filler Call Execution:
  `filler(buf, "config.yaml", &st, next_off)`
  
  | Param | Description |
  | :--- | :--- |
  | `buf` | FUSE kernel page buffer |
  | `name` | Extracted filename string |
  | `&st` | Prepared metadata block |
  | `next_off` | Offset for telldir/seekdir |
  ||
  style.stroke: ${colors.highlight}
  style.stroke-width: 4
}

"Step 6: Termination Check": {
  Decision: {
    shape: diamond
    label: "filler() return value?"
  }
  
  Decision -> "Continue Scanning": "0 (Success)" {
    style.stroke: ${colors.logic}
    style.bold: true
  }
  
  Decision -> "Buffer Full (Stop)": "!= 0 (Full/Error)" {
    style.stroke: ${colors.error}
    style.stroke-dash: 3
  }
  
  "Continue Scanning": {
    shape: step
    label: "Process Entry j+1"
  }
  
  "Buffer Full (Stop)": {
    shape: step
    label: "Return 0 to FUSE Kernel"
    style.fill: ${colors.error}
    style.font-color: white
  }
}

# --- MEMORY LAYOUT COMPONENTS ---

Physical_Disk: {
  label: "Backing File (disk.img)"
  block_1024: {
    label: "Directory Data Block (Index 1024)"
    style.fill: ${colors.data}
    style.opacity: 0.8
  }
}

Daemon_Memory: {
  label: "FUSE Daemon Heap/Stack"
  stack_vars: {
    label: "struct stat entry_stat"
    style.fill: ${colors.header}
    style.font-color: white
  }
  heap_buf: {
    label: "block_buffer[4096]"
    style.fill: ${colors.data}
    style.font-color: white
  }
}

Kernel_VFS_Space: {
  label: "Kernel Address Space"
  output_stream: {
    label: "VFS Page Cache / getdents64() result"
    style.stroke-dash: 5
    style.fill: ${colors.padding}
  }
}

# --- CROSS-LAYER DATA FLOW ---

Physical_Disk.block_1024 -> Daemon_Memory.heap_buf: "DMA read / dd" {
  style.stroke-width: 2
}

Daemon_Memory.heap_buf -> Daemon_Memory.stack_vars: "Deserialization" {
  label: "ext2_dir_entry_2 parsing"
}

Daemon_Memory.stack_vars -> Kernel_VFS_Space.output_stream: "filler() memcpy" {
  style.animated: true
  style.stroke: ${colors.highlight}
}

# --- LEGEND & ANNOTATIONS ---
legend: {
  near: bottom-right
  Header_Logic: "Metadata/Context" { style.fill: ${colors.header} }
  Data_Block: "Raw Storage Data" { style.fill: ${colors.data} }
  Valid_Path: "Success Path" { style.fill: ${colors.logic} }
  System_Call: "Boundary Crossing" { style.stroke: ${colors.highlight}; style.stroke-width: 3 }
  Error_Terminal: "Failure/Full" { style.fill: ${colors.error} }
}

"Step 3: Entry Validation".Directory_Block_Buffer."0x008: rec_len".style.font-color: red
"Step 3: Entry Validation".Directory_Block_Buffer."0x008: rec_len".style.bold: true