layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# Technical Design Specification: FUSE Mount Lifecycle
# State Machine Diagram for Milestone 5

classes: {
  state: {
    shape: rectangle
    style: {
      border-radius: 10
      stroke-width: 2
    }
  }
  initial: {
    shape: circle
    label: ""
    width: 20
    height: 20
    style: {
      fill: black
    }
  }
  error: {
    style: {
      fill: "#ffcccc"
      stroke: red
      font-color: red
      bold: true
    }
  }
  transition_label: {
    style: {
      font-size: 12
      italic: true
    }
  }
}

# State Definitions
START: {class: initial}

UNMOUNTED: {
  class: state
  label: "UNMOUNTED\nInvariant: FD Closed, Image Detached"
}

OPEN_FS: {
  class: state
  label: "OPEN_FS\nAction: block_device_create()\nMapping FD to disk.img"
}

VALIDATE_SB: {
  class: state
  label: "VALIDATE_SB\nAction: read_block(dev, 0, &sb)\nChecking Identification"
}

MOUNTED: {
  class: state
  label: "MOUNTED (RUNNING)\nInvariant: VFS Entry Registered\nLock: pthread_mutex_lock(&fs_lock)"
}

ERROR_CLEANUP: {
  class: [state; error]
  label: "ERROR_STATE\nerrno: EINVAL | EIO"
}

# Sequence of Transitions
START -> UNMOUNTED

UNMOUNTED -> OPEN_FS: "Trigger: parse_args\nGuard: [path exists]" {
  class: transition_label
}

OPEN_FS -> VALIDATE_SB: "Action: fs_open()\nI/O: Read Block 0" {
  class: transition_label
}

VALIDATE_SB -> MOUNTED: "Trigger: fuse_main()\nGuard: [sb.magic == FS_MAGIC]" {
  class: transition_label
}

VALIDATE_SB -> ERROR_CLEANUP: "Guard: [Magic mismatch | Checksum bad]" {
  style: {
    stroke: red
    stroke-dash: 3
  }
  class: transition_label
}

MOUNTED -> MOUNTED: "Operations: (cat, ls, mkdir)\nCallback: fs_fuse_getattr, etc." {
  class: transition_label
}

MOUNTED -> UNMOUNTED: "Trigger: unmount signal\nAction: fs_destroy() [Flush/Sync]" {
  class: transition_label
}

ERROR_CLEANUP -> UNMOUNTED: "Action: block_device_close()" {
  class: transition_label
}

# Illegal Transitions
MOUNTED -> OPEN_FS: "ILLEGAL" {
  style: {
    stroke: red
    stroke-dash: 5
    opacity: 0.5
  }
  label.style.font-color: red
}

# Legend and Metadata
legend: {
  near: bottom-right
  label: "Mount Protocol Invariants"
  
  info: |md
    - **Atomicity**: `rename` ensures inode visibility in either `old` or `new` path.
    - **Persistence**: `fs_destroy` triggers final `fsync()` on the block layer.
    - **Validation**: Checksum CRC64 calculated at `0xFF8` in Block 0.
  |
}

title: {
  shape: text
  label: "FUSE Mount Lifecycle State Machine (M5)"
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}