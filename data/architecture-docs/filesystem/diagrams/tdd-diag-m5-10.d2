layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    center: true
  }
}

# FUSE Performance Overhead Architecture
# Breakdown of 100μs getattr operation

GetAttr_Latency_Profile: {
  shape: class
  label: "FUSE GetAttr Call Profile\nsizeof=100μs (Total Latency)"
  
  # Latency Components as Fields [Name: Cost (Weight)]
  "Context Switching (2x)": "40μs (40%)"
  "FUSE Protocol Overhead": "29μs (29%)"
  "Path Resolution (M3)": "20μs (20%)"
  "Inode Read (M2)": "10μs (10%)"
  "Stat Buffer Fill (M5)": "1μs (1%)"

  # Implementation Method
  "fs_fuse_getattr(path: const char*, stbuf: struct stat*, fi: fuse_file_info*): int"
}

Kernel_Space: {
  style.fill: "#f3f4f6"
  style.stroke: "#374151"
  style.stroke-width: 2

  Application: {
    shape: person
    label: "User Process\n(ls, cat, stat)"
  }

  VFS: {
    label: "Virtual File System (VFS)\nKernel Subsystem"
    stat_syscall: "sys_newstat(path, buf)"
  }

  FUSE_Kernel_Module: {
    label: "fuse.ko\nKernel Module"
    request_queue: "fuse_req_queue"
    device_interface: "/dev/fuse"
  }
}

User_Space: {
  style.fill: "#eff6ff"
  style.stroke: "#1d4ed8"
  style.stroke-width: 2

  FUSE_Daemon: {
    label: "Filesystem Daemon\n(Userspace Process)"
    
    Path_Resolver: {
      shape: package
      label: "Path Resolver (M3)\nCost: 20μs"
      method: "path_resolve(fs, path)"
    }

    Inode_Manager: {
      shape: package
      label: "Inode Manager (M2)\nCost: 10μs"
      method: "read_inode(dev, sb, ino)"
    }

    Marshaller: {
      shape: package
      label: "FUSE Lib / Marshaller\nCost: 29μs"
      method: "fuse_reply_attr()"
    }
  }
}

# Call Sequence and Timing Annotations
Kernel_Space.Application -> Kernel_Space.VFS: "1. stat() syscall"

Kernel_Space.VFS -> Kernel_Space.FUSE_Kernel_Module: "2. Redirect to FUSE"

Kernel_Space.FUSE_Kernel_Module -> User_Space.FUSE_Daemon: "3. Context Switch 1\n(20μs Latency)" {
  style: {
    stroke: "#f97316"
    stroke-width: 3
    stroke-dash: 5
  }
}

User_Space.FUSE_Daemon.Path_Resolver -> User_Space.FUSE_Daemon.Inode_Manager: "4. Internal Logic\n(31μs Work)"

User_Space.FUSE_Daemon -> Kernel_Space.FUSE_Kernel_Module: "5. Context Switch 2\n(20μs Latency)" {
  style: {
    stroke: "#f97316"
    stroke-width: 3
    stroke-dash: 5
  }
}

Kernel_Space.FUSE_Kernel_Module -> Kernel_Space.Application: "6. Return Attributes"

# Ownership and References
User_Space.FUSE_Daemon -> User_Space.FUSE_Daemon.Path_Resolver: "owns"
User_Space.FUSE_Daemon -> User_Space.FUSE_Daemon.Inode_Manager: "owns"
User_Space.FUSE_Daemon -> User_Space.FUSE_Daemon.Marshaller: "owns"

Legend: {
  near: bottom-center
  
  Logic_Work: "Filesystem Work (31%)" {
    style.fill: "#3b82f6"
  }
  Switch_Overhead: "Context Switching (40%)" {
    style.fill: "#f97316"
  }
  Protocol_Overhead: "FUSE Protocol (29%)" {
    style.fill: "#a855f7"
  }
}

GetAttr_Latency_Profile."Context Switching (2x)".style.fill: "#fef3c7"
GetAttr_Latency_Profile."FUSE Protocol Overhead".style.fill: "#f3e8ff"
GetAttr_Latency_Profile."Path Resolution (M3)".style.fill: "#dbeafe"
GetAttr_Latency_Profile."Inode Read (M2)".style.fill: "#dbeafe"
GetAttr_Latency_Profile."Stat Buffer Fill (M5)".style.fill: "#dcfce7"