vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

journal_header_layout: {
  label: "Journal Header Structure (Total Size: 4096 Bytes)"
  
  journal_header: {
    shape: sql_table
    style: {
      stroke: "#333333"
      stroke-width: 2
      shadow: true
    }

    # Column Headers
    "Offset (Hex)": "Field Member (Type)" {constraint: "Size (Bytes)"}

    # --- CACHE LINE 0 (0x00 - 0x3F) ---
    "0x000": "magic (uint32_t)" {
      constraint: "4"
      style: {
        fill: "#E1D5E7" # Purple (Header)
        font-color: black
        bold: true
      }
    }
    "0x004": "version (uint32_t)" {
      constraint: "4"
      style: {
        fill: "#E1D5E7" # Purple (Header)
        font-color: black
      }
    }
    "0x008": "sequence (uint64_t)" {
      constraint: "8"
      style: {
        fill: "#DAE8FC" # Blue (Data)
        font-color: black
      }
    }
    "0x010": "head_ptr (uint64_t)" {
      constraint: "8"
      style: {
        fill: "#FFE6CC" # Orange (Pointer)
        font-color: black
      }
    }
    "0x018": "tail_ptr (uint64_t)" {
      constraint: "8"
      style: {
        fill: "#FFE6CC" # Orange (Pointer)
        font-color: black
      }
    }
    "0x020": "checksum (uint64_t)" {
      constraint: "8"
      style: {
        fill: "#DAE8FC" # Blue (Data)
        font-color: black
      }
    }
    "0x028": "padding_cl0 (uint8_t[24])" {
      constraint: "24"
      style: {
        fill: "#F5F5F5" # Gray (Padding)
        font-color: "#7F7F7F"
        italic: true
      }
    }

    # Cache Line Boundary Visual Row
    cl_boundary: "------------------------------------------------" {
      label: "--- 64B CACHE LINE BOUNDARY ---"
      constraint: "----"
      style: {
        stroke-dash: 5
        font-size: 10
        bold: true
        font-color: "#D73A49"
      }
    }

    # --- PAGE REMAINDER ---
    "0x040": "reserved (uint8_t[4032])" {
      constraint: "4032"
      style: {
        fill: "#F5F5F5" # Gray (Padding)
        font-color: "#7F7F7F"
        italic: true
      }
    }

    # Page Boundary Visual Row
    pg_boundary: "================================================" {
      label: "=== 4096B PAGE BOUNDARY ==="
      constraint: "===="
      style: {
        bold: true
        font-size: 12
        stroke-width: 4
        font-color: "#24292E"
      }
    }
  }
}

legend: "Memory Map Legend" {
  near: bottom-right
  
  l_header: "Header/Metadata (Purple)" {
    shape: rectangle
    style.fill: "#E1D5E7"
  }
  l_data: "Data Members (Blue)" {
    shape: rectangle
    style.fill: "#DAE8FC"
  }
  l_pointer: "Pointers/Offsets (Orange)" {
    shape: rectangle
    style.fill: "#FFE6CC"
  }
  l_padding: "Padding/Reserved (Gray)" {
    shape: rectangle
    style.fill: "#F5F5F5"
  }
}

implementation_notes: |md
  ### Journal Header Implementation Spec
  - **Magic**: Constant `0x4A524E4C` ("JRNL"). Validated on mount to verify disk format compatibility.
  - **Version**: Current schema version. Incompatible versions must block filesystem mounting to prevent data corruption.
  - **Sequence**: Monotonically increasing ID for journal rotation; used to identify the latest valid header during recovery.
  - **Head**: Byte offset within the journal log file where the next log record will be written.
  - **Tail**: Byte offset of the oldest log record required for recovery (used for Checkpointing).
  - **Checksum**: CRC64-ECMA calculated over bytes `[0x000, 0x020)`. Must be verified before updating head/tail pointers.
  - **Alignment**: The structure is explicitly padded to 4KB (standard hardware page size) to ensure atomic sector writes on modern NVMe and Advanced Format (4Kn) drives. This prevents "torn writes" of the metadata header.
| {
  near: top-right
}

# Explicit Growth Direction
growth: "Header Growth Direction" {
  shape: arrow
  direction: down
  style.stroke: "#333333"
  style.stroke-width: 2
}<ctrl63>