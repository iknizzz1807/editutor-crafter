direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

journal_entry_system: Journal Entry Type Definitions {
  description: |md
    ### Journal Entry Architecture
    Every entry in the journal consists of a fixed-size **20-byte header** followed by a **variable-length payload**.
    Entries are written sequentially to the circular buffer.
  |

  journal_entry: {
    shape: class
    label: "JournalEntry (Header)"
    type: "uint16_t"
    flags: "uint16_t"
    length: "uint32_t"
    sequence: "uint64_t"
    checksum: "uint32_t"
    
    notes: "sizeof = 20 bytes"
    style.fill: "#f3e5f5" # Purple Header
  }

  allocation_entries: Allocation Operations {
    je_inode_alloc: {
      shape: class
      label: "JE_INODE_ALLOC (1)"
      payload: "JEInodeAllocData"
      inode_num: "uint64_t"
      purpose: "Marks bit in Inode Bitmap"
      style.fill: "#e3f2fd"
    }
    je_inode_free: {
      shape: class
      label: "JE_INODE_FREE (2)"
      payload: "JEInodeFreeData"
      inode_num: "uint64_t"
      purpose: "Clears bit in Inode Bitmap"
      style.fill: "#e3f2fd"
    }
    je_block_alloc: {
      shape: class
      label: "JE_BLOCK_ALLOC (4)"
      payload: "JEBlockAllocData"
      block_num: "uint64_t"
      purpose: "Marks bit in Block Bitmap"
      style.fill: "#e3f2fd"
    }
    je_block_free: {
      shape: class
      label: "JE_BLOCK_FREE (5)"
      payload: "JEBlockFreeData"
      block_num: "uint64_t"
      purpose: "Clears bit in Block Bitmap"
      style.fill: "#e3f2fd"
    }
  }

  metadata_entries: Metadata Updates {
    je_inode_update: {
      shape: class
      label: "JE_INODE_UPDATE (3)"
      payload: "JEInodeUpdateData"
      inode_num: "uint64_t"
      inode_content: "Inode (4096B)"
      purpose: "Full metadata sync for Inode"
      style.fill: "#fff3e0"
    }
    je_sb_update: {
      shape: class
      label: "JE_SB_UPDATE (8)"
      payload: "JESbUpdateData"
      superblock: "Superblock (4096B)"
      purpose: "Updates free counts/timestamps"
      style.fill: "#fff3e0"
    }
  }

  directory_entries: Namespace Operations {
    je_dir_add: {
      shape: class
      label: "JE_DIR_ADD (6)"
      payload: "JEDirAddData"
      parent_inode: "uint64_t"
      target_inode: "uint64_t"
      name: "char[255]"
      purpose: "Inserts link into directory block"
      style.fill: "#e8f5e9"
    }
    je_dir_remove: {
      shape: class
      label: "JE_DIR_REMOVE (7)"
      payload: "JEDirRemoveData"
      parent_inode: "uint64_t"
      name: "char[255]"
      purpose: "Clears entry from directory block"
      style.fill: "#e8f5e9"
    }
  }

  transaction_control: Transaction Markers {
    je_commit: {
      shape: class
      label: "JE_COMMIT (9)"
      payload: "None (Header only)"
      purpose: "Validates transaction for replay"
      style.fill: "#ffebee"
    }
    je_abort: {
      shape: class
      label: "JE_ABORT (10)"
      payload: "None (Header only)"
      purpose: "Signals txn must be ignored"
      style.fill: "#ffebee"
    }
  }

  # Ownership relationships
  journal_entry -> allocation_entries.je_inode_alloc: owns payload
  journal_entry -> allocation_entries.je_inode_free: owns payload
  journal_entry -> allocation_entries.je_block_alloc: owns payload
  journal_entry -> allocation_entries.je_block_free: owns payload
  
  journal_entry -> metadata_entries.je_inode_update: owns payload
  journal_entry -> metadata_entries.je_sb_update: owns payload
  
  journal_entry -> directory_entries.je_dir_add: owns payload
  journal_entry -> directory_entries.je_dir_remove: owns payload
  
  journal_entry -> transaction_control.je_commit: owns payload
  journal_entry -> transaction_control.je_abort: owns payload
}

legend: {
  near: bottom-center
  header: Header (20B) { style.fill: "#f3e5f5" }
  alloc: Allocation (8B) { style.fill: "#e3f2fd" }
  meta: Metadata (4KB) { style.fill: "#fff3e0" }
  dir: Directory (Var) { style.fill: "#e8f5e9" }
  ctrl: Control (0B) { style.fill: "#ffebee" }
}