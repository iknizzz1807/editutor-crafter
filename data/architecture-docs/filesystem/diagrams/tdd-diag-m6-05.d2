layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header: "#E1D5E7"
    journal: "#D5E8D4"
    txn: "#FFF2CC"
    storage: "#F8CECC"
    kernel: "#DAE8FC"
    io_blue: "#0000FF"
    error_red: "#FF0000"
  }
}

journal_commit_sequence: {
  shape: sequence_diagram
  
  # --- ACTOR DEFINITIONS (Order Established Left-to-Right) ---
  FS: FileSystem {
    tooltip: "High-level Virtual File System layer (ext4/xfs)"
    style.fill: ${colors.header}
  }
  J: Journal {
    tooltip: "JBD2 (Journaling Block Device) sub-system"
    style.fill: ${colors.journal}
  }
  TXN: Transaction {
    tooltip: "In-memory Running/Commit Transaction Handle"
    style.fill: ${colors.txn}
  }
  OS: Kernel {
    tooltip: "Block I/O Layer & Scheduler (Bio/Request)"
    style.fill: ${colors.kernel}
  }
  DEV: BlockDevice {
    tooltip: "Physical storage (NVMe/SSD/HDD) - Non-Volatile Media"
    style.fill: ${colors.storage}
  }

  # --- INITIALIZATION PHASE ---
  init: "Step 1: Transaction Closure" {
    FS -> J: "journal_commit(Journal *j)"
    J -> J: "▼ pthread_mutex_lock(&j->lock)" {
      style.stroke: "#333333"
    }
    J -> TXN: "check txn->state == T_RUNNING"
    TXN -> J: "State Transition: T_LOCKED"
  }

  # --- LOGGING PHASE ---
  logging: "Step 2: Log Descriptor & Data Write-out" {
    J -> J: "Checksum Log Set: crc32c(txn_uuid, entries)"
    J -> J: "Generate JBD2_DESCRIPTOR_BLOCK"
    
    J -> OS: "submit_bio(WRITE | REQ_SYNC, descriptor_block)"
    OS -> DEV: "LBA Write [Log Area]" {
      style.stroke: ${colors.io_blue}
      style.stroke-width: 2
    }
    DEV -> OS: "DMA Transfer Complete"
    OS -> J: "bio_endio() Callback"
  }

  # --- COMMIT PHASE ---
  commit_point: "Step 3: Atomic Commit Record (Point of No Return)" {
    J -> J: "Construct JBD2_COMMIT_BLOCK (8-byte Tail)"
    J -> J: "Set header.block_type = JBD2_COMMIT_BLOCK"
    
    J -> OS: "submit_bio(WRITE | REQ_FUA, commit_block)" {
      style: {
        stroke: ${colors.io_blue}
        stroke-width: 3
      }
    }
    OS -> DEV: "REQ_PREFLUSH | REQ_FUA (Force Unit Access)"
    DEV -> OS: "Commit Record Persistent"
    OS -> J: "I/O Completion: Success"
  }

  # --- DURABILITY BARRIER ---
  durability: "Step 4: Durability & Hardware Cache Flush" {
    OS."CRITICAL: Pipeline Flush (Ensure Metadata/Log separation)"
    
    J -> OS: "fsync(j->dev->fd)" {
      style: {
        stroke: "#0000FF"
        stroke-width: 4
        animated: true
      }
    }
    OS -> DEV: "Issue FLUSH CACHE command"
    DEV -> OS: "NVM Write Completion"
    OS -> J: "0 (Barrier Synchronized)"
  }

  # --- FINALIZATION ---
  finalize: "Step 5: Memory State Transition" {
    J -> J: "j->header.committed_txn_count++"
    J -> TXN: "txn->state = T_FINISHED" {
      style: {
        font-color: ${colors.error_red}
        bold: true
      }
    }
    J -> J: "▲ pthread_mutex_unlock(&j->lock)"
    J -> FS: "return 0 (E_SUCCESS)"
  }

  # --- ERROR HANDLING ---
  error_handling: "Exception: I/O Device Failure during Commit" {
    J -> OS: "fsync(j->dev->fd) [RETRY_1]"
    OS -> J: "EIO (Input/Output Error)" {
      style: {
        stroke: ${colors.error_red}
        stroke-dash: 3
        bold: true
      }
    }
    
    J -> J: "journal_abort(j, -EIO)" {
      style: {
        stroke: ${colors.error_red}
        stroke-width: 2
      }
    }
    
    J -> FS: "-EIO (Filesystem Forced Read-Only)" {
      style.font-color: ${colors.error_red}
    }
  }
}

legend: {
  near: bottom-right
  label: |md
    ### Technical Specification (JBD2/EXT4 Compliance)
    - **T_LOCKED**: Transaction is closed to new handles but not yet persistent.
    - **JBD2_COMMIT_BLOCK**: The 512B/4KB block that makes the txn valid.
    - **FUA (Force Unit Access)**: Bypasses volatile drive cache; writes directly to platter/NAND.
    - **Atomic Commit Point**: If the system crashes *before* the Commit Record ACK, the entire txn is discarded during recovery.
    - **Checksum**: crc32c used to verify log integrity during the `journal_recover` phase.
  |
  
  style: {
    stroke: "#333333"
    fill: "#f9f9f9"
    shadow: true
    border-radius: 4
  }
}