direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ALGORITHM STATE: CIRCULAR BUFFER WRAP-AROUND ---

Step_1: {
  label: "Step 1: Initial Write Request\nOffset=1000, WriteSize=100"
  style.stroke-width: 2
  
  journal_view: {
    grid-columns: 10
    grid-gap: 0
    
    b998: "998" { style.fill: "#e1d5e7" }
    b999: "999" { style.fill: "#e1d5e7" }
    b1000: "1000" { 
      label: "HEAD"
      style: { 
        fill: orange
        stroke: red
        stroke-width: 4
      }
    }
    b1001: "1001" { style.fill: "#dae8fc" }
    ellipsis: "..." { style.stroke-dash: 3 }
    b1022: "1022" { style.fill: "#dae8fc" }
    b1023: "1023" { style.fill: "#dae8fc" }
    wrap: "WRAP" { shape: parallelogram; style.fill: gray }
    b0: "0" { style.fill: "#dae8fc" }
    b1: "1" { style.fill: "#dae8fc" }
  }

  header: |md
    ### Journal Header (State 0)
    - **Total Blocks:** 1024 (0x400)
    - **Head Pointer:** 1000
    - **Tail Pointer:** 500
    - **Write Requested:** 100 blocks
  |
  
  logic: |md
    **Boundary Check:**
    `AvailableSpace = Total - Head`
    `1024 - 1000 = 24 blocks`
    `Required (100) > Available (24)`
    **Result:** Multi-segment write required.
  |
}

Step_2: {
  label: "Step 2: Writing Segment A\n(Blocks 1000 - 1023)"
  style.stroke-width: 2
  
  journal_view: {
    grid-columns: 10
    grid-gap: 0
    
    b998: "998" { style.fill: "#e1d5e7" }
    b999: "999" { style.fill: "#e1d5e7" }
    b1000: "1000" { style.fill: red; style.bold: true; style.stroke: black }
    b1001: "1001" { style.fill: red; style.bold: true; style.stroke: black }
    ellipsis: "..." { style.fill: red; style.bold: true; style.stroke: black }
    b1022: "1022" { style.fill: red; style.bold: true; style.stroke: black }
    b1023: "1023" { style.fill: red; style.bold: true; style.stroke: black }
    wrap: "WRAP" { shape: parallelogram; style.fill: yellow; label: "ACTIVE WRAP" }
    b0: "0" { style.fill: "#dae8fc" }
    b1: "1" { style.fill: "#dae8fc" }
  }

  logic: |md
    **Sub-Operation A:**
    `LinearSize = MIN(100, 1024 - 1000) = 24`
    `DMA_Write(buffer, phys_addr(1000), 24)`
    **Progress:** 24/100 blocks.
  |
}

Step_3: {
  label: "Step 3: Writing Segment B\n(Blocks 0 - 75)"
  style.stroke-width: 2
  
  journal_view: {
    grid-columns: 10
    grid-gap: 0
    
    b1022: "1022" { style.fill: red; style.opacity: 0.5 }
    b1023: "1023" { style.fill: red; style.opacity: 0.5 }
    wrap: "WRAP" { shape: parallelogram; style.fill: gray }
    b0: "0" { style.fill: red; style.bold: true; style.stroke: black }
    b1: "1" { style.fill: red; style.bold: true; style.stroke: black }
    b2: "2" { style.fill: red; style.bold: true; style.stroke: black }
    ellipsis: "..." { style.fill: red; style.bold: true; style.stroke: black }
    b74: "74" { style.fill: red; style.bold: true; style.stroke: black }
    b75: "75" { style.fill: red; style.bold: true; style.stroke: black }
    b76: "76" { style.fill: "#dae8fc" }
  }

  logic: |md
    **Sub-Operation B:**
    `Remaining = 100 - 24 = 76`
    `DMA_Write(buffer + 24, phys_addr(0), 76)`
    **Progress:** 100/100 blocks.
  |
}

Step_4: {
  label: "Step 4: Update Head Pointer"
  style.stroke-width: 2
  
  journal_view: {
    grid-columns: 10
    grid-gap: 0
    
    b73: "73" { style.fill: red; style.opacity: 0.5 }
    b74: "74" { style.fill: red; style.opacity: 0.5 }
    b75: "75" { style.fill: red; style.opacity: 0.5 }
    b76: "76" { 
      label: "NEW HEAD"
      style: { 
        fill: orange
        stroke: red
        stroke-width: 4
        bold: true
      }
    }
    b77: "77" { style.fill: "#dae8fc" }
    b78: "78" { style.fill: "#dae8fc" }
    ellipsis: "..." { style.stroke-dash: 3 }
  }

  header: |md
    ### Journal Header (Final State)
    - **Head Pointer:** 76 ( (1000 + 100) % 1024 )
    - **Tail Pointer:** 500
    - **Status:** IO_COMPLETE
  |
  
  logic: |md
    **Finalization:**
    1. Wait for DMA segment A + B.
    2. Write Journal Header to disk.
    3. `fsync()` header block.
  |
}

# --- CONTROL FLOW ---
Step_1 -> Step_2: "Space check < Requested" {
  style.stroke: red
  style.animated: true
}
Step_2 -> Step_3: "Wrap pointer to base (0)" {
  style.stroke: red
  style.animated: true
}
Step_3 -> Step_4: "Commit Header" {
  style.stroke: green
}

# --- LEGEND & ANNOTATIONS ---
# ELK engine requires constant positions for 'near'

Legend: {
  near: bottom-right
  Metadata: "Metadata/History (Purple)" { style.fill: "#e1d5e7" }
  CurrentWrite: "Active Write (Red/Bold)" { style.fill: red }
  Free: "Free Space (Blue)" { style.fill: "#dae8fc" }
  Pointer: "Head Pointer (Orange)" { style.fill: orange }
}

ann: |md
  ## Implementation Logic for Engineers
  
  c
  // Pseudo-code implementation
  void journal_write(void* data, size_t n_blocks) {
      size_t first_part = MIN(n_blocks, JOURNAL_SIZE - current_head);
      pwrite(fd, data, first_part * B_SIZE, current_head * B_SIZE);
      
      if (n_blocks > first_part) {
          size_t remaining = n_blocks - first_part;
          pwrite(fd, data + (first_part * B_SIZE), remaining * B_SIZE, 0);
      }
      
      update_header((current_head + n_blocks) % JOURNAL_SIZE);
  }
  
  
  **FSync Policy:** Header must only be updated after both payload segments are
  acknowledged by the storage controller.
| {
  near: top-right
}