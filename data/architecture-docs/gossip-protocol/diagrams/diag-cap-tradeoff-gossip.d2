direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # CAP Trade-off in Gossip Systems
  Where gossip protocols sit on the consistency-availability spectrum
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cap_triangle: {
    direction: down
    label: "CAP Theorem Triangle"
    style.fill: "#f0f4f8"
    style.stroke: "#64748b"
    style.stroke-width: 2
    consistency: {
      shape: circle
      label: "Consistency\n(C)"
      style.fill: "#fef3c7"
      style.stroke: "#f59e0b"
      style.stroke-width: 2
      width: 80
    }
    availability: {
      shape: circle
      label: "Availability\n(A)"
      style.fill: "#dcfce7"
      style.stroke: "#22c55e"
      style.stroke-width: 2
      width: 80
    }
    partition: {
      shape: circle
      label: "Partition\nTolerance (P)"
      style.fill: "#dbeafe"
      style.stroke: "#3b82f6"
      style.stroke-width: 2
      width: 80
    }
    consistency -- availability: {
      style.stroke-dash: 3
      style.stroke: "#94a3b8"
    }
    availability -- partition: {
      style.stroke-dash: 3
      style.stroke: "#94a3b8"
    }
    partition -- consistency: {
      style.stroke-dash: 3
      style.stroke: "#94a3b8"
    }
  }
  legend: {
    label: "CAP Combinations"
    style.fill: transparent
    style.stroke: transparent
    cp_box: {
      label: "CP Systems"
      style.fill: "#fef3c7"
      style.stroke: "#f59e0b"
      cp_desc: |md
        **Consistency + Partition Tolerance**
        - Reject writes during partition
        - Majority quorum required
        - Examples: Raft, Paxos, ZooKeeper
      |
    }
    ap_box: {
      label: "AP Systems"
      style.fill: "#dcfce7"
      style.stroke: "#22c55e"
      ap_desc: |md
        **Availability + Partition Tolerance**
        - Accept writes during partition
        - Eventual consistency
        - Examples: **Gossip**, Cassandra, DynamoDB
      |
    }
    ca_box: {
      label: "CA Systems"
      style.fill: "#dbeafe"
      style.stroke: "#3b82f6"
      style.opacity: 0.5
      ca_desc: |md
        **Consistency + Availability**
        - No partition tolerance
        - Only works in reliable networks
        - Rarely practical in distributed systems
      |
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  spectrum: {
    direction: down
    label: "Consistency-Availability Spectrum"
    spec_line: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      strong: {
        shape: circle
        label: "Strong\nConsistency"
        style.fill: "#fef3c7"
        style.stroke: "#f59e0b"
        width: 100
      }
      eventual: {
        shape: circle
        label: "Eventual\nConsistency"
        style.fill: "#dcfce7"
        style.stroke: "#22c55e"
        width: 100
      }
      weak: {
        shape: circle
        label: "Weak\nConsistency"
        style.fill: "#fee2e2"
        style.stroke: "#ef4444"
        width: 100
      }
      strong -> eventual: "Gossip with\nanti-entropy" {
        style.stroke: "#22c55e"
        style.stroke-width: 3
        style.animated: true
      }
      eventual -> weak: {
        style.stroke: "#94a3b8"
        style.stroke-dash: 3
      }
    }
    spec_desc: |md
      **Gossip sits in the middle:**
      - Not strongly consistent (no coordination)
      - Eventually consistent (convergence guarantee)
      - Better than weak (bounded convergence time)
    |
  }
  comparison: {
    direction: down
    label: "Gossip vs Consensus Protocols"
    comp_table: {
      shape: sql_table
      label: "Protocol Comparison"
      row1: "Property | Gossip | Raft/Paxos"
      row2: "Consistency | Eventual | Strong (Linearizable)"
      row3: "Availability | Always accept writes | Majority required"
      row4: "Partition Response | Both sides accept writes | Minority rejects writes"
      row5: "Coordination | None (decentralized) | Leader/Quorum required"
      row6: "Convergence | O(log N) rounds | 1 RTT (when available)"
      row7: "Fault Tolerance | Any number of failures | Minority failures only"
      row8: "Scalability | O(1) per-node bandwidth | O(N) leader bandwidth"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  gossip_arch: {
    direction: down
    label: "Gossip: AP Architecture"
    g_nodes: {
      direction: right
      style.fill: "#f0fdf4"
      style.stroke: "#22c55e"
      g1: {
        shape: circle
        label: "Node A"
        style.fill: "#dcfce7"
        width: 60
      }
      g2: {
        shape: circle
        label: "Node B"
        style.fill: "#dcfce7"
        width: 60
      }
      g3: {
        shape: circle
        label: "Node C"
        style.fill: "#dcfce7"
        width: 60
      }
      g1 <-> g2: "gossip" {
        style.stroke: "#22c55e"
        style.animated: true
      }
      g2 <-> g3: "gossip" {
        style.stroke: "#22c55e"
        style.animated: true
      }
      g3 <-> g1: "gossip" {
        style.stroke: "#22c55e"
        style.animated: true
      }
    }
    g_note: |md
      **During Partition:**
      - All nodes accept writes
      - Updates spread when partition heals
      - Anti-entropy reconciles conflicts
    |
  }
  raft_arch: {
    direction: down
    label: "Raft: CP Architecture"
    r_nodes: {
      direction: right
      style.fill: "#fffbeb"
      style.stroke: "#f59e0b"
      r1: {
        shape: circle
        label: "Leader"
        style.fill: "#fef3c7"
        width: 70
      }
      r2: {
        shape: circle
        label: "Follower"
        style.fill: "#fef3c7"
        width: 60
      }
      r3: {
        shape: circle
        label: "Follower"
        style.fill: "#fef3c7"
        width: 60
      }
      r1 -> r2: "replicate" {
        style.stroke: "#f59e0b"
      }
      r1 -> r3: "replicate" {
        style.stroke: "#f59e0b"
      }
    }
    r_note: |md
      **During Partition:**
      - Minority partition rejects writes
      - No writes without quorum
      - Strong consistency preserved
    |
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tradeoff_viz: {
    direction: down
    label: "Trade-off Visualization"
    tradeoff_graph: {
      direction: right
      axis_y: {
        label: "↑ Consistency"
        style.fill: transparent
        style.stroke: "#64748b"
        y_top: {
          shape: circle
          label: ""
          width: 10
          style.fill: transparent
          style.stroke: transparent
        }
        y_bottom: {
          shape: circle
          label: ""
          width: 10
          style.fill: transparent
          style.stroke: transparent
        }
        y_top -- y_bottom
      }
      plot: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        gossip_point: {
          shape: circle
          label: "Gossip"
          style.fill: "#22c55e"
          style.stroke: "#16a34a"
          width: 50
          tooltip: "Eventual consistency, always available"
        }
        raft_point: {
          shape: circle
          label: "Raft"
          style.fill: "#f59e0b"
          style.stroke: "#d97706"
          width: 50
          tooltip: "Strong consistency, requires quorum"
        }
        dynamo_point: {
          shape: circle
          label: "Dynamo"
          style.fill: "#8b5cf6"
          style.stroke: "#7c3aed"
          width: 50
          tooltip: "Tunable consistency (N, R, W)"
        }
      }
      axis_x: {
        label: "Availability →"
        style.fill: transparent
        style.stroke: "#64748b"
        x_left: {
          shape: circle
          label: ""
          width: 10
          style.fill: transparent
          style.stroke: transparent
        }
        x_right: {
          shape: circle
          label: ""
          width: 10
          style.fill: transparent
          style.stroke: transparent
        }
        x_left -- x_right
      }
    }
  }
  decision: {
    direction: down
    label: "When to Choose Gossip"
    decision_box: {
      style.fill: "#f0fdf4"
      style.stroke: "#22c55e"
      good: |md
        **✓ Choose Gossip When:**
        - High availability is critical
        - Network partitions are expected
        - Eventual consistency is acceptable
        - Large cluster (100+ nodes)
        - Decentralized control preferred
      |
    }
    bad_box: {
      style.fill: "#fef2f2"
      style.stroke: "#ef4444"
      bad: |md
        **✗ Avoid Gossip When:**
        - Strong consistency required
        - Linearizable reads needed
        - Financial transactions
        - Small cluster (3-5 nodes)
        - Coordination is acceptable
      |
    }
  }
}
footer: |md
  **Key Insight:** Gossip trades immediate consistency for availability and partition tolerance.
  Updates spread in O(log N) rounds, guaranteeing eventual convergence even under failures.
| {near: bottom-center}