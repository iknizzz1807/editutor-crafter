direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- SATELLITE SYSTEM MAP ---

title: {
  label: "Gossip Protocol System Map (Satellite View)"
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# ROW 1: CORE DISSEMINATION & MEMBERSHIP
orbit_row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  m1_membership: "M1: Membership Bootstrapping" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    
    peer_list: {
      shape: class
      label: "PeerList (membership/peerlist.go)"
      -mu: "sync.RWMutex"
      -peers: "map[string]*Peer"
      -selfID: "string"
      -deadTTL: "time.Duration"
      +AddPeer(peer): "bool"
      +GetRandomPeers(k): "[]*Peer"
      +UpdateLastSeen(id): "bool"
      +SetState(id, state, inc): "bool"
      +ReapDeadPeers(): "[]string"
    }

    state_machine: {
      label: "Node Life Cycle"
      code: |'text
        ALIVE -> SUSPECT
        SUSPECT -> DEAD
        DEAD -> REAPED
      '|
    }
  }

  m2_push: "M2: Push Dissemination" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"

    gossiper: {
      shape: class
      label: "Gossiper (gossiper.go)"
      -config: "GossipConfig"
      -store: "*state.Store"
      -peerList: "*membership.PeerList"
      -seenCache: "*SeenCache"
      +Start(): "void"
      +gossipRound(): "void"
      +handleGossip(msg, addr): "void"
    }
    
    logic: {
      label: "Dissemination Strategy"
      shape: hexagon
      note: "Epidemic model | SI/SIR"
    }
  }
}

# ROW 2: OPTIMIZATION & FAILURE DETECTION
orbit_row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  m3_antientropy: "M3: Anti-Entropy Pull" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"

    anti_entropy: {
      shape: class
      label: "AntiEntropy (antientropy.go)"
      -merkleTree: "*merkle.Tree"
      -syncInterval: "time.Duration"
      +Start(): "void"
      +digestSync(peer): "error"
      +merkleSync(peer): "error"
    }

    merkle_tree: {
      label: "Merkle Tree"
      shape: hexagon
      row1: "O(log S) state diff"
      row2: "Last-Write-Wins resolve"
    }
  }

  m4_swim: "M4: FAIL DETECTION (SWIM)" {
    direction: down
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"

    failure_detector: {
      shape: class
      label: "FailureDetector (swim/fd.go)"
      -incarnation: "uint64"
      -suspicions: "sync.Map"
      +Start(): "void"
      +sendDirectPing(target): "bool"
      +sendIndirectProbes(target): "bool"
      +markSuspect(nodeID, inc): "void"
      +refuteSuspicion(accusedInc): "void"
    }

    probe_logic: {
      label: "SWIM Probe Cycle"
      shape: diamond
      row1: "Direct Ping -> Timeout"
      row2: "K-Indirect Probes"
    }
  }
}

# ROW 3: SHARED INFRASTRUCTURE
orbit_row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  shared_state: "Global State Store" {
    direction: down
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"

    state_store: {
      shape: sql_table
      label: "Store (state/store.go)"
      f0: "0x00 | mu | sync.RWMutex"
      f1: "0x08 | entries | map[string]*Entry"
      f2: "0x18 | clock | uint64"
      sz: "Total: ~32 bytes (metadata)"
    }

    entry_struct: {
      shape: sql_table
      label: "State Entry"
      f0: "0x00 | Key | string"
      f1: "0x10 | Value | []byte"
      f2: "0x28 | Version | uint64"
      f3: "0x30 | NodeID | string"
      sz: "Total: 64 bytes"
    }
  }

  protocol: "Wire Protocol" {
    direction: down
    style.fill: "#ECEFF1"
    style.stroke: "#455A64"

    msg_header: {
      shape: sql_table
      label: "Packet Header"
      f0: "0x00 | Type | uint8"
      f1: "0x01 | Ver | uint8"
      f2: "0x02 | NodeID | [16]byte"
      f3: "0x12 | TTL | uint8"
      sz: "Total: 20 bytes"
    }

    msg_enum: {
      label: "Message Registry"
      shape: rectangle
      row1: "JOIN 0x01 | GOSSIP 0x10"
      row2: "PING 0x30 | SYNC 0x20"
    }
  }
}

# --- CROSS-COMPONENT COUPLING ---

m2_push.gossiper -> m1_membership.peer_list: "PeerList | Fanout"
m3_antientropy.anti_entropy -> m1_membership.peer_list: "Peer | Random"
m4_swim.failure_detector -> m1_membership.peer_list: "PeerState | Update"
m2_push.gossiper -> shared_state.state_store: "Delta | Disseminate"
m3_antientropy.anti_entropy -> shared_state.state_store: "Digest | Reconcile"
m4_swim.probe_logic -> m4_swim.failure_detector: "Status | Notify"

# --- LEGEND & NAV ---

legend: {
  near: bottom-right
  direction: down
  
  l1: "Push Gossip Flow" {
    style.fill: "#E3F2FD"
    shape: rectangle
  }
  l2: "Membership Sync" {
    style.fill: "#E8F5E9"
    shape: rectangle
  }
  l3: "Anti-Entropy Flow" {
    style.fill: "#FFF3E0"
    shape: rectangle
  }
  l4: "Failure Detection" {
    style.fill: "#FCE4EC"
    shape: rectangle
  }
}

nav_links: |'md
  **Protocol Documentation**
  - [M1: Membership](#m1)
  - [M2: Push Gossip](#m2)
  - [M3: Anti-Entropy](#m3)
  - [M4: Failure Detection](#m4)
'| {
  near: bottom-left
}