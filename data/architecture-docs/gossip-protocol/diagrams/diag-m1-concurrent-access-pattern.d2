direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Concurrent Access Pattern: Mutex vs RWMutex {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
row_comparison: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  col_mutex: "BEFORE: sync.Mutex" {
    direction: down
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    style.stroke-width: 2
    mutex_header: {
      shape: rectangle
      label: "sync.Mutex\n(Readers Block Readers)"
      style: {
        fill: "#FFCCCC"
        bold: true
        font-size: 16
      }
      width: 280
    }
    mutex_diagram: {
      direction: down
      mutex_lock: {
        label: "🔒 MUTEX HELD"
        shape: rectangle
        style: {
          fill: "#FF6B6B"
          font-color: white
          bold: true
        }
        width: 240
      }
      mutex_readers: {
        direction: right
        label: ""
        style.fill: transparent
        style.stroke: transparent
        reader1: {
          label: "Gossip\nSender"
          shape: rectangle
          style: {
            fill: "#FFB3B3"
            stroke: "#CC0000"
            stroke-dash: 4
          }
          width: 100
        }
        reader2: {
          label: "Gossip\nReceiver"
          shape: rectangle
          style: {
            fill: "#FFB3B3"
            stroke: "#CC0000"
            stroke-dash: 4
          }
          width: 100
        }
        reader3: {
          label: "Anti-\nEntropy"
          shape: rectangle
          style: {
            fill: "#FFB3B3"
            stroke: "#CC0000"
            stroke-dash: 4
          }
          width: 100
        }
      }
      mutex_queue: {
        label: "⏳ BLOCKED QUEUE\nAll readers serialize"
        shape: rectangle
        style: {
          fill: "#FFE0E0"
          stroke: "#CC0000"
        }
        width: 240
      }
      mutex_lock -> mutex_readers: "blocks"
      mutex_readers -> mutex_queue: "wait"
    }
    mutex_timeline: {
      label: |md
        **Timeline (serialized):**
        
        T0: Reader1 acquires lock
        T1: Reader1 releases → Reader2 waits
        T2: Reader2 acquires lock  
        T3: Reader2 releases → Reader3 waits
        T4: Reader3 acquires lock
        
        **Total: 4× lock acquisition overhead**
      |
      shape: rectangle
      style: {
        fill: "#FFF8F8"
        font: mono
        font-size: 11
      }
      width: 280
    }
  }
  col_rwmutex: "AFTER: sync.RWMutex" {
    direction: down
    style.fill: "#F0FFF0"
    style.stroke: "#006600"
    style.stroke-width: 2
    rwmutex_header: {
      shape: rectangle
      label: "sync.RWMutex\n(Readers Proceed in Parallel)"
      style: {
        fill: "#CCFFCC"
        bold: true
        font-size: 16
      }
      width: 280
    }
    rwmutex_diagram: {
      direction: down
      rwmutex_rlock: {
        label: "🔓 RLOCK (shared)"
        shape: rectangle
        style: {
          fill: "#4CAF50"
          font-color: white
          bold: true
        }
        width: 240
      }
      rwmutex_readers: {
        direction: right
        label: ""
        style.fill: transparent
        style.stroke: transparent
        rwreader1: {
          label: "Gossip\nSender"
          shape: rectangle
          style: {
            fill: "#A5D6A7"
            stroke: "#006600"
          }
          width: 100
        }
        rwreader2: {
          label: "Gossip\nReceiver"
          shape: rectangle
          style: {
            fill: "#A5D6A7"
            stroke: "#006600"
          }
          width: 100
        }
        rwreader3: {
          label: "Anti-\nEntropy"
          shape: rectangle
          style: {
            fill: "#A5D6A7"
            stroke: "#006600"
          }
          width: 100
        }
      }
      rwmutex_status: {
        label: "✅ ALL PROCEED\nConcurrent read access"
        shape: rectangle
        style: {
          fill: "#E8F5E9"
          stroke: "#006600"
        }
        width: 240
      }
      rwmutex_rlock -> rwmutex_readers: "allows"
      rwmutex_readers -> rwmutex_status: "parallel"
    }
    rwmutex_timeline: {
      label: |md
        **Timeline (parallel):**
        
        T0: Reader1,2,3 all RLock()
        T0: All read peer list simultaneously
        T1: All RUnlock()
        
        **Total: 1× lock acquisition overhead**
      |
      shape: rectangle
      style: {
        fill: "#F8FFF8"
        font: mono
        font-size: 11
      }
      width: 280
    }
  }
}
arrow_transition: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  improvement: {
    label: "→ 4× throughput for read-heavy workloads →"
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      bold: true
      font-size: 14
    }
    width: 200
  }
}
col_mutex.mutex_timeline -> improvement: ""
improvement -> col_rwmutex.rwmutex_timeline: ""
row_access_patterns: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  pattern_readers: "Reader Operations (RLock)" {
    direction: down
    style.fill: "#E8F5E9"
    read_header: {
      label: "**Readers — Use RLock()**"
      shape: text
      style.bold: true
    }
    read_ops: {
      shape: class
      label: "PeerList (membership/peerlist.go)"
      -GetRandomPeers: "[]*Peer"
      -GetPeer: "*Peer"
      -GetAllPeers: "[]*Peer"
      -AliveCount: "int"
      -Size: "int"
      -CreateDigest: "[]PeerDigest"
    }
    read_note: {
      label: |md
        Multiple goroutines can call these
        **simultaneously** without blocking
      |
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        font-size: 12
      }
      width: 260
    }
  }
  pattern_writers: "Writer Operations (Lock)" {
    direction: down
    style.fill: "#FFF3E0"
    write_header: {
      label: "**Writers — Use Lock()**"
      shape: text
      style.bold: true
    }
    write_ops: {
      shape: class
      label: "PeerList (membership/peerlist.go)"
      +AddPeer: "bool"
      +RemovePeer: "bool"
      +UpdateLastSeen: "bool"
      +SetState: "bool"
      +ReapDeadPeers: "[]string"
      +MergeDigest: "(int, int)"
    }
    write_note: {
      label: |md
        Writers get **exclusive** access.
        Readers blocked during write.
      |
      shape: rectangle
      style: {
        fill: "#FFE0B2"
        font-size: 12
      }
      width: 260
    }
  }
}
row_access_patterns_arrow: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  access_balance: {
    label: "Gossip workload: ~90% reads, ~10% writes"
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      bold: true
    }
    width: 300
  }
}
pattern_readers -> access_balance: "many"
access_balance -> pattern_writers: "few"
implementation: "Implementation in Go" {
  direction: down
  code_example: {
    label: "Thread-Safe Peer List Access"
    width: 700
    code: |'go
      type PeerList struct {
          mu      sync.RWMutex   // Read-write lock
          peers   map[string]*Peer
          selfID  string
      }
      // READ operation — multiple concurrent readers OK
      func (pl *PeerList) GetRandomPeers(k int) []*Peer {
          pl.mu.RLock()              // Shared lock
          defer pl.mu.RUnlock()
          // ... select k random peers ...
          return candidates[:k]
      }
      // WRITE operation — exclusive access required
      func (pl *PeerList) AddPeer(peer *Peer) bool {
          pl.mu.Lock()               // Exclusive lock
          defer pl.mu.Unlock()
          // ... modify peers map ...
          return true
      }
    '|
  }
  lock_rules: {
    direction: right
    label: ""
    style.fill: transparent
    style.stroke: transparent
    rule_rlock: {
      label: |md
        **RLock() Rules:**
        - Multiple goroutines can hold simultaneously
        - Blocks while any Lock() is held
        - Use for: Get*, Size, Create*, All read-only ops
      |
      shape: rectangle
      style.fill: "#E8F5E9"
      width: 300
    }
    rule_lock: {
      label: |md
        **Lock() Rules:**
        - Only ONE goroutine can hold
        - Blocks ALL RLock() and Lock() callers
        - Use for: Add*, Remove*, Set*, Update*, Merge*
      |
      shape: rectangle
      style.fill: "#FFF3E0"
      width: 300
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#F5F5F5"
  legend_title: {
    label: "Legend"
    shape: text
    style.bold: true
  }
  blocked: {
    label: "Dashed = Blocked"
    shape: rectangle
