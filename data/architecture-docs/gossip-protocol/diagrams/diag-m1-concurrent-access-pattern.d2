      fill: "#FFB3B3"
      stroke-dash: 4
    }
    width: 100
  }
  running: {
    label: "Solid = Running"
    shape: rectangle
    style: {
      fill: "#A5D6A7"
    }
    width: 100
  }
  contention: {
    label: "Contention Point"
    shape: rectangle
    style: {
      fill: "#FF6B6B"
      font-color: white
    }
    width: 100
  }
  parallel_access: {
    label: "Parallel Access"
    shape: rectangle
    style: {
      fill: "#4CAF50"
      font-color: white
    }
    width: 100
  }
}