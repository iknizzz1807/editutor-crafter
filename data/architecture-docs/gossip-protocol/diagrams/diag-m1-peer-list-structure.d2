direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Thread-Safe Peer List Structure" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  writers: {
    direction: down
    label: "Writer Goroutines"
    style.fill: "#FFE4E1"
    gossip_receiver: {
      label: "Gossip Receiver"
      width: 180
      code: |'go
        // Updates lastSeen
        // Processes JOIN/LEAVE
        pl.UpdateLastSeen(id)
        pl.AddPeer(peer)
      '|
    }
    failure_detector: {
      label: "Failure Detector"
      width: 180
      code: |'go
        // Marks SUSPECT/DEAD
        pl.SetState(id, state, inc)
      '|
    }
    leave_handler: {
      label: "Leave Handler"
      width: 180
      code: |'go
        // Marks LEFT on shutdown
        pl.HandleLeave(msg)
      '|
    }
  }
  peer_list: {
    direction: down
    label: "PeerList (membership/peerlist.go)"
    peer_list_struct: {
      shape: sql_table
      label: "struct PeerList"
      f0: "0x00 | *sync.RWMutex  | mu"
      f1: "0x08 | map[string]*Peer | peers"
      f2: "0x10 | string          | selfID"
      f3: "0x18 | time.Duration   | deadTTL"
      sz: "Total: 32 bytes + map"
    }
    mutex_detail: {
      label: "RWMutex Behavior"
      shape: rectangle
      width: 320
      code: |'text
        ┌─────────────────────────────────────┐
        │  RLock() - Multiple readers OK      │
        │  Lock()  - Exclusive writer only    │
        │  Writer-fair: writers not starved   │
        └─────────────────────────────────────┘
      '|
    }
  }
  readers: {
    direction: down
    label: "Reader Goroutines"
    style.fill: "#E0FFE0"
    gossip_sender: {
      label: "Gossip Sender"
      width: 180
      code: |'go
        // Selects random peers
        peers := pl.GetRandomPeers(k)
      '|
    }
    anti_entropy: {
      label: "Anti-Entropy"
      width: 180
      code: |'go
        // Compares peer lists
        digest := pl.CreateDigest()
      '|
    }
    health_check: {
      label: "Health Check"
      width: 180
      code: |'go
        // Reads peer states
        peer := pl.GetPeer(id)
      '|
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  peer_entry: {
    direction: down
    label: "Peer Entry Structure"
    peer_struct: {
      shape: sql_table
      label: "struct Peer"
      f0: "0x00 | string     | ID"
      f1: "0x10 | string     | Address"
      f2: "0x20 | int        | Port"
      f3: "0x28 | PeerState  | State"
      f4: "0x30 | uint64     | Incarnation"
      f5: "0x38 | time.Time  | LastSeen"
      f6: "0x40 | time.Time  | StateChanged"
      sz: "Total: 72 bytes"
    }
    peer_state_enum: {
      shape: sql_table
      label: "type PeerState int"
      s0: "0 | ALIVE   | Node responding"
      s1: "1 | SUSPECT | May be failing"
      s2: "2 | DEAD    | Confirmed failed"
      s3: "3 | LEFT    | Graceful shutdown"
    }
  }
  lock_matrix: {
    direction: down
    label: "Lock Usage Matrix"
    lock_table: {
      shape: sql_table
      label: "Method → Lock Type"
      r0: "GetPeer()        | RLock | Read-only lookup"
      r1: "GetRandomPeers() | RLock | Read-only selection"
      r2: "GetAllPeers()    | RLock | Snapshot for sync"
      r3: "AddPeer()        | Lock  | Write to map"
      r4: "UpdateLastSeen() | Lock  | Write timestamp"
      r5: "SetState()       | Lock  | Write state field"
      r6: "ReapDeadPeers()  | Lock  | Delete from map"
    }
  }
  concurrency_note: {
    label: "Concurrency Guarantee"
    shape: rectangle
    width: 340
    style.fill: "#FFF8DC"
    code: |'text
      ┌────────────────────────────────────────┐
      │  Invariant: All Peer fields consistent │
      │  - State + Incarnation always paired   │
      │  - LastSeen monotonically increasing   │
      │  - Map entries atomically added/removed│
      └────────────────────────────────────────┘
    '|
  }
}
writers -> peer_list: "Lock()" {
  label: "exclusive"
  style: {
    stroke: "#CC0000"
    stroke-width: 3
  }
}
readers -> peer_list: "RLock()" {
  label: "shared"
  style: {
    stroke: "#006600"
    stroke-width: 2
    stroke-dash: 4
  }
}
peer_list_struct -> peer_struct: "peers[id]" {
  label: "*Peer"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  write_lock: {
    label: "═══ Lock()  "
    shape: text
    style: {
      font-color: "#CC0000"
      bold: true
    }
  }
  read_lock: {
    label: "- - - RLock()  "
    shape: text
    style: {
      font-color: "#006600"
    }
  }
  note: {
    label: "(Multiple RLock OK simultaneously)"
    shape: text
    style.font-color: "#666666"
  }
}