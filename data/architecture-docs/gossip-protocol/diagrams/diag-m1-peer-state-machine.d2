direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
header: {
  label: "Peer Membership State Machine (membership/peer_list.go)"
  style: {
    font-size: 24
    bold: true
    stroke: transparent
    fill: transparent
  }
}

# --- TOP LEVEL COMPONENTS ---
row_join: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  new_node: "New Node | Joins Cluster" {
    shape: oval
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-dash: 3
    }
  }
  join_spacer: {
    style: {
      fill: transparent
      stroke: transparent
    }
    label: " "
  }
}

row_states: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  state_alive: ALIVE {
    shape: circle
    style: {
      fill: "#ACE1AF"
      stroke: "#2E8B57"
      stroke-width: 3
      font-color: "#1a1a1a"
    }
  }
  state_suspect: SUSPECT {
    shape: circle
    style: {
      fill: "#FFF3CD"
      stroke: "#D4A900"
      stroke-width: 3
      font-color: "#1a1a1a"
    }
  }
  state_dead: DEAD {
    shape: circle
    style: {
      fill: "#F8D7DA"
      stroke: "#C62828"
      stroke-width: 3
      font-color: "#1a1a1a"
    }
  }
  state_left: LEFT {
    shape: circle
    style: {
      fill: "#E2E3E5"
      stroke: "#6C757D"
      stroke-width: 3
      font-color: "#1a1a1a"
    }
  }
}

row_reaper: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  reaper: "Dead Peer Reaper | GC Routine" {
    shape: rectangle
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      stroke-dash: 2
    }
  }
  removed: "Removed | Purged" {
    shape: oval
    style: {
      fill: "#FAFAFA"
      stroke: "#BDBDBD"
      stroke-dash: 3
    }
  }
}

# --- CONNECTIONS ---
row_join.new_node -> row_states.state_alive: "JOIN | bootstrap" {
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}

row_states.state_alive -> row_states.state_suspect: "SWIM | timeout" {
  style: {
    stroke: "#D4A900"
    stroke-width: 2
    stroke-dash: 4
  }
}

row_states.state_suspect -> row_states.state_alive: "AliveMsg | refute" {
  style: {
    stroke: "#2E8B57"
    stroke-width: 2
  }
}

row_states.state_suspect -> row_states.state_dead: "Timer | expired" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    stroke-dash: 4
  }
}

row_states.state_alive -> row_states.state_left: "LeaveMsg | graceful" {
  style: {
    stroke: "#6C757D"
    stroke-width: 2
  }
}

row_states.state_dead -> row_reaper.removed: "DeadTTL | reap" {
  style: {
    stroke: "#9E9E9E"
    stroke-width: 2
    stroke-dash: 3
  }
}

row_states.state_left -> row_reaper.removed: "DeadTTL | reap" {
  style: {
    stroke: "#9E9E9E"
    stroke-width: 2
    stroke-dash: 3
  }
}

row_reaper.reaper -> row_reaper.removed: "GC | sweep" {
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
}

row_states.state_suspect -> row_states.state_suspect: "SWIM | re-suspect" {
  style: {
    stroke: "#D4A900"
    stroke-dash: 2
  }
}

# --- METADATA & LEGENDS ---
legend: {
  label: "State Transition Legend"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#E0E0E0"
    border-radius: 8
  }
  grid-columns: 2
  grid-gap: 16
  l1: "SWIM Protocol | M4 Failure Detector"
  l2: "Join Handler | M1 Initialization"
  l3: "Leave Handler | M1 Termination"
  l4: "Reaper | TTL Cleanup"
}
legend.near: bottom-center

initiators: {
  label: "Logic Units"
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FFB300"
    border-radius: 8
  }
  m1: "Module 1: RPC Handlers"
  m4: "Module 4: SWIM Engine"
  gr: "Goroutine: Reaper"
}
initiators.near: top-right