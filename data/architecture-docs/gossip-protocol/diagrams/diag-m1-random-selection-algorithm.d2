direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Random Peer Selection Algorithm
  GetRandomPeers(k int) → []*Peer
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  step1: {
    label: "Step 1: Acquire Read Lock"
    width: 340
    code: |'go
      func (pl *PeerList) GetRandomPeers(k int) []*Peer {
        pl.mu.RLock()
        defer pl.mu.RUnlock()
    '|
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  filter: {
    label: "Step 2: Filter Alive Peers"
    width: 400
    code: |'go
      candidates := make([]*Peer, 0, len(pl.peers))
      for _, peer := range pl.peers {
        // CRITICAL: Exclude self to prevent self-gossip
        if peer.ID != pl.selfID && peer.State == PeerStateAlive {
          candidates = append(candidates, peer)
        }
      }
    '|
  }
  filter_state: {
    shape: sql_table
    label: "PeerState Filter (membership.go)"
    f0: "0x00 | PeerStateAlive   | ✓ Include"
    f1: "0x04 | PeerStateSuspect | ✗ Exclude"
    f2: "0x08 | PeerStateDead    | ✗ Exclude"
    f3: "0x0C | PeerStateLeft    | ✗ Exclude"
    note: "Only ALIVE peers participate in gossip"
  }
}
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  edge_check: {
    shape: diamond
    label: "len(candidates)\n== 0?"
    width: 120
    height: 120
  }
  return_nil: {
    label: "Return nil\n(No peers available)"
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
  }
}
row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  edge_check2: {
    shape: diamond
    label: "k >= len(candidates)?"
    width: 130
    height: 130
  }
  return_all: {
    label: "Step 3a: Return All Candidates"
    width: 380
    code: |'go
      // Return all candidates (already random order from map)
      result := make([]*Peer, len(candidates))
      copy(result, candidates)
      // Still shuffle for uniformity
      rand.Shuffle(len(result), func(i, j int) {
        result[i], result[j] = result[j], result[i]
      })
      return result
    '|
  }
}
row5: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  shuffle: {
    label: "Step 3b: Fisher-Yates Partial Shuffle"
    width: 450
    code: |'go
      // Fisher-Yates shuffle: O(k) for first k elements
      rand.Shuffle(len(candidates), func(i, j int) {
        candidates[i], candidates[j] = candidates[j], candidates[i]
      })
      result := make([]*Peer, k)
      copy(result, candidates[:k])
      return result
    '|
  }
  shuffle_note: {
    label: |md
      **Fisher-Yates Properties:**
      - Unbiased permutation
      - O(n) full shuffle, O(k) partial
      - In-place operation
      - Each element equally likely at each position
    |
    style.fill: "#F0F8FF"
    style.stroke: "#4682B4"
    width: 220
  }
}
row6: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  result: {
    label: "Step 4: Return k Random Peers"
    width: 380
    code: |'go
      // Result: k random alive peers, excluding self
      // Guaranteed: len(result) <= k
      // Guaranteed: no self-gossip (selfID excluded)
      // Guaranteed: uniform random distribution
      return result
    '|
  }
  guarantees: {
    shape: class
    label: "Guarantees (membership.go)"
    no_self: "bool | selfID never in result"
    alive_only: "bool | only PeerStateAlive peers"
    uniform: "bool | each subset equally likely"
    bounded: "bool | len(result) <= min(k, alive_count)"
  }
}
row7: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  edge_cases: {
    label: "Edge Cases & Handling"
    width: 500
    code: |'go
      // Edge Case 1: k > cluster size
      //   → Returns all alive peers (len < k)
      //   → Caller must handle short result
      // Edge Case 2: No alive peers
      //   → Returns nil
      //   → Gossip round skipped
      // Edge Case 3: Only self in peer list
      //   → Returns nil (self excluded)
      //   → Gossip round skipped
      // Edge Case 4: k <= 0
      //   → Returns nil (handled by len check)
    '|
  }
}
row8: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  complexity: {
    shape: class
    label: "Complexity Analysis"
    time_filter: "O(N) | Filter alive peers"
    time_shuffle: "O(k) | Partial Fisher-Yates"
    time_total: "O(N) | Dominated by filter"
    space: "O(N) | Candidates array"
  }
  concurrency: {
    shape: class
    label: "Concurrency (membership.go)"
    lock_type: "sync.RWMutex | Read lock"
    blocking: "No | Multiple readers OK"
    safe: "Yes | Snapshot semantics"
  }
}
row9: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  self_gossip_bug: {
    label: "⚠️ The Self-Gossip Bug"
    width: 480
    style.fill: "#FFF0F5"
    style.stroke: "#DC143C"
    code: |'go
      // BUG: Forgetting to exclude self causes:
      // 1. Wasted bandwidth (loopback messages)
      // 2. Distorted convergence measurements
      // 3. Confused failure detection
      // 4. Invalid protocol behavior in tests
      // FIX: Always check peer.ID != pl.selfID
      if peer.ID != pl.selfID && peer.State == PeerStateAlive {
        candidates = append(candidates, peer)
      }
    '|
  }
}
step1 -> filter: "lock acquired"
filter -> filter_state: "state check"
filter -> edge_check: "candidates collected"
edge_check -> return_nil: "yes"
edge_check -> edge_check2: "no"
edge_check2 -> return_all: "yes (return all)"
edge_check2 -> shuffle: "no (need subset)"
shuffle -> result: "first k selected"
return_all -> result: "all returned"
result -> edge_cases: "validate"
result -> guarantees: "invariants"
shuffle -> shuffle_note: "algorithm"
edge_cases -> complexity: "performance"
result -> concurrency: "thread safety"
filter -> self_gossip_bug: "critical check"