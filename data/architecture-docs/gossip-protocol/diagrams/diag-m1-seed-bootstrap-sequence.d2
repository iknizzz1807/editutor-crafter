vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |md
  # Seed Node Bootstrap Sequence
  New node joins cluster via seed node rendezvous
|

sequence: {
  shape: sequence_diagram

  NewNode: "New Node (Joining)" {
    style.stroke: "#3b82f6"
    style.fill: "#dbeafe"
  }
  Seed1: "Seed Node 1 (Primary)" {
    style.stroke: "#22c55e"
    style.fill: "#dcfce7"
  }
  Seed2: "Seed Node 2 (Backup)" {
    style.stroke: "#22c55e"
    style.fill: "#dcfce7"
  }
  Cluster: "Existing Cluster (Nodes A, B, C)" {
    style.stroke: "#6366f1"
    style.fill: "#e0e7ff"
  }

  phase1: "Phase 1: Bootstrap" {
    NewNode.t1 -> Seed1.t1: "JOIN(nodeID, addr, inc=1)"
    Seed1.t1 -> Seed1.t1: "Add peer to list"
    Seed1.t1 -> NewNode.t1: "ACK + PeerList[A, B, C]"
  }

  phase2: "Phase 2: Retry (if needed)" {
    NewNode.t2 -> Seed1.t2: "JOIN (retry 1)"
    NewNode.t2."Timeout 100ms"
    NewNode.t3 -> Seed1.t3: "JOIN (retry 2)"
    NewNode.t3."Timeout 200ms"
    NewNode.t4 -> Seed2.t4: "JOIN (fallback seed)"
    Seed2.t4 -> NewNode.t4: "ACK + PeerList[A, B, C]"
  }

  phase3: "Phase 3: Announce" {
    NewNode.t5 -> NewNode.t5: "Initialize local peer list"
    NewNode.t5 -> Cluster.a: "GOSSIP(Alive, inc=1, fanout=3)"
    Cluster.a -> Cluster.a: "Add NewNode to peer lists"
  }

  phase4: "Phase 4: Convergence" {
    Cluster.b -> Cluster.c: "Forward NewNode membership"
    Cluster.c -> Cluster.d: "Forward NewNode membership"
    Cluster.d: "All nodes know NewNode within O(log N) rounds"
  }

  NewNode."Converged"
}

backoff: {
  label: "Exponential Backoff Strategy"
  width: 400
  code: |'go
    retryJoin(seed, data):
      for i in 0..maxRetries:
        if sendAndAwait(seed, data, baseDelay * 2^i):
          return success
      return fail
    for seed in config.Seeds:
      if retryJoin(seed, joinMsg): return joined
  '|
}

legend: {
  style.fill: transparent
  style.stroke: "#e5e7eb"

  timeline: "Protocol Period Timeline" {
    p1: "T+0s"
    p2: "T+1s"
    p3: "T+2s"
    p4: "T+3s"
    p1 -> p2: "1 round"
    p2 -> p3: "1 round"
    p3 -> p4: "1 round"
  }

  note: |md
    **Retry Backoff**: 100ms, 200ms, 400ms, 800ms, 1600ms
    **Max Retries**: 5 per seed, then try next seed
    **Convergence**: log₃(N) rounds ≈ 2-3 rounds for 10 nodes
  |
}

legend.near: bottom-right

sequence -> backoff: "Retry logic"
backoff -> legend: "Timing"