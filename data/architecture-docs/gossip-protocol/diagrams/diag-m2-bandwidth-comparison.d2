direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Bandwidth Comparison: Full State vs Delta Gossip
  Per-round bytes sent demonstrates O(N × state_size) vs O(fanout × delta_size)
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  before: {
    label: "Before: Full State Broadcast"
    style.fill: "#2d1b1b"
    style.stroke: "#8b3a3a"
    sender_b: {
      label: "Sender Node"
      style.fill: "#4a2020"
      style.stroke: "#c75050"
      style.font-color: "#ffaaaa"
      state_b: {
        shape: sql_table
        label: "Full State (1 MB)"
        f0: "0x0000 | 1 MB | all entries"
        sz: "1,048,576 bytes"
      }
    }
    cluster_b: {
      label: "Cluster (N=100 nodes)"
      style.fill: "#3d2020"
      style.stroke: "#a04040"
      n1_b: {label: "Node 1"; shape: circle; style.fill: "#5a2828"; style.stroke: "#d06060"}
      n2_b: {label: "Node 2"; shape: circle; style.fill: "#5a2828"; style.stroke: "#d06060"}
      n3_b: {label: "Node 3"; shape: circle; style.fill: "#5a2828"; style.stroke: "#d06060"}
      dots_b: {label: "..."; shape: text; style.font-color: "#ff8888"}
      n99_b: {label: "Node 99"; shape: circle; style.fill: "#5a2828"; style.stroke: "#d06060"}
    }
    sender_b -> cluster_b.n1_b: "1 MB" {style.stroke: "#ff5555"; style.stroke-width: 3}
    sender_b -> cluster_b.n2_b: "1 MB" {style.stroke: "#ff5555"; style.stroke-width: 3}
    sender_b -> cluster_b.n3_b: "1 MB" {style.stroke: "#ff5555"; style.stroke-width: 3}
    sender_b -> cluster_b.n99_b: "1 MB" {style.stroke: "#ff5555"; style.stroke-width: 3}
  }
  after: {
    label: "After: Delta Gossip (fanout=3)"
    style.fill: "#1b2d1b"
    style.stroke: "#3a8b3a"
    sender_a: {
      label: "Sender Node"
      style.fill: "#204a20"
      style.stroke: "#50c750"
      style.font-color: "#aaffaa"
      delta_a: {
        shape: sql_table
        label: "Delta Only (1 KB)"
        f0: "0x0000 | 1 KB | changed entries"
        sz: "1,024 bytes"
      }
    }
    cluster_a: {
      label: "Cluster (N=100 nodes)"
      style.fill: "#203d20"
      style.stroke: "#40a040"
      n1_a: {label: "Node 1"; shape: circle; style.fill: "#285a28"; style.stroke: "#60d060"}
      n2_a: {label: "Node 2"; shape: circle; style.fill: "#285a28"; style.stroke: "#60d060"}
      n3_a: {label: "Node 3"; shape: circle; style.fill: "#285a28"; style.stroke: "#60d060"}
      dots_a: {label: "..."; shape: text; style.font-color: "#88ff88"}
    }
    sender_a -> cluster_a.n1_a: "1 KB" {style.stroke: "#55ff55"; style.stroke-width: 2}
    sender_a -> cluster_a.n2_a: "1 KB" {style.stroke: "#55ff55"; style.stroke-width: 2}
    sender_a -> cluster_a.n3_a: "1 KB" {style.stroke: "#55ff55"; style.stroke-width: 2}
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  comparison: {
    label: "Scaling Comparison"
    style.fill: "#1a1a2e"
    style.stroke: "#4a4a6a"
    bandwidth_table: {
      shape: sql_table
      label: "Bytes Sent Per Round"
      h1: "Approach | Formula | N=100 | N=1000"
      r1: "Full State | N × state_size | 100 MB | 1 GB"
      r2: "Delta Gossip | fanout × delta_size | 3 KB | 3 KB"
      ratio: "Ratio | — | 33,333× | 333,333×"
    }
  }
  formula_box: {
    label: "Bandwidth Complexity"
    width: 350
    full: {
      label: |md
        **Full State Broadcast:**
        
        bandwidth = N × state_size
        
        - Grows linearly with cluster size
        - Sender becomes bottleneck
        - Does not scale beyond ~50 nodes
      |
      style.fill: "#3d2020"
      style.stroke: "#a04040"
    }
    delta: {
      label: |md
        **Delta Gossip:**
        
        bandwidth = fanout × delta_size
        
        - Constant per node regardless of N
        - Scales to 10,000+ nodes
        - fanout=3 provides O(log N) convergence
      |
      style.fill: "#203d20"
      style.stroke: "#40a040"
    }
  }
}
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  note: {
    label: |md
      ### Key Insight: Delta Tracking
      The `lastSent` watermark tracks the highest version transmitted. Only entries with `version > lastSent` are included in gossip messages.
      go
      entries := store.GetDelta(lastSent)
      // Only changed entries, not full state
      
    |
    style.fill: "#2a2a3e"
    style.stroke: "#5a5a7a"
    width: 700
  }
}
legend: {
  near: bottom-right
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  red: "Full State: O(N × S)" {shape: text; style.font-color: "#ff5555"}
  green: "Delta Gossip: O(k × δ)" {shape: text; style.font-color: "#55ff55"}
}