direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Gossip Convergence Probability by Round {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

subtitle: "Probability of Full Dissemination vs Round Number (N=100 nodes)" {
  shape: text
  near: top-center
  style: {
    font-size: 18
    italic: true
    font-color: "#666666"
  }
}

# MAIN ANALYSIS ROW
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  graph_container: {
    label: "Convergence Probability Analysis"
    width: 900
    
    y_axis_label: {
      label: "Probability of\nFull Dissemination\n(0% → 100%)"
      width: 60
      style: {
        font-size: 12
        font-color: "#333333"
      }
    }
    
    graph_area: {
      label: ""
      width: 700
      height: 400
      style: {
        fill: "#FAFAFA"
        stroke: "#CCCCCC"
        stroke-width: 1
      }
      grid_25: {
        label: "25%"
        width: 700
        height: 1
        style: {
          fill: "#E0E0E0"
          stroke: "#E0E0E0"
        }
      }
      grid_50: {
        label: "50%"
        width: 700
        height: 1
        style: {
          fill: "#E0E0E0"
          stroke: "#E0E0E0"
        }
      }
      grid_75: {
        label: "75%"
        width: 700
        height: 1
        style: {
          fill: "#E0E0E0"
          stroke: "#E0E0E0"
        }
      }
      p99_line: {
        label: "99.9% threshold"
        width: 700
        height: 2
        style: {
          fill: "#90EE90"
          stroke: "#32CD32"
          stroke-dash: 5
        }
      }
    }
    
    x_axis_label: {
      label: "Round Number →"
      width: 700
      style: {
        font-size: 14
        font-color: "#333333"
      }
    }
  }
}

# CURVES AND DETAIL ROW
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  curves: {
    label: "Fanout Characteristics"
    f1_curve: {
      label: "fanout = 1"
      shape: text
      style.font-color: "#E74C3C"
      desc: {
        label: |md
          **k=1** (single peer/round)
          - Convergence: ~460 rounds
          - Unreliable: single path
          - Not recommended
        |
        shape: rectangle
        width: 180
        style: {
          fill: "#FDF2F2"
          stroke: "#E74C3C"
          stroke-width: 1
          font-size: 11
        }
      }
    }
    f2_curve: {
      label: "fanout = 2"
      shape: text
      style.font-color: "#F39C12"
      desc: {
        label: |md
          **k=2** (two peers/round)
          - Convergence: ~23 rounds
          - Acceptable for small clusters
          - Moderate redundancy
        |
        shape: rectangle
        width: 180
        style: {
          fill: "#FEF9E7"
          stroke: "#F39C12"
          stroke-width: 1
          font-size: 11
        }
      }
    }
    f3_curve: {
      label: "fanout = 3"
      shape: text
      style: {
        font-color: "#27AE60"
        bold: true
      }
      desc: {
        label: |md
          **k=3** (three peers/round) ⭐
          - Convergence: ~12 rounds
          - **Industry standard**
          - Optimal trade-off
          - log₃(100) ≈ 4.2 rounds
        |
        shape: rectangle
        width: 180
        style: {
          fill: "#E8F8F5"
          stroke: "#27AE60"
          stroke-width: 2
          font-size: 11
          bold: true
        }
      }
    }
    f5_curve: {
      label: "fanout = 5"
      shape: text
      style.font-color: "#3498DB"
      desc: {
        label: |md
          **k=5** (five peers/round)
          - Convergence: ~7 rounds
          - Faster but 67% more msgs
          - Diminishing returns
        |
        shape: rectangle
        width: 180
        style: {
          fill: "#EBF5FB"
          stroke: "#3498DB"
          stroke-width: 1
          font-size: 11
        }
      }
    }
  }
}

# MATH AND LOGIC ROW
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  formula_box: {
    label: "Convergence Probability Formula"
    shape: rectangle
    width: 450
    style: {
      fill: "#FFF9E6"
      stroke: "#F1C40F"
      stroke-width: 2
      border-radius: 8
    }
    formula: {
      label: |'latex
        P(\text{converged after } t \text{ rounds}) = 1 - \left(1 - \frac{k}{N}\right)^{t \times k} \approx 1 - e^{-\frac{kt}{N}}
      '|
      shape: text
    }
    explanation: {
      label: |md
        Where:
        - **k** = fanout (peers contacted per round)
        - **N** = cluster size
        - **t** = number of rounds
        For 99.9% convergence: solve for t when P = 0.999
      |
      shape: text
      style.font-size: 12
    }
  }

  why_k3: {
    label: "Why fanout=3 is the Industry Standard"
    shape: rectangle
    width: 450
    style: {
      fill: "#E8F8F5"
      stroke: "#27AE60"
      stroke-width: 2
      border-radius: 8
    }
    reasons: {
      label: |md
        ### 1. Bandwidth Efficiency
        - Total cluster bandwidth: O(N × k)
        ### 2. Robustness to Failures
        - information has 3 independent paths
        - Prob(fail): (packet_loss)³
        ### 3. Logarithmic Scaling
        - log₃(N) grows extremely slowly
        ### 4. Diminishing Returns
        - k=3 is the efficiency "sweet spot"
      |
      shape: text
      style.font-size: 13
    }
  }
}

# SCALING DATA ROW
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scaling_comparison: {
    label: "Scaling Comparison: O(log N) vs O(N)"
    shape: rectangle
    width: 450
    style: {
      fill: "#F4F6F7"
      stroke: "#566573"
      stroke-width: 1
      border-radius: 8
    }
    comparison: {
      label: |'md
        | Cluster Size | Gossip (k=3) | Broadcast | Speedup |
        |--------------|--------------|-----------|---------|
        | 10 nodes | ~6 rounds | 1 round | 0.17× |
        | 100 nodes | ~12 rounds | 1 round | 0.08× |
        | 1,000 nodes | ~19 rounds | 1 round | 0.05× |
        | 10,000 nodes | ~25 rounds | 1 round | 0.04× |
        
        **Trade-off**: Gossip is decentralized and robust.
      '|
      shape: text
      style.font-size: 12
    }
  }

  convergence_table: {
    label: "Convergence Bounds (N=100, 99.9% delivery)"
    shape: sql_table
    style.font-size: 12
    row1: "k | Expected Rounds | Msgs/Node | Total Cluster Msgs"
    row2: "1 | ~460 | 1 | ~46,000"
    row3: "2 | ~23 | 2 | ~4,600"
    row4: "3 | ~12 | 3 | ~3,600"
    row5: "5 | ~7 | 5 | ~3,500"
    row6: "10 | ~4 | 10 | ~4,000"
    total: "Total: Bound = ceil(log_k(N)) × safety_factor"
  }
}

# LEGEND AND NOTES
legend: {
  label: "Legend"
  near: bottom-right
  shape: rectangle
  width: 200
  style: {
    fill: "#FFFFFF"
    stroke: "#CCCCCC"
    border-radius: 4
  }
  item1: "— k=1 (not recommended)" { shape: text; style.font-color: "#E74C3C"; style.font-size: 11 }
  item2: "— k=2 (acceptable)" { shape: text; style.font-color: "#F39C12"; style.font-size: 11 }
  item3: "— k=3 (recommended) ⭐" { shape: text; style.font-color: "#27AE60"; style.font-size: 11; style.bold: true }
  threshold: "--- 99.9% threshold" { shape: text; style.font-color: "#32CD32"; style.font-size: 11 }
}

notes: {
  label: "Implementation Notes"
  near: bottom-center
  shape: rectangle
  width: 700
  style: {
    fill: "#FEF5E7"
    stroke: "#E67E22"
    stroke-width: 1
    border-radius: 4
  }
  content: {
    label: |md
      **Practical Considerations:**
      - Add 2-3× safety margin to theoretical bounds for variance
      - Monitor actual convergence in production; tune k if needed
      - Adaptive fanout: increase k during high churn or network congestion
    |
    shape: text
    style.font-size: 12
  }
}

# CONNECTIONS
row2.curves.f1_curve.desc -> row4.convergence_table.row2: "k=1"
row2.curves.f3_curve.desc -> row4.convergence_table.row4: "k=3 (optimal)"
row2.curves.f5_curve.desc -> row4.convergence_table.row5: "k=5"