direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # TTL-Bounded Propagation
  Message with TTL=3 in 8-node cluster
'| {
  near: top-center
  shape: callout
}

# Legend explaining visual semantics
legend: {
  near: bottom-right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  ttl_def: |'md
    **TTL (Time-To-Live)** decrements at each hop.
    When TTL=0, message stops propagating.
  '|
  origin_node: Origin Node {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
  }
  forward_node: Forwarded (TTL > 0) {
    style.fill: "#cce5ff"
    style.stroke: "#007bff"
  }
  expire_node: TTL Expired (TTL = 0) {
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
  }
  unreachable_node: Never Reached {
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
  }
}

# Network topology with TTL propagation levels
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  origin: Node A (Origin) {
    shape: sql_table
    label: "Node A (Origin)"
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.stroke-width: 3
    t0: "0x00 | TTL_OUT | 3"
    t1: "0x04 | HOPS    | 0"
    state: "Action: Multicast to B, C, D"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  node_b: Node B {
    shape: sql_table
    style.fill: "#cce5ff"
    style.stroke: "#007bff"
    t0: "0x00 | TTL_IN  | 3"
    t1: "0x04 | TTL_OUT | 2"
    status: "Forwarding enabled"
  }
  node_c: Node C {
    shape: sql_table
    style.fill: "#cce5ff"
    style.stroke: "#007bff"
    t0: "0x00 | TTL_IN  | 3"
    t1: "0x04 | TTL_OUT | 2"
    status: "Forwarding enabled"
  }
  node_d: Node D {
    shape: sql_table
    style.fill: "#cce5ff"
    style.stroke: "#007bff"
    t0: "0x00 | TTL_IN  | 3"
    t1: "0x04 | TTL_OUT | 2"
    status: "Forwarding enabled"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  node_e: Node E {
    shape: sql_table
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    t0: "0x00 | TTL_IN  | 2"
    t1: "0x04 | TTL_OUT | 1"
    status: "Limit Reached"
  }
  node_f: Node F {
    shape: sql_table
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    t0: "0x00 | TTL_IN  | 2"
    t1: "0x04 | TTL_OUT | 1"
    status: "Limit Reached"
  }
  node_g: Node G {
    shape: sql_table
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    t0: "0x00 | TTL_IN  | 2"
    t1: "0x04 | TTL_OUT | 1"
    status: "Limit Reached"
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  node_h: Node H {
    shape: sql_table
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    t0: "0x00 | TTL_IN  | 1"
    t1: "0x04 | TTL_OUT | 0"
    status: "DEAD ON ARRIVAL"
  }
}

# Hop 1: Origin sends (TTL=3)
row1.origin -> row2.node_b: "TTL=3 | send" {
  style.stroke: "#28a745"
  style.stroke-width: 2
  style.animated: true
}
row1.origin -> row2.node_c: "TTL=3 | send" {
  style.stroke: "#28a745"
  style.stroke-width: 2
  style.animated: true
}
row1.origin -> row2.node_d: "TTL=3 | send" {
  style.stroke: "#28a745"
  style.stroke-width: 2
  style.animated: true
}

# Hop 2: First-level forwards (TTL=2)
row2.node_b -> row3.node_e: "TTL=2 | forward" {
  style.stroke: "#007bff"
  style.stroke-width: 2
}
row2.node_c -> row3.node_f: "TTL=2 | forward" {
  style.stroke: "#007bff"
  style.stroke-width: 2
}
row2.node_d -> row3.node_g: "TTL=2 | forward" {
  style.stroke: "#007bff"
  style.stroke-width: 2
}

# Hop 3: Second-level forwards (TTL=1) - expires on arrival
row3.node_e -> row4.node_h: "TTL=1 | expire" {
  style.stroke: "#ffc107"
  style.stroke-dash: 5
  style.stroke-width: 2
}
row3.node_f -> row4.node_h: "TTL=1 | expire" {
  style.stroke: "#ffc107"
  style.stroke-dash: 5
  style.stroke-width: 2
}

# Analysis panel providing mathematical context
analysis: {
  near: bottom-left
  style.fill: "#e9ecef"
  style.stroke: "#6c757d"
  header: "**TTL Analysis for Cluster Coverage**"
  formula: |'md
    **Required TTL for full coverage:**
    `TTL ≥ ⌈log_fanout(N)⌉`
    For N=8 nodes, fanout=3:
    `log₃(8) ≈ 1.89 → TTL ≥ 2`
  '|
  table: |'md
    | Cluster Size | Fanout=3 | Recommended TTL |
    |--------------|----------|-----------------|
    | 10 nodes     | 3        | 4-6             |
    | 100 nodes    | 5        | 6-8             |
    | 1000 nodes   | 7        | 8-10            |
  '|
  insight: |'md
    **Why TTL=3 fails for Node H:**
    - Hop 1: A→B,C,D (TTL: 3→2)
    - Hop 2: B,C,D→E,F,G (TTL: 2→1)
    - Hop 3: E,F,G→H (TTL: 1→0, expires)
    Message reaches H but TTL=0 prevents H from processing.
  '|
}

# Warning regarding partial coverage
warning: {
  near: center-right
  style.fill: "#fff3cd"
  style.stroke: "#856404"
  note: |'md
    ⚠️ **TTL Too Low = Incomplete Coverage**
    With TTL=3 in 8-node cluster:
    - 7/8 nodes receive message
    - Node H receives expired data
    **Rule:** Set TTL ≥ `log_fanout(N) × 1.5`
  '|
}

# Seen-cache behavior
cache_note: {
  near: top-right
  style.fill: "#d1ecf1"
  style.stroke: "#0c5460"
  note: |'md
    💡 **TTL + Seen Cache Interaction**
    TTL is a safety net. The seen-message
    cache (LRU) stops duplicates before TTL
    exhaustion in healthy clusters.
  '|
}