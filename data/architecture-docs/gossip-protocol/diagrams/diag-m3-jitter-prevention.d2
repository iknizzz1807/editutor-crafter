        label: "t=10s"
        width: 80
        style.fill: "#90EE90"
        style.stroke: "#00AA00"
      }
      t20a: {
        label: "t=20s"
        width: 80
        style.fill: "#90EE90"
        style.stroke: "#00AA00"
      }
      t30a: {
        label: "t=30s"
        width: 80
