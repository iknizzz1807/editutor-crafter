direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Sync Storm Prevention with Jitter {
  near: top-center
  style.font-size: 24
  style.bold: true
}

row_before: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  before: {
    direction: down
    label: "WITHOUT JITTER"
    style.stroke-width: 2
    
    timeline_before: {
      direction: right
      label: "Timeline (all nodes sync simultaneously)"
      style.fill: "#FFF0F0"
      style.stroke: "#CC0000"
      t0: {
        label: "t=0s"
        width: 80
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.font-color: white
      }
      t10: {
        label: "t=10s"
        width: 80
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.font-color: white
      }
      t20: {
        label: "t=20s"
        width: 80
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.font-color: white
      }
      t30: {
        label: "t=30s"
        width: 80
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.font-color: white
      }
    }
    
    nodes_before: {
      direction: right
      label: "5 Nodes (synchronized)"
      n1: {
        label: "Node 1"
        width: 60
        height: 40
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
      }
      n2: {
        label: "Node 2"
        width: 60
        height: 40
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
      }
      n3: {
        label: "Node 3"
        width: 60
        height: 40
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
      }
      n4: {
        label: "Node 4"
        width: 60
        height: 40
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
      }
      n5: {
        label: "Node 5"
        width: 60
        height: 40
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
      }
    }
    
    bandwidth_before: {
      label: "Bandwidth Graph"
      style.fill: "#FFF0F0"
      style.stroke: "#CC0000"
      direction: right
      spike1: {
        label: "████\nSPIKE\n100%"
        width: 50
        style.fill: "#CC0000"
        style.font-color: white
      }
      quiet1: {
        label: ""
        width: 60
        style.fill: "#FFE0E0"
      }
      spike2: {
        label: "████\nSPIKE\n100%"
        width: 50
        style.fill: "#CC0000"
        style.font-color: white
      }
      quiet2: {
        label: ""
        width: 60
        style.fill: "#FFE0E0"
      }
      spike3: {
        label: "████\nSPIKE\n100%"
        width: 50
        style.fill: "#CC0000"
        style.font-color: white
      }
    }
    
    problem: {
      label: "Problem: All 5 nodes send sync messages at identical times"
      style.fill: "#FFE0E0"
      style.stroke: "#CC0000"
      style.font-color: "#CC0000"
      width: 300
    }
    peak_before: {
      label: "Peak Bandwidth: 5 × digest_size at each interval"
      style.fill: "#FFCCCC"
      style.stroke: "#CC0000"
      width: 300
    }
  }
}

arrow_node: "Add Jitter\n(±10% random offset)" {
  shape: callout
  style.stroke: "#666666"
  style.stroke-width: 3
  style.font-size: 20
  style.fill: "#F4F4F4"
}

