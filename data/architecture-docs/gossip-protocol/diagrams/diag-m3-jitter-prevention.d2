  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  after: {
    direction: down
    label: "WITH JITTER (10% random offset)"
    style.stroke-width: 2
    
    timeline_after: {
      direction: right
      label: "Timeline (syncs spread across interval)"
      style.fill: "#F0FFF0"
      style.stroke: "#00AA00"
      t0a: {
