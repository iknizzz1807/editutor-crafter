        style.stroke: "#00AA00"
      }
      s2: {
        label: "Node 2: t=9.7s, 19.2s, 29.5s, ..."
        width: 320
        style.fill: "#90EE90"
        style.stroke: "#00AA00"
      }
      s3: {
        label: "Node 3: t=10.8s, 21.1s, 30.4s, ..."
        width: 320
        style.fill: "#90EE90"
        style.stroke: "#00AA00"
      }
      s4: {
        label: "Node 4: t=9.5s, 19.9s, 30.1s, ..."
        width: 320
        style.fill: "#90EE90"
        style.stroke: "#00AA00"
      }
      s5: {
        label: "Node 5: t=10.1s, 20.5s, 31.0s, ..."
        width: 320
        style.fill: "#90EE90"
        style.stroke: "#00AA00"
      }
    }
    
    bandwidth_after: {
      label: "Bandwidth Graph"
      style.fill: "#F0FFF0"
      style.stroke: "#00AA00"
      direction: right
      smooth1: { label: "▓▓▓\n20%"; width: 40; style.fill: "#90EE90"; style.stroke: "#00AA00" }
      smooth2: { label: "▓▓▓\n20%"; width: 40; style.fill: "#90EE90"; style.stroke: "#00AA00" }
      smooth3: { label: "▓▓▓\n20%"; width: 40; style.fill: "#90EE90"; style.stroke: "#00AA00" }
      smooth4: { label: "▓▓▓\n20%"; width: 40; style.fill: "#90EE90"; style.stroke: "#00AA00" }
      smooth5: { label: "▓▓▓\n20%"; width: 40; style.fill: "#90EE90"; style.stroke: "#00AA00" }
      smooth6: { label: "▓▓▓\n20%"; width: 40; style.fill: "#90EE90"; style.stroke: "#00AA00" }
    }
    
    benefit: {
      label: "Benefit: Sync requests spread evenly across the interval"
      style.fill: "#E0FFE0"
      style.stroke: "#00AA00"
      style.font-color: "#006600"
      width: 300
    }
    peak_after: {
      label: "Peak Bandwidth: ~digest_size (constant load)"
      style.fill: "#CCFFCC"
      style.stroke: "#00AA00"
      width: 300
    }
  }
}

comparison: {
  direction: right
  label: "Bandwidth Comparison"
  style.stroke-width: 2
  
  metric_before: {
    label: "WITHOUT JITTER"
    style.fill: "#FFEEEE"
    style.stroke: "#CC0000"
    mb1: "Peak: 5× digest"
    mb2: "Avg: 0.5× digest"
    mb3: "Sawtooth pattern"
  }
  metric_after: {
    label: "WITH JITTER"
    style.fill: "#EEFFEE"
    style.stroke: "#00AA00"
    ma1: "Peak: ~1× digest"
    ma2: "Avg: 0.5× digest"
    ma3: "Flat distribution"
  }
}

code_example: {
  label: "Implementation (Go)"
  width: 500
  code: |'go
    // Add jitter to anti-entropy interval
    func (ae *AntiEntropy) jitter() time.Duration {
      factor := 0.1  // 10% jitter
      jitter := time.Duration(
        float64(ae.config.Interval) * 
        factor * 
        rand.Float64(),
      )
      return ae.config.Interval + jitter
    }
    // Schedule next sync with jitter
    nextDelay := ae.config.Interval + ae.jitter()
    timer.Reset(nextDelay)
  '|
}

legend: {
  near: bottom-right
  direction: right
  style.stroke-dash: 2
  red_key: {
    label: "Spike"
    style.fill: "#CC0000"
    width: 20
  }
  green_key: {
    label: "Smooth"
    style.fill: "#90EE90"
    width: 20
  }
}