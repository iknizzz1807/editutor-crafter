node_a.root_a -> node_a.level1_a.l1_left_a: {
  style.stroke: "#B3261E"
  style.stroke-dash: 3
}
node_a.root_a -> node_a.level1_a.l1_right_a: {
  style.stroke: "#2E7D32"
}
node_a.level1_a.l1_left_a -> node_a.level2_a.l2_a_a: { style.stroke: "#B3261E" }
node_a.level1_a.l1_left_a -> node_a.level2_a.l2_a_b: { style.stroke: "#B3261E" }
node_a.level1_a.l1_right_a -> node_a.level2_a.l2_a_c: { style.stroke: "#2E7D32" }
node_a.level1_a.l1_right_a -> node_a.level2_a.l2_a_d: { style.stroke: "#2E7D32" }
node_a.level2_a.l2_a_a -> node_a.leaves_a.leaf_a1: { style.stroke: "#B3261E" }
node_a.level2_a.l2_a_b -> node_a.leaves_a.leaf_a2: { style.stroke: "#B3261E" }
node_a.level2_a.l2_a_c -> node_a.leaves_a.leaf_a3: { style.stroke: "#2E7D32" }
node_a.level2_a.l2_a_d -> node_a.leaves_a.leaf_a4: { style.stroke: "#2E7D32" }
node_b.root_b -> node_b.level1_b.l1_left_b: {
  style.stroke: "#B3261E"
  style.stroke-dash: 3
}
node_b.root_b -> node_b.level1_b.l1_right_b: {
  style.stroke: "#2E7D32"
}
node_b.level1_b.l1_left_b -> node_b.level2_b.l2_b_a: { style.stroke: "#B3261E" }
node_b.level1_b.l1_left_b -> node_b.level2_b.l2_b_b: { style.stroke: "#B3261E" }
node_b.level1_b.l1_right_b -> node_b.level2_b.l2_b_c: { style.stroke: "#2E7D32" }
node_b.level1_b.l1_right_b -> node_b.level2_b.l2_b_d: { style.stroke: "#2E7D32" }
node_b.level2_b.l2_b_a -> node_b.leaves_b.leaf_b1: { style.stroke: "#B3261E" }
node_b.level2_b.l2_b_b -> node_b.leaves_b.leaf_b2: { style.stroke: "#B3261E" }
node_b.level2_b.l2_b_c -> node_b.leaves_b.leaf_b3: { style.stroke: "#2E7D32" }
node_b.level2_b.l2_b_d -> node_b.leaves_b.leaf_b4: { style.stroke: "#2E7D32" }
comparison: Hash Comparison {
  direction: down
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  step1: "1. Compare Root Hashes" {
    width: 280
    code: |'go
      if rootA == rootB {
        return nil // Identical!
      }
      // Roots differ, recurse
    '|
  }
  step2: "2. Compare Level 1 Hashes" {
    width: 280
    code: |'go
      // Left child differs
      if leftA != leftB {
        recurse(leftA, leftB)
      }
      // Right child matches - skip!
      // (green subtree = no exchange needed)
    '|
  }
  step3: "3. Isolate Differing Keys" {
    width: 280
    code: |'go
      // Only K1, K2 differ
      // Exchange ONLY these entries,
      // not full state
      return []string{"K1", "K2"}
    '|
  }
  step1 -> step2 -> step3
}
exchange: Data Exchange {
  direction: down
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  full_state: Full State Exchange {
    shape: rectangle
    label: "4 keys × 1KB = 4KB"
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-dash: 4
    }
  }
  merkle_exchange: Merkle Exchange {
    shape: rectangle
    label: "2 keys × 1KB = 2KB\n+ 7 hashes × 32B = 224B\nTotal: ~2.2KB (45% savings)"
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      bold: true
    }
  }
  full_state -> merkle_exchange: "Merkle Optimization"
}
complexity: Complexity Analysis {
  direction: down
  style.fill: "#FFF8E1"
  style.stroke: "#F57C00"
  table: {
    shape: sql_table
    label: "Scaling Comparison (S = state size)"
    row1: "Full Digest | O(S) | 40 MB for 1M keys"
    row2: "Merkle Tree | O(log S) | ~700 bytes for 1M keys"
    row3: "Bandwidth Savings | 99.998% | Critical for large state"
  }
  formula: {
    label: "Tree Depth = ceil(log2(S))"
    shape: rectangle
    style.fill: "#FFECB3"
  }
  example: {
    label: "1M keys → 20 levels → 20 hash comparisons\nto find ALL differing keys"
    shape: rectangle
    style.fill: "#FFECB3"
  }
}
legend: Legend {
  near: bottom-right
  style.fill: white
  style.stroke: "#9E9E9E"
  diff: Differing (Exchange) {
    shape: rectangle
    style.fill: "#FFB4AB"
    style.stroke: "#B3261E"
  }
  match: Matching (Skip) {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
}
node_a -> comparison: "Root: 0x7f3a..."
node_b -> comparison: "Root: 0x8b4c..."
comparison -> exchange
exchange -> complexity