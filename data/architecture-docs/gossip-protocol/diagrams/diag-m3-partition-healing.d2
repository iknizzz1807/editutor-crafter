direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Partition Healing Timeline (M3)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
legend: {
  near: top-right
  style.fill: white
  style.stroke: gray
  style.stroke-dash: 2
  state_key: |md
    **State Indicators:**
    - 🟢 ALIVE: Healthy member
    - 🟡 SUSPECT: Potentially failed
    - 🔴 DEAD: Confirmed failed
  |
  partition_key: |md
    **Partition:**
    - Group A: nodes 1-3
    - Group B: nodes 4-6
  |
}
# Phase 1: Pre-Partition
phase1_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  phase1_label: {
    label: "Phase 1\nPre-Partition"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      bold: true
    }
    width: 120
  }
  phase1_state: {
    label: "Cluster State"
    style.fill: "#F5F5F5"
    partition_a: {
      label: "Partition A\n{Node1, Node2, Node3}"
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
      node1_a: {
        label: "Node1"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node2_a: {
        label: "Node2"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node3_a: {
        label: "Node3"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node1_a -- node2_a -- node3_a
    }
    partition_b: {
      label: "Partition B\n{Node4, Node5, Node6}"
      style: {
        fill: "#FFF3E0"
        stroke: "#F57C00"
      }
      node4_b: {
        label: "Node4"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node5_b: {
        label: "Node5"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node6_b: {
        label: "Node6"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node4_b -- node5_b -- node6_b
    }
    partition_a <-> partition_b: "gossip messages" {
      style: {
        stroke: "#1976D2"
        stroke-width: 2
      }
    }
  }
  phase1_data: {
    label: "Shared State"
    shape: sql_table
    state1: "key_x | v=100 | Node1"
    state2: "key_y | v=200 | Node4"
    note: "All 6 nodes agree"
  }
}
# Phase 2: Partition Occurs
phase2_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  phase2_label: {
    label: "Phase 2\nNetwork Partition"
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
      bold: true
    }
    width: 120
  }
  phase2_state: {
    label: "Split Cluster"
    style.fill: "#F5F5F5"
    partition_a2: {
      label: "Partition A (Isolated)"
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
        stroke-width: 3
      }
      node1_a2: {
        label: "Node1"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node2_a2: {
        label: "Node2"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node3_a2: {
        label: "Node3"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node1_a2 -- node2_a2 -- node3_a2
    }
    partition_b2: {
      label: "Partition B (Isolated)"
      style: {
        fill: "#FFF3E0"
        stroke: "#F57C00"
        stroke-width: 3
      }
      node4_b2: {
        label: "Node4"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node5_b2: {
        label: "Node5"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node6_b2: {
        label: "Node6"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node4_b2 -- node5_b2 -- node6_b2
    }
    partition_a2 -- partition_b2: "❌ BLOCKED" {
      style: {
        stroke: "#F44336"
        stroke-width: 3
        stroke-dash: 5
      }
    }
  }
  phase2_event: {
    label: "Partition Event"
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    event_text: |md
      **Network partition occurs**
      - Link between switches fails
      - Groups cannot communicate
      - Each side continues operating
    |
  }
}
# Phase 3: Divergent Updates
phase3_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  phase3_label: {
    label: "Phase 3\nDivergent Writes"
    style: {
      fill: "#FFF8E1"
      stroke: "#FF9800"
      stroke-width: 2
      bold: true
    }
    width: 120
  }
  phase3_state: {
    label: "Diverging State"
    style.fill: "#F5F5F5"
    partition_a3: {
      label: "Partition A State"
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
      state_a: {
        label: "key_x = 'from-A'"
        shape: rectangle
        style: {
          fill: "#BBDEFB"
          stroke: "#1976D2"
          bold: true
        }
      }
      version_a: {
        label: "v=100, Node1"
        shape: text
        style.font-size: 12
      }
      write_a: |md
        **Write during partition:**
        Node1 writes key_x
        value = "from-A"
        version = 100
      |
      state_a -> version_a
    }
    partition_b3: {
      label: "Partition B State"
      style: {
        fill: "#FFF3E0"
        stroke: "#F57C00"
      }
      state_b: {
        label: "key_x = 'from-B'"
        shape: rectangle
        style: {
          fill: "#FFE0B2"
          stroke: "#F57C00"
          bold: true
        }
      }
      version_b: {
        label: "v=100, Node4"
        shape: text
        style.font-size: 12
      }
      write_b: |md
        **Concurrent write:**
        Node4 writes key_x
        value = "from-B"  
        version = 100
        ⚠️ **CONFLICT!**
        Same key, same version
        Different values
      |
      state_b -> version_b
    }
  }
  phase3_conflict: {
    label: "⚠️ Conflict Detected"
    shape: diamond
    style: {
      fill: "#FFEB3B"
      stroke: "#F57F17"
      stroke-width: 2
    }
    conflict_note: |md
      **Same version, different values**
      Resolution: LWW with node ID tiebreaker
      Winner: Node4 (alphabetically higher)
    |
  }
}
# Phase 4: Partition Heals
phase4_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  phase4_label: {
    label: "Phase 4\nPartition Heals"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      bold: true
    }
    width: 120
  }
  phase4_state: {
    label: "Reconnected Cluster"
    style.fill: "#F5F5F5"
    partition_a4: {
      label: "Partition A"
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
      node1_a4: {
        label: "Node1"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node2_a4: {
        label: "Node2"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node3_a4: {
        label: "Node3"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
    }
    partition_b4: {
      label: "Partition B"
      style: {
        fill: "#FFF3E0"
        stroke: "#F57C00"
      }
      node4_b4: {
        label: "Node4"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node5_b4: {
        label: "Node5"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
      node6_b4: {
        label: "Node6"
        shape: circle
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.font-color: white
      }
    }
    partition_a4 <-> partition_b4: "✓ Link restored" {
      style: {
        stroke: "#4CAF50"
        stroke-width: 3
        animated: true
      }
    }
  }
  phase4_event: {
    label: "Healing Event"
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    heal_text: |md
      **Network partition heals**
      - Connectivity restored
      - Anti-entropy begins
      - Nodes exchange digests
    |
  }
}
# Phase 5: Anti-Entropy Rounds
phase5_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  phase5_label: {
    label: "Phase 5\nAnti-Entropy"
    style: {
      fill: "#E1F5FE"
      stroke: "#03A9F4"
      stroke-width: 2
      bold: true
    }
    width: 120
  }
  phase5_process: {
    label: "Anti-Entropy Protocol"
    style.fill: "#F5F5F5"
    round1: {
      label: "Round 1: Digest Exchange"
      style.fill: "#E1F5FE"
      step1: |md
        1. Node1 → Node4: DigestRequest
           {key_x: v=100}
        2. Node4 → Node1: DigestRequest  
           {key_x: v=100}
        3. Both detect: same key, same version
      |
    }
    round2: {
      label: "Round 2: Conflict Detection"
      style.fill: "#FFF3E0"
      step2: |md
        4. Values differ: "from-A" ≠ "from-B"
        5. Apply LWW resolution:
           - Same version (100)
           - Tiebreaker: higher node ID
           - Winner: Node4 > Node1
      |
    }
    round3: {
      label: "Round 3: State Exchange"
      style.fill: "#E8F5E9"
      step3: |md
        6. Node4 sends: key_x="from-B"
        7. Node1 accepts (loses tiebreaker)
        8. Node1 updates local state
        9. Gossip spreads to all nodes
      |
    }
    round1 -> round2 -> round3
  }
  phase5_code: {
    label: "Conflict Resolution (state/store.go)"
    width: 350
    code: |'go
      // ResolveConflict uses LWW with tiebreaker
      func ResolveConflict(local, remote *Entry) *Entry {
          if remote.Version > local.Version {
              return remote
          }
          if local.Version > remote.Version {
              return local
          }
          // Tiebreaker: higher node ID wins
          if remote.NodeID > local.NodeID {
              return remote
          }
          return local
      }
    '|
  }
}
# Phase 6: Converged State
phase6_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  phase6_label: {
    label: "Phase 6\nConverged"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      bold: true
    }
    width: 120
  }
  phase6_state: {
    label: "Final Converged State"
    style.fill: "#F5F5F5"
    all_nodes: {
      label: "All 6 Nodes"
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        stroke-width: 2
      }
      converged_state: {
        label: "key_x = 'from-B'"
        shape: rectangle
        style: {
          fill: "#4CAF50"
          stroke: "#2E7D32"
          font-color: white
          bold: true
        }
      }
      converged_version: {
        label: "v=100, Node4 (winner)"
        shape: text
        style.font-size: 12
      }
      nodes_row: {
        direction: right
        n1: {
          label: "N1"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        n2: {
          label: "N2"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        n3: {
          label: "N3"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        n4: {
          label: "N4"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        n5: {
          label: "N5"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        n6: {
          label: "N6"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
        }
        n1 -- n2 -- n3 -- n4 -- n5 -- n6
      }
      converged_state -> converged_version -> nodes_row
    }
  }
  phase6_summary: {
    label: "Convergence Summary"
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
    summary_text: |md
      **Result: Eventual Consistency Achieved**
      ✅ All nodes converged to same value
      ✅ Conflict resolved deterministically
      ✅ No data corruption
      **Convergence time:**
      ~3 anti-entropy rounds
      (~30 seconds with 10s interval)
      **Trade-off:**
      Partition A's write was lost
      (acceptable for AP systems)
    |
  }
}
# Timeline arrows
phase1_row -> phase2_row: "T+0s\npartition" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}
phase2_row -> phase3_row: "T+5s\nwrites" {
  style: {
    stroke: "#FF9800"
    stroke-width: 2
  }
}
phase3_row -> phase4_row: "T+30s\nheal" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
phase4_row -> phase5_row: "T+30s\nanti-entropy" {
  style: {
    stroke: "#03A9F4"
    stroke-width: 2
  }
}
phase5_row -> phase6_row: "T+60s\nconverged" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
# Footer note
footer: {
  near: bottom-center
  shape: text
  style: {
    font-size: 12
    italic: true
  }
  label: "Partition healing demonstrates CAP theorem: during partition, both sides accept writes (Availability); after healing, anti-entropy converges state (Eventual Consistency)"
}