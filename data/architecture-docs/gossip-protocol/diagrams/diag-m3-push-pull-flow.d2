direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- Title Header ---
header: {
  label: "Push-Pull Anti-Entropy Flow: Bidirectional Sync (1-RTT)"
  style: {
    font-size: 24
    bold: true
    underline: true
    stroke: transparent
    fill: transparent
  }
}

# --- Main Sequence Diagram ---
sequence_flow: {
  shape: sequence_diagram
  
  nodeA: Node A {
    style.stroke: "#4A90D9"
    style.stroke-width: 3
  }
  nodeB: Node B {
    style.stroke: "#5D3FD3"
    style.stroke-width: 3
  }

  phase_digest: Phase 1: Digest Exchange {
    nodeA.t1 -> nodeB.t1: DigestRequest {
      style.stroke: "#4A90D9"
    }
    nodeA.t1: {
      width: 300
      code: |'go
        DigestRequest{
          Digest: map[string]uint64{
            "key1": 5, "key2": 3, "key3": 8,
          },
        }
      '|
    }
    
    nodeB.t1 -> nodeA.t1: DigestRequest {
      style.stroke: "#5D3FD3"
    }
    nodeB.t1: {
      width: 300
      code: |'go
        DigestRequest{
          Digest: map[string]uint64{
            "key1": 4,   // A newer
            "key2": 7,   // B newer
            "key4": 2,   // A missing
          },
        }
      '|
    }
  }

  phase_diff: Phase 2: Identify Delta {
    nodeB.t2: Compare Digests {
      width: 350
      code: |'go
        // B determines reconciliation set
        weNeed:   []string{"key1"}
        theyNeed: []string{"key2", "key4"}
      '|
    }
    nodeA.t2: Compare Digests {
      width: 350
      code: |'go
        // A determines reconciliation set
        weNeed:   []string{"key2", "key4"}
        theyNeed: []string{"key1"}
      '|
    }

    nodeA.t2 -> nodeB.t2: DigestResponse {
      style.stroke: "#4A90D9"
    }
    nodeA.t2: {
      width: 280
      code: |'go
        DigestResponse{
          MissingKeys: ["key2", "key4"],
        }
      '|
    }

    nodeB.t2 -> nodeA.t2: DigestResponse {
      style.stroke: "#5D3FD3"
    }
    nodeB.t2: {
      width: 280
      code: |'go
        DigestResponse{
          MissingKeys: ["key1"],
        }
      '|
    }
  }

  phase_sync: Phase 3: State Sync {
    nodeA.t3 -> nodeB.t3: StateResponse {
      style.stroke: "#4A90D9"
      style.stroke-width: 2
    }
    nodeA.t3: {
      width: 320
      code: |'go
        StateResponse{
          Entries: []Entry{
            {K: "key1", V: "val1", Ver: 5},
          },
        }
      '|
    }

    nodeB.t3 -> nodeA.t3: StateResponse {
      style.stroke: "#5D3FD3"
      style.stroke-width: 2
    }
    nodeB.t3: {
      width: 320
      code: |'go
        StateResponse{
          Entries: []Entry{
            {K: "key2", V: "val2", Ver: 7},
            {K: "key4", V: "val4", Ver: 2},
          },
        }
      '|
    }
  }

  phase_apply: Phase 4: Convergence {
    nodeA.t4: Apply Updates {
      width: 280
      code: |'go
        store.Apply("key2", v7)
        store.Apply("key4", v2)
      '|
    }
    nodeB.t4: Apply Updates {
      width: 280
      code: |'go
        store.Apply("key1", v5)
      '|
    }

    # Use notes for status indicators
    nodeA.t4_status: CONVERGED {
      style.fill: "#90EE90"
      style.bold: true
    }
    nodeB.t4_status: CONVERGED {
      style.fill: "#90EE90"
      style.bold: true
    }
  }
}

# --- Root Level Legend ---
legend_box: Legend {
  near: bottom-right
  direction: down
  
  l1: "A Initiates (Push Phase)" {
    style.font-color: "#4A90D9"
    style.stroke: transparent
  }
  l2: "B Responds (Pull Phase)" {
    style.font-color: "#5D3FD3"
    style.stroke: transparent
  }
  l3: "Final Consistency" {
    style.fill: "#90EE90"
    style.border-radius: 4
  }
}