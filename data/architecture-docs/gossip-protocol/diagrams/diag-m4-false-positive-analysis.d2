direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SWIM False Positive Rate Analysis
  Impact of Ping Timeout and Indirect Probe Fanout on Detection Accuracy
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  chart_area: {
    direction: down
    label: "False Positive Rate vs Packet Loss Rate"
    y_axis: {
      shape: text
      label: |md
        **False Positive Rate (%)**
        0 ─────────────────────────
        1 ───────────────────────── ⚠️ Threshold
        2 ─────────────────────────
        5 ─────────────────────────
        10 ────────────────────────
      |
    }
    x_axis: {
      shape: text
      label: |md
        **Packet Loss Rate (%)**
        0%────1%────2%────3%────4%────5%
      |
    }
    grid: {
      shape: rectangle
      width: 500
      height: 300
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
      threshold_line: {
        shape: rectangle
        width: 500
        height: 2
        style.fill: "#dc3545"
        style.stroke: "#dc3545"
        label: "1% FP Threshold"
        label.near: outside-right-center
      }
    }
  }
  legend_area: {
    direction: down
    label: "Configuration Curves"
    width: 280
    config_k1: {
      shape: rectangle
      label: "k=1 (no indirect)"
      style.fill: "#ff6b6b"
      style.stroke: "#ff6b6b"
      width: 20
    }
    note_k1: |md
      At 5% loss: **~5% FP rate**
      Single point of failure
    |
    config_k2: {
      shape: rectangle
      label: "k=2 (2 indirect probes)"
      style.fill: "#ffa94d"
      style.stroke: "#ffa94d"
      width: 20
    }
    note_k2: |md
      At 5% loss: **~0.25% FP rate**
      Below threshold ✓
    |
    config_k3: {
      shape: rectangle
      label: "k=3 (3 indirect probes)"
      style.fill: "#51cf66"
      style.stroke: "#51cf66"
      width: 20
    }
    note_k3: |md
      At 5% loss: **~0.0125% FP rate**
      Recommended config ✓
    |
    config_k5: {
      shape: rectangle
      label: "k=5 (5 indirect probes)"
      style.fill: "#339af0"
      style.stroke: "#339af0"
      width: 20
    }
    note_k5: |md
      At 5% loss: **~0.0003% FP rate**
      Diminishing returns
    |
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  math_area: {
    direction: down
    label: "Mathematical Model"
    width: 350
    formula_box: {
      shape: rectangle
      style.fill: "#e9ecef"
      style.stroke: "#adb5bd"
      width: 320
      formula: |md
        **False Positive Probability:**
        `P(false_positive) = P_loss^(k+1)`
        Where:
        - `P_loss` = packet loss rate
        - `k` = indirect probe fanout
        - `k+1` = direct + indirect attempts
        **Example (5% loss, k=3):**
        `0.05^4 = 0.00000625 ≈ 0.0006%`
      |
    }
    calculation_table: {
      shape: sql_table
      label: "FP Rate by Configuration (swim.go)"
      r1: "k=1 | 1% loss | 0.01% | ✓"
      r2: "k=1 | 5% loss | 0.25% | ✓"
      r3: "k=1 | 10% loss | 1.00% | ✗"
      r4: "k=3 | 1% loss | 0.000001% | ✓"
      r5: "k=3 | 5% loss | 0.000006% | ✓"
      r6: "k=3 | 10% loss | 0.0001% | ✓"
      r7: "k=5 | 10% loss | 0.0000001% | ✓"
    }
  }
  timeout_area: {
    direction: down
    label: "Ping Timeout Impact"
    width: 350
    timeout_table: {
      shape: sql_table
      label: "Timeout vs False Positives (fd.go)"
      h1: "Timeout | P99 RTT | FP Rate | Status"
      r1: "100ms | 50ms | High | ✗ Too aggressive"
      r2: "200ms | 50ms | Medium | ⚠ Marginal"
      r3: "500ms | 50ms | Low | ✓ Recommended"
      r4: "500ms | 150ms | Low | ✓ Safe margin"
      r5: "1000ms | 50ms | Very Low | ⚠ Slow detection"
    }
    timeout_rule: {
      shape: rectangle
      style.fill: "#d4edda"
      style.stroke: "#28a745"
      width: 320
      label: |md
        **Rule of Thumb:**
        `ping_timeout ≥ 3 × P99_RTT`
        Calibrate with `CalibratePingTimeout()`
        in `swim/config.go` at startup
      |
    }
  }
  recommendation_area: {
    direction: down
    label: "Recommended Configurations"
    width: 350
    prod_config: {
      shape: rectangle
      style.fill: "#cce5ff"
      style.stroke: "#004085"
      style.stroke-width: 2
      width: 320
      label: |md
        **Production (High Reliability)**
        go
        Config{
          PingTimeout: 500ms,
          IndirectFanout: 3,
          ProtocolPeriod: 1s,
          SuspicionMultiplier: 5,
        }
        
        Expected FP: < 0.001%
      |
    }
    dev_config: {
      shape: rectangle
      style.fill: "#fff3cd"
      style.stroke: "#856404"
      width: 320
      label: |md
        **Development (Fast Detection)**
        go
        Config{
          PingTimeout: 200ms,
          IndirectFanout: 2,
          ProtocolPeriod: 500ms,
          SuspicionMultiplier: 3,
        }
        
        Expected FP: < 0.1%
      |
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tradeoff_area: {
    direction: down
    label: "Trade-off Analysis"
    width: 520
    tradeoff_table: {
      shape: sql_table
      label: "Fanout vs Detection Latency (swim.go)"
      f1: "Metric | k=1 | k=2 | k=3 | k=5"
      f2: "FP Rate (5% loss) | 0.25% | 0.0125% | 0.0006% | 0.00003%"
      f3: "Detection Time | 1 RTT | 2 RTT | 2 RTT | 2 RTT"
      f4: "Messages/Round | 1 | 3 | 4 | 6"
      f5: "Bandwidth | Low | Medium | Medium | High"
      f6: "Recommendation | ✗ | ⚠ | ✓ | ⚠"
    }
    diminishing_returns: {
      shape: rectangle
      style.fill: "#f8d7da"
      style.stroke: "#721c24"
      width: 480
      label: |md
        **Diminishing Returns Warning:**
        Beyond k=3, FP rate improvement is negligible:
        - k=3 → k=5: 20x better FP, but 1.5x more bandwidth
        - k=3 → k=7: 400x better FP, but 2x more bandwidth
        For most networks (1-5% loss), k=3 is optimal.
        Only use k>3 in extreme loss environments (>10%).
      |
    }
  }
  code_ref_area: {
    direction: down
    label: "Implementation References"
    width: 480
    code_box: {
      shape: class
      label: "FailureDetector (swim/fd.go)"
      -config: "Config"
      -pendingPings: "sync.Map"
      -suspicions: "sync.Map"
      +sendDirectPing(target): "bool, error"
      +sendIndirectProbes(target): "bool"
      +markSuspect(nodeID, incarnation): "void"
      +refuteSuspicion(accusedInc): "void"
    }
    config_box: {
      shape: class
      label: "Config (swim/config.go)"
      ProtocolPeriod: "time.Duration"
      PingTimeout: "time.Duration"
      IndirectFanout: "int"
      SuspicionMultiplier: "int"
      PiggybackSize: "int"
      +DefaultConfig(): "Config"
    }
    test_ref: {
      shape: rectangle
      style.fill: "#e2e3e5"
      style.stroke: "#383d41"
      width: 440
      label: |md
        **Test Verification:**
        `TestFalsePositiveRate()` in `swim_test.go`
        Runs 1000 protocol periods at 5% packet loss
        Asserts: `falsePositiveRate < 0.01` (1%)
      |
    }
  }
}