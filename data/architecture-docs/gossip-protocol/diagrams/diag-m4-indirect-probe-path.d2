direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT LAYOUT ---

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  step1: {
    direction: down
    label: "Step 1: Direct Ping"
    
    flow: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      origin: "Origin Node A" {
        shape: circle
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      target: "Target Node B" {
        shape: circle
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
      }
      origin -> target: "PING (seq=42)" {
        style.stroke: "#F44336"
        style.stroke-dash: 4
        style.animated: true
        label: "timeout!"
      }
    }
    
    note1: {
      label: |md
        **Direct path fails**
        (packet loss / network issue)
      |
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  step2: {
    direction: down
    label: "Step 2: Indirect Probe (ping-req)"
    
    flow: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      origin2: "Origin Node A" {
        shape: circle
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      
      helpers: "k Helper Nodes" {
        direction: right
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
        helper1: "Node C" {
          shape: circle
          style.fill: "#BBDEFB"
          style.stroke: "#2196F3"
        }
        helper2: "Node D" {
          shape: circle
          style.fill: "#BBDEFB"
          style.stroke: "#2196F3"
        }
        helper3: "Node E" {
          shape: circle
          style.fill: "#BBDEFB"
          style.stroke: "#2196F3"
        }
      }
      
      target2: "Target B" {
        shape: circle
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
      }
      
      origin2 -> helpers.helper1: "PING-REQ\n(target=B, seq=42)" {
        style.stroke: "#2196F3"
        style.stroke-width: 2
      }
      origin2 -> helpers.helper2: "PING-REQ\n(target=B, seq=42)" {
        style.stroke: "#2196F3"
        style.stroke-width: 2
      }
      origin2 -> helpers.helper3: "PING-REQ\n(target=B, seq=42)" {
        style.stroke: "#2196F3"
        style.stroke-width: 2
      }
    }
    
    note2: {
      label: |md
        Origin sends **ping-req** to k=3
        random peers (excluding self/target)
      |
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  step3: {
    direction: down
    label: "Step 3: Helpers Probe Target"
    
    flow: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      helper_row: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        hc: "Node C" {
          shape: circle
          style.fill: "#BBDEFB"
          style.stroke: "#2196F3"
        }
        hd: "Node D" {
          shape: circle
          style.fill: "#BBDEFB"
          style.stroke: "#2196F3"
        }
        he: "Node E" {
          shape: circle
          style.fill: "#BBDEFB"
          style.stroke: "#2196F3"
        }
      }
      
      target3: "Target Node B" {
        shape: circle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      
      helper_row.hc -> target3: "PING" {
        style.stroke: "#4CAF50"
        style.animated: true
      }
      helper_row.hd -> target3: "PING" {
        style.stroke: "#4CAF50"
        style.animated: true
      }
      helper_row.he -> target3: "PING" {
        style.stroke: "#F44336"
        style.stroke-dash: 4
        label: "loss"
      }
      target3 -> helper_row.hc: "ACK" {
        style.stroke: "#4CAF50"
        style.animated: true
      }
      target3 -> helper_row.hd: "ACK" {
        style.stroke: "#4CAF50"
        style.animated: true
      }
    }
    
    note3: {
      label: |md
        Helpers probe target via their
        own network paths
      |
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
  }
}

row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  step4: {
    direction: down
    label: "Step 4: Responses to Origin"
    
    flow: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      helpers4: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        hc4: "Node C" {
          shape: circle
          style.fill: "#C8E6C9"
          style.stroke: "#4CAF50"
        }
        hd4: "Node D" {
          shape: circle
          style.fill: "#C8E6C9"
          style.stroke: "#4CAF50"
        }
        he4: "Node E" {
          shape: circle
          style.fill: "#FFECB3"
          style.stroke: "#FFC107"
        }
      }
      
      origin4: "Origin Node A" {
        shape: circle
        style.fill: "#C8E6C9"
        style.stroke: "#4CAF50"
      }
      
      helpers4.hc4 -> origin4: "ACK (from B)" {
        style.stroke: "#4CAF50"
        style.stroke-width: 3
        style.animated: true
      }
      helpers4.hd4 -> origin4: "ACK (from B)" {
        style.stroke: "#4CAF50"
        style.stroke-width: 3
        style.animated: true
      }
      helpers4.he4 -> origin4: "no response" {
        style.stroke: "#FFC107"
        style.stroke-dash: 4
      }
    }
    
    note4: {
      label: |md
        **Result: Target is ALIVE**
        2 of 3 helpers confirmed reachability.
        Origin marks B as ALIVE.
        Only 1 successful response needed!
      |
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
  }
}

# --- GLOBAL CONNECTIONS ---

row1 -> row2: ""
row2 -> row3: ""
row3 -> row4: ""

# --- ROOT LEVEL ANNOTATIONS ---

legend: "Legend" {
  direction: down
  success: "Success path" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  failure: "Failed path" {
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
  partial: "Partial success" {
    shape: rectangle
    style.fill: "#FFECB3"
    style.stroke: "#FFC107"
  }
}
legend.near: bottom-right

math_box: "False Positive Reduction" {
  math: |md
    **Direct ping only:**
    FP rate = packet_loss_rate
    
    **With k=3 indirect probes:**
    FP rate = packet_loss_rate^(k+1)
    
    At 1% loss:
    - Direct: 1.0%
    - k=3: 0.0001% (10,000× better!)
  |
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
}
math_box.near: top-right