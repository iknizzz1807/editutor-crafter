direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "SWIM Piggyback Buffer (swim/piggyback.go)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  buffer: {
    direction: down
    label: "PiggybackBuffer"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    style.stroke-width: 2
    fields: {
      shape: sql_table
      label: "struct PiggybackBuffer"
      f0: "0x00 | sync.RWMutex  | mu"
      f1: "0x08 | []MemberEvent | events"
      f2: "0x10 | []MemberEvent | priority"
      f3: "0x18 | int          | maxSize"
      sz: "Total: ~32 bytes + slice data"
    }
    config: {
      shape: class
      label: "Config Defaults"
      maxSize: "10 events"
      priorityCap: "3 events"
    }
    fields -> config: "configures"
  }
  event: {
    direction: down
    label: "MemberEvent Structure"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2
    eventStruct: {
      shape: sql_table
      label: "struct MemberEvent"
      f0: "0x00 | string    | NodeID"
      f1: "0x10 | string    | Address"
      f2: "0x20 | int       | Port"
      f3: "0x24 | PeerState | State"
      f4: "0x28 | uint64    | Incarnation"
      f5: "0x30 | int64     | Timestamp"
      sz: "Total: 56 bytes"
    }
    states: {
      label: "PeerState Values"
      shape: class
      alive: "ALIVE = 0"
      suspect: "SUSPECT = 1"
      dead: "DEAD = 2"
      "left": "LEFT = 3"
    }
    eventStruct -> states: "enum"
  }
}

row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  bufferOps: {
    direction: down
    label: "Buffer Operations"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    addEvent: {
      label: "AddEvent(ev)"
      width: 350
      code: |'go
        pb.mu.Lock(); defer pb.mu.Unlock()
        for i, e := range pb.events {
          if e.NodeID == ev.NodeID && ev.Incarnation >= e.Incarnation {
            pb.events[i] = ev; return
          }
        }
        if len(pb.events) >= pb.maxSize { pb.events = pb.events[1:] }
        pb.events = append(pb.events, ev)
      '|
    }
    addPriority: {
      label: "AddPriorityEvent(ev)"
      width: 350
      code: |'go
        pb.mu.Lock(); defer pb.mu.Unlock()
        pb.priority = append(pb.priority, ev)
        if len(pb.priority) > 3 {
          pb.priority = pb.priority[len(pb.priority)-3:]
        }
      '|
    }
    getEvents: {
      label: "GetEvents() []MemberEvent"
      width: 350
      code: |'go
        pb.mu.RLock(); defer pb.mu.RUnlock()
        res := make([]MemberEvent, 0, len(pb.priority)+len(pb.events))
        res = append(res, pb.priority...)
        res = append(res, pb.events...)
        return res
      '|
    }
    addEvent -> addPriority: "priority path"
    addPriority -> getEvents: "retrieval"
  }
  circular: {
    direction: down
    label: "Circular Buffer Behavior"
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    style.stroke-width: 2
    step1: {
      label: "Step 1: Buffer at Capacity"
      width: 300
      code: |'text
        events: [E1][E2][E3][E4][E5][E6][E7][E8][E9][E10]
                                          ↑ maxSize=10
      '|
    }
    step2: {
      label: "Step 2: Add E11 (Evict Oldest)"
      width: 300
      code: |'text
        events: [E2][E3][E4][E5][E6][E7][E8][E9][E10][E11]
                 ↑ (E1 evicted)            ↑ (new tail)
      '|
    }
    step3: {
      label: "Step 3: Update Same Node"
      width: 300
      code: |'text
        events: [E2][E3][E4'][E5][E6]...[E11]
                     ↑
        E4' replaces E4 (same ID, newer incarnation)
      '|
    }
    step1 -> step2: "overflow"
    step2 -> step3: "dedup"
  }
}

row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  messages: {
    direction: down
    label: "Message Attachment Points"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
    ping: {
      shape: class
      label: "PingBody"
      seqNum: "uint64"
      targetID: "string"
      piggyback: "[]MemberEvent"
    }
    pingreq: {
      shape: class
      label: "PingReqBody"
      seqNum: "uint64"
      targetID: "string"
      piggyback: "[]MemberEvent"
    }
    ack: {
      shape: class
      label: "AckBody"
      seqNum: "uint64"
      targetID: "string"
      fromID: "string"
      piggyback: "[]MemberEvent"
    }
    ping -> pingreq: "similar structure"
    pingreq -> ack: "similar structure"
  }
  priority: {
    direction: down
    label: "Event Prioritization"
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
    style.stroke-width: 2
    high: {
      shape: rectangle
      label: |md
        **HIGH PRIORITY**
        - Refutations: ALIVE after SUSPECT
        - Own state changes
      |
      style.fill: "#FFECB3"
      style.stroke: "#FF8F00"
    }
    normal: {
      shape: rectangle
      label: |md
        **NORMAL PRIORITY**
        - Remote SUSPECT/DEAD events
        - New member joins
      |
      style.fill: "#FFF3E0"
      style.stroke: "#FFB74D"
    }
    drop: {
      shape: rectangle
      label: |md
        **DROP CONDITIONS**
        - Older incarnation
        - Buffer overflow (FIFO)
      |
      style.fill: "#FFEBEE"
      style.stroke: "#E53935"
    }
    high -> normal: "after priority"
    normal -> drop: "overflow"
  }
}

row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  flow: {
    direction: down
    label: "Piggyback Flow Diagram"
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
    style.stroke-width: 2
    sender: {
      shape: rectangle
      label: "Sender Node"
      style.fill: "#B2EBF2"
    }
    bufferGet: {
      shape: diamond
      label: "GetEvents()"
    }
    attach: {
      shape: rectangle
      label: "Attach to Message"
      style.fill: "#80DEEA"
    }
    network: {
      shape: rectangle
      label: "UDP Network"
      style.fill: "#4DD0E1"
      style.stroke-dash: 3
    }
    receiver: {
      shape: rectangle
      label: "Receiver Node"
      style.fill: "#B2EBF2"
    }
    process: {
      shape: diamond
      label: "processPiggyback()"
    }
    update: {
      shape: rectangle
      label: "Update PeerList"
      style.fill: "#80DEEA"
    }
    sender -> bufferGet: "1"
    bufferGet -> attach: "2"
    attach -> network: "3"
    network -> receiver: "4"
    receiver -> process: "5"
    process -> update: "6"
  }
  sizing: {
    direction: down
    label: "Sizing Guidelines"
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    style.stroke-width: 2
    formula: {
      label: |md
        **Buffer Size Formula**
        `size = fanout × 2`
        - Example: Fanout=3, Size=6
        - Memory: ~600 bytes (10 events)
      |
      shape: rectangle
      style.fill: "#C5CAE9"
    }
    bandwidth: {
      label: |md
        **Bandwidth Impact**
        - Zero extra UDP packets
        - Amortized cost: overhead inside ping
      |
      shape: rectangle
      style.fill: "#D1C4E9"
    }
    formula -> bandwidth: "optimization"
  }
}

buffer -> messages: "attached to"
messages -> flow: "transmitted via"
bufferOps -> priority: "prioritizes"
sizing -> buffer: "configures"