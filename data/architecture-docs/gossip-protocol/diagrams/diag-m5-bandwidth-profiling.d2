direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Bandwidth Profiling Dashboard"
  sub: "Gossip Protocol M5 — Scaling Verification"
  near: top-center
  style.font-size: 24
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  per_node_panel: {
    direction: down
    label: "Per-Node Metrics (10-node cluster)"
    
    node_metrics_table: {
      shape: sql_table
      label: "Node Bandwidth (10s sample)"
      n0: "node-0 | 2,847 | 2,912 | 5,759"
      n1: "node-1 | 2,891 | 2,856 | 5,747"
      n2: "node-2 | 2,823 | 2,901 | 5,724"
      n3: "node-3 | 2,912 | 2,834 | 5,746"
      n4: "node-4 | 2,856 | 2,889 | 5,745"
      n5: "node-5 | 2,878 | 2,867 | 5,745"
      n6: "node-6 | 2,845 | 2,923 | 5,768"
      n7: "node-7 | 2,901 | 2,812 | 5,713"
      n8: "node-8 | 2,834 | 2,878 | 5,712"
      n9: "node-9 | 2,867 | 2,845 | 5,712"
      avg: "AVG | 2,865 | 2,872 | 5,737 B/s"
    }
    
    variance_note: {
      label: "✓ Variance < 1% — Good distribution"
      style.fill: "#d4edda"
      style.stroke: "#28a745"
      style.font-color: "#155724"
    }
  }

  aggregate_panel: {
    direction: down
    label: "Cluster Aggregate"
    
    aggregate_table: {
      shape: sql_table
      label: "Cluster Summary"
      row1: "Total Bytes Sent | 28,654"
      row2: "Total Bytes Recv | 28,718"
      row3: "Cluster BW | 5,737 B/s"
      row4: "Per-Node Avg | 574 B/s"
    }
    
    config_table: {
      shape: sql_table
      label: "Configuration"
      c1: "Fanout (k) | 3"
      c2: "Gossip Interval | 200ms"
      c3: "Avg Message Size | ~500 B"
      c4: "Updates/sec/node | 10"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  theoretical_panel: {
    direction: down
    label: "Theoretical Bound Analysis"
    
    formula_box: {
      label: "Expected Bandwidth Formula"
      code: |'md
        BW_per_node = k × msg_size × (1 / interval)
        With k=3, msg=500B, interval=200ms:
        BW = 3 × 500 × 5 = 7,500 B/s (gossip only)
        Including anti-entropy (every 10s):
        + digest_size / 10 = ~200 B/s
        Total expected: ~7,700 B/s
      '|
      style.fill: "#e8f4f8"
      style.stroke: "#17a2b8"
    }
    
    comparison_table: {
      shape: sql_table
      label: "Measured vs Expected"
      exp1: "Expected BW | 7,700 B/s"
      exp2: "Measured BW | 5,737 B/s"
      exp3: "Efficiency | 74.5%"
      exp4: "Scaling Factor | 0.74x"
    }
    
    verdict_good: {
      label: "✓ WITHIN BOUNDS"
      note: "Scaling factor < 1.0 indicates efficient delta-based sending"
      style.fill: "#d4edda"
      style.stroke: "#28a745"
      style.font-color: "#155724"
    }
  }

  scaling_panel: {
    direction: down
    label: "Scaling Verification"
    
    scaling_table: {
      shape: sql_table
      label: "Bandwidth vs Cluster Size"
      hdr: "Cluster | Total | Per-Node"
      s1: "N=5  | 5,623 B/s | 1,125 B/s"
      s2: "N=10 | 5,737 B/s | 574 B/s"
      s3: "N=20 | 5,891 B/s | 295 B/s"
      s4: "N=50 | 6,102 B/s | 122 B/s"
      s5: "N=100| 6,287 B/s | 63 B/s"
    }
    
    scaling_note: {
      label: "✓ O(1) per-node confirmed"
      note: "Per-node BW decreases as 1/N; Total BW remains constant"
      style.fill: "#d4edda"
      style.stroke: "#28a745"
      style.font-color: "#155724"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  problem_panel: {
    direction: down
    label: "Problem Detection Example"
    
    problem_table: {
      shape: sql_table
      label: "BAD: O(N²) Detected!"
      hdr: "Cluster | Total | Per-Node"
      p1: "N=5  | 1,250 B/s | 250 B/s"
      p2: "N=10 | 5,000 B/s | 500 B/s"
      p3: "N=20 | 20,000 B/s | 1,000 B/s"
      p4: "N=50 | 125,000 B/s | 2,500 B/s"
      p5: "N=100| 500,000 B/s | 5,000 B/s"
    }
    
    problem_note: {
      label: "✗ SCALING FAILURE"
      note: "Per-node BW grows with N; Indicates broadcast bug"
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
      style.font-color: "#721c24"
    }
    
    root_cause: {
      label: "Common Causes"
      content: |'md
        • Node not excluding self from peer selection
        • Full-state sync instead of delta
        • Missing seen-message cache
        • Fanout = N-1 (broadcast mode)
      '|
      style.fill: "#fff3cd"
      style.stroke: "#856404"
    }
  }

  graph_panel: {
    direction: down
    label: "Time Series Visualization"
    
    timeseries: {
      label: "Bytes/sec over 60s"
      width: 500
      graph: |'md
        8000 ┤
        7500 ┤ ╭─────────────────────────────────────╮
        7000 ┤ │                                     │
        6500 ┤ │  Gossip traffic (stable ~6KB/s)     │
        6000 ┤ │                                     │
        5500 ┤ ╰─────────────────────────────────────╯
        5000 ┤
             └┬────┬────┬────┬────┬────┬────┬────┬────┬
              0s   10s  20s  30s  40s  50s  60s
      '|
      note: "Baseline is push gossip; Spikes are anti-entropy syncs"
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
    }
    
    legend: {
      direction: right
      baseline: {
        label: "━━ Baseline: Push gossip"
        style.fill: "#cce5ff"
        style.stroke: "#004085"
      }
      spike: {
        label: "▲ Spikes: Anti-entropy"
        style.fill: "#fff3cd"
        style.stroke: "#856404"
      }
    }
  }
}

alert_box: {
  label: "Alert Thresholds"
  threshold_data: |'md
    | Metric | Warning | Critical |
    |--------|---------|----------|
    | Scaling factor | > 1.5x | > 2.0x |
    | Per-node variance | > 10% | > 25% |
    | BW growth rate | > O(log N) | > O(N) |
  '|
  style.fill: "#fff3cd"
  style.stroke: "#856404"
}

alert_box.near: bottom-center