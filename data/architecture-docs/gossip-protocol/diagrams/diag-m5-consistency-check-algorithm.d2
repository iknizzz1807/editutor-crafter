direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Consistency Check Algorithm
  Verifies no node holds stale versions after convergence bound
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase1: {
    direction: down
    label: "Phase 1: Collect"
    start: {
      shape: oval
      label: "Start\nConsistency\nCheck"
      style.fill: "#E8F5E9"
    }
    collect: {
      label: "Collect All Committed Versions"
      width: 320
      code: |'go
        committed := make(map[string]VersionInfo)
        for _, node := range nodes {
          for key, entry := range node.Store() {
            committed[key] = VersionInfo{
              Version:    entry.Version,
              CommitTime: time.Now(),
            }
          }
        }
      '|
    }
    committed_store: {
      shape: sql_table
      label: "committed map (in memory)"
      k1: "key | version | commit_time"
      k2: "\"user:1\" | 42 | 10:00:01.500"
      k3: "\"config\" | 7 | 10:00:01.502"
      k4: "\"cache:a\" | 15 | 10:00:01.505"
    }
    start -> collect: "initialize"
    collect -> committed_store: "populate"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase2: {
    direction: down
    label: "Phase 2: Check"
    check_start: {
      shape: oval
      label: "For Each\nNode N"
      style.fill: "#E3F2FD"
    }
    read_local: {
      label: "Read Node N's Local State"
      width: 320
      code: |'go
        for key, localEntry := range n.Store().GetAll() {
          committedInfo, exists := committed[key]
          if !exists {
            continue // New key, not yet tracked
          }
          // Check version...
        }
      '|
    }
    version_check: {
      shape: diamond
      label: "local.version <\ncommitted.version?"
      width: 180
    }
    age_check: {
      shape: diamond
      label: "committed.age >\nconvergence_bound?"
      width: 180
    }
    flag_violation: {
      label: "Flag Consistency Violation"
      style.fill: "#FFCDD2"
      width: 280
      code: |'go
        violations = append(violations, Violation{
          Key:          key,
          NodeID:       n.ID,
          StaleVersion: localEntry.Version,
          ExpectedMin:  committedInfo.Version,
          Age:          time.Since(committedInfo.CommitTime),
        })
      '|
    }
    check_start -> read_local: "iterate"
    read_local -> version_check: "compare"
    version_check -> age_check: "yes (stale)"
    version_check -> read_local: "no (current)\ncontinue to next key" {
      style.stroke-dash: 4
    }
    age_check -> flag_violation: "yes (too old)"
    age_check -> read_local: "no (within bound)\nallow catch-up" {
      style.stroke-dash: 4
    }
  }
  phase3: {
    direction: down
    label: "Phase 3: Report"
    report_start: {
      shape: oval
      label: "Generate\nReport"
      style.fill: "#F3E5F5"
    }
    violation_check: {
      shape: diamond
      label: "violations\n> 0?"
      width: 140
    }
    report_fail: {
      label: "Report FAILED"
      style.fill: "#FFCDD2"
      code: |'go
        log.Errorf("Consistency check failed:")
        for _, v := range violations {
          log.Errorf("  Key %s on %s:", v.Key, v.NodeID)
          log.Errorf("    stale: %d < expected: %d",
            v.StaleVersion, v.ExpectedMin)
        }
      '|
    }
    report_pass: {
      label: "Report PASSED"
      style.fill: "#C8E6C9"
      code: |'go
        log.Infof("Consistency check passed:")
        log.Infof("  Total checks: %d", totalChecks)
        log.Infof("  Violations: 0")
      '|
    }
    end: {
      shape: oval
      label: "End"
    }
    report_start -> violation_check
    violation_check -> report_fail: "yes"
    violation_check -> report_pass: "no"
    report_fail -> end
    report_pass -> end
  }
}
flag_violation -> report_start: "all nodes\nchecked"
legend: {
  near: bottom-center
  label: "Convergence Bound"
  desc: |md
    **convergence_bound** = `gossip_interval × log_fanout(N) × safety_margin`
    - Default: 6 × gossip_interval (~1.2s for 200ms interval)
    - Allows nodes time to receive updates via gossip
    - Violations after bound indicate protocol failure
  |
}
flow_legend: {
  near: bottom-right
  label: "Flow Legend"
  f1: "Solid arrow" {
    shape: text
  }
  f1_arrow: "→ Normal flow" {
    shape: text
  }
  f2: "Dashed arrow" {
    shape: text
  }
  f2_arrow: "→ Continue iteration" {
    shape: text
    style.stroke-dash: 4
  }
  f1_arrow -> f2_arrow: {
    style.opacity: 0
  }
}