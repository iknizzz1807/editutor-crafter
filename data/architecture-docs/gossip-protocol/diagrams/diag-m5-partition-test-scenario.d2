direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # Partition Test Scenario
    Network partition healing with state convergence verification
  '|
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
}
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  phase1: {
    direction: down
    label: "Phase 1: Initial State"
    
    cluster_before: {
      label: "Cluster (6 nodes)"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      
      direction: right
      
      nodes: {
        style.fill: transparent
        style.stroke: transparent
        node_a: { label: "Node A"; shape: circle; style.fill: "#81C784" }
        node_b: { label: "Node B"; shape: circle; style.fill: "#81C784" }
        node_c: { label: "Node C"; shape: circle; style.fill: "#81C784" }
        node_d: { label: "Node D"; shape: circle; style.fill: "#81C784" }
        node_e: { label: "Node E"; shape: circle; style.fill: "#81C784" }
        node_f: { label: "Node F"; shape: circle; style.fill: "#81C784" }
      }
    }
    
    time1: {
      label: "t = 0s"
      shape: parallelogram
      style.fill: "#CFD8DC"
      style.stroke: "#455A64"
    }
    width: 350
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  phase2: {
    direction: down
    label: "Phase 2: Partition Created"
    
    partition_group: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      partition1: {
        label: "Partition 1 (Quorum Loss)"
        style.fill: "#FFCDD2"
        style.stroke: "#E53935"
        style.stroke-dash: 3
        
        nodes: {
          direction: right
          style.fill: transparent
          style.stroke: transparent
          p1_a: {label: "A"; shape: circle; style.fill: "#EF9A9A"}
          p1_b: {label: "B"; shape: circle; style.fill: "#EF9A9A"}
          p1_c: {label: "C"; shape: circle; style.fill: "#EF9A9A"}
        }
        
        update1: {
          label: |'md
            **Write Op:**
            key="x"
            val="from-P1"
            v=100
          '|
          shape: rectangle
          style.fill: "#FFEBEE"
          style.stroke: "#C62828"
        }
        nodes.p1_a -> update1: "Set(x)"
      }
      
      partition_gap: {
        label: "✕ NETWORK SPLIT ✕"
        shape: rectangle
        style.fill: "#B71C1C"
        style.font-color: white
        style.stroke: transparent
        width: 100
      }
      
      partition2: {
        label: "Partition 2 (Quorum Loss)"
        style.fill: "#BBDEFB"
        style.stroke: "#1976D2"
        style.stroke-dash: 3
        
        nodes: {
          direction: right
          style.fill: transparent
          style.stroke: transparent
          p2_d: {label: "D"; shape: circle; style.fill: "#90CAF9"}
          p2_e: {label: "E"; shape: circle; style.fill: "#90CAF9"}
          p2_f: {label: "F"; shape: circle; style.fill: "#90CAF9"}
        }
        
        update2: {
          label: |'md
            **Write Op:**
            key="x"
            val="from-P2"
            v=100
          '|
          shape: rectangle
          style.fill: "#E3F2FD"
          style.stroke: "#1565C0"
        }
        nodes.p2_d -> update2: "Set(x)"
      }
    }
    
    conflict_note: {
      label: |'md
        **DIVERGENCE DETECTED**
        Same key, same version (100)
        Conflicting values in sub-graphs
      '|
      shape: callout
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
    }
    
    time2: {
      label: "t = 2s (Split Brain Active)"
      shape: parallelogram
      style.fill: "#FFCCBC"
      style.stroke: "#D84315"
    }
    width: 650
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  phase3: {
    direction: down
    label: "Phase 3: Partition Healed"
    
    healing: {
      label: "Anti-Entropy (Merkle Tree Sync)"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      
      cluster_sync: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        h_a: {label: "A"; shape: circle; style.fill: "#A5D6A7"}
        h_b: {label: "B"; shape: circle; style.fill: "#A5D6A7"}
        h_c: {label: "C"; shape: circle; style.fill: "#A5D6A7"}
        h_d: {label: "D"; shape: circle; style.fill: "#A5D6A7"}
        h_e: {label: "E"; shape: circle; style.fill: "#A5D6A7"}
        h_f: {label: "F"; shape: circle; style.fill: "#A5D6A7"}
      }
      
      sync_op: {
        label: "Gossip Push-Pull: Reconciling {x}"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#388E3C"
      }
    }
    
    time3: {
      label: "t = 12s (Restored)"
      shape: parallelogram
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
    width: 450
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  phase4: {
    direction: down
    label: "Phase 4: Final Convergence"
    
    converged: {
      label: "Consistent View Reached"
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      
      nodes_final: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        f_a: {label: "A"; shape: circle; style.fill: "#43A047"}
        f_b: {label: "B"; shape: circle; style.fill: "#43A047"}
        f_c: {label: "C"; shape: circle; style.fill: "#43A047"}
        f_d: {label: "D"; shape: circle; style.fill: "#43A047"}
        f_e: {label: "E"; shape: circle; style.fill: "#43A047"}
        f_f: {label: "F"; shape: circle; style.fill: "#43A047"}
      }
      
      final_state: {
        label: |'md
          **Converged State:**
          key="x", val="from-P2", v=100
          **Winner:** Node D (Deterministic ID tiebreaker)
        '|
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#1B5E20"
      }
    }
    
    time4: {
      label: "t = 17s (Consistent)"
      shape: parallelogram
      style.fill: "#81C784"
      style.stroke: "#1B5E20"
    }
    width: 450
  }
}

row1 -> row2: "Network Failure" {
  style.stroke: "#E53935"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row2 -> row3: "Path Restored" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row3 -> row4: "State Sync" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

legend: {
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: { label: "Partition 1 (P1)"; shape: rectangle; style.fill: "#FFCDD2" }
  l2: { label: "Partition 2 (P2)"; shape: rectangle; style.fill: "#BBDEFB" }
  l3: { label: "Converged State"; shape: rectangle; style.fill: "#C8E6C9" }
}
legend.near: bottom-left

timing_table: {
  label: |'md
    ## Timing & State Transitions
    | Phase | Duration | System Event |
    |-------|----------|--------------|
    | Initial | 0-2s | All nodes agree on null |
    | Partition | 2-12s | Divergent writes to P1 and P2 |
    | Healing | 12s | Connectivity restored |
    | Convergence | 12-17s | LWW reconciliation resolves "from-P2" |
  '|
  shape: rectangle
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
  width: 500
}
timing_table.near: bottom-center

resolution_logic: {
  label: |'md
    ### Conflict Resolution (LWW-ID)
    
    **Metadata Comparison:**
    - Version(P1): 100
    - Version(P2): 100
    - Result: **Version Tie**
    
    **Tiebreaker:**
    - NodeID(P1): "A"
    - NodeID(P2): "D"
    - Rule: Max(ID) wins
    - **Resolution: P2 wins**
  '|
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  width: 320
}
resolution_logic.near: bottom-right