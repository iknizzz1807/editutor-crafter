direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Integration Test Harness Architecture (test/harness.go)" {
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
  shape: text
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  test_suite: "TestSuite" {
    direction: down
    label: "Test Suite (test/suite.go)"
    style.fill: "#E8E8E8"
    ts_config: {
      shape: class
      label: "TestSuite"
      -verbose: "bool"
      -parallel: "bool"
      -results: "[]*TestResult"
      +Run(): "error"
      +Report(): "void"
    }
    tests: "Test Cases" {
      direction: right
      grid-columns: 2
      grid-gap: 0
      style.fill: transparent
      tc1: "ConvergenceTest" {
        style.fill: "#ACE1AF"
      }
      tc2: "DetectionTest" {
        style.fill: "#ACE1AF"
      }
      tc3: "FalsePositiveTest" {
        style.fill: "#ACE1AF"
      }
      tc4: "PartitionTest" {
        style.fill: "#ACE1AF"
      }
      tc5: "BandwidthProfile" {
        style.fill: "#ACE1AF"
      }
      tc6: "ConsistencyCheck" {
        style.fill: "#ACE1AF"
      }
      tc7: "ChaosTest" {
        style.fill: "#FFE4B5"
      }
    }
  }
  test_suite_arrow: {
    style.fill: transparent
    style.stroke: transparent
    width: 50
  }
  harness: "Harness" {
    direction: down
    label: "Test Harness (test/harness.go)"
    style.fill: "#B5CAFF"
    harness_config: {
      shape: class
      label: "HarnessConfig"
      +ClusterSize: "int"
      +BasePort: "int"
      +UseRealNetwork: "bool"
      +PacketLossRate: "float64"
      +MessageDelay: "time.Duration"
      +RandomSeed: "int64"
    }
    harness_struct: {
      shape: class
      label: "Harness"
      -config: "HarnessConfig"
      -nodes: "[]*TestNode"
      -transport: "Transport"
      -metrics: "*MetricsCollector"
      +Start(): "error"
      +Stop(): "void"
      +KillNode(idx): "error"
      +RestartNode(idx): "error"
      +Partition(groups): "void"
      +Heal(): "void"
      +SetPacketLoss(rate): "void"
    }
  }
}
test_suite.ts_config -> harness.harness_config: "configures"
test_suite.tests -> harness.harness_struct: "uses"
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  node_cluster: "Node Cluster" {
    direction: down
    label: "Gossip Nodes (N goroutines)"
    style.fill: "#FFF9C4"
    nodes_row: "" {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      node0: "Node 0\n(seed)" {
        style.fill: "#C8E6C9"
        icon: https://icons.terrastruct.com/dev%2Fgo.svg
      }
      node1: "Node 1" {
        style.fill: "#C8E6C9"
        icon: https://icons.terrastruct.com/dev%2Fgo.svg
      }
      node2: "Node 2" {
        style.fill: "#C8E6C9"
        icon: https://icons.terrastruct.com/dev%2Fgo.svg
      }
      node_n: "Node N-1" {
        style.fill: "#C8E6C9"
        style.multiple: true
        icon: https://icons.terrastruct.com/dev%2Fgo.svg
      }
    }
    test_node: {
      shape: class
      label: "TestNode"
      +Node: "*node.Node"
      +ID: "string"
      +metrics: "*NodeMetrics"
      +blocked: "atomic.Bool"
      +blockList: "map[string]bool"
    }
  }
  gap: {
    style.fill: transparent
    style.stroke: transparent
    width: 100
  }
  transport_layer: "Transport Layer" {
    direction: down
    label: "Transport Abstraction"
    style.fill: "#E1BEE7"
    transport_interface: {
      shape: class
      label: "Transport (interface)"
      +Send(from, to, data): "error"
      +Receive(nodeID): "([]byte, string, error)"
      +Partition(groups): "void"
      +Heal(): "void"
      +SetPacketLoss(rate): "void"
      +Close(): "void"
    }
    impl_row: "" {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      real: "RealTransport" {
        style.fill: "#FFCCBC"
        label: "RealTransport\n(UDP Sockets)"
      }
      simulated: "SimulatedTransport" {
        style.fill: "#FFCCBC"
        label: "SimulatedTransport\n(In-Memory Queues)"
      }
    }
    fault_injection: "Fault Injection Controls" {
      direction: right
      style.fill: "#FFCDD2"
      grid-columns: 3
      grid-gap: 0
      fi1: "Packet Loss\n(configurable %)" {
        style.fill: "#FFCDD2"
      }
      fi2: "Network Delay\n(configurable ms)" {
        style.fill: "#FFCDD2"
      }
      fi3: "Partitions\n(group-based)" {
        style.fill: "#FFCDD2"
      }
    }
  }
}
harness.harness_struct -> node_cluster.test_node: "manages"
harness.harness_struct -> transport_layer.transport_interface: "uses"
node_cluster.nodes_row <-> transport_layer.impl_row: "messages"
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  metrics: "Metrics Collection" {
    direction: down
    label: "Metrics Collector"
    style.fill: "#B2DFDB"
    mc_struct: {
      shape: class
      label: "MetricsCollector"
      -nodeData: "map[string]*NodeMetrics"
      +RecordSend(nodeID, bytes): "void"
      +RecordRecv(nodeID, bytes): "void"
      +GetTotalBytesPerSecond(): "float64"
      +GetPerNodeStats(nodeID): "*NodeMetrics"
    }
    node_metrics: {
      shape: class
      label: "NodeMetrics"
      +BytesSent: "uint64"
      +BytesReceived: "uint64"
      +MessagesSent: "uint64"
      +MessagesRecv: "uint64"
      +UpdatesSent: "uint64"
      +UpdatesRecv: "uint64"
    }
  }
  verification: "Verification Hooks" {
    direction: down
    label: "Verification Hooks"
    style.fill: "#DCEDC8"
    v_struct: {
      shape: class
      label: "Verification API"
      +AssertConvergence(key, value, timeout): "void"
      +AssertNodeDetected(deadNodeID, timeout): "void"
      +AssertBandwidthBelow(maxBytesPerSec): "void"
      +AssertNoStaleReads(convergenceBound): "void"
    }
    v_checks: "Property Checks" {
      direction: right
      style.fill: transparent
      grid-columns: 2
      grid-gap: 0
      vc1: "Convergence\n(all nodes agree)" {
        style.fill: "#DCEDC8"
      }
      vc2: "Detection\n(dead nodes marked)" {
        style.fill: "#DCEDC8"
      }
      vc3: "Bandwidth\n(O(1) per node)" {
        style.fill: "#DCEDC8"
      }
      vc4: "Consistency\n(no stale reads)" {
        style.fill: "#DCEDC8"
      }
    }
  }
}
node_cluster.test_node -> metrics.node_metrics: "reports"
test_suite.tests -> verification.v_struct: "calls"
verification.v_checks -> metrics.mc_struct: "reads"
legend: "Legend" {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#666666"
  style.stroke-dash: 2
  l1: "Green boxes: Test implementations" {
    style.fill: "#ACE1AF"
    shape: rectangle
  }
  l2: "Yellow boxes: Core harness" {
    style.fill: "#FFF9C4"
    shape: rectangle
  }
  l3: "Red boxes: Fault injection" {
    style.fill: "#FFCDD2"
    shape: rectangle
  }
  l4: "Blue boxes: Metrics/Verification" {
    style.fill: "#B5CAFF"
    shape: rectangle
  }
}
flow_annotation: |md
  **Test Flow:**
  1. TestSuite configures Harness with ClusterSize, RandomSeed
  2. Harness.Start() spawns N TestNode goroutines
  3. Each TestNode runs full gossip protocol (M1-M4)
  4. Transport layer intercepts messages, applies faults
  5. MetricsCollector tracks bandwidth per node
  6. Verification hooks assert convergence, detection, consistency
  7. ChaosTest can inject continuous random failures
| {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#666666"
    stroke-dash: 2
  }
}