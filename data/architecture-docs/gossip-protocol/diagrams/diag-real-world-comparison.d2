direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    m1: "#E8F4FE"
    m2: "#C7F1FF"
    m3: "#FBBF24"
    m4: "#22C55E"
    m5: "#F59A0B"
    stroke_m1: "#2563EB"
    stroke_m2: "#0EA5E9"
    stroke_m3: "#D97706"
    stroke_m4: "#166534"
    stroke_m5: "#C2410C"
  }
}

title: {
  shape: rectangle
  label: |md
    # Gossip Protocol System Architecture (v1.0)
    **Implementation Blueprint: M1 - M5 Integration**
  |
  near: top-center
  style: {
    stroke-width: 0
    fill: transparent
  }
}

# --- ROW 1: CORE MEMBERSHIP & DISSEMINATION ---
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  m1_membership: {
    label: "M1: Membership & Bootstrapping"
    style.fill: "${colors.m1}"
    style.stroke: "${colors.stroke_m1}"

    peer_list: {
      shape: sql_table
      label: "PeerList (peer.go)"
      f0: "0x00 | RWMutex | lock"
      f1: "0x08 | map[ID]Peer | peers"
      f2: "0x18 | []ID | seed_nodes"
      size: "Total: 32 bytes + map overhead"
    }

    state_machine: {
      shape: rectangle
      label: "Peer State Evolution"
      ALIVE -> SUSPECT: "timeout | ping-fail"
      SUSPECT -> DEAD: "timeout | no-refutation"
      SUSPECT -> ALIVE: "incarnation+1 | refute"
    }
  }

  m2_dissemination: {
    label: "M2: Epidemic Dissemination"
    style.fill: "${colors.m2}"
    style.stroke: "${colors.stroke_m2}"

    message_cache: {
      shape: sql_table
      label: "SeenCache (LRU)"
      row1: "0x00 | map[uint64]bool | seen_ids"
      row2: "0x10 | *List.Element | evict_ptr"
      note: "Prevents broadcast storms"
    }

    push_logic: {
      shape: class
      label: "GossipPusher"
      -fanout: "int"
      -interval: "time.Duration"
      +SelectPeers(n): "[]Peer"
      +Broadcast(msg): "error"
    }
  }
}

# --- ROW 2: REPAIR & DETECTION ---
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  m3_anti_entropy: {
    label: "M3: Merkle Anti-Entropy"
    style.fill: "${colors.m3}"
    style.stroke: "${colors.stroke_m3}"

    merkle_tree: {
      shape: sql_table
      label: "MerkleTree (sync.go)"
      f0: "0x00 | []byte | root_hash"
      f1: "0x20 | map[int]Node | levels"
      f2: "0x30 | Jitter | sync_jitter"
      note: "Heals partitions via push-pull"
    }
  }

  m4_failure_detection: {
    label: "M4: SWIM failure Detection"
    style.fill: "${colors.m4}"
    style.stroke: "${colors.stroke_m4}"

    swim_engine: {
      shape: class
      label: "SWIM_Engine"
      -protocol_period: "time.Duration"
      +Ping(target): "bool"
      +PingReq(proxy, target): "bool"
      +Refute(inc): "void"
    }
  }
}

# --- ROW 3: TESTING & HARNESS ---
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  m5_integration: {
    label: "M5: Test Harness & Simulation"
    style.fill: "${colors.m5}"
    style.stroke: "${colors.stroke_m5}"

    fault_injector: {
      shape: class
      label: "FaultMatrix"
      +KillNode(id): "void"
      +PartitionNetwork(subsets): "void"
      +InjectLatency(delay): "void"
    }

    metrics: {
      shape: sql_table
      label: "ConvergenceTracker"
      m1: "latency_ms | propagation time"
      m2: "msg_count | bandwidth used"
      m3: "false_positives | accuracy"
    }
  }
}

# --- CROSS-LAYER CONNECTIONS ---
row1.m1_membership -> row1.m2_dissemination: "PeerList | select"
row1.m2_dissemination -> row2.m3_anti_entropy: "MissedMsgs | pull"
row1.m1_membership -> row2.m4_failure_detection: "StateUpdates | event"
row2.m4_failure_detection -> row1.m1_membership: "DeadNode | update" {
  style.stroke-dash: 4
}
row2.m3_anti_entropy -> row1.m1_membership: "FullSync | repair"

# --- TESTING HOOKS ---
row3.m5_integration -> row1.m1_membership: "Simulate"
row3.m5_integration -> row2.m4_failure_detection: "Validate"

# --- LEGEND ---
legend: {
  shape: rectangle
  label: "System Legend"
  near: bottom-right
  
  l1: "Blue: Membership (M1)" {
    style.font-color: "${colors.stroke_m1}"
  }
  l2: "Cyan: Dissemination (M2)" {
    style.font-color: "${colors.stroke_m2}"
  }
  l3: "Yellow: Anti-Entropy (M3)" {
    style.font-color: "${colors.stroke_m3}"
  }
  l4: "Green: Failure Detection (M4)" {
    style.font-color: "${colors.stroke_m4}"
  }
  l5: "Orange: Testing (M5)" {
    style.font-color: "${colors.stroke_m5}"
  }
}