layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    free: "#22C55E"
    pointer: "#F97316"
    mutex: "#EC4899"
    padding: "#6B7280"
  }
}

direction: right

title: {
  shape: text
  label: |'md
    # Module Architecture: Peer Management
    ### Thread-safe membership layer for gossip protocol (TDD Spec M1-01)
  '|
  near: top-center
}

# ---------------------------------------------------------------------------------------
# PeerList: Main Management Object
# ---------------------------------------------------------------------------------------
PeerList: {
  style: {
    fill: "${colors.data}"
    stroke: "#1E40AF"
    stroke-width: 3
    font-color: white
    border-radius: 8
  }
  
  header: {
    label: |'md
      **PeerList**
      `*membership.PeerList`
      `sizeof=72 bytes (base)`
    '|
    style: {
      fill: "${colors.header}"
      font-color: white
      stroke: "#6D28D9"
    }
    shape: rectangle
    width: 320
  }

  fields: {
    shape: rectangle
    style: {
      fill: "#EFF6FF"
      stroke: "#BFDBFE"
      font-color: "#1E3A8A"
    }
    width: 320

    mu: |'md
      **00: mu** `sync.RWMutex` (24B)
      *Protects concurrent map/slice access*
    '|
    peers: |'md
      **24: peers** `map[string]*Peer` (8B)
      *Key: Peer UUID string*
    '|
    selfID: |'md
      **32: selfID** `string` (16B)
      *Local node identity*
    '|
    deadTTL: |'md
      **48: deadTTL** `time.Duration` (8B)
      *Reaping threshold*
    '|
    padding: |'md
      **56: reserved** (16B)
      *Cache line alignment padding*
    '|
    padding.style.fill: "${colors.padding}"
  }

  methods: {
    shape: rectangle
    style: {
      fill: "#F0FDF4"
      stroke: "#86EFAC"
      font-color: "#166534"
    }
    width: 320
    
    m1: "`+ AddPeer(p *Peer) bool`"
    m2: "`+ GetRandomPeers(k int) []*Peer`"
    m3: "`+ SetState(id string, s PeerState)`"
    m4: "`+ ReapDeadPeers() []string`"
    m5: "`+ CreateDigest() []PeerDigest`"
  }
}

# ---------------------------------------------------------------------------------------
# Config: Initialization Parameters
# ---------------------------------------------------------------------------------------
Config: {
  style: {
    fill: "${colors.data}"
    stroke: "#1E40AF"
    stroke-width: 2
    font-color: white
    border-radius: 8
  }
  header: {
    label: |'md
      **Config**
      `membership.Config`
    '|
    style: {
      fill: "${colors.header}"
      font-color: white
      stroke: "#6D28D9"
    }
    shape: rectangle
    width: 220
  }
  params: {
    style.fill: "#EFF6FF"
    style.font-color: "#1E3A8A"
    f1: "`SelfID string`"
    f2: "`DeadTTL Duration`"
  }
}

# ---------------------------------------------------------------------------------------
# Peer: Individual Node Record (Memory Layout Detail)
# ---------------------------------------------------------------------------------------
Peer: {
  style: {
    fill: "${colors.data}"
    stroke: "#1E40AF"
    stroke-width: 3
    font-color: white
    border-radius: 8
  }
  header: {
    label: |'md
      **Peer Struct**
      `*membership.Peer`
      `sizeof=120 bytes`
    '|
    style: {
      fill: "${colors.header}"
      font-color: white
      stroke: "#6D28D9"
    }
    shape: rectangle
    width: 320
  }
  mem_layout: {
    shape: rectangle
    style.fill: "#EFF6FF"
    style.font-color: "#1E3A8A"
    
    id: "00: ID (string) [16B]"
    addr: "16: Address (string) [16B]"
    port: "32: Port (int) [8B]"
    state: "40: State (PeerState) [1B]"
    pad: "41: Alignment Padding [7B]"
    inc: "48: Incarnation (uint64) [8B]"
    seen: "56: LastSeen (Time) [24B]"
    changed: "80: StateChanged (Time) [24B]"
    checksum: "104: Reserved/CRC [16B]"
    
    pad.style.fill: "${colors.padding}"
    checksum.style.fill: "${colors.padding}"
  }
}

# ---------------------------------------------------------------------------------------
# PeerState: Typed Enumeration
# ---------------------------------------------------------------------------------------
PeerState: {
  style: {
    fill: "${colors.free}"
    stroke: "#15803D"
    stroke-width: 2
    font-color: white
    border-radius: 8
  }
  header: {
    label: |'md
      **PeerState**
      `uint8`
    '|
    style: {
      fill: "${colors.header}"
      font-color: white
      stroke: "#6D28D9"
    }
    shape: rectangle
  }
  enum: {
    style.fill: "#F0FDF4"
    style.font-color: "#166534"
    v0: "ALIVE (0)"
    v1: "SUSPECT (1)"
    v2: "DEAD (2)"
    v3: "LEFT (3)"
  }
}

# ---------------------------------------------------------------------------------------
# PeerDigest: Wire Protocol Format
# ---------------------------------------------------------------------------------------
PeerDigest: {
  style: {
    fill: "${colors.pointer}"
    stroke: "#C2410C"
    stroke-width: 2
    font-color: white
    border-radius: 8
  }
  header: {
    label: |'md
      **PeerDigest**
      `protocol.PeerDigest`
    '|
    style: {
      fill: "${colors.header}"
      font-color: white
      stroke: "#6D28D9"
    }
    shape: rectangle
  }
  fields: {
    style.fill: "#FFF7ED"
    style.font-color: "#9A3412"
    f1: "ID / Addr / Port"
    f2: "State / Incarnation"
  }
}

# ---------------------------------------------------------------------------------------
# Annotations and Meta-Information
# ---------------------------------------------------------------------------------------
state_machine: {
  label: |'md
    ## State Transitions
    ALIVE ──timeout──> SUSPECT
      ▲                  │
      │ refutation       │ timer
      └──────────────────┘
                         │
                         ▼
                       DEAD ──TTL──> [reaped]
  '|
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#E5E7EB"
    font: mono
    font-size: 14
  }
}

invariants: {
  label: |'md
    ## Key Invariants
    1. **No self-gossip**: `selfID` excluded from digests
    2. **Monotonic**: Incarnation resolution on conflict
    3. **Thread-safety**: Every public method locks `mu`
  '|
  near: top-right
  shape: rectangle
  style: {
    fill: "#FEF3C7"
    stroke: "#F59E0B"
    font-color: "#92400E"
    border-radius: 10
  }
}

lock_behavior: {
  label: |'md
    ## Concurrent Performance
    | Operation | Lock Type | Complexity |
    | :--- | :--- | :--- |
    | GetRandom | RLock | O(N) |
    | AddPeer | Lock | O(1) |
    | Reap | Lock | O(N) |
    | CreateDigest | RLock | O(N) |
  '|
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#F3E8FF"
    stroke: "#A855F7"
    font-color: "#6B21A8"
    border-radius: 10
  }
}

# ---------------------------------------------------------------------------------------
# Relationships
# ---------------------------------------------------------------------------------------
Config -> PeerList: "initializes" {
  style: {
    stroke: "${colors.mutex}"
    stroke-dash: 3
    stroke-width: 2
  }
}

PeerList.fields.peers -> Peer: "manages" {
  style: {
    stroke: "${colors.data}"
    stroke-width: 2
  }
  target-arrowhead.shape: triangle
}

Peer.mem_layout.state -> PeerState: "type" {
  style: {
    stroke: "${colors.free}"
    stroke-dash: 2
    stroke-width: 2
  }
}

PeerList.methods.m5 -> PeerDigest: "serializes" {
  style: {
    stroke: "${colors.pointer}"
    stroke-dash: 3
    stroke-width: 2
  }
}