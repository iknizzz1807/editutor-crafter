vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # M1: Seed Node Bootstrap Sequence
| {near: top-center}
direction: right
new_node: "New Node\n(joining)" {
  shape: person
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.font-color: "#1B5E20"
}
seed_node: "Seed Node\n(known address)" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.font-color: "#0D47A1"
}
existing_cluster: "Existing Cluster\n(other nodes)" {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  style.font-color: "#E65100"
  style.stroke-dash: 3
}
step1: "1. Contact Seed" {
  shape: text
  style.font-size: 12
  style.bold: true
}
step2: "2. JOIN Request" {
  shape: text
  style.font-size: 12
  style.bold: true
}
step3: "3. Peer List Response" {
  shape: text
  style.font-size: 12
  style.bold: true
}
step4: "4. Initialize Local View" {
  shape: text
  style.font-size: 12
  style.bold: true
}
step5: "5. Gossip Announcement" {
  shape: text
  style.font-size: 12
  style.bold: true
}
step6: "6. O(log N) Convergence" {
  shape: text
  style.font-size: 12
  style.bold: true
}
new_node -> step1: ""
step1 -> seed_node: "UDP packet"
new_node -> step2: ""
step2 -> seed_node: |md
  **JOIN**\n
  NodeID: new-node-id\n
  Address: 10.0.0.5\n
  Port: 7946\n
  Incarnation: 1
|
seed_node -> step3: ""
step3 -> new_node: |md
  **ACK + SYNC**\n
  Peer List:\n
  • seed (ALIVE, inc=1)\n
  • node-a (ALIVE, inc=3)\n
  • node-b (ALIVE, inc=2)\n
  • node-c (ALIVE, inc=1)
|
new_node -> step4: ""
step4 -> new_node: "Initialize\nPeerList\nfrom response"
new_node -> step5: ""
step5 -> existing_cluster: "Gossip rounds\nspread new-node\nmembership"
existing_cluster -> step6: ""
step6 -> existing_cluster: |md
  **All nodes converge**\n
  Expected rounds: ⌈log₃(N)⌉\n
  For N=10: ~3 rounds
|
seed_node.style.fill: "#BBDEFB"
existing_cluster.style.fill: "#FFE0B2"
step1.near: top-center
step2.near: top-center
step3.near: top-center
step4.near: top-center
step5.near: top-center
step6.near: top-center