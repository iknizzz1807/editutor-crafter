vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # Memory Layout: Peer Struct
  **Total Size: 112 bytes (1.75 cache lines)**
|| {near: top-center}

# Growth Direction Indicator
growth_arrow: {
  near: center-left
  label: ||md
    ↑ **Lower Addresses** (0x00)
    ↓ **Higher Addresses** (0x70)
  ||
  style.fill: transparent
  style.stroke-width: 0
  style.font-color: "#2C3E50"
}

# Main memory layout container
memory_layout: {
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDC3C7"
    stroke-width: 2
  }

  header: {
    shape: rectangle
    label: "Struct Definition: Peer (64-bit Architecture)"
    style: {
      fill: "#9B59B6"
      stroke: "#7D3C98"
      font-color: white
      bold: true
    }
  }

  offset_legend: "Byte Offset [Hex] | Field Representation | Size [Dec]"

  # --- CACHE LINE 0 (0-63) ---
  
  field_id: {
    label: ||md
      **0x00 | ID (string)**
      *Data Ptr (8B) + Len (8B)*
    ||
    width: 450
    style: {
      fill: "#3498DB"
      stroke: "#2980B9"
      font-color: white
    }
  }

  field_address: {
    label: ||md
      **0x10 | Address (string)**
      *Data Ptr (8B) + Len (8B)*
    ||
    style: {
      fill: "#3498DB"
      stroke: "#2980B9"
      font-color: white
    }
  }

  row_32_47: {
    grid-columns: 2
    field_port: {
      label: "**0x20 | Port** (int64) | 8B"
      style: {
        fill: "#3498DB"
        stroke: "#2980B9"
        font-color: white
      }
    }
    field_state: {
      label: "**0x28 | State** (PeerState) | 8B"
      style: {
        fill: "#3498DB"
        stroke: "#2980B9"
        font-color: white
      }
    }
  }

  row_48_63: {
    grid-columns: 2
    field_incarnation: {
      label: "**0x30 | Incarnation** (uint64) | 8B"
      style: {
        fill: "#3498DB"
        stroke: "#2980B9"
        font-color: white
      }
    }
    padding1: {
      label: "**0x38 | Padding** | 8B"
      style: {
        fill: "#95A5A6"
        stroke: "#7F8C8D"
        font-color: white
      }
    }
  }

  # Visual boundary for Cache Line
  cache_line_0_boundary: "---------------- 64B CACHE LINE BOUNDARY ----------------" {
    style: {
      stroke: "#E74C3C"
      stroke-dash: 4
      stroke-width: 2
      font-color: "#E74C3C"
      bold: true
    }
  }

  # --- CACHE LINE 1 (64-127) ---

  field_lastseen: {
    label: ||md
      **0x40 | LastSeen (time.Time)**
      *Wall (8B) + Ext (8B) + Loc Ptr (8B)*
    ||
    style: {
      fill: "#E67E22"
      stroke: "#D35400"
      font-color: white
    }
  }

  field_statechanged: {
    label: ||md
      **0x58 | StateChanged (time.Time)**
      *Wall (8B) + Ext (8B) + Loc Ptr (8B)*
    ||
    style: {
      fill: "#E67E22"
      stroke: "#D35400"
      font-color: white
    }
  }

  padding_end: {
    label: "**0x70 | Final Size Boundary**"
    style: {
      fill: "#95A5A6"
      stroke: "#7F8C8D"
      font-color: white
    }
  }

  # Sequence flow for structural alignment
  header -> offset_legend -> field_id -> field_address -> row_32_47 -> row_48_63 -> cache_line_0_boundary -> field_lastseen -> field_statechanged -> padding_end: {
    style.stroke: "transparent"
  }
}

# Documentation / Metadata section
metadata: {
  near: center-right
  grid-columns: 1
  
  technical_notes: {
    label: ||md
      ### Technical Implementation Notes
      - **String Header:** 16 bytes (pointer + length).
      - **time.Time:** 24 bytes (wall clock + extension + location pointer).
      - **Alignment:** Struct is 8-byte aligned on 64-bit systems.
      - **False Sharing:** `Incarnation` and `LastSeen` reside on different cache lines.
    ||
    style.fill: "#FDFEFE"
  }

  legend: {
    title: "### Color Legend"
    legend_data: "Data Fields (Scalar/Struct)" { style.fill: "#3498DB"; style.font-color: white }
    legend_pointers: "Complex Types (time.Time)" { style.fill: "#E67E22"; style.font-color: white }
    legend_padding: "Padding (Alignment)" { style.fill: "#95A5A6"; style.font-color: white }
    
    title -> legend_data -> legend_pointers -> legend_padding: {style.stroke: "transparent"}
  }

  size_summary: {
    label: ||md
      ### Size Analysis
      | Field Group | Size | Cumulative |
      | :--- | :--- | :--- |
      | Strings (2) | 32B | 32B |
      | Scalars (3) | 24B | 56B |
      | Alignment Pad | 8B | 64B |
      | time.Time (2) | 48B | 112B |
      | **Total** | **112B** | **1.75 L** |
    ||
    style.fill: "#EAEDED"
  }
}