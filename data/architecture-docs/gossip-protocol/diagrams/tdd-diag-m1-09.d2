direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F97316"
    changed: "#EF4444"
    alive: "#22C55E"
    left: "#F59E0B"
    background: "#F9FAFB"
    border: "#E5E7EB"
    padding: "#6B7280"
  }
}

classes: {
  node_base: {
    shape: rectangle
    width: 240
    height: 160
    style: {
      fill: white
      stroke: "#374151"
      stroke-width: 2
      border-radius: 8
    }
  }
  sequence_label: {
    shape: text
    style: {
      font-size: 16
      font: mono
      bold: true
      font-color: "#4B5563"
    }
  }
  message: {
    style: {
      stroke-width: 2
      animated: true
    }
  }
  leave_msg: {
    label: "UDP: LEAVE (inc: N+1)"
    style: {
      stroke: "#F59E0B"
      stroke-width: 3
      font-color: "#F59E0B"
      bold: true
    }
  }
  alive_node: {
    style: {
      fill: "#DCFCE7"
      stroke: "#22C55E"
    }
  }
  leaving_node: {
    style: {
      fill: "#FEF3C7"
      stroke: "#F59E0B"
      stroke-width: 4
    }
  }
  updated_node: {
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
    }
  }
  state_changed: {
    style: {
      stroke: "#EF4444"
      stroke-width: 5
      shadow: true
    }
  }
}

title: {
  shape: text
  near: top-center
  label: |md
    # Data Flow: Graceful Leave Protocol
    Dissemination and state transitions for node departure. 
    Engineers: Implement byte-ordering as Big-Endian per wire format spec.
  |
  style.font-size: 28
}

# --- PHASE 1: INITIATION ---
Phase_1: {
  label: "PHASE 1: Initiation (Node A increments incarnation and broadcasts LEAVE)"
  style: {
    fill: "#F9FAFB"
    stroke: "#E5E7EB"
    stroke-width: 2
    border-radius: 12
  }

  content: {
    grid-columns: 4
    grid-gap: 60
    style.stroke-width: 0

    Node_A: {
      class: [node_base; leaving_node]
      label: |md
        **Node A**
        ID: `0x41`
        ---
        inc: **6** (N+1)
        state: **LEFT**
      |
    }
    Node_B: {
      class: [node_base; alive_node]
      label: |md
        **Node B**
        ID: `0x42`
        ---
        inc: 5
        state: ALIVE
      |
    }
    Node_C: {
      class: [node_base; alive_node]
      label: |md
        **Node C**
        ID: `0x43`
        ---
        inc: 5
        state: ALIVE
      |
    }
    Node_D: {
      class: [node_base; alive_node]
      label: |md
        **Node D**
        ID: `0x44`
        ---
        inc: 5
        state: ALIVE
      |
    }
    
    Node_A -> Node_B: { class: [message; leave_msg] }
    Node_A -> Node_C: { class: [message; leave_msg] }
    Node_A -> Node_D: { class: [message; leave_msg] }
  }
}

# --- PHASE 2: IMMEDIATE MARK ---
Phase_2: {
  label: "PHASE 2: Mark & Disseminate (Peers merge LEFT state and begin gossip)"
  style: {
    fill: "#F9FAFB"
    stroke: "#E5E7EB"
    stroke-width: 2
    border-radius: 12
  }
  
  content: {
    grid-columns: 4
    grid-gap: 60
    style.stroke-width: 0

    Node_A_2: {
      class: [node_base; leaving_node]
      style.opacity: 0.4
      label: |md
        **Node A**
        (Silent/Dropped)
        ---
        inc: 6
        state: LEFT
      |
    }
    Node_B_2: {
      class: [node_base; updated_node; state_changed]
      label: |md
        **Node B**
        ---
        inc: **6**
        state: **LEFT**
      |
    }
    Node_C_2: {
      class: [node_base; updated_node; state_changed]
      label: |md
        **Node C**
        ---
        inc: **6**
        state: **LEFT**
      |
    }
    Node_D_2: {
      class: [node_base; updated_node; state_changed]
      label: |md
        **Node D**
        ---
        inc: **6**
        state: **LEFT**
      |
    }

    Node_B_2 <-> Node_C_2: {
      label: "Gossip Piggyback (inc=6, state=LEFT)"
      style: {
        stroke: "#3B82F6"
        stroke-dash: 3
        animated: true
        font-color: "#3B82F6"
      }
    }
  }
}

# --- WIRE FORMAT & DATA STRUCTURES ---
Protocol_Specs: {
  grid-columns: 2
  grid-gap: 40
  style.stroke-width: 0
  
  Wire_Header: {
    shape: text
    label: ||md
      ### LeaveBody Wire Format
      UDP Payload Structure (Binary)
      *Fields: Offset | Field Description | Size*
    ||
  }
  
  empty_space: "" { style.opacity: 0 }

  Wire_Format: {
    shape: sql_table
    style.fill: "#F3E8FF"
    style.stroke: "#8B5CF6"
    
    "0x00": "Message Type (0x02 = LEAVE)" {constraint: "1 Byte"}
    "0x01": "Padding / Reserved" {constraint: "1 Byte"}
    "0x02": "Incarnation (Uint64, BE)" {constraint: "8 Bytes"}
    "0x0A": "NodeID Length (Uint16)" {constraint: "2 Bytes"}
    "0x0C": "NodeID String (UTF-8)" {constraint: "Variable"}
    "0x...": "Optional Metadata KV" {constraint: "Variable"}
  }

  Invariants: {
    style: {
      fill: "#ECFDF5"
      stroke: "#22C55E"
      border-radius: 8
    }
    label: |md
      ### Implementation Invariants
      - **Pre-emptive Inc**: Node must increment local incarnation **before** sending.
      - **Bypass Suspect**: LEFT signals are immediate. Do not initiate ping-retry logic.
      - **Ack-less**: LEAVE is a best-effort UDP broadcast/gossip; no direct ACK expected.
      - **Cleanup**: Purge node from active routing table after `2 * T_gossip`.
      - **Conflict**: If Peer sees `inc=6, ALIVE` and receives `inc=6, LEFT`, **LEFT wins**.
    |
  }
}

# --- LEGEND ---
Legend: {
  near: bottom-right
  style: {
    fill: white
    stroke: "#9CA3AF"
    border-radius: 8
  }
  label: |md
    **Visual Reference**
    - 🟢 **ALIVE**: Healthy cluster member
    - 🟡 **LEFT**: Departure initiated by Node A
    - 🔵 **UPDATED**: Peer has merged the LEFT event
    - 🔴 **CHANGED**: State transition in current phase
    - ⚡ **ANIMATED**: Network transmission in progress
  |
}

# Layout Connections
Phase_1 -> Phase_2: "T + 100ms (Dissemination Window)" {
  style: {
    stroke-width: 6
    stroke: "#94A3B8"
    font-size: 18
    bold: true
  }
}

Phase_2 -> Protocol_Specs: "Binary Specification" {
  style: {
    stroke-dash: 5
    stroke: "#8B5CF6"
  }
}

# Final Glob for consistency
***.style.font: mono