vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Layout: GossipBody Message
  **Total Size: 22+ bytes (variable)**
| {near: top-center}
direction: right
header: "Message Header" {
  style.fill: "#9B7ED9"
  style.stroke: "#6B4F9E"
  style.font-color: white
  style.border-radius: 4
  header_layout: {
    grid-columns: 1
    grid-gap: 0
    h_type: "Type (1B)" {
      style.fill: "#C4B0E8"
      style.stroke: "#9B7ED9"
      style.font: mono
      style.bold: true
      width: 120
    }
    h_nodeidlen: "NodeIDLen (1B)" {
      style.fill: "#C4B0E8"
      style.stroke: "#9B7ED9"
      style.font: mono
      style.bold: true
      width: 120
    }
    h_nodeid: "NodeID (N bytes)" {
      style.fill: "#D4C6F0"
      style.stroke: "#9B7ED9"
      style.font: mono
      style.bold: true
      width: 120
    }
    h_timestamp: "Timestamp (8B)" {
      style.fill: "#C4B0E8"
      style.stroke: "#9B7ED9"
      style.font: mono
      style.bold: true
      width: 120
    }
  }
}
body: "Message Body (GossipBody)" {
  style.fill: "#4A90D9"
  style.stroke: "#2E5C8A"
  style.font-color: white
  style.border-radius: 4
  body_layout: {
    grid-columns: 1
    grid-gap: 0
    b_entrycount: "EntryCount (4B)" {
      style.fill: "#7AB3E8"
      style.stroke: "#4A90D9"
      style.font: mono
      style.bold: true
      width: 140
    }
    b_entries: "Entries (variable)" {
      style.fill: "#9AC4EE"
      style.stroke: "#4A90D9"
      style.font: mono
      style.bold: true
      width: 140
      style.stroke-dash: 3
    }
    b_ttl: "TTL (1B)" {
      style.fill: "#7AB3E8"
      style.stroke: "#4A90D9"
      style.font: mono
      style.bold: true
      width: 140
    }
    b_originid: "OriginID (variable)" {
      style.fill: "#9AC4EE"
      style.stroke: "#4A90D9"
      style.font: mono
      style.bold: true
      width: 140
      style.stroke-dash: 3
    }
    b_originclock: "OriginClock (8B)" {
      style.fill: "#7AB3E8"
      style.stroke: "#4A90D9"
      style.font: mono
      style.bold: true
      width: 140
    }
  }
}
offset_col: "Byte Offsets" {
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  style.border-radius: 4
  offset_layout: {
    grid-columns: 1
    grid-gap: 0
    o1: "0x00" {style.font: mono; style.bold: true; width: 80}
    o2: "0x01" {style.font: mono; style.bold: true; width: 80}
    o3: "0x02" {style.font: mono; style.bold: true; width: 80}
    o4: "0x02+N" {style.font: mono; style.bold: true; width: 80}
    o5: "0x0A+N" {style.font: mono; style.bold: true; width: 80}
    o6: "0x0E+N+M" {style.font: mono; style.bold: true; width: 80}
    o7: "var" {style.font: mono; style.bold: true; width: 80}
    o8: "var+1" {style.font: mono; style.bold: true; width: 80}
    o9: "EOF-8" {style.font: mono; style.bold: true; width: 80}
  }
}
size_col: "Field Sizes" {
  style.fill: "#E8F5E9"
  style.stroke: "#81C784"
  style.border-radius: 4
  size_layout: {
    grid-columns: 1
    grid-gap: 0
    s1: "1 byte" {style.font: mono; width: 80}
    s2: "1 byte" {style.font: mono; width: 80}
    s3: "N bytes" {style.font: mono; width: 80}
    s4: "8 bytes" {style.font: mono; width: 80}
    s5: "4 bytes" {style.font: mono; width: 80}
    s6: "M bytes" {style.font: mono; width: 80}
    s7: "1 byte" {style.font: mono; width: 80}
    s8: "K bytes" {style.font: mono; width: 80}
    s9: "8 bytes" {style.font: mono; width: 80}
  }
}
offset_col -> header: "" {style.opacity: 0}
header -> body: "" {style.opacity: 0}
body -> size_col: "" {style.opacity: 0}
legend: "Legend" {
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  style.border-radius: 4
  near: bottom-center
  leg_layout: {
    grid-columns: 3
    grid-gap: 10
    l1: "■ Header" {
      style.fill: "#9B7ED9"
      style.font-color: white
      style.border-radius: 2
    }
    l2: "■ Body" {
      style.fill: "#4A90D9"
      style.font-color: white
      style.border-radius: 2
    }
    l3: "■ Variable Size" {
      style.fill: "#9AC4EE"
      style.font-color: "#2E5C8A"
      style.border-radius: 2
      style.stroke-dash: 3
    }
  }
}
notes: |md
  **Wire Format Notes:**
  - `Type`: Message type discriminator (0x10 for GOSSIP)
  - `NodeIDLen`: Length prefix for sender's node ID (uint8)
  - `NodeID`: UTF-8 encoded node identifier (variable, max 255 bytes)
  - `Timestamp`: Unix nanoseconds, big-endian (int64)
  - `EntryCount`: Number of EntryDigest entries (uint32, big-endian)
  - `Entries`: Concatenated EntryDigest structures
  - `TTL`: Remaining hop count, decremented on forward (uint8)
  - `OriginID`: Original message creator's node ID (length-prefixed)
  - `OriginClock`: Origin's Lamport clock for deduplication (uint64, big-endian)
| {
  near: bottom-center
  style.fill: "#FFF8E1"
  style.stroke: "#FFB300"
  style.border-radius: 4
}