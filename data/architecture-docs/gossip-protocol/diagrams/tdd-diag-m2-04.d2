direction: right
title: |md
  # State Machine: Message Processing
  Gossip message lifecycle with version checking and TTL-bounded forwarding
| {near: top-center}
# State definitions
ReceiveMessage: {
  label: "Receive Message\n\n• Decode protocol message\n• Extract GossipBody\n• Record receive timestamp"
  shape: rectangle
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
}
CheckDuplicate: {
  label: "Check Duplicate\n\n• Compute MessageID\n  (OriginID || OriginClock)\n• Query SeenCache\n• Track: cache hits/misses"
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}
CheckVersion: {
  label: "Check Version\n\n• For each EntryDigest:\n  - Compare remote.Version\n    vs local.Version\n  - Apply tiebreaker if equal"
  shape: diamond
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
ApplyUpdate: {
  label: "Apply Update\n\n• Store.Apply(entry)\n• Update Lamport clock\n• Increment accepted count\n• Update lastSent watermark"
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.bold: true
}
CheckTTL: {
  label: "Check TTL\n\n• Read body.TTL\n• TTL > 0: forward allowed\n• TTL = 0: stop propagation"
  shape: diamond
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}
ForwardMessage: {
  label: "Forward Message\n\n• TTL = TTL - 1\n• Select fanout random peers\n• Preserve OriginID, OriginClock\n• Re-encode and send"
  shape: rectangle
  style.fill: "#E1BEE7"
  style.stroke: "#7B1FA2"
}
# Terminal states
Dropped: {
  label: "DROPPED\n\n(Duplicate detected)"
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
}
Rejected: {
  label: "REJECTED\n\n(Stale version)"
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
}
Complete: {
  label: "COMPLETE\n\n(Message processed,\nno forwarding)"
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
# Illegal state
ILLEGAL_ApplyNoCheck: {
  label: "ILLEGAL\n\nApply without\nversion check"
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#B71C1C"
  style.stroke-dash: 5
  style.bold: true
}
# Transitions
ReceiveMessage -> CheckDuplicate: "Decode success" {
  style.stroke: "#2E86AB"
}
CheckDuplicate -> Dropped: "SeenCache.Seen(id)\n= true" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
}
CheckDuplicate -> CheckVersion: "SeenCache.Seen(id)\n= false\n\nAdd to cache" {
  style.stroke: "#2E7D32"
}
CheckVersion -> ApplyUpdate: "remote.Version > local.Version\nOR\n(remote.Version == local.Version\n AND remote.NodeID > local.NodeID)" {
  style.stroke: "#2E7D32"
  style.bold: true
}
CheckVersion -> Rejected: "remote.Version < local.Version\nOR\n(remote.Version == local.Version\n AND remote.NodeID <= local.NodeID)" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
ApplyUpdate -> CheckTTL: "Update applied\n\n• clock = max(clock, remote.Version)\n• accepted++" {
  style.stroke: "#7B1FA2"
}
CheckTTL -> ForwardMessage: "TTL > 0" {
  style.stroke: "#7B1FA2"
}
CheckTTL -> Complete: "TTL = 0\n\n(Hop limit reached)" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}
ForwardMessage -> Complete: "Forwarded to\nfanout peers" {
  style.stroke: "#1565C0"
  style.animated: true
}
# Illegal transition (dashed red)
ReceiveMessage -> ILLEGAL_ApplyNoCheck: "ILLEGAL:\nSkip version check" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 5
  label: "ILLEGAL"
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  legal: "Legal transition"
  legal.shape: text
  legal.style.font-color: "#2E7D32"
  illegal: "ILLEGAL transition (must reject)"
  illegal.shape: text
  illegal.style.font-color: "#B71C1C"
  illegal.style.bold: true
  terminal: "Terminal state"
  terminal.shape: text
  terminal.style.font-color: "#1565C0"
}
legend.near: bottom-right