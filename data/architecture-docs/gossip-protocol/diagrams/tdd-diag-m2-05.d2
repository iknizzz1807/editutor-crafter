direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# ALGORITHM STEPS: LAMPORT CLOCK UPDATE
## Logical Clock Synchronization and Partial Ordering Invariants
'| {
  near: top-center
}

# --- STAGE 1: PRE-CONDITION ---
before: {
  label: "STATE: [T0] INITIAL"
  style: {
    fill: "#F8F9FA"
    stroke: "#666666"
    stroke-width: 2
    stroke-dash: 5
  }

  local_clock: {
    shape: rectangle
    label: |'md
    ### Register: L_clock
    **Value: 5**
    *Type: Scalar Integer*
    '|
    style: {
      fill: "#FFE4B5"
      stroke: "#D2691E"
      stroke-width: 2
      font: mono
      shadow: true
    }
  }
}

# --- STAGE 2: EXTERNAL EVENT ---
receive: {
  label: "EVENT: RX_PACKET"
  style: {
    fill: "#E1F5FE"
    stroke: "#0288D1"
    stroke-width: 2
  }

  msg: {
    shape: rectangle
    label: |'md
    ### Inbound Message (m)
    **m.timestamp: 8**
    *Source: Node_B*
    '|
    style: {
      fill: "#B0E0E6"
      stroke: "#4682B4"
      stroke-width: 2
      font: mono
    }
  }
}

# --- STAGE 3: ALGORITHM LOGIC ---
operation: {
  label: "PROCEDURE: UPDATE_CLOCK(m)"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }

  step1: {
    label: |'md
    **STEP 1: MAX COMPARISON**
    `observed (m) = 8`
    `internal (L) = 5`
    `temp = max(5, 8) = 8`
    '|
    style: {
      fill: "#98FB98"
      stroke: "#32CD32"
      stroke-width: 2
      font: mono
    }
  }

  step2: {
    label: |'md
    **STEP 2: MONOTONIC STEP**
    `L_new = temp + 1`
    **L_new = 9**
    '|
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      stroke-width: 2
      font: mono
      bold: true
    }
  }

  step1 -> step2: "Atomic Seq" {
    style: {
      stroke: "#228B22"
      stroke-width: 2
      bold: true
    }
  }
}

# --- STAGE 4: POST-CONDITION ---
after: {
  label: "STATE: [T1] SYNCHRONIZED"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
  }

  result: {
    shape: rectangle
    label: |'md
    ### Register: L_clock'
    **Value: 9**
    **Status: UPDATED**
    '|
    style: {
      fill: "#FFB6C1"
      stroke: "#DC143C"
      stroke-width: 3
      font: mono
      bold: true
      shadow: true
    }
  }
}

# --- DATA FLOW CONNECTIONS ---
before.local_clock -> receive.msg: "Network Interrupt" {
  style: {
    stroke: "#0288D1"
    stroke-width: 2
    animated: true
  }
}

receive.msg -> operation.step1: "Pass counter 'm'" {
  style: {
    stroke: "#0288D1"
    stroke-width: 2
  }
}

operation.step2 -> after.result: "Commit Write" {
  style: {
    stroke: "#DC143C"
    stroke-width: 3
    animated: true
  }
}

# --- ALGORITHM SPECIFICATION PANEL ---
rules: {
  near: bottom-center
  shape: rectangle
  label: |'md
### Lamport Synchronization Reference
| Event Context | Algorithm Implementation |
| :--- | :--- |
| **Local Event** | `L = L + 1` (Scalar increment) |
| **Send Event** | `L = L + 1`; `msg.t = L`; `send(msg)` |
| **Receive Event** | `L = max(L, msg.t) + 1` |

**Invariant:** If event `a` happened-before `b` (`a -> b`), then `C(a) < C(b)`.
This mechanism ensures causality is preserved across distributed nodes.
'|
  style: {
    fill: "#FAFAFA"
    stroke: "#424242"
    stroke-width: 1
    font-size: 14
  }
}