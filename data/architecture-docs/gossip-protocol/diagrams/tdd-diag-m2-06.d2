layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
  colors: {
    infected: "#E53935"
    susceptible: "#42A5F5"
    highlight: "#FFB300"
    new_infection: "#D32F2F"
    header: "#673AB7"
    padding: "#90A4AE"
    pointer: "#FB8C00"
  }
}

# -----------------------------------------------------------------------------
# GLOBAL TITLE
# -----------------------------------------------------------------------------
title: |md
  # EPIDEMIC SPREADING MODEL (SI-GOSSIP)
  **Gossip Protocol Convergence & Mathematical Analysis**
  *Intel Manual Reference: DS-GOSSIP-99-REV2*
|
title.near: top-center
title.style.font-size: 28
title.style.bold: true

# -----------------------------------------------------------------------------
# CLASSES & STYLES
# -----------------------------------------------------------------------------
classes: {
  node: {
    shape: circle
    width: 70
    height: 70
    style: {
      stroke-width: 2
      font-size: 16
      bold: true
      shadow: true
    }
  }
  susceptible: {
    style: {
      fill: "#42A5F5"
      stroke: "#1976D2"
      font-color: white
    }
  }
  infected: {
    style: {
      fill: "#E53935"
      stroke: "#B71C1C"
      font-color: white
    }
  }
  newly_infected: {
    style: {
      fill: "#D32F2F"
      stroke: "#FFD600"
      stroke-width: 6
      font-color: white
      bold: true
    }
  }
  container_style: {
    style: {
      stroke: "#263238"
      stroke-width: 3
      fill: "#FAFAFA"
      border-radius: 12
      shadow: true
    }
  }
  formula_box: {
    shape: rectangle
    style: {
      fill: "#F1F8E9"
      stroke: "#558B2F"
      stroke-width: 1
      border-radius: 8
    }
  }
}

# -----------------------------------------------------------------------------
# MEMORY LAYOUT: NODE_CONTROL_BLOCK (NCB)
# -----------------------------------------------------------------------------
NCB_Memory: {
  label: "NODE_CONTROL_BLOCK (NCB) - 64B Cache Line Alignment"
  
  Header: {
    label: "0x00 | NCB_HEADER [struct]"
    style.fill: "#673AB7"
    style.font-color: white
  }

  Body: {
    direction: down
    
    row1: "0x04 | NODE_ID [uint32] | size: 4B" {
      style.fill: "#BBDEFB"
    }
    row2: "0x08 | STATUS_FLAGS (Bit 0: INF) | size: 1B" {
      style.fill: "#E53935"
      style.font-color: white
    }
    row3: "0x09 | ROUND_TIMESTAMP [uint24] | size: 3B" {
      style.fill: "#BBDEFB"
    }
    row4: "0x0C | NEIGHBOR_PTR_LIST [offset] | size: 4B" {
      style.fill: "#FB8C00"
    }
    padding: "0x10 | RESERVED / ALIGNMENT_PAD | size: 48B" {
      style.fill: "#90A4AE"
      style.stroke-dash: 5
    }
  }
  
  style.stroke-dash: 5
  style.stroke: "#263238"
}
NCB_Memory.near: top-left

# -----------------------------------------------------------------------------
# ALGORITHM STATE TRANSITIONS
# -----------------------------------------------------------------------------
Algorithm: {
  direction: right

  round0: {
    label: "ROUND 0: PATIENT ZERO (t=0)"
    class: container_style
    
    n0_a: "A" { class: [node; infected] }
    n0_b: "B" { class: [node; susceptible] }
    n0_c: "C" { class: [node; susceptible] }
    n0_d: "D" { class: [node; susceptible] }
    n0_e: "E" { class: [node; susceptible] }
    n0_f: "F" { class: [node; susceptible] }

    n0_a -> n0_b: "target_1" { style.stroke: "#FFB300"; style.stroke-dash: 3 }
    n0_a -> n0_c: "target_2" { style.stroke: "#FFB300"; style.stroke-dash: 3 }
    n0_a -> n0_d: "target_3" { style.stroke: "#FFB300"; style.stroke-dash: 3 }
    
    stats: |md
      **ROUND STATS**
      - I: 1 | S: 5
      - Fanout k: 3
    |
  }

  round1: {
    label: "ROUND 1: GROWTH (t=1)"
    class: container_style
    
    n1_a: "A" { class: [node; infected] }
    n1_b: "B" { class: [node; newly_infected] }
    n1_c: "C" { class: [node; newly_infected] }
    n1_d: "D" { class: [node; newly_infected] }
    n1_e: "E" { class: [node; susceptible] }
    n1_f: "F" { class: [node; susceptible] }

    n1_b -> n1_e: "INFECT" { style.stroke: red; style.stroke-width: 4; style.animated: true }
    n1_c -> n1_f: "INFECT" { style.stroke: red; style.stroke-width: 4; style.animated: true }
    n1_d -> n1_a: "COLLISION" { style.stroke: gray; style.stroke-dash: 2; style.opacity: 0.4 }

    stats: |md
      **ROUND STATS**
      - I: 4 (Δ+3) | S: 2
      - P(Collision): ~16%
    |
  }

  round2: {
    label: "ROUND 2: TERMINATION (t=2)"
    class: container_style
    
    n2_a: "A" { class: [node; infected] }
    n2_b: "B" { class: [node; infected] }
    n2_c: "C" { class: [node; infected] }
    n2_d: "D" { class: [node; infected] }
    n2_e: "E" { class: [node; newly_infected] }
    n2_f: "F" { class: [node; newly_infected] }

    stats: |md
      **ROUND STATS**
      - I: 6 (Δ+2) | S: 0
      - Status: TERMINATED
    |
  }

  round0 -> round1: "Δt Propagation" { style.stroke-width: 3 }
  round1 -> round2: "Δt Propagation" { style.stroke-width: 3 }
}

# -----------------------------------------------------------------------------
# REFERENCE MODULES
# -----------------------------------------------------------------------------
Mathematics: {
  class: formula_box
  label: |md
    ### CONVERGENCE FORMULAE
    
    **Growth Function:**
    $I_{t+1} = I_t + I_t \cdot k \cdot \frac{N - I_t}{N}$
    
    **Network Latency (L):**
    $L \approx \log_k(N)$
    
    **Infection Probability:**
    $P(S) = (1 - \frac{k}{N})^{I_t}$
  |
}
Mathematics.near: bottom-center

SpecTable: {
  label: |md
    ### Protocol Specs
    | Parameter | Value |
    | :--- | :--- |
    | $N$ | 6 |
    | $k$ | 3 |
    | $Mode$ | SI |
    | $P_{push}$ | 1.0 |
  |
}
SpecTable.near: bottom-right

Legend: {
  s: Susceptible { class: [node; susceptible] }
  i: Infected { class: [node; infected] }
  n: New Infection { class: [node; newly_infected] }
  
  grid-columns: 1
  grid-gap: 10
}
Legend.near: outside-bottom-right