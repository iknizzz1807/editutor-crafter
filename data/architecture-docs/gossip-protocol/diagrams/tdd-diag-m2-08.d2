vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# Sequence Diagram: Gossip Protocol Message Forwarding & TTL Exhaustion
gossip_protocol: {
  shape: sequence_diagram

  # Participants / Actors
  NodeA: Node A {
    shape: person
    style: {
      fill: "#dbeafe"
      stroke: "#2563eb"
    }
  }
  NodeB: Node B {
    style: {
      fill: "#dbeafe"
      stroke: "#2563eb"
    }
  }
  NodeC: Node C {
    style: {
      fill: "#dbeafe"
      stroke: "#2563eb"
    }
  }
  NodeD: Node D {
    style: {
      fill: "#dbeafe"
      stroke: "#2563eb"
    }
  }
  NodeE: Node E {
    style: {
      fill: "#dbeafe"
      stroke: "#2563eb"
    }
  }

  # --- Chronological Execution ---

  Round_1: "Round 1: Initial Broadcast" {
    NodeA -> NodeB: "GossipMsg { TTL=4, Origin=A, Entries=[k1,v1] }" {
      style: {
        stroke: "#2563eb"
        stroke-width: 3
      }
    }
    
    NodeA."State Update" : |md
      **Message Origin**
      - TTL: 4 (Max)
      - OriginID: Node A
      - Entries: [k1:v1]
      - Local Clock: 100
    |
  }

  Round_2: "Round 2: Processing & First Forward" {
    # Spans indicate active processing time
    NodeB.processing {
      NodeB -> NodeB: "Process & Apply Entries"
      NodeB -> NodeB: "Decrement TTL (4 -> 3)"
    }
    
    NodeB -> NodeC: "Forward { TTL=3, Origin=A }" { style.stroke: "#3b82f6" }
    NodeB -> NodeD: "Forward { TTL=3, Origin=A }" { style.stroke: "#3b82f6" }
    NodeB -> NodeE: "Forward { TTL=3, Origin=A }" { style.stroke: "#3b82f6" }

    NodeB."Gossip Logic": |md
      **TTL Check**
      - New TTL: 3
      - Peer Selection: Random(C, D, E)
      - Dedup Cache: Added (A, 100)
    |
  }

  Round_3: "Round 3: Network Propagation" {
    NodeC.proc {
      NodeC -> NodeC: "TTL = 3 - 1 = 2"
    }
    NodeD.proc {
      NodeD -> NodeD: "TTL = 3 - 1 = 2"
    }
    NodeE.proc {
      NodeE -> NodeE: "TTL = 3 - 1 = 2"
    }

    NodeC -> NodeA: "Forward { TTL=2 }" { style.stroke: "#60a5fa" }
    NodeC -> NodeB: "Forward { TTL=2 }" { style.stroke: "#60a5fa" }
    NodeC -> NodeD: "Forward { TTL=2 }" { style.stroke: "#60a5fa" }
    
    NodeD -> NodeA: "Forward { TTL=2 }" { style.stroke: "#60a5fa" }
    NodeD -> NodeB: "Forward { TTL=2 }" { style.stroke: "#60a5fa" }
    NodeD -> NodeE: "Forward { TTL=2 }" { style.stroke: "#60a5fa" }

    NodeC."Note": "Propagation ongoing. Dedup will ignore redundant receipts."
  }

  Round_4: "Round 4: Approaching Limit" {
    NodeA -> NodeA: "Process receipt (TTL=2)"
    NodeA -> NodeA: "New TTL = 1"
    
    NodeA -> NodeC: "Forward { TTL=1 }" { style.stroke: "#93c5fd" }
    NodeA -> NodeD: "Forward { TTL=1 }" { style.stroke: "#93c5fd" }
    
    NodeB -> NodeE: "Forward { TTL=1 }" { style.stroke: "#93c5fd" }

    NodeA."Final Hop Warning": "TTL=1. Only one hop remaining."
  }

  Round_5: "Round 5: TTL Exhaustion (Termination)" {
    NodeC -> NodeC: "Receive { TTL=1 }"
    NodeC.drop: "TTL = 1 - 1 = 0" {
      style: {
        stroke: "#ef4444"
        fill: "#fee2e2"
      }
    }
    
    NodeC -> NodeC: "ILLEGAL: Forwarding blocked (TTL=0)" {
      style: {
        stroke: "#ef4444"
        stroke-dash: 5
      }
    }

    NodeD -> NodeD: "Receive { TTL=1 }"
    NodeD -> NodeD: "Exhausted (TTL=0)" { style.stroke: "#ef4444" }

    NodeE -> NodeE: "Receive { TTL=1 }"
    NodeE -> NodeE: "Exhausted (TTL=0)" { style.stroke: "#ef4444" }

    NodeC."Termination Rule": |md
      **Protocol Invariant**
      - If TTL <= 0:
        - Process Locally: YES
        - Re-broadcast: NO
    | {
      style: {
        fill: "#fef2f2"
        stroke: "#ef4444"
        font-color: "#b91c1c"
      }
    }
  }
}

# Global Diagram Styles
gossip_protocol.** : {
  style: {
    font: mono
  }
}

(gossip_protocol.Round_5 -> gossip_protocol.Round_5)[*].style: {
  animated: true
}