vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Bandwidth Comparison: Full State vs Delta
| {near: top-center}
direction: right
# Cluster Size 10
cluster_10: {
  label: "Cluster Size: 10 nodes"
  header: {
    grid-columns: 3
    grid-gap: 0
    metric_label: "" {style.fill: transparent}
    full_state_label: "Full State\nO(N × S)" {
      style.fill: "#E57373"
      style.stroke: "#C62828"
      style.font-color: white
      style.bold: true
    }
    delta_label: "Delta Only\nO(Δ)" {
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
  }
  bandwidth_row: {
    grid-columns: 3
    grid-gap: 0
    metric: "Bandwidth\nper round" {
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      style.bold: true
    }
    full_10: "10 × 1MB\n= 10 MB/round" {
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.font: mono
    }
    delta_10: "3 × 1KB\n= 3 KB/round" {
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.font: mono
    }
  }
  ratio_row: {
    grid-columns: 3
    grid-gap: 0
    ratio_label: "Ratio" {
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      style.bold: true
    }
    ratio_10: "3,333× more" {
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.font-color: "#B71C1C"
      style.bold: true
    }
    baseline_10: "baseline" {
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.font-color: "#1B5E20"
    }
  }
}
