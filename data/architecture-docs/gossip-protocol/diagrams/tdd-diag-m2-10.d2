vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Convergence Probability by Round
| {near: top-center}

formula_box: {
  near: top-right
  style.fill: "#F8F9FA"
  style.stroke: "#BDC3C7"
  style.border-radius: 8
  formula: |latex
    P(\text{infected}) = 1 - e^{-\frac{k \cdot t}{n}}
  |
  explanation: |md
    **Epidemic Model (SI)**
    - k = fanout (peers/round)
    - n = cluster size
    - t = number of rounds
    **Expected rounds to 99.9%:**
    - k=1: ~6.9 × n (linear)
    - k=2: ~7 rounds
    - k=3: ~5 rounds ✓
    - k=5: ~3 rounds
  |
}

legend: {
  near: bottom-center
  style.fill: transparent
  k1_legend: "k=1 (linear)" {
    style.fill: "#E74C3C"
    style.stroke: "#E74C3C"
  }
  k2_legend: "k=2" {
    style.fill: "#F39C12"
    style.stroke: "#F39C12"
  }
  k3_legend: "k=3 (typical)" {
    style.fill: "#27AE60"
    style.stroke: "#27AE60"
  }
  k5_legend: "k=5" {
    style.fill: "#3498DB"
    style.stroke: "#3498DB"
  }
  theoretical: "ceil(log_k(N))" {
    style.fill: "transparent"
    style.stroke: "#8E44AD"
    style.stroke-dash: 5
  }
}

bound_annotation: |md
  **ceil(log₃(100)) ≈ 5**
  N=100 nodes
  99.9% delivery
| {
  near: center-right
  style.fill: "#ECF0F1"
  style.stroke: "#8E44AD"
  style.border-radius: 4
}

graph_container: {
  # Y-axis
  y_axis: {
    shape: rectangle
    width: 5
    height: 400
    style.fill: "#2C3E50"
    style.stroke: "#2C3E50"
  }
  # X-axis
  x_axis: {
    shape: rectangle
    width: 700
    height: 5
    style.fill: "#2C3E50"
    style.stroke: "#2C3E50"
  }
  y_axis -> x_axis: {
    style.stroke: transparent
  }

  # Y-axis labels
  y_100: "100%"
  y_75: "75%"
  y_50: "50%"
  y_25: "25%"
  y_0: "0%"

  # X-axis labels (rounds)
  r0: "0"
  r1: "1"
  r2: "2"
  r3: "3"
  r4: "4"
  r5: "5"
  r6: "6"
  r7: "7"
  r8: "8"
  r9: "9"
  r10: "10"

  # k=1 curve (linear - slowest)
  k1_r0: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r1: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r2: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r3: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r4: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r5: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r6: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r7: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r8: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r9: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r10: {shape: circle; width: 8; height: 8; style.fill: "#E74C3C"; style.stroke: "#E74C3C"}
  k1_r0 -> k1_r1 -> k1_r2 -> k1_r3 -> k1_r4 -> k1_r5 -> k1_r6 -> k1_r7 -> k1_r8 -> k1_r9 -> k1_r10: {
    style.stroke: "#E74C3C"
    style.stroke-width: 2
  }

  # k=2 curve
  k2_r0: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r1: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r2: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r3: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r4: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r5: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r6: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r7: {shape: circle; width: 8; height: 8; style.fill: "#F39C12"; style.stroke: "#F39C12"}
  k2_r0 -> k2_r1 -> k2_r2 -> k2_r3 -> k2_r4 -> k2_r5 -> k2_r6 -> k2_r7: {
    style.stroke: "#F39C12"
    style.stroke-width: 2
  }

  # k=3 curve (typical production value)
  k3_r0: {shape: circle; width: 8; height: 8; style.fill: "#27AE60"; style.stroke: "#27AE60"}
  k3_r1: {shape: circle; width: 8; height: 8; style.fill: "#27AE60"; style.stroke: "#27AE60"}
  k3_r2: {shape: circle; width: 8; height: 8; style.fill: "#27AE60"; style.stroke: "#27AE60"}
  k3_r3: {shape: circle; width: 8; height: 8; style.fill: "#27AE60"; style.stroke: "#27AE60"}
  k3_r4: {shape: circle; width: 8; height: 8; style.fill: "#27AE60"; style.stroke: "#27AE60"}
  k3_r5: {shape: circle; width: 8; height: 8; style.fill: "#27AE60"; style.stroke: "#27AE60"}
  k3_r0 -> k3_r1 -> k3_r2 -> k3_r3 -> k3_r4 -> k3_r5: {
    style.stroke: "#27AE60"
    style.stroke-width: 3
  }

  # k=5 curve (fastest convergence)
  k5_r0: {shape: circle; width: 8; height: 8; style.fill: "#3498DB"; style.stroke: "#3498DB"}
  k5_r1: {shape: circle; width: 8; height: 8; style.fill: "#3498DB"; style.stroke: "#3498DB"}
  k5_r2: {shape: circle; width: 8; height: 8; style.fill: "#3498DB"; style.stroke: "#3498DB"}
  k5_r3: {shape: circle; width: 8; height: 8; style.fill: "#3498DB"; style.stroke: "#3498DB"}
  k5_r0 -> k5_r1 -> k5_r2 -> k5_r3: {
    style.stroke: "#3498DB"
    style.stroke-width: 2
  }

  # Theoretical bound markers (dashed vertical lines)
  bound_k3: {
    shape: rectangle
    width: 2
    height: 350
    style.fill: "#8E44AD"
    style.stroke: "#8E44AD"
    style.stroke-dash: 5
    style.opacity: 0.6
  }
}

# Axis titles (Root level for valid 'near' positioning)
x_title: "**Gossip Round Number**" {near: bottom-center}
y_title: "**% Nodes Infected**" {near: center-left}