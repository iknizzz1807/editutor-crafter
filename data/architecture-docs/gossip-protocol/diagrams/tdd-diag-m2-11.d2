vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Algorithm: LWW Conflict Resolution (Last-Write-Wins)
  **Context**: Distributed State Synchronization (CRDT/Gossip)
| {near: top-center}

direction: right

classes: {
  data_entry: {
    shape: sql_table
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
  logic_gate: {
    shape: diamond
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      bold: true
    }
  }
  annotation: {
    shape: rectangle
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      stroke-dash: 2
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 0: INITIAL CONFLICT STATE
# -----------------------------------------------------------------------------
before_state: {
  label: "0. INITIAL CONFLICT DETECTED"
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 2
  }

  local_node: "Local State (Replica A)" {
    entry: {
      shape: sql_table
      style.fill: "#E3F2FD"
      # Offset | Field | Size
      "0x00": "REG_ID: user_123" {constraint: "8B (PK)"}
      "0x08": "VERSION: 5" {constraint: "8B (TS)"}
      "0x10": "NODE_ID: node-a" {constraint: "4B (ID)"}
      "0x14": "PAYLOAD: v1_data" {constraint: "32B (DATA)"}
    }
  }

  remote_node: "Incoming State (Replica B)" {
    entry: {
      shape: sql_table
      style.fill: "#FFF3E0"
      # Offset | Field | Size
      "0x00": "REG_ID: user_123" {constraint: "8B (PK)"}
      "0x08": "VERSION: 7" {constraint: "8B (TS)"}
      "0x10": "NODE_ID: node-b" {constraint: "4B (ID)"}
      "0x14": "PAYLOAD: v2_data" {constraint: "32B (DATA)"}
    }
  }

  local_node.entry <-> remote_node.entry: "Gossip Sync Event" {
    style.stroke-dash: 4
    style.stroke: "#9E9E9E"
  }
}

# -----------------------------------------------------------------------------
# STEP 1: RESOLUTION LOGIC
# -----------------------------------------------------------------------------
comparison_logic: {
  label: "1. CONFLICT RESOLUTION HANDLER"
  
  primary_check: "compare(v_rem, v_loc)" {
    class: logic_gate
    label: "remote.version (7)\n>\nlocal.version (5)?"
  }

  tie_breaker: "Tie-Breaker Rule" {
    class: annotation
    label: |md
      **If Versions Equal:**
      `winner = max(NodeID_A, NodeID_B)`
      *Ensures Determinism*
    |
  }
}

# -----------------------------------------------------------------------------
# STEP 2: CONVERGED STATE
# -----------------------------------------------------------------------------
after_state: {
  label: "2. CONVERGED STATE (LOCAL UPDATED)"
  style: {
    fill: "#F1F8E9"
    stroke: "#81C784"
  }

  converged_node: "Replica A (Updated)" {
    winner_entry: {
      shape: sql_table
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.stroke-width: 3
      
      "0x00": "REG_ID: user_123" {constraint: "8B"}
      "0x08": "**VERSION: 7**" {
        constraint: "UPDATED"
        style.font-color: red
        style.bold: true
      }
      "0x10": "**NODE_ID: node-b**" {
        constraint: "WINNER"
        style.font-color: red
        style.bold: true
      }
      "0x14": "**PAYLOAD: v2_data**" {
        constraint: "MERGED"
        style.font-color: red
        style.bold: true
      }
    }
  }

  stale_buffer: "Discarded Log" {
    style.opacity: 0.5
    stale_entry: {
      shape: sql_table
      header: "v1 (STALE)"
      "0x08": "VERSION: 5"
      "0x10": "NODE_ID: node-a"
    }
  }
}

# -----------------------------------------------------------------------------
# DATA FLOW & SEQUENCE
# -----------------------------------------------------------------------------

before_state -> comparison_logic.primary_check: "Trigger Resolution" {
  style.stroke-width: 2
}

comparison_logic.primary_check -> after_state.converged_node: "Result: TRUE\nApply Remote State" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.animated: true
}

after_state.converged_node -> after_state.stale_buffer: "Evict Stale" {
  style.stroke-dash: 5
  style.stroke: "#F44336"
}

# -----------------------------------------------------------------------------
# METADATA & LEGEND
# -----------------------------------------------------------------------------
legend: {
  near: bottom-center
  
  win: Winner State { style.fill: "#C8E6C9" }
  comp: Logic Branch { shape: diamond; style.fill: "#E8F5E9" }
  stale: Stale/Evicted { style.opacity: 0.5 }
}

specs: {
  near: bottom-right
  label: "Implementation Specs"
  style.fill: "#E1F5FE"
  
  rule1: "Rule 1: Timestamp (uint64) Is Absolute"
  rule2: "Rule 2: Node IDs (uuid/string) Must Be Unique"
  rule3: "Rule 3: Deterministic tie-break via Lexicographical ID"
  size: "Total Struct Size: 52 Bytes"
}