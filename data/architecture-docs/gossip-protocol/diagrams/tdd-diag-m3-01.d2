vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Module Architecture: Anti-Entropy (M3)
  Pull Gossip & State Reconciliation
| {near: top-center}

# Main AntiEntropy Manager
AntiEntropy: {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.border-radius: 8
  header: {
    shape: rectangle
    style.fill: "#5C6BC0"
    style.stroke: "#3949AB"
    style.font-color: white
    style.bold: true
    label: "AntiEntropy\n(manager)"
  }
  fields: {
    shape: rectangle
    style.fill: "#FAFAFA"
    config: "config: AntiEntropyConfig"
    nodeID: "nodeID: string"
    store: "store: *state.Store"
    peerList: "peerList: *membership.PeerList"
    conn: "conn: *net.UDPConn"
    merkleTree: "merkleTree: *merkle.Tree"
    merkleDirty: "merkleDirty: atomic.Bool"
    lastSync: "lastSync: sync.Map"
    metrics: "metrics: *SyncMetrics"
  }
  methods: {
    shape: rectangle
    style.fill: "#E3F2FD"
    new: "+ NewAntiEntropy(config, nodeID, store, peerList, conn) *AntiEntropy"
    start: "+ Start()"
    stop: "+ Stop()"
    handleDigestReq: "+ HandleDigestRequest(msg, addr) error"
    handleDigestResp: "+ HandleDigestResponse(msg) ([]string, error)"
    handleStateReq: "+ HandleStateRequest(msg, addr) error"
    handleStateResp: "+ HandleStateResponse(msg) (int, error)"
    getMerkle: "+ GetMerkleTree() *merkle.Tree"
    invalidate: "+ InvalidateMerkleTree()"
    getMetrics: "+ GetMetrics() SyncMetrics"
  }
}

# Merkle Tree Builder
MerkleTree: {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.border-radius: 8
  header: {
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#388E3C"
    style.font-color: white
    style.bold: true
    label: "merkle.Tree\n(builder)"
  }
  fields: {
    shape: rectangle
    style.fill: "#FAFAFA"
    root: "Root: *MerkleNode"
    depth: "Depth: int"
    leaves: "Leaves: []*MerkleNode"
    keyToLeaf: "KeyToLeaf: map[string]*MerkleNode"
    hashSize: "HashSize: int"
  }
  methods: {
    shape: rectangle
    style.fill: "#C8E6C9"
    build: "+ Build(digest map[string]uint64) *Tree"
    getRoot: "+ GetRootHash() [32]byte"
    getSubtree: "+ GetSubtreeHash(path, depth) ([32]byte, bool)"
    diff: "+ Diff(other *Tree) (differing, onlyLocal, onlyRemote []string)"
    getEntries: "+ GetEntriesAtPath(path, depth) []MerkleLeaf"
  }
}

# Merkle Node
MerkleNode: {
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.border-radius: 6
  width: 280
  header: {
    shape: rectangle
    style.fill: "#66BB6A"
    style.font-color: white
    style.bold: true
    label: "MerkleNode"
  }
  body: {
    shape: rectangle
    style.fill: "#FAFAFA"
    hash: "Hash: [32]byte"
    # Quote 'left' and 'right' because they are reserved keywords for positioning
    "left": "Left: *MerkleNode"
    "right": "Right: *MerkleNode"
    parent: "Parent: *MerkleNode"
    key: "Key: string"
    version: "Version: uint64"
    isLeaf: "IsLeaf: bool"
    path: "Path: uint32"
    depth: "Depth: uint8"
    dirty: "Dirty: bool"
  }
}

# LWW Conflict Resolver
LWWResolver: {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.border-radius: 8
  header: {
    shape: rectangle
    style.fill: "#FF9800"
    style.stroke: "#F57C00"
    style.font-color: white
    style.bold: true
    label: "conflict.LWWResolver\n(Last-Write-Wins)"
  }
  fields: {
    shape: rectangle
    style.fill: "#FAFAFA"
    localNodeID: "localNodeID: string"
  }
  methods: {
    shape: rectangle
    style.fill: "#FFE0B2"
    new: "+ NewLWWResolver(localNodeID) *LWWResolver"
    resolve: "+ Resolve(local, remote *Entry) *Entry"
  }
  rules: {
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FFB74D"
    style.border-radius: 4
    label: |md
      **Resolution Rules:**
      1. Higher `Version` wins
      2. Equal versions → higher `NodeID` wins (string compare)
    |
  }
}

# SyncMetrics
SyncMetrics: {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.border-radius: 8
  header: {
    shape: rectangle
    style.fill: "#9C27B0"
    style.font-color: white
    style.bold: true
    label: "SyncMetrics"
  }
  body: {
    shape: rectangle
    style.fill: "#FAFAFA"
    totalSyncs: "TotalSyncs: atomic.Uint64"
    successful: "SuccessfulSyncs: atomic.Uint64"
    failed: "FailedSyncs: atomic.Uint64"
    entriesSent: "EntriesSent: atomic.Uint64"
    entriesRecv: "EntriesReceived: atomic.Uint64"
    bytesSent: "BytesSent: atomic.Uint64"
    bytesRecv: "BytesReceived: atomic.Uint64"
    lastSync: "LastSyncTime: atomic.Int64"
  }
}

# AntiEntropyConfig
AntiEntropyConfig: {
  style.fill: "#E1F5FE"
  style.stroke: "#03A9F4"
  style.border-radius: 6
  header: {
    shape: rectangle
    style.fill: "#03A9F4"
    style.font-color: white
    style.bold: true
    label: "AntiEntropyConfig"
  }
  body: {
    shape: rectangle
    style.fill: "#FAFAFA"
    interval: "Interval: time.Duration (default: 10s)"
    jitter: "JitterFactor: float64 (default: 0.1)"
    merkleEn: "MerkleEnabled: bool (default: true)"
    threshold: "MerkleThreshold: int (default: 1000)"
    syncTimeout: "SyncTimeout: time.Duration (default: 30s)"
    maxChunk: "MaxChunkSize: int (default: 64KB)"
    maxConc: "MaxConcurrentSyncs: int (default: 3)"
  }
}

# Protocol Message Types
ProtocolMessages: {
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  style.border-radius: 8
  header: {
    shape: rectangle
    style.fill: "#607D8B"
    style.font-color: white
    style.bold: true
    label: "Protocol Messages (0x20-0x25)"
  }
  types: {
    shape: rectangle
    style.fill: "#FAFAFA"
    digestReq: "DigestRequest {Mode, Digest, MerkleRoot, MerkleDepth}"
    digestResp: "DigestResponse {NewerKeys, MissingKeys, MerkleDiffs}"
    stateReq: "StateRequest {Keys, IncludeValues}"
    stateResp: "StateResponse {Entries, ChunkInfo}"
    merkleReq: "MerkleRequest {Paths, Depths}"
    merkleResp: "MerkleResponse {SubtreeHashes}"
  }
}

# Store Extensions (from M2)
StoreExtensions: {
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
  style.border-radius: 6
  header: {
    shape: rectangle
    style.fill: "#3F51B5"
    style.font-color: white
    style.bold: true
    label: "state.Store Extensions"
  }
  methods: {
    shape: rectangle
    style.fill: "#C5CAE9"
    createDigest: "+ CreateDigest() map[string]uint64"
    getEntries: "+ GetEntries(keys []string) []*Entry"
    getVersions: "+ GetVersions(keys []string) map[string]uint64"
  }
}

# Resolver Interface
Resolver: {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.border-radius: 6
  header: {
    shape: rectangle
    style.fill: "#F44336"
    style.font-color: white
    style.bold: true
    label: "Resolver (interface)"
  }
  method: {
    shape: rectangle
    style.fill: "#FFCDD2"
    label: "+ Resolve(local, remote *Entry) *Entry"
  }
}

# Connections
AntiEntropy -> MerkleTree: "builds &\nqueries" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
AntiEntropy -> LWWResolver: "resolves\nconflicts" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
AntiEntropy -> SyncMetrics: "records" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
AntiEntropy -> StoreExtensions: "creates digest\ngets entries" {
  style.stroke: "#3F51B5"
  style.stroke-width: 2
}
AntiEntropy -> ProtocolMessages: "encodes/decodes" {
  style.stroke: "#607D8B"
  style.stroke-dash: 3
}
AntiEntropy -> AntiEntropyConfig: "configured by" {
  style.stroke: "#03A9F4"
  style.stroke-dash: 2
}
LWWResolver -> Resolver: "implements" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: false
}
MerkleTree -> MerkleNode: "composed of" {
  style.stroke: "#388E3C"
  target-arrowhead.shape: diamond
}

# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  style.border-radius: 4
  title: {
    style.bold: true
    label: "Legend"
  }
  solid: "────▶ owns/composes"
  dashed: "- - - ▶ references/uses"
  diamond: "◆ composition"
  triangle: "△ implements"
}

# Size annotation
sizeAnnotation: |md
  **Memory Footprint:**
  - AntiEntropy: ~500 bytes
  - MerkleTree (10K keys): ~17.6 MB
  - LWWResolver: ~64 bytes
  - SyncMetrics: ~64 bytes
| {
  near: bottom-left
  shape: text
  style.fill: "#F5F5F5"
  style.border-radius: 4
}