layout-engine: elk
theme-id: 4

title: |'md
# Data Flow: Push-Pull Anti-Entropy Protocol
## Bidirectional state reconciliation in single round-trip
**Version:** 1.0.4 | **Standard:** Gossip-REPL-01
'| {
  near: top-center
}

direction: right

# -----------------------------------------------------------------------------
# Global Styles and Classes
# -----------------------------------------------------------------------------
classes: {
  header: {
    style: {
      bold: true
      font-color: white
      fill: "#1565C0"
      border-radius: 4
    }
  }
  digest: {
    shape: document
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      stroke-width: 2
      shadow: true
    }
  }
  response: {
    shape: document
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
      shadow: true
    }
  }
  state_msg: {
    shape: cylinder
    style: {
      fill: "#FFCCBC"
      stroke: "#E64A19"
      stroke-width: 2
      shadow: true
    }
  }
  arrow_send: {
    style: {
      stroke: "#1976D2"
      stroke-width: 3
      animated: true
    }
  }
  arrow_recv: {
    style: {
      stroke: "#388E3C"
      stroke-width: 3
    }
  }
  hex_label: {
    style: {
      font: mono
      font-size: 10
      font-color: "#546E7A"
    }
  }
}

# -----------------------------------------------------------------------------
# Phase 1: Initial State (State Inconsistency)
# -----------------------------------------------------------------------------
phase1: "Phase 1: Initial State Analysis" {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-dash: 0
  style.stroke-width: 2

  node_states: {
    grid-columns: 2
    grid-gap: 40
    
    node_a_box: "Node A Storage" {
      header: "Local State (L)"
      header.class: header
      data: |'md
        | Key  | Version | TS (ms) |
        |:-----|:-------:|:-------:|
        | key1 | **v5**  | 1704021 |
        | key2 | v3      | 1704010 |
        | key3 | **v8**  | 1704088 |
      '|
    }
    
    node_b_box: "Node B Storage" {
      header: "Remote State (R)"
      header.class: header
      data: |'md
        | Key  | Version | TS (ms) |
        |:-----|:-------:|:-------:|
        | key1 | **v7**  | 1704025 |
        | key2 | v3      | 1704010 |
        | key4 | **v2**  | 1704005 |
      '|
    }
  }
  
  diff_note: "Inconsistency Matrix" {
    shape: rectangle
    content: |'md
      - **Collision:** `key1` (R > L)
      - **Orphan (L):** `key3`
      - **Orphan (R):** `key4`
    '|
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    style.double-border: true
  }
}

# -----------------------------------------------------------------------------
# Phase 2: Digest Exchange (GossipDigestSyn)
# -----------------------------------------------------------------------------
phase2: "Phase 2: Digest Exchange [OpCode: 0x20]" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  
  node_a: "Node A" {
    style.fill: "#BBDEFB"
    digest_a: "Digest A\nLen: 24B\nCRC32: 0xAF" {
      class: digest
    }
  }
  
  node_b: "Node B" {
    style.fill: "#BBDEFB"
    digest_b: "Digest B\nLen: 24B\nCRC32: 0xBC" {
      class: digest
    }
  }
  
  node_a.digest_a -> node_b: "UDP: GossipDigestSyn" {
    class: arrow_send
    tooltip: "Payload: [key1:v5, key2:v3, key3:v8]"
  }
  node_b.digest_b -> node_a: "UDP: GossipDigestSyn" {
    class: arrow_send
    tooltip: "Payload: [key1:v7, key2:v3, key4:v2]"
  }
}

# -----------------------------------------------------------------------------
# Phase 3: Processing (Delta Identification)
# -----------------------------------------------------------------------------
phase3: "Phase 3: Diff Processing & LWW Resolution" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.stroke-width: 2
  
  comp_a: "A Engine" {
    header: "Compute Delta (A vs B)"
    header.class: header
    results: |'md
      | Op    | Key | Version |
      |:------|:---:|:-------:|
      | PULL  | k1  | v7      |
      | PUSH  | k3  | v8      |
      | PULL  | k4  | v2      |
    '|
  }
  
  comp_b: "B Engine" {
    header: "Compute Delta (B vs A)"
    header.class: header
    results: |'md
      | Op    | Key | Version |
      |:------|:---:|:-------:|
      | PUSH  | k1  | v7      |
      | PULL  | k3  | v8      |
      | PUSH  | k4  | v2      |
    '|
  }
}

# -----------------------------------------------------------------------------
# Phase 4: Ack Exchange (GossipDigestAck)
# -----------------------------------------------------------------------------
phase4: "Phase 4: Acknowledgement [OpCode: 0x21]" {
  style.fill: "#FFF3E0"
  style.stroke: "#E64A19"
  style.stroke-width: 2

  node_a2: "Node A" {
    resp_a: "Ack A\nNeeds: [k1, k4]\nOffers: [k3]" {
      class: response
    }
  }
  
  node_b2: "Node B" {
    resp_b: "Ack B\nNeeds: [k3]\nOffers: [k1, k4]" {
      class: response
    }
  }
  
  node_a2.resp_a -> node_b2: "GossipDigestAck" { class: arrow_send }
  node_b2.resp_b -> node_a2: "GossipDigestAck" { class: arrow_send }
}

# -----------------------------------------------------------------------------
# Phase 5: State Synchronization (GossipDigestAck2)
# -----------------------------------------------------------------------------
phase5: "Phase 5: Data Persistence [OpCode: 0x23]" {
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  style.stroke-width: 2

  node_a3: "Node A" {
    state_a: "Payload: {k3: Data_Blob}" {
      class: state_msg
    }
  }
  
  node_b3: "Node B" {
    state_b: "Payload: {k1: Data_Blob, k4: Data_Blob}" {
      class: state_msg
    }
  }
  
  node_a3.state_a -> node_b3: "GossipDigestAck2 (Push)" { class: arrow_send }
  node_b3.state_b -> node_a3: "GossipDigestAck2 (Push)" { class: arrow_send }
}

# -----------------------------------------------------------------------------
# Phase 6: Convergence
# -----------------------------------------------------------------------------
phase6: "Phase 6: Protocol Convergence" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3

  converged: "Cluster State: CONSISTENT (Quorum Met)" {
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.bold: true
    
    final: |'md
      | Key  | Final Version | Authority |
      |:-----|:-------------:|:---------:|
      | key1 | v7            | Node B    |
      | key2 | v3            | Immutable |
      | key3 | v8            | Node A    |
      | key4 | v2            | Node B    |
    '|
  }
}

# -----------------------------------------------------------------------------
# Transitions & Flow
# -----------------------------------------------------------------------------
phase1 -> phase2: "T+1: Multicast Start"
phase2 -> phase3: "T+15ms: Receipt"
phase3 -> phase4: "T+18ms: Diff Computed"
phase4 -> phase5: "T+30ms: Payloads Prepared"
phase5 -> phase6: "T+45ms: Commit to Disk"

# -----------------------------------------------------------------------------
# Technical Specifications
# -----------------------------------------------------------------------------
summary: |'md
### Gossip Implementation Specification
1.  **Transport:** UDP (Lossy) with Application-level ACKs.
2.  **Binary Layout:**
    - `[0-3]`  : Magic Number (0xCAFEBABE)
    - `[4-7]`  : OpCode (0x20-0x23)
    - `[8-11]` : Payload Length
    - `[...]`  : Serialized Key/Version Pairs
3.  **Conflict Resolution:** Last-Write-Wins (LWW) based on 64-bit nanosecond timestamps.
4.  **Anti-Entropy Trigger:** Periodic (every 1s) or Event-driven (on update).
'| {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  style.stroke-width: 2
}