vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Merkle Tree Structure
  Binary tree with root hash, internal nodes, and leaf nodes containing (key, version, hash)
  **Differing subtree highlighted in RED**
| {near: top-center}
direction: down
# Root node
root: {
  shape: rectangle
  label: |md
    **Root Hash**
    `0x7a3f...2b8c`
  |
  style: {
    fill: "#E8E1EF"
    stroke: "#6B4C9A"
    stroke-width: 2
    font: mono
  }
}
# Level 1 - Internal nodes
level1_left: {
  shape: rectangle
  label: |md
    **Hash AB**
    `0xb2d1...f4e3`
  |
  style: {
    fill: "#E8E1EF"
    stroke: "#6B4C9A"
    stroke-width: 2
    font: mono
  }
}
level1_right: {
  shape: rectangle
  label: |md
    **Hash CD**
    `0xc5e7...a9d2`
  |
  style: {
    fill: "#E8E1EF"
    stroke: "#6B4C9A"
    stroke-width: 2
    font: mono
  }
}
# Level 2 - Leaf parent nodes
leaf_parent_a: {
  shape: rectangle
  label: |md
    **Hash A**
    `0x1a2b...3c4d`
  |
  style: {
    fill: "#E8E1EF"
    stroke: "#6B4C9A"
    stroke-width: 2
    font: mono
  }
}
leaf_parent_b: {
  shape: rectangle
  label: |md
    **Hash B**
    `0x5e6f...7g8h`
  |
  style: {
    fill: "#E8E1EF"
    stroke: "#6B4C9A"
    stroke-width: 2
    font: mono
  }
}
leaf_parent_c: {
  shape: rectangle
  label: |md
    **Hash C**
    `0x9i0j...1k2l`
  |
  style: {
    fill: "#FFCCCC"
    stroke: "#CC0000"
    stroke-width: 3
    bold: true
    font: mono
  }
}
leaf_parent_d: {
  shape: rectangle
  label: |md
    **Hash D**
    `0x3m4n...5o6p`
  |
  style: {
    fill: "#E8E1EF"
    stroke: "#6B4C9A"
    stroke-width: 2
    font: mono
  }
}
# Leaf nodes - Key/Version/Hash
leaf_a: {
  shape: rectangle
  label: |md
    **Leaf A**
    ---
    Key: `"user:1001"`
    Version: `42`
    Hash: `0x1a2b...3c4d`
  |
  style: {
    fill: "#D4E8D4"
    stroke: "#2E7D32"
    stroke-width: 2
    font: mono
  }
}
leaf_b: {
  shape: rectangle
  label: |md
    **Leaf B**
    ---
    Key: `"user:1002"`
    Version: `15`
    Hash: `0x5e6f...7g8h`
  |
  style: {
    fill: "#D4E8D4"
    stroke: "#2E7D32"
    stroke-width: 2
    font: mono
  }
}
leaf_c: {
  shape: rectangle
  label: |md
    **Leaf C** ⚠️ DIFFERS
    ---
    Key: `"user:1003"`
    Local: `v=7`
    Remote: `v=23`
    Hash: `0x9i0j...1k2l`
  |
  style: {
    fill: "#FF9999"
    stroke: "#CC0000"
    stroke-width: 3
    bold: true
    font: mono
  }
}
leaf_d: {
  shape: rectangle
  label: |md
    **Leaf D**
    ---
    Key: `"user:1004"`
    Version: `88`
    Hash: `0x3m4n...5o6p`
  |
  style: {
    fill: "#D4E8D4"
    stroke: "#2E7D32"
    stroke-width: 2
    font: mono
  }
}
# Connections from root to level 1
root -> level1_left: "left" {
  style: {
    stroke: "#6B4C9A"
    stroke-width: 2
  }
}
root -> level1_right: "right" {
  style: {
    stroke: "#6B4C9A"
    stroke-width: 2
  }
}
# Connections from level 1 to level 2
level1_left -> leaf_parent_a: "left" {
  style: {
    stroke: "#6B4C9A"
    stroke-width: 2
  }
}
level1_left -> leaf_parent_b: "right" {
  style: {
    stroke: "#6B4C9A"
    stroke-width: 2
  }
}
level1_right -> leaf_parent_c: "left" {
  style: {
    stroke: "#CC0000"
    stroke-width: 3
    bold: true
  }
}
level1_right -> leaf_parent_d: "right" {
  style: {
    stroke: "#6B4C9A"
    stroke-width: 2
  }
}
# Connections from level 2 to leaves
leaf_parent_a -> leaf_a: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
leaf_parent_b -> leaf_b: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
leaf_parent_c -> leaf_c: {
  style: {
    stroke: "#CC0000"
    stroke-width: 3
    bold: true
  }
}
leaf_parent_d -> leaf_d: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
# Legend
legend: {
  near: bottom-right
  legend_title: Legend {
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
  normal_node: Normal Node {
    shape: rectangle
    style: {
      fill: "#E8E1EF"
      stroke: "#6B4C9A"
      stroke-width: 2
    }
  }
  leaf_node: Leaf Node {
    shape: rectangle
    style: {
      fill: "#D4E8D4"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  diff_node: Differing Node {
    shape: rectangle
    style: {
      fill: "#FF9999"
      stroke: "#CC0000"
      stroke-width: 3
      bold: true
    }
  }
  diff_edge: |md
    `---` Differing subtree edge
  | {
    shape: text
    style: {
      stroke: "#CC0000"
      font-color: "#CC0000"
    }
  }
}
# Annotation for diff detection
diff_annotation: |md
  **Diff Detection:**
  1. Compare root hashes
  2. If different, traverse down
  3. Compare child hashes at each level
  4. Stop when reaching differing leaves
  5. Request only differing keys
  **O(log S) comparisons**
  where S = number of keys
| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#FFF9E6"
    stroke: "#E6A800"
    stroke-width: 2
    border-radius: 8
  }
}