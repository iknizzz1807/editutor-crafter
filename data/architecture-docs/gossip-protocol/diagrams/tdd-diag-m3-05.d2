vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F97316"
    padding: "#9CA3AF"
    leaf: "#10B981"
  }
}

title: |md
  # Memory Layout: MerkleNode (64-bit)
  **Total: 88 bytes** (Internal Memory Alignment)
| {near: top-center}

# Memory layout container for the MerkleNode struct
MerkleNode: {
  label: "MerkleNode struct\n(sizeof = 88 bytes)"
  style.fill: transparent
  style.stroke: "#374151"
  style.stroke-width: 2

  # Offset 0x00 - Hash (32 bytes)
  f_hash: {
    label: "Hash\n[32]byte"
    style.fill: "${colors.header}"
    width: 400
    height: 100
  }

  # Offset 0x20 - Left pointer (8 bytes)
  f_left: {
    label: "Left\n*Node"
    style.fill: "${colors.pointer}"
    width: 400
    height: 40
  }

  # Offset 0x28 - Right pointer (8 bytes)
  f_right: {
    label: "Right\n*Node"
    style.fill: "${colors.pointer}"
    width: 400
    height: 40
  }

  # Offset 0x30 - Parent pointer (8 bytes)
  f_parent: {
    label: "Parent\n*Node"
    style.fill: "${colors.pointer}"
    width: 400
    height: 40
  }

  # Offset 0x38 - Key string header (16 bytes)
  # Note: Crosses Cache Line boundary at 64 bytes (Offset 0x40)
  f_key: {
    label: "Key\nstring (ptr+len)"
    style.fill: "${colors.leaf}"
    width: 400
    height: 60
  }

  # Offset 0x48 - Version (8 bytes)
  f_version: {
    label: "Version\nuint64"
    style.fill: "${colors.leaf}"
    width: 400
    height: 40
  }

  # Offset 0x50 - Path (4 bytes)
  f_path: {
    label: "Path\nuint32"
    style.fill: "${colors.data}"
    width: 400
    height: 40
  }

  # Offset 0x54 - Depth (1 byte)
  f_depth: {
    label: "Depth\nuint8"
    style.fill: "${colors.data}"
    width: 400
    height: 30
  }

  # Offset 0x55 - IsLeaf (1 byte)
  f_isleaf: {
    label: "IsLeaf\nbool"
    style.fill: "${colors.leaf}"
    width: 400
    height: 30
  }

  # Offset 0x56 - Dirty (1 byte)
  f_dirty: {
    label: "Dirty\nbool"
    style.fill: "${colors.data}"
    width: 400
    height: 30
  }

  # Offset 0x57 - Padding (1 byte)
  f_padding: {
    label: "Pad\n(align)"
    style.fill: "${colors.padding}"
    width: 400
    height: 30
  }

  # Internal stacking for alignment
  f_hash -> f_left -> f_right -> f_parent -> f_key -> f_version -> f_path -> f_depth -> f_isleaf -> f_dirty -> f_padding: {style.stroke: transparent}
}

# Offset annotations (Left Margin)
offsets: {
  label: "Offset"
  style.fill: transparent
  o00: "0x00"
