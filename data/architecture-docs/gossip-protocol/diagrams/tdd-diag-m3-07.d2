vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# Root-level title to avoid "near keys" constraint on nested shapes
"Diagram Header": |md
  # Anti-Entropy Partition Healing Sequence
  **Protocol:** Bidirectional Digest Exchange (Push-Pull Gossip)  
  **Resolution Strategy:** LWW (Last-Write-Wins) with Node ID Tie-break.
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 18
  }
}

"Partition Healing Timeline": {
  shape: sequence_diagram

  # Actor Definitions
  A: "Partition 1\n(Node A)" {
    style.fill: "#E6E6FA"
  }
  B: "Partition 1\n(Node B)" {
    style.fill: "#E6E6FA"
  }
  C: "Partition 2\n(Node C)" {
    style.fill: "#FFF0F5"
  }
  D: "Partition 2\n(Node D)" {
    style.fill: "#FFF0F5"
  }

  # Phase 1: Local writes during network failure
  "Phase 0: Isolation Period (T < 30s)": {
    A -> A: "Write(k1, 'v1', ver=100, ts=T+5s)"
    C -> C: "Write(k1, 'v2', ver=100, ts=T+8s)"
    
    A."CONFLICT DETECTED: Write k1@v1" {
      style.font-color: "#d73a49"
    }

    (A -> B): "Gossip(k1:100)" {
      style.stroke-dash: 3
    }
    (B -> A): "Ack"
    
    (C -> D): "Gossip(k1:100)" {
      style.stroke-dash: 3
    }
    (D -> C): "Ack"
    
    A."NET_PARTITION: A/B isolated from C/D" {
      style: {
        stroke: red
        stroke-dash: 5
        bold: true
      }
    }
  }

  # Phase 2: Metadata Exchange
  "Phase 1: Digest Exchange (T+30s)": {
    A.t3 -> C.t3: "DigestReq(VectorClock: {A:100, B:98})"
    C.t3 -> A.t3: "DigestReq(VectorClock: {C:100, D:95})"
    
    A."Action: Reconciliation triggered by link-up"

    A.t4 -> C.t4: "DigestResp(Skew: [k1])"
    C.t4 -> A.t4: "DigestResp(Skew: [k1])"
    
    C."LOGIC: Detected version collision (100 == 100)"
  }

  # Phase 3: Payload Transfer & Merge
  "Phase 2: Full State Transfer & Resolution": {
    A.t5 -> C.t5: "FetchState(k1)"
    C.t5 -> A.t5: "FetchState(k1)"
    
    A.t6 -> C.t6: "PushState(k1, v1, node:A)" {
      style.stroke: blue
    }
    C.t6 -> A.t6: "PushState(k1, v2, node:C)" {
      style.stroke: blue
    }

    A."LWW LOGIC: ver(100) == ver(100). Comparing NodeIDs..."
    A."NodeID 'C' > 'A'. Resolving k1 -> 'v2'" {
      style.bold: true
    }
    
    A.t7 -> A.t7: "UpdateStore(k1='v2')" {
      style: {
        stroke: "#28a745"
        fill: "#90EE90"
        bold: true
      }
    }

    A.t7 -> B.t7: "Propagate(k1='v2', ver=100)" {
      style.animated: true
      style.stroke: "#28a745"
    }
    C.t7 -> D.t7: "Propagate(k1='v2', ver=100)" {
      style.animated: true
      style.stroke: "#28a745"
    }
  }

  # Phase 4: Final State
  "Phase 3: Cluster Convergence": {
    B.t8 -> A.t8: "SyncCheck"
    A.t8 -> B.t8: "Consistent(k1)"
    
    D.t8 -> C.t8: "SyncCheck"
    C.t8 -> D.t8: "Consistent(k1)"
    
    A."STABLE STATE: Entropy reconciled to 'v2' globally" {
      style: {
        stroke: "#28a745"
        double-border: true
        bold: true
      }
    }
  }
}

# Global Styling for Sequence elements
("Partition Healing Timeline" -> **)[*]: {
  style: {
    font-size: 14
    stroke: "#444"
  }
}

# Note styling for implementation detail
"Partition Healing Timeline".**."*": {
  style: {
    font-size: 12
    italic: true
    fill: "#f8f9fa"
  }
}