layout-engine: tala

vars: {
  d2-config: {
    theme-id: 6
    sketch: false
    center: true
  }
}

direction: right

# -----------------------------------------------------------------------------
# Global Title & Document Header
# -----------------------------------------------------------------------------
Title: {
  shape: rectangle
  label: |md
    # Anti-Entropy State Machine (A-ESM)
    ## Component: Peer-to-Peer State Convergence Protocol
    **Implementation Spec:** Push-Pull Synchronization via Merkle Tree / Version Vector Digests
    **Target Port:** UDP/7946 (Gossip Control Plane)
  |
  near: top-center
  style: {
    font-size: 22
    stroke-width: 0
    fill: transparent
  }
}

# -----------------------------------------------------------------------------
# States - Detailed Definitions
# -----------------------------------------------------------------------------

Init: {
  shape: circle
  style.fill: "#2D3436"
  style.stroke: "#000000"
  style.font-color: white
  label: "● START"
}

Idle: {
  shape: rectangle
  label: |md
    ### STATE: IDLE
    **Invariant:** `syncInProgress == false`
    **Task:** Waiting for Gossip Clock Tick
    **Interval:** 500ms + rand(200ms)
  |
  style: {
    fill: "#F0F8FF"
    stroke: "#4169E1"
    stroke-width: 3
    border-radius: 8
  }
}

SelectingPeer: {
  shape: rectangle
  label: |md
    ### STATE: SELECTING_PEER
    **Algorithm:** Weighted Random Selection
    **Input:** PeerTable (Status == ALIVE)
    **Output:** `targetPeerID`
  |
  style: {
    fill: "#FFFACD"
    stroke: "#DAA520"
    stroke-width: 2
  }
}

BuildingDigest: {
  shape: rectangle
  label: |md
    ### STATE: BUILDING_DIGEST
    **Action:** Atomic local snapshot
    **Op:** Calculate Merkle Roots
    **Format:** Protobuf/Snappy Compressed
  |
  style: {
    fill: "#E6E6FA"
    stroke: "#9370DB"
    stroke-width: 2
  }
}

SendingRequest: {
  shape: rectangle
  label: |md
    ### STATE: SENDING_REQUEST
    **Payload:** `SyncRequestDigest`
    **Timeout:** 5.0s
    **Retries:** 3
  |
  style: {
    fill: "#FFB6C1"
    stroke: "#DC143C"
    stroke-width: 2
  }
}

ComparingDigests: {
  shape: rectangle
  label: |md
    ### STATE: COMPARING
    **Logic:** Symmetric Difference (Δ)
    **Output:** `weNeed[]`, `theyNeed[]`
  |
  style: {
    fill: "#D5F5E3"
    stroke: "#228B22"
    stroke-width: 3
  }
}

ExchangingState: {
  shape: rectangle
  label: |md
    ### STATE: EXCHANGING
    **Phase 1:** Push (Local -> Remote)
    **Phase 2:** Pull (Remote -> Local)
    **Batching:** 1024 keys/msg
  |
  style: {
    fill: "#D6EAF8"
    stroke: "#1E90FF"
    stroke-width: 2
  }
}

Complete: {
  shape: rectangle
  label: |md
    ### STATE: COMPLETE
    **Update:** `SyncMatrix[peerID].LastSuccess`
    **Action:** Release Local Write-Lock
  |
  style: {
    fill: "#D1FFBD"
    stroke: "#006400"
    double-border: true
    stroke-width: 4
  }
}

Timeout: {
  shape: rectangle
  label: |md
    ### STATE: ERROR_TIMEOUT
    **Counter:** `increment(peerID.fail_count)`
    **Strategy:** Exponential Backoff
  |
  style: {
    fill: "#FF6B6B"
    stroke: "#CC0000"
    font-color: white
    bold: true
  }
}

# -----------------------------------------------------------------------------
# Transitions & Guards
# -----------------------------------------------------------------------------

Init -> Idle: 01: [Boot/Reset]

Idle -> SelectingPeer: 02: [Timer Trigger] {
  label: "interval_expired == true"
}

SelectingPeer -> BuildingDigest: 03: [Valid Peer] {
  label: "peerID != nil"
}

BuildingDigest -> SendingRequest: 04: [Build Success]

SendingRequest -> ComparingDigests: 05: [ACK_DIGEST] {
  style: {
    stroke: "#228B22"
    stroke-width: 4
  }
}

SendingRequest -> Timeout: 06: [UDP_TIMEOUT] {
  style: {
    stroke: "#CC0000"
    stroke-dash: 5
    stroke-width: 2
  }
}

ComparingDigests -> ExchangingState: 07: [Delta Found] {
  label: "len(weNeed) + len(theyNeed) > 0"
}

ComparingDigests -> Complete: 08: [Synchronized] {
  label: "len(Δ) == 0"
}

ExchangingState -> Complete: 09: [Stream Finalized] {
  label: "all_batches_acked == true"
}

Complete -> Idle: 10: [Release Lock]

Timeout -> Idle: 11: [Re-queue Task]

# -----------------------------------------------------------------------------
# Implementation Logic Annotations
# -----------------------------------------------------------------------------

Idle_Invariants: {
  label: |md
    ### [STATE INVARIANTS: IDLE]
    - **Memory:** `localMerkleBuffer` == NULL
    - **Locks:** `RWMutex.Unlocked()`
    - **Network:** Port 7946 Listening
  |
  near: Idle
  style: {
    fill: "#F9F9F9"
    stroke: "#7F8C8D"
    stroke-dash: 4
  }
}

Comparison_Logic: {
  label: |md
    ### [LOGIC: COMPUTE DELTA]
    go
    // Identify missing keys
    for k, remoteVer := range remoteDigest {
        localVer := localState.Get(k).Version
        if remoteVer > localVer {
            pullQueue.Append(k)
        } else if remoteVer < localVer {
            pushQueue.Append(k)
        }
    }
    
  |
  near: ComparingDigests
  style: {
    fill: "#FBFCFC"
    stroke: "#27AE60"
    stroke-dash: 4
  }
}

Conflict_Resolution: {
  label: |md
    ### [CONFLICT RESOLUTION: LWW]
    *Last-Write-Wins (Semantic Level)*
    1. **Primary:** Version Counter (uint64)
    2. **Secondary:** Physical Timestamp (Nano)
    3. **Tertiary:** Lexicographical PeerID
  |
  near: ExchangingState
  style: {
    fill: "#FBFCFC"
    stroke: "#2980B9"
    stroke-dash: 4
  }
}

# -----------------------------------------------------------------------------
# Visual Legend
# -----------------------------------------------------------------------------

Legend: {
  label: "DIAGRAM LEGEND"
  grid-columns: 1
  style: {
    fill: "#FDFEFE"
    stroke: "#333333"
    stroke-width: 1
  }

  SuccessPath: {
    shape: text
    label: "Primary Success Path"
    style.font-color: "#228B22"
    style.bold: true
  }
  
  ErrorPath: {
    shape: text
    label: "Failure / Timeout Path"
    style.font-color: "#CC0000"
    style.italic: true
  }

  InvariantBox: {
    shape: text
    label: "State Invariant / Code Spec"
    style.stroke-dash: 5
    style.font-color: "#666666"
  }
}
Legend.near: bottom-left