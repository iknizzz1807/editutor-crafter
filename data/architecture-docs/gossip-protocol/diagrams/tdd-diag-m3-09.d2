direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT LEVEL ELEMENTS ---
title: |md
  # Sync Storm Prevention with Jitter
  *Implementation Spec for Distributed Gossip/Sync Subsystems*
| {
  near: top-center
  style: {
    stroke-width: 0
    fill: transparent
    font-size: 24
    bold: true
  }
}

# --- SECTION 1: CONGESTION SCENARIO ---
section_no_jitter: "SCENARIO A: Without Jitter (Synchronized Thundering Herd)" {
  style: {
    fill: "#FDECEA"
    stroke: "#F87171"
    stroke-width: 4
    stroke-dash: 5
  }

  timeline: "System Clock (ms)" {
    shape: sql_table
    t0: "0000ms" {constraint: "T_BASE"}
    t1: "1000ms" {constraint: "T_SYNC"}
    t2: "2000ms" {constraint: "T_SYNC"}
    t3: "3000ms" {constraint: "T_SYNC"}
    t4: "4000ms" {constraint: "T_SYNC"}
  }

  nodes: "Fleet Nodes [A-E]" {
    grid-columns: 1
    a: "Node_01" {style.fill: "#FCA5A5"}
    b: "Node_02" {style.fill: "#FCA5A5"}
    c: "Node_03" {style.fill: "#FCA5A5"}
    d: "Node_04" {style.fill: "#FCA5A5"}
    e: "Node_05" {style.fill: "#FCA5A5"}
  }

  # All nodes hitting the same time bucket
  nodes.a -> timeline.t1: "TCP SYN"
  nodes.b -> timeline.t1: "TCP SYN"
  nodes.c -> timeline.t1: "TCP SYN"
  nodes.d -> timeline.t1: "TCP SYN"
  nodes.e -> timeline.t1: "TCP SYN"

  spike_monitor: "Network Ingress (Mbps)" {
    shape: parallelogram
    label: "CRITICAL SPIKE: 5.0Gbps"
    style: {
      fill: "#EF4444"
      stroke: "#B91C1C"
      font-color: white
      bold: true
    }
  }

  timeline.t1 -> spike_monitor: "Packet Buffer Overflow"
  
  # Logic Note (Removed 'near' to fix compilation error)
  note_logic: |md
    ### Storm Mechanism
    When `last_sync + interval <= current_time`,
    all nodes trigger simultaneously.
    Result: **p99 Latency degradation.**
  | {
    style: {
      fill: "#FEF3C7"
      stroke: "#F59E0B"
      border-radius: 8
    }
  }
}

# --- SECTION 2: MITIGATION SCENARIO ---
section_jitter: "SCENARIO B: With 10% Jitter (Probabilistic Distribution)" {
  style: {
    fill: "#ECFDF5"
    stroke: "#10B981"
    stroke-width: 4
  }

  timeline_j: "System Clock (ms)" {
    shape: sql_table
    t0: "0000ms" {constraint: "T_BASE"}
    t1: "1000ms" {constraint: "WINDOW_START"}
    t1_1: "1050ms" {constraint: "JITTER_OFFSET"}
    t1_2: "1100ms" {constraint: "WINDOW_END"}
  }

  nodes_j: "Fleet Nodes [J-O]" {
    grid-columns: 1
    j: "Node_J1" {style.fill: "#6EE7B7"}
    k: "Node_J2" {style.fill: "#6EE7B7"}
    l: "Node_J3" {style.fill: "#6EE7B7"}
    m: "Node_J4" {style.fill: "#6EE7B7"}
    n: "Node_J5" {style.fill: "#6EE7B7"}
  }

  # Nodes spread across the window
  nodes_j.j -> timeline_j.t1: "1002ms"
  nodes_j.k -> timeline_j.t1_1: "1048ms"
  nodes_j.l -> timeline_j.t1_1: "1062ms"
  nodes_j.m -> timeline_j.t1_2: "1091ms"
  nodes_j.n -> timeline_j.t1_2: "1110ms"

  smooth_monitor: "Network Ingress (Mbps)" {
    shape: parallelogram
    label: "NOMINAL: 0.8Gbps"
    style: {
      fill: "#10B981"
      stroke: "#065F46"
      font-color: white
    }
  }

  timeline_j.t1 -> smooth_monitor: "Linear Utilization"
  timeline_j.t1_2 -> smooth_monitor

  # Corrected positioning by removing illegal 'near' and keeping context
  note_jitter: |md
    ### Jitter Advantage
    `delay = rand(0, 0.1 * interval)`
    Requests are decorrelated.
    Result: **Higher throughput.**
  | {
    style: {
      fill: "#D1FAE5"
      stroke: "#10B981"
      border-radius: 8
    }
  }
}

# --- FOOTER ANNOTATION ---
jitter_spec: |md
  ## Implementation Logic (pseudocode)
  go
  func calculateNextSync(baseInterval time.Duration, jitter float64) time.Duration {
      // jitter is percentage (e.g., 0.1 for 10%)
      variation := float64(baseInterval) * jitter * rand.Float64()
      return baseInterval + time.Duration(variation)
  }
  
  **Expected Outcome:**
  - **Bandwidth:** Peak reduced by ~80%
  - **Server Load:** Uniform distribution across time-series buckets
  - **Retries:** Exponential backoff + jitter prevents recursive storms
| {
  near: bottom-center
  style: {
    fill: "#F3F4F6"
    stroke: "#374151"
    font-size: 14
    stroke-width: 2
  }
}

# Connection between sections to show transition
section_no_jitter -> section_jitter: "Apply Jitter Filter" {
  style: {
    stroke-width: 4
    stroke: "#3B82F6"
    animated: true
  }
}