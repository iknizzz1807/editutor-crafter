vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Algorithm Steps: LWW Conflict Resolution
| {near: top-center}
direction: right
Before: "BEFORE: Conflict Detected" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.border-radius: 8
  Local: "Local Entry\n\nKey: \"config\"\nValue: \"timeout=30s\"\nVersion: 5\nNodeID: node-A" {
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    style.stroke-width: 2
    style.border-radius: 6
  }
  Remote: "Remote Entry\n\nKey: \"config\"\nValue: \"timeout=60s\"\nVersion: 5\nNodeID: node-B" {
    style.fill: "#E6E6FA"
    style.stroke: "#9370DB"
    style.stroke-width: 2
    style.border-radius: 6
  }
  vs: "VS" {
    shape: text
    style.font-size: 24
    style.bold: true
    style.font-color: "#CC0000"
  }
}
Step1: "STEP 1: Version Comparison" {
  style.fill: "#F0F8FF"
  style.stroke: "#4682B4"
  style.border-radius: 8
  check: "Check Versions" {
    shape: diamond
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
    style.stroke-width: 2
  }
  result1: "local.Version == remote.Version\n\n5 == 5 ✓" {
    style.fill: "#98FB98"
    style.stroke: "#228B22"
    style.border-radius: 6
    style.bold: true
  }
  note1: |md
    Versions are **EQUAL**
    → Cannot resolve by version alone
    → Proceed to tiebreaker
  | {
    shape: text
    style.font-color: "#333333"
  }
}
Step2: "STEP 2: NodeID Tiebreaker" {
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  style.border-radius: 8
  compare: "Compare NodeIDs\n(String Comparison)" {
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    style.border-radius: 6
  }
  comparison: "node-A < node-B ?\n\n'A' (0x41) < 'B' (0x42)\n\nTRUE ✓" {
    style.fill: "#98FB98"
    style.stroke: "#228B22"
    style.border-radius: 6
    style.bold: true
  }
  rule: |md
    **Tiebreaker Rule:**
    Higher NodeID wins
    node-B > node-A
    → **Remote wins**
  | {
    shape: text
    style.font-color: "#333333"
  }
}
After: "AFTER: Resolution Complete" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.border-radius: 8
  Winner: "WINNER: Remote Entry\n\nKey: \"config\"\nValue: \"timeout=60s\"\nVersion: 5\nNodeID: node-B" {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    style.stroke-width: 3
    style.border-radius: 6
    style.bold: true
  }
  Discarded: "DISCARDED: Local Entry\n\nValue: \"timeout=30s\"\n(NodeID: node-A lost tiebreaker)" {
    style.fill: "#D3D3D3"
    style.stroke: "#999999"
    style.stroke-dash: 3
    style.border-radius: 6
    style.opacity: 0.6
  }
}
Legend: "LWW Resolution Rules" {
  near: bottom-center
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  style.border-radius: 8
  R1: "Rule 1: Higher Version → Wins" {
    shape: text
    style.font-color: "#333333"
  }
  R2: "Rule 2: Equal Version → Higher NodeID Wins" {
    shape: text
    style.font-color: "#228B22"
    style.bold: true
  }
  deterministic: "Result is DETERMINISTIC\nAll nodes reach same conclusion" {
    shape: text
    style.font-color: "#4682B4"
    style.italic: true
  }
}
Before.Local -> Before.vs
Before.vs -> Before.Remote
Before -> Step1: versions equal?
Step1.check -> Step1.result1: equal
Step1.result1 -> Step1.note1
Step1 -> Step2: apply tiebreaker
Step2.compare -> Step2.comparison
Step2.comparison -> Step2.rule
Step2 -> After: resolve
After.Winner -> After.Discarded: replaces
Step1.note1 -> Step2.compare: {
  style.stroke-dash: 3
  style.stroke: "#666666"
}