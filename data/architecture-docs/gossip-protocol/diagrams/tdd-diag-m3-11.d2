vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Merkle Tree Difference Detection
  Hash changes propagate from modified leaves to root
| {near: top-center}
direction: right
# Tree A (Local)
TreeA: Local Tree {
  style.fill: "#E8F4F8"
  style.stroke: "#4A90A4"
  # Root level
  TreeA.Root: "Root Hash\n0x7F3A" {
    shape: rectangle
    style.fill: "#B5AFF6"
    style.stroke: "#7B68EE"
    style.bold: true
    width: 100
  }
  # Level 1
  TreeA.L1_AB: "H(AB)\n0xC4E2" {
    shape: rectangle
    style.fill: "#DEE1EB"
    style.stroke: "#8899AA"
    width: 80
  }
  TreeA.L1_CD: "H(CD)\n0x3D7F" {
    shape: rectangle
    style.fill: "#B5AFF6"
    style.stroke: "#7B68EE"
    style.bold: true
    width: 80
  }
  # Level 2 (leaves)
  TreeA.LeafA: "H(A)\nkey='a'\nv=1" {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#4A90A4"
    width: 70
  }
  TreeA.LeafB: "H(B)\nkey='b'\nv=2" {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#4A90A4"
    width: 70
  }
  TreeA.LeafC: "H(C)\nkey='c'\nv=3" {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#4A90A4"
    width: 70
  }
  TreeA.LeafD: "H(D)\nkey='d'\nv=4" {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#4A90A4"
    width: 70
  }
  # Connections
  TreeA.Root -> TreeA.L1_AB
  TreeA.Root -> TreeA.L1_CD
  TreeA.L1_AB -> TreeA.LeafA
  TreeA.L1_AB -> TreeA.LeafB
  TreeA.L1_CD -> TreeA.LeafC
  TreeA.L1_CD -> TreeA.LeafD
}
# Tree B (Remote)
TreeB: Remote Tree {
  style.fill: "#FFF5E6"
  style.stroke: "#E08040"
  # Root level
  TreeB.Root: "Root Hash\n0x9B2C" {
    shape: rectangle
    style.fill: "#FFB366"
    style.stroke: "#E08040"
    style.bold: true
    width: 100
  }
  # Level 1
  TreeB.L1_AB: "H(AB)\n0xC4E2" {
    shape: rectangle
    style.fill: "#DEE1EB"
    style.stroke: "#8899AA"
    width: 80
  }
  TreeB.L1_CD: "H(CD)\n0xA145" {
    shape: rectangle
    style.fill: "#FFB366"
    style.stroke: "#E08040"
    style.bold: true
    width: 80
  }
  # Level 2 (leaves)
  TreeB.LeafA: "H(A)\nkey='a'\nv=1" {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#4A90A4"
    width: 70
  }
  TreeB.LeafB: "H(B)\nkey='b'\nv=2" {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#4A90A4"
    width: 70
  }
  TreeB.LeafC: "H(C)\nkey='c'\nv=5" {
    shape: rectangle
    style.fill: "#FF6B6B"
    style.stroke: "#CC0000"
    style.bold: true
    width: 70
  }
  TreeB.LeafD: "H(D)\nkey='d'\nv=4" {
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#4A90A4"
    width: 70
  }
  # Connections
  TreeB.Root -> TreeB.L1_AB
  TreeB.Root -> TreeB.L1_CD
  TreeB.L1_AB -> TreeB.LeafA
  TreeB.L1_AB -> TreeB.LeafB
  TreeB.L1_CD -> TreeB.LeafC
  TreeB.L1_CD -> TreeB.LeafD
}
# Highlight differing subtree
DifferingSubtree: Differing Subtree (C-D branch) {
  shape: rectangle
  style: {
    fill: transparent
    stroke: "#CC0000"
    stroke-dash: 5
    stroke-width: 3
  }
}
# Root comparison
RootComparison: Compare Root Hashes {
  shape: diamond
  style.fill: "#FFF"
  style.stroke: "#333"
}
TreeA.Root -> RootComparison: "0x7F3A"
RootComparison -> TreeB.Root: "0x9B2C"
RootComparison.Label: |md
  **DIFFER**
  Roots don't match
  → Recurse to find diff
|
RootComparison.Label.near: top-center
# Diff result
DiffResult: |md
  ## Diff Result
  **Differing keys:** `c`
  **Local:** v=3
  **Remote:** v=5
  Resolution: Accept remote (higher version)
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FFF0F0"
    stroke: "#CC0000"
    border-radius: 8
  }
}
# Legend
Legend: {
  near: bottom-right
  style.fill: transparent
  style.stroke: "#666"
  SameNode: Unchanged {
    shape: rectangle
    style.fill: "#DEE1EB"
  }
  ChangedNode: Hash Changed {
    shape: rectangle
    style.fill: "#FFB366"
  }
  ModifiedLeaf: Modified Entry {
    shape: rectangle
    style.fill: "#FF6B6B"
  }
  SameLeaf: Unchanged Entry {
    shape: rectangle
    style.fill: "#C7F1FF"
  }
  SameNode -> ChangedNode: "Propagates"
  ChangedNode -> ModifiedLeaf: "Identified"
}