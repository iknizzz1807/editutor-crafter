vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Sequence Diagram: Full Anti-Entropy Exchange
  Bidirectional Push-Pull Synchronization Protocol
| {near: top-center}

shape: sequence_diagram

# Define participants
Node_A: Node A {
  style.fill: "#C7F1FF"
}
Node_B: Node B {
  style.fill: "#E4DBFE"
}

# Phase 1: Digest Exchange
Phase_1: "Phase 1: Digest Exchange" {
  Node_A -> Node_B: "DigestRequest {Mode: 0x00, RequesterVersion: clock_A}"
  Node_B -> Node_A: "DigestRequest {Mode: 0x00, RequesterVersion: clock_B}"
}

# Phase 2: Digest Comparison (at each node)
Phase_2: "Phase 2: Digest Comparison" {
  Node_A.compare: "Compare incoming digest vs local"
  Node_A.compare: |md
    - For each key in local:
      - if !remote: add to theyNeed
      - elif remote > local: add to weNeed
  |

  Node_B.compare: "Compare incoming digest vs local"
  Node_B.compare: |md
    - For each key in local:
      - if !remote: add to theyNeed
      - elif remote > local: add to weNeed
  |
}

# Phase 3: Response Exchange
Phase_3: "Phase 3: Response Exchange" {
  Node_A -> Node_B: "DigestResponse {NewerKeys: {}, MissingKeys: theyNeed_A}"
  Node_B -> Node_A: "DigestResponse {NewerKeys: {}, MissingKeys: theyNeed_B}"
}

# Phase 4: State Exchange
Phase_4: "Phase 4: State Exchange" {
  Node_A -> Node_B: "StateResponse {Entries: [Data], ChunkInfo: >64KB}"
  Node_B -> Node_A: "StateResponse {Entries: [Data], ChunkInfo: >64KB}"
}

# Phase 5: Apply with LWW Resolution
Phase_5: "Phase 5: Apply with LWW Resolution" {
  Node_A.apply: "LWW Resolution"
  Node_A.apply: |md
    - entry.Version > local.Version -> Accept
    - entry.Version == local.Version:
      - entry.NodeID > local.NodeID -> Accept
    - Update Lamport clock
  |

  Node_B.apply: "LWW Resolution"
  Node_B.apply: |md
    - entry.Version > local.Version -> Accept
    - entry.Version == local.Version:
      - entry.NodeID > local.NodeID -> Accept
    - Update Lamport clock
  |
}

# Completion
Complete: "Sync Complete" {
  Node_A.status: "State converged"
  Node_B.status: "State converged"
}

# Wire format annotations
Wire_Format_Annotation: |md
  ### Message Types
  - **0x20** DigestRequest (full/Merkle mode)
  - **0x21** DigestResponse (NewerKeys + MissingKeys)
  - **0x22** StateRequest (key list)
  - **0x23** StateResponse (EntryDigest array)

  ### Conflict Resolution
  **Last-Write-Wins (LWW)**:
  1. Higher Version wins
  2. Equal Version → higher NodeID wins

  ### Timing
  - Single round-trip for digest exchange
  - Parallel state transfer in both directions
  - Convergence: O(anti_entropy_interval)
| {near: bottom-center}

# Styling
(Phase_1 -> Phase_5).style.stroke: gray
(Phase_1 -> Phase_5).style.stroke-dash: 2
Node_A.status.style.fill: "#ACE1AF"
Node_B.status.style.fill: "#ACE1AF"