vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Module Architecture: SWIM Failure Detector
| {near: top-center}
direction: right
FailureDetector: {
  style.fill: "#E8D5F2"
  style.stroke: "#7B4B94"
  style.bold: true
  label: "SWIM FailureDetector\n\nManages periodic probing with\ndirect ping → indirect probes →\nsuspicion → death cascade"
  Config: {
    shape: class
    ProtocolPeriod: time.Duration
    PingTimeout: time.Duration
    IndirectFanout: int
    SuspicionTimeoutMult: int
    PiggybackSize: int
  }
  PendingPings: {
    shape: class
    "pendingPings": "sync.Map"
    "pendingPingReqs": "sync.Map"
  }
  Suspicions: {
    shape: class
    "suspicions": "sync.Map"
    "nodeID → *Suspicion"
  }
  PiggybackBuffer: {
    shape: class
    "events": "[]MemberEvent"
    "priority": "[]MemberEvent"
    "seen": "map[string]uint64"
    "AddEvent(e)"
    "AddPriorityEvent(e)"
    "GetEvents() []MemberEvent"
  }
  Metrics: {
    shape: class
    TotalProbes: atomic.Uint64
    SuccessfulProbes: atomic.Uint64
    FailedProbes: atomic.Uint64
    Suspicions: atomic.Uint64
    Refutations: atomic.Uint64
  }
}
Suspicion: {
  style.fill: "#FFF9C9"
  style.stroke: "#9E2146"
  label: "Suspicion\n\nTracks suspected peer\nwith timeout timer"
  struct: {
    shape: class
    NodeID: string
    SuspectTime: time.Time
    Incarnation: uint64
    Confirmations: "map[string]bool"
    Timer: "*time.Timer"
    Done: "chan struct{}"
  }
}
MemberEvent: {
  style.fill: "#FFE7CB"
  style.stroke: "#8B4513"
  label: "MemberEvent\n\nPiggybacked on all\nSWIM messages"
  struct: {
    shape: class
    NodeID: string
    Address: string
    Port: int
    State: PeerState
    Incarnation: uint64
    Timestamp: int64
  }
}
ProtocolMessages: {
  style.fill: "#DEE1EB"
  Ping: {
    shape: class
    label: "PingBody (0x30)"
    SeqNum: uint64
    TargetID: string
    Piggyback: "[]MemberEvent"
  }
  PingReq: {
    shape: class
    label: "PingReqBody (0x31)"
    SeqNum: uint64
    TargetID: string
    Piggyback: "[]MemberEvent"
  }
  Ack: {
    shape: class
    label: "AckBody (0x32)"
    SeqNum: uint64
    TargetID: string
    FromID: string
    Piggyback: "[]MemberEvent"
  }
}
PeerList: {
  style.fill: "#ACE1AF"
  style.stroke: "#2E7D32"
  label: "PeerList\n(from M1)"
  methods: {
    shape: class
    GetRandomPeers(k): "[]*Peer"
    SetState(id, state, inc)
    UpdateLastSeen(id)
    GetPeer(id): "*Peer"
  }
}
UDPConn: {
  shape: diamond
  style.fill: "#B6DDF6"
  style.stroke: "#1565C0"
  label: "UDP\nConnection\n\nnet.UDPConn"
}
FailureDetector.Config -- FailureDetector
FailureDetector.PendingPings -- FailureDetector
FailureDetector.Suspicions -- FailureDetector
FailureDetector.PiggybackBuffer -- FailureDetector
FailureDetector.Metrics -- FailureDetector
FailureDetector.Suspicions -> Suspicion: "creates & tracks"
FailureDetector.PiggybackBuffer -> MemberEvent: "stores"
ProtocolMessages.Ping -> MemberEvent: "contains"
ProtocolMessages.PingReq -> MemberEvent: "contains"
ProtocolMessages.Ack -> MemberEvent: "contains"
FailureDetector <-> PeerList: "reads peers\nupdates state" {
  style.stroke-dash: 3
  style.stroke: "#2E7D32"
}
FailureDetector <-> UDPConn: "sends pings\nreceives acks" {
  style.stroke: "#1565C0"
  style.animated: true
}
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  direct: "Direct Ping (solid)"
  indirect: "Indirect Probe (dashed)"
  piggyback: "Piggyback (dotted)"
  direct_line: {
    shape: text
    label: "──▶ owns/creates"
  }
  indirect_line: {
    shape: text
    label: "- - ▶ references"
  }
  piggyback_line: {
    shape: text
    label: "· · · contains"
  }
}