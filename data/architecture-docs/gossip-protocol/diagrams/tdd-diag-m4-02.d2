vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |'md
# SWIM Protocol Period Structure
### Scalable Weakly-consistent Infection-style Process Group Membership Protocol
*One round: O(1) bandwidth per node regardless of cluster size*
'| {
  near: top-center
}

# Lifecycle Phases Container
phases: {
  grid-columns: 5
  grid-gap: 50
  
  phase1: "1. SELECT PEER\n\nMethod: GetRandomPeers(1)\nFilter: Exclude Self\nExclude Suspected" {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
    width: 240
    height: 160
  }
  
  phase2: "2. DIRECT PING\n\nPayload: Ping(seqNum, G)\nTimer: t_ping (500ms)\nWaiting: Ack(seqNum)" {
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
    width: 240
    height: 160
  }
  
  phase3: "3. INDIRECT PROBES\n\nPayload: PingReq(target, k=3)\nFan-out: Parallel Probes\nTimer: t_ping_req (1000ms)" {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
    width: 240
    height: 160
  }
  
  phase4: "4. MARK SUSPECT\n\nState: Local Suspicion\nTimer: t_suspicion\nAdd to Piggyback List" {
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
    }
    width: 240
    height: 160
  }
  
  phase5: "5. PIGGYBACK\n\nDissemination: Gossip\nEncapsulation: MemberEvent\nLimit: Max 10 per packet" {
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
    }
    width: 240
    height: 160
  }
}

# Flow Sequence
phases.phase1 -> phases.phase2: "Peer Selected" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

phases.phase2 -> phases.phase3: "Timeout\n(No Direct Ack)" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
    stroke-dash: 3
  }
}

phases.phase3 -> phases.phase4: "All Indirect\nProbes Failed" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
    stroke-dash: 3
  }
}

phases.phase4 -> phases.phase5: "Update Cluster\nState" {
  style: {
    stroke: "#9C27B0"
    stroke-width: 2
  }
}

# Success Recovery Paths
phases.phase2 -> phases.phase1: "Direct Ack → ALIVE" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
    animated: true
  }
}

# Indirect Success Junction
indirect_success: "Indirect Ack Received\n→ Confirm ALIVE" {
  shape: diamond
  style: {
    fill: "#C8E6C9"
    stroke: "#4CAF50"
  }
  width: 200
  height: 120
}

phases.phase3 -> indirect_success: "Any k-peer\nreturns Ack" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
    animated: true
  }
}

indirect_success -> phases.phase1: "Reset Period" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

# Timing and Resource Metadata
timing_annotation: {
  near: bottom-center
  style.stroke-width: 0
  # Using |'md ... '| to handle nested pipes in the markdown table
  explanation: |'md
### Protocol Period Configuration (T_p)

| Parameter | Default Value | Description |
| :--- | :--- | :--- |
| **T_p** | 1000ms | Total Protocol Period length |
| **t_ping** | 500ms | Wait time for direct probe response |
| **k** | 3 | Number of intermediary nodes for PingReq |
| **Fan-out** | log(N) | Gossip dissemination factor |

**Bandwidth Analysis:**
- Network Load: `1 * UDP_Packet_Size` per period.
- O(1) per node: Independent of total cluster size `N`.
- Packet Size: ~512 bytes (including IP/UDP headers + 10 gossip items).
'|
}

# Member State Legend
outcomes: {
  near: top-right
  style: {
    fill: "#FAFAFA"
    stroke: "#E0E0E0"
    shadow: true
  }
  
  header: "MEMBER STATES" {
    style: {
      fill: "#ECEFF1"
      bold: true
      text-transform: uppercase
    }
  }
  
  state_alive: "✓ ALIVE" {
    style: {
      fill: "#C8E6C9"
      font-color: "#1B5E20"
      bold: true
    }
  }
  
  state_suspect: "⚠ SUSPECT" {
    style: {
      fill: "#FFF9C4"
      font-color: "#F57F17"
      bold: true
    }
  }
  
  state_dead: "☠ DEAD" {
    style: {
      fill: "#FFCDD2"
      font-color: "#B71C1C"
      bold: true
    }
  }
}

# Annotate constraints
phases.phase4 -> outcomes.state_dead: "Timer t_suspicion\nexpired" {
  style: {
    stroke: "#F44336"
    stroke-dash: 5
  }
}