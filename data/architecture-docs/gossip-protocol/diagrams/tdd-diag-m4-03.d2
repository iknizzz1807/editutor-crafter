vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SWIM Indirect Probe (Ping-Req) Path
  Multi-path failure detection with k=3 indirect probes
| {near: top-center}
direction: right
classes: {
  node: {
    shape: rectangle
    width: 120
    height: 60
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      font: mono
    }
  }
  suspect: {
    shape: rectangle
    width: 120
    height: 60
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      font: mono
    }
  }
  probe_msg: {
    style: {
      stroke: "#7B1FA2"
      stroke-width: 2
      animated: true
    }
  }
  ack_msg: {
    style: {
      stroke: "#2E7D32"
      stroke-width: 2
      animated: true
    }
  }
}
# Nodes
NodeA: "Node A\n(Prober)" {
  class: node
  style.fill: "#E8F5E9"
}
helpers: "Indirect Probe Helpers (k=3)" {
  style: {
    fill: transparent
    stroke: "#7B1FA2"
    stroke-dash: 3
  }
  NodeC: "Node C\n(Helper 1)" {
    class: node
  }
  NodeD: "Node D\n(Helper 2)" {
    class: node
  }
  NodeE: "Node E\n(Helper 3)" {
    class: node
  }
}
NodeB: "Node B\n(Target)" {
  class: suspect
}
# Phase 1: Ping-Req from A to helpers
NodeA -> helpers.NodeC: "PingReq(B)" {
  class: probe_msg
  label: "1a: ping-req\nseq=42"
}
NodeA -> helpers.NodeD: "PingReq(B)" {
  class: probe_msg
  label: "1b: ping-req\nseq=42"
}
NodeA -> helpers.NodeE: "PingReq(B)" {
  class: probe_msg
  label: "1c: ping-req\nseq=42"
}
# Phase 2: Helpers probe target B
helpers.NodeC -> NodeB: "Ping(B)" {
  class: probe_msg
  label: "2a: direct\nprobe"
}
helpers.NodeD -> NodeB: "Ping(B)" {
  class: probe_msg
  label: "2b: direct\nprobe"
}
helpers.NodeE -> NodeB: "Ping(B)" {
  class: probe_msg
  label: "2c: direct\nprobe"
}
# Phase 3: Target B responds to helpers
NodeB -> helpers.NodeC: "Ack" {
  class: ack_msg
  label: "3a: seq=42"
}
NodeB -> helpers.NodeD: "Ack" {
  class: ack_msg
  label: "3b: seq=42"
}
NodeB -> helpers.NodeE: "Ack" {
  class: ack_msg
  label: "3c: seq=42"
}
# Phase 4: Helpers forward ack to prober A
helpers.NodeC -> NodeA: "Ack(B alive)" {
  class: ack_msg
  label: "4a: forward\nack"
}
helpers.NodeD -> NodeA: "Ack(B alive)" {
  class: ack_msg
  label: "4b: forward\nack"
}
helpers.NodeE -> NodeA: "Ack(B alive)" {
  class: ack_msg
  label: "4c: forward\nack"
}
# Legend
legend: "Protocol Flow" {
  near: bottom-center
  step1: "Step 1: A sends ping-req to k helpers" {
    shape: text
    style.font-size: 14
  }
  step2: "Step 2: Each helper probes B directly" {
    shape: text
    style.font-size: 14
  }
  step3: "Step 3: B responds to each helper" {
    shape: text
    style.font-size: 14
  }
  step4: "Step 4: Any helper success = B is ALIVE" {
    shape: text
    style.font-size: 14
    style.font-color: "#2E7D32"
    style.bold: true
  }
}
# Failure probability annotation
prob: |md
  **False Positive Reduction**
  With packet loss rate `p` and `k` helpers:
  `P(false positive) = p^(2k)`
  For p=5%, k=3: `0.05^6 ≈ 0.0000000156`
  vs. direct probe only: `0.05 = 5%`
| {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#F9A825"
    font-size: 12
  }
}