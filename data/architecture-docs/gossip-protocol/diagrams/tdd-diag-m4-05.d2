vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
Node_A: "Node A\n(Detector)"
Node_B: "Node B\n(Suspected)"
Node_C: "Node C\n(Witness 1)"
Node_D: "Node D\n(Witness 2)"
# Phase 1: Initial suspicion
phase1: "Phase 1: Initial Suspicion"
Node_A -> Node_B: "Ping (seq=1001)"
Node_B -> Node_A: "Ack (seq=1001)"
Node_A.note: "B responding normally"
# Phase 2: A detects timeout and suspects B
phase2: "Phase 2: Suspicion Declaration"
Node_A -> Node_A: "Ping timeout\nIndirect probes fail"
Node_A -> Node_C: "SUSPECT(B, inc=5)"
Node_A -> Node_D: "SUSPECT(B, inc=5)"
Node_C.note: "Records:\nB→SUSPECT(inc=5)"
Node_D.note: "Records:\nB→SUSPECT(inc=5)"
# Phase 3: B receives suspicion and refutes
phase3: "Phase 3: Refutation (Self-Defense)"
Node_C -> Node_B: "SUSPECT(B, inc=5)\n(piggybacked)"
Node_B.note: "SEES SUSPECT about self!\nincarnation=5"
Node_B -> Node_B: "incrementIncarnation()\n5 → 6"
# Phase 4: B broadcasts ALIVE with higher incarnation
phase4: "Phase 4: ALIVE Broadcast"
Node_B -> Node_A: "ALIVE(B, inc=6)"
Node_B -> Node_C: "ALIVE(B, inc=6)"
Node_B -> Node_D: "ALIVE(B, inc=6)"
# Phase 5: A receives and accepts refutation
phase5: "Phase 5: Refutation Accepted"
Node_A.note: "Receives ALIVE(inc=6)\n6 > 5 → ACCEPT"
Node_A -> Node_A: "SetState(B, ALIVE, inc=6)"
Node_A -> Node_C: "ALIVE(B, inc=6)\n(propagated)"
Node_A -> Node_D: "ALIVE(B, inc=6)\n(propagated)"
# Final state
final: "Final State: B→ALIVE(inc=6) on all nodes"