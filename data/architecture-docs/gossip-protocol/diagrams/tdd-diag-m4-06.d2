vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

classes: {
  container: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      border-radius: 8
    }
  }
  queue_data: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 4
    }
  }
  priority: {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      border-radius: 4
    }
  }
  seen_map_style: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 4
    }
  }
  arrow_flow: {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
      animated: true
    }
  }
  method_item: {
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      border-radius: 4
      font: mono
      font-size: 14
    }
  }
  header_field: {
    style: {
      fill: "#9575CD"
      font-color: white
      bold: true
    }
  }
}

title: |md
  # Piggyback Buffer Structure
  Priority-Based Dissemination for Gossip Membership Events
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

buffer: PiggybackBuffer {
  class: container
  width: 700
  height: 600

  mu: "sync.RWMutex" {
    shape: rectangle
    class: header_field
    style: {
      font: mono
      bold: true
      border-radius: 4
    }
  }

  priority_queue: "Priority Store (Reserved Slots)" {
    class: priority
    tooltip: "Reserved slots for local refutations and critical updates"
    
    slot0: "Refutation Slot (LIFO)" { class: priority; style.bold: true }
    slot1: "Critical Update 1" { class: priority }
    slot2: "Critical Update 2" { class: priority }
    
    label.near: top-center
  }

  regular_queue: "Regular Buffer (FIFO)" {
    class: queue_data
    tooltip: "FIFO storage for standard gossip dissemination"
    
    r0: "Standard Event N"
    r1: "Standard Event N-1"
    r_dots: "..." { shape: text }
    r_tail: "Standard Event 0"
    
    label.near: top-center
  }

  seen_map: "Seen Map (Deduplication State)" {
    class: seen_map_style
    tooltip: "State map to ensure we don't disseminate stale information"
    
    map_entry: "NodeID → {Incarnation, LastSeen}" {
      style.font: mono
    }
  }
}

methods: "Implementation Interface" {
  class: container
  width: 450

  add_event: "AddEvent(event)" {
    class: method_item
    description: "Dedup vs seen_map; push to Regular FIFO"
  }
  add_priority: "AddPriorityEvent(event)" {
    class: method_item
    description: "Immediate Head-injection; Evict oldest if > 3"
  }
  get_events: "GetEvents(count) -> []Event" {
    class: method_item
    description: "Yield Priority [0:3] then Regular [0:N]"
  }

  add_event -> add_priority: "Upgrades if Refutation" {
    style.stroke-dash: 3
  }
}

# Relationship between State and Methods
buffer.priority_queue <-> methods.add_priority
buffer.regular_queue <-> methods.add_event
buffer.seen_map <- methods.add_event: "Lookup/Update"

event_flow: "Upstream Event Generator" {
  class: container
  
  alive_event: "EVENT: ALIVE (Local)\nIncarnation: 101" {
    class: priority
    style.stroke-width: 4
  }
  suspect_event: "EVENT: SUSPECT (Peer_B)\nIncarnation: 55" {
    class: queue_data
    style.fill: "#FFEBEE"
  }
  dead_event: "EVENT: DEAD (Peer_C)\nIncarnation: 12" {
    class: queue_data
    style.fill: "#ECEFF1"
  }

  alive_event -> suspect_event: "T+1"
  suspect_event -> dead_event: "T+2"
}

event_flow -> buffer: "Ingest (Lock mu)" {
  class: arrow_flow
}

buffer_out: "Serialized Result (Gossip Packet)" {
  class: container
  direction: right

  out_p1: "ALIVE (Self)" { class: priority; style.double-border: true }
  out_r1: "SUSPECT (B)" { class: queue_data }
  out_r2: "DEAD (C)" { class: queue_data }

  out_p1 -> out_r1: "Next"
  out_r1 -> out_r2: "Next"
}

buffer -> buffer_out: "Dispatch (Lock mu)" {
  class: arrow_flow
}

wire: "Packet Wire Layout (MemberEvent)" {
  class: container
  
  byte_layout: {
    grid-columns: 8
    grid-gap: 0
    
    h0: "0x00" { class: header_field }
    h1: "0x01" { class: header_field }
    h2: "..." { class: header_field }
    h3: "var" { class: header_field }
    h4: "var+1" { class: header_field }
    h5: "var+2" { class: header_field }
    h6: "var+10" { class: header_field }
    h7: "var+18" { class: header_field }

    f0: "IDLen" { style.fill: "#D1C4E9" }
    f1: "NodeID (Bytes)" { style.fill: "#E1F5FE"; grid-columns: 2 }
    f2: "AddrLen" { style.fill: "#D1C4E9" }
    f3: "Addr" { style.fill: "#E1F5FE" }
    f4: "Port" { style.fill: "#FFF9C4" }
    f5: "Incarn" { style.fill: "#C8E6C9"; grid-columns: 2 }
  }

  wire_table: ||md
  | Offset | Field | Size | Details |
  | :--- | :--- | :--- | :--- |
  | 0x00 | NodeIDLen | 1B | Length of ID |
  | 0x01 | NodeID | var | UTF-8 String |
  | var | Port | 2B | Network Port |
  | var+2| Incarnation| 8B | uint64 counter |
  ||
  wire_table.shape: text
}

eviction: "Eviction Logic & Invariants" {
  class: container
  
  regular_policy: "Regular Store: FIFO" {
    shape: rectangle
    style.fill: "#E3F2FD"
    tooltip: "Pop oldest when buffer_size > N-3"
  }
  
  priority_policy: "Priority Store: Fixed Cap=3" {
    shape: rectangle
    style.fill: "#FFF3E0"
    tooltip: "Local refutations overwrite slot 0"
  }

  invariants: ||md
  - **Inv-1**: Priority events never drop to Regular store.
  - **Inv-2**: Seen Map entry must be pruned if Event is evicted.
  - **Inv-3**: Refutation (Local) always has highest precedence.
  ||
  invariants.shape: text
}

# Final Flow and Layout Positioning
event_flow -> buffer
buffer -> methods
buffer -> buffer_out
buffer_out -> wire
eviction -> buffer: "Applied to" { 
  style.stroke-dash: 4
  style.stroke: "#7B1FA2"
}
wire.near: bottom-center<ctrl63>