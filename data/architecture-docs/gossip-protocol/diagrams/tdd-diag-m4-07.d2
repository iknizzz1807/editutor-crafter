layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    primary: "#2563EB"
    secondary: "#64748B"
    accent: "#9333EA"
    background: "#F5F5F5"
    text: "#333333"
    border: "#1E3A8A"
    success: "#4CAF50"
    warning: "#F59E0B"
    error: "#EF4444"
    header: "#1E3A8A"
    container: "#E5E7EB"
    node: "#DBEAFE"
    node-active: "#D1FADF"
    node-suspect: "#FEF3C7"
    node-dead: "#FEE22F"
    transport-sim: "#E8F5E8"
    transport-real: "#E6F3FF"
  }
}

title: |md
  # Integration Test Harness Architecture
  **Technical Design Specification**
| {near: top-center}

# Main Harness Container
Harness: {
  style.fill: ${colors.background}
  style.stroke: ${colors.border}
  style.stroke-width: 2
  
  # Configuration
  Config: HarnessConfig {
    style.fill: ${colors.header}
    style.font-color: white
  }
  
  # Core Components
  TestNodes: "Test Nodes [ ]" {
    style.fill: ${colors.container}
    style.multiple: true
  }
  
  TransportInterface: Transport {
    style.fill: ${colors.container}
  }
  
  Collector: MetricsCollector {
    style.fill: ${colors.container}
  }
}

# Test Node Detail
TestNode: {
  shape: class
  style.fill: ${colors.node}
  nodeID: string
  address: string
  port: int
  "+Store()": "*state.Store"
  "+PeerList()": "*membership.PeerList"
  "+IsAlive()": bool
  "+BlockIncoming(nodeIDs ...string)"
  "+UnblockIncoming(nodeIDs ...string)"
  "+BlockAllIncoming()"
  "+UnblockAllIncoming()"
  "+GetMetrics()": "*NodeMetrics"
  "+Addr()": string
}

# Transport Interface Detail
Transport: {
  shape: class
  style.fill: ${colors.container}
  "+Send(from, to string, data []byte)": error
  "+Receive(nodeID string)": "([]byte, string, error)"
  "+Partition(groups ...[]string)"
  "+Heal()"
  "+SetPacketLoss(rate float64)"
  "+SetDelay(delay time.Duration)"
  "+Close()"
}

# SimulatedTransport Class
SimulatedTransport: {
  shape: class
  style.fill: ${colors.transport-sim}
  "mu": "sync.RWMutex"
  "queues": "map[string]chan *envelope"
  "partitions": "map[string]map[string]bool"
  packetLoss: float64
  delay: "time.Duration"
  "+Register(nodeID string)"
  "+Send(from, to string, data []byte)": error
  "+Receive(nodeID string)": "([]byte, string, error)"
  "+Partition(groups ...[]string)"
  "+Heal()"
  "+SetPacketLoss(rate float64)"
  "+SetDelay(delay time.Duration)"
  "+Close()"
}

# RealTransport Class
RealTransport: {
  shape: class
  style.fill: ${colors.transport-real}
  "conns": "map[string]*net.UDPConn"
  "+Register(nodeID string, conn *net.UDPConn)"
  "+Send(from, to string, data []byte)": error
  "+Receive(nodeID string)": "([]byte, string, error)"
  "+Close()"
}

# MetricsCollector Class
MetricsCollector: {
  shape: class
  style.fill: ${colors.container}
  "mu": "sync.RWMutex"
  "nodeData": "map[string]*NodeMetrics"
  "+RecordSend(nodeID string, bytes int)"
  "+RecordRecv(nodeID string, bytes int)"
  "+GetTotalBytesPerSecond(duration time.Duration)": float64
  "+GetPerNodeStats(nodeID string)": "*NodeMetrics"
  "+GetAllStats()": "map[string]*NodeMetrics"
  "+Reset()"
}

# NodeMetrics Class
NodeMetrics: {
  shape: class
  style.fill: ${colors.node-active}
  BytesSent: uint64
  BytesReceived: uint64
  MessagesSent: uint64
  MessagesReceived: uint64
  UpdatesSent: uint64
  UpdatesReceived: uint64
}

# Config Structs
HarnessConfig: {
  shape: class
  style.fill: ${colors.header}
  ClusterSize: int
  BasePort: int
  UseRealNetwork: bool
  PacketLossRate: float64
  MessageDelay: "time.Duration"
  RandomSeed: int64
}

# Relationships
Harness -> Harness.Config: "owns"
Harness -> TestNode: "manages"
Harness -> Transport: "owns"
Harness -> MetricsCollector: "owns"

TestNode -> "state.Store": "owns"
TestNode -> "membership.PeerList": "owns"
TestNode -> "node.Node": "owns"

Transport <- SimulatedTransport: "implements"
Transport <- RealTransport: "implements"

MetricsCollector -> NodeMetrics: "aggregates"

# Data Flow Annotations
(Harness.Config -> Harness): "input parameters"
(Harness.TestNodes -> TestNode): "lifecycle control"
(Harness.TransportInterface -> Transport): "logical binding"
(Harness.Collector -> MetricsCollector): "data aggregation"

legend: {
  near: bottom-right
  
  Header: {
    style.fill: ${colors.header}
    style.font-color: white
  }
  NodeActive: Active Node {
    style.fill: ${colors.node-active}
  }
  Sim: Simulated Transport {
    style.fill: ${colors.transport-sim}
  }
  Real: UDP Transport {
    style.fill: ${colors.transport-real}
  }
}