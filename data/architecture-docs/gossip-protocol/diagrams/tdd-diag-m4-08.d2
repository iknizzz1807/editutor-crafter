vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Algorithm Steps: SWIM Protocol Round
  M4 Failure Detection - Single Protocol Period
| {near: top-center}
direction: right
before: {
  label: "BEFORE"
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
  peer_list: {
    label: "Peer List"
    style.fill: white
    peer1: "peer-1\nALIVE"
    peer2: "peer-2\nALIVE"
    peer3: "peer-3\nALIVE"
    peer4: "peer-4\nALIVE"
    peer5: "peer-5\nALIVE"
  }
  selection: {
    label: "Selection"
    style.fill: "#FFF9C4"
    sel_text: |md
      GetRandomPeers(1)
      → **target = peer-3**
    |
  }
  peer_list -> selection: "select\nrandom"
}
arrow_before: |md
  ▶
| {style.font-size: 24}
step1: {
  label: "STEP 1: Direct Ping"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  sender: {
    label: "Local Node"
    shape: rectangle
    style.fill: "#BBDEFB"
    ping_msg: |md
      **Ping**
      SeqNum: 1001
      TargetID: peer-3
      Piggyback: [...]
    |
  }
  network: {
    label: "UDP Network"
    shape: diamond
    style.fill: "#E1F5FE"
  }
  target: {
    label: "Target\n(peer-3)"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  timer: {
    label: "Timer"
    shape: circle
    style.fill: "#FFECB3"
    timer_text: "500ms"
  }
  sender -> network: "Ping\nseq=1001" {
    style.stroke: "#1976D2"
    style.stroke-width: 2
    style.animated: true
  }
  network -> target: "Ping\nseq=1001" {
    style.stroke: "#1976D2"
    style.stroke-dash: 3
  }
  sender -> timer: "start"
}
arrow1: |md
  ▶
| {style.font-size: 24}
step2: {
  label: "STEP 2: Check Response"
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
  style.stroke-width: 2
  decision: {
    label: "Ack\nReceived?"
    shape: diamond
    style.fill: "#FFE0B2"
    width: 140
  }
  success: {
    label: "YES\n✓"
    shape: circle
    style.fill: "#C8E6C9"
  }
  timeout: {
    label: "NO\n(TIMEOUT)"
    shape: circle
    style.fill: "#FFCDD2"
  }
  success_action: {
    label: "Update\nLastSeen"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  decision -> success: "within\n500ms" {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  decision -> timeout: ">500ms" {
    style.stroke: "#F44336"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
  success -> success_action: "mark\nALIVE" {
    style.stroke: "#4CAF50"
  }
}
arrow2: |md
  ▶
| {style.font-size: 24}
step3: {
  label: "STEP 3: Indirect Probes"
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  condition: {
    label: "if timeout"
    shape: diamond
    style.fill: "#E1BEE7"
    width: 100
  }
  helpers: {
    label: "Select k=3 Helpers"
    style.fill: white
    h1: "helper-1"
    h2: "helper-2"
    h3: "helper-3"
  }
  pingreq_flow: {
    label: ""
    style.fill: transparent
    local_node: "Local\nNode"
    helper1: "H1"
    helper2: "H2"
    helper3: "H3"
    target: "peer-3"
    local_node -> helper1: "PingReq" {style.stroke: "#9C27B0"; style.stroke-dash: 2}
    local_node -> helper2: "PingReq" {style.stroke: "#9C27B0"; style.stroke-dash: 2}
    local_node -> helper3: "PingReq" {style.stroke: "#9C27B0"; style.stroke-dash: 2}
    helper1 -> target: "Ping" {style.stroke: "#9C27B0"}
    helper2 -> target: "Ping" {style.stroke: "#9C27B0"}
    helper3 -> target: "Ping" {style.stroke: "#9C27B0"}
  }
  result: {
    label: "Any Ack?"
    shape: diamond
    style.fill: "#E1BEE7"
  }
  condition -> helpers: "k=3"
  helpers -> pingreq_flow
  pingreq_flow -> result
}
arrow3: |md
  ▶
| {style.font-size: 24}
step4: {
  label: "STEP 4: Mark Suspect"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 2
  condition2: {
    label: "All probes\nfailed?"
    shape: diamond
    style.fill: "#FFCDD2"
    width: 120
  }
  suspect_action: {
    label: "Mark SUSPECT"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.bold: true
    action_text: |md
      peer-3.State = SUSPECT
      peer-3.Incarnation = 5
      Start timer: 5 * ProtocolPeriod
      Add to PiggybackBuffer
    |
  }
  timer_start: {
    label: "Suspicion\nTimer"
    shape: circle
    style.fill: "#FFEBEE"
    timer_text: |md
      **5 seconds**
      (5 × 1s period)
    |
  }
  condition2 -> suspect_action: "YES" {
    style.stroke: "#C62828"
    style.stroke-width: 2
    style.bold: true
  }
  suspect_action -> timer_start: "start"
}
arrow4: |md
  ▶
| {style.font-size: 24}
after: {
  label: "AFTER"
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
  state_changed: {
    label: "State Updated"
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    updated_list: {
      label: "Peer List"
      style.fill: white
      peer1_a: "peer-1\nALIVE"
      peer2_a: "peer-2\nALIVE"
      peer3_a: |md
        **peer-3**
        **SUSPECT** 🔴
        inc: 5
      |
      peer4_a: "peer-4\nALIVE"
      peer5_a: "peer-5\nALIVE"
    }
    style.fill: white
  }
  piggyback: {
    label: "Piggyback Buffer"
    style.fill: "#FFF9C4"
    event: |md
      MemberEvent:
      - NodeID: peer-3
      - State: SUSPECT
      - Incarnation: 5
    |
  }
  timer_running: {
    label: "Timer Running"
    shape: circle
    style.fill: "#FFEBEE"
    timer_status: |md
      On expiry →
      mark DEAD
    |
  }
  updated_list -> piggyback: "event\nadded"
  piggyback -> timer_running: "waiting"
}
# Flow arrows
before -> arrow_before -> step1 -> arrow1 -> step2 -> arrow2 -> step3 -> arrow3 -> step4 -> arrow4 -> after
legend: {
  near: bottom-center
  style.fill: "#F5F5F5"
  legend_title: "Legend"
  success_path: {
    label: ""
    style.fill: transparent
    s1: "Direct ack"
    s2: "✓"
    s1 -> s2 {style.stroke: "#4CAF50"; style.stroke-width: 2}
  }
  fail_path: {
    label: ""
    style.fill: transparent
    f1: "Timeout"
    f2: "→ indirect"
    f1 -> f2 {style.stroke: "#F44336"; style.stroke-dash: 3}
  }
  suspect_path: {
    label: ""
    style.fill: transparent
    sp1: "All fail"
    sp2: "→ SUSPECT"
    sp1 -> sp2 {style.stroke: "#C62828"; style.stroke-width: 2; style.bold: true}
  }
}