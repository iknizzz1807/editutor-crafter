layout-engine: elk

vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
    pad: 40
  }
  colors: {
    header: "#7C3AED"
    data: "#3B82F6"
    free: "#22C55E"
    padding: "#9CA3AF"
    pointers: "#F59E0B"
    border: "#1F2937"
  }
}

title: "Intel Manual 64-bit Architecture: Gossip Wire Format" {
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# Documentation Metadata Block
metadata: |md
  ### Gossip Protocol Message Format (v2.4.0)
  **Transmission Order:** Network Byte Order (Big Endian)
  **Alignment:** Packed structure, 1-byte granularity.
  **Base Header Size:** 14 bytes + Dynamic NodeID length.
  **Checksumming:** Handled at Transport Layer (TCP/TLS).
| {
  near: title
  style: {
    stroke: "#E5E7EB"
    fill: "#F9FAFB"
    border-radius: 8
  }
}

# Main Message Container
base_message: {
  style.stroke-width: 0
  style.fill: transparent
  
  # Byte Offsets (Left Margin Alignment)
  offsets: {
    grid-columns: 1
    grid-gap: 20
    o0: "0x00" {shape: text; style.font: mono; style.font-size: 18}
    o4: "0x04" {shape: text; style.font: mono; style.font-size: 18}
    o5: "0x05" {shape: text; style.font: mono; style.font-size: 18}
    o6: "0x06" {shape: text; style.font: mono; style.font-size: 18}
    oTs: "0x06 + N" {shape: text; style.font: mono; style.font-size: 18}
    oBody: "0x0E + N" {shape: text; style.font: mono; style.font-size: 18}
  }

  # The Physical Layout
  layout: {
    direction: right
    grid-gap: 0
    
    length: "Length\n(4 Bytes)" {
      style.fill: "${colors.data}"
      style.stroke: "${colors.border}"
      style.stroke-width: 2
      tooltip: "uint32 Big-Endian: Total message length excluding this field"
      width: 140
      height: 120
    }
    
    type: "Type\n(1 Byte)" {
      style.fill: "${colors.header}"
      style.stroke: "${colors.border}"
      style.stroke-width: 2
      tooltip: "MessageType Enum: Determines Body deserialization logic"
      width: 100
      height: 120
    }
    
    node_id_len: "NodeIDLen\n(1 Byte)" {
      style.fill: "${colors.header}"
      style.stroke: "${colors.border}"
      style.stroke-width: 2
      tooltip: "uint8: Length of NodeID string (N)"
      width: 100
      height: 120
    }
    
    node_id: "NodeID\n(N Bytes)" {
      style.fill: "${colors.data}"
      style.stroke: "${colors.border}"
      style.stroke-width: 2
      style.stroke-dash: 3
      tooltip: "UTF-8 Unique Identifier of the originating node"
      width: 180
      height: 120
    }
    
    timestamp: "Timestamp\n(8 Bytes)" {
      style.fill: "${colors.data}"
      style.stroke: "${colors.border}"
      style.stroke-width: 2
      tooltip: "int64: Unix Nanoseconds BE. Used for vector clock drift detection."
      width: 180
      height: 120
    }
    
    body: "Body Payload\n(Variable)" {
      style.fill: "${colors.free}"
      style.stroke: "${colors.border}"
      style.stroke-width: 2
      style.stroke-dash: 5
      tooltip: "Type-specific serialized data (e.g., PeerDigest list for SYNC)"
      width: 250
      height: 120
    }

    # Connections for layout ordering
    length -> type -> node_id_len -> node_id -> timestamp -> body
  }
}

# Field Size Annotations (Right Margin)
field_sizes: {
  near: base_message.layout
  s1: "uint32" {shape: text; near: base_message.layout.length}
  s2: "uint8" {shape: text; near: base_message.layout.type}
  s3: "uint8" {shape: text; near: base_message.layout.node_id_len}
  s4: "string" {shape: text; near: base_message.layout.node_id}
  s5: "int64" {shape: text; near: base_message.layout.timestamp}
  s6: "blob" {shape: text; near: base_message.layout.body}
}

# Secondary Structure: PeerDigest for SYNC messages
peer_digest: {
  label: "Sub-Structure: PeerDigest (Serialized in Body Segment)"
  style: {
    stroke: "${colors.pointers}"
    stroke-width: 2
    stroke-dash: 4
    fill: "#FFFBEB"
  }
  
  pd_layout: {
    direction: right
    grid-gap: 0
    
    id_len: "IDLen\n(1B)" {style.fill: "${colors.header}"; width: 70; height: 90}
    id_val: "ID String\n(N Bytes)" {style.fill: "${colors.data}"; width: 140; height: 90}
    addr_len: "AddrLen\n(1B)" {style.fill: "${colors.header}"; width: 70; height: 90}
    addr_val: "IP Address\n(M Bytes)" {style.fill: "${colors.data}"; width: 140; height: 90}
    port: "Port\n(2B BE)" {style.fill: "${colors.data}"; width: 90; height: 90}
    state: "State\n(1B)" {style.fill: "${colors.padding}"; width: 70; height: 90}
    incarnation: "Incarnation\n(8B BE)" {style.fill: "${colors.data}"; width: 140; height: 90}
    
    id_len -> id_val -> addr_len -> addr_val -> port -> state -> incarnation
  }
}

# Legend and Constants using fixed block string syntax
legend: {
  near: peer_digest
  shape: rectangle
  style.fill: "#F3F4F6"
  style.stroke: "#D1D5DB"
  
  table: |md
    ### MessageType Dictionary (Offset 0x04)
    | Value | Name  | Description                  |
    | :---  | :---  | :---                         |
    | 0x01  | JOIN  | New node joining cluster      |
    | 0x02  | LEAVE | Graceful exit                |
    | 0x03  | SYNC  | Anti-entropy state exchange  |
    | 0x04  | ACK   | Sequence confirmation        |
  |
}

# Pointer from Base Body to PeerDigest
(base_message.layout.body -> peer_digest): "If Type == 0x03 (SYNC)" {
  style: {
    stroke: "${colors.pointers}"
    stroke-width: 4
    font-size: 16
    bold: true
  }
  target-arrowhead: triangle
}

# Size Summary
size_calc: "sizeof(Msg) = 14 + NodeIDLen + BodySize" {
  near: base_message.layout.timestamp
  shape: text
  style: {
    font: mono
    font-size: 20
    font-color: "#374151"
    bold: true
  }
}

# Positioning Offsets - Connect text to layout boxes without visible lines
base_message.offsets.o0 -> base_message.layout.length: {style.stroke: transparent; style.opacity: 0}
base_message.offsets.o4 -> base_message.layout.type: {style.stroke: transparent; style.opacity: 0}
base_message.offsets.o5 -> base_message.layout.node_id_len: {style.stroke: transparent; style.opacity: 0}
base_message.offsets.o6 -> base_message.layout.node_id: {style.stroke: transparent; style.opacity: 0}
base_message.offsets.oTs -> base_message.layout.timestamp: {style.stroke: transparent; style.opacity: 0}
base_message.offsets.oBody -> base_message.layout.body: {style.stroke: transparent; style.opacity: 0}

# Growth Direction Annotation
transmission_flow: {
  shape: arrow
  label: "Network Wire Transmission Direction (Big Endian Order)"
  style: {
    stroke: "${colors.pointers}"
    stroke-width: 5
    animated: true
    font-size: 18
  }
}

base_message -> transmission_flow: "Higher Addresses" {
  style: {
    stroke: transparent
    font-size: 14
    italic: true
  }
}