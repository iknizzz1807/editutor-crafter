vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
shape: sequence_diagram
S: Suspecting Node
T: Target Node (Suspected)
P1: Peer 1
P2: Peer 2
P3: Peer 3
# Phase 1: Failure Detection & Suspicion Broadcast
Phase1: Phase 1: Failure Detection {
  S.t1 -> T.t1: Ping (direct probe)
  T.t1 -- S.t1: timeout {
    style.stroke: red
    style.stroke-dash: 3
  }
  S.t2 -> P1.t2: PingReq (indirect probe)
  S.t2 -> P2.t2: PingReq (indirect probe)
  S.t2 -> P3.t2: PingReq (indirect probe)
  P1.t3 -> T.t3: Ping (on behalf of S)
  P2.t4 -> T.t4: Ping (on behalf of S)
  P3.t5 -> T.t5: Ping (on behalf of S)
  T.t3 -- P1.t3: timeout {
    style.stroke: red
    style.stroke-dash: 3
  }
  T.t4 -- P2.t4: timeout {
    style.stroke: red
    style.stroke-dash: 3
  }
  T.t5 -- P3.t5: timeout {
    style.stroke: red
    style.stroke-dash: 3
  }
  P1.t3 -- S.t6: timeout {
    style.stroke: red
    style.stroke-dash: 3
  }
  P2.t4 -- S.t6: timeout {
    style.stroke: red
    style.stroke-dash: 3
  }
  P3.t5 -- S.t6: timeout {
    style.stroke: red
    style.stroke-dash: 3
  }
  S."Mark SUSPECT"
  S."Start suspicion timer"
}
# Phase 2: Suspicion Dissemination via Piggyback
Phase2: Phase 2: Suspicion Dissemination {
  S.t7 -> P1.t7: Gossip message {
    label: "Piggyback: SUSPECT(T, inc=5)"
  }
  S.t8 -> P2.t8: Gossip message {
    label: "Piggyback: SUSPECT(T, inc=5)"
  }
  S.t9 -> P3.t9: Gossip message {
    label: "Piggyback: SUSPECT(T, inc=5)"
  }
  P1.t10 -> T.t10: Gossip message {
    label: "Piggyback: SUSPECT(T, inc=5)"
  }
  P2.t11 -> T.t11: Gossip message {
    label: "Piggyback: SUSPECT(T, inc=5)"
  }
  P3.t12 -> T.t12: Gossip message {
    label: "Piggyback: SUSPECT(T, inc=5)"
  }
}
# Phase 3: Target Detects Suspicion & Refutes
Phase3: Phase 3: Target Detects & Refutes {
  T."Detect SUSPECT about self"
  T."incarnation++"
  T."(5 -> 6)"
  T."Create ALIVE event (inc=6)"
  T."Add to PRIORITY piggyback"
}
# Phase 4: ALIVE Broadcast
Phase4: Phase 4: ALIVE Broadcast {
  T.t13 -> S.t13: ALIVE broadcast {
    label: "Piggyback: ALIVE(T, inc=6)"
    style.stroke: green
    style.bold: true
  }
  T.t14 -> P1.t14: ALIVE broadcast {
    label: "Piggyback: ALIVE(T, inc=6)"
    style.stroke: green
    style.bold: true
  }
  T.t15 -> P2.t15: ALIVE broadcast {
    label: "Piggyback: ALIVE(T, inc=6)"
    style.stroke: green
    style.bold: true
  }
  T.t16 -> P3.t16: ALIVE broadcast {
    label: "Piggyback: ALIVE(T, inc=6)"
    style.stroke: green
    style.bold: true
  }
}
# Phase 5: Acceptance Across Cluster
Phase5: Phase 5: Acceptance Across Cluster {
  S."Accept ALIVE (6 > 5)"
  S."Cancel suspicion timer"
  S."Mark T as ALIVE"
  P1."Accept ALIVE (6 > 5)"
  P1."Mark T as ALIVE"
  P2."Accept ALIVE (6 > 5)"
  P2."Mark T as ALIVE"
  P3."Accept ALIVE (6 > 5)"
  P3."Mark T as ALIVE"
}
# Styling
S.style.fill: "#E8E8E8"
T.style.fill: "#90EE90"
P1.style.fill: "#E8E8E8"
P2.style.fill: "#E8E8E8"
P3.style.fill: "#E8E8E8"
Phase1.style.fill: "#FFE4E1"
Phase2.style.fill: "#FFFACD"
Phase3.style.fill: "#98FB98"
Phase4.style.fill: "#98FB98"
Phase5.style.fill: "#E0FFFF"