vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Module Architecture: Test Harness
  **Technical Specification v1.2**
  *Intel Manual Grade Layout*
| {near: top-center}

# --- CLASSES & INTERFACES ---

Harness: "Test Harness" {
  shape: class
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }
  
  # Fields
  "config": "HarnessConfig"
  "nodes": "[]*TestNode"
  "transport": "Transport"
  "metrics": "*MetricsCollector"
  "done": "chan struct{}"
  "wg": "sync.WaitGroup"

  # Methods
  "Run(ctx context.Context)": error
  "Stop()"
  "InjectFault(fault FaultType)"
}

HarnessConfig: "HarnessConfig" {
  shape: class
  style.fill: "#F1F8E9"
  "+ClusterSize": int
  "+BasePort": int
  "+UseRealNetwork": bool
  "+PacketLossRate": float64
  "+MessageDelay": "time.Duration"
  "+RandomSeed": int64
}

Transport: "<<interface>>\nTransport" {
  shape: class
  tooltip: "Network abstraction layer"
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
  }
  "Send(from, to string, data []byte)": error
  "Receive(nodeID string)": "([]byte, string, error)"
  "Partition(groups ...[]string)"
  "Heal()"
  "SetPacketLoss(rate float64)"
  "Close()"
}

RealTransport: "Real Transport" {
  shape: class
  style.fill: "#BBDEFB"
  "conns": "map[string]*net.UDPConn"
  "mu": "sync.RWMutex"
}

SimulatedTransport: "Simulated Transport" {
  shape: class
  style.fill: "#BBDEFB"
  "queues": "map[string]chan *envelope"
  "partitions": "map[string]map[string]bool"
  "packetLoss": float64
  "delay": "time.Duration"
  "rng": "*rand.Rand"
}

TestNode: "Test Node" {
  shape: class
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
    stroke-width: 2
  }
  tooltip: "Virtual instance of a gossip participant"
  "Node": "*node.Node"
  "ID": string
  "Address": string
  "Port": int
  "metrics": "*NodeMetrics"
  "blocked": "atomic.Bool"
  "blockList": "map[string]bool"
}

NodeMetrics: "Node Metrics" {
  shape: class
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  "BytesSent": uint64
  "BytesReceived": uint64
  "MessagesSent": uint64
  "MessagesRecv": uint64
  "UpdatesSent": uint64
  "UpdatesRecv": uint64
}

MetricsCollector: "Metrics Collector" {
  shape: class
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  "mu": "sync.RWMutex"
  "nodeData": "map[string]*NodeMetrics"
}

# --- TEST COMPONENTS ---

ConvergenceTest: "Convergence Test" {
  shape: class
  style.fill: "#C8E6C9"
  "harness": "*Harness"
  "numUpdates": int
  "timeout": "time.Duration"
  "keyPrefix": string
}

DetectionTest: "Detection Test" {
  shape: class
  style.fill: "#C8E6C9"
  "harness": "*Harness"
  "victimIndex": int
  "timeout": "time.Duration"
}

PartitionTest: "Partition Test" {
  shape: class
  style.fill: "#C8E6C9"
  "harness": "*Harness"
  "partitionGroups": "[][]int"
  "duration": "time.Duration"
  "updatesPerGroup": int
}

BandwidthProfile: "Bandwidth Profile" {
  shape: class
  style.fill: "#C8E6C9"
  "harness": "*Harness"
  "duration": "time.Duration"
  "sampleRate": "time.Duration"
}

ConsistencyCheck: "Consistency Check" {
  shape: class
  style.fill: "#C8E6C9"
  "harness": "*Harness"
  "convergenceBound": "time.Duration"
  "sampleInterval": "time.Duration"
}

ChaosTest: "Chaos Test" {
  shape: class
  style.fill: "#C8E6C9"
  "harness": "*Harness"
  "duration": "time.Duration"
  "killProbability": float64
  "partitionProbability": float64
  "lossProbability": float64
}

# --- RESULT TYPES ---

ConvergenceResult: "Convergence Result" {
  shape: class
  style.fill: "#DCEDC8"
  "ConvergedNodes": int
  "TotalNodes": int
  "TimeToConverge": "time.Duration"
  "RoundsToConverge": int
  "FailedNodes": "[]string"
}

DetectionResult: "Detection Result" {
  shape: class
  style.fill: "#DCEDC8"
  "VictimID": string
  "DetectionTime": "time.Duration"
  "DetectedBy": "[]string"
  "NotDetectedBy": "[]string"
  "ExpectedMaxTime": "time.Duration"
}

PartitionResult: "Partition Result" {
  shape: class
  style.fill: "#DCEDC8"
  "PartitionDuration": "time.Duration"
  "HealingTime": "time.Duration"
  "TotalUpdates": int
  "ConvergedNodes": int
  "DivergentNodes": "[]string"
}

BandwidthResult: "Bandwidth Result" {
  shape: class
  style.fill: "#DCEDC8"
  "BytesPerSecond": float64
  "BytesPerNodePerSec": float64
  "ScalingFactor": float64
}

ConsistencyViolation: "Consistency Violation" {
  shape: class
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
  "Key": string
  "NodeID": string
  "StaleVersion": uint64
  "ExpectedMin": uint64
  "Age": "time.Duration"
}

ChaosResult: "Chaos Result" {
  shape: class
  style.fill: "#DCEDC8"
  "Duration": "time.Duration"
  "Kills": int
  "Restarts": int
  "Partitions": int
  "ConvergenceFailures": int64
  "FinalConverged": bool
}

# --- RELATIONSHIPS ---

# Harness Ownerships
Harness -> HarnessConfig: "owns"
Harness -> TestNode: "owns (array)"
Harness -> Transport: "owns (interface)"
Harness -> MetricsCollector: "owns"

# Interface Implementations (Hollow Triangle)
RealTransport -> Transport: "implements" {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
  style.stroke-dash: 3
}

SimulatedTransport -> Transport: "implements" {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
  style.stroke-dash: 3
}

# Composition & References
TestNode -> NodeMetrics: "owns"
MetricsCollector -> NodeMetrics: "aggregates"
TestNode -> Harness.transport: "references" {
  style.stroke-dash: 5
}

# Test to Harness Relationships
ConvergenceTest -> Harness: "executes"
DetectionTest -> Harness: "executes"
PartitionTest -> Harness: "executes"
BandwidthProfile -> Harness: "executes"
ConsistencyCheck -> Harness: "executes"
ChaosTest -> Harness: "executes"

# Annotations
legend: {
  near: bottom-right
  class_style: "Solid Line: Ownership / Composition" {
    shape: rectangle
    style: {
      stroke: "#2E7D32"
      fill: "#FFFFFF"
      font-size: 12
    }
  }
  interface_style: "Dashed Line + Hollow Triangle: Implementation" {
    shape: rectangle
    style: {
      stroke: "#1976D2"
      stroke-dash: 3
      fill: "#FFFFFF"
      font-size: 12
    }
  }
}