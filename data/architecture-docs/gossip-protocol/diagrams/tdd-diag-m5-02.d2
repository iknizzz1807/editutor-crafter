vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    success: "#22C55E"
    failure: "#EF4444"
    timer: "#F59E0B"
    text: "#1F2937"
  }
}
title: |md
  # Convergence Test Algorithm State Flow
| {near: top-center}
direction: right
Start: {
  shape: oval
  style.fill: "${colors.header}"
  style.font-color: white
  style.bold: true
}
Phase1: Generate Updates {
  style.fill: "${colors.data}"
  style.font-color: white
  updates: "updates = {}" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  loop_start: "for i in [0, numUpdates)" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  key_gen: 'key = "conv-test-{i}"' {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  value_gen: "value = random_bytes()" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  inject: "node = RandomPeer()" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  store: "node.Store().Set(key, value)" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  track: "updates[key] = value" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
}
Phase2: Poll Loop {
  style.fill: "${colors.timer}"
  style.font-color: white
  start_timer: "start = time.Now()" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  deadline: "deadline = After(timeout)" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  ticker: "ticker = NewTicker(checkInterval)" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
}
CheckNode: Check Each Node {
  style.fill: "${colors.data}"
  style.font-color: white
  for_node: "for each node in harness.nodes" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  skip_blocked: "if !node.IsAlive(): continue" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  get_entry: "entry, exists := node.Get(key)" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  check_match: "if !exists || entry.Value != expected" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
}
Decision: All Converged? {
  shape: diamond
  style.fill: "${colors.timer}"
  style.font-color: white
  style.bold: true
}
Success: Record Success {
  style.fill: "${colors.success}"
  style.font-color: white
  calc_time: "TimeToConverge = time.Since(start)" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  calc_rounds: "RoundsToConverge = TimeToConverge / GossipInterval" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  result: "return ConvergenceResult{ConvergedNodes: N}" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
}
Timeout: Record Timeout {
  style.fill: "${colors.failure}"
  style.font-color: white
  failed_nodes: "FailedNodes = [nodes missing updates]" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
  err_return: "return ConvergenceTimeoutError" {
    shape: text
    style.font: mono
    style.font-color: "${colors.text}"
  }
}
End: {
  shape: oval
  style.fill: "${colors.header}"
  style.font-color: white
  style.bold: true
}
Start -> Phase1
Phase1 -> Phase2
Phase2 -> CheckNode
CheckNode -> Decision
Decision -> Success: Yes (all nodes\nhave all updates) {
  style.stroke: "${colors.success}"
  style.bold: true
}
Decision -> Phase2: No (some nodes\nmissing updates) {
  style.stroke: "${colors.timer}"
  style.stroke-dash: 3
}
Decision -> Timeout: deadline\nreached {
  style.stroke: "${colors.failure}"
  style.bold: true
}
Success -> End
Timeout -> End