direction: right
title: |md
  # Fault Injection Test Matrix
  Integration test scenarios for SWIM failure detection
| {near: top-center}
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#4A5568"
    success: "#48BB78"
    warning: "#ECC94B"
    danger: "#F56565"
    info: "#4299E1"
    purple: "#805AD5"
    gray: "#718096"
  }
}
classes: {
  header: {
    style: {
      fill: ${colors.header}
      font-color: white
      bold: true
      font-size: 14
      border-radius: 4
    }
  }
  scenario: {
    style: {
      fill: white
      stroke: "#CBD6E0"
      border-radius: 4
    }
  }
  nodekill: {
    style: {
      fill: "#FED7D7"
      stroke: ${colors.danger}
    }
  }
  partition: {
    style: {
      fill: "#FEEBC8"
      stroke: ${colors.warning}
    }
  }
  packetloss: {
    style: {
      fill: "#BEE3F8"
      stroke: ${colors.info}
    }
  }
  combined: {
    style: {
      fill: "#E9D8FD"
      stroke: ${colors.purple}
    }
  }
  metric: {
    style: {
      fill: "#EDF2F7"
      stroke: "#CBD6E0"
      font: mono
      font-size: 11
    }
  }
  success-badge: {
    shape: circle
    style: {
      fill: ${colors.success}
      font-color: white
      font-size: 12
      bold: true
      stroke: white
      stroke-width: 2
    }
  }
}
# Matrix Container
matrix: {
  label: ""
  # Header Row
  hdr_scenario: "SCENARIO" {class: header}
  hdr_cluster: "CLUSTER\nSIZE" {class: header}
  hdr_duration: "TEST\nDURATION" {class: header}
  hdr_expected: "EXPECTED\nOUTCOME" {class: header}
  hdr_metrics: "MEASURED\nMETRICS" {class: header}
  # Row 1: Node Kill
  r1_type: "🔴 Node Kill" {class: nodekill}
  r1_cluster: "10 nodes" {class: scenario}
  r1_duration: "30s" {class: scenario}
  r1_expected: |md
    • All remaining nodes detect DEAD
    • Detection within:
      `suspicion_timeout + 3*protocol_period`
    • Refutation if false positive
  | {class: scenario}
  r1_metrics: {
    class: metric
    detection_latency: "detection_latency: 5.2s"
    false_positives: "false_positives: 0"
    detection_rate: "detection_rate: 100%"
    refutations: "refutations: 0"
  }
  # Row 2: Partition
  r2_type: "🟡 Network Partition" {class: partition}
  r2_cluster: "6 nodes\n(2 groups)" {class: scenario}
  r2_duration: "60s\n(30s partition)" {class: scenario}
  r2_expected: |md
    • Both sides accept writes (A/P)
    • After heal: LWW resolution
    • Convergence within:
      `5 * anti_entropy_interval`
  | {class: scenario}
  r2_metrics: {
    class: metric
    healing_time: "healing_time: 42s"
    conflicts: "conflicts_resolved: 10"
    convergence: "convergence: 100%"
    data_loss: "data_loss: 0"
  }
  # Row 3: Packet Loss
  r3_type: "🔵 Packet Loss (5%)" {class: packetloss}
  r3_cluster: "10 nodes" {class: scenario}
  r3_duration: "1000\nprotocol\nperiods" {class: scenario}
  r3_expected: |md
    • False positive rate < 1%
    • Indirect probing reduces errors
    • Refutation catches false SUSPECT
  | {class: scenario}
  r3_metrics: {
    class: metric
    total_checks: "total_checks: 90,000"
    false_rate: "false_positive_rate: 0.3%"
    indirect_success: "indirect_success_rate: 94%"
    refutations: "refutations: 12"
  }
  # Row 4: Combined Chaos
  r4_type: "🟣 Combined Chaos" {class: combined}
  r4_cluster: "20 nodes" {class: scenario}
  r4_duration: "60s\ncontinuous" {class: scenario}
  r4_expected: |md
    • System survives continuous failures
    • Convergence after chaos stops
    • No permanent state divergence
  | {class: scenario}
  r4_metrics: {
    class: metric
    kills: "kills: 15"
    restarts: "restarts: 12"
    partitions: "partitions: 3"
    final_converged: "final_converged: ✓"
  }
  # Horizontal connections for alignment
  hdr_scenario -> r1_type -> r2_type -> r3_type -> r4_type: {style.opacity: 0}
  r1_type -> r1_cluster -> r1_duration -> r1_expected -> r1_metrics: {style.opacity: 0}
  r2_type -> r2_cluster -> r2_duration -> r2_expected -> r2_metrics: {style.opacity: 0}
  r3_type -> r3_cluster -> r3_duration -> r3_expected -> r3_metrics: {style.opacity: 0}
  r4_type -> r4_cluster -> r4_duration -> r4_expected -> r4_metrics: {style.opacity: 0}
}
# Legend
legend: {
  label: "Test Scenario Types"
  near: bottom-center
  kill_ex: "Node Kill" {class: nodekill}
  part_ex: "Partition" {class: partition}
  loss_ex: "Packet Loss" {class: packetloss}
  combo_ex: "Combined" {class: combined}
  kill_ex -> part_ex -> loss_ex -> combo_ex: {style.opacity: 0}
}
# Status badges
status: {
  near: top-right
  check1: "✓" {class: success-badge; tooltip: Node Kill tests passing}
  check2: "✓" {class: success-badge; tooltip: Partition tests passing}
  check3: "✓" {class: success-badge; tooltip: Packet Loss tests passing}
  check4: "✓" {class: success-badge; tooltip: Chaos tests passing}
  check1 -> check2 -> check3 -> check4: {style.opacity: 0}
}
# Test Harness Reference
harness_ref: {
  near: bottom-right
  label: |md
    **Test Harness**
    `test/harness.go`
    
    HarnessConfig{
      ClusterSize: 10
      PacketLossRate: 0.05
      RandomSeed: 42
    }
    
  |
  style: {
    fill: "#EDF2F7"
    stroke: "#CBD6E0"
    border-radius: 8
    font: mono
    font-size: 11
  }
}