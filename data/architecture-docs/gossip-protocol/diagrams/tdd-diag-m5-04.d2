vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # SimulatedTransport Architecture
  Deterministic Network Simulation with Fault Injection
| {near: top-center}

# Direction for main layout
direction: right

# Transport Core
transport_core: "SimulatedTransport\nCore" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 3

  state: "Internal State" {
    style.fill: "#F5F5F5"
    queues_map: "queues: map[string]chan *envelope"
    partitions_map: "partitions: map[string]map[string]bool"
    packet_loss: "packetLoss: float64"
    delay: "delay: time.Duration"
    rng: "rng: *rand.Rand"
    closed: "closed: atomic.Bool"
    style.font: mono
    style.font-size: 14
  }
  state.style.fill-pattern: dots
}

# Message Queue Detail (expanded view)
queue_detail: "Message Queue Per Node" {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"

  queue_struct: "chan *envelope (buffered: 10000)" {
    style.fill: "#BBDEFB"
    shape: hexagon
  }

  envelope: "envelope struct" {
    style.fill: "#90CAF9"
    style.font: mono
    style.font-size: 12
    from: "from: string"
    to: "to: string"
    data: "data: []byte"
    send_at: "sendAt: time.Time"
  }

  queue_struct -> envelope: contains
}

# Partition State Detail
partition_detail: "Partition State" {
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"

  partition_map: "partitions map" {
    style.fill: "#FFE0B2"
    shape: diamond
    node_a_blocked: "node-a: {node-b: true, node-c: true}"
    node_b_blocked: "node-b: {node-a: true}"
  }

  partition_map -> node_a_blocked
  partition_map -> node_b_blocked
}

# Transport API
api: "Transport Interface" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.stroke-width: 2

  Send: "Send(from, to string, data []byte) error"
  Receive: "Receive(ctx, nodeID string) ([]byte, string, error)"
  Partition: "Partition(groups ...[]string)"
  Heal: "Heal()"
  SetPacketLoss: "SetPacketLoss(rate float64)"
  SetDelay: "SetDelay(delay time.Duration)"
  Close: "Close()"

  style.font: mono
  style.font-size: 13
}

# Simulated Nodes
nodes: "Simulated Nodes" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"

  node_a: "node-a" {
    style.fill: "#E1BEE7"
    shape: circle
    queue_a: "queue_a\nchan *envelope" {
      style.fill: "#CE93D8"
      shape: queue
    }
  }

  node_b: "node-b" {
    style.fill: "#E1BEE7"
    shape: circle
    queue_b: "queue_b\nchan *envelope" {
      style.fill: "#CE93D8"
      shape: queue
    }
  }

  node_c: "node-c" {
    style.fill: "#E1BEE7"
    shape: circle
    queue_c: "queue_c\nchan *envelope" {
      style.fill: "#CE93D8"
      shape: queue
    }
  }

  node_a -> queue_a: owns
  node_b -> queue_b: owns
  node_c -> queue_c: owns
}

# Send Algorithm Flow
send_flow: "Send Algorithm" {
  style.fill: "#FFEBEE"
  style.stroke: "#D32F2F"

  step1: "1. Acquire RLock" {
    style.fill: "#FFCDD2"
  }
  step2: "2. Check partition\nif partitions[from][to]: return nil" {
    style.fill: "#FFCDD2"
  }
  step3: "3. Apply packet loss\nif rng.Float64() < packetLoss: drop" {
    style.fill: "#FFCDD2"
  }
  step4: "4. Apply delay\nif delay > 0: time.Sleep(delay)" {
    style.fill: "#FFCDD2"
  }
  step5: "5. Create envelope\nenv = &envelope{from, to, data, now}" {
    style.fill: "#FFCDD2"
  }
  step6: "6. Deliver to queue\nselect { queue <- env }" {
    style.fill: "#FFCDD2"
  }

  step1 -> step2 -> step3 -> step4 -> step5 -> step6: {
    style.stroke: "#D32F2F"
    style.stroke-width: 2
  }
}

# Partition Visualization
partition_example: "Partition Example\n(groups: [[node-a], [node-b, node-c]])" {
  style.fill: "#FFF8E1"
  style.stroke: "#FFA000"

  group1: "Group 1" {
    style.fill: "#FFECB3"
    style.stroke: "#FF8F00"
    partitioned_a: "node-a" {
      shape: circle
      style.fill: "#FFD54F"
    }
  }

  group2: "Group 2" {
    style.fill: "#FFECB3"
    style.stroke: "#FF8F00"
    partitioned_b: "node-b" {
      shape: circle
      style.fill: "#FFD54F"
    }
    partitioned_c: "node-c" {
      shape: circle
      style.fill: "#FFD54F"
    }
  }

  partitioned_a -> group2: "❌ BLOCKED" {
    style.stroke: "#D32F2F"
    style.stroke-dash: 5
    style.stroke-width: 3
    style.font-color: "#D32F2F"
    style.bold: true
  }

  partitioned_b -> partitioned_c: "✓ allowed" {
    style.stroke: "#388E3C"
    style.stroke-width: 2
    style.font-color: "#388E3C"
  }
}

# Receive Flow
receive_flow: "Receive Algorithm" {
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"

  receive_step1: "1. Get node's queue\nqueue := queues[nodeID]" {
    style.fill: "#B2EBF2"
  }
  receive_step2: "2. Non-blocking read\nselect { case env := <-queue }" {
    style.fill: "#B2EBF2"
  }
  receive_step3: "3. Return envelope data\nreturn env.data, env.from, nil" {
    style.fill: "#B2EBF2"
  }

  receive_step1 -> receive_step2 -> receive_step3: {
    style.stroke: "#00838F"
    style.stroke-width: 2
  }
}

# Connections
transport_core -> api: implements
transport_core -> queue_detail: manages
transport_core -> partition_detail: maintains
transport_core -> nodes: routes to
send_flow -> transport_core: Send() triggers
receive_flow -> transport_core: Receive() triggers
partition_example -> partition_detail: example of

# Legend
legend: |md
  ## Legend
  - **Gray Box**: Transport core state
  - **Blue Box**: Message queue structures
  - **Orange Box**: Partition state
  - **Green Box**: Public API
  - **Purple Circles**: Simulated nodes
  - **Red Flow**: Send algorithm steps
  - **Cyan Flow**: Receive algorithm steps
  - **Yellow Box**: Partition visualization
| {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 8
}