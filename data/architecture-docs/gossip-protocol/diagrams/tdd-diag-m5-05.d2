vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    sketch: false
    pad: 20
  }
}

# --- STYLE CLASSES (Intel Manual Standard) ---
classes: {
  seed-node: {
    shape: circle
    style: {
      fill: "#8B5CF6"
      stroke: "#6366F1"
      stroke-width: 2
      shadow: true
      font-color: white
      bold: true
    }
  }
  joining-node: {
    shape: circle
    style: {
      fill: "#10B981"
      stroke: "#059669"
      stroke-width: 2
      shadow: true
      font-color: white
      bold: true
    }
  }
  existing-node: {
    shape: circle
    style: {
      fill: "#F59E0B"
      stroke: "#D97706"
      stroke-width: 2
      shadow: true
      font-color: white
      bold: true
    }
  }
  message: {
    style: {
      font-size: 13
      stroke-width: 2
      bold: true
      font: mono
    }
  }
  ack-message: {
    style: {
      stroke: "#10B981"
      font-size: 12
      italic: true
      stroke-dash: 3
    }
  }
}

# --- SEQUENCE DIAGRAM DEFINITION ---
PartitionTestScenario: {
  shape: sequence_diagram
  label: "GOSSIP PROTOCOL: PARTITION RECOVERY & JOIN SEQUENCE"
  
  # Actor Definitions
  Seed: "Seed Node\n(10.0.0.254)" {
    class: seed-node
  }
  NewNode: "New Node\n(10.0.0.1)" {
    class: joining-node
  }
  Existing1: "Existing Node 1\n(10.0.0.2)" {
    class: existing-node
  }
  Existing2: "Existing Node 2\n(10.0.0.3)" {
    class: existing-node
  }

  # Connection Trace: Initial Handshake
  Seed -> NewNode: "1. JOIN request\n{Addr: 10.0.0.1, Port: 8080, Inc: 1}" {
    class: message
    style.stroke: "#8B5CF6"
  }
  
  NewNode <- Seed: "2. ACK + Peer List\n{Success: true, Members: [Seed, E1, E2]}" {
    class: ack-message
  }

  # Container Group: Direct State Synchronization
  SyncPhase: Synchronization Phase {
    NewNode -> Existing1: "3. SYNC message\n{PeerDigest[NewNode:1]}" {
      class: message
      style.stroke: "#10B981"
    }
    NewNode -> Existing2: "3. SYNC message\n{PeerDigest[NewNode:1]}" {
      class: message
      style.stroke: "#10B981"
    }
    Existing1 -> NewNode: "4. SYNC response\n{FullDigest[]}" {
      class: ack-message
    }
    Existing2 -> NewNode: "4. SYNC response\n{FullDigest[]}" {
      class: ack-message
    }
  }

  # Container Group: Epidemic Broadcast
  GossipProp: Gossip Propagation {
    Seed -> Existing1: "5. Gossip: NewNode joined\n{Event: ALIVE, Node: NewNode, Inc: 1}" {
      class: message
      style.stroke: "#8B5CF6"
      style.stroke-dash: 3
    }
    Seed -> Existing2: "5. Gossip: NewNode joined\n{Event: ALIVE, Node: NewNode, Inc: 1}" {
      class: message
      style.stroke: "#8B5CF6"
      style.stroke-dash: 3
    }
  }

  # Container Group: Merkle-Tree / Anti-Entropy Check
  AntiEntropy: Anti-Entropy (Background) {
    NewNode -> Existing1: "6. Anti-entropy sync\n{DigestReq: NewNode}" {
      class: message
      style.stroke: "#10B981"
      style.stroke-dash: 5
    }
    Existing1 -> NewNode: "6. Digest response\n{Keys: [K101, K105], Missing: [K200]}" {
      class: ack-message
      style.stroke-dash: 5
    }
  }
}

# --- DOCUMENTATION & ANALYTICS (Root Level Shapes) ---
Timeline: ||md
### Convergence Analysis & Performance Metrics
| Step | Event Type | Latency Expectation | Network Impact |
| :--- | :--- | :--- | :--- |
| **T0** | TCP Handshake / Join | < 5ms | Unicast (1:1) |
| **T1** | Direct Delta Sync | ~15ms | Unicast (1:N) |
| **T2** | Gossip Fan-out | ~50ms | Multicast O(log N) |
| **T3** | Global Consistency | ~200ms | Cluster-wide |

**Theoretical Bound:** Propagation achieves consistency in ceil(log_fanout(N)) rounds.
**Safety Invariant:** Node increments (Inc) must be monotonically increasing to prevent stale state replay.
|| {
  near: bottom-center
  shape: text
  style: {
    fill: "#F9FAFB"
    stroke: "#D1D5DB"
    stroke-width: 1
    border-radius: 8
    font-size: 14
    font-color: "#374151"
  }
}

# Metadata Label
Legend: ||md
**Node State Legend**
- **Seed**: Static entry point.
- **New**: Joining entity (Green).
- **Existing**: Cluster member (Amber).
|| {
  near: top-left
  style: {
    fill: "#F3F4F6"
    stroke: "#9CA3AF"
    font-size: 12
  }
}