layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    harness: "#E8F5E9"
    harness-header: "#2E7D32"
    test-node: "#D4EDDA"
    metrics: "#FEF3C7"
    metrics-header: "#B45309"
    transport: "#F3F4F6"
    transport-header: "#1E40AF"
    convergence: "#D1FAE5"
    convergence-header: "#059669"
    detection: "#FEE2E2"
    detection-header: "#B91C1C"
    partition: "#FEF9C3"
    partition-header: "#A16207"
    bandwidth: "#E0F2FE"
    bandwidth-header: "#0369A1"
    consistency: "#EDE9FE"
    consistency-header: "#6D28D9"
    chaos: "#FFEDD5"
    chaos-header: "#C2410C"
    test: "#F8FAFC"
    test-header: "#475569"
    result: "#F1F5F9"
    result-header: "#475569"
  }
}

direction: right

title: |md
  # Integration Test Harness Architecture
  **Scope:** Fault-tolerant gossip protocol verification
  **Version:** 1.0.4-RC
| {near: top-center}

# Requirements / Test Capabilities
Requirements: |md
  ### Core Verification Targets
  - **Packet loss injection**: 0% to 100% via SimulatedTransport
  - **Partition testing**: Bi-directional and uni-directional splits
  - **Chaos testing**: Random process SIGKILL and restart cycles
  - **Convergence verification**: Merkle-tree based state consistency
  - **Bandwidth measurement**: Bytes/sec per protocol message type
  - **Consistency verification**: Linearizability checks on KV store
| {
  shape: page
  near: top-left
  style: {
    stroke: "#475569"
    fill: "#F8FAFC"
  }
}

# Core Components
Harness: {
  style.fill: "${colors.harness}"
  style.stroke: "${colors.harness-header}"
  tooltip: "Main coordination engine for integration tests"
  
  Config: {
    shape: class
    ClusterSize: "int (default: 5)"
    BasePort: "int (default: 8000)"
    UseRealNetwork: "bool"
    PacketLossRate: "float64"
    MessageDelay: "time.Duration"
    RandomSeed: "int64"
  }
  
  TestNode_Struct: TestNode {
    shape: class
    "Node": "*node.Node"
    ID: "string (UUID v4)"
    Address: "string (IP)"
    Port: "int"
    "metrics": "*NodeMetrics"
    "blocked": "atomic.Bool"
  }
  
  MetricsCollector: {
    shape: class
    "mu": "sync.RWMutex"
    "nodeData": "map[string]*NodeMetrics"
    "RecordSend(nodeID string, bytes int)": "void"
    "RecordRecv(nodeID string, bytes int)": "void"
    "GetTotalBytesPerSec(duration time.Duration)": "float64"
  }
}

# Transport Layer
Transport: {
  style.fill: "${colors.transport}"
  style.stroke: "${colors.transport-header}"
  tooltip: "Pluggable network abstraction layer"
  
  RealTransport: {
    shape: class
    "conns": "map[string]*net.UDPConn"
    "Send(from string, to string, data []byte)": "error"
    "Receive(nodeID string)": "([]byte, string, error)"
    "Close()": "void"
  }
  
  SimulatedTransport: {
    shape: class
    "mu": "sync.RWMutex"
    "queues": "map[string]chan *envelope"
    "partitions": "map[string]map[string]bool"
    packetLoss: "float64"
    "delay": "time.Duration"
    "Partition(groups ...[]string)": "void"
    "Heal()": "void"
    "SetPacketLoss(rate float64)": "void"
  }
}

# Test Suites & Results
Tests: {
  ConvergenceTest: {
    style.fill: "${colors.convergence}"
    Run: {
      shape: circle
      label: "Execute"
    }
    Result: {
      shape: class
      ConvergedNodes: "int"
      TotalNodes: "int"
      "TimeToConverge": "time.Duration"
      RoundsToConverge: "int"
    }
  }

  DetectionTest: {
    style.fill: "${colors.detection}"
    Run: {
      shape: circle
      label: "Execute"
    }
    Result: {
      shape: class
      VictimID: "string"
      "DetectionTime": "time.Duration"
      "DetectedBy": "[]string"
    }
  }

  PartitionTest: {
    style.fill: "${colors.partition}"
    Run: {
      shape: circle
      label: "Execute"
    }
    Result: {
      shape: class
      "PartitionDuration": "time.Duration"
      "HealingTime": "time.Duration"
      "DivergentNodes": "[]string"
    }
  }

  BandwidthProfile: {
    style.fill: "${colors.bandwidth}"
    Run: {
      shape: circle
      label: "Execute"
    }
    Result: {
      shape: class
      TotalBytesSent: "uint64"
      BytesPerSecond: "float64"
      "Duration": "time.Duration"
    }
  }

  ConsistencyCheck: {
    style.fill: "${colors.consistency}"
    Run: {
      shape: circle
      label: "Execute"
    }
    Result: {
      shape: class
      TotalChecks: "int64"
      "Violations": "[]ConsistencyViolation"
    }
  }

  ChaosTest: {
    style.fill: "${colors.chaos}"
    Run: {
      shape: circle
      label: "Execute"
    }
    Result: {
      shape: class
      Kills: "int"
      Restarts: "int"
      FinalConverged: "bool"
    }
  }
}

# Internal Node Logic
Internal: {
  Store: "Versioned K/V Store"
  PeerList: "Membership Registry"
  FailureDetector: "SWIM Protocol"
  Gossiper: "Push Gossip Engine"
  AntiEntropy: "Merkle/Digest Sync"
}

# Relationships (Structural)
Harness -> Transport: "uses" {style.stroke-dash: 3}
Harness -> Harness.TestNode_Struct: "manages (n=ClusterSize)"
Harness -> Harness.MetricsCollector: "owns"
Harness.TestNode_Struct -> Internal.Store: "owns"
Harness.TestNode_Struct -> Internal.PeerList: "owns"
Harness.TestNode_Struct -> Internal.FailureDetector: "owns"
Harness.TestNode_Struct -> Internal.Gossiper: "owns"
Harness.TestNode_Struct -> Internal.AntiEntropy: "owns"

# Data Flow within Protocol
Harness.TestNode_Struct -> Internal.Store: "versioned kv state"
Harness.TestNode_Struct -> Internal.PeerList: "membership management"
Harness.TestNode_Struct -> Internal.FailureDetector: "SWIM heartbeat"
Harness.TestNode_Struct -> Internal.Gossiper: "push-based epidemic gossip"
Harness.TestNode_Struct -> Internal.AntiEntropy: "merkle-tree sync"

Internal.PeerList -> Internal.FailureDetector: "peer selection"
Internal.PeerList -> Internal.Gossiper: "fanout selection"
Internal.PeerList -> Internal.AntiEntropy: "sync target selection"

Internal.Store -> Internal.Gossiper: "GetDelta()"
Internal.Store -> Internal.AntiEntropy: "CreateDigest()"

Internal.FailureDetector -> Internal.PeerList: "SetState(Dead/Suspect)"
Internal.Gossiper -> Harness.TestNode_Struct: "apply gossip updates"
Internal.AntiEntropy -> Harness.TestNode_Struct: "apply delta updates"

# Test Execution Flow
Harness.Start: "Main Test Loop" {
  style.fill: "${colors.test}"
  style.stroke: "${colors.test-header}"
  style.bold: true
}

Harness.Start -> Tests.ConvergenceTest.Run: "Parallel Exec"
Harness.Start -> Tests.DetectionTest.Run: "Parallel Exec"
Harness.Start -> Tests.PartitionTest.Run: "Sequential Exec"
Harness.Start -> Tests.BandwidthProfile.Run: "Sampling"
Harness.Start -> Tests.ConsistencyCheck.Run: "Verification"
Harness.Start -> Tests.ChaosTest.Run: "Interference"

Tests.ConvergenceTest.Run -> Tests.ConvergenceTest.Result: "generates"
Tests.DetectionTest.Run -> Tests.DetectionTest.Result: "generates"
Tests.PartitionTest.Run -> Tests.PartitionTest.Result: "generates"
Tests.BandwidthProfile.Run -> Tests.BandwidthProfile.Result: "generates"
Tests.ConsistencyCheck.Run -> Tests.ConsistencyCheck.Result: "generates"
Tests.ChaosTest.Run -> Tests.ChaosTest.Result: "generates"

# Styling connections
(Harness.Start -> Tests.*.Run)[*]: {
  style.stroke: "#64748B"
  style.stroke-width: 2
  target-arrowhead: triangle
}

# Legend for Node State
Legend: {
  near: bottom-left
  Active: {
    style.fill: "#D1FAE5"
    label: "Protocol Normal"
  }
  Degraded: {
    style.fill: "#FEF9C3"
    label: "Under Partition"
  }
  Critical: {
    style.fill: "#FEE2E2"
    label: "Fault Detected"
  }
}