layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header_bg: "#E8E8F8"
    header_text: "#4A4A5A"
    check_pass: "#22C55E"
    check_fail: "#E74C3C"
    committed_bg: "#E3F2FD"
    stale_bg: "#FEE2E2"
    arrow_check: "#3B82F6"
    arrow_violation: "#EF4444"
    box_border: "#D1D5DB"
    label_text: "#374151"
    meta_text: "#6B7280"
  }
}

title: |md
  # Consistency Check Algorithm: Stale Read Detection
  *Intel Manual Grade Technical Specification*
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
  }
}

# --- ALGORITHM PHASES ---

# Step 1: Version Snapshot
phase1_box: {
  label: "1. TRACK COMMITTED VERSIONS"
  style: {
    fill: ${colors.committed_bg}
    stroke: ${colors.box_border}
    stroke-width: 2
    border-radius: 8
  }
  
  definition: |md
    **Input:** Store Write Ops
    **Procedure:**
    1. Intercept `COMMIT` signal
    2. Map `Key -> {Version, Timestamp}`
    3. Register in `committed_registry`
  | {
    style: {
      font-size: 12
      font-color: ${colors.label_text}
    }
  }
}

# Step 2: Temporal Trigger
phase2_box: {
  label: "2. PERIODIC SCAN"
  style: {
    fill: ${colors.committed_bg}
    stroke: ${colors.box_border}
    stroke-width: 2
    border-radius: 8
  }
  
  logic: |md
    **Trigger:** `now() - commit_time > T_convergence`
    **Invariant:** 
    $\forall k \in K, \text{nodes } N \text{ must reflect } V_{committed}$
  | {
    style: {
      font-size: 12
      font-color: ${colors.label_text}
    }
  }
}

# Step 3: Distributed Comparison
phase3_box: {
  label: "3. CLUSTER INSPECTION"
  style: {
    fill: ${colors.committed_bg}
    stroke: ${colors.box_border}
    stroke-width: 2
    border-radius: 8
  }
  
  compare: |md
    **Remote Fetch:**
    - `RPC_Get(Node_i, Key_k)`
    **Validation Logic:**
    - **IF** `Remote.V < Local.V`: 
      - **SET** `State = VIOLATION`
    - **ELSE**: 
      - **SET** `State = PASS`
  | {
    style: {
      font-size: 12
      font-color: ${colors.label_text}
    }
  }
}

# Step 4: Violation Reporting
phase4_box: {
  label: "4. VIOLATION NOTIFICATION"
  style: {
    fill: ${colors.stale_bg}
    stroke: ${colors.check_fail}
    stroke-width: 3
    border-radius: 8
  }
  
  report: |md
    **Consolidate Metadata:**
    - `Key`: Resource Identifier
    - `Expected`: Committed Version
    - `Actual`: Stale Version Found
    - `Latency`: $T_{now} - T_{committed}$
  | {
    style: {
      font-size: 12
      font-color: "#7F1D1D"
    }
  }
}

# --- CONNECTIONS & FLOW ---

phase1_box -> phase2_box: "Snapshot\nRecorded" {
  style: {
    stroke: ${colors.arrow_check}
    stroke-width: 2
  }
}

phase2_box -> phase3_box: "Interval\nElapsed" {
  style: {
    stroke: ${colors.arrow_check}
    stroke-width: 2
  }
}

phase3_box -> phase4_box: "Inconsistency\nDetected" {
  style: {
    stroke: ${colors.arrow_violation}
    stroke-dash: 4
    stroke-width: 3
    animated: true
  }
}

# --- DOCUMENTATION & LEGEND ---

legend_box: {
  label: "Legend"
  near: bottom-right
  style: {
    fill: ${colors.header_bg}
    stroke: ${colors.box_border}
    border-radius: 4
    bold: true
  }
  
  item1: "✓ Pass: node_v >= comm_v" { 
    style: { font-color: ${colors.check_pass}; font-size: 10 } 
  }
  item2: "✗ Fail: node_v < comm_v" { 
    style: { font-color: ${colors.check_fail}; font-size: 10 } 
  }
  item3: "⏱ T_convergence: SLA bound" { 
    style: { font-color: ${colors.meta_text}; font-size: 10 } 
  }
}

meta_box: |md
  ### Analysis Specifications
  - **Complexity:** $O(K \times N)$ per sweep
  - **Scope:** Strong eventual consistency validation
  - **Data Structure:** Version Vector Hash Map
| {
  near: bottom-left
  style: {
    fill: ${colors.header_bg}
    stroke: ${colors.box_border}
    border-radius: 4
    font-size: 11
    font-color: ${colors.meta_text}
  }
}