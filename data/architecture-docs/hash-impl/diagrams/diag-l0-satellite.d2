direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
input_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  raw_input: {
    label: "Raw Input (sha256.c)"
    shape: parallelogram
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    style.stroke-width: 2
    style.font-size: 14
    style.bold: true
  }
  input_note: {
    shape: sql_table
    label: "Input Spec"
    r1: "Type    | const uint8_t *msg"
    r2: "Length  | size_t len (0..MAX)"
    r3: "Encode  | arbitrary bytes"
    r4: "Align   | none required"
  }
}
m1_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m1: {
    label: "M1: Padding & Block Parsing (sha256_pad.c)"
    direction: down
    style.fill: "#FFF3CD"
    style.stroke: "#F0A500"
    style.stroke-width: 3
    m1_steps: {
      shape: sql_table
      label: "FIPS 180-4 §5.1.1 — Preprocessing"
      s1: "1. Append 0x80 byte after last message byte"
      s2: "2. Zero-fill until padded_len ≡ 56 (mod 64)"
      s3: "3. Append 64-bit big-endian bit-length L"
      s4: "4. Result: N × 512-bit blocks"
      s5: "Boundary: len=55 → 1 block | len=56 → 2 blocks"
    }
    m1_out: {
      shape: sql_table
      label: "sha256_padded_t"
      f1: "0x00 | uint8_t[] | data[MAX_BLOCKS * 64]"
      f2: "0x.. | size_t    | num_blocks"
      f3: "Block i starts at data + i*64"
    }
  }
  m1_detail: {
    direction: down
    style.fill: "#FFFAF0"
    style.stroke: "#F0A500"
    style.stroke-width: 1
    style.stroke-dash: 4
    block_anatomy: {
      shape: sql_table
      label: "512-bit Block Layout (64 bytes)"
      r1: "0x00..0x?? | msg bytes      | original message"
      r2: "0x??       | 0x80           | marker bit"
      r3: "0x??..0x37 | 0x00 * k       | zero fill"
      r4: "0x38..0x3F | uint64_t BE    | bit-length L"
      r5: "Total: exactly 64 bytes per block"
    }
    endian_note: {
      shape: sql_table
      label: "Big-Endian Rule (all SHA-256)"
      e1: "Length field: buf[56]=(L>>56) .. buf[63]=(L>>0)"
      e2: "Words:  W[i] = (b0<<24)|(b1<<16)|(b2<<8)|b3"
      e3: "Digest: digest[i*4]=(H[i]>>24) .. +3=(H[i]&FF)"
    }
  }
}
m2_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m2: {
    label: "M2: Message Schedule Expansion (sha256_schedule.c)"
    direction: down
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
    style.stroke-width: 3
    m2_parse: {
      shape: sql_table
      label: "Step 1a: Parse Block → W[0..15]"
      p1: "W[t] = BE32(block + t*4)   for t=0..15"
      p2: "W[0] = (block[0]<<24)|..|block[3]"
      p3: "16 words × 32 bits = 512 bits = 1 block"
    }
    m2_expand: {
      shape: sql_table
      label: "Step 1b: Expand → W[16..63]  (FIPS §6.2.2)"
      e1: "W[t] = σ1(W[t-2]) + W[t-7] + σ0(W[t-15]) + W[t-16]"
      e2: "σ0(x) = ROTR(x,7)  ^ ROTR(x,18) ^ SHR(x,3)"
      e3: "σ1(x) = ROTR(x,17) ^ ROTR(x,19) ^ SHR(x,10)"
      e4: "All additions mod 2^32 (uint32_t wraps in C)"
      e5: "Output: uint32_t W[64]  (256 bytes on stack)"
    }
  }
  m2_detail: {
    direction: down
    style.fill: "#F0FFF4"
    style.stroke: "#28A745"
    style.stroke-width: 1
    style.stroke-dash: 4
    rotr_shr: {
      shape: sql_table
      label: "ROTR vs SHR — Critical Difference"
      r1: "ROTR(x,n): bits wrap | no bits lost | bijection"
      r2: "SHR(x,n):  bits lost | irreversible | n zeros in"
      r3: "ROTR32(x,n)=((x>>n)|(x<<(32-n))) on uint32_t"
      r4: "σ uses both: ROTR (diffuse) + SHR (destroy info)"
      r5: "Makes expansion non-invertible — security req."
    }
    sigma_naming: {
      shape: sql_table
      label: "DANGER: σ (lowercase) != Σ (uppercase)"
      n1: "σ0: (7, 18, 3)   — schedule only"
      n2: "σ1: (17, 19, 10) — schedule only"
      n3: "Σ0: (2, 13, 22)  — compression only"
      n4: "Σ1: (6, 11, 25)  — compression only"
      n5: "Swapping these = wrong hash, no error signal"
    }
  }
}
m3_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m3: {
    label: "M3: Compression Function (sha256_compress.c)"
    direction: down
    style.fill: "#F8D7DA"
    style.stroke: "#C0392B"
    style.stroke-width: 3
    m3_init: {
      shape: sql_table
      label: "Step 2: Init Working Vars from H[0..7]"
      i1: "a=H[0] b=H[1] c=H[2] d=H[3]"
      i2: "e=H[4] f=H[5] g=H[6] h=H[7]"
    }
    m3_round: {
      shape: sql_table
      label: "Step 3: 64-Round Loop (FIPS §6.2.2)"
      r1: "T1 = h + Σ1(e) + Ch(e,f,g) + K[t] + W[t]"
      r2: "T2 = Σ0(a) + Maj(a,b,c)"
      r3: "h=g; g=f; f=e; e=d+T1"
      r4: "d=c; c=b; b=a; a=T1+T2"
      r5: "Ch(x,y,z)  = (x&y)^(~x&z)  — MUX: x chooses y or z"
      r6: "Maj(x,y,z) = (x&y)^(x&z)^(y&z) — majority vote"
    }
    m3_update: {
      shape: sql_table
      label: "Step 4: Feed-Forward State Update"
      u1: "H[0]+=a  H[1]+=b  H[2]+=c  H[3]+=d"
      u2: "H[4]+=e  H[5]+=f  H[6]+=g  H[7]+=h"
      u3: "All += are mod 2^32 (Davies-Meyer pattern)"
      u4: "H is now updated — input for next block"
    }
  }
  m3_detail: {
    direction: down
    style.fill: "#FFF5F5"
    style.stroke: "#C0392B"
    style.stroke-width: 1
    style.stroke-dash: 4
    k_constants: {
      shape: sql_table
      label: "K[0..63] — Nothing-Up-My-Sleeve Constants"
      k1: "K[t] = floor(frac(cbrt(prime_t)) * 2^32)"
      k2: "K[0]=0x428a2f98  cbrt(2)=1.2599..."
      k3: "K[1]=0x71374491  cbrt(3)=1.4422..."
      k4: "K[63]=0xc67178f2 cbrt(311)"
      k5: "Independently derivable — no hidden backdoor"
    }
    nonlin_note: {
      shape: sql_table
      label: "Nonlinearity Sources (security)"
      n1: "Ch, Maj: AND creates GF(2) cross-terms xy"
      n2: "Mod addition: carry bits couple all bit positions"
      n3: "XOR+rotation: diffusion (linear but fast)"
      n4: "Mix: XOR(GF2) + ADD(Z/2^32Z) — incompatible algebras"
      n5: "Best preimage attack: ~2^255.9 — near brute-force"
    }
  }
}
hash_state: {
  label: "Running Hash State H[0..7] (32 bytes = 256 bits)"
  direction: right
  style.fill: "#E8D5F5"
  style.stroke: "#7B2D8B"
  style.stroke-width: 3
  h_struct: {
    shape: sql_table
    label: "uint32_t H[8] — persists across ALL blocks"
    h0: "H[0] | uint32_t | 0x6a09e667  frac(sqrt(2))*2^32"
    h1: "H[1] | uint32_t | 0xbb67ae85  frac(sqrt(3))*2^32"
    h2: "H[2] | uint32_t | 0x3c6ef372  frac(sqrt(5))*2^32"
    h3: "H[3] | uint32_t | 0xa54ff53a  frac(sqrt(7))*2^32"
    h4: "H[4] | uint32_t | 0x510e527f  frac(sqrt(11))*2^32"
    h5: "H[5] | uint32_t | 0x9b05688c  frac(sqrt(13))*2^32"
    h6: "H[6] | uint32_t | 0x1f83d9ab  frac(sqrt(17))*2^32"
    h7: "H[7] | uint32_t | 0x5be0cd19  frac(sqrt(19))*2^32"
    note: "MUST reset to these values before every new hash"
  }
  chain_note: {
    shape: sql_table
    label: "Merkle-Damgard Chain"
    c1: "Block 0: H_init → compress(H, block_0) → H_1"
    c2: "Block 1: H_1    → compress(H, block_1) → H_2"
    c3: "Block N: H_N    → compress(H, block_N) → H_final"
    c4: "H_final encodes ALL blocks — not just last block"
    c5: "Length extension: H_final IS the internal state"
  }
}
m4_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m4: {
    label: "M4: Final Output & Validation (sha256.c)"
    direction: down
    style.fill: "#D1ECF1"
    style.stroke: "#0C7B93"
    style.stroke-width: 3
    m4_digest: {
      shape: sql_table
      label: "Digest Serialization — 32 bytes → 64 hex chars"
      d1: "for i in 0..7: digest[i*4+0]=(H[i]>>24) & 0xFF"
      d2: "             : digest[i*4+1]=(H[i]>>16) & 0xFF"
      d3: "             : digest[i*4+2]=(H[i]>> 8) & 0xFF"
      d4: "             : digest[i*4+3]=(H[i]    ) & 0xFF"
      d5: "hex[i*2]   = '0123456789abcdef'[(byte>>4)&0xF]"
      d6: "hex[i*2+1] = '0123456789abcdef'[(byte   )&0xF]"
    }
    m4_ctx: {
      shape: sql_table
      label: "SHA256_CTX — Streaming State (sha256.h)"
      c1: "0x00 | uint32_t[8] | H[8]        — running state"
      c2: "0x20 | uint8_t[64] | buf[64]     — partial block"
      c3: "0x60 | size_t      | buf_len     — bytes in buf"
      c4: "0x68 | uint64_t    | total_bits  — for length field"
      c5: "Total: ~112 bytes — no heap alloc needed"
    }
    m4_api: {
      shape: sql_table
      label: "Streaming API (3 functions)"
      a1: "sha256_init(ctx)            — reset H+buf+counters"
      a2: "sha256_update(ctx, data, n) — buffer+compress"
      a3: "sha256_finalize(ctx, out)   — pad+compress+emit"
      a4: "Invariant: buf_len in [0,63] after every update()"
      a5: "update(chunk1)+update(chunk2) == oneshot(concat)"
    }
  }
  m4_vectors: {
    direction: down
    style.fill: "#E8F7FA"
    style.stroke: "#0C7B93"
    style.stroke-width: 1
    style.stroke-dash: 4
    nist_vectors: {
      shape: sql_table
      label: "NIST Test Vectors (must all pass)"
      v1: "SHA-256(\"\")    = e3b0c44298fc1c14...7852b855  [1 block]"
      v2: "SHA-256(\"abc\") = ba7816bf8f01cfea...f20015ad  [1 block]"
      v3: "SHA-256(56-byte) = 248d6a61d20638b8...db06c1   [2 blocks]"
      v4: "v3 tests: boundary case + Merkle-Damgard chain"
      v5: "If v1+v2 pass but v3 fails: check num_blocks==2"
    }
    hmac_ext: {
      shape: sql_table
      label: "Next: HMAC-SHA-256 (RFC 2104)"
      h1: "HMAC(K,msg) = H(K^opad || H(K^ipad || msg))"
      h2: "ipad = 0x36 * 64,  opad = 0x5C * 64"
      h3: "Double-hash defeats length-extension attack"
      h4: "Inner hash: sha256_update(ipad)+update(msg)"
      h5: "Outer hash: sha256_update(opad)+update(inner)"
    }
  }
}
digest_out: {
  label: "256-bit Digest Output (sha256.c)"
  shape: parallelogram
  style.fill: "#D4EDDA"
  style.stroke: "#28A745"
  style.stroke-width: 2
  style.font-size: 14
  style.bold: true
}
input_row -> m1_row: "uint8_t* + size_t | raw bytes" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  style.bold: true
}
m1_row -> m2_row: "uint8_t block[64] | 512-bit block" {
  style.stroke: "#F0A500"
  style.stroke-width: 2
  style.bold: true
}
m2_row -> m3_row: "uint32_t W[64] | 64 schedule words" {
  style.stroke: "#28A745"
  style.stroke-width: 2
  style.bold: true
}
m3_row -> hash_state: "H[i] += working_var[i] | state update" {
  style.stroke: "#C0392B"
  style.stroke-width: 2
  style.bold: true
}
hash_state -> m3_row: "H[0..7] | next block input" {
  style.stroke: "#7B2D8B"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.bold: true
}
hash_state -> m4_row: "H[0..7] final | after last block" {
  style.stroke: "#7B2D8B"
  style.stroke-width: 2
  style.bold: true
}
m4_row -> digest_out: "uint8_t digest[32] | 64-char hex" {
  style.stroke: "#0C7B93"
  style.stroke-width: 2
  style.bold: true
}
m1_row -> hash_state: "block_i pointer | loop index" {
  style.stroke: "#F0A500"
  style.stroke-width: 1
  style.stroke-dash: 3
}