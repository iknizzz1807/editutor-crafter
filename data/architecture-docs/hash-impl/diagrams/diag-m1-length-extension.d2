direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 5
  }
}
title: |md
  ## Length-Extension Attack: Why the Length Field Is Load-Bearing
  SHA-256 Padding Security — FIPS 180-4 §5.1.1
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  without_len: "VULNERABLE: SHA-256 WITHOUT Length Field" {
    direction: down
    style.fill: "#2d1a1a"
    style.stroke: "#cc2222"
    style.stroke-width: 3
    msg_block_v: "Message Blocks (no length encoded)" {
      direction: right
      style.fill: "#3d2020"
      style.stroke: "#cc3333"
      blk0_v: {
        shape: sql_table
        label: "Block 0 (64 bytes)"
        m0: "0x00 | bytes 0..59  | message data"
        p0: "0x3C | byte 60      | 0x80 marker"
        z0: "0x3D | bytes 61..63 | 0x00 padding"
        style.fill: "#3a2020"
      }
      blk1_v: {
        shape: sql_table
        label: "Block 1 (64 bytes)"
        m1: "0x00 | bytes 0..55  | message data"
        p1: "0x38 | byte 56      | 0x80 marker"
        z1: "0x39 | bytes 57..63 | 0x00 padding"
        note: "NO 64-bit length field here"
        style.fill: "#3a2020"
      }
    }
    compress_v: "Compression Chain (state exposed)" {
      direction: right
      style.fill: "#4a1a1a"
      style.stroke: "#cc3333"
      iv_v: "IV (H0..H7)" {
        style.fill: "#2a2a5a"
        style.stroke: "#5555cc"
        style.font-color: "#aaaaff"
      }
      f0_v: "f(block0)" {
        shape: hexagon
        style.fill: "#3a2a2a"
        style.stroke: "#cc4444"
      }
      f1_v: "f(block1)" {
        shape: hexagon
        style.fill: "#3a2a2a"
        style.stroke: "#cc4444"
      }
      digest_v: "digest = H_final" {
        style.fill: "#5a1a1a"
        style.stroke: "#ff4444"
        style.stroke-width: 3
        style.font-color: "#ff8888"
      }
      iv_v -> f0_v: "H[0..7]"
      f0_v -> f1_v: "H_mid"
      f1_v -> digest_v: "H_final | public"
    }
    attacker_box: "ATTACKER KNOWS: digest = H_final" {
      direction: down
      style.fill: "#4a0a0a"
      style.stroke: "#ff2222"
      style.stroke-width: 2
      atk_state: {
        shape: sql_table
        label: "Attacker Reconstructs State (sha256.c)"
        a1: "ctx.H[0] = digest[0..3]  | loaded from public digest"
        a2: "ctx.H[1] = digest[4..7]  | loaded from public digest"
        a3: "ctx.H[2] = digest[8..11] | loaded from public digest"
        a4: "ctx.H[3..7] = ...        | all from public digest"
        a5: "ctx.buf_len  = 0         | resume at block boundary"
        a6: "ctx.total_bits = ???     | attacker guesses / knows len"
        style.fill: "#3a0000"
        style.stroke: "#ff3333"
      }
      atk_code: {
        label: "Attack Code"
        width: 380
        code: |'c
          SHA256_CTX ctx;
          // NO sha256_init() — load digest directly!
          memcpy(ctx.H, public_digest, 32);
          ctx.buf_len    = 0;
          ctx.total_bits = known_len * 8;
          // Resume hashing with attacker data
          sha256_update(&ctx, evil_suffix, evil_len);
          sha256_finalize(&ctx, forged_mac);
          // forged_mac == SHA-256(secret||msg||pad||evil)
        '|
      }
    }
    vuln_result: "RESULT: Forged MAC accepted as valid" {
      style.fill: "#5a0000"
      style.stroke: "#ff0000"
      style.stroke-width: 3
      style.font-color: "#ff6666"
      style.bold: true
    }
    msg_block_v -> compress_v: "blocks"
    compress_v.digest_v -> attacker_box: "public | read"
    attacker_box -> vuln_result: "sha256_update(evil) | forge"
  }
  gap: "" {
    width: 40
    style.stroke: transparent
    style.fill: transparent
  }
  with_len: "SECURE: SHA-256 WITH Length Field (FIPS 180-4)" {
    direction: down
    style.fill: "#0d2a0d"
    style.stroke: "#22aa22"
    style.stroke-width: 3
    msg_block_s: "Padded Blocks — Length Field Embedded" {
      direction: right
      style.fill: "#152a15"
      style.stroke: "#33aa33"
      blk0_s: {
        shape: sql_table
        label: "Block 0 (64 bytes)"
        m0s: "0x00 | bytes 0..59  | message data"
        p0s: "0x3C | byte 60      | 0x80 marker"
        z0s: "0x3D | bytes 61..63 | 0x00 padding"
        style.fill: "#152a15"
      }
      blk1_s: {
        shape: sql_table
        label: "Block 1 (64 bytes) — FINAL"
        m1s: "0x00 | bytes 0..55  | message data"
        p1s: "0x38 | byte 56      | 0x80 marker"
        l0s: "0x39 | bytes 57..59 | 0x000000 (len hi)"
        l1s: "0x3C | bytes 60..63 | 0x000000D8 (216 bits)"
        note: "Length = 27 bytes * 8 = 216 bits, big-endian"
        style.fill: "#152a15"
        style.stroke: "#33cc33"
        style.stroke-width: 2
      }
    }
    compress_s: "Compression Chain (length baked in)" {
      direction: right
      style.fill: "#0a2a0a"
      style.stroke: "#33aa33"
      iv_s: "IV (H0..H7)" {
        style.fill: "#2a2a5a"
        style.stroke: "#5555cc"
        style.font-color: "#aaaaff"
      }
      f0_s: "f(block0)" {
        shape: hexagon
        style.fill: "#1a3a1a"
        style.stroke: "#44aa44"
      }
      f1_s: "f(block1+LEN)" {
        shape: hexagon
        style.fill: "#1a4a1a"
        style.stroke: "#44cc44"
        style.stroke-width: 2
      }
      digest_s: "digest = H_final" {
        style.fill: "#0a4a0a"
        style.stroke: "#44ff44"
        style.stroke-width: 3
        style.font-color: "#88ff88"
      }
      iv_s -> f0_s: "H[0..7]"
      f0_s -> f1_s: "H_mid"
      f1_s -> digest_s: "H_final | binds length"
    }
    attacker_block_s: "ATTACKER CANNOT FORGE" {
      direction: right
      style.fill: "#1a4a0a"
      style.stroke: "#44cc22"
      atk_fail: {
        shape: sql_table
        label: "Why Extension Fails (sha256_finalize)"
        f1: "digest  | encodes SHA-256(msg || pad(len)) | length is in final block"
        f2: "to extend | attacker needs next block after LEN | but LEN closes the block"
        f3: "new block | would start AFTER the length field | changes H_final"
        f4: "H_final  | already mixed with original length  | attacker cannot match"
        style.fill: "#103010"
        style.stroke: "#44cc22"
      }
      fix_code: {
        label: "Why Forging Fails"
        width: 380
        code: |'c
          // Attacker loads digest into ctx.H — same as before.
          // But now: the FINAL block of original message
          // ALREADY contained the 64-bit length field.
          // Appending evil_suffix requires a NEW block,
          // which hashes as:
          //   f(H_final, [evil_suffix || pad(orig_len + suffix_len)])
          // This is NOT the same as:
          //   SHA-256(secret||msg||evil_suffix)
          // The length field in the original padding
          // makes H_final depend on original length,
          // so resumed compression diverges from any
          // valid hash of the extended message.
        '|
      }
    }
    secure_result: "RESULT: Forged MAC diverges — rejected" {
      style.fill: "#0a4a0a"
      style.stroke: "#44ff44"
      style.stroke-width: 3
      style.font-color: "#88ff88"
      style.bold: true
    }
    msg_block_s -> compress_s: "blocks"
    compress_s.digest_s -> attacker_block_s: "public | read"
    attacker_block_s -> secure_result: "forged != valid | mismatch"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  padding_anatomy: "Padding Length Field — Byte Layout (sha256_pad.c)" {
    direction: down
    style.fill: "#1a1a2a"
    style.stroke: "#5555aa"
    layout_tbl: {
      shape: sql_table
      label: "Final 64-byte Block Structure"
      r0: "0x00 | [0..L-1]  | original message bytes (big-endian words in schedule)"
      r1: "0xL0 | L         | 0x80  — the mandatory 1-bit marker (FIPS 5.1.1)"
      r2: "0xL1 | L+1..55   | 0x00  — zero padding (k zero bytes, k >= 0)"
      r3: "0x38 | 56        | length[7] = (bit_len >> 56) & 0xFF — MSB first"
      r4: "0x39 | 57        | length[6] = (bit_len >> 48) & 0xFF"
      r5: "0x3A | 58        | length[5] = (bit_len >> 40) & 0xFF"
      r6: "0x3B | 59        | length[4] = (bit_len >> 32) & 0xFF"
      r7: "0x3C | 60        | length[3] = (bit_len >> 24) & 0xFF"
      r8: "0x3D | 61        | length[2] = (bit_len >> 16) & 0xFF"
      r9: "0x3E | 62        | length[1] = (bit_len >>  8) & 0xFF"
      r10: "0x3F | 63       | length[0] = (bit_len      ) & 0xFF — LSB last"
      note: "Total: 64 bytes = 512 bits. Length always big-endian. FIPS 180-4 §5.1.1"
    }
    c_impl: {
      label: "C Implementation (sha256_pad.c)"
      width: 420
      code: |'c
        uint64_t bit_length = (uint64_t)len * 8;
        uint8_t *lf = out->data + total_padded - 8;
        lf[0] = (uint8_t)(bit_length >> 56); // MSB
        lf[1] = (uint8_t)(bit_length >> 48);
        lf[2] = (uint8_t)(bit_length >> 40);
        lf[3] = (uint8_t)(bit_length >> 32);
        lf[4] = (uint8_t)(bit_length >> 24);
        lf[5] = (uint8_t)(bit_length >> 16);
        lf[6] = (uint8_t)(bit_length >>  8);
        lf[7] = (uint8_t)(bit_length      ); // LSB
      '|
    }
  }
  hmac_box: "FULL SOLUTION: HMAC-SHA-256 (hmac_sha256.c)" {
    direction: down
    style.fill: "#1a1a3a"
    style.stroke: "#4444cc"
    style.stroke-width: 2
    hmac_formula: {
      shape: sql_table
      label: "HMAC Construction — RFC 2104"
      h0: "Step 1 | ipad = 0x36 * 64        | K XOR ipad (inner key)"
      h1: "Step 2 | inner = SHA-256(ipad_k || msg) | inner hash"
      h2: "Step 3 | opad = 0x5C * 64        | K XOR opad (outer key)"
      h3: "Step 4 | HMAC = SHA-256(opad_k || inner) | outer hash"
      h4: "Security | two nested hashes        | outer binds inner + key"
      h5: "Attack? | attacker knows inner      | cannot extend: outer re-hashes with key"
      style.fill: "#1a1a3a"
      style.stroke: "#5555cc"
    }
    hmac_code: {
      label: "HMAC Sketch (hmac_sha256.c)"
      width: 400
      code: |'c
        // inner = SHA-256(K ^ ipad || message)
        sha256_init(&ctx);
        sha256_update(&ctx, k_xor_ipad, 64);
        sha256_update(&ctx, msg, msg_len);
        sha256_finalize(&ctx, inner);
        // outer = SHA-256(K ^ opad || inner)
        sha256_init(&ctx);           // MUST reset
        sha256_update(&ctx, k_xor_opad, 64);
        sha256_update(&ctx, inner, 32);
        sha256_finalize(&ctx, mac);
        // Extension impossible: outer hash uses opad key
      '|
    }
    hmac_why: {
      shape: sql_table
      label: "Why HMAC Defeats Length Extension"
      w1: "Inner digest  | = SHA-256(ipad_k || msg)    | exposed (same vulnerability)"
      w2: "But outer hash | SHA-256(opad_k || inner)   | wraps inner with secret key"
      w3: "Attacker forges | needs opad_k = K XOR 0x5C | does not know K"
      w4: "Cannot resume  | outer hash starts fresh     | no state to hijack"
      style.fill: "#0a0a2a"
      style.stroke: "#6666dd"
    }
  }
}
row1 -> row2: "length field details + HMAC extension"
legend: "Color Legend" {
  near: bottom-right
  shape: rectangle
  style.fill: "#111122"
  style.stroke: "#333366"
  l1: "Red border = vulnerable path (no length field)"  { style.font-color: "#ff6666" }
  l2: "Green border = secure path (length field present)" { style.font-color: "#66ff66" }
  l3: "Blue border = data structures / byte layout" { style.font-color: "#6688ff" }
  l4: "Purple border = HMAC full solution" { style.font-color: "#aa88ff" }
}