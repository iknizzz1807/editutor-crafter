direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
start: {
  label: "Input: message length L bits"
  shape: oval
  style.fill: "#B5AFF6"
  style.font-color: "#1a1a2e"
  style.bold: true
}
compute_mod: {
  label: "Compute R = L mod 512"
  shape: rectangle
  style.fill: "#DEE1EB"
  style.font-color: "#1a1a2e"
  note: {
    label: "R = bits used in current 512-bit frame"
    style.fill: "#E4DBFE"
    style.stroke: "#B5AFF6"
    style.font-size: 12
  }
}
append_1bit: {
  label: "Append 1-bit (0x80 byte)"
  shape: rectangle
  style.fill: "#DEE1EB"
  style.font-color: "#1a1a2e"
  note2: {
    label: "WARNING: this consumes 1 slot. Only 447 slots remain for zero-fill, not 448."
    style.fill: "#FFE0E0"
    style.stroke: "#FF6B6B"
    style.font-color: "#8B0000"
    style.font-size: 12
    style.bold: true
  }
}
branch: {
  label: "R + 1 <= 448 ?"
  shape: diamond
  style.fill: "#f9d8a7"
  style.font-color: "#1a1a2e"
  style.bold: true
  width: 260
}
single_block_path: {
  label: "SINGLE BLOCK PATH"
  style.fill: "#e6f7e6"
  style.stroke: "#2e7d32"
  style.font-color: "#1b5e20"
  style.bold: true
  direction: down
  zero_fill_single: {
    label: "Zero-fill k bits"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.font-color: "#1b5e20"
    formula_s: {
      label: "k = (447 - R) mod 512"
      style.fill: "#A5D6A7"
      style.stroke: "#2e7d32"
      style.font-size: 13
      style.bold: true
      style.font-color: "#1b5e20"
    }
    formula_detail: {
      label: "k = 447 - R   (since R+1 <= 448, k >= 0)"
      style.fill: "#F1F8E9"
      style.stroke: "#81C784"
      style.font-size: 11
      style.font-color: "#33691e"
    }
  }
  append_len_single: {
    label: "Append 64-bit big-endian L"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.font-color: "#1b5e20"
  }
  result_single: {
    label: "Total = 1 block (512 bits)"
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: "white"
    style.bold: true
  }
  zero_fill_single -> append_len_single -> result_single
}
two_block_path: {
  label: "TWO BLOCK PATH"
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.font-color: "#bf360c"
  style.bold: true
  direction: down
  zero_fill_double: {
    label: "Zero-fill k bits to end block 1"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.font-color: "#bf360c"
    formula_d: {
      label: "k = (511 - R)  [fills to end of 512-bit block]"
      style.fill: "#FFCC80"
      style.stroke: "#e65100"
      style.font-size: 13
      style.bold: true
      style.font-color: "#bf360c"
    }
    overflow_note: {
      label: "R+1 > 448: no room for 64-bit length field in block 1"
      style.fill: "#FFF8E1"
      style.stroke: "#FFA000"
      style.font-size: 11
      style.font-color: "#e65100"
    }
  }
  compress_block1: {
    label: "Compress block 1 (no length field yet)"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.font-color: "#bf360c"
  }
  block2_zeros: {
    label: "Block 2: 448 bits of zero fill"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.font-color: "#bf360c"
  }
  append_len_double: {
    label: "Append 64-bit big-endian L (ends block 2)"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.font-color: "#bf360c"
  }
  result_double: {
    label: "Total = 2 blocks (1024 bits)"
    shape: rectangle
    style.fill: "#FF5722"
    style.font-color: "white"
    style.bold: true
  }
  zero_fill_double -> compress_block1 -> block2_zeros -> append_len_double -> result_double
}
why_447: {
  label: "Why 447, not 448?"
  style.fill: "#1a1a2e"
  style.font-color: "white"
  style.bold: true
  style.border-radius: 8
  direction: down
  slot_budget: {
    shape: sql_table
    label: "512-bit block slot budget"
    msg_bits: "0 .. L-1       | message bits      | L bits"
    one_bit:  "L             | 1-bit marker      | 1 bit  ← consumes slot 448"
    zeros:    "L+1 .. 447    | zero padding      | 447-L bits (may be 0)"
    length:   "448 .. 511    | 64-bit length L   | 64 bits"
    total:    "Total          |                   | 512 bits"
  }
  trap_note: {
    label: "Off-by-one trap: the 1-bit occupies the 448th slot (index L). If you pad to 448 bits total, the length field has NO room. Target is 448 bits AFTER the 1-bit marker, meaning the marker must land at position <= 447."
    style.fill: "#FF6B6B"
    style.font-color: "white"
    style.bold: true
    style.border-radius: 6
    width: 480
  }
}
concrete_examples: {
  label: "Concrete Examples"
  style.fill: "#0d1b2a"
  style.font-color: "white"
  style.bold: true
  direction: down
  examples_table: {
    shape: sql_table
    label: "Boundary cases (message length in bytes)"
    h0: "L bytes | R=L*8 mod 512 | R+1 <= 448? | blocks | zero bytes k"
    e1: "0 bytes  | R=0           | YES (1<=448) | 1      | k=55 bytes"
    e2: "3 bytes  | R=24          | YES (25<=448)| 1      | k=51 bytes"
    e3: "55 bytes | R=440         | YES (441<=448)| 1     | k=0 bytes  (tight!)"
    e4: "56 bytes | R=448         | NO  (449>448)| 2      | spills to block 2"
    e5: "64 bytes | R=0           | YES (1<=448) | 1      | k=55 bytes"
    trap: "55->56 byte boundary triggers extra block — the off-by-one trap"
  }
}
start -> compute_mod -> append_1bit -> branch
branch -> single_block_path: "YES\nR+1 <= 448\n(fits in one block)" {
  style.stroke: "#2e7d32"
  style.font-color: "#2e7d32"
  style.bold: true
}
branch -> two_block_path: "NO\nR+1 > 448\n(no room for length)" {
  style.stroke: "#e65100"
  style.font-color: "#e65100"
  style.bold: true
  style.stroke-dash: 4
}
append_1bit -> why_447: "explains why" {
  style.stroke: "#B5AFF6"
  style.stroke-dash: 3
  style.font-color: "#7B1FA2"
}
single_block_path.result_single -> concrete_examples: "example: L=24 bits (abc)" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
  style.font-color: "#2e7d32"
}
two_block_path.result_double -> concrete_examples: "example: L=448 bits (56 bytes)" {
  style.stroke: "#FF5722"
  style.stroke-dash: 3
  style.font-color: "#e65100"
}