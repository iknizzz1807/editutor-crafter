direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "SHA-256 Padding Anatomy (FIPS 180-4 §5.1.1)" {
  near: top-center
  style: {
    font-size: 18
    bold: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  case1: "CASE A — 'abc' (3 bytes → 1 block)" {
    direction: down
    style.fill: "#f0f4ff"
    style.stroke: "#4a6fa5"
    style.border-radius: 8
    style.font-size: 13
    style.bold: true
    block0: {
      shape: sql_table
      label: "Block 0 — 64 bytes (512 bits)"
      msg_field:  "0x00–0x02 | uint8_t[3]  | message 'abc'  (0x61 0x62 0x63) — 24 bits"
      pad_bit:    "0x03      | uint8_t      | 0x80 marker  — '1' bit + 7 zero bits — 8 bits"
      zero_fill:  "0x04–0x37 | uint8_t[52]  | zero fill — 416 bits"
      len_field:  "0x38–0x3F | uint64_t BE  | length = 0x0000000000000018 (24 bits) — 64 bits"
      total:      "Total: 64 bytes — 1 block — 3+1+52+8 = 64 bytes"
    }
    bit_annot1: {
      shape: sql_table
      label: "Field Bit Counts — Case A"
      r0: "message     |  3 bytes |  24 bits"
      r1: "0x80 marker |  1 byte  |   8 bits"
      r2: "zero fill   | 52 bytes | 416 bits"
      r3: "length BE64 |  8 bytes |  64 bits"
      r4: "TOTAL       | 64 bytes | 512 bits"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  case2: "CASE B — 56-byte message → 2 blocks (boundary trap)" {
    direction: down
    style.fill: "#fff8f0"
    style.stroke: "#c0622a"
    style.border-radius: 8
    style.font-size: 13
    style.bold: true
    block0b: {
      shape: sql_table
      label: "Block 0 — 64 bytes (512 bits)"
      msg_field:  "0x00–0x37 | uint8_t[56]  | message bytes M[0..55] — 448 bits"
      pad_bit:    "0x38      | uint8_t      | 0x80 marker — 8 bits"
      zero_fill:  "0x39–0x3F | uint8_t[7]   | zero fill — 56 bits (NOT enough for len field)"
      no_len:     "—         | (no length)  | length field CANNOT fit: 7 < 8 bytes remain"
      total:      "Total: 64 bytes — NO length field here — SPILL to Block 1"
    }
    block1b: {
      shape: sql_table
      label: "Block 1 — 64 bytes (512 bits)"
      zero_fill:  "0x40–0x77 | uint8_t[56]  | zero fill — 448 bits"
      len_field:  "0x78–0x7F | uint64_t BE  | length = 0x00000000000001C0 (448 bits) — 64 bits"
      total:      "Total: 64 bytes — length field lives here — 2-block padding"
    }
    bit_annot2: {
      shape: sql_table
      label: "Field Bit Counts — Case B"
      r0: "Block 0: message     | 56 bytes | 448 bits"
      r1: "Block 0: 0x80 marker |  1 byte  |   8 bits"
      r2: "Block 0: zero fill   |  7 bytes |  56 bits"
      r3: "Block 1: zero fill   | 56 bytes | 448 bits"
      r4: "Block 1: length BE64 |  8 bytes |  64 bits"
      r5: "TOTAL                |128 bytes |1024 bits (2 blocks)"
    }
    trap_note: "BOUNDARY RULE: if (len % 64 >= 56) → need extra block" {
      style.fill: "#ffe0d0"
      style.stroke: "#c0622a"
      style.border-radius: 6
      style.font-size: 12
      style.bold: true
    }
  }
}
rule_box: {
  shape: sql_table
  label: "Padding Algorithm — FIPS 180-4 §5.1.1"
  r0: "Step 1 | Append 0x80 byte immediately after last message byte"
  r1: "Step 2 | Append k zero bytes: k = smallest k>=0 s.t. (len+1+k) ≡ 56 (mod 64)"
  r2: "Step 3 | Append 8-byte big-endian encoding of (len * 8) — original bit length"
  r3: "Result | Total padded length is always an exact multiple of 64 bytes"
  r4: "55-byte msg → 1 block | 56-byte msg → 2 blocks (the classic trap)"
}
rule_box.near: bottom-center
endian_box: {
  shape: sql_table
  label: "Big-Endian Length Field — 'abc' example (len=3 bytes, bits=24=0x18)"
  r0: "byte offset | 0x38 | 0x39 | 0x3A | 0x3B | 0x3C | 0x3D | 0x3E | 0x3F"
  r1: "hex value   | 0x00 | 0x00 | 0x00 | 0x00 | 0x00 | 0x00 | 0x00 | 0x18"
  r2: "MSB at lowest address — most significant byte 0x00 written first"
  r3: "56-byte msg: bits=448=0x1C0 → bytes [0x00,0x00,0x00,0x00,0x00,0x00,0x01,0xC0]"
}
row1 -> row2: "same algorithm" {
  style.stroke-dash: 4
  style.stroke: "#888888"
}
row2 -> rule_box: "rule summary"
row2 -> endian_box: "length field detail"