direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "The Masking Bug: Python Integer Overflow vs C uint32_t"
  style.font-size: 20
  style.bold: true
}
title.near: top-center
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_panel: "WITHOUT masking (Python)" {
    direction: down
    style.fill: "#fff0f0"
    style.stroke: "#cc0000"
    style.stroke-width: 2
    input_vals: {
      shape: sql_table
      label: "Input Words (32-bit range)"
      w0: "W[t-16] | uint | 0xFFFFFFFF"
      w1: "W[t-7]  | uint | 0xFFFFFFFF"
      w2: "sig0    | uint | 0xFFFFFFFF"
      w3: "sig1    | uint | 0xFFFFFFFF"
    }
    arrow1: "Python: a + b + c + d" {
      shape: parallelogram
      style.fill: "#ffcccc"
      style.stroke: "#cc0000"
    }
    overflow_result: {
      shape: sql_table
      label: "Result — WRONG (33+ bits)"
      r0: "True sum  | int | 0x1FFFFFFFC"
      r1: "Bit width | int | 33 bits"
      r2: "Expected  | u32 | 0xFFFFFFFC"
      r3: "ERROR     | --- | extra bit retained"
    }
    overflow_result.style.fill: "#ffdddd"
    overflow_result.style.stroke: "#cc0000"
    cascade1: "Cascade into next round" {
      shape: diamond
      style.fill: "#ff9999"
      style.stroke: "#cc0000"
    }
    round2_bad: {
      shape: sql_table
      label: "W[t+1] — Diverges from NIST"
      rb0: "W[t+1]  | int | 0x2_garbage"
      rb1: "W[t+2]  | int | 0x4_garbage"
      rb2: "W[t+3]  | int | exploding..."
      rb3: "status  | --- | WRONG HASH"
    }
    round2_bad.style.fill: "#ffcccc"
    round2_bad.style.stroke: "#cc0000"
    input_vals -> arrow1: "sum 4 words"
    arrow1 -> overflow_result: "no truncation"
    overflow_result -> cascade1: "feeds W[t+1]"
    cascade1 -> round2_bad: "error multiplies"
  }
  gap: "" {
    width: 40
    style.stroke: transparent
    style.fill: transparent
  }
  right_panel: "WITH masking (Python) / C uint32_t auto-wrap" {
    direction: down
    style.fill: "#f0fff0"
    style.stroke: "#006600"
    style.stroke-width: 2
    input_vals_r: {
      shape: sql_table
      label: "Input Words (32-bit range)"
      w0r: "W[t-16] | uint32 | 0xFFFFFFFF"
      w1r: "W[t-7]  | uint32 | 0xFFFFFFFF"
      w2r: "sig0    | uint32 | 0xFFFFFFFF"
      w3r: "sig1    | uint32 | 0xFFFFFFFF"
    }
    arrow2: "Python: (a+b+c+d) & 0xFFFFFFFF" {
      shape: parallelogram
      style.fill: "#ccffcc"
      style.stroke: "#006600"
    }
    correct_result: {
      shape: sql_table
      label: "Result — CORRECT (32 bits)"
      rc0: "True sum  | int   | 0x1FFFFFFFC"
      rc1: "Masked    | u32   | 0xFFFFFFFC"
      rc2: "Bit width | bits  | 32 bits"
      rc3: "Status    | check | matches NIST"
    }
    correct_result.style.fill: "#ddffdd"
    correct_result.style.stroke: "#006600"
    cascade2: "Feeds next round" {
      shape: diamond
      style.fill: "#99ff99"
      style.stroke: "#006600"
    }
    round2_good: {
      shape: sql_table
      label: "W[t+1..t+3] — Matches NIST"
      rg0: "W[t+1] | u32 | 0x... correct"
      rg1: "W[t+2] | u32 | 0x... correct"
      rg2: "W[t+3] | u32 | 0x... correct"
      rg3: "status | --- | CORRECT HASH"
    }
    round2_good.style.fill: "#ccffcc"
    round2_good.style.stroke: "#006600"
    input_vals_r -> arrow2: "sum 4 words"
    arrow2 -> correct_result: "& 0xFFFFFFFF truncates"
    correct_result -> cascade2: "feeds W[t+1]"
    cascade2 -> round2_good: "stays in spec"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c_note: "C uint32_t: Automatic Overflow" {
    direction: down
    style.fill: "#f0f4ff"
    style.stroke: "#3333cc"
    style.stroke-width: 2
    c_code: {
      label: "C automatic wrap"
      width: 320
      code: |'c
        /* C: uint32_t wraps at 2^32 automatically */
        uint32_t W[t] = SIGMA_LOWER_1(W[t-2])
                      + W[t-7]
                      + SIGMA_LOWER_0(W[t-15])
                      + W[t-16];
        /* No masking needed — type enforces it */
      '|
    }
    py_code: {
      label: "Python REQUIRED mask"
      width: 320
      code: |'py
        # Python: integers are unbounded — MUST mask
        W[t] = (sigma1(W[t-2])
              + W[t-7]
              + sigma0(W[t-15])
              + W[t-16]) & 0xFFFFFFFF
        # Omitting & 0xFFFFFFFF = silent wrong hash
      '|
    }
  }
  divergence_note: "Divergence Timeline (no masking)" {
    direction: down
    style.fill: "#fffbe6"
    style.stroke: "#cc8800"
    style.stroke-width: 2
    div_table: {
      shape: sql_table
      label: "Schedule Error Propagation"
      d0: "Round W[16] | may be OK   | if inputs small"
      d1: "Round W[17] | risk starts | sigma on big val"
      d2: "Round W[18] | likely bad  | 33-bit sigma arg"
      d3: "Round W[20] | certain bad | cascaded overflow"
      d4: "Final hash  | WRONG       | all 64 chars off"
    }
    note_box: "Why it is silent" {
      style.fill: "#fff3cc"
      style.stroke: "#cc8800"
      note_text: |md
        Python produces a valid-looking 64-char
        hex string — it is just the WRONG hash.
        No exception, no warning, no indication.
        Only comparing against NIST test vectors
        reveals the divergence.
      |
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  verdict: "Language Safety Summary" {
    direction: down
    style.fill: "#f5f0ff"
    style.stroke: "#6600cc"
    style.stroke-width: 2
    vtable: {
      shape: sql_table
      label: "32-bit Modular Arithmetic by Language"
      v0: "C uint32_t    | automatic | no mask needed  | spec-faithful"
      v1: "Python int    | unbounded | & 0xFFFFFFFF    | easy to forget"
      v2: "JS Number     | float64   | & 0xFFFFFFFF    | AND coerces i32"
      v3: "Java int      | wraps i32 | cast to int     | signed — watch"
      v4: "Go uint32     | automatic | no mask needed  | spec-faithful"
      v5: "Rust u32      | panics    | wrapping_add()  | explicit model"
    }
  }
}
row1 -> row2: "after 3-4 rounds"
row2 -> row3: "implementation choice"