direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## ROTR vs SHR: Bit-Level Comparison (32-bit word)
  σ functions combine BOTH operations for full bit dispersion
| {near: top-center}
input_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_label: "Input x" {
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    style.bold: true
    width: 120
  }
  input_word: {
    shape: sql_table
    label: "x = 0xABCDEF01  (example 32-bit word)"
    b31: "bit 31 | 1 | MSB"
    b30: "bit 30 | 0 |"
    b29: "bit 29 | 1 |"
    b28: "bit 28 | 0 |"
    bdot: "... 25 bits ... | ... |"
    b03: "bit  3 | 0 |"
    b02: "bit  2 | 0 | ← These 3 bits"
    b01: "bit  1 | 0 | ← are the key"
    b00: "bit  0 | 1 | ← difference  LSB"
  }
}
ops_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rotr_col: "ROTR(x, 3)  —  Right Rotate by 3" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    rotr_desc: {
      shape: sql_table
      label: "ROTR(x, 3) = (x >> 3) | (x << 29)"
      r_out31: "bit 31 | 0 | ← was bit 2 of x  (WRAPPED)"
      r_out30: "bit 30 | 0 | ← was bit 1 of x  (WRAPPED)"
      r_out29: "bit 29 | 1 | ← was bit 0 of x  (WRAPPED)"
      r_out28: "bit 28 | 1 | ← was bit 31 of x (shifted)"
      r_out27: "bit 27 | 0 | ← was bit 30 of x (shifted)"
      r_dot:   "... 24 bits ... | ... | (shifted right by 3)"
      r_out03: "bit  3 | 1 | ← was bit  6 of x"
      r_out02: "bit  2 | 0 | ← was bit  5 of x"
      r_out01: "bit  1 | 0 | ← was bit  4 of x"
      r_out00: "bit  0 | 0 | ← was bit  3 of x  LSB"
      r_total: "PRESERVED | 32/32 bits | ALL bits survive rotation"
    }
    rotr_prop: "Property: BIJECTIVE (reversible permutation)" {
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      style.bold: true
    }
  }
  gap_col: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 40
  }
  shr_col: "SHR(x, 3)  —  Right Shift by 3" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    shr_desc: {
      shape: sql_table
      label: "SHR(x, 3) = x >> 3"
      s_out31: "bit 31 | 0 | ← ZERO FILLED  (not from x)"
      s_out30: "bit 30 | 0 | ← ZERO FILLED  (not from x)"
      s_out29: "bit 29 | 0 | ← ZERO FILLED  (not from x)"
      s_out28: "bit 28 | 1 | ← was bit 31 of x (shifted)"
      s_out27: "bit 27 | 0 | ← was bit 30 of x (shifted)"
      s_dot:   "... 24 bits ... | ... | (shifted right by 3)"
      s_out03: "bit  3 | 1 | ← was bit  6 of x"
      s_out02: "bit  2 | 0 | ← was bit  5 of x"
      s_out01: "bit  1 | 0 | ← was bit  4 of x"
      s_out00: "bit  0 | 0 | ← was bit  3 of x  LSB"
      s_total: "DESTROYED | 3/32 bits | bits 0,1,2 of x are GONE forever"
    }
    shr_prop: "Property: NON-INVERTIBLE (information destroyed)" {
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      style.stroke-width: 2
      style.bold: true
    }
  }
}
sigma_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sigma0_box: "σ0(x) = ROTR(x,7) ⊕ ROTR(x,18) ⊕ SHR(x,3)" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    sigma0_detail: {
      shape: sql_table
      label: "σ0 used in message schedule for W[t-15]"
      t1: "ROTR(x,7)  | view 1 | rotated perspective — ALL 32 bits present"
      t2: "ROTR(x,18) | view 2 | rotated perspective — ALL 32 bits present"
      t3: "SHR(x,3)   | view 3 | truncated perspective — bits 0,1,2 zeroed"
      xr: "XOR result | output | each output bit depends on 3 different input positions"
      irr: "IRREVERSIBLE | design goal | SHR prevents schedule inversion"
    }
  }
  sigma1_box: "σ1(x) = ROTR(x,17) ⊕ ROTR(x,19) ⊕ SHR(x,10)" {
    direction: down
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    style.stroke-width: 2
    sigma1_detail: {
      shape: sql_table
      label: "σ1 used in message schedule for W[t-2]"
      t1: "ROTR(x,17) | view 1 | rotated perspective — ALL 32 bits present"
      t2: "ROTR(x,19) | view 2 | rotated perspective — ALL 32 bits present"
      t3: "SHR(x,10)  | view 3 | truncated perspective — bits 0-9 zeroed"
      xr: "XOR result | output | wide asymmetry vs σ0 prevents structural symmetry"
      irr: "IRREVERSIBLE | design goal | SHR prevents schedule inversion"
    }
  }
}
key_insight: "KEY INSIGHT: Why BOTH Operations Are Required" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 3
  insight_table: {
    shape: sql_table
    label: "Design rationale for ROTR + SHR combination in σ functions"
    r1: "ROTR alone | Bijective | Schedule would be reversible → attacker can invert W→message"
    r2: "SHR alone  | Lossy     | Too much information destroyed → poor diffusion"
    r3: "ROTR+SHR   | Optimal   | Full diffusion (ROTR) + irreversibility (SHR) achieved"
    r4: "C macro    | ROTR32    | ((uint32_t)(x) >> n) OR ((uint32_t)(x) << (32-n))"
    r5: "C macro    | SHR32     | ((uint32_t)(x) >> n)  — trailing bits permanently lost"
    r6: "Warning    | uint32_t  | MUST use unsigned — signed left-shift is UB in C"
  }
}
input_row -> ops_row: "apply operation"
ops_row.rotr_col -> sigma_row.sigma0_box: "ROTR contributes"
ops_row.shr_col -> sigma_row.sigma0_box: "SHR contributes"
ops_row.rotr_col -> sigma_row.sigma1_box: "ROTR contributes"
ops_row.shr_col -> sigma_row.sigma1_box: "SHR contributes"
sigma_row -> key_insight: "combined effect"
ops_row.rotr_col.rotr_prop -> ops_row.shr_col.shr_prop: "contrast" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 4
}