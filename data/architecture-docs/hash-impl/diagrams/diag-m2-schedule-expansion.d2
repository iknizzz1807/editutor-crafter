direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title_box: "Message Schedule Expansion: W[0]..W[63] (sha256_schedule.c)" {
  style.fill: "#1a1a2e"
  style.font-color: "#e0e0ff"
  style.bold: true
  style.font-size: 18
  style.border-radius: 6
}
row_primitives: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sigma_panel: "Primitive Operations (sha256_schedule.h)" {
    direction: down
    style.fill: "#0d1b2a"
    style.stroke: "#4a9eff"
    style.border-radius: 6
    rotr_def: {
      shape: sql_table
      label: "ROTR32(x, n) — Right-Rotate 32-bit"
      op1: "((uint32_t)(x) >> (n)) | ((uint32_t)(x) << (32-(n)))"
      note: "ALL bits preserved — wraps from right to left"
      constraint: "Precondition: 1 <= n <= 31"
    }
    shr_def: {
      shape: sql_table
      label: "SHR32(x, n) — Logical Right-Shift"
      op1: "(uint32_t)(x) >> (n)"
      note: "Bits shifted off right are LOST — fills zeros left"
      constraint: "Destroys info: enables non-invertibility"
    }
    sigma0_def: {
      shape: sql_table
      label: "σ0(x) — FIPS 180-4 Eq.(4.6)"
      r1: "ROTR32(x,  7)"
      r2: "ROTR32(x, 18)"
      r3: "SHR32 (x,  3)"
      result: "XOR of all three — applied to W[t-15]"
      note: "Constants: (7, 18, 3) — lowercase schedule σ"
    }
    sigma1_def: {
      shape: sql_table
      label: "σ1(x) — FIPS 180-4 Eq.(4.7)"
      r1: "ROTR32(x, 17)"
      r2: "ROTR32(x, 19)"
      r3: "SHR32 (x, 10)"
      result: "XOR of all three — applied to W[t-2]"
      note: "Constants: (17,19,10) — DIFFERENT from uppercase Σ1"
    }
    warning_box: "WARNING: Constant Confusion Bug" {
      style.fill: "#3d0000"
      style.stroke: "#ff4444"
      style.border-radius: 4
      msg1: "σ0 uses (7,18,3)    ← message schedule ONLY"
      msg2: "Σ0 uses (2,13,22)   ← compression fn ONLY"
      msg3: "σ1 uses (17,19,10)  ← message schedule ONLY"
      msg4: "Σ1 uses (6,11,25)   ← compression fn ONLY"
      msg5: "Mixing these produces plausible-looking WRONG W values"
    }
  }
  code_panel: "C Implementation (sha256_schedule.c)" {
    direction: down
    style.fill: "#0d1b2a"
    style.stroke: "#44bb44"
    style.border-radius: 6
    code_macros: {
      label: "Macro Definitions"
      width: 420
      code: |'c
        #define ROTR32(x,n) \
          (((uint32_t)(x)>>(n))|((uint32_t)(x)<<(32-(n))))
        #define SHR32(x,n)  ((uint32_t)(x)>>(n))
        #define SIGMA_LOWER_0(x) \
          (ROTR32((x),7)^ROTR32((x),18)^SHR32((x),3))
        #define SIGMA_LOWER_1(x) \
          (ROTR32((x),17)^ROTR32((x),19)^SHR32((x),10))
      '|
    }
    code_parse: {
      label: "Step 1: Parse 16 Big-Endian Words"
      width: 420
      code: |'c
        for (int t = 0; t < 16; t++) {
          W[t] = ((uint32_t)block[t*4+0]<<24)
               | ((uint32_t)block[t*4+1]<<16)
               | ((uint32_t)block[t*4+2]<< 8)
               | ((uint32_t)block[t*4+3]    );
        }
        /* Big-endian: block[0] is MSB of W[0] */
        /* x86 is little-endian — NEVER use memcpy here */
      '|
    }
    code_expand: {
      label: "Step 2: Expand W[16..63] — Recurrence"
      width: 420
      code: |'c
        for (int t = 16; t < 64; t++) {
          W[t] = SIGMA_LOWER_1(W[t- 2])  /* σ1(W[t-2])  */
               + W[t- 7]                 /* W[t-7]       */
               + SIGMA_LOWER_0(W[t-15])  /* σ0(W[t-15]) */
               + W[t-16];                /* W[t-16]      */
          /* uint32_t auto-wraps at 2^32: mod is FREE */
          /* Python/JS MUST add: & 0xFFFFFFFF          */
        }
      '|
    }
    modular_note: {
      shape: sql_table
      label: "Modular 2^32 Arithmetic"
      c_behavior: "uint32_t: overflow silently discarded — correct"
      python_bug: "int + int = 33-bit value — WRONG without mask"
      python_fix: "(a + b) & 0xFFFFFFFF — required in Python/JS"
      key: "Four-term add wraps once: (T1+T2+T3+T4) mod 2^32"
    }
  }
}
row_words: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_words: "W[0..15] — Parsed from 512-bit Block (sha256_schedule.c:parse)" {
    direction: right
    style.fill: "#0a2a0a"
    style.stroke: "#44bb44"
    style.border-radius: 6
    w0: {
      shape: sql_table
      label: "W[0] (bytes 0-3)"
      val: "0x61626380"
      note: "abc + 0x80 marker"
      style.fill: "#1a4a1a"
    }
    w1: {
      shape: sql_table
      label: "W[1] (bytes 4-7)"
      val: "0x00000000"
      note: "zero fill"
    }
    w2: {
      shape: sql_table
      label: "W[2..13]"
      val: "0x00000000"
      note: "zero fill (12 words)"
    }
    w14: {
      shape: sql_table
      label: "W[14] (bytes 56-59)"
      val: "0x00000000"
      note: "high 32 bits of length"
    }
    w15: {
      shape: sql_table
      label: "W[15] (bytes 60-63)"
      val: "0x00000018"
      note: "low 32 bits: 24 bits"
      style.fill: "#1a4a1a"
    }
  }
  abc_trace: "abc Parse Trace — W[0] = 0x61626380" {
    direction: down
    style.fill: "#1a1a3a"
    style.stroke: "#8888ff"
    style.border-radius: 6
    parse_steps: {
      shape: sql_table
      label: "Big-Endian Word Assembly"
      s0: "block[0]=0x61 << 24 = 0x61000000"
      s1: "block[1]=0x62 << 16 = 0x00620000"
      s2: "block[2]=0x63 <<  8 = 0x00006300"
      s3: "block[3]=0x80 <<  0 = 0x00000080"
      result: "OR together = 0x61626380 = W[0] ✓"
      verify: "NIST SHA-256 Example: W[0]=0x61626380 confirmed"
    }
    endian_warning: {
      shape: sql_table
      label: "Endianness Bug Source"
      bug: "memcpy(&W[0], block, 4) on x86 = 0x80636261 WRONG"
      fix: "Use explicit shift-OR pattern above (ALWAYS)"
      rule: "Never cast uint8_t* to uint32_t* for SHA-256 words"
    }
  }
}
row_expansion: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t16_node: "t=16: W[16] — First Expanded Word" {
    direction: down
    style.fill: "#2a1a00"
    style.stroke: "#ffaa00"
    style.border-radius: 6
    style.font-color: "#ffcc44"
    t16_formula: {
      shape: sql_table
      label: "W[16] = σ1(W[14]) + W[9] + σ0(W[1]) + W[0]"
      term_a: "σ1(W[14]) = σ1(0x00000000) = 0x00000000"
      term_b: "W[9]      = 0x00000000"
      term_c: "σ0(W[1])  = σ0(0x00000000) = 0x00000000"
      term_d: "W[0]      = 0x61626380"
      sum: "W[16] = 0 + 0 + 0 + 0x61626380 = 0x61626380"
      verify: "NIST intermediate: W[16]=0x61626380 ✓"
    }
    t16_deps: {
      shape: sql_table
      label: "Dependency Footprint"
      d1: "W[14] → t-2 term → σ1 applied"
      d2: "W[9]  → t-7 term → direct add"
      d3: "W[1]  → t-15 term → σ0 applied"
      d4: "W[0]  → t-16 term → direct add"
    }
  }
  t17_node: "t=17: W[17] — Second Expanded Word" {
    direction: down
    style.fill: "#2a1a00"
    style.stroke: "#ffaa00"
    style.border-radius: 6
    style.font-color: "#ffcc44"
    t17_formula: {
      shape: sql_table
      label: "W[17] = σ1(W[15]) + W[10] + σ0(W[2]) + W[1]"
      term_a: "σ1(W[15]) = σ1(0x00000018)"
      rotr17: "ROTR(0x18,17)=0x000C0000"
      rotr19: "ROTR(0x18,19)=0x00030000"
      shr10:  "SHR (0x18,10)=0x00000000"
      sigma1: "σ1(0x18)=0x000C0000^0x00030000^0=0x000F0000"
      term_b: "W[10]=0, W[2]=0, σ0(0)=0, W[1]=0"
      sum: "W[17] = 0x000F0000 + 0 + 0 + 0 = 0x000F0000"
      verify: "NIST intermediate: W[17]=0x000F0000 ✓"
    }
    t17_sigma_trace: {
      shape: sql_table
      label: "Manual σ1(0x00000018) Trace"
      x_bin: "0x18 = 0000...0001 1000 (5 bits set)"
      step1: "0x18 >> 17 = 0x0 (bits vanish)"
      step2: "0x18 << 15 = 0x000C0000 (bits wrap via ROTR)"
      step3: "ROTR(0x18,17)=0x000C0000"
      step4: "ROTR(0x18,19)=0x00030000"
      step5: "SHR(0x18,10) =0x00000000"
      xor: "0x000C0000 XOR 0x00030000 = 0x000F0000 ✓"
    }
  }
  t18_node: "t=18: W[18] — Shows σ0(W[3]) Calculation" {
    direction: down
    style.fill: "#2a1a00"
    style.stroke: "#ffaa00"
    style.border-radius: 6
    style.font-color: "#ffcc44"
    t18_formula: {
      shape: sql_table
      label: "W[18] = σ1(W[16]) + W[11] + σ0(W[3]) + W[2]"
      term_a: "σ1(W[16]) = σ1(0x61626380) — complex, compute"
      term_b: "W[11] = 0x00000000"
      term_c: "σ0(W[3]) = σ0(0x80000000)"
      sigma0_80: "ROTR(0x80000000,7) =0x01000000"
      sigma0_81: "ROTR(0x80000000,18)=0x00002000"
      sigma0_82: "SHR (0x80000000,3) =0x10000000"
      sigma0_r: "σ0(0x80000000)=0x01000000^0x00002000^0x10000000=0x11002000"
      term_d: "W[2] = 0x00000000"
      sum: "W[18] = σ1(W[16]) + 0x11002000 (verify vs NIST PDF)"
    }
  }
}
row_diffusion: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  diffusion_panel: "Avalanche Effect: Bit Propagation Through Schedule" {
    direction: down
    style.fill: "#1a001a"
    style.stroke: "#cc44cc"
    style.border-radius: 6
    propagation: {
      shape: sql_table
      label: "Single Bit Flip in W[0] — Cascade Trace"
      step1: "t=16: W[16] directly includes W[0] → W[16] changes"
      step2: "t=23: W[23] includes σ1(W[21]) which includes W[16]"
      step3: "t=32: W[32] has transitive deps on W[16..31]"
      step4: "t=63: Every word W[16..63] affected by W[0] flip"
      result: "1 bit change → all 48 expanded words change"
      security: "Ensures every round of compression sees the change"
    }
    dep_counts: {
      shape: sql_table
      label: "Transitive Dependency Counts (W[0] influence)"
      w16: "W[16]: 1 direct source (W[0])"
      w32: "W[32]: ~8 transitive sources from W[0..15]"
      w48: "W[48]: ~12 transitive sources from W[0..15]"
      w63: "W[63]: depends on majority of W[0..15] transitively"
      goal: "Max spread = max diffusion before compression"
    }
    why_shr: {
      shape: sql_table
      label: "Why SHR (not 3rd ROTR) in σ Functions"
      pure_rotr: "3x ROTR = bijection: σ(x) uniquely determines x"
      problem: "Invertible schedule → possible algebraic inversion"
      shr_fix: "SHR destroys 3 (or 10) bits → non-invertible"
      result: "Cannot reconstruct W[t-15] from σ0(W[t-15]) alone"
      security: "Non-invertibility hardens differential cryptanalysis"
    }
  }
  verification_panel: "Test Framework: Verify vs NIST (sha256_schedule_test.c)" {
    direction: down
    style.fill: "#001a1a"
    style.stroke: "#44cccc"
    style.border-radius: 6
    test_w0: {
      shape: sql_table
      label: "Test: W[0..15] Parse (abc block)"
      t1: "assert(W[0]  == 0x61626380)  // abc + 0x80"
      t2: "assert(W[1]  == 0x00000000)  // zero fill"
      t3: "assert(W[14] == 0x00000000)  // length high"
      t4: "assert(W[15] == 0x00000018)  // length: 24 bits"
      run: "sha256_message_schedule(abc_block, W)"
    }
    test_expanded: {
      shape: sql_table
      label: "Test: Expanded W[16..17] Known Answers"
      t1: "assert(W[16] == 0x61626380)  // NIST Appendix B.1"
      t2: "assert(W[17] == 0x000F0000)  // manually verified"
      t3: "// W[18..63]: compare full output vs NIST PDF table"
      debug: "sha256_print_schedule(W)  // print all 64 words"
    }
    const_check: {
      shape: sql_table
      label: "Constant Sanity Check"
      c1: "sigma_lower != sigma_upper for same input x"
      c2: "SIGMA_LOWER_0(x): rotate by 7,18 shift by 3"
      c3: "SIGMA_UPPER_0(x): rotate by 2,13,22 (NO shift)"
      c4: "If equal: you swapped uppercase/lowercase — fix now"
    }
  }
}
row_fullschedule: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  schedule_viz: "Full Schedule W[0..63]: Dependency Graph Summary" {
    direction: down
    style.fill: "#0a0a1a"
    style.stroke: "#6666ff"
    style.border-radius: 6
    block_parsed: "W[0..15]: Parsed from Block (Green = Input)" {
      style.fill: "#0a2a0a"
      style.stroke: "#44bb44"
      grp: "W[0..15] = big-endian 32-bit words from 64-byte block"
    }
    block_expanded: "W[16..63]: Recurrence Expansion (Yellow = Derived)" {
      style.fill: "#2a2a00"
      style.stroke: "#bbbb00"
      grp: "W[t] = σ1(W[t-2]) + W[t-7] + σ0(W[t-15]) + W[t-16]"
    }
    recurrence_table: {
      shape: sql_table
      label: "Recurrence Index Offsets — Why These Four?"
      idx1: "t-2:  σ1 applied — CLOSE neighbor, rotation mixing"
      idx2: "t-7:  direct add — MID-RANGE dependency"
      idx3: "t-15: σ0 applied — FAR neighbor, rotation+shift mix"
      idx4: "t-16: direct add — FARTHEST: full 16-word span"
      design: "Gaps chosen to maximize linear complexity over GF(2)"
      security: "No short cycles; every word depends on many inputs"
    }
    complexity: {
      shape: sql_table
      label: "Schedule Size and Performance"
      size: "uint32_t W[64] = 256 bytes on stack"
      ops: "48 iterations × (2 sigma calls + 3 additions)"
      alt: "Circular 16-word buffer: 64 bytes RAM, same FLOPS"
      choice: "Full 256-byte schedule: clarity + compiler optimization"
      note: "OpenSSL/BoringSSL/libsodium all use full schedule"
    }
  }
  debug_guide: "Debugging Guide: When W Values Diverge from NIST" {
    direction: down
    style.fill: "#1a0000"
    style.stroke: "#ff4444"
    style.border-radius: 6
    debug_table: {
      shape: sql_table
      label: "Error → Root Cause Mapping"
      e1: "W[0..15] wrong → endianness: use shift-OR not memcpy"
      e2: "W[16] wrong   → check recurrence indices (t-2,7,15,16)"
      e3: "W[17] wrong   → check σ1 constants: must be (17,19,10)"
      e4: "All W[16+] off → σ0/σ1 constants swapped (7,18 vs 2,13)"
      e5: "Python wrong  → missing & 0xFFFFFFFF after each addition"
    }
    overflow_demo: {
      shape: sql_table
      label: "Modular Add: C vs Python Behavior"
      c_ok:  "C uint32_t: 0xFFFFFFFF+1 = 0x00000000 (free wrap)"
      py_bug: "Python:      0xFFFFFFFF+1 = 0x100000000 (WRONG)"
      py_fix: "(0xFFFFFFFF+1) & 0xFFFFFFFF = 0x00000000 (correct)"
      rule: "Treat & 0xFFFFFFFF as the second half of + in Python"
    }
  }
}
title_box -> row_primitives: "defines primitives"
title_box -> row_words: "step 1: parse"
row_words -> row_expansion: "W[0..15] feed recurrence"
row_expansion -> row_diffusion: "W[16..63] analyzed"
row_diffusion -> row_fullschedule: "schedule complete"
row_primitives.sigma_panel.sigma0_def -> row_expansion.t16_node: "σ0(W[t-15])" {
  style.stroke: "#44bb44"
  style.stroke-dash: 4
}
row_primitives.sigma_panel.sigma1_def -> row_expansion.t16_node: "σ1(W[t-2])" {
  style.stroke: "#4a9eff"
  style.stroke-dash: 4
}
row_words.input_words.w0 -> row_expansion.t16_node: "W[t-16]" {
  style.stroke: "#ffaa00"
  style.bold: true
}
row_words.input_words.w1 -> row_expansion.t16_node: "σ0 input" {
  style.stroke: "#44bb44"
  style.stroke-dash: 3
}
row_words.input_words.w15 -> row_expansion.t17_node: "σ1 input W[15]" {
  style.stroke: "#4a9eff"
  style.stroke-dash: 3
}
row_expansion.t16_node -> row_expansion.t17_node: "W[16] feeds t=18 as W[t-2]" {
  style.stroke: "#ff8800"
  style.animated: true
}
row_expansion.t17_node -> row_expansion.t18_node: "W[17] feeds t=19 as W[t-2]" {
  style.stroke: "#ff8800"
  style.animated: true
}
row_expansion.t16_node -> row_diffusion.diffusion_panel: "avalanche starts here" {
  style.stroke: "#cc44cc"
  style.stroke-dash: 5
}