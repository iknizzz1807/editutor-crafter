direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## σ0 and σ1 Function Internals (FIPS 180-4 §4.1.2)
  Message Schedule Expansion — lowercase sigma only
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sigma0_panel: "σ0(x) = ROTR(x,7) ⊕ ROTR(x,18) ⊕ SHR(x,3)" {
    direction: down
    style.fill: "#EEF2FF"
    style.stroke: "#6366F1"
    style.stroke-width: 2
    input0: {
      shape: sql_table
      label: "Input x  (sha256_schedule.c)"
      b31_24: "bits[31..24] | 0xAB | original high byte"
      b23_16: "bits[23..16] | 0xCD | original mid-hi byte"
      b15_08: "bits[15..08] | 0xEF | original mid-lo byte"
      b07_00: "bits[07..00] | 0x01 | original low byte"
    }
    ops0: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      rotr7: {
        shape: sql_table
        label: "ROTR(x, 7)  — bits wrap right→left"
        style.fill: "#DBEAFE"
        style.stroke: "#3B82F6"
        lo7_wrap: "bits[31..25] | x[6..0]   | LOW 7 bits wrap to TOP"
        hi25_shift: "bits[24..00] | x[31..7]  | upper 25 bits shift down"
        note: "NO bits lost — rotation preserves all 32"
      }
      rotr18: {
        shape: sql_table
        label: "ROTR(x, 18) — bits wrap right→left"
        style.fill: "#D1FAE5"
        style.stroke: "#10B981"
        lo18_wrap: "bits[31..14] | x[17..0]  | LOW 18 bits wrap to TOP"
        hi14_shift: "bits[13..00] | x[31..18] | upper 14 bits shift down"
        note: "NO bits lost — rotation preserves all 32"
      }
      shr3: {
        shape: sql_table
        label: "SHR(x, 3)   — bits fall off right edge"
        style.fill: "#FEE2E2"
        style.stroke: "#EF4444"
        hi29_shift: "bits[31..03] | x[31..3]  | upper 29 bits shift down"
        lo3_zero: "bits[02..00] | 0b000     | LOW 3 bits DESTROYED (zeroed)"
        note: "3 bits LOST — deliberate irreversibility"
      }
    }
    xor0: {
      shape: sql_table
      label: "σ0(x) = ROTR7 ⊕ ROTR18 ⊕ SHR3  (mod — no carry, pure XOR)"
      style.fill: "#F3E8FF"
      style.stroke: "#8B5CF6"
      style.stroke-width: 2
      dep_hi: "bits[31..25] | f(x[6..0], x[17..0], x[31..25])  | 3-source mix"
      dep_mid: "bits[24..18] | f(x[31..7], x[17..0], x[31..18]) | 3-source mix"
      dep_lo3: "bits[02..00] | f(x[31..7], x[17..0], 0b000)     | SHR zeroed slot"
      impl: "C:  ROTR32(x,7) ^ ROTR32(x,18) ^ ((x) >> 3)"
      cost: "3 rotations / shifts + 2 XORs  — ~5 cycles"
    }
    input0 -> ops0.rotr7: "ROTR32(x,7)"
    input0 -> ops0.rotr18: "ROTR32(x,18)"
    input0 -> ops0.shr3: "x >> 3"
    ops0.rotr7 -> xor0: "a"
    ops0.rotr18 -> xor0: "b"
    ops0.shr3 -> xor0: "c"
  }
  sigma1_panel: "σ1(x) = ROTR(x,17) ⊕ ROTR(x,19) ⊕ SHR(x,10)" {
    direction: down
    style.fill: "#FFF7ED"
    style.stroke: "#F97316"
    style.stroke-width: 2
    input1: {
      shape: sql_table
      label: "Input x  (sha256_schedule.c)"
      b31_24: "bits[31..24] | 0xAB | original high byte"
      b23_16: "bits[23..16] | 0xCD | original mid-hi byte"
      b15_08: "bits[15..08] | 0xEF | original mid-lo byte"
      b07_00: "bits[07..00] | 0x01 | original low byte"
    }
    ops1: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      rotr17: {
        shape: sql_table
        label: "ROTR(x, 17) — bits wrap right→left"
        style.fill: "#DBEAFE"
        style.stroke: "#3B82F6"
        lo17_wrap: "bits[31..15] | x[16..0]  | LOW 17 bits wrap to TOP"
        hi15_shift: "bits[14..00] | x[31..17] | upper 15 bits shift down"
        note: "NO bits lost — rotation preserves all 32"
      }
      rotr19: {
        shape: sql_table
        label: "ROTR(x, 19) — bits wrap right→left"
        style.fill: "#D1FAE5"
        style.stroke: "#10B981"
        lo19_wrap: "bits[31..13] | x[18..0]  | LOW 19 bits wrap to TOP"
        hi13_shift: "bits[12..00] | x[31..19] | upper 13 bits shift down"
        note: "NO bits lost — rotation preserves all 32"
      }
      shr10: {
        shape: sql_table
        label: "SHR(x, 10)  — bits fall off right edge"
        style.fill: "#FEE2E2"
        style.stroke: "#EF4444"
        hi22_shift: "bits[31..10] | x[31..10] | upper 22 bits shift down"
        lo10_zero: "bits[09..00] | 0x000     | LOW 10 bits DESTROYED (zeroed)"
        note: "10 bits LOST — stronger truncation than σ0"
      }
    }
    xor1: {
      shape: sql_table
      label: "σ1(x) = ROTR17 ⊕ ROTR19 ⊕ SHR10  (mod — no carry, pure XOR)"
      style.fill: "#FEF3C7"
      style.stroke: "#F59E0B"
      style.stroke-width: 2
      dep_hi: "bits[31..19] | f(x[18..0], x[18..0], x[31..19]) | 3-source mix"
      dep_gap: "bits[18..17] | f(x[16..15], x[18..17], x[31..27])| tight gap"
      dep_lo10: "bits[09..00] | f(x[26..17], x[28..19], 0x000) | SHR zeroed slot"
      impl: "C:  ROTR32(x,17) ^ ROTR32(x,19) ^ ((x) >> 10)"
      cost: "3 rotations / shifts + 2 XORs  — ~5 cycles"
    }
    input1 -> ops1.rotr17: "ROTR32(x,17)"
    input1 -> ops1.rotr19: "ROTR32(x,19)"
    input1 -> ops1.shr10: "x >> 10"
    ops1.rotr17 -> xor1: "a"
    ops1.rotr19 -> xor1: "b"
    ops1.shr10 -> xor1: "c"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  asymmetry_note: "Why constants differ between σ0 and σ1" {
    direction: down
    style.fill: "#F8FAFC"
    style.stroke: "#94A3B8"
    cmp: {
      shape: sql_table
      label: "Constant Comparison (FIPS 180-4 §4.1.2)"
      fn_sigma0: "σ0 constants | (7, 18, 3)   | applied to W[t-15] in recurrence"
      fn_sigma1: "σ1 constants | (17, 19, 10) | applied to W[t-2]  in recurrence"
      gap_s0: "σ0 ROTR gap   | 18 - 7 = 11  | bits shifted between the two rotations"
      gap_s1: "σ1 ROTR gap   | 19 - 17 = 2  | NARROW gap — high positional overlap"
      shr_s0: "σ0 SHR loss   | 3 bits lost  | mild truncation"
      shr_s1: "σ1 SHR loss   | 10 bits lost | stronger truncation for W[t-2]"
      why: "Different constants ensure σ0(W[t-15]) and σ1(W[t-2]) have NO"
      why2: "overlapping bit-movement patterns → independent mixing channels"
    }
  }
  recurrence_note: "Schedule recurrence — how σ0 and σ1 combine (sha256_schedule.c)" {
    direction: down
    style.fill: "#F0FDF4"
    style.stroke: "#22C55E"
    rec: {
      shape: sql_table
      label: "W[t] recurrence  (t = 16..63)"
      term1: "σ1(W[t-2])  | ROTR17^ROTR19^SHR10 | recent word — fast diffusion"
      term2: "W[t-7]      | direct copy          | medium-distance dependency"
      term3: "σ0(W[t-15]) | ROTR7^ROTR18^SHR3   | older word — slow diffusion"
      term4: "W[t-16]     | direct copy          | far dependency (full period)"
      add_note: "All four terms added mod 2^32 (uint32_t wraps automatically in C)"
      c_impl: "W[t] = SIGMA_LOWER_1(W[t-2]) + W[t-7] + SIGMA_LOWER_0(W[t-15]) + W[t-16]"
    }
  }
  rotr_vs_shr_note: "ROTR vs SHR: critical distinction" {
    direction: down
    style.fill: "#FFF1F2"
    style.stroke: "#F43F5E"
    diff: {
      shape: sql_table
      label: "ROTR32(x,n) vs x>>n  —  NOT interchangeable"
      rotr_def: "ROTR(x,n) | (x>>n)|(x<<(32-n)) | 0 bits destroyed — bijection"
      shr_def:  "SHR(x,n)  | x >> n              | n bits destroyed — NOT invertible"
      rotr_ex:  "ROTR(0x80000000,1) | 0x40000000 | top bit moved to pos 30"
      shr_ex:   "SHR(0x80000000,1)  | 0x40000000 | same result here..."
      trap:     "SHR(0x00000001,1)  | 0x00000000 | bit[0] GONE — no recovery"
      rotr_trap:"ROTR(0x00000001,1) | 0x80000000 | bit[0] moved to top — safe"
      c_macro:  "ROTR32(x,n) = ((uint32_t)(x)>>(n))|((uint32_t)(x)<<(32-(n)))"
      ub_warn:  "WARNING: n must be 1..31 — n=0 or n=32 is undefined behavior"
    }
  }
}
row1 -> row2: "feeds into"
row2.asymmetry_note -> row2.recurrence_note: "explains"
row2.rotr_vs_shr_note -> row2.recurrence_note: "primitive for"