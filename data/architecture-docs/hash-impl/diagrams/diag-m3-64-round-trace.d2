direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "64-Round State Evolution — 'abc' Test Vector (NIST FIPS 180-4 Appendix B.1)"
  style: {
    font-size: 20
    bold: true
    fill: transparent
    stroke: transparent
  }
}
title.near: top-center
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  init_state: {
    label: "INITIAL STATE (sha256_compress entry)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.border-radius: 6
    shape: sql_table
    r_a: "a | 0x6a09e667 | H[0] — sqrt(2) frac × 2^32"
    r_b: "b | 0xbb67ae85 | H[1] — sqrt(3) frac × 2^32"
    r_c: "c | 0x3c6ef372 | H[2] — sqrt(5) frac × 2^32"
    r_d: "d | 0xa54ff53a | H[3] — sqrt(7) frac × 2^32"
    r_e: "e | 0x510e527f | H[4] — sqrt(11) frac × 2^32"
    r_f: "f | 0x9b05688c | H[5] — sqrt(13) frac × 2^32"
    r_g: "g | 0x1f83d9ab | H[6] — sqrt(17) frac × 2^32"
    r_h: "h | 0x5be0cd19 | H[7] — sqrt(19) frac × 2^32"
  }
  w_inputs: {
    label: "W[0..2] from 'abc' Block"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.border-radius: 6
    shape: sql_table
    w0: "W[0]  | 0x61626380 | 'a','b','c',0x80 big-endian"
    w1: "W[1]  | 0x00000000 | zero bytes 4..7"
    w2: "W[2]  | 0x00000000 | zero bytes 8..11"
    wd: "...   | 0x00000000 | W[3..14] all zero"
    w15: "W[15] | 0x00000018 | length field: 24 bits big-endian"
    note: "W[16..63] expanded via sigma recurrence"
  }
}
row0.init_state -> row0.w_inputs: "feeds"
round_formula: {
  label: "Per-Round Transformation (FIPS 180-4 §6.2.2 Step 3)"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.border-radius: 6
  width: 820
  formula_t1: {
    label: "T1 computation"
    code: |'c
      T1 = h + SIGMA_UPPER_1(e) + CH(e,f,g) + K[t] + W[t]
      /* SIGMA_UPPER_1(e) = ROTR(e,6) ^ ROTR(e,11) ^ ROTR(e,25) */
      /* CH(e,f,g)        = (e & f) ^ (~e & g)                   */
    '|
  }
  formula_t2: {
    label: "T2 computation"
    code: |'c
      T2 = SIGMA_UPPER_0(a) + MAJ(a,b,c)
      /* SIGMA_UPPER_0(a) = ROTR(a,2) ^ ROTR(a,13) ^ ROTR(a,22) */
      /* MAJ(a,b,c)       = (a&b) ^ (a&c) ^ (b&c)               */
    '|
  }
  formula_rot: {
    label: "Register rotation"
    code: |'c
      h=g; g=f; f=e; e=d+T1;
      d=c; c=b; b=a; a=T1+T2;
      /* All additions: mod 2^32 (uint32_t wraps automatically) */
    '|
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rnd0: {
    label: "Round t=0  (K[0]=0x428a2f98, W[0]=0x61626380)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.border-radius: 6
    shape: sql_table
    hdr: "var | value      | derivation"
    ra:  "a   | 0x5d6aebb1 | T1+T2; T1=h+Σ1(e)+Ch(e,f,g)+K[0]+W[0]"
    rb:  "b   | 0x6a09e667 | ← old a"
    rc:  "c   | 0xbb67ae85 | ← old b"
    rd:  "d   | 0x3c6ef372 | ← old c"
    re:  "e   | 0xf70e5939 | d + T1"
    rf:  "f   | 0x510e527f | ← old e"
    rg:  "g   | 0x9b05688c | ← old f"
    rh:  "h   | 0x1f83d9ab | ← old g"
    chk: "NIST | B.1 round 0 — verify a=0x5d6aebb1 e=0xf70e5939"
  }
  rnd1: {
    label: "Round t=1  (K[1]=0x71374491, W[1]=0x00000000)"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.border-radius: 6
    shape: sql_table
    hdr: "var | value      | derivation"
    ra:  "a   | 0x568f3f2f | T1+T2"
    rb:  "b   | 0x5d6aebb1 | ← old a"
    rc:  "c   | 0x6a09e667 | ← old b"
    rd:  "d   | 0xbb67ae85 | ← old c"
    re:  "e   | 0xd04e5fc0 | d + T1; d=0x3c6ef372"
    rf:  "f   | 0xf70e5939 | ← old e"
    rg:  "g   | 0x510e527f | ← old f"
    rh:  "h   | 0x9b05688c | ← old g"
    chk: "NIST | B.1 round 1 — verify a=0x568f3f2f e=0xd04e5fc0"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rnd2: {
    label: "Round t=2  (K[2]=0xb5c0fbcf, W[2]=0x00000000)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.border-radius: 6
    shape: sql_table
    hdr: "var | value      | derivation"
    ra:  "a   | 0x34ffc9c1 | T1+T2"
    rb:  "b   | 0x568f3f2f | ← old a"
    rc:  "c   | 0x5d6aebb1 | ← old b"
    rd:  "d   | 0x6a09e667 | ← old c"
    re:  "e   | 0xdc1eab4c | d + T1; d=0xbb67ae85"
    rf:  "f   | 0xd04e5fc0 | ← old e"
    rg:  "g   | 0xf70e5939 | ← old f"
    rh:  "h   | 0x510e527f | ← old g"
    chk: "NIST | B.1 round 2 — verify a=0x34ffc9c1 e=0xdc1eab4c"
  }
  gap_note: {
    label: "Rounds t=3 through t=62"
    style.fill: "#ECEFF1"
    style.stroke: "#90A4AE"
    style.stroke-dash: 5
    style.border-radius: 6
    shape: sql_table
    n1: "Each round: same formula T1+T2, register rotation"
    n2: "K[t] from cube-root-of-prime table (all 64 values fixed)"
    n3: "W[t] from message schedule expansion (sigma recurrence)"
    n4: "Validate all rounds vs NIST PDF: sha256_debug_rounds()"
    n5: "Any divergence → check sigma constants, CH/MAJ formula, K table"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  rnd63: {
    label: "Round t=63  (K[63]=0xc67178f2, W[63]=expanded)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.border-radius: 6
    shape: sql_table
    hdr: "var | value (post-round 63)  | note"
    ra:  "a   | (compute & compare)    | final working var a"
    rb:  "b   | (compute & compare)    | final working var b"
    rc:  "c   | (compute & compare)    | final working var c"
    rd:  "d   | (compute & compare)    | final working var d"
    re:  "e   | (compute & compare)    | final working var e"
    rf:  "f   | (compute & compare)    | final working var f"
    rg:  "g   | (compute & compare)    | final working var g"
    rh:  "h   | (compute & compare)    | final working var h"
    chk: "NIST | B.1 post-round 63 table — must match exactly"
  }
  state_update: {
    label: "State Update: H[i] += working_var[i]  (FIPS §6.2.2 Step 4)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.border-radius: 6
    shape: sql_table
    u0: "H[0] += a  →  0xba7816bf"
    u1: "H[1] += b  →  0x8f01cfea"
    u2: "H[2] += c  →  0x414140de"
    u3: "H[3] += d  →  0x5dae2223"
    u4: "H[4] += e  →  0xb00361a3"
    u5: "H[5] += f  →  0x96177a9c"
    u6: "H[6] += g  →  0xb410ff61"
    u7: "H[7] += h  →  0xf20015ad"
    note: "+=  is mod 2^32  —  uint32_t wraps automatically in C"
  }
}
final_digest: {
  label: "Final Digest: SHA-256('abc') — NIST FIPS 180-4 Appendix B.1"
  style.fill: "#1B5E20"
  style.font-color: "#FFFFFF"
  style.stroke: "#1B5E20"
  style.border-radius: 8
  shape: sql_table
  d0: "bytes 00..07 | ba7816bf 8f01cfea | H[0] H[1] big-endian"
  d1: "bytes 08..15 | 414140de 5dae2223 | H[2] H[3] big-endian"
  d2: "bytes 16..23 | b00361a3 96177a9c | H[4] H[5] big-endian"
  d3: "bytes 24..31 | b410ff61 f20015ad | H[6] H[7] big-endian"
  hex: "hex string  | ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
}
bugcheck: {
  label: "Bug Diagnosis: If your values diverge from NIST B.1"
  style.fill: "#FBE9E7"
  style.stroke: "#BF360C"
  style.border-radius: 6
  shape: sql_table
  b1: "wrong a at t=0  | check SIGMA_UPPER_0 constants (2,13,22) vs sigma_lower (7,18,3)"
  b2: "wrong e at t=0  | check SIGMA_UPPER_1 constants (6,11,25) and CH formula"
  b3: "diverges t>0    | check variable rotation order: read all old values before assign"
  b4: "wrong T1        | verify K[t] table — K[0]=0x428a2f98 (cbrt(2) frac x 2^32)"
  b5: "wrong T2        | verify MAJ formula: (a&b)^(a&c)^(b&c) not (a&b)|(a&c)|(b&c)"
  b6: "H update wrong  | must use += not = ; any = discards Merkle-Damgard feed-forward"
  b7: "masking missing | Python/JS: apply & 0xFFFFFFFF after every + ; C uint32 wraps OK"
}
row0 -> round_formula: "W[0..63] schedule"
round_formula -> row1: "apply to a..h"
row1 -> row2: "t=1 state feeds t=2"
row2 -> row3: "rounds 3..62 iterate"
row3.rnd63 -> row3.state_update: "a..h after round 63"
row3.state_update -> final_digest: "H[i] += working_var"
final_digest -> bugcheck: "if mismatch →"
bugcheck.near: bottom-center