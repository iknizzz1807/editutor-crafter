direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "SHA-256: The Four Sigma Functions — Uppercase Σ vs Lowercase σ"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    font-color: "#ffffff"
    font-size: 18
    bold: true
    border-radius: 6
    stroke: "#1a1a2e"
  }
}
fatal_warning: {
  label: "FATAL BUG: Mixing Σ (uppercase) constants into σ (lowercase) or vice versa\nproduces plausible-looking 32-bit values with NO error — caught ONLY by NIST vectors"
  shape: rectangle
  style: {
    fill: "#7f0000"
    font-color: "#ffffff"
    font-size: 13
    bold: true
    border-radius: 4
    stroke: "#ff0000"
    stroke-width: 3
  }
}
row_top: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  compression_group: "COMPRESSION FUNCTION  —  uppercase Σ" {
    direction: down
    style: {
      fill: "#0d2137"
      stroke: "#1e90ff"
      stroke-width: 3
      border-radius: 8
      font-color: "#1e90ff"
      font-size: 14
      bold: true
    }
    applied_to_comp: {
      label: "Applied to working variables  a  and  e  inside sha256_compress()"
      style: {
        fill: "#0a192f"
        font-color: "#7ec8e3"
        font-size: 12
        border-radius: 4
        stroke: "#1e5f8a"
      }
    }
    sigma_upper_0: {
      shape: sql_table
      label: "Σ0(a)  —  FIPS 180-4 Eq. 4.4  (sha256_compress.c)"
      r0: "Operation    |  Constant  |  Type  |  Bits preserved?"
      r1: "ROTR(a,  2)  |     2      |  ROTR  |  ALL 32 bits wrap"
      r2: "ROTR(a, 13)  |    13      |  ROTR  |  ALL 32 bits wrap"
      r3: "ROTR(a, 22)  |    22      |  ROTR  |  ALL 32 bits wrap"
      r4: "XOR all 3    |    —       |  XOR   |  Full-entropy output"
      r5: "No SHR used  |    —       |  —     |  ROTATION-ONLY function"
      style: {
        fill: "#1e3a5f"
        stroke: "#1e90ff"
        font-color: "#ffffff"
      }
    }
    sigma_upper_1: {
      shape: sql_table
      label: "Σ1(e)  —  FIPS 180-4 Eq. 4.5  (sha256_compress.c)"
      r0: "Operation    |  Constant  |  Type  |  Bits preserved?"
      r1: "ROTR(e,  6)  |     6      |  ROTR  |  ALL 32 bits wrap"
      r2: "ROTR(e, 11)  |    11      |  ROTR  |  ALL 32 bits wrap"
      r3: "ROTR(e, 25)  |    25      |  ROTR  |  ALL 32 bits wrap"
      r4: "XOR all 3    |    —       |  XOR   |  Full-entropy output"
      r5: "No SHR used  |    —       |  —     |  ROTATION-ONLY function"
      style: {
        fill: "#1e3a5f"
        stroke: "#1e90ff"
        font-color: "#ffffff"
      }
    }
    macro_comp: {
      label: "C Macros — sha256_compress.c"
      width: 500
      code: |'c
        #define SIGMA_UPPER_0(x) \
          (ROTR32((x), 2) ^ ROTR32((x),13) ^ ROTR32((x),22))
        #define SIGMA_UPPER_1(x) \
          (ROTR32((x), 6) ^ ROTR32((x),11) ^ ROTR32((x),25))
        /* used in T2 = SIGMA_UPPER_0(a) + MAJ(a,b,c)        */
        /* used in T1 = h + SIGMA_UPPER_1(e) + CH(e,f,g) + K[t] + W[t] */
      '|
      style: {
        fill: "#0a192f"
        stroke: "#1e90ff"
        font-color: "#7ec8e3"
        border-radius: 4
      }
    }
  }
  schedule_group: "MESSAGE SCHEDULE  —  lowercase σ" {
    direction: down
    style: {
      fill: "#1a2e0d"
      stroke: "#32cd32"
      stroke-width: 3
      border-radius: 8
      font-color: "#32cd32"
      font-size: 14
      bold: true
    }
    applied_to_sched: {
      label: "Applied to schedule words  W[t-15]  and  W[t-2]  inside sha256_message_schedule()"
      style: {
        fill: "#0f1f0a"
        font-color: "#90ee90"
        font-size: 12
        border-radius: 4
        stroke: "#2a6b1a"
      }
    }
    sigma_lower_0: {
      shape: sql_table
      label: "σ0(x)  —  FIPS 180-4 Eq. 4.6  (sha256_schedule.c)"
      r0: "Operation    |  Constant  |  Type  |  Bits preserved?"
      r1: "ROTR(x,  7)  |     7      |  ROTR  |  ALL 32 bits wrap"
      r2: "ROTR(x, 18)  |    18      |  ROTR  |  ALL 32 bits wrap"
      r3: "SHR (x,  3)  |     3      |  SHR   |  3 LSBs DESTROYED"
      r4: "XOR all 3    |    —       |  XOR   |  Partial-entropy output"
      r5: "SHR makes it |    —       |  —     |  NON-INVERTIBLE (by design)"
      style: {
        fill: "#1a3d0f"
        stroke: "#32cd32"
        font-color: "#ffffff"
      }
    }
    sigma_lower_1: {
      shape: sql_table
      label: "σ1(x)  —  FIPS 180-4 Eq. 4.7  (sha256_schedule.c)"
      r0: "Operation    |  Constant  |  Type  |  Bits preserved?"
      r1: "ROTR(x, 17)  |    17      |  ROTR  |  ALL 32 bits wrap"
      r2: "ROTR(x, 19)  |    19      |  ROTR  |  ALL 32 bits wrap"
      r3: "SHR (x, 10)  |    10      |  SHR   |  10 LSBs DESTROYED"
      r4: "XOR all 3    |    —       |  XOR   |  Partial-entropy output"
      r5: "SHR makes it |    —       |  —     |  NON-INVERTIBLE (by design)"
      style: {
        fill: "#1a3d0f"
        stroke: "#32cd32"
        font-color: "#ffffff"
      }
    }
    macro_sched: {
      label: "C Macros — sha256_schedule.c"
      width: 500
      code: |'c
        #define SIGMA_LOWER_0(x) \
          (ROTR32((x), 7) ^ ROTR32((x),18) ^ SHR32((x), 3))
        #define SIGMA_LOWER_1(x) \
          (ROTR32((x),17) ^ ROTR32((x),19) ^ SHR32((x),10))
        /* W[t] = SIGMA_LOWER_1(W[t-2]) + W[t-7]             */
        /*      + SIGMA_LOWER_0(W[t-15]) + W[t-16]  mod 2^32 */
      '|
      style: {
        fill: "#0f1f0a"
        stroke: "#32cd32"
        font-color: "#90ee90"
        border-radius: 4
      }
    }
  }
}
row_diff: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  key_diff: "KEY STRUCTURAL DIFFERENCE" {
    direction: down
    style: {
      fill: "#2a1a00"
      stroke: "#ffa500"
      stroke-width: 2
      border-radius: 6
      font-color: "#ffa500"
      font-size: 13
      bold: true
    }
    diff_table: {
      shape: sql_table
      label: "Uppercase Σ vs Lowercase σ — Structural Comparison"
      h: "Property          |  Uppercase Σ (Compression)  |  Lowercase σ (Schedule)"
      d1: "Operations used  |  ROTR only (3 rotations)    |  ROTR x2 + SHR x1"
      d2: "Bits destroyed   |  NONE — full 32-bit entropy |  3 or 10 bits via SHR"
      d3: "Invertible?      |  YES (pure rotation bijection)|  NO (SHR is lossy)"
      d4: "Applied to       |  Working vars a, e (rich)   |  Schedule words (sparse)"
      d5: "Naming in FIPS   |  Σ0, Σ1 (capital sigma)     |  σ0, σ1 (small sigma)"
      d6: "C macro naming   |  SIGMA_UPPER_0/1            |  SIGMA_LOWER_0/1"
      d7: "File location    |  sha256_compress.c          |  sha256_schedule.c"
      style: {
        fill: "#1a0f00"
        stroke: "#ffa500"
        font-color: "#ffffff"
      }
    }
  }
  why_shr: "WHY σ HAS SHR (THE INSIGHT)" {
    direction: down
    style: {
      fill: "#2a002a"
      stroke: "#da70d6"
      stroke-width: 2
      border-radius: 6
      font-color: "#da70d6"
      font-size: 13
      bold: true
    }
    shr_reason: {
      shape: sql_table
      label: "Design Rationale for SHR in σ functions"
      r1: "Working vars a-h carry FULL 256-bit entropy from previous rounds"
      r2: "→ pure ROTR Σ is safe: no bits need destroying for security"
      r3: "Schedule words W[0..15] start from sparse message (often zeros)"
      r4: "→ SHR in σ makes expansion NON-INVERTIBLE"
      r5: "→ Cannot recover original W[t] from σ(W[t]) — one-way mixing"
      r6: "→ Prevents attacker from solving schedule backwards to find collision"
      r7: "SHR is deliberate irreversibility, not an accident of bit arithmetic"
      style: {
        fill: "#1a001a"
        stroke: "#da70d6"
        font-color: "#e0b0e0"
      }
    }
  }
}
row_constants: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  const_map: "CONSTANT SET QUICK-REFERENCE (memorize these pairs)" {
    direction: down
    style: {
      fill: "#1a1a00"
      stroke: "#ffd700"
      stroke-width: 2
      border-radius: 6
      font-color: "#ffd700"
      font-size: 13
      bold: true
    }
    const_table: {
      shape: sql_table
      label: "All Four Sigma Functions — Constants at a Glance"
      h: "Function  |  Where Used       |  Constant Set  |  Op Types"
      r1: "Σ0(a)    |  T2 in compress   |  2,  13,  22   |  ROTR ROTR ROTR"
      r2: "Σ1(e)    |  T1 in compress   |  6,  11,  25   |  ROTR ROTR ROTR"
      r3: "σ0(x)    |  W[t-15] expand   |  7,  18,   3   |  ROTR ROTR SHR"
      r4: "σ1(x)    |  W[t-2]  expand   |  17, 19,  10   |  ROTR ROTR SHR"
      r5: "MEMORY   |  Σ = even spacing |  2-13-22 gaps  |  11 then 9"
      r6: "AID:     |  σ = odd spacing  |  7-18 then 3   |  11 then -15"
      style: {
        fill: "#0f0f00"
        stroke: "#ffd700"
        font-color: "#ffffff"
      }
    }
  }
  bug_guide: "DEBUGGING: HOW TO CATCH THE SWAP BUG" {
    direction: down
    style: {
      fill: "#1f0a0a"
      stroke: "#ff4444"
      stroke-width: 2
      border-radius: 6
      font-color: "#ff4444"
      font-size: 13
      bold: true
    }
    bug_table: {
      shape: sql_table
      label: "Symptom → Root Cause → Fix"
      h: "Symptom                      |  Root Cause               |  Fix"
      r1: "W[16..63] wrong, W[0..15] OK|  σ constants swapped      |  Check (7,18,3) and (17,19,10)"
      r2: "T1 wrong at round 0          |  Σ1 constants wrong       |  Must be (6,11,25) not (17,19,10)"
      r3: "T2 wrong at round 0          |  Σ0 constants wrong       |  Must be (2,13,22) not (7,18,3)"
      r4: "All rounds wrong after R0    |  Σ0 vs Σ1 swapped         |  Σ0→a in T2, Σ1→e in T1"
      r5: "Schedule ok, compress wrong  |  Used SIGMA_LOWER in T1/T2|  Replace with SIGMA_UPPER macros"
      r6: "Values plausible but wrong   |  ANY sigma swap            |  Compare ALL 64 W[t] to NIST PDF"
      style: {
        fill: "#1f0a0a"
        stroke: "#ff4444"
        font-color: "#ffcccc"
      }
    }
  }
}
title -> fatal_warning
fatal_warning -> row_top
row_top -> row_diff
row_diff -> row_constants
row_top.compression_group.sigma_upper_0 -> row_top.compression_group.sigma_upper_1: "both Σ | ROTR-only"
row_top.schedule_group.sigma_lower_0 -> row_top.schedule_group.sigma_lower_1: "both σ | ROTR+SHR"
row_top.compression_group -> row_top.schedule_group: "Σ ≠ σ — different constants, different ops" {
  style: {
    stroke: "#ff4444"
    stroke-width: 3
    stroke-dash: 5
    font-color: "#ff4444"
    bold: true
  }
}