direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title_box: "Ch and Maj: Boolean Truth Tables (sha256.h)" {
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  style.font-color: "#e0e0ff"
  style.bold: true
  style.font-size: 18
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ch_table: "Ch(x,y,z) — Choice / Multiplexer" {
    shape: sql_table
    style.fill: "#0d2137"
    style.stroke: "#2196F3"
    style.font-color: "#90CAF9"
    hdr: "x | y | z || Ch | if x then y else z"
    r0:  "0 | 0 | 0 || 0  | x=0 → choose z=0"
    r1:  "0 | 0 | 1 || 1  | x=0 → choose z=1"
    r2:  "0 | 1 | 0 || 0  | x=0 → choose z=0"
    r3:  "0 | 1 | 1 || 1  | x=0 → choose z=1"
    r4:  "1 | 0 | 0 || 0  | x=1 → choose y=0"
    r5:  "1 | 0 | 1 || 0  | x=1 → choose y=0"
    r6:  "1 | 1 | 0 || 1  | x=1 → choose y=1"
    r7:  "1 | 1 | 1 || 1  | x=1 → choose y=1"
    formula: "Ch = (x AND y) XOR (NOT x AND z)"
    note1: "AND present → nonlinear over GF(2)"
  }
  maj_table: "Maj(x,y,z) — Majority Vote" {
    shape: sql_table
    style.fill: "#1a0d37"
    style.stroke: "#9C27B0"
    style.font-color: "#CE93D8"
    hdr: "x | y | z || Maj | majority of three bits"
    r0:  "0 | 0 | 0 || 0   | 3× zero  → 0 wins"
    r1:  "0 | 0 | 1 || 0   | 2× zero  → 0 wins"
    r2:  "0 | 1 | 0 || 0   | 2× zero  → 0 wins"
    r3:  "0 | 1 | 1 || 1   | 2× one   → 1 wins"
    r4:  "1 | 0 | 0 || 0   | 2× zero  → 0 wins"
    r5:  "1 | 0 | 1 || 1   | 2× one   → 1 wins"
    r6:  "1 | 1 | 0 || 1   | 2× one   → 1 wins"
    r7:  "1 | 1 | 1 || 1   | 3× one   → 1 wins"
    formula: "Maj = (x AND y) XOR (x AND z) XOR (y AND z)"
    note1: "AND cross-terms → nonlinear over GF(2)"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  linearity_analysis: "Linearity Analysis (sha256.h)" {
    shape: sql_table
    style.fill: "#0d1f0d"
    style.stroke: "#4CAF50"
    style.font-color: "#A5D6A7"
    hdr: "Function | Formula       | Linear? | Balanced? | Crypto Use"
    xor_row: "XOR(a,b) | a ⊕ b         | YES     | YES       | Diffusion only — WEAK"
    and_row: "AND(a,b) | a · b (GF2)   | NO      | NO        | Not balanced — cannot use alone"
    ch_row:  "Ch(x,y,z)| (x∧y)⊕(¬x∧z) | NO      | YES       | SHA-256 compression — CORRECT"
    maj_row: "Maj(x,y,z)|(x∧y)⊕(x∧z)⊕(y∧z)| NO | YES   | SHA-256 compression — CORRECT"
    proof:   "Proof: Ch(1,0,0) XOR Ch(0,1,0) ≠ Ch(1 XOR 0, 0 XOR 1, 0 XOR 0)"
    consequence: "→ Linear cryptanalysis fails: no linear approx with bias ≫ 0"
  }
  nonlinearity_note: "Why AND Creates Nonlinearity (sha256.h)" {
    shape: sql_table
    style.fill: "#1f0d0d"
    style.stroke: "#F44336"
    style.font-color: "#EF9A9A"
    hdr: "Concept | Detail"
    gf2:  "GF(2) addition    | a ⊕ b  (XOR) — linear map: f(a⊕b) = f(a)⊕f(b)"
    mult: "GF(2) multiply    | a · b  (AND) — NOT linear: creates cross-term ab"
    xor_only: "XOR-only system   | Expressible as matrix · input over GF(2)"
    broken:   "XOR-only attack   | Gaussian elimination solves in O(n^3) — trivial"
    ch_and:   "Ch contains AND   | Cross-term x·y appears → cannot linearize"
    maj_and:  "Maj contains AND  | Cross-terms x·y, x·z, y·z → three-way coupling"
    defense:  "Defense achieved  | No linear approx with bias > 2^-16 for 64 rounds"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ch_verify: "Ch Nonlinearity Proof (sha256.h)" {
    shape: sql_table
    style.fill: "#0d1a2e"
    style.stroke: "#2196F3"
    style.font-color: "#90CAF9"
    hdr: "Check | Inputs | Ch Output | Linear would give"
    c1: "Base A  | x=1,y=0,z=0 | 0         | —"
    c2: "Base B  | x=0,y=1,z=0 | 0         | —"
    c3: "XOR in  | x=1,y=1,z=0 | 1         | 0 XOR 0 = 0  ← MISMATCH"
    c4: "Verdict | Ch(A XOR B) ≠ Ch(A) XOR Ch(B) | NONLINEAR confirmed"
    c5: "Formal  | Ch not in span of {x,y,z,1} over GF(2)"
  }
  maj_verify: "Maj Nonlinearity Proof (sha256.h)" {
    shape: sql_table
    style.fill: "#1a0d2e"
    style.stroke: "#9C27B0"
    style.font-color: "#CE93D8"
    hdr: "Check | Inputs | Maj Output | Linear would give"
    m1: "Base A  | x=1,y=0,z=0 | 0          | —"
    m2: "Base B  | x=0,y=1,z=0 | 0          | —"
    m3: "XOR in  | x=1,y=1,z=0 | 1          | 0 XOR 0 = 0  ← MISMATCH"
    m4: "Verdict | Maj(A XOR B) ≠ Maj(A) XOR Maj(B) | NONLINEAR confirmed"
    m5: "Formal  | Maj degree 2 over GF(2) → three AND cross-terms"
  }
}
ch_table -> linearity_analysis: "Ch is nonlinear + balanced"
maj_table -> linearity_analysis: "Maj is nonlinear + balanced"
linearity_analysis -> ch_verify: "verify Ch"
linearity_analysis -> maj_verify: "verify Maj"
ch_verify -> nonlinearity_note: "AND = GF(2) mult"
maj_verify -> nonlinearity_note: "AND = GF(2) mult"