direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## K Constants: Cube Roots of Primes ("Nothing Up My Sleeve")
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  primes: {
    label: "Prime Inputs (FIPS 180-4 §4.2.2)"
    style.fill: "#e8f4f8"
    style.stroke: "#2c7bb6"
    style.border-radius: 8
    p1: {
      shape: sql_table
      label: "First 64 Primes"
      r1: "K[0]  | prime = 2"
      r2: "K[1]  | prime = 3"
      r3: "K[2]  | prime = 5"
      r4: "K[3]  | prime = 7"
      r5: "...   | ..."
      r6: "K[63] | prime = 311"
    }
  }
  derivation_k0: {
    label: "K[0] Derivation: cbrt(2)"
    style.fill: "#eef7ee"
    style.stroke: "#2ca02c"
    style.border-radius: 8
    step1: {
      label: "Step 1: Compute Cube Root"
      width: 340
      code: |'c
        cbrt(2) = 2^(1/3)
               = 1.2599210498948732...
               ^^^ integer part = 1
      '|
    }
    step2: {
      label: "Step 2: Extract Fractional Part"
      width: 340
      code: |'c
        frac(cbrt(2))
          = 1.2599210... - 1
          = 0.2599210498948732...
      '|
    }
    step3: {
      label: "Step 3: Multiply by 2^32"
      width: 340
      code: |'c
        0.2599210498948732
          x 4,294,967,296  (2^32)
          = 1,116,352,408.xxx
          floor() = 1,116,352,408
      '|
    }
    step4: {
      label: "Step 4: Convert to Hex"
      width: 340
      code: |'c
        1,116,352,408
          = 0x428A2F98
          = K[0]  ✓ (matches FIPS 180-4)
      '|
      style.fill: "#d4edda"
    }
    step1 -> step2: "drop integer"
    step2 -> step3: "scale to 32-bit"
    step3 -> step4: "floor + hex"
  }
  derivation_k1: {
    label: "K[1] Derivation: cbrt(3)"
    style.fill: "#eef7ee"
    style.stroke: "#2ca02c"
    style.border-radius: 8
    s1: {
      label: "Step 1: Compute Cube Root"
      width: 320
      code: |'c
        cbrt(3) = 3^(1/3)
               = 1.4422495703074083...
      '|
    }
    s2: {
      label: "Step 2: Fractional Part"
      width: 320
      code: |'c
        frac(cbrt(3))
          = 0.4422495703074083...
      '|
    }
    s3: {
      label: "Step 3: x 2^32 then floor"
      width: 320
      code: |'c
        0.4422495... x 4,294,967,296
          = 1,899,447,441
          = 0x71374491
          = K[1]  ✓
      '|
      style.fill: "#d4edda"
    }
    s1 -> s2: "drop integer"
    s2 -> s3: "scale + floor + hex"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  k_table: {
    label: "K[0..7] — First Eight Round Constants (sha256.c)"
    style.fill: "#f5f0ff"
    style.stroke: "#7b52ab"
    style.border-radius: 8
    kt: {
      shape: sql_table
      label: "const uint32_t K[64] (first 8 shown)"
      r0: "K[0]  | cbrt(2)   | 0x428a2f98"
      r1: "K[1]  | cbrt(3)   | 0x71374491"
      r2: "K[2]  | cbrt(5)   | 0xb5c0fbcf"
      r3: "K[3]  | cbrt(7)   | 0xe9b5dba5"
      r4: "K[4]  | cbrt(11)  | 0x3956c25b"
      r5: "K[5]  | cbrt(13)  | 0x59f111f1"
      r6: "K[6]  | cbrt(17)  | 0x923f82a4"
      r7: "K[7]  | cbrt(19)  | 0xab1c5ed5"
      rn: "...   | ...       | ..."
    }
  }
  nothing_up: {
    label: "Nothing Up My Sleeve"
    style.fill: "#e8f8e8"
    style.stroke: "#28a745"
    style.border-radius: 8
    verify: {
      label: "Public Reproducibility (verifiable by anyone)"
      width: 360
      code: |'py
        import math
        primes = [2,3,5,7,11,13,17,19,...]
        K = [int((p**(1/3) % 1) * 2**32)
             for p in primes[:64]]
        assert K[0] == 0x428a2f98  # True
        assert K[1] == 0x71374491  # True
      '|
    }
    guarantee: {
      label: "Security Guarantee"
      style.fill: "#d4edda"
      style.stroke: "#155724"
      style.border-radius: 6
      g1: "No degrees of freedom: each K is pinned"
      g2: "to the Nth digit of cbrt(prime N)"
      g3: "Designer cannot aim for a backdoor-"
      g4: "friendly value — the derivation is rigid"
      g5: "Anyone can recompute all 64 constants"
      g6: "and verify they match FIPS 180-4"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sha256_good: {
    label: "SHA-256: TRANSPARENT"
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.stroke-width: 3
    style.border-radius: 8
    g: {
      shape: sql_table
      label: "SHA-256 K Constants"
      r1: "Source    | cube roots of primes"
      r2: "Verify?   | YES — pocket calculator"
      r3: "Backdoor? | Impossible: no free params"
      r4: "Audit     | Full public derivation"
      r5: "Status    | Trusted worldwide"
    }
  }
  contrast: {
    label: "CONTRAST"
    style.fill: "#fff3cd"
    style.stroke: "#856404"
    style.border-radius: 8
    width: 180
    c1: "SHA-256"
    c2: "public derivation"
    c3: "↕"
    c4: "Dual_EC_DRBG"
    c5: "opaque constants"
  }
  dual_ec_bad: {
    label: "Dual_EC_DRBG: BACKDOORED"
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.stroke-width: 3
    style.border-radius: 8
    b: {
      shape: sql_table
      label: "Dual_EC_DRBG Constants P, Q"
      r1: "Source    | NSA — NEVER explained"
      r2: "Verify?   | NO — no derivation given"
      r3: "Backdoor? | YES — Snowden 2013"
      r4: "Exploit   | discrete-log(Q = e*P)"
      r5: "Status    | Withdrawn by NIST 2014"
    }
  }
}
row1.primes -> row1.derivation_k0: "prime=2 | input"
row1.primes -> row1.derivation_k1: "prime=3 | input"
row1.derivation_k0 -> row2.k_table: "K[0]=0x428a2f98 | store"
row1.derivation_k1 -> row2.k_table: "K[1]=0x71374491 | store"
row2.k_table -> row2.nothing_up: "all 64 constants | audit"
row2.nothing_up -> row3.sha256_good: "transparent | safe"
row2.nothing_up -> row3.dual_ec_bad: "opaque | BACKDOORED" {
  style.stroke: "#dc3545"
  style.stroke-dash: 4
}
row3.sha256_good -> row3.contrast: "trusted"
row3.dual_ec_bad -> row3.contrast: "withdrawn" {
  style.stroke: "#dc3545"
}