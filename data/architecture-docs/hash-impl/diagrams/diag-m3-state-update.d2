direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Hash State Update After Block Compression (FIPS 180-4 §6.2.2 Step 4)
  `H[i]_new = H[i]_old + working_var[i]  mod 2³²`
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: "BEFORE: H[0..7] (input to block N)" {
    direction: down
    style.fill: "#E8F4FD"
    style.stroke: "#2980B9"
    style.border-radius: 6
    h_label: "Initial Values (Block 0) or\nPrevious Block Output (Block N>0)" {
      style.fill: "#D6EAF8"
      style.stroke: "#2980B9"
      style.font-size: 12
      style.italic: true
    }
    h_vals: {
      shape: sql_table
      label: "H[0..7] — 256-bit running state"
      H0: "H[0] | uint32_t | 0x6a09e667  (Block 0) or prev"
      H1: "H[1] | uint32_t | 0xbb67ae85  (Block 0) or prev"
      H2: "H[2] | uint32_t | 0x3c6ef372  (Block 0) or prev"
      H3: "H[3] | uint32_t | 0xa54ff53a  (Block 0) or prev"
      H4: "H[4] | uint32_t | 0x510e527f  (Block 0) or prev"
      H5: "H[5] | uint32_t | 0x9b05688c  (Block 0) or prev"
      H6: "H[6] | uint32_t | 0x1f83d9ab  (Block 0) or prev"
      H7: "H[7] | uint32_t | 0x5be0cd19  (Block 0) or prev"
      note: "Total: 32 bytes (256 bits)"
    }
  }
  compress_box: "sha256_compress(H, block_N)" {
    direction: down
    style.fill: "#FDEBD0"
    style.stroke: "#E67E22"
    style.border-radius: 6
    init_step: "Step 2: Init working vars" {
      style.fill: "#FDEBD0"
      style.stroke: "#E67E22"
      code1: |'c
        a = H[0]; b = H[1];
        c = H[2]; d = H[3];
        e = H[4]; f = H[5];
        g = H[6]; h = H[7];
      '|
      width: 280
    }
    rounds: "Step 3: 64 Rounds" {
      style.fill: "#FCF3CF"
      style.stroke: "#F39C12"
      code2: |'c
        T1 = h + Σ1(e) + Ch(e,f,g)
           + K[t] + W[t];
        T2 = Σ0(a) + Maj(a,b,c);
        h=g; g=f; f=e; e=d+T1;
        d=c; c=b; b=a; a=T1+T2;
      '|
      width: 280
    }
    wv_out: {
      shape: sql_table
      label: "Working Vars After 64 Rounds"
      wa: "a | uint32_t | e.g. 0x4f434152"
      wb: "b | uint32_t | ..."
      wc: "c | uint32_t | ..."
      wd: "d | uint32_t | ..."
      we: "e | uint32_t | ..."
      wf: "f | uint32_t | ..."
      wg: "g | uint32_t | ..."
      wh: "h | uint32_t | ..."
      note: "Depends on ALL 512 bits of block_N"
    }
  }
  adder: "Step 4: Additive Accumulation" {
    direction: down
    style.fill: "#E8F8E8"
    style.stroke: "#27AE60"
    style.border-radius: 6
    add_label: "Feed-Forward Addition (mod 2³²)" {
      style.fill: "#D5F5E3"
      style.stroke: "#27AE60"
      style.font-size: 12
      style.bold: true
    }
    add_ops: {
      shape: sql_table
      label: "H[i] += working_var[i]  (mod 2³²)"
      op0: "H[0] += a | wraps at 2³² | no mask needed in C uint32_t"
      op1: "H[1] += b | wraps at 2³² | automatic in C"
      op2: "H[2] += c | wraps at 2³² | automatic in C"
      op3: "H[3] += d | wraps at 2³² | automatic in C"
      op4: "H[4] += e | wraps at 2³² | automatic in C"
      op5: "H[5] += f | wraps at 2³² | automatic in C"
      op6: "H[6] += g | wraps at 2³² | automatic in C"
      op7: "H[7] += h | wraps at 2³² | automatic in C"
      note: "Python/JS MUST mask: (H[i] + w) & 0xFFFFFFFF"
    }
    security_note: "Davies-Meyer Feed-Forward" {
      style.fill: "#ABEBC6"
      style.stroke: "#1E8449"
      style.font-size: 11
      label: "Davies-Meyer Feed-Forward\nH_new = f(H_old, M) + H_old\nPrevents fixed-point attacks"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after: "AFTER: H[0..7] (output / next block seed)" {
    direction: down
    style.fill: "#E8F8E8"
    style.stroke: "#27AE60"
    style.border-radius: 6
    after_label: "Updated State: carries ALL prior blocks' influence" {
      style.fill: "#D5F5E3"
      style.stroke: "#27AE60"
      style.font-size: 12
      style.italic: true
    }
    h_new: {
      shape: sql_table
      label: "H[0..7] — Updated 256-bit state"
      H0n: "H[0] | uint32_t | 0xba7816bf  (after abc block)"
      H1n: "H[1] | uint32_t | 0x8f01cfea"
      H2n: "H[2] | uint32_t | 0x414140de"
      H3n: "H[3] | uint32_t | 0x5dae2223"
      H4n: "H[4] | uint32_t | 0xb00361a3"
      H5n: "H[5] | uint32_t | 0x96177a9c"
      H6n: "H[6] | uint32_t | 0xb410ff61"
      H7n: "H[7] | uint32_t | 0xf20015ad"
      note: "Total: 32 bytes — final digest if last block"
    }
  }
  chain_note: "Merkle-Damgård Chain Property" {
    direction: down
    style.fill: "#F4ECF7"
    style.stroke: "#8E44AD"
    style.border-radius: 6
    chain_diag: {
      shape: sql_table
      label: "Block Processing Order (sha256.c)"
      r0: "Block 0 | sha256_compress(H, block[0]) | H updated in place"
      r1: "Block 1 | sha256_compress(H, block[1]) | starts from updated H"
      r2: "Block N | sha256_compress(H, block[N]) | starts from H after block N-1"
      r3: "Digest  | H[0..7] → 32 big-endian bytes | output after last block"
      note: "Change block 0 → ALL subsequent H differ → avalanche across digest"
    }
    chain_code: {
      label: "Outer loop (sha256.c:sha256)"
      width: 380
      code3: |'c
        for (size_t i = 0; i < num_blocks; i++) {
          sha256_compress(H, block_ptr + i*64);
          /* H is MODIFIED in place each iteration */
          /* Block i+1 starts from H after block i */
        }
      '|
    }
  }
  bug_note: "Common Bug: Replace vs Accumulate" {
    direction: down
    style.fill: "#FDEDEC"
    style.stroke: "#C0392B"
    style.border-radius: 6
    style.stroke-dash: 4
    wrong: {
      shape: sql_table
      label: "WRONG — Replace (breaks chain)"
      w0: "H[0] = a | ignores prior blocks | NOT SHA-256"
      w1: "H[1] = b | last block wins only | trivially invertible"
      w2: "..."
      w7: "Every independent call | same result | no chaining"
    }
    correct: {
      shape: sql_table
      label: "CORRECT — Accumulate (FIPS 180-4)"
      c0: "H[0] += a | mod 2³² | prior state preserved"
      c1: "H[1] += b | mod 2³² | feed-forward active"
      c2: "..."
      c7: "Each block contributes | to ALL future H values | collision resistant"
    }
  }
}
digest_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  digest_out: "Final Output: Big-Endian Serialization (sha256_finalize)" {
    direction: down
    style.fill: "#EBF5FB"
    style.stroke: "#1A5276"
    style.border-radius: 6
    ser_code: {
      label: "sha256_finalize (sha256.c)"
      width: 420
      code4: |'c
        for (int i = 0; i < 8; i++) {
          digest[i*4+0] = (uint8_t)(H[i] >> 24); /* MSB first */
          digest[i*4+1] = (uint8_t)(H[i] >> 16);
          digest[i*4+2] = (uint8_t)(H[i] >>  8);
          digest[i*4+3] = (uint8_t)(H[i]      ); /* LSB last */
        }
        /* On x86 (little-endian): CANNOT use memcpy(&H[i], ...) */
      '|
    }
    hex_out: {
      shape: sql_table
      label: "SHA-256(abc) — NIST Test Vector"
      b0: "digest[0..3]  | H[0]=0xba7816bf | ba 78 16 bf"
      b1: "digest[4..7]  | H[1]=0x8f01cfea | 8f 01 cf ea"
      b2: "digest[8..11] | H[2]=0x414140de | 41 41 40 de"
      b3: "digest[12..15]| H[3]=0x5dae2223 | 5d ae 22 23"
      b4: "digest[16..19]| H[4]=0xb00361a3 | b0 03 61 a3"
      b5: "digest[20..23]| H[5]=0x96177a9c | 96 17 7a 9c"
      b6: "digest[24..27]| H[6]=0xb410ff61 | b4 10 ff 61"
      b7: "digest[28..31]| H[7]=0xf20015ad | f2 00 15 ad"
      hex: "Hex: ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
    }
  }
}
row0.before -> row0.compress_box: "a=H[0]..h=H[7] | copy" {
  style.stroke: "#2980B9"
  style.animated: true
}
row0.compress_box -> row0.adder: "a..h after 64 rounds | feed-forward" {
  style.stroke: "#E67E22"
  style.animated: true
}
row0.before -> row0.adder: "H[i]_old | addend" {
  style.stroke: "#2980B9"
  style.stroke-dash: 4
}
row0.adder -> row1.after: "H[i] += w_i mod 2³² | state updated" {
  style.stroke: "#27AE60"
  style.stroke-width: 3
  style.animated: true
}
row1.after -> row1.chain_note: "seeds next block | Merkle-Damgård" {
  style.stroke: "#8E44AD"
  style.animated: true
}
row1.after -> digest_row.digest_out: "if last block | serialize" {
  style.stroke: "#1A5276"
  style.stroke-width: 3
}
row1.chain_note -> row0.compress_box: "next block N+1 | loop back" {
  style.stroke: "#8E44AD"
  style.stroke-dash: 4
}