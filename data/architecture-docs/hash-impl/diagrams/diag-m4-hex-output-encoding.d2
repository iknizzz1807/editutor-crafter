direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Final Output: H[0]..H[7] → 64-Char Hex String (SHA-256('abc'))"
  style.font-size: 18
  style.bold: true
}
title.near: top-center
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hash_state: {
    label: "SHA-256 Hash State (sha256.c)"
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.border-radius: 6
    direction: down
    h0: {
      shape: sql_table
      label: "H[0..7] after sha256_compress()"
      f0: "H[0] | uint32_t | 0xba7816bf"
      f1: "H[1] | uint32_t | 0x8f01cfea"
      f2: "H[2] | uint32_t | 0x414140de"
      f3: "H[3] | uint32_t | 0x5dae2223"
      f4: "H[4] | uint32_t | 0xb00361a3"
      f5: "H[5] | uint32_t | 0x96177a9c"
      f6: "H[6] | uint32_t | 0xb410ff61"
      f7: "H[7] | uint32_t | 0xf20015ad"
      note: "8 x 32-bit = 256-bit digest (in CPU registers)"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  endian_note: {
    label: "Endianness Rule (FIPS 180-4)"
    style.fill: "#fef3c7"
    style.stroke: "#f59e0b"
    style.border-radius: 6
    direction: down
    rule_box: {
      shape: sql_table
      label: "Big-Endian Serialization Requirement"
      r0: "CPU     | x86/ARM = little-endian natively"
      r1: "SHA-256 | ALWAYS writes MSB first (big-endian)"
      r2: "digest[i*4+0] = (uint8_t)(H[i] >> 24)  ← MSB"
      r3: "digest[i*4+1] = (uint8_t)(H[i] >> 16)"
      r4: "digest[i*4+2] = (uint8_t)(H[i] >>  8)"
      r5: "digest[i*4+3] = (uint8_t)(H[i]      )  ← LSB"
      r6: "WRONG: memcpy(&digest[i*4], &H[i], 4)  // LE on x86"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  word_expand: {
    label: "H[0] = 0xba7816bf — Byte Serialization"
    style.fill: "#f0fdf4"
    style.stroke: "#22c55e"
    style.border-radius: 6
    direction: down
    bytes_table: {
      shape: sql_table
      label: "H[0] big-endian extraction"
      b0: "digest[0] | 0xba7816bf >> 24 | 0xba | MSB"
      b1: "digest[1] | 0xba7816bf >> 16 | 0x78"
      b2: "digest[2] | 0xba7816bf >>  8 | 0x16"
      b3: "digest[3] | 0xba7816bf >>  0 | 0xbf | LSB"
      note: "4 bytes extracted, MSB-first — platform independent"
    }
  }
  word_expand_h1: {
    label: "H[1] = 0x8f01cfea — Byte Serialization"
    style.fill: "#f0fdf4"
    style.stroke: "#22c55e"
    style.border-radius: 6
    direction: down
    bytes_h1: {
      shape: sql_table
      label: "H[1] big-endian extraction"
      b0: "digest[4] | 0x8f01cfea >> 24 | 0x8f | MSB"
      b1: "digest[5] | 0x8f01cfea >> 16 | 0x01"
      b2: "digest[6] | 0x8f01cfea >>  8 | 0xcf"
      b3: "digest[7] | 0x8f01cfea >>  0 | 0xea | LSB"
      note: "continues for H[2]..H[7] (24 more bytes)"
    }
  }
  ellipsis_box: {
    label: "H[2]..H[7]"
    style.fill: "#f5f3ff"
    style.stroke: "#8b5cf6"
    style.border-radius: 6
    direction: down
    el: {
      shape: sql_table
      label: "Remaining 6 words"
      e0: "H[2]=0x414140de | digest[8..11]  | 41 41 40 de"
      e1: "H[3]=0x5dae2223 | digest[12..15] | 5d ae 22 23"
      e2: "H[4]=0xb00361a3 | digest[16..19] | b0 03 61 a3"
      e3: "H[5]=0x96177a9c | digest[20..23] | 96 17 7a 9c"
      e4: "H[6]=0xb410ff61 | digest[24..27] | b4 10 ff 61"
      e5: "H[7]=0xf20015ad | digest[28..31] | f2 00 15 ad"
      note: "32 bytes total = 256-bit binary digest"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hex_encode: {
    label: "Nibble → Hex Character Mapping"
    style.fill: "#fff7ed"
    style.stroke: "#f97316"
    style.border-radius: 6
    direction: down
    nibble_table: {
      shape: sql_table
      label: "sha256_to_hex() — nibble extraction"
      n0: "byte 0xba | hi=0xb → 'b' | lo=0xa → 'a' | → \"ba\""
      n1: "byte 0x78 | hi=0x7 → '7' | lo=0x8 → '8' | → \"78\""
      n2: "byte 0x16 | hi=0x1 → '1' | lo=0x6 → '6' | → \"16\""
      n3: "byte 0xbf | hi=0xb → 'b' | lo=0xf → 'f' | → \"bf\""
      n4: "table | static const char HEX[]=\"0123456789abcdef\""
      n5: "high  | HEX[(byte >> 4) & 0x0F]"
      n6: "low   | HEX[(byte     ) & 0x0F]"
      note: "2 hex chars per byte × 32 bytes = 64 chars"
    }
  }
  c_idiom: {
    label: "C Formatting Idiom"
    style.fill: "#fdf4ff"
    style.stroke: "#a855f7"
    style.border-radius: 6
    direction: down
    c_code: {
      label: "printf idiom for H[i]"
      width: 420
      code: |'c
        /* Correct: prints all 8 hex digits, zero-padded */
        printf("%08x", H[i]);
        /* Correct: manual nibble extraction (platform-safe) */
        hex[i*2+0] = HEX[(digest[i] >> 4) & 0x0F];
        hex[i*2+1] = HEX[(digest[i]     ) & 0x0F];
        /* WRONG: %x omits leading zeros — "ba7816bf" OK but
           H[7]=0x00... would print too few chars */
        printf("%x", H[i]);  /* BAD for zero-padded words */
      '|
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  final_digest: {
    label: "Final 64-Char Hex Digest: SHA-256('abc')"
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
    style.border-radius: 8
    style.bold: true
    direction: down
    digest_concat: {
      shape: sql_table
      label: "digest[0..31] → hex[0..63]"
      d0: "H[0] | 0xba7816bf | \"ba7816bf\""
      d1: "H[1] | 0x8f01cfea | \"8f01cfea\""
      d2: "H[2] | 0x414140de | \"414140de\""
      d3: "H[3] | 0x5dae2223 | \"5dae2223\""
      d4: "H[4] | 0xb00361a3 | \"b00361a3\""
      d5: "H[5] | 0x96177a9c | \"96177a9c\""
      d6: "H[6] | 0xb410ff61 | \"b410ff61\""
      d7: "H[7] | 0xf20015ad | \"f20015ad\""
      result: "= \"ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad\""
    }
  }
}
row0 -> row1: "Step 1: apply serialization rule"
row1 -> row2: "Step 2: extract bytes MSB-first | uint32_t → 4 bytes"
row2 -> row3: "Step 3: encode each byte | byte → 2 hex chars"
row3 -> row4: "Step 4: concatenate | 8 words x 8 chars = 64 chars"
row0.hash_state -> row1.endian_note: "FIPS 180-4 §6.2.2"
row1.endian_note -> row2.word_expand: "H[0] first"
row1.endian_note -> row2.word_expand_h1: "H[1] next"
row1.endian_note -> row2.ellipsis_box: "H[2..7]"
row2.word_expand -> row3.hex_encode: "0xba,0x78,0x16,0xbf"
row2.word_expand_h1 -> row3.hex_encode: "0x8f,0x01,0xcf,0xea"
row3.hex_encode -> row4.final_digest: "64 chars | concat"
row3.c_idiom -> row4.final_digest: "printf idiom"