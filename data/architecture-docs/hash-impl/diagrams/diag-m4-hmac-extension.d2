direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "HMAC-SHA-256 = H(K⊕opad || H(K⊕ipad || msg))  —  2 complete SHA-256 passes"
  style: {
    font-size: 18
    bold: true
    fill: transparent
    stroke: transparent
  }
}
title.near: top-center
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  inputs: "Inputs (hmac_sha256.c)" {
    direction: right
    style.fill: "#e8f4f8"
    style.stroke: "#4a90d9"
    style.border-radius: 6
    key_in: {
      shape: sql_table
      label: "key (uint8_t*)"
      len: "key_len : size_t"
      note: "arbitrary length"
    }
    msg_in: {
      shape: sql_table
      label: "message (uint8_t*)"
      len: "msg_len : size_t"
      note: "arbitrary length"
    }
    mac_out: {
      shape: sql_table
      label: "mac[32] (uint8_t*)"
      note: "32-byte HMAC output"
      total: "= HMAC-SHA-256 result"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  key_norm: "Key Normalization (key_len > 64)" {
    direction: down
    style.fill: "#fff8e1"
    style.stroke: "#f9a825"
    style.border-radius: 6
    kn_check: {
      shape: diamond
      label: "key_len > 64?"
      style.fill: "#ffe082"
    }
    kn_hash: {
      shape: sql_table
      label: "sha256(key, key_len, k_block)"
      r1: "k_block[0..31] = SHA-256(key)"
      r2: "k_block[32..63] = 0x00 (zero pad)"
    }
    kn_copy: {
      shape: sql_table
      label: "memcpy(k_block, key, key_len)"
      r1: "k_block[0..key_len-1] = key"
      r2: "k_block[key_len..63]  = 0x00"
    }
    kn_result: {
      shape: sql_table
      label: "k_block[64] (uint8_t)"
      note: "key normalized to exactly 64 bytes"
      total: "same block size as SHA-256"
    }
    kn_check -> kn_hash: "yes | key too long"
    kn_check -> kn_copy: "no  | key fits"
    kn_hash -> kn_result: "uint8_t[32]"
    kn_copy -> kn_result: "uint8_t[key_len]"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  inner_pass: "SHA-256 Pass 1: Inner Hash  H(K⊕ipad || message)" {
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.border-radius: 6
    style.stroke-width: 2
    ip_xor: {
      shape: sql_table
      label: "Build ipad block (64 bytes)"
      r1: "for i in 0..63:"
      r2: "  ipad[i] = k_block[i] ^ 0x36"
      note: "0x36 = 0011 0110 (IPAD constant, RFC 2104)"
    }
    ip_init: {
      shape: sql_table
      label: "sha256_init(ctx)"
      r1: "ctx.H[0..7] = SHA256_INITIAL_HASH"
      r2: "ctx.buf_len = 0"
      r3: "ctx.total_bits = 0"
      note: "CALL 1 of 6  — fresh context"
    }
    ip_upd1: {
      shape: sql_table
      label: "sha256_update(ctx, ipad, 64)"
      r1: "feeds 64 bytes = exactly 1 block"
      r2: "sha256_compress(ctx.H, ipad)"
      r3: "ctx.buf_len = 0 after flush"
      note: "CALL 2 of 6  — K⊕ipad block"
    }
    ip_upd2: {
      shape: sql_table
      label: "sha256_update(ctx, msg, msg_len)"
      r1: "feeds message bytes, any length"
      r2: "buffers partial blocks in ctx.buf"
      r3: "flushes complete 64-byte blocks"
      note: "CALL 3 of 6  — message data"
    }
    ip_final: {
      shape: sql_table
      label: "sha256_finalize(ctx, inner[32])"
      r1: "appends 0x80 to ctx.buf"
      r2: "zero-fills up to byte 55 (or 2nd block)"
      r3: "writes total_bits as 64-bit BE at [56..63]"
      r4: "sha256_compress — final block"
      r5: "serializes H[0..7] -> inner[0..31] (BE)"
      note: "CALL 4 of 6  — produces inner digest"
    }
    ip_result: {
      shape: sql_table
      label: "inner[32] (uint8_t)"
      r1: "= SHA-256(K⊕ipad || message)"
      total: "32 bytes — feeds outer pass"
    }
    ip_xor -> ip_init: "ipad[64]"
    ip_init -> ip_upd1: "SHA256_CTX*"
    ip_upd1 -> ip_upd2: "ctx | 1 block compressed"
    ip_upd2 -> ip_final: "ctx | msg buffered"
    ip_final -> ip_result: "uint8_t[32]"
  }
  outer_pass: "SHA-256 Pass 2: Outer Hash  H(K⊕opad || inner)" {
    direction: down
    style.fill: "#fce4ec"
    style.stroke: "#880e4f"
    style.border-radius: 6
    style.stroke-width: 2
    op_xor: {
      shape: sql_table
      label: "Build opad block (64 bytes)"
      r1: "for i in 0..63:"
      r2: "  opad[i] = k_block[i] ^ 0x5C"
      note: "0x5C = 0101 1100 (OPAD constant, RFC 2104)"
    }
    op_init: {
      shape: sql_table
      label: "sha256_init(ctx)"
      r1: "ctx.H[0..7] = SHA256_INITIAL_HASH"
      r2: "ctx.buf_len = 0"
      r3: "ctx.total_bits = 0"
      note: "CALL 5 of 6  — CRITICAL: reset ctx"
    }
    op_upd1: {
      shape: sql_table
      label: "sha256_update(ctx, opad, 64)"
      r1: "feeds 64 bytes = exactly 1 block"
      r2: "sha256_compress(ctx.H, opad)"
      r3: "ctx.buf_len = 0 after flush"
      note: "CALL 6a of 6  — K⊕opad block"
    }
    op_upd2: {
      shape: sql_table
      label: "sha256_update(ctx, inner, 32)"
      r1: "feeds 32 bytes of inner digest"
      r2: "buffered (32 < 64, no flush yet)"
      r3: "ctx.buf[0..31] = inner"
      r4: "ctx.buf_len = 32"
      note: "CALL 6b of 6  — inner hash appended"
    }
    op_final: {
      shape: sql_table
      label: "sha256_finalize(ctx, mac[32])"
      r1: "32 bytes in buf + 0x80 = 33 bytes used"
      r2: "33 < 56: single-block padding"
      r3: "zero-fills buf[33..55]"
      r4: "writes (64+32)*8=768 bits at [56..63]"
      r5: "sha256_compress — final block"
      r6: "serializes H[0..7] -> mac[0..31] (BE)"
      note: "CALL 6c of 6  — final HMAC output"
    }
    op_result: {
      shape: sql_table
      label: "mac[32] (uint8_t)"
      r1: "= SHA-256(K⊕opad || inner)"
      r2: "= HMAC-SHA-256(K, message)"
      total: "32 bytes — authentication tag"
    }
    op_xor -> op_init: "opad[64]"
    op_init -> op_upd1: "SHA256_CTX*"
    op_upd1 -> op_upd2: "ctx | 1 block compressed"
    op_upd2 -> op_final: "ctx | 32 bytes buffered"
    op_final -> op_result: "uint8_t[32]"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  security_note: "Why 2 Passes? Length-Extension Attack Defense" {
    direction: right
    style.fill: "#f3e5f5"
    style.stroke: "#6a1b9a"
    style.border-radius: 6
    attack_col: "Naive MAC = SHA-256(K || msg)  — BROKEN" {
      direction: down
      style.fill: "#ffebee"
      style.stroke: "#c62828"
      style.border-radius: 4
      atk1: {
        shape: sql_table
        label: "Attacker knows: digest d, len(K||msg)"
        r1: "d = H[0..7] after final compress"
        r2: "d IS the internal state"
        note: "SHA-256 digest = compression output"
      }
      atk2: {
        shape: sql_table
        label: "Attack: resume from state d"
        r1: "Load d into ctx.H[0..7] directly"
        r2: "Set ctx.total_bits = padded_len * 8"
        r3: "sha256_update(ctx, attacker_data, ...)"
        r4: "sha256_finalize(ctx, forged_mac)"
        note: "valid MAC for K||msg||pad||attacker_data"
      }
      atk1 -> atk2: "exploit | digest == state"
      atk2.style.stroke: "#b71c1c"
      atk2.style.fill: "#ffcdd2"
    }
    defense_col: "HMAC = H(opad || H(ipad || msg))  — SAFE" {
      direction: down
      style.fill: "#e8f5e9"
      style.stroke: "#1b5e20"
      style.border-radius: 4
      def1: {
        shape: sql_table
        label: "Outer hash wraps inner digest"
        r1: "mac = H(K⊕opad || inner)"
        r2: "inner = H(K⊕ipad || msg)"
        note: "attacker sees mac, not inner"
      }
      def2: {
        shape: sql_table
        label: "Extension requires knowing opad block"
        r1: "to extend mac, need K⊕opad as prefix"
        r2: "K is secret → opad is secret"
        r3: "attacker cannot construct valid opad"
        note: "length extension is blocked"
      }
      def1 -> def2: "protected | K unknown"
      def2.style.stroke: "#2e7d32"
      def2.style.fill: "#c8e6c9"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ctx_struct: "SHA256_CTX — Streaming State (sha256.h)" {
    shape: sql_table
    label: "SHA256_CTX (sha256.h)"
    f0: "0x00 | uint32_t[8] | H          // running hash state (32 bytes)"
    f1: "0x20 | uint8_t[64] | buf        // partial block buffer (64 bytes)"
    f2: "0x60 | size_t      | buf_len    // valid bytes in buf [0..63]"
    f3: "0x68 | uint64_t    | total_bits // input bits seen across all update() calls"
    total: "Total: 104 bytes on stack — zero heap allocation"
  }
  call_seq: "6 API Calls Per HMAC — Exact Sequence" {
    shape: sql_table
    label: "hmac_sha256() call sequence (hmac.c)"
    c1: "1 | sha256_init(ctx)                  | reset H, buf, total_bits"
    c2: "2 | sha256_update(ctx, ipad, 64)       | K⊕ipad: 1 block compressed"
    c3: "3 | sha256_update(ctx, msg, msg_len)   | message: N blocks compressed"
    c4: "4 | sha256_finalize(ctx, inner)        | pad + final compress + serialize"
    c5: "5 | sha256_init(ctx)                  | RESET — mandatory before reuse"
    c6: "6a| sha256_update(ctx, opad, 64)       | K⊕opad: 1 block compressed"
    c7: "6b| sha256_update(ctx, inner, 32)      | inner: 32 bytes buffered"
    c8: "6c| sha256_finalize(ctx, mac)          | pad(32+64 bits) + compress + done"
    total: "= 2 complete SHA-256 computations  |  HMAC is a 10-line wrapper"
  }
}
title -> row0: ""
row0 -> row1: "key, key_len | normalize"
row1 -> row2: "k_block[64] | XOR with ipad / opad"
row2.inner_pass -> row2.outer_pass: "inner[32] | uint8_t[32]"
row2 -> row3: "mac[32] | why this structure?"
row2 -> row4: "implementation detail"