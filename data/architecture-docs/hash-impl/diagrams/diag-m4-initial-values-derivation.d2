direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## H0..H7 Initial Values: Square Roots of First 8 Primes
  FIPS 180-4 §5.3.3 — "Nothing Up My Sleeve" Construction
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  primes: {
    label: "First 8 Primes (Public, Universal)"
    style.fill: "#e8f4f8"
    style.stroke: "#4a90d9"
    style.border-radius: 8
    p0: "p0 = 2"  { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
    p1: "p1 = 3"  { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
    p2: "p2 = 5"  { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
    p3: "p3 = 7"  { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
    p4: "p4 = 11" { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
    p5: "p5 = 13" { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
    p6: "p6 = 17" { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
    p7: "p7 = 19" { style.fill: "#dbeafe"; style.stroke: "#3b82f6" }
  }
  note_numsource: {
    label: "Nothing-Up-My-Sleeve"
    style.fill: "#f0fdf4"
    style.stroke: "#16a34a"
    style.border-radius: 8
    n1: "Derivation is public" { style.fill: "#dcfce7" }
    n2: "Anyone can verify" { style.fill: "#dcfce7" }
    n3: "No secret choice" { style.fill: "#dcfce7" }
    n4: "No backdoor possible" { style.fill: "#dcfce7" }
    n5: "Contrast: Dual_EC_DRBG" { style.fill: "#fef2f2"; style.stroke: "#ef4444" }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  derive: {
    label: "Derivation Formula (sha256_init.c)"
    style.fill: "#fefce8"
    style.stroke: "#ca8a04"
    style.border-radius: 8
    width: 500
    step1: {
      label: "Step 1: sqrt(prime)"
      width: 460
      code: |'c
        /* sqrt(2) = 1.41421356237... */
        /* sqrt(3) = 1.73205080757... */
        /* sqrt(19) = 4.35889894354... */
      '|
    }
    step2: {
      label: "Step 2: frac() — keep only fractional part"
      width: 460
      code: |'c
        /* frac(sqrt(2))  = 0.41421356237... */
        /* frac(sqrt(3))  = 0.73205080757... */
        /* frac(sqrt(19)) = 0.35889894354... */
      '|
    }
    step3: {
      label: "Step 3: multiply by 2^32, truncate to uint32"
      width: 460
      code: |'c
        /* 0.41421356237 * 4294967296 = 1779033703 */
        /* hex: 0x6A09E667  => H[0]   */
        /* 0.73205080757 * 4294967296 = 3144134277 */
        /* hex: 0xBB67AE85  => H[1]   */
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  h_table: {
    shape: sql_table
    label: "SHA-256 Initial Hash Values H[0..7] (sha256.h)"
    h0: "H[0] | uint32_t | 0x6a09e667 | frac(sqrt(2))  x 2^32"
    h1: "H[1] | uint32_t | 0xbb67ae85 | frac(sqrt(3))  x 2^32"
    h2: "H[2] | uint32_t | 0x3c6ef372 | frac(sqrt(5))  x 2^32"
    h3: "H[3] | uint32_t | 0xa54ff53a | frac(sqrt(7))  x 2^32"
    h4: "H[4] | uint32_t | 0x510e527f | frac(sqrt(11)) x 2^32"
    h5: "H[5] | uint32_t | 0x9b05688c | frac(sqrt(13)) x 2^32"
    h6: "H[6] | uint32_t | 0x1f83d9ab | frac(sqrt(17)) x 2^32"
    h7: "H[7] | uint32_t | 0x5be0cd19 | frac(sqrt(19)) x 2^32"
    sz: "Total: 32 bytes (256 bits) — full compression function input width"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  usage: {
    label: "sha256_init() (sha256.c)"
    style.fill: "#f5f3ff"
    style.stroke: "#7c3aed"
    style.border-radius: 8
    width: 420
    code: |'c
      void sha256_init(SHA256_CTX *ctx) {
          for (int i = 0; i < 8; i++)
              ctx->H[i] = SHA256_INITIAL_HASH[i];
          ctx->buf_len    = 0;
          ctx->total_bits = 0;
      }
    '|
  }
  role: {
    label: "Role of H0..H7 in the Algorithm"
    style.fill: "#fff7ed"
    style.stroke: "#ea580c"
    style.border-radius: 8
    r1: "Input to compression, NOT output directly" { style.fill: "#ffedd5" }
    r2: "a=H[0], b=H[1] ... h=H[7] before round 0" { style.fill: "#ffedd5" }
    r3: "Updated in-place: H[i] += working_var[i]" { style.fill: "#ffedd5" }
    r4: "Final H[0..7] becomes the 256-bit digest" { style.fill: "#ffedd5" }
    r5: "MUST reset per hash — reuse is a security bug" { style.fill: "#fef2f2"; style.stroke: "#ef4444" }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  contrast: {
    label: "H0..H7 vs K[0..63]: Same Principle, Different Sources"
    style.fill: "#f8fafc"
    style.stroke: "#64748b"
    style.border-radius: 8
    shape: sql_table
    c1: "H[0..7] | sqrt of primes | 8 values  | initial compression state"
    c2: "K[0..63] | cbrt of primes | 64 values | round constants per block"
    c3: "Both    | publicly derivable | verifiable | no trapdoor possible"
  }
  compress_entry: {
    label: "sha256_compress() Entry (sha256_compress.c)"
    style.fill: "#f0fdf4"
    style.stroke: "#16a34a"
    style.border-radius: 8
    width: 380
    code: |'c
      void sha256_compress(uint32_t H[8],
                           const uint8_t *block) {
          uint32_t a = H[0], b = H[1];
          uint32_t c = H[2], d = H[3];
          uint32_t e = H[4], f = H[5];
          uint32_t g = H[6], h = H[7];
          /* ... 64 rounds ... */
          H[0] += a; H[1] += b;
          /* ... */
      }
    '|
  }
}
row1 -> row2: "apply sqrt() + frac() + x2^32"
row2 -> row3: "uint32_t truncation"
row3 -> row4: "loaded by sha256_init()"
row4 -> row5: "passed into sha256_compress()"