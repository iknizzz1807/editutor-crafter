direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
iv_block: "IV — Initial Hash Values (FIPS 180-4 §5.3.3)" {
  style.fill: "#e8f4f8"
  style.stroke: "#2c7bb6"
  style.stroke-width: 2
  style.border-radius: 6
  iv_table: {
    shape: sql_table
    label: "SHA256_INITIAL_HASH[8] — nothing-up-my-sleeve"
    h0: "H[0] | uint32_t | 0x6a09e667  ← frac(√2)  × 2³²"
    h1: "H[1] | uint32_t | 0xbb67ae85  ← frac(√3)  × 2³²"
    h2: "H[2] | uint32_t | 0x3c6ef372  ← frac(√5)  × 2³²"
    h3: "H[3] | uint32_t | 0xa54ff53a  ← frac(√7)  × 2³²"
    h4: "H[4] | uint32_t | 0x510e527f  ← frac(√11) × 2³²"
    h5: "H[5] | uint32_t | 0x9b05688c  ← frac(√13) × 2³²"
    h6: "H[6] | uint32_t | 0x1f83d9ab  ← frac(√17) × 2³²"
    h7: "H[7] | uint32_t | 0x5be0cd19  ← frac(√19) × 2³²"
    sz: "Total: 256 bits | Publicly verifiable — no hidden trapdoor"
  }
}
row_compress: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  block0_in: "Block 0 Input (512 bits / 64 bytes)" {
    style.fill: "#fff3cd"
    style.stroke: "#d68910"
    style.stroke-width: 2
    style.border-radius: 6
    b0_table: {
      shape: sql_table
      label: "Padded Block 0 — sha256_pad() output"
      msg:  "bytes  0–N   | uint8_t[] | message bytes"
      mark: "byte   N+1   | uint8_t   | 0x80 (MD marker)"
      zero: "bytes  N+2…55| uint8_t[] | 0x00 fill"
      lenf: "bytes  56–63 | uint64_t  | bit-length big-endian"
      sz:   "Total: 512 bits — exactly one compression input"
    }
  }
  compress0: "sha256_compress(H, Block 0)" {
    style.fill: "#d5f5e3"
    style.stroke: "#1e8449"
    style.stroke-width: 2
    style.border-radius: 6
    c0_class: {
      shape: class
      label: "Compression Function (sha256_compress.c)"
      sched: "sha256_message_schedule(block, W[64])"
      init:  "a..h ← H[0..7]  (working vars)"
      loop:  "for t in 0..63: T1,T2,rotate"
      upd:   "H[i] += working_var[i]  mod 2³²"
      note:  "64 rounds — Feistel-like register rotation"
    }
  }
}
intermediate: "Intermediate Hash State H¹ (256 bits)" {
  style.fill: "#f9ebff"
  style.stroke: "#7d3c98"
  style.stroke-width: 2
  style.border-radius: 6
  int_table: {
    shape: sql_table
    label: "H¹[0..7] — output of Block 0 compression"
    i0: "H¹[0] | uint32_t | H[0] + a  (mod 2³²)"
    i1: "H¹[1] | uint32_t | H[1] + b"
    i2: "H¹[2] | uint32_t | H[2] + c"
    i3: "H¹[3] | uint32_t | H[3] + d"
    i4: "H¹[4] | uint32_t | H[4] + e"
    i5: "H¹[5] | uint32_t | H[5] + f"
    i6: "H¹[6] | uint32_t | H[6] + g"
    i7: "H¹[7] | uint32_t | H[7] + h"
    sz: "Davies-Meyer feed-forward: H¹ = compress(IV, M₀) + IV"
  }
}
single_block_note: "Single-Block Shortcut" {
  style.fill: "#fdebd0"
  style.stroke: "#ca6f1e"
  style.stroke-width: 1
  style.stroke-dash: 5
  style.border-radius: 6
  note: "If input fits in one block (≤ 55 bytes after padding marker),\nloop runs once. H¹ IS the final digest. No second compress call."
}
row_compress2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  block1_in: "Block 1 Input (512 bits / 64 bytes)" {
    style.fill: "#fff3cd"
    style.stroke: "#d68910"
    style.stroke-width: 2
    style.border-radius: 6
    b1_table: {
      shape: sql_table
      label: "Padded Block 1 — two-block boundary case"
      msg2: "bytes  0–55  | uint8_t[] | 0x00 fill (overflow)"
      lenf2:"bytes  56–63 | uint64_t  | original bit-length"
      note2:"Triggered when msg len ≥ 56 bytes (len mod 64 ≥ 56)"
      sz2:  "Total: 512 bits — the extra block holds only length"
    }
  }
  compress1: "sha256_compress(H¹, Block 1)" {
    style.fill: "#d5f5e3"
    style.stroke: "#1e8449"
    style.stroke-width: 2
    style.border-radius: 6
    c1_class: {
      shape: class
      label: "Second Compression (same function, new state)"
      sched2: "sha256_message_schedule(block1, W[64])"
      init2:  "a..h ← H¹[0..7]  (chained from Block 0)"
      loop2:  "for t in 0..63: same 64-round loop"
      upd2:   "H²[i] = H¹[i] + working_var[i]  mod 2³²"
      chain:  "Key: Block 1 starts from H¹, NOT from IV"
    }
  }
}
final_hash: "Final Hash Output H² (256 bits → 64 hex chars)" {
  style.fill: "#eaf2ff"
  style.stroke: "#1a5276"
  style.stroke-width: 3
  style.border-radius: 6
  final_table: {
    shape: sql_table
    label: "H²[0..7] — the SHA-256 digest"
    f0: "H²[0] | 0xba7816bf | example: SHA-256(abc) byte  0..3"
    f1: "H²[1] | 0x8f01cfea | example: SHA-256(abc) byte  4..7"
    f2: "H²[2] | 0x414140de | example: SHA-256(abc) byte  8..11"
    f3: "H²[3] | 0x5dae2223 | example: SHA-256(abc) byte 12..15"
    f4: "H²[4] | 0xb00361a3 | example: SHA-256(abc) byte 16..19"
    f5: "H²[5] | 0x96177a9c | example: SHA-256(abc) byte 20..23"
    f6: "H²[6] | 0xb410ff61 | example: SHA-256(abc) byte 24..27"
    f7: "H²[7] | 0xf20015ad | example: SHA-256(abc) byte 28..31"
    enc: "Encoding: each H[i] → 4 bytes big-endian → 8 hex chars"
    out: "Output: 32 bytes = 64 hex chars (lowercase)"
  }
}
hex_encode: "sha256_to_hex() — Output Serialization" {
  style.fill: "#f2f3f4"
  style.stroke: "#626567"
  style.stroke-width: 1
  style.border-radius: 6
  hex_class: {
    shape: class
    label: "Hex Encoding (sha256.c)"
    op1: "digest[i*4+0] ← H²[i] >> 24  (MSB first — big-endian)"
    op2: "digest[i*4+1] ← H²[i] >> 16"
    op3: "digest[i*4+2] ← H²[i] >>  8"
    op4: "digest[i*4+3] ← H²[i] & 0xFF"
    op5: "hex[i*2]   ← HEX[(byte >> 4) & 0xF]"
    op6: "hex[i*2+1] ← HEX[byte & 0xF]"
    warn: "NEVER memcpy native uint32_t — wrong on little-endian x86"
  }
}
iv_block -> row_compress.block0_in: "H⁰ = IV | 256 bits" {
  style.stroke: "#2c7bb6"
  style.stroke-width: 2
  style.font-color: "#2c7bb6"
}
iv_block -> row_compress.compress0: "H⁰ = IV | initial state" {
  style.stroke: "#2c7bb6"
  style.stroke-width: 2
  style.stroke-dash: 3
}
row_compress.block0_in -> row_compress.compress0: "Block 0 | 512 bits" {
  style.stroke: "#d68910"
  style.stroke-width: 2
}
row_compress.compress0 -> intermediate: "H¹ = IV + compress(Block 0) | 256 bits" {
  style.stroke: "#1e8449"
  style.stroke-width: 3
  style.font-color: "#1e8449"
}
intermediate -> single_block_note: "single-block exit" {
  style.stroke: "#ca6f1e"
  style.stroke-dash: 5
  style.stroke-width: 1
}
intermediate -> row_compress2.block1_in: "H¹ passed as state | 256 bits" {
  style.stroke: "#7d3c98"
  style.stroke-width: 2
  style.font-color: "#7d3c98"
}
intermediate -> row_compress2.compress1: "H¹ = chained state | 256 bits" {
  style.stroke: "#7d3c98"
  style.stroke-width: 2
  style.stroke-dash: 3
}
row_compress2.block1_in -> row_compress2.compress1: "Block 1 | 512 bits" {
  style.stroke: "#d68910"
  style.stroke-width: 2
}
row_compress2.compress1 -> final_hash: "H² = H¹ + compress(Block 1) | 256 bits" {
  style.stroke: "#1e8449"
  style.stroke-width: 3
  style.font-color: "#1e8449"
}
final_hash -> hex_encode: "H²[0..7] | raw bytes" {
  style.stroke: "#1a5276"
  style.stroke-width: 2
}