direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
ctx_struct: "SHA256_CTX (sha256.h)" {
  shape: sql_table
  f0: "0x000 | uint32_t[8] | H[8]       // running hash state (256 bits)"
  f1: "0x020 | uint8_t[64] | buf[64]    // partial block buffer (512 bits)"
  f2: "0x060 | uint64_t    | total_bits // input bits seen so far"
  f3: "0x068 | size_t      | buf_len    // valid bytes in buf [0..63]"
  f4: "Total: 112 bytes on stack — no heap allocation"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_init: "INITIALIZED" {
    shape: circle
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
    width: 160
    height: 160
  }
  init_fields: "sha256_init() (sha256.c)" {
    shape: sql_table
    f0: "H[0..7] | = SHA256_INITIAL_HASH[0..7]"
    f1: "buf[*]  | = 0x00 (memset)"
    f2: "total_bits | = 0"
    f3: "buf_len    | = 0"
    f4: "H[0] = 0x6a09e667  // frac(sqrt(2))*2^32"
    f5: "H[7] = 0x5be0cd19  // frac(sqrt(19))*2^32"
  }
}
state_init -> init_fields: "populates"
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  update_ex: "update() Example: 3-byte + 61-byte calls" {
    shape: sql_table
    label: "Buffer Fill Trace (sha256_update)"
    s0: "Call 1: sha256_update(ctx, msg_a, 3)"
    s1: "  total_bits += 24  =>  total_bits = 24"
    s2: "  buf_len=0 → Phase1 skip"
    s3: "  Phase2: 3 < 64 → no full block → skip"
    s4: "  Phase3: copy 3 bytes to buf[0..2]"
    s5: "  buf_len = 3    // 61 bytes free"
    s6: "---"
    s7: "Call 2: sha256_update(ctx, msg_b, 61)"
    s8: "  total_bits += 488 =>  total_bits = 512"
    s9: "  Phase1: buf_len=3, need=61, can_use=61"
    sa: "  memcpy(buf+3, msg_b, 61) => buf full"
    sb: "  buf_len = 64 => COMPRESS(H, buf)"
    sc: "  buf_len = 0   // buffer flushed"
    sd: "  Phase2: 0 remaining => skip"
    se: "  Phase3: 0 remaining => skip"
  }
}
state_updating: "UPDATING" {
  shape: oval
  style.fill: "#2196F3"
  style.font-color: white
  style.bold: true
  width: 180
  height: 120
}
compress_trigger: "Compression Trigger (sha256_compress)" {
  shape: sql_table
  label: "On buf_len == 64"
  c0: "Condition: buf_len == SHA256_BLOCK_SIZE"
  c1: "Action:    sha256_compress(ctx->H, ctx->buf)"
  c2: "Reset:     ctx->buf_len = 0"
  c3: "H[0..7] updated in-place (+=a..h)"
  c4: "buf contents stale; buf_len=0 is canonical"
  c5: "style.fill: #FF5722 (hot path)"
}
compress_trigger.style.fill: "#FF5722"
compress_trigger.style.font-color: white
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_final: "FINALIZING" {
    shape: diamond
    style.fill: "#9C27B0"
    style.font-color: white
    style.bold: true
    width: 160
    height: 120
  }
  finalize_logic: "sha256_finalize() Padding Logic" {
    shape: sql_table
    p0: "used = buf_len"
    p1: "buf[used++] = 0x80        // append marker"
    p2: "---"
    p3: "BRANCH: used > 56?"
    p4: "  YES (needs 2nd block):"
    p5: "    memset(buf+used, 0, 64-used)"
    p6: "    sha256_compress(H, buf) // block N"
    p7: "    memset(buf, 0, 64)      // fresh block"
    p8: "  NO (fits in 1 block):"
    p9: "    memset(buf+used, 0, 56-used)"
    pa: "---"
    pb: "buf[56..63] = total_bits BE-64 // length field"
    pc: "sha256_compress(H, buf)         // final block"
  }
}
boundary_note: "56-Byte Boundary Case" {
  shape: sql_table
  style.fill: "#FF9800"
  style.font-color: white
  b0: "buf_len=56 after update() calls"
  b1: "  + 0x80 => used=57"
  b2: "  57 > 56 => TWO blocks needed"
  b3: "Block N:   [56 msg bytes][0x80][7x0x00]"
  b4: "Block N+1: [56x0x00][total_bits BE-64]"
  b5: "Contrast: buf_len=55 => ONE block only"
  b6: "  [55 msg bytes][0x80][0 zeros][len]"
}
digest_output: "Digest Output (sha256_finalize)" {
  shape: sql_table
  style.fill: "#607D8B"
  style.font-color: white
  d0: "for i in 0..7:"
  d1: "  digest[i*4+0] = H[i] >> 24  // MSB first"
  d2: "  digest[i*4+1] = H[i] >> 16"
  d3: "  digest[i*4+2] = H[i] >>  8"
  d4: "  digest[i*4+3] = H[i] >>  0  // LSB last"
  d5: "sha256_to_hex: nibble >> 4 and & 0x0F"
  d6: "Output: 64 lowercase hex chars + NUL"
}
state_done: "DONE" {
  shape: circle
  style.fill: "#607D8B"
  style.font-color: white
  style.double-border: true
  width: 120
  height: 120
}
ctx_struct -> row1.state_init: "instantiate"
row1.state_init -> state_updating: "sha256_update(ctx, data, len)" {
  style.stroke: "#2196F3"
  style.bold: true
}
row1.state_init -> row2.update_ex: "buffer walk"
state_updating -> compress_trigger: "buf_len == 64" {
  style.stroke: "#FF5722"
  style.bold: true
}
compress_trigger -> state_updating: "buf_len = 0 | loop continues" {
  style.stroke: "#FF5722"
  style.stroke-dash: 4
}
state_updating -> row2.update_ex: "trace"
state_updating -> row3.state_final: "sha256_finalize(ctx, digest)" {
  style.stroke: "#9C27B0"
  style.bold: true
}
row3.state_final -> row3.finalize_logic: "executes"
row3.finalize_logic -> boundary_note: "56-byte trap"
row3.finalize_logic -> digest_output: "after final compress"
digest_output -> state_done: "32-byte digest ready" {
  style.stroke: "#4CAF50"
  style.bold: true
}
legend: "Color Legend" {
  shape: sql_table
  l0: "Green  | State: INITIALIZED — H loaded, counters zeroed"
  l1: "Blue   | State: UPDATING — bytes accumulating in buffer"
  l2: "Red    | HOT PATH — compression triggered at 64-byte boundary"
  l3: "Purple | State: FINALIZING — padding + length field applied"
  l4: "Orange | BOUNDARY CASE — 56-byte input forces 2-block padding"
  l5: "Gray   | State: DONE — digest emitted, context stale"
}
legend.near: bottom-right