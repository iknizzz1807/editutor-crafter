direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "NIST Test Vector Coverage Map (SHA-256)"
  style: {
    font-size: 22
    bold: true
    fill: transparent
    stroke: transparent
  }
}
title.near: top-center
legend: {
  label: "Color Key"
  style: {
    fill: "#f5f5f5"
    stroke: "#999999"
    border-radius: 6
  }
  m1: "🟦 M1 = Padding/Preprocessing bug"
  m2: "🟩 M2 = Message Schedule bug"
  m3: "🟧 M3 = Compression Function bug"
  m4: "🟥 M4 = Output / State-Reset bug"
  conf: "✅ All 3 pass → strong correctness confidence"
}
legend.near: bottom-right
header_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  col_vec: {
    label: "Test Vector"
    style: {
      fill: "#1a1a2e"
      font-color: white
      bold: true
      border-radius: 4
      font-size: 14
    }
    width: 220
  }
  col_input: {
    label: "Input"
    style: {
      fill: "#1a1a2e"
      font-color: white
      bold: true
      border-radius: 4
      font-size: 14
    }
    width: 180
  }
  col_blocks: {
    label: "Blocks"
    style: {
      fill: "#1a1a2e"
      font-color: white
      bold: true
      border-radius: 4
      font-size: 14
    }
    width: 80
  }
  col_exercises: {
    label: "What It Exercises"
    style: {
      fill: "#1a1a2e"
      font-color: white
      bold: true
      border-radius: 4
      font-size: 14
    }
    width: 480
  }
  col_milestone: {
    label: "Bug Milestone"
    style: {
      fill: "#1a1a2e"
      font-color: white
      bold: true
      border-radius: 4
      font-size: 14
    }
    width: 140
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  r1_vec: {
    label: "TV-1: Empty String"
    style: {
      fill: "#e8f4f8"
      stroke: "#4a90d9"
      border-radius: 4
      font-size: 13
      bold: true
    }
    width: 220
  }
  r1_input: {
    label: "\"\" — 0 bytes"
    style: {
      fill: "#f9f9f9"
      stroke: "#cccccc"
      border-radius: 4
      font-size: 13
      font: mono
    }
    width: 180
  }
  r1_blocks: {
    label: "1 block"
    style: {
      fill: "#f9f9f9"
      stroke: "#cccccc"
      border-radius: 4
      font-size: 13
    }
    width: 80
  }
  r1_exercises: {
    label: "Pad of 0-byte input (buf[0]=0x80, 55 zero bytes, length=0x0000...0000). H[0..7] reset to initial constants. Single call to sha256_compress. Digest output byte ordering."
    style: {
      fill: "#f9f9f9"
      stroke: "#cccccc"
      border-radius: 4
      font-size: 12
    }
    width: 480
  }
  r1_milestone: {
    label: "M1 M3 M4"
    style: {
      fill: "#dbeafe"
      stroke: "#3b82f6"
      bold: true
      border-radius: 4
      font-size: 13
    }
    width: 140
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  r2_vec: {
    label: "TV-2: \"abc\""
    style: {
      fill: "#e8f8ee"
      stroke: "#34a853"
      border-radius: 4
      font-size: 13
      bold: true
    }
    width: 220
  }
  r2_input: {
    label: "\"abc\" — 3 bytes / 24 bits"
    style: {
      fill: "#f9f9f9"
      stroke: "#cccccc"
      border-radius: 4
      font-size: 13
      font: mono
    }
    width: 180
  }
  r2_blocks: {
    label: "1 block"
    style: {
      fill: "#f9f9f9"
      stroke: "#cccccc"
      border-radius: 4
      font-size: 13
    }
    width: 80
  }
  r2_exercises: {
    label: "Standard single-block path. Padding: 0x61 0x62 0x63 0x80 [52 zeros] 0x18. W[0]=0x61626380. 64 compression rounds. H update. Big-endian output of H[0..7]. Idempotence of two independent calls."
    style: {
      fill: "#f9f9f9"
      stroke: "#cccccc"
      border-radius: 4
      font-size: 12
    }
    width: 480
  }
  r2_milestone: {
    label: "M1 M2 M3 M4"
    style: {
      fill: "#dcfce7"
      stroke: "#16a34a"
      bold: true
      border-radius: 4
      font-size: 13
    }
    width: 140
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  r3_vec: {
    label: "TV-3: 448-bit Message"
    style: {
      fill: "#fff7e6"
      stroke: "#f59e0b"
      border-radius: 4
      font-size: 13
      bold: true
    }
    width: 220
  }
  r3_input: {
    label: "\"abcdbcde...nopq\" 56 bytes / 448 bits"
    style: {
      fill: "#f9f9f9"
      stroke: "#cccccc"
      border-radius: 4
      font-size: 12
      font: mono
    }
    width: 180
  }
  r3_blocks: {
    label: "2 blocks"
    style: {
      fill: "#fff3cd"
      stroke: "#f59e0b"
      bold: true
      border-radius: 4
      font-size: 13
    }
    width: 80
  }
  r3_exercises: {
    label: "CRITICAL BOUNDARY: 56 msg bytes + 0x80 = 57 bytes, only 7 bytes remain but 8 needed for length field. Forces extra block. Block-1: [56 bytes][0x80][7 zeros]. Block-2: [56 zeros][length=448 bits]. Merkle-Damgard chaining H between blocks. Loop must iterate num_blocks=2."
    style: {
      fill: "#fff7e6"
      stroke: "#f59e0b"
      border-radius: 4
      font-size: 12
    }
    width: 480
  }
  r3_milestone: {
    label: "M1 M2 M3 M4"
    style: {
      fill: "#fef3c7"
      stroke: "#d97706"
      bold: true
      border-radius: 4
      font-size: 13
    }
    width: 140
  }
}
coverage_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cov_label: {
    label: "Coverage Summary"
    style: {
      fill: "#1a1a2e"
      font-color: white
      bold: true
      border-radius: 4
      font-size: 13
    }
    width: 220
  }
  cov_detail: {
    label: "Empty → single-block zero-input path | abc → standard single-block | 56-byte → two-block boundary. Together: exercises all code paths in padding, schedule, compression, and output formatting. NOT exhaustive (no 1-million-'a' test, no random fuzz). Passing all 3 = strong but not complete confidence."
    style: {
      fill: "#f0f0ff"
      stroke: "#6366f1"
      border-radius: 4
      font-size: 12
    }
    width: 840
  }
}
m1_detail: {
  label: "M1 Padding Bugs Caught By"
  style: {
    fill: "#dbeafe"
    stroke: "#3b82f6"
    border-radius: 6
    font-size: 12
  }
  d1: "TV-1: num_blocks==1 for 0 bytes"
  d2: "TV-2: num_blocks==1 for 3 bytes"
  d3: "TV-3: num_blocks==2 for 56 bytes (boundary!)"
  d4: "TV-1+2: length field = 0x00...00 and 0x00...18"
}
m2_detail: {
  label: "M2 Schedule Bugs Caught By"
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    border-radius: 6
    font-size: 12
  }
  d1: "TV-2: W[0]=0x61626380 (endianness parse)"
  d2: "TV-2: W[16]=0x61626380 (recurrence for zero inputs)"
  d3: "TV-3: W[0..15] from block-2 all-zero except length"
  d4: "Any: wrong sigma constants diverge immediately"
}
m3_detail: {
  label: "M3 Compression Bugs Caught By"
  style: {
    fill: "#fef3c7"
    stroke: "#d97706"
    border-radius: 6
    font-size: 12
  }
  d1: "TV-2: H after compress matches NIST appendix"
  d2: "TV-3: H after block-1 feeds into block-2 correctly"
  d3: "Any: swapped Ch/Maj or uppercase/lowercase sigma"
  d4: "Any: K[] constants wrong (cube-root derivation)"
}
m4_detail: {
  label: "M4 Output / Streaming Bugs Caught By"
  style: {
    fill: "#fce7f3"
    stroke: "#db2777"
    border-radius: 6
    font-size: 12
  }
  d1: "TV-1: digest[0]=0xe3 not 0x44 (big-endian H[0]>>24)"
  d2: "TV-2+3: streaming 1-byte-at-a-time == one-shot"
  d3: "TV-2 run twice: ctx reset between calls"
  d4: "TV-3: total_bits tracked across two update() calls"
}
detail_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m1_detail
  m2_detail
  m3_detail
  m4_detail
}
header_row -> row1: ""
row1 -> row2: ""
row2 -> row3: ""
row3 -> coverage_row: ""
coverage_row -> detail_row: ""