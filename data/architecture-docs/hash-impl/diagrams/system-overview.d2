row_shared.layer_types.sigma_upper_1 -> row_m3.layer_m3.working_vars: "T1 Sigma1(e)"
row_shared.layer_types.ch_mac -> row_m3.layer_m3.working_vars: "T1 Ch(e,f,g)"
row_shared.layer_types.maj_mac -> row_m3.layer_m3.working_vars: "T2 Maj(a,b,c)"
