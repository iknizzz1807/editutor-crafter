direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
row_shared: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_types: {
    direction: down
    label: "SHARED PRIMITIVES  sha256_schedule.h"
    style.fill: "#f0f4ff"
    rotr32: {
      shape: sql_table
      label: "macro ROTR32(x,n)  sha256_schedule.h  [M2]"
      op: "((x)>>(n))|((x)<<(32-(n))) | uint32_t"
      constraint: "n in [1..31] only | UB at n=0,32"
      note: "no bits destroyed — pure rotation"
    }
    shr32: {
      shape: sql_table
      label: "macro SHR32(x,n)  sha256_schedule.h  [M2]"
      op: "(x)>>(n) | uint32_t"
      constraint: "n low-bits LOST forever | fills zeros"
      note: "makes sigma non-invertible"
    }
    sigma_lower_0: {
      shape: sql_table
      label: "macro SIGMA_LOWER_0(x)  sha256_schedule.h  [M2]"
      formula: "ROTR(x,7)^ROTR(x,18)^SHR(x,3) | uint32_t"
      fips: "FIPS 180-4 Eq(4.6) | schedule W[t-15]"
      constants: "(7,18,3) | DO NOT confuse with UPPER"
    }
    sigma_lower_1: {
      shape: sql_table
      label: "macro SIGMA_LOWER_1(x)  sha256_schedule.h  [M2]"
      formula: "ROTR(x,17)^ROTR(x,19)^SHR(x,10) | uint32_t"
      fips: "FIPS 180-4 Eq(4.7) | schedule W[t-2]"
      constants: "(17,19,10) | schedule only"
    }
    sigma_upper_0: {
      shape: sql_table
      label: "macro SIGMA_UPPER_0(x)  sha256_compress.h  [M3]"
      formula: "ROTR(x,2)^ROTR(x,13)^ROTR(x,22) | uint32_t"
      fips: "FIPS 180-4 Eq(4.4) | applied to 'a'"
      constants: "(2,13,22) | ALL ROTR no SHR"
    }
    sigma_upper_1: {
      shape: sql_table
      label: "macro SIGMA_UPPER_1(x)  sha256_compress.h  [M3]"
      formula: "ROTR(x,6)^ROTR(x,11)^ROTR(x,25) | uint32_t"
      fips: "FIPS 180-4 Eq(4.5) | applied to 'e'"
      constants: "(6,11,25) | ALL ROTR no SHR"
    }
    ch_mac: {
      shape: sql_table
      label: "macro CH(x,y,z)  sha256_compress.h  [M3]"
      formula: "((x)&(y))^(~(x)&(z)) | uint32_t"
      semantic: "bitwise MUX: x=1->y  x=0->z | nonlinear AND"
      fips: "FIPS 180-4 Eq(4.2)"
    }
    maj_mac: {
      shape: sql_table
      label: "macro MAJ(x,y,z)  sha256_compress.h  [M3]"
      formula: "((x)&(y))^((x)&(z))^((y)&(z)) | uint32_t"
      semantic: "majority gate: out=1 iff 2+ inputs=1 | nonlinear"
      fips: "FIPS 180-4 Eq(4.3)"
    }
  }
  layer_constants: {
    direction: down
    label: "CONSTANTS  sha256_compress.c / sha256_initial.c"
    style.fill: "#fff8f0"
    k_array: {
      shape: sql_table
      label: "SHA256_K[64]  sha256_compress.c  [M3]"
      element_type: "const uint32_t | 256 bytes total"
      source: "floor(frac(cbrt(prime_n))*2^32) | primes 2..311"
      k0: "K[0]=0x428a2f98 | cbrt(2) verified"
      k1: "K[1]=0x71374491 | cbrt(3)"
      k63: "K[63]=0xc67178f2 | cbrt(311)"
      note: "nothing-up-my-sleeve | extern linkage for tests"
    }
    h_init: {
      shape: sql_table
      label: "SHA256_INITIAL_HASH[8]  sha256_initial.c  [M4]"
      element_type: "const uint32_t | 32 bytes total"
      source: "floor(frac(sqrt(prime_n))*2^32) | primes 2..19"
      h0: "H[0]=0x6a09e667 | frac(sqrt(2))*2^32"
      h1: "H[1]=0xbb67ae85 | frac(sqrt(3))*2^32"
      h7: "H[7]=0x5be0cd19 | frac(sqrt(19))*2^32"
      note: "MUST copy fresh per hash | never share mutable ref"
    }
  }
}
row_m1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_m1: {
    direction: down
    label: "M1: MESSAGE PREPROCESSING  sha256_pad.h / sha256_pad.c"
    style.fill: "#f0fff4"
    padded_t: {
      shape: sql_table
      label: "sha256_padded_t  sha256_pad.h  [M1]"
      data_field: "uint8_t data[MAX_PADDED_BLOCKS*64] | ~1MiB flat"
      num_blocks: "size_t num_blocks | blocks in data[]"
      block_i: "data[i*64..i*64+63] = block i | pointer arith"
      note: "stack-alloc OK for learning impl | heap for prod"
      sz: "Total: SHA256_MAX_PADDED_BLOCKS(16386)*64 bytes"
    }
    pad_fn: {
      shape: class
      label: "sha256_pad.c  [M1]"
      +sha256_pad(msg,len,out): "int (0=ok -1=toolarge)"
      +sha256_get_block(padded,idx): "const uint8_t*"
      -write_be64(buf,val): "void | static helper"
    }
    pad_algo: {
      shape: sql_table
      label: "Padding Algorithm  FIPS 180-4 §5.1.1  [M1]"
      step1: "memset(out,0,sizeof) | zero entire struct"
      step2: "memcpy(out->data,msg,len) | copy message"
      step3: "out->data[len]=0x80 | 1-bit marker"
      step4: "used=len+1 | total_padded=ceil((used+8)/64)*64"
      step5: "write_be64(data+total-8, len*8) | bit-length BE"
      step6: "num_blocks=total_padded/64"
      trap: "len=55->1 block | len=56->2 blocks (THE TRAP)"
      note: "Length field = bits NOT bytes | cast (uint64_t)len*8"
    }
    pad_layout: {
      shape: sql_table
      label: "Block Layout  abc (3 bytes)  [M1]"
      b0: "data[0..2]=0x61 0x62 0x63 | message"
      b3: "data[3]=0x80 | marker"
      b4_55: "data[4..55]=0x00 | zero fill"
      b56_63: "data[56..63]=0x0000000000000018 | 24 bits BE"
      total: "64 bytes = 1 block | W[0]=0x61626380"
    }
  }
}
row_m2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_m2: {
    direction: down
    label: "M2: MESSAGE SCHEDULE  sha256_schedule.h / sha256_schedule.c"
    style.fill: "#f0f8ff"
    w_array: {
      shape: sql_table
      label: "W[64]  caller stack  [M2]"
      element_type: "uint32_t[64] | 256 bytes on stack"
      w0_15: "W[0..15] = big-endian parse of block[0..63]"
      w16_63: "W[t] = recurrence expansion | mod 2^32 auto"
      parse_formula: "W[t]=(block[4t]<<24)|(block[4t+1]<<16)|..."
      recurrence: "W[t]=SIGMA1(W[t-2])+W[t-7]+SIGMA0(W[t-15])+W[t-16]"
      abc_w0: "W[0]=0x61626380 | W[15]=0x00000018 | W[16]=0x61626380"
      abc_w17: "W[17]=0x000F0000 | sigma1(0x18)=0x000F0000"
      note: "caller must declare uint32_t W[64] — no alloc"
    }
    schedule_fn: {
      shape: class
      label: "sha256_schedule.c  [M2]"
      +sha256_message_schedule(block,W): "void"
      +sha256_print_schedule(W): "void | debug only"
    }
    endian_helper: {
      shape: sql_table
      label: "Big-Endian Word Parse  [M1/M2]"
      correct: "(uint32_t)block[t*4+0]<<24 | explicit shifts"
      wrong: "*(uint32_t*)(block+t*4) | x86 gives reversed bytes"
      example: "0x61 0x62 0x63 0x80 -> 0x61626380 (BE correct)"
      platform: "x86 little-endian: cast gives 0x80636261 WRONG"
    }
  }
}
row_m3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_m3: {
    direction: down
    label: "M3: COMPRESSION FUNCTION  sha256_compress.h / sha256_compress.c"
    style.fill: "#fff0f8"
    working_vars: {
      shape: sql_table
      label: "Working Variables a..h  stack-local  [M3]"
      decl: "uint32_t a,b,c,d,e,f,g,h | 32 bytes"
      init: "a=H[0]..h=H[7] | LOCAL COPIES not refs"
      t1: "T1=h+SIGMA1(e)+CH(e,f,g)+K[t]+W[t] | msg input"
      t2: "T2=SIGMA0(a)+MAJ(a,b,c) | structural diffusion"
      rot_h: "h=g; g=f; f=e; e=d+T1 | NOT d+T1+T2"
      rot_a: "d=c; c=b; b=a; a=T1+T2 | BOTH temps"
      note: "T1 T2 computed BEFORE any assignment | RAW safe"
    }
    compress_fn: {
      shape: class
      label: "sha256_compress.c  [M3]"
      +sha256_compress(H,block): "void | updates H in place"
      +sha256_compress_debug(H_init,block): "void | prints rounds"
    }
    compress_steps: {
      shape: sql_table
      label: "Compression Steps  FIPS 180-4 §6.2.2  [M3]"
      step1: "sha256_message_schedule(block,W) | expand 16->64 words"
      step2: "a=H[0]..h=H[7] | copy state to working vars"
      step3: "for t=0..63: T1 T2 then rotate | 64 rounds"
      step4: "H[0]+=a .. H[7]+=h | Davies-Meyer feed-forward"
      critical: "H[i]+=a NOT H[i]=a | += is load-bearing"
      abc_result: "H[0]=0xba7816bf..H[7]=0xf20015ad after abc"
      stack: "W[64]=256B + a..h T1 T2=40B = 296B total frame"
    }
    state_update: {
      shape: sql_table
      label: "Davies-Meyer Feed-Forward  [M3]"
      formula: "H_new[i] = H_old[i] + working_var[i] mod 2^32"
      why: "prior state baked in | attacker cant override"
      note: "same pattern as Davies-Meyer block cipher construct"
    }
  }
}
row_m4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_m4_ctx: {
    direction: down
    label: "M4: STREAMING CONTEXT  sha256.h / sha256_api.c"
    style.fill: "#fffff0"
    sha256_ctx: {
      shape: sql_table
      label: "SHA256_CTX  sha256.h  [M4]"
      H: "uint32_t H[8] | 32 bytes | running hash state"
      buf: "uint8_t buf[64] | 64 bytes | partial block buffer"
      buf_len: "size_t buf_len | 8 bytes | valid bytes in buf [0..63]"
      total_bits: "uint64_t total_bits | 8 bytes | cumulative bit count"
      invariant: "buf_len NEVER==64 | full block always flushed"
      sz: "Total: ~112 bytes | 2 cache lines on x86-64"
    }
    api_fn: {
      shape: class
      label: "sha256_api.c  [M4]"
      +sha256_init(ctx): "void | loads INITIAL_HASH resets counters"
      +sha256_update(ctx,data,len): "void | 3-phase buffer mgmt"
      +sha256_finalize(ctx,digest): "void | pads compresses serializes"
      +sha256_to_hex(digest,hex): "void | nibble extract lowercase"
      +sha256_oneshot(msg,len,hex): "void | stack-local thread-safe"
    }
    update_phases: {
      shape: sql_table
      label: "sha256_update() 3 Phases  [M4]"
      p0: "total_bits += (uint64_t)len*8 | BEFORE any return"
      p1: "if buf_len>0: fill+flush if complete | partial: return"
      p2: "while i+64<=len: compress(data+i) | hot path"
      p3: "if remaining>0: memcpy(buf,data+i,remaining)"
      post: "buf_len in [0..63] always | invariant maintained"
    }
    finalize_algo: {
      shape: sql_table
      label: "sha256_finalize() Algorithm  [M4]"
      s1: "buf[buf_len]=0x80; used=buf_len+1"
      s2a: "if used>56: memset+compress+memset(buf,0) | 2-block"
      s2b: "else: memset(buf+used,0,56-used) | 1-block"
      s3: "write total_bits BE at buf[56..63] | NOT buf_len*8"
      s4: "sha256_compress(H,buf) | final block"
      s5: "H[i]>>24..H[i]&0xFF into digest[i*4..i*4+3] | BE"
      trap: "buf_len=55->used=56: 1-block | buf_len=56->2-block"
    }
    hex_fn: {
      shape: sql_table
      label: "sha256_to_hex()  [M4]"
      hi: "hex[i*2]  = HEX_CHARS[(digest[i]>>4)&0x0F]"
      lo: "hex[i*2+1]= HEX_CHARS[(digest[i])&0x0F]"
      table: "static const char HEX[]=0123456789abcdef | lowercase"
      term: "hex[64]='\\0' | null-terminated C string"
    }
  }
  layer_m4_nist: {
    direction: down
    label: "M4: NIST TEST VECTORS  sha256_api_test.c"
    style.fill: "#f8fff0"
    nist_v1: {
      shape: sql_table
      label: "Vector 1: Empty String  [M4]"
      input: "msg=NULL len=0"
      expected: "e3b0c44298fc1c149afbf4c8996fb924..."
      tests: "1-block pad | 0x80 at [0] | length-field=0"
    }
    nist_v2: {
      shape: sql_table
      label: "Vector 2: abc  [M4]"
      input: "msg=abc len=3"
      expected: "ba7816bf8f01cfea414140de5dae2223..."
      tests: "1-block | W[0]=0x61626380 | H verified in M3"
    }
    nist_v3: {
      shape: sql_table
      label: "Vector 3: 56-byte abcdbcde...  [M4]"
      input: "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
      expected: "248d6a61d20638b8e5c026930c3e6039..."
      tests: "2-block path | buf_len=56 at finalize | critical"
    }
    hmac_ext: {
      shape: sql_table
      label: "HMAC-SHA-256 Extension  [M4]"
      ipad_block: "K xor 0x36 repeated 64 bytes"
      inner: "SHA256(ipad || message)"
      opad_block: "K xor 0x5C repeated 64 bytes"
      outer: "SHA256(opad || inner_hash)"
      note: "double-hash defeats length-extension | 20 lines"
      critical: "sha256_init before outer hash | reset required"
    }
  }
}
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | hash-impl-m1 | Message Preprocessing and Padding"
  m2: "M2 | hash-impl-m2 | Message Schedule Generation"
  m3: "M3 | hash-impl-m3 | Compression Function"
  m4: "M4 | hash-impl-m4 | Final Hash Output and Validation"
}
