vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## W[16..21] Recurrence Dependency Graph
  Edges show which prior word feeds each expanded word, and in which role.
  A change in **W[0]** propagates → W[16] → W[17] → W[18] → ...
| {near: top-center}
classes: {
  input_word: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      font-size: 13
      bold: true
    }
  }
  expanded_word: {
    style: {
      fill: "#FFF3CD"
      stroke: "#D4800A"
      stroke-width: 2
      font-size: 13
      bold: true
    }
  }
  key_word: {
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
      stroke-width: 3
      font-size: 13
      bold: true
    }
  }
}
W0: "W[0] = 0x61626380" {class: key_word}
W1: "W[1] = 0x00000000" {class: input_word}
W2: "W[2] = 0x00000000" {class: input_word}
W3: "W[3] = 0x00000000" {class: input_word}
W4: "W[4] = 0x00000000" {class: input_word}
W5: "W[5] = 0x00000000" {class: input_word}
W6: "W[6] = 0x00000000" {class: input_word}
W7: "W[7] = 0x00000000" {class: input_word}
W9: "W[9] = 0x00000000" {class: input_word}
W10: "W[10] = 0x00000000" {class: input_word}
W11: "W[11] = 0x00000000" {class: input_word}
W14: "W[14] = 0x00000000" {class: input_word}
W15: "W[15] = 0x00000018" {class: key_word}
W16: "W[16] = 0x61626380" {class: expanded_word}
W17: "W[17] = 0x000F0000" {class: expanded_word}
W18: "W[18]" {class: expanded_word}
W19: "W[19]" {class: expanded_word}
W20: "W[20]" {class: expanded_word}
W21: "W[21]" {class: expanded_word}
legend: {
  near: bottom-left
  label: |md
    **Edge Colors / Roles**
    - 🟠 Orange → σ1(W[t-2])
    - 🔵 Blue   → +W[t-7]  (direct)
    - 🟢 Green  → σ0(W[t-15])
    - ⬜ Gray   → +W[t-16] (direct)
  |
  style: {
    fill: "#F8F9FA"
    stroke: "#ADB5BD"
    border-radius: 8
    font-size: 12
  }
}
