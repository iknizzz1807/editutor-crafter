vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: ||md
    ## Module Architecture: Compression Function — `hash-impl-m3`
    **sizeof(SHA256_CTX stack frame)** ≈ 296 bytes · `W[64]`=256B + `a..h,T1,T2`=40B
  ||
  near: top-center
}

# ── External dependencies (M2) ────────────────────────────────────────────
m2: "sha256_schedule.h (Milestone 2)" {
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
  style.border-radius: 6
  
  rotr32: {
    style.fill: "#B8D9F5"
    style.font: mono
    label: "ROTR32(x, n)\n((x>>n)|(x<<(32-n)))\nuint32_t → uint32_t"
  }
  shr32: {
    style.fill: "#B8D9F5"
    style.font: mono
    label: "SHR32(x, n)\n(x >> n)\nuint32_t → uint32_t"
  }
  schedule_fn: {
    style.fill: "#C5E0F5"
    style.font: mono
    label: "sha256_message_schedule(\n  const uint8_t *block,\n  uint32_t W[64]\n) → void\nExpands 64B → 64×uint32_t"
  }
}

# ── Read-only constant ─────────────────────────────────────────────────────
k_array: "SHA256_K[64]" {
  style.fill: "#F3E8FF"
  style.stroke: "#8B5CF6"
  style.border-radius: 6
  label: "SHA256_K[64]\nstatic const uint32_t\n256 bytes · .rodata\n\nK[0]=0x428a2f98  ← ∛2\nK[1]=0x71374491  ← ∛3\n···\nK[63]=0xc67178f2 ← ∛311\n\n\"Nothing up my sleeve\"\n= floor(frac(∛primeₙ)×2³²)"
}

# ── sha256_compress.h macros ───────────────────────────────────────────────
macros: "sha256_compress.h — Uppercase Σ + Boolean Functions" {
  style.fill: "#FFF7E6"
  style.stroke: "#D97706"
  style.border-radius: 6
  
  su0: {
    style.fill: "#FFE4A0"
    style.font: mono
    label: "SIGMA_UPPER_0(x)  [Σ0]\nROTR(x,2)^ROTR(x,13)^ROTR(x,22)\nFIPS §4.1.2 Eq.(4.4)\nApplied to: working var 'a' → T2\nConstants: (2,13,22) — ALL ROTR, no SHR\nuint32_t → uint32_t"
  }
  su1: {
    style.fill: "#FFE4A0"
    style.font: mono
    label: "SIGMA_UPPER_1(x)  [Σ1]\nROTR(x,6)^ROTR(x,11)^ROTR(x,25)\nFIPS §4.1.2 Eq.(4.5)\nApplied to: working var 'e' → T1\nConstants: (6,11,25) — ALL ROTR, no SHR\nuint32_t → uint32_t"
  }
  ch: {
    style.fill: "#FFDDA0"
    style.font: mono
    label: "CH(x, y, z)  [Choice]\n(x&y)^(~x&z)\nFIPS §4.1.2 Eq.(4.2)\nBitwise MUX: x=1→y, x=0→z\nNONLINEAR (AND term)\nApplied to: e,f,g → T1\nuint32_t×3 → uint32_t"
  }
  maj: {
    style.fill: "#FFDDA0"
    style.font: mono
    label: "MAJ(x, y, z)  [Majority]\n(x&y)^(x&z)^(y&z)\nFIPS §4.1.2 Eq.(4.3)\nOutput bit=1 iff ≥2 inputs=1\nNONLINEAR (AND terms)\nApplied to: a,b,c → T2\nuint32_t×3 → uint32_t"
  }
  naming_note: {
    label: ||md
      ⚠️ **Critical: UPPER ≠ LOWER**
      | Macro | Constants | Used in |
      |---|---|---|
      | SIGMA_UPPER_0 | (2,13,22) | compress — `a` |
      | SIGMA_UPPER_1 | (6,11,25) | compress — `e` |
      | SIGMA_LOWER_0 | (7,18,3) | schedule — W[t-15] |
      | SIGMA_LOWER_1 | (17,19,10) | schedule — W[t-2] |
    ||
    style.fill: "#FFF3CD"
    style.font-size: 12
  }
}

# ── Core function ──────────────────────────────────────────────────────────
compress: sha256_compress() {
  style.fill: "#E8F8E8"
  style.stroke: "#16A34A"
  style.border-radius: 8
  style.stroke-width: 2
  
  sig: {
    style.fill: "#C5EFC5"
    style.font: mono
    label: "void sha256_compress(\n  uint32_t  H[8],         ← in/out: hash state\n  const uint8_t *block    ← in:  64-byte block\n)"
  }
  step1: {
    style.fill: "#D4F0D4"
    style.font: mono
    label: "uint32_t W[64];  // 256B stack\nsha256_message_schedule(block, W);\n// W[0..15]  = big-endian words\n// W[16..63] = σ0/σ1 recurrence"
  }
  step2: {
    style.fill: "#D4F0D4"
    style.font: mono
    label: "a=H[0] b=H[1] c=H[2] d=H[3]\ne=H[4] f=H[5] g=H[6] h=H[7]\n// LOCAL COPIES — H[] unchanged until Step 4"
  }
  step3: "Step 3 — 64-Round Loop (t=0..63)" {
    style.fill: "#D4F0D4"
    t1_calc: {
      style.fill: "#B8E8B8"
      style.font: mono
      label: "T1 = h\n   + SIGMA_UPPER_1(e)\n   + CH(e, f, g)\n   + SHA256_K[t]\n   + W[t]"
    }
    t2_calc: {
      style.fill: "#B8E8B8"
      style.font: mono
      label: "T2 = SIGMA_UPPER_0(a)\n   + MAJ(a, b, c)"
    }
    rotation: {
      style.fill: "#B8E8B8"
      style.font: mono
      label: "h=g; g=f; f=e;\ne = d + T1;   ← NOT d+T1+T2\nd=c; c=b; b=a;\na = T1 + T2;  ← BOTH temps"
    }
    t1_calc -> t2_calc: "computed first\n(old values)"
    t2_calc -> rotation: "then assign\n(canonical order)"
  }
  step4: {
    style.fill: "#D4F0D4"
    style.font: mono
    label: "H[0]+=a  H[1]+=b  H[2]+=c  H[3]+=d\nH[4]+=e  H[5]+=f  H[6]+=g  H[7]+=h\n// += not = : Merkle-Damgård chaining\n// mod 2³² automatic via uint32_t"
  }
  sig -> step1
  step1 -> step2
  step2 -> step3
  step3 -> step4
}

# ── H[8] annotation ───────────────────────────────────────────────────────
h_state: "H[8] — Hash State" {
  style.fill: "#EDE9FE"
  style.stroke: "#7C3AED"
  style.border-radius: 6
  label: "uint32_t H[8]\n32 bytes · caller owns\n\nEntry: initial values (M4 init)\n  OR prior block output\nExit:  H[i] += workingVar[i]\n       ∀i ∈ [0..7]  mod 2³²\n\n⚠️  Modified IN PLACE\n    Alias-free from W[64]"
}

# ── W[64] annotation ──────────────────────────────────────────────────────
w_array: "W[64] — Message Schedule" {
  style.fill: "#FEF3C7"
  style.stroke: "#B45309"
  style.border-radius: 6
  label: "uint32_t W[64]\n256 bytes · stack-local\n\nW[0..15]  : block[t×4..t×4+3] big-endian\nW[16..63] : σ1(W[t-2])+W[t-7]\n            +σ0(W[t-15])+W[t-16]\n\nRead-only after schedule call\nFreed on sha256_compress() return"
}

# ── Connections ────────────────────────────────────────────────────────────
m2.rotr32 -> macros.su0: "imported\n(#include)" {style.stroke-dash: 4; style.stroke: "#4A90D9"}
m2.rotr32 -> macros.su1: "imported" {style.stroke-dash: 4; style.stroke: "#4A90D9"}
m2.shr32 -> macros.su0: "imported" {style.stroke-dash: 4; style.stroke: "#4A90D9"}
m2.schedule_fn -> compress.step1: "called\ninternally" {style.stroke: "#16A34A"; style.stroke-width: 2}
k_array -> compress.step3.t1_calc: "K[t] per\nround" {style.stroke: "#8B5CF6"; style.stroke-width: 2}
macros.su0 -> compress.step3.t2_calc: "T2 term\nΣ0(a)" {style.stroke: "#D97706"}
macros.su1 -> compress.step3.t1_calc: "T1 term\nΣ1(e)" {style.stroke: "#D97706"}
macros.ch -> compress.step3.t1_calc: "T1 term\nCh(e,f,g)" {style.stroke: "#D97706"}
macros.maj -> compress.step3.t2_calc: "T2 term\nMaj(a,b,c)" {style.stroke: "#D97706"}
h_state -> compress.sig: "in: H_old[0..7]\ninitialize a..h" {style.stroke: "#7C3AED"; style.stroke-width: 2}
compress.step4 -> h_state: "out: H[i] += wv[i]\nIN-PLACE UPDATE" {
  style.stroke: "#7C3AED"
  style.stroke-width: 2
  target-arrowhead.shape: arrow
}
compress.step1 -> w_array: "fills W[64]\nstack-local" {style.stroke: "#B45309"}
w_array -> compress.step3.t1_calc: "W[t] per\nround" {style.stroke: "#B45309"}

# ── Test vector annotation ─────────────────────────────────────────────────
nist_check: {
  label: ||md
    **Acceptance: NIST "abc" Test Vector**
    Input `H[0..7]` = SHA-256 initial values
    After `sha256_compress(H, abc_block)`:
    
    H[0] = 0xba7816bf   H[4] = 0xb00361a3
    H[1] = 0x8f01cfea   H[5] = 0x96177a9c
    H[2] = 0x414140de   H[6] = 0xb410ff61
    H[3] = 0x5dae2223   H[7] = 0xf20015ad
    
    = SHA-256("abc") final digest ✓
    Debug: `sha256_compress_debug()` prints
    T1, T2, a, e after each of 64 rounds
    for comparison vs NIST Example PDF
  ||
  near: bottom-center
  style.fill: "#F0FFF0"
  style.stroke: "#16A34A"
  style.border-radius: 6
}