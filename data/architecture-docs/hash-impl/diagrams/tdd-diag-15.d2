vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
title: |md
  ## Ch(x, y, z) = (x AND y) XOR (NOT x AND z)
  **Bitwise Multiplexer — Single Bit Position Analysis**
| {near: top-center}
formula: {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#7b68ee"
    stroke-width: 3
    border-radius: 8
    font-color: white
  }
  label: |md
    **FIPS 180-4 §4.1.2, Equation (4.2)**
    `Ch(x, y, z) = (x AND y) XOR (NOT x AND z)`
    Ternary reading: `x ? y : z` (applied bit-by-bit)
    Nonlinear cross-term: output contains **xy** (AND of two inputs)
    → cannot be expressed as `ax ⊕ by ⊕ cz` for any constants a, b, c
  |
}
table_header: {
  shape: rectangle
  style: {
    fill: "#2d2d2d"
    stroke: "#888888"
    stroke-width: 2
    border-radius: 4
    font-color: "#ffffff"
    bold: true
    font-size: 13
  }
  label: "  x  │  y  │  z  │ x AND y │ NOT x AND z │  Ch  │  Interpretation  "
}
