legend_x0: "x = 0 rows: output follows z (blue/green)" {
  shape: rectangle
  style: {
    fill: "#1a2a3a"
    stroke: "#1e5f8a"
    stroke-width: 2
    border-radius: 6
    font-color: "#87ceeb"
    font-size: 12
  }
}
