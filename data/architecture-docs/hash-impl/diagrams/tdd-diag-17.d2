row_s1_fn: "σ1 (x)" {
  style.fill: "#1e3a5f"
  style.font-color: "#7EC8E3"
  style.bold: true
  style.font-size: 16
  width: 120
}
row_s1_domain: {
  label: |'md
    **Message Schedule**
    Applied to W[t−2]
    FIPS §4.1.2 Eq.(4.7)
  '|
  style.fill: "#1e3a5f"
  style.font-color: "#FFD700"
  style.font-size: 13
  style.stroke: "#FFD700"
  style.stroke-width: 2
  width: 200
}
row_s1_formula: {
  label: |'md
    `ROTR¹⁷(x) ⊕ ROTR¹⁹(x) ⊕ SHR¹⁰(x)`
    `((x>>17)|(x<<15)) ^ ((x>>19)|(x<<13)) ^ (x>>10)`
  '|
  style.fill: "#1e3a5f"
  style.font-color: "#E0E0E0"
  style.font-size: 13
  width: 380
}
row_s1_consts: {
  label: |'md
    **ROTR: 17, 19**
    **SHR: 10**
  '|
  style.fill: "#1e3a5f"
  style.font-color: "#7EC8E3"
  style.font-size: 13
  width: 200
}
row_s1_shr: "✔ YES\nSHR(x,10) drops bits" {
  style.fill: "#5a1a1a"
  style.font-color: "#FF6B6B"
  style.bold: true
  style.font-size: 13
  style.stroke: "#FF4444"
  style.stroke-width: 2
  width: 160
}

# ── Divider ────────────────────────────────────────────────────────────────
divider: "BOUNDARY: MESSAGE SCHEDULE (σ) vs COMPRESSION STATE (Σ)" {
  style.fill: "#2d2d2d"
  style.font-color: "#888888"
  style.font-size: 12
  style.italic: true
  width: 1060
}

# ── Σ0 row ─────────────────────────────────────────────────────────────────
row_S0_fn: "Σ0 (x)" {
  style.fill: "#1a3a1a"
  style.font-color: "#90EE90"
  style.bold: true
  style.font-size: 16
  width: 120
}
row_S0_domain: {
  label: |'md
    **Round Compression**
    Applied to working var **a**
    FIPS §4.1.2 Eq.(4.4)
  '|
  style.fill: "#1a3a1a"
  style.font-color: "#FF6B6B"
  style.font-size: 13
  style.stroke: "#FF4444"
  style.stroke-width: 2
  width: 200
}
row_S0_formula: {
  label: |'md
    `ROTR²(x) ⊕ ROTR¹³(x) ⊕ ROTR²²(x)`
    `((x>>2)|(x<<30)) ^ ((x>>13)|(x<<19)) ^ ((x>>22)|(x<<10))`
  '|
  style.fill: "#1a3a1a"
  style.font-color: "#E0E0E0"
  style.font-size: 13
  width: 380
}
row_S0_consts: {
  label: |'md
    **ROTR: 2, 13, 22**
    *(Pure rotation)*
  '|
  style.fill: "#1a3a1a"
  style.font-color: "#90EE90"
  style.font-size: 13
  width: 200
}
row_S0_shr: "✘ NO\nAll entropy preserved" {
  style.fill: "#1a3a1a"
  style.font-color: "#90EE90"
  style.bold: true
  style.font-size: 13
  style.stroke: "#90EE90"
  style.stroke-width: 2
  width: 160
}

# ── Σ1 row ─────────────────────────────────────────────────────────────────
row_S1_fn: "Σ1 (x)" {
  style.fill: "#1a3a1a"
  style.font-color: "#90EE90"
  style.bold: true
  style.font-size: 16
  width: 120
}
row_S1_domain: {
  label: |'md
    **Round Compression**
    Applied to working var **e**
    FIPS §4.1.2 Eq.(4.5)
  '|
  style.fill: "#1a3a1a"
  style.font-color: "#FF6B6B"
  style.font-size: 13
  style.stroke: "#FF4444"
  style.stroke-width: 2
  width: 200
}
row_S1_formula: {
  label: |'md
    `ROTR⁶(x) ⊕ ROTR¹¹(x) ⊕ ROTR²⁵(x)`
    `((x>>6)|(x<<26)) ^ ((x>>11)|(x<<21)) ^ ((x>>25)|(x<<7))`
  '|
  style.fill: "#1a3a1a"
  style.font-color: "#E0E0E0"
  style.font-size: 13
  width: 380
}
row_S1_consts: {
  label: |'md
    **ROTR: 6, 11, 25**
    *(Pure rotation)*
  '|
  style.fill: "#1a3a1a"
  style.font-color: "#90EE90"
  style.font-size: 13
  width: 200
}
row_S1_shr: "✘ NO\nAll entropy preserved" {
  style.fill: "#1a3a1a"
  style.font-color: "#90EE90"
  style.bold: true
  style.font-size: 13
  style.stroke: "#90EE90"
  style.stroke-width: 2
  width: 160
}

# ── Memory Aid Footer ────────────────────────────────────────────────────────
memory_aid: {
  label: |'md
    ### 🧠 Implementation Cheat-Sheet
    *   **σ (sigma)**: Message Schedule (Lowercase looks like a 'w' or part of it). Used for W expansion. Includes SHR.
    *   **Σ (Sigma)**: State Compression (Uppercase is 'State'). Used in round loops. No SHR allowed.
    *   **Index trick**: σ0 uses 7/18/3. Σ0 uses 2/13/22. Swap these and your hash will fail all NIST vectors.
  '|
  near: bottom-center
  style.fill: "#1a1a1a"
  style.font-color: "#E0E0E0"
  style.stroke: "#888888"
  style.stroke-dash: 3
  width: 900
}

danger_box: {
  label: "⚠️ DANGER: DO NOT SWAP σ AND Σ CONSTANTS"
  near: top-right
  style.fill: "#3a0000"
  style.font-color: "#FF6B6B"
  style.stroke: "#FF4444"
  style.bold: true
}

# ── Layout Grid Logic ────────────────────────────────────────────────────────
hdr_fn -> hdr_domain -> hdr_formula -> hdr_consts -> hdr_shr: { style.stroke: transparent }
hdr_fn -> row_s0_fn -> row_s1_fn -> divider -> row_S0_fn -> row_S1_fn: { style.stroke: transparent }
hdr_domain -> row_s0_domain -> row_s1_domain -> row_S0_domain -> row_S1_domain: { style.stroke: transparent }
hdr_formula -> row_s0_formula -> row_s1_formula -> row_S0_formula -> row_S1_formula: { style.stroke: transparent }
hdr_consts -> row_s0_consts -> row_s1_consts -> row_S0_consts -> row_S1_consts: { style.stroke: transparent }
hdr_shr -> row_s0_shr -> row_s1_shr -> row_S0_shr -> row_S1_shr: { style.stroke: transparent }