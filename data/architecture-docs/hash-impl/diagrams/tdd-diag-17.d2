layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: {
  label: |'md
    ## SHA-256 Sigma Functions: Σ0, Σ1, σ0, σ1
    **Comparison Table for Implementation Validation**
  '|
  near: top-center
  style.font-size: 18
}

# ── Column headers ────────────────────────────────────────────────────────────
hdr_fn: "Function" {
  style.fill: "#1a1a2e"
  style.font-color: white
  style.bold: true
  style.font-size: 15
  width: 120
}
hdr_domain: "Purpose" {
  style.fill: "#1a1a2e"
  style.font-color: white
  style.bold: true
  style.font-size: 15
  width: 200
}
hdr_formula: "Implementation Formula" {
  style.fill: "#1a1a2e"
  style.font-color: white
  style.bold: true
  style.font-size: 15
  width: 380
}
hdr_consts: "Shift Constants" {
  style.fill: "#1a1a2e"
  style.font-color: white
  style.bold: true
  style.font-size: 15
  width: 200
}
hdr_shr: "Data Loss (SHR)?" {
  style.fill: "#8B0000"
  style.font-color: white
  style.bold: true
  style.font-size: 15
  width: 160
  style.stroke: "#FF4444"
  style.stroke-width: 3
}

# ── σ0 row ─────────────────────────────────────────────────────────────────
row_s0_fn: "σ0 (x)" {
  style.fill: "#1e3a5f"
  style.font-color: "#7EC8E3"
  style.bold: true
  style.font-size: 16
  width: 120
}
row_s0_domain: {
  label: |'md
    **Message Schedule**
    Applied to W[t−15]
    FIPS §4.1.2 Eq.(4.6)
  '|
  style.fill: "#1e3a5f"
  style.font-color: "#FFD700"
  style.font-size: 13
  style.stroke: "#FFD700"
  style.stroke-width: 2
  width: 200
}
row_s0_formula: {
  label: |'md
    `ROTR⁷(x) ⊕ ROTR¹⁸(x) ⊕ SHR³(x)`
    `((x>>7)|(x<<25)) ^ ((x>>18)|(x<<14)) ^ (x>>3)`
  '|
  style.fill: "#1e3a5f"
  style.font-color: "#E0E0E0"
  style.font-size: 13
  width: 380
}
row_s0_consts: {
  label: |'md
    **ROTR: 7, 18**
    **SHR: 3**
  '|
  style.fill: "#1e3a5f"
  style.font-color: "#7EC8E3"
  style.font-size: 13
  width: 200
}
row_s0_shr: "✔ YES\nSHR(x,3) drops bits" {
  style.fill: "#5a1a1a"
  style.font-color: "#FF6B6B"
  style.bold: true
  style.font-size: 13
  style.stroke: "#FF4444"
  style.stroke-width: 2
  width: 160
}

