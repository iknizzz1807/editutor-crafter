vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  ## SHA-256 Working Variable State Machine: 64-Round Evolution ('abc' Block)
  Each round: only **a** and **e** receive computed values. All others shift down by one position.
| {near: top-center}
# ── Legend ────────────────────────────────────────────────────────────────
legend: {
  near: bottom-left
  style.fill: "#1a1a2e"
  style.stroke: "#7c3aed"
  style.border-radius: 8
  l1: "● INITIAL STATE  — H[i] loaded from SHA256_INITIAL_HASH (sqrt of primes)" {
    shape: text
    style.font-color: "#a78bfa"
    style.font-size: 12
  }
  l2: "● COMPUTED INJECTION — a = T1+T2, e = d+T1 (only two variables with new values)" {
    shape: text
    style.font-color: "#f472b6"
    style.font-size: 12
  }
  l3: "● SHIFT ONLY — b←a, c←b, d←c, f←e, g←f, h←g (six variables just propagate)" {
    shape: text
    style.font-color: "#60a5fa"
    style.font-size: 12
  }
  l4: "● FINAL PRE-UPDATE — a..h values after round 63, before H[i] += step" {
    shape: text
    style.font-color: "#34d399"
    style.font-size: 12
  }
}
# ── PHASE 0: Initial State ─────────────────────────────────────────────────
phase0: "PHASE 0\nINITIALIZATION" {
  style.fill: "#2d1b69"
  style.stroke: "#7c3aed"
  style.stroke-width: 3
  style.border-radius: 8
  init_label: |md
    **Step 2 of sha256_compress():**
    Copy H[0..7] → working variables a..h
    Source: SHA256_INITIAL_HASH (frac(√prime) × 2³²)
  | {style.font-size: 11; style.font-color: "#c4b5fd"}
  init_vars: {
    style.fill: "#1e1b4b"
    style.stroke: "#4c1d95"
    style.border-radius: 6
    a0: "a = H[0] = **0x6a09e667**\n(frac(√2) × 2³²)" {
      style.fill: "#4c1d95"; style.stroke: "#7c3aed"
      style.font-color: "#e9d5ff"; style.font-size: 11
    }
    b0: "b = H[1] = **0xbb67ae85**\n(frac(√3) × 2³²)" {
      style.fill: "#1e3a5f"; style.stroke: "#2563eb"
      style.font-color: "#bfdbfe"; style.font-size: 11
    }
    c0: "c = H[2] = **0x3c6ef372**\n(frac(√5) × 2³²)" {
      style.fill: "#1e3a5f"; style.stroke: "#2563eb"
      style.font-color: "#bfdbfe"; style.font-size: 11
    }
    d0: "d = H[3] = **0xa54ff53a**\n(frac(√7) × 2³²)" {
      style.fill: "#1e3a5f"; style.stroke: "#2563eb"
      style.font-color: "#bfdbfe"; style.font-size: 11
    }
    e0: "e = H[4] = **0x510e527f**\n(frac(√11) × 2³²)" {
      style.fill: "#4c1d95"; style.stroke: "#7c3aed"
      style.font-color: "#e9d5ff"; style.font-size: 11
    }
    f0: "f = H[5] = **0x9b05688c**\n(frac(√13) × 2³²)" {
      style.fill: "#1e3a5f"; style.stroke: "#2563eb"
      style.font-color: "#bfdbfe"; style.font-size: 11
    }
    g0: "g = H[6] = **0x1f83d9ab**\n(frac(√17) × 2³²)" {
      style.fill: "#1e3a5f"; style.stroke: "#2563eb"
      style.font-color: "#bfdbfe"; style.font-size: 11
    }
    h0: "h = H[7] = **0x5be0cd19**\n(frac(√19) × 2³²)" {
      style.fill: "#1e3a5f"; style.stroke: "#2563eb"
      style.font-color: "#bfdbfe"; style.font-size: 11
    }
  }
}
# ── PHASE 1: Round 0 (first round, fully traced) ───────────────────────────
phase1: "PHASE 1\nROUND t=0 (FULLY TRACED)" {
  style.fill: "#1a1a2e"
  style.stroke: "#f472b6"
  style.stroke-width: 3
  style.border-radius: 8
  r0_inputs: "Round 0 Inputs from Message Schedule" {
    style.fill: "#2d1b69"; style.stroke: "#7c3aed"; style.border-radius: 6
    w0: "W[0] = 0x61626380\n('abc' + 0x80 big-endian word)" {
      style.fill: "#1a1a2e"; style.stroke: "#f59e0b"
      style.font-color: "#fef3c7"; style.font-size: 11
    }
    k0: "K[0] = 0x428a2f98\n(floor(frac(∛2) × 2³²))" {
      style.fill: "#1a1a2e"; style.stroke: "#f59e0b"
      style.font-color: "#fef3c7"; style.font-size: 11
    }
  }
  r0_compute: "Round 0 Computation" {
    style.fill: "#1e1b4b"; style.stroke: "#4c1d95"; style.border-radius: 6
    t1_formula: "T1 = h + Σ1(e) + Ch(e,f,g) + K[0] + W[0]" {
      shape: text; style.font-color: "#f472b6"
      style.font-size: 12; style.bold: true
    }
    t2_formula: "T2 = Σ0(a) + Maj(a,b,c)" {
      shape: text; style.font-color: "#f472b6"
      style.font-size: 12; style.bold: true
    }
    t1_val: "T1 = 0x5be0cd19 + Σ1(0x510e527f) + Ch(0x510e527f, 0x9b05688c, 0x1f83d9ab)\n     + 0x428a2f98 + 0x61626380\n→ T1 computes to specific 32-bit value (see NIST appendix)" {
      style.fill: "#0f172a"; style.stroke: "#475569"
      style.font-color: "#94a3b8"; style.font-size: 10
    }
    t2_val: "T2 = Σ0(0x6a09e667) + Maj(0x6a09e667, 0xbb67ae85, 0x3c6ef372)\n→ T2 computes to specific 32-bit value (see NIST appendix)" {
      style.fill: "#0f172a"; style.stroke: "#475569"
      style.font-color: "#94a3b8"; style.font-size: 10
    }
  }
  r0_assign: "Round 0 Assignments — THE CRITICAL ORDER" {
    style.fill: "#1e1b4b"; style.stroke: "#4c1d95"; style.border-radius: 6
    shift_chain: |md
      **Six variables shift (NO computation):**
      h ← g   (old g = 0x1f83d9ab)
      g ← f   (old f = 0x9b05688c)
      f ← e   (old e = 0x510e527f)
      d ← c   (old c = 0x3c6ef372)
      c ← b   (old b = 0xbb67ae85)
      b ← a   (old a = 0x6a09e667)
    | {style.font-size: 11; style.font-color: "#93c5fd"}
    inject_a: "**NEW a = T1 + T2** ← COMPUTED INJECTION\n(carries message data W[0] and structure T2)" {
      style.fill: "#4c1d95"; style.stroke: "#a855f7"; style.stroke-width: 2
      style.font-color: "#e9d5ff"; style.font-size: 11
    }
    inject_e: "**NEW e = d + T1** ← COMPUTED INJECTION\n(d = old d = 0xa54ff53a, T1 includes W[0])\nNOTE: e = d + T1 only — NOT d + T1 + T2" {
      style.fill: "#4c1d95"; style.stroke: "#a855f7"; style.stroke-width: 2
      style.font-color: "#e9d5ff"; style.font-size: 11
    }
  }
}
# ── PHASE 2: Rounds 1-15 (schedule uses only original block words) ─────────
phase2: "PHASE 2\nROUNDS t=1..15 (W FROM PARSED BLOCK WORDS)" {
  style.fill: "#1a1a2e"
  style.stroke: "#60a5fa"
  style.stroke-width: 2
  style.border-radius: 8
  r1_15_note: |md
    **Rounds 1–15**: W[t] values come directly from block byte parsing (M2 Phase A).
    For the 'abc' block: W[1]..W[14] = 0x00000000 (all-zero padding bytes).
    W[15] = 0x00000018 (bit-length field = 24 bits, big-endian).
    **Pattern per round t:**
    - T1 = h_old + Σ1(e_old) + Ch(e_old, f_old, g_old) + K[t] + W[t]
    - T2 = Σ0(a_old) + Maj(a_old, b_old, c_old)
    - a_new = T1 + T2       ← ONLY injection point for 'a'
    - e_new = d_old + T1    ← ONLY injection point for 'e'
    - All others: b=a_old, c=b_old, d=c_old, f=e_old, g=f_old, h=g_old
    **State progresses through 8-deep shift register:**
    The 8 variables form a circular pipeline. After round t, the message
    data from W[t] has been mixed into 'a' and 'e'. By round 8, every
    variable has been touched by at least one injection.
  | {style.font-size: 11; style.font-color: "#93c5fd"}
  shift_invariant: "INVARIANT: b←a, c←b, d←c, f←e, g←f, h←g (every round, no exceptions)" {
    style.fill: "#1e3a5f"; style.stroke: "#2563eb"
    style.font-color: "#bfdbfe"; style.font-size: 12; style.bold: true
  }
}
# ── PHASE 3: Rounds 16-63 (schedule uses expanded words from recurrence) ──
phase3: "PHASE 3\nROUNDS t=16..63 (W FROM σ RECURRENCE EXPANSION)" {
  style.fill: "#1a1a2e"
  style.stroke: "#34d399"
  style.stroke-width: 2
  style.border-radius: 8
  r16_63_note: |md
    **Rounds 16–63**: W[t] = σ1(W[t-2]) + W[t-7] + σ0(W[t-15]) + W[t-16] mod 2³²
    For 'abc': W[16] = 0x61626380, W[17] = 0x000F0000, ... (see M2 schedule output)
    **By round 16**: W[16] re-injects the original message word 0x61626380 into
    the computation — the message data circulates through the schedule expansion.
    **Diffusion**: by round 48, every W[t] depends on every original W[0..15] word.
    Every round's 'a' and 'e' values carry the accumulated influence of all prior
    message words through the T1/T2 computation.
    **K constants**: K[16]..K[63] ensure each round behaves differently even if
    W values repeat. K[t] = floor(frac(∛prime_t) × 2³²) — "nothing up my sleeve."
  | {style.font-size: 11; style.font-color: "#6ee7b7"}
  diffusion_note: "After 64 rounds: every output bit depends on every input bit (avalanche achieved)" {
    style.fill: "#064e3b"; style.stroke: "#10b981"
    style.font-color: "#6ee7b7"; style.font-size: 12; style.bold: true
  }
}
# ── PHASE 4: Round 63 final state (pre-update) ────────────────────────────
phase4: "PHASE 4\nFINAL STATE AFTER ROUND 63 (PRE-UPDATE)" {
  style.fill: "#1a1a2e"
  style.stroke: "#34d399"
  style.stroke-width: 3
  style.border-radius: 8
  final_note: "For SHA-256('abc'): these are the working variable values after round 63, before H[i] += step" {
    shape: text; style.font-color: "#6ee7b7"; style.font-size: 11
  }
  final_vars: {
    style.fill: "#1e1b4b"; style.stroke: "#064e3b"; style.border-radius: 6
    af: "a (final)" { style.fill: "#4c1d95"; style.stroke: "#7c3aed"; style.font-color: "#e9d5ff"; style.font-size: 11 }
    bf: "b (final)" { style.fill: "#1e3a5f"; style.stroke: "#2563eb"; style.font-color: "#bfdbfe"; style.font-size: 11 }
    cf: "c (final)" { style.fill: "#1e3a5f"; style.stroke: "#2563eb"; style.font-color: "#bfdbfe"; style.font-size: 11 }
    df: "d (final)" { style.fill: "#1e3a5f"; style.stroke: "#2563eb"; style.font-color: "#bfdbfe"; style.font-size: 11 }
    ef: "e (final)" { style.fill: "#4c1d95"; style.stroke: "#7c3aed"; style.font-color: "#e9d5ff"; style.font-size: 11 }
    ff: "f (final)" { style.fill: "#1e3a5f"; style.stroke: "#2563eb"; style.font-color: "#bfdbfe"; style.font-size: 11 }
    gf: "g (final)" { style.fill: "#1e3a5f"; style.stroke: "#2563eb"; style.font-color: "#bfdbfe"; style.font-size: 11 }
    hf: "h (final)" { style.fill: "#1e3a5f"; style.stroke: "#2563eb"; style.font-color: "#bfdbfe"; style.font-size: 11 }
  }
}
# ── PHASE 5: State Update (Step 4 of sha256_compress) ─────────────────────
phase5: "PHASE 5\nSTEP 4: HASH STATE UPDATE (DAVIES-MEYER FEED-FORWARD)" {
  style.fill: "#1a1a2e"
  style.stroke: "#f59e0b"
  style.stroke-width: 3
  style.border-radius: 8
  update_formula: |md
    **H[i] += working_var[i]  (mod 2³²)  for i = 0..7**
    H[0] += a    H[1] += b    H[2] += c    H[3] += d
    H[4] += e    H[5] += f    H[6] += g    H[7] += h
    **WHY += and NOT =:**
    The additive fold is the Davies-Meyer feed-forward. Without it, an attacker
    controlling the last block controls the entire hash. With +=, every prior
    block's H_old[i] is permanently baked in — changing any block changes H_old,
    which cascades into every subsequent H value.
    **THE SINGLE MOST IMPACTFUL CHARACTER IN THIS MODULE: '+' in '+='**
  | {style.font-color: "#fef3c7"; style.font-size: 11}
  result_abc: "FOR SHA-256('abc') — FINAL H[0..7] (= NIST test vector output):" {
    style.fill: "#78350f"; style.stroke: "#f59e0b"
    style.font-color: "#fef3c7"; style.font-size: 12; style.bold: true
  }
  digest_words: {
    style.fill: "#1c1917"; style.stroke: "#78350f"; style.border-radius: 6
    h0r: "H[0] = 0xba7816bf" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
    h1r: "H[1] = 0x8f01cfea" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
    h2r: "H[2] = 0x414140de" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
    h3r: "H[3] = 0x5dae2223" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
    h4r: "H[4] = 0xb00361a3" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
    h5r: "H[5] = 0x96177a9c" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
    h6r: "H[6] = 0xb410ff61" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
    h7r: "H[7] = 0xf20015ad" { style.fill: "#292524"; style.stroke: "#78350f"; style.font-color: "#fef3c7"; style.font-size: 11 }
  }
  hex_string: "Concatenated big-endian bytes → 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'" {
    style.fill: "#064e3b"; style.stroke: "#10b981"
    style.font-color: "#6ee7b7"; style.font-size: 11; style.bold: true
    style.font: mono
  }
}
# ── VARIABLE ROLE TAXONOMY ──────────────────────────────────────────────────
roles: "WORKING VARIABLE ROLES (CONSTANT ACROSS ALL 64 ROUNDS)" {
  style.fill: "#1a1a2e"; style.stroke: "#6d28d9"; style.border-radius: 8
  role_a: "a\n← T1+T2\nINJECTION" {
    style.fill: "#4c1d95"; style.stroke: "#a855f7"; style.stroke-width: 3
    style.font-color: "#f5d0fe"; style.font-size: 12; style.bold: true
  }
  role_b: "b ← a\nSHIFT ONLY" {
    style.fill: "#1e3a5f"; style.stroke: "#3b82f6"
    style.font-color: "#bfdbfe"; style.font-size: 11
  }
  role_c: "c ← b\nSHIFT ONLY" {
    style.fill: "#1e3a5f"; style.stroke: "#3b82f6"
    style.font-color: "#bfdbfe"; style.font-size: 11
  }
  role_d: "d ← c\nSHIFT ONLY" {
    style.fill: "#1e3a5f"; style.stroke: "#3b82f6"
    style.font-color: "#bfdbfe"; style.font-size: 11
  }
  role_e: "e\n← d+T1\nINJECTION" {
    style.fill: "#4c1d95"; style.stroke: "#a855f7"; style.stroke-width: 3
    style.font-color: "#f5d0fe"; style.font-size: 12; style.bold: true
  }
  role_f: "f ← e\nSHIFT ONLY" {
    style.fill: "#1e3a5f"; style.stroke: "#3b82f6"
    style.font-color: "#bfdbfe"; style.font-size: 11
  }
  role_g: "g ← f\nSHIFT ONLY" {
    style.fill: "#1e3a5f"; style.stroke: "#3b82f6"
    style.font-color: "#bfdbfe"; style.font-size: 11
  }
  role_h: "h ← g\nSHIFT ONLY" {
    style.fill: "#1e3a5f"; style.stroke: "#3b82f6"
    style.font-color: "#bfdbfe"; style.font-size: 11
  }
}
# ── T1 T2 ANATOMY ───────────────────────────────────────────────────────────
t1t2: "T1 AND T2 ANATOMY (EVERY ROUND)" {
  style.fill: "#1a1a2e"; style.stroke: "#db2777"; style.border-radius: 8
  t1_anatomy: "T1 = h + Σ1(e) + Ch(e,f,g) + K[t] + W[t]" {
    style.fill: "#831843"; style.stroke: "#db2777"
    style.font-color: "#fce7f3"; style.font-size: 12; style.bold: true; style.font: mono
  }
  t1_breakdown: {
    style.fill: "#1a1a2e"; style.stroke: "#9d174d"; style.border-radius: 6
    t1_h: "h — current bottom-of-stack register" { style.font-color: "#f9a8d4"; shape: text; style.font-size: 11 }
    t1_s1: "Σ1(e) = ROTR(e,6)^ROTR(e,11)^ROTR(e,25) — diffusion of e" { style.font-color: "#f9a8d4"; shape: text; style.font-size: 11 }
    t1_ch: "Ch(e,f,g) = (e&f)^(~e&g) — nonlinear mux: e selects f or g" { style.font-color: "#f9a8d4"; shape: text; style.font-size: 11 }
    t1_k: "K[t] — round constant (cube root of t-th prime, frac × 2³²)" { style.font-color: "#fbbf24"; shape: text; style.font-size: 11 }
    t1_w: "W[t] — message schedule word (MESSAGE DATA ENTRY POINT)" { style.font-color: "#fbbf24"; shape: text; style.font-size: 11 }
  }
  t2_anatomy: "T2 = Σ0(a) + Maj(a,b,c)" {
    style.fill: "#831843"; style.stroke: "#db2777"
    style.font-color: "#fce7f3"; style.font-size: 12; style.bold: true; style.font: mono
  }
  t2_breakdown: {
    style.fill: "#1a1a2e"; style.stroke: "#9d174d"; style.border-radius: 6
    t2_s0: "Σ0(a) = ROTR(a,2)^ROTR(a,13)^ROTR(a,22) — diffusion of a" { style.font-color: "#f9a8d4"; shape: text; style.font-size: 11 }
    t2_maj: "Maj(a,b,c) = (a&b)^(a&c)^(b&c) — nonlinear majority vote" { style.font-color: "#f9a8d4"; shape: text; style.font-size: 11 }
    t2_note: "T2 has NO message data — structural diffusion only" { style.font-color: "#6ee7b7"; shape: text; style.font-size: 11 }
  }
}
# ── READ-AFTER-WRITE SAFETY ANNOTATION ────────────────────────────────────
raw_safety: "READ-AFTER-WRITE SAFETY: ASSIGNMENT ORDER IS LOAD-BEARING" {
  style.fill: "#1a1a2e"; style.stroke: "#ef4444"; style.border-radius: 8
  raw_note: |md
    **Correct order (in sha256_compress loop body):**
    
    T1 = h + Σ1(e) + Ch(e,f,g) + K[t] + W[t];   ← uses OLD a..h
    T2 = Σ0(a) + Maj(a,b,c);                      ← uses OLD a..h
    h = g;    g = f;    f = e;                     ← shift: reads old, writes new
    e = d + T1;                                    ← injection: e only, NOT d+T1+T2
    d = c;    c = b;    b = a;                     ← shift: reads old a before overwrite
    a = T1 + T2;                                   ← injection: MUST come AFTER b=a
    
    **Why T1,T2 computed first:** they use OLD values of a..h.
    C evaluates RHS fully before assignment — safe as written.
    **Never reorder `b=a` to after `a=T1+T2`** — b would get the NEW a.
  | {style.font-size: 11; style.font-color: "#fca5a5"}
  trap_e: "TRAP: e = d + T1  (NOT d + T1 + T2) — T2 goes only to 'a'" {
    style.fill: "#450a0a"; style.stroke: "#ef4444"
    style.font-color: "#fca5a5"; style.font-size: 12; style.bold: true
  }
  trap_a: "TRAP: a = T1 + T2 (NOT just T2) — T1 carries the message input" {
    style.fill: "#450a0a"; style.stroke: "#ef4444"
    style.font-color: "#fca5a5"; style.font-size: 12; style.bold: true
  }
}
# ── CONNECTIONS ─────────────────────────────────────────────────────────────
phase0 -> phase1: "initialize a..h\nfrom H[0..7]" {
  style.stroke: "#7c3aed"; style.stroke-width: 2; style.font-color: "#c4b5fd"
}
phase1 -> phase2: "round 0 complete\na,e injected\nb,c,d,f,g,h shifted" {
  style.stroke: "#f472b6"; style.stroke-width: 2; style.font-color: "#f9a8d4"
}
phase2 -> phase3: "rounds 1-15 complete\nW from parsed block\n(W[1..14]=0, W[15]=0x18)" {
  style.stroke: "#60a5fa"; style.stroke-width: 2; style.font-color: "#93c5fd"
}
phase3 -> phase4: "rounds 16-63 complete\nW from σ recurrence\nfull diffusion achieved" {
  style.stroke: "#34d399"; style.stroke-width: 2; style.font-color: "#6ee7b7"
}
phase4 -> phase5: "read final a..h\napply H[i] += step\n(Davies-Meyer feed-forward)" {
  style.stroke: "#f59e0b"; style.stroke-width: 3; style.font-color: "#fbbf24"
}
roles -> t1t2: "T1+T2 drive the\ninjection points" {
  style.stroke: "#db2777"; style.stroke-dash: 4; style.font-color: "#f9a8d4"
}
t1t2 -> raw_safety: "assignment order\nmust respect\nread-before-write" {
  style.stroke: "#ef4444"; style.stroke-dash: 4; style.font-color: "#fca5a5"
}
phase1 -> roles: "role assignment\nidentical every round" {
  style.stroke: "#7c3aed"; style.stroke-dash: 3; style.font-color: "#c4b5fd"
}