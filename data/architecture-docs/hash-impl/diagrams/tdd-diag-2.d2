vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Memory Layout: sha256_padded_t — Two-Block Example (56-byte input)
  **FIPS 180-4 §5.1.1** · Total: 128 bytes · 2 blocks × 64 bytes
| {near: top-center}

# ── STRUCT WRAPPER ────────────────────────────────────────────────────────────
struct: sha256_padded_t {
  style.fill: "#1a1a2e"
  style.stroke: "#9b59b6"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#e8e8f0"

  size_note: |md
    sizeof = 128 bytes (data) + sizeof(size_t)
    Stack-allocated · No heap · Flat contiguous array
  | {
    style.fill: "#2d2d44"
    style.stroke: "#6c3483"
    style.font-color: "#c8c8e0"
    style.border-radius: 4
  }

  # ── BLOCK 0 ──────────────────────────────────────────────────────────────
  block0: "Block 0  [bytes 0x00–0x3F  |  0–63]" {
    style.fill: "#0d1b2a"
    style.stroke: "#2980b9"
    style.stroke-width: 2
    style.border-radius: 4
    style.font-color: "#85c1e9"

    msg_field: |md
      **bytes 0x00–0x37  (0–55)**
      Field: Message bytes (verbatim copy)
      Size: 56 bytes
      Value: original input data
      Color: 🟦 Data
      FIPS: §5.1.1 step 1
    | {
      style.fill: "#1a3a5c"
      style.stroke: "#2980b9"
      style.font-color: "#aed6f1"
      style.border-radius: 3
    }

    marker_field: |md
      **byte 0x38  (56)**
      Field: Padding marker
      Size: 1 byte
      Value: 0x80  =  1000 0000₂
      "1 bit" separator (MSB=1, rest=0)
      Color: 🟪 Header/Control
      FIPS: §5.1.1 step 2
    | {
      style.fill: "#4a235a"
      style.stroke: "#9b59b6"
      style.font-color: "#d2b4de"
      style.border-radius: 3
    }

    zerofill0_field: |md
      **bytes 0x39–0x3F  (57–63)**
      Field: Zero fill — partial (block 0)
      Size: 7 bytes
      Value: 0x00 × 7
      Insufficient space for 8-byte length field
      → overflows to Block 1
      Color: ⬜ Padding
      FIPS: §5.1.1 step 3  (k zero bits)
    | {
      style.fill: "#1e2d1e"
      style.stroke: "#27ae60"
      style.font-color: "#a9dfbf"
      style.border-radius: 3
    }

    msg_field -> marker_field: "len=56\noffset 56"
    marker_field -> zerofill0_field: "7 bytes remain\n< 8 needed"
  }

  # ── BLOCK 1 ──────────────────────────────────────────────────────────────
  block1: "Block 1  [bytes 0x40–0x7F  |  64–127]" {
    style.fill: "#0d1b2a"
    style.stroke: "#e67e22"
    style.stroke-width: 2
    style.border-radius: 4
    style.font-color: "#f0b27a"

    zerofill1_field: |md
      **bytes 0x40–0x77  (64–119)**
      Field: Zero fill — continuation (block 1)
      Size: 56 bytes
      Value: 0x00 × 56
      Color: ⬜ Padding
      FIPS: §5.1.1 step 3  (k zero bits cont.)
    | {
      style.fill: "#1e2d1e"
      style.stroke: "#27ae60"
      style.font-color: "#a9dfbf"
      style.border-radius: 3
    }

    length_field: |md
      **bytes 0x78–0x7F  (120–127)**
      Field: 64-bit big-endian length field
      Size: 8 bytes  (mandatory slot)
      Value: bit_length = 56 × 8 = 448 = 0x01C0
      ┌─────────────────────────────────┐
      │ 0x78: 0x00  (L >> 56)          │
      │ 0x79: 0x00  (L >> 48)          │
      │ 0x7A: 0x00  (L >> 40)          │
      │ 0x7B: 0x00  (L >> 32)          │
      │ 0x7C: 0x00  (L >> 24)          │
      │ 0x7D: 0x00  (L >> 16)          │
      │ 0x7E: 0x01  (L >>  8)  ← MSB  │
      │ 0x7F: 0xC0  (L >>  0)  ← LSB  │
      └─────────────────────────────────┘
      Big-endian: write_be64(buf+120, 448)
      NOT memcpy — x86 is little-endian!
      Color: 🟠 Pointer/Length (orange)
      FIPS: §5.1.1 step 4  "64-bit repr of l"
    | {
      style.fill: "#4a2e00"
      style.stroke: "#e67e22"
      style.font-color: "#fad7a0"
      style.border-radius: 3
    }

    zerofill1_field -> length_field: "56 bytes → 8 bytes\ntotal block = 64 ✓"
  }

  # ── num_blocks FIELD ─────────────────────────────────────────────────────
  num_blocks_field: |md
    **num_blocks  (at offset sizeof(data) = 128)**
    Type: size_t  ·  Size: 8 bytes (64-bit)
    Value: 2  =  total_padded(128) / SHA256_BLOCK_SIZE(64)
    Set by: sha256_pad() Step 7
    Used by: compression loop bound  `i < padded->num_blocks`
    Color: 🟠 Metadata
  | {
    style.fill: "#3d2700"
    style.stroke: "#e67e22"
    style.font-color: "#fdebd0"
    style.border-radius: 3
  }

  block0 -> block1: "overflow\n56+1=57 > 56\n→ 2nd block needed" {
    style.stroke: "#e74c3c"
    style.stroke-width: 2
    style.stroke-dash: 4
    style.font-color: "#e74c3c"
    style.bold: true
  }

  block1 -> num_blocks_field: "total_padded=128\n÷ 64 = 2 blocks" {
    style.stroke: "#e67e22"
    style.stroke-dash: 3
    style.font-color: "#e67e22"
  }
}

# ── FORMULA BOX ──────────────────────────────────────────────────────────────
formula: |md
  **Padding Length Formula (Step 5)**
  used         = len + 1  =  56 + 1  =  57
  total_padded = ⌈(used + 8) / 64⌉ × 64
               = ⌈(57 + 8) / 64⌉ × 64
               = ⌈65 / 64⌉ × 64
               = 2 × 64  =  **128 bytes**

  **Boundary Rule:**
  len ≤ 55  →  1 block   (55+1+0+8 = 64)
  len ≥ 56  →  2 blocks  (56+1+7+56+8 = 128)
| {
  near: bottom-center
  style.fill: "#1a1a1a"
  style.stroke: "#7d3c98"
  style.stroke-width: 2
  style.font-color: "#d2b4de"
  style.border-radius: 5
}

# ── sha256_get_block() ACCESSOR ───────────────────────────────────────────────
accessor: |md
  **sha256_get_block(padded, i)**
  Returns: padded→data + (i × 64)
  Block 0: &data[0]    = 0x000 offset
  Block 1: &data[64]   = 0x040 offset
  O(1) pointer arithmetic · no copy · cache-line aligned
| {
  near: bottom-left
  style.fill: "#1a1a2e"
  style.stroke: "#2980b9"
  style.font-color: "#85c1e9"
  style.border-radius: 4
}

# ── COLOR LEGEND ─────────────────────────────────────────────────────────────
legend: |md
  **Color Legend**
  🟦 Blue    = Data (message bytes)
  🟪 Purple  = Control (0x80 marker)
  ⬜ Green   = Zero padding / Free
  🟠 Orange  = Length field / Metadata
| {
  near: bottom-right
  style.fill: "#1a1a1a"
  style.stroke: "#555555"
  style.font-color: "#cccccc"
  style.border-radius: 4
}