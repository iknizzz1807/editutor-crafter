vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Feed-Forward State Update: Why `+=` Not `=`
  **FIPS 180-4 §6.2.2 Step 4 — Davies-Meyer Construction**
| {near: top-center}

# ─── BEFORE: Inputs to Step 4 ───────────────────────────────────────────
before: "BEFORE Step 4  (end of 64 rounds)" {
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a8a"
  style.border-radius: 8
  style.font-color: white

  H_state: "H[0..7]  — Prior Block State" {
    style.fill: "#2d2d6b"
    style.stroke: "#6060c0"
    style.font-color: "#c0c8ff"
    style.bold: true
    h0: "H[0] = 0x6a09e667" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
    h1: "H[1] = 0xbb67ae85" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
    h2: "H[2] = 0x3c6ef372" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
    h3: "H[3] = 0xa54ff53a" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
    h4: "H[4] = 0x510e527f" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
    h5: "H[5] = 0x9b05688c" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
    h6: "H[6] = 0x1f83d9ab" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
    h7: "H[7] = 0x5be0cd19" { style.fill: "#3a3a80"; style.font-color: "#aab0ff"; style.font: mono }
  }

  wv_state: "a..h  — 64-Round Output" {
    style.fill: "#1a3a1a"
    style.stroke: "#40a040"
    style.font-color: "#80e080"
    wa: "a  = 0x4f434152" { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
    wb: "b  = 0x..." { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
    wc: "c  = 0x..." { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
    wd: "d  = 0x..." { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
    we: "e  = 0x..." { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
    wf: "f  = 0x..." { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
    wg: "g  = 0x..." { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
    wh: "h  = 0x..." { style.fill: "#204020"; style.font-color: "#90e890"; style.font: mono }
  }

  note_before: |md
    **Working vars** a..h
    hold the compression
    output of block i
    — derived from
    H_old + 64 rounds
    over W[0..63]
  | { style.fill: "#111128"; style.font-color: "#8888cc" }
}

# ─── TWO PATHS ───────────────────────────────────────────────────────────

path_wrong: "PATH A  (WRONG)  H[i] = working_var[i]" {
  style.fill: "#2d0a0a"
  style.stroke: "#cc2020"
  style.border-radius: 8
  style.font-color: "#ff8080"

  op_wrong: "H[i]  =  working_var[i]" {
    style.fill: "#4a0a0a"
    style.stroke: "#ff3030"
    style.font-color: "#ff6060"
    style.bold: true
    style.font: mono
    style.font-size: 18
  }

  result_wrong: "Result: H state REPLACED" {
    style.fill: "#3a0808"
    style.stroke: "#cc2020"
    style.font-color: "#ff9090"
    rw0: "H[0] ← a  = 0x4f434152" { style.fill: "#4a1010"; style.font-color: "#ff7070"; style.font: mono }
    rw1: "H[1] ← b  (only last block contributes)" { style.fill: "#4a1010"; style.font-color: "#ff7070"; style.font: mono }
    rw2: "H[2] ← c  ..." { style.fill: "#4a1010"; style.font-color: "#ff7070"; style.font: mono }
    rw3: "H[0..7] holds ONLY last block's output" { style.fill: "#4a1010"; style.font-color: "#ff9090"; style.bold: true }
  }

  attacker_wrong: |md
    ☠️ **ATTACKER WINS**
    Prior block state
    0x6a09e667… is
    **discarded entirely**
    Controlling Block N
    → controls the
    entire digest
    Length-extension
    trivially possible:
    resume from any
    known H state
  | {
    style.fill: "#3a0a0a"
    style.stroke: "#cc0000"
    style.font-color: "#ff7070"
  }
}

path_correct: "PATH B  (CORRECT)  H[i] += working_var[i]  mod 2³²" {
  style.fill: "#0a1f0a"
  style.stroke: "#20a020"
  style.border-radius: 8
  style.font-color: "#80e080"

  op_correct: "H[i]  +=  working_var[i]  (mod 2³²)" {
    style.fill: "#103010"
    style.stroke: "#30c030"
    style.font-color: "#60e060"
    style.bold: true
    style.font: mono
    style.font-size: 18
  }

  result_correct: "Result: H state MIXED (feed-forward)" {
    style.fill: "#0a2a0a"
    style.stroke: "#20a020"
    style.font-color: "#70d070"
    rc0: "H[0] = 0x6a09e667 + 0x4f434152 = 0xba7816bf" { style.fill: "#0f2f0f"; style.font-color: "#80e880"; style.font: mono }
    rc1: "H[1] = 0xbb67ae85 + b          = 0x8f01cfea" { style.fill: "#0f2f0f"; style.font-color: "#80e880"; style.font: mono }
    rc2: "H[2] = 0x3c6ef372 + c          = 0x414140de" { style.fill: "#0f2f0f"; style.font-color: "#80e880"; style.font: mono }
    rc3: "Final digest = H_old ⊕₊ compression_output" { style.fill: "#0f2f0f"; style.font-color: "#a0f0a0"; style.bold: true }
  }

  attacker_correct: |md
    🛡️ **ATTACKER LOSES**
    **Davies-Meyer feed-forward:**
    H_new = f(H_old, block) + H_old
    Every prior block's
    entropy is irreversibly
    folded into H via
    modular addition
    Changing ANY prior
    block changes H_old
    → cascades through
    ALL subsequent blocks
    Cannot control digest
    without controlling
    the full message chain
  | {
    style.fill: "#0a200a"
    style.stroke: "#20a020"
    style.font-color: "#70d870"
  }
}

# ─── AFTER: Final Digest Output ──────────────────────────────────────────

after_correct: "AFTER Step 4  (correct path) — SHA-256(\"abc\") Digest" {
  style.fill: "#0a1a2a"
  style.stroke: "#2060a0"
  style.border-radius: 8
  style.font-color: "#80b0e0"

  digest_words: "Final H[0..7] — big-endian serialized → 64 hex chars" {
    style.fill: "#102030"
    style.stroke: "#3080c0"
    style.font-color: "#70a0d0"
    dw0: "H[0] = 0xba7816bf → bytes: ba 78 16 bf" { style.fill: "#152535"; style.font-color: "#80b8e8"; style.font: mono }
    dw1: "H[1] = 0x8f01cfea → bytes: 8f 01 cf ea" { style.fill: "#152535"; style.font-color: "#80b8e8"; style.font: mono }
    dw2: "H[2] = 0x414140de → bytes: 41 41 40 de" { style.fill: "#152535"; style.font-color: "#80b8e8"; style.font: mono }
    dw3: "H[3] = 0x5dae2223 → bytes: 5d ae 22 23" { style.fill: "#152535"; style.font-color: "#80b8e8"; style.font: mono }
    dw7: "... H[4..7] → b00361a3 96177a9c b410ff61 f20015ad" { style.fill: "#152535"; style.font-color: "#80b8e8"; style.font: mono }
  }

  hex_out: "\"ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad\"" {
    style.fill: "#1a3050"
    style.stroke: "#4090d0"
    style.font-color: "#a0d0ff"
    style.bold: true
    style.font: mono
    style.font-size: 11
  }

  nist_check: "✓ Matches NIST SHA-256(\"abc\") test vector" {
    style.fill: "#102820"
    style.stroke: "#30a060"
    style.font-color: "#60d090"
    style.bold: true
  }
}

# ─── SECURITY ANNOTATION ─────────────────────────────────────────────────

security_note: |md
  ## Davies-Meyer Security Guarantee
  **H_new = compress(H_old, block) + H_old**
  The `+` (mod 2³²) is **not** cosmetic — it is the load-bearing
  one-way ratchet that makes the compression function irreversible:
  - **Without feed-forward**: compress is a block cipher `E(key=H_old, pt=block)`.
    Given ciphertext (H_new) and key (H_old), you can invert it.
  - **With feed-forward**: inversion requires `compress⁻¹(H_new − H_old)`,
    which entangles the block cipher inverse with the unknown H_old.
    No known efficient algorithm exists.
  **Single character. Maximum impact.** `=` vs `+=`
| {
  near: bottom-center
  style.fill: "#0d0d1a"
  style.stroke: "#4040a0"
  style.font-color: "#9090d0"
}

# ─── CONNECTIONS ─────────────────────────────────────────────────────────

before.H_state -> path_wrong.op_wrong: "replace" {
  style.stroke: "#cc3030"
  style.stroke-dash: 4
  style.font-color: "#cc3030"
}
before.wv_state -> path_wrong.op_wrong: "overwrite" {
  style.stroke: "#cc3030"
  style.stroke-dash: 4
  style.font-color: "#cc3030"
}

before.H_state -> path_correct.op_correct: "H_old preserved" {
  style.stroke: "#30a030"
  style.font-color: "#30a030"
}
before.wv_state -> path_correct.op_correct: "added in mod 2³²" {
  style.stroke: "#30a030"
  style.font-color: "#30a030"
}

path_correct.result_correct -> after_correct.digest_words: "serialize big-endian" {
  style.stroke: "#3080c0"
  style.animated: true
  style.font-color: "#3080c0"
}
after_correct.digest_words -> after_correct.hex_out: "nibble extract × 64" {
  style.stroke: "#4090d0"
  style.font-color: "#4090d0"
}
after_correct.hex_out -> after_correct.nist_check {
  style.stroke: "#30a060"
  style.font-color: "#30a060"
}

path_wrong.op_wrong -> path_wrong.result_wrong {
  style.stroke: "#cc2020"
  style.font-color: "#cc2020"
}
path_wrong.result_wrong -> path_wrong.attacker_wrong: "security failure" {
  style.stroke: "#ff2020"
  style.stroke-dash: 5
  style.animated: true
  style.font-color: "#ff3030"
}

path_correct.op_correct -> path_correct.result_correct {
  style.stroke: "#20c020"
  style.font-color: "#20c020"
}
path_correct.result_correct -> path_correct.attacker_correct: "security holds" {
  style.stroke: "#20c020"
  style.font-color: "#20c020"
}