vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

shape: sequence_diagram

# Participants
Caller
sha256_compress
sha256_message_schedule

# Call Sequence
Caller -> sha256_compress: "sha256_compress(H[8], block[64])"

setup: {
  sha256_compress -> sha256_message_schedule: "sha256_message_schedule(block, W)"
  sha256_message_schedule -> sha256_compress: "W[64] populated\n[stack-local: 256 bytes]" {
    style.stroke-dash: 5
  }
}

init: {
  sha256_compress -> sha256_compress: "a=H[0], b=H[1], c=H[2], d=H[3]\ne=H[4], f=H[5], g=H[6], h=H[7]\n[stack-local: 8 × uint32_t]"
}

rounds: {
  sha256_compress -> sha256_compress: "Round t=0..63:\n  T1 = h + Σ1(e) + Ch(e,f,g) + K[t] + W[t]\n  T2 = Σ0(a) + Maj(a,b,c)\n  h=g; g=f; f=e; e=d+T1\n  d=c; c=b; b=a; a=T1+T2\n[stack-local: T1, T2 per round]"
}

feedfwd: {
  sha256_compress -> sha256_compress: "H[0]+=a; H[1]+=b; H[2]+=c; H[3]+=d\nH[4]+=e; H[5]+=f; H[6]+=g; H[7]+=h\n[caller-owned H modified in place]"
}

sha256_compress -> Caller: "return (void)\nH[0..7] updated; W,a..h,T1,T2 freed" {
  style.stroke-dash: 5
}

# Documentation / Legend
ownership: |'md
**Ownership Map**
| Variable | Owner | Size | Lifetime |
|---|---|---|---|
| `H[8]` | Caller | 32 B | Caller scope |
| `block[64]` | Caller | 64 B | Caller scope (read-only) |
| `W[64]` | Stack-local | 256 B | sha256_compress frame |
| `a..h` | Stack-local | 32 B | sha256_compress frame |
| `T1, T2` | Stack-local | 8 B | Per-round only |
'| {
  near: bottom-center
}