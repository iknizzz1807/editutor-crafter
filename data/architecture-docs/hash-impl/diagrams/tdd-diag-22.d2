vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  ## Module Architecture: SHA-256 Public API (hash-impl-m4)
  **sizeof(SHA256_CTX) = 112 bytes** · No heap allocation · Thread-safe for distinct contexts
| {near: top-center}

# ── Constants ─────────────────────────────────────────────────────────────
constants: "Constants (.rodata)" {
  style.fill: "#e8d5f5"
  style.stroke: "#7b2d8b"
  style.stroke-width: 2
  style.border-radius: 6

  block_size: |md
    `SHA256_BLOCK_SIZE = 64`
    512 bits per block
  | {shape: text}

  digest_size: |md
    `SHA256_DIGEST_SIZE = 32`
    256-bit output
  | {shape: text}

  init_hash: |md
    `SHA256_INITIAL_HASH[8]`
    **extern const uint32_t**
    frac(√prime) × 2³²
    H[0]=0x6a09e667 … H[7]=0x5be0cd19
  | {shape: text}
}

# ── SHA256_CTX struct ──────────────────────────────────────────────────────
ctx_struct: "SHA256_CTX  ·  112 bytes (2 cache lines)" {
  style.fill: "#dde8ff"
  style.stroke: "#2255bb"
  style.stroke-width: 2
  style.border-radius: 6

  h_field: "H[8] : uint32_t[8]  ·  32 B\nRunning hash state\nOffset 0x00" {
    style.fill: "#c0d4ff"
    style.stroke: "#2255bb"
    style.border-radius: 4
    shape: rectangle
  }
  buf_field: "buf[64] : uint8_t[64]  ·  64 B\nPartial block buffer\nOffset 0x20" {
    style.fill: "#c0d4ff"
    style.stroke: "#2255bb"
    style.border-radius: 4
    shape: rectangle
  }
  buflen_field: "buf_len : size_t  ·  8 B\nValid bytes in buf ∈ [0, 63]\nOffset 0x60" {
    style.fill: "#c0d4ff"
    style.stroke: "#2255bb"
    style.border-radius: 4
    shape: rectangle
  }
  totalbits_field: "total_bits : uint64_t  ·  8 B\nΣ(len × 8) across update() calls\nOffset 0x68" {
    style.fill: "#c0d4ff"
    style.stroke: "#2255bb"
    style.border-radius: 4
    shape: rectangle
  }
}

# ── Five Public Functions ──────────────────────────────────────────────────
public_api: "sha256.h — Public Functions" {
  style.fill: "#e6f4ea"
  style.stroke: "#2d6a2d"
  style.stroke-width: 2
  style.border-radius: 6

  fn_init: "sha256_init()" {
    style.fill: "#c8e6c9"
    style.stroke: "#2d6a2d"
    style.border-radius: 4
    shape: rectangle
    sig: |md
      `void sha256_init(SHA256_CTX *ctx)`
      **Loads** SHA256_INITIAL_HASH → H[0..7]
      **Sets** buf_len = 0, total_bits = 0
      Must call before first update() and before reuse
    | {shape: text}
  }

  fn_update: "sha256_update()" {
    style.fill: "#c8e6c9"
    style.stroke: "#2d6a2d"
    style.border-radius: 4
    shape: rectangle
    sig: |md
      `void sha256_update(SHA256_CTX *ctx,`
      `                   const uint8_t *data, size_t len)`
      **Phase 1** Fill existing partial buf → flush if full
      **Phase 2** Compress whole blocks directly from data
      **Phase 3** Buffer remainder (0–63 bytes)
      total_bits += (uint64_t)len × 8
    | {shape: text}
  }

  fn_finalize: "sha256_finalize()" {
    style.fill: "#c8e6c9"
    style.stroke: "#2d6a2d"
    style.border-radius: 4
    shape: rectangle
    sig: |md
      `void sha256_finalize(SHA256_CTX *ctx,`
      `                     uint8_t digest[32])`
      Append 0x80 · zero-fill · write 64-bit BE length
      **if** buf_len+1 > 56 → extra block (two compressions)
      Serialize H[0..7] → digest via explicit byte-shift
      ctx is indeterminate after return; reinit before reuse
    | {shape: text}
  }

  fn_to_hex: "sha256_to_hex()" {
    style.fill: "#c8e6c9"
    style.stroke: "#2d6a2d"
    style.border-radius: 4
    shape: rectangle
    sig: |md
      `void sha256_to_hex(const uint8_t digest[32],`
      `                   char hex[65])`
      Each byte → 2 lowercase hex chars via nibble extraction
      hex[64] = '\0'   ·   table: "0123456789abcdef"
      Returns void · no allocation
    | {shape: text}
  }

  fn_oneshot: "sha256_oneshot()" {
    style.fill: "#c8e6c9"
    style.stroke: "#2d6a2d"
    style.border-radius: 4
    shape: rectangle
    sig: |md
      `void sha256_oneshot(const uint8_t *msg,`
      `                    size_t len, char hex[65])`
      Stack-local SHA256_CTX · init → update → finalize → to_hex
      Thread-safe · no shared state · no heap
    | {shape: text}
  }
}

# ── Downstream dependencies ────────────────────────────────────────────────
compress: "sha256_compress()\n(Milestone 3)" {
  style.fill: "#fff3cd"
  style.stroke: "#b07d00"
  style.stroke-width: 2
  style.border-radius: 6
  csig: |md
    `void sha256_compress(`
    `  uint32_t H[8],`
    `  const uint8_t block[64])`
    64-round compression · updates H in-place
    Davies-Meyer feed-forward: H[i] += working_var[i]
  | {shape: text}
}

schedule: "sha256_message_schedule()\n(Milestone 2)" {
  style.fill: "#fce8d5"
  style.stroke: "#a05010"
  style.stroke-width: 2
  style.border-radius: 6
  ssig: |md
    `void sha256_message_schedule(`
    `  const uint8_t *block,`
    `  uint32_t W[64])`
    Parse 16 BE words · expand 48 via σ0/σ1 recurrence
  | {shape: text}
}

# ── API Paths ──────────────────────────────────────────────────────────────
path_oneshot: "One-Shot Path" {
  style.fill: "#f0f8ff"
  style.stroke: "#4488cc"
  style.stroke-dash: 4
  style.border-radius: 6
  summary: |md
    **Single-call API**
    sha256_oneshot(msg, len, hex)
    ↳ stack-local ctx → thread-safe
    ↳ calls init + update + finalize + to_hex
  | {shape: text}
}

path_streaming: "Streaming Path" {
  style.fill: "#fff8f0"
  style.stroke: "#cc6622"
  style.stroke-dash: 4
  style.border-radius: 6
  summary: |md
    **Multi-call API**
    sha256_init(ctx)
    sha256_update(ctx, chunk₁, n₁)
    sha256_update(ctx, chunk₂, n₂)  ← N calls, any sizes
    …
    sha256_finalize(ctx, digest)
    sha256_to_hex(digest, hex)
    ⚠ Must reinit between computations
  | {shape: text}
}

# ── Connections ────────────────────────────────────────────────────────────

# Constants flow into init
constants -> public_api.fn_init: "loads SHA256_INITIAL_HASH" {
  style.stroke: "#7b2d8b"
  style.stroke-dash: 4
}

# CTX is the shared parameter across streaming functions
public_api.fn_init -> ctx_struct: "writes H[0..7]\nbuf_len=0\ntotal_bits=0" {
  style.stroke: "#2d6a2d"
}
public_api.fn_update -> ctx_struct: "reads/writes buf\nbuf_len\ntotal_bits\nH[0..7]" {
  style.stroke: "#2d6a2d"
}
public_api.fn_finalize -> ctx_struct: "reads buf_len\ntotal_bits\nwrites H[0..7]" {
  style.stroke: "#2d6a2d"
}

# update and finalize call compress
public_api.fn_update -> compress: "Phase 2+flush:\nsha256_compress(H, block)" {
  style.stroke: "#b07d00"
  style.stroke-width: 2
}
public_api.fn_finalize -> compress: "final block(s):\nsha256_compress(H, buf)" {
  style.stroke: "#b07d00"
  style.stroke-width: 2
}

# compress calls schedule internally
compress -> schedule: "internal call\nsha256_message_schedule\n(block, W)" {
  style.stroke: "#a05010"
  style.stroke-dash: 3
}

# oneshot is composition
public_api.fn_oneshot -> public_api.fn_init: "calls" {style.stroke: "#4488cc"}
public_api.fn_oneshot -> public_api.fn_update: "calls" {style.stroke: "#4488cc"}
public_api.fn_oneshot -> public_api.fn_finalize: "calls" {style.stroke: "#4488cc"}
public_api.fn_oneshot -> public_api.fn_to_hex: "calls" {style.stroke: "#4488cc"}

# Path annotations reference functions
path_oneshot -> public_api.fn_oneshot: "single entry point" {
  style.stroke: "#4488cc"
  style.stroke-dash: 5
}
path_streaming -> public_api.fn_init: "" {
  style.stroke: "#cc6622"
  style.stroke-dash: 5
}
path_streaming -> public_api.fn_update: "" {
  style.stroke: "#cc6622"
  style.stroke-dash: 5
}
path_streaming -> public_api.fn_finalize: "" {
  style.stroke: "#cc6622"
  style.stroke-dash: 5
}
path_streaming -> public_api.fn_to_hex: "" {
  style.stroke: "#cc6622"
  style.stroke-dash: 5
}