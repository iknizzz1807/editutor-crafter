vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Memory Layout: SHA256_CTX Struct
  **112 bytes · 2 cache lines (64B each)**
| {near: top-center}
ctx: SHA256_CTX {
  style: {
    fill: "#f0f4ff"
    stroke: "#3a3aaa"
    stroke-width: 2
    border-radius: 6
  }
  fields: {
    style: {
      fill: transparent
      stroke: transparent
    }
    h_field: "H[8]  ·  uint32_t[8]" {
      shape: rectangle
      style: {
        fill: "#c4b5fd"
        stroke: "#7c3aed"
        stroke-width: 2
        font-size: 13
        bold: true
      }
      width: 640
      height: 80
    }
    h_detail: |md
      `H[0]`·`H[1]`·`H[2]`·`H[3]`·`H[4]`·`H[5]`·`H[6]`·`H[7]`
      4 B each · 32 bytes total · bytes **0x00 – 0x1F**
      Running hash state · read+write by `sha256_compress()`
    | {
      shape: rectangle
      style: {
        fill: "#ede9fe"
        stroke: "#7c3aed"
        stroke-width: 1
        font-size: 11
      }
      width: 640
      height: 56
    }
    cl0_boundary: "◀── Cache Line 0 boundary (bytes 0–63) ──▶" {
      shape: text
      style: {
        font-size: 11
        italic: true
        font-color: "#1e40af"
        bold: false
      }
    }
    buf_field: "buf[64]  ·  uint8_t[64]" {
      shape: rectangle
      style: {
        fill: "#93c5fd"
        stroke: "#1d4ed8"
        stroke-width: 2
        font-size: 13
        bold: true
      }
      width: 640
      height: 80
    }
    buf_detail: |md
      One full 512-bit message block buffer · bytes **0x20 – 0x5F**
      Accumulates partial input between `update()` calls
      `buf[0..buf_len-1]` valid · `buf[buf_len..63]` unspecified
    | {
      shape: rectangle
      style: {
        fill: "#dbeafe"
        stroke: "#1d4ed8"
        stroke-width: 1
        font-size: 11
      }
      width: 640
      height: 56
    }
    cl1_boundary: "◀── Cache Line 1 boundary (bytes 64–127) ──▶" {
      shape: text
      style: {
        font-size: 11
        italic: true
        font-color: "#1e40af"
        bold: false
      }
    }
    buflen_field: "buf_len  ·  size_t" {
      shape: rectangle
      style: {
        fill: "#6b7280"
        stroke: "#374151"
        stroke-width: 2
        font-size: 13
        bold: true
        font-color: "#ffffff"
      }
      width: 640
      height: 48
    }
    buflen_detail: |md
      bytes **0x60 – 0x67** (8 bytes on 64-bit) · Range: [0, 63]
      **Never** equals 64 — full block flushed immediately in `update()`
    | {
      shape: rectangle
      style: {
        fill: "#f3f4f6"
        stroke: "#374151"
        stroke-width: 1
        font-size: 11
      }
      width: 640
      height: 40
    }
    totalbits_field: "total_bits  ·  uint64_t" {
      shape: rectangle
      style: {
        fill: "#f97316"
        stroke: "#c2410c"
        stroke-width: 2
        font-size: 13
        bold: true
        font-color: "#ffffff"
      }
      width: 640
      height: 48
    }
    totalbits_detail: |md
      bytes **0x68 – 0x6F** (8 bytes) · Σ(len × 8) across all `update()` calls
      Written to FIPS 180-4 length field in `finalize()` · Range: [0, 2⁶⁴−1]
    | {
      shape: rectangle
      style: {
        fill: "#fff7ed"
        stroke: "#c2410c"
        stroke-width: 1
        font-size: 11
      }
      width: 640
      height: 40
    }
  }
}
offsets: "Byte Offsets" {
  style: {
    fill: "#f8fafc"
    stroke: "#94a3b8"
    stroke-width: 1
    border-radius: 4
  }
  o0:  "0x00" { style.fill: "#ede9fe"; style.stroke: "#7c3aed"; style.font-size: 12; style.bold: true }
  o20: "0x20" { style.fill: "#dbeafe"; style.stroke: "#1d4ed8"; style.font-size: 12; style.bold: true }
  o60: "0x60" { style.fill: "#f3f4f6"; style.stroke: "#374151"; style.font-size: 12; style.bold: true }
  o68: "0x68" { style.fill: "#fff7ed"; style.stroke: "#c2410c"; style.font-size: 12; style.bold: true }
  o70: "0x70" { style.fill: "#f1f5f9"; style.stroke: "#64748b"; style.font-size: 12; style.bold: true; label: "0x70 (end)" }
}
access: "Field Access by Function" {
  style: {
    fill: "#f0fdf4"
    stroke: "#15803d"
    stroke-width: 1
    border-radius: 4
  }
  update_reads: "sha256_update() reads/writes" {
    shape: rectangle
    style: {
      fill: "#dcfce7"
      stroke: "#15803d"
      stroke-width: 1
      font-size: 11
    }
    label: |md
      **sha256_update()** reads + writes:
      `H[8]` (via compress) · `buf[]` · `buf_len` · `total_bits`
    |
  }
  finalize_reads: "sha256_finalize() reads/writes" {
    shape: rectangle
    style: {
      fill: "#fef9c3"
      stroke: "#a16207"
      stroke-width: 1
      font-size: 11
    }
    label: |md
      **sha256_finalize()** reads + writes **all fields**:
      `H[8]` → final state → `digest[32]`
      `buf[]` → padding target
      `buf_len` → marker insert point
      `total_bits` → FIPS length field at `buf[56..63]`
    |
  }
  init_writes: "sha256_init() writes" {
    shape: rectangle
    style: {
      fill: "#ede9fe"
      stroke: "#7c3aed"
      stroke-width: 1
      font-size: 11
    }
    label: |md
      **sha256_init()** writes **all fields**:
      `H[i] ← SHA256_INITIAL_HASH[i]` (i=0..7)
      `buf_len ← 0` · `total_bits ← 0`
      `buf[]` → memset 0 (defensive)
    |
  }
}
sizes: "Size Annotations" {
  style: {
    fill: "#fdf2f8"
    stroke: "#9d174d"
    stroke-width: 1
    border-radius: 4
  }
  sz_h:    "H[8]        = 32 B" { style.font-size: 12; style.fill: "#ede9fe"; style.stroke: "#7c3aed" }
  sz_buf:  "buf[64]     = 64 B" { style.font-size: 12; style.fill: "#dbeafe"; style.stroke: "#1d4ed8" }
  sz_blen: "buf_len     =  8 B" { style.font-size: 12; style.fill: "#f3f4f6"; style.stroke: "#374151" }
  sz_tb:   "total_bits  =  8 B" { style.font-size: 12; style.fill: "#fff7ed"; style.stroke: "#c2410c" }
  sz_tot:  "TOTAL       = 112 B (2 × 64B cache lines)" {
    style.font-size: 13
    style.bold: true
    style.fill: "#fce7f3"
    style.stroke: "#9d174d"
    style.font-color: "#9d174d"
  }
}
invariant: |md
  **Key invariants (between init and finalize):**
  `buf_len ∈ [0, 63]`  ·  `total_bits = Σ(len × 8)`  ·  `H[0..7]` valid hash state
  A full 64-byte block is **always** flushed immediately in `sha256_update()` — never left in `buf[]`
| {
  near: bottom-center
  style: {
    font-size: 11
    fill: "#f0f9ff"
    stroke: "#0369a1"
    stroke-width: 1
    border-radius: 4
  }
}
ctx -> offsets: "byte offsets" { style.stroke-dash: 3; style.font-size: 10 }
ctx -> access:  "access patterns" { style.stroke-dash: 3; style.font-size: 10 }
ctx -> sizes:   "sizeof breakdown" { style.stroke-dash: 3; style.font-size: 10 }
offsets.o0  -> ctx.fields.h_field:       "" { style.stroke: "#7c3aed"; style.stroke-width: 2 }
offsets.o20 -> ctx.fields.buf_field:     "" { style.stroke: "#1d4ed8"; style.stroke-width: 2 }
offsets.o60 -> ctx.fields.buflen_field:  "" { style.stroke: "#374151"; style.stroke-width: 2 }
offsets.o68 -> ctx.fields.totalbits_field: "" { style.stroke: "#c2410c"; style.stroke-width: 2 }