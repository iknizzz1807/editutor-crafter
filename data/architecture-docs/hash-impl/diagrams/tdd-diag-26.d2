vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  ## sha256_finalize() Padding — One-Block vs Two-Block Path
| {near: top-center}
entry: "Entry State" {
  shape: rectangle
  style.fill: "#9B59B6"
  style.font-color: white
  style.bold: true
  label: |md
    **Entry**
    ctx→buf[0..buf_len-1] = unprocessed bytes
    ctx→buf_len ∈ [0, 63]
    ctx→total_bits = accumulated bit count
  |
}
step1: "Step 1: Append 0x80 Marker" {
  shape: rectangle
  style.fill: "#2980B9"
  style.font-color: white
  label: |md
    **buf[buf_len] = 0x80**
    used = buf_len + 1
    used ∈ [1, 64]
  |
}
branch: "used > 56 ?" {
  shape: diamond
  style.fill: "#E67E22"
  style.font-color: white
  style.bold: true
  width: 220
  height: 100
}
two_block_a: "Two-Block Path — Flush Block 1" {
  shape: rectangle
  style.fill: "#C0392B"
  style.font-color: white
  label: |md
    **memset(buf + used, 0, 64 − used)**
    Zero-fill buf[used..63]
    (7 bytes max if buf_len=56)
    ─────────────────────────
    **sha256_compress(H, buf)**
    Compress block 1
    (contains msg tail + 0x80 + zeros)
    ─────────────────────────
    **memset(buf, 0, 64)**
    Clear entire buf for block 2
    ⚠ MUST zero ALL bytes —
    stale bytes → wrong digest
  |
}
one_block_b: "One-Block Path — Zero Fill" {
  shape: rectangle
  style.fill: "#27AE60"
  style.font-color: white
  label: |md
    **memset(buf + used, 0, 56 − used)**
    Zero-fill buf[used..55]
    (0 bytes if buf_len=55 / used=56)
    ─────────────────────────
    No compression yet.
    Length field slots buf[56..63]
    are in the SAME block.
  |
}
step3: "Step 3: Write 64-bit Big-Endian Length Field at buf[56..63]" {
  shape: rectangle
  style.fill: "#2980B9"
  style.font-color: white
  label: |md
    **L = ctx→total_bits**
    buf[56] = (L >> 56) & 0xFF   ← MSB
    buf[57] = (L >> 48) & 0xFF
    buf[58] = (L >> 40) & 0xFF
    buf[59] = (L >> 32) & 0xFF
    buf[60] = (L >> 24) & 0xFF
    buf[61] = (L >> 16) & 0xFF
    buf[62] = (L >>  8) & 0xFF
    buf[63] = (L      ) & 0xFF   ← LSB
    ─────────────────────────────────
    ⚠ Use total_bits, NOT buf_len×8
    ⚠ Explicit shifts — NOT memcpy
       (memcpy byte-reverses on x86)
  |
}
step4: "Step 4: Compress Final Block" {
  shape: rectangle
  style.fill: "#2980B9"
  style.font-color: white
  label: |md
    **sha256_compress(ctx→H, ctx→buf)**
    Block contains:
      msg bytes (if one-block path)
      0x80 marker
      zero fill
      8-byte length field
    ─────────────────────
    ctx→H[0..7] now holds
    the final hash state.
  |
}
step5: "Step 5: Serialize Digest (Big-Endian)" {
  shape: rectangle
  style.fill: "#2980B9"
  style.font-color: white
  label: |md
    **for i = 0..7:**
    digest[i×4+0] = (H[i] >> 24) & 0xFF   ← MSB
    digest[i×4+1] = (H[i] >> 16) & 0xFF
    digest[i×4+2] = (H[i] >>  8) & 0xFF
    digest[i×4+3] = (H[i]      ) & 0xFF   ← LSB
    ────────────────────────────────────────
    ⚠ NOT memcpy(digest, H, 32) — little-endian
      platforms write bytes reversed
    Output: digest[0..31] = 32-byte SHA-256 hash
  |
}
exit_state: "Return" {
  shape: rectangle
  style.fill: "#9B59B6"
  style.font-color: white
  style.bold: true
  label: |md
    **digest[0..31]** = correct SHA-256 hash
    ctx state = indeterminate
    Call sha256_init() before reuse
  |
}
boundary_note: |md
  **Boundary Analysis**
  buf_len=55 → used=56 → 56>56? NO → one block
  buf_len=56 → used=57 → 57>56? YES → two blocks ← THE TRAP
  buf_len=0  → used=1  → 1>56?  NO → one block (empty msg)
| {
  near: bottom-right
  shape: rectangle
  style.fill: "#2C3E50"
  style.font-color: "#ECF0F1"
  style.border-radius: 8
}
example_one: |md
  **One-Block Example: "abc" (buf_len=3)**
  used = 4
  buf: [61][62][63][80][00×52][00×7][18]
  1 compress call total
| {
  near: bottom-left
  shape: rectangle
  style.fill: "#1A5276"
  style.font-color: "#AED6F1"
  style.border-radius: 8
}
entry -> step1: "start"
step1 -> branch: "evaluate"
branch -> two_block_a: "YES\nused > 56\n(buf_len ≥ 56)" {
  style.stroke: "#C0392B"
  style.font-color: "#C0392B"
  style.bold: true
}
branch -> one_block_b: "NO\nused ≤ 56\n(buf_len ≤ 55)" {
  style.stroke: "#27AE60"
  style.font-color: "#27AE60"
  style.bold: true
}
two_block_a -> step3: "converge\n(buf is now fresh\nall-zero block)"
one_block_b -> step3: "converge\n(same block,\nlength field fits)"
step3 -> step4
step4 -> step5
step5 -> exit_state