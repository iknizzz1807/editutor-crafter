r1_frac:  "0.73205080757…" { class: frac_cell }
r1_scale: "3,144,134,277.9…" { class: scale_cell }
r1_floor: "3,144,134,277" { class: floor_cell }
r1_hex:   "0xBB67AE85" { class: hex_cell }
r1_field: "H[1]" { class: field_cell }
