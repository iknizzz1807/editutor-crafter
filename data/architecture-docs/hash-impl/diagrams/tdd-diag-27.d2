r4_frac:  "0.31662479036…" { class: frac_cell }
r4_scale: "1,359,893,119.9…" { class: scale_cell }
r4_floor: "1,359,893,119" { class: floor_cell }
r4_hex:   "0x510E527F" { class: hex_cell }
r4_field: "H[4]" { class: field_cell }
# ─── ROW 5 · H[5] ────────────────────────────────────────────
r5_prime: "13" { class: prime_cell }
r5_sqrt:  "3.60555127546…" { class: sqrt_cell }
r5_frac:  "0.60555127546…" { class: frac_cell }
r5_scale: "2,600,822,924.4…" { class: scale_cell }
r5_floor: "2,600,822,924" { class: floor_cell }
r5_hex:   "0x9B05688C" { class: hex_cell }
r5_field: "H[5]" { class: field_cell }
# ─── ROW 6 · H[6] ────────────────────────────────────────────
r6_prime: "17" { class: prime_cell }
r6_sqrt:  "4.12310562562…" { class: sqrt_cell }
r6_frac:  "0.12310562562…" { class: frac_cell }
r6_scale: "528,734,635.1…" { class: scale_cell }
r6_floor: "528,734,635" { class: floor_cell }
r6_hex:   "0x1F83D9AB" { class: hex_cell }
r6_field: "H[6]" { class: field_cell }
# ─── ROW 7 · H[7] ────────────────────────────────────────────
r7_prime: "19" { class: prime_cell }
r7_sqrt:  "4.35889894354…" { class: sqrt_cell }
r7_frac:  "0.35889894354…" { class: frac_cell }
r7_scale: "1,541,325,593.6…" { class: scale_cell }
r7_floor: "1,541,325,593" { class: floor_cell }
r7_hex:   "0x5BE0CD19" { class: hex_cell }
r7_field: "H[7]" { class: field_cell }
# ─── DERIVATION PIPELINE ANNOTATION ──────────────────────────
pipeline: |md
  **Derivation procedure (same for all 8 rows):**
  1. Select the n-th prime p
  2. Compute √p to sufficient decimal precision
  3. Extract the fractional part: frac(√p) = √p − floor(√p)
  4. Scale: frac(√p) × 2³² = frac(√p) × 4,294,967,296
  5. Floor: discard fractional remainder → 32-bit integer
  6. Express as 8-digit hexadecimal → SHA256_INITIAL_HASH[i]
| {
  near: bottom-center
  style: {
    fill: "#F8F8F8"
    stroke: "#999999"
    stroke-width: 1
    font-size: 12
  }
}
security_note: |md
  🔒 **Security property:** Every constant is independently verifiable
  using only a calculator or `python3 -c "import math; hex(int((math.sqrt(2)%1)*2**32))"`.
  No hidden structure, no trapdoor, no designer choice — the derivation
  procedure is more constrained than the space of backdoor-enabling values.
  Contrast with Dual_EC_DRBG (NSA backdoor via unverifiable constants).
| {
  near: bottom-center
  style: {
    fill: "#FFF8E7"
    stroke: "#B8860B"
    stroke-width: 2
    font-size: 11
  }
}
# ─── HORIZONTAL FLOW: header row ─────────────────────────────
hdr_prime -> hdr_sqrt -> hdr_frac -> hdr_scale -> hdr_floor -> hdr_hex -> hdr_field: "" {
  style: { stroke: "#444444"; stroke-width: 1 }
}
# ─── ROW 0 PIPELINE (highlighted) ────────────────────────────
r0_prime -> r0_sqrt: "√" {
  style: { stroke: "#B8860B"; stroke-width: 2; bold: true; font-size: 11 }
}
r0_sqrt -> r0_frac: "frac()" {
  style: { stroke: "#B8860B"; stroke-width: 2; bold: true; font-size: 11 }
}
r0_frac -> r0_scale: "× 2³²" {
  style: { stroke: "#B8860B"; stroke-width: 2; bold: true; font-size: 11 }
}
r0_scale -> r0_floor: "floor()" {
  style: { stroke: "#B8860B"; stroke-width: 2; bold: true; font-size: 11 }
}
r0_floor -> r0_hex: "→ hex" {
  style: { stroke: "#B8860B"; stroke-width: 2; bold: true; font-size: 11 }
}
r0_hex -> r0_field: "" {
  style: { stroke: "#B8860B"; stroke-width: 2 }
}
# ─── ROWS 1–7 PIPELINES (lighter) ────────────────────────────
r1_prime -> r1_sqrt -> r1_frac -> r1_scale -> r1_floor -> r1_hex -> r1_field: "" {
  style: { stroke: "#888888"; stroke-width: 1 }
}
r2_prime -> r2_sqrt -> r2_frac -> r2_scale -> r2_floor -> r2_hex -> r2_field: "" {
  style: { stroke: "#888888"; stroke-width: 1 }
}
r3_prime -> r3_sqrt -> r3_frac -> r3_scale -> r3_floor -> r3_hex -> r3_field: "" {
  style: { stroke: "#888888"; stroke-width: 1 }
}
r4_prime -> r4_sqrt -> r4_frac -> r4_scale -> r4_floor -> r4_hex -> r4_field: "" {
  style: { stroke: "#888888"; stroke-width: 1 }
}
r5_prime -> r5_sqrt -> r5_frac -> r5_scale -> r5_floor -> r5_hex -> r5_field: "" {
  style: { stroke: "#888888"; stroke-width: 1 }
}
r6_prime -> r6_sqrt -> r6_frac -> r6_scale -> r6_floor -> r6_hex -> r6_field: "" {
  style: { stroke: "#888888"; stroke-width: 1 }
}
