}
# ─── VERTICAL COLUMN GROUPING (prime column) ─────────────────
hdr_prime -> r0_prime -> r1_prime -> r2_prime -> r3_prime -> r4_prime -> r5_prime -> r6_prime -> r7_prime: "" {
  style: { stroke: "#7B2D8B"; stroke-width: 1; stroke-dash: 3 }
}
# ─── VERTICAL COLUMN GROUPING (hex output column) ────────────
hdr_hex -> r0_hex -> r1_hex -> r2_hex -> r3_hex -> r4_hex -> r5_hex -> r6_hex -> r7_hex: "" {
  style: { stroke: "#8B3D2D"; stroke-width: 1; stroke-dash: 3 }
}
# ─── VERIFY ANNOTATION on H[0] ───────────────────────────────
verify_h0: |md
  **Verify H[0] yourself:**
  python
  import math
  v = math.sqrt(2) % 1       # 0.41421356237…
  i = int(v * 2**32)         # 1779033703
  hex(i)                     # '0x6a09e667'  ✓
  
| {
  style: {
    fill: "#FFFFF0"
    stroke: "#B8860B"
    stroke-width: 2
    font-size: 11
  }
}
r0_hex -> verify_h0: "✓ verify" {
  style: {
    stroke: "#B8860B"
    stroke-width: 2
    stroke-dash: 4
    font-size: 10
    font-color: "#B8860B"
  }
}