      stroke: "#B8860B"
      stroke-width: 3
      font: mono
      font-size: 12
      bold: true
    }
  }
}
# ─── HEADER ROW ───────────────────────────────────────────────
hdr_prime: "Prime p" { class: header_cell }
hdr_sqrt:  "√p" { class: header_cell }
hdr_frac:  "frac(√p)" { class: header_cell }
hdr_scale: "frac(√p) × 2³²" { class: header_cell }
hdr_floor: "floor(…)" { class: header_cell }
hdr_hex:   "Hex value" { class: header_cell }
hdr_field: "SHA256_INITIAL_HASH[i]" { class: header_cell }
# ─── ROW 0 · H[0] — FULLY ANNOTATED (highlight) ──────────────
r0_prime: "2" { class: highlight_row }
r0_sqrt:  "1.41421356237…" { class: highlight_row }
r0_frac:  "0.41421356237…" { class: highlight_row }
r0_scale: "0.41421… × 4,294,967,296\n= 1,779,033,703.952…" { class: highlight_row }
r0_floor: "1,779,033,703" { class: highlight_row }
r0_hex:   "0x6A09E667" { class: highlight_row }
r0_field: "H[0]" { class: highlight_row }
