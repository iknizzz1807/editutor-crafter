vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  ## Algorithm Steps: Big-Endian Digest Serialization
  ### H[i] → digest[i×4 .. i×4+3]
'| {near: top-center}

direction: right

legend: |'md
  **H[0] = 0xBA7816BF** (SHA-256("abc") first word)
  - **Correct path**: explicit shift-and-mask (big-endian, platform-safe)
  - **Wrong path**: native `memcpy` on x86 (little-endian byte order)
'| {
  near: bottom-center
  style.font-size: 13
}

correct: "✓ CORRECT — Explicit Shift-and-Mask (Big-Endian)" {
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.stroke-width: 2
  style.font-color: "#1b5e20"
  style.bold: true

  h0_word: "H[0] = 0xBA7816BF" {
    style.fill: "#7b1fa2"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }

  d0: |'md
    **digest[0]**
    `(H[0] >> 24) & 0xFF`
    = **0xBA**
    *offset = i×4+0*
  '| {
    style.fill: "#1565c0"
    style.font-color: white
    style.border-radius: 6
  }

  d1: |'md
    **digest[1]**
    `(H[0] >> 16) & 0xFF`
    = **0x78**
    *offset = i×4+1*
  '| {
    style.fill: "#1565c0"
    style.font-color: white
    style.border-radius: 6
  }

  d2: |'md
    **digest[2]**
    `(H[0] >> 8) & 0xFF`
    = **0x16**
    *offset = i×4+2*
  '| {
    style.fill: "#1565c0"
    style.font-color: white
    style.border-radius: 6
  }

  d3: |'md
    **digest[3]**
    `(H[0] >> 0) & 0xFF`
    = **0xBF**
    *offset = i×4+3*
  '| {
    style.fill: "#1565c0"
    style.font-color: white
    style.border-radius: 6
  }

  h0_word -> d0: "bits 31..24\nMSB first" {
    style.stroke: "#388e3c"
    style.stroke-width: 2
    style.bold: true
  }
  d0 -> d1: "bits 23..16" {
    style.stroke: "#388e3c"
    style.stroke-width: 2
  }
  d1 -> d2: "bits 15..8" {
    style.stroke: "#388e3c"
    style.stroke-width: 2
  }
  d2 -> d3: "bits 7..0\nLSB last" {
    style.stroke: "#388e3c"
    style.stroke-width: 2
  }

  result_correct: |'md
    **Memory layout (correct):**
    `digest[0..3] = { 0xBA, 0x78, 0x16, 0xBF }`
    → hex string: **"ba7816bf..."** ✓
  '| {
    style.fill: "#c8e6c9"
    style.stroke: "#388e3c"
    style.font-color: "#1b5e20"
    style.border-radius: 8
  }

  d3 -> result_correct: "final\nbytes" {
    style.stroke: "#388e3c"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
}

wrong: "✗ WRONG — Native memcpy on x86 (Little-Endian)" {
  style.fill: "#ffebee"
  style.stroke: "#c62828"
  style.stroke-width: 2
  style.font-color: "#b71c1c"
  style.bold: true

  h0_word_w: "H[0] = 0xBA7816BF" {
    style.fill: "#7b1fa2"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }

  memcpy_op: |'md
    `memcpy(digest, &H[0], 4)`
    x86 stores **LSB at lowest address**
    (little-endian native byte order)
  '| {
    style.fill: "#e53935"
    style.font-color: white
    style.border-radius: 6
  }

  w0: |'md
    **digest[0]**
    x86 writes LSB first
    = **0xBF** ← WRONG
  '| {
    style.fill: "#b71c1c"
    style.font-color: white
    style.border-radius: 6
  }

  w1: |'md
    **digest[1]**
    = **0x16** ← WRONG
  '| {
    style.fill: "#b71c1c"
    style.font-color: white
    style.border-radius: 6
  }

  w2: |'md
    **digest[2]**
    = **0x78** ← WRONG
  '| {
    style.fill: "#b71c1c"
    style.font-color: white
    style.border-radius: 6
  }

  w3: |'md
    **digest[3]**
    = **0xBA** ← WRONG
  '| {
    style.fill: "#b71c1c"
    style.font-color: white
    style.border-radius: 6
  }

  result_wrong: |'md
    **Memory layout (wrong):**
    `digest[0..3] = { 0xBF, 0x16, 0x78, 0xBA }`
    → hex string: **"bf1678ba..."** ✗
    *Digest does NOT match NIST vectors*
  '| {
    style.fill: "#ffcdd2"
    style.stroke: "#c62828"
    style.font-color: "#b71c1c"
    style.border-radius: 8
  }

  h0_word_w -> memcpy_op: "memcpy\n4 bytes" {
    style.stroke: "#c62828"
    style.stroke-width: 2
  }
  memcpy_op -> w0 {
    style.stroke: "#c62828"
    style.stroke-width: 2
  }
  w0 -> w1 {style.stroke: "#c62828"}
  w1 -> w2 {style.stroke: "#c62828"}
  w2 -> w3 {style.stroke: "#c62828"}
  w3 -> result_wrong {
    style.stroke: "#c62828"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
}

generalloop: "General Pattern: for i = 0..7" {
  style.fill: "#fff8e1"
  style.stroke: "#f57f17"
  style.stroke-width: 2
  style.border-radius: 8

  formula: |'md
    c
    for (int i = 0; i < 8; i++) {
        digest[i*4 + 0] = (uint8_t)(H[i] >> 24); /* MSB */
        digest[i*4 + 1] = (uint8_t)(H[i] >> 16);
        digest[i*4 + 2] = (uint8_t)(H[i] >>  8);
        digest[i*4 + 3] = (uint8_t)(H[i]      ); /* LSB */
    }
    
  '| {style.fill: transparent; style.stroke: transparent}

  offset_table: |'md
    | Word | digest bytes | SHA-256("abc") value |
    |------|-------------|----------------------|
    | H[0] | [0..3]      | BA 78 16 BF          |
    | H[1] | [4..7]      | 8F 01 CF EA          |
    | H[2] | [8..11]     | 41 41 40 DE          |
    | H[3] | [12..15]    | 5D AE 22 23          |
    | H[4] | [16..19]    | B0 03 61 A3          |
    | H[5] | [20..23]    | 96 17 7A 9C          |
    | H[6] | [24..27]    | B4 10 FF 61          |
    | H[7] | [28..31]    | F2 00 15 AD          |
  '| {style.fill: transparent; style.stroke: transparent}

  formula -> offset_table: "applies to each\nH[0]..H[7]" {
    style.stroke: "#f57f17"
    style.stroke-dash: 3
  }
}

correct -> generalloop: "same rule\napplied ×8" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
  style.stroke-dash: 3
}

wrong -> generalloop: "never use\nthis path" {
  style.stroke: "#c62828"
  style.stroke-width: 2
  style.stroke-dash: 5
}

endianness_note: |'md
  **Implementation Critical:**
  SHA-256 is big-endian (FIPS 180-4).
  The shift-and-mask construction is the **endianness bridge** —
  it produces identical byte sequences on ALL platforms.
  `memcpy` of a native integer produces platform-dependent results.
'| {
  near: top-right
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.stroke-width: 1
  style.font-color: "#0d47a1"
  style.border-radius: 8
  style.font-size: 13
}