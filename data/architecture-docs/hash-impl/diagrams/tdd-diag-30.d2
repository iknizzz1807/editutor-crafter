vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  ## Data Flow: Merkle-Damgård Multi-Block Chain
  `sha256_oneshot()` — 56-byte Input ("abcdbcde…nopq")
| {near: top-center}

# ── Initial State ────────────────────────────────────────────────────────────
init: "SHA256_INITIAL_HASH" {
  style.fill: "#9B59B6"
  style.font-color: white
  style.bold: true
  style.border-radius: 6
  label: |md
    **SHA256_INITIAL_HASH[8]**
    H[0] = 0x6a09e667
    H[1] = 0xbb67ae85
    H[2] = 0x3c6ef372
    H[3] = 0xa54ff53a
    H[4] = 0x510e527f
    H[5] = 0x9b05688c
    H[6] = 0x1f83d9ab
    H[7] = 0x5be0cd19
  |
}

# ── Block 0 (64 bytes) ───────────────────────────────────────────────────────
block0: "Block 0 — 64 bytes" {
  style.fill: "#2980B9"
  style.font-color: white
  style.border-radius: 6
  msg_bytes: "Message bytes" {
    style.fill: "#3498DB"
    style.font-color: white
    style.border-radius: 4
    label: |md
      **bytes [0..55]**
      56 × message bytes
      "abcdbcde…nopq"
    |
  }
  marker: "0x80 marker" {
    style.fill: "#7F8C8D"
    style.font-color: white
    style.border-radius: 4
    label: |md
      **byte [56]**
      0x80
      "1 bit" separator
    |
  }
  zero_fill_b0: "Zero fill" {
    style.fill: "#95A5A6"
    style.font-color: white
    style.border-radius: 4
    label: |md
      **bytes [57..63]**
      0x00 × 7
      (no room for length field)
    |
  }
  msg_bytes -> marker -> zero_fill_b0 {
    style.stroke-dash: 3
    style.stroke: "#BDC3C7"
  }
}

compress0: "sha256_compress\n(H, block[0])" {
  style.fill: "#E67E22"
  style.font-color: white
  style.bold: true
  style.border-radius: 6
  style.shadow: true
  label: |md
    **sha256_compress(H, block[0])**
    ① sha256_message_schedule → W[0..63]
    ② a..h ← H[0..7]
    ③ 64 rounds: T1, T2, rotate
    ④ H[i] += working_var[i]  ← feed-forward
    H modified **in place**
  |
}

h_mid: "H after block 0" {
  style.fill: "#E67E22"
  style.font-color: white
  style.border-radius: 6
  label: |md
    **H[0..7]  (updated)**
    H is the same array —
    modified in place by +=
    Carries entropy of
    all 56 message bytes
  |
}

# ── Block 1 (64 bytes) ───────────────────────────────────────────────────────
block1: "Block 1 — 64 bytes" {
  style.fill: "#2980B9"
  style.font-color: white
  style.border-radius: 6
  zero_fill_b1: "Zero fill" {
    style.fill: "#95A5A6"
    style.font-color: white
    style.border-radius: 4
    label: |md
      **bytes [0..55]**
      0x00 × 56
    |
  }
  length_field: "64-bit length field" {
    style.fill: "#C0392B"
    style.font-color: white
    style.border-radius: 4
    label: |md
      **bytes [56..63]**
      0x00 0x00 0x00 0x00
      0x00 0x00 0x01 0xC0
      = 448 bits (56 × 8)
      big-endian, explicit shifts
    |
  }
  zero_fill_b1 -> length_field {
    style.stroke-dash: 3
    style.stroke: "#BDC3C7"
  }
}

compress1: "sha256_compress\n(H, block[1])" {
  style.fill: "#E67E22"
  style.font-color: white
  style.bold: true
  style.border-radius: 6
  style.shadow: true
  label: |md
    **sha256_compress(H, block[1])**
    ① sha256_message_schedule → W[0..63]
    ② a..h ← H[0..7]  ← from block[0] output
    ③ 64 rounds: T1, T2, rotate
    ④ H[i] += working_var[i]
    H modified **in place** again
  |
}

h_final: "H final — digest words" {
  style.fill: "#27AE60"
  style.font-color: white
  style.bold: true
  style.border-radius: 6
  label: |md
    **H[0..7]  (final)**
    H[0] = 0x248d6a61
    H[1] = 0xd20638b8
    H[2] = 0xe5c02693
    H[3] = 0x0c3e6039
    H[4] = 0xa33ce459
    H[5] = 0x64ff2167
    H[6] = 0xf6ecedd4
    H[7] = 0x19db06c1
  |
}

# ── Serialize ─────────────────────────────────────────────────────────────────
serialize: "Serialize H → digest[32]" {
  style.fill: "#1ABC9C"
  style.font-color: white
  style.border-radius: 6
  label: |md
    **Big-endian byte extraction**
    digest[i×4+0] = H[i] >> 24
    digest[i×4+1] = H[i] >> 16
    digest[i×4+2] = H[i] >>  8
    digest[i×4+3] = H[i]
    (NOT memcpy — endianness-safe)
  |
}

digest_buf: "digest[32]" {
  style.fill: "#16A085"
  style.font-color: white
  style.border-radius: 6
  label: |md
    **uint8_t digest[32]**
    0x24 0x8d 0x6a 0x61
    0xd2 0x06 0x38 0xb8 …
    32 raw bytes
  |
}

# ── Hex Encode ────────────────────────────────────────────────────────────────
hex_fn: "sha256_to_hex()" {
  style.fill: "#8E44AD"
  style.font-color: white
  style.border-radius: 6
  label: |md
    **sha256_to_hex(digest, hex)**
    hex[i×2]   = "0123456789abcdef"[byte >> 4]
    hex[i×2+1] = "0123456789abcdef"[byte & 0x0F]
    hex[64] = '\0'
  |
}

hex_out: "hex[65]" {
  style.fill: "#6C3483"
  style.font-color: white
  style.bold: true
  style.border-radius: 6
  label: |md
    **char hex[65]**
    "248d6a61d20638b8
    e5c026930c3e6039
    a33ce45964ff2167
    f6ecedd419db06c1"
    + '\0'
  |
}

# ── Merkle-Damgård annotation ─────────────────────────────────────────────────
md_note: |md
  **Merkle-Damgård Chain**
  H is the same `uint32_t[8]` array
  throughout both calls.
  `sha256_compress()` modifies H **in place**
  via `H[i] += working_var[i]`.
  Block 1 starts from Block 0's output state —
  not from SHA256_INITIAL_HASH.
  This cumulative chaining is what makes
  the final digest depend on every input bit.
| {
  near: bottom-center
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
  style.border-radius: 8
  style.font-color: "#784212"
}

# ── Connections ───────────────────────────────────────────────────────────────
init -> compress0: "H[0..7] ← initial values\ncopied into local H array" {
  style.stroke: "#9B59B6"
  style.stroke-width: 2
  style.bold: true
}
block0 -> compress0: "block pointer\n(64 bytes)" {
  style.stroke: "#2980B9"
  style.stroke-width: 2
}
compress0 -> h_mid: "H[i] += working_var[i]\n(mod 2³²)\nfeed-forward complete" {
  style.stroke: "#E67E22"
  style.stroke-width: 3
  style.bold: true
  style.animated: true
}
h_mid -> compress1: "same H array\npassed again\n(cumulative state)" {
  style.stroke: "#E67E22"
  style.stroke-width: 3
  style.bold: true
  style.stroke-dash: 0
}
block1 -> compress1: "block pointer\n(64 bytes)" {
  style.stroke: "#2980B9"
  style.stroke-width: 2
}
compress1 -> h_final: "H[i] += working_var[i]\nfinal state encodes\nall 56 input bytes" {
  style.stroke: "#27AE60"
  style.stroke-width: 3
  style.bold: true
  style.animated: true
}
h_final -> serialize: "H[0..7] → bytes\nbig-endian extraction" {
  style.stroke: "#1ABC9C"
  style.stroke-width: 2
}
serialize -> digest_buf: "32 raw bytes" {
  style.stroke: "#16A085"
  style.stroke-width: 2
}
digest_buf -> hex_fn: "nibble lookup" {
  style.stroke: "#8E44AD"
  style.stroke-width: 2
}
hex_fn -> hex_out: "64 lowercase\nhex chars + \0" {
  style.stroke: "#6C3483"
  style.stroke-width: 2
}