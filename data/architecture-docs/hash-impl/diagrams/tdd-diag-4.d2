vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

direction: right

title: |'md
## Data Flow: Raw Bytes → sha256_pad() → Indexed Block Array
*FIPS 180-4 §5.1.1 — Module hash-impl-m1*
'| {near: top-center}

caller: "Caller" {
  shape: rectangle
  style.fill: "#E8E8E8"
  style.stroke: "#888888"
  style.bold: true
  msg_in: |'md
    `const uint8_t *msg`
    `size_t len`
  '| {
    shape: rectangle
    style.fill: "#D5D5D5"
    style.stroke: "#888"
    style.font-size: 13
  }
}

pad_fn: "sha256_pad(msg, len, out)" {
  shape: rectangle
  style.fill: "#EDE7F6"
  style.stroke: "#7B1FA2"
  style.bold: true
  style.border-radius: 4
  
  step1: "① memset(out, 0, sizeof)" {
    shape: rectangle
    style.fill: "#BDBDBD"
    style.stroke: "#757575"
    style.font-size: 13
    style.bold: false
    tooltip: "Zero-initialise entire sha256_padded_t. Handles zero-fill implicitly."
  }
  step2: "② memcpy(out→data, msg, len)" {
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke: "#1565C0"
    style.font-size: 13
    style.bold: false
    tooltip: "Copy original message bytes verbatim. Skipped if len==0."
  }
  step3: "③ out→data[len] = 0x80" {
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke: "#1565C0"
    style.font-size: 13
    style.bold: false
    tooltip: "Append the mandatory '1 bit' separator: 0x80 = 10000000₂"
  }
  step4: "④ total_padded = ⌈(len+9)/64⌉×64" {
    shape: rectangle
    style.fill: "#CE93D8"
    style.stroke: "#6A1B9A"
    style.font-size: 13
    style.bold: false
    tooltip: "used = len+1; total_padded = ((used+8+63)/64)*64"
  }
  step5: "⑤ write_be64(out→data + total_padded − 8, len×8)" {
    shape: rectangle
    style.fill: "#FFF176"
    style.stroke: "#F57F17"
    style.font-size: 13
    style.bold: false
    tooltip: "64-bit big-endian bit-length field at last 8 bytes of padded buffer"
  }
  step6: "⑥ out→num_blocks = total_padded / 64" {
    shape: rectangle
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
    style.font-size: 13
    style.bold: false
    tooltip: "Set block count. return 0."
  }
  
  step1 -> step2: "all zeros\nset"
  step2 -> step3: "msg bytes\ncopied"
  step3 -> step4: "0x80\nwritten"
  step4 -> step5: "total_padded\ncomputed"
  step5 -> step6: "length field\nwritten"
}

out_struct: "sha256_padded_t *out" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.bold: true
  
  buf_layout: "out→data[0 .. total_padded−1]" {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
    style.font-size: 13
    
    seg_msg: "msg bytes\n[0 .. len−1]\nColor: Blue" {
      shape: rectangle
      style.fill: "#64B5F6"
      style.stroke: "#1565C0"
      style.font-size: 12
    }
    seg_marker: "0x80\n[len]\nColor: Orange" {
      shape: rectangle
      style.fill: "#FFB74D"
      style.stroke: "#E65100"
      style.font-size: 12
    }
    seg_zero: "0x00…\nzero fill\nColor: Gray" {
      shape: rectangle
      style.fill: "#BDBDBD"
      style.stroke: "#616161"
      style.font-size: 12
    }
    seg_len: "64-bit BE\nlength (bits)\n[−8..−1]\nColor: Yellow" {
      shape: rectangle
      style.fill: "#FFF176"
      style.stroke: "#F57F17"
      style.font-size: 12
    }
    
    seg_msg -> seg_marker -> seg_zero -> seg_len: {
      style.stroke-dash: 0
      style.stroke: "#888"
      style.font-size: 11
    }
  }
  
  num_blocks_field: "out→num_blocks\n= total_padded / 64\n∈ [1, MAX_PADDED_BLOCKS]" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.font-size: 13
  }
  
  bounds_note: |'md
    **Block alignment invariant:**
    `total_padded % 64 == 0`
    `data[len] == 0x80`
    `data[−8..−1]` = big-endian `len×8`
  '| {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.font-size: 12
  }
}

get_block_fn: "sha256_get_block(padded, i)" {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F57F17"
  style.bold: true
  
  ptr_arith: "return padded→data\n  + i × 64" {
    shape: rectangle
    style.fill: "#FFE082"
    style.stroke: "#F57F17"
    style.font-size: 13
    tooltip: "O(1) pointer arithmetic. No copy. Block i starts at byte offset i*64."
  }
  block_ptr: "const uint8_t *block\n[64 bytes, block i]" {
    shape: rectangle
    style.fill: "#FFD54F"
    style.stroke: "#E65100"
    style.font-size: 13
    style.bold: true
  }
  ptr_arith -> block_ptr: "pointer\nreturned"
}

compress_fn: "sha256_compress(H, block)\n(Milestone 3)" {
  shape: rectangle
  style.fill: "#FCE4EC"
  style.stroke: "#880E4F"
  style.bold: true
  style.border-radius: 4
}

block_loop: "for i = 0 .. num_blocks−1" {
  shape: rectangle
  style.fill: "#E0E0E0"
  style.stroke: "#424242"
  style.bold: true
  style.border-radius: 8
}

be64_helper: "write_be64(buf, val)" {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.font-size: 13
  be64_detail: |'md
    c
    buf[0] = val >> 56;
    buf[1] = val >> 48;
    ...
    buf[7] = val;
    
    Platform-independent.
    memcpy of native uint64_t
    is WRONG on x86 (LE).
  '| {
    shape: rectangle
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"
    style.font-size: 12
  }
}

boundary_note: |'md
**Boundary: len=56 → TWO blocks**

| len | used | total_padded | blocks |
|-----|------|-------------|--------|
| 0   | 1    | 64          | 1      |
| 3   | 4    | 64          | 1      |
| 55  | 56   | 64          | 1      |
| **56**  | **57**   | **128**     | **2**  |
| 63  | 64   | 128         | 2      |
'| {
  near: bottom-center
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#F57F17"
  style.font-size: 12
  style.border-radius: 4
}

# Connections
caller.msg_in -> pad_fn.step1: "msg, len\n(entry)" {
  style.stroke: "#7B1FA2"
  style.bold: true
}
pad_fn.step6 -> out_struct.buf_layout: "padded\nbuffer" {
  style.stroke: "#1565C0"
  style.bold: true
}
pad_fn.step6 -> out_struct.num_blocks_field: "block\ncount" {
  style.stroke: "#2E7D32"
}
pad_fn.step5 -> be64_helper: "calls\nfor length\nfield" {
  style.stroke: "#F57F17"
  style.stroke-dash: 4
}
out_struct.num_blocks_field -> block_loop: "num_blocks\ndrives loop" {
  style.stroke: "#424242"
  style.bold: true
}
out_struct.buf_layout -> get_block_fn.ptr_arith: "data[]\nbase pointer" {
  style.stroke: "#E65100"
}
block_loop -> get_block_fn.ptr_arith: "index i" {
  style.stroke: "#424242"
}
get_block_fn.block_ptr -> compress_fn: "64-byte\nblock pointer\n(one per iteration)" {
  style.stroke: "#880E4F"
  style.bold: true
}
block_loop -> compress_fn: "iterates\nnum_blocks times" {
  style.stroke: "#880E4F"
  style.stroke-dash: 5
}