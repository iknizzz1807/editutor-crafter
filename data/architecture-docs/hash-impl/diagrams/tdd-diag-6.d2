vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Algorithm Steps: Concrete Padding Trace
  **FIPS 180-4 §5.1.1 — Four Test Cases: Empty, "abc", 55-byte, 56-byte**
| {near: top-center}
# ─── STEP LEGEND ────────────────────────────────────────────────────────────
legend: {
  near: bottom-center
  style.fill: "#F0F0F0"
  style.stroke: "#888888"
  style.border-radius: 6
  label: |md
    **Color Key:**
    🟣 Header/Input  🔵 Message bytes  ⬜ Zero fill  🟠 Length field  🔴 Boundary trap
  |
}
# ─── CASE 1: EMPTY MESSAGE ───────────────────────────────────────────────────
case1: "Case 1: Empty Message  (len=0, 0 bits)" {
  style.fill: "#F8F4FF"
  style.stroke: "#7B61FF"
  style.border-radius: 8
  input1: Input {
    shape: rectangle
    style.fill: "#C8B8FF"
    style.stroke: "#7B61FF"
    label: "msg = NULL,  len = 0 bytes,  bit_length = 0"
  }
  step1a: "Step 1: Append 0x80" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    label: |md
      `data[0] = 0x80`
      used = 0 + 1 = **1**
    |
  }
  step1b: "Step 2: Compute total_padded" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    label: |md
      used=1,  used+8=9
      `((1+8+63)/64)*64 = (72/64)*64 = 1*64 = 64`
      total_padded = **64 bytes**
    |
  }
  step1c: "Step 3: Zero fill" {
    shape: rectangle
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    label: |md
      Bytes 1..55 = 0x00  →  **55 zero bytes**
      (memset handles this via initial memset of entire struct)
    |
  }
  step1d: "Step 4: Length field @ data[56..63]" {
    shape: rectangle
    style.fill: "#FED7AA"
    style.stroke: "#F97316"
    label: |md
      bit_length = 0 × 8 = 0
      `00 00 00 00 00 00 00 00`
    |
  }
  result1: Buffer Layout (64 bytes = 1 block) {
    shape: rectangle
    style.fill: "#1E1B4B"
    style.font-color: white
    style.border-radius: 4
    label: |md
      `[00] 0x80`
      `[01..55] 0x00 × 55`
      `[56..63] 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00`
      **num_blocks = 1**
    |
  }
  input1 -> step1a -> step1b -> step1c -> step1d -> result1
}
# ─── CASE 2: "abc" (3 bytes) ─────────────────────────────────────────────────
case2: "Case 2: \"abc\"  (len=3, 24 bits)" {
  style.fill: "#F0FDF4"
  style.stroke: "#22C55E"
  style.border-radius: 8
  input2: Input {
    shape: rectangle
    style.fill: "#C8B8FF"
    style.stroke: "#7B61FF"
    label: "msg = 0x61 0x62 0x63,  len = 3 bytes,  bit_length = 24"
  }
  step2a: "Step 1: Copy msg + append 0x80" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    label: |md
      `data[0]=0x61  data[1]=0x62  data[2]=0x63  data[3]=0x80`
      used = 3 + 1 = **4**
    |
  }
  step2b: "Step 2: Compute total_padded" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    label: |md
      used=4,  used+8=12
      `((4+8+63)/64)*64 = (75/64)*64 = 1*64 = 64`
      total_padded = **64 bytes**
    |
  }
  step2c: "Step 3: Zero fill" {
    shape: rectangle
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    label: |md
      Bytes 4..55 = 0x00  →  **52 zero bytes**
    |
  }
  step2d: "Step 4: Length field @ data[56..63]" {
    shape: rectangle
    style.fill: "#FED7AA"
    style.stroke: "#F97316"
    label: |md
      bit_length = 3 × 8 = 24 = 0x0000000000000018
      `00 00 00 00 00 00 00 18`
    |
  }
  result2: Buffer Layout (64 bytes = 1 block) {
    shape: rectangle
    style.fill: "#14532D"
    style.font-color: white
    style.border-radius: 4
    label: |md
      `[00..02] 0x61 0x62 0x63`  ← message bytes
      `[03]     0x80`             ← marker
      `[04..55] 0x00 × 52`       ← zero fill
      `[56..63] 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x18`
      **num_blocks = 1**
    |
  }
  input2 -> step2a -> step2b -> step2c -> step2d -> result2
}
# ─── CASE 3: 55-byte message ─────────────────────────────────────────────────
case3: "Case 3: 55-byte message  (len=55, 440 bits)  ← LAST single-block case" {
  style.fill: "#FFFBEB"
  style.stroke: "#F59E0B"
  style.border-radius: 8
  input3: Input {
    shape: rectangle
    style.fill: "#C8B8FF"
    style.stroke: "#7B61FF"
    label: "msg = 0xAA × 55,  len = 55 bytes,  bit_length = 440"
  }
  step3a: "Step 1: Copy msg + append 0x80" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    label: |md
      `data[0..54] = 0xAA × 55`
      `data[55]    = 0x80`
      used = 55 + 1 = **56**
    |
  }
  step3b: "Step 2: Compute total_padded" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    label: |md
      used=56,  used+8=64
      `((56+8+63)/64)*64 = (127/64)*64 = 1*64 = 64`
      total_padded = **64 bytes**
    |
  }
  step3c: "Step 3: Zero fill" {
    shape: rectangle
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    label: |md
      Bytes 56..55 = **0 zero bytes** (marker lands exactly at byte 55)
      Length field goes immediately at byte 56
    |
  }
  step3d: "Step 4: Length field @ data[56..63]" {
    shape: rectangle
    style.fill: "#FED7AA"
    style.stroke: "#F97316"
    label: |md
      bit_length = 55 × 8 = 440 = 0x00000000000001B8
      `00 00 00 00 00 00 01 B8`
    |
  }
  result3: Buffer Layout (64 bytes = 1 block) {
    shape: rectangle
    style.fill: "#78350F"
    style.font-color: white
    style.border-radius: 4
    label: |md
      `[00..54] 0xAA × 55`        ← message bytes
      `[55]     0x80`              ← marker (0 zero-fill bytes after!)
      `[56..63] 0x00 0x00 0x00 0x00 0x00 0x00 0x01 0xB8`
      **num_blocks = 1**
    |
  }
  boundary_ok: "✓ 55 bytes fits in ONE block" {
    shape: rectangle
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    style.font-color: "#065F46"
    style.bold: true
    label: "used=56 ≤ 56 ⟹ single block  ✓"
  }
  input3 -> step3a -> step3b -> step3c -> step3d -> result3 -> boundary_ok
}
# ─── CASE 4: 56-byte message — THE BOUNDARY TRAP ─────────────────────────────
case4: "Case 4: 56-byte message  (len=56, 448 bits)  ← THE BOUNDARY TRAP" {
  style.fill: "#FFF1F2"
  style.stroke: "#EF4444"
  style.stroke-width: 3
  style.border-radius: 8
  input4: Input {
    shape: rectangle
    style.fill: "#C8B8FF"
    style.stroke: "#7B61FF"
    label: "msg = 0xBB × 56,  len = 56 bytes,  bit_length = 448"
  }
  step4a: "Step 1: Copy msg + append 0x80" {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    label: |md
      `data[0..55] = 0xBB × 56`
      `data[56]    = 0x80`
      used = 56 + 1 = **57**
    |
  }
  step4b: "Step 2: Compute total_padded  ← TRIGGERS 2-BLOCK PATH" {
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 2
    label: |md
      used=57,  used+8=65
      `((57+8+63)/64)*64 = (128/64)*64 = 2*64 = 128`
      total_padded = **128 bytes  ← TWO BLOCKS**
    |
  }
  step4c: "Step 3: Zero fill (spans two blocks)" {
    shape: rectangle
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    label: |md
      Block 0 tail:  bytes 57..63 = 0x00 × 7
      Block 1 body:  bytes 64..119 = 0x00 × 56
      Total zero fill = **63 bytes**
    |
  }
  step4d: "Step 4: Length field @ data[120..127]" {
    shape: rectangle
    style.fill: "#FED7AA"
    style.stroke: "#F97316"
    label: |md
      bit_length = 56 × 8 = 448 = 0x00000000000001C0
      `00 00 00 00 00 00 01 C0`  at bytes 120..127
    |
  }
  block0: Block 0  (bytes 0..63) {
    shape: rectangle
    style.fill: "#7F1D1D"
    style.font-color: white
    style.border-radius: 4
    label: |md
      `[00..55] 0xBB × 56`   ← message bytes
      `[56]     0x80`         ← marker
      `[57..63] 0x00 × 7`    ← zero fill
    |
  }
  block1: Block 1  (bytes 64..127) {
    shape: rectangle
    style.fill: "#7F1D1D"
    style.font-color: white
    style.border-radius: 4
    label: |md
      `[64..119] 0x00 × 56`                          ← zero fill
      `[120..127] 0x00 0x00 0x00 0x00 0x00 0x00 0x01 0xC0`  ← length field
    |
  }
  result4: "num_blocks = 2  ← CRITICAL" {
    shape: rectangle
    style.fill: "#991B1B"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
    label: |md
      **num_blocks = 2**
      Compression function called TWICE
    |
  }
  boundary_trap: "⚠ THE BOUNDARY TRAP" {
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 2
    style.font-color: "#7F1D1D"
    style.bold: true
    label: |md
      used=57 **> 56**  ⟹  two blocks required!
      One extra byte (56→57) triggers an entirely new block.
      55 bytes → 1 block.  56 bytes → 2 blocks.
      This is the #1 first-attempt implementation error.
    |
  }
  input4 -> step4a -> step4b -> step4c -> step4d -> block0
  step4d -> block1
  block0 -> result4
  block1 -> result4
  result4 -> boundary_trap
}
# ─── COMPARISON SUMMARY TABLE ────────────────────────────────────────────────
summary: "Summary: All Four Cases Side-by-Side" {
  style.fill: "#F8FAFC"
  style.stroke: "#64748B"
  style.border-radius: 8
  table: {
    shape: sql_table
    label: "Padding Outcome Table"
    "Input": "Value"
    "len (bytes)": "0  |  3  |  55  |  56"
    "bit_length": "0  |  24  |  440  |  448"
    "used after 0x80": "1  |  4  |  56  |  57"
    "used+8": "9  |  12  |  64  |  65"
    "total_padded (bytes)": "64  |  64  |  64  |  128"
    "num_blocks": "1  |  1  |  1  |  ⚠ 2"
    "zero fill bytes": "55  |  52  |  0  |  63"
    "length field (hex)": "..00  |  ..18  |  ..01B8  |  ..01C0"
  }
  formula: {
    shape: rectangle
    style.fill: "#EFF6FF"
    style.stroke: "#3B82F6"
    style.border-radius: 4
    label: |md
      **General formula:**
      `total_padded = ((used + 8 + 63) / 64) * 64`
      where `used = len + 1`
      **Boundary condition:**
      `if used > 56  →  2 blocks`
      `if used ≤ 56  →  1 block`
      **Common mistakes caught by these 4 tests:**
      1. Missing `+8` in numerator  →  55-byte case fails
      2. Wrong condition `>=` vs `>`  →  56-byte num_blocks=1 (wrong)
      3. Little-endian memcpy for length field  →  wrong hash everywhere
      4. `bit_length = len` instead of `len * 8`  →  length field off by ×8
    |
  }
  table -> formula
}
# ─── LAYOUT CONNECTIONS ──────────────────────────────────────────────────────
case1 -> case2: {style.stroke-dash: 3; style.stroke: "#94A3B8"}
case2 -> case3: {style.stroke-dash: 3; style.stroke: "#94A3B8"}
case3 -> case4: {
  style.stroke: "#EF4444"
  style.stroke-width: 3
  label: "ONE byte triggers\n2nd block"
}
case4 -> summary: {style.stroke-dash: 3; style.stroke: "#94A3B8"}