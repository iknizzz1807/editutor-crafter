layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  shape: text
  label: ||md
    ## Module Architecture: Message Schedule (hash-impl-m2)
    ### Schedule Functions, Macros, and Data Contracts
  ||
  near: top-center
}

# ── M1 Output (upstream) ─────────────────────────────────────────────────
m1_output: "sha256_get_block()" {
  shape: rectangle
  style: {
    fill: "#E8D5F5"
    stroke: "#7B2FBE"
    stroke-width: 2
    font-size: 13
    bold: true
  }
  ret: {
    label: ||md
      **returns:** `const uint8_t *`
      block_index × 64 byte offset
      into `sha256_padded_t.data[]`
      **size:** exactly 64 bytes
      **order:** big-endian, FIPS 180-4
    ||
    style: {
      fill: "#F3E8FF"
      stroke: "#C084FC"
    }
  }
}

# ── Input type ────────────────────────────────────────────────────────────
block_input: "`const uint8_t *block`" {
  shape: parallelogram
  style: {
    fill: "#DBEAFE"
    stroke: "#2563EB"
    font-size: 13
    bold: true
  }
}

m1_output -> block_input: "64-byte pointer\n(never written)" {
  style: {
    stroke: "#7B2FBE"
    stroke-width: 2
    bold: true
  }
}

# ── Macro Layer ───────────────────────────────────────────────────────────
macros: "Macro Layer" {
  style: {
    fill: "#F0FDF4"
    stroke: "#16A34A"
    stroke-width: 2
  }
  
  rotr32: "ROTR32(x, n)" {
    shape: rectangle
    style: {
      fill: "#DCFCE7"
      stroke: "#16A34A"
      font-size: 12
    }
    formula: {
      label: ||md
        `((uint32_t)(x) >> (n)) | ((uint32_t)(x) << (32-(n)))`
        **Type:** `uint32_t → uint32_t`
        **Precond:** n ∈ [1..31]
        **Property:** lossless — all bits preserved
        **UB guard:** n=0 or n=32 → undefined behavior
      ||
      style: {
        fill: "#F0FDF4"
        stroke: "#86EFAC"
      }
    }
    exported: {
      label: ||md
        ✅ **EXPORTED to M3**
        Used by SIGMA_UPPER_0, SIGMA_UPPER_1
      ||
      style: {
        fill: "#BBFFD0"
        stroke: "#16A34A"
      }
    }
  }

  shr32: "SHR32(x, n)" {
    shape: rectangle
    style: {
      fill: "#DCFCE7"
      stroke: "#16A34A"
      font-size: 12
    }
    formula: {
      label: ||md
        `((uint32_t)(x) >> (n))`
        **Type:** `uint32_t → uint32_t`
        **Property:** destructive — low n bits discarded
        **Fills:** vacated MSBs with zero (logical shift)
        **Note:** `uint32_t` guarantees logical not arithmetic shift
      ||
      style: {
        fill: "#F0FDF4"
        stroke: "#86EFAC"
      }
    }
    exported: {
      label: ||md
        ✅ **EXPORTED to M3**
        Used by SIGMA_LOWER_0, SIGMA_LOWER_1
      ||
      style: {
        fill: "#BBFFD0"
        stroke: "#16A34A"
      }
    }
  }

  sl0: "SIGMA_LOWER_0(x) — sigma0" {
    shape: rectangle
    style: {
      fill: "#FEF9C3"
      stroke: "#CA8A04"
      font-size: 12
      bold: true
    }
    formula: {
      label: ||md
        `ROTR32(x, 7) ^ ROTR32(x, 18) ^ SHR32(x, 3)`
        **FIPS 180-4:** §4.1.2 Eq. (4.6)
        **Constants:** (7, 18, 3)
        **Applied to:** W[t-15] in recurrence
        **Non-invertible:** SHR discards 3 bits
      ||
      style: {
        fill: "#FEFCE8"
        stroke: "#FDE047"
      }
    }
    private_note: {
      label: ||md
        🔒 **PRIVATE to M2**
        DO NOT USE in M3
        M3 uses SIGMA_UPPER_0 (2,13,22)
      ||
      style: {
        fill: "#FEF08A"
        stroke: "#CA8A04"
      }
    }
  }

  sl1: "SIGMA_LOWER_1(x) — sigma1" {
    shape: rectangle
    style: {
      fill: "#FEF9C3"
      stroke: "#CA8A04"
      font-size: 12
      bold: true
    }
    formula: {
      label: ||md
        `ROTR32(x, 17) ^ ROTR32(x, 19) ^ SHR32(x, 10)`
        **FIPS 180-4:** §4.1.2 Eq. (4.7)
        **Constants:** (17, 19, 10)
        **Applied to:** W[t-2] in recurrence
        **Non-invertible:** SHR discards 10 bits
      ||
      style: {
        fill: "#FEFCE8"
        stroke: "#FDE047"
      }
    }
    private_note: {
      label: ||md
        🔒 **PRIVATE to M2**
        DO NOT USE in M3
        M3 uses SIGMA_UPPER_1 (6,11,25)
      ||
      style: {
        fill: "#FEF08A"
        stroke: "#CA8A04"
      }
    }
  }
}

# ── sha256_message_schedule ───────────────────────────────────────────────
fn: "sha256_message_schedule()" {
  shape: rectangle
  style: {
    fill: "#EFF6FF"
    stroke: "#2563EB"
    stroke-width: 3
    bold: true
    font-size: 14
  }
  sig: {
    label: ||md
      `void sha256_message_schedule(`
      `    const uint8_t *block,`
      `    uint32_t W[64]`
      `)`
    ||
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
      font: mono
    }
  }

  phase_a: "Phase A — Parse W[0..15]" {
    shape: rectangle
    style: {
      fill: "#EFF6FF"
      stroke: "#93C5FD"
    }
    desc: {
      label: ||md
        **Loop:** `for t = 0..15`
        `W[t] = (block[t×4+0] << 24)`
        `     | (block[t×4+1] << 16)`
        `     | (block[t×4+2] <<  8)`
        `     | (block[t×4+3]      )`
        Big-endian extraction — explicit cast
        to `uint32_t` before each shift.
      ||
      style: {
        fill: "#F0F9FF"
        stroke: "#BAE6FD"
      }
    }
  }

  phase_b: "Phase B — Expand W[16..63]" {
    shape: rectangle
    style: {
      fill: "#EFF6FF"
      stroke: "#93C5FD"
    }
    desc: {
      label: ||md
        **Loop:** `for t = 16..63`
        `W[t] = sigma1(W[t-2])`
        `     + W[t-7]`
        `     + sigma0(W[t-15])`
        `     + W[t-16]  (mod 2^32)`
        `uint32_t` addition wraps automatically.
      ||
      style: {
        fill: "#F0F9FF"
        stroke: "#BAE6FD"
      }
    }
  }

  props: {
    label: ||md
      **Pure function:** same block → same W[0..63]
      **Thread-safe:** distinct (block, W) pairs concurrent
      **Stack:** W[64] = 256 bytes, caller-allocated
    ||
    style: {
      fill: "#DBEAFE"
      stroke: "#93C5FD"
    }
  }
}

# ── Output type ───────────────────────────────────────────────────────────
w_output: "uint32_t W[64]" {
  shape: parallelogram
  style: {
    fill: "#DBEAFE"
    stroke: "#2563EB"
    font-size: 13
    bold: true
  }
  layout: {
    label: ||md
      **W[0..15]:** parsed from block (big-endian)
      **W[16..63]:** recurrence expansion
      **Size:** 64 × 4 = 256 bytes
    ||
    style: {
      fill: "#EFF6FF"
      stroke: "#93C5FD"
    }
  }
}

# ── M3 Consumer ───────────────────────────────────────────────────────────
m3_consumer: "sha256_compress() — M3" {
  shape: rectangle
  style: {
    fill: "#FDF2F8"
    stroke: "#9333EA"
    stroke-width: 2
    font-size: 13
    bold: true
  }
  desc: {
    label: ||md
      Consumes `W[t]` for t = 0..63.
      Imports **ROTR32** and **SHR32**
      to build SIGMA_UPPER_0 and SIGMA_UPPER_1.
    ||
    style: {
      fill: "#FCE7F3"
      stroke: "#F0ABFC"
    }
  }
}

# ── Naming-confusion warning ──────────────────────────────────────────────
warning: {
  shape: text
  label: ||md
    ⚠️ **CRITICAL NAMING DISTINCTION**
    
    | Macro | Constants | Used In | FIPS Eq. |
    | :--- | :--- | :--- | :--- |
    | `SIGMA_LOWER_0` (sigma0) | (7, 18, 3) | **M2 schedule** | (4.6) |
    | `SIGMA_LOWER_1` (sigma1) | (17, 19, 10) | **M2 schedule** | (4.7) |
    | `SIGMA_UPPER_0` (Sigma0) | (2, 13, 22) | **M3 compress** | (4.4) |
    | `SIGMA_UPPER_1` (Sigma1) | (6, 11, 25) | **M3 compress** | (4.5) |
    
    Lowercase sigma uses **SHR** (destructive). Uppercase Sigma uses **ROTR** (lossless).
  ||
  near: bottom-center
  style: {
    fill: "#FFF7ED"
    stroke: "#F97316"
    stroke-width: 2
    font-size: 12
  }
}

# ── Connections ───────────────────────────────────────────────────────────
block_input -> fn: "block[0..63]\nread-only" {
  style: {
    stroke: "#2563EB"
    stroke-width: 2
  }
}

macros.rotr32 -> fn.phase_b: "ROTR32 usage" {
  style: {
    stroke: "#16A34A"
    stroke-dash: 3
  }
}

macros.shr32 -> fn.phase_b: "SHR32 usage" {
  style: {
    stroke: "#16A34A"
    stroke-dash: 3
  }
}

macros.sl0 -> fn.phase_b: "sigma0 applied" {
  style: {
    stroke: "#CA8A04"
    stroke-width: 2
  }
}

macros.sl1 -> fn.phase_b: "sigma1 applied" {
  style: {
    stroke: "#CA8A04"
    stroke-width: 2
  }
}

fn -> w_output: "Populate W" {
  style: {
    stroke: "#2563EB"
    stroke-width: 2
  }
}

w_output -> m3_consumer: "M3 input" {
  style: {
    stroke: "#9333EA"
    stroke-width: 2
  }
}

macros.rotr32 -> m3_consumer: "EXPORTED" {
  style: {
    stroke: "#16A34A"
    stroke-width: 2
    stroke-dash: 5
  }
}

macros.shr32 -> m3_consumer: "EXPORTED (unused)" {
  style: {
    stroke: "#16A34A"
    stroke-dash: 5
    opacity: 0.6
  }
}