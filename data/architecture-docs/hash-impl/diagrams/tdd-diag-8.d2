vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  near: top-center
  label: |md
    ## Data Flow: 64-byte Block → 16 Big-Endian Words → 64 Schedule Words
  |
}

# ─── Stage 1: Byte Parsing ───────────────────────────────────────────────
stage1: "Stage 1: Big-Endian Word Extraction W[0..15]" {
  style: {
    fill: "#E8E4F0"
    stroke: "#6B4FA0"
    stroke-width: 2
    border-radius: 8
  }

  b0: "block[0]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }
  b1: "block[1]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }
  b2: "block[2]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }
  b3: "block[3]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }

  w0_combine: "(uint32_t) OR" {
    shape: diamond
    style: {
      fill: "#4A90D9"
      font-color: white
    }
  }

  w0: "W[0] = 0x61626380\n(for 'abc' block)" {
    style: {
      fill: "#1A5FA8"
      font-color: white
      border-radius: 4
      bold: true
    }
  }

  b0 -> w0_combine: "<< 24" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  b1 -> w0_combine: "<< 16" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  b2 -> w0_combine: "<< 8" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  b3 -> w0_combine: "<< 0" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  w0_combine -> w0

  ellipsis_s1: "... (W[1]..W[14] same pattern)" {
    shape: text
    style: {
      font-color: "#555555"
      italic: true
    }
  }

  b60: "block[60]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }
  b61: "block[61]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }
  b62: "block[62]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }
  b63: "block[63]" {
    style: {
      fill: "#7B2D8B"
      font-color: white
      border-radius: 4
    }
  }

  w15_combine: "(uint32_t) OR" {
    shape: diamond
    style: {
      fill: "#4A90D9"
      font-color: white
    }
  }

  w15: "W[15] = 0x00000018\n(length: 24 bits)" {
    style: {
      fill: "#1A5FA8"
      font-color: white
      border-radius: 4
      bold: true
    }
  }

  b60 -> w15_combine: "<< 24" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  b61 -> w15_combine: "<< 16" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  b62 -> w15_combine: "<< 8" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  b63 -> w15_combine: "<< 0" {
    style: {
      stroke: "#E8A020"
      bold: true
      font-color: "#E8A020"
    }
  }
  w15_combine -> w15

  formula_s1: {
    label: |'md
      **Formula for W[t], t = 0..15:**
      W[t] = (block[t*4+0] << 24)
           | (block[t*4+1] << 16)
           | (block[t*4+2] <<  8)
           | (block[t*4+3]      )
    '|
    style: {
      fill: "#F0EBF8"
      stroke: "#9B6FCC"
      border-radius: 4
    }
  }
}

# ─── Stage 2: Schedule Expansion ─────────────────────────────────────────
stage2: "Stage 2: Schedule Expansion W[16..63]" {
  style: {
    fill: "#E4F0E8"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }

  wt_2: "W[t-2]" {
    style: {
      fill: "#1A5FA8"
      font-color: white
      border-radius: 4
      bold: true
    }
  }
  wt_7: "W[t-7]" {
    style: {
      fill: "#1A5FA8"
      font-color: white
      border-radius: 4
      bold: true
    }
  }
  wt_15: "W[t-15]" {
    style: {
      fill: "#1A5FA8"
      font-color: white
      border-radius: 4
      bold: true
    }
  }
  wt_16: "W[t-16]" {
    style: {
      fill: "#1A5FA8"
      font-color: white
      border-radius: 4
      bold: true
    }
  }

  sigma1_box: "σ₁(x)\nROTR(x,17) ⊕ ROTR(x,19) ⊕ SHR(x,10)" {
    style: {
      fill: "#C62828"
      font-color: white
      border-radius: 6
      bold: true
    }
  }
  sigma0_box: "σ₀(x)\nROTR(x,7) ⊕ ROTR(x,18) ⊕ SHR(x,3)" {
    style: {
      fill: "#AD1457"
      font-color: white
      border-radius: 6
      bold: true
    }
  }

  add_box: "+ mod 2³²\n(4-way addition)" {
    shape: diamond
    style: {
      fill: "#2E7D32"
      font-color: white
      bold: true
    }
  }

  wt: "W[t]\nt = 16..63" {
    style: {
      fill: "#1B5E20"
      font-color: white
      border-radius: 4
      bold: true
      font-size: 16
    }
  }

  wt_2 -> sigma1_box: "σ₁ applied" {
    style: {
      stroke: "#C62828"
      stroke-width: 2
      bold: true
      font-color: "#C62828"
    }
  }
  wt_15 -> sigma0_box: "σ₀ applied" {
    style: {
      stroke: "#AD1457"
      stroke-width: 2
      bold: true
      font-color: "#AD1457"
    }
  }

  sigma1_box -> add_box: "σ₁(W[t-2])" {
    style: {
      stroke: "#C62828"
      stroke-width: 2
      font-color: "#C62828"
    }
  }
  wt_7 -> add_box: "W[t-7]" {
    style: {
      stroke: "#1A5FA8"
      stroke-width: 2
      font-color: "#1A5FA8"
    }
  }
  sigma0_box -> add_box: "σ₀(W[t-15])" {
    style: {
      stroke: "#AD1457"
      stroke-width: 2
      font-color: "#AD1457"
    }
  }
  wt_16 -> add_box: "W[t-16]" {
    style: {
      stroke: "#1A5FA8"
      stroke-width: 2
      font-color: "#1A5FA8"
    }
  }

  add_box -> wt {
    style: {
      stroke: "#1B5E20"
      stroke-width: 3
      bold: true
    }
  }

  recurrence_note: {
    label: |md
      **Recurrence (FIPS 180-4 §6.2.2):**
      W[t] = σ₁(W[t-2]) + W[t-7] + σ₀(W[t-15]) + W[t-16]
      **σ₀ constants:** ROTR×7, ROTR×18, SHR×3
      **σ₁ constants:** ROTR×17, ROTR×19, SHR×10
      **+** = addition mod 2^32 (uint32_t wraps in C)
    |
    style: {
      fill: "#F1F8F2"
      stroke: "#4CAF50"
      border-radius: 4
    }
  }
}

# ─── Inter-Stage Connection ───────────────────────────────────────────────
chain_note: "W[0..15] feed into W[16..63] expansion" {
  shape: text
  style: {
    font-color: "#333333"
    bold: true
    font-size: 14
  }
}

stage1.w0 -> chain_note: {
  style: {
    stroke: "#1A5FA8"
    stroke-dash: 3
  }
}
stage1.w15 -> chain_note: {
  style: {
    stroke: "#1A5FA8"
    stroke-dash: 3
  }
}

chain_note -> stage2.wt_16: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    bold: true
  }
}
chain_note -> stage2.wt_15: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
chain_note -> stage2.wt_7: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    stroke-dash: 4
  }
}
chain_note -> stage2.wt_2: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    stroke-dash: 4
  }
}

# ─── Output Annotation ───────────────────────────────────────────────────
output_note: {
  label: |md
    **Final W[64] array (256 bytes)**
    Consumed by sha256_compress():
    one word W[t] per round, t = 0..63
  |
  style: {
    fill: "#FFF8E1"
    stroke: "#F9A825"
    border-radius: 6
  }
}

stage2.wt -> output_note: {
  style: {
    stroke: "#F9A825"
    stroke-width: 2
    bold: true
  }
}