direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: "SIGPIPE: Write to Closed Connection — Problem vs Fix" {
  near: top-center
  style: {
    font-size: 20
    bold: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  problem_col: "WITHOUT FIX — Default SIGPIPE Behavior" {
    direction: down
    style.fill: "#2d1a1a"
    style.stroke: "#cc3333"
    style.font-color: "#ff6666"
    style.bold: true
    s1: "① Client Sends Request" {
      shape: step
      style.fill: "#1a2d1a"
      style.stroke: "#44aa44"
      detail1: "GET /file.html HTTP/1.1" {
        style.fill: "#112211"
        style.stroke: "#226622"
        style.font-color: "#88cc88"
      }
    }
    s2: "② Client Closes Connection (FIN)" {
      shape: step
      style.fill: "#2d2d1a"
      style.stroke: "#aaaa00"
      detail2: "TCP FIN sent — client side closed" {
        style.fill: "#1a1a00"
        style.stroke: "#666600"
        style.font-color: "#cccc44"
      }
    }
    s3: "③ Server Computing Response" {
      shape: step
      style.fill: "#1a1a2d"
      style.stroke: "#4444aa"
      detail3: "stat() + read() + snprintf() headers" {
        style.fill: "#11112a"
        style.stroke: "#222266"
        style.font-color: "#8888cc"
      }
    }
    s4: "④ Server calls write() / send()" {
      shape: step
      style.fill: "#2d2d2d"
      style.stroke: "#888888"
      code4: |'c
        send(client_fd, buf, len, 0);
        // NO MSG_NOSIGNAL flag
      '|
      width: 380
    }
    s5: "⑤ Kernel: Detects Broken Pipe" {
      shape: step
      style.fill: "#3d1a00"
      style.stroke: "#ff6600"
      detail5: "TCP RST received from peer — EPIPE condition" {
        style.fill: "#1a0d00"
        style.stroke: "#883300"
        style.font-color: "#ff8844"
      }
    }
    s6: "⑥ Kernel Delivers SIGPIPE" {
      shape: step
      style.fill: "#3d0000"
      style.stroke: "#ff0000"
      detail6: "Signal sent to server process — default action: TERMINATE" {
        style.fill: "#1a0000"
        style.stroke: "#660000"
        style.font-color: "#ff4444"
      }
    }
    s7: "⑦ SERVER PROCESS KILLED" {
      shape: oval
      style.fill: "#660000"
      style.stroke: "#ff0000"
      style.font-color: "#ffffff"
      style.bold: true
      style.font-size: 14
    }
    s1 -> s2: "TCP stream"
    s2 -> s3: "FIN in flight"
    s3 -> s4: "compute done"
    s4 -> s5: "RST from kernel"
    s5 -> s6: "SIGPIPE raised" {
      style.stroke: "#ff4400"
      style.stroke-width: 3
    }
    s6 -> s7: "default handler" {
      style.stroke: "#ff0000"
      style.stroke-width: 4
      style.stroke-dash: 0
    }
  }
  fix_col: "WITH FIX — Graceful EPIPE Handling" {
    direction: down
    style.fill: "#1a2d1a"
    style.stroke: "#33cc33"
    style.font-color: "#66ff66"
    style.bold: true
    fix_setup: "Startup: Ignore SIGPIPE" {
      shape: step
      style.fill: "#112211"
      style.stroke: "#226622"
      code_setup: |'c
        signal(SIGPIPE, SIG_IGN);
        // Process-wide: SIGPIPE never kills server
      '|
      width: 400
    }
    f1: "① Client Sends Request" {
      shape: step
      style.fill: "#1a2d1a"
      style.stroke: "#44aa44"
      fdetail1: "GET /file.html HTTP/1.1" {
        style.fill: "#112211"
        style.stroke: "#226622"
        style.font-color: "#88cc88"
      }
    }
    f2: "② Client Closes Connection (FIN)" {
      shape: step
      style.fill: "#2d2d1a"
      style.stroke: "#aaaa00"
      fdetail2: "TCP FIN sent — client side closed" {
        style.fill: "#1a1a00"
        style.stroke: "#666600"
        style.font-color: "#cccc44"
      }
    }
    f3: "③ Server Computing Response" {
      shape: step
      style.fill: "#1a1a2d"
      style.stroke: "#4444aa"
      fdetail3: "stat() + read() + snprintf() headers" {
        style.fill: "#11112a"
        style.stroke: "#222266"
        style.font-color: "#8888cc"
      }
    }
    f4: "④ Server calls send() with check" {
      shape: step
      style.fill: "#1a2d1a"
      style.stroke: "#33aa33"
      code_f4: |'c
        // OPTION A: MSG_NOSIGNAL (per-call)
        n = send(fd, buf, len, MSG_NOSIGNAL);
        // OPTION B: SIG_IGN (process-wide)
        n = send(fd, buf, len, 0);
        if (n < 0) { /* check errno */ }
      '|
      width: 420
    }
    f5: "⑤ Kernel: Returns EPIPE Error" {
      shape: step
      style.fill: "#1a2d1a"
      style.stroke: "#44bb44"
      fdetail5_a: "errno == EPIPE" {
        style.fill: "#0d1a0d"
        style.stroke: "#226622"
        style.font-color: "#88dd88"
      }
      fdetail5_b: "No SIGPIPE delivered (SIG_IGN or MSG_NOSIGNAL)" {
        style.fill: "#0d1a0d"
        style.stroke: "#226622"
        style.font-color: "#88dd88"
      }
    }
    f6: "⑥ Server Checks Return Value" {
      shape: step
      style.fill: "#1a2a1a"
      style.stroke: "#33bb33"
      code_f6: |'c
        if (n < 0 && errno == EPIPE) {
            close(client_fd); // clean FD release
            return;           // worker ready for next
        }
      '|
      width: 400
    }
    f7: "⑦ SERVER CONTINUES RUNNING" {
      shape: oval
      style.fill: "#006600"
      style.stroke: "#00ff00"
      style.font-color: "#ffffff"
      style.bold: true
      style.font-size: 14
    }
    fix_setup -> f1: "startup done"
    f1 -> f2: "TCP stream"
    f2 -> f3: "FIN in flight"
    f3 -> f4: "compute done"
    f4 -> f5: "EPIPE returned" {
      style.stroke: "#44aa44"
      style.stroke-width: 3
    }
    f5 -> f6: "check errno" {
      style.stroke: "#44cc44"
    }
    f6 -> f7: "close FD cleanly" {
      style.stroke: "#00ff00"
      style.stroke-width: 4
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_note: "Kernel Internals: SIGPIPE Generation (server.c)" {
    direction: down
    style.fill: "#1a1a2d"
    style.stroke: "#4444bb"
    tcp_state: {
      shape: sql_table
      label: "TCP State at write() Time"
      r1: "client_fd  | int        | connected socket FD"
      r2: "tcp_state  | TCP_FIN    | FIN received from peer"
      r3: "snd_buf    | bytes      | kernel send buffer (still has space)"
      r4: "rcv_buf    | 0 bytes    | peer closed — RST will come"
      r5: "sk_err     | EPIPE      | error code set by TCP stack"
    }
    sigpipe_flow: "Kernel send() Path" {
      shape: step
      style.fill: "#11112a"
      style.stroke: "#333388"
      code_kern: |'c
        // Kernel: net/ipv4/tcp.c (simplified)
        if (sk->sk_shutdown & SEND_SHUTDOWN) {
            if (!(flags & MSG_NOSIGNAL))
                send_sig(SIGPIPE, current, 0);
            return -EPIPE;
        }
      '|
      width: 440
    }
    tcp_state -> sigpipe_flow: "send() invoked"
  }
  alt_note: "Alternative: MSG_NOSIGNAL (per-call) vs SIG_IGN (global)" {
    direction: down
    style.fill: "#2d2a1a"
    style.stroke: "#aaaa33"
    comparison: {
      shape: sql_table
      label: "Fix Comparison"
      h1: "Approach          | Scope        | Platform     | Recommended"
      r1: "signal(SIG_IGN)   | process-wide | POSIX all    | YES — servers"
      r2: "MSG_NOSIGNAL flag | per-call     | Linux only   | YES — portably"
      r3: "SO_NOSIGPIPE opt  | per-socket   | macOS/BSD    | macOS fallback"
      r4: "SIGPIPE handler   | process-wide | POSIX all    | NO — re-raises"
    }
    bsd_note: "macOS / BSD Note" {
      shape: step
      style.fill: "#1a180d"
      style.stroke: "#776622"
      code_bsd: |'c
        // macOS: MSG_NOSIGNAL not available
        // Use SO_NOSIGPIPE per socket instead:
        int opt = 1;
        setsockopt(fd, SOL_SOCKET,
                   SO_NOSIGPIPE, &opt, sizeof(opt));
        // Then plain send() is safe on macOS
      '|
      width: 440
    }
    comparison -> bsd_note: "platform note"
  }
}
row1 -> row2: "internals" {
  style.stroke-dash: 4
  style.stroke: "#555555"
}