direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
root: {
  label: "RAW BUFFER (char buf[8192])"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    bold: true
    font-size: 14
  }
}
check_ascii: {
  label: "Printable ASCII / valid bytes?"
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 13
  }
}
check_parse: {
  label: "Request line parseable?\n(METHOD SP PATH SP VERSION CRLF)"
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 13
  }
}
check_pathlen: {
  label: "Path length > 8192 bytes?"
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 13
  }
}
check_method: {
  label: "Method in {GET, HEAD}?"
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 13
  }
}
check_version: {
  label: "HTTP version == HTTP/1.1\nor HTTP/1.0?"
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 13
  }
}
check_host: {
  label: "Host header present?\n(required in HTTP/1.1)"
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 13
  }
}
leaf_row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  err_400_ascii: {
    label: "400 Bad Request"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    detail_ascii: "HTTP/1.1 400 Bad Request\r\nContent-Length: N\r\n\r\n<html>..."
    note_ascii: "Body: required (HTML error page)"
    trigger_ascii: "Trigger: NUL byte, non-printable ctrl chars"
  }
}
leaf_row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  err_400_parse: {
    label: "400 Bad Request"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    detail_parse: "HTTP/1.1 400 Bad Request\r\nContent-Length: N\r\n\r\n<html>..."
    note_parse: "Body: required (HTML error page)"
    trigger_parse: "Trigger: missing SP, empty method/path/version"
  }
}
leaf_row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  err_414: {
    label: "414 URI Too Long"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    detail_414: "HTTP/1.1 414 URI Too Long\r\nContent-Length: N\r\n\r\n<html>..."
    note_414: "Body: required (HTML error page)"
    trigger_414: "Trigger: path_len >= MAX_PATH_LEN (8192)"
  }
}
leaf_row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  err_501: {
    label: "501 Not Implemented"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    detail_501: "HTTP/1.1 501 Not Implemented\r\nContent-Length: N\r\n\r\n<html>..."
    note_501: "Body: required (HTML error page)"
    trigger_501: "Trigger: POST, PUT, DELETE, PATCH, etc."
  }
}
leaf_row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  err_400_ver: {
    label: "400 Bad Request"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    detail_400v: "HTTP/1.1 400 Bad Request\r\nContent-Length: N\r\n\r\n<html>..."
    note_400v: "Body: required"
    trigger_400v: "Trigger: garbled version string"
  }
  err_505: {
    label: "505 HTTP Version Not Supported"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    detail_505: "HTTP/1.1 505 HTTP Version Not Supported\r\nContent-Length: N\r\n\r\n<html>..."
    note_505: "Body: required"
    trigger_505: "Trigger: HTTP/2.0, HTTP/0.9, etc."
  }
}
leaf_row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  err_400_host: {
    label: "400 Bad Request"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    detail_host: "HTTP/1.1 400 Bad Request\r\nContent-Length: N\r\n\r\n<html>..."
    note_host: "Body: required (strict RFC 7230 compliance)"
    trigger_host: "Trigger: HTTP/1.1 request missing Host header"
  }
}
ok_continue: {
  label: "PASS — Continue to File Serving"
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#1B5E20"
    stroke-width: 2
    bold: true
    font-size: 14
  }
  note_pass: "method in {GET,HEAD} | path <= 8192 | version HTTP/1.x | Host present"
  next_pass: "→ url_decode() → realpath() → stat() → serve_file()"
}
root -> check_ascii
check_ascii -> leaf_row1.err_400_ascii: "No — invalid bytes" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
check_ascii -> check_parse: "Yes" {
  style.stroke: "#1B5E20"
}
check_parse -> leaf_row2.err_400_parse: "No — malformed" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
check_parse -> check_pathlen: "Yes" {
  style.stroke: "#1B5E20"
}
check_pathlen -> leaf_row3.err_414: "Yes — too long" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
check_pathlen -> check_method: "No — within limit" {
  style.stroke: "#1B5E20"
}
check_method -> leaf_row4.err_501: "No — unsupported method" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
check_method -> check_version: "Yes — GET or HEAD" {
  style.stroke: "#1B5E20"
}
check_version -> leaf_row5.err_400_ver: "No — garbled string" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
check_version -> leaf_row5.err_505: "No — valid but unsupported version" {
  style.stroke: "#E65100"
  style.stroke-dash: 4
}
check_version -> check_host: "Yes — HTTP/1.1 or HTTP/1.0" {
  style.stroke: "#1B5E20"
}
check_host -> leaf_row6.err_400_host: "No — missing Host (HTTP/1.1)" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
check_host -> ok_continue: "Yes — all checks pass" {
  style.stroke: "#1B5E20"
  style.stroke-width: 3
}