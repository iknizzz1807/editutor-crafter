direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "http_request_t Memory Layout (http_parse.h)" {
  near: top-center
  style.font-size: 18
  style.bold: true
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  req_struct: {
    shape: sql_table
    label: "struct http_request_t (http_parse.h)"
    f0:  "0x00 | http_method_t (enum) | method          // GET=0 HEAD=1 OTHER=2"
    pad0: "0x04 | uint8_t[4]          | _pad0           // alignment padding"
    f1:  "0x08 | char*               | path            // ptr into raw recv buf"
    f2:  "0x10 | size_t              | path_len        // bytes, max MAX_PATH_LEN"
    f3:  "0x18 | http_version_t(enum)| http_version    // HTTP10=0 HTTP11=1"
    pad1: "0x1C | uint8_t[4]          | _pad1           // alignment padding"
    f4:  "0x20 | header_kv_t*        | headers         // ptr to header array"
    f5:  "0x28 | int                 | header_count    // 0..MAX_HEADERS (32)"
    pad2: "0x2C | uint8_t[4]          | _pad2           // alignment padding"
    cl_boundary: "0x30 | --- CACHE LINE 1 END (48 B used of 64 B) ---"
    f6:  "0x30 | const char*         | body            // ptr past CRLFCRLF"
    f7:  "0x38 | size_t              | body_len        // 0 if no Content-Length"
    total: "Total: 64 bytes — fits in ONE 64-byte cache line"
  }
  cl_note: {
    label: "Cache-Line Semantics"
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#43a047"
    style.font-size: 13
    l1: "L1: method + path* + path_len + version" {
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
    }
    l2: "L2: headers* + header_count (same line)" {
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
    }
    l3: "L3: body* + body_len (same line)" {
      style.fill: "#dcedc8"
      style.stroke: "#558b2f"
    }
    note: "Hot dispatch path: method+path+headers* — 3 fields, 1 cache-line fetch" {
      style.fill: "#f9fbe7"
      style.stroke: "#827717"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hdr_struct: {
    shape: sql_table
    label: "struct header_kv_t (http_parse.h)"
    h0: "0x00 | char*  | name      // lowercase-normalized (e.g. 'content-type')"
    h1: "0x08 | size_t | name_len  // bytes, excl. NUL"
    h2: "0x10 | char*  | value     // trimmed OWS, unfolded obs-fold"
    h3: "0x18 | size_t | value_len // bytes, excl. NUL"
    ht: "Total: 32 bytes per entry — 2 entries per cache line"
  }
  arr_note: {
    label: "header_kv_t[] Layout"
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    style.font-size: 13
    a0: "headers[0]  @ base+0x00  (32 B)" {
      style.fill: "#bbdefb"
      style.stroke: "#1565c0"
    }
    a1: "headers[1]  @ base+0x20  (32 B) — shares cache line with [0]" {
      style.fill: "#bbdefb"
      style.stroke: "#1565c0"
    }
    a2: "headers[2]  @ base+0x40  (32 B) — new cache line" {
      style.fill: "#90caf9"
      style.stroke: "#0d47a1"
    }
    adots: "...up to headers[31]  @ base+0x3E0  (MAX_HEADERS=32)" {
      style.fill: "#e3f2fd"
      style.stroke: "#1976d2"
    }
    atotal: "Array total: 32 × 32 B = 1024 B (16 cache lines)" {
      style.fill: "#e8eaf6"
      style.stroke: "#3949ab"
    }
  }
  enum_note: {
    label: "Enum Definitions"
    shape: rectangle
    style.fill: "#fce4ec"
    style.stroke: "#c62828"
    style.font-size: 13
    e0: "http_method_t: GET=0  HEAD=1  POST=2  OTHER=3   (4 B)" {
      style.fill: "#ffcdd2"
      style.stroke: "#b71c1c"
    }
    e1: "http_version_t: HTTP10=0  HTTP11=1  UNKNOWN=2  (4 B)" {
      style.fill: "#ffcdd2"
      style.stroke: "#b71c1c"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parse_flow: {
    label: "Parse Pipeline (http_parse.c)"
    shape: rectangle
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
    style.font-size: 13
    s0: "recv() buf[8192]  — raw bytes off wire" {
      style.fill: "#e1bee7"
      style.stroke: "#6a1b9a"
    }
    s1: "scan for CRLFCRLF  — O(n) memchr loop" {
      style.fill: "#e1bee7"
      style.stroke: "#6a1b9a"
    }
    s2: "parse_request_line()  — memchr space×2, copy method/path/version" {
      style.fill: "#ce93d8"
      style.stroke: "#4a148c"
    }
    s3: "parse_headers()  — scan \\n, tolower name, strip OWS, unfold obs-fold" {
      style.fill: "#ce93d8"
      style.stroke: "#4a148c"
    }
    s4: "http_parse_request()  — fills http_request_t, returns 0 / -1 / -2 / -3" {
      style.fill: "#ba68c8"
      style.stroke: "#4a148c"
    }
    s5: "body ptr = buf + (headers_end_offset)" {
      style.fill: "#e1bee7"
      style.stroke: "#6a1b9a"
    }
    note_zero: "Zero-copy: path, body point INTO recv buf — no memcpy for values" {
      style.fill: "#f9fbe7"
      style.stroke: "#827717"
    }
  }
  lookup_flow: {
    label: "get_header() Lookup Path"
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    style.font-size: 13
    l0: "arg: const char* name  (must be lowercase)" {
      style.fill: "#c8e6c9"
      style.stroke: "#1b5e20"
    }
    l1: "linear scan: i=0..header_count-1" {
      style.fill: "#c8e6c9"
      style.stroke: "#1b5e20"
    }
    l2: "strcmp(headers[i].name, name) == 0  → return headers[i].value" {
      style.fill: "#a5d6a7"
      style.stroke: "#1b5e20"
    }
    l3: "return NULL if not found" {
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
    }
    perf: "N<=32: linear scan fits in 2 cache lines — faster than hash table" {
      style.fill: "#f9fbe7"
      style.stroke: "#827717"
    }
  }
}
row1 -> row2: "headers* | points to"
row1.req_struct.f4 -> row2.hdr_struct: "header_kv_t[] | heap/stack"
row2 -> row3: "parse flow | feeds"