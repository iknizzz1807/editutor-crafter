direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # HTTP/1.1 Request Wire Format — Annotated Byte Map
  Complete buffer layout · CRLF vs LF variants · End-of-headers boundary
| {near: top-center}
row_legend: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leg_method: {
    label: "METHOD token"
    style.fill: "#d32f2f"
    style.font-color: white
    style.border-radius: 4
  }
  leg_sp: {
    label: "SP (0x20)"
    style.fill: "#6a1aab"
    style.font-color: white
    style.border-radius: 4
  }
  leg_path: {
    label: "Request-Target"
    style.fill: "#1565c0"
    style.font-color: white
    style.border-radius: 4
  }
  leg_ver: {
    label: "HTTP-version"
    style.fill: "#00695c"
    style.font-color: white
    style.border-radius: 4
  }
  leg_crlf: {
    label: "CRLF (0x0D 0x0A)"
    style.fill: "#e65100"
    style.font-color: white
    style.border-radius: 4
  }
  leg_hname: {
    label: "Header Name"
    style.fill: "#37474f"
    style.font-color: white
    style.border-radius: 4
  }
  leg_colon: {
    label: "COLON + OWS"
    style.fill: "#827717"
    style.font-color: white
    style.border-radius: 4
  }
  leg_hval: {
    label: "Header Value"
    style.fill: "#0277bd"
    style.font-color: white
    style.border-radius: 4
  }
  leg_body: {
    label: "Body (optional)"
    style.fill: "#2e7d32"
    style.font-color: white
    style.border-radius: 4
  }
}
row_variants: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  variant_crlf: "VARIANT A — CRLF (canonical RFC 7230)" {
    direction: down
    style.fill: "#e3f2fd"
    style.border-radius: 6
    buf_request_line: {
      shape: sql_table
      label: "Request Line  [byte 0x00 … 0x1F]"
      style.fill: "#b71c1c"
      style.font-color: white
      f0: "0x00 | 3 bytes  | METHOD  → 'G','E','T'  (0x47 0x45 0x54)"
      f1: "0x03 | 1 byte   | SP      → ' '  (0x20)"
      f2: "0x04 | 12 bytes | path    → '/index.html'  (0x2F…)"
      f3: "0x10 | 1 byte   | SP      → ' '  (0x20)"
      f4: "0x11 | 8 bytes  | version → 'HTTP/1.1'  (0x48…)"
      f5: "0x19 | 1 byte   | CR      → '\\r'  (0x0D)"
      f6: "0x1A | 1 byte   | LF      → '\\n'  (0x0A)"
      total: "Total request line: 27 bytes  (0x00–0x1A inclusive)"
    }
    buf_hdr_host: {
      shape: sql_table
      label: "Header Line 1 — Host  [byte 0x1B … 0x2E]"
      style.fill: "#263238"
      style.font-color: white
      f0: "0x1B | 4 bytes  | name    → 'Host'  (0x48 0x6F 0x73 0x74)"
      f1: "0x1F | 1 byte   | COLON   → ':'  (0x3A)"
      f2: "0x20 | 1 byte   | OWS     → ' '  (0x20)"
      f3: "0x21 | 9 bytes  | value   → 'localhost'  (0x6C…)"
      f4: "0x2A | 1 byte   | CR      → '\\r'  (0x0D)"
      f5: "0x2B | 1 byte   | LF      → '\\n'  (0x0A)"
      total: "Total header 1: 17 bytes  (0x1B–0x2B inclusive)"
    }
    buf_hdr_ua: {
      shape: sql_table
      label: "Header Line 2 — User-Agent  [byte 0x2C … 0x4A]"
      style.fill: "#263238"
      style.font-color: white
      f0: "0x2C | 10 bytes | name    → 'User-Agent'  (0x55…)"
      f1: "0x36 | 1 byte   | COLON   → ':'  (0x3A)"
      f2: "0x37 | 1 byte   | OWS     → ' '  (0x20)"
      f3: "0x38 | 12 bytes | value   → 'curl/7.88.1'  (0x63…)"
      f4: "0x44 | 1 byte   | CR      → '\\r'  (0x0D)"
      f5: "0x45 | 1 byte   | LF      → '\\n'  (0x0A)"
      total: "Total header 2: 26 bytes  (0x2C–0x45 inclusive)"
    }
    buf_hdr_accept: {
      shape: sql_table
      label: "Header Line 3 — Accept  [byte 0x46 … 0x57]"
      style.fill: "#263238"
      style.font-color: white
      f0: "0x46 | 6 bytes  | name    → 'Accept'  (0x41…)"
      f1: "0x4C | 1 byte   | COLON   → ':'  (0x3A)"
      f2: "0x4D | 1 byte   | OWS     → ' '  (0x20)"
      f3: "0x4E | 3 bytes  | value   → '*/*'  (0x2A 0x2F 0x2A)"
      f4: "0x51 | 1 byte   | CR      → '\\r'  (0x0D)"
      f5: "0x52 | 1 byte   | LF      → '\\n'  (0x0A)"
      total: "Total header 3: 13 bytes  (0x46–0x52 inclusive)"
    }
    buf_eoh: {
      shape: sql_table
      label: "END-OF-HEADERS Boundary  [byte 0x53 … 0x54]"
      style.fill: "#e65100"
      style.font-color: white
      f0: "0x53 | 1 byte   | CR      → '\\r'  (0x0D)  ← CRLF #N"
      f1: "0x54 | 1 byte   | LF      → '\\n'  (0x0A)  ← forms \\r\\n\\r\\n with prev line"
      note: "strstr(buf, '\\r\\n\\r\\n') fires HERE — headers complete"
      total: "Empty line: 2 bytes at 0x53–0x54  |  Total header block: 85 bytes"
    }
    buf_body_a: {
      shape: sql_table
      label: "Body  [byte 0x55 … ]  — GET has no body; 0 bytes follow"
      style.fill: "#1b5e20"
      style.font-color: white
      f0: "0x55 | — | (empty)  Content-Length omitted for GET"
      note: "body_len = 0 · req->body pointer set to 0x55 (past empty line)"
    }
    buf_request_line -> buf_hdr_host: "parse_headers() start"
    buf_hdr_host -> buf_hdr_ua
    buf_hdr_ua -> buf_hdr_accept
    buf_hdr_accept -> buf_eoh: "CRLF pair detected"
    buf_eoh -> buf_body_a: "req->body = buf + 0x55"
  }
  variant_lf: "VARIANT B — Bare LF  (robustness requirement)" {
    direction: down
    style.fill: "#fff3e0"
    style.border-radius: 6
    lf_note: {
      shape: sql_table
      label: "Bare-LF Encoding  — same semantics, 1 byte shorter per line"
      style.fill: "#bf360c"
      style.font-color: white
      f0: "0x00 | 3 bytes  | 'GET'  (identical bytes)"
      f1: "0x03 | 1 byte   | SP  (0x20)"
      f2: "0x04 | 12 bytes | '/index.html'"
      f3: "0x10 | 1 byte   | SP  (0x20)"
      f4: "0x11 | 8 bytes  | 'HTTP/1.1'"
      f5: "0x19 | 1 byte   | LF ONLY → '\\n'  (0x0A)  — NO preceding 0x0D"
      total: "Request line: 26 bytes  (1 fewer than CRLF variant)"
    }
    lf_hdr: {
      shape: sql_table
      label: "Header Line — bare LF terminator"
      style.fill: "#4e342e"
      style.font-color: white
      f0: "0x1A | 4 bytes  | 'Host'"
      f1: "0x1E | 1 byte   | ':'"
      f2: "0x1F | 1 byte   | ' '"
      f3: "0x20 | 9 bytes  | 'localhost'"
      f4: "0x29 | 1 byte   | LF ONLY → '\\n'  (0x0A)  — strip trailing \\r if absent"
      total: "Header: 16 bytes (CRLF version was 17)"
    }
    lf_eoh: {
      shape: sql_table
      label: "END-OF-HEADERS — bare LF variant"
      style.fill: "#e65100"
      style.font-color: white
      f0: "0x?? | 1 byte | LF ONLY → '\\n'  (0x0A)"
      note: "Parser scans for \\n, strips optional leading \\r from prev line"
      total: "Empty line = 1 byte  |  Savings: N bytes vs CRLF (N = header count + 1)"
    }
    lf_parser: {
      shape: sql_table
      label: "Parser Robustness Rules (parse_headers.c)"
      style.fill: "#01579b"
      style.font-color: white
      r0: "Rule 1 | scan for \\n with memchr()  — finds both CRLF and bare LF"
      r1: "Rule 2 | after memchr(\\n): if line[line_len-1]=='\\r' then line_len--"
      r2: "Rule 3 | empty-line detect: line_len==0 after \\r strip → end of headers"
      r3: "Rule 4 | NEVER use strchr() — may read past valid buffer region"
      total: "Result: identical http_request_t produced for both Variant A and B"
    }
    lf_note -> lf_hdr
    lf_hdr -> lf_eoh
    lf_eoh -> lf_parser: "normalization path"
  }
}
row_eoh_annotation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ann_eoh: "End-of-Headers Boundary Detail" {
    direction: down
    style.fill: "#fff8e1"
    style.border-radius: 6
    eoh_bytes: {
      shape: sql_table
      label: "The \\r\\n\\r\\n Sequence (4 bytes)"
      f0: "byte N-3 | 0x0D | CR  — final char of last header value line"
      f1: "byte N-2 | 0x0A | LF  — completes last header's CRLF"
      f2: "byte N-1 | 0x0D | CR  — start of empty line"
      f3: "byte N   | 0x0A | LF  — completes empty line → BOUNDARY"
      note: "strstr(buf, '\\r\\n\\r\\n') != NULL  →  read_request() returns"
    }
    eoh_code: {
      label: "Detection Code (read_request.c)"
      width: 480
      code: |'c
        total += n;
        buf[total] = '\0';
        if (strstr(buf, "\r\n\r\n") != NULL)
            return (ssize_t)total;  // complete headers buffered
      '|
    }
    eoh_body_ptr: {
      shape: sql_table
      label: "Body Pointer Calculation"
      f0: "body_start = strstr(buf, '\\r\\n\\r\\n') + 4"
      f1: "req->body = body_start  (points into raw buf — zero copy)"
      f2: "req->body_len = (buf + total_bytes_read) - body_start"
      note: "buf must outlive http_request_t — both on same stack frame"
    }
    eoh_bytes -> eoh_code
    eoh_code -> eoh_body_ptr
  }
  ann_sizes: "Buffer Sizing Rationale" {
    direction: down
    style.fill: "#f3e5f5"
    style.border-radius: 6
    size_table: {
      shape: sql_table
      label: "REQUEST_BUF_SIZE = 8192 bytes (8 KB)"
      f0: "nginx default    | 8 KB per header buffer  (client_header_buffer_size)"
      f1: "Apache default   | 8 KB  (LimitRequestFieldSize)"
      f2: "Typical request  | 300–800 bytes for common GET with 5–10 headers"
      f3: "Worst case legal | ~4 KB  (many large cookie headers)"
      f4: "Our limit        | 8 191 bytes payload + 1 null terminator"
      note: "Exceeding → return -1 → caller sends 413 / 431"
    }
    overflow_guard: {
      label: "Overflow Guard (read_request.c)"
      width: 480
      code: |'c
        while (total < buf_size - 1) {
            ssize_t n = recv(fd, buf + total,
                             buf_size - 1 - total, 0);
            // buf_size-1-total  always > 0
            // guarantees room for null terminator
        }
        return -1; // exhausted without \r\n\r\n
      '|
    }
    size_table -> overflow_guard
  }
}
row_obs_fold: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  obs_fold_box: "RFC 7230 Obsolete Line Folding (obs-fold)" {
    direction: down
    style.fill: "#fce4ec"
    style.border-radius: 6
    obs_wire: {
      shape: sql_table
      label: "Wire Bytes — Folded Header Example"
      f0: "0x?? | 'Subject:'        | header name"
      f1: "0x?? | ' This is'        | partial value"
      f2: "0x?? | CR LF            | line end"
      f3: "0x?? | SP 'a folded val' | continuation — starts with 0x20 or 0x09"
      f4: "0x?? | CR LF            | line end"
      note: "RFC 7230 deprecated obs-fold — real clients still send it"
    }
    obs_rule: {
      shape: sql_table
      label: "Unfolding Rule in parse_headers()"
      f0: "detect  | line[0] == ' ' or line[0] == '\\t'"
      f1: "action  | append ' ' + ltrimmed(continuation) to prev header value"
      f2: "result  | single value string with internal space replacing fold"
      note: "Must check header_count > 0 before accessing prev — no orphan fold"
    }
    obs_wire -> obs_rule: "parser handles"
  }
  case_insensitive_box: "Case-Insensitive Header Name Storage" {
    direction: down
    style.fill: "#e8f5e9"
    style.border-radius: 6
    ci_wire: {
      shape: sql_table
      label: "Three Wire Representations — Same Header"
      f0: "wire form A | 'Content-Type: text/html'"
      f1: "wire form B | 'content-type: text/html'"
      f2: "wire form C | 'CONTENT-TYPE: text/html'"
      note: "RFC 7230 S3.2: header field names are case-insensitive"
    }
    ci_normalize: {
      label: "Normalization Loop (parse_headers.c)"
      width: 420
      code: |'c
        for (size_t i = 0; i < name_len; i++)
            hdr->name[i] =
              (char)tolower((unsigned char)hdr->name[i]);
        // stored: "content-type"
        // lookup: strcmp(hdr->name, "content-type")
      '|
    }
    ci_lookup: {
      shape: sql_table
      label: "get_header() — O(N) Linear Scan"
      f0: "N = MAX_HEADERS = 32"
      f1: "cost = 32 x strcmp()  ≈ few hundred ns"
      f2: "all 32 entries fit in L1 cache (32 x 1152 B = 36 KB → L2)"
      note: "Hash map warranted only when N > 64 or lookup is hot inner loop"
    }
    ci_wire -> ci_normalize
    ci_normalize -> ci_lookup
  }
}
row_legend -> row_variants: "color key applies"
row_variants -> row_eoh_annotation: "boundary detail"
row_eoh_annotation -> row_obs_fold: "edge cases"