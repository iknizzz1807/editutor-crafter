direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  ## HTTP Request Parser — State Machine (http_parse.c)
  *One byte at a time — no backtracking*
| {near: top-center}
START: START {
  shape: circle
  style.fill: "#4CAF50"
  style.font-color: white
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}
REQUEST_LINE: REQUEST_LINE {
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.border-radius: 6
  style.stroke: "#0D47A1"
  label: "REQUEST_LINE\naccumulate: METHOD SP PATH SP VERSION"
  width: 320
}
HEADER_NAME: HEADER_NAME {
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.border-radius: 6
  label: "HEADER_NAME\naccumulate: field-name (tolower)"
  width: 320
}
HEADER_COLON_OWS: HEADER_COLON_OWS {
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.border-radius: 6
  label: "HEADER_COLON_OWS\nskip: OWS after ':'"
  width: 320
}
HEADER_VALUE: HEADER_VALUE {
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.border-radius: 6
  label: "HEADER_VALUE\naccumulate: field-value, strip trail OWS"
  width: 320
}
HEADER_END_CR: HEADER_END_CR {
  shape: rectangle
  style.fill: "#5C6BC0"
  style.font-color: white
  style.border-radius: 6
  label: "HEADER_END_CR\ngot CR — expecting LF"
  width: 320
}
HEADER_END_LF: HEADER_END_LF {
  shape: diamond
  style.fill: "#7B1FA2"
  style.font-color: white
  style.stroke: "#4A148C"
  label: "HEADER_END_LF\nLF seen — empty line?"
  width: 280
}
OBS_FOLD: OBS_FOLD {
  shape: rectangle
  style.fill: "#E65100"
  style.font-color: white
  style.border-radius: 6
  label: "OBS_FOLD\nunfold: SP/TAB continuation\nappend to prev header value"
  width: 320
}
END_OF_HEADERS: END_OF_HEADERS {
  shape: rectangle
  style.fill: "#2E7D32"
  style.font-color: white
  style.border-radius: 6
  label: "END_OF_HEADERS\nbody ptr = buf + pos\nbody_len = total - pos"
  width: 320
}
BODY: BODY {
  shape: rectangle
  style.fill: "#1B5E20"
  style.font-color: white
  style.border-radius: 6
  label: "BODY\nread Content-Length bytes\nfrom socket if needed"
  width: 320
}
PARSE_ERROR: PARSE_ERROR {
  shape: hexagon
  style.fill: "#B71C1C"
  style.font-color: white
  style.stroke: "#7F0000"
  style.stroke-width: 3
  label: "PARSE_ERROR\n→ 400 Bad Request\n→ 414 URI Too Long\n→ 501 Not Implemented"
  width: 320
}
DONE: DONE {
  shape: circle
  style.fill: "#4CAF50"
  style.font-color: white
  style.stroke: "#1B5E20"
  style.stroke-width: 3
  label: "DONE\nhttp_request_t\npopulated"
  width: 160
}
START -> REQUEST_LINE: "any byte\nbegin accumulate"
REQUEST_LINE -> HEADER_NAME: "LF or CRLF\n(end of request line)" {
  style.stroke: "#4CAF50"
}
REQUEST_LINE -> PARSE_ERROR: "no SP found\nor missing VERSION\n→ 400" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
REQUEST_LINE -> PARSE_ERROR: "path_len >= MAX_PATH_LEN\n→ 414" {
  style.stroke: "#FF6D00"
  style.stroke-dash: 4
}
REQUEST_LINE -> PARSE_ERROR: "method not GET/HEAD\n→ 501" {
  style.stroke: "#FF6D00"
  style.stroke-dash: 4
}
HEADER_NAME -> HEADER_COLON_OWS: "':' (COLON)\nstore name via tolower()" {
  style.stroke: "#42A5F5"
}
HEADER_NAME -> PARSE_ERROR: "no ':' on line\nor name_len == 0\n→ 400" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
HEADER_COLON_OWS -> HEADER_COLON_OWS: "SP or TAB\n(skip OWS)" {
  style.stroke: "#78909C"
  style.stroke-dash: 3
}
HEADER_COLON_OWS -> HEADER_VALUE: "any non-OWS byte\nbegin value" {
  style.stroke: "#42A5F5"
}
HEADER_VALUE -> HEADER_END_CR: "CR ('\\r')\nstrip trailing OWS from value" {
  style.stroke: "#FFA726"
}
HEADER_VALUE -> HEADER_END_LF: "bare LF ('\\n')\n(no preceding CR)" {
  style.stroke: "#FFA726"
  style.stroke-dash: 3
}
HEADER_END_CR -> HEADER_END_LF: "LF ('\\n')" {
  style.stroke: "#FFA726"
}
HEADER_END_CR -> PARSE_ERROR: "any other byte\n(CR not followed by LF)\n→ 400" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
HEADER_END_LF -> OBS_FOLD: "next byte = SP or TAB\n(obs-fold detected)" {
  style.stroke: "#FF8F00"
}
HEADER_END_LF -> END_OF_HEADERS: "LF after CR+LF\n(empty line = \\r\\n\\r\\n)" {
  style.stroke: "#66BB6A"
  style.stroke-width: 3
}
HEADER_END_LF -> HEADER_NAME: "any non-empty byte\n(start of next header)" {
  style.stroke: "#42A5F5"
}
OBS_FOLD -> HEADER_VALUE: "SP/TAB stripped\ncontinuation appended\nresume value" {
  style.stroke: "#FF8F00"
}
END_OF_HEADERS -> BODY: "Content-Length > 0\n(POST/PUT)" {
  style.stroke: "#66BB6A"
}
END_OF_HEADERS -> DONE: "Content-Length == 0\nor absent\n(GET/HEAD)" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
BODY -> DONE: "body_len bytes read\nfrom socket" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
annotations: "" {
  style.fill: "#1A1A2E"
  style.stroke: "#3F51B5"
  style.border-radius: 8
  width: 560
  r1: "BLUE  = accumulate state (write to http_request_t fields)" {
    style.font-color: "#90CAF9"
  }
  r2: "PURPLE = branch point (empty line decision)" {
    style.font-color: "#CE93D8"
  }
  r3: "ORANGE = obs-fold handler (RFC 7230 §3.2.6 — unfold continuation)" {
    style.font-color: "#FFCC80"
  }
  r4: "GREEN  = terminal success states" {
    style.font-color: "#A5D6A7"
  }
  r5: "RED    = PARSE_ERROR terminal — send 400 / 414 / 501 then close fd" {
    style.font-color: "#EF9A9A"
  }
  r6: "Dashed red arrows = error transitions (all non-hot-path)" {
    style.font-color: "#EF9A9A"
  }
  r7: "INVARIANT: parser never backtracks — pos advances monotonically" {
    style.font-color: "#FFFFFF"
    style.bold: true
  }
}
annotations.near: bottom-right