direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  browser: "" {
    direction: down
    label: "Browser (Client)"
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.border-radius: 8
    b_cache_empty: {
      shape: cylinder
      label: "Cache: EMPTY"
      style.fill: "#fef9c3"
      style.stroke: "#ca8a04"
    }
  }
  spacer0: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 60
  }
  server: "" {
    direction: down
    label: "HTTP Server (file_server.c)"
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
    style.border-radius: 8
    s_serve: {
      shape: class
      label: "serve_file() — Request 1"
      stat_call: "stat(canonical)"
      mtime_val: "st.st_mtime = 1740909600"
      ims_hdr: "If-Modified-Since: (none)"
      result: "→ serve full body"
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  req1_wire: {
    shape: document
    label: "REQUEST 1 — Wire Bytes"
    width: 440
    style.fill: "#ede9fe"
    style.stroke: "#7c3aed"
    line1: "GET /logo.png HTTP/1.1"
    line2: "Host: example.com"
    line3: "Accept: image/png"
    line4: "(no If-Modified-Since)"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  resp1_wire: {
    shape: document
    label: "RESPONSE 1 — Wire Bytes (200 OK)"
    width: 540
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
    r1l1: "HTTP/1.1 200 OK"
    r1l2: "Content-Type: image/png"
    r1l3: "Content-Length: 524288   (= 512 KB)"
    r1l4: "Last-Modified: Mon, 02 Mar 2026 10:00:00 GMT"
    r1l5: "Connection: keep-alive"
    r1l6: ""
    r1l7: "[512 KB binary body transmitted]"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  browser_after1: "" {
    direction: down
    label: "Browser — After Request 1"
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.border-radius: 8
    b_cache_full: {
      shape: sql_table
      label: "Cache Entry: /logo.png"
      key1: "file_data   | 512 KB (image/png)"
      key2: "last_mod    | Mon, 02 Mar 2026 10:00:00 GMT"
      key3: "stored_at   | Mon, 02 Mar 2026 10:00:05 GMT"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  req2_wire: {
    shape: document
    label: "REQUEST 2 — Wire Bytes (conditional GET)"
    width: 540
    style.fill: "#fef3c7"
    style.stroke: "#d97706"
    q2l1: "GET /logo.png HTTP/1.1"
    q2l2: "Host: example.com"
    q2l3: "If-Modified-Since: Mon, 02 Mar 2026 10:00:00 GMT"
    q2l4: "Accept: image/png"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  server_logic: "" {
    direction: down
    label: "Server — Request 2 Decision Logic (file_server.c)"
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
    style.border-radius: 8
    parse_date: {
      shape: sql_table
      label: "parse_http_date() — IMF-fixdate RFC 7231"
      pd1: "input      | Mon, 02 Mar 2026 10:00:00 GMT"
      pd2: "format     | %a, %d %b %Y %H:%M:%S GMT"
      pd3: "strptime() | fills struct tm (UTC)"
      pd4: "timegm()   | returns time_t = 1740909600"
    }
    stat_cmp: {
      shape: sql_table
      label: "stat() + Comparison"
      sc1: "stat(canonical)     | st.st_mtime = 1740909600"
      sc2: "ims_parsed          | time_t      = 1740909600"
      sc3: "condition           | st.st_mtime <= ims ?"
      sc4: "1740909600 <= 1740909600 | TRUE  → 304"
    }
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  resp2_wire: {
    shape: document
    label: "RESPONSE 2 — Wire Bytes (304 Not Modified)"
    width: 540
    style.fill: "#fee2e2"
    style.stroke: "#dc2626"
    s2l1: "HTTP/1.1 304 Not Modified"
    s2l2: "Content-Type: image/png"
    s2l3: "Content-Length: 524288   (size if served)"
    s2l4: "Last-Modified: Mon, 02 Mar 2026 10:00:00 GMT"
    s2l5: "Connection: keep-alive"
    s2l6: ""
    s2l7: "[NO BODY — 0 bytes of file data sent]"
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bandwidth_saved: {
    shape: hexagon
    label: "Bandwidth Saved"
    style.fill: "#fce7f3"
    style.stroke: "#db2777"
    style.font-size: 16
    style.bold: true
    width: 380
  }
  savings_table: {
    shape: sql_table
    label: "Transfer Audit"
    st1: "Request 1 body sent   | 524,288 bytes (512 KB)"
    st2: "Request 2 body sent   | 0 bytes"
    st3: "Savings               | 524,288 bytes (100%)"
    st4: "Resp 2 header size    | ~160 bytes only"
    st5: "CPU saved             | no open() / read() loop"
  }
}
imf_format: {
  shape: sql_table
  label: "RFC 7231 IMF-fixdate — Required Parse Format"
  f1: "Template  | Day, DD Mon YYYY HH:MM:SS GMT"
  f2: "Example   | Mon, 02 Mar 2026 10:00:00 GMT"
  f3: "strptime  | %a, %d %b %Y %H:%M:%S GMT"
  f4: "Parse fn  | parse_http_date(const char*): time_t"
  f5: "UTC conv  | timegm(&tm)  NOT mktime() — no TZ offset"
  f6: "Fallback  | %A, %d-%b-%y %H:%M:%S GMT  (HTTP/1.0)"
  f7: "On fail   | return (time_t)-1 → skip 304 check"
}
row0 -> row1: "Browser sends GET (no cache entry)"
row1 -> row2: "200 OK | 512 KB body"
row2 -> row3: "Cache stores file + Last-Modified"
row3 -> row4: "Re-visit: browser attaches If-Modified-Since"
row4 -> row5: "If-Modified-Since | parse + compare"
row5 -> row6: "304 Not Modified | 0 bytes body"
row6 -> row7: "512 KB saved"
row7 -> imf_format: "date format"
row0 -> server: "connect"
server -> row2: "200 + Last-Modified"
row4 -> server_logic: "If-Modified-Since"
row5.stat_cmp -> row6: "TRUE | send_304()"
bandwidth_saved.style.fill: "#fce7f3"