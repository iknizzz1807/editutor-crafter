direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
entry: "serve_file() Entry" {
  shape: rectangle
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"
  style.bold: true
}
stat_check: "stat(canonical_path)" {
  shape: diamond
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
  style.bold: true
}
is_dir: "S_ISDIR(st.st_mode) ?" {
  shape: diamond
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
  style.bold: true
}
not_dir: "Serve File Normally" {
  shape: rectangle
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"
  style.bold: true
}
stat_fail: "stat() returned errno" {
  shape: diamond
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
}
send_404_stat: "404 Not Found" {
  shape: rectangle
  style.fill: "#fee2e2"
  style.stroke: "#dc2626"
  style.bold: true
  note: "ENOENT or ENOTDIR"
}
row_dir_checks: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  check_slash: "path ends with '/' ?" {
    shape: diamond
    style.fill: "#fef9c3"
    style.stroke: "#ca8a04"
    style.bold: true
  }
  redirect_301: "301 Moved Permanently" {
    shape: rectangle
    style.fill: "#ede9fe"
    style.stroke: "#7c3aed"
    style.bold: true
    hdr: "Location: path/ header"
    why: "Relative URLs in index.html resolve correctly only when browser path ends with /"
  }
}
append_index: "Append /index.html to canonical_path" {
  shape: rectangle
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"
  note: "new_path = canonical + /index.html"
}
realpath2: "realpath(new_path, canonical2)" {
  shape: diamond
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
  style.bold: true
}
row_index_result: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  index_exists: "stat(canonical2)" {
    shape: diamond
    style.fill: "#fef9c3"
    style.stroke: "#ca8a04"
    style.bold: true
  }
  send_403_noindex: "403 Forbidden" {
    shape: rectangle
    style.fill: "#fee2e2"
    style.stroke: "#dc2626"
    style.bold: true
    why1: "Directory exists but no index.html"
    why2: "NOT 404: directory is found, access denied"
    why3: "Security: no listing reveals file structure"
  }
}
containment_recheck: "Prefix check: canonical2 inside doc_root ?" {
  shape: diamond
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
  note: "index.html itself may be a symlink"
}
send_403_escape: "403 Forbidden" {
  shape: rectangle
  style.fill: "#fee2e2"
  style.stroke: "#dc2626"
  style.bold: true
  why: "index.html symlink escapes doc_root"
}
serve_index: "Serve index.html" {
  shape: rectangle
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"
  style.bold: true
  note: "200 OK + file contents"
}
security_note: "Security Rationale" {
  shape: rectangle
  style.fill: "#f3e8ff"
  style.stroke: "#9333ea"
  r1: "403 (not directory listing) prevents:"
  r2: "- Revealing file/dir names in docroot"
  r3: "- Enumerating upload targets"
  r4: "- Mapping server filesystem layout"
  r5: "Apache: Options -Indexes enforces same policy"
}
entry -> stat_check: "call stat()"
stat_check -> is_dir: "stat() OK"
stat_check -> stat_fail: "stat() error"
stat_fail -> send_404_stat: "ENOENT / ENOTDIR"
is_dir -> not_dir: "false (regular file)"
is_dir -> row_dir_checks.check_slash: "true (directory)"
row_dir_checks.check_slash -> row_dir_checks.redirect_301: "NO — path lacks trailing /"
row_dir_checks.check_slash -> append_index: "YES — path ends with /"
append_index -> realpath2: "resolve symlinks in index path"
realpath2 -> row_index_result.index_exists: "realpath() OK"
realpath2 -> row_index_result.send_403_noindex: "ENOENT: index.html missing"
row_index_result.index_exists -> containment_recheck: "stat() OK"
row_index_result.index_exists -> row_index_result.send_403_noindex: "stat() fails"
containment_recheck -> serve_index: "canonical2 inside doc_root"
containment_recheck -> send_403_escape: "canonical2 OUTSIDE doc_root"
security_note.near: bottom-right