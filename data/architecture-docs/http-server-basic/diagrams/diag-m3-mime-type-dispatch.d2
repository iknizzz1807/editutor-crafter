direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## MIME Type Lookup — Extension Map & Default Fallback (file_server.c)
| {near: top-center}

row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  lookup_fn: {
    label: "get_mime_type (file_server.c)"
    shape: class
    "+get_mime_type(path)": "const char*"
    "-strrchr(path, '.')": "char* dot"
    "-dot_is_null": "application/octet-stream"
    "-loop_MIME_TABLE(dot)": "strcasecmp each entry"
    "-no_match": "application/octet-stream"
  }

  algo_note: {
    label: "Algorithm Notes (file_server.c)"
    shape: sql_table
    a1: "strrchr(path, '.') -> last dot"
    a2: "archive.tar.gz  maps to .gz"
    a3: ".gitignore -> no ext -> octet-stream"
    a4: "case-insensitive: .HTML == .html"
    a5: "sentinel NULL entry ends table"
    a6: "linear scan: N <= 16, fits in L1 cache"
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  mime_table: {
    label: "static mime_entry_t MIME_TABLE[] (file_server.c)"
    shape: sql_table
    h0: "Index | Extension | MIME Type | Browser Action"
    r01: "  [0] | .html | text/html; charset=utf-8 | RENDER as HTML"
    r02: "  [1] | .htm | text/html; charset=utf-8 | RENDER as HTML"
    r03: "  [2] | .css | text/css; charset=utf-8 | APPLY stylesheet"
    r04: "  [3] | .js | application/javascript | EXECUTE as script"
    r05: "  [4] | .json | application/json | DISPLAY raw text"
    r06: "  [5] | .txt | text/plain; charset=utf-8 | DISPLAY raw text"
    r07: "  [6] | .xml | application/xml | DISPLAY/parse XML"
    r08: "  [7] | .svg | image/svg+xml | RENDER inline SVG"
    r09: "  [8] | .png | image/png | DISPLAY inline image"
    r10: "  [9] | .jpg | image/jpeg | DISPLAY inline image"
    r11: " [10] | .jpeg | image/jpeg | DISPLAY inline image"
    r12: " [11] | .gif | image/gif | DISPLAY inline image"
    r13: " [12] | .ico | image/x-icon | FAVICON / inline"
    r14: " [13] | .pdf | application/pdf | EMBED or DOWNLOAD"
    r15: " [14] | .woff | font/woff | LOAD web font"
    r16: " [15] | .woff2 | font/woff2 | LOAD web font"
    r17: " [16] | .webp | image/webp | DISPLAY inline image"
    r18: " [17] | NULL | NULL | sentinel (end loop)"
    sz: "Total: 18 entries x 16 bytes = 288 bytes"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  fallback: {
    label: "Fallback: application/octet-stream"
    shape: sql_table
    f1: "Trigger: extension not in table OR no extension"
    f2: "Browser action: DOWNLOAD dialog (save-as)"
    f3: "Security: prevents browser from executing unknown"
    f4: "Covers: .bin .exe .zip .tar .gz .unknown"
    f5: "Never returns NULL - always valid MIME"
  }

  security_note: {
    label: "Security: Why MIME Matters (file_server.c)"
    shape: sql_table
    s1: "WRONG text/html for .js -> renders as HTML"
    s2: "WRONG text/plain for .js -> modules blocked"
    s3: "Missing charset= on text/* -> browser guesses"
    s4: "X-Content-Type-Options: nosniff -> server trust"
    s5: "application/octet-stream -> force download"
    s6: "Never sniff bytes - use extension only"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  struct_layout: {
    label: "struct mime_entry_t (file_server.c)"
    shape: sql_table
    f0: "0x00 | const char* | extension // e.g. .html"
    f1: "0x08 | const char* | mime_type // e.g. text/html"
    sz: "Total: 16 bytes (64-bit ABI)"
  }

  browser_groups: {
    label: "Browser Action Groups"
    shape: sql_table
    g1: "RENDER: text/html, text/css, image/* (inline)"
    g2: "EXECUTE: application/javascript"
    g3: "DISPLAY: text/plain, application/json, application/xml"
    g4: "EMBED/DL: application/pdf (plugin or download)"
    g5: "FONT LOAD: font/woff, font/woff2"
    g6: "DOWNLOAD: application/octet-stream (save-as)"
  }
}

row0.lookup_fn -> row1.mime_table: "scans linearly"
row0.lookup_fn -> row0.algo_note: "calls"
row1.mime_table -> row2.fallback: "no match"
row1.mime_table -> row2.security_note: "mismatch path"
row2.fallback -> row3.struct_layout: "table element"
row2.security_note -> row3.browser_groups: "classification"