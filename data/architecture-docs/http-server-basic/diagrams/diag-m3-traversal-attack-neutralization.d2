direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Directory Traversal: Three Attack Vectors Neutralized" {
  near: top-center
  style: {
    font-size: 20
    bold: true
    stroke: transparent
    fill: transparent
  }
}
pipeline_legend: "URL-to-Filesystem Pipeline (5 Stages)" {
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
    font-size: 13
    bold: true
  }
  direction: right
  s1: "Stage 1\nURL Decode" {
    style: { fill: "#B3E5FC"; stroke: "#0288D1"; border-radius: 6 }
  }
  s2: "Stage 2\nConcat doc_root" {
    style: { fill: "#B3E5FC"; stroke: "#0288D1"; border-radius: 6 }
  }
  s3: "Stage 3\nrealpath()" {
    style: { fill: "#B3E5FC"; stroke: "#0288D1"; border-radius: 6 }
  }
  s4: "Stage 4\nPrefix Check" {
    style: { fill: "#B3E5FC"; stroke: "#0288D1"; border-radius: 6 }
  }
  s5: "Stage 5\nopen() + serve" {
    style: { fill: "#C8E6C9"; stroke: "#388E3C"; border-radius: 6 }
  }
  s1 -> s2
  s2 -> s3
  s3 -> s4
  s4 -> s5
}
row_attacks: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  attack1: "ATTACK 1: Path Traversal  ../../etc/passwd" {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    direction: down
    a1_req: "Client sends request" {
      style: { fill: "#FFCCBC"; stroke: "#BF360C"; border-radius: 4 }
      raw: "GET /../../../etc/passwd HTTP/1.1" {
        style: { fill: "#FFCCBC"; stroke: "#BF360C"; border-radius: 4; font: mono }
      }
    }
    a1_s1: "Stage 1 — URL Decode (no encoding present)" {
      style: { fill: "#FFF8E1"; stroke: "#F9A825"; border-radius: 4 }
      val: "path = /../../../etc/passwd" {
        style: { fill: "#FFF8E1"; stroke: "#F9A825"; border-radius: 4; font: mono }
      }
    }
    a1_s2: "Stage 2 — Concat with doc_root" {
      style: { fill: "#FFF8E1"; stroke: "#F9A825"; border-radius: 4 }
      val: "/var/www/html/../../../etc/passwd" {
        style: { fill: "#FFF8E1"; stroke: "#F9A825"; border-radius: 4; font: mono }
      }
    }
    a1_s3: "Stage 3 — realpath() resolves .." {
      style: { fill: "#FCE4EC"; stroke: "#C62828"; stroke-width: 2; border-radius: 4 }
      val: "canonical = /etc/passwd" {
        style: { fill: "#FFCDD2"; stroke: "#C62828"; border-radius: 4; font: mono; bold: true }
      }
      note: "All .. components resolved by kernel" {
        style: { fill: "#FCE4EC"; stroke: "#C62828"; border-radius: 4; font-size: 11 }
      }
    }
    a1_s4: "Stage 4 — Prefix Check FAILS" {
      style: { fill: "#B71C1C"; stroke: "#B71C1C"; border-radius: 4 }
      check: "/etc/passwd does NOT start with /var/www/html" {
        style: { fill: "#FFCDD2"; stroke: "#B71C1C"; border-radius: 4; font: mono; bold: true }
      }
      resp: "HTTP 403 Forbidden" {
        style: { fill: "#D32F2F"; stroke: "#B71C1C"; border-radius: 4; font-color: white; bold: true }
      }
    }
    a1_req -> a1_s1
    a1_s1 -> a1_s2
    a1_s2 -> a1_s3
    a1_s3 -> a1_s4: "realpath() normalizes .."
    a1_s4.style.stroke-dash: 0
  }
  attack2: "ATTACK 2: URL-Encoded Traversal" {
    style: {
      fill: "#F3E5F5"
      stroke: "#6A1B9A"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    direction: down
    a2_req: "Client sends request" {
      style: { fill: "#E1BEE7"; stroke: "#4A148C"; border-radius: 4 }
      raw: "GET /%2e%2e%2f%2e%2e%2fetc%2fpasswd HTTP/1.1" {
        style: { fill: "#E1BEE7"; stroke: "#4A148C"; border-radius: 4; font: mono }
      }
    }
    a2_s1: "Stage 1 — URL Decode FIRST" {
      style: { fill: "#FCE4EC"; stroke: "#880E4F"; stroke-width: 2; border-radius: 4 }
      val: "%2e=.  %2f=/  decoded: ../../etc/passwd" {
        style: { fill: "#F8BBD0"; stroke: "#880E4F"; border-radius: 4; font: mono; bold: true }
      }
      note: "decode BEFORE concat — key ordering" {
        style: { fill: "#FCE4EC"; stroke: "#880E4F"; border-radius: 4; font-size: 11; italic: true }
      }
    }
    a2_s2: "Stage 2 — Concat with doc_root" {
      style: { fill: "#EDE7F6"; stroke: "#7B1FA2"; border-radius: 4 }
      val: "/var/www/html/../../etc/passwd" {
        style: { fill: "#EDE7F6"; stroke: "#7B1FA2"; border-radius: 4; font: mono }
      }
    }
    a2_s3: "Stage 3 — realpath() resolves" {
      style: { fill: "#FCE4EC"; stroke: "#C62828"; stroke-width: 2; border-radius: 4 }
      val: "canonical = /etc/passwd" {
        style: { fill: "#FFCDD2"; stroke: "#C62828"; border-radius: 4; font: mono; bold: true }
      }
    }
    a2_s4: "Stage 4 — Prefix Check FAILS" {
      style: { fill: "#B71C1C"; stroke: "#B71C1C"; border-radius: 4 }
      check: "/etc/passwd does NOT start with /var/www/html" {
        style: { fill: "#FFCDD2"; stroke: "#B71C1C"; border-radius: 4; font: mono; bold: true }
      }
      resp: "HTTP 403 Forbidden" {
        style: { fill: "#D32F2F"; stroke: "#B71C1C"; border-radius: 4; font-color: white; bold: true }
      }
    }
    a2_req -> a2_s1: "bytes arrive on wire"
    a2_s1 -> a2_s2: "decoded string"
    a2_s2 -> a2_s3
    a2_s3 -> a2_s4: "realpath() normalizes .."
  }
  attack3: "ATTACK 3: Symlink Escape" {
    style: {
      fill: "#E8F5E9"
      stroke: "#1B5E20"
      stroke-width: 2
      bold: true
      font-size: 13
    }
    direction: down
    a3_req: "Client sends request" {
      style: { fill: "#C8E6C9"; stroke: "#1B5E20"; border-radius: 4 }
      raw: "GET /secret/passwd HTTP/1.1" {
        style: { fill: "#C8E6C9"; stroke: "#1B5E20"; border-radius: 4; font: mono }
      }
    }
    a3_setup: "Filesystem precondition (attacker-placed)" {
      style: { fill: "#FFF9C4"; stroke: "#F57F17"; stroke-width: 2; border-radius: 4 }
      symlink: "/var/www/html/secret  ->  /etc  (symlink)" {
        style: { fill: "#FFF176"; stroke: "#F57F17"; border-radius: 4; font: mono; bold: true }
      }
      note: "string prefix check would PASS: /var/www/html/secret/passwd starts with /var/www/html" {
        style: { fill: "#FFFDE7"; stroke: "#F57F17"; border-radius: 4; font-size: 11; italic: true }
      }
    }
    a3_s1: "Stage 1 — URL Decode (no encoding)" {
      style: { fill: "#F1F8E9"; stroke: "#558B2F"; border-radius: 4 }
      val: "path = /secret/passwd" {
        style: { fill: "#F1F8E9"; stroke: "#558B2F"; border-radius: 4; font: mono }
      }
    }
    a3_s2: "Stage 2 — Concat with doc_root" {
      style: { fill: "#F1F8E9"; stroke: "#558B2F"; border-radius: 4 }
      val: "/var/www/html/secret/passwd" {
        style: { fill: "#F1F8E9"; stroke: "#558B2F"; border-radius: 4; font: mono }
      }
      note2: "naive prefix check here would PASS" {
        style: { fill: "#FFF9C4"; stroke: "#F9A825"; border-radius: 4; font-size: 11; italic: true }
      }
    }
    a3_s3: "Stage 3 — realpath() follows symlink" {
      style: { fill: "#FCE4EC"; stroke: "#C62828"; stroke-width: 2; border-radius: 4 }
      val: "canonical = /etc/passwd" {
        style: { fill: "#FFCDD2"; stroke: "#C62828"; border-radius: 4; font: mono; bold: true }
      }
      note: "/secret -> /etc resolved by kernel lstat+readlink chain" {
        style: { fill: "#FCE4EC"; stroke: "#C62828"; border-radius: 4; font-size: 11; italic: true }
      }
    }
    a3_s4: "Stage 4 — Prefix Check FAILS" {
      style: { fill: "#B71C1C"; stroke: "#B71C1C"; border-radius: 4 }
      check: "/etc/passwd does NOT start with /var/www/html" {
        style: { fill: "#FFCDD2"; stroke: "#B71C1C"; border-radius: 4; font: mono; bold: true }
      }
      resp: "HTTP 403 Forbidden" {
        style: { fill: "#D32F2F"; stroke: "#B71C1C"; border-radius: 4; font-color: white; bold: true }
      }
    }
    a3_req -> a3_setup: "attacker pre-planted symlink"
    a3_req -> a3_s1
    a3_s1 -> a3_s2
    a3_s2 -> a3_s3: "realpath() follows symlink"
    a3_s3 -> a3_s4
  }
}
safe_path: "SAFE PATH — Legitimate Request" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    bold: true
    font-size: 13
  }
  direction: right
  sp1: "GET /images/logo.png" {
    style: { fill: "#C8E6C9"; stroke: "#388E3C"; border-radius: 4; font: mono }
  }
  sp2: "decode: /images/logo.png" {
    style: { fill: "#C8E6C9"; stroke: "#388E3C"; border-radius: 4; font: mono }
  }
  sp3: "/var/www/html/images/logo.png" {
    style: { fill: "#C8E6C9"; stroke: "#388E3C"; border-radius: 4; font: mono }
  }
  sp4: "canonical = /var/www/html/images/logo.png" {
    style: { fill: "#A5D6A7"; stroke: "#2E7D32"; border-radius: 4; font: mono; bold: true }
  }
  sp5: "STARTS WITH /var/www/html — PASS" {
    style: { fill: "#66BB6A"; stroke: "#1B5E20"; border-radius: 4; font: mono; bold: true }
  }
  sp6: "200 OK + file bytes" {
    style: { fill: "#2E7D32"; stroke: "#1B5E20"; border-radius: 4; font-color: white; bold: true }
  }
  sp1 -> sp2: "Stage 1"
  sp2 -> sp3: "Stage 2"
  sp3 -> sp4: "Stage 3"
  sp4 -> sp5: "Stage 4"
  sp5 -> sp6: "Stage 5"
}
key_insight: "Security Invariant" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    font-size: 12
    bold: true
  }
  rule1: "Rule 1: URL-decode BEFORE realpath() — percent-encoding cannot hide .." {
    style: { fill: "#E3F2FD"; stroke: "#1565C0"; border-radius: 4 }
  }
  rule2: "Rule 2: realpath() BEFORE prefix check — symlinks and .. both resolved" {
    style: { fill: "#E3F2FD"; stroke: "#1565C0"; border-radius: 4 }
  }
  rule3: "Rule 3: Check canonical[root_len] == / or NUL — /var/www/html2 cannot match /var/www/html" {
    style: { fill: "#E3F2FD"; stroke: "#1565C0"; border-radius: 4 }
  }
  rule4: "Rule 4: Return 403 (not 404) for out-of-root paths — never leak external filesystem layout" {
    style: { fill: "#E3F2FD"; stroke: "#1565C0"; border-radius: 4 }
  }
}
pipeline_legend -> row_attacks: "all requests enter pipeline"
row_attacks -> safe_path: "safe requests reach Stage 5"
row_attacks -> key_insight: "all attacks blocked at Stage 3-4"