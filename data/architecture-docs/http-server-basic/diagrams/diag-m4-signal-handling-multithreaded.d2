  style.stroke: "#33aa33"
  style.stroke-dash: 3
}
row_solutions.sol_sigmask.step2 -> row_solutions.sol_sigmask.inherit_row.w_inh2: "inherits mask" {
  style.stroke: "#33aa33"
  style.stroke-dash: 3
}
row_solutions.sol_sigmask.step2 -> row_solutions.sol_sigmask.inherit_row.w_inh3: "inherits mask" {
  style.stroke: "#33aa33"
  style.stroke-dash: 3
}
row_solutions.sol_sigmask.inherit_row -> row_solutions.sol_sigmask.inherit_label: "" {
  style.stroke: "#33aa33"
