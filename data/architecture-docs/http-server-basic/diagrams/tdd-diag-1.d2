vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  ## TCP Socket Lifecycle State Machine
  `server.c` — Milestone 1
| {near: top-center}

legend: |md
  **Legend**
  - ● = initial state
  - 🔴 = error / death state
  - `syscall()` = transition trigger
  - RED DASHED = ILLEGAL transition
  - ORANGE = pre-fix death path
| {near: bottom-left}

# ── States ────────────────────────────────────────────────────────────────────
initial: ● {
  shape: circle
  width: 28
  height: 28
  style.fill: "#1a1a2e"
  style.stroke: "#1a1a2e"
}

CLOSED: "CLOSED\n[process start]" {
  shape: rectangle
  style.fill: "#4a235a"
  style.stroke: "#9b59b6"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#f0e6ff"
  style.bold: true
}

SOCKET_CREATED: "SOCKET_CREATED\nFD = socket(AF_INET, SOCK_STREAM, 0)\nInvariant: server_fd ≥ 0" {
  shape: rectangle
  style.fill: "#2e1a4a"
  style.stroke: "#7d3c98"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#e8d5ff"
}

SO_REUSEADDR_SET: "SO_REUSEADDR SET\nsetsockopt(fd, SOL_SOCKET,\nSO_REUSEADDR, &opt, sizeof(opt))\nInvariant: TIME_WAIT bypass enabled" {
  shape: rectangle
  style.fill: "#2e1a4a"
  style.stroke: "#7d3c98"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#e8d5ff"
}

BOUND: "BOUND\nbind(fd, &addr, sizeof(addr))\nInvariant: port 8080 owned,\nhtons(8080) applied" {
  shape: rectangle
  style.fill: "#2e1a4a"
  style.stroke: "#7d3c98"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#e8d5ff"
}

LISTENING: "LISTENING\nlisten(fd, BACKLOG=128)\nInvariant: SYN queue + accept\nqueue active; server_fd READ-ONLY" {
  shape: rectangle
  style.fill: "#1a3a4a"
  style.stroke: "#2e86c1"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#d6eaf8"
  style.bold: true
}

ACCEPT_LOOP: "ACCEPT LOOP\nwhile(!shutdown_flag)\n  client_fd = accept(server_fd, …)\nInvariant: server_fd never closed here" {
  shape: rectangle
  style.fill: "#1a3a2e"
  style.stroke: "#27ae60"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#d5f5e3"
  style.bold: true
}

CLIENT_CONNECTED: "CLIENT_CONNECTED\nclient_fd = accept()\nNew FD in kernel FD table\nInvariant: client_fd ≠ server_fd" {
  shape: rectangle
  style.fill: "#1a3a2e"
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#d5f5e3"
}

READING: "READING\nread_request(client_fd, buf, 8192)\nrecv() loop until \\r\\n\\r\\n\nInvariant: buf[total]='\\0' each recv()" {
  shape: rectangle
  style.fill: "#1a3a2e"
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#d5f5e3"
}

WRITING: "WRITING\nsend_all(client_fd, HTTP_RESPONSE, len)\nMSG_NOSIGNAL on every send()\nInvariant: loop until sent==len" {
  shape: rectangle
  style.fill: "#1a3a2e"
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#d5f5e3"
}

CLIENT_CLOSED: "CLIENT_CLOSED\nclose(client_fd)\nInvariant: FD table entry freed;\ncount returns to baseline" {
  shape: rectangle
  style.fill: "#2e3a1a"
  style.stroke: "#58d68d"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#eafaf1"
}

SERVER_SHUTDOWN: "SERVER_SHUTDOWN\nclose(server_fd)\nAll workers joined\nprocess exit(0)" {
  shape: rectangle
  style.fill: "#1a2e3a"
  style.stroke: "#85c1e9"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#d6eaf8"
}

# ── Error States ──────────────────────────────────────────────────────────────
ERR_BIND: "❌ BIND FAILED\nbind() → EADDRINUSE\n(missing SO_REUSEADDR;\nTIME_WAIT still on port)\nperror() + exit(1)" {
  shape: rectangle
  style.fill: "#4a1a1a"
  style.stroke: "#e74c3c"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#fadbd8"
  style.bold: true
}

ERR_ACCEPT: "⚠ ACCEPT ERROR\nerrno=EINTR → continue\nerrno=EMFILE/ENFILE →\n  sleep(100ms)+continue\nOther → perror()+continue" {
  shape: rectangle
  style.fill: "#3a2a1a"
  style.stroke: "#e67e22"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#fdebd0"
}

ERR_RECV: "⚠ RECV ERROR / EOF\nrecv()==0 → EOF (client FIN)\nrecv()<0 → ECONNRESET\nbuf full, no \\r\\n\\r\\n →\nAll return -1 → close FD" {
  shape: rectangle
  style.fill: "#3a2a1a"
  style.stroke: "#e67e22"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-color: "#fdebd0"
}

SIGPIPE_DEATH: "🔴 PROCESS KILLED\nSIGPIPE (default handler)\nClient closed mid-send;\nwrite() to closed socket\n→ kernel sends SIGPIPE\n→ server DIES" {
  shape: rectangle
  style.fill: "#4a1a1a"
  style.stroke: "#c0392b"
  style.stroke-width: 4
  style.border-radius: 6
  style.font-color: "#f1948a"
  style.bold: true
}

SIGPIPE_FIXED: "✅ EPIPE RETURNED\nsignal(SIGPIPE, SIG_IGN)\nOR MSG_NOSIGNAL flag\n→ send() returns -1/EPIPE\n→ send_all() returns -1\n→ log + close FD (no crash)" {
  shape: rectangle
  style.fill: "#1a3a1a"
  style.stroke: "#27ae60"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#a9dfbf"
  style.bold: true
}

# ── Illegal Transition States ─────────────────────────────────────────────────
ILLEGAL_READ_SERVER: "💀 UNDEFINED BEHAVIOR\nrecv(server_fd, …)\nserver_fd is PASSIVE socket;\nnot connected to any client;\nblocks forever or returns ENOTCONN" {
  shape: rectangle
  style.fill: "#3a1a3a"
  style.stroke: "#8e44ad"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#d7bde2"
  style.italic: true
}

ILLEGAL_WRITE_SERVER: "💀 UNDEFINED BEHAVIOR\nsend(server_fd, …)\nSame: server_fd is not\na connected endpoint" {
  shape: rectangle
  style.fill: "#3a1a3a"
  style.stroke: "#8e44ad"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#d7bde2"
  style.italic: true
}

FD_LEAK_DEATH: "🔴 EMFILE DEATH SPIRAL\nclose(client_fd) omitted;\nFD table fills (limit≈1024);\naccept() → EMFILE;\nserver stops accepting" {
  shape: rectangle
  style.fill: "#4a1a1a"
  style.stroke: "#c0392b"
  style.stroke-width: 3
  style.border-radius: 6
  style.font-color: "#f1948a"
  style.bold: true
}

# ── Main Lifecycle Transitions ────────────────────────────────────────────────
initial -> CLOSED: ""
CLOSED -> SOCKET_CREATED: "socket(AF_INET, SOCK_STREAM, 0)\nReturns: server_fd ≥ 3\n[0=stdin,1=stdout,2=stderr taken]" {
  style.stroke: "#9b59b6"
  style.stroke-width: 2
}
SOCKET_CREATED -> SO_REUSEADDR_SET: "setsockopt(server_fd,\nSOL_SOCKET, SO_REUSEADDR, &1)\n[MUST precede bind()]" {
  style.stroke: "#7d3c98"
}
SO_REUSEADDR_SET -> BOUND: "bind(server_fd, &addr, sizeof(addr))\naddr.sin_port = htons(8080)\naddr.sin_addr = INADDR_ANY" {
  style.stroke: "#7d3c98"
}
BOUND -> LISTENING: "listen(server_fd, 128)\nKernel creates:\n• SYN queue (incomplete)\n• Accept queue (complete)" {
  style.stroke: "#2e86c1"
  style.stroke-width: 2
}
LISTENING -> ACCEPT_LOOP: "Enter while(!shutdown) loop" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
ACCEPT_LOOP -> CLIENT_CONNECTED: "accept() returns client_fd\n[dequeues from kernel accept queue]\nReturns: new FD ≥ baseline+1" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
CLIENT_CONNECTED -> READING: "handle_client(client_fd) called" {
  style.stroke: "#27ae60"
}
READING -> WRITING: "read_request() returns > 0\n\\r\\n\\r\\n found in buf\nFirst line logged to stdout" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
WRITING -> CLIENT_CLOSED: "send_all() returns len\n[all bytes accepted by kernel]\nReturns to main() accept loop" {
  style.stroke: "#58d68d"
  style.stroke-width: 2
}
CLIENT_CLOSED -> ACCEPT_LOOP: "close(client_fd) completes\n[FD table entry freed]\nLoop back to accept()" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
ACCEPT_LOOP -> SERVER_SHUTDOWN: "shutdown_flag set\n(SIGTERM/SIGINT)\nBreak while loop" {
  style.stroke: "#85c1e9"
}

# ── Error Transitions ─────────────────────────────────────────────────────────
SO_REUSEADDR_SET -> ERR_BIND: "bind() → EADDRINUSE\n[Port in TIME_WAIT;\nSO_REUSEADDR missing or\nnot set before bind()]" {
  style.stroke: "#e74c3c"
  style.stroke-width: 2
  style.stroke-dash: 3
}
ACCEPT_LOOP -> ERR_ACCEPT: "accept() < 0\nerrno ∈ {EINTR,EMFILE,\nENFILE,other}" {
  style.stroke: "#e67e22"
  style.stroke-dash: 3
}
ERR_ACCEPT -> ACCEPT_LOOP: "continue (non-fatal)\nServer keeps running" {
  style.stroke: "#e67e22"
  style.stroke-dash: 3
}
READING -> ERR_RECV: "recv()==0 [client EOF]\nrecv()<0 [ECONNRESET]\nbuf full [no delimiter]" {
  style.stroke: "#e67e22"
  style.stroke-dash: 3
}
ERR_RECV -> CLIENT_CLOSED: "handle_client() returns -1\nmain() still calls close(client_fd)\n[close() on every path is invariant]" {
  style.stroke: "#e67e22"
  style.stroke-dash: 3
}

# ── SIGPIPE Path (before fix) ─────────────────────────────────────────────────
WRITING -> SIGPIPE_DEATH: "Client closes connection\nmid-response\nsend() to closed socket\n[WITHOUT MSG_NOSIGNAL\nAND WITHOUT SIG_IGN]" {
  style.stroke: "#c0392b"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.font-color: "#e74c3c"
}

# ── SIGPIPE Fix Path ──────────────────────────────────────────────────────────
WRITING -> SIGPIPE_FIXED: "signal(SIGPIPE,SIG_IGN) at startup\nAND MSG_NOSIGNAL per send()\n→ send() returns -1/EPIPE\n[client disconnect handled gracefully]" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.stroke-dash: 3
}
SIGPIPE_FIXED -> CLIENT_CLOSED: "send_all() returns -1\nlog to stderr\nreturn from handle_client()\nmain() calls close(client_fd)" {
  style.stroke: "#27ae60"
  style.stroke-dash: 3
}

# ── Illegal Transitions (RED DASHED) ─────────────────────────────────────────
LISTENING -> ILLEGAL_READ_SERVER: "ILLEGAL: recv(server_fd,…)\nor read(server_fd,…)" {
  style.stroke: "#8e44ad"
  style.stroke-width: 3
  style.stroke-dash: 8
  style.font-color: "#8e44ad"
}
LISTENING -> ILLEGAL_WRITE_SERVER: "ILLEGAL: send(server_fd,…)\nor write(server_fd,…)" {
  style.stroke: "#8e44ad"
  style.stroke-width: 3
  style.stroke-dash: 8
  style.font-color: "#8e44ad"
}
WRITING -> FD_LEAK_DEATH: "ILLEGAL: return WITHOUT\ncalling close(client_fd)\n→ FD table grows unbounded" {
  style.stroke: "#c0392b"
  style.stroke-width: 3
  style.stroke-dash: 8
  style.font-color: "#c0392b"
}

# ── Annotations ───────────────────────────────────────────────────────────────
# Changed from object-relative near to absolute constant directions for ELK compliance
note_htons: |md
  **htons() is mandatory**
  `sin_port = 8080` (no htons) →
  binds port **36895** (0x901F)
  x86 little-endian swaps 0x1F90
  bind() succeeds; nothing connects
| {
  near: top-right
  style.fill: "#2c1a0e"
  style.stroke: "#e67e22"
  style.font-color: "#fdebd0"
  style.border-radius: 4
}

note_twofd: |md
  **Two distinct FD types:**
  `server_fd` = passive socket
    • Never recv/send from it
    • Lives entire server lifetime
  `client_fd` = connected socket
    • Created per accept()
    • Must close() after each use
| {
  near: center-right
  style.fill: "#0e2c1a"
  style.stroke: "#27ae60"
  style.font-color: "#d5f5e3"
  style.border-radius: 4
}

note_partial: |md
  **Why recv() loops:**
  TCP is a byte stream, not messages.
  One send(1400B) may arrive as:
    • recv()→700B + recv()→700B
    • OR recv()→1400B
  Loop until `\r\n\r\n` found.
  Single recv() = silent data loss.
| {
  near: bottom-right
  style.fill: "#0e2c1a"
  style.stroke: "#27ae60"
  style.font-color: "#d5f5e3"
  style.border-radius: 4
}