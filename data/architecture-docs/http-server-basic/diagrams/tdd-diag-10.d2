vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |md
  ## `http_request_t` + `http_header_t` Memory Layout
  All offsets in decimal bytes · 64-byte cache lines marked
| {near: top-center}

# ─── http_header_t ────────────────────────────────────────────────
hdr_title: "`http_header_t`  (total = 1152 bytes = 18 cache lines)" {
  style.fill: "#3d1a6b"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}

hdr_layout: {
  style.fill: "#f8f4ff"
  style.stroke: "#3d1a6b"
  style.stroke-width: 2
  style.border-radius: 4

  hdr_name: |md
    **+0x000  `name[128]`**
    `char[128]`  ·  128 bytes
    Lowercase ASCII, null-terminated
    e.g. `"content-type\0"`
    Cache lines 0 – 1  (2 lines)
  | {
    style.fill: "#9b59b6"
    style.font-color: white
    style.border-radius: 3
    width: 460
  }

  hdr_cl_boundary_1: "── 64-byte cache line boundary ──" {
    style.fill: "#ede7f6"
    style.stroke: "#9b59b6"
    style.stroke-dash: 4
    style.font-color: "#6a1b9a"
    style.italic: true
    width: 460
  }

  hdr_value: |md
    **+0x080  `value[1024]`**
    `char[1024]`  ·  1024 bytes
    OWS-stripped, obs-fold-unfolded, null-terminated
    Cache lines 2 – 17  (16 lines)
  | {
    style.fill: "#2980b9"
    style.font-color: white
    style.border-radius: 3
    width: 460
  }

  hdr_total: |md
    **Total: 1152 bytes**  ·  18 cache lines  ·  `sizeof(http_header_t) = 1152`
  | {
    style.fill: "#ecf0f1"
    style.stroke: "#7f8c8d"
    style.font-color: "#2c3e50"
    width: 460
  }

  hdr_name -> hdr_cl_boundary_1
  hdr_cl_boundary_1 -> hdr_value
  hdr_value -> hdr_total
}

hdr_title -> hdr_layout: "" {style.stroke-width: 0}

# ─── http_request_t ───────────────────────────────────────────────
req_title: "`http_request_t`  (total ≈ 45,108 bytes · ~44 KB)" {
  style.fill: "#1a3a6b"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}

req_layout: {
  style.fill: "#f0f4ff"
  style.stroke: "#1a3a6b"
  style.stroke-width: 2
  style.border-radius: 4

  f_method: |md
    **+0x0000  `method[16]`**
    `char[16]`  ·  16 bytes
    `"GET"`, `"HEAD"`, `"POST"`, …
    Cache line 0
  | {
    style.fill: "#8e44ad"
    style.font-color: white
    style.border-radius: 3
    width: 560
  }

  f_path: |md
    **+0x0010  `path[8192]`**
    `char[8192]`  ·  8192 bytes
    Raw URL path (NOT percent-decoded)
    Cache lines 0 – 127  (128 lines)
  | {
    style.fill: "#2471a3"
    style.font-color: white
    style.border-radius: 3
    width: 560
  }

  f_cl_1: "── 64-byte cache line boundaries throughout path[] ──" {
    style.fill: "#eaf2ff"
    style.stroke: "#2471a3"
    style.stroke-dash: 4
    style.font-color: "#1a5276"
    style.italic: true
    width: 560
  }

  f_version: |md
    **+0x2010  `version[16]`**
    `char[16]`  ·  16 bytes
    `"HTTP/1.1"` or `"HTTP/1.0"`
    Cache line 128
  | {
    style.fill: "#8e44ad"
    style.font-color: white
    style.border-radius: 3
    width: 560
  }

  f_headers: |md
    **+0x2020  `headers[32]`**
    `http_header_t[32]`  ·  **36,864 bytes**
    32 × 1152 bytes/entry
    Cache lines 129 – 704  (576 lines)
    ⚠ Dominant stack cost — 36 KB alone
  | {
    style.fill: "#117a65"
    style.font-color: white
    style.border-radius: 3
    style.bold: true
    width: 560
  }

  f_cl_2: "── cache line boundaries every 64 bytes through headers[] ──" {
    style.fill: "#e8f8f5"
    style.stroke: "#117a65"
    style.stroke-dash: 4
    style.font-color: "#0e6655"
    style.italic: true
    width: 560
  }

  f_header_count: |md
    **+0xB020  `header_count`**
    `int`  ·  4 bytes
    Valid range: 0 – 32
    Cache line 704
  | {
    style.fill: "#8e44ad"
    style.font-color: white
    style.border-radius: 3
    width: 560
  }

  f_pad: |md
    **+0xB024  (alignment padding)**
    4 bytes — aligns next `const char *` to 8-byte boundary
  | {
    style.fill: "#bdc3c7"
    style.font-color: "#2c3e50"
    style.border-radius: 3
    width: 560
  }

  f_body: |md
    **+0xB028  `body`**
    `const char *`  ·  8 bytes
    Zero-copy pointer into caller's recv buffer
    Points to first byte after `\r\n\r\n`
    NULL if no body bytes captured
    Cache line 704
  | {
    style.fill: "#e67e22"
    style.font-color: white
    style.border-radius: 3
    width: 560
  }

  f_body_len: |md
    **+0xB030  `body_len`**
    `size_t`  ·  8 bytes
    Bytes from `body` to end of buffer
    0 if `body == NULL`
    Cache line 704
  | {
    style.fill: "#e67e22"
    style.font-color: white
    style.border-radius: 3
    width: 560
  }

  f_total: |md
    **+0xB038  end**
    Total: **≈ 45,108 bytes** · 705 cache lines
    `sizeof(http_request_t)` ≈ 45,108 B
  | {
    style.fill: "#ecf0f1"
    style.stroke: "#7f8c8d"
    style.font-color: "#2c3e50"
    width: 560
  }

  f_method -> f_path
  f_path -> f_cl_1
  f_cl_1 -> f_version
  f_version -> f_headers
  f_headers -> f_cl_2
  f_cl_2 -> f_header_count
  f_header_count -> f_pad
  f_pad -> f_body
  f_body -> f_body_len
  f_body_len -> f_total
}

req_title -> req_layout: "" {style.stroke-width: 0}

# ─── Stack concern annotation ─────────────────────────────────────
# Using |' delimiter to allow pipes inside the Markdown table
stack_warn: |'md
  ⚠ **Stack-size concern** (per-connection, single-threaded M3 / per-thread M4)

  | Region | Size |
  |---|---|
  | `http_request_t` on stack | ≈ 45,108 B |
  | `char buf[8192]` (recv buffer) | 8,192 B |
  | `char read_buf[65536]` (M3 file read) | 65,536 B |
  | Misc locals + alignment | ≈ 300 B |
  | **Total per thread** | **≈ 119 KB** |

  Linux default thread stack: **8 MB** → safe for pool of 64 threads
  Compile guard: `gcc -Wframe-larger-than=131072`
'| {
  near: bottom-center
  style.fill: "#fef9e7"
  style.stroke: "#f39c12"
  style.stroke-width: 2
  style.border-radius: 6
}

# ─── Legend ───────────────────────────────────────────────────────
legend: {
  near: bottom-right
  style.fill: "#fafafa"
  style.stroke: "#95a5a6"
  style.border-radius: 4

  l1: "Header/metadata field" {style.fill: "#8e44ad"; style.font-color: white}
  l2: "Data / large buffer" {style.fill: "#2471a3"; style.font-color: white}
  l3: "Pointer (orange = pointer field)" {style.fill: "#e67e22"; style.font-color: white}
  l4: "Padding (gray)" {style.fill: "#bdc3c7"; style.font-color: "#2c3e50"}
  l5: "headers[] array (dominant cost)" {style.fill: "#117a65"; style.font-color: white}
  l6: "Cache line boundary (dashed)" {style.stroke: "#7f8c8d"; style.stroke-dash: 4; style.fill: "#f5f5f5"}

  l1 -- l2: "" {style.stroke-width: 0}
  l2 -- l3: "" {style.stroke-width: 0}
  l3 -- l4: "" {style.stroke-width: 0}
  l4 -- l5: "" {style.stroke-width: 0}
  l5 -- l6: "" {style.stroke-width: 0}
}