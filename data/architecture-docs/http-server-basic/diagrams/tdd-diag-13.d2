vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Case-Insensitive Header Normalization: Before/After Buffer Transformation
'| {near: top-center}

# ─── RAW WIRE BUFFER ───────────────────────────────────────────────────────
raw_buf: "Raw Buffer: buf[]" {
  style.fill: "#1a1a2e"
  style.font-color: white
  style.bold: true
  style.border-radius: 4

  bytes: |'md
`Content-Type:   text/html; charset=utf-8\r\n`
'| {
    style.fill: "#16213e"
    style.font-color: "#00d4aa"
    style.font: mono
  }

  offsets: |'md
| Offset | 0 | 1 | 2 | … | 11 | 12 | 13–15 | 16 | … | 42 | 43 |
|--------|---|---|---|---|----|----|-------|----|----|----|----|
| Byte   | C | o | n | … | e  | :  | SP×3  | t  | … | \r | \n |
| Role   | ← name[0..11] = 12 B → | sep | ← OWS → | ← value → | CRLF |
'| {
    style.fill: "#0f3460"
    style.font-color: "#e0e0e0"
    style.font: mono
    style.font-size: 11
  }
}

# ─── STEP 1: FIND COLON WITH memchr ────────────────────────────────────────
step1: "Step 1 — memchr(line, ':', line_len)" {
  style.fill: "#1b2838"
  style.font-color: white
  style.bold: true

  before: "Before: pointer scan" {
    style.fill: "#2d3a4a"
    scan_vis: |'md
`C  o  n  t  e  n  t  -  T  y  p  e  :  …`
`↑  ·  ·  ·  ·  ·  ·  ·  ·  ·  ·  ·  ^`
`line                               colon`
'| {
      style.fill: "#1e2d3d"
      style.font-color: "#ffd700"
      style.font: mono
      style.font-size: 12
    }
  }

  result: "After: name_len computed" {
    style.fill: "#2d3a4a"
    vals: |'md
`colon     = line + 12`
`name_len  = colon − line = 12`
`path_start = colon + 1   (skip ':')`
'| {
      style.fill: "#1e2d3d"
      style.font-color: "#00ff88"
      style.font: mono
      style.font-size: 12
    }
  }
}

# ─── STEP 2: tolower LOOP ───────────────────────────────────────────────────
step2: "Step 2 — tolower() loop: name[i] = tolower((unsigned char)name[i])" {
  style.fill: "#1b2838"
  style.font-color: white
  style.bold: true

  before_name: "BEFORE (raw copy)" {
    style.fill: "#3a1a1a"
    chars_before: |'md
`C  o  n  t  e  n  t  -  T  y  p  e  \0`
`0x43  …                 0x54  …  0x65`
'| {
      style.fill: "#2d1515"
      style.font-color: "#ff8080"
      style.font: mono
      style.font-size: 12
    }
  }

  transform: "In-place byte transform" {
    style.fill: "#1a2a1a"
    changes: |'md
| Index | Before | Hex | After | Hex  |
|-------|--------|-----|-------|------|
| 0     | **C**  |0x43 | **c** |0x63  |
| 7     | **-**  |0x2D | **-** |0x2D  |
| 8     | **T**  |0x54 | **t** |0x74  |
'| {
      style.fill: "#152515"
      style.font-color: "#80ff80"
      style.font: mono
      style.font-size: 11
    }

    cast_note: |'md
⚠ Cast: `(unsigned char)` MANDATORY
Prevents UB on chars > 0x7F
'| {
      style.fill: "#2a2a00"
      style.font-color: "#ffff00"
      style.font-size: 11
    }
  }

  after_name: "AFTER (lowercased)" {
    style.fill: "#1a3a1a"
    chars_after: |'md
`c  o  n  t  e  n  t  -  t  y  p  e  \0`
`0x63  …                 0x74  …  0x65`
'| {
      style.fill: "#153015"
      style.font-color: "#00ff88"
      style.font: mono
      style.font-size: 12
    }
  }
  before_name -> transform -> after_name
}

# ─── STEP 3: OWS STRIP ──────────────────────────────────────────────────────
step3: "Step 3 — Strip OWS from value (lead + trail)" {
  style.fill: "#1b2838"
  style.font-color: white
  style.bold: true

  ows_before: "Raw value region after ':'" {
    style.fill: "#3a2a1a"
    ows_vis: |'md
`[SP][SP][SP]text/html; charset=utf-8`
` ↑ value_start (raw)          ↑ value_end`
'| {
      style.fill: "#2d2015"
      style.font-color: "#ffaa44"
      style.font: mono
      style.font-size: 12
    }
  }

  lead_strip: "Leading OWS: advance value_start" {
    style.fill: "#1a2a3a"
    lead_code: |'md
`while (*vs == ' ' || *vs == '\t') vs++;`
`vs advances: +3 bytes past 3 spaces`
'| {
      style.fill: "#152030"
      style.font-color: "#88ccff"
      style.font: mono
      style.font-size: 12
    }
  }

  trail_strip: "Trailing OWS: retreat value_end" {
    style.fill: "#1a2a3a"
    trail_code: |'md
`while (*(ve-1) == ' ' || *(ve-1) == '\t') ve--;`
`(no trailing spaces in this example)`
'| {
      style.fill: "#152030"
      style.font-color: "#88ccff"
      style.font: mono
      style.font-size: 12
    }
  }

  ows_after: "Clean value region" {
    style.fill: "#1a3a1a"
    ows_result: |'md
`text/html; charset=utf-8`
` ↑ vs                  ↑ ve`
`value_len = ve − vs = 24`
'| {
      style.fill: "#153015"
      style.font-color: "#00ff88"
      style.font: mono
      style.font-size: 12
    }
  }
  ows_before -> lead_strip -> trail_strip -> ows_after
}

# ─── STEP 4: memcpy INTO http_header_t ──────────────────────────────────────
step4: "Step 4 — memcpy into http_header_t fields" {
  style.fill: "#1b2838"
  style.font-color: white
  style.bold: true

  hdr_struct: "http_header_t (on stack)" {
    style.fill: "#2a1a3a"
    style.border-radius: 4
    name_field: "name[128]" {
      style.fill: "#1e0a2e"
      style.font-color: "#cc88ff"
      name_val: |'md
`"content-type\0"`
`← 13 bytes written (12 + \0)`
offset: "0x000 – 0x080"
'| {
        style.fill: "#150a25"
        style.font-color: "#dd99ff"
        style.font: mono
        style.font-size: 11
      }
    }
    value_field: "value[1024]" {
      style.fill: "#1e0a2e"
      style.font-color: "#cc88ff"
      value_val: |'md
`"text/html; charset=utf-8\0"`
`← 25 bytes written (24 + \0)`
offset: "0x080 – 0x480"
'| {
        style.fill: "#150a25"
        style.font-color: "#dd99ff"
        style.font: mono
        style.font-size: 11
      }
    }
  }

  copy_ops: "memcpy operations" {
    style.fill: "#1a1a3a"
    ops: |'md
`memcpy(hdr->name,  line, name_len=12);`
`hdr->name[12] = '\0';`
`/* tolower loop applied above */`
`memcpy(hdr->value, vs, value_len=24);`
`hdr->value[24] = '\0';`
'| {
      style.fill: "#10102a"
      style.font-color: "#aaaaff"
      style.font: mono
      style.font-size: 11
    }
  }
}

# ─── LOOKUP STAGE ───────────────────────────────────────────────────────────
lookup: "Lookup: get_header(req, \"content-type\")" {
  style.fill: "#1b2838"
  style.font-color: white
  style.bold: true

  caller: "Caller passes lowercase key" {
    style.fill: "#1a2a1a"
    caller_code: |'md
`const char *ct =`
`  get_header(&req, "content-type");`
`                    ↑ lowercase`
'| {
      style.fill: "#102010"
      style.font-color: "#80ff80"
      style.font: mono
      style.font-size: 12
    }
  }

  scan: "Linear scan: strcmp per entry" {
    style.fill: "#2a2a1a"
    scan_loop: |'md
`for (i = 0; i < req->header_count; i++) {`
`  strcmp(req->headers[i].name,`
`         "content-type")`
`  // i=0: "content-type" == "content-type" → MATCH`
`}`
'| {
      style.fill: "#202010"
      style.font-color: "#ffffaa"
      style.font: mono
      style.font-size: 11
    }

    perf_note: |'md
n ≤ 32 entries · ~15 B/name
All in L1 cache after first touch
O(n) but faster than hash for n<32
'| {
      style.fill: "#1a1a00"
      style.font-color: "#cccc44"
      style.font-size: 10
    }
  }

  match: "MATCH → return pointer to value" {
    style.fill: "#1a3a1a"
    style.border-radius: 8
    match_result: |'md
`returns: "text/html; charset=utf-8"`
`         ↑ pointer into hdr->value[]`
`         NO copy — zero allocation`
'| {
      style.fill: "#103010"
      style.font-color: "#00ff88"
      style.font: mono
      style.font-size: 12
    }
  }

  nomatch: "NO MATCH → return NULL" {
    style.fill: "#3a1a1a"
    nomatch_result: |'md
`if strcmp fails for all i:`
`  return NULL`
`Caller checks NULL before use`
'| {
      style.fill: "#2a1010"
      style.font-color: "#ff8080"
      style.font: mono
      style.font-size: 12
    }
  }
}

# ─── BEFORE / AFTER SUMMARY ─────────────────────────────────────────────────
summary: "Before / After: Complete Transformation" {
  style.fill: "#0d0d1a"
  style.font-color: white
  style.bold: true
  style.border-radius: 8

  before_box: "BEFORE (wire bytes)" {
    style.fill: "#2a1a1a"
    style.border-radius: 4
    b: |'md
Name:  `Content-Type`   ← mixed-case
Sep:   `:`
OWS:   `   ` (3 spaces)
Value: `text/html; charset=utf-8`
'| {
      style.fill: "#200a0a"
      style.font-color: "#ff9999"
      style.font: mono
      style.font-size: 12
    }
  }

  arrow_lbl: "→ parse_headers() →" {
    shape: text
    style.font-color: "#ffffff"
    style.bold: true
    style.font-size: 14
  }

  after_box: "AFTER (stored in http_header_t)" {
    style.fill: "#1a2a1a"
    style.border-radius: 4
    a: |'md
name[]:  `content-type\0`  ← all lowercase
value[]: `text/html; charset=utf-8\0`
                            ← OWS stripped
'| {
      style.fill: "#0a200a"
      style.font-color: "#88ff88"
      style.font: mono
      style.font-size: 12
    }
  }
}

invariant: |'md
**Invariant**: All stored header names are lowercase ASCII.
All lookups use lowercase keys. strcmp() suffices — no strcasecmp() needed at lookup time.
Value case is PRESERVED (RFC 7230: header values are case-sensitive by default).
'| {
  style.fill: "#1a1a2a"
  style.font-color: "#aaaaff"
  style.font-size: 11
  near: bottom-center
}

# ─── CONNECTIONS ─────────────────────────────────────────────────────────────
raw_buf -> step1: "line = buf; line_len measured" {
  style.stroke: "#888888"
  style.font-size: 11
}
step1 -> step2: "name span [0..name_len) identified" {
  style.stroke: "#ffd700"
  style.font-size: 11
}
step2 -> step3: "hdr->name[] populated (lowercased)" {
  style.stroke: "#00ff88"
  style.font-size: 11
}
step3 -> step4: "value_start, value_end finalized" {
  style.stroke: "#88aaff"
  style.font-size: 11
}
step4 -> lookup: "req->header_count++ → struct complete" {
  style.stroke: "#cc88ff"
  style.font-size: 11
}

lookup.caller -> lookup.scan -> lookup.match: {
  style.stroke: "#00ff88"
}
lookup.scan -> lookup.nomatch: {
  style.stroke: "#ff4444"
  style.stroke-dash: 5
}

step1 -> summary: {style.opacity: 0}
step4 -> summary: {style.opacity: 0}
summary.before_box -> summary.arrow_lbl -> summary.after_box