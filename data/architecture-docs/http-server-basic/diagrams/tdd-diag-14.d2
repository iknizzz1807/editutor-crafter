vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## obs-fold Unfolding: Before/After Buffer State
  `parse_headers()` — RFC 7230 §3.2.6 Obsolete Line Folding
| {near: top-center}
# ─── BEFORE: Raw Buffer Contents ───────────────────────────────────────────
before: "BEFORE: Raw Buffer (2 header lines)" {
  style.fill: "#e8f4f8"
  style.stroke: "#4a90d9"
  style.stroke-width: 2
  style.border-radius: 6
  line1: |md
    **line 1** → `Subject: This is\r\n`
    offset +0: `S u b j e c t : SP T h i s SP i s \r \n`
  | {
    style.fill: "#dce8f5"
    style.stroke: "#4a90d9"
    style.border-radius: 4
  }
  line2: |md
    **line 2** → `  a continuation\r\n`
    offset +20: `SP SP a SP c o n t i n u a t i o n \r \n`
    ↑ line\[0\] == ' ' **(SPACE — obs-fold trigger)**
  | {
    style.fill: "#fff3cd"
    style.stroke: "#f0a500"
    style.stroke-width: 2
    style.border-radius: 4
  }
  line3: |md
    **line 3** → `\r\n`  ← end-of-headers
  | {
    style.fill: "#e8f5e9"
    style.stroke: "#4caf50"
    style.border-radius: 4
  }
}
# ─── ITERATION 1: Normal Header Parse ───────────────────────────────────────
iter1: "ITERATION 1: Normal Header Line" {
  style.fill: "#f3f0ff"
  style.stroke: "#7c4dff"
  style.stroke-width: 2
  style.border-radius: 6
  step_A: "Step A: Find \\n → line_end" {
    style.fill: "#ede7f6"
    style.border-radius: 4
  }
  step_B: "Step B: line\\_len = 18 (strip \\r)" {
    style.fill: "#ede7f6"
    style.border-radius: 4
  }
  step_C: "Step C: line\[0\]='S' — NOT obs-fold" {
    style.fill: "#ede7f6"
    style.border-radius: 4
  }
  step_D: "Step D: Find colon at offset 7" {
    style.fill: "#ede7f6"
    style.border-radius: 4
  }
  step_E: "Step E: name_len=7  →  name=\"subject\" (lowercased)" {
    style.fill: "#ede7f6"
    style.border-radius: 4
  }
  step_F: "Step F: OWS strip  →  value=\"This is\"" {
    style.fill: "#ede7f6"
    style.border-radius: 4
  }
  step_G: "Step G: header_count++ = 1  →  headers\[0\] committed" {
    style.fill: "#c8e6c9"
    style.stroke: "#388e3c"
    style.border-radius: 4
  }
  step_A -> step_B -> step_C -> step_D -> step_E -> step_F -> step_G
}
# ─── ITERATION 2: obs-fold Detection ────────────────────────────────────────
iter2: "ITERATION 2: obs-fold Continuation" {
  style.fill: "#fff8e1"
  style.stroke: "#f0a500"
  style.stroke-width: 2
  style.border-radius: 6
  chk_sp: "CHECK: line\[0\] == ' '  →  TRUE (SPACE)" {
    style.fill: "#fff3cd"
    style.stroke: "#f0a500"
    style.stroke-width: 2
    style.border-radius: 4
  }
  chk_cnt: "CHECK: header_count > 0  →  TRUE (== 1)" {
    style.fill: "#fff3cd"
    style.stroke: "#f0a500"
    style.stroke-width: 2
    style.border-radius: 4
  }
  obs_path: "OBS-FOLD PATH TAKEN" {
    style.fill: "#ffe082"
    style.stroke: "#ff8f00"
    style.stroke-width: 3
    style.font-size: 16
    style.bold: true
    style.border-radius: 4
  }
  trim: "Trim leading whitespace from continuation:\n\"  a continuation\" → \"a continuation\"\ncont_len = 14" {
    style.fill: "#fff8e1"
    style.border-radius: 4
  }
  calc: "prev_len = strlen(\"This is\") = 7\nspace_needed = 7 + 1 + 14 = 22\n22 < MAX_HEADER_VALUE-1 (1023)  →  fits" {
    style.fill: "#fff8e1"
    style.border-radius: 4
  }
  append: "Append SP + continuation:\nprev->value\[7\] = ' '\nmemcpy(prev->value+8, \"a continuation\", 14)\nprev->value\[22\] = '\\0'" {
    style.fill: "#ffe082"
    style.stroke: "#ff8f00"
    style.border-radius: 4
  }
  no_commit: "header_count UNCHANGED = 1\n(no header_count++)" {
    style.fill: "#fff3cd"
    style.stroke: "#f0a500"
    style.border-radius: 4
  }
  chk_sp -> chk_cnt -> obs_path -> trim -> calc -> append -> no_commit
}
# ─── ILLEGAL CASE: obs-fold when header_count == 0 ──────────────────────────
illegal: "ILLEGAL CASE: obs-fold with header_count == 0" {
  style.fill: "#ffebee"
  style.stroke: "#d32f2f"
  style.stroke-width: 3
  style.border-radius: 6
  illegal_note: |md
    **Input:** Buffer starts with continuation line
    `  orphan continuation\r\n`
    `Host: x\r\n`
    `\r\n`
    line\[0\] == ' '  →  TRUE
    header\_count == 0  →  **NO previous header to append to**
    **ACTION: skip line silently**
    `pos = line_end + 1; continue;`
    header\_count stays 0.
    The orphan continuation is discarded.
  | {
    style.fill: "#ffcdd2"
    style.stroke: "#d32f2f"
    style.stroke-width: 2
    style.border-radius: 4
  }
}
# ─── AFTER: headers[0] final state ──────────────────────────────────────────
after: "AFTER: headers\[0\] Final State" {
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.stroke-width: 2
  style.border-radius: 6
  field_name: |md
    `headers[0].name`  =  `"subject"`
    *(lowercased at parse time — lookup uses lowercase keys)*
  | {
    style.fill: "#c8e6c9"
    style.stroke: "#388e3c"
    style.border-radius: 4
  }
  field_val: |md
    `headers[0].value` =  `"This is a continuation"`
    byte layout:
    `T h i s SP i s SP a SP c o n t i n u a t i o n \0`
    offset:   0          7  8                       22
  | {
    style.fill: "#c8e6c9"
    style.stroke: "#388e3c"
    style.border-radius: 4
  }
  field_cnt: |md
    `header_count` = **1**  *(unchanged by obs-fold iteration)*
  | {
    style.fill: "#a5d6a7"
    style.stroke: "#2e7d32"
    style.stroke-width: 2
    style.border-radius: 4
  }
}
# ─── CONNECTIONS ────────────────────────────────────────────────────────────
before -> iter1: "iteration 1\npos = buf+first_nl+1" {
  style.stroke: "#7c4dff"
  style.stroke-width: 2
}
iter1 -> iter2: "iteration 2\npos = line2_start\nline\[0\]==' '" {
  style.stroke: "#f0a500"
  style.stroke-width: 2
  style.animated: true
}
iter2 -> after: "unfold complete\nheader\_count=1" {
  style.stroke: "#388e3c"
  style.stroke-width: 2
}
iter2.chk_cnt -> illegal: "IF header_count==0\n→ ILLEGAL path" {
  style.stroke: "#d32f2f"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-color: "#d32f2f"
}