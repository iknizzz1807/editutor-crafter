vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
root: "raw buffer received" {
  shape: diamond
  style.fill: "#B5AFF6"
  style.font-size: 14
  style.bold: true
}
bad_read: "400 Bad Request\n[read error / timeout / EOF]" {
  shape: rectangle
  style.fill: "#FF6B6B"
  style.font-color: white
  style.bold: true
}
parse_line: "parse_request_line()" {
  shape: diamond
  style.fill: "#DEE1EB"
  style.font-size: 13
}
uri_414: "414 URI Too Long\n[HTTP_414]\nclose FD" {
  shape: rectangle
  style.fill: "#FF6B6B"
  style.font-color: white
  style.bold: true
}
bad_req_line: "400 Bad Request\n[HTTP_400]\nclose FD" {
  shape: rectangle
  style.fill: "#FF6B6B"
  style.font-color: white
  style.bold: true
}
check_version: "version ==\nHTTP/1.0 or HTTP/1.1?" {
  shape: diamond
  style.fill: "#DEE1EB"
  style.font-size: 13
}
bad_version: "400 Bad Request\n[HTTP_400]\nunrecognized version\nclose FD" {
  shape: rectangle
  style.fill: "#FF6B6B"
  style.font-color: white
  style.bold: true
}
check_method: "classify_method()" {
  shape: diamond
  style.fill: "#DEE1EB"
  style.font-size: 13
}
not_impl: "501 Not Implemented\n[HTTP_501]\nclose FD" {
  shape: rectangle
  style.fill: "#FF6B6B"
  style.font-color: white
  style.bold: true
}
check_host: "Host header present?\n(HTTP/1.1 strict mode)" {
  shape: diamond
  style.fill: "#DEE1EB"
  style.font-size: 13
}
bad_host: "400 Bad Request\n[HTTP_400]\nmissing Host\nclose FD" {
  shape: rectangle
  style.fill: "#FF6B6B"
  style.font-color: white
  style.bold: true
}
serve: "serve_file()\n[M3 pipeline]\nkeep-alive eligible" {
  shape: rectangle
  style.fill: "#4CAF50"
  style.font-color: white
  style.bold: true
}
legend: |md
  **Return codes**
  - `read_request()` ≤ 0 → no HTTP response possible
  - `parse_request_line()` = -1 → 400
  - `parse_request_line()` = -2 → 414
  - `classify_method()` = HTTP_METHOD_OTHER → 501
  - All leaves: `close(client_fd)` after send
| {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.font-size: 12
}
root -> bad_read: "read_request()\nreturns ≤ 0\n[no bytes / EOF / timeout]" {
  style.stroke: "#FF6B6B"
  style.bold: true
}
root -> parse_line: "read_request()\nreturns > 0\n[buffer has \\r\\n\\r\\n]" {
  style.stroke: "#4CAF50"
  style.bold: true
}
parse_line -> uri_414: "returns -2\n[path_len ≥ MAX_PATH_LEN\n= 8192 bytes]" {
  style.stroke: "#FF6B6B"
  style.bold: true
}
parse_line -> bad_req_line: "returns -1\n[no spaces / empty\nmethod or path /\ntruncated version]" {
  style.stroke: "#FF8C00"
  style.bold: true
}
parse_line -> check_version: "returns 0\n[method + path +\nversion extracted]" {
  style.stroke: "#4CAF50"
  style.bold: true
}
check_version -> bad_version: "NO\n[e.g. HTTP/2,\nHTTP/9.9, garbage]" {
  style.stroke: "#FF6B6B"
  style.bold: true
}
check_version -> check_method: "YES\n[HTTP/1.0 or HTTP/1.1]" {
  style.stroke: "#4CAF50"
  style.bold: true
}
check_method -> not_impl: "HTTP_METHOD_OTHER\n[DELETE, PUT, PATCH,\nOPTIONS, TRACE, …]" {
  style.stroke: "#FF6B6B"
  style.bold: true
}
check_method -> check_host: "HTTP_METHOD_GET\nor HTTP_METHOD_HEAD" {
  style.stroke: "#4CAF50"
  style.bold: true
}
check_host -> bad_host: "NULL\n[strict mode only;\nlog-and-continue\nin lenient mode]" {
  style.stroke: "#FF8C00"
  style.bold: true
  style.stroke-dash: 5
}
check_host -> serve: "present\n[or lenient mode\nignores absence]" {
  style.stroke: "#4CAF50"
  style.bold: true
}