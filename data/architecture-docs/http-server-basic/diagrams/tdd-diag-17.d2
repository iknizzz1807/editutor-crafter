vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## HEAD vs GET Response Data Flow
  *Same resource · identical headers · body bytes differ*
| {near: top-center}
client: "Client\n(Browser / curl)" {
  shape: rectangle
  style.fill: "#E8F4F8"
  style.stroke: "#4A90D9"
  style.font-size: 13
}
parser: "http_parse_request()\nbuf → http_request_t" {
  shape: rectangle
  style.fill: "#D4B8E0"
  style.stroke: "#7B2D8B"
  style.font-size: 12
}
classify: "classify_method()\nreq.method" {
  shape: diamond
  style.fill: "#FFD700"
  style.stroke: "#B8860B"
  style.font-size: 12
}
stat_call: "stat(canonical)\n→ struct stat st" {
  shape: rectangle
  style.fill: "#B8D4E8"
  style.stroke: "#2C6B9E"
  style.font-size: 12
  style.bold: true
}
note_stat: |md
  **st.st_size** → Content-Length
  **st.st_mtime** → Last-Modified
  *Computed once; shared by both methods*
| {
  near: top-right
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
  style.font-size: 11
}
header_build: "Build response headers\nsnprintf(header_buf, …)" {
  shape: rectangle
  style.fill: "#B8D4E8"
  style.stroke: "#2C6B9E"
  style.font-size: 12
}
send_headers: "send_all(client_fd,\nheader_buf, header_len)" {
  shape: rectangle
  style.fill: "#90EE90"
  style.stroke: "#2E8B57"
  style.font-size: 12
  style.bold: true
}
branch: "send_body flag" {
  shape: diamond
  style.fill: "#FFB347"
  style.stroke: "#D2691E"
  style.font-size: 12
}
open_file: "open(canonical, O_RDONLY)\n→ file_fd" {
  shape: rectangle
  style.fill: "#90EE90"
  style.stroke: "#2E8B57"
  style.font-size: 12
}
read_loop: "read(file_fd, read_buf, 65536)\n→ send_all(client_fd, …)\n[loop until EOF]" {
  shape: rectangle
  style.fill: "#90EE90"
  style.stroke: "#2E8B57"
  style.font-size: 12
  style.bold: true
}
skip_body: "Body bytes NEVER read\nopen() NOT called\nclose(file_fd) not needed" {
  shape: rectangle
  style.fill: "#FFB6C1"
  style.stroke: "#DC143C"
  style.font-size: 12
  style.italic: true
}
close_fd: "close(file_fd)" {
  shape: rectangle
  style.fill: "#D3D3D3"
  style.stroke: "#696969"
  style.font-size: 12
}
get_col: "GET Response\n(send_body = 1)" {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.font-size: 13
  style.bold: true
  wire_get: |md
    
    HTTP/1.1 200 OK\r\n
    Content-Type: text/html; charset=utf-8\r\n
    Content-Length: 4096\r\n
    Last-Modified: Mon, 01 Jan 2024 12:00:00 GMT\r\n
    Connection: close\r\n
    \r\n
    <html>…4096 bytes of body…</html>
    
  |
}
head_col: "HEAD Response\n(send_body = 0)" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-size: 13
  style.bold: true
  wire_head: |md
    
    HTTP/1.1 200 OK\r\n
    Content-Type: text/html; charset=utf-8\r\n
    Content-Length: 4096\r\n
    Last-Modified: Mon, 01 Jan 2024 12:00:00 GMT\r\n
    Connection: close\r\n
    \r\n
    ← no body bytes follow
    
  |
}
why_same: |md
  **Why Content-Length must be identical for GET and HEAD:**
  RFC 7231 §4.3.2 — HEAD response headers MUST be identical to
  what GET would return. Caching proxies and CDNs use HEAD to
  validate cache freshness; a different Content-Length would
  corrupt cache state. Both methods derive Content-Length from
  **st.st_size** (fstat result) — never from counting bytes sent.
| {
  near: bottom-center
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.font-size: 12
  style.bold: false
}
client -> parser: "1. Raw bytes off wire\nread_request_with_timeout()\n→ char buf[8192]" {
  style.stroke: "#4A90D9"
  style.font-size: 11
}
parser -> classify: "2. http_request_t req\nreq.method = \"GET\" or \"HEAD\"\nreq.path = \"/index.html\"" {
  style.stroke: "#7B2D8B"
  style.font-size: 11
}
classify -> stat_call: "3a. HTTP_METHOD_GET\nsend_body = 1" {
  style.stroke: "#2E8B57"
  style.stroke-width: 2
  style.font-size: 11
  target-arrowhead: {
    shape: arrow
  }
}
classify -> stat_call: "3b. HTTP_METHOD_HEAD\nsend_body = 0" {
  style.stroke: "#DC143C"
  style.stroke-width: 2
  style.font-size: 11
  target-arrowhead: {
    shape: arrow
  }
}
stat_call -> header_build: "4. st.st_size = 4096 bytes\nst.st_mtime = Unix timestamp\nget_mime_type(canonical) = \"text/html; charset=utf-8\"\n[identical for GET and HEAD]" {
  style.stroke: "#2C6B9E"
  style.font-size: 11
  style.bold: true
}
header_build -> send_headers: "5. header_buf:\n\"HTTP/1.1 200 OK\\r\\n\"\n\"Content-Length: 4096\\r\\n\"\n\"Last-Modified: Mon, 01 Jan 2024 …\\r\\n\"\n\"\\r\\n\"\n[bit-for-bit identical for GET and HEAD]" {
  style.stroke: "#2E8B57"
  style.font-size: 11
  style.bold: true
}
send_headers -> client: "6. Headers transmitted to client\n[BOTH methods reach here identically]" {
  style.stroke: "#2E8B57"
  style.stroke-width: 2
  style.font-size: 11
}
send_headers -> branch: "7. Check send_body flag" {
  style.stroke: "#D2691E"
  style.font-size: 11
}
branch -> open_file: "send_body == 1\n(GET path)" {
  style.stroke: "#2E8B57"
  style.stroke-width: 2
  style.font-size: 11
}
branch -> skip_body: "send_body == 0\n(HEAD path)" {
  style.stroke: "#DC143C"
  style.stroke-dash: 4
  style.stroke-width: 2
  style.font-size: 11
}
open_file -> read_loop: "8. file_fd opened\nread 64 KB chunks\n→ send_all() each chunk" {
  style.stroke: "#2E8B57"
  style.font-size: 11
}
read_loop -> close_fd: "9. bytes_read == 0 (EOF)\nAll 4096 bytes sent" {
  style.stroke: "#2E8B57"
  style.font-size: 11
}
read_loop -> get_col: "Client receives:\nheaders + 4096 body bytes\nTotal wire bytes ≈ 4267" {
  style.stroke: "#2E8B57"
  style.stroke-width: 2
  style.font-size: 11
}
skip_body -> head_col: "Client receives:\nheaders only, 0 body bytes\nTotal wire bytes ≈ 171\nContent-Length still = 4096" {
  style.stroke: "#DC143C"
  style.stroke-width: 2
  style.stroke-dash: 3
  style.font-size: 11
}
skip_body -> close_fd: "No file_fd opened\n(skip_body path rejoins)" {
  style.stroke: "#DC143C"
  style.stroke-dash: 4
  style.font-size: 11
}
close_fd -> client: "10. Connection handling complete\nWorker thread loops back\nfor next keep-alive request" {
  style.stroke: "#696969"
  style.stroke-dash: 3
  style.font-size: 11
}