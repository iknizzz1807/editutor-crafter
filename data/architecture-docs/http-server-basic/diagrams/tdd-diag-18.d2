vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: ||md
    # URL Path → Filesystem Path Security Pipeline
    **Five-Stage Defense-in-Depth for Static File Serving**
  ||
  near: top-center
}

# -----------------------------------------------------------------------------
# INPUT DEFINITION
# -----------------------------------------------------------------------------
input: {
  label: "Client Request\nGET /%2e%2e%2fpasswd HTTP/1.1"
  style: {
    fill: "#2d2d2d"
    font-color: "#f0f0f0"
    stroke: "#888888"
    border-radius: 4
    bold: true
    font: mono
  }
}

# -----------------------------------------------------------------------------
# STAGE 1: URL DECODE
# -----------------------------------------------------------------------------
s1: "Stage 1: URL Decode" {
  style: {
    fill: "#3b1f5e"
    font-color: "#e8d5ff"
    stroke: "#9b59b6"
    stroke-width: 2
    border-radius: 6
  }
  
  s1_op: {
    label: ||md
      **Operation**
      - Scan `%XX` sequences.
      - Decode to raw bytes.
      - `%2e` → `.`
      - `%2f` → `/`
    ||
    style: {
      fill: "#2a1545"
      font-color: "#d8bfff"
      stroke: "#6c3483"
    }
  }

  s1_out: "Output:\n/../passwd" {
    style: {
      fill: "#1a0a2e"
      font-color: "#c39bd3"
      stroke: "#7d3c98"
      font: mono
      border-radius: 4
    }
  }

  s1_blocks: {
    label: ||md
      **Attack Vector: Percent-Encoded Traversal**
      Prevents bypasses where `realpath` or prefix 
      checks fail to identify `../` because it 
      remains encoded as `%2e%2e`.
    ||
    style: {
      fill: "#1a0a2e"
      font-color: "#f1948a"
      stroke: "#c0392b"
      border-radius: 4
    }
  }

  s1_op -> s1_out
}

# -----------------------------------------------------------------------------
# STAGE 2: CONCATENATE
# -----------------------------------------------------------------------------
s2: "Stage 2: Concatenate" {
  style: {
    fill: "#1a3a5c"
    font-color: "#d6eaf8"
    stroke: "#2980b9"
    stroke-width: 2
    border-radius: 6
  }

  s2_op: {
    label: ||md
      **Operation**
      Combine Root + Path.
      `doc_root` = `/var/www`
      Result = `/var/www` + `/../passwd`
    ||
    style: {
      fill: "#0e2233"
      font-color: "#aed6f1"
      stroke: "#1f618d"
    }
  }

  s2_out: "Output:\n/var/www/../passwd" {
    style: {
      fill: "#0a1a28"
      font-color: "#7fb3d3"
      stroke: "#2471a3"
      font: mono
      border-radius: 4
    }
  }

  s2_op -> s2_out
}

# -----------------------------------------------------------------------------
# STAGE 3: REALPATH
# -----------------------------------------------------------------------------
s3: "Stage 3: realpath()" {
  style: {
    fill: "#1a4a2a"
    font-color: "#d5f5e3"
    stroke: "#27ae60"
    stroke-width: 2
    border-radius: 6
  }

  s3_op: {
    label: ||md
      **Operation (Canonicalization)**
      - Resolve `..` and `.` components.
      - Resolve symlinks.
      - Remove double slashes.
    ||
    style: {
      fill: "#0e2918"
      font-color: "#a9dfbf"
      stroke: "#1e8449"
    }
  }

  s3_out: "Output:\n/passwd" {
    style: {
      fill: "#081a0e"
      font-color: "#7dcea0"
      stroke: "#239b56"
      font: mono
      border-radius: 4
    }
  }

  s3_op -> s3_out
}

# -----------------------------------------------------------------------------
# STAGE 4: CONTAINMENT CHECK
# -----------------------------------------------------------------------------
s4: "Stage 4: Containment Check" {
  style: {
    fill: "#4a2a0a"
    font-color: "#fdebd0"
    stroke: "#e67e22"
    stroke-width: 2
    border-radius: 6
  }

  s4_op: {
    label: ||md
      **Operation (The Jail Guard)**
      `strncmp(canonical, root, len) == 0`
      Ensure path is still inside `/var/www`.
    ||
    style: {
      fill: "#2a1605"
      font-color: "#f0b27a"
      stroke: "#ca6f1e"
    }
  }

  s4_check: {
    label: "'/passwd' vs '/var/www'\nMISMATCH → REJECT"
    style: {
      fill: "#5b1717"
      font-color: "#f1948a"
      stroke: "#e74c3c"
      font: mono
      border-radius: 4
      bold: true
    }
  }

  s4_403: "HTTP 403 Forbidden" {
    style: {
      fill: "#5b1717"
      font-color: "#f5b7b1"
      stroke: "#c0392b"
      border-radius: 4
      bold: true
    }
  }

  s4_op -> s4_check -> s4_403
}

# -----------------------------------------------------------------------------
# STAGE 5: SERVE
# -----------------------------------------------------------------------------
s5: "Stage 5: open() + Serve" {
  style: {
    fill: "#1a1a4a"
    font-color: "#d6d6ff"
    stroke: "#8e44ad"
    stroke-width: 2
    border-radius: 6
  }

  s5_op: {
    label: "Only reached if prefix match passes.\nopen(canonical, O_RDONLY)"
    style: {
      fill: "#0d0d2a"
      font-color: "#b0b0f0"
      stroke: "#6c3483"
    }
  }

  s5_200: "HTTP 200 OK\n[File Data Stream]" {
    style: {
      fill: "#0a1a0a"
      font-color: "#82e0aa"
      stroke: "#27ae60"
      font: mono
      border-radius: 4
    }
  }

  s5_op -> s5_200
}

# -----------------------------------------------------------------------------
# PIPELINE FLOW
# -----------------------------------------------------------------------------
input -> s1: "Raw URI" { style.font: mono }
s1 -> s2: "Decoded URI" { style.font: mono }
s2 -> s3: "Unsafe Combined Path" { style.font: mono }
s3 -> s4: "Canonical Path" { style.font: mono }
s4 -> s5: "Validated Path" {
  style: {
    stroke-dash: 5
    stroke: "#e67e22"
  }
}

# -----------------------------------------------------------------------------
# BYPASS WARNINGS
# -----------------------------------------------------------------------------
skip1: "SKIP S1: Traversal survives\nprefix check encoded" {
  style: {
    fill: "#5b1717"
    stroke: "#e74c3c"
    stroke-dash: 4
    font-color: "#f5b7b1"
  }
}

skip2: "SKIP S3: Path escapes\nvia unresolved '../'" {
  style: {
    fill: "#5b1717"
    stroke: "#e74c3c"
    stroke-dash: 4
    font-color: "#f5b7b1"
  }
}

input -> skip1: {
  style: {
    stroke: "#e74c3c"
    stroke-dash: 3
    animated: true
  }
}

s2 -> skip2: {
  style: {
    stroke: "#e74c3c"
    stroke-dash: 3
    animated: true
  }
}

legend: "Legend" {
  near: bottom-left
  l1: "Authorized Path" {
    style: {
      stroke: "#2980b9"
    }
  }
  l2: "Attack Path / Skipping" {
    style: {
      stroke: "#e74c3c"
      stroke-dash: 4
    }
  }
}