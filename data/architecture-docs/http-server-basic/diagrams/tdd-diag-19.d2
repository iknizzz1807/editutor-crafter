vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## Directory Traversal: Three Bypass Vectors — Attack Paths & Neutralization
  *Critical invariant: `realpath()` MUST execute before the prefix check*
| {
  near: top-center
  style.font-size: 14
}
# ─── COLUMN HEADERS ──────────────────────────────────────────────────────────
hA: "VECTOR A: URL-Encoded Traversal" {
  style.fill: "#4a1942"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
hB: "VECTOR B: Symlink Escape" {
  style.fill: "#1a3a5c"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
hC: "VECTOR C: Double-Slash / Path Collapse" {
  style.fill: "#1a4a2a"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
# ─── COLUMN A: URL-ENCODED TRAVERSAL ─────────────────────────────────────────
A1: "Client sends:\nGET /%2e%2e%2f%2e%2e%2fetc%2fpasswd" {
  style.fill: "#f8d7da"
  style.stroke: "#c0392b"
  style.border-radius: 6
  style.font-size: 13
}
A2: "STAGE 1: url_decode()\nDecodes %2e→. %2f→/ before\nany path operation" {
  style.fill: "#fff3cd"
  style.stroke: "#e67e22"
  style.border-radius: 6
  style.font-size: 13
}
A2note: |md
  `/%2e%2e%2f%2e%2e%2fetc%2fpasswd`
  → `/../../../etc/passwd`
| {
  style.fill: "#ffeeba"
  style.stroke: "#f39c12"
  style.font-size: 12
}
A3: "STAGE 2: build_full_path()\nConcat with doc_root:\n/var/www/html + /../../../etc/passwd\n= /var/www/html/../../../etc/passwd" {
  style.fill: "#fff3cd"
  style.stroke: "#e67e22"
  style.border-radius: 6
  style.font-size: 13
}
Awarning: "⚠ NAIVE PREFIX CHECK HERE\nwould see /var/www/html/... → PASS\nbut resolves to /etc/passwd → BYPASS!" {
  style.fill: "#f8d7da"
  style.stroke: "#c0392b"
  style.stroke-dash: 5
  style.border-radius: 6
  style.font-size: 12
  style.italic: true
}
A4: "STAGE 3: realpath()\nResolves all .. components\nby walking the kernel's\ndirectory tree" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 6
  style.font-size: 13
}
A4note: |md
  `/var/www/html/../../../etc/passwd`
  → **canonical = `/etc/passwd`**
| {
  style.fill: "#c3e6cb"
  style.stroke: "#27ae60"
  style.font-size: 12
}
A5: "STAGE 4: Prefix Check\nstrncmp('/etc/passwd',\n'/var/www/html', 13)\n= MISMATCH" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 6
  style.font-size: 13
}
A6: "→ 403 Forbidden\nVECTOR A NEUTRALIZED" {
  style.fill: "#b71c1c"
  style.font-color: white
  style.border-radius: 6
  style.bold: true
}
# ─── COLUMN B: SYMLINK ESCAPE ────────────────────────────────────────────────
B1: "Client sends:\nGET /secrets/passwd" {
  style.fill: "#f8d7da"
  style.stroke: "#c0392b"
  style.border-radius: 6
  style.font-size: 13
}
B1note: |md
  Filesystem setup (attacker or accident):
  `/var/www/html/secrets` → symlink → `/etc`
| {
  style.fill: "#fde2e4"
  style.stroke: "#c0392b"
  style.font-size: 12
}
B2: "STAGE 1: url_decode()\n(no percent-encoding;\npath passes through unchanged)" {
  style.fill: "#fff3cd"
  style.stroke: "#e67e22"
  style.border-radius: 6
  style.font-size: 13
}
B3: "STAGE 2: build_full_path()\n/var/www/html + /secrets/passwd\n= /var/www/html/secrets/passwd" {
  style.fill: "#fff3cd"
  style.stroke: "#e67e22"
  style.border-radius: 6
  style.font-size: 13
}
Bwarning: "⚠ NAIVE PREFIX CHECK HERE\n/var/www/html/secrets/passwd\nstarts with /var/www/html → PASS\nbut symlink routes to /etc → BYPASS!" {
  style.fill: "#f8d7da"
  style.stroke: "#c0392b"
  style.stroke-dash: 5
  style.border-radius: 6
  style.font-size: 12
  style.italic: true
}
B4: "STAGE 3: realpath()\nFollows every symlink encountered\nduring path component traversal" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 6
  style.font-size: 13
}
B4note: |md
  `/var/www/html/secrets` is a symlink → `/etc`
  **canonical = `/etc/passwd`**
| {
  style.fill: "#c3e6cb"
  style.stroke: "#27ae60"
  style.font-size: 12
}
B5: "STAGE 4: Prefix Check\ncanonical[13] == '/' ?\n'/etc/passwd'[13] ≠ '/var/www/html'\n= MISMATCH" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 6
  style.font-size: 13
}
B6: "→ 403 Forbidden\nVECTOR B NEUTRALIZED" {
  style.fill: "#b71c1c"
  style.font-color: white
  style.border-radius: 6
  style.bold: true
}
# ─── COLUMN C: DOUBLE-SLASH / PATH COLLAPSE ───────────────────────────────────
C1: "Client sends:\nGET //../../etc/passwd\nor ///etc or /html//../../etc" {
  style.fill: "#f8d7da"
  style.stroke: "#c0392b"
  style.border-radius: 6
  style.font-size: 13
}
C2: "STAGE 1: url_decode()\n(no percent-encoding;\nraw slashes and dots pass through)" {
  style.fill: "#fff3cd"
  style.stroke: "#e67e22"
  style.border-radius: 6
  style.font-size: 13
}
C3: "STAGE 2: build_full_path()\n/var/www/html + //../../etc/passwd\n= /var/www/html//../../etc/passwd" {
  style.fill: "#fff3cd"
  style.stroke: "#e67e22"
  style.border-radius: 6
  style.font-size: 13
}
Cwarning: "⚠ NAIVE PREFIX CHECK HERE\n/var/www/html//../../etc/passwd\nstarts with /var/www/html → PASS\nbut // and .. collapse to /etc → BYPASS!" {
  style.fill: "#f8d7da"
  style.stroke: "#c0392b"
  style.stroke-dash: 5
  style.border-radius: 6
  style.font-size: 12
  style.italic: true
}
C4: "STAGE 3: realpath()\nNormalizes // to /\nResolves all .. components\nProduces single canonical form" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 6
  style.font-size: 13
}
C4note: |md
  `/var/www/html//../../etc/passwd`
  **canonical = `/etc/passwd`**
| {
  style.fill: "#c3e6cb"
  style.stroke: "#27ae60"
  style.font-size: 12
}
C5: "STAGE 4: Prefix Check\nstrncmp('/etc/passwd',\n'/var/www/html', 13)\n= MISMATCH" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 6
  style.font-size: 13
}
C6: "→ 403 Forbidden\nVECTOR C NEUTRALIZED" {
  style.fill: "#b71c1c"
  style.font-color: white
  style.border-radius: 6
  style.bold: true
}
# ─── ORDERING CONSTRAINT BOX ──────────────────────────────────────────────────
invariant: "CRITICAL ORDERING CONSTRAINT\nrealpath() MUST precede prefix check\n\nstring(path).startsWith(root) ≠ filesystem containment\nOnly realpath() resolves the kernel's actual path" {
  style.fill: "#1a237e"
  style.font-color: white
  style.bold: true
  style.border-radius: 8
  style.stroke-width: 3
  style.stroke: "#ff6f00"
  near: bottom-center
}
# ─── COLUMN A CONNECTIONS ─────────────────────────────────────────────────────
hA -> A1
A1 -> A2
A2 -> A2note: "decoded path"
A2 -> A3
A3 -> Awarning: "if checked here" {
  style.stroke-dash: 4
  style.stroke: "#c0392b"
}
A3 -> A4: "Stage 3 MUST come first" {
  style.stroke: "#27ae60"
  style.bold: true
}
A4 -> A4note: "kernel resolves .."
A4 -> A5
A5 -> A6
# ─── COLUMN B CONNECTIONS ─────────────────────────────────────────────────────
hB -> B1
B1 -> B1note: "precondition"
B1 -> B2
B2 -> B3
B3 -> Bwarning: "if checked here" {
  style.stroke-dash: 4
  style.stroke: "#c0392b"
}
B3 -> B4: "Stage 3 MUST come first" {
  style.stroke: "#27ae60"
  style.bold: true
}
B4 -> B4note: "kernel follows symlink"
B4 -> B5
B5 -> B6
# ─── COLUMN C CONNECTIONS ─────────────────────────────────────────────────────
hC -> C1
C1 -> C2
C2 -> C3
C3 -> Cwarning: "if checked here" {
  style.stroke-dash: 4
  style.stroke: "#c0392b"
}
C3 -> C4: "Stage 3 MUST come first" {
  style.stroke: "#27ae60"
  style.bold: true
}
C4 -> C4note: "kernel normalizes path"
C4 -> C5
C5 -> C6
# ─── CROSS-COLUMN STAGE ALIGNMENT LABELS ─────────────────────────────────────
stg1: "① url_decode()" {
  style.fill: "#e8f4f8"
  style.stroke: "#2980b9"
  style.border-radius: 20
  style.font-size: 11
}
stg2: "② build_full_path()" {
  style.fill: "#e8f4f8"
  style.stroke: "#2980b9"
  style.border-radius: 20
  style.font-size: 11
}
stg3: "③ realpath() ← THE SECURITY KEYSTONE" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 20
  style.bold: true
  style.font-size: 11
}
stg4: "④ prefix check (safe only after ③)" {
  style.fill: "#d4edda"
  style.stroke: "#27ae60"
  style.border-radius: 20
  style.font-size: 11
}
stg1 -> stg2 -> stg3 -> stg4
A4 -> stg3 {
  style.stroke-dash: 3
  style.opacity: 0.4
}
B4 -> stg3 {
  style.stroke-dash: 3
  style.opacity: 0.4
}
C4 -> stg3 {
  style.stroke-dash: 3
  style.opacity: 0.4
}
stg4 -> invariant {
  style.stroke: "#ff6f00"
  style.stroke-width: 2
}