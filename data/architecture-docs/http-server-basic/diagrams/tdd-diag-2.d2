vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ## Kernel File Descriptor Table: server_fd vs. client_fd
  Process FD Table · Memory Layout Diagram (Intel Manual Grade)
| {near: top-center}

# ── User Space ──────────────────────────────────────────────────────────────
user_space: "USER SPACE (Process VM)" {
  style: {
    fill: "#f5f5f5"
    stroke: "#2d7a2d"
    stroke-width: 4
    bold: true
  }

  fd_table: "Process FD Table (Array of struct file *)" {
    style.fill: "#eeeeee"
    
    header: "Offset | Field | Size" {
      style: { fill: "#673ab7"; font-color: white; bold: true }
    }

    fd0: "0x00 | fd[0] (stdin)  | 8B" {
      style: { fill: "#9e9e9e"; font-color: white; font: mono }
    }
    fd1: "0x08 | fd[1] (stdout) | 8B" {
      style: { fill: "#9e9e9e"; font-color: white; font: mono }
    }
    fd2: "0x10 | fd[2] (stderr) | 8B" {
      style: { fill: "#9e9e9e"; font-color: white; font: mono }
    }
    
    server_fd_entry: "0x18 | server_fd (3) | 8B" {
      style: {
        fill: "#ff9800"
        stroke: "#e65100"
        stroke-width: 2
        font-color: black
        font: mono
        bold: true
      }
    }
    
    client_fd_entry: "0x20 | client_fd (4) | 8B" {
      style: {
        fill: "#ff9800"
        stroke: "#e65100"
        stroke-width: 2
        font-color: black
        font: mono
        bold: true
      }
    }

    padding: "0x28 | unused / free | ..." {
      style: { fill: "#4caf50"; font-color: white; stroke-dash: 5 }
    }
  }
}

# ── Kernel Space ─────────────────────────────────────────────────────────────
kernel_space: "KERNEL SPACE" {
  style: {
    fill: "#fff3e0"
    stroke: "#e65100"
    stroke-width: 4
    bold: true
  }

  server_sock: "struct file (server_fd)" {
    style: { fill: "#2196f3"; font-color: white; stroke: "#0d47a1" }
    passive_socket: "struct socket [TCP_LISTEN]" {
      style: { fill: "#bbdefb"; font-color: black }
    }
    accept_queue: "Accept Queue (Ring Buffer)" {
      style: { fill: "#e3f2fd"; stroke-dash: 3 }
    }
  }

  client_sock: "struct file (client_fd)" {
    style: { fill: "#2196f3"; font-color: white; stroke: "#0d47a1" }
    connected_socket: "struct socket [TCP_ESTABLISHED]" {
      style: { fill: "#bbdefb"; font-color: black }
    }
    buffers: "Socket Buffers" {
      recv_buf: "sk_rcvbuf (Data)" { style.fill: "#2196f3"; style.font-color: white }
      send_buf: "sk_sndbuf (Data)" { style.fill: "#2196f3"; style.font-color: white }
    }
  }
}

# ── Hardware ────────────────────────────────────────────────────────────────
hardware: "NIC Hardware" {
  style.fill: "#424242"
  style.font-color: white
  nic: "Ethernet Controller"
}

# ── Global Annotations (Root Level) ──────────────────────────────────────────
size_note: "sizeof(int fd) = 4B | sizeof(struct file *) = 8B | Total Table Size = N * 8B" {
  near: bottom-center
  style: {
    fill: "#f1f8e9"
    stroke: "#aed581"
    font-size: 12
    italic: true
  }
}

# ── Connections ──────────────────────────────────────────────────────────────
user_space.fd_table.server_fd_entry -> kernel_space.server_sock: "dereference" {
  style: { stroke: "#ff9800"; stroke-width: 3; animated: true }
}

user_space.fd_table.client_fd_entry -> kernel_space.client_sock: "dereference" {
  style: { stroke: "#ff9800"; stroke-width: 3; animated: true }
}

kernel_space.server_sock.accept_queue -> kernel_space.client_sock: "accept() creates" {
  style: { stroke: "#e65100"; stroke-dash: 3 }
}

hardware.nic -> kernel_space.client_sock.buffers.recv_buf: "DMA Write" {
  style: { stroke: "#4caf50"; stroke-width: 2; stroke-dash: 5 }
}