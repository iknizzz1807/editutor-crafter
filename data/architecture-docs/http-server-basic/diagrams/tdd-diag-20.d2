vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |'md
  ## `url_decode()` State Machine
  Percent-decode with null-byte rejection · Buffer: `src[i]` → `dst[j]`
'| {near: top-center}

# ── States ────────────────────────────────────────────────────────────────────

initial: ● {
  shape: circle
  style: {
    fill: "#1a1a2e"
    stroke: "#1a1a2e"
    font-color: white
  }
  width: 36
  height: 36
}

NORMAL: "NORMAL\n─────────────────\ndst[j++] = src[i++]\ninvariant: j < dst_size−1" {
  shape: rectangle
  style: {
    fill: "#3d1a78"
    font-color: white
    stroke: "#9b59b6"
    stroke-width: 3
    border-radius: 8
    bold: true
  }
}

PERCENT_1: "PERCENT_1\n─────────────────\nhex[0] = src[i+1]\ni advanced past '%'\nwaiting for 2nd hex digit" {
  shape: rectangle
  style: {
    fill: "#1a3a6e"
    font-color: white
    stroke: "#3498db"
    stroke-width: 3
    border-radius: 8
    bold: true
  }
}

PERCENT_2: "PERCENT_2\n─────────────────\nhex[1] = src[i+2]\nbyte = strtol(hex, NULL, 16)\ni += 3" {
  shape: rectangle
  style: {
    fill: "#1a5c3a"
    font-color: white
    stroke: "#2ecc71"
    stroke-width: 3
    border-radius: 8
    bold: true
  }
}

EMIT_PLUS: "EMIT_PLUS\n─────────────────\ndst[j++] = '+'\ni++\n(literal: path ≠ query)" {
  shape: rectangle
  style: {
    fill: "#4a3000"
    font-color: white
    stroke: "#f39c12"
    stroke-width: 2
    border-radius: 8
  }
}

REJECT: "REJECT\n─────────────────\nnull byte decoded\n%00 in path\nreturn −2" {
  shape: rectangle
  style: {
    fill: "#5c1a1a"
    font-color: white
    stroke: "#e74c3c"
    stroke-width: 3
    border-radius: 8
    bold: true
  }
}

ERROR: "ERROR\n─────────────────\nmalformed %XX\nnon-hex digit seen\nreturn −1" {
  shape: rectangle
  style: {
    fill: "#5c1a1a"
    font-color: white
    stroke: "#e74c3c"
    stroke-width: 3
    border-radius: 8
    bold: true
  }
}

BUF_FULL: "BUF_FULL\n─────────────────\nj ≥ dst_size − 1\nbuffer exhausted\nreturn −3" {
  shape: rectangle
  style: {
    fill: "#3d3d00"
    font-color: white
    stroke: "#f1c40f"
    stroke-width: 2
    border-radius: 8
  }
}

SUCCESS: "SUCCESS\n─────────────────\nsrc[i] == '\\0'\ndst[j] = '\\0'\nreturn 0" {
  shape: rectangle
  style: {
    fill: "#1a5c1a"
    font-color: white
    stroke: "#27ae60"
    stroke-width: 3
    border-radius: 8
    bold: true
  }
}

err_initial: ● {
  shape: circle
  style: {
    fill: "#e74c3c"
    stroke: "#e74c3c"
  }
  width: 24
  height: 24
}

err_initial2: ● {
  shape: circle
  style: {
    fill: "#e74c3c"
    stroke: "#e74c3c"
  }
  width: 24
  height: 24
}

err_initial3: ● {
  shape: circle
  style: {
    fill: "#f1c40f"
    stroke: "#f1c40f"
  }
  width: 24
  height: 24
}

# ── Transitions ───────────────────────────────────────────────────────────────

initial -> NORMAL: "start\ni=0, j=0" {
  style: {
    stroke: "#9b59b6"
    stroke-width: 2
    font-color: "#d4c0f0"
    bold: true
  }
}

NORMAL -> SUCCESS: "guard: src[i]=='\\0'\naction: dst[j]='\\0'" {
  style: {
    stroke: "#27ae60"
    stroke-width: 2
    font-color: "#a0e8b0"
    bold: true
  }
}

NORMAL -> BUF_FULL: "guard: j ≥ dst_size−1\naction: return −3" {
  style: {
    stroke: "#f1c40f"
    stroke-width: 2
    font-color: "#f9e47a"
    stroke-dash: 4
  }
}

NORMAL -> PERCENT_1: "trigger: src[i]=='%'\nguard: j < dst_size−1\naction: i++ (advance past '%')" {
  style: {
    stroke: "#3498db"
    stroke-width: 2
    font-color: "#aacfee"
    bold: true
  }
}

NORMAL -> EMIT_PLUS: "trigger: src[i]=='+'\nguard: path context\naction: dst[j++]='+', i++" {
  style: {
    stroke: "#f39c12"
    stroke-width: 2
    font-color: "#f9c87a"
  }
}

NORMAL -> NORMAL: "trigger: printable byte\n(not '%', '+', '\\0')\naction: dst[j++]=src[i++]" {
  style: {
    stroke: "#9b59b6"
    stroke-width: 2
    font-color: "#d4c0f0"
  }
}

EMIT_PLUS -> NORMAL: "return to scan loop" {
  style: {
    stroke: "#f39c12"
    stroke-width: 1
    font-color: "#f9c87a"
    stroke-dash: 3
  }
}

PERCENT_1 -> PERCENT_2: "trigger: isxdigit(src[i+1])\naction: hex[0]=src[i+1], i++" {
  style: {
    stroke: "#2ecc71"
    stroke-width: 2
    font-color: "#a0e8b0"
    bold: true
  }
}

PERCENT_1 -> ERROR: "trigger: !isxdigit(src[i+1])\nguard: src[i+1]∉[0-9,A-F,a-f]\nILLEGAL: malformed escape" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    font-color: "#f5a0a0"
    stroke-dash: 5
    bold: true
  }
}

PERCENT_1 -> ERROR: "trigger: src[i+1]=='\\0'\nguard: truncated sequence '%' at EOS\nILLEGAL: return −1" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 2
    font-color: "#f5a0a0"
    stroke-dash: 5
  }
}

PERCENT_2 -> REJECT: "trigger: decoded_byte==0x00\nguard: %00 decoded to null\nILLEGAL: security rejection" {
  style: {
    stroke: "#e74c3c"
    stroke-width: 3
    font-color: "#f5a0a0"
    stroke-dash: 5
    bold: true
  }
}

PERCENT_2 -> NORMAL: "trigger: decoded_byte≠0\naction: dst[j++]=byte\n        src advanced by 3 total" {
  style: {
    stroke: "#2ecc71"
    stroke-width: 2
    font-color: "#a0e8b0"
    bold: true
  }
}

err_initial -> REJECT
err_initial2 -> ERROR
err_initial3 -> BUF_FULL

# ── Buffer Arithmetic Annotation ──────────────────────────────────────────────

buf_note: |'md
  **Buffer pointer arithmetic**
  | State | `src[i]` advance | `dst[j]` write |
  |-------|-----------------|----------------|
  | NORMAL (plain byte) | `i += 1` | `dst[j++] = src[i]` |
  | NORMAL ('+') | `i += 1` | `dst[j++] = '+'` |
  | PERCENT sequence | `i += 3` | `dst[j++] = decoded` |
  | End of string | — | `dst[j] = '\0'` |

  **Guard on every write:** `j < dst_size − 1`
  (leaves room for null terminator)
'| {
  near: bottom-center
  style: {
    fill: "#1a1a2e"
    font-color: "#d4c0f0"
    stroke: "#9b59b6"
    border-radius: 8
  }
}