vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## realpath() Internals: Kernel dentry/inode Walk
  ### Input: `/var/www/html/../assets/logo.png`
| {near: top-center}
shape: sequence_diagram
libc_realpath: "libc\nrealpath()"
kernel_vfs: "Kernel VFS\nnamei()"
dcache: "dentry\ncache"
disk_io: "Disk I/O\n(on MISS)"
caller: "Caller"
caller -> libc_realpath: "realpath(\"/var/www/html/../assets/logo.png\", canonical)"
component_walk: {
  label: "Component-by-Component Walk"
  libc_realpath -> kernel_vfs: "lstat(\"/var\")"
  kernel_vfs -> dcache: "lookup(root, \"var\")"
  dcache -> kernel_vfs: "HIT → inode #2  (~500 ns)" {
    style.stroke: green
    style.font-color: green
  }
  kernel_vfs -> libc_realpath: "S_ISDIR ✓  path so far: /var"
  libc_realpath -> kernel_vfs: "lstat(\"/var/www\")"
  kernel_vfs -> dcache: "lookup(inode#2, \"www\")"
  dcache -> kernel_vfs: "HIT → inode #31  (~500 ns)" {
    style.stroke: green
    style.font-color: green
  }
  kernel_vfs -> libc_realpath: "S_ISDIR ✓  path so far: /var/www"
  libc_realpath -> kernel_vfs: "lstat(\"/var/www/html\")"
  kernel_vfs -> dcache: "lookup(inode#31, \"html\")"
  dcache -> kernel_vfs: "MISS — not cached" {
    style.stroke: red
    style.font-color: red
  }
  kernel_vfs -> disk_io: "read inode table block" {
    style.stroke-dash: 4
    style.stroke: red
  }
  disk_io -> kernel_vfs: "inode #88 loaded  (~100 µs)" {
    style.stroke-dash: 4
    style.stroke: red
  }
  kernel_vfs -> libc_realpath: "S_ISLNK? → YES → readlink()" {
    style.stroke: orange
    style.font-color: orange
  }
  libc_realpath -> kernel_vfs: "readlink(\"/var/www/html\")"
  kernel_vfs -> libc_realpath: "symlink target: \"/var/www/html-v2\"" {
    style.stroke: orange
    style.font-color: orange
  }
  libc_realpath -> libc_realpath: "Replace component:\npath = /var/www/html-v2"
  libc_realpath -> kernel_vfs: "lstat(\"/var/www/html-v2\")"
  kernel_vfs -> dcache: "lookup(inode#31, \"html-v2\")"
  dcache -> kernel_vfs: "HIT → inode #91  (~500 ns)" {
    style.stroke: green
    style.font-color: green
  }
  kernel_vfs -> libc_realpath: "S_ISDIR ✓  path so far: /var/www/html-v2"
  libc_realpath -> libc_realpath: "See \"..\" component:\npop stack → /var/www"
  libc_realpath -> kernel_vfs: "lstat(\"/var/www/assets\")"
  kernel_vfs -> dcache: "lookup(inode#31, \"assets\")"
  dcache -> kernel_vfs: "HIT → inode #104  (~500 ns)" {
    style.stroke: green
    style.font-color: green
  }
  kernel_vfs -> libc_realpath: "S_ISDIR ✓  path so far: /var/www/assets"
  libc_realpath -> kernel_vfs: "lstat(\"/var/www/assets/logo.png\")"
  kernel_vfs -> dcache: "lookup(inode#104, \"logo.png\")"
  dcache -> kernel_vfs: "HIT → inode #217  (~500 ns)" {
    style.stroke: green
    style.font-color: green
  }
  kernel_vfs -> libc_realpath: "S_ISREG ✓  S_ISLNK? NO → leaf reached"
}
libc_realpath -> caller: "return \"/var/www/assets/logo.png\"  (canonical)" {
  style.stroke: green
  style.font-color: green
  style.bold: true
}
enoent_path: {
  label: "ENOENT Return Path (any missing component)"
  libc_realpath -> kernel_vfs: "lstat(\"/var/www/missing\")"
  kernel_vfs -> dcache: "lookup(inode#31, \"missing\")"
  dcache -> kernel_vfs: "MISS" {
    style.stroke: red
    style.font-color: red
  }
  kernel_vfs -> disk_io: "read directory block" {
    style.stroke-dash: 4
    style.stroke: red
  }
  disk_io -> kernel_vfs: "entry not found" {
    style.stroke-dash: 4
    style.stroke: red
  }
  kernel_vfs -> libc_realpath: "errno = ENOENT" {
    style.stroke: red
    style.font-color: red
  }
  libc_realpath -> caller: "return NULL  (errno = ENOENT → serve_file sends 404)" {
    style.stroke: red
    style.font-color: red
    style.bold: true
  }
}
legend: |md
  **dcache HIT** — dentry found in kernel hash table → ~500 ns (no disk)  
  **dcache MISS** — kernel reads inode block from disk → ~100 µs (SSD) / ~10 ms (HDD)  
  **S_ISLNK** — component is a symlink → readlink() called, target substituted, walk restarts from target  
  **".." component** — libc pops one level from the resolved-path stack; no extra lstat() needed  
  **Depth guard** — ELOOP returned if symlink chain exceeds MAXSYMLINKS (40 on Linux)
| {near: bottom-center}