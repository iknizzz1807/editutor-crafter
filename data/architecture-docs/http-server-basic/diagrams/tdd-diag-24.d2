vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # MIME Type Lookup: Extension Dispatch
  `get_mime_type(const char *path)` — strrchr → linear scan → MIME string
| {near: top-center}
# ── INPUT PATH ────────────────────────────────────────────────────────────────
input: {
  label: "Input: canonical path"
  shape: rectangle
  style.fill: "#7B2D8B"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
  path_val: |md
    `/var/www/html/assets/logo.png`
  | {
    style.fill: "#9B4DAB"
    style.font-color: white
  }
}
# ── strrchr STEP ──────────────────────────────────────────────────────────────
strrchr_box: {
  label: "strrchr(path, '.')"
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
  note: |md
    Scans path **right-to-left**
    for the LAST occurrence of `'.'`
    Returns pointer into `path` string
    at position of the last dot.
    Returns NULL if no dot found.
  | {style.fill: "#1976D2"; style.font-color: white}
}
input.path_val -> strrchr_box
# ── NULL CHECK / BRANCH ───────────────────────────────────────────────────────
null_check: {
  label: "dot == NULL ?"
  shape: diamond
  style.fill: "#E65100"
  style.font-color: white
  style.bold: true
}
strrchr_box -> null_check
# ── EARLY EXIT: no dot ────────────────────────────────────────────────────────
octet_stream_nodot: {
  label: "return\n\"application/octet-stream\""
  shape: rectangle
  style.fill: "#388E3C"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
null_check -> octet_stream_nodot: "YES — no dot in path" {
  style.stroke: "#FF6D00"
  style.font-color: "#FF6D00"
  style.bold: true
}
# ── EMPTY EXTENSION CHECK ─────────────────────────────────────────────────────
empty_check: {
  label: "*(dot+1) == '\\0' ?"
  shape: diamond
  style.fill: "#E65100"
  style.font-color: white
  style.bold: true
}
null_check -> empty_check: "NO — dot found" {
  style.stroke: "#42A5F5"
}
octet_stream_trailing: {
  label: "return\n\"application/octet-stream\""
  shape: rectangle
  style.fill: "#388E3C"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
empty_check -> octet_stream_trailing: "YES — trailing dot\n(e.g. 'file.')" {
  style.stroke: "#FF6D00"
  style.font-color: "#FF6D00"
  style.bold: true
}
# ── THE DOT POINTER ───────────────────────────────────────────────────────────
dot_ptr: {
  label: "dot pointer"
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.border-radius: 4
  annotation: |md
    For `/var/www/html/assets/logo.png`
    dot → `".png"` (suffix substring)
    For `.gitignore` (hidden dotfile)
    dot → `".gitignore"` (points to leading dot)
    → no table match → octet-stream
  | {style.fill: "#1976D2"; style.font-color: white}
}
empty_check -> dot_ptr: "NO — extension present" {
  style.stroke: "#42A5F5"
}
# ── LINEAR SCAN ───────────────────────────────────────────────────────────────
scan: {
  label: "Linear scan of MIME_TABLE[]"
  shape: rectangle
  style.fill: "#1565C0"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
  scan_note: |md
    `for i = 0; MIME_TABLE[i].extension != NULL; i++`
    &nbsp;&nbsp;`if strcasecmp(dot, MIME_TABLE[i].extension) == 0`
    &nbsp;&nbsp;&nbsp;&nbsp;`return MIME_TABLE[i].mime_type`
    Case-insensitive: `.PNG` `.png` `.Png` all match.
    strrchr: `.tar.gz` → dot points to `".gz"` (last dot).
  | {style.fill: "#1976D2"; style.font-color: white}
}
dot_ptr -> scan
# ── MIME TABLE ────────────────────────────────────────────────────────────────
mime_table: {
  label: "static const mime_entry_t MIME_TABLE[] — 18 entries + sentinel"
  shape: rectangle
  style.fill: "#37474F"
  style.font-color: white
  style.border-radius: 4
  row00: "[ 0]  .html  → text/html; charset=utf-8" {style.fill: "#455A64"; style.font-color: white}
  row01: "[ 1]  .htm   → text/html; charset=utf-8" {style.fill: "#455A64"; style.font-color: white}
  row02: "[ 2]  .css   → text/css; charset=utf-8"  {style.fill: "#455A64"; style.font-color: white}
  row03: "[ 3]  .js    → application/javascript"   {style.fill: "#455A64"; style.font-color: white}
  row04: "[ 4]  .mjs   → application/javascript"   {style.fill: "#455A64"; style.font-color: white}
  row05: "[ 5]  .json  → application/json"         {style.fill: "#455A64"; style.font-color: white}
  row06: "[ 6]  .txt   → text/plain; charset=utf-8"{style.fill: "#455A64"; style.font-color: white}
  row07: "[ 7]  .xml   → application/xml"          {style.fill: "#455A64"; style.font-color: white}
  row08: "[ 8]  .svg   → image/svg+xml"            {style.fill: "#455A64"; style.font-color: white}
  row09: "[ 9]  .png   → image/png  ★ MATCH"       {style.fill: "#1B5E20"; style.font-color: "#A5D6A7"; style.bold: true}
  row10: "[10]  .jpg   → image/jpeg"               {style.fill: "#455A64"; style.font-color: white}
  row11: "[11]  .jpeg  → image/jpeg"               {style.fill: "#455A64"; style.font-color: white}
  row12: "[12]  .gif   → image/gif"                {style.fill: "#455A64"; style.font-color: white}
  row13: "[13]  .ico   → image/x-icon"             {style.fill: "#455A64"; style.font-color: white}
  row14: "[14]  .pdf   → application/pdf"          {style.fill: "#455A64"; style.font-color: white}
  row15: "[15]  .woff  → font/woff"                {style.fill: "#455A64"; style.font-color: white}
  row16: "[16]  .woff2 → font/woff2"               {style.fill: "#455A64"; style.font-color: white}
  row17: "[17]  .webp  → image/webp"               {style.fill: "#455A64"; style.font-color: white}
  row18: "[18]  {NULL, NULL}  ← sentinel"          {style.fill: "#B71C1C"; style.font-color: white; style.bold: true}
}
scan -> mime_table
# ── MATCH RESULT ──────────────────────────────────────────────────────────────
match_result: {
  label: "strcasecmp(\".png\", \".png\") == 0\nat index [9]"
  shape: rectangle
  style.fill: "#2E7D32"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
mime_table.row09 -> match_result: "match at i=9" {
  style.stroke: "#69F0AE"
  style.font-color: "#69F0AE"
  style.bold: true
}
# ── FINAL RETURN ──────────────────────────────────────────────────────────────
return_png: {
  label: "return \"image/png\""
  shape: rectangle
  style.fill: "#388E3C"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
  style.shadow: true
}
match_result -> return_png
# ── FALLBACK: no match → sentinel reached ─────────────────────────────────────
octet_sentinel: {
  label: "return\n\"application/octet-stream\""
  shape: rectangle
  style.fill: "#388E3C"
  style.font-color: white
  style.bold: true
  style.border-radius: 4
}
mime_table.row18 -> octet_sentinel: "no match — sentinel NULL\n(e.g. .xyz123, .gitignore)" {
  style.stroke: "#FF6D00"
  style.font-color: "#FF6D00"
  style.bold: true
}
# ── EDGE CASE ANNOTATIONS ─────────────────────────────────────────────────────
edge_cases: {
  label: "Edge Cases"
  shape: rectangle
  style.fill: "#4A148C"
  style.font-color: white
  style.border-radius: 4
  ec1: |md
    **`/path/noext`** — strrchr returns NULL → early exit → `application/octet-stream`
  | {style.fill: "#6A1B9A"; style.font-color: white}
  ec2: |md
    **`/path/file.`** — *(dot+1)=='\0' → trailing-dot exit → `application/octet-stream`
  | {style.fill: "#6A1B9A"; style.font-color: white}
  ec3: |md
    **`/path/.gitignore`** — strrchr returns pointer to leading dot.
    `".gitignore"` matches no entry → sentinel → `application/octet-stream`
  | {style.fill: "#6A1B9A"; style.font-color: white}
  ec4: |md
    **`/path/archive.tar.gz`** — strrchr finds LAST dot → dot=`".gz"`.
    `".gz"` not in table → `application/octet-stream` (not `.tar`)
  | {style.fill: "#6A1B9A"; style.font-color: white}
  ec5: |md
    **`/path/image.PNG`** — strcasecmp is case-insensitive.
    `".PNG"` matches `".png"` at index 9 → `image/png`
  | {style.fill: "#6A1B9A"; style.font-color: white}
}
# ── PERFORMANCE NOTE ──────────────────────────────────────────────────────────
perf_note: |md
  **Performance**: 19 entries × 16 B = 304 B total table size.
  Fits in **5 cache lines** (320 B). Entire scan is L1-resident
  after first request. 19 × strcasecmp on short strings < 200 ns.
  `strrchr` on canonical path (≤ 4096 B): O(n) single pass, sequential.
| {
  near: bottom-center
  style.fill: "#263238"
  style.font-color: "#B0BEC5"
  style.border-radius: 4
}