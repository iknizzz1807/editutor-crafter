vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
title: |md
  ## Hardware Soul: Page Cache & Read Latency Tiers
  `read(file_fd, read_buf, 65536)` — Where Are Your Bytes?
| {near: top-center}
style.fill: "#0d1117"
style.stroke: "#30363d"
legend: {
  near: bottom-right
  style.fill: "#161b22"
  style.stroke: "#30363d"
  style.border-radius: 8
  label: |md
    **Copy Count**
    · read() = 1 copy: page cache → read_buf
    · send() = 1 copy: read_buf → NIC buffer
    · Total = **2 copies** (use sendfile() to reduce to 0)
  |
}
readahead_note: |md
  **Kernel Readahead**
  Sequential access detected →
  prefetch next **128 KB – 512 KB**
  before your next read() call.
  Effective latency → **~0** for
  sustained sequential reads.
| {
  near: bottom-left
  style.fill: "#0d2137"
  style.stroke: "#1f6feb"
  style.border-radius: 8
  style.font-color: "#79c0ff"
}
app: Application Layer {
  style.fill: "#1c2128"
  style.stroke: "#3d444d"
  style.border-radius: 6
  read_call: "read(file_fd, read_buf, 65536)" {
    shape: rectangle
    style.fill: "#2d1b69"
    style.stroke: "#8957e5"
    style.font-color: "#d2a8ff"
    style.bold: true
    style.border-radius: 4
  }
  read_buf: "read_buf[65536]\n(user-space stack)" {
    shape: rectangle
    style.fill: "#0d2137"
    style.stroke: "#1f6feb"
    style.font-color: "#79c0ff"
    style.border-radius: 4
  }
  read_call -> read_buf: "syscall → kernel copies\nbytes into this buffer" {
    style.stroke: "#1f6feb"
    style.stroke-dash: 3
    style.font-color: "#79c0ff"
  }
}
kernel: Kernel Space {
  style.fill: "#161b22"
  style.stroke: "#3d444d"
  style.border-radius: 6
  page_cache: "Page Cache\n(RAM-backed file data)" {
    shape: cylinder
    style.fill: "#1a3a1a"
    style.stroke: "#3fb950"
    style.font-color: "#3fb950"
    style.bold: true
  }
  vfs: "VFS / block layer\n(namei, inode cache, dentry cache)" {
    shape: rectangle
    style.fill: "#1c2128"
    style.stroke: "#3d444d"
    style.font-color: "#8b949e"
    style.border-radius: 4
  }
}
tier1: Tier 1 — L1 / L2 Cache {
  style.fill: "#0d2100"
  style.stroke: "#3fb950"
  style.border-radius: 8
  t1_label: "read_buf recently touched\nby this thread" {
    shape: rectangle
    style.fill: "#0d2100"
    style.stroke: "#3fb950"
    style.font-color: "#3fb950"
    style.border-radius: 4
  }
  t1_lat: "Latency: ~1 ns\n32 KB L1 / 256 KB L2 per core" {
    shape: text
    style.font-color: "#3fb950"
    style.italic: true
  }
}
tier2: Tier 2 — L3 Cache {
  style.fill: "#0d1a00"
  style.stroke: "#56d364"
  style.border-radius: 8
  t2_label: "Page cache lines shared\nacross cores" {
    shape: rectangle
    style.fill: "#0d1a00"
    style.stroke: "#56d364"
    style.font-color: "#56d364"
    style.border-radius: 4
  }
  t2_lat: "Latency: ~10 ns\n8–64 MB shared L3" {
    shape: text
    style.font-color: "#56d364"
    style.italic: true
  }
}
tier3: Tier 3 — Page Cache HIT (RAM) {
  style.fill: "#0d2137"
  style.stroke: "#1f6feb"
  style.border-radius: 8
  t3_label: "File data in kernel page cache\n→ memcpy to user read_buf" {
    shape: rectangle
    style.fill: "#0d2137"
    style.stroke: "#1f6feb"
    style.font-color: "#79c0ff"
    style.border-radius: 4
  }
  t3_lat: "Latency: ~100 ns\n10 GB/s copy bandwidth\n(64 KB copy ≈ 6 µs)" {
    shape: text
    style.font-color: "#79c0ff"
    style.italic: true
  }
  t3_copy: "COPY #1\npage cache → read_buf" {
    shape: rectangle
    style.fill: "#1a2f4a"
    style.stroke: "#388bfd"
    style.font-color: "#388bfd"
    style.bold: true
    style.border-radius: 4
  }
}
tier4: Tier 4 — Page Cache MISS (NVMe SSD) {
  style.fill: "#1a1200"
  style.stroke: "#e3b341"
  style.border-radius: 8
  t4_label: "Page fault → block I/O\nNVMe DMA → page cache\n→ memcpy to user" {
    shape: rectangle
    style.fill: "#1a1200"
    style.stroke: "#e3b341"
    style.font-color: "#e3b341"
    style.border-radius: 4
  }
  t4_lat: "Latency: ~100 µs\n(1000× slower than RAM hit)" {
    shape: text
    style.font-color: "#e3b341"
    style.italic: true
  }
  t4_dma: "NVMe DMA → page cache\n(no CPU involvement)" {
    shape: rectangle
    style.fill: "#2a1e00"
    style.stroke: "#bb8009"
    style.font-color: "#bb8009"
    style.border-radius: 4
  }
}
tier5: Tier 5 — Page Cache MISS (Spinning Disk) {
  style.fill: "#1a0000"
  style.stroke: "#f85149"
  style.border-radius: 8
  t5_label: "Seek + rotational delay\n+ disk DMA → page cache\n→ memcpy to user" {
    shape: rectangle
    style.fill: "#1a0000"
    style.stroke: "#f85149"
    style.font-color: "#f85149"
    style.border-radius: 4
  }
  t5_lat: "Latency: ~10 ms\n(100,000× slower than RAM hit)" {
    shape: text
    style.font-color: "#f85149"
    style.italic: true
  }
  t5_seek: "Seek (~5ms) +\nRotation (~2ms) +\nTransfer (~3ms)" {
    shape: rectangle
    style.fill: "#2a0000"
    style.stroke: "#da3633"
    style.font-color: "#da3633"
    style.border-radius: 4
  }
}
hardware: Hardware / Storage {
  style.fill: "#161b22"
  style.stroke: "#3d444d"
  style.border-radius: 6
  nvme: "NVMe SSD\n(PCIe Gen4)" {
    shape: rectangle
    style.fill: "#1a1200"
    style.stroke: "#e3b341"
    style.font-color: "#e3b341"
    style.border-radius: 4
  }
  hdd: "Spinning Disk\n(7200 RPM HDD)" {
    shape: rectangle
    style.fill: "#1a0000"
    style.stroke: "#f85149"
    style.font-color: "#f85149"
    style.border-radius: 4
  }
  nic: "NIC Send Buffer\n(socket send queue)" {
    shape: rectangle
    style.fill: "#2d1b69"
    style.stroke: "#8957e5"
    style.font-color: "#d2a8ff"
    style.border-radius: 4
  }
}
app.read_buf -> kernel.page_cache: "read() syscall\ncrossing privilege boundary\n(~100–300 ns overhead)" {
  style.stroke: "#8957e5"
  style.stroke-dash: 5
  style.font-color: "#d2a8ff"
}
kernel.page_cache -> tier1: "Hot path:\nread_buf still in CPU cache" {
  style.stroke: "#3fb950"
  style.font-color: "#3fb950"
}
kernel.page_cache -> tier2: "Warm path:\nL3 shared cache hit" {
  style.stroke: "#56d364"
  style.font-color: "#56d364"
}
kernel.page_cache -> tier3: "Normal path:\nRAM page cache hit" {
  style.stroke: "#1f6feb"
  style.font-color: "#79c0ff"
}
kernel.page_cache -> tier4: "Cold path:\npage fault → NVMe" {
  style.stroke: "#e3b341"
  style.font-color: "#e3b341"
}
kernel.page_cache -> tier5: "Cold path:\npage fault → HDD" {
  style.stroke: "#f85149"
  style.font-color: "#f85149"
}
tier4.t4_dma -> hardware.nvme: "PCIe DMA read" {
  style.stroke: "#e3b341"
  style.stroke-dash: 3
  style.font-color: "#e3b341"
}
tier5.t5_seek -> hardware.hdd: "spindle seek + read" {
  style.stroke: "#f85149"
  style.stroke-dash: 3
  style.font-color: "#f85149"
}
tier3.t3_copy -> hardware.nic: "COPY #2: send_all()\nread_buf → NIC buffer\n(user→kernel)" {
  style.stroke: "#8957e5"
  style.stroke-dash: 5
  style.font-color: "#d2a8ff"
}
kernel.vfs -> kernel.page_cache: "inode/dentry lookup\ndcache → inode table" {
  style.stroke: "#3d444d"
  style.font-color: "#6e7681"
  style.stroke-dash: 3
}