vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # `thread_pool_t` + `work_item_t` Memory Layout
  Cache-line annotated · 64 B/line · x86-64 Linux
| {near: top-center}
legend: |md
  **Colors:** Header/Meta=Purple · Data/Queue=Blue · Sync=Orange · Padding=Gray · Pointers=Orange · Hot-line=Red
| {near: bottom-center; style.font-size: 13}
# ── work_item_t sub-diagram ──────────────────────────────────────────────────
wi: "`work_item_t` (24 B — fits in ⅓ cache line)" {
  style.fill: "#e8e0f7"
  style.stroke: "#7c3aed"
  style.stroke-width: 2
  style.font-size: 14
  style.bold: true
  wi_fd: "offset +0x00 │ client_fd  │ int (4 B)" {
    style.fill: "#dbeafe"
    style.stroke: "#2563eb"
    style.font: mono
  }
  wi_pad: "offset +0x04 │ client_ip[INET_ADDRSTRLEN=16]  │ char[16] (16 B)" {
    style.fill: "#dbeafe"
    style.stroke: "#2563eb"
    style.font: mono
  }
  wi_port: "offset +0x14 │ client_port │ int (4 B)" {
    style.fill: "#dbeafe"
    style.stroke: "#2563eb"
    style.font: mono
  }
  wi_end: "end: 0x18 = 24 B total  ·  fits 2.67× per cache line" {
    style.fill: "#f3f0ff"
    style.stroke: "#7c3aed"
    style.italic: true
    style.font-size: 12
  }
  wi_fd -> wi_pad -> wi_port -> wi_end: {style.opacity: 0}
}
# ── thread_pool_t main layout ────────────────────────────────────────────────
tp: "`thread_pool_t`  total ≈ 24 740 B  (~24 KB)" {
  style.fill: "#f8f7ff"
  style.stroke: "#4338ca"
  style.stroke-width: 3
  style.font-size: 15
  style.bold: true
  # ── QUEUE BLOCK ──────────────────────────────────────────────────────────
  q_hdr: "offset 0x0000 ── QUEUE REGION ── 24 576 B (cache lines 0–383)" {
    style.fill: "#7c3aed"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  q0: "0x0000 │ queue[0]   │ work_item_t (24 B)" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font: mono
    style.font-size: 12
  }
  q1: "0x0018 │ queue[1]   │ work_item_t (24 B)" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font: mono
    style.font-size: 12
  }
  q2: "0x0030 │ queue[2]   │ work_item_t (24 B)" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font: mono
    style.font-size: 12
  }
  cl0_note: |'md
    **cache line 0** (0x0000–0x003F, 64 B)
    holds queue[0], queue[1], and 16 B of queue[2]
  '| {
    style.fill: "#ede9fe"
    style.stroke: "#7c3aed"
    style.stroke-dash: 4
    style.font-size: 11
  }
  q_ellipsis: "… queue[3] … queue[1022] … (24 B each, lines 1–382)" {
    style.fill: "#c7d2fe"
    style.stroke: "#6366f1"
    style.font: mono
    style.font-size: 12
    style.italic: true
    style.multiple: true
  }
  q_last: "0x5FE0 │ queue[1023] │ work_item_t (24 B)" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font: mono
    style.font-size: 12
  }
  cl383_note: "cache line 383 ends at 0x5FFF" {
    style.fill: "#ede9fe"
    style.stroke: "#7c3aed"
    style.stroke-dash: 4
    style.font-size: 11
  }
  # ── HOT CONTROL CACHE LINE ───────────────────────────────────────────────
  hot_hdr: "offset 0x6000 ── HOT CONTROL CACHE LINE (line 384) ── ⚠ FALSE-SHARE ZONE ──" {
    style.fill: "#dc2626"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  head_f: "0x6000 │ head   │ int (4 B)  ← consumer writes here" {
    style.fill: "#fee2e2"
    style.stroke: "#dc2626"
    style.stroke-width: 2
    style.font: mono
    style.font-size: 12
    style.bold: true
  }
  tail_f: "0x6004 │ tail   │ int (4 B)  ← producer writes here" {
    style.fill: "#fee2e2"
    style.stroke: "#dc2626"
    style.stroke-width: 2
    style.font: mono
    style.font-size: 12
    style.bold: true
  }
  count_f: "0x6008 │ count  │ int (4 B)  ← both read+write" {
    style.fill: "#fef3c7"
    style.stroke: "#d97706"
    style.stroke-width: 2
    style.font: mono
    style.font-size: 12
    style.bold: true
  }
  pad_align: "0x600C │ (pad)  │ 4 B — alignment before pthread_mutex_t (40 B needs 8-B align)" {
    style.fill: "#e5e7eb"
    style.stroke: "#9ca3af"
    style.font: mono
    style.font-size: 11
    style.italic: true
  }
  false_share_warn: |'md
    ⚠ **MESI False-Sharing Hot-Spot**
    `head` (consumer writes) and `tail` (producer writes)
    share **cache line 384**.  Every write by either thread
    sends an RFO (Request for Ownership), invalidating the
    other core's L1 copy → inter-core bus traffic.
    **Fix for high-throughput use:**
    pad `head` and `tail` to separate 64-B cache lines:
    c
    int head; char _pad0[60];
    int tail; char _pad1[60];
    
    (Not done here; mutex serialises access anyway.)
  '| {
    style.fill: "#fff7ed"
    style.stroke: "#dc2626"
    style.stroke-width: 2
    style.font-size: 12
  }
  # ── SYNC PRIMITIVES ──────────────────────────────────────────────────────
  sync_hdr: "offset 0x6010 ── SYNCHRONISATION PRIMITIVES (lines 384–386)" {
    style.fill: "#f97316"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  lock_f: "0x6010 │ lock (pthread_mutex_t) │ 40 B  [lines 384–385]" {
    style.fill: "#ffedd5"
    style.stroke: "#ea580c"
    style.stroke-width: 2
    style.font: mono
    style.font-size: 12
  }
  not_empty_f: "0x6038 │ not_empty (pthread_cond_t) │ 48 B  [line 385]" {
    style.fill: "#fed7aa"
    style.stroke: "#ea580c"
    style.font: mono
    style.font-size: 12
  }
  not_full_f: "0x6068 │ not_full  (pthread_cond_t) │ 48 B  [lines 385–386]" {
    style.fill: "#fed7aa"
    style.stroke: "#ea580c"
    style.font: mono
    style.font-size: 12
  }
  # ── CONTROL FIELDS ───────────────────────────────────────────────────────
  ctrl_hdr: "offset 0x6098 ── CONTROL + THREAD HANDLES (lines 386–388)" {
    style.fill: "#7c3aed"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  shutdown_f: "0x6098 │ shutdown     │ int  (4 B)  — 0=run, 1=drain+exit" {
    style.fill: "#ede9fe"
    style.stroke: "#7c3aed"
    style.font: mono
    style.font-size: 12
  }
  pad2: "0x609C │ (pad)       │ 4 B — align to 8 for pthread_t*" {
    style.fill: "#e5e7eb"
    style.stroke: "#9ca3af"
    style.font: mono
    style.font-size: 11
    style.italic: true
  }
  threads_f: "0x60A0 │ threads[0..15] │ pthread_t[16] = 128 B  (8 B each, lines 386–387)" {
    style.fill: "#fde68a"
    style.stroke: "#d97706"
    style.font: mono
    style.font-size: 12
  }
  tcount_f: "0x6120 │ thread_count   │ int  (4 B)  — number of live worker threads" {
    style.fill: "#fde68a"
    style.stroke: "#d97706"
    style.font: mono
    style.font-size: 12
  }
  total_note: "0x6124  END  ·  Total: ~24 740 B  ·  sizeof(thread_pool_t) ≈ 24 KB" {
    style.fill: "#4338ca"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  # ── invisible ordering arrows ─────────────────────────────────────────────
  q_hdr -> q0 -> q1 -> q2 -> cl0_note -> q_ellipsis -> q_last -> cl383_note -> hot_hdr -> head_f -> tail_f -> count_f -> pad_align -> false_share_warn -> sync_hdr -> lock_f -> not_empty_f -> not_full_f -> ctrl_hdr -> shutdown_f -> pad2 -> threads_f -> tcount_f -> total_note: {style.opacity: 0}
}
# ── work_item_t → thread_pool_t relationship ─────────────────────────────────
wi -> tp.q0: "1024 × sizeof(work_item_t) = 1024 × 24 B = 24 576 B" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
  style.font-size: 12
  target-arrowhead.shape: triangle
}
# ── MESI annotation ──────────────────────────────────────────────────────────
mesi: |'md
  ## MESI Cache Coherence on Line 384
  | Core | Action | Effect |
  |------|--------|--------|
  | Producer | `tail++` (write) | Acquires **M**odified; all other cores → **I**nvalid |
  | Consumer | `head++` (write) | Sends RFO; prev owner flushes to L3; acquires **M**odified |
  | Any core | `count` read | Shared **S** state; cheap |
  | Any core | `count` write | RFO again → bounce |
  Every enqueue+dequeue pair causes **2 RFO round-trips** on the
  inter-core interconnect, even though `head` and `tail` are logically
  independent.  A 64-B pad between them eliminates this at the cost of
  128 B of wasted struct space.
'| {
  near: bottom-center
  style.fill: "#fff1f2"
  style.stroke: "#dc2626"
  style.stroke-width: 2
  style.font-size: 12
}