vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Circular Work Queue: Enqueue & Dequeue Operations
  **WORK_QUEUE_CAPACITY = 8** · O(1) enqueue · O(1) dequeue · No element shifting
| {near: top-center}
# ─── STEP 1: Initial State ───────────────────────────────────────────────────
s1: "Step 1: Initial State" {
  style.fill: "#f0f4ff"
  style.stroke: "#4a6fa5"
  style.bold: true
  ring1: {
    style.fill: "#e8ecf5"
    style.stroke: "#aab4cc"
    grid-columns: 8
    grid-gap: 0
    c0: "[0]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c1: "[1]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c2: "[2]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c3: "[3]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c4: "[4]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c5: "[5]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c6: "[6]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c7: "[7]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
  }
  meta1: |md
    **head = 0 · tail = 0 · count = 0**
    Queue is EMPTY
    head == tail && count == 0 → empty condition
  | { style.fill: "#dceeff"; style.stroke: "#5599cc" }
}
# ─── STEP 2: Enqueue A ───────────────────────────────────────────────────────
s2: "Step 2: Enqueue Item A  →  queue[tail=0] = A, tail = (0+1)%8 = 1, count = 1" {
  style.fill: "#f0fff4"
  style.stroke: "#3a9a5c"
  style.bold: true
  ring2: {
    style.fill: "#e4f4ea"
    style.stroke: "#99ccaa"
    grid-columns: 8
    grid-gap: 0
    c0: "[0]\nA" {
      style.fill: "#f4d03f"
      style.font-color: "#333"
      style.bold: true
    }
    c1: "[1]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c2: "[2]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c3: "[3]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c4: "[4]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c5: "[5]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c6: "[6]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c7: "[7]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
  }
  ptrs2: {
    style.fill: "#cceecc"
    style.stroke: "#5a9a6a"
    grid-columns: 2
    grid-gap: 0
    h: "▲ head=0\n(next dequeue)" { style.fill: "#d5f5e3"; style.font-color: "#1a5c30" }
    t: "▲ tail=1\n(next enqueue)" { style.fill: "#fef9e7"; style.font-color: "#7d6608" }
  }
  meta2: |md
    **head = 0 · tail = 1 · count = 1**
    `pool->queue[pool->tail] = item`  ← write at tail
    `pool->tail = (pool->tail + 1) % WORK_QUEUE_CAPACITY`  ← advance tail
    `pool->count++`
    `pthread_cond_signal(&pool->not_empty)`  ← wake one worker
  | { style.fill: "#dff0d8"; style.stroke: "#3a9a5c" }
}
# ─── STEP 3: Enqueue B, C ────────────────────────────────────────────────────
s3: "Step 3: Enqueue B → queue[1]=B, Enqueue C → queue[2]=C  (tail=3, count=3)" {
  style.fill: "#f0fff4"
  style.stroke: "#3a9a5c"
  style.bold: true
  ring3: {
    style.fill: "#e4f4ea"
    style.stroke: "#99ccaa"
    grid-columns: 8
    grid-gap: 0
    c0: "[0]\nA" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c1: "[1]\nB" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c2: "[2]\nC" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c3: "[3]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c4: "[4]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c5: "[5]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c6: "[6]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c7: "[7]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
  }
  ptrs3: {
    style.fill: "#cceecc"
    style.stroke: "#5a9a6a"
    grid-columns: 2
    grid-gap: 0
    h: "▲ head=0\n(next dequeue)" { style.fill: "#d5f5e3"; style.font-color: "#1a5c30" }
    t: "▲ tail=3\n(next enqueue)" { style.fill: "#fef9e7"; style.font-color: "#7d6608" }
  }
  meta3: |md
    **head = 0 · tail = 3 · count = 3**
    Items A, B, C occupying consecutive slots
    No element shifting — each enqueue writes exactly 1 slot
  | { style.fill: "#dff0d8"; style.stroke: "#3a9a5c" }
}
# ─── STEP 4: Dequeue ─────────────────────────────────────────────────────────
s4: "Step 4: Dequeue  →  item = queue[head=0] = A,  head = (0+1)%8 = 1,  count = 2" {
  style.fill: "#fff8f0"
  style.stroke: "#c0782a"
  style.bold: true
  ring4: {
    style.fill: "#fef3e8"
    style.stroke: "#dda060"
    grid-columns: 8
    grid-gap: 0
    c0: "[0]\n✓ A\n(dequeued)" {
      style.fill: "#aab4cc"
      style.font-color: "#555"
      style.italic: true
    }
    c1: "[1]\nB" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c2: "[2]\nC" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c3: "[3]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c4: "[4]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c5: "[5]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c6: "[6]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
    c7: "[7]\nEMPTY" { style.fill: "#d4d8e0"; style.font-color: "#888" }
  }
  ptrs4: {
    style.fill: "#fde8cc"
    style.stroke: "#c0782a"
    grid-columns: 2
    grid-gap: 0
    h: "▲ head=1\n(next dequeue)" { style.fill: "#d5f5e3"; style.font-color: "#1a5c30" }
    t: "▲ tail=3\n(next enqueue)" { style.fill: "#fef9e7"; style.font-color: "#7d6608" }
  }
  deq_code: |md
    **Dequeue algorithm (under pool->lock):**
    
    item = pool->queue[pool->head]   ← value copy (24 bytes)
    pool->head = (pool->head + 1) % WORK_QUEUE_CAPACITY
    pool->count--
    pthread_cond_signal(&pool->not_full)
    pthread_mutex_unlock(&pool->lock)
    ← handle item OUTSIDE the lock
    
  | { style.fill: "#fdebd0"; style.stroke: "#c0782a" }
}
# ─── STEP 5: Wrap-around — Full Queue ────────────────────────────────────────
s5: "Step 5: Enqueue D…H + wrap-around  →  tail reaches [7], next goes to [0]  (count=8, FULL)" {
  style.fill: "#fff0f5"
  style.stroke: "#a04070"
  style.bold: true
  ring5: {
    style.fill: "#f9e8ef"
    style.stroke: "#d080a0"
    grid-columns: 8
    grid-gap: 0
    c0: "[0]\nI" {
      style.fill: "#e74c3c"
      style.font-color: white
      style.bold: true
      style.stroke: "#922b21"
      style.stroke-width: 2
    }
    c1: "[1]\nB" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c2: "[2]\nC" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c3: "[3]\nD" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c4: "[4]\nE" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c5: "[5]\nF" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c6: "[6]\nG" { style.fill: "#f4d03f"; style.font-color: "#333"; style.bold: true }
    c7: "[7]\nH" {
      style.fill: "#e74c3c"
      style.font-color: white
      style.bold: true
      style.stroke: "#922b21"
      style.stroke-width: 2
    }
  }
  ptrs5: {
    style.fill: "#f8d7da"
    style.stroke: "#a04070"
    grid-columns: 2
    grid-gap: 0
    h: "▲ head=1\n(next dequeue)\nitem B" { style.fill: "#d5f5e3"; style.font-color: "#1a5c30" }
    t: "▲ tail=1\n(=head → FULL)\ntail == head && count==8" {
      style.fill: "#f8d7da"
      style.font-color: "#922b21"
      style.bold: true
    }
  }
  wraparound: |md
    **Wrap-around:** tail was at [7] (item H)
    Next: `tail = (7+1) % 8 = 0`  ← item I written to [0]
    Then: `tail = (0+1) % 8 = 1`
    Now `tail == head == 1` with `count == 8` → **FULL**
    Full condition: `pool->count >= WORK_QUEUE_CAPACITY`
    (NOT `tail == head` alone — that is also the empty condition)
  | { style.fill: "#fce4ec"; style.stroke: "#a04070" }
}
# ─── STEP 6: Enqueue When Full → 503 ────────────────────────────────────────
s6: "Step 6: Enqueue attempt when count==8  →  return -1  →  caller sends 503" {
  style.fill: "#fff0f0"
  style.stroke: "#cc2222"
  style.stroke-width: 3
  style.bold: true
  reject_code: |md
    **thread_pool_enqueue() when queue is full:**
    c
    pthread_mutex_lock(&pool->lock);
    if (pool->count >= WORK_QUEUE_CAPACITY) {
        pthread_mutex_unlock(&pool->lock);
        return -1;          /* ← NON-BLOCKING: never waits */
    }
    
  | { style.fill: "#fdd"; style.stroke: "#cc2222" }
  caller_code: |md
    **Accept loop on return -1:**
    c
    const char *resp_503 =
        "HTTP/1.1 503 Service Unavailable\r\n"
        "Content-Length: 0\r\n"
        "Connection: close\r\n"
        "Retry-After: 1\r\n"    /* ← backpressure signal */
        "\r\n";
    send(client_fd, resp_503, strlen(resp_503), MSG_NOSIGNAL);
    close(client_fd);           /* ← caller retains ownership on -1 */
    
  | { style.fill: "#fdd"; style.stroke: "#cc2222" }
  reject_label: "503 SERVICE UNAVAILABLE\nQueue full — graceful overload rejection" {
    style.fill: "#cc2222"
    style.font-color: white
    style.bold: true
    style.border-radius: 8
  }
}
# ─── COMPLEXITY LEGEND ───────────────────────────────────────────────────────
complexity: {
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a7a"
  style.border-radius: 6
  grid-columns: 3
  grid-gap: 0
  enq: "ENQUEUE\nO(1)" {
    style.fill: "#0d7a3e"
    style.font-color: white
    style.bold: true
    style.font-size: 20
  }
  deq: "DEQUEUE\nO(1)" {
    style.fill: "#0d4f7a"
    style.font-color: white
    style.bold: true
    style.font-size: 20
  }
  no_shift: "NO ELEMENT\nSHIFTING" {
    style.fill: "#6a0d7a"
    style.font-color: white
    style.bold: true
    style.font-size: 20
  }
}
# ─── CIRCULAR BUFFER INVARIANTS ──────────────────────────────────────────────
invariants: |md
  ## Ring Buffer Invariants (must hold under pool->lock)
  - `count == (tail - head + CAPACITY) % CAPACITY` when `count < CAPACITY`
  - `count == CAPACITY` when `tail == head && full`
  - **Empty:** `count == 0` (head == tail)
  - **Full:** `count == WORK_QUEUE_CAPACITY` (head == tail after wrap)
  - Distinguish empty vs full using `count`, NOT by comparing head and tail alone
  - `tail = (tail + 1) % CAPACITY` — compile target: bitmask `& (CAPACITY-1)` at -O2
  - Power-of-2 capacity (1024) enables bitmask optimisation
| {
  style.fill: "#e8f4fd"
  style.stroke: "#2980b9"
  near: bottom-center
}
# ─── FLOW ARROWS ─────────────────────────────────────────────────────────────
s1 -> s2: "enqueue(A)" { style.stroke: "#3a9a5c"; style.bold: true }
s2 -> s3: "enqueue(B), enqueue(C)" { style.stroke: "#3a9a5c"; style.bold: true }
s3 -> s4: "dequeue() → A" { style.stroke: "#c0782a"; style.bold: true }
s4 -> s5: "enqueue(D..H)+wrap\ntail: 3→4→5→6→7→0→1" { style.stroke: "#a04070"; style.bold: true }
s5 -> s6: "enqueue attempt\ncount==8 → FULL" {
  style.stroke: "#cc2222"
  style.bold: true
  style.stroke-width: 3
}