vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # Concurrency Models: Thread-per-Connection vs Thread Pool
|| {
  near: top-center
}

tpc_side: "Thread-per-Connection (AVOID)" {
  style: {
    fill: "#fff0f0"
    stroke: "#cc3333"
    stroke-width: 2
    border-radius: 8
  }

  accept_loop_l: "accept() Loop" {
    style: {
      fill: "#f4b76c"
      stroke: "#cc6600"
      border-radius: 4
    }
  }

  spawn_note: {
    shape: text
    label: ||md
      `pthread_create()` per connection
      **Cost: ~15 µs × 1000/s = 15 ms/s overhead**
    ||
    style.font-size: 13
  }

  threads: "Unbounded Thread Pool" {
    style: {
      fill: "#fce7c6"
      stroke: "#cc3333"
      border-radius: 4
      multiple: true
    }
    t1: "Thread 1\n8 MB stack" { style.fill: "#f9d8a7" }
    t2: "Thread 2\n8 MB stack" { style.fill: "#f9d8a7" }
    t3: "Thread 3\n8 MB stack" { style.fill: "#f9d8a7" }
    tdots: "… Thread N\n8 MB stack" {
      style.fill: "#f9d8a7"
      style.stroke-dash: 5
    }
  }

  mem_cost: {
    shape: text
    label: ||md
      **N=1000 connections:**
      1000 threads × 8 MB = **8 GB virtual**
      Scheduler overhead grows super-linearly
    ||
    style: {
      font-size: 13
      bold: true
      font-color: "#990000"
    }
  }

  slowloris: "Slowloris Attack" {
    style: {
      fill: "#ffcccc"
      stroke: "#cc0000"
      stroke-width: 2
      border-radius: 4
    }
    slow_desc: {
      shape: text
      label: ||md
        1000 slow connections
        → 1000 threads blocked **forever**
        → Server paralysed
        → Real clients cannot connect
      ||
      style: {
        font-size: 12
        font-color: "#880000"
      }
    }
  }

  verdict_l: "❌ Unbounded resource use\nDegrades under adversarial input" {
    style: {
      fill: "#cc3333"
      font-color: white
      border-radius: 4
      bold: true
    }
  }

  accept_loop_l -> threads: "spawn 1 thread\nper connection" {
    style: {
      stroke: "#cc3333"
      font-color: "#cc3333"
      bold: true
    }
  }
  threads -> mem_cost
  threads -> slowloris: "slow client\nblocks thread"
  slowloris -> verdict_l
}

pool_side: "Thread Pool (PREFERRED)" {
  style: {
    fill: "#f0fff0"
    stroke: "#336633"
    stroke-width: 2
    border-radius: 8
  }

  accept_loop_r: "accept() Loop" {
    style: {
      fill: "#f4b76c"
      stroke: "#cc6600"
      border-radius: 4
    }
  }

  queue: "Bounded Work Queue\ncapacity = 1024 slots" {
    style: {
      fill: "#C7F1FF"
      stroke: "#0066aa"
      border-radius: 4
      3d: true
    }
    q_slots: {
      shape: text
      label: ||md
        [ fd₁ ][ fd₂ ][ fd₃ ] … [ fd₁₀₂₄ ]
        head →                        ← tail
      ||
      style: {
        font-size: 12
        font: mono
      }
    }
  }

  fixed_pool: "Fixed Thread Pool  N=16" {
    style: {
      fill: "#ACE1AF"
      stroke: "#336633"
      stroke-width: 2
      border-radius: 4
    }
    w1: "Worker 1" { style.fill: "#88DCF7" }
    w2: "Worker 2" { style.fill: "#88DCF7" }
    w3: "Worker 3" { style.fill: "#88DCF7" }
    w4: "Worker 4" { style.fill: "#88DCF7" }
    wdots: "Workers 5–16" { style.fill: "#88DCF7"; style.stroke-dash: 5 }
  }

  mem_cost_r: {
    shape: text
    label: ||md
      **N=1000 connections:**
      16 threads × 8 MB = **128 MB virtual**
      984 connections queued or rejected
      `pthread_create()` called **16×  at startup only**
    ||
    style: {
      font-size: 13
      bold: true
      font-color: "#005500"
    }
  }

  slowloris_r: "Slowloris Attack" {
    style: {
      fill: "#d4edda"
      stroke: "#336633"
      border-radius: 4
    }
    slow_desc_r: {
      shape: text
      label: ||md
        1000 slow connections:
        → 16 worker slots filled
        → Queue fills → **503 Retry-After: 1**
        → Fast clients still served
        → Server **continues operating**
      ||
      style: {
        font-size: 12
        font-color: "#005500"
      }
    }
  }

  resp_503: "HTTP/1.1 503\nService Unavailable\nRetry-After: 1" {
    style: {
      fill: "#fff3cd"
      stroke: "#cc8800"
      border-radius: 4
      font: mono
      font-size: 12
    }
  }

  verdict_r: "✅ Bounded resource use\nPredictable under adversarial input" {
    style: {
      fill: "#336633"
      font-color: white
      border-radius: 4
      bold: true
    }
  }

  accept_loop_r -> queue: "enqueue(client_fd)\nO(1) non-blocking" {
    style.stroke: "#0066aa"
  }
  queue -> fixed_pool: "dequeue under\npthread_mutex_lock()" {
    style: {
      stroke: "#336633"
      animated: true
    }
  }
  fixed_pool -> mem_cost_r
  accept_loop_r -> resp_503: "queue full?\nreturn -1 → send 503" {
    style: {
      stroke: "#cc8800"
      stroke-dash: 4
    }
  }
  fixed_pool -> slowloris_r: "after 16 slots full\n→ queue absorbs rest" {
    style: {
      stroke: "#336633"
      stroke-dash: 3
    }
  }
  slowloris_r -> verdict_r
}

model_comparison: {
  label: ||md
    ## Prefer Thread Pool
    | Property | Thread-per-Connection | Thread Pool |
    |---|---|---|
    | Threads at 1000 connections | **1000** | **16** |
    | Virtual memory (1000 conn) | **8 GB** | **128 MB** |
    | `pthread_create` overhead | **15 ms/s at 1k req/s** | **one-time startup** |
    | Slowloris resistance | ❌ None | ✅ 503 + drain |
    | Resource use | Unbounded | **Bounded = predictable** |

    **Invariant:** thread pool contract — exactly N threads, always,
    regardless of connection count. Excess connections get 503.
  ||
  near: bottom-center
  style: {
    fill: "#f8f8f8"
    stroke: "#444444"
    border-radius: 6
  }
}

tpc_side -> pool_side: "prefer for\npredictable resource use\nunder adversarial input" {
  style: {
    stroke: "#333399"
    stroke-width: 3
    bold: true
    font-color: "#333399"
  }
  target-arrowhead.shape: arrow
}