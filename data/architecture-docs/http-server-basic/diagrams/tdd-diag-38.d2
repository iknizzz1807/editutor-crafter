vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  ## Mutex Contention & Cache-Line False Sharing — `server_stats_t`
  **False sharing**: Mutex write invalidates counter cache lines on all cores even though no counter was written.
|
title.near: top-center

# ─────────────────────────────────────────────────────────────
# POOR LAYOUT — single cache line
# ─────────────────────────────────────────────────────────────
poor: "POOR LAYOUT  —  server_stats_t (no padding)" {
  style.fill: "#fff0f0"
  style.stroke: "#cc3333"
  style.stroke-width: 3
  style.border-radius: 6

  cl0_poor: "Cache Line 0  [0x00 – 0x3F]  64 bytes" {
    style.fill: "#ffe0e0"
    style.stroke: "#cc3333"
    style.stroke-dash: 5
    style.stroke-width: 2
    style.border-radius: 4
    style.font: mono

    mutex_poor: {
      label: "pthread_mutex_t  lock\n[0x00 – 0x27]  40 bytes"
      style.fill: "#9b30ff"
      style.font-color: white
      style.bold: true
      style.border-radius: 3
      width: 320
      height: 48
    }
    pad_poor: {
      label: "pad\n[0x28–0x2B]\n4 B"
      style.fill: "#aaaaaa"
      style.font-color: "#ffffff"
      style.border-radius: 3
      width: 32
      height: 48
    }
    active_poor: {
      label: "active_connections\n[0x2C]  4 B"
      style.fill: "#2277dd"
      style.font-color: white
      style.border-radius: 3
      width: 80
      height: 48
    }
    total_poor: {
      label: "total_connections\n[0x30]  4 B"
      style.fill: "#2277dd"
      style.font-color: white
      style.border-radius: 3
      width: 80
      height: 48
    }
    bytes_poor: {
      label: "total_bytes_sent\n[0x34]  8 B"
      style.fill: "#1a5baa"
      style.font-color: white
      style.border-radius: 3
      width: 96
      height: 48
    }
    overflow_poor: {
      label: "SPILLS to\nnext line"
      style.fill: "#ffcccc"
      style.font-color: "#cc0000"
      style.bold: true
      style.border-radius: 3
      width: 80
      height: 48
    }
  }

  cost_poor: {
    label: |md
      **Every mutex acquire writes to cache line 0**
      → x86 `LOCK CMPXCHG` on `lock` field
      → CPU broadcasts **RFO** (Request For Ownership) on memory bus
      → All other cores' copies of line 0 → **INVALID** (I)
      → Cores reading counters must reload from L3/RAM
      → Even though NO counter was modified!
      **Contested lock cost: ~100 ns** (L3 miss)
      **False sharing overhead: ~90 ns per acquisition**
    |
    style.fill: "#fff0cc"
    style.stroke: "#cc8800"
    style.stroke-width: 2
    style.border-radius: 4
  }
}

# ─────────────────────────────────────────────────────────────
# GOOD LAYOUT — padded to cache-line boundary
# ─────────────────────────────────────────────────────────────
good: "GOOD LAYOUT  —  server_stats_t (cache-line padded)" {
  style.fill: "#f0fff4"
  style.stroke: "#228833"
  style.stroke-width: 3
  style.border-radius: 6

  cl0_good: "Cache Line 0  [0x00 – 0x3F]  64 bytes  →  MUTEX ONLY" {
    style.fill: "#e0ffe8"
    style.stroke: "#228833"
    style.stroke-dash: 5
    style.stroke-width: 2
    style.border-radius: 4
    style.font: mono

    mutex_good: {
      label: "pthread_mutex_t  lock\n[0x00 – 0x27]  40 bytes"
      style.fill: "#9b30ff"
      style.font-color: white
      style.bold: true
      style.border-radius: 3
      width: 320
      height: 48
    }
    pad_good: {
      label: "char _pad[24]  —  padding to 64 B\n[0x28 – 0x3F]"
      style.fill: "#aaaaaa"
      style.font-color: white
      style.border-radius: 3
      width: 192
      height: 48
    }
  }

  cl1_good: "Cache Line 1  [0x40 – 0x7F]  64 bytes  →  COUNTERS ONLY" {
    style.fill: "#e0f0ff"
    style.stroke: "#2266cc"
    style.stroke-dash: 5
    style.stroke-width: 2
    style.border-radius: 4
    style.font: mono

    active_good: {
      label: "active_connections\n[0x40]  4 B"
      style.fill: "#2277dd"
      style.font-color: white
      style.border-radius: 3
      width: 100
      height: 48
    }
    pad2_good: {
      label: "pad\n4 B"
      style.fill: "#aaaaaa"
      style.font-color: white
      style.border-radius: 3
      width: 32
      height: 48
    }
    total_conn_good: {
      label: "total_connections\n[0x48]  8 B"
      style.fill: "#1a5baa"
      style.font-color: white
      style.border-radius: 3
      width: 128
      height: 48
    }
    total_req_good: {
      label: "total_requests\n[0x50]  8 B"
      style.fill: "#1a5baa"
      style.font-color: white
      style.border-radius: 3
      width: 128
      height: 48
    }
    bytes_good: {
      label: "total_bytes_sent\n[0x58]  8 B"
      style.fill: "#1a5baa"
      style.font-color: white
      style.border-radius: 3
      width: 128
      height: 48
    }
    remain_good: {
      label: "unused\n[0x60–0x7F]"
      style.fill: "#dddddd"
      style.font-color: "#777777"
      style.border-radius: 3
      width: 128
      height: 48
    }
  }

  benefit_good: {
    label: |md
      **✓ Zero False Sharing**
      → Mutex write dirties only cache line 0.
      → Cache line 1 (counters) stays in **SHARED** state.
      → No RFO broadcast for counter reads.
      **Savings: ~86 ns per counter read during contention.**
    |
    style.fill: "#e8ffe8"
    style.stroke: "#228833"
    style.stroke-width: 2
    style.border-radius: 4
  }
}

# ─────────────────────────────────────────────────────────────
# MESI State Transition Diagram
# ─────────────────────────────────────────────────────────────
mesi: "MESI Protocol — Cache Coherence State Transitions" {
  style.fill: "#f8f4ff"
  style.stroke: "#7733cc"
  style.stroke-width: 2
  style.border-radius: 6

  M: "M\nModified" {
    shape: circle
    style.fill: "#cc3333"
    style.font-color: white
    style.bold: true
  }
  E: "E\nExclusive" {
    shape: circle
    style.fill: "#e07700"
    style.font-color: white
    style.bold: true
  }
  S: "S\nShared" {
    shape: circle
    style.fill: "#228833"
    style.font-color: white
    style.bold: true
  }
  I: "I\nInvalid" {
    shape: circle
    style.fill: "#555555"
    style.font-color: white
    style.bold: true
  }

  S -> I: "Remote write\n(Invalidation)" {
    style.stroke: "#cc3333"
    style.stroke-width: 3
    style.bold: true
    style.font-color: "#cc3333"
  }
  I -> S: "Remote read\n(Reload)" {
    style.stroke: "#2277dd"
    style.stroke-width: 2
  }
  I -> E: "Local read" {
    style.stroke: "#228833"
    style.stroke-width: 2
  }
  E -> M: "Local write" {
    style.stroke: "#228833"
    style.stroke-width: 2
  }
  E -> S: "Remote read" {
    style.stroke: "#888800"
    style.stroke-dash: 3
  }
  M -> I: "Remote RFO" {
    style.stroke: "#cc3333"
    style.stroke-width: 3
  }

  note_poor: |md
    **False Sharing**: Byte 0x00 write invalidates entire 64B block.
    Threads reading byte 0x2C pay I→S reload cost.
  |
}

# ─────────────────────────────────────────────────────────────
# Core contention diagram
# ─────────────────────────────────────────────────────────────
cores: "16 Worker Threads — Cache Line Ownership" {
  style.fill: "#fffef0"
  style.stroke: "#888800"
  style.stroke-width: 2
  style.border-radius: 6

  core_a: "Core 0 (Thread A)" {
    label: |md
      **Core 0** (Acquires Lock)
      `LOCK CMPXCHG`
      Line 0: **M** (Modified)
    |
    style.fill: "#ffe0e0"
    style.stroke: "#cc3333"
  }
  rfo: "RFO Broadcast" {
    shape: diamond
    style.fill: "#ffcc44"
    style.font-color: "#553300"
    style.bold: true
  }
  core_b: "Core 1 (Thread B)" {
    label: |md
      **Core 1** (Reads Counter)
      Line 0: **S→I**
      **Cost: ~100 ns stall**
    |
    style.fill: "#e0e8ff"
    style.stroke: "#2266cc"
  }
  core_c: "Cores 2–15" {
    style.fill: "#e8ffe8"
    style.stroke: "#228833"
    style.multiple: true
  }

  core_a -> rfo: "Write"
  rfo -> core_b: "Invalidate"
  rfo -> core_c: "Invalidate"
}

# ─────────────────────────────────────────────────────────────
# Legend and Global Annotations
# ─────────────────────────────────────────────────────────────
legend: "Legend" {
  style.fill: "#f5f5f5"
  style.stroke: "#999999"
  style.border-radius: 4

  l_mutex: "pthread_mutex_t (40 B)" { style.fill: "#9b30ff"; style.font-color: white }
  l_int: "int (4 B)" { style.fill: "#2277dd"; style.font-color: white }
  l_ll: "long long (8 B)" { style.fill: "#1a5baa"; style.font-color: white }
  l_pad: "Padding" { style.fill: "#aaaaaa"; style.font-color: white }
  l_cl: "64B Cache Line" { style.stroke: "#cc3333"; style.stroke-dash: 5 }
}
legend.near: bottom-right

sizeof_note: |md
  **Memory Statistics**
  - Poor layout: 72 B (Shared line 0)
  - Good layout: 128 B (Separated line 0 and line 1)
  - **Padding cost**: 24 bytes
  - **Performance gain**: ~86 ns/read during contention.
|
sizeof_note.near: bottom-center
sizeof_note.style: {
  fill: "#f0f0ff"
  stroke: "#555599"
  border-radius: 4
}