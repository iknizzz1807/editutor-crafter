vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
title: |md
  ## Three-Level View of a `recv()` Call
  **recv(client_fd, buf, 4096, 0)**
| {near: top-center}
###############################################################
# LEVEL 1 — APPLICATION
###############################################################
app: "Level 1 — Application" {
  style.fill: "#e8d5f5"
  style.stroke: "#7b2d9e"
  style.stroke-width: 2
  style.border-radius: 8
  call_site: "recv(client_fd, buf, 4096, 0)" {
    style.fill: "#c084fc"
    style.stroke: "#7b2d9e"
    style.stroke-width: 2
    style.font: mono
    style.bold: true
  }
  thread_state: |md
    **Thread state machine**
    `RUNNING` → syscall → `BLOCKED`
    (if recv buffer empty)
    `BLOCKED` → data arrives → `RUNNABLE`
    → scheduler picks up → `RUNNING`
    → `recv()` returns
  | {
    style.fill: "#f3e8ff"
    style.stroke: "#a855f7"
  }
  return_note: |md
    **Return value ≤ kernel recv buffer occupancy at that instant**
    A single `write()` on sender → may arrive as
    2, 3, or 20 `recv()` calls on receiver.
    Correct code **always loops**.
  | {
    style.fill: "#fdf4ff"
    style.stroke: "#d946ef"
    style.font-color: "#701a75"
  }
  call_site -> thread_state: "syscall\nentry" {
    style.stroke: "#7b2d9e"
    style.stroke-width: 2
    style.animated: true
  }
  thread_state -> return_note: "recv()\nreturns n" {
    style.stroke: "#7b2d9e"
    style.stroke-dash: 4
  }
}
###############################################################
# LEVEL 2 — OS / KERNEL
###############################################################
kernel: "Level 2 — OS / Kernel" {
  style.fill: "#dbeafe"
  style.stroke: "#1d4ed8"
  style.stroke-width: 2
  style.border-radius: 8
  recv_buf_check: "Check socket recv buffer" {
    style.fill: "#93c5fd"
    style.stroke: "#1d4ed8"
    style.stroke-width: 2
    style.bold: true
  }
  buf_empty: "Buffer EMPTY\nMark thread BLOCKED\nContext-switch away" {
    style.fill: "#fca5a5"
    style.stroke: "#dc2626"
    style.stroke-width: 2
    style.bold: true
  }
  buf_has_data: "Buffer HAS DATA\nCopy: kernel recv buf → user buf\nMark thread RUNNABLE\nReturn n bytes" {
    style.fill: "#86efac"
    style.stroke: "#16a34a"
    style.stroke-width: 2
    style.bold: true
  }
  socket_buf: "Socket recv buffer\n(kernel ring buffer)\ndefault ~87 KB on Linux" {
    style.fill: "#bfdbfe"
    style.stroke: "#2563eb"
    style.stroke-width: 1
    style.font: mono
  }
  interrupt_handler: "Network interrupt handler\nwakes BLOCKED thread\n→ RUNNABLE" {
    style.fill: "#fde68a"
    style.stroke: "#d97706"
    style.stroke-width: 2
  }
  recv_buf_check -> buf_empty: "empty" {
    style.stroke: "#dc2626"
    style.stroke-width: 2
    style.font-color: "#dc2626"
    style.bold: true
  }
  recv_buf_check -> buf_has_data: "has data" {
    style.stroke: "#16a34a"
    style.stroke-width: 2
    style.font-color: "#16a34a"
    style.bold: true
  }
  recv_buf_check -> socket_buf: "reads" {
    style.stroke: "#2563eb"
    style.stroke-dash: 3
  }
  interrupt_handler -> socket_buf: "updates\nbuffer" {
    style.stroke: "#d97706"
    style.stroke-width: 2
    style.animated: true
  }
  buf_empty -> interrupt_handler: "awakened by\ninterrupt" {
    style.stroke: "#d97706"
    style.stroke-dash: 4
    style.animated: true
  }
  interrupt_handler -> buf_has_data: "re-check\nbuffer" {
    style.stroke: "#16a34a"
    style.stroke-dash: 4
  }
}
###############################################################
# LEVEL 3 — HARDWARE
###############################################################
hw: "Level 3 — Hardware" {
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
  style.stroke-width: 2
  style.border-radius: 8
  nic: "NIC\n(Network Interface Card)" {
    style.fill: "#fbbf24"
    style.stroke: "#92400e"
    style.stroke-width: 2
    style.bold: true
  }
  eth_frame: "Receives Ethernet frame\nfrom network wire" {
    style.fill: "#fde68a"
    style.stroke: "#b45309"
    style.stroke-width: 1
  }
  dma: "DMA Transfer\nNIC → kernel ring buffer\n(no CPU involvement)" {
    style.fill: "#fcd34d"
    style.stroke: "#b45309"
    style.stroke-width: 2
    style.bold: true
  }
  interrupt: "Raise hardware interrupt\nto CPU" {
    style.fill: "#f97316"
    style.stroke: "#c2410c"
    style.stroke-width: 2
    style.bold: true
  }
  cpu_note: |md
    **CPU is NOT involved** in DMA transfer.
    Frame data moves directly:
    Wire → NIC buffer → kernel ring buffer
    via bus-master DMA.
    CPU only wakes on the interrupt.
  | {
    style.fill: "#fffbeb"
    style.stroke: "#d97706"
  }
  nic -> eth_frame: "receives" {
    style.stroke: "#b45309"
    style.stroke-width: 2
  }
  eth_frame -> dma: "triggers" {
    style.stroke: "#b45309"
    style.stroke-width: 2
    style.animated: true
  }
  dma -> interrupt: "then raises" {
    style.stroke: "#c2410c"
    style.stroke-width: 2
    style.animated: true
  }
  dma -> cpu_note: "bypasses CPU" {
    style.stroke: "#d97706"
    style.stroke-dash: 3
    style.font-color: "#92400e"
  }
}
###############################################################
# CROSS-LEVEL CONNECTIONS
###############################################################
app.call_site -> kernel.recv_buf_check: "syscall: crosses\nuser/kernel boundary" {
  style.stroke: "#7c3aed"
  style.stroke-width: 3
  style.bold: true
  style.animated: true
}
kernel.buf_has_data -> app.thread_state: "copy to user buf\nreturn n ≤ buf_occupancy" {
  style.stroke: "#16a34a"
  style.stroke-width: 2
  style.stroke-dash: 4
  style.font-color: "#16a34a"
  style.bold: true
}
hw.interrupt -> kernel.interrupt_handler: "hardware interrupt\n→ kernel ISR" {
  style.stroke: "#f97316"
  style.stroke-width: 3
  style.bold: true
  style.animated: true
}
hw.dma -> kernel.socket_buf: "DMA writes\nframe data" {
  style.stroke: "#ca8a04"
  style.stroke-width: 2
  style.animated: true
}