vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  # HTTP Request Parser — State Machine
  Module `http-server-basic-m2` · `http_parse_request()` / `parse_headers()`
| {near: top-center}
# ── States ────────────────────────────────────────────────────────────────────
INIT: {
  shape: circle
  label: "● INIT"
  style.fill: "#2d2d2d"
  style.font-color: white
  style.stroke: "#888"
  style.stroke-width: 2
}
READING_REQUEST_LINE: {
  label: "READING_REQUEST_LINE\n\nInvariant: pos = buf[0]\nbuf[0..first_\\n] is the request line\nno colon search active"
  style.fill: "#3b1f6b"
  style.font-color: "#e8d5ff"
  style.stroke: "#9b59b6"
  style.stroke-width: 2
  style.border-radius: 6
}
READING_HEADERS: {
  label: "READING_HEADERS\n\nInvariant: pos > first_\\n\nheader_count ∈ [0..MAX_HEADERS)\nscanning for colon or empty line"
  style.fill: "#1a3a5c"
  style.font-color: "#d0eaff"
  style.stroke: "#3498db"
  style.stroke-width: 2
  style.border-radius: 6
}
OBS_FOLD_CONTINUATION: {
  label: "OBS_FOLD_CONTINUATION\n\nInvariant: line[0] ∈ {SP, HT}\nheader_count > 0\nprev header value being extended"
  style.fill: "#1a3a2a"
  style.font-color: "#c8f0d8"
  style.stroke: "#27ae60"
  style.stroke-width: 2
  style.border-radius: 6
}
READING_EMPTY_LINE: {
  label: "READING_EMPTY_LINE\n\nInvariant: line_len == 0\nafter stripping \\r (if CRLF)\nend-of-headers marker reached"
  style.fill: "#3a2a00"
  style.font-color: "#ffe8a0"
  style.stroke: "#f39c12"
  style.stroke-width: 2
  style.border-radius: 6
}
BODY_BOUNDARY: {
  label: "BODY_BOUNDARY\n\nInvariant: req.body = line_end+1\nreq.body_len = end - body_start\nbody pointer set into raw buf"
  style.fill: "#2a1a3a"
  style.font-color: "#e8c8ff"
  style.stroke: "#8e44ad"
  style.stroke-width: 2
  style.border-radius: 6
}
DONE: {
  shape: circle
  label: "DONE ◎"
  style.fill: "#1a3a1a"
  style.font-color: "#80ff80"
  style.stroke: "#27ae60"
  style.stroke-width: 3
  style.double-border: true
}
# ── Error States ──────────────────────────────────────────────────────────────
ERR_BAD_REQUEST: {
  label: "ERROR\nBAD_REQUEST\n→ return -1\n→ caller sends 400"
  style.fill: "#5c0000"
  style.font-color: "#ffcccc"
  style.stroke: "#e74c3c"
  style.stroke-width: 3
  style.border-radius: 6
}
ERR_URI_TOO_LONG: {
  label: "ERROR\nURI_TOO_LONG\n→ return -2\n→ caller sends 414"
  style.fill: "#5c2a00"
  style.font-color: "#ffddb0"
  style.stroke: "#e67e22"
  style.stroke-width: 3
  style.border-radius: 6
}
ERR_NOT_IMPL: {
  label: "ERROR\nNOT_IMPL\n→ return -3\n→ caller sends 501"
  style.fill: "#3a3a00"
  style.font-color: "#ffffa0"
  style.stroke: "#f1c40f"
  style.stroke-width: 3
  style.border-radius: 6
}
# ── ILLEGAL re-entry state ─────────────────────────────────────────────────────
ILLEGAL_REENTRY: {
  label: "⚠ ILLEGAL\nRE-ENTRY TO\nREADING_REQUEST_LINE"
  style.fill: "#3a0000"
  style.font-color: "#ff8080"
  style.stroke: "#c0392b"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.border-radius: 6
}
# ── Annotations ───────────────────────────────────────────────────────────────
note_crlf: |md
  **Line-ending normalization (all states)**
  - `memchr(pos, '\n', len)` → finds `\n` (CRLF or bare LF)
  - If `line[line_len-1] == '\r'` → `line_len--` (strip `\r`)
  - Both CRLF and bare LF accepted transparently
| {
  near: bottom-left
  style.fill: "#222"
  style.font-color: "#aaa"
  style.stroke: "#555"
}
note_tolower: |md
  **Header name normalization (READING_HEADERS)**
  `for i in 0..name_len: name[i] = tolower((unsigned char)name[i])`
  Cast to `unsigned char` is **mandatory** — UB on signed chars > 127
| {
  near: bottom-right
  style.fill: "#222"
  style.font-color: "#aaa"
  style.stroke: "#555"
}
# ── Transitions ───────────────────────────────────────────────────────────────
INIT -> READING_REQUEST_LINE: "memset(req,0); enter\nparse_request_line()" {
  style.stroke: "#888"
  style.stroke-width: 2
}
READING_REQUEST_LINE -> READING_HEADERS: "guard: first '\\n' found\naction: pos = first_\\n + 1\n        parse_headers() loop begins" {
  style.stroke: "#3498db"
  style.stroke-width: 2
}
READING_REQUEST_LINE -> ERR_BAD_REQUEST: "guard: no space found (no method/path split)\n    OR no second space (no version)\n    OR empty method or empty path\n    OR version_len == 0 or >= MAX_VERSION_LEN\n    OR unrecognized version string" {
  style.stroke: "#e74c3c"
  style.stroke-width: 2
  style.stroke-dash: 3
}
READING_REQUEST_LINE -> ERR_URI_TOO_LONG: "guard: path_len >= MAX_PATH_LEN (8192)\naction: return -2" {
  style.stroke: "#e67e22"
  style.stroke-width: 2
  style.stroke-dash: 3
}
READING_HEADERS -> READING_HEADERS: "guard: colon found, name_len in [1..127]\naction: copy name → tolower\n        strip OWS from value\n        header_count++\n        pos = line_end + 1" {
  style.stroke: "#3498db"
  style.stroke-width: 2
}
READING_HEADERS -> OBS_FOLD_CONTINUATION: "guard: line[0] ∈ {SP, HT}\n    AND header_count > 0\naction: append ' '+trimmed_cont\n        to prev header value\n        pos = line_end + 1" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
READING_HEADERS -> READING_HEADERS: "guard: line[0] ∈ {SP,HT}\n    AND header_count == 0\n    (orphan continuation)\naction: skip line silently" {
  style.stroke: "#27ae60"
  style.stroke-width: 1
  style.stroke-dash: 4
}
READING_HEADERS -> READING_HEADERS: "guard: no colon in line\n    (malformed header)\naction: skip entry silently" {
  style.stroke: "#95a5a6"
  style.stroke-width: 1
  style.stroke-dash: 4
}
OBS_FOLD_CONTINUATION -> READING_HEADERS: "action: value extended\n        pos advanced\n        continue header loop" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
READING_HEADERS -> READING_EMPTY_LINE: "guard: line_len == 0\n    (empty line after \\r strip)\naction: body_start = line_end + 1" {
  style.stroke: "#f39c12"
  style.stroke-width: 2
}
READING_EMPTY_LINE -> BODY_BOUNDARY: "guard: body_start < end\naction: req.body = body_start\n        req.body_len = end - body_start" {
  style.stroke: "#8e44ad"
  style.stroke-width: 2
}
READING_EMPTY_LINE -> BODY_BOUNDARY: "guard: body_start >= end\naction: req.body = NULL\n        req.body_len = 0" {
  style.stroke: "#8e44ad"
  style.stroke-width: 1
  style.stroke-dash: 4
}
BODY_BOUNDARY -> DONE: "action: return header_count\n        (parse_headers done)\nhttp_parse_request() continues\nto method classification" {
  style.stroke: "#27ae60"
  style.stroke-width: 2
}
READING_HEADERS -> ERR_BAD_REQUEST: "guard: no '\\n' found at all\n    in buf[0..buf_len]\n    (request_line skip fails)" {
  style.stroke: "#e74c3c"
  style.stroke-width: 1
  style.stroke-dash: 3
}
DONE -> ERR_NOT_IMPL: "guard: classify_method() ==\n    HTTP_METHOD_OTHER\n    (not GET or HEAD)\naction: return -3" {
  style.stroke: "#f1c40f"
  style.stroke-width: 2
  style.stroke-dash: 3
}
# ── ILLEGAL transition ─────────────────────────────────────────────────────────
READING_HEADERS -> ILLEGAL_REENTRY: "ILLEGAL: once headers have started\n(pos > first_\\n), the state machine\nmust NEVER return to\nREADING_REQUEST_LINE.\nDoing so would re-parse\nthe request line as a header." {
  style.stroke: "#c0392b"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.animated: true
}
OBS_FOLD_CONTINUATION -> ILLEGAL_REENTRY: "ILLEGAL: continuation line\ncannot restart request line\nparsing. The prev-header pointer\nwould become dangling." {
  style.stroke: "#c0392b"
  style.stroke-width: 1
  style.stroke-dash: 5
}