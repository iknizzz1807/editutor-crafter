direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # 10K Concurrent Connections — Scalability Test Architecture
| {near: top-center}
row_clients: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  client1: Client Machine 1 {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    label: "Client Machine 1\n(2500 connections)"
    c1_threads: Worker Threads {
      shape: rectangle
      style.fill: "#C8E6C9"
      c1_t1: "Thread 1\n625 conns"
      c1_t2: "Thread 2\n625 conns"
      c1_t3: "Thread 3\n625 conns"
      c1_t4: "Thread 4\n625 conns"
    }
  }
  client2: Client Machine 2 {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    label: "Client Machine 2\n(2500 connections)"
    c2_threads: Worker Threads {
      shape: rectangle
      style.fill: "#C8E6C9"
      c2_t1: "Thread 1\n625 conns"
      c2_t2: "Thread 2\n625 conns"
      c2_t3: "Thread 3\n625 conns"
      c2_t4: "Thread 4\n625 conns"
    }
  }
  client3: Client Machine 3 {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    label: "Client Machine 3\n(2500 connections)"
    c3_threads: Worker Threads {
      shape: rectangle
      style.fill: "#C8E6C9"
      c3_t1: "Thread 1\n625 conns"
      c3_t2: "Thread 2\n625 conns"
      c3_t3: "Thread 3\n625 conns"
      c3_t4: "Thread 4\n625 conns"
    }
  }
  client4: Client Machine 4 {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    label: "Client Machine 4\n(2500 connections)"
    c4_threads: Worker Threads {
      shape: rectangle
      style.fill: "#C8E6C9"
      c4_t1: "Thread 1\n625 conns"
      c4_t2: "Thread 2\n625 conns"
      c4_t3: "Thread 3\n625 conns"
      c4_t4: "Thread 4\n625 conns"
    }
  }
}
row_network: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  network: 10GbE Network Switch {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 800
    net_core: {
      direction: right
      label: ""
      ingress: Ingress Queue {
        shape: queue
        style.fill: "#FFE0B2"
        label: "Ingress\nQueue"
      }
      switching: Switch Fabric {
        shape: diamond
        style.fill: "#FFCC80"
        label: "Switch\nFabric"
      }
      egress: Egress Queue {
        shape: queue
        style.fill: "#FFE0B2"
        label: "Egress\nQueue"
      }
    }
  }
}
row_server: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  server: io_uring Echo Server {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 3
    width: 900
    server_core: {
      direction: right
      label: ""
      left_panel: {
        direction: down
        ring: io_uring Instance {
          shape: rectangle
          style.fill: "#BBDEFB"
          style.stroke: "#1976D2"
          sq: Submission Queue {
            shape: sql_table
            label: "SQ (size: 1024)"
            f1: "0x00 | head | uint32"
            f2: "0x04 | tail | uint32"
            f3: "0x08 | mask | uint32"
            f4: "0x0C | array | uint32[1024]"
            sz: "Ring mem: 4KB + 4KB"
          }
          cq: Completion Queue {
            shape: sql_table
            label: "CQ (size: 4096)"
            f1: "0x00 | head | uint32"
            f2: "0x04 | tail | uint32"
            f3: "0x08 | mask | uint32"
            f4: "0x0C | cqes | cqe[4096]"
            sz: "Ring mem: 64KB"
          }
        }
        conn_table: Connection Table {
          shape: sql_table
          label: "conn_table (hash map)"
          f1: "fd | int32"
          f2: "state | conn_state_t"
          f3: "recv_buf_id | uint16"
          f4: "bytes_rx | uint64"
          f5: "bytes_tx | uint64"
          f6: "n_in_flight | int32"
          sz: "16384 entries × 64B = 1MB"
        }
      }
      right_panel: {
        direction: down
        buf_ring: Provided Buffer Ring {
          shape: rectangle
          style.fill: "#BBDEFB"
          style.stroke: "#1976D2"
          buf_header: Buffer Ring Header {
            shape: sql_table
            label: "Buffer Ring (bgid=1)"
            f1: "0x00 | tail | uint16"
            f2: "0x02 | mask | uint16"
            f3: "0x04 | entries | uint16"
            sz: "2048 buffers"
          }
          buf_entries: Buffer Entries {
            shape: sql_table
            label: "io_uring_buf[2048]"
            f1: "0x00 | addr | uint64"
            f2: "0x08 | len | uint32"
            f3: "0x0C | bid | uint16"
            f4: "0x0E | resv | uint16"
            sz: "Entry size: 16B"
          }
        }
        buf_pool: Data Buffers {
          shape: rectangle
          style.fill: "#C8E6C9"
          style.stroke: "#4CAF50"
          buf_pool_table: {
            shape: sql_table
            label: "Buffer Pool"
            f1: "buf[0] | 8KB | @0x7f000000"
            f2: "buf[1] | 8KB | @0x7f002000"
            f3: "buf[2] | 8KB | @0x7f004000"
            f4: "... | ... | ..."
            f5: "buf[2047] | 8KB | @0x7f0FFE000"
            sz: "Total: 2048 × 8KB = 16MB"
          }
        }
      }
    }
  }
}
row_latency: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  latency_box: Latency Measurement Points {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    width: 900
    lat_points: {
      direction: right
      label: ""
      t1: T1 - Client Send {
        shape: circle
        style.fill: "#E1BEE7"
        label: "T1\nClient\nSend"
      }
      t2: T2 - Server Recv {
        shape: circle
        style.fill: "#CE93D8"
        label: "T2\nServer\nRecv"
      }
      t3: T3 - Server Send {
        shape: circle
        style.fill: "#BA68C8"
        label: "T3\nServer\nSend"
      }
      t4: T4 - Client Recv {
        shape: circle
        style.fill: "#AB47BC"
        label: "T4\nClient\nRecv"
      }
      lat_calc: Latency Calc {
        shape: rectangle
        style.fill: "#E1BEE7"
        calc_formula: {
          shape: sql_table
          label: "Latency Metrics"
          f1: "RTT = T4 - T1"
          f2: "Server = T3 - T2"
          f3: "Network = RTT - Server"
          sz: "Percentiles: p50, p95, p99"
        }
      }
    }
  }
}
row_flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  flow_box: Echo Benchmark Message Flow {
    shape: rectangle
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
    width: 900
    flow_steps: {
      direction: right
      label: ""
      step1: "1. CONNECT" {
        shape: step
        style.fill: "#FFF9C4"
      }
      step2: "2. SEND" {
        shape: step
        style.fill: "#FFF59D"
      }
      step3: "3. RECV\n(kernel picks\nbuf from ring)" {
        shape: step
        style.fill: "#FFEE58"
      }
      step4: "4. ECHO\n(zero-copy\nor copy)" {
        shape: step
        style.fill: "#FDD835"
      }
      step5: "5. RETURN\nbuf to ring" {
        shape: step
        style.fill: "#FFEB3B"
      }
      step6: "6. CLOSE" {
        shape: step
        style.fill: "#FBC02D"
      }
    }
  }
}
row_stats: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stats_box: Statistics Collection {
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    width: 900
    stats_inner: {
      direction: right
      label: ""
      stats_srv: Server Stats {
        shape: sql_table
        label: "server_stats"
        f1: "total_accepts | uint64"
        f2: "total_recvs | uint64"
        f3: "total_sends | uint64"
        f4: "bytes_rx | uint64"
        f5: "bytes_tx | uint64"
        f6: "buffers_available | uint32"
      }
      stats_lat: Latency Histogram {
        shape: sql_table
        label: "latency_hist"
        f1: "bucket[0] | 0-1us"
        f2: "bucket[1] | 1-2us"
        f3: "bucket[2] | 2-4us"
        f4: "... | ..."
        f5: "bucket[31] | 8-16s"
        sz: "Log2 buckets: 32"
      }
      stats_sys: System Stats {
        shape: sql_table
        label: "system_stats"
        f1: "cpu_usage | float"
        f2: "mem_usage | uint64"
        f3: "syscall_count | uint64"
        f4: "ctx_switches | uint64"
        f5: "cache_misses | uint64"
      }
    }
  }
}
client1 -> network.ingress: "2500 TCP\nconnections"
client2 -> network.ingress: "2500 TCP\nconnections"
client3 -> network.ingress: "2500 TCP\nconnections"
client4 -> network.ingress: "2500 TCP\nconnections"
network.egress -> server: "10,000\nconcurrent\nconnections" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
}
server -> latency_box.t2: "timestamp\nat recv"
server -> latency_box.t3: "timestamp\nat send"
client1 -> latency_box.t1: "T1"
latency_box.t4 -> client1: "T4"
flow_box -> stats_box: "feed metrics"
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: gray
  leg_title: Legend
  leg1: "Green = Client/Load Gen"
  leg2: "Blue = Server/io_uring"
  leg3: "Purple = Latency Points"
  leg4: "Yellow = Message Flow"
  leg5: "Gray = Statistics"
  leg1.style.fill: "#E8F5E9"
  leg2.style.fill: "#E3F2FD"
  leg3.style.fill: "#F3E5F5"
  leg4.style.fill: "#FFFDE7"
  leg5.style.fill: "#ECEFF1"
}