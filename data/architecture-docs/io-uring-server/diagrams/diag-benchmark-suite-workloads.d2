direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Benchmark Suite — Three Workload Profiles
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  file_io: {
    direction: down
    label: "File I/O Heavy (90/10)"
    file_desc: |md
      **Characteristics:**
      - 90% disk read/write ops
      - 10% network echo
      - Disk latency bound
      - Tests batching efficiency
    |
    file_iouring: {
      label: "io_uring Config"
      shape: class
      +ring_size: "4096"
      +batch_size: "64-256"
      +registered_files: "bool"
      +fixed_buffers: "bool"
      +sqpoll: "bool"
      +zero_copy: "false (disk)"
    }
    file_epoll: {
      label: "epoll Config"
      shape: class
      +max_events: "1024"
      +edge_trigger: "EPOLLET"
      +nonblocking: "O_NONBLOCK"
      +aio: "posix_aio fallback"
    }
    file_metrics: {
      label: "Measurements"
      shape: class
      +latency_p50: "nanoseconds"
      +latency_p95: "nanoseconds"
      +latency_p99: "nanoseconds"
      +throughput_ops: "ops/sec"
      +throughput_mb: "MB/sec"
      +syscall_count: "per 1000 ops"
    }
  }
  network_io: {
    direction: down
    label: "Network I/O Heavy (90/10)"
    net_desc: |md
      **Characteristics:**
      - 90% TCP send/recv
      - 10% config file reads
      - Network latency bound
      - Tests connection scaling
    |
    net_iouring: {
      label: "io_uring Config"
      shape: class
      +ring_size: "4096"
      +multishot_accept: "true"
      +provided_buffers: "buf_ring"
      +sqpoll: "bool"
      +zero_copy_send: "SEND_ZC"
    }
    net_epoll: {
      label: "epoll Config"
      shape: class
      +max_events: "1024"
      +epollet: "edge-triggered"
      +listen_backlog: "1024"
      +per_conn_buf: "pre-allocated"
    }
    net_metrics: {
      label: "Measurements"
      shape: class
      +latency_p50: "microseconds"
      +latency_p95: "microseconds"
      +latency_p99: "microseconds"
      +conn_per_sec: "connections/sec"
      +bytes_per_sec: "MB/sec"
      +syscall_count: "per 1000 ops"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mixed_io: {
    direction: down
    label: "Mixed Workload (50/50)"
    mixed_desc: |md
      **Characteristics:**
      - 50% file I/O operations
      - 50% network I/O operations
      - Tests resource contention
      - Realistic server profile
    |
    mixed_iouring: {
      label: "io_uring Config"
      shape: class
      +ring_size: "4096"
      +registered_files: "mixed types"
      +fixed_buffers: "shared pool"
      +sqpoll: "bool"
      +linked_ops: "write+fsync"
    }
    mixed_epoll: {
      label: "epoll Config"
      shape: class
      +max_events: "1024"
      +thread_pool: "file I/O"
      +event_loop: "network"
      +aio_integration: "libaio"
    }
    mixed_metrics: {
      label: "Measurements"
      shape: class
      +latency_p50: "mixed"
      +latency_p95: "mixed"
      +latency_p99: "mixed"
      +total_ops: "ops/sec"
      +syscall_ratio: "iouring/epoll"
      +cpu_util: "percent"
    }
  }
  measurement_detail: {
    direction: down
    label: "Measurement Methodology"
    meas_latency: {
      label: "Latency Collection"
      shape: class
      -clock_source: "CLOCK_MONOTONIC"
      -precision: "nanoseconds"
      -sample_count: "10000+ per config"
      -histogram_buckets: "32 (log2)"
    }
    meas_syscall: {
      label: "Syscall Counting"
      shape: class
      -method: "perf_event_open"
      -events: "syscalls:sys_enter_*"
      -alt_method: "/proc/pid/stat"
      -normalize: "per 1000 ops"
    }
    meas_env: {
      label: "Test Environment"
      shape: class
      -kernel: "6.0+ required"
      -storage: "NVMe SSD"
      -network: "10GbE loopback"
      -iterations: "3, averaged"
    }
  }
}
legend: {
  near: bottom-center
  label: "Legend"
  shape: rectangle
  style.stroke-dash: 3
  legend_content: {
    direction: right
    l1: "io_uring" {style.fill: "#E8F5E9"}
    l2: "epoll" {style.fill: "#E3F2FD"}
    l3: "metrics" {style.fill: "#FFF3E0"}
  }
}
file_iouring.style.fill: "#E8F5E9"
file_epoll.style.fill: "#E3F2FD"
file_metrics.style.fill: "#FFF3E0"
net_iouring.style.fill: "#E8F5E9"
net_epoll.style.fill: "#E3F2FD"
net_metrics.style.fill: "#FFF3E0"
mixed_iouring.style.fill: "#E8F5E9"
mixed_epoll.style.fill: "#E3F2FD"
mixed_metrics.style.fill: "#FFF3E0"
meas_latency.style.fill: "#F3E5F5"
meas_syscall.style.fill: "#F3E5F5"
meas_env.style.fill: "#F3E5F5"