direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Provided Buffer Ring Replenishment Under Load {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  initial: {
    direction: down
    label: "T0: Initial State"
    ring0: {
      shape: sql_table
      label: "Buffer Ring (bgid=1)"
      f0: "0x00 | buf[0]  | 8KB | available"
      f1: "0x08 | buf[1]  | 8KB | available"
      f2: "0x10 | buf[2]  | 8KB | available"
      f3: "0x18 | ...     | ...  | ..."
      f4: "0x1F8 | buf[63] | 8KB | available"
      sz: "64/64 buffers (100%)"
    }
    stats0: {
      label: "Pool Stats"
      shape: rectangle
      available0: "available: 64"
      threshold0: "threshold: 16 (25%)"
      status0: "status: HEALTHY"
    }
    stats0.style.fill: "#d4edda"
    stats0.style.stroke: "#28a745"
    ring0 -> stats0: "monitor"
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  burst: {
    direction: down
    label: "T1: Connection Burst (50 arrivals)"
    conn_burst: {
      shape: rectangle
      label: "50 New Connections"
      style.fill: "#fff3cd"
      style.stroke: "#856404"
    }
    ring1: {
      shape: sql_table
      label: "Buffer Ring (depleting)"
      g0: "0x00 | buf[0]  | IN_USE | conn_1"
      g1: "0x08 | buf[1]  | IN_USE | conn_2"
      g2: "0x10 | ...     | IN_USE | ..."
      g3: "0x18 | buf[49] | IN_USE | conn_50"
      g4: "0x20 | buf[50] | available"
      g5: "0x28 | ...     | available"
      g6: "0x1F8 | buf[63] | available"
      sz: "14/64 buffers (21.8%)"
    }
    ring1.style.fill: "#f8d7da"
    ring1.style.stroke: "#dc3545"
    conn_burst -> ring1: "RECV with\nBUFFER_SELECT"
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  threshold_hit: {
    direction: down
    label: "T2: Threshold Crossing"
    alert: {
      shape: diamond
      label: "14 < 16\nTHRESHOLD!"
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
    }
    stats1: {
      label: "Pool Stats"
      shape: rectangle
      available1: "available: 14"
      threshold1: "threshold: 16 (25%)"
      status1: "status: LOW - REPLENISH"
    }
    stats1.style.fill: "#f8d7da"
    stats1.style.stroke: "#dc3545"
    alert -> stats1: "check"
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  replenish: {
    direction: down
    label: "T3: Replenishment Posted"
    app: {
      shape: rectangle
      label: "Application"
      code: |'c
        // Return processed buffers
        for (int i = 0; i < 48; i++) {
          io_uring_buf_ring_add(
            ring, buffers[i], 
            8192, i, 0, 0);
        }
        io_uring_buf_ring_advance(ring, 48);
      '|
      width: 320
    }
    app.style.fill: "#e2e3e5"
    app.style.stroke: "#383d41"
    ring2: {
      shape: sql_table
      label: "Buffer Ring (replenished)"
      h0: "0x00 | buf[0]  | 8KB | available"
      h1: "0x08 | buf[1]  | 8KB | available"
      h2: "0x10 | ...     | ...  | ..."
      h3: "0x18 | buf[47] | 8KB | available"
      h4: "0x20 | buf[48] | IN_USE | conn_49"
      h5: "0x28 | buf[49] | IN_USE | conn_50"
      sz: "62/64 buffers (96.8%)"
    }
    ring2.style.fill: "#d4edda"
    ring2.style.stroke: "#28a745"
    app -> ring2: "buf_ring_add()\nx 48"
  }
}
row5: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  enobufs: {
    direction: down
    label: "FAILURE PATH: Delayed Replenishment"
    style.stroke-dash: 4
    style.stroke: "#dc3545"
    ring_empty: {
      shape: sql_table
      label: "Buffer Ring (exhausted)"
      e0: "0x00 | buf[0]  | IN_USE | conn_1"
      e1: "0x08 | ...     | IN_USE | ..."
      e2: "0x1F8 | buf[63] | IN_USE | conn_64"
      sz: "0/64 buffers (0%)"
    }
    ring_empty.style.fill: "#f8d7da"
    ring_empty.style.stroke: "#dc3545"
    cqe_error: {
      shape: rectangle
      label: "CQE Result"
      code: |'c
        cqe->res = -ENOBUFS (105)
        // No buffer available for RECV
        // Connection stalls or drops
      '|
      width: 280
    }
    cqe_error.style.fill: "#f8d7da"
    cqe_error.style.stroke: "#dc3545"
    new_conn: {
      shape: rectangle
      label: "conn_65 RECV"
      style.fill: "#fff3cd"
      style.stroke: "#856404"
    }
    new_conn -> ring_empty: "BUFFER_SELECT\nfails" {
      style.stroke: "#dc3545"
      style.stroke-dash: 4
    }
    ring_empty -> cqe_error: "CQE" {
      style.stroke: "#dc3545"
      style.stroke-dash: 4
    }
  }
}
initial.ring0 -> burst.conn_burst: "50 connections\narrive" {
  style.stroke: "#856404"
  style.stroke-width: 2
}
burst.ring1 -> threshold_hit.alert: "available < threshold" {
  style.stroke: "#dc3545"
  style.stroke-dash: 4
}
threshold_hit.stats1 -> replenish.app: "trigger\nreplenish" {
  style.stroke: "#28a745"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  label: "Color Legend"
  shape: rectangle
  style.fill: white
  style.stroke: "#6c757d"
  green: "GREEN = Healthy pool (>25%)"
  yellow: "YELLOW = Connection activity"
  red: "RED = Threshold breach / ENOBUFS"
}
legend.style.fill-pattern: dots
legend_green: {
  near: bottom-left
  shape: rectangle
  width: 20
  height: 20
  style.fill: "#d4edda"
}
legend_yellow: {
  near: bottom-left
  shape: rectangle
  width: 20
  height: 20
  style.fill: "#fff3cd"
}
legend_red: {
  near: bottom-left
  shape: rectangle
  width: 20
  height: 20
  style.fill: "#f8d7da"
}