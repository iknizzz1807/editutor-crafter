direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Direct I/O Alignment Requirements"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  misaligned: {
    direction: down
    label: "MISALIGNED — Returns EINVAL"
    misaligned_scenario: {
      width: 400
      label: "Misaligned Request"
      code: |'c
        // BAD: Unaligned buffer, offset, size
        char *buf = malloc(4096);      // 0x55a1... (NOT aligned)
        off_t offset = 100;            // NOT block-aligned
        size_t len = 4000;             // NOT multiple of 512
        int fd = open("file.dat", O_RDONLY | O_DIRECT);
        read(fd, buf, len);  // Returns -1, errno = EINVAL
      '|
    }
    err_result: {
      shape: diamond
      label: "EINVAL\nInvalid Argument"
      style: {
        fill: "#FFB4AB"
        stroke: "#BA1A1A"
        font-color: "#BA1A1A"
      }
    }
    misaligned_scenario -> err_result: "read() fails"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  aligned: {
    direction: down
    label: "ALIGNED — Success"
    aligned_scenario: {
      width: 400
      label: "Aligned Request"
      code: |'c
        // GOOD: All aligned correctly
        void *buf;
        posix_memalign(&buf, 4096, 4096);  // 4KB aligned
        off_t offset = 4096;               // Block-aligned
        size_t len = 4096;                 // Multiple of block
        int fd = open("file.dat", O_RDONLY | O_DIRECT);
        read(fd, buf, len);  // Returns 4096 bytes
      '|
    }
    success_result: {
      shape: oval
      label: "Success\n4096 bytes read"
      style: {
        fill: "#B8F397"
        stroke: "#2D6A1F"
        font-color: "#2D6A1F"
      }
    }
    aligned_scenario -> success_result: "DMA direct to buffer"
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  alignment_rules: {
    direction: down
    label: "Alignment Rules"
    rule_buffer: {
      shape: sql_table
      label: "Buffer Address Alignment"
      r1: "Storage Type | Required Alignment"
      r2: "HDD (512B sector) | 512 bytes"
      r3: "SSD (4KB physical) | 4096 bytes"
      r4: "NVMe | 4096 bytes (check queue)"
      r5: "Safe default | 4096 bytes (page)"
    }
    rule_size: {
      shape: sql_table
      label: "Size & Offset Alignment"
      r1: "Parameter | Requirement"
      r2: "Buffer length | Multiple of block size"
      r3: "File offset | Multiple of block size"
      r4: "I/O boundary | Must not cross boundary"
      r5: "Check via | /sys/block/.../logical_block_size"
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  memory_layout: {
    direction: down
    label: "Memory Layout Visualization"
    mem_diagram: {
      direction: right
      address_space: {
        direction: down
        label: "Virtual Address Space"
        addr_0: {
          label: "0x0000"
          width: 60
          height: 30
          style.fill: transparent
        }
        addr_1000: {
          label: "0x1000 (4KB)"
          width: 60
          height: 30
          style.fill: transparent
        }
        addr_2000: {
          label: "0x2000 (8KB)"
          width: 60
          height: 30
          style.fill: transparent
        }
        addr_3000: {
          label: "0x3000 (12KB)"
          width: 60
          height: 30
          style.fill: transparent
        }
        addr_4000: {
          label: "0x4000 (16KB)"
          width: 60
          height: 30
          style.fill: transparent
        }
      }
      pages: {
        direction: down
        label: "Page Boundaries"
        page0: {
          label: "Page 0"
          width: 200
          height: 60
          style: {
            fill: "#E8E8E8"
            stroke: "#666666"
          }
        }
        page1: {
          label: "Page 1"
          width: 200
          height: 60
          style: {
            fill: "#E8E8E8"
            stroke: "#666666"
          }
        }
        page2: {
          label: "Page 2"
          width: 200
          height: 60
          style: {
            fill: "#E8E8E8"
            stroke: "#666666"
          }
        }
      }
      examples: {
        direction: down
        label: "Buffer Examples"
        good_buf: {
          label: "✓ Aligned Buffer"
          width: 200
          height: 60
          style: {
            fill: "#B8F397"
            stroke: "#2D6A1F"
          }
        }
        bad_buf: {
          label: "✗ Misaligned"
          width: 150
          height: 60
          style: {
            fill: "#FFB4AB"
            stroke: "#BA1A1A"
          }
        }
        note: {
          label: "0x1234 (not page-aligned)"
          shape: text
          style.font-size: 12
        }
      }
      address_space.addr_1000 -> pages.page0: ""
      pages.page0 -> examples.good_buf: "posix_memalign(&buf, 4096, 4096)"
    }
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  alignment_check: {
    direction: down
    label: "Runtime Alignment Check"
    check_code: {
      width: 450
      code: |'c
        // Check alignment at runtime
        int get_dio_alignment(int fd) {
            int block_size = 0;
            // Query block device sector size
            if (ioctl(fd, BLKSSZGET, &block_size) < 0) {
                block_size = 4096;  // Safe fallback
            }
            return block_size;
        }
        // Verify alignment before O_DIRECT
        bool is_aligned(void *buf, size_t len, off_t off, int blk) {
            return ((uintptr_t)buf % blk == 0) &&
                   (len % blk == 0) && (off % blk == 0);
        }
      '|
    }
  }
}
row1 -> row2: ""
row2 -> row3: ""
row3 -> row4: ""
row4 -> row5: ""