direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # File I/O Benchmark: io_uring vs pread
  **Throughput comparison across concurrency levels**
| {near: top-center}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  chart_container: {
    label: "Throughput vs Concurrency (4KB reads, NVMe SSD)"
    # Y-axis
    y_axis: {
      label: "Throughput (MB/s)"
      shape: rectangle
      width: 30
      height: 400
      style.fill: transparent
      style.stroke: transparent
    }
    # Chart area with grid
    chart_area: {
      label: ""
      shape: rectangle
      width: 500
      height: 400
      style.fill: "#FAFAFA"
      style.stroke: "#E0E0E0"
      # Grid lines (horizontal)
      grid_3000: {label: ""; shape: rectangle; width: 480; height: 1; style.fill: "#E8E8E8"; style.stroke: transparent}
      grid_2250: {label: ""; shape: rectangle; width: 480; height: 1; style.fill: "#E8E8E8"; style.stroke: transparent}
      grid_1500: {label: ""; shape: rectangle; width: 480; height: 1; style.fill: "#E8E8E8"; style.stroke: transparent}
      grid_750: {label: ""; shape: rectangle; width: 480; height: 1; style.fill: "#E8E8E8"; style.stroke: transparent}
      # Data points - synchronous pread (red)
      pread_1: {shape: circle; width: 16; style.fill: "#E53935"; style.stroke: "#B71C1C"}
      pread_4: {shape: circle; width: 16; style.fill: "#E53935"; style.stroke: "#B71C1C"}
      pread_16: {shape: circle; width: 16; style.fill: "#E53935"; style.stroke: "#B71C1C"}
      pread_64: {shape: circle; width: 16; style.fill: "#E53935"; style.stroke: "#B71C1C"}
      # Data points - io_uring regular (blue)
      regular_1: {shape: circle; width: 16; style.fill: "#1E88E5"; style.stroke: "#0D47A1"}
      regular_4: {shape: circle; width: 16; style.fill: "#1E88E5"; style.stroke: "#0D47A1"}
      regular_16: {shape: circle; width: 16; style.fill: "#1E88E5"; style.stroke: "#0D47A1"}
      regular_64: {shape: circle; width: 16; style.fill: "#1E88E5"; style.stroke: "#0D47A1"}
      # Data points - io_uring fixed (green)
      fixed_1: {shape: circle; width: 16; style.fill: "#43A047"; style.stroke: "#1B5E20"}
      fixed_4: {shape: circle; width: 16; style.fill: "#43A047"; style.stroke: "#1B5E20"}
      fixed_16: {shape: circle; width: 16; style.fill: "#43A047"; style.stroke: "#1B5E20"}
      fixed_64: {shape: circle; width: 16; style.fill: "#43A047"; style.stroke: "#1B5E20"}
      # Crossover annotation
      crossover_box: {
        label: "Crossover Point\nBatching advantage >\nregistration overhead"
        shape: rectangle
        width: 120
        height: 50
        style.fill: "#FFF9C4"
        style.stroke: "#FBC02D"
        style.stroke-dash: 3
      }
    }
    # X-axis
    x_axis: {
      label: "Concurrency (in-flight operations)"
      shape: rectangle
      width: 500
      height: 40
      style.fill: transparent
      style.stroke: transparent
    }
  }
  # Legend and syscall annotations
  sidebar: {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    legend: {
      label: "Legend"
      shape: rectangle
      style.fill: "#F5F5F5"
      style.stroke: "#BDBDBD"
      width: 220
      leg_pread: {
        label: "● Synchronous pread"
        shape: rectangle
        width: 180
        style.fill: transparent
        style.stroke: transparent
        style.font-color: "#E53935"
      }
      leg_regular: {
        label: "● io_uring (regular buffers)"
        shape: rectangle
        width: 180
        style.fill: transparent
        style.stroke: transparent
        style.font-color: "#1E88E5"
      }
      leg_fixed: {
        label: "● io_uring (fixed buffers)"
        shape: rectangle
        width: 180
        style.fill: transparent
        style.stroke: transparent
        style.font-color: "#43A047"
      }
    }
    syscall_table: {
      shape: sql_table
      label: "Syscalls per 1000 operations"
      col1: "Method"
      col2: "1"
      col3: "4"
      col4: "16"
      col5: "64"
      row_pread: "pread | 1000 | 1000 | 1000 | 1000"
      row_regular: "io_uring reg | 1000 | 250 | 63 | 16"
      row_fixed: "io_uring fixed | 1000 | 250 | 63 | 16"
      note: "98.4% reduction at batch=64"
    }
    key_insight: {
      label: |md
        **Key Insight:**
        At concurrency=1, all methods perform
        similarly (syscall per op).
        At concurrency≥4, io_uring batching
        dominates. Fixed buffers add ~10%
        by eliminating per-op validation.
      |
      shape: rectangle
      width: 220
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      style.border-radius: 8
    }
  }
}
# Data table for reference
data_table: {
  shape: sql_table
  label: "Raw Data (4KB reads, NVMe, cached)"
  r1: "Concurrency | pread (MB/s) | io_uring reg | io_uring fixed"
  r2: "1 | 180 | 190 | 195"
  r3: "4 | 520 | 890 | 980"
  r4: "16 | 680 | 1850 | 2100"
  r5: "64 | 720 | 2650 | 2980"
  r6: "Speedup at 64 | 1.0x | 3.7x | 4.1x"
}
# Performance breakdown
perf_breakdown: {
  direction: right
  label: "Per-Operation Overhead Breakdown"
  pread_box: {
    label: "pread()"
    shape: rectangle
    width: 200
    style.fill: "#FFEBEE"
    style.stroke: "#E53935"
    p1: {label: "syscall entry: ~50ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    p2: {label: "fd lookup: ~30ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    p3: {label: "buffer validate: ~50ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    p4: {label: "VFS read: varies"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    p5: {label: "syscall exit: ~50ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    p_total: {label: "Total: ~180ns + I/O"; shape: rectangle; style.fill: "#FFCDD2"; style.stroke: transparent; style.bold: true}
  }
  iouring_box: {
    label: "io_uring (fixed)"
    shape: rectangle
    width: 200
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
    i1: {label: "SQE prepare: ~20ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    i2: {label: "index lookup: ~5ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    i3: {label: "(no validation)"; shape: rectangle; style.fill: transparent; style.stroke: transparent; style.italic: true}
    i4: {label: "VFS read: varies"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    i5: {label: "CQE harvest: ~10ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    i_total: {label: "Total: ~35ns + I/O"; shape: rectangle; style.fill: "#C8E6C9"; style.stroke: transparent; style.bold: true}
  }
  savings_box: {
    label: "Savings"
    shape: rectangle
    width: 150
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    s1: {label: "Per op: ~145ns"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    s2: {label: "At 100K ops/s:"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    s3: {label: "14.5ms saved/s"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
    s4: {label: "= 1.5% CPU"; shape: rectangle; style.fill: transparent; style.stroke: transparent}
  }
}
# Notes section
notes: {
  label: "Benchmark Notes"
  shape: rectangle
  width: 700
  style.fill: "#F5F5F5"
  style.stroke: "#BDBDBD"
  style.border-radius: 4
  note_content: |md
    • **Test conditions:** Linux 6.1, NVMe SSD (Samsung 980 Pro), ext4, direct I/O
    • **Syscall measurement:** `perf stat -e syscalls:sys_enter_io_uring_enter,syscalls:sys_enter_pread64`
    • **Crossover point:** Concurrency ≈ 2-3 is where io_uring overhead amortization exceeds pread
    • **Fixed buffer registration:** One-time cost of ~50μs for 256 buffers, negligible for long-running servers
    • **Cache effects:** At high concurrency, L3 cache pressure affects all methods similarly
  |
}