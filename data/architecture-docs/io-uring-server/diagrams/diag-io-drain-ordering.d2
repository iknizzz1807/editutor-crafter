direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # IO_DRAIN Ordering Guarantee
  **Serialization forces sequential completion before drain target**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  without_drain: {
    direction: down
    label: "Without DRAIN"
    sq_panel: {
      direction: right
      label: "Submission Queue"
      sqe1: {
        label: "SQE 1\nWRITE"
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      sqe2: {
        label: "SQE 2\nWRITE"
        shape: rectangle
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
      }
      sqe3: {
        label: "SQE 3\nCLOSE"
        shape: rectangle
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
      }
    }
    arrow1: {
      shape: text
      label: "↓"
      style.font-size: 24
    }
    cq_panel: {
      direction: right
      label: "Completion Queue (Parallel Execution)"
      cqe3: {
        label: "CQE 3\nres=0"
        shape: rectangle
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
      }
      cqe1: {
        label: "CQE 1\nres=4096"
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      cqe2: {
        label: "CQE 2\nres=4096"
        shape: rectangle
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
      }
    }
    note_parallel: {
      label: "Completions arrive in ANY order\nKernel processes in parallel"
      shape: text
      style.font-color: "#666"
      style.italic: true
    }
    timeline_parallel: {
      direction: right
      label: "Timeline (parallel)"
      t0: {
        label: "T0"
        shape: circle
        style.fill: "#ECEFF1"
      }
      t1: {
        label: "T1"
        shape: circle
        style.fill: "#ECEFF1"
      }
      t2: {
        label: "T2"
        shape: circle
        style.fill: "#ECEFF1"
      }
      t3: {
        label: "T3"
        shape: circle
        style.fill: "#ECEFF1"
      }
      t0 -> t1: "SQE 3 done"
      t1 -> t2: "SQE 1 done"
      t2 -> t3: "SQE 2 done"
    }
  }
  with_drain: {
    direction: down
    label: "With DRAIN on SQE 3"
    sq_panel_drain: {
      direction: right
      label: "Submission Queue"
      sqe1d: {
        label: "SQE 1\nWRITE"
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      sqe2d: {
        label: "SQE 2\nWRITE"
        shape: rectangle
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
      }
      sqe3d: {
        label: "SQE 3\nCLOSE\nDRAIN"
        shape: rectangle
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        style.bold: true
      }
    }
    arrow2: {
      shape: text
      label: "↓"
      style.font-size: 24
    }
    barrier: {
      label: "🚧 BARRIER 🚧\nAll prior ops MUST complete"
      shape: diamond
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.stroke-width: 3
    }
    cq_panel_drain: {
      direction: right
      label: "Completion Queue (Serialized)"
      cqe1d: {
        label: "CQE 1\nres=4096"
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      cqe2d: {
        label: "CQE 2\nres=4096"
        shape: rectangle
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
      }
      cqe3d: {
        label: "CQE 3\nres=0"
        shape: rectangle
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
      }
    }
    note_serial: {
      label: "Completions arrive in ORDER\nSQE 3 waits for 1,2"
      shape: text
      style.font-color: "#666"
      style.italic: true
    }
    timeline_serial: {
      direction: right
      label: "Timeline (serialized)"
      ts0: {
        label: "T0"
        shape: circle
        style.fill: "#ECEFF1"
      }
      ts1: {
        label: "T1"
        shape: circle
        style.fill: "#ECEFF1"
      }
      ts2: {
        label: "T2"
        shape: circle
        style.fill: "#ECEFF1"
      }
      ts3: {
        label: "T3"
        shape: circle
        style.fill: "#ECEFF1"
      }
      ts0 -> ts1: "SQE 1 only"
      ts1 -> ts2: "SQE 2 only"
      ts2 -> ts3: "SQE 3 now"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  throughput_comparison: {
    direction: down
    label: "Throughput Impact"
    metrics: {
      shape: sql_table
      label: "Performance Metrics (1000 ops)"
      m1: "Mode       | Latency/op | Throughput | Parallelism"
      m2: "No DRAIN   | ~150 ns    | 6.5M ops/s | Full (3x)"
      m3: "With DRAIN | ~500 ns    | 2.0M ops/s | Serialized"
      m4: "Overhead   | 3.3x slower| 3.3x less  | Blocked"
    }
    insight: {
      label: "Key Insight"
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
      code: |'c
        // DRAIN creates a serialization point
        // All prior SQEs complete BEFORE drain target starts
        // Use ONLY when ordering is semantically required
        sqe->flags |= IOSQE_IO_DRAIN;  // Force barrier
      '|
    }
  }
  use_cases: {
    direction: down
    label: "When DRAIN Is Necessary"
    case1: {
      label: "Log Rotation"
      shape: rectangle
      style.fill: "#E8F5E9"
      code1: |'c
        // All writes MUST complete before close
        for (i = 0; i < n_writes; i++) {
          prep_write(sqe[i], log_fd, ...);
        }
        prep_close(sqe[n], log_fd);
        sqe[n]->flags |= IOSQE_IO_DRAIN;
      '|
    }
    case2: {
      label: "Atomic Replace"
      shape: rectangle
      style.fill: "#E3F2FD"
      code2: |'c
        // Write new content, then rename atomically
        prep_write(sqe[0], fd, new_data, ...);
        sqe[0]->flags |= IOSQE_IO_LINK;
        prep_rename(sqe[1], oldpath, newpath);
        sqe[1]->flags |= IOSQE_IO_DRAIN;
      '|
    }
    case3: {
      label: "Shutdown Sequence"
      shape: rectangle
      style.fill: "#FFF3E0"
      code3: |'c
        // Drain all pending I/O before exit
        prep_nop(sqe);  // Marker
        sqe->flags |= IOSQE_IO_DRAIN;
        // Wait for this CQE = all prior ops done
      '|
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  label: "Legend"
  l1: {
    label: "Normal SQE"
    shape: rectangle
    style.fill: "#E8F5E9"
  }
  l2: {
    label: "DRAIN SQE"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
  l3: {
    label: "Barrier"
    shape: diamond
    style.fill: "#FFCDD2"
  }
}