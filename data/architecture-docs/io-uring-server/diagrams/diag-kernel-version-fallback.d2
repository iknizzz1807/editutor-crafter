fallback_code: "" {
  direction: down
  fb_title: "Feature Detection Code Pattern (io_uring_setup.c)" {
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    style.bold: true
  }
  fb_code: {
    label: "Runtime Feature Detection"
    width: 600
    code: |'c
      struct io_uring_features {
          bool sqpoll;
          bool zero_copy_send;
          bool provided_buffers;
          int kernel_major;
          int kernel_minor;
      };
      int detect_features(struct io_uring_features *feat) {
          struct utsname uts;
          uname(&uts);
          sscanf(uts.release, "%d.%d", 
                 &feat->kernel_major, &feat->kernel_minor);
          // Test SQPOLL (requires CAP_SYS_NICE)
          struct io_uring ring;
          struct io_uring_params p = { .flags = IORING_SETUP_SQPOLL };
          int ret = io_uring_queue_init_params(16, &ring, &p);
          feat->sqpoll = (ret == 0);
          if (ret == 0) io_uring_queue_exit(&ring);
          // Version-based feature detection
          feat->provided_buffers = (feat->kernel_major > 5 || 
              (feat->kernel_major == 5 && feat->kernel_minor >= 19));
          feat->zero_copy_send = (feat->kernel_major >= 6);
          return 0;
      }
    '|
  }
}
error_handling: "" {
  direction: down
  err_title: "Graceful Error Handling (fallback.c)" {
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    style.bold: true
  }
  err_code: {
    label: "Fallback Wrapper Pattern"
    width: 600
    code: |'c
      int safe_send_zc(struct io_uring *ring, int fd, 
                       void *buf, size_t len, bool *used_zc) {
          struct io_uring_sqe *sqe = io_uring_get_sqe(ring);
          if (!sqe) return -EBUSY;
          if (features.zero_copy_send && registered_buffers) {
              io_uring_prep_send_zc(sqe, fd, buf, len, 0, 0);
              *used_zc = true;
          } else {
              // Fallback to standard send
              io_uring_prep_send(sqe, fd, buf, len, 0);
              *used_zc = false;
          }
          return 0;
      }
      // SQPOLL fallback
      int init_ring(struct io_uring *ring, int size, bool want_sqpoll) {
          struct io_uring_params params = {0};
          if (want_sqpoll) {
              params.flags = IORING_SETUP_SQPOLL;
              params.sq_thread_idle = 100;
          }
          int ret = io_uring_queue_init_params(size, ring, &params);
          if (ret == -EPERM && want_sqpoll) {
              // Missing CAP_SYS_NICE - retry without SQPOLL
              memset(&params, 0, sizeof(params));
              ret = io_uring_queue_init_params(size, ring, &params);
              log_info("SQPOLL unavailable, using standard submit");
          }
          return ret;
      }
    '|
  }
}
