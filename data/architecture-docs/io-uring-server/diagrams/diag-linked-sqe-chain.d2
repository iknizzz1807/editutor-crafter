direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Linked SQE Chains — Atomic Multi-Step Operations" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  sqe_chain: {
    direction: right
    label: "SQE Chain in Submission Queue"
    sqe1: {
      label: "SQE[0]: READ"
      shape: class
      -opcode: "IORING_OP_READ"
      -fd: "file_fd"
      -off: "0x1000"
      -len: "4096"
      -buf: "buf[0]"
      -flags: "IOSQE_IO_LINK"
      -user_data: "0x0001"
    }
    sqe2: {
      label: "SQE[1]: PROCESS"
      shape: class
      -opcode: "IORING_OP_CUSTOM"
      -fd: "buf[0]"
      -off: "0"
      -len: "4096"
      -buf: "buf[1]"
      -flags: "IOSQE_IO_LINK"
      -user_data: "0x0002"
    }
    sqe3: {
      label: "SQE[2]: SEND"
      shape: class
      -opcode: "IORING_OP_SEND"
      -fd: "sock_fd"
      -off: "0"
      -len: "4096"
      -buf: "buf[1]"
      -flags: "0 (end of chain)"
      -user_data: "0x0003"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  link_arrows: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    link1: {
      label: "LINK"
      shape: rectangle
      style: {
        fill: "#4CAF50"
        stroke: "#2E7D32"
        font-color: white
        bold: true
      }
    }
    link2: {
      label: "LINK"
      shape: rectangle
      style: {
        fill: "#4CAF50"
        stroke: "#2E7D32"
        font-color: white
        bold: true
      }
    }
    no_link: {
      label: "NO LINK"
      shape: rectangle
      style: {
        fill: "#9E9E9E"
        stroke: "#616161"
        font-color: white
        bold: true
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  success_flow: {
    label: "SUCCESS PATH: All Operations Complete"
    direction: down
    success_title: {
      shape: rectangle
      label: "SUCCESS PATH"
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        font-color: "#1B5E20"
        bold: true
      }
    }
    cqe_success: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      cqe1s: {
        label: "CQE[0]"
        shape: class
        -user_data: "0x0001"
        -res: "4096"
        -flags: "0"
        style: {
          fill: "#C8E6C9"
        }
      }
      cqe2s: {
        label: "CQE[1]"
        shape: class
        -user_data: "0x0002"
        -res: "4096"
        -flags: "0"
        style: {
          fill: "#C8E6C9"
        }
      }
      cqe3s: {
        label: "CQE[2]"
        shape: class
        -user_data: "0x0003"
        -res: "4096"
        -flags: "0"
        style: {
          fill: "#C8E6C9"
        }
      }
    }
    success_note: {
      label: "All 3 CQEs show res > 0 → Chain executed atomically"
      shape: rectangle
      style: {
        fill: transparent
        stroke: transparent
        font-color: "#1B5E20"
        italic: true
      }
    }
  }
  failure_flow: {
    label: "FAILURE PATH: Step 2 Fails → Auto-Cancel"
    direction: down
    fail_title: {
      shape: rectangle
      label: "FAILURE PATH"
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
        font-color: "#B71C1C"
        bold: true
      }
    }
    cqe_failure: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      cqe1f: {
        label: "CQE[0]"
        shape: class
        -user_data: "0x0001"
        -res: "4096"
        -flags: "0"
        style: {
          fill: "#C8E6C9"
        }
      }
      cqe2f: {
        label: "CQE[1]"
        shape: class
        -user_data: "0x0002"
        -res: "-EINVAL"
        -flags: "0"
        style: {
          fill: "#FFCDD2"
        }
      }
      cqe3f: {
        label: "CQE[2]"
        shape: class
        -user_data: "0x0003"
        -res: "-ECANCELED"
        -flags: "0"
        style: {
          fill: "#FFE0B2"
        }
      }
    }
    fail_note: {
      label: "Step 2 fails → Step 3 auto-cancelled with -ECANCELED"
      shape: rectangle
      style: {
        fill: transparent
        stroke: transparent
        font-color: "#B71C1C"
        italic: true
      }
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  state_machine: {
    label: "Chain State Machine"
    direction: down
    state_init: {
      label: "CHAIN_SUBMITTED"
      shape: oval
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
    }
    state_exec1: {
      label: "EXECUTING_STEP_1"
      shape: oval
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
    }
    state_exec2: {
      label: "EXECUTING_STEP_2"
      shape: oval
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
    }
    state_exec3: {
      label: "EXECUTING_STEP_3"
      shape: oval
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
    }
    state_done: {
      label: "CHAIN_COMPLETE"
      shape: oval
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
      }
    }
    state_fail: {
      label: "CHAIN_FAILED\n(remainder cancelled)"
      shape: diamond
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
      }
    }
  }
  transition_logic: {
    label: "Transition Logic"
    direction: down
    trans1: {
      label: "Step N succeeds?"
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
      }
    }
    trans_yes: {
      label: "YES → Execute Step N+1"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
      }
    }
    trans_no: {
      label: "NO → Cancel all remaining\nPost CQE with -ECANCELED"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
      }
    }
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  direction: down
  leg_link: {
    label: "IOSQE_IO_LINK"
    shape: rectangle
    style: {
      fill: "#4CAF50"
      font-color: white
    }
  }
  leg_success: {
    label: "Success (res > 0)"
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  leg_fail: {
    label: "Failure (res < 0)"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
  }
  leg_cancel: {
    label: "Cancelled (-ECANCELED)"
    shape: rectangle
    style: {
      fill: "#FFE0B2"
      stroke: "#FF9800"
    }
  }
}
sqe_chain.sqe1 -> sqe_chain.sqe2
sqe_chain.sqe2 -> sqe_chain.sqe3
state_machine.state_init -> state_machine.state_exec1: "kernel\nstarts"
state_machine.state_exec1 -> state_machine.state_exec2: "step 1 OK"
state_machine.state_exec2 -> state_machine.state_exec3: "step 2 OK"
state_machine.state_exec3 -> state_machine.state_done: "step 3 OK"
state_machine.state_exec1 -> state_machine.state_fail: "step 1 fail" {
  style.stroke-dash: 4
}
state_machine.state_exec2 -> state_machine.state_fail: "step 2 fail" {
  style.stroke-dash: 4
}
state_machine.state_exec3 -> state_machine.state_fail: "step 3 fail" {
  style.stroke-dash: 4
}
transition_logic.trans1 -> transition_logic.trans_yes: "YES"
transition_logic.trans1 -> transition_logic.trans_no: "NO"