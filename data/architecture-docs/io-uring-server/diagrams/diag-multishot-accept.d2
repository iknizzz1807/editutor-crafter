direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Multishot Accept — Single SQE, Multiple CQEs" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_compare: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  before: "BEFORE: Single-Shot Accept Loop" {
    direction: down
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 3
    loop_header: "Event Loop (one syscall per batch)" {
      shape: rectangle
      style.fill: "#4a3030"
      style.stroke: "#ff6b6b"
    }
    sqe_flow: {
      direction: down
      label: "SQE Submission"
      sqe1: "SQE[0]: accept(fd)" {
        shape: rectangle
        style.fill: "#ff6b6b"
        style.font-color: white
      }
      sqe2: "SQE[1]: accept(fd)" {
        shape: rectangle
        style.fill: "#ff6b6b"
        style.font-color: white
      }
      sqe3: "SQE[n]: accept(fd)" {
        shape: rectangle
        style.fill: "#ff6b6b"
        style.font-color: white
        style.multiple: true
      }
      sqe1 -> sqe2 -> sqe3
    }
    syscall1: "io_uring_enter(to_submit=N)" {
      shape: rectangle
      style.fill: "#8b4513"
      style.font-color: white
      width: 200
    }
    cqe_flow: {
      direction: down
      label: "CQE Harvest"
      cqe1: "CQE[0]: fd=5 ✓" {
        shape: rectangle
        style.fill: "#90EE90"
      }
      cqe2: "CQE[1]: fd=6 ✓" {
        shape: rectangle
        style.fill: "#90EE90"
      }
      cqe3: "CQE[n]: fd=N ✓" {
        shape: rectangle
        style.fill: "#90EE90"
        style.multiple: true
      }
      cqe1 -> cqe2 -> cqe3
    }
    resubmit: "Resubmit N new accept SQEs" {
      shape: rectangle
      style.fill: "#FFD700"
      style.stroke: "#8b4513"
      style.stroke-width: 2
    }
    back_arrow: {
      shape: rectangle
      width: 10
      height: 10
      style.fill: transparent
      style.stroke: transparent
    }
    sqe_flow -> syscall1 -> cqe_flow -> resubmit
    resubmit -> sqe_flow: "loop" {
      style.stroke-dash: 4
      style.animated: true
    }
  }
  after: "AFTER: Multishot Accept" {
    direction: down
    style.fill: "#1f2d1f"
    style.stroke: "#4ade80"
    style.stroke-width: 3
    setup_header: "Setup (ONE time)" {
      shape: rectangle
      style.fill: "#304a30"
      style.stroke: "#4ade80"
    }
    single_sqe: "SQE: accept(fd)\nflags: IORING_ACCEPT_MULTISHOT" {
      shape: rectangle
      style.fill: "#4ade80"
      style.font-color: black
      width: 220
    }
    syscall_once: "io_uring_enter(to_submit=1)" {
      shape: rectangle
      style.fill: "#228B22"
      style.font-color: white
      width: 200
    }
    cqe_stream: {
      direction: down
      label: "CQE Stream (kernel auto-resubmits)"
      mcqe1: "CQE: fd=5, F_MORE=1 ✓" {
        shape: rectangle
        style.fill: "#90EE90"
        width: 180
      }
      mcqe2: "CQE: fd=6, F_MORE=1 ✓" {
        shape: rectangle
        style.fill: "#90EE90"
        width: 180
      }
      mcqe3: "CQE: fd=N, F_MORE=1 ✓" {
        shape: rectangle
        style.fill: "#90EE90"
        style.multiple: true
        width: 180
      }
      mcqe_last: "CQE: fd=M, F_MORE=0 ⚠" {
        shape: rectangle
        style.fill: "#FFD700"
        style.stroke: "#ff6b6b"
        style.stroke-width: 2
        width: 180
      }
      mcqe1 -> mcqe2 -> mcqe3 -> mcqe_last
    }
    terminate: "Multishot terminated\n→ Resubmit ONE SQE" {
      shape: rectangle
      style.fill: "#FFD700"
      style.stroke: "#8b4513"
      style.stroke-width: 2
      width: 200
    }
    setup_header -> single_sqe -> syscall_once -> cqe_stream -> terminate
    terminate -> single_sqe: "rare" {
      style.stroke-dash: 4
      style.stroke: "#ff6b6b"
    }
  }
}
legend: "" {
  direction: right
  near: bottom-center
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    border-radius: 8
  }
  l_title: "Legend" {
    shape: text
    style.font-size: 18
    style.bold: true
    style.font-color: white
  }
  l_more: {
    direction: right
    box_more: "" {
      shape: rectangle
      width: 24
      height: 24
      style.fill: "#90EE90"
    }
    label_more: "F_MORE=1: more CQEs coming" {
      shape: text
      style.font-color: white
    }
  }
  l_done: {
    direction: right
    box_done: "" {
      shape: rectangle
      width: 24
      height: 24
      style.fill: "#FFD700"
      style.stroke: "#ff6b6b"
      style.stroke-width: 2
    }
    label_done: "F_MORE=0: multishot ended" {
      shape: text
      style.font-color: white
    }
  }
  l_syscall: {
    direction: right
    box_sys: "" {
      shape: rectangle
      width: 24
      height: 24
      style.fill: "#8b4513"
    }
    label_sys: "Syscall required" {
      shape: text
      style.font-color: white
    }
  }
}
stats: {
  direction: right
  near: bottom-center
  style: {
    fill: transparent
    stroke: transparent
  }
  before_stats: "Single-Shot:\n• N syscalls per N accepts\n• Resubmit on EVERY CQE\n• O(N) kernel transitions" {
    shape: rectangle
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.font-color: "#ffcccc"
    width: 200
  }
  after_stats: "Multishot:\n• 1 syscall for N+ accepts\n• Kernel auto-resubmits\n• ~O(1) kernel transitions" {
    shape: rectangle
    style.fill: "#1f2d1f"
    style.stroke: "#4ade80"
    style.font-color: "#ccffcc"
    width: 200
  }
}