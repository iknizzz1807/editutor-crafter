direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Provided Buffer Ring for TCP Receive" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  conn_side: {
    direction: down
    label: "Active TCP Connections"
    conn1: {
      shape: class
      label: "Connection 1 (conn_t)"
      fd: "int"
      state: "conn_state_t"
      buf_id: "uint16_t"
    }
    conn2: {
      shape: class
      label: "Connection 2 (conn_t)"
      fd: "int"
      state: "conn_state_t"
      buf_id: "uint16_t"
    }
    connN: {
      shape: class
      label: "Connection N (conn_t)"
      fd: "int"
      state: "conn_state_t"
      buf_id: "uint16_t"
      style.stroke-dash: 3
    }
  }
  kernel_side: {
    direction: down
    label: "Kernel Space"
    socket1: {
      shape: circle
      label: "Socket\nfd=5"
      style.fill: "#E8F4FD"
    }
    socket2: {
      shape: circle
      label: "Socket\nfd=6"
      style.fill: "#E8F4FD"
    }
    socketN: {
      shape: circle
      label: "Socket\nfd=N"
      style.fill: "#E8F4FD"
      style.stroke-dash: 3
    }
    tcp_stack: {
      label: "TCP Stack\n(netfilter → protocol handler)"
      shape: rectangle
      width: 200
      style.fill: "#FFF9E6"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  sqe_block: {
    direction: down
    label: "Submission (SQE)"
    width: 320
    sqe_code: {
      label: "IORING_OP_RECV Setup"
      code: |'c
        sqe->opcode = IORING_OP_RECV;
        sqe->fd = conn->fd;
        sqe->addr = 0;           // No buffer addr
        sqe->len = 0;            // No length
        sqe->buf_group = BGID;   // Buffer group ID
        sqe->flags = IOSQE_BUFFER_SELECT;
        sqe->user_data = conn_id;
      '|
      width: 300
    }
  }
  arrow_select: {
    shape: text
    label: "→ Kernel selects buffer →"
    style: {
      font-color: "#2E7D32"
      bold: true
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  buffer_ring: {
    direction: down
    label: "Provided Buffer Ring (bgid=1)"
    width: 500
    ring_header: {
      shape: sql_table
      label: "struct io_uring_buf_ring"
      h0: "Offset | Field | Value"
      f0: "0x00 | tail | 3"
      f1: "0x04 | ring_mask | 0xFF"
      sz: "256 entries (power of 2)"
    }
    ring_entries: {
      direction: right
      label: "Buffer Entries"
      e0: {
        shape: sql_table
        label: "Entry [0]"
        h0: "Field | Value"
        addr: "addr | 0x7F00_1000"
        len: "len | 8192"
        bid: "bid | 0"
        sz: "24 bytes"
        style.fill: "#C8E6C9"
      }
      e1: {
        shape: sql_table
        label: "Entry [1]"
        h0: "Field | Value"
        addr: "addr | 0x7F00_3000"
        len: "len | 8192"
        bid: "bid | 1"
        sz: "24 bytes"
        style.fill: "#FFCDD2"
      }
      e2: {
        shape: sql_table
        label: "Entry [2]"
        h0: "Field | Value"
        addr: "addr | 0x7F00_5000"
        len: "len | 8192"
        bid: "bid | 2"
        sz: "24 bytes"
        style.fill: "#C8E6C9"
      }
      eD: {
        shape: sql_table
        label: "Entry [255]"
        h0: "Field | Value"
        addr: "addr | ..."
        len: "len | 8192"
        bid: "bid | 255"
        sz: "24 bytes"
        style.stroke-dash: 3
      }
    }
    legend: {
      shape: text
      label: "Green = Available | Red = In Use (by Connection 2)"
      style.font-size: 12
    }
  }
  buffer_pool: {
    direction: down
    label: "Actual Buffers (userspace)"
    width: 300
    buf0: {
      shape: rectangle
      label: "Buffer[0]\n8KB @ 0x7F00_1000"
      width: 120
      style.fill: "#C8E6C9"
    }
    buf1: {
      shape: rectangle
      label: "Buffer[1]\n8KB @ 0x7F00_3000\nContains: 2048 bytes\nOwner: Conn 2"
      width: 120
      style.fill: "#FFCDD2"
    }
    buf2: {
      shape: rectangle
      label: "Buffer[2]\n8KB @ 0x7F00_5000"
      width: 120
      style.fill: "#C8E6C9"
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  cqe_block: {
    direction: down
    label: "Completion (CQE)"
    width: 360
    cqe_struct: {
      shape: sql_table
      label: "struct io_uring_cqe"
      h0: "Offset | Field | Value"
      f0: "0x00 | user_data | 2 (conn_id)"
      f1: "0x08 | res | 2048 (bytes)"
      f2: "0x0C | flags | 0x00020000"
      sz: "16 bytes"
    }
    cqe_decode: {
      label: "CQE Flag Decode"
      code: |'c
        if (cqe->flags & IORING_CQE_F_BUFFER) {
          // Buffer ID in upper 16 bits
          __u16 bid = cqe->flags >> 16;
          // bid = 2, conn 2 received data
          void *data = pool->buffers[bid];
          size_t len = cqe->res;
        }
      '|
      width: 340
    }
  }
  ownership: {
    direction: down
    label: "Ownership Tracking"
    width: 280
    tracking: {
      shape: class
      label: "BufferPool (userspace)"
      n_buffers: "int"
      available: "int"
      in_use: "bool[256]"
      owner_conn: "uint32_t[256]"
      +acquire(): "int"
      +release(bid): "void"
    }
    state_after: {
      label: "State After CQE"
      code: |'c
        pool->in_use[1] = true;
        pool->owner_conn[1] = 2;
        pool->available--; // now 254
        conn[2].buf_id = 1;
        conn[2].recv_len = 2048;
      '|
      width: 260
    }
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  replenish: {
    direction: down
    label: "Buffer Replenishment"
    width: 380
    repl_code: {
      label: "Return Buffer to Ring"
      code: |'c
        void return_buffer(pool, bid) {
          // Add back to ring tail
          io_uring_buf_ring_add(
            pool->ring,
            pool->buffers[bid],
            BUFFER_SIZE,
            bid,
            0, 0
          );
          // Advance tail
          io_uring_buf_ring_advance(
            pool->ring, 1
          );
          pool->in_use[bid] = false;
          pool->available++;
        }
      '|
      width: 360
    }
  }
  warning: {
    shape: callout
    label: "⚠️ If pool exhausts:\nRECV fails with ENOBUFS\nMust return buffers promptly!"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
    }
  }
}
conn_side.socket1 -> kernel_side.socket1: "fd=5" {
  style.stroke-dash: 3
  style.stroke: "#1976D2"
}
conn_side.socket2 -> kernel_side.socket2: "fd=6" {
  style.stroke-dash: 3
  style.stroke: "#1976D2"
}
kernel_side.tcp_stack -> buffer_ring: "Selects from bgid=1" {
  style.stroke: "#2E7D32"
  style.bold: true
}
buffer_ring.e1 -> buffer_pool.buf1: "DMA target" {
  style.stroke: "#D32F2F"
  style.bold: true
}
buffer_pool.buf1 -> cqe_block: "CQE reports bid=1" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 4
}
cqe_block -> ownership: "Track ownership" {
  style.stroke: "#1565C0"
}