  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: {
  label: "After io_uring_setup() + mmap() — Three Shared Memory Regions"
  near: top-center
  shape: text
  style.font-size: 16
}
legend_row: {
  direction: right
  near: top-right
  style: {
    stroke: transparent
    fill: transparent
  }
  legend_app: {
    label: "App writes"
