      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 2
    }
  }
}
mmap_regions: {
  label: "mmap() Regions"
  region1_sq_ring: {
    label: "Region 1: SQ Ring Indices"
    shape: sql_table
    width: 420
    r1_header: "Offset | Type | Field | Owner"
    sq_head_off: "0x00 | __u32 | sq_head | kernel (writes)"
    sq_tail_off: "0x04 | __u32 | sq_tail | app (writes)"
    sq_mask_off: "0x08 | __u32 | ring_mask | shared (read)"
    sq_entries_off: "0x0C | __u32 | ring_entries | shared (read)"
    sq_flags_off: "0x10 | __u32 | flags | shared (read)"
    sq_dropped_off: "0x14 | __u32 | dropped | kernel (writes)"
    sq_array_off: "0x18 | __u32* | array[] | app (writes)"
    sq_ring_total: "Total: sq_off.array + sq_entries * 4 bytes"
  }
  region1_notes: {
    label: "SQ Ring Notes"
    shape: rectangle
    style.fill: "#F5F5F5"
    note1: {
      label: |md
        - **sq_head**: Kernel consumes SQEs from here
        - **sq_tail**: App publishes SQEs here
        - **ring_mask**: `entries - 1` for modulo-free indexing
        - **array[]**: Maps logical index → physical SQE slot
      |
      shape: text
    }
  }
  region2_cq_ring: {
    label: "Region 2: CQ Ring + CQE Array"
    shape: sql_table
    width: 420
    r2_header: "Offset | Type | Field | Owner"
    cq_head_off: "0x00 | __u32 | cq_head | app (writes)"
    cq_tail_off: "0x04 | __u32 | cq_tail | kernel (writes)"
    cq_mask_off: "0x08 | __u32 | ring_mask | shared (read)"
    cq_entries_off: "0x0C | __u32 | ring_entries | shared (read)"
    cq_overflow_off: "0x10 | __u32 | overflow | kernel (writes)"
    cq_cqes_off_off: "0x14 | __u32 | cqes offset | shared (read)"
    cq_padding: "0x18-0x3F | -- | padding (cache line) | --"
    cq_cqe_start: "0x40 | io_uring_cqe[] | cqes[] | kernel (writes)"
    cq_ring_total: "Total: cq_off.cqes + cq_entries * 16 bytes"
  }
  cqe_struct: {
    label: "struct io_uring_cqe (16 bytes)"
    shape: sql_table
    width: 380
    cqe_user_data: "0x00 | __u64 | user_data | copied from SQE"
    cqe_res: "0x08 | __s32 | res | result or -errno"
    cqe_flags: "0x0C | __u32 | flags | CQE flags (BUFFER, MORE, NOTIF)"
    cqe_total: "Size: 16 bytes (1 cache line for 4 CQEs)"
  }
  region3_sqe_array: {
    label: "Region 3: SQE Array (IORING_OFF_SQES)"
    shape: sql_table
    width: 460
    r3_header: "Index | Offset | Type | Field"
    sqe_0: "[0] | 0x00 | io_uring_sqe | SQE 0"
    sqe_1: "[1] | 0x40 | io_uring_sqe | SQE 1"
    sqe_2: "[2] | 0x80 | io_uring_sqe | SQE 2"
    sqe_dots: "... | ... | ... | ..."
    sqe_n: "[n-1] | (n-1)*0x40 | io_uring_sqe | SQE n-1"
    sqe_total: "Total: sq_entries * 64 bytes"
  }
  sqe_struct: {
    label: "struct io_uring_sqe (64 bytes = 1 cache line)"
    shape: sql_table
    width: 440
    sqe_opcode: "0x00 | __u8 | opcode | IORING_OP_READ, WRITE, ACCEPT..."
    sqe_flags: "0x01 | __u8 | flags | IOSQE_FIXED_FILE, IO_LINK..."
    sqe_ioprio: "0x02 | __u16 | ioprio | I/O priority"
    sqe_fd: "0x04 | __s32 | fd | file descriptor or index"
    sqe_off: "0x08 | __u64 | off | file offset"
    sqe_addr: "0x10 | __u64 | addr | buffer address"
    sqe_len: "0x18 | __u32 | len | buffer length"
    sqe_rw_flags: "0x1C | __u32 | rw_flags | operation-specific"
    sqe_user_data: "0x20 | __u64 | user_data | passed to CQE"
    sqe_buf_index: "0x28 | __u16 | buf_index | fixed buffer index"
    sqe_personality: "0x2A | __u16 | personality | creds"
    sqe_splice_fd: "0x2C | __s32 | splice_fd_in | splice source"
    sqe_addr3: "0x30 | __u64 | addr3 | extended address"
    sqe_pad: "0x38 | __u64 | __pad[1] | padding to 64 bytes"
    sqe_size: "Size: 64 bytes (exactly 1 cache line)"
  }
}
ownership_flow: {
  label: "Ownership & Data Flow"
  direction: down
  flow_header: {
    label: "Index Ownership: Split Producer/Consumer Model"
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      bold: true
    }
  }
  ownership_table: {
    label: ""
    shape: sql_table
    width: 480
    owner_header: "Index | Writer | Reader | Purpose"
    owner_sq_head: "SQ head | Kernel | App | Kernel consumes SQEs"
    owner_sq_tail: "SQ tail | App | Kernel | App publishes SQEs"
    owner_cq_head: "CQ head | App | Kernel | App consumes CQEs"
    owner_cq_tail: "CQ tail | Kernel | App | Kernel publishes CQEs"
    owner_note: "Each side ONLY writes indices it owns — no synchronization needed"
  }
  app_actions: {
    label: "Application Actions"
    direction: right
    app_submit: {
      label: "Submit SQE"
      shape: rectangle
      style.fill: "#E8F5E9"
      width: 200
      submit_code: |'c
        // 1. Get SQE at tail % entries
        sqe = &sqes[tail & ring_mask];
        // 2. Prepare SQE (write data)
        sqe->opcode = IORING_OP_READ;
        sqe->fd = fd;
        sqe->addr = (u64)buf;
        sqe->len = len;
        sqe->user_data = id;
        // 3. Publish with barrier
        smp_store_release(&sq_tail, 
                          tail + 1);
      '|
    }
    app_harvest: {
      label: "Harvest CQE"
      shape: rectangle
      style.fill: "#E8F5E9"
      width: 200
      harvest_code: |'c
        // 1. Load CQ tail with barrier
        tail = smp_load_acquire(&cq_tail);
        // 2. Check for completions
        if (tail != *cq_head) {
          cqe = &cqes[head & ring_mask];
          // Process cqe->res, cqe->user_data
          (*cq_head)++;  // Advance
        }
      '|
    }
  }
  kernel_actions: {
    label: "Kernel Actions"
    direction: right
    kernel_consume: {
      label: "Consume SQEs"
      shape: rectangle
      style.fill: "#E3F2FD"
      width: 200
      consume_code: |'c
        // Kernel reads SQ tail
        tail = smp_load_acquire(&sq_tail);
        // Process SQEs from head to tail
        while (*sq_head != tail) {
          idx = sq_array[head & ring_mask];
          sqe = &sqes[idx];
          process_sqe(sqe);
          (*sq_head)++;
        }
      '|
    }
    kernel_publish: {
      label: "Publish CQE"
      shape: rectangle
      style.fill: "#E3F2FD"
      width: 200
      publish_code: |'c
        // Kernel writes CQE
        cqe = &cqes[tail & ring_mask];
        cqe->user_data = sqe->user_data;
        cqe->res = result;
        cqe->flags = flags;
        // Publish with barrier
        smp_store_release(&cq_tail, 
                          tail + 1);
      '|
    }
  }
}
barrier_section: {
  label: "Memory Barrier Requirements"
  direction: down
  barrier_why: {
    label: "Why Barriers Are NOT Optional"
    shape: rectangle
    style.fill: "#FFF8E1"
    width: 500
    barrier_text: |md
      **The trap:** x86 has strong memory ordering, so developers assume barriers aren't needed.
      **The reality:** The **compiler** can reorder independent memory writes!
      c
      // DANGEROUS: compiler may reorder!
      sqes[idx].opcode = IORING_OP_READ;  // Write SQE data
      *sq_tail = new_tail;                 // Publish tail
      // If kernel reads new_tail before SQE is written → GARBAGE!
      
      **The solution:** Use `smp_store_release()` when publishing, `smp_load_acquire()` when consuming.
      - **Store-release:** Ensures all prior writes complete before the store becomes visible
      - **Load-acquire:** Ensures all subsequent reads see data after the load completes
      On x86, these compile to compiler barriers (`asm volatile("" ::: "memory")`).
      On ARM, they compile to actual `dmb ish` instructions.
    |
  }
  barrier_impl: {
    label: "Barrier Implementations"
    shape: class
    width: 380
    store_release: "+smp_store_release(p, v): void"
    load_acquire: "+smp_load_acquire(p): __typeof__(*p)"
    barrier_note: "// From barrier.h / liburing"
  }
}
mmap_sequence: {
  label: "mmap() Sequence After io_uring_setup()"
  direction: down
  setup_code: {
    label: "Setup Code"
    shape: rectangle
    style.fill: "#F5F5F5"
    width: 500
    code: |'c
      struct io_uring_params params = {0};
      int ring_fd = syscall(__NR_io_uring_setup, 256, &params);
      // Calculate sizes from params
      size_t sq_ring_size = params.sq_off.array + 
                            params.sq_entries * sizeof(unsigned);
      size_t cq_ring_size = params.cq_off.cqes + 
                            params.cq_entries * sizeof(struct io_uring_cqe);
      size_t sqes_size = params.sq_entries * sizeof(struct io_uring_sqe);
      // Map SQ ring (offset IORING_OFF_SQ_RING = 0)
      void *sq_ring = mmap(NULL, sq_ring_size, PROT_READ | PROT_WRITE,
                           MAP_SHARED | MAP_POPULATE, ring_fd, 0);
      // Map SQE array (offset IORING_OFF_SQES = 0x10000000)
      struct io_uring_sqe *sqes = mmap(NULL, sqes_size, PROT_READ | PROT_WRITE,
                                        MAP_SHARED | MAP_POPULATE, ring_fd, 
                                        IORING_OFF_SQES);
      // Map CQ ring (offset IORING_OFF_CQ_RING = 0x80000000)
      void *cq_ring = mmap(NULL, cq_ring_size, PROT_READ | PROT_WRITE,
                           MAP_SHARED | MAP_POPULATE, ring_fd, 
                           IORING_OFF_CQ_RING);
      // Set up pointers using offsets from params
      sq_head = sq_ring + params.sq_off.head;
      sq_tail = sq_ring + params.sq_off.tail;
      cq_head = cq_ring + params.cq_off.head;
      cq_tail = cq_ring + params.cq_off.tail;
    '|
  }
}
flow_arrows: {
  direction: down
  style: {
    stroke: transparent
