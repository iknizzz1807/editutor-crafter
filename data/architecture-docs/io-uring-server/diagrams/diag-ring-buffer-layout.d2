  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    animated: true
  }
}
kernel_box -> app_box: "SQ head, CQ tail (kernel writes, app reads)" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}
app_box -> kernel_box: "CQ head (app writes, kernel reads)" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    stroke-dash: 4
  }
}
region1_sq_ring -> region2_cq_ring: "Sequential in memory\n(if single mmap)"
region2_cq_ring -> region3_sqe_array: "Separate mmap region\n(IORING_OFF_SQES)"
region3_sqe_array -> sqe_struct: "Each SQE is 64 bytes"
region2_cq_ring -> cqe_struct: "Each CQE is 16 bytes"