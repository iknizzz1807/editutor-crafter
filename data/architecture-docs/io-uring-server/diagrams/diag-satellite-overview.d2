direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  label: "io_uring Server Architecture — Satellite Map"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  m1_l: "M1: Ring Foundations"
  m1_l.style.fill: "#E8F5E9"
  m2_l: "M2: File I/O"
  m2_l.style.fill: "#E3F2FD"
  m3_l: "M3: TCP Server"
  m3_l.style.fill: "#FFF3E0"
  m4_l: "M4: Advanced Features"
  m4_l.style.fill: "#F3E5F5"
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  hub: io_uring Ring Buffer {
    direction: down
    style: {
      fill: "#FAFAFA"
      stroke: "#1976D2"
      stroke-width: 3
      shadow: true
    }
    sq: Submission Queue {
      shape: queue
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
      }
    }
    cq: Completion Queue {
      shape: queue
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
      }
    }
    sqe: SQE (64 bytes) {
      shape: class
      label: "struct io_uring_sqe"
      opcode: "__u8"
      flags: "__u8"
      fd: "__s32"
      addr: "__u64"
      len: "__u32"
      user_data: "__u64"
      buf_index: "__u16"
    }
    cqe: CQE (16 bytes) {
      shape: class
      label: "struct io_uring_cqe"
      user_data: "__u64"
      res: "__s32"
      flags: "__u32"
    }
    sq -- sqe: "entries[]"
    cq -- cqe: "entries[]"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  m1: M1 Ring Foundations {
    direction: down
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
    }
    m1_desc: {
      shape: text
      label: "Batched submission eliminates syscall overhead"
      style.font-size: 11
    }
    m1_structs: {
      direction: right
      ring_setup: {
        shape: sql_table
        label: "io_uring_params"
        f0: "0x00 | __u32 | sq_entries"
        f1: "0x04 | __u32 | cq_entries"
        f2: "0x08 | __u32 | flags"
        f3: "0x0C | __u32 | sq_thread_cpu"
        sz: "Setup via syscall"
      }
      barrier: {
        shape: class
        label: "Memory Barriers"
        smp_store_release: "void"
        smp_load_acquire: "typeof*(p)"
      }
    }
    m1_buffers: Buffer Strategies {
      direction: right
      fixed: Fixed Buffers {
        shape: class
        label: "IORING_REGISTER_BUFFERS"
        iov_base: "void*"
        iov_len: "size_t"
        prep: "READ_FIXED"
      }
      provided: Provided Ring {
        shape: class
        label: "IORING_REGISTER_PBUF_RING"
        ring_addr: "__u64"
        ring_entries: "__u32"
        bgid: "__u16"
        buf_select: "IOSQE_BUFFER_SELECT"
      }
    }
    m1_api: {
      direction: right
      m1_syscalls: {
        label: "Kernel Interface"
        io_uring_setup: "syscall"
        io_uring_enter: "syscall"
        io_uring_register: "syscall"
      }
      m1_helpers: {
        label: "liburing Helpers"
        get_sqe: "struct io_uring_sqe*"
        submit: "int"
        wait_cqe: "int"
        cqe_seen: "void"
      }
    }
  }
  m2: M2 File I/O {
    direction: down
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
    m2_desc: {
      shape: text
      label: "Registered resources bypass per-op validation"
      style.font-size: 11
    }
    m2_structs: {
      direction: right
      reg_files: {
        shape: sql_table
        label: "Registered Files"
        f0: "idx 0 | struct file* | fd 3"
        f1: "idx 1 | struct file* | fd 7"
        f2: "idx 2 | struct file* | fd 12"
        sz: "IOSQE_FIXED_FILE"
      }
      short_read: {
        shape: class
        label: "Short Read Handler"
        total_requested: "size_t"
        bytes_read: "size_t"
        offset: "off_t"
        resubmit: "void"
      }
    }
    m2_dio: Direct I/O {
      direction: right
      alignment: {
        shape: class
        label: "Alignment Rules"
        buffer_addr: "4096 (page)"
        offset: "4096 (block)"
        length: "block size"
      }
      error_handling: {
        shape: class
        label: "DIO Errors"
        EINVAL: "alignment"
        EIO: "disk failure"
        ENOMEM: "lock fail"
      }
    }
    m2_api: {
      direction: right
      m2_reg: {
        label: "Registration"
        register_files: "IORING_REGISTER_FILES"
        register_buffers: "IORING_REGISTER_BUFFERS"
        files_update: "IORING_REGISTER_FILES_UPDATE"
      }
      m2_ops: {
        label: "Operations"
        prep_read: "IORING_OP_READ"
        prep_write: "IORING_OP_WRITE"
        prep_read_fixed: "IORING_OP_READ_FIXED"
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  m3: M3 TCP Server {
    direction: down
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
    m3_desc: {
      shape: text
      label: "Async connection lifecycle with safe cleanup"
      style.font-size: 11
    }
    m3_structs: {
      direction: right
      conn_state: {
        shape: class
        label: "Connection State"
        fd: "int"
        state: "conn_state_t"
        n_in_flight: "int"
        recv_buffer_id: "__u16"
        cancel_requested: "bool"
      }
      conn_enum: {
        shape: class
        label: "conn_state_t enum"
        CONN_FREE: "0"
        CONN_ACTIVE: "1"
        CONN_RECVING: "2"
        CONN_SENDING: "3"
        CONN_CANCELING: "4"
        CONN_CLOSED: "5"
      }
    }
    m3_lifecycle: {
      direction: right
      accept: {
        label: "Multishot Accept"
        shape: hexagon
      }
      recv: {
        label: "Provided Buffer Recv"
        shape: hexagon
      }
      send: {
        label: "Short Write Handler"
        shape: hexagon
      }
      cancel: {
        label: "Async Cancel"
        shape: hexagon
      }
      close: {
        label: "Safe Close"
        shape: hexagon
      }
      accept -> recv -> send -> cancel -> close
    }
    m3_api: {
      direction: right
      m3_ops: {
        label: "Operations"
        prep_accept: "IORING_OP_ACCEPT"
        prep_recv: "IORING_OP_RECV"
        prep_send: "IORING_OP_SEND"
        prep_cancel_fd: "IORING_OP_ASYNC_CANCEL"
      }
      m3_flags: {
        label: "Key Flags"
        multishot: "IORING_CQE_F_MORE"
        buffer: "IORING_CQE_F_BUFFER"
        cancel_all: "IOSQE_ASYNC_CANCEL_ALL"
      }
    }
  }
  m4: M4 Advanced Features {
    direction: down
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    m4_desc: {
      shape: text
      label: "Zero-copy, SQ polling, linked ops, benchmarks"
      style.font-size: 11
    }
    m4_structs: {
      direction: right
      zc_state: {
        shape: class
        label: "Zero-Copy State"
        buffer: "void*"
        length: "size_t"
        state: "zc_state_t"
        notif_pending: "bool"
      }
      zc_enum: {
        shape: class
        label: "zc_state_t enum"
        ZC_SUBMITTED: "0"
        ZC_COMPLETED: "1"
        ZC_NOTIFIED: "2"
        ZC_ERROR: "3"
      }
    }
    m4_features: {
      direction: right
      sqpoll: SQ Polling {
        shape: class
        label: "IORING_SETUP_SQPOLL"
        sq_thread_idle: "__u32"
        sq_thread_cpu: "__u32"
        benefit: "no submit syscall"
      }
      linked: Linked SQEs {
        shape: class
        label: "IOSQE_IO_LINK"
        chain: "SQE1 → SQE2 → SQE3"
        failure: "-ECANCELED cascade"
        drain: "IOSQE_IO_DRAIN"
      }
    }
    m4_bench: Benchmark Suite {
      direction: right
      workloads: {
        label: "Workloads"
        file_io: "disk-bound"
        net_io: "network-bound"
        mixed: "50/50 split"
      }
      metrics: {
        label: "Metrics"
        throughput: "ops/sec, MB/sec"
        latency: "p50, p95, p99"
        syscalls: "perf count"
      }
    }
    m4_api: {
      direction: right
      m4_ops: {
        label: "Operations"
        prep_send_zc: "IORING_OP_SEND_ZC"
        prep_fsync: "IORING_OP_FSYNC"
      }
      m4_flags: {
        label: "Key Flags"
        notif: "IORING_CQE_F_NOTIF"
        link: "IOSQE_IO_LINK"
        drain: "IOSQE_IO_DRAIN"
      }
    }
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  shared: Shared Components {
    direction: right
    style: {
      fill: "#ECEFF1"
      stroke: "#607D8B"
      stroke-dash: 3
    }
    buffer_pool: {
      label: "Buffer Pool Manager"
      shape: class
      buffers: "void**"
      n_buffers: "int"
      in_use: "bool*"
      acquire: "int"
      release: "void"
    }
    sqe_prep: {
      label: "SQE Preparation"
      shape: class
      io_uring_prep_read: "void"
      io_uring_prep_write: "void"
      io_uring_prep_recv: "void"
      io_uring_prep_send: "void"
    }
    cqe_loop: {
      label: "CQE Processing Loop"
      shape: class
      io_uring_for_each_cqe: "macro"
      handle_cqe: "callback"
      io_uring_cq_advance: "void"
    }
  }
}
prereq: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  prereq_label: {
    shape: text
    label: "Prerequisites:"
    style.bold: true
  }
  p1: M1 → M2 {
    style: {
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
  p2: M2 → M3 {
    style: {
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  p3: M3 → M4 {
    style: {
      stroke: "#F57C00"
      stroke-width: 2
    }
  }
}
hub.sq -> m1.m1_api.m1_syscalls: "io_uring_enter"
hub.cq <- m1.m1_api.m1_helpers: "wait_cqe"
hub.sqe -> m2.m2_structs.reg_files: "IOSQE_FIXED_FILE"
hub.sqe -> m3.m3_structs.conn_state: "user_data = conn_id"
hub.sqe -> m4.m4_structs.zc_state: "SEND_ZC"
m1.m1_buffers.fixed -> m2.m2_dio.alignment: "aligned_alloc"
m1.m1_buffers.provided -> m3.m3_lifecycle.recv: "buf_group"
m2.m2_api.m2_reg -> m3.m3_api.m3_ops: "registered fds"
m3.m3_structs.conn_state -> m4.m4_structs.zc_state: "buffer tracking"
shared.buffer_pool -> m2.m2_structs.short_read: "acquire/release"
shared.buffer_pool -> m3.m3_lifecycle.recv: "provided ring"
shared.sqe_prep -> m1.m1_api.m1_helpers: "helpers"
shared.cqe_loop -> m3.m3_api.m3_flags: "flag handling"
p1 -> p2 -> p3