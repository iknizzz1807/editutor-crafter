direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Short Read Handling — State Evolution"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
classes: {
  state_box: {
    style: {
      fill: "#E8F4E8"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 6
    }
  }
  op_box: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 6
    }
  }
  complete_box: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 3
      border-radius: 6
    }
  }
  buffer_box: {
    style: {
      fill: "#FFF8E1"
      stroke: "#F57C00"
      stroke-width: 2
      border-radius: 4
    }
  }
  arrow_label: {
    style: {
      font-size: 14
      font-color: "#37474F"
    }
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  state1: {
    class: state_box
    label: "Initial State"
    width: 280
    fields: {
      shape: sql_table
      label: "struct read_request"
      f1: "0x00 | off_t     | offset = 0"
      f2: "0x08 | size_t    | total = 4096"
      f3: "0x10 | size_t    | remaining = 4096"
      f4: "0x18 | void*     | buf_ptr = 0x1000"
      f5: "0x20 | size_t    | completed = 0"
      sz: "Total: 40 bytes"
    }
  }
  buffer1: {
    class: buffer_box
    label: "Buffer (4KB)"
    width: 200
    mem: {
      shape: sql_table
      label: "User Buffer @ 0x1000"
      b1: "0x0000 - 0x0FFF | 4096 bytes | EMPTY"
      note: "All 4KB available for data"
    }
  }
}
row1 -> row2a: {
  label: "Submit SQE: READ(fd, buf=0x1000, len=4096, off=0)"
  class: arrow_label
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}
row2a: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  op1: {
    class: op_box
    label: "io_uring_prep_read()"
    width: 260
    sqe: {
      shape: sql_table
      label: "SQE (64 bytes)"
      op: "opcode = IORING_OP_READ"
      fd: "fd = registered_index"
      addr: "addr = 0x1000"
      len: "len = 4096"
      off: "off = 0"
      ud: "user_data = request_id"
    }
  }
  cqe1: {
    class: op_box
    label: "CQE Arrives"
    width: 200
    result: {
      shape: sql_table
      label: "Completion Queue Entry"
      res: "res = 3000"
      flags: "flags = 0"
      note: "SHORT READ!"
    }
  }
  kernel1: {
    label: |md
      **Kernel Action:**
      - Read from file at offset 0
      - Only 3000 bytes available
      - Returns partial data
    |
    shape: rectangle
    width: 220
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-dash: 3
    }
  }
}
row2a -> row3: {
  label: "CQE->res = 3000 < requested (4096)"
  class: arrow_label
  style: {
    stroke: "#D32F2F"
    stroke-width: 2
    stroke-dash: 4
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  state2: {
    class: state_box
    label: "State After First Read"
    width: 280
    fields: {
      shape: sql_table
      label: "struct read_request"
      f1: "0x00 | off_t     | offset = 3000"
      f2: "0x08 | size_t    | total = 4096"
      f3: "0x10 | size_t    | remaining = 1096"
      f4: "0x18 | void*     | buf_ptr = 0x1000"
      f5: "0x20 | size_t    | completed = 3000"
      sz: "Total: 40 bytes"
    }
  }
  buffer2: {
    class: buffer_box
    label: "Buffer (Partial Fill)"
    width: 260
    mem: {
      shape: sql_table
      label: "User Buffer @ 0x1000"
      b1: "0x0000 - 0x0BB7 | 3000 bytes | DATA ✓"
      b2: "0x0BB8 - 0x0FFF | 1096 bytes | EMPTY"
      note: "3000 filled, 1096 remaining"
    }
  }
  calc: {
    label: |'c
      // State update logic:
      req->completed += cqe->res;  // += 3000
      req->offset += cqe->res;     // += 3000
      req->remaining = 
        req->total - req->completed;
      // remaining = 4096 - 3000 = 1096
    '|
    shape: rectangle
    width: 280
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      font: mono
      font-size: 12
    }
  }
}
row3 -> row4: {
  label: "Resubmit: READ(fd, buf=0x1BB8, len=1096, off=3000)"
  class: arrow_label
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  op2: {
    class: op_box
    label: "io_uring_prep_read()"
    width: 260
    sqe: {
      shape: sql_table
      label: "SQE (Resubmit)"
      op: "opcode = IORING_OP_READ"
      fd: "fd = registered_index"
      addr: "addr = 0x1BB8"
      len: "len = 1096"
      off: "off = 3000"
      note: "Continue from partial"
    }
  }
  cqe2: {
    class: complete_box
    label: "CQE Arrives (Complete)"
    width: 200
    result: {
      shape: sql_table
      label: "Completion Queue Entry"
      res: "res = 1096"
      flags: "flags = 0"
      note: "READ COMPLETE"
    }
  }
  kernel2: {
    label: |md
      **Kernel Action:**
      - Read from file at offset 3000
      - 1096 bytes available
      - Request fully satisfied
    |
    shape: rectangle
    width: 220
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-dash: 3
    }
  }
}
row4 -> row5: {
  label: "CQE->res = 1096, completed + res == total"
  class: arrow_label
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  state3: {
    class: complete_box
    label: "Final State (Complete)"
    width: 280
    fields: {
      shape: sql_table
      label: "struct read_request"
      f1: "0x00 | off_t     | offset = 4096"
      f2: "0x08 | size_t    | total = 4096"
      f3: "0x10 | size_t    | remaining = 0"
      f4: "0x18 | void*     | buf_ptr = 0x1000"
      f5: "0x20 | size_t    | completed = 4096"
      sz: "Total: 40 bytes"
    }
  }
  buffer3: {
    class: complete_box
    label: "Buffer (Fully Filled)"
    width: 260
    mem: {
      shape: sql_table
      label: "User Buffer @ 0x1000"
      b1: "0x0000 - 0x0FFF | 4096 bytes | DATA ✓"
      note: "All 4KB filled via 2 reads"
    }
  }
  final: {
    label: |'c
      // Completion check:
      if (req->completed >= req->total) {
        req->state = READ_COMPLETE;
        // Buffer now has all data
        // Safe to process
        process_data(buf, 4096);
      }
    '|
    shape: rectangle
    width: 280
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      font: mono
      font-size: 12
    }
  }
}
legend: {
  near: bottom-center
  label: "Short Read Handling Summary"
  grid-columns: 4
  grid-gap: 20
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  l1: {
    label: |md
      **Request**
      Total: 4096 bytes
    |
  }
  l2: {
    label: |md
      **Read #1**
      Got: 3000 bytes
      Offset: 0 → 3000
    |
  }
  l3: {
    label: |md
      **Read #2**
      Got: 1096 bytes
      Offset: 3000 → 4096
    |
  }
  l4: {
    label: |md
      **Result**
      2 CQEs, 2 SQEs
      4096 bytes total
    |
  }
}
key_insight: {
  near: bottom-center
  label: |md
    **Key Insight:** A "short read" (res < requested) is NOT an error. It means the kernel returned partial data.
    The application must resubmit for remaining bytes at the updated offset with an adjusted buffer pointer.
  |
  shape: callout
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    stroke-width: 2
  }
  width: 600
}