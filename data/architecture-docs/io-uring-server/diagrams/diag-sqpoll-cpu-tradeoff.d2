direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "SQ Polling CPU Tradeoff Analysis" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
subtitle: "Syscall Overhead vs Polling CPU Cost — Finding the Crossover Point" {
  near: top-center
  shape: text
  style.font-size: 18
}
row_graphs: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  graph_no_sqpoll: "Without SQPOLL" {
    direction: down
    style.fill: "#1a1a2e"
    style.stroke: "#4a4a6a"
    style.border-radius: 8
    y_axis_no: {
      label: "CPU Usage %"
      style.font-color: "#88ccff"
    }
    graph_area_no: {
      width: 320
      height: 240
      style.fill: "#0d0d1a"
      style.stroke: "#333355"
      syscall_curve: {
        label: "Syscall Overhead"
        style.fill: "#ff6b6b"
        shape: diamond
      }
      baseline_50: {
        label: "50% Application Work"
        style.fill: "#4ecdc4"
      }
      total_no: {
        label: "Total CPU"
        style.fill: "#ffe66d"
      }
    }
    x_axis_no: {
      label: "Ops/sec (K)"
      style.font-color: "#88ccff"
    }
    annotation_no: |md
      **Syscall cost dominates at high rates**
      At 500K ops/sec:
      - Syscalls: ~35% CPU
      - App work: ~50% CPU
      - **Total: 85% CPU**
    | {
      width: 280
    }
  }
  graph_sqpoll: "With SQPOLL" {
    direction: down
    style.fill: "#1a1a2e"
    style.stroke: "#4a4a6a"
    style.border-radius: 8
    y_axis_sq: {
      label: "CPU Usage %"
      style.font-color: "#88ccff"
    }
    graph_area_sq: {
      width: 320
      height: 240
      style.fill: "#0d0d1a"
      style.stroke: "#333355"
      poll_curve: {
        label: "Polling Thread (fixed)"
        style.fill: "#a855f7"
      }
      baseline_50_sq: {
        label: "50% Application Work"
        style.fill: "#4ecdc4"
      }
      total_sq: {
        label: "Total CPU"
        style.fill: "#22c55e"
      }
    }
    x_axis_sq: {
      label: "Ops/sec (K)"
      style.font-color: "#88ccff"
    }
    annotation_sq: |md
      **Fixed polling cost, zero syscall overhead**
      At 500K ops/sec:
      - Polling: ~15% CPU (fixed)
      - App work: ~50% CPU
      - **Total: 65% CPU**
    | {
      width: 280
    }
  }
}
row_crossover: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  crossover_analysis: "Crossover Point Analysis" {
    direction: down
    style.fill: "#1e293b"
    style.stroke: "#475569"
    style.border-radius: 8
    width: 420
    crossover_title: {
      label: "Where SQPOLL Wins"
      style: {
        bold: true
        font-size: 18
        font-color: "#22c55e"
      }
    }
    crossover_data: {
      shape: sql_table
      label: "Break-Even Analysis (syscall_t: syscall overhead)"
      f0: "Parameter | Value | Note"
      f1: "Syscall cost | ~80-150ns | Context switch + kernel entry"
      f2: "Polling cost | ~10-15% CPU | One dedicated core"
      f3: "Break-even rate | ~100-150K ops/sec | Crossover point"
      f4: "Below break-even | No SQPOLL | Syscalls cheaper than polling"
      f5: "Above break-even | Use SQPOLL | Syscalls exceed polling cost"
    }
    crossover_formula: |'c
      // Break-even calculation
      // polling_cpu = 0.15 * 1_core (constant)
      // syscall_cpu = ops_per_sec * syscall_ns / 1e9
      float break_even = POLLING_CPU / (SYSCALL_NS / 1e9);
      // Result: ~100,000 - 150,000 ops/sec
    '|
  }
  workload_tuning: "sq_thread_idle Tuning by Workload" {
    direction: down
    style.fill: "#1e293b"
    style.stroke: "#475569"
    style.border-radius: 8
    width: 420
    tuning_title: {
      label: "Optimal Idle Timeout Values"
      style: {
        bold: true
        font-size: 18
        font-color: "#f59e0b"
      }
    }
    tuning_table: {
      shape: sql_table
      label: "Recommended Settings"
      t0: "Workload Type | Idle (ms) | Rationale"
      t1: "HFT Trading | 1-5 | Sub-microsecond latency critical"
      t2: "Game Server | 5-20 | Bursty traffic, need quick response"
      t3: "Web Server | 20-100 | Moderate request rate"
      t4: "API Gateway | 50-100 | Mixed latency requirements"
      t5: "Batch Processing | 100-500 | Infrequent submissions OK"
      t6: "Background Worker | 500-1000 | Very low submission rate"
    }
    tuning_note: |md
      **Tuning Strategy:**
      1. Start with `sq_thread_idle = 100ms`
      2. Monitor `/proc/<pid>/task/<sqpoll-tid>/stat`
      3. If thread sleeps too often → increase idle
      4. If CPU waste during quiet periods → decrease idle
      5. Target: 80-90% wake efficiency
    |
  }
}
row_decision: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  decision_matrix: "SQPOLL Decision Matrix" {
    direction: down
    style.fill: "#0f172a"
    style.stroke: "#334155"
    style.border-radius: 8
    width: 860
    decision_title: {
      label: "When to Enable SQPOLL"
      style: {
        bold: true
        font-size: 20
        font-color: "#60a5fa"
      }
    }
    decision_table: {
      shape: sql_table
      label: "Decision Criteria"
      d0: "Factor | Use SQPOLL | Skip SQPOLL"
      d1: "Ops rate | >100K/sec | <50K/sec"
      d2: "CPU cores | 8+ available | <4 cores"
      d3: "Latency req | Sub-millisecond | >10ms OK"
      d4: "Submission pattern | Continuous | Bursty with gaps"
      d5: "Privileges | CAP_SYS_NICE | Unprivileged"
      d6: "Power budget | Unlimited | Battery/lower power"
    }
    warning_box: "Privilege Requirement" {
      style: {
        fill: "#7f1d1d"
        stroke: "#dc2626"
        border-radius: 4
      }
      warning_text: |md
        **SQPOLL requires CAP_SYS_NICE or root**
        Without privileges, `io_uring_queue_init_params` returns `-EPERM`.
        Always implement graceful fallback to non-SQPOLL mode.
      |
    }
  }
}
row_code: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  impl_box: "Implementation Pattern" {
    direction: down
    style.fill: "#1e1e2e"
    style.stroke: "#45475a"
    style.border-radius: 8
    width: 860
    impl_title: {
      label: "Graceful SQPOLL Setup with Fallback"
      style: {
        bold: true
        font-size: 18
        font-color: "#cba6f7"
      }
    }
    code_block: {
      width: 820
      label: "sqpoll_setup.c"
      code: |'c
        int setup_ring_with_sqpoll(struct io_uring *ring, int size, 
                                    bool request_sqpoll, unsigned int idle_ms) {
            struct io_uring_params params = {0};
            if (request_sqpoll) {
                params.flags = IORING_SETUP_SQPOLL;
                params.sq_thread_idle = idle_ms;
            }
            int ret = io_uring_queue_init_params(size, ring, &params);
            if (ret == -EPERM && request_sqpoll) {
                // Missing CAP_SYS_NICE - fall back gracefully
                fprintf(stderr, "SQPOLL requires CAP_SYS_NICE, using default mode\n");
                memset(&params, 0, sizeof(params));
                ret = io_uring_queue_init_params(size, ring, &params);
            }
            return ret;  // 0 on success, negative errno on failure
        }
      '|
    }
  }
}
row_metrics: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  metrics_box: "Monitoring SQPOLL Efficiency" {
    direction: down
    style.fill: "#1e293b"
    style.stroke: "#475569"
    style.border-radius: 8
    width: 860
    metrics_title: {
      label: "Key Metrics to Track"
      style: {
        bold: true
        font-size: 18
        font-color: "#10b981"
      }
    }
    metrics_code: {
      width: 820
      label: "sqpoll_monitor.sh"
      code: |'bash
        #!/bin/bash
        # Find SQPOLL thread (named "io_uring-sq")
        PID=$1
        SQPOLL_TID=$(pgrep -f "io_uring-sq" | head -1)
        if [ -z "$SQPOLL_TID" ]; then
            echo "SQPOLL thread not found"
            exit 1
        fi
        # Monitor CPU usage and wake rate
        echo "SQPOLL Thread: $SQPOLL_TID"
        while true; do
            # CPU time from /proc/<tid>/stat (field 14=utime, 15=stime)
            CPU=$(ps -p $SQPOLL_TID -o %cpu --no-headers)
            # Wake count from io_uring stats (kernel 6.5+)
            if [ -f "/proc/$PID/io_uring" ]; then
                WAKES=$(grep "sqpoll_wake" /proc/$PID/io_uring 2>/dev/null || echo "N/A")
            else
                WAKES="N/A"
            fi
            echo "$(date +%H:%M:%S) - CPU: ${CPU}% | Wakes: $WAKES"
            sleep 1
        done
      '|
    }
  }
}
legend: "Color Legend" {
  near: bottom-center
  direction: right
  style.fill: "#0f172a"
  style.border-radius: 4
  legend_syscall: {
    label: "Syscall Overhead"
    style.fill: "#ff6b6b"
  }
  legend_poll: {
    label: "Polling Cost"
    style.fill: "#a855f7"
  }
  legend_app: {
    label: "Application Work"
    style.fill: "#4ecdc4"
  }
  legend_total_no: {
    label: "Total (no SQPOLL)"
    style.fill: "#ffe66d"
  }
  legend_total_sq: {
    label: "Total (SQPOLL)"
    style.fill: "#22c55e"
  }
}
arrow_annotation: {
  label: "SQPOLL saves CPU\nat high op rates"
  style: {
    stroke: "#22c55e"
    stroke-dash: 4
    font-color: "#22c55e"
    bold: true
  }
}
graph_no_sqpoll.graph_area_no -> graph_sqpoll.graph_area_sq: arrow_annotation