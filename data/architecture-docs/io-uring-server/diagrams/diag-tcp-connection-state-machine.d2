direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Connection State Machine
  io_uring-driven lifecycle with in-flight tracking
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  accepting: {
    shape: oval
    label: "ACCEPTING"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    inflight: "n_in_flight: 1"
    sqe_type: "SQE: ACCEPT"
    style.font-size: 20
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  reading: {
    shape: oval
    label: "READING"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    inflight: "n_in_flight: 1"
    sqe_type: "SQE: RECV"
    style.font-size: 20
  }
  processing: {
    shape: diamond
    label: "PROCESSING"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    inflight: "n_in_flight: 0"
    sqe_type: "(no SQE pending)"
    style.font-size: 20
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  writing: {
    shape: oval
    label: "WRITING"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    inflight: "n_in_flight: 1"
    sqe_type: "SQE: SEND"
    style.font-size: 20
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  closing: {
    shape: oval
    label: "CLOSING"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    inflight: "n_in_flight: 1+"
    sqe_type: "SQE: CLOSE/CANCEL"
    style.font-size: 20
  }
  closed: {
    shape: oval
    label: "CLOSED"
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    inflight: "n_in_flight: 0"
    sqe_type: "fd = -1"
    style.font-size: 20
  }
}
error_state: {
  shape: oval
  label: "ERROR"
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-size: 20
}
accepting -> reading: "CQE: accept ok\nres = client_fd\nsubmit RECV" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
reading -> processing: "CQE: recv ok\nres = byte_count\nbuffer filled" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
processing -> writing: "response ready\nsubmit SEND" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
writing -> reading: "CQE: send ok\nres = bytes_sent\nsubmit RECV" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
reading -> closing: "CQE: res = 0\n(peer closed)" {
  style.stroke: "#795548"
  style.stroke-dash: 4
}
writing -> closing: "CQE: res < 0\n(EPIPE/ECONNRESET)" {
  style.stroke: "#795548"
  style.stroke-dash: 4
}
closing -> closed: "CQE: close ok\nor cancel confirmed\nn_in_flight → 0" {
  style.stroke: "#607D8B"
  style.stroke-width: 2
}
accepting -> error_state: "CQE: res < 0\n(EINVAL/EMFILE)" {
  style.stroke: "#C62828"
  style.stroke-dash: 4
}
reading -> error_state: "CQE: res < 0\n(ECONNRESET)" {
  style.stroke: "#C62828"
  style.stroke-dash: 4
}
processing -> closing: "protocol error\nor timeout" {
  style.stroke: "#795548"
  style.stroke-dash: 4
}
error_state -> closing: "cleanup required\ncancel in-flight" {
  style.stroke: "#C62828"
  style.stroke-dash: 4
}
legend: {
  near: bottom-right
  label: "Legend"
  normal: "—— Normal transition"
  error: "- - - Error / cleanup path"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.font-size: 16
}
tracking_box: {
  label: "In-Flight Tracking Rules"
  rule1: "ACCEPTING: 1 (accept SQE pending)"
  rule2: "READING: 1 (recv SQE pending)"
  rule3: "PROCESSING: 0 (no SQE, buffer owned)"
  rule4: "WRITING: 1 (send SQE pending)"
  rule5: "CLOSING: N (cancel + close SQEs)"
  rule6: "CLOSED: 0 (fd = -1, safe to free)"
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.font-size: 14
}
tracking_box.near: bottom-left
short_write: {
  label: "Short Write Handling"
  desc: "If CQE.res < send_total:\n  resubmit SEND with offset\n  keep n_in_flight = 1"
  shape: rectangle
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
  style.font-size: 14
}
short_write.near: bottom-center