      buffer_aligned: "bool | meets req"
      length_aligned: "bool | meets req"
      offset_remainder: "uint32_t | offset % align"
      buffer_remainder: "uint32_t | addr % align"
      length_remainder: "uint32_t | len % align"
    }
  }
}
row_network: "" {
  direction: right
