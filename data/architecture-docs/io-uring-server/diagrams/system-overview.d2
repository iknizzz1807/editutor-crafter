direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
title: |md
  # io_uring High-Performance Server
  **System Blueprint** — Implementation-Ready Architecture
  Linux 5.1+ (5.19+ for provided buffers, 6.0+ for zero-copy)
| {
  near: top-center
  shape: text
  style.font-size: 20
}
row_infra: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_space: {
    direction: down
    label: "KERNEL SPACE"
    style.fill: "#E8F4EA"
    style.stroke: "#4CAF50"
    io_uring_core: {
      shape: class
      label: "io_uring Core  linux/io_uring.h  [M1]"
      -sq_ring: "struct io_rings *"
      -cq_ring: "struct io_rings *"
      -sqes: "struct io_uring_sqe *"
      -cqes: "struct io_uring_cqe *"
      -ring_fd: "int"
      -sq_entries: "uint32_t"
      -cq_entries: "uint32_t"
    }
    sqe: {
      shape: sql_table
      label: "struct io_uring_sqe  64 bytes  [M1]"
      opcode: "uint8_t | offset 0x00"
      flags: "uint8_t | offset 0x01"
      ioprio: "uint16_t | offset 0x02"
      fd: "int32_t | offset 0x04"
      off: "uint64_t | offset 0x08"
      addr: "uint64_t | offset 0x10"
      len: "uint32_t | offset 0x18"
      rw_flags: "uint32_t | offset 0x1C"
      user_data: "uint64_t | offset 0x20"
      buf_index: "uint16_t | offset 0x28"
      buf_group: "uint16_t | offset 0x2A"
      sz: "Total: 64 bytes (1 cache line)"
    }
    cqe: {
      shape: sql_table
      label: "struct io_uring_cqe  16 bytes  [M1]"
      user_data: "uint64_t | offset 0x00"
      res: "int32_t | offset 0x08"
      flags: "uint32_t | offset 0x0C"
      sz: "Total: 16 bytes"
    }
    ring_offsets: {
      shape: sql_table
      label: "io_sqring_offsets  [M1]"
      head: "uint32_t | kernel writes"
      tail: "uint32_t | app writes"
      ring_mask: "uint32_t | entries - 1"
      ring_entries: "uint32_t | count"
      flags: "uint32_t | IORING_SQ_*"
      dropped: "uint32_t | overflow cnt"
      array: "uint32_t | SQE index array"
    }
  }
  userspace_core: {
    direction: down
    label: "USERSPACE — CORE"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    io_uring_ring: {
      shape: class
      label: "io_uring_ring_t  io_uring_internal.h  [M1]"
      -ring_fd: "int"
      -sq_head: "uint32_t *"
      -sq_tail: "uint32_t *"
      -sq_ring_mask: "uint32_t *"
      -sq_array: "uint32_t *"
      -sqes: "struct io_uring_sqe *"
      -sq_entries: "uint32_t"
      -cq_head: "uint32_t *"
      -cq_tail: "uint32_t *"
      -cq_ring_mask: "uint32_t *"
      -cqes: "struct io_uring_cqe *"
      -cq_entries: "uint32_t"
      +io_uring_init(): "int"
      +io_uring_cleanup(): "void"
      +io_uring_get_sqe(): "struct io_uring_sqe *"
      +io_uring_submit(): "int"
      +io_uring_submit_and_wait(): "int"
      +io_uring_peek_cqe(): "int"
      +io_uring_wait_cqe(): "int"
      +io_uring_cqe_seen(): "void"
    }
    barrier_funcs: {
      shape: class
      label: "Memory Barriers  [M1]"
      +io_uring_smp_store_release(): "void"
      +io_uring_smp_load_acquire(): "uint32_t"
    }
  }
}
row_buffers: "" {
