row_file_io: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  file_server: {
    direction: down
    label: "FILE I/O SERVER  [M2]"
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    file_table: {
      shape: class
      label: "file_table_t  file_table.h  [M2]"
      -slots: "file_slot_t[MAX_FILES]"
      -n_active: "uint32_t"
      -n_registered: "uint32_t"
      -kernel_fds: "int *"
      -dirty: "bool"
      +file_table_init(): "int"
      +file_table_register(): "int"
      +file_table_unregister(): "int"
      +file_table_lookup(): "int"
      +file_table_ref(): "int"
      +file_table_unref(): "void"
    }
    file_slot: {
      shape: sql_table
      label: "file_slot_t  288 bytes"
      original_fd: "int | posix fd"
      registered_index: "uint32_t | kernel index"
      state: "file_slot_state_t | lifecycle"
      open_flags: "uint32_t | O_RDONLY, O_DIRECT"
      file_size: "uint64_t | cached stat"
      ref_count: "uint32_t | in-flight ops"
      error_count: "uint32_t | health monitor"
      path: "char[256] | for debugging"
      sz: "Total: 288 bytes (~4.5 cache lines)"
    }
    read_request: {
      shape: sql_table
      label: "read_request_t  64 bytes  [M2]"
      user_data: "uint64_t | app identifier"
      slot_index: "uint32_t | file slot"
      buffer_index: "uint32_t | buffer pool"
      state: "read_req_state_t | state machine"
      start_offset: "uint64_t | original offset"
      current_offset: "uint64_t | for resubmit"
      total_requested: "uint32_t | original len"
      bytes_completed: "uint32_t | accumulated"
      last_result: "int32_t | CQE res"
      retry_count: "uint32_t | short reads"
      flags: "uint32_t | READ_REQ_FLAG_*"
      completion_cb: "void (*)(read_request *, void *)"
      cb_context: "void *"
      sz: "Total: 64 bytes (1 cache line)"
    }
    read_states: {
      shape: sql_table
      label: "read_req_state_t  [M2]"
      free: "READ_REQ_FREE | available"
      submitted: "READ_REQ_SUBMITTED | SQE in ring"
      partial: "READ_REQ_PARTIAL | short read"
      complete: "READ_REQ_COMPLETE | success"
      eof: "READ_REQ_EOF | end of file"
      error: "READ_REQ_ERROR | failed"
      cancelled: "READ_REQ_CANCELLED | explicit cancel"
    }
  }
  dio_module: {
    direction: down
    label: "DIRECT I/O  [M2]"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
