      send_buf_bid: "uint16_t | buffer bid"
      send_total: "uint32_t | total to send"
      send_done: "uint32_t | sent so far"
      n_in_flight: "uint8_t | pending ops"
      cancel_requested: "bool | cleanup flag"
      multishot_more: "bool | IORING_CQE_F_MORE"
      bytes_received: "uint64_t | stats"
      bytes_sent: "uint64_t | stats"
      last_active_ns: "uint64_t | timeout check"
      sz: "Total: 64 bytes (1 cache line)"
    }
    conn_states: {
      shape: sql_table
      label: "conn_state_t  [M3]"
      free: "CONN_FREE | slot available"
      accepting: "CONN_ACCEPTING | accept pending"
      active: "CONN_ACTIVE | ready for I/O"
      recving: "CONN_RECVING | recv in flight"
      sending: "CONN_SENDING | send in flight"
      cancelling: "CONN_CANCELLING | cancel pending"
      closing: "CONN_CLOSING | close pending"
      closed: "CONN_CLOSED | awaiting cleanup"
      error: "CONN_ERROR | needs cleanup"
