      -recommended_alignment: "uint32_t"
      -dio_supported: "bool"
      -device_path: "char[256]"
      +dio_query_alignment(): "int"
      +dio_check_alignment(): "dio_alignment_result_t"
      +dio_adjust_alignment(): "int"
      +dio_alloc_buffer(): "void *"
    }
    alignment_result: {
      shape: sql_table
      label: "dio_alignment_result_t"
