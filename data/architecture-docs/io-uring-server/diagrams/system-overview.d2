      submitted: "BUFFER_SUBMITTED | in-flight SQE"
      processing: "BUFFER_PROCESSING | CQE harvested"
      error: "BUFFER_ERROR | cleanup needed"
    }
    buffer_slot: {
      shape: sql_table
      label: "buffer_slot_t  32 bytes"
      addr: "void * | buffer address"
      size: "uint32_t | current size"
      capacity: "uint32_t | allocated size"
      state: "buffer_state_t | ownership"
      owner_user_data: "uint64_t | owning request"
      acquire_time_ns: "uint64_t | for timeout"
      dio_aligned: "uint32_t | Direct I/O ok"
      sz: "Total: 32 bytes"
    }
    buffer_pool_tracker: {
      shape: class
      label: "buffer_pool_t  [M2]"
      -slots: "buffer_slot_t *"
      -n_buffers: "uint32_t"
      -n_free: "uint32_t"
      -n_submitted: "uint32_t"
      -n_processing: "uint32_t"
      -buffer_size: "uint32_t"
      -alignment: "uint32_t"
      -free_head: "uint32_t"
      -free_next: "uint32_t *"
      +buffer_pool_init(): "int"
      +buffer_acquire(): "int"
      +buffer_release(): "int"
      +buffer_mark_processing(): "int"
      +buffer_check_timeouts(): "uint32_t"
