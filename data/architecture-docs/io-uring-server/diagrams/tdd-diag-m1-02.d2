vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    data: "#5C9AD4"
    free: "#7BC96C"
    padding: "#B0B0B0"
    pointer: "#F5A623"
    kernel: "#E74C3C"
    userspace: "#3498DB"
    ring-border: "#2C3E50"
    cache-line: "#E8E8E8"
  }
}

title: |'md
# SQ/CQ Ring Buffer Memory Layout
## Intel Manual Standard: io_uring kernel-user shared memory
'| {near: top-center}

direction: right

mmap_regions: {
  label: "Shared mmap Regions (Allocated by Kernel)"
  style: {
    stroke: "#333333"
    stroke-width: 4
    fill: "#FDFDFD"
  }

  region_sq_ring: {
    label: "Region 1: SQ Ring (IORING_OFF_SQ_RING)\nRW: User/Kernel"
    style: {
      fill: "${colors.userspace}"
      stroke: "${colors.ring-border}"
      stroke-width: 2
      opacity: 0.9
    }
    sq_ring_layout: {
      label: ""
      direction: down
      sq_header: {
        label: "io_sqring_offsets structure"
        style.fill: "${colors.header}"
        shape: rectangle
        header_content: {
          shape: rectangle
          style.fill: "${colors.cache-line}"
          label: |'md
| Offset | Field | Size | Description |
|:-------|:------|:-----|:------------|
| 0x00 | **head** | 4B | Index into SQEs (Kernel owned) |
| 0x04 | **tail** | 4B | Index into SQEs (App owned) |
| 0x08 | **ring_mask** | 4B | sq_entries - 1 |
| 0x0C | **ring_entries** | 4B | Total SQEs (Power of 2) |
| 0x10 | **flags** | 4B | IORING_SQ_NEED_WAKEUP etc. |
| 0x14 | **dropped** | 4B | Number of invalid SQEs |
| 0x18 | **array** | 4B | Offset to index array |
| 0x1C | **resv[3]** | 12B | Padding / Reserved |
'|
        }
      }
      sq_array_section: {
        label: "SQ Index Array (Indirection Layer)"
        style.fill: "${colors.data}"
        shape: rectangle
        array_content: {
          shape: rectangle
          style.fill: "${colors.cache-line}"
          label: |'md
[Offset: sq_off.array]
+--------+--------+--------+--------+
| sqe[0] | sqe[1] | sqe[2] |  ...   |
+--------+--------+--------+--------+
*User writes tail index here to point to specific SQEs*
'|
        }
      }
    }
  }

  region_sqes: {
    label: "Region 2: SQE Array (IORING_OFF_SQES)\nRW: User/Kernel"
    style: {
      fill: "${colors.data}"
      stroke: "${colors.ring-border}"
      stroke-width: 2
    }
    sqe_layout: {
      label: ""
      direction: down
      sqe_struct: {
        label: "struct io_uring_sqe (Size: 64B - Single Cache Line)"
        style.fill: "${colors.header}"
        shape: rectangle
        sqe_content: {
          shape: rectangle
          style.fill: "${colors.cache-line}"
          label: |'md
| Byte | Field | Description |
|:-----|:------|:------------|
| 0x00 | opcode | IORING_OP_READV, WRITEV, etc. |
| 0x01 | flags | IOSQE_FIXED_FILE, IOSQE_IO_DRAIN |
| 0x04 | fd | Target file descriptor |
| 0x08 | off | File offset or buffer address |
| 0x10 | addr | Pointer to user buffer |
| 0x18 | len | Buffer length |
| 0x20 | user_data | Application-defined tag (opaque) |
| 0x30 | addr3 | Extended address data |
| 0x38 | padding | Alignment to 64 bytes |
'|
        }
      }
      sqe_array_map: {
        label: "Global Submission Queue Entry Pool"
        style.fill: "${colors.cache-line}"
        shape: rectangle
        label: |'md
| Cache Line | Index | Size |
|:-----------|:------|:-----|
| L0 | sqes[0] | 64B |
| L1 | sqes[1] | 64B |
| L2 | sqes[2] | 64B |
| ... | ... | ... |
| LN | sqes[N-1] | 64B |
'|
      }
    }
  }

  region_cq_ring: {
    label: "Region 3: CQ Ring (IORING_OFF_CQ_RING)\nRW: User/Kernel"
    style: {
      fill: "${colors.kernel}"
      stroke: "${colors.ring-border}"
      stroke-width: 2
    }
    cq_ring_layout: {
      label: ""
      direction: down
      cq_header: {
        label: "io_cqring_offsets structure"
        style.fill: "${colors.header}"
        shape: rectangle
        cq_header_content: {
          shape: rectangle
          style.fill: "${colors.cache-line}"
          label: |'md
| Offset | Field | Size | Description |
|:-------|:------|:-----|:------------|
| 0x00 | **head** | 4B | Index (App owned) |
| 0x04 | **tail** | 4B | Index (Kernel owned) |
| 0x08 | **ring_mask** | 4B | cq_entries - 1 |
| 0x0C | **ring_entries** | 4B | Total CQEs |
| 0x10 | **overflow** | 4B | Kernel overflow count |
| 0x14 | **cqes** | 4B | Offset to entries |
'|
        }
      }
      cqe_entries_section: {
        label: "CQE Entries (16B each)"
        style.fill: "${colors.data}"
        shape: rectangle
        cqe_content_table: {
          shape: rectangle
          style.fill: "${colors.cache-line}"
          label: |'md
| Offset | Field | Size | Description |
|:-------|:------|:-----|:------------|
| 0x00 | user_data | 8B | Copied from SQE |
| 0x08 | res | 4B | Return value (e.g. bytes read) |
| 0x0C | flags | 4B | Completion flags |
'|
        }
      }
    }
  }
}

ownership_logic: {
  label: "Distributed Ownership Model (Lock-Free)"
  style: {
    fill: "#F0F4F8"
    stroke: "#2C3E50"
    stroke-width: 2
  }
  table: {
    shape: rectangle
    style.fill: white
    label: |'md
### Single-Producer Single-Consumer Indices
| Structure | Index | Producer (Writes) | Consumer (Reads) |
|:----------|:------|:------------------|:-----------------|
| **SQ** | head | **Kernel** | User |
| **SQ** | tail | **User** | Kernel |
| **CQ** | head | **User** | Kernel |
| **CQ** | tail | **Kernel** | User |

*Barriers ensure producer writes are visible before index updates.*
'|
  }
}

memory_barriers: {
  label: "Submission Flow & Memory Barriers"
  style: {
    fill: "#FFF8E7"
    stroke: "${colors.pointer}"
    stroke-width: 2
  }
  barrier_sequence: {
    shape: sequence_diagram
    user: Application
    rings: Memory (Rings/SQEs)
    kern: Linux Kernel

    user.t1 -> rings.t1: "1. Fill SQE fields (addr, len, opcode)"
    user."STORE_RELEASE: Tail must not be visible before SQE data"
    user.t2 -> rings.t2: "2. Update SQ.tail = (tail + 1)"
    user.t3 -> kern.t3: "3. io_uring_enter(SUBMIT) syscall"
    kern.t4 -> rings.t4: "4. LOAD_ACQUIRE: Read SQ.tail"
    kern.t5 -> rings.t5: "5. Consume SQEs up to tail"
  }
}

# Documentation / Notes Sections (Fixed 'near' usage for ELK)
cache_line_note: {
  label: |'md
### Cache Performance Design
- **SQE (64B):** Perfectly fits one L1 cache line.
- **CQE (16B):** 4 entries per 64B line; minimizes cache misses during reaping.
- **Index separation:** Head and Tail reside in separate cache lines to 
  prevent **False Sharing** between Kernel (Consumer) and User (Producer).
'|
  shape: rectangle
  style.fill: "#E1F5FE"
  style.stroke: "#01579B"
  near: top-right
}

size_reference: {
  label: |'md
### Mapping Size Reference (N=256)
- **SQ Ring:** ~1064 Bytes
- **SQE Array:** 256 * 64 = 16,384 Bytes
- **CQ Ring:** ~8212 Bytes (CQ entries = 2*SQ)
- **Total:** ~26 KB (Page aligned mmap)
'|
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#1B5E20"
  near: bottom-right
}

# Logical Connections
mmap_regions.region_sq_ring -> ownership_logic: "Defines Indices"
ownership_logic -> memory_barriers: "Enforces Protocol"