vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: {
  near: top-center
  shape: text
  label: ||md
    # io_uring_sqe Structure — 64-Byte Layout
    *Intel Manual Quality Specification*
    Size: 64 bytes (1 cache line) | Alignment: 64-byte aligned
  ||
}

# === STYLE CLASSES ===
classes: {
  header_field: {
    style: {
      fill: "#E8D5F0"
      stroke: "#6B46C1"
      stroke-width: 2
    }
  }
  data_field: {
    style: {
      fill: "#D4E8F8"
      stroke: "#2B6CB0"
      stroke-width: 2
    }
  }
  pointer_field: {
    style: {
      fill: "#FFE4C4"
      stroke: "#C05621"
      stroke-width: 2
    }
  }
  flag_field: {
    style: {
      fill: "#D4F0D4"
      stroke: "#2F855A"
      stroke-width: 2
    }
  }
  pad_field: {
    style: {
      fill: "#E8E8E8"
      stroke: "#718096"
      font-color: "#718096"
      stroke-dash: 3
    }
  }
  offset_text: {
    style: {
      font: mono
      font-size: 14
      font-color: "#4A5568"
      stroke-width: 0
    }
  }
  size_text: {
    style: {
      font: mono
      font-size: 12
      font-color: "#718096"
      stroke-width: 0
    }
  }
}

# === MEMORY LAYOUT CORE ===
io_uring_sqe: {
  grid-columns: 3
  grid-gap: 10
  style: {
    stroke: "#2D3748"
    stroke-width: 3
    fill: "#F7FAFC"
    border-radius: 4
  }

  # Offset Column
  off00: "0x00" { class: offset_text }
  # Field Column
  f00: "__u8 opcode" { class: header_field }
  # Size Column
  s00: "1B" { class: size_text }

  off01: "0x01" { class: offset_text }
  f01: "__u8 flags" { class: header_field }
  s01: "1B" { class: size_text }

  off02: "0x02" { class: offset_text }
  f02: "__u16 ioprio" { class: header_field }
  s02: "2B" { class: size_text }

  off04: "0x04" { class: offset_text }
  f04: "__s32 fd" { class: pointer_field }
  s04: "4B" { class: size_text }

  off08: "0x08" { class: offset_text }
  f08: "__u64 off / addr2" { class: data_field }
  s08: "8B" { class: size_text }

  off10: "0x10" { class: offset_text }
  f10: "__u64 addr" { class: data_field }
  s10: "8B" { class: size_text }

  off18: "0x18" { class: offset_text }
  f18: "__u32 len" { class: data_field }
  s18: "4B" { class: size_text }

  off1C: "0x1C" { class: offset_text }
  f1C: "rw_flags (union)" { class: flag_field }
  s1C: "4B" { class: size_text }

  off20: "0x20" { class: offset_text }
  f20: "__u64 user_data" { 
    class: header_field
    style.bold: true 
  }
  s20: "8B" { class: size_text }

  off28: "0x28" { class: offset_text }
  f28: "buf_index (union)" { class: pointer_field }
  s28: "2B" { class: size_text }

  off2A: "0x2A" { class: offset_text }
  f2A: "buf_group" { class: pointer_field }
  s2A: "2B" { class: size_text }

  off2C: "0x2C" { class: offset_text }
  f2C: "personality" { class: pad_field }
  s2C: "2B" { class: size_text }

  off2E: "0x2E" { class: offset_text }
  f2E: "splice_fd_in" { class: pad_field }
  s2E: "2B" { class: size_text }

  off30: "0x30" { class: offset_text }
  f30: "addr3 / cmd_p" { class: data_field }
  s30: "8B" { class: size_text }

  off38: "0x38" { class: offset_text }
  f38: "__pad2[1]" { class: pad_field }
  s38: "8B" { class: size_text }

  f*: {
    style.font: mono
    width: 320
    height: 32
  }
}

# === ANNOTATIONS ===
annot_ctrl: "Op Control (4B)" {
  style: {
    fill: "#FDF2F8"
    stroke: "#9D174D"
    border-radius: 4
    font-size: 11
  }
}

annot_fd: "File Context" {
  style: {
    fill: "#FFFBEB"
    stroke: "#92400E"
    border-radius: 4
    font-size: 11
  }
}

annot_data: "Data / Buffers (20B)" {
  style: {
    fill: "#EFF6FF"
    stroke: "#1E40AF"
    border-radius: 4
    font-size: 11
  }
}

annot_userdata: "Request Correlation" {
  style: {
    fill: "#F5F3FF"
    stroke: "#5B21B6"
    bold: true
    border-radius: 4
    font-size: 11
  }
}

annot_buf: "Fixed Buffer Selection" {
  style: {
    fill: "#FFFBEB"
    stroke: "#92400E"
    border-radius: 4
    font-size: 11
  }
}

# === CACHE LINE REPRESENTATION ===
cache_boundary: {
  style: {
    fill: transparent
    stroke: "#E53E3E"
    stroke-dash: 5
    stroke-width: 2
  }
  label: |md
    ### L1 Cache Line Boundary (64B)
    Aligned SQE prevents false sharing and double cache-misses.
  |
  label.near: outside-bottom-center
}

# === LEGEND ===
legend: {
  near: top-right
  style: {
    fill: "#FFFFFF"
    stroke: "#CBD5E0"
    shadow: true
  }
  
  title: "Legend" { 
    style: {
      bold: true
      underline: true
      font-size: 16
    }
  }
  
  h: "Header/Control" { class: header_field }
  d: "Data/Buffers" { class: data_field }
  f: "Operation Flags" { class: flag_field }
  p: "Pointers/FDs" { class: pointer_field }
  x: "Reserved/Pad" { class: pad_field }

  h.width: 180
  d.width: 180
  f.width: 180
  p.width: 180
  x.width: 180
}