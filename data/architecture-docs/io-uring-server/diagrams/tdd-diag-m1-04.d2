vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # io_uring_cqe Structure — 16-Byte Layout
  Completion Queue Entry (one cache line shared by 4 CQEs)
| {near: top-center}
direction: right
# Main CQE structure
cqe_container: {
  label: "struct io_uring_cqe (16 bytes)"
  style.fill: "#E8E8E8"
  style.stroke: "#333333"
  style.stroke-width: 2
  # Byte offset column
  offsets: {
    shape: sql_table
    label: "Offset"
    style.fill: "#9B59B6"
    row0: "0x00" {constraint: primary_key}
    row1: "0x08" {constraint: primary_key}
    row2: "0x0C" {constraint: primary_key}
  }
  # Field column
  fields: {
    shape: sql_table
    label: "Field"
    style.fill: "#3498DB"
    user_data: "user_data" {constraint: primary_key}
    res: "res" {constraint: primary_key}
    flags: "flags" {constraint: primary_key}
  }
  # Size column
  sizes: {
    shape: sql_table
    label: "Size"
    style.fill: "#27AE60"
    size1: "8 bytes" {constraint: primary_key}
    size2: "4 bytes" {constraint: primary_key}
    size3: "4 bytes" {constraint: primary_key}
  }
  # Type/Description column
  types: {
    shape: sql_table
    label: "Type / Description"
    style.fill: "#F39C12"
    type1: "__u64 (request ID)" {constraint: primary_key}
    type2: "__s32 (signed result)" {constraint: primary_key}
    type3: "__u32 (status flags)" {constraint: primary_key}
  }
}
# Visual byte layout
byte_layout: {
  label: "Byte Layout (little-endian)"
  # Row 1: user_data (bytes 0-7)
  row1_label: "0x00" {
    style.fill: "#9B59B6"
    style.font-color: white
    width: 60
  }
  byte0: "0" {style.fill: "#3498DB"; width: 40}
  byte1: "1" {style.fill: "#3498DB"; width: 40}
  byte2: "2" {style.fill: "#3498DB"; width: 40}
  byte3: "3" {style.fill: "#3498DB"; width: 40}
  byte4: "4" {style.fill: "#3498DB"; width: 40}
  byte5: "5" {style.fill: "#3498DB"; width: 40}
  byte6: "6" {style.fill: "#3498DB"; width: 40}
  byte7: "7" {style.fill: "#3498DB"; width: 40}
  user_data_label: "user_data (8 bytes)" {
    style.fill: transparent
    style.font-color: "#3498DB"
    style.bold: true
  }
  # Row 2: res (bytes 8-11)
  row2_label: "0x08" {
    style.fill: "#9B59B6"
    style.font-color: white
    width: 60
  }
  byte8: "8" {style.fill: "#E74C3C"; width: 40}
  byte9: "9" {style.fill: "#E74C3C"; width: 40}
  byte10: "A" {style.fill: "#E74C3C"; width: 40}
  byte11: "B" {style.fill: "#E74C3C"; width: 40}
  byte12_pad: "C" {style.fill: "#BDC3C7"; width: 40}
  byte13_pad: "D" {style.fill: "#BDC3C7"; width: 40}
  byte14_pad: "E" {style.fill: "#BDC3C7"; width: 40}
  byte15_pad: "F" {style.fill: "#BDC3C7"; width: 40}
  res_label: "res (4B) | flags (4B)" {
    style.fill: transparent
    style.font-color: "#333333"
    style.bold: true
  }
}
# res value interpretation
res_interpretation: {
  label: "res Field Interpretation"
  style.fill: "#FDF2E9"
  style.stroke: "#E74C3C"
  style.stroke-width: 2
  positive: {
    label: "res > 0  →  SUCCESS"
    style.fill: "#27AE60"
    style.font-color: white
  }
  positive_desc: |md
    Bytes successfully transferred
    (read: bytes read, write: bytes written)
  |
  zero: {
    label: "res = 0  →  EOF"
    style.fill: "#F39C12"
    style.font-color: white
  }
  zero_desc: |md
    End-of-file on read
    (connection closed by peer on socket)
  |
  negative: {
    label: "res < 0  →  ERROR"
    style.fill: "#E74C3C"
    style.font-color: white
  }
  negative_desc: |md
    **-res is the errno value**
    Example: res = -22 → EINVAL
    Use: strerror(-cqe->res)
  |
}
# flags field bits
flags_breakdown: {
  label: "flags Field Bits"
  style.fill: "#ECF0F1"
  style.stroke: "#34495E"
  bit_layout: {
    label: "Bit Layout (32 bits)"
    bits_31_20: "31:20" {style.fill: "#BDC3C7"; width: 60}
    bits_19_16: "19:16" {style.fill: "#F39C12"; width: 60}
    bits_15_0: "15:0" {style.fill: "#BDC3C7"; width: 60}
    reserved1_label: "reserved" {style.fill: transparent}
    buffer_label: "BUFFER" {style.fill: transparent; style.font-color: "#F39C12"}
    reserved2_label: "reserved" {style.fill: transparent}
  }
  flag_meanings: {
    label: ""
    buffer_flag: {
      label: "IORING_CQE_F_BUFFER (bit 16)"
      style.fill: "#F39C12"
    }
    buffer_desc: |md
      Set when provided buffer was selected.
      Buffer ID in bits [31:16] (shift right by 16).
    |
    more_flag: {
      label: "IORING_CQE_F_MORE (bit 17)"
      style.fill: "#3498DB"
    }
    more_desc: |md
      More CQEs will follow (multishot ops).
    |
    notif_flag: {
      label: "IORING_CQE_F_NOTIF (bit 18)"
      style.fill: "#9B59B6"
    }
    notif_desc: |md
      Zero-copy notification: buffer is safe.
    |
  }
}
# Code example
code_example: |go
  // CQE result handling pattern
  if (cqe->res > 0) {
      // Success: res contains byte count
      printf("Transferred %d bytes\n", cqe->res);
  } else if (cqe->res == 0) {
      // EOF
      printf("End of file\n");
  } else {
      // Error: -res is errno
      int err = -cqe->res;
      fprintf(stderr, "Error: %s\n", strerror(err));
  }
  // Buffer ID extraction (if provided buffers used)
  if (cqe->flags & IORING_CQE_F_BUFFER) {
      __u16 buf_id = cqe->flags >> IORING_CQE_BUFFER_SHIFT;
      void *data = buffer_pool[buf_id];
  }
|
# Cache line note
cache_note: |md
  **Cache Line Sharing:** Four CQEs (4 × 16 = 64 bytes) fit in one cache line.
  Harvesting CQEs sequentially has excellent cache locality.
| {
  style.fill: "#D5F5E3"
  style.stroke: "#27AE60"
}
# Legend
legend: {
  label: "Color Legend"
  style.fill: white
  style.stroke: "#333333"
  offset_col: "Offset column" {style.fill: "#9B59B6"}
  field_col: "Field / Data" {style.fill: "#3498DB"}
  size_col: "Size indicator" {style.fill: "#27AE60"}
  type_col: "Type / Description" {style.fill: "#F39C12"}
  error_col: "Error handling" {style.fill: "#E74C3C"}
  padding_col: "Padding / Reserved" {style.fill: "#BDC3C7"}
}
# Connections
cqe_container.offsets -> cqe_container.fields
cqe_container.fields -> cqe_container.sizes
cqe_container.sizes -> cqe_container.types
res_interpretation.positive -> res_interpretation.positive_desc
res_interpretation.zero -> res_interpretation.zero_desc
res_interpretation.negative -> res_interpretation.negative_desc
flags_breakdown.bit_layout -> flags_breakdown.flag_meanings
flags_breakdown.flag_meanings.buffer_flag -> flags_breakdown.flag_meanings.buffer_desc
flags_breakdown.flag_meanings.more_flag -> flags_breakdown.flag_meanings.more_desc
flags_breakdown.flag_meanings.notif_flag -> flags_breakdown.flag_meanings.notif_desc