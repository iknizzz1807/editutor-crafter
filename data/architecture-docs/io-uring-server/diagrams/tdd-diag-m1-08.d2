vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Fixed Buffer Registration — Memory Pinning
  **Zero-Copy I/O Optimization**
| {near: top-center}

direction: right

# User Space Container
user_space: "User Space (Ring Owner)" {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2

  # iovec array: Virtual Memory View
  iovec_array: "iovec Array (Memory Descriptors)" {
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    
    iovec_0: "iovec[0]\n━━━━━━━━━━━\niov_base: 0x7f1000\niov_len: 4096" {
      tooltip: "Page aligned virtual address"
    }
    iovec_1: "iovec[1]\n━━━━━━━━━━━\niov_base: 0x7f2000\niov_len: 4096"
    iovec_2: "iovec[2]\n━━━━━━━━━━━\niov_base: 0x7f3000\niov_len: 4096"
    iovec_n: "iovec[n-1]\n━━━━━━━━━━━\niov_base: 0x7f...\niov_len: 4096" {
      style.stroke-dash: 3
    }
    
    iovec_0 -> iovec_1 -> iovec_2 -> iovec_n {style.stroke: transparent}
  }

  # Registration syscall - The "Setup" cost
  register_call: "syscall(__NR_io_uring_register,\n  ring_fd,\n  IORING_REGISTER_BUFFERS,\n  iovecs, n)" {
    shape: code
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.font: mono
    width: 320
  }

  # SQE with fixed buffer - The "Fast Path"
  sqe_fixed: "SQE: IORING_OP_READ_FIXED\n━━━━━━━━━━━━━━━━━━━━━━━━\nfd: registered_file_idx\nbuf_index: 2  ← Fast Lookup\nlen: 4096\noff: 8192" {
    shape: code
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.font: mono
  }
}

# Kernel Space Container
kernel_space: "Kernel Space (Ring Context)" {
  style.fill: "#FFEBEE"
  style.stroke: "#D32F2F"
  style.stroke-width: 2

  # Page pinning process: Internal validation and pinning
  pin_process: "Buffer Registration Logic" {
    style.fill: "#FFCDD2"
    
    validate: "1. Validate\niovec range" {
      style.fill: white
      shape: diamond
    }
    
    pin_pages: "2. Pin Pages\n(get_user_pages_fast)" {
      style.fill: white
      style.stroke: "#D32F2F"
      style.stroke-width: 2
      tooltip: "Sets page->count and prevents swapping"
    }
    
    build_table: "3. Build Internal\nMap Table" {
      style.fill: white
    }
    
    validate -> pin_pages: "success" {style.stroke: "#388E3C"}
    pin_pages -> build_table
  }

  # Pinned buffer table: Physical Memory View
  buffer_table: "Registered Buffer Table (io_mapped_ubuf)" {
    style.fill: "#B3E5FC"
    style.stroke: "#0288D1"
    
    entry_0: "Index 0\nphys: 0x1A3B000" { style.font: mono }
    entry_1: "Index 1\nphys: 0x1A3C000" { style.font: mono }
    entry_2: "Index 2\nphys: 0x1A3D000" { 
      style.font: mono
      style.stroke-width: 3
      style.stroke: "#7B1FA2"
    }
    entry_n: "Index n-1\nphys: 0x1A3..." {
      style.stroke-dash: 3
      style.font: mono
    }
    
    entry_0 -> entry_1 -> entry_2 -> entry_n {style.stroke: transparent}
  }

  # DMA path - The hardware interface
  dma_engine: "DMA Controller\n(PCIe Bus Master)" {
    shape: hexagon
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    style.multiple: true
  }
}

# Storage device
storage: "NVMe Storage Device" {
  shape: cylinder
  style.fill: "#CFD8DC"
  style.stroke: "#455A64"
}

# High-Detail Connections
user_space.iovec_array -> user_space.register_call: "1. Pass iovecs" {
  style.stroke: "#F9A825"
  style.stroke-width: 2
}

user_space.register_call -> kernel_space.pin_process.validate: "2. Registration Syscall" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
  style.animated: true
}

kernel_space.pin_process.build_table -> kernel_space.buffer_table: "3. Store Phys Addrs" {
  style.stroke: "#0288D1"
  style.stroke-width: 2
}

user_space.sqe_fixed -> kernel_space.buffer_table: "4. Fast Indexing (O(1))" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  style.animated: true
}

kernel_space.buffer_table.entry_2 -> kernel_space.dma_engine: "5. Resolved Phys Addr" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 5
  style.stroke-width: 2
}

kernel_space.dma_engine -> storage: "6. DMA Transfer" {
  style.stroke: "#455A64"
  style.stroke-width: 3
  label: "Zero-Copy Path"
}

# Legend and Annotations
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#9E9E9E"
  label: "Implementation Legend"
  
  syscall_boundary: "Control Plane (High Latency)" {
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  data_ref: "Data Reference (Zero-Latency)" {
    style.stroke: "#7B1FA2"
  }
  phys_path: "Physical DMA Path" {
    style.stroke: "#455A64"
    style.stroke-width: 3
  }
}

annotation: |md
  ### Engineering Specs: READ_FIXED
  1. **Registration (Setup)**:
     - Invokes `get_user_pages()` to pin memory into RAM.
     - Increases `locked_vm` rlimit for the process.
     - Creates `io_mapped_ubuf` structures in kernel heap.
  2. **I/O Execution (Fast Path)**:
     - No `copy_from_user` of iovec structures per I/O.
     - No page table walk per request.
     - No memory allocation/deallocation in the I/O path.
  3. **Hardware Requirements**:
     - Buffer must be page-aligned to prevent DMA crossing page boundaries.
     - Direct I/O (O_DIRECT) semantics apply.
| {
  near: bottom-center
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
}