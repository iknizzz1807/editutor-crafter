vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    kernel: "#3B82F6"
    app: "#10B981"
    buffer: "#F59E0B"
    arrow-kernel: "#EF4444"
    arrow-app: "#22C55E"
  }
}
title: |md
  # Provided Buffer Ring Architecture
  Kernel-managed buffer selection for zero-allocation receives
| {near: top-center}
direction: right
# Ring Header Structure
ring_header: {
  label: "io_uring_buf_ring\n(Shared Memory)"
  style.fill: "${colors.header}"
  style.stroke: "#7C3AED"
  style.font-color: white
  header_region: {
    label: "Ring Header"
    style.fill: "#A78BFA"
    style.stroke: "#7C3AED"
    tail_ptr: {
      label: "tail\n(uint16_t *)"
      shape: hexagon
      style.fill: "${colors.app}"
      style.font-color: white
    }
    tail_desc: |md
      Application writes here
      to add buffers
    |
    tail_desc.shape: text
    tail_desc.style.font-size: 12
    tail_desc.style.font-color: "#6B7280"
  }
}
# Buffer Entries Array
buffer_entries: {
  label: "Buffer Entries Array\n(io_uring_buf[N])"
  style.fill: "#1F2937"
  style.stroke: "#374151"
  style.font-color: white
  entry_0: {
    label: "[0]\naddr: 0x7f001000\nlen: 8192\nbid: 0"
    shape: queue
    style.fill: "${colors.buffer}"
    style.stroke: "#D97706"
    style.font-color: black
    style.font-size: 11
  }
  entry_1: {
    label: "[1]\naddr: 0x7f003000\nlen: 8192\nbid: 1"
    shape: queue
    style.fill: "${colors.buffer}"
    style.stroke: "#D97706"
    style.font-color: black
    style.font-size: 11
  }
  entry_2: {
    label: "[2]\naddr: 0x7f005000\nlen: 8192\nbid: 2"
    shape: queue
    style.fill: "${colors.buffer}"
    style.stroke: "#D97706"
    style.font-color: black
    style.font-size: 11
  }
  entry_head: {
    label: "HEAD\n← Kernel reads"
    shape: queue
    style.fill: "${colors.kernel}"
    style.stroke: "#1D4ED8"
    style.font-color: white
    style.font-size: 11
    style.bold: true
  }
  entry_gap: {
    label: "..."
    shape: text
    style.font-color: "#9CA3AF"
  }
  entry_tail: {
    label: "TAIL\n← App writes"
    shape: queue
    style.fill: "${colors.app}"
    style.stroke: "#059669"
    style.font-color: white
    style.font-size: 11
    style.bold: true
  }
  entry_n: {
    label: "[N-1]\naddr: 0x7f...\nlen: 8192\nbid: N-1"
    shape: queue
    style.fill: "#374151"
    style.stroke: "#4B5563"
    style.font-color: "#9CA3AF"
    style.font-size: 11
  }
}
# Kernel Side
kernel_consumer: {
  label: "KERNEL SPACE"
  style.fill: "${colors.kernel}"
  style.stroke: "#1D4ED8"
  style.font-color: white
  style.opacity: 0.9
  kernel_logic: {
    label: "RECV with BUFFER_SELECT"
    style.fill: "#1E40AF"
    style.stroke: "#1D4ED8"
    select_buf: |md
      1. Read `head` position
      2. Get `io_uring_buf[head]`
      3. DMA data to `buf.addr`
      4. Return `bid` in CQE flags
      5. Increment `head`
    |
    select_buf.shape: text
    select_buf.style.font-size: 11
    select_buf.style.font-color: white
  }
  head_ptr: {
    label: "head\n(internal)"
    shape: hexagon
    style.fill: "${colors.kernel}"
    style.stroke: "#1D4ED8"
    style.font-color: white
  }
}
# Application Side  
app_producer: {
  label: "USER SPACE"
  style.fill: "${colors.app}"
  style.stroke: "#059669"
  style.font-color: white
  style.opacity: 0.9
  app_logic: {
    label: "Buffer Replenishment"
    style.fill: "#047857"
    style.stroke: "#059669"
    return_buf: |md
      1. Process received data
      2. Call `io_uring_buf_ring_add()`
      3. Set `addr`, `len`, `bid`
      4. Call `io_uring_buf_ring_advance()`
      5. `tail` incremented
    |
    return_buf.shape: text
    return_buf.style.font-size: 11
    return_buf.style.font-color: white
  }
}
# Actual Data Buffers
data_buffers: {
  label: "Data Buffers\n(Pre-allocated Pool)"
  style.fill: "#F3F4F6"
  style.stroke: "#9CA3AF"
  buf_0: {
    label: "8KB\nBuffer 0"
    shape: cylinder
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
  }
  buf_1: {
    label: "8KB\nBuffer 1"
    shape: cylinder
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
  }
  buf_2: {
    label: "8KB\nBuffer 2"
    shape: cylinder
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
  }
  buf_n: {
    label: "8KB\nBuffer N"
    shape: cylinder
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
  }
}
# Connections
ring_header.header_region.tail_ptr -> buffer_entries.entry_tail: "tail points to\nnext write slot" {
  style.stroke: "${colors.app}"
  style.stroke-width: 2
  style.stroke-dash: 3
}
kernel_consumer.head_ptr -> buffer_entries.entry_head: "head points to\nnext available" {
  style.stroke: "${colors.kernel}"
  style.stroke-width: 2
}
# Kernel consumes
buffer_entries.entry_head -> kernel_consumer: "SELECTS" {
  style.stroke: "${colors.arrow-kernel}"
  style.stroke-width: 3
  style.animated: true
  label: "Kernel consumes\nbuffer for RECV"
}
# App replenishes
app_producer -> buffer_entries.entry_tail: "ADDS" {
  style.stroke: "${colors.arrow-app}"
  style.stroke-width: 3
  style.animated: true
  label: "App returns\nbuffer to ring"
}
# Buffer address references
buffer_entries.entry_0 -> data_buffers.buf_0: "addr" {style.stroke: "${colors.buffer}"; style.stroke-dash: 2}
buffer_entries.entry_1 -> data_buffers.buf_1: "addr" {style.stroke: "${colors.buffer}"; style.stroke-dash: 2}
buffer_entries.entry_2 -> data_buffers.buf_2: "addr" {style.stroke: "${colors.buffer}"; style.stroke-dash: 2}
# DMA from kernel to buffer
kernel_consumer.kernel_logic -> data_buffers.buf_1: "DMA\ndirectly\nto buffer" {
  style.stroke: "${colors.arrow-kernel}"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.animated: true
}
# Legend
legend: {
  near: bottom-center
  style.fill: "#F9FAFB"
  style.stroke: "#E5E7EB"
  legend_title: "Ring State Flow" {shape: text; style.bold: true}
  free_buf: {
    label: "Available\n(in ring)"
    shape: square
    style.fill: "${colors.buffer}"
    style.stroke: "#D97706"
  }
  in_use: {
    label: "In Use\n(awaiting return)"
    shape: square
    style.fill: "#9CA3AF"
    style.stroke: "#6B7280"
  }
  head_marker: {
    label: "HEAD\n(kernel position)"
    shape: square
    style.fill: "${colors.kernel}"
    style.stroke: "#1D4ED8"
  }
  tail_marker: {
    label: "TAIL\n(app position)"
    shape: square
    style.fill: "${colors.app}"
    style.stroke: "#059669"
  }
}
# Size annotation
size_note: |md
  **Registration:**
  c
  struct io_uring_buf_reg reg = {
    .ring_addr = (uint64_t)buf_ring,
    .ring_entries = N,
    .bgid = BUFFER_GROUP_ID
  };
  io_uring_register(ring_fd, 
    IORING_REGISTER_PBUF_RING, 
    &reg, 1);
  
| {
  near: bottom-right
  shape: rectangle
  style.fill: "#F3F4F6"
  style.stroke: "#D1D5DB"
  style.font-size: 11
}