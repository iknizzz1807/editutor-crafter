vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Registered File Descriptor Table
  ## Eliminating Per-Operation Kernel Lookup via io_uring
| {near: top-center}

# ============================================
# Traditional Path (Left Side)
# ============================================
traditional_path: "Traditional Path: fdget_pos()" {
  style: {
    fill: "#FFF0F0"
    stroke: "#CC0000"
    stroke-width: 2
  }

  app_fd_trad: "Application fd = 7" {
    shape: rectangle
    style: {
      fill: "#FFCCCC"
      stroke: "#990000"
      font: mono
      bold: true
    }
  }

  step1_lookup: |md
    **Step 1: fdtable Lookup**
    ~10-30ns
    - Bounds check: `fd < max_fds`
    - Array access: `files->fd_array[fd]`
    - NULL check
  | {
    shape: rectangle
    style.fill: "#FFE6E6"
  }

  step2_refcount: |md
    **Step 2: Reference Count**
    ~20-50ns (atomic)
    - `atomic_long_inc(&file->f_count)`
    - Cache line bounce possible
  | {
    shape: rectangle
    style.fill: "#FFE6E6"
  }

  step3_lock: |md
    **Step 3: Position Lock**
    ~20-100ns
    - `mutex_lock(&file->f_pos_lock)`
    - Read `f_pos` value
  | {
    shape: rectangle
    style.fill: "#FFE6E6"
  }

  step4_validate: |md
    **Step 4: Buffer Validation**
    ~50-100ns
    - Is address in userspace?
    - Is memory mapped?
    - VMA traversal
  | {
    shape: rectangle
    style.fill: "#FFE6E6"
  }

  overhead_box: |md
    **Total Overhead: 100-280ns**
    Per operation, every time
  | {
    shape: rectangle
    style: {
      fill: "#FF9999"
      stroke: "#CC0000"
      stroke-width: 2
      bold: true
    }
  }

  app_fd_trad -> step1_lookup: "syscall entry"
  step1_lookup -> step2_refcount
  step2_refcount -> step3_lock
  step3_lock -> step4_validate
  step4_validate -> overhead_box
}

# ============================================
# Registered Path (Right Side)
# ============================================
registered_path: "Registered Path: Direct Pointer" {
  style: {
    fill: "#F0FFF0"
    stroke: "#006600"
    stroke-width: 2
  }

  reg_index: "Registered Index = 2" {
    shape: rectangle
    style: {
      fill: "#CCFFCC"
      stroke: "#006600"
      font: mono
      bold: true
    }
  }

  direct_deref: |md
    **Direct Pointer Dereference**
    ~5-10ns
    Single memory access:
    `registered_files[index]`
    Pre-validated at registration
  | {
    shape: rectangle
    style: {
      fill: "#E6FFE6"
      stroke: "#006600"
    }
  }

  savings_box: |md
    **Overhead Eliminated: 95-270ns**
    Per operation savings
  | {
    shape: rectangle
    style: {
      fill: "#99FF99"
      stroke: "#006600"
      stroke-width: 2
      bold: true
    }
  }

  reg_index -> direct_deref: "SQE with\nIOSQE_FIXED_FILE"
  direct_deref -> savings_box
}

# ============================================
# Kernel File Table (Center)
# ============================================
kernel_table: "Kernel Registered File Table" {
  style: {
    fill: "#E6E6FF"
    stroke: "#6666CC"
    stroke-width: 2
  }

  table_header: |md
    **struct file *registered_files[]**
    Allocated in io_uring_ctx
  | {
    shape: rectangle
    style: {
      fill: "#CCCCFF"
      bold: true
    }
  }

  index_0: "Index 0" {
    shape: rectangle
    style: {
      fill: "#E6E6FF"
      font: mono
    }
    ptr_0: "→ struct file * (fd=3)" {
      shape: rectangle
      style: {
        fill: "#FFFFCC"
        stroke: "#CCCC00"
      }
    }
  }

  index_1: "Index 1" {
    shape: rectangle
    style: {
      fill: "#E6E6FF"
      font: mono
    }
    ptr_1: "→ struct file * (fd=5)" {
      shape: rectangle
      style: {
        fill: "#FFFFCC"
        stroke: "#CCCC00"
      }
    }
  }

  index_2: "Index 2" {
    shape: rectangle
    style: {
      fill: "#CCFFCC"
      stroke: "#006600"
      stroke-width: 3
      bold: true
      font: mono
    }
    ptr_2: "→ struct file * (fd=7)" {
      shape: rectangle
      style: {
        fill: "#FFFFCC"
        stroke: "#CCCC00"
        bold: true
      }
    }
  }

  index_3: "Index 3" {
    shape: rectangle
    style: {
      fill: "#E6E6FF"
      font: mono
    }
    ptr_3: "→ struct file * (fd=12)" {
      shape: rectangle
      style: {
        fill: "#FFFFCC"
        stroke: "#CCCC00"
      }
    }
  }

  table_header -> index_0
  index_0 -> index_1
  index_1 -> index_2
  index_2 -> index_3
}

# ============================================
# SQE Comparison
# ============================================
sqe_comparison: "SQE Field Comparison" {
  style: {
    fill: "#F5F5F5"
    stroke: "#666666"
  }

  sqe_traditional: {
    label: ||md
    **Traditional SQE**
    c
    sqe->opcode = IORING_OP_READ
    sqe->fd = 7          // actual fd
    sqe->flags = 0       // no FIXED_FILE
    sqe->addr = buf
    sqe->len = 4096
    
    ||
    shape: rectangle
    style: {
      fill: "#FFCCCC"
      font: mono
    }
  }

  sqe_registered: {
    label: ||md
    **Registered SQE**
    c
    sqe->opcode = IORING_OP_READ
    sqe->fd = 2          // INDEX into table
    sqe->flags = IOSQE_FIXED_FILE
    sqe->addr = buf
    sqe->len = 4096
    
    ||
    shape: rectangle
    style: {
      fill: "#CCFFCC"
      font: mono
    }
  }

  sqe_traditional -> sqe_registered: "Same operation,\nless kernel work" {
    style: {
      stroke: "#006600"
      stroke-width: 2
      stroke-dash: 5
    }
  }
}

# ============================================
# Process File Descriptor Table (Traditional Only)
# ============================================
process_fdtable: "Process fd_table (Traditional Only)" {
  style: {
    fill: "#FFF5E6"
    stroke: "#CC6600"
  }

  fdtable_header: |md
    **files_struct → fdtable**
    Per-process, requires lookup
  | {
    shape: rectangle
    style: {
      fill: "#FFE6CC"
      bold: true
    }
  }

  fd_array: "fd_array[256]" {
    shape: rectangle
    style: {
      fill: "#FFF5E6"
      font: mono
    }
    fd_0: "[0] → stdin"
    fd_1: "[1] → stdout"
    fd_2: "[2] → stderr"
    fd_3: "[3] → socket"
    fd_5: "[5] → file"
    fd_7: "[7] → our_file" {
      style: {
        fill: "#FFCCCC"
        bold: true
        stroke: "#CC0000"
      }
    }
    fd_12: "[12] → pipe"
  }
}

# ============================================
# Connections
# ============================================

# Traditional path goes through process fdtable
traditional_path.app_fd_trad -> process_fdtable.fd_array.fd_7: "Must traverse\nper-process table" {
  style: {
    stroke: "#CC0000"
    stroke-dash: 3
  }
}

# Registered path bypasses to kernel table directly
registered_path.reg_index -> kernel_table.index_2: "Direct index\ninto kernel array" {
  style: {
    stroke: "#006600"
    stroke-width: 2
    animated: true
  }
}

# Show the mapping
kernel_table.index_2.ptr_2 -> process_fdtable.fd_array.fd_7: "Points to same\nstruct file" {
  style: {
    stroke: "#666666"
    stroke-dash: 5
  }
}

# SQE connection
sqe_comparison.sqe_traditional -> traditional_path.app_fd_trad: "uses" {
  style.stroke: "#CC0000"
}
sqe_comparison.sqe_registered -> registered_path.reg_index: "uses" {
  style: {
    stroke: "#006600"
    stroke-width: 2
  }
}

# ============================================
# Performance Summary
# ============================================
perf_summary: ||md
  ### Performance Impact at Scale
  | Scenario | Traditional | Registered | Savings |
  |----------|-------------|------------|---------|
  | 100K ops/sec | 10-28ms CPU | 0.5-1ms CPU | 90-95% |
  | 1M ops/sec | 100-280ms CPU | 5-10ms CPU | 95%+ |

  **Key Insight:** The savings compound with batching.
  With 64 ops per batch, registration saves
  95-270ns per IO by skipping atomic increments
  and fdtable traversals.
|| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#F0F0F0"
    stroke: "#666666"
    stroke-width: 2
  }
}