vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Direct I/O Alignment Requirements (Intel SDM Grade)
  `O_DIRECT` enforces strict alignment for DMA transfers to bypass Kernel Page Cache.
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# STYLING CLASSES
# -----------------------------------------------------------------------------------------
classes: {
  memory_segment: {
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
  header_seg: {
    style: {
      stroke-width: 2
      border-radius: 4
      fill: "#D1C4E9" # Purple
    }
  }
  data_seg: {
    style: {
      stroke-width: 2
      border-radius: 4
      fill: "#BBDEFB" # Blue
    }
  }
  error_seg: {
    style: {
      stroke-width: 2
      border-radius: 4
      fill: "#FFCDD2" # Red
    }
  }
  padding_seg: {
    style: {
      stroke-width: 2
      border-radius: 4
      fill: "#CFD8DC" # Gray
    }
  }
  success_border: {
    style: {
      stroke: "#2E7D32"
      stroke-width: 4
    }
  }
  fail_border: {
    style: {
      stroke: "#C62828"
      stroke-width: 4
    }
  }
}

# -----------------------------------------------------------------------------------------
# ALIGNED REQUEST (SUCCESS)
# -----------------------------------------------------------------------------------------
aligned_scen: "✓ CASE 01: FULLY ALIGNED REQUEST" {
  class: success_border
  
  memory_map: {
    label: "Memory / File Mapping View"
    
    page_boundary: {
      label: "4096B Page Boundary"
      style: {
        stroke-dash: 5
        stroke: black
        stroke-width: 3
      }
    }
    
    buffer: "User Space Buffer" {
      class: data_seg
      label: ||md
        **Buffer Address (Pointer)**
        `0x7F00_0000` (4KB Aligned)
        `Offset: 0B`
      ||
      width: 400
      height: 100
    }
    
    file_ptr: "Storage Media Block" {
      class: data_seg
      label: ||md
        **LBA / File Offset**
        `8192 bytes` (2 Blocks)
        `8192 % 4096 = 0`
      ||
      width: 400
      height: 80
    }
    
    xfer: "DMA Transfer Size" {
      class: data_seg
      label: ||md
        **Payload Length**
        `16384 bytes` (4 Blocks)
        `16384 % 4096 = 0`
      ||
      width: 400
      height: 80
    }
    
    buffer -> file_ptr: "DMA Start"
    file_ptr -> xfer: "Sequential IO"
  }
  
  status: "Result: 0 (SUCCESS)" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      font-color: "#1B5E20"
      bold: true
    }
  }
  memory_map.xfer -> status
}

# -----------------------------------------------------------------------------------------
# MISALIGNED BUFFER ADDRESS
# -----------------------------------------------------------------------------------------
misalign_buf: "✗ CASE 02: MISALIGNED VIRTUAL ADDR" {
  class: fail_border
  
  mem_fault: {
    label: "Memory Layout Violation"
    
    bad_ptr: "Unsafe Buffer Address" {
      class: error_seg
      label: ||md
        **Buffer Address**
        `0x7F00_0380`
        `0x380 (896) % 4096 != 0`
      ||
      width: 400
      height: 120
    }
    
    padding: "Hardware Misalignment Gap" {
      class: padding_seg
      label: "896 Bytes Offset From Page"
      height: 40
    }
    
    bad_ptr -> padding: "CPU <-> DMA Controller Conflict"
  }
  
  status: "Result: -EINVAL (Invalid Argument)" {
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      font-color: "#B71C1C"
      bold: true
    }
  }
  mem_fault.padding -> status
}

# -----------------------------------------------------------------------------------------
# MISALIGNED OFFSET
# -----------------------------------------------------------------------------------------
misalign_off: "✗ CASE 03: MISALIGNED FILE OFFSET" {
  class: fail_border
  
  off_fault: {
    label: "Block Device Violation"
    
    valid_buf: "Aligned Buffer" {
      class: data_seg
      label: "Addr: 0x7F00_0000 ✓"
      width: 400
    }
    
    invalid_off: "Misaligned File Offset" {
      class: error_seg
      label: ||md
        **Offset: 1000 bytes**
        `1000 % 512 (Sector) != 0`
        `1000 % 4096 (Block) != 0`
      ||
      width: 400
      height: 100
    }
    
    valid_buf -> invalid_off: "Illegal Seek"
  }
  
  status: "Result: -EINVAL" {
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      font-color: "#B71C1C"
      bold: true
    }
  }
  off_fault.invalid_off -> status
}

# -----------------------------------------------------------------------------------------
# ALIGNMENT RULES PANEL (INTEL SDM STYLE TABLE)
# -----------------------------------------------------------------------------------------
rules_panel: {
  near: bottom-center
  shape: rectangle
  width: 900
  style: {
    fill: "#E1F5FE"
    stroke: "#01579B"
    stroke-width: 2
  }
  
  content: ||md
    ### System Architecture Alignment Requirements (O_DIRECT)
    
    | Parameter        | Mathematical Invariant        | Storage Layer | Alignment Requirement |
    |------------------|-------------------------------|---------------|-----------------------|
    | `*buf` (Address) | `addr & (page_size - 1) == 0` | Memory (MMU)  | 4096 Bytes (Typical)  |
    | `offset` (Seek)  | `offset % block_size == 0`    | FS / VFS      | 512B (Sector) or 4KB  |
    | `count` (Length) | `len % block_size == 0`       | Hardware Bus  | Multiple of Block     |
    
    **Implementation Note:**
    Use `posix_memalign(&buf, sysconf(_SC_PAGESIZE), size)` to ensure cross-platform compliance.
    Direct I/O bypasses the page cache, meaning the CPU cache and storage media are not kept coherent by the kernel.
  ||
}

# Grouping for visual separation
aligned_scen -> misalign_buf: {style.stroke-width: 0}
misalign_buf -> misalign_off: {style.stroke-width: 0}