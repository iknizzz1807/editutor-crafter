vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Async Read Request Structure — Memory Layout
direction: right

title: |md
  ## `async_read_op` Structure (64 bytes)
  Cache-line aligned for optimal memory access
| {near: top-center}

# Memory regions container
memory_layout: {
  # Offset labels (left side)
  offsets: {
    shape: text
    label: |md
      **Offset**
      `0x00`
      `0x08`
      `0x0C`
      `0x10`
      `0x18`
      `0x20`
      `0x28`
      `0x30`
      `0x38`
      `0x3C`
    |
    style.font: mono
    style.font-size: 14
  }

  # Field definitions (center)
  fields: {
    shape: sql_table
    label: "Memory Layout (Ordered)"
    
    user_data: "uint64"
    file_index: "uint32"
    internal_pad: "uint32" {style.fill: "#EEEEEE"}
    start_offset: "int64"
    current_offset: "int64"
    total_requested: "size_t"
    bytes_completed: "size_t"
    buffer_ptr: "void*" {style.fill: "#FFF3E0"}
    status: "enum (uint32)"
    error_code: "int32"
  }
  
  # Remove default constraint text
  fields.user_data.constraint: ""
  fields.file_index.constraint: ""
  fields.internal_pad.constraint: "Padding"
  fields.start_offset.constraint: ""
  fields.current_offset.constraint: ""
  fields.total_requested.constraint: ""
  fields.bytes_completed.constraint: ""
  fields.buffer_ptr.constraint: "Pointer"
  fields.status.constraint: ""
  fields.error_code.constraint: ""

  fields.style.fill: "#E3F2FD"
  fields.style.stroke: "#1565C0"

  # Size annotations (right side)
  sizes: {
    shape: text
    label: |md
      **Size**
      8 bytes
      4 bytes
      4 bytes
      8 bytes
      8 bytes
      8 bytes
      8 bytes
      8 bytes
      4 bytes
      4 bytes
    |
    style.font: mono
    style.font-size: 14
  }
}

memory_layout.offsets -> memory_layout.fields: {style.opacity: 0}
memory_layout.fields -> memory_layout.sizes: {style.opacity: 0}

# Field descriptions below
descriptions: {
  direction: right
  grid-columns: 2
  grid-gap: 40
  
  user_data_desc: {
    shape: rectangle
    label: |md
      **user_data** (8B)
      Application identifier for callback matching.
      Copied from SQE to CQE for request correlation.
    |
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  
  file_index_desc: {
    shape: rectangle
    label: |md
      **file_index** (4B)
      Index into registered file descriptor table.
      Enables O(1) kernel file lookup via IOSQE_FIXED_FILE.
    |
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  
  offset_desc: {
    shape: rectangle
    label: |md
      **start_offset / current_offset** (8B each)
      `start_offset`: Original requested file position.
      `current_offset`: Updated after short reads for resubmission.
    |
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2
  }
  
  bytes_desc: {
    shape: rectangle
    label: |md
      **total_requested / bytes_completed** (8B each)
      Track partial read progress across short reads.
      Resubmit when `bytes_completed < total_requested`.
    |
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2
  }
  
  buffer_desc: {
    shape: rectangle
    label: |md
      **buffer_ptr** (8B)
      Pointer to fixed buffer from registered pool.
      MUST NOT be reused while operation is in-flight.
    |
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    style.stroke-width: 2
  }
  
  status_desc: {
    shape: rectangle
    label: |md
      **status / error_code** (4B each)
      State machine: PENDING → PARTIAL → COMPLETE/ERROR.
      Negative errno stored on failure for diagnostics.
    |
    style.fill: "#EDE7F6"
    style.stroke: "#5E35B1"
    style.stroke-width: 2
  }
}

memory_layout -> descriptions: {style.opacity: 0}

# Status enum detail
status_enum: {
  label: |md
    ### Status Enum Values
  |
  near: bottom-left
  grid-columns: 2
  
  pending: {
    shape: rectangle
    label: "READ_REQ_SUBMITTED\nSQE submitted, awaiting CQE"
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
  partial: {
    shape: rectangle
    label: "READ_REQ_PARTIAL\nShort read, resubmitting"
    style.fill: "#FFECB3"
    style.stroke: "#FF8F00"
  }
  complete: {
    shape: rectangle
    label: "READ_REQ_COMPLETE\nAll bytes read successfully"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  error: {
    shape: rectangle
    label: "READ_REQ_ERROR\nOperation failed (check error_code)"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
}

# Total size annotation
total_size: {
  shape: rectangle
  label: |md
    **Total: 64 bytes (one cache line)**
    Aligned to 64-byte boundary for cache efficiency.
    No false sharing with adjacent structures.
  |
  near: bottom-center
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    stroke-width: 3
    bold: true
  }
}