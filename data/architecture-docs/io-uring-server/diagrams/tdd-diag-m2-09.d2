vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

title: {
  label: ||md
    # File I/O Performance Analysis: pread vs io_uring
    **Environment:** Linux Kernel 6.2 | NVMe Gen4 SSD (PCIe 4.0 x4)
    **Workload:** 1,000 Random Reads | 4KB Block Size | Single Thread
    **Architecture:** x86_64 User-Kernel Ring Buffer Synchronization
  ||
  near: top-center
  style: {
    stroke-width: 0
    font-size: 16
    font-color: "#1a237e"
  }
}

# Technical Context & Definitions
legend: {
  near: top-right
  shape: rectangle
  style: {
    fill: "#f8f9fa"
    stroke: "#78909c"
    stroke-dash: 2
    border-radius: 10
    shadow: true
  }
  label: ||md
    ### 🛠️ Subsystem Configuration
    | Feature | Sync pread | io_uring Registered |
    | :--- | :--- | :--- |
    | **Mapping** | `copy_to_user` | `Fixed Buffers` (DMA) |
    | **FD Resolution** | Per-call | `Fixed Files` (Pre-indexed) |
    | **Submissions** | Blocking Syscall | Ring-Buffer SQEs |
    | **Completions** | Return value | Ring-Buffer CQEs |
  ||
}

# Main Analysis Container
results: {
  style: {
    fill: white
    stroke: "#263238"
    stroke-width: 3
    border-radius: 15
    shadow: true
  }

  # 1. THROUGHPUT VISUALIZATION (IOPS)
  throughput_section: {
    label: "I. Throughput Efficiency (Total Ops/Sec)"
    style: {
      fill: "#f1f8e9"
      stroke: "#689f38"
      border-radius: 12
      bold: true
    }

    # Baseline representation
    pread_perf: {
      shape: rectangle
      width: 250
      height: 80
      style: {
        fill: "#ef5350"
        stroke: "#b71c1c"
        stroke-width: 2
        border-radius: 4
      }
      label: ||md
        **[BASE] pread**
        `15,000 IOPS`
        Efficiency: 100%
      ||
    }

    # Batched representation
    batched_perf: {
      shape: rectangle
      width: 500
      height: 80
      style: {
        fill: "#29b6f6"
        stroke: "#01579b"
        stroke-width: 2
        border-radius: 4
      }
      label: ||md
        **io_uring (Batched)**
        `35,000 IOPS`
        Efficiency: 233%
      ||
    }

    # Peak Optimized representation
    optimized_perf: {
      shape: rectangle
      width: 650
      height: 80
      style: {
        fill: "#66bb6a"
        stroke: "#1b5e20"
        stroke-width: 3
        border-radius: 4
        shadow: true
      }
      label: ||md
        **io_uring (Registered)**
        `50,000 IOPS`
        Efficiency: 333%
      ||
    }

    # Layout anchors for bar alignment
    pread_perf -> batched_perf -> optimized_perf: { style.opacity: 0 }
  }

  # 2. LATENCY MICRO-METRICS
  latency_section: {
    label: "II. Latency Distribution (μs)"
    style: {
      fill: "#fffde7"
      stroke: "#fbc02d"
      border-radius: 12
    }

    # Data rows manually structured using a proper grid container
    latency_grid: {
      grid-columns: 4
      grid-gap: 5
      style.fill: "#ffffff"
      style.stroke: "#fbc02d"
      style.border-radius: 8
      
      # Headers
      h1: "Metric" { style.bold: true; style.underline: true }
      h2: "pread (Sync)" { style.bold: true; style.font-color: "#b71c1c"; style.underline: true }
      h3: "io_uring (Batch)" { style.bold: true; style.font-color: "#01579b"; style.underline: true }
      h4: "io_uring (Reg)" { style.bold: true; style.font-color: "#1b5e20"; style.underline: true }

      # Row 1: P50
      r1_l: "p50 (Median)" { style.italic: true }
      r1_v1: "80 µs" { style.fill: "#ffebee"; style.stroke: "#ffcdd2" }
      r1_v2: "28 µs" { style.fill: "#e1f5fe"; style.stroke: "#b3e5fc" }
      r1_v3: "18 µs" { style.fill: "#e8f5e9"; style.stroke: "#c8e6c9" }

      # Row 2: P95
      r2_l: "p95 (Tail)" { style.italic: true }
      r2_v1: "150 µs" { style.fill: "#ffebee"; style.stroke: "#ffcdd2" }
      r2_v2: "61 µs" { style.fill: "#e1f5fe"; style.stroke: "#b3e5fc" }
      r2_v3: "42 µs" { style.fill: "#e8f5e9"; style.stroke: "#c8e6c9" }

      # Row 3: P99
      r3_l: "p99 (Worst)" { style.italic: true }
      r3_v1: "287 µs" { style.fill: "#ffebee"; style.stroke: "#ffcdd2" }
      r3_v2: "98 µs" { style.fill: "#e1f5fe"; style.stroke: "#b3e5fc" }
      r3_v3: "71 µs" { style.fill: "#e8f5e9"; style.stroke: "#c8e6c9" }
    }
  }

  # 3. KERNEL INTERFACE ANALYSIS
  syscall_section: {
    label: "III. Subsystem Interaction & Context Switches"
    style: {
      fill: "#e1f5fe"
      stroke: "#0288d1"
      border-radius: 12
    }

    syscall_breakdown: {
      grid-columns: 3
      grid-gap: 30

      # SYNC VIEW
      sync_model: {
        shape: rectangle
        style: {
          fill: "#ffffff"
          stroke: "#d32f2f"
          border-radius: 8
        }
        label: ||md
          ### Sync I/O Path (pread)
          - **1,000 Calls**
          - 1,000 User -> Kernel Transitions
          - 1,000 Kernel -> User Transitions
          - *Impact: High TLB Pressure*
        ||
      }

      # BATCHED VIEW
      batch_model: {
        shape: rectangle
        style: {
          fill: "#ffffff"
          stroke: "#1976d2"
          border-radius: 8
        }
        label: ||md
          ### Async Batch Path
          - **16 `io_uring_enter` Calls**
          - Amortized: 1 syscall / 64 SQEs
          - **98.4% Switch Reduction**
          - *Impact: Reduced Branch Mispredicts*
        ||
      }

      # REGISTERED VIEW (FIXED)
      reg_model: {
        shape: rectangle
        style: {
          fill: "#e0f2f1"
          stroke: "#00796b"
          border-radius: 8
          double-border: true
        }
        label: ||md
          ### Registered Resource Path
          - **16 `io_uring_enter` Calls**
          - **No buffer map/unmap per op**
          - **Fixed FD lookup bypass**
          - *Impact: Minimal CPU Cycles/Op*
        ||
      }
    }

    # Buffer Visualization
    buffer_layout: {
      label: "4KB Page Boundary Alignment (Registered Buffers)"
      grid-columns: 8
      grid-gap: 2
      style.fill: "#eceff1"
      
      p1: "Page 0" { style.fill: "#80cbc4"; style.stroke: "#004d40" }
      p2: "Page 1" { style.fill: "#80cbc4"; style.stroke: "#004d40" }
      p3: "Page 2" { style.fill: "#80cbc4"; style.stroke: "#004d40" }
      p4: "Page 3" { style.fill: "#80cbc4"; style.stroke: "#004d40" }
      p5: "..." { style.opacity: 0.5 }
      p6: "Page N" { style.fill: "#80cbc4"; style.stroke: "#004d40" }
    }
    
    # Corrected annotation targeting absolute path
    annotation: "Pre-mapped DMA Regions" {
      shape: text
      style.italic: true
      style.font-color: "#00796b"
    }
  }

  # Layout ordering
  throughput_section -> latency_section -> syscall_section: { style.opacity: 0 }
}

# 4. FINAL ARCHITECTURAL INSIGHT
insight_callout: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#fff9c4"
    stroke: "#fbc02d"
    stroke-width: 2
    border-radius: 12
    shadow: true
  }
  label: ||md
    ### 🔬 Architectural Performance Summary
    The `io_uring` implementation achieves a **3.3x throughput gain** over `pread` by addressing three primary overheads:
    
    1.  **System Call Amortization**: Reducing user-kernel boundary crossings from $O(N)$ to $O(N/batch\_size)$.
    2.  **Memory Management**: "Registered Buffers" provide the kernel with pre-validated, long-lived pointers, eliminating per-I/O `virt_to_page` lookups and page pinning.
    3.  **Synchronization**: The Submission (SQ) and Completion (CQ) rings are shared memory structures using memory barriers instead of expensive mutexes or spinlocks for coordination.
  ||
}

# Metadata Annotations
results.syscall_section.buffer_layout.p1.tooltip: "Offset: 0x0000 | Size: 4096B"
results.syscall_section.buffer_layout.p2.tooltip: "Offset: 0x1000 | Size: 4096B"
results.syscall_section.buffer_layout.p3.tooltip: "Offset: 0x2000 | Size: 4096B"
results.syscall_section.buffer_layout.p4.tooltip: "Offset: 0x3000 | Size: 4096B"