vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Multishot Accept — Single SQE, Multiple CQEs
  *Intel Manual Quality Technical Specification v1.0*
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------
# 1. Memory Layout Specifications (Standard Byte-Aligned Layout)
# -----------------------------------------------------------------------------
memory_specs: {
  label: "Data Structure Byte Layouts (sizeof=64B/16B)"
  
  sqe_layout: "io_uring_sqe (64 Bytes)" {
    shape: sql_table
    style.fill: "#DCD0FF" # Purple header
    
    # [Offset] : [Field Type + Name] {constraint: [Details]} [Size]
    "0x00": "unsigned char opcode" {constraint: "IORING_OP_ACCEPT"; style.fill: "#E1EFFE"}
    "0x01": "unsigned char flags" {constraint: "IOSQE_FIXED_FILE"; style.fill: "#E1EFFE"}
    "0x02": "unsigned short ioprio" {style.fill: "#E1EFFE"}
    "0x04": "signed int fd" {constraint: "Listening Socket (Orange=Ptr/FD)"; style.fill: "#FFEDD5"}
    "0x08": "unsigned long long off" {style.fill: "#E1EFFE"}
    "0x10": "unsigned long long addr" {constraint: "struct sockaddr*"; style.fill: "#FFEDD5"}
    "0x18": "unsigned int len" {constraint: "socklen_t*"; style.fill: "#FFEDD5"}
    "0x1C": "unsigned int accept_flags" {constraint: "IORING_ACCEPT_MULTISHOT (bit 0)"; style.fill: "#E1EFFE"}
    "0x20": "unsigned long long user_data" {constraint: "Request Tag"; style.fill: "#E1EFFE"}
    "0x28": "unsigned short buf_index" {style.fill: "#E1EFFE"}
    "0x2A": "unsigned short personality" {style.fill: "#E1EFFE"}
    "0x2C": "unsigned int pad[3]" {style.fill: "#F3F4F6"; constraint: "Reserved Padding"}
  }

  cqe_layout: "io_uring_cqe (16 Bytes)" {
    shape: sql_table
    style.fill: "#DCD0FF" # Purple header
    
    "0x00": "unsigned long long user_data" {constraint: "From SQE"; style.fill: "#E1EFFE"}
    "0x08": "signed int res" {constraint: "New Client FD (>0) or Error (<0)"; style.fill: "#E1EFFE"}
    "0x0C": "unsigned int flags" {
      style.fill: "#BAE6FD" # Blue data
      constraint: "IORING_CQE_F_MORE (bit 1)"
    }
  }
}

# -----------------------------------------------------------------------------
# 2. Logic & State Transitions (Algorithm Comparison)
# -----------------------------------------------------------------------------
section_old: "Traditional Approach (Step-by-Step submission)" {
  style.fill: "#FFE4E1"
  style.stroke: "#CD5C5C"
  style.stroke-dash: 3
  
  old_sqe1: "1. SQE OP_ACCEPT" {
    style.fill: "#FFA07A"
    style.stroke: "#CD5C5C"
  }
  old_sqe2: "2. SQE OP_ACCEPT" {
    style.fill: "#FFA07A"
    style.stroke: "#CD5C5C"
  }
  old_sqe3: "3. SQE OP_ACCEPT" {
    style.fill: "#FFA07A"
    style.stroke: "#CD5C5C"
  }
  old_sqen: "N. SQE OP_ACCEPT" {
    style.fill: "#FFA07A"
    style.stroke: "#CD5C5C"
    style.multiple: true
  }
  old_sqe1 -> old_sqe2 -> old_sqe3 -> old_sqen: "Serial Submission"
  
  old_note: |md
    **Efficiency Bottleneck:**
    - User must submit new SQE for every incoming connection
    - High syscall overhead
  |
}

section_new: "Multishot Approach (Persistent State)" {
  style.fill: "#E6FFE6"
  style.stroke: "#228B22"
  
  single_sqe: "SINGLE SQE\nOP_ACCEPT\n(RE-ARMS KERNEL)" {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    style.bold: true
  }
  
  cqe_region: "Kernel-Generated CQE Stream" {
    style.fill: "#F0FFF0"
    style.stroke-dash: 2
    
    cqe1: "CQE 1\nres=fd(4)\nF_MORE=1" {
      style.fill: "#98FB98"
    }
    cqe2: "CQE 2\nres=fd(5)\nF_MORE=1" {
      style.fill: "#98FB98"
    }
    cqe3: "CQE 3\nres=fd(6)\nF_MORE=1" {
      style.fill: "#98FB98"
    }
    cqen: "CQE N\nres=fd(N)\nF_MORE=?" {
      style.fill: "#98FB98"
      style.multiple: true
    }
    cqe1 -> cqe2 -> cqe3 -> cqen: "Streaming events"
  }
  
  single_sqe -> cqe_region: "1 submission handles\nmultiple connections" {
    style.stroke: "#228B22"
    style.stroke-width: 2
    style.bold: true
  }
}

section_flow: "Userspace Control Flow" {
  style.fill: "#F0F8FF"
  style.stroke: "#4169E1"
  
  check_more: "Loop: Check\nIORING_CQE_F_MORE" {
    shape: diamond
    style.fill: "#ADD8E6"
  }
  
  continue_flow: "F_MORE=1\nKernel re-arms\nWait for next CQE" {
    style.fill: "#90EE90"
  }
  
  resubmit_flow: "F_MORE=0\nSQE Retired\nHandle Error/Exhaustion" {
    style.fill: "#FFD700"
    style.stroke: "#FF8C00"
  }
  
  check_more -> continue_flow: "Bit 1 set"
  check_more -> resubmit_flow: "Bit 1 cleared" {
    style.stroke: "#FF8C00"
    style.stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# 3. Performance Metrics (Fixed Grid Table)
# -----------------------------------------------------------------------------
comparison: "Performance Benchmarks" {
  grid-columns: 3
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"

  # Row 1 Headers
  h_met: "Metric" {style.bold: true; style.underline: true}
  h_trad: "Traditional (N SQEs)" {style.bold: true; style.underline: true}
  h_multi: "Multishot (1 SQE)" {style.bold: true; style.underline: true}

  # Row 2
  r1_c1: "Submission Overhead"
  r1_c2: "N submissions per N clients"
  r1_c3: "1 submission total"

  # Row 3
  r2_c1: "Kernel Transitions"
  r2_c2: "High (Context Switches)"
  r2_c3: "Low (Amortized)"

  # Row 4
  r3_c1: "Request State"
  r3_c2: "Deleted after 1 CQE"
  r3_c3: "Persistent in Kernel"

  # Row 5
  r4_c1: "Scalability"
  r4_c2: "O(N) Complexity"
  r4_c3: "O(1) Complexity"
}

# -----------------------------------------------------------------------------
# 4. Global Connections & Annotations
# -----------------------------------------------------------------------------
section_old -> section_new: "REFACTOR: Enable IORING_ACCEPT_MULTISHOT" {
  style.stroke: "#228B22"
  style.stroke-width: 4
}

section_new.cqe_region -> section_flow.check_more

resubmit_loop: "Application\nResubmission Path" {
  shape: text
  style.font-color: "#4169E1"
}

section_flow.resubmit_flow -> resubmit_loop -> section_new.single_sqe: "Terminal Loopback" {
  style.stroke: "#4169E1"
  style.stroke-dash: 5
  style.animated: true
}

footer: |md
  **Implementation Critical:** If `-EMFILE` or `-ENFILE` is returned in `CQE.res`, `F_MORE` will be 0. 
  The application **must** clear file descriptor pressure and resubmit the multishot SQE.
| {near: bottom-center}

legend: "Intel Reference Legend" {
  near: bottom-right
  sqe_box: "SQE (Intel 64B)" { style.fill: "#90EE90" }
  cqe_box: "CQE (Intel 16B)" { style.fill: "#98FB98" }
  bit_active: "Active: F_MORE=1" { style.fill: "#BAE6FD" }
  bit_inactive: "Terminal: F_MORE=0" { style.fill: "#FFD700" }
}