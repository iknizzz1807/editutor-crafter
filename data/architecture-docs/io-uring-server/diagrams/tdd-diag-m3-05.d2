layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
  }
  colors: {
    header: "#7E22CE"
    data: "#2563EB"
    sent: "#16A34A"
    pending: "#9333EA"
    retry: "#DC2626"
    padding: "#94A3B8"
    pointer: "#EA580C"
    memory_bg: "#F8FAFC"
  }
}

title: |md
  # Intel® Short Write Handling — Partial Send Recovery
  **Protocol:** io_uring SEND (OP_0x1A) | **Buffer:** 4KB Sequential
  **Recovery Path:** Userspace Resubmission with Pointer Arithmetic
|
title.near: top-center

# -----------------------------------------------------------------------------
# STEP 0: INITIAL SUBMISSION
# -----------------------------------------------------------------------------
step0: {
  label: "STEP 0: Initial SQE Preparation"
  style.stroke-dash: 0

  sqe: {
    shape: sql_table
    label: "io_uring_sqe (Submission Queue Entry)"
    "opcode": "IORING_OP_SEND (26)"
    "fd": "0x03 (TCP Socket)"
    "addr": "0x00001000"
    "len": "4096 Bytes"
    "flags": "0x00"
    "user_data": "REQ_ID_A1"
  }

  mem: "Virtual Memory (Base: 0x1000)" {
    style.fill: "${colors.memory_bg}"
    
    buf: {
      grid-columns: 1
      grid-gap: 0
      
      h: "0x1000 [ 4096B PENDING ]" {
        style: {
          fill: "${colors.pending}"
          fill-pattern: lines
          font-color: white
          stroke-width: 2
        }
      }
    }
  }
  
  sqe -> mem.buf.h: "Points to address 0x1000" {
    style.stroke: "${colors.pointer}"
    target-arrowhead: diamond
  }
}

# -----------------------------------------------------------------------------
# STEP 1: PARTIAL COMPLETION (SHORT WRITE)
# -----------------------------------------------------------------------------
step1: {
  label: "STEP 1: Partial Completion Interrupt"
  style.stroke: "${colors.retry}"
  style.stroke-width: 4

  cqe: {
    shape: sql_table
    label: "io_uring_cqe (Completion Queue Entry)"
    "user_data": "REQ_ID_A1"
    "res": "**1024** (Bytes Actually Sent)" {
      style.font-color: red
      style.bold: true
    }
    "flags": "0"
    
    status: "SHORT WRITE DETECTED" {
      style.fill: "${colors.retry}"
      style.font-color: white
    }
  }

  mem: "Virtual Memory State" {
    style.fill: "${colors.memory_bg}"
    
    buf: {
      grid-columns: 2
      grid-gap: 0
      
      sent: "0x1000..0x13FF (1024B)" {
        label: "SENT"
        style.fill: "${colors.sent}"
        style.font-color: white
      }
      remain: "0x1400..0x1FFF (3072B)" {
        label: "REMAINING"
        style.fill: "${colors.pending}"
        style.fill-pattern: lines
      }
    }
    
    cursor: "Kernel Cursor: 0x1400" {
      shape: text
      near: top-right
      style.font-color: "${colors.pointer}"
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 2: RECOVERY & RESUBMISSION
# -----------------------------------------------------------------------------
step2: {
  label: "STEP 2: Calculation & Resubmit"
  style.stroke: "${colors.pointer}"

  logic: {
    shape: class
    label: "Userspace Handler"
    "+handle_cqe(res=1024)"
    "+bytes_sent += 1024"
    "+remaining = 4096 - 1024"
    "+next_addr = 0x1000 + 1024"
  }

  new_sqe: {
    shape: sql_table
    label: "New SQE (Retry Segment)"
    "opcode": "IORING_OP_SEND"
    "addr": "**0x1400**" {
      style.font-color: red
      style.bold: true
    }
    "len": "**3072**" {
      style.font-color: red
      style.bold: true
    }
    "user_data": "REQ_ID_A2"
  }

  mem: "Memory Visibility" {
    buf: {
      grid-columns: 2
      grid-gap: 0
      old: "0x1000 (Already Sent)" {
        style.opacity: 0.3
      }
      active: "0x1400 (Active Range)" {
        style: {
          fill: "${colors.retry}"
          stroke-width: 4
          bold: true
        }
      }
    }
  }
  
  logic -> new_sqe: "Prepare offset"
  new_sqe -> mem.buf.active: "Targets remaining slice" {
    style.stroke: "${colors.pointer}"
  }
}

# -----------------------------------------------------------------------------
# STEP 3: FINAL TRANSMISSION
# -----------------------------------------------------------------------------
step3: {
  label: "STEP 3: Full Completion"
  style.stroke: "${colors.sent}"

  cqe_final: {
    shape: sql_table
    label: "Final CQE"
    "res": "3072"
    "status": "TOTAL_SENT: 4096" {
      style.font-color: "${colors.sent}"
      style.bold: true
    }
  }

  mem: "Final Memory State" {
    buf: {
      label: "FULL BUFFER TRANSMITTED (4096/4096)"
      style: {
        fill: "${colors.sent}"
        fill-pattern: dots
        stroke: "${colors.sent}"
      }
    }
  }
  
  complete_flag: "OK" {
    shape: circle
    style.fill: "${colors.sent}"
    style.font-color: white
  }
}

# -----------------------------------------------------------------------------
# FLOW CONNECTORS
# -----------------------------------------------------------------------------
step0 -> step1: "Kernel Process: Send Interrupted" {
  style.stroke-width: 2
}

step1 -> step2: "Userspace Recovery Loop" {
  style: {
    stroke: "${colors.retry}"
    stroke-width: 4
    animated: true
  }
}

step2 -> step3: "Submission -> Success" {
  style.stroke-width: 2
}

# -----------------------------------------------------------------------------
# FOOTER & ANNOTATIONS
# -----------------------------------------------------------------------------
annotation: |md
  ### Implementation Logic (C pseudo)
  c
  // Partial write handler for async send
  if (cqe->res > 0 && cqe->res < req->total_len) {
      // 1. Update internal state
      req->bytes_sent += cqe->res;
      
      // 2. Prepare next fragment SQE
      struct io_uring_sqe *sqe = io_uring_get_sqe(ring);
      io_uring_prep_send(sqe, fd, 
                         req->buf + req->bytes_sent, 
                         req->total_len - req->bytes_sent, 
                         0);
                         
      // 3. Chain user data for recovery tracking
      sqe->user_data = (uint64_t)req; 
      io_uring_submit(ring);
  }
  
|
annotation.near: bottom-left

legend: {
  near: bottom-right
  p: "Pending/Buffered" { style.fill: "${colors.pending}" }
  s: "Sent/Complete" { style.fill: "${colors.sent}" }
  r: "Active Resubmit" { style.fill: "${colors.retry}" }
}