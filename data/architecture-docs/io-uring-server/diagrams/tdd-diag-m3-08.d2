vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Connection Structure Layout
  **sizeof = 64 bytes (one cache line)**
|
Connection_t: {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  style.border-radius: 4
  grid-rows: 1
  grid-columns: 1
  grid-gap: 0
  # Byte offsets on left
  offset_col: {
    style.fill: "#F0F0F0"
    style.stroke: "#CCCCCC"
    width: 60
    off_00: |md
    **0x00**
    |
    off_04: |md
    **0x04**
    |
    off_08: |md
    **0x08**
    |
    off_10: |md
    **0x10**
    |
    off_18: |md
    **0x18**
    |
    off_20: |md
    **0x20**
    |
    off_28: |md
    **0x28**
    |
    off_30: |md
    **0x30**
    |
    off_38: |md
    **0x38**
    |
  }
  # Field boxes
  field_col: {
    style.fill: transparent
    width: 280
    fd_box: {
      style.fill: "#FFB366"
      style.stroke: "#CC8800"
      width: 280
      height: 40
      fd_label: |md
      **fd**: int32_t
      Socket file descriptor (-1 if free/closed)
      |
    }
    state_box: {
      style.fill: "#FF6B6B"
      style.stroke: "#CC5555"
      width: 70
      height: 40
      state_label: |md
      **state**
      |
    }
    padding1_box: {
      style.fill: "#DDDDDD"
      style.stroke: "#AAAAAA"
      width: 70
      height: 40
      padding1_label: |md
      **pad**
      |
    }
    id_box: {
      style.fill: "#7FB3D5"
      style.stroke: "#5A8AB0"
      width: 140
      height: 40
      id_label: |md
      **conn_id**: uint32_t
      Unique connection identifier
      |
    }
    recv_buf_box: {
      style.fill: "#82E0AA"
      style.stroke: "#58D68D"
      width: 140
      height: 40
      recv_buf_label: |md
      **recv_buf_id**: uint16_t
      Buffer from provided ring
      |
    }
    recv_len_box: {
      style.fill: "#82E0AA"
      style.stroke: "#58D68D"
      width: 140
      height: 40
      recv_len_label: |md
      **recv_len**: uint32_t
      Bytes received
      |
    }
    send_total_box: {
      style.fill: "#85C1E9"
      style.stroke: "#5DADE2"
      width: 140
      height: 40
      send_total_label: |md
      **send_total**: uint32_t
      Total bytes to send
      |
    }
    send_done_box: {
      style.fill: "#85C1E9"
      style.stroke: "#5DADE2"
      width: 140
      height: 40
      send_done_label: |md
      **send_done**: uint32_t
      Bytes sent so far
      |
    }
    n_inflight_box: {
      style.fill: "#F9E79F"
      style.stroke: "#D4AC0D"
      width: 70
      height: 40
      n_inflight_label: |md
      **n_in_flight**
      |
    }
    cancel_box: {
      style.fill: "#E59866"
      style.stroke: "#BA7A4D"
      width: 70
      height: 40
      cancel_label: |md
      **cancel**
      |
    }
    padding2_box: {
      style.fill: "#DDDDDD"
      style.stroke: "#AAAAAA"
      width: 140
      height: 40
      padding2_label: |md
      **padding (3 bytes)**
      |
    }
    bytes_recv_box: {
      style.fill: "#D7BDE2"
      style.stroke: "#AF7AC5"
      width: 280
      height: 40
      bytes_recv_label: |md
      **bytes_received**: uint64_t
      Total received statistics
      |
    }
    bytes_sent_box: {
      style.fill: "#D7BDE2"
      style.stroke: "#AF7AC5"
      width: 280
      height: 40
      bytes_sent_label: |md
      **bytes_sent**: uint64_t
      Total sent statistics
      |
    }
  }
  # Size annotations on right
  size_col: {
    style.fill: "#F0F0F0"
    style.stroke: "#CCCCCC"
    width: 60
    size_4a: |md
    **4 B**
    |
    size_1: |md
    **1 B**
    |
    size_3: |md
    **3 B**
    |
    size_4b: |md
    **4 B**
    |
    size_2: |md
    **2 B**
    |
    size_4c: |md
    **4 B**
    |
    size_4d: |md
    **4 B**
    |
    size_4e: |md
    **4 B**
    |
    size_1b: |md
    **1 B**
    |
    size_3b: |md
    **3 B**
    |
    size_8a: |md
    **8 B**
    |
    size_8b: |md
    **8 B**
    |
  }
  # Layout connections
  offset_col.off_00 -> field_col.fd_box: {style.opacity: 0}
  offset_col.off_04 -> field_col.state_box: {style.opacity: 0}
  offset_col.off_08 -> field_col.id_box: {style.opacity: 0}
  offset_col.off_10 -> field_col.recv_buf_box: {style.opacity: 0}
  offset_col.off_18 -> field_col.send_total_box: {style.opacity: 0}
  offset_col.off_20 -> field_col.send_done_box: {style.opacity: 0}
  offset_col.off_28 -> field_col.n_inflight_box: {style.opacity: 0}
  offset_col.off_30 -> field_col.bytes_recv_box: {style.opacity: 0}
  offset_col.off_38 -> field_col.bytes_sent_box: {style.opacity: 0}
  field_col.fd_box -> size_col.size_4a: {style.opacity: 0}
  field_col.state_box -> size_col.size_1: {style.opacity: 0}
  field_col.id_box -> size_col.size_4b: {style.opacity: 0}
  field_col.recv_buf_box -> size_col.size_2: {style.opacity: 0}
  field_col.send_total_box -> size_col.size_4d: {style.opacity: 0}
  field_col.send_done_box -> size_col.size_4e: {style.opacity: 0}
  field_col.n_inflight_box -> size_col.size_1b: {style.opacity: 0}
  field_col.bytes_recv_box -> size_col.size_8a: {style.opacity: 0}
  field_col.bytes_sent_box -> size_col.size_8b: {style.opacity: 0}
}
# Legend
legend: {
  near: bottom-center
  grid-columns: 5
  grid-gap: 10
  leg1: {
    style.fill: "#FFB366"
    style.stroke: "#CC8800"
    width: 80
    height: 24
    label: "File Descriptor"
  }
  leg2: {
    style.fill: "#FF6B6B"
    style.stroke: "#CC5555"
    width: 80
    height: 24
    label: "State"
  }
  leg3: {
    style.fill: "#82E0AA"
    style.stroke: "#58D68D"
    width: 80
    height: 24
    label: "Recv Fields"
  }
  leg4: {
    style.fill: "#85C1E9"
    style.stroke: "#5DADE2"
    width: 80
    height: 24
    label: "Send Fields"
  }
  leg5: {
    style.fill: "#D7BDE2"
    style.stroke: "#AF7AC5"
    width: 80
    height: 24
    label: "Statistics"
  }
}
# Cache line annotation
cache_line_note: |md
  **Cache Line Boundary (64 bytes)**
  Structure fits exactly in one cache line for optimal performance.
| {near: bottom-center}