vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |md
  # User Data Encoding — 64-bit Layout
  ### Single-field dispatch for O(1) CQE routing
| {near: top-center}

# 1. Memory Layout Specification
# Visualizing the 64-bit word structure
memory_layout: {
  direction: right
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  style.stroke-width: 2
  
  # Bit indices for clarity
  bits: {
    grid-columns: 3
    grid-gap: 0
    b63: "63" { style.font-size: 10; style.font-color: "#9ca3af"; style.stroke: transparent; style.fill: transparent }
    b59: "59" { style.font-size: 10; style.font-color: "#9ca3af"; style.stroke: transparent; style.fill: transparent }
    b47: "47" { style.font-size: 10; style.font-color: "#9ca3af"; style.stroke: transparent; style.fill: transparent }
  }

  encoding: {
    direction: right
    
    op_type: "[ OP TYPE ]" {
      tooltip: "Bits 63-60: 4-bit Operation Selector"
      width: 120
      style: {
        fill: "#7c3aed"
        stroke: "#a855f7"
        font-color: white
        bold: true
      }
    }
    
    reserved: "[ RESERVED ]" {
      tooltip: "Bits 59-48: 12-bit Padding for Alignment"
      width: 150
      style: {
        fill: "#374151"
        stroke: "#6b7280"
        font-color: "#9ca3af"
      }
    }
    
    conn_id: "[ CONNECTION ID ]" {
      tooltip: "Bits 47-0: 48-bit Unique Identifier"
      width: 300
      style: {
        fill: "#0ea5e9"
        stroke: "#38bdf8"
        font-color: white
        bold: true
      }
    }
    
    op_type -- reserved -- conn_id
  }

  size_labels: {
    grid-columns: 3
    grid-gap: 0
    s1: "4 bits" { width: 120; style.font-size: 11; style.font-color: "#a855f7"; style.stroke: transparent; style.fill: transparent }
    s2: "12 bits" { width: 150; style.font-size: 11; style.font-color: "#6b7280"; style.stroke: transparent; style.fill: transparent }
    s3: "48 bits" { width: 300; style.font-size: 11; style.font-color: "#38bdf8"; style.stroke: transparent; style.fill: transparent }
  }
}

# 2. Reference Tables & Logical Flow
main_content: {
  grid-columns: 2
  grid-gap: 40

  # Enum values for Op Type
  op_reference: {
    style.fill: "#0f0f1a"
    style.stroke: "#4a4a6a"
    header: "Operation Type Reference" {
      style.fill: "#7c3aed"
      style.font-color: white
      style.bold: true
    }
    
    table: {
      shape: sql_table
      style.stroke: "#4a4a6a"
      "0x0": "ACCEPT | Multishot Listener"
      "0x1": "RECV   | Data Ingress"
      "0x2": "SEND   | Data Egress"
      "0x3": "CANCEL | Timeout/Abort"
      "0x4": "STAT   | File Stat"
    }
    header -- table
  }

  # Dispatch Logic
  logic_flow: {
    style.fill: "#0f0f1a"
    style.stroke: "#4a4a6a"
    
    cqe_input: "CQE.user_data" {
      shape: circle
      style.fill: "#fbbf24"
      style.bold: true
    }
    
    extract: "val = data >> 60" {
      style.font: mono
      style.fill: "#1e1e2e"
    }
    
    router: "Switch(val)" {
      shape: diamond
      style.fill: "#1e1e2e"
      style.font-color: "#38bdf8"
    }
    
    handlers: {
      h_accept: "handle_accept()"
      h_recv: "handle_recv()"
      h_send: "handle_send()"
      
      h_accept.style.fill: "#1e1e2e"
      h_recv.style.fill: "#1e1e2e"
      h_send.style.fill: "#1e1e2e"
      h_accept.style.font: mono
      h_recv.style.font: mono
      h_send.style.font: mono
    }
    
    cqe_input -> extract -> router
    router -> handlers.h_accept: "0x0"
    router -> handlers.h_recv: "0x1"
    router -> handlers.h_send: "0x2"
  }
}

# 3. Implementation Block
# Using triple-pipe to handle bitwise operators in C code safely
code_helper: {
  shape: rectangle
  style.fill: "#0f0f1a"
  style.stroke: "#059669"
  style.stroke-width: 2
  
  label: "Kernel-Space Encoding Macros"
  
  source: |||c
/**
 * Layout: [ Type:4 ] [ Reserved:12 ] [ ConnID:48 ]
 */
#define USER_DATA_TYPE_SHIFT 60
#define USER_DATA_CONN_MASK  0xFFFFFFFFFFFFULL

static inline uint64_t encode_user_data(uint8_t type, uint64_t id) {
    return ((uint64_t)type << USER_DATA_TYPE_SHIFT) | (id & USER_DATA_CONN_MASK);
}

static inline uint8_t get_type(uint64_t data) {
    return (uint8_t)(data >> USER_DATA_TYPE_SHIFT);
}

static inline uint64_t get_conn_id(uint64_t data) {
    return data & USER_DATA_CONN_MASK;
}
|||
  source.style.font: mono
  source.style.fill: "#111827"
}

# Layout constraints
memory_layout -> main_content: { style.stroke-width: 0 }
main_content -> code_helper: { style.stroke-width: 0 }

footer_note: |md
  **Implementation Context:**
  - **O(1) Complexity:** Dispatch avoids hash-map lookups by encoding context directly in the 64-bit identifier.
  - **ID Capacity:** 48-bit `conn_id` allows for 281,474,976,710,656 concurrent descriptors.
  - **Zero Branching:** Type extraction is performed via single CPU cycle bit-shift.
| {
  near: bottom-center
  style.font-size: 14
}