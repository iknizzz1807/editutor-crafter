vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Buffer Ring Replenishment Under Load
  **Provided Buffer Ring Monitoring & ENOBUFS Prevention Flow**
| {near: top-center}
# === Normal Flow ===
normal_flow: {
  label: "Normal Operation Flow"
  recv_submit: {
    shape: rectangle
    label: "1. Submit RECV\nwith BUFFER_SELECT"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
  kernel_selects: {
    shape: rectangle
    label: "2. Kernel Selects\nBuffer from Ring"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  buffer_removed: {
    shape: rectangle
    label: "3. Buffer Removed\nfrom Available Pool"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  cqe_arrives: {
    shape: diamond
    label: "4. Recv CQE\nArrives"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  process_data: {
    shape: rectangle
    label: "5. Process Data\nin Buffer"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
  }
  return_buffer: {
    shape: rectangle
    label: "6. Return Buffer\nto Ring"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.bold: true
  }
  recv_submit -> kernel_selects: "buf_group=N"
  kernel_selects -> buffer_removed: "available--"
  buffer_removed -> cqe_arrives: "IORING_CQE_F_BUFFER"
  cqe_arrives -> process_data: "bid in flags"
  process_data -> return_buffer: "after echo"
}
# === Buffer Return Detail ===
buffer_return_detail: {
  label: "Buffer Return Implementation"
  buf_ring_add: {
    shape: rectangle
    label: "io_uring_buf_ring_add(\n  ring, buf, len, bid,\n  offset, buf_offset\n)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  buf_ring_advance: {
    shape: rectangle
    label: "io_uring_buf_ring_advance(\n  ring, count\n)"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.bold: true
  }
  available_inc: {
    shape: rectangle
    label: "available++\nBuffer in ring"
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
  }
  buf_ring_add -> buf_ring_advance: "add to tail"
  buf_ring_advance -> available_inc: "visible to kernel"
}
# === Monitoring Flow ===
monitoring: {
  label: "Monitoring & Warning"
  check_available: {
    shape: diamond
    label: "Check\navailable\ncount"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  threshold_check: {
    shape: diamond
    label: "available <\n25% threshold?"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  warn: {
    shape: rectangle
    label: "⚠️ LOG WARNING\nBuffer pool low"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.bold: true
  }
  normal: {
    shape: rectangle
    label: "✓ Healthy"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  check_available -> threshold_check
  threshold_check -> warn: "Yes"
  threshold_check -> normal: "No"
}
# === Ring State Visualization ===
ring_state: {
  label: "Ring State Visualization"
  ring_full: {
    shape: rectangle
    label: "Ring Full\n████████████████\navailable = 2048"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  ring_normal: {
    shape: rectangle
    label: "Normal Load\n████████░░░░░░░░\navailable = 1024 (50%)"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
  }
  ring_warning: {
    shape: rectangle
    label: "⚠️ Warning\n████░░░░░░░░░░░░\navailable = 512 (25%)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.bold: true
  }
  ring_critical: {
    shape: rectangle
    label: "🔴 Critical\n█░░░░░░░░░░░░░░░\navailable = 64 (3%)"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
  ring_full -> ring_normal -> ring_warning -> ring_critical
}
# === ENOBUFS Prevention ===
enobufs_prevention: {
  label: "ENOBUFS Prevention"
  enobufs_cqe: {
    shape: rectangle
    label: "ENOBUFS CQE\nres = -ENOBUF"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.bold: true
  }
  no_buffers: {
    shape: rectangle
    label: "No buffers\nin ring"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
  replenish: {
    shape: rectangle
    label: "Replenish\nReturn buffers"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  retry: {
    shape: rectangle
    label: "Retry RECV\nafter delay"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
  enobufs_cqe -> no_buffers: "ring empty"
  no_buffers -> replenish: "return processed\nbuffers first"
  replenish -> retry: "then retry"
}
# === Connections ===
normal_flow.return_buffer -> buffer_return_detail.buf_ring_add: "after echo"
buffer_return_detail.available_inc -> monitoring.check_available: "periodic check"
monitoring.warn -> enobufs_prevention.enobufs_cqe: "if ignored"
enobufs_prevention.retry -> normal_flow.recv_submit: "resubmit"
# === Statistics Box ===
stats: {
  label: "Statistics Tracking"
  stats_box: {
    shape: rectangle
    label: |md
      
      struct buffer_stats {
        uint32_t total;      // 2048
        uint32_t available;  // current
        uint32_t in_use;     // total - available
        uint32_t peak_use;   // max concurrent
        uint64_t returns;    // total returned
      }
      
    |
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
    style.font: mono
  }
}
# === Legend ===
legend: {
  label: "Legend"
  legend_box: {
    shape: rectangle
    label: |md
      - 🟢 Green: Healthy/Success
      - 🟡 Yellow: Normal operation
      - 🟠 Orange: Warning threshold
      - 🔴 Red: Critical/Error
      - Buffer MUST be returned after send complete
      - Never reuse buffer until returned
    |
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
  }
}