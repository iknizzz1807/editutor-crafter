vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |'md
  # Zero-Copy Send — Kernel DMA from User Buffer
  **IORING_OP_SEND_ZC eliminates payload copy by enabling direct NIC DMA from registered user buffers**
'| {
  near: top-center
  style.font-size: 24
}

direction: right

# Legend
legend: {
  near: bottom-right
  style.fill: "#f5f5f5"
  style.stroke: "#666"
  style.border-radius: 4
  
  legend_title: "Memory Legend" {shape: text; style.bold: true}
  
  user_mem: "User Data (Blue)" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  kernel_mem: "Kernel Headers (Purple)" {
    shape: rectangle  
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  hw_comp: "Hardware (Orange)" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }
}

# User Space - Registered Buffer Pool
user_space: "User Space (Ring 3)" {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  
  registered_buffers: "Registered Buffer Pool (Fixed Buffers)" {
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    style.stroke-dash: 5
    
    user_buf_0: "Buffer 0\n[Phys: 0x1A2000]\n(Page-aligned, Pinned)" {
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
      style.bold: true
    }
    user_buf_1: "Buffer 1\n[Phys: 0x1B4000]" {
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
    user_buf_n: "Buffer N\n[Phys: 0x1C8000]" {
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
  }

  sqe_prep: "SQE Submission" {
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
    sqe_fields: |'md
      **IORING_OP_SEND_ZC**
      *   `opcode`: SEND_ZC
      *   `fd`: Socket File Descriptor
      *   `buf_index`: 0 (Registered Index)
      *   `len`: 4096 (Payload Size)
      *   `addr`: 0x7f... (User Virtual Addr)
    '| {shape: text}
  }
}

# Kernel Space
kernel_space: "Kernel Space (Ring 0)" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  
  io_uring_core: "io_uring Subsystem" {
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    sq_ring: "Submission Queue\n(Memory Mapped)" {
      style.fill: "#CE93D8"
    }
    sqe_processor: "Worker Thread\n(Validation & Mapping)" {
      style.fill: "#CE93D8"
    }
  }

  network_stack: "Network Stack (TCP/IP)" {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    
    header_gen: "Protocol Header Buffers" {
      tcp_header: "TCP Header\n(20 bytes)" {
        shape: rectangle
        style.fill: "#D1C4E9"
        style.stroke: "#5E35B1"
      }
      ip_header: "IP Header\n(20 bytes)" {
        shape: rectangle
        style.fill: "#D1C4E9"
        style.stroke: "#5E35B1"
      }
      eth_header: "Ethernet Header\n(14 bytes)" {
        shape: rectangle
        style.fill: "#D1C4E9"
        style.stroke: "#5E35B1"
      }
    }

    scatter_gather: "Scatter-Gather List (SGL)" {
      style.fill: "#B39DDB"
      style.stroke: "#512DA8"
      sgl_entry_0: "SG Entry 0\n• type: KERNEL_BUF\n• addr: 0xFFFF... (Headers)" {
        style.fill: "#9575CD"
      }
      sgl_entry_1: "SG Entry 1\n• type: USER_FIXED\n• addr: 0x1A2000 (Payload)" {
        style.fill: "#7E57C2"
        style.font-color: white
        style.bold: true
      }
    }
  }

  nic_driver: "NIC Driver (TX Path)" {
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
  }
}

# Hardware Layer
hardware: "Hardware Layer (PCIe)" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  
  nic: "NIC (Network Interface Card)" {
    style.fill: "#FFE0B2"
    style.stroke: "#E65100"
    
    dma_engine: "DMA Engine" {
      style.fill: "#FFCC80"
      style.stroke: "#EF6C00"
    }
    tx_ring: "TX Descriptor Ring" {
      style.fill: "#FFB74D"
      style.stroke: "#E65100"
    }
  }
}

# Network Output
network_wire: "Network Wire (Physical Link)" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  packet_view: |'md
    **On-Wire Packet Layout:**
    
    [Eth][IP][TCP][  Payload Data (from User Buffer)  ][FCS]
    |<- Kernel ->| |<---------- Zero Copy ----------->|
    
  '| {shape: text}
}

# Connections
user_space.sqe_prep -> kernel_space.io_uring_core.sq_ring: "1. Post SQE" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}

kernel_space.io_uring_core.sq_ring -> kernel_space.io_uring_core.sqe_processor: "2. Consume"

kernel_space.io_uring_core.sqe_processor -> kernel_space.network_stack.header_gen: "3. Alloc Headers"

kernel_space.network_stack.header_gen -> kernel_space.network_stack.scatter_gather: "4. Map Headers"

kernel_space.network_stack.scatter_gather <-> user_space.registered_buffers.user_buf_0: "5. Map Physical User Addr" {
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.bold: true
}

kernel_space.network_stack.scatter_gather -> kernel_space.nic_driver: "6. Send SGL"

kernel_space.nic_driver -> hardware.nic.tx_ring: "7. Ring Doorbell"

# DMA Flows
hardware.nic.dma_engine -> kernel_space.network_stack.header_gen: "8a. DMA Read Headers" {
  style.stroke: "#E65100"
  style.stroke-dash: 5
}

hardware.nic.dma_engine -> user_space.registered_buffers.user_buf_0: "8b. DMA Read Payload (NO COPY)" {
  style.stroke: "#D32F2F"
  style.stroke-width: 4
  style.animated: true
}

hardware.nic.dma_engine -> network_wire.packet_view: "9. Transmit"

# CQE Flow logic
cqe_system: "Completion & Notification" {
  near: bottom-left
  style.fill: "#FFEBEE"
  
  first_cqe: "Completion CQE\n(res=bytes)" {
    tooltip: "Indicates packet is queued to NIC"
    style.fill: "#FFCDD2"
  }
  
  second_cqe: "Notification CQE\n(IORING_CQE_F_NOTIF)" {
    tooltip: "Indicates NIC has finished DMA; buffer safe to reuse"
    style.fill: "#C8E6C9"
  }
  
  first_cqe -> second_cqe: "Sequential"
}

hardware.nic.dma_engine -> cqe_system.first_cqe: "10. Interrupt"
cqe_system.second_cqe -> user_space.registered_buffers: "11. Release Buffer" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}

# Technical Insight
insight: |'md
  ### Zero-Copy Performance Metrics
  *   **Traditional:** `CPU Copying` @ ~20GB/s.
  *   **SEND_ZC:** `Zero CPU usage` for payload.
  *   **Constraint:** Buffer is locked (pinned) until notification CQE.
  *   **Use Case:** Large payloads (>4KB), high-bandwidth links (100GbE+).
'| {
  near: top-right
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.border-radius: 8
  width: 300
}