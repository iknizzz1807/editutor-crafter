vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

# === CLASSES ===
classes: {
  card_sqp: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 8
    }
  }
  card_default: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
      border-radius: 8
    }
  }
  analysis_box: {
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      border-radius: 8
    }
  }
  decision_node: {
    shape: diamond
    style: {
      fill: "#E1F5FE"
      stroke: "#0288D1"
    }
  }
}

# === GLOBAL TITLE ===
title: {
  shape: text
  label: |md
    # SQ Polling CPU Tradeoff Analysis
    ### Kernel Thread (SQPOLL) vs Syscall-Per-Batch Modes
  |
}

# === GRAPH SECTION ===
graph_container: {
  label: "Performance vs Efficiency Visualization"
  style: {
    stroke-dash: 3
    stroke: "#607D8B"
  }
  
  grid-columns: 2
  grid-gap: 20
  
  y_axis: {
    shape: text
    label: |md
      **CPU %**
      100%
      │
      80%
      │
      60%
      │
      40%
      │
      20%
      │
      0%───
    |
  }
  
  plot_area: {
    shape: rectangle
    width: 600
    height: 300
    style.font: mono
    label: |md
            │
      100% ─┼─────────────────────────────────────
            │    ╭───────────────────────────────
       80% ─┼───╱ SQPOLL (1 core burned constantly)
            │  ╱
       60% ─┼ ╱
            │╱
       40% ─┼──────────────────────╲
            │                       ╲
       20% ─┼────────────────────────╲─────── Non-SQPOLL
            │                                 (syscall per batch)
        0% ─┼───┬───────┬───────┬───────┬───────┬───
            │   0     50K    100K    150K    200K   250K
            │            Submissions/sec
    |
  }
  
  legend: {
    sqp_leg: {
      shape: text
      label: "━━━ SQPOLL: 1 CPU core @ 100% (independent of rate)"
      style.font-color: "#1976D2"
    }
    nonsqp_leg: {
      shape: text
      label: "━━━ Non-SQPOLL: CPU scales with submission rate"
      style.font-color: "#F57C00"
    }
  }
}

# === ANALYSIS ROW ===
analysis_row: {
  grid-columns: 2
  grid-gap: 40

  breakeven: {
    class: analysis_box
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
    label: ||md
      ### Break-Even Thresholds
      
      | Submission Rate | Recommended Mode |
      | :--- | :--- |
      | < 80K ops/sec | **Non-SQPOLL** (Efficiency) |
      | 80K-120K ops/sec | **Marginal** (Latency vs Core) |
      | > 120K ops/sec | **SQPOLL** (Performance) |
    ||
  }

  cost_logic: {
    class: analysis_box
    label: |md
      ### Cost Calculation Logic
      **Syscall Overhead (Non-SQPOLL):**
      - ~100ns per `io_uring_enter()`
      - Batch size: 64 ops
      
      **At 100K ops/sec:**
      - Syscalls/sec: 1,563
      - Context Switch Overhead: ~1-3μs
      - Total CPU Impact: **~1.5% - 5%**
      
      **At 1M ops/sec:**
      - Syscalls/sec: 15,625
      - Total CPU Impact: **~15% - 45%**
      
      *SQPOLL eliminates this entirely.*
    |
  }
}

# === DETAILED COMPARISON ===
comparison: {
  grid-columns: 2
  grid-gap: 40
  
  sqpoll_details: {
    class: card_sqp
    label: |md
      ### SQPOLL (IORING_SETUP_SQPOLL)
      **Mechanics:**
      - Kernel kthread polls SQ head
      - Zero syscalls for submission
      - Sub-μs submission latency
      - Core is pinned/reserved
      
      **Best for:**
      - High-frequency trading
      - Real-time packet processing
      - Persistent high-load streams
    |
  }
  
  nonsqp_details: {
    class: card_default
    label: |md
      ### Non-SQPOLL (Default)
      **Mechanics:**
      - Explicit `io_uring_enter` syscall
      - CPU scales with submission rate
      - Thread sleeps when idle
      - Context switch penalty
      
      **Best for:**
      - General-purpose API servers
      - Bursty/Irregular workloads
      - Multi-tenant shared CPU envs
    |
  }
}

# === CONFIGURATION GUIDANCE ===
tuning_guide: {
  class: analysis_box
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
  }
  label: ||md
    ## `sq_thread_idle` Tuning Table
    
    | Workload Profile | Recommended `idle_ms` | Logic |
    | :--- | :--- | :--- |
    | HFT / Real-time | 1 - 5 ms | High responsiveness |
    | Web Services | 10 - 50 ms | Balance responsiveness vs power |
    | Batch Process | 100 - 1000 ms | Maximize kthread uptime during long runs |
  ||
}

# === DECISION TREE ===
decision_flow: {
  label: "Selection Logic Flow"
  
  q_throughput: "Sustained >100K\nops/sec?" { class: decision_node }
  q_spare_core: "Dedicated Core\nAvailable?" { class: decision_node }
  q_latency: "Requires <1μs\nLatency?" { class: decision_node }
  
  res_sqp: "USE SQPOLL" {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      bold: true
      border-radius: 8
    }
  }
  
  res_default: "USE DEFAULT" {
    style: {
      fill: "#FFCCBC"
      stroke: "#D84315"
      bold: true
      border-radius: 8
    }
  }

  q_throughput -> q_spare_core: "Yes" { 
    style.stroke: "#2E7D32" 
    style.stroke-width: 2
  }
  q_throughput -> res_default: "No" { 
    style.stroke: "#D84315" 
    style.stroke-dash: 3
  }
  
  q_spare_core -> q_latency: "Yes" { 
    style.stroke: "#2E7D32" 
    style.stroke-width: 2
  }
  q_spare_core -> res_default: "No" { 
    style.stroke: "#D84315" 
    style.stroke-dash: 3
  }
  
  q_latency -> res_sqp: "Yes" { 
    style.stroke: "#2E7D32" 
    style.stroke-width: 2
  }
  q_latency -> res_default: "No" { 
    style.stroke: "#D84315" 
    style.stroke-dash: 3
  }
}

# === KEY INSIGHT ===
summary_insight: {
  shape: rectangle
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    stroke-width: 3
    border-radius: 12
    shadow: true
  }
  label: |md
    ### Strategic Summary
    SQPOLL trades **deterministic resource allocation** (1 dedicated CPU core) for the total 
    **elimination of syscall overhead**. The architectural break-even point is reached when 
    the cumulative cost of syscall context switches and overhead exceeds the capacity 
    of the dedicated polling core—typically found in workloads exceeding **100,000 IOPS**.
  |
}

# Layout constraints - Sequential stacking for clear reading path
graph_container -> analysis_row
analysis_row -> comparison
comparison -> tuning_guide
tuning_guide -> decision_flow
decision_flow -> summary_insight

# Formatting for the invisible flow
(graph_container -> analysis_row)[0].style.stroke: transparent
(analysis_row -> comparison)[0].style.stroke: transparent
(comparison -> tuning_guide)[0].style.stroke: transparent
(tuning_guide -> decision_flow)[0].style.stroke: transparent
(decision_flow -> summary_insight)[0].style.stroke: transparent