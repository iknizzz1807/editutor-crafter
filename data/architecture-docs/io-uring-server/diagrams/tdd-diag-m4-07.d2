vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Linked SQE Failure Propagation (io_uring)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

classes: {
  success_op: {
    shape: circle
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      stroke-width: 3
    }
  }
  failed_op: {
    shape: circle
    style: {
      fill: "#FF6B6B"
      stroke: "#8B0000"
      stroke-width: 3
      font-color: white
    }
  }
  cancelled_op: {
    shape: circle
    style: {
      fill: "#FFB347"
      stroke: "#CC8400"
      stroke-width: 3
      font-color: black
    }
  }
  chain_container: {
    style: {
      fill: "#F8F8FF"
      stroke: "#4169E1"
      stroke-width: 2
      border-radius: 8
    }
  }
  cqe_box: {
    shape: rectangle
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      border-radius: 4
    }
  }
  state_box: {
    style: {
      fill: "#E6E6FA"
      stroke: "#483D8B"
      border-radius: 6
    }
  }
}

direction: right

# ========== NORMAL CASE ==========
normal_section: "Normal Case: All Operations Succeed" {
  class: chain_container
  width: 700
  
  normal_chain_id: "Chain ID: 0x1001" {
    shape: text
    style: {
      font-size: 18
      bold: true
      font-color: "#2E8B57"
    }
  }
  
  normal_op1: "Op 1\nIORING_OP_READ\n[IOSQE_IO_LINK]" {
    class: success_op
    width: 140
    height: 140
  }
  
  normal_op2: "Op 2\nIORING_OP_WRITE\n[IOSQE_IO_LINK]" {
    class: success_op
    width: 140
    height: 140
  }
  
  normal_op3: "Op 3\nIORING_OP_FSYNC" {
    class: success_op
    width: 140
    height: 140
  }
  
  normal_op1 -> normal_op2: "Link Active" {
    style: {
      stroke: "#228B22"
      stroke-width: 3
    }
  }
  normal_op2 -> normal_op3: "Link Active" {
    style: {
      stroke: "#228B22"
      stroke-width: 3
    }
  }
}

# CQE results for normal case
normal_cqe_grp: "Completion Results" {
  normal_cqe1: "CQE 1\nres = +4096" {
    class: cqe_box
    width: 120
  }
  normal_cqe2: "CQE 2\nres = +4096" {
    class: cqe_box
    width: 120
  }
  normal_cqe3: "CQE 3\nres = 0" {
    class: cqe_box
    width: 120
  }
  normal_cqe1 -> normal_cqe2 -> normal_cqe3
}

normal_section -> normal_cqe_grp: "Execute Chain" {
  style: {
    stroke: "#228B22"
    stroke-dash: 3
    animated: true
  }
}

# Normal case result
normal_result: "Result: CHAIN_STATE_COMPLETE\nAll operations executed successfully" {
  class: state_box
  near: bottom-left
  width: 300
  style: {
    font-color: "#2E8B57"
  }
}

# ========== FAILURE CASE ==========
failure_section: "Failure Case: Op 1 Fails, Subsequent Cancelled" {
  class: chain_container
  width: 700
  
  failure_chain_id: "Chain ID: 0x2002" {
    shape: text
    style: {
      font-size: 18
      bold: true
      font-color: "#8B0000"
    }
  }
  
  failure_op1: "Op 1\nIORING_OP_READ\n[FAIL: -EINVAL]" {
    class: failed_op
    width: 140
    height: 140
    style: {
      bold: true
    }
  }
  
  failure_op2: "Op 2\nIORING_OP_WRITE\n[CANCELLED]" {
    class: cancelled_op
    width: 140
    height: 140
    style: {
      bold: true
    }
  }
  
  failure_op3: "Op 3\nIORING_OP_FSYNC\n[CANCELLED]" {
    class: cancelled_op
    width: 140
    height: 140
    style: {
      bold: true
    }
  }
  
  failure_op1 -> failure_op2: "ABORT LINK\nPropagate" {
    style: {
      stroke: "#8B0000"
      stroke-width: 4
      stroke-dash: 2
    }
  }
  failure_op2 -> failure_op3: "CANCELLED" {
    style: {
      stroke: "#CC8400"
      stroke-width: 3
      stroke-dash: 5
    }
  }
}

# CQE results for failure case
failure_cqe_grp: "Completion Results" {
  failure_cqe1: "CQE 1\nres = -EINVAL\n(Root Error)" {
    class: cqe_box
    width: 160
    style: {
      fill: "#FFE4E1"
      stroke: "#8B0000"
      bold: true
    }
  }
  failure_cqe2: "CQE 2\nres = -ECANCELED\n(Subsequent)" {
    class: cqe_box
    width: 160
    style: {
      fill: "#FFF3E0"
      stroke: "#CC8400"
      bold: true
    }
  }
  failure_cqe3: "CQE 3\nres = -ECANCELED\n(Subsequent)" {
    class: cqe_box
    width: 160
    style: {
      fill: "#FFF3E0"
      stroke: "#CC8400"
      bold: true
    }
  }
  failure_cqe1 -> failure_cqe2 -> failure_cqe3
}

failure_section -> failure_cqe_grp: "Execute Chain" {
  style: {
    stroke: "#8B0000"
    stroke-dash: 3
    animated: true
  }
}

# Failure case result
failure_result: "Result: CHAIN_STATE_FAILED\nfirst_error = -EINVAL\nn_cancelled = 2" {
  class: state_box
  near: bottom-right
  width: 320
  style: {
    font-color: "#8B0000"
  }
}

# ========== KEY ==========
key_section: "State Machine Legend" {
  width: 500
  
  key_title: "Chain State Transitions" {
    shape: text
    style: {
      font-size: 16
      bold: true
    }
  }
  
  key_success: "Success\n(res >= 0)" {
    class: success_op
    width: 100
    height: 100
  }
  
  key_failed: "Failed\n(Root Error)" {
    class: failed_op
    width: 100
    height: 100
  }
  
  key_cancelled: "Cancelled\n(-ECANCELED)" {
    class: cancelled_op
    width: 100
    height: 100
  }
  
  key_success -> key_failed: "Transition on Error"
  key_failed -> key_cancelled: "Propagation"
}

# Annotations
annotation1: |md
  ### Failure Propagation Rule:
  1.  Kernel checks `IOSQE_IO_LINK` flag.
  2.  If an SQE in a chain fails (`res < 0`), the link is broken.
  3.  The kernel skips submission of all remaining SQEs in the current chain.
  4.  Every skipped SQE results in a CQE with `res = -ECANCELED`.
  5.  User-space must identify the *first* error in the sequence.
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FFFACD"
    stroke: "#DAA520"
    border-radius: 4
  }
}

annotation2: |md
  ### Chain Metadata Tracking:
  - **chain_id**: Tracked per linked sequence.
  - **n_submitted**: Count of SQEs sharing the link.
  - **n_completed**: Incremented on successful CQE.
  - **first_error**: Captured from the first CQE where `res < 0` AND `res != -ECANCELED`.
| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#E0FFFF"
    stroke: "#008B8B"
    border-radius: 4
  }
}