vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Latency Histogram Memory Layout
| {near: top-center}

# Main structure
histogram: "latency_histogram_t" {
  shape: rectangle
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
  
  # Count array header
  count_header: "uint64_t count[32]" {
    shape: rectangle
    style.fill: "#D4E6F1"
    style.stroke: "#2E5A88"
    style.font: mono
    style.font-size: 14
    style.bold: true
  }

  # Count buckets visualization
  buckets_container: "Log2 Buckets (256 bytes total)" {
    shape: rectangle
    style.fill: "#F5F5F5"
    style.stroke: "#999999"
    style.stroke-dash: 3
    
    bucket_00: "0-1μs" {style.fill: "#B4D7F0"; style.font-size: 11; style.font: mono}
    bucket_01: "1-2μs" {style.fill: "#B4D7F0"; style.font-size: 11; style.font: mono}
    bucket_02: "2-4μs" {style.fill: "#74C476"; style.font-size: 11; style.font: mono}
    bucket_03: "4-8μs" {style.fill: "#74C476"; style.font-size: 11; style.font: mono}
    bucket_04: "8-16μs" {style.fill: "#FFC000"; style.font-size: 11; style.font: mono}
    bucket_05: "16-32μs" {style.fill: "#FFC000"; style.font-size: 11; style.font: mono}
    bucket_06: "32-64μs" {style.fill: "#FF9900"; style.font-size: 11; style.font: mono}
    bucket_07: "64-128μs" {style.fill: "#FF9900"; style.font-size: 11; style.font: mono}
    bucket_08: "128-256μs" {style.fill: "#FF6600"; style.font-size: 11; style.font: mono}
    bucket_09: "256-512μs" {style.fill: "#FF6600"; style.font-size: 11; style.font: mono}
    bucket_10: "512μ-1ms" {style.fill: "#FF3300"; style.font-size: 11; style.font: mono}
    bucket_11: "1-2ms" {style.fill: "#FF3300"; style.font-size: 11; style.font: mono}
    bucket_12: "2-4ms" {style.fill: "#CC0000"; style.font-size: 11; style.font: mono}
    bucket_13: "4-8ms" {style.fill: "#CC0000"; style.font-size: 11; style.font: mono}
    bucket_14: "8-16ms" {style.fill: "#990000"; style.font-size: 11; style.font: mono}
    bucket_15: "16-32ms" {style.fill: "#990000"; style.font-size: 11; style.font: mono}
    bucket_16: "32-64ms" {style.fill: "#660000"; style.font-size: 11; style.font: mono}
    bucket_17: "64-128ms" {style.fill: "#660000"; style.font-size: 11; style.font: mono}
    bucket_18: "128-256ms" {style.fill: "#330000"; style.font-size: 11; style.font: mono}
    bucket_rest: "..." {style.fill: "#E0E0E0"; style.font-size: 11; style.font: mono}
    bucket_31: "8-16s" {style.fill: "#000000"; style.font-color: white; style.font-size: 11; style.font: mono}
  }

  # Statistics fields
  stats_section: "Statistics (32 bytes)" {
    shape: rectangle
    style.fill: "#FFF8DC"
    style.stroke: "#DAA520"
    
    total_samples_f: "uint64_t total_samples" {
      style.fill: "#E6F3FF"
      style.stroke: "#4169E1"
      style.font: mono
      style.font-size: 12
    }
    total_ns_f: "uint64_t total_ns" {
      style.fill: "#E6F3FF"
      style.stroke: "#4169E1"
      style.font: mono
      style.font-size: 12
    }
    min_ns_f: "uint64_t min_ns" {
      style.fill: "#FFE6E6"
      style.stroke: "#CC6666"
      style.font: mono
      style.font-size: 12
    }
    max_ns_f: "uint64_t max_ns" {
      style.fill: "#FFE6E6"
      style.stroke: "#CC6666"
      style.font: mono
      style.font-size: 12
    }
  }
}

# Memory layout annotation
layout_info: |md
  **Total Size: 288 bytes**
  - count[32]: 256 bytes (offset 0x00-0xFF)
  - total_samples: 8 bytes (offset 0x100)
  - total_ns: 8 bytes (offset 0x108)
  - min_ns: 8 bytes (offset 0x110)
  - max_ns: 8 bytes (offset 0x118)
| {near: center-right}

# Percentile calculation example
percentile_calc: "Percentile Calculation" {
  shape: rectangle
  style.fill: "#F0FFF0"
  style.stroke: "#228B22"
  style.stroke-width: 2
  
  algorithm: |md
    c
    uint64_t latency_percentile(
        latency_histogram_t *h, int p) {
      uint64_t target = h->total_samples * p / 100;
      uint64_t cumulative = 0;
      for (int i = 0; i < 32; i++) {
        cumulative += h->buckets[i];
        if (cumulative >= target) {
          // Return middle of bucket range
          uint64_t base_us = (i == 0) ? 0 : (1ULL << (i - 1));
          return base_us * 1000; // to ns
        }
      }
      return h->max_ns;
    }
    
  |
  
  examples: "Example Values" {
    shape: rectangle
    style.fill: "#FFFAF0"
    ex_p50: "p50: Find bucket where cumulative >= 50%" {
      style.fill: "#B4D7F0"
      style.font-size: 11
    }
    ex_p95: "p95: Find bucket where cumulative >= 95%" {
      style.fill: "#FFC000"
      style.font-size: 11
    }
    ex_p99: "p99: Find bucket where cumulative >= 99%" {
      style.fill: "#FF6600"
      style.font-size: 11
    }
  }
}

# Connections
histogram -> layout_info
histogram -> percentile_calc

# Layout connections within histogram
histogram.count_header -> histogram.buckets_container
histogram.buckets_container -> histogram.stats_section

histogram.buckets_container.bucket_00 -> histogram.buckets_container.bucket_01
histogram.buckets_container.bucket_01 -> histogram.buckets_container.bucket_02
histogram.buckets_container.bucket_02 -> histogram.buckets_container.bucket_03
histogram.buckets_container.bucket_03 -> histogram.buckets_container.bucket_04
histogram.buckets_container.bucket_04 -> histogram.buckets_container.bucket_05
histogram.buckets_container.bucket_05 -> histogram.buckets_container.bucket_06
histogram.buckets_container.bucket_06 -> histogram.buckets_container.bucket_07
histogram.buckets_container.bucket_07 -> histogram.buckets_container.bucket_08
histogram.buckets_container.bucket_08 -> histogram.buckets_container.bucket_09
histogram.buckets_container.bucket_09 -> histogram.buckets_container.bucket_10
histogram.buckets_container.bucket_10 -> histogram.buckets_container.bucket_11
histogram.buckets_container.bucket_11 -> histogram.buckets_container.bucket_12
histogram.buckets_container.bucket_12 -> histogram.buckets_container.bucket_13
histogram.buckets_container.bucket_13 -> histogram.buckets_container.bucket_14
histogram.buckets_container.bucket_14 -> histogram.buckets_container.bucket_15
histogram.buckets_container.bucket_15 -> histogram.buckets_container.bucket_16
histogram.buckets_container.bucket_16 -> histogram.buckets_container.bucket_17
histogram.buckets_container.bucket_17 -> histogram.buckets_container.bucket_18
histogram.buckets_container.bucket_18 -> histogram.buckets_container.bucket_rest
histogram.buckets_container.bucket_rest -> histogram.buckets_container.bucket_31

histogram.stats_section.total_samples_f -> histogram.stats_section.total_ns_f
histogram.stats_section.total_ns_f -> histogram.stats_section.min_ns_f
histogram.stats_section.min_ns_f -> histogram.stats_section.max_ns_f

# Percentile example connections
percentile_calc.examples.ex_p50 -> percentile_calc.examples.ex_p95
percentile_calc.examples.ex_p95 -> percentile_calc.examples.ex_p99