vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    supported: "#2E7D32"
    unsupported: "#C62828"
    partial: "#EF6C00"
    header-bg: "#283593"
    cell-bg: "#FFFFFF"
    fallback-bg: "#FFF3E0"
    accent-blue: "#1A237E"
    row-alt: "#E8EAF6"
  }
}

title: |md
  # Kernel Version Feature Fallback Matrix
  *Technical implementation guide for io_uring feature compatibility and runtime branching.*
| {
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

direction: right

# --- Matrix Grid Implementation ---
matrix: {
  grid-rows: 5
  grid-columns: 5
  grid-gap: 0
  style: {
    stroke: ${colors.accent-blue}
    stroke-width: 4
    shadow: true
  }

  # Row 1: Logical Headers
  header_kernel: "Kernel Version / Opcode" {
    style: {
      fill: ${colors.header-bg}
      font-color: white
      bold: true
      font-size: 16
    }
  }
  header_51: "v5.1 (Legacy)" {
    style: {
      fill: ${colors.header-bg}
      font-color: white
      bold: true
      font-size: 16
    }
  }
  header_519: "v5.19 (Modern)" {
    style: {
      fill: ${colors.header-bg}
      font-color: white
      bold: true
      font-size: 16
    }
  }
  header_60: "v6.0+ (Latest)" {
    style: {
      fill: ${colors.header-bg}
      font-color: white
      bold: true
      font-size: 16
    }
  }
  header_fallback: "Fallback Path Strategy" {
    style: {
      fill: ${colors.header-bg}
      font-color: white
      bold: true
      font-size: 16
    }
  }

  # Row 2: Registered Files (Descriptor optimization)
  feature_reg_files: "Registered Files\n(IORING_REGISTER_FILES)" {
    style: {
      fill: ${colors.row-alt}
      bold: true
    }
  }
  reg_51: "✓ Supported" {
    style: {
      fill: ${colors.supported}
      font-color: white
      bold: true
    }
  }
  reg_519: "✓ Supported" {
    style: {
      fill: ${colors.supported}
      font-color: white
      bold: true
    }
  }
  reg_60: "✓ Supported" {
    style: {
      fill: ${colors.supported}
      font-color: white
      bold: true
    }
  }
  reg_fallback: "N/A - Direct path only" {
    style: {
      fill: ${colors.cell-bg}
      font-color: "#757575"
      italic: true
    }
  }

  # Row 3: Provided Buffer Rings (High-speed networking)
  feature_pbuf: "Provided Buffer Rings\n(IORING_REGISTER_PBUF_RING)" {
    style: {
      fill: ${colors.row-alt}
      bold: true
    }
  }
  pbuf_51: "✗ Unsupported" {
    style: {
      fill: ${colors.unsupported}
      font-color: white
      bold: true
    }
  }
  pbuf_519: "✓ Supported" {
    style: {
      fill: ${colors.supported}
      font-color: white
      bold: true
    }
  }
  pbuf_60: "✓ Supported" {
    style: {
      fill: ${colors.supported}
      font-color: white
      bold: true
    }
  }
  pbuf_fallback: |md
    **Automatic Fallback:**
    - Pre-allocate `iovec` array pool
    - Manual `IORING_OP_READ` cycles
    - *Fixed Buffer Registration*
  | {
    style: {
      fill: ${colors.fallback-bg}
      font-size: 12
    }
  }

  # Row 4: Zero-Copy Send (High-throughput egress)
  feature_zc: "Zero-Copy Send\n(IORING_OP_SEND_ZC)" {
    style: {
      fill: ${colors.row-alt}
      bold: true
    }
  }
  zc_51: "✗ Unsupported" {
    style: {
      fill: ${colors.unsupported}
      font-color: white
      bold: true
    }
  }
  zc_519: "✗ Unsupported" {
    style: {
      fill: ${colors.unsupported}
      font-color: white
      bold: true
    }
  }
  zc_60: "✓ Supported" {
    style: {
      fill: ${colors.supported}
      font-color: white
      bold: true
    }
  }
  zc_fallback: |md
    **Performance Fallback:**
    - `IORING_OP_SEND` (Sync)
    - Kernel-space copy overhead
    - *Approx -8% Throughput cost*
  | {
    style: {
      fill: ${colors.fallback-bg}
      font-size: 12
    }
  }

  # Row 5: SQ Polling (Submission Offloading)
  feature_sqpoll: "SQ Polling\n(IORING_SETUP_SQPOLL)" {
    style: {
      fill: ${colors.row-alt}
      bold: true
    }
  }
  sqpoll_51: "⚠ Restricted" {
    style: {
      fill: ${colors.partial}
      font-color: white
      bold: true
    }
    tooltip: "Requires CAP_SYS_NICE or root permissions"
  }
  sqpoll_519: "⚠ Restricted" {
    style: {
      fill: ${colors.partial}
      font-color: white
      bold: true
    }
  }
  sqpoll_60: "⚠ Restricted" {
    style: {
      fill: ${colors.partial}
      font-color: white
      bold: true
    }
  }
  sqpoll_fallback: |md
    **Latency Fallback:**
    - Batched `io_uring_enter` calls
    - Manual user-space event polling
    - *Increased Syscall overhead*
  | {
    style: {
      fill: ${colors.fallback-bg}
      font-size: 12
    }
  }
}

# --- Visual Legend ---
legend: {
  near: bottom-center
  grid-columns: 3
  grid-gap: 30
  style: {
    stroke: "#BDBDBD"
    stroke-dash: 4
    border-radius: 8
    fill: "#FAFAFA"
    stroke-width: 2
  }

  l1: "Full Implementation Support" {
    style: {
      fill: ${colors.supported}
      font-color: white
      bold: true
      border-radius: 4
    }
  }
  l2: "Kernel / Permission Constraint" {
    style: {
      fill: ${colors.partial}
      font-color: white
      bold: true
      border-radius: 4
    }
  }
  l3: "Opcode Unavailable (Fallback Active)" {
    style: {
      fill: ${colors.unsupported}
      font-color: white
      bold: true
      border-radius: 4
    }
  }
}

# --- Logic Sequence Flow ---
detect_flow: {
  label: "Runtime Initialization & Feature Detection Sequence"
  near: center-right
  style: {
    fill: "#F5F5F5"
    stroke: "#333333"
    border-radius: 12
    stroke-width: 3
    shadow: true
  }

  uname: "1. Parse uname() syscall\nIdentify Major/Minor kernel version" {
    style.fill: white
    style.border-radius: 5
  }
  probe: "2. IORING_REGISTER_PROBE\nQuery available opcodes bitmask" {
    style.fill: white
    style.border-radius: 5
  }
  capabilities: "3. Check CAP_SYS_NICE\nValidate SQPOLL context permissions" {
    style.fill: white
    style.border-radius: 5
  }
  config: "4. Allocate specialized Ring Context\nSet opcode function pointers" {
    style: {
      fill: "#C8E6C9"
      bold: true
      stroke: ${colors.supported}
      border-radius: 5
    }
  }

  uname -> probe: "Version Match"
  probe -> capabilities: "Feature Flags"
  capabilities -> config: "Assign Logic"
}

# --- Implementation Annotations ---
annotations: {
  near: bottom-left
  note_box: |md
    ### Implementation Note
    All fallback paths are implemented using a 
    **Strategy Pattern** to minimize runtime 
    conditional overhead. 

    Feature detection is performed **once** 
    during ring instantiation; subsequent 
    hot-path calls use resolved function 
    pointers to ensure minimal CPU branch 
    misprediction.
  | {
    shape: rectangle
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      stroke-width: 2
      shadow: true
      double-border: true
    }
  }
}