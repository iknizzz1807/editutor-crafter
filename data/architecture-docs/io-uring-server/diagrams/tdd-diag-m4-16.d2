layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: ||md
# Syscall Count Measurement & Validation
### Performance validation methodology for io_uring optimization suites
|| {
  near: top-center
  style: {
    font-size: 34
    bold: true
    font-color: "#0D47A1"
  }
}

direction: down

# -----------------------------------------------------------------------------
# Section 1: Measurement Methodologies
# -----------------------------------------------------------------------------
measurement_approaches: {
  label: "1. Measurement Methodologies: Kernel Interface Instrumentation"
  grid-columns: 2
  grid-gap: 60
  style: {
    stroke-width: 2
    stroke-dash: 5
    fill: "#F8F9FA"
    border-radius: 15
  }

  perf_method: {
    label: "Method A: perf_event_open (Low Overhead)"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 12
      shadow: true
    }
    
    header: ||md
    ### Production Tracepoint API
    Uses hardware/software counters. Zero-copy kernel-to-user reporting.
    - **Context**: In-process or system-wide
    - **Overhead**: < 1% CPU cycle impact
    ||
    
    # Memory Layout for the Attribute Struct
    perf_attr_struct: {
      label: "struct perf_event_attr (Memory Layout)"
      0x00: "type: PERF_TYPE_TRACEPOINT" {style.fill: "#D1C4E9"}
      0x04: "size: 0x78 (120 bytes)" {style.fill: "#D1C4E9"}
      0x08: "config: 0x2B8 (io_uring_enter)" {style.fill: "#BBDEFB"}
      0x10: "sample_period: 1" {style.fill: "#BBDEFB"}
      0x18: "sample_type: PERF_SAMPLE_IP|TID" {style.fill: "#BBDEFB"}
      0x20: "read_format: PERF_FORMAT_GROUP" {style.fill: "#BBDEFB"}
      0x28: "flags: disabled | inherit" {style.fill: "#CFD8DC"}
      0x30: "wakeup_events: 1" {style.fill: "#CFD8DC"}
      
      # Annotations for Engineers
      footer: ||md
      **sizeof=120 bytes**. Alignment must be 8-byte boundary.
      ||
    }

    syscall_selectors: {
      shape: class
      label: "Tracepoint Registry"
      "0x2B7": "sys_enter_io_uring_setup"
      "0x2B8": "sys_enter_io_uring_enter"
      "0x2B9": "sys_enter_io_uring_register"
      style.fill: "#E1F5FE"
    }
    
    perf_attr_struct -> syscall_selectors: "fd = perf_event_open(&attr, ...)" {
      style.stroke: "#1565C0"
      style.bold: true
    }
  }

  strace_method: {
    label: "Method B: strace -c (Ptrace Interception)"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      border-radius: 12
      shadow: true
    }
    header: ||md
    ### Inspection & Debugging
    Intercepts every transition between User Space and Kernel Space.
    - **Mechanism**: PTRACE_SYSCALL
    - **Overhead**: High (200%-500% slowdown)
    ||
    command: {
      shape: rectangle
      label: |bash
      # Capture summary statistics for specific ops
      strace -c -S calls \
        -e trace=io_uring_setup,io_uring_enter,read,write \
        ./io_uring_server
      |
      style: {
        fill: "#263238"
        font-color: "#80D8FF"
        font: mono
      }
    }
    output: {
      shape: rectangle
      label: ||md
      **Aggregate Kernel Statistics**
      | syscall | calls | errors | total_time |
      | :--- | :--- | :--- | :--- |
      | read | 10000 | 0 | 1.2s |
      | write | 10000 | 0 | 0.8s |
      | io_uring_enter | 157 | 0 | 0.02s |
      ||
      style.fill: "#FFFFFF"
    }
    command -> output: "Aggregated on Process Termination" {
      style.stroke: "#E65100"
      style.stroke-dash: 2
    }
  }
}

# -----------------------------------------------------------------------------
# Section 2: Optimization Lifecycle
# -----------------------------------------------------------------------------
measurement_flow: {
  label: "2. Performance Transition: Baseline vs. Optimized State"
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#757575"
    border-radius: 10
  }

  before_phase: {
    label: "Phase I: Synchronous Baseline"
    style: {
      fill: "#FFEBEE"
      stroke: "#B71C1C"
      stroke-width: 4
    }
    baseline_config: {
      label: "I/O Model: Non-Blocking Epoll"
      shape: rectangle
      style.fill: white
      config_text: ||md
      - **Ready List**: epoll_wait()
      - **Flow**: 
         1. Loop start -> epoll_wait
         2. recv() -> user buffer
         3. process() -> user logic
         4. send() -> kernel socket
      ||
    }
    baseline_measure: {
      label: "Trap Trace"
      shape: hexagon
      style.fill: "#EF9A9A"
      style.bold: true
    }
    baseline_result: {
      label: "Syscall Volume"
      shape: cylinder
      style.fill: white
      result_text: ||md
      **30,003 Total**
      (3.0 syscalls/op)
      ||
      style.font-color: "#B71C1C"
      style.bold: true
      style.font-size: 20
    }
    baseline_config -> baseline_measure -> baseline_result
  }

  after_phase: {
    label: "Phase II: Asynchronous io_uring"
    style: {
      fill: "#E8F5E9"
      stroke: "#1B5E20"
      stroke-width: 4
    }
    optimized_config: {
      label: "I/O Model: Completion Queue"
      shape: rectangle
      style.fill: white
      config_text: ||md
      - **Shared Rings**: SQ/CQ in Mapped Memory
      - **Optimization Flags**:
         - IORING_SETUP_SQPOLL (**Kernel Thread**)
         - IORING_REGISTER_FILES (**Fixed fds**)
         - IORING_SETUP_IOPOLL (**Busy Wait**)
      ||
    }
    optimized_measure: {
      label: "Trap Trace"
      shape: hexagon
      style.fill: "#A5D6A7"
      style.bold: true
    }
    optimized_result: {
      label: "Syscall Volume"
      shape: cylinder
      style.fill: white
      result_text: ||md
      **157 Total**
      (0.015 syscalls/op)
      ||
      style.font-color: "#1B5E20"
      style.bold: true
      style.font-size: 20
    }
    optimized_config -> optimized_measure -> optimized_result
  }

  (before_phase -> after_phase): "99.47% Trap Reduction (Context Switches Eliminated)" {
    style: {
      stroke-width: 8
      stroke: "#2E7D32"
      animated: true
    }
  }
}

# -----------------------------------------------------------------------------
# Section 3: Data & Validation
# -----------------------------------------------------------------------------
data_validation: {
  grid-columns: 2
  grid-gap: 40
  
  comparison_table: {
    label: "3. Optimization Validation Matrix (Synthetic Benchmark)"
    style: {
      fill: "#FFFFFF"
      stroke: "#9E9E9E"
      stroke-width: 2
      shadow: true
    }
    content: ||md
    ### Comparative Metrics per 10,000 I/O Operations
    | Implementation | Syscalls | Ratio (calls/op) | % Reduction | Latency p99 |
    | :--- | :--- | :--- | :--- | :--- |
    | **epoll (Baseline)** | 30,003 | 3.0003 | 0.00% | 287 μs |
    | **io_uring (Default)** | 313 | 0.0313 | 98.95% | 98 μs |
    | **io_uring (+Fixed)** | 313 | 0.0313 | 98.95% | 82 μs |
    | **io_uring (+SQPOLL)** | 4 | 0.0004 | 99.98% | 68 μs |
    ||
  }

  validation_checklist: {
    label: "4. Experimental Control Checklist"
    style: {
      fill: "#E1F5FE"
      stroke: "#0288D1"
      border-radius: 8
    }
    checklist: ||md
    ### Reliability Requirements for Peer Review
    - [x] **Thermal Throttling**: CPU pinned to Max Freq
    - [x] **Isolation**: cgroups/cpuset used for worker threads
    - [x] **Kernel Version**: 5.15+ (LTS) or 6.x (Mainline)
    - [x] **Sample Size**: Mean of 20 runs, SD < 5%
    - [x] **Observability**: Concurrent `mpstat 1` to monitor SI/HI
    ||
  }
}

# -----------------------------------------------------------------------------
# Section 4: Implementation
# -----------------------------------------------------------------------------
perf_implementation: {
  label: "Reference Implementation: Context Switch Counter (Go/Linux)"
  style: {
    fill: "#1A237E"
    font-color: white
    stroke-width: 2
    border-radius: 4
  }
  code: ||go
// Measurement wrapper for perf_event tracing
func OpenCounter(cpu int, counterType uint32) (int, error) {
    attr := unix.PerfEventAttr{
        Type:   unix.PERF_TYPE_SOFTWARE,
        Config: uint64(counterType),
        Size:   uint32(unsafe.Sizeof(unix.PerfEventAttr{})),
        Bits:   unix.PerfBitDisabled | unix.PerfBitInherit,
    }
    // syscall.PerfEventOpen(attr, pid, cpu, group_fd, flags)
    fd, err := unix.PerfEventOpen(&attr, 0, cpu, -1, 0)
    if err != nil {
        return -1, fmt.Errorf("perf_event_open failed: %w", err)
    }
    return fd, nil
}

func MeasureOperation(fd int, payload func()) uint64 {
    // Reset and Start Counter
    unix.IoctlSetInt(fd, unix.PERF_EVENT_IOC_RESET, 0)
    unix.IoctlSetInt(fd, unix.PERF_EVENT_IOC_ENABLE, 0)
    
    payload() // Critical section under measurement
    
    // Stop Counter
    unix.IoctlSetInt(fd, unix.PERF_EVENT_IOC_DISABLE, 0)
    
    var count uint64
    binary.Read(os.NewFile(uintptr(fd), "perf"), binary.LittleEndian, &count)
    return count
}
||
}

# -----------------------------------------------------------------------------
# Global Connections & Styling
# -----------------------------------------------------------------------------
measurement_approaches -> measurement_flow: "Apply methodology to target app" {
  style.stroke-width: 2
}
measurement_flow -> data_validation: "Generate formal Performance Report" {
  style.stroke-width: 2
}
data_validation -> perf_implementation: "Implement Continuous Validation Hook" {
  style.stroke-dash: 4
}

***.style.font: mono
(*** -> ***)[*]: {
  style.stroke: "#455A64"
  style.font-size: 14
}