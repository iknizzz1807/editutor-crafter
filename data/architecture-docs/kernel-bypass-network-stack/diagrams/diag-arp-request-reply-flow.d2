direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # ARP Request/Reply Packet Flow
  Broadcast discovery, unicast response, and gratuitous announcement
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  host_a: {
    direction: down
    label: "Host A (192.168.1.10)"
    arp_cache_a: {
      shape: sql_table
      label: "ARP Cache (host_a)"
      f0: "0x00 | uint32_t | ip_addr"
      f1: "0x04 | uint8_t[6] | mac"
      f2: "0x0A | uint8_t   | state"
      f3: "0x0B | uint64_t  | expires"
      sz: "24 bytes/entry"
    }
    cache_state_a: {
      label: "Before: Empty"
      code: |'c
        cache[0].ip = 0x00000000;
        cache[0].state = EMPTY;
      '|
      width: 280
    }
  }
  switch: {
    label: "Ethernet Switch\n(L2 Broadcast Domain)"
    shape: rectangle
    width: 200
    style.fill: "#E8E8E8"
    broadcast_note: {
      label: "FF:FF:FF:FF:FF:FF\nBroadcast MAC"
      shape: text
      style.font-color: "#8B0000"
      style.italic: true
    }
  }
  host_b: {
    direction: down
    label: "Host B (192.168.1.50)"
    arp_cache_b: {
      shape: sql_table
      label: "ARP Cache (host_b)"
      f0: "0x00 | uint32_t | ip_addr"
      f1: "0x04 | uint8_t[6] | mac"
      f2: "0x0A | uint8_t   | state"
      f3: "0x0B | uint64_t  | expires"
      sz: "24 bytes/entry"
    }
    cache_state_b: {
      label: "Before: Empty"
      code: |'c
        cache[0].ip = 0x00000000;
        cache[0].state = EMPTY;
      '|
      width: 280
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    direction: down
    label: "Step 1: ARP Request (Broadcast)"
    width: 600
    step1_desc: {
      label: "Host A needs to send to 192.168.1.50 but has no MAC mapping"
      shape: text
      style.font-color: "#555"
    }
    arp_request_pkt: {
      shape: sql_table
      label: "ARP Request Packet"
      htype: "0x00 | uint16_t | htype = 1 (Ethernet)"
      ptype: "0x02 | uint16_t | ptype = 0x0800 (IPv4)"
      hlen: "0x04 | uint8_t  | hlen = 6"
      plen: "0x05 | uint8_t  | plen = 4"
      oper: "0x06 | uint16_t | oper = 1 (REQUEST)"
      sha: "0x08 | uint8_t[6] | sha = AA:BB:CC:00:00:01"
      spa: "0x0E | uint32_t | spa = 192.168.1.10"
      tha: "0x12 | uint8_t[6] | tha = 00:00:00:00:00:00"
      tpa: "0x18 | uint32_t | tpa = 192.168.1.50"
      sz: "Total: 28 bytes"
    }
    eth_frame_req: {
      shape: sql_table
      label: "Ethernet Frame (Request)"
      dst: "0x00 | uint8_t[6] | dst = FF:FF:FF:FF:FF:FF"
      src: "0x06 | uint8_t[6] | src = AA:BB:CC:00:00:01"
      type: "0x0C | uint16_t | type = 0x0806 (ARP)"
      payload: "0x0E | ARP pkt  | [28 bytes ARP]"
      sz: "Total: 42 bytes (+padding)"
    }
  }
  step2: {
    direction: down
    label: "Step 2: ARP Reply (Unicast)"
    width: 600
    step2_desc: {
      label: "Host B recognizes its IP, responds with MAC"
      shape: text
      style.font-color: "#555"
    }
    arp_reply_pkt: {
      shape: sql_table
      label: "ARP Reply Packet"
      htype2: "0x00 | uint16_t | htype = 1 (Ethernet)"
      ptype2: "0x02 | uint16_t | ptype = 0x0800 (IPv4)"
      hlen2: "0x04 | uint8_t  | hlen = 6"
      plen2: "0x05 | uint8_t  | plen = 4"
      oper2: "0x06 | uint16_t | oper = 2 (REPLY)"
      sha2: "0x08 | uint8_t[6] | sha = DD:EE:FF:00:00:01"
      spa2: "0x0E | uint32_t | spa = 192.168.1.50"
      tha2: "0x12 | uint8_t[6] | tha = AA:BB:CC:00:00:01"
      tpa2: "0x18 | uint32_t | tpa = 192.168.1.10"
      sz2: "Total: 28 bytes"
    }
    eth_frame_reply: {
      shape: sql_table
      label: "Ethernet Frame (Reply)"
      dst2: "0x00 | uint8_t[6] | dst = AA:BB:CC:00:00:01"
      src2: "0x06 | uint8_t[6] | src = DD:EE:FF:00:00:01"
      type2: "0x0C | uint16_t | type = 0x0806 (ARP)"
      payload2: "0x0E | ARP pkt  | [28 bytes ARP]"
      sz2: "Total: 42 bytes"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step3: {
    direction: down
    label: "Step 3: Cache Population"
    width: 600
    step3_desc: {
      label: "Both hosts update caches from observed traffic"
      shape: text
      style.font-color: "#555"
    }
    passive_learning: {
      label: "Passive Learning Rule"
      code: |'c
        // Any ARP packet teaches us something
        void arp_learn(cache, sender_ip, sender_mac) {
          entry = cache_lookup(cache, sender_ip);
          if (entry) {
            entry->mac = sender_mac;
            entry->state = REACHABLE;
            entry->expires = now + 300s;
          }
        }
      '|
      width: 350
    }
    host_a_after: {
      shape: sql_table
      label: "Host A Cache (After)"
      ip_a: "ip = 192.168.1.50"
      mac_a: "mac = DD:EE:FF:00:00:01"
      state_a: "state = REACHABLE"
      sz_a: "(from reply)"
    }
    host_b_after: {
      shape: sql_table
      label: "Host B Cache (After)"
      ip_b: "ip = 192.168.1.10"
      mac_b: "mac = AA:BB:CC:00:00:01"
      state_b: "state = REACHABLE"
      sz_b: "(from request)"
    }
  }
  step4: {
    direction: down
    label: "Step 4: Gratuitous ARP (Optional)"
    width: 600
    step4_desc: {
      label: "Announce presence, detect IP conflicts"
      shape: text
      style.font-color: "#555"
    }
    gratuitous_pkt: {
      shape: sql_table
      label: "Gratuitous ARP (Announcement)"
      g_htype: "0x00 | uint16_t | htype = 1"
      g_ptype: "0x02 | uint16_t | ptype = 0x0800"
      g_hlen: "0x04 | uint8_t  | hlen = 6"
      g_plen: "0x05 | uint8_t  | plen = 4"
      g_oper: "0x06 | uint16_t | oper = 1 (REQUEST)"
      g_sha: "0x08 | uint8_t[6] | sha = DD:EE:FF:00:00:01"
      g_spa: "0x0E | uint32_t | spa = 192.168.1.50"
      g_tha: "0x12 | uint8_t[6] | tha = 00:00:00:00:00:00"
      g_tpa: "0x18 | uint32_t | tpa = 192.168.1.50"
      g_sz: "Asking about own IP!"
    }
    conflict_detect: {
      label: "Conflict Detection"
      code: |'c
        // If we receive ARP for our IP
        // from a DIFFERENT MAC, conflict!
        if (tpa == our_ip && 
            sha != our_mac) {
          log("IP CONFLICT DETECTED!");
          // May send defensive ARP
        }
      '|
      width: 300
    }
  }
}
flow_arrows: {
  direction: down
  host_a_to_switch: {
    label: "Broadcast to all ports"
    code: |'c
      eth.dst = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
      eth.src = {0xAA,0xBB,0xCC,0,0,1};
      eth.type = 0x0806;
    '|
    width: 320
  }
}
host_a -> switch: "ARP Request\n(Broadcast)" {
  style.stroke: "#8B0000"
  style.stroke-width: 3
}
switch -> host_b: "ARP Request\n(Flooded)" {
  style.stroke: "#8B0000"
  style.stroke-dash: 4
}
host_b -> switch: "ARP Reply\n(Unicast to A)" {
  style.stroke: "#006400"
  style.stroke-width: 3
}
switch -> host_a: "ARP Reply\n(Forwarded)" {
  style.stroke: "#006400"
}
legend: {
  near: bottom-center
  style.fill: "#F5F5F5"
  style.stroke: "#CCC"
  broadcast_line: "───── Broadcast (FF:FF:FF:FF:FF:FF)" {
    shape: text
    style.font-color: "#8B0000"
  }
  unicast_line: "───── Unicast (specific MAC)" {
    shape: text
    style.font-color: "#006400"
  }
  timing_note: "Typical: 1-3ms for complete exchange" {
    shape: text
    style.font-color: "#666"
    style.italic: true
  }
}