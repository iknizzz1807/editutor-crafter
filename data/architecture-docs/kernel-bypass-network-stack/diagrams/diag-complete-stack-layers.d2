direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Kernel Bypass Network Stack — Complete Architecture
  **Full vertical slice: Application → TCP → IP → Ethernet → NIC**
| {near: top-center}

row_app: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  app_api: {
    direction: down
    label: "Application Layer"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    api: {
      shape: class
      label: "User API (tcp_api.c)"
      +connect(dst_ip, dst_port): "tcp_conn_t*"
      +send(conn, data, len): "int"
      +recv(conn, buf, len): "int"
      +close(conn): "int"
    }
    app_buf: {
      shape: sql_table
      label: "Application Buffer (app_buf)"
      f0: "0x00 | uint8_t* | data"
      f1: "0x08 | uint32_t | len"
      f2: "0x0C | uint32_t | offset"
      sz: "Total: 16 bytes"
    }
  }
}

row_tcp: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tcp_layer: {
    direction: down
    label: "TCP Layer (tcp.c)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    tcp_conn: {
      shape: class
      label: "struct tcp_conn (64B cache line)"
      -local_addr: "uint32_t"
      -remote_addr: "uint32_t"
      -local_port: "uint16_t"
      -remote_port: "uint16_t"
      -snd_una: "uint32_t"
      -snd_nxt: "uint32_t"
      -rcv_nxt: "uint32_t"
      -rcv_wnd: "uint32_t"
      -cwnd: "uint32_t"
      -state: "tcp_state_t"
      +tcp_input(conn, seg): "void"
      +tcp_output(conn, data, len): "int"
    }
    tcp_sendq: {
      shape: sql_table
      label: "TCP Send Buffer (tcp_send_buf)"
      f0: "0x00 | uint32_t | snd_una"
      f1: "0x04 | uint32_t | snd_nxt"
      f2: "0x08 | uint8_t* | data_ptr"
      f3: "0x10 | uint32_t | head"
      f4: "0x14 | uint32_t | tail"
      f5: "0x18 | uint64_t | rtx_timer"
      sz: "Total: 32 bytes + ring"
    }
    tcp_recvq: {
      shape: sql_table
      label: "TCP Recv Buffer (tcp_recv_buf)"
      f0: "0x00 | uint32_t | rcv_nxt"
      f1: "0x04 | uint32_t | rcv_wnd"
      f2: "0x08 | uint8_t* | data_ptr"
      f3: "0x10 | uint32_t | head"
      f4: "0x14 | uint32_t | tail"
      sz: "Total: 24 bytes + ring"
    }
  }
}

row_ip: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ip_layer: {
    direction: down
    label: "IP Layer (ip.c)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    ip_hdr: {
      shape: sql_table
      label: "IPv4 Header (20 bytes)"
      f0: "0x00 | uint8_t | ver_ihl"
      f1: "0x01 | uint8_t | tos"
      f2: "0x02 | uint16_t | total_len"
      f3: "0x04 | uint16_t | id"
      f4: "0x06 | uint16_t | flags_fragoff"
      f5: "0x08 | uint8_t | ttl"
      f6: "0x09 | uint8_t | protocol"
      f7: "0x0A | uint16_t | checksum"
      f8: "0x0C | uint32_t | src_addr"
      f9: "0x10 | uint32_t | dst_addr"
      sz: "Total: 20 bytes (IHL=5)"
    }
    route: {
      shape: class
      label: "Routing Table (route.c)"
      -entries: "route_entry[256]"
      +route_lookup(dst): "route_entry*"
    }
  }
  arp_layer: {
    direction: down
    label: "ARP Layer (arp.c)"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    arp_cache: {
      shape: sql_table
      label: "ARP Cache (arp_cache_t)"
      f0: "0x00 | uint32_t | ip"
      f1: "0x04 | uint8_t[6] | mac"
      f2: "0x0A | uint8_t | state"
      f3: "0x0B | uint8_t | pad[5]"
      f4: "0x10 | uint64_t | expires_at"
      sz: "Total: 24 bytes/entry"
    }
  }
}

row_eth: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  eth_layer: {
    direction: down
    label: "Ethernet Layer (eth.c)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    eth_hdr: {
      shape: sql_table
      label: "Ethernet Header (14 bytes)"
      f0: "0x00 | uint8_t[6] | dst_mac"
      f1: "0x06 | uint8_t[6] | src_mac"
      f2: "0x0C | uint16_t | ethertype"
      sz: "Total: 14 bytes"
    }
    eth_parse: {
      shape: class
      label: "eth_parse_result"
      -dst_mac: "const uint8_t*"
      -src_mac: "const uint8_t*"
      -ethertype: "uint16_t"
      -payload: "const uint8_t*"
      -payload_len: "uint16_t"
      +eth_parse(pkt, len, out): "int"
    }
  }
}

row_driver: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  driver_layer: {
    direction: down
    label: "NIC Driver Layer (driver.c)"
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    xsk: {
      shape: class
      label: "AF_XDP Socket (xsk.c)"
      -rx_ring: "xsk_ring_cons"
      -tx_ring: "xsk_ring_prod"
      -umem: "xsk_umem_info*"
      -fd: "int"
      +xsk_rx_burst(xsk, bufs, n): "uint32_t"
      +xsk_tx_burst(xsk, bufs, n): "uint32_t"
    }
    umem: {
      shape: sql_table
      label: "UMEM Configuration"
      f0: "0x00 | void* | area"
      f1: "0x08 | size_t | size"
      f2: "0x10 | uint32_t | frame_size"
      f3: "0x14 | uint32_t | num_frames"
      sz: "Pool: 2048 frames × 2KB"
    }
  }
  ring_layer: {
    direction: down
    label: "Ring Buffers (Zero-Copy)"
    style.fill: "#FFFDE7"
    style.stroke: "#FFC107"
    fill_ring: {
      shape: sql_table
      label: "Fill Ring (App → Kernel)"
      f0: "0x00 | uint64_t | addr[0]"
      f1: "0x08 | uint64_t | addr[1]"
      f2: "0x10 | uint64_t | addr_offset"
      note: "Producer: App, Consumer: Kernel"
    }
    rx_ring: {
      shape: sql_table
      label: "RX Ring (Kernel → App)"
      f0: "0x00 | uint64_t | addr"
      f1: "0x08 | uint32_t | len"
      f2: "0x0C | uint32_t | options"
      note: "Producer: Kernel, Consumer: App"
    }
    tx_ring: {
      shape: sql_table
      label: "TX Ring (App → Kernel)"
      f0: "0x00 | uint64_t | addr"
      f1: "0x08 | uint32_t | len"
      f2: "0x0C | uint32_t | options"
      note: "Producer: App, Consumer: Kernel"
    }
  }
}

row_hw: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  nic_hw: {
    direction: down
    label: "Hardware Layer"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    nic: {
      shape: class
      label: "NIC Hardware"
      -rx_desc_ring: "dma_addr_t*"
      -tx_desc_ring: "dma_addr_t*"
      -mmio_regs: "volatile uint32_t*"
      +DMA Engine: "Direct Memory Access"
      +PCIe Interface: "Gen3 x8 / Gen4 x4"
    }
    desc: {
      shape: sql_table
      label: "NIC Descriptor (16B)"
      f0: "0x00 | uint64_t | buf_addr"
      f1: "0x08 | uint16_t | length"
      f2: "0x0A | uint16_t | vlan_tag"
      f3: "0x0C | uint32_t | flags"
      sz: "16 bytes (1 cache line)"
    }
  }
  dma_region: {
    direction: down
    label: "DMA Memory Region"
    style.fill: "#E1F5FE"
    style.stroke: "#03A9F4"
    pkt_pool: {
      shape: cylinder
      label: "Packet Buffer Pool\n2048 × 2KB frames\n4MB total"
    }
    dma_note: {
      label: |'md
        **Zero-Copy Path:**
        1. NIC DMA → Packet Buffer
        2. App reads same buffer
        3. No copy between layers
        4. Return addr to Fill Ring
      '|
    }
  }
}

legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  "title_node": {
    label: "Buffer Ownership Transfer"
    style.bold: true
  }
  "ptr_pass": {
    label: "——► Pointer pass (0-copy)"
    style.stroke: "#4CAF50"
  }
  "hdr_prepend": {
    label: "------► Header prepend only"
    style.stroke: "#FF5722"
    style.stroke-dash: 4
  }
  "dma_xfer": {
    label: "~~~~~~~~► DMA transfer"
    style.stroke: "#9C27B0"
    style.stroke-dash: 3
  }
}

row_app.app_api.api -> row_tcp.tcp_layer.tcp_conn: "tcp_conn_t* | connect" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_tcp.tcp_layer.tcp_sendq -> row_ip.ip_layer.ip_hdr: "payload ptr | segment" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_ip.ip_layer.route -> row_ip.arp_layer.arp_cache: "next_hop IP | lookup" {
  style.stroke: "#E91E63"
}
row_ip.arp_layer.arp_cache -> row_eth.eth_layer.eth_hdr: "dst_mac | resolved" {
  style.stroke: "#E91E63"
}
row_eth.eth_layer.eth_hdr -> row_driver.driver_layer.xsk: "frame ptr | build" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_driver.driver_layer.umem -> row_driver.ring_layer.tx_ring: "frame addr | enqueue" {
  style.stroke: "#FFC107"
}
row_driver.ring_layer.tx_ring -> row_hw.nic_hw.nic: "desc addr | MMIO doorbell" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
}
row_hw.nic_hw.nic -> row_hw.dma_region.pkt_pool: "DMA | read packet" {
  style.stroke: "#03A9F4"
  style.stroke-dash: 5
  style.animated: true
}
row_hw.nic_hw.nic -> row_driver.ring_layer.rx_ring: "RX desc | writeback" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
}
row_driver.ring_layer.rx_ring -> row_driver.driver_layer.umem: "frame addr | dequeue" {
  style.stroke: "#FFC107"
}
row_driver.driver_layer.xsk -> row_eth.eth_layer.eth_parse: "pkt_data | parse" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_eth.eth_layer.eth_parse -> row_ip.ip_layer.ip_hdr: "payload ptr | IP hdr" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_ip.ip_layer.ip_hdr -> row_tcp.tcp_layer.tcp_conn: "TCP segment | lookup conn" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_tcp.tcp_layer.tcp_recvq -> row_app.app_api.app_buf: "data ptr | deliver" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

stats: {
  near: bottom-center
  label: |'md
    **Latency Budget (Target: <5μs)**
    | Layer | Operation | Budget |
    |-------|-----------|--------|
    | NIC | DMA to ring | ~100ns |
    | Driver | Ring poll | ~5ns |
    | Eth | Header parse | ~20ns |
    | IP | Header parse | ~20ns |
    | TCP | Header + lookup | ~50ns |
    | TCP | Data process | ~100ns |
    | App | Buffer delivery | ~50ns |
    | **Total** | **Hot path** | **~345ns** |
  '|
}