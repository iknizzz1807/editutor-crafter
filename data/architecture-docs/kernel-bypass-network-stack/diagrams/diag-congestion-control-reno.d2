direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Reno Congestion Control — AIMD State Machine
  **Additive Increase, Multiplicative Decrease**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  slow_start: {
    direction: down
    label: "SLOW START\n(Exponential Growth)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    ss_desc: {
      label: "cwnd < ssthresh"
      shape: diamond
      style.fill: "#C8E6C9"
    }
    ss_growth: {
      label: "cwnd += MSS per ACK\n(Window doubles per RTT)"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    ss_desc -> ss_growth: "enter"
    ss_exit: {
      label: "cwnd >= ssthresh?"
      shape: diamond
      style.fill: "#C8E6C9"
    }
    ss_growth -> ss_exit: "each ACK"
  }
  congestion_avoidance: {
    direction: down
    label: "CONGESTION AVOIDANCE\n(Linear Growth)"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    ca_desc: {
      label: "cwnd >= ssthresh"
      shape: diamond
      style.fill: "#BBDEFB"
    }
    ca_growth: {
      label: "cwnd += (MSS² / cwnd) per ACK\n(~1 MSS per RTT)"
      shape: rectangle
      style.fill: "#90CAF9"
    }
    ca_desc -> ca_growth: "enter"
    ca_steady: {
      label: "Steady-state\nprobing"
      shape: rectangle
      style.fill: "#64B5F6"
    }
    ca_growth -> ca_steady: "continue"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  loss_detection: {
    direction: down
    label: "LOSS DETECTION"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    triple_dup: {
      label: "3× Duplicate ACK\n(Fast Retransmit)"
      shape: hexagon
      style.fill: "#FFCC80"
    }
    timeout_event: {
      label: "RTO Timeout\n(Slow Start Reset)"
      shape: hexagon
      style.fill: "#FFAB91"
    }
  }
  recovery: {
    direction: down
    label: "FAST RECOVERY"
    style.fill: "#FCE4EC"
    style.stroke: "#AD1457"
    fr_enter: {
      label: "ssthresh = cwnd/2\ncwnd = ssthresh + 3×MSS"
      shape: rectangle
      style.fill: "#F8BBD9"
    }
    fr_process: {
      label: "cwnd += MSS per dup ACK\n(Inflate window)"
      shape: rectangle
      style.fill: "#F48FB1"
    }
    fr_exit: {
      label: "New ACK arrives\ncwnd = ssthresh"
      shape: rectangle
      style.fill: "#EC407A"
      style.font-color: white
    }
    fr_enter -> fr_process -> fr_exit
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeout_recovery: {
    direction: down
    label: "TIMEOUT RECOVERY\n(Severe Loss)"
    style.fill: "#FFEBEE"
    style.stroke: "#B71C1C"
    to_action: {
      label: "ssthresh = cwnd/2\ncwnd = 1 MSS"
      shape: rectangle
      style.fill: "#FFCDD2"
    }
    to_restart: {
      label: "Restart from\nSLOW START"
      shape: rectangle
      style.fill: "#EF5350"
      style.font-color: white
    }
    to_action -> to_restart
  }
}
# State transitions
slow_start.ss_exit -> congestion_avoidance.ca_desc: "YES\nenter CA" {
  style.stroke: "#1565C0"
  style.stroke-width: 3
}
slow_start.ss_exit -> slow_start.ss_growth: "NO\ncontinue SS" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
congestion_avoidance.ca_steady -> loss_detection.triple_dup: "3 dup ACKs" {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
congestion_avoidance.ca_steady -> loss_detection.timeout_event: "timeout" {
  style.stroke: "#B71C1C"
  style.stroke-width: 2
  style.stroke-dash: 5
}
loss_detection.triple_dup -> recovery.fr_enter: "Fast Retransmit" {
  style.stroke: "#AD1457"
  style.stroke-width: 3
}
recovery.fr_exit -> congestion_avoidance.ca_desc: "Resume CA" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
loss_detection.timeout_event -> timeout_recovery.to_action: "Severe loss" {
  style.stroke: "#B71C1C"
  style.stroke-width: 3
}
timeout_recovery.to_restart -> slow_start.ss_desc: "Reset to SS" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}
# Loss from slow start
slow_start.ss_growth -> loss_detection.triple_dup: "loss detected" {
  style.stroke: "#E65100"
  style.stroke-dash: 4
}
# Variables panel
variables: {
  label: "State Variables"
  shape: sql_table
  style.fill: "#F5F5F5"
  cwnd: "cwnd | uint32 | Congestion window (bytes)"
  ssthresh: "ssthresh | uint32 | Slow start threshold"
  mss: "MSS | uint16 | Maximum segment size (~1460)"
  dup_count: "dup_ack | uint8 | Duplicate ACK counter"
}
# Algorithm summary
aimd_summary: {
  label: "AIMD Algorithm"
  shape: class
  style.fill: "#E1F5FE"
  +additive_increase: "cwnd grows linearly in CA"
  +multiplicative_decrease: "cwnd = cwnd / 2 on loss"
  +slow_start: "cwnd doubles per RTT initially"
  +fast_recovery: "Avoid reset on single loss"
  -timeout_penalty: "Full reset to 1 MSS"
}
legend: {
  near: bottom-center
  label: "Transition Legend"
  shape: rectangle
  style.fill: transparent
  style.stroke: "#9E9E9E"
  normal: "────▶ Normal transition"
  loss: "- - -▶ Loss detection"
  recovery_path: "════▶ Recovery path"
}
legend.normal.style.stroke: "#1565C0"
legend.loss.style.stroke: "#E65100"
legend.loss.style.stroke-dash: 5
legend.recovery_path.style.stroke: "#AD1457"
legend.recovery_path.style.stroke-width: 3