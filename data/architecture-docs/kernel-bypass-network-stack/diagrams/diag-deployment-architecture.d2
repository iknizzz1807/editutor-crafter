direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Production Deployment Architecture
  Kernel Bypass Stack — High Availability Configuration
| {near: top-center}
row_trading: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  trading: Trading Systems {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    strategy: Strategy Engine {
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    risk: Risk Management {
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    order: Order Router {
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    strategy -> risk: validate
    risk -> order: approve
  }
}
row_stack: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  stack: Kernel Bypass Stack {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    api: API Layer {
      shape: rectangle
      style.fill: "#BBDEFB"
      +connect(dst, port): "int"
      +send(conn, data, len): "ssize_t"
      +recv(conn, buf, len): "ssize_t"
      +close(conn): "int"
    }
    tcp: TCP Layer {
      shape: rectangle
      style.fill: "#BBDEFB"
      -conn_table: "struct tcp_conn*"
      -cwnd: "uint32_t"
      +tcp_input(pkt): "void"
      +tcp_output(conn): "int"
    }
    ip: IP/UDP Layer {
      shape: rectangle
      style.fill: "#BBDEFB"
      -routing_table: "struct route_entry*"
      -frag_table: "struct frag_entry*"
      +ip_input(pkt): "void"
      +ip_output(dst, proto): "int"
    }
    eth: Ethernet/ARP {
      shape: rectangle
      style.fill: "#BBDEFB"
      -arp_cache: "struct arp_cache"
      +eth_parse(pkt): "struct eth_hdr*"
      +eth_build(frame): "uint16_t"
    }
    bypass: Kernel Bypass {
      shape: rectangle
      style.fill: "#90CAF9"
      -rx_ring: "struct xsk_ring_cons"
      -tx_ring: "struct xsk_ring_prod"
      -umem: "struct xsk_umem_info*"
      +xsk_poll(): "uint32_t"
      +xsk_send(pkt): "int"
    }
    api -> tcp: "tcp_send()"
    tcp -> ip: "ip_output()"
    ip -> eth: "eth_build()"
    eth -> bypass: "xsk_send()"
    bypass -> eth: "RX pkt"
    eth -> ip: "ip_input()"
    ip -> tcp: "tcp_input()"
    tcp -> api: "recv_cb()"
  }
}
row_ha: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  ha: High Availability {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    primary: Primary Node {
      shape: rectangle
      style.fill: "#FFE0B2"
      style.bold: true
    }
    secondary: Secondary Node {
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke-dash: 3
    }
    heartbeat: Heartbeat Service {
      shape: diamond
      style.fill: "#FFCC80"
      -interval_ms: "10"
      -timeout_ms: "100"
      +send_pulse(): "void"
      +check_alive(): "int"
    }
    failover: Failover Controller {
      shape: hexagon
      style.fill: "#FFCC80"
      -state: "PRIMARY|SECONDARY"
      -vip: "uint32_t"
      +promote(): "void"
      +demote(): "void"
      +arp_gratuitous(): "void"
    }
    primary -> heartbeat: "pulse"
    heartbeat -> secondary: "monitor"
    heartbeat -> failover: "timeout"
    failover -> secondary: "promote"
    secondary -> failover: "ack"
  }
}
row_network: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  network: Network Interfaces {
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    bonding: NIC Bonding (LACP) {
      shape: rectangle
      style.fill: "#E1BEE7"
      -mode: "802.3ad"
      -slaves: "2"
      style.multiple: true
    }
    nic0: NIC 0 {
      shape: rectangle
      style.fill: "#CE93D8"
      -pci: "0000:01:00.0"
      -driver: "vfio-pci"
    }
    nic1: NIC 1 {
      shape: rectangle
      style.fill: "#CE93D8"
      -pci: "0000:01:00.1"
      -driver: "vfio-pci"
    }
    mgmt: Management NIC {
      shape: rectangle
      style.fill: "#CE93D8"
      -pci: "0000:02:00.0"
      -driver: "igb"
    }
    bonding -> nic0: "active"
    bonding -> nic1: "standby"
  }
}
row_exchange: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  exchange: Exchange Gateway {
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    gw: Exchange {
      shape: cloud
      style.fill: "#FFCDD2"
    }
    switch: Core Switch {
      shape: rectangle
      style.fill: "#FFCDD2"
    }
    switch -> gw: "market data"
    gw -> switch: "orders"
  }
}
row_mgmt: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  mgmt_net: Management Network {
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    monitor: Monitoring {
      shape: rectangle
      style.fill: "#CFD8DC"
      -prometheus: ":9090"
      -grafana: ":3000"
    }
    config: Config Server {
      shape: rectangle
      style.fill: "#CFD8DC"
    }
    log: Log Aggregator {
      shape: rectangle
      style.fill: "#CFD8DC"
    }
  }
}
trading.order -> stack.api: "send_order()"
stack.api -> trading.api: "on_fill()"
stack.bypass -> network.bonding: "DMA RX/TX"
ha.primary -> stack: "active"
ha.secondary -> stack: "standby"
network.bonding -> exchange.switch: "L2 link"
exchange.switch -> network.bonding: "L2 link"
network.mgmt -> mgmt_net.monitor: "metrics"
network.mgmt -> mgmt_net.config: "sync"
network.mgmt -> mgmt_net.log: "logs"
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  data: Data Path {
    shape: rectangle
    style.fill: "#E3F2FD"
  }
  ha_legend: HA Control {
    shape: rectangle
    style.fill: "#FFF3E0"
  }
  mgmt_legend: Management {
    shape: rectangle
    style.fill: "#ECEFF1"
  }
}
connections_legend: |md
  **Connection Types:**
  - Solid: Data flow
  - Dashed: Control/standby
  - Animated: Active heartbeat
| {near: bottom-center}