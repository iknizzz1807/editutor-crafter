direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "DPDK vs. AF_XDP Architecture Comparison"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_compare: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  dpdk_side: {
    direction: down
    label: "DPDK Approach"
    dpdk_app: {
      label: "Application"
      shape: rectangle
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
    }
    dpdk_pmd: {
      label: "Poll Mode Driver (PMD)"
      shape: class
      label: "PMD (user-space)"
      -vendor_driver: "void*"
      -register_map: "volatile uint32_t*"
      -ring_base: "struct rte_ring*"
      +poll_rx(queue): "uint16_t"
      +send_tx(queue, mbufs): "uint16_t"
      +init_device(pci_addr): "int"
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
      }
    }
    dpdk_mempool: {
      label: "Hugepage Memory Pool\n(DMA-safe, physically contiguous)"
      shape: cylinder
      style: {
        fill: "#A5D6A7"
        stroke: "#43A047"
      }
    }
    dpdk_nic: {
      label: "NIC Hardware\n(Detached from kernel)"
      shape: rectangle
      style: {
        fill: "#81C784"
        stroke: "#2E7D32"
        stroke-width: 3
      }
    }
    dpdk_app -> dpdk_pmd: "rte_eth_rx_burst()"
    dpdk_pmd -> dpdk_mempool: "DMA direct"
    dpdk_pmd <-> dpdk_nic: "MMIO registers"
    dpdk_mempool <-> dpdk_nic: "DMA"
  }
  afxdp_side: {
    direction: down
    label: "AF_XDP Approach"
    xdp_app: {
      label: "Application"
      shape: rectangle
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
        stroke-width: 2
      }
    }
    xdp_socket: {
      label: "AF_XDP Socket"
      shape: class
      label: "xsk_socket"
      -fd: "int"
      -umem: "struct xsk_umem*"
      -rx_ring: "struct xsk_ring_cons"
      -tx_ring: "struct xsk_ring_prod"
      +recv(): "int"
      +send(addr, len): "int"
      +get_data(addr): "void*"
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
      }
    }
    xdp_umem: {
      label: "UMEM Region\n(User-space registered)"
      shape: cylinder
      style: {
        fill: "#90CAF9"
        stroke: "#1E88E5"
      }
    }
    xdp_kernel: {
      label: "Kernel XDP Program\n(Runs in driver context)"
      shape: rectangle
      width: 200
      code: |'c
        SEC("xdp")
        int xdp_prog(struct xdp_md *ctx) {
          // Early packet filter
          // Redirect to AF_XDP socket
          return XDP_PASS;
        }
      '|
      style: {
        fill: "#64B5F6"
        stroke: "#1565C0"
      }
    }
    xdp_nic: {
      label: "NIC Hardware\n(Kernel driver attached)"
      shape: rectangle
      style: {
        fill: "#42A5F5"
        stroke: "#1565C0"
        stroke-width: 3
      }
    }
    xdp_app -> xdp_socket: "recvmsg()"
    xdp_socket -> xdp_umem: "UMEM lookup"
    xdp_socket <- xdp_kernel: "Fill/RX rings"
    xdp_kernel <- xdp_nic: "Driver RX"
    xdp_umem <-> xdp_nic: "DMA (zerocopy mode)"
  }
}
row_rings: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  dpdk_rings: {
    label: "DPDK Ring Structure"
    shape: sql_table
    label: "struct rte_ring (lock-free SPSC)"
    f0: "0x00 | uint32_t | prod.head"
    f1: "0x04 | uint32_t | prod.tail"
    f2: "0x08 | uint32_t | cons.head"
    f3: "0x0C | uint32_t | cons.tail"
    f4: "0x10 | void*[]   | ring[]"
    sz: "Cache-line aligned per producer/consumer"
    style: {
      fill: "#C8E6C9"
    }
  }
  xdp_rings: {
    label: "AF_XDP Four-Ring Design"
    shape: sql_table
    label: "AF_XDP Ring Quartet"
    f0: "Fill Ring  | App → Kernel | Available buffers"
    f1: "RX Ring    | Kernel → App | Received packets"
    f2: "TX Ring    | App → Kernel | Packets to send"
    f3: "Comp Ring  | Kernel → App | TX completions"
    sz: "Each ring: producer + consumer indices"
    style: {
      fill: "#BBDEFB"
    }
  }
}
row_tradeoffs: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  dpdk_tradeoffs: {
    direction: down
    label: "DPDK Characteristics"
    dpdk_pros: {
      label: "Strengths"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 280
      code: |'text
        ✓ Ultra-low latency (0.5-2μs)
        ✓ Predictable performance
        ✓ Full hardware control
        ✓ Mature ecosystem (10+ years)
        ✓ Hardware offload support
      '|
    }
    dpdk_cons: {
      label: "Requirements"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 280
      code: |'text
        ✗ Specific NIC hardware required
        ✗ Hugepages mandatory
        ✗ NIC detached from kernel
        ✗ Root/capabilities needed
        ✗ Complex setup
      '|
    }
  }
  xdp_tradeoffs: {
    direction: down
    label: "AF_XDP Characteristics"
    xdp_pros: {
      label: "Strengths"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 280
      code: |'text
        ✓ Standard Linux interface
        ✓ Works with any XDP-capable NIC
        ✓ Kernel networking coexists
        ✓ Simpler deployment
        ✓ No special drivers needed
      '|
    }
    xdp_cons: {
      label: "Requirements"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 280
      code: |'text
        ✗ Higher latency (2-5μs)
        ✗ Linux 5.4+ recommended
        ✗ XDP program overhead
        ✗ Less mature ecosystem
        ✗ Some kernel path still active
      '|
    }
  }
}
row_versions: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  version_table: {
    label: "Version Requirements"
    shape: sql_table
    label: "Kernel Version Matrix"
    r0: "Linux 4.18  | AF_XDP introduced"
    r1: "Linux 5.1   | XDP_REDIRECT support"
    r2: "Linux 5.4   | Production-ready AF_XDP"
    r3: "Linux 5.10  | XDP multi-buffer, improved perf"
    r4: "DPDK 20.11+ | AF_XDP PMD available"
    r5: "DPDK 22.11+ | Full AF_XDP feature parity"
  }
  perf_table: {
    label: "Performance Comparison"
    shape: sql_table
    label: "Latency & Throughput"
    r0: "Metric          | DPDK      | AF_XDP"
    r1: "RX latency      | 0.5-2μs   | 2-5μs"
    r2: "TX latency      | 0.3-1μs   | 1-3μs"
    r3: "Throughput      | ~40 Mpps  | ~20 Mpps"
    r4: "Zero-copy       | Yes       | Yes (5.4+)"
    r5: "Batch efficiency| Excellent | Good"
  }
}
dpdk_side -> xdp_side: "Trade-off:\nControl vs. Convenience" {
  style: {
    stroke-dash: 4
    stroke: "#7B1FA2"
  }
}