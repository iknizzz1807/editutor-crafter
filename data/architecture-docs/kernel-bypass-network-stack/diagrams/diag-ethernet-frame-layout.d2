direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Ethernet Frame Structure — Byte Layout
| {near: top-center}

# Physical Layer Components
preamble_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  preamble: {
    shape: sql_table
    label: "Preamble (802.3 PLCP)"
    b0: "0x00 | 7 bytes | 0x55 0x55 0x55 0x55 0x55 0x55 0x55"
    note: "Alternating bits for clock synchronization"
  }
  sfd: {
    shape: sql_table
    label: "SFD (Start Frame Delimiter)"
    b0: "0x07 | 1 byte | 0xD5 (11010101)"
    note: "Marks start of Ethernet frame"
  }
}

preamble_row -> frame_row: "L1 -> L2 Handover"

# Data Link Layer - Main Ethernet Frame
frame_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  eth_header: {
    direction: down
    label: "Ethernet Header (14 bytes)"
    dst_mac: {
      shape: sql_table
      label: "Destination MAC (eth.h)"
      b0: "0x00 | uint8_t[0] | dst[0]"
      b1: "0x01 | uint8_t[1] | dst[1]"
      b2: "0x02 | uint8_t[2] | dst[2]"
      b3: "0x03 | uint8_t[3] | dst[3]"
      b4: "0x04 | uint8_t[4] | dst[4]"
      b5: "0x05 | uint8_t[5] | dst[5]"
      sz: "Total: 6 bytes"
    }
    src_mac: {
      shape: sql_table
      label: "Source MAC (eth.h)"
      b0: "0x06 | uint8_t[0] | src[0]"
      b1: "0x07 | uint8_t[1] | src[1]"
      b2: "0x08 | uint8_t[2] | src[2]"
      b3: "0x09 | uint8_t[3] | src[3]"
      b4: "0x0A | uint8_t[4] | src[4]"
      b5: "0x0B | uint8_t[5] | src[5]"
      sz: "Total: 6 bytes"
    }
    ethertype: {
      shape: sql_table
      label: "EtherType (Network Order)"
      b0: "0x0C | uint8_t[0] | type_hi"
      b1: "0x0D | uint8_t[1] | type_lo"
      v1: "0x0800 | IPv4"
      v2: "0x86DD | IPv6"
      v3: "0x0806 | ARP"
      sz: "Total: 2 bytes"
    }
  }

  payload: {
    direction: down
    label: "Data Payload"
    payload_table: {
      shape: sql_table
      label: "L3 Segment (IP/ARP)"
      b0: "0x0E | data[0]"
      b1: "0x0F | data[1]"
      b2: "0x10 | ..."
      b3: "0xXX | data[N]"
      min: "Min: 46 bytes (padded)"
      max: "Max: 1500 bytes (MTU)"
    }
  }

  fcs: {
    shape: sql_table
    label: "FCS (Frame Check Sequence)"
    b0: "N+0 | crc[0]"
    b1: "N+1 | crc[1]"
    b2: "N+2 | crc[2]"
    b3: "N+3 | crc[3]"
    note: "CRC-32 (IEEE 802.3)"
    sz: "4 bytes (NIC verified)"
  }
}

eth_header.dst_mac -> eth_header.src_mac -> eth_header.ethertype -> payload.payload_table -> fcs

# VLAN Tagging Extension
vlan_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vlan_insert: {
    label: "802.1Q VLAN Tag (4 bytes)"
    shape: sql_table
    b0: "0x0C | uint16_t | TPID = 0x8100"
    b1: "0x0E | uint16_t | TCI (PCP+DEI+VID)"
    tci_vid: "VID: 12-bit VLAN ID"
    tci_pcp: "PCP: 3-bit Priority"
  }
  vlan_logic: {
    label: "VLAN Insertion Logic"
    code: |'c
      // Replaces EtherType position at 0x0C
      // Original EtherType shifts to offset 0x10
      [DST][SRC][0x8100][TCI][TYPE][PAYLOAD]
    '|
    width: 380
  }
}

frame_row -> vlan_row: "Optional Tagging"

# Size Specifications
sizes_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  min_frame: {
    shape: rectangle
    label: "Minimum Frame: 64B\n(14B Hdr + 46B Payload + 4B FCS)"
    style.fill: "#FFE4B5"
  }
  max_frame: {
    shape: rectangle
    label: "Standard MTU: 1518B\n(14B Hdr + 1500B Payload + 4B FCS)"
    style.fill: "#98FB98"
  }
  jumbo_frame: {
    shape: rectangle
    label: "Jumbo Frame: ~9018B\n(HW Support Required)"
    style.fill: "#ADD8E6"
    style.stroke-dash: 4
  }
}

# Performance & Hardware Alignment
perf_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cache_info: {
    shape: class
    label: "Cache Alignment (x86_64)"
    line_size: "64 bytes"
    header_offset: "14 bytes"
    alignment: "Requires __attribute__((packed))"
    latency: "L1 Hit: ~1ns | L1 Miss: ~4ns"
  }
  cache_layout: {
    shape: sql_table
    label: "struct eth_hdr (C)"
    f0: "0x00 | uint8_t[6] | dst"
    f1: "0x06 | uint8_t[6] | src"
    f2: "0x0C | uint16_t   | type"
    sz: "Total: 14 bytes"
  }
  align_code: {
    label: "Alignment Macro"
    code: |'c
      struct eth_hdr {
          uint8_t  dst[6];
          uint8_t  src[6];
          uint16_t type;
      } __attribute__((packed));
    '|
    width: 350
  }
}

# Parsing Component
parse_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parse_struct: {
    shape: class
    label: "High-Performance Parser"
    +eth_parse(frame, len, res): "int"
    -res_dst_mac: "uint8_t*"
    -res_src_mac: "uint8_t*"
    -res_type: "uint16_t"
    -res_payload: "uint8_t*"
    -res_vlan: "int"
  }
  parse_logic: {
    label: "Parser Implementation"
    code: |'c
      int eth_parse(const uint8_t *pkt, uint16_t len, struct res *r) {
        if (len < 14) return -1;
        r->res_dst_mac = (uint8_t*)pkt;
        r->res_src_mac = (uint8_t*)pkt + 6;
        r->res_type = ntohs(*(uint16_t*)(pkt + 12));
        if (r->res_type == 0x8100) { // Handle VLAN
          r->res_type = ntohs(*(uint16_t*)(pkt + 16));
          r->res_payload = (uint8_t*)pkt + 18;
        } else {
          r->res_payload = (uint8_t*)pkt + 14;
        }
        return 0;
      }
    '|
    width: 400
  }
}

# Metadata & Legend
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  header: "Implementation Notes"
  endian: "All multi-byte fields are Big-Endian (Network Order)"
  offsets: "Byte offsets start at 0x00"
  stripping: "Preamble/SFD/FCS usually handled by NIC hardware"
}