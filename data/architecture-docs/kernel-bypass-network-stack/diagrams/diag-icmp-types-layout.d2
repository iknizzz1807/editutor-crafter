direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # ICMP Message Types and Layout
  Internet Control Message Protocol (RFC 792)
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  icmp_header: {
    shape: sql_table
    label: "struct icmp_hdr (icmp.h)"
    f0: "0x00 | uint8_t  | type"
    f1: "0x01 | uint8_t  | code"
    f2: "0x02 | uint16_t | checksum"
    f3: "0x04 | uint8_t[4]| data (type-specific)"
    sz: "Total: 8 bytes"
  }
  common_types: {
    label: "Common Message Types"
    shape: class
    +TYPE_ECHO_REPLY: "0"
    +TYPE_DEST_UNREACH: "3"
    +TYPE_REDIRECT: "5"
    +TYPE_ECHO_REQUEST: "8"
    +TYPE_TIME_EXCEEDED: "11"
    +TYPE_PARAM_PROBLEM: "12"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  echo_request: {
    shape: sql_table
    label: "Echo Request (type=8)"
    f0: "0x00 | 8        | type"
    f1: "0x01 | 0        | code"
    f2: "0x02 | uint16_t | checksum"
    f3: "0x04 | uint16_t | id"
    f4: "0x06 | uint16_t | seq"
    f5: "0x08 | uint8_t[]| data (optional)"
    sz: "Min: 8 bytes"
  }
  echo_reply: {
    shape: sql_table
    label: "Echo Reply (type=0)"
    f0: "0x00 | 0        | type"
    f1: "0x01 | 0        | code"
    f2: "0x02 | uint16_t | checksum"
    f3: "0x04 | uint16_t | id"
    f4: "0x06 | uint16_t | seq"
    f5: "0x08 | uint8_t[]| data (echoed)"
    sz: "Min: 8 bytes"
  }
  dest_unreach: {
    shape: sql_table
    label: "Dest Unreachable (type=3)"
    f0: "0x00 | 3        | type"
    f1: "0x01 | code     | 0-15"
    f2: "0x02 | uint16_t | checksum"
    f3: "0x04 | uint16_t | unused"
    f4: "0x06 | uint16_t | mtu (code=4)"
    f5: "0x08 | IP hdr   | original"
    f6: "0x1C | uint8_t[8]| orig data"
    sz: "Total: 36+ bytes"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  time_exceeded: {
    shape: sql_table
    label: "Time Exceeded (type=11)"
    f0: "0x00 | 11       | type"
    f1: "0x01 | code     | 0=TTL, 1=frag"
    f2: "0x02 | uint16_t | checksum"
    f3: "0x04 | uint32_t | unused"
    f4: "0x08 | IP hdr   | original"
    f5: "0x1C | uint8_t[8]| orig data"
    sz: "Total: 36+ bytes"
  }
  code_table: {
    label: "Destination Unreachable Codes"
    shape: class
    +CODE_NET_UNREACH: "0"
    +CODE_HOST_UNREACH: "1"
    +CODE_PROTO_UNREACH: "2"
    +CODE_PORT_UNREACH: "3"
    +CODE_FRAG_NEEDED: "4"
    +CODE_SRC_ROUTE_FAIL: "5"
    +CODE_NET_UNKNOWN: "6"
    +CODE_HOST_UNKNOWN: "7"
  }
}
processing_flow: {
  label: "ICMP Processing Flow (icmp.c)"
  direction: down
  step1: {
    label: "1. Parse ICMP Header"
    width: 350
    code: |'c
      struct icmp_hdr *icmp = (struct icmp_hdr *)ip->payload;
      if (ip->payload_len < 8) return -1;  // Too short
      if (ip_checksum(icmp, ip->payload_len) != 0) return -1;
    '|
  }
  step2: {
    label: "2. Dispatch by Type"
    width: 350
    code: |'c
      switch (icmp->type) {
        case ICMP_TYPE_ECHO_REQUEST:
          icmp_send_echo_reply(...);
          break;
        case ICMP_TYPE_DEST_UNREACH:
          if (icmp->code == 4) handle_pmtu(...);
          break;
        case ICMP_TYPE_TIME_EXCEEDED:
          handle_ttl_exceeded(...);
          break;
      }
    '|
  }
  step3: {
    label: "3. Echo Reply Generation"
    width: 350
    code: |'c
      // Swap src/dst IP, set type=0, recalc checksum
      reply->type = ICMP_TYPE_ECHO_REPLY;
      reply->checksum = 0;
      reply->checksum = ip_checksum(reply, len);
      ip_send(src_ip, dst_ip, IP_PROTO_ICMP, reply, len);
    '|
  }
  step1 -> step2 -> step3
}
legend: {
  near: bottom-center
  label: "ICMP in IP Stack"
  shape: class
  -encapsulation: "IP payload (proto=1)"
  -purpose: "Error reporting + diagnostics"
  -reliability: "Best-effort, no guarantees"
  -rate_limit: "Token bucket per source"
}
icmp_header -> echo_request: "type=8"
icmp_header -> echo_reply: "type=0"
icmp_header -> dest_unreach: "type=3"
icmp_header -> time_exceeded: "type=11"