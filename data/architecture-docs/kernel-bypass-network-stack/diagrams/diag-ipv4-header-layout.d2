direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: "IPv4 Header — Complete Byte Layout"
  note: "20-60 bytes | Network Byte Order (Big-Endian)"
  shape: rectangle
  style.fill: "#f3f4f6"
}
title_node.near: top-center

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  byte0: {
    shape: sql_table
    label: "Byte 0 (Bit 0-7)"
    f0: "0x00 | 4 bits | Version // 4 for IPv4"
    f1: "0x00 | 4 bits | IHL // Header length / 4"
    f2: "Range: 5 to 15 (20 to 60 bytes)"
  }

  byte1: {
    shape: sql_table
    label: "Byte 1 (Bit 8-15)"
    f0: "0x01 | 6 bits | DSCP // DiffServ Code Point"
    f1: "0x01 | 2 bits | ECN // Congestion Notification"
    f2: "TOS: Type of Service (Legacy)"
  }

  bytes2_3: {
    shape: sql_table
    label: "Bytes 2-3 (Total Length)"
    f0: "0x02 | uint8 | len_hi"
    f1: "0x03 | uint8 | len_lo"
    f2: "Total: 16-bit uint (Big Endian)"
    f3: "Size: Header + Data (Max 65535)"
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  bytes4_5: {
    shape: sql_table
    label: "Bytes 4-5 (Identification)"
    f0: "0x04 | uint8 | id_hi"
    f1: "0x05 | uint8 | id_lo"
    f2: "Usage: IP Fragmentation ID"
    f3: "Fragments of same packet share ID"
  }

  bytes6_7: {
    shape: sql_table
    label: "Bytes 6-7 (Flags & Offset)"
    f0: "0x06 | 3 bits | Flags // [R|DF|MF]"
    f1: "0x06 | 5 bits | Offset_hi"
    f2: "0x07 | 8 bits | Offset_lo"
    f3: "Unit: 8-byte blocks"
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  byte8: {
    shape: sql_table
    label: "Byte 8 (TTL)"
    f0: "0x08 | uint8 | time_to_live"
    f1: "Decrement per hop"
    f2: "ttl=0: Drop + ICMP Time Exceeded"
  }

  byte9: {
    shape: sql_table
    label: "Byte 9 (Protocol)"
    f0: "0x09 | uint8 | protocol_type"
    f1: "1: ICMP | 6: TCP | 17: UDP"
    f2: "See: IANA Registry"
  }

  bytes10_11: {
    shape: sql_table
    label: "Bytes 10-11 (Checksum)"
    f0: "0x0A | uint16 | header_checksum"
    f1: "Algorithm: 1s Complement Sum"
    f2: "Header only verification"
  }
}

row4: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  src_addr: {
    shape: sql_table
    label: "Bytes 12-15 (Source IP)"
    f0: "0x0C | uint8 | octet1"
    f1: "0x0D | uint8 | octet2"
    f2: "0x0E | uint8 | octet3"
    f3: "0x0F | uint8 | octet4"
    sz: "Total: 32 bits (IPv4)"
  }

  dst_addr: {
    shape: sql_table
    label: "Bytes 16-19 (Dest IP)"
    f0: "0x10 | uint8 | octet1"
    f1: "0x11 | uint8 | octet2"
    f2: "0x12 | uint8 | octet3"
    f3: "0x13 | uint8 | octet4"
    sz: "Total: 32 bits (IPv4)"
  }
}

row5: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  options_block: {
    shape: sql_table
    label: "Bytes 20-59 (Options)"
    f0: "Variable | 0-40 bytes"
    f1: "Active: Only if IHL > 5"
    f2: "Padding: Ensure 32-bit boundary"
  }

  checksum_logic: {
    shape: class
    label: "Checksum Calc (RFC 1071)"
    +calculate(buf, len): "uint16"
    -fold_carry(sum32): "uint16"
    note: "1. Sum 16-bit words"
    note2: "2. Fold 32-bit carries"
    note3: "3. Bitwise NOT result"
  }
}

row6: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ip_struct: {
    shape: class
    label: "struct ip_hdr (ip.h)"
    -v_ihl: "uint8_t"
    -tos: "uint8_t"
    -len: "uint16_t"
    -id: "uint16_t"
    -off: "uint16_t"
    -ttl: "uint8_t"
    -proto: "uint8_t"
    -sum: "uint16_t"
    -src: "uint32_t"
    -dst: "uint32_t"
    +get_ver(h): "uint8_t"
    +get_ihl(h): "uint8_t"
  }

  logic_impl: {
    label: "Implementation Macros"
    code: |'c
#define IP_V(ip)  (((ip)->v_ihl) >> 4)
#define IP_HL(ip) (((ip)->v_ihl) & 0x0f)
#define IP_OFF(ip) (ntohs((ip)->off) & 0x1fff)
    '|
  }
}

row1 -> row2: "Next 32-bits"
row2 -> row3: "Next 32-bits"
row3 -> row4: "Addresses"
row4 -> row5: "Extension"
row5 -> row6: "Implementation"