direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "MAC Address Byte Order: Wire vs. Memory Representations" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  wire_order: {
    direction: down
    label: "Wire Transmission Order"
    wire_frame: {
      shape: rectangle
      width: 600
      style.fill: "#E8F4FD"
      explanation: |md
        **On the Ethernet wire, MAC bytes transmit sequentially:**
        `00:11:22:33:44:55`
        - Byte 0 (`0x00`) transmitted first
        - Byte 5 (`0x55`) transmitted last
        - **Canonical bit order** — same on all systems
      |
    }
    wire_bytes: {
      shape: sql_table
      label: "Wire Order (canonical)"
      b0: "Byte 0 | 0x00 | First transmitted"
      b1: "Byte 1 | 0x11"
      b2: "Byte 2 | 0x22"
      b3: "Byte 3 | 0x33"
      b4: "Byte 4 | 0x44"
      b5: "Byte 5 | 0x55 | Last transmitted"
    }
    wire_bytes.style.fill: "#D4EDDA"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  little_endian: {
    direction: down
    label: "Little-Endian System (x86, ARM)"
    style.fill: "#FFF3CD"
    le_memory: {
      shape: sql_table
      label: "Memory Layout (uint8_t mac[6])"
      m0: "mac[0] | 0x00"
      m1: "mac[1] | 0x11"
      m2: "mac[2] | 0x22"
      m3: "mac[3] | 0x33"
      m4: "mac[4] | 0x44"
      m5: "mac[5] | 0x55"
      note: "Same as wire order when stored as byte array"
    }
    le_memory.style.fill: "#FFF3CD"
    le_trap: {
      label: "The Trap: uint64_t Interpretation"
      width: 350
      code: |'c
        // WRONG: Interpreting as integer
        uint64_t mac_int = *(uint64_t*)mac;
        // Result on LE: 0x5544332211000000
        // Bytes appear reversed!
        // WRONG: Comparing as integers
        if (mac_int == other_mac_int) ...
        // May fail due to padding byte differences
      '|
    }
    le_trap.style.fill: "#F8D7DA"
  }
  big_endian: {
    direction: down
    label: "Big-Endian System (PowerPC, SPARC)"
    style.fill: "#D4EDDA"
    be_memory: {
      shape: sql_table
      label: "Memory Layout (uint8_t mac[6])"
      m0: "mac[0] | 0x00"
      m1: "mac[1] | 0x11"
      m2: "mac[2] | 0x22"
      m3: "mac[3] | 0x33"
      m4: "mac[4] | 0x44"
      m5: "mac[5] | 0x55"
      note: "Same as wire order when stored as byte array"
    }
    be_memory.style.fill: "#D4EDDA"
    be_trap: {
      label: "The Trap: uint64_t Interpretation"
      width: 350
      code: |'c
        // WRONG: Interpreting as integer
        uint64_t mac_int = *(uint64_t*)mac;
        // Result on BE: 0x0011223344550000
        // Looks 'correct' but padding differs
        // across compilers/architectures
      '|
    }
    be_trap.style.fill: "#F8D7DA"
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  correct_approach: {
    direction: down
    label: "Correct Approach: Always Use Byte Arrays"
    style.fill: "#D4EDDA"
    correct_code: {
      label: "MAC Address Operations (mac_utils.h)"
      width: 500
      code: |'c
        // MAC address is ALWAYS uint8_t[6] — never interpret as integer
        typedef uint8_t mac_addr_t[6];
        // Compare: byte-by-byte (architecture independent)
        static inline int mac_eq(const uint8_t *a, const uint8_t *b) {
            return memcmp(a, b, 6) == 0;
        }
        // Copy: memcpy (never assign as struct/int)
        static inline void mac_cpy(uint8_t *dst, const uint8_t *src) {
            memcpy(dst, src, 6);
        }
        // Parse from string: "00:11:22:33:44:55"
        int mac_from_string(const char *str, uint8_t *mac) {
            unsigned int tmp[6];
            if (sscanf(str, "%02X:%02X:%02X:%02X:%02X:%02X",
                       &tmp[0], &tmp[1], &tmp[2],
                       &tmp[3], &tmp[4], &tmp[5]) != 6) {
                return -1;
            }
            for (int i = 0; i < 6; i++) {
                mac[i] = (uint8_t)tmp[i];
            }
            return 0;
        }
        // Convert to string (for logging)
        void mac_to_string(const uint8_t *mac, char *buf, size_t sz) {
            snprintf(buf, sz, "%02X:%02X:%02X:%02X:%02X:%02X",
                     mac[0], mac[1], mac[2],
                     mac[3], mac[4], mac[5]);
        }
      '|
    }
    correct_code.style.fill: "#E8F4FD"
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  wrong_patterns: {
    direction: down
    label: "Common Mistakes to Avoid"
    wrong_code: {
      width: 480
      code: |'c
        // MISTAKE 1: Integer comparison
        uint64_t m1 = *(uint64_t*)mac1;  // Alignment UB!
        uint64_t m2 = *(uint64_t*)mac2;
        if (m1 == m2) { ... }  // WRONG
        // MISTAKE 2: Bitwise operations
        uint64_t oui = (mac_int >> 40) & 0xFFFFFF;  // WRONG
        // Correct:
        uint32_t oui = (mac[0] << 16) | (mac[1] << 8) | mac[2];
        // MISTAKE 3: Struct assignment
        struct { uint64_t mac; } s;  // WRONG: padding issues
        s.mac = *(uint64_t*)src_mac;
        // MISTAKE 4: Host-to-network conversion
        // MACs don't need hton/ntoh — they're byte arrays!
        mac_addr_t mac = htonll(mac_int);  // WRONG: don't do this
      '|
    }
    wrong_code.style.fill: "#F8D7DA"
  }
  key_insight: {
    direction: down
    label: "Key Insight"
    insight_box: {
      shape: rectangle
      width: 400
      style.fill: "#E2E3E5"
      text: |md
        **MAC addresses are byte arrays, not integers.**
        The "wire order" and "memory order" are the same when you store MACs as `uint8_t[6]`.
        The confusion only arises when you try to:
        - Interpret the 6 bytes as a 64-bit integer
        - Perform arithmetic on MAC addresses
        - Use `htonl()`/`ntohl()` on MAC data
        **Rule**: Never convert MACs to integers. Use `memcmp()` for compare, `memcpy()` for copy, byte indexing for parsing.
      |
    }
  }
}
legend: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#F8F9FA"
    stroke: "#DEE2E6"
  }
  legend_text: |md
    **Color Legend:**
    🟢 Green = Correct approach / Works consistently  
    🟡 Yellow = Architecture-specific behavior  
    🔴 Red = Common mistakes / Undefined behavior
  |
}
wire_order -> little_endian: "Same bytes" {
  style: {
    stroke: "#28A745"
    stroke-width: 2
  }
}
wire_order -> big_endian: "Same bytes" {
  style: {
    stroke: "#28A745"
    stroke-width: 2
  }
}
little_endian.le_trap -> correct_approach: "Avoid by using byte arrays" {
  style: {
    stroke: "#DC3545"
    stroke-dash: 4
  }
}
big_endian.be_trap -> correct_approach: "Avoid by using byte arrays" {
  style: {
    stroke: "#DC3545"
    stroke-dash: 4
  }
}
wrong_patterns -> correct_approach: "Fix with" {
  style: {
    stroke: "#6C757D"
    stroke-dash: 3
  }
}