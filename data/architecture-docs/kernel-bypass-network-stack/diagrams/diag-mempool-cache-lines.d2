direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  title: {
    shape: rectangle
    label: |'md
      # Buffer Pool Cache Line Layout
      **64-byte cache line boundaries marked | Hot vs Cold field analysis**
    '|
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  mbuf_core: {
    direction: down
    label: "struct rte_mbuf (rte_mbuf_core.h)"
    
    cache_line_0: {
      shape: sql_table
      label: "Cache Line 0 — HOT (RX/TX Path)"
      f00: "0x00 | void*      | buf_addr"
      f08: "0x08 | void*      | buf_iova"
      f10: "0x10 | uint16_t   | data_off"
      f12: "0x12 | uint16_t   | refcnt (atomic)"
      f14: "0x14 | uint16_t   | nb_segs"
      f16: "0x16 | uint8_t    | port"
      f17: "0x17 | uint8_t    | ol_flags_0"
      f18: "0x18 | uint64_t   | ol_flags_rem"
      f20: "0x20 | uint32_t   | packet_type"
      f24: "0x24 | uint32_t   | pkt_len"
      f28: "0x28 | uint16_t   | data_len"
      f2a: "0x2A | uint16_t   | vlan_tci"
      f2c: "0x2C | uint32_t   | rss_hash"
      f30: "0x30 | uint16_t   | vlan_tci_outer"
      f32: "0x32 | uint16_t   | reserved"
      f34: "0x34 | uint8_t    | timestamp"
      f35: "0x35 | uint8_t    | padding"
      pad: "0x38 | uint64_t   | unused to 0x40"
      sz: "Total: 64 bytes"
    }
    
    cache_line_1: {
      shape: sql_table
      label: "Cache Line 1 — WARM (TX Path)"
      f40: "0x40 | uint64_t   | tx_offload"
      f48: "0x48 | uint16_t   | l2_len"
      f4a: "0x4A | uint16_t   | l3_len"
      f4c: "0x4C | uint16_t   | l4_len"
      f4e: "0x4E | uint16_t   | tso_segsz"
      f50: "0x50 | uint32_t   | sched"
      f54: "0x54 | uint16_t   | inner_l2_len"
      f56: "0x56 | uint16_t   | inner_l3_len"
      f58: "0x58 | uint64_t   | dynfield1"
      f60: "0x60 | void*      | pool (mempool*)"
      f68: "0x68 | void*      | next (mbuf*)"
      pad: "0x70 | uint64_t   | unused to 0x80"
      sz: "Total: 64 bytes"
    }
    
    cache_line_2: {
      shape: sql_table
      label: "Cache Line 2 — COLD (Mgmt)"
      f80: "0x80 | void*      | shinfo (shared_info*)"
      f88: "0x88 | uint64_t   | dynfield2"
      f90: "0x90 | uint64_t   | dynfield3"
      f98: "0x98 | uint64_t   | dynfield4"
      fa0: "0xA0 | uint64_t   | timestamp_cold"
      fa8: "0xA8 | uint32_t   | seqn"
      fac: "0xAC | uint32_t   | padding"
      fb0: "0xB0 | uint8_t    | priv0"
      pad: "0xB1 | variable   | private data area"
      sz: "Total: 64+ bytes"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  mempool_ring: {
    direction: down
    label: "struct rte_mempool (rte_mempool.h)"
    
    mp_cache_line_0: {
      shape: sql_table
      label: "Cache Line 0 — HOT (Config)"
      f00: "0x00 | const char* | name"
      f08: "0x08 | void*       | pool_config"
      f10: "0x10 | uint32_t    | flags"
      f14: "0x14 | int32_t     | socket_id"
      f18: "0x18 | uint32_t    | size"
      f1c: "0x1C | uint32_t    | cache_size"
      f20: "0x20 | uint32_t    | elt_size"
      f24: "0x24 | uint32_t    | header_size"
      f28: "0x28 | uint32_t    | trailer_size"
      f2c: "0x2C | uint32_t    | private_data_size"
      f30: "0x30 | int         | ops_index"
      f34: "0x34 | uint32_t    | populated_size"
      pad: "0x38 | uint64_t    | unused to 0x40"
      sz: "Total: 64 bytes"
    }
    
    mp_cache_line_1: {
      shape: sql_table
      label: "Cache Line 1 — LOCAL CACHE"
      f40: "0x40 | void**      | objs (LIFO stack)"
      f48: "0x48 | uint32_t    | len (cache count)"
      f4c: "0x4C | uint32_t    | flushthresh"
      f50: "0x50 | uint32_t    | backoff"
      pad: "0x54 | uint64_t    | padding to 0x80"
      sz: "Total: 64 bytes"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  analysis: {
    direction: down
    label: "Cache Line Analysis"
    
    hot_fields: {
      shape: class
      label: "Hot Path Fields (L1 Resident)"
      +buf_addr: "void* (DMA target)"
      +data_off: "uint16_t (offset)"
      +refcnt: "uint16_t (atomic)"
      +pkt_len: "uint32_t (total)"
      +data_len: "uint16_t (segment)"
      +port: "uint8_t (ingress)"
      +pool: "void* (back-ref)"
      +next: "void* (segment-link)"
    }
    
    cold_fields: {
      shape: class
      label: "Cold Path Fields (L3/RAM)"
      -ol_flags: "uint64_t (hints)"
      -tx_offload: "uint64_t (flags)"
      -shinfo: "void* (shared)"
      -timestamp: "uint64_t (latency)"
      -dynfield: "uint64_t[] (app)"
    }
  }
  
  false_sharing: {
    direction: down
    label: "False Sharing Risks"
    
    risk1: {
      shape: class
      label: "Per-Core Cache (mempool_cache)"
      +len: "uint32_t (count)"
      +flushthresh: "uint32_t (trigger)"
      +objs: "void** (ptr array)"
      #note: "Isolation: Each core cache"
      #impact: "Adjacent cores trigger MESI"
    }
    
    risk2: {
      shape: class
      label: "Atomic refcnt contention"
      +refcnt: "uint16_t (atomic ops)"
      +nb_segs: "uint16_t (meta)"
      +port: "uint8_t (port info)"
      #note: "Atomic update on CL0"
      #impact: "Invalidates line for peers"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  fix_recommendations: {
    direction: down
    label: "Optimization Fixes"
    
    fix1: {
      label: "Fix 1: Pad Per-Core Caches"
      code: |'c
        struct rte_mempool_cache {
            void **objs;
            uint32_t len;
            /* Explicit 64-byte alignment */
            char pad[64 - 12];
        } __rte_cache_aligned;
      '|
      width: 380
    }
    
    fix2: {
      label: "Fix 2: Separate Hot/Cold"
      code: |'c
        struct mbuf_opt {
            MARKER cacheline0;
            void *buf_addr;
            uint16_t data_off;
            /* Avoid atomics in shared hot CL */
            volatile uint16_t refcnt;
        } __rte_cache_aligned;
      '|
      width: 380
    }
  }
  
  latency_impact: {
    direction: down
    label: "Latency Impact Analysis"
    
    impact_table: {
      shape: sql_table
      label: "Memory Hierarchy Costs (3.2 GHz)"
      l1: "L1 Hit      | 4 ns    | 12 cyc"
      l2: "L2 Hit      | 12 ns   | 38 cyc"
      l3: "L3 Hit      | 40 ns   | 128 cyc"
      ram: "RAM Access  | 100 ns  | 320 cyc"
      numa: "NUMA Remote | 150 ns  | 480 cyc"
      contention: "False Share | +200 ns | MESI"
      total: "Cycle Budget| 5000 ns | 16k cyc"
    }
  }
}

row1 -> row2: "mbuf -> pool"
row2 -> row3: "analysis"
row3 -> row4: "solutions"

mbuf_core.cache_line_0.style.fill: "#E8F5E9"
mbuf_core.cache_line_1.style.fill: "#FFF3E0"
mbuf_core.cache_line_2.style.fill: "#ECEFF1"
mempool_ring.mp_cache_line_0.style.fill: "#E8F5E9"
mempool_ring.mp_cache_line_1.style.fill: "#FFF3E0"
analysis.hot_fields.style.fill: "#C8E6C9"
analysis.cold_fields.style.fill: "#FFCCBC"
false_sharing.risk1.style.fill: "#FFCDD2"
false_sharing.risk2.style.fill: "#FFCDD2"
fix_recommendations.fix1.style.fill: "#C8E6C9"
fix_recommendations.fix2.style.fill: "#C8E6C9"
latency_impact.impact_table.style.fill: "#E3F2FD"