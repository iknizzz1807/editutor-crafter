direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Packet Reception — Step-by-Step Trace
  **Wire to Application in ~2μs**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage1: {
    direction: down
    label: "Stage 1: Physical"
    style.fill: "#E8F4FD"
    wire: {
      label: "Wire Arrival"
      shape: rectangle
      width: 140
      code: |'c
        // Electrical signal on copper
        // or light pulse on fiber
        // Bit stream: 10110...
      '|
    }
    phy: {
      label: "PHY Layer"
      shape: rectangle
      width: 140
      code: |'c
        // Signal decoding
        // Clock recovery
        // 8b/10b or 64b/66b
      '|
    }
    wire_to_phy: "Signal arrives" {
      style.stroke: "#2980B9"
    }
    timing1: {
      label: "⏱ ~50ns"
      shape: text
      style.font-color: "#2980B9"
      style.bold: true
    }
  }
  stage2: {
    direction: down
    label: "Stage 2: MAC"
    style.fill: "#D5F5E3"
    mac: {
      label: "MAC Layer"
      shape: rectangle
      width: 140
      code: |'c
        // Ethernet frame check
        // FCS validation
        // Address filtering
      '|
    }
    dma_req: {
      label: "DMA Request"
      shape: rectangle
      width: 140
      code: |'c
        // Read descriptor from
        // RX ring tail pointer
        // Get buffer address
      '|
    }
    mac_to_dma: "Frame valid" {
      style.stroke: "#27AE60"
    }
    timing2: {
      label: "⏱ ~30ns"
      shape: text
      style.font-color: "#27AE60"
      style.bold: true
    }
  }
  stage3: {
    direction: down
    label: "Stage 3: DMA"
    style.fill: "#FCF3CF"
    dma_xfer: {
      label: "DMA Transfer"
      shape: rectangle
      width: 140
      code: |'c
        // PCIe bus transaction
        // Write packet data to
        // host RAM buffer
      '|
    }
    ring_update: {
      label: "RX Ring Update"
      shape: rectangle
      width: 140
      code: |'c
        // Advance tail pointer
        // Store packet length
        // Set status bits
      '|
    }
    dma_to_ring: "Write complete" {
      style.stroke: "#F39C12"
    }
    timing3: {
      label: "⏱ ~100ns"
      shape: text
      style.font-color: "#F39C12"
      style.bold: true
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage4: {
    direction: down
    label: "Stage 4: Poll Detection"
    style.fill: "#FADBD8"
    poll: {
      label: "CPU Poll"
      shape: rectangle
      width: 160
      code: |'c
        // Read RX ring head
        // Compare head != tail
        // New packets available!
      '|
    }
    desc_read: {
      label: "Descriptor Read"
      shape: rectangle
      width: 160
      code: |'c
        // Load descriptor struct
        // addr: 0x12345000
        // len:  1420 bytes
        // flags: DONE
      '|
    }
    poll_to_desc: "Packets found" {
      style.stroke: "#E74C3C"
    }
    timing4: {
      label: "⏱ ~5-100ns"
      shape: text
      style.font-color: "#E74C3C"
      style.bold: true
    }
  }
  stage5: {
    direction: down
    label: "Stage 5: Buffer Access"
    style.fill: "#E8DAEF"
    buf_ptr: {
      label: "Buffer Pointer"
      shape: rectangle
      width: 160
      code: |'c
        // Calculate: base + offset
        // pkt = umem + desc.addr
        // Point to raw bytes
      '|
    }
    cache_miss: {
      label: "Cache Fill"
      shape: rectangle
      width: 160
      code: |'c
        // NIC just wrote this memory
        // NOT in any CPU cache!
        // ~100ns to fetch from RAM
      '|
    }
    ptr_to_cache: "First access" {
      style.stroke: "#8E44AD"
    }
    timing5: {
      label: "⏱ ~100ns"
      shape: text
      style.font-color: "#8E44AD"
      style.bold: true
    }
  }
  stage6: {
    direction: down
    label: "Stage 6: Processing"
    style.fill: "#D6EAF8"
    parse: {
      label: "Header Parse"
      shape: rectangle
      width: 160
      code: |'c
        // Eth: dst[6] src[6] type[2]
        // IP:  hdr[20] ...
        // TCP: hdr[20] ...
      '|
    }
    deliver: {
      label: "App Delivery"
      shape: rectangle
      width: 160
      code: |'c
        // Callback or ring buffer
        // Hand off to application
        // Return buffer to pool
      '|
    }
    parse_to_deliver: "Headers done" {
      style.stroke: "#3498DB"
    }
    timing6: {
      label: "⏱ ~50-200ns"
      shape: text
      style.font-color: "#3498DB"
      style.bold: true
    }
  }
}
stage1.wire -> stage1.phy
stage1.phy -> stage2.mac
stage2.mac -> stage2.dma_req
stage2.dma_req -> stage3.dma_xfer
stage3.dma_xfer -> stage3.ring_update
stage3.ring_update -> stage4.poll
stage4.poll -> stage4.desc_read
stage4.desc_read -> stage5.buf_ptr
stage5.buf_ptr -> stage5.cache_miss
stage5.cache_miss -> stage6.parse
stage6.parse -> stage6.deliver
timeline: {
  label: "Cumulative Timing"
  shape: rectangle
  width: 500
  style.fill: "#2C3E50"
  style.font-color: white
  t0: "T+0ns    | Wire: Electrical signal arrives at NIC port"
  t1: "T+50ns   | PHY:  Signal decoded, clock recovered"
  t2: "T+80ns   | MAC:  Frame validated, DMA initiated"
  t3: "T+180ns  | DMA:  Packet written to host RAM"
  t4: "T+185ns  | Poll: CPU detects new descriptor (cache hit)"
  t5: "T+285ns  | Cache: First packet access (cache miss penalty)"
  t6: "T+400ns  | Parse: All headers extracted"
  t7: "T+500ns  | Done: Data delivered to application"
  total: "─────────| TOTAL: ~500ns (optimal) / ~1500ns (realistic)"
  style.fill: "#2C3E50"
}
timeline.near: bottom-center
legend: {
  near: bottom-right
  label: "Cache Timing"
  l1: {
    label: "L1 Hit: ~4ns"
    shape: text
    style.font-color: "#27AE60"
  }
  l2: {
    label: "L2 Hit: ~12ns"
    shape: text
    style.font-color: "#F39C12"
  }
  l3: {
    label: "L3 Hit: ~40ns"
    shape: text
    style.font-color: "#E67E22"
  }
  miss: {
    label: "RAM Access: ~100ns"
    shape: text
    style.font-color: "#E74C3C"
  }
}