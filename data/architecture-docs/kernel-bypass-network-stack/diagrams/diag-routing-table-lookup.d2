direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # IP Routing Table — Longest Prefix Match (LPM)
  Data Walk: Route lookup for destination 10.0.5.100
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_packet: {
    label: "Input Packet"
    dst_ip: "0x00 | uint32_t | dst_addr"
    dst_val: "0x0A | 0x00 | 0x05 | 0x64"
    total: "Dest: 10.0.5.100"
    shape: sql_table
  }
  input_packet.style.fill: "#E8F4FD"
}
row_lpm: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  lpm_engine: {
    direction: down
    label: "LPM Lookup (route_lpm.c)"
    step1: {
      label: "Step 1: Extract /24 prefix"
      width: 320
      code: |'c
        uint32_t dst = 0x0A000564;  // 10.0.5.100
        uint32_t prefix24 = dst & 0xFFFFFF00;
        // prefix24 = 0x0A000500 = 10.0.5.0
      '|
    }
    step2: {
      label: "Step 2: Hash lookup /24 bucket"
      width: 320
      code: |'c
        uint32_t hash = prefix24 ^ (prefix24 >> 16);
        struct route_entry *e = table->buckets[hash & MASK];
      '|
    }
    step3: {
      label: "Step 3: Verify & select best match"
      width: 320
      code: |'c
        // Compare all matching entries
        // Select longest prefix (largest netmask)
        return best_route;
      '|
    }
  }
  route_table: {
    direction: down
    label: "Route Entry Table (route_table.c)"
    route_entry: {
      shape: sql_table
      label: "struct route_entry"
      f0: "0x00 | uint32_t   | network"
      f1: "0x04 | uint32_t   | netmask"
      f2: "0x08 | uint32_t   | gateway"
      f3: "0x0C | uint32_t   | src_addr"
      f4: "0x10 | uint8_t    | ifindex"
      f5: "0x11 | uint8_t    | metric"
      sz: "Total: 20 bytes"
    }
  }
}
row_routes: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  routes: {
    direction: down
    label: "Active Routes (multi-homed host)"
    r_default: {
      shape: sql_table
      label: "Route 0: Default"
      network: "0.0.0.0/0"
      gateway: "10.0.1.1"
      src: "10.0.1.10"
      iface: "eth0"
      note: "Catch-all via ISP gateway"
    }
    r_lan: {
      shape: sql_table
      label: "Route 1: LAN"
      network: "10.0.1.0/24"
      gateway: "0.0.0.0"
      src: "10.0.1.10"
      iface: "eth0"
      note: "Direct delivery"
    }
    r_dmz: {
      shape: sql_table
      label: "Route 2: DMZ"
      network: "10.0.5.0/24"
      gateway: "0.0.0.0"
      src: "10.0.5.10"
      iface: "eth1"
      note: "Direct delivery"
    }
    r_vpn: {
      shape: sql_table
      label: "Route 3: VPN"
      network: "192.168.100.0/24"
      gateway: "10.0.5.254"
      src: "10.0.5.10"
      iface: "eth1"
      note: "Via VPN concentrator"
    }
  }
  r_default.style.fill: "#FFF3E0"
  r_lan.style.fill: "#E8F5E9"
  r_dmz.style.fill: "#C8E6C9"
  r_vpn.style.fill: "#E3F2FD"
}
row_match: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  match_process: {
    direction: down
    label: "LPM Match Process"
    match_header: {
      shape: sql_table
      label: "Comparing 10.0.5.100"
      r0: "Route | Prefix | Match? | Mask Bits"
    }
    match_results: {
      shape: sql_table
      label: "Match Results"
      m0: "Default | 0.0.0.0/0 | YES | 0"
      m1: "LAN | 10.0.1.0/24 | NO | --"
      m2: "DMZ | 10.0.5.0/24 | YES | 24 ★"
      m3: "VPN | 192.168.100.0/24 | NO | --"
      winner: "Best Match: Route 2 (DMZ)"
    }
  }
  match_results.style.fill: "#C8E6C9"
}
row_result: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  next_hop: {
    direction: down
    label: "Next-Hop Resolution"
    nh_decision: {
      shape: diamond
      label: "gateway == 0.0.0.0?"
    }
    nh_direct: {
      label: "Direct Delivery"
      width: 280
      code: |'c
        // On-link: ARP resolve dst IP
        next_hop_ip = dst_addr;  // 10.0.5.100
        next_hop_if = eth1;
        arp_resolve(next_hop_ip, &mac);
      '|
    }
    nh_indirect: {
      label: "Indirect Delivery"
      width: 280
      code: |'c
        // Off-link: ARP resolve gateway
        next_hop_ip = route->gateway;
        next_hop_if = route->ifindex;
        arp_resolve(next_hop_ip, &mac);
      '|
    }
    nh_decision -> nh_direct: "Yes (on-link)"
    nh_decision -> nh_indirect: "No (via gateway)"
  }
  output: {
    direction: down
    label: "Forwarding Result"
    out_result: {
      shape: sql_table
      label: "Forwarding Info"
      f0: "next_hop_ip | 10.0.5.100"
      f1: "src_addr | 10.0.5.10"
      f2: "out_iface | eth1"
      f3: "needs_arp | true"
      sz: "Direct delivery to destination"
    }
    out_result.style.fill: "#C8E6C9"
  }
}
row_interfaces: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  interfaces: {
    direction: down
    label: "Multi-Homed Host Interfaces"
    eth0: {
      shape: class
      label: "eth0 (LAN)"
      -ip: "10.0.1.10"
      -netmask: "255.255.255.0"
      -mac: "AA:BB:CC:00:00:01"
      -mtu: "1500"
      +tx(pkt): "int"
    }
    eth1: {
      shape: class
      label: "eth1 (DMZ)"
      -ip: "10.0.5.10"
      -netmask: "255.255.255.0"
      -mac: "AA:BB:CC:00:00:02"
      -mtu: "1500"
      +tx(pkt): "int"
    }
    eth0 -> eth1: "Separate\nnetworks"
  }
  eth0.style.fill: "#E8F5E9"
  eth1.style.fill: "#C8E6C9"
}
row_impl: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  impl: {
    direction: down
    label: "LPM Implementation (route_lpm.c)"
    lpm_func: {
      label: "Longest Prefix Match"
      width: 400
      code: |'c
        struct route_entry *route_lookup(struct routing_table *t, 
                                          uint32_t dst_addr) {
          struct route_entry *best = NULL;
          uint32_t best_mask = 0;
          for (int i = 0; i < t->count; i++) {
            struct route_entry *e = &t->entries[i];
            // Check if destination matches this route's network
            if ((dst_addr & e->netmask) == 
                (e->network & e->netmask)) {
              // Longer prefix = more specific match
              if (e->netmask > best_mask ||
                  (e->netmask == best_mask && 
                   e->metric < best->metric)) {
                best = e;
                best_mask = e->netmask;
              }
            }
          }
          return best;
        }
      '|
    }
    lpm_opt: {
      label: "Optimization: LPM Trie"
      width: 400
      code: |'c
        // For large tables, use a trie (O(k) where k=32)
        // Each level represents one bit of the address
        // Most specific match found by walking to deepest node
        struct lpm_node {
          struct lpm_node *child[2];  // 0 and 1 bits
          struct route_entry *route;  // NULL or valid
        };
      '|
    }
  }
}
row_input -> row_lpm: "dest IP"
row_lpm -> row_routes: "scan routes"
row_routes -> row_match: "compare"
row_match -> row_result: "best match"
row_result -> row_interfaces: "select iface"
legend: {
  near: bottom-right
  label: "Legend"
  direct: "Direct (on-link)" {
    shape: text
    style.font-color: "#2E7D32"
  }
  indirect: "Indirect (gateway)" {
    shape: text
    style.font-color: "#1565C0"
  }
  wildcard: "Default route" {
    shape: text
    style.font-color: "#E65100"
  }
}