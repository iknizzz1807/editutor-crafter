direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Kernel Bypass Network Stack
  ### Satellite Map — Complete System Architecture
| {near: top-center}
row_m5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m5: {
    direction: down
    label: "M5: Optimization & Production Hardening"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    numa: {
      label: "NUMA Topology"
      style.fill: "#C8E6C9"
      numa_alloc: "NUMA-aware allocation"
      numa_pin: "CPU/memory pinning"
      numa_node: "Per-node memory pools"
    }
    cache: {
      label: "Cache Optimization"
      style.fill: "#C8E6C9"
      cache_layout: "Data structure layout"
      cache_prefetch: "Software prefetch"
      cache_align: "Cache-line alignment"
    }
    lockfree: {
      label: "Lock-Free Data Paths"
      style.fill: "#C8E6C9"
      lockfree_ring: "SPSC ring buffers"
      lockfree_stats: "Per-core statistics"
      lockfree_rcu: "RCU-style reads"
    }
    monitor: {
      label: "Monitoring & Capture"
      style.fill: "#C8E6C9"
      monitor_hist: "Latency histograms"
      monitor_prom: "Prometheus metrics"
      monitor_pcap: "In-stack packet capture"
    }
  }
}
row_m4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m4: {
    direction: down
    label: "M4: TCP Implementation"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    tcp_state: {
      label: "TCP State Machine"
      style.fill: "#BBDEFB"
      tcp_states: "11-state machine"
      tcp_handshake: "3-way handshake"
      tcp_teardown: "Connection teardown"
    }
    tcp_reliability: {
      label: "Reliability"
      style.fill: "#BBDEFB"
      tcp_seq: "Sequence numbers"
      tcp_ack: "ACK mechanism"
      tcp_retx: "Retransmission timers"
    }
    tcp_flow: {
      label: "Flow & Congestion Control"
      style.fill: "#BBDEFB"
      tcp_window: "Sliding windows"
      tcp_reno: "TCP Reno (AIMD)"
      tcp_cubic: "CUBIC algorithm"
    }
    tcp_conn: {
      label: "Connection Management"
      style.fill: "#BBDEFB"
      tcp_table: "10K connection table"
      tcp_timer: "Timer wheel"
      tcp_syn: "SYN cookies"
    }
  }
}
row_m3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m3: {
    direction: down
    label: "M3: IP & UDP Layer"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    ip_core: {
      label: "IPv4 Processing"
      style.fill: "#FFE0B2"
      ip_hdr: "Header parsing (20-60 bytes)"
      ip_cksum: "Checksum verification"
      ip_route: "Routing table lookup"
    }
    ip_frag: {
      label: "Fragmentation"
      style.fill: "#FFE0B2"
      frag_reasm: "Reassembly buffer"
      frag_pmtu: "Path MTU Discovery"
      frag_df: "Don't Fragment flag"
    }
    udp_layer: {
      label: "UDP Transport"
      style.fill: "#FFE0B2"
      udp_hdr: "8-byte header"
      udp_socket: "Socket abstraction"
      udp_cksum: "Pseudo-header checksum"
    }
    icmp_layer: {
      label: "ICMP Control"
      style.fill: "#FFE0B2"
      icmp_echo: "Echo request/reply"
      icmp_unreach: "Destination unreachable"
      icmp_pmtu: "Fragmentation needed"
    }
  }
}
row_m2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m2: {
    direction: down
    label: "M2: Ethernet & ARP Layer"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    eth_layer: {
      label: "Ethernet Frame"
      style.fill: "#E1BEE7"
      eth_hdr: "14-byte header"
      eth_mac: "MAC address handling"
      eth_parse: "Frame parsing"
    }
    arp_layer: {
      label: "ARP Protocol"
      style.fill: "#E1BEE7"
      arp_req: "ARP request"
      arp_reply: "ARP reply"
      arp_grat: "Gratuitous ARP"
    }
    arp_cache: {
      label: "ARP Cache"
      style.fill: "#E1BEE7"
      cache_table: "Hash table (256 entries)"
      cache_state: "Entry state machine"
      cache_pending: "Pending packet queue"
    }
    vlan: {
      label: "802.1Q VLAN"
      style.fill: "#E1BEE7"
      vlan_tag: "VLAN tag parsing"
      vlan_vid: "VLAN ID extraction"
    }
  }
}
row_m1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m1: {
    direction: down
    label: "M1: Kernel Bypass Setup"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    dpdk: {
      label: "DPDK Path"
      style.fill: "#FFCDD2"
      dpdk_eal: "EAL initialization"
      dpdk_pmd: "PMD drivers"
      dpdk_mbuf: "rte_mbuf structure"
      dpdk_ring: "RX/TX ring buffers"
    }
    afxdp: {
      label: "AF_XDP Path"
      style.fill: "#FFCDD2"
      xdp_socket: "XDP socket creation"
      xdp_umem: "UMEM registration"
      xdp_rings: "Fill/RX/TX/Comp rings"
      xdp_zc: "Zero-copy mode"
    }
    perf: {
      label: "Performance"
      style.fill: "#FFCDD2"
      perf_lat: "Sub-2μs latency target"
      perf_batch: "Batch processing"
      perf_stats: "Statistics collection"
    }
  }
}
row_hw: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hardware: {
    direction: down
    label: "Hardware Layer"
    style.fill: "#ECEFF1"
    style.stroke: "#455A64"
    nic: {
      label: "NIC Hardware"
      shape: rectangle
      style.fill: "#CFD8DC"
      nic_dma: "DMA Engine"
      nic_ring: "HW Ring Buffers"
      nic_ts: "HW Timestamping"
    }
    cpu: {
      label: "CPU & Memory"
      shape: rectangle
      style.fill: "#CFD8DC"
      cpu_l1l2l3: "L1/L2/L3 Cache Hierarchy"
      cpu_numa: "NUMA Topology"
      cpu_tsc: "TSC Timestamp Counter"
    }
    pcie: {
      label: "PCIe Bus"
      shape: rectangle
      style.fill: "#CFD8DC"
      pcie_mmio: "MMIO Registers"
      pcie_dma: "DMA Transfers"
    }
  }
}
row_api: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  api: {
    direction: right
    label: "Application API"
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    api_tcp: {
      label: "TCP API"
      style.fill: "#FFECB3"
      api_connect: "connect()"
      api_send: "send()"
      api_recv: "recv()"
      api_close: "close()"
    }
    api_udp: {
      label: "UDP API"
      style.fill: "#FFECB3"
      api_udpsend: "udp_send()"
      api_udprecv: "udp_recv()"
      api_bind: "bind()"
    }
    api_stats: {
      label: "Stats API"
      style.fill: "#FFECB3"
      api_metrics: "get_metrics()"
      api_latency: "get_latency_hist()"
    }
  }
}
arrows_m5_m4: {
  style.stroke: "#1565C0"
  style.stroke-width: 2
  m5.lockfree -> m4.tcp_conn: "Lock-free\nconn table"
  m5.cache -> m4.tcp_state: "Cache-aligned\nstate"
  m5.numa -> m4: "NUMA-local\nbuffers"
}
arrows_m4_m3: {
  style.stroke: "#E65100"
  style.stroke-width: 2
  m4.tcp_reliability -> m3.udp_layer: "ACK over\nIP/UDP"
  m4.tcp_flow -> m3.ip_core: "Segments in\nIP packets"
}
arrows_m3_m2: {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  m3.ip_core -> m2.eth_layer: "IP in\nEthernet"
  m3.ip_route -> m2.arp_cache: "Next-hop\nMAC lookup"
  m3.udp_layer -> m2.arp_layer: "ARP for\ndest MAC"
}
arrows_m2_m1: {
  style.stroke: "#C62828"
  style.stroke-width: 2
  m2.eth_layer -> m1.dpdk: "Frame TX/RX"
  m2.eth_layer -> m1.afxdp: "Frame TX/RX"
  m2.arp_cache -> m1.perf: "Cache hit\nlatency"
}
arrows_m1_hw: {
  style.stroke: "#455A64"
  style.stroke-width: 2
  m1.dpdk -> hardware.nic: "PMD ↔ NIC"
  m1.afxdp -> hardware.nic: "XDP ↔ NIC"
  m1.perf -> hardware.cpu: "Cache\nawareness"
}
arrows_api_m4: {
  style.stroke: "#FF8F00"
  style.stroke-width: 2
  api.api_tcp -> m4: "TCP calls"
  api.api_udp -> m3.udp_layer: "UDP calls"
  api.api_stats -> m5.monitor: "Metrics"
}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  legend_title: "Data Flow" {style.bold: true}
  legend_rx: {
    label: "RX Path (up)"
    style.fill: "#E8F5E9"
  }
  legend_tx: {
    label: "TX Path (down)"
    style.fill: "#E3F2FD"
  }
  legend_opt: {
    label: "Optimization spans all"
    style.fill: "#FFF3E0"
  }
  legend_rx -> legend_tx -> legend_opt: {style.stroke: transparent}
}
perf_budget: {
  near: bottom-left
  label: |md
    **Latency Budget (5μs target)**
    - NIC DMA: ~100ns
    - Ring poll: ~5ns
    - Eth/IP/TCP parse: ~60ns
    - Conn lookup: ~30ns
    - Processing: ~100ns
    - Cache misses (2×): ~200ns
    - **Total: ~500ns (stack)**
    - **Remaining: ~4.5μs (app + network)**
  |
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
}
cross_cuts: {
  near: center-right
  label: "Cross-Cutting Concerns"
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  cc1: "NUMA awareness (all layers)"
  cc2: "Cache optimization (all layers)"
  cc3: "Lock-free design (all layers)"
  cc4: "Batching (M1, M3, M4)"
  cc5: "Statistics (all layers)"
}