direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_block: {
  label: "TCP Sliding Window Visual Mechanics (RFC 793 / 1323)"
  style.font-size: 24
  style.bold: true
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  sender_context: "SENDER (TX STATE)" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    
    send_buf_logical: {
      shape: sql_table
      label: "Logical Send Buffer Map"
      row1: "0x0000 | [0 - 999]    | ACKed / Discardable"
      row2: "0x03E8 | [1000 - 4999] | Sent - Unacknowledged (In-Flight)"
      row3: "0x1388 | [5000 - 15999]| Usable - Not Yet Sent"
      row4: "0x3E80 | [16000+]      | Future - Outside Window"
      total: "SND.WND Size: 11,000 bytes"
    }
    
    window_pointers: {
      direction: right
      style.stroke: transparent
      una: "SND.UNA" {
        label: "SND.UNA: 1000\n(Oldest UnACKed)"
        style.font-color: "#1565C0"
        style.stroke: "#1565C0"
      }
      nxt: "SND.NXT" {
        label: "SND.NXT: 5000\n(Next Sequence)"
        style.font-color: "#D84315"
        style.stroke: "#D84315"
      }
      wnd: "SND.WND" {
        label: "SND.WND: 11000\n(Advertised)"
        style.font-color: "#6A1B9A"
        style.stroke: "#6A1B9A"
      }
    }
    
    congestion_control: {
      label: "Congestion Control Logic"
      logic: |'md
        **Effective Window Calculation**
        `eff_wnd = min(SND.WND, cwnd)`
        - cwnd: 14,600 (10 MSS)
        - SND.WND: 11,000
        - Result: **11,000 bytes allowed**
      '|
    }
  }

  spacer: {
    width: 40
    style.stroke: transparent
    style.fill: transparent
  }

  receiver_context: "RECEIVER (RX STATE)" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    
    recv_buf_logical: {
      shape: sql_table
      label: "Logical Receive Buffer Map"
      row1: "0x0000 | [0 - 999]    | Delivered to App"
      row2: "0x03E8 | [1000 - 4999] | Buffered - Out of Order/Pending"
      row3: "0x1388 | [5000 - 65535]| Free Space (Available Window)"
      total: "Advertised RCV.WND: 60,536 bytes"
    }
    
    recv_pointers: {
      direction: right
      style.stroke: transparent
      nxt: "RCV.NXT" {
        label: "RCV.NXT: 5000\n(Expect Next)"
        style.font-color: "#1565C0"
        style.stroke: "#1565C0"
      }
      wnd: "RCV.WND" {
        label: "RCV.WND: 60536\n(Buffer Left)"
        style.font-color: "#2E7D32"
        style.stroke: "#2E7D32"
      }
    }
    
    flow_status: {
      label: "Receiver Window Math"
      logic: |'md
        **Window Advertisement**
        `Win = Max_Buf - (Next_Expected - Last_Read)`
        - Max_Buf: 65,536
        - Pending: 4,000
        - **Advertised: 61,536**
      '|
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  sequence_viz: {
    direction: down
    label: "Sequence Space Visualization"
    width: 1000
    
    chart: {
      label: "Byte Stream Timeline"
      content: |"md
        Byte Index: 0       1000      5000      16000     65535
                    |---------|---------|---------|---------|
                    [ ACKED ] [IN-FLIGHT] [ USABLE ] [ FUTURE ]
                    ^         ^         ^
                 SND.UNA   SND.NXT   SND.UNA+WND
      "|
    }
    
    legend: {
      direction: right
      style.stroke: transparent
      l1: "ACKed" { style.fill: "#81C784" }
      l2: "In Flight" { style.fill: "#FFB74D" }
      l3: "Usable" { style.fill: "#64B5F6" }
      l4: "Future" { style.fill: "#E0E0E0" }
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  protocol_flow: {
    direction: down
    label: "Packet Exchange (Window Scaling)"
    interaction: {
      shape: sequence_diagram
      S: Sender
      R: Receiver
      S -> R: "SYN [wscale=7]"
      R -> S: "SYN-ACK [wscale=7]"
      S -> R: "DATA [seq=1000, len=1000]"
      R -> S: "ACK [ack=2000, win=512]"
      note: "Win 512 << 7 = 65,536 bytes"
      S -> R: "DATA [seq=2000, len=4000]"
      R -> S: "ACK [ack=6000, win=0]"
      note: "Zero Window (Receiver Full)"
    }
  }

  bdp_analysis: {
    direction: down
    label: "Link Saturation Analysis (BDP)"
    calc: {
      label: "Bandwidth-Delay Product"
      style.fill: "#FFF3E0"
      formula: |'md
        **Formula:** `BDP = Bandwidth * RTT`
        
        **Example:**
        - Link: 10 Gbps
        - RTT: 20 ms
        - BDP = 25 MB
        
        **Conclusion:**
        Standard 16-bit window (64KB) only
        saturates **0.25%** of the link.
        *Window Scale is mandatory.*
      '|
    }
    scale_struct: {
      shape: class
      label: "TCP Options (tcp.h)"
      -kind: "uint8_t"
      -length: "uint8_t"
      -shift: "uint8_t"
      +get_scaled_win(raw): "uint32_t"
      +set_scale_factor(f): "void"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  kernel_logic: {
    direction: down
    label: "Kernel Implementation (Linux-style)"
    advance_code: {
      label: "tcp_input.c: Sliding logic"
      code: |'c
        void tcp_ack_update(struct tcp_sock *tp, uint32_t ack) {
            uint32_t newly_acked = ack - tp->snd_una;
            // Slide window left edge
            tp->snd_una = ack; 
            
            // Check available window for output
            uint32_t in_flight = tp->snd_nxt - tp->snd_una;
            if (in_flight < tp->snd_wnd) {
                tcp_data_snd_check(tp);
            }
        }
      '|
    }
  }

  memory_structs: {
    direction: down
    label: "Memory Management"
    sk_buff: {
      shape: sql_table
      label: "struct sk_buff_head (skbuff.h)"
      f0: "0x00 | struct sk_buff* | next"
      f1: "0x08 | struct sk_buff* | prev"
      f2: "0x10 | uint32_t        | qlen"
      f3: "0x14 | spinlock_t      | lock"
      sz: "Total: 24 bytes (cached)"
    }
    buffer_strat: {
      label: "Zero-Copy Buffering"
      style.fill: "#F3E5F5"
      details: |'md
        **Page-Based Buffering**
        - Data stored in `skb_shared_info`
        - ACKs trigger `skb_unlink` and `kfree`
        - Prevents copy-overhead on retransmit
      '|
    }
  }
}

# Root-level connections
row1.sender_context -> row1.receiver_context: "TCP Segment | mtu=1500" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.animated: true
}

row1.receiver_context -> row1.sender_context: "ACK + WIN | size=40" {
  style.stroke: "#1565C0"
  style.stroke-dash: 4
}

legend_node: {
  label: "Technical Legend"
  effective: "Effective Window = min(RCV.WND, cwnd)"
  effective.style.font-color: "#6A1B9A"
  mss: "MSS = Maximum Segment Size (default 1460)"
  mss.style.font-color: "#2E7D32"
}
legend_node.near: bottom-right