direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Connection Teardown — FIN/RST Paths
| {near: top-center}
row_normal: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  normal_close: {
    direction: down
    label: "Normal Close (4-Way Handshake)"
    client_normal: {
      shape: rectangle
      label: "Client\n(Active Close)"
      style.fill: "#E8F5E9"
    }
    server_normal: {
      shape: rectangle
      label: "Server\n(Passive Close)"
      style.fill: "#E3F2FD"
    }
    # State boxes
    client_est1: {
      label: "ESTABLISHED"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 120
    }
    server_est1: {
      label: "ESTABLISHED"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 120
    }
    # FIN 1
    fin1: {
      label: "FIN\nseq=U"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 80
    }
    client_fin1: {
      label: "FIN_WAIT_1"
      shape: rectangle
      style.fill: "#FFECB3"
      width: 120
    }
    # ACK 1
    ack1: {
      label: "ACK\nack=U+1"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 80
    }
    server_ack1: {
      label: "CLOSE_WAIT"
      shape: rectangle
      style.fill: "#B3E5FC"
      width: 120
    }
    # FIN 2
    fin2: {
      label: "FIN\nseq=V"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 80
    }
    client_fin2: {
      label: "FIN_WAIT_2"
      shape: rectangle
      style.fill: "#FFF9C4"
      width: 120
    }
    # ACK 2
    ack2: {
      label: "ACK\nack=V+1"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 80
    }
    client_tw: {
      label: "TIME_WAIT\n(2*MSL)"
      shape: rectangle
      style.fill: "#F8BBD9"
      width: 120
    }
    server_fin: {
      label: "LAST_ACK"
      shape: rectangle
      style.fill: "#FFCCBC"
      width: 120
    }
    client_closed: {
      label: "CLOSED"
      shape: rectangle
      style.fill: "#CFD8DC"
      width: 120
    }
    server_closed: {
      label: "CLOSED"
      shape: rectangle
      style.fill: "#CFD8DC"
      width: 120
    }
    # Connections
    client_est1 -> client_fin1: "close()"
    client_fin1 -> fin1: "send"
    fin1 -> server_ack1: ""
    server_ack1 -> ack1: ""
    ack1 -> client_fin2: ""
    server_ack1 -> server_fin: "close()"
    server_fin -> fin2: "send"
    fin2 -> client_tw: ""
    client_tw -> ack2: ""
    ack2 -> server_closed: ""
    client_tw -> client_closed: "timeout"
  }
  tw_explain: {
    direction: down
    label: "TIME_WAIT Purpose"
    width: 320
    why: {
      shape: rectangle
      style.fill: "#FFF3E0"
      width: 300
      label: |md
        **Why 2*MSL (60-120s)?**
        1. **Final ACK loss recovery**
           If final ACK is lost, server retransmits FIN.
           Client must remain to re-ACK.
        2. **Old segment purge**
           Prevents delayed segments from old connection
           being misinterpreted by new connection with
           same 4-tuple.
      |
    }
    msl: {
      shape: rectangle
      style.fill: "#E8F5E9"
      width: 300
      label: |md
        **MSL = Maximum Segment Lifetime**
        - RFC 793: MSL = 60 seconds
        - Linux default: 60 seconds (2*MSL = 120s)
        - HFT tuning: Reduce to 2-10s (risky!)
      |
    }
    problems: {
      shape: rectangle
      style.fill: "#FFEBEE"
      width: 300
      label: |md
        **Production Issues**
        - 10K conn/s × 60s = 600K TIME_WAIT entries
        - Port exhaustion on active closer side
        - Fixes: SO_REUSEADDR, client-side close
      |
    }
  }
}
row_abort: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  abort_close: {
    direction: down
    label: "Abortive Close (RST)"
    client_abort: {
      label: "Client"
      shape: rectangle
      style.fill: "#E8F5E9"
    }
    server_abort: {
      label: "Server"
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    client_est_ab: {
      label: "ESTABLISHED"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 120
    }
    server_est_ab: {
      label: "ESTABLISHED"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 120
    }
    rst_pkt: {
      label: "RST\nseq=X"
      shape: rectangle
      style.fill: "#F44336"
      style.font-color: white
      width: 80
    }
    client_rst: {
      label: "CLOSED\n(immediate)"
      shape: rectangle
      style.fill: "#CFD8DC"
      width: 120
    }
    server_rst: {
      label: "CLOSED\n(immediate)"
      shape: rectangle
      style.fill: "#CFD8DC"
      width: 120
    }
    client_est_ab -> rst_pkt: "SO_LINGER(0)\nor abort"
    rst_pkt -> server_rst: ""
    client_est_ab -> client_rst: ""
  }
  rst_explain: {
    direction: down
    label: "RST Scenarios"
    width: 320
    rst_when: {
      shape: rectangle
      style.fill: "#FFEBEE"
      width: 300
      label: |md
        **When RST is Sent**
        1. **SO_LINGER with 0 timeout**
           - Application sets linger=0
           - close() sends RST immediately
        2. **Application abort**
           - Unrecoverable error detected
           - Immediate termination required
        3. **Protocol violation**
           - Invalid segment received
           - No matching connection exists
      |
    }
    rst_effects: {
      shape: rectangle
      style.fill: "#FFF3E0"
      width: 300
      label: |md
        **RST Effects**
        - **No TIME_WAIT** — immediate cleanup
        - **Data loss** — unacked data discarded
        - **Application sees**: ECONNRESET
        - **No FIN handshake** — abrupt termination
        ⚠️ Use only when data integrity
        is not a concern!
      |
    }
  }
}
row_simul: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  simul_close: {
    direction: down
    label: "Simultaneous Close"
    client_sim: {
      label: "Client"
      shape: rectangle
      style.fill: "#E8F5E9"
    }
    server_sim: {
      label: "Server"
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    c_est_sim: { label: "ESTABLISHED"; shape: rectangle; style.fill: "#C8E6C9"; width: 100 }
    s_est_sim: { label: "ESTABLISHED"; shape: rectangle; style.fill: "#BBDEFB"; width: 100 }
    c_fin1_sim: { label: "FIN_WAIT_1"; shape: rectangle; style.fill: "#FFECB3"; width: 100 }
    s_fin1_sim: { label: "FIN_WAIT_1"; shape: rectangle; style.fill: "#FFECB3"; width: 100 }
    fin_c_s: { label: "FIN"; shape: rectangle; style.fill: "#FFCDD2"; width: 60 }
    fin_s_c: { label: "FIN"; shape: rectangle; style.fill: "#FFCDD2"; width: 60 }
    c_closing: { label: "CLOSING"; shape: rectangle; style.fill: "#D1C4E9"; width: 100 }
    s_closing: { label: "CLOSING"; shape: rectangle; style.fill: "#D1C4E9"; width: 100 }
    ack_sim1: { label: "ACK"; shape: rectangle; style.fill: "#C8E6C9"; width: 60 }
    ack_sim2: { label: "ACK"; shape: rectangle; style.fill: "#C8E6C9"; width: 60 }
    c_tw_sim: { label: "TIME_WAIT"; shape: rectangle; style.fill: "#F8BBD9"; width: 100 }
    s_tw_sim: { label: "TIME_WAIT"; shape: rectangle; style.fill: "#F8BBD9"; width: 100 }
    c_cl_sim: { label: "CLOSED"; shape: rectangle; style.fill: "#CFD8DC"; width: 100 }
    s_cl_sim: { label: "CLOSED"; shape: rectangle; style.fill: "#CFD8DC"; width: 100 }
    c_est_sim -> c_fin1_sim: "close()"
    s_est_sim -> s_fin1_sim: "close()"
    c_fin1_sim -> fin_c_s: ""
    s_fin1_sim -> fin_s_c: ""
    fin_c_s -> s_fin1_sim: ""
    fin_s_c -> c_fin1_sim: ""
    c_fin1_sim -> c_closing: "recv FIN"
    s_fin1_sim -> s_closing: "recv FIN"
    c_closing -> ack_sim1: ""
    s_closing -> ack_sim2: ""
    ack_sim1 -> s_closing: ""
    ack_sim2 -> c_closing: ""
    c_closing -> c_tw_sim: "recv ACK"
    s_closing -> s_tw_sim: "recv ACK"
    c_tw_sim -> c_cl_sim: ""
    s_tw_sim -> s_cl_sim: ""
  }
  simul_explain: {
    direction: down
    label: "Simultaneous Close"
    width: 320
    simul_when: {
      shape: rectangle
      style.fill: "#E8F5E9"
      width: 300
      label: |md
        **When It Happens**
        Both sides call close() at nearly the
        same time — FINs cross in flight.
        Common in:
        - Peer-to-peer protocols
        - Bidirectional streaming shutdown
        - Timeout-triggered closes
      |
    }
    simul_states: {
      shape: rectangle
      style.fill: "#F3E5F5"
      width: 300
      label: |md
        **State Transitions**
        ESTABLISHED → FIN_WAIT_1 (send FIN)
        FIN_WAIT_1 → CLOSING (recv FIN before ACK)
        CLOSING → TIME_WAIT (recv ACK)
        TIME_WAIT → CLOSED (2*MSL timeout)
        Both sides enter TIME_WAIT!
      |
    }
  }
}
legend_box: {
  label: "Legend"
  width: 400
  direction: right
  colors: {
    direction: down
    est: { label: "ESTABLISHED"; shape: rectangle; style.fill: "#C8E6C9"; width: 90 }
    fin1: { label: "FIN_WAIT_1"; shape: rectangle; style.fill: "#FFECB3"; width: 90 }
    fin2: { label: "FIN_WAIT_2"; shape: rectangle; style.fill: "#FFF9C4"; width: 90 }
    cw: { label: "CLOSE_WAIT"; shape: rectangle; style.fill: "#B3E5FC"; width: 90 }
  }
  colors2: {
    direction: down
    closing: { label: "CLOSING"; shape: rectangle; style.fill: "#D1C4E9"; width: 90 }
    la: { label: "LAST_ACK"; shape: rectangle; style.fill: "#FFCCBC"; width: 90 }
    tw: { label: "TIME_WAIT"; shape: rectangle; style.fill: "#F8BBD9"; width: 90 }
    closed: { label: "CLOSED"; shape: rectangle; style.fill: "#CFD8DC"; width: 90 }
  }
  packets: {
    direction: down
    fin_p: { label: "FIN packet"; shape: rectangle; style.fill: "#FFCDD2"; width: 90 }
    ack_p: { label: "ACK packet"; shape: rectangle; style.fill: "#C8E6C9"; width: 90 }
    rst_p: { label: "RST packet"; shape: rectangle; style.fill: "#F44336"; style.font-color: white; width: 90 }
  }
}
legend_box.near: bottom-center