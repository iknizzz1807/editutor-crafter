direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  closed: {
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
  }
  listen: {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  connecting: {
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
  }
  established: {
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
  }
  closing: {
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
  }
  timewait: {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  syn: {
    style.stroke: "#1976D2"
    style.stroke-width: 2
  }
  synack: {
    style.stroke: "#F57C00"
    style.stroke-width: 2
  }
  ack: {
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  fin: {
    style.stroke: "#C2185B"
    style.stroke-width: 2
  }
  rst: {
    style.stroke: "#D32F2F"
    style.stroke-dash: 4
    style.stroke-width: 2
  }
  timeout: {
    style.stroke: "#7B1FA2"
    style.stroke-dash: 3
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  CLOSED: {
    shape: circle
    class: closed
    label: "CLOSED"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  LISTEN: {
    shape: circle
    class: listen
    label: "LISTEN"
  }
  SYN_SENT: {
    shape: circle
    class: connecting
    label: "SYN_SENT"
  }
  SYN_RECEIVED: {
    shape: circle
    class: connecting
    label: "SYN_RCVD"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ESTABLISHED: {
    shape: circle
    class: established
    label: "ESTABLISHED"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  FIN_WAIT_1: {
    shape: circle
    class: closing
    label: "FIN_WAIT_1"
  }
  FIN_WAIT_2: {
    shape: circle
    class: closing
    label: "FIN_WAIT_2"
  }
  CLOSING: {
    shape: circle
    class: closing
    label: "CLOSING"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  TIME_WAIT: {
    shape: circle
    class: timewait
    label: "TIME_WAIT"
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  CLOSE_WAIT: {
    shape: circle
    class: closing
    label: "CLOSE_WAIT"
  }
  LAST_ACK: {
    shape: circle
    class: closing
    label: "LAST_ACK"
  }
}
# Connection Establishment (Client path)
CLOSED -> LISTEN: "open (passive)" {class: syn}
CLOSED -> SYN_SENT: "SYN (active)" {class: syn}
SYN_SENT -> ESTABLISHED: "SYN+ACK / ACK" {class: synack}
SYN_SENT -> CLOSED: "timeout / RST" {class: rst}
# Connection Establishment (Server path)
LISTEN -> SYN_RECEIVED: "SYN / SYN+ACK" {class: syn}
SYN_RECEIVED -> ESTABLISHED: "ACK" {class: ack}
SYN_RECEIVED -> LISTEN: "RST" {class: rst}
# Connection Termination (Active Close path)
ESTABLISHED -> FIN_WAIT_1: "FIN (active close)" {class: fin}
FIN_WAIT_1 -> FIN_WAIT_2: "ACK" {class: ack}
FIN_WAIT_2 -> TIME_WAIT: "FIN / ACK" {class: fin}
TIME_WAIT -> CLOSED: "2MSL timeout" {class: timeout}
# Simultaneous Close
FIN_WAIT_1 -> CLOSING: "FIN / ACK" {class: fin}
CLOSING -> TIME_WAIT: "ACK" {class: ack}
# Connection Termination (Passive Close path)
ESTABLISHED -> CLOSE_WAIT: "FIN / ACK" {class: fin}
CLOSE_WAIT -> LAST_ACK: "FIN (close)" {class: fin}
LAST_ACK -> CLOSED: "ACK" {class: ack}
# RST transitions (abort from any state)
ESTABLISHED -> CLOSED: "RST (abort)" {class: rst}
FIN_WAIT_1 -> CLOSED: "RST" {class: rst}
FIN_WAIT_2 -> CLOSED: "RST" {class: rst}
CLOSE_WAIT -> CLOSED: "RST" {class: rst}
# Self-loop for data transfer
ESTABLISHED -> ESTABLISHED: "DATA / ACK" {
  class: ack
  style.stroke-dash: 2
}
# Legend
legend: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend_title: "TCP State Transitions" {
    style.stroke: "#333"
    style.fill: "#FAFAFA"
    shape: rectangle
    width: 280
  }
  legend_items: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    l1: "SYN: Start connection" {class: syn}
    l2: "SYN+ACK: Handshake response" {class: synack}
    l3: "ACK: Acknowledgment" {class: ack}
    l4: "FIN: Graceful close" {class: fin}
    l5: "RST: Abort connection" {class: rst}
    l6: "timeout: Timer expiry" {class: timeout}
  }
}
legend.near: bottom-right