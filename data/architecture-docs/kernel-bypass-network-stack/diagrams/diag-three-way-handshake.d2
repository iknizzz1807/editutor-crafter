direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TCP Three-Way Handshake
  ### Sequence Number Initialization & Option Negotiation
| {near: top-center}
handshake: {
  shape: sequence_diagram
  client: Client (Active Opener)
  server: Server (Passive Opener)
  init: {
    client."state: CLOSED"
    server."state: LISTEN"
  }
  step1_syn: {
    client.t1 -> server.t1: "SYN"
    client.t1: |md
      seq = ISN_C (random)
      flags: SYN=1, ACK=0
      options:
        - MSS = 1460
        - WScale = 7
        - SACKOK
    |
    server.t1 -> server.t1: "ISN_C stored\nsnd_nxt = ISN_C + 1"
  }
  step2_synack: {
    server.t2 -> client.t2: "SYN+ACK"
    server.t2: |md
      seq = ISN_S (random)
      ack = ISN_C + 1
      flags: SYN=1, ACK=1
      options:
        - MSS = 1460
        - WScale = 7
        - SACKOK
    |
    client.t2 -> client.t2: "ISN_S stored\nsnd_nxt = ISN_S + 1"
    client."state: SYN_SENT → ESTABLISHED"
  }
  step3_ack: {
    client.t3 -> server.t3: "ACK"
    client.t3: |md
      seq = ISN_C + 1
      ack = ISN_S + 1
      flags: SYN=0, ACK=1
      (no options on pure ACK)
    |
    server."state: SYN_RECEIVED → ESTABLISHED"
  }
  established: {
    client."Connection ESTABLISHED"
    server."Connection ESTABLISHED"
    client."cwnd = 10 MSS (init)"
    server."cwnd = 10 MSS (init)"
  }
}
legend_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  seq_nums: {
    label: "Sequence Numbers"
    shape: sql_table
    f0: "ISN_C | Client Initial Seq"
    f1: "ISN_S | Server Initial Seq"
    f2: "SYN consumes 1 seq number"
    f3: "Data starts at ISN + 1"
  }
  options: {
    label: "TCP Options Negotiated"
    shape: sql_table
    o0: "MSS | 1460 bytes (max seg)"
    o1: "WScale | 7 (window x128)"
    o2: "SACKOK | Selective ACK"
  }
  states: {
    label: "State Transitions"
    shape: sql_table
    s0: "Client | CLOSED→SYN_SENT→ESTABLISHED"
    s1: "Server | LISTEN→SYN_RECEIVED→ESTABLISHED"
  }
}
packet_details: {
  direction: right
  syn_pkt: {
    label: "Packet 1: SYN"
    shape: class
    +src_port: "ephemeral (e.g. 54321)"
    +dst_port: "80"
    +seq_num: "ISN_C (e.g. 0x4A3B2C1D)"
    +ack_num: "0 (not valid)"
    +flags: "SYN=1"
    +window: "65535"
    +options: "[MSS=1460][WScale=7][SACKOK]"
  }
  synack_pkt: {
    label: "Packet 2: SYN+ACK"
    shape: class
    +src_port: "80"
    +dst_port: "54321"
    +seq_num: "ISN_S (e.g. 0x8E7F6A5B)"
    +ack_num: "ISN_C + 1"
    +flags: "SYN=1, ACK=1"
    +window: "65535"
    +options: "[MSS=1460][WScale=7][SACKOK]"
  }
  ack_pkt: {
    label: "Packet 3: ACK"
    shape: class
    +src_port: "54321"
    +dst_port: "80"
    +seq_num: "ISN_C + 1"
    +ack_num: "ISN_S + 1"
    +flags: "ACK=1"
    +window: "65535 >> 7 = 511"
    +options: "(none on pure ACK)"
  }
}
timing: {
  label: "Timing Characteristics"
  shape: rectangle
  width: 600
  note: |md
    **RTT Estimation Begins After Handshake**
    - Packet 1 → Packet 2: 1 RTT (SYN to SYN+ACK)
    - Packet 2 → Packet 3: Processing delay only
    - Total handshake: ~1-2 RTT depending on network
    **Security Note**: ISN (Initial Sequence Number) must be cryptographically
    random to prevent blind spoofing attacks (RFC 6528).
  |
}
handshake -> legend_row
legend_row -> packet_details
packet_details -> timing