direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- NIC HARDWARE LAYER ---
nic_hardware: "NIC Hardware (PCIe Device)" {
  style: {
    fill: "#f3f4f6"
    stroke: "#7c3aed"
    stroke-width: 4
    double-border: true
  }

  dma_engine: "DMA Control Engine" {
    shape: rectangle
    style: {
      fill: "#9333ea"
      font-color: white
      stroke-width: 2
      bold: true
    }
    fetch_desc: "Descriptor Fetch Logic"
    write_data: "Payload DMA Write-back"
    status_update: "Status/EOP Update"
  }

  mmio_registers: "MMIO Registers (BAR0)" {
    tooltip: "PCIe BAR0 Base Address - Map to Kernel/User Space"
    style.fill: "#faf5ff"
    style.stroke: "#7c3aed"
    
    rx_head: "RX_HEAD_PTR\n(Offset 0x100)" {
      shape: rectangle
      tooltip: "Updated by Hardware after successful DMA write"
      style.fill: "#e9d5ff"
      style.stroke: "#7c3aed"
    }
    rx_tail: "RX_TAIL_PTR\n(Offset 0x108)" {
      shape: rectangle
      tooltip: "Updated by Software to provide empty buffers to NIC"
      style.fill: "#e9d5ff"
      style.stroke: "#7c3aed"
    }
    tx_head: "TX_HEAD_PTR\n(Offset 0x200)" {
      shape: rectangle
      tooltip: "Updated by Hardware after packet wire-time transmission"
      style.fill: "#e9d5ff"
      style.stroke: "#7c3aed"
    }
    tx_tail: "TX_TAIL_PTR\n(Offset 0x208)" {
      shape: rectangle
      tooltip: "Software Doorbell: NIC polls this for new work"
      style.fill: "#e9d5ff"
      style.stroke: "#7c3aed"
    }
  }
}

# --- SYSTEM RAM LAYER ---
system_ram: "System RAM (DMA-able Memory)" {
  style: {
    stroke-width: 4
    stroke: "#2563eb"
    fill: "#f8fafc"
  }

  rx_ring: "RX Descriptor Ring (Circular)" {
    tooltip: "Size: 32KB (2048 Descriptors * 16 Bytes)"
    style: {
      stroke-dash: 5
      fill: "#eff6ff"
      stroke: "#2563eb"
    }
    
    desc_array: "Descriptor Array [0..2047]" {
      grid-columns: 1
      
      d0: "Slot 0: {addr=0x1A00, len=0, status=OWN_NIC}" {
        style.fill: "#bfdbfe"
        style.stroke: "#2563eb"
        style.bold: true
      }
      d1: "Slot 1: {addr=0x2B00, len=0, status=OWN_NIC}" {
        style.fill: "#bfdbfe"
        style.stroke: "#2563eb"
      }
      d2: "Slot 2: EMPTY (OWN_CPU / PROCESSED)" {
        style.fill: "#f3f4f6"
        style.stroke: "#9ca3af"
        style.opacity: 0.6
      }
      dn: "... [Remaining N Descriptors]" {
        style.stroke-dash: 3
        style.fill: transparent
      }
    }
  }

  tx_ring: "TX Descriptor Ring" {
    tooltip: "Size: 32KB"
    style: {
      stroke-dash: 5
      fill: "#fffbeb"
      stroke: "#d97706"
    }
    
    desc_array_tx: "Descriptor Array [0..2047]" {
      grid-columns: 1
      
      t0: "Slot 0: {addr=0x3C00, len=1500, cmd=EOP|RS}" {
        style.fill: "#fde68a"
        style.stroke: "#d97706"
        style.bold: true
      }
      t1: "Slot 1: {addr=0x0, len=0, status=FREE}" {
        style.fill: "#f3f4f6"
        style.stroke: "#9ca3af"
        style.opacity: 0.6
      }
      tn: "... [Remaining N Descriptors]" {
        style.stroke-dash: 3
        style.fill: transparent
      }
    }
  }

  buffer_pool: "UMEM / Packet Data Pages" {
    style.fill: "#ecfdf5"
    style.stroke: "#059669"
    
    frame_0: "Frame 0 (MTU 2048B)" {
      tooltip: "Physical Address: 0x1A00"
      style.fill: "#3b82f6"
      style.font-color: white
      style.bold: true
    }
    frame_1: "Frame 1 (MTU 2048B)" {
      tooltip: "Physical Address: 0x3C00"
      style.fill: "#3b82f6"
      style.font-color: white
    }
    frame_2: "Frame 2 (Available/Free)" {
      style.fill: "#10b981"
      style.font-color: white
      style.stroke-dash: 2
    }
  }
}

# --- DATA STRUCTURE SPECIFICATION ---
desc_spec: "Descriptor Memory Layout (16-Byte Block)" {
  shape: sql_table
  style.fill: "#bfdbfe"
  style.stroke: "#2563eb"
  
  0x00: "buffer_addr : uint64" {constraint: "8 bytes"}
  0x08: "packet_len : uint32" {constraint: "4 bytes"}
  0x0C: "status_opts : uint32" {constraint: "4 bytes"}
  
  header: "sizeof = 16 bytes (64B Cacheline holds 4 descs)"
}

# --- LOGIC & DATA FLOWS ---
# 1. RX Path: Fetching and Writing
nic_hardware.dma_engine -> system_ram.rx_ring.desc_array.d0: "1. Fetch RX Descriptor" {
  style: {
    stroke: orange
    stroke-width: 2
    bold: true
  }
}
nic_hardware.dma_engine -> system_ram.buffer_pool.frame_0: "2. DMA Write (Packet Payload)" {
  style: {
    stroke: blue
    animated: true
    stroke-width: 3
  }
}
nic_hardware.dma_engine -> system_ram.rx_ring.desc_array.d0: "3. Descriptor Writeback (Set Status)" {
  style: {
    stroke: purple
    stroke-width: 2
  }
}

# 2. Pointer References (Head/Tail Logic)
nic_hardware.mmio_registers.rx_head -> system_ram.rx_ring.desc_array.d1: "RX_HEAD: Next available for HW" {
  style.stroke-dash: 3
  style.stroke: "#7c3aed"
}
system_ram.tx_ring.desc_array_tx.t0 -> system_ram.buffer_pool.frame_1: "Points to TX data source" {
  style.stroke-dash: 3
  style.stroke: "#d97706"
}

# 3. TX Path
system_ram.tx_ring.desc_array_tx.t0 -> nic_hardware.dma_engine: "DMA Read (Triggered by Doorbell)" {
  style: {
    stroke: red
    stroke-width: 2
    bold: true
  }
}

# --- DOCUMENTATION ---
# FIXED: Changed 'near: system_ram' to constant value 'bottom-right' for ELK engine compatibility
note: |md
  ### Ring Buffer Management Logic
  - **Memory Ordering**: NIC reads `tx_tail` to detect work. Ensure memory barrier before doorbell write.
  - **RX Head**: Incremented by HW after successful DMA and status writeback.
  - **RX Tail**: Incremented by SW after packet processing and buffer reclaim.
  - **Ownership**: 'OWN_NIC' bit prevents CPU from touching active DMA targets.
  - **Cache Locality**: Descriptor arrays should be 64-byte aligned for performance.
| {
  near: bottom-right
  style: {
    stroke: "#7c3aed"
    fill: "#f5f3ff"
    font-size: 14
  }
}

# --- GLOBAL CONNECTIVITY & SYNC ---
nic_hardware.mmio_registers.rx_head -> nic_hardware.dma_engine: "HW Update Sync"
nic_hardware.mmio_registers.tx_tail -> nic_hardware.dma_engine: "Doorbell Interrupt/Trigger" {
  style.stroke: red
  style.stroke-width: 2
}

# Layout constraints for better readability
system_ram.rx_ring -> system_ram.tx_ring: "Parallel Ring Layout" {
  style.opacity: 0
}

# Legend for Field Colors
legend: "Memory Context Legend" {
  near: top-right
  header: "Color Codes"
  field1: "DMA Protected (Blue)" { style.fill: "#bfdbfe" }
  field2: "Free/CPU Owned (Gray)" { style.fill: "#f3f4f6" }
  field3: "Active TX Data (Yellow)" { style.fill: "#fde68a" }
  field4: "Empty Frame (Green)" { style.fill: "#10b981" }
}