direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

buffer_pool_architecture: {
  label: "Zero-Copy Buffer Pool Architecture (kbns-m1)"
  
  pool_struct: {
    shape: sql_table
    label: "struct kbns_buf_pool (sizeof=Variable NUMA-local)"
    base_addr: "void* | 8B" 
    phys_addr: "uint64_t | 8B"
    frame_size: "uint32_t | 4B"
    num_frames: "uint32_t | 4B"
    free_stack_ptr: "kbns_addr_t* | 8B"
    per_core_cache_ptr: "void* | 8B"
    
    style: {
      fill: white
      stroke: black
      stroke-width: 2
    }
  }

  memory_layout: {
    label: "Physical Memory Layout (Hugepages)"
    
    frame_0: {
      label: "Frame N (2048 Bytes)"
      
      header: {
        label: "kbns_buf_hdr (Cache Line 0)"
        shape: sql_table
        0x00: "ref_count | 4B"
        0x04: "pool_id | 4B"
        0x08: "data_off | 4B"
        0x0C: "data_len | 4B"
        0x10: "frame_idx | 4B"
        0x14: "flags | 4B"
        0x18: "timestamp | 8B"
        0x20: "reserved | 32B"
        
        style: {
          fill: "#E1BEE7" # Purple (Header)
          stroke: "#6a1b9a"
          stroke-dash: 5 # Cache line indication
        }
      }
      
      headroom: {
        label: "Reserved Headroom (Cache Line 1)"
        height: 60
        style: {
          fill: "#F5F5F5" # Gray (Padding)
          stroke: "#757575"
          stroke-dash: 5
        }
      }
      
      payload: {
        label: "Packet Data Area (Cache Lines 2-31)"
        height: 120
        style: {
          fill: "#BBDEFB" # Blue (Data)
          stroke: "#1565c0"
        }
      }
    }
  }

  free_list_logic: {
    label: "Lock-Free Resource Management"
    
    global_stack: {
      shape: cylinder
      label: "Global Free Stack (Atomic Top)"
      entry_0: "Addr_0"
      entry_1: "Addr_1"
      entry_n: "Addr_N"
      
      style: {
        fill: "#C8E6C9" # Green (Free)
        stroke: "#2e7d32"
      }
    }
    
    per_core_cache: {
      label: "Per-Core L1 Cache (False Sharing Protected)"
      
      core_0: {
        shape: sql_table
        label: "Cache Core 0"
        indices: "kbns_addr_t[256] | 2048B"
        count: "uint32_t | 4B"
        padding: "char[60] | 60B" # Pad to next cache line
        
        style: {
          fill: white
          stroke: "#ef6c00" # Orange (Pointer logic)
          stroke-width: 2
        }
      }
      
      core_1: {
        shape: sql_table
        label: "Cache Core 1"
        indices: "kbns_addr_t[256] | 2048B"
        count: "uint32_t | 4B"
        padding: "char[60] | 60B"
        
        style: {
          fill: white
          stroke: "#ef6c00"
          stroke-width: 2
        }
      }
    }
  }

  # Connections and Pointers
  pool_struct.free_stack_ptr -> free_list_logic.global_stack: "points to" {
    style: {
      stroke: "#ef6c00"
      stroke-width: 2
    }
  }
  
  free_list_logic.global_stack -> memory_layout.frame_0.header: "stores offset to" {
    style: {
      stroke: "#2e7d32"
      stroke-dash: 3
    }
  }
  
  per_core_cache.core_0 -> free_list_logic.global_stack: "batch refill" {
    style: {
      animated: true
      stroke: "#2e7d32"
    }
  }
  
  memory_layout.frame_0.header.0x08 -> memory_layout.frame_0.payload: "data_off defines start" {
    style: {
      stroke: "#6a1b9a"
    }
  }
}

legend: {
  near: bottom-right
  Header: {style.fill: "#E1BEE7"}
  Data: {style.fill: "#BBDEFB"}
  Free: {style.fill: "#C8E6C9"}
  Padding: {style.fill: "#F5F5F5"}
  Pointers: {style.fill: "#ef6c00"}
}

annotation: |md
  ### Implementation Notes
  - **Zero-Copy**: Hardware DMA writes to `Packet Data Area`. Software adjusts `data_off` to prepend headers in `Headroom`.
  - **Cache Locality**: `kbns_buf_hdr` is exactly 64 bytes, ensuring metadata fits in one L1 cache line access.
  - **False Sharing**: Per-core caches are padded with 60 bytes to ensure `count` variables for different cores never sit on the same cache line.
  - **Alignment**: `memory_layout` base is 2MB or 1GB page aligned.
| {
  near: top-right
}