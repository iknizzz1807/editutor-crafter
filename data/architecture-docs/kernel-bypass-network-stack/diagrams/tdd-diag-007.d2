direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# --- STYLING CLASSES (Intel Manual Spec Colors) ---
classes: {
  Header: {
    style: {
      fill: "#D1C4E9"
      stroke: "#512DA8"
      stroke-width: 2
    }
  }
  Data: {
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  Free: {
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
  Padding: {
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      stroke-dash: 3
    }
  }
  Pointers: {
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
      stroke-width: 2
    }
  }
}

# --- DIAGRAM STRUCTURE ---
buffer_pool_ring: {
  label: "kbns_ring Memory Layout (Cache-Aligned SPSC Ring)\nTotal Size: 32,832 Bytes"
  
  # --- CACHE LINE 0 ---
  cl0: {
    label: "Cache Line 0: Producer Metadata"
    style.stroke-dash: 5
    
    p_idx: "0x00 | producer_idx | 4B" { class: Pointers }
    p_cached: "0x04 | producer_cached | 4B" { class: Pointers }
    p_pad: "0x08 | __padding[56] | 56B" { class: Padding }
    
    p_idx -> p_cached -> p_pad
  }

  # --- CACHE LINE 1 ---
  cl1: {
    label: "Cache Line 1: Consumer Metadata"
    style.stroke-dash: 5
    
    c_idx: "0x40 | consumer_idx | 4B" { class: Pointers }
    c_cached: "0x44 | consumer_cached | 4B" { class: Pointers }
    c_pad: "0x48 | __padding[56] | 56B" { class: Padding }
    
    c_idx -> c_cached -> c_pad
  }

  # --- CACHE LINE 2 ---
  cl2: {
    label: "Cache Line 2: Ring Descriptors [0..3]"
    style.stroke-dash: 5
    
    d0: "0x80 | kbns_desc[0] | 16B" {
      addr: "base_addr (8B)" { class: Pointers }
      len: "data_len (4B)" { class: Data }
      flags: "flags (4B)" { class: Header }
      addr -> len -> flags
    }
    d1: "0x90 | kbns_desc[1] | 16B" {
      addr: "base_addr (8B)" { class: Pointers }
      len: "data_len (4B)" { class: Data }
      flags: "flags (4B)" { class: Header }
      addr -> len -> flags
    }
    d2: "0xA0 | kbns_desc[2] | 16B" {
      addr: "base_addr (8B)" { class: Pointers }
      len: "data_len (4B)" { class: Data }
      flags: "flags (4B)" { class: Header }
      addr -> len -> flags
    }
    d3: "0xB0 | kbns_desc[3] | 16B" {
      addr: "base_addr (8B)" { class: Pointers }
      len: "data_len (4B)" { class: Data }
      flags: "flags (4B)" { class: Header }
      addr -> len -> flags
    }
    
    d0 -> d1 -> d2 -> d3
  }

  # --- CACHE LINE 3 ---
  cl3: "Cache Line 3..N: kbns_desc[4...2047]" {
    style.fill-pattern: lines
    style.stroke-dash: 5
    style.fill: "#EEEEEE"
  }

  cl0 -> cl1: "Line Boundary (64B Alignment)" {
    style.stroke: red
    style.stroke-width: 2
    style.stroke-dash: 4
  }
  cl1 -> cl2: "Array Start Offset (0x80)"
  cl2 -> cl3: "Sequential Mapping"
}

# FIXED: Changed near: buffer_pool_ring to a constant value
annotation: |md
  # Performance & Architecture Specifications
  - **Managed Buffer Pool**: 8,192 frames @ 2048B each (16MB Total)
  - **Descriptor Count**: 2,048 (Power of 2 for bitwise wrapping)
  - **Bus Width Alignment**: 64-byte aligned (Cache Line Size)
  
  ## Cache Coherency Strategy
  To eliminate **L1/L2 False Sharing (Cache Line Bouncing)**, the `producer_idx` 
  and `consumer_idx` are isolated on distinct cache lines. 
  - Producer writes to CL0, reads CL1 (cached).
  - Consumer writes to CL1, reads CL0 (cached).
  
  ## Descriptor Format (16 Bytes)
  1. `base_addr` (64-bit): Physical pointer to packet buffer.
  2. `data_len` (32-bit): Actual payload size in bytes.
  3. `flags` (32-bit): Bitmask for checksum, VLAN, and offload metadata.
| {
  near: top-right
}

# Detailed Legend for Field Interpretation
legend: {
  near: bottom-right
  h: Header/Flags (32b) { class: Header }
  d: Data/Payload Size (32b) { class: Data }
  p: Padding (Explicit Alignment) { class: Padding }
  ptr: Memory Pointers (64b) { class: Pointers }
}