direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# HFT Latency Distribution Analysis - High Precision Networking Stack
latency_distribution: {
  label: "HFT Latency Distribution Analysis (Nanosecond Precision)"
  tooltip: "High-Frequency Trading System Jitter and Tail Analysis"
  
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
    stroke: "#212529"
  }

  # Use a grid to organize the main sections instead of 'near' constants
  grid-columns: 2
  grid-gap: 40

  histogram_canvas: {
    label: "Latency Frequency Spectrum"
    
    style: {
      stroke: "#333"
      fill: white
      stroke-dash: 0
      double-border: true
    }

    # Internal layout of the histogram
    grid-rows: 2
    grid-columns: 2
    vertical-gap: 0
    horizontal-gap: 0

    # Row 1: Y-axis and Data
    y_axis: "Packet Frequency (Log Scale)" {
      shape: rectangle
      width: 10
      height: 250
      style.fill: "#333"
    }

    distribution: {
      label: "Histogram Sample Data"
      grid-columns: 15
      grid-gap: 2
      style.stroke-width: 0
      style.fill: transparent

      # Histogram Bars: Using height to represent frequency
      b1: { height: 20; style.fill: "#4dabf7"; tooltip: "800ns - Cold start" }
      b2: { height: 60; style.fill: "#4dabf7"; tooltip: "950ns - Pipeline warm" }
      b3: { height: 120; style.fill: "#4dabf7"; tooltip: "1100ns - Fast path" }
      b4: { 
        label: "P50\n(1.2μs)"
        height: 200
        style: {
          fill: "#339af0"
          bold: true
          stroke: "#1864ab"
          stroke-width: 2
        }
      }
      b5: { height: 150; style.fill: "#339af0" }
      b6: { height: 80; style.fill: "#339af0" }
      b7: { height: 40; style.fill: "#ff922b" }
      b8: { height: 25; style.fill: "#ff922b" }
      b9: { height: 15; style.fill: "#ff922b" }
      b10: { 
        label: "P99\n(2.9μs)"
        height: 10
        style: {
          fill: "#ff922b"
          bold: true
          stroke: "#d9480f"
          stroke-width: 2
        }
      }
      b11: { height: 8; style.fill: "#fa5252" }
      b12: { height: 6; style.fill: "#fa5252" }
      b13: { height: 5; style.fill: "#fa5252" }
      b14: { 
        label: "P99.9\n(4.2μs)"
        height: 4
        style: {
          fill: "#fa5252"
          bold: true
          stroke: "#c92a2a"
          stroke-width: 2
        }
      }
      b15: { 
        label: "Tail"
        height: 3
        style: {
          fill: "#fa5252"
          stroke-dash: 2
        }
      }
    }

    # Row 2: Origin and X-axis
    origin_corner: {
      width: 10
      height: 10
      style.fill: "#333"
    }

    x_axis: "Latency (Nanoseconds)" {
      shape: rectangle
      width: 500
      height: 10
      style.fill: "#333"
    }
  }

  # Statistical Performance Metrics Table
  metrics: {
    label: "Statistical Performance Metrics"
    grid-rows: 3
    grid-gap: 10

    p50_info: "P50 (Median): 1,200ns | ~3,600 Cycles" {
      style: {
        fill: "#e7f5ff"
        stroke: "#339af0"
        border-radius: 4
      }
    }
    p99_info: "P99 (Outliers): 2,900ns | ~8,700 Cycles" {
      style: {
        fill: "#fff4e6"
        stroke: "#ff922b"
        border-radius: 4
      }
    }
    p999_info: "P99.9 (The Tail): 4,200ns | ~12,600 Cycles" {
      style: {
        fill: "#fff5f5"
        stroke: "#fa5252"
        border-radius: 4
      }
    }
  }

  causes: "Latency Root Causes (Deterministic vs Stochastic)" {
    shape: package
    grid-columns: 1
    
    cache_miss: "L3 Cache Miss (+100-300ns)" {
      style: {
        fill: "#ff922b"
        stroke-width: 1
      }
    }
    numa_hop: "NUMA Remote Access (+150-200ns)" {
      style: {
        fill: "#fd7e14"
        stroke-width: 1
      }
    }
    kernel_jitter: "OS/Interrupt Jitter (+5,000ns+)" {
      style: {
        fill: "#fa5252"
        stroke: "#c92a2a"
        bold: true
        double-border: true
      }
    }
  }

  analysis: |md
    ### Why Tail Latency Matters in HFT
    1. **Adverse Selection**: If your P99.9 is high, you are slow exactly when the market is most volatile.
    2. **Deterministic Execution**: Algorithms assume a fixed "look-to-book" time.
    3. **Micro-Bursting**: A single cache miss (100ns) at P99 cascades into a queueing disaster.
  | {
    shape: rectangle
    style: {
      fill: "#fff9db"
      stroke: "#fcc419"
      border-radius: 8
      font-size: 14
    }
  }
}

# Correlations between histogram points and metric definitions
(latency_distribution.histogram_canvas.distribution.b4 -> latency_distribution.metrics.p50_info): "Optimized Path" {
  style.stroke: "#339af0"
  style.stroke-dash: 3
}

(latency_distribution.histogram_canvas.distribution.b10 -> latency_distribution.metrics.p99_info): "Cache Stall" {
  style.stroke: "#ff922b"
  style.stroke-dash: 3
}

(latency_distribution.histogram_canvas.distribution.b14 -> latency_distribution.metrics.p999_info): "Context Switch" {
  style.stroke: "#fa5252"
  style.stroke-dash: 3
}

# Causality mapping from root causes to histogram tail
latency_distribution.causes.kernel_jitter -> latency_distribution.histogram_canvas.distribution.b15: "Systemic Jitter Entry" {
  source-arrowhead: diamond
  style: {
    stroke: red
    stroke-width: 3
    animated: true
  }
}