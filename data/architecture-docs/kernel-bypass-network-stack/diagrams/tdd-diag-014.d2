layout-engine: elk
theme-id: 4

direction: right

# Global classes for memory coloring and technical styling
classes: {
  header_cell: {
    style: {
      fill: "#f0f0f0"
      stroke: "#000000"
      bold: true
    }
  }
  mem_key: { style.fill: "#E1D5E7" }
  mem_data: { style.fill: "#DAE8FC" }
  mem_state: { style.fill: "#D5E8D4" }
  mem_time: { style.fill: "#FFF2CC" }
  mem_counter: { style.fill: "#F8CECC" }
  mem_padding: { style.fill: "#F5F5F5" }
}

arp_cache_system: "ARP Cache Architecture (kbns-m2)" {
  style: {
    stroke-width: 4
    fill: "#ffffff"
    stroke: "#2c3e50"
  }
  
  arp_cache_struct: {
    shape: class
    label: "struct arp_cache\nsizeof=16.5 KB (L1 Optimized)"
    
    entries: "entries[256]: struct arp_entry"
    seq: "volatile uint32_t (seqlock)"
    stats: "struct stats_counters"
    time_now: "uint64_t (*time_now)(void)"

    "lookup(uint32_t ip, struct arp_entry *out)": "struct arp_entry*"
    "update(uint32_t ip, uint8_t *mac, bool is_static)": "int"
    "gc()": "void"
    "remove(uint32_t ip)": "int"
  }

  memory_layout: "arp_entry Memory Layout\nsizeof=64 bytes (One Cache Line)" {
    grid-columns: 3
    grid-gap: 0
    
    # Header row
    h1: "Offset" { class: header_cell }
    h2: "Field Definition" { class: header_cell }
    h3: "Size" { class: header_cell }

    # Data rows (Offset | Field | Size)
    o0: "0x00"; f0: "ip: uint32_t (Lookup Key)"; s0: "4B"
    o1: "0x04"; f1: "mac: uint8_t[6] (HW Address)"; s1: "6B"
    o2: "0x0A"; f2: "state: uint8_t (FSM State)"; s2: "1B"
    o3: "0x0B"; f3: "retries: uint8_t"; s3: "1B"
    o4: "0x0C"; f4: "flags: uint16_t (Internal)"; s4: "2B"
    o5: "0x10"; f5: "expires_at: uint64_t (TTL)"; s5: "8B"
    o6: "0x18"; f6: "last_used: uint64_t (LRU)"; s6: "8B"
    o7: "0x20"; f7: "pending_count: uint32_t"; s7: "4B"
    o8: "0x24"; f8: "_padding: uint8_t[28] (Align)"; s8: "28B"

    # Applying classes individually or via semicolon chains to fix the compiler error
    o0.class: mem_key; f0.class: mem_key; s0.class: mem_key
    o1.class: mem_data; f1.class: mem_data; s1.class: mem_data
    o2.class: mem_state; f2.class: mem_state; s2.class: mem_state
    o3.class: mem_state; f3.class: mem_state; s3.class: mem_state
    o4.class: mem_state; f4.class: mem_state; s4.class: mem_state
    o5.class: mem_time; f5.class: mem_time; s5.class: mem_time
    o6.class: mem_time; f6.class: mem_time; s6.class: mem_time
    o7.class: mem_counter; f7.class: mem_counter; s7.class: mem_counter
    o8.class: mem_padding; f8.class: mem_padding; s8.class: mem_padding
  }

  hash_logic: "Open Addressing & Linear Probing" {
    shape: rectangle
    input_ip: "Input IP: 192.168.1.50" {shape: circle}
    hash_fn: "Hash Calculation\n((ip>>24)^(ip>>16)^(ip>>8)^ip) & 0xFF" {shape: diamond}
    
    table_viz: {
      grid-rows: 5
      grid-gap: 0
      
      slot_i: "Slot [i]: [IP_A]" {style.fill: "#F8CECC"}
      slot_i1: "Slot [i+1]: [COLLISION - IP_B]" {style.fill: "#F8CECC"}
      slot_i2: "Slot [i+2]: [EMPTY]" {style.fill: "#D5E8D4"}
      slot_i3: "..."
      slot_n: "Slot [255]"
    }

    input_ip -> hash_fn: "Step 1: Ingress"
    hash_fn -> table_viz.slot_i: "Step 2: Indexing"
    table_viz.slot_i -> table_viz.slot_i1: "Step 3: Mismatch (Probe)"
    table_viz.slot_i1 -> table_viz.slot_i2: "Step 4: Resolve"
  }

  seqlock_mech: "Seqlock Protocol (Lock-Free Reads)" {
    read_flow: |md
      **Reader Protocol**
      1. Read `seq` (Must be **EVEN**)
      2. `__smp_rmb()` (Read Barrier)
      3. `memcpy` entry to local buffer
      4. `__smp_rmb()` (Read Barrier)
      5. Read `seq` again
      6. **IF** `seq_start != seq_end` OR `odd(seq_start)` **RETRY**
    |
    write_flow: |md
      **Writer Protocol**
      1. `atomic_add(&seq, 1)` (seq is **ODD**)
      2. `__smp_wmb()` (Write Barrier)
      3. Update entry fields (volatile stores)
      4. `__smp_wmb()` (Write Barrier)
      5. `atomic_add(&seq, 1)` (seq is **EVEN**)
    |
    style.fill: "#f8f9fa"
    style.stroke: "#bdc3c7"
  }

  arp_cache_struct -> memory_layout: "Array of" {style.stroke-dash: 5}
  arp_cache_struct -> hash_logic: "Implements"
  memory_layout -> seqlock_mech: "Synchronization" {style.stroke: orange}
}

legend: "Color Legend" {
  near: bottom-right
  c1: "Identification/Key" {style.fill: "#E1D5E7"}
  c2: "Payload/MAC" {style.fill: "#DAE8FC"}
  c3: "Status/FSM" {style.fill: "#D5E8D4"}
  c4: "Time/Epochs" {style.fill: "#FFF2CC"}
  c5: "Alignment Padding" {style.fill: "#F5F5F5"}
}

annotation: |md
  ### Implementation Notes for Engineering:
  - **Cache Line Alignment**: `struct arp_entry` is padded to 64B. `__attribute__((aligned(64)))` is mandatory to prevent **False Sharing** between hardware threads updating adjacent indices.
  - **Memory Barriers**: Explicit `sfence`/`lfence` or compiler barriers (`atomic_thread_fence`) are required between sequence counter increments and data access to ensure store-visibility on x86/ARM architectures.
  - **Linear Probing**: Table size is 256. At >70% load factor, performance degrades; the `gc()` method is triggered by `lookup()` if expired TTLs are encountered during probing.
  - **Volatile Semantics**: The `seq` counter must be accessed via `volatile` or atomic pointers to bypass register caching by the compiler.
| {
  near: bottom-center
  style.font-size: 14
}