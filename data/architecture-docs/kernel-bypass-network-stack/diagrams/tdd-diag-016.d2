direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# ARP Resolution State Machine
# Implements RFC 4861 neighbor discovery logic adapted for kbns-m2 cache

start: {
  shape: circle
  label: ""
  width: 20
  height: 20
  style: {
    fill: black
  }
}

IDLE: {
  shape: rectangle
  label: "IDLE\n(No Entry)"
  tooltip: "IP address not present in cache."
}

INCOMPLETE: {
  shape: rectangle
  label: "INCOMPLETE\n(Resolving)"
  tooltip: "ARP Request sent, awaiting reply. Retries < 3."
}

REACHABLE: {
  shape: rectangle
  label: "REACHABLE\n(Valid)"
  tooltip: "Mapping confirmed. TTL active (300s)."
  style: {
    stroke: green
    stroke-width: 2
  }
}

STALE: {
  shape: rectangle
  label: "STALE\n(Tentative)"
  tooltip: "TTL expired. Mapping usable but unconfirmed."
  style: {
    stroke: orange
    stroke-dash: 3
  }
}

FAILED: {
  shape: rectangle
  label: "FAILED\n(Resolution Error)"
  tooltip: "Max retries exceeded. Entry pending GC."
  style: {
    fill: "#ffcccc"
    stroke: red
    stroke-width: 2
  }
}

# Transitions
start -> IDLE

IDLE -> INCOMPLETE: "Send IP Packet\n[Miss] / Queue Pkt + Send ARP Req" {
  style: {
    font-size: 12
  }
}

INCOMPLETE -> INCOMPLETE: "RTO Timeout\n[Retries < 3] / Send ARP Req" {
  style: {
    stroke-dash: 5
  }
}

INCOMPLETE -> REACHABLE: "Recv ARP Reply\n/ Update Cache + Flush Queue" {
  style: {
    stroke: green
    bold: true
  }
}

INCOMPLETE -> FAILED: "RTO Timeout\n[Retries == 3] / Drop Pending" {
  style: {
    stroke: red
  }
}

REACHABLE -> STALE: "TTL Expired\n[300s]" {
  style: {
    font-color: gray
  }
}

STALE -> REACHABLE: "Traffic Confirmed\n(TCP ACK) / Reset TTL" {
  style: {
    stroke: green
  }
}

STALE -> INCOMPLETE: "Data Sent\n/ Send ARP Probe" {
  label.near: outside-bottom-center
}

FAILED -> INCOMPLETE: "New Request\n/ Restart Resolution" {
  style: {
    stroke-dash: 3
  }
}

REACHABLE -> REACHABLE: "Recv ARP Reply\n/ Refresh TTL" {
  style: {
    opacity: 0.6
  }
}

# Documentation Overlay
legend: {
  near: bottom-center
  label: |md
    ### ARP State Invariants
    - **INCOMPLETE**: `pending_count > 0`
    - **REACHABLE**: `expires_at > now`
    - **STALE**: `expires_at <= now`, mapping used until verification
    - **FAILED**: Result of max retries (3)
  |
  style: {
    stroke: "#cccccc"
    fill: "#f9f9f9"
    font-size: 11
  }
}