layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    pad: 40
  }
}

# --- ROOT LEVEL ANNOTATIONS & LEGEND ---

Header_Title: {
  near: top-center
  shape: text
  label: "IPv4 Header Structure — Memory Layout (RFC 791)"
  style: {
    font-size: 24
    bold: true
  }
}

Offset_Label_Root: {
  near: top-left
  shape: text
  label: "Byte Offset"
  style: { 
    font-size: 14
    italic: true 
    font-color: "#757575"
  }
}

Legend: {
  near: bottom-right
  Header_Col: "Header Fields" { style.fill: "#6a1b9a"; style.font-color: white }
  Addr_Col: "Addresses (Orange)" { style.fill: "#ef6c00"; style.font-color: white }
  Data_Col: "Payload (Blue)" { style.fill: "#1565c0"; style.font-color: white }
  Padding_Col: "Reserved/Padding" { style.fill: "#757575"; style.font-color: white }
}

Annotations: |md
  ### IPv4 Memory Alignment & Technical Specs
  - **Memory Ordering**: Fields are transmitted in **Big-Endian** (Network Byte Order).
  - **IHL (Internet Header Length)**: 4-bit field. Value is number of 32-bit words. Min=5 (20B), Max=15 (60B).
  - **Total Length**: 16-bit field. Max packet size = 65,535 bytes.
  - **Fragmentation**: Fragment Offset is measured in 8-byte blocks (64 bits).
  - **Cache Performance**: 20-byte header fits entirely within a single **64B L1 Cache Line**.
| {
  near: center-right
}

# --- MAIN MEMORY CONTAINER ---

IPv4_Header_Layout: {
  style: {
    stroke-width: 2
    fill: "#f5f5f5"
  }

  # Header for Bit Positions
  Bit_Indices: {
    grid-columns: 5
    width: 900
    # FIX: Replaced empty space with "Offset" to satisfy the non-empty label constraint for shape: text
    label_spacer: "Offset" { shape: text; width: 60; style.font-size: 12; style.font-color: "#757575" }
    b0: "Bits 0-7" { shape: text; style.font-size: 12 }
    b1: "Bits 8-15" { shape: text; style.font-size: 12 }
    b2: "Bits 16-23" { shape: text; style.font-size: 12 }
    b3: "Bits 24-31" { shape: text; style.font-size: 12 }
  }

  # Row 0: 0x00 - 0x03
  Row_0: {
    grid-columns: 6
    width: 900
    
    Offset: "0x00" { shape: text; style.font-size: 11; style.font: mono }
    
    Ver_IHL: {
      grid-columns: 2
      Ver: "Version\n(4b)" { style.fill: "#6a1b9a"; style.font-color: white }
      IHL: "IHL\n(4b)" { style.fill: "#6a1b9a"; style.font-color: white }
    }
    
    TOS: "Type of Service / DiffServ\n(8b)" {
      tooltip: "DSCP (6b) + ECN (2b)"
      style.fill: "#6a1b9a"; style.font-color: white
    }
    
    Total_Len: "Total Length\n(16b)" {
      style.fill: "#6a1b9a"; style.font-color: white
      width: 400
    }
    
    # Use standard shape for spacers to avoid text label validation
    Padding_Empty: "." { style.opacity: 0; width: 1 }
    
    Size: "4 bytes" { shape: text; style.font-size: 10; style.font-color: "#757575" }
  }

  # Row 1: 0x04 - 0x07
  Row_1: {
    grid-columns: 5
    width: 900
    
    Offset: "0x04" { shape: text; style.font-size: 11; style.font: mono }
    
    ID: "Identification\n(16b)" {
      style.fill: "#6a1b9a"; style.font-color: white
      width: 400
    }
    
    Flags_Frag: {
      grid-columns: 4
      R: "R" { style.fill: "#757575"; style.font-color: white }
      DF: "DF" { style.fill: "#6a1b9a"; style.font-color: white }
      MF: "MF" { style.fill: "#6a1b9a"; style.font-color: white }
      Frag: "Fragment Offset (13b)" { style.fill: "#6a1b9a"; style.font-color: white; width: 250 }
    }
    
    Empty: "." { style.opacity: 0; width: 1 }
    
    Size: "4 bytes" { shape: text; style.font-size: 10; style.font-color: "#757575" }
  }

  # Row 2: 0x08 - 0x0B
  Row_2: {
    grid-columns: 5
    width: 900
    
    Offset: "0x08" { shape: text; style.font-size: 11; style.font: mono }
    
    TTL: "Time To Live\n(8b)" {
      style.fill: "#6a1b9a"; style.font-color: white
    }
    
    Proto: "Protocol\n(8b)" {
      tooltip: "TCP=6, UDP=17, ICMP=1"
      style.fill: "#6a1b9a"; style.font-color: white
    }
    
    Checksum: "Header Checksum\n(16b)" {
      style.fill: "#6a1b9a"; style.font-color: white
      width: 400
    }
    
    Size: "4 bytes" { shape: text; style.font-size: 10; style.font-color: "#757575" }
  }

  # Row 3: 0x0C - 0x0F (Source IP)
  Row_3: {
    grid-columns: 3
    width: 900
    
    Offset: "0x0C" { shape: text; style.font-size: 11; style.font: mono }
    
    Src_IP: "Source IPv4 Address (32 bits)" {
      style.fill: "#ef6c00"; style.font-color: white
      width: 800
    }
    
    Size: "4 bytes" { shape: text; style.font-size: 10; style.font-color: "#757575" }
  }

  # Row 4: 0x10 - 0x13 (Destination IP)
  Row_4: {
    grid-columns: 3
    width: 900
    
    Offset: "0x10" { shape: text; style.font-size: 11; style.font: mono }
    
    Dst_IP: "Destination IPv4 Address (32 bits)" {
      style.fill: "#ef6c00"; style.font-color: white
      width: 800
    }
    
    Size: "4 bytes" { shape: text; style.font-size: 10; style.font-color: "#757575" }
  }

  # Visual Page Boundary / End of Fixed Header
  Header_End_Divider: {
    label: "---------------- Minimum Header Boundary (20 Bytes) ----------------"
    style: { 
      stroke-dash: 5
      font-size: 12
      font-color: "#d32f2f"
      stroke: "#d32f2f"
    }
  }

  # Row 5: Payload / Options
  Payload_Section: {
    grid-columns: 3
    width: 900
    
    Offset: "0x14" { shape: text; style.font-size: 11; style.font: mono }
    
    Data_Area: "Options (Variable Length) and Payload Data" {
      style.fill: "#1565c0"
      style.font-color: white
      style.fill-pattern: grain
      width: 800
      height: 100
    }
    
    Growth: "↓ Growth" { shape: text; style.italic: true }
  }
}

# --- CACHE LINE VISUALIZATION ---
Cache_Line_Marker: {
  label: "64-Byte Cache Line Boundary"
  near: center-left
  style: {
    stroke-dash: 2
    font-size: 10
    font-color: "#757575"
  }
}

# Metadata Annotations
IPv4_Header_Layout.Row_0.Ver_IHL.Ver.tooltip: "Fixed value 4 for IPv4"
IPv4_Header_Layout.Row_0.Ver_IHL.IHL.tooltip: "Header length in 32-bit words"
IPv4_Header_Layout.Row_1.Flags_Frag.DF.tooltip: "Don't Fragment"
IPv4_Header_Layout.Row_1.Flags_Frag.MF.tooltip: "More Fragments"