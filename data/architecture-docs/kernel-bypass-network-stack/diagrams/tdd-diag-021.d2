direction: right
layout-engine: elk
theme-id: 4

# IP/UDP/TCP Checksum Algorithm - Implementation Grade Specification
# Matching TDD Modules: kbns-m3 (IP/UDP), kbns-m4 (TCP)

checksum_algorithm: {
  label: "Algorithm: One's Complement Checksum"

  step_1: {
    label: "1. Pseudo-Header Construction (TCP/UDP Only)"
    
    memory_layout: {
      shape: sql_table
      0x00: "Source IPv4 Address" {constraint: "4 Bytes (Big-Endian)"}
      0x04: "Destination IPv4 Address" {constraint: "4 Bytes (Big-Endian)"}
      0x08: "Zero Padding | Protocol (6 or 17)" {constraint: "2 Bytes"}
      0x0A: "UDP/TCP Length" {constraint: "2 Bytes"}
    }
    
    annotation: |md
      **Invariants:**
      - Pseudo-header ensures end-to-end delivery validation.
      - Total length = 12 bytes.
    |
  }

  step_2: {
    label: "2. Accumulator Initialization"
    
    state: {
      accumulator: "0x00000000" {
        style: {
          stroke: red
          stroke-width: 4
        }
      }
      ptr: "data_start"
      remaining: "len"
    }
    
    logic: "Initialize 32-bit sum to allow carry accumulation without overflow."
  }

  step_3: {
    label: "3. 16-bit Word Accumulation"
    
    sum_loop: {
      shape: sequence_diagram
      acc: 32-bit Accumulator
      mem: Memory (16-bit words)
      
      mem -> acc: sum += *ptr++
      mem -> acc: sum += *ptr++
      acc -> acc: **Accumulate Carries in upper 16 bits**
    }
    
    note: |md
      c
      while (len > 1) {
          sum += *words++;
          len -= 2;
      }
      
    |
  }

  step_4: {
    label: "4. Odd Byte Handling"
    
    comparison: {
      before: {
        last_byte: "0xAB"
        padding: "None"
      }
      after: {
        shifted_word: "**0xAB00**" {
          style: {
            stroke: red
            bold: true
          }
        }
        action: "sum += shifted_word"
      }
    }
    
    annotation: "If length is odd, the final byte is treated as the MSB of a 16-bit word padded with 0x00."
  }

  step_5: {
    label: "5. Primary Carry Fold"
    
    fold_logic: {
      input: "0x0001ABCD"
      operation: "(sum & 0xFFFF) + (sum >> 16)"
      result: "**0x0000ABCE**" {
        style: {
          stroke: red
          bold: true
        }
      }
    }
    
    desc: "Move carry bits from bits [31:16] back into bits [15:0]."
  }

  step_6: {
    label: "6. Secondary Carry Fold"
    
    fold_logic: {
      input: "0x0000FFFF"
      operation: "(sum & 0xFFFF) + (sum >> 16)"
      result: "**0x00000000** (with carry)"
      final: "Handle potential second carry from first fold."
    }
  }

  step_7: {
    label: "7. One's Complement (Bitwise NOT)"
    
    final_state: {
      sum: "0xABCD"
      not_sum: "**0x5432**" {
        style: {
          fill: "#e1d5e7"
          stroke: red
          bold: true
        }
      }
    }
    
    return_val: "return (uint16_t)~sum"
  }

  # Connections for algorithm flow
  step_1 -> step_2 -> step_3 -> step_4 -> step_5 -> step_6 -> step_7
}

# Styling
checksum_algorithm.step_1.memory_layout.style.fill: "#f8cecc"
checksum_algorithm.step_7.final_state.not_sum.style.fill: "#d5e8d4"

# Satellite Map Reference Links
legend: {
  near: bottom-right
  note: |md
    **Legend**
    - Red/Bold: Mutated State
    - Purple: Header Data
    - Blue: Accumulation State
  |
}