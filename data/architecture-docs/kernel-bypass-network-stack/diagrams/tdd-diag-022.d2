direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# LEGEND - Root level spec for memory interpretation
header_legend: {
  shape: package
  label: "Memory Map Legend"
  near: top-left
  h: ICMP Header (Purple) {
    style.fill: "#d1b3ff"
  }
  d: Data/Payload (Blue) {
    style.fill: "#b3d9ff"
  }
  r: Reserved/Padding (Gray) {
    style.fill: "#e0e0e0"
  }
}

icmp_layout: {
  label: "ICMP Message Type Layouts (IPv4)"

  generic_header: {
    label: "ICMP Generic Header (8 Bytes)"
    
    struct: {
      grid-columns: 3
      grid-gap: 0
      
      # Row 0
      h0_off: "0x00" { style.stroke-dash: 2 }
      h0_field: "Type" { style.fill: "#d1b3ff"; style.bold: true }
      h0_size: "1B" { style.stroke-dash: 2 }
      
      # Row 1
      h1_off: "0x01" { style.stroke-dash: 2 }
      h1_field: "Code" { style.fill: "#d1b3ff"; style.bold: true }
      h1_size: "1B" { style.stroke-dash: 2 }
      
      # Row 2
      h2_off: "0x02" { style.stroke-dash: 2 }
      h2_field: "Checksum" { style.fill: "#d1b3ff"; style.bold: true }
      h2_size: "2B" { style.stroke-dash: 2 }
      
      # Row 3
      h4_off: "0x04" { style.stroke-dash: 2 }
      h4_field: "Rest of Header (Type-Specific Content)" { style.fill: "#d1b3ff"; style.bold: true }
      h4_size: "4B" { style.stroke-dash: 2 }
    }
  }

  echo_layout: {
    label: "ICMP Echo Request/Reply (Type 8 / Type 0)"
    
    struct: {
      grid-columns: 3
      grid-gap: 0
      
      t0: "0x00"
      t1: "Type (8 or 0)" { style.fill: "#d1b3ff"; style.bold: true }
      t2: "1B"
      
      c0: "0x01"
      c1: "Code (0)" { style.fill: "#d1b3ff"; style.bold: true }
      c2: "1B"
      
      cs0: "0x02"
      cs1: "Checksum" { style.fill: "#d1b3ff" }
      cs2: "2B"
      
      id0: "0x04"
      id1: "Identifier" { style.fill: "#b3d9ff"; style.bold: true }
      id2: "2B"
      
      sq0: "0x06"
      sq1: "Sequence Number" { style.fill: "#b3d9ff"; style.bold: true }
      sq2: "2B"
      
      da0: "0x08"
      da1: "Optional Payload Data" { style.fill: "#b3d9ff" }
      da2: "Var"
    }
  }

  dest_unreach: {
    label: "ICMP Destination Unreachable (Type 3)"
    
    struct: {
      grid-columns: 3
      grid-gap: 0
      
      u0_off: "0x00"
      u0_field: "Type (3)"
      u0_field.style.fill: "#d1b3ff"
      u0_field.style.bold: true
      u0_size: "1B"
      
      u1_off: "0x01"
      u1_field: "Code (0-15)"
      u1_field.style.fill: "#d1b3ff"
      u1_field.style.bold: true
      u1_size: "1B"
      
      u2_off: "0x02"
      u2_field: "Checksum" { style.fill: "#d1b3ff" }
      u2_size: "2B"
      
      u4_off: "0x04"
      u4_field: "Unused (Must be 0)" { style.fill: "#e0e0e0" }
      u4_size: "2B"
      
      u6_off: "0x06"
      u6_field: "Next-Hop MTU (PMTUD)" { style.fill: "#b3d9ff"; style.bold: true }
      u6_size: "2B"
      
      u8_off: "0x08"
      u8_field: "Original IP Header Copy" { style.fill: "#b3d9ff" }
      u8_size: "20B"
      
      u28_off: "0x1C"
      u28_field: "Original Payload (First 64 Bits)" { style.fill: "#b3d9ff" }
      u28_size: "8B"
    }
  }

  time_exceeded: {
    label: "ICMP Time Exceeded (Type 11)"
    
    struct: {
      grid-columns: 3
      grid-gap: 0
      
      x0_off: "0x00"
      x0_field: "Type (11)"
      x0_field.style.fill: "#d1b3ff"
      x0_field.style.bold: true
      x0_size: "1B"
      
      x1_off: "0x01"
      x1_field: "Code (0 or 1)"
      x1_field.style.fill: "#d1b3ff"
      x1_field.style.bold: true
      x1_size: "1B"
      
      x2_off: "0x02"
      x2_field: "Checksum" { style.fill: "#d1b3ff" }
      x2_size: "2B"
      
      x4_off: "0x04"
      x4_field: "Unused (Reserved)" { style.fill: "#e0e0e0" }
      x4_size: "4B"
      
      x8_off: "0x08"
      x8_field: "Original IP Header" { style.fill: "#b3d9ff" }
      x8_size: "20B"
      
      x28_off: "0x1C"
      x28_field: "Original Payload (64 Bits)" { style.fill: "#b3d9ff" }
      x28_size: "8B"
    }
  }

  # Layout constraints
  generic_header -> echo_layout: "Specialization"
  echo_layout -> dest_unreach
  dest_unreach -> time_exceeded
}

# ANNOTATIONS - Root level (Corrected near constraint for ELK engine)
annotation: |md
  ### ICMP Implementation Details (RFC 792)
  - **Checksum Algorithm:** 16-bit one's complement of the one's complement sum of the ICMP message starting with the ICMP Type.
  - **Type 3 Code 4:** Used for Path MTU Discovery. If a router cannot forward a packet because it is too large for the next link and the DF (Don't Fragment) bit is set, it sends this message. The MTU field at offset `0x06` indicates the MTU of that link.
  - **Type 11:** 
    - Code 0: TTL (Time to Live) exceeded in transit.
    - Code 1: Fragment reassembly time exceeded.
  - **Cache Locality:** The standard 8-byte ICMP header fits within a single cache line (64B). In high-performance bypass stacks, ensuring original IP header data is pre-aligned can reduce L1 misses.
| {
  near: bottom-center
}