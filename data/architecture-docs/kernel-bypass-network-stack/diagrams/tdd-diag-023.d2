direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# IP Routing Table Lookup Algorithm: Longest Prefix Match (LPM)
# Intel Manual Quality Implementation-Grade Diagram

title: |md
  # Algorithm: IP Routing Table Lookup (LPM)
  **Objective:** Select the most specific route for Destination IP: `10.1.1.50`
| {near: top-center}

# --- Shared State Definitions ---
classes: {
  step_container: {
    style: {
      stroke-width: 2
      border-radius: 8
    }
  }
  register: {
    shape: sql_table
    style: {
      fill: "#f8f9fa"
      stroke: "#212529"
    }
  }
  highlight: {
    style: {
      stroke: "#d90429"
      stroke-width: 4
      font-color: "#d90429"
      bold: true
    }
  }
}

# --- Step 1: Initialization ---
step1: "Step 1: Initialization" {
  class: step_container
  
  registers: {
    shape: sql_table
    "Target IP": "0x0A010132 (10.1.1.50)"
    "Best Match": "NULL"
    "Max Prefix": "-1"
    "Best Metric": "255"
  }
  
  description: |md
    ### Setup
    Initialize search registers to 
    identity values. 
    LPM requires scanning 
    available route entries.
  |
}

# --- Step 2: First Match (General) ---
step2: "Step 2: Prefix Match (10.0.0.0/8)" {
  class: step_container
  
  logic: |md
    **Bitwise AND Comparison:**
    IP:   `00001010.00000001.00000001.00110010`
    Mask: `11111111.00000000.00000000.00000000` (/8)
    -------------------------------------------
    Res:  `00001010.00000000.00000000.00000000` (**10.0.0.0**)
    **Result: MATCH**
  |

  registers: {
    shape: sql_table
    "Target IP": "10.1.1.50"
    "Best Match": "**10.0.0.0/8**" {style.font-color: red}
    "Max Prefix": "**8**" {style.font-color: red}
    "Best Metric": "**0**" {style.font-color: red}
  }
}

# --- Step 3: Better Match (Specific) ---
step3: "Step 3: Longest Prefix (10.1.1.0/24)" {
  class: step_container
  
  logic: |md
    **Bitwise AND Comparison:**
    IP:   `10.1.1.50`
    Mask: `255.255.255.0` (/24)
    --------------------------
    Res:  `10.1.1.0`
    **24 bits > 8 bits**
  |

  registers: {
    shape: sql_table
    "Target IP": "10.1.1.50"
    "Best Match": "**10.1.1.0/24**" {style.font-color: red}
    "Max Prefix": "**24**" {style.font-color: red}
    "Best Metric": "**10**" {style.font-color: red}
  }
}

# --- Step 4: Metric Tie-Break ---
step4: "Step 4: Metric Tie-Break" {
  class: step_container
  
  comparison: |md
    ### Tie-Breaking
    Found redundant route:
    `10.1.1.0/24` (Metric: 5)
    
    Current Best: 10
    Candidate: 5
    **Action: Update Best**
  |

  registers: {
    shape: sql_table
    "Target IP": "10.1.1.50"
    "Best Match": "10.1.1.0/24"
    "Max Prefix": "24"
    "Best Metric": "**5**" {style.font-color: red}
  }
}

# --- Step 5: Final Selection ---
step5: "Step 5: Completion" {
  class: step_container
  
  result: |md
    ### Selected Hop
    **Target:** 10.1.1.50
    **Gateway:** 10.1.1.1
    **Interface:** eth0
    **MTU:** 1500
  | {style.fill: "#d8f3dc"}

  registers: {
    shape: sql_table
    "Status": "**COMPLETE**" {style.font-color: green}
    "Final Route": "10.1.1.0/24"
  }
}

# --- Connections ---
step1 -> step2: "Next Entry"
step2 -> step3: "Better specificity found"
step3 -> step4: "Equal specificity found"
step4 -> step5: "Optimization Finished"

# --- Algorithm Invariants Footer ---
legend: |md
  ## Algorithm Invariants
  1. **Longest Prefix Wins:** Higher bit-count in netmask always overrides metric.
  2. **Metric Tie-Break:** If prefix lengths are identical, route with lowest metric is chosen.
  3. **Default Fallback:** `0.0.0.0/0` matches only if no other prefixes satisfy the mask.
| {near: bottom-center}

# Styles
step1.registers.Max Prefix: {style.bold: true}
step2.registers.Max Prefix: {style.bold: true}
step3.registers.Max Prefix: {style.bold: true}
step4.registers.Best Metric: {style.bold: true}