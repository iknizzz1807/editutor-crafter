direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# TCP HEADER MEMORY MAP - ARCHITECTURAL SPECIFICATION
# -----------------------------------------------------------------------------------------
# Offset | Field Description (Intel Manual Standard)               | Size
# -----------------------------------------------------------------------------------------

TCP_STACK: {
  tcp_header_map: {
    grid-columns: 3
    vertical-gap: 0
    horizontal-gap: 20
    style.stroke-width: 0

    # TABLE HEADERS
    offset_label: "**Byte Offset**" { 
      shape: text
      style.font-color: "#212121"
      style.bold: true
    }
    field_label: "**Field Description (Bit Layout)**" { 
      shape: text
      style.font-color: "#212121"
      style.bold: true
    }
    size_label: "**Field Size**" { 
      shape: text
      style.font-color: "#212121"
      style.bold: true
    }

    # BYTE 0-3: PORTS
    r0_off: "0x00"
    r0_field: "Source Port" {
      style: { fill: "#f3e5f5"; stroke: "#4527a0"; stroke-width: 2 }
      tooltip: "Identifies the sending port"
    }
    r0_size: "16 bits"

    r2_off: "0x02"
    r2_field: "Destination Port" {
      style: { fill: "#f3e5f5"; stroke: "#4527a0"; stroke-width: 2 }
      tooltip: "Identifies the receiving port"
    }
    r2_size: "16 bits"

    # BYTE 4-7: SEQUENCE NUMBER
    r4_off: "0x04"
    r4_field: "Sequence Number" {
      height: 60
      style: { fill: "#f3e5f5"; stroke: "#4527a0"; stroke-width: 2 }
      tooltip: "Initial Sequence Number (SYN=1) or Accumulative Sequence Number (SYN=0)"
    }
    r4_size: "32 bits"

    # BYTE 8-11: ACKNOWLEDGMENT NUMBER
    r8_off: "0x08"
    r8_field: "Acknowledgment Number" {
      height: 60
      style: { fill: "#f3e5f5"; stroke: "#4527a0"; stroke-width: 2 }
      tooltip: "Valid if ACK flag is set. Contains next expected sequence number."
    }
    r8_size: "32 bits"

    # BYTE 12-13: DATA OFFSET, RESERVED, FLAGS
    r12_off: "0x0C"
    r12_field: {
      label: ""
      style: { fill: "#f3e5f5"; stroke: "#4527a0"; stroke-width: 2 }
      
      bits: {
        grid-columns: 11
        grid-gap: 0
        style.stroke-width: 0

        do: "Data\nOff" { style.fill: "#e1bee7"; width: 50; tooltip: "4 bits: Header length in 32-bit words" }
        res: "Res" { style.fill: "#eeeeee"; width: 40; tooltip: "3 bits: Reserved" }
        ns: "NS" { style.fill: "#ce93d8"; width: 35; tooltip: "ECN-nonce" }
        cwr: "CWR" { style.fill: "#ce93d8"; width: 35; tooltip: "Congestion Window Reduced" }
        ece: "ECE" { style.fill: "#ce93d8"; width: 35; tooltip: "ECN-Echo" }
        urg: "URG" { style.fill: "#ce93d8"; width: 35; tooltip: "Urgent Pointer" }
        ack: "ACK" { style.fill: "#ce93d8"; width: 35; tooltip: "Acknowledgment" }
        psh: "PSH" { style.fill: "#ce93d8"; width: 35; tooltip: "Push Function" }
        rst: "RST" { style.fill: "#ce93d8"; width: 35; tooltip: "Reset the connection" }
        syn: "SYN" { style.fill: "#ce93d8"; width: 35; tooltip: "Synchronize" }
        fin: "FIN" { style.fill: "#ce93d8"; width: 35; tooltip: "Finish" }
      }
    }
    r12_size: "16 bits"

    # BYTE 14-15: WINDOW SIZE
    r14_off: "0x0E"
    r14_field: "Window Size" {
      style: { fill: "#f3e5f5"; stroke: "#4527a0"; stroke-width: 2 }
    }
    r14_size: "16 bits"

    # BYTE 16-17: CHECKSUM
    r16_off: "0x10"
    r16_field: "Checksum" {
      style: { fill: "#f3e5f5"; stroke: "#4527a0"; stroke-width: 2 }
      tooltip: "16-bit one's complement of header + data"
    }
    r16_size: "16 bits"

    # BYTE 18-19: URGENT POINTER
    r18_off: "0x12"
    r18_field: "Urgent Pointer" {
      style: { fill: "#fff3e0"; stroke: "#e65100"; stroke-width: 2 }
      tooltip: "Offset indicating the last urgent data byte"
    }
    r18_size: "16 bits"

    # OPTIONS MARKER
    sep_off: "---"
    sep_field: "Variable Options Segment (Data Offset * 4)" {
      shape: text
      style: { font-color: "#757575"; italic: true; bold: true }
    }
    sep_size: "---"

    # COMMON OPTIONS
    o20_off: "0x14"
    o20_field: "Option: Maximum Segment Size (MSS)" {
      style: { fill: "#e3f2fd"; stroke: "#1976d2"; stroke-dash: 3 }
      label: "MSS [Kind=2][Len=4][Value]"
    }
    o20_size: "4 Bytes"

    o24_off: "0x18"
    o24_field: "Option: Window Scale" {
      style: { fill: "#e3f2fd"; stroke: "#1976d2"; stroke-dash: 3 }
      label: "WSOPT [Kind=3][Len=3][Shift]"
    }
    o24_size: "3 Bytes"

    # ALIGNMENT PADDING
    pad_off: "0xXX"
    pad_field: "Padding (Alignment to 32-bit boundary)" {
      style: { fill: "#eeeeee"; stroke: "#757575"; stroke-dash: 5 }
    }
    pad_size: "Variable"

    # CACHE LINE ANNOTATION
    cl_off: "---"
    cl_field: "-------------------- 64B CACHE LINE BOUNDARY --------------------" {
      shape: text
      style: { font-color: red; bold: true }
    }
    cl_size: "---"

    # DATA PAYLOAD
    data_off: "0xXX"
    data_field: "Application Data / Payload" {
      height: 80
      style: { fill: "#bbdefb"; stroke: "#1976d2"; stroke-width: 3 }
    }
    data_size: "MTU - Hdr"
  }

  # METADATA AND LEGEND
  meta_info: {
    # The near key is removed to prevent the grid-descendant error. 
    # Siblings inside the same container will flow naturally.

    legend: {
      grid-columns: 2
      style.stroke: "#cccccc"
      style.fill: "#fafafa"
      
      h_box: "" { style.fill: "#f3e5f5"; width: 25; height: 15; style.stroke: "#4527a0" }
      h_lbl: "TCP Fixed Header (Metadata)" { shape: text }
      
      p_box: "" { style.fill: "#fff3e0"; width: 25; height: 15; style.stroke: "#e65100" }
      p_lbl: "Pointers / Offsets" { shape: text }
      
      o_box: "" { style.fill: "#e3f2fd"; width: 25; height: 15; style.stroke: "#1976d2" }
      o_lbl: "TCP Options (Extensions)" { shape: text }
      
      d_box: "" { style.fill: "#bbdefb"; width: 25; height: 15; style.stroke: "#1976d2" }
      d_lbl: "Data Payload" { shape: text }
      
      pad_box: "" { style.fill: "#eeeeee"; width: 25; height: 15; style.stroke: "#757575" }
      pad_lbl: "Padding / Reserved" { shape: text }
    }

    specs: |md
      ### Implementation Details (RFC 9293)
      - **Minimal Header**: 20 Octets (without options)
      - **Maximum Header**: 60 Octets (Data Offset limit = 15 words)
      - **Endianness**: Big-Endian (Network Byte Order)
      - **Word Size**: All fields aligned to 4-byte boundaries
      - **Checksum**: Covers pseudo-header (IP addresses, protocol, length)
    |
  }
}

# STYLING GLOBALS
***.style.font-size: 14
TCP_STACK.tcp_header_map.*_off.style.font: mono
TCP_STACK.tcp_header_map.*_size.style.font: mono
TCP_STACK.tcp_header_map.*_off.style.font-color: "#616161"
TCP_STACK.tcp_header_map.*_size.style.font-color: "#616161"
TCP_STACK.tcp_header_map.offset_label.style.font-size: 16
TCP_STACK.tcp_header_map.field_label.style.font-size: 16
TCP_STACK.tcp_header_map.size_label.style.font-size: 16