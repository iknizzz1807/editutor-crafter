direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# TCP State Machine Invariants & Metadata
title: |md
  # TCP Finite State Machine (RFC 793)
  **Invariants:**
  - Sequence numbers wrap at $2^{32}$
  - $SND.UNA \le SND.NXT$
  - Handshake: 3-way
  - Teardown: 4-way or RST
| {
  near: top-center
}

# Participants and States
states: {
  START: "" {
    shape: circle
    style: {
      fill: black
      stroke-width: 0
    }
  }

  CLOSED: "CLOSED" {
    tooltip: "Connection is non-existent. Invariant: All buffers freed."
    style.stroke-width: 4
  }

  LISTEN: "LISTEN" {
    tooltip: "Waiting for SYN from remote peer."
    invariant: "Passive Open active"
  }

  SYN_SENT: "SYN_SENT" {
    tooltip: "SYN sent, waiting for matching SYN-ACK."
    invariant: "SND.UNA = ISS; SND.NXT = ISS+1"
  }

  SYN_RECEIVED: "SYN_RECEIVED" {
    tooltip: "SYN received and acknowledged. Waiting for final ACK."
    invariant: "RCV.NXT = IRS+1"
  }

  ESTABLISHED: "ESTABLISHED" {
    tooltip: "Data transfer phase. Reliability mechanisms active."
    style: {
      fill: "#e6f3ff"
      stroke: "#0078d4"
      stroke-width: 6
    }
    invariant: "Reliable byte-stream open"
  }

  FIN_WAIT_1: "FIN_WAIT_1" {
    tooltip: "Active close: FIN sent, waiting for ACK or remote FIN."
  }

  FIN_WAIT_2: "FIN_WAIT_2" {
    tooltip: "FIN acknowledged. Waiting for remote peer's FIN."
  }

  CLOSING: "CLOSING" {
    tooltip: "Simultaneous close: Recv FIN after sending FIN."
  }

  TIME_WAIT: "TIME_WAIT" {
    tooltip: "Wait 2*MSL to ensure late segments are dropped."
    invariant: "Timer = 120s (default)"
  }

  CLOSE_WAIT: "CLOSE_WAIT" {
    tooltip: "Passive close: Received FIN. Waiting for local app close."
  }

  LAST_ACK: "LAST_ACK" {
    tooltip: "Local FIN sent. Waiting for final ACK from peer."
  }
}

# Transitions: Opening Sequence
states.START -> states.CLOSED

states.CLOSED -> states.LISTEN: "Passive Open / -"
states.CLOSED -> states.SYN_SENT: "Active Open / send SYN" {
  style.stroke: "#8e44ad"
}

states.LISTEN -> states.SYN_RECEIVED: "recv SYN / send SYN+ACK"
states.LISTEN -> states.CLOSED: "Close / -"

states.SYN_SENT -> states.ESTABLISHED: "recv SYN+ACK / send ACK" {
  style.stroke: "#8e44ad"
  style.stroke-width: 3
}
states.SYN_SENT -> states.SYN_RECEIVED: "recv SYN / send ACK\n(Simultaneous Open)" {
  style.stroke-dash: 3
}
states.SYN_SENT -> states.CLOSED: "Close or Timeout / -"

states.SYN_RECEIVED -> states.ESTABLISHED: "recv ACK / -" {
  style.stroke: "#8e44ad"
}
states.SYN_RECEIVED -> states.FIN_WAIT_1: "Close / send FIN"

# Transitions: Closing Sequence (Active)
states.ESTABLISHED -> states.FIN_WAIT_1: "Close / send FIN" {
  style.stroke: "#2980b9"
}

states.FIN_WAIT_1 -> states.FIN_WAIT_2: "recv ACK / -" {
  style.stroke: "#2980b9"
}
states.FIN_WAIT_1 -> states.CLOSING: "recv FIN / send ACK\n(Simultaneous Close)"
states.FIN_WAIT_1 -> states.TIME_WAIT: "recv FIN+ACK / send ACK"

states.FIN_WAIT_2 -> states.TIME_WAIT: "recv FIN / send ACK" {
  style.stroke: "#2980b9"
}

states.CLOSING -> states.TIME_WAIT: "recv ACK / -"

states.TIME_WAIT -> states.CLOSED: "Timeout (2*MSL) / -" {
  style.stroke-dash: 5
}

# Transitions: Closing Sequence (Passive)
states.ESTABLISHED -> states.CLOSE_WAIT: "recv FIN / send ACK" {
  style.stroke: "#27ae60"
}

states.CLOSE_WAIT -> states.LAST_ACK: "Close / send FIN" {
  style.stroke: "#27ae60"
}

states.LAST_ACK -> states.CLOSED: "recv ACK / -" {
  style.stroke: "#27ae60"
}

# Abnormal Transitions (Resets)
states.ESTABLISHED -> states.CLOSED: "recv RST / abort" {
  style: {
    stroke: red
    stroke-width: 2
  }
}

states.SYN_RECEIVED -> states.CLOSED: "recv RST / -" {
  style.stroke: red
}

states.SYN_SENT -> states.CLOSED: "recv RST / -" {
  style.stroke: red
}

# Legend and Annotations
legend: {
  near: bottom-right
  opening: "Opening / Handshake" {
    style.stroke: "#8e44ad"
  }
  active: "Active Close Path" {
    style.stroke: "#2980b9"
  }
  passive: "Passive Close Path" {
    style.stroke: "#27ae60"
  }
  illegal: "ILLEGAL TRANSITION" {
    style: {
      stroke: red
      stroke-dash: 3
    }
  }
}

# Explicitly marking a forbidden transition for engineer clarity
states.LISTEN -> states.FIN_WAIT_1: "ILLEGAL" {
  style: {
    stroke: red
    stroke-dash: 3
  }
}

# Styling Page Page
style: {
  fill: "#fcfcfc"
}