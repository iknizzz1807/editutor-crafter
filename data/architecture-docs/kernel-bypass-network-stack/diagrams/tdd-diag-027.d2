direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# MAIN HANDSHAKE SEQUENCE
handshake_protocol: {
  shape: sequence_diagram
  
  client: "TCP Client Stack\n(Active Open)" {
    tooltip: "Initiator: High-performance kernel bypass stack"
    style: {
      stroke: "#2980b9"
      fill: "#ebf5fb"
      stroke-width: 4
    }
  }
  server: "TCP Server Stack\n(Passive Open)" {
    tooltip: "Responder: Listening on 0.0.0.0:PORT"
    style: {
      stroke: "#c0392b"
      fill: "#fdedec"
      stroke-width: 4
    }
  }

  # Initial Invariants
  client."STATE: CLOSED\nSND.UNA: 0\nSND.NXT: 0"
  server."STATE: LISTEN\nRCV.NXT: 0"

  # Step 1: SYN Transmission
  client.t1: "GENERATE ISN_c\nALLOCATE TCB" {
    style.fill: "#fcf3cf"
  }
  
  client.t1 -> server.t1: "SEGMENT 1: [SYN]\n------------------\nSEQ: ISN_c\nACK: 0\nCTL: 0x02 (SYN)\nWIN: 65535\nOPT: MSS=1460, WS=7" {
    tooltip: "Byte 13: 00000010 (SYN)"
    style: {
      stroke: blue
      stroke-width: 2
      animated: true
    }
  }
  
  client."TRANSITION: SYN_SENT" {
    style: {
      font-color: red
      bold: true
    }
  }
  
  # Step 2: SYN-ACK Response
  server.t2: "VERIFY SYN\nRCV.NXT = ISN_c + 1\nGENERATE ISN_s" {
    style.fill: "#fcf3cf"
  }
  
  server.t2 -> client.t2: "SEGMENT 2: [SYN, ACK]\n----------------------\nSEQ: ISN_s\nACK: ISN_c + 1\nCTL: 0x12 (SYN|ACK)\nWIN: 65535\nOPT: MSS=1460, WS=7" {
    tooltip: "Byte 13: 00010010 (SYN+ACK)"
    style: {
      stroke: purple
      stroke-width: 2
      animated: true
    }
  }
  
  server."TRANSITION: SYN_RECEIVED" {
    style: {
      font-color: red
      bold: true
    }
  }

  # Step 3: Final ACK
  client.t3: "VERIFY SYN-ACK\nSND.UNA = ISN_c + 1\nSND.NXT = ISN_c + 1\nRCV.NXT = ISN_s + 1" {
    style.fill: "#d5f5e3"
  }
  
  client.t3 -> server.t3: "SEGMENT 3: [ACK]\n------------------\nSEQ: ISN_c + 1\nACK: ISN_s + 1\nCTL: 0x10 (ACK)\nWIN: 65535" {
    tooltip: "Byte 13: 00010000 (ACK)"
    style: {
      stroke: green
      stroke-width: 2
      animated: true
    }
  }
  
  client."TRANSITION: ESTABLISHED" {
    style: {
      font-color: "#1e8449"
      bold: true
    }
  }

  # Step 4: Server Finalization
  server.t4: "VERIFY ACK\nSND.UNA = ISN_s + 1\nSND.NXT = ISN_s + 1\nTRANSITION:\nESTABLISHED" {
    style.fill: "#d5f5e3"
  }
}

# Fixed: Using a constant positioning value for ELK engine compatibility
handshake_summary: |md
  ### RFC 9293 / 793 Compliant Handshake
  - **ISN Selection**: Cryptographically secure PRNG required to prevent sequence prediction attacks.
  - **Option Negotiation**: MSS (Maximum Segment Size) and Window Scaling (WS) are only exchanged during the SYN segments.
  - **TCB State**: Transition to `ESTABLISHED` occurs on the initiator side upon receipt of SYN-ACK, and on the responder side upon receipt of the final ACK.
  - **Retransmission**: If SYN-ACK is not received, initiator enters exponential backoff (typically 1s, 3s, 7s).
| {
  near: bottom-center
  style: {
    stroke: "#7f8c8d"
    fill: "#fdfefe"
    stroke-dash: 2
    font-size: 14
  }
}

# Explicit Global Styles for Engineering Clarity
handshake_protocol.client.style.font: mono
handshake_protocol.server.style.font: mono

# Connection styling overrides for specific indexes
(handshake_protocol.client.t1 -> handshake_protocol.server.t1)[0].source-arrowhead: circle
(handshake_protocol.server.t2 -> handshake_protocol.client.t2)[0].source-arrowhead: circle
(handshake_protocol.client.t3 -> handshake_protocol.server.t3)[0].source-arrowhead: circle

# Arrowhead custom styling
(handshake_protocol.client.t1 -> handshake_protocol.server.t1)[0].target-arrowhead: triangle {
  style.filled: true
}
(handshake_protocol.server.t2 -> handshake_protocol.client.t2)[0].target-arrowhead: triangle {
  style.filled: true
}
(handshake_protocol.client.t3 -> handshake_protocol.server.t3)[0].target-arrowhead: triangle {
  style.filled: true
}