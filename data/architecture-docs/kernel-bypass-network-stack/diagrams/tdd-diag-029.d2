direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  styles: {
    byte_block: {
      style: {
        stroke-width: 1
        border-radius: 2
        font-size: 14
        height: 60
        width: 100
      }
    }
  }
}

# -----------------------------------------------------------------------------
# TCP SLIDING WINDOW MECHANICS - TECHNICAL SPECIFICATION
# Implementation Reference: RFC 9293 (Transmission Control Protocol)
# -----------------------------------------------------------------------------

classes: {
  ack_data: {
    style: {
      fill: "#d3d3d3"
      stroke: "#9e9e9e"
      stroke-width: 1
      border-radius: 2
      font-size: 14
    }
    label: "ACK'd"
  }
  inflight_data: {
    style: {
      fill: "#ffcc80"
      stroke: "#f57c00"
      stroke-width: 1
      border-radius: 2
      font-size: 14
    }
    label: "In-Flight"
  }
  usable_data: {
    style: {
      fill: "#90caf9"
      stroke: "#1976d2"
      stroke-width: 1
      border-radius: 2
      font-size: 14
    }
    label: "Usable"
  }
  future_data: {
    style: {
      fill: "#eeeeee"
      stroke: "#bdbdbd"
      stroke-dash: 2
      stroke-width: 1
      border-radius: 2
      font-size: 14
    }
    label: "Future"
  }
  pointer: {
    shape: parallelogram
    style: {
      fill: "#ffa726"
      stroke: "#ef6c00"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
}

legend: {
  shape: package
  near: top-right
  label: "Window State Legend"
  
  ack: Acknowledged { 
    class: ack_data
    tooltip: "Data confirmed by receiver via cumulative ACK"
  }
  inflight: In-Flight { 
    class: inflight_data
    tooltip: "Sent but not yet acknowledged (SND.NXT - SND.UNA)"
  }
  usable: Usable { 
    class: usable_data
    tooltip: "Inside window but not yet sent"
  }
  future: Future { 
    class: future_data
    tooltip: "Outside current offered window"
  }
}

# -----------------------------------------------------------------------------
# STEP 1: INITIAL STEADY STATE
# -----------------------------------------------------------------------------
step_1: {
  label: "1. Initial Steady State"
  direction: right
  
  stream: {
    grid-columns: 10
    grid-gap: 5
    
    b0: "0-99" { class: ack_data }
    b1: "100-109" { class: inflight_data }
    b2: "110-119" { class: inflight_data }
    b3: "120-129" { class: inflight_data }
    b4: "130-139" { class: usable_data }
    b5: "140-149" { class: usable_data }
    b6: "150-159" { class: future_data }
    b7: "160-169" { class: future_data }
    b8: "170-179" { class: future_data }
    b9: "180+" { class: future_data }
  }

  pointers: {
    una: "SND_UNA\n(100)" { class: pointer }
    nxt: "SND_NXT\n(130)" { class: pointer }
    wnd_end: "UNA + WND\n(150)" { class: pointer }
    
    una -> _ . stream.b1
    nxt -> _ . stream.b4
    wnd_end -> _ . stream.b6
  }

  calc: ||md
    ### State Invariants
    | Variable | Value | Description |
    | :--- | :--- | :--- |
    | **SND_UNA** | 100 | Oldest unacked byte |
    | **SND_NXT** | 130 | Next byte to send |
    | **SND_WND** | 50 | Peer Window |
    | **Usable** | 20 | Remaining credits |
  ||
  calc.style.stroke-width: 0
}

# -----------------------------------------------------------------------------
# STEP 2: DATA TRANSMISSION
# -----------------------------------------------------------------------------
step_2: {
  label: "2. Application Sends 10 Bytes"
  direction: right
  
  stream: {
    grid-columns: 10
    grid-gap: 5
    
    b0: "0-99" { class: ack_data }
    b1: "100-109" { class: inflight_data }
    b2: "110-119" { class: inflight_data }
    b3: "120-129" { class: inflight_data }
    b4: "**130-139**" { 
      class: inflight_data
      style: {
        stroke: red
        stroke-width: 5
        bold: true
      }
    }
    b5: "140-149" { class: usable_data }
    b6: "150-159" { class: future_data }
    b7: "160-169" { class: future_data }
    b8: "170-179" { class: future_data }
    b9: "180+" { class: future_data }
  }

  pointers: {
    una: "SND_UNA\n(100)" { class: pointer }
    nxt: "**SND_NXT\n(140)**" { 
      class: pointer
      style: { fill: red; font-color: white }
    }
    wnd_end: "UNA + WND\n(150)" { class: pointer }
    
    una -> _ . stream.b1
    nxt -> _ . stream.b5
    wnd_end -> _ . stream.b6
  }

  calc: |md
    ### Transition: Send Event
    - **Buffer Shift**: 10 bytes Usable → **In-Flight**
    - **Logic**: `SND_NXT += 10`
    - **Constraint**: `SND_NXT` cannot exceed `SND_UNA + SND_WND`
  |
  calc.style.stroke-width: 0
}

# -----------------------------------------------------------------------------
# STEP 3: WINDOW SLIDE
# -----------------------------------------------------------------------------
step_3: {
  label: "3. Receiver ACKs 20 Bytes"
  direction: right
  
  stream: {
    grid-columns: 10
    grid-gap: 5
    
    b0: "0-99" { class: ack_data }
    b1: "**100-109**" { class: ack_data; style.stroke: red; style.stroke-width: 3 }
    b2: "**110-119**" { class: ack_data; style.stroke: red; style.stroke-width: 3 }
    b3: "120-129" { class: inflight_data }
    b4: "130-139" { class: inflight_data }
    b5: "140-149" { class: usable_data }
    b6: "**150-159**" { class: usable_data; style.stroke: red; style.stroke-width: 3 }
    b7: "**160-169**" { class: usable_data; style.stroke: red; style.stroke-width: 3 }
    b8: "170-179" { class: future_data }
    b9: "180+" { class: future_data }
  }

  pointers: {
    una: "**SND_UNA\n(120)**" { 
      class: pointer
      style: { fill: red; font-color: white }
    }
    nxt: "SND_NXT\n(140)" { class: pointer }
    wnd_end: "**UNA + WND\n(170)**" { 
      class: pointer
      style: { fill: red; font-color: white }
    }
    
    una -> _ . stream.b3
    nxt -> _ . stream.b5
    wnd_end -> _ . stream.b8
  }

  calc: |md
    ### Transition: ACK Event
    - **Cumulative ACK**: Received 120
    - **SND_UNA**: Advances `100 → 120`
    - **Slide**: Right-edge of window shifts `150 → 170`
    - **Outcome**: 20 bytes of Future → **Usable**
  |
  calc.style.stroke-width: 0
}

# Sequence Flow Control
step_1 -> step_2: "Output: TCP Segment [SEQ=130, LEN=10]" {
  style: {
    stroke: blue
    stroke-width: 4
    animated: true
  }
}

step_2 -> step_3: "Input: ACK [ACK=120, WND=50]" {
  style: {
    stroke: blue
    stroke-width: 4
    animated: true
  }
}

annotation: |md
  ## RFC 9293 Implementation Note
  
  The transmitter must maintain the following relationship:
  `OfferedWindow = SND.WND`
  `UsedWindow = SND.NXT - SND.UNA`
  `UsableWindow = OfferedWindow - UsedWindow`
  
  **Pointer Definitions:**
  - **SND_UNA**: Pointer to first byte of In-Flight sequence
  - **SND_NXT**: Pointer to first byte of Usable sequence
  - **Window End**: Pointer to first byte of Future sequence
|
annotation.near: step_3
annotation.style: {
  font-size: 16
  fill: "#fff3e0"
  stroke: "#ffa726"
  border-radius: 8
}