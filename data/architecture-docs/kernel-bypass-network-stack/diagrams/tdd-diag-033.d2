direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# ---------------------------------------------------------------------------
# AGENT: TECHNICAL DESIGN ARTIST
# DIAGRAM: SYN COOKIES ALGORITHM (STATELESS FLOOD DEFENSE)
# PURPOSE: IMPLEMENTATION SPEC FOR KERNEL NETWORK STACK
# ---------------------------------------------------------------------------

syn_cookie_system: {
  label: "SYN Cookie Protocol & Memory Layout"
  
  # 1. MEMORY LAYOUT DIAGRAM (32-Bit Register View)
  # ---------------------------------------------------------------------------
  header_anchor: "Cookie Component Specification" {
    cookie_layout: {
      grid-columns: 3
      grid-gap: 0
      style.stroke-width: 2

      # Row 1: Logical Field Names
      v1: "MSS\n(3 bits)" { 
        style.fill: "#D1C4E9" # Purple (Header)
        style.bold: true
      }
      v2: "COUNTER\n(5 bits)" { 
        style.fill: "#BBDEFB" # Blue (Data)
        style.bold: true
      }
      v3: "HMAC HASH\n(24 bits)" { 
        style.fill: "#C8E6C9" # Green (Verification)
        style.bold: true
      }
      
      # Row 2: Bit Positions (Intel Manual Style)
      t1: "31..........29" { 
        style: {
          font: mono
          font-size: 10
          fill: "#EDE7F6"
        }
      }
      t2: "28......24" { 
        style: {
          font: mono
          font-size: 10
          fill: "#E3F2FD"
        }
      }
      t3: "23.........................................0" { 
        style: {
          font: mono
          font-size: 10
          fill: "#E8F5E9"
        }
      }
    }
  }

  # 2. ALGORITHM FLOW - PHASE A: GENERATION (INCOMING SYN)
  # ---------------------------------------------------------------------------
  generation: "Phase A: Stateless Generation" {
    direction: down
    
    step_1: "1. SYN Arrival\n| t = 0 |" {
      tooltip: "Incoming SYN packet with Client ISN"
      shape: parallelogram
      style.stroke: "#D32F2F"
      style.stroke-width: 4
    }

    step_2: "2. Cryptographic Hash" {
      logic: "HMAC_SHA256(SIP, DIP, SP, DP, Secret, Counter)"
      result: "Truncated to 24-bit ISN suffix"
      style.fill: "#FFF9C4"
    }

    step_3: "3. MSS Encoding" {
      lookup: "Client_MSS -> Index[0..7]"
      mapping: "3-bit value injected into ISN[31:29]"
      style.fill: "#E1F5FE"
    }

    step_4: "4. SYN-ACK Outbound" {
      action: "Response SEQ = COOKIE"
      state: "MEMORY CLEAN: NO TCB ALLOCATED"
      style.stroke: "#D32F2F"
      style.fill: "#FFEBEE"
      style.bold: true
    }

    step_1 -> step_2: "Trigger: Backlog Full"
    step_2 -> step_3: "Append Data"
    step_3 -> step_4: "Final ISN"
  }

  # 3. ALGORITHM FLOW - PHASE B: VALIDATION (INCOMING ACK)
  # ---------------------------------------------------------------------------
  validation: "Phase B: Stateless Validation" {
    direction: down
    
    step_5: "5. Final ACK" {
      input: "Packet: [Seq, AckNum]"
      extract: "Cookie = AckNum - 1"
      shape: parallelogram
    }

    step_6: "6. Verify Integrity" {
      logic: "Re-run HMAC with current/prev Secret"
      compare: "Is (Computed_Hash == Extracted_Hash)?"
      style.fill: "#FCE4EC"
    }

    step_7: "7. TCB Restoration" {
      condition: "Match == TRUE"
      action: "ALLOCATE TCB & MSS"
      status: "STATE: ESTABLISHED"
      style.stroke: "#388E3C"
      style.stroke-width: 4
      style.fill: "#C8E6C9"
      style.bold: true
    }

    step_8: "8. Rejection" {
      condition: "Invalid/Expired"
      action: "SEND RST"
      style.stroke: "#D32F2F"
      style.fill: "#FFCDD2"
    }

    step_5 -> step_6: "Stateless Inspection"
    step_6 -> step_7: "Valid"
    step_6 -> step_8: "Invalid"
  }

  # 4. CROSS-PHASE TRANSITION
  # ---------------------------------------------------------------------------
  generation.step_4 -> validation.step_5: "Network RTT\n(Server remains stateless)" {
    style: {
      stroke-dash: 5
      animated: true
      stroke: orange
    }
  }
}

# 5. DOCUMENTATION ANNOTATIONS
# ---------------------------------------------------------------------------
# FIXED: Using |'md ... '| to escape the $ symbol from $2^{24}$ to prevent substitution errors.
annotation: |'md
  ### SYN Cookie Protocol (RFC 4987)
  **Security & Technical Constraints:**
  1. **Counter (5 bits):** Increments every 64s. Validates cookies within a 32-minute window.
  2. **MSS Encoding:** 
     - 0: 536 | 1: 1460 | 2: 1440 | 3: 1400
     - 4: 4312 | 5: 8961 | 6: 65535 | 7: Custom
  3. **Stateless Nature:** No memory is allocated on the server between Step 4 and Step 5.
  4. **Hash Collision:** 24 bits provides $2^{24}$ entropy; adequate for burst defense.
'|

annotation.near: syn_cookie_system.header_anchor

# 6. GLOBAL STYLING GLOBS
# ---------------------------------------------------------------------------
syn_cookie_system.** {
  style: {
    stroke-width: 2
    border-radius: 4
    font: mono
  }
}

# Highlighting Critical Path States
syn_cookie_system.generation.step_4.state.style.font-color: "#D32F2F"
syn_cookie_system.validation.step_7.status.style.font-color: "#1B5E20"

# Directional constraints for the sub-blocks
syn_cookie_system.generation.direction: down
syn_cookie_system.validation.direction: down
syn_cookie_system.direction: right