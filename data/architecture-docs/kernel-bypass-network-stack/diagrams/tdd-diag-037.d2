direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# CPU Cache Hierarchy & Locality Mapping
# 0-5µs Latency Path Optimization

cpu_core: CPU Core (Execution Unit) {
  style: {
    stroke-width: 4
    fill: "#f8f9fa"
  }

  l1_cache: L1 Data Cache (32KB) {
    tooltip: "Latency: ~4ns (4-5 cycles)"
    style: {
      stroke-dash: 5
      fill: "#f3e5f5"
    }

    # Cache Line 0
    rx_ring_indices: {
      shape: sql_table
      0x00: producer_idx {label: "4B"; style.fill: "#ce93d8"}
      0x04: padding {label: "60B"; style.fill: "#eeeeee"}
    }

    # Cache Line 1
    tcp_conn_hot: {
      shape: sql_table
      0x00: tuple_id {label: "12B"; style.fill: "#ce93d8"}
      0x0C: state_flags {label: "4B"; style.fill: "#ce93d8"}
      0x10: seq_numbers {label: "16B"; style.fill: "#90caf9"}
      0x20: windows {label: "8B"; style.fill: "#90caf9"}
      0x28: last_rx {label: "8B"; style.fill: "#90caf9"}
      0x30: padding {label: "16B"; style.fill: "#eeeeee"}
    }

    per_core_stats: {
      label: "Per-Core Counters"
      shape: rectangle
      style.fill: "#a5d6a7"
    }
  }

  l2_cache: L2 Unified Cache (256KB) {
    tooltip: "Latency: ~12ns (12-14 cycles)"
    style: {
      stroke-dash: 5
      fill: "#e3f2fd"
    }

    active_buffers: {
      label: "Active Packet Buffers (Mbufs)"
      shape: sql_table
      0x00: metadata_hdr {label: "64B"; style.fill: "#ce93d8"}
      0x40: eth_ip_headers {label: "40B"; style.fill: "#90caf9"}
      0x68: payload_start {label: "N bytes"; style.fill: "#90caf9"}
    }

    arp_cache_hot: {
      label: "Hot ARP Entries"
      shape: rectangle
      style.fill: "#ffcc80"
    }
  }
}

l3_cache: L3 Shared Cache (16MB-32MB) {
  tooltip: "Latency: ~40ns (40-60 cycles)"
  style: {
    stroke-width: 2
    fill: "#fff3e0"
  }

  connection_table: {
    label: "Global Connection Table (10K Conns)"
    shape: sql_table
    0x00: hash_buckets {label: "128KB"; style.fill: "#ffcc80"}
    0x01: inactive_ccbs {label: "3.2MB"; style.fill: "#90caf9"}
  }

  routing_table: {
    label: "LPM Routing Table"
    shape: rectangle
    style.fill: "#90caf9"
  }

  histograms: {
    label: "Latency Histograms (All Cores)"
    shape: rectangle
    style.fill: "#a5d6a7"
  }
}

system_ram: System RAM (Hugepages) {
  tooltip: "Latency: ~100ns"
  style: {
    stroke-width: 4
    fill: "#e8f5e9"
  }

  buffer_pool: {
    label: "2MB/1GB Hugepage Memory Pool"
    shape: rectangle
    style.fill: "#a5d6a7"
  }

  cold_data: {
    label: "Cold Connections & PCAP Rings"
    shape: rectangle
    style.fill: "#eeeeee"
  }
}

nic_hardware: Network Interface Card {
  shape: cylinder
  style.fill: "#cfd8dc"
}

# Data Flow & Locality Mapping
nic_hardware -> system_ram.buffer_pool: "1. DMA Write (PCIe)" {
  style: {
    stroke: "#1976d2"
    stroke-width: 2
    animated: true
  }
}

cpu_core.l1_cache.rx_ring_indices -> nic_hardware: "2. Poll MMIO / Ring" {
  style: {
    stroke: "#7b1fa2"
    stroke-dash: 3
  }
}

system_ram.buffer_pool -> l3_cache: "3. Cache Populate" {
  style.stroke: "#43a047"
}

l3_cache -> cpu_core.l2_cache: "4. HW Prefetch" {
  style.stroke: "#43a047"
}

cpu_core.l2_cache -> cpu_core.l1_cache: "5. Process (L1 Hit)" {
  style: {
    stroke: "#7b1fa2"
    stroke-width: 3
  }
}

# Annotations
legend: {
  near: bottom-right
  header: Header/Metadata { style.fill: "#ce93d8" }
  data: Payload/Segment { style.fill: "#90caf9" }
  free: Memory/Pools { style.fill: "#a5d6a7" }
  padding: Alignment/Reserved { style.fill: "#eeeeee" }
  pointers: State/Lookups { style.fill: "#ffcc80" }
}

note: |md
  ### Cache Locality Invariants
  1. **Hot Path Zero-Copy**: Data stays in RAM while descriptors cycle L1.
  2. **Prefetch Distance**: SW Prefetch (T0) must be 2 packets ahead.
  3. **CCB Alignment**: `tcp_conn` hot fields must fit in CL 0 & 1.
  4. **NUMA Affinity**: CPU Core and NIC must share NUMA node to avoid 150ns interconnect penalty.
| {
  near: bottom-left
}