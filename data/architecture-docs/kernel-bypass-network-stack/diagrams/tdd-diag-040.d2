direction: right
layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- STYLING CLASSES (Intel/Manual Quality Spec) ---
classes: {
  header_purple: {
    style: {
      fill: "#f3e5f5"
      stroke: "#6f42c1"
      stroke-width: 3
      font-color: "#6f42c1"
      bold: true
    }
  }
  data_blue: {
    style: {
      fill: "#e3f2fd"
      stroke: "#007bff"
      font-color: "#007bff"
    }
  }
  free_green: {
    style: {
      fill: "#e8f5e9"
      stroke: "#28a745"
      font-color: "#28a745"
    }
  }
  padding_gray: {
    style: {
      fill: "#f8f9fa"
      stroke: "#6c757d"
      font-color: "#6c757d"
      stroke-dash: 3
    }
  }
  pointer_orange: {
    style: {
      fill: "#fff3e0"
      stroke: "#fd7e14"
      font-color: "#d35400"
    }
  }
}

# --- PROCESSOR ARCHITECTURE & MEMORY LAYOUT ---
# CORRECTED: Parent is a generic container to allow nesting complex shapes
kbns_m5_processor: "Adaptive Batch Processor (kbns-m5)" {
  tooltip: "Core kernel-bypass batching logic. Designed for cache-line alignment."
  style: {
    fill: "#ffffff"
    stroke: "#212529"
    stroke-width: 2
  }
  
  # Memory Layout Specification
  memory_layout: "Cache-Line 0 (Offsets 0x00-0x3F)" {
    shape: sql_table
    style.stroke: "#6f42c1"
    style.stroke-width: 2

    # Offset | Field Descriptor | Size
    hdr: "Offset | Field Identifier" { 
      constraint: "Size"
    }
    hdr.class: header_purple

    mode: "0x00 | mode: batch_mode_t" { constraint: "4B" }
    mode.class: data_blue

    c_size: "0x04 | current_size: uint32_t" { constraint: "4B" }
    c_size.class: data_blue

    timeout: "0x08 | timeout_ns: uint64_t" { constraint: "8B" }
    timeout.class: data_blue

    doorbell: "0x10 | *doorbell_addr: uintptr_t" { constraint: "8B" }
    doorbell.class: pointer_orange

    stats: "0x18 | stats_counter: uint64_t" { constraint: "8B" }
    stats.class: data_blue

    boundary: "0x20 | --- 64B CACHE LINE BOUNDARY ---" { constraint: "DASHED" }
    boundary.class: padding_gray

    pad: "0x20 | reserved_padding" { constraint: "32B" }
    pad.class: padding_gray
  }

  # CORRECTED: Class applied only to the methods interface
  interface: "Kernel Interface" {
    shape: class
    style.fill: "#f8f9fa"
    
    "process_batch(uintptr_t* ptrs, size_t count)": "void"
    "update_optimal_n(latency_stats_t stats)": "uint32_t"
  }
  
  label: |'md
    **kbns-m5 Stack Controller**
    `sizeof=64 bytes`
    `alignment=64`
  '|
}

# --- PERFORMANCE ANALYSIS CORE ---
batch_tradeoff: "Batch Size vs. Latency Performance Analysis" {
  style: {
    stroke-width: 2
    fill: "#ffffff"
    double-border: true
  }

  # Simulation of Axis using shapes
  y_axis: "Latency (μs)" {
    height: 300
    width: 15
    style: {
      stroke: "#212529"
      fill: "#212529"
    }
  }

  x_axis: "Batch Size (N)" {
    height: 15
    width: 600
    style: {
      stroke: "#212529"
      fill: "#212529"
    }
  }

  # Analytical Curves
  overhead_curve: "Amortized Fixed Costs" {
    tooltip: "Amortized MMIO and Context Switch costs."
    style: {
      stroke: "#6f42c1"
      stroke-width: 4
      stroke-dash: 5
    }
    label: |'md
      **Amortized Costs:**
      `O(1/N)`
    '|
  }

  wait_curve: "Wait/Queuing Latency" {
    tooltip: "Wait time for batch accumulation."
    style: {
      stroke: "#007bff"
      stroke-width: 4
      stroke-dash: 2
    }
    label: |'md
      **Wait Latency:**
      `O(N)`
    '|
  }

  total_curve: "**TOTAL E2E LATENCY**" {
    style: {
      stroke: "#dc3545"
      stroke-width: 6
      shadow: true
    }
  }

  optimal_point: "SWEET SPOT" {
    shape: diamond
    style: {
      fill: "#ffc107"
      stroke: "#212529"
      stroke-width: 3
    }
  }

  # Operational Zones
  zones: {
    small_batch: "Under-utilization" {
      style: {
        fill: "#f8d7da"
        stroke: "#f5c6cb"
        stroke-dash: 3
        opacity: 0.4
      }
    }
    large_batch: "High Jitter" {
      style: {
        fill: "#fff3cd"
        stroke: "#ffeeba"
        stroke-dash: 3
        opacity: 0.4
      }
    }
  }

  # Logic Flows
  zones.small_batch -> overhead_curve: "High MMIO/pkt"
  zones.large_batch -> wait_curve: "Queuing Delay"
  
  optimal_point -> total_curve: "Min(L)" {
    style.animated: true
    style.stroke: "#28a745"
  }

  # Detailed analytical breakdown
  analysis: |'md
    ### Numerical Performance Budget (Target < 2μs)
    
    | Batch Size (N) | Wait (ns) | Overhead (ns) | Total (ns) |
    | :--- | :--- | :--- | :--- |
    | **1 (Poll)** | 0 | 250 | 250 |
    | **8** | 400 | 31 | 431 |
    | **32 (Opt)** | 1600 | 8 | **1608** |
    | **64** | 3200 | 4 | 3204 |
    
    **Derivation:** $L_{total} = \frac{C_{fixed}}{N} + \frac{(N-1)}{2R}$
  '| 
}

# --- EXTERNAL RELATIONSHIPS ---
kbns_m5_processor -> batch_tradeoff: "Tuning N" {
  style: {
    stroke-dash: 5
    stroke: "#fd7e14"
    stroke-width: 2
  }
}

# Positioning
batch_tradeoff.analysis.near: batch_tradeoff.x_axis

# --- LEGEND ---
legend: "Performance Metric Legend" {
  near: bottom-center
  style.fill: "#f8f9fa"
  
  def1: "Fixed Overhead (MMIO)" {
    style.fill: "#6f42c1"
    style.stroke: "#6f42c1"
  }
  def2: "Wait Time (Linear)" {
    style.fill: "#007bff"
    style.stroke: "#007bff"
  }
  def3: "Total E2E Latency" {
    style.fill: "#dc3545"
    style.stroke: "#dc3545"
    style.bold: true
  }
  def4: "Pointer Field (64-bit)" {
    style.fill: "#fff3e0"
    style.stroke: "#fd7e14"
  }
}