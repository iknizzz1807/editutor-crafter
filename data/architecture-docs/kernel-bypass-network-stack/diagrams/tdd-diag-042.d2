  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 20
  }
  colors: {
    header: "#7c3aed"
    data: "#2563eb"
    free: "#16a34a"
    padding: "#94a3b8"
    pointer: "#ea580c"
    hot_path: "#dc2626"
      hot_path: "#607D8B"
