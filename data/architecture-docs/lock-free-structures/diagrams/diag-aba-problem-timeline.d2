direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # ABA Problem Timeline
  **The CAS Window of Vulnerability**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  threadA: {
    direction: down
    label: "Thread A"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    t1: {
      label: "T1: Load top"
      width: 200
      code: |'c
        old_top = atomic_load(&top);
        // old_top = P
      '|
    }
    t2: {
      label: "T2: Read next"
      width: 200
      code: |'c
        new_top = old_top->next;
        // new_top = Q
      '|
    }
    t3: {
      label: "**PREEMPTED**"
      width: 200
      style.fill: "#FFCDD2"
      code: |'c
        // Thread descheduled
        // ...waiting...
      '|
    }
    t4: {
      label: "T7: CAS succeeds"
      width: 200
      style.fill: "#C8E6C9"
      code: |'c
        CAS(&top, P, Q)
        // SUCCESS! (P matches)
        // But Q was freed!
      '|
    }
  }
  threadB: {
    direction: down
    label: "Thread B"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    tb1: {
      label: "T3: Pop P"
      width: 200
      code: |'c
        pop() succeeds
        // top = Q
        // P removed
      '|
    }
    tb2: {
      label: "T4: Pop Q"
      width: 200
      code: |'c
        pop() succeeds
        // top = R
        // Q removed
      '|
    }
    tb3: {
      label: "T5: Free P, Q"
      width: 200
      style.fill: "#FFCDD2"
      code: |'c
        free(P);
        free(Q);
        // Memory recycled
      '|
    }
    tb4: {
      label: "T6: Push P'"
      width: 200
      style.fill: "#FFCDD2"
      code: |'c
        new_node = malloc();
        // Allocator returns
        // address of P!
        push(new_node);
      '|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memInitial: {
    label: "Memory State: Initial (T0)"
    direction: down
    style.fill: "#F5F5F5"
    stackInit: {
      shape: sql_table
      label: "Stack Structure"
      top_ptr: "top | Node* | → P"
    }
    nodeP: {
      shape: class
      label: "Node P @ 0x1000"
      value: "int64_t"
      next: "Node* → Q"
    }
    nodeQ: {
      shape: class
      label: "Node Q @ 0x2000"
      value: "int64_t"
      next: "Node* → R"
    }
    nodeR: {
      shape: class
      label: "Node R @ 0x3000"
      value: "int64_t"
      next: "Node* → NULL"
    }
  }
  memVuln: {
    label: "Memory State: Vulnerable (T5)"
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    vulnNote: {
      label: "⚠️ WINDOW OF VULNERABILITY"
      width: 300
      style.fill: "#FFCDD2"
      style.font-color: "#B71C1C"
    }
    stackVuln: {
      shape: sql_table
      label: "Stack Structure"
      top_ptr: "top | Node* | → R"
    }
    freedP: {
      shape: class
      label: "Node P @ 0x1000"
      style.fill: "#FFCDD2"
      value: "int64_t | FREED"
      next: "Node* | GARBAGE"
    }
    freedQ: {
      shape: class
      label: "Node Q @ 0x2000"
      style.fill: "#FFCDD2"
      value: "int64_t | FREED"
      next: "Node* | GARBAGE"
    }
    nodeRV: {
      shape: class
      label: "Node R @ 0x3000"
      value: "int64_t"
      next: "Node* → NULL"
    }
  }
  memFinal: {
    label: "Memory State: Corrupted (T7)"
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    corruptNote: {
      label: "☠️ CORRUPTION: top → FREED MEMORY"
      width: 300
      style.fill: "#FFCDD2"
      style.font-color: "#B71C1C"
    }
    stackCorrupt: {
      shape: sql_table
      label: "Stack Structure"
      top_ptr: "top | Node* | → Q (FREED!)"
    }
    recycledP: {
      shape: class
      label: "Node P' @ 0x1000"
      style.fill: "#E1BEE7"
      value: "int64_t | NEW DATA"
      next: "Node* → NULL"
    }
    freedQF: {
      shape: class
      label: "Node Q @ 0x2000"
      style.fill: "#FFCDD2"
      value: "int64_t | FREED"
      next: "Node* | GARBAGE"
    }
    nodeRF: {
      shape: class
      label: "Node R @ 0x3000"
      value: "int64_t"
      next: "Node* → NULL"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  flowArrows: {
    direction: down
    label: ""
    style.fill: transparent
    style.stroke: transparent
    arrow1: {
      label: ""
      width: 1
      height: 1
    }
  }
  timeline: {
    direction: right
    label: "Timeline of Events"
    style.fill: "#ECEFF1"
    step1: "T0\nInitial\nState" {shape: circle}
    step2: "T1-T2\nA loads\nP, Q" {shape: circle}
    step3: "T3\nB pops\nP" {shape: circle}
    step4: "T4\nB pops\nQ" {shape: circle}
    step5: "T5\nB frees\nP, Q" {shape: circle; style.fill: "#FFCDD2"}
    step6: "T6\nB pushes\nP' @ 0x1000" {shape: circle; style.fill: "#E1BEE7"}
    step7: "T7\nA CAS\nsucceeds!" {shape: circle; style.fill: "#FFCDD2"}
    step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> step7
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  casAnalysis: {
    label: "Why CAS Succeeds Incorrectly"
    width: 400
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    analysis: |md
      ## The Fatal Assumption
      Thread A's CAS only compares **address equality**:
      
      CAS(&top, expected=P, desired=Q)
      if (top == P) {   // ✓ TRUE (P' is at 0x1000)
        top = Q;        // top now points to FREED memory!
        return SUCCESS;
      }
      
      **The problem**: P and P' have the same address but represent
      completely different logical nodes. CAS cannot distinguish them.
      **The consequence**: `top` now points to Q, which was freed.
      Any subsequent pop() dereferences freed memory → use-after-free.
    |
  }
  solution: {
    label: "Solution: Tagged Pointers"
    width: 400
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    taggedLayout: {
      shape: sql_table
      label: "TaggedPtr (16 bytes)"
      version: "0x00 | uint64_t | version counter"
      ptr: "0x08 | Node*   | pointer to node"
      total: "CAS compares BOTH fields"
    }
    whyWorks: |md
      ## Version Counter Prevents ABA
      With tagged pointers, each modification increments
      the version counter. Thread A's CAS becomes:
      
      CAS(&top, 
          expected={v:0, ptr:P},
          desired={v:1, ptr:Q})
      Current top is {v:3, ptr:P'}
      // v:0 ≠ v:3 → CAS FAILS!
      
      The version mismatch detects that P was recycled.
      Thread A retries with correct state.
    |
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  l1: "Initial State" {style.fill: "#F5F5F5"}
  l2: "Thread A" {style.fill: "#E8F4FD"}
  l3: "Thread B" {style.fill: "#FFF3E0"}
  l4: "Freed/Danger" {style.fill: "#FFCDD2"}
  l5: "Recycled Node" {style.fill: "#E1BEE7"}
  l6: "Success (Misleading)" {style.fill: "#C8E6C9"}
}
threadA.t1 -> threadB.tb1: "A preempted\nbefore CAS" {style.stroke-dash: 4; style.stroke: "#F44336"}
threadA.t3 -> threadA.t4: "A resumes\nwindow closes" {style.stroke: "#4CAF50"; style.animated: true}
threadB.tb3 -> threadB.tb4: "Allocator\nrecycles P" {style.stroke: "#9C27B0"; style.stroke-dash: 3}