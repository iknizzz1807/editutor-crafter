direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  near: top-center
  label: |'md
    # Incremental Bucket Splitting
    ## Split-Ordered List Hash Map Resize
  '|
}

row_before: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  before: {
    direction: down
    label: "BEFORE: N Buckets"
    
    bucket_array_before: {
      direction: right
      label: "Bucket Array (size=4)"
      style.fill: "#E8F4FD"
      style.stroke: "#2E86AB"
      b0_before: {
        label: "Bucket 0"
        style.fill: "#B8D4E8"
        idx: "index: 0"
      }
      b1_before: {
        label: "Bucket 1"
        style.fill: "#B8D4E8"
        idx: "index: 1"
      }
      b2_before: {
        label: "Bucket 2"
        style.fill: "#B8D4E8"
        idx: "index: 2"
      }
      b3_before: {
        label: "Bucket 3"
        style.fill: "#B8D4E8"
        idx: "index: 3"
      }
    }
    
    list_before: {
      direction: right
      label: "Split-Ordered List"
      style.fill: "#FFF9E6"
      style.stroke: "#E6A800"
      head_before: {
        label: "HEAD"
        shape: circle
        style.fill: "#FFE066"
      }
      s0_before: {
        label: "S0\nso_key=0"
        shape: hexagon
        style.fill: "#90EE90"
      }
      k4_before: {
        label: "K4\nso_key=4"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      k8_before: {
        label: "K8\nso_key=8"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      s2_before: {
        label: "S2\nso_key=2"
        shape: hexagon
        style.fill: "#90EE90"
      }
      k10_before: {
        label: "K10\nso_key=10"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      s1_before: {
        label: "S1\nso_key=1"
        shape: hexagon
        style.fill: "#90EE90"
      }
      k9_before: {
        label: "K9\nso_key=9"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      s3_before: {
        label: "S3\nso_key=3"
        shape: hexagon
        style.fill: "#90EE90"
      }
      null_before: {
        label: "NULL"
        shape: circle
        style.fill: "#D3D3D3"
      }
      head_before -> s0_before -> k4_before -> k8_before -> s2_before -> k10_before -> s1_before -> k9_before -> s3_before -> null_before
    }
    
    bucket_array_before.b0_before -> list_before.s0_before: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
    bucket_array_before.b1_before -> list_before.s1_before: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
    bucket_array_before.b2_before -> list_before.s2_before: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
    bucket_array_before.b3_before -> list_before.s3_before: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
  }
}

invariant_box: {
  label: "Reverse-Bit Invariant"
  style.fill: "#FFE4E1"
  style.stroke: "#DC143C"
  width: 600
  inv_code: |'c
    // Bucket split preserves list order
    // because reverse-bit ordering groups elements:
    //
    // Bucket 0: so_keys 0, 4, 8, 12, ... (contiguous!)
    // Bucket 4: so_keys 4, 12, 20, ... (subset of bucket 0)
    //
    // When bucket 0 splits into 0 and 4:
    // - Bucket 0 keeps: 0, 8, 16, 24, ...
    // - Bucket 4 gets:  4, 12, 20, 28, ...
    // Both groups are CONTIGUOUS in the sorted list!
  '|
}

row_after: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  after: {
    direction: down
    label: "AFTER: 2N Buckets"
    
    bucket_array_after: {
      direction: right
      label: "Bucket Array (size=8)"
      style.fill: "#E8F4FD"
      style.stroke: "#2E86AB"
      b0_after: {
        label: "Bucket 0"
        style.fill: "#B8D4E8"
      }
      b4_new: {
        label: "Bucket 4"
        style.fill: "#FFB6C1"
        style.stroke: "#FF1493"
        style.stroke-width: 3
      }
      b1_after: {
        label: "Bucket 1"
        style.fill: "#B8D4E8"
      }
      b5_new: {
        label: "Bucket 5"
        style.fill: "#FFB6C1"
        style.stroke: "#FF1493"
        style.stroke-width: 3
      }
      b2_after: {
        label: "Bucket 2"
        style.fill: "#B8D4E8"
      }
      b6_new: {
        label: "Bucket 6"
        style.fill: "#FFB6C1"
        style.stroke: "#FF1493"
        style.stroke-width: 3
      }
      b3_after: {
        label: "Bucket 3"
        style.fill: "#B8D4E8"
      }
      b7_new: {
        label: "Bucket 7"
        style.fill: "#FFB6C1"
        style.stroke: "#FF1493"
        style.stroke-width: 3
      }
    }
    
    list_after: {
      direction: right
      label: "Split-Ordered List (SAME NODES, NEW SENTINELS)"
      style.fill: "#FFF9E6"
      style.stroke: "#E6A800"
      head_after: {
        label: "HEAD"
        shape: circle
        style.fill: "#FFE066"
      }
      s0_after: {
        label: "S0"
        shape: hexagon
        style.fill: "#90EE90"
      }
      s4_new: {
        label: "S4\n(NEW)"
        shape: hexagon
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.stroke-width: 2
      }
      k4_after: {
        label: "K4"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      k8_after: {
        label: "K8"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      s2_after: {
        label: "S2"
        shape: hexagon
        style.fill: "#90EE90"
      }
      s6_new: {
        label: "S6\n(NEW)"
        shape: hexagon
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.stroke-width: 2
      }
      k10_after: {
        label: "K10"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      s1_after: {
        label: "S1"
        shape: hexagon
        style.fill: "#90EE90"
      }
      s5_new: {
        label: "S5\n(NEW)"
        shape: hexagon
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.stroke-width: 2
      }
      k9_after: {
        label: "K9"
        shape: rectangle
        style.fill: "#DDA0DD"
      }
      s3_after: {
        label: "S3"
        shape: hexagon
        style.fill: "#90EE90"
      }
      s7_new: {
        label: "S7\n(NEW)"
        shape: hexagon
        style.fill: "#FF6B6B"
        style.stroke: "#CC0000"
        style.stroke-width: 2
      }
      null_after: {
        label: "NULL"
        shape: circle
        style.fill: "#D3D3D3"
      }
      head_after -> s0_after -> s4_new -> k4_after -> k8_after -> s2_after -> s6_new -> k10_after -> s1_after -> s5_new -> k9_after -> s3_after -> s7_new -> null_after
    }
    
    bucket_array_after.b0_after -> list_after.s0_after: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
    bucket_array_after.b4_new -> list_after.s4_new: "NEW" {
      style.stroke: "#FF1493"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
    bucket_array_after.b1_after -> list_after.s1_after: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
    bucket_array_after.b5_new -> list_after.s5_new: "NEW" {
      style.stroke: "#FF1493"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
    bucket_array_after.b2_after -> list_after.s2_after: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
    bucket_array_after.b6_new -> list_after.s6_new: "NEW" {
      style.stroke: "#FF1493"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
    bucket_array_after.b3_after -> list_after.s3_after: "ptr" {
      style.stroke: "#2E86AB"
      style.stroke-width: 2
    }
    bucket_array_after.b7_new -> list_after.s7_new: "NEW" {
      style.stroke: "#FF1493"
      style.stroke-width: 3
      style.stroke-dash: 4
    }
  }
}

parent_box: {
  label: "Parent Bucket Relationship"
  style.fill: "#E6FFE6"
  style.stroke: "#228B22"
  width: 600
  parent_code: |'c
    // parent = bucket & (bucket - 1)  // Clear lowest set bit
    //
    // Bucket 4's parent = 4 & 3 = 0  → S4 inserted after S0
    // Bucket 5's parent = 5 & 4 = 4  → S5 inserted after S4
    //
    // Initialization is RECURSIVE: ensure parent exists first
  '|
}

key_box: {
  label: "Key"
  style.fill: "#F0F0F0"
  style.stroke: "#666"
  legend: |'md
    **S0, S1, ...** = Sentinel nodes (bucket markers)
    **K4, K8, ...** = Data nodes (key-value pairs)
    **so_key** = reverse_bits(hash) | REGULAR_BIT
    **RED sentinels** = Newly inserted during resize
    **Data nodes NEVER move** — only sentinels are added
  '|
}

resize_arrow: {
  label: "RESIZE\nN → 2N"
  shape: diamond
  style.fill: "#FFD700"
  style.stroke: "#B8860B"
  style.stroke-width: 3
}

row_before.before -> resize_arrow: "trigger resize" {
  style.stroke: "#B8860B"
  style.stroke-width: 2
  style.stroke-dash: 5
}
resize_arrow -> row_after.after: "lazy init" {
  style.stroke: "#B8860B"
  style.stroke-width: 2
  style.stroke-dash: 5
}