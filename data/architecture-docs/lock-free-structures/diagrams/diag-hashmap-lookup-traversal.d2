direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Visual Styles and Classes
classes: {
  container: {
    style: {
      fill: "#F8F9FA"
      stroke: "#DEE2E6"
      stroke-width: 2
      border-radius: 8
    }
  }
  bucket: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  sentinel: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
  }
  datanode: {
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
}

title: {
  label: "Lock-free Split-Ordered Hash Map: Lookup Traversal"
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

lookup_info: {
  label: "Lookup Protocol"
  note: "1. Hash key to index | 2. Load sentinel | 3. Traverse by so_key | 4. Compare key | 5. Stop if next is Sentinel"
  shape: rectangle
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    stroke-dash: 3
  }
}
lookup_info.near: top-right

# ROW 1: Memory Structures
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  bucket_array: {
    shape: sql_table
    label: "Bucket Array (lf_hashmap.c)"
    class: container
    b0: "0x00 | void* | bucket_0 (Sentinel 0)"
    b1: "0x08 | void* | bucket_1 (Sentinel 1)"
    b2: "0x10 | void* | bucket_2 (Sentinel 2)"
    bn: "0x.. | void* | bucket_n"
    
    style.stroke: "#1976D2"
  }

  linked_list: {
    label: "Split-Ordered List (Memory View)"
    class: container
    direction: down

    sentinel_0: {
      shape: sql_table
      label: "Sentinel 0 (Bucket 0 Marker)"
      class: sentinel
      f0: "0x00 | uint64_t | so_key = rev(0)"
      f1: "0x08 | node_t*  | next -> sentinel_1"
    }

    sentinel_1: {
      shape: sql_table
      label: "Sentinel 1 (Bucket 1 Marker)"
      class: sentinel
      f0: "0x00 | uint64_t | so_key = rev(1)"
      f1: "0x08 | node_t*  | next -> node_a"
      style.stroke-width: 4
    }

    node_a: {
      shape: sql_table
      label: "Node A (Data)"
      class: datanode
      f0: "0x00 | uint64_t | so_key = rev(17) | MSB"
      f1: "0x08 | void*    | key = 17"
      f2: "0x10 | void*    | value"
      f3: "0x18 | node_t*  | next -> node_b"
    }

    node_b: {
      shape: sql_table
      label: "Node B (TARGET)"
      class: datanode
      f0: "0x00 | uint64_t | so_key = rev(33) | MSB"
      f1: "0x08 | void*    | key = 33"
      f2: "0x10 | void*    | value"
      f3: "0x18 | node_t*  | next -> sentinel_2"
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }

    sentinel_2: {
      shape: sql_table
      label: "Sentinel 2 (Bucket 2 Marker)"
      class: sentinel
      f0: "0x00 | uint64_t | so_key = rev(2)"
      f1: "0x08 | node_t*  | next -> ..."
    }
  }
}

# ROW 2: Implementation Logic
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  trace: {
    label: "Lookup Implementation (Hazard Pointer Protected)"
    class: container
    direction: right
    
    step1: {
      label: "T1: Find Entry Point"
      code: |'c
        uint64_t b_idx = hash % size;
        node_t* s = get_bucket(map, b_idx);
        hp_protect(HP_PREV, s);
      '|
    }

    step2: {
      label: "T2: Pointer Chasing"
      code: |'c
        while (curr != NULL) {
          node_t* next = hp_load(&curr->next);
          if (next->so_key > target) return NULL;
          if (next->so_key == target) break;
          curr = next;
        }
      '|
    }

    step3: {
      label: "T3: Validation"
      code: |'c
        if (next && key_eq(next->key, k)) {
          void* val = next->value;
          hp_release_all();
          return val;
        }
      '|
    }
  }
}

# Connections
row1.bucket_array -> row1.linked_list.sentinel_1: "0x08 | entry" {
  style.stroke: "#1976D2"
  style.stroke-width: 3
}

row1.linked_list.sentinel_0 -> row1.linked_list.sentinel_1: "next"
row1.linked_list.sentinel_1 -> row1.linked_list.node_a: "① traverse" {
  style.stroke: "#388E3C"
  style.animated: true
}
row1.linked_list.node_a -> row1.linked_list.node_b: "② traverse" {
  style.stroke: "#388E3C"
  style.animated: true
}
row1.linked_list.node_b -> row1.linked_list.sentinel_2: "③ stop (Sentinel)" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 3
}

row2.trace.step1 -> row2.trace.step2 -> row2.trace.step3: "Logic Flow"

# Status Indicators
find_result: {
  label: "MATCH FOUND"
  shape: callout
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    font-color: "#1B5E20"
    bold: true
  }
}

# Link callout to target without using relative near
find_result -> row1.linked_list.node_b: "key matches" {
  style.stroke: "#2E7D32"
}

# Legend
legend: {
  shape: rectangle
  label: "Diagram Legend"
  s: "Sentinel Node (Bucket Marker)" {
    class: sentinel
  }
  d: "Data Node (Key-Value)" {
    class: datanode
  }
  style.fill: "#F1F3F4"
}
legend.near: bottom-right