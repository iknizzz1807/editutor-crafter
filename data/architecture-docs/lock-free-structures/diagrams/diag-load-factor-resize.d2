direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Load Factor Monitoring & Resize State Machine {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
states: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  normal: {
    shape: oval
    label: "NORMAL\nOPERATION"
    style: {
      fill: "#ACE1AF"
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }
  threshold: {
    shape: diamond
    label: "Load Factor\n> 2.0?"
    style: {
      fill: "#FFF9C4"
      stroke: "#F57F17"
      stroke-width: 2
    }
  }
  resizing: {
    shape: hexagon
    label: "INCREMENTAL\nRESIZE"
    style: {
      fill: "#FFCCBC"
      stroke: "#D84315"
      stroke-width: 3
    }
  }
  complete: {
    shape: oval
    label: "RESIZE\nCOMPLETE"
    style: {
      fill: "#B3E5FC"
      stroke: "#0277BD"
      stroke-width: 3
    }
  }
}
normal -> threshold: "After each\ninsert" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
threshold -> resizing: "YES\nTrigger resize" {
  style.stroke: "#D84315"
  style.stroke-width: 3
  style.animated: true
}
threshold -> normal: "NO\nContinue" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
resizing -> complete: "All buckets\ninitialized" {
  style.stroke: "#0277BD"
  style.stroke-width: 2
}
complete -> normal: "Resume\nnormal ops" {
  style.stroke: "#0277BD"
  style.stroke-dash: 3
}
resizing -> resizing: "Initialize next\nbucket on access" {
  style.stroke: "#D84315"
  style.stroke-dash: 4
}
annotations: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  normal_ops: {
    label: "NORMAL PHASE"
    style.fill: "#ACE1AF"
    style.stroke: "#2E7D32"
    width: 280
    ops: |'c
      insert() → O(1) avg
      lookup() → O(1) avg
      delete() → O(1) avg
      Bucket access:
        bucket = hash % bucket_count
        sentinel = buckets[bucket]
        traverse from sentinel
    '|
  }
  resize_ops: {
    label: "RESIZE PHASE"
    style.fill: "#FFCCBC"
    style.stroke: "#D84315"
    width: 280
    ops: |'c
      insert() → May init bucket
      lookup() → May init bucket
      delete() → May init bucket
      On-demand init:
        if bucket sentinel == NULL:
          init_bucket(b) // lazy
          // inserts sentinel into
          // split-ordered list
    '|
  }
  complete_ops: {
    label: "POST-RESIZE"
    style.fill: "#B3E5FC"
    style.stroke: "#0277BD"
    width: 280
    ops: |'c
      All buckets initialized
      bucket_count = 2 * old_count
      No rehashing needed!
      Elements already in
      correct positions due to
      reverse-bit ordering
    '|
  }
}
states.normal -> annotations.normal_ops: "Behavior" {
  style.stroke: "#666666"
  style.stroke-dash: 2
  style.opacity: 0.5
}
states.resizing -> annotations.resize_ops: "Behavior" {
  style.stroke: "#666666"
  style.stroke-dash: 2
  style.opacity: 0.5
}
states.complete -> annotations.complete_ops: "Behavior" {
  style.stroke: "#666666"
  style.stroke-dash: 2
  style.opacity: 0.5
}
load_factor_detail: {
  label: "Load Factor Calculation"
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    border-radius: 8
  }
  width: 320
  formula: |'c
    load_factor = element_count / bucket_count
    // Trigger resize when:
    if (load_factor > 2.0) {
      new_bucket_count = bucket_count * 2
      // Allocate new array
      // Lazy init on access
    }
    // Note: During resize, ops use
    // current bucket_count for modulo
    // New buckets init as needed
  '|
}
load_factor_detail.near: bottom-center
progression: {
  direction: right
  label: "Resize Progression Example"
  style: {
    fill: transparent
    stroke: "#9E9E9E"
    border-radius: 8
  }
  step1: {
    label: "Before\n16 buckets"
    style.fill: "#ACE1AF"
    bucket_array1: {
      shape: sql_table
      label: "Buckets[16]"
      b0: "0 | sentinel →"
      b1: "1 | sentinel →"
      dots1: "... | ..."
      b15: "15 | sentinel →"
    }
  }
  arrow1: {
    label: "Resize\nTriggered"
    shape: diamond
    style: {
      fill: "#FFF9C4"
      stroke: "#F57F17"
    }
  }
  step2: {
    label: "During\n32 buckets"
    style.fill: "#FFCCBC"
    bucket_array2: {
      shape: sql_table
      label: "Buckets[32]"
      b0: "0 | sentinel →"
      b1: "1 | sentinel →"
      dots2: "... | ..."
      b15: "15 | sentinel →"
      b16: "16 | NULL (lazy)"
      b17: "17 | NULL (lazy)"
      dots3: "... | ..."
      b31: "31 | NULL (lazy)"
    }
  }
  arrow2: {
    label: "All Init"
    shape: diamond
    style: {
      fill: "#FFF9C4"
      stroke: "#F57F17"
    }
  }
  step3: {
    label: "Complete\n32 buckets"
    style.fill: "#B3E5FC"
    bucket_array3: {
      shape: sql_table
      label: "Buckets[32]"
      b0c: "0 | sentinel →"
      b1c: "1 | sentinel →"
      dots4: "... | ..."
      b31c: "31 | sentinel →"
      note: "All sentinels initialized"
    }
  }
  step1 -> arrow1 -> step2 -> arrow2 -> step3
}
progression.near: bottom-center