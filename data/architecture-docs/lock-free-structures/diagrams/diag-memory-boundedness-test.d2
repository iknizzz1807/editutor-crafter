direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Memory Boundedness Under Load
  Hazard Pointer Reclamation Effect
| {
  near: top-center
  style.font-size: 24
}

row_graphs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  without_hp: {
    direction: down
    label: "Without Hazard Pointers (Memory Leak)"
    
    graph_area: {
      direction: right
      style.stroke: transparent
      
      y_axis: "Memory (MB)" {
        shape: text
        style.font-size: 14
        style.font-color: "#666666"
      }
      
      main_plot: {
        direction: down
        style.stroke: transparent
        
        plot_window: {
          style.stroke: "#666666"
          style.fill: transparent
          width: 380
          height: 250
          
          leak_curve: {
            width: 340
            height: 200
            style.stroke: "#DC3545"
            style.fill: "linear-gradient(to top, #DC3545, #FF6B6B)"
            style.opacity: 0.3
            style.stroke-width: 3
          }
        }
        
        x_axis: "Time (seconds)" {
          shape: text
          style.font-size: 14
          style.font-color: "#666666"
        }
      }
    }

    annotation_leak: {
      width: 400
      label: "Unbounded Growth"
      code: |'c
        // Every pop/dequeue leaks the node
        // No reclamation mechanism
        // Memory grows linearly with operations
        // Eventually exhausts available memory (OOM)
      '|
      style.fill: "#FFE5E5"
      style.stroke: "#DC3545"
      style.stroke-dash: 3
    }
  }

  with_hp: {
    direction: down
    label: "With Hazard Pointers (Safe Reclamation)"
    
    graph_area: {
      direction: right
      style.stroke: transparent
      
      y_axis: "Memory (MB)" {
        shape: text
        style.font-size: 14
        style.font-color: "#666666"
      }
      
      main_plot: {
        direction: down
        style.stroke: transparent
        
        plot_window: {
          style.stroke: "#666666"
          style.fill: transparent
          width: 380
          height: 250
          
          sawtooth_area: {
            width: 340
            height: 60
            style.stroke: "#28A745"
            style.fill: "linear-gradient(to top, #28A745, #90EE90)"
            style.opacity: 0.3
            style.stroke-width: 2
            
            threshold_line: {
              height: 1
              label: "Scan threshold"
              label.near: outside-top-right
              style.stroke: "#FFC107"
              style.stroke-dash: 5
            }
          }
          
          reclaim_event: "hazard_scan_and_reclaim()" {
            shape: text
            style.font-size: 11
            style.font-color: "#28A745"
            style.italic: true
          }
        }
        
        x_axis: "Time (seconds)" {
          shape: text
          style.font-size: 14
          style.font-color: "#666666"
        }
      }
    }

    annotation_reclaim: {
      width: 400
      label: "Bounded Sawtooth Pattern"
      code: |'c
        // Retirement list fills until threshold
        // Scan frees unprotected nodes
        // Memory oscillations are strictly bounded:
        // Bound = 2 × threads × hazard_slots × node_size
      '|
      style.fill: "#E8F5E9"
      style.stroke: "#28A745"
      style.stroke-dash: 3
    }
  }
}

row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  comparison: {
    direction: down
    label: "Memory Behavior Comparison"
    
    metrics_table: {
      shape: sql_table
      label: "Memory Metrics (16 threads, 1M ops/sec)"
      row1: "Metric          | Without HP      | With HP"
      row2: "Peak Memory     | Unbounded       | ~64 MB"
      row3: "Average Memory  | Linear Growth   | ~40 MB"
      row4: "Variance        | Increasing      | Stable Sawtooth"
      row5: "Upper Bound     | None            | 2 × T × S × N"
      row6: "Failure Mode    | OOM Crash       | Graceful Bounded"
    }

    formula_box: {
      label: "Bounded Memory Formula"
      width: 450
      code: |'c
        // Bound = (max_elements × sizeof(Node))
        //       + (2 × num_threads × slots_per_thread × sizeof(Node))
        //       + (num_threads × slots_per_thread × sizeof(void*))
        //
        // Example (16 threads, 2 slots, 24-byte nodes):
        //   Overhead ≈ 64 × 24 + 256 bytes = 1,792 bytes
      '|
      style.fill: "#F5F5F5"
      style.stroke: "#666666"
    }
  }

  lifecycle: {
    direction: down
    label: "Hazard Pointer Lifecycle"
    
    lifecycle_diagram: {
      direction: down
      phase1: {
        label: "1. Operations Generate Retired Nodes"
        code: |'c
          CAS(&prev->next, old_node, new_node);
          hazard_retire(old_node); // To local list
        '|
        width: 350
        style.fill: "#FFF3CD"
        style.stroke: "#FFC107"
      }
      phase2: {
        label: "2. Retirement List Threshold"
        code: |'c
          if (retire_list.count >= 2 * threads * slots) {
            hazard_scan_and_reclaim();
          }
        '|
        width: 350
        style.fill: "#FFF3CD"
        style.stroke: "#FFC107"
      }
      phase3: {
        label: "3. Scan & Reclaim"
        code: |'c
          // Snapshot all current hazard pointers
          // Free nodes not present in snapshot
          for (node in retire_list) {
            if (!is_protected(node)) free(node);
          }
        '|
        width: 350
        style.fill: "#D4EDDA"
        style.stroke: "#28A745"
      }
    }
    lifecycle_diagram.phase1 -> lifecycle_diagram.phase2: "accumulate"
    lifecycle_diagram.phase2 -> lifecycle_diagram.phase3: "threshold met"
    lifecycle_diagram.phase3 -> lifecycle_diagram.phase1: "cycle"
  }
}

legend: {
  near: bottom-center
  direction: right
  
  leak: {
    shape: rectangle
    width: 20; height: 10
    style.fill: "#DC3545"
  }
  leak_l: "Unbounded Leak" { shape: text }
  
  safe: {
    shape: rectangle
    width: 20; height: 10
    style.fill: "#28A745"
  }
  safe_l: "Bounded Reclamation" { shape: text }
  
  thresh: {
    shape: rectangle
    width: 20; height: 2
    style.stroke: "#FFC107"
    style.stroke-dash: 3
  }
  thresh_l: "Scan Threshold" { shape: text }
}

key_insight: {
  near: bottom-center
  width: 850
  label: "Key Insight: Deterministic Memory Safety"
  code: |'c
    // Hazard pointers achieve boundedness through threshold-triggered scans.
    // 1. Local retirement lists prevent global lock contention.
    // 2. O(1) amortized reclamation overhead.
    // 3. The sawtooth pattern ensures memory usage never exceeds the 
    //    configured capacity (2 * Threads * Slots).
    //
    // Safety is guaranteed because no node is ever freed while a
    // thread-local hazard pointer still references its address.
  '|
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
}