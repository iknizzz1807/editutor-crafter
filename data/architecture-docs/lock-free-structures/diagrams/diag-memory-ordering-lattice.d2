direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Memory Ordering Lattice (C11/C++11)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
lattice: {
  direction: down
  relaxed: {
    shape: rectangle
    label: "memory_order_relaxed"
    width: 400
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
    guarantee: {
      label: "Guarantees"
      shape: rectangle
      width: 380
      code: |'c
        • Atomicity only
        • No ordering constraints
        • No visibility guarantees
        • Compiler cannot eliminate
      '|
    }
    example: {
      label: "Use Case: Statistics Counter"
      shape: rectangle
      width: 380
      code: |'c
        atomic_int request_count;
        void handle_request(void) {
          // Just counting, no data dependency
          atomic_fetch_add_explicit(
            &request_count, 1,
            memory_order_relaxed
          );
        }
      '|
    }
    cost: "Cost: ~1x (no barrier)"
  }
  edge_relaxed_acquire: {
    shape: rectangle
    width: 350
    style: {
      fill: transparent
      stroke: transparent
    }
    label: |md
      ▼ **+Load-load/store ordering**
      ▼ **+Synchronizes-with release stores**
    |
  }
  acquire: {
    shape: rectangle
    label: "memory_order_acquire"
    width: 400
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
    guarantee: {
      label: "Guarantees"
      shape: rectangle
      width: 380
      code: |'c
        • No reads/writes AFTER this load
          can be reordered BEFORE it
        • Forms synchronizes-with with
          matching release store
        • Creates happens-before edge
      '|
    }
    example: {
      label: "Use Case: Reading Published Data"
      shape: rectangle
      width: 380
      code: |'c
        // Consumer waits for data
        while (atomic_load_explicit(
          &ready,
          memory_order_acquire) == 0) {
          spin();
        }
        // All writes before release
        // are now visible
        use(data);
      '|
    }
    cost: "Cost: ~2-5x (load barrier)"
  }
  edge_acquire_release: {
    shape: rectangle
    width: 350
    style: {
      fill: transparent
      stroke: transparent
    }
    label: |md
      ▼ **+Store-load ordering**
      ▼ **+Both acquire AND release semantics**
    |
  }
  acq_rel: {
    shape: rectangle
    label: "memory_order_acq_rel"
    width: 400
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
    guarantee: {
      label: "Guarantees"
      shape: rectangle
      width: 380
      code: |'c
        • Combines acquire + release
        • For read-modify-write ops only
        • No reads/writes after can move
          before (acquire)
        • No reads/writes before can move
          after (release)
      '|
    }
    example: {
      label: "Use Case: CAS Operations"
      shape: rectangle
      width: 380
      code: |'c
        // Atomic increment with data
        do {
          old = atomic_load(&counter);
          new = old + delta;
        } while (!atomic_compare_exchange_strong(
          &counter, &old, new,
          memory_order_acq_rel,
          memory_order_acquire
        ));
      '|
    }
    cost: "Cost: ~2-5x (full barrier)"
  }
  edge_acq_rel_seqcst: {
    shape: rectangle
    width: 350
    style: {
      fill: transparent
      stroke: transparent
    }
    label: |md
      ▼ **+Global total order**
      ▼ **+Single modification order**
      ▼ **+Sequential consistency**
    |
  }
  seq_cst: {
    shape: rectangle
    label: "memory_order_seq_cst"
    width: 400
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 3
    }
    guarantee: {
      label: "Guarantees"
      shape: rectangle
      width: 380
      code: |'c
        • All seq_cst ops have single
          global total order
        • All threads agree on order
        • Strongest guarantee
        • Default for atomic ops
      '|
    }
    example: {
      label: "Use Case: Spinlock / Flag"
      shape: rectangle
      width: 380
      code: |'c
        // Simple spinlock
        void lock(atomic_flag* f) {
          while (atomic_flag_test_and_set(
            f, memory_order_seq_cst)) {
            spin();
          }
        }
        // Ensures all threads see
        // same lock acquisition order
      '|
    }
    cost: "Cost: ~10-100x (full fence)"
  }
  relaxed -> edge_relaxed_acquire -> acquire -> edge_acquire_release -> acq_rel -> edge_acq_rel_seqcst -> seq_cst: {
    style: {
      stroke: "#666"
      stroke-width: 2
    }
  }
}
legend: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#CCC"
  }
  title: "Key Insight"
  content: |md
    **Weakest to Strongest**: Each level adds guarantees without removing previous ones.
    **Rule of Thumb**:
    - `relaxed`: Counters, statistics (no data dependency)
    - `acquire/release`: Producer-consumer, data publication
    - `acq_rel`: RMW operations that both read and publish
    - `seq_cst`: When you need a global order (locks, flags)
    **Default is seq_cst**: Use it unless profiling shows it's a bottleneck.
  |
}