direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # MESI Cache Coherence Protocol
  State Machine for Multi-Core Memory Consistency
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_M: {
    shape: circle
    label: "M"
    width: 120
    style: {
      fill: "#FF6B6B"
      stroke: "#C0392B"
      stroke-width: 3
      font-color: white
      bold: true
      font-size: 36
    }
    desc: "MODIFIED\n\n• Only valid copy\n• Memory stale\n• Can read/write"
  }
  state_E: {
    shape: circle
    label: "E"
    width: 120
    style: {
      fill: "#4ECDC4"
      stroke: "#16A085"
      stroke-width: 3
      font-color: white
      bold: true
      font-size: 36
    }
    desc: "EXCLUSIVE\n\n• Only valid copy\n• Memory current\n• Can read/write"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_S: {
    shape: circle
    label: "S"
    width: 120
    style: {
      fill: "#F7DC6F"
      stroke: "#F39C12"
      stroke-width: 3
      font-color: "#5D4E37"
      bold: true
      font-size: 36
    }
    desc: "SHARED\n\n• Multiple copies exist\n• Memory current\n• Can only read"
  }
  state_I: {
    shape: circle
    label: "I"
    width: 120
    style: {
      fill: "#BDC3C7"
      stroke: "#7F8C8D"
      stroke-width: 3
      font-color: white
      bold: true
      font-size: 36
    }
    desc: "INVALID\n\n• No valid data\n• Must fetch on access\n• Default state"
  }
}
legend: {
  near: top-right
  label: "Legend"
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.stroke-width: 2
  bus_msg: "BusRd / BusRdX" {
    style.fill: "#E8F4FD"
    style.stroke: "#3498DB"
    shape: rectangle
  }
  local: "Local CPU Op" {
    style.fill: "#E8F8E8"
    style.stroke: "#27AE60"
    shape: rectangle
  }
  snoop: "Snoop Response" {
    style.fill: "#FFF3E0"
    style.stroke: "#E67E22"
    shape: rectangle
  }
}
transitions: {
  label: "State Transitions"
  style.fill: white
  style.stroke: "#34495E"
  style.stroke-width: 2
  t_IM_read: |md
    **I → M (Read Miss → Write)**
    
    CPU Read → BusRd
    If no other shares: I → E → M (on write)
    If other shares: I → S
    
  |
  t_IM_write: |md
    **I → M (Write Miss)**
    
    CPU Write → BusRdX
    Others invalidate → I
    This core → M
    
  |
  t_EM: |md
    **E → M (Write Hit)**
    
    CPU Write → No bus msg
    Silent upgrade: E → M
    ~10 cycles (local)
    
  |
  t_SM: |md
    **S → M (Write to Shared)**
    
    CPU Write → BusUpgr
    All other S → I
    This core → M
    ~100-300 cycles
    
  |
  t_ES: |md
    **E → S (Other Reads)**
    
    Snoop BusRd → Share signal
    E → S (give up exclusivity)
    
  |
  t_MS: |md
    **M → S (Other Reads)**
    
    Snoop BusRd → Writeback + Share
    Flush M data to memory
    M → S
    
  |
  t_MI: |md
    **M → I (Other Writes)**
    
    Snoop BusRdX → Writeback
    Flush data, invalidate self
    
  |
  t_SI: |md
    **S → I (Other Writes)**
    
    Snoop BusRdX → Invalidate
    Silent: just drop copy
    
  |
}
ordering_box: {
  label: "Memory Ordering Implications"
  style.fill: "#F0F4F8"
  style.stroke: "#2C3E50"
  style.stroke-width: 2
  ordering_content: |md
    **Why MESI Matters for Lock-Free Code:**
    1. **Write Visibility**
       - Store sits in store buffer ~50 cycles
       - `memory_order_release` drains buffer
       - Other cores see write after MESI propagation
    2. **Read Latency Varies**
       - L1 hit (M/E/S): ~3 cycles
       - L3 hit: ~40 cycles  
       - Remote M state: ~100+ cycles (cache-to-cache)
    3. **Atomic Operation Cost**
       - `fetch_add` on M line: ~10 cycles
       - `fetch_add` on S line: ~100-300 cycles (invalidation)
       - Contention = cache line ping-pong
    4. **False Sharing**
       - Two vars on same 64-byte line
       - Core A writes var1, Core B writes var2
       - Both cores see M→I→M transitions
       - Solution: padding to cache line boundary
  |
}
cost_table: {
  label: "Transition Costs (Approximate)"
  shape: sql_table
  f0: "Transition | Trigger | Bus Msg | Latency"
  f1: "I → E | Read miss, no shares | BusRd | ~100 cycles"
  f2: "I → S | Read miss, shares exist | BusRd | ~100 cycles"
  f3: "I → M | Write miss | BusRdX | ~300 cycles"
  f4: "E → M | Write hit | None | ~10 cycles"
  f5: "S → M | Write to shared | BusUpgr | ~200 cycles"
  f6: "M → S/I | Other reads | Writeback | ~200 cycles"
}
state_M -> state_E: "Writeback\n(Flush to Mem)" {
  style: {
    stroke: "#27AE60"
    stroke-width: 2
  }
}
state_E -> state_M: "CPU Write\n(No Bus)" {
  style: {
    stroke: "#27AE60"
    stroke-width: 3
  }
}
state_E -> state_S: "Snoop BusRd\n(Other Core Reads)" {
  style: {
    stroke: "#E67E22"
    stroke-width: 2
    stroke-dash: 3
  }
}
state_S -> state_M: "CPU Write\n+ BusUpgr" {
  style: {
    stroke: "#E74C3C"
    stroke-width: 2
  }
}
state_S -> state_I: "Snoop BusRdX\n(Other Writes)" {
  style: {
    stroke: "#E67E22"
    stroke-width: 2
    stroke-dash: 3
  }
}
state_M -> state_S: "Snoop BusRd\n+ Writeback" {
  style: {
    stroke: "#E67E22"
    stroke-width: 2
    stroke-dash: 3
  }
}
state_M -> state_I: "Snoop BusRdX\n+ Writeback" {
  style: {
    stroke: "#E67E22"
    stroke-width: 2
    stroke-dash: 3
  }
}
state_I -> state_E: "Read Miss\n(No Shares)" {
  style: {
    stroke: "#3498DB"
    stroke-width: 2
  }
}
state_I -> state_S: "Read Miss\n(Shares Exist)" {
  style: {
    stroke: "#3498DB"
    stroke-width: 2
  }
}
state_I -> state_M: "Write Miss\n(BusRdX)" {
  style: {
    stroke: "#E74C3C"
    stroke-width: 3
  }
}
state_E -> state_I: "Snoop BusRdX\n(Other Writes)" {
  style: {
    stroke: "#E67E22"
    stroke-width: 2
    stroke-dash: 3
  }
}
contention_note: {
  label: "Contention Hotspot"
  near: bottom-center
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  content: |md
    **Cache Line Ping-Pong**
    When N threads hammer same cache line:
    
    T1: CAS → M (others I)
    T2: CAS → wait for T1's M
    T2: CAS → M (others I)  
    T3: CAS → wait for T2's M
    
    Each CAS: ~100-500 cycles
    Under 16-thread contention:
    ~6% success rate per attempt
  |
}