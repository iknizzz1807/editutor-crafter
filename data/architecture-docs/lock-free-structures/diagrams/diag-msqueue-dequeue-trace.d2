direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Michael-Scott Queue: Dequeue Sentinel Pattern
  Sentinel node always exists; real data is at `head->next`
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  nonempty: {
    direction: down
    label: "Non-Empty Queue"
    before: {
      label: "Before Dequeue"
      width: 400
      head_ptr: {
        shape: rectangle
        label: "head"
        width: 80
        style.fill: "#B5AFF6"
      }
      tail_ptr: {
        shape: rectangle
        label: "tail"
        width: 80
        style.fill: "#B5AFF6"
      }
      sentinel: {
        shape: rectangle
        label: "SENTINEL\n(dummy)\nnext →"
        width: 100
        style.fill: "#DEE1EB"
        style.stroke-dash: 3
      }
      node_a: {
        shape: rectangle
        label: "Node A\nvalue: 42\nnext →"
        width: 100
        style.fill: "#ACE1AF"
      }
      node_b: {
        shape: rectangle
        label: "Node B\nvalue: 99\nnext → NULL"
        width: 100
        style.fill: "#ACE1AF"
      }
      head_ptr -> sentinel: "points to"
      tail_ptr -> node_b: "points to"
      sentinel -> node_a: "next"
      node_a -> node_b: "next"
    }
    operation: {
      label: "Dequeue Operation"
      width: 380
      step1: {
        label: "Step 1: Read head"
        code: |'c
          head = atomic_load(&queue->head);
          // head points to sentinel
        '|
        width: 350
        style.fill: "#FFF9C9"
      }
      step2: {
        label: "Step 2: Read head->next (first real node)"
        code: |'c
          next = atomic_load(&head->next);
          // next points to Node A
          // This is where real data lives!
        '|
        width: 350
        style.fill: "#FFF9C9"
      }
      step3: {
        label: "Step 3: Read value BEFORE CAS"
        code: |'c
          *value = next->value;  // 42
          // Must read before CAS!
          // Node may be freed after CAS succeeds
        '|
        width: 350
        style.fill: "#FCE7C6"
      }
      step4: {
        label: "Step 4: CAS head from sentinel to next"
        code: |'c
          CAS(&queue->head, head, next);
          // If success: head now points to Node A
          // Node A becomes the NEW sentinel
        '|
        width: 350
        style.fill: "#ACE1AF"
      }
      step1 -> step2 -> step3 -> step4
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after: {
    direction: down
    label: "After Successful Dequeue"
    state: {
      width: 400
      head_ptr2: {
        shape: rectangle
        label: "head"
        width: 80
        style.fill: "#B5AFF6"
      }
      tail_ptr2: {
        shape: rectangle
        label: "tail"
        width: 80
        style.fill: "#B5AFF6"
      }
      old_sentinel: {
        shape: rectangle
        label: "OLD\nSENTINEL\n(orphaned)"
        width: 100
        style.fill: "#FFB3BA"
        style.stroke: red
        style.stroke-dash: 5
      }
      new_sentinel: {
        shape: rectangle
        label: "NEW SENTINEL\n(Node A)\nvalue: 42\nnext →"
        width: 100
        style.fill: "#DEE1EB"
        style.stroke-dash: 3
      }
      node_b2: {
        shape: rectangle
        label: "Node B\nvalue: 99\nnext → NULL"
        width: 100
        style.fill: "#ACE1AF"
      }
      head_ptr2 -> new_sentinel: "now points to"
      tail_ptr2 -> node_b2: "unchanged"
      new_sentinel -> node_b2: "next"
      old_sentinel.style.opacity: 0.5
    }
    note: {
      label: "Key Insight"
      width: 380
      content: |md
        - Old sentinel is now **orphaned** (retired via hazard pointers)
        - Node A becomes the **new sentinel**  
        - Returned value was **42** (from old head->next)
        - Dequeue returns **head->next->value**, NOT head->value!
      |
      style.fill: "#E4DBFE"
    }
  }
}
divider: {
  shape: rectangle
  label: "═"
  width: 900
  style.fill: transparent
  style.stroke: "#CBD6E0"
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  empty: {
    direction: down
    label: "Empty Queue Case"
    empty_state: {
      width: 400
      head_ptr3: {
        shape: rectangle
        label: "head"
        width: 80
        style.fill: "#B5AFF6"
      }
      tail_ptr3: {
        shape: rectangle
        label: "tail"
        width: 80
        style.fill: "#B5AFF6"
      }
      sentinel3: {
        shape: rectangle
        label: "SENTINEL\n(dummy)\nnext → NULL"
        width: 100
        style.fill: "#DEE1EB"
        style.stroke-dash: 3
      }
      null_marker: {
        shape: circle
        label: "NULL"
        width: 60
        style.fill: "#FFB3BA"
      }
      head_ptr3 -> sentinel3: "both point to"
      tail_ptr3 -> sentinel3: "sentinel"
      sentinel3 -> null_marker: "next"
    }
    empty_check: {
      label: "Empty Queue Detection"
      width: 380
      check_code: {
        label: "Dequeue on Empty Queue"
        code: |'c
          head = atomic_load(&queue->head);
          next = atomic_load(&head->next);
          if (next == NULL) {
              // Queue is EMPTY
              // Sentinel exists but has no data after it
              return false;  // Dequeue failed
          }
        '|
        width: 350
        style.fill: "#FCE7C6"
      }
      explanation: {
        label: "Why Sentinel Eliminates Special Cases"
        width: 350
        content: |md
          - **head** is never NULL (always points to sentinel)
          - **Empty check** is simply `head->next == NULL`
          - **No NULL dereference** when checking head
          - **Single code path** for all cases
        |
        style.fill: "#E4DBFE"
      }
      check_code -> explanation
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  summary: {
    label: "Sentinel Pattern Summary"
    width: 850
    table: {
      shape: sql_table
      label: "Sentinel Node Benefits"
      r1: "Always exists | head never NULL"
      r2: "Marks boundary | separates logical regions"
      r3: "Simplifies code | single path for empty/non-empty"
      r4: "Enables atomicity | CAS only on head pointer"
      r5: "Becomes data | old data nodes become new sentinels"
    }
    invariant: {
      label: "Critical Invariant"
      width: 350
      content: |md
        
        REAL DATA is always at:
          head->next->value
        NEVER at:
          head->value (sentinel has no data)
        
      |
      style.fill: "#FCE7C6"
      style.border-radius: 8
    }
    table -> invariant
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  width: 200
  l1: {
    label: "Sentinel Node"
    shape: rectangle
    style.fill: "#DEE1EB"
    style.stroke-dash: 3
    width: 80
  }
  l2: {
    label: "Data Node"
    shape: rectangle
    style.fill: "#ACE1AF"
    width: 80
  }
  l3: {
    label: "Orphaned (retired)"
    shape: rectangle
    style.fill: "#FFB3BA"
    style.stroke-dash: 5
    width: 80
  }
}