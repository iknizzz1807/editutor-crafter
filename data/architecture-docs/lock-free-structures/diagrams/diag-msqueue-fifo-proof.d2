direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
title: {
  label: "FIFO Ordering Verification\nConcurrent enqueue/dequeue with sequence preservation"
  style.stroke: transparent
  style.fill: transparent
  style.font-size: 24
  style.bold: true
}

# --- LEGEND SECTION ---
legend: {
  near: bottom-right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  items: {
    shape: sql_table
    label: "Symbolic Legend"
    e1: "Enqueue linearization point"
    d1: "Dequeue linearization point"
    n1: "Node (value)"
  }
}

# --- MAIN FLOW ROW ---
row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  timeline: {
    direction: down
    label: "Concurrent Timeline"
    t0: "t₀" { shape: circle; width: 40; style.fill: "#e9ecef" }
    t1: "t₁" { shape: circle; width: 40; style.fill: "#e9ecef" }
    t2: "t₂" { shape: circle; width: 40; style.fill: "#e9ecef" }
    t3: "t₃" { shape: circle; width: 40; style.fill: "#e9ecef" }
    t4: "t₄" { shape: circle; width: 40; style.fill: "#e9ecef" }
    t5: "t₅" { shape: circle; width: 40; style.fill: "#e9ecef" }
    t6: "t₆" { shape: circle; width: 40; style.fill: "#e9ecef" }
    
    t0 -> t1 -> t2 -> t3 -> t4 -> t5 -> t6: {
      style.stroke: "#adb5bd"
      style.stroke-dash: 3
    }
  }

  thread_a: {
    direction: down
    label: "Thread A\n(Producer 1)"
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    a_enq1: "enqueue(1)" { shape: rectangle; style.fill: "#c3e6cb" }
    a_enq1_lp: "CAS ✓\nlp=t₁" { 
      shape: diamond; width: 80; style.fill: "#28a745"; style.font-color: white 
    }
    a_enq2: "enqueue(4)" { shape: rectangle; style.fill: "#c3e6cb" }
    a_enq2_lp: "CAS ✓\nlp=t₄" { 
      shape: diamond; width: 80; style.fill: "#28a745"; style.font-color: white 
    }
    a_enq1 -> a_enq1_lp -> a_enq2 -> a_enq2_lp: { style.stroke: "#28a745" }
  }

  thread_b: {
    direction: down
    label: "Thread B\n(Producer 2)"
    style.fill: "#cce5ff"
    style.stroke: "#007bff"
    b_enq1: "enqueue(2)" { shape: rectangle; style.fill: "#b8daff" }
    b_enq1_lp: "CAS ✓\nlp=t₂" { 
      shape: diamond; width: 80; style.fill: "#007bff"; style.font-color: white 
    }
    b_enq2: "enqueue(5)" { shape: rectangle; style.fill: "#b8daff" }
    b_enq2_lp: "CAS ✓\nlp=t₅" { 
      shape: diamond; width: 80; style.fill: "#007bff"; style.font-color: white 
    }
    b_enq1 -> b_enq1_lp -> b_enq2 -> b_enq2_lp: { style.stroke: "#007bff" }
  }

  thread_c: {
    direction: down
    label: "Thread C\n(Producer 3)"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    c_enq1: "enqueue(3)" { shape: rectangle; style.fill: "#ffeeba" }
    c_enq1_lp: "CAS ✓\nlp=t₃" { 
      shape: diamond; width: 80; style.fill: "#ffc107"; style.font-color: black 
    }
    c_enq2: "enqueue(6)" { shape: rectangle; style.fill: "#ffeeba" }
    c_enq2_lp: "CAS ✓\nlp=t₆" { 
      shape: diamond; width: 80; style.fill: "#ffc107"; style.font-color: black 
    }
    c_enq1 -> c_enq1_lp -> c_enq2 -> c_enq2_lp: { style.stroke: "#ffc107" }
  }

  thread_d: {
    direction: down
    label: "Thread D\n(Consumer)"
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    d_wait1: "spin..." { shape: rectangle; style.fill: "#f5c6cb"; style.stroke-dash: 3 }
    d_deq1: "dequeue()→1" { shape: rectangle; style.fill: "#f5c6cb" }
    d_deq1_lp: "CAS ✓" { 
      shape: diamond; width: 80; style.fill: "#dc3545"; style.font-color: white 
    }
    d_deq2: "dequeue()→2" { shape: rectangle; style.fill: "#f5c6cb" }
    d_deq3: "dequeue()→3" { shape: rectangle; style.fill: "#f5c6cb" }
    d_deq4: "dequeue()→4" { shape: rectangle; style.fill: "#f5c6cb" }
    d_deq5: "dequeue()→5" { shape: rectangle; style.fill: "#f5c6cb" }
    d_deq6: "dequeue()→6" { shape: rectangle; style.fill: "#f5c6cb" }
    
    d_wait1 -> d_deq1 -> d_deq1_lp -> d_deq2 -> d_deq3 -> d_deq4 -> d_deq5 -> d_deq6: {
      style.stroke: "#dc3545"
    }
  }

  queue_state: {
    direction: down
    label: "Internal State Evolution"
    style.fill: "#e2e3e5"
    style.stroke: "#6c757d"
    qs_init: "[S]→∅" { shape: rectangle; style.fill: "#f8f9fa" }
    qs_1: "[S]→[1]" { shape: rectangle; style.fill: "#d4edda" }
    qs_12: "[S]→[1]→[2]" { shape: rectangle; style.fill: "#cce5ff" }
    qs_123: "[S]→[1]→[2]→[3]" { shape: rectangle; style.fill: "#fff3cd" }
    
    qs_init -> qs_1 -> qs_12 -> qs_123: {
      style.stroke: "#6c757d"
      style.stroke-dash: 3
    }
  }
}

# --- PROOF SECTION ROW ---
row_proof: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  proof_box: {
    direction: down
    label: "Formal FIFO Verification"
    width: 650
    style.fill: "#f8f9fa"
    style.stroke: "#28a745"
    style.stroke-width: 2

    invariant: {
      label: |'md
        **Invariant**: Total Order on Sequence
        Linearization Points (LPs) defined by hardware CAS serialization:
        - **t₁**: Thread A links node [1]
        - **t₂**: Thread B links node [2] to [1]
        - **t₃**: Thread C links node [3] to [2]
        - **t₄**: Thread A links node [4] to [3]
      '|
      shape: rectangle
      style.fill: white
      width: 600
    }
    
    dequeue_order: {
      label: |'md
        **Observation**: Dequeue Retrieval Table
        | Action | Value | Proof (Head->Next) |
        | :--- | :--- | :--- |
        | Deq 1 | 1 | LP t₁ is oldest visible |
        | Deq 2 | 2 | Linked order [1]->[2] |
        | Deq 3 | 3 | Linked order [2]->[3] |
        | Deq 4 | 4 | Linked order [3]->[4] |
      '|
      shape: rectangle
      style.fill: white
      width: 600
    }

    conclusion: {
      label: |'md
        **Result**: FIFO Preservation Confirmed
        Hardware atomicity on `tail->next` ensures a single monotonic path.
        Dequeue follows this path exactly, preserving original LP order.
      '|
      shape: rectangle
      style.fill: "#d4edda"
      width: 600
    }
  }

  key_insight: {
    direction: down
    label: "Concurrent Mechanics"
    width: 380
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    
    insight_text: {
      label: |'md
        **Linearization Analysis**
        The CAS on `tail->next` is the definitive event.
        1. No two CAS operations succeed for the same pointer.
        2. Succeeding CAS creates a "happens-before" relationship.
        3. The resulting linked list structure is the physical 
           manifestation of the logical timeline.
      '|
      shape: rectangle
      style.fill: white
      width: 350
    }
  }
}

# --- CROSS-COMPONENT LINKS ---
row_timeline.thread_a.a_enq1_lp -> row_timeline.queue_state.qs_1: "t1 | CAS" {
  style.stroke: "#28a745"
  style.stroke-dash: 3
}
row_timeline.thread_b.b_enq1_lp -> row_timeline.queue_state.qs_12: "t2 | CAS" {
  style.stroke: "#007bff"
  style.stroke-dash: 3
}
row_timeline.thread_c.c_enq1_lp -> row_timeline.queue_state.qs_123: "t3 | CAS" {
  style.stroke: "#ffc107"
  style.stroke-dash: 3
}