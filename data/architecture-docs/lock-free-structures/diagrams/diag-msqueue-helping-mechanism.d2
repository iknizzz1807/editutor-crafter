direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: |md
    # Helping Mechanism: Advancing a Lagging Tail
    *Michael-Scott Queue Lock-Free Progress Guarantee*
  |
  near: top-center
  style: {
    stroke-width: 0
    fill: transparent
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  state_initial: {
    direction: down
    label: "T0: Initial State (Lagging)"
    
    queue_init: {
      shape: sql_table
      label: "Queue (reactor.h)"
      f0: "0x00 | MSNode* | head → S (sentinel)"
      f1: "0x08 | MSNode* | tail → S (LAGGING)"
      f2: "0x10 | MSNode* | S.next → N (Thread B linked)"
      sz: "Total: 24 bytes"
    }
    
    nodes_init: {
      direction: right
      label: "Memory Layout"
      
      sentinel_init: "S\n(Sentinel)" {
        shape: circle
        style.fill: "#E8E8E8"
      }
      
      node_n: "N\n(New Node)" {
        shape: circle
        style.fill: "#90EE90"
      }
      
      null_init: "NULL" {
        shape: oval
        style.stroke-dash: 3
      }
      
      sentinel_init -> node_n: "next | CAS(S.next, NULL, N)"
      node_n -> null_init: "0x00"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  thread_b: {
    direction: down
    label: "Thread B (Stalled Enqueuer)"
    style.stroke: "#FF6B6B"
    style.stroke-dash: 3
    
    b_step1: {
      label: "Phase 1: Link ✓"
      code: |'c
        // N is now reachable from S
        if (CAS(&S->next, NULL, N)) {
           // Node is logically in queue
        }
      '|
      width: 280
      style.fill: "#90EE90"
    }
    
    b_step2: {
      label: "Phase 2: Swing ⏸"
      code: |'c
        // Thread B descheduled here
        // Before advancing queue->tail
        CAS(&queue->tail, S, N);
      '|
      width: 280
      style.fill: "#FFB6C1"
    }
    
    b_note: "STALLED: Context Switch" {
      shape: callout
      style.font-color: "#FF6B6B"
      style.italic: true
    }
    
    b_step1 -> b_step2
  }
  
  thread_a: {
    direction: down
    label: "Thread A (New Enqueuer / Helper)"
    style.stroke: "#4169E1"
    
    a_observe: {
      label: "1. Observe Inconsistency"
      code: |'c
        t = atomic_load(&q->tail);
        n = atomic_load(&t->next);
        if (n != NULL) {
          // Tail is lagging! 
        }
      '|
      width: 300
      style.fill: "#ADD8E6"
    }
    
    a_help: {
      label: "2. ADVANCE TAIL (Help B)"
      code: |'c
        // Complete B's work for them
        CAS(&q->tail, t, n);
        // system-wide progress!
      '|
      width: 300
      style.fill: "#90EE90"
      style.bold: true
    }
    
    a_observe -> a_help: "Detects n != NULL"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  state_after: {
    direction: down
    label: "T1: Post-Helping State"
    
    queue_after: {
      shape: sql_table
      label: "Queue (Consistent)"
      f0: "0x00 | MSNode* | head → S"
      f1: "0x08 | MSNode* | tail → N (FIXED)"
      f2: "0x10 | MSNode* | S.next → N"
      sz: "Thread A advanced tail to N"
    }
    
    nodes_after: {
      direction: right
      label: "Memory Layout"
      
      sentinel_after: "S" {
        shape: circle
        style.fill: "#E8E8E8"
      }
      
      node_n_after: "N" {
        shape: circle
        style.fill: "#90EE90"
      }
      
      null_after: "NULL" {
        shape: oval
        style.stroke-dash: 3
      }
      
      sentinel_after -> node_n_after
      node_n_after -> null_after
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  thread_b_resume: {
    direction: down
    label: "Thread B Resumes"
    style.stroke: "#FF6B6B"
    style.stroke-dash: 3
    
    b_cas: {
      label: "CAS Fails Safely"
      code: |'c
        // Try to swing S -> N
        CAS(&queue->tail, S, N);
        // FAILS: tail is already N
      '|
      width: 280
      style.fill: "#E8E8E8"
    }
    
    b_return: {
      label: "Operation Success"
      code: |'c
        // Element is in queue
        // Tail is advanced
        return true;
      '|
      width: 280
      style.fill: "#90EE90"
    }
    
    b_cas -> b_return
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  guarantee_box: {
    label: "Lock-Free Implementation Note"
    width: 600
    details: |md
      **Mechanism**: "Helping" (Progress Guarantee)
      - If a thread observes a lagging pointer, it helps advance it before proceeding.
      - **System-Wide Progress**: Even if Thread B crashes at `b_step2`, Thread A ensures the data structure remains consistent.
      - **No Blockage**: Thread A never waits for Thread B to wake up.
    |
  }
}

flow_indicator: "SEQUENCE FLOW" {
  shape: rectangle
  style.fill: "#F4F4F4"
}

flow_indicator -> row1: "Initial Lag"
row1 -> row2: "Helping Event"
row2 -> row3: "Tail Corrected"
row3 -> row4: "B Resumes"
row4 -> row5: "Conclusion"