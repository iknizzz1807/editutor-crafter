direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Michael-Scott Queue Structure
  Sentinel-based design eliminates empty-queue special case
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pointers: {
    direction: down
    label: "Queue Pointers"
    head_ptr: {
      shape: hexagon
      label: "head"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    tail_ptr: {
      shape: hexagon
      label: "tail"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
  }
  spacer: {
    width: 40
    style.fill: transparent
    style.stroke: transparent
  }
  nodes: {
    direction: right
    label: "Linked List (Split-Ordered)"
    sentinel: {
      shape: rectangle
      label: "SENTINEL\n(dummy)"
      width: 100
      height: 70
      style.fill: "#FFECB3"
      style.stroke: "#FF9800"
      style.stroke-width: 3
      style.stroke-dash: 4
      note: |md
        - No data payload
        - Always exists
        - Value unused
      |
    }
    node_a: {
      shape: rectangle
      label: "Node A\nvalue: 10"
      width: 90
      height: 70
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    node_b: {
      shape: rectangle
      label: "Node B\nvalue: 20"
      width: 90
      height: 70
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    node_c: {
      shape: rectangle
      label: "Node C\nvalue: 30"
      width: 90
      height: 70
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    null_term: {
      shape: circle
      label: "NULL"
      width: 50
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.stroke-width: 2
    }
  }
}
invariants: {
  label: "MSQueue Invariants"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  inv1: "1. head always points to sentinel (dummy node)"
  inv2: "2. Real data starts at head->next"
  inv3: "3. tail points to last node OR second-to-last (may lag)"
  inv4: "4. Empty queue: head->next == NULL (sentinel only)"
  inv5: "5. Dequeue removes sentinel, next becomes new sentinel"
}
pointers.head_ptr -> nodes.sentinel: {
  label: "always"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
pointers.tail_ptr -> nodes.node_c: {
  label: "last node"
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
lagging_tail: {
  label: "Note: tail may lag behind!"
  shape: callout
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
lagging_tail -> pointers.tail_ptr: "if enqueue in progress"
dequeue_note: {
  label: "Dequeue reads head->next->value\nthen CAS head to head->next"
  shape: callout
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
}
dequeue_note -> nodes.node_a: "first real element"