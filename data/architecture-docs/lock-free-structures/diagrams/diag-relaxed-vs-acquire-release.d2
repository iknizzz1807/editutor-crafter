direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Relaxed vs Acquire/Release: Visibility Demonstration
  **The same code, different memory ordering, different outcomes**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  relaxed: {
    direction: down
    label: "memory_order_relaxed"
    style.stroke: "#D32F2F"
    style.fill: "#FFEBEE"
    relaxed_code: {
      label: "Thread 1 (Writer)"
      width: 320
      code: |'c
        // NO ordering guarantees!
        atomic_store_explicit(&x, 1, 
            memory_order_relaxed);
        atomic_store_explicit(&y, 1, 
            memory_order_relaxed);
      '|
    }
    relaxed_code2: {
      label: "Thread 2 (Reader)"
      width: 320
      code: |'c
        // Can see y=1 but x=0!
        r1 = atomic_load_explicit(&y, 
            memory_order_relaxed);
        r2 = atomic_load_explicit(&x, 
            memory_order_relaxed);
        // BUG: r1==1 && r2==0 is possible!
      '|
    }
    relaxed_trace: {
      label: "Execution Trace (ARM/Weak Ordering)"
      width: 320
      shape: sequence_diagram
      T1: Thread 1
      T2: Thread 2
      StoreBuffer: Store Buffer
      Cache: L1 Cache
      T1.t1 -> StoreBuffer: "store x=1 (buffered)"
      T1.t2 -> StoreBuffer: "store y=1 (buffered)"
      StoreBuffer.t3 -> Cache: "y reaches cache FIRST\n(reorder allowed!)"
      T2.t4 -> Cache: "load y → sees 1"
      StoreBuffer.t5 -> Cache: "x reaches cache LATER"
      T2.t6 -> Cache: "load x → sees 0!"
      T2."BUG: r1=1, r2=0"
    }
    relaxed_result: {
      label: "Result: SURPRISING"
      width: 320
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
      result: |md
        **r1 = 1, r2 = 0** is legal!
        - Thread 2 sees `y == 1` but `x == 0`
        - Violates programmer intuition
        - **Happens on ARM, not on x86**
      |
    }
  }
  acquire_release: {
    direction: down
    label: "memory_order_acquire/release"
    style.stroke: "#388E3C"
    style.fill: "#E8F5E9"
    ar_code: {
      label: "Thread 1 (Writer)"
      width: 320
      code: |'c
        // RELEASE: all prior writes visible
        atomic_store_explicit(&x, 1, 
            memory_order_relaxed);
        atomic_store_explicit(&y, 1, 
            memory_order_release); // ← fence
      '|
    }
    ar_code2: {
      label: "Thread 2 (Reader)"
      width: 320
      code: |'c
        // ACQUIRE: see all prior released writes
        while(atomic_load_explicit(&y, 
            memory_order_acquire) == 0);
        // After acquire, x MUST be visible
        r2 = atomic_load_explicit(&x, 
            memory_order_relaxed);
        // CORRECT: if r1==1 then r2==1
      '|
    }
    ar_trace: {
      label: "Execution Trace (All Platforms)"
      width: 320
      shape: sequence_diagram
      T1: Thread 1
      T2: Thread 2
      StoreBuffer: Store Buffer
      Cache: L1 Cache
      T1.t1 -> Cache: "store x=1 (must complete first)"
      T1.t2 -> StoreBuffer: "store y=1 + RELEASE fence"
      StoreBuffer.t3 -> Cache: "y visible AFTER x\n(release ensures order)"
      T2.t4 -> Cache: "load y → sees 1 (ACQUIRE)"
      T2.t5 -> Cache: "load x → sees 1\n(acquire guarantees it!)"
      T2."CORRECT: r1=1, r2=1"
    }
    ar_result: {
      label: "Result: CORRECT"
      width: 320
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      result: |md
        **r1 = 1 ⟹ r2 = 1** guaranteed!
        - Release on y ensures x is visible first
        - Acquire on y ensures we see x after
        - **Happens-before established**
      |
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hardware: {
    direction: down
    label: "Hardware Effects"
    store_buffer: {
      label: "Store Buffer (Write Reordering)"
      width: 380
      code: |'c
        // CPU doesn't write directly to cache
        // Writes go to store buffer first (~50 cycles)
        x = 1;  // → Store Buffer entry
        y = 1;  // → Store Buffer entry
        // Buffer can drain in ANY order!
        // Unless: RELEASE fence forces drain order
      '|
    }
    load_speculation: {
      label: "Load Speculation (Read Reordering)"
      width: 380
      code: |'c
        // CPU speculatively loads before confirming
        // If cache line is Shared, load is fast
        // If another core has Modified, must wait
        r1 = y;  // Speculative load
        r2 = x;  // Might complete before r1!
        // Unless: ACQUIRE fence prevents reordering
      '|
    }
  }
  ordering: {
    direction: down
    label: "Memory Ordering Lattice"
    lattice: {
      label: ""
      width: 380
      seq_cst: {
        label: "seq_cst"
        shape: circle
        style.fill: "#90CAF9"
      }
      acq_rel: {
        label: "acq_rel"
        shape: circle
        style.fill: "#A5D6A7"
      }
      acquire: {
        label: "acquire"
        shape: circle
        style.fill: "#C8E6C9"
      }
      release: {
        label: "release"
        shape: circle
        style.fill: "#C8E6C9"
      }
      consume: {
        label: "consume"
        shape: circle
        style.fill: "#FFF9C4"
      }
      relaxed: {
        label: "relaxed"
        shape: circle
        style.fill: "#FFCDD2"
      }
      seq_cst -> acq_rel
      acq_rel -> acquire
      acq_rel -> release
      acquire -> consume
      consume -> relaxed
      release -> relaxed
      seq_cst.label.near: top-center
      relaxed.label.near: bottom-center
    }
  }
  happens_before: {
    direction: down
    label: "Happens-Before Relationship"
    hb_diagram: {
      label: ""
      width: 380
      writer: {
        label: "Writer (Thread 1)"
        style.fill: "#BBDEFB"
        w1: "data[i] = compute()"
        w2: "ready = 1 (release)"
      }
      reader: {
        label: "Reader (Thread 2)"
        style.fill: "#C8E6C9"
        r1: "while(ready == 0) (acquire)"
        r2: "use data[i]"
      }
      writer.w1 -> writer.w2: "sequenced-before"
      writer.w2 -> reader.r1: "synchronizes-with\n(release → acquire)"
      reader.r1 -> reader.r2: "sequenced-before"
      hb_note: |md
        **Transitivity**: writer.w1 → writer.w2 → reader.r1 → reader.r2
        Therefore: **writer.w1 happens-before reader.r2**
        Reader MUST see all data writes!
      |
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  red: "Red = Bug possible" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
  }
  green: "Green = Correct" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  blue: "Blue = Strongest" {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
}