direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Retirement List Lifecycle
  **Hazard Pointer Memory Reclamation Protocol**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase1: "PHASE 1\nActive Node" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    in_struct: {
      label: "Node in\nData Structure"
      shape: rectangle
      width: 120
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
    }
    note1: {
      label: "Thread A holds reference\nvia atomic_load(&top)"
      shape: text
      style.font-color: "#2E7D32"
      style.font-size: 12
    }
  }
  arrow1: {
    label: "CAS succeeds\nnode removed"
    shape: text
    width: 80
    style.font-color: "#1565C0"
  }
  phase2: "PHASE 2\nRetirement" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    retire_call: {
      label: "hazard_retire(node)"
      shape: rectangle
      width: 140
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
    }
    retire_list: {
      direction: right
      label: "Thread-Local\nRetirement List"
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      node1: {
        label: "nodeₐ"
        shape: circle
        style.fill: "#FFCC80"
      }
      node2: {
        label: "nodeᵦ"
        shape: circle
        style.fill: "#FFCC80"
      }
      node3: {
        label: "nodeᵧ"
        shape: circle
        style.fill: "#FFCC80"
      }
      node1 -> node2 -> node3
    }
    count_label: {
      label: "count = 3"
      shape: text
      style.font-color: "#E65100"
      style.bold: true
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  threshold_check: "THRESHOLD CHECK" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    width: 280
    formula: {
      shape: rectangle
      label: |md
        **Trigger Condition:**
        
        count >= 2 × N × H
        
        N = active threads
        H = hazard slots per thread
      |
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
    }
    example: {
      label: |md
        Example: 16 threads × 2 slots
        **Threshold = 64 nodes**
      |
      shape: text
      style.font-color: "#0D47A1"
    }
    check_result: {
      label: "count (3) < 64\n→ No scan yet"
      shape: diamond
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
  }
  more_retires: {
    direction: down
    label: "... more operations ...\nmore nodes retired"
    style.fill: transparent
    style.stroke: transparent
    style.font-color: "#666"
    style.font-size: 14
  }
  threshold_met: "THRESHOLD MET" {
    direction: down
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    style.stroke-width: 2
    width: 200
    count_now: {
      label: "count = 67\n≥ 64"
      shape: rectangle
      style.fill: "#F8BBD9"
      style.stroke: "#C2185B"
      style.bold: true
    }
    trigger: {
      label: "TRIGGER\nhazard_scan_and_reclaim()"
      shape: rectangle
      style.fill: "#F48FB1"
      style.stroke: "#AD1457"
      style.font-color: white
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scan_phase: "PHASE 3\nScan Algorithm" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    width: 380
    step1: {
      label: "Step 1: Snapshot Hazard Pointers"
      shape: rectangle
      width: 320
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    hazard_registry: "Global Hazard Registry" {
      direction: right
      style.fill: "#CE93D8"
      style.stroke: "#6A1B9A"
      t0: {
        label: "T0\n[ptr₁, NULL]"
        shape: rectangle
        style.fill: "#BA68C8"
      }
      t1: {
        label: "T1\n[ptr₂, ptr₃]"
        shape: rectangle
        style.fill: "#BA68C8"
      }
      t2: {
        label: "T2\n[NULL, NULL]"
        shape: rectangle
        style.fill: "#AB47BC"
      }
      t3: {
        label: "Tₙ\n[ptr₄, ptr₅]"
        shape: rectangle
        style.fill: "#BA68C8"
      }
    }
    protected_set: {
      label: |md
        **Protected Set:**
        `{ptr₁, ptr₂, ptr₃, ptr₄, ptr₅}`
      |
      shape: rectangle
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    step2: {
      label: "Step 2: Partition Retirement List"
      shape: rectangle
      width: 320
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    partition: {
      direction: right
      label: ""
      check_each: {
        label: |md
          For each retired node:
          
          if node ∈ Protected Set:
              keep (protected)
          else:
              free (unprotected)
          
        |
        shape: rectangle
        width: 180
        style.fill: "#CE93D8"
        style.stroke: "#6A1B9A"
      }
      arrow: "→" {shape: text}
      result: {
        direction: down
        label: ""
        protected_nodes: {
          label: "Protected\n(kept in list)"
          shape: rectangle
          style.fill: "#C8E6C9"
          style.stroke: "#388E3C"
        }
        freed_nodes: {
          label: "Unprotected\n→ free()"
          shape: rectangle
          style.fill: "#FFCDD2"
          style.stroke: "#C62828"
        }
      }
    }
  }
  result_arrow: {
    label: "Update\ncount"
    shape: text
    width: 60
    style.font-color: "#6A1B9A"
  }
  phase4: "PHASE 4\nAfter Scan" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 200
    updated_list: {
      label: "Updated\nRetirement List"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
    }
    new_count: {
      label: "count = remaining\nprotected nodes"
      shape: text
      style.font-color: "#2E7D32"
    }
    freed_note: {
      label: "Unprotected nodes\nhave been free()'d"
      shape: text
      style.font-color: "#388E3C"
      style.font-size: 12
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  final_state: "MEMORY STATE" {
    direction: right
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    style.stroke-width: 2
    width: 500
    in_struct_box: {
      label: "In Data\nStructure"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    in_retire_box: {
      label: "In Retirement\nList (Protected)"
      shape: rectangle
      style.fill: "#FFE0B2"
    }
    freed_box: {
      label: "Freed\n(Unprotected)"
      shape: rectangle
      style.fill: "#FFCDD2"
    }
    in_struct_box -> in_retire_box: "CAS removes" {style.stroke-dash: 3}
    in_retire_box -> freed_box: "Scan frees" {style.stroke-dash: 3}
  }
}
invariant_box: "CRITICAL INVARIANT" {
  width: 500
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  style.stroke-width: 3
  invariant: {
    label: |md
      **A node is only freed if it's NOT in any hazard pointer slot at the start of the scan.**
      This guarantees: Any thread still dereferencing a node has it protected,
      so the scan will see that protection and NOT free the node.
    |
    shape: text
    style.font-size: 13
  }
}
phase1.arrow1 -> phase2
threshold_check.check_result -> more_retires {style.stroke-dash: 4; style.stroke: "#999"}
more_retires -> threshold_met
threshold_met.trigger -> scan_phase.step1
scan_phase.partition.result -> result_arrow -> phase4.updated_list
phase4 -> final_state
final_state -> invariant_box
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#BDBDBD"
  l1: {
    label: "● Green: Active/Safe"
    shape: text
    style.font-size: 11
  }
  l2: {
    label: "● Orange: Retired (Pending)"
    shape: text
    style.font-size: 11
  }
  l3: {
    label: "● Red: Freed (Reclaimed)"
    shape: text
    style.font-size: 11
  }
  l4: {
    label: "● Purple: Scan Processing"
    shape: text
    style.font-size: 11
  }
}