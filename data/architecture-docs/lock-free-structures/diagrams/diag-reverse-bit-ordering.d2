direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Reverse-Bit Ordering: The Key to Lock-Free Resizing
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  concept: {
    direction: down
    label: "Core Insight"
    insight: {
      width: 320
      label: "Reverse hash bits to create\nlist ordering that survives splits"
      code: |'c
        // Normal: hash % buckets
        // Problem: elements scatter on resize
        // Reverse-bit: so_key = reverse(hash)
        // Solution: elements stay in order
      '|
    }
    insight.style.fill: "#E8F5E9"
    insight.style.stroke: "#4CAF50"
  }
  transform: {
    direction: down
    label: "Bit Transformation (4-bit example)"
    original: {
      shape: sql_table
      label: "Original Hash"
      h0: "hash=0 | 0000"
      h1: "hash=1 | 0001"
      h2: "hash=2 | 0010"
      h3: "hash=3 | 0011"
      h4: "hash=4 | 0100"
      h5: "hash=5 | 0101"
      h6: "hash=6 | 0110"
      h7: "hash=7 | 0111"
    }
    arrow_label: {
      label: "reverse_bits()"
      shape: text
      style.font-color: "#1565C0"
      style.bold: true
    }
    reversed: {
      shape: sql_table
      label: "Reversed (so_key)"
      r0: "rev(0)=0  | 0000"
      r1: "rev(1)=8  | 1000"
      r2: "rev(2)=4  | 0100"
      r3: "rev(3)=12 | 1100"
      r4: "rev(4)=2  | 0010"
      r5: "rev(5)=10 | 1010"
      r6: "rev(6)=6  | 0110"
      r7: "rev(7)=14 | 1110"
    }
    original -> arrow_label -> reversed
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  list_2buckets: {
    direction: down
    label: "With 2 Buckets"
    list2: {
      label: "Sorted List (by so_key)"
      width: 280
      node0: {
        shape: rectangle
        label: "[S0] sentinel"
        style.fill: "#FFECB3"
        style.stroke: "#FF9800"
      }
      node4: {
        shape: rectangle
        label: "[4] hash=2, so_key=4"
        style.fill: "#E3F2FD"
      }
      node8: {
        shape: rectangle
        label: "[8] hash=1, so_key=8"
        style.fill: "#E8F5E9"
      }
      node12: {
        shape: rectangle
        label: "[12] hash=3, so_key=12"
        style.fill: "#E8F5E9"
      }
      node0 -> node4 -> node8 -> node12 -> null2
      null2.label: "NULL"
      null2.shape: circle
      null2.style.stroke: "#9E9E9E"
    }
    buckets2: {
      label: "Bucket Array"
      shape: sql_table
      b0: "bucket[0] | → S0"
      b1: "bucket[1] | → S1 (implicit)"
    }
    legend2: {
      label: "hash % 2:"
      shape: text
    }
    map2_0: {
      label: "hash 0,2,4,6 → bucket 0"
      shape: text
      style.font-color: "#1565C0"
    }
    map2_1: {
      label: "hash 1,3,5,7 → bucket 1"
      shape: text
      style.font-color: "#2E7D32"
    }
  }
  split_arrow: {
    label: "RESIZE\n2 → 4"
    shape: diamond
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.bold: true
    width: 80
  }
  list_4buckets: {
    direction: down
    label: "With 4 Buckets (After Split)"
    list4: {
      label: "Same List, New Sentinels"
      width: 320
      s0: {
        shape: rectangle
        label: "[S0] bucket 0"
        style.fill: "#FFECB3"
        style.stroke: "#FF9800"
      }
      s2: {
        shape: rectangle
        label: "[S2] NEW!"
        style.fill: "#FFCDD2"
        style.stroke: "#E53935"
      }
      node4b: {
        shape: rectangle
        label: "[4] hash=2"
        style.fill: "#E3F2FD"
      }
      s4: {
        shape: rectangle
        label: "[S4] NEW!"
        style.fill: "#FFCDD2"
        style.stroke: "#E53935"
      }
      s1: {
        shape: rectangle
        label: "[S8=S1] bucket 1"
        style.fill: "#FFECB3"
        style.stroke: "#FF9800"
      }
      s6: {
        shape: rectangle
        label: "[S6] NEW!"
        style.fill: "#FFCDD2"
        style.stroke: "#E53935"
      }
      node12b: {
        shape: rectangle
        label: "[12] hash=3"
        style.fill: "#E8F5E9"
      }
      s0 -> s2 -> node4b -> s4 -> s1 -> s6 -> node12b -> null4
      null4.label: "NULL"
      null4.shape: circle
      null4.style.stroke: "#9E9E9E"
    }
    buckets4: {
      label: "Bucket Array (2x)"
      shape: sql_table
      b0: "bucket[0] | → S0"
      b1: "bucket[1] | → S8"
      b2: "bucket[2] | → S2"
      b3: "bucket[3] | → S12"
    }
    note4: {
      label: "Elements never move!\nOnly sentinels added."
      shape: text
      style.font-color: "#D32F2F"
      style.bold: true
    }
  }
  list_2buckets -> split_arrow -> list_4buckets
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  proof: {
    direction: down
    label: "Why This Works"
    width: 380
    invariant: {
      label: "The Invariant"
      code: |'c
        // Bucket split: bucket[i] → bucket[i], bucket[i+N]
        // 
        // Elements for bucket[i] have so_key in range:
        //   [reverse(i), reverse(i+1))
        //
        // Elements for bucket[i+N] have so_key in range:
        //   [reverse(i+N), reverse(i+N+1))
        //
        // These ranges are CONTIGUOUS in sorted order!
        // No element moves when bucket splits.
      '|
      style.fill: "#E8F5E9"
    }
    example: {
      label: "Concrete Example"
      code: |'c
        // bucket[0] splits into bucket[0] and bucket[2]
        // bucket[0] elements: so_key ∈ [0, 4)
        //   reverse(0)=0, reverse(1)=8... wait
        //   Actually: hash % 2 == 0 means hash is even
        //   Even hashes: 0,2,4,6 → reversed: 0,4,2,6
        //   Sorted: 0,2,4,6 → so_keys in [0,8)
        // bucket[2] elements: hash % 4 == 2
        //   Hashes: 2,6,10,14 → reversed: 4,6,10,14
        //   Sorted after bucket[0] elements!
      '|
      style.fill: "#E3F2FD"
    }
  }
  parent_rel: {
    direction: down
    label: "Parent Bucket Relationship"
    parent_code: {
      label: "Finding Parent"
      code: |'c
        // When expanding from N to 2N buckets:
        // bucket[i] is parent of bucket[i+N]
        static inline uint64_t parent_bucket(uint64_t b) {
            return b & (b - 1);  // clear lowest set bit
        }
        // Examples:
        // parent(4) = 4 & 3 = 0
        // parent(5) = 5 & 4 = 4
        // parent(6) = 6 & 5 = 4
        // parent(7) = 7 & 6 = 6
      '|
      style.fill: "#FFF3E0"
    }
    init_order: {
      label: "Initialization Order"
      shape: sql_table
      label: "Bucket Init Dependencies"
      b4: "bucket[4] | needs | bucket[0]"
      b5: "bucket[5] | needs | bucket[4] → bucket[0]"
      b6: "bucket[6] | needs | bucket[4] → bucket[0]"
      b7: "bucket[7] | needs | bucket[6] → bucket[4] → bucket[0]"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  so_key_struct: {
    direction: down
    label: "SO-Key Structure"
    bits: {
      label: "64-bit so_key Layout"
      width: 360
      code: |'c
        // Sentinel node (marks bucket boundary):
        // [ reversed_bucket_index              ]
        // [63                              0]
        // No high bit set
        // Example: bucket 5 → so_key = reverse(5) = 0xA000000000000000
        // Regular node (holds key-value):
        // [1| reversed_hash                    ]
        // [63|62                            0]
        // High bit = 1 (SO_KEY_REGULAR_BIT)
        // Example: hash 5 → so_key = reverse(5) | (1<<63)
      '|
      style.fill: "#F3E5F5"
    }
    ordering: {
      label: "Why Sentinels Sort First"
      code: |'c
        // bucket 1 sentinel: so_key = reverse(1)
        //   = 0x8000000000000000 (no high bit)
        // hash 1 regular node: so_key = reverse(1) | (1<<63)
        //   = 0x8000000000000001 (high bit set)
        // 0x8000000000000000 < 0x8000000000000001
        // Sentinel sorts BEFORE regular nodes!
        // Lookup starts at sentinel, finds all bucket's elements.
      '|
      style.fill: "#E8F5E9"
    }
  }
  code_impl: {
    direction: down
    label: "Implementation"
    reverse_func: {
      label: "Reverse Bits Function"
      code: |'c
        static inline uint64_t reverse_bits(uint64_t x) {
        #if defined(__GNUC__) || defined(__clang__)
            return __builtin_bitreverse64(x);
        #else
            uint64_t result = 0;
            for (int i = 0; i < 64; i++) {
                result = (result << 1) | (x & 1);
                x >>= 1;
            }
            return result;
        #endif
        }
        #define SO_KEY_REGULAR_BIT (1ULL << 63)
        // Regular node key
        static inline uint64_t make_so_key(uint64_t hash) {
            return reverse_bits(hash) | SO_KEY_REGULAR_BIT;
        }
        // Sentinel node key
        static inline uint64_t make_sentinel_key(uint64_t bucket) {
            return reverse_bits(bucket);
        }
      '|
      style.fill: "#FFF8E1"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  sentinel_leg: {
    label: "Sentinel"
    shape: rectangle
    style.fill: "#FFECB3"
    style.stroke: "#FF9800"
  }
  new_sentinel_leg: {
    label: "New Sentinel"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  data_leg: {
    label: "Data Node"
    shape: rectangle
    style.fill: "#E3F2FD"
  }
}