direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Lock-free Data Structures Atlas
  ### From Atomic Primitives to Production-Ready Concurrent Containers
| {near: top-center}
row_primitives: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m1: M1: Atomic Operations & Memory Ordering {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      font-color: "#0D47A1"
    }
    width: 320
    label: "Foundation Layer"
    primitives: {
      shape: class
      label: "Core Primitives (stdatomic.h)"
      width: 280
      +atomic_load: "T* → T"
      +atomic_store: "T*, T → void"
      +atomic_cas: "T*, T, T → bool"
      +atomic_fetch_add: "T*, T → T"
    }
    ordering: {
      shape: class
      label: "Memory Ordering"
      width: 280
      relaxed: "No ordering guarantees"
      acquire: "Read barrier"
      release: "Write barrier"
      seq_cst: "Total order"
    }
    concepts: {
      shape: rectangle
      width: 280
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      aba: "ABA Problem"
      happens_before: "Happens-Before"
      mesi: "MESI Protocol"
    }
  }
}
row_structures: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m2: M2: Treiber Stack {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      font-color: "#1B5E20"
    }
    width: 300
    stack_struct: {
      shape: class
      label: "TreiberStack"
      width: 260
      -top: "AtomicTaggedPtr"
      +push: "int64_t → void"
      +pop: "→ int64_t | empty"
    }
    stack_concepts: {
      shape: rectangle
      width: 260
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      cas_loop: "CAS Loop Pattern"
      tagged_ptr: "Tagged Pointers (16B)"
      lifo: "LIFO Linearization"
    }
  }
  m3: M3: Michael-Scott Queue {
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      font-color: "#BF360C"
    }
    width: 300
    queue_struct: {
      shape: class
      label: "MSQueue"
      width: 260
      -head: "_Atomic(Node*)"
      -tail: "_Atomic(Node*)"
      +enqueue: "int64_t → void"
      +dequeue: "→ int64_t | empty"
    }
    queue_concepts: {
      shape: rectangle
      width: 260
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
      sentinel: "Sentinel Node"
      helping: "Helping Mechanism"
      fifo: "FIFO Linearization"
    }
  }
}
row_reclamation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m4: M4: Hazard Pointers & Memory Reclamation {
    shape: rectangle
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
      font-color: "#880E4F"
    }
    width: 480
    hp_struct: {
      shape: class
      label: "Hazard Pointer System"
      width: 200
      -registry: "HazardThreadSlot[]"
      -retire_list: "RetirementList"
      +protect: "slot, node → void"
      +release: "slot → void"
      +retire: "node → void"
    }
    hp_protocol: {
      shape: rectangle
      width: 240
      style.fill: "#F8BBD9"
      style.stroke: "#C2185B"
      step1: "1. Set hazard pointer"
      step2: "2. Load node pointer"
      step3: "3. Validate still valid"
      step4: "4. Access node safely"
    }
  }
}
row_hashmap: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m5: M5: Lock-free Hash Map {
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      font-color: "#4A148C"
    }
    width: 620
    hm_struct: {
      shape: class
      label: "LFHashMap (Split-Ordered List)"
      width: 280
      -buckets: "_Atomic(BucketEntry*)"
      -bucket_count: "atomic uint64"
      -element_count: "atomic uint64"
      +insert: "key, value → bool"
      +lookup: "key → value | null"
      +delete: "key → bool"
    }
    hm_concepts: {
      shape: rectangle
      width: 280
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
      reverse_bits: "Reverse-Bit Ordering"
      split_order: "Split-Ordered List"
      lazy_buckets: "Lazy Bucket Init"
      two_phase_del: "Two-Phase Delete"
    }
  }
}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  deps: Dependencies
  m1_legend: "M1: Foundation" {style.fill: "#E3F2FD"}
  m2_legend: "M2: LIFO Stack" {style.fill: "#E8F5E9"}
  m3_legend: "M3: FIFO Queue" {style.fill: "#FFF3E0"}
  m4_legend: "M4: Safe Reclamation" {style.fill: "#FCE4EC"}
  m5_legend: "M5: Hash Map" {style.fill: "#F3E5F5"}
}
m1 -> m2: "CAS + Tagged Pointers" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
}
m1 -> m3: "CAS + Memory Order" {
  style: {
    stroke: "#E65100"
    stroke-width: 3
  }
}
m2 -> m4: "Memory Leak Problem" {
  label: "Pop nodes need\nsafe reclamation"
  style: {
    stroke: "#C2185B"
    stroke-width: 2
    stroke-dash: 4
  }
}
m3 -> m4: "Memory Leak Problem" {
  label: "Dequeue nodes need\nsafe reclamation"
  style: {
    stroke: "#C2185B"
    stroke-width: 2
    stroke-dash: 4
  }
}
m4 -> m5: "Hazard Protection" {
  label: "All traversals\nuse HP for safety"
  style: {
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}
m2 -> m5: "Linked List CAS" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    stroke-dash: 3
  }
}
m3 -> m5: "Helping Pattern" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    stroke-dash: 3
  }
}