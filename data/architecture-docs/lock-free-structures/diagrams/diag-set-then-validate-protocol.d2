direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Set-Then-Validate Protocol
  Protecting nodes in lock-free structures requires publishing the hazard pointer BEFORE dereferencing
| {near: top-center}
row_compare: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wrong: {
    direction: down
    label: "WRONG: Load First, Then Protect"
    wrong_step1: {
      label: "Step 1: Load Pointer"
      width: 280
      code: |'c
        Node* node = atomic_load(&stack->top);
      '|
      style.fill: "#FFE4E1"
      style.stroke: "#8B0000"
    }
    wrong_gap: {
      label: "⚠️ RACE WINDOW"
      width: 280
      desc: |md
        Between load and protect, another thread can:
        1. Pop this node
        2. Retire it
        3. Free the memory
      |
      style.fill: "#FF6B6B"
      style.stroke: "#8B0000"
      style.font-color: "#8B0000"
    }
    wrong_step2: {
      label: "Step 2: Set Hazard (Too Late!)"
      width: 280
      code: |'c
        hazard_protect(slot, node);
        // node might already be freed!
      '|
      style.fill: "#FFE4E1"
      style.stroke: "#8B0000"
    }
    wrong_step3: {
      label: "Step 3: Use-After-Free!"
      width: 280
      code: |'c
        return node->value;  // 💥 CRASH
      '|
      style.fill: "#8B0000"
      style.font-color: white
    }
    wrong_step1 -> wrong_gap: "nanoseconds pass"
    wrong_gap -> wrong_step2: "unprotected"
    wrong_step2 -> wrong_step3: "dereference freed"
  }
  right: {
    direction: down
    label: "CORRECT: Set, Load, Validate"
    right_step1: {
      label: "Step 1: Set Hazard (Tentative)"
      width: 280
      code: |'c
        // Publish what we're about to load
        hazard_protect(slot, atomic_load(&top));
      '|
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    right_step2: {
      label: "Step 2: Load Pointer"
      width: 280
      code: |'c
        Node* node = atomic_load(&stack->top);
      '|
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    right_step3: {
      label: "Step 3: Validate"
      width: 280
      code: |'c
        // Is our protection still valid?
        if (node != atomic_load(&slot)) {
          // No! Retry from step 1
        }
      '|
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    right_step4: {
      label: "Step 4: Safe Dereference"
      width: 280
      code: |'c
        return node->value;  // ✓ Safe!
        hazard_release(slot);
      '|
      style.fill: "#2E7D32"
      style.font-color: white
    }
    right_step1 -> right_step2: "protected"
    right_step2 -> right_step3: "validate"
    right_step3 -> right_step4: "confirmed safe"
  }
}
row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline_title: {
    label: "Timeline: Why Validation Matters"
    style.fill: transparent
    style.stroke: transparent
  }
}
timeline: {
  direction: down
  t0: {
    label: "T0: Initial State"
    width: 600
    state: |md
      
      stack->top → Node A (valid)
      Thread 1 hazard_slot[0] = NULL
      Thread 2 hazard_slot[0] = NULL
      
    |
    style.fill: "#E3F2FD"
  }
  t1: {
    label: "T1: Thread 1 Sets Hazard"
    width: 600
    state: |md
      
      Thread 1: hazard_protect(0, top)  // slot[0] = &Node A
      Thread 1 hazard_slot[0] = Node A
      
    |
    style.fill: "#C8E6C9"
  }
  t2: {
    label: "T2: Thread 2 Tries to Free Node A"
    width: 600
    state: |md
      
      Thread 2: pop() succeeds, retires Node A
      Thread 2: hazard_scan_and_reclaim()
        → Sees Thread 1's slot[0] = Node A
        → CANNOT free Node A (protected!)
      
    |
    style.fill: "#FFF9C4"
  }
  t3: {
    label: "T3: Thread 1 Safe to Dereference"
    width: 600
    state: |md
      
      Thread 1: validates node == slot (yes)
      Thread 1: reads node->value  // Safe!
      Thread 1: hazard_release(0)
      
    |
    style.fill: "#C8E6C9"
  }
  t0 -> t1: "protect"
  t1 -> t2: "concurrent"
  t2 -> t3: "scan respects protection"
}
legend: {
  near: bottom-center
  label: "Key Insight"
  insight: |md
    The hazard pointer doesn't protect a *specific* node—it protects **whatever is at that address right now**.
    If the address changes between setting and loading, validation fails and we retry.
    This ensures the node we dereference is the same one we protected.
  |
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  width: 500
}