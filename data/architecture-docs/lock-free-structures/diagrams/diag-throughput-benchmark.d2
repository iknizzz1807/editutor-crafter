direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  content: |'md
    # Lock-free vs Mutex Throughput Under Contention
    **Benchmark: Hash Map Operations (50% insert, 30% lookup, 20% delete)**
  '|
  shape: rectangle
  style.fill: "#F4F6F7"
}
title.near: top-center

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  chart_1_thread: {
    direction: down
    label: "1 Thread (No Contention)"
    bar_mutex_1: {
      label: "Mutex"
      width: 280
      height: 50
      style.fill: "#E74C3C"
      style.stroke: "#C0392B"
    }
    bar_mutex_1_label: "2.5M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    bar_lockfree_1: {
      label: "Lock-Free"
      width: 224
      height: 50
      style.fill: "#3498DB"
      style.stroke: "#2980B9"
    }
    bar_lockfree_1_label: "2.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    insight_1: {
      content: |md
        **Mutex wins ~20%**
        Lower overhead without contention
        Simpler code path, better cache locality
      |
      style.fill: "#FADBD8"
    }
  }

  chart_4_threads: {
    direction: down
    label: "4 Threads (Low Contention)"
    bar_lockfree_4: {
      label: "Lock-Free"
      width: 336
      height: 50
      style.fill: "#3498DB"
      style.stroke: "#2980B9"
    }
    bar_lockfree_4_label: "6.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    bar_mutex_4: {
      label: "Mutex"
      width: 224
      height: 50
      style.fill: "#E74C3C"
      style.stroke: "#C0392B"
    }
    bar_mutex_4_label: "4.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    insight_4: {
      content: |md
        **Lock-Free wins ~50%**
        Contention begins, lock wait times increase
        CAS failures still rare
      |
      style.fill: "#D4E6F1"
    }
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  chart_8_threads: {
    direction: down
    label: "8 Threads (Medium Contention)"
    bar_lockfree_8: {
      label: "Lock-Free"
      width: 400
      height: 50
      style.fill: "#3498DB"
      style.stroke: "#2980B9"
    }
    bar_lockfree_8_label: "10.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    bar_mutex_8: {
      label: "Mutex"
      width: 200
      height: 50
      style.fill: "#E74C3C"
      style.stroke: "#C0392B"
    }
    bar_mutex_8_label: "5.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    insight_8: {
      content: |md
        **Lock-Free wins ~100%**
        Mutex contention spikes, threads queue
        Lock-free scales via parallel CAS attempts
      |
      style.fill: "#D4E6F1"
    }
  }

  chart_16_threads: {
    direction: down
    label: "16 Threads (High Contention)"
    bar_lockfree_16: {
      label: "Lock-Free"
      width: 448
      height: 50
      style.fill: "#27AE60"
      style.stroke: "#1E8449"
    }
    bar_lockfree_16_label: "14.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    bar_mutex_16: {
      label: "Mutex"
      width: 160
      height: 50
      style.fill: "#E74C3C"
      style.stroke: "#C0392B"
    }
    bar_mutex_16_label: "5.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    insight_16: {
      content: |md
        **Lock-Free wins ~180%**
        Mutex: severe lock convoying
        Lock-free: CAS backoff prevents starvation
      |
      style.fill: "#D4EFDF"
    }
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  chart_32_threads: {
    direction: down
    label: "32 Threads (Extreme Contention)"
    bar_lockfree_32: {
      label: "Lock-Free"
      width: 512
      height: 50
      style.fill: "#27AE60"
      style.stroke: "#1E8449"
    }
    bar_lockfree_32_label: "16.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    bar_mutex_32: {
      label: "Mutex"
      width: 128
      height: 50
      style.fill: "#C0392B"
      style.stroke: "#922B21"
    }
    bar_mutex_32_label: "4.0M ops/sec" {
      style.font-color: black
      style.bold: true
    }
    insight_32: {
      content: |md
        **Lock-Free wins ~300%**
        Mutex: threads spend most time waiting
        Lock-free: progress guaranteed per operation
      |
      style.fill: "#D4EFDF"
    }
  }

  contention_graph: {
    label: "Contention Impact Over Time"
    width: 380
    explanation: {
      content: |md
        Throughput scales with threads
        until contention dominates
      |
    }
    mutex_curve: {
      label: "Mutex → Plateau then DEGRADE"
      shape: parallelogram
      style.fill: "#FADBD8"
      style.stroke: "#E74C3C"
    }
    lockfree_curve: {
      label: "Lock-Free → Linear scaling"
      shape: parallelogram
      style.fill: "#D4EFDF"
      style.stroke: "#27AE60"
    }
  }
}

legend: {
  direction: right
  mutex_legend: {
    label: "Mutex-Based"
    style.fill: "#E74C3C"
    style.stroke: "#C0392B"
  }
  lockfree_legend: {
    label: "Lock-Free"
    style.fill: "#3498DB"
    style.stroke: "#2980B9"
  }
  lockfree_winner: {
    label: "Lock-Free (Winner)"
    style.fill: "#27AE60"
    style.stroke: "#1E8449"
  }
}
legend.near: bottom-right

analysis: {
  label: "Performance Crossover Analysis"
  crossover_point: {
    content: |md
      ## Critical Insight: The 4-8 Thread Crossover
      **Below 4 threads**: Mutex overhead is acceptable
      - Lock acquisition/release is ~25-50ns
      - Rare blocking, good cache behavior
      **Above 8 threads**: Lock-free becomes essential
      - Mutex wait time dominates (>200ns avg)
      - Lock convoys form under burst traffic
      - Lock-free CAS backoff prevents thundering herd
    |
    style.fill: "#FEF9E7"
    style.stroke: "#F39C12"
  }
  recommendation: {
    content: |'md
      ## When to Use Each Approach
      | Scenario | Recommendation | Rationale |
      |----------|----------------|-----------|
      | Embedded/1-2 cores | Mutex | Simpler, lower overhead |
      | Desktop apps (4 cores) | Either | Marginal difference |
      | Server (8+ cores) | Lock-Free | 2x+ throughput gain |
      | Real-time systems | Lock-Free | No unbounded wait |
      | High-frequency trading | Lock-Free | Latency predictability |
    '|
    style.fill: "#EBF5FB"
    style.stroke: "#3498DB"
  }
}
analysis.near: bottom-center