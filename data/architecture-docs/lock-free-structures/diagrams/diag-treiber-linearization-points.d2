direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Treiber Stack Linearization Points
  ## The CAS is the Single Instant Where Operations Take Effect
| {near: top-center}
legend_box: {
  near: top-right
  label: "Legend"
  legend_content: {
    shape: rectangle
    style.fill: transparent
    cas_success: "● CAS Success = Linearization Point"
    cas_fail: "○ CAS Failure (retry)"
    push_op: "Push operation"
    pop_op: "Pop operation"
    cas_success.style.font-color: green
    cas_fail.style.font-color: red
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  thread_a: {
    direction: down
    label: "Thread A: push(42)"
    style.stroke: "#4A90D9"
    style.fill: "#E8F4FD"
    ta_start: "Start push(42)" {
      shape: oval
      style.fill: white
    }
    ta_load: "Load top → NULL" {
      shape: rectangle
      width: 140
    }
    ta_link: "node.next = NULL" {
      shape: rectangle
      width: 140
    }
    ta_cas: "CAS(top, NULL, node42)\n✓ SUCCESS" {
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.bold: true
      width: 160
    }
    ta_ret: "Return success" {
      shape: oval
      style.fill: white
    }
    ta_start -> ta_load
    ta_load -> ta_link
    ta_link -> ta_cas
    ta_cas -> ta_ret
  }
  thread_b: {
    direction: down
    label: "Thread B: push(17)"
    style.stroke: "#D94A4A"
    style.fill: "#FDE8E8"
    tb_start: "Start push(17)" {
      shape: oval
      style.fill: white
    }
    tb_load1: "Load top → NULL" {
      shape: rectangle
      width: 140
    }
    tb_cas1: "CAS(top, NULL, node17)\n✗ FAIL (top changed)" {
      shape: rectangle
      style.fill: "#FFB6C1"
      style.stroke-dash: 3
      width: 160
    }
    tb_load2: "Load top → node42" {
      shape: rectangle
      width: 140
    }
    tb_link2: "node17.next = node42" {
      shape: rectangle
      width: 140
    }
    tb_cas2: "CAS(top, node42, node17)\n✓ SUCCESS" {
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.bold: true
      width: 160
    }
    tb_ret: "Return success" {
      shape: oval
      style.fill: white
    }
    tb_start -> tb_load1
    tb_load1 -> tb_cas1
    tb_cas1 -> tb_load2
    tb_load2 -> tb_link2
    tb_link2 -> tb_cas2
    tb_cas2 -> tb_ret
  }
  thread_c: {
    direction: down
    label: "Thread C: pop()"
    style.stroke: "#4AD94A"
    style.fill: "#E8FDE8"
    tc_start: "Start pop()" {
      shape: oval
      style.fill: white
    }
    tc_wait: "Spin (top = NULL)" {
      shape: rectangle
      style.fill: "#FFFACD"
      width: 140
    }
    tc_load: "Load top → node17" {
      shape: rectangle
      width: 140
    }
    tc_read: "Read node17.next → node42" {
      shape: rectangle
      width: 160
    }
    tc_cas: "CAS(top, node17, node42)\n✓ SUCCESS" {
      shape: hexagon
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.bold: true
      width: 160
    }
    tc_ret: "Return 17" {
      shape: oval
      style.fill: white
    }
    tc_start -> tc_wait
    tc_wait -> tc_load
    tc_load -> tc_read
    tc_read -> tc_cas
    tc_cas -> tc_ret
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    label: "Global Timeline & Stack State"
    direction: down
    style.fill: "#F5F5F5"
    time_marker: {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent
      t0: "t₀" {
        shape: circle
        width: 40
        style.fill: white
      }
      t1: "t₁" {
        shape: circle
        width: 40
        style.fill: "#90EE90"
        style.bold: true
        label: "t₁\nCAS_A"
      }
      t2: "t₂" {
        shape: circle
        width: 40
        style.fill: "#90EE90"
        style.bold: true
        label: "t₂\nCAS_B"
      }
      t3: "t₃" {
        shape: circle
        width: 40
        style.fill: "#90EE90"
        style.bold: true
        label: "t₃\nCAS_C"
      }
      t0 -> t1: "→"
      t1 -> t2: "→"
      t2 -> t3: "→"
    }
    state_evolution: {
      label: "Stack State Evolution"
      direction: right
      state0: {
        label: "Initial"
        shape: rectangle
        width: 100
        state0_text: "top → NULL\n(empty)"
      }
      state1: {
        label: "After t₁"
        shape: rectangle
        width: 100
        state1_text: "top → [42]\n          ↓\n        NULL"
      }
      state2: {
        label: "After t₂"
        shape: rectangle
        width: 100
        state2_text: "top → [17]\n          ↓\n       [42]\n          ↓\n        NULL"
      }
      state3: {
        label: "After t₃"
        shape: rectangle
        width: 100
        state3_text: "top → [42]\n          ↓\n        NULL\n(returned 17)"
      }
      state0 -> state1: "A's CAS"
      state1 -> state2: "B's CAS"
      state2 -> state3: "C's CAS"
    }
  }
  linearization_proof: {
    label: "Linearization Proof"
    direction: down
    style.fill: "#FFF8DC"
    width: 400
    proof_content: |md
      **Theorem**: The Treiber stack is linearizable.
      **Linearization Points**:
      - `push(v)`: Successful CAS on `top`
      - `pop()`: Successful CAS on `top`
      **Key Properties**:
      1. **Atomicity**: Each CAS is atomic at hardware level
      2. **Total Order**: CAS operations on same address are totally ordered
      3. **Real-time Preservation**: If op A completes before op B starts, A's linearization point precedes B's
      **Valid Linearization**: ⟨ push_A(42), push_B(17), pop_C() ⟩
      Result: pop_C returns 17 (top of stack after both pushes)
    |
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  concurrent_view: {
    label: "Concurrent Execution View"
    direction: down
    style.fill: "#E8E8E8"
    width: 600
    timeline_visual: {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent
      col_a: {
        label: "Thread A"
        direction: down
        style.fill: "#E8F4FD"
        a1: "invoke push(42)"
        a2: "..."
        a3: "CAS succeeds ●" {
          style.fill: "#90EE90"
          style.bold: true
        }
        a4: "..."
        a5: "return"
        a1 -> a2 -> a3 -> a4 -> a5
      }
      col_b: {
        label: "Thread B"
        direction: down
        style.fill: "#FDE8E8"
        b1: "invoke push(17)"
        b2: "CAS fails ○" {
          style.fill: "#FFB6C1"
        }
        b3: "retry..."
        b4: "CAS succeeds ●" {
          style.fill: "#90EE90"
          style.bold: true
        }
        b5: "return"
        b1 -> b2 -> b3 -> b4 -> b5
      }
      col_c: {
        label: "Thread C"
        direction: down
        style.fill: "#E8FDE8"
        c1: "invoke pop()"
        c2: "spin (empty)"
        c3: "..."
        c4: "CAS succeeds ●" {
          style.fill: "#90EE90"
          style.bold: true
        }
        c5: "return 17"
        c1 -> c2 -> c3 -> c4 -> c5
      }
    }
    annotation: {
      label: "Linearization Order"
      direction: right
      style.fill: transparent
      lp1: "LP₁: A's CAS (t₁)" {
        shape: hexagon
        style.fill: "#90EE90"
      }
      lp2: "LP₂: B's CAS (t₂)" {
        shape: hexagon
        style.fill: "#90EE90"
      }
      lp3: "LP₃: C's CAS (t₃)" {
        shape: hexagon
        style.fill: "#90EE90"
      }
      lp1 -> lp2 -> lp3
    }
  }
  ordering_rules: {
    label: "Ordering Rules"
    direction: down
    style.fill: "#F0F8FF"
    width: 350
    rules: |md
      **Sequential Specification**:
      A stack is linearizable if there exists a total order of operations that:
      1. Preserves real-time order
      2. Satisfies LIFO semantics
      **For our example**:
      - A's push(42) completes at t₁
      - B's push(17) starts before t₁, completes after t₂
      - C's pop() starts after t₁, completes at t₃
      **Linearization**: ⟨ A.push(42), B.push(17), C.pop()=17 ⟩
      ✓ Valid: pop returns 17 (most recently pushed)
      ✓ Real-time preserved: A before C
    |
  }
}
cas_window: {
  label: "The CAS Window: Where Races Happen"
  direction: down
  style.fill: "#FFF0F5"
  window_content: {
    direction: right
    style.fill: transparent
    window_code: {
      label: "CAS Loop in push()"
      width: 320
      code: |'c
        do {
          old_top = atomic_load(&top);  // ← Window opens
          new_node->next = old_top;
          // ← Other threads can modify top here
        } while (!CAS(&top, old_top, new_node));
        // ↑ Linearization point: atomic instant
      '|
    }
    window_explanation: {
      label: "Race Window Analysis"
      width: 320
      explanation: |md
        **Between load and CAS**:
        - Any number of other pushes/pops can complete
        - `old_top` becomes stale
        - CAS will fail (version mismatch)
        **At CAS success**:
        - Single atomic instant
        - Thread "wins" the race
        - Operation takes effect globally
        **No partial states visible**:
        - Either CAS succeeds (done) or fails (retry)
        - Stack is always in consistent state
      |
    }
  }
}
footer: {
  near: bottom-center
  label: ""
  style.fill: transparent
  style.stroke: transparent
  footer_text: |md
    **Key Insight**: Linearizability means each operation appears to occur atomically at its linearization point.
    All correct lock-free algorithms have well-defined linearization points — typically the successful CAS.
  |
}