direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Treiber Push: Step-by-Step Trace
  CAS-based lock-free stack push with retry on contention
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    direction: down
    label: "Step 1: Allocate Node"
    code: |'c
      Node* new_node = malloc(sizeof(Node));
      new_node->value = value;
    '|
    width: 320
  }
  step2: {
    direction: down
    label: "Step 2: Load Current Top"
    code: |'c
      old_top = atomic_load_explicit(
        &stack->top, 
        memory_order_acquire
      );
    '|
    width: 320
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step3: {
    direction: down
    label: "Step 3: Link New Node"
    code: |'c
      new_node->next = old_top.ptr;
      new_top.version = old_top.version + 1;
      new_top.ptr = new_node;
    '|
    width: 320
  }
  step4: {
    direction: down
    label: "Step 4: CAS Top Pointer"
    code: |'c
      CAS(&stack->top, old_top, new_top)
      // Atomically updates both
      // pointer AND version
    '|
    width: 320
  }
}
row1.step1 -> row1.step2: "node ready"
row1.step2 -> row2.step3: "old_top cached"
row2.step3 -> row2.step4: "new_top prepared"
success_path: {
  label: "CAS Succeeds"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  result_success: |md
    ✓ CAS returned `true`
    ✓ `stack->top` now points to `new_node`
    ✓ Push complete - return immediately
  |
}
failure_path: {
  label: "CAS Fails (Contention)"
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  result_failure: |md
    ✗ CAS returned `false`
    ✗ Another thread modified `top` first
    ✗ `old_top` updated to current value
  |
  retry: {
    label: "Retry Loop"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    retry_code: |'c
      // Backoff (optional)
      exponential_backoff(&delay);
      // Loop back to Step 2
      // Re-load old_top with new state
    '|
    width: 300
  }
  result_failure -> retry: "retry"
  retry -> row1.step2: "reload top" {
    style.stroke: "#FF9800"
    style.stroke-dash: 4
    style.animated: true
  }
}
row2.step4 -> success_path: "success" {
  style.stroke: "#4CAF50"
}
row2.step4 -> failure_path: "failure" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
memory_layout: {
  label: "Memory Layout During Push"
  style.fill: "#F5F5F5"
  before: {
    label: "Before Push"
    shape: sql_table
    stack_top: "stack->top | TaggedPtr | {v:5, ptr:A}"
    node_a: "Node A | next | → B"
    node_b: "Node B | next | → NULL"
  }
  after: {
    label: "After Successful Push"
    shape: sql_table
    stack_top_new: "stack->top | TaggedPtr | {v:6, ptr:NEW}"
    node_new: "Node NEW | next | → A"
    node_a2: "Node A | next | → B"
    node_b2: "Node B | next | → NULL"
  }
  before -> after: "CAS({v:5,A}, {v:6,NEW})" {
    label: "atomic swap"
    style.stroke: "#2196F3"
    style.bold: true
  }
}
legend: {
  near: bottom-center
  label: "Linearization Point"
  content: |md
    The **successful CAS** is the linearization point.
    At this exact instant, the push "takes effect" and
    becomes visible to all other threads.
  |
}
success_path.style.font-color: "#2E7D32"
failure_path.style.font-color: "#C62828"