direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Treiber Stack: Lock-free LIFO Structure (treiber_stack.h)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row_before: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  
  initial_state: {
    direction: down
    label: "Memory Layout: Initial State"
    
    top_ptr_before: {
      shape: rectangle
      label: "stack->top (atomic)"
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
    }
    
    node_a: {
      shape: sql_table
      label: "Node A (0x7f00...)"
      f0: "value | int64_t | 42"
      f1: "next  | Node*   | → Node B"
    }
    
    node_b: {
      shape: sql_table
      label: "Node B (0x7f11...)"
      f0: "value | int64_t | 17"
      f1: "next  | Node*   | → Node C"
    }
    
    node_c: {
      shape: sql_table
      label: "Node C (bottom)"
      f0: "value | int64_t | 99"
      f1: "next  | Node*   | NULL"
    }
    
    null_node: {
      label: "NULL"
      shape: circle
      style.fill: "#FFEBEE"
    }
    
    top_ptr_before -> node_a: "0x08 | ptr"
    node_a -> node_b: "next"
    node_b -> node_c: "next"
    node_c -> null_node: "0x0"
  }
}

row_push: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  
  push_operation: {
    direction: down
    label: "Push Operation: CAS Loop Logic"
    
    step1: {
      label: "T1: Load Head"
      code: |'c
        // atomic_load ensures consistency
        old_top = atomic_load(&stack->top);
        // old_top now holds ptr to Node A
      '|
      width: 320
      style.fill: "#FFF3E0"
    }
    
    step2: {
      label: "T2: Link New Node"
      code: |'c
        new_node = malloc(sizeof(Node));
        new_node->val = 55;
        // Point to current head
        new_node->next = old_top; 
      '|
      width: 320
      style.fill: "#E3F2FD"
    }
    
    step3: {
      label: "T3: Commit Swap"
      code: |'c
        // Linearization point
        if (CAS(&stack->top, old_top, new_node))
          return SUCCESS;
        else
          goto retry; // Top changed
      '|
      width: 320
      style.fill: "#E8F5E9"
    }
    
    step1 -> step2 -> step3
  }
  
  push_visual: {
    direction: down
    label: "Post-Push Visual State"
    
    top_ptr_after: {
      shape: rectangle
      label: "stack->top"
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        stroke-width: 3
      }
    }
    
    new_node: {
      shape: sql_table
      label: "Node NEW (0x7f22...)"
      f0: "value | 55"
      f1: "next  | → Node A"
      style.fill: "#C8E6C9"
    }
    
    node_a_link: {
      shape: sql_table
      label: "Node A"
      f0: "value | 42"
      f1: "next  | → Node B"
      style.fill: "#FFF9C4"
    }
    
    dots: {
      label: "⋮"
      shape: text
    }
    
    top_ptr_after -> new_node: "CAS update"
    new_node -> node_a_link: "next"
  }
}

row_contended: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  
  thread_grid: {
    label: "Contention Scenario: Multiple Writers"
    direction: right
    
    t1: {
      label: "Thread 1 (Winner)"
      code: |'c
        old=A, new=X
        CAS(top, A, X)
        // Returns true
      '|
      style.fill: "#BBDEFB"
    }
    
    t2: {
      label: "Thread 2 (Retry)"
      code: |'c
        old=A, new=Y
        CAS(top, A, Y)
        // Returns false (top is X)
      '|
      style.fill: "#FFCDD2"
    }
    
    t3: {
      label: "Thread 3 (Retry)"
      code: |'c
        old=A, new=Z
        CAS(top, A, Z)
        // Returns false (top is X)
      '|
      style.fill: "#FFCDD2"
    }
    
    t2 -> t1: "interference" {style.stroke: red; style.stroke-dash: 3}
    t3 -> t1: "interference" {style.stroke: red; style.stroke-dash: 3}
  }
}

row_struct: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  
  definitions: {
    direction: down
    label: "C Implementation Details"
    
    node_struct: {
      shape: class
      label: "struct TreiberNode"
      +value: "int64_t"
      +next: "TreiberNode*"
    }
    
    stack_struct: {
      shape: class
      label: "struct TreiberStack"
      # Using prefix + to avoid keyword collision with 'top'
      +top: "_Atomic TaggedPtr"
    }
    
    tagged_struct: {
      shape: sql_table
      label: "struct TaggedPtr (ABA-safe)"
      f0: "0x00 | uint64_t | version // seq count"
      f1: "0x08 | Node*    | ptr     // address"
      sz: "Total: 16 bytes (Double-word CAS)"
    }
  }
  
  impl_notes: {
    label: "Implementation Notes"
    notes: |md
      - **Linearization Point**: The successful `atomic_compare_exchange_weak`.
      - **ABA Prevention**: 64-bit version tag incremented on every change.
      - **Hardware Requirements**: Requires `cmpxchg16b` on x86_64 for atomic 128-bit swap.
      - **Memory Management**: Use Hazard Pointers or Epoch-based Reclamation to prevent Use-After-Free during `pop`.
    |
    width: 350
    style.fill: "#E8EAF6"
  }
}

legend: {
  near: bottom-right
  grid-columns: 2
  l1: "🟢 SUCCESS PATH" { style.fill: "#C8E6C9" }
  l2: "🔴 CAS CONFLICT" { style.fill: "#FFCDD2" }
  l3: "🔵 DATA FLOW" { style.fill: "#BBDEFB" }
  l4: "🟡 SHARED DATA" { style.fill: "#FFF9C4" }
}