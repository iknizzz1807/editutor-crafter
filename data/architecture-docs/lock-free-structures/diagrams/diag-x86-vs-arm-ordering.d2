direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Platform Memory Model Differences
  **x86 TSO vs ARM Weak Ordering**
| {near: top-center}

row_compare: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  x86_section: {
    direction: down
    label: "x86 (TSO - Total Store Order)"
    
    x86_header: {
      shape: rectangle
      label: "x86 TSO\nStrong Memory Model"
      style.fill: "#4A90D9"
      style.font-color: white
      style.stroke: "#2E5A8C"
    }

    x86_guarantees: {
      shape: rectangle
      label: "Hardware Guarantees"
      width: 320
      g1: |md
        ✓ **Load-Load**: Preserved (In-Order)
        ✓ **Store-Store**: Preserved (In-Order)
        ✓ **Load-Store**: Preserved
        ✗ **Store-Load**: MAY REORDER
      |
    }

    x86_reorder: {
      shape: rectangle
      label: "Allowed Reordering"
      width: 320
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      r1: |md
        Thread A:
          store x ← 1
          load  r1 ← y   // May execute BEFORE store
        
        Store buffer holds writes (~50 cycles)
        Later loads can bypass buffered stores
      |
    }

    x86_barriers: {
      shape: sql_table
      label: "Barrier Instructions (x86)"
      f0: "mfence | Full fence | Prevents all reorderings"
      f1: "lfence | Load fence | Prevents Load-Load reorder"
      f2: "sfence | Store fence | Prevents Store-Store reorder"
      f3: "lock prefix | Atomic + full fence | lock cmpxchg"
      sz: "Note: mfence cost ~100-300 cycles"
    }

    x86_example: {
      label: "Safe Pattern on x86"
      width: 320
      code: |'c
        data = 42;
        // No hardware barrier needed!
        ready = 1;  // Store-Store preserved
        
        while (!ready); // spin
        use(data);      // Load-Load preserved
      '|
    }
  }

  arm_section: {
    direction: down
    label: "ARM (Weak Memory Ordering)"
    
    arm_header: {
      shape: rectangle
      label: "ARM Weak Ordering\nRelaxed Memory Model"
      style.fill: "#E67E22"
      style.font-color: white
      style.stroke: "#B35A00"
    }

    arm_guarantees: {
      shape: rectangle
      label: "Hardware Guarantees"
      width: 320
      g1: |md
        ✗ **Load-Load**: MAY REORDER
        ✗ **Store-Store**: MAY REORDER
        ✗ **Load-Store**: MAY REORDER
        ✗ **Store-Load**: MAY REORDER
      |
    }

    arm_reorder: {
      shape: rectangle
      label: "Allowed Reordering"
      width: 320
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      r1: |md
        Thread A:
          store x ← 1
          store y ← 1   // May become visible BEFORE x
        Thread B:
          load  r1 ← y  // Sees y=1
          load  r2 ← x  // But x=0!
      |
    }

    arm_barriers: {
      shape: sql_table
      label: "Barrier Instructions (ARM)"
      f0: "dmb sy | Full system | All memory ops complete"
      f1: "dmb ish | Inner shareable | Coherent with cores"
      f2: "dmb ishld | Load-load only | Acquire semantics"
      f3: "dmb ishst | Store-store only | Release semantics"
      f4: "ldar/stlr | Built-in | ARMv8 Acquire/Release"
      sz: "Note: dmb sy cost ~50-150 cycles"
    }

    arm_example: {
      label: "Safe Pattern on ARM"
      width: 320
      code: |'c
        data = 42;
        __asm__ volatile("dmb ish" ::: "memory");
        atomic_store_explicit(&ready, 1, release);
        
        while (atomic_load_explicit(&ready, acq) == 0);
        use(data); // Barrier ensures visibility
      '|
    }
  }
}

row_message: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  message_box: {
    label: "Message Passing: Relaxed vs Correct"
    width: 700
    desc: |md
      ### The Canonical Test Case
      Can Thread 2 observe `y == 1` but `x == 0` after Thread 1 writes `x = 1; y = 1;`?
    |
  }
}

row_matrix: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  x86_matrix_wrapper: {
    direction: down
    matrix_x86: {
      label: "x86 Reordering Matrix"
      grid-rows: 5
      grid-columns: 5
      grid-gap: 0
      h1: {label: ""; style.fill: "#E8E8E8"}
      h2: {label: "Load"; style.fill: "#E8E8E8"}
      h3: {label: "Store"; style.fill: "#E8E8E8"}
      h4: {label: "LL/SC"; style.fill: "#E8E8E8"}
      h5: {label: "Fence"; style.fill: "#E8E8E8"}
      r1: {label: "Load"; style.fill: "#E8E8E8"}
      c1: {label: "—"; style.fill: "#90EE90"}
      c2: {label: "—"; style.fill: "#90EE90"}
      c3: {label: "—"; style.fill: "#90EE90"}
      c4: {label: "—"; style.fill: "#90EE90"}
      r2: {label: "Store"; style.fill: "#E8E8E8"}
      c5: {label: "✗"; style.fill: "#FFB6C1"}
      c6: {label: "—"; style.fill: "#90EE90"}
      c7: {label: "—"; style.fill: "#90EE90"}
      c8: {label: "—"; style.fill: "#90EE90"}
      r3: {label: "LL/SC"; style.fill: "#E8E8E8"}
      c9: {label: "✗"; style.fill: "#FFB6C1"}
      c10: {label: "—"; style.fill: "#90EE90"}
      c11: {label: "—"; style.fill: "#90EE90"}
      c12: {label: "—"; style.fill: "#90EE90"}
      r4: {label: "Fence"; style.fill: "#E8E8E8"}
      c13: {label: "—"; style.fill: "#90EE90"}
      c14: {label: "—"; style.fill: "#90EE90"}
      c15: {label: "—"; style.fill: "#90EE90"}
      c16: {label: "—"; style.fill: "#90EE90"}
    }
    legend_x86: {
      shape: rectangle
      label: "— = Preserved | ✗ = May reorder (Store→Load only)"
      style.fill: "#F5F5F5"
    }
  }

  arm_matrix_wrapper: {
    direction: down
    matrix_arm: {
      label: "ARM Reordering Matrix"
      grid-rows: 5
      grid-columns: 5
      grid-gap: 0
      ah1: {label: ""; style.fill: "#E8E8E8"}
      ah2: {label: "Load"; style.fill: "#E8E8E8"}
      ah3: {label: "Store"; style.fill: "#E8E8E8"}
      ah4: {label: "LL/SC"; style.fill: "#E8E8E8"}
      ah5: {label: "Fence"; style.fill: "#E8E8E8"}
      ar1: {label: "Load"; style.fill: "#E8E8E8"}
      ac1: {label: "✗"; style.fill: "#FFB6C1"}
      ac2: {label: "✗"; style.fill: "#FFB6C1"}
      ac3: {label: "✗"; style.fill: "#FFB6C1"}
      ac4: {label: "—"; style.fill: "#90EE90"}
      ar2: {label: "Store"; style.fill: "#E8E8E8"}
      ac5: {label: "✗"; style.fill: "#FFB6C1"}
      ac6: {label: "✗"; style.fill: "#FFB6C1"}
      ac7: {label: "✗"; style.fill: "#FFB6C1"}
      ac8: {label: "—"; style.fill: "#90EE90"}
      ar3: {label: "LL/SC"; style.fill: "#E8E8E8"}
      ac9: {label: "✗"; style.fill: "#FFB6C1"}
      ac10: {label: "✗"; style.fill: "#FFB6C1"}
      ac11: {label: "—"; style.fill: "#90EE90"}
      ac12: {label: "—"; style.fill: "#90EE90"}
      ar4: {label: "Fence"; style.fill: "#E8E8E8"}
      ac13: {label: "—"; style.fill: "#90EE90"}
      ac14: {label: "—"; style.fill: "#90EE90"}
      ac15: {label: "—"; style.fill: "#90EE90"}
      ac16: {label: "—"; style.fill: "#90EE90"}
    }
    legend_arm: {
      shape: rectangle
      label: "— = Preserved | ✗ = May reorder (Most cases)"
      style.fill: "#F5F5F5"
    }
  }
}

row_c11: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  c11_mapping: {
    label: "C11/C++11 Memory Ordering → Hardware Barriers"
    width: 720
    mapping_table: {
      shape: sql_table
      label: "Mapping Table (atomic operations)"
      r0: "Ordering | x86 Instruction | ARM Instruction"
      r1: "relaxed | mov (no barrier) | ldr/str (no barrier)"
      r2: "acquire | compiler fence | ldar (load-acquire)"
      r3: "release | mov (TSO handles) | stlr (store-release)"
      r4: "acq_rel | mfence | dmb ish + ldar/stlr"
      r5: "seq_cst | mfence | dmb ish (full barrier)"
      sz: "ARMv8 ldar/stlr are more efficient than explicit dmb"
    }
    portability: {
      label: "Portability Rule"
      width: 680
      rule: |md
        ### ⚠️ Use explicit memory ordering — never rely on x86 behavior!
        Code that "works on x86" with `memory_order_relaxed` may silently fail on ARM.
        c
        atomic_store_explicit(&flag, 1, memory_order_release);
        while (atomic_load_explicit(&flag, memory_order_acquire) == 0);
        
      |
    }
  }
}

row_why: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  reasons_x86: {
    shape: rectangle
    label: "x86 Philosophy"
    width: 340
    style.fill: "#E8F4FD"
    content: |md
      **TSO**: Simple programming, fewer bugs.
      Optimized for single-thread performance
      with predictable multi-thread behavior.
    |
  }
  reasons_arm: {
    shape: rectangle
    label: "ARM Philosophy"
    width: 340
    style.fill: "#FDF4E8"
    content: |md
      **Weak**: Max hardware flexibility.
      Optimized for power efficiency.
      Allows aggressive store buffering.
    |
  }
}