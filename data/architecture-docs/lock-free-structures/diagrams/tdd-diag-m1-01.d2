vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |md
  # Memory Ordering Lattice
  ## C11 `<stdatomic.h>` Ordering Relationships
| {near: top-center}

# Lattice nodes - ordered from weakest to strongest
relaxed: "memory_order_relaxed" {
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
    font: mono
  }
  tooltip: "No synchronization, only atomicity"
}

consume: "memory_order_consume" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
    font: mono
  }
  tooltip: "Data-dependent ordering (rarely used)"
}

acquire: "memory_order_acquire" {
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
    font: mono
  }
  tooltip: "No reads/writes before can be reordered after"
}

release: "memory_order_release" {
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
    font: mono
  }
  tooltip: "No reads/writes after can be reordered before"
}

acq_rel: "memory_order_acq_rel" {
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
    font: mono
  }
  tooltip: "Combine acquire + release semantics"
}

seq_cst: "memory_order_seq_cst" {
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-width: 3
    font: mono
    bold: true
  }
  tooltip: "Total global ordering (strongest, default)"
}

# Lattice edges - "stronger than" relationships
# All stroke-widths corrected to integers (1-15)
relaxed -> acquire: "stronger" {
  style: {
    stroke: "#666"
    stroke-width: 2
  }
}

relaxed -> consume: {
  style: {
    stroke: "#666"
    stroke-width: 2
    stroke-dash: 3
  }
}

consume -> acquire: {
  style: {
    stroke: "#666"
    stroke-width: 2
    stroke-dash: 3
  }
}

relaxed -> release: "stronger" {
  style: {
    stroke: "#666"
    stroke-width: 2
  }
}

acquire -> acq_rel: "stronger" {
  style: {
    stroke: "#666"
    stroke-width: 2
  }
}

release -> acq_rel: "stronger" {
  style: {
    stroke: "#666"
    stroke-width: 2
  }
}

acq_rel -> seq_cst: "stronger" {
  style: {
    stroke: "#666"
    stroke-width: 2
  }
}

# Legend box
legend: {
  label: "Ordering Semantics"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 2
  }
  weak: "○ Weakest: No guarantees" {
    shape: text
    style: { font-size: 12 }
  }
  sync: "● Acquire/Release: Pairwise sync" {
    shape: text
    style: { font-size: 12 }
  }
  strong: "◆ Strongest: Total order" {
    shape: text
    style: { font-size: 12 }
  }
}
legend.near: bottom-right

# Cost annotation
cost: {
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FFC107"
  }
  label: ||md
**Relative Cost (x86)**
| Ordering | Cycles |
|----------|--------|
| relaxed  | ~1x    |
| acq/rel  | ~2-5x  |
| seq_cst  | ~10-100x |
||
}
cost.near: bottom-left