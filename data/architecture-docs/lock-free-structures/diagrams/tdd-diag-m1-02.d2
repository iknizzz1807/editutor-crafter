layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- DOCUMENT METADATA ---
title: |'md
  # CAS Loop Anatomy
  ### Atomic Compare-and-Swap (CAS) Instruction Cycle
  *Technical Specification for Lock-Free Synchronization*
'| {
  near: top-center
}

# --- GLOBAL STYLING ---
***.style.font-size: 16
***.style.font: mono

# --- STATE DEFINITIONS ---

step1_load: {
  label: "STEP 1: ATOMIC LOAD (ACQUIRE)"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }
  
  description: |'md
    **Hardware Operation:** `MOV [reg], [mem]`
    **Memory Ordering:** `memory_order_acquire`
    - Invalidate local cache line if MESI state is 'I'
    - Load `target` memory into local register `RAX`
    - Establish *happens-before* relationship
  '|
  
  registers: {
    shape: sql_table
    label: "Local CPU Registers (t=0)"
    RAX: "old_val (0x00)" { style.font-color: orange }
    RDI: "target_addr (0x7F...)" { style.font-color: blue }
    instruction: "MOV RAX, [RDI]"
  }
}

step2_compute: {
  label: "STEP 2: SPECULATIVE COMPUTATION"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
  }
  
  description: |'md
    **Pure Function:** `f(x) -> y`
    - Local computation in execution unit (ALU)
    - Speculative: assumes `RAX` is still valid
    - Minimal latency: typically 1-3 cycles
  '|
  
  registers: {
    shape: sql_table
    label: "Register State (t=1)"
    RAX: "old_val (Expected)"
    RBX: "**new_val** (RAX + Δ)" { style.font-color: red; style.bold: true }
    instruction: "LEA RBX, [RAX + 1]"
  }
}

step3_cas: {
  label: "STEP 3: LOCK CMPXCHG (ATOMIC)"
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
    bold: true
  }
  
  description: |'md
    **Atomic Primitive (Instruction Pointer):**
    asm
    lock cmpxchg [rdi], rbx
    
    1. **Lock Bus/Cache:** Assert `LOCK#` or lock cache line.
    2. **Compare:** `[RDI] == RAX?`
    3. **Swap:** If EQ, `[RDI] = RBX`. Else, `RAX = [RDI]`.
  '|
}

step4_success: {
  label: "LINEARIZATION POINT: SUCCESS"
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 4
    bold: true
  }
  
  description: |'md
    **Result Flags:** `ZF=1`
    - Value `new_val` is now globally visible
    - Memory Barrier: `Release` semantics enforced
    - Exit critical loop
  '|
}

step5_failure: {
  label: "CONFLICT: FAILURE (RETRY)"
  shape: rectangle
  style: {
    fill: "#FFCDD2"
    stroke: "#D32F2F"
    stroke-width: 2
  }
  
  description: |'md
    **Result Flags:** `ZF=0`
    - `[RDI]` was modified by another core (MESI: Remote Write)
    - `RAX` is automatically updated with *current* value of `[RDI]`
    - **Abort Path**
  '|
}

backoff: {
  label: "EXPONENTIAL BACKOFF"
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-dash: 3
    stroke-width: 2
  }
  
  description: |'md
    **Contention Mitigation:**
    - `PAUSE` instruction (Intel)
    - Prevents pipeline flush on memory violation
    - Reduces L3 cache traffic
  '|
}

# --- CONNECTIONS & FLOW ---

step1_load -> step2_compute: "Speculative Start" {
  style.stroke: "#666"
}

step2_compute -> step3_cas: "Invoke CAS" {
  style.stroke: "#666"
}

step3_cas -> step4_success: "ZF=1 (Match)" {
  label: "COMMIT"
  style.stroke: "#388E3C"
  style.stroke-width: 4
}

step3_cas -> step5_failure: "ZF=0 (Mismatch)" {
  label: "STALE DATA"
  style.stroke: "#D32F2F"
  style.stroke-width: 4
}

step5_failure -> backoff: "High Contention" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 4
}

backoff -> step1_load: "Retry with jitter" {
  style: {
    stroke: "#9C27B0"
    stroke-dash: 3
    animated: true
  }
}

step5_failure -> step1_load: "Tight Loop" {
  style: {
    stroke: "#666"
    stroke-dash: 5
  }
}

# --- ANNOTATIONS ---

timing_annotation: {
  near: top-right
  shape: text
  label: |'md
    ### Architectural Note:
    **Linearization Point**
    The precise clock cycle where 
    the atomic swap is validated by the 
    memory controller or cache coherency
    logic (MESI Protocol).
  '|
  style: {
    font-size: 14
    italic: true
    font-color: "#555"
  }
}

# Fix: Use |'md ... '| to prevent the table pipes | from terminating the block prematurely
legend: |'md
  **Timing Summary (Intel x86-64 Skylake+)**

  | Phase        | Latency (Cycles) | HW Barrier |
  |--------------|------------------|------------|
  | **Load**     | 4-5 (L1 Hit)     | Acquire    |
  | **Compute**  | 1-3              | N/A        |
  | **CAS**      | 18-40 (Uncont.)  | Lock/Total |
  | **Failure**  | 100+ (Miss)      | N/A        |
'| {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#CCC"
    font-size: 12
  }
}

# --- STYLING GLOBS ---
(step3_cas -> step4_success)[0]: {
  target-arrowhead: * {
    shape: triangle
    style.filled: true
  }
}

(step3_cas -> step5_failure)[0]: {
  target-arrowhead: * {
    shape: triangle
    style.filled: true
  }
}