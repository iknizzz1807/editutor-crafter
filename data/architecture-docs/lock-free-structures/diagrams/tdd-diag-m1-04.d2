layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B5B95"
    ptr: "#E69138"
    data: "#45818E"
    metadata: "#6AA84F"
    text: "#333333"
    padding: "#BDBDBD"
    bg: "#FFFFFF"
    cache: "#C00000"
  }
}

title: |'md
  # TaggedPtr Memory Layout
  **16 bytes total** • **16-byte aligned** for atomic `lock cmpxchg16b`
'| {
  near: top-center
}

# Explicit Size Annotation in top right
size_box: {
  near: top-right
  total: "sizeof(TaggedPtr) = 16 bytes" {
    style.font: mono
    style.font-size: 14
    style.font-color: ${colors.text}
  }
  align: "alignof(TaggedPtr) = 16" {
    style.font: mono
    style.font-size: 14
    style.font-color: ${colors.text}
  }
  style.stroke: transparent
}

# Main Layout Container
layout_container: {
  style.fill: ${colors.bg}
  style.stroke: "#000000"
  style.stroke-width: 1

  # Memory Table using a Grid
  memory_grid: {
    grid-columns: 3
    vertical-gap: 0
    horizontal-gap: 30
    style.stroke: transparent

    # --- ROW 0: HEADERS ---
    h1: "Offset" { style: { font-color: ${colors.header}; bold: true; stroke: transparent } }
    h2: "Field Layout (RDX:RAX)" { style: { font-color: ${colors.header}; bold: true; stroke: transparent } }
    h3: "Description & Constraints" { style: { font-color: ${colors.header}; bold: true; stroke: transparent } }

    # --- ROW 1: VERSION FIELD ---
    o0: "0x00" {
      height: 80
      style: { stroke: transparent; font: mono; font-size: 16 }
    }
    version_block: "uint64_t version" {
      height: 80
      width: 320
      style: {
        fill: ${colors.metadata}
        stroke: ${colors.text}
        stroke-width: 2
        bold: true
      }
    }
    version_note: |'md
      **ABA Protection Counter**
      Loaded into **RDX** register.
      Incremented on every successful CAS.
    '| {
      style.stroke: transparent
      style.font-size: 12
    }

    # --- ROW 2: POINTER FIELD ---
    o8: "0x08" {
      height: 80
      style: { stroke: transparent; font: mono; font-size: 16 }
    }
    ptr_block: "uintptr_t ptr" {
      height: 80
      width: 320
      style: {
        fill: ${colors.ptr}
        stroke: ${colors.text}
        stroke-width: 2
        bold: true
      }
    }
    ptr_note: |'md
      **Payload/Node Address**
      Loaded into **RAX** register.
      Must be 8-byte aligned if pointing to nodes.
    '| {
      style.stroke: transparent
      style.font-size: 12
    }

    # --- ROW 3: BOUNDARY ---
    o16: "0x10" {
      style: { stroke: transparent; font: mono; font-size: 16; bold: true }
    }
    boundary: "Next Allocation / Alignment Boundary" {
      height: 30
      style: {
        fill: ${colors.padding}
        stroke-dash: 3
        opacity: 0.6
      }
    }
    boundary_note: "16-byte boundary required for hardware CAS." {
      style.stroke: transparent
      style.font-size: 11
      style.italic: true
    }
  }

  # Cache Line Indicator
  cache_boundary: "" {
    width: 650
    height: 0
    style: {
      stroke: ${colors.cache}
      stroke-width: 3
      stroke-dash: 5
    }
    label: "64B Cache Line Alignment Segment"
    label.near: outside-bottom-center
    style.font-color: ${colors.cache}
    style.bold: true
  }
}

# Technical Implementation Metadata
footer_info: {
  near: bottom-center
  grid-columns: 2
  grid-gap: 40
  style.stroke: transparent

  assertions: |'md
    ### Atomic Invariants
    c
    #include <stdatomic.h>
    #include <assert.h>

    // Static check for CAS compatibility
    _Static_assert(sizeof(TaggedPtr) == 16, 
      "TaggedPtr must be 128 bits");
    
    _Static_assert(_Alignof(TaggedPtr) == 16, 
      "Strict 16-byte alignment required");
    
  '| {
    style: { fill: "#fdfdfd"; stroke: "#cccccc"; border-radius: 4 }
  }

  bit_logic: |'md
    ### Register State (x86_64)
    When performing `cmpxchg16b`:
    1. `RDX` contains high 64 bits (`version`)
    2. `RAX` contains low 64 bits (`ptr`)
    3. `RCX:RBX` contains the *new* `version:ptr`
    4. Destination must be 16-byte aligned in memory.
  '| {
    style: { fill: "#fdfdfd"; stroke: "#cccccc"; border-radius: 4 }
  }
}

# Visual Legend
legend: {
  near: bottom-left
  direction: right
  l1: {
    m: "" { width: 20; height: 20; style.fill: ${colors.metadata} }
    t: "Metadata (Version)" { style.stroke: transparent; style.font-size: 11 }
  }
  l2: {
    m: "" { width: 20; height: 20; style.fill: ${colors.ptr} }
    t: "Pointer (Data)" { style.stroke: transparent; style.font-size: 11 }
  }
  l3: {
    m: "" { width: 20; height: 20; style.fill: ${colors.padding} }
    t: "Alignment/Padding" { style.stroke: transparent; style.font-size: 11 }
  }
}