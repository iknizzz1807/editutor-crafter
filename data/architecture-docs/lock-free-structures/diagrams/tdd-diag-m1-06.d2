vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # x86 vs ARM Memory Model Comparison
  **Allowed Reorderings in Concurrent Memory Access**
| {near: top-center}
direction: right
# ============================================================================
# x86 TSO (Total Store Order)
# ============================================================================
x86_section: x86-64: Total Store Order (TSO) {
  style.fill: "#E8F4E8"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  x86_desc: |md
    **Strong Memory Model**
    Most reorderings prevented by hardware.
    Only store→load reordering allowed.
  | {shape: text}
  x86_allowed: ALLOWED Reorderings {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    store_load: Store → Load {
      style.fill: "#FFECB3"
      style.stroke: "#F57C00"
      sl_desc: |md
        **Store-Load Reordering**
        
        x = 1;      // Store
        r = y;      // Load
        
        CPU may execute load before store
        completes (store buffer).
        *Only reordering allowed on x86!*
      | {shape: text}
    }
  }
  x86_prevented: PREVENTED Reorderings {
    style.fill: "#A5D6A7"
    style.stroke: "#388E3C"
    x86_ll: Load → Load {
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
      ll_desc: |md
        Loads execute in order
      | {shape: text}
    }
    x86_ss: Store → Store {
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
      ss_desc: |md
        Stores visible in order
      | {shape: text}
    }
    x86_ls: Load → Store {
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
      ls_desc: |md
        Load completes before store
      | {shape: text}
    }
    x86_ll -> x86_ss -> x86_ls
  }
  x86_note: |md
    **Implication**: Code that "works" on x86
    may break on ARM without explicit barriers.
    Store buffer causes store→load reordering
    (typically 50-100 cycle window).
  | {shape: text}
}
# ============================================================================
# ARM (Weakly Ordered)
# ============================================================================
arm_section: ARM: Weakly Ordered Memory Model {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  arm_desc: |md
    **Weak Memory Model**
    Hardware allows most reorderings for
    performance. Explicit barriers required.
  | {shape: text}
  arm_allowed: ALL Reorderings ALLOWED {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    arm_sl: Store → Load {
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      arm_sl_desc: |md
        Store → Load ✓
      | {shape: text}
    }
    arm_ll: Load → Load {
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      arm_ll_desc: |md
        Load → Load ✓
      | {shape: text}
    }
    arm_ss: Store → Store {
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      arm_ss_desc: |md
        Store → Store ✓
      | {shape: text}
    }
    arm_ls: Load → Store {
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      arm_ls_desc: |md
        Load → Store ✓
      | {shape: text}
    }
    arm_sl -> arm_ll -> arm_ss -> arm_ls
  }
  arm_note: |md
    **Implication**: Any relaxed code that
    "works" on x86 is likely BROKEN on ARM!
    Always use acquire/release semantics
    for portable concurrent code.
  | {shape: text}
}
# ============================================================================
# Comparison Matrix
# ============================================================================
comparison: Reordering Comparison Matrix {
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  grid-columns: 3
  grid-gap: 0
  header_op: Operation {
    class: header
  }
  header_x86: x86 TSO {
    class: header
  }
  header_arm: ARM Weak {
    class: header
  }
  row1_op: Store → Load
  row1_x86: ✓ ALLOWED {
    style.fill: "#FFECB3"
  }
  row1_arm: ✓ ALLOWED {
    style.fill: "#FFCDD2"
  }
  row2_op: Load → Load
  row2_x86: ✗ Prevented {
    style.fill: "#C8E6C9"
  }
  row2_arm: ✓ ALLOWED {
    style.fill: "#FFCDD2"
  }
  row3_op: Store → Store
  row3_x86: ✗ Prevented {
    style.fill: "#C8E6C9"
  }
  row3_arm: ✓ ALLOWED {
    style.fill: "#FFCDD2"
  }
  row4_op: Load → Store
  row4_x86: ✗ Prevented {
    style.fill: "#C8E6C9"
  }
  row4_arm: ✓ ALLOWED {
    style.fill: "#FFCDD2"
  }
}
classes: {
  header: {
    style: {
      fill: "#455A64"
      font-color: white
      bold: true
    }
  }
}
# ============================================================================
# Message-Passing Example
# ============================================================================
example: Message-Passing Bug Demonstration {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  example_code: |md
    **The Bug That Hides on x86**
    c
    // Thread 1 (Producer)
    data = 42;              // (1) Store data
    ready = 1;              // (2) Store flag
    // Thread 2 (Consumer)  
    while (!ready) {}       // (3) Load flag
    print(data);            // (4) Load data
    
  | {shape: text}
  x86_result: x86 Result {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    x86_outcome: |md
      **Usually Works** (by accident)
      Store→Store prevented: (1) before (2)
      Load→Load prevented: (3) before (4)
      But: Store→Load CAN reorder!
      Rare edge cases may still fail.
    | {shape: text}
  }
  arm_result: ARM Result {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    arm_outcome: |md
      **BROKEN Without Barriers!**
      All reorderings possible:
      - (2) may be visible before (1)
      - (4) may execute before (3)
      Consumer may see `ready=1` but
      `data=0` (uninitialized)!
    | {shape: text}
  }
  x86_result -> arm_result: Same Code\, Different Results {
    style.stroke: "#7B1FA2"
    style.stroke-dash: 3
    style.font-color: "#7B1FA2"
  }
}
# ============================================================================
# Solution
# ============================================================================
solution: Portable Solution {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  solution_code: |md
    **Always Use Acquire/Release Semantics**
    c
    // Thread 1 (Producer)
    data = 42;
    atomic_store_explicit(&ready, 1, memory_order_release);
    // Thread 2 (Consumer)
    while (atomic_load_explicit(&ready, memory_order_acquire) == 0) {}
    print(data);  // Guaranteed to see 42
    
    **Release** ensures all prior writes visible before the store.
    **Acquire** ensures all subsequent reads see data after the load.
    Works correctly on **both** x86 and ARM!
  | {shape: text}
}
x86_section -> comparison -> example -> solution