vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: "Atomic Wrapper API Architecture" {
  style: {
    font-size: 32
    bold: true
    underline: true
    font-color: "#2E2E2E"
  }
  near: top-center
}

# ============================================================================
# Core Atomic Operations Container
# ============================================================================
core_ops: "Core Atomic Operations" {
  style: {
    fill: "#E8F4FD"
    stroke: "#2E86AB"
    stroke-width: 3
    double-border: true
  }

  load_ops: "Load Operations" {
    style.fill: "#B8D4E8"
    load_int: ||md
      ### atomic_load_int
      `int atomic_load_int(atomic_int_t*, order)`
      - **RELAXED**: ~3 cycles
      - **ACQUIRE**: ~3-5 cycles
      - **SEQ_CST**: ~10-20 cycles
    ||
    load_u64: ||md
      ### atomic_load_u64
      `uint64_t atomic_load_u64(atomic_u64_t*, order)`
      - 8-byte aligned access
    ||
    load_ptr: ||md
      ### atomic_load_ptr
      `uintptr_t atomic_load_ptr(atomic_ptr_t*, order)`
      - Native word-size atomicity
    ||
  }

  store_ops: "Store Operations" {
    style.fill: "#B8D4E8"
    store_int: ||md
      ### atomic_store_int
      `void atomic_store_int(atomic_int_t*, value, order)`
      - **RELAXED**: ~3 cycles
      - **RELEASE**: ~3-10 cycles
    ||
    store_u64: ||md
      ### atomic_store_u64
      `void atomic_store_u64(atomic_u64_t*, value, order)`
    ||
    store_ptr: ||md
      ### atomic_store_ptr
      `void atomic_store_ptr(atomic_ptr_t*, value, order)`
    ||
  }

  cas_ops: "Compare-and-Swap Operations" {
    style.fill: "#C8E6C9"
    cas_int: ||md
      ### atomic_cas_int
      `CASResult atomic_cas_int(addr, expected, desired, success_order, failure_order)`
      - **Uncontended**: ~10-20 cycles
      - **Contended**: ~100-500 cycles
    ||
    cas_weak: ||md
      ### atomic_cas_weak_int
      - Spurious failure allowed
      - Optimized for LL/SC (ARM/PowerPC)
    ||
    cas_u64: ||md
      ### atomic_cas_u64
      - `lock cmpxchg` on x86
    ||
  }

  fetch_ops: "Fetch-and-Modify Operations" {
    style.fill: "#FFF9C4"
    fetch_add: ||md
      ### atomic_fetch_add_int
      `int atomic_fetch_add_int(addr, delta, order)`
      - Returns **OLD** value
      - x86: `lock xadd` instruction
    ||
    fetch_sub: ||md
      ### atomic_fetch_sub_int
      `int atomic_fetch_sub_int(addr, delta, order)`
    ||
  }
}

# ============================================================================
# Tagged Pointer Operations Container (ABA Prevention)
# ============================================================================
tagged_ops: "Tagged Pointer Operations (16-byte)" {
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 3
    shadow: true
  }

  tagged_types: "Memory Layouts" {
    style.fill: "#E1BEE7"
    tagged_ptr: ||md
      ### TaggedPtr Struct
      c
      struct TaggedPtr {
        uint64_t version;  // Offset 0x00 (8 bytes)
        uintptr_t ptr;     // Offset 0x08 (8 bytes)
      } // Total sizeof: 16 bytes
      
      - Aligned to 16-byte boundary
      - Prevents ABA via versioning
    ||
    cas_result: ||md
      ### TaggedCASResult
      c
      struct TaggedCASResult {
        bool success;
        TaggedPtr observed;
      }
      
    ||
  }

  tagged_funcs: "API Functions" {
    style.fill: "#E1BEE7"
    tagged_load: ||md
      **atomic_load_tagged**
      - Uses `VMOVDBQA` or `lock cmpxchg16b`
    ||
    tagged_cas: ||md
      **atomic_cas_tagged**
      - `cmpxchg16b` on x86_64
      - Compares 128-bit block atomically
    ||
  }
}

# ============================================================================
# Backoff and Synchronization
# ============================================================================
backoff: "Backoff Utilities" {
  style.fill: "#FFECB3"
  backoff_state: ||md
    ### BackoffState
    c
    struct BackoffState {
      uint32_t delay;
      uint32_t max_delay;
    }
    
  ||
  backoff_funcs: ||md
    - **backoff_wait**: Exponential Pause
    - **cpu_pause**: x86 `pause`, ARM `isb/yield`
  ||
}

# ============================================================================
# Shared Types and Ordering
# ============================================================================
result_types: "Result Types" {
  style.fill: "#FFCDD2"
  cas_result: ||md
    ### CASResult
    c
    struct CASResult {
      bool success;
      uintptr_t observed;
    }
    
    - Allows retry without re-loading
  ||
}

ordering: "Memory Ordering Constants" {
  style.fill: "#B2DFDB"
  order_consts: ||md
    - **ORDER_RELAXED**: No ordering
    - **ORDER_ACQUIRE**: Load-Load, Load-Store barrier
    - **ORDER_RELEASE**: Store-Store, Load-Store barrier
    - **ORDER_SEQ_CST**: Total global ordering
  ||
}

# ============================================================================
# Relationships
# ============================================================================
core_ops.cas_ops -> result_types: "returns success/observed"
core_ops.load_ops -> ordering: "configured by"
core_ops.store_ops -> ordering: "configured by"
core_ops.cas_ops -> ordering: "configured by"
core_ops.fetch_ops -> ordering: "configured by"
tagged_ops.tagged_funcs -> tagged_ops.tagged_types: "operates on"
tagged_ops.tagged_funcs -> result_types: "returns result"
backoff -> core_ops.cas_ops: "mitigates contention"

# ============================================================================
# Documentation & Legend
# ============================================================================
legend: ||md
  ### Performance & Implementation Guide
  | Operation | Uncontended | Contended (High) | Arch Instruction |
  | :--- | :--- | :--- | :--- |
  | **Load (relaxed)** | ~3 cycles | ~3 cycles | `mov` |
  | **Store (release)** | ~3-10 cycles | ~10-20 cycles | `mov` (x86) / `stlr` (ARM) |
  | **CAS (int)** | ~10-20 cycles | ~100-500 cycles | `lock cmpxchg` |
  | **Fetch-Add** | ~10-15 cycles | ~100-300 cycles | `lock xadd` |
  | **Tagged CAS** | ~20-30 cycles | ~200-500 cycles | `lock cmpxchg16b` |

  **ABA Prevention Protocol:**
  - Tagged pointers must be 16-byte aligned.
  - The `version` counter must be incremented on every `tagged_ptr_next` call.
|| {
  near: bottom-center
}