vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    thread_color: "#4A90D9"
    counter_color: "#E74C3C"
    result_color: "#27AE60"
    cas_color: "#9B59B6"
    fetch_color: "#F39C12"
    mem_header: "#6C3483"
    padding: "#BDC3C7"
  }
}

title: |'md
  # Counter Stress Test Data Flow & Memory Specification
  **Scenario: N threads × M increments → Atomic Counter → Final Verification**
  *Intel x86-64 Instruction Level Detail*
'| {
  near: top-center
  shape: text
}

# ============================================================================
# Thread Pool Implementation
# ============================================================================
threads: "Worker Thread Pool (N)" {
  style.fill: ${colors.thread_color}
  style.stroke: "#2E5A8C"
  style.stroke-width: 2
  style.shadow: true

  t0: "Thread 0\n[TID: 0x401]" {
    shape: person
    style.fill: "#D0E1F9"
  }
  t1: "Thread 1\n[TID: 0x402]" {
    shape: person
    style.fill: "#D0E1F9"
  }
  t_ellipsis: "..." {
    shape: text
    style.font-size: 24
    style.bold: true
  }
  tN: "Thread N-1\n[TID: 0x4FF]" {
    shape: person
    style.fill: "#D0E1F9"
  }
}

# ============================================================================
# CAS Loop Path (Software-Driven Atomics)
# ============================================================================
cas_path: "CAS Loop Path (Algorithm A)" {
  style.fill: "#F5E6FF"
  style.stroke: ${colors.cas_color}
  style.double-border: true

  cas_load: "1. atomic_load(&counter)\n`MOV EAX, [ptr]`\nacquire ordering" {
    style.fill: "#E8D4F8"
    style.stroke-dash: 0
  }
  cas_compute: "2. new_val = old_val + 1" {
    shape: diamond
    style.fill: "#D4B8E8"
  }
  cas_attempt: "3. LOCK CMPXCHG [ptr], EDX\nAtomic swap if equal" {
    style.fill: ${colors.cas_color}
    style.font-color: white
    style.bold: true
  }
  cas_retry: "CAS Failed?\nZF=0 (ZF is Zero Flag)" {
    shape: diamond
    style.fill: "#C9A8D8"
  }

  cas_load -> cas_compute: "Register Read"
  cas_compute -> cas_attempt: "Set Expected"
  cas_attempt -> cas_retry: "Status Flag"
  cas_retry -> cas_load: "YES (Contention)\nRetry Loop" {
    style.stroke-dash: 3
    style.animated: true
    style.stroke: red
  }
}

# ============================================================================
# Fetch-Add Path (Hardware-Optimized Atomics)
# ============================================================================
fetch_path: "Fetch-Add Path (Algorithm B)" {
  style.fill: "#FFF5E6"
  style.stroke: ${colors.fetch_color}
  style.double-border: true

  fetch_op: "LOCK XADD [ptr], 1\nSingle Instruction\nImplicit Bus Lock" {
    style.fill: ${colors.fetch_color}
    style.font-color: white
    style.bold: true
  }
  fetch_return: "Retire Instruction\nReturns PREVIOUS Value" {
    style.fill: "#FFE4B3"
  }

  fetch_op -> fetch_return: "O(1) Success"
}

# ============================================================================
# Shared Atomic Counter & Memory Alignment
# ============================================================================
counter: "Shared Atomic Memory (Target)" {
  shape: cylinder
  style.fill: ${colors.counter_color}
  style.font-color: white
  style.stroke: "#C0392B"
  style.stroke-width: 4

  mem_layout: |'md
    ### Memory Layout (Intel x86-64)
    | Offset | Field | Size | Details |
    | :--- | :--- | :--- | :--- |
    | 0x00 | **counter** | 4B | Aligned 32-bit Integer |
    | 0x04 | **padding** | 60B | Cache-line Alignment |
    | **0x40** | **-** | - | **Next Cache Line** |

    **Protocol:** MESI (Modified, Exclusive, Shared, Invalid)
    **Contention:** Cache line bounces between cores
  '| {
    style.font-size: 14
  }
}

# ============================================================================
# Final Verification Logic
# ============================================================================
verification: "Verification & Assertion" {
  style.fill: ${colors.result_color}
  style.font-color: white
  style.stroke: "#1E8449"

  expected: "Expected Sum:\nTotal = N * M" {
    shape: hexagon
    style.fill: "#2ECC71"
  }
  actual: "Actual State:\natomic_load(&counter)" {
    shape: hexagon
    style.fill: "#2ECC71"
  }
  compare: "Equality Assert" {
    shape: diamond
    style.fill: "#58D68D"
    style.font-color: black
  }
  pass: "PASS ✓\nNo Lost Updates" {
    shape: circle
    style.fill: "#27AE60"
    style.bold: true
  }
  fail: "FAIL ✗\nRace Detected" {
    shape: circle
    style.fill: "#E74C3C"
    style.bold: true
  }

  expected -> compare
  actual -> compare
  compare -> pass: "Result == Total" {
    style.stroke: "#27AE60"
    style.stroke-width: 3
  }
  compare -> fail: "Result < Total" {
    style.stroke: "#E74C3C"
    style.stroke-width: 3
  }
}

# ============================================================================
# Global Data Flow
# ============================================================================
threads.t0 -> cas_path: "Loop Start" { style.stroke: ${colors.cas_color} }
threads.t1 -> fetch_path: "Loop Start" { style.stroke: ${colors.fetch_color} }
threads.tN -> cas_path: "Loop Start" { style.stroke: ${colors.cas_color} }

cas_path.cas_attempt -> counter: "Write Transaction" {
  style.stroke: ${colors.cas_color}
  style.stroke-width: 4
  target-arrowhead.shape: diamond
}
fetch_path.fetch_op -> counter: "Atomic Operation" {
  style.stroke: ${colors.fetch_color}
  style.stroke-width: 4
  target-arrowhead.shape: diamond
}
counter -> verification.actual: "Final Barrier Load" {
  style.stroke: ${colors.counter_color}
  style.stroke-width: 3
}

# ============================================================================
# Legend & Performance Specs
# ============================================================================
legend: "Architectural Legend" {
  near: bottom-right
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  
  cas: "CAS Loop (Retries possible)" {
    style.fill: ${colors.cas_color}
    style.font-color: white
  }
  fetch: "XADD (Single instruction)" {
    style.fill: ${colors.fetch_color}
    style.font-color: white
  }
  sync: "L1 Cache Barrier" {
    style.stroke-dash: 5
    style.stroke: ${colors.counter_color}
  }
}

perf_notes: |'md
  ## Performance Analysis (Simulated)
  | Thread Count | CAS Latency | Fetch-Add Latency | Scalability |
  | :--- | :--- | :--- | :--- |
  | 1 | 45 cycles | 15 cycles | N/A |
  | 4 | 240 cycles | 85 cycles | High |
  | 16 | 980 cycles | 310 cycles | Moderate |
  | 64 | 4,200 cycles | 950 cycles | Low |

  **Observations:**
  1. CAS overhead grows non-linearly with thread count due to retry loops.
  2. Fetch-Add remains faster as it avoids branch prediction misses from retries.
  3. Bus contention on the cache line is the primary bottleneck for both.
'| {
  near: bottom-left
  style.font-size: 14
}