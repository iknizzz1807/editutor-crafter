vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5E3"
    version: "#7C3AED"
    ptr: "#2563EB"
    border: "#6B7280"
    annotation: "#6B7280"
    cache: "#10B981"
  }
}

title: |md
  # Tagged Pointer 16-Byte Layout
  **Double-Width CAS via cmpxchg16b (x86-64)**
| {near: top-center}

direction: right

# Main memory layout structure
layout: {
  # Container for the 16-byte structure
  structure: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: ${colors.border}
      stroke-width: 2
    }
    
    # Version field (8 bytes)
    version: {
      label: "version: uint64_t\nOffset: 0x00\nSize: 8 bytes"
      shape: rectangle
      width: 220
      height: 70
      style: {
        fill: ${colors.version}
        stroke: ${colors.border}
        font-color: white
        bold: true
      }
    }
    
    # Pointer field (8 bytes)
    ptr: {
      label: "ptr: uintptr_t\nOffset: 0x08\nSize: 8 bytes"
      shape: rectangle
      width: 220
      height: 70
      style: {
        fill: ${colors.ptr}
        stroke: ${colors.border}
        font-color: white
        bold: true
      }
    }
    
    version -> ptr: { style.stroke: transparent }
  }

  # Byte offset annotations on left margin
  offsets: {
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
    off0: "0x00"
    off8: "0x08"
    off10: "0x10"
    
    off0 -> off8 -> off10: { style.stroke: transparent }
  }

  # Map offsets to the structure boundaries
  offsets.off0 -> structure.version: { 
    style: {
      stroke-dash: 3
      stroke: ${colors.annotation}
    }
  }
  
  # Cache line overlay definition
  cache_line: {
    label: "Cache Line (64 bytes)\nTaggedPtr occupies bytes 0-15"
    shape: rectangle
    width: 240
    height: 180
    style: {
      fill: transparent
      stroke: ${colors.cache}
      stroke-dash: 5
      stroke-width: 2
    }
  }
  
  cache_line -> structure: { style.stroke: transparent }
}

# Right side: architectural alignment requirements
requirements: {
  shape: rectangle
  width: 320
  style: {
    fill: ${colors.header}
    stroke: ${colors.border}
    border-radius: 8
  }
  title: "**Alignment Requirements**"
  req1: "• sizeof(TaggedPtr) = 16 bytes"
  req2: "• alignof(TaggedPtr) = 16 bytes"
  req3: "• Fits in single cache line"
  req4: "• cmpxchg16b requires 16-byte alignment"
  
  title -> req1 -> req2 -> req3 -> req4: { style.stroke: transparent }
}

layout -> requirements: " "

# Bottom section: version counter logic
semantics: {
  shape: rectangle
  width: 550
  style: {
    fill: "#FEF3C7"
    stroke: ${colors.border}
    border-radius: 8
  }
  stitle: "**Version Counter Semantics**"
  content: |md
    • Monotonically increases on every CAS operation
    • Prevents ABA problem via version mismatch detection
    • Wraps after 2^64 modifications (practically infinite)
    • CAS compares BOTH ptr AND version atomically via RDX:RAX
  |
  stitle -> content: { style.stroke: transparent }
}

layout -> semantics: { style.stroke: transparent }

# Bottom-right: Static assertions for engineers
assertions: {
  near: bottom-right
  shape: rectangle
  width: 350
  style: {
    fill: "#FEE2E2"
    stroke: "#DC2626"
    border-radius: 4
    font: mono
    font-size: 13
  }
  label: |md
    **Compile-time Verification (C11/C++11):**
    c
    static_assert(sizeof(TaggedPtr) == 16,
      "TaggedPtr must be 16 bytes");
    static_assert(alignof(TaggedPtr) == 16,
      "TaggedPtr must be 16-byte aligned");
    
  |
}

# Diagram Legend
legend: {
  near: bottom-left
  shape: rectangle
  style: {
    fill: white
    stroke: ${colors.border}
    border-radius: 4
  }
  ltitle: "**Field Legend**"
  lver: {
    label: "Version (Tag)"
    shape: rectangle
    width: 100
    style.fill: ${colors.version}
    style.font-color: white
  }
  lptr: {
    label: "Data Pointer"
    shape: rectangle
    width: 100
    style.fill: ${colors.ptr}
    style.font-color: white
  }
  lcache: {
    label: "Cache Boundary"
    shape: rectangle
    width: 100
    style: {
      fill: transparent
      stroke: ${colors.cache}
      stroke-dash: 3
    }
  }
  
  ltitle -> lver -> lptr -> lcache: { style.stroke: transparent }
}