direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B5B95"
    data: "#4A90A4"
    free: "#7CB342"
    padding: "#9E9E9E"
    pointer: "#FF8C00"
    changed: "#DC143C"
    success: "#228B22"
    neutral: "#F5F5F5"
    code_bg: "#2D2D2D"
  }
}

title: |md
  # Treiber Stack Push: Step-by-Step CAS Protocol
  ### Linearization Point: Successful CAS on top
| {near: top-center}

# -----------------------------------------------------------------------------
# STEP 1: ALLOCATION
# -----------------------------------------------------------------------------
step1: {
  label: "Step 1: Allocate New Node"
  style.stroke-width: 2
  
  s1_container: {
    direction: right
    style.stroke-width: 0
    
    s1_before: "BEFORE" {
      s1_stack_before: {
        label: "Stack State"
        shape: rectangle
        style.fill: ${colors.neutral}
        s1_top_ptr: "top → NULL" {
          shape: text
          style.font-color: ${colors.pointer}
          style.bold: true
        }
      }
    }
    
    s1_arrow: "→" {
      shape: text
      style.font-size: 24
    }
    
    s1_after: "AFTER" {
      s1_stack_after: {
        label: "Stack (unchanged)"
        shape: rectangle
        style.fill: ${colors.neutral}
        s1_top_ptr2: "top → NULL" {
          shape: text
          style.font-color: ${colors.pointer}
        }
      }
      s1_new_node: {
        label: "new_node (allocated)\n─────────────\nvalue: 42\nnext: ???\naddr: 0x1000"
        shape: rectangle
        style.fill: ${colors.changed}
        style.stroke: ${colors.changed}
        style.bold: true
      }
    }
  }

  impl_note: |md
    ### Implementation Detail
    c
    Node* new_node = malloc(sizeof(Node));
    new_node->value = 42;
    // new_node->next set in Step 3
    
  | {
    style.stroke-dash: 3
    style.fill: "#FFF9C4"
  }
}

# -----------------------------------------------------------------------------
# STEP 2: LOAD
# -----------------------------------------------------------------------------
step2: {
  label: "Step 2: Load Current Top"
  
  s2_code: |c
  TaggedPtr old_top;
  do {
    // ACQUIRE: see all prior writes
    old_top = atomic_load_explicit(
      &stack->top, 
      memory_order_acquire
    );
  | {
    shape: rectangle
    style.fill: ${colors.code_bg}
    style.font-color: "#F8F8F2"
  }
  
  s2_state_viz: {
    direction: right
    style.stroke-width: 0
    
    s2_state: {
      label: "CPU Registers"
      shape: rectangle
      style.fill: ${colors.neutral}
      s2_old_top: {
        label: "old_top\n──────────\nversion: 5\nptr: 0x2000"
        shape: rectangle
        style.fill: ${colors.data}
        style.bold: true
      }
    }
    
    s2_stack: {
      label: "Stack Memory"
      shape: rectangle
      style.fill: ${colors.neutral}
      s2_top_tagged: {
        label: "top = {v:5, ptr:0x2000}"
        shape: rectangle
        style.fill: ${colors.header}
        style.font-color: white
      }
      s2_node_a: "Node A @ 0x2000\nvalue: 10\nnext: NULL" {
        shape: rectangle
        style.fill: ${colors.data}
      }
      s2_top_tagged -> s2_node_a: "points to"
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 3: LINK
# -----------------------------------------------------------------------------
step3: {
  label: "Step 3: Link New Node"
  
  s3_code: |c
  // Link new node to old top
  new_node->next = old_top.ptr;
  // Prepare new tagged pointer
  TaggedPtr new_top = {
    .version = old_top.version + 1,
    .ptr = new_node
  };
  | {
    shape: rectangle
    style.fill: ${colors.code_bg}
    style.font-color: "#F8F8F2"
  }
  
  s3_viz: {
    direction: right
    style.stroke-width: 0
    
    s3_state: {
      s3_new_node: {
        label: "new_node @ 0x1000\n──────────────\nvalue: 42\nnext: 0x2000 ← LINKED"
        shape: rectangle
        style.fill: ${colors.changed}
        style.bold: true
      }
      s3_new_top: {
        label: "new_top (register)\n──────────────\nversion: 6 (= 5+1)\nptr: 0x1000"
        shape: rectangle
        style.fill: ${colors.data}
        style.bold: true
      }
      s3_new_node -> s3_new_top: "prepared" {
        style.stroke-dash: 3
      }
    }
  }

  aba_note: |md
    **Key Insight**: Version increment prevents the **ABA problem**.
    Even if address `0x2000` is recycled, the version tag `6` will not match the stale tag `5`.
  | {
    style.italic: true
    style.fill: "#E1F5FE"
  }
}

# -----------------------------------------------------------------------------
# STEP 4: CAS
# -----------------------------------------------------------------------------
step4: {
  label: "Step 4: CAS (Atomic Exchange)"
  
  s4_code: |c
  // ATTEMPT ATOMIC SWAP
  bool success = atomic_compare_exchange_weak_explicit(
    &stack->top,
    &old_top,      // IN/OUT: expected
    new_top,       // Desired value
    memory_order_release, // Publish writes
    memory_order_acquire  // See winner's writes
  );
  if (success) return; // Push complete!
  | {
    shape: rectangle
    style.fill: ${colors.code_bg}
    style.font-color: "#F8F8F2"
  }
  
  s4_outcome: {
    label: "Execution Branching"
    s4_success: {
      label: "SUCCESS PATH"
      shape: rectangle
      style.fill: ${colors.success}
      style.font-color: white
      s4_s_note: |md
        1. top == old_top
        2. Atomic swap: top = new_top
        3. **Linearization Point Reached**
      | {shape: text}
    }
    s4_fail: {
      label: "FAILURE PATH"
      shape: rectangle
      style.fill: ${colors.changed}
      style.font-color: white
      s4_f_note: |md
        1. top != old_top (Contention)
        2. old_top updated to current value
        3. Retry from Step 2
      | {shape: text}
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 5: FINAL STATE
# -----------------------------------------------------------------------------
step5: {
  label: "Step 5: Final Result (Successful Push)"
  
  s5_compare: {
    direction: right
    style.stroke-width: 0
    
    s5_before: "BEFORE CAS" {
      s5_b_stack: {
        label: "top → {v:5, ptr:0x2000}"
        shape: rectangle
        style.fill: ${colors.neutral}
      }
      s5_b_node: "Node A @ 0x2000" {
        shape: rectangle
        style.fill: ${colors.data}
      }
      s5_b_stack -> s5_b_node
    }
    
    s5_arrow: "CAS\nSUCCESS" {
      shape: text
      style.bold: true
      style.font-color: ${colors.success}
    }
    
    s5_after: "AFTER CAS" {
      s5_a_stack: {
        label: "top → {v:6, ptr:0x1000}"
        shape: rectangle
        style.fill: ${colors.success}
        style.bold: true
      }
      s5_a_new: "Node NEW @ 0x1000\nvalue: 42\nnext: 0x2000" {
        shape: rectangle
        style.fill: ${colors.changed}
        style.bold: true
      }
      s5_a_old: "Node A @ 0x2000" {
        shape: rectangle
        style.fill: ${colors.data}
      }
      s5_a_stack -> s5_a_new
      s5_a_new -> s5_a_old: "next"
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 6: CONTENTION
# -----------------------------------------------------------------------------
step6: {
  label: "Step 6: Retry on Contention"
  
  s6_viz: {
    direction: right
    style.stroke-width: 0
    
    s6_scenario: {
      label: "The Race Condition"
      s6_t1: "Thread 1 (Preempted)" {
        style.fill: "#E3F2FD"
        s6_t1_state: "Loaded {v:5, ptr:0x2000}" { shape: text }
      }
      s6_t2: "Thread 2 (Winner)" {
        style.fill: "#E8F5E9"
        s6_t2_action: "Succeeds CAS first!" {
          style.bold: true
          style.font-color: ${colors.success}
        }
      }
      s6_t1 -> s6_t2: "Time" { style.stroke-width: 1 }
    }
    
    s6_result: {
      label: "T1 Reaction"
      s6_fail_state: {
        label: "CAS FAILS\nExpected: v5, 0x2000\nActual: v6, 0x3000"
        shape: rectangle
        style.fill: ${colors.changed}
        style.bold: true
        style.font-color: white
      }
      s6_retry: {
        label: "Retry Loop"
        style.fill: ${colors.header}
        style.font-color: white
        s6_retry_note: "1. Refresh top\n2. Re-link\n3. Re-try CAS" { shape: text }
      }
      s6_fail_state -> s6_retry: "Restart"
    }
  }

  guarantee_note: |md
    ### Progress Guarantee: Lock-Free
    System-wide progress is guaranteed. While Thread 1 retries, it is because **Thread 2 successfully completed an operation**. No global deadlocks are possible.
  | {
    style.bold: true
    style.fill: "#F1F8E9"
  }
}

# -----------------------------------------------------------------------------
# MEMORY LAYOUT
# -----------------------------------------------------------------------------
memory_layout: {
  label: "Memory Representation"
  
  ml_struct: {
    label: "TaggedPtr Struct (16 Bytes)"
    shape: rectangle
    style.fill: ${colors.neutral}
    
    ml_version: {
      label: "version\nSize: 8B | Offset: 0x00"
      shape: rectangle
      style.fill: ${colors.header}
      style.font-color: white
    }
    ml_ptr: {
      label: "ptr (pointer)\nSize: 8B | Offset: 0x08"
      shape: rectangle
      style.fill: ${colors.pointer}
    }
  }

  hardware_note: |md
    ### Hardware Requirement
    Requires **DWCAS** (Double-Width Compare and Swap) like `cmpxchg16b` on x86_64 to ensure both pointer and version are swapped atomically.
  | {
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
  }
}

# -----------------------------------------------------------------------------
# FLOW CONNECTIONS
# -----------------------------------------------------------------------------
step1 -> step2 -> step3 -> step4 -> step5: "Normal Execution Path" {
  style.stroke-dash: 5
  style.animated: true
}

step4 -> step6: "On Contention" {
  style.stroke: ${colors.changed}
  style.stroke-dash: 3
}