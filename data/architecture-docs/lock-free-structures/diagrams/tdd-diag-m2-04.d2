vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    changed: "#DC2626"
    normal: "#374151"
    pointer: "#7C3AED"
    success: "#16A34A"
    empty: "#9CA3AF"
  }
}
title: |md
  # Pop Operation Step-by-Step
  ### Treiber Stack with Tagged Pointer (16 bytes)
| {near: top-center}
direction: right
# =============================================================================
# STEP 1: Load Tagged Top
# =============================================================================
step1: {
  label: "Step 1: Load Tagged Top"
  before1: {
    label: "State Before"
    style.fill: "#F3F4F6"
    style.stroke: "#9CA3AF"
    stack1: {
      label: "TreiberStack"
      style.fill: "#EDE9FE"
      style.stroke: "#7C3AED"
      top1: "top (16 bytes)\n┌─────────────────────┐\n│ version: 5          │\n│ ptr: ────────────────┼──┐\n└─────────────────────┘   │\n                          ▼"
    }
    nodeA: {
      label: "Node A\nvalue: 42\nnext: ──► Node B"
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
    }
    nodeB: {
      label: "Node B\nvalue: 17\nnext: ──► Node C"
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
    }
    nodeC: {
      label: "Node C\nvalue: 99\nnext: NULL"
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
    }
    stack1 -> nodeA: "ptr"
    nodeA -> nodeB: "next"
    nodeB -> nodeC: "next"
  }
  arrow1: " ──► " {
    shape: text
    style.font-size: 20
    style.bold: true
  }
  code1: {
    label: |md
  c
  TaggedPtr old_top;
  old_top = atomic_load_explicit(
      &stack->top,
      memory_order_acquire
  );
  
  **Result:**
  - `old_top.version = 5`
  - `old_top.ptr = &NodeA`
|
    shape: rectangle
    style.fill: "#1F2937"
    style.stroke: "#374151"
    style.font-color: "#F9FAF8"
    style.font: mono
    width: 320
  }
}
# =============================================================================
# STEP 2: Check Empty
# =============================================================================
step2: {
  label: "Step 2: Check Empty"
  check2: {
    label: |md
  c
  if (old_top.ptr == NULL) {
      return {success: false, value: 0};
  }
  // old_top.ptr == &NodeA != NULL
  // Continue...
  
|
    shape: rectangle
    style.fill: "#1F2937"
    style.stroke: "#374151"
    style.font-color: "#F9FAF8"
    style.font: mono
    width: 320
  }
  note2: |md
  **Empty Stack Check:**
  If `old_top.ptr == NULL`, the stack
  is empty. Return failure immediately
  without any CAS operation.
  In this case, stack is NOT empty.
| {
    shape: rectangle
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
  }
}
# =============================================================================
# STEP 3: Read Next Pointer
# =============================================================================
step3: {
  label: "Step 3: Read Next (Protected)"
  state3: {
    label: "State During Read"
    style.fill: "#F3F4F6"
    style.stroke: "#9CA3AF"
    stack3: {
      label: "TreiberStack"
      style.fill: "#EDE9FE"
      style.stroke: "#7C3AED"
      top3: "top\n{version:5, ptr:NodeA}"
    }
    nodeA3: {
      label: "Node A\nvalue: 42\nnext: ──► Node B"
      style.fill: "${colors.changed}"
      style.stroke: "${colors.changed}"
      style.bold: true
      style.font-color: white
    }
    nodeB3: {
      label: "Node B\nvalue: 17\nnext: ──► Node C"
      style.fill: "${colors.changed}"
      style.stroke: "${colors.changed}"
      style.bold: true
      style.font-color: white
    }
    nodeC3: {
      label: "Node C\nvalue: 99\nnext: NULL"
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
    }
    stack3 -> nodeA3: "ptr"
    nodeA3 -> nodeB3: "next"
    nodeB3 -> nodeC3: "next"
  }
  code3: {
    label: |md
  c
  // Hazard pointer protection (M4)
  hp_protect(0, old_top.ptr);
  // Validate protection is current
  // (set-then-validate protocol)
  // Read next pointer BEFORE CAS
  new_top.ptr = old_top.ptr->next;
  // new_top.ptr = &NodeB
  new_top.version = old_top.version + 1;
  // new_top.version = 6
  
|
    shape: rectangle
    style.fill: "#1F2937"
    style.stroke: "#374151"
    style.font-color: "#F9FAF8"
    style.font: mono
    width: 340
  }
  note3: |md
  **Key Insight:**
  Read `next` BEFORE CAS attempt.
  After successful CAS, another thread
  might pop again and the node could
  be retired. Reading while protected
  ensures safe access.
  **Version increments to 6** to
  prevent ABA problem.
| {
    shape: rectangle
    style.fill: "#DCFCE7"
    style.stroke: "${colors.success}"
  }
}
# =============================================================================
# STEP 4: CAS Top
# =============================================================================
step4: {
  label: "Step 4: CAS Top (Linearization Point)"
  before4: {
    label: "Before CAS"
    style.fill: "#FEF2F2"
    style.stroke: "${colors.changed}"
    old4: {
      label: "old_top\n{version: 5, ptr: NodeA}"
      style.fill: "${colors.changed}"
      style.stroke: "${colors.changed}"
      style.font-color: white
    }
    new4: {
      label: "new_top\n{version: 6, ptr: NodeB}"
      style.fill: "${colors.success}"
      style.stroke: "${colors.success}"
      style.font-color: white
    }
    arrow4: "CAS(&stack->top, old_top, new_top)"
  }
  cas_code4: {
    label: |md
  c
  bool success = atomic_compare_exchange_weak_explicit(
      &stack->top,
      &old_top,      // Updated on failure
      new_top,
      memory_order_release,  // Success
      memory_order_acquire   // Failure
  );
  if (success) {
      // LINEARIZATION POINT
      // Pop is now visible to all threads
  }
  
|
    shape: rectangle
    style.fill: "#1F2937"
    style.stroke: "#374151"
    style.font-color: "#F9FAF8"
    style.font: mono
    width: 360
  }
  note4: |md
  **CAS Semantics:**
  Atomic operation that:
  1. Compares `stack->top` with `old_top`
     (BOTH version AND ptr, 16 bytes)
  2. If equal: stores `new_top`, returns true
  3. If not equal: updates `old_top` to
     current value, returns false
  **Weak variant** allows spurious failure
  in loops (more efficient on ARM).
| {
    shape: rectangle
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
  }
}
# =============================================================================
# STEP 5: Return Value (Success)
# =============================================================================
step5: {
  label: "Step 5: Return Value (CAS Succeeded)"
  after5: {
    label: "State After"
    style.fill: "#F0FDF4"
    style.stroke: "${colors.success}"
    stack5: {
      label: "TreiberStack"
      style.fill: "#EDE9FE"
      style.stroke: "#7C3AED"
      top5: "top (16 bytes)\n┌─────────────────────┐\n│ version: 6 ✓        │\n│ ptr: ────────────────┼──┐\n└─────────────────────┘   │\n                          ▼"
    }
    nodeA5: {
      label: "Node A\nvalue: 42\n(ORPHANED)"
      style.fill: "#FEE2E2"
      style.stroke: "${colors.changed}"
      style.stroke-dash: 3
      style.font-color: "${colors.changed}"
    }
    nodeB5: {
      label: "Node B\nvalue: 17\nnext: ──► Node C"
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
    }
    nodeC5: {
      label: "Node C\nvalue: 99\nnext: NULL"
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
    }
    stack5 -> nodeB5: "ptr"
    nodeB5 -> nodeC5: "next"
    orphan5: nodeA5 -> nodeB5: "dangling" {
      style.stroke-dash: 3
      style.stroke: "${colors.changed}"
    }
  }
  code5: {
    label: |md
  c
  // CAS succeeded!
  // Read value while we have reference
  int64_t value = old_top.ptr->value;
  // value = 42
  // Release hazard protection
  hp_release(0);
  // Retire old node for safe reclamation
  hp_retire(old_top.ptr);  // M4
  return (PopResult){
      .success = true,
      .value = 42
  };
  
|
    shape: rectangle
    style.fill: "#1F2937"
    style.stroke: "#374151"
    style.font-color: "#F9FAF8"
    style.font: mono
    width: 320
  }
  note5: |md
  **Result:**
  ✓ `success = true`
  ✓ `value = 42`
  ✓ Version incremented: 5 → 6
  ✓ Node A orphaned (retired to M4)
  **Memory Safety (M4):**
  Node A is retired, not freed.
  Scan will free when no hazard
  pointers protect it.
| {
    shape: rectangle
    style.fill: "#DCFCE7"
    style.stroke: "${colors.success}"
  }
}
# =============================================================================
# Step flow
# =============================================================================
step1 -> step2: ""
step2 -> step3: "not empty"
step3 -> step4: ""
step4 -> step5: "CAS success"
# =============================================================================
# Legend
# =============================================================================
legend: {
  label: "Legend"
  near: bottom-center
  changed: {
    label: "Changed/Active"
    style.fill: "${colors.changed}"
    style.font-color: white
  }
  normal: {
    label: "Unchanged"
    style.fill: "#DBEAFE"
  }
  orphan: {
    label: "Orphaned (Retired)"
    style.fill: "#FEE2E2"
    style.stroke-dash: 3
  }
  success: {
    label: "Success/Result"
    style.fill: "${colors.success}"
    style.font-color: white
  }
}
# =============================================================================
# Key invariants
# =============================================================================
invariants: {
  label: |md
  ### Key Invariants
  1. **Version always increments** on each successful CAS
     - Prevents ABA: even if ptr recycles, version differs
  2. **16-byte atomic CAS** compares BOTH fields atomically
     - Uses `cmpxchg16b` on x86-64
  3. **Linearization point** = successful CAS
     - All threads agree on operation order at this instant
  4. **Memory ordering**:
     - Acquire on load: see prior writes
     - Release on CAS success: publish our writes
     - Acquire on CAS failure: see winner's writes
|
  near: bottom-center
  shape: rectangle
  style.fill: "#F8FAFC"
  style.stroke: "#64748B"
}