vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    normal: "#4A5568"
    danger: "#E53E3E"
    success: "#38A169"
    warning: "#DD6B20"
    info: "#3182CE"
    memory: "#718096"
  }
}

title: |md
  # ABA Attack Timeline
  ### Thread 1's CAS succeeds on recycled memory
| {
  near: top-center
  style: {
    font-size: 24
    stroke-width: 0
  }
}

# The sequence diagram is placed inside a container to allow 'near' positioning 
# for labels and titles at the parent level, bypassing the sequence-diagram constraint.
ABA_Scenario: {
  
  Timeline: {
    shape: sequence_diagram

    Thread_1: Thread 1\n(Attacker) {
      style: {
        fill: "#FED7D7"
        stroke: "${colors.danger}"
      }
    }

    Shared_Stack: Shared Stack\n(Memory) {
      style: {
        fill: "#E2E8F0"
        stroke: "${colors.normal}"
      }
    }

    Thread_2: Thread 2\n(Victim) {
      style: {
        fill: "#BEE3F8"
        stroke: "${colors.info}"
      }
    }

    # --- T0: INITIAL STATE ---
    Thread_1."T0: Initial State"
    Shared_Stack."Stack Layout: A → B → C → NULL"

    # --- PHASE 1: ATTAKER STARTS ---
    Thread_1 -> Shared_Stack: 1. Load old_top = A
    Thread_1 -> Shared_Stack: 2. Read A->next = B
    
    # Preemption marker using a note
    Thread_1.p1: "3. ⚠️ PREEMPTED" {
      style: {
        stroke: "${colors.danger}"
        bold: true
        font-color: "${colors.danger}"
      }
    }

    # --- PHASE 2: VICTIM INTERFERENCE ---
    Thread_2 -> Shared_Stack: 4. pop() → CAS(top, A, B)
    Shared_Stack."Stack: B → C" {
      style.font-color: "${colors.info}"
    }

    Thread_2 -> Shared_Stack: 5. pop() → CAS(top, B, C)
    Shared_Stack."Stack: C" {
      style.font-color: "${colors.info}"
    }

    Thread_2 -> Shared_Stack: 6. free(A), free(B)
    
    Thread_2 -> Shared_Stack: 7. push(X)
    Shared_Stack."Stack: X → C\n(X re-uses A's address!)" {
      style: {
        bold: true
        font-color: "${colors.warning}"
      }
    }

    # --- PHASE 3: ATTACKER RESUMES ---
    Thread_1.r1: "8. 🔄 RESUMES" {
      style: {
        stroke: "${colors.success}"
        bold: true
      }
    }

    Thread_1 -> Shared_Stack: 9. CAS(top, A, B)
    
    Shared_Stack -> Shared_Stack: "Check: top == old_top (A)?"
    Shared_Stack -> Shared_Stack: "✓ YES (Address matches X)" {
      style: {
        font-color: "${colors.success}"
        bold: true
      }
    }

    Shared_Stack -> Shared_Stack: "Action: top = B"
    
    # --- RESULT: CORRUPTION ---
    Thread_1.err: "💥 CORRUPTION" {
      style: {
        fill: "${colors.danger}"
        font-color: white
        stroke-width: 4
      }
    }
    Shared_Stack."ERROR: Top now points\nto FREED memory (B)!" {
      style: {
        font-color: "${colors.danger}"
        bold: true
      }
    }
  }
}

Danger_Note: |md
  ### The Trap (ABA Problem)
  - **The Comparison:** Thread 1's CAS compares the **memory address**, not the content or a version tag.
  - **Memory Recycling:** Node **A** was freed and Node **X** was allocated at that exact same address.
  - **False Positive:** CAS succeeds because `current_top (X @ addr A) == old_top (A)`.
  - **Corruption:** Thread 1 installs `B` as the new top, but `B` was already freed and potentially overwritten.
| {
  near: bottom-center
  style: {
    stroke: "${colors.danger}"
    stroke-width: 2
    fill: "#FFF5F5"
    border-radius: 8
  }
}

# Apply global styles for arrows
(ABA_Scenario.Timeline.** -> ABA_Scenario.Timeline.**)[*]: {
  style: {
    stroke: "${colors.normal}"
    font-size: 14
  }
}

# Highlight the successful but incorrect CAS
(ABA_Scenario.Timeline.Thread_1 -> ABA_Scenario.Timeline.Shared_Stack)[2]: {
  style: {
    stroke: "${colors.success}"
    stroke-width: 3
    animated: true
  }
}