vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    thread-a: "#4A90D9"
    thread-b: "#D94A4A"
    thread-c: "#4AD94A"
    cas-success: "#FFD700"
    timeline: "#333333"
    label-bg: "#F5F5F5"
    border: "#2E2E2E"
    pointer: "#FF8C00"
  }
}

title: |md
  # Linearization Points: Concurrent Stack Operations
  ### Successful CAS (Compare-And-Swap) defines the atomic instant of state transition
| {near: top-center}

direction: right

# Global Timeline Header
timeline_container: {
  style.fill: transparent
  style.stroke: transparent
  
  timeline_label: "Real-Time Timeline (Execution History)" {
    shape: text
    style.font-size: 20
    style.bold: true
  }
  
  time_axis: {
    shape: rectangle
    width: 1200
    height: 40
    style.fill: ${colors.timeline}
    style.stroke: ${colors.timeline}
    style.border-radius: 2
    
    labels: {
      grid-columns: 4
      grid-gap: 280
      style.stroke: transparent
      t0: "T₀ (Start)" {shape: text; style.font-color: white; style.font-size: 14}
      t1: "T₁" {shape: text; style.font-color: white; style.font-size: 14}
      t2: "T₂" {shape: text; style.font-color: white; style.font-size: 14}
      t3: "T_end" {shape: text; style.font-color: white; style.font-size: 14}
    }
  }
}

# The core execution grid representing concurrent threads
thread_operations: {
  grid-rows: 3
  grid-columns: 1
  grid-gap: 40
  style.stroke: transparent

  # --- THREAD A ---
  thread_a: {
    label: "Thread A (TID: 0x101) | Op: push(42)"
    style.fill: "#F0F7FF"
    style.stroke: ${colors.thread-a}
    style.stroke-width: 2
    style.border-radius: 8
    
    ops: {
      direction: right
      style.stroke: transparent
      
      step1: "1. Load 'top'\n(old = S0)" {
        shape: rectangle
        style.fill: "#E8F4FC"
        style.stroke: ${colors.thread-a}
      }
      
      step2: "2. node.next = old\n(Local Prep)" {
        shape: rectangle
        style.fill: "#E8F4FC"
        style.stroke: ${colors.thread-a}
      }
      
      step3: "3. CAS(top, old, node)\n★ LINEARIZATION POINT" {
        shape: rectangle
        style.fill: ${colors.cas-success}
        style.stroke: "#B8860B"
        style.bold: true
        style.font-size: 16
        tooltip: "Linearization point: The moment push(42) becomes visible to all threads."
      }
      
      step4: "4. Return SUCCESS" {
        shape: rectangle
        style.fill: "#90EE90"
        style.stroke: "#228B22"
      }

      stack_view: "Stack Post-A:\n[42] -> [S0] -> ..." {
        shape: rectangle
        style.fill: ${colors.label-bg}
        style.font: mono
        style.stroke-dash: 3
      }
      
      step1 -> step2 -> step3 -> step4 -> stack_view
    }
  }

  # --- THREAD B ---
  thread_b: {
    label: "Thread B (TID: 0x202) | Op: pop()"
    style.fill: "#FFF5F5"
    style.stroke: ${colors.thread-b}
    style.stroke-width: 2
    style.border-radius: 8
    
    ops: {
      direction: right
      style.stroke: transparent
      
      wait: "Blocking/Concurrent\nLatency" {
        style.fill: transparent
        style.stroke: ${colors.thread-b}
        style.stroke-dash: 5
        width: 150
      }
      
      step1: "1. Load 'top'\n(old = 42)" {
        shape: rectangle
        style.fill: "#FCE8E8"
        style.stroke: ${colors.thread-b}
      }
      
      step2: "2. next = old.next\n(Local Prep)" {
        shape: rectangle
        style.fill: "#FCE8E8"
        style.stroke: ${colors.thread-b}
      }
      
      step3: "3. CAS(top, 42, S0)\n★ LINEARIZATION POINT" {
        shape: rectangle
        style.fill: ${colors.cas-success}
        style.stroke: "#B8860B"
        style.bold: true
        style.font-size: 16
        tooltip: "Linearization point: The moment 42 is logically removed from the stack."
      }
      
      step4: "4. Return 42" {
        shape: rectangle
        style.fill: "#90EE90"
        style.stroke: "#228B22"
      }

      stack_view: "Stack Post-B:\n[S0] -> ..." {
        shape: rectangle
        style.fill: ${colors.label-bg}
        style.font: mono
        style.stroke-dash: 3
      }
      
      wait -> step1 -> step2 -> step3 -> step4 -> stack_view
    }
  }

  # --- THREAD C ---
  thread_c: {
    label: "Thread C (TID: 0x303) | Op: push(99)"
    style.fill: "#F5FFF5"
    style.stroke: ${colors.thread-c}
    style.stroke-width: 2
    style.border-radius: 8
    
    ops: {
      direction: right
      style.stroke: transparent
      
      wait: "Awaiting Previous\nOperations" {
        style.fill: transparent
        style.stroke: ${colors.thread-c}
        style.stroke-dash: 5
        width: 350
      }
      
      step1: "1. Load 'top'\n(old = S0)" {
        shape: rectangle
        style.fill: "#E8FCE8"
        style.stroke: ${colors.thread-c}
      }
      
      step2: "2. node.next = old" {
        shape: rectangle
        style.fill: "#E8FCE8"
        style.stroke: ${colors.thread-c}
      }
      
      step3: "3. CAS(top, S0, node)\n★ LINEARIZATION POINT" {
        shape: rectangle
        style.fill: ${colors.cas-success}
        style.stroke: "#B8860B"
        style.bold: true
        style.font-size: 16
      }
      
      step4: "4. Return SUCCESS" {
        shape: rectangle
        style.fill: "#90EE90"
        style.stroke: "#228B22"
      }

      stack_view: "Stack Post-C:\n[99] -> [S0] -> ..." {
        shape: rectangle
        style.fill: ${colors.label-bg}
        style.font: mono
        style.stroke-dash: 3
      }
      
      wait -> step1 -> step2 -> step3 -> step4 -> stack_view
    }
  }
}

# Shared State Pointer Visualization (The 'top' variable)
shared_state: {
  shape: sql_table
  style.fill: "#FFFEEB"
  
  atomic_variable: "Shared Variable: atomic<Node*> top"
}

# Cross-thread dependencies and temporal constraints
inter_thread_constraints: {
  style.stroke: transparent
  
  (thread_operations.thread_a.ops.step4 -> thread_operations.thread_b.ops.step1): "A Finish -> B Start" {
    style.stroke: "#666"
    style.stroke-dash: 4
    style.animated: true
  }
  
  (thread_operations.thread_b.ops.step4 -> thread_operations.thread_c.ops.step1): "B Finish -> C Start" {
    style.stroke: "#666"
    style.stroke-dash: 4
    style.animated: true
  }
}

# Footer Analysis
analysis: {
  near: bottom-center
  grid-columns: 2
  grid-gap: 50
  
  invariant_box: |md
    ### Real-Time Ordering Invariant
    **Requirement:** If operation $Op_1$ completes before $Op_2$ starts, then $LP(Op_1) < LP(Op_2)$.
    **Observation:**
    - $Op_A$ (Push 42) completes at $T_1$.
    - $Op_B$ (Pop) starts after $T_1$.
    - Therefore, the stack *must* contain 42 when $Op_B$ linearizes.
  | {
    style.fill: "#FFFEEB"
    style.stroke: "#D4AF37"
    style.border-radius: 8
  }

  legal_history: |md
    ### Sequential History
    The linearized execution sequence is:
    1. `Push(42)` at $LP_A$
    2. `Pop() -> 42` at $LP_B$
    3. `Push(99)` at $LP_C$
    
    *Valid Stack History: [] -> [42] -> [] -> [99]*
  | {
    style.fill: "#EBFBFF"
    style.stroke: "#37A1D4"
    style.border-radius: 8
  }
}

# Documentation Legend
legend_panel: {
  near: bottom-right
  style.fill: "#FFF"
  style.stroke: "#CCC"
  style.border-radius: 4
  
  cas: "Successful CAS" {
    style.fill: ${colors.cas-success}
    style.stroke: "#B8860B"
    style.bold: true
  }
  local: "Local Computation" {
    style.fill: "#E8E8E8"
    style.stroke: "#AAA"
  }
  success: "Finalized State" {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
}