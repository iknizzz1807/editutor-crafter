vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# =============================================================================
# HEADER & DOCUMENTATION
# =============================================================================
title: |md
  # Cache Line Ping-Pong Under Contention
  **MESI Protocol State Transitions During Concurrent CAS Operations**
  *Intel® Architecture Optimization Reference Manual Style*
| {near: top-center}

# =============================================================================
# STYLING CLASSES
# =============================================================================
classes: {
  state_M: {
    style: {
      fill: "#DC2626"
      font-color: white
      bold: true
      stroke: "#991B1B"
    }
  }
  state_E: {
    style: {
      fill: "#16A34A"
      font-color: white
      bold: true
      stroke: "#14532D"
    }
  }
  state_S: {
    style: {
      fill: "#2563EB"
      font-color: white
      bold: true
      stroke: "#1E3A8A"
    }
  }
  state_I: {
    style: {
      fill: "#6B7280"
      font-color: white
      bold: true
      stroke: "#374151"
    }
  }
  invalidation_flow: {
    style: {
      stroke: "#DC2626"
      stroke-width: 3
      stroke-dash: 4
      animated: true
    }
  }
  transition_success: {
    style: {
      stroke: "#16A34A"
      stroke-width: 2
    }
  }
}

# =============================================================================
# MEMORY LAYOUT: 64-BYTE CACHE LINE
# =============================================================================
# Rule 1: Exact byte offsets left, sizes right. Purple=Header, Blue=Data, Gray=Padding.
memory_layout: "Physical Memory Representation (alignas(64))" {
  style: {
    stroke: black
    stroke-width: 4
    stroke-dash: 5
  }
  
  grid-columns: 3
  grid-gap: 0
  
  # Row 0: Header
  o0: "0x00" {shape: text}
  f0: "Control Header" {
    style.fill: "#C084FC"
    style.font-color: white
    width: 400
  }
  s0: "[8 Bytes]" {shape: text}

  # Row 1: Padding 1
  o1: "0x08" {shape: text}
  f1: "Padding (Hardware Dead-Zone)" {
    style.fill: "#94A3B8"
    style.font-color: white
  }
  s1: "[24 Bytes]" {shape: text}

  # Row 2: ATOMIC TARGET
  o2: "0x20" {shape: text}
  f2: "ATOMIC_VAL (CAS Target)" {
    style.fill: "#3B82F6"
    style.font-color: white
    style.bold: true
    style.double-border: true
  }
  s2: "[8 Bytes]" {shape: text}

  # Row 3: Padding 2
  o3: "0x28" {shape: text}
  f3: "Padding (Hardware Dead-Zone)" {
    style.fill: "#94A3B8"
    style.font-color: white
  }
  s3: "[24 Bytes]" {shape: text}

  # Footer
  o4: "0x40" {shape: text}
  f4: "PAGE_BOUNDARY / NEXT_LINE" {
    style.stroke-dash: 2
    style.fill: transparent
  }
  s4: "Total: 64B" {shape: text}
}

# =============================================================================
# MESI STATE TRANSITION SEQUENCE
# =============================================================================
# Rule 4: Participants, Lock acquire/release, normal=blue, error=red.
# Rule 5: Transitions with triggers and actions.
ping_pong: {
  shape: sequence_diagram
  
  core0: "Intel Core (0)" {
    shape: person
    style.fill: "#DBEAFE"
  }
  bus: "System Interconnect / L3" {
    style.stroke-dash: 5
  }
  core1: "Intel Core (1)" {
    shape: person
    style.fill: "#FEF3C7"
  }

  core0.m: "STATE: M" {class: state_M}
  
  # Step 1: Local CAS
  "core0 -> core0": "LOCK CMPXCHG [Success] {"
    tooltip: "Executed in local cache (M state)"
  }
  
  # Step 2: Contention Begins
  core1.rfo: "Atomic Write"
  core1.rfo -> bus: BusRdX (Request For Ownership)
  
  # Step 3: Snoop & Invalidate
  bus -> core0: Invalidate (Snoop Hit) {class: invalidation_flow}
  core0 -> core0: **M → I** {class: state_I}
  core0 -> bus: ACK + Data Forward (Modified Line)
  
  # Step 4: Ownership Migration
  bus -> core1: Data + Ownership {class: transition_success}
  core1 -> core1: **I → M** {class: state_M}
  
  # Step 5: Core 1 Success
  "core1 -> core1": "LOCK CMPXCHG [Success]"
  
  # Step 6: Ping-Pong Back
  core0.retry: "CAS Retry"
  core0.retry -> bus: BusRdX
  bus -> core1: Invalidate {class: invalidation_flow}
  core1 -> core1: **M → I** {class: state_I}
# REMOVED (extra closing brace): }

# =============================================================================
# METRICS TABLE
# =============================================================================
latency_metrics: "Architecture Latency Metrics" {
  m: "" {
    grid-columns: 3
    grid-gap: 0
    style.fill: "#FFFFFF"
    
    # Header
    h1: "Operation Context" {style: {bold: true; fill: "#E2E8F0"}}
    h2: "Cycles (Typ.)" {style: {bold: true; fill: "#E2E8F0"}}
    h3: "Bus Impact" {style: {bold: true; fill: "#E2E8F0"}}
    
    # Rows
    r1_1: "L1 Hit (Local M-State)"
    r1_2: "12-15"
    r1_3: "None (Silent)"
    
    r2_1: "Remote L1 Hit (Fwd)"
    r2_2: "40-80"
    r2_3: "Snoop/HITM"
    
    r3_1: "Contended RFO (Ping-Pong)"
    r3_2: "200-500+"
    r3_3: "Full Serialization"
  }
}

# =============================================================================
# ANALYSIS BLOCK
# =============================================================================
analysis_text: |md
  ### Contention Analysis: The "Lock-Free" Paradox
  
  1. **Atomic Serialization**: `LOCK` prefix forces a global order on the system bus via IDI (In-Die Interconnect).
  2. **RFO Storm**: Concurrent `CMPXCHG` triggers continuous **Read-For-Ownership (RFO)** requests.
  3. **Memory Ordering Clears**: Incoming invalidations cause execution units to flush speculative loads, spiking `machine_clears.memory_ordering`.
  4. **Performance Impact**: Throughput drops from ~80M ops/sec (single core) to <2M ops/sec (highly contended).
| {
  style.stroke: "#F59E0B"
  style.fill: "#FFFBEB"
  style.border-radius: 8
}

# =============================================================================
# LEGEND
# =============================================================================
legend: "MESI Legend" {
  m: "M: Modified (Exclusive/Dirty)" {class: state_M}
  e: "E: Exclusive (Clean)" {class: state_E}
  s: "S: Shared (Read-Only)" {class: state_S}
  i: "I: Invalid (Stale)" {class: state_I}
}

# =============================================================================
# POSITIONING (Fixed 'center' to 'center-right')
# =============================================================================
memory_layout.near: top-left
legend.near: top-right

ping_pong.near: center-right

analysis_text.near: bottom-left
latency_metrics.near: bottom-right