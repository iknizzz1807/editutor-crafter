vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
  colors: {
    attempt: "#E4DBFE"
    backoff: "#F9D8A7"
    success: "#ACE1AF"
    fail: "#FCE7C6"
    max: "#F6C889"
  }
}
title: |md
  # Exponential Backoff State Machine
| {near: top-center}
direction: right
states: {
  init: "Initialize\ndelay = 1" {
    shape: circle
    style.fill: ${colors.attempt}
  }
  attempt: "Attempt CAS\n(atomic op)" {
    shape: rectangle
    style.fill: ${colors.attempt}
    style.border-radius: 8
  }
  decision: "CAS\nResult?" {
    shape: diamond
    style.fill: "#DEE1EB"
  }
  success: "Success!\nReturn" {
    shape: circle
    style.fill: ${colors.success}
    style.double-border: true
  }
  backoff: "Backoff\nspin(delay)" {
    shape: rectangle
    style.fill: ${colors.backoff}
    style.border-radius: 8
  }
  double: "delay =\nmin(delay × 2, 1024)" {
    shape: rectangle
    style.fill: ${colors.max}
    style.border-radius: 8
  }
}
init -> attempt: "begin"
attempt -> decision
decision -> success: "success" {
  style.stroke: "#228B22"
  style.stroke-width: 3
}
decision -> backoff: "failure" {
  style.stroke: "#DC143C"
}
backoff -> double
double -> attempt: "retry"
legend: |md
  **State Descriptions:**
  - **init**: Initialize backoff delay to 1
  - **attempt**: Execute CAS operation
  - **backoff**: Spin for `delay` iterations with CPU pause
  - **double**: Exponentially increase delay, capped at 1024
  **CAS = Compare-And-Swap atomic operation**
| {near: bottom-center}