vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header: "#7C3AED"
    thread: "#3B82F6"
    stack: "#10B981"
    success: "#22C55E"
    counter: "#F59E0B"
    verify: "#EF4444"
    padding: "#E5E7EB"
    pointer: "#F97316"
  }
}

# ============================================================================
# Header and Title
# ============================================================================
title: {
  shape: rectangle
  near: top-center
  label: ||md
    # Treiber Stack Stress Test Architecture
    ### 16+ Worker Threads | 1M+ Operations | Zero Lost Elements
  ||
  style: {
    stroke-width: 0
    fill: transparent
    font-size: 18
  }
}

direction: right

# ============================================================================
# Worker Thread Pool
# ============================================================================
worker_pool: Worker Thread Pool {
  style: {
    fill: "${colors.thread}"
    stroke: "#1E40AF"
    font-color: white
  }
  
  t0: {
    shape: person
    label: "Thread 0"
    style.fill: white
  }
  t1: {
    shape: person
    label: "Thread 1"
    style.fill: white
  }
  t2: {
    shape: person
    label: "Thread 2"
    style.fill: white
  }
  tdots: "..." {
    style.stroke-width: 0
    style.font-color: white
  }
  t15: {
    shape: person
    label: "Thread 15"
    style.fill: white
  }
}

# ============================================================================
# Operation Distribution logic
# ============================================================================
operations: Random Operations {
  style: {
    fill: "#1E3A5F"
    stroke: "#0F172A"
    font-color: white
  }
  
  push_ops: {
    label: "40% Push\n(val = tid*1M + i)"
    style.fill: "#059669"
    style.font-color: white
  }
  pop_ops: {
    label: "40% Pop\n(CAS validation)"
    style.fill: "#DC2626"
    style.font-color: white
  }
  mixed_ops: {
    label: "20% Mixed\n(Alt. Sequence)"
    style.fill: "#7C3AED"
    style.font-color: white
  }
}

# ============================================================================
# Treiber Stack Memory Structure
# ============================================================================
treiber_stack: Treiber Stack {
  style.fill: "${colors.stack}"
  style.stroke: "#047857"
  
  top_ptr: {
    shape: sql_table
    label: "Top Pointer (Atomic)"
    tag: "uint64_t [Offset 0x00]" {constraint: "ABA Tag"}
    ptr: "void*    [Offset 0x08]" {constraint: "Node Ptr"}
    style.fill: "#D1FAE5"
  }
  
  node_a: {
    shape: sql_table
    label: "Node A (Memory: 0x7f...00)"
    val: "int   [0x00]" {label: "42"}
    next: "void* [0x08]"
    style.fill: white
  }
  
  node_b: {
    shape: sql_table
    label: "Node B (Memory: 0x7f...40)"
    val: "int   [0x00]" {label: "17"}
    next: "void* [0x08]"
    style.fill: white
  }
  
  null_marker: NULL {
    shape: circle
    style.fill: "${colors.padding}"
  }

  top_ptr.ptr -> node_a: "Atomic Load" {
    style.stroke: "${colors.pointer}"
    style.stroke-width: 2
  }
  node_a.next -> node_b: "Next Link"
  node_b.next -> null_marker: "Terminator"
}

# ============================================================================
# CAS Contention Zone
# ============================================================================
contention: CAS Contention Zone {
  style: {
    fill: "#FEE2E2"
    stroke: "#B91C1C"
    stroke-dash: 3
  }
  
  cas_loop: {
    shape: rectangle
    label: ||cpp
      // Atomic CAS Loop (C++11)
      do {
        old_top = top.load();
        new_node->next = old_top.ptr;
        new_top = {new_node, old_top.tag + 1};
      } while (!top.compare_exchange_weak(
          old_top, new_top,
          std::memory_order_release,
          std::memory_order_relaxed
      ));
    ||
    style: {
      fill: white
      font: mono
    }
  }
  
  backoff: {
    label: "Exponential Backoff\n(Delay: 2^n cycles)"
    shape: rectangle
    style.fill: "#DBEAFE"
  }
}

# ============================================================================
# Atomic Monitoring Counters
# ============================================================================
counters: Atomic Monitoring {
  style.fill: "${colors.counter}"
  style.stroke: "#B45309"
  
  push_count: {
    label: "g_push_count\n(atomic_int)"
    shape: cylinder
    style.fill: "#FEF3C7"
  }
  
  pop_count: {
    label: "g_pop_count\n(atomic_int)"
    shape: cylinder
    style.fill: "#FEF3C7"
  }
}

# ============================================================================
# Verification System
# ============================================================================
verification: Global Verification {
  style.fill: "${colors.verify}"
  style.stroke: "#991B1B"
  style.font-color: white
  
  invariant: {
    label: "Safety Invariant"
    shape: diamond
    style.fill: "#FCA5A5"
    style.font-color: black
  }
  
  formula: {
    shape: rectangle
    label: |md
      **Assert Logic:**
      `Count(Walk(Stack)) + g_pop == g_push`
    |
    style: {
      fill: white
      font: mono
      font-color: black
    }
  }
  
  result: {
    label: "✓ PASS: 0 LOST"
    style: {
      fill: "${colors.success}"
      font-color: white
      bold: true
    }
  }
}

# ============================================================================
# Connections
# ============================================================================
worker_pool -> operations: "Execute Task" {style.stroke-width: 2}
operations -> treiber_stack: "Invoke Method"
treiber_stack -> contention: "Arbitrate Access"
contention -> counters: "Inc (on Success)"
counters -> verification: "Final Read"
treiber_stack -> verification: "Stack Walk (Snapshot)"
verification.invariant -> verification.formula: "Check"
verification.formula -> verification.result: "Validate"

# ============================================================================
# Thread-Local Storage
# ============================================================================
thread_local: Thread-Local Storage {
  style.fill: "#E0E7FF"
  style.stroke: "#3730A3"
  
  seed: "rand_r seed" {style.fill: white}
  ops: "op_count" {style.fill: white}
}

worker_pool -> thread_local: "Owns" {style.stroke-dash: 3}
thread_local -> operations: "Input Seed"

# ============================================================================
# Technical Legend & Profiling
# ============================================================================
legend_meta: {
  shape: rectangle
  label: |md
    ### Hardware Architecture Notes
    * **Memory Model**: TSO (x86_64)
    * **CAS Instruction**: `LOCK CMPXCHG16B`
    * **Cache Line**: 64B (Aligned)
    * **Contention Cycle**: ~240ns avg per thread
  |
  style: {
    fill: "#F0FDF4"
    stroke: "#166534"
    font-size: 12
  }
}

# Styling Globs
***.style.font: mono