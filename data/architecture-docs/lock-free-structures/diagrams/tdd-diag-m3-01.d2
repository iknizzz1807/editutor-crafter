vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  node: {
    shape: rectangle
    width: 120
    height: 60
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 4
    }
  }
  sentinel: {
    shape: rectangle
    width: 120
    height: 60
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      border-radius: 4
      stroke-dash: 4
    }
  }
  pointer: {
    shape: diamond
    width: 60
    height: 40
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  label: {
    shape: text
    style: {
      font-size: 11
      font-color: "#424242"
    }
  }
  null_node: {
    shape: rectangle
    width: 60
    height: 40
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      stroke-width: 1
      stroke-dash: 3
      border-radius: 4
    }
  }
}
title: Michael-Scott Queue Structure {
  near: top-center
  shape: text
  style: {
    font-size: 20
    bold: true
    underline: true
  }
}
# Pointer labels
head_label: "head" {
  class: label
  style.font-size: 14
  style.bold: true
}
tail_label: "tail" {
  class: label
  style.font-size: 14
  style.bold: true
}
# Pointers
head_ptr: "" {
  class: pointer
  label: "head\nptr"
}
tail_ptr: "" {
  class: pointer
  label: "tail\nptr"
}
# Queue structure
queue_container: "MSQueue" {
  style: {
    fill: "#F5F5F5"
    stroke: "#757575"
    stroke-width: 2
    border-radius: 8
  }
  # Sentinel node (dummy)
  sentinel: "|md\n**SENTINEL**\n(dummy node)\nkey=NULL\nvalue=undefined\n|" {
    class: sentinel
    width: 140
  }
  # Data nodes
  node1: "|md\n**Node 1**\nvalue: 10\n|" {
    class: node
  }
  node2: "|md\n**Node 2**\nvalue: 20\n|" {
    class: node
  }
  node3: "|md\n**Node 3**\nvalue: 30\n|" {
    class: node
  }
  # NULL terminator
  null_term: "NULL" {
    class: null_node
  }
  # Connections within queue
  sentinel -> node1: "next" {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
    }
    target-arrowhead.shape: arrow
  }
  node1 -> node2: "next" {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
    }
    target-arrowhead.shape: arrow
  }
  node2 -> node3: "next" {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
    }
    target-arrowhead.shape: arrow
  }
  node3 -> null_term: "next" {
    style: {
      stroke: "#9E9E9E"
      stroke-width: 1
      stroke-dash: 3
    }
    target-arrowhead.shape: arrow
  }
}
# Head pointer to sentinel
head_label -> head_ptr: {
  style.stroke: transparent
}
head_ptr -> queue_container.sentinel: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: true
}
# Tail pointer to last node
tail_label -> tail_ptr: {
  style.stroke: transparent
}
tail_ptr -> queue_container.node3: {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: true
}
# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  legend_title: "Legend" {
    style: {
      bold: true
      font-size: 12
    }
  }
  leg_sentinel: "Sentinel (dummy)" {
    class: sentinel
    width: 100
    height: 30
  }
  leg_data: "Data node" {
    class: node
    width: 100
    height: 30
  }
  legend_title -> leg_sentinel -> leg_data: {style.opacity: 0}
}
# Annotations
annotation: |md
**Key Invariants:**
- `head` always points to sentinel (never NULL)
- `tail` points to last real node or sentinel
- Real data is at `head->next`, not `head`
- Dequeue removes sentinel, makes `head->next` new sentinel
| {
  near: bottom-left
  shape: text
  style: {
    font-size: 11
    font-color: "#616161"
  }
}