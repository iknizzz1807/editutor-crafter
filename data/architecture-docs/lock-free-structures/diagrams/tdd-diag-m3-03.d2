vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header: "#7C3AED"
    data: "#3B82F6"
    pointer: "#F59E0B"
    changed: "#EF4444"
    success: "#10B981"
    null: "#6B7280"
    background: "#F9FAFB"
    note_bg: "#FEF3C7"
    padding: "#E5E7EB"
  }
}

title: |md
  # Enqueue Protocol Implementation Spec
  ## Michael-Scott Lock-Free Queue (Atomic CAS)
  **Linearizability Point & Lagging Tail Handling**
| {near: top-center}

direction: right

# Global Styles for Technical Precision
***.style.font: mono
***.style.stroke-width: 2

# STEP 1: Linking the Node
step1: {
  label: "STEP 1: LINK NEW NODE (Linearization Point)"
  style: {
    fill: "${colors.background}"
    stroke: "${colors.header}"
    stroke-width: 4
    double-border: true
  }

  before: {
    label: "Initial State (Quiescent)"
    style.stroke: "${colors.null}"
    
    tail_ptr: "TAIL_PTR\n[Addr: 0x00]\n[Val: 0xA0]" {
      shape: circle
      style.fill: "${colors.pointer}"
      style.font-color: white
    }
    
    tail_node: {
      label: "Node @0xA0 (Tail)"
      style.fill: "${colors.data}"
      style.font-color: white
      
      header: "Offset +0: Header (8B)" { style.fill: "${colors.header}" }
      payload: "Offset +8: Data (8B)" { style.fill: "${colors.data}" }
      next_field: "Offset +16: next -> NULL (0x0)" {
        style.stroke: "${colors.null}"
        style.bold: false
        style.fill: transparent
      }
    }
    
    new_node: {
      label: "Unlinked Node @0xB0"
      style.fill: "${colors.data}"
      style.opacity: 0.4
      style.stroke-dash: 3
    }
    
    tail_ptr -> tail_node: "loads current"
  }

  cas_op: "CAS(0xA8, 0x0, 0xB0)" {
    tooltip: "Atomic Compare-and-Swap on tail->next memory address"
    shape: parallelogram
    style: {
      fill: "${colors.changed}"
      font-color: white
      bold: true
    }
  }

  after: {
    label: "After Successful CAS"
    style.stroke: "${colors.success}"
    
    tail_node_linked: {
      label: "Node @0xA0 (Old Tail)"
      style.fill: "${colors.data}"
      style.font-color: white
      
      header: "Header (8B)" { style.fill: "${colors.header}" }
      next_field: "next -> 0xB0" {
        style.font-color: "${colors.changed}"
        style.bold: true
        style.stroke: "${colors.changed}"
        style.stroke-width: 3
      }
    }
    
    new_node_linked: {
      label: "Node @0xB0\n[STATUS: LINKED]"
      style.fill: "${colors.success}"
      style.font-color: white
      style.bold: true
      style.double-border: true
    }
    
    tail_node_linked.next_field -> new_node_linked: {
      style.stroke: "${colors.changed}"
      style.stroke-width: 5
      style.animated: true
    }
  }

  before -> cas_op -> after
}

# STEP 2: Moving the Tail
step2: {
  label: "STEP 2: SWING TAIL POINTER"
  style: {
    fill: "${colors.background}"
    stroke: "${colors.header}"
    stroke-width: 4
    double-border: true
  }

  before_swing: {
    label: "State: Lagging Tail"
    style.stroke: "${colors.null}"
    
    tail_ptr_lag: "TAIL_PTR\n[Addr: 0x00]\n[Val: 0xA0]" {
      shape: circle
      style.fill: "${colors.pointer}"
    }
    
    old_node: "Node @0xA0" {
      style.fill: "${colors.null}"
      style.opacity: 0.5
    }
    
    new_node_ready: "Node @0xB0" {
      style.fill: "${colors.success}"
      style.font-color: white
    }
    
    tail_ptr_lag -> old_node: "LAGGING"
    old_node -> new_node_ready: "Physical Link OK"
  }

  cas_swing: "CAS(0x00, 0xA0, 0xB0)" {
    tooltip: "Atomic update of Global Tail Pointer (Swing pointer to new node)"
    shape: parallelogram
    style: {
      fill: "${colors.changed}"
      font-color: white
      bold: true
    }
  }

  after_swing: {
    label: "Final Consistent State"
    style.stroke: "${colors.success}"
    
    tail_ptr_final: "TAIL_PTR\n[Val: 0xB0]" {
      shape: circle
      style.fill: "${colors.pointer}"
      style.double-border: true
    }
    
    final_node: "Node @0xB0" {
      label: "Node @0xB0\n[STATUS: GLOBAL TAIL]"
      style.fill: "${colors.success}"
      style.font-color: white
      style.bold: true
    }
    
    tail_ptr_final -> final_node: {
      label: "Swing successful"
      style.stroke: "${colors.changed}"
      style.stroke-width: 5
      style.animated: true
    }
  }

  before_swing -> cas_swing -> after_swing
}

# Protocol Logic Flow
step1 -> step2: "Condition: CAS_1 Success" {
  style.stroke: "${colors.success}"
  style.stroke-width: 3
  style.stroke-dash: 5
}

# Documentation Annotations - Fixed for ELK Compliance
note1: |md
  ### LINEARIZATION POINT
  The enqueue is **logically complete** 
  once Step 1 CAS succeeds. 
  Even if the thread crashes before Step 2, 
  the element is reachable by traversing `head`.
| {
  near: top-right
  style: {
    fill: "${colors.note_bg}"
    stroke: "${colors.pointer}"
    border-radius: 6
  }
}

note2: |md
  ### HELPING SEMANTICS
  If a thread finds `tail->next != NULL`,
  it knows the global tail pointer is lagging.
  It will attempt Step 2 on behalf of 
  the lagging thread (Lock-free cooperation).
| {
  near: bottom-right
  style: {
    fill: "${colors.note_bg}"
    stroke: "${colors.pointer}"
    border-radius: 6
  }
}

legend: {
  near: bottom-left
  style.fill: white
  style.stroke: "${colors.null}"
  
  title: "Memory Specification Legend" {
    shape: text
    style.bold: true
  }
  
  ptr_def: "• Orange Circle: Atomic Pointer (64-bit)" {
    style.font-color: "${colors.pointer}"
  }
  change_def: "• Red Parallelogram: CAS Atomic Mutation" {
    style.font-color: "${colors.changed}"
  }
  success_def: "• Green Double-Border: Post-Linearization State" {
    style.font-color: "${colors.success}"
  }
  offset_def: "• Offset annotations represent byte-level layouts" {
    style.font-color: "#4B5563"
  }
}

# Formatting Overrides for clarity
step1.after.tail_node_linked.next_field.style: {
  stroke: "${colors.changed}"
  stroke-width: 4
}
step2.after_swing.tail_ptr_final.style: {
  stroke: "${colors.success}"
  stroke-width: 4
}