# Legend
# =============================================================================
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  
  title: "Visual Key"
  
  lagging: "Inconsistent State\n(Lagging Tail)" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 3
  }
  
  helping: "Helping Logic" {
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  
  node_new: "New Enqueued Node" {
    shape: circle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  
  node_data: "Existing Data" {
    shape: circle
    style.fill: "#B3E5FC"
  }
}

# =============================================================================
# Code Implementation Reference
# =============================================================================
code_reference: |md
  c
  // Michael-Scott Lock-Free Enqueue
  void enqueue(Queue* q, int val) {
    Node* n = new Node(val);
    while (true) {
      Node* tail = q->tail;
      Node* next = tail->next;
      if (tail == q->tail) { // Consistency check
        if (next == NULL) {
          // --- PHASE 1: Try to link new node ---
          if (CAS(&tail->next, NULL, n)) {
            // --- PHASE 2: Try to advance tail ---
            CAS(&q->tail, tail, n); 
            return;
          }
        } else {
          // --- HELPING: Tail lagging, advance it ---
          CAS(&q->tail, tail, next);
        }
      }
    }
  }
  
| {near: bottom-center}