vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Helping Mechanism: Tail Advance Cooperation
  Thread A stalls mid-enqueue → Thread B detects lagging tail → Thread B helps complete
|
direction: right
# Time phases
T0: {
  label: "T0: Initial State"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  queue_init: {
    shape: sequence_diagram
    head_ptr: "head → S"
    tail_ptr: "tail → S"
    node_S: "S (sentinel)"
    note: "Empty queue:\nhead == tail == S\nS->next == NULL"
  }
}
T1: {
  label: "T1: Thread A Links Node"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  thread_A: {
    style.fill: "#FFE0B2"
    step1: "1. A loads tail = S"
    step2: "2. A loads S->next = NULL"
    step3: "3. A creates node X"
    step4: "4. A CAS(S->next, NULL, X) ✓"
    step5: "5. A PREEMPTED..."
    step5.style.fill: "#FFCC80"
    step5.style.bold: true
  }
  intermediate_state: {
    shape: sequence_diagram
    head_ptr: "head → S"
    tail_ptr: "tail → S (LAGGING!)"
    link: "S->next → X"
    note: "Intermediate state:\ntail not yet advanced\nbut X is linked"
    note.style.fill: "#FFEBEE"
  }
}
T2: {
  label: "T2: Thread B Detects Lag"
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  thread_B: {
    style.fill: "#BBDEFB"
    step1: "1. B loads tail = S"
    step2: "2. B loads S->next = X"
    step3: "3. B detects: next != NULL"
    step3.style.fill: "#90CAF9"
    step3.style.bold: true
    step4: "4. B knows tail is lagging"
  }
  detection_state: {
    shape: sequence_diagram
    head_ptr: "head → S"
    tail_ptr: "tail → S"
    link: "S->next → X"
    detection: "B sees:\ntail->next != NULL"
    detection.style.fill: "#E3F2FD"
    detection.style.stroke: "#2196F3"
  }
}
T3: {
  label: "T3: Thread B Helps"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  thread_B_help: {
    style.fill: "#C8E6C9"
    step1: "5. B CAS(tail, S, X)"
    step2: "6. CAS succeeds!"
    step2.style.fill: "#A5D6A7"
    step2.style.bold: true
    step3: "7. tail now points to X"
  }
  helped_state: {
    shape: sequence_diagram
    head_ptr: "head → S"
    tail_ptr: "tail → X ✓"
    link: "S->next → X"
    note: "Queue now consistent:\ntail advanced by B\nwhile A was stalled"
    note.style.fill: "#E8F5E9"
  }
}
T4: {
  label: "T4: Thread A Resumes"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  thread_A_resume: {
    style.fill: "#E1BEE7"
    step1: "8. A resumes execution"
    step2: "9. A tries CAS(tail, S, X)"
    step3: "10. CAS fails (tail != S)"
    step3.style.fill: "#FFCDD2"
    step4: "11. No problem! B already did it"
    step4.style.fill: "#C8E6C9"
  }
  final_state: {
    shape: sequence_diagram
    head_ptr: "head → S"
    tail_ptr: "tail → X"
    link: "S → X → NULL"
    note: "Final state:\nBoth threads succeeded\nQueue is correct"
    note.style.fill: "#E8F5E9"
  }
}
# Flow arrows
T0 -> T1: "A starts enqueue"
T1 -> T2: "A preempted\nB starts enqueue"
T2 -> T3: "B helps advance tail"
T3 -> T4: "A resumes"
# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  title: "Legend"
  thread_A_color: {
    label: "Thread A (stalled)"
    shape: rectangle
    style.fill: "#FFE0B2"
  }
  thread_B_color: {
    label: "Thread B (helper)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  critical: {
    label: "Critical observation"
    shape: rectangle
    style.fill: "#90CAF9"
  }
  success: {
    label: "Successful operation"
    shape: rectangle
    style.fill: "#A5D6A7"
  }
}
# Key insight box
insight: |md
  **Key Insight:** The helping mechanism ensures lock-free progress.
  - Thread A's tail swing is *best-effort*
  - If A stalls, any other thread can complete it
  - The system progresses even if individual threads block
  - This is why MS queue is truly lock-free, not just wait-free
|
insight.near: bottom-center
insight.style.fill: "#FFF8E1"
insight.style.stroke: "#FFC107"