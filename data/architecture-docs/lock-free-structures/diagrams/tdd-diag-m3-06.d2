vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    sentinel: "#9B59B6"
    data: "#3498DB"
    orphaned: "#95A5A6"
    head_ptr: "#E74C3C"
    action: "#F39C12"
  }
}
direction: right
title: |md
  # Dequeue with Sentinel Swapping
  ## Michael-Scott Queue Pattern
| {near: top-center}
before: {
  label: "BEFORE DEQUEUE"
  style.fill: "#FDF2E9"
  style.stroke: "#D68910"
  style.border-radius: 8
  head_before: "head" {
    shape: circle
    style.fill: ${colors.head_ptr}
    style.font-color: white
    style.stroke: "#C0392B"
  }
  sentinel_before: "sentinel\n(dummy)" {
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.font-color: white
    style.stroke: "#7D3C98"
    width: 80
  }
  data_before: "value: 42\n(data)" {
    shape: rectangle
    style.fill: ${colors.data}
    style.font-color: white
    style.stroke: "#2980B9"
    width: 80
  }
  null_before: "NULL" {
    shape: circle
    style.fill: "#ECF0F1"
    style.stroke: "#BDC3C7"
    style.font-color: "#7F8C8D"
  }
  head_before -> sentinel_before: "points to" {
    style.stroke: ${colors.head_ptr}
    style.stroke-width: 2
  }
  sentinel_before -> data_before: "next" {
    style.stroke: ${colors.sentinel}
  }
  data_before -> null_before: "next" {
    style.stroke: ${colors.data}
  }
}
cas_operation: {
  label: "CAS OPERATION\n\nCAS(&head, sentinel, data_node)\n\n• Compare: head == sentinel ✓\n• Swap: head = data_node\n• Result: SUCCESS"
  shape: rectangle
  style.fill: ${colors.action}
  style.font-color: white
  style.stroke: "#D68910"
  style.bold: true
  width: 200
}
after: {
  label: "AFTER DEQUEUE"
  style.fill: "#E8F8F5"
  style.stroke: "#1ABC9C"
  style.border-radius: 8
  head_after: "head" {
    shape: circle
    style.fill: ${colors.head_ptr}
    style.font-color: white
    style.stroke: "#C0392B"
  }
  orphaned: "sentinel\n(ORPHANED)" {
    shape: rectangle
    style.fill: ${colors.orphaned}
    style.font-color: white
    style.stroke: "#7F8C8D"
    style.stroke-dash: 3
    style.opacity: 0.6
    width: 80
  }
  new_sentinel: "value: 42\n(new sentinel)" {
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.font-color: white
    style.stroke: "#7D3C98"
    width: 80
  }
  null_after: "NULL" {
    shape: circle
    style.fill: "#ECF0F1"
    style.stroke: "#BDC3C7"
    style.font-color: "#7F8C8D"
  }
  head_after -> new_sentinel: "points to" {
    style.stroke: ${colors.head_ptr}
    style.stroke-width: 2
  }
  new_sentinel -> null_after: "next" {
    style.stroke: ${colors.sentinel}
  }
  orphaned -> orphaned: "no references\n(leaked until M4)" {
    style.stroke-dash: 3
    style.stroke: ${colors.orphaned}
    style.font-color: ${colors.orphaned}
  }
}
before -> cas_operation -> after
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: transparent
  l1: "Sentinel (dummy node)" {
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.font-color: white
    width: 120
  }
  l2: "Data node" {
    shape: rectangle
    style.fill: ${colors.data}
    style.font-color: white
    width: 120
  }
  l3: "Orphaned (leaked)" {
    shape: rectangle
    style.fill: ${colors.orphaned}
    style.font-color: white
    style.stroke-dash: 3
    width: 120
  }
  l4: "Head pointer" {
    shape: circle
    style.fill: ${colors.head_ptr}
    style.font-color: white
    width: 60
  }
}
note: |md
  **Key Insight:** Dequeue doesn't remove the data node—
  it removes the *sentinel* and promotes the data node
  to become the new sentinel. The old sentinel becomes
  garbage (leaked until M4 hazard pointer integration).
| {near: bottom-center}