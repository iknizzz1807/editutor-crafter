vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # Lagging Tail Detection State Machine
  **MS Queue: Help Advance Tail Before Dequeue**
| {near: top-center}

# Initial state
Start: "● INITIAL" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}

# Detection states
LoadHead: "Load Head" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
LoadTail: "Load Tail" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
LoadNext: "Load Head→Next" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

# Decision node
CheckHeadEqTail: "head == tail?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}
CheckNextNull: "next == NULL?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}

# Lagging tail detection state
LaggingDetected: "⚠️ LAGGING TAIL\nDETECTED" {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.bold: true
  style.font-color: "#C62828"
}

# Help advance tail states
ReadActualNext: "Read tail→next\n(actual next node)" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}
AttemptCAS: "CAS(tail, old_tail, next)" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}
CASSuccess: "CAS Success" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
CASFail: "CAS Fail" {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
}

# Continue to dequeue
RetryDequeue: "Retry Dequeue\nwith updated state" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}

# Normal dequeue path
QueueEmpty: "Queue Empty\nReturn failure" {
  style.fill: "#ECEFF1"
  style.stroke: "#546E7A"
}
ProceedDequeue: "Proceed with\nNormal Dequeue" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}

# Transitions
Start -> LoadHead: "Begin dequeue"
LoadHead -> LoadTail: "head loaded"
LoadTail -> LoadNext: "tail loaded"
LoadNext -> CheckHeadEqTail: "next loaded"

CheckHeadEqTail -> ProceedDequeue: "NO\n(head ≠ tail)" {
  style.stroke: "#2E7D32"
}
CheckHeadEqTail -> CheckNextNull: "YES\n(head == tail)"

CheckNextNull -> QueueEmpty: "YES\n(next == NULL)\n→ Empty Queue" {
  style.stroke: "#546E7A"
}
CheckNextNull -> LaggingDetected: "NO\n(next ≠ NULL)\n→ TAIL LAGGING!" {
  style.stroke: "#C62828"
  style.bold: true
}

# Helping mechanism
LaggingDetected -> ReadActualNext: "Help advance tail"
ReadActualNext -> AttemptCAS: "next = tail→next"
AttemptCAS -> CASSuccess: "success"
AttemptCAS -> CASFail: "fail\n(race with\nother thread)"

CASSuccess -> RetryDequeue: "tail advanced"
CASFail -> RetryDequeue: "another thread\nadvanced tail"
RetryDequeue -> LoadHead: "restart dequeue\nwith fresh state"

# Invariant box
Invariant: |md
  **INVARIANT:**
  If `head == tail` AND `head->next != NULL`:
  - Some thread completed link phase
  - But did not complete tail swing
  - Helping ensures lock-free progress
| {
  near: top-right
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
  style.stroke-dash: 3
}

# Annotation
# Corrected near value to use absolute positioning compatible with elk
Annotation: |md
  **Why Help?**
  Thread A: linked node but stalled/crashed
  Thread B: observes lagging tail
  Without helping: all future enqueues blocked
  With helping: any thread can complete A's work
| {
  near: bottom-right
}