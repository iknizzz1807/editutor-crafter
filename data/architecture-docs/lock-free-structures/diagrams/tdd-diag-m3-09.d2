vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    enqueue1: "#4A90D9"
    enqueue2: "#5BA0E9"
    enqueue3: "#6BB0F9"
    dequeue: "#E85D75"
    timeline: "#2C3E50"
    label: "#34495E"
    bg_blue: "#E8F4FD"
    bg_red: "#FDE8EC"
    bg_gray: "#F0F4F8"
  }
}

classes: {
  thread: {
    style: {
      stroke-width: 2
      border-radius: 8
    }
  }
  op_box: {
    shape: rectangle
    width: 140
    style: {
      font-color: white
      bold: true
      stroke-width: 0
      shadow: true
    }
  }
  linear_point: {
    shape: diamond
    style: {
      font-color: white
      bold: true
      stroke-width: 1
    }
  }
  time_marker: {
    shape: circle
    width: 12
    height: 12
    style: {
      font-size: 11
      bold: true
    }
  }
}

title: |md
  ## FIFO Ordering Proof
  **Linearization points (LP) define the canonical sequence of operations.**
| {
  near: top-center
  style.font-size: 18
}

direction: right

# --- Chronological Axis ---
timeline: {
  label: "Global Wall Clock / Linearization Axis"
  style: {
    stroke: ${colors.timeline}
    stroke-dash: 5
    fill: transparent
  }
  
  t0: "T₀" { class: time_marker; style.fill: ${colors.timeline}; style.font-color: ${colors.label} }
  t1: "T₁" { class: time_marker; style.fill: ${colors.timeline}; style.font-color: ${colors.label} }
  t2: "T₂" { class: time_marker; style.fill: ${colors.timeline}; style.font-color: ${colors.label} }
  t3: "T₃" { class: time_marker; style.fill: ${colors.timeline}; style.font-color: ${colors.label} }
  t4: "T₄" { class: time_marker; style.fill: ${colors.timeline}; style.font-color: ${colors.label} }
  t5: "T₅" { class: time_marker; style.fill: ${colors.timeline}; style.font-color: ${colors.label} }

  t0 -> t1 -> t2 -> t3 -> t4 -> t5: { style.stroke: ${colors.timeline} }
}

# --- Producer Context ---
producer_thread: {
  label: "Producer Thread (Linearizes on Tail CAS)"
  class: thread
  style.fill: ${colors.bg_blue}
  style.stroke: ${colors.enqueue1}
  
  enq1: "enqueue(A)\nCAS tail->next" {
    class: op_box
    style.fill: ${colors.enqueue1}
  }
  enq2: "enqueue(B)\nCAS tail->next" {
    class: op_box
    style.fill: ${colors.enqueue2}
  }
  enq3: "enqueue(C)\nCAS tail->next" {
    class: op_box
    style.fill: ${colors.enqueue3}
  }
  
  enq1 -> enq2 -> enq3: { style.stroke-dash: 4 }
}

# --- Consumer Context ---
consumer_thread: {
  label: "Consumer Thread (Linearizes on Head CAS)"
  class: thread
  style.fill: ${colors.bg_red}
  style.stroke: ${colors.dequeue}
  
  deq1: "dequeue()\nreturns A" {
    class: op_box
    style.fill: ${colors.enqueue1}
  }
  deq2: "dequeue()\nreturns B" {
    class: op_box
    style.fill: ${colors.enqueue2}
  }
  deq3: "dequeue()\nreturns C" {
    class: op_box
    style.fill: ${colors.enqueue3}
  }
  
  deq1 -> deq2 -> deq3: { style.stroke-dash: 4 }
}

# --- Atomic Event Points ---
linearization_points: {
  label: "Atomic Ordering Events"
  style.fill: ${colors.bg_gray}
  style.stroke: ${colors.timeline}
  
  lp1: "LP₁" { class: linear_point; style.fill: ${colors.enqueue1} }
  lp2: "LP₂" { class: linear_point; style.fill: ${colors.enqueue2} }
  lp3: "LP₃" { class: linear_point; style.fill: ${colors.enqueue3} }
  lp4: "LP₄" { class: linear_point; style.fill: ${colors.enqueue1}; style.stroke: ${colors.dequeue} }
  lp5: "LP₅" { class: linear_point; style.fill: ${colors.enqueue2}; style.stroke: ${colors.dequeue} }
  lp6: "LP₆" { class: linear_point; style.fill: ${colors.enqueue3}; style.stroke: ${colors.dequeue} }
  
  lp1 -> lp2 -> lp3 -> lp4 -> lp5 -> lp6: { style.stroke-dash: 2 }
}

# --- Technical Proof Summary ---
proof_invariant: {
  label: |md
    ### FIFO Safety Invariants
    1. **Structural Integrity**: Nodes linked in order. `CAS(tail->next)` only succeeds if `tail->next == NULL`.
    2. **Linearization**: Hardware-level CAS ensures a total order of successful updates.
    3. **Visibility**: If LP₁ completes before LP₂ starts, LP₁ must precede LP₂ in the total order.
    4. **Chain Order**: `dequeue()` must follow the `head->next` pointers, ensuring oldest node is removed.
  |
  shape: rectangle
  width: 320
  style: {
    fill: "#FAFBFC"
    stroke: ${colors.timeline}
    stroke-width: 2
    font-size: 13
  }
}

# --- The Sequential Proof ---
ordering_proof: {
  label: "Logical Proof Path"
  style.fill: "#F8F9FA"
  style.stroke: ${colors.timeline}
  
  logic: |md
    **Total Ordering Theorem:**
    `LP₁ (enq A) < LP₂ (enq B) < LP₃ (enq C)`
    
    *Since queue is a Linked Chain:*
    `deq()` follows nodes `A → B → C`
    
    *Execution Result:*
    `LP₄ (deq A) < LP₅ (deq B) < LP₆ (deq C)`
    
    **Result:** FIFO sequence is strictly preserved.
  | {
    shape: rectangle
    style.fill: white
    style.stroke: ${colors.timeline}
  }
}

# --- Memory State Transitions ---
queue_evolution: {
  label: "Queue State Snapshots"
  style.fill: "#F5F7FA"
  style.stroke: ${colors.timeline}
  
  state0: "Initial\n[H]→∅" { shape: rectangle; style.fill: white }
  state1: "After LP₁\n[H]→[A]" { shape: rectangle; style.fill: ${colors.enqueue1}; style.font-color: white }
  state2: "After LP₂\n[H]→[A]→[B]" { shape: rectangle; style.fill: ${colors.enqueue2}; style.font-color: white }
  state3: "After LP₃\n[H]→[A]→[B]→[C]" { shape: rectangle; style.fill: ${colors.enqueue3}; style.font-color: white }
  
  state0 -> state1 -> state2 -> state3: { style.stroke-dash: 2 }
}

# --- Mappings & Semantic Connections ---
producer_thread.enq1 -> linearization_points.lp1
producer_thread.enq2 -> linearization_points.lp2
producer_thread.enq3 -> linearization_points.lp3

linearization_points.lp4 -> consumer_thread.deq1: "Resolves A"
linearization_points.lp5 -> consumer_thread.deq2: "Resolves B"
linearization_points.lp6 -> consumer_thread.deq3: "Resolves C"

# Invariant/Proof Layout Hints
producer_thread -- queue_evolution: { style.stroke: transparent }
proof_invariant -- ordering_proof: { style.stroke: transparent }

# Timeline Alignment
timeline.t1 -> linearization_points.lp1: { style.stroke-dash: 5; style.opacity: 0.3 }
timeline.t4 -> linearization_points.lp4: { style.stroke-dash: 5; style.opacity: 0.3 }