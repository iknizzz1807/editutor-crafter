title: {
  label: ||md
    # Multi-Producer Multi-Consumer FIFO Verification Test
    **Target: Michael-Scott (MS) Lock-Free Queue | Item: (uint32_t ID, uint32_t Seq)**
  ||
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# --- MEMORY LAYOUT DEFINITION ---
item_layout: {
  shape: sql_table
  label: "Tagged Item Memory Layout (64-bit Word)"
  near: top-left
  
  00_31: "Sequence Number (uint32)" {constraint: "bits 0-31"}
  32_63: "Producer ID (uint32)" {constraint: "bits 32-63"}
  
  style: {
    fill: "#f8fafc"
    stroke: "#334155"
    stroke-width: 2
  }
}

# --- PRODUCER GROUP ---
producers: Producers {
  style: {
    fill: "#eef2ff"
    stroke: "#6366f1"
    stroke-width: 2
    stroke-dash: 4
  }
  
  p0: P0 { shape: hexagon; style.fill: "#c7d2fe" }
  p1: P1 { shape: hexagon; style.fill: "#c7d2fe" }
  p2: P2 { shape: hexagon; style.fill: "#c7d2fe" }
  p3: P3 { shape: hexagon; style.fill: "#c7d2fe" }
  p4: P4 { shape: hexagon; style.fill: "#c7d2fe" }
  p5: P5 { shape: hexagon; style.fill: "#c7d2fe" }
  p6: P6 { shape: hexagon; style.fill: "#c7d2fe" }
  p7: P7 { shape: hexagon; style.fill: "#c7d2fe" }
}

# --- MS QUEUE STRUCTURE ---
queue: "MS Queue (Heap State)" {
  style: {
    fill: "#fffbeb"
    stroke: "#f59e0b"
    stroke-width: 3
  }

  sentinel: Sentinel {
    label: "HEAD\n(Sentinel)"
    style.fill: "#cbd5e1"
  }
  
  n1: "(P2, 0)" { style.fill: "#fef3c7" }
  n2: "(P0, 0)" { style.fill: "#fef3c7" }
  n3: "(P5, 0)" { style.fill: "#fef3c7" }
  n4: "(P2, 1)" { style.fill: "#fef3c7" }
  n5: "(P0, 1)" { style.fill: "#fef3c7" }
  dots: "..." { shape: text }

  sentinel -> n1: "next"
  n1 -> n2: "next"
  n2 -> n3: "next"
  n3 -> n4: "next"
  n4 -> n5: "next"
  n5 -> dots: "next"
}

# --- CONSUMER GROUP ---
consumers: Consumers {
  style: {
    fill: "#ecfdf5"
    stroke: "#10b981"
    stroke-width: 2
    stroke-dash: 4
  }
  
  c0: C0 { shape: hexagon; style.fill: "#a7f3d0" }
  c1: C1 { shape: hexagon; style.fill: "#a7f3d0" }
  c2: C2 { shape: hexagon; style.fill: "#a7f3d0" }
  c3: C3 { shape: hexagon; style.fill: "#a7f3d0" }
  c4: C4 { shape: hexagon; style.fill: "#a7f3d0" }
  c5: C5 { shape: hexagon; style.fill: "#a7f3d0" }
  c6: C6 { shape: hexagon; style.fill: "#a7f3d0" }
  c7: C7 { shape: hexagon; style.fill: "#a7f3d0" }
}

# --- EDGE INTERACTIONS (P -> Q) ---
producers.p0 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }
producers.p1 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }
producers.p2 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }
producers.p3 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }
producers.p4 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }
producers.p5 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }
producers.p6 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }
producers.p7 -> queue: "CAS Enqueue" { style: { stroke: "#3b82f6"; animated: true; stroke-width: 2 } }

# --- EDGE INTERACTIONS (Q -> C) ---
queue -> consumers.c0: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }
queue -> consumers.c1: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }
queue -> consumers.c2: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }
queue -> consumers.c3: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }
queue -> consumers.c4: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }
queue -> consumers.c5: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }
queue -> consumers.c6: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }
queue -> consumers.c7: "CAS Dequeue" { style: { stroke: "#10b981"; animated: true; stroke-width: 2 } }

# --- VERIFICATION SYSTEM ---
verification: "FIFO Validator State" {
  style: {
    fill: "#f0fdf4"
    stroke: "#22c55e"
    stroke-width: 2
  }

  tracker: "Sequence Shadow Registers" {
    style.fill: "#ffffff"
    t0: "P0: expected_seq++"
    t1: "P1: expected_seq++"
    t2: "P2: expected_seq++"
    t3: "P3: expected_seq++"
    t4: "P4: expected_seq++"
    t5: "P5: expected_seq++"
    t6: "P6: expected_seq++"
    t7: "P7: expected_seq++"
    
    t*.style.font: mono
  }

  logic_desc: ||md
    ### Assertion Logic
    c
    void verify(uint64_t item) {
      uint32_t pid = (uint32_t)(item >> 32);
      uint32_t seq = (uint32_t)(item & 0xFFFFFFFF);
      
      // Atomic increment and compare
      uint32_t last = atomic_load(&expected[pid]);
      if (seq != last) fail("FIFO Violation");
      atomic_store(&expected[pid], last + 1);
    }
    
  ||
}

consumers -> verification: "Verification Stream" {
  style: {
    stroke: "#22c55e"
    stroke-dash: 5
    stroke-width: 2
  }
}

# --- CONFIGURATION SUMMARY ---
test_meta: {
  label: ||md
    ## Test Matrix
    | Component | Implementation |
    | :--- | :--- |
    | **Threads** | 8 Producers / 8 Consumers |
    | **Structure** | Lock-Free Michael-Scott Queue |
    | **Payload** | 64-bit Atomic Word |
    | **Workload** | 100k Items per Producer |
    | **Total Ops** | 1.6M Atomic CAS Operations |
    | **Platform** | x86_64 TSO Memory Model |
  ||
  near: bottom-right
  style: {
    fill: "#f1f5f9"
    stroke: "#475569"
  }
}

legend: {
  near: bottom-left
  p_color: "Producer Ops" { style.fill: "#6366f1" }
  c_color: "Consumer Ops" { style.fill: "#10b981" }
  v_color: "FIFO Verification" { style.fill: "#22c55e" }
}