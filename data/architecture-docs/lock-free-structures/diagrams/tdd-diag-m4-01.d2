vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#4A5568"
    thread_a: "#3182CE"
    thread_b: "#38A169"
    hazard_slot: "#ED8936"
    node: "#805AD5"
    protected: "#48BB78"
    danger: "#E53E3E"
    text_light: "#FFFFFF"
    text_dark: "#2D3748"
  }
}
title: |md
  # Hazard Pointer Concept
  Safe Memory Reclamation via Publish-Subscribe Protocol
| {near: top-center}
direction: right
# ============================================================================
# Thread A: Publishing Protection
# ============================================================================
Thread_A: {
  label: "Thread A\n(Accessing Node)"
  style.fill: "${colors.thread_a}"
  style.stroke: "#2C5282"
  style.font-color: "${colors.text_light}"
  style.border-radius: 8
  hazard_slot_0: {
    label: "Hazard Slot 0\n\n0x7F3A1000"
    shape: rectangle
    style.fill: "${colors.hazard_slot}"
    style.stroke: "#C05621"
    style.font-color: "${colors.text_dark}"
    style.bold: true
  }
  hazard_slot_1: {
    label: "Hazard Slot 1\n\nNULL"
    shape: rectangle
    style.fill: "#EDF2F7"
    style.stroke: "#A0AEC0"
    style.font-color: "${colors.text_dark}"
  }
  local_var: {
    label: "local_node = 0x7F3A1000"
    shape: code
    style.fill: "#EBF8FF"
    style.stroke: "${colors.thread_a}"
    language: c
  }
  hazard_slot_0 -> local_var: "protects" {
    style.stroke-dash: 3
    style.stroke: "${colors.thread_a}"
  }
}
# ============================================================================
# Global Hazard Pointer Registry
# ============================================================================
Registry: {
  label: "Global Hazard Pointer Registry"
  style.fill: "#F7FAFC"
  style.stroke: "${colors.header}"
  style.border-radius: 12
  style.stroke-width: 2
  header: {
    label: "Thread ID | Slot 0        | Slot 1"
    shape: rectangle
    style.fill: "${colors.header}"
    style.font-color: "${colors.text_light}"
    style.bold: true
  }
  row_0: {
    label: "    0     | 0x7F3A1000    | NULL"
    shape: rectangle
    style.fill: "${colors.protected}"
    style.font-color: "${colors.text_dark}"
    style.bold: true
  }
  row_1: {
    label: "    1     | NULL          | NULL"
    shape: rectangle
    style.fill: "#FFFFFF"
    style.font-color: "${colors.text_dark}"
  }
  row_2: {
    label: "    2     | 0x7F3A2000    | NULL"
    shape: rectangle
    style.fill: "${colors.protected}"
    style.font-color: "${colors.text_dark}"
  }
  row_dots: {
    label: "   ...    | ...           | ..."
    shape: rectangle
    style.fill: "#FFFFFF"
    style.font-color: "#A0AEC0"
  }
  header -> row_0 -> row_1 -> row_2 -> row_dots {style.opacity: 0}
}
# ============================================================================
# Thread B: Scanning Before Freeing
# ============================================================================
Thread_B: {
  label: "Thread B\n(Reclaiming Memory)"
  style.fill: "${colors.thread_b}"
  style.stroke: "#276749"
  style.font-color: "${colors.text_light}"
  style.border-radius: 8
  retire_list: {
    label: "Retirement List\n\n[0x7F3A1000]\n[0x7F3A3000]\n[0x7F3A4000]"
    shape: rectangle
    style.fill: "#FED7D7"
    style.stroke: "${colors.danger}"
    style.font-color: "${colors.text_dark}"
  }
  scan_result: {
    label: "Scan Result\n\n0x7F3A1000: PROTECTED\n0x7F3A3000: FREE\n0x7F3A4000: FREE"
    shape: rectangle
    style.fill: "#C6F6D5"
    style.stroke: "${colors.protected}"
    style.font-color: "${colors.text_dark}"
  }
  retire_list -> scan_result: "scan" {
    label: "hp_scan_and_reclaim()"
    style.stroke: "${colors.thread_b}"
    style.bold: true
  }
}
# ============================================================================
# Target Node
# ============================================================================
Node_0x7F3A1000: {
  label: "Node @ 0x7F3A1000\n\nvalue: 42\nnext: 0x7F3A2000"
  shape: rectangle
  style.fill: "${colors.node}"
  style.stroke: "#553C9A"
  style.font-color: "${colors.text_light}"
  style.bold: true
  style.border-radius: 8
  style.3d: true
}
# ============================================================================
# Connections
# ============================================================================
Thread_A.hazard_slot_0 -> Registry.row_0: "publish\n(memory_order_release)" {
  style.stroke: "${colors.hazard_slot}"
  style.stroke-width: 2
  style.bold: true
}
Thread_A.local_var -> Node_0x7F3A1000: "dereference\n(protected access)" {
  style.stroke: "${colors.thread_a}"
  style.stroke-width: 2
}
Registry.row_0 -> Thread_B.scan_result: "snapshot\n(memory_order_acquire)" {
  label: "scan reads\nall slots"
  style.stroke: "${colors.protected}"
  style.stroke-width: 2
  style.bold: true
}
Thread_B.scan_result -> Node_0x7F3A1000: "NOT freed\n(in hazard slot)" {
  style.stroke: "${colors.protected}"
  style.stroke-width: 3
  style.bold: true
  style.animated: true
}
# ============================================================================
# Protocol Explanation
# ============================================================================
Protocol: {
  label: "Set-Then-Validate Protocol"
  style.fill: "#FFFBEB"
  style.stroke: "#D69E2E"
  style.border-radius: 8
  step1: {
    label: "1. Load pointer from source"
    shape: text
    style.font-color: "${colors.text_dark}"
  }
  step2: {
    label: "2. Store to hazard slot (release)"
    shape: text
    style.font-color: "${colors.text_dark}"
  }
  step3: {
    label: "3. Validate source unchanged"
    shape: text
    style.font-color: "${colors.text_dark}"
  }
  step4: {
    label: "4. Safe to dereference"
    shape: text
    style.font-color: "${colors.protected}"
    style.bold: true
  }
}
# ============================================================================
# Invariant Box
# ============================================================================
Invariant: {
  label: |md
    **Core Invariant:**
    A node present in ANY hazard slot
    will NEVER be freed by scan_and_reclaim.
    This guarantees Thread A's access is safe
    as long as the hazard slot is set.
  |
  shape: rectangle
  style.fill: "#EBF8FF"
  style.stroke: "${colors.thread_a}"
  style.border-radius: 8
  style.font-color: "${colors.text_dark}"
}
# ============================================================================
# Layout positioning
# ============================================================================
Thread_A -> Registry {
  style.opacity: 0
}
Registry -> Thread_B {
  style.opacity: 0
}
Thread_B -> Protocol {
  style.opacity: 0
}
Protocol -> Invariant {
  style.opacity: 0
}