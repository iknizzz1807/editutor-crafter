vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Set-Then-Validate Protocol
  ## Race Prevention via Validation Step
|
direction: right
# ============================================================================
# VULNERABLE PATTERN: Load Then Protect (RACE CONDITION)
# ============================================================================
vulnerable_header: {
  label: "VULNERABLE PATTERN"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    font-color: "#B71C1C"
    bold: true
  }
}
vulnerable_timeline: {
  grid-columns: 2
  grid-gap: 0
  v_t1_label: {
    label: "Thread 1\n(Victim)"
    style: {
      fill: "#FFCDD2"
      stroke: "#EF5350"
      bold: true
    }
  }
  v_t2_label: {
    label: "Thread 2\n(Reclaimer)"
    style: {
      fill: "#FFCDD2"
      stroke: "#EF5350"
      bold: true
    }
  }
  # Thread 1 operations
  v_t1_1: {
    label: "1. node = load(&top)"
    style.fill: "#FFECB3"
  }
  v_t2_1: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
  v_t1_2: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
  v_t2_2: {
    label: |md
      2. CAS(&top, node, next)
         **SUCCESS**
    |
    style: {
      fill: "#FFECB3"
      bold: true
    }
  }
  v_t1_3: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
  v_t2_3: {
    label: |md
      3. retire(node)
         hp_retire(ptr)
    |
    style.fill: "#FFECB3"
  }
  v_t1_4: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
  v_t2_4: {
    label: |md
      4. scan()
         **node NOT protected**
         → **free(node)**
    |
    style: {
      fill: "#FFCDD2"
      font-color: "#B71C1C"
      bold: true
    }
  }
  v_t1_5: {
    label: |md
      5. hp_protect(slot, node)
         **TOO LATE!**
    |
    style: {
      fill: "#FFCDD2"
      font-color: "#B71C1C"
      bold: true
    }
  }
  v_t2_5: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
  v_t1_6: {
    label: |md
      6. access(node)
         **USE-AFTER-FREE!**
    |
    style: {
      fill: "#B71C1C"
      font-color: "#FFFFFF"
      bold: true
    }
  }
  v_t2_6: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
}
vulnerable_result: {
  label: |md
    **RESULT: Memory Corruption**
    Thread 1 loaded the pointer but hadn't
    protected it yet. Thread 2 freed it.
  |
  style: {
    fill: "#B71C1C"
    font-color: "#FFFFFF"
    bold: true
  }
}
# ============================================================================
# SAFE PATTERN: Set-Then-Validate (NO RACE)
# ============================================================================
safe_header: {
  label: "SAFE PATTERN"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: "#1B5E20"
    bold: true
  }
}
safe_timeline: {
  grid-columns: 2
  grid-gap: 0
  s_t1_label: {
    label: "Thread 1\n(Safe)"
    style: {
      fill: "#C8E6C9"
      stroke: "#66BB6A"
      bold: true
    }
  }
  s_t2_label: {
    label: "Thread 2\n(Reclaimer)"
    style: {
      fill: "#C8E6C9"
      stroke: "#66BB6A"
      bold: true
    }
  }
  # Thread 1 operations with validation
  s_t1_1: {
    label: |md
      1. node = load(&top)
         *Read pointer value*
    |
    style.fill: "#E8F5E9"
  }
  s_t2_1: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
  s_t1_2: {
    label: |md
      2. hp_protect(slot, node)
         *Publish protection*
    |
    style: {
      fill: "#C8E6C9"
      bold: true
    }
  }
  s_t2_2: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
  s_t1_3: {
    label: |md
      3. validate:
         current = load(&top)
         **current != node?**
         → **RETRY**
    |
    style: {
      fill: "#FFF9C4"
      font-color: "#F57F17"
      bold: true
    }
  }
  s_t2_3: {
    label: |md
      3. CAS(&top, node, next)
         *Changed top!*
    |
    style.fill: "#E8F5E9"
  }
  s_t1_4: {
    label: |md
      4. Validation FAILED
         Retry loop...
         node = load(&top)  *new value*
    |
    style: {
      fill: "#FFF9C4"
      bold: true
    }
  }
  s_t2_4: {
    label: |md
      4. retire(old_node)
         scan() → sees protection
         **CANNOT FREE**
    |
    style.fill: "#C8E6C9"
  }
  s_t1_5: {
    label: |md
      5. hp_protect(slot, new_node)
         validate: **MATCH**
         → **SAFE TO ACCESS**
    |
    style: {
      fill: "#A5D6A7"
      font-color: "#1B5E20"
      bold: true
    }
  }
  s_t2_5: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
  }
}
safe_result: {
  label: |md
    **RESULT: Safe Access**
    Validation detected that the pointer
    changed. Thread 1 retries with the
    current value, ensuring protection
    is valid before dereferencing.
  |
  style: {
    fill: "#2E7D32"
    font-color: "#FFFFFF"
    bold: true
  }
}
# ============================================================================
# PROTOCOL PSEUDOCODE
# ============================================================================
protocol_box: {
  label: "Set-Then-Validate Protocol"
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
  }
  pseudocode: |code
    void* hp_protect_load(slot, source) {
        void* node;
        do {
            // Step 1: Load pointer value
            node = atomic_load(source, ACQUIRE);
            // Step 2: Publish protection
            hp_protect(slot, node);
            // Step 3: Validate - still current?
        } while (node != atomic_load(source, ACQUIRE));
        return node;  // Guaranteed valid protection
    }
  |
}
# ============================================================================
# KEY INSIGHT BOX
# ============================================================================
insight_box: {
  label: |md
    ## Key Insight
    We're not protecting a *specific* node — we're
    protecting **"whatever is at `source` right now"**.
    If another thread changes `source` between our
    load and protect, validation detects this and
    we retry with the new value.
    The protection is only valid if our published
    value matches the current source value.
  |
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
# ============================================================================
# TIMING DIAGRAM: PROTECTION WINDOW
# ============================================================================
timing_header: {
  label: "Protection Window Analysis"
  style: {
    fill: "#ECEFF1"
    stroke: "#546E7A"
    stroke-width: 2
    bold: true
  }
}
timing_diagram: {
  shape: sequence_diagram
  Thread1: Thread 1
  Thread2: Thread 2
  Thread1 -> Thread1: "load(source)"
  Thread1 -> Thread1: "hp_protect(slot, node)"
  Thread1 -> Thread1: "validate: load(source)"
  race_window: {
    label: "Race Window"
    Thread1 -> Thread1: "|'md ← Vulnerable window between load and protect →'|"
  }
  Thread1 -> Thread1: "if match: safe access"
  Thread1 -> Thread1: "if mismatch: retry"
}
# ============================================================================
# CONNECTIONS
# ============================================================================
vulnerable_header -> vulnerable_timeline
vulnerable_timeline -> vulnerable_result
safe_header -> safe_timeline
safe_timeline -> safe_result
vulnerable_result -> protocol_box -> safe_result
protocol_box -> insight_box
insight_box -> timing_header
timing_header -> timing_diagram