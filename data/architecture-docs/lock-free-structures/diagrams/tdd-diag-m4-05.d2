vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# Retirement List Lifecycle State Machine
title: |md
  # Retirement List Lifecycle
  **Hazard Pointer Memory Reclamation Flow**
| {near: top-center}
# States
initial: {
  shape: circle
  label: ""
  style.fill: "#4CAF50"
}
in_data_structure: {
  label: "In Data\nStructure"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}
removed: {
  label: "Removed\n(Logical Delete)"
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
}
in_retirement_list: {
  label: "In Retirement\nList"
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
}
threshold_check: {
  shape: diamond
  label: "Threshold\nReached?"
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}
scan_snapshot: {
  label: "Scan:\nSnapshot All\nHazard Pointers"
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
}
check_protected: {
  shape: diamond
  label: "Protected\nby HP?"
  style.fill: "#FFF8E1"
  style.stroke: "#FFA000"
}
freed: {
  label: "Freed\n(Memory Reclaimed)"
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.font-color: "#1B5E20"
}
retained: {
  label: "Retained\n(Protected)"
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
}
# Final states
freed_final: {
  shape: circle
  label: "●"
  style.fill: "#4CAF50"
}
retained_final: {
  shape: circle
  label: "●"
  style.fill: "#F44336"
}
# Transitions
initial -> in_data_structure: "Node allocated\nand inserted"
in_data_structure -> removed: "CAS succeeds\n(node unlinked)"
removed -> in_retirement_list: "hp_retire(node)"
in_retirement_list -> threshold_check: "Add to list"
threshold_check -> in_retirement_list: "No\n(wait for more)" {
  style.stroke: "#F57C00"
  style.stroke-dash: 3
}
threshold_check -> scan_snapshot: "Yes\n(count ≥ threshold)"
scan_snapshot -> check_protected: "For each\nretired node"
check_protected -> freed: "No\n(not in snapshot)"
check_protected -> retained: "Yes\n(in snapshot)"
freed -> freed_final: ""
retained -> in_retirement_list: "Keep in list\n(next scan)" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 3
}
# Annotations
legend: {
  near: bottom-right
  threshold_formula: |md
    **Scan Threshold:**
    
    count ≥ 2 × threads × slots_per_thread
    
  |
  state_legend: {
    grid-columns: 2
    grid-gap: 8
    green_node: {
      label: ""
      width: 20
      shape: circle
      style.fill: "#4CAF50"
    }
    green_label: "Initial/Final (freed)"
    red_node: {
      label: ""
      width: 20
      shape: circle
      style.fill: "#F44336"
    }
    red_label: "Final (retained)"
    diamond_node: {
      label: ""
      width: 20
      shape: diamond
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
    }
    diamond_label: "Decision point"
  }
}
# Key invariant
invariant: {
  near: bottom-left
  content: |md
    **Key Invariant:**
    A node is only freed if it's not in ANY hazard pointer slot at the start of the scan.
    **Memory Ordering:**
    - `hp_protect`: `memory_order_release`
    - Scan reads: `memory_order_acquire`
    - Establishes happens-before relationship
  |
}
# Timing annotation
timing: {
  near: top-right
  content: |md
    **Timing Windows:**
    1. **Remove → Retire**: Immediate
    2. **Retire → Scan**: Bounded by threshold
    3. **Scan → Free**: Only if unprotected
    **Amortized Cost**: O(1) per retirement
  |
}