vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Scan-and-Reclaim Algorithm
  **Hazard Pointer Memory Reclamation (M4)**
  *Implementation-Grade State Transition Diagram*
| {near: top-center}

direction: right

classes: {
  step: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      font: mono
      border-radius: 4
    }
  }
  data_header: {
    style: {
      fill: "#607D8B"
      font-color: white
      bold: true
    }
  }
  data_cell: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
  }
  pointer: {
    style: {
      stroke: "#FB8C00"
      stroke-width: 2
      animated: true
    }
  }
  logic_gate: {
    shape: diamond
    style: {
      fill: "#F5F5F5"
    }
  }
}

# --- MEMORY STRUCTURES ---
# Corrections: Removed \n from labels of sql_table shapes

registry: "Hazard Pointer Registry (Global State)" {
  shape: sql_table
  style.fill: "#F5F5F5"
  style.stroke: "#607D8B"
  
  header: "Thread ID | Offset | Slot Value (Atomic)" {class: data_header}
  t0_s0: "T0 | 0x00 | 0x1000 (Node A)" {style.fill: "#C8E6C9"}
  t0_s1: "T0 | 0x08 | 0x0000 (NULL)"
  t1_s0: "T1 | 0x10 | 0x2000 (Node B)" {style.fill: "#C8E6C9"}
  t1_s1: "T1 | 0x18 | 0x3000 (Node C)" {style.fill: "#C8E6C9"}
  t2_s0: "T2 | 0x20 | 0x0000 (NULL)"
  t2_s1: "T2 | 0x28 | 0x1000 (Node A)" {style.fill: "#C8E6C9"}
}

retire_list: "Retirement List (Local Storage)" {
  shape: sql_table
  style.fill: "#F5F5F5"
  style.stroke: "#607D8B"
  
  header: "Index | Address | State" {class: data_header}
  idx0: "0 | 0x1000 | RETIRED" {style.fill: "#FFE0B2"}
  idx1: "1 | 0x2000 | RETIRED" {style.fill: "#FFE0B2"}
  idx2: "2 | 0x4000 | RETIRED" {style.fill: "#FFE0B2"}
  idx3: "3 | 0x5000 | RETIRED" {style.fill: "#FFE0B2"}
}

# --- ALGORITHM STEPS ---

step1: |md
  ### Step 1: SNAPSHOT
  **Read Global HP Registry**
  - Iterate all active threads
  - `atomic_load(acquire)` slots
  - Store non-NULLs in `plist[]`
| {
  class: step
  width: 300
}

step2: |md
  ### Step 2: PARTITION
  **Cross-Reference Snapshot**
  - Sort `plist[]` for lookup
  - For `node` in `RetireList`:
    - If `node` in `plist`: **PROTECTED**
    - Else: **UNPROTECTED**
| {
  class: step
  width: 300
}

step3: |md
  ### Step 3: FREE
  **Final Reclamation**
  - `free()` Unprotected nodes
  - Re-insert Protected to list
  - `count = protected.size()`
| {
  class: step
  width: 300
}

# --- WORKFLOW CONNECTIONS ---

registry -> step1: "atomic_load(acquire)" {
  class: pointer
  source-arrowhead: circle
}

retire_list -> step2: "scan retired addresses" {
  style.stroke-dash: 3
  style.stroke: "#607D8B"
}

step1 -> step2: "Local plist[]: [0x1000, 0x2000, 0x3000]" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    bold: true
  }
}

step2 -> step3: "Unprotected: [0x4000, 0x5000]" {
  style: {
    stroke: "#F44336"
    stroke-width: 3
    bold: true
  }
}

# --- FINAL STATE ANNOTATIONS ---

freed_nodes: "Memory Manager (Heap)" {
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 2
  
  f1: "0x4000: **FREED**" {style.font-color: red}
  f2: "0x5000: **FREED**" {style.font-color: red}
}

protected_rem: "RetireList (Post-Scan)" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  
  p1: "0x1000: ACTIVE" {style.bold: true}
  p2: "0x2000: ACTIVE" {style.bold: true}
}

step3 -> freed_nodes: "call free()" {
  class: pointer
  style.stroke: "#F44336"
}
step3 -> protected_rem: "retain" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

# --- INVARIANTS AND LEGEND ---

legend: "Intel Manual Spec: HP M4" {
  near: bottom-left
  style.fill: white
  style.stroke: "#2196F3"
  
  L1: "Atomic Operation" {
    style: {
      stroke-dash: 3
    }
  }
  L2: "Data Dependency" {
    style: {
      stroke-width: 2
      stroke: "#FB8C00"
    }
  }
  
  note: |md
    **Safety Property**
    $\forall n \in \text{RetireList}$, 
    $n$ is reclaimed $\iff$
    $n \notin \text{Registry}$
  |
}

ordering_guarantees: |md
  ## Memory Ordering Guarantees
  1. **Producer:** `store(node, release)` to HP slot.
  2. **Consumer:** `load(HP, acquire)` in scan.
  3. **Result:** Creates a total order where node 
     visibility is guaranteed before reclamation 
     logic begins.
| {
  near: bottom-right
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    stroke-width: 1
  }
}

# Metadata annotations
(step1 -> step2)[0].style.font-size: 11
(step2 -> step3)[0].style.font-size: 11
registry.t0_s0 -> step1: "snapshot 0x1000" {
  style: {
    stroke: "#4CAF50"
    stroke-dash: 3
  }
}
registry.t1_s0 -> step1: "snapshot 0x2000" {
  style: {
    stroke: "#4CAF50"
    stroke-dash: 3
  }
}