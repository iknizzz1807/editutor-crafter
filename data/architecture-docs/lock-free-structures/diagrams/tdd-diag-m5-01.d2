vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B5B95"
    sentinel: "#88B04B"
    regular: "#5B5EA6"
    bucket: "#F7CAC9"
    pointer: "#92A8D1"
    text: "#034F84"
  }
}
title: |md
  # Split-Ordered List Concept
  **Single sorted linked list with logical bucket regions**
| {near: top-center}
direction: right
# Legend
legend: {
  label: ""
  near: bottom-right
  sent_node: {
    label: "Sentinel Node\n(bucket marker)"
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.stroke: "#5D8C3E"
    style.font-size: 12
  }
  reg_node: {
    label: "Regular Node\n(key-value pair)"
    shape: rectangle
    style.fill: ${colors.regular}
    style.stroke: "#3D3D6B"
    style.font-size: 12
  }
  bucket_ptr: {
    label: "Bucket Pointer\n(indexes into list)"
    shape: circle
    style.fill: ${colors.bucket}
    style.stroke: "#D4A5A5"
    style.font-size: 12
  }
}
# Bucket Array (logical view)
buckets: {
  label: "Bucket Array\n(bucket_count = 4)"
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  b0: {
    label: "Bucket 0\n→ S0"
    shape: rectangle
    style.fill: ${colors.bucket}
    style.stroke: "#D4A5A5"
  }
  b1: {
    label: "Bucket 1\n→ S1"
    shape: rectangle
    style.fill: ${colors.bucket}
    style.stroke: "#D4A5A5"
  }
  b2: {
    label: "Bucket 2\n→ S2"
    shape: rectangle
    style.fill: ${colors.bucket}
    style.stroke: "#D4A5A5"
  }
  b3: {
    label: "Bucket 3\n→ S3"
    shape: rectangle
    style.fill: ${colors.bucket}
    style.stroke: "#D4A5A5"
  }
}
# Split-Ordered List (physical structure)
list: {
  label: "Split-Ordered List (sorted by so_key)"
  style.fill: "#FAFAFA"
  style.stroke: "#DDDDDD"
  direction: right
  head: {
    label: "HEAD\nso_key=0"
    shape: rectangle
    style.fill: ${colors.header}
    style.stroke: "#4A4A72"
    style.font-color: white
  }
  s0: {
    label: "S0\nsentinel"
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.stroke: "#5D8C3E"
  }
  k1: {
    label: "K1\nhash=0"
    shape: rectangle
    style.fill: ${colors.regular}
    style.stroke: "#3D3D6B"
    style.font-color: white
  }
  k2: {
    label: "K2\nhash=4"
    shape: rectangle
    style.fill: ${colors.regular}
    style.stroke: "#3D3D6B"
    style.font-color: white
  }
  s2: {
    label: "S2\nsentinel"
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.stroke: "#5D8C3E"
  }
  k3: {
    label: "K3\nhash=2"
    shape: rectangle
    style.fill: ${colors.regular}
    style.stroke: "#3D3D6B"
    style.font-color: white
  }
  s1: {
    label: "S1\nsentinel"
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.stroke: "#5D8C3E"
  }
  k4: {
    label: "K4\nhash=1"
    shape: rectangle
    style.fill: ${colors.regular}
    style.stroke: "#3D3D6B"
    style.font-color: white
  }
  s3: {
    label: "S3\nsentinel"
    shape: rectangle
    style.fill: ${colors.sentinel}
    style.stroke: "#5D8C3E"
  }
  null: {
    label: "NULL"
    shape: circle
    style.fill: "#EEEEEE"
    style.stroke: "#999999"
  }
  head -> s0 -> k1 -> k2 -> s2 -> k3 -> s1 -> k4 -> s3 -> null
}
# Bucket to Sentinel connections
buckets.b0 -> list.s0: {
  style.stroke: ${colors.pointer}
  style.stroke-dash: 3
}
buckets.b1 -> list.s1: {
  style.stroke: ${colors.pointer}
  style.stroke-dash: 3
}
buckets.b2 -> list.s2: {
  style.stroke: ${colors.pointer}
  style.stroke-dash: 3
}
buckets.b3 -> list.s3: {
  style.stroke: ${colors.pointer}
  style.stroke-dash: 3
}
# Key insight annotation
insight: |md
  **Key Insight: Buckets don't contain elements**
  • Buckets are **logical regions** in a single list
  • Sentinel nodes mark where each bucket begins
  • Elements between sentinels belong to that bucket
  • Resizing only adds new sentinels—no element movement!
| {near: bottom-center}
# Reverse-bit ordering note
ordering: |md
  **Reverse-bit ordering ensures:**
  When bucket 0 splits into 0 and 2:
  • Bucket 0 keeps: so_keys 0x0..., 0x4..., 0x8...
  • Bucket 2 gets: so_keys 0x2..., 0x6..., 0xA...
  These groups are **contiguous** in the sorted list!
| {near: top-right}