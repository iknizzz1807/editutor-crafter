d2
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5F7"
    bucket0: "#6BB3D0"
    bucket2: "#FF9400"
    data: "#FFA500"
    sentinel0: "#B5AFF6"
    sentinel2: "#E8D5F7"
    arrow: "#666666"
  }
  # Legend
  legend: {
    near: bottom-right
    bucket0_color: {
      shape: rectangle
      width: 120
      style.fill: ${colors.bucket0}
      label: "Bucket 0"
    }
    bucket2_color: {
      shape: rectangle
      width: 120
      style.fill: ${colors.bucket2}
      label: "Bucket 2"
    }
    data_color: {
      shape: circle
      width: 60
      style.fill: ${colors.data}
    }
    sentinel_shape: {
      shape: diamond
      width: 50
      style.fill: ${colors.sentinel0}
    }
  }
  # Before Split
  before_split: {
    title: {
      label: "Before Split"
      near: top-center
      shape: text
      style.font-size: 28
      style.bold: true
    }
    bucket0_before: {
      label: "Bucket 0"
      style.fill: ${colors.bucket0}
    }
    data1: {
      class: data_color
      label: "K1\nso_key: 0x8..."
    }
    data2: {
      class: data_color
      label: "K2\nso_key: 0x4..."
    }
    data3: {
      class: data_color
      label: "K3\nso_key: 0xC..."
    }
    data4: {
      class: data_color
      label: "K4\nso_key: 0x2..."
    }
    data5: {
      class: data_color
      label: "K5\nso_key: 0xA..."
    }
    sentinel_before: {
      class: sentinel_shape
      label: "S0"
    }
    # Connections
    bucket0_before -> sentinel_before: "covers"
    sentinel_before -> data1: "->"
    data1 -> data2: "->"
    data2 -> data3: "->"
    data3 -> data4: "->"
    data4 -> data5: "->"
  }
  # After Split
  after_split: {
    title: {
      label: "After Split (4 buckets)"
      near: top-center
      shape: text
      style.font-size: 28
      style.bold: true
    }
    bucket0_after: {
      label: "Bucket 0"
      style.fill: ${colors.bucket0}
    }
    bucket2_after: {
      label: "Bucket 2 (NEW)"
      style.fill: ${colors.bucket2}
      style.stroke-dash: 3
    }
    data1_after: {
      class: data_color
      label: "K1\nso_key: 0x8..."
    }
    data4_after: {
      class: data_color
      label: "K4\nso_key: 0x2..."
    }
    data2_after: {
      class: data_color
      label: "K2\nso_key: 0x4..."
    }
    data5_after: {
      class: data_color
      label: "K5\nso_key: 0xA..."
    }
    data3_after: {
      class: data_color
      label: "K3\nso_key: 0xC..."
    }
    sentinel0_after: {
      class: sentinel_shape
      label: "S0"
      style.fill: ${colors.sentinel0}
    }
    sentinel2_after: {
      class: sentinel_shape
      style.fill: ${colors.sentinel2}
      label: "S2"
    }
    # Connections
    bucket0_after -> sentinel0_after: "covers"
    bucket2_after -> sentinel2_after: "covers"
    sentinel0_after -> data1_after: "->"
    data1_after -> data4_after: "->"
    sentinel2_after -> data2_after: "->"
    data2_after -> data5_after: "->"
    data5_after -> data3_after: "->"
  }
  # Arrow between states
  before_split -> after_split: {
    label: "RESIZE\n(dbl buckets)"
    style.stroke-dash: 3
    style.stroke-width: 3
    style.animated: true
  }
  legend
}