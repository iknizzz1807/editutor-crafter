vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Incremental Resize: On-Demand Bucket Initialization
  Lazy initialization with parent-first dependency chain
| {near: top-center}
direction: right
# Legend
legend: {
  style.fill: transparent
  shape: rectangle
  initialized: "Initialized Bucket" {style.fill: "#ACE1AF"}
  pending: "Pending (NULL sentinel)" {style.fill: "#E8E8E8"}
  parent_child: "Parent → Child dependency"
  initialized -> pending: parent_child {
    style.stroke-dash: 3
    style.stroke: gray
  }
}
# Phase 1: Initial State (4 buckets)
phase1: "Phase 1: Initial State (4 buckets)" {
  style.fill: "#F0F0F0"
  style.stroke: "#666"
  buckets_4: "Bucket Array" {
    grid-columns: 4
    grid-gap: 0
    b0: "0\n✓" {style.fill: "#ACE1AF"}
    b1: "1\n✓" {style.fill: "#ACE1AF"}
    b2: "2\nNULL" {style.fill: "#E8E8E8"}
    b3: "3\nNULL" {style.fill: "#E8E8E8"}
  }
  list_4: "Split-Ordered List" {
    head_4: "HEAD" {shape: circle}
    s0_4: "S0" {style.fill: "#B5AFF6"}
    s1_4: "S1" {style.fill: "#B5AFF6"}
    head_4 -> s0_4
    s0_4 -> s1_4
    s1_4 -> "..." {shape: text}
  }
  note1: |md
    Only buckets 0, 1 initialized
    Buckets 2, 3 have NULL sentinels
  | {shape: text}
}
# Phase 2: Thread accesses bucket 2
phase2: "Phase 2: Access bucket 2 → needs parent" {
  style.fill: "#FFF9E6"
  style.stroke: "#CC9900"
  thread: "Thread\naccessing\nbucket 2" {
    shape: person
    style.fill: "#FFD700"
  }
  check: "Check parent\nbucket 0" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  parent_ok: "Parent 0\nalready ✓" {
    style.fill: "#ACE1AF"
  }
  thread -> check: "init_bucket(2)"
  check -> parent_ok: "parent(2) = 0"
}
# Phase 3: Thread accesses bucket 6
phase3: "Phase 3: Access bucket 6 → chain init" {
  style.fill: "#E6F3FF"
  style.stroke: "#0066CC"
  thread2: "Thread\naccessing\nbucket 6" {
    shape: person
    style.fill: "#87CEEB"
  }
  chain: "Dependency Chain" {
    grid-rows: 1
    grid-gap: 20
    step1: "6 → parent(6)=4\nNULL?" {style.fill: "#FFE4B5"}
    step2: "4 → parent(4)=0\n✓" {style.fill: "#ACE1AF"}
    step3: "Init bucket 4\ninsert S4" {style.fill: "#B5AFF6"}
    step4: "Init bucket 6\ninsert S6" {style.fill: "#B5AFF6"}
    step1 -> step2: "check" {style.stroke-dash: 3}
    step2 -> step3: "init"
    step3 -> step4: "init"
  }
  thread2 -> chain: "init_bucket(6)"
}
# Phase 4: Concurrent race
phase4: "Phase 4: Race condition handling" {
  style.fill: "#FFE6E6"
  style.stroke: "#CC0000"
  t1: "Thread 1" {shape: person; style.fill: "#FFB6C1"}
  t2: "Thread 2" {shape: person; style.fill: "#FFB6C1"}
  cas_race: "CAS(buckets[5], NULL, S5)" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  winner: "Winner: S5 inserted\nLoser: Free local S5', use winner's" {
    style.fill: "#ACE1AF"
  }
  t1 -> cas_race
  t2 -> cas_race
  cas_race -> winner
}
# Phase 5: Final state (8 buckets)
phase5: "Phase 5: After lazy init (8 buckets)" {
  style.fill: "#E6FFE6"
  style.stroke: "#006600"
  buckets_8: "Bucket Array" {
    grid-columns: 4
    grid-gap: 0
    b0_f: "0 ✓" {style.fill: "#ACE1AF"}
    b1_f: "1 ✓" {style.fill: "#ACE1AF"}
    b2_f: "2 ✓" {style.fill: "#ACE1AF"}
    b3_f: "3 ✓" {style.fill: "#ACE1AF"}
    b4_f: "4 ✓" {style.fill: "#ACE1AF"}
    b5_f: "5 ✓" {style.fill: "#ACE1AF"}
    b6_f: "6 ✓" {style.fill: "#ACE1AF"}
    b7_f: "7 NULL" {style.fill: "#E8E8E8"}
  }
  list_8: "Split-Ordered List" {
    head_8: "HEAD" {shape: circle}
    s0_8: "S0" {style.fill: "#B5AFF6"}
    s4_8: "S4" {style.fill: "#B5AFF6"}
    s2_8: "S2" {style.fill: "#B5AFF6"}
    s6_8: "S6" {style.fill: "#B5AFF6"}
    s1_8: "S1" {style.fill: "#B5AFF6"}
    s5_8: "S5" {style.fill: "#B5AFF6"}
    s3_8: "S3" {style.fill: "#B5AFF6"}
    head_8 -> s0_8
    s0_8 -> s4_8
    s4_8 -> s2_8
    s2_8 -> s6_8
    s6_8 -> s1_8
    s1_8 -> s5_8
    s5_8 -> s3_8
    s3_8 -> "..." {shape: text}
  }
  note5: |md
    Sentinels inserted in reverse-bit order
    No element movement required
    Bucket 7 still pending (never accessed)
  | {shape: text}
}
# Parent bucket formula
formula: "Parent Bucket Formula" {
  style.fill: "#F5F5F5"
  style.stroke: "#333"
  code: |go
    // Clear lowest set bit
    parent(bucket) = bucket & (bucket - 1)
    Examples:
      parent(1) = 1 & 0 = 0
      parent(2) = 2 & 1 = 0  
      parent(3) = 3 & 2 = 2
      parent(4) = 4 & 3 = 0
      parent(5) = 5 & 4 = 4
      parent(6) = 6 & 5 = 4
      parent(7) = 7 & 6 = 6
  | {shape: code}
}
# Flow arrows
phase1 -> phase2 -> phase3 -> phase4 -> phase5 {
  style.stroke: "#666"
  style.stroke-width: 2
}
formula -> phase3 {
  style.stroke: "#999"
  style.stroke-dash: 3
}
# Key properties box
properties: "Key Properties" {
  style.fill: "#E6E6FA"
  p1: "✓ No global coordination" {shape: text}
  p2: "✓ Lazy initialization on access" {shape: text}
  p3: "✓ CAS ensures single-winner" {shape: text}
  p4: "✓ Parent always before child" {shape: text}
  p5: "✓ No element movement" {shape: text}
}