layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Lock-free Insert Trace
Compute hash → Get bucket sentinel → Traverse list → CAS insert
'| {
  near: top-center
}

direction: right

Step_1: {
  label: "Step 1: Compute Hash & Bucket"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  compute: {
    shape: code
    label: |'go
hash = hash_fn(key)
bucket = hash % bucket_count
so_key = reverse_bits(hash) | REGULAR_BIT
    '|
  }
  result: {
    shape: text
    label: |'md
**Results:**
- hash: `0x12345678`
- bucket: `5`
- so_key: `0x9E...78 | 0x8000...`
    '|
  }
  compute -> result
}

Step_2: {
  label: "Step 2: Get/Init Bucket Sentinel"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  bucket_check: {
    label: |'md
Check if bucket 5 sentinel exists
`sentinel = buckets[5].sentinel`
    '|
  }
  init_if_needed: {
    label: |'md
If NULL: Initialize bucket
- Ensure parent bucket initialized
- Create sentinel node
- Insert sentinel into list
    '|
    style.stroke-dash: 3
  }
  sentinel_result: {
    style.fill: "#C8E6C9"
    label: |'md
**Got sentinel S5**
- so_key = reverse_bits(5)
- Points into list at bucket 5 position
    '|
  }
  bucket_check -> init_if_needed: "if NULL"
  init_if_needed -> sentinel_result
  bucket_check -> sentinel_result: "if exists"
}

Step_3: {
  label: "Step 3: Traverse Sorted List"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  list_state: {
    head: "HEAD" {
      shape: square
      style.fill: "#E1BEE7"
    }
    s5: "S5\n(sentinel)" {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    k1: "K1\nso_key: 0x91..." {
      shape: rectangle
    }
    k2: "K2\nso_key: 0x93..." {
      shape: rectangle
    }
    s7: "S7\n(sentinel)" {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    k3: "K3\nso_key: 0xC7..." {
      shape: rectangle
    }
    null: "NULL" {
      shape: circle
      style.fill: "#EEEEEE"
    }
    head -> s5 -> k1 -> k2 -> s7 -> k3 -> null
  }
  traversal: {
    shape: text
    label: |'md
**Find Position (hp_protect slots 0,1)**
1. prev = S5, curr = K1
2. K1.so_key < target.so_key → advance
3. prev = K1, curr = K2  
4. K2.so_key < target.so_key → advance
5. prev = K2, curr = S7
6. S7.so_key > target.so_key → **STOP**
**Position found:** insert between K2 and S7
    '|
  }
  list_state -> traversal
}

Step_4: {
  label: "Step 4: Prepare New Node"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  new_node: {
    shape: rectangle
    style.fill: "#A5D6A7"
    style.stroke: "#388E3C"
    style.bold: true
    label: |'md
**New Node (allocated)**
- so_key: 0x9E...78 | 0x8000...
- key:    user_key
- value:  user_value
- next:   S7 (curr)
    '|
  }
  prep: {
    shape: code
    label: |'go
new_node->next = curr  // Link to S7
// CAS will update prev->next
    '|
  }
  new_node -> prep
}

Step_5: {
  label: "Step 5: CAS Insert"
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  cas_attempt: {
    shape: code
    label: |'go
// CAS Loop:
CAS(&prev->next, curr, new_node)
// prev = K2
// expected curr = S7
// desired = new_node
    '|
  }
  success: {
    style.fill: "#C8E6C9"
    style.bold: true
    label: |'md
**CAS SUCCESS ✓**
Linearization point!
K2->next now points to new_node
Element is visible to all threads
    '|
  }
  failure: {
    style.fill: "#FFCDD2"
    label: |'md
**CAS FAIL ✗**
Another thread modified list
→ Retry from Step 3
→ Reload prev, curr
→ Use observed value
    '|
  }
  cas_attempt -> success: "success"
  cas_attempt -> failure: "failure"
  failure -> cas_attempt: "retry" {
    style.stroke-dash: 3
  }
}

Step_6: {
  label: "Step 6: Final State"
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  final_list: {
    head2: "HEAD" {
      shape: square
      style.fill: "#E1BEE7"
    }
    s5_2: "S5" {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    k1_2: "K1" {
      shape: rectangle
    }
    k2_2: "K2" {
      shape: rectangle
      style.stroke: "#4CAF50"
      style.stroke-width: 3
    }
    new: "NEW\ninserted!" {
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    s7_2: "S7" {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    k3_2: "K3" {
      shape: rectangle
    }
    null2: "NULL" {
      shape: circle
      style.fill: "#EEEEEE"
    }
    head2 -> s5_2 -> k1_2 -> k2_2 -> new -> s7_2 -> k3_2 -> null2
    (k2_2 -> new)[0].label: "CAS changed\nthis link"
    (k2_2 -> new)[0].style: {
      stroke: "#4CAF50"
      stroke-width: 3
      bold: true
    }
  }
  update: {
    shape: code
    label: |'go
atomic_fetch_add(&map->element_count, 1)
return {success: true, oom: false}
    '|
  }
  final_list -> update
}

Duplicate_Check: {
  label: "Duplicate Detection"
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  dup_scenario: {
    label: |'md
**During traversal, if:**
`curr->so_key == target_so_key`
AND
`eq_fn(curr->key, user_key)`
    '|
  }
  dup_action: {
    style.fill: "#FFECB3"
    label: |'md
**Key already exists!**
- free(new_node)
- release hazard slots
- return {success: false, oom: false}
    '|
  }
  dup_scenario -> dup_action
}

Hazard_Protection: {
  label: "Hazard Pointer Usage"
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  slots: {
    shape: text
    label: |'md
**Slot 0:** prev node
**Slot 1:** curr node
Set-then-validate protocol:
1. Load pointer
2. hp_protect(slot, node)
3. Validate still current
4. If changed, retry
    '|
  }
  timeline: {
    shape: code
    label: |'go
hp_protect(0, prev)
hp_protect(1, curr)
// ... access prev->next, curr->so_key ...
hp_release(0)
hp_release(1)
    '|
  }
  slots -> timeline
}

Step_1 -> Step_2
Step_2 -> Step_3
Step_3 -> Step_4
Step_4 -> Step_5
Step_5 -> Step_6

Step_3 -> Duplicate_Check: "during find" {
  style.stroke-dash: 5
  style.stroke: "#FFC107"
}
Step_3 -> Hazard_Protection: "protects nodes" {
  style.stroke-dash: 5
  style.stroke: "#E91E63"
}

legend: {
  shape: text
  near: bottom-center
  label: |'md
**Legend:**
🟠 Sentinel nodes (mark bucket boundaries)
🟢 Inserted node (result of this operation)
🔴 CAS operation (linearization point)
🔵 Hazard pointer protection required
'|
}