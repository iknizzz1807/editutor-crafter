vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5B7"
    sentinel: "#B8D4E3"
    regular: "#D4E8B8"
    target: "#FFB4B4"
    found: "#90EE90"
    arrow: "#4A5568"
    highlight: "#E53E3E"
  }
}

title: |md
  # Lock-free Hash Map: Lookup Traversal
  **Operation**: Traverse sorted list from bucket sentinel to find target key
  **Spec**: Harris-Michael Algorithm for Lock-Free Linked Lists
| {near: top-center}

direction: right

# Initial State - Complete List view
initial: {
  label: "State 0: Global View\nTarget: so_key=0x8000...0005"
  
  sentinel_start: "Bucket Sentinel\nso_key=0x8...0000\nkey=NULL" {
    shape: rectangle
    style.fill: ${colors.sentinel}
  }
  node1: "Node A\nso_key=0x8...0002\nkey='foo'" {
    shape: rectangle
    style.fill: ${colors.regular}
  }
  node2: "Node B\nso_key=0x8...0005\nkey='bar'" {
    shape: rectangle
    style.fill: ${colors.target}
    style.stroke: ${colors.highlight}
    style.stroke-width: 4
  }
  node3: "Node C\nso_key=0x8...0008\nkey='baz'" {
    shape: rectangle
    style.fill: ${colors.regular}
  }
  null: "NULL" {shape: oval}

  sentinel_start -> node1: "next"
  node1 -> node2: "next"
  node2 -> node3: "next"
  node3 -> null: "next"
}

# Step 1: Load sentinel
step1: {
  label: "Step 1: Load Sentinel\nhazard_protect(0, sentinel)"
  
  s1_sentinel: "SENTINEL\nso_key=0x...0000\nkey=NULL" {
    shape: rectangle
    style.fill: ${colors.found}
    style.bold: true
  }
  s1_node1: "Node A\n0x...0002" {
    shape: rectangle
    style.fill: ${colors.regular}
    style.opacity: 0.4
  }
  s1_node2: "Node B\n0x...0005" {
    shape: rectangle
    style.fill: ${colors.target}
    style.opacity: 0.4
  }
  
  s1_sentinel -> s1_node1 -> s1_node2
  
  s1_hazard: |md
    ### Traversal Context
    **Hazard Slot 0**: sentinel (0x...0000)
    **prev** = sentinel
    **curr** = NULL (not loaded)
    ---
    *Sentinel is safe from reclaim*
  | {
    shape: text
    style.font-size: 14
  }
}

# Step 2: Compare and advance
step2: {
  label: "Step 2: Advance to Target\nwhile curr->so_key < target"
  
  s2_prev: "prev: Node A\n0x...0002" {
    shape: rectangle
    style.fill: ${colors.found}
    style.stroke: "#000"
    style.stroke-width: 2
  }
  s2_curr: "curr: Node B\n0x...0005\nMATCH" {
    shape: rectangle
    style.fill: ${colors.target}
    style.stroke: ${colors.highlight}
    style.stroke-width: 4
    style.bold: true
  }
  s2_next: "next: Node C\n0x...0008" {
    shape: rectangle
    style.fill: ${colors.regular}
    style.opacity: 0.4
  }
  
  s2_prev -> s2_curr: "next"
  s2_curr -> s2_next: "next"
  
  s2_logic: |md
    ### Comparison Logic
    **Target**: 0x...0005
    **Action**: `curr->so_key (0x05) == target (0x05)`
    **Loop**: EXIT (Condition `<` failed)
    ---
    **HP Slot 0**: Node A (prev)
    **HP Slot 1**: Node B (curr)
  | {
    shape: text
    style.font-size: 14
  }
}

# Step 3: Check equality
step3: {
  label: "Step 3: Result Verification\nso_key match → compare keys"
  
  s3_curr: "Node B\nso_key=0x...0005\nkey='bar'" {
    shape: rectangle
    style.fill: ${colors.found}
    style.bold: true
    style.double-border: true
  }
  
  s3_target: "SEARCH PARAMS\nso_key=0x...0005\nkey='bar'" {
    shape: rectangle
    style.fill: ${colors.target}
    style.stroke-dash: 5
  }
  
  s3_curr -> s3_result: "eq_fn('bar', 'bar')"
  
  s3_result: "TRUE: FOUND!\nreturn {found, value}" {
    shape: diamond
    style.fill: ${colors.found}
    style.bold: true
    style.stroke-width: 3
  }
  
  s3_logic: |md
    ### Verification Steps
    1. **SO_KEY**: 0x05 == 0x05 (Match)
    2. **KEY TYPE**: !NULL (Not a sentinel)
    3. **KEY DATA**: 'bar' == 'bar' (Match)
    ---
    **Return**: SUCCESS
  | {
    shape: text
    style.font-size: 14
  }
}

# Not found case
not_found: {
  label: "Alternate: Hash Collision\nso_key matches, but key differs"
  
  nf_curr: "Node X\nso_key=0x...0005\nkey='qux'" {
    shape: rectangle
    style.fill: ${colors.regular}
  }
  nf_target: "SEARCH PARAMS\nso_key=0x...0005\nkey='bar'" {
    shape: rectangle
    style.fill: ${colors.target}
    style.stroke-dash: 5
  }
  
  nf_curr -> nf_result: "eq_fn('qux', 'bar')"
  
  nf_result: "FALSE: NOT FOUND\nkey mismatch" {
    shape: diamond
    style.fill: "#FF6B6B"
    style.font-color: "#FFF"
  }
  
  nf_logic: |md
    ### Collision Logic
    *Different keys produced same SO_KEY*
    1. **SO_KEY**: Match (0x05)
    2. **KEY DATA**: 'qux' != 'bar' (Mismatch)
    ---
    **Return**: FAILURE (Not found)
  | {
    shape: text
    style.font-size: 14
  }
}

# Algorithm pseudocode
algorithm: {
  label: "Lookup Implementation (C-Style)"
  code: |go
    func hm_list_find(start *Node, target_so uint64, target_key string) {
      prev := start
      hp_protect(0, prev)
      
      curr := atomic_load(&prev.next)
      hp_protect(1, curr)
      
      for curr != nil && curr.so_key < target_so {
        prev = curr
        hp_protect(0, prev) // Shift HP
        curr = atomic_load(&curr.next)
        hp_protect(1, curr)
      }
      
      if curr != nil && curr.so_key == target_so && 
         curr.key != nil && eq(curr.key, target_key) {
        return found(prev, curr)
      }
      return not_found(prev, curr)
    }
  | {
    shape: text
    style.font: mono
    style.font-size: 14
    style.stroke: "#AAA"
    style.fill: "#F8F8F8"
  }
}

# Control Flow
initial -> step1: "1. Begin"
step1 -> step2: "2. Traverse"
step2 -> step3: "3. Verify Match"
step2 -> not_found: "3b. Collision"

# Layout Hints
step1.s1_hazard.style.font-color: "#2D3748"
step2.s2_logic.style.font-color: "#2D3748"
step3.s3_logic.style.font-color: "#2D3748"
not_found.nf_logic.style.font-color: "#2D3748"