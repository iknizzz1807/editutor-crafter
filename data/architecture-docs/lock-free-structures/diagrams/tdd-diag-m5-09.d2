layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    pad: 40
  }
  colors: {
    header: "#6F42C1"
    data: "#0366D6"
    free: "#28A745"
    padding: "#6A737D"
    pointer: "#D15704"
    marked: "#D73A49"
  }
}

# --------------------------------------------------------------------------------
# HEADER & TITLE
# --------------------------------------------------------------------------------
title: |md
  # Two-Phase Delete Protocol (Lock-Free)
  **Engineering Specification: Intel x86-64 Memory Model Implementation**
  *Protocol: Logical Mark → Physical Unlink → Deferred Reclamation (RCU/Hazard Pointers)*
|
title.shape: text
title.near: top-center
title.style: {
  font-size: 28
  bold: true
}

# --------------------------------------------------------------------------------
# CLASSES & STYLES
# --------------------------------------------------------------------------------
classes: {
  memory_node: {
    shape: sql_table
    style: {
      stroke: "#24292E"
      stroke-width: 2
      fill: "#FFFFFF"
      border-radius: 4
    }
  }
  marked_node: {
    style: {
      fill: "#FFEEF0"
      stroke: "#D73A49"
      stroke-width: 4
      bold: true
    }
  }
  cas_operation: {
    shape: parallelogram
    style: {
      fill: "#FFF5B1"
      stroke: "#DBAB09"
      font: mono
      bold: true
    }
  }
}

# --------------------------------------------------------------------------------
# PHASE 1: LOGICAL DELETE (MARKING)
# --------------------------------------------------------------------------------
phase1: "PHASE 1: ATOMIC LOGICAL MARK" {
  style: {
    fill: "#F6F8FA"
    stroke: "#0366D6"
    stroke-width: 2
    double-border: true
  }

  p1_before: "1.1: State BEFORE Mark" {
    node_prev: "PREV (0x1000)" {
      shape: sql_table
      next: "0x2000" {constraint: "PTR"}
    }
    node_curr: "CURR (0x2000)" {
      shape: sql_table
      style.fill: "#E1F5FE"
      next: "0x3000" {constraint: "LIVE"}
    }
    node_next: "NEXT (0x3000)" {
      shape: sql_table
      next: "0x4000"
    }
    
    node_prev.next -> node_curr: "prev->next"
    node_curr.next -> node_next: "curr->next"
  }

  p1_transition: "LP: CAS(&curr->next, 0x3000, 0x3001)" {
    class: cas_operation
  }

  p1_after: "1.2: State AFTER Mark (Linearized)" {
    node_prev_a: "PREV (0x1000)" {
      shape: sql_table
      next: "0x2000"
    }
    node_curr_a: "CURR (0x2000)" {
      class: marked_node
      shape: sql_table
      next: "0x3001" {constraint: "MARKED"}
    }
    node_next_a: "NEXT (0x3000)" {
      shape: sql_table
      next: "0x4000"
    }
    
    node_prev_a.next -> node_curr_a
    node_curr_a.next -> node_next_a: "Logical Link Intact" {
      style: {
        stroke: "#D73A49"
        stroke-width: 4
      }
    }
  }
  
  p1_before -> p1_transition -> p1_after {
    style.stroke-dash: 5
  }
}

# --------------------------------------------------------------------------------
# PHASE 2: PHYSICAL DELETE (UNLINKING)
# --------------------------------------------------------------------------------
phase2: "PHASE 2: ATOMIC PHYSICAL UNLINK" {
  style: {
    fill: "#F0F9FF"
    stroke: "#28A745"
    stroke-width: 2
    double-border: true
  }

  p2_before: "2.1: Detect Marked Bit" {
    u_prev: "PREV (0x1000)" {
      shape: sql_table
      next: "0x2000"
    }
    u_curr: "CURR (0x2000)" {
      class: marked_node
      shape: sql_table
      next: "0x3001"
    }
    u_next: "NEXT (0x3000)" {
      shape: sql_table
    }
    
    u_prev.next -> u_curr
    u_curr.next -> u_next
  }

  p2_transition: "CAS(&prev->next, 0x2000, 0x3000)" {
    class: cas_operation
  }

  p2_after: "2.2: Pointer Bypass Complete" {
    un_prev: "PREV (0x1000)" {
      shape: sql_table
      style.fill: "#DCFFE4"
      next: "0x3000" {constraint: "NEW"}
    }
    un_curr: "CURR (0x2000)" {
      shape: sql_table
      style.opacity: 0.3
      next: "0x3001"
    }
    un_next: "NEXT (0x3000)" {
      shape: sql_table
    }
    
    un_prev.next -> un_next: "PHYSICAL BYPASS" {
      style: {
        stroke: "#28A745"
        stroke-width: 5
      }
    }
    un_curr.next -> un_next: "Retired" {
      style.stroke-dash: 3
      style.opacity: 0.2
    }
  }

  p2_before -> p2_transition -> p2_after {
    style.stroke-dash: 5
  }
}

# --------------------------------------------------------------------------------
# MEMORY SPECIFICATION (INTEL 64-BIT ALIGNMENT)
# --------------------------------------------------------------------------------
mem_spec: "Memory Layout: Node structure (sizeof=32B)" {
  shape: sql_table
  style: {
    fill: "#F4F6F7"
    stroke: "#24292E"
  }
  
  "Offset 0x00": "Header / Metadata [8 Bytes]" {style.fill: "#E8DAEF"}
  "Offset 0x08": "Value / Payload [8 Bytes]" {style.fill: "#D6EAF8"}
  "Offset 0x10": "Next Pointer (Mark Bit at Bit 0) [8 Bytes]" {style.fill: "#FBEEE6"}
  "Offset 0x18": "Padding / Reserved [8 Bytes]" {style.fill: "#EBEDEF"}
}

pointer_bitfield: "Next Pointer Bit Encoding (64-bit)" {
  grid-rows: 1
  grid-columns: 2
  grid-gap: 0
  
  addr: "Canonical Virtual Address [Bits 63...1]" {
    width: 500
    height: 60
    style: {
      fill: "#0366D6"
      font-color: white
      bold: true
    }
  }
  mark: "MARK [Bit 0]" {
    width: 100
    height: 60
    style: {
      fill: "#D73A49"
      font-color: white
      bold: true
    }
  }
}

# --------------------------------------------------------------------------------
# IMPLEMENTATION MECHANISMS
# --------------------------------------------------------------------------------
mechanisms: {
  helping: "Helping Logic" {
    style.fill: "#F5EEF8"
    desc: |md
      **Lock-Freedom Guarantee:**
      If any thread (e.g., a concurrent `Find`)
      encounters a node with the `Mark Bit` set, it
      **MUST** attempt to complete Phase 2 (Unlink)
      before continuing its own operation.
    |
  }

  linearization: "Linearization Point" {
    style.fill: "#E8F8F5"
    desc: |md
      **The Atomic Moment of Deletion:**
      The delete is technically "complete"
      at the moment the `Mark Bit` is set in
      Phase 1. Subsequent unlinking is merely
      cleanup.
    |
  }

  hazard: "Hazard Pointer (Safe Reclamation)" {
    style.fill: "#FEF9E7"
    desc: |md
      **Step-by-Step Protection:**
      1. Protect `prev` via HP[0].
      2. Protect `curr` via HP[1].
      3. Validate `prev->next == curr`.
      4. If bit 0 set, help Phase 2.
    |
  }
}

# --------------------------------------------------------------------------------
# GLOBAL CONNECTIONS
# --------------------------------------------------------------------------------
phase1 -> phase2: "Mark Success" {
  style: {
    stroke: "#0366D6"
    stroke-width: 3
    animated: true
  }
}

mem_spec -> pointer_bitfield: "Internal Encoding"
mechanisms.helping -> phase2: "Executes"
mechanisms.linearization -> phase1.p1_transition: "Defines"
mechanisms.hazard -> mem_spec: "Protects Access"

# Positioning
mem_spec.near: bottom-right
mechanisms.near: bottom-left
pointer_bitfield.near: bottom-center
title.near: top-center