vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Logical Delete Marking (Memory Layout)
  **Intel Manual Reference Quality**
  Atomic State Transition: Pointer Stealing LSB Protocol
|
title.near: top-center

direction: right

classes: {
  node_base: {
    shape: rectangle
    width: 480
  }
  # Flattened classes to resolve inheritance error
  active_node_class: {
    shape: rectangle
    width: 480
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
    }
  }
  deleted_node_class: {
    shape: rectangle
    width: 480
    style: {
      fill: "#FFE4E1"
      stroke: "#DC143C"
      stroke-width: 3
      stroke-dash: 4
    }
  }
  field_label: {
    shape: rectangle
    width: 100
    height: 40
    style: {
      # Purple for Headers
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      font: mono
      font-size: 12
      bold: true
    }
  }
  field_value: {
    shape: rectangle
    width: 280
    height: 40
    style: {
      # Blue for Data
      fill: "#E3F2FD"
      stroke: "#1976D2"
      font: mono
      font-size: 14
    }
  }
  pointer_value: {
    shape: rectangle
    width: 280
    height: 40
    style: {
      # Orange for Pointers
      fill: "#FFF3E0"
      stroke: "#F57C00"
      font: mono
      font-size: 14
    }
  }
  offset: {
    shape: text
    style: {
      font-size: 11
      font-color: "#555"
      font: mono
    }
  }
  macro_code: {
    shape: code
    style: {
      fill: "#F5F5DC"
      stroke: "#8B4513"
      font: mono
      font-size: 12
    }
  }
  pointer_box: {
    shape: rectangle
    style: {
      fill: "#FFFDE7"
      stroke: "#FBC02D"
      font: mono
    }
  }
}

# =============================================================================
# ACTIVE NODE
# =============================================================================
active_node: "Active Node (State: ALIVE)" {
  class: active_node_class
  tooltip: "sizeof=32 bytes (Half cache-line)"
  
  layout: {
    grid-columns: 3
    grid-gap: 0
    
    o0: "+0x00" {class: offset}
    l_so: "so_key" {class: field_label}
    v_so: "0x8000000000000001" {class: field_value}
    
    o8: "+0x08" {class: offset}
    l_key: "key_ptr" {class: field_label}
    v_key: "0x00007F1234567000" {class: pointer_value}
    
    o16: "+0x10" {class: offset}
    l_val: "val_ptr" {class: field_label}
    v_val: "0x00007F1234568000" {class: pointer_value}
    
    o24: "+0x18" {class: offset}
    l_next: "next" {
      class: field_label
      style.fill: "#81C784" # Green for un-marked pointer field
    }
    v_next: "0x00007F1234569000" {
      class: pointer_value
      style.stroke: "#2E7D32"
      style.stroke-width: 3
    }
  }
  
  # Removed .near from nested child to fix compile error
  active_annotation: |md
    ### Memory Invariant
    - Aligned to 8-byte boundary.
    - `next` LSB = `0`.
    - Safe to dereference for traversal.
  |
}

# =============================================================================
# LOGICALLY DELETED NODE
# =============================================================================
deleted_node: "Marked Node (State: DELETED)" {
  class: deleted_node_class
  
  layout: {
    grid-columns: 3
    grid-gap: 0
    
    do0: "+0x00" {class: offset}
    dl_so: "so_key" {class: field_label}
    dv_so: "0x8000000000000001" {class: field_value}
    
    do8: "+0x08" {class: offset}
    dl_key: "key_ptr" {class: field_label}
    dv_key: "0x00007F1234567000" {class: pointer_value}
    
    do16: "+0x10" {class: offset}
    dl_val: "val_ptr" {class: field_label}
    dv_val: "0x00007F1234568000" {class: pointer_value}
    
    do24: "+0x18" {class: offset}
    dl_next: "next" {
      class: field_label
      style.fill: "#E57373" # Red for marked pointer field
    }
    dv_next: "0x00007F1234569001" {
      class: pointer_value
      style.stroke: "#B71C1C"
      style.stroke-width: 4
      style.bold: true
    }
  }
  
  # Removed .near from nested child to fix compile error
  deleted_annotation: |md
    ### Marked Invariant
    - `next` LSB = `1`.
    - CAS failure point for other concurrent modifications.
    - Dereference requires `HM_UNMARK_PTR`.
  |
}

# =============================================================================
# MARKING MACROS
# =============================================================================
macros_section: "Atomic Bit-Level Operations (hm_util.h)" {
  macro_container: {
    style.fill: "#FFFAF0"
    style.stroke: "#8B4513"
    style.stroke-width: 2
    
    # |' ... '| handles bitwise OR pipe correctly
    macro_mark_bit: |'c
      // Bit 0: Reserved for logical delete flag
      #define HM_MARK_BIT      ((uintptr_t)1)
      
      // Atomic State Query
      #define HM_IS_MARKED(p)  (((uintptr_t)(p)) & HM_MARK_BIT)
      
      // Set State (Logical Delete)
      #define HM_MARK_PTR(p)   ((void*)(((uintptr_t)(p)) | HM_MARK_BIT))
      
      // Clean Pointer (Dereference Preparation)
      #define HM_UNMARK_PTR(p) ((void*)(((uintptr_t)(p)) & ~HM_MARK_BIT))
    '|
    macro_mark_bit.class: macro_code
    macro_mark_bit.width: 520
  }
}

# =============================================================================
# BIT MANIPULATION DETAIL
# =============================================================================
bit_detail: "Pointer Stealing Visualization" {
  original: {
    label: "Physical Address (Aligned: 0x...000)"
    class: pointer_box
    width: 450
    
    grid: {
      grid-columns: 4
      b_high: "[63...3] Virtual Page Offset" {style.fill: "#EEEEEE"}
      b2: "0" {style.fill: "#EEEEEE"}
      b1: "0" {style.fill: "#EEEEEE"}
      b0: "0" {style.fill: "#A5D6A7"; style.bold: true}
    }
  }
  
  marked: {
    label: "Logical Address (Marked: 0x...001)"
    class: pointer_box
    width: 450
    style.fill: "#FFCDD2"
    
    grid: {
      grid-columns: 4
      mb_high: "[63...3] Virtual Page Offset" {style.fill: "#EEEEEE"}
      mb2: "0" {style.fill: "#EEEEEE"}
      mb1: "0" {style.fill: "#EEEEEE"}
      mb0: "1" {style.fill: "#EF5350"; style.bold: true}
    }
  }

  # Removed .near from nested child to fix compile error
  note: |md
    Since `malloc` aligns to at least 8 bytes, the lower 3 bits are always zero.
    We steal **Bit 0** for the lock-free logical delete signal.
  |
}

# =============================================================================
# PROTOCOL FLOW
# =============================================================================
delete_protocol: "Hazard-Pointer Implementation Protocol" {
  p1: "Phase 1: Logical Mark" {
    style.fill: "#FFF0F5"
    step1: "1. Protect target with HP\n2. Capture next ptr\n3. CAS mark bit 0"
    step1.shape: rectangle
    
    code1: |'c
      // Phase 1 Linearization Point
      uintptr_t old = (uintptr_t)node->next;
      if (!HM_IS_MARKED(old)) {
          void* marked = HM_MARK_PTR(old);
          if (atomic_cas(&node->next, (void*)old, marked)) {
              return SUCCESS_LOGICAL;
          }
      }
    '|
    code1.class: macro_code
  }
  
  p2: "Phase 2: Physical Unlink" {
    style.fill: "#F0FFF0"
    step2: "1. Update prev->next to skip target\n2. Retire target to HP-Queue"
    step2.shape: rectangle
    
    code2: |'c
      // Phase 2 Cleanup
      void* clean = HM_UNMARK_PTR(target->next);
      if (atomic_cas(&prev->next, target, clean)) {
          hp_retire(target);
      }
    '|
    code2.class: macro_code
  }
}

# =============================================================================
# CONNECTIONS
# =============================================================================
active_node -> deleted_node: "atomic_cas(LSB | 1)" {
  style: {
    stroke: "#DC143C"
    stroke-width: 5
    animated: true
  }
}

macros_section -> bit_detail: "Impl Detail" {
  style.stroke-dash: 5
}

delete_protocol.p1 -> delete_protocol.p2: "Step 2: Unlink"

# =============================================================================
# LEGEND
# =============================================================================
legend: {
  near: bottom-right
  legend_title: "Memory Layout Key"
  legend_title.style.bold: true
  
  items: {
    grid-columns: 2
    c1: "" {width: 40; height: 20; style.fill: "#E1BEE7"}
    t1: "Header / Field Name (Purple)" {shape: text; style.font-size: 11}
    c2: "" {width: 40; height: 20; style.fill: "#E3F2FD"}
    t2: "Data Content (Blue)" {shape: text; style.font-size: 11}
    c3: "" {width: 40; height: 20; style.fill: "#FFF3E0"}
    t3: "Pointer Address (Orange)" {shape: text; style.font-size: 11}
    c4: "" {width: 40; height: 20; style.fill: "#EF5350"}
    t4: "State: Logically Deleted" {shape: text; style.font-size: 11}
  }
}