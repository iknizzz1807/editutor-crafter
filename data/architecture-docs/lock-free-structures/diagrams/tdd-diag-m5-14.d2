d2
direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Concurrent Stress Test
| {near: top-center}
# Worker threads
Worker_1: {
  shape: person
  label: "Worker 1"
}
Worker_2: {
  shape: person
  label: "Worker 2"
}
Worker_3: {
  shape: person
  label: "..."
}
Worker_16: {
  shape: person
  label: "Worker 16"
  style.opacity: 0.5
}
# LFHashMap
HashMap: {
  shape: cylinder
  style.fill: "#E8F1FF"
  label: "Lock-Free\nHashMap"
  head: Head Node {
    shape: rectangle
    style.fill: "#B5AFF6"
  }
  buckets: Bucket Array {
    style.fill: "#DEE1EB"
    bucket_0: "Bucket 0"
    bucket_n: "Bucket N"
  }
  sorted_list: Sorted List {
    style.fill: "#E4DBFE"
    node_1: "Node"
    node_n: "Node"
  }
}
# Operations
Worker_1 -> HashMap: "Insert\n40%"
Worker_1 -> HashMap: "Lookup\n35%" {
  style.stroke: "#88DCF7"
}
Worker_2 -> HashMap: "Delete\n25%" {
  style.stroke: "#F69E03"
}
# Counters (tracking results)
Counters: {
  shape: rectangle
  style.fill: "#ACE1AF"
  insert_success: "insert_success\n0"
  insert_duplicate: "insert_duplicate\n0"
  lookup_found: "lookup_found\n0"
  lookup_miss: "lookup_miss\n0"
  delete_success: "delete_success\n0"
  delete_miss: "delete_miss\n0"
}
Worker_1 -> Counters: "increment" {
  style.stroke: "#167c3c"
  style.animated: true
}
Worker_2 -> Counters: "increment" {
  style.stroke: "#167c3c"
}
# Verification
Verification: {
  shape: diamond
  label: "Final Check"
  check: "inserts - deletes == final_size"
}
Counters -> Verification: "report" {
  style.stroke: "#9E2146"
}
# Annotations
annotation: |md
  **Test Configuration:**
  - 16 worker threads
  - 50,000 ops per thread
  - Random 40% insert / 35% lookup / 25% delete
  - Key range: 0-10,000
| {
  near: bottom-center
  style.fill: "#F6F9FC"
}