layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 30
  }
}

# --- Style Definitions ---
classes: {
  axis_label: {
    style: {
      font-size: 16
      bold: true
      fill: "#263238"
      font-color: white
      text-transform: uppercase
    }
  }
  lf_bar: {
    style: {
      fill: "#4CAF50"
      stroke: "#1B5E20"
      font-color: white
      stroke-width: 2
      border-radius: 4
      shadow: true
    }
  }
  mutex_bar: {
    style: {
      fill: "#F44336"
      stroke: "#B71C1C"
      font-color: white
      stroke-width: 2
      border-radius: 4
      shadow: true
    }
  }
  mem_header: {
    style: {
      fill: "#673AB7"
      font-color: white
      bold: true
      font: mono
    }
  }
  data_field: {
    style: {
      fill: "#2196F3"
      font-color: white
      font: mono
    }
  }
  pad_field: {
    style: {
      fill: "#9E9E9E"
      font-color: "#424242"
      stroke-dash: 3
    }
  }
}

# --- Header Section ---
header: {
  shape: text
  label: |md
    # Performance Analysis: Lock-free (CAS) vs Mutex-Based Throughput
    **Benchmark Environment:** 32-core x86_64 (Intel Xeon Scalable)
    **Workload Characteristics:** High Contention | Mixed Access (80% Read / 20% Write)
  |
  near: top-center
}

# --- Throughput Comparison Chart ---
throughput_analysis: {
  label: "Comparative System Throughput (Million Ops/sec)"
  
  chart_grid: {
    grid-rows: 5
    grid-columns: 3
    grid-gap: 20
    
    # Headers
    h1: "Concurrent Threads" { class: axis_label }
    h2: "Lock-Free (CAS)" { class: axis_label }
    h3: "Mutex (Pthread)" { class: axis_label }

    # Row 1: 1 Thread
    r1_t: "1 Thread" { style.bold: true }
    r1_lf: "1.25M" { 
      class: lf_bar
      width: 100 
    }
    r1_mx: "1.18M" { 
      class: mutex_bar
      width: 95
    }

    # Row 2: 4 Threads
    r4_t: "4 Threads" { style.bold: true }
    r4_lf: "4.82M" { 
      class: lf_bar
      width: 250
    }
    r4_mx: "3.21M" { 
      class: mutex_bar
      width: 160
    }

    # Row 3: 16 Threads
    r16_t: "16 Threads" { style.bold: true }
    r16_lf: "14.22M" { 
      class: lf_bar
      width: 450
    }
    r16_mx: "2.10M" { 
      class: mutex_bar
      width: 80
      tooltip: "Performance collapse due to lock contention overhead"
    }

    # Row 4: 32 Threads
    r32_t: "32 Threads" { style.bold: true }
    r32_lf: "22.50M" { 
      class: lf_bar
      width: 600
    }
    r32_mx: "1.42M" { 
      class: mutex_bar
      width: 50
      tooltip: "L1 Cache thrashing and context switching dominate CPU time"
    }
  }
}

# --- Memory Architecture Model ---
cache_contention_model: {
  label: "Memory Layout: L1 Cache Line Contention (64-Byte Line)"
  
  grid_container: {
    grid-columns: 2
    grid-gap: 0

    offsets: {
      grid-rows: 8
      grid-gap: 0
      o0: "0x00" { style.font: mono; height: 40; width: 60 }
      o1: "0x08" { style.font: mono; height: 40; width: 60 }
      o2: "0x10" { style.font: mono; height: 40; width: 60 }
      o3: "0x18" { style.font: mono; height: 40; width: 60 }
      o4: "0x20" { style.font: mono; height: 40; width: 60 }
      o5: "0x28" { style.font: mono; height: 40; width: 60 }
      o6: "0x30" { style.font: mono; height: 40; width: 60 }
      o7: "0x38" { style.font: mono; height: 40; width: 60 }
    }

    layout: {
      grid-rows: 8
      grid-gap: 0
      
      word0: "pthread_mutex_t (State)" { 
        class: mem_header
        tooltip: "Atomic word causing MESI Invalidation storm"
        height: 40
        width: 300
      }
      word1: "Protected Data (Atomic/Volatile)" { class: data_field; height: 40 }
      word2: "Protected Data (Atomic/Volatile)" { class: data_field; height: 40 }
      word3: "Padding (False Sharing Zone)" { class: pad_field; height: 40 }
      word4: "Padding (False Sharing Zone)" { class: pad_field; height: 40 }
      word5: "Padding (False Sharing Zone)" { class: pad_field; height: 40 }
      word6: "Padding (False Sharing Zone)" { class: pad_field; height: 40 }
      word7: "Padding (False Sharing Zone)" { class: pad_field; height: 40 }
    }
  }

  technical_note: {
    shape: text
    label: |md
      ### Contention Mechanism
      * **MESI Protocol:** Lock acquisition on `0x00` forces `Invalidate` signals to all other 31 cores.
      * **False Sharing:** Even if threads access different parts of `Data`, the whole line is locked/flushed.
      * **Futex Wait:** Failed acquisitions trigger kernel context switches (~2-5µs penalty).
    |
  }
}

# --- Metadata and Annotations ---
cache_contention_model.boundary_top: "Cache Line Start" {
  shape: text
  style.font-size: 12
}

cache_contention_model.boundary_bottom: "Cache Line End (64B)" {
  shape: text
  style.font-size: 12
}

# --- Legend Section ---
legend_container: {
  label: "Legend"
  near: bottom-left
  
  l1: "Lock-Free (Wait-Free CAS Loop)" {
    class: lf_bar
    width: 250
  }
  l2: "Mutex-Based (Pthread_mutex_lock)" {
    class: mutex_bar
    width: 250
  }
}

# --- Global Relationships ---
throughput_analysis.chart_grid.r32_mx -> cache_contention_model.grid_container.layout.word0: "Contention Root Cause" {
  style: {
    stroke: "#F44336"
    stroke-width: 3
    stroke-dash: 5
    animated: true
  }
}

# --- Tooltip Refinement ---
cache_contention_model.grid_container.layout.word0.tooltip: "sizeof(mutex_t) = 40B on x86_64, usually padded to cache line"