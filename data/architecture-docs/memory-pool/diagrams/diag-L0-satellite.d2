direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT LEVEL ANNOTATIONS ---
title: |'md
  # Memory Pool Atlas
  ### System Map — Three Interconnected Milestones
'| {
  near: top-center
}

legend: {
  near: bottom-right
  label: "DIAGRAM LEGEND"
  core_flow: {
    label: "Core Components"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  symbology: |'md
    **Relationship Types**
    - `──▶` Build dependency
    - `══▶` Extends / Wraps
    - `- - ▶` Debug logic
  '|
}

# --- MILESTONE 1 ROW ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  m1_region: {
    direction: down
    label: "MILESTONE 1: Fixed-Size Aligned Pool"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 3
    style.border-radius: 8

    m1_core: {
      direction: right
      style.stroke: transparent
      style.fill: transparent

      m1_struct: {
        shape: sql_table
        label: "struct MemoryPool (m1_pool.h)"
        f0: "0x00 | void*       | base"
        f1: "0x08 | size_t      | block_size"
        f2: "0x10 | size_t      | capacity"
        f3: "0x18 | size_t      | allocated"
        f4: "0x20 | void*       | free_list_head"
        f5: "0x28 | uint64_t*   | allocated_map"
        sz: "Total: 48 bytes (aligned)"
      }

      m1_ops: {
        label: "O(1) Operations"
        style.fill: "#C8E6C9"
        style.stroke: "#388E3C"
        alloc: "pool_alloc(): LIFO Pop"
        free: "pool_free(): LIFO Push"
      }
    }

    m1_alignment: {
      label: "Alignment Constraints"
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
      align_note: |'md
        - Block size ≥ `sizeof(void*)`
        - Multiple of `alignof(max_align_t)`
        - Base address must be cache-aligned
      '|
    }

    m1_intrusive: {
      label: "Intrusive Free List"
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      intrusive_note: |'md
        Free blocks store `next` pointer
        inside their own memory segment:
        `[ next_ptr | unused_padding... ]`
      '|
    }
  }
}

# --- MILESTONE 2 ROW ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  m2_region: {
    direction: down
    label: "MILESTONE 2: Pool Growth & Lifecycle"
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    style.stroke-width: 3
    style.border-radius: 8

    m2_storage: {
      direction: right
      style.stroke: transparent
      style.fill: transparent

      m2_chunk: {
        shape: sql_table
        label: "struct Chunk (m2_internal.h)"
        f0: "0x00 | void*   | memory_block"
        f1: "0x08 | size_t  | num_blocks"
        f2: "0x10 | Chunk*  | next_chunk"
        sz: "Total: 24 bytes"
      }

      m2_extended_pool: {
        shape: sql_table
        label: "MemoryPool (M2 Growth Engine)"
        f0: "0x00 | Chunk*     | head_chunk"
        f1: "0x08 | size_t     | blocks_per_chunk"
        f2: "0x10 | size_t     | total_capacity"
        f3: "0x18 | size_t     | max_chunks_allowed"
        f4: "0x20 | size_t     | current_usage_bytes"
        f5: "0x28 | size_t     | active_chunk_count"
        sz: "+ Inherited M1 list management"
      }
    }

    m2_growth: {
      label: "Dynamic Growth Algorithm"
      style.fill: "#DCEDC8"
      style.stroke: "#689F38"
      grow_logic: |'md
        When `free_list_head == NULL`:
        1. `malloc` new `Chunk` metadata
        2. `aligned_alloc` heap storage
        3. Link `Chunk` into pool chain
        4. Thread new blocks into `free_list`
      '|
    }

    m2_unified: {
      label: "Unified Free List"
      style.fill: "#B2DFDB"
      style.stroke: "#00796B"
      unified_note: |'md
        Blocks from non-contiguous chunks
        all live on the same global list:
        `C1[B0] -> C2[B5] -> C1[B1] -> NULL`
      '|
    }
  }
}

# --- MILESTONE 3 ROW ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  m3_region: {
    direction: down
    label: "MILESTONE 3: Thread Safety & Debugging"
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
    style.stroke-width: 3
    style.border-radius: 8

    m3_sync: {
      direction: right
      style.stroke: transparent
      style.fill: transparent

      mutex_struct: {
        shape: sql_table
        label: "MemoryPool (M3 Safe Structure)"
        f0: "0x00 | pthread_mutex_t | lock"
        f1: "0x28 | bool            | debug_mode"
        f2: "0x29 | uint8_t         | padding[7]"
        f3: "0x30 | PoolStats*      | telemetry"
        sz: "Total: 56 bytes + M1/M2 fields"
      }

      protected_state: {
        label: "Protected Critical Sections"
        style.fill: "#FFCCBC"
        style.stroke: "#E64A19"
        prot_list: |'md
          - Free list head mutation
          - Chunk chain expansion
          - Allocation counters
        '|
      }
    }

    m3_debug: {
      direction: right
      style.stroke: transparent
      style.fill: transparent

      poison: {
        label: "Memory Poisoning"
        style.fill: "#F8BBD9"
        style.stroke: "#AD1457"
        poison_note: |'md
          `PATTERN = 0xDE`
          - On `free()`: `memset(ptr, 0xDE)`
          - On `alloc()`: verify `0xDE` intact
          - Catches Use-After-Free writes
        '|
      }

      canary: {
        label: "Safety Canaries"
        style.fill: "#E1BEE7"
        style.stroke: "#8E24AA"
        canary_note: |'md
          `MAGIC = 0xCAFEBABE`
          - Layout: `[CANARY][DATA][CANARY]`
          - Validated during `pool_free()`
          - Catches Buffer Overflows
        '|
      }
    }

    m3_compile: {
      label: "Compile-Time Feature Toggles"
      style.fill: "#D1C4E9"
      style.stroke: "#512DA8"
      compile_note: |'md
        #ifdef POOL_DEBUG
          - Heavyweight validation enabled
          - Canary/Poison logic active
        #else
          - Lock-only overhead
          - Debug logic optimized out
        #endif
      '|
    }
  }
}

# --- CROSS-MILESTONE RELATIONSHIPS ---
m1_region.m1_core -> m2_region.m2_growth: "Pool Exhaustion | triggers" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}

m1_region.m1_intrusive -> m2_region.m2_unified: "Logic Extension" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 4
}

m2_region -> m3_region.m3_sync: "Concurrency Wrapper" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}

m3_region.m3_sync -> m3_region.m3_debug: "Optional | guards" {
  style.stroke: "#C2185B"
  style.stroke-dash: 4
}

flow_summary: |'md
  **Implementation Roadmap**
  1. **M1 (Fixed)**: O(1) alloc, intrustive pointers, memory alignment.
  2. **M2 (Growth)**: Dynamic chunking, non-contiguous heap expansion.
  3. **M3 (Hardened)**: Thread-safe locking, buffer canaries, poisoning.
'| {
  near: bottom-center
}