direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Pool Allocator — Complete Architecture (Milestone 3)
  Thread-safe, dynamically growing pool with debugging infrastructure
| {near: top-center}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pool_header: {
    direction: down
    label: "pool_t (memory_pool.h)"
    pool_struct: {
      shape: sql_table
      label: "struct MemoryPool"
      f0: "0x00 | Chunk*         | chunks"
      f1: "0x08 | size_t         | block_size"
      f2: "0x10 | size_t         | blocks_per_chunk"
      f3: "0x18 | size_t         | total_capacity"
      f4: "0x20 | size_t         | allocated"
      f5: "0x28 | void*          | free_list_head"
      f6: "0x30 | uint64_t*      | allocated_map"
      f7: "0x38 | size_t         | map_size"
      f8: "0x40 | size_t         | max_chunks"
      f9: "0x48 | size_t         | max_bytes"
      f10: "0x50 | size_t        | chunk_count"
      f11: "0x58 | pthread_mutex_t | mutex"
      sz: "Total: 96 bytes (x86-64)"
    }
    debug_state: {
      shape: sql_table
      label: "Debug State (#ifdef POOL_DEBUG)"
      d0: "+0x60 | bool | use_canaries"
      d1: "+0x64 | bool | use_poison"
      dsz: "8 bytes (conditional)"
    }
    pool_struct.style.fill: "#E8F4FD"
    debug_state.style.fill: "#FFF3E0"
  }
  chunk_registry: {
    direction: down
    label: "Chunk Registry (Linked List)"
    chunk0: {
      shape: sql_table
      label: "Chunk 0 (Initial)"
      c0: "0x00 | void*   | memory → 0x7f0000"
      c1: "0x08 | size_t  | num_blocks = 100"
      c2: "0x10 | Chunk*  | next → Chunk 1"
      csz: "24 bytes"
    }
    chunk1: {
      shape: sql_table
      label: "Chunk 1 (Growth)"
      c0: "0x00 | void*   | memory → 0x7f4000"
      c1: "0x08 | size_t  | num_blocks = 100"
      c2: "0x10 | Chunk*  | next → Chunk 2"
      csz: "24 bytes"
    }
    chunk2: {
      shape: sql_table
      label: "Chunk N (Latest)"
      c0: "0x00 | void*   | memory → 0x7f8000"
      c1: "0x08 | size_t  | num_blocks = 100"
      c2: "0x10 | Chunk*  | next → NULL"
      csz: "24 bytes"
    }
    chunk0 -> chunk1: "next"
    chunk1 -> chunk2: "next"
    chunk0.style.fill: "#E8F5E9"
    chunk1.style.fill: "#E8F5E9"
    chunk2.style.fill: "#E8F5E9"
  }
}
row_memory: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bitmap_section: {
    direction: down
    label: "Allocation Bitmap"
    bitmap_struct: {
      shape: sql_table
      label: "allocated_map (uint64_t[])"
      b0: "[0]  | 0b...10110010 | blocks 0-63"
      b1: "[1]  | 0b...00101000 | blocks 64-127"
      b2: "[2]  | 0b...00000000 | blocks 128-191"
      b3: "..."
      bnote: "1 bit per block: 1=allocated, 0=free"
      bsiz: "(capacity + 63) / 64 * 8 bytes"
    }
    bitmap_struct.style.fill: "#F3E5F5"
  }
  mutex_section: {
    direction: down
    label: "Thread Synchronization"
    mutex_struct: {
      shape: sql_table
      label: "pthread_mutex_t mutex"
      m0: "Internal futex word"
      m1: "Spin count"
      m2: "Owner tid (if locked)"
      mnote: "Protects: free_list_head, allocated, allocated_map"
      msz: "40-48 bytes (platform dependent)"
    }
    mutex_struct.style.fill: "#FFEBEE"
  }
  stats_section: {
    direction: down
    label: "Statistics API"
    stats_struct: {
      shape: sql_table
      label: "PoolStats (query result)"
      s0: "size_t | total_blocks"
      s1: "size_t | allocated"
      s2: "size_t | free"
      s3: "size_t | chunk_count"
      s4: "size_t | block_size"
      s5: "size_t | total_bytes"
      s6: "size_t | overhead_bytes"
      ssz: "56 bytes"
    }
    stats_struct.style.fill: "#E0F2F1"
  }
}
row_chunks: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  chunk0_blocks: {
    direction: down
    label: "Chunk 0 Memory (0x7f0000)"
    width: 320
    block_layout: {
      shape: sql_table
      label: "Block Layout (64-byte blocks)"
      bl0: "0x00-0x3F | Block 0  | [ALLOCATED] user data"
      bl1: "0x40-0x7F | Block 1  | [FREE] next→Block3"
      bl2: "0x80-0xBF | Block 2  | [ALLOCATED] user data"
      bl3: "0xC0-0xFF | Block 3  | [FREE] next→Block5"
      bl4: "0x100-...  | Block 4  | [FREE] next→NULL"
      bl5: "...        | Block 99 | [ALLOCATED]"
      blnote: "Free blocks: intrusive linked list via first 8 bytes"
    }
    block_layout.style.fill: "#FFF8E1"
  }
  chunk1_blocks: {
    direction: down
    label: "Chunk 1 Memory (0x7f4000)"
    width: 320
    block_layout1: {
      shape: sql_table
      label: "Block Layout (64-byte blocks)"
      bl0: "0x00-0x3F | Block 100 | [ALLOCATED]"
      bl1: "0x40-0x7F | Block 101 | [ALLOCATED]"
      bl2: "0x80-...   | Block 102+| [FREE]..."
      blnote: "Cross-chunk free list: Block 99 → Block 100"
    }
    block_layout1.style.fill: "#FFF8E1"
  }
}
row_debug: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  canary_section: {
    direction: down
    label: "Canary Protection (Debug Mode)"
    canary_layout: {
      shape: sql_table
      label: "Block with Canaries (use_canaries=true)"
      ca0: "+0x00     | uint64_t | FRONT_CANARY"
      ca1: "+0x08     | uint8_t  | user_data[block_size-16]"
      ca2: "+size-8   | uint64_t | BACK_CANARY"
      ca3: "CANARY_VALUE = 0xCAFEBABEDEADBEEF"
      canote: "Checked on pool_free() → detects overflow/underflow"
    }
    canary_layout.style.fill: "#FCE4EC"
  }
  poison_section: {
    direction: down
    label: "Memory Poisoning (Debug Mode)"
    poison_layout: {
      shape: sql_table
      label: "Freed Block Pattern (use_poison=true)"
      p0: "Byte 0-N  | 0xDE | POISON_PATTERN"
      p1: "Detection: pool_alloc() verifies pattern"
      p2: "Modified bytes → use-after-free write"
      pnote: "memset(ptr, 0xDE, block_size) on free"
    }
    poison_layout.style.fill: "#ECEFF1"
  }
}
row_freelist: "" {
  direction: down
  label: "Unified Free List (Cross-Chunk)"
  freelist_code: {
    label: "Free List Threading"
    width: 700
    code: |'c
      // Free list spans all chunks non-contiguously
      // Chunk 0: Block1(0x7f0040) → Block3(0x7f00C0) → Block4(0x7f0100)
      //                                              ↓
      // Chunk 1: Block102(0x7f4100) → Block103(0x7f4140) → NULL
      //
      // free_list_head = 0x7f0040  (Block 1 in Chunk 0)
      // Allocation pops from head, free pushes to head (LIFO)
    '|
  }
}
row_api: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  api_ops: {
    direction: down
    label: "Thread-Safe Operations"
    alloc_op: {
      label: "pool_alloc(pool)"
      width: 320
      code: |'c
        pthread_mutex_lock(&pool->mutex);
        if (pool->free_list_head == NULL) {
            if (!grow_pool(pool)) {
                pthread_mutex_unlock(&pool->mutex);
                return NULL;
            }
        }
        void* block = pool->free_list_head;
        pool->free_list_head = *(void**)block;
        pool->allocated++;
        bitmap_set(pool->allocated_map, index);
        pthread_mutex_unlock(&pool->mutex);
        return block;
      '|
    }
    free_op: {
      label: "pool_free(pool, ptr)"
      width: 320
      code: |'c
        pthread_mutex_lock(&pool->mutex);
        index = find_block_index(pool, ptr);
        if (!bitmap_test(pool->allocated_map, index)) {
            pthread_mutex_unlock(&pool->mutex);
            return false; // Double-free!
        }
        bitmap_clear(pool->allocated_map, index);
        #ifdef POOL_DEBUG
          if (pool->use_poison) memset(ptr, 0xDE, ...);
        #endif
        *(void**)ptr = pool->free_list_head;
        pool->free_list_head = ptr;
        pool->allocated--;
        pthread_mutex_unlock(&pool->mutex);
      '|
    }
  }
}
row_legend: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    label: "Color Legend"
    core: "Core Pool State" {style.fill: "#E8F4FD"}
    chunks: "Chunk Registry" {style.fill: "#E8F5E9"}
    bitmap: "Allocation Bitmap" {style.fill: "#F3E5F5"}
    mutex: "Thread Safety" {style.fill: "#FFEBEE"}
    debug: "Debug Features" {style.fill: "#FFF3E0"}
    canary: "Canary Protection" {style.fill: "#FCE4EC"}
    memory: "Memory Regions" {style.fill: "#FFF8E1"}
    stats: "Statistics" {style.fill: "#E0F2F1"}
  }
}
legend.near: bottom-right
pool_header.pool_struct -> chunk_registry.chunk0: "chunks"
pool_header.pool_struct -> bitmap_section.bitmap_struct: "allocated_map"
pool_header.pool_struct -> mutex_section.mutex_struct: "mutex"
chunk_registry.chunk0 -> chunk0_blocks.block_layout: "memory"
chunk_registry.chunk1 -> chunk1_blocks.block_layout1: "memory"