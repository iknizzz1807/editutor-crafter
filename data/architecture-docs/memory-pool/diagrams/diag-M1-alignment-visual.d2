direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Alignment: Why CPUs Care
  **8-byte read at aligned vs misaligned addresses**
| {near: top-center}
row_aligned: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  aligned_section: {
    direction: down
    label: "ALIGNED ACCESS (0x1000)"
    aligned_addr: {
      label: "Address 0x1000"
      shape: rectangle
      width: 180
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.font-color: "#006400"
      style.bold: true
    }
    aligned_cache: {
      direction: down
      label: "Single Cache Line Access"
      line0: {
        shape: rectangle
        label: |md
          **Cache Line 0** (64 bytes)
          `0x1000 - 0x103F`
        |
        width: 280
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
      }
      data_region: {
        direction: right
        width: 280
        byte0: {
          label: "0x1000"
          shape: rectangle
          width: 60
          style.fill: "#4CAF50"
          style.font-color: white
          style.bold: true
        }
        byte1: {
          label: "0x1008"
          shape: rectangle
          width: 60
          style.fill: "#4CAF50"
          style.font-color: white
          style.bold: true
        }
        dots: {
          label: "..."
          shape: text
          width: 40
        }
        byteN: {
          label: "0x103F"
          shape: rectangle
          width: 60
          style.fill: "#E8F5E9"
          style.stroke: "#4CAF50"
        }
      }
      read_region: {
        label: "8-byte read entirely within line"
        shape: rectangle
        width: 280
        style.fill: "#81C784"
        style.stroke: "#2E7D32"
        style.bold: true
      }
    }
    aligned_result: {
      label: "Result: 1 memory cycle"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      style.font-color: "#1B5E20"
      style.bold: true
    }
  }
}
row_misaligned: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  misaligned_section: {
    direction: down
    label: "MISALIGNED ACCESS (0x1003)"
    misaligned_addr: {
      label: "Address 0x1003"
      shape: rectangle
      width: 180
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.font-color: "#B71C1C"
      style.bold: true
    }
    misaligned_cache: {
      direction: down
      label: "Crosses Cache Line Boundary"
      line1: {
        shape: rectangle
        label: |md
          **Cache Line 0** (64 bytes)
          `0x1000 - 0x103F`
        |
        width: 280
        style.fill: "#FFEBEE"
        style.stroke: "#EF5350"
      }
      data_row1: {
        direction: right
        width: 280
        mbyte0: {
          label: "0x1000"
          shape: rectangle
          width: 60
          style.fill: "#FFEBEE"
          style.stroke: "#EF5350"
        }
        mbyte1: {
          label: "0x1003"
          shape: rectangle
          width: 60
          style.fill: "#EF5350"
          style.font-color: white
          style.bold: true
        }
        mdots: {
          label: "..."
          shape: text
          width: 40
        }
        mbyteN: {
          label: "0x103F"
          shape: rectangle
          width: 60
          style.fill: "#EF5350"
          style.font-color: white
          style.bold: true
        }
      }
      split_marker: {
        label: "5 bytes here ─────────── 3 bytes here"
        shape: rectangle
        width: 280
        style.fill: "#FFCDD2"
        style.stroke: "#E53935"
        style.stroke-dash: 4
      }
      line2: {
        shape: rectangle
        label: |md
          **Cache Line 1** (64 bytes)
          `0x1040 - 0x107F`
        |
        width: 280
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
      }
      data_row2: {
        direction: right
        width: 280
        m2byte0: {
          label: "0x1040"
          shape: rectangle
          width: 60
          style.fill: "#FF9800"
          style.font-color: white
          style.bold: true
        }
        m2byte1: {
          label: "0x1048"
          shape: rectangle
          width: 60
          style.fill: "#FFF3E0"
          style.stroke: "#FF9800"
        }
        m2dots: {
          label: "..."
          shape: text
          width: 40
        }
        m2byteN: {
          label: "0x107F"
          shape: rectangle
          width: 60
          style.fill: "#FFF3E0"
          style.stroke: "#FF9800"
        }
      }
    }
    misaligned_result: {
      label: "Result: 2 memory cycles (or fault!)"
      shape: rectangle
      width: 200
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.font-color: "#B71C1C"
      style.bold: true
    }
  }
}
row_misaligned -> row_aligned: "Compare" {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
}
legend_section: {
  direction: right
  label: "Architecture Behavior"
  x86_box: {
    label: "x86-64"
    shape: rectangle
    width: 160
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
  }
  x86_box.desc: |md
    **Performance penalty**
    2 cache accesses
    Hardware handles split
  |
  arm_box: {
    label: "ARM (strict mode)"
    shape: rectangle
    width: 160
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  arm_box.desc: |md
    **Hardware fault**
    SIGBUS or exception
    Requires software fixup
  |
}
code_example: {
  label: "Alignment Rule (alignof)"
  width: 400
  code: |'c
    // CPU alignment requirements:
    // - 4-byte int must be at address % 4 == 0
    // - 8-byte pointer must be at address % 8 == 0
    // - 16-byte SIMD must be at address % 16 == 0
    alignof(max_align_t)  // 8 or 16 on most systems
    // Pool allocator must ensure:
    // 1. Base address is aligned
    // 2. Block size is multiple of alignment
    // Then ALL blocks are automatically aligned
  '|
}
legend_section.near: bottom-center
code_example.near: bottom-center