direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # pool_alloc(): O(1) Pop from Head
  Constant time complexity (3 operations) regardless of pool size.
| {near: top-center}

row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  before_state: {
    direction: down
    label: "INITIAL STATE: Free List Linked"
    
    free_list_head: {
      shape: sql_table
      label: "Pool Controller"
      f0: "0x00 | void* | free_list_head -> 0x1000"
    }
    
    pool_region: {
      label: "Memory Pool Region"
      style.fill: "#FAFAFA"
      
      block0: {
        label: "Block 0 (Head)\nAddr: 0x1000"
        width: 150
        height: 70
        style.fill: "#BBDEFB"
        style.stroke: "#1976D2"
        style.stroke-width: 3
      }
      block1: {
        label: "Block 1\nAddr: 0x1040"
        width: 150
        height: 70
        style.fill: "#E3F2FD"
        style.stroke: "#1976D2"
      }
      block2: {
        label: "Block 2\nAddr: 0x1080"
        width: 150
        height: 70
        style.fill: "#E3F2FD"
        style.stroke: "#1976D2"
      }
    }
    
    note: {
      label: "Nodes store next pointer in the first 8 bytes of the block itself."
      shape: callout
    }
  }
}

row_step1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  step1: {
    label: "STEP 1: Capture Current Head"
    width: 450
    code: |'c
      void* block = pool->free_list_head;
      // Local variable 'block' now holds 0x1000
    '|
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  
  state1_visual: {
    label: "Logic: Pointer Assignment"
    block_ptr: "0x1000"
    block_ptr.style.bold: true
    block_ptr.style.fill: "#C8E6C9"
  }
}

row_step2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  step2: {
    label: "STEP 2: Advance Head Pointer"
    width: 450
    code: |'c
      pool->free_list_head = *(void**)block;
      // 1. Dereference block (0x1000) to get 0x1040
      // 2. Set head to 0x1040
    '|
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  
  state2_visual: {
    label: "Logic: List Advancement"
    head_update: "head -> 0x1040"
    head_update.style.bold: true
    head_update.style.fill: "#BBDEFB"
  }
}

row_step3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  step3: {
    label: "STEP 3: Finalize and Return"
    width: 450
    code: |'c
      pool->allocated_count++;
      return block; // Returns 0x1000 to caller
    '|
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
}

row_final: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  final_state: {
    direction: down
    label: "FINAL STATE: Allocation Complete"
    
    free_list_head_final: {
      shape: sql_table
      label: "Pool Controller"
      f0: "0x00 | void* | free_list_head -> 0x1040"
    }
    
    pool_final: {
      label: "Memory Pool Region"
      
      b0_final: {
        label: "Block 0\nSTATUS: ALLOCATED"
        width: 150
        height: 70
        style.fill: "#FFCDD2"
        style.stroke: "#D32F2F"
      }
      b1_final: {
        label: "Block 1 (New Head)\nAddr: 0x1040"
        width: 150
        height: 70
        style.fill: "#A5D6A7"
        style.stroke: "#2E7D32"
        style.stroke-width: 3
      }
    }
    
    result: {
      label: "RETURN VALUE: 0x1000"
      shape: diamond
      style.fill: "#C8E6C9"
      style.bold: true
    }
  }
}

summary: {
  label: "Complexity Analysis (Implementation Logic)"
  style.fill: "#FFF9C4"
  content: |md
    - **Time Complexity**: O(1). Only involves 1 memory read and 1 memory write.
    - **Space Complexity**: O(1). No additional allocation required for management.
    - **Thread Safety**: Requires atomic CAS on `free_list_head` if multi-threaded.
  |
}

# Connections defining the flow between stages
row_before -> row_step1: "invoke pool_alloc()"
row_step1 -> row_step2
row_step2 -> row_step3
row_step3 -> row_final: "return address"

# Pointers within initial state
before_state.free_list_head -> before_state.pool_region.block0: "0x1000"
before_state.pool_region.block0 -> before_state.pool_region.block1: "next: 0x1040" {style.stroke-dash: 3}
before_state.pool_region.block1 -> before_state.pool_region.block2: "next: 0x1080" {style.stroke-dash: 3}

# Pointers within final state
final_state.free_list_head_final -> final_state.pool_final.b1_final: "0x1040"
final_state.result -> final_state.pool_final.b0_final: "targets" {style.stroke-dash: 5}

legend: {
  shape: package
  label: "Visual Legend"
  free: "Available Block" { style.fill: "#E3F2FD" }
  current_head: "Active List Head" { style.fill: "#BBDEFB"; style.stroke-width: 3 }
  allocated: "Allocated/In-Use" { style.fill: "#FFCDD2" }
}
legend.near: bottom-right