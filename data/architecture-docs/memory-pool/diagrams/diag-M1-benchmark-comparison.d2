direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Pool vs malloc: Latency Distribution
| {near: top-center}
row_comparison: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  malloc_panel: {
    direction: down
    label: "malloc/free"
    width: 420
    malloc_desc: |md
      **General-purpose allocator**
      - Variable latency: 10ns – 10μs (1000x range)
      - Fragmentation causes unpredictable delays
      - May trigger syscalls (mmap, sbrk)
    |
    malloc_hist: {
      label: "Latency Distribution (log scale)"
      width: 400
      height: 280
      malloc_10ns: {
        label: "10ns"
        width: 35
        height: 180
        style.fill: "#E8F5E9"
        style.stroke: "#81C784"
      }
      malloc_50ns: {
        label: "50ns"
        width: 35
        height: 200
        style.fill: "#C8E6C9"
        style.stroke: "#66BB6A"
      }
      malloc_100ns: {
        label: "100ns"
        width: 35
        height: 160
        style.fill: "#A5D6A7"
        style.stroke: "#4CAF50"
      }
      malloc_500ns: {
        label: "500ns"
        width: 35
        height: 120
        style.fill: "#FFCC80"
        style.stroke: "#FFA726"
      }
      malloc_1us: {
        label: "1μs"
        width: 35
        height: 90
        style.fill: "#FFAB91"
        style.stroke: "#FF7043"
      }
      malloc_5us: {
        label: "5μs"
        width: 35
        height: 50
        style.fill: "#EF9A9A"
        style.stroke: "#EF5350"
      }
      malloc_10us: {
        label: "10μs"
        width: 35
        height: 30
        style.fill: "#E53935"
        style.stroke: "#C62828"
      }
    }
    malloc_stats: {
      shape: sql_table
      label: "malloc Statistics"
      min: "10 ns"
      median: "~45 ns"
      p99: "~800 ns"
      max: "10,000 ns (10μs)"
      variance: "HIGH"
    }
  }
  pool_panel: {
    direction: down
    label: "pool_alloc/pool_free"
    width: 420
    pool_desc: |md
      **Fixed-size pool allocator**
      - Tight latency cluster: 5–12ns
      - O(1) pointer operations only
      - Zero syscalls in steady state
    |
    pool_hist: {
      label: "Latency Distribution (linear scale)"
      width: 400
      height: 280
      pool_4ns: {
        label: "4ns"
        width: 45
        height: 40
        style.fill: "#BBDEFB"
        style.stroke: "#64B5F6"
      }
      pool_5ns: {
        label: "5ns"
        width: 45
        height: 200
        style.fill: "#1565C0"
        style.stroke: "#0D47A1"
      }
      pool_6ns: {
        label: "6ns"
        width: 45
        height: 260
        style.fill: "#1976D2"
        style.stroke: "#1565C0"
      }
      pool_7ns: {
        label: "7ns"
        width: 45
        height: 220
        style.fill: "#1E88E5"
        style.stroke: "#1976D2"
      }
      pool_8ns: {
        label: "8ns"
        width: 45
        height: 140
        style.fill: "#42A5F5"
        style.stroke: "#1E88E5"
      }
      pool_10ns: {
        label: "10ns"
        width: 45
        height: 50
        style.fill: "#90CAF9"
        style.stroke: "#64B5F6"
      }
      pool_12ns: {
        label: "12ns"
        width: 45
        height: 20
        style.fill: "#E3F2FD"
        style.stroke: "#BBDEFB"
      }
    }
    pool_stats: {
      shape: sql_table
      label: "Pool Statistics"
      min: "4 ns"
      median: "6 ns"
      p99: "10 ns"
      max: "12 ns"
      variance: "LOW"
    }
  }
}
legend_panel: {
  direction: right
  width: 850
  style.fill: transparent
  style.stroke: transparent
  legend_good: {
    label: "Predictable latency"
    width: 200
    style.fill: "#1565C0"
    style.stroke: "#0D47A1"
    style.font-color: white
  }
  legend_warn: {
    label: "Occasional delays"
    width: 200
    style.fill: "#FFA726"
    style.stroke: "#F57C00"
    style.font-color: white
  }
  legend_bad: {
    label: "Tail latency spikes"
    width: 200
    style.fill: "#E53935"
    style.stroke: "#C62828"
    style.font-color: white
  }
}
insight_box: {
  label: "Key Insight"
  width: 850
  insight_content: |md
    **Predictability > Raw Speed**
    malloc's *average* latency (~45ns) is reasonable, but its *worst-case* (10μs) is **1000x slower**.
    For real-time systems (game engines, audio processing, network stacks), this variance causes:
    - Frame rate stutter
    - Audio dropouts  
    - Packet processing delays
    The pool allocator trades flexibility for **bounded latency** — every allocation costs ~6ns, always.
  |
}
comparison_arrow: {
  label: ""
  width: 850
  height: 60
  style.fill: transparent
  style.stroke: transparent
  arrow_left: {
    label: "malloc: Wide variance"
    width: 380
    style.fill: transparent
    style.stroke: "#EF5350"
    style.stroke-width: 3
    style.stroke-dash: 5
  }
  arrow_right: {
    label: "pool: Tight cluster"
    width: 380
    style.fill: transparent
    style.stroke: "#1565C0"
    style.stroke-width: 3
  }
}