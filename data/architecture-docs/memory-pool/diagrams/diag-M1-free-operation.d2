direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "pool_free(): O(1) Push to Head"
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  before: "BEFORE: Free Called" {
    direction: down
    style.stroke: "#666"
    
    before_note: {
      shape: callout
      label: "ptr = 0x1040 (block to free)"
      style: {
        font-color: "#B71C1C"
        bold: true
        fill: "#FFEBEE"
      }
    }
    
    pool_state: {
      shape: sql_table
      label: "Memory Pool (Pre-Free)"
      h: "free_list_head | 0x1080"
      b1: "0x1000 | ALLOCATED | [User Data]"
      b2: "0x1040 | ALLOCATED | [User Data] <--- ptr"
      b3: "0x1080 | FREE      | next: 0x10C0"
      b4: "0x10C0 | FREE      | next: NULL"
      
      style.fill: "#E8F5E9"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  step1: "STEP 1: Write current head into freed block" {
    direction: down
    style.stroke: "#1565C0"
    style.stroke-width: 3
    
    step1_logic: {
      label: "T1: Update Next Pointer"
      code: |'c
        // Store current head in freed block's header
        *(void**)ptr = pool->free_list_head;
        // Memory at 0x1040 now contains 0x1080
      '|
    }
    
    pool_s1: {
      shape: sql_table
      label: "Memory Pool (Post-Write)"
      h: "free_list_head | 0x1080 (unchanged)"
      b1: "0x1000 | ALLOCATED | [User Data]"
      b2: "0x1040 | NOW FREE  | next: 0x1080 (Updated!)"
      b3: "0x1080 | FREE      | next: 0x10C0"
      b4: "0x10C0 | FREE      | next: NULL"
      
      style.fill: "#E3F2FD"
    }
    
    write_indicator: {
      shape: parallelogram
      label: "Write: 0x1080 -> *0x1040"
      style: {
        stroke: "#1565C0"
        stroke-width: 2
        fill: "#E3F2FD"
      }
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  step2: "STEP 2: Point head at freed block" {
    direction: down
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    
    step2_logic: {
      label: "T2: Update Free List Head"
      code: |'c
        // Update head to point to the new head of list
        pool->free_list_head = ptr;
        // free_list_head = 0x1040
      '|
    }
    
    pool_s2: {
      shape: sql_table
      label: "Memory Pool (Post-Head-Update)"
      h: "free_list_head | 0x1040 (Updated!)"
      b1: "0x1000 | ALLOCATED | [User Data]"
      b2: "0x1040 | FREE (HEAD)| next: 0x1080"
      b3: "0x1080 | FREE      | next: 0x10C0"
      b4: "0x10C0 | FREE      | next: NULL"
      
      style.fill: "#E8F5E9"
    }
    
    head_indicator: {
      shape: parallelogram
      label: "Update: head = 0x1040"
      style: {
        stroke: "#2E7D32"
        stroke-width: 2
        fill: "#E8F5E9"
      }
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  result: "RESULT: New Linked List State" {
    direction: down
    style.stroke: "#2E7D32"
    
    list_viz: {
      label: "Logical Free List (LIFO Stack)"
      
      head: "pool->free_list_head" {
        shape: hexagon
        style.fill: "#81C784"
      }
      
      n1: "Block 0x1040" {
        shape: rectangle
        style.fill: "#C8E6C9"
      }
      
      n2: "Block 0x1080" {
        shape: rectangle
        style.fill: "#C8E6C9"
      }
      
      n3: "Block 0x10C0" {
        shape: rectangle
        style.fill: "#C8E6C9"
      }
      
      nil: "NULL" {
        shape: oval
        style.fill: "#BDBDBD"
      }
      
      head -> n1: "points"
      n1 -> n2: "next"
      n2 -> n3: "next"
      n3 -> nil: "next"
    }
  }
}

legend: {
  near: bottom-center
  direction: right
  style.stroke: "#333"
  
  L1: "ALLOCATED" { style.fill: "#FFCDD2" }
  L2: "FREE" { style.fill: "#C8E6C9" }
  L3: "MODIFIED" { style.fill: "#BBDEFB" }
}

complexity_note: {
  near: bottom-right
  label: |'md
    ### Complexity Analysis
    - **Time**: O(1)
    - **Space**: O(0) (in-place)
    
    *Implementation Note:*
    The first 4-8 bytes of the freed memory block are reused as the 'next' pointer for the intrusive list.
  '|
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
  }
}

row1 -> row2: "void* ptr | free(ptr)"
row2 -> row3: "atomic | update"
row3 -> row4: "done"