direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |md
    # Intrusive Free List: Memory Layout
    ### The `next` pointer and user data share the same physical address
  |
  shape: rectangle
  style.stroke: transparent
  style.fill: transparent
}

# ROW 1: States of a single 64-byte block
memory_states: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  free_side: {
    direction: down
    label: "STATE: FREE"
    free_block: {
      shape: sql_table
      label: "Block Memory (64 bytes)"
      f0: "0x00 | void*   | next_ptr // Linked list pointer"
      f1: "0x08 | uint8_t | unused[56] // Available memory"
      sz: "Total: 64 bytes"
    }
    free_block.style.fill: "#E8F5E9"
    free_block.style.stroke: "#4CAF50"
    
    note: {
      label: |md
        **Pointer Persistence**
        When in the free list, the first 8 bytes
        must remain valid to find the next block.
      |
      shape: rectangle
      style.stroke-dash: 3
    }
  }

  alloc_side: {
    direction: down
    label: "STATE: ALLOCATED"
    alloc_block: {
      shape: sql_table
      label: "Block Memory (64 bytes)"
      f0: "0x00 | uint8_t | user_data[0] // OVERWRITES next_ptr"
      f1: "0x01 | uint8_t | user_data[1]"
      f2: "0x08 | uint8_t | user_data[8]"
      f3: "0x3F | uint8_t | user_data[63]"
      sz: "Total: 64 bytes"
    }
    alloc_block.style.fill: "#E3F2FD"
    alloc_block.style.stroke: "#2196F3"

    note: {
      label: |md
        **Zero Overhead**
        The user gets the full 64 bytes.
        No hidden headers or footers.
      |
      shape: rectangle
      style.stroke-dash: 3
    }
  }
}

# ROW 2: Logic and Implementation details
implementation_details: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  logic_flow: {
    label: "Implementation Logic (pool.c)"
    code: |'c
      typedef struct Node { struct Node* next; } Node;

      void* pool_alloc(Pool* p) {
        Node* n = p->free_list;
        if (!n) return NULL;
        p->free_list = n->next; // Pop head
        return (void*)n;        // Return raw memory
      }

      void pool_free(Pool* p, void* ptr) {
        Node* n = (Node*)ptr;   // Cast to Node
        n->next = p->free_list; // Push to head
        p->free_list = n;
      }
    '|
    width: 450
  }

  key_insight: {
    label: "Key Insight: Type Punning"
    content: |md
      The system uses **Intrusive pointers**.
      The list metadata only exists while
      the object is *not* in use.
      
      - **Cost:** 0 bytes per allocation.
      - **Requirement:** Min block size ≥ `sizeof(void*)`.
    |
    shape: rectangle
    style.fill: "#FFFDE7"
  }
}

# Connections representing state transitions
memory_states.free_side.free_block -> memory_states.alloc_side.alloc_block: "pool_alloc() | pop" {
  style.stroke: "#FF9800"
  style.stroke-width: 3
  style.animated: true
}

memory_states.alloc_side.alloc_block -> memory_states.free_side.free_block: "pool_free() | push" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  style.stroke-dash: 5
}

# Structural link between logic and visual
implementation_details -> memory_states: "Operational Logic" {
  style.stroke: "#9E9E9E"
}