direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # What malloc Actually Does vs Pool Simplicity
  **Why pool allocation is O(1): eliminate the search, eliminate the complexity**
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  before: {
    direction: down
    label: "BEFORE: malloc General-Purpose Allocator"
    malloc_overview: {
      label: "malloc(64) — What Actually Happens"
      width: 450
      style.fill: "#FFF0F0"
      style.stroke: "#CC0000"
      desc: |md
        General-purpose allocator must handle **any size** request.
        This flexibility has a cost: pointer chasing through metadata.
      |
    }
    malloc_heap: {
      direction: down
      label: "Heap State (Fragmented)"
      width: 450
      style.fill: "#FAFAFA"
      heap_row1: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        h_used1: {
          label: "USED\n128 bytes\nuser data"
          width: 100
          style.fill: "#FFCCCC"
          style.stroke: "#990000"
        }
        h_free1: {
          label: "FREE\n64 bytes\nnext: 0x1080"
          width: 80
          style.fill: "#CCFFCC"
          style.stroke: "#009900"
        }
        h_used2: {
          label: "USED\n256 bytes\nuser data"
          width: 120
          style.fill: "#FFCCCC"
          style.stroke: "#990000"
        }
        h_free2: {
          label: "FREE\n32 bytes\n(next too small!)"
          width: 70
          style.fill: "#FFFFCC"
          style.stroke: "#999900"
        }
      }
      heap_row2: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        h_used3: {
          label: "USED\n64 bytes\nuser data"
          width: 80
          style.fill: "#FFCCCC"
          style.stroke: "#990000"
        }
        h_free3: {
          label: "FREE\n192 bytes\nnext: NULL"
          width: 140
          style.fill: "#CCFFCC"
          style.stroke: "#009900"
        }
      }
    }
    malloc_metadata: {
      direction: down
      label: "Per-Block Metadata (Hidden from User)"
      width: 450
      style.fill: "#F5F5FF"
      meta_struct: {
        shape: sql_table
        label: "struct BlockHeader (malloc internal)"
        f0: "0x00 | size_t    | size       // block size + flags"
        f1: "0x08 | size_t    | prev_size  // for coalescing"
        f2: "0x10 | Block*    | next_free  // free list link"
        f3: "0x18 | Block*    | prev_free  // doubly-linked!"
        f4: "0x20 | void*     | user_data  // actual pointer returned"
        sz: "Overhead: 32 bytes per allocation"
      }
    }
    malloc_steps: {
      direction: down
      label: "malloc(64) Execution Path"
      width: 450
      style.fill: "#FFF8F0"
      step1: {
        label: "Step 1: Size Class Lookup"
        width: 400
        code: |'c
          // Find appropriate bin for 64-byte request
          int bin = (64 + 15) / 16;  // bin = 4
          FreeList* list = &arena->bins[bin];
        '|
      }
      step2: {
        label: "Step 2: Search Free List"
        width: 400
        code: |'c
          // Scan for block >= 64 bytes
          Block* b = list->head;
          while (b != NULL) {
            if (b->size >= 64) break;  // found!
            b = b->next_free;          // cache miss!
          }
        '|
      }
      step3: {
        label: "Step 3: Split Decision"
        width: 400
        code: |'c
          // Found 128-byte block, need 64
          if (b->size - 64 >= MIN_BLOCK) {
            split_block(b, 64);  // create new free block
            // Update 3 data structures!
          }
        '|
      }
      step4: {
        label: "Step 4: Unlink from Free List"
        width: 400
        code: |'c
          // Remove from doubly-linked list
          if (b->prev_free) b->prev_free->next_free = b->next_free;
          if (b->next_free) b->next_free->prev_free = b->prev_free;
          // 2 pointer writes, 2 conditionals
        '|
      }
    }
    malloc_complexity: {
      label: "Worst Case: O(n) search through free list\nBest Case: O(1) if cached, but still 4+ pointer ops\nFragmentation: Splits create tiny unusable blocks"
      width: 450
      style.fill: "#FFE0E0"
      style.stroke: "#CC0000"
    }
  }
  after: {
    direction: down
    label: "AFTER: Pool Allocator"
    pool_overview: {
      label: "pool_alloc() — What Actually Happens"
      width: 450
      style.fill: "#F0FFF0"
      style.stroke: "#009900"
      desc: |md
        Pool allocator knows **exact size** at init time.
        No searching, no splitting, no metadata per block.
      |
    }
    pool_state: {
      direction: down
      label: "Pool State (All Blocks Same Size)"
      width: 450
      style.fill: "#FAFAFA"
      pool_row1: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        p_block0: {
          label: "BLOCK 0\n64 bytes\n[ALLOCATED]"
          width: 90
          style.fill: "#CCFFCC"
          style.stroke: "#009900"
        }
        p_block1: {
          label: "BLOCK 1\n64 bytes\n→ next: block2"
          width: 90
          style.fill: "#E0FFE0"
          style.stroke: "#009900"
        }
        p_block2: {
          label: "BLOCK 2\n64 bytes\n→ next: block3"
          width: 90
          style.fill: "#E0FFE0"
          style.stroke: "#009900"
        }
        p_block3: {
          label: "BLOCK 3\n64 bytes\n→ next: NULL"
          width: 90
          style.fill: "#E0FFE0"
          style.stroke: "#009900"
        }
      }
      pool_row2: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        p_block4: {
          label: "BLOCK 4\n64 bytes\n[ALLOCATED]"
          width: 90
          style.fill: "#CCFFCC"
          style.stroke: "#009900"
        }
        p_block5: {
          label: "BLOCK 5\n64 bytes\n[ALLOCATED]"
          width: 90
          style.fill: "#CCFFCC"
          style.stroke: "#009900"
        }
        p_block6: {
          label: "BLOCK 6\n64 bytes\n[ALLOCATED]"
          width: 90
          style.fill: "#CCFFCC"
          style.stroke: "#009900"
        }
        p_block7: {
          label: "BLOCK 7\n64 bytes\n→ next: block1"
          width: 90
          style.fill: "#E0FFE0"
          style.stroke: "#009900"
        }
      }
      free_ptr: {
        label: "free_list_head → BLOCK 7"
        width: 380
        style.fill: "#E8F8E8"
        style.stroke: "#006600"
        style.font: mono
      }
    }
    pool_metadata: {
      direction: down
      label: "Pool Structure (One-Time Setup)"
      width: 450
      style.fill: "#F0FFF0"
      pool_struct: {
        shape: sql_table
        label: "struct MemoryPool (5 fields total)"
        f0: "0x00 | void*     | base           // start of memory"
        f1: "0x08 | size_t    | block_size     // 64 bytes (constant)"
        f2: "0x10 | size_t    | capacity       // 8 blocks (constant)"
        f3: "0x18 | size_t    | allocated      // 4 (just a counter)"
        f4: "0x20 | void*     | free_list_head // pop from here"
        sz: "Per-block overhead: 0 bytes (intrusive list)"
      }
    }
    pool_steps: {
      direction: down
      label: "pool_alloc() Execution Path"
      width: 450
      style.fill: "#F0FFF8"
      p_step1: {
        label: "The Complete Algorithm"
        width: 400
        code: |'c
          void* pool_alloc(MemoryPool* pool) {
              if (pool->free_list_head == NULL)
                  return NULL;           // pool exhausted
              void* block = pool->free_list_head;
              pool->free_list_head = *(void**)block;
              pool->allocated++;
              return block;
          }
        '|
      }
      p_step2: {
        label: "That's It. 4 Operations Total."
        width: 400
        style.fill: "#E0FFE0"
        code: |'c
          // 1. NULL check (predictable branch)
          // 2. Load free_list_head (1 cache line)
          // 3. Load next pointer from block (1 cache line)
          // 4. Store new head + increment counter
        '|
      }
    }
    pool_complexity: {
      label: "Always O(1): 2 loads, 2 stores, 1 branch\nNo searching, no splitting, no coalescing\nNo fragmentation: all blocks identical size"
      width: 450
      style.fill: "#E0FFE0"
      style.stroke: "#009900"
    }
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  comparison: {
    direction: right
    label: "Complexity Eliminated by Pool"
    width: 950
    style.fill: "#F8F8F8"
    eliminated: {
      label: "❌ ELIMINATED"
      width: 300
      style.fill: "#FFE0E0"
      e1: "Size class lookup"
      e2: "Free list search (O(n))"
      e3: "Block splitting logic"
      e4: "Doubly-linked list maintenance"
      e5: "Coalescing on free"
      e6: "Per-block size headers"
      e7: "Fragmentation tracking"
    }
    retained: {
      label: "✓ RETAINED"
      width: 300
      style.fill: "#E0FFE0"
      r1: "Single NULL check"
      r2: "Free list head load"
      r3: "Next pointer load"
      r4: "Head pointer store"
    }
    result: {
      label: "RESULT"
      width: 300
      style.fill: "#E0E0FF"
      res1: "malloc: 40-50 ns/op"
      res2: "pool:   8-12 ns/op"
      res3: "5-6x faster"
      res4: "Predictable latency"
    }
  }
}
before -> after: "Trade flexibility\nfor speed" {
  style.stroke: "#666666"
  style.stroke-dash: 4
  style.font-color: "#666666"
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  used_key: {
    label: "[ALLOCATED]"
    style.fill: "#CCFFCC"
    style.stroke: "#009900"
  }
  free_key: {
    label: "[FREE]"
    style.fill: "#E0FFE0"
    style.stroke: "#009900"
  }
  tiny_key: {
    label: "[TOO SMALL]"
    style.fill: "#FFFFCC"
    style.stroke: "#999900"
  }
}