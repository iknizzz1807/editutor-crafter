direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Pool Structure: Contiguous Region to Blocks
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pool_header: {
    shape: sql_table
    label: "pool_t (pool.h)"
    f0: "0x00 | void*      | base"
    f1: "0x08 | size_t     | block_size"
    f2: "0x10 | size_t     | capacity"
    f3: "0x18 | size_t     | allocated"
    f4: "0x20 | void*      | free_list_head"
    f5: "0x28 | uint64_t*  | allocated_map"
    f6: "0x30 | size_t     | map_size"
    sz: "Total: 56 bytes"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_region: {
    label: "Contiguous Memory Region (pool->base)"
    style.fill: "#E8F4E8"
    style.stroke: "#2D5A2D"
    direction: right
    block0: {
      label: "Block 0"
      shape: rectangle
      width: 120
      style.fill: "#B8D4B8"
      offset: "offset: 0x0000"
      content: "[next_ptr | ...]"
      content.style.font-size: 11
    }
    block1: {
      label: "Block 1"
      shape: rectangle
      width: 120
      style.fill: "#B8D4B8"
      offset: "offset: 0x0040"
      content: "[next_ptr | ...]"
      content.style.font-size: 11
    }
    block2: {
      label: "Block 2"
      shape: rectangle
      width: 120
      style.fill: "#B8D4B8"
      offset: "offset: 0x0080"
      content: "[next_ptr | ...]"
      content.style.font-size: 11
    }
    dots: {
      label: "..."
      shape: text
      style.font-size: 20
    }
    blockN: {
      label: "Block N-1"
      shape: rectangle
      width: 120
      style.fill: "#B8D4B8"
      offset: "offset: (N-1)*64"
      content: "[NULL | ...]"
      content.style.font-size: 11
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  block_detail: {
    label: "Single Block Detail (64 bytes)"
    style.fill: "#FFF8E8"
    style.stroke: "#8B7355"
    detail: {
      shape: sql_table
      label: "Block Memory Layout"
      b0: "0x00 | void*  | next (free list ptr)"
      b1: "0x08 | --    | user_data[0..55]"
      note: "When FREE: next points to next free block"
      note2: "When ALLOC: entire block is user data"
    }
  }
  free_list: {
    label: "Free List Structure"
    style.fill: "#E8E8F4"
    style.stroke: "#4A4A8B"
    fl_header: {
      label: "free_list_head"
      shape: rectangle
      style.fill: "#B8B8D8"
    }
    fl_b0: {
      label: "Block 0"
      shape: circle
      style.fill: "#D8D8F8"
    }
    fl_b1: {
      label: "Block 1"
      shape: circle
      style.fill: "#D8D8F8"
    }
    fl_bn: {
      label: "Block N-1"
      shape: circle
      style.fill: "#D8D8F8"
      style.stroke-dash: 3
    }
    null_term: {
      label: "NULL"
      shape: rectangle
      style.fill: "#FFD8D8"
    }
    fl_header -> fl_b0: "points to"
    fl_b0 -> fl_b1: "next"
    fl_b1 -> fl_bn: "..."
    fl_bn -> null_term: "next"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  size_calc: {
    label: "Size Calculations"
    style.fill: "#F0F0F0"
    style.stroke: "#666666"
    calc: |md
      
      total_size = block_size * capacity
                 = 64 * N bytes
      Block i address:
        base + (i * block_size)
        = base + (i * 64)
      Block i offset:
        i * 64 bytes
      
    |
  }
  alignment: {
    label: "Alignment Requirements"
    style.fill: "#F0F0F0"
    style.stroke: "#666666"
    align: |md
      
      block_size requirements:
      1. >= sizeof(void*) (8 bytes)
      2. Multiple of alignof(max_align_t)
      Base address:
      - aligned_alloc(max_align_t, total)
      Result: All blocks aligned!
      
    |
  }
}
pool_header -> memory_region: "base points to"