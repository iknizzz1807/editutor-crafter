direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Dynamic Growth: Adding New Chunks
  Pool state evolution when free list is exhausted
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_before: {
    direction: down
    label: "STATE 1: Pool Exhausted"
    chunk_registry1: {
      label: "Chunk Registry"
      shape: class
      +head: "Chunk*"
      +count: "size_t = 1"
    }
    chunk1_meta: {
      label: "Chunk 0 Metadata"
      shape: sql_table
      f0: "0x00 | void*    | memory = 0x1000"
      f1: "0x08 | size_t   | num_blocks = 4"
      f2: "0x10 | Chunk*   | next = NULL"
    }
    chunk_registry1 -> chunk1_meta: "head"
    memory_region1: {
      direction: right
      label: "Memory Region (Chunk 0 @ 0x1000)"
      block0_used: {
        label: "Block 0\n[ALLOCATED]"
        shape: rectangle
        style.fill: "#f8d7da"
        style.stroke: "#721c24"
      }
      block1_used: {
        label: "Block 1\n[ALLOCATED]"
        shape: rectangle
        style.fill: "#f8d7da"
        style.stroke: "#721c24"
      }
      block2_used: {
        label: "Block 2\n[ALLOCATED]"
        shape: rectangle
        style.fill: "#f8d7da"
        style.stroke: "#721c24"
      }
      block3_used: {
        label: "Block 3\n[ALLOCATED]"
        shape: rectangle
        style.fill: "#f8d7da"
        style.stroke: "#721c24"
      }
    }
    free_list_empty: {
      label: "free_list_head = NULL"
      shape: diamond
      style.fill: "#f8d7da"
      style.stroke: "#721c24"
    }
    pool_stats1: {
      label: "Pool State"
      shape: class
      +total_capacity: "size_t = 4"
      +allocated: "size_t = 4"
      +free_list_head: "void* = NULL"
      +chunk_count: "size_t = 1"
    }
    chunk1_meta -> memory_region1: "memory points to"
    pool_stats1 -> free_list_empty: "exhausted"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_transition: {
    direction: down
    label: "grow_pool() Called"
    step1: {
      label: "Step 1: Allocate Chunk Metadata"
      width: 320
      code: |'c
        Chunk* new_chunk = malloc(sizeof(Chunk));
        // Separate allocation - user cannot corrupt
      '|
    }
    step2: {
      label: "Step 2: Allocate Block Storage"
      width: 320
      code: |'c
        size_t sz = block_size * blocks_per_chunk;
        void* mem = aligned_alloc(alignof(max_align_t), sz);
        // mem = 0x5000 (non-contiguous!)
      '|
    }
    step3: {
      label: "Step 3: Link New Chunk"
      width: 320
      code: |'c
        new_chunk->memory = mem;
        new_chunk->num_blocks = 4;
        new_chunk->next = pool->chunks;
        pool->chunks = new_chunk;  // prepend
      '|
    }
    step1 -> step2 -> step3: "then"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_after: {
    direction: down
    label: "STATE 2: New Chunk Integrated"
    chunk_registry2: {
      label: "Chunk Registry (Linked List)"
      shape: class
      +head: "Chunk* → Chunk 1"
      +count: "size_t = 2"
    }
    chunks_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      chunk1_meta2: {
        label: "Chunk 1 (NEW)"
        shape: sql_table
        f0: "0x00 | void*    | memory = 0x5000"
        f1: "0x08 | size_t   | num_blocks = 4"
        f2: "0x10 | Chunk*   | next → Chunk 0"
      }
      arrow_link: {
        label: "→"
        shape: text
        style.font-size: 24
      }
      chunk0_meta2: {
        label: "Chunk 0 (ORIGINAL)"
        shape: sql_table
        f0: "0x00 | void*    | memory = 0x1000"
        f1: "0x08 | size_t   | num_blocks = 4"
        f2: "0x10 | Chunk*   | next = NULL"
      }
    }
    chunk_registry2 -> chunk1_meta2: "head"
    chunk1_meta2 -> chunk0_meta2: "next"
    memory_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      memory_region2_new: {
        direction: right
        label: "NEW Region (Chunk 1 @ 0x5000)"
        nb0: {
          label: "Block 0\n[FREE]\nnext→0x5040"
          shape: rectangle
          style.fill: "#d4edda"
          style.stroke: "#155724"
        }
        nb1: {
          label: "Block 1\n[FREE]\nnext→0x5080"
          shape: rectangle
          style.fill: "#d4edda"
          style.stroke: "#155724"
        }
        nb2: {
          label: "Block 2\n[FREE]\nnext→0x50C0"
          shape: rectangle
          style.fill: "#d4edda"
          style.stroke: "#155724"
        }
        nb3: {
          label: "Block 3\n[FREE]\nnext→NULL"
          shape: rectangle
          style.fill: "#d4edda"
          style.stroke: "#155724"
        }
      }
      gap: {
        label: "non-contiguous\n(gap in address space)"
        shape: text
        style.font-color: "#6c757d"
      }
      memory_region2_old: {
        direction: right
        label: "OLD Region (Chunk 0 @ 0x1000)"
        ob0: {
          label: "Block 0\n[ALLOCATED]"
          shape: rectangle
          style.fill: "#f8d7da"
          style.stroke: "#721c24"
        }
        ob1: {
          label: "Block 1\n[ALLOCATED]"
          shape: rectangle
          style.fill: "#f8d7da"
          style.stroke: "#721c24"
        }
        ob2: {
          label: "Block 2\n[ALLOCATED]"
          shape: rectangle
          style.fill: "#f8d7da"
          style.stroke: "#721c24"
        }
        ob3: {
          label: "Block 3\n[ALLOCATED]"
          shape: rectangle
          style.fill: "#f8d7da"
          style.stroke: "#721c24"
        }
      }
    }
    chunk1_meta2 -> memory_region2_new: "memory"
    chunk0_meta2 -> memory_region2_old: "memory"
    free_list_integrated: {
      label: "Unified Free List"
      shape: rectangle
      style.fill: "#e2e3e5"
      style.stroke: "#383d41"
      fl_head: {
        label: "free_list_head\n= 0x5000"
        shape: rectangle
        style.fill: "#d4edda"
        style.stroke: "#155724"
      }
    }
    pool_stats2: {
      label: "Pool State (After Growth)"
      shape: class
      +total_capacity: "size_t = 8"
      +allocated: "size_t = 4"
      +free_list_head: "void* = 0x5000"
      +chunk_count: "size_t = 2"
    }
    free_list_integrated -> memory_region2_new.nb0: "points to"
    pool_stats2 -> free_list_integrated
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  unified_list: {
    direction: down
    label: "UNIFIED FREE LIST: Non-Contiguous But Connected"
    list_visual: {
      direction: right
      label: "Free List Traversal (LIFO push order)"
      node1: {
        label: "0x5000\n(Chunk 1, Block 0)"
        shape: rectangle
        style.fill: "#d4edda"
        style.stroke: "#155724"
      }
      node2: {
        label: "0x5040\n(Chunk 1, Block 1)"
        shape: rectangle
        style.fill: "#d4edda"
        style.stroke: "#155724"
      }
      node3: {
        label: "0x5080\n(Chunk 1, Block 2)"
        shape: rectangle
        style.fill: "#d4edda"
        style.stroke: "#155724"
      }
      node4: {
        label: "0x50C0\n(Chunk 1, Block 3)"
        shape: rectangle
        style.fill: "#d4edda"
        style.stroke: "#155724"
      }
      null_node: {
        label: "NULL"
        shape: circle
        style.fill: "#e2e3e5"
      }
    }
    insight: {
      label: "Key Insight"
      width: 400
      code: |'c
        // Free list threads through addresses,
        // not contiguous memory regions.
        // Block at 0x5000 points to 0x5040
        // regardless of which chunk owns them.
        // pool_free() doesn't need to know
        // which chunk a block came from!
      '|
    }
    list_visual.node1 -> list_visual.node2 -> list_visual.node3 -> list_visual.node4 -> list_visual.null_node: "next"
  }
}
row1 -> row2: "pool_alloc() returns NULL"
row2 -> row3: "grow_pool() succeeds"
row3 -> row4: "result"
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  alloc: {
    label: "[ALLOCATED]"
    shape: rectangle
    style.fill: "#f8d7da"
    style.stroke: "#721c24"
  }
  free: {
    label: "[FREE]"
    shape: rectangle
    style.fill: "#d4edda"
    style.stroke: "#155724"
  }
  metadata: {
    label: "Chunk Metadata\n(separate allocation)"
    shape: rectangle
    style.fill: "#fff3cd"
    style.stroke: "#856404"
  }
}