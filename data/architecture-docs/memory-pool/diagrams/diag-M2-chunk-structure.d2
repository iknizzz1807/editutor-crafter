direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Chunk Metadata Layout
  Metadata allocated separately from block storage to prevent user corruption
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  chunk_meta: {
    direction: down
    label: "Chunk Metadata (chunk_t)"
    meta_struct: {
      shape: sql_table
      label: "struct Chunk (memory_pool.h)"
      f0: "0x00 | struct Chunk* | next"
      f1: "0x08 | size_t        | num_blocks"
      f2: "0x10 | void*         | memory"
      sz: "Total: 24 bytes (3 pointers)"
    }
    meta_note: {
      label: "Stored in SEPARATE malloc()"
      shape: text
      style.font-color: "#4A90D9"
      style.italic: true
    }
  }
  arrow_container: {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    width: 60
    ptr_arrow: {
      shape: text
      label: "→"
      style.font-size: 32
      style.font-color: "#6B7280"
    }
  }
  block_region: {
    direction: down
    label: "Block Storage Region"
    blocks_table: {
      shape: sql_table
      label: "aligned_alloc(alignment, block_size × num_blocks)"
      b0: "0x0000 | Block 0  | 64 bytes"
      b1: "0x0040 | Block 1  | 64 bytes"
      b2: "0x0080 | Block 2  | 64 bytes"
      b3: "0x00C0 | Block 3  | 64 bytes"
      b4: "0x0100 | Block 4  | 64 bytes"
      bn: "...     | Block n  | 64 bytes"
    }
    block_note: {
      label: "User writes to THESE blocks"
      shape: text
      style.font-color: "#E74C3C"
      style.italic: true
    }
  }
}
chunk_meta.meta_struct.f2 -> block_region.blocks_table.b0: "memory ptr" {
  style.stroke: "#6B7280"
  style.stroke-dash: 3
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  why_separate: {
    direction: down
    label: "Why Separate Allocations?"
    width: 380
    reason1: {
      label: |md
        **1. User Data Isolation**
        User writes to block storage cannot corrupt the `next` pointer or `memory` pointer
      |
    }
    reason2: {
      label: |md
        **2. Metadata Lifetime**
        Chunk metadata persists even when all blocks are allocated (no free list pointers inside)
      |
    }
    reason3: {
      label: |md
        **3. Safe Traversal**
        `pool_destroy()` can walk chunk list without reading potentially corrupted user data
      |
    }
  }
  wrong_approach: {
    direction: down
    label: "WRONG: Inline Metadata"
    width: 380
    style.stroke: "#E74C3C"
    style.stroke-dash: 4
    wrong_struct: {
      shape: sql_table
      label: "DANGEROUS: metadata inside block"
      w0: "0x00 | struct Chunk* | next"
      w1: "0x08 | size_t        | num_blocks"
      w2: "0x10 | User Data...  | ???"
      note: "User overwrites next → list corruption!"
    }
  }
}
why_separate.reason1 -> wrong_approach: "avoids" {
  style.stroke: "#27AE60"
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  direction: down
  label: "Legend"
  l1: {
    label: "Blue = Metadata (protected)"
    shape: rectangle
    style.fill: "#E8F4FD"
    style.stroke: "#4A90D9"
  }
  l2: {
    label: "Red = User-writable (danger zone)"
    shape: rectangle
    style.fill: "#FDE8E8"
    style.stroke: "#E74C3C"
  }
}
chunk_meta.style.fill: "#E8F4FD"
chunk_meta.style.stroke: "#4A90D9"
block_region.style.fill: "#FDE8E8"
block_region.style.stroke: "#E74C3C"