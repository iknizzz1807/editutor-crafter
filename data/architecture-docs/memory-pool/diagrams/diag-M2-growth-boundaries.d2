direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Bounded vs Unbounded Growth
| {near: top-center}
row_unbounded: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  unbounded: {
    direction: down
    label: "UNBOUNDED (max_chunks = 0)"
    stage1: {
      label: "t=0"
      chunk1: {
        label: "Chunk 0"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        blocks1: |md
          □ □ □ □ □
          □ □ □ □ □
        |
      }
    }
    stage2: {
      label: "t=1 (exhausted)"
      chunk1b: {
        label: "Chunk 0"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        blocks1b: |md
          ■ ■ ■ ■ ■
          ■ ■ ■ ■ ■
        |
      }
    }
    stage3: {
      label: "t=2 (grew)"
      chunk1c: {
        label: "Chunk 0"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        blocks1c: |md
          ■ ■ ■ ■ ■
          ■ ■ ■ ■ ■
        |
      }
      chunk2: {
        label: "Chunk 1"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        blocks2: |md
          □ □ □ □ □
          □ □ □ □ □
        |
      }
    }
    stage4: {
      label: "t=N (OOM!)"
      chunk1d: {
        label: "Chunk 0"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
      }
      ellipsis1: {
        label: "..."
        shape: text
      }
      chunkN: {
        label: "Chunk N"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
      }
      oom: {
        label: "OUT OF MEMORY"
        style.fill: "#B71C1C"
        style.font-color: white
        style.stroke: "#B71C1C"
        style.bold: true
      }
    }
    stage1 -> stage2: "alloc()"
    stage2 -> stage3: "grow_pool()"
    stage3 -> stage4: "repeat..."
  }
}
row_bounded: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bounded: {
    direction: down
    label: "BOUNDED (max_chunks = 2)"
    bstage1: {
      label: "t=0"
      bchunk1: {
        label: "Chunk 0"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        bblocks1: |md
          □ □ □ □ □
          □ □ □ □ □
        |
      }
    }
    bstage2: {
      label: "t=1 (exhausted)"
      bchunk1b: {
        label: "Chunk 0"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        bblocks1b: |md
          ■ ■ ■ ■ ■
          ■ ■ ■ ■ ■
        |
      }
    }
    bstage3: {
      label: "t=2 (grew)"
      bchunk1c: {
        label: "Chunk 0"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
        bblocks1c: |md
          ■ ■ ■ ■ ■
          ■ ■ ■ ■ ■
        |
      }
      bchunk2: {
        label: "Chunk 1"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        bblocks2: |md
          □ □ □ □ □
          □ □ □ □ □
        |
      }
    }
    bstage4: {
      label: "t=3 (LIMIT HIT)"
      bchunk1d: {
        label: "Chunk 0"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
      }
      bchunk2b: {
        label: "Chunk 1"
        style.fill: "#FFCDD2"
        style.stroke: "#F44336"
      }
      null_ret: {
        label: "pool_alloc()\n→ NULL"
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
        style.bold: true
      }
      limit_check: {
        label: "chunk_count >= max_chunks"
        shape: diamond
        style.fill: "#FFE0B2"
        style.stroke: "#FF9800"
      }
    }
    bstage1 -> bstage2: "alloc()"
    bstage2 -> bstage3: "grow_pool()"
    bstage3 -> bstage4: "alloc() when full"
  }
}
row_legend: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    direction: right
    label: "Legend"
    free_block: {
      label: "□ Free"
      shape: text
      style.font-color: "#4CAF50"
    }
    used_block: {
      label: "■ Allocated"
      shape: text
      style.font-color: "#F44336"
    }
  }
}
row_tradeoff: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tradeoff: {
    label: "Trade-off Analysis"
    unbounded_pros: {
      label: "Unbounded"
      style.fill: "#FFEBEE"
      style.stroke: "#EF5350"
      flex: |md
        ✓ Flexibility
        ✓ No capacity planning
        ✗ Memory exhaustion
        ✗ Unpredictable failures
      |
    }
    bounded_pros: {
      label: "Bounded"
      style.fill: "#E8F5E9"
      style.stroke: "#66BB6A"
      safe: |md
        ✓ Predictable limits
        ✓ Graceful degradation
        ✓ Resource protection
        ✗ Requires planning
      |
    }
  }
}
row_unbounded -> row_bounded
row_bounded -> row_legend
row_legend -> row_tradeoff