direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Pool Lifecycle State Machine {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
states: {
  direction: down
  uninitialized: UNINITIALIZED {
    shape: circle
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 2
    }
    desc: "MemoryPool struct\nzeroed or garbage" {
      shape: text
      style.font-size: 11
    }
  }
  initialized: INITIALIZED {
    shape: rectangle
    style: {
      fill: "#ACE1AF"
      stroke: "#2E8B57"
      stroke-width: 2
    }
    label: "INITIALIZED\n(1 chunk)"
    desc: "• base pointer valid\n• free_list built\n• mutex initialized\n• capacity = initial" {
      shape: text
      style.font-size: 11
    }
  }
  growing: GROWING {
    shape: hexagon
    style: {
      fill: "#87CEEB"
      stroke: "#4682B4"
      stroke-width: 2
    }
    label: "GROWING\n(N chunks)"
    desc: "• chunks linked list\n• unified free_list\n• bitmap spans all\n• auto-expand on alloc" {
      shape: text
      style.font-size: 11
    }
  }
  destroying: DESTROYING {
    shape: diamond
    style: {
      fill: "#FFB6C1"
      stroke: "#DC143C"
      stroke-width: 2
    }
    desc: "• Lock mutex\n• Check allocated count\n• Free all chunk memory\n• Destroy mutex" {
      shape: text
      style.font-size: 11
    }
  }
  destroyed: DESTROYED {
    shape: circle
    style: {
      fill: "#D3D3D3"
      stroke: "#666666"
      stroke-width: 2
    }
    desc: "struct zeroed\nready for reuse" {
      shape: text
      style.font-size: 11
    }
  }
}
transitions: {
  direction: down
  t_init: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 1
    height: 1
  }
  t_alloc: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 1
    height: 1
  }
  t_exhaust: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 1
    height: 1
  }
  t_destroy: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 1
    height: 1
  }
  t_leak: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 1
    height: 1
  }
  t_done: {
    shape: rectangle
    style: {
      fill: transparent
      stroke: transparent
    }
    width: 1
    height: 1
  }
}
uninitialized -> states.initialized: "pool_init()\n[success]" {
  style: {
    stroke: "#2E8B57"
    stroke-width: 2
    bold: true
  }
}
uninitialized -> destroyed: "pool_init()\n[failure]" {
  style: {
    stroke: "#DC143C"
    stroke-dash: 4
  }
}
states.initialized -> states.growing: "pool_alloc()\n[free_list empty]\n→ grow_pool()" {
  style: {
    stroke: "#4682B4"
    stroke-width: 2
  }
}
states.growing -> states.growing: "pool_alloc()\n[exhausted]\n→ grow_pool()\n[chunk_count < max]" {
  style: {
    stroke: "#4682B4"
    stroke-width: 2
  }
}
states.growing -> states.growing: "pool_free()\n→ push to free_list" {
  style: {
    stroke: "#8B4513"
    stroke-width: 1
    stroke-dash: 3
  }
}
states.growing -> states.destroying: "pool_destroy()" {
  style: {
    stroke: "#DC143C"
    stroke-width: 2
    bold: true
  }
}
states.initialized -> states.destroying: "pool_destroy()" {
  style: {
    stroke: "#DC143C"
    stroke-width: 2
    bold: true
  }
}
states.destroying -> leak_check: "allocated > 0?" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 2
  }
}
leak_check: LEAK CHECK {
  shape: diamond
  style: {
    fill: "#FFE4B5"
    stroke: "#FF8C00"
    stroke-width: 2
  }
  action: "fprintf(stderr,\n  \"WARNING: %zu blocks\n   still allocated!\n\")" {
    shape: text
    style: {
      font-size: 10
      font-color: "#8B0000"
    }
  }
}
leak_check -> states.destroyed: "[no leaks]\nfree all chunks\nmemset(pool, 0)" {
  style: {
    stroke: "#2E8B57"
    stroke-width: 2
  }
}
leak_check -> states.destroyed: "[leaks detected]\nlog warning\nfree all chunks\nmemset(pool, 0)" {
  style: {
    stroke: "#FF8C00"
    stroke-dash: 4
  }
}
legend: {
  near: bottom-right
  legend_title: Legend {
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
  normal: "Normal transition" {
    shape: text
    style.font-size: 11
  }
  error: "Error / warning path" {
    shape: text
    style: {
      font-size: 11
      font-color: "#DC143C"
    }
  }
  loop: "Self-transition (loop)" {
    shape: text
    style: {
      font-size: 11
      font-color: "#8B4513"
    }
  }
  check: "Conditional check" {
    shape: text
    style: {
      font-size: 11
      font-color: "#FF8C00"
    }
  }
}