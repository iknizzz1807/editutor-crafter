direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Debug Feature Detection Matrix"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
matrix: {
  grid-columns: 4
  grid-rows: 7
  grid-gap: 0
  c1_header: Bug Type {
    class: header
  }
  c2_header: Detection Method {
    class: header
  }
  c3_header: Detects Read {
    class: header
  }
  c4_header: Detects Write {
    class: header
  }
  r1_bug: Use-After-Free
  r1_method: Memory Poisoning {
    class: detected
    label: "Poison Pattern (0xDE)\nfilled on free"
  }
  r1_read: "—"
  r1_write: "✓"
  r2_bug: Buffer Overflow
  r2_method: Canary Values {
    class: detected
    label: "Front + Back\n0xCAFEBABE..."
  }
  r2_read: "—"
  r2_write: "✓"
  r3_bug: Buffer Underflow
  r3_method: Canary Values {
    class: detected
    label: "Front Canary\nat block start"
  }
  r3_read: "—"
  r3_write: "✓"
  r4_bug: Double-Free
  r4_method: Bitmap Tracking {
    class: detected
    label: "1-bit per block\nallocated state"
  }
  r4_read: "—"
  r4_write: "—"
  r5_bug: Memory Leak
  r5_method: Counter Check {
    class: detected
    label: "allocated > 0\nat pool_destroy()"
  }
  r5_read: "—"
  r5_write: "—"
  r6_bug: Read-After-Free
  r6_method: "NOT DETECTED" {
    class: not_detected
    label: "Requires HW support\n(MPK, MTE) or mprotect"
  }
  r6_read: "✗"
  r6_write: "—"
}
classes: {
  header: {
    style: {
      bold: true
      fill: "#4A5568"
      font-color: white
      stroke: "#2D3748"
      stroke-width: 2
    }
  }
  detected: {
    style: {
      fill: "#C6F6D5"
      stroke: "#38A169"
    }
  }
  not_detected: {
    style: {
      fill: "#FED7D7"
      stroke: "#E53E3E"
      font-color: "#C53030"
      bold: true
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.stroke: transparent
  check: "✓ = Detected" {
    style: {
      fill: "#C6F6D5"
      stroke: "#38A169"
    }
  }
  dash: "— = N/A" {
    style: {
      fill: "#E2E8F0"
      stroke: "#A0AEC0"
    }
  }
  cross: "✗ = Not Detected" {
    style: {
      fill: "#FED7D7"
      stroke: "#E53E3E"
    }
  }
}
note: {
  label: |md
    **Detection Timing**
    - **Poisoning**: Verified on `pool_alloc()` reallocation
    - **Canaries**: Verified on `pool_free()` call
    - **Bitmap**: Checked during `pool_free()` operation
    - **Leaks**: Reported at `pool_destroy()` time
  |
  near: bottom-right
  style: {
    fill: "#EDF2F7"
    stroke: "#A0AEC0"
    stroke-dash: 3
  }
}