direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Race Condition: Concurrent pool_alloc Without Mutex"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  thread_a: {
    direction: down
    label: "Thread A"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    ta_label: {
      label: "pool_alloc()"
      shape: text
      style.font-size: 18
      style.bold: true
    }
    step_a1: {
      label: "T1: Read free_list_head"
      width: 260
      code: |'c
        head = pool->free_list_head;
        // head = 0x1000
      '|
      style.fill: "#FFF3E0"
    }
    step_a2: {
      label: "T2: Read next from block"
      width: 260
      code: |'c
        next = *(void**)head;
        // next = 0x1040
      '|
      style.fill: "#FFF3E0"
    }
    step_a3: {
      label: "T3: Update head"
      width: 260
      code: |'c
        pool->free_list_head = next;
        // head = 0x1040
      '|
      style.fill: "#E8F5E9"
    }
    step_a4: {
      label: "T4: Return block"
      width: 260
      code: |'c
        return head; // 0x1000
      '|
      style.fill: "#E8F5E9"
    }
    step_a1 -> step_a2 -> step_a3 -> step_a4
  }
  shared_state: {
    direction: down
    label: "Shared Pool State"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 3
    state_label: {
      label: "CRITICAL SECTION\n(No Mutex Protection!)"
      shape: text
      style: {
        font-size: 14
        bold: true
        font-color: "#C62828"
      }
    }
    free_list_head: {
      shape: sql_table
      label: "free_list_head"
      r1: "Address | Value"
      r2: "0x00 | void* | 0x1000"
      r3: "0x08 | size_t | allocated++"
      style.fill: "#FFCDD2"
    }
    memory_blocks: {
      label: "Memory Blocks (Free List)"
      shape: sql_table
      r1: "Block | next_ptr | Status"
      r2: "0x1000 | 0x1040 | FREE"
      r3: "0x1040 | 0x1080 | FREE"
      r4: "0x1080 | NULL | FREE"
      style.fill: "#FFCDD2"
    }
    free_list_head -> memory_blocks: "points to"
  }
  thread_b: {
    direction: down
    label: "Thread B"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    tb_label: {
      label: "pool_alloc()"
      shape: text
      style.font-size: 18
      style.bold: true
    }
    step_b1: {
      label: "T1: Read free_list_head"
      width: 260
      code: |'c
        head = pool->free_list_head;
        // head = 0x1000 (!)
      '|
      style.fill: "#FFF3E0"
    }
    step_b2: {
      label: "T2: Read next from block"
      width: 260
      code: |'c
        next = *(void**)head;
        // next = 0x1040
      '|
      style.fill: "#FFF3E0"
    }
    step_b3: {
      label: "T3: Update head"
      width: 260
      code: |'c
        pool->free_list_head = next;
        // head = 0x1040
      '|
      style.fill: "#E8F5E9"
    }
    step_b4: {
      label: "T4: Return block"
      width: 260
      code: |'c
        return head; // 0x1000 (!)
      '|
      style.fill: "#E8F5E9"
    }
    step_b1 -> step_b2 -> step_b3 -> step_b4
  }
}
row1.thread_a.step_a1 -> row1.shared_state.free_list_head: "read 0x1000" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
row1.thread_b.step_b1 -> row1.shared_state.free_list_head: "read 0x1000" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  timeline: {
    label: "Interleaved Execution Timeline"
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    t0: {
      label: "Time"
      shape: text
      style.bold: true
    }
    t1: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      t1a: {
        label: "T1"
        shape: circle
        style.fill: "#FFF3E0"
      }
      t1b: {
        label: "Both read\n0x1000"
        shape: text
        style.font-color: "#C62828"
        style.bold: true
      }
    }
    t2: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      t2a: {
        label: "T2"
        shape: circle
        style.fill: "#FFF3E0"
      }
      t2b: {
        label: "Both read\n0x1040"
        shape: text
        style.font-color: "#C62828"
        style.bold: true
      }
    }
    t3: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      t3a: {
        label: "T3"
        shape: circle
        style.fill: "#E8F5E9"
      }
      t3b: {
        label: "Both write\n0x1040"
        shape: text
        style.font-color: "#C62828"
        style.bold: true
      }
    }
    t4: {
      direction: right
      label: ""
      style: {
        stroke: transparent
        fill: transparent
      }
      t4a: {
        label: "T4"
        shape: circle
        style.fill: "#E8F5E9"
      }
      t4b: {
        label: "Both return\n0x1000"
        shape: text
        style.font-color: "#C62828"
        style.bold: true
      }
    }
    t1 -> t2 -> t3 -> t4
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  corruption_result: {
    label: "CORRUPTION RESULT"
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
    bug1: {
      label: "BUG #1: Duplicate Allocation"
      shape: diamond
      style.fill: "#FFCDD2"
      width: 200
    }
    bug2: {
      label: "BUG #2: Lost Block"
      shape: diamond
      style.fill: "#FFCDD2"
      width: 200
    }
    bug3: {
      label: "BUG #3: Memory Leak"
      shape: diamond
      style.fill: "#FFCDD2"
      width: 200
    }
    desc1: {
      label: "Block 0x1000 returned\nto BOTH threads"
      shape: text
      style.font-color: "#B71C1C"
    }
    desc2: {
      label: "Block 0x1080 orphaned\n(never on free list)"
      shape: text
      style.font-color: "#B71C1C"
    }
    desc3: {
      label: "Link 0x1040→0x1080\npermanently lost"
      shape: text
      style.font-color: "#B71C1C"
    }
    bug1 -> desc1
    bug2 -> desc2
    bug3 -> desc3
  }
  fix_section: {
    label: "THE FIX: Mutex Protection"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    fix_code: {
      label: "Critical Section Serialized"
      width: 340
      code: |'c
        void* pool_alloc(MemoryPool* pool) {
            pthread_mutex_lock(&pool->mutex);
            // Only ONE thread here at a time
            void* block = pool->free_list_head;
            pool->free_list_head = *(void**)block;
            pool->allocated++;
            pthread_mutex_unlock(&pool->mutex);
            return block;
        }
      '|
      style.fill: "#C8E6C9"
    }
    fix_result: {
      label: "Result: Thread A completes ENTIRE\nallocation before Thread B starts"
      shape: text
      style.font-color: "#2E7D32"
      style.bold: true
    }
    fix_code -> fix_result
  }
}
row2.timeline -> row3.corruption_result: "causes" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 4
}
legend: {
  near: bottom-center
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: {
    label: "Orange = Read operation (unsafe)"
    shape: text
  }
  l2: {
    label: "Green = Write operation (unsafe)"
    shape: text
  }
  l3: {
    label: "Red = Corruption / Bug detected"
    shape: text
  }
}