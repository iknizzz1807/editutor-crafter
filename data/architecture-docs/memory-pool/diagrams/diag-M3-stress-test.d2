direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Concurrent Stress Test Architecture
  **8 threads × 100,000 ops = 800,000 total operations**
| {near: top-center}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  threads_col: {
    direction: down
    label: "Thread Pool (pthread_create)"
    thread0: {
      label: "Thread 0"
      shape: person
      style.fill: "#E8F4FD"
    }
    thread1: {
      label: "Thread 1"
      shape: person
      style.fill: "#E8F4FD"
    }
    thread2: {
      label: "Thread 2"
      shape: person
      style.fill: "#E8F4FD"
    }
    thread3: {
      label: "Thread 3"
      shape: person
      style.fill: "#E8F4FD"
    }
    thread4: {
      label: "Thread 4"
      shape: person
      style.fill: "#E8F4FD"
    }
    thread5: {
      label: "Thread 5"
      shape: person
      style.fill: "#E8F4FD"
    }
    thread6: {
      label: "Thread 6"
      shape: person
      style.fill: "#E8F4FD"
    }
    thread7: {
      label: "Thread 7"
      shape: person
      style.fill: "#E8F4FD"
    }
  }
  operations_col: {
    direction: down
    label: "Per-Thread Operations"
    op_cycle: {
      label: "100K Iterations"
      shape: oval
      style.fill: "#FFF9E6"
    }
    alloc_op: {
      label: "pool_alloc()"
      shape: rectangle
      style.fill: "#D4EDDA"
    }
    free_op: {
      label: "pool_free()"
      shape: rectangle
      style.fill: "#F8D7DA"
    }
    verify_op: {
      label: "Verify Pattern\n(0xAB ^ thread_id)"
      shape: diamond
      style.fill: "#E2E3E5"
    }
    held_blocks: {
      label: "held_blocks[10]"
      shape: queue
      style.fill: "#D1ECF1"
    }
    op_cycle -> alloc_op: "50%"
    op_cycle -> verify_op: "50%"
    verify_op -> free_op: "pass"
    alloc_op -> held_blocks: "store"
    held_blocks -> free_op: "random idx"
  }
  pool_col: {
    direction: down
    label: "Shared MemoryPool"
    mutex: {
      label: "pthread_mutex_t"
      shape: hexagon
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
    }
    pool_state: {
      shape: sql_table
      label: "MemoryPool (pool.c)"
      f0: "free_list_head | void*"
      f1: "allocated | size_t"
      f2: "allocated_map | uint64_t*"
      f3: "chunks | Chunk*"
      note: "Protected by mutex"
    }
    chunks: {
      label: "Chunk List"
      shape: cylinder
      style.multiple: true
    }
    mutex -> pool_state: "serializes access"
    pool_state -> chunks
  }
}
row_verification: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  verify_phase: {
    direction: down
    label: "Verification Phase (pthread_join)"
    v1: {
      label: "✓ No Crashes"
      shape: rectangle
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
    }
    v2: {
      label: "✓ No Deadlocks"
      shape: rectangle
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
    }
    v3: {
      label: "✓ No Data Corruption"
      shape: rectangle
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
    }
    v4: {
      label: "✓ Pool State Consistent"
      shape: rectangle
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
    }
  }
  consistency: {
    direction: down
    label: "Final State Check"
    check: {
      shape: sql_table
      label: "PoolStats Verification"
      c0: "allocated == 0 | all returned"
      c1: "free == total_capacity | full pool"
      c2: "chunk_count | bounded growth"
    }
    pass: {
      label: "PASS: No corruption"
      shape: oval
      style.fill: "#28A745"
      style.font-color: white
    }
    check -> pass
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  l1: {
    label: "Green = Allocation path"
    shape: rectangle
    style.fill: "#D4EDDA"
  }
  l2: {
    label: "Red = Free path"
    shape: rectangle
    style.fill: "#F8D7DA"
  }
  l3: {
    label: "Gold = Mutex (serialization)"
    shape: hexagon
    style.fill: "#FFD700"
  }
  l4: {
    label: "Blue = Thread context"
    shape: person
    style.fill: "#E8F4FD"
  }
}
threads_col.thread0 -> operations_col.op_cycle: "rand()"
threads_col.thread7 -> operations_col.op_cycle: "rand()" {
  style.stroke-dash: 3
}
operations_col.alloc_op -> pool_col.mutex: "lock()"
operations_col.free_op -> pool_col.mutex: "lock()"
row_main -> row_verification: "threads complete"