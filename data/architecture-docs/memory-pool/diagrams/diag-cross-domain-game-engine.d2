direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_block: {
  label: "Game Engine Object Pool Allocator (v1.1.0)"
  note: |'md
    ### Implementation Standards
    - **O(1) Allocation/Deallocation**: Achieved via embedded free-list.
    - **Cache Alignment**: Blocks aligned to 64-byte cache line boundaries.
    - **Thread Safety**: Mutex-guarded chunk growth.
  '|
}

# --- Row 1: Structural Definitions ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  memory_pool_struct: {
    shape: sql_table
    label: "struct MemoryPool (pool.h)"
    f0: "0x00 | size_t | block_size // Aligned to 16/64 bytes"
    f1: "0x08 | uint32_t | blocks_per_chunk // Growth factor"
    f2: "0x0C | uint32_t | max_chunks // Safety limit"
    f3: "0x10 | void* | free_list_head // O(1) access"
    f4: "0x18 | PoolChunk* | first_chunk // Linked list of storage"
    f5: "0x20 | pthread_mutex_t | lock // Guard for growth"
    total: "Total: 64 bytes (1 cache line)"
  }

  pool_chunk_struct: {
    shape: sql_table
    label: "struct PoolChunk (pool.c)"
    f0: "0x00 | PoolChunk* | next_chunk"
    f1: "0x08 | void* | data_base // Memory start"
    f2: "0x10 | uint32_t | used_count // For deferred free"
    f3: "0x14 | uint8_t[4] | padding"
    total: "Total: 24 bytes"
  }

  pool_api: {
    shape: class
    label: "Pool Allocator API"
    +pool_init(p, block_sz, n): "int"
    +pool_alloc(p): "void*"
    +pool_free(p, ptr): "void"
    -pool_grow(p): "bool"
    +pool_destroy(p): "void"
  }
}

# --- Row 2: Memory Layout & Logic ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  visual_layout: {
    label: "Internal Memory Topology"
    
    chunk_1: {
      label: "Chunk 0 (Base)"
      block_0: "Block 0 (Used)" { style.fill: "#f8cecc" }
      block_1: "Block 1 (Free)" { style.fill: "#d5e8d4" }
      block_2: "Block 2 (Free)" { style.fill: "#d5e8d4" }
    }

    chunk_2: {
      label: "Chunk 1 (Allocated on Growth)"
      block_3: "Block 3 (Free)" { style.fill: "#d5e8d4" }
      block_4: "Block 4 (Free)" { style.fill: "#d5e8d4" }
    }
    
    chunk_1.block_1 -> chunk_1.block_2: "next_free"
    chunk_1.block_2 -> chunk_2.block_3: "next_free"
    chunk_2.block_3 -> chunk_2.block_4: "next_free (NULL)"
  }

  alloc_logic: {
    label: "Allocation Hot-Path"
    width: 400
    code: |'c
      pthread_mutex_lock(&p->lock);
      if (!p->free_list_head) {
        if (!pool_grow(p)) return NULL;
      }
      void* ptr = p->free_list_head;
      p->free_list_head = *(void**)ptr;
      pthread_mutex_unlock(&p->lock);
      return ptr;
    '|
  }
}

# --- Row 3: Performance Comparison ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  comparison: |'md
    | Feature | Malloc/Free (Standard) | Pool Allocator (Optimized) |
    | :--- | :--- | :--- |
    | **Time Complexity** | O(log N) or O(N) | **O(1) Guaranteed** |
    | **Fragmentation** | High (External) | **Zero (Internal)** |
    | **Cache Locality** | Poor (Scattered) | **High (Contiguous Chunks)** |
    | **Thread Contention** | Global Heap Lock | **Local Per-Pool Mutex** |
  '|
}

# --- Connections ---
row1.memory_pool_struct -> row2.visual_layout.chunk_1.block_1: "0x10 | pop"
row1.memory_pool_struct -> row1.pool_chunk_struct: "0x18 | tracks"
row2.alloc_logic -> row2.visual_layout: "pop node"

legend: {
  shape: rectangle
  near: bottom-right
  used_mem: "Used Block" { style.fill: "#f8cecc" }
  free_mem: "Free Block" { style.fill: "#d5e8d4" }
}