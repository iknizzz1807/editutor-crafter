vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6b5b95"
    pointer: "#f4a261"
    data: "#7eb5d6"
    counter: "#a8d8b9"
    padding: "#d3d3d3"
    text_dark: "#1a1a2e"
    offset_text: "#888888"
    border: "#4a4a6a"
  }
}

title: |md
  # MemoryPool Structure Layout
  `sizeof(MemoryPool) = 56 bytes`
  *Intel-grade technical specification for 64-bit architecture*
| {near: top-center}

# Alignment and Layout Grid
# This container represents the physical memory mapping of the struct
memory_pool: {
  grid-columns: 3
  grid-gap: 0
  vertical-gap: 0
  horizontal-gap: 20
  
  style: {
    fill: "#1a1a2e"
    stroke: "${colors.border}"
    stroke-width: 2
  }

  # --- HEADER ROW ---
  h_off: "Offset" { shape: text; style: { font-color: white; bold: true; font: mono } }
  h_field: "MemoryPool Struct Field (64-bit alignment)" {
    style: {
      fill: "${colors.header}"
      font-color: white
      bold: true
      stroke: "${colors.border}"
    }
    width: 450
    height: 40
  }
  h_type: "Type / Details" { shape: text; style: { font-color: white; bold: true } }

  # --- 0x00: base ---
  off_00: "0x00" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_00: "base" {
    tooltip: "Pointer to the start of the contiguous memory region"
    style: {
      fill: "${colors.pointer}"
      stroke: "#c47a3a"
      font-color: "${colors.text_dark}"
      bold: true
    }
    width: 450
    height: 50
  }
  type_00: "void* | 8B | Aligned start" { shape: text; style: { font: mono; font-size: 11; font-color: "#cccccc" } }

  # --- 0x08: block_size ---
  off_08: "0x08" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_08: "block_size" {
    tooltip: "Size of each individual memory block in bytes"
    style: {
      fill: "${colors.data}"
      stroke: "#4a7c9b"
      font-color: "${colors.text_dark}"
    }
    width: 450
    height: 50
  }
  type_08: "size_t | 8B | Block size" { shape: text; style: { font: mono; font-size: 11; font-color: "#cccccc" } }

  # --- 0x10: capacity ---
  off_10: "0x10" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_10: "capacity" {
    tooltip: "Total number of blocks available in the pool"
    style: {
      fill: "${colors.data}"
      stroke: "#4a7c9b"
      font-color: "${colors.text_dark}"
    }
    width: 450
    height: 50
  }
  type_10: "size_t | 8B | Total capacity" { shape: text; style: { font: mono; font-size: 11; font-color: "#cccccc" } }

  # --- 0x18: allocated ---
  off_18: "0x18" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_18: "allocated" {
    tooltip: "Number of blocks currently in use"
    style: {
      fill: "${colors.counter}"
      stroke: "#5a8b6a"
      font-color: "${colors.text_dark}"
    }
    width: 450
    height: 50
  }
  type_18: "size_t | 8B | [MUTABLE] active" { shape: text; style: { font: mono; font-size: 11; font-color: "#ff6b6b" } }

  # --- 0x20: free_list_head ---
  off_20: "0x20" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_20: "free_list_head" {
    tooltip: "Pointer to the first available free block"
    style: {
      fill: "${colors.pointer}"
      stroke: "#c47a3a"
      font-color: "${colors.text_dark}"
    }
    width: 450
    height: 50
  }
  type_20: "void* | 8B | [MUTABLE] LIFO" { shape: text; style: { font: mono; font-size: 11; font-color: "#ff6b6b" } }

  # --- 0x28: allocated_map ---
  off_28: "0x28" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_28: "allocated_map" {
    tooltip: "Bitmap for tracking block status (1=In Use, 0=Free)"
    style: {
      fill: "${colors.pointer}"
      stroke: "#c47a3a"
      font-color: "${colors.text_dark}"
    }
    width: 450
    height: 50
  }
  type_28: "uint64_t* | 8B | [MUTABLE] map" { shape: text; style: { font: mono; font-size: 11; font-color: "#ff6b6b" } }

  # --- 0x30: map_size ---
  off_30: "0x30" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_30: "map_size" {
    tooltip: "Size of the allocated_map in 64-bit words"
    style: {
      fill: "${colors.data}"
      stroke: "#4a7c9b"
      font-color: "${colors.text_dark}"
    }
    width: 450
    height: 50
  }
  type_30: "size_t | 8B | Bitmap length" { shape: text; style: { font: mono; font-size: 11; font-color: "#cccccc" } }

  # --- 0x38: PADDING (To cache line) ---
  off_38: "0x38" { shape: text; style: { font: mono; font-color: "${colors.offset_text}" } }
  field_38: "Internal / External Padding" {
    style: {
      fill: "${colors.padding}"
      stroke: "#999999"
      stroke-dash: 3
      font-color: "#666666"
      italic: true
    }
    width: 450
    height: 30
  }
  type_38: "8B | Align to 64B" { shape: text; style: { font: mono; font-size: 11; font-color: "#999999" } }
}

# Legend Section
legend: {
  near: bottom-right
  grid-columns: 2
  grid-gap: 15
  style: {
    fill: "#2a2a3e"
    stroke: "${colors.border}"
    border-radius: 8
  }
  
  ptr_box: "" {
    width: 30; height: 20
    style.fill: "${colors.pointer}"
  }
  ptr_text: "Pointer (8 Bytes)" { shape: text; style.font-color: white }
  
  data_box: "" {
    width: 30; height: 20
    style.fill: "${colors.data}"
  }
  data_text: "Configuration/Size" { shape: text; style.font-color: white }
  
  mut_box: "" {
    width: 30; height: 20
    style.fill: "${colors.counter}"
  }
  mut_text: "State Counter" { shape: text; style.font-color: white }

  hot_box: "" {
    width: 30; height: 20
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    style.fill: transparent
  }
  hot_text: "Mutable (Write-Heavy)" { shape: text; style.font-color: "#ff6b6b" }
}

# Technical Specs Annotation
alignment_note: |md
  ### Layout Implementation Details
  - **Memory Alignment**: 8-byte (64-bit) natural alignment.
  - **Fragmentation**: Zero internal fragmentation; 56-byte packed structure.
  - **Cache Locality**: Struct fits entirely within a single **64-byte L1 cache line**.
  - **Padding**: 8 bytes of slack space (0x38-0x3F) before next cache line.
  - **Critical Path**: `free_list_head` and `allocated` are modified on every `alloc`/`free`.
| {
  near: top-right
  shape: rectangle
  style: {
    fill: "#2a2a3e"
    stroke: "${colors.border}"
    font-color: "#cccccc"
    font-size: 12
  }
  width: 350
}

# Boundary line indicator
memory_pool.field_38 -> cache_line_boundary: "64B Cache Line Limit" {
  style: {
    stroke: "#ff6b6b"
    stroke-dash: 5
    font-color: "#ff6b6b"
    font-size: 10
  }
}

cache_line_boundary: {
  shape: person
  style.opacity: 0
  height: 0
  width: 0
}