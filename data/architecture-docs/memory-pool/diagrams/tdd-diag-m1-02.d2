vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B59B6"
    data: "#3498DB"
    free: "#27AE60"
    padding: "#7F8C8D"
    pointer: "#E67E22"
    allocated: "#E74C3C"
    free_block: "#2ECC71"
  }
}

title: |md
  # Pool Region to Blocks Mapping
  Contiguous allocated region divided into fixed-size blocks with intrusive free list
| {near: top-center}

direction: right

pool_region: "Pool Region (Pre-allocated Memory)" {
  style.fill: "${colors.data}"
  style.stroke: "#2980B9"
  style.stroke-width: 3
  
  header: "Pool Metadata" {
    style.fill: "${colors.header}"
    style.font: mono
    style.font-size: 20
    
    base_ptr: "base: 0x1000\n(Region Start)"
    block_size: "block_size: 64 bytes\n(Aligned)"
    capacity: "capacity: 6 blocks"
    allocated: "allocated: 3"
    free_head: "free_list_head\n→ Block 1"
  }

  blocks: "Block Array (384 bytes total)" {
    grid-columns: 3
    grid-gap: 15
    
    block_0: "Block 0\n0x1000\n[ALLOCATED]" {
      style.fill: "${colors.allocated}"
      style.font-color: white
      style.bold: true
      user_data_0: "User Data\n[0x1000-0x103F]\n64 bytes" {
        shape: text
        style.fill: transparent
        style.font: mono
        style.font-size: 18
      }
    }
    block_1: "Block 1\n0x1040\n[FREE]" {
      style.fill: "${colors.free_block}"
      style.font-color: white
      style.bold: true
      free_ptr_1: "next: 0x10C0\n→ Block 3" {
        shape: text
        style.fill: transparent
        style.font: mono
        style.font-size: 18
        style.font-color: "#1A5276"
      }
    }
    block_2: "Block 2\n0x1080\n[ALLOCATED]" {
      style.fill: "${colors.allocated}"
      style.font-color: white
      style.bold: true
      user_data_2: "User Data\n[0x1080-0x10BF]\n64 bytes" {
        shape: text
        style.fill: transparent
        style.font: mono
        style.font-size: 18
      }
    }
    block_3: "Block 3\n0x10C0\n[FREE]" {
      style.fill: "${colors.free_block}"
      style.font-color: white
      style.bold: true
      free_ptr_3: "next: 0x1100\n→ Block 4" {
        shape: text
        style.fill: transparent
        style.font: mono
        style.font-size: 18
        style.font-color: "#1A5276"
      }
    }
    block_4: "Block 4\n0x1100\n[FREE]" {
      style.fill: "${colors.free_block}"
      style.font-color: white
      style.bold: true
      free_ptr_4: "next: NULL\n(End of List)" {
        shape: text
        style.fill: transparent
        style.font: mono
        style.font-size: 18
        style.font-color: "#1A5276"
      }
    }
    block_5: "Block 5\n0x1140\n[ALLOCATED]" {
      style.fill: "${colors.allocated}"
      style.font-color: white
      style.bold: true
      user_data_5: "User Data\n[0x1140-0x117F]\n64 bytes" {
        shape: text
        style.fill: transparent
        style.font: mono
        style.font-size: 18
      }
    }
  }
}

block_detail: "Block Internal Structure" {
  style.fill: "#ECF0F1"
  style.stroke: "#BDC3C7"
  
  free_block_layout: "FREE Block Layout" {
    style.fill: "${colors.free_block}"
    style.font-color: white
    offset_0: "Offset 0x00"
    next_ptr: "void* next\n(8 bytes)\n→ Next Free Block" {
      style.fill: "${colors.pointer}"
      style.bold: true
    }
    unused: "Unused Space\n(block_size - 8 bytes)" {
      style.fill: "${colors.free}"
      style.fill-pattern: dots
    }
  }
  
  allocated_block_layout: "ALLOCATED Block Layout" {
    style.fill: "${colors.allocated}"
    style.font-color: white
    offset_0_a: "Offset 0x00"
    user_data_start: "User Data\n(Overwrites next ptr)" {
      style.fill: "${colors.data}"
      style.bold: true
    }
    user_data_rest: "User Data Continues\n(Full block_size available)"
  }
}

free_list_diagram: "Intrusive Free List (Logical View)" {
  style.fill: "#FDFEFE"
  style.stroke: "#BDC3C7"
  
  list_header: "free_list_head" {
    shape: diamond
    style.fill: "${colors.pointer}"
    style.font-color: white
  }
  node_1: "Block 1\n0x1040" {
    shape: circle
    style.fill: "${colors.free_block}"
    style.font-color: white
    style.font: mono
  }
  node_3: "Block 3\n0x10C0" {
    shape: circle
    style.fill: "${colors.free_block}"
    style.font-color: white
    style.font: mono
  }
  node_4: "Block 4\n0x1100" {
    shape: circle
    style.fill: "${colors.free_block}"
    style.font-color: white
    style.font: mono
  }
  null_node: "NULL" {
    shape: circle
    style.fill: "#7F8C8D"
    style.font-color: white
  }
  
  list_header -> node_1: "points to" {
    style.stroke: "${colors.pointer}"
    style.stroke-width: 3
    target-arrowhead.shape: arrow
  }
  node_1 -> node_3: "next" {
    style.stroke: "${colors.pointer}"
    style.stroke-dash: 3
    target-arrowhead.shape: arrow
  }
  node_3 -> node_4: "next" {
    style.stroke: "${colors.pointer}"
    style.stroke-dash: 3
    target-arrowhead.shape: arrow
  }
  node_4 -> null_node: "next" {
    style.stroke: "${colors.pointer}"
    style.stroke-dash: 3
    target-arrowhead.shape: arrow
  }
}

memory_layout: "Memory Address Layout" {
  style.fill: "#2C3E50"
  style.font-color: white
  
  addr_table: ||md
    | Address  | Block | State      | Contents           |
    |----------|-------|------------|--------------------| 
    | 0x1000   | 0     | ALLOCATED  | User Data          |
    | 0x1040   | 1     | FREE       | next → 0x10C0      |
    | 0x1080   | 2     | ALLOCATED  | User Data          |
    | 0x10C0   | 3     | FREE       | next → 0x1100      |
    | 0x1100   | 4     | FREE       | next → NULL        |
    | 0x1140   | 5     | ALLOCATED  | User Data          |
    | 0x1180   | -     | END        | (End of Region)    |
  ||
  addr_table.shape: text
  addr_table.style.font: mono
  addr_table.style.font-size: 16
}

operations: "O(1) Memory Operations" {
  style.fill: "#F9EBEA"
  
  alloc_op: "pool_alloc() - POP from Head" {
    style.fill: "#E8F8F5"
    content: |md
      1. block = free_list_head (0x1040)
      2. next = *(void**)block (0x10C0)
      3. free_list_head = next
      4. return block → User owns all 64 bytes
    |
    content.shape: text
    content.style.font: mono
    content.style.font-size: 14
  }
  
  free_op: "pool_free(ptr) - PUSH to Head" {
    style.fill: "#FDEDEC"
    content: |md
      1. Validate ptr (bounds + alignment)
      2. *(void**)ptr = free_list_head
      3. free_list_head = ptr
      4. Block rejoins free list
    |
    content.shape: text
    content.style.font: mono
    content.style.font-size: 14
  }
}

legend: "Color Legend" {
  style.fill: "#F8F9F9"
  alloc_key: "ALLOCATED BLOCK" {
    style.fill: "${colors.allocated}"
    style.font-color: white
  }
  free_key: "FREE BLOCK (IN LIST)" {
    style.fill: "${colors.free_block}"
    style.font-color: white
  }
  ptr_key: "NEXT POINTER STORAGE" {
    style.fill: "${colors.pointer}"
    style.font-color: white
  }
  user_key: "USER DATA REGION" {
    style.fill: "${colors.data}"
    style.font-color: white
  }
}

pool_region.header.free_head -> pool_region.blocks.block_1: "free_list_head\npoints here" {
  style.stroke: "${colors.pointer}"
  style.stroke-width: 2
  style.animated: true
  target-arrowhead.shape: arrow
  target-arrowhead.style.filled: true
}

footer: |md
  **Key Design Principles:**
  1. **Contiguous Region**: Single `aligned_alloc()` call reserves all memory upfront.
  2. **Fixed Block Size**: All blocks identical size (64 bytes, aligned to `max_align_t`).
  3. **Intrusive Free List**: Next pointer stored INSIDE free block (zero overhead).
  4. **O(1) Operations**: Allocation = pop from head, Deallocation = push to head.
  5. **Pointer Overwrite**: When allocated, user data occupies the space where `next` was.
| {
  near: bottom-center
  style.font-size: 14
}