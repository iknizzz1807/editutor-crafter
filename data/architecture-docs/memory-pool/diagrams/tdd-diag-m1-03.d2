vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Alignment Rounding Logic
  Step-by-step transformation: `requested_size` → `block_size`
| {near: top-center}
direction: right
step1: {
  label: "STEP 1\nInput"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  input: |md
    **requested_size**
    User's desired block size
    (any value ≥ 0)
  |
}
step2: {
  label: "STEP 2\nMinimum Size Check"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  check: |md
    
    min_size = sizeof(void*)
    typically 8 bytes (64-bit)
    
  |
  decision: {
    shape: diamond
    label: "requested_size\n< min_size?"
    style.fill: "#FFE0B2"
  }
  branch_yes: "Yes\n(too small)"
  branch_no: "No\n(sufficient)"
  result_min: |md
    
    block_size = min_size
    = sizeof(void*)
    = 8 bytes
    
    *Needed for free list*
    *pointer storage*
  |
  result_pass: |md
    
    block_size = requested_size
    (unchanged)
    
  |
  decision -> branch_yes: "true" {style.stroke: "#4CAF50"}
  decision -> branch_no: "false" {style.stroke: "#F44336"}
  branch_yes -> result_min
  branch_no -> result_pass
}
step3: {
  label: "STEP 3\nAlignment Rounding"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  align_formula: |md
    
    alignment = alignof(max_align_t)
              = 16 bytes (typical)
    block_size = (block_size + alignment - 1)
                 & ~(alignment - 1)
    
  |
  bitop: {
    label: "Bitwise Operation Breakdown"
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    mask: |md
      **Mask Creation:**
      
      ~(alignment - 1)
      = ~(16 - 1)
      = ~0x0F
      = 0xFFFF...F0
      
      Clears low 4 bits
    |
    add: |md
      **Round Up:**
      
      (value + 15) & 0xFFFF...F0
      Example: value = 23
      (23 + 15) = 38 = 0x26
      0x26 & 0xF0 = 0x20 = 32
      
    |
  }
}
step4: {
  label: "STEP 4\nOutput"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  output: |md
    **Final block_size**
    ✓ ≥ sizeof(void*)
    ✓ Multiple of alignment
    ✓ All blocks aligned
  |
  invariants: {
    label: "Guaranteed Invariants"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    inv1: "block_size % alignment == 0"
    inv2: "block_size ≥ sizeof(void*)"
  }
}
step1 -> step2: "validate" {style.stroke: "#2196F3"; style.stroke-width: 2}
step2 -> step3: "round up" {style.stroke: "#9C27B0"; style.stroke-width: 2}
step3 -> step4: "finalize" {style.stroke: "#4CAF50"; style.stroke-width: 2}
examples: {
  label: "Worked Examples"
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  ex1: {
    label: "Example 1: Small Request"
    style.fill: "#FFF8E1"
    calc1: |md
      Input: `requested_size = 5`
      Step 2: 5 < 8 → block_size = 8
      Step 3: (8 + 15) & ~15
              = 23 & 0xF0
              = 16
      **Output: 16 bytes**
    |
  }
  ex2: {
    label: "Example 2: Already Aligned"
    style.fill: "#E3F2FD"
    calc2: |md
      Input: `requested_size = 64`
      Step 2: 64 ≥ 8 → block_size = 64
      Step 3: (64 + 15) & ~15
              = 79 & 0xF0
              = 64
      **Output: 64 bytes**
    |
  }
  ex3: {
    label: "Example 3: Unaligned"
    style.fill: "#FCE4EC"
    calc3: |md
      Input: `requested_size = 100`
      Step 2: 100 ≥ 8 → block_size = 100
      Step 3: (100 + 15) & ~15
              = 115 & 0xF0
              = 112
      **Output: 112 bytes**
    |
  }
  ex1 -> ex2 -> ex3
}
annotation: |md
  **Why This Matters:**
  1. **Free list storage**: Every free block must hold a `void*` pointer (8 bytes)
  2. **CPU alignment**: Misaligned access causes penalties or faults
  3. **Block boundaries**: If base is aligned and block_size is aligned, every block N is aligned
| {
  near: top-right
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  style.stroke-dash: 2
}