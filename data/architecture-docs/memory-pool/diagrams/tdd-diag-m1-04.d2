direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Free List Construction During Initialization
  **Memory Layout & Pointer Threading Specification**
  *Architecture: Fixed-size block allocator | Block: 64B | Word: 8B*
| {near: top-center}

# --- GLOBAL CLASSES ---
classes: {
  block_base: {
    width: 250
    height: 140
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
  raw_block: {
    style: {
      fill: "#DEE2E6"
      stroke: "#ADB5BD"
      stroke-dash: 4
    }
  }
  linked_block: {
    style: {
      fill: "#E2F0D9"
      stroke: "#385723"
      bold: true
      shadow: true
    }
  }
  ptr_field: {
    height: 40
    label: "NEXT_LINK (8B)"
    style: {
      font-size: 11
      bold: true
      font: mono
      border-radius: 2
      fill: "#FFC107"
      stroke: "#7F6000"
    }
  }
  data_field: {
    height: 80
    label: "AVAILABLE USER DATA (56B)\n[ Padding / Uninitialized ]"
    style: {
      font-size: 10
      italic: true
      fill: "#CFE2FF"
      stroke: "#0D6EFD"
      font-color: "#084298"
    }
  }
}

# --- STEP 1: BEFORE STATE ---
before: {
  label: "STEP 1: RAW CONTIGUOUS BUFFER"
  style: {
    fill: "#F8F9FA"
    stroke: "#6C757D"
    stroke-width: 4
    double-border: true
  }
  
  desc: |md
    ### UNINITIALIZED POOL
    **Base Address:** `0x1000`
    **Total Size:** 320 Bytes
    **State:** Raw allocated buffer before threading logic.
  |
  
  memory_region: {
    style: {
      fill: "#F1F3F5"
      stroke: "#ADB5BD"
    }
    
    b0: "BLOCK 0\n[Addr: 0x1000]\nOffset: +0" { class: [block_base; raw_block] }
    b1: "BLOCK 1\n[Addr: 0x1040]\nOffset: +64" { class: [block_base; raw_block] }
    b2: "BLOCK 2\n[Addr: 0x1080]\nOffset: +128" { class: [block_base; raw_block] }
    b3: "BLOCK 3\n[Addr: 0x10C0]\nOffset: +192" { class: [block_base; raw_block] }
    b4: "BLOCK 4\n[Addr: 0x1100]\nOffset: +256" { class: [block_base; raw_block] }
    
    grid: |md
      | Block | Start | End |
      | :--- | :--- | :--- |
      | 0 | 0x1000 | 0x103F |
      | 1 | 0x1040 | 0x107F |
      | 2 | 0x1080 | 0x10BF |
      | 3 | 0x10C0 | 0x10FF |
      | 4 | 0x1100 | 0x113F |
    | {
      style.font-size: 11
      style.fill: "#FFF3CD"
    }
  }
}

# --- TRANSITION LOGIC ---
transition: {
  width: 200
  loop_visual: {
    shape: circle
    label: "THREADING\nPROCESS"
    width: 120
    height: 120
    style: {
      fill: "#0D6EFD"
      stroke: "#0B5ED7"
      font-color: "white"
      bold: true
      shadow: true
    }
  }
  
  logic_annotation: |md
    **Algorithm:**
    1. `ptr = base`
    2. `for i in 0..N-1:`
    3. &nbsp;&nbsp;`*ptr = (ptr + 64)`
    4. &nbsp;&nbsp;`ptr += 64`
    5. `*ptr = NULL`
  | {
    style.font-size: 12
  }
}

# --- STEP 2: AFTER STATE ---
after: {
  label: "STEP 2: THREADED FREE LIST (READY)"
  style: {
    fill: "#F8F9FA"
    stroke: "#198754"
    stroke-width: 4
    double-border: true
  }
  
  desc: |md
    ### INITIALIZED STATE
    Each block's leading 8-bytes now contains the
    memory address of the subsequent block.
  |
  
  head_ptr: "POOL_HEAD\nValue: 0x1000" {
    style: {
      fill: "#0D6EFD"
      font-color: "white"
      stroke: "#0B5ED7"
      bold: true
      stroke-width: 3
    }
    width: 200
    height: 80
  }
  
  region: {
    style: {
      fill: "#D1E7DD"
      stroke: "#198754"
    }
    
    blk0: {
      label: "BLOCK 0 (0x1000)"
      class: [block_base; linked_block]
      next: "LINK -> 0x1040" { class: ptr_field }
      data: { class: data_field }
    }
    
    blk1: {
      label: "BLOCK 1 (0x1040)"
      class: [block_base; linked_block]
      next: "LINK -> 0x1080" { class: ptr_field }
      data: { class: data_field }
    }
    
    blk2: {
      label: "BLOCK 2 (0x1080)"
      class: [block_base; linked_block]
      next: "LINK -> 0x10C0" { class: ptr_field }
      data: { class: data_field }
    }
    
    blk3: {
      label: "BLOCK 3 (0x10C0)"
      class: [block_base; linked_block]
      next: "LINK -> 0x1100" { class: ptr_field }
      data: { class: data_field }
    }
    
    blk4: {
      label: "BLOCK 4 (0x1100)"
      class: [block_base; linked_block]
      next: "LINK -> 0x0 (NULL)" { 
        class: ptr_field
        style: {
          fill: "#DC3545"
          font-color: "white"
          stroke: "#842029"
        }
      }
      data: { class: data_field }
    }
  }
}

# --- CONNECTIONS ---

# Macro Flow
before -> after: "INIT_POOL()" {
  style: {
    stroke: "#0D6EFD"
    stroke-width: 8
    stroke-dash: 5
    animated: true
  }
}

# Pointer Links
after.head_ptr -> after.region.blk0: "ENTRY" {
  style: {
    stroke: "#0D6EFD"
    stroke-width: 4
  }
  target-arrowhead: triangle
}

# Threading logic visualization (linking fields to blocks)
after.region.blk0.next -> after.region.blk1: "Next Address" {
  style: { stroke: "#FFC107"; stroke-width: 3; animated: true }
  target-arrowhead: triangle
}
after.region.blk1.next -> after.region.blk2: "Next Address" {
  style: { stroke: "#FFC107"; stroke-width: 3; animated: true }
  target-arrowhead: triangle
}
after.region.blk2.next -> after.region.blk3: "Next Address" {
  style: { stroke: "#FFC107"; stroke-width: 3; animated: true }
  target-arrowhead: triangle
}
after.region.blk3.next -> after.region.blk4: "Next Address" {
  style: { stroke: "#FFC107"; stroke-width: 3; animated: true }
  target-arrowhead: triangle
}

# Footer Code Implementation
impl: |md
  c
  /* Technical Reference: Free List Init */
  typedef struct Block {
      struct Block* next;     // Offset 0 (8 bytes)
      uint8_t data[56];       // Offset 8 (56 bytes)
  } Block;

  void pool_init(void* mem, size_t n) {
      Block* pool = (Block*)mem;
      for (size_t i = 0; i < n - 1; ++i) {
          pool[i].next = &pool[i + 1]; // Set link to contiguous next
      }
      pool[n - 1].next = NULL;         // Terminal sentinel
  }
  
| {
  near: bottom-center
  style: {
    fill: "#212529"
    font-color: "#F8F9FA"
    border-radius: 8
    font: mono
  }
}