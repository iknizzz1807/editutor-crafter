vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # pool_alloc Operation Sequence
  O(1) Block Allocation from Free List
| {near: top-center}
sequence: {
  shape: sequence_diagram
  Caller: "Caller\n(Application)"
  Pool: "MemoryPool\nstruct"
  FreeList: "Free List\n(Intrusive)"
  Block0: "Block 0\n(0x1000)"
  Block1: "Block 1\n(0x1040)"
  step1_check: {
    label: "Step 1: NULL Check"
    Caller -> Pool: "pool_alloc(pool)"
    Pool -> Pool: "if (free_list_head == NULL)\n  return NULL"
  }
  step2_read_head: {
    label: "Step 2: Read Head"
    Pool -> FreeList: "Read free_list_head"
    FreeList -> Pool: "0x1000 (Block 0)"
  }
  step3_read_next: {
    label: "Step 3: Read Next Pointer"
    Pool -> Block0: "Read *(void**)0x1000"
    Block0 -> Pool: "0x1040 (next free block)"
  }
  step4_update_head: {
    label: "Step 4: Update Head"
    Pool -> Pool: "free_list_head = 0x1040"
    Pool -> Pool: "allocated++"
  }
  step5_bitmap: {
    label: "Step 5: Mark Allocated"
    Pool -> Pool: "index = get_block_index(0x1000)\nbitmap_set(allocated_map, index)"
  }
  step6_return: {
    label: "Step 6: Return Block"
    Pool -> Caller: "return 0x1000"
  }
}
before_state: {
  label: "BEFORE: Free List State"
  header_row: {
    shape: text
    label: "**MemoryPool State**"
  }
  pool_before: {
    shape: class
    label: ""
    free_list_head: "void* 0x1000"
    allocated: "size_t 3"
    capacity: "size_t 8"
  }
  free_list_before: {
    label: "Free List (Linked)"
    blk0_free: {
      label: "Block 0\n0x1000\n[FREE]"
      shape: rectangle
      style.fill: "#90EE90"
    }
    blk1_free: {
      label: "Block 1\n0x1040\n[FREE]"
      shape: rectangle
      style.fill: "#90EE90"
    }
    blk2_used: {
      label: "Block 2\n0x1080\n[USED]"
      shape: rectangle
      style.fill: "#FFB6C1"
    }
    blk3_free: {
      label: "Block 3\n0x10C0\n[FREE]"
      shape: rectangle
      style.fill: "#90EE90"
    }
    blk0_free -> blk1_free: "next: 0x1040"
    blk1_free -> blk3_free: "next: 0x10C0"
    blk3_free -> null_term: "next: NULL"
    head_ptr: {
      label: "free_list_head →"
      shape: text
    }
    head_ptr -> blk0_free
  }
  bitmap_before: {
    label: "Bitmap (1=allocated, 0=free)"
    bmp_header: {
      shape: text
      label: "| Block | 0 | 1 | 2 | 3 | 4 | 5 | 6 | 7 |"
    }
    bmp_bits: {
      shape: text
      label: "| State | 0 | 0 | **1** | 0 | **1** | **1** | 0 | 0 |"
    }
  }
}
after_state: {
  label: "AFTER: Free List State"
  pool_after: {
    shape: class
    label: ""
    free_list_head: "void* 0x1040"
    allocated: "size_t 4"
    capacity: "size_t 8"
  }
  free_list_after: {
    label: "Free List (Linked)"
    blk0_used_after: {
      label: "Block 0\n0x1000\n**[ALLOCATED]**"
      shape: rectangle
      style.fill: "#FFB6C1"
      style.bold: true
      style.stroke: red
    }
    blk1_free_after: {
      label: "Block 1\n0x1040\n[FREE]"
      shape: rectangle
      style.fill: "#90EE90"
    }
    blk2_used_after: {
      label: "Block 2\n0x1080\n[USED]"
      shape: rectangle
      style.fill: "#FFB6C1"
    }
    blk3_free_after: {
      label: "Block 3\n0x10C0\n[FREE]"
      shape: rectangle
      style.fill: "#90EE90"
    }
    blk1_free_after -> blk3_free_after: "next: 0x10C0"
    blk3_free_after -> null_term_after: "next: NULL"
    head_ptr_after: {
      label: "free_list_head →"
      shape: text
    }
    head_ptr_after -> blk1_free_after
    returned_ptr: {
      label: "RETURNED →"
      shape: text
      style.font-color: red
      style.bold: true
    }
    returned_ptr -> blk0_used_after
  }
  bitmap_after: {
    label: "Bitmap (Block 0 now allocated)"
    bmp_header_a: {
      shape: text
      label: "| Block | 0 | 1 | 2 | 3 | 4 | 5 | 6 | 7 |"
    }
    bmp_bits_a: {
      shape: text
      label: "| State | **1** | 0 | 1 | 0 | 1 | 1 | 0 | 0 |"
    }
    changed_bit: {
      label: "↑ Changed"
      shape: text
      style.font-color: red
      style.bold: true
    }
  }
}
memory_ops: {
  label: "Memory Operations Count"
  ops: {
    shape: class
    "1. Load free_list_head": "1 cache line (L1 likely)"
    "2. Load *free_list_head": "1 cache line (block data)"
    "3. Store free_list_head": "1 write"
    "4. Increment allocated": "1 write"
    "5. Bitmap set": "1 read-modify-write"
  }
  total: {
    label: "**Total: ~5 memory operations**\n~8-15 nanoseconds typical"
    shape: text
  }
}
classes: {
  free_block: {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  used_block: {
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
  }
  changed: {
    style.bold: true
    style.stroke: red
    style.stroke-width: 3
  }
}
before_state -> after_state: "pool_alloc()\nreturns 0x1000" {
  style.stroke: "#4169E1"
  style.stroke-width: 3
  style.bold: true
}