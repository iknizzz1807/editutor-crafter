    w2_b191: "b191" {style.fill: "#F3E5F5"; style.font: mono; style.font-size: 12}
    w2_dots: "В·В·В·" {style.fill: "#FFFFFF"; style.font: mono; style.font-size: 12}
    w2_b129: "b129" {style.fill: "#F3E5F5"; style.font: mono; style.font-size: 12}
    w2_b128: "b128" {style.fill: "#F3E5F5"; style.font: mono; style.font-size: 12}
    w2_unused: "(unused)" {
