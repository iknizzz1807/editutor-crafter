layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Bitmap for Block State
**Array of `uint64_t` words вҖ” 1 bit per block**
'|
title.near: top-center

direction: right

index_calc: {
  shape: text
  style: {
    font: mono
    font-size: 18
    fill: "#F5F5F5"
    stroke: "#666666"
    stroke-width: 2
    border-radius: 8
  }
  content: |'md
**Index Calculation:**
c
word_index = block_index / 64;
bit_index  = block_index % 64;

// Example: block 75
word_index = 75 / 64 = 1
bit_index  = 75 % 64 = 11


**Operations:**
c
// Set bit (mark allocated)
map[word] |= (1ULL << bit);

// Clear bit (mark free)
map[word] &= ~(1ULL << bit);

// Test bit (check state)
return (map[word] & (1ULL << bit)) != 0;

'|
}

bitmap_array: {
  style.fill: "#FAFAFA"
  style.stroke: "#333333"
  style.stroke-width: 2
  
  header: "allocated_map (uint64_t array)" {
    style.fill: "#E8E8E8"
    style.stroke: "#333333"
    style.font: mono
    style.bold: true
  }

  word0: {
    grid-columns: 8
    grid-gap: 2
    w0_label: "[0]" {
      style.fill: "#D5E8D4"
      style.stroke: "#82B366"
      style.font: mono
      style.bold: true
      width: 40
    }
    w0_b63: "b63" {style.fill: "#E1F5FE"; style.font: mono; style.font-size: 12}
    w0_b62: "b62" {style.fill: "#E1F5FE"; style.font: mono; style.font-size: 12}
    w0_dots: "В·В·В·" {style.fill: "#FFFFFF"; style.font: mono; style.font-size: 12}
