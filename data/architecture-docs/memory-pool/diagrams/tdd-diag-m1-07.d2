legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#666666"
  style.stroke-width: 1
  style.border-radius: 8

  legend_title: "Legend" {
    style.fill: "#E0E0E0"
    style.bold: true
  }

  row1: {
    grid-columns: 4
    grid-gap: 8
    leg1: "0 = FREE" {style.fill: "#E1F5FE"; style.stroke: "#4FC3F7"}
    leg2: "1 = ALLOC'D" {style.fill: "#FFF3E0"; style.stroke: "#FFB74D"}
    leg3: "SELECTED" {
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
      style.stroke-width: 2
      style.bold: true
    }
    leg4: "UNUSED" {
      style.fill: "#EEEEEE"
      style.stroke-dash: 3
    }
  }
}

mapping_table: {
  style.fill: "#FAFAFA"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.border-radius: 8
  
  map_title: "Block Index вҶ’ Bitmap Location" {
    style.fill: "#E8E8E8"
    style.stroke: "#333333"
    style.font: mono
    style.bold: true
  }

  map_content: |'md
| Block Index | Word Index | Bit Index | Word Bit Position |
|:-----------:|:----------:|:---------:|:-----------------:|
| 0           | 0          | 0         | word[0] & (1<<0)  |
| 1           | 0          | 1         | word[0] & (1<<1)  |
| 63          | 0          | 63        | word[0] & (1<<63) |
| **64**      | **1**      | **0**     | word[1] & (1<<0)  |
| 65          | 1          | 1         | word[1] & (1<<1)  |
| **75**      | **1**      | **11**    | word[1] & (1<<11) |
| 127         | 1          | 63        | word[1] & (1<<63) |
| 128         | 2          | 0         | word[2] & (1<<0)  |
'|
  map_content.shape: text
}

memory_layout_view: {
  style.fill: "#FAFAFA"
  style.stroke: "#333333"
  style.stroke-width: 2

  mem_title: "Memory Visual Representation" {
    style.fill: "#E8E8E8"
    style.stroke: "#333333"
    style.font: mono
    style.bold: true
  }

  mem_content: |'md
**allocated_map[0]:**
в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ b63 в”Ӯ b62 в”Ӯ b61 в”Ӯ    ...    в”Ӯ b2  в”Ӯ b1  в”Ӯ b0  в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Ө
в”ӮBlk63в”ӮBlk62в”ӮBlk61в”Ӯ    ...    в”ӮBlk2 в”ӮBlk1 в”ӮBlk0 в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ
  *1 = allocated (Orange), 0 = free (Blue)*

**allocated_map[1]:**
в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯb127 в”Ӯ    ...    в”Ӯb75вҳ… в”Ӯ    ...    в”Ӯb65  в”Ӯb64  в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Ө
в”ӮBlk127в”Ӯ   ...    в”ӮBlk75в”Ӯ    ...    в”ӮBlk65в”ӮBlk64в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ
          в–І
          в”Ӯ **Block 75** is at word[1], bit 11
'|
  mem_content.shape: text
}

