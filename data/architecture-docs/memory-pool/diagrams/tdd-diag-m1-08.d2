vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Block Index Calculation
  ## `get_block_index(pool, ptr)` → Global Index
| {near: top-center}
direction: right
inputs: {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  pool_label: "Input: MemoryPool* pool" {
    shape: text
    style.font: mono
  }
  ptr_label: "Input: void* ptr" {
    shape: text
    style.font: mono
  }
}
step1: {
  label: "Step 1: Cast to Byte Pointers"
  style.fill: "#B5D8F7"
  code1: |c
    const char* base = (const char*)pool->base;
    const char* block = (const char*)ptr;
  | {
    shape: text
    style.font: mono
    style.font-size: 14
  }
  note1: "Use char* for byte-level arithmetic" {
    shape: text
    style.font-color: "#666666"
    style.italic: true
  }
}
step2: {
  label: "Step 2: Bounds Check (Lower)"
  style.fill: "#B5D8F7"
  code2: |c
    if (block < base) return -1;
  | {
    shape: text
    style.font: mono
    style.font-size: 14
  }
  note2: "Pointer before pool → Invalid" {
    shape: text
    style.font-color: "#666666"
    style.italic: true
  }
}
step3: {
  label: "Step 3: Calculate Offset"
  style.fill: "#FFE4B5"
  code3: |c
    size_t offset = (size_t)(block - base);
  | {
    shape: text
    style.font: mono
    style.font-size: 14
  }
  note3: "Bytes from pool start to pointer" {
    shape: text
    style.font-color: "#666666"
    style.italic: true
  }
}
step4: {
  label: "Step 4: Bounds Check (Upper)"
  style.fill: "#B5D8F7"
  code4: |c
    size_t total_size = pool->block_size * pool->capacity;
    if (offset >= total_size) return -1;
  | {
    shape: text
    style.font: mono
    style.font-size: 14
  }
  note4: "Pointer after pool end → Invalid" {
    shape: text
    style.font-color: "#666666"
    style.italic: true
  }
}
step5: {
  label: "Step 5: Alignment Verification"
  style.fill: "#FFB5B5"
  code5: |c
    if (offset % pool->block_size != 0) return -1;
  | {
    shape: text
    style.font: mono
    style.font-size: 14
  }
  note5: "Mid-block pointer → Misaligned (Invalid)" {
    shape: text
    style.font-color: "#666666"
    style.italic: true
  }
}
step6: {
  label: "Step 6: Compute Index"
  style.fill: "#B5F7B5"
  code6: |c
    return (ssize_t)(offset / pool->block_size);
  | {
    shape: text
    style.font: mono
    style.font-size: 14
  }
  note6: "Global block index [0..capacity-1]" {
    shape: text
    style.font-color: "#666666"
    style.italic: true
  }
}
outputs: {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  success: "Return: index ≥ 0" {
    shape: text
    style.font: mono
    style.fill: "#B5F7B5"
  }
  error: "Return: -1 (invalid)" {
    shape: text
    style.font: mono
    style.fill: "#FFB5B5"
  }
}
inputs -> step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> outputs
example: {
  label: "Example Calculation"
  style.fill: "#F5F5F5"
  style.stroke: "#999999"
  ex_title: "Given:" {
    shape: text
    style.bold: true
  }
  ex_input: |md
    - `pool->base` = 0x1000
    - `pool->block_size` = 64 (0x40)
    - `pool->capacity` = 100
    - `ptr` = 0x1140
  | {
    shape: text
    style.font: mono
  }
  ex_calc: |md
    **Calculation:**
    1. `offset` = 0x1140 - 0x1000 = 0x140 = **320 bytes**
    2. `320 < 6400` ✓ (within bounds)
    3. `320 % 64` = 0 ✓ (aligned)
    4. `index` = 320 / 64 = **5**
  | {
    shape: text
    style.font: mono
  }
  ex_result: "Result: Block index = 5" {
    shape: text
    style.bold: true
    style.font-color: "#006600"
  }
}
memory_visual: {
  label: "Memory Layout Visualization"
  style.fill: "#F0F0F0"
  style.stroke: "#999999"
  mem_base: {
    label: "0x1000"
    shape: text
    style.font: mono
    style.font-size: 12
  }
  block0: {
    label: "Block 0\n[0x1000-0x103F]"
    shape: rectangle
    width: 100
    style.fill: "#DDDDDD"
  }
  block1: {
    label: "Block 1\n[0x1040-0x107F]"
    shape: rectangle
    width: 100
    style.fill: "#DDDDDD"
  }
  dots: {
    label: "..."
    shape: text
  }
  block5: {
    label: "Block 5\n[0x1140-0x117F]\n← ptr"
    shape: rectangle
    width: 100
    style.fill: "#FFE4B5"
    style.stroke: "#FF8C00"
    style.stroke-width: 2
  }
  dots2: {
    label: "..."
    shape: text
  }
  block99: {
    label: "Block 99\n[0x2F80-0x2FBF]"
    shape: rectangle
    width: 100
    style.fill: "#DDDDDD"
  }
  mem_end: {
    label: "0x2FC0"
    shape: text
    style.font: mono
    style.font-size: 12
  }
}
error_cases: {
  label: "Error Cases (Return -1)"
  style.fill: "#FFF0F0"
  style.stroke: "#CC0000"
  err1: {
    label: "Before Pool\nptr < base"
    shape: rectangle
    style.fill: "#FFB5B5"
  }
  err2: {
    label: "After Pool\nptr >= base + total_size"
    shape: rectangle
    style.fill: "#FFB5B5"
  }
  err3: {
    label: "Misaligned\noffset % block_size != 0"
    shape: rectangle
    style.fill: "#FFB5B5"
  }
  err1 -> err2 -> err3
}