vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cache Line Analysis: pool_alloc() Operation
  Shows memory access pattern during single allocation
| {near: top-center}
direction: right
step1: {
  label: "Step 1: Read pool->free_list_head"
  pool_struct: {
    grid-columns: 4
    grid-gap: 0
    h_chunks: "chunks"
    h_block_size: "block_size"
    h_bpc: "blocks_per_chunk"
    h_cap: "total_capacity"
    v1: "0x00"
    v2: "0x08"
    v3: "0x10"
    v4: "0x18"
    chunks_val: "0x5000"
    bs_val: "64"
    bpc_val: "100"
    cap_val: "100"
    h_allocated: "allocated"
    h_free: "free_list_head"
    h_map: "allocated_map"
    h_ms: "map_size"
    v5: "0x20"
    v6: "0x28"
    v7: "0x30"
    v8: "0x38"
    alloc_val: "42"
    free_val: "0x5A80"
    map_val: "0x6000"
    ms_val: "2"
    h_maxc: "max_chunks"
    h_maxb: "max_bytes"
    h_cc: "chunk_count"
    h_pad: "(padding)"
    v9: "0x40"
    v10: "0x48"
    v11: "0x50"
    v12: "0x58"
    maxc_val: "0"
    maxb_val: "0"
    cc_val: "1"
    pad_val: "-"
    *.style.fill: "#E8E8E8"
    *.style.stroke: "#666666"
    *.style.font-size: 14
  }
  cache_line_0: {
    label: "Cache Line 0\n(0x00-0x3F)"
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 3
    style.stroke-dash: 0
  }
  cache_line_1: {
    label: "Cache Line 1\n(0x40-0x7F)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 3
  }
  pool_struct.cache_line_0 -> pool_struct.h_free: {
    style.stroke: "#FF5722"
    style.stroke-width: 4
    style.animated: true
  }
}
step2: {
  label: "Step 2: Read next pointer from block"
  block_memory: {
    grid-columns: 8
    grid-gap: 0
    b0: "[0-7]\nnext"
    b8: "[8-15]"
    b16: "[16-23]"
    b24: "[24-31]"
    b32: "[32-39]"
    b40: "[40-47]"
    b48: "[48-55]"
    b56: "[56-63]"
    b0_val: "0x5AC0"
    b8_val: "user"
    b16_val: "user"
    b24_val: "user"
    b32_val: "user"
    b40_val: "user"
    b48_val: "user"
    b56_val: "user"
    b0.style.fill: "#FFCDD2"
    b0.style.stroke: "#D32F2F"
    b0.style.stroke-width: 3
    b0.style.font: mono
    b0.style.bold: true
    b*.style.fill: "#ECEFF1"
    b*.style.stroke: "#90A4AE"
    b*.style.font-size: 12
  }
  block_addr: {
    label: "Block at 0x5A80\n(free_list_head)"
    shape: text
    style.font-size: 16
    style.bold: true
  }
  cache_line_block: {
    label: "Single Cache Line\n(64 bytes)"
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 3
  }
  block_memory.cache_line_block -> block_memory.b0: {
    style.stroke: "#FF5722"
    style.stroke-width: 4
    style.animated: true
  }
}
step3: {
  label: "Step 3: Update pool state"
  pool_after: {
    grid-columns: 4
    grid-gap: 0
    h2_allocated: "allocated"
    h2_free: "free_list_head"
    h2_map: "allocated_map"
    h2_ms: "map_size"
    v2_5: "0x20"
    v2_6: "0x28"
    v2_7: "0x30"
    v2_8: "0x38"
    alloc2_val: "43"
    free2_val: "0x5AC0"
    map2_val: "0x6000"
    ms2_val: "2"
    h2_allocated.style.fill: "#FFCDD2"
    h2_allocated.style.stroke: "#D32F2F"
    h2_allocated.style.stroke-width: 3
    h2_allocated.style.bold: true
    h2_free.style.fill: "#FFCDD2"
    h2_free.style.stroke: "#D32F2F"
    h2_free.style.stroke-width: 3
    h2_free.style.bold: true
    *.style.font-size: 14
  }
  changed: {
    label: "CHANGED\n(written)"
    shape: text
    style.font-color: "#D32F2F"
    style.bold: true
    style.font-size: 16
  }
}
step1 -> step2: "Dereference\nfree_list_head" {
  style.stroke: "#1976D2"
  style.stroke-width: 3
  style.animated: true
}
step2 -> step3: "Write back\nnew head" {
  style.stroke: "#388E3C"
  style.stroke-width: 3
  style.animated: true
}
legend: {
  near: bottom-center
  l1: {
    label: "Read access"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    style.stroke-width: 3
  }
  l2: {
    label: "Write access"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 3
  }
  l3: {
    label: "Cache line boundary (64B)"
    shape: rectangle
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 3
  }
}
analysis: |md
  ## Cache Behavior Summary
  **Total cache lines touched: 2-3**
  1. **Pool structure** — Likely L1 hot (frequently accessed)
     - Cache Line 0: fields 0x00-0x3F (read)
     - Cache Line 1: fields 0x40-0x7F (read/write)
  2. **Free block** — May be L2/L3 if not recently accessed
     - Single cache line (first 8 bytes for next pointer)
  **L1 hit scenario**: ~2-3 cycles
  **L1 miss, L2 hit**: ~10-15 cycles
  **Full miss to memory**: ~100-300 cycles
  **Prefetch opportunity**: Sequential allocation through
  free list benefits from hardware prefetcher.
| {near: bottom-right}