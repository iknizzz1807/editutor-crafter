layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# --------------------------------------------------------------------------------------------
# GLOBAL STYLES & CLASSES
# --------------------------------------------------------------------------------------------
classes: {
  state: {
    shape: rectangle
    style: {
      fill: "#E8F4F8"
      stroke: "#2E86AB"
      stroke-width: 2
      border-radius: 8
    }
  }
  exhausted: {
    shape: rectangle
    style: {
      fill: "#FF6B6B"
      stroke: "#C92A2A"
      stroke-width: 4
      font-color: white
      bold: true
      shadow: true
    }
  }
  error: {
    shape: diamond
    style: {
      fill: "#FFE066"
      stroke: "#F59F00"
      stroke-width: 2
    }
  }
  terminal: {
    shape: circle
    style: {
      fill: "#4ECDC4"
      stroke: "#087F5B"
      stroke-width: 2
    }
  }
  transition_label: {
    style: {
      font-size: 12
      font: mono
    }
  }
}

# --------------------------------------------------------------------------------------------
# HEADER SECTION
# --------------------------------------------------------------------------------------------
title: {
  shape: text
  label: |md
    # Pool Exhaustion State Machine
    ### Critical Path: `free_list_head == NULL` OR `allocated == capacity`
  |
  near: top-center
}

# --------------------------------------------------------------------------------------------
# STATE DEFINITIONS
# --------------------------------------------------------------------------------------------
direction: right

initial: "●" {
  class: terminal
  tooltip: "Pool Entry Point: Memory mapping established, free list initialized."
}

has_free_blocks: {
  label: "Has Free Blocks\n(Empty/Ready)"
  class: state
  tooltip: |md
    **Invariant:**
    - `free_list_head != NULL`
    - `allocated == 0`
    - Pointer points to index 0.
  |
}

partial_use: {
  label: "Partial Allocation"
  class: state
  tooltip: |md
    **Invariant:**
    - `free_list_head != NULL`
    - `0 < allocated < capacity`
  |
}

exhausted_state: {
  label: "POOL EXHAUSTED\n(Capacity Reached)"
  class: exhausted
  tooltip: |md
    **Invariant:**
    - `free_list_head == NULL`
    - `allocated == capacity`
    - Next allocation attempt triggers safety fault.
  |
}

alloc_failed: {
  label: "Allocation Failed\n(Return NULL)"
  class: error
  style: {
    font-color: "#C92A2A"
    bold: true
  }
}

# --------------------------------------------------------------------------------------------
# TRANSITION LOGIC
# --------------------------------------------------------------------------------------------
initial -> has_free_blocks: "pool_init()" {
  style.stroke: "#087F5B"
}

has_free_blocks -> partial_use: "pool_alloc()\n[success]"

partial_use -> partial_use: "pool_alloc()\n[allocated < cap-1]" {
  style.stroke-dash: 3
}

partial_use -> exhausted_state: "pool_alloc()\n[last block taken]" {
  style: {
    stroke: "#C92A2A"
    stroke-width: 4
  }
}

exhausted_state -> alloc_failed: "pool_alloc()\n[guard: head == NULL]" {
  style: {
    stroke: "#C92A2A"
    stroke-width: 2
    animated: true
  }
}

exhausted_state -> partial_use: "pool_free()\n[head restored]" {
  style: {
    stroke: "#087F5B"
    stroke-width: 3
  }
}

partial_use -> has_free_blocks: "pool_free()\n[allocated == 1]"

alloc_failed -> exhausted_state: "Retry / Failover" {
  style.stroke-dash: 5
}

# --------------------------------------------------------------------------------------------
# VISUAL PANELS (Memory & Algorithm)
# --------------------------------------------------------------------------------------------
panels: {
  memory_state: {
    label: "Physical Memory Layout (Exhausted State)"
    style: {
      fill: "#F8F9FA"
      stroke: "#DEE2E6"
      stroke-dash: 3
    }

    grid-columns: 3
    grid-gap: 10

    b0: "B0: USED" { style.fill: "#FF6B6B"; style.font-color: white }
    b1: "B1: USED" { style.fill: "#FF6B6B"; style.font-color: white }
    b2: "B2: USED" { style.fill: "#FF6B6B"; style.font-color: white }
    b3: "B3: USED" { style.fill: "#FF6B6B"; style.font-color: white }
    b4: "B4: USED" { style.fill: "#FF6B6B"; style.font-color: white }
    b5: "B5: USED" { style.fill: "#FF6B6B"; style.font-color: white }
    
    footer: {
      shape: text
      label: "Free List Head: [ NULL ]"
      style.font-color: red
      style.bold: true
    }
  }

  algorithm: {
    label: "Safety Guard Implementation"
    style: {
      fill: "#FFF3BF"
      stroke: "#F59F00"
    }
    implementation: |go
      func pool_alloc(pool *MemoryPool) void* {
          // GUARD: Check exhaustion before pointer math
          if pool.free_list_head == nil {
              return nil  // STATE: alloc_failed
          }
          // Normal Path
          block := pool.free_list_head
          pool.free_list_head = block.next
          pool.allocated++
          return block
      }
    |
  }
}

# Positioning panels relative to states
panels.memory_state.near: exhausted_state
panels.algorithm.near: bottom-center

# --------------------------------------------------------------------------------------------
# LEGEND
# --------------------------------------------------------------------------------------------
legend: {
  near: bottom-right
  style: {
    fill: white
    stroke: "#ADB5BD"
    border-radius: 4
  }
  
  l1: "● Start" {
    style: {
      fill: "#4ECDC4"
      stroke: "#087F5B"
      border-radius: 999
    }
  }
  l2: "Healthy" {
    style: {
      fill: "#E8F4F8"
      stroke: "#2E86AB"
    }
  }
  l3: "Critical / Full" {
    style: {
      fill: "#FF6B6B"
      stroke: "#C92A2A"
      font-color: white
    }
  }
  l4: "◇ Fault State" {
    shape: diamond
    style: {
      fill: "#FFE066"
      stroke: "#F59F00"
    }
  }
}