vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Invalid Pointer Detection
  **pool_free() Validation Steps**
| {near: top-center}
direction: right
step1: Step 1: Bounds Check {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  check1: |md
    **Lower Bound Test**
    
    if (ptr < base)
      → INVALID (before pool)
    
  |
  check2: |md
    **Upper Bound Test**
    
    if (ptr >= base + capacity × block_size)
      → INVALID (after pool)
    
  |
  check1 -> check2: {style.stroke: "#2196F3"}
}
step2: Step 2: Alignment Check {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  align_check: |md
    **Block Boundary Test**
    
    offset = ptr - base
    if (offset % block_size != 0)
      → INVALID (mid-block pointer)
    
  |
}
step3: Step 3: Return Result {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  valid: |md
    **VALID**
    
    return block_index
    = offset / block_size
    
  | {style.fill: "#C8E6C9"}
  invalid: |md
    **INVALID**
    
    return -1
    (error indicator)
    
  | {style.fill: "#FFCDD2"}
  valid - invalid: {style.stroke: "#BDBDBD"; style.stroke-dash: 2}
}
step1 -> step2: Bounds OK? {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
step2 -> step3.valid: Aligned? {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
step2 -> step3.invalid: Misaligned {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 4
}
step1 -> step3.invalid: Out of Bounds {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 4
}
memory_layout: Memory Layout Example {
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  base_addr: |md
    **base = 0x1000**
    **block_size = 64 (0x40)**
    **capacity = 4**
  | {style.fill: "#E1BEE7"}
  block0: Block 0\n0x1000-0x103F {style.fill: "#BBDEFB"}
  block1: Block 1\n0x1040-0x107F {style.fill: "#BBDEFB"}
  block2: Block 2\n0x1080-0x10BF {style.fill: "#BBDEFB"}
  block3: Block 3\n0x10C0-0x10FF {style.fill: "#BBDEFB"}
  after_pool: (invalid)\n0x1100+ {style.fill: "#FFCDD2"}
  block0 -> block1 -> block2 -> block3 -> after_pool
}
examples: Test Cases {
  grid-columns: 2
  style.fill: "#FAFAFA"
  ptr_0x1000: ptr = 0x1000 {style.fill: "#C8E6C9"}
  result_0x1000: ✓ VALID (block 0) {style.fill: "#C8E6C9"}
  ptr_0x1040: ptr = 0x1040 {style.fill: "#C8E6C9"}
  result_0x1040: ✓ VALID (block 1) {style.fill: "#C8E6C9"}
  ptr_0x1020: ptr = 0x1020 {style.fill: "#FFCDD2"}
  result_0x1020: ✗ MISALIGNED\n(offset=32, 32%64≠0) {style.fill: "#FFCDD2"}
  ptr_0x0FF0: ptr = 0x0FF0 {style.fill: "#FFCDD2"}
  result_0x0FF0: ✗ BEFORE POOL\n(ptr < base) {style.fill: "#FFCDD2"}
  ptr_0x1100: ptr = 0x1100 {style.fill: "#FFCDD2"}
  result_0x1100: ✗ AFTER POOL\n(ptr ≥ base+4×64) {style.fill: "#FFCDD2"}
  ptr_stack: ptr = &stack_var {style.fill: "#FFCDD2"}
  result_stack: ✗ OUT OF BOUNDS\n(not in pool memory) {style.fill: "#FFCDD2"}
}
step3 -> memory_layout: {style.opacity: 0}
memory_layout -> examples: {style.opacity: 0}
legend: |md
  
  ssize_t find_block_index(pool, ptr) {
    const char* base = (const char*)pool->base;
    const char* block = (const char*)ptr;
    // Step 1: Bounds check
    if (block < base) return -1;
    size_t offset = (size_t)(block - base);
    size_t total_size = pool->block_size * pool->capacity;
    if (offset >= total_size) return -1;
    // Step 2: Alignment check  
    if (offset % pool->block_size != 0) return -1;
    // Step 3: Return valid index
    return (ssize_t)(offset / pool->block_size);
  }
  
| {near: bottom-center}