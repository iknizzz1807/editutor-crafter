vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Alignment at Base and Block Boundaries
  **Why aligned base alone is insufficient**
| {near: top-center}
direction: right
correct: {
  label: "CORRECT\nAligned Base + Aligned Block Size"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  correct_base: "Base: 0x1000\n(16-byte aligned)" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.font: mono
    style.stroke: "#2E7D32"
  }
  correct_blocks: {
    grid-columns: 3
    grid-gap: 0
    cb0: "Block 0\n0x1000" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      width: 80
    }
    cb1: "Block 1\n0x1040" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      width: 80
    }
    cb2: "Block 2\n0x1080" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      width: 80
    }
  }
  correct_note: |md
    
    block_size = 64 (16×4)
    Block 0: 0x1000 ✓
    Block 1: 0x1040 ✓
    Block 2: 0x1080 ✓
    ALL blocks aligned!
    
  | {
    style.fill: transparent
  }
  correct_base -> correct_blocks: "64-byte blocks"
}
wrong: {
  label: "WRONG\nAligned Base + Wrong Block Size"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  wrong_base: "Base: 0x1000\n(16-byte aligned)" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.font: mono
    style.stroke: "#C62828"
  }
  wrong_blocks: {
    grid-columns: 3
    grid-gap: 0
    wb0: "Block 0\n0x1000" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      width: 80
    }
    wb1: "Block 1\n0x1018" {
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.bold: true
      style.font-color: "#C62828"
      width: 80
    }
    wb2: "Block 2\n0x1030" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      width: 80
    }
  }
  wrong_note: |md
    
    block_size = 24 (NOT 16 multiple)
    Block 0: 0x1000 ✓
    Block 1: 0x1018 ✗
      0x1018 % 16 = 8
      MISALIGNED!
    Block 2: 0x1030 ✓
    
  | {
    style.fill: transparent
  }
  wrong_base -> wrong_blocks: "24-byte blocks"
}
divider: "" {
  shape: rectangle
  width: 2
  style.fill: "#9E9E9E"
  style.stroke: "#9E9E9E"
}
correct -- divider -- wrong: {
  style.stroke: transparent
}
key_insight: |md
  ## The Rule
  **Both conditions must hold:**
  1. Base address aligned to `max_align_t`
  2. Block size is a multiple of `max_align_t`
  If either fails, some blocks will be misaligned.
  
  aligned_size = (size + alignment - 1) & ~(alignment - 1)
  
  This rounds size UP to the next alignment boundary.
| {
  near: bottom-center
  style.fill: "#FFF8E1"
  style.stroke: "#F9A825"
  style.border-radius: 8
}
alignment_grid: {
  label: "16-Byte Alignment Grid Reference"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  grid: {
    grid-columns: 8
    grid-gap: 0
    g0: "0x00" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
    g1: "0x10" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
    g2: "0x20" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
    g3: "0x30" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
    g4: "0x40" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
    g5: "0x50" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
    g6: "0x60" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
    g7: "0x70" {style.fill: "#E3F2FD"; style.font: mono; style.font-size: 10; width: 40}
  }
  grid_note: "Each column represents a 16-byte aligned boundary\nOnly addresses at column starts are properly aligned" {
    style.fill: transparent
    style.font-size: 11
  }
}