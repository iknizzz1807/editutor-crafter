vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Pointer Arithmetic with `char*`
  Byte-level vs. Scaled Arithmetic in C Memory Management
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

direction: right

section_types: "Types & Their Arithmetic Scaling" {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2

  type_table: {
    shape: sql_table
    Type: type {constraint: primary_key}
    "Size (x64)": size
    "ptr + 1 Increment": offset

    char: "1 byte" {constraint: unique}
    "1 byte": "+1 byte"

    int: "4 bytes" {constraint: unique}
    "4 bytes": "+4 bytes"

    void: "N/A" {constraint: unique}
    "N/A": "ERROR (Standard C)*"

    "char*": "8 bytes" {constraint: unique}
    "8 bytes": "byte-level (+1)"
  }

  note_types: |md
    * **void*** arithmetic is a GNU extension (not standard C).
    In standard C, you must cast to **char*** for byte-level math.
  | {
    shape: text
    style.font-size: 14
  }
}

section_char: "char* Arithmetic (Byte-Level)" {
  style.fill: "#E8F8E8"
  style.stroke: "#4CAF50"
  style.stroke-width: 2

  char_example: |c
    char* base = (char*)0x1000;
    char* p1 = base + 0;    // 0x1000
    char* p2 = base + 1;    // 0x1001
    char* p3 = base + 64;   // 0x1040
  |

  char_visual: {
    grid-columns: 4
    grid-gap: 0

    c0: "0x1000" {
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    c1: "0x1001" {
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    c2: "0x1002" {
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    c3: "..." {
      style.fill: "#E8F5E9"
      style.stroke: "#81C784"
    }

    label0: "base" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#2E7D32"
      style.bold: true
    }
    label1: "base + 1" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#2E7D32"
    }
    label2: "base + 2" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#2E7D32"
    }
    label3: "" {
      style.fill: transparent
      style.stroke: transparent
    }
  }

  note_char: |md
    **Result:** Each `+1` advances by **exactly 1 byte**.
    This is the fundamental unit for arbitrary memory offsets.
  | {shape: text}
}

section_int: "int* Arithmetic (Scaled)" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2

  int_example: |c
    int* base = (int*)0x1000;
    int* p1 = base + 0;    // 0x1000
    int* p2 = base + 1;    // 0x1004 (+4!)
    int* p3 = base + 16;   // 0x1040 (+64)
  |

  int_visual: {
    grid-columns: 4
    grid-gap: 0

    i0: "0x1000 — 0x1003" {
      style.fill: "#FFE0B2"
      style.stroke: "#FF9800"
    }
    i1: "0x1004 — 0x1007" {
      style.fill: "#FFE0B2"
      style.stroke: "#FF9800"
    }
    i2: "0x1008 — 0x100B" {
      style.fill: "#FFE0B2"
      style.stroke: "#FF9800"
    }
    i3: "..." {
      style.fill: "#FFF8E1"
      style.stroke: "#FFB74D"
    }

    label0: "base" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#E65100"
      style.bold: true
    }
    label1: "base + 1" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#E65100"
    }
    label2: "base + 2" {
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#E65100"
    }
    label3: "" {
      style.fill: transparent
      style.stroke: transparent
    }
  }

  note_int: |md
    **Result:** Each `+1` advances by **sizeof(int) = 4 bytes**.
    The compiler automatically scales offsets by element size.
  | {shape: text}
}

section_pool: "Real-World Pattern: Memory Pools" {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2

  pool_code: |c
    // Block iteration using char* for byte-level control
    char* current = (char*)pool->base;
    for (size_t i = 0; i < num_blocks; i++) {
        void** block_ptr = (void**)current;
        *block_ptr = current + block_size;  // Store next block offset
        current += block_size;               // Jump by byte count
    }
  |

  pool_visual: {
    direction: right
    base: "pool->base\n0x1000" {
      shape: rectangle
      style.fill: "#E1BEE7"
      style.stroke: "#9C27B0"
    }
    block1: "Block 0\n0x1000 - 0x103F" {
      shape: rectangle
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
      style.multiple: true
    }
    block2: "Block 1\n0x1040 - 0x107F" {
      shape: rectangle
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
      style.multiple: true
    }
    block3: "Block 2\n0x1080 - 0x10BF" {
      shape: rectangle
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
      style.multiple: true
    }

    base -> block1: "char* + 0" {style.stroke: "#9C27B0"}
    block1 -> block2: "char* + 64" {style.stroke: "#9C27B0"; style.bold: true}
    block2 -> block3: "char* + 64" {style.stroke: "#9C27B0"; style.bold: true}
  }
}

section_formula: "The General Formula" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 2

  formula_box: {
    style: {
      fill: "#FFCDD2"
      stroke: "#E53935"
      stroke-width: 3
    }
    
    # Using block string with backticks |`md ... `| to handle table pipes
    formula: |`md
      ## Pointer Arithmetic Rule
      
      `ptr + n`  ≡  `(uintptr_t)ptr + (n * sizeof(*ptr))`
      
      | Pointer Type | sizeof(*ptr) | `ptr + 1` adds |
      | :----------- | :----------- | :------------- |
      | `char*`      | 1            | 1 byte         |
      | `short*`     | 2            | 2 bytes        |
      | `int*`       | 4            | 4 bytes        |
      | `long*`      | 8            | 8 bytes        |
      | `void**`     | 8            | 8 bytes        |
    `| {shape: text}
  }

  why_matters: |md
    ### Why This Matters for Allocators
    1. **Byte-level control:** Pools use arbitrary block sizes (e.g., 64 bytes). Only `char*` ensures `+64` is exactly 64 bytes.
    2. **Alignment safety:** Arithmetic via `char*` allows manual enforcement of alignment boundaries (8, 16, 64-byte).
    3. **Universal Access:** Casting to `char*` is the standard C idiom for examining the raw representation of any object.
  | {shape: text}
}

section_comparison: "Side-by-Side Comparison" {
  style.fill: "#E0F2F1"
  style.stroke: "#009688"
  style.stroke-width: 2

  comparison: {
    grid-columns: 2
    grid-gap: 20

    char_side: {
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      header: "char* base = 0x1000;" {
        style.fill: "#C8E6C9"
        style.bold: true
      }
      r0: "base + 0  → 0x1000" {style.stroke: transparent}
      r1: "base + 1  → 0x1001" {style.stroke: transparent}
      r2: "base + 64 → 0x1040" {style.stroke: transparent}
      footer: "✓ Predictable byte offsets" {
        style.fill: "#A5D6A7"
        style.font-color: "#1B5E20"
        style.bold: true
      }
    }

    int_side: {
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      header: "int* base = 0x1000;" {
        style.fill: "#FFE0B2"
        style.bold: true
      }
      r0: "base + 0  → 0x1000" {style.stroke: transparent}
      r1: "base + 1  → 0x1004" {style.stroke: transparent}
      r2: "base + 16 → 0x1040" {style.stroke: transparent}
      footer: "⚠ Scaled by sizeof(int)=4" {
        style.fill: "#FFCC80"
        style.font-color: "#E65100"
        style.bold: true
      }
    }
  }
}

section_casting: "Pattern: Explicit Casting" {
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  style.stroke-width: 2

  cast_example: |c
    // Common pattern in intrusive data structures
    void* block = get_raw_block();

    // 1. Math: Get byte-offset for next pointer
    char* offset_ptr = (char*)block + sizeof(void*);

    // 2. Access: Treat that offset as a place to store a pointer
    void** store_location = (void**)offset_ptr;
    *store_location = next_free_block;
  |

  note_cast: |md
    ### The Two Essential Casts
    1. **`(char*)ptr`**: "I want to perform math in byte units."
    2. **`(T**)ptr`**: "I want to read/write a pointer-sized value at this address."
  | {shape: text}
}

footer: |md
  **Key Concept:** In C/C++, pointer arithmetic is **always relative to the size of the type pointed to**.
  `char*` is used as the "Universal Byte Pointer" because `sizeof(char)` is guaranteed to be 1.
| {
  near: bottom-center
  shape: text
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font-size: 14
    italic: true
  }
}