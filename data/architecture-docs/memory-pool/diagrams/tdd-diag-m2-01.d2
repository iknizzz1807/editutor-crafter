vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # MemoryPool Structure Layout
  *Intel Manual Quality Specification - Memory Alignment & Thread Safety*
| {near: top-center}

direction: right

# --- MemoryPool Main Controller (128 bytes) ---
# Aligned to 64B cache line boundary
MemoryPool: {
  label: "MemoryPool Structure (sizeof=128B)\nPrimary Thread-Safe Controller"
  style: {
    fill: "#E8D5E8" # Header: Purple
    stroke: "#7B3F7B"
    stroke-width: 2
    shadow: true
  }
  
  fields: {
    grid-columns: 1
    grid-gap: 0
    style.fill: "#F5E6F5"

    f00: "chunks (Chunk*)\n+0x00 | size: 8B | [64-bit Ptr]" {
      style.fill: "#FFE4B5" # Pointer: Orange
      style.stroke: "#CC8800"
    }
    f08: "block_size (size_t)\n+0x08 | size: 8B | [Immutable]" {
      style.fill: "#B5D5FF" # Data: Blue
      style.stroke: "#0066CC"
    }
    f10: "blocks_per_chunk (size_t)\n+0x10 | size: 8B | [Immutable]" {
      style.fill: "#B5D5FF"
      style.stroke: "#0066CC"
    }
    f18: "total_capacity (size_t)\n+0x18 | size: 8B" {
      style.fill: "#B5FFB5" # Meta: Green
      style.stroke: "#008800"
    }
    f20: "allocated (size_t)\n+0x20 | size: 8B | 🔒 ATOMIC/MUTEX" {
      style.fill: "#FFB5B5" # Critical: Red
      style.stroke: "#CC0000"
    }
    f28: "free_list_head (void*)\n+0x28 | size: 8B | 🔒 MUTEX PROTECTED" {
      style.fill: "#FFE4B5" # Pointer: Orange
      style.stroke: "#CC8800"
      style.bold: true
    }
    f30: "allocated_map (uint64_t*)\n+0x30 | size: 8B | [Heap Ptr]" {
      style.fill: "#FFE4B5" 
      style.stroke: "#CC8800"
    }
    f38: "map_size (size_t)\n+0x38 | size: 8B" {
      style.fill: "#B5FFB5"
      style.stroke: "#008800"
    }
    f40: "max_chunks (size_t)\n+0x40 | size: 8B | [Limit]" {
      style.fill: "#D5D5D5" # Padding/Static: Gray
      style.stroke: "#666666"
    }
    f48: "max_bytes (size_t)\n+0x48 | size: 8B" {
      style.fill: "#D5D5D5"
      style.stroke: "#666666"
    }
    f50: "chunk_count (size_t)\n+0x50 | size: 8B | 🔒 MUTEX" {
      style.fill: "#FFB5B5"
      style.stroke: "#CC0000"
    }
    f58: "pthread_mutex_t (OS-Specific)\n+0x58 | size: 40B | 🔒 PRIMARY LOCK OBJECT" {
      style.fill: "#FF6B6B"
      style.stroke: "#990000"
      style.stroke-width: 3
    }
  }
}

# --- Chunk Metadata Structure (24 bytes) ---
Chunk: {
  label: "Chunk Metadata (sizeof=24B)\nSingly Linked List Node"
  style: {
    fill: "#D4EDDA"
    stroke: "#155724"
    stroke-width: 2
  }
  cfields: {
    grid-columns: 1
    grid-gap: 0
    style.fill: "#E8F5E8"
    cmem: "memory (void*)\n+0x00 | size: 8B | [Storage Ptr]" {
      style.fill: "#FFE4B5" 
      style.stroke: "#CC8800"
    }
    cnum: "num_blocks (size_t)\n+0x08 | size: 8B" {
      style.fill: "#B5FFB5"
      style.stroke: "#008800"
    }
    cnext: "next (Chunk*)\n+0x10 | size: 8B | [Link Ptr]" {
      style.fill: "#FFE4B5"
      style.stroke: "#CC8800"
    }
  }
}

# --- Block Storage Region (64B Aligned) ---
BlockStorage: {
  label: "Block Storage Region\n(Aligned via aligned_alloc)"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-dash: 3
  }
  blocks: {
    grid-columns: 4
    grid-gap: 4
    b0: "Block 0\n[STATUS: FREE]" {
      style.fill: "#C8E6C9" # Free: Green
      style.stroke: "#2E7D32"
    }
    b1: "Block 1\n[STATUS: ALLOC'D]" {
      style.fill: "#FFCDD2" # Alloc: Red
      style.stroke: "#C62828"
    }
    b2: "Block 2\n[STATUS: FREE]" {
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
    b3: "Block N\n[DATA TAIL]" {
      style.fill: "#E0E0E0"
      style.stroke: "#757575"
    }
  }
}

# --- Allocation Bitmap (Bit-indexed) ---
Bitmap: {
  label: "allocated_map (Memory Bitmap)\n64-bit Packed Word Access"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
  }
  words: {
    grid-columns: 2
    grid-gap: 8
    w0: "word[0]\nBits 00..63" {
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
    }
    w1: "word[1]\nBits 64..127" {
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
    }
  }
}

# Fix: Use constant 'near' values for ELK engine compatibility
BitmapLegend: |md
  **Bitmap Index Specification:**
  - `Bit 1`: Block is Allocated (Busy)
  - `Bit 0`: Block is Available (Idle)
  - Word size = `sizeof(uint64_t)`
| {
  near: bottom-left
}

# --- Reference Trace (Pointers & Ownership) ---

# Pool Free Head to first storage slot
MemoryPool.fields.f28 -> BlockStorage.blocks.b0: "head → first free" {
  style.stroke: "#CC8800"
  style.stroke-width: 2
}

# Pool Bitmap ptr to actual bitmap data
MemoryPool.fields.f30 -> Bitmap.words.w0: "bitmap_ptr" {
  style.stroke: "#E65100"
  style.stroke-dash: 4
}

# Registry head to metadata node
MemoryPool.fields.f00 -> Chunk.cfields: "chunks_head" {
  style.stroke: "#155724"
  style.stroke-width: 2
}

# Metadata owns the allocated block segment
Chunk.cfields.cmem -> BlockStorage: "owns region" {
  style.stroke: "#1565C0"
  source-arrowhead: * {
    shape: diamond
    style.filled: true
  }
}

# Singly Linked List Reference
Chunk.cfields.cnext -> Chunk: "next_node" {
  style.stroke: "#CC8800"
  style.stroke-dash: 5
}

# --- Implementation Annotation ---
annotation: |md
  ### Pool Implementation Notes:
  1. **Memory Alignment**: Main controller is 128B (2 cache lines). Mutex is placed at the end to prevent false sharing with frequently accessed counters.
  2. **Atomic Invariants**: `allocated` count must be updated atomically or under the pool mutex to remain consistent with the bitmap state.
  3. **Registry**: Chunks are stored in a linked list for easy expansion; however, `allocated_map` is a contiguous array for cache-friendly bit-scanning.
  4. **Bitmap Search**: Implementation uses `__builtin_ctzl` for hardware-accelerated free block discovery.
| {
  near: top-right
}

# --- Global Legend ---
legend_container: {
  label: "Component Legend"
  near: bottom-center
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.stroke-width: 1
  
  l1: "🔒 Mutex Protected" {
    style.fill: "#FFB5B5"
  }
  l2: "Immutable / Configuration" {
    style.fill: "#D5D5D5"
  }
  l3: "Pointer / Offset Address" {
    style.fill: "#FFE4B5"
  }
  l4: "Free Memory Block" {
    style.fill: "#C8E6C9"
  }
}