vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Chunk Registry Linked List
  Non-contiguous memory regions tracked via singly-linked list
| {near: top-center}
direction: right
classes: {
  pointer: {
    shape: circle
    width: 40
    height: 40
    style: {
      fill: "#FFA500"
      stroke: "#CC8400"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  chunk: {
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 2
    }
  }
  memory: {
    shape: rectangle
    style: {
      fill: "#4A90D9"
      stroke: "#2E5A8C"
      stroke-width: 2
      font-color: white
      stroke-dash: 0
    }
  }
  null: {
    shape: circle
    width: 50
    height: 50
    style: {
      fill: "#333333"
      stroke: "#111111"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
}
pool: MemoryPool {
  chunks_head: Head {
    class: pointer
  }
  style: {
    fill: "#F5F5F5"
    stroke: "#999999"
    stroke-width: 3
    border-radius: 8
  }
}
chunk0: Chunk 0 {
  class: chunk
  meta: |md
    c
    struct Chunk {
      void*  memory;     // 0x1000
      size_t num_blocks; // 100
      Chunk* next;       // → Chunk 1
    }
    
|
  mem0: Memory Region {
    class: memory
    label: |md
      **0x1000 - 0x28FF**
      100 blocks × 64 bytes
      (6,400 bytes total)
    |
    width: 180
  }
}
chunk1: Chunk 1 {
  class: chunk
  meta: |md
    c
    struct Chunk {
      void*  memory;     // 0x5000
      size_t num_blocks; // 100
      Chunk* next;       // → Chunk 2
    }
    
|
  mem1: Memory Region {
    class: memory
    label: |md
      **0x5000 - 0x68FF**
      100 blocks × 64 bytes
      (6,400 bytes total)
    |
    width: 180
  }
}
chunk2: Chunk 2 {
  class: chunk
  meta: |md
    c
    struct Chunk {
      void*  memory;     // 0xA000
      size_t num_blocks; // 100
      Chunk* next;       // → NULL
    }
    
|
  mem2: Memory Region {
    class: memory
    label: |md
      **0xA000 - 0xB8FF**
      100 blocks × 64 bytes
      (6,400 bytes total)
    |
    width: 180
  }
}
null_term: NULL {
  class: null
}
gap0: |md
  **Address Gap**
  0x2900 - 0x4FFF
  (10 KB unused)
| {
  shape: text
  style: {
    font-color: "#888888"
    italic: true
  }
}
gap1: |md
  **Address Gap**
  0x6900 - 0x9FFF
  (14 KB unused)
| {
  shape: text
  style: {
    font-color: "#888888"
    italic: true
  }
}
# Registry links (metadata pointers)
pool.chunks_head -> chunk0: "chunks" {
  style: {
    stroke: "#CC8400"
    stroke-width: 3
    bold: true
  }
  target-arrowhead: {
    shape: arrow
  }
}
chunk0 -> chunk1: "next" {
  style: {
    stroke: "#CC8400"
    stroke-width: 3
    bold: true
  }
  target-arrowhead: {
    shape: arrow
  }
}
chunk1 -> chunk2: "next" {
  style: {
    stroke: "#CC8400"
    stroke-width: 3
    bold: true
  }
  target-arrowhead: {
    shape: arrow
  }
}
chunk2 -> null_term: "next" {
  style: {
    stroke: "#CC8400"
    stroke-width: 3
    bold: true
  }
  target-arrowhead: {
    shape: arrow
  }
}
# Chunk-to-memory ownership
chunk0 -> chunk0.mem0: "memory" {
  style: {
    stroke: "#2E5A8C"
    stroke-width: 2
    stroke-dash: 3
  }
  source-arrowhead: {
    shape: diamond
    style.filled: true
  }
}
chunk1 -> chunk1.mem1: "memory" {
  style: {
    stroke: "#2E5A8C"
    stroke-width: 2
    stroke-dash: 3
  }
  source-arrowhead: {
    shape: diamond
    style.filled: true
  }
}
chunk2 -> chunk2.mem2: "memory" {
  style: {
    stroke: "#2E5A8C"
    stroke-width: 2
    stroke-dash: 3
  }
  source-arrowhead: {
    shape: diamond
    style.filled: true
  }
}
# Gap annotations
chunk0.mem0 -> gap0 {
  style: {
    stroke: "#CCCCCC"
    stroke-width: 1
    stroke-dash: 5
    opacity: 0.5
  }
}
gap0 -> chunk1.mem1 {
  style: {
    stroke: "#CCCCCC"
    stroke-width: 1
    stroke-dash: 5
    opacity: 0.5
  }
}
chunk1.mem1 -> gap1 {
  style: {
    stroke: "#CCCCCC"
    stroke-width: 1
    stroke-dash: 5
    opacity: 0.5
  }
}
gap1 -> chunk2.mem2 {
  style: {
    stroke: "#CCCCCC"
    stroke-width: 1
    stroke-dash: 5
    opacity: 0.5
  }
}
legend: {
  near: bottom-center
  legend_title: Legend {
    shape: text
    style: {
      bold: true
      font-size: 20
    }
  }
  solid_line: "Solid orange → Chunk list linkage (next pointers)" {
    shape: text
  }
  dashed_line: "Dashed blue → Chunk owns memory region" {
    shape: text
  }
  gap_note: "Gray gaps = Non-contiguous virtual address space" {
    shape: text
  }
  key_insight: |md
    **Key Insight:** Chunks are allocated separately from their block storage.
    User writes cannot corrupt chunk metadata. Each `malloc(sizeof(Chunk))` 
    creates metadata; each `aligned_alloc()` creates block storage.
  | {
    shape: text
    style: {
      font-color: "#333333"
      italic: true
    }
  }
  style: {
    fill: "#FAFAFA"
    stroke: "#DDDDDD"
    border-radius: 8
  }
}