vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # grow_pool() Decision Tree
  Growth algorithm with limit enforcement and rollback on failure
| {near: top-center}
direction: down
start: ● START {
  shape: circle
  style.fill: "#4CAF50"
  style.stroke: "#2E7D32"
}
check_chunks: "max_chunks > 0 &&\nchunk_count >= max_chunks?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
fail_limit_chunks: RETURN false\nPOOL_ERROR_CHUNK_LIMIT {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
check_bytes: "max_bytes > 0 &&\n(current_bytes + new_chunk_bytes)\n> max_bytes?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
fail_limit_bytes: RETURN false\nPOOL_ERROR_BYTE_LIMIT {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
alloc_chunk_meta: "chunk = malloc(sizeof(Chunk))" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
check_chunk_meta: "chunk == NULL?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
fail_chunk_meta: RETURN false\nPOOL_ERROR_CHUNK_ALLOC {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
alloc_block_storage: "memory = aligned_alloc(\n  alignof(max_align_t),\n  new_chunk_bytes)" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
check_block_storage: "memory == NULL?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
rollback_1: "free(chunk)" {
  style.fill: "#FCE4EC"
  style.stroke: "#AD1457"
  style.stroke-dash: 3
}
fail_block_storage: RETURN false\nPOOL_ERROR_MEMORY_ALLOC {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
init_chunk: "chunk->memory = memory\nchunk->num_blocks = blocks_per_chunk\nchunk->next = chunks\nchunks = chunk" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
expand_bitmap: "new_map = realloc(\n  allocated_map,\n  new_map_size * sizeof(uint64_t))" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
check_bitmap: "new_map == NULL?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
rollback_2: "chunks = chunk->next\nfree(memory)\nfree(chunk)" {
  style.fill: "#FCE4EC"
  style.stroke: "#AD1457"
  style.stroke-dash: 3
}
fail_bitmap: RETURN false\nPOOL_ERROR_BITMAP_EXPAND {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
zero_bitmap: "FOR i = map_size TO new_map_size-1:\n  new_map[i] = 0" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
update_pool: "allocated_map = new_map\nmap_size = new_map_size\ntotal_capacity = new_capacity\nchunk_count++" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
thread_blocks: "block = memory\nFOR i = 0 TO blocks_per_chunk-1:\n  *(void**)block = free_list_head\n  free_list_head = block\n  block += block_size" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
success: RETURN true {
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.font-color: "#1B5E20"
  style.bold: true
}
start -> check_chunks
check_chunks -> fail_limit_chunks: YES
check_chunks -> check_bytes: NO
check_bytes -> fail_limit_bytes: YES
check_bytes -> alloc_chunk_meta: NO
alloc_chunk_meta -> check_chunk_meta
check_chunk_meta -> fail_chunk_meta: YES
check_chunk_meta -> alloc_block_storage: NO
alloc_block_storage -> check_block_storage
check_block_storage -> rollback_1: YES
rollback_1 -> fail_block_storage
check_block_storage -> init_chunk: NO
init_chunk -> expand_bitmap
expand_bitmap -> check_bitmap
check_bitmap -> rollback_2: YES
rollback_2 -> fail_bitmap
check_bitmap -> zero_bitmap: NO
zero_bitmap -> update_pool
update_pool -> thread_blocks
thread_blocks -> success
legend: |md
  ## Legend
  - **Green boxes**: State modifications (success path)
  - **Blue boxes**: Memory allocations
  - **Yellow diamonds**: Decision points
  - **Red boxes**: Failure returns
  - **Pink dashed boxes**: Rollback cleanup
  ### Error Codes
  - `POOL_ERROR_CHUNK_LIMIT`: max_chunks reached
  - `POOL_ERROR_BYTE_LIMIT`: max_bytes would be exceeded
  - `POOL_ERROR_CHUNK_ALLOC`: malloc(Chunk) failed
  - `POOL_ERROR_MEMORY_ALLOC`: aligned_alloc() failed
  - `POOL_ERROR_BITMAP_EXPAND`: realloc() failed
  ### Pre-condition
  Caller MUST hold `pool->mutex`
| {
  near: bottom-left
}