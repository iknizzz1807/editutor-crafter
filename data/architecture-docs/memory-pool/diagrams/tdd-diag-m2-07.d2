vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Block Index Search Across Chunks
  **find_block_index() Algorithm — O(chunk_count)**
| {near: top-center}
direction: right
step_1: {
  label: "STEP 1\nInitialize Search"
  vars: |md
    c
    const char* target = (const char*)ptr;
    size_t blocks_before = 0;
    
  |
  init_state: {
    label: "Initial State"
    shape: rectangle
    style.fill: "#E8F4FD"
    fields: |md
      **target** = `0x5100` (ptr to find)  
      **blocks_before** = `0`  
      **current_chunk** = `pool->chunks`
    |
  }
}
step_2: {
  label: "STEP 2\nIterate Chunk List"
  loop: {
    shape: diamond
    label: "More chunks?"
    style.fill: "#FFF9E6"
  }
  loop_yes: "YES → Check bounds"
  loop_no: "NO → Return -1 (not found)"
}
step_3: {
  label: "STEP 3\nBounds Check Current Chunk"
  calc: |md
    c
    chunk_start = (const char*)chunk->memory;
    chunk_end = chunk_start + 
                (chunk->num_blocks * pool->block_size);
    if (target >= chunk_start && target < chunk_end)
      → FOUND! Proceed to STEP 4
    else
      → Update blocks_before += chunk->num_blocks
      → Advance: chunk = chunk->next
      → Loop to STEP 2
    
  |
  chunk_layout: {
    label: "Chunk Memory Layout"
    chunk_0: {
      label: "Chunk 0"
      shape: rectangle
      style.fill: "#C8E6C9"
      mem_0: |md
        `memory`: `0x1000`  
        `num_blocks`: `100`  
        Range: `[0x1000, 0x5000)`
      |
    }
    chunk_1: {
      label: "Chunk 1"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
      style.stroke-width: 3
      mem_1: |md
        `memory`: `0x5000`  
        `num_blocks`: `100`  
        Range: `[0x5000, 0x9000)`  
        **← TARGET FOUND HERE!**
      |
    }
    chunk_2: {
      label: "Chunk 2"
      shape: rectangle
      style.fill: "#C8E6C9"
      mem_2: |md
        `memory`: `0x9000`  
        `num_blocks`: `100`  
        Range: `[0x9000, 0xD000)`
      |
    }
    null_term: {
      label: "NULL"
      shape: circle
      style.fill: "#BDBDBD"
    }
    chunk_0 -> chunk_1 -> chunk_2 -> null_term
  }
}
step_4: {
  label: "STEP 4\nCalculate Local Index"
  local_calc: |md
    c
    // Within found chunk:
    offset = target - chunk_start;
    // Alignment check
    if (offset % pool->block_size != 0)
      return -1;  // Misaligned pointer!
    // Local index within this chunk
    local_index = offset / pool->block_size;
    
  |
  example: {
    label: "Example Calculation"
    shape: rectangle
    style.fill: "#E1F5FE"
    style.stroke: "#0288D1"
    style.stroke-width: 2
    calc_example: |md
      **target** = `0x5100`  
      **chunk_start** = `0x5000` (Chunk 1)  
      **block_size** = `64` bytes  
      `offset` = `0x5100 - 0x5000` = `0x100` = `256`  
      `256 % 64` = `0` ✓ (aligned)  
      `local_index` = `256 / 64` = `4`
    |
  }
}
step_5: {
  label: "STEP 5\nCompute Global Index"
  global_calc: |md
    c
    // Global index = blocks from previous chunks
    //              + local index within current chunk
    return blocks_before + local_index;
    
  |
  result_box: {
    label: "FINAL RESULT"
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: white
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    style.bold: true
    result: |md
      **global_index** = `blocks_before` + `local_index`  
      **global_index** = `100` + `4` = **`104`**  
      Block 104 is in Chunk 1, local position 4
    |
  }
}
iteration_trace: {
  label: "Iteration Trace (target = 0x5100)"
  trace: {
    shape: sequence_diagram
    iter1: "Iteration 1\nChunk 0: [0x1000, 0x5000)\n0x5100 >= 0x1000? YES\n0x5100 < 0x5000? NO\nblocks_before = 100"
    iter2: "Iteration 2\nChunk 1: [0x5000, 0x9000)\n0x5100 >= 0x5000? YES\n0x5100 < 0x9000? YES\nFOUND!"
    calc: "Calculate\noffset = 256\nlocal_index = 4\nglobal_index = 104"
    iter1 -> iter2: "Advance to next chunk"
    iter2 -> calc: "Compute index"
  }
}
error_cases: {
  label: "Error Cases (Return -1)"
  case1: {
    label: "Pointer Before Pool"
    shape: rectangle
    style.fill: "#FFEBEE"
    desc1: |md
      `target < chunk_start` for all chunks  
      → Pointer not from this pool
    |
  }
  case2: {
    label: "Pointer After Pool"
    shape: rectangle
    style.fill: "#FFEBEE"
    desc2: |md
      `target >= chunk_end` for all chunks  
      → Pointer not from this pool
    |
  }
  case3: {
    label: "Misaligned Pointer"
    shape: rectangle
    style.fill: "#FFEBEE"
    desc3: |md
      `offset % block_size != 0`  
      → Pointer to middle of block, not start
    |
  }
}
complexity: {
  label: "Complexity Analysis"
  time: {
    label: "Time Complexity"
    shape: rectangle
    style.fill: "#F3E5F5"
    time_desc: |md
      **O(chunk_count)** — Linear scan of chunk list  
      Must traverse until found or exhausted.  
      For fixed-size growth:  
      `chunks = total_blocks / blocks_per_chunk`
    |
  }
  space: {
    label: "Space Complexity"
    shape: rectangle
    style.fill: "#F3E5F5"
    space_desc: |md
      **O(1)** — Only local variables  
      - `target` pointer  
      - `blocks_before` counter  
      - Loop iterator
    |
  }
  optimization: {
    label: "Optimization Options"
    shape: rectangle
    style.fill: "#E8F5E9"
    opt_desc: |md
      **For faster frees:**
      1. **Sorted chunk array** — Binary search O(log n)  
      2. **Block header** — Store chunk ID per block  
      3. **Radix tree** — Page-table style lookup
    |
  }
}
# Connections
step_1 -> step_2
step_2 -> step_3: "chunk != NULL"
step_3 -> step_2: "target not in chunk"
step_3 -> step_4: "target in chunk"
step_4 -> step_5