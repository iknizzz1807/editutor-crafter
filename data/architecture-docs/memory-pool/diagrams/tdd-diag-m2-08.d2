vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |'md
# Growth Limit State Machine
States and transitions for pool growth decisions
'| {near: top-center}

# States
CAN_GROW: {
  label: "CAN_GROW"
  shape: circle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 3
  }
}

AT_CHUNK_LIMIT: {
  label: "AT_CHUNK_LIMIT"
  shape: circle
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 3
  }
}

AT_BYTE_LIMIT: {
  label: "AT_BYTE_LIMIT"
  shape: circle
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 3
  }
}

GROW_FAILED: {
  label: "GROW_FAILED"
  shape: circle
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-width: 3
  }
}

POOL_EXHAUSTED: {
  label: "POOL_EXHAUSTED"
  shape: circle
  style: {
    fill: "#FFCDD2"
    stroke: "#B71C1C"
    stroke-width: 3
    font-color: "#B71C1C"
  }
}

# Initial state indicator
initial: "●" {
  shape: circle
  width: 20
  style.fill: "#4CAF50"
}

initial -> CAN_GROW: "pool_init()"

# Transitions from CAN_GROW
CAN_GROW -> CAN_GROW: "alloc succeeds\n(block available)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

CAN_GROW -> CAN_GROW: "grow_pool()\n→ success" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
    stroke-dash: 3
  }
}

CAN_GROW -> AT_CHUNK_LIMIT: "grow_pool()\n→ chunk_count >= max_chunks" {
  style: {
    stroke: "#FF9800"
    stroke-width: 2
  }
}

CAN_GROW -> AT_BYTE_LIMIT: "grow_pool()\n→ bytes + chunk > max_bytes" {
  style: {
    stroke: "#FF9800"
    stroke-width: 2
  }
}

CAN_GROW -> GROW_FAILED: "grow_pool()\n→ malloc/alloc failed" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}

# Transitions from AT_CHUNK_LIMIT
AT_CHUNK_LIMIT -> AT_CHUNK_LIMIT: "alloc succeeds\n(block available)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

AT_CHUNK_LIMIT -> POOL_EXHAUSTED: "free_list_head == NULL\ncannot grow (limit)" {
  style: {
    stroke: "#B71C1C"
    stroke-width: 2
  }
}

# Transitions from AT_BYTE_LIMIT
AT_BYTE_LIMIT -> AT_BYTE_LIMIT: "alloc succeeds\n(block available)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

AT_BYTE_LIMIT -> POOL_EXHAUSTED: "free_list_head == NULL\ncannot grow (limit)" {
  style: {
    stroke: "#B71C1C"
    stroke-width: 2
  }
}

# Transitions from GROW_FAILED
GROW_FAILED -> GROW_FAILED: "alloc succeeds\n(block available)" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

GROW_FAILED -> POOL_EXHAUSTED: "free_list_head == NULL\ncannot grow (OOM)" {
  style: {
    stroke: "#B71C1C"
    stroke-width: 2
  }
}

# Recovery from POOL_EXHAUSTED
POOL_EXHAUSTED -> CAN_GROW: "pool_free()\n→ block returned" {
  style: {
    stroke: "#2196F3"
    stroke-width: 2
    stroke-dash: 5
  }
}

# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  legend_title: "Legend" {
    shape: text
    style.font-size: 16
    style.bold: true
  }
  green_state: "Available for Growth" {
    shape: circle
    width: 30
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  orange_state: "At Limit (Read-Only)" {
    shape: circle
    width: 30
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
  }
  red_state: "Growth Failed / Exhausted" {
    shape: circle
    width: 30
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
    }
  }
  success_trans: "→ Success Path" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  limit_trans: "→ Limit Hit" {
    style: {
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  fail_trans: "→ Failure Path" {
    style: {
      stroke: "#F44336"
      stroke-width: 2
    }
  }
  recovery_trans: "→ Recovery" {
    style: {
      stroke: "#2196F3"
      stroke-width: 2
      stroke-dash: 5
    }
  }
}

# State invariants
invariants: |'md
## State Invariants
**CAN_GROW**: `chunk_count < max_chunks` AND `total_bytes < max_bytes`
**AT_CHUNK_LIMIT**: `chunk_count >= max_chunks` (max_chunks > 0)
**AT_BYTE_LIMIT**: `total_bytes + chunk_size > max_bytes` (max_bytes > 0)
**GROW_FAILED**: `malloc()` or `aligned_alloc()` returned NULL
**POOL_EXHAUSTED**: `free_list_head == NULL` AND cannot grow
'| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    border-radius: 4
    font: mono
    font-size: 12
  }
}

# Transition guards
guards: |'md
## Transition Guards
| From | To | Guard |
|------|-----|-------|
| CAN_GROW | AT_CHUNK_LIMIT | `max_chunks > 0 && chunk_count >= max_chunks` |
| CAN_GROW | AT_BYTE_LIMIT | `max_bytes > 0 && current + new > max_bytes` |
| CAN_GROW | GROW_FAILED | `malloc() == NULL || aligned_alloc() == NULL` |
| AT_*_LIMIT | POOL_EXHAUSTED | `free_list_head == NULL` |
| POOL_EXHAUSTED | CAN_GROW | `pool_free()` called |
'| {
  near: top-right
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    border-radius: 4
    font: mono
    font-size: 11
  }
}