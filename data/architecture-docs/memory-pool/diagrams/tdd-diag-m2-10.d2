vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # PoolStats Structure
  **56 bytes total (7 × 8-byte fields)**
| {near: top-center}
direction: right
PoolStats: "PoolStats struct (56 bytes)" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
  fields: {
    grid-columns: 1
    grid-gap: 0
    f0: "total_blocks" {
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
      width: 300
    }
    f8: "allocated" {
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
      width: 300
    }
    f10: "free" {
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
      width: 300
    }
    f18: "chunk_count" {
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
      width: 300
    }
    f20: "block_size" {
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
      width: 300
    }
    f28: "total_bytes" {
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
      width: 300
    }
    f30: "overhead_bytes" {
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
      width: 300
    }
  }
}
offsets: {
