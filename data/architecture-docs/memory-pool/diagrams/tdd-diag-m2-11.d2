      bold: true
      font-size: 20
    }
  }
}

container: MemoryPool Total Allocation {
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  style.stroke-width: 2

  block_storage: Block Storage (User Data) {
    class: storage
    style.fill: "#E3F2FD"
    chunk0_blocks: |md
      **Chunk 0 Blocks**
      Size: `block_size × num_blocks`
      (e.g., 64B × 100 = 6,400 bytes)
    |
    chunk1_blocks: |md
      **Chunk 1 Blocks**
      Size: `block_size × num_blocks`
      (e.g., 64B × 100 = 6,400 bytes)
    |
    chunkN_blocks: |md
      **Chunk N Blocks**
      Size: `block_size × num_blocks`
      (e.g., 64B × 100 = 6,400 bytes)
    |
  }

  metadata_overhead: Metadata Overhead {
    class: metadata
    style.fill: "#FFF3E0"

    chunk_metadata: Chunk Metadata {
      style.fill: "#FFE0B2"
      chunk0_meta: |md
        **Chunk 0 Structure**
        `sizeof(Chunk) = 24 bytes`
        - [0x00] `void* memory` (8B)
        - [0x08] `size_t num_blocks` (8B)
        - [0x10] `Chunk* next` (8B)
      |
      chunk1_meta: |md
        **Chunk 1**
        Fixed size: 24 bytes
      |
      chunkN_meta: |md
        **Chunk N**
        Fixed size: 24 bytes
      |
    }

    bitmap_storage: Bitmap Storage {
      style.fill: "#C8E6C9"
      bitmap_detail: ||md
        **Allocation State Bitmap**
        Calculated: `map_size × sizeof(uint64_t)`
        
        Density: 1 bit per block
        - `1` = Allocated
        - `0` = Free
        
        `map_size = ceil(capacity / 64)`
        Example (200 blocks):
        `ceil(200/64) = 4 words`
        `4 words × 8 bytes = 32 bytes`
      ||
    }
  }
}

formula_box: |md
  ## Total Overhead Formula
  
  $$TotalBytes = (Chunks \times 24) + (\lceil \frac{Blocks}{64} \rceil \times 8)$$
  
  **Example Calculation (200 blocks, 2 chunks):**
  - chunk_count = 2
  - map_size = 4
  - overhead = (2 × 24) + (4 × 8) = 80 bytes
| {
  class: formula
  near: bottom-center
}

breakdown: Overhead Breakdown {
  grid-columns: 2
  style.fill: "#ECEFF1"
  
  chunk_overhead: |md
    ### Chunk Metadata
    Fixed cost per linked chunk: **24 bytes**
    
    c
    typedef struct Chunk {
      void* memory;       // ptr to start
      size_t num_blocks;  // block count
      struct Chunk* next; // list linkage
    } Chunk;
    
    
    **Total:** `chunk_count × 24`
  | { class: metadata }

  bitmap_overhead: ||md
    ### Bitmap Scalability
    Growth: **1 byte per 8 blocks**

    | Capacity | map_size | Total Bytes |
    |----------|----------|-------------|
    | 100      | 2        | 16 bytes    |
    | 200      | 4        | 32 bytes    |
    | 1000     | 16       | 128 bytes   |
  || { class: bitmap }
}

ratio_example: ||md
  ## Efficiency Analysis
  **Configuration:**
  - Block size: 64 bytes
  - Capacity: 200 blocks (2 chunks)
  
  **Memory Consumption:**
  | Component | Bytes | % |
  |-----------|-------|---|
  | User Data | 12,800| 99.38% |
  | Metadata  | 48    | 0.37% |
  | Bitmap    | 32    | 0.25% |
  | **Total** | **12,880** | **100%** |

  **Verdict:**
  ✅ **Overhead < 1%** (High Efficiency)
|| {
  near: bottom-right
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
}

# Technical Relationships
chunk_metadata -> bitmap_storage: "Combined static\noverhead" {
  style.stroke-dash: 3
  style.stroke: "#7B1FA2"
}

block_storage -> metadata_overhead: "Metadata tracking\nlayer" {
  style.stroke: "#757575"
  style.stroke-dash: 5
}