vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Automatic Growth in pool_alloc()
  **Flow: free_list_head == NULL triggers grow_pool()**
| {near: top-center}
shape: sequence_diagram
Caller
Pool: "MemoryPool"
Grow: "grow_pool()"
FreeList: "free_list_head"
Caller."1. pool_alloc(pool)"
Step1: {
  label: "Step 1: Check free list"
  Pool.t1 -> FreeList.t1: "read free_list_head"
  FreeList.t1 -> Pool.t1: "returns NULL"
  Pool.t1 -> Pool.t1: "free_list_head == NULL?"
  Pool.t1."✗ Pool exhausted"
}
Step2: {
  label: "Step 2: Attempt growth"
  Pool.t2 -> Grow.t2: "call grow_pool(pool)"
  Grow.t2 -> Grow.t2: "Check max_chunks limit"
  Grow.t2 -> Grow.t2: "Check max_bytes limit"
  Grow.t2 -> Grow.t2a: "malloc(Chunk metadata)"
  Grow.t2a -> Grow.t2a: "aligned_alloc(block storage)"
  Grow.t2a -> Grow.t2a: "realloc(bitmap)"
  Grow.t2a -> Grow.t2a: "Thread new blocks to free list"
  Grow.t2a -> Pool.t2: "return true (growth OK)"
  Pool.t2."✓ New chunk added"
}
Step3: {
  label: "Step 3: Pop from free list"
  Pool.t3 -> FreeList.t3: "read free_list_head"
  FreeList.t3 -> Pool.t3: "returns block_ptr"
  Pool.t3 -> Pool.t3: "next = *(void**)block_ptr"
  Pool.t3 -> FreeList.t3: "free_list_head = next"
  Pool.t3 -> Pool.t3: "allocated++"
  Pool.t3 -> Pool.t3: "bitmap_set(index)"
}
Caller.t3 <- Pool.t3: "return block_ptr"
FailurePath: {
  label: "Failure Path (growth failed)"
  Pool.tf -> Grow.tf: "call grow_pool(pool)"
  Grow.tf -> Grow.tf: "Limit exceeded OR OOM"
  Grow.tf -> Pool.tf: "return false"
  Pool.tf."✗ Cannot grow"
  Caller.tf <- Pool.tf: "return NULL"
}
Step1.style.stroke: "#3B82F6"
Step2.style.stroke: "#10B981"
Step3.style.stroke: "#8B5CF6"
FailurePath.style.stroke: "#EF4444"
FailurePath.style.stroke-dash: 3
Pool.style.fill: "#DBEAFE"
Grow.style.fill: "#D1FAE5"
FreeList.style.fill: "#FEF3C7"