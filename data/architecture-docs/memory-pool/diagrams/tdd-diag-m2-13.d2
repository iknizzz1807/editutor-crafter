vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # get_block_by_index: Global Index → Block Pointer
  Reverse lookup logic for leak reporting and diagnostics.
| {
  near: top-center
  style.font-size: 24
}

direction: right

# --------------------------------------------------------------------------------
# CLASSES FOR CONSISTENT STYLING
# --------------------------------------------------------------------------------
classes: {
  logic_step: {
    style: {
      border-radius: 8
      stroke-width: 2
    }
  }
  io_node: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      bold: true
      font-size: 18
    }
  }
  code_block: {
    shape: text
    style: {
      font: mono
      font-size: 14
    }
  }
}

# --------------------------------------------------------------------------------
# MAIN PIPELINE
# --------------------------------------------------------------------------------
Input: {
  class: io_node
  global_index: {
    shape: rectangle
    label: "INPUT:\nglobal_index\n(e.g., 157)"
  }
}

Step1: {
  class: logic_step
  label: "Step 1: Initialize Search"
  style.fill: "#FFF9E6"
  style.stroke: "#D4A574"
  init: |md
    c
    size_t blocks_scanned = 0;
    pool_chunk_t *chunk = pool->chunks;
    
  | {class: code_block}
}

Step2: {
  class: logic_step
  label: "Step 2: Traverse Chunk List"
  style.fill: "#E6F9E6"
  style.stroke: "#4CAF50"
  loop: |md
    c
    while (chunk != NULL) {
      // Current chunk bounds: 
      // [blocks_scanned, blocks_scanned + chunk->num_blocks)
      if (global_index < blocks_scanned + chunk->num_blocks) {
        break; // Found containing chunk
      }
      blocks_scanned += chunk->num_blocks;
      chunk = chunk->next;
    }
    if (!chunk) return NULL; // Out of bounds
    
  | {class: code_block}
}

Step3: {
  class: logic_step
  label: "Step 3: Resolve Local Offset"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  calc: |md
    c
    size_t local_index = global_index - blocks_scanned;
    // Calculation: 157 - 100 = 57
    
  | {class: code_block}
}

Step4: {
  class: logic_step
  label: "Step 4: Pointer Arithmetic"
  style.fill: "#FFE0B2"
  style.stroke: "#FF9800"
  ptr: |md
    c
    void* block = (char*)chunk->memory + 
                 (local_index * pool->block_size);
    // 0x5000 + (57 * 64) = 0x5E40
    
  | {class: code_block}
}

Output: {
  class: io_node
  result: {
    shape: rectangle
    label: "OUTPUT:\nMemory Address\n(e.g., 0x5E40)"
  }
}

# --------------------------------------------------------------------------------
# CONNECTIONS
# --------------------------------------------------------------------------------
Input.global_index -> Step1: "query(157)"
Step1 -> Step2: "init_ptr"
Step2 -> Step3: "chunk_match" {
  style.stroke: green
  style.stroke-width: 3
}
Step3 -> Step4: "offset"
Step4 -> Output.result: "0x5E40"

# --------------------------------------------------------------------------------
# COMPLEMENTARY DETAILS (SIDEBARS)
# --------------------------------------------------------------------------------
Complexity: {
  near: top-right
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  note: |md
    ### Time Complexity: **O(N)**
    Where **N** is the number of chunks.
    Worst case: Traverse entire linked list.
    
    *Implementation Note:* For high-frequency
    lookups, consider a chunk-index lookup table.
  | {shape: text}
}

# USING DOUBLE PIPES TO FIX THE PREVIOUS COMPILER ERROR (Markdown tables contain single pipes)
Example: ||md
  ## Example Walkthrough
  **Pool Configuration:**
  - `block_size` = 64 bytes
  - `Chunk 0`: Base `0x1000`, 100 blocks (Indicies 0-99)
  - `Chunk 1`: Base `0x5000`, 100 blocks (Indicies 100-199)

  **Query:** `get_block_by_index(pool, 157)`

  | Iteration | current_chunk | scanned | Condition: `157 < scanned + size` | Action |
  | :--- | :--- | :--- | :--- | :--- |
  | 1 | Chunk 0 | 0 | `157 < 100` -> **False** | `scanned += 100`, `next` |
  | 2 | Chunk 1 | 100 | `157 < 200` -> **True** | **BREAK** |

  **Math:** `0x5000 + ((157 - 100) * 64) = 0x5E40`
|| {
  near: bottom-center
  style.fill: "#F0F0F0"
}

ChunkVisualization: {
  near: center-right
  label: "Memory Hierarchy Concept"
  style.stroke: "#333333"
  style.stroke-dash: 3

  Chunk0: {
    label: "Chunk 0 (Scanned)"
    style.fill: "#E0E0E0"
    b0: "idx: 0"
    b99: "idx: 99"
  }
  
  Chunk1: {
    label: "Chunk 1 (Target)"
    style.fill: "#FFF9C4"
    b100: "idx: 100"
    b157: "idx: 157\n[Target]" {
      style.fill: "#FF5722"
      style.font-color: white
      style.bold: true
      style.double-border: true
    }
    b199: "idx: 199"
  }

  Chunk0.b99 -> Chunk1.b100: "next_ptr"
}