vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Why `realloc()` Cannot Work for Memory Pools
  ## Existing pointers become invalid when memory moves
| {near: top-center}

direction: right

# BEFORE: Initial allocation with scattered pointers
before: {
  label: "BEFORE: Application has scattered pointers"
  
  pool_region: Pool Region (0x1000) {
    style.fill: "#E8E8E8"
    style.stroke: "#666666"
    
    block0: Block 0 {
      style.fill: "#B8D4E8"
      label: "0x1000\n[ALLOCATED]"
    }
    block1: Block 1 {
      style.fill: "#B8D4E8"
      label: "0x1040\n[ALLOCATED]"
    }
    block2: Block 2 {
      style.fill: "#C8E8C8"
      label: "0x1080\n[FREE]"
    }
    block3: Block 3 {
      style.fill: "#B8D4E8"
      label: "0x10C0\n[ALLOCATED]"
    }
  }

  app_state: Application State {
    style.fill: "#FFF8E8"
    style.stroke: "#CC9900"
    
    struct_a: "struct node {\n  void* data; // = 0x1000\n}"
    cache_entry: "cache->buffer = 0x1040"
    linked_node: "list->item = 0x10C0"
    global_ptr: "global_ptr = 0x1000"
  }

  # References from Pool to App State (showing which pointers track which blocks)
  pool_region.block0 -> app_state.struct_a: "ptr1" {style.stroke: "#4A90D9"}
  pool_region.block1 -> app_state.cache_entry: "ptr2" {style.stroke: "#4A90D9"}
  pool_region.block3 -> app_state.linked_node: "ptr3" {style.stroke: "#4A90D9"}
}

# ARROW: realloc attempt
arrow: {
  label: "realloc(pool, larger_size)\n\nMay move memory\nif no adjacent space!"
  shape: text
  style: {
    font-size: 18
    bold: true
    font-color: "#CC0000"
  }
}

# AFTER: realloc moves memory - DISASTER
after: {
  label: "AFTER: realloc() moved memory → DANGLING POINTERS"
  
  old_region: OLD Region (0x1000) {
    style.fill: "#FFE8E8"
    style.stroke: "#CC0000"
    style.stroke-dash: 3
    
    old_label: |md
      ### FREED / INVALID
      Memory returned to OS
      No longer belongs to Pool
    | {shape: text}
  }

  new_region: NEW Pool Region (0x5000) {
    style.fill: "#E8FFE8"
    style.stroke: "#00AA00"
    
    new_block0: Block 0 {
      style.fill: "#B8D4E8"
      label: "0x5000"
    }
    new_block1: Block 1 {
      style.fill: "#B8D4E8"
      label: "0x5040"
    }
    new_block2: Block 2 {
      style.fill: "#C8E8C8"
      label: "0x5080\n[FREE]"
    }
    new_block3: Block 3 {
      style.fill: "#B8D4E8"
      label: "0x50C0"
    }
    new_block4: Block 4 {
      style.fill: "#C8E8C8"
      label: "0x5100\n[NEW SPACE]"
    }
  }

  dangling_state: Application State {
    style.fill: "#FFE8E8"
    style.stroke: "#CC0000"
    style.font-color: "#CC0000"
    
    dang_struct: "struct node {\n  void* data; // = 0x1000 ⚠️\n}"
    dang_cache: "cache->buffer = 0x1040 ⚠️\nUSE-AFTER-FREE!"
    dang_list: "list->item = 0x10C0 ⚠️\nINVALID!"
    dang_global: "global_ptr = 0x1000 ⚠️\nPOINTS TO DEALLOCATED"
  }

  # Dangling pointer arrows (pointing to the now invalid memory region)
  old_region.old_label -> dangling_state.dang_struct: "ptr1 ⚠️" {
    style: {
      stroke: "#CC0000"
      stroke-dash: 5
      animated: true
    }
  }
  old_region.old_label -> dangling_state.dang_cache: "ptr2 ⚠️" {
    style: {
      stroke: "#CC0000"
      stroke-dash: 5
      animated: true
    }
  }
  old_region.old_label -> dangling_state.dang_list: "ptr3 ⚠️" {
    style: {
      stroke: "#CC0000"
      stroke-dash: 5
      animated: true
    }
  }
}

before -> arrow -> after

# Key insight box
insight: |md
  ## The Fundamental Problem
  `realloc()` is oblivious to the pointers your application holds. 
  
  When it moves memory to find a contiguous larger block:
  1. The OS maps the physical pages to a **new virtual address** (e.g., 0x5000).
  2. The old virtual address (0x1000) is **unmapped or marked free**.
  3. Your variables `struct_a.data`, `cache->buffer`, etc., still contain the **old address values**.
  
  **Result:** High-frequency, unpredictable crashes or silent data corruption.
  **Design Rule:** For memory pools, use **Chunk-Chaining** (Singly Linked Lists of fixed-size blocks) instead of resizing contiguous buffers.
| {
  near: bottom-center
  style: {
    fill: "#FFF8F0"
    stroke: "#CC6600"
    stroke-width: 2
    border-radius: 8
  }
}

# Legend
legend: {
  near: top-right
  style.fill: "#F8F8F8"
  legend_title: "Memory Legend"
  
  alloc: Allocated Block {
    style.fill: "#B8D4E8"
  }
  free: Free Block {
    style.fill: "#C8E8C8"
  }
  invalid: Deallocated/Unmapped {
    style.fill: "#FFE8E8"
    style.stroke-dash: 3
    style.stroke: "#CC0000"
  }
  valid_ptr: Valid Reference {
    shape: text
    label: "→ Correct Mapping"
  }
  dang_ptr: Dangling Pointer {
    shape: text
    label: "⚠️ Stale Reference"
    style.font-color: "#CC0000"
  }
}