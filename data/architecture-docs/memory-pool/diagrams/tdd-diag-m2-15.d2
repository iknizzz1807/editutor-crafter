vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Pool Growth Strategies Comparison
  Fixed-Size Chunks vs Geometric Growth
| {
  near: top-center
}

direction: right

# ========== STRATEGY 1: FIXED-SIZE CHUNKS ==========
fixed_strategy: {
  label: "Fixed-Size Chunks"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 3

  fixed_desc: |md
    **Strategy:** Every new chunk has the same number of blocks as the initial allocation.
    `blocks_per_chunk = initial_blocks` (constant)
  | {
    shape: text
  }

  fixed_timeline: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    f_t0: "t₀"; f_t0.style: { fill: "#A8DADC"; font: mono; bold: true }
    f_t1: "t₁"; f_t1.style: { fill: "#A8DADC"; font: mono; bold: true }
    f_t2: "t₂"; f_t2.style: { fill: "#A8DADC"; font: mono; bold: true }
    f_t3: "t₄"; f_t3.style: { fill: "#A8DADC"; font: mono; bold: true }
    f_t4: "tₙ"; f_t4.style: { fill: "#A8DADC"; font: mono; bold: true }
  }

  fixed_blocks: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 20
    f_b0: "Chunk 0\n100 blocks" {
      shape: rectangle
      style: { fill: "#457B9D"; font-color: white; stroke: "#1D3557" }
      width: 100
      height: 80
    }
    f_b1: "Chunk 1\n100 blocks" {
      shape: rectangle
      style: { fill: "#457B9D"; font-color: white; stroke: "#1D3557" }
      width: 100
      height: 80
    }
    f_b2: "Chunk 2\n100 blocks" {
      shape: rectangle
      style: { fill: "#457B9D"; font-color: white; stroke: "#1D3557" }
      width: 100
      height: 80
    }
    f_b3: "Chunk 3\n100 blocks" {
      shape: rectangle
      style: { fill: "#457B9D"; font-color: white; stroke: "#1D3557" }
      width: 100
      height: 80
    }
    f_b4: "Chunk N\n100 blocks" {
      shape: rectangle
      style: { fill: "#457B9D"; font-color: white; stroke: "#1D3557"; multiple: true }
      width: 100
      height: 80
    }
  }

  fixed_arrow: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    fa0: "→"; fa0.shape: text; fa0.style.font-size: 24
    fa1: "→"; fa1.shape: text; fa1.style.font-size: 24
    fa2: "→"; fa2.shape: text; fa2.style.font-size: 24
    fa3: "→"; fa3.shape: text; fa3.style.font-size: 24
    fa4: "→"; fa4.shape: text; fa4.style.font-size: 24
  }

  fixed_growth: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    fg0: "+0"; fg0.shape: text; fg0.style: { font: mono; font-color: "#2A9D8F" }
    fg1: "+100"; fg1.shape: text; fg1.style: { font: mono; font-color: "#2A9D8F" }
    fg2: "+100"; fg2.shape: text; fg2.style: { font: mono; font-color: "#2A9D8F" }
    fg3: "+100"; fg3.shape: text; fg3.style: { font: mono; font-color: "#2A9D8F" }
    fg4: "+100"; fg4.shape: text; fg4.style: { font: mono; font-color: "#2A9D8F" }
  }

  fixed_total: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    ft0: "=100"; ft0.shape: text; ft0.style: { font: mono; bold: true }
    ft1: "=200"; ft1.shape: text; ft1.style: { font: mono; bold: true }
    ft2: "=300"; ft2.shape: text; ft2.style: { font: mono; bold: true }
    ft3: "=400"; ft3.shape: text; ft3.style: { font: mono; bold: true }
    ft4: "=N×100"; ft4.shape: text; ft4.style: { font: mono; bold: true }
  }

  fixed_timeline -> fixed_blocks -> fixed_arrow -> fixed_growth -> fixed_total
}

# ========== STRATEGY 2: GEOMETRIC GROWTH ==========
geo_strategy: {
  label: "Geometric Growth (Doubling)"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 3

  geo_desc: |md
    **Strategy:** Each new chunk doubles in size. Like `std::vector` growth.
    `blocks_per_chunk = previous_total_capacity` (doubles each time)
  | {
    shape: text
  }

  geo_timeline: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    g_t0: "t₀"; g_t0.style: { fill: "#FFCC80"; font: mono; bold: true }
    g_t1: "t₁"; g_t1.style: { fill: "#FFCC80"; font: mono; bold: true }
    g_t2: "t₂"; g_t2.style: { fill: "#FFCC80"; font: mono; bold: true }
    g_t3: "t₄"; g_t3.style: { fill: "#FFCC80"; font: mono; bold: true }
    g_t4: "tₙ"; g_t4.style: { fill: "#FFCC80"; font: mono; bold: true }
  }

  geo_blocks: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 20
    g_b0: "Chunk 0\n100 blocks" {
      shape: rectangle
      style: { fill: "#FB8C00"; font-color: white; stroke: "#BF360C" }
      width: 60
      height: 40
    }
    g_b1: "Chunk 1\n100 blocks" {
      shape: rectangle
      style: { fill: "#FB8C00"; font-color: white; stroke: "#BF360C" }
      width: 60
      height: 40
    }
    g_b2: "Chunk 2\n200 blocks" {
      shape: rectangle
      style: { fill: "#FB8C00"; font-color: white; stroke: "#BF360C" }
      width: 100
      height: 80
    }
    g_b3: "Chunk 3\n400 blocks" {
      shape: rectangle
      style: { fill: "#FB8C00"; font-color: white; stroke: "#BF360C" }
      width: 140
      height: 120
    }
    g_b4: "Chunk N\n??? blocks" {
      shape: rectangle
      style: { fill: "#FB8C00"; font-color: white; stroke: "#BF360C"; multiple: true }
      width: 180
      height: 160
    }
  }

  geo_arrow: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    ga0: "→"; ga0.shape: text; ga0.style.font-size: 24
    ga1: "→"; ga1.shape: text; ga1.style.font-size: 24
    ga2: "→"; ga2.shape: text; ga2.style.font-size: 24
    ga3: "→"; ga3.shape: text; ga3.style.font-size: 24
    ga4: "→"; ga4.shape: text; ga4.style.font-size: 24
  }

  geo_growth: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    gg0: "+0"; gg0.shape: text; gg0.style: { font: mono; font-color: "#E65100" }
    gg1: "+100"; gg1.shape: text; gg1.style: { font: mono; font-color: "#E65100" }
    gg2: "+200"; gg2.shape: text; gg2.style: { font: mono; font-color: "#E65100" }
    gg3: "+400"; gg3.shape: text; gg3.style: { font: mono; font-color: "#E65100" }
    gg4: "+2×"; gg4.shape: text; gg4.style: { font: mono; font-color: "#E65100" }
  }

  geo_total: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-columns: 5
    grid-gap: 0
    gt0: "=100"; gt0.shape: text; gt0.style: { font: mono; bold: true }
    gt1: "=200"; gt1.shape: text; gt1.style: { font: mono; bold: true }
    gt2: "=400"; gt2.shape: text; gt2.style: { font: mono; bold: true }
    gt3: "=800"; gt3.shape: text; gt3.style: { font: mono; bold: true }
    gt4: "=2ᴺ×100"; gt4.shape: text; gt4.style: { font: mono; bold: true }
  }

  geo_timeline -> geo_blocks -> geo_arrow -> geo_growth -> geo_total
}

# ========== TRADE-OFFS MATRIX ==========
tradeoffs: {
  label: "Trade-Off Analysis"
  style.fill: "#F5F5F5"
  style.stroke: "#424242"
  style.stroke-width: 2
  direction: right

  metrics: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-rows: 7
    grid-gap: 8
    m_header: "Metric"; m_header.style: { fill: "#424242"; font-color: white; bold: true }
    m1: "Chunk Count (for N blocks)"; m1.style.fill: "#E0E0E0"
    m2: "Allocation Size"; m2.style.fill: "#E0E0E0"
    m3: "Memory Waste Risk"; m3.style.fill: "#E0E0E0"
    m4: "OOM Failure Mode"; m4.style.fill: "#E0E0E0"
    m5: "Chunk Metadata Overhead"; m5.style.fill: "#E0E0E0"
    m6: "Predictability"; m6.style.fill: "#E0E0E0"
  }

  fixed_col: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-rows: 7
    grid-gap: 8
    f_header: "Fixed-Size"; f_header.style: { fill: "#457B9D"; font-color: white; bold: true }
    f1: "N / chunk_size"; f1.style: { fill: "#E8F4FD"; font: mono }
    f2: "Constant ✓"; f2.style: { fill: "#C8E6C9"; font: mono }
    f3: "Low ✓"; f3.style: { fill: "#C8E6C9"; font: mono }
    f4: "Graceful degradation"; f4.style: { fill: "#C8E6C9"; font: mono }
    f5: "High (more chunks)"; f5.style: { fill: "#FFCDD2"; font: mono }
    f6: "Excellent ✓"; f6.style: { fill: "#C8E6C9"; font: mono }
  }

  geo_col: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-rows: 7
    grid-gap: 8
    g_header: "Geometric"; g_header.style: { fill: "#FB8C00"; font-color: white; bold: true }
    g1: "log₂(N / initial)"; g1.style: { fill: "#FFF3E0"; font: mono }
    g2: "Growing ⚠"; g2.style: { fill: "#FFE0B2"; font: mono }
    g3: "High (last chunk)"; g3.style: { fill: "#FFCDD2"; font: mono }
    g4: "Sudden large OOM"; g4.style: { fill: "#FFCDD2"; font: mono }
    g5: "Low (fewer chunks)"; g5.style: { fill: "#C8E6C9"; font: mono }
    g6: "Variable ⚠"; g6.style: { fill: "#FFE0B2"; font: mono }
  }

  metrics -> fixed_col -> geo_col
}

# ========== FAILURE MODE DIAGRAM ==========
failure_modes: {
  label: "Failure Mode Analysis"
  style.fill: "#FAFAFA"
  style.stroke: "#616161"
  style.stroke-width: 2
  direction: right

  fixed_failure: {
    label: "Fixed-Size: Graceful Degradation"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"

    ff_timeline: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      grid-columns: 6
      grid-gap: 5
      ff0: "Request\n64KB"; ff0.shape: rectangle; ff0.style.fill: "#81C784"; ff0.width: 60
      ff1: "Alloc\n✓"; ff1.shape: circle; ff1.style: { fill: "#4CAF50"; font-color: white }
      ff2: "Request\n64KB"; ff2.shape: rectangle; ff2.style.fill: "#81C784"; ff2.width: 60
      ff3: "Alloc\n✓"; ff3.shape: circle; ff3.style: { fill: "#4CAF50"; font-color: white }
      ff4: "OOM"; ff4.shape: diamond; ff4.style: { fill: "#FF5722"; font-color: white }
      ff5: "Return\nNULL"; ff5.shape: rectangle; ff5.style.fill: "#BDBDBD"
    }
    ff_note: |md
      **Predictable failure:** System runs until memory exhausted, then gracefully returns NULL. Easy to handle, easy to test.
    | { shape: text; style.font-size: 14 }
  }

  geo_failure: {
    label: "Geometric: Sudden Death"
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"

    gf_timeline: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      grid-columns: 6
      grid-gap: 5
      gf0: "Request\n64KB"; gf0.shape: rectangle; gf0.style.fill: "#FFCC80"; gf0.width: 60
      gf1: "Alloc\n✓"; gf1.shape: circle; gf1.style: { fill: "#4CAF50"; font-color: white }
      gf2: "Request\n512KB\n(8× growth!)"; gf2.shape: rectangle; gf2.style: { fill: "#FFCC80"; stroke: "#E65100"; stroke-width: 3 }; gf2.width: 80
      gf3: "OOM\n(denied)"; gf3.shape: diamond; gf3.style: { fill: "#F44336"; font-color: white; stroke: "#B71C1C"; stroke-width: 2 }
      gf4: "Return\nNULL"; gf4.shape: rectangle; gf4.style.fill: "#BDBDBD"
      gf5: "50%\nunused!"; gf5.shape: rectangle; gf5.style: { fill: "#FFCDD2"; stroke-dash: 3 }
    }
    gf_note: |md
      **Unpredictable failure:** Small request triggers massive allocation attempt. May fail even when plenty of memory exists (fragmentation).
    | { shape: text; style.font-size: 14 }
  }

  fixed_failure <-> geo_failure: "Compare" {
    style: { stroke-dash: 5; stroke: "#9E9E9E" }
  }
}

# ========== CHUNK COUNT COMPARISON ==========
chunk_comparison: {
  label: "Chunk Count for 10,000 Blocks (initial=100)"
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"
  grid-columns: 2
  grid-gap: 40

  fixed_chunks: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-rows: 3
    grid-gap: 10
    fc_label: "Fixed-Size: 100 chunks"; fc_label.style: { fill: "#457B9D"; font-color: white; bold: true }
    fc_visual: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      grid-columns: 10
      grid-gap: 2
      fc0: ""; fc0.shape: square; fc0.style.fill: "#457B9D"; fc0.width: 20
      fc1: ""; fc1.shape: square; fc1.style.fill: "#457B9D"; fc1.width: 20
      fc2: ""; fc2.shape: square; fc2.style.fill: "#457B9D"; fc2.width: 20
      fc3: ""; fc3.shape: square; fc3.style.fill: "#457B9D"; fc3.width: 20
      fc4: ""; fc4.shape: square; fc4.style.fill: "#457B9D"; fc4.width: 20
      fc5: ""; fc5.shape: square; fc5.style.fill: "#457B9D"; fc5.width: 20
      fc6: ""; fc6.shape: square; fc6.style.fill: "#457B9D"; fc6.width: 20
      fc7: ""; fc7.shape: square; fc7.style.fill: "#457B9D"; fc7.width: 20
      fc8: ""; fc8.shape: square; fc8.style.fill: "#457B9D"; fc8.width: 20
      fc9: "..."; fc9.shape: text; fc9.style.fill: transparent
    }
    fc_overhead: |md
      **Overhead:** 100 × 24 bytes = 2,400 bytes metadata
    | { shape: text }
  }

  geo_chunks: {
    label: ""
    style.fill: transparent
    style.stroke: transparent
    grid-rows: 3
    grid-gap: 10
    gc_label: "Geometric: 7 chunks"; gc_label.style: { fill: "#FB8C00"; font-color: white; bold: true }
    gc_visual: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      grid-columns: 7
      grid-gap: 2
      gc0: ""; gc0.shape: square; gc0.style.fill: "#FB8C00"; gc0.width: 20
      gc1: ""; gc1.shape: square; gc1.style.fill: "#FB8C00"; gc1.width: 20
      gc2: ""; gc2.shape: square; gc2.style.fill: "#FB8C00"; gc2.width: 30
      gc3: ""; gc3.shape: square; gc3.style.fill: "#FB8C00"; gc3.width: 40
      gc4: ""; gc4.shape: square; gc4.style.fill: "#FB8C00"; gc4.width: 60
      gc5: ""; gc5.shape: square; gc5.style.fill: "#FB8C00"; gc5.width: 80
      gc6: ""; gc6.shape: square; gc6.style.fill: "#FB8C00"; gc6.width: 100
    }
    gc_overhead: |md
      **Overhead:** 7 × 24 bytes = 168 bytes metadata
      *Sizes: 100, 100, 200, 400, 800, 1600, 3200, 6400*
    | { shape: text }
  }
}

# ========== DECISION MATRIX ==========
decision: {
  label: "When to Use Each Strategy"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  direction: right

  use_fixed: {
    label: "Use Fixed-Size When:"
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    fixed_reasons: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      grid-rows: 6
      grid-gap: 5
      fr1: "✓ **Embedded systems** — predictable memory usage" { shape: text }
      fr2: "✓ **Real-time systems** — bounded allocation time" { shape: text }
      fr3: "✓ **Memory-constrained** — gradual degradation" { shape: text }
      fr4: "✓ **Testing/debugging** — reproducible behavior" { shape: text }
      fr5: "✓ **Tiered limits** — `max_chunks` enforcement is simple" { shape: text }
      fr6: "✓ **Simple implementation** — this TDD uses fixed-size" { shape: text }
    }
  }

  use_geo: {
    label: "Use Geometric When:"
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
    geo_reasons: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      grid-rows: 6
      grid-gap: 5
      gr1: "✓ **Desktop/server** — abundant memory" { shape: text }
      gr2: "✓ **High throughput** — fewer chunk traversals" { shape: text }
      gr3: "✓ **Long-running** — amortized overhead" { shape: text }
      gr4: "✓ **Similar to std::vector** — familiar semantics" { shape: text }
      gr5: "⚠ **Accept OOM risk** — large allocations may fail" { shape: text }
      gr6: "⚠ **Accept waste** — up to 50% of last chunk unused" { shape: text }
    }
  }
}

# ========== CONNECT ELEMENTS ==========
fixed_strategy <-> tradeoffs: "" { style.stroke: transparent }
geo_strategy <-> tradeoffs: "" { style.stroke: transparent }
tradeoffs <-> failure_modes: "" { style.stroke: transparent }
failure_modes <-> chunk_comparison: "" { style.stroke: transparent }
chunk_comparison <-> decision: "" { style.stroke: transparent }

# ========== LEGEND ==========
legend: {
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  near: bottom-center
  grid-columns: 4
  grid-gap: 20
  l1: "✓ Advantage"; l1.style: { fill: "#C8E6C9"; font: mono }
  l2: "⚠ Caution"; l2.style: { fill: "#FFE0B2"; font: mono }
  l3: "✗ Risk"; l3.style: { fill: "#FFCDD2"; font: mono }
  l4: "→ Growth direction"; l4.style: { font: mono }
}