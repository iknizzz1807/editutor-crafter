layout-engine: elk
theme-id: 4
title: |md
  # Pool Free Operation: O(1) Push to Head
| {near: top-center}
direction: right
classes: {
  container: {
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 2
      border-radius: 8
    }
  }
  block: {
    style: {
      fill: white
      stroke: "#333333"
      stroke-width: 1
      font: mono
    }
  }
  allocated: {
    style: {
      fill: "#FF6B6B"
      stroke: "#CC0000"
      font: mono
      bold: true
    }
  }
  free: {
    style: {
      fill: "#6BCB77"
      stroke: "#228B22"
      font: mono
    }
  }
  pointer: {
    shape: text
    style: {
      font: mono
      font-size: 14
      font-color: "#0066CC"
    }
  }
  operation: {
    style: {
      fill: "#FFE066"
      stroke: "#CC9900"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
}
step1: "Step 1: Before pool_free()" {
  pool_before: {
    style.fill: transparent
    style.stroke: transparent
    header: "MemoryPool" {
      shape: rectangle
      style.fill: "#9B59B6"
      style.font-color: white
      style.bold: true
      allocated: "allocated: 3" {style.fill: transparent; style.font-color: white; style.stroke: transparent}
      head: "free_list_head → Block 3" {style.fill: transparent; style.font-color: white; style.stroke: transparent}
    }
    blocks_before: "Block Array" {
      grid-columns: 5
      grid-gap: 4
      b0: "Block 0\n[ALLOC'D]" {class: allocated}
      b1: "Block 1\n[ALLOC'D]" {class: allocated}
      b2: "Block 2\n[ALLOC'D]\n(to free)" {class: operation}
      b3: "Block 3\n[FREE]\n→ NULL" {class: free}
      b4: "Block 4\n[FREE]\n→ Block 3" {class: free}
    }
  }
}
arrow1: "pool_free(pool, Block 2)" {
  shape: text
  style.font-size: 16
  style.bold: true
  style.fill: "#FFE066"
}
step2: "Step 2: Validation & Bitmap Check" {
  validation: {
    style.fill: "#FFF9E6"
    style.stroke: "#CC9900"
    check1: "✓ Pointer within pool bounds?" {shape: text; style.font: mono; style.stroke: transparent}
    check2: "✓ Pointer at block boundary?" {shape: text; style.font: mono; style.stroke: transparent}
    check3: "✓ Bitmap shows ALLOCATED (not double-free)?" {shape: text; style.font: mono; style.stroke: transparent}
    bitmap: "allocated_map[0]" {
      style.fill: "#E0E0E0"
      grid-columns: 8
      grid-gap: 2
      bit0: "1" {style.fill: "#FF6B6B"; style.font-color: white}
      bit1: "1" {style.fill: "#FF6B6B"; style.font-color: white}
      bit2: "1" {style.fill: "#FFE066"; style.font-color: black; style.bold: true}
      bit3: "0" {style.fill: "#6BCB77"; style.font-color: white}
      bit4: "0" {style.fill: "#6BCB77"; style.font-color: white}
      bit5: "0" {style.fill: "#E0E0E0"}
      bit6: "0" {style.fill: "#E0E0E0"}
      bit7: "0" {style.fill: "#E0E0E0"}
    }
  }
}
arrow2: "Validation Passed" {
  shape: text
  style.font-size: 14
  style.font-color: "#228B22"
  style.bold: true
}
step3: "Step 3: Clear Bitmap Bit" {
  bitmap_op: {
    style.fill: "#E0FFE0"
    style.stroke: "#228B22"
    op: "bitmap_clear(map, 2)" {shape: text; style.font: mono; style.bold: true; style.stroke: transparent}
    bitmap_after: "allocated_map[0] (after)" {
      style.fill: "#E0E0E0"
      grid-columns: 8
      grid-gap: 2
      bit0: "1" {style.fill: "#FF6B6B"; style.font-color: white}
      bit1: "1" {style.fill: "#FF6B6B"; style.font-color: white}
      bit2: "0" {style.fill: "#6BCB77"; style.font-color: white; style.bold: true}
      bit3: "0" {style.fill: "#6BCB77"; style.font-color: white}
      bit4: "0" {style.fill: "#6BCB77"; style.font-color: white}
      bit5: "0" {style.fill: "#E0E0E0"}
      bit6: "0" {style.fill: "#E0E0E0"}
      bit7: "0" {style.fill: "#E0E0E0"}
    }
  }
}
arrow3: "Bit cleared" {
  shape: text
  style.font-size: 14
  style.font-color: "#228B22"
}
step4: "Step 4: Push to Free List Head" {
  push_op: {
    style.fill: "#E0FFE0"
    style.stroke: "#228B22"
    code: |md
      c
      *(void**)Block2 = free_list_head;  // Block2->next = Block3
      free_list_head = Block2;            // New head
      pool->allocated--;
      
    | {shape: text; style.stroke: transparent; style.font: mono}
    pointer_store: "Block 2 now stores pointer to Block 3" {
      shape: text
      style.font: mono
      style.stroke: transparent
    }
  }
}
arrow4: "Push complete" {
  shape: text
  style.font-size: 14
  style.font-color: "#228B22"
}
step5: "Step 5: After pool_free() - Complete" {
  pool_after: {
    style.fill: transparent
    style.stroke: transparent
    header_after: "MemoryPool (updated)" {
      shape: rectangle
      style.fill: "#9B59B6"
      style.font-color: white
      style.bold: true
      allocated_after: "allocated: 2 (was 3)" {style.fill: transparent; style.font-color: white; style.stroke: transparent}
      head_after: "free_list_head → Block 2 (NEW)" {style.fill: "#FFE066"; style.font-color: black; style.stroke: transparent}
    }
    blocks_after: "Block Array (updated)" {
      grid-columns: 5
      grid-gap: 4
      b0a: "Block 0\n[ALLOC'D]" {class: allocated}
      b1a: "Block 1\n[ALLOC'D]" {class: allocated}
      b2a: "Block 2\n[FREE]\n→ Block 3" {class: free; style.bold: true}
      b3a: "Block 3\n[FREE]\n→ NULL" {class: free}
      b4a: "Block 4\n[FREE]\n→ Block 3" {class: free}
    }
  }
}
summary: |md
  ## O(1) Free Operation Summary
  **Operations performed:**
  1. Bounds check: `ptr >= base && ptr < end`
  2. Alignment check: `offset % block_size == 0`
  3. Double-free check: `bitmap_test(index) == true`
  4. Clear bitmap: `bitmap_clear(map, index)`
  5. Store next pointer: `*(void**)ptr = free_list_head`
  6. Update head: `free_list_head = ptr`
  7. Decrement counter: `allocated--`
  **Key insight:** Block 2 is now at the head of the free list.  
  Next `pool_alloc()` will return Block 2 (LIFO order).
| {near: bottom-center}