vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cache Locality Degradation with Multiple Chunks
| {near: top-center}
direction: right
single_chunk: {
  label: "Single Chunk\n(Contiguous Memory)"
  header_single: {
    shape: rectangle
    label: ""
    style.fill: "#8B5CF6"
    style.stroke: "#6D28D9"
    style.font-color: white
    width: 480
    height: 40
  }
  block_0: {
    label: "Block 0\n0x1000"
    shape: rectangle
    style.fill: "#3B82F6"
    style.stroke: "#1D4ED8"
    style.font-color: white
    width: 80
    height: 60
  }
  block_1: {
    label: "Block 1\n0x1040"
    shape: rectangle
    style.fill: "#3B82F6"
    style.stroke: "#1D4ED8"
    style.font-color: white
    width: 80
    height: 60
  }
  block_2: {
    label: "Block 2\n0x1080"
    shape: rectangle
    style.fill: "#3B82F6"
    style.stroke: "#1D4ED8"
    style.font-color: white
    width: 80
    height: 60
  }
  block_3: {
    label: "Block 3\n0x10C0"
    shape: rectangle
    style.fill: "#3B82F6"
    style.stroke: "#1D4ED8"
    style.font-color: white
    width: 80
    height: 60
  }
  block_4: {
    label: "Block 4\n0x1100"
    shape: rectangle
    style.fill: "#10B981"
    style.stroke: "#059669"
    style.font-color: white
    width: 80
    height: 60
  }
  block_5: {
    label: "Block 5\n0x1140"
    shape: rectangle
    style.fill: "#10B981"
    style.stroke: "#059669"
    style.font-color: white
    width: 80
    height: 60
  }
  header_single -> block_0 -> block_1 -> block_2 -> block_3 -> block_4 -> block_5: {
    style.stroke: transparent
  }
  prefetch_arrow: {
    label: "← Hardware Prefetcher\nSees Sequential Access"
    shape: text
    style.fill: transparent
    style.font-color: "#059669"
    style.font-size: 14
    style.italic: true
  }
  block_2 -> prefetch_arrow: {
    style.stroke: "#10B981"
    style.stroke-dash: 3
  }
  cache_line_single: {
    label: "Cache Line (64 bytes)\nBlocks 0-1 fit in one line"
    shape: rectangle
    style.fill: transparent
    style.stroke: "#F59E0B"
    style.stroke-dash: 5
    style.stroke-width: 2
    width: 170
    height: 80
  }
}
multi_chunk: {
  label: "Multiple Chunks\n(Non-Contiguous Memory)"
  chunk_0: {
    label: "Chunk 0"
    shape: rectangle
    style.fill: "#8B5CF6"
    style.stroke: "#6D28D9"
    style.font-color: white
    m_block_0: {
      label: "Block 0\n0x1000"
      shape: rectangle
      style.fill: "#3B82F6"
      style.stroke: "#1D4ED8"
      style.font-color: white
      width: 70
      height: 50
    }
    m_block_1: {
      label: "Block 1\n0x1040"
      shape: rectangle
      style.fill: "#3B82F6"
      style.stroke: "#1D4ED8"
      style.font-color: white
      width: 70
      height: 50
    }
    m_block_2: {
      label: "Block 2\n0x1080"
      shape: rectangle
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
      style.font-color: white
      width: 70
      height: 50
    }
    chunk_0 -> m_block_0 -> m_block_1 -> m_block_2: {
      style.stroke: transparent
    }
  }
  gap_0: {
    label: "≈≈≈\nGap"
    shape: text
    style.fill: transparent
    style.font-color: "#6B7280"
  }
  chunk_1: {
    label: "Chunk 1"
    shape: rectangle
    style.fill: "#8B5CF6"
    style.stroke: "#6D28D9"
    style.font-color: white
    m_block_3: {
      label: "Block 3\n0x5000"
      shape: rectangle
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
      style.font-color: white
      width: 70
      height: 50
    }
    m_block_4: {
      label: "Block 4\n0x5040"
      shape: rectangle
      style.fill: "#10B981"
      style.stroke: "#059669"
      style.font-color: white
      width: 70
      height: 50
    }
    m_block_5: {
      label: "Block 5\n0x5080"
      shape: rectangle
      style.fill: "#10B981"
      style.stroke: "#059669"
      style.font-color: white
      width: 70
      height: 50
    }
    chunk_1 -> m_block_3 -> m_block_4 -> m_block_5: {
      style.stroke: transparent
    }
  }
  gap_1: {
    label: "≈≈≈\nGap"
    shape: text
    style.fill: transparent
    style.font-color: "#6B7280"
  }
  chunk_2: {
    label: "Chunk 2"
    shape: rectangle
    style.fill: "#8B5CF6"
    style.stroke: "#6D28D9"
    style.font-color: white
    m_block_6: {
      label: "Block 6\n0x9000"
      shape: rectangle
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
      style.font-color: white
      width: 70
      height: 50
    }
    m_block_7: {
      label: "Block 7\n0x9040"
      shape: rectangle
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
      style.font-color: white
      width: 70
      height: 50
    }
    m_block_8: {
      label: "Block 8\n0x9080"
      shape: rectangle
      style.fill: "#10B981"
      style.stroke: "#059669"
      style.font-color: white
      width: 70
      height: 50
    }
    chunk_2 -> m_block_6 -> m_block_7 -> m_block_8: {
      style.stroke: transparent
    }
  }
  chunk_0 -> gap_0 -> chunk_1 -> gap_1 -> chunk_2: {
    style.stroke: transparent
  }
}
comparison: {
  label: ""
  style.fill: transparent
  good: {
    label: "Single Chunk Access Pattern"
    shape: rectangle
    style.fill: "#ECFDF5"
    style.stroke: "#10B981"
    style.font-color: "#065F46"
    good_title: {
      label: "✓ Excellent Cache Locality"
      shape: text
      style.fill: transparent
      style.font-color: "#059669"
      style.bold: true
    }
    good_points: |md
      - Sequential addresses (0x1000, 0x1040, 0x1080...)
      - Hardware prefetcher detects pattern
      - Next block likely already in L1 cache
      - 1 cache line holds multiple blocks
      - TLB entries reused efficiently
    | {shape: text}
    good_title -> good_points: {style.stroke: transparent}
  }
  bad: {
    label: "Multi-Chunk Access Pattern"
    shape: rectangle
    style.fill: "#FEF2F2"
    style.stroke: "#EF4444"
    style.font-color: "#991B1B"
    bad_title: {
      label: "✗ Degraded Cache Locality"
      shape: text
      style.fill: transparent
      style.font-color: "#DC2626"
      style.bold: true
    }
    bad_points: |md
      - Scattered addresses (0x1000 → 0x5000 → 0x9000)
      - Prefetcher sees random access
      - Each chunk = potential cache miss
      - More TLB pressure (more pages)
      - Free list crosses chunk boundaries
    | {shape: text}
    bad_title -> bad_points: {style.stroke: transparent}
  }
  good -> bad: {style.stroke: transparent}
}
access_pattern: {
  label: ""
  style.fill: transparent
  seq_access: {
    label: "Sequential Allocation (Single Chunk)"
    shape: sequence_diagram
    thread_seq: Thread
    l1_seq: "L1 Cache"
    mem_seq: Memory
    thread_seq -> l1_seq: "alloc Block 0"
    l1_seq -> mem_seq: "fetch cache line\n(contains Block 0,1)"
    mem_seq -> l1_seq: "64 bytes"
    l1_seq -> thread_seq: "Block 0 pointer"
    thread_seq -> l1_seq: "alloc Block 1" {
      style.stroke: "#10B981"
    }
    l1_seq -> thread_seq: "HIT! Already cached" {
      style.stroke: "#10B981"
      style.bold: true
    }
  }
  scatter_access: {
    label: "Cross-Chunk Allocation"
    shape: sequence_diagram
    thread_scatter: Thread
    l1_scatter: "L1 Cache"
    mem_scatter: Memory
    thread_scatter -> l1_scatter: "alloc Block 0\n(Chunk 0)"
    l1_scatter -> mem_scatter: "fetch 0x1000"
    mem_scatter -> l1_scatter: "64 bytes"
    l1_scatter -> thread_scatter: "Block 0"
    thread_scatter -> l1_scatter: "alloc Block 3\n(Chunk 1)" {
      style.stroke: "#EF4444"
    }
    l1_scatter -> mem_scatter: "fetch 0x5000\n(NOT in cache!)" {
      style.stroke: "#EF4444"
    }
    mem_scatter -> l1_scatter: "64 bytes\n(latency!)" {
      style.stroke: "#EF4444"
    }
    l1_scatter -> thread_scatter: "Block 3"
  }
  seq_access -> scatter_access: {style.stroke: transparent}
}
metrics: {
  label: ""
  style.fill: transparent
  metric_header: {
    label: "Cache Performance Metrics"
    shape: rectangle
    style.fill: "#1F2937"
    style.font-color: white
    style.bold: true
  }
  metric_row1: {
    label: ""
    shape: rectangle
    style.fill: "#F3F4F6"
    m_label1: {label: "Metric"; shape: text; style.bold: true}
    m_single1: {label: "Single Chunk"; shape: text; style.bold: true; style.font-color: "#059669"}
    m_multi1: {label: "Multi-Chunk"; shape: text; style.bold: true; style.font-color: "#DC2626"}
    m_label1 -> m_single1 -> m_multi1: {style.stroke: transparent}
  }
  metric_row2: {
    label: ""
    shape: rectangle
    style.fill: "#FFFFFF"
    m_label2: {label: "L1 Cache Hits"; shape: text}
    m_single2: {label: "~95%"; shape: text; style.font-color: "#059669"}
    m_multi2: {label: "~60-80%"; shape: text; style.font-color: "#DC2626"}
    m_label2 -> m_single2 -> m_multi2: {style.stroke: transparent}
  }
  metric_row3: {
    label: ""
    shape: rectangle
    style.fill: "#F3F4F6"
    m_label3: {label: "TLB Misses"; shape: text}
    m_single3: {label: "1 per pool"; shape: text; style.font-color: "#059669"}
    m_multi3: {label: "1 per chunk"; shape: text; style.font-color: "#DC2626"}
    m_label3 -> m_single3 -> m_multi3: {style.stroke: transparent}
  }
  metric_row4: {
    label: ""
    shape: rectangle
    style.fill: "#FFFFFF"
    m_label4: {label: "Prefetch Efficiency"; shape: text}
    m_single4: {label: "High"; shape: text; style.font-color: "#059669"}
    m_multi4: {label: "Low/None"; shape: text; style.font-color: "#DC2626"}
    m_label4 -> m_single4 -> m_multi4: {style.stroke: transparent}
  }
  metric_row5: {
    label: ""
    shape: rectangle
    style.fill: "#F3F4F6"
    m_label5: {label: "Alloc Latency (avg)"; shape: text}
    m_single5: {label: "~8-15 ns"; shape: text; style.font-color: "#059669"}
    m_multi5: {label: "~15-50 ns"; shape: text; style.font-color: "#DC2626"}
    m_label5 -> m_single5 -> m_multi5: {style.stroke: transparent}
  }
  metric_header -> metric_row1 -> metric_row2 -> metric_row3 -> metric_row4 -> metric_row5: {
    style.stroke: "#D1D5DB"
  }
}
mitigation: {
  label: ""
  style.fill: "#FEF3C7"
  style.stroke: "#F59E0B"
  style.border-radius: 8
  mit_title: {
    label: "⚠ Mitigation Strategies"
    shape: text
    style.bold: true
    style.font-color: "#92400E"
  }
  mit_content: |md
    1. **Prefer larger initial chunks** over many small growths
    2. **Use geometric growth** (double chunk size each time)
    3. **Thread-local pools** eliminate cross-chunk access patterns
    4. **Bulk operations** allocate from same chunk when possible
    5. **Warm-up phase** pre-touch chunks before latency-sensitive work
  | {shape: text}
  mit_title -> mit_content: {style.stroke: transparent}
}
legend: {
  label: ""
  style.fill: transparent
  leg_header: {
    label: "Block States"
    shape: text
    style.bold: true
  }
  leg_alloc: {
    label: "Allocated"
    shape: rectangle
    style.fill: "#3B82F6"
    style.font-color: white
    width: 80
  }
  leg_free: {
    label: "Free"
    shape: rectangle
    style.fill: "#10B981"
    style.font-color: white
    width: 80
  }
  leg_cross: {
    label: "Cross-chunk\naccess"
    shape: rectangle
    style.fill: "#EF4444"
    style.font-color: white
    width: 80
  }
  leg_header -> leg_alloc -> leg_free -> leg_cross: {style.stroke: transparent}
}
single_chunk -> comparison.good -> access_pattern.seq_access: {style.stroke: transparent}
multi_chunk -> comparison.bad -> access_pattern.scatter_access: {style.stroke: transparent}
access_pattern -> metrics -> mitigation -> legend: {
  style.stroke: "#9CA3AF"
  style.stroke-dash: 3
}