vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Race Condition: Concurrent pool_alloc() Without Mutex
  Two threads read the same free_list_head, causing duplicate allocation
| {near: top-center}
sequence: {
  shape: sequence_diagram
  Thread_A: {
    label: "Thread A"
    shape: person
  }
  Thread_B: {
    label: "Thread B"
    shape: person
  }
  FreeList: "Free List\nHead Pointer"
  Block0: "Block 0\n(0x1000)"
  Block1: "Block 1\n(0x1040)"
  step1: {
    Thread_A -> FreeList: "read free_list_head"
    FreeList -> Thread_A: "returns 0x1000"
  }
  step2: {
    Thread_B -> FreeList: "read free_list_head"
    FreeList -> Thread_B: "returns 0x1000"
  }
  step3: {
    Thread_A -> Block0: "read *(void**)0x1000"
    Block0 -> Thread_A: "returns 0x1040"
  }
  step4: {
    Thread_B -> Block0: "read *(void**)0x1000"
    Block0 -> Thread_B: "returns 0x1040"
  }
  step5: {
    Thread_A -> FreeList: "write free_list_head = 0x1040"
  }
  step6: {
    Thread_B -> FreeList: "write free_list_head = 0x1040"
  }
  step7: {
    Thread_A -> Thread_A: "return 0x1000"
    Thread_B -> Thread_B: "return 0x1000"
  }
  Thread_A."❌ Both threads\ngot same block!"
  Thread_B."❌ Block 0x1080\nlost from free list!"
}
result: {
  direction: right
  correct: "Correct Behavior" {
    style.fill: "#ACE1AF"
    style.stroke: green
    note1: |md
      Sequential access:
      - Thread A gets 0x1000
      - Thread B gets 0x1040
      - Each block allocated once
    |
  }
  buggy: "Race Condition Result" {
    style.fill: "#FFB6B6"
    style.stroke: red
    note2: |md
      Concurrent access:
      - Both threads get 0x1000
      - Block 0x1080 orphaned
      - Memory corruption when
        both threads write to 0x1000
    |
  }
}
memory_state: "Memory State After Race" {
  direction: right
  free_list_state: {
    shape: class
    label: "Free List (Corrupted)"
    head: "void* free_list_head = 0x1040"
    note: "// Points to Block 1, not Block 0"
  }
  block_diagram: {
    label: ""
    block0: {
      label: "Block 0\n0x1000"
      shape: rectangle
      style.fill: "#FFB6B6"
      style.stroke: red
      style.bold: true
    }
    block1: {
      label: "Block 1\n0x1040"
      shape: rectangle
      style.fill: "#FFE4B5"
      style.stroke: orange
    }
    block2: {
      label: "Block 2\n0x1080"
      shape: rectangle
      style.fill: "#D3D3D3"
      style.stroke-dash: 3
    }
    block0 -> block1: "next"
    block1 -> block2: "next"
    block2 -> lost: "next → ???"
    lost: {
      label: "ORPHANED\n(Unreachable)"
      shape: text
      style.font-color: red
      style.bold: true
    }
  }
  legend: |md
    **Legend:**
    🔴 Red = Allocated twice (corruption!)
    🟠 Orange = On free list  
    ⬜ Gray = Lost memory leak
  |
}
solution_hint: {
  near: bottom-center
  style.fill: "#E8F4FD"
  style.stroke: blue
  style.stroke-dash: 3
  label: |md
    **Solution:** Wrap `pool_alloc()` and `pool_free()` with `pthread_mutex_lock()` / `pthread_mutex_unlock()` 
    to ensure only one thread accesses shared state at a time.
  |
}