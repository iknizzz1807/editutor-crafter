vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
Mutex Serialization: {
  shape: sequence_diagram
  ThreadA: Thread A
  ThreadB: Thread B
  Mutex: pthread_mutex_t
  FreeList: free_list_head
  ThreadA -> Mutex: pthread_mutex_lock()
  Mutex -> ThreadA: acquired ✓ {
    style.stroke: "#22c55e"
  }
  ThreadA.t1 -> FreeList.t1: read head
  FreeList.t1 -> ThreadA.t1: 0x1000
  ThreadA.t1 -> FreeList.t2: write head = 0x1040
  ThreadA.t1 -> Mutex: pthread_mutex_unlock()
  Mutex -> ThreadA.t1: released {
    style.stroke: "#22c55e"
  }
  ThreadB.t1 -> Mutex: pthread_mutex_lock()
  Mutex -> ThreadB.t1: BLOCKED... {
    style.stroke: "#ef4444"
    style.stroke-dash: 3
  }
  ThreadB.t2 -> Mutex: pthread_mutex_lock()
  Mutex -> ThreadB.t2: acquired ✓ {
    style.stroke: "#22c55e"
  }
  ThreadB.t2 -> FreeList.t3: read head
  FreeList.t3 -> ThreadB.t2: 0x1040
  ThreadB.t2 -> FreeList.t4: write head = 0x1080
  ThreadB.t2 -> Mutex: pthread_mutex_unlock()
  Mutex -> ThreadB.t2: released {
    style.stroke: "#22c55e"
  }
}
Critical_Section_A: {
  ThreadA.t1
  FreeList.t1
  FreeList.t2
}
Critical_Section_B: {
  ThreadB.t2
  FreeList.t3
  FreeList.t4
}
Critical_Section_A.style: {
  fill: "#fef3c7"
  stroke: "#f59e0b"
  stroke-dash: 4
}
Critical_Section_B.style: {
  fill: "#dbeafe"
  stroke: "#3b82f6"
  stroke-dash: 4
}
legend: |md
  **Critical Section Guarantees:**
  - Only ONE thread inside at a time
  - All shared state modifications serialized
  - No interleaving of free list operations
| {
  near: bottom-center
  style.fill: "#f3f4f6"
  style.stroke: "#9ca3af"
}