layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header: "#673AB7"
    data: "#2196F3"
    free: "#4CAF50"
    padding: "#9E9E9E"
    pointer: "#FF9800"
    critical: "#FF8F00"
    error: "#B71C1C"
  }
}

title: |md
  # pool_alloc() Technical Specification
  ## Thread-Safe Fixed-Block Allocator with Mutex Serialization
  ### Reference: Intel Memory Management Manual Vol 3.
| {
  near: top-center
  shape: text
}

# --- MEMORY LAYOUT DEFINITION ---
# Illustrating the physical structure of the pool_t control block

memory_layout: {
  label: "STRUCT pool_t Layout (sizeof=64B)"
  style.stroke: "#333"
  style.fill: "#F5F5F5"

  00_08: "0x00 | mutex (pthread_mutex_t)" {
    style.fill: "#D1C4E9"
    width: 300
  }
  08_16: "0x08 | free_list_head (void*)" {
    style.fill: "#BBDEFB"
    width: 300
  }
  16_24: "0x10 | allocated_map (uint64_t*)" {
    style.fill: "#BBDEFB"
    width: 300
  }
  24_32: "0x18 | block_size (size_t)" {
    style.fill: "#C8E6C9"
    width: 300
  }
  32_40: "0x20 | total_blocks (uint32_t)" {
    style.fill: "#C8E6C9"
    width: 300
  }
  40_48: "0x28 | allocated_count (uint32_t)" {
    style.fill: "#C8E6C9"
    width: 300
  }
  48_64: "0x30 | PADDING (Cache Line Alignment)" {
    style.fill: "#EEEEEE"
    style.stroke-dash: 3
    width: 300
  }

  00_08.label: "8 Bytes"
  08_16.label: "8 Bytes (Pointer)"
  16_24.label: "8 Bytes (Pointer)"
  24_32.label: "8 Bytes"
  32_40.label: "4 Bytes"
  40_48.label: "4 Bytes"
  48_64.label: "16 Bytes"
}

# --- ALGORITHM STATE FLOW ---

flow_container: {
  direction: down

  start: ● {
    shape: circle
    style.fill: "#2E7D32"
    style.stroke: "#1B5E20"
  }

  step_01: "01. pthread_mutex_lock(&pool->mutex)" {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      bold: true
    }
    tooltip: "Acquire exclusive lock. Thread blocks here if contested."
  }

  step_02: "02. pool == NULL?" {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
    }
  }

  step_03: "03. return NULL\n(Invalid Handle)" {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      font-color: "#C62828"
    }
  }

  step_04: "04. free_list_head == NULL?" {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
    }
  }

  step_05: "05. grow_pool(pool)" {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
    }
    tooltip: "Invokes sbrk/mmap to expand physical backing."
  }

  step_06: "06. grow succeeded?" {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
    }
  }

  step_07: "07. pthread_mutex_unlock()\nreturn NULL" {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      font-color: "#C62828"
      bold: true
    }
  }

  step_08: |md
    ### 08. Pop Block (O(1))
    `block = pool->free_list_head`
    **`pool->free_list_head = *(void**)block`**
    `pool->allocated++`
  | {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }

  step_09: "09. index = find_block_index(pool, block)" {
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
  }

  step_10: "10. index >= 0?" {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
    }
  }

  step_11: "11. bitmap_set(allocated_map, index)" {
    shape: rectangle
    style: {
      fill: "#E0F7FA"
      stroke: "#00838F"
    }
  }

  step_12: "12. pthread_mutex_unlock(&pool->mutex)" {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      bold: true
    }
  }

  step_13: "13. DEBUG INSTRUMENTATION:\ncheck_poison(block)\nwrite_canaries(block)" {
    shape: rectangle
    style: {
      fill: "#FCE4EC"
      stroke: "#AD1457"
      stroke-dash: 3
    }
  }

  step_14: "14. return block" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 4
    }
  }

  end: ● {
    shape: circle
    style.fill: "#1565C0"
    style.stroke: "#0D47A1"
  }

  # --- FLOW CONNECTIONS ---
  start -> step_01: "CALL pool_alloc()"
  step_01 -> step_02
  step_02 -> step_03: "TRUE"
  step_02 -> step_04: "FALSE"

  step_04 -> step_05: "TRUE\n(Exhausted)"
  step_04 -> step_08: "FALSE\n(Available)"

  step_05 -> step_06
  step_06 -> step_07: "FALSE\n(ENOMEM)"
  step_06 -> step_08: "TRUE\n(Grown)"

  step_08 -> step_09
  step_09 -> step_10
  step_10 -> step_11: "TRUE"
  step_10 -> step_12: "FALSE\n(Corrupt)"

  step_11 -> step_12
  step_07 -> end: "ERROR EXIT"
  step_12 -> step_13
  step_13 -> step_14
  step_14 -> end: "SUCCESS"
  step_03 -> end
}

# --- ANNOTATIONS (COMPASS FIX) ---

mutex_note: |md
  ### Mutex Guarantees
  - **Atomicity:** `free_list_head`
  - **Consistency:** `allocated` counter
  - **Thread-Safety:** `allocated_map`
  - **Serialization:** `grow_pool()`
| {
  near: top-right
  style.fill: "#E3F2FD"
}

safety_note: |md
  ### Liveness Requirement
  Every return path **MUST** call 
  `pthread_mutex_unlock` to avoid 
  permanent deadlock of the pool.
| {
  near: center-right
  style.fill: "#FFEBEE"
}

perf_note: |md
  ### Algorithm Complexity
  **Time:** O(1) - List pop.
  **Space:** O(1) - Bitmap update.
  No linear scans required.
| {
  near: bottom-right
  style.fill: "#E8F5E9"
}

debug_note: |md
  ### Instrumentation
  Performed **AFTER** unlock
  to minimize mutex hold time.
  Safely operates on local var.
| {
  near: bottom-left
  style.fill: "#FCE4EC"
}

# --- LEGEND ---
legend: {
  near: bottom-center
  direction: right
  
  l1: "Mutex Op" { style.fill: "#E3F2FD"; style.stroke: "#1565C0" }
  l2: "Decision" { shape: diamond; style.fill: "#FFF3E0"; style.stroke: "#EF6C00" }
  l3: "State Mod" { style.fill: "#E8F5E9"; style.stroke: "#2E7D32" }
  l4: "Termination" { style.fill: "#FFEBEE"; style.stroke: "#C62828" }
}

# --- STYLING GLOBAL ---
***.style.font: mono
***.style.border-radius: 4