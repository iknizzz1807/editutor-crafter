vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  # Base byte styles for spreading to avoid D2 class nesting error
  byte_defaults: {
    shape: square
    width: 35
    height: 35
    style: {
      font: mono
      font-size: 11
    }
  }
}

title: |md
  # Poison Detection Workflow
  **Memory Pool Debug Feature: Use-After-Free Write Detection**
  *Implementation Specification for Pool Debug Mode*
| {near: top-center}

direction: right

classes: {
  pool_block: {
    shape: rectangle
    width: 400
    height: 220
    style: {
      fill: "#F7FAFC"
      stroke: "#2C5282"
      stroke-width: 2
      shadow: true
    }
  }
  step_box: {
    shape: rectangle
    style: {
      fill: "#EBF8FF"
      stroke: "#3182CE"
      stroke-width: 2
      border-radius: 4
    }
  }
  success_box: {
    shape: rectangle
    style: {
      fill: "#C6F6D5"
      stroke: "#38A169"
      stroke-width: 2
      border-radius: 4
    }
  }
  error_box: {
    shape: rectangle
    style: {
      fill: "#FED7D7"
      stroke: "#C53030"
      stroke-width: 2
      border-radius: 4
    }
  }
  # Refactored byte classes without internal "class" key
  poison_byte: {
    ...${byte_defaults}
    style: {
      fill: "#9AE6B4"
      stroke: "#276749"
    }
  }
  user_byte: {
    ...${byte_defaults}
    style: {
      fill: "#FBD38D"
      stroke: "#B7791F"
    }
  }
  corrupted_byte: {
    ...${byte_defaults}
    style: {
      fill: "#FC8181"
      stroke: "#C53030"
      bold: true
    }
  }
}

FREE_PHASE: "PHASE 1: pool_free(ptr)" {
  style.fill: "#F0F9FF"
  style.stroke: "#3182CE"
  style.stroke-width: 3

  step1_free: "1. User calls pool_free()\nVerify ptr belongs to pool" {
    class: step_box
  }

  allocated_block: "Allocated Block\n(User Data at 0x...)" {
    class: pool_block
    row0: {
      grid-columns: 8
      b00: "01" {class: user_byte}
      b01: "02" {class: user_byte}
      b02: "03" {class: user_byte}
      b03: "04" {class: user_byte}
      b04: "05" {class: user_byte}
      b05: "06" {class: user_byte}
      b06: "07" {class: user_byte}
      b07: "08" {class: user_byte}
    }
    row1: {
      grid-columns: 8
      b10: "09" {class: user_byte}
      b11: "0A" {class: user_byte}
      b12: "0B" {class: user_byte}
      b13: "0C" {class: user_byte}
      b14: "0D" {class: user_byte}
      b15: "0E" {class: user_byte}
      b16: "0F" {class: user_byte}
      b17: "10" {class: user_byte}
    }
    note1: "Block contains valid\napplication state" {
      shape: text
      style.italic: true
    }
  }

  step2_poison: "2. Apply Poison Pattern\nmemset(ptr, 0xDE, size)" {
    class: step_box
  }

  poisoned_block: "Freed Block\n(Poisoned Status)" {
    class: pool_block
    prow0: {
      grid-columns: 8
      pb00: "DE" {class: poison_byte}
      pb01: "DE" {class: poison_byte}
      pb02: "DE" {class: poison_byte}
      pb03: "DE" {class: poison_byte}
      pb04: "DE" {class: poison_byte}
      pb05: "DE" {class: poison_byte}
      pb06: "DE" {class: poison_byte}
      pb07: "DE" {class: poison_byte}
    }
    prow1: {
      grid-columns: 8
      pb10: "DE" {class: poison_byte}
      pb11: "DE" {class: poison_byte}
      pb12: "DE" {class: poison_byte}
      pb13: "DE" {class: poison_byte}
      pb14: "DE" {class: poison_byte}
      pb15: "DE" {class: poison_byte}
      pb16: "DE" {class: poison_byte}
      pb17: "DE" {class: poison_byte}
    }
    note2: "All user bytes overwritten\nwith 0xDE" {
      shape: text
      style.italic: true
    }
  }

  step3_push: "3. Push to Free List\nNext pointer overwrites\nfirst 8 bytes" {
    class: step_box
  }

  step1_free -> allocated_block -> step2_poison -> poisoned_block -> step3_push
}

CORRUPTION_PHASE: "PHASE 2: Illegal Use-After-Free Write" {
  style.fill: "#FFF5F5"
  style.stroke: "#C53030"
  style.stroke-width: 3

  bug_step: "⚠️ BUG: User Write\n*ptr = 0xDEADBEEF" {
    class: error_box
    style: {
      bold: true
    }
  }

  corrupted_block: "Corrupted Memory\n(In-Situ Link List)" {
    class: pool_block
    style.stroke: "#C53030"
    crow0: {
      grid-columns: 8
      cb00: "EF" {class: corrupted_byte}
      cb01: "BE" {class: corrupted_byte}
      cb02: "AD" {class: corrupted_byte}
      cb03: "DE" {class: corrupted_byte}
      cb04: "DE" {class: poison_byte}
      cb05: "DE" {class: poison_byte}
      cb06: "DE" {class: poison_byte}
      cb07: "DE" {class: poison_byte}
    }
    crow1: {
      grid-columns: 8
      cb10: "DE" {class: poison_byte}
      cb11: "DE" {class: poison_byte}
      cb12: "DE" {class: poison_byte}
      cb13: "DE" {class: poison_byte}
      cb14: "DE" {class: poison_byte}
      cb15: "DE" {class: poison_byte}
      cb16: "DE" {class: poison_byte}
      cb17: "DE" {class: poison_byte}
    }
    note3: "Poison pattern at offset 0\nbroken by user write" {
      shape: text
      style.font-color: "#C53030"
    }
  }

  bug_step -> corrupted_block
}

ALLOC_PHASE: "PHASE 3: pool_alloc() Validation" {
  style.fill: "#F0FFF4"
  style.stroke: "#276749"
  style.stroke-width: 3

  step4_alloc: "4. pool_alloc() requested\nPop block from Free List" {
    class: step_box
  }

  step5_scan: "5. Integrity Scan\nValidate 0xDE pattern" {
    class: step_box
  }

  decision: "Block integrity\nintact?" {
    shape: diamond
    style: {
      fill: "#FEFCBF"
      stroke: "#B7791F"
    }
  }

  error_path: "✗ FAIL: Integrity Error" {
    class: error_box
  }

  error_report: "DEBUG LOG:\nUAF Write detected at\nblock 0x... offset 0x00" {
    class: error_box
    style: {
      font: mono
      font-size: 11
    }
  }

  success_path: "✓ PASS: Block Clean" {
    class: success_box
  }

  step6_return: "6. Zero out & Return\nmemset(ptr, 0, size)" {
    class: success_box
  }

  step4_alloc -> step5_scan -> decision
  decision -> error_path: "No"
  decision -> success_path: "Yes"
  error_path -> error_report
  success_path -> step6_return
}

FREE_PHASE -> CORRUPTION_PHASE -> ALLOC_PHASE: "Timeline"

legend: "DIAGRAM LEGEND" {
  style.fill: "#F7FAFC"
  style.stroke: "#A0AEC0"
  
  l1: "Poison Pattern (0xDE)" {
    class: poison_byte
  }
  l2: "User Data (Valid)" {
    class: user_byte
  }
  l3: "Corruption (UAF)" {
    class: corrupted_byte
  }
}

legend_meta: |md
  ### Integrity Rules
  1. **Poisoning:** Performed on `pool_free()`.
  2. **Validation:** Performed on `pool_alloc()`.
  3. **Pattern:** `0xDE` (Decimal 222).
  4. **Detection:** Identifies writes between free and allocation.
| {near: bottom-center}

code_implementation: |go
  // Validate function called during pool_alloc
  func debugCheckPoison(block []byte) {
      // First 8 bytes might be linked-list pointer
      for i := 8; i < len(block); i++ {
          if block[i] != 0xDE {
              panic(fmt.Sprintf("UAF Detected at offset %d", i))
          }
      }
  }
| {near: bottom-center}