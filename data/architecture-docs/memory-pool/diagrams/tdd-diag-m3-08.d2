layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # CANARY BLOCK LAYOUT (TDD-M3-08)
  ### Memory Safety & Integrity Verification System
  Architecture for overflow and underflow detection via guard values.
  **sizeof = N bytes**
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------
# 1. MEMORY LAYOUT REPRESENTATION
# -----------------------------------------------------------------------------
block_container: {
  label: "Physical Memory Allocation Map"
  style: {
    fill: "#F8F9FA"
    stroke: "#DEE2E6"
    stroke-width: 2
  }

  # Visual representation of the contiguous memory buffer
  block_frame: {
    grid-columns: 3
    grid-gap: 0
    
    front_canary: |md
      **FRONT CANARY**
      `0x00`: [8 Bytes]
      `Value: 0xCAFEBABE...`
    | {
      tooltip: "Offset: 0x00 | Size: 8 bytes | Type: uint64_t"
      style: {
        fill: "#E8D5E8" # Purple: Header
        stroke: "#8B4789"
        stroke-width: 2
      }
      width: 200
      height: 120
    }

    user_data: |md
      **USER PAYLOAD SPACE**
      `Offset: 0x08`
      `Size: (N - 16) Bytes`
      *Valid Data Region*
    | {
      tooltip: "Offset: 0x08 | Size: N-16 bytes | Type: raw_data"
      style: {
        fill: "#D4E6F1" # Blue: Data
        stroke: "#2874A6"
        stroke-width: 2
      }
      width: 350
      height: 120
    }

    back_canary: |md
      **BACK CANARY**
      `Offset: N-8`
      `Value: 0xDEADBEEF...`
    | {
      tooltip: "Offset: N-8 | Size: 8 bytes | Type: uint64_t"
      style: {
        fill: "#E8D5E8" # Purple: Header/Metadata
        stroke: "#8B4789"
        stroke-width: 2
      }
      width: 200
      height: 120
    }
  }

  # Mapping offsets to the visual blocks above
  offset_labels: {
    grid-columns: 3
    grid-gap: 0
    style.stroke-width: 0
    
    o0: "0x00\n[Internal Start]" {
      style.font-size: 12
      width: 200
    }
    o8: "0x08\n[User Pointer]" {
      style: {
        font-size: 12
        font-color: "#D35400" # Orange: Pointers
        bold: true
      }
      width: 350
    }
    on: "N-0x08\n[Tail Guard]" {
      style.font-size: 12
      width: 200
    }
  }
}

# -----------------------------------------------------------------------------
# 2. IMPLEMENTATION LOGIC (Sequence Diagrams)
# -----------------------------------------------------------------------------
pointer_adjustment: {
  label: "Pointer Arithmetic & Lifecycle Management"
  style: {
    fill: "#FFF9E6"
    stroke: "#D4AC0D"
    stroke-width: 1
  }

  alloc_flow: {
    shape: sequence_diagram
    pool: MemoryPool
    block: Raw Memory
    user: App Caller
    
    pool -> block: "malloc(N bytes)"
    block -> block: "Write MAGIC at head [0x00]"
    block -> block: "Write MAGIC at tail [N-8]"
    block -> user: "return (base_ptr + 8)"
    user."Note: App receives pointer to user_data segment only."
  }

  free_flow: {
    shape: sequence_diagram
    user: App Caller
    monitor: Verifier
    pool: MemoryPool
    system: Runtime
    
    user -> monitor: "free(user_ptr)"
    monitor -> monitor: "base = user_ptr - 8"
    monitor -> monitor: "front_val = *base"
    monitor -> monitor: "back_val = *(base + N - 8)"
    
    monitor -> monitor: "Verify: val == MAGIC"
    
    monitor -> pool: "OK: release(base)" {
      style.stroke: "#2ECC71"
      target-arrowhead.style.filled: true
    }
    
    monitor -> system: "ERROR: Corrupt! Panic()" {
      style: {
        stroke: "#E74C3C"
        stroke-width: 3
      }
    }
  }
}

# -----------------------------------------------------------------------------
# 3. ANALYSIS & SPECIFICATIONS (FIXED SYNTAX)
# -----------------------------------------------------------------------------
detection_table: {
  label: "Integrity Analysis Matrix"
  style: {
    fill: "#F4F4F4"
    stroke: "#666666"
  }

  # Using unique block string delimiters to avoid conflict with markdown pipes
  info: |'md'
    | Corruption Vector | Sentinel Affected | Detection Latency | Mechanism |
    |-------------------|-------------------|-------------------|-----------|
    | **Buffer Overflow** | Back Canary | Late (at `free`) | Tail Guard Mismatch |
    | **Buffer Underflow** | Front Canary | Late (at `free`) | Head Guard Mismatch |
    | **Heap Spray** | Both | Non-deterministic | Pattern Overwrite |

    **Sentinel Magic:** `0xCAFEBABEDEADBEEF`
    - High entropy: Reduced collision probability.
    - Non-zero: Detects unintended `bzero` resets.
  '| {
    shape: text
  }
}

# -----------------------------------------------------------------------------
# 4. CODE IMPLEMENTATION MACROS (FIXED SYNTAX)
# -----------------------------------------------------------------------------
constants: {
  label: "Technical Implementation Macros (C99/C11)"
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
  }

  code: |'c'
    #define CANARY_VAL  0xCAFEBABEDEADBEEFULL
    #define CANARY_SIZE sizeof(uint64_t)

    /**
     * @brief Translates user pointer to allocation start.
     */
    #define GET_BLOCK_START(user_ptr) \
      ((void*)((uint8_t*)(user_ptr) - CANARY_SIZE))
      
    /**
     * @brief Locates trailing canary.
     */
    #define GET_BACK_CANARY(start, total_size) \
      ((uint64_t*)((uint8_t*)(start) + (total_size) - CANARY_SIZE))
  '| {
    shape: text
  }
}

# -----------------------------------------------------------------------------
# 5. ANNOTATIONS & RELATIONSHIPS
# -----------------------------------------------------------------------------
block_container -> pointer_adjustment: "Protocol applied to"
pointer_adjustment -> detection_table: "Logic derivation"
detection_table -> constants: "Source definition"

block_container.block_frame.user_data -> cache_line_hint: {style.stroke-dash: 5}
cache_line_hint: "Aligned to 64B cache line boundary" {
  shape: text
  style.font-size: 10
  style.font-color: "#7F8C8D"
}