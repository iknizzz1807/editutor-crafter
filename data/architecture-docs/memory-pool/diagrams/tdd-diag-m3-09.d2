direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- PAGE HEADER ---
header: |md
  # Canary Verification on Free
  ### Technical Specification: Memory Safety Enforcement (M3-Safety-09)
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 18
  }
}

# --- MEMORY LAYOUT DIAGRAM ---
# Intel Manual Style: Byte-accurate sequential layout
memory_layout: "Physical Memory Block Layout (64B)" {
  style: {
    stroke-width: 2
    fill: "#F8F8F8"
  }

  layout: {
    grid-columns: 1
    grid-gap: 0

    front_canary: "0x00 | Front Canary (Magic: 0xCAFEBABEDEADBEEF)" {
      height: 60
      style: {
        fill: "#E8D4F0" # Purple Header
        stroke-width: 2
        bold: true
      }
    }

    user_data: "0x08 | User Data Payload (48 Bytes)" {
      height: 120
      style: {
        fill: "#C7E6FA" # Blue Data
        stroke-dash: 0
      }
    }

    back_canary: "0x38 | Back Canary (Magic: 0xCAFEBABEDEADBEEF)" {
      height: 60
      style: {
        fill: "#E8D4F0" # Purple Header
        stroke-width: 2
        bold: true
      }
    }
    
    footer_offset: "0x40 | End of Block Boundary" {
      style: {
        stroke-width: 0
        fill: "transparent"
        font-color: "#666666"
        italic: true
      }
    }
  }

  annotations: |md
    **Layout Specifications:**
    - **Header Size**: 8 bytes (uint64_t)
    - **Footer Size**: 8 bytes (uint64_t)
    - **Payload Size**: Variable (here 48B)
    - **Total Block Size**: 64 bytes (Exact Cache Line)
    - **Alignment**: 8-byte boundary
  | {
    style.font-size: 12
  }
}

# --- ALGORITHM STATE DIAGRAM ---
# State machine for the pool_free() validation gate
verification_logic: "Algorithm: pool_free() Canary Validation" {
  
  step1: "1. Address Translation" {
    shape: rectangle
    label: "uint8_t *block_start = (uint8_t*)ptr - 8"
    style: {
      fill: "#F5F5F5"
      font: mono
    }
  }

  step2: "2. Load Invariants" {
    shape: rectangle
    label: "v_front = *(uint64_t*)block_start\nv_back = *(uint64_t*)(block_start + payload_size + 8)"
    style: {
      fill: "#F5F5F5"
      font: mono
    }
  }

  step3: "3. Verification Gate" {
    shape: diamond
    label: "Check Magic Values"
    tooltip: "Verify v_front == MAGIC && v_back == MAGIC"
    style.fill: "#FFF9C4"
  }

  step4_fail: "4. Raise Critical Exception" {
    shape: rectangle
    label: "PANIC: Heap Corruption Detected\nCall kprintf_trace() & abort()"
    style: {
      fill: "#FFCDD2" # Red Error
      stroke: "#B71C1C"
      font-color: "#B71C1C"
      bold: true
      stroke-width: 3
    }
  }

  step4_pass: "4. Proceed to Deallocation" {
    shape: rectangle
    label: "Zero out memory area\nAppend to Free List"
    style: {
      fill: "#C8E6C9" # Green Free
      stroke: "#2E7D32"
    }
  }

  step1 -> step2: "Next"
  step2 -> step3: "Compare"
  step3 -> step4_fail: "Mismatch (RED)" {
    style: {
      stroke: "#B71C1C"
      stroke-width: 3
      animated: true
    }
  }
  step3 -> step4_pass: "Match (OK)" {
    style: {
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }
}

# --- POINTER ARITHMETIC ---
pointer_math: "Pointer Arithmetic Logic" {
  direction: down
  
  user_ptr: "user_ptr (0x...08)" {
    shape: circle
    style.fill: "#FFECB3" # Orange Pointer
  }
  
  offset_op: "Subtract 8 Bytes" {
    shape: parallelogram
    style.font: mono
  }
  
  internal_ptr: "block_ptr (0x...00)" {
    shape: circle
    style.fill: "#C8E6C9"
  }

  user_ptr -> offset_op: "Input to free()"
  offset_op -> internal_ptr: "Resulting Handle"
}

# --- TRACE CONNECTIONS ---
memory_layout.layout.front_canary -> verification_logic.step2: "Read Header" {
  style: {
    stroke: "#9C27B0"
    stroke-dash: 5
  }
}
memory_layout.layout.back_canary -> verification_logic.step2: "Read Footer" {
  style: {
    stroke: "#9C27B0"
    stroke-dash: 5
  }
}

# --- COMPREHENSIVE SUMMARY ---
# Explicitly set shape: rectangle to allow double-border styling
summary_box: |md
  ### Implementation Invariants
  - **Front Guard**: Detects heap underflow (buffer start violations).
  - **Back Guard**: Detects heap overflow (buffer end violations).
  - **Entropy**: Canary values should ideally be randomized per boot.
  - **Size Logic**: `sizeof(block) = user_requested_size + 16`.
| {
  shape: rectangle
  near: bottom-center
  style: {
    fill: "#FDF5E6"
    stroke: "#DAA520"
    double-border: true
  }
}

# --- LEGEND ---
legend: "Engineer's Legend" {
  near: bottom-right
  canary: "Canary Field" { style.fill: "#E8D4F0" }
  data: "User Data" { style.fill: "#C7E6FA" }
  ptr: "Pointer Variable" { style.fill: "#FFECB3" }
  state_err: "Error/Illegal" { style.fill: "#FFCDD2" }
  state_ok: "Safe/Free" { style.fill: "#C8E6C9" }
}