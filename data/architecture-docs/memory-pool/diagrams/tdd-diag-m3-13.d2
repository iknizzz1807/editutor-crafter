d2
direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  title: "pool_alloc() with Mutex Flow" {near: top-center}
subgraph: "Thread Context" {
  style.fill: "#E8F4F8"
  style.stroke: "#1a73c8"
  style.font-size: 14
  style.font-color: "#4a5568"
}
  stack_frame: {
    shape: rectangle
    style.fill: white
    style.stroke: "#dee2e6"
    width: 600
    label: ""
  }
  ThreadContext: "ThreadContext struct" {
    shape: class
    style.fill: "#DBEAFE"
    style.stroke: "#1a73c8"
    width: 280
    pool: "MemoryPool* pool"
    thread_id: "int thread_id"
    ops_completed: "size_t ops_completed"
    held_blocks: "void* held_blocks[10]"
    held_count: "size_t held_count"
    corruption_detected: "size_t corruption_detected"
  }
  note: |md
    Each thread maintains local state
    to verify data integrity
  |
}
subgraph: "Critical Section: pool_alloc()" {
  style.fill: "#FEF3C7"
  style.stroke: "#EF4444"
  style.stroke-width: 2
  alloc_entry: "Enter pool_alloc()" {
    shape: rectangle
    style.fill: "#DBEAFE"
  }
  null_check: "pool == NULL?" {
    shape: diamond
  }
  lock_acquire: "pthread_mutex_lock(&pool->mutex)" {
    shape: rectangle
    style.fill: "#FDE68A"
    style.bold: true
  }
  check_free: "free_list_head == NULL?" {
    shape: diamond
  }
  grow_attempt: "grow_pool(pool)?" {
    shape: diamond
  }
  pop_block: "Pop block from free list" {
    shape: rectangle
    style.fill: "#BBF7D0"
  }
  update_bitmap: "bitmap_set(allocated_map, index)" {
    shape: rectangle
    style.fill: "#BBF7D0"
  }
  lock_release: "pthread_mutex_unlock(&pool->mutex)" {
    shape: rectangle
    style.fill: "#FDE68A"
    style.bold: true
  }
  return_block: "Return block pointer" {
    shape: rectangle
    style.fill: "#D1FAE5"
  }
  return_null: "Return NULL" {
    shape: rectangle
    style.fill: "#FEE2E2"
  }
  alloc_entry -> null_check
  null_check -> lock_acquire: "No"
  null_check -> return_null: "Yes"
  lock_acquire -> check_free
  check_free -> grow_attempt: "Yes"
  check_free -> pop_block: "No"
  grow_attempt -> pop_block: "Success"
  grow_attempt -> lock_release: "Fail"
  pop_block -> update_bitmap
  update_bitmap -> lock_release
  lock_release -> return_block
}
debug_section: "Debug Checks (after unlock)" {
  shape: rectangle
  style.fill: "#E0E7FF"
  style.stroke: "#3B82F6"
  style.stroke-dash: 3
  width: 280
  label: |md
    #ifdef POOL_DEBUG
    if (use_poison) {
      check_poison(block);
    }
    if (use_canaries) {
      write_canaries(block);
      return block + CANARY_SIZE;
    }
    #endif
    return block;
  |
}
subgraph: "Shared Mutable State" {
  style.fill: "#F3E4E6"
  style.stroke: "#6B7280"
  free_list_head: "free_list_head\n(void*)" {
    shape: cylinder
    style.fill: "#FCD34D"
  }
  allocated_counter: "allocated\n(size_t)" {
    shape: cylinder
    style.fill: "#FCD34D"
  }
  allocated_map: "allocated_map\n(uint64_t*)" {
    shape: cylinder
    style.fill: "#FCD34D"
  }
  mutex_state: "mutex\n(pthread_mutex_t)" {
    shape: circle
    style.fill: "#EF4444"
    style.stroke: "#DC2626"
    style.stroke-width: 3
  }
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: white
  style.stroke: "#9CA3AF"
  width: 500
  legend_title: "Legend" {
    style.bold: true
  }
  lock_acq: "Lock Acquire/Release"
  unlock: "Unlock on ALL paths"
  debug: "Debug (compiled out)"
}
lock_acq.class: lock_acq
unlock.class: unlock
debug.class: debug
classes: {
  lock_acq: {
    style: {
      fill: "#FDE68A"
      bold: true
    }
  }
  unlock: {
    style: {
      fill: "#FDE68A"
      bold: true
    }
  }
  debug: {
    style: {
      fill: "#E0E7FF"
      stroke-dash: 3
    }
  }
}