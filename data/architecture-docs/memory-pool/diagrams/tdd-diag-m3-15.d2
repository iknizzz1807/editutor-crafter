vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # ABA Problem in Lock-Free Free Lists
  ## Why CAS (Compare-And-Swap) Can Succeed Incorrectly
| {near: top-center}

direction: right

# ============================================
# CLASSES & STYLING
# ============================================
classes: {
  free_node: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 4
    }
  }
  target_node: {
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 3
      bold: true
    }
  }
  corrupt_node: {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 3
    }
  }
  thread_actor: {
    shape: circle
    style: {
      font-color: white
      bold: true
      shadow: true
    }
  }
  pointer_label: {
    shape: text
    style: {
      font: mono
      bold: true
    }
  }
}

# ============================================
# INITIAL STATE
# ============================================
initial_state: {
  label: "T=0: STABLE STATE"
  style.stroke-dash: 5
  
  header: |md
    ### Linked List
    `head` points to A.
    Free list is healthy.
  |

  head_ptr: "free_list_head" {class: pointer_label}
  
  block_a: {
    class: free_node
    label: "Node A\nptr: 0x1000\nnext: 0x1040"
  }
  block_b: {
    class: free_node
    label: "Node B\nptr: 0x1040\nnext: 0x1080"
  }
  block_c: {
    class: free_node
    label: "Node C\nptr: 0x1080\nnext: NULL"
  }

  head_ptr -> block_a: {style.stroke: "#1565C0"; style.stroke-width: 3}
  block_a -> block_b: {style.stroke: "#666"}
  block_b -> block_c: {style.stroke: "#666"}
}

# ============================================
# STEP 1: READ
# ============================================
step1: {
  label: "T=1: THREAD 1 SNAPSHOT"
  style.stroke-dash: 5

  header: |md
    ### T1 Reads State
    T1 reads `head` (A) and `A.next` (B).
    **Context Switch occurs now.**
  |

  head_ptr: "free_list_head" {class: pointer_label}
  
  block_a: {
    class: target_node
    label: "Node A\n[Snapshot: 0x1000]"
  }
  block_b: {
    class: target_node
    label: "Node B\n[Snapshot: 0x1040]"
  }

  t1: "Thread 1" {
    class: thread_actor
    style.fill: "#FF9800"
  }

  head_ptr -> block_a
  t1 -> block_a: "reads A" {style.stroke-dash: 3}
  t1 -> block_b: "reads A.next" {style.stroke-dash: 3}
  
  note: |md
    **T1 Register State:**
    - `old_val` = 0x1000 (A)
    - `new_val` = 0x1040 (B)
  | {
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
  }
}

# ============================================
# STEP 2: ABA MODIFICATION
# ============================================
step2: {
  label: "T=2: THREAD 2 INTERFERENCE"
  style.stroke-dash: 5

  header: |md
    ### ABA Sequence
    1. T2 pops A, pops B.
    2. T2 pushes A back.
    `head` is A again, but list is changed.
  |

  head_ptr: "free_list_head" {class: pointer_label}
  
  block_x: {
    class: free_node
    label: "Node X\nptr: 0x9000\nnext: 0x1000"
  }
  block_a: {
    class: corrupt_node
    label: "Node A\nptr: 0x1000\nnext: 0x1080"
  }
  block_b: "Node B\n(ALLOCATED)" {
    style.fill: "#B0BEC5"
    style.stroke: "#455A64"
    style.font-color: "#455A64"
  }
  block_c: {class: free_node; label: "Node C"}

  t2: "Thread 2" {
    class: thread_actor
    style.fill: "#4CAF50"
  }

  head_ptr -> block_x
  block_x -> block_a
  block_a -> block_c: "Changed!" {style.stroke: "#C62828"; style.stroke-width: 2}
  
  t1_shadow: "T1 (Asleep)" {
    class: thread_actor
    style.fill: "#9E9E9E"
  }
  t1_shadow -> block_a: "Holding stale B ptr" {style.stroke: "#9E9E9E"; style.stroke-dash: 2}
}

# ============================================
# STEP 3: CAS SUCCESS (CORRUPTION)
# ============================================
step3: {
  label: "T=3: FATAL CAS COMPLETION"
  style.stroke-dash: 5

  header: |md
    ### CAS Succeeds
    T1 resumes. `head` is A? Yes.
    T1 sets `head` to B.
    **CRITICAL FAILURE.**
  |

  head_ptr: "free_list_head" {class: pointer_label}
  
  block_b: {
    class: corrupt_node
    label: "Node B\nIN USE BY T2!"
    style.fill: "#FFCDD2"
  }
  
  block_c: "Node C\n(ORPHANED)" {style.opacity: 0.4}
  block_a: "Node A\n(LEAKED)" {style.opacity: 0.4}

  t1_exec: "T1 Resumes" {
    class: thread_actor
    style.fill: "#D32F2F"
  }

  head_ptr -> block_b: "CORRUPT POINTER" {
    style.stroke: "#C62828"
    style.stroke-width: 4
  }
  
  t1_exec -> head_ptr: "CAS(A, B) -> OK" {style.stroke: "#D32F2F"}
  
  failure_note: |md
    **SYSTEM CORRUPTED**
    - `head` points to allocated memory.
    - Node C is lost (Memory Leak).
    - Next caller gets a dirty pointer.
  | {
    style.fill: "#FFCDD2"
    style.stroke: "#B71C1C"
    style.font-color: "#B71C1C"
    style.bold: true
  }
}

# ============================================
# GLOBAL CONNECTIONS & ANNOTATIONS
# ============================================

initial_state -> step1: "Thread 1 Scheduled"
step1 -> step2: "Preemption / T2 Runs"
step2 -> step3: "T1 Resumes Execution"

summary: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#424242"
    stroke-width: 2
    shadow: true
  }
  content: |md
    ## The ABA Essence
    - Semantic check (Value A) passed.
    - Logical state (Chain integrity) failed.
    - Physical pointer A was reused while B was removed.

    ## Hardened Fixes
    1. **Hazard Pointers**: T1 marks A as "In-Use" so T2 cannot re-add it to the list yet.
    2. **Tagged Pointers**: Store `(Pointer, Version)`. CAS checks both. `(A, 1)` != `(A, 2)`.
    3. **LL/SC**: Load-Link/Store-Conditional hardware primitives.
  |
}

legend: {
  near: top-right
  style.fill: "#F5F5F5"
  
  free: "Free Node" {class: free_node}
  target: "T1 Target" {class: target_node}
  fail: "Corrupted/Invalid" {class: corrupt_node}
}

# Style overrides for specific connections in step 3
(step3.head_ptr -> step3.block_b)[0].style.animated: true
(step3.head_ptr -> step3.block_b)[0].style.stroke: red