vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Detailed Leak Report Format
  ## pool_destroy() Leak Detection Algorithm
| {near: top-center}

direction: right

# Input State
input_state: "Input State" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"

  bitmap_state: "allocated_map Bitmap" {
    shape: sql_table
    style.fill: "#F5E6FF"
    word0: "uint64_t word0" {constraint: "bits 0-63"}
    word1: "uint64_t word1" {constraint: "bits 64-127"}
    word2: "uint64_t word2" {constraint: "bits 128-191"}
  }

  pool_fields: "MemoryPool Fields" {
    shape: class
    chunks: "Chunk*"
    total_capacity: "size_t"
    allocated: "size_t > 0"
    map_size: "size_t"
  }

  bitmap_state -> pool_fields
}

# Chunk Registry
chunk_registry: "Chunk Registry" {
  style.fill: "#E8F4FF"
  style.stroke: "#4A90D9"

  chunk0: "Chunk 0" {
    shape: class
    memory: "void* = 0x1000"
    num_blocks: "size_t = 100"
    next: "Chunk* → chunk1"
  }

  chunk1: "Chunk 1" {
    shape: class
    memory: "void* = 0x5000"
    num_blocks: "size_t = 100"
    next: "Chunk* → NULL"
  }

  chunk0 -> chunk1: "next"
}

# Algorithm Flow
algorithm: "Leak Detection Algorithm" {
  style.fill: "#FFF8E8"
  style.stroke: "#D4A500"

  step1: "Step 1: Check allocated > 0" {
    style.fill: "#FFE4B5"
    shape: diamond
  }

  step2: "Step 2: Iterate Bitmap" {
    style.fill: "#98FB98"
    label: |md
      c
      for (i = 0; i < total_capacity; i++) {
        if (bitmap_test(map, i)) {
          // Block i is leaked
        }
      }
      
    |
  }

  step3: "Step 3: Find Chunk for Index" {
    style.fill: "#98FB98"
    label: |md
      c
      blocks_scanned = 0
      for chunk in chunks:
        if i < blocks_scanned + chunk->num_blocks:
          // Block is in this chunk
          local_idx = i - blocks_scanned
          break
        blocks_scanned += chunk->num_blocks
      
    |
  }

  step4: "Step 4: Calculate Address" {
    style.fill: "#98FB98"
    label: |md
      c
      address = (char*)chunk->memory + 
                (local_idx * block_size)
      
    |
  }

  step5: "Step 5: Print Report Line" {
    style.fill: "#98FB98"
    label: |md
      c
      fprintf(stderr, 
        "  [%zu] %p\n", 
        global_idx, address)
      
    |
  }

  step1 -> step2: "Yes"
  step2 -> step3: "bit == 1"
  step3 -> step4
  step4 -> step5
  step5 -> step2: "next bit"
}

# Output Format
output: "stderr Output Format" {
  style.fill: "#FFE4E4"
  style.stroke: "#D9534F"

  header: {
    label: |md
      pool_destroy: WARNING: 3 blocks still allocated!
      Leaked blocks:
    |
  }

  line1: {
    style.fill: "#FFCCCC"
    label: "  [12] 0x1000"
  }

  line2: {
    style.fill: "#FFCCCC"
    label: "  [45] 0x11C0"
  }

  line3: {
    style.fill: "#FFCCCC"
    label: "  [150] 0x5800"
  }

  header -> line1
  line1 -> line2
  line2 -> line3
}

# Example Calculation
example: "Example: Index 150 → Address" {
  style.fill: "#E8FFE8"
  style.stroke: "#4CAF50"
  label: |md
    **Global Index: 150**
    1. **Chunk 0**: blocks 0-99 (num_blocks=100)
       - 150 >= 100? Yes, skip.
       - blocks_scanned = 100
    2. **Chunk 1**: blocks 100-199 (num_blocks=100)
       - 150 < 100 + 100? Yes!
       - local_idx = 150 - 100 = 50
       - address = 0x5000 + (50 * 64)
       - address = 0x5000 + 0xC80 = **0x5C80**
    **Output**: `[150] 0x5C80`
  |
}

# Connections
input_state.pool_fields -> algorithm.step1
chunk_registry.chunk0 -> algorithm.step3
algorithm.step5 -> output.line1

# Legend
legend: "Legend" {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#999999"

  bitmap_cell: "Bitmap Cell" {
    style.fill: "#F5E6FF"
  }
  chunk_cell: "Chunk Metadata" {
    style.fill: "#E8F4FF"
  }
  algo_cell: "Algorithm Step" {
    style.fill: "#98FB98"
  }
  output_cell: "Output Line" {
    style.fill: "#FFCCCC"
  }
}

# Code Reference
code_block: {
  style.fill: "#2D2D2D"
  style.font-color: "#FFFFFF"
  style.border-radius: 8
  label: |md
    ### Complete pool_destroy Implementation
    c
    void pool_destroy(MemoryPool* pool) {
        if (pool == NULL) return;
        pthread_mutex_lock(&pool->mutex);
        if (pool->allocated > 0) {
            fprintf(stderr, "pool_destroy: WARNING: %zu blocks still allocated!\n", pool->allocated);
    #ifdef POOL_DEBUG
            fprintf(stderr, "Leaked blocks:\n");
            size_t blocks_scanned = 0;
            for (Chunk* chunk = pool->chunks; chunk != NULL; chunk = chunk->next) {
                for (size_t i = 0; i < chunk->num_blocks; i++) {
                    size_t global_idx = blocks_scanned + i;
                    if (bitmap_test(pool->allocated_map, global_idx)) {
                        void* block = (char*)chunk->memory + i * pool->block_size;
                        fprintf(stderr, "  [%zu] %p\n", global_idx, block);
                    }
                }
                blocks_scanned += chunk->num_blocks;
            }
    #endif
        }
        pthread_mutex_unlock(&pool->mutex);
        // ... resource cleanup logic ...
    }
    
  |
}