vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Debug Feature Detection Matrix
  Memory Pool M3 — Compile-Time and Runtime Feature Control
| {near: top-center}

direction: right

matrix: {
  grid-rows: 15
  grid-columns: 6
  grid-gap: 0

  # --- ROW 0: HEADER ---
  h_scenario: "Scenario" {
    style.fill: "#4A5568"
    style.font-color: white
    style.bold: true
    style.stroke: "#2D3748"
    width: 150
  }
  h_pool_debug: "POOL_DEBUG\n(Compile Macro)" {
    style.fill: "#4A5568"
    style.font-color: white
    style.bold: true
    style.stroke: "#2D3748"
    width: 120
  }
  h_poison: "use_poison\n(Runtime Flag)" {
