  # --- ROW 6: SPACER ---
  sep: "" { style: { fill: transparent; stroke: transparent }; height: 40 }
  sep2: "" { style: { fill: transparent; stroke: transparent } }
  sep3: "" { style: { fill: transparent; stroke: transparent } }
  sep4: "" { style: { fill: transparent; stroke: transparent } }
