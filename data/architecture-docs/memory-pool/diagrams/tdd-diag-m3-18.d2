  l2_canary: "✗ NO" {
    style.fill: "#FED7D7"
    style.font-color: "#C53030"
    style.stroke: "#FEB2B2"
  }
  l2_combined: "✓ YES" {
    style.fill: "#C6F6D5"
    style.font-color: "#276749"
    style.bold: true
    style.stroke: "#9AE6B4"
  }
  l2_notes: "Corrupts 0xDE pattern" {
    style.fill: "#EDF2F7"
    style.font-color: "#4A5568"
    style.stroke: "#E2E8F0"
  }
  l2_fill: "" {style.fill: "#EDF2F7"; style.stroke: "#E2E8F0"}

  # --- ROW 10: OVERFLOW ---
  l3_bug: "Buffer Overflow\n(Out-of-Bounds)" {
    style.fill: "#F7FAFC"
    style.font-color: "#2D3748"
    style.stroke: "#E2E8F0"
  }
  l3_poison: "✗ NO" {
    style.fill: "#FED7D7"
    style.font-color: "#C53030"
    style.stroke: "#FEB2B2"
  }
  l3_canary: "✓ YES" {
    style.fill: "#C6F6D5"
    style.font-color: "#276749"
    style.bold: true
    style.stroke: "#9AE6B4"
  }
  l3_combined: "✓ YES" {
    style.fill: "#C6F6D5"
    style.font-color: "#276749"
    style.bold: true
    style.stroke: "#9AE6B4"
