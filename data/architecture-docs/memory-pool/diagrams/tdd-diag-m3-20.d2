vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Production Observability Integration
  PoolStats → Metrics Export Pipeline
| {near: top-center}

direction: right

# Memory Pool Instance
pool_instance: MemoryPool Instance {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  internal_state: |md
    **Internal State**
    
    chunks: 0x7f8a...
    block_size: 64
    total_capacity: 10000
    allocated: 7234
    free_list_head: 0x7f8b...
    chunk_count: 10
  |
  mutex: pthread_mutex_t {
    shape: diamond
    style.fill: "#FFE4B5"
    style.stroke: "#DAA520"
    style.stroke-width: 2
    label: "🔒 mutex"
  }
}

# Statistics Collection
stats_collection: Statistics Collection {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  pool_get_stats: pool_get_stats() {
    shape: hexagon
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
    label: "pool_get_stats()\n[thread-safe]"
  }
  poolstats_struct: PoolStats Structure {
    shape: class
    style.fill: "#A5D6A7"
    total_blocks: "size_t total_blocks"
    allocated: "size_t allocated"
    free: "size_t free"
    chunk_count: "size_t chunk_count"
    block_size: "size_t block_size"
    total_bytes: "size_t total_bytes"
    overhead_bytes: "size_t overhead_bytes"
  }
  pool_get_stats -> poolstats_struct: populates {
    style.stroke: "#388E3C"
    style.stroke-width: 2
    style.animated: true
  }
}

# Metric Transformation
metric_transform: Metric Transformation {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  transformation: |'md
    **Metric Mapping**
    | PoolStats Field | Prometheus Metric |
    |-----------------|-------------------|
    | `allocated` | `pool_allocated_blocks` |
    | `free` | `pool_free_blocks` |
    | `total_capacity` | `pool_capacity_blocks` |
    | `chunk_count` | `pool_chunk_count` |
    | `total_bytes` | `pool_total_bytes` |
    | `overhead_bytes` | `pool_overhead_bytes` |
  '|
  metric_exporter: MetricExporter {
    shape: parallelogram
    style.fill: "#FFCC80"
    style.stroke: "#E65100"
    label: "MetricExporter\n\npoll_interval: 15s\nlabels: {pool_id, instance}"
  }
}

# Prometheus Metrics
prometheus_metrics: Prometheus Metrics {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  metric_allocated: |md
    **pool_allocated_blocks**
    promql
    # TYPE pool_allocated_blocks gauge
    pool_allocated_blocks{pool_id="main", instance="app-01"} 7234
    
  |
  metric_free: |md
    **pool_free_blocks**
    promql
    # TYPE pool_free_blocks gauge
    pool_free_blocks{pool_id="main", instance="app-01"} 2766
    
  |
  metric_capacity: |md
    **pool_capacity_blocks**
    promql
    # TYPE pool_capacity_blocks gauge
    pool_capacity_blocks{pool_id="main", instance="app-01"} 10000
    
  |
  metric_chunks: |md
    **pool_chunk_count**
    promql
    # TYPE pool_chunk_count gauge
    pool_chunk_count{pool_id="main", instance="app-01"} 10
    
  |
  metric_bytes: |md
    **pool_total_bytes**
    promql
    # TYPE pool_total_bytes gauge
    pool_total_bytes{pool_id="main", instance="app-01"} 640000
    
  |
  metric_overhead: |md
    **pool_overhead_bytes**
    promql
    # TYPE pool_overhead_bytes gauge
    pool_overhead_bytes{pool_id="main", instance="app-01"} 656
    
  |
}

# Prometheus Server
prometheus_server: Prometheus Server {
  style.fill: "#E65100"
  style.stroke: "#BF360C"
  style.font-color: white
  scrape_config: |md
    **Scrape Config**
    yaml
    scrape_configs:
      - job_name: 'memory_pool'
        scrape_interval: 15s
        static_configs:
          - targets: ['app:9090']
    
  |
}

# Grafana Dashboard
grafana_dashboard: Grafana Dashboard {
  style.fill: "#1F1F1F"
  style.stroke: "#F46800"
  style.font-color: "#F46800"
  panels: |md
    **Dashboard Panels**
    1. **Pool Utilization Gauge**
       `allocated / total_capacity * 100`
    2. **Allocation Rate**
       `rate(pool_allocated_blocks[5m])`
    3. **Growth Events**
       `delta(pool_chunk_count[1h])`
    4. **Memory Efficiency**
       `overhead_bytes / total_bytes * 100`
  |
}

# Alert Manager
alertmanager: AlertManager {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 2
  alerts: |md
    **Alert Rules**
    🔴 **PoolExhaustion**
    
    pool_allocated_blocks / pool_capacity_blocks > 0.9
    for: 5m
    severity: critical
    
    🟡 **HighGrowthRate**
    
    delta(pool_chunk_count[1h]) > 5
    severity: warning
    
    🟡 **HighOverhead**
    
    pool_overhead_bytes / pool_total_bytes > 0.1
    severity: warning
  |
}

# Connections
pool_instance.mutex -> stats_collection.pool_get_stats: "1. lock mutex\n2. snapshot state" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  style.stroke-dash: 3
}
stats_collection.poolstats_struct -> metric_transform.metric_exporter: "3. pass struct" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
metric_transform.metric_exporter -> prometheus_metrics.metric_allocated: "4. expose metrics\n   /metrics endpoint" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.animated: true
}
prometheus_metrics.metric_free -> prometheus_metrics.metric_allocated: "HTTP GET /metrics" {
  style.stroke: "#1976D2"
  style.stroke-dash: 3
}
prometheus_metrics <-> prometheus_server: scrape {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
prometheus_server -> grafana_dashboard: query {
  style.stroke: "#F46800"
  style.stroke-width: 2
}
prometheus_server -> alertmanager: evaluate rules {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# APM Integration
apm: APM Integration {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  opentelemetry: OpenTelemetry Collector {
    shape: parallelogram
    style.fill: "#E1BEE7"
    trace_correlation: |md
      **Trace Correlation**
      Link pool operations to request traces:
      
      span.set_attribute("pool.allocated", stats.allocated)
      span.set_attribute("pool.utilization", util_pct)
    |
  }
  jaeger: Jaeger Tracing {
    style.fill: "#60B0D4"
    style.stroke: "#00838F"
  }
}

metric_transform.metric_exporter -> apm.opentelemetry: "trace enrichment" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}
apm.opentelemetry -> apm.jaeger: export traces {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}

# Legend
legend: |'md
  ## Data Flow Legend
  | Style | Meaning |
  |-------|---------|
  | Solid line | Data flow |
  | Dashed line | Control/trigger |
  | Animated | Polling/scraping |
  ## Metric Types
  - **Gauge**: Point-in-time value (can go up/down)
  - **Counter**: Cumulative (only increases)
  ## Key Metrics
  | Metric | Type | Purpose |
  |--------|------|---------|
  | `pool_allocated_blocks` | Gauge | Current usage |
  | `pool_free_blocks` | Gauge | Available capacity |
  | `pool_chunk_count` | Gauge | Growth indicator |
'| {
  near: bottom-left
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
}

# Code Example
code_example: |md
  ## Integration Code
  c
  // metrics_exporter.c
  #include "memory_pool.h"
  #include <prometheus.h>
  void export_pool_metrics(MemoryPool* pool) {
      PoolStats stats;
      pool_get_stats(pool, &stats);  // Thread-safe snapshot
      prom_gauge_set(pool_allocated_gauge, stats.allocated);
      prom_gauge_set(pool_free_gauge, stats.free);
      prom_gauge_set(pool_capacity_gauge, stats.total_blocks);
      prom_gauge_set(pool_chunks_gauge, stats.chunk_count);
      prom_gauge_set(pool_bytes_gauge, stats.total_bytes);
      prom_gauge_set(pool_overhead_gauge, stats.overhead_bytes);
  }
  // Called by Prometheus scraper every 15s
  void metrics_handler(http_request* req) {
      export_pool_metrics(&global_pool);
      prom_http_export(req->response);
  }
  
| {
  near: bottom-right
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFB300"
}