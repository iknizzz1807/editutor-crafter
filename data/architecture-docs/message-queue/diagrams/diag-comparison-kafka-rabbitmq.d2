direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Message Broker Architecture Comparison
  |
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  kafka: {
    direction: down
    label: "Apache Kafka"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    kafka_model: {
      label: "Pull Model"
      style.fill: "#C8E6C9"
      kafka_producers: {
        label: "Producers"
        direction: right
        p1: {shape: person}
        p2: {shape: person}
        p3: {shape: person}
      }
      kafka_producers -> kafka_broker: "push"
      kafka_broker: {
        label: "Broker (Partition-Based)"
        style.fill: "#A5D6A7"
        kafka_topic: {
          label: "Topic: orders"
          style.fill: "#81C784"
          kafka_p0: {
            label: "Partition 0\n[0][1][2][3]..."
            shape: queue
            style.fill: "#66BB6A"
          }
          kafka_p1: {
            label: "Partition 1\n[0][1][2][3]..."
            shape: queue
            style.fill: "#66BB6A"
          }
          kafka_p2: {
            label: "Partition 2\n[0][1][2][3]..."
            shape: queue
            style.fill: "#66BB6A"
          }
        }
        kafka_log: {
          label: "Append-Only Log\n(Your M3)"
          shape: cylinder
          style.fill: "#4CAF50"
        }
        kafka_topic -> kafka_log: "persist"
      }
      kafka_broker -> kafka_consumers: "poll"
      kafka_consumers: {
        label: "Consumer Group"
        direction: right
        style.fill: "#C8E6C9"
        kafka_c1: {
          label: "C1\n(P0)"
          shape: person
        }
        kafka_c2: {
          label: "C2\n(P1)"
          shape: person
        }
        kafka_c3: {
          label: "C3\n(P2)"
          shape: person
        }
      }
    }
    kafka_features: {
      label: "Key Characteristics"
      style.fill: "#E8F5E9"
      kf1: "Partition = parallelism unit"
      kf2: "Consumer pulls (poll)"
      kf3: "Offset stored by consumer"
      kf4: "Log retention (time/size)"
      kf5: "No built-in DLQ"
    }
    kafka_model -> kafka_features: {
      style.stroke: transparent
    }
  }
  rabbitmq: {
    direction: down
    label: "RabbitMQ"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
    rabbit_model: {
      label: "Push Model"
      style.fill: "#FFE0B2"
      rabbit_producers: {
        label: "Producers"
        direction: right
        rp1: {shape: person}
        rp2: {shape: person}
        rp3: {shape: person}
      }
      rabbit_producers -> rabbit_exchange: "publish"
      rabbit_exchange: {
        label: "Exchange\n(routing)"
        shape: diamond
        style.fill: "#FFB74D"
      }
      rabbit_exchange -> rabbit_queue1: "bind"
      rabbit_exchange -> rabbit_queue2: "bind"
      rabbit_exchange -> rabbit_queue3: "bind"
      rabbit_queues: {
        label: "Queues"
        direction: right
        style.fill: "#FFCC80"
        rabbit_queue1: {
          label: "Queue A"
          shape: queue
          style.fill: "#FFA726"
        }
        rabbit_queue2: {
          label: "Queue B"
          shape: queue
          style.fill: "#FFA726"
        }
        rabbit_queue3: {
          label: "Queue C"
          shape: queue
          style.fill: "#FFA726"
        }
      }
      rabbit_broker: {
        label: "Broker"
        style.fill: "#FFE0B2"
        rabbit_exchange
        rabbit_queues
      }
      rabbit_broker -> rabbit_consumers: "push"
      rabbit_consumers: {
        label: "Consumers"
        direction: right
        style.fill: "#FFE0B2"
        rabbit_c1: {
          label: "C1"
          shape: person
        }
        rabbit_c2: {
          label: "C2"
          shape: person
        }
        rabbit_c3: {
          label: "C3"
          shape: person
        }
      }
    }
    rabbit_features: {
      label: "Key Characteristics"
      style.fill: "#FFF3E0"
      rf1: "Exchange routes messages"
      rf2: "Broker pushes to consumer"
      rf3: "ACK/NACK per message"
      rf4: "Queue-based retention"
      rf5: "Built-in DLQ support"
    }
    rabbit_model -> rabbit_features: {
      style.stroke: transparent
    }
  }
  your_broker: {
    direction: down
    label: "Your Broker (Hybrid)"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
    your_model: {
      label: "Hybrid Model"
      style.fill: "#BBDEFB"
      your_producers: {
        label: "Producers"
        direction: right
        yp1: {shape: person}
        yp2: {shape: person}
        yp3: {shape: person}
      }
      your_producers -> your_broker: "TCP + framing"
      your_broker: {
        label: "Broker (M1-M4)"
        style.fill: "#90CAF9"
        your_router: {
          label: "Topic Router\n(M1)"
          style.fill: "#64B5F6"
          your_fanout: {
            label: "Fan-Out\n(pub/sub)"
            style.fill: "#42A5F5"
          }
          your_group: {
            label: "Consumer Group\n(M2)"
            style.fill: "#42A5F5"
          }
        }
        your_persistence: {
          label: "Persistence Layer\n(M3)"
          direction: right
          style.fill: "#64B5F6"
          your_log: {
            label: "Append-Only Log\n(offset-based)"
            shape: cylinder
            style.fill: "#2196F3"
          }
          your_offsets: {
            label: "Consumer\nOffsets"
            shape: cylinder
            style.fill: "#2196F3"
          }
        }
        your_router -> your_persistence: "fsync"
      }
      your_broker -> your_consumers: "deliver"
      your_consumers: {
        label: "Consumers"
        direction: right
        style.fill: "#BBDEFB"
        your_c1: {
          label: "C1\n(ACK/NACK)"
          shape: person
        }
        your_c2: {
          label: "C2\n(ACK/NACK)"
          shape: person
        }
        your_c3: {
          label: "C3\n(ACK/NACK)"
          shape: person
        }
      }
    }
    your_features: {
      label: "Key Characteristics"
      style.fill: "#E3F2FD"
      yf1: "Topic = routing unit (Kafka)"
      yf2: "Broker delivers (RabbitMQ)"
      yf3: "Visibility timeout + ACK"
      yf4: "Log + offset (Kafka)"
      yf5: "DLQ as topic (M4)"
    }
    your_model -> your_features: {
      style.stroke: transparent
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  comparison: {
    label: "Architecture Decisions Comparison"
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
    }
    comp_table: {
      shape: sql_table
      label: "Design Trade-offs"
      row1: "Aspect | Kafka | RabbitMQ | Your Broker"
      row2: "Delivery | Pull (poll) | Push | Push (hybrid)"
      row3: "Parallelism | Partitions | Queues | Topics + Groups"
      row4: "Ordering | Per-partition | Per-queue | Per-topic"
      row5: "Persistence | Log + offset | Queue storage | Log + offset"
      row6: "DLQ | Manual | Built-in | Built-in (M4)"
      row7: "Backpressure | Consumer-controlled | Prefetch | THROTTLE cmd"
      row8: "Protocol | Binary (custom) | AMQP | Binary (custom)"
    }
  }
  inheritance: {
    label: "What You Inherited"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
    from_kafka: {
      label: "From Kafka"
      style.fill: "#E1BEE7"
      fk1: "Append-only log"
      fk2: "Offset-based tracking"
      fk3: "Consumer groups"
      fk4: "Retention policies"
      fk5: "Topic-partition model"
    }
    from_rabbit: {
      label: "From RabbitMQ"
      style.fill: "#E1BEE7"
      fr1: "ACK/NACK protocol"
      fr2: "Visibility timeout"
      fr3: "Push delivery"
      fr4: "DLQ pattern"
      fr5: "Consumer prefetch"
    }
    your_unique: {
      label: "Your Innovations"
      style.fill: "#CE93D8"
      yu1: "THROTTLE backpressure"
      yu2: "JSON DLQ inspection"
      yu3: "Three-level health"
      yu4: "Hybrid fan-out + groups"
      yu5: "Configurable fsync"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  leg_kafka: {
    label: "Kafka Pattern"
    style: {
      fill: "#A5D6A7"
      stroke: "#2E7D32"
    }
  }
  leg_rabbit: {
    label: "RabbitMQ Pattern"
    style: {
      fill: "#FFCC80"
      stroke: "#E65100"
    }
  }
  leg_yours: {
    label: "Your Implementation"
    style: {
      fill: "#90CAF9"
      stroke: "#1565C0"
    }
  }
  leg_hybrid: {
    label: "Hybrid/Novel"
    style: {
      fill: "#CE93D8"
      stroke: "#7B1FA2"
    }
  }
}