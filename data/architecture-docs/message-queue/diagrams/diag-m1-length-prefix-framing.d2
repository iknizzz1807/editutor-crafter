direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Length-Prefixed Message Framing (protocol/framing.go)"
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  wire_format: {
    direction: down
    label: "Wire Format"
    frame: {
      label: "Frame on Wire"
      width: 500
      direction: right
      
      length_prefix: {
        shape: rectangle
        label: "Length Prefix"
        info: |'md
          4 bytes | uint32
          Big-Endian
        '|
        width: 150
        style: {
          fill: "#E8F5E9"
          stroke: "#2E7D32"
          stroke-width: 2
        }
      }
      
      payload: {
        shape: rectangle
        label: "Payload"
        info: |'md
          N bytes | Variable
          Command + Data
        '|
        width: 300
        style: {
          fill: "#E3F2FD"
          stroke: "#1565C0"
          stroke-width: 2
        }
      }
      
      length_prefix -> payload: "length=N" {
        style.stroke-dash: 3
      }
    }
    
    example: {
      label: "Example: PUBLISH orders hello"
      width: 500
      style: {
        fill: "#FFF8E1"
        stroke: "#F57C00"
        border-radius: 4
      }
      ex_code: {
        label: "Hex View"
        code: |"c
          Frame Length: 0x0000000E (14 bytes)
          ┌────────────┬─────────────────────────────┐
          │ 0x0000000E │ 0x01 orders hello ...       │
          │  4 bytes   │       14 bytes              │
          └────────────┴─────────────────────────────┘
        "|
      }
    }
  }

  byte_layout: {
    direction: down
    label: "Memory Representation"
    width: 400
    
    layout_table: {
      shape: sql_table
      label: "struct Frame (protocol/framing.go)"
      f0: "0x00 | uint32    | length // Big-Endian"
      f1: "0x04 | []byte    | payload // size = length"
      note: "Note: Max size 64MB"
      sz: "Total: 4 + length bytes"
    }
    
    endianness: {
      label: "Endianness Strategy"
      width: 380
      style.fill: "#F3E5F5"
      reason: {
        label: "Why Big-Endian?"
        content: |'md
          1. Network Byte Order Standard
          2. Predictable Read (ReadFull 4)
          3. `binary.BigEndian.Uint32(b)`
        '|
      }
    }
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  receive_loop: {
    direction: down
    label: "FrameReader State Machine"
    
    state_init: {
      shape: circle
      label: "START"
      style: {
        fill: "#4CAF50"
        font-color: white
      }
    }
    
    state_read_len: {
      shape: rectangle
      label: "READ_LENGTH"
      code: |'go
        io.ReadFull(conn, buf[0:4])
        length = BE.Uint32(buf)
      '|
      width: 320
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
    }
    
    state_validate: {
      shape: diamond
      label: "Valid Size?"
      width: 200
      style: {
        fill: "#FFF3E0"
        stroke: "#E65100"
      }
    }
    
    state_read_payload: {
      shape: rectangle
      label: "READ_PAYLOAD"
      code: |'go
        p := make([]byte, length)
        io.ReadFull(conn, p)
      '|
      width: 320
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
        stroke-width: 2
      }
    }
    
    state_dispatch: {
      shape: rectangle
      label: "DISPATCH"
      code: |'go
        msg := Unmarshal(p)
        Bus.Publish(msg)
      '|
      width: 320
      style: {
        fill: "#F3E5F5"
        stroke: "#7B1FA2"
        stroke-width: 2
      }
    }
    
    state_error: {
      shape: rectangle
      label: "ERROR"
      code: |'go
        return ErrInvalidLength
        conn.Close()
      '|
      width: 200
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
    }
    
    state_init -> state_read_len: "connect" { style.stroke: "#4CAF50" }
    state_read_len -> state_validate: "read 4B" { style.stroke: "#2E7D32" }
    state_validate -> state_read_payload: "length <= limit" { style.stroke: "#1565C0" }
    state_validate -> state_error: "overflow" { 
      style.stroke: "#C62828"
      style.stroke-dash: 4
    }
    state_read_payload -> state_dispatch: "read N" { style.stroke: "#7B1FA2" }
    state_dispatch -> state_read_len: "loop" { 
      style.stroke: "#4CAF50"
      style.animated: true 
    }
  }

  tcp_reality: {
    direction: down
    label: "TCP Byte Stream Logic"
    width: 380
    
    problem: {
      label: "TCP Segmentation"
      width: 360
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
      content: |'md
        **Problem:** Stream-oriented
        One write might be split into
        multiple read packets.
      '|
    }
    
    solution: {
      label: "Explicit Framing"
      width: 360
      style: {
        fill: "#E8F5E9"
        stroke: "#2E7D32"
        stroke-width: 2
      }
      content: |'md
        **Solution:** Length prefix
        tells the reader exactly how
        many bytes to buffer.
      '|
    }
    
    problem -> solution: "provides bounds" {
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
  }
}

row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  code_impl: {
    direction: down
    label: "Reader Implementation"
    width: 500
    
    frame_reader: {
      shape: class
      label: "FrameReader (framing.go)"
      -reader: "*bufio.Reader"
      "+NewFrameReader(r io.Reader)": "*FrameReader"
      "+ReadFrame()": "([]byte, error)"
    }
    
    readframe_code: {
      label: "ReadFrame Implementation"
      width: 480
      style: {
        fill: "#263238"
        font-color: "#ECEFF1"
        border-radius: 4
      }
      code: |"go
        func (fr *FrameReader) ReadFrame() ([]byte, error) {
          lenBuf := make([]byte, 4)
          if _, err := io.ReadFull(fr.reader, lenBuf); err != nil {
            return nil, err
          }
          n := binary.BigEndian.Uint32(lenBuf)
          if n > MaxSize { return nil, ErrTooLarge }
          p := make([]byte, n)
          _, err := io.ReadFull(fr.reader, p)
          return p, err
        }
      "|
    }
  }

  frame_writer: {
    direction: down
    label: "Writer Implementation"
    width: 400
    
    writer_class: {
      shape: class
      label: "FrameWriter (framing.go)"
      -writer: "io.Writer"
      "+NewFrameWriter(w io.Writer)": "*FrameWriter"
      "+WriteFrame(p []byte)": "error"
    }
    
    write_code: {
      label: "WriteFrame Implementation"
      width: 380
      style: {
        fill: "#263238"
        font-color: "#ECEFF1"
        border-radius: 4
      }
      code: |"go
        func (fw *FrameWriter) WriteFrame(p []byte) error {
          buf := make([]byte, 4)
          binary.BigEndian.PutUint32(buf, uint32(len(p)))
          if _, err := fw.writer.Write(buf); err != nil {
            return err
          }
          _, err := fw.writer.Write(p)
          return err
        }
      "|
    }
  }
}

legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  
  grid-columns: 2
  "Length/Control": { style.fill: "#E8F5E9" }
  "Payload/Data": { style.fill: "#E3F2FD" }
  "Processing": { style.fill: "#F3E5F5" }
  "Error Path": { style.fill: "#FFEBEE" }
}