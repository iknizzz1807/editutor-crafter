direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Wire Protocol Specification
  Binary message framing for TCP transport
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  framing: {
    direction: down
    label: "Message Framing"
    frame_layout: {
      shape: sql_table
      label: "Frame Layout (all messages)"
      f0: "0x00-0x03 | uint32  | Length Prefix (BE)"
      f1: "0x04-N    | bytes   | Frame Payload"
      sz: "Total: 4 + N bytes"
    }
    frame_note: {
      width: 280
      code: |'c
        // Length prefix = payload size
        // Big-endian byte order
        // Max frame: 10 MB
      '|
    }
  }
  cmd_types: {
    direction: down
    label: "Command Types"
    cmd_table: {
      shape: sql_table
      label: "Command Registry"
      c0: "0x01 | PUBLISH         | Client → Server"
      c1: "0x02 | PUBLISH_ACK     | Server → Client"
      c2: "0x03 | SUBSCRIBE       | Client → Server"
      c3: "0x04 | SUBSCRIBE_ACK   | Server → Client"
      c4: "0x05 | UNSUBSCRIBE     | Client → Server"
      c5: "0x06 | UNSUBSCRIBE_ACK | Server → Client"
      c6: "0x07 | MESSAGE         | Server → Client"
      c7: "0x08 | HEARTBEAT       | Bidirectional"
      c8: "0x09 | HEARTBEAT_ACK   | Bidirectional"
      c9: "0x10 | ERROR           | Server → Client"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  publish_cmd: {
    direction: down
    label: "Client Commands"
    publish: {
      shape: sql_table
      label: "PUBLISH (0x01)"
      p0: "0x00      | uint8   | Cmd = 0x01"
      p1: "0x01-0x02 | uint16  | TopicLen (BE)"
      p2: "0x03-N    | bytes   | Topic (UTF-8)"
      p3: "N+0-N+1   | uint16  | PayloadLen (BE)"
      p4: "N+2-M     | bytes   | Payload"
      sz: "Min: 6 bytes"
    }
    subscribe: {
      shape: sql_table
      label: "SUBSCRIBE (0x03)"
      s0: "0x00      | uint8   | Cmd = 0x03"
      s1: "0x01-0x02 | uint16  | TopicLen (BE)"
      s2: "0x03-N    | bytes   | Topic (UTF-8)"
      sz: "Min: 3 bytes"
    }
    unsubscribe: {
      shape: sql_table
      label: "UNSUBSCRIBE (0x05)"
      u0: "0x00      | uint8   | Cmd = 0x05"
      u1: "0x01-0x02 | uint16  | TopicLen (BE)"
      u2: "0x03-N    | bytes   | Topic (UTF-8)"
      sz: "Same as SUBSCRIBE"
    }
  }
  server_resp: {
    direction: down
    label: "Server Responses"
    publish_ack: {
      shape: sql_table
      label: "PUBLISH_ACK (0x02)"
      a0: "0x00 | uint8 | Cmd = 0x02"
      sz: "Total: 1 byte"
    }
    subscribe_ack: {
      shape: sql_table
      label: "SUBSCRIBE_ACK (0x04)"
      sa0: "0x00      | uint8  | Cmd = 0x04"
      sa1: "0x01-0x02 | uint16 | TopicLen (BE)"
      sa2: "0x03-N    | bytes  | Topic (UTF-8)"
      sz: "Mirrors SUBSCRIBE"
    }
    error_resp: {
      shape: sql_table
      label: "ERROR (0x10)"
      e0: "0x00    | uint8 | Cmd = 0x10"
      e1: "0x01-N  | bytes | Error Message"
      sz: "Variable length"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  message_delivery: {
    direction: down
    label: "Message Delivery"
    message_cmd: {
      shape: sql_table
      label: "MESSAGE (0x07) — Server → Client"
      m0: "0x00      | uint8   | Cmd = 0x07"
      m1: "0x01-0x02 | uint16  | TopicLen (BE)"
      m2: "0x03-N    | bytes   | Topic (UTF-8)"
      m3: "N+0-N+1   | uint16  | PayloadLen (BE)"
      m4: "N+2-M     | bytes   | Payload"
      m5: "M+0-M+7   | uint64  | MessageID (BE)"
      sz: "Min: 14 bytes"
    }
    msg_note: {
      width: 300
      code: |'c
        // MessageID is server-assigned
        // Used for ACK/NACK correlation
        // Unique per message
      '|
    }
  }
  heartbeat: {
    direction: down
    label: "Liveness Commands"
    heartbeat_cmd: {
      shape: sql_table
      label: "HEARTBEAT (0x08)"
      h0: "0x00 | uint8 | Cmd = 0x08"
      sz: "Total: 1 byte (no payload)"
    }
    heartbeat_ack: {
      shape: sql_table
      label: "HEARTBEAT_ACK (0x09)"
      ha0: "0x00 | uint8 | Cmd = 0x09"
      sz: "Total: 1 byte (no payload)"
    }
    hb_note: {
      width: 260
      code: |'c
        // Sent every 30 seconds
        // Timeout after 60 seconds
        // Triggers connection close
      '|
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  example: {
    direction: down
    label: "Wire Example"
    ex_publish: {
      width: 400
      code: |'c
        // PUBLISH "hello" to topic "orders"
        // Frame Length: 0x0000000E (14 bytes)
        // Payload:
        //   0x01              // PUBLISH
        //   0x0006            // TopicLen: 6
        //   "orders"          // Topic (6 bytes)
        //   0x0005            // PayloadLen: 5
        //   "hello"           // Payload (5 bytes)
        //
        // Hex: 00 00 00 0E  01  00 06 6F 72 64 65 72 73
        //                   00 05 68 65 6C 6C 6F
      '|
    }
  }
  flow: {
    direction: down
    label: "Protocol Flow"
    flow_diagram: {
      shape: sequence_diagram
      client: Client
      server: Server
      client -> server: SUBSCRIBE orders
      server -> client: SUBSCRIBE_ACK orders
      client -> server: PUBLISH orders "msg"
      server -> client: PUBLISH_ACK
      server -> client: MESSAGE orders "msg" id=1
    }
  }
}
legend: {
  near: bottom-right
  label: "Field Types"
  types: {
    shape: sql_table
    label: "Type Reference"
    t0: "uint8  | 1 byte  | Command type"
    t1: "uint16 | 2 bytes | Length (BE)"
    t2: "uint32 | 4 bytes | Length/Offset (BE)"
    t3: "uint64 | 8 bytes | MessageID (BE)"
    t4: "bytes  | N bytes | Variable data"
    t5: "BE = Big-Endian (network byte order)"
  }
}