direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: "TCP Byte Stream Reality: Boundaries are NOT preserved"
  shape: rectangle
  near: top-center
  style: {
    font-size: 24
    bold: true
    fill: "#f8f9fa"
    stroke-width: 0
  }
}

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  
  expected: {
    direction: down
    label: "Developer Mental Model (WRONG)"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    style.fill: "#f1f8e9"

    exp_sender: {
      label: "Sender (send A, then B)"
      shape: rectangle
      width: 250
    }
    exp_wire: {
      label: "TCP Segment preservation"
      shape: queue
      width: 250
      style.stroke-dash: 3
    }
    exp_receiver: {
      label: "Receiver"
      shape: rectangle
      width: 250
    }
    exp_result: {
      label: "Read 1 = A\nRead 2 = B"
      shape: callout
      width: 250
      style.bold: true
      style.fill: "#c8e6c9"
    }
    exp_sender -> exp_wire: "msg A"
    exp_wire -> exp_receiver: "msg B"
    exp_receiver -> exp_result: "Success"
  }

  spacer_h: {
    style.stroke: transparent
    style.fill: transparent
    width: 50
  }

  reality: {
    direction: down
    label: "TCP Reality (BYTE STREAM)"
    style.stroke: "#F44336"
    style.stroke-width: 2
    style.fill: "#ffebee"

    real_sender: {
      label: "Sender (Stream of bytes)"
      shape: rectangle
      width: 250
    }
    real_wire: {
      label: "Network Buffers / MTU / Nagle"
      shape: queue
      width: 250
      style.stroke-dash: 3
    }
    real_receiver: {
      label: "Receiver"
      shape: rectangle
      width: 250
    }
    real_result: {
      label: "Arbitrary Read Sizes"
      shape: callout
      width: 250
      style.bold: true
      style.fill: "#ffcdd2"
    }
    real_sender -> real_wire: "bytes 0-149"
    real_wire -> real_receiver: "fragments"
    real_receiver -> real_result: "Data Corruption"
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  read_logic_patterns: {
    direction: down
    label: "TCP read() Non-Deterministic Behavior"
    style.fill: "#eceff1"
    
    scenario_title: {
      label: "Sends: msgA (100B) + msgB (50B)"
      shape: rectangle
      width: 800
      style.font: mono
      style.fill: "#cfd8dc"
    }

    grid_container: {
      grid-columns: 4
      style.stroke: transparent
      style.fill: transparent
      
      s1: {
        label: "Pattern 1: Lucky\nRead 1: 100B\nRead 2: 50B"
        style.fill: "#e8f5e9"
      }
      s2: {
        label: "Pattern 2: Split\nRead 1: 40B\nRead 2: 110B"
        style.fill: "#fff3e0"
      }
      s3: {
        label: "Pattern 3: Coalesced\nRead 1: 150B (A+B)"
        style.fill: "#ffebee"
      }
      s4: {
        label: "Pattern 4: Tiny reads\nRead 1: 1B\nRead 2: 1B..."
        style.fill: "#f3e5f5"
      }
    }
    scenario_title -> grid_container: "OS decides fragmentation"
  }
}

row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  broken_code: {
    direction: down
    label: "Naive (Dangerous) Implementation"
    style.stroke: "#f44336"
    
    broken_impl: {
      label: "BROKEN handleConnection (net.Conn)"
      code: |'go
      buf := make([]byte, 1024)
      for {
          n, _ := conn.Read(buf)
          // BUG: n could be partial A, 
          // or A + start of B
          processMessage(buf[:n])
      }
      '|
      width: 400
    }
    broken_reason: "Result: Works on Localhost, Fails on WAN" {
      style.fill: "#ffcdd2"
    }
    broken_impl -> broken_reason
  }

  spacer_h2: {
    style.stroke: transparent
    style.fill: transparent
    width: 20
  }

  solution_approach: {
    direction: down
    label: "Application-Layer Framing (Correct)"
    style.stroke: "#4caf50"

    frame_layout: {
      shape: sql_table
      label: "Framed Message Protocol"
      f1: "0x00 | uint32 | payload_len (N)"
      f2: "0x04 | byte[N] | actual_data"
      total: "Total: 4 + N bytes"
    }

    correct_impl: {
      label: "FIXED handleConnection (io.ReadFull)"
      code: |'go
      // Step 1: Read prefix (exactly 4B)
      io.ReadFull(conn, lenBuf)
      n := binary.BigEndian.Uint32(lenBuf)
      // Step 2: Read payload (exactly N bytes)
      payload := make([]byte, n)
      io.ReadFull(conn, payload)
      '|
      width: 400
    }
    frame_layout -> correct_impl: "Defines Boundary"
  }
}

insight_box: {
  label: |md
    ### Architectural Standard
    TCP is a **stream of bytes**, not a stream of packets. Application logic must provide its own **framing** (e.g., Length-Prefix or Delimiters) to reconstruct message boundaries.
  |
  shape: rectangle
  near: bottom-center
  width: 800
  style: {
    fill: "#fffde7"
    stroke: "#fbc02d"
    stroke-width: 2
  }
}

# Cross-row connections for logic flow
row1.expected.exp_result -> row2.read_logic_patterns.scenario_title: "Assumes Pattern 1" {
  style.stroke: "#4caf50"
  style.stroke-dash: 3
}
row1.reality.real_result -> row2.read_logic_patterns.scenario_title: "Causes Patterns 2,3,4" {
  style.stroke: "#f44336"
  style.stroke-dash: 3
}