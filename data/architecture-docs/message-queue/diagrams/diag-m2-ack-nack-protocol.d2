vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: {
  shape: text
  label: "MQ ACK/NACK Protocol: Technical Implementation Blueprint"
  style: {
    font-size: 32
    bold: true
  }
}

# --- ROW 1: SUCCESSFUL ACKNOWLEDGMENT FLOW ---
ack_path_container: {
  label: "SCENARIO A: Standard Completion (ACK)"
  style.fill: "#f8fff8"
  style.stroke: "#2e7d32"
  
  ack_flow: {
    shape: sequence_diagram
    consumer_a: Consumer A
    broker: Broker
    in_flight: In-Flight Tracker
    
    init: {
      consumer_a -> broker: "RECEIVE | msgID=42"
      broker -> in_flight: "TrackInFlight | msgID=42, cons=A"
    }
    
    processing: {
      consumer_a.t1 -> consumer_a.t1: "Execute Handler | order-123"
    }
    
    completion: {
      consumer_a.t2 -> broker: "ACK | msgID=42"
      broker -> in_flight: "RemoveRecord | msgID=42"
      broker -> consumer_a: "ACK_OK"
    }
  }
}

# --- ROW 2: FAILURE AND REDELIVERY FLOW ---
nack_path_container: {
  label: "SCENARIO B: Negative Acknowledgment (NACK) with Immediate Retry"
  style.fill: "#fff8f8"
  style.stroke: "#c62828"
  
  nack_flow: {
    shape: sequence_diagram
    consumer_a: Consumer A
    broker: Broker
    in_flight: In-Flight Tracker
    pending: Pending Queue
    consumer_b: Consumer B
    
    failure_init: {
      consumer_a -> broker: "RECEIVE | msgID=99"
      broker -> in_flight: "TrackInFlight | msgID=99, cons=A"
    }
    
    nack_trigger: {
      consumer_a.t1 -> consumer_a.t1: "JSON Parse Error"
      consumer_a -> broker: "NACK | msgID=99, reason='malformed'"
    }
    
    broker_logic: {
      broker -> in_flight: "ClearRecord | msgID=99"
      broker -> pending: "Re-Queue | priority=IMMEDIATE"
    }
    
    redelivery: {
      broker -> consumer_b: "RECEIVE | msgID=99, retry=2"
      consumer_b.note: "Targeted to different consumer to avoid stuck-state affinity"
    }
  }
}

# --- ROW 3: ANALYSIS & STATE TRANSITIONS ---
analysis_row: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  insights_box: {
    label: "Protocol Analysis"
    width: 500
    content: |'md
    ### Operational Characteristics
    - **Acknowledge (ACK)**: Atomic removal from In-Flight set. Clears visibility timeout.
    - **Negative-Ack (NACK)**: Explicit failure. Bypasses standard TTL/timeout to trigger immediate re-processing.
    - **Consumer Affinity**: Broker excludes the NACK-ing consumer from the immediate redelivery pool for that specific message.
    - **Idempotency**: Downstream systems MUST handle Scenario B where Msg 99 is processed by both A (partial) and B (full).
    '|
  }

  state_evolution: {
    label: "Message State Evolution"
    direction: down
    
    ack_states: {
      direction: right
      style.stroke: "#2e7d32"
      s1: "PENDING" { shape: circle; style.fill: white }
      s2: "IN_FLIGHT" { shape: circle; style.fill: "#fff9c4" }
      s3: "ARCHIVED" { shape: circle; style.fill: "#c8e6c9" }
      
      s1 -> s2: "Delivery"
      s2 -> s3: "ACK"
    }
    
    nack_states: {
      direction: right
      style.stroke: "#c62828"
      n1: "PENDING" { shape: circle; style.fill: white }
      n2: "IN_FLIGHT (A)" { shape: circle; style.fill: "#fff9c4" }
      n3: "PENDING (Retry)" { shape: circle; style.fill: "#ffcdd2" }
      n4: "IN_FLIGHT (B)" { shape: circle; style.fill: "#fff9c4" }
      
      n1 -> n2: "v1"
      n2 -> n3: "NACK (A)"
      n3 -> n4: "v2"
    }
  }
}

# --- ROW 4: WIRE FORMAT SPECIFICATIONS ---
wire_formats: {
  label: "Binary Wire Protocol Formats"
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ack_table: {
    shape: sql_table
    label: "ACK Frame (Type 0x11)"
    f0: "0x00 | uint8  | type = 0x11"
    f1: "0x01 | uint64 | message_id // Big-endian"
    f2: "0x09 | uint32 | crc32      // Frame integrity"
    sz: "Total Size: 13 bytes"
  }

  nack_table: {
    shape: sql_table
    label: "NACK Frame (Type 0x12)"
    n0: "0x00 | uint8  | type = 0x12"
    n1: "0x01 | uint64 | message_id"
    n2: "0x09 | uint16 | reason_len"
    n3: "0x0B | string | reason     // UTF-8 payload"
    n4: ".... | uint32 | crc32"
    sz: "Total Size: 15 + reason_len bytes"
  }
}

# --- GLOBAL LEGEND ---
legend: {
  shape: rectangle
  near: bottom-right
  label: "Legend"
  style.fill: "#eeeeee"
  l1: "🟢 ACK Path" { style.font-color: "#2e7d32" }
  l2: "🔴 NACK Path" { style.font-color: "#c62828" }
  l3: "🟡 Processing" { style.font-color: "#f9a825" }
}