        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
        width: 130
        buf1_after: {
          label: "chan buffer: 10"
          shape: rectangle
          style.fill: "#C8E6C9"
          width: 100
        }
        goroutine1: {
          label: "deliveryLoop()"
          shape: oval
          style.fill: "#E1BEE7"
