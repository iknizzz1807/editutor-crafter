        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
        width: 130
        buf2_after: {
          label: "chan buffer: 10"
          shape: rectangle
          style.fill: "#C8E6C9"
          width: 100
        }
        goroutine2: {
          label: "deliveryLoop()"
          shape: oval
          style.fill: "#E1BEE7"
          width: 90
        }
      }
    }
    router_after -> c1_after.buf1_after: "non-blocking\nsend" {
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
    router_after -> c2_after.buf2_after: "non-blocking\nsend" {
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
    c1_after.goroutine1 -> c1_after: "pop & send\n(own pace)"
    c2_after.goroutine2 -> c2_after: "pop & send\n(own pace)"
    timeline_after: {
      label: "Timeline"
      shape: rectangle
      width: 320
      t1: "T=0ms:   msg1→buf1, msg2→buf2 (parallel)"
      t2: "T=1ms:   msg2 → C2 done ✓"
      t3: "T=0-100ms: msg1 → C1 processing..."
      t4: "T=100ms: msg1 → C1 done ✓"
      t5: "T=101ms: msg3 → C2 done ✓"
      total: "**Total for 3 msgs: ~101ms**"
      style.fill: "#E8F5E9"
    }
  }
}
row_code: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  code_before: {
    label: "Sequential Dispatch (blocking)"
    width: 350
    code: |'go
      // BUG: slow consumer blocks all
      for _, client := range subs {
        // If C1 takes 100ms,
        // C2 waits 100ms!
        deliverToClient(msg, client)
      }
    '|
  }
  code_after: {
    label: "Per-Consumer Buffered Channel"
    width: 380
    code: |'go
      // Each consumer has own goroutine
      type SubscriberState struct {
        client  *Client
        deliver chan *Command // buf=10
        stop    chan struct{}
      }
      // Non-blocking send in Publish()
      select {
      case sub.deliver <- msg:
        delivered++  // queued
      default:
        log.Printf("buffer full, drop")
      }
      // Separate goroutine per consumer
      func deliveryLoop(sub *SubscriberState) {
        for cmd := range sub.deliver {
          sendCommand(sub.client, cmd)
          // C1's slowness only affects C1
        }
      }
    '|
  }
}
row_summary: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  summary: {
    label: "Key Insight"
    width: 750
    code: |'text
      Per-consumer goroutines with buffered channels decouple delivery from processing speed:
      • Fast consumers (C2) process at their own pace — not blocked by slow peers
      • Slow consumers (C1) fill their buffer; when full, messages drop (backpressure signal)
      • DefaultPrefetchCount=10 gives 10-message headstart before blocking
      This pattern appears in: Kafka consumer prefetch, RabbitMQ prefetch_count, SQS MaxNumberOfMessages
    '|
  }
}
row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: {
    shape: sql_table
    label: "Head-of-Line Blocking: Comparison"
    metric: "Metric"
    before_col: "Sequential Dispatch"
    after_col: "Per-Consumer Buffer"
    row1: "C2 throughput | Blocked by C1 | Independent of C1"
    row2: "Latency for msg2 | 100ms (waits for C1) | 1ms (immediate)"
    row3: "Total time (3 msgs) | ~300ms | ~101ms"
    row4: "Slow consumer impact | Affects ALL consumers | Isolated to self"
    row5: "Memory overhead | None | ~10 msgs × consumer count"
  }
}