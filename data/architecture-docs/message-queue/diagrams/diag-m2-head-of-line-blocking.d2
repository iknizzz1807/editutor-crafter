  direction: right
  style.stroke: transparent
  style.fill: transparent
  label_before: |md
    ## ❌ BEFORE: Sequential Dispatch
  | {
    width: 380
  }
  label_after: |md
    ## ✓ AFTER: Per-Consumer Buffers
  | {
    width: 380
  }
}
