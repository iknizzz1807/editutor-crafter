direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Consumer Group Rebalancing
  Partition Assignment & In-Flight Message Recovery
| {near: top-center}

row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state_before: {
    label: "State A: Initial Assignment (2 Consumers)"
    direction: down
    
    partitions_before: {
      label: "16 Partitions (Round-Robin)"
      shape: rectangle
      style.fill: "#E8F5E9"
      grid-columns: 4
      grid-gap: 4
      p0: "P0\nconsumer-1" {style.fill: "#BBDEFB"}
      p1: "P1\nconsumer-2" {style.fill: "#FFCDD2"}
      p2: "P2\nconsumer-1" {style.fill: "#BBDEFB"}
      p3: "P3\nconsumer-2" {style.fill: "#FFCDD2"}
      p4: "P4\nconsumer-1" {style.fill: "#BBDEFB"}
      p5: "P5\nconsumer-2" {style.fill: "#FFCDD2"}
      p6: "P6\nconsumer-1" {style.fill: "#BBDEFB"}
      p7: "P7\nconsumer-2" {style.fill: "#FFCDD2"}
      p8: "P8\nconsumer-1" {style.fill: "#BBDEFB"}
      p9: "P9\nconsumer-2" {style.fill: "#FFCDD2"}
      p10: "P10\nconsumer-1" {style.fill: "#BBDEFB"}
      p11: "P11\nconsumer-2" {style.fill: "#FFCDD2"}
      p12: "P12\nconsumer-1" {style.fill: "#BBDEFB"}
      p13: "P13\nconsumer-2" {style.fill: "#FFCDD2"}
      p14: "P14\nconsumer-1" {style.fill: "#BBDEFB"}
      p15: "P15\nconsumer-2" {style.fill: "#FFCDD2"}
    }

    consumers_before: {
      direction: right
      grid-columns: 2
      grid-gap: 20
      c1_before: {
        label: "Consumer-1"
        shape: rectangle
        style.fill: "#BBDEFB"
        style.stroke: "#1976D2"
        width: 180
        assigns_c1: |md
          **Partitions:** P0, P2, P4, P6, P8, P10, P12, P14
          **In-Flight:** 3 messages
          - msg@offset=100 (P2)
          - msg@offset=101 (P4)
          - msg@offset=102 (P8)
        |
      }
      c2_before: {
        label: "Consumer-2"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: "#D32F2F"
        width: 180
        assigns_c2: |md
          **Partitions:** P1, P3, P5, P7, P9, P11, P13, P15
          **In-Flight:** 2 messages
          - msg@offset=200 (P3)
          - msg@offset=201 (P7)
        |
      }
    }
    partitions_before -> consumers_before: "assigned to"
  }
}

trigger: {
  label: "TRIGGER: Consumer-3 Joins Group"
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  width: 200
}

row_before -> trigger: "Join(consumer-3)"

row_rebalance: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state_rebalance: {
    label: "State B: Rebalancing In Progress"
    direction: down
    
    rebalance_flow: {
      label: "Rebalance Sequence"
      shape: rectangle
      style.fill: "#FFF3E0"
      width: 350
      sequence_list: |md
        1. Consumer-3 sends JOIN request
        2. Coordinator detects membership change
        3. **Lock group** (pause deliveries)
        4. Revoke assignments from C1, C2
        5. Calculate new partition mapping
        6. Assign partitions round-robin: 3 ways
        7. Send new assignments to all members
        8. **Unlock group** (resume deliveries)
      |
    }

    in_flight_handling: {
      label: "In-Flight Message Handling"
      shape: rectangle
      style.fill: "#FFEBEE"
      width: 350
      handling_logic: |md
        **During Rebalance:**
        - C1 has 3 in-flight -> mark VisibleAfter = now()
        - C2 has 2 in-flight -> mark VisibleAfter = now()
        - Messages become eligible for redelivery
        - After VisibilityTimeout (30s):
          - Unacked -> re-queue to new partition owner
          - Acked -> remove from in-flight
      |
    }
    rebalance_flow -> in_flight_handling: "triggers"
  }
}

trigger -> row_rebalance: "coordinator"

row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state_after: {
    label: "State C: Final Assignment (3 Consumers)"
    direction: down
    
    partitions_after: {
      label: "16 Partitions (Rebalanced)"
      shape: rectangle
      style.fill: "#E8F5E9"
      grid-columns: 4
      grid-gap: 4
      p0a: "P0\nC1" {style.fill: "#BBDEFB"}
      p1a: "P1\nC2" {style.fill: "#FFCDD2"}
      p2a: "P2\nC3" {style.fill: "#C8E6C9"}
      p3a: "P3\nC1" {style.fill: "#BBDEFB"}
      p4a: "P4\nC2" {style.fill: "#FFCDD2"}
      p5a: "P5\nC3" {style.fill: "#C8E6C9"}
      p6a: "P6\nC1" {style.fill: "#BBDEFB"}
      p7a: "P7\nC2" {style.fill: "#FFCDD2"}
      p8a: "P8\nC3" {style.fill: "#C8E6C9"}
      p9a: "P9\nC1" {style.fill: "#BBDEFB"}
      p10a: "P10\nC2" {style.fill: "#FFCDD2"}
      p11a: "P11\nC3" {style.fill: "#C8E6C9"}
      p12a: "P12\nC1" {style.fill: "#BBDEFB"}
      p13a: "P13\nC2" {style.fill: "#FFCDD2"}
      p14a: "P14\nC3" {style.fill: "#C8E6C9"}
      p15a: "P15\nC1" {style.fill: "#BBDEFB"}
    }

    consumers_after: {
      direction: right
      grid-columns: 3
      grid-gap: 15
      c1_after: {
        label: "Consumer-1"
        shape: rectangle
        style.fill: "#BBDEFB"
        style.stroke: "#1976D2"
        width: 140
        a1: |md
          **P:** P0, P3, P6, P9, P12, P15
          **Redelivered:**
          - msg@200 (from C2)
        |
      }
      c2_after: {
        label: "Consumer-2"
        shape: rectangle
        style.fill: "#FFCDD2"
        style.stroke: "#D32F2F"
        width: 140
        a2: |md
          **P:** P1, P4, P7, P10, P13
          **Stats:** Active
        |
      }
      c3_after: {
        label: "Consumer-3"
        shape: rectangle
        style.fill: "#C8E6C9"
        style.stroke: "#388E3C"
        width: 140
        a3: |md
          **P:** P2, P5, P8, P11, P14
          **NEW - receives:**
          - msg@100 (from C1)
          - msg@101 (from C1)
        |
      }
    }
    partitions_after -> consumers_after: "reassigned"
  }
}

row_rebalance -> row_after: "complete"

legend: {
  near: bottom-left
  direction: right
  style.stroke: transparent
  l1: "Consumer-1" {style.fill: "#BBDEFB"; width: 100}
  l2: "Consumer-2" {style.fill: "#FFCDD2"; width: 100}
  l3: "Consumer-3" {style.fill: "#C8E6C9"; width: 100}
}

timeline_summary: {
  near: bottom-right
  label: "Timeline Summary"
  details: |md
    T+0ms: Consumer-3 joins
    T+5ms: Coordinator detects change, locks group
    T+10ms: Assignments revoked
    T+50ms: New mapping calculated
    T+100ms: Assignments pushed
    T+150ms: Group unlocked
    T+30s: Visibility timeout expires
  |
}