direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Visibility Timeout: At-Least-Once Delivery" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
timeline: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  t0: {
    label: "T=0"
    shape: circle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  t30: {
    label: "T=30s"
    shape: circle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
  }
  t31: {
    label: "T=31s"
    shape: circle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
  }
  t32: {
    label: "T=32s"
    shape: circle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  t0 -> t30: "30s window"
  t30 -> t31: "timeout"
  t31 -> t32: "redeliver"
}
queue_state: {
  label: "Message Queue State"
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  broker: {
    label: "Broker"
    shape: rectangle
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    msg: {
      label: "Message\nID: 42"
      shape: rectangle
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
    }
  }
  consumers: {
    label: "Consumers"
    direction: right
    style.fill: transparent
    style.stroke: transparent
    consumer_a: {
      label: "Consumer A"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      status_a: {
        label: "CRASHED"
        shape: diamond
        style.fill: "#EF5350"
        style.font-color: white
      }
    }
    consumer_b: {
      label: "Consumer B"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      status_b: {
        label: "ACTIVE"
        shape: diamond
        style.fill: "#66BB6A"
        style.font-color: white
      }
    }
  }
}
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#BDBDBD"
  visible: {
    label: "VISIBLE"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  invisible: {
    label: "INVISIBLE"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  visible -> invisible: "deliver"
  invisible -> visible: "timeout/ACK"
}
explanation: {
  near: bottom-center
  width: 600
  code: |'text
    VISIBILITY TIMEOUT MECHANISM:
    1. T=0:   Message delivered to Consumer A
              → Message becomes INVISIBLE (not delivered to others)
    2. T=30s: No ACK received from Consumer A
              → Visibility timeout expires
              → Consumer A may have crashed
    3. T=31s: Message becomes VISIBLE again
              → Returned to queue for redelivery
    4. T=32s: Message delivered to Consumer B
              → At-least-once delivery preserved
    KEY INSIGHT: Message doesn't disappear on delivery.
    It becomes invisible, then reappears if unacknowledged.
    This handles consumer crashes automatically.
  '|
}
state_t0: {
  label: "T=0: Deliver to Consumer A"
  direction: right
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  q0: {
    label: "Queue"
    shape: cylinder
    style.fill: "#FFCDD2"
    m0: {
      label: "msg#42\nINVISIBLE"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke-dash: 3
    }
  }
  ca0: {
    label: "Consumer A\n(receives msg#42)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  cb0: {
    label: "Consumer B"
    shape: rectangle
    style.fill: "#E0E0E0"
  }
  q0 -> ca0: "deliver" {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
}
state_t30: {
  label: "T=30s: Timeout Expired (No ACK)"
  direction: right
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  q30: {
    label: "Queue"
    shape: cylinder
    style.fill: "#FFE0B2"
    m30: {
      label: "msg#42\nTIMEOUT"
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke: "#FF9800"
      style.stroke-width: 2
    }
  }
  ca30: {
    label: "Consumer A\nCRASHED"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.stroke-dash: 4
  }
  cb30: {
    label: "Consumer B"
    shape: rectangle
    style.fill: "#E0E0E0"
  }
  q30 -> ca30: "NO ACK" {
    style.stroke: "#F44336"
    style.stroke-dash: 4
    style.stroke-width: 2
  }
}
state_t31: {
  label: "T=31s: Message Visible Again"
  direction: right
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  q31: {
    label: "Queue"
    shape: cylinder
    style.fill: "#C8E6C9"
    m31: {
      label: "msg#42\nVISIBLE"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      style.stroke-width: 2
    }
  }
  ca31: {
    label: "Consumer A\n(dead)"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.stroke-dash: 4
    style.opacity: 0.5
  }
  cb31: {
    label: "Consumer B\n(available)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  m31 -> cb31: "ready for\ndelivery" {
    style.stroke: "#2196F3"
    style.stroke-dash: 3
  }
}
state_t32: {
  label: "T=32s: Redeliver to Consumer B"
  direction: right
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  q32: {
    label: "Queue"
    shape: cylinder
    style.fill: "#FFCDD2"
    m32: {
      label: "msg#42\nINVISIBLE"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke-dash: 3
    }
  }
  ca32: {
    label: "Consumer A\n(dead)"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.stroke-dash: 4
    style.opacity: 0.5
  }
  cb32: {
    label: "Consumer B\n(receives msg#42)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  q32 -> cb32: "redeliver" {
    style.stroke: "#2196F3"
    style.stroke-width: 2
    style.animated: true
  }
}
state_t0 -> state_t30: "30 seconds pass" {
  style.stroke: "#757575"
  style.stroke-width: 2
}
state_t30 -> state_t31: "timeout\nexpires" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
state_t31 -> state_t32: "redelivery" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.animated: true
}
duplication_warning: {
  near: bottom-left
  label: "DUPLICATION SCENARIO"
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  warning_text: {
    label: "If Consumer A actually processed\nthe message but crashed before ACK,\nConsumer B will also process it.\n\nThis is why consumers MUST be\nIDEMPOTENT in at-least-once systems."
    shape: text
    style.font-color: "#E65100"
    style.italic: true
  }
}