direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Application-Level Backpressure: THROTTLE Command {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  step1: {
    direction: down
    label: "T0: Normal Operation"
    width: 280
    producer1: {
      label: "Producer"
      shape: rectangle
      style.fill: "#E8F5E9"
    }
    broker1: {
      label: "Broker"
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    queue1: {
      label: "Queue\nDepth: 1000"
      shape: queue
      style.fill: "#C8E6C9"
    }
    consumer1: {
      label: "Consumer"
      shape: rectangle
      style.fill: "#FFF3E0"
    }
    producer1 -> broker1: "PUBLISH\n(order-123)"
    broker1 -> queue1: "append"
    queue1 -> consumer1: "deliver"
    metrics1: {
      label: "Lag: 500\nThreshold: 10000"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        stroke-width: 2
      }
    }
  }
  arrow1: {
    label: "lag grows"
    shape: text
    style.font-color: "#666"
  }
  step2: {
    direction: down
    label: "T1: Lag Exceeds Threshold"
    width: 280
    producer2: {
      label: "Producer"
      shape: rectangle
      style.fill: "#E8F5E9"
    }
    broker2: {
      label: "Broker"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
        stroke-width: 2
      }
    }
    queue2: {
      label: "Queue\nDepth: 12000"
      shape: queue
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
      }
    }
    consumer2: {
      label: "Consumer\n(slow)"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
      }
    }
    producer2 -> broker2: "PUBLISH\n(order-456)"
    metrics2: {
      label: "Lag: 12000\n> Threshold!"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#F44336"
        stroke-width: 3
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  step3: {
    direction: down
    label: "T2: THROTTLE Response"
    width: 280
    producer3: {
      label: "Producer\n(waiting)"
      shape: rectangle
      style: {
        fill: "#FFF9C4"
        stroke: "#FFA000"
        stroke-width: 2
      }
    }
    broker3: {
      label: "Broker"
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    throttle_cmd: {
      label: "THROTTLE Command\n0x20 | delay_ms:100 | lag:12000"
      shape: rectangle
      style: {
        fill: "#FFF9C4"
        stroke: "#FFA000"
        stroke-dash: 4
      }
      width: 240
    }
    broker3 -> producer3: "THROTTLE\n(delay 100ms)"
    producer3 -> throttle_cmd: {
      style.stroke: transparent
    }
    note3: {
      label: "Producer backs off\nfor 100ms"
      shape: text
      style: {
        font-color: "#FFA000"
        italic: true
      }
    }
  }
  arrow2: {
    label: "backoff"
    shape: text
    style.font-color: "#666"
  }
  step4: {
    direction: down
    label: "T3: Consumer Catches Up"
    width: 280
    producer4: {
      label: "Producer\n(waiting)"
      shape: rectangle
      style: {
        fill: "#FFF9C4"
        stroke: "#FFA000"
      }
    }
    broker4: {
      label: "Broker"
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    queue4: {
      label: "Queue\nDepth: 8000"
      shape: queue
      style.fill: "#C8E6C9"
    }
    consumer4: {
      label: "Consumer\n(processing)"
      shape: rectangle
      style.fill: "#FFF3E0"
    }
    queue4 -> consumer4: "deliver\n(batch)"
    metrics4: {
      label: "Lag: 6000\n> Low: 5000"
      shape: rectangle
      style: {
        fill: "#FFF9C4"
        stroke: "#FFA000"
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  step5: {
    direction: down
    label: "T4: Lag Below Low Threshold"
    width: 280
    producer5: {
      label: "Producer"
      shape: rectangle
      style.fill: "#E8F5E9"
    }
    broker5: {
      label: "Broker"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        stroke-width: 2
      }
    }
    queue5: {
      label: "Queue\nDepth: 3000"
      shape: queue
      style.fill: "#C8E6C9"
    }
    consumer5: {
      label: "Consumer"
      shape: rectangle
      style.fill: "#FFF3E0"
    }
    producer5 -> broker5: "PUBLISH\n(order-789)"
    broker5 -> queue5: "append"
    metrics5: {
      label: "Lag: 3000\n< Low: 5000"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        stroke-width: 2
      }
    }
  }
  arrow3: {
    label: "resume"
    shape: text
    style.font-color: "#666"
  }
  step6: {
    direction: down
    label: "T5: Normal PUBLISH_ACK"
    width: 280
    producer6: {
      label: "Producer"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        stroke-width: 2
      }
    }
    broker6: {
      label: "Broker"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        stroke-width: 2
      }
    }
    ack_cmd: {
      label: "PUBLISH_ACK Command\n0x02 | msgID:789"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
      }
      width: 220
    }
    broker6 -> producer6: "PUBLISH_ACK\n(msgID=789)"
    producer6 -> ack_cmd: {
      style.stroke: transparent
    }
    note6: {
      label: "Normal operation\nresumed"
      shape: text
      style: {
        font-color: "#4CAF50"
        italic: true
      }
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  label: "Hysteresis Thresholds"
  high: {
    label: "High: 10000\n(start throttle)"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
  }
  low: {
    label: "Low: 5000\n(stop throttle)"
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  explanation: {
    label: |md
      **Why two thresholds?**
      Prevents rapid toggling between
      throttle/no-throttle states
    |
    shape: text
    style.font-size: 12
  }
}
protocol_box: {
  near: bottom-center
  label: "THROTTLE Command Wire Format"
  format: {
    shape: sql_table
    label: "THROTTLE (0x20)"
    f0: "0x00 | uint8  | CmdType = 0x20"
    f1: "0x01 | uint16 | DelayMs (BE)"
    f2: "0x03 | uint32 | CurrentLag (BE)"
    sz: "Total: 7 bytes"
  }
}
step1 -> step2: "consumers slow\nlag accumulates" {
  style: {
    stroke-dash: 3
    animated: true
  }
}
step3 -> step4: "100ms delay" {
  style: {
    stroke-dash: 3
  }
}
step4 -> step5: "consumers\ncatch up" {
  style: {
    stroke-dash: 3
    animated: true
  }
}
step5 -> step6: "lag < 5000" {
  style: {
    stroke: "#4CAF50"
  }
}