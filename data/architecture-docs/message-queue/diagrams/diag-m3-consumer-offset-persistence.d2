direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Consumer Offset Persistence {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory: {
    direction: down
    label: "In-Memory State"
    style.fill: "#E8F4E8"
    style.stroke: "#2D7D2D"
    groupOffsets: {
      shape: sql_table
      label: "OffsetStore.offsets (sync.Map)"
      g1: "orders-group | orders | 0 | 15847"
      g2: "orders-group | payments | 0 | 8923"
      g3: "analytics-group | orders | 2 | 12401"
      g4: "analytics-group | events | 0 | 45210"
    }
  }
  arrow1: {
    shape: text
    label: "← atomic commit →"
    style.font-color: "#666"
  }
  disk: {
    direction: down
    label: "Persistent Storage"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    offsetFile: {
      shape: sql_table
      label: "consumer_offsets.json"
      r1: "\"orders-group\": {"
      r2: "  \"orders\": 15847,"
      r3: "  \"payments\": 8923"
      r4: "},"
      r5: "\"analytics-group\": {"
      r6: "  \"orders\": 12401,"
      r7: "  \"events\": 45210"
      r8: "}"
    }
    tempFile: {
      shape: sql_table
      label: "consumer_offsets.json.tmp"
      t1: "(staging file during write)"
      t2: "written completely first"
      t3: "then renamed atomically"
      style.stroke-dash: 3
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  protocol: {
    direction: down
    label: "Atomic Write Protocol"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    width: 400
    step1: {
      label: "1. Serialize to temp file"
      width: 360
      code: |'go
        tempPath := filePath + ".tmp"
        jsonData, _ := json.Marshal(data)
        os.WriteFile(tempPath, jsonData, 0644)
      '|
    }
    step2: {
      label: "2. fsync temp file (ensure durability)"
      width: 360
      code: |'go
        file, _ := os.Open(tempPath)
        file.Sync()
        file.Close()
      '|
    }
    step3: {
      label: "3. Atomic rename (POSIX guarantee)"
      width: 360
      code: |'go
        // Rename is atomic on POSIX
        os.Rename(tempPath, filePath)
      '|
    }
  }
  guarantees: {
    direction: down
    label: "Crash Safety Guarantees"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    g1: {
      label: "Crash before step 1"
      desc: "Old file intact, offsets preserved"
      style.fill: "#C8E6C9"
    }
    g2: {
      label: "Crash during step 1-2"
      desc: "Temp incomplete, old file exists"
      style.fill: "#C8E6C9"
    }
    g3: {
      label: "Crash during step 3"
      desc: "Either old OR new file exists"
      style.fill: "#FFF9C4"
    }
    g4: {
      label: "After step 3 completes"
      desc: "New file visible, atomically replaced"
      style.fill: "#C8E6C9"
    }
  }
}
memory.groupOffsets -> disk.offsetFile: "CommitOffset()" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
disk.tempFile -> disk.offsetFile: "rename()" {
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.animated: true
}
protocol.step1 -> protocol.step2 -> protocol.step3
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: transparent
  style.stroke: "#999"
  l1: "Key: Atomic rename ensures offset file is never in partially-written state"
  l2: "Recovery: On startup, load offsets from JSON; missing file = start from 0"
}