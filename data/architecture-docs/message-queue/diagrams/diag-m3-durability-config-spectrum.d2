direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Durability Configuration Spectrum
  **Trade-off: Speed vs. Data Safety**
|
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  fast_end: {
    direction: down
    label: "FAST BUT RISKY"
    style.fill: "#FFE4E1"
    style.stroke: "#DC143C"
    style.stroke-width: 2
    
    risk: "Messages may be lost\non crash or power failure"
  }

  slow_end: {
    direction: down
    label: "SLOW BUT SAFE"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    
    safety: "Zero data loss\nsurvives any failure"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  spectrum: {
    label: "Durability Spectrum (Amortized Cost of fsync)"
    width: 800
    gradient: {
      shape: rectangle
      width: 780
      height: 30
      style.fill: "linear-gradient(to right, #DC143C, #FF8C00, #FFD700, #90EE90, #2E7D32)"
      style.stroke: "#333"
      style.stroke-width: 1
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  os_managed: {
    direction: down
    label: "OS-Managed\n(No fsync)"
    style.fill: "#FFCCCB"
    style.stroke: "#DC143C"
    width: 150
    throughput: "1M+ msg/s"
    latency: "< 1 ms"
    risk_node: "HIGH RISK" {
      style.fill: "#DC143C"
      style.font-color: white
      style.stroke: "#8B0000"
    }
    desc: |md
      - Never calls fsync()
      - OS flushes lazily
      - Loss: Seconds of data
    |
  }

  batched_1000: {
    direction: down
    label: "Batched\n(N=1000)"
    style.fill: "#FFE4B5"
    style.stroke: "#FF8C00"
    width: 150
    throughput: "100K msg/s"
    latency: "1-10 ms"
    risk_node: "MEDIUM RISK" {
      style.fill: "#FF8C00"
      style.font-color: white
      style.stroke: "#CC7000"
    }
    desc: |md
      - fsync every 1000 msgs
      - Or every 100ms
      - Loss: Last batch
    |
  }

  kafka_default: {
    direction: down
    label: "Kafka Style\n(Timed fsync)"
    style.fill: "#F0E68C"
    style.stroke: "#BDB76B"
    width: 150
    throughput: "50K-200K msg/s"
    latency: "5-50 ms"
    risk_node: "LOW-MEDIUM" {
      style.fill: "#DAA520"
      style.font-color: white
      style.stroke: "#B8860B"
    }
    desc: |md
      - OS flush + Timed
      - Default: ~5 seconds
      - Replication adds safety
    |
  }

  batched_100: {
    direction: down
    label: "Batched\n(N=100)"
    style.fill: "#98FB98"
    style.stroke: "#3CB371"
    width: 150
    throughput: "10K-50K msg/s"
    latency: "10-50 ms"
    risk_node: "LOW RISK" {
      style.fill: "#3CB371"
      style.font-color: white
      style.stroke: "#228B22"
    }
    desc: |md
      - Frequent fsync()
      - Small batches
      - Loss: < 100 msgs
    |
  }

  per_write: {
    direction: down
    label: "Per-Write\n(fsync every msg)"
    style.fill: "#90EE90"
    style.stroke: "#2E7D32"
    width: 150
    throughput: "100-1K msg/s"
    latency: "10-30 ms"
    risk_node: "MINIMAL RISK" {
      style.fill: "#2E7D32"
      style.font-color: white
      style.stroke: "#1B5E20"
    }
    desc: |md
      - Hard durability
      - Sync IO path
      - Loss: Zero
    |
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  rabbitmq: {
    direction: down
    label: "RabbitMQ Range"
    style.fill: "#FF6B35"
    style.stroke: "#D4380D"
    style.stroke-dash: 3
    style.double-border: true
    width: 180
    position: "Mode: Persistent"
    note: |md
      - Configurable per queue
      - Uses batching for files
      - Confirms to publisher
    |
  }

  production: {
    direction: down
    label: "Typical Enterprise"
    style.fill: "#4169E1"
    style.stroke: "#1E3A8A"
    style.stroke-dash: 3
    style.double-border: true
    width: 180
    position: "Batched + Multi-AZ"
    note: |md
      - Balance of TPT/Safety
      - Relies on sync replication
      - N=500 is common
    |
  }

  financial: {
    direction: down
    label: "Financial/Ledger"
    style.fill: "#6B8E23"
    style.stroke: "#556B2F"
    style.stroke-dash: 3
    style.double-border: true
    width: 180
    position: "Strict Per-Write"
    note: |md
      - Absolute zero loss
      - Higher latency accepted
      - Sync Replica flush
    |
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  code_config: {
    label: "Implementation API (broker.go)"
    width: 380
    code: |'go
      type WriterConfig struct {
          DurabilityMode   Mode
          BatchSize        int           // N messages
          BatchTimeout     time.Duration // M ms
      }
      const (
          PerWrite   Mode = iota // fsync every write
          Batched                // fsync every N or M
          OSManaged              // never fsync
      )
    '|
  }

  decision_table: {
    label: "Decision Matrix"
    width: 420
    # Use |'md delimiter because table contains | characters
    content: |'md
      | Use Case | Mode | Justification |
      | :--- | :--- | :--- |
      | High-vol Logs | OS-Managed | Throughput >> Loss |
      | Event Bus | Batched (1000) | Amortized Disk IO |
      | Order Sync | Batched (100) | Small failure window |
      | Payments | Per-Write | Data is Money |
      | Analytics | OS-Managed | Re-ingestible data |
    '|
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  warning_box: {
    label: "⚠️ Critical Technical Insight"
    style.fill: "#FFF3CD"
    style.stroke: "#FFC107"
    style.stroke-width: 2
    width: 800
    insight: |'md
      **The fsync() cost is a physical constraint** — forcing a disk head or NAND controller to commit (1-30ms).
      - **NVMe**: ~0.5ms | **SSD**: ~2ms | **HDD**: ~15ms per fsync operation.
      Batching amortizes this cost: 1000 messages with 1 fsync = **0.002ms** overhead per message.
      **REPLICATION IS NOT FSYNC**: Un-fsynced data in page cache is lost on power failure, even if replicated.
    '|
  }
}

# Explicit layout connections
fast_end -> os_managed: "Direct Path"
slow_end -> per_write: "Direct Path"

os_managed -> batched_1000: "Increasing Durability"
batched_1000 -> kafka_default
kafka_default -> batched_100
batched_100 -> per_write

rabbitmq -> kafka_default: "Overlap"
production -> batched_1000: "Standard"
financial -> per_write: "Compliance"