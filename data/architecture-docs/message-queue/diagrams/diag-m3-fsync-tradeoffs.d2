direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # The fsync Throughput Tradeoff
  **Durability vs. Speed: Choose Your Position on the Spectrum**
| {near: top-center}
row_comparison: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  mode_per_write: {
    direction: down
    label: "Per-Write fsync"
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.stroke-width: 3
    safety_badge: {
      label: "MAXIMUM\nDURABILITY"
      shape: oval
      style.fill: "#28a745"
      style.font-color: white
      style.bold: true
    }
    throughput_box: {
      label: "~100 msg/sec"
      style.fill: "#ffc107"
      style.stroke: "#856404"
      style.bold: true
      width: 120
    }
    behavior: {
      label: "Behavior"
      shape: rectangle
      desc: |md
        - `fsync()` after every write
        - Each message guaranteed on disk
        - Blocks until physical write completes
      |
    }
    crash_impact: {
      label: "Crash Impact"
      shape: rectangle
      style.fill: "#d4edda"
      desc: |md
        **ZERO DATA LOSS**
        Every acknowledged message survives
      |
    }
    use_case: {
      label: "Best For"
      shape: rectangle
      desc: |md
        - Financial transactions
        - Critical audit logs
        - Compliance requirements
      |
    }
    safety_badge -> throughput_box
    throughput_box -> behavior
    behavior -> crash_impact
    crash_impact -> use_case
  }
  mode_batched: {
    direction: down
    label: "Batched fsync"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.stroke-width: 3
    balance_badge: {
      label: "BALANCED"
      shape: oval
      style.fill: "#ffc107"
      style.font-color: "#333"
      style.bold: true
    }
    throughput_box: {
      label: "~10,000 msg/sec"
      style.fill: "#17a2b8"
      style.font-color: white
      style.bold: true
      width: 120
    }
    behavior: {
      label: "Behavior"
      shape: rectangle
      desc: |md
        - `fsync()` every N writes or M ms
        - Default: every 1000 msgs or 100ms
        - Kafka default: every 5 seconds
      |
    }
    crash_impact: {
      label: "Crash Impact"
      shape: rectangle
      style.fill: "#fff3cd"
      desc: |md
        **LOSE LAST BATCH**
        Up to N messages or M ms of data
      |
    }
    use_case: {
      label: "Best For"
      shape: rectangle
      desc: |md
        - General purpose messaging
        - Event streaming (Kafka default)
        - Most production workloads
      |
    }
    balance_badge -> throughput_box
    throughput_box -> behavior
    behavior -> crash_impact
    crash_impact -> use_case
  }
  mode_os: {
    direction: down
    label: "OS-Managed"
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.stroke-width: 3
    speed_badge: {
      label: "MAXIMUM\nTHROUGHPUT"
      shape: oval
      style.fill: "#dc3545"
      style.font-color: white
      style.bold: true
    }
    throughput_box: {
      label: "~100,000+ msg/sec"
      style.fill: "#28a745"
      style.font-color: white
      style.bold: true
      width: 120
    }
    behavior: {
      label: "Behavior"
      shape: rectangle
      desc: |md
        - Never call `fsync()`
        - OS decides when to flush
        - Dirty pages live in RAM
      |
    }
    crash_impact: {
      label: "Crash Impact"
      shape: rectangle
      style.fill: "#f8d7da"
      desc: |md
        **SECONDS TO MINUTES**
        All unflushed data lost
        (depends on OS dirty page timeout)
      |
    }
    use_case: {
      label: "Best For"
      shape: rectangle
      desc: |md
        - High-volume telemetry
        - Temporary caching
        - Acceptable data loss scenarios
      |
    }
    speed_badge -> throughput_box
    throughput_box -> behavior
    behavior -> crash_impact
    crash_impact -> use_case
  }
}
spectrum_bar: {
  label: "Durability/Speed Spectrum"
  style.fill: transparent
  style.stroke: "#333"
  style.stroke-width: 2
  left_label: {
    label: "SAFE\n(slow)"
    shape: text
    style.font-color: "#28a745"
    style.bold: true
  }
  right_label: {
    label: "FAST\n(risky)"
    shape: text
    style.font-color: "#dc3545"
    style.bold: true
  }
  gradient: {
    shape: rectangle
    width: 600
    height: 20
    style.fill: "linear-gradient(to right, #28a745, #ffc107, #dc3545)"
    style.stroke: "#333"
  }
  marker_safe: {
    label: "per-write"
    shape: text
    style.font-size: 12
  }
  marker_balanced: {
    label: "batched"
    shape: text
    style.font-size: 12
  }
  marker_fast: {
    label: "OS-managed"
    shape: text
    style.font-size: 12
  }
}
code_example: {
  label: "Configuring Durability Mode (broker/config.go)"
  width: 500
  code: |'go
    type DurabilityMode int
    const (
        DurabilityPerWrite DurabilityMode = iota  // fsync every write
        DurabilityBatched                          // fsync every N/timeout
        DurabilityOSManaged                        // never fsync
    )
    type WriterConfig struct {
        DurabilityMode DurabilityMode
        BatchSize      int           // 1000 msgs
        BatchTimeout   time.Duration // 100ms
    }
  '|
}
key_insight: {
  label: "Key Insight"
  shape: callout
  style.fill: "#e2e3e5"
  desc: |md
    **There is no "right" answer** — only tradeoffs.
    The fsync decision is a CAP theorem choice:
    - Per-write = CP (consistent, slower)
    - OS-managed = AP (available, may lose data)
    **Most production systems choose batched** with a small window,
    accepting that a crash might lose the last ~100ms of messages.
  |
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  legend_title: {
    label: "fsync Cost Reference"
    shape: text
    style.bold: true
  }
  ssd: {
    label: "SSD: 1-10ms per fsync"
    shape: rectangle
    style.fill: "#f8f9fa"
  }
  hdd: {
    label: "HDD: 10-30ms per fsync"
    shape: rectangle
    style.fill: "#f8f9fa"
  }
  nvme: {
    label: "NVMe: 0.1-1ms per fsync"
    shape: rectangle
    style.fill: "#f8f9fa"
  }
}
row_comparison.mode_per_write -> spectrum_bar.marker_safe: "safest"
row_comparison.mode_batched -> spectrum_bar.marker_balanced: "balanced"
row_comparison.mode_os -> spectrum_bar.marker_fast: "fastest"