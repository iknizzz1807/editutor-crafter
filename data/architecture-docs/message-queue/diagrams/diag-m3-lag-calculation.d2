    }
    entry9: {
      shape: rectangle
      label: "[9] order-010"
      style.fill: "#FCE4D6"
      style.stroke: "#E67E22"
      style.stroke-width: 3
    }
    entry10: {
      shape: rectangle
      label: "[10] order-011"
      style.fill: "#FCE4D6"
      style.stroke: "#E67E22"
      style.stroke-width: 3
    }
    entry11: {
      shape: rectangle
      label: "[11] order-012"
      style.fill: "#FCE4D6"
      style.stroke: "#E67E22"
      style.stroke-width: 3
    }
    latest: {
      shape: rectangle
      label: "[12] order-013"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      style.stroke-width: 3
    }
    legend_processed: "Processed" {
      shape: rectangle
      style.fill: "#B8D4E8"
      width: 80
    }
    legend_pending: "Pending" {
      shape: rectangle
      style.fill: "#FCE4D6"
      style.stroke: "#E67E22"
      width: 80
    }
    legend_latest: "Latest" {
      shape: rectangle
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      width: 80
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  offsets: Offset Tracking {
    direction: down
    style.fill: "#FFF3CD"
    width: 280
    latest_box: {
      label: "Latest Log Offset"
      shape: rectangle
      style: {
        fill: "#D4EDDA"
        stroke: "#28A745"
        stroke-width: 2
        bold: true
        font-size: 18
      }
      width: 240
    }
    latest_value: {
      label: "= 12"
      shape: text
      style: {
        font-size: 28
        bold: true
        font-color: "#28A745"
      }
    }
    committed_box: {
      label: "Consumer Committed Offset"
      shape: rectangle
      style: {
        fill: "#FCE4D6"
        stroke: "#E67E22"
        stroke-width: 2
        bold: true
        font-size: 18
      }
      width: 240
    }
    committed_value: {
      label: "= 8"
      shape: text
      style: {
        font-size: 28
        bold: true
        font-color: "#E67E22"
      }
    }
    lag_box: {
      label: "Consumer Lag"
      shape: rectangle
      style: {
        fill: "#F8D7DA"
        stroke: "#DC3545"
        stroke-width: 2
        bold: true
        font-size: 18
      }
      width: 240
    }
    lag_formula: {
      label: "= 12 - 8 = 4 messages"
      shape: text
      style: {
        font-size: 24
        bold: true
        font-color: "#DC3545"
      }
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  backpressure: Backpressure Decision Engine {
    direction: down
    style.fill: "#F5F5F5"
    width: 600
    bp_title: {
      label: "BackpressureManager (broker/backpressure.go)"
      shape: text
      style: {
        bold: true
        font-size: 16
      }
    }
    bp_struct: {
      shape: class
      label: "BackpressureManager"
      -lagThresholdHigh: "int64"
      -lagThresholdLow: "int64"
      -latestOffset: "int64"
      -throttling: "int32"
      -groups: "map[string]*GroupLag"
      +UpdateLatestOffset(offset): "void"
      +UpdateCommittedOffset(group, offset): "void"
      +CalculateLag(): "int64"
      +ShouldThrottle(): "bool"
    }
    bp_logic: {
      label: "Throttling Logic (Hysteresis)"
      code: |'go
        func (bm *BackpressureManager) ShouldThrottle() bool {
          currentLag := bm.CalculateLag()
          currentlyThrottling := atomic.LoadInt32(&bm.throttling) == 1
          if currentlyThrottling {
            if currentLag < bm.lagThresholdLow {  // 5000
              atomic.StoreInt32(&bm.throttling, 0)
              return false  // Stop throttling
            }
            return true
          }
          if currentLag > bm.lagThresholdHigh {  // 10000
            atomic.StoreInt32(&bm.throttling, 1)
            return true  // Start throttling
          }
          return false
        }
      '|
      width: 380
    }
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  thresholds: Threshold Configuration {
    direction: down
    style.fill: "#E2E3E5"
    width: 280
    th_title: {
      label: "Default Thresholds"
      shape: text
      style.bold: true
    }
    th_high: {
      label: "LagThresholdHigh: 10,000"
      shape: rectangle
      style.fill: "#F8D7DA"
    }
    th_low: {
      label: "LagThresholdLow: 5,000"
      shape: rectangle
      style.fill: "#FFF3CD"
    }
    th_delay: {
      label: "ThrottleDelay: 100ms"
      shape: rectangle
      style.fill: "#D4EDDA"
    }
    hysteresis: {
      label: "Hysteresis prevents rapid toggling"
      shape: text
      style.italic: true
      style.font-color: "#6C757D"
    }
  }
  response: Throttle Response {
    direction: down
    style.fill: "#F8D7DA"
    width: 280
    resp_title: {
      label: "When Lag > Threshold"
      shape: text
      style.bold: true
      style.font-color: "#DC3545"
    }
    cmd_box: {
      label: "THROTTLE Command (0x20)"
      shape: rectangle
      style.fill: "#FFFFFF"
    }
    cmd_format: {
      label: |md
        **Format:**
        - 1 byte: Command (0x20)
        - 2 bytes: DelayMs (BE)
        - 4 bytes: CurrentLag (BE)
      |
      shape: text
      style.font: mono
      style.font-size: 12
    }
    action: {
      label: "Producer backs off for DelayMs"
      shape: text
      style.italic: true
    }
  }
}
log.latest_box -> offsets.latest_box: "Latest offset\nproduced" {
  style.stroke: "#28A745"
  style.stroke-width: 2
}
log.entry8 -> offsets.committed_box: "Committed offset\n(acknowledged)" {
  style.stroke: "#E67E22"
  style.stroke-dash: 4
}
offsets.lag_box -> backpressure.bp_title: "Drives decision" {
  style.stroke: "#DC3545"
  style.stroke-width: 2
}
backpressure.bp_logic -> response.cmd_box: "lag > threshold" {
  style.stroke: "#DC3545"
  style.stroke-dash: 4
  label: "triggers"
}