      style.fill: "#B8D4E8"
    }
    entry3: {
      shape: rectangle
      label: "[3] order-004"
      style.fill: "#B8D4E8"
    }
    entry4: {
      shape: rectangle
      label: "[4] order-005"
      style.fill: "#B8D4E8"
    }
    entry5: {
      shape: rectangle
      label: "[5] order-006"
      style.fill: "#B8D4E8"
    }
    entry6: {
      shape: rectangle
      label: "[6] order-007"
      style.fill: "#B8D4E8"
    }
    entry7: {
      shape: rectangle
      label: "[7] order-008"
      style.fill: "#B8D4E8"
    }
    entry8: {
      shape: rectangle
      label: "[8] order-009"
      style.fill: "#FCE4D6"
