  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  log: Append-Only Log (topic: orders) {
    direction: down
    style.fill: "#E8F4FD"
    entry0: {
      shape: rectangle
      label: "[0] order-001"
      style.fill: "#B8D4E8"
    }
    entry1: {
      shape: rectangle
      label: "[1] order-002"
      style.fill: "#B8D4E8"
    }
    entry2: {
      shape: rectangle
