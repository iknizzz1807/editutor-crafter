direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Log Entry Binary Format"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  log_entry: {
    label: "Log Entry Layout (variable size)"
    header: {
      label: "Header (22 bytes fixed)"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      offset: {
        label: "Offset\n8 bytes\n0x00-0x07"
        shape: rectangle
        style.fill: "#B8D4E3"
        width: 80
      }
      timestamp: {
        label: "Timestamp\n8 bytes\n0x08-0x0F"
        shape: rectangle
        style.fill: "#B8D4E3"
        width: 80
      }
      topic_len: {
        label: "TopicLen\n2 bytes\n0x10-0x11"
        shape: rectangle
        style.fill: "#B8D4E3"
        width: 80
      }
      payload_len: {
        label: "PayloadLen\n4 bytes\n0x12-0x15"
        shape: rectangle
        style.fill: "#B8D4E3"
        width: 80
      }
    }
    body: {
      label: "Body (variable)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      style.stroke-width: 2
      topic: {
        label: "Topic\nN bytes\n0x16+"
        shape: rectangle
        style.fill: "#FFE0B2"
        width: 120
      }
      payload: {
        label: "Payload\nM bytes\nvaries"
        shape: rectangle
        style.fill: "#FFE0B2"
        width: 120
      }
    }
    footer: {
      label: "Footer (4 bytes)"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
      crc32: {
        label: "CRC32\n4 bytes\nlast"
        shape: rectangle
        style.fill: "#A5D6A7"
        width: 100
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  crc_scope: {
    label: "CRC32 Calculation Scope"
    style.fill: "#FAFAFA"
    style.stroke: "#424242"
    crc_header: {
      label: |md
        **Checksum covers ALL bytes EXCEPT CRC field itself**
      |
      shape: text
      style.font-size: 14
    }
    scope_box: {
      label: "Bytes Included in CRC"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      style.stroke-width: 3
      style.stroke-dash: 4
      width: 350
      included: {
        label: "Offset + Timestamp + TopicLen + PayloadLen + Topic + Payload"
        shape: text
        style.font-size: 12
        style.bold: true
      }
    }
    excluded_box: {
      label: "Bytes EXCLUDED from CRC"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      style.stroke-width: 3
      width: 350
      excluded: {
        label: "CRC32 (4 bytes at end)"
        shape: text
        style.font-size: 12
        style.bold: true
      }
    }
  }
  validation: {
    label: "Recovery Validation Flow"
    style.fill: "#FAFAFA"
    style.stroke: "#424242"
    read_entry: {
      label: "Read Entry\nfrom Disk"
      shape: oval
      style.fill: "#E8EAF6"
    }
    calc_crc: {
      label: "Calculate CRC32\nover bytes [0 : len-4]"
      shape: rectangle
      style.fill: "#FFF8E1"
    }
    compare: {
      label: "Compare\nstored vs calculated"
      shape: diamond
      style.fill: "#FCE4EC"
    }
    match: {
      label: "Entry Valid\nProcess normally"
      shape: oval
      style.fill: "#C8E6C9"
    }
    mismatch: {
      label: "CRC Mismatch\nSkip entry\nLog warning"
      shape: oval
      style.fill: "#FFCDD2"
    }
    read_entry -> calc_crc: "parse"
    calc_crc -> compare: "result"
    compare -> match: "equal" {
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
    compare -> mismatch: "not equal" {
      style.stroke: "#C62828"
      style.stroke-width: 2
      style.stroke-dash: 4
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  example: {
    label: "Example: PUBLISH to topic \"orders\""
    style.fill: "#FAFAFA"
    style.stroke: "#424242"
    ex_table: {
      shape: sql_table
      label: "Log Entry (log/writer.go)"
      f0: "0x00-0x07 | uint64    | Offset = 0x0000000000000042"
      f1: "0x08-0x0F | int64     | Timestamp = 1709821200000000000"
      f2: "0x10-0x11 | uint16    | TopicLen = 6"
      f3: "0x12-0x15 | uint32    | PayloadLen = 11"
      f4: "0x16-0x1B | [6]byte   | Topic = \"orders\""
      f5: "0x1C-0x26 | [11]byte  | Payload = \"order-12345\""
      f6: "0x27-0x2A | uint32    | CRC32 = 0xDEADBEEF"
      sz: "Total: 43 bytes (22 header + 17 body + 4 footer)"
    }
    note: {
      label: |md
        **Field Sizes:**
        - Header: 22 bytes (always)
        - Body: `len(Topic) + len(Payload)` bytes
        - Footer: 4 bytes (always)
        **CRC32 Algorithm:**
        go
        crc := crc32.ChecksumIEEE(
          buf[0 : len(buf)-4]
        )
        
      |
      shape: rectangle
      style.fill: "#F5F5F5"
      width: 320
    }
  }
  corruption: {
    label: "Corruption Detection"
    style.fill: "#FAFAFA"
    style.stroke: "#424242"
    causes: {
      shape: sql_table
      label: "CRC Mismatch Causes"
      c1: "Bit flip | Cosmic ray, failing RAM"
      c2: "Partial write | Power loss during write()"
      c3: "Media degradation | Bad disk sector"
      c4: "Network error | Corrupted transfer"
    }
    handling: {
      label: |md
        **Recovery Behavior:**
        1. Log warning with entry offset
        2. Skip corrupted entry
        3. Scan forward for next valid header
        4. Continue processing
        **Never halt broker on single corrupt entry**
      |
      shape: rectangle
      style.fill: "#FFF3E0"
      width: 280
    }
  }
}
legend: {
  near: bottom-right
  label: "Color Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  header_key: {
    label: "Header (fixed)"
    shape: rectangle
    style.fill: "#E8F4FD"
    width: 100
  }
  body_key: {
    label: "Body (variable)"
    shape: rectangle
    style.fill: "#FFF3E0"
    width: 100
  }
  crc_key: {
    label: "CRC32 (checksum)"
    shape: rectangle
    style.fill: "#E8F5E9"
    width: 100
  }
}