direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# ROW 1: GROWTH PATTERN ANALYSIS
# -----------------------------------------------------------------------------
monitoring_patterns: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  linear_analysis: {
    label: "Pattern A: Linear DLQ Growth"
    
    stats: {
      shape: sql_table
      label: "TimeSeries Data (Linear Accumulation)"
      t1: "T+1m | 200 msg  | HEALTHY"
      t2: "T+2m | 450 msg  | HEALTHY"
      t3: "T+3m | 700 msg  | WARNING"
      t4: "T+4m | 950 msg  | WARNING"
      t5: "T+5m | 1200 msg | DEGRADED"
      threshold: "Limit | 1000 msg | ALERT_TRIGGERED"
    }

    status_indicator: {
      shape: rectangle
      label: "Status: DEGRADED"
      note: "Warning: DLQ depth exceeding linear threshold"
      style.fill: "#fff3cd"
      style.stroke: "#ffc107"
    }
  }

  exponential_analysis: {
    label: "Pattern B: Exponential DLQ Growth"
    
    stats: {
      shape: sql_table
      label: "TimeSeries Data (Poison Pill Pattern)"
      t1: "T+1m | 50 msg   | HEALTHY"
      t2: "T+2m | 100 msg  | HEALTHY"
      t3: "T+3m | 250 msg  | WARNING"
      t4: "T+4m | 600 msg  | WARNING"
      t5: "T+5m | 1500 msg | CRITICAL"
      t6: "T+6m | 3500 msg | CRITICAL"
      meta: "Trend: Unbounded recursive growth"
    }

    critical_indicator: {
      shape: rectangle
      label: "Status: CRITICAL"
      note: "Immediate Investigation: Possible Poison Message"
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
      style.font-color: "#721c24"
    }
  }
}

# -----------------------------------------------------------------------------
# ROW 2: IMPLEMENTATION LOGIC (health.go)
# -----------------------------------------------------------------------------
implementation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  logic_engine: {
    label: "HealthChecker Component"
    
    checker_class: {
      shape: class
      label: "HealthChecker (health.go)"
      -broker: "*PersistentBroker"
      -dlqThreshold: "int"
      -lagThreshold: "int64"
      +Check(): "*HealthResponse"
    }

    # RENAMED from 'steps' to 'execution_flow' to avoid keyword collision
    execution_flow: {
      label: "Internal Check Algorithm"
      
      step1: {
        label: "Fetch Metrics"
        code: |'go
          topics := hc.broker.GetDLQTopics()
          var total int
          var violators []string
        '|
      }

      step2: {
        label: "Evaluate Thresholds"
        code: |'go
          for _, t := range topics {
            depth := hc.broker.GetDLQDepth(t)
            total += depth
            if depth > hc.dlqThreshold {
              violators = append(violators, t)
            }
          }
        '|
      }

      step3: {
        label: "Determine HealthState"
        code: |'go
          if len(violators) > 0 {
            return &HealthResponse{
              Status: StatusDegraded,
              Total:  total,
            }
          }
        '|
      }

      step1 -> step2 -> step3: "Logic Flow"
    }
  }

  api_contract: {
    label: "Output Contract"

    resp_struct: {
      shape: class
      label: "HealthResponse (JSON DTO)"
      status: "string"
      timestamp: "int64"
      total_depth: "int"
      violators: "[]string"
    }

    example_json: {
      label: "Example Payload"
      code: |'json
        {
          "status": "DEGRADED",
          "timestamp": 1709606400,
          "total_depth": 1523,
          "violators": ["orders.dlq"]
        }
      '|
    }

    resp_struct -> example_json: "Marshals To"
  }
}

# -----------------------------------------------------------------------------
# ROW 3: DEPLOYMENT & CONFIGURATION
# -----------------------------------------------------------------------------
deployment_config: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  k8s_integration: {
    label: "Kubernetes Runtime Policy"

    probe_config: {
      label: "Pod Probes (deployment.yaml)"
      code: |'yaml
        livenessProbe:
          httpGet:
            path: /health
            port: 8080
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health
            port: 8080
          periodSeconds: 10
      '|
    }

    mapping_table: {
      shape: sql_table
      label: "Probe Behavior Matrix"
      h1: "HEALTHY   | 200 OK  | Traffic: ALLOW | Action: None"
      h2: "DEGRADED  | 200 OK  | Traffic: ALLOW | Action: PagerAlert"
      h3: "UNHEALTHY | 503 ERR | Traffic: DENY  | Action: RestartPod"
    }
  }

  env_parameters: {
    label: "Runtime Configuration"
    
    vars_table: {
      shape: sql_table
      label: "Environment Variables"
      v1: "DLQ_THRESHOLD | 1000  | Trigger warning state"
      v2: "LAG_THRESHOLD | 10000 | Consumer delay limit"
      v3: "CHECK_INTERVAL| 30s   | Polling frequency"
    }
  }
}

# -----------------------------------------------------------------------------
# CONNECTORS & LEGEND
# -----------------------------------------------------------------------------
monitoring_patterns -> implementation: "triggers"
implementation -> deployment_config: "reports to"

legend_box: {
  label: "Alerting Guidelines"
  documentation: |'md
    ### Growth Classifications
    - **Linear**: Result of high volume or slow consumers. Resolution: Scale workers.
    - **Exponential**: Result of unprocessable messages. Resolution: Fix downstream bug.
    
    ### State Definitions
    - **DEGRADED**: Service functional but requires engineer attention.
    - **UNHEALTHY**: Service state corrupt; restart initiated by Orchestrator.
  '|
}
legend_box.near: bottom-right