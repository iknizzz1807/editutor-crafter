direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Dead Letter Queue as Separate Topic Architecture"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  original_topic: {
    direction: down
    label: "orders (Original Topic)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    pending_queue: {
      label: "Pending Queue"
      shape: queue
      style.fill: "#C8E6C9"
    }
    in_flight: {
      label: "In-Flight Map"
      shape: cylinder
      style.fill: "#A5D6A7"
    }
    pending_queue -> in_flight: "deliver"
  }
  consumer_group: {
    direction: down
    label: "Consumer Group"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    consumer1: {
      label: "Consumer A"
      shape: person
    }
    consumer2: {
      label: "Consumer B"
      shape: person
    }
    consumer3: {
      label: "Consumer C"
      shape: person
    }
  }
  original_topic.in_flight -> consumer_group: "MsgID: 42\nPayload"
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  retry_logic: {
    direction: down
    label: "Retry Logic (ConsumerGroup)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    retry_counter: {
      shape: sql_table
      label: "Retry Counter"
      f0: "MsgID | 42"
      f1: "Count | 5"
      f2: "Max | 5"
    }
    decision: {
      label: "retries >= max_retries?"
      shape: diamond
    }
    retry_counter -> decision
  }
  failure_path: {
    direction: down
    label: "Failure Handling"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    nack: {
      label: "NACK received\n(reason: \"deserialization error\")"
      shape: parallelogram
    }
    retry_queue: {
      label: "Re-queue for retry"
      shape: queue
      style.fill: "#FFCDD2"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dlq_manager: {
    direction: down
    label: "DLQManager"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    move_method: {
      label: "MoveToDLQ()"
      shape: hexagon
      style.fill: "#E1BEE7"
    }
    dlq_msg: {
      shape: sql_table
      label: "DLQMessage (JSON)"
      f0: "OriginalTopic | orders"
      f1: "OriginalOffset | 42"
      f2: "OriginalPayload | {...}"
      f3: "RetryCount | 5"
      f4: "LastFailureReason | deserialization error"
      f5: "FailedAt | 1709625600000000000"
      f6: "ConsumerID | consumer-b"
      f7: "IsReplayed | false"
      sz: "JSON serialized for inspection"
    }
    move_method -> dlq_msg: "wrap"
  }
  dlq_topic: {
    direction: down
    label: "orders.dlq (Dead Letter Topic)"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    style.stroke-width: 2
    style.stroke-dash: 4
    dlq_log: {
      label: "orders.dlq.log"
      shape: cylinder
      style.fill: "#F8BBD9"
    }
    dlq_log_note: {
      label: "Full topic with:\n- Persistence\n- Retention policies\n- Same protocol"
      shape: text
      style.font-size: 12
      style.italic: true
    }
    dlq_log -> dlq_log_note
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dlq_subscribers: {
    direction: down
    label: "DLQ Subscribers (Ops/Alerting)"
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    style.stroke-width: 2
    ops_console: {
      label: "Operations Console\n(Inspection API)"
      shape: rectangle
      style.fill: "#B2EBF2"
    }
    alerting: {
      label: "Alerting System\n(DLQ depth monitor)"
      shape: rectangle
      style.fill: "#B2EBF2"
    }
    dlq_consumer: {
      label: "DLQ Consumer\n(manual replay)"
      shape: person
    }
  }
}
consumer_group -> row2.retry_logic.nack: "NACK\n(failure)" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
  style.animated: true
}
row2.retry_logic.decision -> row2.failure_path.retry_queue: "No\n(retry)" {
  label: "retries < max"
  style.stroke: "#FF9800"
}
row2.retry_logic.decision -> row3.dlq_manager.move_method: "Yes\n(poison)" {
  label: "retries >= max"
  style.stroke: "#9C27B0"
  style.stroke-width: 3
}
row3.dlq_manager.dlq_msg -> row3.dlq_topic.dlq_log: "append" {
  label: "JSON payload"
  style.stroke: "#E91E63"
  style.stroke-width: 2
}
row3.dlq_topic.dlq_log -> row4.dlq_subscribers: "fan-out" {
  label: "DLQ messages"
  style.stroke: "#00BCD4"
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  normal: {
    label: "Normal flow"
    shape: text
  }
  retry_line: {
    label: "Retry path"
    shape: text
    style.font-color: "#FF9800"
  }
  poison_line: {
    label: "Poison message path"
    shape: text
    style.font-color: "#9C27B0"
  }
  dlq_topic_line: {
    label: "DLQ (separate topic)"
    shape: text
    style.font-color: "#E91E63"
  }
}