direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Health Check States and Criteria
| {near: top-center}
row_states: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_healthy: {
    direction: down
    label: HEALTHY
    shape: circle
    style: {
      fill: "#ACE1AF"
      stroke: "#2E7D32"
      stroke-width: 3
      font-color: "#1B5E20"
      bold: true
      font-size: 20
    }
    desc: |md
      All checks pass
      Ready to serve traffic
    |
  }
  state_degraded: {
    direction: down
    label: DEGRADED
    shape: circle
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 3
      font-color: "#F57F17"
      bold: true
      font-size: 20
    }
    desc: |md
      Operational but impaired
      Alerts should fire
    |
  }
  state_unhealthy: {
    direction: down
    label: UNHEALTHY
    shape: circle
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 3
      font-color: "#B71C1C"
      bold: true
      font-size: 20
    }
    desc: |md
      Cannot serve traffic
      Kubernetes restarts pod
    |
  }
}
state_healthy -> state_degraded: "DLQ growing\nOR lag high\nOR some consumers down" {
  style: {
    stroke: "#F9A825"
    stroke-width: 2
  }
}
state_degraded -> state_healthy: "All checks pass\nagain" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    stroke-dash: 4
  }
}
state_degraded -> state_unhealthy: "Log unwritable\nOR all consumers dead\nOR critical failure" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}
state_unhealthy -> state_degraded: "Critical issue\nresolved" {
  style: {
    stroke: "#F9A825"
    stroke-width: 2
    stroke-dash: 4
  }
}
row_checks: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  check_log: {
    direction: down
    label: Log Writable Check
    shape: class
    check: "() error"
    crit: "CRITICAL"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
    }
  }
  check_consumers: {
    direction: down
    label: Consumer Groups Check
    shape: class
    active: "() int"
    total: "() int"
    warn: "DEGRADED if 0 active"
    crit: "UNHEALTHY if all dead"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
    }
  }
  check_dlq: {
    direction: down
    label: DLQ Growth Check
    shape: class
    depth: "() int"
    threshold: "int (default 1000)"
    warn: "DEGRADED if exceeded"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
    }
  }
  check_lag: {
    direction: down
    label: Consumer Lag Check
    shape: class
    lag: "() int64"
    threshold: "int64 (default 10000)"
    warn: "DEGRADED if exceeded"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
    }
  }
}
check_log -> state_unhealthy: "FAIL" {
  style: {
    stroke: "#C62828"
    stroke-width: 3
    bold: true
  }
}
check_consumers -> state_unhealthy: "all dead" {
  style: {
    stroke: "#C62828"
    stroke-width: 3
  }
}
check_consumers -> state_degraded: "none active" {
  style: {
    stroke: "#F9A825"
    stroke-width: 2
  }
}
check_dlq -> state_degraded: "depth > threshold" {
  style: {
    stroke: "#F9A825"
    stroke-width: 2
  }
}
check_lag -> state_degraded: "lag > threshold" {
  style: {
    stroke: "#F9A825"
    stroke-width: 2
  }
}
legend: {
  near: bottom-center
  label: HTTP Status Codes
  style.fill: transparent
  style.stroke: "#CBD6E0"
  healthy: "HEALTHY/DEGRADED → HTTP 200 (traffic served)" {
    style.fill: "#ACE1AF"
  }
  unhealthy: "UNHEALTHY → HTTP 503 (traffic stopped)" {
    style.fill: "#FFCDD2"
  }
}