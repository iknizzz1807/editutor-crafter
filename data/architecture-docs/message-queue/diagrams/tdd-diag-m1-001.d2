vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Module Architecture: Protocol Layer Components
  **Intel-Manual Grade Specification**
  *Data flow from TCP stream through frame extraction to command object construction*
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# STYLING & CLASSES
# -----------------------------------------------------------------------------------------
classes: {
  tcp_socket: {
    shape: hexagon
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      shadow: true
    }
  }
  protocol_component: {
    style: {
      fill: "#FFF9E6"
      stroke: "#F9A825"
      stroke-width: 2
      border-radius: 4
    }
  }
  data_structure: {
    shape: class
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  memory_layout: {
    shape: sql_table
    style: {
      stroke: "#37474F"
      stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------------------
# NETWORK LAYER
# -----------------------------------------------------------------------------------------
TcpInterface: {
  class: tcp_socket
  label: "Network Interface\n(net.Conn / Socket)"
  tooltip: "Physical TCP Stream - Byte Array Source"
}

# -----------------------------------------------------------------------------------------
# FRAME SPECIFICATION (Memory Layout)
# -----------------------------------------------------------------------------------------
FrameFormat: {
  class: memory_layout
  label: "Wire Format: Length-Prefixed Frame"
  
  "Offset 0x00": "Length (Big-Endian)" {
    constraint: "4 Bytes [uint32]"
    style.fill: "#D1C4E9"
  }
  "Offset 0x04": "Payload (Command Data)" {
    constraint: "N Bytes [[]byte]"
    style.fill: "#BBDEFB"
  }
  "Alignment": "Padding" {
    constraint: "0-7 Bytes (64-bit alignment)"
    style.fill: "#CFD8DC"
    style.stroke-dash: 3
  }
}

# -----------------------------------------------------------------------------------------
# PROTOCOL IMPLEMENTATION (Logic)
# -----------------------------------------------------------------------------------------
FrameReader: {
  class: data_structure
  label: "FrameReader"
  reader: "*bufio.Reader"
  buffer_size: "int (default 4KB)"
  
  "ReadFrame()": "([]byte, error)"
  "NewFrameReader(r io.Reader)": "*FrameReader"
}

FrameWriter: {
  class: data_structure
  label: "FrameWriter"
  writer: "io.Writer"
  
  "WriteFrame(payload []byte)": "error"
  "NewFrameWriter(w io.Writer)": "*FrameWriter"
}

CommandParser: {
  class: data_structure
  label: "CommandParser"
  internal_buffer: "[]byte"
  
  "Parse(data []byte)": "(*Command, error)"
  "parsePublish(d []byte)": "*Command"
  "parseSubscribe(d []byte)": "*Command"
}

CommandEncoder: {
  class: data_structure
  label: "CommandEncoder"
  
  "Encode(cmd *Command)": "([]byte, error)"
}

# -----------------------------------------------------------------------------------------
# DATA DOMAIN
# -----------------------------------------------------------------------------------------
CommandObj: {
  class: data_structure
  label: "Command Object"
  Type: "CommandType"
  Topic: "string"
  Payload: "[]byte"
  MsgID: "uint64"
}

CommandTypes: {
  class: protocol_component
  label: "OpCode Mapping\n0x01: PUBLISH\n0x02: PUB_ACK\n0x03: SUB\n0x04: SUB_ACK\n0x05: UNSUB\n0x10: ERROR"
  style.font: mono
}

# -----------------------------------------------------------------------------------------
# AUXILIARY & CONSTANTS
# -----------------------------------------------------------------------------------------
ProtocolLimits: {
  class: protocol_component
  label: "Protocol Limits\n- MaxFrame: 10MB\n- MaxTopic: 256B\n- ReadTimeout: 30s"
  style.fill: "#F1F8E9"
}

ErrorRegistry: {
  class: protocol_component
  label: "Error States\n- ErrCorruptFrame\n- ErrBufferOverflow\n- ErrInvalidOpCode"
  style.fill: "#FFEBEE"
}

# -----------------------------------------------------------------------------------------
# COMPONENT CONNECTIONS
# -----------------------------------------------------------------------------------------

# Read Path
TcpInterface -> FrameReader: "Stream In (RX)" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}

FrameReader -> FrameFormat: "Extract Length" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}

FrameFormat -> CommandParser: "Forward Payload" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}

CommandParser -> CommandObj: "Finalize Struct" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}

# Write Path
CommandObj -> CommandEncoder: "Serialize (TX)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}

CommandEncoder -> FrameWriter: "Wrap in Frame" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}

FrameWriter -> TcpInterface: "Flush to Socket" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}

# Error Path
FrameReader -> ErrorRegistry: "ErrCorruptFrame" {
  style: {
    stroke: "#C62828"
    stroke-dash: 3
    stroke-width: 2
  }
}

CommandParser -> ErrorRegistry: "ErrInvalidOpCode" {
  style: {
    stroke: "#C62828"
    stroke-dash: 3
    stroke-width: 2
  }
}

# References/Ownership
CommandObj -> CommandTypes: "Assign OpCode" { 
  style.stroke-dash: 4 
}
ProtocolLimits -> FrameReader: "Enforce Size" { 
  style.stroke-dash: 4 
}
ProtocolLimits -> CommandParser: "Check Limits" { 
  style.stroke-dash: 4 
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
Legend: {
  near: bottom-right
  label: |md
    ### Architectural Legend
    - **Blue (Animated)**: Inbound Byte Stream
    - **Purple (Solid)**: Outbound Response
    - **Red (Dashed)**: Terminal Error Flow
    - **Memory Header**: Fixed Overhead (4B)
    - **Data Blocks**: Variable Payload (NB)
  |
  style: {
    fill: "#FAFAFA"
    stroke: "#E0E0E0"
    border-radius: 8
  }
}