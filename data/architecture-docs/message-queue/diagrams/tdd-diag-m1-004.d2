vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Memory Layout: Length-Prefixed Frame
  ## Wire Protocol Binary Structure
|
title.near: top-center

direction: right

# Structural Grid for Memory Mapping
memory_map: {
  # Offset Column
  offsets: {
    style.stroke-width: 0
    style.fill: transparent
    
    o00: "0x00" { style.font: mono; style.font-color: "#8b9dc3" }
    o04: "0x04" { style.font: mono; style.font-color: "#8b9dc3" }
    o64: "0x40" { style.font: mono; style.font-color: "#8b9dc3" }
    oN: "0x04+N" { style.font: mono; style.font-color: "#8b9dc3" }
    
    o00 -> o04 -> o64 -> oN: {style.stroke-width: 0}
  }

  # The Actual Data Frame
  frame: {
    style: {
      fill: "#1a1a2e"
      stroke: "#4a4a6a"
      stroke-width: 2
      double-border: true
    }

    header: Header (Fixed 4 Bytes) {
      style: {
        fill: "#6b4c9a"
        stroke: "#8b6cba"
        font-color: "#ffffff"
      }
      
      length_prefix: {
        grid-columns: 4
        grid-gap: 0
        style.stroke-width: 0
        
        b0: "Byte 0\n[MSB]" { style.fill: "#9d7cc6"; style.font-size: 10 }
        b1: "Byte 1" { style.fill: "#9d7cc6"; style.font-size: 10 }
        b2: "Byte 2" { style.fill: "#9d7cc6"; style.font-size: 10 }
        b3: "Byte 3\n[LSB]" { style.fill: "#9d7cc6"; style.font-size: 10 }
      }
      
      annotation: "uint32_t (Big-Endian)\nValue = N" {
        shape: text
        style.font-color: "#c4b5e0"
        style.font-size: 12
      }
    }

    payload: Frame Payload (N Bytes) {
      style: {
        fill: "#2d5a7b"
        stroke: "#4d7a9b"
        font-color: "#ffffff"
      }
      
      message_data: "Variable Message Data Content" {
        style: {
          fill: "#3d6a8b"
          stroke: "#5d8aab"
          font-color: "#a0c4e0"
          font-size: 16
          bold: true
        }
        width: 400
        height: 120
      }

      cache_marker: "" {
        shape: text
        label: "--- 64B Cache Line Boundary ---"
        style.font-color: "#ff7b72"
        style.stroke-dash: 5
        style.font-size: 11
      }
    }

    # Internal layout flow
    header -> payload: "0x04 Offset" {
      style.stroke: "#8b6cba"
      style.stroke-width: 2
    }
  }

  # Size/Constraint Column
  constraints: {
    style.stroke-width: 0
    style.fill: transparent
    
    s4: "4 Bytes" { style.font-color: "#8b9dc3" }
    sn: "N Bytes" { style.font-color: "#8b9dc3" }
    
    s4 -> sn: {style.stroke-width: 0}
  }
}

# Cross-linking annotations
memory_map.offsets.o00 -> memory_map.frame.header: { style.stroke-dash: 3; style.stroke: "#4a4a6a" }
memory_map.offsets.o04 -> memory_map.frame.payload: { style.stroke-dash: 3; style.stroke: "#4a4a6a" }
memory_map.frame.header -> memory_map.constraints.s4: { style.stroke-dash: 3; style.stroke: "#4a4a6a" }
memory_map.frame.payload -> memory_map.constraints.sn: { style.stroke-dash: 3; style.stroke: "#4a4a6a" }

# Legend
legend: {
  near: bottom-left
  style: {
    fill: "#0d1117"
    stroke: "#30363d"
    border-radius: 8
  }
  
  l_title: "Memory Legend" { style.bold: true; style.font-color: "#ffffff" }
  
  purple: "Header / Meta" {
    style.fill: "#6b4c9a"
    style.font-color: "#ffffff"
  }
  blue: "Application Data" {
    style.fill: "#2d5a7b"
    style.font-color: "#ffffff"
  }
  boundary: "Cache/Page Boundary" {
    style.stroke: "#ff7b72"
    style.stroke-dash: 5
  }
}

# Fix for the reported block string error: using |'md ... '|
spec_table: |'md
### Binary Layout Specification
| Offset | Size | Field | Type | Description |
|:-------|:-----|:------|:-----|:------------|
| 0x00 | 4 | Length Prefix | uint32_t (BE) | Total payload size in bytes. |
| 0x04 | N | Frame Payload | raw bytes | Content opaque to protocol layer. |

**Constraint Invariants**:
1. `N >= 1` (Minimum frame size is 5 bytes).
2. `N <= 10MB` (Protocol enforcement limit).
3. All integers are **Network Byte Order** (Big-Endian).
'|
spec_table.near: bottom-center
spec_table.style: {
  fill: "#161b22"
  stroke: "#30363d"
  font-color: "#c9d1d9"
}

# Example Binary Data Block
example_frame: {
  near: top-right
  style: {
    fill: "#0d1117"
    stroke: "#30363d"
    border-radius: 8
  }
  
  label: "Example Binary (hex)"
  
  binary_dump: |'md
text
00 00 00 0E  // Len: 14 (Header)
01           // Cmd: PUB (Payload Start)
00 06        // TopicLen: 6
6F 72 64 65  // "orde"
72 73        // "rs"
00 05        // DataLen: 5
68 65 6C 6C  // "hell"
6F           // "o"

'|
}
example_frame.binary_dump.style.font-size: 10

# Total Metadata
total_size: "Total Structure Size: 4 + N Bytes" {
  near: bottom-right
  shape: cloud
  style: {
    fill: "#1a1a2e"
    font-color: "#ffffff"
    stroke: "#8b6cba"
  }
}