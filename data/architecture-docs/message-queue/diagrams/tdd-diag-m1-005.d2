vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Memory Layout: PUBLISH Command Payload
  **Total Size: 5 + TopicLen + PayloadLen bytes**
|
PUBLISH_Payload: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }
  grid-columns: 5
  grid-gap: 0
  header_row: {
    grid-columns: 5
    grid-gap: 0
    style.fill: "#2d2d44"
    byte_0_label: |md
      **Byte 0**
    | {style.fill: "#3d3d5c"; style.font-color: "#e0e0e0"}
    byte_1_label: |md
      **Byte 1**
    | {style.fill: "#3d3d5c"; style.font-color: "#e0e0e0"}
    byte_2_label: |md
      **Byte 2**
    | {style.fill: "#3d3d5c"; style.font-color: "#e0e0e0"}
    byte_3_label: |md
      **Byte 3+**
    | {style.fill: "#3d3d5c"; style.font-color: "#e0e0e0"}
    variable_label: |md
      **Variable**
    | {style.fill: "#3d3d5c"; style.font-color: "#e0e0e0"}
  }
  cmd_type: {
    shape: rectangle
    label: |md
      **0x01**
      _Command_
      _Type_
    |
    style: {
      fill: "#7c3aed"
      font-color: white
      stroke: "#9d5cf5"
      stroke-width: 2
    }
    width: 100
  }
  topic_len_hi: {
    shape: rectangle
    label: |md
      **TopicLen**
      _(MSB)_
    |
    style: {
      fill: "#2563eb"
      font-color: white
      stroke: "#4a8af7"
      stroke-width: 2
    }
    width: 100
  }
  topic_len_lo: {
    shape: rectangle
    label: |md
      **TopicLen**
      _(LSB)_
    |
    style: {
      fill: "#2563eb"
      font-color: white
      stroke: "#4a8af7"
      stroke-width: 2
    }
    width: 100
  }
  topic_bytes: {
    shape: rectangle
    label: |md
      **Topic**
      _UTF-8 String_
      _(TopicLen bytes)_
    |
    style: {
      fill: "#0891b2"
      font-color: white
      stroke: "#22b8cf"
      stroke-width: 2
    }
    width: 120
  }
  payload_section: {
    shape: rectangle
    label: |md
      **Payload**
      _Len (2B) + Data_
      _(Variable)_
    |
    style: {
      fill: "#059669"
      font-color: white
      stroke: "#10b981"
      stroke-width: 2
    }
    width: 140
  }
}
legend: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
  }
  legend_title: |md
    ### Field Specifications
  | {style.font-color: "#e0e0e0"}
  cmd_spec: {
    shape: rectangle
    label: |md
      **Command Type (1 byte)**
      - Offset: `0x00`
      - Size: 1 byte
      - Value: `0x01` (PUBLISH)
      - Endianness: N/A
    |
    style: {
      fill: "#7c3aed"
      font-color: white
    }
  }
  topiclen_spec: {
    shape: rectangle
    label: |md
      **Topic Length (2 bytes)**
      - Offset: `0x01` - `0x02`
      - Size: 2 bytes
      - Type: `uint16` (big-endian)
      - Range: 0 - 65535
    |
    style: {
      fill: "#2563eb"
      font-color: white
    }
  }
  topic_spec: {
    shape: rectangle
    label: |md
      **Topic Name (variable)**
      - Offset: `0x03`
      - Size: TopicLen bytes
      - Encoding: UTF-8
      - Max: 256 bytes
    |
    style: {
      fill: "#0891b2"
      font-color: white
    }
  }
  payload_spec: {
    shape: rectangle
    label: |md
      **Payload (variable)**
      - Offset: `0x03 + TopicLen`
      - Size: 2 + PayloadLen bytes
      - Format: `uint16` len + bytes
      - Max: 1,048,576 bytes
    |
    style: {
      fill: "#059669"
      font-color: white
    }
  }
  cmd_spec -- topiclen_spec
  topiclen_spec -- topic_spec
  topic_spec -- payload_spec
}
example: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
  }
  example_title: |md
    ### Example: PUBLISH "hello" to topic "orders"
  | {style.font-color: "#e0e0e0"}
  grid-columns: 1
  byte_stream: {
    shape: rectangle
    style: {
      fill: "#0d0d1a"
      font: mono
      font-color: "#22d3ee"
      stroke: "#22d3ee"
      stroke-width: 1
    }
    label: |md
      
      Offset  00 01 02 03 04 05 06 07 08 09 0A 0B 0C 0D 0E
              ┌──┬──┬──┬──┬──┬──┬──┬──┬──┬──┬──┬──┬──┬──┬──┐
              │01│00│06│6F│72│64│65│72│73│00│05│68│65│6C│6C│
              └──┴──┴──┴──┴──┴──┴──┴──┴──┴──┴──┴──┴──┴──┴──┘
              │  │  │  └────────────────┘  │  └────────────┘
              │  │  │       Topic          │    Payload
              │  │  │    "orders" (6)      │   "hello" (5)
              │  │  │                      │
              │  │  └─ TopicLen: 0x0006    └─ PayloadLen: 0x0005
              │  │
              │  └─ TopicLen MSB
              │
              └─ Cmd: PUBLISH (0x01)
      
    |
  }
  breakdown: {
    shape: rectangle
    style: {
      fill: "#1e1e3f"
      font-color: "#a0a0c0"
    }
    label: |md
      **Byte Breakdown:**
      - `0x01` — Command type (PUBLISH)
      - `0x00 0x06` — Topic length = 6 (big-endian)
      - `0x6F 0x72 0x64 0x65 0x72 0x73` — "orders" (UTF-8)
      - `0x00 0x05` — Payload length = 5 (big-endian)
      - `0x68 0x65 0x6C 0x6C 0x6F` — "hello" (UTF-8)
      **Total payload size: 15 bytes**
    |
  }
}
notes: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
  }
  note_title: |md
    ### Wire Format Notes
  | {style.font-color: "#e0e0e0"}
  note_content: {
    shape: rectangle
    style: {
      fill: "#2d2d44"
      font-color: "#c0c0e0"
    }
    label: |md
      - All multi-byte integers use **big-endian** (network byte order)
      - The 4-byte **frame length prefix** (not shown) wraps this payload
      - Frame length = payload size (excludes the 4-byte prefix itself)
      - Maximum topic length enforced: **256 bytes**
      - Maximum payload length enforced: **1,048,576 bytes** (1 MB)
      - Total frame size must not exceed **10,485,760 bytes** (10 MB)
    |
  }
}
PUBLISH_Payload -- legend: {style.stroke: "#4a4a6a"; style.stroke-dash: 3}
legend -- example: {style.stroke: "#4a4a6a"; style.stroke-dash: 3}
example -- notes: {style.stroke: "#4a4a6a"; style.stroke-dash: 3}