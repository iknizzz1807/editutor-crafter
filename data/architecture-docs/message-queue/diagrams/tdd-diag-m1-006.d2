vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    cmd: "#8B5CF6"
    len_field: "#3B82F6"
    string_field: "#10B981"
    id_field: "#F59E0B"
  }
}
title: |md
  # Memory Layout: MESSAGE Delivery Command (0x07)
  Server → Client message delivery frame
| {near: top-center}
MESSAGE_Command: {
  style.fill: transparent
  style.stroke: transparent
  label: ""
  header_row: {
    shape: rectangle
    label: ""
    style.fill: transparent
    style.stroke: transparent
    offset_label: "Offset"
    size_label: "Size"
    field_label: "Field"
    value_label: "Value/Description"
  }
  row_cmd: {
    shape: rectangle
    label: ""
    style.fill: transparent
    style.stroke: transparent
    offset_0: "0x00" {
      style.fill: "${colors.cmd}"
      style.font-color: white
      style.bold: true
    }
    size_1: "1 byte" {
      style.fill: "${colors.cmd}"
      style.font-color: white
    }
    field_cmd: "Command Type" {
      style.fill: "${colors.cmd}"
      style.font-color: white
      style.bold: true
    }
    value_cmd: "0x07 (MESSAGE)" {
      style.fill: "${colors.cmd}"
      style.font-color: white
      style.font: mono
    }
  }
  row_topiclen: {
    shape: rectangle
    label: ""
    style.fill: transparent
    style.stroke: transparent
    offset_1: "0x01" {
      style.fill: "${colors.len_field}"
      style.font-color: white
      style.bold: true
    }
    size_2: "2 bytes" {
      style.fill: "${colors.len_field}"
      style.font-color: white
    }
    field_topiclen: "Topic Length" {
      style.fill: "${colors.len_field}"
      style.font-color: white
      style.bold: true
    }
    value_topiclen: "uint16 BE (max 256)" {
      style.fill: "${colors.len_field}"
      style.font-color: white
      style.font: mono
    }
  }
  row_topic: {
    shape: rectangle
    label: ""
    style.fill: transparent
    style.stroke: transparent
    offset_3: "0x03" {
      style.fill: "${colors.string_field}"
      style.font-color: white
      style.bold: true
    }
    size_topic: "N bytes" {
      style.fill: "${colors.string_field}"
      style.font-color: white
    }
    field_topic: "Topic Name" {
      style.fill: "${colors.string_field}"
      style.font-color: white
      style.bold: true
    }
    value_topic: "UTF-8 encoded string" {
      style.fill: "${colors.string_field}"
      style.font-color: white
      style.font: mono
    }
  }
  row_payloadlen: {
    shape: rectangle
    label: ""
    style.fill: transparent
    style.stroke: transparent
    offset_plen: "0x03+N" {
      style.fill: "${colors.len_field}"
      style.font-color: white
      style.bold: true
    }
    size_plen: "2 bytes" {
      style.fill: "${colors.len_field}"
      style.font-color: white
    }
    field_payloadlen: "Payload Length" {
      style.fill: "${colors.len_field}"
      style.font-color: white
      style.bold: true
    }
    value_payloadlen: "uint16 BE (max 1MB)" {
      style.fill: "${colors.len_field}"
      style.font-color: white
      style.font: mono
    }
  }
  row_payload: {
    shape: rectangle
    label: ""
    style.fill: transparent
    style.stroke: transparent
    offset_payload: "0x05+N" {
      style.fill: "${colors.string_field}"
      style.font-color: white
      style.bold: true
    }
    size_payload: "M bytes" {
      style.fill: "${colors.string_field}"
      style.font-color: white
    }
    field_payload: "Message Payload" {
      style.fill: "${colors.string_field}"
      style.font-color: white
      style.bold: true
    }
    value_payload: "Raw message bytes" {
      style.fill: "${colors.string_field}"
      style.font-color: white
      style.font: mono
    }
  }
  row_msgid: {
    shape: rectangle
    label: ""
    style.fill: transparent
    style.stroke: transparent
    offset_msgid: "0x05+N+M" {
      style.fill: "${colors.id_field}"
      style.font-color: white
      style.bold: true
    }
    size_msgid: "8 bytes" {
      style.fill: "${colors.id_field}"
      style.font-color: white
    }
    field_msgid: "Message ID" {
      style.fill: "${colors.id_field}"
      style.font-color: white
      style.bold: true
    }
    value_msgid: "uint64 BE (server-assigned)" {
      style.fill: "${colors.id_field}"
      style.font-color: white
      style.font: mono
    }
  }
}
legend: {
  near: bottom-center
  style.fill: "#1E293B"
  style.stroke: "#475569"
  style.border-radius: 8
  style.font-color: white
  title: "Legend"
  cmd_legend: "■ Command Type (1 byte)" {
    style.fill: "${colors.cmd}"
    style.font-color: white
    shape: text
  }
  len_legend: "■ Length Fields (2 bytes each)" {
    style.fill: "${colors.len_field}"
    style.font-color: white
    shape: text
  }
  string_legend: "■ Variable Data (N/M bytes)" {
    style.fill: "${colors.string_field}"
    style.font-color: white
    shape: text
  }
  id_legend: "■ Message ID (8 bytes)" {
    style.fill: "${colors.id_field}"
    style.font-color: white
    shape: text
  }
}
total_size: |md
  **Total Size:** `13 + N + M` bytes minimum  
  (1 + 2 + N + 2 + M + 8)
| {near: bottom-right}
endianness: |md
  **Byte Order:** Big-Endian (network byte order)  
  All multi-byte integers transmitted MSB first
| {near: bottom-left}
example: {
  near: top-right
  style.fill: "#0F172A"
  style.stroke: "#334155"
  style.border-radius: 8
  title: "Example: MESSAGE for topic 'orders'"
  bytes: |md
    
    Offset  Bytes                    Field
    ──────────────────────────────────────────
    0x00    07                       Command = MESSAGE
    0x01    00 06                    TopicLen = 6
    0x03    6F 72 64 65 72 73        "orders" (UTF-8)
    0x09    00 05                    PayloadLen = 5
    0x0B    68 65 6C 6C 6F           "hello"
    0x10    00 00 00 00 00 00 00 2A  MsgID = 42
    
  |
}
direction: right