vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Data Flow: Client Connect to Subscribe
  TCP Connection → Registration → SUBSCRIBE Command Flow
| {near: top-center}
# Actors
Client: {
  label: "Client\n(net.Conn)"
  shape: person
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
}
Server: {
  label: "Server\n(*broker.Server)"
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}
ConnMgr: {
  label: "ConnectionManager\n(*ConnectionManager)"
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
TopicRouter: {
  label: "TopicRouter\n(*TopicRouter)"
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}
# Sequence flow
Client -> Server: "1. TCP Accept\nnet.Conn" {
  style.stroke: "#2E86AB"
  style.stroke-width: 3
}
Server -> Server: "2. NewClient(conn)\n*Client" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
}
Server -> ConnMgr: "3. Register(client)\nclient.ID: string" {
  style.stroke: "#2E7D32"
}
ConnMgr -> ConnMgr: "connections[ID] = client\nmap[string]*Client" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
Server -> Client: "4. Read Loop\nFrameReader.ReadFrame()" {
  style.stroke: "#2E86AB"
}
Client -> Server: "5. SUBSCRIBE Command\n{Type: 0x03, Topic: string}" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
}
Server -> Server: "6. ParseCommand(frame)\n*protocol.Command" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
}
Server -> TopicRouter: "7. Subscribe(topic, client)\ntopic: string, client: *Client" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
TopicRouter -> TopicRouter: "8. Add to subscribers\nsubscribers[client.ID] = state\nmap[string]*subscriberState" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}
TopicRouter -> TopicRouter: "9. Spawn deliveryLoop\ngo deliveryLoop(subState)" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}
Server -> Client: "10. SUBSCRIBE_ACK\n{Type: 0x04, Topic: string}" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
}
# Annotations
Annotation: |md
  ## Wire Protocol Types
  **Frame**: `[]byte` (length-prefixed)
  - 4 bytes: Length (uint32 BE)
  - N bytes: Payload
  **SUBSCRIBE (0x03)**:
  - 1 byte: Command type
  - 2 bytes: TopicLen (uint16 BE)
  - N bytes: Topic (UTF-8)
  **SUBSCRIBE_ACK (0x04)**:
  - 1 byte: Command type
  - 2 bytes: TopicLen (uint16 BE)
  - N bytes: Topic (UTF-8)
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
}