vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
Connection Lifecycle State Machine: {
  style.fill: transparent
  # Initial state
  init: {
    shape: circle
    style.fill: "#4A5568"
    width: 20
    height: 20
    label: ""
  }
  # Main states
  IDLE: {
    style.fill: "#E2E8F0"
    style.stroke: "#4A5568"
    label: |md
      **IDLE**
      ---
      *No connection*
      *Resources: None*
    |
  }
  CONNECTING: {
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
    label: |md
      **CONNECTING**
      ---
      *TCP handshake in progress*
      *Resources: Socket FD*
      *Timeout: 10s*
    |
  }
  CONNECTED: {
    style.fill: "#DBEAFE"
    style.stroke: "#2563EB"
    label: |md
      **CONNECTED**
      ---
      *TCP established*
      *Resources: Socket, Read buffer*
      *ClientID assigned*
    |
  }
  AUTHENTICATING: {
    style.fill: "#F3E8FF"
    style.stroke: "#9333EA"
    style.stroke-dash: 3
    label: |md
      **AUTHENTICATING**
      ---
      *(Future M5)*
      *Credentials validation*
      *Resources: Auth context*
    |
  }
  ACTIVE: {
    style.fill: "#D1FAE5"
    style.stroke: "#059669"
    label: |md
      **ACTIVE**
      ---
      *Fully operational*
      *Resources: Full client state*
      *Subscriptions active*
      *Heartbeat: 30s interval*
    |
  }
  CLOSING: {
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    label: |md
      **CLOSING**
      ---
      *Cleanup in progress*
      *Unsubscribing topics*
      *Flushing buffers*
    |
  }
  CLOSED: {
    style.fill: "#1F2937"
    style.stroke: "#374151"
    style.font-color: white
    label: |md
      **CLOSED**
      ---
      *Connection terminated*
      *All resources freed*
      *Final state*
    |
  }
  # Error state
  ERROR: {
    shape: diamond
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    style.stroke-width: 3
    label: |md
      **ERROR**
      ---
      *Fatal error*
    |
  }
  # Transitions
  init -> IDLE: "startup" {
    style.stroke: "#4A5568"
  }
  IDLE -> CONNECTING: "TCP Connect()" {
    label.near: top-center
  }
  CONNECTING -> CONNECTED: "SYN/ACK complete" {
    style.stroke: "#059669"
    style.bold: true
  }
  CONNECTING -> ERROR: "Connection refused\nTimeout (10s)\nNetwork unreachable" {
    style.stroke: "#DC2626"
    style.stroke-dash: 3
  }
  CONNECTED -> AUTHENTICATING: "(Future: AUTH cmd)" {
    style.stroke: "#9333EA"
    style.stroke-dash: 3
    style.animated: true
  }
  CONNECTED -> ACTIVE: "ClientID assigned\nReady for commands" {
    style.stroke: "#059669"
    style.bold: true
  }
  AUTHENTICATING -> ACTIVE: "Auth success" {
    style.stroke: "#059669"
  }
  AUTHENTICATING -> ERROR: "Auth failed" {
    style.stroke: "#DC2626"
  }
  ACTIVE -> ACTIVE: "HEARTBEAT_ACK\n(30s interval)" {
    style.stroke: "#059669"
    label: |md
      Reset
      LastActivity
    |
  }
  ACTIVE -> CLOSING: "Client Close()\nServer shutdown" {
    style.stroke: "#D97706"
  }
  ACTIVE -> ERROR: "Heartbeat timeout (60s)\nRead error\nWrite error" {
    style.stroke: "#DC2626"
    style.stroke-dash: 3
  }
  CLOSING -> CLOSED: "Cleanup complete\nSocket closed" {
    style.stroke: "#4A5568"
    style.bold: true
  }
  ERROR -> CLOSING: "Initiate cleanup" {
    style.stroke: "#DC2626"
  }
  # ILLEGAL transitions
  CLOSED -> CONNECTED: "ILLEGAL: Must create new connection" {
    style.stroke: "#DC2626"
    style.stroke-dash: 5
    style.stroke-width: 3
    style.font-color: "#DC2626"
    style.bold: true
  }
  CLOSED -> ACTIVE: "ILLEGAL: Cannot revive closed connection" {
    style.stroke: "#DC2626"
    style.stroke-dash: 5
    style.stroke-width: 3
    style.font-color: "#DC2626"
    style.bold: true
  }
  CLOSING -> ACTIVE: "ILLEGAL: Cleanup is terminal" {
    style.stroke: "#DC2626"
    style.stroke-dash: 5
    style.stroke-width: 3
    style.font-color: "#DC2626"
    style.bold: true
  }
}
Legend: {
  near: bottom-right
  style.fill: transparent
  valid_transition: "────▶ Valid transition" {
    shape: text
    style.fill: transparent
  }
  error_transition: "- - - ▶ Error path" {
    shape: text
    style.fill: transparent
    style.stroke: "#DC2626"
  }
  illegal_transition: "═══▶ ILLEGAL" {
    shape: text
    style.fill: transparent
    style.stroke: "#DC2626"
    style.bold: true
  }
  future_feature: "(Future M5)" {
    shape: text
    style.fill: transparent
    style.stroke: "#9333EA"
    style.italic: true
  }
}