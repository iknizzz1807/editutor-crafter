vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
  colors: {
    active: "#4CAF50"
    transitioning: "#2196F3"
    inactive: "#9E9E9E"
    error: "#F44336"
  }
}
title: |md
  # Topic Subscription State Machine
  Client Subscription Lifecycle
| {near: top-center}
direction: right
# Define states
UNSUBSCRIBED: {
  style.fill: "${colors.inactive}"
  style.stroke: "#616161"
  label: |md
    **UNSUBSCRIBED**
    ---
    *Initial State*
    Invariants:
    - Not receiving messages
    - No topic entry in router
  |
}
SUBSCRIBING: {
  style.fill: "${colors.transitioning}"
  style.stroke: "#1565C0"
  style.stroke-dash: 3
  label: |md
    **SUBSCRIBING**
    ---
    *Transient State*
    Invariants:
    - SUBSCRIBE sent
    - Awaiting SUBSCRIBE_ACK
    - Timeout pending
  |
}
SUBSCRIBED: {
  style.fill: "${colors.active}"
  style.stroke: "#2E7D32"
  label: |md
    **SUBSCRIBED**
    ---
    *Active State*
    Invariants:
    - Receiving messages (fan-out)
    - Entry in TopicRouter
    - Delivery goroutine active
    - Buffered channel open
  |
}
UNSUBSCRIBING: {
  style.fill: "${colors.transitioning}"
  style.stroke: "#1565C0"
  style.stroke-dash: 3
  label: |md
    **UNSUBSCRIBING**
    ---
    *Transient State*
    Invariants:
    - UNSUBSCRIBE sent
    - Awaiting UNSUBSCRIBE_ACK
    - Delivery stopping
  |
}
ERROR: {
  style.fill: "${colors.error}"
  style.stroke: "#C62828"
  label: |md
    **ERROR**
    ---
    *Terminal State*
    Recovery:
    - Log error
    - Close connection
    - Trigger cleanup
  |
}
# Transitions
UNSUBSCRIBED -> SUBSCRIBING: |md
  **SUBSCRIBE cmd**
  Trigger: Client sends
  0x03 command
  Guard: topic != ""
  Action:
  - Add to pending subs
  - Send to server
| {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
SUBSCRIBING -> SUBSCRIBED: |md
  **SUBSCRIBE_ACK**
  Trigger: Server responds
  0x04 command
  Guard: None
  Action:
  - Add to TopicRouter
  - Spawn delivery loop
  - Update client state
| {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
SUBSCRIBING -> ERROR: |md
  **Timeout / Error**
  Trigger: No ACK within
  timeout period
  Guard: None
  Action:
  - Remove pending sub
  - Send ERROR to client
| {
  style.stroke: "${colors.error}"
  style.stroke-width: 2
  style.stroke-dash: 5
}
SUBSCRIBED -> UNSUBSCRIBING: |md
  **UNSUBSCRIBE cmd**
  Trigger: Client sends
  0x05 command
  Guard: Is subscribed
  Action:
  - Mark for removal
  - Send to server
| {
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
UNSUBSCRIBING -> UNSUBSCRIBED: |md
  **UNSUBSCRIBE_ACK**
  Trigger: Server responds
  0x06 command
  Guard: None
  Action:
  - Remove from TopicRouter
  - Close delivery channel
  - Clear client state
| {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
# Connection close - direct to UNSUBSCRIBED
SUBSCRIBED -> UNSUBSCRIBED: |md
  **Connection Close**
  Trigger: TCP FIN/RST
  or heartbeat timeout
  Guard: None
  Action:
  - Atomic cleanup
  - Remove all subs
  - Stop delivery loops
| {
  style.stroke: "#FF5722"
  style.stroke-width: 2
  style.stroke-dash: 5
}
SUBSCRIBING -> UNSUBSCRIBED: |md
  **Connection Close**
  Trigger: TCP close
  during pending sub
  Guard: None
  Action:
  - Cleanup pending
| {
  style.stroke: "#FF5722"
  style.stroke-width: 2
  style.stroke-dash: 5
}
UNSUBSCRIBING -> UNSUBSCRIBED: |md
  **Connection Close**
  Trigger: TCP close
  during pending unsub
  Guard: None
  Action:
  - Force cleanup
| {
  style.stroke: "#FF5722"
  style.stroke-width: 2
  style.stroke-dash: 5
}
# Initial state marker
initial: ● {
  style.fill: "#4CAF50"
  shape: circle
}
initial -> UNSUBSCRIBED
# Legend
legend: {
  near: bottom-right
  label: |md
    **Legend**
    ● Initial State
    ──▶ Normal Transition
    - - -▶▶ Error/Force Transition
    State Colors:
    🟢 Active (SUBSCRIBED)
    🔵 Transitioning
    ⚫ Inactive (UNSUBSCRIBED)
    🔴 Error
  |
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
}
# Illegal transitions note
illegal: {
  near: bottom-left
  label: |md
    **ILLEGAL Transitions**
    - SUBSCRIBED → SUBSCRIBING
      (already subscribed)
    - UNSUBSCRIBED → UNSUBSCRIBING
      (nothing to unsubscribe)
    - SUBSCRIBING → UNSUBSCRIBING
      (must complete or timeout first)
    - ERROR → any state
      (connection terminated)
  |
  style.fill: "#FFEBEE"
  style.stroke: "${colors.error}"
  style.stroke-dash: 3
}