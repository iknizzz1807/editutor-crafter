vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Sequence: Full Pub/Sub Flow with Multiple Subscribers
  Complete message flow from producer to parallel subscriber delivery
| {near: top-center}

# Legend for technical clarity
legend: {
  near: bottom-right
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  legend_title: "Legend" {
    style.bold: true
    style.font-size: 14
  }
  sync_msg: "──▶ Synchronous Message" {
    shape: text
    style.font-size: 11
  }
  async_msg: "- -▶ Asynchronous/Non-blocking" {
    shape: text
    style.font-size: 11
  }
  lock_symbol: "🔒 Lock acquired" {
    shape: text
    style.font-size: 11
  }
  unlock_symbol: "🔓 Lock released" {
    shape: text
    style.font-size: 11
  }
  goroutine_symbol: "🚀 New goroutine spawned" {
    shape: text
    style.font-size: 11
  }
}

# Main Participants - Defined outside for detailed styling
Producer: {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
  style.stroke-width: 2
}

Broker: {
  style.fill: "#fff3e0"
  style.stroke: "#f57c00"
  style.stroke-width: 2
  
  ConnectionHandler: {
    shape: rectangle
    style.fill: "#ffe0b2"
    label: "Connection\nHandler\n(Goroutine)"
  }
  TopicRouter: {
    shape: rectangle
    style.fill: "#ffcc80"
    label: "TopicRouter\n(Fan-out)"
  }
  DeliveryQueue1: {
    shape: queue
    style.fill: "#c8e6c9"
    label: "Delivery\nQueue\n(Sub1)"
  }
  DeliveryQueue2: {
    shape: queue
    style.fill: "#c8e6c9"
    label: "Delivery\nQueue\n(Sub2)"
  }
  DeliveryQueue3: {
    shape: queue
    style.fill: "#c8e6c9"
    label: "Delivery\nQueue\n(Sub3)"
  }
}

Subscriber1: {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.stroke-width: 2
  label: "Subscriber 1\n(Consumer)"
}

Subscriber2: {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.stroke-width: 2
  label: "Subscriber 2\n(Consumer)"
}

Subscriber3: {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  style.stroke-width: 2
  label: "Subscriber 3\n(Consumer)"
}

HeartbeatMonitor: {
  shape: diamond
  style.fill: "#fce4ec"
  style.stroke: "#c2185b"
  label: "Heartbeat\nMonitor\n(Background)"
}

# Sequence Flow Implementation
sequence: {
  shape: sequence_diagram
  
  # Define order of life-lines
  Producer; Broker.ConnectionHandler; Broker.TopicRouter; Broker.DeliveryQueue1; Broker.DeliveryQueue2; Broker.DeliveryQueue3; Subscriber1; Subscriber2; Subscriber3; HeartbeatMonitor

  # Step 1: Producer sends PUBLISH
  step1_init: {
    Producer -> Broker.ConnectionHandler: "PUBLISH {topic: 'orders', payload: 'msg-123'}" {
      style.stroke: "#1976d2"
      style.stroke-width: 2
    }
  }

  # Step 2: Frame parsing and concurrency control
  step2_parse: {
    Broker.ConnectionHandler: "🔒 writeMu.Lock()"
    Broker.ConnectionHandler -> Broker.ConnectionHandler: "FrameReader.ReadFrame()" {
      style.stroke: "#f57c00"
      style.stroke-dash: 3
    }
    Broker.ConnectionHandler: "🔓 writeMu.Unlock()"
  }

  # Step 3: Global Routing Logic
  step3_route: {
    Broker.ConnectionHandler -> Broker.TopicRouter: "Publish(topic, payload, msgID)" {
      style.stroke: "#f57c00"
      style.stroke-width: 2
    }
    Broker.TopicRouter: "🔒 topicsMu.RLock()"
    Broker.TopicRouter -> Broker.TopicRouter: "Get subscriber snapshot" {
      style.stroke: "#f57c00"
      style.stroke-dash: 3
    }
    Broker.TopicRouter: "🔓 topicsMu.RUnlock()"
  }

  # Step 4: Fan-out to independent delivery channels
  step4_fanout: {
    Broker.TopicRouter -> Broker.DeliveryQueue1: "deliver <- MESSAGE (non-blocking)" {
      style.stroke: "#388e3c"
      style.stroke-dash: 5
      style.animated: true
    }
    Broker.TopicRouter -> Broker.DeliveryQueue2: "deliver <- MESSAGE (non-blocking)" {
      style.stroke: "#388e3c"
      style.stroke-dash: 5
      style.animated: true
    }
    Broker.TopicRouter -> Broker.DeliveryQueue3: "deliver <- MESSAGE (non-blocking)" {
      style.stroke: "#388e3c"
      style.stroke-dash: 5
      style.animated: true
    }
  }

  # Step 5: Subscriber delivery phase
  step5_delivery: {
    Broker.DeliveryQueue1: "🚀 delivery goroutine"
    Broker.DeliveryQueue2: "🚀 delivery goroutine"
    Broker.DeliveryQueue3: "🚀 delivery goroutine"
    
    Broker.DeliveryQueue1 -> Subscriber1: "MESSAGE {topic, payload, msgID=1}" {
      style.stroke: "#388e3c"
      style.stroke-width: 2
    }
    Broker.DeliveryQueue2 -> Subscriber2: "MESSAGE {topic, payload, msgID=1}" {
      style.stroke: "#388e3c"
      style.stroke-width: 2
    }
    Broker.DeliveryQueue3 -> Subscriber3: "MESSAGE {topic, payload, msgID=1}" {
      style.stroke: "#388e3c"
      style.stroke-width: 2
    }
  }

  # Step 6: Confirmation loop
  step6_ack: {
    Broker.TopicRouter -> Broker.ConnectionHandler: "Return subscriberCount" {
      style.stroke: "#f57c00"
    }
    Broker.ConnectionHandler: "🔒 writeMu.Lock()"
    Broker.ConnectionHandler -> Producer: "PUBLISH_ACK {msgID: 1}" {
      style.stroke: "#1976d2"
      style.stroke-width: 2
    }
    Broker.ConnectionHandler: "🔓 writeMu.Unlock()"
  }

  # Background tasks: System health
  heartbeat_bg: {
    HeartbeatMonitor -> HeartbeatMonitor: "Check every 30s" {
      style.stroke: "#c2185b"
      style.stroke-dash: 3
    }
    HeartbeatMonitor -> Broker.ConnectionHandler: "Send HEARTBEAT" {
      style.stroke: "#c2185b"
      style.stroke-dash: 5
    }
    Broker.ConnectionHandler -> HeartbeatMonitor: "HEARTBEAT_ACK" {
      style.stroke: "#c2185b"
      style.stroke-dash: 5
    }
  }
}

# Documentation Annotations: Timing
timing_box: {
  near: top-right
  style.fill: "#fff8e1"
  style.stroke: "#ffc107"
  timing_title: "Timing Constraints" {
    style.bold: true
  }
  t1: "PUBLISH → PUBLISH_ACK: <10ms (local)" {
    shape: text
    style.font-size: 10
  }
  t2: "Fan-out delivery: Non-blocking" {
    shape: text
    style.font-size: 10
  }
  t3: "Per-subscriber delivery: Serial within goroutine" {
    shape: text
    style.font-size: 10
  }
  t4: "Heartbeat interval: 30s" {
    shape: text
    style.font-size: 10
  }
  t5: "Heartbeat timeout: 60s (death detection)" {
    shape: text
    style.font-size: 10
  }
}

# Documentation Annotations: Deadlock Prevention
locks_box: {
  near: bottom-left
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
  locks_title: "Lock Hierarchy" {
    style.bold: true
  }
  l1: "1. Server.mu (server state)" {
    shape: text
    style.font-size: 10
  }
  l2: "2. ConnectionManager.mu (registry)" {
    shape: text
    style.font-size: 10
  }
  l3: "3. TopicRouter.topicsMu (topic map)" {
    shape: text
    style.font-size: 10
  }
  l4: "4. topicState.mu (subscriber map)" {
    shape: text
    style.font-size: 10
  }
  l5: "5. Client.writeMu (write serialize)" {
    shape: text
    style.font-size: 10
  }
}

# System Integrity Constants
invariants_box: {
  near: bottom-center
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  inv_title: "Key Invariants" {
    style.bold: true
  }
  i1: "✓ Per-topic message ordering preserved" {
    shape: text
    style.font-size: 10
  }
  i2: "✓ No subscriber blocks another (buffered channels)" {
    shape: text
    style.font-size: 10
  }
  i3: "✓ Message IDs globally unique, monotonically increasing" {
    shape: text
    style.font-size: 10
  }
  i4: "✓ Delivery buffer size: 100 messages/subscriber" {
    shape: text
    style.font-size: 10
  }
}