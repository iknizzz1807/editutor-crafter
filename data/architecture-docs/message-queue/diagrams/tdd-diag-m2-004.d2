vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Memory Layout: NACK Command
'| {near: top-center}

# Logical Layout Container
NACK_Frame: "NACK Command Frame Structure" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2

  header_note: |'md
    **Total Size:** Variable (11 + N bytes)
    **Command ID:** 0x12 (NACK)
  '|

  # Field definitions with offsets
  Offset_0: "0x00: Command Type" {
    label: |'md
      **Type ID**
      `0x12` (1 byte)
    '|
    style.fill: "#9B59B6" # Header/Purple
    style.font-color: white
    width: 200
  }

  Offset_1: "0x01: Message ID" {
    label: |'md
      **Message ID**
      uint64 (8 bytes, BE)
    '|
    style.fill: "#3498DB" # Data/Blue
    style.font-color: white
    width: 200
  }

  Offset_9: "0x09: Reason Length" {
    label: |'md
      **Reason Length**
      uint16 (2 bytes, BE)
    '|
    style.fill: "#E67E22" # Length/Orange
    style.font-color: white
    width: 200
  }

  Offset_B: "0x0B: Reason String" {
    label: |'md
      **Reason Payload**
      UTF-8 String (N bytes)
    '|
    style.fill: "#2ECC71" # Free/Green
    style.font-color: white
    width: 200
  }
}

# Byte-level visualization
Byte_Layout: "Physical Byte Layout (Big-Endian)" {
  style.fill: white
  style.stroke: "#333333"
  style.stroke-dash: 3

  row1: {
    grid-columns: 8
    grid-gap: 2
    b0: "0x00" {style.fill: "#9B59B6"; style.font-color: white; style.font-size: 10; width: 60}
    b1: "0x01" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
    b2: "0x02" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
    b3: "0x03" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
    b4: "0x04" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
    b5: "0x05" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
    b6: "0x06" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
    b7: "0x07" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
  }

  row2: {
    grid-columns: 8
    grid-gap: 2
    b8: "0x08" {style.fill: "#3498DB"; style.font-color: white; style.font-size: 10; width: 60}
    b9: "0x09" {style.fill: "#E67E22"; style.font-color: white; style.font-size: 10; width: 60}
    bA: "0x0A" {style.fill: "#E67E22"; style.font-color: white; style.font-size: 10; width: 60}
    bB: "0x0B..." {style.fill: "#2ECC71"; style.font-color: white; style.font-size: 10; width: 60}
    pad1: "Pad" {style.fill: "#CCCCCC"; style.font-size: 10; width: 60}
    pad2: "Pad" {style.fill: "#CCCCCC"; style.font-size: 10; width: 60}
    pad3: "Pad" {style.fill: "#CCCCCC"; style.font-size: 10; width: 60}
    pad4: "Pad" {style.fill: "#CCCCCC"; style.font-size: 10; width: 60}
  }

  legend_table: |'md
    ### Field Specification
    | Offset | Size | Name | Description |
    | :--- | :--- | :--- | :--- |
    | 0x00 | 1B | CMD | Always 0x12 for NACK |
    | 0x01 | 8B | MSGID | Unique Identifier of rejected msg |
    | 0x09 | 2B | RLEN | Length of rejection string |
    | 0x0B | NB | REASON| Error description payload |
  '|
}

# Calculated Metrics
Calculations: "Size Constraints" {
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  formula: |'md
    **Frame Formula:**
    `Size = 1 + 8 + 2 + N`
    
    *   **Minimum:** 11 bytes (Header only)
    *   **Maximum:** 11 + 65535 bytes (RLEN cap)
    *   **Alignment:** 8-byte padding recommended for Reason if N+11 is not divisible by 8.
  '|
}

# Binary Sample
Wire_Sample: "Wire Representation Example" {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  ex: |'md
    **NACK for Msg 0x2A with reason "busy"**
    
    hex
    12                    ; CMD (NACK)
    00 00 00 00 00 00 00 2A ; MSGID (42)
    00 04                 ; RLEN (4 bytes)
    62 75 73 79           ; REASON ("busy")
    
  '|
}

# Metadata Legend
Color_Legend: "Type Metadata" {
  grid-columns: 2
  grid-gap: 5
  cmd: "Header / Control" {style.fill: "#9B59B6"; style.font-color: white}
  fixed: "Fixed Data" {style.fill: "#3498DB"; style.font-color: white}
  length: "Length Pointer" {style.fill: "#E67E22"; style.font-color: white}
  var: "Variable Payload" {style.fill: "#2ECC71"; style.font-color: white}
}

# Offset flow connections
NACK_Frame.Offset_0 -> Byte_Layout.row1.b0: "Mapping" {style.stroke: "#9B59B6"; style.stroke-dash: 3}
NACK_Frame.Offset_1 -> Byte_Layout.row1.b1: "Mapping" {style.stroke: "#3498DB"; style.stroke-dash: 3}
NACK_Frame.Offset_9 -> Byte_Layout.row2.b9: "Mapping" {style.stroke: "#E67E22"; style.stroke-dash: 3}
NACK_Frame.Offset_B -> Byte_Layout.row2.bB: "Mapping" {style.stroke: "#2ECC71"; style.stroke-dash: 3}