vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Layout: InFlightMessage Structure
  **sizeof=72 bytes (fits in single cache line)**
|
InFlightMessage: {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
  header: |md
    **InFlightMessage** - Tracks delivered but unacknowledged messages
  | {
    style.fill: "#9B59B6"
    style.font-color: white
    style.stroke: "#8E44AD"
  }
  field1: {
    label: "MsgID"
    type: "uint64"
    offset: "0x00"
    size: "8 bytes"
    style.fill: "#E8F4FD"
  }
  field2: {
    label: "Payload"
    type: "*[]byte"
    offset: "0x08"
    size: "16 bytes (slice header)"
    style.fill: "#F39C12"
  }
  field3: {
    label: "ConsumerID"
    type: "string"
    offset: "0x18"
    size: "16 bytes (string header)"
    style.fill: "#F39C12"
  }
  field4: {
    label: "Partition"
    type: "int"
    offset: "0x28"
    size: "8 bytes"
    style.fill: "#27AE60"
  }
  field5: {
    label: "DeliveredAt"
    type: "time.Time"
    offset: "0x30"
    size: "24 bytes"
    style.fill: "#3498DB"
  }
  field6: {
    label: "VisibleAfter"
    type: "time.Time"
    offset: "0x48"
    size: "24 bytes"
    style.fill: "#3498DB"
  }
  field7: {
    label: "DeliveryCount"
    type: "int"
    offset: "0x60"
    size: "8 bytes"
    style.fill: "#27AE60"
  }
}
legend: {
  style.fill: white
  style.stroke: "#CCCCCC"
  legend_title: |md
    **Field Type Legend**
  | {
    style.fill: "#333333"
    style.font-color: white
  }
  ptr: {
    label: "Pointer/Reference"
    style.fill: "#F39C12"
    style.stroke: "#D68910"
  }
  scalar: {
    label: "Scalar (int, uint)"
    style.fill: "#27AE60"
    style.stroke: "#1E8449"
  }
  time: {
    label: "time.Time (24B)"
    style.fill: "#3498DB"
    style.stroke: "#2980B9"
  }
}
annotations: |md
  ## Memory Usage Notes
  - **Total: 72 bytes** (one cache line on x86-64)
  - Payload and ConsumerID are **slice/string headers** (ptr + len + cap)
  - Actual string/byte data stored separately on heap
  - time.Time is 24 bytes (wall + ext + loc pointer)
  ## Alignment
  - All fields 8-byte aligned for atomic access
  - No padding waste between fields
  - Cache-friendly for visibility scanner iteration
| {
  near: bottom-center
}
offsets: {
  style.fill: "#F5F5F5"
  off0: "0x00"
  off8: "0x08"
  off18: "0x18"
  off28: "0x28"
  off30: "0x30"
  off48: "0x48"
  off60: "0x60"
  off68: "0x68 (end)"
}
InFlightMessage.field1 -> offsets.off0
InFlightMessage.field2 -> offsets.off8
InFlightMessage.field3 -> offsets.off18
InFlightMessage.field4 -> offsets.off28
InFlightMessage.field5 -> offsets.off30
InFlightMessage.field6 -> offsets.off48
InFlightMessage.field7 -> offsets.off60