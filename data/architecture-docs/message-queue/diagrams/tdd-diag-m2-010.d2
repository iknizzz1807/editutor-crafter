direction: right
layout-engine: elk
theme-id: 6

# STATE MACHINE: CONSUMER GROUP MEMBERSHIP
# State transition logic for partition assignment and heartbeat lifecycle.

title: "State Machine: Consumer Group Membership" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------------------
# CLASSES & STYLES
# -----------------------------------------------------------------------------------------

classes: {
  state: {
    shape: rectangle
    style: {
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  error_state: {
    shape: diamond
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
    }
  }
  transition_label: {
    style: {
      font-size: 14
      italic: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# STATES
# -----------------------------------------------------------------------------------------

start: {
  shape: circle
  style.fill: "#2E7D32"
  width: 25
  height: 25
  label: ""
}

outside: OUTSIDE_GROUP {
  class: state
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  
  info: |md
    **IDLE STATE**
    - No partition assignments
    - Network connection established
    - Can send `SUBSCRIBE`
  |
}

joining: JOINING {
  class: state
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  
  info: |md
    **PENDING ASSIGNMENT**
    - `JoinGroup` request sent
    - Waiting for group leader
    - Consumer blocked from fetching
  |
}

active: ACTIVE_MEMBER {
  class: state
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  
  info: |md
    **STEADY STATE**
    - `SyncGroup` complete
    - Partitions mapped to local fetchers
    - Heartbeat thread active
  |
}

leaving: LEAVING {
  class: state
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  
  info: |md
    **CLEANUP PHASE**
    - Committing final offsets
    - Revoking partition ownership
    - Informing Coordinator
  |
}

heartbeat_timeout: "HEARTBEAT_TIMEOUT\n(Dead)" {
  class: error_state
  
  info: |md
    **SESSION EXPIRED**
    - Missed $N$ heartbeats
    - Coordinator removes member
  |
}

rebalance_failed: "REBALANCE_FAILED\n(Retryable)" {
  class: error_state
  
  info: |md
    **TIMEOUT EXCEEDED**
    - Leader failed to assign
    - Re-entering join phase
  |
}

end: {
  shape: circle
  style: {
    fill: "#424242"
    double-border: true
  }
  width: 25
  height: 25
  label: ""
}

# -----------------------------------------------------------------------------------------
# TRANSITIONS
# -----------------------------------------------------------------------------------------

start -> outside: "init_client()"

outside -> joining: "SUBSCRIBE" {
  style: {
    stroke: "#1565C0"
    animated: true
  }
}

joining -> active: "ASSIGNMENT_RECVD\n(SyncGroup Response)" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
}

joining -> rebalance_failed: "TIMEOUT\n(t > 5s)" {
  style: {
    stroke: "#C2185B"
    stroke-dash: 3
  }
}

rebalance_failed -> joining: "BACKOFF_RETRY" {
  style.stroke-dash: 3
}

active -> active: "HEARTBEAT_ACK" {
  style.stroke: "#2E7D32"
}

active -> heartbeat_timeout: "SESSION_EXPIRED\n(t > 30s)" {
  style: {
    stroke: "#B71C1C"
    stroke-width: 2
  }
}

heartbeat_timeout -> leaving: "FORCE_CLOSE" {
  style.stroke: "#B71C1C"
}

active -> leaving: "UNSUBSCRIBE" {
  style.stroke: "#C2185B"
}

leaving -> outside: "OFFSETS_COMMITTED" {
  style.stroke: "#424242"
}

outside -> end: "SHUTDOWN"

# -----------------------------------------------------------------------------------------
# ILLEGAL TRANSITIONS (Red Dashed)
# -----------------------------------------------------------------------------------------

active -> outside: "ILLEGAL: SKIP_LEAVE" {
  style: {
    stroke: "#B71C1C"
    stroke-dash: 5
    stroke-width: 4
  }
  source-arrowhead: cross
}

# -----------------------------------------------------------------------------------------
# ANNOTATIONS
# -----------------------------------------------------------------------------------------

legend: {
  near: bottom-right
  
  ok: "Normal Path" {
    style.stroke: "#2E7D32"
  }
  err: "Failure Path" {
    style.stroke: "#B71C1C"
    style.stroke-dash: 3
  }
  illegal: "Illegal State Jump" {
    style: {
      stroke: "#B71C1C"
      stroke-dash: 5
    }
  }
}