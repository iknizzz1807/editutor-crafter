# Algorithm Steps: Round-Robin Partition Assignment
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Algorithm Steps: Round-Robin Partition Assignment
| {near: top-center}
direction: right
input_section: {
  label: "INPUT"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  member_list: {
    label: "Member List"
    shape: rectangle
    style.fill: "#BBDEFB"
    member_data: |md
      
      members[] = [
        "consumer-A",
        "consumer-B", 
        "consumer-C"
      ]
      
    |
  }
  partition_count: {
    label: "PartitionCount = 16"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
}
step1: {
  label: "STEP 1: Clear Old Assignments"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  clear_action: {
    label: "Clear Maps"
    shape: rectangle
    style.fill: "#FFE0B2"
    clear_code: |md
      
      partitionToConsumer = {}
      consumerToPartitions = {}
      
    |
  }
  capture_old: {
    label: "Capture Old State"
    shape: rectangle
    style.fill: "#FFE0B2"
    old_code: |md
      
      oldAssignments = copy(
        consumerToPartitions
      )
      
    |
  }
}
step2: {
  label: "STEP 2: Round-Robin Assignment"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  loop_header: {
    label: "FOR partition = 0 TO 15"
    shape: diamond
    style.fill: "#C8E6C9"
  }
  calc: {
    label: "Calculate Consumer"
    shape: rectangle
    style.fill: "#A5D6A7"
    calc_code: |md
      
      consumerID = members[
        partition % len(members)
      ]
      
    |
  }
  assign1: {
    label: "Assign Partition→Consumer"
    shape: rectangle
    style.fill: "#A5D6A7"
    assign1_code: |md
      
      partitionToConsumer[partition] = 
        consumerID
      
    |
  }
  assign2: {
    label: "Update Consumer→Partitions"
    shape: rectangle
    style.fill: "#A5D6A7"
    assign2_code: |md
      
      consumerToPartitions[consumerID]
        .append(partition)
      
    |
  }
  loop_header -> calc -> assign1 -> assign2
  assign2 -> loop_header: "next partition" {style.stroke-dash: 3}
}
step3: {
  label: "STEP 3: Track Changed Consumers"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  compare_header: {
    label: "FOR each consumer"
    shape: diamond
    style.fill: "#E1BEE7"
  }
  compare_action: {
    label: "Compare Assignments"
    shape: rectangle
    style.fill: "#CE93D8"
    compare_code: |md
      
      oldParts = oldAssignments[consumer]
      newParts = consumerToPartitions[consumer]
      if (!partitionsEqual(
          oldParts, newParts)):
        changed.append(consumer)
      
    |
  }
  compare_header -> compare_action
}
output_section: {
  label: "OUTPUT"
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  maps_output: {
    label: "Assignment Maps"
    shape: rectangle
    style.fill: "#BBDEFB"
    maps_data: |md
      **partitionToConsumer:**
      
      {0: A, 1: B, 2: C, 3: A, 
       4: B, 5: C, ...}
      
      **consumerToPartitions:**
      
      {A: [0,3,6,9,12,15],
       B: [1,4,7,10,13],
       C: [2,5,8,11,14]}
      
    |
  }
  changed_output: {
    label: "Changed Consumers"
    shape: rectangle
    style.fill: "#BBDEFB"
    changed_data: |md
      
      changed[] = consumers whose
        partition assignments differ
        from old state
      
    |
  }
}
# Flow connections
input_section -> step1: "begin"
step1 -> step2: "maps cleared"
step2 -> step3: "assignment complete"
step3 -> output_section: "return"
# Invariant box
invariants: {
  label: "INVARIANTS"
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 2
  inv1: "• Every partition assigned to exactly ONE consumer"
  inv2: "• Partitions distributed evenly (diff ≤ 1)"
  inv3: "• No partition assigned to non-existent consumer"
  inv4: "• Round-robin ensures predictable distribution"
  inv1.style.fill: "#FFCDD2"
  inv2.style.fill: "#FFCDD2"
  inv3.style.fill: "#FFCDD2"
  inv4.style.fill: "#FFCDD2"
}
# Example calculation box
example: {
  label: "EXAMPLE: 3 Consumers, 16 Partitions"
  style.fill: "#F1F8E9"
  style.stroke: "#8BC34A"
  style.stroke-width: 2
  ex_title: "Distribution Result" {style.bold: true}
  consumer_a: {
    label: "consumer-A"
    partitions: "partitions [0, 3, 6, 9, 12, 15]"
    count: "6 partitions"
    style.fill: "#DCEDC8"
  }
  consumer_b: {
    label: "consumer-B"
    partitions: "partitions [1, 4, 7, 10, 13]"
    count: "5 partitions"
    style.fill: "#DCEDC8"
  }
  consumer_c: {
    label: "consumer-C"
    partitions: "partitions [2, 5, 8, 11, 14]"
    count: "5 partitions"
    style.fill: "#DCEDC8"
  }
}
invariants -> example