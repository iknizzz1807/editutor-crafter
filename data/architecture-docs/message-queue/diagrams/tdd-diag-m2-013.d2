direction: right
layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    sketch: false
    pad: 20
  }
}

title: |md
  # Algorithm Steps: Rebalance on Member Change
  ## Consumer Group Partition Reassignment Protocol
| {
  near: top-center
  style.font-size: 24
}

# ---------------------------------------------------------------------------------
# CLASSES FOR CONSISTENCY
# ---------------------------------------------------------------------------------
classes: {
  step_container: {
    style: {
      stroke-width: 2
      border-radius: 8
    }
  }
  logic_gate: {
    shape: diamond
    style.fill: "#F3E5F5"
  }
  state_change: {
    style: {
      font-color: "#D32F2F"
      bold: true
    }
  }
  data_structure: {
    shape: sql_table
    style.fill: "#E3F2FD"
  }
}

# ---------------------------------------------------------------------------------
# MAIN ALGORITHM WORKFLOW (Renamed from 'steps' to avoid reserved board keyword)
# ---------------------------------------------------------------------------------
rebalance_workflow: {
  # Trigger Event
  trigger: {
    shape: diamond
    label: "Join/Leave\nEvent"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 4
    }
  }

  # Step 1: Atomic State Lock
  step1: {
    class: step_container
    label: "01: Rebalance Lock"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
    flag: {
      shape: hexagon
      label: "rebalancing = **true**"
      style: {
        fill: "#FFE0B2"
        stroke: "#E65100"
        bold: true
        font-color: "#BF360C"
      }
    }
    desc: |md
      **Atomic Mutex Acquire**
      Prevents race conditions during
      concurrent member join/leave.
    |
  }

  # Step 2: Snapshot Membership
  step2: {
    class: step_container
    label: "02: Fetch Member Set"
    style: {
      fill: "#E1F5FE"
      stroke: "#0288D1"
    }
    members: {
      shape: sql_table
      label: "GroupMembers (Snapshot)"
      id: "MemberID" {constraint: PK}
      c_a: "consumer-a"
      c_b: "consumer-b"
      c_new: "**consumer-c**" {style.font-color: red; style.bold: true}
    }
  }

  # Step 3: Round-Robin Distribution
  step3: {
    class: step_container
    label: "03: Reassign Partitions"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
    
    assignment_logic: {
      direction: right
      before: {
        shape: sql_table
        label: "Old Mapping (N=2)"
        p0_7: "consumer-a"
        p8_15: "consumer-b"
      }
      calc: "Re-calculate\n(16 / 3)" {
        shape: parallelogram
        style.fill: "#E1BEE7"
      }
      after: {
        shape: sql_table
        label: "New Mapping (N=3)"
        p0_5: "consumer-a"
        p6_10: "consumer-b"
        p11_15: "**consumer-c**" {style.font-color: red; style.bold: true}
      }
      before -> calc -> after
    }
  }

  # Step 4: Handle departing message visibility
  step4: {
    class: step_container
    label: "04: In-Flight Recovery"
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
    }
    condition: {
      shape: diamond
      label: "Member\nLeaving?"
      style.fill: "#FFCDD2"
    }
    action: {
      shape: rectangle
      label: "Visibility Reset"
      style: {
        fill: "#FFCDD2"
        stroke: "#B71C1C"
      }
      update: "**VisibleAfter = NOW**" {
        style.font-color: red
        style.bold: true
      }
    }
    condition -> action: "Yes"
  }

  # Step 5: Notify Subscribers
  step5: {
    class: step_container
    label: "05: Assignment Sync"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
    }
    broadcast: {
      shape: package
      label: "NOTIFY_ASSIGNMENT"
      target: "All Active Members"
    }
  }

  # Step 6: Unlock
  step6: {
    class: step_container
    label: "06: Cleanup"
    style: {
      fill: "#ECEFF1"
      stroke: "#455A64"
    }
    flag_reset: {
      shape: hexagon
      label: "rebalancing = **false**"
      style.fill: "#CFD8DC"
    }
    metrics: |md
      **SLA CHECK**
      Total Time: < 5s
      Status: COMPLETE
    |
  }
}

# ---------------------------------------------------------------------------------
# FLOW CONNECTIONS (Using rebalance_workflow prefix)
# ---------------------------------------------------------------------------------
rebalance_workflow.trigger -> rebalance_workflow.step1: "Start" {style.stroke: "#4CAF50"; style.stroke-width: 3}
rebalance_workflow.step1 -> rebalance_workflow.step2: "Locked" {style.stroke-dash: 3}
rebalance_workflow.step2 -> rebalance_workflow.step3: "Ready"
rebalance_workflow.step3 -> rebalance_workflow.step4: "Assigned"
rebalance_workflow.step4 -> rebalance_workflow.step5: "Cleared"
rebalance_workflow.step5 -> rebalance_workflow.step6: "Notified"

# ---------------------------------------------------------------------------------
# ANNOTATIONS & INVARIANTS
# ---------------------------------------------------------------------------------
invariant_box: {
  near: bottom-left
  label: "⚠️ CRITICAL SYSTEM INVARIANT"
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 4
    double-border: true
  }
  content: |md
    **Zero-Loss Guarantee**
    Any partition transfer requires the
    Broker to force `VisibleAfter = now`
    on all unacknowledged messages held
    by the departing consumer.
    
    *Execution Offset:* T+450ms
  |
}

timing_constraint: {
  near: bottom-center
  label: "⏱️ PERFORMANCE SLA"
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
  }
  text: "Max Latency: 5,000ms\nVisibility Cycle: 1,000ms"
}

# ---------------------------------------------------------------------------------
# LEGEND
# ---------------------------------------------------------------------------------
legend: {
  near: bottom-right
  label: "Manual Reference"
  style.fill: "#FAFAFA"
  
  l1: "Logic/Decision" { shape: diamond; style.fill: "#F3E5F5" }
  l2: "State Change" { style.font-color: red; style.bold: true }
  l3: "Atomic Flag" { shape: hexagon; style.fill: "#FFE0B2" }
  l4: "Data Structure" { shape: sql_table; style.fill: "#E3F2FD" }
}