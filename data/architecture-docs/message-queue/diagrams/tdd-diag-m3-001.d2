vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    free: "#22C55E"
    padding: "#9CA3AF"
    pointer: "#F97316"
  }
}
title: |md
  # DurabilityMode Configuration Tradeoffs
| {near: top-center}
direction: right
PerWrite: {
  style.fill: "${colors.header}"
  style.font-color: white
  label: "DurabilityPerWrite\n\n• fsync every write\n• Maximum durability\n• ~100-1000 msg/s\n• Zero data loss"
  Flow1: {
    shape: sequence_diagram
    Producer -> Server: PUBLISH
    Server -> Log: Append
    Server -> Log: fsync()
    Server -> Producer: ACK
  }
  Flow1.style.stroke: "${colors.header}"
}
Batched: {
  style.fill: "${colors.data}"
  style.font-color: white
  label: "DurabilityBatched\n\n• fsync every N writes or M ms\n• Balanced durability\n• ~10K-100K msg/s\n• N msgs or M ms loss window"
  Flow2: {
    shape: sequence_diagram
    Producer1: Producer
    Server1: Server
    Log1: Log
    Producer1 -> Server1: PUBLISH 1
    Server1 -> Log1: Append
    Server1 -> Producer1: ACK
    Producer2: Producer
    Producer2 -> Server1: PUBLISH N
    Server1 -> Log1: Append
    Server1 -> Log1: fsync() {
      style.stroke: "${colors.header}"
    }
    Server1 -> Producer2: ACK
  }
  Flow2.style.stroke: "${colors.data}"
}
OSManaged: {
  style.fill: "${colors.free}"
  style.font-color: white
  label: "DurabilityOSManaged\n\n• Never fsync\n• OS page cache only\n• ~1M+ msg/s\n• Seconds-to-minutes loss"
  Flow3: {
    shape: sequence_diagram
    Producer3: Producer
    Server2: Server
    OS: OS Page Cache
    Producer3 -> Server2: PUBLISH
    Server2 -> OS: Write to cache
    Server2 -> Producer3: ACK
    OS -> Disk: eventual flush {
      style.stroke-dash: 5
      style.animated: true
    }
  }
  Flow3.style.stroke: "${colors.free}"
}
PerWrite -> Batched: "Higher\nThroughput" {
  style.stroke: "${colors.pointer}"
  style.font-color: "${colors.pointer}"
}
Batched -> OSManaged: "Higher\nThroughput" {
  style.stroke: "${colors.pointer}"
  style.font-color: "${colors.pointer}"
}
legend: |md
  **Tradeoff Spectrum**
  Moving right increases throughput but decreases durability guarantees.
  - **PerWrite**: Maximum safety, minimum speed
  - **Batched**: Balanced (recommended default)
  - **OSManaged**: Maximum speed, minimum safety
| {near: bottom-center}