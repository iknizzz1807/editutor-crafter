vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Memory Layout: Log Entry Binary Format
  **Total Size: 26 + TopicLen + PayloadLen bytes**
|
# Row structure - each field as a cell
header_container: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  grid-columns: 4
  grid-gap: 0
  # Header Row 1: Offset (8 bytes)
  f1_label: |md
    **Offset**
    `0x00-0x07`
  | {
    style.fill: "#E8D5E8"
    style.stroke: "#8B668B"
    width: 180
  }
  f1_size: |md
    **8 bytes**
    `uint64 BE`
  | {
    style.fill: "#E8D5E8"
    style.stroke: "#8B668B"
    width: 120
  }
  f1_desc: |md
    Monotonically increasing
    log position
  | {
    style.fill: "#E8D5E8"
    style.stroke: "#8B668B"
    width: 180
  }
  f1_hex: |md
    `00 00 00 00`
    `00 00 00 01`
  | {
    style.fill: "#E8D5E8"
    style.stroke: "#8B668B"
    style.font: mono
    width: 140
  }
  # Header Row 2: Timestamp (8 bytes)
  f2_label: |md
    **Timestamp**
    `0x08-0x0F`
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    width: 180
  }
  f2_size: |md
    **8 bytes**
    `int64 BE`
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    width: 120
  }
  f2_desc: |md
    Unix nanoseconds
    when created
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    width: 180
  }
  f2_hex: |md
    `18 F2 C8 A3`
    `5B 00 00 00`
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    style.font: mono
    width: 140
  }
  # Header Row 3: Topic Length (2 bytes)
  f3_label: |md
    **TopicLen**
    `0x10-0x11`
  | {
    style.fill: "#D5E8E8"
    style.stroke: "#668B8B"
    width: 180
  }
  f3_size: |md
    **2 bytes**
    `uint16 BE`
  | {
    style.fill: "#D5E8E8"
    style.stroke: "#668B8B"
    width: 120
  }
  f3_desc: |md
    Length of topic name
    (max 256)
  | {
    style.fill: "#D5E8E8"
    style.stroke: "#668B8B"
    width: 180
  }
  f3_hex: |md
    `00 06`
  | {
    style.fill: "#D5E8E8"
    style.stroke: "#668B8B"
    style.font: mono
    width: 140
  }
  # Header Row 4: Topic (variable)
  f4_label: |md
    **Topic**
    `0x12-0x11+TL`
  | {
    style.fill: "#E8E8D5"
    style.stroke: "#8B8B66"
    width: 180
  }
  f4_size: |md
    **N bytes**
    `UTF-8`
  | {
    style.fill: "#E8E8D5"
    style.stroke: "#8B8B66"
    width: 120
  }
  f4_desc: |md
    Topic name string
    (TopicLen bytes)
  | {
    style.fill: "#E8E8D5"
    style.stroke: "#8B8B66"
    width: 180
  }
  f4_hex: |md
    `6F 72 64 65`
    `72 73`
  | {
    style.fill: "#E8E8D5"
    style.stroke: "#8B8B66"
    style.font: mono
    width: 140
  }
  # Header Row 5: Payload Length (4 bytes)
  f5_label: |md
    **PayloadLen**
    `0x12+TL`
  | {
    style.fill: "#D5D5E8"
    style.stroke: "#66668B"
    width: 180
  }
  f5_size: |md
    **4 bytes**
    `uint32 BE`
  | {
    style.fill: "#D5D5E8"
    style.stroke: "#66668B"
    width: 120
  }
  f5_desc: |md
    Length of payload
    (max 10MB)
  | {
    style.fill: "#D5D5E8"
    style.stroke: "#66668B"
    width: 180
  }
  f5_hex: |md
    `00 00 00 05`
  | {
    style.fill: "#D5D5E8"
    style.stroke: "#66668B"
    style.font: mono
    width: 140
  }
  # Header Row 6: Payload (variable)
  f6_label: |md
    **Payload**
    `0x16+TL`
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    width: 180
  }
  f6_size: |md
    **M bytes**
    `binary`
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    width: 120
  }
  f6_desc: |md
    Raw message content
    (PayloadLen bytes)
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    width: 180
  }
  f6_hex: |md
    `68 65 6C 6C`
    `6F`
  | {
    style.fill: "#D5E8D5"
    style.stroke: "#668B66"
    style.font: mono
    width: 140
  }
  # Header Row 7: CRC32 (4 bytes)
  f7_label: |md
    **CRC32**
    `0x16+TL+PL`
  | {
    style.fill: "#E8D5D5"
    style.stroke: "#8B6666"
    width: 180
  }
  f7_size: |md
    **4 bytes**
    `uint32 BE`
  | {
    style.fill: "#E8D5D5"
    style.stroke: "#8B6666"
    width: 120
  }
  f7_desc: |md
    Checksum of all
    preceding bytes
  | {
    style.fill: "#E8D5D5"
    style.stroke: "#8B6666"
    width: 180
  }
  f7_hex: |md
    `A3 5B 7C 9D`
  | {
    style.fill: "#E8D5D5"
    style.stroke: "#8B6666"
    style.font: mono
    width: 140
  }
}
# Visual byte layout
layout_title: |md
  ## Byte-Level Memory Layout
| {
  near: top-center
}
byte_grid: {
  grid-columns: 8
  grid-gap: 2
  style.fill: "#F8F8F8"
  style.stroke: "#CCCCCC"
  style.stroke-width: 1
  # Byte offset labels
  b00: |md
    `+0`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  b01: |md
    `+1`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  b02: |md
    `+2`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  b03: |md
    `+3`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  b04: |md
    `+4`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  b05: |md
    `+5`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  b06: |md
    `+6`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  b07: |md
    `+7`
  | { style.fill: "#EEEEEE"; style.font: mono; style.font-size: 14; width: 60 }
  # Offset row (bytes 0-7)
  o0: |md
    **O7**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  o1: |md
    **O6**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  o2: |md
    **O5**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  o3: |md
    **O4**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  o4: |md
    **O3**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  o5: |md
    **O2**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  o6: |md
    **O1**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  o7: |md
    **O0**
  | { style.fill: "#E8D5E8"; style.stroke: "#8B668B"; style.font: mono; width: 60 }
  # Timestamp row (bytes 8-15)
  t0: |md
    **T7**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  t1: |md
    **T6**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  t2: |md
    **T5**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  t3: |md
    **T4**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  t4: |md
    **T3**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  t5: |md
    **T2**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  t6: |md
    **T1**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  t7: |md
    **T0**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  # TopicLen row (bytes 16-17) + Topic start
  tl0: |md
    **TL1**
  | { style.fill: "#D5E8E8"; style.stroke: "#668B8B"; style.font: mono; width: 60 }
  tl1: |md
    **TL0**
  | { style.fill: "#D5E8E8"; style.stroke: "#668B8B"; style.font: mono; width: 60 }
  tp0: |md
    **T0**
  | { style.fill: "#E8E8D5"; style.stroke: "#8B8B66"; style.font: mono; width: 60 }
  tp1: |md
    **T1**
  | { style.fill: "#E8E8D5"; style.stroke: "#8B8B66"; style.font: mono; width: 60 }
  tp2: |md
    **T2**
  | { style.fill: "#E8E8D5"; style.stroke: "#8B8B66"; style.font: mono; width: 60 }
  tp3: |md
    **T3**
  | { style.fill: "#E8E8D5"; style.stroke: "#8B8B66"; style.font: mono; width: 60 }
  tp4: |md
    **...**
  | { style.fill: "#E8E8D5"; style.stroke: "#8B8B66"; style.font: mono; width: 60 }
  tp5: |md
    **TN**
  | { style.fill: "#E8E8D5"; style.stroke: "#8B8B66"; style.font: mono; width: 60 }
  # PayloadLen row + Payload start
  pl0: |md
    **PL3**
  | { style.fill: "#D5D5E8"; style.stroke: "#66668B"; style.font: mono; width: 60 }
  pl1: |md
    **PL2**
  | { style.fill: "#D5D5E8"; style.stroke: "#66668B"; style.font: mono; width: 60 }
  pl2: |md
    **PL1**
  | { style.fill: "#D5D5E8"; style.stroke: "#66668B"; style.font: mono; width: 60 }
  pl3: |md
    **PL0**
  | { style.fill: "#D5D5E8"; style.stroke: "#66668B"; style.font: mono; width: 60 }
  pp0: |md
    **P0**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  pp1: |md
    **P1**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  pp2: |md
    **...**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  pp3: |md
    **PM**
  | { style.fill: "#D5E8D5"; style.stroke: "#668B66"; style.font: mono; width: 60 }
  # CRC32 row
  c0: |md
    **C3**
  | { style.fill: "#E8D5D5"; style.stroke: "#8B6666"; style.font: mono; width: 60 }
  c1: |md
    **C2**
  | { style.fill: "#E8D5D5"; style.stroke: "#8B6666"; style.font: mono; width: 60 }
  c2: |md
    **C1**
  | { style.fill: "#E8D5D5"; style.stroke: "#8B6666"; style.font: mono; width: 60 }
  c3: |md
    **C0**
  | { style.fill: "#E8D5D5"; style.stroke: "#8B6666"; style.font: mono; width: 60 }
  c_empty1: "" { style.fill: transparent; style.stroke: transparent; width: 60 }
  c_empty2: "" { style.fill: transparent; style.stroke: transparent; width: 60 }
  c_empty3: "" { style.fill: transparent; style.stroke: transparent; width: 60 }
  c_empty4: "" { style.fill: transparent; style.stroke: transparent; width: 60 }
}
# Legend
legend: {
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  legend_title: |md
    ### Field Legend
  |
  legend_grid: {
    grid-columns: 2
    grid-gap: 5
    leg_offset: |md
      ■ Offset (8B)
    | { style.fill: "#E8D5E8"; style.stroke: "#8B668B" }
    leg_offset_desc: |md
      Log position, BE
    | { style.fill: transparent; style.stroke: transparent }
    leg_ts: |md
      ■ Timestamp (8B)
    | { style.fill: "#D5E8D5"; style.stroke: "#668B66" }
    leg_ts_desc: |md
      Unix nanos, BE
    | { style.fill: transparent; style.stroke: transparent }
    leg_topiclen: |md
      ■ TopicLen (2B)
    | { style.fill: "#D5E8E8"; style.stroke: "#668B8B" }
    leg_topiclen_desc: |md
      Topic length, BE
    | { style.fill: transparent; style.stroke: transparent }
    leg_topic: |md
      ■ Topic (N B)
    | { style.fill: "#E8E8D5"; style.stroke: "#8B8B66" }
    leg_topic_desc: |md
      UTF-8 string
    | { style.fill: transparent; style.stroke: transparent }
    leg_plen: |md
      ■ PayloadLen (4B)
    | { style.fill: "#D5D5E8"; style.stroke: "#66668B" }
    leg_plen_desc: |md
      Payload length, BE
    | { style.fill: transparent; style.stroke: transparent }
    leg_payload: |md
      ■ Payload (M B)
    | { style.fill: "#D5E8D5"; style.stroke: "#668B66" }
    leg_payload_desc: |md
      Raw bytes
    | { style.fill: transparent; style.stroke: transparent }
    leg_crc: |md
      ■ CRC32 (4B)
    | { style.fill: "#E8D5D5"; style.stroke: "#8B6666" }
    leg_crc_desc: |md
      Checksum, BE
    | { style.fill: transparent; style.stroke: transparent }
  }
}
# Size summary
size_info: {
  style.fill: "#F0F0F0"
  style.stroke: "#999999"
  size_title: |md
    ### Size Calculation
  |
  size_formula: |md
    
    Total = 8 (offset)
          + 8 (timestamp)
          + 2 (topicLen)
          + N (topic)
          + 4 (payloadLen)
          + M (payload)
          + 4 (CRC32)
    Total = 26 + N + M bytes
    Minimum = 26 bytes (empty topic + empty payload)
    Maximum = 26 + 256 + 10,485,760 bytes ≈ 10 MB
    
  | {
    style.font: mono
    style.fill: "#FFFFFF"
  }
}
# Notes
notes: {
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  notes_title: |md
    ### Implementation Notes
  |
  notes_content: |md
    - **Endianness**: All multi-byte integers are **big-endian** (network byte order)
    - **CRC32**: IEEE polynomial, calculated over bytes 0 through `22+N+M-1` (all bytes except CRC field)
    - **Alignment**: No padding; fields are packed consecutively
    - **Validation**: Decode verifies CRC before returning; `ErrCRCMismatch` on corruption
    - **Offset**: Monotonically increasing, globally unique across all topics
  |
}
# Example
example: {
  style.fill: "#F5F5FF"
  style.stroke: "#6A5ACD"
  ex_title: |md
    ### Example: PUBLISH "hello" to topic "orders"
  |
  ex_content: |md
    
    Offset:     00 00 00 00 00 00 00 01     (1)
    Timestamp:  18 F2 C8 A3 5B 00 00 00     (1709635200000000000)
    TopicLen:   00 06                        (6)
    Topic:      6F 72 64 65 72 73           ("orders")
    PayloadLen: 00 00 00 05                  (5)
    Payload:    68 65 6C 6C 6F              ("hello")
    CRC32:      A3 5B 7C 9D                  (checksum)
    Total size: 8 + 8 + 2 + 6 + 4 + 5 + 4 = 37 bytes
    
  | {
    style.font: mono
    style.fill: "#FFFFFF"
  }
}
header_container -> byte_grid: "maps to" { style.stroke-dash: 3; style.stroke: "#999999" }
byte_grid -> legend: ""
legend -> size_info: ""
size_info -> notes: ""
notes -> example: ""