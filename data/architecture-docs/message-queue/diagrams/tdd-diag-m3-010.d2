direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5E3"
    topic: "#D5E8D4"
    payload: "#DAE8FC"
    crc: "#F8CECC"
    buffer: "#F5F5F5"
    marker: "#666666"
    pointer: "#FF9900"
    border: "#2C3E50"
  }
}

title: ||md
  # Log Entry Encoding Algorithm
  ## Method: `LogEntry.Encode(dest []byte) (int, error)`
  *Intel-grade Technical Specification for Byte Serialization & IEEE CRC32 Integrity*
|| {near: top-center}

Input: {
  shape: class
  label: "Source Object: LogEntry"
  Offset: "uint64 (BigEndian)"
  Timestamp: "int64 (BigEndian)"
  Topic: "string (max 64KB)"
  Payload: "[]byte (max 4GB)"
  
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: "#FFFFFF"
  }
}

encoding_process: {
  label: "Encoding Sequence"
  style.stroke-dash: 3

  step1: {
    label: "Step 1: Write Fixed-Size Header"
    header_buffer: {
      label: "Buffer Allocation [0:22]"
      style.fill: ${colors.buffer}
      
      f0: "Offset" {
        label: "Offset\n(8B BE)\n[0:8]"
        style.fill: ${colors.header}
      }
      f8: "Timestamp" {
        label: "Timestamp\n(8B BE)\n[8:16]"
        style.fill: ${colors.header}
      }
      f16: "TopicLen" {
        label: "TopicLen\n(2B BE)\n[16:18]"
        style.fill: ${colors.header}
      }
      f18: "PayloadLen" {
        label: "PayloadLen\n(4B BE)\n[18:22]"
        style.fill: ${colors.header}
      }
      
      f0 -> f8 -> f16 -> f18: {style.stroke-width: 0}
    }
    note1: ||md
      **Logic:**
      - `binary.BigEndian.PutUint64(buf[0:8], e.Offset)`
      - `binary.BigEndian.PutUint64(buf[8:16], uint64(e.Timestamp))`
      - `binary.BigEndian.PutUint16(buf[16:18], uint16(len(topicBytes)))`
      - `binary.BigEndian.PutUint32(buf[18:22], uint32(len(e.Payload)))`
    || {near: bottom-center}
  }

  step2: {
    label: "Step 2: Serialize Topic String"
    topic_section: {
      label: "Buffer Extension [22:22+N]"
      style.fill: ${colors.buffer}
      header_ref: {
        label: "Fixed Header\n(22 Bytes)"
        style.fill: ${colors.header}
      }
      topic_bytes: {
        label: "Topic Data\n(UTF8 Bytes)\n[22 : 22+N]"
        style.fill: ${colors.topic}
        style.bold: true
      }
      header_ref -> topic_bytes: {style.stroke-width: 0}
    }
    note2: ||md
      **Logic:**
      - `copy(buf[22:22+N], topicBytes)`
      - **Invariants:**
        - N must match `TopicLen` from Step 1.
        - Topic must be UTF-8 valid.
    || {near: bottom-center}
  }

  step3: {
    label: "Step 3: Serialize Binary Payload"
    payload_section: {
      label: "Buffer Extension [22+N : 22+N+M]"
      style.fill: ${colors.buffer}
      
      prev_data: {
        label: "Header + Topic\n(22 + N Bytes)"
        style.fill: "#E0E0E0"
      }
      payload_bytes: {
        label: "Payload Data\n(Raw Bytes)\n[22+N : 22+N+M]"
        style.fill: ${colors.payload}
        style.bold: true
      }
      prev_data -> payload_bytes: {style.stroke-width: 0}
    }
    note3: ||md
      **Logic:**
      - `copy(buf[22+N : 22+N+M], e.Payload)`
      - M = `PayloadLen`.
      - Supports zero-copy if using `writev`.
    || {near: bottom-center}
  }

  step4: {
    label: "Step 4: Compute & Append CRC32"
    final_buffer: {
      label: "Final Buffer Seal"
      style.fill: ${colors.buffer}
      
      checksum_range: {
        label: "Checksum Range (Data Segment)\n[0 : 22+N+M]"
        style: {
          stroke: ${colors.crc}
          stroke-width: 4
          stroke-dash: 5
          fill: white
        }
      }
      
      crc_field: {
        label: "CRC32 IEEE\n(4B BE)\n[End-4 : End]"
        style.fill: ${colors.crc}
        style.bold: true
      }
      
      checksum_range -> crc_field: "IEEE 802.3 Polynomial" {
        style: {
          stroke: ${colors.crc}
          stroke-width: 2
          animated: true
        }
      }
    }
    note4: ||md
      **Logic:**
      - `ck := crc32.ChecksumIEEE(buf[:22+N+M])`
      - `binary.BigEndian.PutUint32(buf[22+N+M:], ck)`
      - Final size: `26 + N + M` bytes.
    || {near: bottom-center}
  }

  step1 -> step2 -> step3 -> step4: {
    style: {
      stroke-width: 4
      stroke: "#2C3E50"
    }
  }
}

Output: {
  label: "Final Memory Layout / Wire Format"
  
  memory_map: {
    grid-columns: 7
    grid-gap: 0
    
    b1: "Offset\n(8B)" { style.fill: ${colors.header} }
    b2: "TS\n(8B)" { style.fill: ${colors.header} }
    b3: "TLen\n(2B)" { style.fill: ${colors.header} }
    b4: "PLen\n(4B)" { style.fill: ${colors.header} }
    b5: "Topic\n(N Bytes)" { style.fill: ${colors.topic} }
    b6: "Payload\n(M Bytes)" { style.fill: ${colors.payload} }
    b7: "CRC\n(4B)" { style.fill: ${colors.crc} }
  }
  
  spec_table: ||md
    ### Wire Format Specification (Big Endian)
    | Offset | Field | Size | Type | Description |
    | :--- | :--- | :--- | :--- | :--- |
    | 0 | Offset | 8 | uint64 | Unique log sequence number |
    | 8 | Timestamp | 8 | int64 | Unix nanoseconds |
    | 16 | TopicLen | 2 | uint16 | Length of Topic field (N) |
    | 18 | PayloadLen | 4 | uint32 | Length of Payload field (M) |
    | 22 | Topic | N | []byte | UTF-8 encoded topic string |
    | 22+N | Payload | M | []byte | Raw application binary data |
    | 22+N+M | CRC32 | 4 | uint32 | IEEE Checksum (Fields 0 to 22+N+M) |
  ||
  
  style: {
    stroke: "#2C3E50"
    stroke-width: 2
    fill: "#FDFEFE"
  }
}

Input -> encoding_process.step1: "Call .Encode()" {
  style.stroke: ${colors.pointer}
}
encoding_process.step4 -> Output: "Return Serialized Slice" {
  style.stroke: ${colors.pointer}
}

legend: {
  near: bottom-right
  key: {
    label: "Color Legend"
    h: "Control Header (Fixed)" { style.fill: ${colors.header} }
    t: "Variable Topic" { style.fill: ${colors.topic} }
    p: "Variable Payload" { style.fill: ${colors.payload} }
    c: "Integrity (CRC32)" { style.fill: ${colors.crc} }
    b: "Working Buffer" { style.fill: ${colors.buffer} }
  }
}