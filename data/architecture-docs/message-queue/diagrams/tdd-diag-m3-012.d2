vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    healthy: "#4CAF50"
    degraded: "#FF9800"
    critical: "#F44336"
    band: "#E3F2FD"
    threshold: "#2196F3"
    text: "#37474F"
  }
}
title: |md
  # Algorithm: Backpressure Decision with Hysteresis
| {near: top-center}
direction: right
# Main states
state_idle: "IDLE\n(No Throttle)" {
  style: {
    fill: "${colors.healthy}"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: white
    bold: true
    font-size: 20
  }
}
state_throttle: "THROTTLING\n(Active Backpressure)" {
  style: {
    fill: "${colors.critical}"
    stroke: "#C62828"
    stroke-width: 3
    font-color: white
    bold: true
    font-size: 20
  }
}
# Hysteresis band visualization
hysteresis_band: {
  label: "Hysteresis Band\n(Prevents Rapid Toggling)"
  width: 500
  height: 350
  style: {
    fill: "${colors.band}"
    stroke: "#90CAF9"
    stroke-dash: 3
  }
  # Threshold lines
  high_line: "LagThresholdHigh = 10,000" {
    style: {
      stroke: "${colors.threshold}"
      stroke-width: 2
      stroke-dash: 5
    }
  }
  low_line: "LagThresholdLow = 5,000" {
    style: {
      stroke: "${colors.threshold}"
      stroke-width: 2
      stroke-dash: 5
    }
  }
}
# Flow from IDLE
state_idle -> check_lag_idle: "Check Lag" {
  style: {
    stroke: "#37474F"
    stroke-width: 2
  }
}
check_lag_idle: "lag > High?" {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
}
check_lag_idle -> state_idle: "NO\n(Stay IDLE)" {
  style: {
    stroke: "${colors.healthy}"
    stroke-width: 3
  }
}
check_lag_idle -> state_throttle: "YES\n(Start Throttle)" {
  style: {
    stroke: "${colors.critical}"
    stroke-width: 3
    animated: true
  }
}
# Flow from THROTTLING
state_throttle -> check_lag_throttle: "Check Lag" {
  style: {
    stroke: "#37474F"
    stroke-width: 2
  }
}
check_lag_throttle: "lag < Low?" {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
}
check_lag_throttle -> state_throttle: "NO\n(Stay Throttling)" {
  style: {
    stroke: "${colors.critical}"
    stroke-width: 3
  }
}
check_lag_throttle -> state_idle: "YES\n(Stop Throttle)" {
  style: {
    stroke: "${colors.healthy}"
    stroke-width: 3
  }
}
# Annotation for hysteresis concept
hysteresis_explain: |md
  **Hysteresis Gap = 5,000**
  - Start throttling at **10,000**
  - Stop throttling at **5,000**
  This 5,000 message gap prevents:
  - Rapid on/off toggling
  - Oscillation around single threshold
  - Producer confusion from flip-flopping
| {
  near: top-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    font-size: 14
  }
}
# Algorithm pseudocode
algorithm_box: |md
  go
  func ShouldThrottle() bool {
    throttling := atomic.Load(&bm.throttling)
    lag := CalculateLag()
    if throttling {
      // Use LOWER threshold to stop
      if lag < LagThresholdLow {
        atomic.Store(&bm.throttling, 0)
        return false  // STOP
      }
      return true  // Continue
    } else {
      // Use HIGHER threshold to start
      if lag > LagThresholdHigh {
        atomic.Store(&bm.throttling, 1)
        return true  // START
      }
      return false  // Continue
    }
  }
  
| {
  near: bottom-center
  style: {
    fill: "#263238"
    font-color: "#ECEFF1"
    font: mono
    font-size: 12
  }
}
# Key invariants
invariants: |md
  **Invariants:**
  1. Once throttling starts, continues until lag drops below **LagThresholdLow**
  2. State transitions are atomic (no race conditions)
  3. Different thresholds for entry vs exit = stable state
| {
  near: bottom-left
  style: {
    fill: "#E8F5E9"
    stroke: "#81C784"
    font-size: 13
  }
}