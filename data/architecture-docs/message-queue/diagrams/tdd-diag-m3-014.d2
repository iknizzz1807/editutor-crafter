direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 40
  }
}

title: "State Machine: Backpressure Logic & Hysteresis" {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# --- State Context Containers (ELK compatible grouping) ---

Normal_Context: {
  style: {
    stroke: "#228B22"
    stroke-dash: 2
    fill: "#F0FFF0"
  }

  NORMAL: "STATE: NORMAL" {
    shape: circle
    tooltip: "System is operating within nominal lag parameters."
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      stroke-width: 5
      shadow: true
    }
  }

  normal_invariant: ||md
### [0x00] Invariant: System Nominal
- **Consumer Lag**: < 10,000 pkts (High Watermark)
- **Protocol Action**: `PUBLISH_ACK` (0x01)
- **Publisher State**: Full Throughput (100%)
- **Manager Flag**: `throttling = 0x0`
|| {
    shape: rectangle
    style: {
      font-size: 14
      fill: "#FFFFFF"
      stroke: "#228B22"
      border-radius: 8
    }
  }
  
  normal_invariant -> NORMAL: "Invariants" {
    style.stroke-dash: 3
    style.stroke: "#228B22"
  }
}

Throttling_Context: {
  style: {
    stroke: "#DC143C"
    stroke-dash: 2
    fill: "#FFF0F0"
  }

  THROTTLING: "STATE: THROTTLING" {
    shape: circle
    tooltip: "Backpressure active. High consumer lag detected."
    style: {
      fill: "#FFB6C1"
      stroke: "#DC143C"
      stroke-width: 5
      shadow: true
    }
  }

  throttling_invariant: ||md
### [0x01] Invariant: System Overloaded
- **Consumer Lag**: > 5,000 pkts (Low Watermark)
- **Protocol Action**: `THROTTLE` (0x20)
- **Publisher State**: `DelayMs` injection active
- **Manager Flag**: `throttling = 0x1`
|| {
    shape: rectangle
    style: {
      font-size: 14
      fill: "#FFFFFF"
      stroke: "#DC143C"
      border-radius: 8
    }
  }

  throttling_invariant -> THROTTLING: "Invariants" {
    style.stroke-dash: 3
    style.stroke: "#DC143C"
  }
}

# --- Transitions ---

Normal_Context.NORMAL -> Throttling_Context.THROTTLING: ||md
1. **Trigger**: <span style="color:red; font-weight:bold;">lag_event > 10,000</span>
2. **Guard**: `atomic.LoadInt32(&throttling) == 0`
3. **Action Seq**:
   - `atomic.StoreInt32(&throttling, 1)`
   - `NotifyPublishers(OP_THROTTLE)`
   - `UpdateMetrics(BP_START)`
|| {
  style: {
    stroke: "#DC143C"
    stroke-width: 4
    animated: true
  }
}

Throttling_Context.THROTTLING -> Normal_Context.NORMAL: ||md
1. **Trigger**: <span style="color:red; font-weight:bold;">lag_event < 5,000</span>
2. **Guard**: `atomic.LoadInt32(&throttling) == 1`
3. **Action Seq**:
   - `atomic.StoreInt32(&throttling, 0)`
   - `NotifyPublishers(OP_RESUME)`
   - `UpdateMetrics(BP_STOP)`
|| {
  style: {
    stroke: "#228B22"
    stroke-width: 4
    animated: true
  }
}

# --- Protocol Frame Layout (Technical Detail) ---

throttle_format: "THROTTLE Frame Layout (0x20)" {
  near: top-right
  shape: sql_table
  style: {
    stroke: "#B8860B"
    stroke-width: 2
  }
  
  "0x00": "OP_CODE: 0x20" {
    constraint: "1 Byte"
    style.fill: "#E6E6FA" # Header Purple
  }
  "0x01": "DELAY_MS_HI" {
    constraint: "1 Byte (BE)"
    style.fill: "#E1F5FE" # Data Blue
  }
  "0x02": "DELAY_MS_LO" {
    constraint: "1 Byte (BE)"
    style.fill: "#E1F5FE" # Data Blue
  }
  "0x03": "LAG_DEPTH_B3" {
    constraint: "1 Byte"
    style.fill: "#E1F5FE" # Data Blue
  }
  "0x04": "LAG_DEPTH_B2" {
    constraint: "1 Byte"
    style.fill: "#E1F5FE" # Data Blue
  }
  "0x05": "LAG_DEPTH_B1" {
    constraint: "1 Byte"
    style.fill: "#E1F5FE" # Data Blue
  }
  "0x06": "LAG_DEPTH_B0" {
    constraint: "1 Byte"
    style.fill: "#E1F5FE" # Data Blue
  }
  "0x07": "PADDING" {
    constraint: "1 Byte (0x00)"
    style.fill: "#EEEEEE" # Padding Gray
  }
}

# --- Supplemental Reference Documentation ---

hysteresis: {
  near: bottom-left
  shape: rectangle
  width: 500
  style: {
    fill: "#F5F5DC"
    stroke: "#8B4513"
    stroke-dash: 4
  }
  explanation: ||md
## Hysteresis Logic Table (TDD-014)

| Current State | Lag Range | Condition | Next State |
| :--- | :--- | :--- | :--- |
| **NORMAL** | [0, 10000) | `lag < HI_WM` | **NORMAL** |
| **NORMAL** | [10000, ∞) | `lag >= HI_WM` | **THROTTLING** |
| **THROTTLING** | (5000, ∞] | `lag > LO_WM` | **THROTTLING** |
| **THROTTLING** | [0, 5000] | `lag <= LO_WM` | **NORMAL** |

**Rationale**: The 5,000 packet hysteresis band prevents state flapping at high frequency.
||
}

# --- State Markers & Warnings ---

●: "Boot: lag=0"
● -> Normal_Context.NORMAL: "INIT" {
  style: {
    stroke-width: 2
    stroke: black
  }
}

illegal_section: {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FFF0F0"
    stroke: red
    stroke-width: 2
  }
  label: ||md
### ⚠️ ILLEGAL TRANSITIONS (CRITICAL)
- **Direct 0 -> NORMAL**: Illegal if `boot_lag > 5k`.
- **Oscillation**: Transition `THROTTLING -> NORMAL` with `lag = 7k` is <span style="color:red; font-weight:bold;">ILLEGAL</span>.
- **Concurrent**: Multiple threads MUST use `CAS` on `throttling` flag.
||
}

# --- Style Globs & Fine-tuning ---

***.style.font: mono
(Normal_Context.NORMAL -> Throttling_Context.THROTTLING)[0].source-arrowhead: circle
(Throttling_Context.THROTTLING -> Normal_Context.NORMAL)[0].source-arrowhead: circle
(Normal_Context.NORMAL -> Throttling_Context.THROTTLING)[0].target-arrowhead: triangle
(Throttling_Context.THROTTLING -> Normal_Context.NORMAL)[0].target-arrowhead: triangle

# Visual Cues for State Hierarchy
Normal_Context.NORMAL.style.double-border: true
Throttling_Context.THROTTLING.style.double-border: true