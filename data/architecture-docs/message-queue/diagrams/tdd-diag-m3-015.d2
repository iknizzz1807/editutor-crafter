layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: ||md
  # Publish Flow: Full Persistent Lifecycle
  **Type:** Sequence Diagram | **Subsystem:** Message Broker Core
  **Spec:** PERSIST-01-REQ
||
title.near: top-center
title.style.stroke-width: 0

# --- Style Definitions ---
classes: {
  process_box: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      border-radius: 8
    }
  }
  data_box: {
    style: {
      fill: "#FFF3E0"
      stroke: "#E07B39"
      stroke-width: 2
      border-radius: 4
    }
  }
  infra_box: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  actor_style: {
    style: {
      fill: "#F5F5F5"
      stroke: "#333333"
      stroke-width: 2
    }
  }
}

# --- Sequence Diagram Implementation ---
publish_sequence: {
  shape: sequence_diagram

  # Actor Definitions with Implementation Details
  client: "Client\n(TCP Producer)" {
    class: actor_style
  }
  reader: "FrameReader\n(Netty/NIO)" {
    class: process_box
  }
  parser: "ParseCommand\n(ProtocolCodec)" {
    class: process_box
  }
  handler: "handlePublish\n(CommandProcessor)" {
    class: process_box
  }
  logger: "LogWriter\n(Persistence Engine)" {
    class: data_box
  }
  router: "TopicManager\n(Routing Engine)" {
    class: process_box
  }
  bpm: "BackpressureMgr\n(FlowController)" {
    class: infra_box
  }

  # Grouping Actors into Logic Tiers
  NetworkTier: "Network Layer" {
    client
    reader
  }
  ProtocolTier: "Protocol Layer" {
    parser
  }
  LogicTier: "Command Handler" {
    handler
  }
  StorageTier: "Persistence Layer" {
    logger
  }
  DistributionTier: "Routing Layer" {
    router
  }
  ControlTier: "Backpressure" {
    bpm
  }

  # --- Interaction Sequence ---
  
  # 1. Ingress Phase
  client -> reader: "TCP PDU: [Len: 4B][Type: 1B][Payload: NB]"
  reader -> parser: "Raw Frame: [Bytes]"
  parser -> handler: "PUBLISH_REQ: {topic: 'orders', qos: 1}"

  # 2. Admission Control & Resource Checking
  handler -> bpm: "ShouldThrottle(clientID: 'prod-01')"
  bpm -> handler: "status: PROCEED (false)"

  # 3. Durability Phase (WAL Implementation)
  handler -> logger: "Append(topic, payload)"
  logger -> logger: "1. Assign Global Offset (Atomic 64-bit)\n2. Calc CRC32 checksum\n3. Serialized LogEntry -> WAL Buffer\n4. Flush/fsync to .log file"
  logger -> handler: "result: {offset: 0x1A2B, status: SUCCESS}"

  # 4. State Synchronization
  handler -> bpm: "UpdateHighWatermark(offset: 0x1A2B)"

  # 5. Distribution Phase
  handler -> router: "FanOut(topic, payload, offset)"
  router -> handler: "subscribers_found: 15"

  # 6. Final Acknowledgment
  handler -> client: "PUBLISH_ACK: {msgID: 0x1A2B, ts: 1700000000}"
}

# --- Annotations & Specifications ---
notes: |md
  ## Engineering Specs & Invariants
  - **Durability:** ACK is prohibited until `LogWriter` returns a valid file offset.
  - **Ordering:** Offsets are monotonically increasing per partition.
  - **Backpressure:** Measured via `inflight_bytes` vs `client_quota` inside `BackpressureMgr`.
  - **Error Handling:** Any `LogWriter` failure results in a `PUB_ERR` and connection reset.
  - **Performance:** Critical path (1->3->6) target latency < 2ms (SSD persistent).
|
notes.near: bottom-center

# --- Specific Connection Styling ---
# Use index targeting for specific visual highlights
(publish_sequence.handler -> publish_sequence.logger)[0].style: {
  stroke: "#E07B39"
  stroke-width: 3
  animated: true
}

(publish_sequence.handler -> publish_sequence.client)[0].style: {
  stroke: "#388E3C"
  stroke-width: 3
}

(publish_sequence.parser -> publish_sequence.handler)[0].style.stroke-dash: 0

# Visual cues for TCP traffic
(publish_sequence.client -> publish_sequence.reader)[0].style.font-color: "#2E86AB"