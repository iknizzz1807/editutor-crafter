vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    api-blue: "#4A90D9"
    handler-green: "#5BA55B"
    broker-purple: "#8B5CF6"
    dlq-orange: "#F59E0B"
    metrics-teal: "#14B8A6"
    health-red: "#EF4444"
    health-yellow: "#F59E0B"
    health-green: "#22C55E"
  }
}
title: |md
  # Module Architecture: Inspection API Components
| {near: top-center}
direction: right
InspectionAPI: {
  label: "InspectionAPI\n(HTTP Server)"
  style.fill: "${colors.api-blue}"
  style.stroke: "#2563EB"
  style.font-color: white
  style.bold: true
  router: "HTTP Router\n(Mux)" {
    shape: rectangle
    style.fill: "#60A5FA"
  }
  routes: "Routes" {
    shape: rectangle
    style.fill: "#3B82F6"
    style.stroke: "#1D4ED8"
    style.font-color: white
  }
}
handlers: {
  label: "Request Handlers"
  style.fill: "${colors.handler-green}"
  dlq_list: "handleDLQList\nGET /api/v1/dlq/" {
    shape: rectangle
    style.fill: "#4ADE80"
  }
  dlq_messages: "handleDLQMessages\nGET /api/v1/dlq/{topic}/messages" {
    shape: rectangle
    style.fill: "#4ADE80"
  }
  dlq_replay: "handleDLQReplay\nPOST /api/v1/dlq/{topic}/replay" {
    shape: rectangle
    style.fill: "#4ADE80"
  }
  topics_list: "handleTopicsList\nGET /api/v1/topics" {
    shape: rectangle
    style.fill: "#4ADE80"
  }
  topic_metrics: "handleTopicMetrics\nGET /api/v1/topics/{topic}/metrics" {
    shape: rectangle
    style.fill: "#4ADE80"
  }
  metrics: "handleMetrics\nGET /metrics" {
    shape: rectangle
    style.fill: "#4ADE80"
  }
  health: "handleHealth\nGET /health" {
    shape: rectangle
    style.fill: "#4ADE80"
  }
}
broker_interface: {
  label: "BrokerInterface"
  style.fill: "${colors.broker-purple}"
  style.stroke: "#7C3AED"
  style.font-color: white
  style.bold: true
  methods: |md
    - GetDLQTopics()
    - GetTopicDepth(topic)
    - GetConsumerLag(topic)
    - GetDLQDepth(topic)
    - GetDataDir()
    - GetConnectionCount()
    - GetTopics()
    - Publish(topic, payload)
    - GetMetricsCollector()
  | {shape: text}
}
support_components: {
  label: "Support Components"
  style.fill: "#E5E7EB"
  dlq_manager: "DLQManager\n- MoveToDLQ()\n- GetDLQTopicName()\n- IsDLQTopic()" {
    style.fill: "${colors.dlq-orange}"
    style.stroke: "#D97706"
  }
  metrics_collector: "MetricsCollector\n- RecordPublish()\n- RecordConsume()\n- RecordError()\n- GetRates()" {
    style.fill: "${colors.metrics-teal}"
    style.stroke: "#0D9488"
  }
  health_checker: "HealthChecker\n- Check()\n- checkLogWritable()\n- checkConsumerGroups()\n- checkDLQGrowth()\n- checkConsumerLag()" {
    style.fill: "#FBBF24"
    style.stroke: "#D97706"
  }
  log_reader: "LogReader\n- OpenReader()\n- ReadNext()\n- ReadAll()" {
    style.fill: "#9CA3AF"
    style.stroke: "#6B7280"
  }
}
http_client: "HTTP Client\n(Operations, K8s)" {
  shape: person
  style.fill: "#F3F4F6"
}
data_files: {
  label: "Data Files"
  style.fill: "#F9FAFB"
  style.stroke: "#D1D5DB"
  style.stroke-dash: 3
  dlq_logs: "{topic}.dlq.log\n(DLQ Messages)" {
    shape: cylinder
    style.fill: "${colors.dlq-orange}"
    style.fill-pattern: lines
  }
}
# Connections
http_client -> InspectionAPI: "HTTP Request\n:8081"
InspectionAPI.router -> InspectionAPI.routes: "route"
InspectionAPI.routes -> handlers.dlq_list
InspectionAPI.routes -> handlers.dlq_messages
InspectionAPI.routes -> handlers.dlq_replay
InspectionAPI.routes -> handlers.topics_list
InspectionAPI.routes -> handlers.topic_metrics
InspectionAPI.routes -> handlers.metrics
InspectionAPI.routes -> handlers.health
handlers.dlq_list -> broker_interface: "GetDLQTopics()\nGetTopicDepth()"
handlers.dlq_messages -> broker_interface: "GetDataDir()"
handlers.dlq_messages -> log_reader: "readDLQMessages()"
handlers.dlq_replay -> broker_interface: "Publish()"
handlers.dlq_replay -> log_reader: "Read DLQ entries"
handlers.topics_list -> broker_interface: "GetTopics()\nGetTopicDepth()"
handlers.topic_metrics -> broker_interface: "GetConsumerLag()\nGetDLQDepth()"
handlers.topic_metrics -> metrics_collector: "GetRates()"
handlers.metrics -> broker_interface: "GetConnectionCount()"
handlers.metrics -> metrics_collector: "publishCount\nconsumeCount\nerrorCount"
handlers.health -> health_checker: "Check()"
handlers.health -> broker_interface: "Publish() (test)"
log_reader -> data_files.dlq_logs: "Read"
broker_interface <-> support_components.dlq_manager: "uses"
broker_interface <-> support_components.metrics_collector: "uses"
# Annotations
annotation: |md
  **Key Integration Points:**
  - InspectionAPI runs on separate port (default 8081)
  - All handlers use BrokerInterface for decoupling
  - Health endpoint for Kubernetes probes
  - Metrics for monitoring systems
  - DLQ files are standard log files
| {near: bottom-center}