vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Module Architecture: Heartbeat Manager
| {near: top-center}
# Main HeartbeatManager container
HeartbeatManager: {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  # Core data structure
  consumers_map: {
    label: "consumers: map[string]*ConsumerHeartbeat"
    shape: rectangle
    style.fill: "#F0E6FF"
    style.stroke: "#7B4B94"
    style.font: mono
  }
  # Configuration
  config: {
    label: "Configuration"
    shape: rectangle
    style.fill: "#E8F8E8"
    style.stroke: "#4CAF50"
    timeout: {
      label: "timeout: 30s\n(default)"
      shape: text
      style.font: mono
      style.font-size: 12
    }
    onDeath_callback: {
      label: "onDeath: func(consumerID)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.font: mono
    }
  }
  # State variables
  state: {
    label: "State"
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    running: {
      label: "running: bool"
      shape: text
      style.font: mono
      style.font-size: 12
    }
    mu_lock: {
      label: "mu: sync.RWMutex"
      shape: text
      style.font: mono
      style.font-size: 12
    }
    stopCh: {
      label: "stopCh: chan struct{}"
      shape: text
      style.font: mono
      style.font-size: 12
    }
  }
  consumers_map -- config: "configured by"
  consumers_map -- state: "protected by"
}
# ConsumerHeartbeat struct detail
ConsumerHeartbeat: {
  style.fill: "#FFF0F0"
  style.stroke: "#E53935"
  style.stroke-width: 2
  label: "ConsumerHeartbeat"
  fields: {
    shape: rectangle
    style.fill: white
    style.stroke: "#E53935"
    field_list: |md
      ID: string
      LastHeartbeat: time.Time
      ConsumerGroup: string
      IsAlive: bool
    |
  }
}
# Monitor Loop Process
MonitorLoop: {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  style.stroke-dash: 3
  label: "monitorLoop()"
  ticker: {
    label: "ticker: 5s interval"
    shape: circle
    style.fill: "#BBDEFB"
  }
  checkConsumers: {
    label: "checkConsumers()"
    shape: rectangle
    style.fill: white
    style.stroke: "#1976D2"
  }
  ticker -> checkConsumers: "triggers"
}
# Death Detection Logic
DeathDetection: {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  label: "Death Detection Logic"
  condition: {
    label: "now - LastHeartbeat > timeout"
    shape: diamond
    style.fill: "#FFCDD2"
  }
  mark_dead: {
    label: "IsAlive = false"
    shape: rectangle
    style.fill: "#EF9A9A"
  }
  call_callback: {
    label: "go onDeath(consumerID)"
    shape: rectangle
    style.fill: "#FF8A65"
    style.font: mono
  }
  log_death: {
    label: "log death event"
    shape: rectangle
    style.fill: "#FFAB91"
  }
  condition -> mark_dead: "YES"
  mark_dead -> call_callback
  call_callback -> log_death
}
# Consumer Group Integration
ConsumerGroup: {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.stroke-width: 2
  label: "ConsumerGroup (M2)"
  members: {
    label: "members: map[string]*ConsumerState"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.font: mono
  }
  rebalance: {
    label: "rebalance()"
    shape: rectangle
    style.fill: "#A5D6A7"
  }
  Leave: {
    label: "Leave(consumerID)"
    shape: rectangle
    style.fill: "#81C784"
  }
}
# Registration Flow
Registration: {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  label: "Registration Flow"
  Register: {
    label: "Register(consumerID, group)"
    shape: rectangle
    style.fill: "#E1BEE7"
  }
  create_hb: {
    label: "Create ConsumerHeartbeat\nIsAlive=true\nLastHeartbeat=now()"
    shape: rectangle
    style.fill: "#CE93D8"
  }
  Register -> create_hb
}
# Heartbeat Recording
HeartbeatRecord: {
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  label: "Heartbeat Recording"
  RecordHeartbeat: {
    label: "RecordHeartbeat(consumerID)"
    shape: rectangle
    style.fill: "#B2EBF2"
  }
  update: {
    label: "LastHeartbeat = now()\nIsAlive = true"
    shape: rectangle
    style.fill: "#80DEEA"
  }
  RecordHeartbeat -> update
}
# Connections
HeartbeatManager.consumers_map -> ConsumerHeartbeat: "contains"
MonitorLoop.checkConsumers -> DeathDetection.condition: "evaluates"
DeathDetection.call_callback -> ConsumerGroup.Leave: "triggers"
ConsumerGroup.members -> HeartbeatManager.Register: "on Join()"
Registration.create_hb -> HeartbeatManager.consumers_map: "adds to"
# Methods box
Methods: {
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  label: "Public Methods"
  methods_list: |md
    Register(consumerID, group)
    Unregister(consumerID)
    RecordHeartbeat(consumerID)
    SetOnDeath(callback)
    Start()
    Stop()
    GetAliveConsumers() []string
    GetDeadConsumers() []string
    GetConsumerGroup(consumerID) string
  |
}
HeartbeatManager -> Methods: "exposes"
# Legend
Legend: {
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.stroke-dash: 2
  near: bottom-right
  legend_title: {
    label: "Legend"
    shape: text
    style.bold: true
  }
  goroutine: {
    label: "Dashed = Goroutine"
    shape: rectangle
    style.stroke-dash: 3
    style.fill: white
  }
  thread_safe: {
    label: "RWMutex Protected"
    shape: rectangle
    style.fill: "#FFF8E1"
  }
  callback: {
    label: "Async Callback"
    shape: rectangle
    style.fill: "#FFF3E0"
  }
}