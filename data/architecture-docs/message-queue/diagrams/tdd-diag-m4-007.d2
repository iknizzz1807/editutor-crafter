vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Layout: HealthResponse JSON
| {near: top-center}
direction: right
HealthResponse: {
  label: "HealthResponse\n(sizeof = ~200 bytes avg)"
  style.fill: "#E8D5F2"
  style.stroke: "#7B2D8E"
  style.stroke-width: 2
  offset_0x00: {
    label: "Status\noffset: 0x00\nsize: 16 bytes\nenum: HEALTHY | DEGRADED | UNHEALTHY"
    style.fill: "#C8A2C8"
    style.stroke: "#7B2D8E"
  }
  offset_0x10: {
    label: "Timestamp\noffset: 0x10\nsize: 8 bytes\nint64 Unix seconds"
    style.fill: "#B19CD9"
    style.stroke: "#7B2D8E"
  }
  offset_0x18: {
    label: "Checks\noffset: 0x18\nsize: map[string]CheckResult\n4 entries typical"
    style.fill: "#9FE2BF"
    style.stroke: "#228B22"
    style.stroke-dash: 3
  }
  offset_0x20: {
    label: "Warnings\noffset: 0x20\nsize: []string\nvariable length"
    style.fill: "#FFB347"
    style.stroke: "#FF8C00"
    style.stroke-dash: 3
  }
}
CheckResult: {
  label: "CheckResult\n(sizeof = ~64 bytes)"
  style.fill: "#E8D5F2"
  style.stroke: "#7B2D8E"
  style.stroke-width: 2
  cr_status: {
    label: "Status\noffset: 0x00\nsize: 16 bytes\nenum: HEALTHY | DEGRADED | UNHEALTHY"
    style.fill: "#C8A2C8"
    style.stroke: "#7B2D8E"
  }
  cr_message: {
    label: "Message\noffset: 0x10\nsize: string\nhuman-readable"
    style.fill: "#B19CD9"
    style.stroke: "#7B2D8E"
  }
  cr_details: {
    label: "Details\noffset: 0x20\nsize: interface{}\nmap[string]any"
    style.fill: "#9FE2BF"
    style.stroke: "#228B22"
    style.stroke-dash: 3
  }
}
HealthResponse.offset_0x18 -> CheckResult: "4 entries\n(log_writable,\nconsumer_groups,\ndlq_growth,\nconsumer_lag)" {
  style.stroke: "#228B22"
  style.stroke-dash: 5
}
legend: {
  near: bottom-center
  label: ""
  header_field: {
    label: "Header/Primary\nfields"
    style.fill: "#C8A2C8"
  }
  data_field: {
    label: "Data/Timestamp\nfields"
    style.fill: "#B19CD9"
  }
  nested_field: {
    label: "Nested/Map\nstructures"
    style.fill: "#9FE2BF"
    style.stroke-dash: 3
  }
  variable_field: {
    label: "Variable-length\narrays"
    style.fill: "#FFB347"
    style.stroke-dash: 3
  }
}
annotation: |md
  **JSON Wire Format:**
  json
  {
    "status": "HEALTHY",
    "timestamp": 1709635200,
    "checks": {
      "log_writable": {"status": "HEALTHY", "message": "Log is writable"},
      "consumer_groups": {"status": "HEALTHY", "message": "2/2 groups active"},
      "dlq_growth": {"status": "DEGRADED", "message": "DLQ exceeds threshold"},
      "consumer_lag": {"status": "HEALTHY", "message": "Lag within range"}
    },
    "warnings": ["DLQ exceeding threshold: orders.dlq (1500)"]
  }
  
| {near: bottom-center}