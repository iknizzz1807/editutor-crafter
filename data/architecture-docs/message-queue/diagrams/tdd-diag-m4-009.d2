vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Data Flow: DLQ Replay to Original Topic
  Messages receive NEW offsets when replayed
| {near: top-center}
direction: right
dlq_log: DLQ Log File {
  shape: cylinder
  style.fill: "#E8D5B7"
  style.stroke: "#8B7355"
  entry_1: Entry @ Offset 0 {
    shape: rectangle
    style.fill: "#F5E6D3"
    style.stroke: "#8B7355"
  }
  entry_2: Entry @ Offset 1 {
    shape: rectangle
    style.fill: "#F5E6D3"
    style.stroke: "#8B7355"
  }
  entry_3: Entry @ Offset 2 {
    shape: rectangle
    style.fill: "#F5E6D3"
    style.stroke: "#8B7355"
  }
}
api_handler: Replay Handler {
  shape: rectangle
  style.fill: "#B5D8EB"
  style.stroke: "#2E6A8A"
  read: Read Entry
  parse: Parse JSON
  wrap: Wrap Metadata
  publish: Publish
}
dlq_msg: DLQMessage JSON {
  shape: class
  style.fill: "#D4E5F7"
  style.stroke: "#2E6A8A"
  original_topic: string
  original_offset: uint64
  original_payload: base64
  retry_count: int
  last_failure_reason: string
  failed_at: int64
  consumer_id: string
  is_replayed: bool
  replay_count: int
}
replay_payload: Replay Payload {
  shape: class
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  original_payload: bytes
  replayed: true
  original_offset: uint64
  dlq_offset: uint64
  replay_count: int
  replayed_at: int64
}
original_topic_log: Original Topic Log {
  shape: cylinder
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  existing_1: ...existing entries... {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#81C784"
    style.stroke-dash: 3
  }
  new_entry: NEW Entry @ Offset N+1 {
    shape: rectangle
    style.fill: "#A5D6A7"
    style.stroke: "#2E7D32"
    style.bold: true
  }
}
offset_counter: Offset Counter {
  shape: hexagon
  style.fill: "#FFE0B2"
  style.stroke: "#E65100"
  counter: "atomic.AddUint64\n→ NEW Offset"
}
dlq_log.entry_2 -> api_handler.read: "1. Read DLQ entry\n(by offset or all)" {
  style.stroke: "#8B7355"
  style.stroke-width: 2
}
api_handler.read -> api_handler.parse: "2. Read bytes"
api_handler.parse -> dlq_msg: "3. Deserialize\nJSON to struct" {
  style.stroke-dash: 3
}
dlq_msg -> api_handler.wrap: "4. Extract\nOriginalPayload"
api_handler.wrap -> replay_payload: "5. Create replay\npayload with metadata"
replay_payload -> api_handler.publish: "6. Ready to\npublish"
api_handler.publish -> offset_counter: "7. Assign NEW\nmonotonic offset" {
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.animated: true
}
offset_counter -> original_topic_log.new_entry: "8. Append with\nNEW offset N+1" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.animated: true
}
legend: {
  near: bottom-right
  style.fill: transparent
  style.stroke: "#666"
  style.stroke-dash: 3
  note: |md
    **Key Insight**: Replay is NOT undo
    - Original message stays in DLQ
    - NEW message created with NEW offset
    - Ordering NOT preserved
    - Consumers see it as brand new
  |
}
annotation: |md
  
  ReplayRequest:
  {
    "dlq_offsets": [1, 2, 3],  // specific
    "all": true                // or all
  }
  ReplayResponse:
  {
    "original_topic": "orders",
    "replay_count": 1,
    "new_offsets": [42],       // NEW!
    "errors": []
  }
  
| {near: bottom-center}