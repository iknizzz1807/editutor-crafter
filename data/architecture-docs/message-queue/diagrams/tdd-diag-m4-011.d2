vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Consumer Heartbeat Death Detection
  ## Automatic Rebalance Trigger Flow
| {near: top-center}
direction: right
# Initial State: Consumer Alive
initial_state: "T=0: Consumer Joins Group" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  consumer_a: "Consumer A\n(IsAlive: true)" {
    shape: person
    style.fill: "#81C784"
  }
  heartbeat_mgr: "HeartbeatManager\nLastHeartbeat: T=0" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  group: "ConsumerGroup\nMembers: [A, B]" {
    shape: rectangle
    style.fill: "#A5D6A7"
    partitions_a: "Partitions [0-7]"
    partitions_b: "Partitions [8-15]"
  }
  consumer_a -> heartbeat_mgr: "Register()\nLastHeartbeat=T=0"
  heartbeat_mgr -> group: "Consumer tracked"
}
# Monitoring Phase
monitoring: "T=5s, 10s, 15s, 20s, 25s: Monitor Loop Runs" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  monitor_loop: "monitorLoop()\n(5s interval)" {
    shape: diamond
    style.fill: "#FFE0B2"
  }
  check: "now - LastHeartbeat\n> timeout?" {
    shape: diamond
    style.fill: "#FFCC80"
  }
  skip: "Skip\n(alive)" {
    shape: text
    style.fill: transparent
  }
  monitor_loop -> check: "check each consumer"
  check -> skip: "NO"
}
# Timeout Detection
timeout: "T=30s: Timeout Exceeded (no heartbeat)" {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  time_check: "now - LastHeartbeat\n= 30s > 25s timeout" {
    shape: diamond
    style.fill: "#FFCDD2"
  }
  mark_dead: "Set IsAlive = false\nLog: 'marked DEAD'" {
    shape: rectangle
    style.fill: "#EF9A9A"
    style.bold: true
    style.font-color: "#B71C1C"
  }
  callback_trigger: "onDeath callback\ntriggered" {
    shape: rectangle
    style.fill: "#E57373"
  }
  time_check -> mark_dead: "YES"
  mark_dead -> callback_trigger: "async"
}
# Rebalancing
rebalance: "Rebalance Triggered" {
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  leave_op: "group.Leave(consumerID)" {
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  in_flight: "Mark in-flight messages\nVisibleAfter = now()" {
    shape: rectangle
    style.fill: "#90CAF9"
  }
  reassign: "Rebalance partitions\nacross remaining members" {
    shape: rectangle
    style.fill: "#64B5F6"
  }
  new_assignment: "Consumer B\ngets ALL 16 partitions" {
    shape: person
    style.fill: "#42A5F5"
  }
  callback_trigger -> leave_op: ""
  leave_op -> in_flight: ""
  in_flight -> reassign: ""
  reassign -> new_assignment: ""
}
# Final State
final_state: "T=35s: Recovery Complete" {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  dead_consumer: "Consumer A\n(IsAlive: false)" {
    shape: person
    style.fill: "#D1C4E9"
    style.stroke-dash: 3
    style.opacity: 0.6
  }
  alive_consumer: "Consumer B\n(IsAlive: true)" {
    shape: person
    style.fill: "#B39DDB"
  }
  recovered_msgs: "In-flight messages\nredelivered to B" {
    shape: rectangle
    style.fill: "#9575CD"
  }
  dead_consumer -> recovered_msgs: "messages\nrecovered"
  alive_consumer <- recovered_msgs: "redelivery"
}
# Flow connections
initial_state -> monitoring: "monitoring starts"
monitoring -> timeout: "timeout detected"
timeout -> rebalance: "rebalance chain"
rebalance -> final_state: "recovery"
# Timeline annotation
timeline: |md
  **Timeline:**
  - T=0: Consumer registers, LastHeartbeat set
  - T=5,10,15,20,25s: Monitor checks (passes)
  - T=30s: Timeout exceeded, marked DEAD
  - T=31s: Rebalance triggered
  - T=35s: Recovery complete
| {near: bottom-center}
# Key metrics
metrics: {
  near: center-right
  header: "Configuration" {
    shape: rectangle
    style.fill: "#CFD8DC"
    style.bold: true
  }
  timeout_val: "HeartbeatTimeout: 25s\n(3 missed @ 10s interval)" {
    shape: rectangle
    style.fill: "#ECEFF1"
  }
  scan_val: "Scan Interval: 5s\n(monitorLoop ticker)" {
    shape: rectangle
    style.fill: "#ECEFF1"
  }
  detection_val: "Max Detection Time: 30s\n(timeout + scan interval)" {
    shape: rectangle
    style.fill: "#ECEFF1"
  }
}