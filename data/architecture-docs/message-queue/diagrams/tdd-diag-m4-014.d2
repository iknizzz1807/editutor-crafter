vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 20
  }
}

title: |md
  # Health Check State Machine
  ### Component State Aggregation Logic & HTTP Mapping
| {near: top-center}

# Component Check States
# We use rectangle with border-radius to represent UML States
log_writable: "Log Writable Check" {
  style: {
    border-radius: 12
    stroke-dash: 0
    fill: "#f8f9fa"
  }
  
  passing: "PASSING" {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      border-radius: 8
    }
  }
  failing: "FAILING\n\nlog write error\n→ UNHEALTHY overall" {
    style: {
      fill: "#FF6B6B"
      stroke: "#8B0000"
      bold: true
      border-radius: 8
    }
  }
  passing -> failing: "write test fails"
  failing -> passing: "write succeeds\n(recovery)"
}

consumer_groups: "Consumer Groups Check" {
  style: {
    border-radius: 12
    stroke-dash: 0
    fill: "#f8f9fa"
  }

  passing: "PASSING\n\n≥1 active consumer" {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      border-radius: 8
    }
  }
  warning: "WARNING\n\nno consumer groups" {
    style: {
      fill: "#FFE4B5"
      stroke: "#FF8C00"
      border-radius: 8
    }
  }
  failing: "FAILING\n\nall groups empty\n→ UNHEALTHY overall" {
    style: {
      fill: "#FF6B6B"
      stroke: "#8B0000"
      bold: true
      border-radius: 8
    }
  }
  passing -> warning: "groups unregistered"
  warning -> passing: "consumer joins"
  warning -> failing: "all consumers leave"
  failing -> warning: "consumer rejoins"
}

dlq_growth: "DLQ Growth Check" {
  style: {
    border-radius: 12
    stroke-dash: 0
    fill: "#f8f9fa"
  }

  passing: "PASSING\n\ndepth ≤ 1000" {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      border-radius: 8
    }
  }
  warning: "WARNING\n\ndepth > 1000\n→ DEGRADED overall" {
    style: {
      fill: "#FFE4B5"
      stroke: "#FF8C00"
      bold: true
      border-radius: 8
    }
  }
  passing -> warning: "depth > 1000"
  warning -> passing: "depth ≤ 1000\n(cleanup/replay)"
}

consumer_lag: "Consumer Lag Check" {
  style: {
    border-radius: 12
    stroke-dash: 0
    fill: "#f8f9fa"
  }

  passing: "PASSING\n\nlag ≤ 10,000" {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      border-radius: 8
    }
  }
  warning: "WARNING\n\nlag > 10,000\n→ DEGRADED overall" {
    style: {
      fill: "#FFE4B5"
      stroke: "#FF8C00"
      bold: true
      border-radius: 8
    }
  }
  passing -> warning: "lag > 10,000"
  warning -> passing: "lag ≤ 10,000\n(consumers catch up)"
}

# Overall Health Aggregation Logic
aggregation: "Overall Health Aggregation" {
  style: {
    border-radius: 12
    stroke-width: 2
    fill: "#ffffff"
    double-border: true
  }

  healthy: "HEALTHY\n\nall checks PASSING" {
    style: {
      fill: "#32CD32"
      stroke: "#006400"
      font-color: white
      bold: true
      border-radius: 8
    }
  }
  degraded: "DEGRADED\n\n≥1 WARNING, no FAILING\n(HTTP 200, alert ops)" {
    style: {
      fill: "#FFD700"
      stroke: "#B8860B"
      bold: true
      border-radius: 8
    }
  }
  unhealthy: "UNHEALTHY\n\n≥1 FAILING\n(HTTP 503, restart pod)" {
    style: {
      fill: "#DC143C"
      stroke: "#8B0000"
      font-color: white
      bold: true
      border-radius: 8
    }
  }
  
  healthy -> degraded: "any WARNING"
  degraded -> healthy: "all PASSING"
  degraded -> unhealthy: "any FAILING"
  unhealthy -> degraded: "all FAILING→WARNING"
}

# Dependency Mappings (Influence lines)
log_writable.failing -> aggregation.unhealthy: "Critical Failure" {
  style: {
    stroke-dash: 5
    stroke: "#8B0000"
    stroke-width: 2
  }
}
consumer_groups.warning -> aggregation.degraded: "Non-Critical" {
  style: {
    stroke-dash: 5
    stroke: "#FF8C00"
  }
}
consumer_groups.failing -> aggregation.unhealthy: "Critical Failure" {
  style: {
    stroke-dash: 5
    stroke: "#8B0000"
    stroke-width: 2
  }
}
dlq_growth.warning -> aggregation.degraded: "Degraded Performance" {
  style: {
    stroke-dash: 5
    stroke: "#FF8C00"
  }
}
consumer_lag.warning -> aggregation.degraded: "Degraded Performance" {
  style: {
    stroke-dash: 5
    stroke: "#FF8C00"
  }
}

# Operational Legend
legend: ||md
  ## Thresholds & Metrics
  | Check | WARNING Trigger | FAILING Trigger |
  |-------|-----------------|-----------------|
  | **Log Writable** | N/A | Disk I/O Write Failure |
  | **Consumer Groups** | Count == 0 | Count == 0 AND required |
  | **DLQ Growth** | > 1,000 items | N/A |
  | **Consumer Lag** | > 10,000 ms | N/A |

  ## HTTP Status Code Mapping
  - **HEALTHY**   : `200 OK`
  - **DEGRADED**  : `200 OK` (Triggers PagerDuty)
  - **UNHEALTHY** : `503 Service Unavailable` (K8s Restart)
|| {
  near: bottom-center
}

# Entry Point Marker
initial: "●" {
  shape: circle
  style.fill: "#4A90D9"
  style.stroke: "#2C3E50"
  width: 24
  height: 24
}

initial -> log_writable.passing
initial -> consumer_groups.passing
initial -> dlq_growth.passing
initial -> consumer_lag.passing