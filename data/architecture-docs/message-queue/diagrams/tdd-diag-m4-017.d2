vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # Sequence: Consumer Death Detection and Rebalance
  **Scenario:** Consumer crash → heartbeat timeout → automatic rebalancing
| {
  near: top-center
  shape: text
}

# Sequence Container
rebalance_sequence: {
  shape: sequence_diagram

  # Participants
  consumer1: Consumer 1 {
    shape: person
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  consumer2: Consumer 2 {
    shape: person
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  hb_manager: HeartbeatManager {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  server: Server {
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
  }
  group: ConsumerGroup {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  assignment: PartitionAssignment {
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
  }

  # --- Normal Phase ---
  normal_ops: {
    label: Steady State
    consumer1.active -> hb_manager: HEARTBEAT (Seq: 442)
    hb_manager -> consumer1.active: HEARTBEAT_ACK
  }

  # --- Failure Phase ---
  failure_event: {
    label: Consumer Failure
    
    # Note attached to consumer1
    consumer1."❌ CRASH: OS SIGKILL or Hardware Failure\nLast Heartbeat: T+0s"
    
    hb_manager.monitor -> hb_manager.monitor: "Interval Scan (5s)"
    hb_manager.monitor -> hb_manager.monitor: "LastHB(C1) > 30s? TRUE" {
      style.stroke: "#D32F2F"
      style.font-color: "#D32F2F"
    }
  }

  # --- Detection & Rebalance Phase ---
  rebalance_trigger: {
    label: Detection & Rebalance
    
    hb_manager.monitor -> server.handler: "onDeath(consumer1)" {
      style.stroke: "#D32F2F"
      style.stroke-width: 2
    }
    
    server.handler -> group.proc: "Leave(consumer1)"
    
    group.proc -> group.proc: "Mark in-flight offsets as visible"
    group.proc -> group.proc: "Purge C1 from MembershipMap"
    
    group.proc -> assignment.calc: "Rebalance Triggered"
    
    assignment.calc -> assignment.calc: "Redistribute Partitions [0..15]"
    assignment.calc -> assignment.calc: "Algorithm: Round Robin (Available Members)"
    
    assignment.calc -> consumer2.update: "NEW_ASSIGNMENT: Partitions [0-15]" {
      style.stroke: "#388E3C"
      style.bold: true
    }
    
    consumer2.update."Partitions Active: [0-15]\nAssignment Generation: 2"
  }
}

# Annotations (Positioned at constants for ELK compatibility)
timeline: |md
  ### ⏱️ Rebalance Timeline
  - **T+0s:** Consumer 1 crashes.
  - **T+30s:** Heartbeat timeout threshold reached.
  - **T+35s:** Monitor loop identifies dead consumer.
  - **T+36s:** Server initiates group rebalance.
  - **T+37s:** Consumer 2 assumes full ownership.
| {
  near: bottom-left
  shape: text
  style.font-size: 12
}

legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 4
  
  l1: Normal Heartbeat {
    style.stroke: "#1976D2"
  }
  l2: Failure Path {
    style.stroke: "#D32F2F"
    style.stroke-width: 2
  }
  l3: Rebalance Ops {
    style.stroke: "#388E3C"
  }
}

# Global Styles
***.style.font-size: 14
(*** -> ***)[*]: {
  style.font-size: 12
}