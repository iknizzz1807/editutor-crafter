vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Data Flow: Complete DLQ Lifecycle
  Normal → Failure → Retry → Poison → DLQ → Inspection → Fix → Replay → Success
| {near: top-center}
# Legend
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  normal_msg: "Normal Message" {shape: rectangle; style.fill: "#d4edda"; style.stroke: "#28a745"}
  failed_msg: "Failed Attempt" {shape: rectangle; style.fill: "#fff3cd"; style.stroke: "#ffc107"}
  poison_msg: "Poison Message" {shape: rectangle; style.fill: "#f8d7da"; style.stroke: "#dc3545"}
  dlq_msg: "DLQ Entry" {shape: rectangle; style.fill: "#e2e3e5"; style.stroke: "#6c757d"}
  success_msg: "Successful" {shape: rectangle; style.fill: "#cce5ff"; style.stroke: "#007bff"}
}
# Phase 1: Normal Message Flow
phase1_normal: "Phase 1: Normal Flow" {
  style.fill: "#d4edda"
  style.stroke: "#28a745"
  style.stroke-width: 2
  producer: "Producer" {
    shape: rectangle
    style.fill: white
  }
  broker: "Message Broker" {
    shape: rectangle
    style.fill: white
    pending_queue: "Pending\nQueue" {shape: cylinder}
    topic_log: "Topic Log\n{topic}.log" {shape: cylinder}
  }
  consumer_group: "Consumer Group\n'orders-default'" {
    shape: rectangle
    style.fill: white
    consumer1: "Consumer-1" {shape: person}
    consumer2: "Consumer-2" {shape: person}
  }
  producer -> broker.pending_queue: "1. PUBLISH\npayload" {style.stroke: "#28a745"; style.animated: true}
  broker.pending_queue -> broker.topic_log: "2. Persist\noffset=100" {style.stroke: "#28a745"}
  broker.topic_log -> consumer_group.consumer1: "3. Deliver\nmsgID=100" {style.stroke: "#28a745"; style.animated: true}
}
# Phase 2: Failure & Retry Cycle
phase2_retry: "Phase 2: Failure & Retry Cycle" {
  style.fill: "#fff3cd"
  style.stroke: "#ffc107"
  style.stroke-width: 2
  retry_tracker: "Retry Counter\nmsgID:100 → count" {
    shape: rectangle
    style.fill: white
    count0: "attempt 1: count=0"
    count1: "attempt 2: count=1"
    count2: "attempt 3: count=2"
    count3: "attempt 4: count=3"
    count4: "attempt 5: count=4"
    count5: "attempt 6: count=5\n≥ MaxRetries!"
    count0 -> count1 -> count2 -> count3 -> count4 -> count5 {style.stroke: "#ffc107"}
  }
  in_flight: "In-Flight\nTracker" {
    shape: rectangle
    style.fill: white
  }
  visibility_timer: "Visibility\nTimeout\n(30s)" {
    shape: circle
    style.fill: "#fff3cd"
  }
  failed_consumer: "Consumer\n(processing fails)" {
    shape: person
    style.fill: "#f8d7da"
  }
  error_handler: "Error Handler\n'processing failed:\ninvalid JSON'" {
    shape: rectangle
    style.fill: "#f8d7da"
  }
  in_flight -> failed_consumer: "deliver" {style.stroke: "#ffc107"}
  failed_consumer -> error_handler: "NACK\nreason='invalid JSON'" {style.stroke: "#dc3545"; style.animated: true}
  error_handler -> retry_tracker: "increment\ncounter" {style.stroke: "#ffc107"}
  error_handler -> in_flight: "re-queue for\nredelivery" {style.stroke-dash: 3; style.stroke: "#ffc107"}
  visibility_timer -> in_flight: "timeout →\nauto-redeliver" {style.stroke-dash: 3; style.stroke: "#6c757d"}
}
# Phase 3: Poison Detection & DLQ Move
phase3_poison: "Phase 3: Poison Detection → DLQ" {
  style.fill: "#f8d7da"
  style.stroke: "#dc3545"
  style.stroke-width: 2
  poison_check: "Poison Check\ncount(5) ≥ MaxRetries(5)" {
    shape: diamond
    style.fill: "#f8d7da"
  }
  dlq_manager: "DLQManager\n.MoveToDLQ()" {
    shape: rectangle
    style.fill: "#e2e3e5"
    style.stroke: "#6c757d"
    style.bold: true
  }
  dlq_message: "DLQMessage JSON" {
    shape: class
    style.fill: "#f8f9fa"
    original_topic: "original_topic: 'orders'"
    original_offset: "original_offset: 100"
    original_payload: "original_payload: base64..."
    retry_count: "retry_count: 5"
    failure_reason: "last_failure_reason: 'invalid JSON'"
    failed_at: "failed_at: 1709635200000000000"
    consumer_id: "consumer_id: 'consumer-1'"
    is_replayed: "is_replayed: false"
  }
  dlq_topic: "DLQ Topic\n'orders.dlq'" {
    shape: cylinder
    style.fill: "#e2e3e5"
    style.stroke: "#6c757d"
  }
  poison_check -> dlq_manager: "YES\n→ Move to DLQ" {style.stroke: "#dc3545"; style.bold: true}
  dlq_manager -> dlq_message: "wrap with\nmetadata" {style.stroke: "#6c757d"}
  dlq_message -> dlq_topic: "append JSON\noffset=0" {style.stroke: "#6c757d"}
}
# Phase 4: Operator Inspection
phase4_inspect: "Phase 4: Operator Inspection" {
  style.fill: "#e2e3e5"
  style.stroke: "#6c757d"
  style.stroke-width: 2
  api_server: "Inspection API\n:8081" {
    shape: rectangle
    style.fill: white
    style.stroke: "#007bff"
  }
  dlq_list: "GET /api/v1/dlq/" {
    shape: rectangle
    style.fill: "#cce5ff"
  }
  dlq_messages: "GET /api/v1/dlq/orders/messages\n?offset=0&limit=50" {
    shape: rectangle
    style.fill: "#cce5ff"
  }
  operator: "Operator" {
    shape: person
    style.fill: "#cce5ff"
  }
  analysis: "Root Cause Analysis\n\n✓ Schema changed\n✓ Consumer expects v2\n✓ Message is v1 format\n\n→ Deploy schema fix" {
    shape: rectangle
    style.fill: "#d4edda"
    style.stroke: "#28a745"
  }
  operator -> api_server: "inspect DLQ" {style.stroke: "#007bff"}
  api_server -> dlq_list: "list topics" {style.stroke: "#007bff"}
  dlq_list -> dlq_messages: "get messages" {style.stroke: "#007bff"}
  dlq_messages -> operator: "JSON response\nwith payload,\nreason, timestamps" {style.stroke: "#007bff"}
  operator -> analysis: "identify\nroot cause" {style.stroke: "#28a745"}
}
# Phase 5: Replay & Success
phase5_replay: "Phase 5: Replay & Success" {
  style.fill: "#cce5ff"
  style.stroke: "#007bff"
  style.stroke-width: 2
  replay_request: "POST /api/v1/dlq/orders/replay\n\n{'dlq_offsets': [0]}" {
    shape: rectangle
    style.fill: "#cce5ff"
  }
  replay_handler: "Replay Handler" {
    shape: rectangle
    style.fill: white
    parse: "Parse DLQMessage"
    wrap: "Wrap with replay metadata"
    publish: "Publish as NEW message"
  }
  replayed_payload: "Replayed Payload JSON\n\n{\n 'original_payload': [...],\n 'replayed': true,\n 'original_offset': 100,\n 'dlq_offset': 0,\n 'replay_count': 1,\n 'replayed_at': ...\n}" {
    shape: class
    style.fill: "#d4edda"
  }
  original_topic: "Original Topic\n'orders'" {
    shape: cylinder
    style.fill: "#d4edda"
  }
  fixed_consumer: "Consumer\n(schema fixed)" {
    shape: person
    style.fill: "#d4edda"
  }
  success_ack: "ACK\n(msg processed)" {
    shape: rectangle
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.bold: true
  }
  replay_request -> replay_handler: "trigger replay" {style.stroke: "#007bff"; style.animated: true}
  replay_handler -> replayed_payload: "construct" {style.stroke: "#28a745"}
  replayed_payload -> original_topic: "NEW offset=500\n(not 100!)" {style.stroke: "#28a745"; style.bold: true}
  original_topic -> fixed_consumer: "deliver" {style.stroke: "#28a745"; style.animated: true}
  fixed_consumer -> success_ack: "process OK" {style.stroke: "#28a745"}
}
# Flow connections between phases
phase1_normal.consumer_group -> phase2_retry.failed_consumer: "message\nfails" {style.stroke: "#dc3545"; style.stroke-dash: 5}
phase2_retry.retry_tracker -> phase3_poison.poison_check: "max retries\nexceeded" {style.stroke: "#dc3545"; style.bold: true}
phase3_poison.dlq_topic -> phase4_inspect.api_server: "inspect" {style.stroke: "#6c757d"; style.stroke-dash: 3}
phase4_inspect.analysis -> phase5_replay.replay_request: "fix deployed,\nreplay message" {style.stroke: "#28a745"; style.animated: true}