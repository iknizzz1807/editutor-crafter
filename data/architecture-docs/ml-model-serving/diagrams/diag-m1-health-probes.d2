direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# ROOT LEVEL NODES
# -----------------------------------------------------------------------------
title: {
  label: |md
    # Readiness vs Liveness Probes
    *Kubernetes health checking for ML model servers*
  |
  style.stroke: transparent
  style.fill: transparent
}

# -----------------------------------------------------------------------------
# ROW 1: STATE EVOLUTION
# -----------------------------------------------------------------------------
probes: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  liveness_sm: {
    label: "Liveness Probe (Process Lifecycle)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    
    alive: {
      shape: circle
      label: "Process\nAlive"
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
    }
    dead: {
      shape: circle
      label: "Process\nDead"
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
    }
    alive -> dead: "Crash / OOM" {
      style.stroke: "#C62828"
      style.stroke-dash: 4
    }
  }

  readiness_sm: {
    label: "Readiness Probe (Model Lifecycle)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    
    loading: {
      shape: circle
      label: "Loading"
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
    }
    warming: {
      shape: circle
      label: "Warming"
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
    }
    ready: {
      shape: circle
      label: "Ready"
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
    }
    failed: {
      shape: circle
      label: "Failed"
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
    }

    loading -> warming: "model_load"
    warming -> ready: "inference_warmup"
    loading -> failed: "io_error"
    warming -> failed: "cuda_error"
  }
}

# -----------------------------------------------------------------------------
# ROW 2: DATA STRUCTURE / LOGIC
# -----------------------------------------------------------------------------
logic: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  liveness_table: {
    shape: sql_table
    label: "Probe Type: Liveness"
    f1: "Endpoint | /health/liveness"
    f2: "200 OK | Process is running"
    f3: "Failure | Kubernetes Restarts Pod"
    sz: "Goal: Recovery from deadlocks"
  }

  readiness_table: {
    shape: sql_table
    label: "Probe Type: Readiness"
    f1: "Endpoint | /health/readiness"
    f2: "200 OK | Send Traffic"
    f3: "503 Error | Remove from Service"
    sz: "Goal: Avoid dropping requests"
  }
}

# -----------------------------------------------------------------------------
# ROW 3: TIMELINE
# -----------------------------------------------------------------------------
timeline_container: {
  label: "Startup Lifecycle Timeline"
  style.fill: "#F5F5F5"
  
  timeline: {
    direction: right
    t0: "T=0s (Init)" { shape: diamond; style.fill: "#E1BEE7" }
    t1: "T=20s (Loaded)" { shape: diamond; style.fill: "#E1BEE7" }
    t2: "T=25s (Ready)" { shape: diamond; style.fill: "#C8E6C9" }

    t0 -> t1: "Model IO"
    t1 -> t2: "Warmup"
  }

  status: {
    direction: right
    p1: {
      label: "|md **Loading Phase**\nLiveness: 200\nReadiness: 503| "
      style.fill: "#FFF9C4"
    }
    p2: {
      label: "|md **Warming Phase**\nLiveness: 200\nReadiness: 503| "
      style.fill: "#FFF9C4"
    }
    p3: {
      label: "|md **Ready Phase**\nLiveness: 200\nReadiness: 200| "
      style.fill: "#C8E6C9"
    }
  }
}

# -----------------------------------------------------------------------------
# ROW 4: IMPLEMENTATION CODE
# -----------------------------------------------------------------------------
impl: {
  label: "Implementation (FastAPI / Python)"
  direction: right
  style.fill: "#FAFAFA"
  
  liveness_code: {
    label: "Liveness Check"
    code: |'python
      @app.get("/health/liveness")
      async def liveness_check():
          # Simple check if event loop is running
          return {"status": "alive"}
    '|
  }

  readiness_code: {
    label: "Readiness Check"
    code: |'python
      @app.get("/health/readiness")
      async def readiness_check():
          # Check if model weight loading is complete
          if not model_manager.is_ready():
              raise HTTPException(status_code=503)
          return {"status": "ready"}
    '|
  }
}

# -----------------------------------------------------------------------------
# GLOBAL ANNOTATION
# -----------------------------------------------------------------------------
key_insight: {
  label: |md
    **Key Insight**: A pod can be *alive* but not *ready*. 
    During model loading, the process runs (liveness=200) but cannot serve (readiness=503).
    Kubernetes routes traffic only when both probes pass.
  |
  style.fill: "#E1BEE7"
  style.stroke: "#7B1FA2"
}

# -----------------------------------------------------------------------------
# LAYOUT CONSTRAINTS (Rule G: Root-level only)
# -----------------------------------------------------------------------------
key_insight.near: bottom-center

# Connections between rows for flow
probes -> logic: "defines"
logic -> timeline_container: "results in"
timeline_container -> impl: "implements"