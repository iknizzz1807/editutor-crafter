direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Backpressure and Queue Depth Management
  Request flow through queue with depth-based rejection
| {near: top-center}
row_incoming: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  client_pool: {
    direction: down
    label: "Incoming Requests"
    client1: {
      label: "Client 1"
      shape: person
      style.fill: "#E8F4FD"
    }
    client2: {
      label: "Client 2"
      shape: person
      style.fill: "#E8F4FD"
    }
    client3: {
      label: "Client N"
      shape: person
      style.fill: "#E8F4FD"
      style.stroke-dash: 3
    }
  }
}
row_queue: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  queue_section: {
    direction: down
    label: "Request Queue (asyncio.Queue)"
    depth_check: {
      label: "Depth Check"
      shape: diamond
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
      width: 140
    }
    request_queue: {
      label: "Request Queue"
      shape: queue
      style.fill: "#D4EDDA"
      style.stroke: "#155724"
      width: 200
    }
    queue_metrics: {
      shape: sql_table
      label: "Queue State (RequestQueue)"
      f0: "queue.qsize() | int | current depth"
      f1: "max_depth | int | 1000 (config)"
      f2: "total_enqueued | int | counter"
      f3: "total_rejected | int | counter"
      sz: "Rejection threshold: qsize >= max_depth"
    }
  }
}
row_decision: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  accept_path: {
    direction: down
    label: "Accept Path"
    accept_node: {
      label: "ACCEPT\nHTTP 200"
      shape: oval
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      style.bold: true
      style.font-size: 18
    }
    enqueue_op: {
      label: "await queue.put(request)"
      shape: rectangle
      style.fill: "#CCE5FF"
      style.stroke: "#004085"
    }
    batcher: {
      label: "Batcher\nProcesses"
      shape: rectangle
      style.fill: "#E2E3E5"
      style.stroke: "#383D41"
    }
  }
  reject_path: {
    direction: down
    label: "Reject Path"
    reject_node: {
      label: "REJECT\nHTTP 503"
      shape: oval
      style.fill: "#F8D7DA"
      style.stroke: "#DC3545"
      style.bold: true
      style.font-size: 18
    }
    error_response: {
      label: |md
        json
        {
          "error": "Service overloaded",
          "retry_after": "1s"
        }
        
      |
      shape: rectangle
      style.fill: "#F8D7DA"
      style.stroke: "#DC3545"
      width: 180
    }
    client_retry: {
      label: "Client Backoff\n+ Retry"
      shape: rectangle
      style.fill: "#FFF3CD"
      style.stroke: "#856404"
    }
  }
}
row_timing: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timing_box: {
    label: "Request Lifecycle Timing"
    shape: rectangle
    style.fill: "#F8F9FA"
    style.stroke: "#6C757D"
    width: 450
    timing_code: |'python
      async def enqueue(request: BatchRequest) -> bool:
          # O(1) depth check
          if self.queue.qsize() >= self.max_depth:
              self.total_rejected += 1
              request.set_error(RuntimeError(
                  f"Queue at capacity ({self.max_depth})"
              ))
              return False  # ~0.1ms
          await self.queue.put(request)
          self.total_enqueued += 1
          return True  # ~0.5ms (async)
    '|
  }
}
row_metrics: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  metrics_box: {
    direction: down
    label: "Prometheus Metrics"
    metrics_output: {
      shape: rectangle
      style.fill: "#FFF"
      style.stroke: "#6C757D"
      style.font: mono
      width: 400
      metrics_text: |'
        queue_inference_depth 847
        queue_inference_max_depth 1000
        queue_inference_total_enqueued 15234
        queue_inference_total_rejected 127
        queue_inference_rejection_rate 0.0083
      '|
    }
  }
}
# Connections
client_pool.client1 -> queue_section.depth_check: "request" {
  style.stroke: "#004085"
  style.animated: true
}
client_pool.client2 -> queue_section.depth_check: "request" {
  style.stroke: "#004085"
  style.animated: true
}
queue_section.depth_check -> accept_path.accept_node: "qsize < max_depth" {
  label: "depth OK\n(~0.1ms)"
  style.stroke: "#28A745"
  style.stroke-width: 3
}
queue_section.depth_check -> reject_path.reject_node: "qsize >= max_depth" {
  label: "at capacity"
  style.stroke: "#DC3545"
  style.stroke-dash: 4
  style.stroke-width: 2
}
accept_path.accept_node -> accept_path.enqueue_op: "proceed" {
  style.stroke: "#28A745"
}
accept_path.enqueue_op -> queue_section.request_queue: "add to tail" {
  style.stroke: "#155724"
  style.animated: true
}
queue_section.request_queue -> accept_path.batcher: "batch loop\ndrains queue" {
  style.stroke: "#383D41"
}
reject_path.reject_node -> reject_path.error_response: "immediate\nresponse" {
  style.stroke: "#DC3545"
}
reject_path.error_response -> reject_path.client_retry: "client\nhandles" {
  style.stroke: "#856404"
  style.stroke-dash: 3
}
# Legend
legend: {
  near: bottom-right
  label: "Legend"
  accept: "Accept (200)" {
    shape: oval
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
  }
  reject: "Reject (503)" {
    shape: oval
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
  }
  animated_flow: "Active request flow" {
    shape: text
    style.font-color: "#004085"
  }
}