direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Dynamic Batch Formation Timeline
  Requests arrive asynchronously, batch forms at timeout
| {near: top-center}
timeline_container: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  time_axis: {
    shape: rectangle
    style.fill: transparent
    style.stroke: "#666"
    style.stroke-width: 2
    width: 800
    height: 40
    t0_label: "t=0ms" {
      style.fill: transparent
      style.stroke: transparent
      style.font-size: 14
    }
    t10_label: "t=10ms" {
      style.fill: transparent
      style.stroke: transparent
      style.font-size: 14
    }
    t30_label: "t=30ms" {
      style.fill: transparent
      style.stroke: transparent
      style.font-size: 14
    }
    t45_label: "t=45ms" {
      style.fill: transparent
      style.stroke: transparent
      style.font-size: 14
    }
    t50_label: "t=50ms\n(timeout)" {
      style.fill: transparent
      style.stroke: transparent
      style.font-size: 14
      style.font-color: "#c0392b"
      style.bold: true
    }
    t90_label: "t=90ms" {
      style.fill: transparent
      style.stroke: transparent
      style.font-size: 14
    }
  }
  requests_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    req1: "Request 1\narrives t=0" {
      shape: rectangle
      width: 120
      style.fill: "#3498db"
      style.stroke: "#2980b9"
      style.font-color: white
      style.stroke-width: 2
    }
    req2: "Request 2\narrives t=10ms" {
      shape: rectangle
      width: 120
      style.fill: "#2ecc71"
      style.stroke: "#27ae60"
      style.font-color: white
      style.stroke-width: 2
    }
    req3: "Request 3\narrives t=30ms" {
      shape: rectangle
      width: 120
      style.fill: "#9b59b6"
      style.stroke: "#8e44ad"
      style.font-color: white
      style.stroke-width: 2
    }
    req4: "Request 4\narrives t=45ms" {
      shape: rectangle
      width: 120
      style.fill: "#e67e22"
      style.stroke: "#d35400"
      style.font-color: white
      style.stroke-width: 2
    }
  }
  wait_times_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    wait1: "Wait: 50ms\n(queued longest)" {
      shape: rectangle
      width: 120
      style.fill: "#ecf0f1"
      style.stroke: "#bdc3c7"
      style.font-color: "#7f8c8d"
    }
    wait2: "Wait: 40ms" {
      shape: rectangle
      width: 120
      style.fill: "#ecf0f1"
      style.stroke: "#bdc3c7"
      style.font-color: "#7f8c8d"
    }
    wait3: "Wait: 20ms" {
      shape: rectangle
      width: 120
      style.fill: "#ecf0f1"
      style.stroke: "#bdc3c7"
      style.font-color: "#7f8c8d"
    }
    wait4: "Wait: 5ms\n(queued shortest)" {
      shape: rectangle
      width: 120
      style.fill: "#ecf0f1"
      style.stroke: "#bdc3c7"
      style.font-color: "#7f8c8d"
    }
  }
}
batch_container: {
  label: "Batch Processing (t=50ms → t=90ms)"
  width: 700
  style.fill: "#fef9e7"
  style.stroke: "#f1c40f"
  style.stroke-width: 3
  style.stroke-dash: 5
  batch_content: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    batch_formation: {
      label: "Batch Formation\n──────────────\n4 requests grouped\nmax_batch_size=32\ntimeout=50ms"
      shape: rectangle
      width: 180
      style.fill: "#f1c40f"
      style.stroke: "#d4ac0d"
      style.font-color: "#7d6608"
    }
    arrow1: {
      shape: text
      label: "→"
      style.font-size: 28
      style.fill: transparent
      style.stroke: transparent
    }
    inference: {
      label: "GPU Inference\n──────────────\nSingle kernel launch\nProcesses all 4 together\nLatency: 40ms"
      shape: rectangle
      width: 180
      style.fill: "#e74c3c"
      style.stroke: "#c0392b"
      style.font-color: white
    }
    arrow2: {
      shape: text
      label: "→"
      style.font-size: 28
      style.fill: transparent
      style.stroke: transparent
    }
    response_split: {
      label: "Response Routing\n──────────────\nResults split by index\nEach request gets\nits prediction"
      shape: rectangle
      width: 180
      style.fill: "#1abc9c"
      style.stroke: "#16a085"
      style.font-color: white
    }
  }
}
requests_row.req1 -> wait_times_row.wait1
requests_row.req2 -> wait_times_row.wait2
requests_row.req3 -> wait_times_row.wait3
requests_row.req4 -> wait_times_row.wait4
wait_times_row.wait1 -> batch_container.batch_content.batch_formation: "batch"
wait_times_row.wait2 -> batch_container.batch_content.batch_formation: "batch"
wait_times_row.wait3 -> batch_container.batch_content.batch_formation: "batch"
wait_times_row.wait4 -> batch_container.batch_content.batch_formation: "batch"
metrics_box: {
  label: "Latency Breakdown"
  shape: rectangle
  width: 500
  style.fill: "#2c3e50"
  style.stroke: "#1a252f"
  style.font-color: white
  metrics_content: |md
    **Request 1:** Total = 50ms wait + 40ms inference = **90ms**
    **Request 2:** Total = 40ms wait + 40ms inference = **80ms**
    **Request 3:** Total = 20ms wait + 40ms inference = **60ms**
    **Request 4:** Total = 5ms wait + 40ms inference = **45ms**
    **Throughput gain:** 4 requests / 90ms = **44 req/s**
    vs sequential: 4 × 40ms = 160ms = **25 req/s** → **1.76× improvement**
  |
}
legend: {
  label: "Key Insight"
  shape: callout
  width: 350
  style.fill: "#ebf5fb"
  style.stroke: "#3498db"
  legend_text: |md
    The **50ms timeout** bounds worst-case latency.
    First request waits longest but still gets
    response within acceptable SLA window.
    GPU processes all 4 in **single batch**,
    amortizing kernel launch overhead.
  |
}
legend.near: bottom-right
batch_container -> metrics_box: "produces"