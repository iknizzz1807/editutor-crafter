direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    low_util: "#ff6b6b"
    high_util: "#51cf66"
    sequential_bar: "#ff8787"
    batched_bar: "#69db7c"
    sequential_color: "#ffe3e3"
    batched_color: "#d3f9d8"
    sequential_border: "#fa5252"
    batched_border: "#40c057"
  }
}
title: {
  near: top-center
  shape: text
  label: "GPU Utilization: Sequential vs Batched Inference"
  style: {
    font-size: 28
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  before: "BEFORE: Sequential Inference" {
    direction: down
    style: {
      fill: ${colors.sequential_color}
      stroke: ${colors.sequential_border}
      stroke-width: 2
      border-radius: 8
    }
    gpu_title_before: {
      label: "GPU Core Utilization Heatmap"
      style: {
        bold: true
        font-size: 16
        underline: true
      }
    }
    heatmap_before: "" {
      direction: right
      grid-columns: 8
      grid-rows: 8
      grid-gap: 2
      style.fill: transparent
      style.stroke: transparent
      # Row 1 - mostly idle (1 active core)
      c1_1.style.fill: ${colors.high_util}
      c1_2.style.fill: ${colors.low_util}
      c1_3.style.fill: ${colors.low_util}
      c1_4.style.fill: ${colors.low_util}
      c1_5.style.fill: ${colors.low_util}
      c1_6.style.fill: ${colors.low_util}
      c1_7.style.fill: ${colors.low_util}
      c1_8.style.fill: ${colors.low_util}
      # Row 2 - idle
      c2_1.style.fill: ${colors.low_util}
      c2_2.style.fill: ${colors.low_util}
      c2_3.style.fill: ${colors.low_util}
      c2_4.style.fill: ${colors.low_util}
      c2_5.style.fill: ${colors.low_util}
      c2_6.style.fill: ${colors.low_util}
      c2_7.style.fill: ${colors.low_util}
      c2_8.style.fill: ${colors.low_util}
      # Row 3 - idle
      c3_1.style.fill: ${colors.low_util}
      c3_2.style.fill: ${colors.low_util}
      c3_3.style.fill: ${colors.low_util}
      c3_4.style.fill: ${colors.low_util}
      c3_5.style.fill: ${colors.low_util}
      c3_6.style.fill: ${colors.low_util}
      c3_7.style.fill: ${colors.low_util}
      c3_8.style.fill: ${colors.low_util}
      # Row 4 - mostly idle
      c4_1.style.fill: ${colors.low_util}
      c4_2.style.fill: ${colors.low_util}
      c4_3.style.fill: ${colors.low_util}
      c4_4.style.fill: ${colors.high_util}
      c4_5.style.fill: ${colors.low_util}
      c4_6.style.fill: ${colors.low_util}
      c4_7.style.fill: ${colors.low_util}
      c4_8.style.fill: ${colors.low_util}
      # Row 5 - idle
      c5_1.style.fill: ${colors.low_util}
      c5_2.style.fill: ${colors.low_util}
      c5_3.style.fill: ${colors.low_util}
      c5_4.style.fill: ${colors.low_util}
      c5_5.style.fill: ${colors.low_util}
      c5_6.style.fill: ${colors.low_util}
      c5_7.style.fill: ${colors.low_util}
      c5_8.style.fill: ${colors.low_util}
      # Row 6 - idle
      c6_1.style.fill: ${colors.low_util}
      c6_2.style.fill: ${colors.low_util}
      c6_3.style.fill: ${colors.low_util}
      c6_4.style.fill: ${colors.low_util}
      c6_5.style.fill: ${colors.low_util}
      c6_6.style.fill: ${colors.low_util}
      c6_7.style.fill: ${colors.low_util}
      c6_8.style.fill: ${colors.low_util}
      # Row 7 - mostly idle
      c7_1.style.fill: ${colors.low_util}
      c7_2.style.fill: ${colors.low_util}
      c7_3.style.fill: ${colors.low_util}
      c7_4.style.fill: ${colors.low_util}
      c7_5.style.fill: ${colors.high_util}
      c7_6.style.fill: ${colors.low_util}
      c7_7.style.fill: ${colors.low_util}
      c7_8.style.fill: ${colors.low_util}
      # Row 8 - idle
      c8_1.style.fill: ${colors.low_util}
      c8_2.style.fill: ${colors.low_util}
      c8_3.style.fill: ${colors.low_util}
      c8_4.style.fill: ${colors.low_util}
      c8_5.style.fill: ${colors.low_util}
      c8_6.style.fill: ${colors.low_util}
      c8_7.style.fill: ${colors.low_util}
      c8_8.style.fill: ${colors.low_util}
    }
    util_label_before: {
      label: "~5% Utilization"
      style: {
        font-size: 20
        bold: true
        font-color: ${colors.sequential_border}
      }
    }
    problem_box: {
      label: "Problem: 95% of GPU cores sit idle\nwhile waiting for kernel launches"
      style: {
        fill: "#fff5f5"
        stroke: ${colors.sequential_border}
        stroke-dash: 3
        font-size: 12
      }
    }
  }
  arrow: {
    label: "→"
    style: {
      font-size: 48
      bold: true
    }
  }
  after: "AFTER: Batched Inference" {
    direction: down
    style: {
      fill: ${colors.batched_color}
      stroke: ${colors.batched_border}
      stroke-width: 2
      border-radius: 8
    }
    gpu_title_after: {
      label: "GPU Core Utilization Heatmap"
      style: {
        bold: true
        font-size: 16
        underline: true
      }
    }
    heatmap_after: "" {
      direction: right
      grid-columns: 8
      grid-rows: 8
      grid-gap: 2
      style.fill: transparent
      style.stroke: transparent
      # Row 1 - mostly active
      c1_1.style.fill: ${colors.high_util}
      c1_2.style.fill: ${colors.high_util}
      c1_3.style.fill: ${colors.high_util}
      c1_4.style.fill: ${colors.high_util}
      c1_5.style.fill: ${colors.high_util}
      c1_6.style.fill: ${colors.high_util}
      c1_7.style.fill: ${colors.high_util}
      c1_8.style.fill: ${colors.high_util}
      # Row 2 - active
      c2_1.style.fill: ${colors.high_util}
      c2_2.style.fill: ${colors.high_util}
      c2_3.style.fill: ${colors.high_util}
      c2_4.style.fill: ${colors.high_util}
      c2_5.style.fill: ${colors.high_util}
      c2_6.style.fill: ${colors.high_util}
      c2_7.style.fill: ${colors.high_util}
      c2_8.style.fill: ${colors.high_util}
      # Row 3 - active
      c3_1.style.fill: ${colors.high_util}
      c3_2.style.fill: ${colors.high_util}
      c3_3.style.fill: ${colors.high_util}
      c3_4.style.fill: ${colors.high_util}
      c3_5.style.fill: ${colors.high_util}
      c3_6.style.fill: ${colors.high_util}
      c3_7.style.fill: ${colors.high_util}
      c3_8.style.fill: ${colors.high_util}
      # Row 4 - active
      c4_1.style.fill: ${colors.high_util}
      c4_2.style.fill: ${colors.high_util}
      c4_3.style.fill: ${colors.high_util}
      c4_4.style.fill: ${colors.high_util}
      c4_5.style.fill: ${colors.high_util}
      c4_6.style.fill: ${colors.high_util}
      c4_7.style.fill: ${colors.high_util}
      c4_8.style.fill: ${colors.high_util}
      # Row 5 - active
      c5_1.style.fill: ${colors.high_util}
      c5_2.style.fill: ${colors.high_util}
      c5_3.style.fill: ${colors.high_util}
      c5_4.style.fill: ${colors.high_util}
      c5_5.style.fill: ${colors.high_util}
      c5_6.style.fill: ${colors.high_util}
      c5_7.style.fill: ${colors.high_util}
      c5_8.style.fill: ${colors.high_util}
      # Row 6 - active
      c6_1.style.fill: ${colors.high_util}
      c6_2.style.fill: ${colors.high_util}
      c6_3.style.fill: ${colors.high_util}
      c6_4.style.fill: ${colors.high_util}
      c6_5.style.fill: ${colors.high_util}
      c6_6.style.fill: ${colors.high_util}
      c6_7.style.fill: ${colors.high_util}
      c6_8.style.fill: ${colors.high_util}
      # Row 7 - active
      c7_1.style.fill: ${colors.high_util}
      c7_2.style.fill: ${colors.high_util}
      c7_3.style.fill: ${colors.high_util}
      c7_4.style.fill: ${colors.high_util}
      c7_5.style.fill: ${colors.high_util}
      c7_6.style.fill: ${colors.high_util}
      c7_7.style.fill: ${colors.high_util}
      c7_8.style.fill: ${colors.high_util}
      # Row 8 - mostly active
      c8_1.style.fill: ${colors.high_util}
      c8_2.style.fill: ${colors.high_util}
      c8_3.style.fill: ${colors.high_util}
      c8_4.style.fill: ${colors.high_util}
      c8_5.style.fill: ${colors.high_util}
      c8_6.style.fill: ${colors.high_util}
      c8_7.style.fill: ${colors.high_util}
      c8_8.style.fill: ${colors.high_util}
    }
    util_label_after: {
      label: "~80% Utilization"
      style: {
        font-size: 20
        bold: true
        font-color: ${colors.batched_border}
      }
    }
    solution_box: {
      label: "Solution: Single kernel launch\nprocesses 32 requests in parallel"
      style: {
        fill: "#ebfbee"
        stroke: ${colors.batched_border}
        font-size: 12
      }
    }
  }
}
legend_row: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  legend_idle: {
    label: "■ Idle Core"
    style: {
      font-color: ${colors.low_util}
      fill: transparent
      stroke: transparent
    }
  }
  legend_active: {
    label: "■ Active Core"
    style: {
      font-color: ${colors.high_util}
      fill: transparent
      stroke: transparent
    }
  }
}
throughput_section: "Throughput Comparison" {
  direction: right
  style: {
    fill: "#f8f9fa"
    stroke: "#dee2e6"
    border-radius: 8
  }
  bar_chart: "" {
    direction: right
    style: {
      fill: transparent
      stroke: transparent
    }
    sequential_bar_container: {
      direction: down
      style: {
        fill: transparent
        stroke: transparent
      }
      seq_label: {
        label: "Sequential"
        style: { bold: true }
      }
      seq_bar: {
        width: 100
        height: 150
        style: {
          fill: ${colors.sequential_bar}
          stroke: ${colors.sequential_border}
        }
      }
      seq_value: {
        label: "100 RPS"
        style: {
          bold: true
          font-size: 18
          font-color: ${colors.sequential_border}
        }
      }
    }
    batched_bar_container: {
      direction: down
      style: {
        fill: transparent
        stroke: transparent
      }
      batch_label: {
        label: "Batched"
        style: { bold: true }
      }
      batch_bar: {
        width: 100
        height: 400
        style: {
          fill: ${colors.batched_bar}
          stroke: ${colors.batched_border}
        }
      }
      batch_value: {
        label: "800 RPS"
        style: {
          bold: true
          font-size: 18
          font-color: ${colors.batched_border}
        }
      }
    }
  }
  metrics_summary: {
    direction: down
    label: "Key Metrics"
    style: {
      fill: white
      stroke: "#dee2e6"
      border-radius: 4
    }
    throughput_gain: {
      label: "8x Throughput Improvement"
      style: {
        font-size: 20
        bold: true
        font-color: ${colors.batched_border}
      }
    }
    latency_note: {
      label: "Latency: 50ms → 62ms (batch=32)"
      style: { font-size: 14 }
    }
    batch_note: {
      label: "Optimal batch size: 32 requests"
      style: { font-size: 14 }
    }
    kernel_note: {
      label: "1 kernel launch vs 32 sequential"
      style: { font-size: 14 }
    }
  }
}
why_section: "Why Batching Works" {
  direction: down
  style: {
    fill: "#f1f3f4"
    stroke: "#dadce0"
    border-radius: 8
  }
  explanation: {
    label: "GPU Architecture Benefit"
    style: {
      bold: true
      underline: true
    }
  }
  detail: {
    label: "• 6,912 CUDA cores (NVIDIA A100)\n• Single request uses ~5% of cores\n• Batch of 32 fills ~80% of cores\n• Matrix multiply: O(n³) compute, O(n²) memory\n• Larger batches = better arithmetic intensity"
    style: { font-size: 12 }
  }
}