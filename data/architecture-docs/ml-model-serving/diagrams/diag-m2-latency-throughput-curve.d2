direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Latency-Throughput Pareto Frontier
  **Batch Size Tradeoffs in Dynamic Request Batching**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  graph: {
    label: "Batch Size vs Latency & Throughput"
    width: 600
    y_axis: {
      label: "Latency (ms) / Throughput (req/s)"
      shape: text
      style.font-size: 12
    }
    x_axis: {
      label: "Batch Size"
      shape: text
    }
    origin: {
      shape: circle
      width: 10
      style.fill: black
    }
    bs1: {
      label: "1"
      shape: text
    }
    bs4: {
      label: "4"
      shape: text
    }
    bs8: {
      label: "8"
      shape: text
    }
    bs16: {
      label: "16"
      shape: text
    }
    bs32: {
      label: "32"
      shape: text
    }
    bs64: {
      label: "64"
      shape: text
    }
    bs128: {
      label: "128"
      shape: text
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    label: "Legend"
    width: 250
    latency_line: {
      label: "Latency (ms)"
      shape: rectangle
      style.fill: "#DC2626"
      style.stroke: "#DC2626"
    }
    throughput_line: {
      label: "Throughput (req/s)"
      shape: rectangle
      style.fill: "#2563EB"
      style.stroke: "#2563EB"
    }
    optimal_zone: {
      label: "Optimal Operating Region"
      shape: rectangle
      style.fill: "#22C55E"
      style.stroke: "#22C55E"
      style.opacity: 0.3
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  data_table: {
    shape: sql_table
    label: "Batch Size Performance Metrics"
    col1: "Batch | Latency | Throughput | GPU Util"
    row1: "1    | 12ms   | 83 rps    | 8%"
    row2: "4    | 18ms   | 222 rps   | 35%"
    row3: "8    | 24ms   | 333 rps   | 52%"
    row4: "16   | 38ms   | 421 rps   | 68%"
    row5: "32   | 62ms   | 516 rps   | 81%"
    row6: "64   | 108ms  | 592 rps   | 89%"
    row7: "128  | 195ms  | 656 rps   | 94%"
  }
  optimal_box: {
    label: "Optimal Region (Batch 16-32)"
    width: 280
    desc: |md
      **Sweet Spot Characteristics:**
      - Latency: 38-62ms (acceptable p99)
      - Throughput: 421-516 rps (6x baseline)
      - GPU Utilization: 68-81%
      - Memory headroom for activations
    |
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeout_impact: {
    label: "Timeout Impact on Batching"
    width: 400
    scenario1: {
      label: "Short Timeout (10ms)"
      shape: rectangle
      style.fill: "#FEF3C7"
      effect: |md
        - Smaller average batches
        - Lower throughput
        - Bounded latency (good for SLA)
      |
    }
    scenario2: {
      label: "Long Timeout (100ms)"
      shape: rectangle
      style.fill: "#DBEAFE"
      effect: |md
        - Larger average batches
        - Higher throughput
        - Unbounded latency (risk SLA violation)
      |
    }
    scenario3: {
      label: "Optimal Timeout (50ms)"
      shape: rectangle
      style.fill: "#D1FAE5"
      effect: |md
        - Balanced batch formation
        - Good throughput (400+ rps)
        - Bounded latency (p99 < 100ms)
      |
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tradeoff_curve: {
    shape: sql_table
    label: "Pareto Frontier Analysis"
    col1: "Region | Batch | Tradeoff"
    low_batch: "Low Batch (1-4)  | 1-4   | Low latency, poor GPU utilization"
    optimal: "Optimal (16-32)   | 16-32 | Best latency-throughput balance"
    high_batch: "High Batch (64+)  | 64+   | Max throughput, latency explodes"
    diminishing: "Diminishing Returns | 128+ | Throughput gains minimal, latency 2x"
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  key_insights: {
    label: "Key Insights"
    width: 600
    insight1: {
      label: "1. Throughput increases sublinearly"
      shape: rectangle
      style.fill: "#DBEAFE"
    }
    insight2: {
      label: "2. Latency increases superlinearly"
      shape: rectangle
      style.fill: "#FEE2E2"
    }
    insight3: {
      label: "3. Optimal batch = max throughput before latency cliff"
      shape: rectangle
      style.fill: "#D1FAE5"
    }
    insight4: {
      label: "4. Timeout bounds worst-case latency"
      shape: rectangle
      style.fill: "#FEF3C7"
    }
  }
}
arrow_note: {
  label: |md
    **Latency-Throughput Tradeoff:**
    - You cannot maximize both simultaneously
    - Every gain in throughput costs some latency
    - Choose operating point based on SLA requirements
  |
  shape: rectangle
  style.fill: "#F3F4F6"
  width: 350
  near: bottom-center
}