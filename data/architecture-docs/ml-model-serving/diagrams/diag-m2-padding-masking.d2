direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Variable-Length Input Padding and Attention Masking
| {near: top-center}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_section: {
    direction: down
    label: "BEFORE: Raw Variable-Length Sequences"
    seq_a: {
      label: "Request A (5 tokens)"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      width: 280
      tokens_a: |md
        `[T1] [T2] [T3] [T4] [T5]`
        Length: 5
      |
    }
    seq_b: {
      label: "Request B (8 tokens)"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      width: 280
      tokens_b: |md
        `[T1] [T2] [T3] [T4] [T5] [T6] [T7] [T8]`
        Length: 8 (max)
      |
    }
    seq_c: {
      label: "Request C (3 tokens)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.stroke-width: 2
      width: 280
      tokens_c: |md
        `[T1] [T2] [T3]`
        Length: 3
      |
    }
    problem_note: {
      label: "Problem: Cannot stack\nDifferent shapes: (5,), (8,), (3,)"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      style.stroke-dash: 3
      width: 260
    }
  }
}
row_arrow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arrow_container: {
    direction: down
    label: ""
    pad_op: {
      label: "PAD TO MAX LENGTH (8)"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#9C27B0"
      style.stroke-width: 3
      width: 200
      pad_desc: |md
        1. Find max length = 8
        2. Pad shorter sequences
        3. Create attention mask
      |
    }
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after_section: {
    direction: down
    label: "AFTER: Padded Batch (3, 8)"
    padded_matrix: {
      label: "Padded Input IDs Tensor"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      width: 340
      matrix_content: |md
        
        Request A: [T1] [T2] [T3] [T4] [T5] [PAD] [PAD] [PAD]
        Request B: [T1] [T2] [T3] [T4] [T5] [T6] [T7] [T8]
        Request C: [T1] [T2] [T3] [PAD] [PAD] [PAD] [PAD] [PAD]
        
        Shape: (3, 8)
        PAD = 0 (padding token)
      |
    }
    mask_matrix: {
      label: "Attention Mask Tensor"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
      width: 340
      mask_content: |md
        
        Request A: [ 1 ] [ 1 ] [ 1 ] [ 1 ] [ 1 ] [ 0 ] [ 0 ] [ 0 ]
        Request B: [ 1 ] [ 1 ] [ 1 ] [ 1 ] [ 1 ] [ 1 ] [ 1 ] [ 1 ]
        Request C: [ 1 ] [ 1 ] [ 1 ] [ 0 ] [ 0 ] [ 0 ] [ 0 ] [ 0 ]
        
        Shape: (3, 8)
        1 = real token, 0 = padding
      |
    }
    legend: {
      label: "Legend"
      shape: rectangle
      style.fill: "#FAFAFA"
      style.stroke: "#9E9E9E"
      width: 340
      legend_content: |md
        🟢 **Real Token**: mask=1, attends to others
        ⚪ **PAD Token**: mask=0, ignored by attention
        **Padding Overhead**: (8-5) + (8-8) + (8-3) = 8 tokens
        **Efficiency**: 16 real / 24 total = 66.7%
      |
    }
  }
}
row_transformer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  transformer_section: {
    direction: down
    label: "How Attention Uses Mask"
    attention_viz: {
      label: "Self-Attention with Mask"
      shape: rectangle
      style.fill: "#FFF8E1"
      style.stroke: "#FFC107"
      style.stroke-width: 2
      width: 360
      attention_content: |'python
        # Attention scores before softmax
        scores = Q @ K.T / sqrt(d_k)
        # Apply mask: -inf where mask=0
        scores = scores.masked_fill(mask == 0, -inf)
        # Softmax: -inf becomes 0.0
        weights = softmax(scores)  # sum=1.0
      '|
    }
    attention_effect: {
      label: "Effect on Request A"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 360
      effect_content: |md
        Token 1 can attend to: T1, T2, T3, T4, T5
        Token 1 cannot attend to: PAD, PAD, PAD
        Weights: [0.20, 0.20, 0.20, 0.20, 0.20, 0.00, 0.00, 0.00]
      |
    }
  }
}
row_before -> row_arrow: "Detect lengths"
row_arrow -> row_after: "Pad + Mask"
row_after -> row_transformer: "Feed to model"