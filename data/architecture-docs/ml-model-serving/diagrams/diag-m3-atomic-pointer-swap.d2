direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Atomic Pointer Swap Mechanism
  Memory layout showing safe version transition
| {near: top-center}
# State containers
states_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: "BEFORE SWAP" {
    direction: down
    style.fill: "#E8F4E8"
    style.stroke: "#2D7D2D"
    pointer_old: {
      label: "active_ptr"
      shape: rectangle
      width: 140
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
    v1_box: "v1.0.0 (OLD)" {
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
      model_v1: {
        shape: class
        label: "Model v1.0.0"
        -weights: "Tensor[512MB]"
        -in_flight: "int = 3"
        +predict(): "Tensor"
      }
    }
    pointer_old -> v1_box: {
      style.stroke: "#4CAF50"
      style.stroke-width: 3
      target-arrowhead.shape: triangle
      target-arrowhead.style.filled: true
    }
    v2_box: "v2.0.0 (NEW)" {
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      model_v2: {
        shape: class
        label: "Model v2.0.0"
        -weights: "Tensor[512MB]"
        -in_flight: "int = 0"
        +predict(): "Tensor"
      }
    }
    note_loading: |md
      New model loaded
      in memory, warmed
      up, ready to swap
    | {
      near: v2_box
    }
  }
  swap_op: "ATOMIC SWAP" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    cpu_box: {
      label: "CPU Instruction"
      width: 200
      code: |'c
        // Atomic compare-and-swap
        old = active_ptr;
        active_ptr = new_ptr;
        // Single instruction
        // No intermediate state
      '|
    }
    lock_icon: {
      label: "🔒 LOCK HELD"
      shape: diamond
      style.fill: "#C62828"
      style.font-color: white
    }
    guarantee_box: {
      label: "Guarantees"
      width: 200
      g1: "✓ All-or-nothing swap"
      g2: "✓ Memory barrier"
      g3: "✓ No torn reads"
      g4: "✓ O(1) operation"
    }
  }
  after: "AFTER SWAP" {
    direction: down
    style.fill: "#E8F4E8"
    style.stroke: "#2D7D2D"
    pointer_new: {
      label: "active_ptr"
      shape: rectangle
      width: 140
      style.fill: "#2196F3"
      style.font-color: white
      style.bold: true
    }
    v1_box_after: "v1.0.0 (DRAINING)" {
      style.fill: "#FFECB3"
      style.stroke: "#FF8F00"
      style.stroke-dash: 3
      model_v1_after: {
        shape: class
        label: "Model v1.0.0"
        -weights: "Tensor[512MB]"
        -in_flight: "int = 3"
        status: "DRAINING"
      }
    }
    v2_box_after: "v2.0.0 (ACTIVE)" {
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      model_v2_after: {
        shape: class
        label: "Model v2.0.0"
        -weights: "Tensor[512MB]"
        -in_flight: "int = 0"
        status: "ACTIVE"
      }
    }
    pointer_new -> v2_box_after: {
      style.stroke: "#2196F3"
      style.stroke-width: 3
      target-arrowhead.shape: triangle
      target-arrowhead.style.filled: true
    }
    draining_note: |md
      Old model kept in
      memory until in_flight
      reaches zero
    | {
      near: v1_box_after
    }
  }
}
# Flow arrows
before.pointer_old -> swap_op.cpu_box: "swap()"
swap_op.cpu_box -> after.pointer_new: "complete"
# Reader visibility section
readers_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  reader_timeline: "What Readers See" {
    direction: down
    reader_a: {
      label: "Reader A"
      width: 180
      code: |'c
        ptr = active_ptr;
        // Sees v1.0.0
        result = ptr->predict(in);
      '|
    }
    reader_b: {
      label: "Reader B (during swap)"
      width: 180
      code: |'c
        ptr = active_ptr;
        // Sees v1.0.0 OR v2.0.0
        // Never partial/corrupted
        result = ptr->predict(in);
      '|
    }
    reader_c: {
      label: "Reader C (after swap)"
      width: 180
      code: |'c
        ptr = active_ptr;
        // Sees v2.0.0
        result = ptr->predict(in);
      '|
    }
  }
  invariant_box: "INVARIANT" {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    width: 300
    inv_title: "Every reader sees a consistent model"
    inv_list: |md
      **NEVER POSSIBLE:**
      - Half-initialized model
      - Corrupted pointer
      - Mixed v1/v2 state
      **ALWAYS GUARANTEED:**
      - Valid model reference
      - Complete model weights
      - Callable predict() method
    |
  }
}
# Memory layout detail
memory_section: "Memory Layout Detail" {
  direction: right
  memory_before: "Before Swap" {
    direction: down
    mem_addr: {
      shape: sql_table
      label: "GPU Memory (8GB)"
      addr_0x00: "0x0000 | Model v1 weights | 512 MB"
      addr_0x80: "0x8000 | Model v1 activations | 256 MB"
      addr_0xA0: "0xA000 | Model v2 weights | 512 MB"
      addr_0xC0: "0xC000 | Model v2 activations | 256 MB"
      addr_0xE0: "0xE000 | FREE | 6.5 GB"
      note: "active_ptr = 0x0000"
    }
  }
  memory_after: "After Swap" {
    direction: down
    mem_addr_after: {
      shape: sql_table
      label: "GPU Memory (8GB)"
      addr_0x00: "0x0000 | Model v1 (draining) | 512 MB"
      addr_0x80: "0x8000 | Model v1 activations | 256 MB"
      addr_0xA0: "0xA000 | Model v2 (active) | 512 MB"
      addr_0xC0: "0xC000 | Model v2 activations | 256 MB"
      addr_0xE0: "0xE000 | FREE | 6.5 GB"
      note: "active_ptr = 0xA000"
    }
  }
}
# Timing diagram
timing_section: "Timing: Atomic Swap Sequence" {
  direction: right
  timing: {
    shape: sequence_diagram
    RequestHandler
    AtomicPointer
    Memory
    RequestHandler -> AtomicPointer: get()
    AtomicPointer -> Memory: read active_ptr
    Memory -> AtomicPointer: 0x0000 (v1)
    AtomicPointer -> RequestHandler: Model v1
    swap_op: "SWAP OPERATION" {
      RequestHandler -> AtomicPointer: swap(v2)
      AtomicPointer -> AtomicPointer: acquire lock
      AtomicPointer -> Memory: write active_ptr = 0xA000
      AtomicPointer -> AtomicPointer: release lock
      AtomicPointer -> RequestHandler: success
    }
    RequestHandler -> AtomicPointer: get()
    AtomicPointer -> Memory: read active_ptr
    Memory -> AtomicPointer: 0xA000 (v2)
    AtomicPointer -> RequestHandler: Model v2
  }
}
# Legend
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  l_title: "Legend"
  l_active: "→ ACTIVE pointer (green/blue)"
  l_draining: "Dashed border = DRAINING"
  l_atomic: "Single instruction = atomic"
  l_guarantee: "Readers never see partial state"
}