direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Budget During Hot Swap
| {near: top-center}
memory_chart: {
  grid-columns: 3
  grid-gap: 30
  phase1_label: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 180
    label: "**PHASE 1**\nNormal Operation"
  }
  phase2_label: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 180
    label: "**PHASE 2**\nDuring Swap\n*(Peak Memory)*"
  }
  phase3_label: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 180
    label: "**PHASE 3**\nAfter Swap"
  }
  phase1_bar: "" {
    direction: up
    style.stroke: transparent
    style.fill: transparent
    width: 180
    activations1: "Activations\n~1.6 GB" {
      style.fill: "#6B8E23"
      style.stroke: "#556B2F"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 80
    }
    model1: "Model v1.0\n~1.0 GB" {
      style.fill: "#4682B4"
      style.stroke: "#2F4F4F"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 50
    }
    os1: "OS + Context\n~0.4 GB" {
      style.fill: "#A9A9A9"
      style.stroke: "#696969"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 20
    }
  }
  phase2_bar: "" {
    direction: up
    style.stroke: transparent
    style.fill: transparent
    width: 180
    activations2: "Activations\n~1.6 GB" {
      style.fill: "#6B8E23"
      style.stroke: "#556B2F"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 80
    }
    newmodel2: "Model v2.0\n~1.0 GB" {
      style.fill: "#9370DB"
      style.stroke: "#4B0082"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 50
    }
    oldmodel2: "Model v1.0\n~1.0 GB" {
      style.fill: "#4682B4"
      style.stroke: "#2F4F4F"
      style.stroke-width: 2
      style.stroke-dash: 4
      style.font-color: white
      width: 160
      height: 50
    }
    os2: "OS + Context\n~0.4 GB" {
      style.fill: "#A9A9A9"
      style.stroke: "#696969"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 20
    }
  }
  phase3_bar: "" {
    direction: up
    style.stroke: transparent
    style.fill: transparent
    width: 180
    activations3: "Activations\n~1.6 GB" {
      style.fill: "#6B8E23"
      style.stroke: "#556B2F"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 80
    }
    model3: "Model v2.0\n~1.0 GB" {
      style.fill: "#9370DB"
      style.stroke: "#4B0082"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 50
    }
    os3: "OS + Context\n~0.4 GB" {
      style.fill: "#A9A9A9"
      style.stroke: "#696969"
      style.stroke-width: 2
      style.font-color: white
      width: 160
      height: 20
    }
  }
  usage1: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 180
    label: "**Total: 3.0 GB**\n*(75% of 4 GB GPU)*"
  }
  usage2: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 180
    label: "**Total: 4.0 GB**\n*(100% of 4 GB GPU)*\n\n⚠️ **PEAK**"
    style.font-color: "#B22222"
  }
  usage3: "" {
    style.stroke: transparent
    style.fill: transparent
    width: 180
    label: "**Total: 3.0 GB**\n*(75% of 4 GB GPU)*"
  }
}
timeline: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  width: 700
  t1: "t₀" {
    shape: circle
    style.fill: "#4682B4"
    style.stroke: "#2F4F4F"
    style.font-color: white
    width: 40
  }
  t2: "t₁" {
    shape: circle
    style.fill: "#DAA520"
    style.stroke: "#B8860B"
    style.font-color: white
    width: 40
  }
  t3: "t₂" {
    shape: circle
    style.fill: "#9370DB"
    style.stroke: "#4B0082"
    style.font-color: white
    width: 40
  }
  arrow1: "" {
    shape: text
    label: "Load v2.0"
  }
  arrow2: "" {
    shape: text
    label: "Swap & Drain"
  }
  t1 -> t2: {
    style.stroke: "#666666"
    style.stroke-width: 3
  }
  t2 -> t3: {
    style.stroke: "#666666"
    style.stroke-width: 3
  }
}
peak_annotation: {
  near: bottom-center
  label: |md
    ### Peak Memory Formula
    
    peak_memory = old_model + new_model + activations + overhead
                = 1.0 GB  + 1.0 GB   + 1.6 GB     + 0.4 GB
                = 4.0 GB (100% capacity)
    
    **⚠️ Critical:** During hot swap, GPU runs at 100% capacity with **zero safety margin**.
    **Mitigation strategies:**
    1. Use smaller batch sizes during swap window
    2. Load model to CPU first, then move to GPU
    3. Ensure old model is draining (no new inferences)
  |
  width: 600
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  style.stroke-width: 2
  style.border-radius: 8
}
legend: {
  direction: right
  near: bottom-center
  style.stroke: transparent
  style.fill: transparent
  leg1: "Model v1.0" {
    shape: rectangle
    style.fill: "#4682B4"
    width: 80
    height: 20
  }
  leg2: "Model v2.0" {
    shape: rectangle
    style.fill: "#9370DB"
    width: 80
    height: 20
  }
  leg3: "Activations" {
    shape: rectangle
    style.fill: "#6B8E23"
    width: 80
    height: 20
  }
  leg4: "OS Overhead" {
    shape: rectangle
    style.fill: "#A9A9A9"
    width: 80
    height: 20
  }
}
phase1_label -> phase2_label -> phase3_label: {
  style.stroke: transparent
}