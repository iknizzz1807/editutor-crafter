direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Request Draining During Hot Swap {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  t0: "T0\nHot Swap\nInitiated" {
    shape: rectangle
    style: {
      fill: "#FFF3CD"
      stroke: "#856404"
      stroke-width: 2
      bold: true
    }
  }
  t1: "T1\nRequests\nCompleting" {
    shape: rectangle
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
      stroke-width: 2
    }
  }
  t2: "T2\nCounter\n= 0" {
    shape: rectangle
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
      stroke-width: 2
    }
  }
  t3: "T3\nOld Model\nUnloaded" {
    shape: rectangle
    style: {
      fill: "#CCE5FF"
      stroke: "#004085"
      stroke-width: 2
      bold: true
    }
  }
}
t0 -> t1 -> t2 -> t3: "Time →" {
  style.stroke-dash: 3
}
counter_flow: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  counter_5: "in_flight = 5" {
    shape: circle
    style: {
      fill: "#F8D7DA"
      stroke: "#721C24"
      stroke-width: 2
      font: mono
      bold: true
    }
  }
  counter_3: "in_flight = 3" {
    shape: circle
    style: {
      fill: "#FCE4D6"
      stroke: "#856404"
      stroke-width: 2
      font: mono
    }
  }
  counter_1: "in_flight = 1" {
    shape: circle
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
      stroke-width: 2
      font: mono
    }
  }
  counter_0: "in_flight = 0" {
    shape: circle
    style: {
      fill: "#CCE5FF"
      stroke: "#004085"
      stroke-width: 3
      font: mono
      bold: true
    }
  }
}
counter_5 -> counter_3: "req_done()" {
  style.stroke: green
}
counter_3 -> counter_1: "req_done()" {
  style.stroke: green
}
counter_1 -> counter_0: "req_done()" {
  style.stroke: green
  style.stroke-width: 2
}
models_section: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  old_model: "Old Model\n(v1.0.0)\nstatus: DRAINING" {
    shape: cylinder
    style: {
      fill: "#F8D7DA"
      stroke: "#721C24"
      stroke-width: 2
      stroke-dash: 5
    }
  }
  new_model: "New Model\n(v2.0.0)\nstatus: ACTIVE" {
    shape: cylinder
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
      stroke-width: 2
    }
  }
  old_model -> new_model: "Atomic\nPointer\nSwap" {
    style: {
      stroke: "#004085"
      stroke-width: 3
      animated: true
    }
  }
}
requests_section: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  in_flight_reqs: "In-Flight Requests" {
    style.fill: transparent
    req1: "req_A\ncompletes" {
      shape: oval
      style.fill: "#D4EDDA"
    }
    req2: "req_B\ncompletes" {
      shape: oval
      style.fill: "#D4EDDA"
    }
    req3: "req_C\ncompletes" {
      shape: oval
      style.fill: "#D4EDDA"
    }
    req4: "req_D\ncompletes" {
      shape: oval
      style.fill: "#D4EDDA"
    }
    req5: "req_E\ncompletes" {
      shape: oval
      style.fill: "#D4EDDA"
    }
    req1 -> req2 -> req3 -> req4 -> req5
  }
  new_requests: "New Requests" {
    style.fill: transparent
    new1: "new_1" {
      shape: oval
      style.fill: "#CCE5FF"
    }
    new2: "new_2" {
      shape: oval
      style.fill: "#CCE5FF"
    }
    new3: "new_3" {
      shape: oval
      style.fill: "#CCE5FF"
    }
    new1 -> new2 -> new3
  }
  in_flight_reqs -> new_requests: "→ Route to\nNew Model" {
    style: {
      stroke: "#155724"
      stroke-width: 2
    }
  }
}
drain_event: "DRAIN COMPLETE\nwait_for_drain() returns True\n→ safe to unload" {
  shape: diamond
  style: {
    fill: "#CCE5FF"
    stroke: "#004085"
    stroke-width: 2
    bold: true
  }
}
counter_0 -> drain_event: "Signal" {
  style.stroke-dash: 4
  style.stroke: "#004085"
}
unload_action: "unload_version(v1.0.0)\n→ del model\n→ torch.cuda.empty_cache()" {
  shape: rectangle
  width: 280
  style: {
    fill: "#F8D7DA"
    stroke: "#721C24"
    font: mono
  }
}
drain_event -> unload_action: "Trigger" {
  style.stroke-width: 2
}
tracker_class: "RequestTracker (drain logic)" {
  shape: class
  label: "RequestTracker (hot_swap.py)"
  -_counts: "Dict[str, int]"
  -_drain_events: "Dict[str, Event]"
  -_drain_timeout: "float"
  +acquire(version_id): "void"
  +release(version_id): "int"
  +start_drain(version_id): "void"
  +wait_for_drain(version_id): "bool"
  +force_drain(version_id): "void"
}
counter_5 -> tracker_class: "Tracked by" {
  style.stroke-dash: 3
  style.stroke: gray
}
legend: "" {
  near: bottom-center
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  l1: "Draining" {
    shape: rectangle
    style: {
      fill: "#F8D7DA"
      stroke: "#721C24"
      stroke-dash: 5
    }
  }
  l2: "Active" {
    shape: rectangle
    style: {
      fill: "#D4EDDA"
      stroke: "#155724"
    }
  }
  l3: "Complete" {
    shape: rectangle
    style: {
      fill: "#CCE5FF"
      stroke: "#004085"
    }
  }
}