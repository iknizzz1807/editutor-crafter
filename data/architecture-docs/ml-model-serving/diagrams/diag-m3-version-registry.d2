direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Model Registry Structure {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  registry: {
    label: "ModelRegistry (versioning/registry.py)"
    direction: down
    header: {
      shape: sql_table
      label: "class ModelRegistry"
      f0: "_versions: OrderedDict[str, ModelVersion]"
      f1: "_active_version_id: str | None"
      f2: "_lock: asyncio.Lock"
      f3: "_max_versions_in_memory: int = 3"
      sz: "Total: ~1KB metadata"
    }
    header.style.stroke: "#5C6BC0"
    header.style.fill: "#E8EAF6"
    methods: {
      shape: class
      label: "Methods"
      +register_version(version, auto_load): "bool"
      +get_version(version_id): "ModelVersion | None"
      +get_active_version(): "ModelVersion | None"
      +validate_compatibility(new_id): "Tuple[bool, str | None]"
      -_load_version_internal(id): "bool"
      -_unload_version_internal(id): "bool"
    }
    methods.style.fill: "#E3F2FD"
  }
  pointer_block: {
    direction: down
    label: "Active Pointer"
    active_ptr: {
      shape: sql_table
      label: "_active_version_id"
      val: '"v2.0.0"'
      type: "str"
    }
    active_ptr.style.fill: "#C8E6C9"
    active_ptr.style.stroke: "#43A047"
    ptr_desc: {
      label: "Atomic pointer swap enables\nzero-downtime version changes"
      shape: rectangle
      width: 220
    }
    ptr_desc.style.fill: "#F1F8E9"
    ptr_desc.style.stroke-dash: 3
  }
}
registry.header -> pointer_block.active_ptr: "references"
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  v1_version: {
    direction: down
    label: "Version v1.0.0 (STABLE)"
    v1_meta: {
      shape: sql_table
      label: "ModelVersion"
      f0: "0x00 | str         | version_id = 'v1.0.0'"
      f1: "0x08 | str         | model_path = 'models/v1.pt'"
      f2: "0x10 | VersionStatus | status = DEPRECATED"
      f3: "0x18 | datetime    | training_date"
      f4: "0x20 | str         | training_data_hash"
      f5: "0x28 | float       | accuracy = 0.942"
      f6: "0x30 | float       | f1_score = 0.918"
      f7: "0x38 | ModelSchema | schema"
      f8: "0x40 | Module      | loaded_model = None"
      f9: "0x48 | int         | in_flight_count = 0"
      sz: "Total: ~2.1KB metadata"
    }
    v1_meta.style.fill: "#FFECB3"
    v1_meta.style.stroke: "#FFA000"
    v1_schema: {
      shape: sql_table
      label: "ModelSchema (v1)"
      f0: "input_shapes: {'input': (None, 3, 224, 224)}"
      f1: "input_dtypes: {'input': 'float32'}"
      f2: "output_shapes: {'logits': (None, 1000)}"
      f3: "output_dtypes: {'logits': 'float32'}"
    }
    v1_schema.style.fill: "#FFF8E1"
    v1_schema.style.stroke: "#FFB300"
  }
  v2_version: {
    direction: down
    label: "Version v2.0.0 (ACTIVE)"
    v2_meta: {
      shape: sql_table
      label: "ModelVersion"
      f0: "0x00 | str         | version_id = 'v2.0.0'"
      f1: "0x08 | str         | model_path = 'models/v2.pt'"
      f2: "0x10 | VersionStatus | status = ACTIVE"
      f3: "0x18 | datetime    | training_date"
      f4: "0x20 | str         | training_data_hash"
      f5: "0x28 | float       | accuracy = 0.963"
      f6: "0x30 | float       | f1_score = 0.951"
      f7: "0x38 | ModelSchema | schema"
      f8: "0x40 | Module      | loaded_model = <ResNet>"
      f9: "0x48 | int         | in_flight_count = 12"
      sz: "Total: ~2.1KB + model weights"
    }
    v2_meta.style.fill: "#C8E6C9"
    v2_meta.style.stroke: "#43A047"
    v2_schema: {
      shape: sql_table
      label: "ModelSchema (v2)"
      f0: "input_shapes: {'input': (None, 3, 224, 224)}"
      f1: "input_dtypes: {'input': 'float32'}"
      f2: "output_shapes: {'logits': (None, 1000)}"
      f3: "output_dtypes: {'logits': 'float32'}"
      compat: "✓ Compatible with v1"
    }
    v2_schema.style.fill: "#E8F5E9"
    v2_schema.style.stroke: "#66BB6A"
  }
}
registry.header -> v1_version.v1_meta: "_versions['v1.0.0']"
registry.header -> v2_version.v2_meta: "_versions['v2.0.0']"
pointer_block.active_ptr -> v2_version.v2_meta: "points to" {
  style.stroke: "#43A047"
  style.stroke-width: 3
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  memory_layout: {
    direction: down
    label: "GPU Memory Layout (Hot Swap)"
    mem_before: {
      shape: sql_table
      label: "Before Swap"
      f0: "[0x0000 - 0x8000] v1.0.0 weights"
      f1: "[0x8000 - 0x8200] v1 activations"
      f2: "[0x8200 - 0x8400] CUDA context"
      f3: "[0x8400 - 0xFFFF] FREE"
      total: "Peak: 2.1GB / 8GB"
    }
    mem_before.style.fill: "#E3F2FD"
    mem_during: {
      shape: sql_table
      label: "During Swap"
      f0: "[0x0000 - 0x8000] v1.0.0 (draining)"
      f1: "[0x8000 - 0x8200] v1 activations"
      f2: "[0x8200 - 0x8400] CUDA context"
      f3: "[0x8400 - 0x10400] v2.0.0 (loading)"
      f4: "[0x10400 - 0x10600] v2 activations"
      f5: "[0x10600 - 0xFFFF] MARGIN"
      total: "Peak: 4.2GB / 8GB (2.5x)"
    }
    mem_during.style.fill: "#FFF3E0"
    mem_during.style.stroke: "#FF9800"
    mem_after: {
      shape: sql_table
      label: "After Swap"
      f0: "[0x0000 - 0x8000] FREE (GC'd)"
      f1: "[0x8000 - 0x10000] v2.0.0 weights"
      f2: "[0x10000 - 0x10200] v2 activations"
      f3: "[0x10200 - 0x10400] CUDA context"
      f4: "[0x10400 - 0xFFFF] FREE"
      total: "Peak: 2.2GB / 8GB"
    }
    mem_after.style.fill: "#E8F5E9"
    mem_after.style.stroke: "#4CAF50"
  }
  status_enum: {
    direction: down
    label: "Version Status Lifecycle"
    status_table: {
      shape: sql_table
      label: "enum VersionStatus"
      s0: "STAGED     → Loaded, not serving"
      s1: "ACTIVE     → Currently serving traffic"
      s2: "DRAINING   → Was active, waiting for requests"
      s3: "DEPRECATED → Unloaded, metadata retained"
      s4: "FAILED     → Load/validation failed"
    }
    status_table.style.fill: "#F3E5F5"
    status_table.style.stroke: "#9C27B0"
    flow: {
      direction: right
      staged: "STAGED" {
        shape: oval
        style.fill: "#E3F2FD"
      }
      active: "ACTIVE" {
        shape: oval
        style.fill: "#C8E6C9"
      }
      draining: "DRAINING" {
        shape: oval
        style.fill: "#FFF9C4"
      }
      deprecated: "DEPRECATED" {
        shape: oval
        style.fill: "#FFECB3"
      }
      failed: "FAILED" {
        shape: diamond
        style.fill: "#FFCDD2"
      }
      staged -> active: "hot_swap()"
      active -> draining: "swap to new"
      draining -> deprecated: "drain complete"
      staged -> failed: "load error"
    }
  }
}
legend: {
  near: bottom-right
  legend_box: {
    label: "Legend"
    shape: rectangle
    style.fill: "#FAFAFA"
    active_item: "Green = Active/Serving" {
      shape: rectangle
    }
    active_item.style.fill: "#C8E6C9"
    staged_item: "Blue = Staged/Loading" {
      shape: rectangle
    }
    staged_item.style.fill: "#E3F2FD"
    draining_item: "Yellow = Draining" {
      shape: rectangle
    }
    draining_item.style.fill: "#FFF9C4"
    deprecated_item: "Orange = Deprecated" {
      shape: rectangle
    }
    deprecated_item.style.fill: "#FFECB3"
  }
}