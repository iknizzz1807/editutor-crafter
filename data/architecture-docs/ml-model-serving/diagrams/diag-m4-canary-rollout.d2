direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Gradual Canary Rollout Stages
  Progressive traffic shift with checkpoint validation
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stable_v1: {
    label: "Stable v1.0.0\n100% → 95% → 90% → 75% → 50% → 0%"
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    width: 180
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage1: {
    direction: down
    label: "Stage 1"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    traffic_pct: {
      label: "5%"
      shape: circle
      style: {
        fill: "#1565C0"
        font-color: white
        bold: true
      }
      width: 50
    }
    duration: {
      label: "1 hour"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    gate1: {
      label: "Checkpoint Gate"
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
        stroke-width: 2
      }
    }
    criteria1: {
      label: |md
        **Success Criteria:**
        - Error rate < 1%
        - p99 latency < 200ms
        - Min 100 samples
      |
      shape: rectangle
      style.fill: "#FFFDE7"
      width: 160
    }
    traffic_pct -> duration -> gate1 -> criteria1
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage2: {
    direction: down
    label: "Stage 2"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    traffic_pct: {
      label: "10%"
      shape: circle
      style: {
        fill: "#2E7D32"
        font-color: white
        bold: true
      }
      width: 50
    }
    duration: {
      label: "1 hour"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    gate2: {
      label: "Checkpoint Gate"
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
        stroke-width: 2
      }
    }
    criteria2: {
      label: |md
        **Success Criteria:**
        - Error rate < 0.5%
        - p99 latency < 180ms
        - Min 500 samples
      |
      shape: rectangle
      style.fill: "#FFFDE7"
      width: 160
    }
    traffic_pct -> duration -> gate2 -> criteria2
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage3: {
    direction: down
    label: "Stage 3"
    style.fill: "#FFF3E0"
    style.stroke: "#EF6C00"
    traffic_pct: {
      label: "25%"
      shape: circle
      style: {
        fill: "#EF6C00"
        font-color: white
        bold: true
      }
      width: 50
    }
    duration: {
      label: "2 hours"
      shape: rectangle
      style.fill: "#FFE0B2"
    }
    gate3: {
      label: "Checkpoint Gate"
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
        stroke-width: 2
      }
    }
    criteria3: {
      label: |md
        **Success Criteria:**
        - Error rate < 0.2%
        - p99 latency < 150ms
        - Min 2,000 samples
        - No business metric regression
      |
      shape: rectangle
      style.fill: "#FFFDE7"
      width: 160
    }
    traffic_pct -> duration -> gate3 -> criteria3
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage4: {
    direction: down
    label: "Stage 4"
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    traffic_pct: {
      label: "50%"
      shape: circle
      style: {
        fill: "#C2185B"
        font-color: white
        bold: true
      }
      width: 50
    }
    duration: {
      label: "4 hours"
      shape: rectangle
      style.fill: "#F8BBD9"
    }
    gate4: {
      label: "Checkpoint Gate"
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
        stroke-width: 2
      }
    }
    criteria4: {
      label: |md
        **Success Criteria:**
        - Error rate < 0.1%
        - p99 latency < 120ms
        - Min 10,000 samples
        - Statistical significance achieved
      |
      shape: rectangle
      style.fill: "#FFFDE7"
      width: 160
    }
    traffic_pct -> duration -> gate4 -> criteria4
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stage5: {
    direction: down
    label: "Stage 5 (Complete)"
    style.fill: "#E8EAF6"
    style.stroke: "#3949AB"
    traffic_pct: {
      label: "100%"
      shape: circle
      style: {
        fill: "#3949AB"
        font-color: white
        bold: true
      }
      width: 50
    }
    final: {
      label: |md
        **FULL PROMOTION**
        Canary v2.0.0 is now
        the new stable version
        Previous stable: deprecated
      |
      shape: rectangle
      style: {
        fill: "#C5CAE9"
        stroke-width: 2
        stroke: "#3949AB"
      }
      width: 160
    }
    traffic_pct -> final
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  canary_v2: {
    label: "Canary v2.0.0\n0% → 5% → 10% → 25% → 50% → 100%"
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
    width: 180
  }
}
row1.stable_v1 -> row2.stage1: "initialize"
row2.stage1.gate1 -> row3.stage2: "PASS" {
  style.stroke: "#2E7D32"
  style.bold: true
}
row3.stage2.gate2 -> row4.stage3: "PASS" {
  style.stroke: "#2E7D32"
  style.bold: true
}
row4.stage3.gate3 -> row5.stage4: "PASS" {
  style.stroke: "#2E7D32"
  style.bold: true
}
row5.stage4.gate4 -> row6.stage5: "PASS" {
  style.stroke: "#2E7D32"
  style.bold: true
}
rollback: {
  label: "Rollback\n(Any Stage)"
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-dash: 4
  }
  width: 120
}
row2.stage1.gate1 -> rollback: "FAIL" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
}
row3.stage2.gate2 -> rollback: "FAIL" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
}
row4.stage3.gate3 -> rollback: "FAIL" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
}
row5.stage4.gate4 -> rollback: "FAIL" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
}
rollback -> row1.stable_v1: "100% traffic\nrestored" {
  style.stroke-dash: 4
  style.stroke: "#C62828"
  style.animated: true
}
legend: {
  near: bottom-right
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  pass: {
    label: "PASS: Proceed to next stage"
    shape: rectangle
    style.fill: "#E8F5E9"
  }
  fail: {
    label: "FAIL: Trigger rollback"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke-dash: 4
  }
  gate: {
    label: "Checkpoint: Validate criteria"
    shape: diamond
    style.fill: "#FFF9C4"
  }
  pass -> fail -> gate
}
timeline: {
  near: bottom-center
  label: "Total Duration: ~8 hours (if all gates pass)"
  shape: rectangle
  style: {
    fill: transparent
    font-size: 14
    italic: true
  }
}