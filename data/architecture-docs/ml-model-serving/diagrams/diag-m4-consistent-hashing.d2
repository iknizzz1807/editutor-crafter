      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
    pos_50: {
      label: "50%"
      shape: circle
      width: 40
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
    pos_75: {
      label: "75%"
      shape: circle
      width: 40
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
    pos_90: {
      label: "90%"
      shape: circle
      width: 60
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.stroke-width: 3
    }
    pos_100: {
      label: "100%"
      shape: circle
      width: 60
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.stroke-width: 3
