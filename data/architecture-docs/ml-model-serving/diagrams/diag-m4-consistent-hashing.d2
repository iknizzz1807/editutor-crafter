    height: 100
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    style.font-color: "#2E7D32"
  }
  bucket_canary: {
    label: "Bucket: CANARY\nVersion: v2.0.0\nWeight: 10%"
    shape: rectangle
    width: 150
    height: 100
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 3
    style.font-color: "#E65100"
  }
}
row_examples: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  user_alice: {
    label: "User: alice_123\nHash: 23\n→ STABLE"
    shape: rectangle
    width: 140
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  user_bob: {
    label: "User: bob_456\nHash: 67\n→ STABLE"
    shape: rectangle
    width: 140
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  user_carol: {
    label: "User: carol_789\nHash: 94\n→ CANARY"
    shape: rectangle
    width: 140
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
    style.stroke-width: 2
  }
  user_dave: {
    label: "User: dave_001\nHash: 5\n→ STABLE"
    shape: rectangle
    width: 140
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
}
row_determinism: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  proof_box: {
    label: "Determinism Proof"
    width: 600
    style.fill: "#F5F5F5"
    style.stroke: "#9E9E9E"
    style.stroke-dash: 3
    step1: {
      label: "1. SHA-256(alice_123) → 0x7a3f...b2c1"
      width: 280
    }
    step2: {
      label: "2. 0x7a3f...b2c1 % 100 = 23"
      width: 280
    }
    step3: {
      label: "3. 23 < 90 → Route to STABLE"
      width: 280
      style.fill: "#C8E6C9"
    }
    step4: {
      label: "4. Same input → Same hash → Same bucket\n(EVERY TIME)"
      width: 280
      style.fill: "#E3F2FD"
      style.font: mono
    }
  }
}
row_code: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hash_fn: {
    label: "Hash Function (traffic_splitter.py)"
    width: 450
    code: |'python
      def _hash_user(self, user_id: str) -> int:
          """Hash user_id to 0-99 percentile."""
          hash_bytes = hashlib.sha256(
              user_id.encode('utf-8')
          ).digest()
          hash_int = int.from_bytes(
              hash_bytes[:8], byteorder='big'
          )
          return hash_int % 100  # 0-99
    '|
  }
  route_fn: {
    label: "Routing Logic (traffic_splitter.py)"
    width: 400
    code: |'python
      def route(self, user_id: str) -> str:
          user_hash = self._hash_user(user_id)
          # Cumulative weight check
          cumulative = 0.0
          for alloc in self.allocations:
              cumulative += alloc.weight_percent
              if user_hash < cumulative:
                  return alloc.version_id
          # alice: hash=23 < 90 → v1.0.0
          # carol: hash=94 < 100 → v2.0.0
    '|
  }
}
row_ring.pos_0 -> row_buckets.bucket_stable: "0-89"
row_ring.pos_90 -> row_buckets.bucket_canary: "90-99"
row_examples.user_alice -> row_buckets.bucket_stable: "hash 23" {style.stroke: "#4CAF50"; style.stroke-width: 2}
row_examples.user_bob -> row_buckets.bucket_stable: "hash 67" {style.stroke: "#4CAF50"; style.stroke-width: 2}
row_examples.user_carol -> row_buckets.bucket_canary: "hash 94" {style.stroke: "#FF9800"; style.stroke-width: 2}
row_examples.user_dave -> row_buckets.bucket_stable: "hash 5" {style.stroke: "#4CAF50"; style.stroke-width: 2}
legend: {
  near: bottom-right
  stable_legend: {
    label: "■ Stable (v1.0.0)"
    shape: rectangle
    width: 120
    style.fill: "#C8E6C9"
