direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Consistent Hashing for Deterministic Routing
  Traffic Split: 90% Stable (v1.0.0) / 10% Canary (v2.0.0)
| {near: top-center}
row_ring: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ring_container: {
    label: "Hash Ring (SHA-256(user_id) % 100)"
    width: 500
    # Ring representation - positions marked
    pos_0: {
      label: "0%"
