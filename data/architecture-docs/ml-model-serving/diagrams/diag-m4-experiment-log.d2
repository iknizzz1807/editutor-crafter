direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Experiment Log Schema & Sample Entries {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  schema_section: {
    direction: down
    label: "Log Entry Schema"
    
    log_entry_schema: {
      shape: sql_table
      label: "PredictionLog (experiment_log.py)"
      f0: "0x00 | float64   | timestamp       // Unix epoch"
      f1: "0x08 | string    | request_id      // UUID v4"
      f2: "0x10 | string    | user_id         // Client ID"
      f3: "0x18 | string    | model_version   // Semantic version"
      f4: "0x20 | string    | input_hash      // SHA256 snippet"
      f5: "0x28 | Any       | prediction      // Result payload"
      f6: "0x30 | float64   | latency_ms      // Wall clock time"
      f7: "0x38 | bool      | success         // Error flag"
      f8: "0x40 | string?   | error_message   // Traceback/Null"
      f9: "0x48 | int       | allocation_hash // A/B Bucket"
      sz: "Total: ~80 bytes (heap dependent)"
    }
    
    field_descriptions: {
      shape: rectangle
      width: 380
      label: |'md
        **Field Semantics:**
        - `request_id`: Primary key for log joining
        - `input_hash`: Used to detect feature drift
        - `allocation_hash`: 0-99 bucket for consistent routing
        - `latency_ms`: P99 monitoring metric
      '|
    }
  }

  sample_entries: {
    direction: down
    label: "Sample Log Entries"
    
    entry_v1: {
      label: "v1.0.0 Entry"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      code: |'json
        {
          "timestamp": 1710264832.451,
          "request_id": "a3f7c2e1",
          "model_version": "v1.0.0",
          "prediction": {"class": "cat", "prob": 0.92},
          "latency_ms": 45.3,
          "allocation_hash": 87
        }
      '|
      width: 420
    }
    
    entry_v2: {
      label: "v2.0.0 Entry"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      code: |'json
        {
          "timestamp": 1710264832.892,
          "request_id": "b8d4a1f6",
          "model_version": "v2.0.0",
          "prediction": {"class": "dog", "prob": 0.87},
          "latency_ms": 52.1,
          "allocation_hash": 12
        }
      '|
      width: 420
    }
    
    entry_error: {
      label: "Error Entry"
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      code: |'json
        {
          "timestamp": 1710264833.124,
          "request_id": "c2e9b7d4",
          "success": false,
          "error_message": "CUDA OOM: batch too large",
          "latency_ms": 1023.7
        }
      '|
      width: 420
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  routing_section: {
    direction: down
    label: "Deterministic Allocation"
    
    hash_flow: {
      label: "A/B Routing Logic"
      code: |'python
        # Hash-based allocation logic
        user_hash = SHA256(user_id) % 100
        if user_hash < 90:
            version = "v1.0.0" # Stable
        else:
            version = "v2.0.0" # Canary
      '|
      width: 320
    }
    
    bucket_dist: {
      shape: rectangle
      width: 320
      label: |'md
        **Hash Distribution:**
        | Range | Version | Traffic |
        |-------|---------|---------|
        | 0-89  | v1.0.0  | 90%     |
        | 90-99 | v2.0.0  | 10%     |
      '|
    }
  }

  logging_section: {
    direction: down
    label: "Storage Partitioning"
    
    file_format: {
      label: "exp-001.jsonl"
      code: |'json
        {"timestamp":1710264832.451...}
        {"timestamp":1710264832.892...}
        {"timestamp":1710264833.124...}
      '|
      width: 380
    }
    
    query_example: {
      label: "Post-hoc SQL Analysis"
      code: |'sql
        SELECT model_version, 
               AVG(latency_ms) as lat,
               COUNT(*) as n
        FROM experiment_logs
        GROUP BY model_version;
      '|
      width: 380
    }
  }

  legend_section: {
    direction: down
    label: "Metadata Legend"
    
    legend_v1: {
      label: "v1.0.0 (Stable)"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      width: 200
    }
    legend_v2: {
      label: "v2.0.0 (Canary)"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
      width: 200
    }
    legend_error: {
      label: "Failed Inference"
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      width: 200
    }
  }
}

# Connections
schema_section.log_entry_schema -> sample_entries: "generates"
routing_section.hash_flow -> sample_entries.entry_v1: "hash < 90"
routing_section.hash_flow -> sample_entries.entry_v2: "hash >= 90"
sample_entries -> logging_section.file_format: "append (JSONL)"