direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Per-Version Metrics Collection
  Parallel metric streams for baseline vs canary comparison
| {near: top-center}
row_requests: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  incoming: "Incoming Requests" {
    shape: queue
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
}
row_split: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  splitter: "Traffic Splitter\n(hash(user_id) % 100)" {
    shape: diamond
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 160
  }
}
incoming -> splitter: "requests"
row_streams: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  baseline_stream: "BASELINE STREAM\nv1.0.0 (90%)" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    baseline_latency: "LatencyHistogram" {
      shape: class
      label: "LatencyHistogram (v1.0.0)"
      -buckets: "[1, 5, 10, 25, 50, 75, 100, 150, 200, 300, 500, ...]"
      -sum_total: "float"
      -count_total: "int"
      +observe(latency_ms): "void"
      +percentile(p): "float"
      +to_prometheus_format(): "str"
    }
    baseline_error: "ErrorCounter" {
      shape: class
      label: "ErrorCounter (v1.0.0)"
      -request_count: "int"
      -error_count: "int"
      +record(success): "void"
      +get_error_rate(): "float"
    }
    baseline_pred: "PredictionDistribution" {
      shape: class
      label: "PredictionDistribution (v1.0.0)"
      -samples: "deque[float]"
      -n_bins: "int = 20"
      -baseline_histogram: "dict"
      +record(prediction): "void"
      +compute_histogram(): "dict"
      +compare_to_baseline(): "dict"
    }
  }
  canary_stream: "CANARY STREAM\nv2.0.0 (10%)" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.stroke-width: 2
    canary_latency: "LatencyHistogram" {
      shape: class
      label: "LatencyHistogram (v2.0.0)"
      -buckets: "[1, 5, 10, 25, 50, 75, 100, 150, 200, 300, 500, ...]"
      -sum_total: "float"
      -count_total: "int"
      +observe(latency_ms): "void"
      +percentile(p): "float"
      +to_prometheus_format(): "str"
    }
    canary_error: "ErrorCounter" {
      shape: class
      label: "ErrorCounter (v2.0.0)"
      -request_count: "int"
      -error_count: "int"
      +record(success): "void"
      +get_error_rate(): "float"
    }
    canary_pred: "PredictionDistribution" {
      shape: class
      label: "PredictionDistribution (v2.0.0)"
      -samples: "deque[float]"
      -n_bins: "int = 20"
      -baseline_histogram: "dict"
      +record(prediction): "void"
      +compute_histogram(): "dict"
      +compare_to_baseline(): "dict"
    }
  }
}
splitter -> baseline_stream: "90%"
splitter -> canary_stream: "10%"
row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparator: "PerVersionMetrics.compare_versions()" {
    shape: hexagon
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    width: 200
  }
}
baseline_stream -> comparator: "metrics_a"
canary_stream -> comparator: "metrics_b"
row_dashboard: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dashboard: "COMPARISON DASHBOARD" {
    direction: down
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    style.stroke-width: 2
    width: 700
    latency_panel: "Latency Comparison" {
      shape: rectangle
      style.fill: "#FAFAFA"
      width: 650
      latency_table: {
        shape: sql_table
        label: "Latency Percentiles"
        p50: "Percentile | v1.0.0 (ms) | v2.0.0 (ms) | Diff %"
        p90: "p50        | 45.2       | 42.1       | -6.9%"
        p95: "p90        | 78.3       | 71.5       | -8.7%"
        p99: "p95        | 98.7       | 89.2       | -9.6%"
        row5: "p99        | 145.3      | 128.4      | -11.6%"
      }
    }
    error_panel: "Error Rate Comparison" {
      shape: rectangle
      style.fill: "#FAFAFA"
      width: 650
      error_table: {
        shape: sql_table
        label: "Error Rates"
        r1: "Metric         | v1.0.0    | v2.0.0    | Diff"
        r2: "Error Rate     | 0.012%    | 0.008%    | -0.004%"
        r3: "Request Count  | 157,432   | 17,481    | --"
        r4: "Error Count    | 19        | 1         | --"
      }
    }
    pred_panel: "Prediction Distribution Comparison" {
      shape: rectangle
      style.fill: "#FAFAFA"
      width: 650
      pred_table: {
        shape: sql_table
        label: "Distribution Stats"
        s1: "Statistic      | v1.0.0    | v2.0.0    | Shift"
        s2: "Mean           | 0.523     | 0.531     | +1.5%"
        s3: "Std Dev        | 0.142     | 0.138     | -2.8%"
        s4: "TV Distance    | --        | 0.034     | LOW"
      }
    }
    recommendation: "RECOMMENDATION: Treatment (v2.0.0) shows 8-11% latency improvement\nwith no error rate increase. Consider promoting to higher traffic." {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.font-color: "#2E7D32"
      width: 650
    }
  }
}
comparator -> dashboard: "comparison result"
row_prometheus: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  prometheus: "Prometheus\n/metrics endpoint" {
    shape: cylinder
    style.fill: "#FF5722"
    style.font-color: white
  }
}
dashboard -> prometheus: "scrape"
row_alerts: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  alerting: "AlertManager" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    rules: "Alert Rules" {
      shape: class
      label: "Alert Rules"
      -error_rate_multiplier: "2.0  # canary > 2x stable"
      -latency_p99_multiplier: "2.0"
      -latency_p50_multiplier: "1.5"
      -min_samples: "100"
      +evaluate(): "List[Alert]"
    }
    state: "Alert State" {
      shape: class
      label: "Current State"
      -consecutive_failures: "0"
      -last_alert_time: "float"
      -cooldown_seconds: "3600"
      +should_alert(): "bool"
    }
  }
}
prometheus -> alerting: "evaluate rules"
legend: |md
  **Color Legend:**
  - 🟢 Green: Baseline (stable) version metrics
  - 🟡 Yellow: Canary (treatment) version metrics
  - 🟣 Purple: Comparison/aggregation logic
  - 🔴 Red: Alerting thresholds
| {
  near: bottom-left
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  width: 300
}