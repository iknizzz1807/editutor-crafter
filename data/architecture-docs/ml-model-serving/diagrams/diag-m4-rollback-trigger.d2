direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Automatic Canary Rollback Trigger {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  timeline_header: Timeline {
    shape: rectangle
    width: 600
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      bold: true
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  time_markers: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    t0: t=0 {
      shape: text
      style.font-size: 12
    }
    t1: t=30s {
      shape: text
      style.font-size: 12
    }
    t2: t=60s {
      shape: text
      style.font-size: 12
    }
    t3: t=90s {
      shape: text
      style.font-size: 12
    }
    t4: t=120s {
      shape: text
      style.font-size: 12
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  canary_deployment: Canary Deployment (10% traffic) {
    shape: rectangle
    width: 600
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-dash: 3
    }
    canary_label: "Canary: v2.0.0 | Stable: v1.0.0" {
      shape: text
      style.font-size: 11
    }
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  error_spike_region: Error Rate Spike Detected {
    shape: rectangle
    width: 600
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
    }
    spike_details: "Canary error rate: 8.2% | Stable error rate: 2.1%" {
      shape: text
      style: {
        font-size: 11
        font-color: "#C62828"
      }
    }
  }
}
row5: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  rollback_region: Automatic Rollback Executed {
    shape: rectangle
    width: 600
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
    rollback_details: "Traffic → 100% stable | Rollback time: 0.8s" {
      shape: text
      style: {
        font-size: 11
        font-color: "#E65100"
      }
    }
  }
}
state_flow: {
  direction: down
  monitor: ErrorRateMonitor {
    shape: class
    label: "ErrorRateMonitor (health_checker.py)"
    -canary_errors: "int"
    -canary_total: "int"
    -stable_errors: "int"
    -stable_total: "int"
    -window_seconds: "float"
    +check_health(): "(bool, str)"
    +compute_error_rate(): "float"
    +record_result(): "void"
  }
  compare: Comparison {
    shape: diamond
    label: "Canary Error Rate\n> 2x Stable?"
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
  monitor -> compare: "error rates" {
    label: "canary=8.2%\nstable=2.1%"
  }
  normal: Continue Canary {
    shape: oval
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  trigger: Trigger Rollback {
    shape: oval
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
    }
  }
  compare -> normal: "No (ratio < 2x)" {
    style.stroke: "#4CAF50"
  }
  compare -> trigger: "Yes (3.9x > 2x)" {
    style: {
      stroke: "#F44336"
      stroke-width: 2
      animated: true
    }
  }
}
rollback_sequence: {
  direction: down
  label: "Rollback Sequence"
  step1: Step 1: Detect Threshold Breach {
    width: 350
    code: |'python
      canary_rate = 0.082   # 8.2%
      stable_rate = 0.021   # 2.1%
      multiplier = canary_rate / stable_rate
      # multiplier = 3.9x > 2.0x threshold
      if multiplier > 2.0:
          trigger_rollback("Error rate exceeded")
    '|
  }
  step2: Step 2: Atomic Traffic Swap {
    width: 350
    code: |'python
      # Instant pointer swap (O(1))
      await pointer.swap(stable_version)
      # Route 100% to stable
      splitter.update_weights([
          TrafficAllocation("v1.0.0", 100.0),
          TrafficAllocation("v2.0.0", 0.0),
      ])
    '|
  }
  step3: Step 3: Fire Alert {
    width: 350
    code: |'python
      alert = Alert(
          rule_name="error_rate_critical",
          severity=AlertSeverity.CRITICAL,
          message="Canary error rate 3.9x baseline"
      )
      await pagerduty.send(alert)
      await slack.notify("#ml-alerts", alert)
    '|
  }
  step1 -> step2: "threshold breached" {
    style.stroke: "#F44336"
    style.animated: true
  }
  step2 -> step3: "traffic swapped" {
    style.stroke: "#FF9800"
  }
}
threshold_analysis: {
  direction: down
  label: "Threshold Analysis"
  baseline_box: Stable Baseline {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
    baseline_metrics: {
      shape: sql_table
      label: "Stable Version Metrics"
      f0: "Error Rate | 2.1%"
      f1: "Latency p99 | 145ms"
      f2: "Sample Count | 15,420"
    }
  }
  canary_box: Canary Metrics {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
    }
    canary_metrics: {
      shape: sql_table
      label: "Canary Version Metrics"
      f0: "Error Rate | 8.2% ⚠️"
      f1: "Latency p99 | 312ms ⚠️"
      f2: "Sample Count | 1,714"
    }
  }
  calc_box: Ratio Calculation {
    shape: rectangle
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
    }
    calc: |md
      **Error Rate Multiplier:**
      
      8.2% / 2.1% = 3.9x
      
      **Threshold: 2.0x**
      **Result: 3.9x > 2.0x → ROLLBACK**
    |
  }
  baseline_box -> canary_box: "compare" {
    style.stroke-dash: 3
  }
  canary_box -> calc_box: "compute ratio"
}
event_timeline: {
  direction: down
  label: "Event Timeline"
  events: {
    shape: sequence_diagram
    HealthMonitor
    CanaryVersion
    StableVersion
    TrafficSplitter
    AlertSystem
    HealthMonitor.t1 -> CanaryVersion.t1: "Record error (8.2%)"
    HealthMonitor.t2 -> CanaryVersion.t2: "Check health"
    CanaryVersion.t2 -> HealthMonitor.t2: "error_rate=0.082"
    HealthMonitor.t2 -> StableVersion.t2: "Get baseline"
    StableVersion.t2 -> HealthMonitor.t2: "error_rate=0.021"
    HealthMonitor.t2 -> HealthMonitor.t2: "ratio=3.9x > 2.0x"
    HealthMonitor.t3 -> TrafficSplitter.t3: "ROLLBACK NOW"
    TrafficSplitter.t3 -> TrafficSplitter.t3: "swap to 100% stable"
    TrafficSplitter.t3 -> CanaryVersion.t3: "Stop traffic"
    TrafficSplitter.t3 -> StableVersion.t3: "Route all traffic"
    HealthMonitor.t3 -> AlertSystem.t3: "Fire CRITICAL alert"
  }
}
rollback_state: {
  direction: down
  label: "Rollback State Machine"
  state_running: Running Canary {
    shape: circle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  state_checking: Health Check {
    shape: diamond
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
    }
  }
  state_healthy: Continue {
    shape: circle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  state_draining: Draining Canary {
    shape: circle
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
  }
  state_rolledback: Rolled Back {
    shape: circle
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
    }
  }
  state_running -> state_checking: "periodic check"
  state_checking -> state_healthy: "healthy"
  state_healthy -> state_running: "continue"
  state_checking -> state_draining: "threshold exceeded" {
    style: {
      stroke: "#F44336"
      stroke-width: 2
    }
  }
  state_draining -> state_rolledback: "traffic swapped"
}
metrics_before_after: {
  direction: right
  label: "Before vs After Rollback"
  before: Before Rollback {
    shape: rectangle
    width: 280
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
    }
    before_table: {
      shape: sql_table
      label: "Traffic Distribution"
      r0: "v1.0.0 (Stable) | 90%"
      r1: "v2.0.0 (Canary) | 10%"
      r2: "Overall Error | 2.7%"
    }
  }
  arrow: → {
    shape: text
    style: {
      font-size: 24
      bold: true
    }
  }
  after: After Rollback {
    shape: rectangle
    width: 280
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
    after_table: {
      shape: sql_table
      label: "Traffic Distribution"
      r0: "v1.0.0 (Stable) | 100%"
      r1: "v2.0.0 (Canary) | 0%"
      r2: "Overall Error | 2.1%"
    }
  }
  before -> arrow
  arrow -> after
}
alert_example: {
  direction: down
  label: "Alert Payload"
  alert_box: {
    shape: rectangle
    width: 450
    style: {
      fill: "#212121"
      font-color: "#FFFFFF"
    }
    alert_code: |'json
      {
        "alert_id": "alert-2024-0312-001",
        "severity": "CRITICAL",
        "rule_name": "canary_error_rate_exceeded",
        "timestamp": "2024-03-12T14:32:45Z",
        "canary_version": "v2.0.0",
        "stable_version": "v1.0.0",
        "canary_error_rate": 0.082,
        "stable_error_rate": 0.021,
        "multiplier": 3.9,
        "threshold": 2.0,
        "action_taken": "ROLLBACK",
        "rollback_duration_ms": 823,
        "message": "Canary error rate (8.2%) is 3.9x stable baseline (2.1%)"
      }
    '|
  }
}
config_box: Rollback Configuration {
  shape: class
  label: "HealthCheckConfig"
  -check_interval_seconds: "float = 30.0"
  -min_samples_required: "int = 50"
  -max_error_rate_multiplier: "float = 2.0"
  -max_latency_p50_multiplier: "float = 1.5"
  -max_latency_p99_multiplier: "float = 2.0"
  -consecutive_failures_threshold: "int = 3"
  +check_health(): "Tuple[bool, str]"
}
state_flow -> rollback_sequence
rollback_sequence -> threshold_analysis
threshold_analysis -> event_timeline
event_timeline -> rollback_state
rollback_state -> metrics_before_after
metrics_before_after -> alert_example
alert_example -> config_box