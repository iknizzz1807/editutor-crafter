direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Sample Size and Statistical Significance
  Detection threshold vs sample size for ML model improvements
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  detection_graph: {
    label: "Detection Threshold vs Sample Size"
    width: 450
    axes: {
      label: "Axes"
      x_axis: "Sample Size (per group)"
      y_axis: "Minimum Detectable Effect (%)"
    }
    curve_10k: "10K samples: 2.5% MDE"
    curve_15k: "15K samples: 1.0% MDE"
    curve_50k: "50K samples: 0.5% MDE"
    curve_100k: "100K samples: 0.3% MDE"
    curve_10k.style.fill: "#FFB3BA"
    curve_15k.style.fill: "#BAFFC9"
    curve_50k.style.fill: "#BAE1FF"
    curve_100k.style.fill: "#FFFFBA"
    curve_15k: {
      style: {
        stroke: "#22C55E"
        stroke-width: 3
        bold: true
      }
    }
  }
  effect_table: {
    label: "Effect Size Detection Guide"
    shape: sql_table
    f1: "Sample Size | MDE | Use Case"
    f2: "5,000      | 5.0% | Major UI changes"
    f3: "10,000     | 2.5% | Feature launches"
    f4: "15,000     | 1.0% | Model improvements"
    f5: "50,000     | 0.5% | Fine-tuning"
    f6: "100,000    | 0.3% | Subtle optimizations"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  annotation_box: {
    label: "Key Insight"
    width: 400
    style: {
      fill: "#FEF3C7"
      stroke: "#F59E0B"
      stroke-width: 2
      border-radius: 8
    }
    insight: |md
      ### 15K samples needed to detect 1% improvement
      At 1,000 requests/day:
      - **157 days** to statistical significance
      - Plan experiments accordingly
      - Consider increasing traffic or reducing variance
    |
  }
  formula_box: {
    label: "Sample Size Formula"
    width: 400
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
      stroke-width: 2
      border-radius: 8
    }
    formula: |md
      
      n = 2 × (Z_α + Z_β)² × σ² / Δ²
      Where:
      - Z_α = 1.96 (95% confidence)
      - Z_β = 0.84 (80% power)
      - σ = standard deviation
      - Δ = minimum detectable effect
      
    |
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  power_curve: {
    label: "Statistical Power vs Sample Size"
    width: 450
    power_80: "80% Power (recommended)"
    power_90: "90% Power"
    power_95: "95% Power"
    power_80.style.fill: "#86EFAC"
    power_90.style.fill: "#93C5FD"
    power_95.style.fill: "#C4B5FD"
    power_80: {
      style: {
        stroke: "#16A34A"
        stroke-width: 3
      }
    }
    note: "Higher power requires larger samples"
    note.shape: text
    note.style.font-color: "#6B7280"
  }
  tradeoffs: {
    label: "The Tradeoff Triangle"
    shape: sql_table
    t1: "Constraint | Impact"
    t2: "Small sample | Low power, miss real effects"
    t3: "Large sample | Long experiment duration"
    t4: "Large effect | Easier to detect"
    t5: "Small effect | Requires huge samples"
    t6: "High variance | More samples needed"
    t7: "Low variance | Fewer samples needed"
  }
}
detection_graph.axes -> annotation_box: "15K samples" {
  style: {
    stroke: "#22C55E"
    stroke-width: 2
    stroke-dash: 4
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: white
  mde: "MDE = Minimum Detectable Effect"
  power: "Power = P(detect real effect)"
  alpha: "α = 0.05 (significance level)"
  mde.style.font-size: 14
  power.style.font-size: 14
  alpha.style.font-size: 14
}