direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  incoming: {
    label: "Incoming Requests"
    shape: queue
    width: 180
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hasher: {
    label: "Hash Function\n(hash(user_id) % 100)"
    shape: hexagon
    width: 200
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bucket_container: {
    label: "Bucket Assignment (0-99)"
    width: 600
    buckets: {
      shape: sql_table
      label: "Percentile Buckets"
      b0: "0-9    | 10 buckets | CANARY (v2.0.0)"
      b1: "10-89  | 80 buckets | STABLE (v1.0.0)"
      b2: "90-99  | 10 buckets | STABLE (v1.0.0)"
      note: "Total: 100 buckets | 90% Stable / 10% Canary"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  canary_router: {
    label: "Canary Route\n(buckets 0-9)"
    shape: diamond
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
  stable_router: {
    label: "Stable Route\n(buckets 10-99)"
    shape: diamond
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  canary_model: {
    label: "Model v2.0.0\n(Canary)"
    shape: cylinder
    width: 160
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
  }
  stable_model: {
    label: "Model v1.0.0\n(Stable)"
    shape: cylinder
    width: 160
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  response: {
    label: "Prediction Response"
    shape: oval
    width: 200
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
  }
}
incoming -> hasher: "user_id" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
hasher -> bucket_container.buckets: "hash % 100" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
bucket_container.buckets -> canary_router: "if 0-9\n(10%)" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 3
}
bucket_container.buckets -> stable_router: "if 10-99\n(90%)" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
canary_router -> canary_model: "route" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
}
stable_router -> stable_model: "route" {
  style.stroke: "#4CAF50"
}
canary_model -> response: "prediction" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 3
}
stable_model -> response: "prediction" {
  style.stroke: "#9C27B0"
}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  label: "Traffic Split Legend"
  canary_legend: "Canary (v2.0.0): 10% traffic" {
    shape: text
    style.font-color: "#F44336"
  }
  stable_legend: "Stable (v1.0.0): 90% traffic" {
    shape: text
    style.font-color: "#4CAF50"
  }
  hash_legend: "Same user_id always routes to same version" {
    shape: text
    style.font-color: "#666"
  }
}