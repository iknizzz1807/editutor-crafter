direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Drift Detection Pipeline
  **Data Walk: From Request Sampling to Alert Firing**
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  requests: {
    label: "Incoming Requests (1000 RPS)"
    width: 140
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    req1: "req_001"
    req2: "req_002"
    req_etc: "..."
    req1000: "req_1000"
  }

  sampler: {
    label: "Deterministic Sampler"
    width: 200
    logic: {
      label: "Rate: 1/1000"
      code: |'python
        counter += 1
        if counter % 1000 == 0:
            return True  # sample
        return False
      '|
    }
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }

  note_sampling: {
    shape: callout
    label: "Reduces 1000 RPS to 1/sec\n~3600 samples/hour"
    style.fill: "#FFF8E1"
  }

  sampled: {
    label: "Sampled Request"
    width: 140
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}

row1.requests -> row1.sampler: "stream"
row1.sampler -> row1.sampled: "1/1000"

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  extractor: {
    label: "Feature Extractor (python)"
    width: 220
    features: {
      shape: sql_table
      label: "features dict"
      f0: "age | 34.5"
      f1: "income | 75000.0"
      f2: "session_len | 245.0"
      f3: "click_rate | 0.12"
      sz: "Total: 4 features"
    }
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
  }

  buffer: {
    label: "Reservoir Buffer"
    width: 220
    visualization: {
      label: "Sliding Window (n=5000)"
      grid-columns: 5
      s1: {width: 15; height: 15; style.fill: "#4CAF50"}
      s2: {width: 15; height: 15; style.fill: "#4CAF50"}
      s3: {width: 15; height: 15; style.fill: "#4CAF50"}
      s4: {width: 15; height: 15; style.fill: "#4CAF50"}
      s5: {width: 15; height: 15; style.fill: "#4CAF50"}
      s6: {width: 15; height: 15; style.fill: "#E0E0E0"}
      s7: {width: 15; height: 15; style.fill: "#E0E0E0"}
      s8: {width: 15; height: 15; style.fill: "#E0E0E0"}
      s9: {width: 15; height: 15; style.fill: "#E0E0E0"}
      s10: {width: 15; height: 15; style.fill: "#E0E0E0"}
    }
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }

  note_window: {
    shape: callout
    label: "Maintains representative\ndistribution over time"
    style.fill: "#E3F2FD"
  }
}

row1.sampled -> row2.extractor: "JSON"
row2.extractor -> row2.buffer: "features | push"

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  baseline: {
    label: "Training Baseline"
    width: 200
    baseline_data: {
      shape: sql_table
      label: "FeatureBaseline (S3)"
      row0: "feature_name | age"
      row1: "samples | [23, 45, ...]"
      row2: "mean | 42.3"
      row3: "std | 15.2"
      sz: "Stored in Parquet"
    }
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
  }

  ks_test: {
    label: "KS Test Engine"
    width: 320
    calc: {
      label: "2-Sample Kolmogorov-Smirnov"
      code: |'python
        # KS Statistic
        D = max|CDF_baseline(x) - CDF_live(x)|
        # P-value (asymptotic)
        n_eff = sqrt(n1*n2/(n1+n2))
        lambda = (n_eff * D)**2
        p = 2 * sum((-1)**(k-1) * exp(-2*k**2 * lambda))
      '|
    }
    output: {
      shape: sql_table
      label: "KSTestResult"
      r0: "statistic (D) | 0.0847"
      r1: "p_value | 0.0023"
      r2: "is_significant | True"
    }
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
  }
}

row2.buffer -> row3.ks_test: "live_samples"
row3.baseline -> row3.ks_test: "ref_samples"

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  threshold_check: {
    label: "P < 0.01?"
    shape: diamond
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }

  note_threshold: {
    shape: callout
    label: "Cooldown: 1 hour\nPrevents fatigue"
    style.fill: "#FCE4EC"
  }

  no_alert: {
    label: "Stable: Continue"
    width: 140
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-dash: 3
  }

  alert: {
    label: "DRIFT DETECTED"
    width: 220
    alert_detail: {
      shape: sql_table
      label: "Slack Alert Payload"
      a0: "feature | age"
      a1: "p_value | 0.0023"
      a2: "D_stat | 0.0847"
      a3: "severity | WARNING"
    }
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.font-color: "#B71C1C"
  }
}

row3.ks_test -> row4.threshold_check: "result"
row4.threshold_check -> row4.no_alert: "False"
row4.threshold_check -> row4.alert: "True" {
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.animated: true
}

visual_panel: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  cdf_panel: {
    label: "KS Test Visual Intuition"
    direction: right
    baseline_cdf: {
      label: "Baseline CDF"
      code: |'md
        1.0 ┤       ╭──────
            │     ╱
        0.5 │   ╱
            │ ╱
        0.0 ┤─
            └──────────────
      '|
    }
    live_cdf: {
      label: "Live CDF (Shifted)"
      code: |'md
        1.0 ┤         ╭────
            │       ╱
        0.5 │     ╱   ← SHIFT
            │   ╱
        0.0 ┤──
            └──────────────
      '|
    }
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
  }

  metrics_panel: {
    label: "Prometheus Export"
    code: |'prometheus
      drift_ks_statistic{feature="age"} 0.0847
      drift_p_value{feature="age"} 0.0023
      drift_detected{feature="age"} 1
      drift_baseline_age_days 45
    '|
    style.fill: "#263238"
    style.stroke: "#37474F"
    style.font-color: "#ECEFF1"
  }
}

row4 -> visual_panel: "Telemetry"

legend: {
  near: bottom-right
  direction: down
  style.fill: "#f9f9f9"
  title: "Color Semantics"
  l1: "Green: Stable Path" {style.font-color: "#4CAF50"}
  l2: "Orange: Sampling Path" {style.font-color: "#FF9800"}
  l3: "Red: Drift/Warning" {style.font-color: "#D32F2F"}
  l4: "Blue: Data stream" {style.font-color: "#2196F3"}
}