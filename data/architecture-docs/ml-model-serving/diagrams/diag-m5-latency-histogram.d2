row2_arrow: row2.buckets -> row3.percentiles: "Percentile | interpolate"
# Row 3: Percentile Calculation
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  percentile_calc: {
    label: "Percentile Calculation Algorithm"
    direction: down
    algorithm: {
      label: "LatencyHistogram.percentile(p)"
      width: 380
      code: |'python
def percentile(self, p: float) -> float:
    if self.count_total == 0:
        return 0.0
    # Target count for this percentile
    target = (p / 100.0) * self.count_total
    # Find bucket containing target
    prev_count = 0
    prev_bound = 0.0
    for bucket in self.buckets:
        if bucket.count >= target:
            # Percentile is in this bucket
            # Linear interpolation within bucket
            width = bucket.upper_bound - prev_bound
            obs_in_bucket = bucket.count - prev_count
            obs_needed = target - prev_count
            fraction = obs_needed / obs_in_bucket
            return prev_bound + (width * fraction)
        prev_count = bucket.count
        prev_bound = bucket.upper_bound
    return self.buckets[-1].upper_bound * 2
'|
    }
  }
  percentile_examples: {
    label: "Percentile Examples"
    direction: down
    p50_calc: {
      label: "p50 (Median)"
      shape: rectangle
      width: 350
      code: |md
        target = 0.50 * 10,000 = 5,000th request
        bucket{le='25'}  has 892   < 5,000
        bucket{le='50'}  has 5,247 ≥ 5,000 ✓
        prev_count = 892, prev_bound = 25
        obs_in_bucket = 5,247 - 892 = 4,355
        obs_needed = 5,000 - 892 = 4,108
        fraction = 4,108 / 4,355 = 0.943
        p50 = 25 + (50 - 25) * 0.943 = 48.6ms
      |
    }
    p95_calc: {
      label: "p95"
      shape: rectangle
      width: 350
      code: |md
        target = 0.95 * 10,000 = 9,500th request
        bucket{le='150'} has 9,456 < 9,500
        bucket{le='200'} has 9,789 ≥ 9,500 ✓
        prev_count = 9,456, prev_bound = 150
        obs_in_bucket = 9,789 - 9,456 = 333
        obs_needed = 9,500 - 9,456 = 44
        fraction = 44 / 333 = 0.132
        p95 = 150 + (200 - 150) * 0.132 = 156.6ms
      |
    }
    p99_calc: {
      label: "p99"
      shape: rectangle
      width: 350
      code: |md
        target = 0.99 * 10,000 = 9,900th request
        bucket{le='200'} has 9,789 < 9,900
        bucket{le='500'} has 9,956 ≥ 9,900 ✓
        prev_count = 9,789, prev_bound = 200
        obs_in_bucket = 9,956 - 9,789 = 167
        obs_needed = 9,900 - 9,789 = 111
        fraction = 111 / 167 = 0.665
        p99 = 200 + (500 - 200) * 0.665 = 399.5ms
      |
    }
  }
}
row3_arrow: row3.percentile_examples -> row4.prometheus: "Export | format"
