  prometheus: {
    label: "Prometheus Text Exposition Format"
    direction: down
    metric_output: {
      label: "/metrics endpoint output"
      width: 420
      code: |md
        # TYPE model_inference_latency_ms histogram
        model_inference_latency_ms_bucket{le="1",version="v1.0.0"} 0
        model_inference_latency_ms_bucket{le="5",version="v1.0.0"} 23
        model_inference_latency_ms_bucket{le="10",version="v1.0.0"} 156
        model_inference_latency_ms_bucket{le="25",version="v1.0.0"} 892
        model_inference_latency_ms_bucket{le="50",version="v1.0.0"} 5247
        model_inference_latency_ms_bucket{le="75",version="v1.0.0"} 7834
        model_inference_latency_ms_bucket{le="100",version="v1.0.0"} 8912
        model_inference_latency_ms_bucket{le="150",version="v1.0.0"} 9456
        model_inference_latency_ms_bucket{le="200",version="v1.0.0"} 9789
        model_inference_latency_ms_bucket{le="500",version="v1.0.0"} 9956
        model_inference_latency_ms_bucket{le="+Inf",version="v1.0.0"} 10000
        model_inference_latency_ms_sum{version="v1.0.0"} 523847.0
        model_inference_latency_ms_count{version="v1.0.0"} 10000
      |
    }
  }
  promql: {
    label: "PromQL Queries"
    direction: down
    queries: {
      label: "Common PromQL Percentile Queries"
      width: 420
      code: |md
        # p50 latency over 5 minutes
        histogram_quantile(0.50, 
          rate(model_inference_latency_ms_bucket[5m])
        )
        # p95 latency per version
        histogram_quantile(0.95, 
          sum by (le, version) (
            rate(model_inference_latency_ms_bucket[5m])
          )
        )
        # p99 latency - alert threshold
        histogram_quantile(0.99, 
          rate(model_inference_latency_ms_bucket[5m])
        ) > 500
        # Request rate (from _count)
        rate(model_inference_latency_ms_count[1m])
        # Average latency (from _sum / _count)
        rate(model_inference_latency_ms_sum[5m) 
          / rate(model_inference_latency_ms_count[5m])
      |
    }
  }
}
# Row 5: SLA-Aligned Buckets
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sla_buckets: {
    label: "SLA-Aligned Bucket Design"
    direction: down
    default_vs_sla: {
      shape: sql_table
      label: "Bucket Strategy Comparison"
      r1: "Default Buckets | [1,5,10,25,50,75,100,150,200,300,500,750,1000,2000,5000]"
      r2: "SLA-Aligned (p99=200ms) | [50,100,150,200,250,300,400,500,1000]"
      r3: "Rationale | Put buckets at 0.5x, 0.75x, 1x, 1.25x, 1.5x, 2x your SLA"
    }
    sla_code: {
      label: "create_for_sla() method"
      width: 380
      code: |'python
@classmethod
def create_for_sla(cls, p99_sla_ms: float):
    """
    Create histogram with buckets aligned to SLA.
    Ensures detection when latency approaches SLA.
    """
    multipliers = [0.25, 0.5, 0.75, 1.0, 1.25, 1.5, 2.0, 3.0, 5.0]
    bounds = [p99_sla_ms * m for m in multipliers]
    # Add fine-grained buckets below SLA
    fine_bounds = [1, 5, 10, 25, 50]
    all_bounds = sorted(set(fine_bounds + bounds))
    return cls(buckets=[
        HistogramBucket(upper_bound=b) 
        for b in all_bounds
    ])
'|
    }
  }
  accuracy_note: {
    label: "Approximation Accuracy"
    direction: down
    accuracy_table: {
      shape: sql_table
      label: "Trade-off: Bucket Width vs Accuracy"
      r1: "Narrow buckets | High accuracy | More memory/compute"
      r2: "Wide buckets | Low accuracy | Less memory/compute"
      r3: "Rule of thumb | Bucket width ≤ 10% of target percentile"
    }
    example: {
      label: "Example Error"
      width: 350
      code: |md
        True p99: 398ms
        Bucket boundaries: [..., 200, 500, ...]
        Without interpolation:
          Would report p99 ∈ (200, 500)
          Error: up to 302ms!
        With linear interpolation:
          Reports p99 ≈ 399.5ms
          Error: ~1.5ms (0.4%)
      |
    }
  }
}
# Final summary
summary: {
  label: "Key Insights"
  near: bottom-center
  width: 800
  code: |md
    1. **Cumulative buckets**: Prometheus convention - each bucket counts ALL observations ≤ its boundary
    2. **Linear interpolation**: Percentiles are approximated by interpolating within the containing bucket
    3. **SLA-aligned buckets**: Design bucket boundaries around your SLAs for meaningful alerts
    4. **Three required metrics**: `_bucket` (per boundary), `_sum` (total), `_count` (observations)
    5. **Bounded memory**: Fixed number of buckets regardless of observation count
  |
}
