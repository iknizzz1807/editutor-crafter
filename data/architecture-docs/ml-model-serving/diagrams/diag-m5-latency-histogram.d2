      sum_row: "_sum | 523,847.0"
      count_row: "_count | 10,000"
    }
    cumulative_note: {
      label: "Cumulative Convention"
      width: 320
      code: |md
        Each bucket count = ALL observations
        less than or equal to bucket boundary.
        bucket{le='50'} = 5,247 means:
        5,247 requests had latency < 50ms
        NOT 5,247 requests in [25, 50) range!
      |
    }
  }
  visual_histogram: {
