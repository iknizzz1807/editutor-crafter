direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    loader: "#E8F5E9"
    batcher: "#E3F2FD"
    router: "#FFF3E0"
    splitter: "#F3E5F5"
    monitor: "#FFEBEE"
    request: "#FAFAFA"
    core: "#ECEFF1"
  }
}
title: |md
  # ML Model Serving: Interactive Atlas
  Satellite View — Five Milestones as Interconnected Regions
| {near: top-center}
# External Request Layer
row_request: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  client: Client {
    shape: person
    style.fill: ${colors.request}
  }
  api_gateway: API Gateway {
    style.fill: ${colors.request}
    width: 140
  }
  client -> api_gateway: HTTP Request
}
# Core Pipeline (Row 1)
row_core: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # M1: Model Loader Region
  m1_region: "M1: Model Loader" {
    style.fill: ${colors.loader}
    style.stroke: "#4CAF50"
    link: layers.m1
    m1_components: {
      direction: down
      device_detector: Device Detector {
        width: 120
        style.fill: white
      }
      memory_checker: Memory Budget {
        width: 120
        style.fill: white
      }
      model_loader: Model Load {
        width: 120
        style.fill: white
      }
      warmup: CUDA Warmup {
        width: 120
        style.fill: white
      }
      device_detector -> memory_checker: "GPU/CPU"
      memory_checker -> model_loader: "OK"
      model_loader -> warmup: "Loaded"
    }
    m1_struct: LoadedModel {
      shape: sql_table
      label: "struct LoadedModel (loader.h)"
      f0: "0x00 | nn.Module  | model"
      f1: "0x08 | Device    | device"
      f2: "0x10 | string    | version"
      f3: "0x18 | float     | warmup_ms"
      sz: "Total: 32 bytes"
    }
  }
  # M2: Request Batcher Region
  m2_region: "M2: Request Batcher" {
    style.fill: ${colors.batcher}
    style.stroke: "#2196F3"
    link: layers.m2
    m2_components: {
      direction: down
      request_queue: Request Queue {
        shape: queue
        width: 120
        style.fill: white
      }
      batch_former: Batch Former {
        width: 120
        style.fill: white
      }
      padder: Variable Padder {
        width: 120
        style.fill: white
      }
      inference: Batch Inference {
        width: 120
        style.fill: white
      }
      request_queue -> batch_former: "deque"
      batch_former -> padder: "List[Request]"
      padder -> inference: "Tensor[B,N,...]"
    }
    m2_struct: BatchRequest {
      shape: sql_table
      label: "struct BatchRequest (batcher.h)"
      f0: "0x00 | string    | request_id"
      f1: "0x08 | Tensor    | input"
      f2: "0x10 | Future    | result"
      f3: "0x18 | float     | arrival_ts"
      sz: "Total: 40 bytes"
    }
  }
}
# Version Management Layer (Row 2)
row_version: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # M3: Version Router Region
  m3_region: "M3: Version Router" {
    style.fill: ${colors.router}
    style.stroke: "#FF9800"
    link: layers.m3
    m3_components: {
      direction: down
      registry: Model Registry {
        width: 130
        style.fill: white
      }
      atomic_ptr: Atomic Pointer {
        width: 130
        style.fill: white
      }
      drainer: Request Drainer {
        width: 130
        style.fill: white
      }
      rollback: Rollback Handler {
        width: 130
        style.fill: white
      }
      registry -> atomic_ptr: "version_id"
      atomic_ptr -> drainer: "swap"
      drainer -> rollback: "drained"
    }
    m3_struct: ModelVersion {
      shape: sql_table
      label: "struct ModelVersion (registry.h)"
      f0: "0x00 | string      | version_id"
      f1: "0x08 | nn.Module   | model"
      f2: "0x10 | VersionStat | status"
      f3: "0x18 | int         | in_flight"
      f4: "0x20 | Schema      | schema"
      sz: "Total: 56 bytes"
    }
  }
  # M4: Traffic Splitter Region
  m4_region: "M4: Traffic Splitter" {
    style.fill: ${colors.splitter}
    style.stroke: "#9C27B0"
    link: layers.m4
    m4_components: {
      direction: down
      hasher: Consistent Hash {
        width: 130
        style.fill: white
      }
      splitter: Traffic Split {
        width: 130
        style.fill: white
      }
      canary: Canary Controller {
        width: 130
        style.fill: white
      }
      stats: Statistical Analyzer {
        width: 130
        style.fill: white
      }
      hasher -> splitter: "hash % 100"
      splitter -> canary: "version_id"
      canary -> stats: "metrics"
    }
    m4_struct: TrafficAllocation {
      shape: sql_table
      label: "struct TrafficAllocation (splitter.h)"
      f0: "0x00 | string | version_id"
      f1: "0x08 | float  | weight_pct"
      f2: "0x10 | string | description"
      sz: "Total: 24 bytes"
    }
  }
}
# Monitoring Layer (Row 3)
row_monitor: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  # M5: Monitoring Region
  m5_region: "M5: Monitoring & Drift" {
    style.fill: ${colors.monitor}
    style.stroke: "#F44336"
    link: layers.m5
    m5_components: {
      direction: down
      latency: Latency Histogram {
        width: 130
        style.fill: white
      }
      prediction: Prediction Monitor {
        width: 130
        style.fill: white
      }
      drift: KS Test Detector {
        width: 130
        style.fill: white
      }
      alerts: Alert Manager {
        width: 130
        style.fill: white
      }
      latency -> prediction: "p50/p99"
      prediction -> drift: "distribution"
      drift -> alerts: "p_value"
    }
    m5_struct: DriftResult {
      shape: sql_table
      label: "struct KSTestResult (drift.h)"
      f0: "0x00 | string | feature"
      f1: "0x08 | float  | d_statistic"
      f2: "0x10 | float  | p_value"
      f3: "0x18 | bool   | significant"
      sz: "Total: 32 bytes"
    }
  }
  # Output Layer
  output_region: Output {
    style.fill: ${colors.core}
    width: 200
    response: Response {
      style.fill: white
    }
    metrics_export: Prometheus Metrics {
      style.fill: white
    }
    alert_channel: Alert Channel {
      style.fill: white
    }
    response -> metrics_export
    metrics_export -> alert_channel
  }
}
# Data Flow Arrows (Cross-Region)
row_request.api_gateway -> row_core.m1_region.m1_components.device_detector: "POST /predict" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
row_core.m1_region.m1_components.warmup -> row_core.m2_region.m2_components.request_queue: "LoadedModel | ready" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
}
row_core.m2_region.m2_components.inference -> row_version.m3_region.m3_components.registry: "Tensor | predict" {
  style.stroke: "#FF9800"
  style.stroke-width: 3
}
row_version.m3_region.m3_components.atomic_ptr -> row_version.m4_region.m4_components.splitter: "version_id | route" {
  style.stroke: "#9C27B0"
  style.stroke-width: 3
}
row_version.m4_region.m4_components.stats -> row_monitor.m5_region.m5_components.latency: "Metrics | observe" {
  style.stroke: "#F44336"
  style.stroke-width: 3
}
row_monitor.m5_region.m5_components.alerts -> row_monitor.output_region.alert_channel: "Alert | fire" {
  style.stroke: red
  style.stroke-dash: 4
}
# Backpressure Flow (Dashed)
row_core.m2_region.m2_components.request_queue -> row_request.api_gateway: "503 | backpressure" {
  style.stroke: red
  style.stroke-dash: 4
  style.animated: true
}
# Rollback Flow (Dashed)
row_monitor.m5_region.m5_components.alerts -> row_version.m3_region.m3_components.rollback: "rollback | trigger" {
  style.stroke: orange
  style.stroke-dash: 4
}
# Legend
legend: Legend {
  near: bottom-right
  style.fill: white
  style.stroke: "#BDBDBD"
  l1: M1 Model Loader {
    style.fill: ${colors.loader}
  }
  l2: M2 Request Batcher {
    style.fill: ${colors.batcher}
  }
  l3: M3 Version Router {
    style.fill: ${colors.router}
  }
  l4: M4 Traffic Splitter {
    style.fill: ${colors.splitter}
  }
  l5: M5 Monitoring {
    style.fill: ${colors.monitor}
  }
  l1 -> l2 -> l3 -> l4 -> l5
}
# Layers for Drill-Down
layers: {
  m1: {
    title: |md
      # M1: Model Loading, Inference & Serialization
      Click any component for implementation details
    | {near: top-center}
    direction: down
    phase1: "Phase 1: Device Detection" {
      style.fill: ${colors.loader}
      device_check: {
        label: "Device Detection (loader.c)"
        code: |'python
          def get_device() -> torch.device:
              if torch.cuda.is_available():
                  device = torch.device("cuda")
                  gpu_name = torch.cuda.get_device_name(0)
                  gpu_memory = torch.cuda.get_device_properties(0).total_memory / 1e9
                  print(f"[Device] Using CUDA: {gpu_name} ({gpu_memory:.1f} GB)")
              else:
                  device = torch.device("cpu")
                  print("[Device] CUDA not available, using CPU")
              return device
        '|
        width: 400
      }
    }
    phase2: "Phase 2: Memory Budget" {
      style.fill: ${colors.loader}
      memory_check: {
        label: "Memory Budget Validation (loader.c)"
        code: |'python
          def check_memory_budget(model_path, device, safety_margin=0.3):
              model_size = os.path.getsize(model_path)
              if device.type == "cuda":
                  total = torch.cuda.get_device_properties(0).total_memory
                  free = total - torch.cuda.memory_reserved(0)
                  required = model_size * 4  # Model + activations
                  if free - required < total * safety_margin:
                      raise RuntimeError(f"Insufficient GPU memory")
        '|
        width: 400
      }
    }
    phase3: "Phase 3: Model Load + Eval" {
      style.fill: ${colors.loader}
      model_load: {
        label: "Model Loading (loader.c)"
        code: |'python
          def load_model(model_path, device) -> nn.Module:
              model = torch.load(model_path, map_location=device)
              model.eval()  # CRITICAL: Disable dropout/batchnorm train mode
              model = model.to(device)
              return model
        '|
        width: 400
      }
    }
    phase4: "Phase 4: CUDA Warmup" {
      style.fill: ${colors.loader}
      warmup: {
        label: "CUDA Warmup (loader.c)"
        code: |'python
          def warmup_model(model, device, input_shape, n_runs=5):
              dummy = torch.randn(input_shape, device=device)
              for i in range(n_runs):
                  with torch.no_grad():
                      _ = model(dummy)
                  # First run: ~500ms (kernel compilation)
                  # Subsequent: ~50ms (cached kernels)
        '|
        width: 400
      }
    }
    phase1 -> phase2 -> phase3 -> phase4
  }
  m2: {
    title: |md
      # M2: Request Batching
      Dynamic batching for GPU throughput optimization
    | {near: top-center}
    direction: down
    queue_arch: Queue Architecture {
      style.fill: ${colors.batcher}
      batch_request: {
        shape: sql_table
        label: "struct BatchRequest (batcher.h)"
        f0: "0x00 | str      | request_id"
        f1: "0x08 | Tensor   | input_tensor"
        f2: "0x10 | Future   | result_future"
        f3: "0x18 | float    | arrival_time"
        f4: "0x20 | Status   | status"
        sz: "Total: 48 bytes"
      }
      request_queue: {
        shape: class
        label: "RequestQueue (batcher.h)"
        -queue: "asyncio.Queue"
        -max_depth: "int"
        +enqueue(req): "bool"
        +get_batch(max_size, timeout): "List[BatchRequest]"
        +qsize(): "int"
      }
    }
    batch_formation: Batch Formation Loop {
      style.fill: ${colors.batcher}
      loop_code: {
        label: "Batch Formation (batcher.c)"
        code: |'python
          async def _batch_loop(self):
              while self._running:
                  # Wait for first request (with timeout)
                  batch = await self.queue.get_batch(
                      max_batch_size=32,
                      timeout_ms=50.0
                  )
                  if not batch:
                      continue
                  # Pad variable-length inputs
                  inputs, mask = self._pad_and_stack(batch)
                  # Single GPU kernel launch for entire batch
                  outputs = await self._run_inference(inputs)
                  # Route results back to each requester
                  self._route_results(outputs, batch)
        '|
        width: 450
      }
    }
    padding: Variable-Length Padding {
      style.fill: ${colors.batcher}
      pad_code: {
        label: "Padding Logic (batcher.c)"
        code: |'python
          def _pad_and_stack(self, tensors):
              max_len = max(t.shape[1] for t in tensors)
              padded = torch.zeros(batch, max_len, features)
              mask = torch.zeros(batch, max_len)
              for i, t in enumerate(tensors):
                  seq_len = t.shape[1]
                  padded[i, :seq_len] = t
                  mask[i, :seq_len] = 1  # Real tokens
              return padded, mask  # mask=1 for real, 0 for pad
        '|
        width: 450
      }
    }
    queue_arch -> batch_formation -> padding
  }
  m3: {
    title: |md
      # M3: Model Versioning & Hot Reload
      Zero-downtime deployment with atomic pointer swaps
    | {near: top-center}
    direction: down
    registry: Model Registry {
      style.fill: ${colors.router}
      version_struct: {
        shape: sql_table
        label: "struct ModelVersion (registry.h)"
        f0: "0x00 | str          | version_id"
        f1: "0x08 | str          | model_path"
        f2: "0x10 | VersionStat  | status"
        f3: "0x18 | nn.Module    | loaded_model"
        f4: "0x20 | Schema       | schema"
        f5: "0x28 | int          | in_flight_count"
        sz: "Total: 64 bytes"
      }
    }
    hot_swap: Hot Swap Sequence {
      style.fill: ${colors.router}
      swap_code: {
        label: "Atomic Swap (hotswap.c)"
        code: |'python
          async def hot_swap(self, new_version_id):
              # 1. Load new version (parallel with serving)
              new_version = await self.load_version(new_version_id)
              # 2. Validate schema compatibility
              if not self.validate_schema(active, new_version):
                  return False, "Schema incompatible"
              # 3. Atomic pointer swap (O(1))
              old_version = await self.pointer.swap(new_version)
              # 4. Drain old version in-flight requests
              await self.tracker.wait_for_drain(old_version.version_id)
              # 5. Unload old version
              await self.unload_version(old_version)
        '|
        width: 450
      }
    }
    draining: Request Draining {
      style.fill: ${colors.router}
      drain_code: {
        label: "Drain Tracking (drainer.c)"
        code: |'python
          class RequestTracker:
              async def acquire(self, version_id):
                  self._counts[version_id] += 1
              async def release(self, version_id):
                  self._counts[version_id] -= 1
                  if self._counts[version_id] == 0:
                      self._drain_events[version_id].set()
              async def wait_for_drain(self, version_id, timeout=30):
                  await asyncio.wait_for(
                      self._drain_events[version_id].wait(),
                      timeout=timeout
                  )
        '|
        width: 450
      }
    }
    registry -> hot_swap -> draining
  }
  m4: {
    title: |md
      # M4: A/B Testing & Canary Deployment
      Statistically rigorous experimentation
    | {near: top-center}
    direction: down
    routing: Deterministic Routing {
      style.fill: ${colors.splitter}
      hash_code: {
        label: "Consistent Hashing (splitter.c)"
        code: |'python
          class TrafficSplitter:
              def _hash_user(self, user_id: str) -> int:
                  hash_bytes = hashlib.sha256(user_id.encode()).digest()
                  hash_int = int.from_bytes(hash_bytes[:8], 'big')
                  return hash_int % 100  # Percentile bucket
              def route(self, user_id: str) -> str:
                  user_hash = self._hash_user(user_id)
                  cumulative = 0.0
                  for alloc in self.allocations:
                      cumulative += alloc.weight_percent
                      if user_hash < cumulative:
                          return alloc.version_id  # Deterministic!
        '|
        width: 450
      }
    }
    canary: Canary Controller {
      style.fill: ${colors.splitter}
      canary_code: {
        label: "Canary Rollout (canary.c)"
        code: |'python
          class CanaryRolloutController:
              # Stages: 5% -> 10% -> 25% -> 50% -> 100%
              async def _rollout_loop(self):
                  for canary_pct in [5, 10, 25, 50, 100]:
                      self._update_splitter(canary_pct)
                      await asyncio.sleep(stage_duration)
                      # Health check at each stage
                      is_healthy = await self.health_checker.check(
                          stable_version, canary_version
                      )
                      if not is_healthy:
                          await self._trigger_rollback(reason)
                          return
        '|
        width: 450
      }
    }
    stats: Statistical Analysis {
      style.fill: ${colors.splitter}
      stats_code: {
        label: "Significance Testing (stats.c)"
        code: |'python
          class StatisticalAnalyzer:
              def two_sample_t_test(self, sample_a, sample_b):
                  # H0: means are equal
                  # H1: means are different
                  se_diff = sqrt(se_a**2 + se_b**2)
                  t_stat = (mean_a - mean_b) / se_diff
                  p_value = self._t_p_value(t_stat, df)
                  return TestResult(
                      p_value=p_value,
                      is_significant=(p_value < 0.05)
                  )
        '|
        width: 450
      }
    }
    routing -> canary -> stats
  }
  m5: {
    title: |md
      # M5: Monitoring & Drift Detection
      Statistical drift detection with KS tests
    | {near: top-center}
    direction: down
    latency_mon: Latency Monitoring {
      style.fill: ${colors.monitor}
      histogram: {
        label: "Prometheus Histogram (monitor.c)"
        code: |'python
          class LatencyHistogram:
              # Buckets: 1, 5, 10, 25, 50, 75, 100, 150, 200, 300, 500, 750, 1000ms
              def observe(self, latency_ms):
                  for bucket in self.buckets:
                      if latency_ms < bucket.upper_bound:
                          bucket.count += 1  # Cumulative
              def percentile(self, p):
                  target = (p / 100.0) * self.count_total
                  # Linear interpolation within bucket
                  return interpolated_value
        '|
        width: 450
      }
    }
    drift_det: Drift Detection {
      style.fill: ${colors.monitor}
      ks_test: {
        label: "KS Test (drift.c)"
        code: |'python
          class KSTestDetector:
              def test(self, baseline, live_samples):
                  # H0: Same distribution
                  # H1: Different distribution
                  # Compute CDFs
                  cdf_baseline = self._compute_cdf(baseline.sorted)
                  cdf_live = self._compute_cdf(sorted(live_samples))
                  # KS statistic = max vertical distance
                  D = max(|cdf_baseline(x) - cdf_live(x)|)
                  # p-value from asymptotic distribution
                  p_value = self._ks_p_value(D, n1, n2)
                  return KSTestResult(D, p_value, p_value < 0.01)
        '|
        width: 450
      }
    }
    sampling: Sampling Strategy {
      style.fill: ${colors.monitor}
      sampler: {
        label: "Reservoir Sampling (sampler.c)"
        code: |'python
          class DriftDetectionSampler:
              sample_rate = 1000  # 1 in 1000 requests
              def should_sample(self):
                  self._request_counter += 1
                  return self._request_counter % self.sample_rate == 0
              def record_features(self, features):
                  for name, value in features.items():
                      # Reservoir sampling maintains
                      # representative sample of stream
                      self._buffers[name].add(value)
        '|
        width: 450
      }
    }
    latency_mon -> drift_det -> sampling
  }
}