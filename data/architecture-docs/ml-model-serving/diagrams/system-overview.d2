direction: right
# ML Model Serving API - System Blueprint
# Implementation-Ready Architecture Diagram
variables: {
  milestone-color: "#E3F2FD"
  core-color: "#FFF3E0"
  data-color: "#E8F5E9"
  infra-color: "#F3E5F5"
}
# ============= MILESTONE NAVIGATION =============
Nav: {
  shape: sql_table
  M1: {
    label: "M1: Model Loading"
    link: "#m1-model-loading"
  }
  M2: {
    label: "M2: Request Batching"
    link: "#m2-request-batching"
  }
  M3: {
    label: "M3: Model Versioning"
    link: "#m3-model-versioning"
  }
  M4: {
    label: "M4: A/B Testing"
    link: "#m4-ab-testing"
  }
  M5: {
    label: "M5: Monitoring & Drift"
    link: "#m5-monitoring-drift-detection"
  }
}
# ============= M1: MODEL LOADING =============
M1: {
  label: "M1: Model Loading"
  link: "#m1-model-loading"
  M1_Schema: {
    label: "schema.py"
    shape: sql_table
    InferenceRequest: {
      id: "str"
      inputs: "List[Union[str, float, List[float]]]"
      parameters: "Optional[Dict[str, Any]]"
    }
    InferenceRequest.__fields__: {
      id: "PK, str - Unique request identifier"
      inputs: "List[Union[str, float, List[float]]] - Tokenized or raw inputs"
      parameters: "Optional[Dict[str, Any]] - Model-specific parameters"
    }
    InferenceResponse: {
      id: "str"
      model_version: "str"
      outputs: "List[Union[int, float, List[float], str]]"
      latency_ms: "float"
      drift_score: "Optional[float]"
    }
    ModelMetadata: {
      model_id: "str"
      version: "str"
      framework: "Literal[torch, tensorflow, onnx]"
      input_shape: "List[int]"
      output_shape: "List[int]"
      dtype: "str"
    }
  }
  M1_Device: {
    label: "device.py"
    shape: sql_table
    DeviceManager: {
      _device: "torch.device"
      _memory_fraction: "float"
    }
    DeviceManager.__methods__: {
      get_device: "() -> torch.device"
      get_device_name: "() -> str"
      get_memory_info: "() -> Dict[str, float]"
      set_memory_fraction: "(fraction: float) -> None"
      synchronize: "() -> None"
    }
  }
  M1_ModelLoader: {
    label: "model_loader.py"
    shape: sql_table
    ModelLoader: {
      _cache: "Dict[str, torch.nn.Module]"
      _device: "torch.device"
      _load_hooks: "List[Callable]"
    }
    ModelLoader.__methods__: {
      load: "(path: str) -> torch.nn.Module"
      load_from_registry: "(model_id: str, version: str) -> torch.nn.Module"
      _deserialize: "(data: bytes, framework: str) -> torch.nn.Module"
      _validate_model: "(model: torch.nn.Module) -> bool"
      register_hook: "(hook: Callable) -> None"
      clear_cache: "() -> None"
    }
  }
  M1_Warmup: {
    label: "warmup.py"
    shape: sql_table
    WarmupRunner: {
      _model: "torch.nn.Module"
      _device: "torch.device"
      _warmup_samples: "int"
      _warmup_batch_sizes: "List[int]"
    }
    WarmupRunner.__methods__: {
      run: "() -> WarmupResult"
      _generate_dummy_input: "(shape: List[int]) -> torch.Tensor"
      _run_inference_cycles: "(n: int, batch_size: int) -> List[float]"
    }
    WarmupResult: {
      success: "bool"
      warmup_latency_ms: "float"
      memory_allocated_mb: "float"
    }
  }
  M1_Serialization: {
    label: "serialization.py"
    shape: sql_table
    Serializer: {
      _format: "Literal[torch, onnx, safetensors]"
    }
    Serializer.__methods__: {
      serialize: "(model: torch.nn.Module) -> bytes"
      deserialize: "(data: bytes) -> torch.nn.Module"
      to_onnx: "(model: torch.nn.Module, path: str) -> None"
      from_onnx: "(path: str) -> onnx.ModelProto"
    }
  }
  M1_Health: {
    label: "health.py"
    shape: sql_table
    HealthChecker: {
      _model_container: "ModelContainer"
      _last_check: "datetime"
      _check_interval_s: "float"
    }
    HealthChecker.__methods__: {
      check: "() -> HealthStatus"
      _check_device_memory: "() -> float"
      _check_model_responsive: "() -> bool"
    }
    HealthStatus: {
      healthy: "bool"
      model_loaded: "bool"
      device_memory_used: "float"
      last_inference_ms: "Optional[float]"
    }
  }
  M1_Container: {
    label: "model_container.py"
    shape: sql_table
    ModelContainer: {
      _model: "torch.nn.Module"
      _metadata: "ModelMetadata"
      _device: "torch.device"
      _is_ready: "bool"
    }
    ModelContainer.__methods__: {
      predict: "(inputs: torch.Tensor) -> torch.Tensor"
      predict_batch: "(inputs: List[torch.Tensor]) -> List[torch.Tensor]"
      get_metadata: "() -> ModelMetadata"
      is_ready: "() -> bool"
      _set_model: "(model: torch.nn.Module) -> None"
    }
  }
  M1_Lifespan: {
    label: "lifespan.py"
    shape: sql_table
    LifespanManager: {
      _container: "ModelContainer"
      _loader: "ModelLoader"
      _warmup: "WarmupRunner"
      _config: "Config"
    }
    LifespanManager.__methods__: {
      startup: "() -> None"
      shutdown: "() -> None"
      reload_model: "(version: str) -> None"
    }
  }
  M1_Endpoints: {
    label: "endpoints.py"
    shape: sql_table
    Endpoints.__methods__: {
      infer: "(request: InferenceRequest) -> InferenceResponse"
      batch_infer: "(requests: List[InferenceRequest]) -> List[InferenceResponse]"
      health: "() -> HealthStatus"
      metadata: "() -> ModelMetadata"
    }
  }
  M1_Main: {
    label: "main.py"
    shape: sql_table
    App.__methods__: {
      create_app: "() -> FastAPI"
      register_routes: "(app: FastAPI) -> None"
      register_middleware: "(app: FastAPI) -> None"
    }
  }
}
M1_Device -> M1_ModelLoader: "provides device"
M1_ModelLoader -> M1_Container: "loads model"
M1_Warmup -> M1_Container: "warms up"
M1_Schema -> M1_Endpoints: "defines types"
M1_Serialization -> M1_ModelLoader: "deserializes"
M1_Health -> M1_Container: "checks"
M1_Container -> M1_Lifespan: "managed by"
M1_Lifespan -> M1_Main: "initializes"
M1_Endpoints -> M1_Main: "registered in"
# ============= M2: REQUEST BATCHING =============
M2: {
  label: "M2: Request Batching"
  link: "#m2-request-batching"
  M2_Queue: {
    label: "request_queue.py"
    shape: sql_table
    RequestQueue: {
      _queue: "asyncio.Queue[InferenceRequest]"
      _max_size: "int"
      _timeout_ms: "float"
      _pending_futures: "Dict[str, asyncio.Future]"
    }
    RequestQueue.__methods__: {
      enqueue: "(request: InferenceRequest) -> asyncio.Future"
      dequeue_batch: "(max_batch: int, timeout_ms: float) -> List[Tuple[InferenceRequest, asyncio.Future]]"
      _resolve_future: "(request_id: str, result: Any) -> None"
      size: "() -> int"
    }
  }
  M2_Padder: {
    label: "padder.py"
    shape: sql_table
    Padder: {
      _pad_value: "float"
      _pad_side: "Literal[left, right]"
    }
    Padder.__methods__: {
      pad_batch: "(inputs: List[torch.Tensor]) -> Tuple[torch.Tensor, List[List[int]]]"
      unpad_batch: "(outputs: torch.Tensor, lengths: List[List[int]]) -> List[torch.Tensor]"
      _compute_lengths: "(tensors: List[torch.Tensor]) -> List[List[int]]"
    }
    PaddingResult: {
      padded_tensor: "torch.Tensor"
      original_lengths: "List[List[int]]"
      mask: "Optional[torch.Tensor]"
    }
  }
  M2_Batcher: {
    label: "batcher.py"
    shape: sql_table
    DynamicBatcher: {
      _queue: "RequestQueue"
      _padder: "Padder"
      _model: "ModelContainer"
      _max_batch_size: "int"
      _max_wait_ms: "float"
      _batch_event: "asyncio.Event"
    }
    DynamicBatcher.__methods__: {
      start: "() -> None"
      stop: "() -> None"
      _batch_loop: "() -> None"
      _process_batch: "(requests: List, futures: List) -> None"
      submit: "(request: InferenceRequest) -> asyncio.Future"
    }
  }
  M2_Router: {
    label: "result_router.py"
    shape: sql_table
    ResultRouter: {
      _pending: "Dict[str, asyncio.Future]"
    }
    ResultRouter.__methods__: {
      register: "(request_id: str, future: asyncio.Future) -> None"
      resolve: "(request_id: str, result: InferenceResponse) -> None"
      resolve_batch: "(results: List[InferenceResponse]) -> None"
      reject: "(request_id: str, error: Exception) -> None"
    }
  }
  M2_Metrics: {
    label: "metrics.py"
    shape: sql_table
    BatchMetrics: {
      _batch_sizes: "List[int]"
      _batch_latencies: "List[float]"
      _queue_times: "List[float]"
    }
    BatchMetrics.__methods__: {
      record_batch: "(size: int, latency_ms: float, queue_time_ms: float) -> None"
      get_avg_batch_size: "() -> float"
      get_p99_latency: "() -> float"
      get_throughput: "() -> float"
    }
  }
  M2_Benchmark: {
    label: "benchmark.py"
    shape: sql_table
    BenchmarkRunner: {
      _batcher: "DynamicBatcher"
      _n_requests: "int"
      _concurrency: "int"
    }
    BenchmarkRunner.__methods__: {
      run: "() -> BenchmarkResult"
      _generate_requests: "(n: int) -> List[InferenceRequest]"
      _measure_latency: "() -> List[float]"
    }
    BenchmarkResult: {
      total_requests: "int"
      avg_latency_ms: "float"
      p50_latency_ms: "float"
      p99_latency_ms: "float"
      throughput_rps: "float"
    }
  }
}
M2_Queue -> M2_Batcher: "provides requests"
M2_Padder -> M2_Batcher: "pads inputs"
M2_Batcher -> M2_Router: "routes results"
M2_Batcher -> M2_Metrics: "records"
M2_Batcher -> M2_Benchmark: "benchmarked by"
# M1 to M2 dependencies
M1_Container -> M2_Batcher: "model for inference"
M1_Schema -> M2_Queue: "request types"
# ============= M3: MODEL VERSIONING =============
M3: {
  label: "M3: Model Versioning"
  link: "#m3-model-versioning"
  M3_Schema: {
    label: "schema.py"
    shape: sql_table
    VersionInfo: {
      version: "str"
      created_at: "datetime"
      model_path: "str"
      checksum: "str"
      status: "Literal[loading, active, deprecated, failed]"
    }
    VersionTransition: {
      from_version: "str"
      to_version: "str"
      timestamp: "datetime"
      trigger: "Literal[manual, auto, rollback]"
    }
  }
  M3_ModelVersion: {
    label: "model_version.py"
    shape: sql_table
    ModelVersion: {
      version: "str"
      model: "torch.nn.Module"
      metadata: "ModelMetadata"
      loaded_at: "datetime"
      inference_count: "int"
    }
    ModelVersion.__methods__: {
      predict: "(inputs: torch.Tensor) -> torch.Tensor"
      increment_inference_count: "() -> None"
      get_stats: "() -> VersionStats"
    }
  }
  M3_Registry: {
    label: "model_registry.py"
    shape: sql_table
    ModelRegistry: {
      _versions: "Dict[str, ModelVersion]"
      _storage_backend: "StorageBackend"
      _active_version: "Optional[str]"
    }
    ModelRegistry.__methods__: {
      register: "(version: str, path: str) -> ModelVersion"
      get: "(version: str) -> ModelVersion"
      get_active: "() -> ModelVersion"
      set_active: "(version: str) -> None"
      list_versions: "() -> List[VersionInfo]"
      deprecate: "(version: str) -> None"
    }
  }
  M3_AtomicPointer: {
    label: "atomic_pointer.py"
    shape: sql_table
    AtomicModelPointer: {
      _pointer: "Optional[ModelVersion]"
      _lock: "threading.RLock"
    }
    AtomicModelPointer.__methods__: {
      get: "() -> Optional[ModelVersion]"
      set: "(model: ModelVersion) -> None"
      swap: "(new_model: ModelVersion) -> ModelVersion"
      compare_and_swap: "(expected: ModelVersion, new: ModelVersion) -> bool"
    }
  }
  M3_Tracker: {
    label: "request_tracker.py"
    shape: sql_table
    RequestTracker: {
      _inflight: "Dict[str, str]"
      _version_counts: "Dict[str, int]"
    }
    RequestTracker.__methods__: {
      start_request: "(request_id: str, version: str) -> None"
      end_request: "(request_id: str) -> None"
      get_inflight_count: "(version: str) -> int"
      wait_for_drain: "(version: str, timeout_s: float) -> bool"
    }
  }
  M3_HotSwap: {
    label: "hot_swap_manager.py"
    shape: sql_table
    HotSwapManager: {
      _pointer: "AtomicModelPointer"
      _registry: "ModelRegistry"
      _tracker: "RequestTracker"
      _swap_hooks: "List[Callable]"
    }
    HotSwapManager.__methods__: {
      hot_swap: "(new_version: str) -> SwapResult"
      _load_new_version: "(version: str) -> ModelVersion"
      _wait_for_drain: "(old_version: str) -> bool"
      _notify_hooks: "() -> None"
    }
    SwapResult: {
      success: "bool"
      old_version: "str"
      new_version: "str"
      drain_time_ms: "float"
    }
  }
  M3_Rollback: {
    label: "rollback_monitor.py"
    shape: sql_table
    RollbackMonitor: {
      _error_threshold: "float"
      _latency_threshold_ms: "float"
      _window_size: "int"
      _error_counts: "Dict[str, int]"
    }
    RollbackMonitor.__methods__: {
      record_error: "(version: str) -> None"
      record_success: "(version: str) -> None"
      should_rollback: "(version: str) -> bool"
      get_error_rate: "(version: str) -> float"
    }
  }
  M3_Router: {
    label: "version_router.py"
    shape: sql_table
    VersionRouter: {
      _pointer: "AtomicModelPointer"
      _tracker: "RequestTracker"
    }
    VersionRouter.__methods__: {
      route: "(request: InferenceRequest) -> ModelVersion"
      route_with_tracking: "(request: InferenceRequest) -> Tuple[ModelVersion, str]"
    }
  }
}
M3_Schema -> M3_ModelVersion: "defines"
M3_ModelVersion -> M3_Registry: "registered in"
M3_Registry -> M3_HotSwap: "provides versions"
M3_AtomicPointer -> M3_HotSwap: "atomic swap"
M3_AtomicPointer -> M3_Router: "current version"
M3_Tracker -> M3_HotSwap: "tracks inflight"
M3_Rollback -> M3_HotSwap: "triggers rollback"
# M1/M2 to M3 dependencies
M1_ModelLoader -> M3_Registry: "loads models"
M2_Batcher -> M3_Router: "gets current version"
# ============= M4: A/B TESTING =============
M4: {
  label: "M4: A/B Testing"
  link: "#m4-ab-testing"
  M4_Splitter: {
    label: "traffic_splitter.py"
    shape: sql_table
    TrafficSplitter: {
      _allocations: "Dict[str, float]"
      _hash_ring: "List[Tuple[int, str]]"
      _total_replicas: "int"
    }
    TrafficSplitter.__methods__: {
      split: "(request: InferenceRequest) -> str"
      set_allocation: "(version: str, weight: float) -> None"
      get_allocations: "() -> Dict[str, float]"
      _hash_request: "(request: InferenceRequest) -> int"
      _build_hash_ring: "() -> None"
    }
    SplitDecision: {
      version: "str"
      hash_value: "int"
      allocation_percent: "float"
    }
  }
  M4_Metrics: {
    label: "per_version_metrics.py"
    shape: sql_table
    PerVersionMetrics: {
      _metrics: "Dict[str, VersionMetrics]"
    }
    PerVersionMetrics.__methods__: {
      record: "(version: str, latency_ms: float, success: bool) -> None"
      get: "(version: str) -> VersionMetrics"
      get_all: "() -> Dict[str, VersionMetrics]"
      reset: "(version: str) -> None"
    }
    VersionMetrics: {
      version: "str"
      request_count: "int"
      success_count: "int"
      error_count: "int"
      total_latency_ms: "float"
      avg_latency_ms: "float"
      p50_latency_ms: "float"
      p99_latency_ms: "float"
    }
  }
  M4_Analyzer: {
    label: "statistical_analyzer.py"
    shape: sql_table
    StatisticalAnalyzer: {
      _confidence_level: "float"
      _min_samples: "int"
    }
    StatisticalAnalyzer.__methods__: {
      compare_versions: "(control: VersionMetrics, treatment: VersionMetrics) -> ComparisonResult"
      _t_test: "(a: List[float], b: List[float]) -> Tuple[float, float]"
      _compute_effect_size: "(control_mean: float, treatment_mean: float, pooled_std: float) -> float"
    }
    ComparisonResult: {
      control_version: "str"
      treatment_version: "str"
      latency_diff_ms: "float"
      error_rate_diff: "float"
      p_value: "float"
      effect_size: "float"
      is_significant: "bool"
    }
  }
  M4_Canary: {
    label: "canary_controller.py"
    shape: sql_table
    CanaryController: {
      _splitter: "TrafficSplitter"
      _analyzer: "StatisticalAnalyzer"
      _metrics: "PerVersionMetrics"
      _config: "CanaryConfig"
    }
    CanaryController.__methods__: {
      start_canary: "(new_version: str, initial_percent: float) -> None"
      advance_canary: "() -> float"
      abort_canary: "() -> None"
      complete_canary: "() -> None"
      get_status: "() -> CanaryStatus"
    }
    CanaryConfig: {
      initial_percent: "float"
      increment_percent: "float"
      increment_interval_s: "float"
      max_percent: "float"
      error_threshold: "float"
      latency_threshold_ms: "float"
    }
    CanaryStatus: {
      active: "bool"
      new_version: "str"
      current_percent: "float"
      time_elapsed_s: "float"
      should_abort: "bool"
    }
  }
  M4_Health: {
    label: "health_checker.py"
    shape: sql_table
    VersionHealthChecker: {
      _metrics: "PerVersionMetrics"
      _thresholds: "HealthThresholds"
    }
    VersionHealthChecker.__methods__: {
      check: "(version: str) -> VersionHealth"
      check_all: "() -> Dict[str, VersionHealth]"
    }
    HealthThresholds: {
      max_error_rate: "float"
      max_p99_latency_ms: "float"
      min_sample_count: "int"
    }
    VersionHealth: {
      version: "str"
      healthy: "bool"
      error_rate: "float"
      p99_latency_ms: "float"
      issues: "List[str]"
    }
  }
  M4_Experiment: {
    label: "experiment_manager.py"
    shape: sql_table
    ExperimentManager: {
      _experiments: "Dict[str, Experiment]"
      _splitter: "TrafficSplitter"
      _metrics: "PerVersionMetrics"
    }
    ExperimentManager.__methods__: {
      create: "(config: ExperimentConfig) -> Experiment"
      start: "(experiment_id: str) -> None"
      stop: "(experiment_id: str) -> ExperimentResult"
      get_results: "(experiment_id: str) -> ExperimentResult"
      list_active: "() -> List[Experiment]"
    }
    Experiment: {
      id: "str"
      name: "str"
      control_version: "str"
      treatment_version: "str"
      traffic_split: "float"
      start_time: "datetime"
      end_time: "Optional[datetime]"
      status: "Literal[created, running, completed, aborted]"
    }
    ExperimentResult: {
      experiment_id: "str"
      winner: "Optional[str]"
      confidence: "float"
      control_metrics: "VersionMetrics"
      treatment_metrics: "VersionMetrics"
      recommendation: "str"
    }
  }
}
M4_Splitter -> M4_Canary: "splits traffic"
M4_Metrics -> M4_Analyzer: "provides data"
M4_Metrics -> M4_Health: "health check data"
M4_Analyzer -> M4_Canary: "statistical analysis"
M4_Analyzer -> M4_Experiment: "experiment results"
M4_Health -> M4_Canary: "health signals"
M4_Splitter -> M4_Experiment: "traffic allocation"
# M3 to M4 dependencies
M3_Registry -> M4_Splitter: "available versions"
M3_ModelVersion -> M4_Metrics: "version info"
# ============= M5: MONITORING & DRIFT DETECTION =============
M5: {
  label: "M5: Monitoring & Drift Detection"
  link: "#m5-monitoring-drift-detection"
  M5_Latency: {
    label: "latency_histogram.py"
    shape: sql_table
    LatencyHistogram: {
      _buckets: "List[float]"
      _counts: "List[int]"
      _sum: "float"
      _count: "int"
      _lock: "threading.Lock"
    }
    LatencyHistogram.__methods__: {
      observe: "(value: float) -> None"
      merge: "(other: LatencyHistogram) -> None"
      get_percentile: "(p: float) -> float"
      get_stats: "() -> HistogramStats"
      to_prometheus: "() -> str"
    }
    HistogramStats: {
      count: "int"
      sum: "float"
      min: "float"
      max: "float"
      p50: "float"
      p90: "float"
      p99: "float"
    }
  }
  M5_Tracker: {
    label: "per_version_tracker.py"
    shape: sql_table
    PerVersionTracker: {
      _histograms: "Dict[str, LatencyHistogram]"
      _error_counts: "Dict[str, int]"
      _request_counts: "Dict[str, int]"
    }
    PerVersionTracker.__methods__: {
      record: "(version: str, latency_ms: float, success: bool) -> None"
      get_histogram: "(version: str) -> LatencyHistogram"
      get_error_rate: "(version: str) -> float"
      export_prometheus: "() -> str"
    }
  }
  M5_Prediction: {
    label: "prediction_monitor.py"
    shape: sql_table
    PredictionMonitor: {
      _prediction_store: "Deque[Tuple[np.ndarray, float, str]]"
      _max_size: "int"
    }
    PredictionMonitor.__methods__: {
      record: "(features: np.ndarray, prediction: float, version: str) -> None"
      get_recent: "(n: int) -> List[Tuple[np.ndarray, float, str]]"
      get_by_version: "(version: str) -> List[Tuple[np.ndarray, float]]"
    }
  }
  M5_Baseline: {
    label: "feature_baseline.py"
    shape: sql_table
    FeatureBaseline: {
      _feature_stats: "Dict[str, FeatureStats]"
      _sample_size: "int"
    }
    FeatureBaseline.__methods__: {
      fit: "(data: np.ndarray) -> None"
      update: "(data: np.ndarray) -> None"
      get_stats: "(feature_idx: int) -> FeatureStats"
      save: "(path: str) -> None"
      load: "(path: str) -> FeatureBaseline"
    }
    FeatureStats: {
      mean: "float"
      std: "float"
      min: "float"
      max: "float"
      percentiles: "Dict[int, float]"
    }
  }
  M5_KSDetector: {
    label: "ks_test_detector.py"
    shape: sql_table
    KSTestDetector: {
      _baseline: "FeatureBaseline"
      _p_threshold: "float"
      _window_size: "int"
    }
    KSTestDetector.__methods__: {
      detect: "(current_data: np.ndarray) -> DriftResult"
      _ks_test: "(baseline: np.ndarray, current: np.ndarray) -> Tuple[float, float]"
      _compute_drift_score: "(p_values: List[float]) -> float"
    }
    DriftResult: {
      drifted: "bool"
      drift_score: "float"
      feature_scores: "Dict[int, float]"
      p_values: "Dict[int, float]"
      timestamp: "datetime"
    }
  }
  M5_Sampler: {
    label: "drift_sampler.py"
    shape: sql_table
    DriftSampler: {
      _reservoir: "List[np.ndarray]"
      _max_size: "int"
      _count: "int"
    }
    DriftSampler.__methods__: {
      add: "(features: np.ndarray) -> None"
      get_sample: "() -> np.ndarray"
      _reservoir_sample: "(item: np.ndarray) -> bool"
      reset: "() -> None"
    }
  }
  M5_Alert: {
    label: "alert_manager.py"
    shape: sql_table
    AlertManager: {
      _rules: "List[AlertRule]"
      _notifiers: "List[Notifier]"
      _alert_history: "Deque[Alert]"
    }
    AlertManager.__methods__: {
      evaluate: "(metrics: Dict[str, Any]) -> List[Alert]"
      add_rule: "(rule: AlertRule) -> None"
      notify: "(alert: Alert) -> None"
      get_history: "(since: datetime) -> List[Alert]"
    }
    AlertRule: {
      name: "str"
      condition: "str"
      threshold: "float"
      severity: "Literal[info, warning, critical]"
      cooldown_s: "float"
    }
    Alert: {
      rule_name: "str"
      message: "str"
      severity: "str"
      timestamp: "datetime"
      value: "float"
      threshold: "float"
    }
  }
  M5_Logger: {
    label: "structured_logger.py"
    shape: sql_table
    StructuredLogger: {
      _logger: "logging.Logger"
      _default_fields: "Dict[str, Any]"
    }
    StructuredLogger.__methods__: {
      log_inference: "(request: InferenceRequest, response: InferenceResponse) -> None"
      log_drift: "(result: DriftResult) -> None"
      log_version_change: "(transition: VersionTransition) -> None"
      log_experiment: "(experiment: Experiment, result: ExperimentResult) -> None"
    }
  }
}
M5_Latency -> M5_Tracker: "histograms by version"
M5_Baseline -> M5_KSDetector: "reference distribution"
M5_Sampler -> M5_KSDetector: "sampled data"
M5_Prediction -> M5_Sampler: "features for sampling"
M5_KSDetector -> M5_Alert: "drift alerts"
M5_Tracker -> M5_Alert: "latency/error alerts"
M5_Alert -> M5_Logger: "structured logging"
# M1-M4 to M5 dependencies
M3_Registry -> M5_Tracker: "version info"
M2_Metrics -> M5_Latency: "batch metrics"
M4_Metrics -> M5_Tracker: "per-version data"
M4_Analyzer -> M5_Logger: "experiment logs"
# ============= CROSS-MILESTONE CONNECTIONS =============
M1_Lifespan -> M3_HotSwap: "initializes pointer"
M2_Batcher -> M4_Splitter: "batch with routing"
M3_HotSwap -> M4_Canary: "version promotion"
M4_Experiment -> M3_Registry: "version activation"
M5_Alert -> M3_Rollback: "triggers rollback"
M5_Alert -> M4_Canary: "aborts canary"
# ============= DATA FLOW ANNOTATIONS =============
DataFlows: {
  shape: sql_table
  InferenceFlow: {
    step_1: "Request -> M2_Queue.enqueue() -> Future"
    step_2: "M2_Batcher.dequeue_batch() -> List[Request, Future]"
    step_3: "M2_Padder.pad_batch() -> PaddedTensor"
    step_4: "M3_Router.route() -> ModelVersion"
    step_5: "M4_Splitter.split() -> version"
    step_6: "ModelVersion.predict() -> Output"
    step_7: "M2_Router.resolve() -> InferenceResponse"
    step_8: "M5_Tracker.record() -> metrics"
  }
  VersionFlow: {
    step_1: "M3_Registry.register() -> ModelVersion"
    step_2: "M3_HotSwap.hot_swap() -> SwapResult"
    step_3: "M3_AtomicPointer.swap() -> atomic"
    step_4: "M3_Tracker.wait_for_drain() -> safe"
  }
  DriftFlow: {
    step_1: "M5_Prediction.record() -> store"
    step_2: "M5_Sampler.add() -> reservoir"
    step_3: "M5_KSDetector.detect() -> DriftResult"
    step_4: "M5_Alert.evaluate() -> Alert"
    step_5: "M3_Rollback.should_rollback() -> action"
  }
}