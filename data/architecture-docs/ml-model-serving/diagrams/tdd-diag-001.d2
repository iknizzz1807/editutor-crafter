direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 6
    pad: 40
  }
}

classes: {
  state_normal: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  state_initial: {
    shape: circle
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }
  state_error: {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  state_ready: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  transition_class: {
    style: {
      stroke: "#37474F"
      stroke-width: 2
    }
  }
  error_transition_class: {
    style: {
      stroke: "#C62828"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  health_box: {
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF8F00"
      stroke-width: 1
      border-radius: 4
      font-size: 11
    }
  }
}

# Title Container
Header: {
  shape: text
  label: "Model Loading Lifecycle State Machine\nM1 Module — ModelState Transition Diagram"
  style: {
    font-size: 24
    bold: true
    underline: true
  }
  near: top-center
}

# Initial state
INIT: "●" {
  class: state_initial
}

# Main states
LOADING: {
  class: state_normal
  label: "LOADING"
  
  details: |'md
    **Invariant:**
    • `model_path` is valid
    • GPU device detected
    • Memory allocated

    **Entry Actions:**
    • `load_weights(path)`
    • `init_tokenizer()`
    • `verify_integrity()`
  '|
  details.shape: text
  
  health_probes: {
    class: health_box
    label: "Health Probes:\n├─ Liveness: 200 OK\n└─ Readiness: 503"
  }
}

WARMING_UP: {
  class: state_normal
  label: "WARMING_UP"
  
  details: |'md
    **Invariant:**
    • Weights in VRAM
    • CUDA context active
    • GPU mem reserved

    **Entry Actions:**
    • `run_warmup_kernels()`
    • `exec_inf_samples()`
    • `populate_cache()`
  '|
  details.shape: text
  
  health_probes: {
    class: health_box
    label: "Health Probes:\n├─ Liveness: 200 OK\n└─ Readiness: 503"
  }
}

READY: {
  class: state_ready
  label: "READY"
  
  details: |'md
    **Invariant:**
    • Model operational
    • Warmup complete
    • Accepting requests

    **Entry Actions:**
    • `set_state(READY)`
    • `emit_ready_metric()`
    • `start_batcher()`
  '|
  details.shape: text
  
  health_probes: {
    class: health_box
    label: "Health Probes:\n├─ Liveness: 200 OK\n└─ Readiness: 200 OK"
  }
}

FAILED: {
  class: state_error
  label: "FAILED"
  
  details: |'md
    **Invariant:**
    • Error logged
    • state == FAILED
    • Partial allocation

    **Entry Actions:**
    • `log_error_context()`
    • `emit_fail_metric()`
    • `notify_ops()`
  '|
  details.shape: text
  
  health_probes: {
    class: health_box
    label: "Health Probes:\n├─ Liveness: 200 OK\n└─ Readiness: 503"
  }
}

# Transitions
INIT -> LOADING: "start_loading(path, cfg)\n[guard: path_exists ∧ gpu_ok]" {
  class: transition_class
}

LOADING -> WARMING_UP: "on_weights_loaded()\n[guard: weights_valid ∧ integrity_ok]\n/action: transition_state(WARMING_UP)" {
  class: transition_class
}

LOADING -> FAILED: "on_load_error(err)\n[guard: err != null]\n/action: capture_context()" {
  class: error_transition_class
}

WARMING_UP -> READY: "on_warmup_complete()\n[guard: samples >= min]\n/action: enable_traffic()" {
  class: transition_class
}

WARMING_UP -> FAILED: "on_warmup_error(err)\n[guard: cuda_err ∨ oom]\n/action: log_diagnostics()" {
  class: error_transition_class
}

READY -> LOADING: "on_reload_req(new_path)\n[guard: graceful_shutdown]\n/action: cleanup()" {
  class: transition_class
}

READY -> READY: "on_health_check()\n[guard: model_healthy]\n/action: update_metrics()" {
  class: transition_class
}

FAILED -> LOADING: "on_retry()\n[guard: backoff ∧ retry < max]\n/action: inc_retry_counter()" {
  class: error_transition_class
}

# Documentation & Summaries
Meta: {
  near: bottom-left

  legend: {
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
    }
    label: |'md
      ### DOCUMENTATION LEGEND
      | Symbol | Description |
      | :--- | :--- |
      | `━━▶` | Normal transition |
      | `╍╍╍▶` | Error path (dashed) |
      | `●` | Entry Point |
      | `[...]` | Guard Condition |
      | `/` | Side-effect Action |
    '|
  }

  health_summary: {
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
    }
    label: |'md
      ### PROBE STATUS MATRIX
      | State | Liveness | Readiness | Traffic Allowed |
      | :--- | :--- | :--- | :--- |
      | **LOADING** | 200 | 503 | NO |
      | **WARMING** | 200 | 503 | NO |
      | **READY** | 200 | 200 | YES |
      | **FAILED** | 200 | 503 | NO |
    '|
  }
}

# Implementation Notes for Engineers
EngineeringNote: {
  shape: rectangle
  near: bottom-right
  style: {
    fill: "#F5F5F5"
    stroke-width: 1
    font-size: 12
  }
  label: |'md
    ### Implementation Requirements (v1.0.4)
    1. **Thread Safety:** State transitions must be atomic (mutex-protected).
    2. **CUDA Context:** Ensure `cudaFree(0)` is called during `INIT` to verify driver.
    3. **Metrics:** All state durations reported to Prometheus as `model_state_seconds_total`.
    4. **Timeout:** Total transition from `INIT` to `READY` must not exceed 300s.
  '|
}