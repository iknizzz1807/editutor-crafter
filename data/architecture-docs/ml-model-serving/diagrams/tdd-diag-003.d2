direction: right
layout-engine: elk
theme-id: 4
title: {
  label: "CUDA Warmup Effect on Latency"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}
warmup_sequence: {
  label: "Warmup Algorithm Steps"
  start: {
    shape: oval
    label: "Start"
    style.fill: "#E8F5E9"
  }
  load_model: {
    shape: rectangle
    label: "Load Model\nto GPU"
    style.fill: "#E3F2FD"
  }
  config_warmup: {
    shape: rectangle
    label: "Configure N\nwarmup runs\n(default: 5)"
    style.fill: "#E3F2FD"
  }
  init_latencies: {
    shape: rectangle
    label: "Initialize\nlatencies = []"
    style.fill: "#FFF3E0"
  }
  loop_check: {
    shape: diamond
    label: "run < N?"
    style.fill: "#F3E5F5"
  }
  dummy_input: {
    shape: rectangle
    label: "Create dummy\ninput tensor"
    style.fill: "#E3F2FD"
  }
  sync_before: {
    shape: rectangle
    label: "torch.cuda.synchronize()\nRecord start_time"
    style.fill: "#FFECB3"
  }
  inference: {
    shape: rectangle
    label: "model(dummy_input)"
    style.fill: "#FFCDD2"
  }
  sync_after: {
    shape: rectangle
    label: "torch.cuda.synchronize()\nRecord end_time"
    style.fill: "#FFECB3"
  }
  calc_latency: {
    shape: rectangle
    label: "latency = end - start\nlatencies.append(latency)"
    style.fill: "#FFF3E0"
  }
  increment: {
    shape: rectangle
    label: "run += 1"
    style.fill: "#E3F2FD"
  }
  return_latencies: {
    shape: parallelogram
    label: "return latencies[]"
    style.fill: "#C8E6C9"
  }
  end: {
    shape: oval
    label: "End"
    style.fill: "#E8F5E9"
  }
  start -> load_model
  load_model -> config_warmup
  config_warmup -> init_latencies
  init_latencies -> loop_check
  loop_check -> dummy_input: "Yes"
  loop_check -> return_latencies: "No"
  dummy_input -> sync_before
  sync_before -> inference
  inference -> sync_after
  sync_after -> calc_latency
  calc_latency -> increment
  increment -> loop_check
  return_latencies -> end
}
timing_comparison: {
  label: ""
  |'md
  ## Timing Comparison
  | Run | Description | Latency |
  |-----|-------------|---------|
  | 1 | **Cold** - JIT kernel compilation | ~487ms |
  | 2 | Warm - cached kernels | ~45ms |
  | 3 | Warm - cached kernels | ~44ms |
  | 4 | Warm - cached kernels | ~43ms |
  | 5 | Warm - cached kernels | ~43ms |
  **First inference triggers CUDA kernel JIT compilation**
  **Subsequent inferences use cached compiled kernels**
  '|
}
cold_vs_warm: {
  label: "Cold vs Warm Inference"
  cold_inference: {
    label: "Cold Inference\n(Run 1)"
    style.fill: "#FFCDD2"
    cold_step1: {
      label: "1. CUDA Kernel\nJIT Compilation"
      style.fill: "#FFCDD2"
    }
    cold_step2: {
      label: "2. Kernel\nExecution"
      style.fill: "#FFCDD2"
    }
    cold_step3: {
      label: "3. Memory\nTransfer"
      style.fill: "#FFCDD2"
    }
    cold_step1 -> cold_step2 -> cold_step3
  }
  warm_inference: {
    label: "Warm Inference\n(Runs 2-5)"
    style.fill: "#C8E6C9"
    warm_step1: {
      label: "1. Use Cached\nKernels"
      style.fill: "#C8E6C9"
    }
    warm_step2: {
      label: "2. Kernel\nExecution"
      style.fill: "#C8E6C9"
    }
    warm_step3: {
      label: "3. Memory\nTransfer"
      style.fill: "#C8E6C9"
    }
    warm_step1 -> warm_step2 -> warm_step3
  }
  cold_inference -> warm_inference: {
    label: "After first\ninference"
    style.stroke-dash: 3
  }
}
latency_graph: {
  label: "Latency per Run"
  |'md
  
  Latency (ms)
  500 ┤
     │ ●
  400 ┤ │
     │ │
  300 ┤ │
     │ │
  200 ┤ │
     │ │
  100 ┤ │
     │ │ ●  ●  ●  ●
   50 ┤ │ │  │  │  │
     │ │ │  │  │  │
    0 ┼─┴─┴──┴──┴──┴──
        1  2  3  4  5
           Run #
  
  '|
  style.fill: "#FAFAFA"
}
key_insight: {
  |'md
  ### Key Implementation Details
  - **`torch.cuda.synchronize()`** ensures accurate timing by waiting for GPU operations to complete
  - **JIT compilation** occurs on first kernel invocation, not at model load time
  - **Cached kernels** persist for the lifetime of the process
  - **Production inference** should always perform warmup before serving requests
  '|
  style.fill: "#E8F5E9"
}
warmup_sequence -> timing_comparison -> cold_vs_warm -> latency_graph -> key_insight: {
  style.opacity: 0
}