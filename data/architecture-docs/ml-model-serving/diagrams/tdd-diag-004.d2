direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# -----------------------------------------------------------------------------------------
# GLOBAL TITLE & ANNOTATIONS
# -----------------------------------------------------------------------------------------
title: |md
  # Tensor Shape Validation Flow
  ### Implementation Specification v1.0.4
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# -----------------------------------------------------------------------------------------
# INPUT STAGE: RAW PAYLOAD
# -----------------------------------------------------------------------------------------
JSON_Request: {
  shape: document
  label: "JSON Request\n(Payload)"
  style.fill: "#E3F2FD"
  content: {
    shape: code
    label: |
      {
        "inputs": {
          "input_ids": [101, 2023, 102],
          "attention_mask": [1, 1, 1]
        }
      }
    |
    style.font-size: 11
  }
}

# -----------------------------------------------------------------------------------------
# VALIDATION INFRASTRUCTURE
# -----------------------------------------------------------------------------------------
RequestParser: {
  shape: rectangle
  label: "Request Parser\n(parse_json)"
  style.fill: "#FFF3E0"
  tooltip: "Extracts python dict from bytes"
}

SchemaRegistry: {
  shape: cylinder
  label: "InputSchema\nRegistry"
  style.fill: "#F3E5F5"
  schemas: {
    shape: sql_table
    label: "Registered Validation Schemas"
    input_ids: "int64" {constraint: "Rank-2: [batch, seq]"}
    attention_mask: "int64" {constraint: "Rank-2: [batch, seq]"}
  }
}

# -----------------------------------------------------------------------------------------
# VALIDATION ENGINE
# -----------------------------------------------------------------------------------------
ModelInputValidator: {
  shape: rectangle
  label: "ModelInputValidator\n.validate_request()"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}

# SUB-DECISIONS & PROCESSES
InputExistenceCheck: {
  shape: diamond
  label: "Input\nExists?"
  style.fill: "#FFECB3"
}

MissingInputError: {
  shape: hexagon
  label: "ERROR\nMissing Input"
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 2
}

TensorConversion: {
  shape: rectangle
  label: "Tensor Conversion\n(torch.tensor())"
  style.fill: "#B2DFDB"
  conversion_details: {
    shape: code
    label: |
      tensor = torch.tensor(
          data,
          dtype=schema.dtype,
          device='cpu'
      )
    |
    style.font-size: 10
  }
}

ConversionError: {
  shape: hexagon
  label: "ERROR\nConversion Failed"
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}

DtypeValidation: {
  shape: diamond
  label: "Dtype\nMatch?"
  style.fill: "#FFECB3"
}

DtypeMismatchError: {
  shape: hexagon
  label: "ERROR\nDtype Mismatch"
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  detail: {
    shape: text
    label: "Expected: schema.dtype\nReceived: tensor.dtype"
    style.font-size: 9
    style.italic: true
  }
}

RankValidation: {
  shape: diamond
  label: "Rank\nValid?"
  style.fill: "#FFECB3"
}

RankMismatchError: {
  shape: hexagon
  label: "ERROR\nInvalid Rank"
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  detail: {
    shape: text
    label: "Expected: len(schema.shape)\nReceived: tensor.dim()"
    style.font-size: 9
    style.italic: true
  }
}

ShapeValidation: {
  shape: diamond
  label: "Shape\nMatch?"
  style.fill: "#FFECB3"
}

ShapeMismatchError: {
  shape: hexagon
  label: "ERROR\nShape Mismatch"
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  detail: {
    shape: text
    label: "Schema: schema.shape[i]\nTensor: tensor.size(i)\n(None = dynamic dim)"
    style.font-size: 9
    style.italic: true
  }
}

# -----------------------------------------------------------------------------------------
# OUTPUT & INTERFACE DEFINITIONS
# -----------------------------------------------------------------------------------------
ValidatedTensors: {
  shape: rectangle
  label: "Validated Tensors\nDict[str, torch.Tensor]"
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
}

ModelInput: {
  shape: hexagon
  label: "Model Input\n(Ready for Inference)"
  style.fill: "#4CAF50"
  style.font-color: white
  style.stroke: "#1B5E20"
}

InputSchema: {
  shape: class
  style.fill: "#E1F5FE"
  name: string
  shape_spec: "Tuple[Union[int, None], ...]"
  dtype: "torch.dtype"
  description: string
  validate: "(tensor: Tensor) -> Tuple[bool, Optional[str]]"
}

ValidationResult: {
  shape: class
  style.fill: "#F1F8E9"
  success: bool
  tensors: "Optional[Dict[str, Tensor]]"
  error_message: "Optional[str]"
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS: LOGICAL FLOW
# -----------------------------------------------------------------------------------------
JSON_Request -> RequestParser: "1. raw payload"
RequestParser -> ModelInputValidator: "2. parsed dict"
SchemaRegistry -> ModelInputValidator: "3. schema lookup"
ModelInputValidator -> InputExistenceCheck: "4. iter schemas"

# Branching: Input Check
InputExistenceCheck -> MissingInputError: "NO\n(missing key)" {
  style.stroke: red
}
MissingInputError -> ValidationResult: "return"

InputExistenceCheck -> TensorConversion: "YES"

# Branching: Conversion
TensorConversion -> ConversionError: "FAIL\n(cast error)" {
  style.stroke: red
}
ConversionError -> ValidationResult: "return"
TensorConversion -> DtypeValidation: "SUCCESS"

# Branching: Dtype
DtypeValidation -> DtypeMismatchError: "NO" {
  style.stroke: red
}
DtypeMismatchError -> ValidationResult: "return"
DtypeValidation -> RankValidation: "YES"

# Branching: Rank
RankValidation -> RankMismatchError: "NO" {
  style.stroke: red
}
RankMismatchError -> ValidationResult: "return"
RankValidation -> ShapeValidation: "YES"

# Branching: Final Shape Check
ShapeValidation -> ShapeMismatchError: "NO" {
  style.stroke: red
}
ShapeMismatchError -> ValidationResult: "return"
ShapeValidation -> ValidatedTensors: "YES\n(All Clear)"

# Branching: Completion
ValidatedTensors -> ModelInput: "7. aggregate"
ModelInput -> ValidationResult: "Finalize"

InputSchema -> SchemaRegistry: "Entry Pattern"

# Return Path (Dashed)
ValidationResult -> JSON_Request: {
  style.stroke-dash: 5
  style.stroke: "#9E9E9E"
  label: "return result\n(success/error)"
}

# -----------------------------------------------------------------------------------------
# MEMORY LAYOUT DETAIL (Intel Manual Style)
# -----------------------------------------------------------------------------------------
TensorMemory: {
  label: "In-Memory Tensor Alignment (64B Cache Line)"
  style.stroke: orange
  style.stroke-width: 2
  
  grid-columns: 1
  grid-gap: 0

  header: {
    grid-columns: 4
    grid-gap: 0
    o0: "Offset 0x00" { style.fill: purple; style.font-color: white }
    o16: "Offset 0x10" { style.fill: purple; style.font-color: white }
    o32: "Offset 0x20" { style.fill: purple; style.font-color: white }
    o48: "Offset 0x30" { style.fill: purple; style.font-color: white }
  }

  line: {
    grid-columns: 4
    grid-gap: 0
    ptr: "Storage Pointer (8B)" { style.fill: orange }
    meta: "Shape Meta (8B)" { style.fill: blue; style.font-color: white }
    stride: "Stride Meta (8B)" { style.fill: blue; style.font-color: white }
    pad: "Padding (8B)" { style.fill: gray }
  }
}
TensorMemory.near: bottom-right

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-left
  style.fill: "#FAFAFA"
  style.stroke-dash: 3
  
  title: {
    shape: text
    label: "LEGEND"
    style.bold: true
  }
  
  l1: {
    grid-columns: 2
    grid-gap: 10
    
    proc: "Process Step" { shape: rectangle; style.fill: "#E8F5E9" }
    dec: "Decision" { shape: diamond; style.fill: "#FFECB3" }
    err: "Error State" { shape: hexagon; style.fill: "#FFCDD2" }
    succ: "Success" { shape: hexagon; style.fill: "#4CAF50" }
  }
}