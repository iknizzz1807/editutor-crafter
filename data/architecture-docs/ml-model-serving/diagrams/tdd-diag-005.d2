layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: Serialization Benchmark Comparison {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
    font-color: "#4B0082" # Purple for Header
  }
}

subtitle: NumPy Array Serialization (32Г—768 Embeddings) {
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}

# Input Data - Data Component (Blue)
input: {
  shape: rectangle
  label: "Input Data\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nNumPy Array\nShape: (32, 768)\nDtype: float32\nSize: 98,304 values"
  style: {
    fill: "#E3F2FD" # Blue for Data
    stroke: "#1976D2"
    stroke-width: 2
    font-size: 13
  }
}

# Stdlib json Path (Left Branch) - Inefficient Path
stdlib_path: {
  label: "stdlib json"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
  }

  step1_to_list: {
    label: "Step 1: ndarray.tolist()\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nConvert to Python list\nвҡ пёҸ  Recursive iteration\nвҡ пёҸ  Type conversion overhead"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
  }

  step2_dumps: {
    label: "Step 2: json.dumps()\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nSerialize to JSON string\nвҡ пёҸ  Pure Python loop\nвҡ пёҸ  No SIMD optimization"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
  }

  timing_breakdown: {
    label: "Timing Breakdown\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n.tolist(): ~45ms\n.dumps(): ~44ms\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nTotal: 89.3ms"
    shape: rectangle
    style: {
      fill: "#EF9A9A"
      stroke: "#B71C1C"
      bold: true
    }
  }

  output_size: {
    label: "Output Size\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n378.0 KB\n(Pretty-printed)"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
  }

  step1_to_list -> step2_dumps: "Python list\n(heavy object)" {
    style: {
      stroke: "#C62828"
      stroke-dash: 3
    }
  }
  step2_dumps -> timing_breakdown
  timing_breakdown -> output_size
}

# orjson Path (Right Branch) - Efficient Path (Green)
orjson_path: {
  label: "orjson"
  style: {
    fill: "#E8F5E9" # Green for Efficient/Free
    stroke: "#2E7D32"
    stroke-width: 2
  }

  step1_optimize: {
    label: "Step 1: Optimize Path\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nOption A: ndarray.tobytes()\nOption B: np.asarray() + OPT_NAIVE_UTC\nOption C: Direct serialization"
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
  }

  step2_orjson: {
    label: "Step 2: orjson.dumps()\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nRust-based serialization\nвң“ SIMD-accelerated\nвң“ Zero-copy where possible\nвң“ Direct buffer writing"
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
  }

  timing_breakdown: {
    label: "Timing Breakdown\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nPrep: ~2ms\n.dumps(): ~7ms\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nTotal: 8.7ms"
    shape: rectangle
    style: {
      fill: "#A5D6A7"
      stroke: "#1B5E20"
      bold: true
    }
  }

  output_size: {
    label: "Output Size\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n351.2 KB\n(Compact binary)"
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
  }

  step1_optimize -> step2_orjson: "bytes/buffer\n(lightweight)" {
    style: {
      stroke: "#2E7D32"
      stroke-dash: 3
    }
  }
  step2_orjson -> timing_breakdown
  timing_breakdown -> output_size
}

# Connections from input
input -> stdlib_path.step1_to_list: "Path A" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}

input -> orjson_path.step1_optimize: "Path B" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

# Comparison Summary Box
comparison: {
  label: "Performance Summary\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ     Metric       в”Ӯ stdlib jsonв”Ӯ   orjson   в”Ӯ\nв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\nв”Ӯ Serialize Time   в”Ӯ   89.3ms   в”Ӯ    8.7ms   в”Ӯ\nв”Ӯ Output Size      в”Ӯ   378.0 KB в”Ӯ   351.2 KB в”Ӯ\nв”Ӯ Throughput       в”Ӯ  4.2 MB/s  в”Ӯ  40.4 MB/s в”Ӯ\nв”Ӯ Speedup          в”Ӯ     1x     в”Ӯ   10.26x   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
  shape: rectangle
  style: {
    fill: "#F5F5F5" # Gray for Padding/Summary
    stroke: "#424242"
    stroke-width: 3
    font-size: 12
    font: mono # Corrected from font-family
  }
}

# Speedup indicator
speedup_badge: {
  label: "рҹҡҖ 10.26x FASTER"
  shape: rectangle
  style: {
    fill: "#4CAF50"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: white
    bold: true
    font-size: 18
    shadow: true
  }
}

# Key Differences
key_diffs: {
  label: "Key Differences\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nвҖў stdlib: Pure Python, GC pressure\nвҖў orjson: Rust native, SIMD\nвҖў orjson: 7% smaller output\nвҖў orjson: Predictable latency"
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00" # Orange for Pointers/Key Points
    double-border: true
  }
}

# Layout connections
stdlib_path.output_size -> comparison
orjson_path.output_size -> comparison
comparison -> speedup_badge
comparison -> key_diffs

# Recommendation
recommendation: {
  label: "вң“ RECOMMENDED\nfor Production ML Serving"
  shape: diamond
  style: {
    fill: "#81C784"
    stroke: "#2E7D32"
    stroke-width: 2
    font-color: white
    bold: true
  }
}

speedup_badge -> recommendation: "orjson" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    animated: true
  }
}