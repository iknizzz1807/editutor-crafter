direction: right
shape: sequence_diagram
font-family: IBM Plex Sans
title: Health Probe Response Logic {
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
k8s: Kubernetes Probe
api: ML Model Server
state: ModelState
# Liveness probe - always returns 200
k8s -> api: GET /health/liveness
api -> state: check process running?
state -> api: ✓ process alive
api -> k8s: HTTP 200 OK {
  style.stroke-dash: 3
}
# Readiness probe scenarios
# Scenario 1: LOADING state
group: ModelState = LOADING {
  k8s -> api: GET /health/readiness
  api -> state: get current state
  state -> api: LOADING
  api -> k8s: HTTP 503 Service Unavailable {
    style.stroke: "#E5484D"
  }
}
# Scenario 2: WARMING_UP state
group: ModelState = WARMING_UP {
  k8s -> api: GET /health/readiness
  api -> state: get current state
  state -> api: WARMING_UP
  api -> k8s: HTTP 503 Service Unavailable {
    style.stroke: "#E5484D"
  }
}
# Scenario 3: FAILED state
group: ModelState = FAILED {
  k8s -> api: GET /health/readiness
  api -> state: get current state
  state -> api: FAILED
  api -> k8s: HTTP 503 Service Unavailable {
    style.stroke: "#E5484D"
  }
}
# Scenario 4: READY state
group: ModelState = READY {
  k8s -> api: GET /health/readiness
  api -> state: get current state
  state -> api: READY ✓
  api -> k8s: HTTP 200 OK {
    style.stroke: "#30A46C"
  }
}
# State transition note
note: {
  shape: text
  style: {
    font-size: 11
    italic: true
  }
  Lifecycle: LOADING → WARMING_UP → READY
  (or → FAILED on error)
}