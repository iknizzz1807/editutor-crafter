vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# FastAPI Lifespan Handler Sequence Diagram
# Implementation-grade sequence for ML Model Serving API
FastAPI_Lifespan_System: {
  grid-columns: 2
  
  Sequence: {
    shape: sequence_diagram
    
    # === PARTICIPANTS ===
    # Order of declaration determines left-to-right order
    fastapi_app: "FastAPI\nApplication" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    lifespan: "Lifespan\nHandler" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    device_detector: "Device\nDetector" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    memory_checker: "Memory\nChecker" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    model_loader: "Model\nLoader" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    warmup: "GPU\nWarmup" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    global_state: "GlobalState\nSingleton" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    health_live: "/health/live\nEndpoint" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }
    health_ready: "/health/ready\nEndpoint" {
      style.fill: "#1e3a5f"
      style.font-color: white
      style.bold: true
    }

    # === SEQUENCE FLOW ===
    
    # Phase 1: Application Startup
    fastapi_app -> lifespan: "on_startup startup_event" {
      style.stroke: "#2563eb"
      style.bold: true
    }

    # Phase 2: Initialize GlobalState
    lifespan -> global_state: "model_state = LOADING" {
      style.stroke: "#f59e0b"
    }
    global_state."model_state: None → LOADING\nrequest_count: 0\nerror_count: 0" {
      style.fill: "#fef3c7"
      style.stroke: "#f59e0b"
    }

    # Phase 3: Device Detection
    lifespan -> device_detector: "get_device()" {
      style.stroke: "#2563eb"
    }
    device_detector."torch.cuda.is_available()\ntorch.cuda.get_device_name(0)" {
      style.fill: "#dbeafe"
      style.stroke: "#2563eb"
    }
    device_detector -> lifespan: "DeviceInfo(device='cuda:0', memory_total_gb=80.0)" {
      style.stroke: "#16a34a"
    }

    # Phase 4: Memory Budget Check
    lifespan -> memory_checker: "check_memory_budget(model_size_gb=4.2)" {
      style.stroke: "#2563eb"
    }
    memory_checker."required = model_size / (1 - margin)\navailable = torch.cuda.mem_get_info()\nreturn available > required" {
      style.fill: "#dbeafe"
      style.stroke: "#2563eb"
    }
    memory_checker -> lifespan: "MemoryBudget(is_sufficient=True)" {
      style.stroke: "#16a34a"
    }

    # Phase 5: Model Loading
    lifespan -> model_loader: "load_model(model_path='/models/bert', device='cuda:0')" {
      style.stroke: "#2563eb"
    }
    model_loader."torch.load(model_path)\nmodel.to(device)\nmodel.eval()" {
      style.fill: "#dbeafe"
      style.stroke: "#2563eb"
    }
    model_loader -> lifespan: "model: nn.Module (size_gb=4.2)" {
      style.stroke: "#16a34a"
    }
    lifespan -> global_state: "model = model\nmodel_state = WARMING_UP" {
      style.stroke: "#f59e0b"
    }
    global_state."model_state: LOADING → WARMING_UP" {
      style.fill: "#fef3c7"
      style.stroke: "#f59e0b"
    }

    # Phase 6: GPU Warmup
    lifespan -> warmup: "warmup_model(batches=3)" {
      style.stroke: "#2563eb"
    }
    warmup."FOR i in range(warmup_batches):\n  _ = model(sample_input)\n  torch.cuda.synchronize()" {
      style.fill: "#dbeafe"
      style.stroke: "#2563eb"
    }
    warmup -> lifespan: "WarmupResult(avg_latency_ms=12.5)" {
      style.stroke: "#16a34a"
    }

    # Phase 8: Mark Ready
    lifespan -> global_state: "model_state = READY\nready_since = time.time()" {
      style.stroke: "#16a34a"
      style.bold: true
    }
    global_state."model_state: WARMING_UP → READY" {
      style.fill: "#dcfce7"
      style.stroke: "#16a34a"
    }

    # Phase 9: Startup Complete
    lifespan -> fastapi_app: "startup_complete" {
      style.stroke: "#16a34a"
      style.bold: true
    }

    # === HEALTH ENDPOINT AVAILABILITY ===
    fastapi_app -> health_live: "GET /health/live" {
      style.stroke: "#6b7280"
      style.stroke-dash: 3
    }
    health_live -> fastapi_app: "200 OK {'model_state': 'LOADING'}" {
      style.stroke: "#6b7280"
      style.stroke-dash: 3
    }

    fastapi_app -> health_ready: "GET /health/ready" {
      style.stroke: "#f59e0b"
      style.stroke-dash: 3
    }
    health_ready -> global_state: "check state == READY" {
      style.stroke: "#f59e0b"
      style.stroke-dash: 3
    }
    global_state -> health_ready: "False" {
      style.stroke: "#f59e0b"
      style.stroke-dash: 3
    }
    health_ready -> fastapi_app: "503 Unavailable" {
      style.stroke: "#f59e0b"
      style.stroke-dash: 3
    }
  }

  Documentation: {
    # Supplemental technical info placed outside sequence to avoid actor lifelines
    state_box: "ModelState Lifecycle\n\n[LOADING] -> [WARMING_UP] -> [READY]\n\nAny Phase Failure -> [FAILED]" {
      style.fill: "#fefce8"
      style.stroke: "#ca8a04"
      style.multiple: true
    }

    error_handler: "Error Handling Logic\n\ntry:\n  await startup()\nexcept Exception as e:\n  state = FAILED\n  raise RuntimeError(e)" {
      style.fill: "#fef2f2"
      style.stroke: "#dc2626"
      style.multiple: true
    }

    legend: "Legend\n\nBlue: System Flow\nGreen: Success/Ready\nOrange: State Update\nGrey Dash: Async Health" {
      style.fill: "#f8fafc"
      style.stroke: "#94a3b8"
    }
  }
}