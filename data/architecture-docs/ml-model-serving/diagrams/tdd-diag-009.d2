layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
  }
  cool_classics: {
    primary: "#1A5F7A"
    secondary: "#57C5B6"
    accent: "#159895"
    dark: "#002B5B"
    light: "#F8F6F4"
    warning: "#E76F51"
    success: "#2A9D8F"
    text: "#1A1A2E"
  }
}

classes: {
  handler: {
    shape: rectangle
    style: {
      fill: "${cool_classics.light}"
      stroke: "${cool_classics.primary}"
      stroke-width: 2
      font-color: "${cool_classics.text}"
      border-radius: 4
    }
  }
  queue: {
    shape: cylinder
    style: {
      fill: "${cool_classics.secondary}"
      stroke: "${cool_classics.dark}"
      stroke-width: 2
      font-color: "${cool_classics.dark}"
      # FIXED: removed 3d: true as cylinders do not support it in D2
    }
  }
  processor: {
    shape: rectangle
    style: {
      fill: "${cool_classics.accent}"
      stroke: "${cool_classics.dark}"
      stroke-width: 3
      font-color: "${cool_classics.light}"
      bold: true
      border-radius: 6
      shadow: true
    }
  }
  model: {
    shape: diamond
    style: {
      fill: "${cool_classics.warning}"
      stroke: "${cool_classics.dark}"
      stroke-width: 2
      font-color: "${cool_classics.light}"
    }
  }
  future: {
    shape: circle
    style: {
      fill: "${cool_classics.success}"
      stroke: "${cool_classics.dark}"
      stroke-width: 2
      font-color: "${cool_classics.light}"
    }
  }
  container_box: {
    style: {
      fill: "transparent"
      stroke: "${cool_classics.dark}"
      stroke-dash: 4
      stroke-width: 1
      font-color: "${cool_classics.dark}"
      bold: true
      opacity: 0.8
    }
  }
  loop: {
    shape: circle
    style: {
      fill: "${cool_classics.primary}"
      stroke: "${cool_classics.dark}"
      stroke-width: 2
      font-color: "${cool_classics.light}"
    }
  }
}

title: {
  label: "Dynamic Batcher Architecture (Inference Pipeline)"
  shape: text
  style: {
    font-size: 28
    bold: true
    font-color: "${cool_classics.dark}"
    underline: true
  }
}

# HTTP Layer
http_layer: {
  class: container_box
  label: "HTTP Layer\n(asyncio handlers)"
  handler_1: {
    class: handler
    label: "Handler 1\nPOST /predict"
  }
  handler_2: {
    class: handler
    label: "Handler 2\nPOST /predict"
  }
  handler_n: {
    class: handler
    label: "Handler N\nPOST /predict"
  }
}

# Future objects tied to handlers
futures_layer: {
  class: container_box
  label: "Futures Layer\n(asyncio.Future)"
  future_1: {
    class: future
    label: "F₁"
  }
  future_2: {
    class: future
    label: "F₂"
  }
  future_n: {
    class: future
    label: "Fₙ"
  }
}

# Request Queue
request_queue: {
  class: queue
  label: "RequestQueue\n(asyncio.Queue)"
  # FIXED: removed double-border: true as cylinders do not support it in D2
  style: {
    stroke-width: 3
  }
}

# Queue item detail
queue_item: {
  shape: rectangle
  label: |
    QueueItem {
      request_id: str
      inputs: List[dict]
      future: asyncio.Future
      timestamp: float
    }
  |
  style: {
    fill: "${cool_classics.light}"
    stroke: "${cool_classics.secondary}"
    stroke-width: 1
    font: mono
    font-size: 11
    multiple: true
    border-radius: 2
  }
}

# Dynamic Batcher Container
dynamic_batcher: {
  class: container_box
  label: "DynamicBatcher\n(background asyncio.Task)"
  
  batch_loop: {
    class: loop
    label: "Batch\nLoop"
  }
  
  step_wait: {
    shape: rectangle
    label: "1. await queue.get()\n(wait for first request)"
    style: {
      fill: "${cool_classics.light}"
      stroke: "${cool_classics.primary}"
      stroke-width: 2
      border-radius: 4
    }
  }
  
  step_drain: {
    shape: rectangle
    label: "2. queue.get_nowait()\n(drain until empty or\nmax_batch_size)"
    style: {
      fill: "${cool_classics.light}"
      stroke: "${cool_classics.primary}"
      stroke-width: 2
      border-radius: 4
    }
  }
  
  step_pad: {
    shape: rectangle
    label: "3. Pad inputs\n(create attention masks\nfor variable lengths)"
    style: {
      fill: "${cool_classics.light}"
      stroke: "${cool_classics.accent}"
      stroke-width: 2
      border-radius: 4
    }
  }
  
  batch_tensor: {
    shape: rectangle
    label: |
      BatchedTensor {
        input_ids: [B, max_seq_len]
        attention_mask: [B, max_seq_len]
        batch_indices: List[int]
      }
    |
    style: {
      fill: "${cool_classics.secondary}"
      stroke: "${cool_classics.dark}"
      stroke-width: 2
      font: mono
      font-size: 10
      border-radius: 4
    }
  }

  batch_loop -> step_wait: "iterates"
  step_wait -> step_drain: "first item"
  step_drain -> step_pad: "collected batch"
  step_pad -> batch_tensor: "padded tensor"
}

# Model Inference
model_inference: {
  class: model
  label: "Model\nInference\n(GPU)"
  width: 120
  height: 120
}

# Result Router
result_router: {
  shape: rectangle
  class: processor
  label: "Result Router\n(batch → individual)"
  
  router_logic: {
    shape: rectangle
    label: |
      for i, result in enumerate(outputs):
          future = pending_futures[i]
          future.set_result(result)
          metrics.observe_duration()
    |
    style: {
      fill: "${cool_classics.light}"
      stroke: "${cool_classics.dark}"
      font: mono
      font-size: 10
      border-radius: 4
    }
  }
}

# Metrics
prometheus: {
  shape: rectangle
  label: |
    Prometheus Metrics
    ────────────────────
    • batch_size: histogram
    • batch_wait_time: histogram  
    • queue_depth: gauge
    • inference_latency: histogram
  |
  style: {
    fill: "${cool_classics.warning}"
    stroke: "${cool_classics.dark}"
    stroke-width: 1
    font: mono
    font-size: 10
    border-radius: 4
    opacity: 0.9
  }
}

# Request Flow
http_layer.handler_1 -> request_queue: {
  label: "submit()\n+ Future"
  style: {
    stroke: "${cool_classics.primary}"
    stroke-width: 2
    animated: true
  }
}
http_layer.handler_2 -> request_queue: {
  style: {
    stroke: "${cool_classics.primary}"
    stroke-width: 2
    animated: true
  }
}
http_layer.handler_n -> request_queue: {
  style: {
    stroke: "${cool_classics.primary}"
    stroke-width: 2
    animated: true
  }
}

# Queue to batcher
request_queue -> dynamic_batcher.step_wait: {
  label: "get()"
  style: {
    stroke: "${cool_classics.secondary}"
    stroke-width: 3
    animated: true
  }
}

# Batch tensor to model
dynamic_batcher.batch_tensor -> model_inference: {
  label: "tensor\n[B, seq_len]"
  style: {
    stroke: "${cool_classics.accent}"
    stroke-width: 3
    animated: true
  }
}

# Model to router
model_inference -> result_router: {
  label: "outputs\n[B, ...]"
  style: {
    stroke: "${cool_classics.warning}"
    stroke-width: 3
    animated: true
  }
}

# Router back to futures
result_router -> futures_layer.future_1: {
  label: "set_result()"
  style: {
    stroke: "${cool_classics.success}"
    stroke-width: 2
    stroke-dash: 3
  }
}
result_router -> futures_layer.future_2: {
  style: {
    stroke: "${cool_classics.success}"
    stroke-width: 2
    stroke-dash: 3
  }
}
result_router -> futures_layer.future_n: {
  style: {
    stroke: "${cool_classics.success}"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Futures resolve to handlers
futures_layer.future_1 -> http_layer.handler_1: {
  label: "await"
  style: {
    stroke: "${cool_classics.dark}"
    stroke-width: 1
    stroke-dash: 2
    opacity: 0.6
  }
}
futures_layer.future_2 -> http_layer.handler_2: {
  style: {
    stroke: "${cool_classics.dark}"
    stroke-width: 1
    stroke-dash: 2
    opacity: 0.6
  }
}
futures_layer.future_n -> http_layer.handler_n: {
  style: {
    stroke: "${cool_classics.dark}"
    stroke-width: 1
    stroke-dash: 2
    opacity: 0.6
  }
}

# Metrics connection
dynamic_batcher.step_drain -> prometheus: {
  label: "record"
  style: {
    stroke: "${cool_classics.warning}"
    stroke-width: 1
    stroke-dash: 2
    opacity: 0.5
  }
}
request_queue -> prometheus: {
  label: "gauge"
  style: {
    stroke: "${cool_classics.warning}"
    stroke-width: 1
    stroke-dash: 2
    opacity: 0.5
  }
}

# Queue item reference
queue_item -> request_queue: {
  label: "item type"
  style: {
    stroke: "${cool_classics.secondary}"
    stroke-width: 1
    stroke-dash: 4
    opacity: 0.4
  }
}

# Legend
legend_box: {
  near: bottom-right
  shape: rectangle
  label: |
    Legend
    ─────────────────────
    ━━━▶ Request flow
    - - -▶ Async resolution
    ⏵ Animated = active data
    Key Constraints:
    • max_batch_size: 32
    • max_wait_time: 10ms
    • queue.maxsize: 1000
  |
  style: {
    fill: "${cool_classics.light}"
    stroke: "${cool_classics.dark}"
    stroke-width: 1
    font-size: 11
    border-radius: 4
  }
}

# Backpressure indicator
backpressure: {
  shape: diamond
  label: "Backpressure\nqueue.full()\n→ HTTP 503"
  style: {
    fill: "${cool_classics.warning}"
    stroke: "${cool_classics.dark}"
    stroke-width: 1
    font-size: 10
  }
}
backpressure -> request_queue: {
  label: "triggers"
  style: {
    stroke: "${cool_classics.warning}"
    stroke-width: 1
    stroke-dash: 2
  }
}