direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# GPU Utilization: Sequential vs Batched
# Technical visualization of kernel launch overhead and SIMD efficiency

classes: {
  # Timing Component Classes
  launch: {
    label: "Kernel Launch\nOverhead"
    shape: rectangle
    style: {
      fill: "#ff6b6b"
      stroke: "#c92a2a"
      stroke-width: 2
    }
  }
  compute: {
    label: "GPU Compute\n(Utilization)"
    shape: rectangle
    style: {
      fill: "#51cf66"
      stroke: "#2f9e44"
      stroke-width: 2
    }
  }
  idle: {
    label: "GPU Idle\n(Waiting)"
    shape: rectangle
    style: {
      fill: "#dee2e6"
      stroke: "#adb5bd"
      stroke-dash: 3
    }
  }
  
  # Section Containers
  section_box: {
    style: {
      stroke: "#343a40"
      stroke-width: 3
      fill: "#f8f9fa"
      border-radius: 8
    }
  }
  
  # Metric Text
  metric_bad: {
    style: {
      font-color: "#c92a2a"
      bold: true
    }
  }
  metric_good: {
    style: {
      font-color: "#2f9e44"
      bold: true
    }
  }
}

title: |md
  # GPU Utilization Analysis
  ## Sequential Inference vs. Batched Inference
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
  }
}

# Global Legend
legend: {
  near: top-right
  label: "Timeline Key"
  
  k: { class: launch }
  c: { class: compute }
  i: { class: idle }
  
  k -> c -> i: "Execution Phase"
}

# ---------------------------------------------------------
# Sequential Inference Section
# ---------------------------------------------------------
sequential: {
  class: section_box
  label: "Sequential Inference (Batch Size = 1)"
  
  timeline: {
    label: "Temporal Execution Trace (48µs Total)"
    
    req1: {
      label: "Request 1"
      l: { class: launch; width: 60; label: "Launch\n10µs" }
      c: { class: compute; width: 20; label: "Ops\n2µs" }
      i: { class: idle; width: 40; label: "Gap" }
      l -> c -> i
    }
    
    req2: {
      label: "Request 2"
      l: { class: launch; width: 60; label: "Launch\n10µs" }
      c: { class: compute; width: 20; label: "Ops\n2µs" }
      i: { class: idle; width: 40; label: "Gap" }
      l -> c -> i
    }
    
    req3: {
      label: "Request 3"
      l: { class: launch; width: 60; label: "Launch\n10µs" }
      c: { class: compute; width: 20; label: "Ops\n2µs" }
      i: { class: idle; width: 40; label: "Gap" }
      l -> c -> i
    }
    
    req4: {
      label: "Request 4"
      l: { class: launch; width: 60; label: "Launch\n10µs" }
      c: { class: compute; width: 20; label: "Ops\n2µs" }
      i: { class: idle; width: 40; label: "Gap" }
      l -> c -> i
    }
    
    req1 -> req2 -> req3 -> req4: "Serial Bus"
  }
  
  metrics: {
    label: "Efficiency Metrics"
    style.fill: "#fff3bf"
    
    txt: |md
      - **Total Latency:** 48.0µs
      - **Compute Time:** 8.0µs
      - **Overhead:** 40.0µs
    |
    util: "GPU UTIL: 16.7%" { class: metric_bad }
  }
  
  timeline -> metrics
}

# ---------------------------------------------------------
# Batched Inference Section
# ---------------------------------------------------------
batched: {
  class: section_box
  label: "Batched Inference (Batch Size = 4)"
  
  batch_timeline: {
    label: "Temporal Execution Trace (18µs Total)"
    
    full_batch: {
      label: "Parallel Compute Group"
      
      launch_phase: {
        class: launch
        width: 60
        label: "Unified Launch\n10µs"
      }
      
      parallel_phase: {
        class: compute
        width: 80
        label: "SIMD Parallel Compute\n4x Parallel = 8µs"
        
        detail: {
          label: "Internal SIMD Threads"
          r1: { shape: circle; style.fill: "#74c0fc"; label: "R1" }
          r2: { shape: circle; style.fill: "#74c0fc"; label: "R2" }
          r3: { shape: circle; style.fill: "#74c0fc"; label: "R3" }
          r4: { shape: circle; style.fill: "#74c0fc"; label: "R4" }
          r1 -- r2 -- r3 -- r4
        }
      }
      
      launch_phase -> parallel_phase
    }
  }
  
  metrics: {
    label: "Efficiency Metrics"
    style.fill: "#d3f9d8"
    
    txt: |md
      - **Total Latency:** 18.0µs
      - **Compute Time:** 8.0µs
      - **Overhead:** 10.0µs
    |
    util: "GPU UTIL: 44.4%" { class: metric_good }
    throughput: "2.67x THROUGHPUT GAIN" { style.bold: true }
  }
  
  batch_timeline -> metrics
}

# ---------------------------------------------------------
# Technical Breakdown
# ---------------------------------------------------------
overhead_breakdown: {
  label: "Kernel Launch Overhead Components"
  class: section_box
  
  cpu_task: "CPU: Context Switch / API Call\n(5-8µs)" { style.fill: "#e9ecef" }
  pcie_bus: "PCIe: Arg Copy / Command Push\n(2-4µs)" { style.fill: "#dee2e6" }
  gpu_sched: "GPU: Hardware Scheduler Init\n(1-2µs)" { style.fill: "#ced4da" }
  
  cpu_task -> pcie_bus -> gpu_sched
}

summary: {
  label: "Summary Comparison"
  class: section_box
  style.fill: "#e7f5ff"
  
  s: "Sequential: High Latency, Low Util" { style.fill: "#ffe3e3" }
  b: "Batched: Low Latency/Request, High Util" { style.fill: "#d3f9d8" }
  i: "RESULT: 62% Latency Reduction per Batch" { style.bold: true }
  
  s -> b -> i
}

# Flow and Connections
sequential -> batched: "Enable Batching" {
  style: {
    stroke: "#339af0"
    stroke-width: 4
  }
}

batched -> overhead_breakdown: "Overhead Amortization" {
  style.stroke-dash: 5
}

overhead_breakdown -> summary: "System Performance"

# Positioning Fixed via Constants
annotation_seq: |md
  **STALL WARNING**
  GPU spends 83% of time
  waiting for CPU launch signals.
| {
  near: top-left
  shape: text
  style.font-color: red
}

annotation_batch: |md
  **OPTIMIZED**
  Fixed overhead cost is
  spread across 4 requests.
| {
  near: top-center
  shape: text
  style.font-color: green
}

# Corrected anchor for Insight box
insight_box: {
  shape: rectangle
  near: bottom-center
  label: "SYSTEM ARCHITECT NOTE: GPU Kernels are extremely fast but 'expensive' to start. Batching is the primary mechanism to reach hardware Roofline limits by making compute time significantly larger than the fixed launch overhead (~10µs)."
  style: {
    fill: "#fff9db"
    stroke: "#fab005"
    stroke-width: 2
    font-size: 16
  }
}