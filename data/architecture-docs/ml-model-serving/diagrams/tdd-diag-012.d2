direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    latency: "#E74C3C"
    throughput: "#3498DB"
    optimal: "#27AE60"
    axis: "#2C3E50"
    background: "#FDFEFE"
  }
}

# --- GLOBAL STYLES ---
classes: {
  latency_point: {
    shape: circle
    style: {
      fill: ${colors.latency}
      stroke: white
      stroke-width: 1
    }
  }
  throughput_point: {
    shape: diamond
    style: {
      fill: ${colors.throughput}
      stroke: white
      stroke-width: 1
    }
  }
  axis_label: {
    shape: text
    style: {
      font-size: 14
      bold: true
    }
  }
  annotation_box: {
    style: {
      stroke-width: 2
      border-radius: 4
      font-size: 12
    }
  }
}

title: {
  label: "Latency-Throughput Pareto Frontier\nRequest Batching Performance Trade-offs (NVIDIA T4 / Triton)"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# --- PLOT AREA CONTAINER ---
plot_area: {
  style: {
    fill: ${colors.background}
    stroke: "#BDC3C7"
    stroke-width: 1
  }

  # Axes
  x_axis: {
    label: "Batch Size (Log Scale)"
    shape: rectangle
    style.stroke: ${colors.axis}
    style.stroke-width: 4
    width: 900
    height: 4
  }
  
  y_axis_latency: {
    label: "Latency (ms)"
    shape: rectangle
    style.stroke: ${colors.latency}
    style.stroke-width: 4
    width: 4
    height: 450
  }
  
  y_axis_throughput: {
    label: "Throughput (req/s)"
    shape: rectangle
    style.stroke: ${colors.throughput}
    style.stroke-width: 4
    width: 4
    height: 450
  }

  # Batch Size X-Axis Markers
  batch_markers: {
    grid-columns: 7
    grid-gap: 80
    b1: "1"; b4: "4"; b8: "8"; b16: "16"; b32: "32"; b64: "64"; b128: "128"
    *.style.font-size: 12
  }

  # Latency Curve Data Points
  latency_1: { label: "12ms"; class: latency_point }
  latency_4: { label: "22ms"; class: latency_point }
  latency_8: { label: "38ms"; class: latency_point }
  latency_16: { label: "58ms"; class: latency_point; style.fill: "#F39C12" }
  latency_32: { 
    label: "65ms"
    class: latency_point
    style: {
      fill: ${colors.optimal}
      stroke-width: 3
      stroke: black
    }
  }
  latency_64: { label: "95ms"; class: latency_point }
  latency_128: { label: "195ms"; class: latency_point; style.fill: "#C0392B" }

  # Throughput Curve Data Points
  throughput_1: { label: "83"; class: throughput_point }
  throughput_4: { label: "182"; class: throughput_point }
  throughput_8: { label: "316"; class: throughput_point }
  throughput_16: { label: "410"; class: throughput_point; style.fill: "#F39C12" }
  throughput_32: { 
    label: "492"
    class: throughput_point
    style: {
      fill: ${colors.optimal}
      stroke-width: 3
      stroke: black
    }
  }
  throughput_64: { label: "545"; class: throughput_point }
  throughput_128: { label: "656"; class: throughput_point }

  # Curve Connections
  latency_1 -> latency_4 -> latency_8 -> latency_16 -> latency_32 -> latency_64 -> latency_128: {
    style: {
      stroke: ${colors.latency}
      stroke-width: 4
    }
    label: "Latency Curve"
    label.near: top-center
  }

  throughput_1 -> throughput_4 -> throughput_8 -> throughput_16 -> throughput_32 -> throughput_64 -> throughput_128: {
    style: {
      stroke: ${colors.throughput}
      stroke-width: 4
      stroke-dash: 5
    }
    label: "Throughput Curve"
    label.near: top-center
  }
}

# --- ANNOTATIONS & ZONES ---
zones: {
  optimal_region: {
    label: "Sweet Spot (Batch 32)\nOptimal GPU Saturation\nMin Jitter"
    class: annotation_box
    style: {
      fill: "#D5F5E3"
      stroke: ${colors.optimal}
      stroke-dash: 4
    }
  }
  
  plateau_zone: {
    label: "Plateau Zone\nIO Bound / Diminishing Returns"
    class: annotation_box
    style: {
      fill: "#FDEBD0"
      stroke: "#F39C12"
      stroke-dash: 4
    }
  }

  warning_zone: {
    label: "⚠ Warning\nSLA Violation (>150ms)"
    class: annotation_box
    style: {
      fill: "#FADBD8"
      stroke: "#E74C3C"
      stroke-dash: 4
    }
  }
}

# --- METRICS & LEGEND ---
sidebar: {
  metrics_box: {
    shape: sql_table
    label: "Operational Metrics @ Optimal"
    batch: "32 (Optimal)"
    throughput: "492 req/s"
    latency_p99: "65.4 ms"
    gpu_util: "81.4%"
    memory_pinned: "4.2 GB"
  }

  legend: {
    label: "Chart Legend"
    l_lat: "● Latency (Measured)" { style.font-color: ${colors.latency} }
    l_thr: "◆ Throughput (Measured)" { style.font-color: ${colors.throughput} }
    l_opt: "★ Optimal Selection" { style.font-color: ${colors.optimal} }
  }
}

# --- RELATIONSHIPS (Placement Hints) ---
plot_area.latency_32 -> zones.optimal_region: { style.stroke-dash: 3 }
plot_area.throughput_128 -> zones.plateau_zone: { style.stroke-dash: 3 }
plot_area.latency_128 -> zones.warning_zone: { style.stroke-dash: 3 }

# GPU Utilization callouts
plot_area.batch_markers.b1 -> gpu_low: "GPU 8%" { style.stroke-dash: 2 }
plot_area.batch_markers.b32 -> gpu_mid: "GPU 81%" { 
  style: {
    stroke-dash: 2
    stroke: ${colors.optimal}
    stroke-width: 2
  }
}
plot_area.batch_markers.b128 -> gpu_high: "GPU 94%" { style.stroke-dash: 2 }

gpu_low: { shape: text; style.font-size: 10 }
gpu_mid: { shape: text; style.font-size: 10; style.bold: true; style.font-color: ${colors.optimal} }
gpu_high: { shape: text; style.font-size: 10 }