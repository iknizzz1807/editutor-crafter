# Legend and Technical Reference
legend: {
  label: "Algorithm Legend"
  near: bottom-left
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
  
  item1: "█ Active Token (Attended)" {
    style.font-color: "#2E7D32"
  }
  item2: "█ Padding Token (Masked)" {
    style.font-color: "#E65100"
  }
}

implementation_logic: {
  label: |md
    ### Vectorized Implementation (PyTorch)
    python
    def prepare_batch(sequences):
        # 1. Calculate static dimensions
        lengths = [len(s) for s in sequences]
        max_l = max(lengths)
        B = len(sequences)
        
        # 2. Pre-allocate tensors on device
        ids = torch.zeros((B, max_l), dtype=torch.long)
        mask = torch.zeros((B, max_l), dtype=torch.long)
        
        # 3. Scatter raw data into tensors
        for i, s in enumerate(sequences):
            ids[i, :len(s)] = torch.tensor(s)
            mask[i, :len(s)] = 1
            
        return ids, mask
    
  |
  near: bottom-right
  style: {
    fill: "#263238"
    stroke: "#37474F"
    font-color: "#ECEFF1"
    font-size: 11
    multiple: true
  }
}