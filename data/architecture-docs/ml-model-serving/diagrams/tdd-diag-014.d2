direction: right
layout-engine: elk
title: {
  label: Request Queue State Machine
  shape: text
  near: top-center
  style.font-size: 24
  style.bold: true
  style.underline: true
}
# State styles
classes: {
  state_normal: {
    shape: circle
    style.stroke: "#4A90D9"
    style.stroke-width: 2
    style.fill: "#E8F4FD"
  }
  state_terminal: {
    shape: circle
    style.stroke: "#D9534F"
    style.stroke-width: 3
    style.fill: "#FDEDED"
  }
  state_active: {
    shape: circle
    style.stroke: "#5CB85C"
    style.stroke-width: 3
    style.fill: "#E8F5E8"
  }
  transition: {
    style.stroke: "#666666"
    style.stroke-width: 2
    style.animated: true
  }
}
# Initial pseudo-state
initial: {
  shape: circle
  style.fill: "#333333"
  style.stroke: "#333333"
  width: 20
  height: 20
}
# States
accepting: {
  class: state_active
  label: "accepting\n\n• Queue active\n• Accepts new requests\n• Returns batches"
  width: 140
  height: 140
}
draining: {
  class: state_normal
  label: "draining\n\n• No new requests\n• Process remaining\n• graceful shutdown"
  width: 140
  height: 140
}
shutdown: {
  class: state_terminal
  label: "shutdown\n\n• Queue closed\n• No operations\n• Terminal state"
  width: 140
  height: 140
}
# Transitions from initial state
initial -> accepting: {
  label: "init"
  style.stroke-width: 2
}
# Self-transitions on accepting
accepting -> accepting: {
  label: "enqueue()\l— Add request to queue\l— Returns position\l— Backpressure check\l"
  class: transition
}
accepting -> accepting: {
  label: "get_batch()\l— Pop up to batch_size\l— Returns List[Request]\l— Non-blocking\l"
  class: transition
}
# Transition to draining
accepting -> draining: {
  label: "shutdown(wait=True)\l— Graceful shutdown\l— Sets _is_draining=True\l— Rejects new requests\l"
  class: transition
  style.stroke: "#E67E22"
}
# Self-transition on draining
draining -> draining: {
  label: "get_batch()\l— Drain remaining\l— Until queue empty\l"
  class: transition
}
# Transition from accepting to shutdown (immediate)
accepting -> shutdown: {
  label: "shutdown(wait=False)\l— Immediate shutdown\l— Clears queue\l"
  class: transition
  style.stroke: "#D9534F"
}
# Transition from draining to shutdown
draining -> shutdown: {
  label: "queue.empty()\lOR\lshutdown(wait=False)\l"
  class: transition
  style.stroke: "#D9534F"
}
# Guard conditions legend
legend: {
  label: "Transition Guards & Invariants"
  shape: rectangle
  style.stroke: "#CCCCCC"
  style.stroke-dash: 4
  style.fill: "#FAFAFA"
  guard_enqueue: {
    label: "enqueue()\n─────────────\nguard: state == ACCEPTING\naction: queue.put_nowait()\nraises: QueueClosedError if draining"
    shape: rectangle
    style.fill: "#E8F4FD"
  }
  guard_getbatch: {
    label: "get_batch()\n─────────────\nguard: state != SHUTDOWN\naction: pop min(n, qsize)\nreturns: List[Request]"
    shape: rectangle
    style.fill: "#E8F4FD"
  }
  guard_shutdown: {
    label: "shutdown(wait)\n─────────────\nwait=True  → draining\nwait=False → shutdown\nraises: RuntimeError if already shutdown"
    shape: rectangle
    style.fill: "#FDEDED"
  }
}
# State invariants panel
invariants: {
  label: "State Invariants"
  shape: rectangle
  style.stroke: "#CCCCCC"
  style.stroke-dash: 4
  style.fill: "#FAFAFA"
  inv_accepting: {
    label: "ACCEPTING\n─────────\n• _is_draining = False\n• _is_shutdown = False\n• queue.put() allowed"
    shape: rectangle
    style.fill: "#E8F5E8"
  }
  inv_draining: {
    label: "DRAINING\n────────\n• _is_draining = True\n• _is_shutdown = False\n• queue.put() rejected"
    shape: rectangle
    style.fill: "#FFF8E8"
  }
  inv_shutdown: {
    label: "SHUTDOWN\n─────────\n• _is_shutdown = True\n• All operations rejected\n• Queue cleared"
    shape: rectangle
    style.fill: "#FDEDED"
  }
}
# Positioning
legend -> invariants: {
  style.opacity: 0
}
# Note about asyncio.Queue
note: {
  label: "Implementation Note\n────────────────────\nBacked by asyncio.Queue\nThread-safe via asyncio locks\nSupports backpressure via maxsize"
  shape: rectangle
  style.fill: "#FFF9E6"
  style.stroke: "#E6B800"
  style.stroke-dash: 3
}