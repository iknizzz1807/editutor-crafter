direction: right
layout-engine: elk

vars: {
  window_size: 1000
  percentile_indices: "p50: (n-1)*0.50, p90: (n-1)*0.90, p95: (n-1)*0.95, p99: (n-1)*0.99"
}

classes: {
  deque: {
    shape: class
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  metric_counter: {
    shape: hexagon
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
  metric_histogram: {
    shape: cylinder
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
}

title: "BatcherMetrics Sliding Window Data Structure" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# INPUT LAYER: Record Methods
# ═══════════════════════════════════════════════════════════════════════════════
input_layer: {
  label: "Input Layer\n(record methods)"
  record_request: {
    label: "record_request(\n  queue_wait_ms: float,\n  inference_ms: float,\n  total_ms: float\n)"
    shape: parallelogram
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
  }
  record_batch: {
    label: "record_batch(\n  batch_size: int\n)"
    shape: parallelogram
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
  }
  record_rejection: {
    label: "record_rejection()"
    shape: parallelogram
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
  }
  record_timeout: {
    label: "record_timeout()"
    shape: parallelogram
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE LAYER: Sliding Window Deques
# ═══════════════════════════════════════════════════════════════════════════════
storage_layer: {
  label: "Storage Layer\n(Sliding Window Deques)"
  
  latency_deques: {
    label: "Latency Sample Deques"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-dash: 3
    }
    queue_wait_times_ms: {
      class: deque
      label: "queue_wait_times_ms\n────────────────\nmaxlen: ${window_size}\ntype: deque[float]\n────────────────\n[0]: oldest wait time\n[1]: ...\n[n-1]: newest wait time"
    }
    inference_times_ms: {
      class: deque
      label: "inference_times_ms\n────────────────\nmaxlen: ${window_size}\ntype: deque[float]\n────────────────\n[0]: oldest inference\n[1]: ...\n[n-1]: newest inference"
    }
    total_times_ms: {
      class: deque
      label: "total_times_ms\n────────────────\nmaxlen: ${window_size}\ntype: deque[float]\n────────────────\n[0]: oldest total\n[1]: ...\n[n-1]: newest total"
    }
  }

  batch_sizes: {
    class: deque
    label: "batch_sizes\n────────────────\nmaxlen: ${window_size}\ntype: deque[int]\n────────────────\n[0]: oldest batch size\n[1]: ...\n[n-1]: newest batch size"
    style: {
      fill: "#FFF8E1"
      stroke: "#F57F17"
    }
  }

  counters: {
    label: "Cumulative Counters"
    style: {
      fill: "#FCE4EC"
      stroke: "#AD1457"
    }
    total_requests: {
      label: "total_requests: int\n────────────────\nAtomic increment\non each request"
      shape: stored_data
    }
    total_batches: {
      label: "total_batches: int\n────────────────\nAtomic increment\non each batch"
      shape: stored_data
    }
    total_rejected: {
      label: "total_rejected: int\n────────────────\nRejected requests\ncount"
      shape: stored_data
    }
    total_timeouts: {
      label: "total_timeouts: int\n────────────────\nTimed out requests\ncount"
      shape: stored_data
    }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMPUTATION LAYER: Percentile Calculator
# ═══════════════════════════════════════════════════════════════════════════════
computation_layer: {
  label: "Computation Layer\n(Percentile Calculation)"
  
  algorithm: {
    label: "Percentile Algorithm"
    shape: class
    style: {
      fill: "#E8F5E9"
      stroke: "#1B5E20"
    }
    method: {
      label: "calculate_percentile(\n  samples: deque[float],\n  percentile: float\n) -> float"
    }
    algo_steps: {
      label: "Algorithm Steps\n────────────────────────────────\n1. snapshot = list(samples)\n   # Copy deque to list\n\n2. if len(snapshot) == 0:\n      return 0.0\n\n3. sorted_data = sorted(snapshot)\n   # Ascending sort\n\n4. n = len(sorted_data)\n\n5. index = (n - 1) * (percentile / 100)\n   # Linear interpolation\n\n6. lower_idx = floor(index)\n   upper_idx = ceil(index)\n\n7. if lower_idx == upper_idx:\n      return sorted_data[lower_idx]\n   else:\n      weight = index - lower_idx\n      return sorted_data[lower_idx] * (1 - weight)\n           + sorted_data[upper_idx] * weight"
      shape: text
      style: {
        font: mono
        font-size: 12
      }
    }
  }

  percentiles: {
    label: "Percentile Index Computation"
    shape: sql_table
    style: {
      fill: "#F3E5F5"
    }
    p50: "index = (n-1) * 0.50"
    p90: "index = (n-1) * 0.90"
    p95: "index = (n-1) * 0.95"
    p99: "index = (n-1) * 0.99"
  }

  batch_percentiles: {
    label: "Batch Size Percentiles"
    shape: sql_table
    style: {
      fill: "#FFF8E1"
    }
    bp50: "median batch size"
    bp90: "90th percentile"
    bp95: "95th percentile"
    bp99: "99th percentile"
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# OUTPUT LAYER: Prometheus Export Format
# ═══════════════════════════════════════════════════════════════════════════════
prometheus_output: {
  label: "Prometheus Export Format\n(metrics endpoint)"
  
  histograms: {
    label: "Histogram Metrics"
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-dash: 3
    }
    queue_wait_histogram: {
      class: metric_histogram
      label: "batcher_queue_wait_ms\n──────────────────────\nTYPE: histogram\n──────────────────────\n_bucket{le=\"1.0\"}\n_bucket{le=\"5.0\"}\n_bucket{le=\"10.0\"}\n_bucket{le=\"25.0\"}\n_bucket{le=\"50.0\"}\n_bucket{le=\"100.0\"}\n_bucket{le=\"250.0\"}\n_bucket{le=\"500.0\"}\n_bucket{le=\"+Inf\"}\n_sum\n_count"
    }
    inference_histogram: {
      class: metric_histogram
      label: "batcher_inference_ms\n──────────────────────\nTYPE: histogram\n──────────────────────\n_bucket{le=\"1.0\"}\n_bucket{le=\"5.0\"}\n_bucket{le=\"10.0\"}\n_bucket{le=\"25.0\"}\n_bucket{le=\"50.0\"}\n_bucket{le=\"100.0\"}\n_bucket{le=\"250.0\"}\n_bucket{le=\"+Inf\"}\n_sum\n_count"
    }
    total_time_histogram: {
      class: metric_histogram
      label: "batcher_total_time_ms\n──────────────────────\nTYPE: histogram\n──────────────────────\n_bucket{le=\"10.0\"}\n_bucket{le=\"25.0\"}\n_bucket{le=\"50.0\"}\n_bucket{le=\"100.0\"}\n_bucket{le=\"250.0\"}\n_bucket{le=\"500.0\"}\n_bucket{le=\"1000.0\"}\n_bucket{le=\"+Inf\"}\n_sum\n_count"
    }
  }

  gauges: {
    label: "Gauge Metrics (Window Percentiles)"
    style: {
      fill: "#E8F5E9"
      stroke: "#1B5E20"
      stroke-dash: 3
    }
    latency_gauges: {
      label: "Latency Percentile Gauges\n────────────────────────────────\nbatcher_queue_wait_p50_ms GAUGE\nbatcher_queue_wait_p90_ms GAUGE\nbatcher_queue_wait_p95_ms GAUGE\nbatcher_queue_wait_p99_ms GAUGE\n────────────────────────────────\nbatcher_inference_p50_ms GAUGE\nbatcher_inference_p90_ms GAUGE\nbatcher_inference_p95_ms GAUGE\nbatcher_inference_p99_ms GAUGE\n────────────────────────────────\nbatcher_total_time_p50_ms GAUGE\nbatcher_total_time_p90_ms GAUGE\nbatcher_total_time_p95_ms GAUGE\nbatcher_total_time_p99_ms GAUGE"
      shape: text
      style: {
        font: mono
        font-size: 11
      }
    }
    batch_gauges: {
      label: "Batch Size Percentile Gauges\n────────────────────────────────\nbatcher_batch_size_p50 GAUGE\nbatcher_batch_size_p90 GAUGE\nbatcher_batch_size_p95 GAUGE\nbatcher_batch_size_p99 GAUGE\n────────────────────────────────\nbatcher_batch_size_avg GAUGE"
      shape: text
      style: {
        font: mono
        font-size: 11
      }
    }
  }

  counters_output: {
    label: "Counter Metrics (Cumulative)"
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-dash: 3
    }
    counter_metrics: {
      label: "Counter Exports\n────────────────────────────────\nbatcher_requests_total COUNTER\n  LABELS: {status=\"success|rejected|timeout\"}\n────────────────────────────────\nbatcher_batches_total COUNTER\n────────────────────────────────\nbatcher_rejected_total COUNTER\n────────────────────────────────\nbatcher_timeouts_total COUNTER\n────────────────────────────────\nbatcher_window_size GAUGE\n  VALUE: ${window_size}"
      shape: text
      style: {
        font: mono
        font-size: 11
      }
    }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# DATA FLOW CONNECTIONS
# ═══════════════════════════════════════════════════════════════════════════════
input_layer.record_request -> storage_layer.latency_deques.queue_wait_times_ms: "append()\nO(1)"
input_layer.record_request -> storage_layer.latency_deques.inference_times_ms: "append()\nO(1)"
input_layer.record_request -> storage_layer.latency_deques.total_times_ms: "append()\nO(1)"
input_layer.record_request -> storage_layer.counters.total_requests: "increment"
input_layer.record_batch -> storage_layer.batch_sizes: "append()\nO(1)"
input_layer.record_batch -> storage_layer.counters.total_batches: "increment"
input_layer.record_rejection -> storage_layer.counters.total_rejected: "increment"
input_layer.record_timeout -> storage_layer.counters.total_timeouts: "increment"

storage_layer.latency_deques.queue_wait_times_ms -> computation_layer.algorithm: "snapshot()"
storage_layer.latency_deques.inference_times_ms -> computation_layer.algorithm: "snapshot()"
storage_layer.latency_deques.total_times_ms -> computation_layer.algorithm: "snapshot()"
storage_layer.batch_sizes -> computation_layer.batch_percentiles: "snapshot()"

computation_layer.percentiles -> prometheus_output.gauges.latency_gauges: "percentile values"
computation_layer.batch_percentiles -> prometheus_output.gauges.batch_gauges: "batch percentiles"

storage_layer.latency_deques.queue_wait_times_ms -> prometheus_output.histograms.queue_wait_histogram: "all samples"
storage_layer.latency_deques.inference_times_ms -> prometheus_output.histograms.inference_histogram: "all samples"
storage_layer.latency_deques.total_times_ms -> prometheus_output.histograms.total_time_histogram: "all samples"

storage_layer.counters.total_requests -> prometheus_output.counters_output.counter_metrics: "export"
storage_layer.counters.total_batches -> prometheus_output.counters_output.counter_metrics: "export"
storage_layer.counters.total_rejected -> prometheus_output.counters_output.counter_metrics: "export"
storage_layer.counters.total_timeouts -> prometheus_output.counters_output.counter_metrics: "export"

# ═══════════════════════════════════════════════════════════════════════════════
# MEMORY LAYOUT DETAIL
# ═══════════════════════════════════════════════════════════════════════════════
memory_layout: {
  label: "Memory Layout (deque internals)"
  near: bottom-center
  deque_structure: {
    label: "collections.deque Internals\n────────────────────────────────────────\n┌─────────────────────────────────────┐\n│  deque[maxlen=1000]                 │\n├─────────────────────────────────────┤\n│  left (popleft)  │  right (append)  │\n│       ←          │       →          │\n├─────────────────────────────────────┤\n│  BLOCK: 64 entries per block        │\n│  ┌────┬────┬────┬────┬─────────┐    │\n│  │ v0 │ v1 │ v2 │ .. │ v63     │    │\n│  └────┴────┴────┴────┴─────────┘    │\n│         ↓ linked list ↓             │\n│  ┌────┬────┬────┬────┬─────────┐    │\n│  │ v64│ v65│ v66│ .. │ v127    │    │\n│  └────┴────┴────┴────┴─────────┘    │\n│  ... (up to 1000 entries)           │\n├─────────────────────────────────────┤\n│  Thread-safe for append/appendleft  │\n│  Auto-popleft when len > maxlen     │\n└─────────────────────────────────────┘"
    shape: text
    style: {
      font: mono
      font-size: 10
      fill: "#FAFAFA"
      stroke: "#424242"
    }
  }
  sliding_window_behavior: {
    label: "Sliding Window Behavior\n────────────────────────────────────────\n  Initial: [ ] (empty)\n  \n  After 3 appends:\n  [v0] → [v1] → [v2]\n  \n  After 1000 appends (full window):\n  [v0] → [v1] → ... → [v999]\n  \n  On 1001st append:\n  v0 auto-removed (popleft)\n  [v1] → [v2] → ... → [v1000]\n  \n  Window always maintains:\n  min(len(deque), maxlen) samples"
    shape: text
    style: {
      font: mono
      font-size: 10
      fill: "#E8F5E9"
      stroke: "#2E7D32"
    }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# SAMPLE PROMETHEUS OUTPUT
# ═══════════════════════════════════════════════════════════════════════════════
sample_output: {
  label: "Sample Prometheus Text Output"
  near: bottom-right
  output_example: {
    label: "# HELP batcher_queue_wait_ms Queue wait time in milliseconds\n# TYPE batcher_queue_wait_ms histogram\nbatcher_queue_wait_ms_bucket{le=\"1.0\"} 45\nbatcher_queue_wait_ms_bucket{le=\"5.0\"} 234\nbatcher_queue_wait_ms_bucket{le=\"10.0\"} 567\nbatcher_queue_wait_ms_bucket{le=\"25.0\"} 823\nbatcher_queue_wait_ms_bucket{le=\"50.0\"} 945\nbatcher_queue_wait_ms_bucket{le=\"100.0\"} 989\nbatcher_queue_wait_ms_bucket{le=\"+Inf\"} 1000\nbatcher_queue_wait_ms_sum 18456.7\nbatcher_queue_wait_ms_count 1000\n\n# HELP batcher_queue_wait_p95_ms 95th percentile queue wait\n# TYPE batcher_queue_wait_p95_ms gauge\nbatcher_queue_wait_p95_ms 42.3\n\n# HELP batcher_requests_total Total requests processed\n# TYPE batcher_requests_total counter\nbatcher_requests_total{status=\"success\"} 9847\nbatcher_requests_total{status=\"rejected\"} 23\nbatcher_requests_total{status=\"timeout\"} 12"
    shape: text
    style: {
      font: mono
      font-size: 9
      fill: "#263238"
      stroke: "#37474F"
    }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# THREAD SAFETY ANNOTATION
# ═══════════════════════════════════════════════════════════════════════════════
thread_safety: {
  label: "Thread Safety Notes"
  near: bottom-left
  notes: {
    label: "Concurrency Model\n────────────────────────────────────────\n• Deques: Thread-safe for append()\n  but NOT for read-modify-write\n\n• Counters: Use threading.Lock()\n  or atomic increment\n\n• Percentile calc: Snapshot copy\n  prevents race during sort\n\n• Recommended: threading.RLock()\n  for composite operations"
    shape: text
    style: {
      font: mono
      font-size: 10
      fill: "#FFFDE7"
      stroke: "#F9A825"
    }
  }
}