direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# --- STYLES & CLASSES ---
classes: {
  header_purple: {
    style: {
      fill: "#E1D5E7"
      stroke: "#9673A6"
      font-color: "#000000"
      bold: true
    }
  }
  data_blue: {
    style: {
      fill: "#DAE8FC"
      stroke: "#6C8EBF"
    }
  }
  enum_purple: {
    style: {
      fill: "#F8CECC"
      stroke: "#B85450"
    }
  }
}

# --- MODEL REGISTRY ---
ModelRegistry: {
  shape: class
  class: header_purple
  tooltip: "Main singleton for model lifecycle management. sizeof=128 bytes"
  
  "_versions": "OrderedDict[str, ModelVersion]"
  "_active_version_id": "str"
  "_lock": "threading.RLock"
  "max_versions_in_memory": "int = 3"
  
  "get_version(id: str)": "ModelVersion | None"
  "get_active()": "ModelVersion | None"
  "register(path: str)": "str"
  "activate(id: str)": "bool"
  "drain(id: str)": "bool"
}

VersionStatus: {
  shape: class
  class: enum_purple
  tooltip: "Version Lifecycle States"
  STAGED: const
  ACTIVE: const
  DRAINING: const
  DEPRECATED: const
  FAILED: const
}

ModelVersion: {
  shape: class
  class: data_blue
  tooltip: "Metadata and runtime handle for a specific model artifact. sizeof=512 bytes"
  
  "version_id": "str"
  "model_path": "str"
  "status": "VersionStatus"
  "training_date": "datetime"
  "training_data_hash": "str"
  "accuracy_metrics": "dict[str, float]"
  "hyperparameters": "dict[str, Any]"
  "schema": "ModelSchema"
  "loaded_model": "nn.Module | None"
  "device": "torch.device | None"
  "load_time": "datetime | None"
  "warmup_latency_ms": "float | None"
  "in_flight_count": "int = 0"
}

ModelSchema: {
  shape: class
  class: data_blue
  tooltip: "Input/Output Tensor signatures"
  "input_shapes": "dict[str, tuple[int, ...]]"
  "input_dtypes": "dict[str, str]"
  "output_shapes": "dict[str, tuple[int, ...]]"
  "output_dtypes": "dict[str, str]"
}

# --- RUNTIME STATE VISUALIZATION ---
VersionsContainer: {
  shape: rectangle
  label: "_versions: OrderedDict"
  style: {
    stroke-dash: 2
    fill: "#F5F5F5"
  }
  
  v1: {
    shape: class
    label: "ModelVersion\nv1.0.0"
    status: "STAGED"
    style.fill: "#FFF2CC"
  }
  v2: {
    shape: class
    label: "ModelVersion\nv1.1.0"
    status: "ACTIVE"
    style.fill: "#D5E8D4"
    style.stroke-width: 3
  }
  v3: {
    shape: class
    label: "ModelVersion\nv1.2.0"
    status: "DRAINING"
    style.fill: "#F8CECC"
  }
}

# --- RELATIONSHIPS ---

# Registry owns the versions container
ModelRegistry -> VersionsContainer: "references" {
  source-arrowhead: 1
  target-arrowhead: "*"
  style.stroke: "#5C8B5C"
  style.stroke-width: 2
}

# Link instances to the definition
VersionsContainer.v1 -> ModelVersion: "instance_of" {
  style.stroke-dash: 3
  style.stroke: "#6B6B6B"
}
VersionsContainer.v2 -> ModelVersion: "instance_of" {
  style.stroke-dash: 3
  style.stroke: "#6B6B6B"
}
VersionsContainer.v3 -> ModelVersion: "instance_of" {
  style.stroke-dash: 3
  style.stroke: "#6B6B6B"
}

# Domain references
ModelVersion -> VersionStatus: "status enum" {
  style.stroke-dash: 3
  style.stroke: "#5C5C8B"
}

ModelVersion -> ModelSchema: "owns" {
  style.stroke: "#5C8B5C"
  target-arrowhead: "*"
}

# Pointers and Protection
ActivePointer: {
  shape: hexagon
  label: "_active_version_id"
  style.fill: "#FFE6CC"
}

ActivePointer -> VersionsContainer.v2: "points_to" {
  style.stroke: "#8B5C5C"
  style.stroke-width: 3
}

LockMechanism: {
  shape: rectangle
  label: "_lock: RLock\n(Thread Safety)"
  style.fill: "#E1D5E7"
}

ModelRegistry -> LockMechanism: "protects concurrent access" {
  style.stroke-dash: 3
  style.stroke: "#8B8B5C"
}