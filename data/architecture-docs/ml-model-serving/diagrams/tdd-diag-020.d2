direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Memory Budget During Hot Swap - GPU Memory Layout
# Peak Memory = Old Model + New Model + Activation Buffers (~2.5x single-model)

classes: {
  memory_region: {
    style: {
      stroke-width: 3
      font: mono
    }
  }
  old_model: {
    style: {
      fill: "#FF6B6B"
      stroke: "#C92A2A"
    }
  }
  new_model: {
    style: {
      fill: "#4DABF7"
      stroke: "#1864AB"
    }
  }
  activation: {
    style: {
      fill: "#69DB7C"
      stroke: "#2B8A3E"
    }
  }
  metadata: {
    style: {
      fill: "#FFE066"
      stroke: "#E67700"
    }
  }
  free_space: {
    style: {
      fill: "#E9ECEF"
      stroke: "#ADB5BD"
      stroke-dash: 4
    }
  }
  address_label: {
    shape: text
    style: {
      font: mono
      font-size: 11
      bold: true
    }
  }
}

title: "Memory Budget During Hot Swap" {
  shape: text
  style: {
    font-size: 20
    bold: true
    underline: true
  }
}

subtitle: "Peak Memory: 2.5x Single-Model | Both models coexist during atomic pointer swap" {
  shape: text
  style: {
    font-size: 13
    italic: true
  }
}

# Memory Address Space Container
GPU_Memory: {
  label: "GPU Memory Space (8GB Total)"
  style: {
    fill: "#F8F9FA"
    stroke: "#343A40"
    stroke-width: 4
  }
  # Address Column
  addresses: {
    label: "Address Offsets"
    a0: "0x0000_0000" {
      class: address_label
    }
    a1: "0x0001_0000" {
      class: address_label
    }
    a2: "0x0800_0000" {
      class: address_label
    }
    a3: "0x1000_0000" {
      class: address_label
    }
    a4: "0x1800_0000" {
      class: address_label
    }
    a5: "0x2000_0000" {
      class: address_label
    }
  }
  # Memory Regions
  MetaData: {
    class: [memory_region; metadata]
    label: "Model Metadata\n(Page Tables, Pointers)\n\nSize: 64KB\nAlign: 4KB boundary"
    width: 200
    height: 60
  }
  OldModel: {
    class: [memory_region; old_model]
    label: "OLD MODEL (v1.2.3)\n━━━━━━━━━━━━━━━━\nWeights: 1.8GB\nBias: 0.15GB\nEmbeddings: 0.05GB\n━━━━━━━━━━━━━━━━\nTOTAL: 2GB\nRefCount: 3"
    width: 200
    height: 180
  }
  NewModel: {
    class: [memory_region; new_model]
    label: "NEW MODEL (v1.2.4)\n━━━━━━━━━━━━━━━━\nWeights: 1.8GB\nBias: 0.15GB\nEmbeddings: 0.05GB\n━━━━━━━━━━━━━━━━\nTOTAL: 2GB\nStatus: LOADING"
    width: 200
    height: 180
  }
  ActivationBuffer: {
    class: [memory_region; activation]
    label: "ACTIVATION BUFFERS\n━━━━━━━━━━━━━━━━━━\nKV Cache: 2GB\nAttention: 1GB\nIntermediate: 1GB\n━━━━━━━━━━━━━━━━━━\nTOTAL: ~4GB\nCache Lines: 64B"
    width: 200
    height: 240
  }
  FreeSpace: {
    class: [memory_region; free_space]
    label: "Available Headroom\n\n~0GB (At Capacity)\n\nGC Pending on\nOld Model Release"
    width: 200
    height: 60
  }
}

# Memory Layout Diagram
Memory_Layout: {
  # Visual memory blocks
  meta_block: {
    shape: rectangle
    class: metadata
    label: "Metadata\n64KB"
    width: 300
    height: 40
  }
  old_block: {
    shape: rectangle
    class: old_model
    label: "OLD MODEL v1.2.3\n2GB (0x0800_0000)\nRefCount: 3 | Active Inferences: 12"
    width: 300
    height: 150
  }
  new_block: {
    shape: rectangle
    class: new_model
    label: "NEW MODEL v1.2.4\n2GB (0x1000_0000)\nLoading: 87% ████████▒░"
    width: 300
    height: 150
  }
  activation_block: {
    shape: rectangle
    class: activation
    label: "Activation Buffers\n~4GB (0x1800_0000)\n├─ KV Cache: 2GB\n├─ Attention: 1GB\n└─ Intermediate: 1GB"
    width: 300
    height: 200
  }
  free_block: {
    shape: rectangle
    class: free_space
    label: "Free Space\n~0GB\n(Exhausted)"
    width: 300
    height: 40
  }
  # Connections for visual flow
  meta_block -> old_block: {
    style.opacity: 0
  }
  old_block -> new_block: {
    style.opacity: 0
  }
  new_block -> activation_block: {
    style.opacity: 0
  }
  activation_block -> free_block: {
    style.opacity: 0
  }
}

# Address Annotations
AddressMarks: {
  "0x0000_0000": {
    shape: text
    class: address_label
  }
  "0x0001_0000 (64KB)": {
    shape: text
    class: address_label
  }
  "0x0800_0000 (2GB)": {
    shape: text
    class: address_label
  }
  "0x1000_0000 (4GB)": {
    shape: text
    class: address_label
  }
  "0x1800_0000 (6GB)": {
    shape: text
    class: address_label
  }
  "0x2000_0000 (8GB)": {
    shape: text
    class: address_label
  }
}

# Hot Swap State Info
HotSwapState: {
  label: "Hot Swap State"
  style.fill: "#FFF9DB"
  Phase: {
    shape: diamond
    style.fill: "#FF922B"
    label: "PHASE 2\nLOADING"
  }
  Timeline: {
    shape: sequence_diagram
    p1: "Phase 1: Init"
    p2: "Phase 2: Load ★"
    p3: "Phase 3: Warmup"
    p4: "Phase 4: Swap"
    p5: "Phase 5: GC"
    p1 -> p2: "trigger"
    p2 -> p3: "load_complete"
    p3 -> p4: "warmup_ok"
    p4 -> p5: "refcount=0"
  }
  Metrics: {
    shape: sql_table
    Peak_Memory: "8GB / 8GB (100%)"
    Old_Model: "2GB (pending release)"
    New_Model: "2GB (87% loaded)"
    Activations: "4GB (active)"
    Memory_Multiplier: "2.5x normal"
  }
}

# Legend
Legend: {
  label: "Memory Region Legend"
  old_key: {
    shape: rectangle
    class: old_model
    label: "Old Model\n(To Be Released)"
    width: 100
    height: 40
  }
  new_key: {
    shape: rectangle
    class: new_model
    label: "New Model\n(Loading)"
    width: 100
    height: 40
  }
  act_key: {
    shape: rectangle
    class: activation
    label: "Activation Buffers\n(Runtime)"
    width: 100
    height: 40
  }
  meta_key: {
    shape: rectangle
    class: metadata
    label: "Metadata\n(System)"
    width: 100
    height: 40
  }
  free_key: {
    shape: rectangle
    class: free_space
    label: "Free Space\n(Available)"
    width: 100
    height: 40
  }
}

# Critical Warning
Warning: "⚠ CRITICAL: Peak memory usage during hot swap requires 2.5x single-model capacity" {
  shape: text
  style: {
    font-size: 14
    bold: true
    font-color: "#C92A2A"
  }
}

# Connections
title -> subtitle -> GPU_Memory
GPU_Memory -> Memory_Layout -> HotSwapState
HotSwapState -> Legend
Legend -> Warning

# Memory Budget Calculation
BudgetCalc: {
  label: "Memory Budget Calculation"
  shape: sql_table
  Single_Model: "2GB"
  Peak_During_HotSwap: "2GB + 2GB + 4GB = 8GB"
  Multiplier: "8GB / 2GB = 4x (worst case)"
  Typical_Multiplier: "~2.5x with optimizations"
  Minimum_GPU_Memory: "8GB recommended"
}
Legend -> BudgetCalc