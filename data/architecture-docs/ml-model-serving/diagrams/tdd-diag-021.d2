direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
title: "Atomic Pointer Swap Mechanism" {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: "Module M3 - HotSwapManager Consistency Guarantee" {
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}

# --- STATE 1: PRE-SWAP ---
Before_Swap: {
  label: "Phase 1: Steady State (v1.0.0)"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
  
  old_version: {
    shape: cylinder
    label: "Version: v1.0.0\nStatus: ACTIVE\nBase: 0x7FFF0010"
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      bold: true
    }
  }
  
  pointer_before: {
    shape: diamond
    label: "AtomicPointer\n[Mem: 0x00A4]\nVal: 0x7FFF0010"
    style.fill: "#FFC107"
  }
  
  requests_before: {
    shape: rectangle
    label: "In-Flight Requests\n(Worker Threads 1-5)"
    style.fill: "#BBDEFB"
    style.multiple: true
  }
  
  pointer_before -> old_version: "reads" {
    style.stroke-width: 2
  }
  requests_before -> pointer_before: "fetch addr"
}

# --- LOGIC: ALGORITHM DEFINITION ---
Algorithm_Steps: {
  label: "Atomic Swap Procedure"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
  }
  
  step1: {
    shape: hexagon
    label: "Step 1\nLock Acquisition\n\nawait self._lock.acquire()"
    style: {
      fill: "#FF5722"
      font-color: white
      bold: true
    }
  }
  
  step2: {
    shape: hexagon
    label: "Step 2\nAtomic Update\n\n[CAS Operation]\nptr.swap(new_addr)"
    style: {
      fill: "#FF9800"
      bold: true
    }
  }
  
  step3: {
    shape: hexagon
    label: "Step 3\nFinalization\n\nself._lock.release()"
    style: {
      fill: "#FFC107"
      bold: true
    }
  }
  
  step1 -> step2 -> step3: {
    style.stroke-width: 4
  }
}

# --- CONCURRENCY: CRITICAL SECTION ---
Critical_Section: {
  label: "⚠️ EXCLUSIVE LOCK DOMAIN"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-dash: 5
  }
  
  blocked_swap: {
    shape: rectangle
    label: "Concurrent Swap\nRequest (Blocked)"
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
    }
  }
  
  wait_queue: {
    label: "Process Wait Queue\n(FIFO)"
    style.multiple: true
    style.fill: "#EEEEEE"
  }
  
  blocked_swap -> wait_queue: "yields" {
    style: {
      stroke: "#EF5350"
      stroke-dash: 3
    }
  }
}

# --- STATE 2: POST-SWAP ---
After_Swap: {
  label: "Phase 2: Transition & Drain"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  
  new_version: {
    shape: cylinder
    label: "Version: v2.0.0\nStatus: ACTIVE\nBase: 0x8AAA1100"
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      bold: true
    }
  }
  
  old_version_draining: {
    shape: cylinder
    label: "Version: v1.0.0\nStatus: DRAINING"
    style: {
      fill: "#FF9800"
      stroke: "#E65100"
      stroke-dash: 4
    }
  }
  
  pointer_after: {
    shape: diamond
    label: "AtomicPointer\nVal: 0x8AAA1100"
    style.fill: "#00BCD4"
  }
  
  new_requests: {
    shape: rectangle
    label: "New Requests\n(Worker Threads 6+)"
    style.fill: "#C8E6C9"
  }
  
  draining_requests: {
    shape: rectangle
    label: "Legacy Refs\n(Ref Counter > 0)"
    style.fill: "#FFE0B2"
  }
  
  pointer_after -> new_version: "reads"
  new_requests -> pointer_after: "get latest"
  old_version_draining -> draining_requests: "cleanup" {
    style.stroke-dash: 3
  }
}

# --- DATA STRUCTURE ---
Class_Definition: {
  AtomicVersionPointer: {
    shape: class
    style.fill: "#E1F5FE"
    
    "_version_id": "Optional[str]"
    "_version": "Optional[ModelVersion]"
    "_lock": "asyncio.Lock"
    "_ref_counts": "Dict[str, int]"
    
    "swap(new_v)": "ModelVersion"
    "acquire_ref()": "str"
    "release_ref(id)": "void"
    "get_version()": "ModelVersion"
  }
}

# --- SPECS ---
Consistency_Guarantee: {
  label: "Consistency Invariants"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
  
  guarantee_text: {
    shape: text
    label: |md
      - **Linearizability**: All requests see exactly one version.
      - **Isolation**: No partial v2 data visible during swap.
      - **Atomicity**: Swap is single bus-locked instruction.
      - **Ref-Counting**: Old version stays in RAM until refs == 0.
      - **Zero Latency**: Reads are non-blocking (Lock-Free).
    |
  }
}

# --- TIMELINE ---
Timeline: {
  label: "Operation Linearization Timeline"
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
  }
  
  t1: "T1" { shape: circle; style.fill: "#64B5F6" }
  t2: "T2" { shape: circle; style.fill: "#FF7043" }
  t3: "T3" { shape: circle; style.fill: "#FFA726" }
  t4: "T4" { shape: circle; style.fill: "#66BB6A" }
  
  t1_label: "Lock Acquire" { shape: text }
  t2_label: "Swap Pointer" { shape: text }
  t3_label: "Lock Release" { shape: text }
  t4_label: "Drain Complete" { shape: text }
  
  t1 -> t1_label
  t2 -> t2_label
  t3 -> t3_label
  t4 -> t4_label
  
  t1 -> t2 -> t3 -> t4: {
    style: {
      stroke-width: 4
      stroke: "#455A64"
    }
  }
}

# --- GLOBAL CONNECTIONS ---
Before_Swap -> Algorithm_Steps: "Trigger Update" {
  style.stroke-width: 2
  style.stroke: "#1565C0"
}

Algorithm_Steps.step1 -> Critical_Section: "Acquire Mutex" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}

Algorithm_Steps -> After_Swap: "Commit Changes" {
  style.stroke-width: 3
  style.stroke: "#2E7D32"
}

Class_Definition -> Algorithm_Steps: "Implementation Logic" {
  style.stroke-dash: 5
}

After_Swap -> Consistency_Guarantee: "Verification" {
  style.stroke: "#7B1FA2"
}

Algorithm_Steps -> Timeline: "Sequence Mapping" {
  style.stroke: "#BDBDBD"
  style.stroke-dash: 2
}