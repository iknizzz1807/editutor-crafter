direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Version Routing Architecture
  **Subsystem ID:** SVC-RESOLVER-01
  **Spec:** TDD-DIAG-025
| {
  near: top-center
  shape: text
}

# Request entry point with technical metadata
HTTPRequest: {
  shape: hexagon
  style.fill: "#E8F5E9"
  label: "HTTP Request\nPOST /predict"
  tooltip: "Entry protocol: HTTPS/2.0"
}

# Central routing component with detailed internal logic blocks
VersionRouter: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
  label: "VersionRouter (Logic Engine)"

  internals: {
    url_parser: {
      label: "Regex URL Parser\n^/v/([a-z0-9-]+)/"
      shape: rectangle
      style.font-size: 10
    }
    header_parser: {
      label: "Header Parser\nKey: X-Model-Version"
      shape: rectangle
      style.font-size: 10
    }
    fallback_resolver: {
      label: "Default Resolver\nSource: AtomicPointer"
      shape: rectangle
      style.font-size: 10
    }
    decision_engine: {
      label: "Decision Logic\n(COALESCE)"
      shape: diamond
      style.fill: "#FFFFFF"
    }
  }
}

# Routing sources with priority mapping
# FIXED: Nested 'schema' map removed as sql_table rows cannot have children.
URLPath: {
  shape: sql_table
  label: "Priority 1: URL Segment"
  style.fill: "#FFF3E0"
  segment: "/v/{id}/predict"
  extraction: "capture group 1"
  validation: "uuid_v4"
}

HeaderSource: {
  shape: sql_table
  label: "Priority 2: Header Map"
  style.fill: "#F3E5F5"
  key: "X-Model-Version"
  encoding: "UTF-8"
  limit: "64 chars"
}

DefaultVersion: {
  shape: sql_table
  label: "Priority 3: System Default"
  style.fill: "#ECEFF1"
  source: "Consul / Etcd"
  caching: "TTL 30s"
}

# Dependency Layer
ModelRegistry: {
  shape: cylinder
  label: "Model Metadata DB"
  style.fill: "#FFF8E1"
}

AtomicVersionPointer: {
  shape: sql_table
  label: "AtomicVersionPointer (Memory-Mapped)"
  style.fill: "#FCE4EC"
  # Byte offsets documented in labels for engineer implementation
  "0x00 (8B)": "uint64 active_version_id"
  "0x08 (8B)": "uint64 promotion_timestamp"
  "0x10 (16B)": "char[16] cluster_id"
  "0x20 (32B)": "Padding/Reserved" {style.fill: gray}
}

RequestTracker: {
  shape: rectangle
  label: "Prometheus Metric Sink"
  style.fill: "#E0F7FA"
}

# Output Resolution
ModelVersion: {
  shape: rectangle
  label: "Resolved ModelVersion"
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 3
    bold: true
  }
}

# Connections - Request flow
HTTPRequest -> VersionRouter: "packet arrival" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}

# Inspection paths - Sequential probing
VersionRouter.internals.url_parser -> URLPath: {
  style.stroke-dash: 3
  label: "Probe 1"
}

VersionRouter.internals.header_parser -> HeaderSource: {
  style.stroke-dash: 3
  label: "Probe 2"
}

VersionRouter.internals.fallback_resolver -> DefaultVersion: {
  style.stroke-dash: 3
  label: "Probe 3"
}

# Internal routing logic mapping
VersionRouter.internals.url_parser -> VersionRouter.internals.decision_engine: "Candidate A"
VersionRouter.internals.header_parser -> VersionRouter.internals.decision_engine: "Candidate B"
VersionRouter.internals.fallback_resolver -> VersionRouter.internals.decision_engine: "Candidate C"

# Decision output
VersionRouter.internals.decision_engine -> ModelVersion: "RESOLVED_ID" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

# External Reference Dependencies
VersionRouter -> ModelRegistry: {
  style.stroke-dash: 5
  label: "SQL lookup"
}

VersionRouter -> AtomicVersionPointer: {
  style.stroke-dash: 5
  label: "mmap read"
}

VersionRouter -> RequestTracker: {
  style.stroke-dash: 5
  label: "UDP 514"
}

# System Integrity Connection
ModelRegistry -> AtomicVersionPointer: {
  label: "writes pointer"
  style: {
    stroke: "#1565C0"
    stroke-dash: 2
  }
}

# Legend with specific technical markers
legend: {
  label: "Protocol Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  
  l1: "──  Synchronous Call" {
    shape: text
    style.font-size: 10
  }
  l2: "--  Async / Reference" {
    shape: text
    style.font-size: 10
  }
  l3: "Priority Order: Path > Header > Default" {
    shape: text
    style.font-size: 10
    style.bold: true
  }
}

# Fixed Annotation - Using ELK-compatible constant position
annotation: {
  shape: text
  label: |md
    ### Routing Resolution Logic
    1. **Extract** version from URL path segment.
    2. **If null**, extract from `X-Model-Version` header.
    3. **If null**, fetch pointer from `AtomicVersionPointer`.
    4. **Validate** resolved ID against `ModelRegistry`.
  |
  near: top-right
}

# Styling Globs
***.style.font: mono
(*** -> ***)[*].style.font-size: 10