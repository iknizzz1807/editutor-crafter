direction: right
layout-engine: elk
title: {
  label: "Statistical Significance Testing\nTwo-Sample T-Test Algorithm"
  shape: text
  near: top-center
}
# Input Data
inputs: {
  shape: rectangle
  style.fill: "#E3F2FD"
  sample_a: {
    shape: rectangle
    label: "Sample A"
    style.fill: "#BBDEFB"
    mean_a: { label: "mean_A\nμ_A" }
    std_a: { label: "std_dev_A\nσ_A" }
    n_a: { label: "n_A\nsample size" }
  }
  sample_b: {
    shape: rectangle
    label: "Sample B"
    style.fill: "#BBDEFB"
    mean_b: { label: "mean_B\nμ_B" }
    std_b: { label: "std_dev_B\nσ_B" }
    n_b: { label: "n_B\nsample size" }
  }
}
# Step 1: Compute Standard Errors
step1: {
  shape: rectangle
  label: "Step 1: Compute Standard Errors"
  style.fill: "#E8F5E9"
  se_a: {
    label: "SE_A = σ_A / √n_A"
    shape: text
  }
  se_b: {
    label: "SE_B = σ_B / √n_B"
    shape: text
  }
}
# Step 2: Compute SE of Difference
step2: {
  shape: rectangle
  label: "Step 2: Standard Error of Difference"
  style.fill: "#E8F5E9"
  se_diff: {
    label: "SE_diff = √(SE_A² + SE_B²)"
    shape: text
  }
}
# Step 3: Compute T-Statistic
step3: {
  shape: rectangle
  label: "Step 3: Compute T-Statistic"
  style.fill: "#E8F5E9"
  t_stat: {
    label: "t = (μ_A - μ_B) / SE_diff"
    shape: text
  }
}
# Step 4: Degrees of Freedom (Welch's)
step4: {
  shape: rectangle
  label: "Step 4: Degrees of Freedom\n(Welch's Formula)"
  style.fill: "#E8F5E9"
  df_formula: {
    label: "df = (SE_A² + SE_B²)² /\n[(SE_A⁴/(n_A-1)) + (SE_B⁴/(n_B-1))]"
    shape: text
  }
}
# Step 5: Compute P-Value
step5: {
  shape: rectangle
  label: "Step 5: Compute P-Value"
  style.fill: "#E8F5E9"
  p_value: {
    label: "p = 2 × P(T > |t|)\n(Student's t-distribution)"
    shape: text
  }
  test_type: {
    label: "Test Type:\n• Two-tailed (default)\n• One-tailed (greater/less)"
    shape: text
  }
}
# Step 6: Effect Size
step6: {
  shape: rectangle
  label: "Step 6: Effect Size\n(Cohen's d)"
  style.fill: "#E8F5E9"
  pooled_std: {
    label: "σ_pooled = √[(σ_A² + σ_B²) / 2]"
    shape: text
  }
  cohens_d: {
    label: "d = (μ_A - μ_B) / σ_pooled"
    shape: text
  }
}
# Step 7: Confidence Interval
step7: {
  shape: rectangle
  label: "Step 7: Confidence Interval"
  style.fill: "#E8F5E9"
  ci_formula: {
    label: "CI = (μ_A - μ_B) ± t_crit × SE_diff\n(typically 95% confidence)"
    shape: text
  }
}
# Output: Test Result
output: {
  shape: rectangle
  label: "TestResult"
  style.fill: "#FFF3E0"
  results: {
    t_statistic: { label: "t_statistic" }
    p_value: { label: "p_value" }
    df: { label: "degrees_of_freedom" }
    effect_size: { label: "effect_size (d)" }
    ci_lower: { label: "ci_lower" }
    ci_upper: { label: "ci_upper" }
    is_significant: { label: "is_significant\n(p < α)" }
  }
}
# Interpretation
interpretation: {
  shape: diamond
  label: "Interpretation"
  style.fill: "#FCE4EC"
  significant: {
    label: "Significant (p < 0.05)\n→ Reject H₀\n→ Models differ meaningfully"
    shape: text
  }
  not_significant: {
    label: "Not Significant (p ≥ 0.05)\n→ Fail to reject H₀\n→ No meaningful difference"
    shape: text
  }
}
# Connections
inputs.sample_a -> step1: "Input"
inputs.sample_b -> step1: "Input"
step1 -> step2: "SE values"
step2 -> step3: "SE_diff"
step3 -> step4: "t-stat"
step3 -> step5: "t-stat"
step4 -> step5: "df"
step5 -> step6: "continue"
step6 -> step7: "effect size"
step2 -> step7: "SE_diff"
step5 -> output: "p-value"
step3 -> output: "t-stat"
step4 -> output: "df"
step6 -> output: "d"
step7 -> output: "CI"
output -> interpretation: "evaluate"
# Alpha threshold note
alpha_note: {
  shape: text
  label: "α = 0.05 (typical significance level)\n\nEffect Size Interpretation:\n• |d| < 0.2: Small\n• 0.2 ≤ |d| < 0.8: Medium\n• |d| ≥ 0.8: Large"
  near: bottom-center
}