direction: right
layout-engine: elk
theme-id: 200
title: Sample Size vs Detectable Effect |'md\n## Statistical Power Analysis for A/B Testing\n\n**Formula:** `n = 2 × (Z_α + Z_β)² × σ² / Δ²`\n\nThis diagram shows the data flow for calculating required sample size\nto detect a meaningful effect in A/B experiments.\n'|
variables: {
  shape: rectangle
  label: "Input Parameters"
  style.fill: "#E3F2FD"
  alpha: {
    shape: rectangle
    label: "Significance Level\n(α = 0.05)"
    style.fill: "#BBDEFB"
  }
  beta: {
    shape: rectangle
    label: "Type II Error\n(β = 0.20)"
    style.fill: "#BBDEFB"
  }
  power: {
    shape: rectangle
    label: "Statistical Power\n(1-β = 0.80)"
    style.fill: "#90CAF9"
  }
  sigma: {
    shape: rectangle
    label: "Population\nVariance (σ²)"
    style.fill: "#BBDEFB"
  }
  delta: {
    shape: rectangle
    label: "Minimum Detectable\nEffect (Δ)"
    style.fill: "#BBDEFB"
  }
}
variables: {
  alpha -> z_alpha
  beta -> z_beta
}
z_scores: {
  shape: rectangle
  label: "Z-Score Lookup"
  style.fill: "#FFF3E0"
  z_alpha: {
    shape: rectangle
    label: "Z_α = 1.96\n(two-tailed)"
    style.fill: "#FFE0B2"
  }
  z_beta: {
    shape: rectangle
    label: "Z_β = 0.84\n(one-tailed)"
    style.fill: "#FFE0B2"
  }
}
z_scores: {
  z_alpha -> numerator
  z_beta -> numerator
}
numerator: {
  shape: rectangle
  label: "Numerator Calculation\n(Z_α + Z_β)² × σ² × 2"
  style.fill: "#E8F5E9"
}
effect_sq: {
  shape: rectangle
  label: "Effect Squared\nΔ²"
  style.fill: "#FFEBEE"
}
variables.sigma -> numerator
variables.delta -> effect_sq
division: {
  shape: diamond
  label: "Division\n÷"
  style.fill: "#F3E5F5"
}
numerator -> division
effect_sq -> division
sample_size: {
  shape: rectangle
  label: "Required Sample Size\n(n per group)"
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}
division -> sample_size
insights: {
  shape: rectangle
  label: "Key Insights"
  style.fill: "#FAFAFA"
  insight1: {
    shape: text
    |'md\n**Smaller Δ → Larger n**\nDetecting small effects requires more samples\n'|
  }
  insight2: {
    shape: text
    |'md\n**Higher Power → Larger n**\n80% power is standard minimum\n'|
  }
  insight3: {
    shape: text
    |'md\n**Higher Variance → Larger n**\nNoisy data needs more samples\n'|
  }
}
sample_size -> insights
legend: {
  shape: rectangle
  label: "Parameter Definitions"
  style.fill: "#FAFAFA"
  params: {
    shape: text
    |'md\n| Symbol | Definition | Typical Value |\n|--------|------------|---------------|\n| α | Significance level | 0.05 |\n| β | Type II error rate | 0.20 |\n| 1-β | Statistical power | 0.80 |\n| σ² | Population variance | Data-dependent |\n| Δ | Minimum detectable effect | Business-defined |\n| n | Sample size per group | Calculated |\n'|
  }
}
example: {
  shape: rectangle
  label: "Example Calculation"
  style.fill: "#FFF8E1"
  calc: {
    shape: text
    |'md\n**Given:**\n- α = 0.05 → Z_α = 1.96\n- β = 0.20 → Z_β = 0.84\n- σ² = 0.25 (conversion rate variance)\n- Δ = 0.05 (5% minimum detectable effect)\n\n**Calculation:**\n\nn = 2 × (1.96 + 0.84)² × 0.25 / 0.05²\nn = 2 × 7.84 × 0.25 / 0.0025\nn = 1,568 per group\n\n**Total sample needed: 3,136 users**\n'|
  }
}