direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- STYLING CLASSES ---
classes: {
  annotation_box: {
    shape: rectangle
    style: {
      stroke-dash: 3
      stroke: "#6b7280"
      fill: "#f3f4f6"
      font-color: "#374151"
      italic: true
      font-size: 11
    }
  }
  header_style: {
    style: {
      fill: "#1a1a2e"
      stroke: "#4a9eff"
      stroke-width: 4
      font-color: "#ffffff"
      bold: true
      font-size: 18
    }
  }
  module_style: {
    shape: hexagon
    style: {
      fill: "#2d3748"
      stroke: "#48bb78"
      stroke-width: 3
      font-color: "#48bb78"
      bold: true
    }
  }
  offset_label: {
    shape: text
    style: {
      font: mono
      font-size: 11
      font-color: "#6b7280"
    }
  }
}

title: |md
  # Experiment Log Structure (PredictionLog)
  **Specification:** Engineering Manual v1.2.0
  **Memory Alignment:** 8-Byte (QWORD)
  **Serialization:** Protobuf / FlatBuffers Optimized
| {
  near: top-center
  shape: text
}

# --- MAIN DATA STRUCTURE ---
PredictionLog: {
  style: {
    fill: "#f8fafc"
    stroke: "#4a9eff"
    stroke-width: 2
    shadow: true
  }

  Header: "struct PredictionLog (0x0000)" {
    class: header_style
  }

  # --- Section 1: Core ID ---
  CoreSection: {
    label: "Core Identification Block"
    style.fill: "#e0e7ff"
    style.stroke: "#4f46e5"
    
    annotation: "Offset [0x00 - 0x2F]\nFixed 48B Header\nNo-Alloc Zone" {
      class: annotation_box
    }

    t_0x00: "0x00 | timestamp: float64 [8B]" { tooltip: "Unix Epoch Nanos" }
    t_0x08: "0x08 | experiment_id: uuid [16B]" { tooltip: "RFC 4122" }
    t_0x18: "0x18 | request_id: uuid [16B]" { tooltip: "Trace ID" }
    t_0x28: "0x28 | user_id: uint64 [8B]" { tooltip: "Hash ID" }
  }

  # --- Section 2: Model ---
  AllocationSection: {
    label: "Model & Routing Context"
    style.fill: "#f0fdf4"
    style.stroke: "#16a34a"

    annotation: "Offset [0x30 - 0x6F]\nVariable Metadata\nPointer-heavy" {
      class: annotation_box
    }
    
    t_0x30: "0x30 | model_version: string_ref [8B]"
    t_0x38: "0x38 | allocation_hash: int32 [4B]"
    t_0x3C: "0x3C | padding: char[4]" { style.fill: "#d1d5db" }
    t_0x40: "0x40 | input_hash: sha256 [32B]"
  }

  # --- Section 3: Inference ---
  OutputSection: {
    label: "Inference Result Payload"
    style.fill: "#fff7ed"
    style.stroke: "#ea580c"

    annotation: "Offset [0x70 - 0x9F]\nOutput Buffer\nHeap References" {
      class: annotation_box
    }
    
    t_0x70: "0x70 | prediction_ptr: *byte [8B]"
    t_0x78: "0x78 | prediction_class: uint16 [2B]"
    t_0x7A: "0x7A | padding: char[2]" { style.fill: "#d1d5db" }
    t_0x7C: "0x7C | confidence: float32 [4B]"
  }

  # --- Section 4: Telemetry ---
  StatusSection: {
    label: "SLA & Telemetry Metadata"
    style.fill: "#fef2f2"
    style.stroke: "#dc2626"

    annotation: "Offset [0xA0 - End]\nSLA Metrics\nMonitoring Path" {
      class: annotation_box
    }
    
    t_0xA0: "0xA0 | latency_ms: float32 [4B]"
    t_0xA4: "0xA4 | success: bool [1B]"
    t_0xA5: "0xA5 | padding: char[3]" { style.fill: "#d1d5db" }
    t_0xA8: "0xA8 | error_msg_ref: string_ref [8B]"
    t_0xB0: "0xB0 | metadata_map_ptr: *map [8B]"
  }
}

# --- INFRASTRUCTURE CONTEXT ---

ExperimentLogger: {
  class: module_style
  label: "MODULE M4\nExperiment\nLogger"
}

# Solid arrow = Owns/Creates (Architecture Rule)
ExperimentLogger -> PredictionLog: "ALLOCATE & POPULATE\n(Zero-Copy Path)" {
  style: {
    stroke: "#48bb78"
    stroke-width: 3
  }
}

ExperimentStore: {
  shape: cylinder
  label: "S3 Experiment\nLog Store\n(Parquet/Snappy)"
  style: {
    fill: "#2d3748"
    stroke: "#ed8936"
    font-color: "#ed8936"
    stroke-width: 3
  }
}

# Dashed arrow = References/Persists
PredictionLog -> ExperimentStore: "PERSIST VIA FIREHOSE\n(Async Buffer)" {
  style: {
    stroke: "#ed8936"
    stroke-width: 2
    stroke-dash: 3
  }
}

DriftDetector: {
  shape: diamond
  label: "ML Ops\nDrift\nDetector"
  style: {
    fill: "#2d3748"
    stroke: "#f56565"
    font-color: "#f56565"
    stroke-width: 3
  }
}

ExperimentStore -> DriftDetector: "POLL INPUT_HASH\n(Distribution Check)" {
  style: {
    stroke: "#f56565"
    stroke-width: 2
  }
}

# Boundary Legend
Legend: {
  near: bottom-right
  header: "Byte Alignment & Layout Legend"
  
  field_8b: "Fixed Width / 8B Aligned" {
    style: {
      fill: "#e0e7ff"
      stroke-dash: 0
    }
  }
  padding: "Alignment Padding" {
    style: {
      fill: "#d1d5db"
      stroke: "#9ca3af"
    }
  }
  variable: "Heap Reference / Ptr" {
    style: {
      fill: "#fff7ed"
      stroke-dash: 5
    }
  }
}