layout-engine: elk
direction: right

title: "Latency Histogram Bucket Structure | Memory Layout" {
  near: top-center
  shape: text
  style: {
    font-size: 26
    bold: true
    underline: true
  }
}

# Instruction-Compliant Color Classes
classes: {
  header_cell: {
    style: {
      fill: "#8B5CF6"
      font-color: white
      bold: true
      stroke: "#4C1D95"
      stroke-width: 2
    }
  }
  data_cell: {
    style: {
      fill: "#3B82F6"
      font-color: white
      stroke: "#1D4ED8"
      stroke-width: 2
    }
  }
  pointer_cell: {
    style: {
      fill: "#F97316"
      font-color: white
      stroke: "#9A3412"
      stroke-width: 2
    }
  }
  padding_cell: {
    style: {
      fill: "#9CA3AF"
      font-color: "#374151"
      stroke-dash: 3
      stroke: "#4B5563"
    }
  }
  free_cell: {
    style: {
      fill: "#22C55E"
      font-color: white
      stroke: "#15803D"
      stroke-width: 2
    }
  }
  memory_box: {
    style: {
      fill: "#F8FAFC"
      stroke: "#0F172A"
      stroke-width: 3
      border-radius: 4
    }
  }
}

# Legend: Engineer Grade Reference
legend: {
  label: "Memory Map Legend"
  near: top-left
  width: 280
  grid-columns: 1
  style: {
    fill: "#F1F5F9"
    stroke: "#334155"
    stroke-width: 2
  }
  
  h: "Header/Metadata (8B)" { class: header_cell }
  d: "Data Field (8B)" { class: data_cell }
  p: "Pointer/Reference (8B)" { class: pointer_cell }
  x: "Padding/Alignment" { class: padding_cell }
  f: "Free/Available" { class: free_cell }
}

# Main Structure: LatencyHistogram (Stack/Heap Container)
latency_histogram: {
  class: memory_box
  label: "LatencyHistogram Structure | sizeof = 56 bytes"
  
  # Object Header (Standard Runtime Metadata)
  obj_header: {
    label: "Runtime Header (16B)"
    grid-columns: 1
    style.stroke: "#64748B"
    
    t_ptr: "0x00 | type_ptr (vtable) [8 bytes]" { class: pointer_cell }
    r_cnt: "0x08 | refcount (atomic) [8 bytes]" { class: header_cell }
  }

  # Instance Fields
  fields: {
    label: "Instance Fields (40B)"
    grid-columns: 1
    style.stroke: "#64748B"
    
    b_ptr: "0x10 | buckets_ptr ----> [8 bytes]" { class: pointer_cell }
    s_tot: "0x18 | sum_total (float64) [8 bytes]" { class: data_cell }
    c_tot: "0x20 | count_total (int64) [8 bytes]" { class: data_cell }
    pad1:  "0x28 | alignment_padding  [8 bytes]" { class: padding_cell }
    pad2:  "0x30 | alignment_padding  [8 bytes]" { class: padding_cell }
  }
  
  # Structural Layout Connection
  obj_header -> fields: { style.stroke: transparent; style.opacity: 0 }
}

# Bucket Array (Target of buckets_ptr)
bucket_array: {
  class: memory_box
  label: "Heap: HistogramBucket Array | 16 bytes per element"
  
  # Slice/Array Metadata
  array_header: {
    label: "Metadata"
    grid-columns: 2
    len: "len: 8 bytes" { class: header_cell }
    cap: "cap: 8 bytes" { class: header_cell }
  }

  # Data Segments
  bucket_0: {
    label: "Bucket[0] @0x10"
    grid-columns: 1
    b0_u: "upper: 5.0ms" { class: data_cell }
    b0_c: "count: 1247" { class: data_cell }
  }
  
  bucket_1: {
    label: "Bucket[1] @0x20"
    grid-columns: 1
    b1_u: "upper: 10.0ms" { class: data_cell }
    b1_c: "count: 2891" { class: data_cell }
  }
  
  bucket_2: {
    label: "Bucket[2] @0x30"
    grid-columns: 1
    b2_u: "upper: 25.0ms" { class: data_cell }
    b2_c: "count: 4523" { class: data_cell }
  }
  
  bucket_n: {
    label: "..."
    style.stroke: transparent
    style.fill: transparent
  }

  bucket_last: {
    label: "Bucket[N-1] @Final"
    grid-columns: 1
    bl_u: "upper: +Inf" { class: data_cell }
    bl_c: "count: 5000" { class: data_cell }
  }

  # Sequence flow for ELK positioning
  (array_header -> bucket_0 -> bucket_1 -> bucket_2 -> bucket_n -> bucket_last).style: {
    stroke: transparent
    opacity: 0
  }
}

# Detail: The Atomic Unit of Storage
bucket_detail: {
  class: memory_box
  label: "HistogramBucket Layout Detail"
  
  upper: "Offset 0x00 | upper_bound (float64)" { 
    class: data_cell 
    tooltip: "The maximum latency value (exclusive) for this bucket."
  }
  count: "Offset 0x08 | count (int64)" { 
    class: data_cell 
    tooltip: "Cumulative number of observations ≤ upper_bound."
  }
  
  upper -> count: "8 bytes" { style.stroke-dash: 2 }
}

# Cache Line Visual Guide
cache_line: {
  label: "L1 Cache Boundary (64 Bytes)"
  style: {
    stroke: "#F59E0B"
    stroke-width: 4
    stroke-dash: 6
    fill: transparent
    bold: true
  }
  content: "4 Buckets x 16B = 64B" {
    shape: text
    style.font-color: "#D97706"
  }
}

# Algorithms: observe()
observe_op: {
  label: "ALGORITHM: observe(latency)"
  style: {
    fill: "#ECFDF5"
    stroke: "#10B981"
  }
  
  step: |md
    ### Binary Search or Linear Scan
    1. Update **sum_total** += latency
    2. Update **count_total**++
    3. For each Bucket **B**:
       - If latency < B.upper_bound:
         - **B.count++** (Cumulative update)
  |
}

# Algorithms: percentile()
percentile_op: {
  label: "ALGORITHM: percentile(q)"
  style: {
    fill: "#F5F3FF"
    stroke: "#8B5CF6"
  }
  
  formula: |latex
    P_q = L + (U - L) \cdot \frac{N \cdot q - C_{prev}}{C_{curr} - C_{prev}}
  |
  
  desc: "Where L,U are bucket bounds and C is cumulative count." { shape: text }
}

# Summary and Constraints
specs: {
  label: "Technical Specifications"
  style.fill: "#FFFBEB"
  grid-columns: 1
  
  a: "Word Size: 64-bit (8 bytes)"
  b: "Alignment: 8-byte boundaries enforced"
  c: "Concurrency: Atomic updates required for counts"
  d: "Memory: ~216 bytes for 10-bucket instance"
}

# Physical/Logical Connections
latency_histogram.fields.b_ptr -> bucket_array.array_header: "Deref buckets_ptr" {
  style: {
    stroke: "#F97316"
    stroke-width: 3
    animated: true
  }
}

# Global Positioning using invisible connections (fixed syntax)
legend -> latency_histogram: { style.stroke: transparent; style.opacity: 0 }
latency_histogram -> bucket_array: { style.stroke: transparent; style.opacity: 0 }
bucket_array -> bucket_detail: { style.stroke: transparent; style.opacity: 0 }
bucket_detail -> observe_op: { style.stroke: transparent; style.opacity: 0 }
observe_op -> percentile_op: { style.stroke: transparent; style.opacity: 0 }
percentile_op -> specs: { style.stroke: transparent; style.opacity: 0 }
specs -> cache_line: { style.stroke: transparent; style.opacity: 0 }