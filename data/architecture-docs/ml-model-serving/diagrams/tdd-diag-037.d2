direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "KS Test: Comparing Distributions" {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# Step 1: Sort Both Samples
step1: {
  label: "1. Sort Observed Samples"
  style: {
    fill: "#F8F9FA"
    stroke-width: 2
  }
  
  input_group: {
    label: "Unsorted Data"
    sample1_unsorted: {
      label: "Sample 1 (Baseline)\nX = [0.42, 0.17, 0.89, 0.31, 0.56]\nn=5"
      shape: rectangle
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
    }
    sample2_unsorted: {
      label: "Sample 2 (Current)\nY = [0.38, 0.62, 0.15, 0.71, 0.29]\nm=5"
      shape: rectangle
      style: {
        fill: "#FFF3E0"
        stroke: "#F57C00"
      }
    }
  }

  output_group: {
    label: "Rank-Ordered Data"
    sample1_sorted: {
      label: "Sorted Sample 1\nX' = [0.17, 0.31, 0.42, 0.56, 0.89]"
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
        bold: true
      }
    }
    sample2_sorted: {
      label: "Sorted Sample 2\nY' = [0.15, 0.29, 0.38, 0.62, 0.71]"
      shape: rectangle
      style: {
        fill: "#FFE0B2"
        stroke: "#F57C00"
        bold: true
      }
    }
  }

  input_group -> output_group: "Sort(ASC)" {
    style: {
      stroke: "#4CAF50"
      stroke-width: 4
      font-size: 18
      bold: true
    }
  }
}

# Step 2: Compute Empirical CDFs
step2: {
  label: "2. Compute Empirical CDFs (ECDF)"
  style: {
    fill: "#F8F9FA"
  }
  
  sorted_inputs: {
    label: "Sorted Inputs"
    s1: {
      label: "S1: [0.17, 0.31, 0.42, 0.56, 0.89]"
      style.fill: "#E3F2FD"
    }
    s2: {
      label: "S2: [0.15, 0.29, 0.38, 0.62, 0.71]"
      style.fill: "#FFF3E0"
    }
  }

  cdf_formula: {
    label: "ECDF Calculation\nFₙ(x) = 1/n ∑ I(Xᵢ ≤ x)"
    shape: callout
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-dash: 3
    }
  }

  cdf_outputs: {
    label: "Step Functions"
    cdf1_table: {
      label: "F₁(x) (Baseline)\n[0, 0.17): 0.0\n[0.17, 0.31): 0.2\n[0.31, 0.42): 0.4\n[0.42, 0.56): 0.6\n[0.56, 0.89): 0.8\n[0.89, ∞): 1.0"
      style.fill: "#BBDEFB"
      style.font: mono
    }
    cdf2_table: {
      label: "F₂(x) (Current)\n[0, 0.15): 0.0\n[0.15, 0.29): 0.2\n[0.29, 0.38): 0.4\n[0.38, 0.62): 0.6\n[0.62, 0.71): 0.8\n[0.71, ∞): 1.0"
      style.fill: "#FFE0B2"
      style.font: mono
    }
  }

  sorted_inputs -> cdf_formula -> cdf_outputs
}

# Step 3: Find Maximum Vertical Distance
step3: {
  label: "3. Determine D-Statistic"
  style: {
    fill: "#F8F9FA"
  }

  cdf_graph: {
    label: "Vertical Distance Analysis"
    style.fill: "#FFFFFF"
    
    plot: {
      label: "CDF Superimposition Graph\n\n1.0 |      ┌─── F₁(x)\n    |   ┌──┘\n0.5 | ┌─┘\n    | ┘    <-- D is Max Gap\n0.0 └───────────────\n      0.0        1.0"
      shape: rectangle
    }
    
    d_stat_visual: {
      label: "Dₙ,ₘ = sup|F₁(x) - F₂(x)|"
      shape: rectangle
      style: {
        fill: "#FFEBEE"
        stroke: "#D32F2F"
        bold: true
        stroke-width: 3
      }
    }
  }

  d_calculation: {
    label: "Iteration Logic\n\nCheck at every jump point:\nx=0.15: |0.0 - 0.2| = 0.2\nx=0.17: |0.2 - 0.2| = 0.0\nx=0.29: |0.2 - 0.4| = 0.2\n...\nMax Distance Found:\nD = 0.20"
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      font: mono
    }
  }

  cdf_graph -> d_calculation
}

# Step 4: P-Value and Significance
step4: {
  label: "4. Null Hypothesis Testing"
  style: {
    fill: "#F8F9FA"
  }

  d_input: {
    label: "D-Stat: 0.20\nn=5, m=5"
    shape: rectangle
    style.fill: "#E3F2FD"
  }

  pvalue_formula: {
    label: "P-Value Approximation\n\nStatistic: λ = D√(nm/(n+m))\nP ≈ Q_ks(λ)\n\nThreshold (α): 0.05"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
    }
  }

  interpretation: {
    label: "Final Decision"
    pvalue_result: {
      label: "p-value: 0.99 (approx)"
      style: {
        fill: "#C8E6C9"
        bold: true
      }
    }
    result: {
      label: "Verdict: FAIL TO REJECT H₀\nNo Drift Detected ✓"
      style: {
        fill: "#A5D6A7"
        stroke: "#2E7D32"
        bold: true
      }
    }
  }

  d_input -> pvalue_formula -> interpretation
}

# Flow Connections
step1 -> step2 -> step3 -> step4: {
  style: {
    stroke: "#757575"
    stroke-width: 3
    stroke-dash: 5
  }
}

# Legend and Global Annotations
legend: {
  near: bottom-right
  baseline: "■ Baseline (Reference)" {
    shape: text
    style.font-color: "#1976D2"
  }
  current: "■ Current (Production)" {
    shape: text
    style.font-color: "#F57C00"
  }
  statistic: "■ KS Statistic (D)" {
    shape: text
    style.font-color: "#D32F2F"
  }
}