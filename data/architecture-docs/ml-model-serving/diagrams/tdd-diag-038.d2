vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 101
  }
}

direction: right

# Global Title and Metadata
title: {
  label: "DRIFT DETECTION PIPELINE: STATISTICAL VALIDATION ARCHITECTURE"
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
    font-color: "#1A237E"
  }
}

# 1. INPUT SECTION: INGESTION LAYER
requests: {
  label: "Ingestion Layer\n(Feature Vector Stream)"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
  
  http_req: {
    label: "HTTP Proxy\nPOST /v1/predict"
    shape: hexagon
    style.fill: "#BBDEFB"
    tooltip: "Entry point for real-time inference requests"
  }
  
  feature_spec: {
    label: "Feature Schema\n[Size: 512 Floats | 2048 Bytes]"
    shape: text
    style.font-size: 12
    style.italic: true
  }
}

# 2. SAMPLING LAYER: RESERVOIR IMPLEMENTATION
sampling: {
  label: "Sampling Control Plane"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
  }
  
  sampler: {
    label: "DriftDetectionSampler"
    shape: rectangle
    style: {
      stroke: "#FF9800"
      stroke-width: 2
      bold: true
    }
  }
  
  should_sample: {
    label: "should_sample()\nDecision Gate"
    shape: diamond
    style.fill: "#FFE0B2"
  }
  
  reservoir: {
    label: "Sampling Implementation"
    shape: rectangle
    style.fill: "#FFFFFF"
    
    algorithm: |python
      def should_sample(self):
          # K: reservoir capacity (e.g. 10,000)
          # N: total stream count (rolling)
          if self.count < self.capacity:
              return True
          return random.random() < (self.capacity / self.count)
    |
  }
}

# 3. FEATURE STORAGE: PERSISTENCE LAYER
storage: {
  label: "Feature Observation Buffer"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  
  buffer: {
    label: "Sample Cache\n(In-Memory)\nsizeof=20MB"
    shape: cylinder
    style: {
      stroke: "#4CAF50"
      stroke-width: 2
      fill: "#C8E6C9"
    }
  }
  
  record: {
    label: "append_feature_vector()\nSerialization"
    shape: rectangle
    style: {
      fill: "#A5D6A7"
      border-radius: 4
      double-border: true
    }
  }
  
  metadata: {
    label: "Window: 5min\nMax Records: 10k"
    shape: text
    style.font-size: 12
    style.font: mono
  }
}

# 4. STATISTICAL TESTING: DETECTION ENGINE
testing: {
  label: "Statistical Analysis Engine"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }
  
  scheduler: {
    label: "Cron: */5 * * * *"
    shape: circle
    style: {
      stroke: "#9C27B0"
      stroke-width: 2
      fill: "#E1BEE7"
    }
  }
  
  ks_test: {
    label: "Kolmogorov-Smirnov\nTwo-Sample Test"
    shape: rectangle
    style: {
      stroke: "#9C27B0"
      stroke-width: 3
      bold: true
      shadow: true
    }
  }
  
  comparison: {
    label: "Null Hypothesis (H0):\nDistributions Identical"
    shape: diamond
    style.fill: "#CE93D8"
  }
}

# 5. BASELINE DATA: REFERENCE DISTRIBUTION
baseline: {
  label: "Reference Store"
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    stroke-width: 2
  }
  
  training_dist: {
    label: "Frozen Baseline\n(Training/Val Set)\nFormat: Protobuf"
    shape: cylinder
    style: {
      stroke: "#607D8B"
      fill: "#CFD8DC"
    }
  }
  
  load_baseline: {
    label: "Pull from S3\nRegistry"
    shape: parallelogram
    style: {
      fill: "#B0BEC5"
      stroke: "#546E7A"
    }
  }
}

# 6. ALERT MANAGEMENT: INCIDENT CONTROL
alerts: {
  label: "Incident Orchestration"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
  }
  
  alert_mgr: {
    label: "DriftAlertManager"
    shape: rectangle
    style: {
      stroke: "#F44336"
      stroke-width: 2
      bold: true
    }
  }
  
  evaluate: {
    label: "P-Value Check\n(α = 0.05)"
    shape: diamond
    style.fill: "#FFCDD2"
  }
  
  cooldown: {
    label: "Suppression Logic\n(Deduplication)"
    shape: rectangle
    style: {
      fill: "#EF9A9A"
      border-radius: 4
      stroke-dash: 2
    }
  }
  
  sla_info: {
    label: "SEVERITY CLASSIFICATION\n--------------------\n• p < 0.05 : WARNING\n• p < 0.01 : CRITICAL"
    shape: text
    style.font-size: 11
    style.bold: true
  }
}

# 7. OUTPUT CHANNELS: NOTIFICATION DISPATCH
output: {
  label: "Downstream Consumers"
  style: {
    fill: "#E0F7FA"
    stroke: "#00838F"
    stroke-width: 2
  }
  
  notify: {
    label: "Dispatch Bus"
    shape: step
    style: {
      stroke: "#00BCD4"
      stroke-width: 2
      fill: "#B2EBF2"
    }
  }
  
  channels: {
    label: "Sink Interfaces"
    shape: rectangle
    style.fill: "#E0F2F1"
    
    pd: "PagerDuty (Incident)"
    slack: "Slack (Log)"
    email: "Stakeholders (Report)"
    
    pd.style.fill: "#FFCDD2"
    slack.style.fill: "#C8E6C9"
    email.style.fill: "#E1F5FE"
  }
}

# 8. AUDIT LOGGING: OBSERVABILITY
logging: {
  label: "Audit Trail"
  style: {
    fill: "#F9FBE7"
    stroke: "#827717"
    stroke-width: 2
  }
  
  log_entry: {
    label: "JSON Incident Record"
    shape: rectangle
    style.fill: "#FFFFFF"
    
    payload: |json
      {
        "event": "drift_detected",
        "p_value": 0.003,
        "severity": "CRITICAL",
        "timestamp": "2024-01-15T10:30:00Z",
        "detector": "KS-Test-V2"
      }
    |
  }
}

# --- CONNECTIONS ---

# Request Flow
requests.http_req -> sampling.sampler: "intercept" {style.bold: true}
sampling.sampler -> sampling.should_sample: "check bias"
sampling.should_sample -> sampling.reservoir: "evaluate K/N"
sampling.should_sample -> storage.record: "TRUE: Record" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
}
sampling.should_sample -> requests.http_req: "FALSE: Pass-thru" {
  style: {
    stroke: "#757575"
    stroke-dash: 5
  }
}

# Persistence
storage.record -> storage.buffer: "write vector"

# Analysis Flow
storage.buffer -> testing.scheduler: "trigger batch" {
  style.stroke-dash: 3
}
testing.scheduler -> testing.ks_test: "invoke detector"
baseline.training_dist -> testing.ks_test: "reference data"
testing.ks_test -> testing.comparison: "calculate distance"

# Baseline Setup
baseline.load_baseline -> baseline.training_dist: "init load"

# Notification Flow
testing.comparison -> alerts.alert_mgr: "report drift"
alerts.alert_mgr -> alerts.evaluate: "check alpha"
alerts.evaluate -> alerts.cooldown: "check suppression"
alerts.cooldown -> output.notify: "DISPATCH ALERT" {
  style: {
    stroke: "#C62828"
    stroke-width: 4
  }
}
alerts.evaluate -> logging.log_entry: "persist event"

# Channel Routing
output.notify -> output.channels.pd: "Critical"
output.notify -> output.channels.slack: "Info"

# --- LEGEND ---
legend: {
  label: "Architecture Legend"
  shape: rectangle
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 2
    fill: "#FAFAFA"
  }
  
  f1: "━━━ Primary Data Path" {shape: text}
  f2: "┈⤖ Async/Periodic Flow" {shape: text}
  f3: "◇ Decision Logic" {shape: text}
}
legend.near: bottom-right