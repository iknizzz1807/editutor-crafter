layout-engine: elk
title: {
    label: "ML Model Serving: Complete Architecture"
    near: top-center
    shape: text
    style.font-size: 28
}
subgraph m1_model_loading {
    label: "M1: Model Loading"
    shape: rectangle
    style.fill: "#E8F5E5"
    memory_check: {
        label: "Memory Budget\nValidation"
        shape: rectangle
    }
    load_model: {
        label: "Load Model\nWeights"
        shape: rectangle
    }
    warmup: {
        label: "Warmup\nInference"
        shape: rectangle
    }
    health_check: {
        label: "Health\nCheck"
        shape: diamond
    }
    ready_state: {
        label: "Ready"
        shape: circle
        style.fill: "#90EE90"
    }
    memory_check -> load_model -> warmup -> health_check -> ready_state
}
subgraph m2_batching {
    label: "M2: Request Batching"
    shape: rectangle
    style.fill: "#B8E0F2"
    request_queue: {
        label: "Request\nQueue"
        shape: cylinder
    }
    batcher: {
        label: "Dynamic\nBatcher"
        shape: rectangle
    }
    pad_stack: {
        label: "pad_and_stack\nVariable Inputs"
        shape: rectangle
    }
    attention_mask: {
        label: "Attention\nMask Generator"
        shape: rectangle
    }
    gpu_inference: {
        label: "GPU Batch\nInference"
        shape: rectangle
    }
    request_queue -> batcher -> pad_stack -> attention_mask -> gpu_inference
}
subgraph m3_versioning {
    label: "M3: Model Versioning & Hot Swap"
    shape: rectangle
    style.fill: "#F8E0F2"
    version_registry: {
        label: "Version\nRegistry"
        shape: cylinder
    }
    schema_validator: {
        label: "Schema\nCompatibility"
        shape: diamond
    }
    hot_swap: {
        label: "Atomic\nHot Swap"
        shape: rectangle
    }
    drain_queue: {
        label: "Drain\nPending"
        shape: rectangle
    }
    unload_old: {
        label: "Unload\nOld Version"
        shape: rectangle
    }
    rollback_monitor: {
        label: "Rollback\nMonitor"
        shape: diamond
    }
    version_registry -> schema_validator -> hot_swap -> drain_queue -> unload_old -> rollback_monitor
}
subgraph m4_ab_testing {
    label: "M4: A/B Testing & Canary"
    shape: rectangle
    style.fill: "#A7C1AF"
    router: {
        label: "Request\nRouter"
        shape: diamond
    }
    version_a: {
        label: "Version A\n(Stable)"
        shape: rectangle
    }
    version_b: {
        label: "Version B\n(Canary)"
        shape: rectangle
    }
    traffic_weights: {
        label: "Traffic\nWeights"
        shape: rectangle
    }
    stats_analyzer: {
        label: "Statistical\nAnalyzer"
        shape: rectangle
    }
    staged_rollout: {
        label: "Staged\nRollout"
        shape: rectangle
    }
    router -> version_a: "90%"
    router -> version_b: "10%"
    version_a -> stats_analyzer
    version_b -> stats_analyzer
    stats_analyzer -> traffic_weights
    traffic_weights -> staged_rollout
}
subgraph m5_monitoring {
    label: "M5: Monitoring & Drift Detection"
    shape: rectangle
    style.fill: "#ACE1AF"
    latency_histogram: {
        label: "Latency\nHistogram"
        shape: rectangle
    }
    prediction_monitor: {
        label: "Prediction\nDistribution"
        shape: rectangle
    }
    baseline_manager: {
        label: "Baseline\nManager"
        shape: cylinder
    }
    ks_test: {
        label: "KS Test\nDetector"
        shape: rectangle
    }
    alert_manager: {
        label: "Alert\nManager"
        shape: rectangle
    }
    prometheus: {
        label: "Prometheus\nExport"
        shape: cylinder
    }
    structured_logs: {
        label: "Structured\nLogs"
        shape: cylinder
    }
    latency_histogram -> prometheus
    prediction_monitor -> ks_test
    baseline_manager -> ks_test
    ks_test -> alert_manager
    alert_manager -> structured_logs
}
m1_model_loading.ready_state -> m2_batching.request_queue: "model ready"
m2_batching.gpu_inference -> m5_monitoring.latency_histogram: "record latency"
m2_batching.gpu_inference -> m5_monitoring.prediction_monitor: "record prediction"
m3_versioning.rollback_monitor -> m4_ab_testing.staged_rollout: "rollback trigger"
m4_ab_testing.stats_analyzer -> m3_versioning.version_registry: "promote version"
m5_monitoring.alert_manager -> m3_versioning.hot_swap: "drift alert"
m5_monitoring.alert_manager -> m4_ab_testing.traffic_weights: "adjust traffic"
external_requests: {
    label: "Incoming\nRequests"
    shape: circle
    style.fill: "#FFE4B5"
}
external_requests -> m2_batching.request_queue
m2_batching.gpu_inference -> response: {
    label: "Response"
    shape: circle
    style.fill: "#98FB98"
}