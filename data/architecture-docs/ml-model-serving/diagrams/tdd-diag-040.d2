direction: right
title: ML Model Inference Service Architecture
# Main Service Container
InferenceService: {
  shape: rectangle
  style.fill: "#E3F2FD"
  # HTTP Layer
  HTTPLayer: {
    shape: rectangle
    style.fill: "#BBDEFB"
    label: "HTTP API Layer"
    FastAPI: {
      shape: hexagon
      label: "FastAPI\nServer"
    }
    PredictEndpoint: {
      shape: diamond
      label: "/predict\nEndpoint"
    }
    HealthProbes: {
      shape: rectangle
      label: "Health Probes\n• /health\n• /ready"
    }
  }
  # Request Processing
  RequestProcessing: {
    shape: rectangle
    style.fill: "#C8E6C9"
    label: "Request Processing"
    RequestQueue: {
      shape: queue
      label: "asyncio.Queue\nRequest Buffer"
    }
    InputValidator: {
      shape: diamond
      label: "Input\nValidator"
    }
    SchemaRegistry: {
      shape: cylinder
      label: "Schema\nRegistry"
    }
  }
  # Dynamic Batching
  DynamicBatching: {
    shape: rectangle
    style.fill: "#FFF9C4"
    label: "Dynamic Batching"
    Batcher: {
      shape: hexagon
      label: "DynamicBatcher\nBackground Task"
    }
    BatchConfig: {
      shape: rectangle
      label: "Config\n• batch_size: 32\n• timeout_ms: 50\n• max_latency: 100ms"
    }
    Padding: {
      shape: rectangle
      label: "Padding &\nAttention Masks\nVariable Length"
    }
    FutureResolver: {
      shape: diamond
      label: "Future\nResolver"
    }
  }
  # Model Management
  ModelManager: {
    shape: rectangle
    style.fill: "#F8BBD9"
    label: "Model Management"
    VersionRegistry: {
      shape: cylinder
      label: "Version Registry\n• v1 (stable)\n• v2 (canary)"
    }
    ModelCache: {
      shape: cylinder
      label: "Model Cache\nMemory Pool"
    }
    HotSwapper: {
      shape: hexagon
      label: "Hot Swapper\nGraceful Reload"
    }
    Warmup: {
      shape: rectangle
      label: "Warmup\nSingle Step"
    }
  }
  # A/B Testing & Routing
  ABTesting: {
    shape: rectangle
    style.fill: "#D1C4E9"
    label: "A/B Testing"
    TrafficRouter: {
      shape: hexagon
      label: "Traffic Router\nHash-based"
    }
    RolloutController: {
      shape: rectangle
      label: "Rollout Controller\n5%→10%→25%→50%→100%"
    }
    CanaryConfig: {
      shape: rectangle
      label: "Canary Config\n• threshold\n• health checks"
    }
    UserTargeting: {
      shape: rectangle
      label: "User Targeting\nX-experiment-id"
    }
  }
}
# Monitoring Stack
Monitoring: {
  shape: rectangle
  style.fill: "#FFCCBC"
  label: "Monitoring Stack"
  # Drift Detection
  DriftDetection: {
    shape: rectangle
    style.fill: "#FFAB91"
    label: "Drift Detection"
    Sampler: {
      shape: diamond
      label: "Reservoir\nSampler\n1/N rate"
    }
    KSTest: {
      shape: hexagon
      label: "KS Test\np < 0.01"
    }
    Baseline: {
      shape: cylinder
      label: "Baseline\nDistribution"
    }
    DriftResults: {
      shape: rectangle
      label: "Drift Results\n• feature_name\n• ks_statistic\n• p_value"
    }
  }
  # Metrics
  Metrics: {
    shape: rectangle
    style.fill: "#FF8A65"
    label: "Metrics Collection"
    Prometheus: {
      shape: hexagon
      label: "Prometheus\nExport"
    }
    LatencyMetrics: {
      shape: rectangle
      label: "Latency\n• p50, p95, p99\n• error rate"
    }
    ThroughputMetrics: {
      shape: rectangle
      label: "Throughput\n• RPS\n• batch efficiency"
    }
  }
  # Alerting
  Alerting: {
    shape: rectangle
    style.fill: "#FF7043"
    label: "Alerting"
    AlertRules: {
      shape: rectangle
      label: "Alert Rules\n• p_value < 0.001\n• ks_statistic > 0.1\n• error_rate > 5%"
    }
    AlertQueue: {
      shape: queue
      label: "Alert Queue\nCooldown Period"
    }
    SeverityRouter: {
      shape: diamond
      label: "Severity\nRouter\nINFO/WARN/CRIT"
    }
  }
  Logging: {
    shape: cylinder
    label: "Structured Logging\nJSON Lines"
  }
}
# Rollback Controller
RollbackController: {
  shape: rectangle
  style.fill: "#EF9A9A"
  label: "Rollback Controller"
  HealthChecker: {
    shape: diamond
    label: "Health\nChecker"
  }
  ThresholdMonitor: {
    shape: rectangle
    label: "Threshold Monitor\nLive vs Baseline"
  }
  RollbackExecutor: {
    shape: hexagon
    label: "Rollback\nExecutor"
  }
}
# Connections
HTTPLayer.FastAPI -> RequestProcessing.RequestQueue: "enqueue request"
RequestProcessing.RequestQueue -> DynamicBatching.Batcher: "pull batch"
RequestProcessing.InputValidator -> RequestProcessing.SchemaRegistry: "validate"
DynamicBatching.Batcher -> DynamicBatching.Padding: "pad sequences"
DynamicBatching.Padding -> ModelManager.VersionRegistry: "route to model"
DynamicBatching.FutureResolver -> HTTPLayer.FastAPI: "resolve future"
ModelManager.HotSwapper -> ModelManager.Warmup: "warmup step"
ModelManager.VersionRegistry -> ABTesting.TrafficRouter: "version selection"
ABTesting.TrafficRouter -> ABTesting.UserTargeting: "deterministic hash"
ABTesting.RolloutController -> ABTesting.TrafficRouter: "traffic weights"
ABTesting.CanaryConfig -> RollbackController.HealthChecker: "threshold config"
Monitoring.DriftDetection.Sampler -> Monitoring.DriftDetection.KSTest: "sample"
Monitoring.DriftDetection.KSTest -> Monitoring.DriftDetection.Baseline: "compare"
Monitoring.DriftDetection.KSTest -> Monitoring.DriftDetection.DriftResults: "results"
Monitoring.DriftDetection.DriftResults -> Monitoring.Alerting.AlertRules: "evaluate"
Monitoring.Metrics.Prometheus -> Monitoring.Metrics.LatencyMetrics: "scrape"
Monitoring.Metrics.Prometheus -> Monitoring.Metrics.ThroughputMetrics: "scrape"
Monitoring.Alerting.AlertRules -> Monitoring.Alerting.AlertQueue: "fire"
Monitoring.Alerting.AlertQueue -> Monitoring.Alerting.SeverityRouter: "route"
RollbackController.HealthChecker -> RollbackController.ThresholdMonitor: "check"
RollbackController.ThresholdMonitor -> RollbackController.RollbackExecutor: "exceeded"
RollbackController.RollbackExecutor -> ABTesting.RolloutController: "rollback"

direction: right
title: Dynamic Batching Flow Detail
# Request Sources
Clients: {
  shape: rectangle
  style.fill: "#E8F5E9"
  label: "Client Requests\n(R1, R2, R3, ...)"
}
# Queue Stage
QueueStage: {
  shape: rectangle
  style.fill: "#C8E6C9"
  AsyncQueue: {
    shape: queue
    label: "asyncio.Queue\nFIFO Buffer"
  }
  FuturePool: {
    shape: cylinder
    label: "Future Pool\n{R1: Future1\n R2: Future2\n R3: Future3}"
  }
}
# Batch Formation
BatchFormation: {
  shape: rectangle
  style.fill: "#FFF9C4"
  BatchWindow: {
    shape: rectangle
    label: "Batching Window\nmax_batch=32\ntimeout=50ms"
  }
  SequencePad: {
    shape: rectangle
    label: "Sequence Padding\n[1,2,3] → [1,2,3,0,0]\nAttention: [1,1,1,0,0]"
  }
  BatchTensor: {
    shape: rectangle
    style.fill: "#FFEB3B"
    label: "Batched Tensor\nshape: [B, max_seq_len]"
  }
}
# Model Inference
ModelInference: {
  shape: rectangle
  style.fill: "#F8BBD9"
  Model: {
    shape: hexagon
    label: "Model\nForward Pass"
  }
  OutputBuffer: {
    shape: rectangle
    label: "Output Buffer\n[B, output_dim]"
  }
}
# Unbatch & Resolve
Resolution: {
  shape: rectangle
  style.fill: "#D1C4E9"
  Unbatcher: {
    shape: diamond
    label: "Unbatch\nSplit Results"
  }
  FutureResolver: {
    shape: rectangle
    label: "Future.set_result()\nR1 → result1\nR2 → result2\nR3 → result3"
  }
}
# Response
Responses: {
  shape: rectangle
  style.fill: "#B2DFDB"
  label: "HTTP Responses\nto respective clients"
}
# Flow
Clients -> QueueStage.AsyncQueue: "POST /predict"
QueueStage.AsyncQueue -> QueueStage.FuturePool: "create Future"
QueueStage.FuturePool -> BatchFormation.BatchWindow: "collect"
BatchFormation.BatchWindow -> BatchFormation.SequencePad: "pad"
BatchFormation.SequencePad -> BatchFormation.BatchTensor: "stack"
BatchFormation.BatchTensor -> ModelInference.Model: "infer"
ModelInference.Model -> ModelInference.OutputBuffer: "output"
ModelInference.OutputBuffer -> Resolution.Unbatcher: "split"
Resolution.Unbatcher -> Resolution.FutureResolver: "resolve"
Resolution.FutureResolver -> Responses: "await Future"

direction: down
title: Canary Rollout State Machine
# States
Idle: {
  shape: circle
  style.fill: "#E8F5E9"
  label: "Idle"
}
Initializing: {
  shape: circle
  style.fill: "#FFF9C4"
  label: "Initializing\nLoad Model v2"
}
Warmup: {
  shape: circle
  style.fill: "#FFE0B2"
  label: "Warmup\nSingle Step"
}
Stage5: {
  shape: circle
  style.fill: "#C8E6C9"
  label: "Stage 1\n5% Traffic"
}
Stage10: {
  shape: circle
  style.fill: "#C8E6C9"
  label: "Stage 2\n10% Traffic"
}
Stage25: {
  shape: circle
  style.fill: "#C8E6C9"
  label: "Stage 3\n25% Traffic"
}
Stage50: {
  shape: circle
  style.fill: "#C8E6C9"
  label: "Stage 4\n50% Traffic"
}
Complete: {
  shape: circle
  style.fill: "#A5D6A7"
  label: "Complete\n100% v2"
}
Rollback: {
  shape: circle
  style.fill: "#EF9A9A"
  label: "Rollback\nRevert to v1"
}
# Decision Nodes
HealthCheck1: {
  shape: diamond
  style.fill: "#BBDEFB"
  label: "Health\nCheck"
}
HealthCheck2: {
  shape: diamond
  style.fill: "#BBDEFB"
  label: "Health\nCheck"
}
HealthCheck3: {
  shape: diamond
  style.fill: "#BBDEFB"
  label: "Health\nCheck"
}
HealthCheck4: {
  shape: diamond
  style.fill: "#BBDEFB"
  label: "Health\nCheck"
}
DriftCheck: {
  shape: diamond
  style.fill: "#FFCC80"
  label: "Drift\nDetection\np < 0.01?"
}
# Transitions
Idle -> Initializing: "deploy triggered"
Initializing -> Warmup: "model loaded"
Warmup -> Stage5: "warmup OK"
Warmup -> Rollback: "warmup fail"
Stage5 -> HealthCheck1: "observe"
HealthCheck1 -> Stage10: "OK\np99 < threshold"
HealthCheck1 -> DriftCheck: "metrics"
DriftCheck -> Stage10: "no drift"
DriftCheck -> Rollback: "drift detected"
Stage10 -> HealthCheck2: "observe"
HealthCheck2 -> Stage25: "OK"
HealthCheck2 -> Rollback: "error > 5%"
Stage25 -> HealthCheck3: "observe"
HealthCheck3 -> Stage50: "OK"
HealthCheck3 -> Rollback: "error > 5%"
Stage50 -> HealthCheck4: "observe"
HealthCheck4 -> Complete: "OK"
HealthCheck4 -> Rollback: "error > 5%"
Rollback -> Idle: "reset"

direction: right
title: Drift Detection Pipeline
# Input Source
RequestStream: {
  shape: rectangle
  style.fill: "#E3F2FD"
  label: "Request Stream\nProduction Traffic"
}
# Sampling
SamplingStage: {
  shape: rectangle
  style.fill: "#BBDEFB"
  label: "Sampling"
  ReservoirSampler: {
    shape: diamond
    label: "Reservoir\nSampler\nrate=1/100"
  }
  SampleBuffer: {
    shape: cylinder
    label: "Sample Buffer\nN=1000 samples"
  }
}
# Feature Extraction
FeatureExtraction: {
  shape: rectangle
  style.fill: "#C8E6C9"
  FeatureExtractor: {
    shape: hexagon
    label: "Feature\nExtractor"
  }
  Features: {
    shape: rectangle
    label: "Features\n• input_length\n• token_entropy\n• confidence"
  }
}
# Statistical Testing
StatisticalTest: {
  shape: rectangle
  style.fill: "#FFF9C4"
  BaselineDist: {
    shape: cylinder
    label: "Baseline\nDistribution\n(Training Data)"
  }
  KSTest: {
    shape: hexagon
    label: "Kolmogorov-\nSmirnov Test"
  }
  TestResults: {
    shape: rectangle
    label: "Test Results\n• ks_statistic\n• p_value\n• is_significant"
  }
}
# Decision
Decision: {
  shape: rectangle
  style.fill: "#FFCCBC"
  ThresholdCheck: {
    shape: diamond
    label: "p < 0.01?"
  }
  SignificanceLevel: {
    shape: rectangle
    label: "Significance\n• p < 0.001: CRITICAL\n• p < 0.01: WARNING\n• ks > 0.1: MODERATE"
  }
}
# Actions
Actions: {
  shape: rectangle
  style.fill: "#EF9A9A"
  AlertFire: {
    shape: hexagon
    label: "Fire Alert\n{severity, message}"
  }
  LogDrift: {
    shape: cylinder
    label: "Drift Log\nJSON Lines"
  }
  TriggerRollback: {
    shape: rectangle
    label: "Trigger\nRollback"
  }
}
# Flow
RequestStream -> SamplingStage.ReservoirSampler: "incoming"
SamplingStage.ReservoirSampler -> SamplingStage.SampleBuffer: "sample"
SamplingStage.SampleBuffer -> FeatureExtraction.FeatureExtractor: "extract"
FeatureExtraction.FeatureExtractor -> FeatureExtraction.Features: "compute"
FeatureExtraction.Features -> StatisticalTest.KSTest: "test"
StatisticalTest.BaselineDist -> StatisticalTest.KSTest: "reference"
StatisticalTest.KSTest -> StatisticalTest.TestResults: "result"
StatisticalTest.TestResults -> Decision.ThresholdCheck: "evaluate"
Decision.ThresholdCheck -> Decision.SignificanceLevel: "check"
Decision.ThresholdCheck -> Actions.AlertFire: "significant"
Actions.AlertFire -> Actions.LogDrift: "log"
Actions.AlertFire -> Actions.TriggerRollback: "critical"

direction: down
title: Alert Rule Evaluation Flow
# Input
DriftResults: {
  shape: rectangle
  style.fill: "#E3F2FD"
  label: "Drift Results\n[\n  {feature, ks_stat, p_value},\n  ...\n]"
}
# Alert Rule Engine
AlertEngine: {
  shape: rectangle
  style.fill: "#BBDEFB"
  label: "Alert Rule Engine"
  RuleSet: {
    shape: rectangle
    label: "Active Rules\n─────────────\n• p_value < 0.001 → CRITICAL\n• ks_statistic > 0.1 → WARNING\n• error_rate > 5% → WARNING\n• latency_p99 > 500ms → INFO"
  }
  Evaluator: {
    shape: hexagon
    label: "Rule\nEvaluator"
  }
  CooldownManager: {
    shape: rectangle
    label: "Cooldown Manager\n─────────────────\n• CRITICAL: 5min\n• WARNING: 15min\n• INFO: 60min"
  }
}
# Alert State
AlertState: {
  shape: rectangle
  style.fill: "#C8E6C9"
  RecentAlerts: {
    shape: cylinder
    label: "Recent Alerts\n[timestamp, rule_id, severity]"
  }
  NewAlerts: {
    shape: queue
    label: "New Alerts\nQueue"
  }
}
# Alert Router
AlertRouter: {
  shape: rectangle
  style.fill: "#FFF9C4"
  SeverityRouter: {
    shape: diamond
    label: "Route by\nSeverity"
  }
  Channels: {
    shape: rectangle
    label: "Channels\n─────────────\nCRITICAL → PagerDuty\nWARNING  → Slack\nINFO     → Dashboard"
  }
}
# Flow
DriftResults -> AlertEngine.Evaluator: "evaluate"
AlertEngine.RuleSet -> AlertEngine.Evaluator: "rules"
AlertEngine.CooldownManager -> AlertEngine.Evaluator: "check cooldown"
AlertEngine.RecentAlerts -> AlertEngine.CooldownManager: "history"
AlertEngine.Evaluator -> AlertState.NewAlerts: "fired alerts"
AlertState.NewAlerts -> AlertRouter.SeverityRouter: "route"
AlertRouter.SeverityRouter -> AlertRouter.Channels: "dispatch"

direction: right
title: Model Hot Swap Sequence
# Timeline
t0: {
  shape: circle
  style.fill: "#E8F5E9"
  label: "t0"
}
t1: {
  shape: circle
  style.fill: "#FFF9C4"
  label: "t1"
}
t2: {
  shape: circle
  style.fill: "#FFE0B2"
  label: "t2"
}
t3: {
  shape: circle
  style.fill: "#C8E6C9"
  label: "t3"
}
t4: {
  shape: circle
  style.fill: "#A5D6A7"
  label: "t4"
}
# States
State0: {
  shape: rectangle
  label: "State: v1 Active\n──────────────\n• Model v1 loaded\n• 100% traffic\n• No v2 in memory"
}
State1: {
  shape: rectangle
  label: "State: Loading v2\n──────────────\n• Model v1 serving\n• Model v2 loading\n• Memory: v1 + v2"
}
State2: {
  shape: rectangle
  label: "State: Warmup\n──────────────\n• v1 still serving\n• v2 warmup step\n• Validate outputs"
}
State3: {
  shape: rectangle
  label: "State: Canary\n──────────────\n• v1: 95% traffic\n• v2: 5% traffic\n• Monitor metrics"
}
State4: {
  shape: rectangle
  label: "State: Complete\n──────────────\n• v2: 100% traffic\n• v1 unloaded\n• Memory: v2 only"
}
# Connections with labels
t0 -> State0
t1 -> State1
t2 -> State2
t3 -> State3
t4 -> State4
t0 -> t1: "deploy command"
t1 -> t2: "load complete"
t2 -> t3: "warmup OK"
t3 -> t4: "rollout success"

direction: right
title: Request Routing & User Consistency
# Client Layer
Clients: {
  shape: rectangle
  style.fill: "#E3F2FD"
  User1: {shape: circle, label: "User A"}
  User2: {shape: circle, label: "User B"}
  User3: {shape: circle, label: "User C"}
  User4: {shape: circle, label: "User D"}
}
# Routing Layer
Router: {
  shape: rectangle
  style.fill: "#C8E6C9"
  HashFunction: {
    shape: hexagon
    label: "Hash(user_id)\n% 100"
  }
  RoutingTable: {
    shape: rectangle
    label: "Routing Table\n─────────────\n0-4   → v2 (5%)\n5-99  → v1 (95%)"
  }
  VersionSelector: {
    shape: diamond
    label: "Version\nSelector"
  }
}
# Model Versions
Models: {
  shape: rectangle
  style.fill: "#F8BBD9"
  ModelV1: {
    shape: hexagon
    label: "Model v1\n(Stable)"
  }
  ModelV2: {
    shape: hexagon
    label: "Model v2\n(Canary)"
  }
}
# Consistency Example
Consistency: {
  shape: rectangle
  style.fill: "#FFF9C4"
  label: "Consistency Guarantee\n─────────────────────\nUser A: hash=3   → v2 ✓\nUser B: hash=42  → v1 ✓\nUser C: hash=7   → v1 ✓\nUser D: hash=1   → v2 ✓\n─────────────────────\nSame user → Same version\n(every request)"
}
# Flow
Clients.User1 -> Router.HashFunction: "user_id"
Clients.User2 -> Router.HashFunction: "user_id"
Router.HashFunction -> Router.RoutingTable: "hash value"
Router.RoutingTable -> Router.VersionSelector: "range check"
Router.VersionSelector -> Models.ModelV1: "95%"
Router.VersionSelector -> Models.ModelV2: "5%"
Router.VersionSelector -> Consistency: "deterministic"

direction: right
title: Memory Layout - Model Cache
# Memory Block
MemoryBlock: {
  shape: rectangle
  style.fill: "#ECEFF1"
  width: 600
  # Header Section
  Header: {
    shape: rectangle
    style.fill: "#E1BEE7"
    width: 600
    label: "Header (16B)\n┌─────────────────────────────────────┐\n│ magic: 0xMLIN (4B)                  │\n│ version: uint32 (4B)                │\n│ flags: uint32 (4B)                  │\n│ checksum: uint32 (4B)               │\n└─────────────────────────────────────┘"
  }
  # Metadata Section
  Metadata: {
    shape: rectangle
    style.fill: "#BBDEFB"
    width: 600
    label: "Model Metadata (32B)\n┌─────────────────────────────────────┐\n│ model_id: uuid (16B)                │\n│ input_dim: uint32 (4B)              │\n│ hidden_dim: uint32 (4B)             │\n│ output_dim: uint32 (4B)             │\n│ num_layers: uint32 (4B)             │\n└─────────────────────────────────────┘"
  }
  # Weights Pointer
  WeightsPtr: {
    shape: rectangle
    style.fill: "#C8E6C9"
    width: 600
    label: "Weights Block (variable)\n┌─────────────────────────────────────┐\n│ ptr: *float32 (8B)                  │\n│ size: size_t (8B)                   │\n│ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─│\n│ [Embedding: vocab×dim]               │\n│ [Attention: layers×4×dim²]          │\n│ [FFN: layers×2×dim×ffn]             │\n└─────────────────────────────────────┘"
  }
  # Cache Line Marker
  CacheLine: {
    shape: rectangle
    style.stroke-dash: 3
    style.fill: "transparent"
    width: 600
    label: "║ 64B cache line boundary ║"
  }
  # Sequence Container
  SeqContainer: {
    shape: rectangle
    style.fill: "#FFE0B2"
    width: 600
    label: "Variable-Length Sequence Pool\n┌─────────────────────────────────────┐\n│ capacity: size_t (8B)               │\n│ head_ptr: *SeqEntry (8B)            │\n│ free_list: *SeqEntry (8B)           │\n│ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─│\n│ SeqEntry {                          │\n│   data: *token (ptr)                │\n│   len: uint32, cap: uint32          │\n│   next: *SeqEntry                   │\n│ }                                   │\n└─────────────────────────────────────┘"
  }
  # Free Space
  FreeSpace: {
    shape: rectangle
    style.fill: "#A5D6A7"
    width: 600
    label: "Free Space (aligned to page boundary)\n┌─────────────────────────────────────┐\n│                                     │\n│         Available Memory            │\n│                                     │\n└─────────────────────────────────────┘"
  }
}
# Legend
Legend: {
  shape: rectangle
  label: "Legend\n─────────────\n🟣 Header fields\n🔵 Data fields\n🟢 Free space\n🟠 Variable containers\n⬛ Page boundary (4KB)"
}

