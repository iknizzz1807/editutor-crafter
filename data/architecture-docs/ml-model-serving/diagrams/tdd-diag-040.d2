direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
  }
}

title: |md
  # Training Baseline Storage Structure
  *Implementation Spec v1.2.3 - ML Infrastructure*
| {
  near: top-center
  shape: text
}

# --- CLASSES / DATA STRUCTURES ---

ModelBaseline: {
  shape: class
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    fill: "#F3E5F5"
  }
  
  # Header/Purple
  label: "ModelBaseline (Size: Variable)"
  
  # Fields (Blue)
  model_version: "str (e.g., 'v1.2.3')"
  capture_time: "ISO-8601 Datetime"
  feature_baselines: "Dict[str, FeatureBaseline]"
  prediction_baseline: "Optional[DistributionStats]"
  metadata: "Dict[str, Any]"
}

FeatureBaseline: {
  shape: class
  style: {
    stroke: "#1976D2"
    stroke-width: 2
    fill: "#E3F2FD"
  }
  
  label: "FeatureBaseline (Size: ~12KB)"
  
  feature_name: "str"
  samples: "float[1000] (Reservoir)"
  min_val: "float64"
  max_val: "float64"
  mean: "float64"
  std: "float64"
  sorted_samples: "float64[1000] (for KS-test)"
}

# --- SAMPLING LOGIC ---

ReservoirSampling: {
  label: |md
    ### Reservoir Sampling Strategy
    **Algorithm:** K-fixed Reservoir
    **Capacity (K):** 1000 samples
    ***
    - Maintains statistical representativeness
    - $P(include) = K/N$
    - O(1) space complexity per feature
  |
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    border-radius: 8
  }
}

# --- STORAGE REPRESENTATION ---

JSON_Storage: {
  label: "baseline_v{version}.json"
  shape: code
  language: json
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
  # Fixing the multiline block string error
  value: |json
    {
      "model_version": "v1.2.3",
      "capture_time": "2024-01-15T10:30:00Z",
      "feature_baselines": {
        "age": {
          "samples": [25.0, 32.0, 45.0],
          "min_val": 18.0,
          "mean": 42.5
        }
      },
      "metadata": {
        "sample_size": 10000
      }
    }
  |
}

StorageDirectory: {
  label: "BaselineManager.storage_dir"
  icon: folder
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
  }
  # Fixing the multiline block string and map termination
  files: |md
    /app/baselines/
    ├── baseline_v1.0.0.json
    ├── baseline_v1.1.0.json
    └── baseline_v1.2.3.json
  |
}

# --- RELATIONSHIPS / SEQUENCES ---

ModelBaseline.feature_baselines -> FeatureBaseline: "1:N Relationship" {
  style: {
    stroke: "#1976D2"
    stroke-dash: 3
    source-arrowhead: 1
    target-arrowhead: "*"
  }
}

ReservoirSampling -> FeatureBaseline.samples: "populates reservoir" {
  style: {
    stroke: "#2E7D32"
    animated: true
  }
}

ModelBaseline -> JSON_Storage: "JSON.stringify()" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    stroke-dash: 5
  }
}

JSON_Storage -> StorageDirectory: "Local FS Write" {
  style: {
    stroke: "#455A64"
    target-arrowhead: triangle
  }
}

# --- ANNOTATIONS ---

note: |md
  **Implementation Notes:**
  - `sorted_samples` is computed at serialization time for optimization.
  - Storage directory must be persistent across container restarts.
| {
  near: StorageDirectory
  shape: text
  style: {
    font-size: 10
    italic: true
  }
}