  Grafana: {
    shape: rectangle
    label: "Grafana\nDashboards"
  }
  AlertManager: {
    shape: rectangle
    label: "AlertManager\nRouting"
  }
}
# Flow
App.Handler -> Processing.Batcher: "batch request"
Processing.Batcher -> Processing.DriftSampler: "sample"
Processing.DriftSampler -> Storage.PredictionLog: "log"
Processing.Batcher -> Storage.MetricsStore: "record"
Storage.PredictionLog -> Export.LogExporter: "export"
Storage.MetricsStore -> Export.PrometheusExporter: "expose"
Export.PrometheusExporter -> External.PrometheusServer: "scrape"
External.PrometheusServer -> External.Grafana: "query"
External.PrometheusServer -> External.AlertManager: "alert"
App.Lifespan -> Processing.Batcher: "start/stop"