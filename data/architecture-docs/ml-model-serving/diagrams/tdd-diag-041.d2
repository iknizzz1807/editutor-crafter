vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: "Alert Threshold Tuning: Sensitivity vs Noise Trade-offs"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# ============================================================================
# INPUT LAYER: Metric Sources
# ============================================================================
metrics_layer: {
  label: "Metric Collection Layer"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  prometheus_metrics: {
    label: "Prometheus Metrics\n• model_prediction_distribution\n• feature_drift_score\n• p_value_kolmogorov_smirnov\n• alert_threshold_config"
    shape: stored_data
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  live_inference_samples: {
    label: "Live Inference Samples\nWindow: T-1h to T"
    shape: queue
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
  baseline_distribution: {
    label: "Baseline Distribution\n(Training Data Reference)"
    shape: cylinder
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
}

# ============================================================================
# STATISTICAL ANALYSIS LAYER
# ============================================================================
analysis_layer: {
  label: "Statistical Analysis Layer"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
  ks_test_calculator: {
    label: "KS-Test Calculator\n\nComputes:\n• D-statistic (max distance)\n• p-value (significance)\n• Critical values lookup"
    shape: hexagon
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  p_value_result: {
    label: "P-Value Result\n\nExample: p = 0.003"
    shape: circle
    style: {
      fill: "#90CAF9"
      stroke: "#1976D2"
      stroke-width: 3
    }
  }
  threshold_evaluator: {
    label: "Threshold Evaluator\n\np < α_threshold ?"
    shape: diamond
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
}

# ============================================================================
# THRESHOLD CONFIGURATION PANEL
# ============================================================================
threshold_config: {
  label: "Threshold Configuration"
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
    stroke-dash: 5
  }
  alpha_001: {
    label: "RECOMMENDED\nα = 0.01\n(p < 0.01)\n\nBalanced detection"
    shape: square
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      font-color: white
      bold: true
      stroke-width: 3
    }
  }
  alpha_005: {
    label: "More Sensitive\nα = 0.05\n(p < 0.05)\n\n⚠ Higher false positives"
    shape: square
    style: {
      fill: "#FF9800"
      stroke: "#F57C00"
      font-color: white
    }
  }
  alpha_0010: {
    label: "Very Sensitive\nα = 0.10\n(p < 0.10)\n\n⚠ Noise prone"
    shape: square
    style: {
      fill: "#F44336"
      stroke: "#D32F2F"
      font-color: white
    }
  }
  alpha_0001: {
    label: "Conservative\nα = 0.001\n(p < 0.001)\n\nMay miss subtle drift"
    shape: square
    style: {
      fill: "#2196F3"
      stroke: "#1976D2"
      font-color: white
    }
  }
  alpha_001 -> alpha_005: {
    label: "↑ Sensitivity\n↑ False Positives"
    style: {
      stroke: "#FF9800"
      stroke-width: 2
      animated: true
    }
  }
  alpha_001 -> alpha_0001: {
    label: "↓ Sensitivity\n↓ False Positives"
    style: {
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
}

# ============================================================================
# SENSITIVITY VS NOISE CURVE VISUALIZATION
# ============================================================================
tradeoff_visualization: {
  label: "Sensitivity vs False Positive Trade-off Curve"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }
  curve_visual: {
    label: ""
    shape: rectangle
    width: 400
    height: 200
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
  }
  y_axis: {
    label: "Rate (%)"
    shape: text
    style: {
      font-size: 12
    }
  }
  x_axis: {
    label: "P-Value Threshold (α)"
    shape: text
    style: {
      font-size: 12
    }
  }
  true_positive_curve: {
    label: "── True Positive Rate (Sensitivity)"
    shape: text
    style: {
      font-color: "#4CAF50"
      bold: true
    }
  }
  false_positive_curve: {
    label: "-- False Positive Rate (Noise)"
    shape: text
    style: {
      font-color: "#F44336"
      bold: true
    }
  }
  optimal_zone: {
    label: "█ OPTIMAL ZONE\n   α = 0.01 - 0.05"
    shape: text
    style: {
      font-color: "#2E7D32"
      bold: true
      font-size: 14
    }
  }
  danger_zone: {
    label: "█ DANGER ZONE\n   α > 0.05\n   Alert Fatigue Risk"
    shape: text
    style: {
      font-color: "#D32F2F"
      bold: true
      font-size: 14
    }
  }
}

# ============================================================================
# ALERT FATIGUE MODEL
# ============================================================================
alert_fatigue_model: {
  label: "Alert Fatigue Model"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
  }
  fatigue_curve: {
    label: "Engineer Responsiveness\nvs Alert Frequency\n\nLow alerts → High attention\nHigh alerts → Low attention\n(Desensitization)"
    shape: parallelogram
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
  }
  weekly_alert_count: {
    label: "Weekly Alert Volume"
    shape: class
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
    }
    field_low: "1-5 alerts/week: ✓ Sustainable"
    field_medium: "5-15 alerts/week: ⚠ Borderline"
    field_high: "15+ alerts/week: ✗ Fatigue threshold"
  }
  fatigue_impact: {
    label: "Fatigue Impact\n\n• Ignored alerts\n• Delayed response\n• Missed real incidents\n• Team burnout"
    shape: document
    style: {
      fill: "#EF9A9A"
      stroke: "#B71C1C"
    }
  }
  fatigue_curve -> weekly_alert_count -> fatigue_impact: {
    style: {
      stroke: "#C62828"
      stroke-width: 2
    }
  }
}

# ============================================================================
# DECISION ENGINE
# ============================================================================
decision_engine: {
  label: "Alert Decision Engine"
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    stroke-width: 2
  }
  alert_rule_evaluator: {
    label: "Alert Rule Evaluator\n\nexpr: p_value < threshold\nAND\nalert_cooldown_expired\nAND\nseverity_tier_match"
    shape: code
    language: python
    style: {
      fill: "#C5CAE9"
      stroke: "#3F51B5"
    }
  }
  severity_classifier: {
    label: "Severity Classifier\n\n• P0: p < 0.001 (Critical)\n• P1: p < 0.01 (Warning)\n• P2: p < 0.05 (Info)"
    shape: step
    style: {
      fill: "#C5CAE9"
      stroke: "#3F51B5"
    }
  }
  rate_limiter: {
    label: "Rate Limiter\n\nMax alerts per hour: 3\nCooldown period: 30min\nDeduplication window: 5min"
    shape: queue
    style: {
      fill: "#C5CAE9"
      stroke: "#3F51B5"
    }
  }
  alert_rule_evaluator -> severity_classifier -> rate_limiter: {
    style: {
      stroke: "#3F51B5"
      stroke-width: 2
    }
  }
}

# ============================================================================
# OUTPUT LAYER: Notifications
# ============================================================================
output_layer: {
  label: "Notification Channels"
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    stroke-width: 2
  }
  pagerduty: {
    label: "PagerDuty\n(P0/P1 Only)"
    shape: square
    style: {
      fill: "#FFCC80"
      stroke: "#EF6C00"
    }
  }
  slack_channel: {
    label: "#ml-alerts\n(All Severities)"
    shape: square
    style: {
      fill: "#FFCC80"
      stroke: "#EF6C00"
    }
  }
  metrics_dashboard: {
    label: "Grafana Dashboard\n• Drift trends\n• Alert history\n• Threshold tuning"
    shape: rectangle
    style: {
      fill: "#FFCC80"
      stroke: "#EF6C00"
    }
  }
  audit_log: {
    label: "Audit Log\n• Timestamp\n• p-value\n• Threshold used\n• Decision outcome"
    shape: cylinder
    style: {
      fill: "#FFE0B2"
      stroke: "#EF6C00"
    }
  }
}

# ============================================================================
# FEEDBACK LOOP: Threshold Adjustment
# ============================================================================
feedback_loop: {
  label: "Feedback Loop"
  style: {
    stroke: "#6A1B9A"
    stroke-dash: 4
  }
  alert_analysis: {
    label: "Weekly Alert Review\n\n• False positive rate\n• Missed detections\n• Threshold adjustment\n• SLO compliance"
    shape: document
    style: {
      fill: "#E1BEE7"
      stroke: "#6A1B9A"
    }
  }
  threshold_tuner: {
    label: "Threshold Tuner\n\nAuto-tune based on:\n• Historical FP rate\n• Business impact\n• Team capacity"
    shape: rectangle
    style: {
      fill: "#E1BEE7"
      stroke: "#6A1B9A"
      border-radius: 4
    }
  }
  alert_analysis -> threshold_tuner: {
    label: "Adjust α"
    style: {
      stroke: "#6A1B9A"
      stroke-width: 2
      stroke-dash: 4
    }
  }
}

# ============================================================================
# MAIN DATA FLOW CONNECTIONS
# ============================================================================
metrics_layer.prometheus_metrics -> analysis_layer.ks_test_calculator: {
  label: "metric samples"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
metrics_layer.live_inference_samples -> analysis_layer.ks_test_calculator: {
  label: "window data"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
metrics_layer.baseline_distribution -> analysis_layer.ks_test_calculator: {
  label: "reference"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

analysis_layer.ks_test_calculator -> analysis_layer.p_value_result: {
  label: "compute"
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}
analysis_layer.p_value_result -> analysis_layer.threshold_evaluator: {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

threshold_config.alpha_001 -> analysis_layer.threshold_evaluator: {
  label: "α = 0.01"
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    bold: true
  }
}

analysis_layer.threshold_evaluator -> decision_engine.alert_rule_evaluator: {
  label: "trigger?"
  style: {
    stroke: "#3F51B5"
    stroke-width: 2
  }
}

decision_engine.rate_limiter -> output_layer.pagerduty: {
  label: "P0/P1"
  style: {
    stroke: "#FF8F00"
    stroke-width: 2
  }
}
decision_engine.rate_limiter -> output_layer.slack_channel: {
  label: "all"
  style: {
    stroke: "#FF8F00"
    stroke-width: 2
  }
}
decision_engine.rate_limiter -> output_layer.metrics_dashboard: {
  style: {
    stroke: "#FF8F00"
    stroke-width: 1
  }
}
decision_engine.rate_limiter -> output_layer.audit_log: {
  style: {
    stroke: "#FF8F00"
    stroke-width: 1
    stroke-dash: 3
  }
}

output_layer.audit_log -> feedback_loop.alert_analysis: {
  label: "weekly"
  style: {
    stroke: "#6A1B9A"
    stroke-width: 2
    stroke-dash: 4
  }
}
feedback_loop.threshold_tuner -> threshold_config.alpha_001: {
  label: "tune"
  style: {
    stroke: "#6A1B9A"
    stroke-width: 2
    stroke-dash: 4
  }
}

tradeoff_visualization.optimal_zone -> threshold_config.alpha_001: {
  label: "recommended"
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
    stroke-dash: 3
  }
}

output_layer.slack_channel -> alert_fatigue_model.fatigue_curve: {
  label: "volume"
  style: {
    stroke: "#C62828"
    stroke-width: 2
    stroke-dash: 4
  }
}

# ============================================================================
# RECOMMENDATIONS BOX
# ============================================================================
recommendations: {
  label: "Implementation Recommendations"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    double-border: true
  }
  rec_title: {
    label: "✓ Starting Points for Drift Detection"
    shape: text
    style: {
      font-size: 16
      bold: true
      underline: true
    }
  }
  rec_1: { label: "1. Default threshold: p < 0.01 (α = 0.01)" }
  rec_2: { label: "2. For critical models: p < 0.001 (more conservative)" }
  rec_3: { label: "3. For experimental: p < 0.05 (more sensitive)" }
  rec_4: { label: "4. Monitor weekly alert volume, target < 10/week" }
  rec_5: { label: "5. Implement cooldown: max 3 alerts/hour per metric" }
  rec_6: { label: "6. Review false positive rate weekly, adjust α" }
  rec_7: { label: "7. KS-test for continuous, Chi-square for categorical" }
  rec_8: { label: "8. Window size: 1000+ samples for valid statistics" }
}

# ============================================================================
# LEGEND
# ============================================================================
legend: {
  label: "Legend"
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
  data_flow: {
    label: "───▶ Data Flow"
    shape: text
  }
  config_flow: {
    label: "- - -▶ Configuration"
    shape: text
  }
  feedback_flow: {
    label: "·····▶ Feedback/Adjustment"
    shape: text
  }
  recommended: {
    label: "█ Recommended Path"
    shape: text
    style: { font-color: "#4CAF50" }
  }
  warning: {
    label: "█ Warning/High Risk"
    shape: text
    style: { font-color: "#F44336" }
  }
}