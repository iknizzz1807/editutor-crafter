layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
}

direction: right

title: {
  shape: text
  near: top-center
  label: |'md
# Production ML Model Serving Architecture
*Technical Implementation Specification (V2.4)*
  '|
  style: {
    font-size: 28
    bold: true
  }
}

# --- CLASSES & STYLING ---
# Implementing System Instruction #1: Header=Purple, Data=Blue, Free=Green, Padding=Gray
classes: {
  service: {
    shape: rectangle
    style: {
      fill: "#f8f9fa"
      stroke: "#212529"
      stroke-width: 2
    }
  }
  mem_header: {
    style: {
      fill: "#e1d5e7" # Purple
      stroke: "#9673a6"
      bold: true
    }
  }
  mem_data: {
    style: {
      fill: "#dae8fc" # Blue
      stroke: "#6c8ebf"
    }
  }
  stable: {
    style: {
      fill: "#d4edda"
      stroke: "#28a745"
    }
  }
  canary: {
    style: {
      fill: "#fff3cd"
      stroke: "#ffc107"
    }
  }
  logic: {
    shape: diamond
    style: {
      fill: "#e7f5ff"
    }
  }
}

# --- ARCHITECTURE LAYERS ---

clients: Client Layer {
  web_client: "Web Application" { 
    shape: person 
  }
  api_client: "External API" { 
    shape: rectangle
    icon: https://icons.terrastruct.com/dev/terminal.svg
  }
  mobile_client: "Mobile App" { 
    shape: rectangle
    icon: https://icons.terrastruct.com/essentials/028-phone.svg
  }
}

load_balancer: "L7 Load Balancer" {
  shape: hexagon
  tooltip: "Sticky Sessions: User-Hash Based"
  style.fill: "#dee2e6"
}

api_gateway: "API Gateway" {
  class: service
  rate_limiter: "Rate Limiter" { class: logic }
  auth: "Auth Handler" { class: logic }
  validator: "Schema Validator" { class: logic }
  
  rate_limiter -> auth -> validator
}

traffic_splitter: "Traffic Splitter" {
  class: logic
  rule_table: {
    shape: sql_table
    class: mem_header
    
    "0x00": "v1.0.0" {
      label: "v1.0.0 (Weight 90%)"
      class: mem_data
    }
    "0x08": "v2.0.0" {
      label: "v2.0.0 (Weight 10%)"
      class: mem_data
    }
  }
}

model_servers: "Model Server Pool" {
  server_v1: "Server v1.0.0 (Stable)" {
    class: stable
    internal: {
      shape: sequence_diagram
      req_q: "Request Queue"
      batch: "Dynamic Batcher"
      model: "ResNet-50 v1"
      req_q -> batch: "dequeue()"
      batch -> model: "predict(Tensor)"
    }
  }
  server_v2: "Server v2.0.0 (Canary)" {
    class: canary
    internal: {
      shape: sequence_diagram
      req_q: "Request Queue"
      batch: "Dynamic Batcher"
      model: "ResNet-50 v2"
      req_q -> batch: "dequeue()"
      batch -> model: "predict(Tensor)"
    }
  }
}

batching_engine: "Dynamic Batching Engine" {
  queue: "Request Queue" { shape: queue }
  collector: "Batch Collector" {
    shape: sql_table
    class: mem_header
    "MAX_BATCH_SIZE": "32 (Tensors)" { class: mem_data }
    "TIMEOUT": "50ms (Hard Deadline)" { class: mem_data }
    "MAX_DEPTH": "1000 (Backpressure)" { class: mem_data }
  }
  padder: "Variable Length Padder" {
    tooltip: "Zero-padding for Tensor uniformity"
  }
  
  queue -> collector -> padder
}

lifecycle: "Model Loading Lifecycle" {
  proc: {
    shape: sequence_diagram
    device: "1. CUDA Detect"
    mem: "2. Memory Check"
    load: "3. Load Weights"
    warmup: "4. Warmup"
    
    device -> mem: "Found GPU 0"
    mem -> load: "8GB Avail"
    load -> warmup: "Eval Mode"
  }
}

monitoring: "Observability & Health" {
  endpoints: "Health Checks" {
    liveness: "/health/live" { class: logic }
    readiness: "/health/ready" { class: logic }
  }
  metrics_db: "Prometheus TSDB" { shape: cylinder }
  stats: "Performance Matrix" {
    shape: sql_table
    class: mem_header
    v1_stable: "45ms p95 | 0.1% Err" { class: mem_data }
    v2_canary: "42ms p95 | 0.2% Err" { class: mem_data }
  }
}

drift_system: "Drift Detection" {
  baseline: "Baseline Manager" {
    shape: sql_table
    class: mem_header
    f1_mean: "127.5 (std 2.1)" { class: mem_data }
    f2_std: "0.5 (std 0.01)" { class: mem_data }
  }
  ks_test: "KS Test Engine" { class: logic }
  
  baseline -> ks_test: "Compare"
}

canary_ctrl: "Canary Controller" {
  health_check: "Policy Table" {
    shape: sql_table
    class: mem_header
    error_rate: "> 1.0% -> Rollback" { class: mem_data }
    latency_delta: "> +20ms -> Alert" { class: mem_data }
  }
  
  rollout_fsm: "Rollout State Machine" {
    IDLE -> INIT: "Start"
    INIT -> C5: "Health OK"
    C5 -> C10: "Metrics OK"
    C10 -> C25: "Metrics OK"
    C25 -> FULL: "Success"
    
    C5 -> ROLLBACK: "Alert Triggered"
    C10 -> ROLLBACK: "Alert Triggered"
    
    C5: "Canary 5%"
    C10: "Canary 10%"
    C25: "Canary 25%"
    ROLLBACK: "Rollback State" {
      style.fill: "#f8d7da"
      style.stroke: "#dc3545"
    }
  }
}

prediction_logs: "Structured Logging" {
  schema: "Log Schema" {
    shape: sql_table
    class: mem_header
    "00": "ts: ISO8601" { class: mem_data }
    "08": "uid: UUID" { class: mem_data }
    "24": "pred: float32[1000]" { class: mem_data }
    "4024": "lat: uint32" { class: mem_data }
  }
  storage: "S3 Data Lake" { shape: cylinder }
  schema -> storage: "Async Export"
}

# --- CONNECTIONS ---

clients -> load_balancer: "HTTPS/gRPC"
load_balancer -> api_gateway: "L7 Route"

api_gateway.validator -> traffic_splitter: "Validated Request"

traffic_splitter -> model_servers.server_v1: "90% Traffic"
traffic_splitter -> model_servers.server_v2: "10% Traffic"

model_servers.server_v1 -> batching_engine: "Enqueue"
model_servers.server_v2 -> batching_engine: "Enqueue"

batching_engine -> lifecycle: "Trigger Inference"
lifecycle -> monitoring.endpoints: "Update Status"

monitoring.stats -> canary_ctrl: "Real-time Metrics"
monitoring.stats -> drift_system: "Inference Data"

drift_system -> monitoring.metrics_db: "Alert Signals"

canary_ctrl.rollout_fsm -> traffic_splitter.rule_table: "Update Weights"

monitoring.stats -> prediction_logs.schema: "Metadata"

# --- LEGEND ---
legend: "System Legend" {
  near: bottom-right
  stable_box: "Stable Version" { class: stable }
  canary_box: "Canary Version" { class: canary }
  logic_gate: "Decision Point" { class: logic }
  ext_svc: "External Service" { shape: hexagon }
}

# --- FOOTER ---
# Using block string |'md ... '| to handle the pipe character safely
footer: {
  shape: text
  near: bottom-center
  label: |'md
**sizeof=64 bytes (cache aligned)** | **Isolation Level: Kubernetes Pod** | **Deployment: Canary (v2.0.0)**
  '|
}