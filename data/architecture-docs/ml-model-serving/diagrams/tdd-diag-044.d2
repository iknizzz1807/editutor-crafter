direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    input: "#E3F2FD"
    latency: "#FFF3E0"
    latency_detail: "#FFE0B2"
    drift: "#E8F5E9"
    drift_detail: "#C8E6C9"
    detection: "#FCE4EC"
    detection_detail: "#F8BBD9"
    alert: "#F3E5F5"
    alert_detail: "#E1BEE7"
    export: "#E0F7FA"
    export_detail: "#80DEEA"
    external_prom: "#FF9800"
    external_alert: "#F44336"
  }
}

# --- GLOBAL STYLING ---
classes: {
  intel_header: {
    style: {
      font-color: white
      bold: true
      stroke-width: 2
    }
  }
  component_class: {
    shape: class
    style: {
      shadow: true
      border-radius: 4
    }
  }
}

title: |md
  # Complete Monitoring Stack
  ## Module 5: Monitoring & Drift Detection
  **Technical Design Specification**
| {
  near: top-center
  shape: text
}

# --- LAYERS ---

# Input Layer
InferenceRequest: "Inference Request\n(POST /predict)" {
  shape: queue
  style.fill: ${colors.input}
  tooltip: "Entry point for all inference telemetry"
}

# Latency Recording Layer
LatencyRecording: Latency Recording {
  style.fill: ${colors.latency}
  
  LatencyHistogram: {
    shape: class
    class: component_class
    style.fill: ${colors.latency_detail}
    
    "+buckets": "Dict[int, int]"
    "+bucket_bounds": "List[float]"
    "+total_count": "int"
    "+sum_ms": "float"
    
    "+record(latency_ms: float)": "void"
    "+get_percentile(p: float)": "float"
    "+to_prometheus_format()": "str"
  }

  PerVersionTracker: Per-Version Latency Tracker {
    shape: class
    class: component_class
    style.fill: ${colors.latency_detail}
    
    "+version_histograms": "Dict[str, LatencyHistogram]"
    
    "+record(version, latency_ms)": "void"
    "+get_version_metrics()": "Dict"
  }
}

# Drift Sampling Layer
DriftSampling: Drift Sampling {
  style.fill: ${colors.drift}
  
  Sampler: Drift Detection Sampler {
    shape: class
    class: component_class
    style.fill: ${colors.drift_detail}
    
    "+reservoir": "List[Sample]"
    "+max_size": "int"
    "+total_seen": "int"
    
    "+add_sample(features, prediction)": "void"
    "+get_samples()": "List[Sample]"
    "+should_trigger_test()": "bool"
  }

  PredictionMonitor: Prediction Distribution Monitor {
    shape: class
    class: component_class
    style.fill: ${colors.drift_detail}
    
    "+prediction_counts": "Dict[Any, int]"
    "+confidence_buckets": "List[int]"
    
    "+record_prediction(pred, confidence)": "void"
    "+get_distribution()": "Dict"
  }
}

# Drift Detection Layer
DriftDetection: Periodic Drift Test {
  style.fill: ${colors.detection}
  
  KSTestDetector: K-S Test Detector {
    shape: class
    class: component_class
    style.fill: ${colors.detection_detail}
    
    "+feature_baselines": "Dict[str, Baseline]"
    "+alpha": "float"
    
    "+test_drift(samples)": "DriftResult"
    "+ks_statistic(cdf1, cdf2)": "float"
  }

  BaselineManager: Baseline Manager {
    shape: class
    class: component_class
    style.fill: ${colors.detection_detail}
    
    "+baselines": "Dict[str, FeatureBaseline]"
    "+last_capture_date": "datetime"
    
    "+capture_baseline(training_data)": "void"
    "+load_baseline(version)": "Baseline"
  }
}

# Alert Evaluation Layer
AlertEvaluation: Alert Evaluation {
  style.fill: ${colors.alert}
  
  AlertManager: Alert Manager {
    shape: class
    class: component_class
    style.fill: ${colors.alert_detail}
    
    "+rules": "List[AlertRule]"
    "+active_alerts": "Dict[str, Alert]"
    "+cooldown_seconds": "int"
    
    "+evaluate(metrics, drift_results)": "void"
    "+fire_alert(rule, context)": "void"
    "+resolve_alert(alert_id)": "void"
  }

  AlertRule: Alert Rule {
    shape: class
    class: component_class
    style.fill: ${colors.alert_detail}
    
    "+name": "str"
    "+condition": "Callable"
    "+severity": "str"
    "+threshold": "float"
  }
}

# Export Layer
Export: Export & Logging {
  style.fill: ${colors.export}
  
  PrometheusExporter: Prometheus Exporter {
    shape: hexagon
    style.fill: ${colors.export_detail}
    label: |md
      **Metrics Exported**
      - `model_latency_seconds`
      - `prediction_total`
      - `drift_score_ks`
      - `alerts_active`
    |
  }

  StructuredLogger: Structured Request Logger {
    shape: class
    class: component_class
    style.fill: ${colors.export_detail}
    
    "+log_path": "Path"
    "+buffer": "List[LogEntry]"
    
    "+log_request(id, input, output, ms)": "void"
    "+flush()": "void"
  }

  LogOutput: "JSON Logs\n/audit/requests/" {
    shape: stored_data
    style.fill: "#B2EBF2"
  }
}

# --- EXTERNAL SYSTEMS ---
PrometheusServer: Prometheus Server {
  shape: cylinder
  style.fill: ${colors.external_prom}
  style.stroke: "#E65100"
}

AlertingChannel: Alerting Channel {
  shape: diamond
  style.fill: ${colors.external_alert}
  style.font-color: white
}

# --- CONNECTIONS (FLOW) ---

# Synchronous Path
InferenceRequest -> LatencyRecording.LatencyHistogram: "1. record latency" {
  style.stroke: "#1976D2"
  style.stroke-width: 3
}
InferenceRequest -> DriftSampling.Sampler: "2. sample features" {
  style.stroke: "#1976D2"
  style.stroke-width: 3
}
InferenceRequest -> DriftSampling.PredictionMonitor: "3. monitor predictions" {
  style.stroke: "#1976D2"
  style.stroke-width: 3
}

# Async/Periodic Internal Flow
LatencyRecording.LatencyHistogram -> LatencyRecording.PerVersionTracker: "aggregate"
DriftSampling.Sampler -> DriftDetection.KSTestDetector: "4. periodic test" {
  style.stroke-dash: 5
}
DriftDetection.BaselineManager -> DriftDetection.KSTestDetector: "provide baseline"

# Alert Evaluation Path
DriftDetection.KSTestDetector -> AlertEvaluation.AlertManager: "5. drift results" {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}
LatencyRecording.PerVersionTracker -> AlertEvaluation.AlertManager: "5. latency metrics" {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}
AlertEvaluation.AlertRule -> AlertEvaluation.AlertManager: "evaluate rules"

# Telemetry & Export Path
AlertEvaluation.AlertManager -> Export.PrometheusExporter: "6. export metrics" {
  style.stroke: "#00796B"
}
LatencyRecording.PerVersionTracker -> Export.PrometheusExporter: "6. export metrics" {
  style.stroke: "#00796B"
}
DriftDetection.KSTestDetector -> Export.PrometheusExporter: "6. export metrics" {
  style.stroke: "#00796B"
}
InferenceRequest -> Export.StructuredLogger: "6. log request" {
  style.stroke: "#00796B"
}
Export.StructuredLogger -> Export.LogOutput: "write"

# External Hooks
Export.PrometheusExporter -> PrometheusServer: "scrape\n(/metrics)" {
  style.stroke-dash: 3
  style.stroke: ${colors.external_prom}
}
AlertEvaluation.AlertManager -> AlertingChannel: "fire alert (PagerDuty/Slack)" {
  style.stroke: ${colors.external_alert}
  style.stroke-width: 3
}

# --- LEGEND & ANNOTATIONS ---
Legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  
  sync_path: "Sync Telemetry Path" {
    shape: text
    style.font-color: "#1976D2"
    style.bold: true
  }
  async_path: "Async Periodic Path" {
    shape: text
    style.font-color: "#777777"
  }
  alert_path: "Critical Alert Path" {
    shape: text
    style.font-color: "#D32F2F"
    style.bold: true
  }
}

Implementation_Notes: |md
  ### Monitoring Implementation Details
  - **Reservoir Sampling:** Sampler uses a fixed-size reservoir to avoid memory exhaustion during high traffic.
  - **Latency Histograms:** Buckets are exponentially spaced (e.g., 1ms, 2ms, 5ms, 10ms, 25ms...).
  - **K-S Test:** Performed every 1000 samples or 1 hour, whichever comes first.
  - **Log Buffer:** Structured Logger uses a 5MB ring buffer to ensure zero-loss request logging.
| {
  near: bottom-left
  shape: text
}