direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Local Derivative Computation Per Operation"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
operations: {
  label: "Operation Reference Table"
  width: 900
  addition: {
    shape: sql_table
    label: "Addition: c = a + b"
    f1: "Forward | c.data = a.data + b.data"
    d1: "∂c/∂a | 1"
    d2: "∂c/∂b | 1"
    code1: "_backward() | self.grad += out.grad"
    code2: "_backward() | other.grad += out.grad"
    note: "Derivative of sum: both inputs receive full upstream gradient"
  }
  multiplication: {
    shape: sql_table
    label: "Multiplication: c = a * b"
    f1: "Forward | c.data = a.data * b.data"
    d1: "∂c/∂a | b.data"
    d2: "∂c/∂b | a.data"
    code1: "_backward() | self.grad += other.data * out.grad"
    code2: "_backward() | other.grad += self.data * out.grad"
    note: "Local derivative is sibling's VALUE (not gradient)"
  }
  power: {
    shape: sql_table
    label: "Power: c = a ** n  (n is constant int/float)"
    f1: "Forward | c.data = a.data ** n"
    d1: "∂c/∂a | n * a.data^(n-1)"
    d2: "∂c/∂n | N/A (not tracked)"
    code1: "_backward() | self.grad += n * (self.data**(n-1)) * out.grad"
    code2: "_backward() | (none - n is not a Value)"
    note: "Power rule: d(x^n)/dx = n*x^(n-1)"
  }
  negation: {
    shape: sql_table
    label: "Negation: c = -a  (via a * -1)"
    f1: "Forward | c.data = -a.data"
    d1: "∂c/∂a | -1"
    code1: "_backward() | self.grad += -1 * out.grad"
    note: "Implemented as multiplication by -1"
  }
  subtraction: {
    shape: sql_table
    label: "Subtraction: c = a - b  (via a + (-b))"
    f1: "Forward | c.data = a.data - b.data"
    d1: "∂c/∂a | 1"
    d2: "∂c/∂b | -1"
    code1: "_backward() | self.grad += out.grad"
    code2: "_backward() | other.grad += -1 * out.grad"
    note: "Implemented as a + (-b), derivative of -b is -1"
  }
  division: {
    shape: sql_table
    label: "Division: c = a / b  (via a * b**-1)"
    f1: "Forward | c.data = a.data / b.data"
    d1: "∂c/∂a | 1/b"
    d2: "∂c/∂b | -a/b²"
    code1: "_backward() | self.grad += (1/other.data) * out.grad"
    code2: "_backward() | other.grad += (-self.data/other.data²) * out.grad"
    note: "Implemented as a * (b**-1), chain rule applies"
  }
  tanh: {
    shape: sql_table
    label: "Tanh Activation: c = tanh(a)"
    f1: "Forward | c.data = (e^2x - 1) / (e^2x + 1)"
    d1: "∂c/∂a | 1 - tanh²(a)"
    code1: "_backward() | self.grad += (1 - t²) * out.grad"
    note: "t is cached output value; avoids recomputing exp()"
    cache: "t captured | from forward pass"
  }
  relu: {
    shape: sql_table
    label: "ReLU Activation: c = relu(a)"
    f1: "Forward | c.data = max(0, a.data)"
    d1: "∂c/∂a | 1 if a > 0, else 0"
    code1: "_backward() | self.grad += (out.data > 0) * out.grad"
    note: "Dead neuron: if a ≤ 0 always, gradient is 0 forever"
    warn: "Boolean cast | (out.data > 0) → 1 or 0"
  }
}
legend: {
  label: "Legend"
  near: bottom-right
  width: 350
  vars: {
    shape: sql_table
    label: "Variable Conventions"
    v1: "self | left operand (a)"
    v2: "other | right operand (b)"
    v3: "out | output Value (c)"
    v4: "out.grad | upstream gradient (∂L/∂c)"
    v5: "t | cached tanh output"
  }
  rules: {
    shape: sql_table
    label: "Critical Rules"
    r1: "Use += | gradients ACCUMULATE"
    r2: "Use .data | for local derivatives"
    r3: "Use .grad | for upstream flow"
    r4: "Never = | would overwrite paths"
  }
}
chain_rule: {
  label: "Chain Rule Formula"
  near: bottom-left
  width: 400
  formula: {
    shape: rectangle
    label: |md
      **Gradient Flow:**
      `∂L/∂a = (∂c/∂a) × (∂L/∂c)`
      `operand.grad += local_derivative × out.grad`
    |
    style: {
      fill: "#E8F4E8"
      stroke: "#4A7C4A"
      font: mono
    }
  }
}