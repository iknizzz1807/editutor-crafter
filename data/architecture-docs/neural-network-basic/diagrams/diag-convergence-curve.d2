direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Loss vs. Epoch: Training Convergence Dynamics
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  good_fit: {
    direction: down
    label: "Good Convergence"
    width: 400
    axis_y: {
      label: "Loss"
      shape: rectangle
      width: 30
      height: 300
      style.fill: transparent
      style.stroke: transparent
    }
    plot_area: {
      label: ""
      width: 350
      height: 300
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
      p0: {
        shape: circle
        width: 12
        style.fill: "#e74c3c"
        tooltip: "Epoch 0: Loss = 0.85"
      }
      p1: {
        shape: circle
        width: 10
        style.fill: "#e67e22"
        tooltip: "Epoch 100: Loss = 0.42"
      }
      p2: {
        shape: circle
        width: 10
        style.fill: "#f39c12"
        tooltip: "Epoch 300: Loss = 0.15"
      }
      p3: {
        shape: circle
        width: 10
        style.fill: "#27ae60"
        tooltip: "Epoch 500: Loss = 0.05"
      }
      p4: {
        shape: circle
        width: 10
        style.fill: "#27ae60"
        tooltip: "Epoch 800: Loss = 0.01"
      }
      p5: {
        shape: circle
        width: 10
        style.fill: "#2ecc71"
        tooltip: "Epoch 1000: Loss = 0.005"
      }
      curve_segment1: {
        label: ""
        shape: rectangle
        width: 60
        height: 4
        style.fill: "#3498db"
        style.stroke: transparent
      }
      curve_segment2: {
        label: ""
        shape: rectangle
        width: 80
        height: 3
        style.fill: "#3498db"
        style.stroke: transparent
      }
      plateau: {
        label: "Plateau"
        shape: rectangle
        width: 100
        height: 2
        style.fill: "#27ae60"
        style.stroke: transparent
      }
    }
    axis_x: {
      label: "Epoch →"
      shape: rectangle
      width: 350
      height: 30
      style.fill: transparent
      style.stroke: transparent
    }
    annotation_rapid: {
      label: "Rapid Descent\n(lr=0.1 visible)"
      shape: callout
      style.fill: "#fff3cd"
      style.stroke: "#ffc107"
    }
    annotation_plateau: {
      label: "Convergence\nPlateau"
      shape: callout
      style.fill: "#d4edda"
      style.stroke: "#28a745"
    }
    annotation_minimum: {
      label: "Near Zero\nMinimum"
      shape: callout
      style.fill: "#cce5ff"
      style.stroke: "#007bff"
    }
  }
  underfit: {
    direction: down
    label: "Underfitting (High Plateau)"
    width: 400
    plot_area_u: {
      label: ""
      width: 350
      height: 300
      style.fill: "#f8f9fa"
      style.stroke: "#dee2e6"
      u0: {
        shape: circle
        width: 12
        style.fill: "#e74c3c"
        tooltip: "Epoch 0: Loss = 0.80"
      }
      u1: {
        shape: circle
        width: 10
        style.fill: "#e67e22"
        tooltip: "Epoch 200: Loss = 0.35"
      }
      u2: {
        shape: circle
        width: 10
        style.fill: "#f39c12"
        tooltip: "Epoch 500: Loss = 0.28"
      }
      u3: {
        shape: circle
        width: 10
        style.fill: "#f39c12"
        tooltip: "Epoch 800: Loss = 0.25"
      }
      u4: {
        shape: circle
        width: 10
        style.fill: "#f39c12"
        tooltip: "Epoch 1000: Loss = 0.24"
      }
      high_plateau: {
        label: "Stuck at 0.24"
        shape: rectangle
        width: 120
        height: 2
        style.fill: "#e74c3c"
        style.stroke: transparent
      }
    }
    cause_box: {
      label: "Possible Causes:"
      shape: rectangle
      width: 340
      style.fill: "#fff3cd"
      style.stroke: "#ffc107"
      c1: "• Network too small (insufficient capacity)"
      c2: "• Learning rate too low"
      c3: "• Local minimum trap"
      c4: "• Features don't capture signal"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phases: {
    label: "Training Phase Dynamics"
    width: 800
    phase1: {
      label: "Phase 1: Initial Descent\n(Epochs 0-200)"
      shape: rectangle
      width: 240
      style.fill: "#ffebee"
      style.stroke: "#e53935"
      desc1: |md
        - Loss drops rapidly
        - Gradients are large
        - Learning rate visible in step size
        - Moving toward nearest valley
      |
    }
    phase2: {
      label: "Phase 2: Refinement\n(Epochs 200-600)"
      shape: rectangle
      width: 240
      style.fill: "#fff8e1"
      style.stroke: "#ffb300"
      desc2: |md
        - Loss decreases more slowly
        - Gradients shrink
        - Fine-tuning parameters
        - Approaching minimum
      |
    }
    phase3: {
      label: "Phase 3: Convergence\n(Epochs 600+)"
      shape: rectangle
      width: 240
      style.fill: "#e8f5e9"
      style.stroke: "#43a047"
      desc3: |md
        - Loss plateaus near minimum
        - Gradients near zero
        - Small oscillations around optimum
        - Training complete
      |
    }
    phase1 -> phase2: "gradient\nshrinks"
    phase2 -> phase3: "approach\nminimum"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  learning_rates: {
    label: "Learning Rate Effects"
    width: 800
    lr_good: {
      label: "lr = 0.1 (Good)"
      shape: rectangle
      width: 250
      style.fill: "#e8f5e9"
      style.stroke: "#4caf50"
      curve_g: {
        label: "↓ → → →"
        shape: rectangle
        width: 200
        height: 80
        style.fill: transparent
        style.stroke: "#4caf50"
        style.stroke-dash: 2
      }
      desc_g: "Smooth descent to minimum"
    }
    lr_high: {
      label: "lr = 1.0 (Too High)"
      shape: rectangle
      width: 250
      style.fill: "#ffebee"
      style.stroke: "#f44336"
      curve_h: {
        label: "↓ ↑ ↓ ↑ ↑"
        shape: rectangle
        width: 200
        height: 80
        style.fill: transparent
        style.stroke: "#f44336"
        style.stroke-dash: 2
      }
      desc_h: "Oscillates, may diverge"
    }
    lr_low: {
      label: "lr = 0.001 (Too Low)"
      shape: rectangle
      width: 250
      style.fill: "#fff3e0"
      style.stroke: "#ff9800"
      curve_l: {
        label: "→ → → → →"
        shape: rectangle
        width: 200
        height: 80
        style.fill: transparent
        style.stroke: "#ff9800"
        style.stroke-dash: 2
      }
      desc_l: "Barely moves, very slow"
    }
  }
}
legend: {
  near: bottom-center
  label: "Convergence Indicators"
  indicator1: {
    label: "● Initial Loss High (0.5-1.0)"
    shape: rectangle
    width: 200
    style.fill: "#e74c3c"
    style.font-color: white
  }
  indicator2: {
    label: "● Rapid Early Drop"
    shape: rectangle
    width: 200
    style.fill: "#f39c12"
    style.font-color: white
  }
  indicator3: {
    label: "● Smooth Plateau < 0.01"
    shape: rectangle
    width: 200
    style.fill: "#27ae60"
    style.font-color: white
  }
}
good_fit.plot_area.p0 -> good_fit.plot_area.p1 -> good_fit.plot_area.p2 -> good_fit.plot_area.p3 -> good_fit.plot_area.p4 -> good_fit.plot_area.p5: {
  style.stroke: "#3498db"
  style.stroke-width: 2
}
underfit.plot_area_u.u0 -> underfit.plot_area_u.u1 -> underfit.plot_area_u.u2 -> underfit.plot_area_u.u3 -> underfit.plot_area_u.u4: {
  style.stroke: "#e74c3c"
  style.stroke-width: 2
}