direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Complete Computational Graph: Training Pipeline
  **XOR Network: 2 inputs → 4 hidden → 1 output (17 parameters)**
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  inputs: {
    direction: down
    label: "INPUT LAYER"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    x1: {
      shape: sql_table
      label: "Input x₁"
      val: "data | 1.0"
      grad: "grad | 0.0"
    }
    x2: {
      shape: sql_table
      label: "Input x₂"
      val: "data | 0.0"
      grad2: "grad | 0.0"
    }
  }
  weights_l1: {
    direction: down
    label: "HIDDEN LAYER 1 WEIGHTS"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    w11: {
      shape: sql_table
      label: "w₁₁ (Value)"
      d: "data | 0.42"
      g: "grad | -0.08"
    }
    w12: {
      shape: sql_table
      label: "w₁₂ (Value)"
      d: "data | -0.31"
      g: "grad | 0.12"
    }
    w13: {
      shape: sql_table
      label: "w₁₃ (Value)"
      d: "data | 0.67"
      g: "grad | -0.05"
    }
    w14: {
      shape: sql_table
      label: "w₁₄ (Value)"
      d: "data | -0.55"
      g: "grad | 0.03"
    }
    b1: {
      shape: sql_table
      label: "b₁ (bias)"
      d: "data | 0.12"
      g: "grad | 0.15"
    }
  }
}
row_hidden: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hidden_neurons: {
    direction: down
    label: "HIDDEN NEURONS (tanh)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    h1: {
      shape: class
      label: "Neuron h₁"
      +forward: "Σ(w·x) + b"
      +activate: "tanh(act)"
      -output: "Value(0.38)"
      -gradient: "grad=0.21"
    }
    h2: {
      shape: class
      label: "Neuron h₂"
      +forward: "Σ(w·x) + b"
      +activate: "tanh(act)"
      -output: "Value(-0.15)"
      -gradient: "grad=-0.08"
    }
    h3: {
      shape: class
      label: "Neuron h₃"
      +forward: "Σ(w·x) + b"
      +activate: "tanh(act)"
      -output: "Value(0.52)"
      -gradient: "grad=0.14"
    }
    h4: {
      shape: class
      label: "Neuron h₄"
      +forward: "Σ(w·x) + b"
      +activate: "tanh(act)"
      -output: "Value(-0.29)"
      -gradient: "grad=-0.11"
    }
  }
  weights_l2: {
    direction: down
    label: "OUTPUT LAYER WEIGHTS"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    w21: {
      shape: sql_table
      label: "w₂₁ (Value)"
      d: "data | 0.88"
      g: "grad | -0.33"
    }
    w22: {
      shape: sql_table
      label: "w₂₂ (Value)"
      d: "data | -0.44"
      g: "grad | 0.18"
    }
    w23: {
      shape: sql_table
      label: "w₂₃ (Value)"
      d: "data | 0.71"
      g: "grad | -0.27"
    }
    w24: {
      shape: sql_table
      label: "w₂₄ (Value)"
      d: "data | -0.62"
      g: "grad | 0.21"
    }
    b2: {
      shape: sql_table
      label: "b₂ (bias)"
      d: "data | 0.05"
      g: "grad | 0.42"
    }
  }
}
row_output: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_neuron: {
    direction: down
    label: "OUTPUT NEURON (linear)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    out: {
      shape: class
      label: "Output ŷ"
      +forward: "Σ(w·h) + b"
      -value: "Value(0.0156)"
      -grad: "1.0 (seed)"
      -op: "linear"
    }
  }
  loss_computation: {
    direction: down
    label: "LOSS COMPUTATION"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    target: {
      shape: sql_table
      label: "Target y"
      t: "data | 0.0"
    }
    diff: {
      shape: class
      label: "Difference"
      +op: "ŷ - y"
      -val: "Value(0.0156)"
      -grad: "0.0312"
    }
    squared: {
      shape: class
      label: "Squared Error"
      +op: "(ŷ-y)²"
      -val: "Value(0.000244)"
      -grad: "1.0"
    }
    mse: {
      shape: class
      label: "MSE Loss"
      +op: "avg(errors)"
      -val: "Value(0.000244)"
      -grad: "1.0 (seed)"
    }
  }
}
row_backward: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  backward_flow: {
    direction: down
    label: "BACKWARD PASS (Topological Order)"
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    width: 400
    step1: {
      label: "Step 1: Seed Loss Gradient"
      width: 380
      code: |'python
        loss.grad = 1.0  # ∂L/∂L = 1
      '|
    }
    step2: {
      label: "Step 2: Backprop Through Mean"
      width: 380
      code: |'python
        # d(mean)/d(each_error) = 1/n
        for se in squared_errors:
            se.grad += loss.grad * (1.0/n)
      '|
    }
    step3: {
      label: "Step 3: Backprop Through Square"
      width: 380
      code: |'python
        # d(x²)/dx = 2x
        diff.grad += 2 * diff.data * squared.grad
      '|
    }
    step4: {
      label: "Step 4: Backprop Through Subtraction"
      width: 380
      code: |'python
        # d(y-x)/dx = -1, d(y-x)/dy = 1
        pred.grad += -1 * diff.grad
        target.grad += 1 * diff.grad
      '|
    }
    step5: {
      label: "Step 5: Backprop Through Linear Output"
      width: 380
      code: |'python
        # d(Σw·h + b)/dw_i = h_i
        # d(Σw·h + b)/dh_i = w_i
        for i, (w, h) in enumerate(zip(w2, hidden)):
            w2[i].grad += h.data * out.grad
            hidden[i].grad += w.data * out.grad
        b2.grad += out.grad
      '|
    }
    step6: {
      label: "Step 6: Backprop Through Tanh"
      width: 380
      code: |'python
        # d(tanh(x))/dx = 1 - tanh²(x)
        act.grad += (1 - h.data**2) * h.grad
      '|
    }
    step7: {
      label: "Step 7: Backprop Through Hidden Weights"
      width: 380
      code: |'python
        # Chain rule accumulation
        for i, (w, x) in enumerate(zip(w1, inputs)):
            w1[i].grad += x.data * act.grad
            x.grad += w.data * act.grad
        b1.grad += act.grad
      '|
    }
  }
  optimizer: {
    direction: down
    label: "SGD OPTIMIZER UPDATE"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    width: 380
    zero_grad_step: {
      label: "Step A: zero_grad()"
      code: |'python
        # Reset before backward (per epoch)
        for p in network.parameters():
            p.grad = 0.0
      '|
    }
    backward_call: {
      label: "Step B: loss.backward()"
      code: |'python
        # Fills all gradients via chain rule
        # Topological sort ensures correct order
        topo = build_topo(loss)
        for node in reversed(topo):
            node._backward()
      '|
    }
    step_update: {
      label: "Step C: optimizer.step()"
      code: |'python
        # Gradient descent update
        lr = 0.1
        for p in network.parameters():
            p.data -= lr * p.grad
            # Example: w=0.42, grad=-0.08
            # p.data = 0.42 - 0.1*(-0.08) = 0.428
      '|
    }
    update_example: {
      shape: sql_table
      label: "Parameter Update Example"
      before: "w₁₁ before | 0.4200"
      gradient: "w₁₁ grad  | -0.0800"
      delta: "lr × grad  | -0.0080"
      after: "w₁₁ after  | 0.4280"
    }
  }
}
gradient_legend: {
  direction: right
  label: "GRADIENT FLOW LEGEND"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  forward_arrow: "Forward Pass"
  backward_arrow: "Backward Pass"
  forward_arrow.style.stroke: "#2196F3"
  backward_arrow.style.stroke: "#F44336"
  backward_arrow.style.stroke-dash: 4
}
connections: {
  direction: down
  label: "DATA FLOW CONNECTIONS"
  style.fill: transparent
  style.stroke: transparent
  c1: "inputs.x1 → weights_l1 (forward)" {
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  c2: "weights_l1 → hidden_neurons (forward)" {
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  c3: "hidden_neurons → weights_l2 (forward)" {
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  c4: "weights_l2 → output_neuron (forward)" {
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  c5: "output_neuron → loss_computation (forward)" {
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  c6: "loss_computation → backward_flow (backward)" {
    style.stroke: "#F44336"
    style.stroke-dash: 4
    style.stroke-width: 2
  }
  c7: "backward_flow → optimizer (update)" {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
}
row_input.inputs -> row_hidden.hidden_neurons: "w·x + b | forward" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
row_hidden.hidden_neurons -> row_output.output_neuron: "tanh(·) | forward" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
row_output.output_neuron -> row_output.loss_computation: "ŷ | forward" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
row_output.loss_computation -> row_backward.backward_flow: "∂L/∂· | backward" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
  style.stroke-width: 2
}
row_backward.backward_flow -> row_backward.optimizer: "grad | update" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
parameter_summary: {
  direction: right
  label: "PARAMETER SUMMARY"
  style.fill: "#FFFDE7"
  style.stroke: "#FFC107"
  layer1: {
    shape: sql_table
    label: "Hidden Layer 1"
    params: "4 neurons × (2+1) | 12 params"
    weights: "4×2 weights | 8"
    biases: "4 biases | 4"
  }
  layer2: {
    shape: sql_table
    label: "Output Layer"
    params: "1 neuron × (4+1) | 5 params"
    weights: "1×4 weights | 4"
    biases: "1 bias | 1"
  }
  total: {
    shape: sql_table
    label: "TOTAL"
    all: "All parameters | 17"
  }
}
epoch_cycle: {
  direction: down
  label: "TRAINING EPOCH CYCLE"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  width: 350
  cycle_code: |'python
    for epoch in range(epochs):
        # 1. Forward: build computational graph
        predictions = [network(x) for x in X]
        # 2. Loss: measure error
        loss = mse_loss(predictions, Y)
        # 3. Zero: reset gradients
        optimizer.zero_grad()
        # 4. Backward: compute gradients
        loss.backward()  # Topological traversal
        # 5. Step: update parameters
        optimizer.step()  # p.data -= lr * p.grad
  '|
}
legend_box: {
  near: bottom-right
  label: "Color Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  blue: "Blue arrows = Forward pass (data flow)"
  red: "Red dashed = Backward pass (gradient flow)"
  green: "Green arrows = Parameter updates"
  orange: "Orange boxes = Learnable weights"
  purple: "Purple boxes = Output/loss nodes"
  blue.style.font-color: "#2196F3"
  red.style.font-color: "#F44336"
  green.style.font-color: "#4CAF50"
  orange.style.font-color: "#FF9800"
  purple.style.font-color: "#9C27B0"
}