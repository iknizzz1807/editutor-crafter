direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Gradient Flow: L = (a×b + c)²
  **Backward Pass Data Walk**
'|
title.near: top-center

# Initial State
row_init: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  init_box: {
    label: "Initial Values"
    width: 280
    init_vals: |md
      a = Value(2.0)
      b = Value(3.0)  
      c = Value(1.0)
      L = (a*b + c)**2
      L.data = (6 + 1)² = 49
    |
  }
  seed_box: {
    label: "Seed Gradient"
    width: 260
    seed: |md
      L.grad = 1.0  # dL/dL = 1
      All others: grad = 0.0
    |
    style.fill: "#E8F5E9"
  }
}

# Step 1: Power backward
row_step1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1_code: {
    label: "Step 1: pow(2)._backward()"
    width: 340
    code: |'python
      # L = d ** 2, where d = a*b + c = 7
      # d(x^n)/dx = n * x^(n-1) * out.grad
      d.grad += 2 * d.data * L.grad
      d.grad += 2 * 7 * 1.0
      d.grad = 14.0
    '|
  }
  step1_result: {
    label: "After Step 1"
    width: 200
    result: |md
      L.grad = 1.0 ✓
      d.grad = 14.0 ← NEW
      a,b,c.grad = 0.0
    |
    style.fill: "#FFF3E0"
  }
}

# Step 2: Addition backward
row_step2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step2_code: {
    label: "Step 2: add._backward()"
    width: 340
    code: |'python
      # d = t + c, where t = a*b = 6
      # d(a+b)/da = 1, d(a+b)/db = 1
      # Gradient passes through unchanged
      t.grad += d.grad  # 14.0
      c.grad += d.grad  # 14.0
    '|
  }
  step2_result: {
    label: "After Step 2"
    width: 200
    result: |md
      L.grad = 1.0
      d.grad = 14.0 ✓
      t.grad = 14.0 ← NEW
      c.grad = 14.0 ← NEW
      a,b.grad = 0.0
    |
    style.fill: "#FFF3E0"
  }
}

# Step 3: Multiplication backward
row_step3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step3_code: {
    label: "Step 3: mul._backward()"
    width: 340
    code: |'python
      # t = a * b
      # d(ab)/da = b, d(ab)/db = a
      a.grad += b.data * t.grad
      a.grad += 3.0 * 14.0 = 42.0
      b.grad += a.data * t.grad
      b.grad += 2.0 * 14.0 = 28.0
    '|
  }
  step3_result: {
    label: "After Step 3"
    width: 200
    result: |md
      L.grad = 1.0
      d.grad = 14.0 ✓
      t.grad = 14.0 ✓
      c.grad = 14.0 ✓
      a.grad = 42.0 ← NEW
      b.grad = 28.0 ← NEW
    |
    style.fill: "#E8F5E9"
  }
}

# Computational graph visualization
row_graph: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  graph_forward: {
    label: "Forward Graph (data values)"
    direction: down
    width: 320
    leaf_a: "a | data=2.0" {
      shape: circle
      style.fill: "#E3F2FD"
    }
    leaf_b: "b | data=3.0" {
      shape: circle
      style.fill: "#E3F2FD"
    }
    leaf_c: "c | data=1.0" {
      shape: circle
      style.fill: "#E3F2FD"
    }
    node_mul: "(×) | data=6.0" {
      shape: diamond
      style.fill: "#FCE4EC"
    }
    node_add: "(+) | data=7.0" {
      shape: diamond
      style.fill: "#FCE4EC"
    }
    node_pow: "(²) | data=49.0" {
      shape: diamond
      style.fill: "#FCE4EC"
    }
    node_L: "L | data=49.0" {
      shape: circle
      style.fill: "#C8E6C9"
    }
    leaf_a -> node_mul: "2.0"
    leaf_b -> node_mul: "3.0"
    leaf_c -> node_add: "1.0"
    node_mul -> node_add: "6.0"
    node_add -> node_pow: "7.0"
    node_pow -> node_L: "49.0"
  }
  graph_backward: {
    label: "Backward Graph (gradient flow)"
    direction: down
    width: 320
    grad_L: "L | grad=1.0" {
      shape: circle
      style.fill: "#C8E6C9"
    }
    grad_pow: "(²) | grad=14.0" {
      shape: diamond
      style.fill: "#FFF9C4"
    }
    grad_add: "(+) | grad=14.0" {
      shape: diamond
      style.fill: "#FFF9C4"
    }
    grad_mul: "(×) | grad=14.0" {
      shape: diamond
      style.fill: "#FFF9C4"
    }
    grad_a: "a | grad=42.0" {
      shape: circle
      style.fill: "#FFCDD2"
    }
    grad_b: "b | grad=28.0" {
      shape: circle
      style.fill: "#FFCDD2"
    }
    grad_c: "c | grad=14.0" {
      shape: circle
      style.fill: "#FFCDD2"
    }
    grad_L -> grad_pow: "× 2×7 = 14"
    grad_pow -> grad_add: "pass 14"
    grad_add -> grad_mul: "pass 14"
    grad_add -> grad_c: "pass 14"
    grad_mul -> grad_a: "× b=3 → 42"
    grad_mul -> grad_b: "× a=2 → 28"
  }
}

# Final verification
row_verify: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  verify_box: {
    label: "Analytical Verification"
    width: 400
    verify: |md
      L = (a·b + c)² = (2·3 + 1)² = 49
      ∂L/∂a = 2(a·b+c) · b = 2·7·3 = 42 ✓
      ∂L/∂b = 2(a·b+c) · a = 2·7·2 = 28 ✓  
      ∂L/∂c = 2(a·b+c) · 1 = 2·7·1 = 14 ✓
    |
    style.fill: "#E8F5E9"
  }
}

# Chain rule summary
summary: {
  label: "Chain Rule Applied at Each Node"
  width: 500
  chain_rule: |'md
    | Node | Operation | Local Derivative | Gradient Computation |
    |------|-----------|------------------|---------------------|
    | pow2 | x → x² | 2x | 2 × 7 × 1 = 14 |
    | add | x+y → sum | 1, 1 | 1 × 14 = 14 (both) |
    | mul | x·y → product | y, x | 3×14=42, 2×14=28 |
  '|
}

# Sequencing connections
row_init -> row_step1: "seed"
row_step1 -> row_step2: "backward"
row_step2 -> row_step3: "backward"
row_step3 -> row_graph: "visualize"
row_graph -> row_verify: "verify"
row_verify -> summary: "conclude"