direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Computational Graph Building in Action (micrograd.py)"
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#f0f0f0"
    stroke-width: 2
  }
}

content: "" {
  style.stroke: transparent
  style.fill: transparent
  
  step1: {
    direction: right
    style.fill: "#fafafa"
    style.stroke-dash: 5
    
    info: {
      label: "Step 1: Initial State"
      code: |'python
        a = Value(2.0)
        b = Value(3.0)
        # a._prev = set()
        # b._prev = set()
      '|
      width: 300
    }

    viz: {
      direction: right
      style.stroke: transparent
      
      val_a: {
        shape: sql_table
        label: "Value a"
        f0: "0x00 | double | data = 2.0"
        f1: "0x08 | double | grad = 0.0"
        f2: "0x10 | set*   | _prev = ∅"
        f3: "0x18 | char*  | _op = ''"
        sz: "Total: 32 bytes"
        style.fill: "#E8F5E9"
      }

      val_b: {
        shape: sql_table
        label: "Value b"
        f0: "0x00 | double | data = 3.0"
        f1: "0x08 | double | grad = 0.0"
        f2: "0x10 | set*   | _prev = ∅"
        f3: "0x18 | char*  | _op = ''"
        sz: "Total: 32 bytes"
        style.fill: "#E3F2FD"
      }
    }
  }

  step2: {
    direction: right
    style.fill: "#fafafa"
    style.stroke-dash: 5
    
    info: {
      label: "Step 2: Multiplication Node"
      code: |'python
        c = a * b
        # c.data = 6.0
        # c._prev = {a, b}
        # c._op = '*'
      '|
      width: 300
    }

    viz: {
      direction: right
      style.stroke: transparent
      
      val_a: {
        shape: sql_table
        label: "Value a"
        f0: "data = 2.0"
        style.fill: "#E8F5E9"
      }
      
      val_b: {
        shape: sql_table
        label: "Value b"
        f0: "data = 3.0"
        style.fill: "#E3F2FD"
      }

      val_c: {
        shape: sql_table
        label: "Value c (NEW)"
        f0: "0x00 | double | data = 6.0"
        f1: "0x08 | double | grad = 0.0"
        f2: "0x10 | set*   | _prev = {a, b}"
        f3: "0x18 | char*  | _op = '*'"
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
      }

      val_a -> val_c: "parent"
      val_b -> val_c: "parent"
    }
  }

  step3: {
    direction: right
    style.fill: "#fafafa"
    style.stroke-dash: 5
    
    info: {
      label: "Step 3: Addition & Graph Fan-in"
      code: |'python
        d = c + a
        # d.data = 8.0
        # d._prev = {c, a}
        # d._op = '+'
      '|
      width: 300
    }

    viz: {
      direction: right
      style.stroke: transparent
      
      val_a: {
        shape: sql_table
        label: "Value a (REUSED)"
        f0: "data = 2.0"
        style.fill: "#FFCDD2"
        style.stroke: "#D32F2F"
        style.stroke-width: 3
      }
      
      val_c: {
        shape: sql_table
        label: "Value c"
        f0: "data = 6.0"
        style.fill: "#FFF3E0"
      }

      val_d: {
        shape: sql_table
        label: "Value d (NEW)"
        f0: "0x00 | double | data = 8.0"
        f1: "0x08 | double | grad = 0.0"
        f2: "0x10 | set*   | _prev = {c, a}"
        f3: "0x18 | char*  | _op = '+'"
        style.fill: "#F3E5F5"
        style.stroke: "#9C27B0"
      }

      val_a -> val_c: "*"
      val_c -> val_d: "+"
      val_a -> val_d: "+ (FAN-IN)" {
        style.stroke: "#D32F2F"
        style.stroke-width: 3
        style.stroke-dash: 4
      }
    }
  }

  step1 -> step2: "Value.__mul__(a, b)"
  step2 -> step3: "Value.__add__(c, a)"
}

key_insight: {
  label: "Implementation Insight: Gradient Accumulation"
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 2
  }
  
  content: |'md
    Value `a` exists in both `c._prev` and `d._prev`.
    
    When `d.backward()` is called:
    1. `d` sends grad to `c` and `a`.
    2. `c` sends grad to `a` and `b`.
    
    `a.grad` MUST use `+=` to correctly capture 
    the total derivative across both branches.
  '|
}

key_insight.near: bottom-center