direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Layer as Neuron Collection
  **Same inputs, independent weights, parallel outputs**
| {near: top-center}
row_inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  inputs: {
    direction: down
    label: "Input Vector (shared)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    x1: {
      shape: sql_table
      label: "x₁"
      val: "float | Input feature 1"
    }
    x2: {
      shape: sql_table
      label: "x₂"
      val: "float | Input feature 2"
    }
  }
}
row_neurons: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  neuron_0: {
    direction: down
    label: "Neuron 0"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    weights_0: {
      shape: sql_table
      label: "Weights (unique)"
      w0_0: "w₀₀ | float | weight for x₁"
      w0_1: "w₀₁ | float | weight for x₂"
      b0: "b₀ | float | bias"
      total: "3 params"
    }
    compute_0: {
      label: "Computation"
      width: 280
      code: |'python
        # Neuron 0: unique weights
        act = b₀ + w₀₀*x₁ + w₀₁*x₂
        y₀ = tanh(act)
      '|
    }
    out_0: {
      shape: circle
      label: "y₀"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    weights_0 -> compute_0
    compute_0 -> out_0
  }
  neuron_1: {
    direction: down
    label: "Neuron 1"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    weights_1: {
      shape: sql_table
      label: "Weights (unique)"
      w1_0: "w₁₀ | float | weight for x₁"
      w1_1: "w₁₁ | float | weight for x₂"
      b1: "b₁ | float | bias"
      total: "3 params"
    }
    compute_1: {
      label: "Computation"
      width: 280
      code: |'python
        # Neuron 1: unique weights
        act = b₁ + w₁₀*x₁ + w₁₁*x₂
        y₁ = tanh(act)
      '|
    }
    out_1: {
      shape: circle
      label: "y₁"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    weights_1 -> compute_1
    compute_1 -> out_1
  }
  neuron_2: {
    direction: down
    label: "Neuron 2"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    weights_2: {
      shape: sql_table
      label: "Weights (unique)"
      w2_0: "w₂₀ | float | weight for x₁"
      w2_1: "w₂₁ | float | weight for x₂"
      b2: "b₂ | float | bias"
      total: "3 params"
    }
    compute_2: {
      label: "Computation"
      width: 280
      code: |'python
        # Neuron 2: unique weights
        act = b₂ + w₂₀*x₁ + w₂₁*x₂
        y₂ = tanh(act)
      '|
    }
    out_2: {
      shape: circle
      label: "y₂"
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
    }
    weights_2 -> compute_2
    compute_2 -> out_2
  }
}
row_output: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  outputs: {
    direction: down
    label: "Output Vector"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    y_vec: {
      shape: sql_table
      label: "Layer Output"
      y0: "y₀ | float | Neuron 0 output"
      y1: "y₁ | float | Neuron 1 output"
      y2: "y₂ | float | Neuron 2 output"
      dim: "Shape: [3]"
    }
  }
}
layer_container: {
  label: "Layer(nin=2, nout=3)"
  style.stroke: "#FF9800"
  style.stroke-dash: 5
  style.fill: transparent
}
inputs -> neuron_0: "x₁, x₂ | broadcast"
inputs -> neuron_1: "x₁, x₂ | broadcast"
inputs -> neuron_2: "x₁, x₂ | broadcast"
neuron_0 -> outputs: "y₀"
neuron_1 -> outputs: "y₁"
neuron_2 -> outputs: "y₂"
legend: {
  near: bottom-right
  label: "Parameter Sharing"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  shared: {
    label: "✓ Shared"
    style.fill: "#E8F4FD"
  }
  unique: {
    label: "✗ Unique per neuron"
    style.fill: "#FFF3E0"
  }
  note: |md
    - **Inputs**: Same `[x₁, x₂]` fed to all neurons
    - **Weights**: Each neuron has its own `[wᵢ₀, wᵢ₁, bᵢ]`
    - **Total params**: 3 neurons × 3 params = **9**
  |
}
summary: {
  near: bottom-left
  label: "Layer Class (Python)"
  width: 400
  code: |'python
    class Layer:
        def __init__(self, nin, nout, activation='tanh'):
            # nout independent neurons, each with nin inputs
            self.neurons = [Neuron(nin, activation) 
                           for _ in range(nout)]
        def __call__(self, x):
            # All neurons receive SAME input x
            return [n(x) for n in self.neurons]
        def parameters(self):
            # Collect weights from all neurons
            params = []
            for n in self.neurons:
                params.extend(n.parameters())
            return params  # 9 params for Layer(2, 3)
  '|
}