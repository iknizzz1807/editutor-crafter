direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  shape: text
  label: "Learning Rate Impact on Training"
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

row_container: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  too_high: "LR Too High (η = 1.0)" {
    direction: down
    style.fill: "#FFE4E1"
    style.stroke: "#DC143C"
    style.stroke-width: 2

    chart: {
      shape: code
      width: 280
      label: |'md
Loss
│   ╱╲  ╱╲
│  ╱  ╲╱  ╲   ← Oscillating
│ ╱       ╲╱╲
│╱          ╲╱ ← Diverging!
└─────────────→ Epoch
      '|
    }

    code_logic: {
      label: "Update: w -= 1.0 × grad"
      width: 260
      code: |'python
# Epoch 0: loss = 0.5
# Epoch 1: loss = 2.3  ← overshoot
# Epoch 2: loss = 15.7 ← explode!
# Epoch 3: loss = ∞
      '|
    }

    verdict: "VERDICT: Diverges" {
      style: {
        fill: "#DC143C"
        font-color: white
        bold: true
      }
    }
  }

  optimal: "LR Optimal (η = 0.1)" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 3

    chart: {
      shape: code
      width: 280
      label: |'md
Loss
│╲
│ ╲___
│     ╲___      ← Smooth descent
│         ────
│             ─ ← Converged!
└─────────────→ Epoch
      '|
    }

    code_logic: {
      label: "Update: w -= 0.1 × grad"
      width: 260
      code: |'python
# Epoch 0:   loss = 0.5
# Epoch 100: loss = 0.1
# Epoch 500: loss = 0.01
# Epoch 1000: loss ≈ 0  ✓
      '|
    }

    verdict: "VERDICT: Converges" {
      style: {
        fill: "#2E7D32"
        font-color: white
        bold: true
      }
    }
  }

  too_low: "LR Too Low (η = 0.0001)" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#FF8F00"
    style.stroke-width: 2

    chart: {
      shape: code
      width: 280
      label: |'md
Loss
│╲
│ ╲
│  ╲_________
│            ______ ← Barely
│                  ______ moving
└─────────────→ Epoch
      '|
    }

    code_logic: {
      label: "Update: w -= 0.0001 × grad"
      width: 260
      code: |'python
# Epoch 0:    loss = 0.5
# Epoch 100:  loss = 0.499
# Epoch 1000: loss = 0.49
# Epoch 1M:   loss = 0.1  ✗
      '|
    }

    verdict: "VERDICT: Too Slow" {
      style: {
        fill: "#FF8F00"
        font-color: white
        bold: true
      }
    }
  }
}

goldilocks: "The Goldilocks Principle" {
  width: 900
  direction: down
  
  comparison_table: {
    shape: code
    width: 880
    label: |'md
| Scenario | Learning Rate | Behavior | Symptom |
|----------|---------------|----------|---------|
| Too High | η > 0.5 | Overshoots minimum, gradient explosion | Loss spikes → ∞ |
| **Optimal** | **0.01 < η < 0.5** | **Steady descent to minimum** | **Loss decreases smoothly** |
| Too Low | η < 0.001 | Tiny steps, excruciatingly slow | Loss barely moves |
    '|
  }

  rule_note: {
    shape: text
    label: "Rule of Thumb: Start with η = 0.1. If loss explodes, try 0.01. If loss barely decreases, try 0.5."
    style: {
      font-size: 16
      italic: true
    }
  }
}

too_high.chart -> optimal.chart: "Increase η" {
  style.stroke-dash: 3
  style.stroke: gray
}

optimal.chart -> too_low.chart: "Decrease η" {
  style.stroke-dash: 3
  style.stroke: gray
}