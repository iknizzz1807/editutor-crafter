direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Loss Landscape: Where Optimization Lives
  The loss surface is a high-dimensional terrain. Gradient descent is a ball rolling downhill.
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  param_space: {
    direction: down
    label: "Parameter Space (θ)"
    axis_w: {
      label: "w (weight)"
      shape: rectangle
      width: 280
      height: 30
      style.fill: "#E8E8E8"
      style.stroke: "#999"
    }
    axis_b: {
      label: "b (bias)"
      shape: rectangle
      width: 30
      height: 180
      style.fill: "#E8E8E8"
      style.stroke: "#999"
    }
  }
  loss_surface: {
    direction: down
    label: "Loss Surface L(θ)"
    width: 500
    contour: {
      shape: rectangle
      label: |svg
        <svg viewBox="0 0 300 200" xmlns="http://www.w3.org/2000/svg">
          <!-- Contour lines representing loss levels -->
          <ellipse cx="80" cy="70" rx="25" ry="18" fill="none" stroke="#c0392b" stroke-width="2"/>
          <ellipse cx="80" cy="70" rx="45" ry="32" fill="none" stroke="#e74c3c" stroke-width="1.5"/>
          <ellipse cx="80" cy="70" rx="70" ry="50" fill="none" stroke="#f39c12" stroke-width="1.5"/>
          <ellipse cx="80" cy="70" rx="100" ry="70" fill="none" stroke="#f1c40f" stroke-width="1.2"/>
          <!-- Global minimum -->
          <circle cx="80" cy="70" r="6" fill="#27ae60"/>
          <text x="80" y="55" text-anchor="middle" font-size="10" fill="#27ae60" font-weight="bold">Global Min</text>
          <!-- Local minimum -->
          <ellipse cx="200" cy="120" rx="15" ry="12" fill="none" stroke="#e67e22" stroke-width="2"/>
          <circle cx="200" cy="120" r="4" fill="#e67e22"/>
          <text x="200" y="105" text-anchor="middle" font-size="9" fill="#e67e22">Local Min</text>
          <!-- Saddle point -->
          <circle cx="140" cy="150" r="4" fill="#9b59b6"/>
          <text x="140" y="165" text-anchor="middle" font-size="9" fill="#9b59b6">Saddle</text>
          <!-- SGD path -->
          <path d="M 250 40 Q 220 60 180 80 Q 140 95 100 90 Q 85 85 80 70" 
                fill="none" stroke="#3498db" stroke-width="2.5" stroke-dasharray="5,3"/>
          <circle cx="250" cy="40" r="5" fill="#3498db"/>
          <text x="255" y="35" font-size="9" fill="#3498db">Start (init)</text>
          <circle cx="80" cy="70" r="5" fill="#3498db" stroke="#2980b9" stroke-width="2"/>
          <!-- Gradient arrows -->
          <defs>
            <marker id="arrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
              <path d="M0,0 L0,6 L9,3 z" fill="#e74c3c"/>
            </marker>
          </defs>
          <line x1="180" y1="80" x2="120" y2="75" stroke="#e74c3c" stroke-width="1.5" marker-end="url(#arrow)"/>
          <line x1="120" y1="100" x2="90" y2="75" stroke="#e74c3c" stroke-width="1.5" marker-end="url(#arrow)"/>
          <!-- Bad init path -->
          <path d="M 220 160 Q 210 140 200 120" 
                fill="none" stroke="#95a5a6" stroke-width="1.5" stroke-dasharray="3,2"/>
          <text x="235" y="155" font-size="8" fill="#95a5a6">Bad init</text>
        </svg>
      |
      width: 320
      height: 220
      style.fill: "#FAFAFA"
      style.stroke: "#DDD"
    }
    legend: {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent
      global_min: {
        label: "● Global Minimum"
        shape: rectangle
        width: 120
        style.fill: transparent
        style.font-color: "#27ae60"
      }
      local_min: {
        label: "● Local Minimum"
        shape: rectangle
        width: 120
        style.fill: transparent
        style.font-color: "#e67e22"
      }
      sgd_path: {
        label: "- - SGD Path"
        shape: rectangle
        width: 100
        style.fill: transparent
        style.font-color: "#3498db"
      }
      gradient: {
        label: "→ Gradient"
        shape: rectangle
        width: 90
        style.fill: transparent
        style.font-color: "#e74c3c"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  update_rule: {
    direction: down
    label: "SGD Update Rule"
    formula: {
      label: |md
        
        θ_new = θ_old - η · ∇L(θ)
        
        - **θ**: Parameters (weights, biases)
        - **η**: Learning rate (step size)
        - **∇L**: Gradient (points uphill)
        - **Minus**: We go *opposite* to gradient
      |
      shape: rectangle
      width: 280
      style.fill: "#EBF5FB"
      style.stroke: "#3498db"
      style.border-radius: 8
    }
  }
  landscape_features: {
    direction: down
    label: "Landscape Features"
    features: {
      shape: sql_table
      label: "Feature (terrain.h)"
      f0: "0x00 | Global Min | Lowest loss point"
      f1: "0x01 | Local Min  | Trapped valley"
      f2: "0x02 | Saddle     | Flat ridge (slow)"
      f3: "0x03 | Plateau    | Near-zero gradient"
      f4: "0x04 | Cliff      | Exploding gradient"
      sz: "Total: 5 terrain types"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  init_matters: {
    direction: down
    label: "Why Initialization Matters"
    init_scenarios: {
      direction: right
      good_init: {
        label: "Good Init"
        width: 140
        style.fill: "#D5F5E3"
        style.stroke: "#27ae60"
        good_code: |'python
# Random, small values
w = np.random.randn(n) * 0.01
b = np.zeros(n)
# → Near activation center
# → Gradients flow well
        '|
      }
      bad_init: {
        label: "Bad Init"
        width: 140
        style.fill: "#FADBD8"
        style.stroke: "#e74c3c"
        bad_code: |'python
# All zeros
w = np.zeros(n)
b = np.zeros(n)
# → Same gradients everywhere
# → No symmetry breaking
        '|
      }
      large_init: {
        label: "Too Large"
        width: 140
        style.fill: "#FCF3CF"
        style.stroke: "#f39c12"
        large_code: |'python
# Huge values
w = np.random.randn(n) * 100
b = np.random.randn(n) * 100
# → Tanh saturation
# → Gradients ≈ 0
        '|
      }
    }
  }
  learning_rate_effect: {
    direction: down
    label: "Learning Rate η"
    lr_cases: {
      direction: right
      lr_low: {
        label: "η = 0.001 (Too Low)"
        shape: rectangle
        width: 130
        style.fill: "#FDEBD0"
        lr_low_desc: |md
          - Crawling downhill
          - 10,000+ epochs needed
          - May never reach minimum
        |
      }
      lr_good: {
        label: "η = 0.1 (Good)"
        shape: rectangle
        width: 130
        style.fill: "#D5F5E3"
        lr_good_desc: |md
          - Steady descent
          - Smooth convergence
          - Reaches minimum
        |
      }
      lr_high: {
        label: "η = 10.0 (Too High)"
        shape: rectangle
        width: 130
        style.fill: "#FADBD8"
        lr_high_desc: |md
          - Jumps past minimum
          - Oscillates wildly
          - Loss explodes!
        |
      }
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step_trace: {
    direction: down
    label: "Single SGD Step (optimizer.c)"
    width: 420
    step_flow: {
      direction: right
      s1: {
        label: "1. Compute Loss"
        shape: rectangle
        width: 100
        style.fill: "#EBF5FB"
        s1_code: |'c
          L = mse(pred, target)
          // L is a Value*
        '|
      }
      s2: {
        label: "2. Backward"
        shape: rectangle
        width: 100
        style.fill: "#F5EEF8"
        s2_code: |'c
          L->backward();
          // Fills all p->grad
        '|
      }
      s3: {
        label: "3. Update"
        shape: rectangle
        width: 100
        style.fill: "#E8F8F5"
        s3_code: |'c
          p->data -= lr * p->grad;
          // Mutate in-place
        '|
      }
      s4: {
        label: "4. Zero Grad"
        shape: rectangle
        width: 100
        style.fill: "#FDEDEC"
        s4_code: |'c
          p->grad = 0.0;
          // Prevent accumulation
        '|
      }
    }
    s1 -> s2: "∂L/∂θ"
    s2 -> s3: "gradients ready"
    s3 -> s4: "params updated"
    s4 -> s1: "next epoch" {
      style.stroke-dash: 4
      style.animated: true
    }
  }
  gradient_direction: {
    direction: down
    label: "Gradient Points Uphill"
    grad_box: {
      shape: rectangle
      width: 260
      style.fill: "#F9EBEA"
      style.stroke: "#c0392b"
      grad_content: |md
        **∇L** = [∂L/∂w₁, ∂L/∂w₂, ..., ∂L/∂b]
        Points in direction of **steepest ascent**.
        To **decrease** loss, move **opposite**:
        
        θ_new = θ - η·∇L
        
        The "minus" is critical!
      |
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_layout: {
    direction: down
    label: "Loss Surface in Memory"
    value_struct: {
      shape: sql_table
      label: "struct Value (autograd.h)"
      f0: "0x00 | float     | data    // Current value"
      f1: "0x04 | float     | grad    // ∂L/∂self"
      f2: "0x08 | Value**   | _prev   // Children"
      f3: "0x10 | void(*)() | _backward"
      f4: "0x18 | char*     | _op     // '+', '*', 'tanh'"
      sz: "Total: 32 bytes per node"
    }
    note: {
      label: "Each parameter is a Value*.\nGradients accumulate in .grad field.\nUpdate mutates .data directly."
      shape: rectangle
      width: 300
      style.fill: "#F4F6F7"
      style.stroke: "#999"
    }
  }
  convergence_signals: {
    direction: down
    label: "Convergence Diagnostics"
    signals: {
      shape: sql_table
      label: "Loss Curve Patterns (train.c)"
      s0: "Steady ↓      | Learning well"
      s1: "Flat early    | η too low"
      s2: "Spikes/oscill | η too high"
      s3: "Plateau       | Local min or saturated"
      s4: "→ ∞ or NaN    | Divergence! Reduce η"
      sz: "Monitor loss every 100 epochs"
    }
  }
}
init_matters -> loss_surface: "Start position\naffects outcome" {
  style.stroke: "#27ae60"
  style.stroke-dash: 3
}
learning_rate_effect -> loss_surface: "Step size\naffects trajectory" {
  style.stroke: "#3498db"
  style.stroke-dash: 3
}