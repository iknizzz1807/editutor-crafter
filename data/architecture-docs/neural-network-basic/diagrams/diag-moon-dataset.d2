direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  node_base: {
    shape: circle
    width: 25
    height: 25
    style: {
      stroke-width: 2
    }
  }
  input_neuron: {
    shape: circle
    width: 25
    height: 25
    style: {
      stroke-width: 2
      fill: "#d5e8d4"
      stroke: "#82b366"
    }
  }
  hidden_neuron: {
    shape: circle
    width: 25
    height: 25
    style: {
      stroke-width: 2
      fill: "#e1d5e7"
      stroke: "#9673a6"
    }
  }
  output_neuron: {
    shape: circle
    width: 25
    height: 25
    style: {
      stroke-width: 2
      fill: "#fff2cc"
      stroke: "#d6b656"
    }
  }
  c0_point: {
    shape: circle
    width: 14
    style: {
      fill: "#3498db"
      stroke: "#2980b9"
      opacity: 0.8
    }
  }
  c1_point: {
    shape: circle
    width: 14
    style: {
      fill: "#e67e22"
      stroke: "#d35400"
      opacity: 0.8
    }
  }
}

header_section: {
  style.stroke: transparent
  style.fill: transparent
  title: |md
    # Moon Dataset Classification
    *Non-linearly separable binary classification learned by 2-layer MLP*
  |
}

row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scatter_grid: {
    label: "Feature Space (2D Scatter Distribution)"
    
    class_0_cluster: {
      label: "Class 0 Cluster (Inner Moon)"
      p1_0.class: c0_point
      p2_0.class: c0_point
      p3_0.class: c0_point
      p4_0.class: c0_point
      p5_0.class: c0_point
    }
    
    class_1_cluster: {
      label: "Class 1 Cluster (Outer Moon)"
      p1_1.class: c1_point
      p2_1.class: c1_point
      p3_1.class: c1_point
      p4_1.class: c1_point
      p5_1.class: c1_point
    }

    boundary: {
      label: "Learned Decision Boundary"
      style: {
        fill: transparent
        stroke: "#2c3e50"
        stroke-dash: 4
        stroke-width: 3
      }
    }
    
    axes: {
      x_axis: "Feature x1 (Radius)"
      y_axis: "Feature x2 (Angle)"
    }
  }

  network_panel: {
    direction: down
    label: "MLP Architecture (Feedforward)"
    
    layer_in: {
      shape: class
      label: "Input Layer (x)"
      +x1: "float32 // feature 1"
      +x2: "float32 // feature 2"
    }
    
    layer_h1: {
      shape: class
      label: "Hidden Layer 1 (8 neurons)"
      -n1_h1: "tanh"
      -n2_h1: "tanh"
      -n3_h1: "tanh"
      -n8_h1: "tanh"
    }
    
    layer_h2: {
      shape: class
      label: "Hidden Layer 2 (8 neurons)"
      -n1_h2: "tanh"
      -n2_h2: "tanh"
      -n3_h2: "tanh"
      -n8_h2: "tanh"
    }
    
    layer_out: {
      shape: class
      label: "Output Layer (y_hat)"
      +logit: "float32"
      +predict(threshold): "binary"
    }

    layer_in -> layer_h1: "24 Params | Forward"
    layer_h1 -> layer_h2: "72 Params | Forward"
    layer_h2 -> layer_out: "9 Params | Forward"
    
    summary_box: {
      params_summary: |md
        **Total: 105 Parameters**
        Type: Fully Connected Dense
        Optimization: Adam (lr=0.01)
      |
    }
  }
}

row_coords: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  coords_table: {
    shape: sql_table
    label: "Memory Layout (Training Samples)"
    r0: "0x00 | float32 | x1 // 1.00"
    r1: "0x04 | float32 | x2 // 0.10"
    r2: "0x08 | int32   | y  // 0"
    r3: "0x0C | float32 | x1 // 0.71"
    r4: "0x10 | float32 | x2 // 0.71"
    r5: "0x14 | int32   | y  // 0"
    r_gap: "0x18 | void*   | skip // Stride 12"
    r50: "0x258 | float32 | x1 // 1.71"
    r51: "0x25C | float32 | x2 // 0.39"
    r52: "0x260 | int32   | y  // 1"
    sz: "Total: 1200 bytes (100 samples)"
  }

  formula_panel: {
    label: "Mathematical Logic"
    
    forward_pass: {
      label: "Inference Loop"
      width: 400
      code: |'python
        def forward(x):
          # x is [1, 2] tensor
          h1 = tanh(x @ W1 + b1)
          h2 = tanh(h1 @ W2 + b2)
          z = h2 @ W3 + b3
          return 1.0 / (1.0 + exp(-z))
      '|
    }
    
    decision_rule: {
      label: "Classification Rule"
      width: 400
      code: |'python
        # Predicted Class y_hat
        if sigmoid(logit) >= 0.5:
            return 1 # Moon B
        else:
            return 0 # Moon A
      '|
    }
  }
}

row_results: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  metrics: {
    shape: sql_table
    label: "Training Statistics"
    s1: "Epochs | 500"
    s2: "Batch Size | 16"
    s3: "Optimizer | Adam"
    s4: "Loss | MSE (0.0078)"
    s5: "Val Acc | 99.2%"
  }

  insight_box: {
    label: "Architectural Analysis"
    width: 500
    content: |md
      **Non-Linear Transformation**
      A linear perceptron fails on this manifold.
      
      1. **Layer 1**: Warps the 2D input space.
      2. **Layer 2**: Performs high-dimensional projection.
      
      **Universal Approximation**: tanh provides the curvature 
      needed to fit the interleaved boundary.
    |
  }
}

legend_box: {
  label: "Visualization Legend"
  direction: right
  c0: "Class 0 (Blue)" {
    style.fill: "#3498db"
    style.stroke: "#2980b9"
  }
  c1: "Class 1 (Orange)" {
    style.fill: "#e67e22"
    style.stroke: "#d35400"
  }
  db: "Decision Boundary" {
    style.stroke: "#2c3e50"
    style.stroke-dash: 4
  }
}
legend_box.near: bottom-right