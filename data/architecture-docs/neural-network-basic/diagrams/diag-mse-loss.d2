direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # MSE Loss Computation Structure
  **Mean Squared Error**: $L = \frac{1}{N}\sum_{i=1}^{N}(\hat{y}_i - y_i)^2$
|

row_inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  predictions_box: {
    label: "Predictions Vector (ŷ)"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    
    pred_0: {
      shape: sql_table
      label: "Node ŷ₀"
      0x00: "float32 | data // ŷ₀"
      0x04: "float32 | grad // ∂L/∂ŷ₀"
      sz: "Total: 8 bytes"
    }
    pred_1: {
      shape: sql_table
      label: "Node ŷ₁"
      0x00: "float32 | data // ŷ₁"
      0x04: "float32 | grad // ∂L/∂ŷ₁"
      sz: "Total: 8 bytes"
    }
  }

  targets_box: {
    label: "Targets Vector (y)"
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
    
    tgt_0: {
      shape: sql_table
      label: "Node y₀"
      0x00: "float32 | data // y₀"
      0x04: "float32 | grad // 0.0"
      sz: "Total: 8 bytes"
    }
    tgt_1: {
      shape: sql_table
      label: "Node y₁"
      0x00: "float32 | data // y₁"
      0x04: "float32 | grad // 0.0"
      sz: "Total: 8 bytes"
    }
  }
}

row_diff: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  diff_box: {
    label: "Step 1: Residuals (ŷᵢ - yᵢ)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    
    diff_0: {
      shape: class
      label: "SubOp_0"
      -inputs: "ŷ₀, y₀"
      -op: "SUB"
      -out: "0.42"
    }
    diff_1: {
      shape: class
      label: "SubOp_1"
      -inputs: "ŷ₁, y₁"
      -op: "SUB"
      -out: "-0.15"
    }
  }
}

row_squared: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  sq_box: {
    label: "Step 2: Squared Errors (residual²)"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    
    sq_0: {
      shape: class
      label: "PowOp_0"
      -input: "diff_0"
      -op: "SQUARE"
      -out: "0.1764"
    }
    sq_1: {
      shape: class
      label: "PowOp_1"
      -input: "diff_1"
      -op: "SQUARE"
      -out: "0.0225"
    }
  }
}

row_loss: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  loss_box: {
    label: "Step 3: Reduction (Mean)"
    style.fill: "#FFEBEE"
    
    mse_final: {
      shape: sql_table
      label: "MSE Loss Object"
      0x00: "float32 | scalar_loss"
      0x04: "float32 | grad_seed (1.0)"
      0x08: "uint32  | N_samples"
      op: "REDUCE_MEAN"
    }
  }
}

# Root-level positioning (Correcting 'near' violations)
legend_box: {
  label: "Backward Pass Implementation"
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  code: |'python
    def backward(loss, ŷ, y, N):
      upstream = loss.grad / N
      for i in range(N):
        # chain: 2 * (ŷ - y) * upstream
        ŷ[i].grad += 2 * (ŷ[i].data - y[i].data) * upstream
  '|
}
legend_box.near: bottom-right

formula_box: {
  label: "Numerical Properties"
  style.fill: "#E0F7FA"
  style.stroke: "#00BCD4"
  content: |md
    - Non-negative: $L \in [0, \infty)$
    - Convex: Global minimum exists
    - Sensitivity: High for outliers
  |
}
formula_box.near: bottom-left

input_context: {
  label: "N prediction-target pairs"
  style.stroke-dash: 3
}
input_context.near: top-right

reduction_context: {
  label: "Scalar Output Node"
  style.stroke: red
}
reduction_context.near: bottom-center

# Connections
row_inputs.predictions_box.pred_0 -> row_diff.diff_box.diff_0: "float32 | ŷ₀"
row_inputs.targets_box.tgt_0 -> row_diff.diff_box.diff_0: "float32 | y₀"
row_inputs.predictions_box.pred_1 -> row_diff.diff_box.diff_1: "float32 | ŷ₁"
row_inputs.targets_box.tgt_1 -> row_diff.diff_box.diff_1: "float32 | y₁"

row_diff.diff_box.diff_0 -> row_squared.sq_box.sq_0: "residual"
row_diff.diff_box.diff_1 -> row_squared.sq_box.sq_1: "residual"

row_squared.sq_box.sq_0 -> row_loss.loss_box.mse_final: "SE₀"
row_squared.sq_box.sq_1 -> row_loss.loss_box.mse_final: "SE₁"

# Backprop markers
row_loss.loss_box.mse_final -> row_squared.sq_box.sq_0: "1/N | grad" {style.stroke-dash: 4; style.stroke: red}
row_squared.sq_box.sq_0 -> row_diff.diff_box.diff_0: "2*diff | grad" {style.stroke-dash: 4; style.stroke: red}