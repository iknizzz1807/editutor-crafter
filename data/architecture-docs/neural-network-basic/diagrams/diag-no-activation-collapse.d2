direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Why Non-Linearity Matters {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: {
    direction: down
    label: "WITH ONLY LINEAR ACTIVATIONS"
    style.fill: "#2d1f1f"
    style.stroke: "#ff6b6b"
    style.stroke-width: 3
    network_linear: {
      direction: down
      label: "Network Architecture"
      style.fill: "#1a1a1a"
      style.stroke: "#ff6b6b"
      layer1_lin: {
        direction: right
        label: "Layer 1 (Linear)"
        style.fill: "#3d2a2a"
        w1: {
          shape: rectangle
          label: "W₁"
          style.fill: "#ff6b6b"
          style.font-color: white
          width: 50
        }
        x: {
          shape: rectangle
          label: "x"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
        b1: {
          shape: rectangle
          label: "+b₁"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
      }
      no_act1: {
        label: "❌ NO ACTIVATION"
        shape: text
        style.font-color: "#ff6b6b"
        style.bold: true
      }
      layer2_lin: {
        direction: right
        label: "Layer 2 (Linear)"
        style.fill: "#3d2a2a"
        w2: {
          shape: rectangle
          label: "W₂"
          style.fill: "#ff6b6b"
          style.font-color: white
          width: 50
        }
        h1: {
          shape: rectangle
          label: "h₁"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
        b2: {
          shape: rectangle
          label: "+b₂"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
      }
      no_act2: {
        label: "❌ NO ACTIVATION"
        shape: text
        style.font-color: "#ff6b6b"
        style.bold: true
      }
    }
    collapse_box: {
      label: "COLLAPSES TO"
      style.fill: "#2a1515"
      style.stroke: "#ff6b6b"
      style.stroke-dash: 3
      equation: |tex
        W_2(W_1x + b_1) + b_2 = \underline{W'x + b'}
      |
    }
    result_linear: {
      direction: down
      label: "Result: Single Linear Transform"
      style.fill: "#1a0a0a"
      style.stroke: "#ff6b6b"
      collapse_result: {
        direction: right
        style.fill: "#3d1a1a"
        wp: {
          shape: rectangle
          label: "W'"
          style.fill: "#ff6b6b"
          style.font-color: white
          width: 50
        }
        xp: {
          shape: rectangle
          label: "x"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
        bp: {
          shape: rectangle
          label: "+b'"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
      }
      single_layer: {
        label: "= 1 effective layer"
        shape: text
        style.font-color: "#ff6b6b"
        style.bold: true
      }
    }
    function_space_lin: {
      direction: down
      label: "Function Space Representable"
      style.fill: "#1a1a1a"
      style.stroke: "#ff6b6b"
      style.stroke-dash: 2
      space_desc_lin: {
        label: "Only straight lines"
        shape: text
        style.font-color: "#cccccc"
      }
      graph_lin: {
        direction: right
        label: ""
        style.fill: transparent
        style.stroke: "#333333"
        y_axis_lin: {
          label: "y"
          shape: text
          style.font-color: "#888888"
        }
        plot_area_lin: {
          label: ""
          style.fill: "#0d0d0d"
          style.stroke: "#333333"
          width: 150
          height: 100
          line_only: {
            label: "━━━ Only possibility"
            shape: text
            style.font-color: "#ff6b6b"
          }
        }
        x_axis_lin: {
          label: "x"
          shape: text
          style.font-color: "#888888"
        }
      }
    }
    problem_box: {
      direction: down
      label: "THE PROBLEM"
      style.fill: "#2a1515"
      style.stroke: "#ff6b6b"
      prob_text1: {
        label: "Adding more layers"
        shape: text
        style.font-color: "#ffaaaa"
      }
      prob_text2: {
        label: "does NOT increase"
        shape: text
        style.font-color: "#ffaaaa"
      }
      prob_text3: {
        label: "expressive power!"
        shape: text
        style.font-color: "#ffaaaa"
        style.bold: true
      }
      math_fact: {
        label: "100 layers = 1 layer"
        shape: rectangle
        style.fill: "#ff6b6b"
        style.font-color: white
        style.bold: true
      }
    }
  }
  arrow_col: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    width: 80
    vs_text: {
      label: "VS"
      shape: text
      style: {
        font-size: 28
        bold: true
        font-color: "#888888"
      }
    }
  }
  after: {
    direction: down
    label: "WITH NON-LINEAR ACTIVATIONS (tanh)"
    style.fill: "#1f2d1f"
    style.stroke: "#6bff6b"
    style.stroke-width: 3
    network_nonlin: {
      direction: down
      label: "Network Architecture"
      style.fill: "#1a1a1a"
      style.stroke: "#6bff6b"
      layer1_nl: {
        direction: right
        label: "Layer 1 (Linear)"
        style.fill: "#2a3d2a"
        w1_nl: {
          shape: rectangle
          label: "W₁"
          style.fill: "#6bff6b"
          style.font-color: black
          width: 50
        }
        x_nl: {
          shape: rectangle
          label: "x"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
        b1_nl: {
          shape: rectangle
          label: "+b₁"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
      }
      act1_box: {
        direction: right
        label: ""
        style.fill: transparent
        style.stroke: transparent
        act1: {
          shape: hexagon
          label: "tanh"
          style.fill: "#6bff6b"
          style.font-color: black
          style.bold: true
        }
        check1: {
          label: "✓"
          shape: text
          style.font-color: "#6bff6b"
          style.font-size: 24
          style.bold: true
        }
      }
      layer2_nl: {
        direction: right
        label: "Layer 2 (Linear)"
        style.fill: "#2a3d2a"
        w2_nl: {
          shape: rectangle
          label: "W₂"
          style.fill: "#6bff6b"
          style.font-color: black
          width: 50
        }
        h1_nl: {
          shape: rectangle
          label: "h₁"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
        b2_nl: {
          shape: rectangle
          label: "+b₂"
          style.fill: "#4a4a4a"
          style.font-color: white
          width: 40
        }
      }
      act2_box: {
        direction: right
        label: ""
        style.fill: transparent
        style.stroke: transparent
        act2: {
          shape: hexagon
          label: "tanh"
          style.fill: "#6bff6b"
          style.font-color: black
          style.bold: true
        }
        check2: {
          label: "✓"
          shape: text
          style.font-color: "#6bff6b"
          style.font-size: 24
          style.bold: true
        }
      }
    }
    no_collapse_box: {
      label: "CANNOT BE SIMPLIFIED"
      style.fill: "#152a15"
      style.stroke: "#6bff6b"
      style.stroke-dash: 3
      equation_nl: |tex
        W_2 \cdot \tanh(W_1 x + b_1) + b_2 \neq \text{simpler form}
      |
    }
    result_nonlin: {
      direction: down
      label: "Result: True Multi-Layer Transform"
      style.fill: "#0a1a0a"
      style.stroke: "#6bff6b"
      multi_result: {
        direction: right
        style.fill: "#1a3d1a"
        layer_eff1: {
          shape: rectangle
          label: "Layer 1\n+bend"
          style.fill: "#6bff6b"
          style.font-color: black
          width: 60
          height: 50
        }
        arrow_eff: {
          label: "→"
          shape: text
          style.font-color: "#6bff6b"
        }
        layer_eff2: {
          shape: rectangle
          label: "Layer 2\n+bend"
          style.fill: "#6bff6b"
          style.font-color: black
          width: 60
          height: 50
        }
      }
      multi_layer: {
        label: "= 2 independent transformations"
        shape: text
        style.font-color: "#6bff6b"
        style.bold: true
      }
    }
    function_space_nl: {
      direction: down
      label: "Function Space Representable"
      style.fill: "#1a1a1a"
      style.stroke: "#6bff6b"
      style.stroke-dash: 2
      space_desc_nl: {
        label: "Any continuous function!"
        shape: text
        style.font-color: "#cccccc"
      }
      graph_nl: {
        direction: right
        label: ""
        style.fill: transparent
        style.stroke: "#333333"
        y_axis_nl: {
          label: "y"
          shape: text
          style.font-color: "#888888"
        }
        plot_area_nl: {
          label: ""
          style.fill: "#0d0d0d"
          style.stroke: "#333333"
          width: 150
          height: 100
          curves: {
            label: "∿ ❬❭ ∿ Any curve!"
            shape: text
            style.font-color: "#6bff6b"
          }
        }
        x_axis_nl: {
          label: "x"
          shape: text
          style.font-color: "#888888"
        }
      }
    }
    benefit_box: {
      direction: down
      label: "THE BENEFIT"
      style.fill: "#152a15"
      style.stroke: "#6bff6b"
      ben_text1: {
        label: "Each layer adds a"
        shape: text
        style.font-color: "#aaffaa"
      }
      ben_text2: {
        label: "\"fold\" in function space"
        shape: text
        style.font-color: "#aaffaa"
      }
      ben_text3: {
        label: "= more expressive!"
        shape: text
        style.font-color: "#aaffaa"
        style.bold: true
      }
      math_benefit: {
        label: "More layers = More power"
        shape: rectangle
        style.fill: "#6bff6b"
        style.font-color: black
        style.bold: true
      }
    }
  }
}
explanation_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  intuition_box: {
    direction: down
    label: "INTUITION: The Paper Folding Model"
    style.fill: "#1a1a2e"
    style.stroke: "#8888ff"
    style.stroke-width: 2
    paper_row: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      paper1: {
        label: "Linear Only"
        style.fill: "#2a2a3e"
        flat_paper: {
          label: "📄📄📄"
          shape: text
          style.font-size: 24
        }
        flat_desc: {
          label: "Stack flat = still flat"
          shape: text
          style.font-color: "#aaaacc"
        }
      }
      paper2: {
        label: "With Activations"
        style.fill: "#2a2a3e"
        folded_paper: {
          label: "📄↗️📄↙️📄"
          shape: text
          style.font-size: 24
        }
        folded_desc: {
          label: "Each layer folds!"
          shape: text
          style.font-color: "#aaaacc"
        }
      }
    }
    result_fold: {
      label: "More folds → More complex 3D shapes → More complex functions"
      shape: text
      style.font-color: "#8888ff"
      style.bold: true
    }
  }
  math_summary: {
    direction: down
    label: "Mathematical Summary"
    style.fill: "#1a2a1a"
    style.stroke: "#88ff88"
    style.stroke-width: 2
    math_item1: {
      label: "Linear: f(g(x)) = ax + b (still linear)"
      shape: text
      style.font-color: "#aaffaa"
    }
    math_item2: {
      label: "Non-linear: f(σ(g(x))) ≠ any simpler form"
      shape: text
      style.font-color: "#aaffaa"
    }
    math_item3: {
      label: "Universal Approximation: MLP with non-linearity"
      shape: text
      style.font-color: "#aaffaa"
    }
    math_item4: {
      label: "  can approximate ANY continuous function"
      shape: text
      style.font-color: "#aaffaa"
      style.bold: true
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#1a1a1a"
  style.stroke: "#444444"
  leg1: {
    label: "W₁, W₂"
    shape: text
    style.font-color: "#888888"
  }
  leg2: {
    label: "= Weight matrices"
    shape: text
    style.font-color: "#666666"
  }
  leg3: {
    label: "b₁, b₂"
    shape: text
    style.font-color: "#888888"
  }
  leg4: {
    label: "= Bias vectors"
    shape: text
    style.font-color: "#666666"
  }
  leg5: {
    shape: hexagon
    label: "tanh"
    style.fill: "#6bff6b"
    style.font-color: black
  }
  leg6: {
    label: "= Non-linearity"
    shape: text
    style.font-color: "#666666"
  }
}