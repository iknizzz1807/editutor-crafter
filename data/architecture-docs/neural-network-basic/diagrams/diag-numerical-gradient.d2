direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Numerical Gradient Verification
  Central Difference Approximation for Autograd Debugging
| {near: top-center}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  formula_panel: {
    direction: down
    label: "Central Difference Formula"
    formula: |latex
      f'(x) \approx \frac{f(x+h) - f(x-h)}{2h}
    |
    components: {
      shape: sql_table
      label: "Formula Components (gradient_check.py)"
      f0: "h          | float   | step size (1e-5 default)"
      f1: "x          | float   | point of evaluation"
      f2: "f(x+h)     | float   | forward evaluation"
      f3: "f(x-h)     | float   | backward evaluation"
      f4: "2h         | float   | denominator (symmetric)"
      sz: "Output: df/dx at x"
    }
    error_order: {
      label: "Error Analysis"
      width: 320
      code: |'python
        # One-sided: [f(x+h) - f(x)] / h
        #   Error: O(h) ~ h
        # Centered (ours): [f(x+h) - f(x-h)] / 2h
        #   Error: O(h²) ~ h²
        # With h=1e-5:
        #   One-sided error ~ 1e-5
        #   Centered error  ~ 1e-10
        #   5 orders of magnitude better!
      '|
    }
  }
  geometry_panel: {
    direction: down
    label: "Geometric Interpretation"
    curve_visual: {
      label: "f(x) Curve with Secant Line"
      width: 380
      axes: {
        shape: class
        label: "Visualization Components"
        x_axis: "horizontal axis: x values"
        y_axis: "vertical axis: f(x) values"
        curve: "smooth function curve f(x)"
        point_x_minus_h: "point at (x-h, f(x-h))"
        point_x: "point at (x, f(x)) — tangent point"
        point_x_plus_h: "point at (x+h, f(x+h))"
        secant_line: "line through (x-h, f(x-h)) and (x+h, f(x+h))"
        tangent_line: "tangent at x (true derivative)"
      }
    }
    geometry_math: {
      label: "Geometric Meaning"
      width: 360
      code: |'python
        # The secant line slope approximates tangent:
        #
        #   slope = [f(x+h) - f(x-h)] / [(x+h) - (x-h)]
        #         = [f(x+h) - f(x-h)] / 2h
        #
        # As h -> 0, secant -> tangent
        #   lim(h->0) [f(x+h) - f(x-h)] / 2h = f'(x)
        #
        # Key insight: we use TWO points symmetrically
        # placed around x for better approximation
      '|
    }
  }
}
row_step_size: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  h_good: {
    direction: down
    label: "h = 1e-5 (Optimal)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    good_visual: {
      label: "Sweet Spot"
      width: 280
      code: |'python
        h = 1e-5  # Goldilocks zone
        # Why it works:
        # - Small enough: secant ≈ tangent
        # - Large enough: avoids float64 noise
        # - Error: O(1e-10) acceptable
        # For double precision (float64):
        #   machine epsilon ≈ 2.2e-16
        #   sqrt(epsilon) ≈ 1.5e-8
        #   h = 1e-5 >> epsilon ✓
        #   h = 1e-5 << typical scales ✓
      '|
    }
    good_curve: {
      shape: sql_table
      label: "Approximation Quality"
      f0: "h         | 1e-5"
      f1: "true f'(x)| 2.0000"
      f2: "approx    | 2.0001"
      f3: "error     | ~1e-4"
      f4: "status    | PASS ✓"
    }
  }
  h_large: {
    direction: down
    label: "h = 0.1 (Too Large)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    large_visual: {
      label: "Secant ≠ Tangent"
      width: 280
      code: |'python
        h = 0.1  # Too big!
        # Problem: secant line is far from tangent
        # The finite difference measures chord slope,
        # not instantaneous rate of change
        #
        # For f(x) = x² at x=3:
        #   true f'(3) = 6
        #   f(3.1) - f(2.9) / 0.2 = 6.01
        #   Error: 0.01 (large!)
        #
        # Curve is too curved at this scale
      '|
    }
    large_curve: {
      shape: sql_table
      label: "Approximation Quality"
      f0: "h         | 0.1"
      f1: "true f'(x)| 2.0000"
      f2: "approx    | 2.1500"
      f3: "error     | ~0.15"
      f4: "status    | POOR ✗"
    }
  }
  h_small: {
    direction: down
    label: "h = 1e-15 (Too Small)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    small_visual: {
      label: "Catastrophic Cancellation"
      width: 280
      code: |'python
        h = 1e-15  # Too small!
        # Problem: floating-point precision
        # float64 has ~16 significant digits
        #
        # x + h and x - h may be identical!
        #   x = 1.0
        #   x + 1e-15 = 1.000000000000001
        #   x - 1e-15 = 0.999999999999999
        #
        # But f(x+h) - f(x-h) loses precision
        # due to subtraction of nearly equal values
      '|
    }
    small_curve: {
      shape: sql_table
      label: "Approximation Quality"
      f0: "h         | 1e-15"
      f1: "true f'(x)| 2.0000"
      f2: "approx    | 0.0 or NaN"
      f3: "error     | 100%+"
      f4: "status    | FAIL ✗"
    }
  }
}
row_tolerance: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tolerance_check: {
    direction: down
    label: "Gradient Check Implementation"
    check_code: {
      label: "gradient_check.py"
      width: 420
      code: |'python
        def check_gradient(analytical_grad, numerical_grad, tol=1e-5):
            """
            Compare analytical vs numerical gradients.
            Returns True if they match within tolerance.
            """
            # Relative error formula (handles any scale):
            rel_error = abs(analytical_grad - numerical_grad) / \
                        (abs(numerical_grad) + 1e-8)
            if rel_error < tol:
                print(f"  ✓ PASS: rel_error = {rel_error:.2e}")
                return True
            else:
                print(f"  ✗ FAIL: analytical={analytical_grad:.6f}")
                print(f"          numerical={numerical_grad:.6f}")
                print(f"          rel_error={rel_error:.2e}")
                return False
      '|
    }
    tolerance_table: {
      shape: sql_table
      label: "Tolerance Guidelines (gradient_check.py)"
      f0: "tol       | 1e-4   | acceptable (rough check)"
      f1: "tol       | 1e-5   | good (default)"
      f2: "tol       | 1e-6   | strict (production)"
      f3: "tol       | 1e-7   | very strict (double precision limit)"
      f4: "rel_error | formula | |analytical - numerical| / (|numerical| + ε)"
    }
  }
  example_trace: {
    direction: down
    label: "Example: Checking Loss Gradient"
    trace_code: {
      label: "Verification Trace"
      width: 400
      code: |'python
        # Expression: L = (a * b + c) ** 2
        # At: a=2.0, b=3.0, c=4.0
        # Expected: dL/da = 60.0
        # Step 1: Analytical (autograd)
        a = Value(2.0)
        b = Value(3.0)
        c = Value(4.0)
        L = (a * b + c) ** 2
        L.backward()
        analytical = a.grad  # Should be 60.0
        # Step 2: Numerical (finite diff)
        h = 1e-5
        f_plus = ((2.0 + h) * 3.0 + 4.0) ** 2   # 100.60
        f_minus = ((2.0 - h) * 3.0 + 4.0) ** 2  # 99.40
        numerical = (f_plus - f_minus) / (2 * h)  # 60.0
        # Step 3: Compare
        check_gradient(analytical, numerical)
        # Output: ✓ PASS: rel_error = 1.23e-10
      '|
    }
  }
}
row_workflow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  workflow: {
    direction: down
    label: "Debugging Workflow"
    workflow_steps: {
      shape: class
      label: "When Gradients Look Wrong"
      step1: "1. Isolate: create minimal reproducible expression"
      step2: "2. Compute: analytical gradient via backward()"
      step3: "3. Verify: numerical gradient with h=1e-5"
      step4: "4. Compare: use relative error formula"
      step5: "5. Debug: if mismatch, check _backward() implementation"
    }
    common_bugs: {
      label: "Common Gradient Bugs"
      width: 380
      code: |'python
        # Bug 1: Using grad instead of data
        # WRONG: self.grad += other.grad * out.grad
        # RIGHT: self.grad += other.data * out.grad
        # Bug 2: Wrong sign in derivative
        # d(x^-1)/dx = -x^-2 (negative!)
        # Bug 3: Missing accumulation (using = not +=)
        # Causes: multi-path gradients lost
        # Bug 4: Tanh numerical overflow
        # exp(2*x) overflows for |x| > ~350
        # Fix: use cached output t in _backward
      '|
    }
  }
  summary: {
    direction: down
    label: "Key Takeaways"
    summary_box: {
      shape: sql_table
      label: "Numerical Gradient Checklist"
      f0: "✓ Use centered difference [f(x+h)-f(x-h)]/2h"
      f1: "✓ Set h = 1e-5 for float64 (1e-3 for float32)"
      f2: "✓ Compare with relative error, tolerance 1e-5"
      f3: "✓ Test at multiple random points"
      f4: "✓ Check each input independently"
      f5: "✗ Never use h < 1e-10 (precision loss)"
      f6: "✗ Never use h > 0.01 (approximation error)"
    }
  }
}
legend: {
  near: bottom-right
  label: "Color Legend"
  style.fill: "#F5F5F5"
  green: {
    label: "Correct Range"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  red: {
    label: "Problematic Range"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
}