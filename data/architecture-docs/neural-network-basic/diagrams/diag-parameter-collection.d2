direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Recursive Parameter Collection
  `MLP.parameters()` → `Layer.parameters()` → `Neuron.parameters()` → `[w1, w2, ..., b]`
|
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mlp_box: {
    direction: down
    label: "MLP (mlp.py)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    mlp_class: {
      shape: class
      label: "class MLP"
      -layers: "List[Layer]"
      +__call__(x): "Value | List[Value]"
      +parameters(): "List[Value]"
    }
    mlp_code: {
      label: "parameters() implementation"
      width: 320
      code: |'python
        def parameters(self):
            params = []
            for layer in self.layers:
                params.extend(layer.parameters())
            return params
      '|
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_box: {
    direction: down
    label: "Layer (mlp.py)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    layer_class: {
      shape: class
      label: "class Layer"
      -neurons: "List[Neuron]"
      -activation: "str"
      +__call__(x): "Value | List[Value]"
      +parameters(): "List[Value]"
    }
    layer_code: {
      label: "parameters() implementation"
      width: 320
      code: |'python
        def parameters(self):
            params = []
            for neuron in self.neurons:
                params.extend(neuron.parameters())
            return params
      '|
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  neuron_box: {
    direction: down
    label: "Neuron (mlp.py)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    neuron_class: {
      shape: class
      label: "class Neuron"
      -w: "List[Value]"
      -b: "Value"
      -activation: "str"
      +__call__(x): "Value"
      +parameters(): "List[Value]"
    }
    neuron_code: {
      label: "parameters() implementation"
      width: 320
      code: |'python
        def parameters(self):
            return self.w + [self.b]
      '|
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  value_box: {
    direction: down
    label: "Value (value.py)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    value_struct: {
      shape: sql_table
      label: "Value objects (leaf nodes)"
      f0: "data | float"
      f1: "grad | float"
      f2: "_prev | Set[Value]"
      f3: "_backward | Callable"
      note: "Trainable parameters"
    }
  }
}

row1.mlp_box.mlp_code -> row2.layer_box.layer_code: "layer.parameters()" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}

row2.layer_box.layer_code -> row3.neuron_box.neuron_code: "neuron.parameters()" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}

row3.neuron_box.neuron_code -> row4.value_box.value_struct: "List[Value]" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}

legend: {
  near: bottom-right
  label: "Collection Flow"
  step1: {
    label: "1. MLP iterates layers"
    style.fill: "#E8F4FD"
  }
  step2: {
    label: "2. Layer iterates neurons"
    style.fill: "#FFF3E0"
  }
  step3: {
    label: "3. Neuron returns w + b"
    style.fill: "#E8F5E9"
  }
  step4: {
    label: "4. All lists flattened"
    style.fill: "#F3E5F5"
  }
}

example: {
  near: bottom-left
  label: "Example: MLP(3, [4, 1])"
  params: {
    shape: sql_table
    label: "Flattened Parameter List"
    l1: "Layer 1 | 4 neurons x (3w + 1b) | 16 params"
    l2: "Layer 2 | 1 neuron x (4w + 1b) | 5 params"
    total: "Total | 21 Value objects"
  }
}