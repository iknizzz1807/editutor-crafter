direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # MLP(3, [4, 4, 1]) Parameter Calculation
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer1: {
    direction: down
    label: "Layer 1 (Hidden)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    spec: {
      shape: sql_table
      label: "Layer 1 Specification"
      inputs: "Input neurons | 3"
      outputs: "Output neurons | 4"
      activation: "Activation | tanh"
    }
    calc1: {
      shape: sql_table
      label: "Parameter Calculation"
      weights: "Weights | 3 × 4 = 12"
      biases: "Biases | 4 × 1 = 4"
      total1: "Subtotal | 16"
    }
  }
  layer2: {
    direction: down
    label: "Layer 2 (Hidden)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    spec2: {
      shape: sql_table
      label: "Layer 2 Specification"
      inputs2: "Input neurons | 4"
      outputs2: "Output neurons | 4"
      activation2: "Activation | tanh"
    }
    calc2: {
      shape: sql_table
      label: "Parameter Calculation"
      weights2: "Weights | 4 × 4 = 16"
      biases2: "Biases | 4 × 1 = 4"
      total2: "Subtotal | 20"
    }
  }
  layer3: {
    direction: down
    label: "Layer 3 (Output)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    spec3: {
      shape: sql_table
      label: "Layer 3 Specification"
      inputs3: "Input neurons | 4"
      outputs3: "Output neurons | 1"
      activation3: "Activation | linear"
    }
    calc3: {
      shape: sql_table
      label: "Parameter Calculation"
      weights3: "Weights | 4 × 1 = 4"
      biases3: "Biases | 1 × 1 = 1"
      total3: "Subtotal | 5"
    }
  }
}
row1.layer1 -> row1.layer2: "4 values"
row1.layer2 -> row1.layer3: "4 values"
formula_box: {
  label: "General Formula"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  formula: {
    label: |md
      **Per Layer:** `(n_in × n_out) + n_out`
      - `n_in × n_out` = weight matrix size
      - `n_out` = one bias per neuron
    |
  }
}
summary: {
  shape: sql_table
  label: "Total Parameter Count"
  l1: "Layer 1 | 16"
  l2: "Layer 2 | 20"
  l3: "Layer 3 | 5"
  total: "TOTAL | 41"
  total.style.fill: "#C8E6C9"
  total.style.bold: true
}
formula_box.near: top-right
summary.near: bottom-center