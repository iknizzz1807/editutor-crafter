title: |md
  # micrograd vs PyTorch: Conceptual Equivalence
  The same neural network principles, expressed in two implementations
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  micrograd: {
    direction: down
    label: "micrograd (Your Implementation)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    value_class: {
      label: "Value Class (scalar autograd)"
      width: 380
      code: |'python
        class Value:
          def __init__(self, data, _children=(), _op=''):
            self.data = data        # scalar float
            self.grad = 0.0         # d(output)/d(self)
            self._backward = lambda: None
            self._prev = set(_children)
            self._op = _op
          def __add__(self, other):
            other = other if isinstance(other, Value) else Value(other)
            out = Value(self.data + other.data, (self, other), '+')
            def _backward():
              self.grad += out.grad
              other.grad += out.grad
            out._backward = _backward
            return out
      '|
    }
    neuron_class: {
      label: "Neuron Class"
      width: 380
      code: |'python
        class Neuron:
          def __init__(self, nin, activation='tanh'):
            self.w = [Value(random.uniform(-1, 1)) 
                      for _ in range(nin)]
            self.b = Value(random.uniform(-1, 1))
          def __call__(self, x):
            act = self.b
            for wi, xi in zip(self.w, x):
              act = act + wi * xi
            return act.tanh()
          def parameters(self):
            return self.w + [self.b]
      '|
    }
    layer_class: {
      label: "Layer Class"
      width: 380
      code: |'python
        class Layer:
          def __init__(self, nin, nout, activation='tanh'):
            self.neurons = [Neuron(nin, activation) 
                           for _ in range(nout)]
          def __call__(self, x):
            out = [n(x) for n in self.neurons]
            return out[0] if len(out) == 1 else out
          def parameters(self):
            params = []
            for n in self.neurons:
              params.extend(n.parameters())
            return params
      '|
    }
    mlp_class: {
      label: "MLP Class"
      width: 380
      code: |'python
        class MLP:
          def __init__(self, nin, nouts):
            sz = [nin] + nouts
            self.layers = []
            for i in range(len(nouts)):
              act = 'tanh' if i < len(nouts)-1 else 'linear'
              self.layers.append(Layer(sz[i], sz[i+1], act))
          def __call__(self, x):
            for layer in self.layers:
              x = layer(x)
            return x
          def parameters(self):
            params = []
            for layer in self.layers:
              params.extend(layer.parameters())
            return params
      '|
    }
  }
  pytorch: {
    direction: down
    label: "PyTorch (Production Framework)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    tensor_class: {
      label: "torch.Tensor (vectorized autograd)"
      width: 380
      code: |'python
        import torch
        # Tensor with gradient tracking
        x = torch.tensor([1.0, 2.0, 3.0], 
                         requires_grad=True)
        # Operations build computational graph
        y = x.sum() + x[0] * x[1]
        # data attribute holds values
        print(x.data)   # tensor([1., 2., 3.])
        # grad attribute holds gradients
        y.backward()
        print(x.grad)   # tensor([2., 2., 1.])
      '|
    }
    linear_class: {
      label: "nn.Linear (built-in layer)"
      width: 380
      code: |'python
        import torch.nn as nn
        class NeuronAsLinear(nn.Module):
          def __init__(self, nin):
            super().__init__()
            # Linear: nin inputs -> 1 output
            self.linear = nn.Linear(nin, 1)
          def forward(self, x):
            # Weighted sum + bias, then tanh
            return torch.tanh(self.linear(x))
          def parameters(self):
            return list(self.linear.parameters())
            # weight: (1, nin), bias: (1,)
      '|
    }
    sequential: {
      label: "nn.Sequential (layer container)"
      width: 380
      code: |'python
        class LayerAsLinear(nn.Module):
          def __init__(self, nin, nout):
            super().__init__()
            # Linear: nin -> nout
            self.linear = nn.Linear(nin, nout)
          def forward(self, x):
            return torch.tanh(self.linear(x))
          def parameters(self):
            return list(self.linear.parameters())
            # weight: (nout, nin), bias: (nout,)
      '|
    }
    mlp_module: {
      label: "nn.Module (network container)"
      width: 380
      code: |'python
        class MLP(nn.Module):
          def __init__(self, nin, nouts):
            super().__init__()
            layers = []
            sz = [nin] + nouts
            for i in range(len(nouts)):
              act = nn.Tanh() if i < len(nouts)-1 else nn.Identity()
              layers.append(nn.Linear(sz[i], sz[i+1]))
              layers.append(act)
            self.net = nn.Sequential(*layers)
          def forward(self, x):
            return self.net(x)
          def parameters(self):
            return list(self.net.parameters())
      '|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mapping: {
    direction: down
    label: "Concept Mapping"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    width: 800
    table: {
      shape: sql_table
      label: "Direct Concept Equivalence"
      row1: "micrograd | PyTorch | Purpose"
      row2: "Value | torch.Tensor | Differentiable container"
      row3: "Value.data | tensor.data | Forward-pass value"
      row4: "Value.grad | tensor.grad | Backward-pass gradient"
      row5: "Value._prev | tensor.grad_fn | Graph connectivity"
      row6: "Value._backward | autograd.Function | Local derivative"
      row7: "Neuron | nn.Linear | Learnable transformation"
      row8: "Layer | [nn.Linear]* | Parallel transformations"
      row9: "MLP | nn.Sequential | Composed layers"
      row10: ".parameters() | .parameters() | All learnable params"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  micrograd_training: {
    direction: down
    label: "micrograd Training Loop"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 380
    code: |'python
      # Create network: 2 -> 4 -> 1
      net = MLP(2, [4, 1])
      # Training loop
      for epoch in range(1000):
        # 1. Forward pass
        preds = [net(x) for x in X]
        # 2. Compute loss
        loss = mse_loss(preds, Y)
        # 3. Zero gradients
        for p in net.parameters():
          p.grad = 0.0
        # 4. Backward pass
        loss.backward()
        # 5. Update parameters (SGD)
        for p in net.parameters():
          p.data -= 0.1 * p.grad
    '|
  }
  pytorch_training: {
    direction: down
    label: "PyTorch Training Loop"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    width: 380
    code: |'python
      # Create network: 2 -> 4 -> 1
      net = MLP(2, [4, 1])
      optimizer = torch.optim.SGD(net.parameters(), lr=0.1)
      criterion = nn.MSELoss()
      # Training loop
      for epoch in range(1000):
        # 1. Forward pass
        preds = net(X_tensor)
        # 2. Compute loss
        loss = criterion(preds, Y_tensor)
        # 3. Zero gradients
        optimizer.zero_grad()
        # 4. Backward pass
        loss.backward()
        # 5. Update parameters (SGD)
        optimizer.step()
    '|
  }
}
