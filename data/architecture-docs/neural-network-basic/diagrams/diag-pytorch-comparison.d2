      r3: "Operations | Python loops | C++/CUDA kernels"
      r4: "Parameters | ~100 | ~billions"
      r5: "Hardware | CPU | GPU/TPU clusters"
      r6: "Training time | Minutes | Days/weeks"
    }
  }
