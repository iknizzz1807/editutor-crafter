direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: ReLU Derivative Visualization {
  style: {
    font-size: 24
    bold: true
    underline: true
  }
  near: top-center
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  relu_forward: {
    label: "ReLU(x) = max(0, x)"
    width: 300
    header: {
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    pos_region: {
      label: "x > 0"
      formula: "ReLU(x) = x"
      example: "ReLU(3) = 3"
      style.fill: "#C8E6C9"
    }
    zero_point: {
      label: "x = 0"
      formula: "ReLU(0) = 0"
      style.fill: "#FFF9C4"
    }
    neg_region: {
      label: "x < 0"
      formula: "ReLU(x) = 0"
      example: "ReLU(-3) = 0"
      style.fill: "#FFCDD2"
    }
  }
  relu_backward: {
    label: "d(ReLU)/dx"
    width: 300
    header: {
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    pos_grad: {
      label: "x > 0"
      formula: "grad = 1"
      meaning: "Gradient FLOWS"
      style.fill: "#C8E6C9"
    }
    zero_grad: {
      label: "x = 0"
      formula: "grad = undefined"
      meaning: "Subgradient"
      style.fill: "#FFF9C4"
    }
    neg_grad: {
      label: "x < 0"
      formula: "grad = 0"
      meaning: "Gradient BLOCKED"
      style.fill: "#FFCDD2"
    }
  }
}
relu_forward -> relu_backward: "backward pass" {
  style: {
    stroke: "#2196F3"
    stroke-width: 2
    stroke-dash: 3
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  flow_positive: {
    label: "Gradient Flow: Positive Region"
    width: 280
    input_pos: {
      label: "Input: x = 3.0"
      style.fill: "#E8F5E9"
    }
    relu_pos: {
      label: "ReLU(3.0)"
      formula: "= max(0, 3.0)"
      result: "= 3.0"
      style.fill: "#A5D6A7"
    }
    grad_pos: {
      label: "Backward Pass"
      code: |'python
  # d(ReLU)/dx = 1 for x > 0
  x.grad += 1.0 * out.grad
  # Gradient flows through!
      '|
      style.fill: "#C8E6C9"
      width: 240
    }
    input_pos -> relu_pos -> grad_pos
  }
  flow_negative: {
    label: "Gradient Flow: Negative Region"
    width: 280
    input_neg: {
      label: "Input: x = -2.0"
      style.fill: "#FFEBEE"
    }
    relu_neg: {
      label: "ReLU(-2.0)"
      formula: "= max(0, -2.0)"
      result: "= 0.0"
      style.fill: "#EF9A9A"
    }
    grad_neg: {
      label: "Backward Pass"
      code: |'python
  # d(ReLU)/dx = 0 for x < 0
  x.grad += 0.0 * out.grad
  # Gradient blocked!
      '|
      style.fill: "#FFCDD2"
      width: 240
    }
    input_neg -> relu_neg -> grad_neg
  }
}
dead_neuron: {
  label: "Dead Neuron Problem"
  width: 600
  header: {
    label: "What is a Dead Neuron?"
    style: {
      fill: "#FFCDD2"
      stroke: "#E53935"
      bold: true
    }
  }
  explanation: {
    label: "Dead Neuron Condition"
    content: |md
A neuron becomes "dead" when:
- It always receives **negative pre-activation** values
- ReLU outputs **0** for all inputs
- Gradient is **always 0** → **no learning**
- Weight updates never occur
    |
    style.fill: "#FFF3E0"
    width: 280
  }
  causes: {
    label: "Common Causes"
    items: |md
1. **Bad initialization**: Weights start too negative
2. **High learning rate**: Large update pushes weights into negative regime
3. **Gradient explosion**: Previous updates were too aggressive
    |
    style.fill: "#FCE4EC"
    width: 280
  }
  prevention: {
    label: "Prevention Strategies"
    items: |md
1. **Leaky ReLU**: f(x) = max(0.01x, x)
2. **He initialization**: Scale weights by √(2/n)
3. **Lower learning rate**: Smaller updates
4. **Gradient clipping**: Cap gradient magnitude
    |
    style.fill: "#E8F5E9"
    width: 280
  }
  explanation -> causes -> prevention
}
row1 -> row2: "gradient flow examples"
row2 -> dead_neuron: "consequence"
legend: {
  near: bottom-center
  label: "Color Legend"
  green: {
    label: "Green: Gradient flows (learning occurs)"
    style.fill: "#C8E6C9"
  }
  red: {
    label: "Red: Gradient blocked (no learning)"
    style.fill: "#FFCDD2"
  }
  yellow: {
    label: "Yellow: Boundary case (undefined at x=0)"
    style.fill: "#FFF9C4"
  }
}