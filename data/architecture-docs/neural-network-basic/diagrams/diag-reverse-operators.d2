direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Reverse Operator Dispatch {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  case1: Case 1: `2 + Value(3)` {
    direction: down
    style.fill: "#FFF9E6"
    c1_step1: {
      label: "Step 1: Python evaluates left-to-right"
      width: 280
      code: |'python
        # Expression: 2 + Value(3)
        # Left operand: 2 (int)
        # Right operand: Value(3)
      '|
    }
    c1_step2: {
      label: "Step 2: Try int.__add__"
      width: 280
      code: |'python
        result = (2).__add__(Value(3))
        # int.__add__ doesn't know
        # how to add a Value!
        # Returns: NotImplemented
      '|
      style.fill: "#FFE6E6"
    }
    c1_step3: {
      label: "Step 3: Try reflected operation"
      width: 280
      code: |'python
        # Python fallback:
        # Try right operand's __radd__
        result = Value(3).__radd__(2)
      '|
      style.fill: "#E6FFE6"
    }
    c1_step4: {
      label: "Step 4: Value.__radd__ handles it"
      width: 280
      code: |'python
        def __radd__(self, other):
            # Delegate to __add__
            # (addition is commutative)
            return self + other
        # Returns: Value(5)
      '|
      style.fill: "#E6F3FF"
    }
    c1_step1 -> c1_step2: "evaluates"
    c1_step2 -> c1_step3: "NotImplemented"
    c1_step3 -> c1_step4: "calls"
  }
  case2: Case 2: `Value(3) + 2` {
    direction: down
    style.fill: "#E6FFE6"
    c2_step1: {
      label: "Step 1: Python evaluates left-to-right"
      width: 280
      code: |'python
        # Expression: Value(3) + 2
        # Left operand: Value(3)
        # Right operand: 2 (int)
      '|
    }
    c2_step2: {
      label: "Step 2: Try Value.__add__"
      width: 280
      code: |'python
        result = Value(3).__add__(2)
        # Value.__add__ handles
        # int by converting to Value
      '|
      style.fill: "#E6F3FF"
    }
    c2_step3: {
      label: "Step 3: Conversion inside __add__"
      width: 280
      code: |'python
        def __add__(self, other):
            # Convert int to Value
            other = other if isinstance(
                other, Value
            ) else Value(other)
            # Now: other = Value(2)
      '|
      style.fill: "#FFF0E6"
    }
    c2_step4: {
      label: "Step 4: Proceed with normal addition"
      width: 280
      code: |'python
        out = Value(
            self.data + other.data,
            (self, other), '+'
        )
        # Returns: Value(5)
      '|
      style.fill: "#E6F3FF"
    }
    c2_step1 -> c2_step2: "evaluates"
    c2_step2 -> c2_step3: "handles"
    c2_step3 -> c2_step4: "computes"
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  l1: "Direct path" {
    style.fill: "#E6FFE6"
    style.stroke: "#4CAF50"
  }
  l2: "Fallback path" {
    style.fill: "#FFE6E6"
    style.stroke: "#F44336"
  }
  l3: "Conversion step" {
    style.fill: "#FFF0E6"
    style.stroke: "#FF9800"
  }
  l4: "Success" {
    style.fill: "#E6F3FF"
    style.stroke: "#2196F3"
  }
}
dispatch_flow: Dispatch Flow Summary {
  direction: down
  width: 600
  flow_code: |'python
    # Python's operator dispatch rules:
    #
    # For expression: a + b
    #
    # 1. Try: type(a).__add__(a, b)
    #    - If returns NotImplemented, continue...
    #
    # 2. Try: type(b).__radd__(b, a)
    #    - If returns NotImplemented, raise TypeError
    #
    # Key insight: __radd__ is the "reflected" or "right" version
    # Called when left operand doesn't know how to handle right operand
  '|
}
implementation: Required Reflected Operators {
  direction: down
  width: 600
  impl_code: |'python
    class Value:
        # ... (other methods)
        def __radd__(self, other):
            """Called for: other + self"""
            return self + other  # Commutative, delegate
        def __rsub__(self, other):
            """Called for: other - self"""
            return (-self) + other  # Rewrite
        def __rmul__(self, other):
            """Called for: other * self"""
            return self * other  # Commutative, delegate
        def __rtruediv__(self, other):
            """Called for: other / self"""
            return other * self**(-1)  # Rewrite
  '|
}