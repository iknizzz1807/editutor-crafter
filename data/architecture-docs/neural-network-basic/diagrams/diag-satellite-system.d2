direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # micrograd System Architecture
  Scalar Autograd Engine — Implementation Blueprint
|
title.near: top-center

# ============================================
# ROW 1: Foundation - Milestone 1
# ============================================
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m1_container: {
    direction: down
    label: "MILESTONE 1: Value Class (engine.py)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    
    value_class: {
      shape: class
      label: "Value"
      +data: "float"
      +grad: "float"
      -_backward: "callable"
      -_prev: "set[Value]"
      -_op: "str"
      +__add__(other): "Value"
      +__mul__(other): "Value"
      +__pow__(n): "Value"
      +tanh(): "Value"
      +relu(): "Value"
    }
    
    m1_note: {
      label: "Core Responsibilities"
      width: 300
      text: |md
        • Wraps scalar float with gradient tracking
        • Operator overloading builds DAG
        • Stores `_backward` closure for local chain rule
      |
    }
  }
  
  graph_example: {
    direction: down
    label: "Computational Graph Example (DAG)"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    
    nodes: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      a: "a" { shape: circle; width: 50 }
      b: "b" { shape: circle; width: 50 }
      mul: "(*)" { shape: diamond; style.fill: "#FFE082" }
      c: "c = a*b" { shape: circle; width: 70 }
      
      a -> mul
      b -> mul
      mul -> c
    }
    
    note: "Each node = Value instance" {
      style.font-size: 12
    }
  }
}

# ============================================
# ROW 2: Backward Pass - Milestone 2
# ============================================
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m2_container: {
    direction: down
    label: "MILESTONE 2: Backward Pass"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    
    backward_logic: {
      shape: class
      label: "Autograd Controller"
      +build_topo(root): "list[Value]"
      +backward(root): "void"
      +apply_chain_rule(node): "void"
    }
    
    topo_process: {
      direction: right
      label: "Topological Sort"
      style.fill: "#BBDEFB"
      input: { shape: document; label: "Graph Root" }
      algo: { shape: hexagon; label: "DFS" }
      output: { shape: queue; label: "Linear Order" }
      
      input -> algo -> output
    }
  }
  
  chain_rule: {
    direction: down
    label: "Chain Rule Mechanics"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    
    formula: {
      label: "Gradient Accumulation"
      text: |md
        **Local Derivative:**
        `a.grad += (local_deriv) * (upstream_grad)`
      |
      width: 320
    }
    
    flow: {
      direction: right
      style.fill: transparent
      L: "Loss (grad=1.0)" { shape: circle; style.fill: "#E1BEE7" }
      C: "Node C" { shape: circle; style.fill: "#CE93D8" }
      A: "Node A" { shape: circle; style.fill: "#BA68C8" }
      
      L -> C: "Upstream"
      C -> A: "Local x Upstream"
    }
  }
}

# ============================================
# ROW 3: Neural Network Architecture - Milestone 3
# ============================================
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m3_container: {
    direction: down
    label: "MILESTONE 3: Neural Network (nn.py)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    
    neuron_class: {
      shape: class
      label: "Neuron"
      -w: "list[Value]"
      -b: "Value"
      +__call__(x): "Value"
      +parameters(): "list[Value]"
    }
    
    layer_class: {
      shape: class
      label: "Layer"
      -neurons: "list[Neuron]"
      +__call__(x): "list[Value]"
      +parameters(): "list[Value]"
    }
    
    mlp_class: {
      shape: class
      label: "MLP"
      -layers: "list[Layer]"
      +__call__(x): "Value"
      +parameters(): "list[Value]"
    }
  }
  
  visual_mlp: {
    direction: down
    label: "MLP Architecture"
    style.fill: "#FFECB3"
    
    network: {
      direction: right
      style.fill: transparent
      in: "Inputs" {
        i1: ""; i2: ""
        style.fill: "#FFE082"
      }
      h1: "Layer 1" {
        n1: ""; n2: ""; n3: ""
        style.fill: "#FFD54F"
      }
      out: "Output" {
        o1: "ŷ"
        style.fill: "#FFB74D"
      }
      
      in -> h1 -> out
    }
    params: "Total Params: sum(len(p.parameters()))" {
      style.font-size: 11
    }
  }
}

# ============================================
# ROW 4: Training Loop - Milestone 4
# ============================================
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  m4_container: {
    direction: down
    label: "MILESTONE 4: Training Loop"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    
    optimizer: {
      shape: class
      label: "SGD"
      -params: "list[Value]"
      -lr: "float"
      +zero_grad(): "void"
      +step(): "void"
    }
    
    loss_fn: {
      shape: class
      label: "MSE Loss"
      +calculate(y_pred, y_true): "Value"
    }
  }
  
  loop: {
    direction: down
    label: "Epoch Operations"
    style.fill: "#FFCDD2"
    
    s1: {
      label: "1. Forward"
      code: |'python
        ypred = [model(x) for x in X]
      '|
    }
    s2: {
      label: "2. Loss"
      code: |'python
        loss = sum((p-y)**2) / n
      '|
    }
    s3: {
      label: "3. Zero Grad"
      code: |'python
        model.zero_grad()
      '|
    }
    s4: {
      label: "4. Backward"
      code: |'python
        loss.backward()
      '|
    }
    s5: {
      label: "5. Update"
      code: |'python
        for p in params: p.data -= lr * p.grad
      '|
    }
    
    s1 -> s2 -> s3 -> s4 -> s5
    s5 -> s1: "Next Epoch" { style.stroke-dash: 3 }
  }
}

# ============================================
# SYSTEM COUPLING
# ============================================
row1.m1_container.value_class -> row2.m2_container.backward_logic: "Forms DAG for"
row1.m1_container.value_class -> row3.m3_container.neuron_class: "Used for w, b"
row2.m2_container.backward_logic -> row4.m4_container.loop.s4: "Triggers grad flow"
row3.m3_container.mlp_class -> row4.m4_container.optimizer: "Provides parameters"

legend: {
  label: "Legend"
  near: bottom-right
  items: {
    direction: down
    m1: "Foundation (Value)" { style.fill: "#E8F5E9" }
    m2: "Autograd Engine" { style.fill: "#E3F2FD" }
    m3: "Architecture (NN)" { style.fill: "#FFF3E0" }
    m4: "Optimization" { style.fill: "#FFEBEE" }
  }
}