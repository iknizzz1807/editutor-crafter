direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: "SGD Update Mechanics: p.data -= lr * p.grad"
  style: {
    font-size: 24
    bold: true
    fill: "#f8f9fa"
    stroke: "#dee2e6"
  }
}
title.near: top-center

row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  param_state: {
    label: "T0: Parameter State (Value.h)"
    param_value: {
      shape: sql_table
      label: "struct Value (p)"
      f0: "0x00 | double | data: 2.50 // current weight"
      f1: "0x08 | double | grad: 0.80 // ∂Loss/∂p"
      note: "Total size: 16 bytes"
    }
  }
  
  gradient_meaning: {
    label: "Gradient Interpretation"
    width: 380
    explanation: |'md
      **Gradient = 0.80** means:
      - If we **increase** $p$ by $\epsilon$, loss increases by $0.80 \times \epsilon$
      - If we **decrease** $p$ by $\epsilon$, loss decreases by $0.80 \times \epsilon$
      
      **Rule:** To reduce loss, move in the **negative** gradient direction.
    '|
  }
}

row_numberline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  axis_good: {
    label: "Optimization Path: Optimal lr=0.5"
    width: 700
    
    numberline_visual: {
      shape: rectangle
      width: 600
      height: 120
      style.fill: "#1a1a2e"
      style.stroke: "#4a4a6a"
      
      p_start: "p=2.50" {
        shape: circle
        width: 20
        style.fill: "#ff6b6b"
        label.near: outside-top-center
      }
      
      p_end: "p'=2.10" {
        shape: circle
        width: 20
        style.fill: "#4ecdc4"
        label.near: outside-top-center
      }
    }
    
    calc_good: |'md
      **Update calculation:**
      
      1. $step = lr \times p.grad$
      2. $step = 0.5 \times 0.80 = 0.40$
      3. $p' = p.data - step = 2.10$
      
      Result: **Smooth descent** towards local minimum.
    '|
  }
}

row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  lr_too_high: {
    label: "Path A: lr=5.0 (High)"
    width: 320
    axis_high: {
      shape: rectangle
      width: 280
      height: 60
      style.fill: "#2a1a1a"
      style.stroke: "#ff6b6b"
    }
    calc_high: |'md
      $p' = 2.50 - (5.0 \times 0.80)$
      $p' = 2.50 - 4.00 = -1.50$
      
      **Status:** ✗ OVERSHOT!
      Jumps across the valley.
    '|
    warning_high: {
      shape: callout
      label: "⚠️ Risk: Divergence"
      style.fill: "#ff6b6b"
      style.font-color: white
    }
  }
  
  lr_too_low: {
    label: "Path B: lr=0.01 (Low)"
    width: 320
    axis_low: {
      shape: rectangle
      width: 280
      height: 60
      style.fill: "#1a2a1a"
      style.stroke: "#ffd93d"
    }
    calc_low: |'md
      $p' = 2.50 - (0.01 \times 0.80)$
      $p' = 2.50 - 0.008 = 2.492$
      
      **Status:** 🐢 TOO SLOW
      Computationally expensive.
    '|
    warning_low: {
      shape: callout
      label: "⚠️ Risk: Stalling"
      style.fill: "#ffd93d"
      style.font-color: black
    }
  }
}

row_update_logic: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  formula_box: {
    label: "Engine Implementation (optimizer.py)"
    width: 450
    code: |'python
    def step(self):
        for p in self.params:
            if p.grad is None: continue
            # Mutate in-place to avoid 
            # building extra graph nodes
            p.data -= self.lr * p.grad
    '|
    table_desc: |'md
      | Symbol | Role | Implementation |
      | :--- | :--- | :--- |
      | `-=` | Step opposite to grad | In-place mutation |
      | `lr` | Learning Rate | Scalar hyperparam |
      | `p.grad` | Slope | Accumulated in `.backward()` |
    '|
  }
  
  memory_note: {
    label: "Memory Safety Detail"
    width: 300
    note: |'md
      **Why in-place `p.data -=`?**
      
      If we used `p = p - lr * grad`:
      1. Python creates a NEW object.
      2. Autograd tracks this subtraction.
      3. Graph grows infinitely.
      4. **Memory Leak (OOM)**.
      
      In-place keeps graph static.
    '|
  }
}

row_best_practice: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  recommendation: {
    label: "Hyperparameter Tuning Guide"
    width: 780
    guide: |'md
      ### Diagnostic Table
      | Observable Symptom | Root Cause | Action |
      | :--- | :--- | :--- |
      | Loss becomes `NaN` or `Inf` | LR too high (Exploding) | Reduce LR by factor of 10 |
      | Loss flatlines for 100 epochs | LR too low (Stalling) | Increase LR by factor of 2-5 |
      | Loss fluctuates up and down | LR near oscillation point | Add momentum or decay LR |
      | Loss decreases smoothly | **Just Right** | Maintain current settings |
    '|
  }
}

# Explicit connections using qualified paths
row_numberline.axis_good.numberline_visual.p_start -> row_numberline.axis_good.numberline_visual.p_end: "Update Step" {
  style.stroke: "#4ecdc4"
  style.stroke-width: 4
  style.animated: true
}

row_before -> row_numberline: "Inputs"
row_numberline -> row_comparison: "Evaluation"
row_comparison -> row_update_logic: "Code Implementation"
row_update_logic -> row_best_practice: "Operational Guide"