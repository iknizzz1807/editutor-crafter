direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_container: {
  style.stroke: transparent
  style.fill: transparent
  title: Tanh Derivative Derivation {
    shape: rectangle
    style: {
      font-size: 32
      bold: true
      underline: true
      stroke: transparent
      fill: transparent
    }
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  tanh_forward: {
    direction: down
    label: "Forward Pass: tanh(x)"
    
    tanh_curve: {
      shape: class
      label: "tanh(x) Curve Properties"
      output_range: "Output ∈ (-1, 1)"
      saturates_pos: "x → +∞ : tanh(x) → +1"
      saturates_neg: "x → -∞ : tanh(x) → -1"
      zero_crossing: "x = 0 : tanh(x) = 0"
    }
    
    formula_box: {
      label: "Mathematical Definition"
      width: 340
      formula: |'latex
        \tanh(x) = \frac{e^x - e^{-x}}{e^x + e^{-x}}
      '|
    }
    
    key_points: {
      shape: sql_table
      label: "Key Points (tanh)"
      p1: "x = -3 | tanh = -0.995"
      p2: "x = -1 | tanh = -0.762"
      p3: "x = 0  | tanh = 0.000"
      p4: "x = +1 | tanh = +0.762"
      sz: "Symmetric: tanh(-x) = -tanh(x)"
    }
  }

  tanh_derivative: {
    direction: down
    label: "Backward Pass: d/dx tanh(x)"
    
    derivative_curve: {
      shape: class
      label: "1 - tanh²(x) Curve Properties"
      max_value: "Maximum = 1 at x = 0"
      approaches_zero: "→ 0 as |x| → ∞"
      symmetric: "Even function: f(-x) = f(x)"
      range: "Derivative ∈ (0, 1]"
    }
    
    derivative_formula: {
      label: "The Beautiful Identity"
      width: 340
      formula: |'latex
        \frac{d}{dx}\tanh(x) = 1 - \tanh^2(x)
      '|
    }
    
    derivative_points: {
      shape: sql_table
      label: "Key Points (derivative)"
      d1: "x = -3 | d = 0.010"
      d2: "x = -1 | d = 0.420"
      d3: "x = 0  | d = 1.000"
      d4: "x = +1 | d = 0.420"
      sz: "Peak gradient at origin"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  insight_box: {
    label: "🔑 Key Insight: Derivative Depends on Output, Not Input"
    width: 720
    insight: |md
      The derivative formula uses **tanh(x)** — the **output value** — not x directly.
      This means during the backward pass, we only need the **cached forward output** `t`:
      
      d(tanh(x))/dx = 1 - t²    where t = tanh(x)
      
      We do NOT need to recompute tanh(x) from scratch!
    |
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  stability_comparison: {
    direction: down
    label: "Numerical Stability Comparison"
    
    wrong_approach: {
      shape: rectangle
      label: "❌ WRONG: Recompute in backward"
      style: {
        fill: "#FFB4AB"
        stroke: "#BA1A1A"
      }
      width: 320
      code_wrong: |"python
        def _backward():
            # Recomputes exp(2x)
            t = (exp(2*x)-1)/(exp(2*x)+1)
            # ^ Can overflow if x > 355
            self.grad += (1-t**2) * out.grad
      "|
    }
    
    correct_approach: {
      shape: rectangle
      label: "✅ CORRECT: Use cached output"
      style: {
        fill: "#BAF2B8"
        stroke: "#1A7317"
      }
      width: 320
      code_correct: |"python
        def _backward():
            # Uses cached t from forward pass
            # t is in range [-1, 1], stable
            self.grad += (1-t**2) * out.grad
      "|
    }
    wrong_approach -> correct_approach: "Refactor"
  }
  
  overflow_explanation: {
    direction: down
    label: "Why Recomputation Overflows"
    
    overflow_table: {
      shape: sql_table
      label: "exp(2x) Values at Large x"
      row1: "x = 10  | exp(20)  ≈ 5e8"
      row2: "x = 50  | exp(100) ≈ 3e43"
      row3: "x = 100 | exp(200) ≈ 7e86"
      row4: "x = 355 | exp(710) → OVERFLOW"
      note: "Float64 max ≈ 1.8e308"
    }
    
    overflow_note: {
      label: "Risk: exp(2x) blows up float64"
      width: 300
      style: {
        fill: "#FFE4B5"
        stroke: "#FF8C00"
      }
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  implementation_flow: {
    direction: down
    label: "Complete tanh Implementation (value.py)"
    
    forward_box: {
      label: "Forward Pass"
      width: 380
      style.fill: "#E3F2FD"
      forward_code: |"python
        def tanh(self):
            x = self.data
            t = math.tanh(x) # Built-in is stable
            out = Value(t, (self,), 'tanh')
            def _backward():
                self.grad += (1 - t**2) * out.grad
            out._backward = _backward
            return out
      "|
    }
    
    backward_box: {
      label: "Backward Pass (inside closure)"
      width: 380
      style.fill: "#E8F5E9"
      backward_code: |"python
        # Chain Rule Implementation:
        # local_grad = 1 - t**2
        # self.grad += local_grad * out.grad
        # Closure CAPTURES 't' from forward scope
        # No recomputation required.
      "|
    }
    forward_box -> backward_box: "t is captured"
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  summary: {
    direction: down
    label: "Implementation Summary"
    
    reason_table: {
      shape: sql_table
      label: "Benefits of Caching tanh Output"
      r1: "1 | Numerical Stability | No exp() overflow"
      r2: "2 | Efficiency | Single subtraction + square"
      r3: "3 | Correctness | Uses forward-evaluated state"
      r4: "4 | Cleanliness | Concise closure syntax"
    }
    
    gradient_flow: {
      shape: class
      label: "Gradient Calculation"
      upstream: "upstream: out.grad"
      local: "local: (1 - t^2)"
      operation: "operation: upstream * local"
    }
  }
}

legend: {
  label: "Color Legend"
  red: {
    label: "Overflow Risk"
    style.fill: "#FFB4AB"
  }
  green: {
    label: "Safe Approach"
    style.fill: "#BAF2B8"
  }
  blue: {
    label: "Forward Operation"
    style.fill: "#E3F2FD"
  }
}
legend.near: bottom-right