direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Topological Sort Step-by-Step
  DFS-based ordering for backpropagation on `L = (a*b + c)²`
| {near: top-center}
# Computational Graph Structure
graph_structure: {
  label: "Computational Graph"
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  direction: right
  leaves: {
    direction: down
    label: ""
    style.stroke: transparent
    style.fill: transparent
    a: {
      shape: circle
      label: "a"
      style.fill: "#e3f2fd"
      style.stroke: "#1976d2"
    }
    b: {
      shape: circle
      label: "b"
      style.fill: "#e3f2fd"
      style.stroke: "#1976d2"
    }
    c: {
      shape: circle
      label: "c"
      style.fill: "#e3f2fd"
      style.stroke: "#1976d2"
    }
  }
  ops: {
    direction: down
    label: ""
    style.stroke: transparent
    style.fill: transparent
    mul: {
      shape: circle
      label: "*"
      style.fill: "#fff3e0"
      style.stroke: "#f57c00"
    }
    add: {
      shape: circle
      label: "+"
      style.fill: "#fff3e0"
      style.stroke: "#f57c00"
    }
    pow: {
      shape: circle
      label: "**"
      style.fill: "#fff3e0"
      style.stroke: "#f57c00"
    }
  }
  output: {
    label: ""
    style.stroke: transparent
    style.fill: transparent
    L: {
      shape: circle
      label: "L"
      style.fill: "#e8f5e9"
      style.stroke: "#388e3c"
      style.bold: true
    }
  }
  leaves.a -> ops.mul: "w_a"
  leaves.b -> ops.mul: "w_b"
  leaves.c -> ops.add: "w_c"
  ops.mul -> ops.add: "ab"
  ops.add -> ops.pow: "ab+c"
  ops.pow -> output.L: "L"
}
# Step-by-Step DFS Execution
steps_container: {
  label: "DFS Topological Sort Execution"
  style.fill: "#fafafa"
  style.stroke: "#bdbdbd"
  direction: down
  step1: {
    label: "Step 1: Start DFS from L"
    style.fill: "#e8f5e9"
    style.stroke: "#4caf50"
    width: 600
    code: |'python
      build_topo(L):
        visited = {}          # Empty
        stack = [L]           # Push L
    '|
    state: |md
      **Visited:** `{}`  
      **Recursion Stack:** `[L]`  
      **Order:** `[]`
    |
  }
  step2: {
    label: "Step 2: Visit L → recurse to (**)"
    style.fill: "#fff8e1"
    style.stroke: "#ffc107"
    width: 600
    code: |'python
      build_topo(L):
        visited.add(L)        # L marked
        for child in L._prev: # child = (**)
          build_topo((**))    # Recursive call
    '|
    state: |md
      **Visited:** `{L}`  
      **Recursion Stack:** `[L → (**)]`  
      **Order:** `[]`
    |
  }
  step3: {
    label: "Step 3: Visit (**) → recurse to (+)"
    style.fill: "#fff8e1"
    style.stroke: "#ffc107"
    width: 600
    code: |'python
      build_topo((**)):
        visited.add((**))
        for child in (**)._prev:  # child = (+)
          build_topo((+))         # Recursive call
    '|
    state: |md
      **Visited:** `{L, **}`  
      **Recursion Stack:** `[L → ** → +]`  
      **Order:** `[]`
    |
  }
  step4: {
    label: "Step 4: Visit (+) → recurse to (*) and c"
    style.fill: "#fff8e1"
    style.stroke: "#ffc107"
    width: 600
    code: |'python
      build_topo((+)):
        visited.add((+))
        for child in (+)._prev:   # (*), c
          build_topo((*))         # First child
    '|
    state: |md
      **Visited:** `{L, **, +}`  
      **Recursion Stack:** `[L → ** → + → *]`  
      **Order:** `[]`
    |
  }
  step5: {
    label: "Step 5: Visit (*) → recurse to a and b"
    style.fill: "#fff8e1"
    style.stroke: "#ffc107"
    width: 600
    code: |'python
      build_topo((*)):
        visited.add((*))
        for child in (*)._prev:   # a, b
          build_topo(a)           # First child
    '|
    state: |md
      **Visited:** `{L, **, +, *}`  
      **Recursion Stack:** `[L → ** → + → * → a]`  
      **Order:** `[]`
    |
  }
  step6: {
    label: "Step 6: a is leaf → append and return"
    style.fill: "#e3f2fd"
    style.stroke: "#2196f3"
    width: 600
    code: |'python
      build_topo(a):
        visited.add(a)
        a._prev = {}        # No children
        order.append(a)     # ADD TO ORDER
        return              # Pop from stack
    '|
    state: |md
      **Visited:** `{L, **, +, *, a}`  
      **Recursion Stack:** `[L → ** → + → *]`  
      **Order:** `[a]` ✓
    |
  }
  step7: {
    label: "Step 7: Back to (*) → visit b"
    style.fill: "#e3f2fd"
    style.stroke: "#2196f3"
    width: 600
    code: |'python
      # Back in build_topo((*))
      build_topo(b)         # Second child
      # b is leaf, same as a
      order.append(b)
    '|
    state: |md
      **Visited:** `{L, **, +, *, a, b}`  
      **Recursion Stack:** `[L → ** → + → *]`  
      **Order:** `[a, b]` ✓
    |
  }
  step8: {
    label: "Step 8: (*) done → append and return"
    style.fill: "#e3f2fd"
    style.stroke: "#2196f3"
    width: 600
    code: |'python
      # All children of (*) visited
      order.append((*))     # ADD TO ORDER
      return                # Pop from stack
    '|
    state: |md
      **Visited:** `{L, **, +, *, a, b}`  
      **Recursion Stack:** `[L → ** → +]`  
      **Order:** `[a, b, *]` ✓
    |
  }
  step9: {
    label: "Step 9: Back to (+) → visit c"
    style.fill: "#e3f2fd"
    style.stroke: "#2196f3"
    width: 600
    code: |'python
      # Back in build_topo((+))
      build_topo(c)         # Second child
      # c is leaf
      order.append(c)
    '|
    state: |md
      **Visited:** `{L, **, +, *, a, b, c}`  
      **Recursion Stack:** `[L → ** → +]`  
      **Order:** `[a, b, *, c]` ✓
    |
  }
  step10: {
    label: "Step 10: (+) done → append and return"
    style.fill: "#e3f2fd"
    style.stroke: "#2196f3"
    width: 600
    code: |'python
      # All children of (+) visited
      order.append((+))     # ADD TO ORDER
      return
    '|
    state: |md
      **Visited:** `{L, **, +, *, a, b, c}`  
      **Recursion Stack:** `[L → **]`  
      **Order:** `[a, b, *, c, +]` ✓
    |
  }
  step11: {
    label: "Step 11: (**) done → append and return"
    style.fill: "#e3f2fd"
    style.stroke: "#2196f3"
    width: 600
    code: |'python
      # All children of (**) visited
      order.append((**))    # ADD TO ORDER
      return
    '|
    state: |md
      **Visited:** `{L, **, +, *, a, b, c}`  
      **Recursion Stack:** `[L]`  
      **Order:** `[a, b, *, c, +, **]` ✓
    |
  }
  step12: {
    label: "Step 12: L done → append → COMPLETE"
    style.fill: "#e8f5e9"
    style.stroke: "#4caf50"
    style.bold: true
    width: 600
    code: |'python
      # All children of L visited
      order.append(L)       # ADD TO ORDER
      return                # DFS complete!
    '|
    state: |md
      **Visited:** `{L, **, +, *, a, b, c}`  
      **Recursion Stack:** `[]` ✓  
      **Order:** `[a, b, *, c, +, **, L]` ✓
    |
  }
}
# Final Result
result: {
  label: "Result: Topological Order for Backprop"
  style.fill: "#e8f5e9"
  style.stroke: "#388e3c"
  width: 700
  direction: down
  topo_order: {
    label: "Forward (Topo) Order"
    style.fill: "#bbdefb"
    style.stroke: "#1976d2"
    code: |'python
      topo = [a, b, *, c, +, **, L]
      # Children appear BEFORE parents
      # Leaves (a, b, c) come first
      # Output (L) comes last
    '|
  }
  reverse_order: {
    label: "Reverse Order for Backprop"
    style.fill: "#ffccbc"
    style.stroke: "#e64a19"
    code: |'python
      reverse_topo = [L, **, +, c, *, b, a]
      # Parents appear BEFORE children
      # Output (L) comes first (grad = 1.0)
      # Leaves receive accumulated gradients last
    '|
  }
}
# Gradient Flow Visualization
gradient_flow: {
  label: "Gradient Flow in Reverse Topo Order"
  style.fill: "#fff3e0"
  style.stroke: "#ff9800"
  width: 700
  flow_table: {
    shape: sql_table
    label: "Backward Pass Execution"
    step: "Step"
    node: "Node"
    action: "Action"
    gradient: "Gradient Propagation"
    s1: "1 | L | Seed | grad = 1.0"
    s2: "2 | ** | ∂L/∂(+) | 2 × (ab+c) × 1.0"
    s3: "3 | + | ∂L/∂(*) | grad × 1 = 2(ab+c)"
    s4: "4 | + | ∂L/∂c | grad × 1 = 2(ab+c)"
    s5: "5 | * | ∂L/∂a | grad × b"
    s6: "6 | * | ∂L/∂b | grad × a"
    s7: "7 | c | Leaf | Accumulated ∂L/∂c"
    s8: "8 | b | Leaf | Accumulated ∂L/∂b"
    s9: "9 | a | Leaf | Accumulated ∂L/∂a"
  }
}
# Key Insight
insight: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  near: bottom-center
  key_insight: |md
    ### Key Insight: Why Children Before Parents?
    In the DFS traversal, we append a node to `order` **after** recursively visiting all its children.
    This guarantees that in the final order:
    - Every node appears **after** all nodes it depends on
    - For backprop, we reverse this order to process dependencies correctly
    
    Forward:  a → b → * → c → + → ** → L
              ↑___________________↑
              Children come first
    Backward: L → ** → + → c → * → b → a
              ↑___________________↑
              Parents come first (gradients flow down)
    
  |
}
# Connections
steps_container.step1 -> steps_container.step2: "DFS"
steps_container.step2 -> steps_container.step3: "recurse"
steps_container.step3 -> steps_container.step4: "recurse"
steps_container.step4 -> steps_container.step5: "recurse"
steps_container.step5 -> steps_container.step6: "recurse"
steps_container.step6 -> steps_container.step7: "return"
steps_container.step7 -> steps_container.step8: "return"
steps_container.step8 -> steps_container.step9: "return"
steps_container.step9 -> steps_container.step10: "return"
steps_container.step10 -> steps_container.step11: "return"
steps_container.step11 -> steps_container.step12: "return"
result -> gradient_flow: "Used for"
gradient_flow -> insight: "Explains"