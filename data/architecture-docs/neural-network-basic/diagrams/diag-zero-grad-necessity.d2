direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Why zero_grad() is Essential" {
  near: top-center
  style: {
    font-size: 32
    bold: true
  }
}
row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  without_zero: {
    direction: down
    label: "WITHOUT zero_grad()"
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
    style.stroke-width: 2
    epoch1: {
      label: "Epoch 1"
      style.fill: white
      params1: {
        shape: sql_table
        label: "Parameters"
        p1: "w1 | data=0.5 | grad=0.0"
        p2: "w2 | data=-0.3 | grad=0.0"
      }
      loss1: "Loss = 0.50"
      backward1: {
        label: "backward()"
        code: |'python
          w1.grad += 0.12
          w2.grad += -0.08
        '|
        width: 200
      }
      result1: {
        shape: sql_table
        label: "After Backward"
        r1: "w1 | grad=0.12"
        r2: "w2 | grad=-0.08"
      }
    }
    epoch2: {
      label: "Epoch 2 (accumulates!)"
      style.fill: "#FFF0F0"
      params2: {
        shape: sql_table
        label: "Parameters (updated)"
        p1: "w1 | data=0.488 | grad=0.12"
        p2: "w2 | data=-0.292 | grad=-0.08"
      }
      loss2: "Loss = 0.48"
      backward2: {
        label: "backward() — NO ZERO!"
        code: |'python
          w1.grad += 0.11  # was 0.12
          w2.grad += -0.07 # was -0.08
          # Now: grad=0.23, -0.15
        '|
        width: 220
      }
      result2: {
        shape: sql_table
        label: "Accumulated Gradients"
        r1: "w1 | grad=0.23 (!)"
        r2: "w2 | grad=-0.15 (!)"
      }
    }
    epoch3: {
      label: "Epoch 3 (explodes!)"
      style.fill: "#FFE4E1"
      params3: {
        shape: sql_table
        label: "Parameters"
        p1: "w1 | data=0.465 | grad=0.23"
        p2: "w2 | data=-0.277 | grad=-0.15"
      }
      loss3: "Loss = 0.52 ↑"
      backward3: {
        label: "backward()"
        code: |'python
          w1.grad += 0.14
          # Total: 0.37 (3× intended!)
          w2.grad += -0.09
          # Total: -0.24 (3× intended!)
        '|
        width: 240
      }
      result3: {
        shape: sql_table
        label: "Exploding Gradients"
        r1: "w1 | grad=0.37 (!!!)"
        r2: "w2 | grad=-0.24 (!!!)"
      }
    }
  }
  with_zero: {
    direction: down
    label: "WITH zero_grad()"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    epoch1_z: {
      label: "Epoch 1"
      style.fill: white
      params1_z: {
        shape: sql_table
        label: "Parameters"
        p1: "w1 | data=0.5 | grad=0.0"
        p2: "w2 | data=-0.3 | grad=0.0"
      }
      loss1_z: "Loss = 0.50"
      backward1_z: {
        label: "backward()"
        code: |'python
          w1.grad += 0.12
          w2.grad += -0.08
        '|
        width: 200
      }
      result1_z: {
        shape: sql_table
        label: "After Backward"
        r1: "w1 | grad=0.12"
        r2: "w2 | grad=-0.08"
      }
    }
    epoch2_z: {
      label: "Epoch 2 (fresh start)"
      style.fill: "#F1F8E9"
      params2_z: {
        shape: sql_table
        label: "Parameters (updated)"
        p1: "w1 | data=0.488 | grad=0.0 ✓"
        p2: "w2 | data=-0.292 | grad=0.0 ✓"
      }
      zero_z: {
        label: "zero_grad() called!"
        style.fill: "#C8E6C9"
        code: |'python
          w1.grad = 0.0  # Reset!
          w2.grad = 0.0  # Reset!
        '|
        width: 200
      }
      loss2_z: "Loss = 0.45"
      backward2_z: {
        label: "backward()"
        code: |'python
          w1.grad += 0.10
          w2.grad += -0.06
        '|
        width: 200
      }
      result2_z: {
        shape: sql_table
        label: "Clean Gradients"
        r1: "w1 | grad=0.10"
        r2: "w2 | grad=-0.06"
      }
    }
    epoch3_z: {
      label: "Epoch 3 (stable)"
      style.fill: "#E8F5E9"
      params3_z: {
        shape: sql_table
        label: "Parameters"
        p1: "w1 | data=0.478 | grad=0.0 ✓"
        p2: "w2 | data=-0.286 | grad=0.0 ✓"
      }
      zero3_z: {
        label: "zero_grad() called!"
        style.fill: "#C8E6C9"
        code: |'python
          w1.grad = 0.0
          w2.grad = 0.0
        '|
        width: 200
      }
      loss3_z: "Loss = 0.41 ↓"
      backward3_z: {
        label: "backward()"
        code: |'python
          w1.grad += 0.08
          w2.grad += -0.05
        '|
        width: 200
      }
      result3_z: {
        shape: sql_table
        label: "Correct Gradients"
        r1: "w1 | grad=0.08"
        r2: "w2 | grad=-0.05"
      }
    }
  }
}
loss_curves: {
  direction: right
  label: "Loss Curves Comparison"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  curve_bad: {
    label: "Without zero_grad()"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    axes1: {
      label: "Loss vs Epoch"
      style.fill: white
      y1: {
        label: "Loss"
        style.stroke: "#666"
      }
      x1: {
        label: "Epoch"
        style.stroke: "#666"
      }
      line1: {
        label: "0.50 → 0.48 → 0.52 → 0.71 → 1.3 → EXPLODE"
        style.stroke: "#F44336"
        style.stroke-width: 3
        style.stroke-dash: 0
      }
    }
    verdict1: {
      label: "❌ Diverges: Effective LR grows each epoch"
      style.fill: "#FFCDD2"
    }
  }
  curve_good: {
    label: "With zero_grad()"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    axes2: {
      label: "Loss vs Epoch"
      style.fill: white
      y2: {
        label: "Loss"
        style.stroke: "#666"
      }
      x2: {
        label: "Epoch"
        style.stroke: "#666"
      }
      line2: {
        label: "0.50 → 0.45 → 0.41 → 0.32 → 0.18 → 0.05"
        style.stroke: "#4CAF50"
        style.stroke-width: 3
      }
    }
    verdict2: {
      label: "✅ Converges: Consistent LR = 0.1"
      style.fill: "#C8E6C9"
    }
  }
}
math_explanation: {
  label: "The Math Behind the Bug"
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  formula: {
    label: |'text
      Without zero_grad():
      ─────────────────────────────────────────
      Update at epoch n:  w -= lr × (g₁ + g₂ + ... + gₙ)
      After 100 epochs:   w -= lr × 100×g_actual  ← WRONG!
      With zero_grad():
      ─────────────────────────────────────────
      Update at epoch n:  w -= lr × gₙ
      Always:             w -= lr × g_current    ← CORRECT!
    '|
    width: 450
  }
}
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#666"
  item1: "+= accumulates (correct within one backward)" { style.fill: "#E3F2FD" }
  item2: "= assigns (correct for zero_grad)" { style.fill: "#E8F5E9" }
  item3: "Missing zero = gradient explosion" { style.fill: "#FFEBEE" }
}