direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
title: |md
  # micrograd: Neural Network from Scratch
  Scalar-valued autograd engine with reverse-mode automatic differentiation
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_core: {
    direction: down
    label: "CORE ENGINE (value.py) [M1-M2]"
    value_struct: {
      shape: sql_table
      label: "struct Value (value.py)"
      data: "float | scalar value"
      grad: "float | gradient ∂L/∂self"
      _prev: "set[Value] | graph children"
      _op: "str | operation label"
      _backward: "Callable | gradient closure"
      sz: "Total: ~350-400 bytes"
    }
    value_class: {
      shape: class
      label: "Value class (value.py) [M1-M2]"
      -data: "float"
      -grad: "float"
      -_prev: "set[Value]"
      -_op: "str"
      -_backward: "Callable"
      +__init__(data, _children, _op): "None"
      +__add__(other): "Value"
      +__mul__(other): "Value"
      +__sub__(other): "Value"
      +__truediv__(other): "Value"
      +__pow__(other): "Value"
      +__neg__(): "Value"
      +__radd__(other): "Value"
      +__rmul__(other): "Value"
      +tanh(): "Value"
      +relu(): "Value"
      +backward(): "None"
      +zero_grad(): "None"
    }
  }
  layer_ops: {
    direction: down
    label: "OPERATORS [M1]"
    ops_table: {
      shape: sql_table
      label: "Operator Local Derivatives"
      add: "+ | ∂out/∂a=1, ∂out/∂b=1"
      mul: "* | ∂out/∂a=b.data"
      pow: "**n | ∂out/∂a=n*x^(n-1)"
      neg: "- | via *(-1)"
      div: "/ | via *(b**-1)"
      tanh_op: "tanh | 1-tanh²(x)"
      relu_op: "ReLU | 1 if x>0 else 0"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_nn: {
    direction: down
    label: "NEURAL NETWORK (nn.py) [M3]"
    neuron_class: {
      shape: class
      label: "class Neuron (nn.py) [M3]"
      -w: "list[Value] | weights"
      -b: "Value | bias"
      -activation: "str | tanh/relu/linear"
      -nin: "int | input count"
      +__init__(nin, activation): "None"
      +__call__(x): "Value"
      +parameters(): "list[Value]"
    }
    layer_class: {
      shape: class
      label: "class Layer (nn.py) [M3]"
      -neurons: "list[Neuron]"
      -nin: "int"
      -nout: "int"
      +__init__(nin, nout, activation): "None"
      +__call__(x): "Value | list[Value]"
      +parameters(): "list[Value]"
    }
    mlp_class: {
      shape: class
      label: "class MLP (nn.py) [M3]"
      -layers: "list[Layer]"
      -nin: "int"
      -nouts: "list[int]"
      +__init__(nin, nouts): "None"
      +__call__(x): "Value | list[Value]"
      +parameters(): "list[Value]"
    }
  }
  layer_train: {
    direction: down
    label: "TRAINING (train.py) [M4]"
    sgd_class: {
      shape: class
      label: "class SGD (train.py) [M4]"
      -parameters: "list[Value]"
      -lr: "float | learning rate"
      +__init__(parameters, lr): "None"
      +zero_grad(): "None"
      +step(): "None"
    }
    train_func: {
      shape: class
      label: "Training Functions (train.py) [M4]"
      +mse_loss(preds, targets): "Value"
      +train(net, X, Y, epochs, lr): "list[float]"
    }
    loss_struct: {
      shape: sql_table
      label: "MSE Loss Computation"
      formula: "L = (1/N) × Σ(yᵢ - ŷᵢ)²"
      gradient: "∂L/∂ŷᵢ = -2(yᵢ - ŷᵢ)/N"
      range: "L ∈ [0, ∞)"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_graph: {
    direction: down
    label: "COMPUTATIONAL GRAPH [M1-M2]"
    graph_flow: {
      shape: rectangle
      label: |md
        **Forward Pass (Graph Construction)**
        
        a = Value(2.0)
        b = Value(3.0)
        c = a * b + a  # c = 8.0
        
        Graph: a → (*) → (+) → c
               b ↗    ↑
                      a ┘
      |
    }
    topo_algo: {
      shape: rectangle
      label: |md
        **Topological Sort (DFS)**
        python
        def build_topo(v):
          if v not in visited:
            visited.add(v)
            for child in v._prev:
              build_topo(child)
            topo.append(v)
        
        Order: [a, b, intermediate, c]
        Reverse: [c, intermediate, b, a]
      |
    }
  }
  layer_backprop: {
    direction: down
    label: "BACKPROPAGATION [M2]"
    backprop_flow: {
      shape: rectangle
      label: |md
        **Backward Pass Algorithm**
        
        1. topo = build_topo(loss)
        2. loss.grad = 1.0  # seed
        3. for node in reversed(topo):
             node._backward()
        
        Chain Rule: ∂L/∂a = ∂L/∂c × ∂c/∂a
      |
    }
    grad_accum: {
      shape: rectangle
      label: |md
        **Gradient Accumulation**
        python
        # Multi-path: a used twice
        b = a + a  # b = 2a
        # a.grad += 1  (from self)
        # a.grad += 1  (from other)
        # Result: a.grad = 2 ✓
        
        Uses += not = for accumulation
      |
    }
  }
  layer_training: {
    direction: down
    label: "TRAINING LOOP [M4]"
    training_loop: {
      shape: rectangle
      label: |md
        **Training Sequence (per epoch)**
        python
        for epoch in range(epochs):
            # 1. Forward pass
            preds = [network(x) for x in X]
            # 2. Compute loss
            loss = mse_loss(preds, Y)
            # 3. Zero gradients (CRITICAL)
            optimizer.zero_grad()
            # 4. Backward pass
            loss.backward()
            # 5. Update parameters
            optimizer.step()
        
      |
    }
    sgd_update: {
      shape: rectangle
      label: |md
        **SGD Parameter Update**
        python
        # Direct mutation (no new Value)
        p.data -= lr * p.grad
        
        NOT: p = p - Value(lr) * p.grad
        (would create new object, leak memory)
      |
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_arch: {
    direction: down
    label: "NETWORK ARCHITECTURE [M3]"
    mlp_example: {
      shape: sql_table
      label: "MLP(3, [4, 4, 1]) Example"
      layer0: "Layer 0 | 3→4 | 16 params"
      layer1: "Layer 1 | 4→4 | 20 params"
      layer2: "Layer 2 | 4→1 | 5 params"
      total: "Total: 41 parameters"
    }
    neuron_compute: {
      shape: rectangle
      label: |md
        **Neuron Computation**
        
        output = activation(Σ(wᵢ×xᵢ) + b)
        
        - 3 weights + 1 bias per neuron
        - tanh for hidden layers
        - linear for output layer
      |
    }
  }
  layer_dataflow: {
    direction: down
    label: "DATA FLOW [M1-M4]"
    dataflow_table: {
      shape: sql_table
      label: "Tensor Shape Tracking"
      input_X: "X | (N, nin) | training inputs"
      target_Y: "Y | (N,) | target values"
      forward_out: "predictions | list[Value] | N outputs"
      loss_scalar: "loss | () | scalar Value"
      gradients: "params.grad | (P,) | P parameters"
      history: "loss_history | (epochs,) | per epoch"
    }
  }
  layer_xor: {
    direction: down
    label: "XOR TRAINING [M4]"
    xor_dataset: {
      shape: sql_table
      label: "XOR Dataset"
      sample0: "[0,0] | → | 0"
      sample1: "[0,1] | → | 1"
      sample2: "[1,0] | → | 1"
      sample3: "[1,1] | → | 0"
      note: "Non-linearly separable"
    }
    xor_result: {
      shape: rectangle
      label: |md
        **Training Results**
        - Network: MLP(2, [4, 1]) = 13 params
        - Epochs: 2000
        - Learning rate: 0.1
        - Final loss: < 0.01
        - Predictions within 0.15 error
      |
    }
  }
}
layer_core.value_struct -> layer_core.value_class: "defines"
layer_core.value_class -> layer_nn.neuron_class: "weights/bias"
layer_nn.neuron_class -> layer_nn.layer_class: "contains"
layer_nn.layer_class -> layer_nn.mlp_class: "chains"
layer_nn.mlp_class -> layer_train.train_func: "network param"
layer_train.sgd_class -> layer_train.train_func: "optimizer"
layer_train.train_func -> layer_core.value_class: "backward()"
layer_graph.graph_flow -> layer_backprop.backprop_flow: "traverses"
layer_backprop.backprop_flow -> layer_training.training_loop: "step 4"
layer_training.training_loop -> layer_train.sgd_class: "steps 3,5"
layer_nn.mlp_class -> layer_arch.mlp_example: "e.g."
layer_arch.mlp_example -> layer_xor.xor_dataset: "trains on"
layer_xor.xor_result -> layer_training.training_loop: "converges"
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | neural-network-basic-m1 | Value Class with Autograd"
  m2: "M2 | neural-network-basic-m2 | Backward Pass & Gradient Verification"
  m3: "M3 | neural-network-basic-m3 | Neuron, Layer, and MLP"
  m4: "M4 | neural-network-basic-m4 | Training Loop & Optimizer"
}