vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Computational Graph Building
  **Expression: `c = a * b + a`**
  *Technical implementation details for local gradient tracking and backpropagation.*
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

classes: {
  leaf: {
    shape: circle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      font-color: "#1B5E20"
    }
  }
  intermediate: {
    shape: diamond
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      font-color: "#0D47A1"
    }
  }
  output: {
    shape: hexagon
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 3
      font-color: "#BF360C"
      bold: true
    }
  }
  step_container: {
    style: {
      stroke: "#BDBDBD"
      stroke-width: 1
      fill: "#FFFFFF"
      border-radius: 12
    }
  }
  connection: {
    style: {
      stroke: "#78909C"
      stroke-width: 2
    }
  }
}

direction: right

step1: {
  label: "Step 1: Initialization of Leaf Nodes"
  class: step_container
  
  a1: {
    label: |md
      **a**
      `data = 2.0`
      `grad = 0.0`
      `_prev = {}`
      `_op = ""`
    |
    class: leaf
  }
  
  b1: {
    label: |md
      **b**
      `data = 3.0`
      `grad = 0.0`
      `_prev = {}`
      `_op = ""`
    |
    class: leaf
  }
  
  note1: |md
    **Leaf Node Invariants:**
    - Created directly via `Value(data)`
    - `_prev`: Empty set (base of recursion)
    - `_op`: Null string
    - `_backward`: Identity function (no-op)
  | {
    style.fill: "#FAFAFA"
    style.stroke: "#EEEEEE"
  }
}

step2: {
  label: "Step 2: Multiplication Operator `a * b`"
  class: step_container
  
  a2: {
    class: leaf
    label: "a\ndata=2.0"
  }
  b2: {
    class: leaf
    label: "b\ndata=3.0"
  }
  
  mul_node: {
    label: |md
      **t** (temp)
      `data = 6.0`
      `_prev = {a, b}`
      `_op = "*"`
    |
    class: intermediate
  }
  
  a2 -> mul_node: {
    class: connection
    label: "self"
  }
  b2 -> mul_node: {
    class: connection
    label: "other"
  }
  
  note2: |md
    **Multiplication Logic (`__mul__`):**
    1. Result `data = a.data * b.data`
    2. Pointer set `_prev` captures parents.
    3. `_backward` defined as:
       `a.grad += b.data * out.grad`
       `b.grad += a.data * out.grad`
  | {
    style.fill: "#FAFAFA"
    style.stroke: "#EEEEEE"
  }
}

step3: {
  label: "Step 3: Addition Operator `t + a` (Accumulation)"
  class: step_container
  
  a3: {
    class: leaf
    label: "a\ndata=2.0"
    style.stroke-width: 4
  }
  b3: {
    class: leaf
    label: "b\ndata=3.0"
    style.opacity: 0.4
  }
  t3: {
    label: "t\ndata=6.0"
    class: intermediate
  }
  
  c3: {
    label: |md
      **c** (final output)
      `data = 8.0`
      `_prev = {t, a}`
      `_op = "+"`
    |
    class: output
  }
  
  b3 -> t3: {
    style: {
      stroke-dash: 3
      stroke: "#BDBDBD"
    }
  }
  a3 -> t3: {
    class: connection
  }
  t3 -> c3: {
    class: connection
    label: "self"
  }
  a3 -> c3: {
    class: connection
    label: "other"
    style.stroke: "#E65100"
    style.stroke-width: 3
  }
  
  note3: |md
    **Critical State: Variable Reuse**
    - Node `a` is consumed by both `*` and `+`.
    - This creates a non-tree DAG.
    - Addition `_backward` logic:
      `self.grad += out.grad`
      `other.grad += out.grad`
  | {
    style.fill: "#FFF8E1"
    style.stroke: "#FFE082"
  }
}

final_dag: {
  label: "Final Computational DAG Structure"
  class: step_container
  
  leaf_a: {
    class: leaf
    label: |md
      **a**
      `Value(2.0)`
    |
  }
  leaf_b: {
    class: leaf
    label: |md
      **b**
      `Value(3.0)`
    |
  }
  node_t: {
    class: intermediate
    label: |md
      **t** = a * b
      `Value(6.0)`
      `_op: "*"`
    |
  }
  node_c: {
    class: output
    label: |md
      **c** = t + a
      `Value(8.0)`
      `_op: "+"`
    |
  }
  
  leaf_a -> node_t: "weight"
  leaf_b -> node_t: "input"
  leaf_a -> node_c: "residual connection" {
    style: {
      stroke: "#E65100"
      stroke-width: 4
      animated: true
    }
  }
  node_t -> node_c: "main flow"
  
  legend: |md
    **Topological Sort order:**
    [a, b] → [t] → [c]
    
    **Backprop Path:**
    1. Begin at `c`
    2. Branch to `t` and `a`
    3. Branch from `t` to `a` and `b`
  | {
    style.fill: "#FAFAFA"
    style.stroke: "#EEEEEE"
  }
}

step1 -> step2: {
  style: {
    stroke-dash: 5
    stroke: "#9E9E9E"
  }
}
step2 -> step3: {
  style: {
    stroke-dash: 5
    stroke: "#9E9E9E"
  }
}
step3 -> final_dag: {
  style: {
    stroke-dash: 5
    stroke: "#9E9E9E"
  }
}

backward_note: {
  label: |md
    ## Chain Rule Execution (c.backward())
    
    Processing in reverse topological order:
    
    **1. Seed Output Gradient**
    `c.grad = 1.0`
    
    **2. Addition Gradient (c -> t, a)**
    `t.grad += 1.0 * c.grad = 1.0`
    `a.grad += 1.0 * c.grad = 1.0`
    
    **3. Multiplication Gradient (t -> a, b)**
    `a.grad += b.data * t.grad = 3.0 * 1.0 = 3.0`
    `b.grad += a.data * t.grad = 2.0 * 1.0 = 2.0`
    
    **Final Result Mapping:**
    - `a.grad`: 1.0 (from +) + 3.0 (from *) = **4.0**
    - `b.grad`: 2.0 (from *) = **2.0**
    - `t.grad`: 1.0
  |
  near: bottom-right
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
    font-size: 16
  }
}