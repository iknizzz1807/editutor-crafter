vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Operator Overload Execution Flow
  Call stack from `a + b` through `__add__` to Value creation and `_backward` closure capture
| {near: top-center}
direction: down
# Python Expression Layer
python_expr: {
  label: "Python Expression Layer"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  source_code: |md
    python
    a = Value(2.0)
    b = Value(3.0)
    c = a + b   # ← Triggers __add__
    
  | {shape: text}
}
# Call Stack Trace
call_stack: {
  label: "Call Stack Trace"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  # Step 1: Expression Evaluation
  step1: {
    label: "Step 1: Expression Evaluation"
    style.fill: "#FFE0B2"
    expr_eval: |md
      Python interpreter sees: `a + b`
      1. Check if `a` has `__add__` method
      2. `a` is `Value` instance → HAS `__add__`
      3. Call: `a.__add__(b)`
    | {shape: text}
  }
  # Step 2: Method Dispatch
  step2: {
    label: "Step 2: Method Dispatch"
    style.fill: "#FFCC80"
    method_dispatch: |md
      python
      def __add__(self, other):
          # self = a (Value with data=2.0)
          # other = b (Value with data=3.0)
      
    | {shape: text}
  }
  # Step 3: Type Normalization
  step3: {
    label: "Step 3: Type Normalization"
    style.fill: "#FFB74D"
    type_norm: |md
      python
      # Ensure other is a Value
      other = other if isinstance(other, Value) else Value(other)
      # other is already Value(3.0) → no conversion
      
    | {shape: text}
  }
  # Step 4: Forward Computation
  step4: {
    label: "Step 4: Forward Computation"
    style.fill: "#FFA726"
    forward: |md
      python
      # Compute the actual sum
      result_data = self.data + other.data
      # result_data = 2.0 + 3.0 = 5.0
      
    | {shape: text}
  }
  # Step 5: Value Node Creation
  step5: {
    label: "Step 5: Value Node Creation"
    style.fill: "#FF9800"
    style.font-color: white
    value_creation: |md
      python
      out = Value(result_data, (self, other), '+')
      # Creates: Value(data=5.0, _prev={a, b}, _op='+')
      
    | {shape: text}
  }
  # Step 6: Backward Closure Definition
  step6: {
    label: "Step 6: _backward Closure Definition"
    style.fill: "#F57C00"
    style.font-color: white
    closure_def: |md
      python
      def _backward():
          # Captures: self, other, out
          self.grad += out.grad      # a.grad += c.grad
          other.grad += out.grad     # b.grad += c.grad
      out._backward = _backward
      
    | {shape: text}
  }
  # Step 7: Return
  step7: {
    label: "Step 7: Return Result"
    style.fill: "#EF6C00"
    style.font-color: white
    return_result: |md
      python
      return out  # Value(5.0) with graph connectivity
      
    | {shape: text}
  }
}
# Memory State Diagrams
memory_state: {
  label: "Memory State During Execution"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  # Before __add__
  before: {
    label: "Before `__add__` Call"
    style.fill: "#C8E6C9"
    var_a: {
      label: "a"
      shape: rectangle
      style.fill: "#A5D6A7"
      data_a: "data: 2.0"
      grad_a: "grad: 0.0"
      prev_a: "_prev: {}"
      op_a: "_op: ''"
    }
    var_b: {
      label: "b"
      shape: rectangle
      style.fill: "#A5D6A7"
      data_b: "data: 3.0"
      grad_b: "grad: 0.0"
      prev_b: "_prev: {}"
      op_b: "_op: ''"
    }
  }
  # After __add__
  after: {
    label: "After `__add__` Returns (c = a + b)"
    style.fill: "#81C784"
    var_a2: {
      label: "a"
      shape: rectangle
      style.fill: "#66BB6A"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
      data_a2: "data: 2.0"
      grad_a2: "grad: 0.0"
      prev_a2: "_prev: {}"
      op_a2: "_op: ''"
    }
    var_b2: {
      label: "b"
      shape: rectangle
      style.fill: "#66BB6A"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
      data_b2: "data: 3.0"
      grad_b2: "grad: 0.0"
      prev_b2: "_prev: {}"
      op_b2: "_op: ''"
    }
    var_c: {
      label: "c (NEW)"
      shape: rectangle
      style.fill: "#43A047"
      style.stroke: "#1B5E20"
      style.stroke-width: 3
      style.bold: true
      data_c: "data: 5.0"
      grad_c: "grad: 0.0"
      prev_c: "_prev: {a, b}"
      op_c: "_op: '+'"
      backward_c: "_backward: <closure>"
    }
  }
}
# Closure Capture Detail
closure_detail: {
  label: "_backward Closure Capture Detail"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  closure_box: {
    label: "_backward Closure Object"
    shape: rectangle
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    closure_content: |md
      **Closure Environment (captured variables):**
      - `self` → reference to `a` (Value 2.0)
      - `other` → reference to `b` (Value 3.0)  
      - `out` → reference to result `c` (Value 5.0)
      **Function Body:**
      python
      def _backward():
          self.grad += out.grad
          other.grad += out.grad
      
      **When called (during backward pass):**
      - Reads: `out.grad` (upstream gradient)
      - Writes: `self.grad`, `other.grad` (accumulates)
    | {shape: text}
  }
  gradient_flow: {
    label: "Gradient Flow When _backward() Called"
    style.fill: "#CE93D8"
    flow: |md
      If `c.grad = 1.0` (seed from backward):
      
      c.grad = 1.0
           │
           ▼
      ┌─────────────────────┐
      │   _backward()       │
      │                     │
      │ a.grad += 1.0       │ → a.grad = 1.0
      │ b.grad += 1.0       │ → b.grad = 1.0
      └─────────────────────┘
      Result: Both inputs receive gradient 1
      (correct for addition: d(a+b)/da = 1, d(a+b)/db = 1)
      
    | {shape: text}
  }
}
# Graph Structure Built
graph_built: {
  label: "Computational Graph Structure Built"
  style.fill: "#E0F2F1"
  style.stroke: "#009688"
  style.stroke-width: 2
  node_a: {
    label: "a\nValue(2.0)"
    shape: circle
    style.fill: "#B2DFDB"
  }
  node_b: {
    label: "b\nValue(3.0)"
    shape: circle
    style.fill: "#B2DFDB"
  }
  node_add: {
    label: "(+)\n_op: '+'"
    shape: diamond
    style.fill: "#80CBC4"
  }
  node_c: {
    label: "c\nValue(5.0)"
    shape: circle
    style.fill: "#4DB6AC"
    style.stroke: "#00695C"
    style.stroke-width: 2
  }
  node_a -> node_add: "self"
  node_b -> node_add: "other"
  node_add -> node_c: "out"
  graph_note: |md
    **Graph Properties:**
    - `c._prev = {a, b}` (children)
    - `c._op = '+'` (operation label)
    - `c._backward` (gradient function)
    **Backward traversal** visits nodes in
    reverse topological order, calling
    each `_backward` to propagate gradients.
  | {shape: text}
}
# Execution Timeline
timeline: {
  label: "Execution Timeline"
  style.fill: "#FFFDE7"
  style.stroke: "#FFC107"
  style.stroke-width: 2
  t1: {
    label: "t₁"
    shape: circle
    style.fill: "#FFF9C4"
    t1_note: "Python parses\n`a + b`"
  }
  t2: {
    label: "t₂"
    shape: circle
    style.fill: "#FFF59D"
    t2_note: "Dispatch to\n`a.__add__(b)`"
  }
  t3: {
    label: "t₃"
    shape: circle
    style.fill: "#FFEE58"
    t3_note: "Type check\nother is Value"
  }
  t4: {
    label: "t₄"
    shape: circle
    style.fill: "#FFEB3B"
    t4_note: "Compute\n2.0 + 3.0 = 5.0"
  }
  t5: {
    label: "t₅"
    shape: circle
    style.fill: "#FDD835"
    t5_note: "Create new\nValue(5.0)"
  }
  t6: {
    label: "t₆"
    shape: circle
    style.fill: "#FBC02D"
    t6_note: "Define _backward\nclosure"
  }
  t7: {
    label: "t₇"
    shape: circle
    style.fill: "#F9A825"
    style.font-color: white
    t7_note: "Attach closure\nto out._backward"
  }
  t8: {
    label: "t₈"
    shape: circle
    style.fill: "#F57F17"
    style.font-color: white
    t8_note: "Return out\n(assign to c)"
  }
  t1 -> t2 -> t3 -> t4 -> t5 -> t6 -> t7 -> t8: {style.stroke: "#FF8F00"}
}
# Connections between sections
python_expr -> call_stack.step1: "triggers" {style.stroke-dash: 3}
call_stack.step7 -> memory_state.after: "creates" {style.stroke: "#4CAF50"}
memory_state.after -> graph_built: "forms graph" {style.stroke: "#009688"}
call_stack.step6 -> closure_detail: "defines" {style.stroke: "#9C27B0"}