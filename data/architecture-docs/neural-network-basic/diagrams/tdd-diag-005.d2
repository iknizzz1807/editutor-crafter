vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Reverse Operator Dispatch
  Python Method Resolution: `2 + Value(3)`
| {near: top-center}
shape: sequence_diagram
# Participants in evaluation order
int_2: "int (2)"
value_3: "Value (3)"
python_runtime: "Python\nRuntime"
result: "Result"
# Step 1: Initial expression evaluation
step1: {
  int_2 -> python_runtime: "evaluates: 2 + Value(3)"
  python_runtime -> int_2: "__add__(Value(3))"
  int_2 -> python_runtime: "NotImplemented\n(int doesn't know Value)"
}
# Step 2: Reflected operation fallback
step2: {
  python_runtime."Phase 1 Failed"
  python_runtime -> value_3: "__radd__(2)\n[reflected operation]"
  value_3 -> value_3: "return self + other\n[delegates to __add__]"
}
# Step 3: Final computation
step3: {
  value_3 -> python_runtime: "Value(5)\n[computed via __add__]"
  python_runtime -> result: "Value(data=5.0)"
}
# Annotations explaining the process
int_2."int.__add__:\nOnly handles int + int\nReturns NotImplemented\nfor unknown types"
value_3."Value.__radd__:\nFallback for\nleft-side scalar\nreturn self + other"
result."✓ Success:\nExpression resolves\nto Value object\nconnected to graph"
# Style the failure/success states
step1.style.stroke: "#E74C3C"
step2.style.stroke: "#F39C12"
step3.style.stroke: "#27AE60"
int_2.style.fill: "#FADBD8"
value_3.style.fill: "#D4EFDF"
python_runtime.style.fill: "#FCF3CF"
result.style.fill: "#D5F5E3"