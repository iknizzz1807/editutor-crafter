vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Multiplication Backward Derivation
  ## d(ab)/da = b, d(ab)/db = a
| {near: top-center}
direction: right
# Forward pass context
forward_context: {
  label: "Forward Pass"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  forward_eq: |md
    
    c = a × b
    Where:
      a = 3.0
      b = 2.0  
      c = 6.0
    
  |
}
# Derivation panel
derivation: {
  label: "Chain Rule Derivation"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  step1: |md
    ### Step 1: Apply Chain Rule
    
    ∂L/∂a = ∂L/∂c × ∂c/∂a
    ∂L/∂b = ∂L/∂c × ∂c/∂b
    
  |
  step2: |md
    ### Step 2: Compute Local Derivatives
    
    ∂c/∂a = ∂(a×b)/∂a = b
    ∂c/∂b = ∂(a×b)/∂b = a
    
    *Treat sibling as constant*
  |
  step3: |md
    ### Step 3: Combine
    
    a.grad += b.data × c.grad
    b.grad += a.data × c.grad
    
  |
}
# Critical insight box
critical: {
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  style.stroke-width: 3
  warning_title: "⚠️ CRITICAL INSIGHT" {
    style.bold: true
    style.font-size: 18
    style.font-color: "#C62828"
  }
  correct: |md
    ### ✅ CORRECT: Use `.data`
    python
    def _backward():
        a.grad += b.data * c.grad
        b.grad += a.data * c.grad
    
    Local derivative = **value** of sibling
  |
  wrong: |md
    ### ❌ WRONG: Using `.grad`
    python
    def _backward():
        a.grad += b.grad * c.grad  # BUG!
        b.grad += a.grad * c.grad  # BUG!
    
    This would use gradient, not value
  |
}
# Visual representation
visual: {
  label: "Visual: Gradient Flow"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  a_node: {
    label: "a\n.data = 3.0\n.grad = ?"
    shape: circle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
  b_node: {
    label: "b\n.data = 2.0\n.grad = ?"
    shape: circle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
  mul_node: {
    label: "×"
    shape: diamond
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
  }
  c_node: {
    label: "c\n.data = 6.0\n.grad = 1.0"
    shape: circle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  a_node -> mul_node: "data: 3.0"
  b_node -> mul_node: "data: 2.0"
  mul_node -> c_node
  # Backward arrows with formulas
  c_node -> mul_node: "grad: 1.0" {
    style.stroke: "#D32F2F"
    style.stroke-width: 2
    style.stroke-dash: 4
    style.animated: true
  }
  mul_node -> a_node: "grad += b.data × c.grad\n= 2.0 × 1.0 = 2.0" {
    style.stroke: "#D32F2F"
    style.stroke-width: 2
    style.stroke-dash: 4
  }
  mul_node -> b_node: "grad += a.data × c.grad\n= 3.0 × 1.0 = 3.0" {
    style.stroke: "#D32F2F"
    style.stroke-width: 2
    style.stroke-dash: 4
  }
}
# Code implementation
implementation: {
  label: "Implementation"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  code: |python
    def __mul__(self, other):
        other = other if isinstance(other, Value) else Value(other)
        out = Value(self.data * other.data, (self, other), '*')
        def _backward():
            # ∂(ab)/∂a = b  → use b.data
            # ∂(ab)/∂b = a  → use a.data
            self.grad += other.data * out.grad
            other.grad += self.data * out.grad
        out._backward = _backward
        return out
  |
}
# Why it matters
why_matters: {
  style.fill: "#E0F7FA"
  style.stroke: "#00BCD4"
  style.stroke-width: 2
  explanation: |md
    ### Why `.data` not `.grad`?
    The **local derivative** of multiplication is the *value* of the other operand:
    - `∂(a×b)/∂a = b` — b is treated as a **constant**
    - We use `b.data` (the constant value), not `b.grad` (how b's output changes)
    The gradient `b.grad` tells us how loss changes with respect to b.
    But here, we need: "how does c change when a changes, holding b fixed?"
    That's `b.data` — the numeric value of b.
  |
}
# Connections
forward_context -> derivation
derivation -> critical
critical -> visual
visual -> implementation
implementation -> why_matters