vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Power Operation Backward Derivation
  ## Mathematical: d(x^n)/dx = n · x^(n-1)
| {near: top-center}
direction: right
Step_1: {
  label: "Step 1: Forward Pass"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  exponent_capture: |md
    ### Closure Captures Exponent
    python
    def __pow__(self, other):
        # other is captured in closure!
        out = Value(self.data ** other, 
                    (self,), f'**{other}')
        def _backward():
            # 'other' is remembered here
            self.grad += other * \
                (self.data ** (other - 1)) * \
                out.grad
        out._backward = _backward
        return out
    
  | {style.fill: "#FFF3E0"}
  closure_diagram: {
    style.fill: "#E3F2FD"
    closure_box: "Closure Object\n_backward()" {
      style.fill: "#BBDEFB"
      shape: rectangle
      captures: "Captured Variables" {
        style.fill: "#90CAF9"
        other_label: "other = n"
        other_val: "3"
        style.stroke: "#1565C0"
      }
      computation: "Computation Body" {
        style.fill: "#64B5F6"
        formula: "grad = n × x^(n-1) × out.grad"
        style.font: mono
        style.font-size: 14
      }
    }
  }
}
Step_2: {
  label: "Step 2: Derivation Chain"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  formula_chain: {
    style.fill: "#F1F8E9"
    base: "f(x) = x^n" {
      style.fill: "#C8E6C9"
      style.bold: true
    }
    arrow1: base -> derivative {
      label: "Power Rule"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    derivative: "f'(x) = n · x^(n-1)" {
      style.fill: "#A5D6A7"
      style.bold: true
    }
    arrow2: derivative -> applied {
      label: "Chain Rule"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    applied: "∂L/∂x = n · x^(n-1) · ∂L/∂out" {
      style.fill: "#81C784"
      style.bold: true
    }
  }
  variables: {
    style.fill: "#DCEDC8"
    var_n: "n (exponent)" {
      style.fill: "#FFF9C4"
      label.near: outside-top-center
    }
    var_x: "x (input.data)" {
      style.fill: "#FFECB3"
      label.near: outside-top-center
    }
    var_grad: "out.grad (upstream)" {
      style.fill: "#FFE0B2"
      label.near: outside-top-center
    }
  }
}
Step_3: {
  label: "Step 3: Concrete Example"
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  example: |md
    ### Example: x³ at x = 2.0
    **Forward:**
    - `self.data = 2.0`
    - `other = 3`
    - `out.data = 2³ = 8.0`
    **Closure captures:**
    - `other = 3` (the exponent)
    - `self` reference
    **Backward (when out.grad = 1.0):**
    
    self.grad += 3 × (2.0)^(3-1) × 1.0
    self.grad += 3 × 4.0 × 1.0
    self.grad += 12.0
    
    **Verification:**
    - d(x³)/dx at x=2 = 3×2² = 12 ✓
  | {style.fill: "#FFF8E1"}
  value_flow: {
    style.fill: "#FFECB3"
    input: "x = 2.0" {
      shape: circle
      style.fill: "#FFE082"
    }
    power_op: "**3" {
      shape: diamond
      style.fill: "#FFD54F"
    }
    output: "out = 8.0" {
      shape: circle
      style.fill: "#FFCA28"
    }
    grad_in: "out.grad = 1.0" {
      shape: circle
      style.fill: "#FFB74D"
    }
    grad_out: "x.grad = 12.0" {
      shape: circle
      style.fill: "#FFA726"
    }
    input -> power_op: "forward"
    power_op -> output: "8.0"
    grad_in -> power_op: "backward" {
      style.stroke-dash: 5
      style.stroke: "#E65100"
    }
    power_op -> grad_out: "12.0" {
      style.stroke-dash: 5
      style.stroke: "#E65100"
    }
  }
}
Step_4: {
  label: "Step 4: Why Closure Matters"
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  why_closure: |md
    ### Why Capture Exponent in Closure?
    **Problem:** Each power node has a different exponent
    python
    a = Value(2.0)
    b = a ** 2    # exponent = 2
    c = a ** 3    # exponent = 3
    d = a ** 0.5  # exponent = 0.5
    
    **Solution:** Each `_backward` "remembers" its own exponent
    - `b._backward` computes: `2 × x¹ × grad`
    - `c._backward` computes: `3 × x² × grad`
    - `d._backward` computes: `0.5 × x^(-0.5) × grad`
    The closure captures `other` at **creation time**,
    so each node has the correct formula forever.
  | {style.fill: "#F8BBD9"}
  closure_instances: {
    style.fill: "#FCE4EC"
    closure_b: "_backward for b" {
      style.fill: "#F48FB1"
      exp_b: "other = 2"
      formula_b: "grad = 2 × x¹ × out.grad"
    }
    closure_c: "_backward for c" {
      style.fill: "#F06292"
      exp_c: "other = 3"
      formula_c: "grad = 3 × x² × out.grad"
    }
    closure_d: "_backward for d" {
      style.fill: "#EC407A"
      exp_d: "other = 0.5"
      formula_d: "grad = 0.5 × x^(-0.5) × out.grad"
    }
    closure_b -> closure_c -> closure_d: "different exponents" {
      style.stroke-dash: 3
      style.stroke: "#880E4F"
    }
  }
}
Step_5: {
  label: "Step 5: Implementation Detail"
  style.fill: "#E1F5FE"
  style.stroke: "#03A9F4"
  code_detail: |md
    ### Critical Implementation Notes
    **1. Exponent must be int or float (not Value):**
    python
    assert isinstance(other, (int, float)), \
        "Only int/float powers supported"
    
    **2. Uses self.data, not self.grad:**
    python
    # CORRECT: local derivative uses the VALUE
    self.grad += other * (self.data ** (other - 1)) * out.grad
    # WRONG: would use gradient, not value
    # self.grad += other * (self.grad ** (other - 1)) * out.grad
    
    **3. Handles negative exponents (for division):**
    python
    # a / b = a * b**(-1)
    # Works because (-1) ** (other - 1) = (-1) ** (-2)
    
    **4. Accumulates with += (not =):**
    python
    self.grad += ...  # Allows multiple paths to x
    
  | {style.fill: "#B3E5FC"}
  data_vs_grad: {
    style.fill: "#E0F7FA"
    data_box: ".data (value)" {
      style.fill: "#80DEEA"
      desc: "Used in local\nderivative computation"
    }
    grad_box: ".grad (gradient)" {
      style.fill: "#4DD0E1"
      desc: "Accumulated from\nbackward pass"
    }
    data_box -> grad_box: "NOT mixed!" {
      style.stroke: "#006064"
      style.stroke-width: 2
    }
  }
}
Step_1 -> Step_2 -> Step_3 -> Step_4 -> Step_5: "Derivation Flow" {
  style.stroke: "#37474F"
  style.stroke-width: 3
}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  title: "Legend"
  forward: "→ Forward pass" {
    shape: text
  }
  backward: "⇢ Backward pass" {
    shape: text
    style.stroke-dash: 5
  }
  capture: "Closure capture" {
    shape: text
    style.fill: "#BBDEFB"
  }
}