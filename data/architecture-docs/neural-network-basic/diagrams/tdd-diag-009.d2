vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#7C3AED"
    data: "#4A90D2"
    free: "#228B22"
    padding: "#9E9E9E"
    pointer: "#F5A623"
    active: "#DC3545"
    gradient: "#FFC107"
    border: "#2D3748"
  }
}

classes: {
  memory_cell: {
    style: {
      stroke: "${colors.border}"
      stroke-width: 2
      font: mono
      font-size: 14
    }
  }
  value_box: {
    style: {
      fill: "${colors.data}"
      stroke: "${colors.header}"
      stroke-width: 2
      font: mono
      font-size: 14
    }
  }
  field_label: {
    style: {
      font: mono
      font-size: 12
      font-color: "#4A5568"
      bold: true
    }
  }
  pointer_style: {
    style: {
      fill: "${colors.pointer}"
      stroke: "${colors.pointer}"
      font-color: white
      font-size: 11
    }
  }
  section_header: {
    style: {
      fill: "${colors.header}"
      font-color: white
      bold: true
      font-size: 16
    }
  }
}

title: |md
  # Value Object Anatomy & Memory Layout
  ## Implementation Specification: Micrograd Scalar Engine
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# Memory Offset Labels (Left Margin)
offsets: {
  grid-columns: 1
  grid-gap: 10
  style.stroke-width: 0
  style.fill: transparent
  
  o0: "0x00" { class: field_label }
  o8: "0x08" { class: field_label }
  o16: "0x10" { class: field_label }
  o24: "0x18" { class: field_label }
  o32: "0x20" { class: field_label }
  o40: "0x28" { class: field_label }
  o48: "0x30" { class: field_label }
  o56: "0x38" { class: field_label }
}

value_object: {
  label: "Value Class Instance (PyObject Struct)"
  shape: rectangle
  style: {
    fill: white
    stroke: "${colors.border}"
    stroke-width: 3
    shadow: true
  }

  py_head: {
    label: "PyObject_HEAD"
    class: section_header
    width: 400
    
    refcnt: "ob_refcnt (uint64)" {
      class: memory_cell
      style.fill: "#EDF2F7"
    }
    type_ptr: "ob_type (*PyTypeObject)" {
      class: memory_cell
      style.fill: "${colors.pointer}"
    }
  }

  attributes: {
    label: "Instance Dictionary / __slots__"
    class: section_header
    
    data_row: {
      field: "data (float64)" { class: field_label }
      val: "3.14159265" { 
        class: value_box
        style.fill: "${colors.data}"
      }
    }
    
    grad_row: {
      field: "grad (float64)" { class: field_label }
      val: "0.00000000" { 
        class: value_box
        style.fill: "${colors.gradient}"
      }
    }
    
    prev_row: {
      field: "_prev (set ptr)" { class: field_label }
      val: "0x7f8a21" { 
        class: value_box
        style.fill: "${colors.pointer}"
      }
    }
    
    op_row: {
      field: "_op (str ptr)" { class: field_label }
      val: "'+' (0x2b)" { 
        class: value_box
        style.fill: "${colors.padding}"
      }
    }
    
    back_row: {
      field: "_backward" { class: field_label }
      val: "<function closure>" { 
        class: value_box
        style.fill: "${colors.active}"
      }
    }
  }
}

# Structural Details
cache_line_alert: "--- 64B Cache Line Boundary ---" {
  shape: text
  style: {
    font-size: 10
    font-color: red
    stroke-dash: 3
  }
}

# Connections for logical flow
value_object.attributes.prev_row.val -> heap_storage: "References Parents" {
  style: {
    stroke: "${colors.pointer}"
    stroke-width: 2
    animated: true
  }
}

heap_storage: {
  label: "Heap Memory (Set Data)"
  shape: cylinder
  style.fill: "#F7FAFC"
  node_a: "Value(a)"
  node_b: "Value(b)"
}

# Footer and Metadata
memory_info: |md
  **Memory Statistics**
  - `sizeof(Value)`: 56 bytes (fixed fields)
  - `PyObject Overhead`: 16 bytes
  - `Alignment`: 8-byte boundaries
  - `Total Footprint`: ~410 bytes (inc. dict/set overhead)
| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#FEFCBF"
    stroke: "#ECC94B"
    font-size: 12
  }
}

legend: {
  label: "Color Map / Legend"
  near: bottom-right
  grid-columns: 2
  grid-gap: 8
  
  l1: "Core Scalar Data" { style.fill: "${colors.data}" }
  l2: "Autograd Gradient" { style.fill: "${colors.gradient}" }
  l3: "Memory Pointer" { style.fill: "${colors.pointer}" }
  l4: "Computation Op" { style.fill: "${colors.padding}" }
  l5: "Backward Closure" { style.fill: "${colors.active}" }
  l6: "System Header" { style.fill: "${colors.header}" }
}

# Positioning sync
offsets.o0 -> value_object.py_head.refcnt: { style.opacity: 0 }
offsets.o16 -> value_object.attributes.data_row.val: { style.opacity: 0 }