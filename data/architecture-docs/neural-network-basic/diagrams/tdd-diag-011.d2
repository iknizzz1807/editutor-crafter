vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  # Color Palette: Header=Purple, Data=Blue, Free=Green, Padding=Gray, Pointers=Orange
  colors: {
    header: "#8E44AD"
    data: "#2980B9"
    pointer: "#E67E22"
    free: "#27AE60"
    padding: "#7F8C8D"
    text: "#2C3E50"
    boundary: "#C0392B"
  }
}

classes: {
  header-block: {
    style: {
      fill: "${colors.header}"
      font-color: white
      bold: true
      font-size: 14
    }
  }
  data-block: {
    style: {
      fill: "${colors.data}"
      font-color: white
    }
  }
  pointer-block: {
    style: {
      fill: "${colors.pointer}"
      font-color: white
    }
  }
  free-block: {
    style: {
      fill: "${colors.free}"
      font-color: white
    }
  }
  padding-block: {
    style: {
      fill: "${colors.padding}"
      font-color: white
    }
  }
  boundary-line: {
    shape: rectangle
    style: {
      stroke: "${colors.boundary}"
      stroke-width: 3
      stroke-dash: 5
      fill: transparent
      font-color: "${colors.boundary}"
      bold: true
    }
  }
}

title: |md
  # Neural Engine: Value Object Memory Layout
  **Object Type:** `micrograd.engine.Value`
  **Total Size:** ~350-400 bytes (Heap Allocated)
  **Page Alignment:** 8-byte aligned
| {
  near: top-center
  style: {
    font-size: 18
    bold: true
    fill: transparent
  }
}

memory_layout: {
  grid-rows: 10
  grid-columns: 3
  grid-gap: 0
  
  # Row 1: Header
  h_off: "Byte Offset" { class: header-block }
  h_field: "Field Descriptor" { class: header-block }
  h_size: "Field Size" { class: header-block }
  
  # Row 2: Python Object Header
  off_0: "0x00 (0)" { class: padding-block }
  field_0: "PyObject_HEAD (Ref Count + Type Ptr)" { class: header-block }
  size_0: "16 B" { class: padding-block }
  
  # Row 3: Instance Dict Pointer
  off_16: "0x10 (16)" { class: padding-block }
  field_16: "Instance __dict__ Pointer" { class: pointer-block }
  size_16: "8 B" { class: padding-block }
  
  # Row 4: Scalar Data
  off_24: "0x18 (24)" { class: padding-block }
  field_24: "'data' (PyFloatObject Reference)" { class: data-block }
  size_24: "24 B" { class: padding-block }
  
  # Row 5: Gradient Data
  off_48: "0x30 (48)" { class: padding-block }
  field_48: "'grad' (PyFloatObject Reference)" { class: data-block }
  size_48: "24 B" { class: padding-block }
  
  # Row 6: Graph Connectivity
  off_72: "0x48 (72)" { class: padding-block }
  field_72: "'_prev' (PySetObject Pointer)" { class: pointer-block }
  size_72: "~72 B*" { class: padding-block }
  
  # Row 7: Operation String
  off_144: "0x90 (144)" { class: padding-block }
  field_144: "'_op' (PyUnicodeObject Pointer)" { class: pointer-block }
  size_144: "~50 B*" { class: padding-block }
  
  # Row 8: Backprop Function
  off_194: "0xC2 (194)" { class: padding-block }
  field_194: "'_backward' (PyFunctionObject Pointer)" { class: pointer-block }
  size_194: "~140 B*" { class: padding-block }
  
  # Row 9: Meta/Reserved
  off_334: "0x14E (334)" { class: padding-block }
  field_334: "Internal Metadata / Cache" { class: data-block }
  size_334: "Variable" { class: padding-block }

  # Row 10: Padding/Free Space
  off_end: "---" { class: padding-block }
  field_end: "Alignment Padding / Slop Space" { class: padding-block }
  size_end: "Variable" { class: free-block }
}

# Technical Overlays
cache_boundary_1: "L1 Cache Line Boundary (64B)" {
  class: boundary-line
  width: 500
}

cache_boundary_2: "L1 Cache Line Boundary (128B)" {
  class: boundary-line
  width: 500
}

cache_boundary_3: "L1 Cache Line Boundary (192B)" {
  class: boundary-line
  width: 500
}

legend: {
  near: center-right
  header: "Legend" { shape: text; style.bold: true }
  l1: "Header / Metadata" { style.fill: "${colors.header}"; style.font-color: white }
  l2: "Pointer / Reference" { style.fill: "${colors.pointer}"; style.font-color: white }
  l3: "Active Computation Data" { style.fill: "${colors.data}"; style.font-color: white }
  l4: "Free / Slop Space" { style.fill: "${colors.free}"; style.font-color: white }
  l5: "Internal Padding" { style.fill: "${colors.padding}"; style.font-color: white }
}

implementation_notes: |md
  ### Implementation Notes
  - **PyObject_HEAD**: Standard 16-byte header for CPython objects on 64-bit systems.
  - **Pointer Overhead**: Each attribute in `__slots__` or `__dict__` is an 8-byte pointer to a heap-allocated object.
  - **Memory Impact**: Because `Value` instances are created for every operation in a neural network, total memory scales linearly with the number of nodes in the computational graph.
  - **Alignment**: CPython allocator uses 8-byte alignment for all object allocations.
| {
  near: bottom-center
  style: {
    font-size: 11
    fill: "#F8F9F9"
    stroke: "#D5DBDB"
  }
}