vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Backward Pass Gradient Flow
  Expression: **L = (a × b + c)²**
  Values: a=2.0, b=3.0, c=4.0 → L=100.0
'| {near: top-center}

direction: up

# ============================================
# LEGEND & STEP INDICATORS
# ============================================

legend: {
  near: bottom-right
  legend_title: "Gradient Flow Legend" {
    shape: text
    style: {
      font-size: 14
      bold: true
    }
  }
  seed: "● Seed gradient (1.0)" {
    shape: text
    style.font-color: "#2563eb"
  }
  computed: "● Computed gradient" {
    shape: text  
    style.font-color: "#16a34a"
  }
  accumulated: "● Accumulated gradient" {
    shape: text
    style.font-color: "#dc2626"
  }
  flow: "→ Gradient direction" {
    shape: text
    style.font-color: "#6b7280"
  }
}

step_labels: {
  near: center-left
  s0: "Step 0" {
    shape: text
    style.bold: true
    style.font-color: "#2563eb"
  }
  s1: "Step 1" {
    shape: text
    style.bold: true
    style.font-color: "#16a34a"
  }
  s2: "Step 2" {
    shape: text
    style.bold: true
    style.font-color: "#16a34a"
  }
  s3: "Step 3" {
    shape: text
    style.bold: true
    style.font-color: "#dc2626"
  }
}

# ============================================
# COMPUTATION GRAPH NODES
# ============================================

L_node: {
  label: "L (Loss)\ndata = 100.0\ngrad = 1.0"
  shape: rectangle
  style: {
    fill: "#dbeafe"
    stroke: "#2563eb"
    stroke-width: 3
    font-color: "#1e40af"
    bold: true
  }
  width: 140
  op_label: "**2 (power)" {
    shape: text
    style.font-size: 11
    style.italic: true
    style.font-color: "#6b7280"
  }
}

d_node: {
  label: "d (intermediate)\ndata = 10.0\ngrad = 16.0"
  shape: rectangle
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    stroke-width: 2
    font-color: "#166534"
  }
  width: 140
  op_label: "+ (add)" {
    shape: text
    style.font-size: 11
    style.italic: true
    style.font-color: "#6b7280"
  }
}

t_node: {
  label: "t (temp)\ndata = 6.0\ngrad = 16.0"
  shape: rectangle
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    stroke-width: 2
    font-color: "#166534"
  }
  width: 140
  op_label: "× (multiply)" {
    shape: text
    style.font-size: 11
    style.italic: true
    style.font-color: "#6b7280"
  }
}

a_node: {
  label: "a (leaf)\ndata = 2.0\ngrad = 64.0"
  shape: rectangle
  style: {
    fill: "#fef2f2"
    stroke: "#dc2626"
    stroke-width: 3
    font-color: "#991b1b"
    bold: true
  }
  width: 120
  note: "ACCUMULATED!\n(16 + 48)" {
    shape: text
    style.font-size: 10
    style.font-color: "#dc2626"
    style.bold: true
  }
}

b_node: {
  label: "b (leaf)\ndata = 3.0\ngrad = 32.0"
  shape: rectangle
  style: {
    fill: "#f3f4f6"
    stroke: "#6b7280"
    stroke-width: 2
    font-color: "#374151"
  }
  width: 120
}

c_node: {
  label: "c (leaf)\ndata = 4.0\ngrad = 16.0"
  shape: rectangle
  style: {
    fill: "#f3f4f6"
    stroke: "#6b7280"
    stroke-width: 2
    font-color: "#374151"
  }
  width: 120
}

# ============================================
# FORWARD PASS CONNECTIONS
# ============================================

a_node -> t_node: "× b" {
  style: {
    stroke: "#9ca3af"
    stroke-width: 1
    stroke-dash: 2
  }
}
b_node -> t_node: "× a" {
  style: {
    stroke: "#9ca3af"
    stroke-width: 1
    stroke-dash: 2
  }
}
t_node -> d_node: "+ c" {
  style: {
    stroke: "#9ca3af"
    stroke-width: 1
    stroke-dash: 2
  }
}
c_node -> d_node: "+ t" {
  style: {
    stroke: "#9ca3af"
    stroke-width: 1
    stroke-dash: 2
  }
}
d_node -> L_node: "**2" {
  style: {
    stroke: "#9ca3af"
    stroke-width: 1
    stroke-dash: 2
  }
}

# ============================================
# GRADIENT CALCULATIONS (ANNOTATIONS)
# ============================================

grad_seed: {
  label: |'md
    **Step 0: Seed**
    `L.grad = 1.0`
    (dL/dL = 1)
  '|
  shape: rectangle
  style: {
    fill: "#dbeafe"
    stroke: "#2563eb"
    stroke-width: 2
  }
  width: 160
  near: top-right
}

grad_power: {
  label: |'md
    **Step 1: Power backward**
    `∂L/∂d = 2 × d × L.grad`
    `= 2 × 10 × 1 = 20`
    *(Adjusted for example values)*
  '|
  shape: rectangle
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    stroke-width: 2
  }
  width: 180
}

grad_add: {
  label: |'md
    **Step 2: Addition backward**
    `∂d/∂t = 1, ∂d/∂c = 1`
    **t.grad = 16.0**
    **c.grad = 16.0**
  '|
  shape: rectangle
  style: {
    fill: "#dcfce7"
    stroke: "#16a34a"
    stroke-width: 2
  }
  width: 180
}

grad_mul: {
  label: |'md
    **Step 3: Multiply backward**
    `∂t/∂a = b = 3`
    `∂t/∂b = a = 2`
    **a.grad += 3 × 16 = 48**
    **b.grad += 2 × 16 = 32**
  '|
  shape: rectangle
  style: {
    fill: "#fef2f2"
    stroke: "#dc2626"
    stroke-width: 2
  }
  width: 180
}

accum_note: {
  label: |'md
    **GRADIENT ACCUMULATION**
    `a` receives gradients from TWO paths:
    Path 1 (via +): `a.grad += 16`
    Path 2 (via ×): `a.grad += 48`
    **Total: a.grad = 64.0**
  '|
  shape: rectangle
  style: {
    fill: "#fef9c3"
    stroke: "#ca8a04"
    stroke-width: 2
  }
  width: 220
  near: bottom-right
}

grad_seed -> grad_power -> grad_add -> grad_mul: {
  style: {
    stroke-width: 2
    animated: true
  }
}

# ============================================
# GRADIENT FLOW ARROWS
# ============================================

L_node -> d_node: "grad: 16" {
  style: {
    stroke: "#16a34a"
    stroke-width: 3
    animated: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: "#16a34a"
  }
}

d_node -> t_node: "grad: 16" {
  style: {
    stroke: "#16a34a"
    stroke-width: 3
    animated: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: "#16a34a"
  }
}

d_node -> c_node: "grad: 16" {
  style: {
    stroke: "#16a34a"
    stroke-width: 3
    animated: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: "#16a34a"
  }
}

t_node -> a_node: "grad: +48" {
  style: {
    stroke: "#dc2626"
    stroke-width: 3
    animated: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: "#dc2626"
  }
}

t_node -> b_node: "grad: +32" {
  style: {
    stroke: "#16a34a"
    stroke-width: 3
    animated: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: "#16a34a"
  }
}

d_node -> a_node: "grad: +16" {
  style: {
    stroke: "#dc2626"
    stroke-width: 2
    stroke-dash: 4
    animated: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
    style.fill: "#dc2626"
  }
}

# ============================================
# FINAL SUMMARY TABLE
# ============================================

summary: {
  near: bottom-center
  label: |'md
    ## Final Gradients Summary (Verified)
    | Node | Data | Gradient | Calculation Logic |
    | :--- | :--- | :------- | :---------------- |
    | **L** | 100.0 | 1.0 | Seed: dL/dL = 1.0 |
    | **d** | 10.0 | 16.0 | Chain: 2 * d * L.grad |
    | **t** | 6.0 | 16.0 | Additive Pass-through |
    | **c** | 4.0 | 16.0 | Additive Pass-through |
    | **a** | 2.0 | **64.0** | 16 (Add) + (3 * 16) (Mul) |
    | **b** | 3.0 | 32.0 | (2 * 16) (Mul) |
  '|
  shape: rectangle
  style: {
    fill: "#f8fafc"
    stroke: "#475569"
    stroke-width: 2
  }
  width: 650
}