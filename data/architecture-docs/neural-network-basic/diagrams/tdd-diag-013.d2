vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Chain Rule Mechanics
  **upstream_gradient × local_derivative = downstream_gradient**
| {
  near: top-center
}

classes: {
  value_node: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 4
    }
  }
  operation_node: {
    shape: diamond
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
    }
  }
  gradient_flow: {
    style: {
      stroke: "#DC2626"
      stroke-width: 3
      animated: true
    }
  }
  forward_flow: {
    style: {
      stroke: "#2563EB"
      stroke-width: 2
      stroke-dash: 3
    }
  }
  label_box: {
    shape: rectangle
    style: {
      fill: "#F3F4F6"
      stroke: "#9CA3AF"
      stroke-dash: 2
      font-size: 14
    }
  }
}

direction: right

# === FORWARD PASS ===
forward_section: Forward Pass (Data Flow) {
  direction: right
  
  a_forward: a = 2.0 {
    class: value_node
  }
  b_forward: b = 3.0 {
    class: value_node
  }
  c_forward: c = a × b {
    class: operation_node
    style.fill: "#DBEAFE"
    tooltip: "6.0"
  }
  d_forward: d = c + a {
    class: operation_node
    style.fill: "#DBEAFE"
    tooltip: "8.0"
  }
  L_forward: L = d² {
    class: operation_node
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
    }
    tooltip: "64.0"
  }

  a_forward -> c_forward: "x=2.0" {class: forward_flow}
  b_forward -> c_forward: "y=3.0" {class: forward_flow}
  c_forward -> d_forward: "6.0" {class: forward_flow}
  a_forward -> d_forward: "2.0" {class: forward_flow}
  d_forward -> L_forward: "8.0" {class: forward_flow}

  c_val: "Result: 6.0" { class: label_box }
  d_val: "Result: 8.0" { class: label_box }
  L_val: "Final L: 64.0" { 
    class: label_box 
    style.fill: "#FEE2E2"
  }
}

# === BACKWARD PASS ===
backward_section: Backward Pass (Gradient Flow) {
  direction: right
  
  L_back: "L.grad = 1.0\n(seed)" {
    class: value_node
    style: {
      fill: "#DCFCE7"
      stroke: "#16A34A"
    }
  }
  d_back: "d.grad = 16.0\n= 1.0 × 2d" {
    class: value_node
    style.fill: "#FEF3C7"
  }
  c_back: "c.grad = 16.0\n= 16.0 × 1" {
    class: value_node
    style.fill: "#FEF3C7"
  }
  a_back: "a.grad = 20.0\n= 16.0×1 + 16.0×3\n(accumulated!)" {
    class: value_node
    style: {
      fill: "#E0E7FF"
      stroke: "#4F46E5"
    }
  }
  b_back: "b.grad = 32.0\n= 16.0 × 2" {
    class: value_node
    style.fill: "#FEF3C7"
  }

  L_back -> d_back: "∂L/∂d = 2d = 16" {class: gradient_flow}
  d_back -> c_back: "∂d/∂c = 1" {class: gradient_flow}
  d_back -> a_back: "∂d/∂a = 1" {
    class: gradient_flow
    style.stroke-dash: 2
  }
  c_back -> a_back: "∂c/∂a = b = 3" {
    class: gradient_flow
    style.stroke: "#9333EA"
  }
  c_back -> b_back: "∂c/∂b = a = 2" {class: gradient_flow}
}

# === CHAIN RULE FORMULA BOX ===
formula_box: |md
  ## Chain Rule at Each Node
  **Power Node (L = d²):**
  - upstream = 1.0 (seed)
  - local = 2d = 16
  - downstream = 1.0 × 16 = 16
  
  **Addition Node (d = c + a):**
  - upstream = 16.0
  - local_∂d/∂c = 1
  - local_∂d/∂a = 1
  - downstream_to_c = 16 × 1 = 16
  - downstream_to_a = 16 × 1 = 16
  
  **Multiplication Node (c = a × b):**
  - upstream = 16.0
  - local_∂c/∂a = b = 3
  - local_∂c/∂b = a = 2
  - downstream_to_a = 16 × 3 = 48
  - downstream_to_b = 16 × 2 = 32
  
  **Gradient Accumulation for 'a':**
  - a.grad = 16 (from d) + 48 (from c) = 64
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#374151"
    stroke-width: 2
    border-radius: 8
  }
}

# === LEGEND ===
legend: Legend {
  near: top-right
  grid-columns: 2
  grid-gap: 10
  
  fwd: "→ Forward (data)" {
    class: forward_flow
    style.animated: false
  }
  bwd: "→ Backward (gradient)" {
    class: gradient_flow
    style.animated: false
  }
  acc: "→ Accumulation path" {
    style: {
      stroke: "#9333EA"
      stroke-width: 3
    }
  }
  val: "Value/Result" {
    class: value_node
  }
  op: "Operation" {
    class: operation_node
  }
}

# === CONNECT FORWARD TO BACKWARD ===
forward_section -> backward_section: "backward()\n↓" {
  style: {
    stroke: "#DC2626"
    stroke-width: 4
    stroke-dash: 5
    animated: true
  }
}

# === KEY INSIGHT BOX ===
insight: |md
  **Key Insight:** Each node only needs to know:
  1. **Upstream gradient** (flowing in from output)
  2. **Local derivative** (how its output changes with input)
  
  The chain rule composes automatically:
  `∂L/∂a = ∂L/∂d × ∂d/∂a + ∂L/∂d × ∂d/∂c × ∂c/∂a`
| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#ECFDF5"
    stroke: "#059669"
    stroke-width: 2
    border-radius: 8
  }
}