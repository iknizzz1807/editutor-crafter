  }
  t_cache: {
    label: "t (cached)"
    shape: diamond
    style.fill: "#FFE082"
    style.stroke: "#FF8F00"
  }
  backward_node: {
    label: "_backward()"
    shape: hexagon
    style.fill: "#A5D6A7"
  }
  grad_node: {
    label: "self.grad"
    shape: circle
    style.fill: "#C8E6C9"
  }

  x_node -> tanh_node: "forward" {
    style.stroke: "#1976D2"
  }
  tanh_node -> t_cache: "store t" {
    style.stroke: "#FF8F00"
    style.stroke-dash: 3
  }
  t_cache -> backward_node: "closure\naccess" {
    style.stroke: "#FF8F00"
    style.stroke-width: 2
  }
  backward_node -> grad_node: "(1-t²)×out.grad" {
    style.stroke: "#4CAF50"
  }
}

proof_flow -> implementation_section: {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5
}
