vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "ReLU Derivative Visualization" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Graph container
# This represents the coordinate system for the derivative function
graph: {
  width: 700
  height: 450
  style: {
    fill: white
    stroke: "#333"
    stroke-width: 2
  }

  # Axis Labels (Positioned relative to components)
  y_label: "∂ReLU/∂x" {
    shape: text
    style: {
      font-size: 18
      italic: true
    }
  }

  x_label: "x" {
    shape: text
    style: {
      font-size: 20
      italic: true
    }
  }

  # Axes Components
  y_axis: {
    width: 2
    height: 300
    style.fill: "#333"
    style.stroke: "#333"
  }

  x_axis: {
    width: 500
    height: 2
    style.fill: "#333"
    style.stroke: "#333"
  }

  # Gradient = 0 region (x ≤ 0)
  # Represents the 'Dead Zone' where the neuron does not update
  zero_region: {
    label: ""
    width: 200
    height: 6
    style: {
      fill: "#e74c3c"
      stroke: "#c0392b"
      stroke-width: 4
    }
  }

  # Gradient = 1 region (x > 0)
  # Represents the active region where gradient flows perfectly
  one_region: {
    label: ""
    width: 200
    height: 6
    style: {
      fill: "#27ae60"
      stroke: "#1e8449"
      stroke-width: 4
    }
  }

  # Discontinuity point at x=0
  # Usually treated as an open circle on the negative side
  discontinuity: {
    shape: circle
    width: 16
    height: 16
    style: {
      fill: white
      stroke: "#e74c3c"
      stroke-width: 3
    }
  }

  # Filled point at (0, 1) - subgradient choice or inclusion in active set
  subgrad_point: {
    shape: circle
    width: 16
    height: 16
    style: {
      fill: "#27ae60"
      stroke: "#1e8449"
      stroke-width: 3
    }
  }

  # Value labels
  label_0: "0" {
    shape: text
    style.font-size: 16
  }
  label_1: "1" {
    shape: text
    style.font-size: 16
  }

  # Region annotations explaining the mathematical state
  left_annotation: |md
    **x ≤ 0**
    ∂ReLU/∂x = **0**
  | {
    style: {
      fill: "#fdf2f2"
      stroke: "#c0392b"
      font-color: "#c0392b"
      font-size: 14
    }
  }

  right_annotation: |md
    **x > 0**
    ∂ReLU/∂x = **1**
  | {
    style: {
      fill: "#e8f8f5"
      stroke: "#1e8449"
      font-color: "#1e8449"
      font-size: 14
    }
  }

  # Using connections instead of invalid "shape: arrow"
  left_annotation -> zero_region: {
    style: {
      stroke: "#c0392b"
      stroke-width: 2
    }
  }
  right_annotation -> one_region: {
    style: {
      stroke: "#1e8449"
      stroke-width: 2
    }
  }

  # Structural layout helpers 
  # Using opacity 0 and stroke-width 0 to keep layout constraints without visual noise
  y_axis -> label_1: { 
    style: {
      stroke-width: 0
      opacity: 0
    }
  }
  label_1 -> subgrad_point: { style.stroke-dash: 3 }
  zero_region -> discontinuity: { 
    style: {
      stroke-width: 0
      opacity: 0
    }
  }
  discontinuity -> subgrad_point: { 
    label: "Step Discontinuity"
    style.stroke-dash: 5
  }
}

# Formula box showing the piecewise definition
formula: {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#f8f9fa"
    stroke: "#dee2e6"
    stroke-width: 2
    border-radius: 8
  }
  title: "Derivative Definition" {
    shape: text
    style: {
      bold: true
      font-size: 16
    }
  }
  content: |md
    ReLU(x) = max(0, x)
    
    ∂ReLU(x)/∂x = 
      1   if x > 0
      0   if x < 0
    
    At x = 0: **subgradient = 0** (standard convention in many ML frameworks)
  | {
    shape: text
    style: {
      font: mono
      font-size: 13
    }
  }
}

# Legend for quick identification
legend: {
  near: bottom-right
  style: {
    fill: white
    stroke: "#ddd"
    border-radius: 4
  }
  title: "Legend" {
    shape: text
    style.bold: true
  }
  grad_zero: {
    width: 40
    height: 8
    style: {
      fill: "#e74c3c"
      stroke: "#c0392b"
    }
  }
  grad_zero_label: "Gradient = 0 (dead zone)" {
    shape: text
    style.font-size: 12
  }
  grad_one: {
    width: 40
    height: 8
    style: {
      fill: "#27ae60"
      stroke: "#1e8449"
    }
  }
  grad_one_label: "Gradient = 1 (passes through)" {
    shape: text
    style.font-size: 12
  }
  open_circle: {
    shape: circle
    width: 12
    height: 12
    style: {
      fill: white
      stroke: "#333"
      stroke-width: 2
    }
  }
  open_label: "Open circle: value NOT included" {
    shape: text
    style.font-size: 12
  }
  filled_circle: {
    shape: circle
    width: 12
    height: 12
    style: {
      fill: "#333"
      stroke: "#333"
      stroke-width: 2
    }
  }
  filled_label: "Filled circle: value included" {
    shape: text
    style.font-size: 12
  }
}

# Key insight box regarding the engineering implications
insight: {
  near: center-right
  shape: rectangle
  style: {
    fill: "#fff3cd"
    stroke: "#ffc107"
    stroke-width: 2
    border-radius: 8
  }
  title: "⚠️ Dead Neuron Problem" {
    shape: text
    style: {
      bold: true
      font-size: 14
      font-color: "#856404"
    }
  }
  content: |md
    If a ReLU neuron always receives **negative** inputs:
    • Output = 0 always
    • Gradient = 0 always  
    • **Never learns! (Dead state)**
    
    Solutions: careful initialization, Leaky ReLU, 
    or lower learning rates.
  | {
    shape: text
    style.font-size: 12
  }
}

# Structural Layout Helpers (Fixing invalid display: none with opacity: 0)
graph -> formula: { 
  style: {
    stroke-width: 0
    opacity: 0
  }
}
graph -> legend: { 
  style: {
    stroke-width: 0
    opacity: 0
  }
}
graph -> insight: { 
  style: {
    stroke-width: 0
    opacity: 0
  }
}