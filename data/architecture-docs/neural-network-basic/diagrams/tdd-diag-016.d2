vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Numerical Gradient Approximation
  **Central Difference Method Implementation Spec**
| {near: top-center}

direction: right

# --- Section 1: Inputs ---
section_input: {
  label: "Function & Evaluation Point"
  style: {
    fill: "#E8F4FD"
    stroke: "#2E86AB"
    stroke-width: 2
  }
  
  func: {
    label: "f(x)"
    shape: oval
    style: {
      fill: "#2E86AB"
      font-color: white
      bold: true
    }
  }
  
  point: {
    label: "x"
    shape: circle
    style: {
      fill: "#A23B72"
      font-color: white
    }
    width: 45
    height: 45
  }
  
  h: {
    label: "h = step size\n(typically 1e-5)"
    shape: hexagon
    style: {
      fill: "#F18F01"
      font-color: white
    }
  }
}

# --- Section 2: Intermediate Values ---
section_evaluation: {
  label: "Function Evaluations"
  style: {
    fill: "#FCE8E8"
    stroke: "#C73E1D"
    stroke-width: 2
  }
  
  x_plus_h: {
    label: "x + h"
    shape: rectangle
    style: {
      fill: "#C73E1D"
      font-color: white
    }
  }
  
  x_minus_h: {
    label: "x - h"
    shape: rectangle
    style: {
      fill: "#C73E1D"
      font-color: white
    }
  }
  
  f_plus: {
    label: "f(x + h)"
    shape: oval
    style: {
      fill: "#E8B4BC"
      stroke: "#C73E1D"
      stroke-width: 2
    }
  }
  
  f_minus: {
    label: "f(x - h)"
    shape: oval
    style: {
      fill: "#E8B4BC"
      stroke: "#C73E1D"
      stroke-width: 2
    }
  }
  
  x_plus_h -> f_plus: "evaluate"
  x_minus_h -> f_minus: "evaluate"
}

# --- Section 3: Result Calculation ---
section_formula: {
  label: "Central Difference Formula"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  
  numerator: {
    label: "f(x + h) - f(x - h)"
    shape: rectangle
    style.fill: "#A5D6A7"
  }
  
  denominator: {
    label: "2h"
    shape: rectangle
    style.fill: "#A5D6A7"
  }
  
  division: {
    label: "÷"
    shape: circle
    style: {
      fill: "#2E7D32"
      font-color: white
    }
    width: 40
    height: 40
  }
  
  gradient: {
    label: "f'(x) ≈ Grad"
    shape: parallelogram
    style: {
      fill: "#2E7D32"
      font-color: white
      bold: true
    }
  }
  
  # Logic Flow
  _.section_evaluation.f_plus -> numerator: "subtract"
  _.section_evaluation.f_minus -> numerator
  
  numerator -> division
  _.section_input.h -> denominator: "multiply by 2"
  denominator -> division
  division -> gradient
}

# --- Section 4: Geometry ---
section_visual: {
  label: "Geometric Interpretation"
  style: {
    fill: "#FFF8E1"
    stroke: "#F9A825"
    stroke-width: 2
  }
  
  curve_info: |md
    **Slope Analysis**
    The secant line through
    (x-h, f(x-h)) and (x+h, f(x+h))
    approximates the tangent at x
  |
  
  tangent: {
    label: "True tangent\nslope = f'(x)"
    shape: parallelogram
    style: {
      fill: "#2E7D32"
      font-color: white
    }
  }
  
  secant: {
    label: "Secant line\nslope ≈ f'(x)"
    shape: parallelogram
    style: {
      fill: "#F9A825"
      font-color: white
      stroke-dash: 3
    }
  }
  
  secant -> tangent: "approximates"
}

# --- Global Logic Connections ---
section_input.func -> section_evaluation.x_plus_h
section_input.func -> section_evaluation.x_minus_h
section_input.h -> section_evaluation.x_plus_h
section_input.h -> section_evaluation.x_minus_h

# --- Section 5: Stability Analysis ---
section_error: {
  label: "Error Analysis & Numerical Stability"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }
  
  truncation: {
    label: "Truncation Error"
    shape: rectangle
    style.fill: "#CE93D8"
    
    formula: |md
      **Order: O(h²)**
      Taylor expansion cancels 
      the O(h) term:
      Error ≈ (h²/6)f'''(ξ)
    |
  }
  
  roundoff: {
    label: "Round-off Error"
    shape: rectangle
    style.fill: "#CE93D8"
    
    formula: |md
      **Order: O(ε/h)**
      Floating-point noise ε 
      is amplified by small h.
      Limit: 1e-16 for double.
    |
  }
  
  optimal: {
    label: "Optimal h Selection"
    shape: diamond
    style: {
      fill: "#7B1FA2"
      font-color: white
    }
    
    derivation: |md
      **h_opt ≈ √ε ≈ 1e-8**
      Minimizes combined 
      Total Error function.
    |
  }
  
  truncation -> optimal: "decreases\nwith h"
  roundoff -> optimal: "increases\nwith h"
}

# --- Section 6: Benchmarking ---
section_comparison: {
  label: "Method Accuracy Comparison"
  style: {
    fill: "#E0F7FA"
    stroke: "#00838F"
    stroke-width: 2
  }
  
  onesided: {
    label: "Forward Difference\n[f(x+h) - f(x)] / h"
    shape: rectangle
    style: {
      fill: "#B2EBF2"
      stroke: "#00838F"
    }
    accuracy: "Error: O(h)"
  }
  
  central: {
    label: "Central Difference\n[f(x+h) - f(x-h)] / 2h"
    shape: rectangle
    style: {
      fill: "#00838F"
      font-color: white
      bold: true
    }
    accuracy: "Error: O(h²)"
  }
  
  onesided -> central: "Quadratic scaling\nleads to significantly\nhigher precision"
}

# Cross-section Flow
section_formula.gradient -> section_error: "validate stability"
section_error -> section_comparison: "justifies choice"

legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#666"
  style.stroke-dash: 2
  
  note: |md
    ### Implementation Note
    The **Central Difference** uses points on both sides of **x**,
    meaning the first-order error terms cancel out in the 
    subtraction. This results in an approximation that is 
    orders of magnitude more stable than Forward or 
    Backward differences.
  |
}