vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: ||md
  # Gradient Verification Workflow (v2.1.0)
  ### Comparison of Analytical vs. Numerical Gradients in Autograd Engines
  *Implementation Spec for Verifying Backpropagation Chain Rule*
| {near: top-center}

shape: sequence_diagram

# -------------------------------------------------------------------------------------------
# PARTICIPANT DEFINITIONS
# -------------------------------------------------------------------------------------------
# Engineering classes for consistent technical styling
classes: {
  engine_component: {
    style: {
      stroke: "#2c3e50"
      stroke-width: 2
      font: mono
    }
  }
  storage_unit: {
    style: {
      fill: "#ecf0f1"
      stroke: "#2980b9"
      double-border: true
    }
  }
}

Test_Suite: Test Suite {
  shape: person
  tooltip: "Primary entry point for unit tests (PyTest/C++ GTest)"
}

Expression_Builder: Expression Builder {
  class: engine_component
  tooltip: "Parses infix notation into Computational Graph (DAG)"
  label: "Expression Builder\n(Parser/AST)"
}

Network: Neural Network Context {
  class: storage_unit
  tooltip: "sizeof=1024 bytes (Graph Header + Pointer Table)"
  label: "Network Context\n[Value Nodes]"
}

Forward_Pass: Forward Pass Logic {
  class: engine_component
  tooltip: "Executes operation kernels (ADD, MUL, POW)"
}

Loss_Function: Objective Function {
  class: engine_component
  tooltip: "Scalar output (L) for backward trigger"
}

Backward_Pass: Autograd Engine {
  class: engine_component
  tooltip: "Reverse-mode automatic differentiation engine"
  label: "Autograd Engine\n(Backprop)"
}

# Participant fix: Avoiding 'sql_table' shape inside sequence diagram to prevent compiler panic
# using Markdown table for high-fidelity byte layout visualization
Gradient_Store: Gradient Register File {
  class: storage_unit
  label: |md
    **Gradient Register File**
    | Offset | Field | Type |
    | :--- | :--- | :--- |
    | 0x00 | a.grad | f64 |
    | 0x08 | b.grad | f64 |
    | 0x10 | c.grad | f64 |
  ||
}

Numerical_Gradient: Finite Difference Estimator {
  class: engine_component
  tooltip: "High-precision O(h²) approximation"
}

Comparator: Gradient Checker {
  class: engine_component
  tooltip: "Evaluates relative error with L2 normalization"
}

# -------------------------------------------------------------------------------------------
# EXECUTION FLOW
# -------------------------------------------------------------------------------------------

Test_Suite."01: [INIT] Initialize Verification"

Setup: {
  Test_Suite -> Expression_Builder: "build_expression(raw_string)"
  Expression_Builder -> Network: "instantiate nodes(a, b, c)"
  Expression_Builder -> Forward_Pass: "Inject Expression Graph (DAG)"
}

Analytical_Path: {
  Forward_Pass -> Loss_Function: "compute_loss() -> float64(L)"
  Test_Suite -> Backward_Pass: "L.backward() // Backprop Trigger"
  
  # Chain rule recursive application
  Backward_Pass -> Gradient_Store: "update_grad(node, grad)" {
    style: {
      stroke: "#c0392b"
      stroke-width: 3
      stroke-dash: 2
      bold: true
      animated: true
    }
  }
  
  Gradient_Store."I/O: Atomic Write to 0x00..0x18" {
    style: {
      stroke: "#e67e22"
      font-size: 10
    }
  }
}

Numerical_Path: {
  Test_Suite -> Numerical_Gradient: "compute_numerical(f, x, h=1e-5)"
  
  # Vertical annotation for the numerical estimator logic
  Numerical_Gradient."Est: [f(x+h) - f(x-h)] / 2h" {
    style: {
      font-size: 11
      italic: true
      font-color: "#7f8c8d"
    }
  }
}

Comparison_Logic: {
  Gradient_Store -> Comparator: "pull_analytical_vector(128-bit SIMD)"
  Numerical_Gradient -> Comparator: "pull_numerical_vector(128-bit SIMD)"
  
  Comparator -> Comparator: "rel_err = |a-n| / max(|a|+|n|, ε)" {
    style: {
      stroke: "#2980b9"
      animated: true
      stroke-width: 2
    }
  }
  
  Comparator -> Test_Suite: "result: {passed, error_f64}" {
    style: {
      stroke: "#27ae60"
      stroke-width: 3
    }
    target-arrowhead: * {
      shape: diamond
      style.filled: true
    }
  }
}

Test_Suite."02: [DONE] Assert Tolerance (<1e-5)" {
  style: {
    stroke: "#27ae60"
    bold: true
    fill: "#e8f5e9"
  }
}

# -------------------------------------------------------------------------------------------
# TECHNICAL ANNOTATIONS
# -------------------------------------------------------------------------------------------

# Global Participant Overrides
*.style: {
  font: mono
  stroke-width: 1
}

# Engineering specifications for implementation reference
legend: ||md
  ### Engineering Specs: Gradient Verification
  - **Memory Layout**: `Gradient_Store` aligned to 64-bit boundaries. 
  - **Memory Consistency**: Writes must complete before `Comparator` pull.
  - **Epsilon (ε)**: `1e-8` applied to relative error denominator for numerical stability.
  - **Complexity Analysis**:
    - **Analytical**: `O(N)` traversal of the computational graph.
    - **Numerical**: `O(2 * N)` forward passes using centered difference method.
  - **Hardware Interface**: Uses 128-bit vector registers for gradient comparison.
| {
  near: bottom-right
  style: {
    fill: "#f8f9fa"
    stroke: "#bdc3c7"
    font-size: 11
    shadow: true
  }
}

# Visual indicators for critical path
(Forward_Pass -> Loss_Function)[0].style.stroke: "#3498db"
(Test_Suite -> Numerical_Gradient)[0].style.stroke-dash: 5
||