vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Neuron Computation Graph
  ## Forward Pass: y = σ(Σwᵢxᵢ + b)
| {near: top-center}
classes: {
  input: {
    shape: circle
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
  weight: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  intermediate: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      border-radius: 4
    }
  }
  bias: {
    shape: parallelogram
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
    }
  }
  accumulator: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 3
      border-radius: 8
      font: mono
    }
  }
  activation: {
    shape: hexagon
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 3
    }
  }
  output: {
    shape: circle
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      stroke-width: 3
      font-color: white
    }
  }
}
direction: right
input_layer: {
  x₁: {
    class: input
    label: "x₁"
  }
  x₂: {
    class: input
    label: "x₂"
  }
  x₃: {
    class: input
    label: "x₃"
  }
  x_dot: {
    label: "⋮"
    shape: text
  }
  xₙ: {
    class: input
    label: "xₙ"
  }
}
weight_layer: {
  w₁: {
    class: weight
    label: "w₁"
  }
  w₂: {
    class: weight
    label: "w₂"
  }
  w₃: {
    class: weight
    label: "w₃"
  }
  w_dot: {
    label: "⋮"
    shape: text
  }
  wₙ: {
    class: weight
    label: "wₙ"
  }
}
multiply_layer: {
  m₁: {
    class: intermediate
    label: "×"
  }
  m₂: {
    class: intermediate
    label: "×"
  }
  m₃: {
    class: intermediate
    label: "×"
  }
  m_dot: {
    label: "⋮"
    shape: text
  }
  mₙ: {
    class: intermediate
    label: "×"
  }
}
product_layer: {
  p₁: {
    class: intermediate
    label: "w₁x₁"
    style.fill: "#C8E6C9"
  }
  p₂: {
    class: intermediate
    label: "w₂x₂"
    style.fill: "#C8E6C9"
  }
  p₃: {
    class: intermediate
    label: "w₃x₃"
    style.fill: "#C8E6C9"
  }
  p_dot: {
    label: "⋮"
    shape: text
  }
  pₙ: {
    class: intermediate
    label: "wₙxₙ"
    style.fill: "#C8E6C9"
  }
}
bias_node: {
  b: {
    class: bias
    label: "b\n(bias)"
  }
}
sum_node: {
  summation: {
    class: accumulator
    label: "Σ + b\n(weighted sum)"
    width: 140
  }
}
activation_node: {
  act: {
    class: activation
    label: "σ(z)\ntanh/ReLU"
    width: 120
  }
}
output_node: {
  y: {
    class: output
    label: "y"
    width: 60
  }
}
# Input to multiply connections
input_layer.x₁ -> multiply_layer.m₁
input_layer.x₂ -> multiply_layer.m₂
input_layer.x₃ -> multiply_layer.m₃
input_layer.xₙ -> multiply_layer.mₙ
# Weight to multiply connections
weight_layer.w₁ -> multiply_layer.m₁
weight_layer.w₂ -> multiply_layer.m₂
weight_layer.w₃ -> multiply_layer.m₃
weight_layer.wₙ -> multiply_layer.mₙ
# Multiply to product
multiply_layer.m₁ -> product_layer.p₁: "Value" {
  style.stroke-dash: 2
}
multiply_layer.m₂ -> product_layer.p₂: "Value" {
  style.stroke-dash: 2
}
multiply_layer.m₃ -> product_layer.p₃: "Value" {
  style.stroke-dash: 2
}
multiply_layer.mₙ -> product_layer.pₙ: "Value" {
  style.stroke-dash: 2
}
# Products to sum
product_layer.p₁ -> sum_node.summation
product_layer.p₂ -> sum_node.summation
product_layer.p₃ -> sum_node.summation
product_layer.pₙ -> sum_node.summation
# Bias to sum
bias_node.b -> sum_node.summation
# Sum to activation
sum_node.summation -> activation_node.act: "z = Σwᵢxᵢ + b" {
  style.stroke-width: 2
  style.stroke: "#1976D2"
}
# Activation to output
activation_node.act -> output_node.y: "out" {
  style.stroke-width: 3
  style.stroke: "#4CAF50"
}
# Legend
legend: {
  near: bottom-right
  legend_title: {
    label: "Legend"
    shape: text
    style.font-size: 16
    style.bold: true
  }
  l1: {
    class: input
    label: "Input (xᵢ)"
  }
  l2: {
    class: weight
    label: "Weight (wᵢ)"
  }
  l3: {
    class: bias
    label: "Bias (b)"
  }
  l4: {
    class: activation
    label: "Activation (σ)"
  }
  l5: {
    class: output
    label: "Output (y)"
  }
}
# Mathematical formula annotation
formula: |md
  
  Forward Pass:
  z = Σᵢ(wᵢ × xᵢ) + b
  y = σ(z)
  Where:
  - xᵢ: input values
  - wᵢ: learnable weights
  - b: learnable bias
  - σ: activation function (tanh, ReLU, linear)
  - y: neuron output (Value object)
  
| {near: bottom-left}