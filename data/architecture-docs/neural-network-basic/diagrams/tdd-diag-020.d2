vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Layer Parallel Structure
  Multiple neurons process the same input vector independently
| {near: top-center}

classes: {
  input-node: {
    shape: circle
    width: 60
    height: 60
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      font-color: "#1A5276"
      font-size: 14
      bold: true
    }
  }
  neuron: {
    shape: rectangle
    width: 140
    height: 100
    style: {
      fill: "#E8F8F5"
      stroke: "#148F77"
      stroke-width: 2
      font-color: "#0E6655"
      font-size: 12
      border-radius: 8
    }
  }
  weight-label: {
    shape: text
    style: {
      font-size: 10
      font-color: "#7B7D7D"
      italic: true
    }
  }
  output-node: {
    shape: circle
    width: 50
    height: 50
    style: {
      fill: "#FDEDEC"
      stroke: "#CB4335"
      stroke-width: 2
      font-color: "#922B21"
      font-size: 12
      bold: true
    }
  }
  section-label: {
    shape: text
    style: {
      font-size: 16
      bold: true
      font-color: "#2C3E50"
    }
  }
}

direction: right

# Input vector
inputs: {
  class: section-label
  label: "Input Vector x"
  near: top-left
}

x0: {
  class: input-node
  label: "x₀"
}
x1: {
  class: input-node
  label: "x₁"
}
x2: {
  class: input-node
  label: "x₂"
}

# Weight matrix visualization
W_matrix: {
  label: "Weight Matrix W"
  shape: rectangle
  width: 180
  height: 160
  style: {
    fill: "#FEF9E7"
    stroke: "#D4AC0D"
    stroke-width: 2
    stroke-dash: 4
    font-color: "#7D6608"
    font-size: 14
    border-radius: 4
  }
  w_desc: |md
    **W ∈ ℝⁿᵒᵘᵗ×ⁿⁱⁿ**
    Each row = one neuron's weights
  | {
    style.font-size: 11
  }
}

# Neurons in parallel
neurons_container: {
  label: "Layer (nout=4 neurons)"
  style: {
    fill: "transparent"
    stroke: "#148F77"
    stroke-width: 2
    stroke-dash: 3
    border-radius: 12
  }
  neuron_0: {
    class: neuron
    label: |md
      **Neuron 0**
      y₀ = tanh(Σw₀ᵢxᵢ + b₀)
    |
  }
  neuron_1: {
    class: neuron
    label: |md
      **Neuron 1**
      y₁ = tanh(Σw₁ᵢxᵢ + b₁)
    |
  }
  neuron_2: {
    class: neuron
    label: |md
      **Neuron 2**
      y₂ = tanh(Σw₂ᵢxᵢ + b₂)
    |
  }
  neuron_3: {
    class: neuron
    label: |md
      **Neuron 3**
      y₃ = tanh(Σw₃ᵢxᵢ + b₃)
    |
  }
}

# Output vector
outputs: {
  class: section-label
  label: "Output Vector y"
  near: top-right
}

y0: {
  class: output-node
  label: "y₀"
}
y1: {
  class: output-node
  label: "y₁"
}
y2: {
  class: output-node
  label: "y₂"
}
y3: {
  class: output-node
  label: "y₃"
}

# Connections: inputs to all neurons (broadcast pattern)
x0 -> neurons_container.neuron_0: {
  label: "w₀₀"
  style: {
    stroke: "#5DADE2"
    stroke-width: 2
  }
}
x0 -> neurons_container.neuron_1: {
  label: "w₁₀"
  style: {
    stroke: "#5DADE2"
    stroke-width: 2
  }
}
x0 -> neurons_container.neuron_2: {
  label: "w₂₀"
  style: {
    stroke: "#5DADE2"
    stroke-width: 2
  }
}
x0 -> neurons_container.neuron_3: {
  label: "w₃₀"
  style: {
    stroke: "#5DADE2"
    stroke-width: 2
  }
}

x1 -> neurons_container.neuron_0: {
  label: "w₀₁"
  style: {
    stroke: "#58D68D"
    stroke-width: 2
  }
}
x1 -> neurons_container.neuron_1: {
  label: "w₁₁"
  style: {
    stroke: "#58D68D"
    stroke-width: 2
  }
}
x1 -> neurons_container.neuron_2: {
  label: "w₂₁"
  style: {
    stroke: "#58D68D"
    stroke-width: 2
  }
}
x1 -> neurons_container.neuron_3: {
  label: "w₃₁"
  style: {
    stroke: "#58D68D"
    stroke-width: 2
  }
}

x2 -> neurons_container.neuron_0: {
  label: "w₀₂"
  style: {
    stroke: "#BB8FCE"
    stroke-width: 2
  }
}
x2 -> neurons_container.neuron_1: {
  label: "w₁₂"
  style: {
    stroke: "#BB8FCE"
    stroke-width: 2
  }
}
x2 -> neurons_container.neuron_2: {
  label: "w₂₂"
  style: {
    stroke: "#BB8FCE"
    stroke-width: 2
  }
}
x2 -> neurons_container.neuron_3: {
  label: "w₃₂"
  style: {
    stroke: "#BB8FCE"
    stroke-width: 2
  }
}

# Connections: neurons to outputs
neurons_container.neuron_0 -> y0: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 2
  }
}
neurons_container.neuron_1 -> y1: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 2
  }
}
neurons_container.neuron_2 -> y2: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 2
  }
}
neurons_container.neuron_3 -> y3: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 2
  }
}

# Parameter count annotation
param_count: |md
  ## Parameter Count
  **Per neuron:** `nin` weights + 1 bias = `nin + 1`
  **Layer total:** `nout × (nin + 1)`
  **Example (nin=3, nout=4):**
  - 4 neurons × (3 weights + 1 bias) = **16 parameters**
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#F8F9F9"
    stroke: "#BDC3C7"
    stroke-width: 1
    border-radius: 4
    font-size: 11
  }
}

# Key insight
key_insight: |md
  ### Key Insight: Parallel Independence
  - All neurons receive the **same input vector** x
  - Each neuron computes **independently** (no connections between neurons)
  - Outputs form a **vector** y ∈ ℝⁿᵒᵘᵗ
  - This is **fully-connected** (dense) layer structure
| {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#EBF5FB"
    stroke: "#3498DB"
    stroke-width: 1
    border-radius: 4
    font-size: 11
  }
}

# Matrix notation
matrix_form: |md
  ### Matrix Form
  
  y = tanh(Wx + b)
  
  Where:
  - W: weight matrix (nout × nin)
  - x: input vector (nin × 1)
  - b: bias vector (nout × 1)
  - y: output vector (nout × 1)
| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#FEF5E7"
    stroke: "#E67E22"
    stroke-width: 1
    border-radius: 4
    font-size: 11
  }
}