vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Parameter Count Formula
  ## Counting Trainable Values in Neural Networks
| {
  near: top-center
  style.font-size: 24
}
direction: right
# ============================================
# LAYER PARAMETER FORMULA
# ============================================
layer_formula: {
  label: "Layer Parameter Count"
  style: {
    fill: "#E8F4FD"
    stroke: "#2563EB"
    stroke-width: 2
    border-radius: 8
  }
  formula_box: |md
    **Layer(nin, nout) Parameters:**
    
    params_per_layer = nout √Ч (nin + 1)
    
    Where:
    - `nout` = number of neurons
    - `nin` = inputs per neuron
    - `+1` = bias term per neuron
  | {
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
      border-radius: 4
    }
  }
}
# ============================================
# SINGLE LAYER BREAKDOWN
# ============================================
single_layer: {
  label: "Single Layer Anatomy"
  style: {
    fill: "#FEF3C7"
    stroke: "#D97706"
    stroke-width: 2
    border-radius: 8
  }
  direction: right
  inputs: {
    label: "Inputs\n(nin)"
    style.fill: "#D1FAE5"
    style.stroke: "#059669"
    in1: "xвВБ"
    in2: "xвВВ"
    in3: "..."
    inn: "xвВЩбµҐвВЩ"
  }
  layer_box: {
    label: "Layer\n(nout neurons)"
    style.fill: "#FEF9C3"
    style.stroke: "#CA8A04"
    neuron_0: {
      label: "Neuron 0"
      style.fill: "#FDE68A"
      w0: "wвВАвВА, wвВАвВБ, ..., wвВАвВЩ\n(weights: nin)"
      b0: "+ bвВА\n(bias: 1)"
    }
    neuron_1: {
      label: "Neuron 1"
      style.fill: "#FDE68A"
      w1: "wвВБвВА, wвВБвВБ, ..., wвВБвВЩ\n(weights: nin)"
      b1: "+ bвВБ\n(bias: 1)"
    }
    dots: {
      label: "вЛЃ"
      shape: text
      style.font-size: 24
    }
    neuron_n: {
      label: "Neuron nout-1"
      style.fill: "#FDE68A"
      wn: "wвВЩвВА, wвВЩвВБ, ..., wвВЩвВЩ\n(weights: nin)"
      bn: "+ bвВЩ\n(bias: 1)"
    }
  }
  outputs: {
    label: "Outputs\n(nout)"
    style.fill: "#E0E7FF"
    style.stroke: "#4F46E5"
    out1: "yвВА"
    out2: "yвВБ"
    dots2: "..."
    outn: "yвВЩвВТбµ§вВЬ"
  }
  inputs -> layer_box: "nin\nconnections\nper neuron"
  layer_box -> outputs: "nout\nvalues"
}
# ============================================
# PER-NEURON BREAKDOWN
# ============================================
neuron_breakdown: {
  label: "Per-Neuron Parameter Count"
  style: {
    fill: "#F3E8FF"
    stroke: "#9333EA"
    stroke-width: 2
    border-radius: 8
  }
  direction: down
  header: |md
    **Each Neuron has:**
  | {
    shape: text
    style.bold: true
  }
  weights_row: {
    direction: right
    weights_label: "nin weights"
    weights_detail: |md
      One weight per input:
      
      [wвВА, wвВБ, wвВВ, ..., wвВЩбµҐвВЩвВЛвВБ]
      
    | {
      style.fill: "#F5D0FE"
    }
  }
  plus: {
    shape: text
    label: "+"
    style.font-size: 28
    style.bold: true
  }
  bias_row: {
    direction: right
    bias_label: "1 bias"
    bias_detail: |md
      Single scalar:
      
      b
      
    | {
      style.fill: "#F5D0FE"
    }
  }
  equals: {
    shape: text
    label: "="
    style.font-size: 28
    style.bold: true
  }
  total_row: {
    direction: right
    total_label: "nin + 1"
    total_detail: |md
      **parameters per neuron**
    | {
      style.fill: "#A855F7"
      style.font-color: white
      style.bold: true
    }
  }
  weights_row -> plus -> bias_row -> equals -> total_row
}
# ============================================
# MLP TOTAL FORMULA
# ============================================
mlp_formula: {
  label: "MLP Total Parameter Count"
  style: {
    fill: "#ECFDF5"
    stroke: "#059669"
    stroke-width: 2
    border-radius: 8
  }
  formula: |md
    **MLP(nin, [hвВБ, hвВВ, ..., hвВЦ]) Parameters:**
    
    total = ќ£бµҐ (layer_i_outputs √Ч (layer_i_inputs + 1))
    
    Or equivalently:
    
    total = hвВБ√Ч(nin+1) + hвВВ√Ч(hвВБ+1) + ... + hвВЦ√Ч(hвВЦвВЛвВБ+1)
    
  | {
    style.fill: "#D1FAE5"
  }
}
# ============================================
# CONCRETE EXAMPLE
# ============================================
example: {
  label: "Concrete Example: MLP(3, [4, 4, 1])"
  style: {
    fill: "#FEE2E2"
    stroke: "#DC2626"
    stroke-width: 2
    border-radius: 8
  }
  direction: right
  layer0: {
    label: "Layer 0"
    style.fill: "#FECACA"
    calc0: |md
      **nin=3 вЖТ nout=4**
      
      4 √Ч (3 + 1) = 16
      
      - 4 neurons
      - Each: 3 weights + 1 bias
    | {
      style.fill: "#FEF2F2"
    }
  }
  layer1: {
    label: "Layer 1"
    style.fill: "#FECACA"
    calc1: |md
      **nin=4 вЖТ nout=4**
      
      4 √Ч (4 + 1) = 20
      
      - 4 neurons
      - Each: 4 weights + 1 bias
    | {
      style.fill: "#FEF2F2"
    }
  }
  layer2: {
    label: "Layer 2"
    style.fill: "#FECACA"
    calc2: |md
      **nin=4 вЖТ nout=1**
      
      1 √Ч (4 + 1) = 5
      
      - 1 neuron
      - 4 weights + 1 bias
    | {
      style.fill: "#FEF2F2"
    }
  }
  layer0 -> layer1 -> layer2
}
# ============================================
# TOTAL CALCULATION
# ============================================
total_calc: {
  label: "Total Parameter Calculation"
  style: {
    fill: "#1E3A5F"
    stroke: "#0EA5E9"
    stroke-width: 3
    border-radius: 8
    font-color: white
  }
  direction: down
  sum_label: |md
    **Sum Across All Layers:**
  | {
    shape: text
    style.font-color: white
    style.bold: true
  }
  sum_calc: |md
    
    Layer 0:  4 √Ч (3 + 1) = 16
    Layer 1:  4 √Ч (4 + 1) = 20
    Layer 2:  1 √Ч (4 + 1) =  5
    вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
    TOTAL:                   41
    
  | {
    style.fill: "#0F172A"
    style.font-color: "#22D3EE"
    style.font: mono
    style.border-radius: 4
  }
  result: |md
    ## **MLP(3, [4, 4, 1]) has 41 parameters**
  | {
    style.fill: "#059669"
    style.font-color: white
    style.bold: true
    style.border-radius: 4
  }
}
# ============================================
# VISUAL MATRIX REPRESENTATION
# ============================================
matrix_viz: {
  label: "Weight Matrix View (Layer 0)"
  style: {
    fill: "#F8FAFC"
    stroke: "#64748B"
    border-radius: 8
  }
  direction: down
  matrix_label: |md
    **Weight Matrix W (4√Ч3) + Bias Vector b (4):**
  | {
    shape: text
  }
  matrix: |md
    
         xвВА   xвВБ   xвВВ      bias
    вФМвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФР   вФМвФАвФАвФАвФАвФР
    вФВ wвВАвВА  wвВАвВБ  wвВАвВВ  вФВ + вФВ bвВА вФВ вЖТ yвВА
    вФВ wвВБвВА  wвВБвВБ  wвВБвВВ  вФВ   вФВ bвВБ вФВ вЖТ yвВБ
    вФВ wвВВвВА  wвВВвВБ  wвВВвВВ  вФВ   вФВ bвВВ вФВ вЖТ yвВВ
    вФВ wвВГвВА  wвВГвВБ  wвВГвВВ  вФВ   вФВ bвВГ вФВ вЖТ yвВГ
    вФФвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФШ   вФФвФАвФАвФАвФАвФШ
    12 weights + 4 biases = 16 parameters
    
  | {
    style.fill: "#F1F5F9"
    style.font: mono
  }
  note: |md
    *Each row = one neuron's parameters (3 weights + 1 bias)*
  | {
    shape: text
    style.italic: true
    style.font-size: 12
  }
}
# ============================================
# GENERAL FORMULA SUMMARY
# ============================================
summary: {
  label: "Quick Reference"
  style: {
    fill: "#1E293B"
    stroke: "#475569"
    border-radius: 8
    font-color: white
  }
  direction: right
  card1: |md
    ### Layer
    
    params = nout √Ч (nin + 1)
    
  | {
    style.fill: "#334155"
    style.border-radius: 4
  }
  card2: |md
    ### MLP
    
    params = ќ£ layers
    
  | {
    style.fill: "#334155"
    style.border-radius: 4
  }
  card3: |md
    ### Neuron
    
    params = nin + 1
    
  | {
    style.fill: "#334155"
    style.border-radius: 4
  }
}
# ============================================
# CONNECTIONS
# ============================================
layer_formula -> single_layer: "visualize"
single_layer -> neuron_breakdown: "break down"
neuron_breakdown -> mlp_formula: "extend"
mlp_formula -> example: "example"
example -> total_calc: "compute"
total_calc -> matrix_viz: "verify"
matrix_viz -> summary: "summarize"