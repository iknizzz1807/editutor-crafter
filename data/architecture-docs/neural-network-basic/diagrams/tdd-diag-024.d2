vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Why Non-Linearity Matters
  **Proof: Linear layers without activation collapse into a single linear transformation.**
| {
  near: top-center
  style: {
    font-size: 24
    stroke-width: 0
    fill: transparent
  }
}

direction: right

# Main content container to manage side-by-side comparison without 'near' dependency
comparison: {
  grid-columns: 2
  grid-gap: 60
  style.stroke-width: 0

  # --- LEFT COLUMN: COLLAPSING LINEAR CASE ---
  linear_case: {
    label: "WITHOUT ACTIVATION (COLLAPSES)"
    style: {
      fill: "#FDF2F2"
      stroke: "#D32F2F"
      stroke-width: 2
      border-radius: 12
      font-color: "#D32F2F"
      bold: true
    }

    proof_graph: {
      direction: right
      style.fill: transparent
      
      input_space: "Input Space\nx ∈ ℝⁿ" {
        shape: circle
        style.fill: "#E3F2FD"
        style.stroke: "#1976D2"
      }
      
      layer1: "Linear Layer 1\nW₁, b₁" {
        shape: rectangle
        style.fill: "#FFF3E0"
        style.stroke: "#F57C00"
      }
      
      hidden_no_act: "Hidden Layer\n(NO ACTIVATION)\n\nh = W₁x + b₁" {
        shape: rectangle
        style.fill: "#FFEBEE"
        style.stroke: "#D32F2F"
        style.stroke-dash: 4
      }
      
      layer2: "Linear Layer 2\nW₂, b₂" {
        shape: rectangle
        style.fill: "#FFF3E0"
        style.stroke: "#F57C00"
      }
      
      output: "Output\ny ∈ ℝᵐ" {
        shape: circle
        style.fill: "#E8F5E9"
        style.stroke: "#388E3C"
      }

      input_space -> layer1: "x"
      layer1 -> hidden_no_act
      hidden_no_act -> layer2: "h"
      layer2 -> output: "y"
    }

    collapse_text: |md
      ### Mathematical Proof of Collapse
      If we stack linear layers without non-linearities:
      1. $h = W_1 x + b_1$
      2. $y = W_2 h + b_2$
      
      Substitute (1) into (2):
      $y = W_2(W_1 x + b_1) + b_2$
      $y = (W_2 W_1)x + (W_2 b_1 + b_2)$
      
      Let $W' = W_2 W_1$ and $b' = W_2 b_1 + b_2$:
      **$y = W'x + b'$**
      
      **Conclusion:** Two layers are mathematically identical to one single layer.
    | {
      shape: rectangle
      style: {
        fill: "#FFFDE7"
        stroke: "#FBC02D"
        font-size: 14
      }
    }
  }

  # --- RIGHT COLUMN: EXPRESSIVE NON-LINEAR CASE ---
  expressive_case: {
    label: "WITH ACTIVATION (EXPRESSIVE)"
    style: {
      fill: "#F1F8E9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 12
      font-color: "#388E3C"
      bold: true
    }

    contrast_graph: {
      direction: right
      style.fill: transparent
      
      input_c: "Input Space\nx ∈ ℝⁿ" {
        shape: circle
        style.fill: "#E3F2FD"
        style.stroke: "#1976D2"
      }
      
      layer1c: "Linear Layer 1\nW₁, b₁" {
        shape: rectangle
        style.fill: "#FFF3E0"
        style.stroke: "#F57C00"
      }
      
      hidden_act: "Hidden Layer\nWITH ACTIVATION σ\n\nh = σ(W₁x + b₁)" {
        shape: rectangle
        style.fill: "#E8F5E9"
        style.stroke: "#388E3C"
        style.bold: true
        style.double-border: true
      }
      
      layer2c: "Linear Layer 2\nW₂, b₂" {
        shape: rectangle
        style.fill: "#FFF3E0"
        style.stroke: "#F57C00"
      }
      
      output_c: "Output\ny ∈ ℝᵐ" {
        shape: circle
        style.fill: "#E8F5E9"
        style.stroke: "#388E3C"
      }

      input_c -> layer1c: "x"
      layer1c -> hidden_act
      hidden_act -> layer2c: "h"
      layer2c -> output_c: "y"
    }

    benefit_text: |md
      ### Non-Linearity Power
      With an activation function $\sigma$ (e.g., ReLU, Tanh):
      1. $h = \sigma(W_1 x + b_1)$
      2. $y = W_2 h + b_2$
      
      Substituting results in:
      **$y = W_2 \sigma(W_1 x + b_1) + b_2$**
      
      **Why this works:**
      - $\sigma$ is **non-linear**: $\sigma(a+b) \neq \sigma(a) + \sigma(b)$
      - Matrix multiplication cannot "factor out" the $\sigma$
      - Each layer creates a unique feature transformation
      - **Result:** Neural network can approximate any function.
    | {
      shape: rectangle
      style: {
        fill: "#E8F5E9"
        stroke: "#388E3C"
        font-size: 14
      }
    }
  }
}

# --- VISUAL INTUITION SECTION ---
visual_intuition: {
  style: {
    fill: "#F8F9FA"
    stroke: "#DEE2E6"
    border-radius: 8
  }
  
  label: "Structural Intuition"
  
  linear_stack: {
    grid-columns: 5
    grid-gap: 15
    L1: "Linear Layer" { style.fill: "#FFF3E0" }
    plus1: "+" { shape: text }
    L2: "Linear Layer" { style.fill: "#FFF3E0" }
    equals: "=" { shape: text }
    single: "One Big Linear Layer" { 
      style.fill: "#FFEBEE"
      style.stroke: "#D32F2F"
      style.stroke-dash: 3
    }
  }

  spacer: { style.opacity: 0; height: 20 }

  nonlinear_stack: {
    grid-columns: 5
    grid-gap: 15
    NL1: "Linear" { style.fill: "#FFF3E0" }
    S1: "σ" { style.fill: "#C8E6C9"; style.bold: true; shape: circle }
    NL2: "Linear" { style.fill: "#FFF3E0" }
    S2: "σ" { style.fill: "#C8E6C9"; style.bold: true; shape: circle }
    Deep: "Deep Hierarchical Features" { 
      style.fill: "#E3F2FD" 
      style.stroke: "#1976D2"
      style.multiple: true
    }
  }
}

# --- CONCLUSION AT THE BOTTOM ---
conclusion: |md
  ### Final Insight for Architects
  **Depth without non-linearity is a computational waste.**
  A 1,000-layer network without activation functions has the exact same representational power as a single-layer perceptron. The activation function is the "engine" that enables deep learning by allowing the model to learn complex, non-planar boundaries in high-dimensional space.
| {
  near: bottom-center
  width: 800
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 3
    border-radius: 8
  }
}