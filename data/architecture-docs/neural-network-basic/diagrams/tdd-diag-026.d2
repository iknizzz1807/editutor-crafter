vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |'md
  # Weight Initialization Rationale
  ### Why random [-1, 1] initialization works for micrograd networks
'| {near: top-center}

direction: right

# === ZERO INITIALIZATION (WRONG) ===
zero_init: "Zero Initialization" {
  style.fill: "#FFB4AB"
  style.stroke: "#BA1A1A"
  style.font-color: "#410002"
  style.stroke-width: 2

  problem: "CRITICAL FAILURE: Symmetry" {
    shape: text
    style.font-color: "#BA1A1A"
    style.bold: true
    style.font-size: 18
  }

  neuron1: "Neuron 1 (Top)" {
    w: "weights = [0.0, 0.0, 0.0]"
    b: "bias = 0.0"
    style.fill: "#FFDAD6"
  }
  neuron2: "Neuron 2 (Mid)" {
    w: "weights = [0.0, 0.0, 0.0]"
    b: "bias = 0.0"
    style.fill: "#FFDAD6"
  }
  neuron3: "Neuron 3 (Bot)" {
    w: "weights = [0.0, 0.0, 0.0]"
    b: "bias = 0.0"
    style.fill: "#FFDAD6"
  }

  result: "Symmetry Trap" {
    label: "All neurons compute IDENTICAL values\n→ Gradients are mathematically identical\n→ Updates are identical every iteration\n→ Hidden layer collapses to 1 effective neuron"
    style.fill: "#FFDAD6"
    style.stroke: "#BA1A1A"
    style.border-radius: 5
  }

  neuron1 -> result: "f(x) = 0"
  neuron2 -> result: "f(x) = 0"
  neuron3 -> result: "f(x) = 0"
}

# === LARGE INITIALIZATION (WRONG) ===
large_init: "Large Initialization" {
  style.fill: "#FFB4AB"
  style.stroke: "#BA1A1A"
  style.font-color: "#410002"
  style.stroke-width: 2

  problem: "CRITICAL FAILURE: Saturation" {
    shape: text
    style.font-color: "#BA1A1A"
    style.bold: true
    style.font-size: 18
  }

  weights_large: "Large Weights" {
    label: "w ∈ [-100, 100]\n(High Variance)"
    style.fill: "#FFDAD6"
  }

  act_large: "Dot Product" {
    label: "act = Σ(wᵢ·xᵢ) + b\n\nExample:\nact = (100 * 1) + (-50 * 2) + (75 * 3)\nact = 225"
    style.fill: "#FFDAD6"
  }

  tanh_large: "Tanh Activation" {
    label: "tanh(225) ≈ 1.0000\n(Saturated State)"
    style.fill: "#FFDAD6"
  }

  grad_large: "Local Gradient" {
    label: "∂L/∂act = (1 - tanh²(act))\n∂L/∂act = (1 - 1.0²) ≈ 0.0"
    style.fill: "#FFB4AB"
    style.stroke: "#BA1A1A"
    style.bold: true
  }

  weights_large -> act_large: "Input Flow"
  act_large -> tanh_large: "Non-linearity"
  tanh_large -> grad_large: "Vanishing Gradient!" {
    style.stroke: "#BA1A1A"
    style.stroke-width: 4
    style.animated: true
  }
}

# === RANDOM [-1, 1] INITIALIZATION (CORRECT) ===
random_init: "Random [-1, 1] Initialization ✓" {
  style.fill: "#D4EDDA"
  style.stroke: "#155724"
  style.font-color: "#155724"
  style.stroke-width: 2

  benefit1: "BENEFIT 1: Symmetry Breaking" {
    shape: text
    style.font-color: "#155724"
    style.bold: true
    style.font-size: 18
  }

  r_neuron1: "Neuron 1 (Unique)" {
    w: "w = [0.23, -0.71, 0.45]"
    b: "b = 0.12"
    style.fill: "#C3F7C8"
  }
  r_neuron2: "Neuron 2 (Unique)" {
    w: "w = [-0.56, 0.89, -0.33]"
    b: "b = -0.67"
    style.fill: "#C3F7C8"
  }
  r_neuron3: "Neuron 3 (Unique)" {
    w: "w = [0.11, 0.44, -0.92]"
    b: "b = 0.78"
    style.fill: "#C3F7C8"
  }

  r_result: "Divergent Learning" {
    label: "Neurons compute UNIQUE values\n→ Distinct gradient directions\n→ Independent weight optimization\n→ Utilizes full learning capacity"
    style.fill: "#C3F7C8"
    style.stroke: "#155724"
    style.border-radius: 5
  }

  r_neuron1 -> r_result: "f₁(x)"
  r_neuron2 -> r_result: "f₂(x)"
  r_neuron3 -> r_result: "f₃(x)"
}

# === RANDOM INIT - BENEFIT 2 ===
random_init2: "Unsaturated Signal ✓" {
  style.fill: "#D4EDDA"
  style.stroke: "#155724"
  style.font-color: "#155724"
  style.stroke-width: 2

  benefit2: "BENEFIT 2: Signal Propagation" {
    shape: text
    style.font-color: "#155724"
    style.bold: true
    style.font-size: 18
  }

  weights_good: "Small Weights" {
    label: "w ∈ [-1.0, 1.0]\n(Low Variance)"
    style.fill: "#C3F7C8"
  }

  act_good: "Dot Product" {
    label: "act = Σ(wᵢ·xᵢ) + b\n\nExample:\nact = (0.23*1) + (-0.11*2) + (0.05*3)\nact = 0.16"
    style.fill: "#C3F7C8"
  }

  tanh_good: "Tanh Activation" {
    label: "tanh(0.16) ≈ 0.158\n(Linear Region)"
    style.fill: "#C3F7C8"
  }

  grad_good: "Local Gradient" {
    label: "∂L/∂act = (1 - tanh²(0.16))\n∂L/∂act = (1 - 0.025) ≈ 0.975"
    style.fill: "#D4EDDA"
    style.stroke: "#155724"
    style.bold: true
  }

  weights_good -> act_good: "Input Flow"
  act_good -> tanh_good: "Non-linearity"
  tanh_good -> grad_good: "Strong Gradient Flow" {
    style.stroke: "#155724"
    style.stroke-width: 4
    style.animated: true
  }
}

# === SUMMARY TABLE ===
summary: "Comparison Matrix" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  
  content: |'md
    | Initialization Strategy | Symmetry Broken | Avoids Saturation | Learning Capability |
    | :--- | :---: | :---: | :--- |
    | **Zero Initialization** | ❌ NO | ✅ YES | **Fails** (Redundant Neurons) |
    | **Large [-100, 100]** | ✅ YES | ❌ NO | **Fails** (Dead Neurons/Vanishing Grad) |
    | **Random [-1, 1]** | ✅ YES | ✅ YES | **Success** (Optimal Gradient Flow) |

    ### The Micrograd "Sweet Spot":
    1. **Small Magnitude:** Keeps `act` close to 0 where `tanh` is approximately linear.
    2. **High Gradient:** `∂tanh/∂x` is maximized (≈1.0) when `x` is near zero.
    3. **Implementation:** `w = [Value(random.uniform(-1, 1)) for _ in range(nin)]`
  '|
}

# === FORMULA BOX ===
formula_box: "Mathematical Proof of Saturation" {
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  
  details: |'md
    ### Tanh Gradient Decay
    The backward pass relies on the chain rule:
    $$\frac{\partial L}{\partial w} = \frac{\partial L}{\partial out} \cdot \frac{\partial out}{\partial act} \cdot \frac{\partial act}{\partial w}$$

    For Tanh:
    $$\frac{\partial out}{\partial act} = 1 - \tanh^2(act)$$

    **Case A: $|act| \gg 1$ (Saturation)**
    If $act = 10$, $\tanh(10) \approx 0.99999$.
    Then $1 - 0.99999^2 \approx 0$.
    The gradient is "squashed" to zero, killing the update to $w$.

    **Case B: $|act| \approx 0$ (Linear Region)**
    If $act = 0$, $\tanh(0) = 0$.
    Then $1 - 0^2 = 1.0$.
    The gradient passes through at full strength.
  '|
}

# === CONNECTIONS ===
zero_init -> random_init: "FIX: Inject Entropy" {
  style.stroke: "#155724"
  style.stroke-dash: 5
}
large_init -> random_init2: "FIX: Scale Variance" {
  style.stroke: "#155724"
  style.stroke-dash: 5
}

random_init -> summary
random_init2 -> summary
summary -> formula_box

# === FOOTNOTE ===
note: |'md
  **Engineer's Note:** For larger networks (Deep Learning), we use **Xavier (Glorot)** or **He Initialization** 
  which scales the range by $1/\sqrt{n_{in}}$ to maintain variance across many layers. 
  For Micrograd's shallow MLP, `uniform(-1, 1)` is a robust heuristic.
'| {
  near: bottom-center
  shape: text
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.italic: true
}