vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SGD Update Mechanics
  ## Single Parameter Update: p.data ← p.data - η × p.grad
| {near: top-center}
direction: right
classes: {
  before_box: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
  after_box: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
  gradient_box: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
  operation_box: {
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      border-radius: 8
    }
  }
  result_box: {
    style: {
      fill: "#E0F2F1"
      stroke: "#009688"
      stroke-width: 2
      border-radius: 8
      font: mono
    }
  }
}
section_before: "BEFORE UPDATE" {
  param_before: {
    class: before_box
    label: |md
      **Parameter p**
      `p.data = 2.000`
      `p.grad = +0.500`
    |
  }
  param_before_explanation: |md
    Parameter has current value and computed gradient from backward pass.
    Gradient points toward *higher* loss (uphill direction).
  | {
    shape: text
    style.font-size: 12
    style.font-color: "#666666"
  }
}
section_gradient: "GRADIENT INTERPRETATION" {
  gradient_direction: {
    class: gradient_box
    label: |md
      **Gradient Direction**
      `grad = +0.500` means:
      - Increasing p increases loss
      - Decreasing p decreases loss
      - ∂L/∂p = +0.500 (slope is positive)
    |
  }
  loss_landscape: {
    shape: hexagon
    label: |md
      **Loss Landscape**
      At p=2.0, the loss curve slopes upward.
      We want to move in the *opposite* direction.
    |
    style: {
      fill: "#FFF8E1"
      stroke: "#FFC107"
      stroke-width: 2
    }
  }
  gradient_direction -> loss_landscape: "interprets" {
    style.stroke-dash: 3
    style.stroke: "#FF9800"
  }
}
section_operation: "SGD UPDATE OPERATION" {
  formula: {
    class: operation_box
    label: |md
      **Update Formula**
      
      p.data = p.data - η × p.grad
      p.data = 2.000 - 0.1 × 0.500
      p.data = 2.000 - 0.050
      p.data = 1.950
      
    |
  }
  learning_rate: {
    shape: diamond
    label: |md
      **Learning Rate η = 0.1**
      Controls step size.
      Too large: overshoot minimum
      Too small: slow convergence
    |
    style: {
      fill: "#FCE4EC"
      stroke: "#E91E63"
      stroke-width: 2
    }
  }
  formula -> learning_rate: "scaled by" {
    style.stroke: "#9C27B0"
    style.stroke-dash: 3
  }
}
section_after: "AFTER UPDATE" {
  param_after: {
    class: after_box
    label: |md
      **Parameter p (updated)**
      `p.data = 1.950`
      `p.grad = +0.500` (unchanged)
    |
  }
  delta: {
    class: result_box
    label: |md
      **Change Applied**
      `Δp = -0.050`
      Negative change because:
      - Gradient was positive (+0.5)
      - We subtract η × grad
      - Moved toward lower loss
    |
  }
}
param_before -> gradient_direction: "analyze" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
gradient_direction -> formula: "compute update" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
formula -> param_after: "apply" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  style.animated: true
}
param_after -> delta: "measure" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}
annotation_critical: |md
  **⚠️ CRITICAL IMPLEMENTATION DETAIL**
  The update MUST mutate `p.data` directly:
  python
  # CORRECT: Direct mutation
  p.data -= lr * p.grad
  # WRONG: Creates new Value, doesn't update original!
  p = p - Value(lr) * Value(p.grad)
  
  Direct mutation avoids adding the update to the computational graph,
  preventing memory leaks during long training runs.
| {
  near: bottom-center
  shape: text
  style: {
    font-size: 11
    font-color: "#C62828"
    fill: "#FFEBEE"
    stroke: "#EF5350"
    stroke-width: 1
    border-radius: 4
  }
}
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#E0E0E0"
  style.border-radius: 8
  legend_title: "Key Insight"
  legend_text: |md
    • Gradient points **uphill** (toward higher loss)
    • SGD **subtracts** gradient (moves downhill)
    • Learning rate **scales** the step size
    • Parameter **mutated in-place** (no new Value)
  | {shape: text}
}