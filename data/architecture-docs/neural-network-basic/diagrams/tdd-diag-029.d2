vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Training Loop Data Flow
  Complete cycle: Forward → Loss → Backward → Update
| {near: top-center}
classes: {
  data_block: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 4
    }
  }
  compute_block: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      border-radius: 4
    }
  }
  gradient_block: {
    style: {
      fill: "#FCE4EC"
      stroke: "#E91E63"
      stroke-width: 2
      border-radius: 4
    }
  }
  update_block: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      border-radius: 4
    }
  }
  epoch_container: {
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      stroke-dash: 3
      border-radius: 8
    }
  }
}
direction: right
epoch: "Training Epoch" {
  class: epoch_container
  # STEP 1: INPUT DATA
  inputs: "Input Data\nX, Y" {
    class: data_block
    width: 120
  }
  # STEP 2: FORWARD PASS
  forward: "Forward Pass" {
    class: compute_block
    width: 160
    network_call: |md
      `predictions = [network(x) for x in X]`
    |
  }
  # STEP 3: LOSS COMPUTATION
  loss_compute: "Loss Computation" {
    class: compute_block
    width: 180
    mse_formula: |md
      `loss = mse_loss(predictions, Y)`
      **MSE = (1/N) × Σ(yᵢ - ŷᵢ)²**
    |
  }
  # STEP 4: ZERO GRADIENTS
  zero_grads: "Zero Gradients" {
    class: gradient_block
    width: 160
    zero_call: |md
      `optimizer.zero_grad()`
      Sets all p.grad = 0.0
    |
  }
  # STEP 5: BACKWARD PASS
  backward_pass: "Backward Pass" {
    class: gradient_block
    width: 180
    backward_call: |md
      `loss.backward()`
      **Topological sort → chain rule**
      Populates ∂L/∂p for all params
    |
  }
  # STEP 6: PARAMETER UPDATE
  param_update: "Parameter Update" {
    class: update_block
    width: 180
    step_call: |md
      `optimizer.step()`
      **p.data -= η × p.grad**
      Direct mutation (no graph growth)
    |
  }
  # Flow connections
  inputs -> forward: "X vectors" {
    style: {
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
  forward -> loss_compute: "predictions\n(list[Value])" {
    style: {
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  loss_compute -> zero_grads: "loss\n(Value)" {
    style: {
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  zero_grads -> backward_pass: "gradients\nzeroed" {
    style: {
      stroke: "#E91E63"
      stroke-width: 2
    }
  }
  backward_pass -> param_update: "gradients\ncomputed" {
    style: {
      stroke: "#E91E63"
      stroke-width: 2
    }
  }
}
# Show loop back
param_update -> inputs: "Repeat for\nnext epoch" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
    stroke-dash: 5
    animated: true
  }
}
# Critical order annotation
order_note: |md
  ## ⚠️ CRITICAL ORDER
  1. **Forward**: Compute predictions
  2. **Loss**: Measure error
  3. **Zero_grad**: Reset gradients (BEFORE backward!)
  4. **Backward**: Compute gradients
  5. **Step**: Update parameters
  Wrong order = broken training!
| {
  near: bottom-center
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    border-radius: 8
  }
}
# Data structures detail
structures: "Data Structures" {
  direction: right
  x_structure: "X: list[list[float]]\n[[0,0], [0,1], [1,0], [1,1]]" {
    style.fill: "#E3F2FD"
  }
  y_structure: "Y: list[float]\n[0, 1, 1, 0]  (XOR)" {
    style.fill: "#E3F2FD"
  }
  pred_structure: "predictions: list[Value]\nEach connected to graph" {
    style.fill: "#FFF8E1"
  }
  loss_structure: "loss: Value\nScalar, connected to graph" {
    style.fill: "#FFF8E1"
  }
  params_structure: "parameters: list[Value]\nweights + biases" {
    style.fill: "#E8F5E9"
  }
}
# Gradient flow detail
gradient_flow: "Gradient Flow" {
  direction: right
  seed: "loss.grad = 1.0\n(seed gradient)" {
    style.fill: "#FCE4EC"
  }
  propagate: "Chain rule:\n∂L/∂p = Σ ∂L/∂out × ∂out/∂p" {
    style.fill: "#FCE4EC"
  }
  accumulate: "Accumulation:\np.grad += local_grad\n(uses += not =)" {
    style.fill: "#FCE4EC"
  }
  seed -> propagate -> accumulate
}
# SGD detail
sgd_detail: "SGD Update Formula" {
  direction: right
  formula: |md
    
    p.data = p.data - η × p.grad
    where:
      η = learning_rate (e.g., 0.1)
      p.grad = ∂loss/∂p
    
  | {
    style: {
      fill: "#E8F5E9"
      border-radius: 4
    }
  }
  correct: "✓ CORRECT:\np.data -= lr * p.grad\n(direct mutation)" {
    style: {
      fill: "#C8E6C9"
      border-radius: 4
    }
  }
  wrong: "✗ WRONG:\np = p - lr * p.grad\n(creates new Value!)" {
    style: {
      fill: "#FFCDD2"
      border-radius: 4
    }
  }
}