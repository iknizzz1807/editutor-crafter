vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Learning Rate (η) Effects on Neural Network Training
  *Technical Analysis of Gradient Descent Convergence*
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

direction: right

# === GLOBAL CLASSES ===
classes: {
  chart_point: {
    shape: circle
    width: 10
    height: 10
  }
  chart_container: {
    style: {
      stroke-width: 1
      stroke-dash: 2
      fill: "#ffffff"
      fill-pattern: grain
    }
  }
  metric_box: {
    style: {
      border-radius: 4
      font-size: 12
    }
  }
}

# === SECTION 1: TOO HIGH ===
too_high: {
  label: "CASE A: η = 10.0 (Overshooting)"
  style: {
    fill: "#FFE4E1"
    stroke: "#DC143C"
    stroke-width: 2
    border-radius: 8
  }

  chart_area: {
    class: chart_container
    
    # Simulating Divergence (Oscillating with increasing amplitude)
    p0: { class: chart_point; style.fill: "#DC143C" }
    p1: { class: chart_point; style.fill: "#DC143C" }
    p2: { class: chart_point; style.fill: "#DC143C" }
    p3: { class: chart_point; style.fill: "#DC143C" }
    p4: { class: chart_point; style.fill: "#DC143C" }
    p5: { class: chart_point; style.fill: "#DC143C" }

    p0 -> p1 -> p2 -> p3 -> p4 -> p5: {
      style: {
        stroke: "#DC143C"
        stroke-width: 3
        animated: true
      }
    }
  }

  analysis: |md
    ### Divergence Analysis
    - **Update:** $w_{t+1} = w_t - 10.0 \cdot \nabla L$
    - **Behavior:** Step size exceeds the width of the loss bowl.
    - **Status:** **CRITICAL FAILURE**
    - Loss explodes ($L \to \infty$)
  | {
    class: metric_box
  }
}

# === SECTION 2: TOO LOW ===
too_low: {
  label: "CASE B: η = 0.0001 (Vanishing Progress)"
  style: {
    fill: "#FFF8DC"
    stroke: "#DAA520"
    stroke-width: 2
    border-radius: 8
  }

  chart_area: {
    class: chart_container
    
    # Simulating Stagnation (Nearly horizontal line)
    lp0: { class: chart_point; style.fill: "#DAA520" }
    lp1: { class: chart_point; style.fill: "#DAA520" }
    lp2: { class: chart_point; style.fill: "#DAA520" }
    lp3: { class: chart_point; style.fill: "#DAA520" }
    lp4: { class: chart_point; style.fill: "#DAA520" }
    lp5: { class: chart_point; style.fill: "#DAA520" }

    lp0 -> lp1 -> lp2 -> lp3 -> lp4 -> lp5: {
      style: {
        stroke: "#DAA520"
        stroke-width: 2
      }
    }
  }

  analysis: |md
    ### Stagnation Analysis
    - **Update:** $w_{t+1} = w_t - 0.0001 \cdot \nabla L$
    - **Behavior:** Steps are too small to escape local minima or reach global minima.
    - **Status:** **INEFFICIENT**
    - Computational waste; "Flat" loss curve.
  | {
    class: metric_box
  }
}

# === SECTION 3: OPTIMAL ===
optimal: {
  label: "CASE C: η = 0.1 (Optimal Convergence)"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }

  chart_area: {
    class: chart_container
    
    # Simulating smooth exponential decay to zero
    gp0: { class: chart_point; style.fill: "#2E7D32" }
    gp1: { class: chart_point; style.fill: "#2E7D32" }
    gp2: { class: chart_point; style.fill: "#2E7D32" }
    gp3: { class: chart_point; style.fill: "#2E7D32" }
    gp4: { class: chart_point; style.fill: "#2E7D32" }
    gp5: { class: chart_point; style.fill: "#2E7D32" }

    gp0 -> gp1 -> gp2 -> gp3 -> gp4 -> gp5: {
      style: {
        stroke: "#2E7D32"
        stroke-width: 3
      }
    }
  }

  analysis: |md
    ### Convergence Analysis
    - **Update:** $w_{t+1} = w_t - 0.1 \cdot \nabla L$
    - **Behavior:** Steps are proportional to the gradient, slowing down as minimum is reached.
    - **Status:** **SUCCESS**
    - Robust training; Generalizable weights.
  | {
    class: metric_box
  }
}

# === ANNOTATIONS & LEGEND ===

formula_overlay: |md
  ## Gradient Descent Update Rule
  $\theta_{next} = \theta_{curr} - \eta \cdot \frac{\partial L}{\partial \theta}$
  
  Where:
  - $\theta$: Parameters (Weights/Biases)
  - $\eta$: Learning Rate (Step Size)
  - $\nabla L$: Loss Gradient
| {
  near: bottom-left
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    border-radius: 8
  }
}

legend: {
  near: top-right
  style: {
    fill: "#F8F9FA"
    stroke: "#CED4DA"
    border-radius: 4
  }
  
  title: "Visual Guide"
  diverge: "Divergent Path" {
    style.font-color: "#DC143C"
    style.bold: true
  }
  stagnate: "Stagnant Path" {
    style.font-color: "#DAA520"
    style.bold: true
  }
  converge: "Convergent Path" {
    style.font-color: "#2E7D32"
    style.bold: true
  }
}

# Structural Layout Helper
too_high -> too_low -> optimal: {
  style.stroke: transparent
}