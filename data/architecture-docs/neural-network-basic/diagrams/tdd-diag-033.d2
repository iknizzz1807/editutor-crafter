direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    header_purple: "#7C3AED"
    data_blue: "#3B82F6"
    pointer_orange: "#F97316"
    padding_gray: "#94A3B8"
    boundary_fill: "linear-gradient(135deg, #E0F2FE 0%, #E0F2FE 45%, #FEE2E2 55%, #FEE2E2 100%)"
    background: "#F8FAFC"
  }
}

title: |md
  # XOR Decision Boundary & Neural Topology
  ## Non-Linear Manifold Mapping Specification
  *Intel® Manual Quality Reference - Revision 1.0.5*
| {near: top-center}

# 1. DECISION MANIFOLD (INPUT SPACE TOPOLOGY)
DecisionSpace: {
  label: "Decision Manifold (2D Feature Space)"
  style: {
    stroke-width: 2
    fill: ${colors.background}
    border-radius: 12
    shadow: true
  }

  # Input Dimension Reference
  x_axis: "Input Feature x₁ ∈ [0, 1]" {
    shape: text
    style.font-size: 16
    style.bold: true
  }
  
  y_axis: "Input Feature x₂ ∈ [0, 1]" {
    shape: text
    style.font-size: 16
    style.bold: true
  }

  # Manifold Geometry
  boundary: {
    shape: hexagon
    width: 500
    height: 500
    label: "Non-Linear Hyperplane Projection\nh(x) = σ(W₂ · tanh(W₁x + b₁) + b₂)"
    style: {
      fill: ${colors.boundary_fill}
      stroke: "#475569"
      stroke-width: 4
      stroke-dash: 6
      opacity: 0.7
    }
  }

  # Ground Truth Class Clusters (Static Encodings)
  class0_00: "(0,0) → 0" {
    shape: circle
    width: 100
    style: {
      fill: ${colors.data_blue}
      stroke: "#1E40AF"
      stroke-width: 5
      font-color: white
      bold: true
      shadow: true
    }
  }
  
  class0_11: "(1,1) → 0" {
    shape: circle
    width: 100
    style: {
      fill: ${colors.data_blue}
      stroke: "#1E40AF"
      stroke-width: 5
      font-color: white
      bold: true
      shadow: true
    }
  }

  class1_01: "(0,1) → 1" {
    shape: diamond
    width: 115
    height: 115
    style: {
      fill: "#EF4444"
      stroke: "#991B1B"
      stroke-width: 5
      font-color: white
      bold: true
      shadow: true
    }
  }
  
  class1_10: "(1,0) → 1" {
    shape: diamond
    width: 115
    height: 115
    style: {
      fill: "#EF4444"
      stroke: "#991B1B"
      stroke-width: 5
      font-color: white
      bold: true
      shadow: true
    }
  }
}

# 2. ARCHITECTURE & MEMORY SUBSYSTEM
Network: {
  near: top-right
  style: {
    fill: "#FFFFFF"
    stroke: "#334155"
    border-radius: 10
    double-border: true
  }

  Header: "MLP(2, [4], 1) Neural Architecture" {
    style.bold: true
    style.font-size: 18
  }
  
  # Memory Layout Specification (Intel Manual Quality)
  # Total size = 17 Params (FP32) = 68 Bytes
  MemoryMap: {
    shape: sql_table
    label: "Parameter Weight/Bias Tensor Layout (68 Bytes)"
    style.fill: ${colors.header_purple}
    
    "0x00": "W₁ Matrix [2x4]" {
      constraint: "32B (8x FP32)"
      style.fill: ${colors.data_blue}
    }
    "0x20": "b₁ Bias Vector [4]" {
      constraint: "16B (4x FP32)"
      style.fill: ${colors.pointer_orange}
    }
    "0x30": "W₂ Matrix [4x1]" {
      constraint: "16B (4x FP32)"
      style.fill: ${colors.data_blue}
    }
    "0x40": "b₂ Bias Scalar [1]" {
      constraint: "4B (1x FP32)"
      style.fill: ${colors.pointer_orange}
    }
    "0x44": "Padding / Alignment" {
      constraint: "60B (to cache line)"
      style.fill: ${colors.padding_gray}
    }
  }

  Topology: |md
    ### Layer Definitions
    - **L₀ (Input):** Feature Vector $\mathbf{x} \in \mathbb{R}^2$
    - **L₁ (Hidden):** 4 Units, $\phi = \tanh$
    - **L₂ (Output):** 1 Unit, $\phi = \sigma$
    - **sizeof:** 68 bytes (Fits in single L1 cache line)
  |
}

# 3. TRAINING & CONVERGENCE SPECIFICATIONS
Training: {
  near: bottom-left
  style: {
    fill: "#FFFBEB"
    stroke: "#B45309"
    border-radius: 8
  }
  Stats: |md
    ### Execution Metadata
    - **Optimizer:** Adam ($\alpha=0.01, \beta_1=0.9, \beta_2=0.999$)
    - **Loss Function:** Binary Cross-Entropy
    - **Convergence Criterion:** $\Delta\mathcal{L} < 10^{-6}$
    - **Final Epoch:** 2,140
    - **Final Global Loss:** 0.000412
  |
}

# 4. MATHEMATICAL FORMULATION
InferenceMath: {
  near: bottom-right
  style: {
    fill: "#F0FDFA"
    stroke: "#0D9488"
    border-radius: 8
    opacity: 0.95
  }
  Latex: |latex
    \begin{aligned}
    \mathbf{z}^{(1)} &= \mathbf{W}^{(1)}\mathbf{x} + \mathbf{b}^{(1)} \\
    \mathbf{a}^{(1)} &= \tanh(\mathbf{z}^{(1)}) \\
    \hat{y} &= \sigma(\mathbf{W}^{(2)}\mathbf{a}^{(1)} + \mathbf{b}^{(2)}) \\
    \mathcal{L} &= -(y\log\hat{y} + (1-y)\log(1-\hat{y}))
    \end{aligned}
  |
}

# 5. COMPONENT RELATIONSHIPS
Network.MemoryMap -> DecisionSpace.boundary: "Parameters θ define hyperplane topology" {
  style.stroke: "#64748B"
  style.stroke-width: 3
  style.animated: true
}

DecisionSpace.class0_00 -> DecisionSpace.boundary: "Region Mapping α" {style.stroke-dash: 2}
DecisionSpace.class1_01 -> DecisionSpace.boundary: "Region Mapping β" {style.stroke-dash: 2}

Training.Stats -> Network: "Gradient Descent updates θ" {
  style.stroke: "#B45309"
  style.stroke-dash: 3
}

# 6. LEGEND
Legend: {
  near: top-left
  style: {
    fill: white
    stroke: "#94A3B8"
    border-radius: 6
  }
  c0: "Class 0 (XOR False)" {
    shape: circle
    width: 20
    style.fill: ${colors.data_blue}
  }
  c1: "Class 1 (XOR True)" {
    shape: diamond
    width: 22
    height: 22
    style.fill: "#EF4444"
  }
  bound: "Non-Linear Boundary" {
    style.stroke-dash: 4
    style.stroke: grey
  }
}