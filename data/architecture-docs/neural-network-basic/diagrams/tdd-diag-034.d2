direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Neural Network Architecture: Value Object and Computational Graph Analysis" {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --- Root Classes Definition ---
classes: {
  # Memory Layout Classes
  field-label: {
    style: {
      fill: "#7C3AED"
      font-color: white
      font-size: 11
      font: mono
    }
  }
  data-field: { style: { fill: "#E8F4FC"; stroke: "#3B82F6"; font: mono } }
  grad-field: { style: { fill: "#FFE5E5"; stroke: "#FF6B6B"; font: mono } }
  prev-field: { style: { fill: "#FFF3E0"; stroke: "#FFA500"; font: mono } }
  backward-field: { style: { fill: "#F0F8FF"; stroke: "#4169E1"; font: mono } }
  padding: { style: { fill: "#D1D5DB"; stroke: "#9CA3AF"; stroke-dash: 3 } }

  # Graph Construction Classes
  value-node: { shape: circle; style: { fill: "#3B82F6"; font-color: white; font: mono } }
  operation-node: { shape: diamond; style: { fill: "#8B5CF6"; font-color: white; font: mono } }
  forward-edge: { style: { stroke: "#10B981"; stroke-width: 2; animated: true } }
}

# 1. Memory Layout and Field Structure
ValueObjectAnatomy: {
  direction: right
  label: "Value Object Anatomy (Memory Layout)"
  tooltip: "sizeof(Value) = 64 bytes (excluding heap overhead)"

  MemoryLayout: {
    header: |'md
      ### CPython Object: `class Value`
      *Byte-aligned field structure*
    '| {
      shape: text
    }

    # Offset markers for Intel-style manual layout
    offsets: {
      direction: down
      "0x00": "PyObject_HEAD" { width: 220; height: 40; style.fill: "#F3F4F6" }
      "0x10": "data (float64)" { class: data-field; width: 220 }
      "0x18": "grad (float64)" { class: grad-field; width: 220 }
      "0x20": "_prev (PyObject*)" { class: prev-field; width: 220 }
      "0x28": "_op (PyObject*)" { class: data-field; width: 220 }
      "0x30": "_backward (Callable*)" { class: backward-field; width: 220 }
      "0x38": "padding/metadata" { class: padding; width: 220 }
      
      "0x00" -> "0x10" -> "0x18" -> "0x20" -> "0x28" -> "0x30" -> "0x38"
    }

    size_annotation: |'md
      **Total Size Summary:**
      - Header: 16 Bytes
      - Payload: 40 Bytes
      - Alignment: 8 Bytes
      - **Total: 64B (1 Cache Line)**
    '| {
      shape: text
      style.font: mono
    }
  }
}

# 2. Computational Graph Construction
GraphConstruction: {
  direction: right
  label: "Computational Graph Building"

  Expression: |'md
    ## Expression: `c = (a * b) + a`
    Building graph through operator overloading (`__add__`, `__mul__`)
  '| { shape: text }

  a: "a\n2.0" { class: value-node }
  b: "b\n3.0" { class: value-node }
  multiply_op: "*" { class: operation-node }
  temp: "t\n6.0" { class: value-node; style.fill: "#A855F7" }
  add_op: "+" { class: operation-node }
  c: "c\n8.0" { class: value-node }

  a -> multiply_op: "op1" { class: forward-edge }
  b -> multiply_op: "op2" { class: forward-edge }
  multiply_op -> temp { class: forward-edge }
  temp -> add_op { class: forward-edge }
  a -> add_op: "residual" { class: forward-edge; style.stroke: "#F59E0B" }
  add_op -> c { class: forward-edge }
}

# 3. DFS and Backpropagation Ordering
TopologicalSort: {
  direction: right
  label: "Topological Sort & Backprop Order"

  SortingLogic: {
    code: |'python
      def build_topo(v):
          if v not in visited:
              visited.add(v)
              for child in v._prev:
                  build_topo(child)
              topo.append(v)
    '| { shape: rectangle; style.fill: "#1E293B"; style.font-color: "#E5E7EB" }
  }

  VisualTraversal: {
    L: "L" { shape: circle; style.fill: "#F59E0B" }
    add: "+" { shape: diamond; style.fill: "#8B5CF6" }
    mul: "*" { shape: diamond; style.fill: "#8B5CF6" }
    a: "a"; b: "b"; c: "c"
    
    L -> add -> mul -> a
    mul -> b
    add -> c
    
    (L -> add)[0].label: "Step 6"
    (add -> mul)[0].label: "Step 4"
    (mul -> a)[0].label: "Step 1"
    (mul -> b)[0].label: "Step 2"
    (add -> c)[0].label: "Step 5"
  }
}

# 4. Learning Rate Diagnostics
ConvergenceAnalysis: {
  direction: right
  label: "Loss Convergence Analysis"

  LossCurve: {
    Plot: |'md
      ### Loss Visualization
      Loss
       ^
       | *
       |  \
       |   \  (High η - Divergence Risk)
       |    *
       |     \__
       |        ---___  (Target Convergence)
       |              -------
       +----------------------------> Epochs
    '| {
      style.font: mono
      style.fill: transparent
      shape: rectangle
    }

    PhaseAnalysis: {
      grid-columns: 3
      grid-gap: 20
      
      HighLR: |'md
        **High η (Divergence)**
        - Oscillation around minima
        - Gradient exploding
      '| { style.fill: "#FEE2E2" }

      LowLR: |'md
        **Low η (Stagnation)**
        - Vanishingly small updates
        - High computation cost
      '| { style.fill: "#FEF3C7" }

      IdealLR: |'md
        **Ideal η (Optimal)**
        - Smooth exponential decay
        - Faster time-to-minima
      '| { style.fill: "#DCFCE7" }
    }
  }
}

# 5. Gradient Flow Mechanics
BackwardPassFlow: {
  direction: right
  label: "Reverse-Mode AD: Gradient Flow"

  L: "L (1.0)" { shape: circle; style.fill: "#F59E0B" }
  add: "+" { shape: diamond }
  t: "t (1.0)" { shape: circle }
  c: "c (1.0)" { shape: circle }
  mul: "*" { shape: diamond }
  a: "a (3.0)" { shape: circle }
  b: "b (2.0)" { shape: circle }

  # Gradient path moves backward
  L -> add: "Upstream" { style.stroke: red; style.animated: true }
  add -> t: "Chain Rule" { style.stroke: red; style.animated: true }
  add -> c: "Chain Rule" { style.stroke: red; style.animated: true }
  t -> mul: "Local Deriv" { style.stroke: red; style.animated: true }
  mul -> a: "b * 1.0" { style.stroke: red; style.animated: true }
  mul -> b: "a * 1.0" { style.stroke: red; style.animated: true }

  Legend: |'md
    **Backprop Rule:**
    `self.grad += upstream_grad * local_derivative`
    *Note: Gradient is accumulated (+=) to handle multigraph usage.*
  '| {
    shape: text
    style.fill: "#F0F9FF"
  }
}

# 6. Training Pipeline Execution
TrainingPipeline: {
  direction: right
  label: "Training Cycle (Standard Iteration)"
  
  Loop: {
    Data -> Forward -> Loss -> ZeroGrad -> Backward -> Step -> Data
    
    Forward: "1. Forward Pass" { style.fill: "#EFF6FF" }
    Loss: "2. Loss Calc" { style.fill: "#F5F3FF" }
    ZeroGrad: "3. zero_grad()" { style.fill: "#FEE2E2" }
    Backward: "4. backward()" { style.fill: "#FEE2E2" }
    Step: "5. optimizer.step()" { 
      style.fill: "#DCFCE7"
      tooltip: "w = w - η * grad"
    }
  }
}