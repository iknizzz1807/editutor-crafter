vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Complete Computational Graph for Training
  Full graph showing Value connections from inputs through network layers to loss
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}
direction: right
# Input Layer
inputs: "Input Vector x" {
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  x1: "x₁ = 1.0" {
    shape: text
    style.font: mono
  }
  x2: "x₂ = -1.0" {
    shape: text
    style.font: mono
  }
}
# Hidden Layer 1 (4 neurons with tanh)
hidden1: "Hidden Layer 1 (tanh)" {
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  h1_n1: "Neuron 1" {
    style.fill: "#BBDEFB"
    shape: rectangle
    w_sum_1: "Σ(w·x) + b" {
      shape: text
      style.font-size: 11
    }
    tanh_1: "tanh()" {
      shape: diamond
      style.fill: "#90CAF9"
      style.stroke: "#1976D2"
    }
    w_sum_1 -> tanh_1
  }
  h1_n2: "Neuron 2" {
    style.fill: "#BBDEFB"
    shape: rectangle
    w_sum_2: "Σ(w·x) + b"
    tanh_2: "tanh()" {
      shape: diamond
      style.fill: "#90CAF9"
    }
    w_sum_2 -> tanh_2
  }
  h1_n3: "Neuron 3" {
    style.fill: "#BBDEFB"
    shape: rectangle
    w_sum_3: "Σ(w·x) + b"
    tanh_3: "tanh()" {
      shape: diamond
      style.fill: "#90CAF9"
    }
    w_sum_3 -> tanh_3
  }
  h1_n4: "Neuron 4" {
    style.fill: "#BBDEFB"
    shape: rectangle
    w_sum_4: "Σ(w·x) + b"
    tanh_4: "tanh()" {
      shape: diamond
      style.fill: "#90CAF9"
    }
    w_sum_4 -> tanh_4
  }
}
# Hidden Layer 2 (4 neurons with tanh)
hidden2: "Hidden Layer 2 (tanh)" {
  style.fill: "#E1F5FE"
  style.stroke: "#03A9F4"
  style.stroke-width: 2
  h2_n1: "Neuron 1" {
    style.fill: "#B3E5FC"
    shape: rectangle
    h2_sum_1: "Σ(w·h) + b"
    h2_tanh_1: "tanh()" {
      shape: diamond
      style.fill: "#81D4FA"
    }
    h2_sum_1 -> h2_tanh_1
  }
  h2_n2: "Neuron 2" {
    style.fill: "#B3E5FC"
    shape: rectangle
    h2_sum_2: "Σ(w·h) + b"
    h2_tanh_2: "tanh()" {
      shape: diamond
      style.fill: "#81D4FA"
    }
    h2_sum_2 -> h2_tanh_2
  }
  h2_n3: "Neuron 3" {
    style.fill: "#B3E5FC"
    shape: rectangle
    h2_sum_3: "Σ(w·h) + b"
    h2_tanh_3: "tanh()" {
      shape: diamond
      style.fill: "#81D4FA"
    }
    h2_sum_3 -> h2_tanh_3
  }
  h2_n4: "Neuron 4" {
    style.fill: "#B3E5FC"
    shape: rectangle
    h2_sum_4: "Σ(w·h) + b"
    h2_tanh_4: "tanh()" {
      shape: diamond
      style.fill: "#81D4FA"
    }
    h2_sum_4 -> h2_tanh_4
  }
}
# Output Layer (1 neuron, linear)
output_layer: "Output Layer (linear)" {
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  style.stroke-width: 2
  out_neuron: "Output Neuron" {
    style.fill: "#FFE0B2"
    shape: rectangle
    out_sum: "Σ(w·h) + b"
    out_linear: "identity()" {
      shape: diamond
      style.fill: "#FFCC80"
      style.stroke: "#F57C00"
    }
    out_sum -> out_linear
  }
}
# Prediction
prediction: "ŷ (prediction)" {
  shape: circle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.stroke-width: 3
  style.bold: true
}
# Target
target: "y (target)" {
  shape: circle
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}
# Loss Computation
loss_comp: "MSE Loss Computation" {
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  style.stroke-width: 2
  diff: "(ŷ - y)" {
    shape: rectangle
    style.fill: "#F8BBD9"
  }
  squared: "(ŷ - y)²" {
    shape: rectangle
    style.fill: "#F48FB1"
  }
  diff -> squared
}
# Final Loss
loss: "Loss L" {
  shape: circle
  style.fill: "#E1BEE7"
  style.stroke: "#9C27B0"
  style.stroke-width: 3
  style.bold: true
}
# Connections: Input to Hidden Layer 1
inputs -> hidden1: "Value connections\n(×, + ops)" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
# Connections: Hidden Layer 1 to Hidden Layer 2
hidden1 -> hidden2: "4→4 connections" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
# Connections: Hidden Layer 2 to Output
hidden2 -> output_layer: "4→1 connections" {
  style.stroke: "#03A9F4"
  style.stroke-width: 2
}
# Output to Prediction
output_layer -> prediction: "scalar Value" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.bold: true
}
# Target connection
target -> loss_comp: "" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 3
}
# Prediction to Loss
prediction -> loss_comp: "" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
# Loss computation to Loss
loss_comp -> loss: "" {
  style.stroke: "#E91E63"
  style.stroke-width: 3
  style.bold: true
}
# Legend
legend: "Graph Legend" {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  value_node: "Value node" {
    shape: rectangle
    style.fill: "#E0E0E0"
  }
  op_node: "Operation node" {
    shape: diamond
    style.fill: "#BDBDBD"
  }
  data_node: "Scalar data" {
    shape: circle
    style.fill: "#9E9E9E"
  }
  gradient: "← Gradient flow" {
    shape: text
    style.font: mono
    style.font-color: "#D32F2F"
  }
}
# Backward pass annotation
backward_note: |md
  **Backward Pass:**
  1. `loss.grad = 1.0` (seed)
  2. Topological sort orders all nodes
  3. Reverse traversal calls each `_backward()`
  4. Gradients accumulate via `+=`
  5. All parameters receive `∂L/∂p`
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  style.stroke-width: 2
  style.font-size: 12
}
# Parameter annotation
param_note: |md
  **Parameters:**
  - Layer 1: 4 × (2 + 1) = 12 weights + 4 biases = 16
  - Layer 2: 4 × (4 + 1) = 16 weights + 4 biases = 20  
  - Layer 3: 1 × (4 + 1) = 4 weights + 1 bias = 5
  - **Total: 41 parameters** (all Value objects)
| {
  near: bottom-left
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.font-size: 12
}
# Gradient flow arrow (conceptual)
loss -> hidden2: "∂L/∂h" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 5
  style.animated: true
  style.opacity: 0.5
}
# Key insight
insight: |md
  **Key Insight:** Every line represents a `Value` object
  connection. The `+`, `×`, `tanh` operations each create
  a new `Value` with `_prev` pointing to its operands and
  `_backward` closure computing local derivatives.
| {
  near: top-right
  shape: rectangle
  style.fill: "#E1F5FE"
  style.stroke: "#0288D1"
  style.stroke-width: 2
  style.font-size: 11
}