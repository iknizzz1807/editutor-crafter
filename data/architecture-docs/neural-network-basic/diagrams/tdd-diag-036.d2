title: {
  shape: text
  near: top-center
  label: ||md
    # TRAINING LOOP ARCHITECTURE & SEQUENCE
    **ML Pipeline v1.0** | *Forward ➜ Loss ➜ Zero Grad ➜ Backward ➜ Step*
  ||
  style: {
    font-size: 24
    bold: true
    stroke-width: 0
    fill: transparent
  }
}

# Participant classes for consistent Intel-style manual layout
classes: {
  actor_base: {
    style: {
      bold: true
      font-color: white
      stroke-width: 2
    }
  }
  forward_msg: {
    style: {
      stroke: "#2980b9"
      font-color: "#2980b9"
      bold: true
    }
  }
  backward_msg: {
    style: {
      stroke: "#c0392b"
      font-color: "#c0392b"
      stroke-dash: 2
    }
  }
}

training_loop_seq: {
  shape: sequence_diagram
  style: {
    stroke: "#222222"
    stroke-width: 2
    fill: "#fcfcfc"
  }

  # --- Participant Definitions ---
  training_loop: Training Loop {
    shape: person
    class: actor_base
    tooltip: "Main orchestrator for epoch/batch iterations. Controls the GIL and execution flow."
    style.fill: "#9C27B0"
  }
  
  network: Neural Network (MLP) {
    class: actor_base
    tooltip: "Computational graph. Memory footprint: ~450MB (FP32 weights)."
    style.fill: "#2196F3"
  }
  
  mse_fn: MSE Loss Function {
    class: actor_base
    tooltip: "Criterion: 1/N * Σ(y - ŷ)²"
    style.fill: "#FF9800"
  }
  
  optimizer: SGD Optimizer {
    class: actor_base
    tooltip: "Stochastic Gradient Descent. State: Momentum buffers (64-bit floats)."
    style.fill: "#4CAF50"
  }
  
  loss_val: Loss Scalar {
    class: actor_base
    tooltip: "The differentiable leaf node of the Autograd graph."
    style.fill: "#F44336"
  }

  # --- Sequence Timeline ---
  
  training_loop: "ENTRY: For each epoch e ∈ E"

  step_1_forward: Forward Pass Phase {
    training_loop -> network: "forward(X_batch)" {
      tooltip: "Input Tensor: [Batch, Channels, H, W]"
    }
    network -> network: "compute_activations()" {
      tooltip: "Layer-wise GEMM operations"
    }
    network -> training_loop: "predictions: Tensor" {
      style.stroke-dash: 3
    }
  }

  step_2_loss: Compute Loss {
    training_loop -> mse_fn: "mse_loss(pred, target)"
    mse_fn -> mse_fn: "calculate_distance()"
    mse_fn -> training_loop: "loss: Value" {
      style.stroke-dash: 3
    }
  }

  step_3_zero_grad: Reset Gradients {
    training_loop -> optimizer: "zero_grad()"
    optimizer -> optimizer: "memset(p.grad, 0, sizeof(p))"
    optimizer -> training_loop: "ACK: grads_cleared" {
      style.stroke-dash: 3
    }
  }

  step_4_backward: Backward Pass (Autograd) {
    training_loop -> loss_val: "backward()"
    loss_val -> loss_val: "topo_sort(DAG)"
    loss_val -> network: "propagate_grad(dL/dy)" {
      style.stroke: "#F44336"
    }
    network -> network: "accumulate_gradients()"
    network -> training_loop: "grad_status: READY" {
      style.stroke-dash: 3
    }
  }

  step_5_update: Parameter Update {
    training_loop -> optimizer: "step()"
    optimizer -> optimizer: "θ = θ - η * ∇θ"
    optimizer -> training_loop: "params: UPDATED" {
      style.stroke-dash: 3
    }
  }

  training_loop: "EXIT: Converged"
}

implementation_notes: {
  near: bottom-center
  shape: text
  label: |md
    ### TECHNICAL SPECIFICATION REFERENCE: ML-CORE-01
    
    #### Operational Invariants
    - **Batch Constraints**: ${X} \in \mathbb{R}^{B \times I}$ where ${B}$ is batch size (stride-aligned).
    - **Gradient Reset**: `optimizer.zero_grad()` must precede `backward()` call to avoid gradient accumulation.
    - **Memory Persistence**: The `Value` objects maintain back-references to nodes until the graph is freed.
    
    #### Mathematical Kernels
    - **MSE Criterion**: ${L} = \frac{1}{n} \sum_{i=1}^{n} (y_i - \hat{y}_i)^2$
    - **SGD Update**: $\theta_{t+1} = \theta_t - \eta \cdot \frac{\partial L}{\partial \theta_t}$
    
    #### Resource Usage (Estimation)
    - **Activation Memory**: ${O}(\text{layers} \times \text{batch_size})$
    - **Gradient Memory**: ${O}(\text{parameter_count})$
  |
  
  style: {
    fill: "#F5F5F5"
    stroke: "#bdc3c7"
    stroke-width: 1
    border-radius: 8
    font-size: 14
  }
}

# Global style rules for internal connections within the container
(training_loop_seq.** -> training_loop_seq.**)[*]: {
  style: {
    font-size: 12
    bold: true
    font-color: "#34495e"
    stroke-width: 2
  }
}

# Style participant notes
training_loop_seq.**.style.font-size: 11
training_loop_seq.**.style.italic: true