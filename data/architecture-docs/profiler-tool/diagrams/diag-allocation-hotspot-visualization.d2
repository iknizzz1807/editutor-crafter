code_ref: {
  direction: down
  label: "Implementation Reference (profiler.rs)"
  code_block: {
    label: "HotSpot Analysis"
    width: 450
    code: |'rust
impl AllocationTracker {
  pub fn analyze_hot_spots(&self) -> HotSpotReport {
    let mut sites: Vec<HotSpot> = Vec::new();
    for entry in self.call_site_stats.iter() {
      let hash = *entry.key();
      let stats = entry.value();
      sites.push(HotSpot {
        call_site_hash: hash,
        total_allocated: stats.total_allocated,
        live_bytes: stats.live_bytes,
        alloc_count: stats.alloc_count,
        avg_alloc_size: stats.total_allocated 
                      / stats.alloc_count,
      });
    }
    sites.sort_by(|a, b| 
      b.total_allocated.cmp(&a.total_allocated));
    HotSpotReport { sites, .. }
  }
}
'|
  }
}
footer: |md
  **Insight:** The Pareto principle applies—optimize the top 3 allocation sites to eliminate >50% of memory pressure.
| {near: bottom-center}