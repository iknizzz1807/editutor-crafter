direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Allocation Tracking: Metadata Structure
  Memory overhead per tracked allocation
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  allocation: {
    shape: sql_table
    label: "struct AllocationInfo (tracker.rs)"
    f0: "0x00 | usize       | address"
    f1: "0x08 | usize       | size"
    f2: "0x10 | u64         | timestamp_ns"
    f3: "0x18 | u64         | thread_id"
    f4: "0x20 | u64         | call_site_hash"
    f5: "0x28 | Vec<usize>  | call_stack"
    f6: "0x38 | bool        | freed"
    f7: "0x40 | Option<u64> | freed_timestamp_ns"
    sz: "Base: 72 bytes + stack"
  }
  callstack: {
    label: "Call Stack Storage"
    width: 320
    code: |'rust
      // Heap-allocated, variable size
      call_stack: Vec<usize>
      // Typical: 16-32 frames
      // 16 frames = 128 bytes
      // 32 frames = 256 bytes
      // Max 128 frames = 1024 bytes
    '|
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  overhead: {
    label: "Memory Overhead Analysis"
    width: 380
    code: |'rust
      // Per-allocation metadata cost:
      Base struct:     72 bytes
      Call stack (avg 20 frames): 160 bytes
      Vec overhead:    24 bytes
      DashMap entry:   ~32 bytes
      ────────────────────────────
      Total per alloc: ~288 bytes
      // Tracking 1M allocations:
      Metadata total: ~275 MB
    '|
  }
  callsite: {
    shape: sql_table
    label: "struct CallSiteStats (aggregated)"
    f0: "0x00 | u64 | total_allocated"
    f1: "0x08 | u64 | total_freed"
    f2: "0x10 | u64 | live_bytes"
    f3: "0x18 | u64 | alloc_count"
    f4: "0x20 | u64 | free_count"
    f5: "0x28 | u64 | peak_live_bytes"
    sz: "Total: 48 bytes"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memlayout: {
    label: "In-Memory Layout"
    shape: rectangle
    width: 600
    mem: |'text
      ┌─────────────────────────────────────────────────────┐
      │ DashMap<usize, AllocationInfo>                      │
      │ ┌─────────┬───────────────────────────────────────┐ │
      │ │ Key     │ Value (AllocationInfo)                │ │
      │ ├─────────┼───────────────────────────────────────┤ │
      │ │ 0x7f01  │ [0x7f01][1024][t=100][tid=1][hash=42] │ │
      │ │ ...     │ [call_stack: 20 addrs][false][None]   │ │
      │ ├─────────┼───────────────────────────────────────┤ │
      │ │ 0x8a20  │ [0x8a20][4096][t=105][tid=3][hash=17] │ │
      │ │ ...     │ [call_stack: 15 addrs][true][t=150]   │ │
      │ └─────────┴───────────────────────────────────────┘ │
      │ Sharded across N locks for concurrent access       │
      └─────────────────────────────────────────────────────┘
    '|
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cacheimpact: {
    label: "Cache Impact"
    width: 280
    code: |'rust
      // Cache line: 64 bytes
      // AllocationInfo: ~4-5 lines
      // Random access pattern:
      // - Hash lookup: 1 miss
      // - Value read: 1-2 misses
      // - Call stack: 2-4 misses
      // ~50-100 cycles per lookup
    '|
    style.fill: "#fce7c6"
  }
  boehm: {
    label: "The Boehm Effect"
    width: 280
    code: |'rust
      // Profiler allocations change
      // application memory layout:
      // 1. Different free list order
      // 2. Shifted fragmentation
      // 3. Cache pressure changes
      // May hide the exact bug
      // you're trying to find!
    '|
    style.fill: "#f6c889"
  }
}
allocation -> callstack: "stores"
overhead -> callsite: "aggregates by hash"
memlayout -> cacheimpact: "causes"
cacheimpact -> boehm: "triggers"
legend: {
  near: bottom-center
  cache: "Orange = performance consideration"
  cache.style.fill: "#fce7c6"
  warn: "Yellow = profiling artifact"
  warn.style.fill: "#f6c889"
}