        width: 380
        style: {
          fill: "#e0e0e0"
          stroke: "#666"
        }
      }
      aframe2: {
        label: "handle_request"
        width: 380
        style: {
          fill: "#ff8c42"
          stroke: "#666"
        }
      }
      aframe3_cpu: {
        label: "fetch_data [CPU]"
        width: 30
        style: {
          fill: "#ff8c42"
          stroke: "#333"
          font-size: 10
        }
      }
      aframe3_await: {
        label: "fetch_data [AWAIT]"
        width: 220
        style: {
          fill: "#5b9bd5"
          stroke: "#333"
          font-color: white
        }
      }
      aframe4_cpu: {
        label: "http_get [CPU]"
        width: 25
        style: {
          fill: "#ffb366"
          stroke: "#333"
          font-size: 9
        }
      }
      aframe4_await: {
        label: "http_get [AWAIT]"
        width: 205
        style: {
          fill: "#7ba3d0"
          stroke: "#333"
          font-color: white
        }
      }
      aframe5: {
        label: "process [CPU]"
        width: 120
        style: {
          fill: "#ff8c42"
          stroke: "#333"
        }
      }
      aframe6: {
        label: "compute [CPU]"
        width: 120
        style: {
          fill: "#ffb366"
          stroke: "#333"
        }
      }
    }
    
    async_note: {
      label: |'md
        ✓ Clearly shows `fetch_data` spent:
        - **30 samples** in CPU (orange)
        - **220 samples** awaiting I/O (blue)
      '|
      width: 380
      style.fill: "#e0f0ff"
    }
  }
}

row2: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  
  time_attribution: {
    direction: down
    label: "Time Attribution Model"
    width: 500
    
    formula: {
      label: |'md
        **Total Task Time = Spawn → Completion**
        
        ┌─────────────────────────────────────────────────────┐
        │                   TOTAL TIME                        │
        │  (width in flame graph)                             │
        ├─────────┬─────────────────────────┬────────────────┤
        │ CPU     │      AWAIT TIME         │    CPU         │
        │ (poll)  │   (I/O + Timer + Wait)  │   (poll)       │
        │  50μs   │         50ms            │     100μs      │
        └─────────┴─────────────────────────┴────────────────┘
      '|
      width: 450
      style.fill: "#f8f8f8"
    }
    
    breakdown: {
      direction: right
      label: ""
      style.stroke: transparent
      
      cpu_box: {
        label: |'md
          **CPU Time** (Orange)
          ─────────────────
          - Active `poll()` calls
          - Computation
          - Memory operations
        '|
        width: 200
        style: {
          fill: "#fff0e0"
          stroke: "#ff8c42"
        }
      }
      await_box: {
        label: |'md
          **Await Time** (Blue)
          ───────────────────
          - I/O wait (socket, file)
          - Timer delays
          - Scheduler queue time
        '|
        width: 220
        style: {
          fill: "#e0f0ff"
          stroke: "#5b9bd5"
        }
      }
    }
  }
  
  comparison: {
    direction: down
    label: "What Standard Profilers Miss"
    
    scenario: {
      label: |'md
        **Example: `fetch_data()` task**
        | Metric | Standard | Async-Aware |
        |--------|----------|-------------|
        | Samples | 250 | 250 |
        | CPU | ??? | 30 (12%) |
        | Await | ??? | 220 (88%) |
        | Cause | "Slow" | **I/O Bound** |
      '|
      width: 400
      style.fill: "#f0f0f0"
    }
  }
}

row3: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  
  implementation: {
    direction: down
    label: "Implementation: Async Time Tracking"
    
    impl_code: {
      label: "Poll Lifecycle Tracking (task_tracker.rs)"
      width: 500
      code: |'rust
        impl AsyncTaskTracker {
          fn begin_poll(&mut self, start_ns: u64) {
            if let Some(last_end) = self.last_poll_end_ns {
              self.total_await_ns += start_ns - last_end;
            }
            self.last_poll_start_ns = Some(start_ns);
          }
          fn end_poll(&mut self, end_ns: u64) {
            let start = self.last_poll_start_ns.unwrap();
            self.total_poll_ns += end_ns - start;
            self.last_poll_end_ns = Some(end_ns);
          }
        }
      '|
      style: {
        fill: "#1e1e1e"
        font-color: "#d4d4d4"
        font: mono
      }
    }
    
    impl_note: {
      label: |'md
        **Key insight:** Await time is inferred from gaps between polls.
        Measure the silence between `poll()` calls.
      '|
      width: 480
      style.fill: "#fffde0"
    }
  }
  
  visualization: {
    direction: down
    label: "Visualization: Dual-Color Rendering"
    
    vis_code: {
      label: "Color Selection Logic"
      width: 400
      code: |'rust
        fn color_for_frame(frame: &Frame) -> Color {
          match frame.phase {
            TaskPhase::Polling => {
              Color::rgb(255, 140, 66) // Orange
            }
            TaskPhase::Awaiting { cause } => {
              match cause {
                IoWait => Color::rgb(91, 155, 213),
                _ => Color::rgb(135, 206, 250),
              }
            }
          }
        }
      '|
      style: {
        fill: "#1e1e1e"
        font-color: "#d4d4d4"
        font: mono
      }
    }
  }
}

legend: {
  direction: right
  label: "Key"
  
  orange_key: "CPU (poll)" {
    style: {
      fill: "#ff8c42"
      font-color: white
    }
  }
  blue_key: "Await (I/O)" {
    style: {
      fill: "#5b9bd5"
      font-color: white
    }
  }
  light_blue_key: "Await (Sched)" {
    style: {
      fill: "#87ceeb"
      font-color: black
    }
  }
}
legend.near: bottom-center

# Connections for Standard Graph
standard.std_graph.frame1 -> standard.std_graph.frame2
standard.std_graph.frame2 -> standard.std_graph.frame3
standard.std_graph.frame2 -> standard.std_graph.frame5
standard.std_graph.frame3 -> standard.std_graph.frame4
standard.std_graph.frame5 -> standard.std_graph.frame6

# Connections for Async Graph
async.async_graph.aframe1 -> async.async_graph.aframe2
async.async_graph.aframe2 -> async.async_graph.aframe3_cpu
async.async_graph.aframe2 -> async.async_graph.aframe3_await
async.async_graph.aframe2 -> async.async_graph.aframe5
async.async_graph.aframe3_cpu -> async.async_graph.aframe4_cpu
async.async_graph.aframe3_await -> async.async_graph.aframe4_await
async.async_graph.aframe5 -> async.async_graph.aframe6