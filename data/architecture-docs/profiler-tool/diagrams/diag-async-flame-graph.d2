direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "Async-Aware Flame Graph Visualization"
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
title.near: top-center

row1: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  
  standard: {
    direction: down
    label: "Standard Flame Graph (Blind to Async)"
    
    std_legend: {
      label: |'md
        **Cannot distinguish:**
        - CPU work vs I/O wait
        - Active polling vs suspended
        - All samples appear as "work"
      '|
      width: 200
      style.fill: "#f0f0f0"
    }
    
    std_graph: {
      label: "Standard View (samples)"
      width: 400
      
      frame1: {
        label: "main"
        width: 380
        style: {
          fill: "#ffb347"
          stroke: "#666"
        }
      }
      frame2: {
        label: "handle_request"
        width: 380
        style: {
          fill: "#ff7f7f"
          stroke: "#666"
        }
      }
      frame3: {
        label: "fetch_data  ???"
        width: 250
        style: {
          fill: "#ff9999"
          stroke: "#666"
        }
      }
      frame4: {
        label: "http_get  ???"
        width: 250
        style: {
          fill: "#ffaaaa"
          stroke: "#666"
        }
      }
      frame5: {
        label: "process"
        width: 120
        style: {
          fill: "#ff7f7f"
          stroke: "#666"
        }
      }
      frame6: {
        label: "compute"
        width: 120
        style: {
          fill: "#ffaaaa"
          stroke: "#666"
        }
      }
    }
    
    std_note: {
      label: |'md
        ❌ Cannot see that `fetch_data`
        spent 95% of time **awaiting**
        network I/O, not computing
      '|
      width: 380
      style.fill: "#ffe0e0"
    }
  }

  async: {
    direction: down
    label: "Async-Aware Flame Graph (CPU vs Await)"
    
    async_legend_box: {
      direction: right
      label: ""
      width: 400
      style.stroke: transparent
      
      cpu_legend: {
        label: "CPU Time"
        width: 120
        style: {
          fill: "#ff8c42"
          stroke: "#666"
          font-color: white
          bold: true
        }
      }
      await_legend: {
        label: "Await Time"
        width: 180
        style: {
