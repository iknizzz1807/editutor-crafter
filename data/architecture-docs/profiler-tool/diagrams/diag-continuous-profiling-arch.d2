direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: "Continuous Profiling Architecture (v1.2.0)"
  style.font-size: 28
  style.bold: true
  style.stroke: transparent
  style.fill: transparent
}
title.near: top-center

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scrape: {
    direction: down
    label: "Scrape Triggers (collector.go)"
    prometheus: {
      label: "Prometheus Scraper"
      shape: rectangle
      style.fill: "#E6522C"
      style.stroke: "#C4411F"
      style.font-color: white
    }
    k8s: {
      label: "K8s Sidecar"
      shape: rectangle
      style.fill: "#326CE5"
      style.stroke: "#2554A4"
      style.font-color: white
    }
    manual: {
      label: "Manual Trigger (CURL)"
      shape: rectangle
      style.fill: "#4A5568"
      style.stroke: "#2D3748"
      style.font-color: white
    }
  }

  endpoint: {
    direction: down
    label: "HTTP Server (:6060)"
    style.fill: "#EDF2F7"
    style.stroke: "#A0AEC0"
    handler: {
      label: "Profile Handler (Async)"
      shape: rectangle
    }
    rate_limiter: {
      label: "Rate Limiter (1/30s)"
      shape: diamond
      style.fill: "#FED7D7"
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  profiler: {
    direction: down
    label: "In-Process Profiler (runtime/pprof)"
    style.fill: "#C6F6D5"
    style.stroke: "#38A169"
    sampler: {
      label: "Sampler (49 Hz Prime)"
      shape: rectangle
    }
    buffer: {
      label: "Ring Buffer (64K Samples)"
      shape: cylinder
      style.fill: "#9AE6B4"
    }
    aggregator: {
      label: "Stack Aggregator"
      shape: rectangle
    }
  }

  formats: {
    direction: down
    label: "Exporter Formats"
    style.fill: "#E9D8FD"
    style.stroke: "#805AD5"
    pprof: {
      label: "pprof (Protobuf)"
      shape: document
      style.fill: "#D6BCFA"
    }
    collapsed: {
      label: "Collapsed Stacks"
      shape: document
      style.fill: "#D6BCFA"
    }
    svg: {
      label: "Flame Graph (SVG)"
      shape: document
      style.fill: "#D6BCFA"
    }
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  storage: {
    direction: down
    label: "Persistence Layer"
    style.fill: "#FED7E2"
    style.stroke: "#D53F8C"
    circular: {
      label: "Circular Buffer (24h)"
      shape: cylinder
      style.multiple: true
    }
    object_store: {
      label: "Cloud Object Store"
      shape: cylinder
      style.fill: "#FBB6CE"
    }
    compression: {
      label: "Gzip Engine (~10x)"
      shape: rectangle
    }
  }

  observability: {
    direction: down
    label: "Analysis Stack"
    style.fill: "#BEE3F8"
    style.stroke: "#3182CE"
    grafana: {
      label: "Grafana Plugin"
      shape: rectangle
      style.fill: "#F68F3A"
      style.font-color: white
    }
    pyroscope: {
      label: "Pyroscope Ingest"
      shape: rectangle
      style.fill: "#6B46C1"
      style.font-color: white
    }
  }
}

row4: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  overhead: {
    direction: down
    label: "Runtime Resource Budget"
    style.fill: "#FED7AA"
    style.stroke: "#DD6B20"
    cpu_overhead: {
      shape: sql_table
      label: "CPU Usage (Overhead)"
      r1: "Sampler | 49 Hz | ~0.5%"
      r2: "Aggregator | 30s | ~0.3%"
      r3: "Encoder | On-Demand | ~0.1%"
      total: "Target | <1.0% Total"
    }
    memory_overhead: {
      shape: sql_table
      label: "Memory Footprint"
      r1: "Ring Buffer | 64K x 1KB | 64.0 MB"
      r2: "Symbol Cache | 10K Entry | 1.0 MB"
      r3: "Aggregated | 5K Path | 0.5 MB"
      total: "Static Heap | ~66.0 MB"
    }
  }

  storage_budget: {
    direction: down
    label: "Storage Projection"
    style.fill: "#C6F6D5"
    style.stroke: "#38A169"
    per_profile: {
      shape: sql_table
      label: "Per 30s Window"
      r1: "Raw Samples | 1,470 | 147 KB"
      r2: "Collapsed | 5K Paths | 50 KB"
      r3: "pprof Gzip | Protobuf | 15 KB"
      total: "Avg Size | 212 KB Raw"
    }
    daily: {
      shape: sql_table
      label: "Daily Retention (2.8K Profiles)"
      r1: "Uncompressed | 2880 x 212K | 611 MB"
      r2: "Compressed | Gzip -9 | 61 MB"
      r3: "Symbol Dedup | Global | 100 MB"
      total: "30-Day Project | ~3 GB"
    }
  }
}

# Connections
row1.scrape.prometheus -> row1.endpoint.handler: "HTTP GET | pull"
row1.scrape.k8s -> row1.endpoint.handler: "Sidecar | proxy"
row1.scrape.manual -> row1.endpoint.handler: "CLI | trigger"

row1.endpoint.handler -> row1.endpoint.rate_limiter: "AuthZ | check"
row1.endpoint.rate_limiter -> row2.profiler.sampler: "Signal | start"
row2.profiler.sampler -> row2.profiler.buffer: "Raw | stream"
row2.profiler.buffer -> row2.profiler.aggregator: "Batch | fold"

row2.profiler.aggregator -> row2.formats.pprof: "Proto | encode"
row2.profiler.aggregator -> row2.formats.collapsed: "Txt | export"
row2.profiler.aggregator -> row2.formats.svg: "XML | render"

row2.formats.pprof -> row3.storage.circular: "FS | write"
row3.storage.circular -> row3.storage.compression: "CPU | gzip"
row3.storage.compression -> row3.storage.object_store: "S3 | upload"

row3.storage.object_store -> row3.observability.grafana: "JSON | query"
row3.storage.object_store -> row3.observability.pyroscope: "GRPC | push"

row1.endpoint.handler -> row2.formats.pprof: "Response | pprof" {
  style.stroke-dash: 4
  style.stroke: "#805AD5"
}

legend: {
  label: "Flow Control Legend"
  style.fill: "#F7FAFC"
  style.stroke: "#CBD5E0"
  
  scrape_flow: {
    label: "Scrape Request"
    style.stroke: "#3182CE"
  }
  profile_flow: {
    label: "Profile Mutation"
    style.stroke: "#38A169"
  }
  response_flow: {
    label: "Egress Response"
    style.stroke-dash: 4
    style.stroke: "#805AD5"
  }
}
legend.near: bottom-right