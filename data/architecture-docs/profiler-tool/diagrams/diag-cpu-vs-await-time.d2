direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # CPU vs Await Time Attribution
    Async task timeline: distinguishing active polling from waiting
  |
  near: top-center
  shape: text
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    direction: down
    label: "Task Execution Timeline"
    t0: {
      label: "Poll #1"
      width: 80
      code: |'rust
        // read_request().await
        // Active CPU work
        poll(Future)
      '|
      style.fill: "#ff6b6b"
      style.stroke: "#c92a2a"
    }
    gap1: {
      label: "Await #1\n5ms I/O"
      width: 200
      style.fill: "#74c0fc"
      style.stroke: "#1971c2"
      style.stroke-dash: 4
    }
    t1: {
      label: "Poll #2"
      width: 60
      code: |'rust
        // parse().await
        // Quick parse
        poll(Future)
      '|
      style.fill: "#ff6b6b"
      style.stroke: "#c92a2a"
    }
    gap2: {
      label: "Await #2\n2ms Sched"
      width: 100
      style.fill: "#b197fc"
      style.stroke: "#7048e8"
      style.stroke-dash: 4
    }
    t2: {
      label: "Poll #3"
      width: 80
      code: |'rust
        // process().await
        // Final work
        poll(Future)
      '|
      style.fill: "#ff6b6b"
      style.stroke: "#c92a2a"
    }
    t0 -> gap1: "Pending"
    gap1 -> t1: "Wake"
    t1 -> gap2: "Pending"
    gap2 -> t2: "Wake"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    direction: down
    label: "Time Attribution Categories"
    cpu_box: {
      label: "CPU Time (Polling)"
      style.fill: "#ff6b6b"
      style.stroke: "#c92a2a"
      width: 150
    }
    io_box: {
      label: "I/O Wait Time"
      style.fill: "#74c0fc"
      style.stroke: "#1971c2"
      width: 150
    }
    sched_box: {
      label: "Scheduling Delay"
      style.fill: "#b197fc"
      style.stroke: "#7048e8"
      width: 150
    }
  }
  breakdown: {
    direction: down
    label: "Breakdown Table"
    header: {
      shape: sql_table
      label: "Time Attribution"
      phase: "Phase | Type | Duration"
    }
    row1: {
      shape: sql_table
      label: "Poll #1"
      type: "CPU"
      dur: "100µs"
      style.fill: "#ff6b6b"
    }
    row2: {
      shape: sql_table
      label: "Await #1"
      type: "I/O Wait"
      dur2: "5ms"
      style.fill: "#74c0fc"
    }
    row3: {
      shape: sql_table
      label: "Poll #2"
      type: "CPU"
      dur3: "50µs"
      style.fill: "#ff6b6b"
    }
    row4: {
      shape: sql_table
      label: "Await #2"
      type: "Sched"
      dur4: "2ms"
      style.fill: "#b197fc"
    }
    row5: {
      shape: sql_table
      label: "Poll #3"
      type: "CPU"
      dur5: "100µs"
      style.fill: "#ff6b6b"
    }
    total: {
      shape: sql_table
      label: "TOTAL"
      cpu: "CPU: 250µs"
      await: "Await: 7ms"
      style.fill: "#e9ecef"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  detection: {
    direction: down
    label: "Detection Logic (AsyncTaskTracker)"
    width: 500
    step1: {
      label: "1. begin_poll(task_id)"
      code: |'rust
        // Record poll start timestamp
        self.active_polls.insert(task_id, start_ns);
        // Calculate await time since last poll
        await_time = start_ns - last_poll_end_ns;
      '|
    }
    step2: {
      label: "2. end_poll(task_id, result)"
      code: |'rust
        // Record poll duration as CPU time
        cpu_time = end_ns - start_ns;
        // Categorize await by gap duration:
        if gap < 1ms      → scheduling delay
        if gap < 100ms    → I/O wait
        if gap >= 100ms   → timer/unknown
      '|
    }
    step1 -> step2: "poll(Future)\nreturns"
  }
  metrics: {
    direction: down
    label: "Output Metrics"
    metric1: {
      label: "TaskTimeBreakdown"
      shape: class
      task_id: "AsyncTaskId"
      cpu_time_ns: "u64"
      await_time_ns: "u64"
      io_wait_ns: "u64"
      sched_ns: "u64"
      cpu_percent: "f64"
    }
    calc: {
      label: |md
        **CPU Efficiency:**
        `250µs / 7.25ms = 3.4%`
        **Interpretation:**
        Task is I/O bound.
        Optimize I/O path, not CPU.
      |
    }
    metric1 -> calc: "enables"
  }
}
row1 -> row2: ""
row2 -> row3: ""