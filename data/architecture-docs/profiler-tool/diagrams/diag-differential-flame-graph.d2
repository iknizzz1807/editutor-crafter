direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Differential Flame Graph: Before & After Comparison
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  baseline_section: {
    direction: down
    label: "BASELINE PROFILE"
    baseline_flame: {
      label: "Flame Graph View"
      width: 450
      height: 200
      frame_root: {
        label: "main"
        style.fill: "#c0c0c0"
        width: 420
      }
      frame_process: {
        label: "process_request"
        style.fill: "#ffb347"
        width: 300
      }
      frame_parse: {
        label: "parse_json"
        style.fill: "#ff6b6b"
        width: 180
      }
      frame_db: {
        label: "db_query"
        style.fill: "#87ceeb"
        width: 100
      }
      frame_cache: {
        label: "cache_lookup"
        style.fill: "#90ee90"
        width: 100
      }
    }
    baseline_stats: {
      shape: sql_table
      label: "Sample Counts"
      row1: "parse_json    | 200 (20%)"
      row2: "db_query      | 150 (15%)"
      row3: "cache_lookup  | 100 (10%)"
      row4: "process_req   | 350 (35%)"
      total: "Total: 1000 samples"
    }
  }
  comparison_section: {
    direction: down
    label: "COMPARISON PROFILE"
    comparison_flame: {
      label: "Flame Graph View"
      width: 450
      height: 200
      frame_root2: {
        label: "main"
        style.fill: "#c0c0c0"
        width: 420
      }
      frame_process2: {
        label: "process_request"
        style.fill: "#ffb347"
        width: 300
      }
      frame_parse2: {
        label: "parse_json"
        style.fill: "#ff6b6b"
        width: 90
      }
      frame_db2: {
        label: "db_query"
        style.fill: "#87ceeb"
        width: 200
      }
      frame_cache2: {
        label: "cache_lookup"
        style.fill: "#90ee90"
        width: 100
      }
    }
    comparison_stats: {
      shape: sql_table
      label: "Sample Counts"
      row1: "parse_json    | 80 (8%)"
      row2: "db_query      | 300 (30%)"
      row3: "cache_lookup  | 100 (10%)"
      row4: "process_req   | 350 (35%)"
      total: "Total: 1000 samples"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  diff_legend: {
    direction: down
    label: "DIFFERENTIAL LEGEND"
    width: 200
    red_box: {
      label: "RED"
      style.fill: "#ff4444"
      width: 60
      height: 30
    }
    red_desc: |md
      **Regression**
      More samples (slower)
    |
    blue_box: {
      label: "BLUE"
      style.fill: "#4444ff"
      width: 60
      height: 30
    }
    blue_desc: |md
      **Improvement**
      Fewer samples (faster)
    |
    gray_box: {
      label: "GRAY"
      style.fill: "#888888"
      width: 60
      height: 30
    }
    gray_desc: |md
      **Unchanged**
      Same sample count
    |
  }
  diff_flame: {
    direction: down
    label: "DIFFERENTIAL FLAME GRAPH"
    diff_visual: {
      label: ""
      width: 500
      diff_root: {
        label: "main"
        style.fill: "#888888"
        width: 480
      }
      diff_process: {
        label: "process_request"
        style.fill: "#888888"
        width: 340
      }
      diff_parse: {
        label: "parse_json -60%"
        style.fill: "#4444ff"
        width: 100
      }
      diff_db: {
        label: "db_query +100%"
        style.fill: "#ff4444"
        width: 220
      }
      diff_cache: {
        label: "cache_lookup 0%"
        style.fill: "#888888"
        width: 110
      }
    }
    diff_table: {
      shape: sql_table
      label: "Change Analysis"
      row1: "parse_json   | 200 → 80   | -60% | IMPROVED"
      row2: "db_query     | 150 → 300  | +100%| REGRESSED"
      row3: "cache_lookup | 100 → 100  | 0%   | UNCHANGED"
      note: "Width = comparison samples, Color = change direction"
    }
  }
}
baseline_section -> comparison_section: "After optimization" {
  style.stroke-dash: 4
  style.stroke: "#666666"
}
row1 -> row2: "Generate differential view"
analysis_box: {
  label: "INTERPRETATION GUIDE"
  width: 700
  insight1: |md
    ### ⚠️ Common Misinterpretation
    "db_query went from 15% to 30% - it got worse!"
    **CORRECT:** db_query's *share* increased because we optimized parse_json.
    The absolute time for db_query may not have changed.
    Always check **absolute sample counts**, not just percentages.
  |
  insight2: |md
    ### ✅ Correct Analysis
    1. parse_json: 200 → 80 samples = **60% faster** (optimization worked)
    2. db_query: 150 → 300 samples = **potential regression** OR **same work, larger share**
    3. Total time: may have decreased even though db_query's share increased
  |
}
analysis_box.near: bottom-center