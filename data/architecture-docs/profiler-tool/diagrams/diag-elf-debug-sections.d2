direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "ELF Binary: Debug Information Sections"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
elf_layout: {
  label: "ELF Binary Layout (file offset order)"
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  style.stroke-width: 2
  header: {
    shape: rectangle
    label: "ELF Header\n(0x00)"
    width: 180
    style.fill: "#e9ecef"
    style.stroke: "#6c757d"
  }
  phdr: {
    shape: rectangle
    label: "Program Headers\n(segment table)"
    width: 180
    style.fill: "#e9ecef"
    style.stroke: "#6c757d"
  }
  text_section: {
    shape: rectangle
    label: ".text\n(executable code)"
    width: 180
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.bold: true
  }
  rodata: {
    shape: rectangle
    label: ".rodata\n(read-only data)"
    width: 180
    style.fill: "#e9ecef"
    style.stroke: "#6c757d"
  }
  symtab: {
    shape: sql_table
    label: ".symtab (symbol table)"
    width: 180
    row1: "0x00 | st_name | → .strtab offset"
    row2: "0x04 | st_value | address / 0"
    row3: "0x08 | st_size | symbol size"
    row4: "0x0C | st_info | bind + type"
    row5: "0x0D | st_other | visibility"
    row6: "0x0E | st_shndx | section index"
    total: "Full symbols (stripped: removed)"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
  }
  strtab: {
    shape: rectangle
    label: ".strtab\n(symbol name strings)"
    width: 180
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
  }
  dynsym: {
    shape: rectangle
    label: ".dynsym\n(dynamic symbols)"
    width: 180
    style.fill: "#e7f1ff"
    style.stroke: "#0d6efd"
  }
  dynstr: {
    shape: rectangle
    label: ".dynstr\n(dynamic strings)"
    width: 180
    style.fill: "#e7f1ff"
    style.stroke: "#0d6efd"
  }
}
debug_sections: {
  label: "DWARF Debug Sections (if compiled with -g)"
  style.fill: "#f0e6ff"
  style.stroke: "#8b5cf6"
  style.stroke-dash: 4
  debug_info: {
    shape: sql_table
    label: ".debug_info (DWARF core)"
    row1: "0x00 | unit_length | compilation unit size"
    row2: "0x04 | version | DWARF version (4/5)"
    row3: "0x06 | abbrev_offset | → .debug_abbrev"
    row4: "0x0A | DIEs | type/function/variable"
    total: "Primary debug metadata"
    style.fill: "#e9d5ff"
    style.stroke: "#8b5cf6"
  }
  debug_abbrev: {
    shape: rectangle
    label: ".debug_abbrev\n(abbreviation tables)"
    width: 200
    style.fill: "#e9d5ff"
    style.stroke: "#8b5cf6"
  }
  debug_line: {
    shape: sql_table
    label: ".debug_line (source mapping)"
    row1: "0x00 | unit_length | line program size"
    row2: "0x04 | header | file/dir table"
    row3: "0x?? | opcodes | state machine"
    row4: " — | address | → file:line mapping"
    total: "Address → source location"
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
  }
  debug_str: {
    shape: rectangle
    label: ".debug_str\n(debug strings)"
    width: 200
    style.fill: "#e9d5ff"
    style.stroke: "#8b5cf6"
  }
  debug_ranges: {
    shape: rectangle
    label: ".debug_ranges\n(address ranges)"
    width: 200
    style.fill: "#e9d5ff"
    style.stroke: "#8b5cf6"
  }
}
unwind_sections: {
  label: "Unwind Information"
  style.fill: "#fef3c7"
  style.stroke: "#f59e0b"
  eh_frame: {
    shape: sql_table
    label: ".eh_frame (unwind tables)"
    row1: "0x00 | length | CIE/FDE size"
    row2: "0x04 | CIE_id | 0=CIE, else FDE"
    row3: "0x08 | aug | augmentation string"
    row4: " — | CFA | frame pointer rules"
    total: "Stack unwinding (always present)"
    style.fill: "#fef3c7"
    style.stroke: "#f59e0b"
  }
  eh_frame_hdr: {
    shape: rectangle
    label: ".eh_frame_hdr\n(binary search table)"
    width: 200
    style.fill: "#fef3c7"
    style.stroke: "#f59e0b"
  }
}
link_sections: {
  label: "Debug Link / Build ID"
  style.fill: "#dcfce7"
  style.stroke: "#22c55e"
  gnu_debuglink: {
    shape: sql_table
    label: ".gnu_debuglink"
    row1: "0x00 | filename | 'foo.debug\\0'"
    row2: "0x?? | padding | align to 4"
    row3: " — | crc32 | checksum of debug"
    total: "Path to separate debug file"
    style.fill: "#dcfce7"
    style.stroke: "#22c55e"
  }
  note_build_id: {
    shape: sql_table
    label: ".note.gnu.build-id"
    row1: "0x00 | namesz | 4 ('GNU')"
    row2: "0x04 | descsz | 20 (SHA-1)"
    row3: "0x08 | type | NT_GNU_BUILD_ID"
    row4: "0x0C | name | 'GNU'"
    row5: "0x10 | build_id | unique ID"
    total: "Lookup: .build-id/ab/cdef.debug"
    style.fill: "#dcfce7"
    style.stroke: "#22c55e"
  }
}
legend: {
  label: "Symbol Resolution Priority"
  near: bottom-center
  priority: {
    shape: rectangle
    width: 400
    code: |'text
      1. .symtab     → Full symbols (stripped: removed)
      2. .dynsym     → Exported/imported symbols (always present)
      3. DWARF       → Function names + file:line (if -g)
      4. debuglink   → External .debug file
      5. build-id    → /usr/lib/debug/.build-id/xx/yyy.debug
    '|
    style.fill: "#f8f9fa"
    style.stroke: "#dee2e6"
  }
}
elf_layout.header -> elf_layout.phdr
elf_layout.phdr -> elf_layout.text_section
elf_layout.text_section -> elf_layout.rodata
elf_layout.rodata -> elf_layout.symtab
elf_layout.symtab -> elf_layout.strtab
elf_layout.strtab -> elf_layout.dynsym
elf_layout.dynsym -> elf_layout.dynstr
debug_sections.debug_info -> debug_sections.debug_line: "references"
debug_sections.debug_abbrev -> debug_sections.debug_info: "defines DIE layout"
debug_sections.debug_str -> debug_sections.debug_info: "string pool"
unwind_sections.eh_frame_hdr -> unwind_sections.eh_frame: "index"
elf_layout.symtab -> elf_layout.strtab: "st_name offset"