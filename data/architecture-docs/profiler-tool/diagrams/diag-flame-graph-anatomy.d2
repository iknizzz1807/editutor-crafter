direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Flame Graph Anatomy: Reading the Visualization"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
title.near: top-center

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  flame_graph: {
    direction: down
    label: "Sample Flame Graph (profiler.c)"
    
    frame_root: {
      label: "root (main)"
      width: 600
      style: {
        fill: "#ff7f7f"
        stroke: "#333"
        stroke-width: 2
      }
      code: |'md
        **1000 samples (100%)**
        Base of the stack.
      '|
    }

    layer1: "" {
      direction: right
      style.stroke: transparent
      frame_l1a: {
        label: "process_request()"
        width: 400
        style.fill: "#ffbf7f"
        code: "600 samples (60%)"
      }
      frame_l1b: {
        label: "handle_signal()"
        width: 180
        style.fill: "#7fff7f"
        code: "300 samples (30%)"
      }
      frame_l1c: {
        label: "init()"
        width: 20
        style.fill: "#7f7fff"
        code: "2% width"
      }
    }

    layer2: "" {
      direction: right
      style.stroke: transparent
      frame_l2a: {
        label: "parse_json()"
        width: 300
        style.fill: "#ffff7f"
        code: "300 samples (30%)"
      }
      frame_l2b: {
        label: "validate()"
        width: 90
        style.fill: "#ff7fff"
        code: "90 samples (9%)"
      }
      pad_l2: "" { 
        width: 210
        style.opacity: 0 
      }
    }

    layer3: "" {
      direction: right
      style.stroke: transparent
      frame_l3a: {
        label: "decode_string()"
        width: 250
        style.fill: "#bf7f3f"
        code: "**HOT SPOT** (25%)"
      }
      frame_l3b: {
        label: "tokenize()"
        width: 40
        style.fill: "#3fbf7f"
        code: "4% width"
      }
      pad_l3: "" { 
        width: 310
        style.opacity: 0 
      }
    }

    frame_root -> layer1
    layer1.frame_l1a -> layer2.frame_l2a
    layer2.frame_l2a -> layer3.frame_l3a
  }

  legend: "" {
    direction: down
    label: "Reading Guide"
    axis_legend: {
      shape: sql_table
      label: "Axis Meanings"
      r1: "X-Axis | Sample count (NOT time!)"
      r2: "Y-Axis | Stack depth (root at bottom)"
      r3: "Width  | Proportion of samples"
      r4: "Color  | Arbitrary (or by package)"
      sz: "Scale: 1px = 1.6 samples"
    }
    color_legend: {
      shape: sql_table
      label: "Color Meanings"
      c1: "#ff7f7f | Root / Entry"
      c5: "#ffff7f | Parsing logic"
      c7: "#bf7f3f | Leaf / Hot Spot"
    }
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  misinterpretations: {
    direction: down
    label: "Common Misinterpretations"
    myth1: {
      label: "MYTH: X-axis shows time order"
      width: 380
      style: { fill: "#ffcccc"; stroke: "#cc0000"; stroke-dash: 3 }
      code: |'md
        **WRONG!** X-axis has NO temporal meaning.
        Samples are collapsed; order is arbitrary.
        Left-to-right is NOT start-to-finish.
      '|
    }
    myth2: {
      label: "MYTH: Taller = More Time"
      width: 380
      style: { fill: "#ffcccc"; stroke: "#cc0000"; stroke-dash: 3 }
      code: |'md
        **WRONG!** Height = stack depth only.
        A tall, thin stack is a deep call
        chain that happens rarely.
      '|
    }
  }

  correct_reading: {
    direction: down
    label: "Correct Interpretation"
    truth1: {
      label: "Width = Resource Usage"
      width: 380
      style: { fill: "#ccffcc"; stroke: "#006600" }
      code: |'md
        **CORRECT!** Look for wide leaf boxes.
        Width is proportional to CPU samples.
        Wide = function was on-CPU often.
      '|
    }
    truth2: {
      label: "Inclusive vs Self-Time"
      width: 380
      style: { fill: "#ccffcc"; stroke: "#006600" }
      code: |'md
        **CORRECT!** Parent width is inclusive.
        It includes all cycles spent in children.
        Leaf width is primarily self-time.
      '|
    }
  }
}

row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  formula_box: {
    direction: down
    label: "Statistical Foundation"
    calc: {
      label: "Width Model"
      width: 500
      style: { fill: "#e8e8e8"; font: mono }
      code: |'c
        // Width calculation (statistical)
        w(func) = (samples_f / total_samples) * 100%
        
        // Example (decode_string):
        // 250 / 1000 = 25% width
        // Precision increases with samples.
      '|
    }
  }

  action_guide: {
    direction: down
    label: "Optimization Strategy"
    workflow_table: {
      shape: sql_table
      label: "Workflow"
      s1: "1. Find widest leaf boxes (Hot Spots)"
      s2: "2. Examine stack context (Trace Up)"
      s3: "3. Check multiple paths (Merged View)"
      s4: "4. Target leaf for code efficiency"
      s5: "5. Target parent to reduce frequency"
    }
  }
}

row1 -> row2: "Anatomy | analysis"
row2 -> row3: "Logic | action"