direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: "LD_PRELOAD: Library Interposition Mechanism"
  shape: package
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  app: {
    direction: down
    label: "Application (main.c)"
    style.fill: "#E8F4FD"
    code: {
      label: "User Code"
      width: 250
      code: |'c
        void* ptr = malloc(1024);
        // Process data...
        free(ptr);
      '|
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dynlink: {
    direction: down
    label: "Dynamic Linker (ld-linux.so)"
    style.fill: "#FFF3E0"
    res_order: {
      label: "Symbol Resolution Order"
      width: 380
      code: |'c
        // 1. LD_PRELOAD libraries (first!)
        // 2. LD_LIBRARY_PATH paths
        // 3. /etc/ld.so.cache entries
        // 4. Default system paths (/lib, /usr/lib)
      '|
    }
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  preload: {
    direction: down
    label: "LD_PRELOAD Library (libmem_profiler.so)"
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    wrapper: {
      shape: class
      label: "malloc() Wrapper"
      +malloc(size): "void*"
      +free(ptr): "void"
      +calloc(nmemb, size): "void*"
      +realloc(ptr, size): "void*"
      -track_allocation(ptr, size): "void"
      -track_free(ptr): "void"
    }
    guard: {
      label: "Recursion Guard"
      width: 320
      code: |'c
        thread_local bool in_profiler = false;
        if (in_profiler) return real_malloc(size);
        in_profiler = true;
        // ... tracking code ...
        in_profiler = false;
      '|
    }
  }
}

row4: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dlsym_box: {
    direction: down
    label: "Real Function Lookup"
    style.fill: "#F3E5F5"
    lookup: {
      width: 350
      code: |'c
        // Get real malloc from next library
        void* (*real_malloc)(size_t) = 
          dlsym(RTLD_NEXT, "malloc");
      '|
    }
    rtld_next: {
      label: "RTLD_NEXT"
      shape: diamond
      style.fill: "#E1BEE7"
    }
  }
}

row5: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  libc: {
    direction: down
    label: "libc.so.6"
    style.fill: "#FFCDD2"
    real_impl: {
      shape: class
      label: "Real Implementations"
      +malloc(size): "void*"
      +free(ptr): "void"
      +brk(ptr): "void*"
      +mmap(args): "void*"
    }
    heap: {
      label: "Heap Management"
      shape: cylinder
      style.fill: "#EF9A9A"
    }
  }
}

# Connections using absolute paths to resolve scoping
row1.app.code -> row2.dynlink.res_order: "malloc() | call" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}

row2.dynlink.res_order -> row3.preload.wrapper: "resolves symbol" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 3
}

row3.preload.wrapper -> row3.preload.guard: "interpose" {
  style.stroke: "#2E7D32"
}

row3.preload.guard -> row4.dlsym_box.lookup: "dlsym(NEXT)" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}

row4.dlsym_box.rtld_next -> row5.libc.real_impl: "finds real" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}

row5.libc.real_impl -> row5.libc.heap: "mmap/brk" {
  style.stroke: "#C62828"
}

row5.libc.real_impl -> row3.preload.wrapper: "void* | return" {
  style.stroke: "#C62828"
  style.stroke-dash: 5
}

row3.preload.wrapper -> row1.app.code: "void* | return" {
  style.stroke: "#1565C0"
  style.stroke-dash: 5
}

# Legend Implementation
interception_legend: {
  shape: sql_table
  label: "Interception Flow"
  step1: "1. App calls malloc()"
  step2: "2. Linker finds wrapper in LD_PRELOAD"
  step3: "3. Wrapper tracks allocation"
  step4: "4. Wrapper calls real_malloc via RTLD_NEXT"
  step5: "5. Real malloc allocates memory"
}
interception_legend.near: bottom-right