direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Multi-Threaded Sample Collection
  Signal delivery, thread-local buffers, and lock-free aggregation
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  thread1: {
    direction: down
    label: "Thread 1 (TID: 12345)"
    style.fill: "#e8f5e9"
    style.stroke: "#4caf50"
    stack1: {
      shape: rectangle
      label: "User Stack"
      code: |'c
        process_request()
        parse_json()
        decode_string()  ← RIP
      '|
      width: 200
    }
    tls1: {
      label: "Thread-Local State"
      shape: sql_table
      f0: "0x00 | u64      | tid"
      f1: "0x08 | bool     | in_handler"
      f2: "0x10 | *Sample  | current_buf"
      sz: "32 bytes"
    }
    buf1: {
      label: "Local Sample Buffer"
      shape: cylinder
      style.fill: "#c8e6c9"
    }
  }
  thread2: {
    direction: down
    label: "Thread 2 (TID: 12346)"
    style.fill: "#e3f2fd"
    style.stroke: "#2196f3"
    stack2: {
      shape: rectangle
      label: "User Stack"
      code: |'c
        handle_connection()
        read_request()
        wait_for_data()  ← RIP
      '|
      width: 200
    }
    tls2: {
      label: "Thread-Local State"
      shape: sql_table
      f0: "0x00 | u64      | tid"
      f1: "0x08 | bool     | in_handler"
      f2: "0x10 | *Sample  | current_buf"
      sz: "32 bytes"
    }
    buf2: {
      label: "Local Sample Buffer"
      shape: cylinder
      style.fill: "#bbdefb"
    }
  }
  thread3: {
    direction: down
    label: "Thread 3 (TID: 12347)"
    style.fill: "#fff3e0"
    style.stroke: "#ff9800"
    stack3: {
      shape: rectangle
      label: "User Stack"
      code: |'c
        background_worker()
        process_queue()
        dequeue_item()  ← RIP
      '|
      width: 200
    }
    tls3: {
      label: "Thread-Local State"
      shape: sql_table
      f0: "0x00 | u64      | tid"
      f1: "0x08 | bool     | in_handler"
      f2: "0x10 | *Sample  | current_buf"
      sz: "32 bytes"
    }
    buf3: {
      label: "Local Sample Buffer"
      shape: cylinder
      style.fill: "#ffe0b2"
    }
  }
}
kernel_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timer: {
    label: "ITIMER_PROF\n(99 Hz)"
    shape: oval
    style.fill: "#ffcdd2"
    style.stroke: "#f44336"
  }
  scheduler: {
    label: "Kernel Scheduler"
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#9e9e9e"
    note: |md
      **Signal Delivery Rules:**
      - SIGPROF delivered to *running* thread
      - Respects CPU time (user + system)
      - Sleeping threads are NOT sampled
    |
  }
}
signal_delivery: {
  direction: right
  label: "Signal Delivery (SIGPROF)"
  step1: {
    label: "1. Timer Fires"
    code: |'c
      // Hardware timer interrupt
      // -> kernel checks ITIMER_PROF
      // -> decrements remaining time
    '|
    width: 280
  }
  step2: {
    label: "2. Select Target"
    code: |'c
      // Find currently running thread
      // on this CPU core
      target = current->on_cpu;
    '|
    width: 280
  }
  step3: {
    label: "3. Deliver Signal"
    code: |'c
      // Build signal frame on user stack
      // Save registers (RIP, RBP, RSP...)
      // Redirect to sigprof_handler()
    '|
    width: 280
  }
}
aggregation_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ring_buffer: {
    direction: down
    label: "Lock-Free Ring Buffer"
    style.fill: "#f3e5f5"
    style.stroke: "#9c27b0"
    struct: {
      shape: sql_table
      label: "struct RingBuffer (profiler.h)"
      f0: "0x00 | *Sample   | data"
      f1: "0x08 | usize     | capacity"
      f2: "0x10 | AtomicUsize | write_pos"
      f3: "0x18 | AtomicUsize | read_pos"
      f4: "0x20 | AtomicUsize | count"
      sz: "40 bytes + samples"
    }
    sample: {
      shape: sql_table
      label: "struct RawSample (64-byte aligned)"
      f0: "0x00 | u64       | thread_id"
      f1: "0x08 | u64       | timestamp_ns"
      f2: "0x10 | u8        | depth"
      f3: "0x11 | u8[7]     | _padding"
      f4: "0x18 | [usize;128]| addresses"
      sz: "1048 bytes (fits 16/cache line)"
    }
  }
  dashmap: {
    direction: down
    label: "DashMap Aggregator"
    style.fill: "#e0f7fa"
    style.stroke: "#00bcd4"
    shards: {
      label: "Sharded Locks (32 shards)"
      shape: rectangle
      code: |'c
        // Each shard has its own RwLock
        // Reduces contention vs single Mutex
        struct Shard {
          lock: RwLock<()>,
          map: HashMap<K, V>,
        }
      '|
      width: 300
    }
    aggregate: {
      label: "Aggregation Logic"
      shape: class
      -samples: "DashMap<Path, usize>"
      -total: "AtomicU64"
      +add_sample(): "void"
      +get_hot_paths(): "Vec<Path>"
    }
  }
}
race_conditions: {
  direction: down
  label: "Race Condition Scenarios"
  style.fill: "#fff8e1"
  style.stroke: "#ffc107"
  scenario1: {
    label: "Scenario 1: Concurrent write_pos Update"
    code: |'c
      // Thread A                    // Thread B
      let slot = write_pos           let slot = write_pos
        .fetch_add(1);                 .fetch_add(1);
      // slot = 100                  // slot = 101
      // Both get unique slots ✓
      // Atomic fetch_add is safe
    '|
    width: 350
  }
  scenario2: {
    label: "Scenario 2: False Sharing"
    code: |'c
      // Problem: adjacent samples share cache line
      // Thread A writes samples[100]
      // Thread B writes samples[101]
      // Same 64-byte cache line!
      // Solution: align Sample to 64 bytes
      #[repr(C, align(64))]
      struct RawSample { ... }
    '|
    width: 350
  }
  scenario3: {
    label: "Scenario 3: Signal During malloc"
    code: |'c
      // DANGER: signal interrupts malloc
      // Signal handler must NOT call malloc!
      // Use thread_local guard:
      thread_local! {
        static IN_HANDLER: Cell<bool>;
      }
      if IN_HANDLER.get() { return; }
    '|
    width: 350
  }
}
handler_flow: {
  direction: down
  label: "Signal Handler Flow (Async-Signal-Safe)"
  step_a: {
    label: "Entry: sigprof_handler()"
    code: |'c
      // 1. Check recursion guard (TLS)
      if (IN_HANDLER.get()) return;
      IN_HANDLER.set(true);
    '|
    width: 350
  }
  step_b: {
    label: "Capture Context"
    code: |'c
      // 2. Extract registers from ucontext
      ucontext_t *ctx = (ucontext_t*)ucontext;
      rbp = ctx->uc_mcontext.gregs[REG_RBP];
      rip = ctx->uc_mcontext.gregs[REG_RIP];
    '|
    width: 350
  }
  step_c: {
    label: "Walk Stack (Frame Pointers)"
    code: |'c
      // 3. Follow rbp chain
      while (rbp && depth < MAX_DEPTH) {
        addresses[depth++] = *(rbp + 1); // ret addr
        rbp = *rbp; // prev frame
      }
    '|
    width: 350
  }
  step_d: {
    label: "Write to Ring Buffer"
    code: |'c
      // 4. Atomic slot reservation
      slot = write_pos.fetch_add(1) % CAPACITY;
      samples[slot] = (RawSample){tid, ts, depth, addrs};
      IN_HANDLER.set(false);
    '|
    width: 350
  }
}
timer -> scheduler: "timer interrupt"
scheduler -> thread1.stack1: "SIGPROF\nto running\nthread" {
  style.stroke: "#f44336"
  style.stroke-dash: 3
  style.animated: true
}
thread1.buf1 -> ring_buffer.struct: "commit" {
  style.stroke: "#9c27b0"
}
thread2.buf2 -> ring_buffer.struct: "commit" {
  style.stroke: "#9c27b0"
}
thread3.buf3 -> ring_buffer.struct: "commit" {
  style.stroke: "#9c27b0"
}
ring_buffer.struct -> dashmap.aggregate: "drain &\naggregate" {
  style.stroke: "#00bcd4"
  style.stroke-dash: 5
}
legend: {
  near: bottom-right
  style.fill: "#fafafa"
  style.stroke: "#e0e0e0"
  item1: "Red dashed = signal delivery path"
  item2: "Purple = lock-free ring buffer ops"
  item3: "Cyan = aggregation (post-processing)"
}