direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Profiler Overhead: Where Cycles Go
  **5% Budget Breakdown at 99 Hz, 20-frame average stack**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  budget: {
    label: "5% Overhead Budget\n(50ms per second)"
    shape: rectangle
    width: 280
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    style.stroke-width: 3
    breakdown: {
      shape: sql_table
      label: "Overhead Components (99 Hz, 20 frames)"
      c1: "Component | Time/Sample | Per Second | % Budget"
      c2: "Signal Delivery | ~700ns | 69μs | 0.14%"
      c3: "Stack Unwind | ~4μs | 396μs | 0.79%"
      c4: "Sample Storage | ~500ns | 50μs | 0.10%"
      c5: "Aggregation* | ~2μs | 198μs | 0.40%"
      c6: "Cache/TLB Miss | ~3μs | 297μs | 0.59%"
      c7: "Safety Margin | — | — | ~3%"
      total: "Total: ~1.5ms/s = 0.15% (ideal)"
    }
    note: "* Aggregation deferred to post-profile"
  }
  scaling: {
    label: "Scaling Laws"
    shape: rectangle
    width: 320
    freq_table: {
      shape: sql_table
      label: "Sampling Frequency Impact"
      f1: "10 Hz | 0.015% | Production"
      f2: "49 Hz | 0.074% | Continuous"
      f3: "99 Hz | 0.15% | Development"
      f4: "999 Hz | 1.5% | Detailed"
      f5: "9999 Hz | 15%+ | Distorts results"
    }
    depth_table: {
      shape: sql_table
      label: "Stack Depth Impact (at 99 Hz)"
      d1: "5 frames | 1.0μs unwind | 0.01%"
      d2: "20 frames | 4.0μs unwind | 0.04%"
      d3: "50 frames | 10.0μs unwind | 0.10%"
      d4: "128 frames | 25.6μs unwind | 0.25%"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  signal: {
    label: "Signal Delivery (~700ns)"
    style.fill: "#E6F3FF"
    components: {
      shape: sql_table
      label: "struct SignalCost (kernel/signal.h)"
      s1: "0x00 | Timer interrupt | ~100ns"
      s2: "0x04 | Kernel entry | ~100ns"
      s3: "0x08 | Signal frame setup | ~200ns"
      s4: "0x0C | User-space jump | ~100ns"
      s5: "0x10 | Return path | ~200ns"
      sz: "Total: ~700ns (constant)"
    }
    note: "Hardware timer → IDT → kernel → signal frame → handler"
  }
  unwind: {
    label: "Stack Unwind (~200ns/frame)"
    style.fill: "#FFF0E6"
    components: {
      shape: sql_table
      label: "struct UnwindCost (profiler/unwind.c)"
      u1: "0x00 | RBP validation | ~20ns"
      u2: "0x04 | Memory load (RBP) | ~50ns"
      u3: "0x08 | Memory load (RIP) | ~50ns"
      u4: "0x0C | Bounds check | ~20ns"
      u5: "0x10 | Buffer store | ~30ns"
      u6: "0x14 | Loop overhead | ~30ns"
      sz: "Per-frame: ~200ns"
    }
    note: "20 frames × 200ns = 4μs per sample"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  storage: {
    label: "Sample Storage (~500ns)"
    style.fill: "#E6FFE6"
    components: {
      shape: sql_table
      label: "struct StorageCost (profiler/buffer.c)"
      st1: "0x00 | Atomic fetch_add | ~50ns"
      st2: "0x04 | Ring buffer slot | ~50ns"
      st3: "0x08 | Timestamp (RDTSC) | ~30ns"
      st4: "0x0C | Thread ID (sys_gettid) | ~300ns"
      st5: "0x10 | Memcpy addresses | ~70ns"
      sz: "Total: ~500ns (lock-free)"
    }
    note: "Pre-allocated buffer → no malloc in handler"
  }
  sync: {
    label: "Synchronization (Deferred)"
    style.fill: "#F0E6FF"
    components: {
      shape: sql_table
      label: "struct SyncCost (profiler/aggregate.c)"
      sy1: "0x00 | Hash table insert | ~100ns"
      sy2: "0x04 | String interning | ~200ns"
      sy3: "0x08 | Counter update | ~50ns"
      sy4: "0x0C | Lock acquisition* | AVOIDED"
      sz: "Deferred: NOT in signal handler"
    }
    note: "Aggregation happens post-profile in safe context"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hidden: {
    label: "Hidden Costs (Often Overlooked)"
    style.fill: "#FFE6E6"
    style.stroke: "#CC0000"
    costs: {
      shape: sql_table
      label: "struct HiddenCost (profiler/reality.c)"
      h1: "Cache pollution | Handler code evicts app"
      h2: "TLB pressure | Sample buffer access"
      h3: "Pipeline stall | Context switch"
      h4: "Branch mispredict | Unwind loop"
      h5: "Memory bandwidth | 1KB write/sample"
      sz: "Estimate: +2-3× visible overhead"
    }
  }
  danger: {
    label: "Danger Zone: 100μs+ Handlers"
    style.fill: "#FFCCCC"
    style.stroke: "#FF0000"
    style.stroke-width: 2
    causes: {
      shape: sql_table
      label: "What Breaks the Budget"
      b1: "malloc() in handler | DEADLOCK RISK"
      b2: "printf() logging | LOCK CONTENTION"
      b3: "pthread_mutex | DEADLOCK RISK"
      b4: "DWARF unwind | 5-20× slower"
      b5: "Symbol lookup | String ops"
      sz: "These cause 50-500μs handlers"
    }
    impact: {
      shape: sql_table
      label: "Impact at 99 Hz"
      i1: "50μs handler | 0.5% overhead"
      i2: "100μs handler | 1.0% overhead"
      i3: "500μs handler | 5.0% overhead"
      i4: "1ms handler | 10%+ DISTORTION"
    }
  }
}
budget -> scaling: "scales with"
signal -> unwind: "triggers"
unwind -> storage: "produces"
storage -> sync: "buffers for"
hidden -> danger: "can cause"
legend: {
  near: bottom-center
  label: "Overhead Budget Rules"
  l1: "Signal-safe: NO malloc, NO locks, NO I/O"
  l2: "Pre-allocate: All buffers before profiling"
  l3: "Defer: Symbol resolution to post-profile"
  l4: "Prime freq: 49/99 Hz avoids lock-step"
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#999999"
}