direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Profiler Tool: System Overview & Profile Merging" {
  shape: text
  style: {
    font-size: 32
    bold: true
    italic: true
  }
}

pipeline: {
  style.stroke: transparent
  style.fill: transparent

  row1: {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    step1: {
      label: "1. Statistical Sampling (sampler.rs)"
      code: |'rust
        // Signal handler triggered by timer
        for i in 0..max_samples {
          let stack = walk_stack(rbp, rip);
          samples[i] = Sample {
            stack,
            timestamp: now(),
          };
        }
      '|
      width: 400
    }

    step2: {
      label: "2. Stack Folding (aggregator.rs)"
      code: |'rust
        for sample in samples {
          let stack: Vec<String> = sample.addrs
            .iter().rev()
            .filter_map(|&a| symbols.lookup(a))
            .collect();
          collapsed.add(&stack, 1);
        }
      '|
      width: 400
    }
  }

  row2: {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    step3: {
      label: "3. Call Graph Construction (graph.rs)"
      code: |'rust
        let mut graph = CallGraph::new();
        for sample in samples {
          graph.insert_stack(&sample.stack);
        }
        // Build weighted edges for analysis
        graph.compute_weights();
      '|
      width: 400
    }

    step4: {
      label: "4. Flame Graph Rendering (render.rs)"
      code: |'rust
        let tree = build_flame_tree(collapsed);
        let renderer = FlameRenderer::new(1200, 16);
        // Generates SVG rects with color schemes
        let svg = renderer.render(&tree);
      '|
      width: 400
    }
  }

  row3: {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    step5: {
      label: "5. Profile Export (export.rs)"
      code: |'rust
        match format {
          "pprof" => write_pprof(data, path)?,
          "json"  => write_speedscope(data, path)?,
          "svg"   => write_svg(svg_data, path)?,
          _       => return Err("Unsupported"),
        }
      '|
      width: 400
    }
  }

  # Orchestration Flow
  row1.step1 -> row1.step2: "Vec<Sample> | batch"
  row1.step2 -> row2.step3: "CollapsedStacks | aggregate"
  row2.step3 -> row2.step4: "GraphNodes | analyze"
  row2.step4 -> row3.step5: "SVG/Buffer | serialize"
}

legend_container: {
  label: "Visualization Legend"
  style: {
    stroke: "#cccccc"
    stroke-dash: 2
    fill: "#f9f9f9"
  }
  
  legend_items: {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    cpu_time: "CPU Hotpath" {
      style.fill: "#ff7f7f"
      style.stroke: "#cc0000"
    }
    
    io_wait: "I/O Blocking" {
      style.fill: "#7f7fff"
      style.stroke: "#0000cc"
    }

    cpu_time -> io_wait: "Preemption"
  }
}

legend_container.near: bottom-right

# Global error paths
row1.step1 -> row3.step5: "Failure | abort" {
  style: {
    stroke: "#ff0000"
    stroke-dash: 4
  }
}