direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Recursive Functions in Call Graphs & Flame Graphs"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  recursive_section: {
    direction: down
    label: "Recursive Call Chain"
    call_stack: {
      label: "Physical Stack (Sample at t=100ms)"
      shape: rectangle
      width: 320
      style.fill: "#E8F4FD"
      code: |'c
        fib(5)
          ↓ calls
        fib(4)
          ↓ calls  
        fib(3)
          ↓ calls
        fib(2)    ← sample here
      '|
    }
    stack_note: {
      label: "Same function appears N times"
      shape: callout
      style.fill: "#FFF9E6"
    }
    stack_note -> call_stack
  }
  graph_section: {
    direction: down
    label: "Call Graph Representation"
    call_graph: {
      shape: class
      label: "Node: fib"
      -total_samples: "250"
      -self_samples: "250"
      -callers: "{main, fib}"
      -callees: "{fib}"
    }
    self_edge: {
      label: "Self-Edge\n(fib → fib)"
      shape: rectangle
      width: 180
      style: {
        fill: "#FFE6E6"
        stroke: "#CC0000"
        stroke-dash: 3
      }
    }
    call_graph -> self_edge: "250 calls" {
      style: {
        stroke: "#CC0000"
        stroke-dash: 3
        animated: true
      }
    }
    graph_note: {
      label: "Collapsed to single node\nwith self-referencing edge"
      shape: callout
      style.fill: "#FFF9E6"
    }
    graph_note -> call_graph
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  flame_recursive: {
    direction: down
    label: "Flame Graph: Recursive"
    flame_rec: {
      shape: rectangle
      width: 400
      style.fill: "#F5F5F5"
      f0: {
        label: "main"
        shape: rectangle
        width: 380
        style.fill: "#C8E6C9"
      }
      f1: {
        label: "fib(5)"
        shape: rectangle
        width: 380
        style.fill: "#FFCC80"
      }
      f2: {
        label: "fib(4)"
        shape: rectangle
        width: 380
        style.fill: "#FFCC80"
      }
      f3: {
        label: "fib(3)"
        shape: rectangle
        width: 380
        style.fill: "#FFCC80"
      }
      f4: {
        label: "fib(2) + fib(1) + ..."
        shape: rectangle
        width: 380
        style.fill: "#FFCC80"
      }
      f0 -> f1 -> f2 -> f3 -> f4
    }
    width_note: {
      label: "Width at each depth shows\nrecursive calls in samples"
      shape: text
    }
  }
  flame_iterative: {
    direction: down
    label: "Flame Graph: Iterative"
    flame_iter: {
      shape: rectangle
      width: 400
      style.fill: "#F5F5F5"
      i0: {
        label: "main"
        shape: rectangle
        width: 380
        style.fill: "#C8E6C9"
      }
      i1: {
        label: "fib_iterative"
        shape: rectangle
        width: 380
        style.fill: "#90CAF9"
      }
      i0 -> i1
    }
    depth_note: {
      label: "Single frame\nno stack growth"
      shape: text
    }
  }
}
comparison: {
  label: "Comparison: Recursive vs Iterative"
  shape: rectangle
  width: 900
  table: ||md
    | Aspect | Recursive `fib` | Iterative `fib` |
    |--------|-----------------|-----------------|
    | Stack depth | N frames per sample | 1 frame per sample |
    | Call graph | Single node + self-edge | Single node, no self-edge |
    | Flame graph | Wide bars at multiple depths | Single bar |
    | Sample attribution | All to `fib` | All to `fib_iterative` |
    | Visual pattern | "Towers" of same color | Flat profile |
    | Profiler sees | Same function N times | Function once |
  ||
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  impl_section: {
    direction: down
    label: "Implementation: Detecting Recursion"
    code_block: {
      label: "Call Graph Construction"
      width: 450
      code: |'rust
        impl CallGraph {
          fn is_recursive(&self, func: &str) -> bool {
            self.nodes.get(func)
              .map(|n| n.callees.contains_key(func))
              .unwrap_or(false)
          }
          fn recursion_depth(&self, samples: &[Sample]) 
            -> HashMap<String, usize> 
          {
            // Count max stack depth per function
            let mut depths = HashMap::new();
            for s in samples {
              let count = s.stack.iter()
                .filter(|&&f| f == func).count();
              depths.entry(func)
                .and_modify(|d| *d = (*d).max(count))
                .or_insert(count);
            }
            depths
          }
        }
      '|
    }
  }
  handling_section: {
    direction: down
    label: "Flame Graph Handling"
    handle_code: {
      label: "Collapse vs Expand"
      width: 450
      code: |'rust
        // Option 1: Collapse to single bar
        // Total width = sum of all recursive samples
        // Option 2: Show depth distribution
        // Each depth level shown separately
        // Flame graph naturally shows both:
        // - Width = total samples across all depths
        // - Height = max recursion depth observed
        fn render_recursive(node: &FlameNode) {
          // Recursive calls appear as children
          // with same function name
          for child in &node.children {
            if child.name == node.name {
              // Self-reference = recursion
              render_recursive(child);
            }
          }
        }
      '|
    }
  }
}
key_insight: {
  label: "Key Insight"
  shape: rectangle
  width: 900
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    border-radius: 8
  }
  insight: |md
    **Recursion in profilers:**
    1. **Physical stack** shows N copies of the same function
    2. **Call graph** collapses to single node with self-edge
    3. **Flame graph** preserves visual representation of depth
    4. **Sample counts** are attributed correctly regardless of approach
    5. **TCO (Tail Call Optimization)** may hide recursion entirely
    The profiler cannot distinguish "deep recursion" from "many separate calls"
    without tracking individual call chains — samples are snapshots, not traces.
  |
}
row1 -> row2: "transforms to"
row2 -> comparison: "compare"
comparison -> row3: "implementation"
row3 -> key_insight: "understanding"