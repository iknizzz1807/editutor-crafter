direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Profiler Tool: System Architecture
  Complete sampling profiler with CPU, memory, async, and export capabilities
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  target: {
    direction: down
    label: "Target Application"
    style.fill: "#E8F4EA"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    app_code: {
      label: "Application Code"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    sync_funcs: {
      label: "Sync Functions"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    async_runt: {
      label: "Async Runtime\n(Tokio)"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    alloc_call: {
      label: "malloc/free\ncalls"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  intercept: {
    direction: down
    label: "Interception Layer"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    signal_hand: {
      label: "Signal Handler\n(SIGPROF)"
      shape: rectangle
      style.fill: "#FFE0B2"
    }
    ld_preload: {
      label: "LD_PRELOAD\nInterposition"
      shape: rectangle
      style.fill: "#FFE0B2"
    }
    task_wrap: {
      label: "Task Wrapper\n(Future trait)"
      shape: rectangle
      style.fill: "#FFE0B2"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  engine: {
    direction: down
    label: "Profiler Engine Core"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 3
    cpu_samp: {
      label: "M1: CPU Sampler"
      shape: class
      -epoll_fd: "int"
      -sample_buf: "RingBuffer"
      -frequency: "u64"
      +start_sampling(): "Result<>"
      +stop_sampling(): "ProfileData"
      +walk_stack(): "Vec<usize>"
    }
    call_graph: {
      label: "M2: Call Graph Builder"
      shape: class
      -nodes: "HashMap<ID, Node>"
      -edges: "Vec<Edge>"
      +from_samples(): "CallGraph"
      +fold_stacks(): "Collapsed"
      +build_flame(): "FlameTree"
    }
    mem_track: {
      label: "M3: Memory Tracker"
      shape: class
      -allocations: "DashMap"
      -call_sites: "HashMap"
      +record_malloc(): "void"
      +record_free(): "void"
      +detect_leaks(): "LeakReport"
    }
    async_prof: {
      label: "M4: Async Profiler"
      shape: class
      -tasks: "DashMap<TaskID, Life>"
      -relationships: "Graph"
      +record_spawn(): "void"
      +begin_poll(): "void"
      +end_poll(): "void"
      +time_breakdown(): "TaskTime"
    }
    export: {
      label: "M5: Export & Integration"
      shape: class
      -symbols: "SymbolTable"
      -dwarf: "DwarfInfo"
      +to_pprof(): "Vec<u8>"
      +to_collapsed(): "String"
      +to_json(): "String"
      +serve_http(): "void"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output: {
    direction: down
    label: "Output Formats"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    pprof_out: {
      label: "pprof\nProtobuf"
      shape: cylinder
      style.fill: "#E1BEE7"
    }
    collaps: {
      label: "Collapsed\nStacks"
      shape: document
      style.fill: "#E1BEE7"
    }
    flame_svg: {
      label: "Flame Graph\nSVG"
      shape: rectangle
      style.fill: "#E1BEE7"
    }
    json_out: {
      label: "speedscope\nJSON"
      shape: document
      style.fill: "#E1BEE7"
    }
    http_end: {
      label: "HTTP\nEndpoint"
      shape: rectangle
      style.fill: "#E1BEE7"
    }
  }
}
legend: {
  near: bottom-right
  label: "Data Flow Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  cpu_flow: "CPU samples" {style.fill: "#EF5350"}
  mem_flow: "Memory events" {style.fill: "#AB47BC"}
  async_flow: "Async context" {style.fill: "#42A5F5"}
  export_flow: "Export data" {style.fill: "#66BB6A"}
}
target.app_code -> intercept.signal_hand: "timer interrupt" {
  style.stroke: "#EF5350"
  style.stroke-width: 2
}
target.sync_funcs -> intercept.signal_hand: "stack walk" {
  style.stroke: "#EF5350"
  style.stroke-dash: 3
}
target.alloc_call -> intercept.ld_preload: "malloc/free" {
  style.stroke: "#AB47BC"
  style.stroke-width: 2
}
target.async_runt -> intercept.task_wrap: "poll/wake" {
  style.stroke: "#42A5F5"
  style.stroke-width: 2
}
intercept.signal_hand -> engine.cpu_samp: "RawSample[]" {
  style.stroke: "#EF5350"
  style.stroke-width: 2
}
intercept.ld_preload -> engine.mem_track: "AllocInfo" {
  style.stroke: "#AB47BC"
  style.stroke-width: 2
}
intercept.task_wrap -> engine.async_prof: "TaskEvent" {
  style.stroke: "#42A5F5"
  style.stroke-width: 2
}
engine.cpu_samp -> engine.call_graph: "samples" {
  style.stroke: "#EF5350"
}
engine.cpu_samp -> engine.async_prof: "async samples" {
  style.stroke: "#42A5F5"
  style.stroke-dash: 3
}
engine.mem_track -> engine.call_graph: "alloc stacks" {
  style.stroke: "#AB47BC"
  style.stroke-dash: 3
}
engine.call_graph -> engine.export: "ProfileData" {
  style.stroke: "#66BB6A"
}
engine.async_prof -> engine.export: "AsyncReport" {
  style.stroke: "#66BB6A"
}
engine.mem_track -> engine.export: "LeakReport" {
  style.stroke: "#66BB6A"
}
engine.export -> output.pprof_out: ".pb" {
  style.stroke: "#66BB6A"
}
engine.export -> output.collaps: ".txt" {
  style.stroke: "#66BB6A"
}
engine.export -> output.flame_svg: ".svg" {
  style.stroke: "#66BB6A"
}
engine.export -> output.json_out: ".json" {
  style.stroke: "#66BB6A"
}
engine.export -> output.http_end: ":6060" {
  style.stroke: "#66BB6A"
}
intercept_internal: {
  label: "Interception Details"
  near: bottom-left
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  sig_note: |md
    **Signal Handler (M1)**
    - Async-signal-safe only
    - Pre-allocated buffers
    - Frame pointer unwinding
  |
  ld_note: |md
    **LD_PRELOAD (M3)**
    - dlsym(RTLD_NEXT)
    - Recursion guards
    - Thread-local state
  |
  wrap_note: |md
    **Task Wrapper (M4)**
    - poll() instrumentation
    - Spawn context capture
    - Wake tracking
  |
}