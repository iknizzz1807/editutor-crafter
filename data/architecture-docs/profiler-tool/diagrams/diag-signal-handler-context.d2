direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Signal Handler Execution Context"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  level1: {
    direction: down
    label: "Level 1: Application"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    app_code: {
      label: "Application Code"
      width: 200
      code: |'c
        void process_request() {
          parse_json();      // executing
          validate();        // pending
          transform();       // pending
        }
      '|
    }
    app_state: {
      label: "Runtime State"
      shape: sql_table
      f1: "RIP | 0x401a3c"
      f2: "RSP | 0x7fff..."
      f3: "RBP | 0x7fff..."
      f4: "State | Running"
    }
    app_code -> app_state: "registers"
  }
  level2: {
    direction: down
    label: "Level 2: OS/Kernel"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    timer_hw: {
      label: "Timer Interrupt"
      width: 200
      code: |'c
        // Hardware timer fires
        LAPIC_timer -> CPU_int
        // Vector 0xE0 (ITIMER_PROF)
      '|
    }
    kernel_path: {
      label: "Kernel Path"
      shape: sql_table
      k1: "1 | Save context"
      k2: "2 | Find target thread"
      k3: "3 | Build signal frame"
      k4: "4 | Set return trampoline"
    }
    timer_hw -> kernel_path: "interrupt"
  }
  level3: {
    direction: down
    label: "Level 3: Signal Handler"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    handler: {
      label: "sigprof_handler()"
      width: 200
      code: |'c
        void handler(int sig, 
          siginfo_t *info, 
          void *ucontext) {
          // Get RBP from ucontext
          // Walk frame pointers
          // Write to pre-alloc'd buffer
          // NO malloc/locks/printf!
        }
      '|
    }
    context: {
      label: "Restricted Context"
      shape: sql_table
      c1: "Stack | sigaltstack"
      c2: "Time | ~2-5 μs budget"
      c3: "State | Async-signal"
      c4: "Safety | Critical!"
    }
    handler -> context: "executes in"
  }
}
row1.level1.app_code -> row1.level2.timer_hw: "interrupted by" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row1.level2.kernel_path -> row1.level3.handler: "delivers SIGPROF" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.animated: true
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  safe_funcs: {
    direction: down
    label: "Async-Signal-Safe Functions"
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 280
    safe_list: {
      shape: sql_table
      label: "CAN Call (safe)"
      s1: "write() | direct syscall"
      s2: "read() | direct syscall"
      s3: "sigprocmask() | signal ops"
      s4: "_exit() | terminate"
      s5: "getpid() | no locks"
      s6: "atomic ops | lock-free"
      s7: "memcpy() | no allocation"
    }
  }
  forbidden_funcs: {
    direction: down
    label: "FORBIDDEN Functions"
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    style.stroke-width: 2
    width: 280
    forbid_list: {
      shape: sql_table
      label: "CANNOT Call (unsafe)"
      f1: "malloc() | locks heap"
      f2: "free() | locks heap"
      f3: "printf() | internal mutex"
      f4: "pthread_mutex_lock() | deadlock!"
      f5: "fprintf() | file locks"
      f6: "backtrace() | may alloc"
      f7: "dlsym() | not async-safe"
    }
  }
  reason_box: {
    direction: down
    label: "Why Restricted?"
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    style.stroke-width: 2
    width: 280
    reasons: {
      shape: sql_table
      label: "Deadlock Scenarios"
      r1: "malloc() | handler interrupts malloc → lock held → deadlock"
      r2: "mutex | handler interrupts lock holder → wait forever"
      r3: "printf | internal stdio lock → deadlock"
      r4: "alloc | recursive malloc → corruption"
    }
  }
}
row1.level3.handler -> row2.safe_funcs: "can use" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row1.level3.handler -> row2.forbidden_funcs: "AVOID!" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    direction: down
    label: "Execution Timeline"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    t0: {
      label: "T0: Application Running"
      shape: circle
      style.fill: "#4CAF50"
    }
    t1: {
      label: "T1: Timer Fires"
      shape: circle
      style.fill: "#FF9800"
    }
    t2: {
      label: "T2: Kernel Transition"
      shape: circle
      style.fill: "#FFC107"
    }
    t3: {
      label: "T3: Handler Executes"
      shape: circle
      style.fill: "#F44336"
    }
    t4: {
      label: "T4: Resume Application"
      shape: circle
      style.fill: "#4CAF50"
    }
    t0 -> t1: "~10ms interval" {
      style.stroke-dash: 3
    }
    t1 -> t2: "~500ns"
    t2 -> t3: "~200ns"
    t3 -> t4: "~2-5μs handler"
  }
  safety_rules: {
    direction: down
    label: "Signal Safety Rules"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    rule1: {
      label: "Rule 1: Pre-allocate Everything"
      code: |'c
        // At startup (NOT in handler)
        buffer = malloc(SAMPLE_BUF_SIZE);
        // Handler only writes to buffer
      '|
      width: 320
    }
    rule2: {
      label: "Rule 2: Use Lock-Free Structures"
      code: |'c
        // Atomic operations only
        slot = atomic_fetch_add(&pos, 1);
        buffer[slot % SIZE] = sample;
      '|
      width: 320
    }
    rule3: {
      label: "Rule 3: Detect Recursion"
      code: |'c
        thread_local bool in_handler = false;
        if (in_handler) return; // reentrant!
        in_handler = true;
        // ... handler code ...
        in_handler = false;
      '|
      width: 320
    }
    rule1 -> rule2 -> rule3
  }
}
legend: {
  near: bottom-center
  label: "Legend"
  style.fill: white
  style.stroke: gray
  l1: "Green = Safe / Allowed"
  l2: "Red = Dangerous / Forbidden"
  l3: "Orange = Transition / Caution"
  l4: "Blue = Data Flow / Read"
  l1.style.fill: "#C8E6C9"
  l2.style.fill: "#FFCDD2"
  l3.style.fill: "#FFE0B2"
  l4.style.fill: "#BBDEFB"
}