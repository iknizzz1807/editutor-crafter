direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Stack Folding for Flame Graph Input
  Aggregating individual samples into collapsed format
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_section: {
    direction: down
    label: "Raw Samples (990 individual traces)"
    sample1: {
      label: "Sample #1"
      width: 280
      code: |'c
        main()
        └── process_request()
            └── parse_json()
                └── decode_string()
      '|
      style.fill: "#E8F4FD"
    }
    sample2: {
      label: "Sample #2"
      width: 280
      code: |'c
        main()
        └── process_request()
            └── parse_json()
                └── decode_string()
      '|
      style.fill: "#E8F4FD"
    }
    sample3: {
      label: "Sample #3"
      width: 280
      code: |'c
        main()
        └── process_request()
            └── validate()
      '|
      style.fill: "#FFF4E8"
    }
    sample4: {
      label: "Sample #4"
      width: 280
      code: |'c
        main()
        └── process_request()
            └── parse_json()
                └── decode_string()
      '|
      style.fill: "#E8F4FD"
    }
    sample5: {
      label: "Sample #5"
      width: 280
      code: |'c
        main()
        └── handle_signal()
      '|
      style.fill: "#F4E8FD"
    }
    ellipsis: {
      label: "... 985 more samples ..."
      width: 280
      style.fill: "#F0F0F0"
      style.stroke-dash: 3
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fold_section: {
    direction: down
    label: "Folding Process"
    fold_box: {
      width: 400
      label: "Aggregation Algorithm"
      code: |'c
        for each sample:
          path = join(stack_frames, ";")
          counts[path] += 1
      '|
      style.fill: "#E8FDE8"
    }
    operations: {
      direction: right
      label: ""
      op1: {
        label: "1. Normalize"
        width: 180
        code: |'c
          Convert stack to
          semicolon-separated
          path string
        '|
        style.fill: "#FFFDE8"
      }
      op2: {
        label: "2. Hash"
        width: 180
        code: |'c
          Use path as key
          in hash table
        '|
        style.fill: "#FFFDE8"
      }
      op3: {
        label: "3. Count"
        width: 180
        code: |'c
          Increment count
          for each path
        '|
        style.fill: "#FFFDE8"
      }
    }
    result_counts: {
      label: "Path Hash Table"
      shape: sql_table
      width: 500
      p1: "main;process_request;parse_json;decode_string | 3"
      p2: "main;process_request;validate | 1"
      p3: "main;handle_signal | 1"
      note: "... (unique paths only)"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_section: {
    direction: down
    label: "Collapsed Stack Format Output"
    output_file: {
      width: 520
      label: "profile.collapsed"
      code: |'
        # Profile metadata
        # samples: 5
        # unique_paths: 3
        main;process_request;parse_json;decode_string 3
        main;process_request;validate 1
        main;handle_signal 1
      '|
      style.fill: "#F5F5F5"
      style.font: mono
    }
    format_desc: {
      label: "Format: path count"
      width: 520
      desc: |md
        - **Path**: Stack frames root→leaf, semicolon-separated  
        - **Count**: Number of times this exact path appeared  
        - **One line per unique path** (not per sample)
      |
      style.fill: transparent
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  flame_section: {
    direction: down
    label: "Resulting Flame Graph Structure"
    flame_tree: {
      shape: class
      label: "FlameGraphNode Tree"
      name: "String"
      value: "usize (sample count)"
      children: "Vec<FlameGraphNode>"
    }
    tree_visual: {
      width: 600
      label: "Visual Representation"
      code: |'
        ┌─────────────────────────────────────────────┐
        │                    main (5)                 │
        ├─────────────────────────────────┬───────────┤
        │        process_request (4)      │handle_sig │
        ├─────────────────┬───────────────┤   (1)     │
        │   parse_json(3) │  validate(1)  │           │
        ├─────────────────┤               │           │
        │ decode_string(3)│               │           │
        └─────────────────┴───────────────┴───────────┘
              Width ∝ sample count
      '|
      style.fill: "#FFF8E8"
    }
  }
}
input_section -> fold_section: "samples | aggregate" {
  style.stroke: "#2563EB"
  style.stroke-width: 2
}
fold_section -> output_section: "collapsed | export" {
  style.stroke: "#16A34A"
  style.stroke-width: 2
}
output_section -> flame_section: "render | visualize" {
  style.stroke: "#9333EA"
  style.stroke-width: 2
}
legend: {
  near: bottom-right
  direction: right
  label: ""
  style.stroke: transparent
  style.fill: transparent
  l1: {
    label: "Same path = same line"
    width: 160
    style.fill: "#E8F4FD"
  }
  l2: {
    label: "Different path = new line"
    width: 160
    style.fill: "#FFF4E8"
  }
}
benefits: {
  near: bottom-center
  label: "Benefits of Folding"
  width: 800
  desc: |md
    • **Compression**: 990 samples → ~50 unique paths (20× smaller)  
    • **Human-readable**: Can grep, sort, analyze with standard tools  
    • **Tool-agnostic**: Works with flamegraph.pl, speedscope, custom tools  
    • **Lossless**: All sample counts preserved, no information discarded
  |
  style.fill: "#F0FDF4"
}