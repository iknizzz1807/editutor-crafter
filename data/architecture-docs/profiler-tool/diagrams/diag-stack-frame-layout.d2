direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Stack Frame Layout & Frame Pointer Chaining
  Frame pointer chain enables stack unwinding by creating a linked list through the stack
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stack_view: {
    direction: down
    label: "Stack Memory (grows downward)"
    frame3: {
      label: "Frame 3: main() @ 0x401000"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      f3_ret: "0x7fff0008 | return addr → __libc_start_main"
      f3_rbp: "0x7fff0000 | saved RBP → 0x7fff1000 (frame 2)"
      f3_local1: "0x7fff0010 | argc (int)"
      f3_local2: "0x7fff0018 | argv (char**)"
    }
    frame2: {
      label: "Frame 2: process_request() @ 0x401a00"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      f2_ret: "0x7fff1010 | return addr → 0x401050 (main+0x50)"
      f2_rbp: "0x7fff1000 | saved RBP → 0x7fff2000 (frame 1)"
      f2_local1: "0x7fff1008 | conn (TcpStream*)"
      f2_local2: "0x7fff1018 | buffer (Vec<u8>)"
      f2_local3: "0x7fff1028 | len (usize)"
    }
    frame1: {
      label: "Frame 1: parse_json() @ 0x402500  ← CURRENT"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#E65100"
      style.stroke-width: 3
      f1_ret: "0x7fff2010 | return addr → 0x401a80 (process_request+0x80)"
      f1_rbp: "0x7fff2000 | saved RBP → 0x7fff3000 (frame 0)"
      f1_local1: "0x7fff2008 | input (&str)"
      f1_local2: "0x7fff2018 | parser (JsonParser)"
      f1_cur: "0x7fff2080 | RSP (stack pointer)"
    }
    frame0: {
      label: "Frame 0: decode_string() @ 0x403000"
      shape: rectangle
      style.fill: "#FCE4EC"
      style.stroke: "#C2185B"
      f0_ret: "0x7fff3010 | return addr → 0x402580 (parse_json+0x80)"
      f0_rbp: "0x7fff3000 | saved RBP → NULL (end of chain)"
      f0_local1: "0x7fff3008 | s (&str)"
      f0_rip: "0x7fff3018 | RSP → RIP: 0x4030a3 (decode_string+0xa3)"
    }
    low_mem: {
      label: "Lower addresses (stack grows this way)"
      shape: text
      style.font-color: "#666666"
      style.italic: true
    }
  }
  legend: {
    direction: down
    label: "Frame Structure"
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
    struct_info: {
      shape: sql_table
      label: "struct StackFrame (x86_64)"
      f_ret: "0x00 | void* | return_addr // caller's RIP"
      f_rbp: "0x08 | void* | saved_rbp   // chain link"
      f_loc: "0x10 | varies | locals[...]  // frame data"
      total: "Size varies per function"
    }
    regs: {
      label: "Key Registers"
      shape: class
      rbp_reg: "RBP | Frame Base | Points to saved_rbp"
      rsp_reg: "RSP | Stack Ptr | Points to top of stack"
      rip_reg: "RIP | Instr Ptr | Current execution addr"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  chain_view: {
    direction: down
    label: "Frame Pointer Chain (Linked List in Memory)"
    chain_visual: {
      direction: right
      style.fill: transparent
      node0: {
        label: "RBP\n0x7fff2000"
        shape: circle
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
        style.stroke-width: 3
      }
      arrow0: {
        label: "*RBP"
        shape: text
      }
      node1: {
        label: "0x7fff3000\n(parse_json)"
        shape: circle
        style.fill: "#FCE4EC"
        style.stroke: "#C2185B"
      }
      arrow1: {
        label: "*0x7fff3000"
        shape: text
      }
      node2: {
        label: "NULL\n(end)"
        shape: circle
        style.fill: "#F5F5F5"
        style.stroke: "#9E9E9E"
      }
    }
    chain_code: {
      label: "Unwinding Algorithm"
      width: 400
      code: |'c
        // Walk the frame pointer chain
        void** rbp = current_rbp;
        while (rbp != NULL && rbp > (void*)0x1000) {
            void* return_addr = *(rbp + 1);  // ret at rbp+8
            process_frame(return_addr);
            rbp = *rbp;  // follow chain: RBP → saved RBP
        }
      '|
    }
  }
  prologue: {
    direction: down
    label: "Function Prologue (establishes frame)"
    prologue_code: {
      width: 380
      code: |'asm
        ; Standard prologue - creates stack frame
        push   rbp              ; save caller's RBP
        mov    rbp, rsp         ; establish our frame base
        sub    rsp, 64          ; allocate locals
        ; Now: RBP points to saved_rbp
        ;      RBP+8 = return address
        ;      RBP+16 = first local
      '|
    }
    epilogue_code: {
      label: "Function Epilogue (tears down frame)"
      width: 380
      code: |'asm
        ; Standard epilogue - destroys stack frame
        mov    rsp, rbp         ; deallocate locals
        pop    rbp              ; restore caller's RBP
        ret                     ; pop return addr → RIP
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  omit_frame: {
    direction: down
    label: "WITH -fomit-frame-pointer"
    broken: {
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#D32F2F"
      style.stroke-dash: 4
      bad_code: {
        width: 380
        code: |'asm
          ; Optimized prologue - NO frame pointer!
          sub    rsp, 64          ; just allocate locals
          ; RBP is now a general-purpose register!
          ; Used for: loop counter, cached value, etc.
          ; PROBLEM: No saved_rbp chain to follow!
          ; Unwinding stops here. Stack trace truncated.
        '|
      }
      result: {
        label: "Result: Stack trace depth = 1-3 frames"
        shape: text
        style.font-color: "#C62828"
        style.bold: true
      }
    }
    broken_chain: {
      direction: right
      label: "Broken Chain"
      bnode0: {
        label: "RBP\n(garbage)"
        shape: circle
        style.fill: "#FFCDD2"
        style.stroke: "#D32F2F"
      }
      bnode1: {
        label: "???"
        shape: circle
        style.fill: "#FFCDD2"
        style.stroke: "#D32F2F"
        style.stroke-dash: 4
      }
      bx: {
        label: "✗"
        shape: text
        style.font-color: "#D32F2F"
        style.font-size: 32
        style.bold: true
      }
    }
  }
  keep_frame: {
    direction: down
    label: "WITH -fno-omit-frame-pointer"
    working: {
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      good_code: {
        width: 380
        code: |'asm
          ; Debug-friendly prologue
          push   rbp              ; maintain chain
          mov    rbp, rsp
          sub    rsp, 64
          ; RBP always points to valid saved_rbp
          ; Unwinding works perfectly!
        '|
      }
      result: {
        label: "Result: Stack trace depth = 20-100+ frames"
        shape: text
        style.font-color: "#2E7D32"
        style.bold: true
      }
    }
    working_chain: {
      direction: right
      label: "Intact Chain"
      gnode0: {
        label: "RBP"
        shape: circle
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
      gnode1: {
        label: "saved"
        shape: circle
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
      gnode2: {
        label: "saved"
        shape: circle
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
      gdots: {
        label: "..."
        shape: text
      }
      gnode3: {
        label: "NULL"
        shape: circle
        style.fill: "#E8F5E9"
        style.stroke: "#2E7D32"
      }
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tradeoffs: {
    direction: down
    label: "Trade-offs"
    comparison: {
      shape: sql_table
      label: "Frame Pointer Decision Matrix"
      opt1: "-fomit-frame-pointer | +2-5% perf | +1 free register | No stack traces"
      opt2: "-fno-omit-frame-pointer | -2-5% perf | RBP reserved | Full stack traces"
      opt3: "-fno-omit-leaf-frame-pointer | -1-2% perf | Leaf frames ok | Partial traces"
      note: "Recommendation: Use -fno-omit-frame-pointer for profiling builds"
    }
  }
  dwi: {
    direction: down
    label: "Alternative: DWARF Unwinding"
    dwarf_info: {
      width: 400
      code: |'c
        // When frame pointers unavailable, use DWARF CFI
        // .eh_frame section describes how to unwind at each IP
        // Example CFI entry:
        // 0x401000-0x401050: CFA = RSP + 16, RBP = CFA - 8
        // 0x401050-0x4010a0: CFA = RSP + 32, RBP = [CFA - 16]
        // Pros: Works without frame pointers
        // Cons: 5-20x slower, complex parsing, may not be signal-safe
      '|
    }
    perf_note: {
      label: "Frame pointer: ~200ns unwind\nDWARF: ~1-5μs unwind"
      shape: text
      style.font-color: "#666666"
      style.italic: true
    }
  }
}
stack_view.frame3 -> stack_view.frame2: "RBP chain"
stack_view.frame2 -> stack_view.frame1: "RBP chain"
stack_view.frame1 -> stack_view.frame0: "RBP chain"
chain_visual.node0 -> chain_visual.node1: "dereference"
chain_visual.node1 -> chain_visual.node2: "dereference"