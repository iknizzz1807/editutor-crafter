direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Temporal Allocation Analysis
  Memory usage over time showing allocation rate, free rate, and live bytes
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  graph_panel: {
    direction: down
    label: "Memory Timeline (T=0 to T=60 seconds)"
    y_axis: {
      direction: down
      label: "Bytes / Operations"
      shape: rectangle
      width: 40
      height: 300
      style.fill: transparent
      style.stroke: "#666"
    }
    graph_area: {
      direction: right
      width: 600
      time_grid: {
        grid-columns: 6
        grid-gap: 0
        style.fill: transparent
        t0: {
          label: "0s"
          shape: rectangle
          width: 100
          height: 300
          style.fill: transparent
          style.stroke: "#e0e0e0"
          style.stroke-dash: 2
        }
        t10: {
          label: "10s"
          shape: rectangle
          width: 100
          height: 300
          style.fill: transparent
          style.stroke: "#e0e0e0"
          style.stroke-dash: 2
        }
        t20: {
          label: "20s"
          shape: rectangle
          width: 100
          height: 300
          style.fill: transparent
          style.stroke: "#e0e0e0"
          style.stroke-dash: 2
        }
        t30: {
          label: "30s"
          shape: rectangle
          width: 100
          height: 300
          style.fill: transparent
          style.stroke: "#e0e0e0"
          style.stroke-dash: 2
        }
        t40: {
          label: "40s"
          shape: rectangle
          width: 100
          height: 300
          style.fill: transparent
          style.stroke: "#e0e0e0"
          style.stroke-dash: 2
        }
        t50: {
          label: "50s"
          shape: rectangle
          width: 100
          height: 300
          style.fill: transparent
          style.stroke: "#e0e0e0"
          style.stroke-dash: 2
        }
      }
    }
    x_axis: {
      label: "Time (seconds)"
      shape: rectangle
      width: 640
      height: 30
      style.fill: transparent
      style.stroke: "#666"
