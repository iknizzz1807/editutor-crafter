  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend: {
    direction: right
    label: "Legend"
    width: 700
    alloc_line: {
      label: "─── Allocations/sec"
      shape: rectangle
      width: 150
      style.fill: "#e8f5e9"
      style.stroke: "#4caf50"
      style.stroke-width: 3
    }
    free_line: {
      label: "─── Frees/sec"
      shape: rectangle
      width: 150
      style.fill: "#e3f2fd"
      style.stroke: "#2196f3"
      style.stroke-width: 3
    }
    live_bytes: {
      label: "─── Live Bytes"
      shape: rectangle
      width: 150
      style.fill: "#fff3e0"
      style.stroke: "#ff9800"
      style.stroke-width: 3
    }
    high_water: {
      label: "◆ High-Water Mark"
      shape: rectangle
      width: 150
      style.fill: "#ffebee"
      style.stroke: "#f44336"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase_analysis: {
    direction: right
    label: "Phase Analysis"
    width: 700
    phase1: {
      label: "Phase 1\n0-20s\nInit Spike"
      shape: rectangle
      width: 200
      style.fill: "#e8f5e9"
      style.stroke: "#4caf50"
      desc: |md
        - Rapid allocation during init
        - Frees lag behind
        - Live bytes spike then stabilize
      |
    }
    phase2: {
      label: "Phase 2\n20-40s\nSteady State"
      shape: rectangle
      width: 200
      style.fill: "#e3f2fd"
      style.stroke: "#2196f3"
      desc: |md
        - Alloc ≈ Free rate
        - Memory stable
        - Healthy pattern
      |
    }
    phase3: {
      label: "Phase 3\n40-60s\nLeak Detected"
      shape: rectangle
      width: 200
      style.fill: "#ffebee"
      style.stroke: "#f44336"
      desc: |md
        - Alloc > Free consistently
        - Diverging lines = leak
        - Live bytes grow linearly
      |
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  metrics_panel: {
    direction: right
    label: "Temporal Metrics"
    width: 700
    current_state: {
      shape: sql_table
      label: "Current State (T=60s)"
      f1: "live_bytes | u64 | 157,286,400"
      f2: "alloc_rate | u64 | 12,800/s"
      f3: "free_rate | u64 | 8,200/s"
      f4: "net_growth | i64 | +4,600/s"
      sz: "Leak rate: 4.6 KB/s"
    }
    high_water_mark: {
      shape: sql_table
      label: "High-Water Mark"
      f1: "peak_bytes | u64 | 157,286,400"
      f2: "peak_time | u64 | T=60s"
      f3: "peak_allocs | u64 | 2,847,291"
      sz: "Container limit: 256 MB"
    }
    sampling_config: {
      shape: sql_table
      label: "Sampling Config"
      f1: "interval_ms | u64 | 100"
      f2: "max_samples | usize | 36,000"
      f3: "retention | Duration | 1 hour"
      sz: "Memory: ~2.8 MB buffer"
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  code_panel: {
    direction: down
    label: "Temporal Tracker Implementation (memory_temporal.rs)"
    width: 720
    struct_def: {
      label: "TemporalTracker Structure"
      width: 700
      code: |'rust
        pub struct TemporalTracker {
            samples: VecDeque<TemporalSample>,
            sample_interval_ms: u64,
            last_sample: Instant,
            max_samples: usize,
        }
        pub struct TemporalSample {
            pub time_ms: u64,
            pub live_bytes: u64,
            pub alloc_count: u64,
            pub free_count: u64,
            pub interval_allocs: u64,
            pub interval_frees: u64,
            pub interval_bytes_allocated: u64,
            pub interval_bytes_freed: u64,
        }
      '|
    }
    leak_detection: {
      label: "Leak Pattern Detection (Linear Regression)"
      width: 700
      code: |'rust
        fn detect_leak_pattern(&self) -> Option<LeakPattern> {
            if self.samples.len() < 10 { return None; }
            // Linear regression on live_bytes over time
            let n = self.samples.len() as f64;
            let sum_x: f64 = self.samples.iter().map(|s| s.time_ms as f64).sum();
            let sum_y: f64 = self.samples.iter().map(|s| s.live_bytes as f64).sum();
            let sum_xy: f64 = self.samples.iter()
                .map(|s| (s.time_ms as f64) * (s.live_bytes as f64))
                .sum();
            let sum_xx: f64 = self.samples.iter()
                .map(|s| (s.time_ms as f64).powi(2))
                .sum();
            let slope = (n * sum_xy - sum_x * sum_y) / (n * sum_xx - sum_x * sum_x);
            let bytes_per_second = slope * 1000.0;
            // Leak if growing > 1 KB/s
            if bytes_per_second > 1024.0 {
                Some(LeakPattern { bytes_per_second, confidence: 0.8 })
            } else { None }
        }
      '|
    }
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  visualization_panel: {
    direction: down
    label: "Export Formats"
    width: 720
    csv_export: {
      label: "CSV Export (for Grafana/Excel)"
      width: 700
      code: |'rust
        pub fn export_csv(&self) -> String {
            let mut csv = String::from(
                "time_ms,live_bytes,alloc_count,free_count,interval_allocs,interval_frees\n"
            );
            for sample in &self.samples {
                csv.push_str(&format!(
                    "{},{},{},{},{},{}\n",
                    sample.time_ms, sample.live_bytes,
                    sample.alloc_count, sample.free_count,
                    sample.interval_allocs, sample.interval_frees
                ));
            }
            csv
        }
      '|
    }
    prometheus_export: {
      label: "Prometheus Exposition Format"
      width: 700
      code: |'
        # HELP memory_live_bytes Current live allocation bytes
        # TYPE memory_live_bytes gauge
        memory_live_bytes 157286400
        # HELP memory_alloc_rate Allocs per second
        # TYPE memory_alloc_rate gauge
        memory_alloc_rate 12800
        # HELP memory_free_rate Frees per second  
        # TYPE memory_free_rate gauge
        memory_free_rate 8200
        # HELP memory_high_water_bytes Peak live bytes
        # TYPE memory_high_water_bytes gauge
        memory_high_water_bytes 157286400
      '|
    }
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  alert_panel: {
    direction: right
    label: "Alert Conditions"
    width: 700
    alert1: {
      label: "⚠️ Leak Warning"
      shape: diamond
      style.fill: "#fff3e0"
      style.stroke: "#ff9800"
      condition: |md
        **Trigger:** net_growth > 1 KB/s for > 30s
        **Indicates:** Memory not being freed
        at expected rate
      |
    }
    alert2: {
      label: "🚨 OOM Risk"
      shape: diamond
      style.fill: "#ffebee"
      style.stroke: "#f44336"
      condition: |md
        **Trigger:** live_bytes > 80% of limit
        **Indicates:** Approaching container
        memory limit, OOM kill imminent
      |
    }
    alert3: {
      label: "✓ Healthy"
      shape: diamond
      style.fill: "#e8f5e9"
      style.stroke: "#4caf50"
      condition: |md
        **Trigger:** alloc_rate ≈ free_rate
        within 5% variance
        **Indicates:** Stable memory usage
      |
    }
  }
}
phase_analysis.phase1 -> phase_analysis.phase2: "stabilize"
phase_analysis.phase2 -> phase_analysis.phase3: "leak starts" {
  style.stroke: "#f44336"
  style.stroke-dash: 4
  style.animated: true
}
alert_panel.alert1 -> alert_panel.alert2: "escalates" {
  style.stroke: "#ff9800"
  style.stroke-dash: 3
}