direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Stack Unwinding: Three Methods Compared
  Trade-offs: Speed vs Accuracy vs Hardware Requirements
| {near: top-center}
methods: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  method1: {
    direction: down
    label: "Method 1: Frame Pointer Walking"
    header1: {
      style.fill: "#4CAF50"
      style.stroke: "#388E3C"
      style.font-color: white
      label: "✓ FASTEST"
    }
    before1: {
      label: "Stack Layout (with -fno-omit-frame-pointer)"
      shape: rectangle
      width: 280
      stack_before: {
        shape: sql_table
        label: "Stack Memory"
        f0: "0x7fff... | saved rbp  | 0x7fff1000"
        f1: "0x7fff... | return addr| parse_json"
        f2: "0x7fff... | saved rbp  | 0x7fff0ff0"
        f3: "0x7fff... | return addr| decode_str"
        f4: "0x7fff... | saved rbp  | 0x7fff0fe0"
        f5: "0x7fff... | local var  | data ptr"
        note: "Linked list via saved rbp"
      }
    }
    algo1: {
      label: "Unwind Algorithm"
      width: 280
      code: |'c
        void* rbp = current_rbp;
        while (rbp != NULL) {
          void* ret = *(rbp + 8);
          record(ret);
          rbp = *rbp;  // follow chain
        }
      '|
    }
    after1: {
      label: "Result: Full Trace"
      shape: rectangle
      width: 280
      result1: {
        shape: sql_table
        label: "Captured Stack"
        r0: "0 | decode_string"
        r1: "1 | parse_json"
        r2: "2 | process_request"
        r3: "3 | main"
        total: "Depth: 4 frames"
      }
    }
    pros1: {
      label: "PROS"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 280
      pros_list: |md
        • **~200-500ns** per frame
        • Simple implementation
        • No debug info needed
        • Async-signal-safe
        • Works in production
      |
    }
    cons1: {
      label: "CONS"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 280
      cons_list: |md
        • Requires `-fno-omit-frame-pointer`
        • Loses 1 register (rbp)
        • ~2-5% performance hit
        • Breaks with optimizations
        • Leaf functions may omit FP
      |
    }
  }
  method2: {
    direction: down
    label: "Method 2: DWARF Unwind Tables"
    header2: {
      style.fill: "#2196F3"
      style.stroke: "#1976D2"
      style.font-color: white
      label: "✓ MOST ACCURATE"
    }
    before2: {
      label: ".eh_frame Section (DWARF CFI)"
      shape: rectangle
      width: 280
      eh_frame: {
        shape: sql_table
        label: "CFI Table Entries"
        e0: "0x401000 | CFA=rsp+8  | rbp=[CFA-16]"
        e1: "0x401010 | CFA=rsp+16 | rbp=[CFA-8]"
        e2: "0x401020 | CFA=rbp+16 | rip=[CFA-8]"
        e3: "0x401030 | CFA=rsp+24 | rbx=[CFA-24]"
        note: "Per-instruction unwind rules"
      }
    }
    algo2: {
      label: "Unwind Algorithm"
      width: 280
      code: |'c
        // For each frame:
        1. Find CFI entry for current RIP
        2. Parse DWARF expressions
        3. Compute CFA (Canonical Frame Addr)
        4. Restore registers from CFA offsets
        5. Repeat until stack end
      '|
    }
    after2: {
      label: "Result: Full Trace + Inlines"
      shape: rectangle
      width: 280
      result2: {
        shape: sql_table
        label: "Captured Stack"
        r0: "0 | decode_string @ line:45"
        r1: "1 | [inlined] validate_utf8"
        r2: "2 | parse_json @ line:120"
        r3: "3 | process_request @ line:89"
        total: "Depth: 4 + 1 inlined"
      }
    }
    pros2: {
      label: "PROS"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 280
      pros_list: |md
        • Works with any optimization
        • Handles inline functions
        • No frame pointer needed
        • Shows source lines
        • Standard ELF section
      |
    }
    cons2: {
      label: "CONS"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 280
      cons_list: |md
        • **~5-20μs** per frame (10-50× slower)
        • Complex parsing
        • Large binary size (+10-30%)
        • May not be async-signal-safe
        • Memory allocation risk
      |
    }
  }
  method3: {
    direction: down
    label: "Method 3: Intel LBR Hardware"
    header3: {
      style.fill: "#9C27B0"
      style.stroke: "#7B1FA2"
      style.font-color: white
      label: "✓ ZERO OVERHEAD"
    }
    before3: {
      label: "Hardware: Last Branch Record"
      shape: rectangle
      width: 280
      lbr_hw: {
        shape: sql_table
        label: "LBR Registers (MSR)"
        l0: "LBR_0  | from: 0x401234 | to: 0x401a3c"
        l1: "LBR_1  | from: 0x401100 | to: 0x401234"
        l2: "LBR_2  | from: 0x400f00 | to: 0x401100"
        l3: "LBR_3  | from: 0x400e00 | to: 0x400f00"
        note: "32 pairs on Skylake, 16 on older"
      }
    }
    algo3: {
      label: "Capture Algorithm"
      width: 280
      code: |'c
        // No unwinding needed!
        // Hardware records every branch
        void on_sample() {
          for (int i = 0; i < 32; i++) {
            record(lbr_from[i], lbr_to[i]);
          }
        }
      '|
    }
    after3: {
      label: "Result: Branch Trace (partial)"
      shape: rectangle
      width: 280
      result3: {
        shape: sql_table
        label: "Captured Branches"
        r0: "0 | decode_string → ret"
        r1: "1 | parse_json → call decode"
        r2: "2 | process_request → call parse"
        r3: "3 | [truncated - depth limit]"
        total: "Depth: 3 (hardware limited)"
      }
    }
    pros3: {
      label: "PROS"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 280
      pros_list: |md
        • **~0ns** unwind time
        • No code modification
        • Works on stripped binaries
        • Kernel-mode support
        • Perfect for hot-path profiling
      |
    }
    cons3: {
      label: "CONS"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 280
      cons_list: |md
        • **Intel only** (no AMD equivalent)
        • Depth limited to 16-32
        • Requires privileged access
        • Only captures branches, not full stack
        • Lost on context switch
      |
    }
  }
}
comparison: {
  direction: down
  label: "Performance Comparison"
  metrics: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    speed: {
      label: "Unwind Speed"
      shape: rectangle
      width: 300
      speed_data: {
        shape: sql_table
        label: "Time per 20-frame stack"
        s0: "Frame Pointer  | ~4-10μs   | ████"
        s1: "DWARF CFI      | ~100-400μs| ████████████████████"
        s2: "Intel LBR      | ~0μs      |"
        note: "Lower is better"
      }
    }
    accuracy: {
      label: "Accuracy / Coverage"
      shape: rectangle
      width: 300
      accuracy_data: {
        shape: sql_table
        label: "Stack recovery rate"
        a0: "Frame Pointer  | 60-90%    | ████████"
        a1: "DWARF CFI      | 95-99%    | ████████████████████"
        a2: "Intel LBR      | 40-70%    | ████████"
        note: "Higher is better"
      }
    }
    requirements: {
      label: "Requirements"
      shape: rectangle
      width: 300
      req_data: {
        shape: sql_table
        label: "What you need"
        r0: "Frame Pointer  | Compile flag"
        r1: "DWARF CFI      | .eh_frame section"
        r2: "Intel LBR      | Intel CPU + perf_event"
        note: "Complexity varies"
      }
    }
  }
}
recommendation: {
  label: "Recommendation"
  width: 900
  rec_content: |md
    **Production Profiling:** Use Frame Pointer (Method 1) with `-fno-omit-frame-pointer`. Best balance of speed and reliability.
    **Deep Debugging:** Use DWARF (Method 2) when you need inlined functions, source lines, or cannot recompile.
    **Ultra-Low Overhead:** Use LBR (Method 3) for hot-path profiling on Intel systems where 16-32 frame depth is sufficient.
    **Hybrid Approach:** Start with frame pointer for speed, fall back to DWARF for truncated stacks.
  |
}
legend: {
  near: bottom-center
  label: "Color Legend"
  direction: right
  style.fill: transparent
  style.stroke: transparent
  green_box: {
    label: "Fast / Recommended"
    shape: rectangle
    style.fill: "#C8E6C9"
    width: 120
  }
  red_box: {
    label: "Slow / Limitations"
    shape: rectangle
    style.fill: "#FFCDD2"
    width: 120
  }
  blue_box: {
    label: "Accurate"
    shape: rectangle
    style.fill: "#BBDEFB"
    width: 120
  }
  purple_box: {
    label: "Hardware"
    shape: rectangle
    style.fill: "#E1BEE7"
    width: 120
  }
}