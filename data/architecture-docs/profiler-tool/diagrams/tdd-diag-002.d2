layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
  }
}

title: {
  shape: text
  label: ||md
  # RawSample Memory Layout
  Total: 1048 bytes | 8-byte aligned | ~16.4 cache lines
  ||
  near: top-center
}

# Left Margin: Offsets
offsets: {
  addr_00: "0x00" { shape: text }
  addr_08: "0x08" { shape: text }
  addr_10: "0x10" { shape: text }
  addr_11: "0x11" { shape: text; style.opacity: 0.6 }
  addr_18: "0x18" { shape: text }
  addr_40: "0x40" { shape: text; style.font-color: red }
  addr_418: "0x418" { shape: text }
}

# Right Margin: Sizes
sizes: {
  s_8b_1: "8B" { shape: text }
  s_8b_2: "8B" { shape: text }
  s_1b: "1B" { shape: text }
  s_7b: "7B" { shape: text }
  s_8b_3: "8B" { shape: text }
  s_1016b: "1016B" { shape: text }
  s_8b_4: "8B" { shape: text }
}

# Fields
thread_id: {
  label: "thread_id\nu64"
  width: 300; height: 40
  style.fill: "#9B59B6"; style.stroke: "#8E44AD"; style.font-color: white
}
timestamp_ns: {
  label: "timestamp_ns\nu64"
  width: 300; height: 40
  style.fill: "#9B59B6"; style.stroke: "#8E44AD"; style.font-color: white
}
depth: {
  label: "depth\nu8"
  width: 50; height: 40
  style.fill: "#9B59B6"; style.stroke: "#8E44AD"; style.font-color: white
}
padding: {
  label: "_padding\n[u8; 7]"
  width: 250; height: 40
  style.fill: "#95A5A6"; style.stroke: "#7F8C8D"; style.stroke-dash: 5
}
addresses_0: {
  label: "addresses[0]\nusize"
  width: 300; height: 40
  style.fill: "#3498DB"; style.stroke: "#2980B9"; style.font-color: white
}
addresses_bulk: {
  label: "addresses[1..126]\n[usize; 127]\n\n... 127 × 8B = 1016B ..."
  width: 300; height: 120
  style.fill: "#3498DB"; style.stroke: "#2980B9"; style.stroke-dash: 3; style.font-color: white
}
addresses_end: {
  label: "addresses[127]\nusize"
  width: 300; height: 40
  style.fill: "#3498DB"; style.stroke: "#2980B9"; style.font-color: white
}

# Layout constraints (Rows)
offsets.addr_00 -> thread_id -> sizes.s_8b_1: {style.stroke: transparent}
offsets.addr_08 -> timestamp_ns -> sizes.s_8b_2: {style.stroke: transparent}
offsets.addr_10 -> depth
depth -> padding -> sizes.s_7b: {style.stroke: transparent}
offsets.addr_18 -> addresses_0 -> sizes.s_8b_3: {style.stroke: transparent}

# Cache Line marker
cache_boundary: "--- Cache Line Boundary (64B) ---" {
  shape: text
  style.font-color: "#E74C3C"
  style.bold: true
}

offsets.addr_40 -> cache_boundary -> addresses_bulk -> sizes.s_1016b: {style.stroke: transparent}
offsets.addr_418 -> addresses_end -> sizes.s_8b_4: {style.stroke: transparent}

# Vertical sequence
thread_id -> timestamp_ns -> depth -> addresses_0 -> cache_boundary -> addresses_bulk -> addresses_end: {
  style.stroke: transparent
}

# Metadata block
metadata: {
  shape: rectangle
  label: ||md
  ### RawSample Struct
  `#[repr(C, align(8))]`

  | Field | Offset | Size |
  | :--- | :--- | :--- |
  | thread_id | 0x00 | 8 |
  | timestamp_ns | 0x08 | 8 |
  | depth | 0x10 | 1 |
  | _padding | 0x11 | 7 |
  | addresses | 0x18 | 1024 |
  
  **Total Size: 1048 Bytes**
  ||
  style.fill: "#ECF0F1"
  style.stroke: "#BDC3C7"
}

# Legend
legend: {
  shape: rectangle
  label: ||md
  **Legend**
  - Purple: Header/Metadata
  - Blue: Data Array
  - Gray: Padding
  - Red: Cache Line (64B)
  ||
  style.fill: "#FAFAFA"
  near: bottom-right
}

metadata -> legend: {style.stroke: transparent}