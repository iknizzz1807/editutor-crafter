direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: "Signal Handler State Machine (M1)" {
  shape: text
  near: top-center
  style.font-size: 18
  style.bold: true
}

# Initial state marker
start: ● {
  shape: circle
  width: 20
  height: 20
  style: {
    fill: "#7D6DF2"
    stroke-width: 0
  }
}

# State definitions
INACTIVE: {
  label: "INACTIVE\ng_running = false\nprofiler not initialized"
  style: {
    fill: "#E8E4F0"
    stroke: "#7D6DF2"
    bold: true
  }
}

ACTIVE: {
  label: "ACTIVE\ng_running = true\nhandler registered\nready for signals"
  style: {
    fill: "#D4F4DD"
    stroke: "#22C55E"
    bold: true
  }
}

SAMPLING: {
  label: "SAMPLING\nin_sigprof = true\nunwinding stack\nwriting to buffer"
  style: {
    fill: "#FEF3C7"
    stroke: "#F59E0B"
    bold: true
  }
}

RECURSION_DETECTED: {
  label: "RECURSION_DETECTED\nin_sigprof == true\non entry → abort\nsignal skipped"
  style: {
    fill: "#FEE2E2"
    stroke: "#EF4444"
    bold: true
    double-border: true
  }
}

COMPLETED: {
  label: "COMPLETED\nbuffer write done\nin_sigprof = false\nready for next signal"
  style: {
    fill: "#DBEAFE"
    stroke: "#3B82F6"
    bold: true
  }
}

# Transitions
start -> INACTIVE

INACTIVE -> ACTIVE: "start()" {
  style: {
    stroke: "#7D6DF2"
    animated: true
  }
}

ACTIVE -> SAMPLING: "sigprof_handler entry\n[guard: !in_sigprof]" {
  style: {
    stroke: "#22C55E"
  }
}

ACTIVE -> RECURSION_DETECTED: "sigprof_handler entry\n[guard: in_sigprof == true]" {
  style: {
    stroke: "#EF4444"
    stroke-dash: 3
  }
}

RECURSION_DETECTED -> ACTIVE: "return immediately\nILLEGAL" {
  style: {
    stroke: "#EF4444"
    stroke-dash: 3
  }
}

SAMPLING -> COMPLETED: "buffer_write success\nstack unwind complete" {
  style: {
    stroke: "#F59E0B"
  }
}

COMPLETED -> ACTIVE: "in_sigprof = false\nawait next SIGPROF" {
  style: {
    stroke: "#3B82F6"
  }
}

ACTIVE -> INACTIVE: "stop()\nSIG_IGN" {
  style: {
    stroke: "#7D6DF2"
    stroke-dash: 5
  }
}

# Legend
legend: {
  label: Legend
  near: bottom-left
  style: {
    stroke-dash: 3
    fill: "#FAFAFA"
  }
  
  grid-columns: 2
  grid-gap: 10
  
  normal: "Normal transition" { shape: text }
  normal_line: "" {
    height: 2
    width: 40
    style.fill: "#22C55E"
    style.stroke-width: 0
  }
  
  error: "Error / Rejection" { shape: text }
  error_line: "" {
    height: 2
    width: 40
    style: {
      fill: "#EF4444"
      stroke-width: 0
      stroke-dash: 2
    }
  }
  
  control: "Control flow" { shape: text }
  control_line: "" {
    height: 2
    width: 40
    style: {
      fill: "#7D6DF2"
      stroke-width: 0
      stroke-dash: 3
    }
  }
}

# Invariant note
invariant: {
  label: |md
    **State Invariant:**
    
    in_sigprof == true
    ⟺
    state ∈ {SAMPLING, RECURSION_DETECTED}
    
  |
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: "#F5F5F5"
    multiple: true
  }
  near: bottom-right
}