direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "ucontext Register Extraction\nPlatform-Specific Code Paths"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

step1: {
  label: "Step 1: Signal Handler Entry"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  entry_point: "Signal Handler\nReceives ucontext_t*" {
    shape: hexagon
    style.fill: "#BBDEFB"
  }
  safety_check: "Verify Async-Signal-Safe\nContext" {
    shape: diamond
    style.fill: "#FFF9C4"
  }
}

step2: {
  label: "Step 2: Architecture Detection"
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.stroke-width: 2
  arch_check: "cfg!(target_arch)" {
    shape: diamond
    style.fill: "#C8E6C9"
  }
  x86_path: "\"x86_64\"" {
    shape: text
    style.font-size: 14
    style.bold: true
  }
  arm_path: "\"aarch64\"" {
    shape: text
    style.font-size: 14
    style.bold: true
  }
}

step3_x86: {
  label: "Step 3a: x86_64 Extraction"
  style.fill: "#FFEBEE"
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  x86_note: |md
    **Changed: Architecture Branch**
    - RED indicates active x86_64 path
  |
  ucontext_x86: {
    label: "ucontext_t\nuc_mcontext.gregs[]"
    shape: class
    style.fill: "#FFCDD2"
    gregs: "gregs: [REG_RBP, REG_RIP, ...]"
  }
  extract_rbp: "Extract REG_RBP\n(Frame Pointer)" {
    shape: rectangle
    style.fill: "#EF9A9A"
    style.bold: true
  }
  extract_rip: "Extract REG_RIP\n(Instruction Pointer)" {
    shape: rectangle
    style.fill: "#EF9A9A"
    style.bold: true
  }
}

step3_arm: {
  label: "Step 3b: aarch64 Extraction"
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
  style.stroke-width: 3
  arm_note: |md
    **Changed: Architecture Branch**
    - ORANGE indicates active aarch64 path
  |
  ucontext_arm: {
    label: "ucontext_t\nuc_mcontext"
    shape: class
    style.fill: "#FFE0B2"
    regs: "regs[29]: Frame Pointer"
    pc: "pc: Program Counter"
  }
  extract_x29: "Extract x29\n(Frame Pointer)" {
    shape: rectangle
    style.fill: "#FFCC80"
    style.bold: true
  }
  extract_pc: "Extract pc\n(Program Counter)" {
    shape: rectangle
    style.fill: "#FFCC80"
    style.bold: true
  }
}

step4: {
  label: "Step 4: RegisterContext Build"
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  reg_context: {
    label: "RegisterContext {\n  rbp: u64,\n  rip: u64\n}"
    shape: class
    style.fill: "#E1BEE7"
  }
  validation: "Validate Non-NULL\nPointers" {
    shape: diamond
    style.fill: "#FFF9C4"
  }
}

step5: {
  label: "Step 5: Return to Unwinder"
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  style.stroke-width: 2
  result: {
    label: "Result<RegisterContext,\nUnwindError>"
    shape: class
    style.fill: "#B2EBF2"
  }
  output_note: |md
    **Complete State**
    - Ready for stack unwinding
    - Frame chain traversal begins
  |
}

# Control Flow Connections
step1.entry_point -> step1.safety_check: "validate context"
step1.safety_check -> step2.arch_check: "safe to proceed"

step2.arch_check -> step3_x86: "x86_64" {
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.bold: true
}
step2.arch_check -> step3_arm: "aarch64" {
  style.stroke: "#F57C00"
  style.stroke-width: 3
  style.bold: true
}

# x86 Data Flow
step3_x86.ucontext_x86 -> step3_x86.extract_rbp: "gregs[REG_RBP]"
step3_x86.ucontext_x86 -> step3_x86.extract_rip: "gregs[REG_RIP]"
step3_x86.extract_rbp -> step4.reg_context: "rbp value"
step3_x86.extract_rip -> step4.reg_context: "rip value"

# ARM Data Flow
step3_arm.ucontext_arm -> step3_arm.extract_x29: "regs[29]"
step3_arm.ucontext_arm -> step3_arm.extract_pc: "mc.pc"
step3_arm.extract_x29 -> step4.reg_context: "rbp value"
step3_arm.extract_pc -> step4.reg_context: "rip value"

step4.reg_context -> step4.validation: "constructed"
step4.validation -> step5.result: "valid"

# Documentation and Reference
legend: {
  label: "Legend"
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  x86_legend: "x86_64 Path" {
    style.fill: "#FFCDD2"
  }
  arm_legend: "aarch64 Path" {
    style.fill: "#FFE0B2"
  }
  shared_legend: "Shared Logic" {
    style.fill: "#E1BEE7"
  }
}

code_ref: |rust
### Code Reference (src/unwinder/context.rs)
impl RegisterContext {
  #[cfg(target_arch = "x86_64")]
  pub unsafe fn from_ucontext(ctx: &ucontext_t) -> Self {
    Self {
      rbp: ctx.uc_mcontext.gregs[REG_RBP as usize] as u64,
      rip: ctx.uc_mcontext.gregs[REG_RIP as usize] as u64,
    }
  }
  #[cfg(target_arch = "aarch64")]
  pub unsafe fn from_ucontext(ctx: &ucontext_t) -> Self {
    Self {
      rbp: ctx.uc_mcontext.regs[29],  // x29 = FP
      rip: ctx.uc_mcontext.pc,         // pc
    }
  }
}
| {
  near: bottom-center
  style.fill: "#263238"
  style.font-color: "#ECEFF1"
}