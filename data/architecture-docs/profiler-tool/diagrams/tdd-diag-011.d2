direction: right
layout-engine: elk
theme: 4
title: Call Graph Data Model {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
CallGraph: {
  shape: class
  style.fill: "#E3F2FD"
  +nodes: HashMap<String, CallGraphNode>
  +roots: HashSet<String>
  +total_samples: usize
}
CallGraphNode: {
  shape: class
  style.fill: "#FFF3E0"
  +function_name: String
  +total_samples: usize
  +self_samples: usize
  +callees: HashMap<String, CallGraphEdge>
  +callers: HashMap<String, CallGraphEdge>
}
CallGraphEdge: {
  shape: class
  style.fill: "#F3E5F5"
  +target_function: String
  +sample_count: usize
}
CallGraph.nodes -> CallGraphNode: "contains\n0..*" {
  style.stroke-dash: 3
}
CallGraphNode.callees -> CallGraphEdge: "contains\n0..*" {
  style.stroke-dash: 3
}
CallGraphNode.callers -> CallGraphEdge: "contains\n0..*" {
  style.stroke-dash: 3
}
legend: {
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  HashMap: {
    shape: text
    style: {
      font-size: 12
    }
  }
}
legend.HashMap: "HashMap<K, V> - Key-value mapping\nHashSet<T> - Unique value collection"