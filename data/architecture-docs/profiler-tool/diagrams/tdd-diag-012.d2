layout-engine: elk
theme-id: 4

direction: right

# Style definitions
classes: {
  data_node: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      font-color: "#0D47A1"
    }
  }
  transform_node: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      font-color: "#E65100"
    }
  }
  array_box: {
    shape: rectangle
    style: {
      fill: "#F5F5F5"
      stroke: "#757575"
      multiple: true
    }
  }
  result_node: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      font-color: "#1B5E20"
    }
  }
}

# Input: Raw Sample
RawSample: {
  class: data_node
  label: "RawSample"
  addresses: {
    class: array_box
    label: "[addr1, addr2, addr3]"
    width: 180
  }
  meta: {
    shape: text
    label: "depth: 3\ntimestamp_ns: 1234567890\nthread_id: 42"
    style: {
      font-size: 12
      italic: true
    }
  }
  addresses -> meta: {
    style.opacity: 0
  }
}

# Transform 1: Symbol Lookup
SymbolLookup: {
  class: transform_node
  label: "Symbol\nLookup"
  width: 100
  height: 80
  
  lookup_table: {
    shape: sql_table
    label: "Symbol Table"
    "0x7fff1234": funcA
    "0x7fff5678": funcB
    "0x7fff9abc": funcC
  }
}

# Intermediate: Symbolized Array
Symbolized: {
  class: data_node
  label: "Symbolized\nStack"
  funcs: {
    class: array_box
    label: "[funcA, funcB, funcC]"
    width: 180
  }
  note: {
    shape: text
    label: "Stack grows down\nfuncA = leaf frame"
    style: {
      font-size: 11
      italic: true
    }
  }
}

# Transform 2: Reverse
Reverse: {
  class: transform_node
  label: "Reverse\nOrder"
  width: 100
  height: 80
}

# Intermediate: Reversed Array
Reversed: {
  class: data_node
  label: "Root→Leaf\nOrder"
  funcs: {
    class: array_box
    label: "[funcC, funcB, funcA]"
    width: 180
  }
  note: {
    shape: text
    label: "funcC = root caller\nfuncA = leaf callee"
    style: {
      font-size: 11
      italic: true
    }
  }
}

# Transform 3: Join
Join: {
  class: transform_node
  label: "Join\nwith ';'"
  width: 100
  height: 80
}

# Output: Collapsed Path
CollapsedPath: {
  class: result_node
  label: "Collapsed\nStack Path"
  path: {
    shape: rectangle
    label: "\"funcC;funcB;funcA\""
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      bold: true
    }
    width: 180
  }
  format: {
    shape: text
    label: "Flamegraph.pl format:\nroot;parent;child"
    style: {
      font-size: 11
      italic: true
    }
  }
}

# Connections
RawSample -> SymbolLookup: "addresses[]" {
  style.stroke-dash: 3
}
SymbolLookup -> Symbolized: "resolve" {
  style.stroke-dash: 3
}
Symbolized -> Reverse: "leaf→root" {
  style.stroke-dash: 3
}
Reverse -> Reversed: "root→leaf" {
  style.stroke-dash: 3
}
Reversed -> Join: "ordered[]" {
  style.stroke-dash: 3
}
Join -> CollapsedPath: "concat" {
  style.stroke-dash: 3
}

# Title
title: {
  shape: text
  label: "# Sample to Call Path Transformation"
  near: top-center
  style: {
    font-size: 20
    bold: true
    underline: true
  }
}

# Legend
legend: {
  shape: rectangle
  label: "Legend"
  style.stroke-dash: 5
  near: bottom-right
  
  data: "Data" {
    class: data_node
  }
  transform: "Transform" {
    class: transform_node
  }
  result: "Result" {
    class: result_node
  }
  
  data -> transform -> result: {
    style.opacity: 0
  }
}

# Process annotation
process_note: {
  shape: rectangle
  near: bottom-left
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
  }
  label: |md
    **Transformation Pipeline**
    1. **Symbol Lookup**: Resolve raw instruction pointers to function names via ELF/DWARF debug info
    2. **Reverse**: Convert from stack order (leaf first) to call order (root first)
    3. **Join**: Collapse into semicolon-separated path for flame graph aggregation
  |
}