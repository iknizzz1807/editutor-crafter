direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
step_1: {
  shape: rectangle
  label: "1. Calculate max_depth"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  desc: {
    shape: text
    label: "Traverse flame graph tree\nto find maximum depth"
  }
  state_before: {
    shape: rectangle
    label: "Input"
    style.fill: "#F5F5F5"
    tree: "FlameGraphNode root"
  }
  state_after: {
    shape: rectangle
    label: "Output"
    style.fill: "#C8E6C9"
    result: "max_depth = deepest level"
  }
}
step_2: {
  shape: rectangle
  label: "2. Determine height"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  desc: {
    shape: text
    label: "total_height = (max_depth + 1) × row_height\nsvg_height = total_height + header_padding"
  }
  state_after: {
    shape: rectangle
    label: "Output"
    style.fill: "#C8E6C9"
    result: "Canvas dimensions set"
  }
}
step_3: {
  shape: rectangle
  label: "3. render_node(x, width, depth)"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 3
  style.bold: true
  desc: {
    shape: text
    label: "Recursive function entry\nx: horizontal offset\nwidth: node width\ndepth: current level"
  }
  params: {
    shape: class
    label: "Parameters"
    style.fill: "#FFF3E0"
    x: "f64: horizontal position"
    "width": "f64: rectangle width"
    depth: "usize: tree depth"
  }
}
step_4: {
  shape: rectangle
  label: "4. Draw rect"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  desc: {
    shape: text
    label: "y = depth × row_height\nSVG rect element:\n  x, y, width, height\n  fill color from palette"
  }
  svg_output: {
    label: |xml
      <rect x="{x}" y="{y}" width="{width}" height="{row_height}" fill="{color}"/>
    |
  }
}
step_5: {
  shape: diamond
  label: "5. Draw text if fits?"
  style.fill: "#FFF8E1"
  style.stroke: "#F57C00"
  style.stroke-width: 2
  check: {
    shape: text
    label: "Condition:\ntext_width < width - padding"
  }
  yes_branch: {
    shape: rectangle
    label: "Draw text"
    style.fill: "#C8E6C9"
    svg: "<text>label</text>"
  }
  no_branch: {
    shape: rectangle
    label: "Skip text"
    style.fill: "#FFCDD2"
    reason: "Too narrow"
  }
}
step_6: {
  shape: rectangle
  label: "6. Recurse children"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  desc: {
    shape: text
    label: "For each child:\n  child_x = x + accumulated_width\n  child_width = (child.value / parent.value) × width\n  render_node(child_x, child_width, depth + 1)"
  }
  state_change: {
    shape: class
    label: "Updated Parameters"
    style.fill: "#FFEBEE"
    style.bold: true
    x: "x + offset: RED"
    "width": "proportional: RED"
    depth: "depth + 1: RED"
  }
}
# Flow connections
step_1 -> step_2: {
  label: "max_depth\ncomputed"
  style.stroke: "#2E7D32"
}
step_2 -> step_3: {
  label: "canvas ready"
  style.stroke: "#2E7D32"
}
step_3 -> step_4: {
  label: "enter recursion"
  style.stroke: "#2E7D32"
}
step_4 -> step_5: {
  style.stroke: "#2E7D32"
}
step_5 -> step_6: {
  label: "continue"
  style.stroke: "#2E7D32"
}
step_6 -> step_3: {
  label: "for each child\n(depth + 1)"
  style.stroke: "#C62828"
  style.stroke-dash: 4
}
# Legend
legend: {
  shape: rectangle
  label: "Legend"
  style.fill: "#FAFAFA"
  green: "Stable state" {shape: text}
  red: "Changed/mutated" {shape: text}
  orange: "Decision point" {shape: text}
}