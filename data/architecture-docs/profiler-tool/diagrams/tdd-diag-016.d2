layout-engine: elk
theme-id: 4

# HEADER SECTION
header: {
  near: top-center
  title: "Differential Flame Graph Color Scheme" {
    shape: text
    style: {
      font-size: 28
      bold: true
      underline: true
    }
  }
  subtitle: "color_for_change(base, comp) → RGB" {
    shape: text
    style: {
      font-size: 16
      italic: true
    }
  }
}

# 1. INPUT ANALYSIS (BYTE SPECIFICATION)
inputs: {
  label: "Memory Representation (F64)"
  base_val: "base: f64" {
    style.fill: "#e3e3ff"
    tooltip: "Baseline sample count"
  }
  comp_val: "comp: f64" {
    style.fill: "#ffe3e3"
    tooltip: "Comparison sample count"
  }
}

# 2. CALCULATION LOGIC
ratio_calc: {
  label: "Step 1: Ratio Calculation"
  style.fill: "#f5f5f5"
  
  formula: |'md
    rust
    // Handle edge cases first
    if base == 0.0 && comp == 0.0 { return GRAY_ABSENT; }
    if base == 0.0 { return RED_NEW; }
    
    let ratio = comp / base;
    
  '|
}

# 3. COLOR SPECTRUM MAPPING
spectrum: {
  label: "Step 2: Color Space Mapping"
  style.stroke-dash: 3
  
  improvement: {
    label: "IMPROVEMENT (ratio < 0.9)"
    style.fill: "#e3e3ff"
    style.stroke: "#0000ff"
    blue_formula: |'md
      **Intensity Calculation**
      $I = \min(255, (1.0 - ratio) \times 255)$
      $RGB = (255-I, 255-I, 255)$
    '| { shape: text }
  }

  neutral: {
    label: "STABLE (0.9 ≤ ratio ≤ 1.1)"
    style.fill: "#f0f0f0"
    style.stroke: "#808080"
    gray_info: "Fixed: #c0c0c0" { shape: text }
  }

  regression: {
    label: "REGRESSION (ratio > 1.1)"
    style.fill: "#ffe3e3"
    style.stroke: "#ff0000"
    red_formula: |'md
      **Intensity Calculation**
      $I = \min(255, (ratio - 1.0) \times 255)$
      $RGB = (255, 255-I, 255-I)$
    '| { shape: text }
  }
}

# 4. DECISION FLOW
decision_logic: {
  label: "Control Flow"
  
  start: ●
  is_both_zero: "base=0 & comp=0?" { shape: diamond; style.fill: "#ffffcc" }
  is_base_zero: "base=0?" { shape: diamond; style.fill: "#ffffcc" }
  compare: "ratio vs [0.9, 1.1]" { shape: diamond; style.fill: "#ffffcc" }
  
  res_absent: "#808080 (Absent)" { style.fill: "#808080"; style.font-color: white }
  res_new: "#ff0000 (New)" { style.fill: "#ff0000"; style.font-color: white }
  res_blue: "Blue Gradient" { style.fill: "#0000ff"; style.font-color: white }
  res_gray: "#c0c0c0 (Neutral)" { style.fill: "#c0c0c0" }
  res_red: "Red Gradient" { style.fill: "#ff0000"; style.font-color: white }

  start -> is_both_zero
  is_both_zero -> res_absent: "Yes"
  is_both_zero -> is_base_zero: "No"
  is_base_zero -> res_new: "Yes"
  is_base_zero -> compare: "No"
  
  compare -> res_blue: "ratio < 0.9"
  compare -> res_gray: "0.9 ≤ r ≤ 1.1"
  compare -> res_red: "ratio > 1.1"
}

# 5. VISUAL REFERENCE
color_bar: {
  label: "Visual Ratio Reference"
  grid-columns: 7
  grid-gap: 0
  
  c0: "0.0" { style.fill: "#0000ff"; style.font-color: white }
  c1: "0.5" { style.fill: "#7f7fff"; style.font-color: white }
  c2: "0.9" { style.fill: "#f0f0ff" }
  c3: "1.0" { style.fill: "#c0c0c0" }
  c4: "1.1" { style.fill: "#fff0f0" }
  c5: "1.5" { style.fill: "#ff7f7f" }
  c6: "2.0+" { style.fill: "#ff0000"; style.font-color: white }
}

# CONNECTIONS
inputs -> ratio_calc: "Extract F64"
ratio_calc -> spectrum: "Ratio Value"
spectrum -> decision_logic: "Apply Constraints"
decision_logic -> color_bar: "Target Color"

# FOOTER LEGEND
legend: {
  near: bottom-right
  b: "■ Blue: Improvement" { shape: text; style.font-color: "#0000ff" }
  g: "■ Gray: No Change" { shape: text; style.font-color: "#808080" }
  r: "■ Red: Regression" { shape: text; style.font-color: "#ff0000" }
}