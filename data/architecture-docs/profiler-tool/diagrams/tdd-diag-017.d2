direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}
title: "Collapsed Stack Format Structure" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# ============================================
# TEXT FORMAT STRUCTURE
# ============================================
text_format: {
  label: "Text Format Structure"
  header: {
    shape: text
    label: "# Metadata Comments (optional)"
    style.font-color: "#6A737D"
  }
  metadata_example: {
    shape: rectangle
    label: "# total_samples: 150\n# profile_version: 1.0\n# created_at: 2024-01-15T10:30:00Z"
    style.fill: "#FDF6E3"
    style.stroke: "#CB4B16"
    style.multiple: true
    style.font: mono
  }
  header2: {
    shape: text
    label: "# Stack Lines (required)"
    style.font-color: "#6A737D"
  }
  stack_example: {
    shape: rectangle
    label: "main;process_request;parse_json 120\nmain;process_request;validate_input 85\nmain;handle_error 15"
    style.fill: "#F5F5F5"
    style.stroke: "#0077B6"
    style.multiple: true
    style.font: mono
  }
}
# ============================================
# ANATOMY OF A STACK LINE
# ============================================
anatomy: {
  label: "Anatomy of a Stack Line"
  parts: {
    label: ""
    frame_root: {
      label: "root"
      shape: rectangle
      style.fill: "#B8D4E3"
      style.stroke: "#0077B6"
    }
    sep1: {
      label: ";"
      shape: text
      style.fill: "#E74C3C"
      style.font-color: "#E74C3C"
      style.bold: true
    }
    frame_middle: {
      label: "middle"
      shape: rectangle
      style.fill: "#B8D4E3"
      style.stroke: "#0077B6"
    }
    sep2: {
      label: ";"
      shape: text
      style.fill: "#E74C3C"
      style.font-color: "#E74C3C"
      style.bold: true
    }
    frame_leaf: {
      label: "leaf"
      shape: rectangle
      style.fill: "#B8D4E3"
      style.stroke: "#0077B6"
    }
    space: {
      label: "␣"
      shape: text
      style.fill: "#27AE60"
      style.font-color: "#27AE60"
      style.bold: true
    }
    count: {
      label: "count"
      shape: rectangle
      style.fill: "#D5F5E3"
      style.stroke: "#27AE60"
    }
  }
  parts.frame_root -> parts.sep1 -> parts.frame_middle -> parts.sep2 -> parts.frame_leaf -> parts.space -> parts.count
  annotations: {
    path_note: {
      label: "← Path (semicolon-separated stack frames) →"
      shape: text
      style.font-color: "#0077B6"
      style.italic: true
    }
    sep_note: {
      label: "Separator"
      shape: text
      style.font-color: "#E74C3C"
      style.italic: true
    }
    count_note: {
      label: "Sample\ncount"
      shape: text
      style.font-color: "#27AE60"
      style.italic: true
    }
  }
}
# ============================================
# PARSING STATE MACHINE
# ============================================
state_machine: {
  label: "Import Parsing State Machine"
  START: {
    shape: circle
    style.fill: "#27AE60"
    label: ""
  }
  READ_LINE: {
    shape: rectangle
    label: "Read Line"
    style.fill: "#E8F4FD"
  }
  CHECK_EOF: {
    shape: diamond
    label: "EOF?"
    style.fill: "#FFF3CD"
  }
  CHECK_EMPTY: {
    shape: diamond
    label: "Empty\nLine?"
    style.fill: "#FFF3CD"
  }
  CHECK_COMMENT: {
    shape: diamond
    label: "Starts\nwith #?"
    style.fill: "#FFF3CD"
  }
  PARSE_METADATA: {
    shape: rectangle
    label: "Parse Metadata\nkey: value"
    style.fill: "#FDF6E3"
  }
  FIND_LAST_SPACE: {
    shape: rectangle
    label: "Find Last Space\n(split path/count)"
    style.fill: "#E8F4FD"
  }
  VALIDATE_COUNT: {
    shape: diamond
    label: "Count is\nnumeric?"
    style.fill: "#FFF3CD"
  }
  SPLIT_PATH: {
    shape: rectangle
    label: "Split Path\non ';'"
    style.fill: "#E8F4FD"
  }
  BUILD_STACK: {
    shape: rectangle
    label: "Build Stack\nfrom frames"
    style.fill: "#E8F4FD"
  }
  ADD_TO_COLLECTION: {
    shape: rectangle
    label: "Add to\nCollapsedStacks"
    style.fill: "#D5F5E3"
  }
  ERROR: {
    shape: rectangle
    label: "Error:\nInvalid Format"
    style.fill: "#FADBD8"
    style.stroke: "#E74C3C"
  }
  END: {
    shape: circle
    style.fill: "#E74C3C"
    label: ""
  }
  # Transitions
  START -> READ_LINE: "Begin import"
  READ_LINE -> CHECK_EOF: "Line read"
  CHECK_EOF -> END: "Yes\n(all done)"
  CHECK_EOF -> CHECK_EMPTY: "No"
  CHECK_EMPTY -> READ_LINE: "Yes\n(skip)"
  CHECK_EMPTY -> CHECK_COMMENT: "No"
  CHECK_COMMENT -> PARSE_METADATA: "Yes"
  CHECK_COMMENT -> FIND_LAST_SPACE: "No"
  PARSE_METADATA -> READ_LINE: "Store metadata\ncontinue"
  FIND_LAST_SPACE -> VALIDATE_COUNT: "Split on last ' '"
  VALIDATE_COUNT -> ERROR: "No\n(parse error)"
  VALIDATE_COUNT -> SPLIT_PATH: "Yes"
  SPLIT_PATH -> BUILD_STACK: "frames[]"
  BUILD_STACK -> ADD_TO_COLLECTION: "Stack ready"
  ADD_TO_COLLECTION -> READ_LINE: "Success\n(continue)"
  ERROR -> END: "Abort"
}
# ============================================
# FORMAT RULES BOX
# ============================================
rules: {
  label: "Format Rules"
  rules_list: {
    shape: rectangle
    label: "| Rule | Description |\n|------|-------------|\n| Metadata | Lines starting with #, format: # key: value |\n| Path | Stack frames separated by semicolons (;) |\n| Count | Integer after last space in line |\n| Encoding | UTF-8 text, newline-separated |\n| Empty | Empty lines are ignored |\n| Order | Lines can be in any order |\n| Merging | Same paths accumulate counts |"
    style.fill: "#FAFAFA"
    style.multiple: true
    style.font: mono
  }
}
# ============================================
# EXAMPLE WITH LABELS
# ============================================
example: {
  label: "Complete Example"
  ex_box: {
    shape: rectangle
    label: "# profiler: rust-profiler v0.1.0\n# total_samples: 500\n# duration_ms: 10000\n#\nmain;worker;process_item;parse 150\nmain;worker;process_item;validate 100\nmain;worker;write_result 75\nmain;logger;flush 50\nmain;setup;init_config 25\nmain 100"
    style.fill: "#F8F9FA"
    style.stroke: "#DEE2E6"
    style.multiple: true
    style.font: mono
  }
  arrow1: {
    shape: text
    label: "← Metadata section"
    style.font-color: "#CB4B16"
  }
  arrow2: {
    shape: text
    label: "← Empty comment line (ignored)"
    style.font-color: "#6A737D"
  }
  arrow3: {
    shape: text
    label: "← 4-frame stack with 150 samples"
    style.font-color: "#0077B6"
  }
  arrow4: {
    shape: text
    label: "← Single-frame stack (root only)"
    style.font-color: "#27AE60"
  }
}
# Layout connections (invisible, for structure)
text_format -> anatomy
anatomy -> state_machine
state_machine -> rules
rules -> example