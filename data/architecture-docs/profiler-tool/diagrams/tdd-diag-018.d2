direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: ||md
    ### String Interning for Memory Efficiency
    **Memory Layout** — StringInterner Structure
  ||
  near: top-center
}

# StringInterner struct definition (Stack/Static)
StringInterner: {
  shape: rectangle
  style.fill: "#E1BEE7"
  
  # Header section (metadata)
  header: {
    shape: rectangle
    style.fill: "#9C27B0"
    style.font-color: "#FFFFFF"
    label: ||md
      **Struct Header**
      0x0000 | ptr vtable     | 8B
      0x0008 | len strings    | 8B
      0x0010 | cap strings    | 8B
      0x0018 | len indices    | 8B
      0x0020 | cap indices    | 8B
    ||
  }
  
  # Padding to illustrate memory alignment
  padding_internal: {
    shape: rectangle
    style.fill: "#9E9E9E"
    label: ||md
      0x0028 | padding (Gray) | 24B
    ||
  }

  # Strings vector metadata
  strings_vec: {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: "#FFFFFF"
    label: ||md
      **Vec&lt;String&gt; strings**
      0x0040 | ptr data       | 8B
      0x0048 | len: 5         | 8B
      0x0050 | cap: 8         | 8B
    ||
  }
  
  # Indices HashMap metadata
  indices_map: {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: "#FFFFFF"
    label: ||md
      **HashMap&lt;Arc&lt;str&gt;, u64&gt;**
      0x0060 | ptr buckets    | 8B
      0x0068 | len: 5         | 8B
      0x0070 | cap: 8         | 8B
      0x0078 | hash_seed      | 8B
    ||
  }
}

# Cache Line Marker
cache_line_boundary: {
  shape: text
  label: "-------------------------- 64B Cache Line Boundary --------------------------"
  style.stroke-dash: 5
  style.font-color: "#666666"
}

# String table data section (Heap)
string_table: {
  shape: rectangle
  style.fill: "#BBDEFB"
  label: "Heap: String Table Data (Contiguous)"
  
  idx_0: {
    shape: rectangle
    style.fill: "#4CAF50" 
    label: ||md
      **[0] ""** (reserved)
      0x0000 | size: 0B      | 0B
    ||
  }
  idx_1: {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: "#FFFFFF"
    label: ||md
      **[1] "main"**
      0x0000 | ptr+len       | 16B
    ||
  }
  idx_2: {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: "#FFFFFF"
    label: ||md
      **[2] "foo::bar"**
      0x0010 | ptr+len       | 16B
    ||
  }
  idx_3: {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: "#FFFFFF"
    label: ||md
      **[3] "allocate"**
      0x0020 | ptr+len       | 16B
    ||
  }
  idx_4: {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: "#FFFFFF"
    label: ||md
      **[4] "process"**
      0x0030 | ptr+len       | 16B
    ||
  }
  free_space: {
    shape: rectangle
    style.fill: "#4CAF50"
    label: ||md
      **[5-7] Free Slots**
      Capacity: 3 slots      | 48B
    ||
  }
}

# HashMap buckets (Heap)
hash_buckets: {
  shape: rectangle
  style.fill: "#BBDEFB"
  label: "Heap: HashMap Buckets"
  bucket_0: {
    shape: rectangle
    style.fill: "#FF9800" 
    label: ||md
      **Bucket 0**
      hash: 0x7a3f
      key_ptr -> [1]
      val: 1 (u64)
    ||
  }
  bucket_1: {
    shape: rectangle
    style.fill: "#FF9800"
    label: ||md
      **Bucket 1**
      hash: 0xb2c1
      key_ptr -> [2]
      val: 2 (u64)
    ||
  }
}

# intern() function flow (Algorithm State)
intern_flow: {
  label: "Algorithm: intern(s: &str) -> u64"
  
  step_1: {
    shape: diamond
    style.fill: "#FFF3E0"
    label: "In indices?"
  }
  step_2_yes: {
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: "#FFFFFF"
    label: ||md
      **HIT**
      Return idx O(1)
    ||
  }
  step_2_no: {
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: "#FFFFFF"
    label: ||md
      **MISS**
      1. push strings
      2. insert map
      3. Return new idx
    ||
  }

  step_1 -> step_2_yes: "found" { 
    style.stroke: "#4CAF50" 
  }
  step_1 -> step_2_no: "not found" { 
    style.stroke: "#F44336" 
  }
}

# Connections for Pointers
StringInterner.strings_vec -> string_table: "ptr" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
StringInterner.indices_map -> hash_buckets: "ptr" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
hash_buckets.bucket_0 -> string_table.idx_1: "key ref" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}

# Page Boundary Marker
page_boundary: {
  shape: text
  label: "============================ 4096B Page Boundary ============================"
  style.font-color: "#000000"
  style.bold: true
}

# Size annotations and stats
stats: {
  shape: rectangle
  style.fill: "#F5F5F5"
  label: ||md
    **Memory Footprint**
    - Interner Struct: 128B
    - String Heap: 128B
    - Map Heap: 256B
    **Total: 512B**

    **Efficiency Analysis**
    Unique: 5 strings
    Overhead: ~100B
    Savings: **~74%**
  ||
}

# Technical Legend
legend: {
  shape: rectangle
  near: bottom-right
  label: ||md
    **Technical Legend**
    - 🟪 Purple: Header/VTable
    - 🟦 Blue: Active Data
    - 🟩 Green: Free/Reserved
    - 🟧 Orange: Pointer/Bucket
    - ⬜ Gray: Alignment Padding
  ||
}