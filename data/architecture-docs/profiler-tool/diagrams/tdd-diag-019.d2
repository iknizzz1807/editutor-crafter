direction: right
layout-engine: elk
title: {
  label: "Inlined Function Visibility Problem\nAlgorithm Steps: Profile Attribution with DWARF Fallback"
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
  style.underline: true
}
# Step 1: Source Code with #[inline] Functions
step1_container: {
  label: "STEP 1: Source Code with Inline Annotations"
  style.fill: "#E8F5E9"
  step_number: {
    label: "1"
    shape: circle
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
  }
  source_code: {
    label: ""
    shape: rectangle
    style.fill: "#FAFAFA"
    style.stroke: "#333"
    main_function: {
      label: "fn main() {\n    let data = process(input);\n    let result = compute(data);\n}"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.font: mono
      style.font-size: 11
    }
    inline_process: {
      label: "#[inline]\nfn process(x) -> T {\n    // transformation logic\n    x.transform()\n}"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#D32F2F"
      style.stroke-width: 3
      style.font: mono
      style.font-size: 11
      style.bold: true
    }
    inline_compute: {
      label: "#[inline(always)]\nfn compute(x) -> R {\n    // calculation logic\n    x.calculate()\n}"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#D32F2F"
      style.stroke-width: 3
      style.font: mono
      style.font-size: 11
      style.bold: true
    }
    source_layout: {
      label: "Source Structure\n• main() → separate function\n• process() → #[inline] hint\n• compute() → #[inline(always)]"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.font-size: 10
    }
    main_function -> inline_process: "calls"
    main_function -> inline_compute: "calls"
    inline_process -> source_layout: {
      style.stroke-dash: 3
    }
  }
  visibility_note: {
    label: "⚠️ Compiler will inline these functions\ninto caller during optimization"
    shape: parallelogram
    style.fill: "#FFF9C4"
    style.font-color: "#F57C00"
  }
  source_code -> visibility_note
}
# Step 2: Compiler Optimization (Inlining)
step2_container: {
  label: "STEP 2: Compiler Optimization - Function Inlining"
  style.fill: "#FFF3E0"
  step_number: {
    label: "2"
    shape: circle
    style.fill: "#FF9800"
    style.font-color: white
    style.bold: true
  }
  compiler_box: {
    label: ""
    shape: rectangle
    compiler: {
      label: "rustc -O2\n(Compiler)"
      shape: hexagon
      style.fill: "#FFE0B2"
      style.bold: true
    }
    optimization: {
      label: "Optimization Pass:\n\n1. Analyze call graph\n2. Identify inline candidates\n3. Expand #[inline] functions\n4. Eliminate function boundaries"
      shape: rectangle
      style.fill: "#FFF8E1"
    }
    compiler -> optimization
  }
  transformation: {
    label: "Function bodies copied\ndirectly into main()"
    shape: parallelogram
    style.fill: "#FFECB3"
    style.font-color: "#E65100"
    style.bold: true
  }
  compiler_box -> transformation
}
# Step 3: Assembly Output - No Separate Function Entries
step3_container: {
  label: "STEP 3: Assembly Output - Inlined Code"
  style.fill: "#E3F2FD"
  step_number: {
    label: "3"
    shape: circle
    style.fill: "#2196F3"
    style.font-color: white
    style.bold: true
  }
  assembly_output: {
    label: ""
    shape: rectangle
    style.fill: "#FAFAFA"
    main_symbol: {
      label: "main:\n    push rbp\n    mov rbp, rsp\n    ; process() code inlined here\n    call transform\n    ; compute() code inlined here\n    call calculate\n    pop rbp\n    ret"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.font: mono
      style.font-size: 10
    }
    process_missing: {
      label: "process:\n❌ SYMBOL NOT PRESENT\n(Function was inlined)"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
      style.stroke-width: 3
      style.font: mono
      style.font-size: 10
      style.bold: true
      style.font-color: "#D32F2F"
    }
    compute_missing: {
      label: "compute:\n❌ SYMBOL NOT PRESENT\n(Function was inlined)"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
      style.stroke-width: 3
      style.font: mono
      style.font-size: 10
      style.bold: true
      style.font-color: "#D32F2F"
    }
    symbols_present: {
      label: "Symbol Table:\n✓ main @ 0x401000\n✗ process (MISSING)\n✗ compute (MISSING)"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.font-size: 10
    }
    main_symbol -> process_missing
    main_symbol -> compute_missing
    process_missing -> symbols_present: {
      style.stroke-dash: 3
    }
  }
}
# Step 4: Profiler Sample Collection
step4_container: {
  label: "STEP 4: Profiler Samples (99Hz)"
  style.fill: "#F3E5F5"
  step_number: {
    label: "4"
    shape: circle
    style.fill: "#9C27B0"
    style.font-color: white
    style.bold: true
  }
  profiler_stack: {
    label: ""
    shape: rectangle
    stack_frame_1: {
      label: "Sample @ T=0.05s\nStack:\n  #0: 0x401023 (main+0x23)\n  #1: 0x7fff... (__libc_start_main)"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.font: mono
      style.font-size: 9
    }
    stack_frame_2: {
      label: "Sample @ T=0.15s\nStack:\n  #0: 0x401045 (main+0x45)\n  #1: 0x7fff... (__libc_start_main)"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.font: mono
      style.font-size: 9
    }
    stack_frame_3: {
      label: "Sample @ T=0.25s\nStack:\n  #0: 0x401067 (main+0x67)\n  #1: 0x7fff... (__libc_start_main)"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.font: mono
      style.font-size: 9
    }
  }
  attribution_problem: {
    label: "⚠️ All samples attributed to 'main'\n\nTime spent in process() logic:\n  → Shows as main+0x23\n\nTime spent in compute() logic:\n  → Shows as main+0x45\n\nInlined functions are INVISIBLE!"
    shape: parallelogram
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 2
    style.font-color: "#C62828"
    style.bold: true
  }
  stack_frame_2 -> attribution_problem
}
# Step 5: DWARF Debug Info Fallback
step5_container: {
  label: "STEP 5: DWARF Debug Info Resolution (Fallback)"
  style.fill: "#E8F5E9"
  step_number: {
    label: "5"
    shape: circle
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
  }
  dwarf_resolution: {
    label: ""
    shape: rectangle
    dwarf_lookup: {
      label: "DWARF Debug Info Lookup"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.bold: true
    }
    address_table: {
      label: ".debug_info Section:\n\n0x401020 - 0x401030:\n  DW_TAG_inlined_subroutine\n  DW_AT_abstract_origin = 'process'\n  DW_AT_call_file = 'main.rs'\n  DW_AT_call_line = 2\n\n0x401040 - 0x401055:\n  DW_TAG_inlined_subroutine\n  DW_AT_abstract_origin = 'compute'\n  DW_AT_call_file = 'main.rs'\n  DW_AT_call_line = 3"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.font: mono
      style.font-size: 9
    }
    dwarf_lookup -> address_table
  }
  resolution_result: {
    label: "✅ Resolved Attribution:\n\n0x401023 → process (inlined)\n0x401045 → compute (inlined)\n0x401067 → main (direct)"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
    style.bold: true
  }
  dwarf_resolution -> resolution_result
}
# Step 6: Final Profile with Inlined Functions
step6_container: {
  label: "STEP 6: Corrected Profile Attribution"
  style.fill: "#E3F2FD"
  step_number: {
    label: "6"
    shape: circle
    style.fill: "#2196F3"
    style.font-color: white
    style.bold: true
  }
  before_container: {
    label: "BEFORE\n(Without DWARF)"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    before_profile: {
      label: "main: 100% ████████████\nprocess: 0%   \ncompute: 0%"
      shape: rectangle
      style.fill: "#FAFAFA"
      style.font: mono
      style.font-size: 10
    }
  }
  after_container: {
    label: "AFTER\n(With DWARF Fallback)"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    after_profile: {
      label: "main: 30%    ███\nprocess: 40%  ████\ncompute: 30%  ███"
      shape: rectangle
      style.fill: "#FAFAFA"
      style.font: mono
      style.font-size: 10
    }
  }
  arrow: before_container -> after_container: {
    label: "DWARF\nResolution"
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
  }
}
# Flow connections
step1_container -> step2_container -> step3_container -> step4_container -> step5_container -> step6_container: {
  style.stroke: "#666"
  style.stroke-width: 2
}
# Alternative path: DWARF bypass
dwarf_bypass: {
  label: "DWARF Fallback Path\n(Requires -g debug flag)"
  shape: parallelogram
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
step3_container -> dwarf_bypass: {
  label: "symbols\nmissing"
  style.stroke-dash: 5
  style.stroke: "#D32F2F"
}
dwarf_bypass -> step5_container: {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#333"
  red_item: {
    label: "Red border/fill = Missing or Problem"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    style.stroke-width: 2
  }
  green_item: {
    label: "Green border/fill = Resolved/Correct"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  orange_item: {
    label: "Orange = Transformation step"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
  }
}
legend <- step6_container: {
  style.stroke-dash: 3
  style.stroke: "#999"
}