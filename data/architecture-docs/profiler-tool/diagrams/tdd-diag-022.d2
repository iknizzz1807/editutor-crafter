direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: "AllocationInfo Memory Layout" {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    font-color: "#7c3aed"
  }
}

# Memory layout container
layout: {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }
}

# Offset labels column
layout.offsets: {
  shape: rectangle
  style.fill: "#0d0d1a"
  style.stroke-width: 0
}

layout.offsets.o0: "0x00" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o8: "0x08" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o10: "0x10" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o18: "0x18" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o20: "0x20" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o28: "0x28" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o30: "0x30" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o38: "0x38" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o39: "0x39" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o40: "0x40" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}
layout.offsets.o48: "0x48" {
  shape: text
  style: { font-size: 12; font: mono; font-color: "#9ca3af" }
}

# Fields column
layout.fields: {
  shape: rectangle
  style.fill: "#1a1a2e"
  style.stroke-width: 0
}

layout.fields.address: "address: usize" {
  style: {
    fill: "#3b82f6"
    font-color: white
    stroke: "#60a5fa"
  }
}
layout.fields.size: "size: usize" {
  style: {
    fill: "#3b82f6"
    font-color: white
    stroke: "#60a5fa"
  }
}
layout.fields.timestamp: "timestamp_ns: u64" {
  style: {
    fill: "#3b82f6"
    font-color: white
    stroke: "#60a5fa"
  }
}
layout.fields.thread: "thread_id: u64" {
  style: {
    fill: "#3b82f6"
    font-color: white
    stroke: "#60a5fa"
  }
}
layout.fields.vec_ptr: "call_stack.ptr: *mut usize" {
  style: {
    fill: "#f97316"
    font-color: white
    stroke: "#fb923c"
  }
}
layout.fields.vec_cap: "call_stack.cap: usize" {
  style: {
    fill: "#3b82f6"
    font-color: white
    stroke: "#60a5fa"
  }
}
layout.fields.vec_len: "call_stack.len: usize" {
  style: {
    fill: "#3b82f6"
    font-color: white
    stroke: "#60a5fa"
  }
}
layout.fields.freed: "freed: bool" {
  style: {
    fill: "#22c55e"
    font-color: white
    stroke: "#4ade80"
  }
}
layout.fields.padding: "<padding>" {
  style: {
    fill: "#6b7280"
    font-color: white
    stroke: "#9ca3af"
    stroke-dash: 4
  }
}
layout.fields.freed_ts: "freed_timestamp_ns: Option<u64>" {
  style: {
    fill: "#22c55e"
    font-color: white
    stroke: "#4ade80"
  }
}

# Size labels column
layout.sizes: {
  shape: rectangle
  style.fill: "#0d0d1a"
  style.stroke-width: 0
}

layout.sizes.s8a: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s8b: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s8c: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s8d: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s8e: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s8f: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s8g: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s1: "1B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }
layout.sizes.s7: "7B" { shape: text; style: { font-size: 11; font-color: "#6b7280" } }
layout.sizes.s8h: "8B" { shape: text; style: { font-size: 11; font-color: "#9ca3af" } }

# Visual Annotations
cache_line_0: "┄┄┄ Cache Line Boundary (64B) ┄┄┄" {
  shape: text
  style: {
    font-color: "#fbbf24"
    font-size: 10
    stroke-dash: 3
  }
}

heap_note: "call_stack data → HEAP (allocated)" {
  shape: rectangle
  style: {
    fill: "#fef3c7"
    font-color: "#92400e"
    stroke: "#f59e0b"
    stroke-dash: 4
  }
}

total_size: "Total Size: 72 bytes (0x48)" {
  shape: rectangle
  style: {
    fill: "#1e3a5f"
    font-color: "#93c5fd"
    stroke: "#3b82f6"
    bold: true
  }
}

# Growth direction
growth: "↑ Higher addresses" {
  shape: text
  style: { font-color: "#9ca3af"; font-size: 10 }
}

# Connections for alignment
layout.offsets.o0 -> layout.fields.address -> layout.sizes.s8a { style.stroke: transparent }
layout.offsets.o8 -> layout.fields.size -> layout.sizes.s8b { style.stroke: transparent }
layout.offsets.o10 -> layout.fields.timestamp -> layout.sizes.s8c { style.stroke: transparent }
layout.offsets.o18 -> layout.fields.thread -> layout.sizes.s8d { style.stroke: transparent }
layout.offsets.o20 -> layout.fields.vec_ptr -> layout.sizes.s8e { style.stroke: transparent }
layout.offsets.o28 -> layout.fields.vec_cap -> layout.sizes.s8f { style.stroke: transparent }
layout.offsets.o30 -> layout.fields.vec_len -> layout.sizes.s8g { style.stroke: transparent }
layout.offsets.o38 -> layout.fields.freed -> layout.sizes.s1 { style.stroke: transparent }
layout.offsets.o39 -> layout.fields.padding -> layout.sizes.s7 { style.stroke: transparent }
layout.offsets.o40 -> layout.fields.freed_ts -> layout.sizes.s8h { style.stroke: transparent }

layout.fields.vec_ptr -> heap_note { style: { stroke: "#f59e0b"; stroke-dash: 4 } }

# Legend
legend: {
  shape: rectangle
  label: "Memory Map Legend"
  style: { fill: "#1a1a2e"; stroke: "#4a4a6a" }
  
  data: "Data Field" { style: { fill: "#3b82f6"; font-color: white } }
  ptr: "Pointer" { style: { fill: "#f97316"; font-color: white } }
  free: "Free/Status" { style: { fill: "#22c55e"; font-color: white } }
  pad: "Padding" { style: { fill: "#6b7280"; font-color: white } }
}