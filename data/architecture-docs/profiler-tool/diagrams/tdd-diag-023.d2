direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: {
  label: "Recursion Guard State Machine\nThread-Local IN_PROFILER Flag"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# Initial trigger
Start: ● {
  style.stroke-width: 0
}

# Idle state
Idle: {
  label: "IDLE\nIN_PROFILER = false"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 10
  }
}

# Decision point after malloc interception
CheckFlag: {
  label: "CHECK\nIN_PROFILER?"
  shape: diamond
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
  }
}

# Active tracking state
Tracking: {
  label: "TRACKING\nIN_PROFILER = true"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    border-radius: 10
  }
}

# Skip state for recursive calls
SkipTracking: {
  label: "SKIP\n(Recursive Call)"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
    border-radius: 10
  }
}

# Return state
Return: {
  label: "RETURN\nto caller"
  style: {
    fill: "#F3E5F5"
    stroke: "#6A1B9A"
    stroke-width: 2
    border-radius: 10
  }
}

# Final reset state (logical completion)
ResetIdle: {
  label: "IDLE\nIN_PROFILER = false"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    double-border: true
    border-radius: 10
  }
}

# Transitions
Start -> Idle

Idle -> CheckFlag: "malloc() intercepted\n[trigger: allocation]" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}

CheckFlag -> Tracking: "[IN_PROFILER == false]" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

CheckFlag -> SkipTracking: "[IN_PROFILER == true]\n(Boehm effect detected)" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    stroke-dash: 4
  }
}

Tracking -> Tracking: "record_allocation()\nupdate_stats()\n[track: size, ptr, ip]" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

Tracking -> ResetIdle: "set IN_PROFILER = false\n[guard: release]" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

SkipTracking -> Return: "pass-through\nto real_malloc()" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    stroke-dash: 4
  }
}

ResetIdle -> Return: "[return: ptr]" {
  style: {
    stroke: "#6A1B9A"
    stroke-width: 2
  }
}

Return -> Idle: "[ready for next call]" {
  style: {
    stroke: "#757575"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Legend
legend: {
  label: Legend
  shape: rectangle
  near: top-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 2
  }
  normal_flow: "───▶ Normal Flow" { shape: text }
  recursive_flow: "- - -▶ Recursive Path" { shape: text }
  guard_note: "[...] = Guard Condition" { shape: text }
  tls_note: "TLS: Thread-Local Storage" { shape: text }
}