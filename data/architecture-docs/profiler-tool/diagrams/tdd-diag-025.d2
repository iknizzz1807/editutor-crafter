direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Leak Detection Algorithm" {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Step 1: Iterate allocations map
step1: {
  label: "Step 1: Iterate Allocations Map"
  style.fill: "#E3F2FD"
  input_state: {
    label: "Input: AllocationTracker"
    style.fill: "#FFF3E0"
    allocations: {
      label: "allocations: DashMap<Addr, AllocationInfo>"
      style.fill: "#F5F5F5"
      entry_1: "0x1000 -> {size: 256, freed: false, hash: 0xA1}"
      entry_2: "0x2000 -> {size: 1024, freed: true, hash: 0xB2}"
      entry_3: "0x3000 -> {size: 512, freed: false, hash: 0xA1}"
      entry_4: "0x4000 -> {size: 128, freed: false, hash: 0xC3}"
    }
  }
  iter_icon: {
    shape: circle
    label: "🔄"
    style.fill: "#2196F3"
  }
}

# Step 2: Filter !freed
step2: {
  label: "Step 2: Filter !freed"
  style.fill: "#E8F5E9"
  filter_logic: {
    label: "IF info.freed: CONTINUE"
    shape: diamond
    style.fill: "#FFEB3B"
  }
  filtered: {
    label: "Filtered Allocations (not freed)"
    style.fill: "#C8E6C9"
    f1: "0x1000 -> {size: 256, hash: 0xA1}"
    f2: "0x3000 -> {size: 512, hash: 0xA1}"
    f3: "0x4000 -> {size: 128, hash: 0xC3}"
  }
  discarded: {
    label: "Discarded (freed)"
    style.fill: "#FFCDD2"
    style.stroke-dash: 3
    d1: "0x2000 -> {freed: true}"
  }
}

# Step 3: Group by call_site_hash
step3: {
  label: "Step 3: Group by call_site_hash"
  style.fill: "#F3E5F5"
  grouper: {
    label: "sites_by_hash: HashMap<u64, LeakSite>"
    style.fill: "#E1BEE7"
    group_A1: {
      label: "0xA1"
      style.fill: "#CE93D8"
      addrs_a1: "[0x1000, 0x3000]"
    }
    group_C3: {
      label: "0xC3"
      style.fill: "#CE93D8"
      addrs_c3: "[0x4000]"
    }
  }
}

# Step 4: Aggregate bytes, count, age range
step4: {
  label: "Step 4: Aggregate bytes, count, age range"
  style.fill: "#FFF8E1"
  agg_A1: {
    label: "LeakSite 0xA1"
    style.fill: "#FFE082"
    bytes_a1: "total_bytes: 768 (256+512)"
    count_a1: "count: 2"
    age_a1: "age_range: [t1, t3]"
  }
  agg_C3: {
    label: "LeakSite 0xC3"
    style.fill: "#FFE082"
    bytes_c3: "total_bytes: 128"
    count_c3: "count: 1"
    age_c3: "age_range: [t4, t4]"
  }
  totals: {
    label: "Running Totals"
    style.fill: "#FFB74D"
    total_bytes: "total_leaked_bytes: 896"
    total_count: "total_leaked_count: 3"
  }
}

# Step 5: Sort by total_bytes descending
step5: {
  label: "Step 5: Sort by total_bytes DESC"
  style.fill: "#ECEFF1"
  before_sort: {
    label: "Before Sort"
    style.fill: "#CFD8DC"
    style.stroke-dash: 3
    bs1: "[0xA1, 0xC3]"
  }
  sort_icon: {
    shape: circle
    label: "⬇️"
    style.fill: "#607D8B"
  }
  after_sort: {
    label: "After Sort"
    style.fill: "#B0BEC5"
    as1: "sites[0] = 0xA1 (768 bytes)"
    as2: "sites[1] = 0xC3 (128 bytes)"
  }
}

# Step 6: Generate report
step6: {
  label: "Step 6: Generate LeakReport"
  style.fill: "#E1F5FE"
  report: {
    label: "LeakReport"
    style.fill: "#81D4FA"
    sites: "sites: Vec<LeakSite>"
    total_bytes: "total_leaked_bytes: 896"
    total_count: "total_leaked_count: 3"
    duration: "profiling_duration: Duration"
  }
  output_icon: {
    shape: circle
    label: "📊"
    style.fill: "#03A9F4"
  }
}

# Flow connections
step1.iter_icon -> step2.filter_logic: "each entry"
step2.filter_logic -> step2.filtered: "NOT freed"
step2.filter_logic -> step2.discarded: "freed"
step2.filtered -> step3.grouper: "group"
step3.grouper -> step4.agg_A1: "aggregate"
step3.grouper -> step4.agg_C3: "aggregate"
step4.agg_A1 -> step4.totals: "+="
step4.agg_C3 -> step4.totals: "+="
step4.totals -> step5.before_sort: "collect"
step5.before_sort -> step5.sort_icon: "sort"
step5.sort_icon -> step5.after_sort
step5.after_sort -> step6.report: "wrap"
step6.report -> step6.output_icon: "return"

# Legend
legend: {
  shape: rectangle
  label: "Legend"
  style.fill: "#FAFAFA"
  near: bottom-right
  hash_def: |md
    **call_site_hash**: `u64` hash of call stack frames
    Used to identify unique allocation sites
  |
  leaksite_def: |md
    **LeakSite**: Grouped allocation info
    - `call_stack`: `Vec<usize>`
    - `allocation_ids`: `Vec<usize>`
    - `total_bytes`: `u64`
    - `count`: `u64`
    - `oldest/newest_timestamp_ns`: `u64`
  |
}