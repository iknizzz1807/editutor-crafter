direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: {
  shape: text
  label: "Hot Spot Report Generation - Data Flow"
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# Input Data Structure
call_site_stats: {
  shape: cylinder
  label: "call_site_stats\nDashMap<u64, CallSiteStats>"
  style.fill: "#E3F2FD"
  tooltip: ||md
    **Input Container**
    - Concurrent hash map
    - Key: call_site_hash (u64)
    - Value: CallSiteStats struct
  ||
}

# CallSiteStats structure detail
call_site_stats_structure: {
  shape: class
  label: "CallSiteStats"
  style.fill: "#F3E5F5"
  total_allocated: "u64"
  total_freed: "u64"
  live_bytes: "u64"
  alloc_count: "u64"
  free_count: "u64"
  peak_live_bytes: "u64"
  representative_stack: "Vec<usize>"
}

# Step 1: Iterate
step1_iterate: {
  shape: rectangle
  label: "Iterate\nDashMap"
  style.fill: "#FFF3E0"
}

step1_annotation: {
  shape: text
  label: ||md
    **Step 1: Iterate**
    rust
    for entry in call_site_stats.iter() {
      let (hash, stats) = entry.pair();
    }
    
  ||
}

# Step 2: Extract tuples
extracted_tuples: {
  shape: class
  label: "Extracted Tuple"
  style.fill: "#E8F5E9"
  call_site_hash: "u64"
  stats: "&CallSiteStats"
  stack: "Vec<usize>"
}

step2_annotation: {
  shape: text
  label: ||md
    **Step 2: Extract**
    Collect into vector of tuples:
    - call_site_hash
    - stats reference  
    - representative_stack
  ||
}

# Step 3: Sort
step3_sort: {
  shape: rectangle
  label: "Sort by\ntotal_allocated"
  style.fill: "#FFEBEE"
}

step3_annotation: {
  shape: text
  label: ||md
    **Step 3: Sort**
    rust
    tuples.sort_by(|a, b| {
      b.stats.total_allocated
        .cmp(&a.stats.total_allocated)
    });
    
    Descending order by allocation volume
  ||
}

# Step 4: Take top N
step4_take: {
  shape: rectangle
  label: "Take top N"
  style.fill: "#E0F7FA"
}

step4_annotation: {
  shape: text
  label: ||md
    **Step 4: Limit**
    rust
    let top_n: Vec<_> = sorted
      .into_iter()
      .take(limit)
      .collect();
    
  ||
}

# Step 5: Symbol Resolution
symbol_resolver: {
  shape: rectangle
  label: "Symbol Resolver\n(SymbolCache)"
  style.fill: "#FCE4EC"
  tooltip: ||md
    **Step 5: Symbol Resolution**
    For each address in call_stack:
    rust
    let sym = symbol_cache.resolve(addr)?;
    
    Returns: function name + file:line
  ||
}

# HotSpot structure
hotspot_struct: {
  shape: class
  label: "HotSpot"
  style.fill: "#F1F8E9"
  call_site_hash: "u64"
  call_stack: "Vec<String>"
  total_allocated: "u64"
  avg_alloc_size: "f64"
  live_bytes: "u64"
  peak_live_bytes: "u64"
  alloc_count: "u64"
}

# Step 6: Format
step6_format: {
  shape: rectangle
  label: "Format\nReport"
  style.fill: "#FFF8E1"
}

step6_annotation: {
  shape: text
  label: ||md
    **Step 6: Format Output**
    For each HotSpot:
    [N] function_name (file.rs:123)
        Total: 1.2 MB
        Live: 256 KB
        Peak: 512 KB
        Count: 1,024 allocs
  ||
}

# Final Output
hotspot_report: {
  shape: document
  label: "HotSpotReport"
  style.fill: "#C8E6C9"
}

report_structure: {
  shape: class
  label: "HotSpotReport"
  style.fill: "#DCEDC8"
  sites: "Vec<HotSpot>"
  total_allocated: "u64"
  total_allocs: "u64"
  current_live_bytes: "u64"
  peak_live_bytes: "u64"
}

# Data Flow Connections
call_site_stats -> step1_iterate: "iter()" {
  style.stroke: "#1976D2"
}

call_site_stats_structure -> call_site_stats: {
  style.stroke-dash: 3
  style.stroke: "#9E9E9E"
}

step1_iterate -> extracted_tuples: "extract" {
  style.stroke: "#1976D2"
}

step1_annotation -- step1_iterate: {
  style.stroke: transparent
}

extracted_tuples -> step3_sort: "Vec<Tuple>" {
  style.stroke: "#1976D2"
}

step2_annotation -- extracted_tuples: {
  style.stroke: transparent
}

step3_sort -> step4_take: "sorted[]" {
  style.stroke: "#1976D2"
}

step3_annotation -- step3_sort: {
  style.stroke: transparent
}

step4_take -> hotspot_struct: "top N" {
  style.stroke: "#1976D2"
}

step4_annotation -- step4_take: {
  style.stroke: transparent
}

hotspot_struct -> symbol_resolver: "resolve addresses" {
  style.stroke: "#388E3C"
}

symbol_resolver -> hotspot_struct: "Vec<String>" {
  style.stroke: "#388E3C"
  style.stroke-dash: 3
}

hotspot_struct -> step6_format: "formatted" {
  style.stroke: "#1976D2"
}

step6_annotation -- step6_format: {
  style.stroke: transparent
}

step6_format -> hotspot_report: "write" {
  style.stroke: "#1976D2"
}

hotspot_report -> report_structure: {
  style.stroke-dash: 3
  style.stroke: "#9E9E9E"
}

# Legend
legend: {
  shape: rectangle
  style.fill: "#FAFAFA"
  label: "Legend"
  
  legend_text: {
    shape: text
    label: ||md
      - **Cylinder**: Persistent data store
      - **Process**: Transformation step
      - **Class**: Data structure
      - **Document**: Output artifact
      - → Data flow
      - ⭢ Structure reference
    ||
  }
}

# Flow direction indicator
flow_direction: {
  shape: text
  label: "→ Flow Direction →"
  near: bottom-center
  style.italic: true
}