vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

shape: sequence_diagram

# Participants
loader: "ld.so\n(Dynamic Linker)"
init_section: ".init_array\n(ELF Section)"
init_fn: "init()\n(Constructor)"
init_prof: "init_profiler()\n(Initializer)"
tracker: "TRACKER\n(OnceLock<AllocationTracker>)"
temporal: "TEMPORAL\n(OnceLock<Mutex<TemporalTracker>>)"
atexit_handler: "atexit\n(Exit Handler)"
main: "Main Program\n(Application)"

# Sequence flow
loader -> init_section: "Load library via LD_PRELOAD"
init_section -> init_fn: "Invoke constructor from .init_array"
init_fn -> init_prof: "Call init_profiler()"

# Tracker Phase
init_prof -> tracker: "get_or_init()"
tracker -> tracker: "AllocationTracker::new()"
tracker -> tracker: "activate()"
tracker -> init_prof: "TRACKER ready"

# Temporal Phase
init_prof -> temporal: "get_or_init()"
temporal -> temporal: "TemporalTracker::new(100, 36000)"
temporal -> temporal: "Wrap in Mutex"
temporal -> init_prof: "TEMPORAL ready"

# Exit Handler
init_prof -> atexit_handler: "libc::atexit(dump_final_report)"
atexit_handler -> atexit_handler: "Register exit handler"

# Handover
init_prof -> main: "Ready for malloc/free interposition"

# Initialization Blocks
"Library Constructor": {
  init_section
  init_fn
  init_prof
}

"OnceLock Initialization": {
  tracker
  temporal
}