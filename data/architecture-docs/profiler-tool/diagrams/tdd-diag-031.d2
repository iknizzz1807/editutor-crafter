direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: "Physical vs Logical Call Stack" {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: "The Async Profiler's Challenge" {
  shape: text
  near: top-center
  style: {
    font-size: 16
    italic: true
  }
}

physical_stack: "Physical Stack (Sampler View)" {
  style.fill: "#E74C3C"
  style.stroke: "#C0392B"
  style.font-color: white
  
  note: |'md
    *Thread's actual call stack at SIGPROF*
    *sizeof=144 bytes*
  '| {
    shape: text
    style: {
      font-size: 11
      italic: true
    }
  }

  poll: "poll()" {
    shape: rectangle
    style.fill: "#FADBD8"
    style.font-color: "#1A1A1A"
    type: "runtime_frame"
    size: "48 bytes"
  }
  poll_future: "poll_future()" {
    shape: rectangle
    style.fill: "#F5B7B1"
    style.font-color: "#1A1A1A"
    type: "executor_frame"
    size: "64 bytes"
  }
  closure: "closure<F>()" {
    shape: rectangle
    style.fill: "#F1948A"
    style.font-color: "#1A1A1A"
    type: "async_wrapper"
    size: "32 bytes"
  }
  
  poll -> poll_future: calls
  poll_future -> closure: calls
}

logical_stack: "Logical Stack (Developer View)" {
  style.fill: "#27AE60"
  style.stroke: "#1E8449"
  style.font-color: white
  
  note: |'md
    *Causal application-level call path*
    *sizeof=240 bytes*
  '| {
    shape: text
    style: {
      font-size: 11
      italic: true
    }
  }

  main: "main()" {
    shape: rectangle
    style.fill: "#D5F5E3"
    style.font-color: "#1A1A1A"
    type: "entry_point"
    size: "16 bytes"
  }
  handle_request: "handle_request()" {
    shape: rectangle
    style.fill: "#ABEBC6"
    style.font-color: "#1A1A1A"
    type: "business_logic"
    size: "128 bytes"
  }
  read_request: "read_request()" {
    shape: rectangle
    style.fill: "#82E0AA"
    style.font-color: "#1A1A1A"
    type: "io_logic"
    size: "96 bytes"
  }
  
  main -> handle_request: calls
  handle_request -> read_request: calls
}

bridge: {
  style.stroke-width: 0
  style.fill: transparent

  disconnect: "THE DISCONNECT" {
    shape: rectangle
    style.fill: "#F4D03F"
    style.stroke: "#D4AC0D"
    style.stroke-width: 3
    style.font-color: "#1A1A1A"
    style.bold: true
  }

  waker_bridge: "Waker Tracking" {
    shape: hexagon
    style.fill: "#9B59B6"
    style.stroke: "#7D3C98"
    style.font-color: white
    
    label: "Map task ID →\nlogical parent"
  }
}

physical_stack -> bridge.disconnect: "Sampler captures\nthis stack" {
  style.stroke-dash: 4
  style.stroke: "#C0392B"
  style.stroke-width: 2
}

bridge.disconnect -> logical_stack: "Developer needs\nthis context" {
  style.stroke-dash: 4
  style.stroke: "#1E8449"
  style.stroke-width: 2
}

bridge.disconnect -> bridge.waker_bridge: "M4 Solution" {
  style.stroke: "#7D3C98"
  style.stroke-width: 2
  style.stroke-dash: 3
}

legend: {
  shape: rectangle
  style.fill: "#FDFEFE"
  style.stroke: "#BDC3C7"
  near: bottom-center
  
  legend_title: "Legend" {
    shape: text
    style: {
      bold: true
      font-size: 12
    }
  }
  
  physical_label: "Runtime/Executor frames" {
    shape: text
    style.font-size: 10
  }
  
  logical_label: "Application frames" {
    shape: text
    style.font-size: 10
  }
  
  gap_label: "← Async execution hides causal relationships →" {
    shape: text
    style: {
      font-size: 10
      italic: true
    }
  }
}