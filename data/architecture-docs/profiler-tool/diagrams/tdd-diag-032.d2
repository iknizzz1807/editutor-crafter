direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: {
  label: "Async Task State Machine"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Initial marker
start: "" {
  shape: circle
  style: {
    fill: "#0D32B2"
    stroke: "#0D32B2"
  }
}

# States
SPAWNED: {
  label: "SPAWNED"
  style: {
    fill: "#E1F5FE"
    stroke: "#0288D1"
    stroke-width: 2
    font-color: "#01579B"
    border-radius: 10
  }
}

POLLING: {
  label: "POLLING\n(CPU Time)"
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
    stroke-width: 2
    font-color: "#E65100"
    border-radius: 10
  }
}

AWAITING: {
  label: "AWAITING\n(Wait Time)"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
    font-color: "#4A148C"
    border-radius: 10
  }
}

COMPLETED: {
  label: "COMPLETED"
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
    stroke-width: 2
    font-color: "#1B5E20"
    border-radius: 10
  }
}

# Final marker
end: "" {
  shape: circle
  style: {
    fill: "#000000"
    stroke: "#000000"
    double-border: true
  }
}

# Transitions
start -> SPAWNED: "task.spawn()" {
  style: {
    stroke: "#0D32B2"
    stroke-width: 2
  }
}

SPAWNED -> POLLING: "begin_poll" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
}

POLLING -> AWAITING: "poll → Pending" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    animated: true
  }
}

AWAITING -> POLLING: "wake received\n→ begin_poll" {
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    animated: true
  }
}

POLLING -> COMPLETED: "poll → Ready" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}

COMPLETED -> end: {
  style: {
    stroke: "#000000"
    stroke-width: 2
  }
}

# Legend
legend: {
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 4
  }
  near: bottom-center

  cpu_time: "■ CPU Time (POLLING)" {
    shape: text
    style: {
      font-color: "#F57C00"
    }
  }
  wait_time: "■ Wait Time (AWAITING)" {
    shape: text
    style: {
      font-color: "#7B1FA2"
    }
  }
  pending_transition: "→ Pending: task yielded" {
    shape: text
    style: {
      font-color: "#616161"
    }
  }
  ready_transition: "→ Ready: task completed" {
    shape: text
    style: {
      font-color: "#616161"
    }
  }
}

legend -> AWAITING: {
  style: {
    opacity: 0
  }
}