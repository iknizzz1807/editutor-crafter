direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: {
  label: "Task Identity Thread-Local Propagation"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# Sequence Diagram Container
task_propagation: {
  shape: sequence_diagram

  # Participants
  profiler: Profiler {
    style.fill: "#E8F5E9"
  }
  tracker: AsyncTaskTracker {
    style.fill: "#E3F2FD"
  }
  context: "CURRENT_TASK_ID\n(ThreadLocal)" {
    style.fill: "#FFF3E0"
  }
  future: ProfiledFuture {
    style.fill: "#F3E5F5"
  }
  nested: Nested Spawn {
    style.fill: "#FFEBEE"
  }
  relationships: TaskRelationshipGraph {
    style.fill: "#E0F7FA"
  }

  # Sequence Flow
  profiler -> tracker: "profiled_spawn<T>(future)"
  tracker -> tracker: "allocate_task_id()" {
    style.stroke-dash: 3
  }
  tracker -> profiler: "return AsyncTaskId(42)" {
    style.stroke-dash: 3
  }

  profiler -> context: "CURRENT_TASK_ID.set(Some(42))"
  context -> profiler: "TaskContextGuard created" {
    style.stroke-dash: 3
  }

  profiler -> future: "poll(inner_future, cx)"
  future -> nested: "spawn(nested_task)"

  nested -> context: "CURRENT_TASK_ID.get()"
  context -> nested: "Some(42) // parent_id" {
    style.stroke-dash: 3
  }

  nested -> tracker: "allocate_task_id() → 43" {
    style.stroke-dash: 3
  }
  nested -> relationships: "record_spawn(parent=42, child=43)"
  relationships -> nested: "edge recorded" {
    style.stroke-dash: 3
  }

  nested -> future: "nested future spawned" {
    style.stroke-dash: 3
  }
  future -> profiler: "Poll::Pending" {
    style.stroke-dash: 3
  }

  profiler -> context: "guard.drop()"
  context -> profiler: "CURRENT_TASK_ID restored to previous" {
    style.stroke-dash: 3
  }

  # Notes
  context: {
    "Invariant: TaskContextGuard\nensures RAII cleanup\non scope exit"
    "Thread-local storage:\nCell<Option<AsyncTaskId>>\nallows interior mutability"
  }
  relationships: {
    "TaskRelationshipGraph\nbuilds parent-child tree\nfor async flame graphs"
  }
}