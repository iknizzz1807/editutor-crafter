layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
  }
}

title: {
  shape: text
  label: "Task Relationship Graph"
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

subtitle: {
  shape: text
  label: |md
    ### M4: Async/Aware Profiling
    `TaskRelationshipGraph` struct for tracking parent-child relationships between async tasks.
    *sizeof=72 bytes (two DashMaps + padding)*
  |
  near: top-right
}

# 1. Memory Layout (Intel Manual Standard)
# Header=Purple, Data=Blue, Padding=Gray
TaskMemoryLayout: {
  shape: sql_table
  label: "struct TaskRelationshipGraph"
  style: {
    stroke: "#6B5B95"
    fill: "#6B5B95" # Header=Purple
  }
  
  "0x00": "parents: DashMap<AsyncTaskId, Option<AsyncTaskId>>" {
    constraint: "32 bytes"
    style.fill: "#D4E6F1" # Data=Blue
  }
  "0x20": "children: DashMap<AsyncTaskId, Vec<AsyncTaskId>>" {
    constraint: "32 bytes"
    style.fill: "#D4E6F1" # Data=Blue
  }
  
  # Cache line boundary (64B)
  "---": "------------------------------------------------" {
    style.stroke-dash: 5
  }

  "0x40": "metadata / internal_padding" {
    constraint: "8 bytes"
    style.fill: "#E5E7E9" # Padding=Gray
  }
}

TaskMemoryLayout.footer: "Total size: 72 bytes" {
  near: bottom-center
  shape: text
  style.italic: true
}

# 2. Architecture Definitions
# solid arrow=owns, hollow triangle=implements
TaskRelationshipGraph: {
  shape: class
  style.stroke: "#6B5B95"
  
  "record_spawn(parent: Option<AsyncTaskId>, child: AsyncTaskId)": void
  "logical_stack_for(task_id: AsyncTaskId)": "Vec<AsyncTaskId>"
  "descendants(task_id: AsyncTaskId)": "Vec<AsyncTaskId>"
  "validate()": "Result<(), GraphError>"
}

ParentsMapDetail: {
  label: "DashMap `parents` (1:1)"
  shape: class
  style.fill: "#D4E6F1"
  "Key": "AsyncTaskId (Child)"
  "Value": "Option<AsyncTaskId> (Parent)"
}

ChildrenMapDetail: {
  label: "DashMap `children` (1:N)"
  shape: class
  style.fill: "#D4E6F1"
  "Key": "AsyncTaskId (Parent)"
  "Value": "Vec<AsyncTaskId> (Children)"
}

# 3. Type Definitions
# Colors: Free/Green
AsyncTaskId: {
  shape: class
  style.fill: "#D5F5E3"
  label: "AsyncTaskId (u64)"
  "Size": "8 bytes"
}

# 4. Algorithm State / Implementation
LogicalStackAlgorithm: {
  label: "Algorithm: logical_stack_for()"
  shape: rectangle
  style: {
    fill: "#FCF3CF"
    stroke: "#B7950B"
  }
  content: |md
    ```rust
    fn logical_stack_for(&self, task_id: AsyncTaskId) -> Vec<AsyncTaskId> {
      let mut stack = vec![task_id];
      let mut current = Some(task_id);
      while let Some(id) = current {
        if let Some(parent) = self.parents.get(&id) {
          if let Some(pid) = *parent {
            stack.push(pid);
            current = Some(pid);
          } else { break; }
        } else { break; }
      }
      stack.reverse();
      stack
    }
    
  |
}

# 5. Example Visualization
ExampleDAG: {
  label: "Example Task Hierarchy"
  style.stroke-dash: 3
  
  T1: "Task 1 (Root)" { shape: circle; style.fill: "#D5F5E3" }
  T2: "Task 2" { shape: circle; style.fill: "#D4E6F1" }
  T3: "Task 3" { shape: circle; style.fill: "#D4E6F1" }
  T4: "Task 4" { shape: circle; style.fill: "#D4E6F1" }
  
  T1 -> T2: "spawns"
  T1 -> T3: "spawns"
  T2 -> T4: "spawns"
}

# Relationships
TaskRelationshipGraph -> TaskMemoryLayout: "represented by"
TaskRelationshipGraph -> ParentsMapDetail: "owns"
TaskRelationshipGraph -> ChildrenMapDetail: "owns"
TaskRelationshipGraph -> LogicalStackAlgorithm: "implements" {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

# Orange = Pointers/References
ParentsMapDetail -> AsyncTaskId: "references" { 
  style: {
    stroke-dash: 5
    stroke: "#E67E22" 
  }
}
ChildrenMapDetail -> AsyncTaskId: "references" { 
  style: {
    stroke-dash: 5
