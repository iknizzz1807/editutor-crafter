direction: right
layout-engine: elk
title: {
  label: Thread Migration Tracking
  shape: text
  near: top-center
}
# Thread pools
thread_1: {
  label: Thread 1
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}
thread_2: {
  label: Thread 2
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
}
# Task lifecycle states
initial_state: {
  label: "AsyncTaskLifecycle\nthreads_seen: []"
  shape: stored_data
  style.fill: "#F5F5F5"
}
poll_t1: {
  label: "POLL\non Thread 1"
  shape: circle
  style.fill: "#BBDEFB"
  style.stroke: "#1976D2"
}
state_after_t1: {
  label: "threads_seen = [1]"
  shape: stored_data
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}
wake_t2: {
  label: "WAKE\non Thread 2"
  shape: diamond
  style.fill: "#FFE0B2"
  style.stroke: "#F57C00"
}
poll_t2: {
  label: "POLL\non Thread 2"
  shape: circle
  style.fill: "#FFCC80"
  style.stroke: "#F57C00"
}
state_after_t2: {
  label: "threads_seen = [1, 2]"
  shape: stored_data
  style.fill: "#4CAF50"
  style.stroke: "#2E7D32"
  style.font-color: white
}
# Data flow connections
initial_state -> poll_t1: {
  label: "task spawned"
  style.stroke-dash: 3
}
poll_t1 -> state_after_t1: {
  label: "poll completes"
}
state_after_t1 -> wake_t2: {
  label: "waker called"
  style.stroke-dash: 3
}
wake_t2 -> poll_t2: {
  label: "work-stealing\nmigration"
  style.stroke: "#F57C00"
  style.stroke-width: 2
}
poll_t2 -> state_after_t2: {
  label: "poll completes"
}
# Thread groupings (visual containers)
group_t1: {
  label: ""
  style.fill: transparent
  style.stroke: "#1976D2"
  style.stroke-dash: 4
}
group_t2: {
  label: ""
  style.fill: transparent
  style.stroke: "#F57C00"
  style.stroke-dash: 4
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  legend_poll: {
    label: "Poll Event"
    shape: circle
  }
  legend_wake: {
    label: "Wake Event"
    shape: diamond
  }
  legend_state: {
    label: "State Snapshot"
    shape: stored_data
  }
  legend_migrate: {
    label: "Thread Migration"
    shape: text
  }
}
legend -> poll_t2: {
  style.opacity: 0
}