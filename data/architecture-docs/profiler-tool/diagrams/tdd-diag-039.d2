direction: down
layout-engine: elk
title: {
  label: "Async-Aware Flame Graph Coloring Algorithm\nDual-Color Scheme for CPU vs Await Time Attribution"
  shape: text
  near: top-center
}
legend: {
  label: "Color Legend"
  shape: rectangle
  style.fill: "#f8f9fa"
  cpu_color: {
    label: "CPU Poll Time\n(Active Execution)"
    shape: rectangle
    style.fill: "#e74c3c"
    style.stroke: "#c0392b"
    width: 120
    height: 40
  }
  await_color: {
    label: "Await Time\n(Async Waiting)"
    shape: rectangle
    style.fill: "#3498db"
    style.stroke: "#2980b9"
    width: 120
    height: 40
  }
  note: {
    label: "Width ∝ Total Time\nDepth = Logical Stack"
    shape: text
    style.italic: true
    style.font-size: 12
  }
  cpu_color -> await_color -> note
}
flame_graph: {
  label: "Sample Async Flame Graph"
  shape: rectangle
  style.stroke-dash: 3
  level_0: {
    label: "main()"
    shape: rectangle
    style.fill: "#e74c3c"
    style.stroke: "#c0392b"
    width: 600
    height: 36
    level_1_a: {
      label: "run_server()"
      shape: rectangle
      style.fill: "#e74c3c"
      style.stroke: "#c0392b"
      width: 350
      height: 36
      level_2_a: {
        label: "handle_request()"
        shape: rectangle
        style.fill: "#e74c3c"
        style.stroke: "#c0392b"
        width: 200
        height: 36
        level_3_poll: {
          label: "poll"
          shape: rectangle
          style.fill: "#e74c3c"
          style.stroke: "#c0392b"
          width: 40
          height: 36
        }
        level_3_await: {
          label: "await"
          shape: rectangle
          style.fill: "#3498db"
          style.stroke: "#2980b9"
          width: 80
          height: 36
        }
        level_3_poll2: {
          label: "poll"
          shape: rectangle
          style.fill: "#e74c3c"
          style.stroke: "#c0392b"
          width: 30
          height: 36
        }
        level_3_await2: {
          label: "await"
          shape: rectangle
          style.fill: "#3498db"
          style.stroke: "#2980b9"
          width: 50
          height: 36
        }
      }
      level_2_b: {
        label: "process_data()"
        shape: rectangle
        style.fill: "#e74c3c"
        style.stroke: "#c0392b"
        width: 100
        height: 36
        level_3_cpu: {
          label: "CPU"
          shape: rectangle
          style.fill: "#e74c3c"
          style.stroke: "#c0392b"
          width: 60
          height: 36
        }
        level_3_await_b: {
          label: "await"
          shape: rectangle
          style.fill: "#3498db"
          style.stroke: "#2980b9"
          width: 40
          height: 36
        }
      }
    }
    level_1_b: {
      label: "background_task()"
      shape: rectangle
      style.fill: "#e74c3c"
      style.stroke: "#c0392b"
      width: 200
      height: 36
      level_2_c: {
        label: "async_op()"
        shape: rectangle
        style.fill: "#e74c3c"
        style.stroke: "#c0392b"
        width: 120
        height: 36
        poll_seg: {
          label: "P"
          shape: rectangle
          style.fill: "#e74c3c"
          style.stroke: "#c0392b"
          width: 20
          height: 36
        }
        await_seg: {
          label: "A"
          shape: rectangle
          style.fill: "#3498db"
          style.stroke: "#2980b9"
          width: 50
          height: 36
        }
        poll_seg2: {
          label: "P"
          shape: rectangle
          style.fill: "#e74c3c"
          style.stroke: "#c0392b"
          width: 25
          height: 36
        }
        await_seg2: {
          label: "A"
          shape: rectangle
          style.fill: "#3498db"
          style.stroke: "#2980b9"
          width: 25
          height: 36
        }
      }
    }
  }
}
algorithm: {
  label: "Coloring Algorithm Steps"
  shape: sequence_diagram
  step_1: {
    label: "1. Collect Async Events"
    shape: rectangle
    style.fill: "#ecf0f1"
    desc_1: {
      label: "Gather TASK_POLL_START, TASK_POLL_END,\nAWAIT_POINT, TASK_SPAWN events"
      shape: text
      style.font-size: 11
    }
  }
  step_2: {
    label: "2. Build Logical Stack"
    shape: rectangle
    style.fill: "#ecf0f1"
    desc_2: {
      label: "Reconstruct call hierarchy from\nparent_task_id relationships"
      shape: text
      style.font-size: 11
    }
  }
  step_3: {
    label: "3. Calculate Time Segments"
    shape: rectangle
    style.fill: "#ecf0f1"
    desc_3: {
      label: "Poll time = POLL_END - POLL_START\nAwait time = Next_POLL_START - POLL_END"
      shape: text
      style.font-size: 11
    }
  }
  step_4: {
    label: "4. Assign Colors"
    shape: rectangle
    style.fill: "#ecf0f1"
    desc_4: {
      label: "CPU segments → Red/Orange (#e74c3c)\nAwait segments → Blue (#3498db)"
      shape: text
      style.font-size: 11
    }
  }
  step_5: {
    label: "5. Render Flame Graph"
    shape: rectangle
    style.fill: "#ecf0f1"
    desc_5: {
      label: "Width = Total segment time\nDepth = Logical call depth\nColor = Segment type"
      shape: text
      style.font-size: 11
    }
  }
  step_1 -> step_2 -> step_3 -> step_4 -> step_5
}
comparison: {
  label: "Traditional vs Async-Aware Flame Graph"
  traditional: {
    label: "Traditional\n(Single Color)"
    shape: rectangle
    style.fill: "#e74c3c"
    style.stroke: "#c0392b"
    width: 200
    height: 60
    note_t: {
      label: "Cannot distinguish\nCPU vs I/O wait"
      shape: text
      style.font-size: 10
      style.bold: true
    }
  }
  arrow: {
    label: "→"
    shape: text
    style.font-size: 24
  }
  async_aware: {
    label: "Async-Aware\n"
    shape: rectangle
    style.fill: "#e74c3c"
    style.stroke: "#c0392b"
    width: 200
    height: 60
    segment_1: {
      label: "CPU"
      shape: rectangle
      style.fill: "#e74c3c"
      width: 50
    }
    segment_2: {
      label: "await"
      shape: rectangle
      style.fill: "#3498db"
      width: 80
    }
    segment_3: {
      label: "CPU"
      shape: rectangle
      style.fill: "#e74c3c"
      width: 40
    }
    segment_4: {
      label: "await"
      shape: rectangle
      style.fill: "#3498db"
      width: 30
    }
    note_a: {
      label: "Clear visibility of\nasync bottlenecks"
      shape: text
      style.font-size: 10
      style.bold: true
    }
  }
  traditional -> arrow -> async_aware
}
legend -> flame_graph -> algorithm -> comparison