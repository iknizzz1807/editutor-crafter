direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Tokio Runtime Integration Points" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Legend
legend: {
  shape: rectangle
  style.fill: "#1a1a2e"
  style.stroke: "#4a4a6a"
  legend_title: "Legend" {
    shape: text
    style.font-size: 14
    style.bold: true
  }
  hook_point: "Hook Point" {
    shape: rectangle
    style.fill: "#7c3aed"
  }
  wrapper: "Wrapper/Interceptor" {
    shape: rectangle
    style.fill: "#2563eb"
  }
  context: "Thread-Local Context" {
    shape: cylinder
    style.fill: "#059669"
  }
  data_flow: "Data Flow" {
    shape: rectangle
    style.fill: "#6b7280"
  }
}

# Application Layer
user_app: "User Application" {
  shape: rectangle
  style.fill: "#1e293b"
  style.stroke: "#475569"
  spawn_call: "tokio::spawn(async_task)" {
    shape: text
    style.font-size: 12
  }
}

# Hook Layer
hooks: "Integration Hooks" {
  shape: rectangle
  style.fill: "#0f172a"
  style.stroke: "#334155"
  profiled_spawn: "profiled_spawn()" {
    shape: rectangle
    style.fill: "#7c3aed"
    style.stroke: "#a78bfa"
    tooltip: "Replaces tokio::spawn via macro"
  }
  profiled_spawn_ann: |md
  • Intercepts spawn calls
  • Wraps future with `ProfiledFuture`
  • Assigns unique `TaskId`
  | {
    shape: text
    style.font-size: 10
    style.italic: true
  }
  block_on_wrapper: "Runtime::block_on Wrapper" {
    shape: rectangle
    style.fill: "#7c3aed"
    style.stroke: "#a78bfa"
    tooltip: "Sets up profiling context for blocking entry"
  }
  block_on_ann: |md
  • Initialize profiler on entry
  • Flush data on exit
  • Handle main future context
  | {
    shape: text
    style.font-size: 10
    style.italic: true
  }
  thread_callback: "on_thread_start Callback" {
    shape: rectangle
    style.fill: "#7c3aed"
    style.stroke: "#a78bfa"
    tooltip: "Registered with tokio runtime builder"
  }
  thread_ann: |md
  • Track worker thread IDs
  • Initialize thread-local storage
  • Register with sampler
  | {
    shape: text
    style.font-size: 10
    style.italic: true
  }
}

# Wrapper Components
wrappers: "Future Instrumentation" {
  shape: rectangle
  style.fill: "#0f172a"
  style.stroke: "#334155"
  profiled_future: "ProfiledFuture[F]" {
    shape: rectangle
    style.fill: "#2563eb"
    style.stroke: "#60a5fa"
    poll_enter: "poll_enter()" {
      shape: rectangle
      style.fill: "#1d4ed8"
    }
    poll_exit: "poll_exit()" {
      shape: rectangle
      style.fill: "#1d4ed8"
    }
  }
  profiled_future -> profiled_future.poll_enter
  profiled_future -> profiled_future.poll_exit

  task_guard: "TaskContextGuard (RAII)" {
    shape: rectangle
    style.fill: "#2563eb"
    style.stroke: "#60a5fa"
    tooltip: "Manages CURRENT_TASK_ID lifecycle"
  }
}

# Thread-Local Storage
tls: "Thread-Local Storage" {
  shape: cylinder
  style.fill: "#0f172a"
  style.stroke: "#334155"
  current_task_id: "CURRENT_TASK_ID" {
    shape: cylinder
    style.fill: "#059669"
    style.stroke: "#34d399"
    tooltip: "Option[TaskId] - active task context"
  }
  in_poll: "IN_POLL_CONTEXT" {
    shape: cylinder
    style.fill: "#059669"
    style.stroke: "#34d399"
    tooltip: "bool - inside future poll"
  }
}

# Tracing Layer
tracing: "Tracing Integration" {
  shape: rectangle
  style.fill: "#0f172a"
  style.stroke: "#334155"
  tracing_layer: "TaskTracingLayer" {
    shape: rectangle
    style.fill: "#7c3aed"
    style.stroke: "#a78bfa"
  }
  tracing_ann: |md
  Implements `tracing::Layer`
  • on_new_span
  • on_enter
  • on_exit
  | {
    shape: text
    style.font-size: 10
    style.italic: true
  }
  span_events: "Span Events" {
    shape: rectangle
    style.fill: "#6b7280"
    span_created: "task_created" {
      shape: text
      style.font-size: 11
    }
    span_entered: "task_polled" {
      shape: text
      style.font-size: 11
    }
    span_exited: "task_awaiting" {
      shape: text
      style.font-size: 11
    }
    span_closed: "task_completed" {
      shape: text
      style.font-size: 11
    }
  }
}

# Profiler Core
profiler: "Profiler Core" {
  shape: rectangle
  style.fill: "#0f172a"
  style.stroke: "#334155"
  sampler: "SIGPROF Sampler" {
    shape: rectangle
    style.fill: "#dc2626"
    style.stroke: "#f87171"
  }
  task_tracker: "AsyncTaskTracker" {
    shape: rectangle
    style.fill: "#2563eb"
    style.stroke: "#60a5fa"
    task_map: "DashMap[TaskId, TaskInfo]" {
      shape: cylinder
      style.fill: "#1d4ed8"
    }
  }
  lifecycle: "AsyncTaskLifecycle" {
    shape: rectangle
    style.fill: "#2563eb"
    style.stroke: "#60a5fa"
    cpu_time: "cpu_time: Duration" {
      shape: text
      style.font-size: 10
    }
    await_time: "await_time: Duration" {
      shape: text
      style.font-size: 10
    }
    poll_count: "poll_count: u64" {
      shape: text
      style.font-size: 10
    }
  }
}

# Tokio Runtime
tokio_runtime: "Tokio Runtime" {
  shape: rectangle
  style.fill: "#1e293b"
  style.stroke: "#475569"
  worker_threads: "Worker Threads" {
    shape: rectangle
    style.fill: "#334155"
    worker_1: "Worker 0" {
      shape: text
      style.font-size: 11
    }
    worker_2: "Worker N" {
      shape: text
      style.font-size: 11
    }
  }
  task_queue: "Task Queue" {
    shape: queue
    style.fill: "#475569"
  }
}

# Connections
user_app -> hooks.profiled_spawn: "spawn call" {
  style.stroke: "#a78bfa"
  style.stroke-dash: 3
}
hooks.profiled_spawn -> wrappers.profiled_future: "wraps future" {
  style.stroke: "#60a5fa"
  label: "ProfiledFuture::new(fut, task_id)"
}
hooks.block_on_wrapper -> tls: "init context" {
  style.stroke: "#34d399"
}
hooks.thread_callback -> tokio_runtime: "registered via\nruntime.builder()" {
  style.stroke: "#a78bfa"
  style.stroke-dash: 3
}
wrappers.profiled_future -> wrappers.task_guard: "creates guard\non poll" {
  style.stroke: "#60a5fa"
}
wrappers.task_guard -> tls.current_task_id: "set/reset" {
  style.stroke: "#34d399"
  label: "RAII lifecycle"
}
wrappers.task_guard -> tls.in_poll: "true/false" {
  style.stroke: "#34d399"
}
profiler.sampler -> tls.current_task_id: "reads during\nsample" {
  style.stroke: "#dc2626"
  label: "SIGPROF"
}
profiler.sampler -> profiler.task_tracker: "records sample\nwith task_id" {
  style.stroke: "#dc2626"
}
tracing.tracing_layer -> profiler.task_tracker: "task events" {
  style.stroke: "#a78bfa"
}
profiler.task_tracker -> profiler.lifecycle: "updates" {
  style.stroke: "#60a5fa"
}
tokio_runtime -> hooks.thread_callback: "callback on\nthread start" {
  style.stroke: "#475569"
  style.stroke-dash: 3
}
wrappers.profiled_future -> tokio_runtime: "returns polled\nfuture" {
  style.stroke: "#475569"
}
tracing.span_events -> tracing.tracing_layer: "emits" {
  style.stroke: "#6b7280"
}

# Positioning
legend <- hooks
user_app -> hooks
hooks -> wrappers
wrappers -> tls
tls -> profiler
tokio_runtime -> hooks
tracing -> profiler