direction: down
title: ELF Binary Debug Sections {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Legend
legend: {
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#dee2e6"
  legend_title: {
    label: Legend
    shape: text
    style.font-size: 14
    style.bold: true
  }
  hdr_color: { label: "■ Header/Metadata"; shape: text }
  code_color: { label: "■ Code (.text)"; shape: text }
  data_color: { label: "■ Symbol Data"; shape: text }
  debug_color: { label: "■ DWARF Debug"; shape: text }
  link_color: { label: "■ Debug Link"; shape: text }
  hdr_color.style.font-color: "#6B21A8"
  code_color.style.font-color: "#059669"
  data_color.style.font-color: "#2563EB"
  debug_color.style.font-color: "#DC2626"
  link_color.style.font-color: "#D97706"
}
# ELF Header Section
elf_header: {
  label: "ELF Header (0x000 - 0x03F)"
  shape: rectangle
  style.fill: "#E9D5FF"
  style.stroke: "#6B21A8"
  style.stroke-width: 2
  e_ident: {
    label: "e_ident[16]\nMagic: 7F 45 4C 46\nClass: 64-bit\nEndian: Little"
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#6B21A8"
  }
  e_type: { label: "e_type: ET_EXEC/ET_DYN"; shape: rectangle; style.fill: "#F3E8FF"; style.stroke: "#6B21A8" }
  e_machine: { label: "e_machine: EM_X86_64"; shape: rectangle; style.fill: "#F3E8FF"; style.stroke: "#6B21A8" }
  e_phoff: { label: "e_phoff: 0x40"; shape: rectangle; style.fill: "#F3E8FF"; style.stroke: "#6B21A8" }
  e_shoff: { label: "e_shoff: 0xXXXX"; shape: rectangle; style.fill: "#F3E8FF"; style.stroke: "#6B21A8" }
  offset_note: {
    label: "Offset: 0x000\nSize: 64 bytes (0x40)"
    shape: text
    style.font-size: 10
    style.font-color: "#6B21A8"
  }
}
# Program Headers
program_headers: {
  label: "Program Headers (0x040 - 0x0XX)"
  shape: rectangle
  style.fill: "#E9D5FF"
  style.stroke: "#6B21A8"
  style.stroke-width: 2
  ph_entry: {
    label: "Phdr[0..n]\nPT_LOAD segments\nPT_DYNAMIC\nPT_NOTE"
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#6B21A8"
  }
  offset_note_ph: {
    label: "Offset: 0x040\nSize: 56 × n entries"
    shape: text
    style.font-size: 10
    style.font-color: "#6B21A8"
  }
}
# .note.gnu.build-id section
note_gnu_build_id: {
  label: ".note.gnu.build-id (0xXXX)"
  shape: rectangle
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.stroke-width: 2
  note_header: {
    label: "Note Header\nnamesz: 4 (GNU)\ndescsz: 20\ntype: NT_GNU_BUILD_ID"
    shape: rectangle
    style.fill: "#FFEDD5"
    style.stroke: "#D97706"
  }
  build_id: {
    label: "Build ID (SHA1/MD5)\n20 bytes unique identifier\nExample: abc123def456..."
    shape: rectangle
    style.fill: "#FED7AA"
    style.stroke: "#D97706"
  }
  offset_note_build: {
    label: "Offset: PT_NOTE segment\nSize: 36 bytes typical\nAlign: 4 bytes"
    shape: text
    style.font-size: 10
    style.font-color: "#D97706"
  }
}
# Page boundary marker
page_boundary_1: {
  label: "═══════════════════════════════════════ PAGE BOUNDARY (0x1000 / 4KB) ═══════════════════════════════════════"
  shape: rectangle
  style.fill: "#374151"
  style.stroke: "#1F2937"
  style.stroke-width: 3
  style.font-color: "#F9FAFB"
  style.bold: true
}
# .text section (code)
text_section: {
  label: ".text (Executable Code)"
  shape: rectangle
  style.fill: "#D1FAE5"
  style.stroke: "#059669"
  style.stroke-width: 2
  code_block: {
    label: "Machine Instructions\n(x86-64 opcodes)\n\n• Function prologues\n• Function bodies\n• Function epilogues\n• Jump tables"
    shape: rectangle
    style.fill: "#ECFDF5"
    style.stroke: "#059669"
  }
  cache_line_1: {
    label: "┄┄┄┄┄┄┄┄┄┄┄┄ Cache Line (64B) ┄┄┄┄┄┄┄┄┄┄┄┄"
    shape: text
    style.font-color: "#6B7280"
    style.stroke-dash: 4
  }
  hot_code: {
    label: "Hot Path Code\n(Frequently executed)"
    shape: rectangle
    style.fill: "#A7F3D0"
    style.stroke: "#059669"
  }
  offset_note_text: {
    label: "Offset: 0x1000 (page-aligned)\nSize: Variable (KB-MB)\nFlags: R-X (read + execute)"
    shape: text
    style.font-size: 10
    style.font-color: "#059669"
  }
}
# .dynsym section (Dynamic Symbol Table)
dynsym_section: {
  label: ".dynsym (Dynamic Symbol Table)"
  shape: rectangle
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  style.stroke-width: 2
  sym_entry_0: {
    label: "Sym[0] (STN_UNDEF)\nst_name: 0\nst_value: 0\nst_size: 0"
    shape: rectangle
    style.fill: "#EFF6FF"
    style.stroke: "#2563EB"
  }
  sym_entry_1: {
    label: "Sym[1] main\nst_name: offset\nst_value: 0xXXXX\nst_size: 0xXXX\nst_info: STT_FUNC|STB_GLOBAL"
    shape: rectangle
    style.fill: "#BFDBFE"
    style.stroke: "#2563EB"
  }
  sym_entry_n: {
    label: "Sym[n] exported_func\nst_name: offset\nst_value: 0xXXXX\nst_size: 0xXXX\nst_shndx: .text"
    shape: rectangle
    style.fill: "#BFDBFE"
    style.stroke: "#2563EB"
  }
  dynstr_ref: {
    label: "→ References .dynstr\n   for symbol names"
    shape: text
    style.font-size: 10
    style.font-color: "#2563EB"
  }
  offset_note_dynsym: {
    label: "Offset: 0xXXXX\nEntry Size: 24 bytes\nCount: n exported symbols"
    shape: text
    style.font-size: 10
    style.font-color: "#2563EB"
  }
}
# .symtab section (Full Symbol Table - stripped in prod)
symtab_section: {
  label: ".symtab (Symbol Table) ⚠️ STRIPPED IN PRODUCTION"
  shape: rectangle
  style.fill: "#E5E7EB"
  style.stroke: "#6B7280"
  style.stroke-width: 2
  style.stroke-dash: 4
  symtab_header: {
    label: "Full Symbol Table\n(Includes ALL symbols:\n static, local, debug)"
    shape: rectangle
    style.fill: "#F3F4F6"
    style.stroke: "#9CA3AF"
    style.stroke-dash: 4
  }
  local_syms: {
    label: "Local Symbols\nstatic_function\nfile_scope_var\n\n⚠️ Removed by:\nstrip --strip-all\nor -s linker flag"
    shape: rectangle
    style.fill: "#F9FAFB"
    style.stroke: "#9CA3AF"
    style.stroke-dash: 4
  }
  offset_note_symtab: {
    label: "Offset: 0xXXXX\nEntry Size: 24 bytes\n⚠️ 0 bytes if stripped"
    shape: text
    style.font-size: 10
    style.font-color: "#6B7280"
  }
}
# Page boundary for debug sections
page_boundary_2: {
  label: "═══════════════════════════════════════ DEBUG SECTIONS (often separate .debug file) ═══════════════════════════════════════"
  shape: rectangle
  style.fill: "#374151"
  style.stroke: "#1F2937"
  style.stroke-width: 3
  style.font-color: "#F9FAFB"
  style.bold: true
}
# .debug_info section (DWARF)
debug_info_section: {
  label: ".debug_info (DWARF Debug Information)"
  shape: rectangle
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.stroke-width: 2
  compilation_unit: {
    label: "Compilation Unit Header\nunit_length: 0xXXXX\nversion: DWARF-4/5\naddr_size: 8"
    shape: rectangle
    style.fill: "#FECACA"
    style.stroke: "#DC2626"
  }
  die_tree: {
    label: "DIE Tree (Debug Info Entries)\n\nDW_TAG_compile_unit\n├── DW_TAG_subprogram (main)\n│   ├── DW_TAG_formal_parameter\n│   └── DW_TAG_variable\n├── DW_TAG_subprogram (helper)\n└── DW_TAG_base_type (int)"
    shape: rectangle
    style.fill: "#FCA5A5"
    style.stroke: "#DC2626"
  }
  abbrev_ref: {
    label: "→ References .debug_abbrev\n   for abbreviation tables"
    shape: text
    style.font-size: 10
    style.font-color: "#DC2626"
  }
  offset_note_debug_info: {
    label: "Offset: 0xXXXX\nSize: KB-MB per CU\nFormat: DWARF 4/5"
    shape: text
    style.font-size: 10
    style.font-color: "#DC2626"
  }
}
# .debug_line section
debug_line_section: {
  label: ".debug_line (Line Number Table)"
  shape: rectangle
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.stroke-width: 2
  line_header: {
    label: "Line Program Header\nunit_length: 0xXXXX\nversion: DWARF-4/5\nmin_inst_length: 1\nline_base: -5\nline_range: 14"
    shape: rectangle
    style.fill: "#FECACA"
    style.stroke: "#DC2626"
  }
  file_table: {
    label: "File Name Table\n[0] \"main.c\"\n[1] \"/usr/include/stdio.h\"\n[2] \"helper.c\"\n..."
    shape: rectangle
    style.fill: "#FECACA"
    style.stroke: "#DC2626"
  }
  line_matrix: {
    label: "Line Number Matrix\n\naddr      line  col  file\n0x1000    10    0    main.c\n0x1015    11    0    main.c\n0x102A    15    0    main.c\n..."
    shape: rectangle
    style.fill: "#FCA5A5"
    style.stroke: "#DC2626"
  }
  offset_note_debug_line: {
    label: "Offset: 0xXXXX\nSize: Varies\nEnables: addr→source mapping"
    shape: text
    style.font-size: 10
    style.font-color: "#DC2626"
  }
}
# .gnu_debuglink section
gnu_debuglink_section: {
  label: ".gnu_debuglink (Separate Debug File)"
  shape: rectangle
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.stroke-width: 2
  debug_filename: {
    label: "Debug Filename\n\"executable.debug\" or\n\"executable\"\n(null-padded)"
    shape: rectangle
    style.fill: "#FFEDD5"
    style.stroke: "#D97706"
  }
  padding: {
    label: "Padding (to 4-byte align)"
    shape: rectangle
    style.fill: "#F3F4F6"
    style.stroke: "#9CA3AF"
  }
  crc32: {
    label: "CRC32 Checksum\n(4 bytes)\nValidates debug file"
    shape: rectangle
    style.fill: "#FED7AA"
    style.stroke: "#D97706"
  }
  offset_note_debuglink: {
    label: "Offset: 0xXXXX\nSize: 12-40 bytes\nLookup: /usr/lib/debug/.build-id/..."
    shape: text
    style.font-size: 10
    style.font-color: "#D97706"
  }
}
# Section Header Table
section_headers: {
  label: "Section Header Table (at e_shoff)"
  shape: rectangle
  style.fill: "#E9D5FF"
  style.stroke: "#6B21A8"
  style.stroke-width: 2
  sh_entry: {
    label: "Shdr[0..n]\nsh_name: section name\nsh_type: SHT_XXX\nsh_offset: file offset\nsh_size: section size\nsh_link: related section\nsh_info: extra info"
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#6B21A8"
  }
  shstrtab_ref: {
    label: "→ References .shstrtab\n   for section names"
    shape: text
    style.font-size: 10
    style.font-color: "#6B21A8"
  }
  offset_note_sh: {
    label: "Offset: e_shoff\nEntry Size: 64 bytes\nCount: e_shnum"
    shape: text
    style.font-size: 10
    style.font-color: "#6B21A8"
  }
}
# Connections showing relationships
elf_header -> program_headers: "e_phoff" { style.stroke: "#6B21A8"; style.stroke-dash: 3 }
elf_header -> section_headers: "e_shoff" { style.stroke: "#6B21A8"; style.stroke-dash: 3 }
program_headers -> note_gnu_build_id: "PT_NOTE" { style.stroke: "#D97706"; style.stroke-dash: 3 }
program_headers -> text_section: "PT_LOAD" { style.stroke: "#059669"; style.stroke-dash: 3 }
dynsym_section -> debug_info_section: "symbol resolution" { style.stroke: "#6B7280"; style.stroke-dash: 5 }
debug_info_section -> debug_line_section: "line info ref" { style.stroke: "#DC2626"; style.stroke-dash: 3 }
# Size summary
size_summary: {
  label: "TOTAL FILE SIZE: Variable (typically 10KB - 100MB+)\n\nMinimal (stripped): ~Header + .text + .dynsym + .shstrtab\nWith Debug Info: + .debug_info + .debug_line + .debug_abbrev + .debug_str\nSeparate Debug: .gnu_debuglink points to external .debug file"
  shape: rectangle
  style.fill: "#F9FAFB"
  style.stroke: "#374151"
  style.stroke-width: 2
  style.font-size: 11
}
# Cache line markers
cache_line_legend: {
  label: "┄┄┄ Cache Line Boundary (64 bytes) ┄┄┄"
  shape: text
  style.font-color: "#6B7280"
  style.stroke-dash: 4
}
# Debug file lookup flow
debug_lookup_flow: {
  label: "Debug File Lookup Order:\n1. .gnu_debuglink → /usr/lib/debug/<path>\n2. .note.gnu.build-id → /usr/lib/debug/.build-id/ab/cdef.../debug\n3. Embedded .debug_* sections"
  shape: rectangle
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.stroke-width: 1
  style.font-size: 10
}