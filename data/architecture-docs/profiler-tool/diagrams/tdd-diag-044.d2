direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

classes: {
  active_step: {
    style: {
      fill: "#ffcccc"
      bold: true
      stroke-width: 3
    }
  }
  data_transform: {
    style: {
      fill: "#ccffcc"
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#fff4cc"
    }
  }
  error_path: {
    style: {
      fill: "#ffaaaa"
    }
  }
}

title: "Symbol Resolution Pipeline" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Container renamed from 'steps' to 'pipeline_flow' to avoid D2 reserved keyword conflict with composition boards
resolution_process: {
  step1_input: "INPUT\n───\naddress: 0x7f12345678" {
    shape: rectangle
    style.fill: "#e8f4f8"
  }
  step1: "1. Find Containing Module" {
    shape: rectangle
    class: active_step
  }
  step1_check: "FOR each module m:\n  IF addr >= m.start\n  AND addr < m.end" {
    shape: diamond
    style.fill: "#fff4cc"
  }
  step1_module: "module = m\nBREAK" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
  step1_notfound: "module = None\n→ RETURN None" {
    shape: rectangle
    style.fill: "#ffaaaa"
  }
  step2: "2. Calculate Offset" {
    shape: rectangle
    class: active_step
  }
  step2_calc: "offset = addr - module.start\n         + module.file_offset" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
  step3: "3. Binary Search .symtab" {
    shape: rectangle
    class: active_step
  }
  step3_search: "idx = partition_point(\n  symbols, |s| s.addr <= offset)" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
  step3_check: "Found in\n.symtab?" {
    shape: diamond
    style.fill: "#fff4cc"
  }
  step4: "4. Try .dynsym" {
    shape: rectangle
    class: active_step
  }
  step4_search: "Binary search\n.dynsym section" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
  step4_check: "Found in\n.dynsym?" {
    shape: diamond
    style.fill: "#fff4cc"
  }
  step5: "5. DWARF Lookup" {
    shape: rectangle
    class: active_step
  }
  step5_check: "Debug file\nexists?" {
    shape: diamond
    style.fill: "#fff4cc"
  }
  step5_dwarf: "Query DWARF for:\n• source file\n• line number" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
  step6: "6. Cache Result" {
    shape: rectangle
    class: active_step
  }
  step6_cache: "cache.insert(addr, info)" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
  step7: "7. Return SymbolInfo" {
    shape: rectangle
    class: active_step
  }
  step7_output: "OUTPUT\n───\nSymbolInfo {\n  name: \"main\"\n  address: 0x7f...\n  size: 256\n  file: \"main.c\"\n  line: 42\n}" {
    shape: rectangle
    style.fill: "#ccffcc"
  }

  step1_input -> step1: "resolve(addr)"
  step1 -> step1_check
  step1_check -> step1_module: "YES"
  step1_module -> step2
  step1_check -> step1_notfound: "NO (loop)"
  step1_notfound -> step1_check: "next m"
  step1_check -> step1_notfound: "NO (exhausted)"
  step2 -> step2_calc
  step2_calc -> step3
  step3 -> step3_search
  step3_search -> step3_check
  step3_check -> step4: "NO (miss)"
  step4 -> step4_search
  step4_search -> step4_check
  step4_check -> step1_notfound: "NO"
  step4_check -> step5_check: "YES"
  step3_check -> step5_check: "YES"
  step5_check -> step5_dwarf: "YES"
  step5_dwarf -> step6
  step5_check -> step6: "NO (skip DWARF)"
  step6 -> step6_cache
  step6_cache -> step7
  step7 -> step7_output
}

data_structures: {
  label: "Key Data Structures"
  module_entry: {
    shape: class
    label: "ModuleEntry"
    start_address: usize
    end_address: usize
    file_offset: usize
    symbols: "Vec<SymbolInfo>"
    dynsyms: "Vec<SymbolInfo>"
    debug_file: "Option<PathBuf>"
    style.multiple: true
  }
  symbol_info: {
    shape: class
    label: "SymbolInfo"
    name: String
    address: usize
    size: usize
    source_file: "Option<String>"
    line_number: "Option<u32>"
    style.multiple: true
  }
  cache_struct: {
    shape: class
    label: "Resolver"
    modules: "Vec<ModuleEntry>"
    cache: "HashMap<usize, SymbolInfo>"
    style.multiple: true
  }
}

legend: {
  label: "Legend"
  near: bottom-right
  active_step_leg: "Active Step\n(red, bold)" {
    shape: rectangle
    style: {
      fill: "#ffcccc"
      bold: true
      stroke-width: 3
    }
  }
  data_transform_leg: "Data Transform\n(green)" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
  decision_leg: "Decision Point\n(yellow)" {
    shape: diamond
    style.fill: "#fff4cc"
  }
  error_path_leg: "Error/Not Found\n(red)" {
    shape: rectangle
    style.fill: "#ffaaaa"
  }
}

# Apply classes to visually highlight state
resolution_process.step1_input.class: active_step
resolution_process.step1.class: active_step
resolution_process.step2.class: active_step
resolution_process.step3.class: active_step
resolution_process.step4.class: active_step
resolution_process.step5.class: active_step
resolution_process.step6.class: active_step
resolution_process.step7.class: active_step