direction: right
layout-engine: elk
classes: {
  process: {
    shape: hexagon
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
  decision: {
    shape: diamond
    style.fill: "#FFF3E0"
    style.stroke: "#EF6C00"
  }
  file: {
    shape: stored_data
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
  path: {
    shape: page
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  terminal: {
    shape: oval
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
  success: {
    shape: oval
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }
}
title: {
  label: "Separate Debug File Lookup\nFallback Chain"
  shape: text
  style.underline: true
  style.font-size: 24
}
# Input
binary_input: {
  label: "ELF Binary"
  class: file
}
binary_info: {
  label: "Extract\n.debuglink &\nBuild-ID"
  class: process
}
# Main Decision
main_branch: {
  label: "Lookup\nStrategy"
  class: decision
}
# === GNU_DEBUGLINK Path ===
debuglink_section: {
  label: ".gnu_debuglink\nSection Found?"
  class: decision
}
debuglink_name: {
  label: "Extract Debug\nFilename"
  class: process
}
# DebugLink Search Paths
debuglink_search: {
  label: "DebugLink Search Paths"
  shape: rectangle
  style.stroke-dash: 3
  dl_path1: {
    label: "1. <binary_dir>/.debug/<name>"
    class: path
  }
  dl_path2: {
    label: "2. <binary_dir>/../.debug/<name>"
    class: path
  }
  dl_path3: {
    label: "3. /usr/lib/debug/<path>/<name>"
    class: path
  }
  dl_path4: {
    label: "4. /usr/lib/debug/.build-id/<id>.debug"
    class: path
  }
  dl_path1 -> dl_path2: "not found"
  dl_path2 -> dl_path3: "not found"
  dl_path3 -> dl_path4: "not found"
}
dl_check1: {
  label: "File\nExists?"
  class: decision
}
# === Build-ID Path ===
buildid_section: {
  label: ".note.gnu.build-id\nSection Found?"
  class: decision
}
buildid_parse: {
  label: "Parse Build-ID\n(ab/cdef...)"
  class: process
}
# Build-ID Search Paths
buildid_search: {
  label: "Build-ID Search Paths"
  shape: rectangle
  style.stroke-dash: 3
  bi_path1: {
    label: "1. /usr/lib/debug/.build-id/<ab>/<cdef>.debug"
    class: path
  }
  bi_path2: {
    label: "2. /lib/debug/.build-id/<ab>/<cdef>.debug"
    class: path
  }
  bi_path3: {
    label: "3. <binary_dir>/.build-id/<ab>/<cdef>.debug"
    class: path
  }
  bi_path1 -> bi_path2: "not found"
  bi_path2 -> bi_path3: "not found"
}
bi_check1: {
  label: "File\nExists?"
  class: decision
}
# Outcomes
debug_found: {
  label: "Debug File\nLoaded"
  class: success
}
debug_not_found: {
  label: "No Separate\nDebug Info"
  class: terminal
}
use_embedded: {
  label: "Use Embedded\nSymbols Only"
  class: process
}
# Connections
binary_input -> binary_info
binary_info -> main_branch
main_branch -> debuglink_section: "try first"
main_branch -> buildid_section: "fallback"
# DebugLink flow
debuglink_section -> debuglink_name: "yes"
debuglink_section -> buildid_section: "no"
debuglink_name -> dl_path1
dl_path1 -> dl_check1
dl_check1 -> debug_found: "yes"
dl_check1 -> dl_path2: "no"
dl_path4 -> debug_not_found: "all failed"
# Build-ID flow
buildid_section -> buildid_parse: "yes"
buildid_section -> debug_not_found: "no"
buildid_parse -> bi_path1
bi_path1 -> bi_check1
bi_check1 -> debug_found: "yes"
bi_check1 -> bi_path2: "no"
bi_path3 -> debug_not_found: "all failed"
# Final fallback
debug_not_found -> use_embedded
# Example path annotation
example: {
  label: "Example Build-ID Path:\n.build-id/ab/cdef1234567890.debug\n└─┬─┘ └──────┬──────┘\n 2hex    remainder"
  shape: text
  style.font-size: 11
  style.italic: true
}