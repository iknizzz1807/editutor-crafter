direction: right
layout-engine: elk
theme-id: 4
title: {
  label: "Profile Merge Algorithm"
  shape: text
  near: top-center
}
step1: {
  label: "1"
  shape: circle
  style: {
    fill: "#7C3AED"
    font-color: white
    stroke: "#5B21B6"
  }
}
load_p1: {
  label: "Load Profile 1"
  shape: rectangle
  style: {
    fill: "#3B82F6"
    font-color: white
    stroke: "#1D4ED8"
  }
}
collapsed1: {
  label: "CollapsedStacks\n{\n  \"main;foo;bar\": 150\n  \"main;baz\": 80\n  \"main;foo\": 45\n}"
  shape: code
  language: json
  style: {
    fill: "#1E293B"
    font-color: "#E2E8F0"
    stroke: "#475569"
  }
}
step2: {
  label: "2"
  shape: circle
  style: {
    fill: "#7C3AED"
    font-color: white
    stroke: "#5B21B6"
  }
}
load_p2: {
  label: "Load Profile 2"
  shape: rectangle
  style: {
    fill: "#3B82F6"
    font-color: white
    stroke: "#1D4ED8"
  }
}
collapsed2: {
  label: "CollapsedStacks\n{\n  \"main;foo;bar\": 75\n  \"main;qux\": 60\n  \"main;foo\": 30\n}"
  shape: code
  language: json
  style: {
    fill: "#1E293B"
    font-color: "#E2E8F0"
    stroke: "#475569"
  }
}
step3: {
  label: "3"
  shape: circle
  style: {
    fill: "#7C3AED"
    font-color: white
    stroke: "#5B21B6"
  }
}
merge: {
  label: "Merge HashMaps\n(Add Counts)"
  shape: hexagon
  style: {
    fill: "#F59E0B"
    font-color: white
    stroke: "#D97706"
  }
}
hashmap: {
  label: "HashMap<String, u64>\n┌─────────────────┬───────┐\n│ main;foo;bar    │ 225   │\n│ main;baz        │ 80    │\n│ main;qux        │ 60    │\n│ main;foo        │ 75    │\n└─────────────────┴───────┘"
  shape: code
  style: {
    fill: "#1E293B"
    font-color: "#E2E8F0"
    stroke: "#475569"
  }
}
step4: {
  label: "4"
  shape: circle
  style: {
    fill: "#7C3AED"
    font-color: white
    stroke: "#5B21B6"
  }
}
calc: {
  label: "Recalculate Total\nsum = 225+80+60+75 = 440"
  shape: rectangle
  style: {
    fill: "#10B981"
    font-color: white
    stroke: "#059669"
  }
}
step5: {
  label: "5"
  shape: circle
  style: {
    fill: "#7C3AED"
    font-color: white
    stroke: "#5B21B6"
  }
}
output: {
  label: "Output Merged\nCollapsedStacks"
  shape: rectangle
  style: {
    fill: "#10B981"
    font-color: white
    stroke: "#059669"
  }
}
result: {
  label: "CollapsedStacks\n{\n  \"main;foo;bar\": 225\n  \"main;baz\": 80\n  \"main;qux\": 60\n  \"main;foo\": 75\n}\nTotal Samples: 440"
  shape: code
  language: json
  style: {
    fill: "#064E3B"
    font-color: "#D1FAE5"
    stroke: "#059669"
  }
}
step1 -> load_p1 -> collapsed1 -> step3
step2 -> load_p2 -> collapsed2 -> step3
step3 -> merge -> hashmap -> step4
step4 -> calc -> step5 -> output -> result