direction: right
layout-engine: elk
theme: 4
title: {
  label: "HTTP Endpoint Routing\nprofiler-m5"
  shape: text
  near: top-center
}
http_client: {
  label: "HTTP Client"
  shape: hexagon
  style.font-color: "#1a5fb4"
}
warp_router: {
  label: "Warp Router\nprofiling_routes()"
  shape: diamond
  style.font-color: "#613583"
}
state: {
  label: "ContinuousProfilerState"
  shape: cylinder
  style.stroke-dash: 3
  style.font-color: "#865e3c"
}
http_client -> warp_router: "GET /debug/*" {
  style.stroke-width: 2
}
warp_router -> state: "read\nstate" {
  style.stroke-dash: 3
  style.stroke-width: 1
}
pprof_endpoint: {
  label: "/debug/pprof/profile"
  shape: queue
  style.fill: "#f6d32d"
}
flamegraph_endpoint: {
  label: "/debug/flamegraph"
  shape: queue
  style.fill: "#ff7800"
}
collapsed_endpoint: {
  label: "/debug/collapsed"
  shape: queue
  style.fill: "#2ec27e"
}
json_endpoint: {
  label: "/debug/profile/json"
  shape: queue
  style.fill: "#3584e4"
}
warp_router -> pprof_endpoint: {
  style.stroke-width: 2
  label: "path!"
}
warp_router -> flamegraph_endpoint: {
  style.stroke-width: 2
  label: "path!"
}
warp_router -> collapsed_endpoint: {
  style.stroke-width: 2
  label: "path!"
}
warp_router -> json_endpoint: {
  style.stroke-width: 2
  label: "path!"
}
pprof_bytes: {
  label: "pprof\nbytes"
  shape: oval
  style.fill: "#f9f06d"
}
svg_output: {
  label: "SVG"
  shape: oval
  style.fill: "#ffbe6f"
}
text_output: {
  label: "text\n(collapsed)"
  shape: oval
  style.fill: "#8ff0a4"
}
json_output: {
  label: "JSON\n(speedscope)"
  shape: oval
  style.fill: "#99c1f1"
}
pprof_endpoint -> pprof_bytes: "application/octet-stream"
flamegraph_endpoint -> svg_output: "image/svg+xml"
collapsed_endpoint -> text_output: "text/plain"
json_endpoint -> json_output: "application/json"
pprof_endpoint -> state: "access" {
  style.stroke-dash: 3
  style.stroke: "#c0bfbc"
}
flamegraph_endpoint -> state: "access" {
  style.stroke-dash: 3
  style.stroke: "#c0bfbc"
}
collapsed_endpoint -> state: "access" {
  style.stroke-dash: 3
  style.stroke: "#c0bfbc"
}
json_endpoint -> state: "access" {
  style.stroke-dash: 3
  style.stroke: "#c0bfbc"
}
legend: {
  label: "Legend\n─── owns\n- - - references"
  shape: text
  near: bottom-right
}