layout-engine: elk
theme-id: 4
title: "Complete Profiler Architecture Overview"
direction: right
UserSpace: "User Space" {
  style.fill: "#E8F4FF"
  style.stroke: "#4A90D2"
  CLI: "CLI Tool" {
    shape: rectangle
    style.fill: "#B8D4E0"
  }
  App: "Application\n(with profiler)" {
    shape: rectangle
    style.fill: "#D4E8F4"
  }
  ProfilerLib: "Profiler Library" {
    shape: rectangle
    style.fill: "#4CAF50"
  }
}
Kernel_: "Kernel" {
  style.fill: "#F9F9F9"
  style.stroke: "#666"
  Timer: "Timer\n(setitimer)" {
    shape: rectangle
  }
  Signal: "Signal\nDelivery" {
    shape: rectangle
  }
}
CLI -> App: "profile/record"
App -> ProfilerLib: "links"
ProfilerLib -> Timer: "configures"
Timer -> Signal: "triggers"
Signal -> ProfilerLib: "SIGPROF"
OutputFormats: "Output Formats" {
  style.fill: "#FCE4C6"
  Collapsed: ".collapsed"
  Pprof: ".pb"
  JSON: ".json"
  SVG: ".svg"
}
ProfilerLib -> OutputFormats: "exports"