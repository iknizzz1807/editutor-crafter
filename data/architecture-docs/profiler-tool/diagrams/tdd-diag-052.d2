layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
  }
}

title: {
  label: "Profiler System Overview: Differential Flame Graph Generation"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

legend: {
  near: top-right
  Core: "Core Component" {
    style.fill: "#E3F2FD"
  }
  Data: "Data Structure" {
    shape: cylinder
    style.fill: "#FFF3E0"
  }
  External: "External Interface" {
    shape: hexagon
    style.fill: "#E8F5E9"
  }
}

user_process: {
  label: "Target Process (PID: 8421)"
  style.fill: "#E3F2FD"
  
  threads: {
    label: "Thread Pool"
    main_thread: "main() [TID: 8421]" {
      style.fill: "#BBDEFB"
    }
    worker_1: "worker() [TID: 8422]" {
      style.fill: "#BBDEFB"
    }
  }

  call_stack: {
    label: "Register & Stack State"
    shape: sql_table
    RIP: "0x7f3a2c1048c3" {constraint: "Instruction Pointer"}
    RSP: "0x7ffd4e8a1dc8" {constraint: "Stack Pointer"}
    frame_0: "main+0x42" {style.fill: "#FFCDD2"}
    frame_1: "process_data+0x1a" {style.fill: "#FFCDD2"}
    frame_2: "compute_hash+0x8" {style.fill: "#FFCDD2"}
  }
}

profiler_core: {
  label: "Profiler Engine"
  style.fill: "#EDE7F6"
  
  sampler: {
    label: "Sampling & Unwinding"
    config: "99 Hz / SIGPROF" {
      style.fill: "#E8F5E9"
    }
    timer: "Timer Handler" {
      style.fill: "#BBDEFB"
    }
    unwinder: "Stack Unwinder" {
      style.fill: "#BBDEFB"
    }
  }
  
  symbolizer: {
    label: "Symbol Resolution"
    dwarf: "DWARF Parser"
    cache: "Addr->Sym Cache" {
      shape: cylinder
      style.fill: "#FFF3E0"
    }
  }
  
  aggregator: {
    label: "Sample Aggregator"
    hash_map: "Stack Hash -> Count" {
      shape: cylinder
      style.fill: "#FFF3E0"
    }
  }
}

shared_memory: {
  label: "Shared Memory Ring Buffer"
  shape: cylinder
  style.fill: "#FFF3E0"
  
  header: {
    shape: sql_table
    style.fill: "#9575CD" # Purple Header
    magic: "0x50524f46" {constraint: "4B"}
    version: "1" {constraint: "1B"}
    head: "142" {constraint: "4B"}
    tail: "138" {constraint: "4B"}
  }
}

output: {
  flamegraph: "Flame Graph (SVG)" { shape: hexagon; style.fill: "#E8F5E9" }
  pprof: "pprof (proto)" { shape: hexagon; style.fill: "#E8F5E9" }
}

# --- Connections ---

user_process.threads -> profiler_core.sampler: "ptrace(PTRACE_ATTACH)" {
  style.stroke-dash: 3
  label.near: top-center
}

user_process.call_stack -> profiler_core.sampler.unwinder: "VMA Scan / Stack Walk" {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}

profiler_core.sampler -> shared_memory: "Enqueue sample_t" {
  style.stroke: "#388E3C"
  style.stroke-width: 2
}

shared_memory -> profiler_core.aggregator: "Consume Samples" {
  style.stroke: "#388E3C"
}

profiler_core.aggregator -> profiler_core.symbolizer: "Resolve PC" {
  style.stroke: "#1976D2"
}

profiler_core.aggregator -> output.flamegraph: "Generate"
profiler_core.aggregator -> output.pprof: "Export"

# --- Detailed Memory Layout ---

sample_t_layout: {
  label: "sample_t Memory Layout (128 bytes)"
  shape: sql_table
  style.fill: "#9575CD" # Purple Header
  
  "0x00": "timestamp (u64)" {constraint: "8B"; style.fill: "#64B5F6"}
  "0x08": "tid (u32)" {constraint: "4B"; style.fill: "#64B5F6"}
  "0x0C": "cpu (u16)" {constraint: "2B"; style.fill: "#64B5F6"}
  "0x0E": "flags (u16)" {constraint: "2B"; style.fill: "#64B5F6"}
  "0x10": "pc (u64)" {constraint: "8B"; style.fill: "#64B5F6"}
  "0x18": "depth (u8)" {constraint: "1B"; style.fill: "#64B5F6"}
  "0x19": "padding" {constraint: "7B"; style.fill: "#BDBDBD"}
  "0x20": "frames (u64[12])" {constraint: "96B"; style.fill: "#64B5F6"}
}

profiler_core.sampler -> sample_t_layout: {
  style.opacity: 0.2
  style.stroke-dash: 5
}