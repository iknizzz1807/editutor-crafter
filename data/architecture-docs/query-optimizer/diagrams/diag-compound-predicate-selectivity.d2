direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Compound Predicate Selectivity
  ## The Independence Assumption
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  theory: {
    direction: down
    label: "Theory: Independence Assumption"
    formula_box: {
      label: ""
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      style.border-radius: 8
      formula: |md
        **P(A AND B) = P(A) × P(B)**
        Assumes events A and B are statistically independent
      | {shape: text}
    }
    and_example: {
      label: "AND: Multiply Selectivities"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.border-radius: 8
      and_calc: |md
        `WHERE age > 30 AND income > 100K`
        - P(age > 30) = 0.50
        - P(income > 100K) = 0.10
        - **Estimated: 0.50 × 0.10 = 0.05**
        - **Estimated rows: 5% of table**
      | {shape: text}
    }
    or_example: {
      label: "OR: Inclusion-Exclusion"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.border-radius: 8
      or_calc: |md
        `WHERE status = 'active' OR status = 'pending'`
        - P(A) = 0.30, P(B) = 0.20
        - **P(A OR B) = P(A) + P(B) - P(A)×P(B)**
        - = 0.30 + 0.20 - 0.06 = **0.44**
        - **Estimated rows: 44% of table**
      | {shape: text}
    }
  }
  venn: {
    direction: down
    label: "Venn Diagram Interpretation"
    venn_canvas: {
      label: ""
      style.fill: "#FAFAFA"
      style.stroke: "#E0E0E0"
      circle_a: {
        shape: circle
        label: "A"
        style.fill: "#BBDEFB"
        style.stroke: "#1976D2"
        style.opacity: 0.6
        width: 120
      }
      circle_b: {
        shape: circle
        label: "B"
        style.fill: "#C8E6C9"
        style.stroke: "#388E3C"
        style.opacity: 0.6
        width: 120
      }
      intersection_label: {
        label: "A ∩ B"
        shape: text
        style.font-size: 14
        style.bold: true
      }
    }
    venn_legend: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      leg1: "Circle A = Rows matching predicate A" {shape: text}
      leg2: "Circle B = Rows matching predicate B" {shape: text}
      leg3: "Overlap = Rows matching BOTH" {shape: text}
      leg4: "|md Independence = overlap area equals `P(A) × P(B)` |\n|md Correlation = overlap differs from expected |" {shape: text}
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  breakdown: {
    direction: down
    label: "⚠️ Where It Breaks Down"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.border-radius: 8
    problem: {
      label: "Correlated Columns Violate Independence"
      style.fill: "#FFCDD2"
      style.border-radius: 4
      corr_example: |md
        **Query:** `WHERE age > 30 AND income > 100K`
        **Independence assumes:** Age and income unrelated
        **Reality:** Income correlates with age!
        - Older people tend to earn more
        - Overlap is LARGER than expected
      | {shape: text}
    }
    comparison: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      est_col: {
        label: "Estimated"
        style.fill: "#E3F2FD"
        style.border-radius: 4
        est_val: |md
          **5% selectivity**
          (0.50 × 0.10)
          ~5,000 rows
          (from 100,000)
        | {shape: text}
      }
      actual_col: {
        label: "Actual"
        style.fill: "#E8F5E9"
        style.border-radius: 4
        act_val: |md
          **15% selectivity**
          (correlation)
          ~15,000 rows
          (from 100,000)
        | {shape: text}
      }
      est_col -> actual_col: "3x Error!" {
        style.stroke: "#F44336"
        style.stroke-width: 3
        style.bold: true
      }
    }
    cascade: {
      label: "Error Cascades Through Plan"
      style.fill: "#FFCDD2"
      style.border-radius: 4
      cascade_text: |md
        1. **Wrong cardinality estimate** → 5K vs 15K rows
        2. **Wrong operator choice** → HashJoin spills to disk
        3. **Wrong memory allocation** → Too small buffer
        4. **Query 10x slower** → User unhappy
      | {shape: text}
    }
  }
  mitigation: {
    direction: down
    label: "Mitigation Strategies"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.border-radius: 8
    strat1: {
      label: "1. Multi-Column Statistics"
      style.fill: "#C8E6C9"
      style.border-radius: 4
      s1_text: |md
        PostgreSQL: `CREATE STATISTICS s (ndistinct) ON age, income FROM users;`
        Captures correlation between columns
      | {shape: text}
    }
    strat2: {
      label: "2. Query Feedback"
      style.fill: "#C8E6C9"
      style.border-radius: 4
      s2_text: |md
        Track actual vs estimated cardinality
        Adjust statistics or use hints for repeat queries
      | {shape: text}
    }
    strat3: {
      label: "3. Conservative Estimates"
      style.fill: "#C8E6C9"
      style.border-radius: 4
      s3_text: |md
        Use `sqrt(P(A) × P(B))` for AND instead of `P(A) × P(B)`
        Assumes some positive correlation (safer default)
      | {shape: text}
    }
    strat4: {
      label: "4. Adaptive Execution"
      style.fill: "#C8E6C9"
      style.border-radius: 4
      s4_text: |md
        If actual rows >> estimated mid-query:
        - Switch to different join algorithm
        - Spill gracefully to disk
      | {shape: text}
    }
  }
}
theory.and_example -> venn.venn_canvas: "visualized as" {
  style.stroke-dash: 3
  style.stroke: "#9E9E9E"
}
venn.venv_canvas -> breakdown.problem: "violated by" {
  style.stroke: "#F44336"
  style.stroke-dash: 3
}
breakdown.mitigation_link: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
}
breakdown.cascade -> mitigation.strat1: "solved by" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  label: "Key Insight"
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
  style.border-radius: 8
  legend_text: |md
    **The independence assumption is the optimizer's biggest source of errors.**
    It's a pragmatic tradeoff: collecting correlation statistics for every column pair 
    would make ANALYZE too expensive. Production databases collect limited multi-column 
    stats and accept estimation errors on correlated predicates.
  | {shape: text}
}